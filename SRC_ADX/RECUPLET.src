#<AdxTL>@(#)3.0.0.0 $Revision$
Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","RECUPLET","UTIRECLET",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE 
Endcase
Return

$OUVRE 
If clalev([F:HAE])=0 : Local File GACCENTRY     [HAE] : Endif 
If clalev([F:DAE])=0 : Local File GACCENTRYD    [DAE] : Endif 
If clalev([F:DAE7])=0: Local File GACCENTRYD    [DAE7]: Endif 
If clalev([F:DAE8])=0: Local File GACCENTRYD    [DAE8]: Endif 
If clalev([F:DAE9])=0: Local File GACCENTRYD    [DAE9]: Endif 
If clalev([F:DUD])=0 : Local File GACCDUDATE    [DUD] : Endif
If clalev([F:MTC])=0 : Local File MATCHCODE     [MTC] : Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR    [FIY] : Endif 
If clalev([F:PER])=0 : Local File PERIOD        [PER] : Endif 
If clalev([F:FCY])=0 : Local File FACILITY      [FCY] : Endif 
If clalev([F:CPY])=0 : Local File COMPANY       [CPY] : Endif
If clalev([F:GCM])=0 : Local File GACM          [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED          [LED] : Endif 
If clalev([F:GAC])=0 : Local File GACCOUNT      [GAC] : Endif 
If clalev([F:BPR])=0 : Local File BPARTNER      [BPR] : Endif 
If clalev([F:TCU])=0 : Local File TABCUR        [TCU] : Endif 
Return

$INIT
Gosub OUVRE
TMP = 1
Return 

$INIT_DIA
Return

$EXEC
Local Integer ANOM
Call RECUPLET([M:DIA]LEDTYP,[M:DIA]COA,[M:DIA]NBSOC,[M:DIA]SOC,[M:DIA]SITE,[M:DIA]RECUP,[M:DIA]COMPTE,GSERVEUR,0,ANOM)
TRA = 1
Return

Subprog RECUPLET(REFERENTIEL,PLAN,NBSOC,SOC,SITE,RECUP,COMPTE,BATCH,DIRECT,ANOM)
Value    Integer REFERENTIEL
Value    Char    PLAN
Value    Integer NBSOC
Value    Char    SOC()(1..)
Value    Char    SITE
Value    Integer RECUP
Value    Char    COMPTE
Value    Integer BATCH
Value    Integer DIRECT    : # Paramètres de récup non saisis 
Variable Integer ANOM      : # Nbre d'anomalies

Gosub OUVRE 

Local Integer CPTMAX , TEST , STOP , OK , NBCPT , FLDEV , ARRET
Local Char    FILECT(250) , ACCCUR(GLONGAC) , BPRCUR(GLONBPR)
Local Decimal DEB_CUR , CRE_CUR , DEB_SOC , CRE_SOC , DEB_RPT , CRE_RPT
Local Char    DEVISE(GLONCUR)
Local Integer MAXECT
Local Mask    LETTRAGE [LTR]
MAXECT = max(1000,dim([M:LTR]NUM))
Close Local Mask [LTR]
Default Mask [DIA]

Local Integer NBECR , TBECR(1..MAXECT)
Local Integer NBECH , TBECH(1..MAXECT) , TBLIG(1..MAXECT)
Local Decimal TBIPT(1..MAXECT)
Local Integer NBMTC
Local Date    TBDAT(1..100)
Local Integer STA , CAS, COK
Local Char    PCETYP(GLONGTE)(1..5) , PCENUM(GLONVCR)(1..5) , MESSAGE(80)
Local Integer NBREC
Local Integer OKDAT
Local Date    DATMIN, DATMAX, DATMIN1, DATMAX1
Local Integer EQ1 , EQ2


######################################################
## Paramètres d'optimisation des boucles
## pour éviter le vieux snapshot too old
######################################################
CPTMAX = 20

######################### Trace détaillée si TEST=1
TEST  = 0

If !(BATCH | DIRECT)
 If RECUP=2
  Call OUVRE_TRACE(mess(116,116,1)) From LECFIC
 # Récupération lettrage
 Else
  Call OUVRE_TRACE(mess(115,116,1)) From LECFIC
 # Vérification lettrage
 Endif 
Endif

If RECUP=2
 Call ECR_TRACE(mess(116,116,1),0) From GESECRAN
Else
 Call ECR_TRACE(mess(115,116,1),0) From GESECRAN
Endif
If COMPTE<>""
 Call ECR_TRACE(mess(56,116,1)-COMPTE,0) From GESECRAN
# Compte
Endif

For ISOC=1 To NBSOC
 SOCIETE = SOC(ISOC)
 OK = 1
 If RECUP=2 & !TEST & !DIRECT
  Call MONOCPY(SOCIETE, OK) From AX3MONO # <JFL>
 Endif
 If OK
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call ECR_TRACE(mess(2,116,1)-SOCIETE,0) From GESECRAN
  # Société
  Read [CPY]CPY0 = SOCIETE
  Gosub RECUP
 Endif
 If RECUP=2 & !TEST & !DIRECT
  Call MULTICPY(SOCIETE) From AX3MONO # <JFL>
 Endif
Next ISOC
If NBSOC=0
 Read [FCY]FCY0 = SITE
 SOCIETE = [F:FCY]LEGCPY
 Read [CPY]CPY0 = SOCIETE
 Gosub RECUP
Endif

$FIN
If !(BATCH | DIRECT)
 Call FERME_TRACE From LECFIC 
Endif

End
 
$RECUP
NBREC = 0
Gosub RECSOC
Return

$RECSOC
If NBSOC>0
 If [M:DIA]SITE<>""
  Read [F:FCY]FCY0 = [M:DIA]SITE
  If !fstat
   SITE = [F:FCY]FCY : Gosub RECSITE
  Endif
 Else
  For [FCY]FCY0 Where LEGCPY=SOCIETE & FINFLG=2
   SITE = [F:FCY]FCY : Gosub RECSITE
  Next
 Endif
Else
 Gosub RECSITE
Endif
Return

$RECSITE
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(5,116,1)-SITE,0) From GESECRAN
# Site
Call ECR_TRACE(mess(49,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN
 # Début récupération
Filter [DAE9] Order By Key CLE=CPY;FCYLIN;ACC;BPR;MTC;ACCDAT;ACCNUM

COK = 1
ACCCUR = ""
BPRCUR = ""

$BOUCLE_SOC
STOP   = 0
NBCPT  = 0
FILECT  = 'LEDTYP='+num$(REFERENTIEL)
FILECT -= '& CPY="'+SOCIETE+'"'
FILECT -= '& FCYLIN="'+SITE+'"'
If COMPTE<>""
 FILECT -= '& ACC="'+COMPTE+'"'
Endif
If ACCCUR<>""
 If BPRCUR<>""
  FILECT -= '& ACC="'+ACCCUR+'"'
  FILECT -= '& BPR>"'+BPRCUR+'"'
 Else
  FILECT -= '& ACC>"'+ACCCUR+'"'
 Endif
Endif

For [DAE8]DAE1(5) Where evalue(FILECT)
 Read [GAC]GAC0 = PLAN;[F:DAE8]ACC
 If fstat=0 & [F:GAC]MTC=2
  For [DAE9]CLE(5) Where LEDTYP=REFERENTIEL & CPY=[F:DAE8]CPY & FCYLIN=[F:DAE8]FCYLIN & ACC=[F:DAE8]ACC
&   & BPR=[F:DAE8]BPR & MTC>="A" & MTC<="ZZZZZ" & FLGMTC=0
   FLDEV  = 0
   DEVISE = ""
   Raz DEB_CUR, CRE_CUR
   Raz DEB_SOC, CRE_SOC
   Raz DEB_RPT, CRE_RPT
   Raz TBECR , NBECR
   Raz NBMTC , TBDAT
   DATMAX  = [0/0/0]
   DATMIN  = [31/12/9999]
   DATMAX1 = [0/0/0]
   DATMIN1 = [0/0/0]
   GBIDA1  = [0/0/0]
   OKDAT   = 1
   For [DAE9]CLE
    Read [HAE]HAE0 = [F:DAE9]TYP;[F:DAE9]NUM
    OK = 1
    If left$([F:HAE]REFINT,3)="MTC" : # Le délettrage va le virer
     mkstat = 0
     Call CONTPER([F:HAE]ACCDAT,REFERENTIEL,[F:HAE]FCY) From CPTSUB
     If !mkstat : OK = 0 : Endif
    Endif 
    If OK   :# (pièce normale) ou (pièce de lettrage auto et période fermée)
     NBECR += 1
     If NBECR > MAXECT
      # Valeur trop petite
      COK=0 : Call ECR_TRACE("dim([M:LTR]NUM):"-mess(8,135,1),1) From GESECRAN
      Break 3
     Endif
     TBECR(NBECR) = [F:DAE9]ACCNUM
     If DEVISE=""
      DEVISE = [F:HAE]CUR
      If DEVISE<>[F:HAE]CURLED
       FLDEV  = 1
      Endif
     Elsif FLDEV & DEVISE<>[F:HAE]CUR
      FLDEV  = 0
     Endif
     DATMIN = min(DATMIN,[F:DAE9]ACCDAT)
     DATMAX = max(DATMAX,[F:DAE9]ACCDAT)
    Else   :# pièce de lettrage auto et période ouverte
     NBMTC += 1
     TBDAT(NBMTC) = [F:DAE9]ACCDAT
    Endif
    If DATMIN1=[0/0/0]
     DATMIN1 = [F:DAE9]MTCDATMIN
    Elsif DATMIN1<>[F:DAE9]MTCDATMIN
     OKDAT = 0
    Endif
    If DATMAX1=[0/0/0]
     DATMAX1 = [F:DAE9]MTCDATMAX
    Elsif DATMAX1<>[F:DAE9]MTCDATMAX
     OKDAT = 0
    Endif
    If GBIDA1=[0/0/0]
     GBIDA1 = [F:DAE9]MTCDAT : # Pour conserver la date de lettrage
    Endif
    If [F:DAE9]SNS=1
     If [F:HAE]CUR=DEVISE : DEB_CUR += [F:DAE9]AMTCUR : Endif
     DEB_SOC += [F:DAE9]AMTLED
    Else 
     If [F:HAE]CUR=DEVISE : CRE_CUR += [F:DAE9]AMTCUR : Endif
     CRE_SOC += [F:DAE9]AMTLED
    Endif 
    If [F:DAE9]BPR<>""
     OKECH = 1
     For [DUD]DUD6 Where FLGCLE=1 & ACCNUM=[F:DAE9]ACCNUM
      OKECH = 0
      Call ECR_TRACE([F:DAE9]FCYLIN-[F:DAE9]ACC-[F:DAE9]BPR-[F:DAE9]MTC-":"-mess(24,119,1),0) From GESECRAN
      If RECUP=2
       Trbegin [DUD]
        [F:DUD]PAYCUR = [F:DUD]AMTCUR
        [F:DUD]PAYLOC = [F:DUD]AMTLOC
        Call SLDECH("DUD")From MODECHE
        Rewrite [DUD]
        Call HISTOECH("DUD",1,[F:HAE]ACCDAT)From MODECHE
       Commit
      Endif
     Next
    Endif
   Next 
   Gosub VERF_LET
  Next
  For [DAE7]DAE1 Where LEDTYP=REFERENTIEL & CPY=[F:DAE8]CPY & FCYLIN=[F:DAE8]FCYLIN
&                    & ACC=[F:DAE8]ACC & BPR=[F:DAE8]BPR & MTC=""
   For [DUD]DUD1 Where ACCNUM=[F:DAE7]ACCNUM & (PAYCUR<>0 or PAYLOC<>0)
    Call ECR_TRACE([F:DAE7]FCYLIN-[F:DAE7]ACC-[F:DAE7]BPR-num$([F:DAE7]ACCNUM)-[F:DAE7]NUM-":"-mess(24,119,1),0) From GESECRAN
    If RECUP=2
     Trbegin [DUD]
      [F:DUD]PAYCUR = 0
      [F:DUD]PAYLOC = 0
      Call SLDECH("DUD")From MODECHE
      Rewrite [DUD]
      Call HISTOECH("DUD",1,[F:DAE]ACCDAT)From MODECHE
     Commit
    Endif
   Next
  Next
  NBCPT += 1
  If NBCPT>CPTMAX
   ACCCUR = [F:DAE8]ACC
   BPRCUR = [F:DAE8]BPR 
   STOP   = 1
   Break
  Endif
 Endif
Next
If COK<1 : Return : Endif

If STOP
 Goto BOUCLE_SOC
Elsif BPRCUR<>""
 BPRCUR = ""
 Goto BOUCLE_SOC
Endif

Call ECR_TRACE(mess(50,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN
# Fin récupération
Return


$VERF_LET
EQ1 = 1 : EQ2 = 1
If DEB_SOC<>CRE_SOC : EQ1 = 0 : Endif
If FLDEV & DEB_CUR<>CRE_CUR : EQ2 = 0 : Endif
If !EQ1 or !EQ2
 GMESSAGE = mess(117,116,1)-":" : # Déséquilibre
 If !EQ1 : GMESSAGE -= mess(91,105,1)        : Endif : # Montant société
 If !EQ2 : GMESSAGE -= mess(32,105,1)-DEVISE : Endif : # Montant
 Call ECR_TRACE([F:DAE9]FCYLIN-[F:DAE9]ACC-[F:DAE9]BPR-[F:DAE9]MTC-":"-GMESSAGE,0) From GESECRAN
Endif
If DATMIN<>DATMIN1 or DATMAX<>DATMAX1
 OKDAT = 0
Endif
For I=1 To NBMTC
 If TBDAT(I)<DATMIN or TBDAT(I)>DATMAX
  OKDAT = 0 : # Pour le message
  EQ1   = 0 : # Pour la récup
 Endif
Next I
If !OKDAT
 GMESSAGE = mess(96,105,1) : # Erreur sur date de lettrage
 Call ECR_TRACE([F:DAE9]FCYLIN-[F:DAE9]ACC-[F:DAE9]BPR-[F:DAE9]MTC-":"-GMESSAGE,0) From GESECRAN 
Endif
If RECUP=2
 Gosub REC_LET
Endif
Return

$REC_LET
If !EQ1 or !EQ2
 Gosub RELETTRE
Elsif !OKDAT
 Call DEBTRANS From GLOCK
 Gosub TR1
# RAS TVB
Endif
Return

$TR1
GOK = 1
Trbegin [DAE]
 Update [DAE]
& Where LEDTYP=REFERENTIEL & CPY=[F:DAE9]CPY & FCYLIN=[F:DAE9]FCYLIN
&     & ACC=[F:DAE9]ACC & BPR=[F:DAE9]BPR & MTC=[F:DAE9]MTC
& With MTCDATMIN=DATMIN , MTCDATMAX=DATMAX
Commit
Return

$RELETTRE
COK = 1
If FLDEV & EQ2
 CAS = 2
Else
 CAS = 1
Endif
If [F:DAE9]BPR<>""
 NBECH = 0
 For I=1 To NBECR
  For [DUD]DUD1 Where ACCNUM=TBECR(I)
   NBECH +=1
   If NBECH>MAXECT
    # Valeur trop petite
    COK=0 : Call ECR_TRACE("dim([M:LTR]NUM):"-mess(8,135,1),1) From GESECRAN
    Break 2
   Endif
   TBECH(NBECH) = TBECR(I)
   TBLIG(NBECH) = [F:DUD]DUDLIG
   If CAS=1
    TBIPT(NBECH) = [F:DUD]AMTLOC
   Else
    TBIPT(NBECH) = [F:DUD]AMTCUR
   Endif
  Next
 Next I
Else
 Raz TBLIG, TBIPT
Endif
If COK<1 : Return : Endif
Trbegin [DAE], [DUD]
 Call DELETTRE(SOCIETE,SITE,REFERENTIEL,[F:DAE9]ACC,[F:DAE9]BPR,[F:DAE9]MTC) From DELETTRAGE
 CAS += 4 : # Pour forcer la date de lettrage
 If GBIDA1=[0/0/0]
  GBIDA1 = date$
 Endif
 Raz PCETYP, PCENUM, STA
 If [F:DAE9]BPR<>""
  Call LETTRAGE(NBECH,TBECH,TBLIG,TBIPT,CAS,0,STA,MESSAGE,PCETYP,PCENUM) From CPTLET
 Else
  Call LETTRAGE(NBECR,TBECR,TBLIG,TBIPT,CAS,0,STA,MESSAGE,PCETYP,PCENUM) From CPTLET
 Endif
 If STA
  Rollback
 Else
  Commit
 Endif
Read [DAE]DAE2 = TBECR(1)
If STA
 Call ECR_TRACE(mess(58,116,1)-":"-MESSAGE,1) From GESECRAN : # Erreur
Else
 Call ECR_TRACE(mess(118,116,1)-":"-[F:DAE]MTC,0) From GESECRAN : # Nouveau lettrage
 For I=1 To dim(PCENUM)
  If PCENUM(I)<>""
   Call ECR_TRACE(mess(40,107,1)-":"-PCETYP(I)-PCENUM(I),0) From GESECRAN : # Création pièce
  Endif
 Next I
Endif
NBREC += 1
Return

#########################################################################
## Etiquettes écran RECUPLET
#########################################################################
Subprog C_GRPSOC(VALEUR)
Variable Char    VALEUR()
Call C_GRPSOC(VALEUR) From SUBLTR
End

Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Call AS_LEDTYP(VALEUR) From SUBLTR
End

Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
Call C_LEDTYP(VALEUR) From SUBLTR
End

Subprog C_NBSOC
Call C_NBSOC From SUBLTR
End

Subprog AS_SOC(VALEUR)
Variable Char    VALEUR()
Call AS_SOC(VALEUR) From SUBLTR
End

Subprog C_SOC(VALEUR)
Variable Char    VALEUR()
Call C_SOC(VALEUR) From SUBLTR
End

Subprog AS_SITE(VALEUR)
Variable Char VALEUR
Call AS_SITE(VALEUR) From SUBLTR
End

Subprog C_SITE(VALEUR)
Variable Char    VALEUR()
Call C_SITE(VALEUR) From SUBLTR
End

