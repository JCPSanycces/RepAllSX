###################################
$CHARGE_SITPAR
If [F:HRDAE]EMPDDS="" : Return : Endif :#80005 if no employee, none etrdat defined.
nolign=0
For [DAC]DAC0 Where YEAEMPDDS=[F:HRDAE]YEAEMPDDS & EMPDDS=[F:HRDAE]EMPDDS & CTRNUM=[F:HRDAE]CTRNUM & TYPDAE=[F:HRDAE]TYPDAE & FLGDNA=[F:HRDAE]FLGDNA
& & (ETRDAT>=[F:HRDAE]ETRDAT | (ETRDAT>=addmonth([F:HRDAE]ETRDAT,-2) & OLDSPE>1)) & ETRDAT<=[F:HRDAE]XITDAT
& & XITDAT<=[F:HRDAE]XITDAT
 nolign += 1
 [M:DAE9]=[F:DAC]
 [M:DAE9]ETRDAT2(nolign-1)=[F:DAC]ETRDAT
 [M:DAE9]XITDAT2(nolign-1)=[F:DAC]XITDAT
Next
[M:DAE9]NBLIG= nolign

# N4DS - Zones CRPNPAC / RAEP
[M:DAE9]NBPAC = max(0, find(0, [M:DAE9]PACTYPCOT)-1 )
[M:DAE9]NBRAE = max(0, find(0, [M:DAE9]RAETYPSTU)-1 )

Return

###################################
$SAUVE_SITPAR
Delete [DAC] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS &  CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE & FLGDNA=[M:DAE0]FLGDNA
& & (ETRDAT>=[M:DAE2]ETRDAT | (ETRDAT>=addmonth([M:DAE2]ETRDAT,-2) & OLDSPE>1)) & ETRDAT<=[M:DAE2]XITDAT
& & XITDAT<=[M:DAE2]XITDAT
If fstat=1
 GOK =-1 : GLOCK = "$DADEMP4" : Return
Endif
For nolign=1 To [M:DAE9]NBLIG
 [F:DAC]ETRDAT= [M:DAE9]ETRDAT2(nolign-1)
 [F:DAC]XITDAT= [M:DAE9]XITDAT2(nolign-1)
 [F:DAC]=[M:DAE9]
 [F:DAC]YEAEMPDDS=[F:HRDAE]YEAEMPDDS
 [F:DAC]EMPDDS=[F:HRDAE]EMPDDS
 [F:DAC]CTRNUM=[F:HRDAE]CTRNUM
 [F:DAC]TYPDAE=[F:HRDAE]TYPDAE
 [F:DAC]FLGDNA=[F:HRDAE]FLGDNA
 Write [DAC]
 If fstat<>0
  GOK = 0 : Call FSTA("DAC") From GLOCK : Break
 Endif
Next
Return

