&    | [ADI]A1="145" | [ADI]A1="146" | [ADI]A1="149" | [ADI]A1="157" | [ADI]A1="158" | [ADI]A1="159" | [ADI]A1="160"| [ADI]A1="903"
  #Valeur non autorisée
  GMESSAGE=mess(100,10703,1)
