Subprog AM_PSNJOB(VALEUR)
Variable Char    VALEUR()
Call GRISE_AT(10604,VALEUR)
End

Subprog AM_CATJOB(VALEUR)
Variable Char    VALEUR()
Call GRISE_AT(10357,VALEUR)
End

Subprog GRISE_AT(NUM,VALEUR)
Value Integer NUM
Value Char    VALEUR()
If VALEUR="" : End : Endif
Read[F:ADI]CODE=NUM;VALEUR
If !fstat & ([F:ADI]A1='07' | [F:ADI]A1='37')
 Effzo[M:DAE2]25 : Grizo [M:DAE2]25
 Effzo[M:DAE2]HRSWRK  : Grizo [M:DAE2]HRSWRK
Else
 Actzo [M:DAE2]25
 Actzo [M:DAE2]HRSWRK
Endif
End
