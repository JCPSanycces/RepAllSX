 #
 Read [POS]POS1(2) = [M]WRKCRY;VALEUR
 If fstat<=2
  [M]WRKCODSEE = [F:POS]POSCTYCOD
  Affzo WRKCODSEE
 Endif
Endif
End

##################################################################
# Etiquettes écrans [DAE2]
##################################################################

########################################
Subprog C_ETRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[M]ETRDAT : End : Endif
Local Integer TROUVE
Gosub DEBFIN
#80913
If val(GFLAG)<>2
 If VALEUR<DEBANN | VALEUR> FINANN
  #Période incorrecte
  GMESSAGE = mess(25,10702,1)
  mkstat=2 : End
 Endif
Endif
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
For [F:HRCTR]CTR1 Where REFNUM=[M:DAE0]EMPDDS & CTRNUM=[M:DAE0]CTRNUM  & CTRDAT<=VALEUR
 If  [F:HRCTR]XITDAT=[0/0/0] | ([F:HRCTR]XITDAT<>[0/0/0] & [F:HRCTR]XITDAT>=VALEUR)
  TROUVE=1 : Break
Endif
Next
If !TROUVE
 #Salarié non présent sur
 GMESSAGE=mess(140,10702,1)-[M:DAE0]CTRNUM
 mkstat=2 : End
Else
 [M:DAE2]ETRDAT=VALEUR
 Gosub INIT_JOB
Endif
End

########################################
Subprog AM_ETRDAT(VALEUR)
Variable Date    VALEUR
#Si la fiche existe je la charge...
Read[F:HRDAE]DAE0=[M:DAE0]YEAEMPDDS;[M:DAE0]EMPDDS;[M:DAE0]CTRNUM;VALEUR;[M:DAE0]TYPDAE;[M:DAE0]FLGDNA
If !fstat : [M:DAE0]=[F:HRDAE] : Endif
End

########################################
Subprog C_XITDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[M]XITDAT : End : Endif
Local Integer TROUVE
Gosub DEBFIN
#80913
If val(GFLAG)<>2
 If VALEUR<DEBANN | VALEUR> FINANN
  #Période incorrecte
  GMESSAGE = mess(25,10702,1)
  mkstat=2 : End
 Endif
Endif
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
For [F:HRCTR]CTR1 Where REFNUM=[M:DAE0]EMPDDS & CTRNUM=[M:DAE0]CTRNUM  & CTRDAT<=[M:DAE2]ETRDAT
 If  [F:HRCTR]XITDAT=[0/0/0] | ([F:HRCTR]XITDAT<>[0/0/0] & [F:HRCTR]XITDAT>=VALEUR)
  TROUVE=1 : Break
Endif
Next
If !TROUVE
 #Salarié non présent sur
 GMESSAGE=mess(140,10702,1)-[M:DAE0]CTRNUM
 mkstat=2 : End
Else
 [M:DAE2]XITDAT=VALEUR
 Gosub INIT_JOB
Endif
End

########################################
$DEBFIN
Local Char VALPAR (10)
Local Date DEBANN, FINANN

Local Integer TROUVE , VBTP, VNBT
VBTP=func AFNC.ACTIV("BTP")
If [M:DAE0]TYPDAE>2
 NVBT=0
Else
 VNBT=1
Endif

If VBTP
 DEBANN=gdat$(01,04,val([M:DAE0]YEAEMPDDS))
 FINANN=gdat$(31,03,val([M:DAE0]YEAEMPDDS)+1)
 Return
Endif

Call PARAM([M:DAE0]ETRFCY,"DMA",VALPAR) From ADOVAL
If VALPAR="" : VALPAR="12" : Endif
If val(VALPAR)=12
 DEBANN=gdat$(01,01,val([M:DAE0]YEAEMPDDS))
 FINANN=gdat$(31,12,val([M:DAE0]YEAEMPDDS))
Else
 DEBANN=gdat$(01,val(VALPAR)+1,val([M:DAE0]YEAEMPDDS)-1)
 FINANN=gdat$(eomonth(gdat$(01,val(VALPAR),val([M:DAE0]YEAEMPDDS))),val(VALPAR),val([M:DAE0]YEAEMPDDS))
Endif
Return

########################################
Subprog C_ETRGRD(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Actzo [M:DAE2]ETRGRD,XITGRD
Else
 Effzo [M:DAE2]ETRGRD,XITGRD
 Grizo [M:DAE2]ETRGRD,XITGRD
Endif
End

########################################
Subprog C_XITGRD(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Actzo [M:DAE2]ETRGRD,XITGRD
Else
 Effzo [M:DAE2]ETRGRD,XITGRD
 Grizo [M:DAE2]ETRGRD,XITGRD
Endif
End

########################################
Subprog C_TYPJOB(VALEUR)
Variable Integer VALEUR
If VALEUR=2 | VALEUR=3 | VALEUR=14 :#temps partiel ou intérimaire ou forfait jour (N4DS)
 Actzo [M:DAE2]RATMIDWRK
Else
 Effzo [M:DAE2]RATMIDWRK
 Grizo [M:DAE2]RATMIDWRK
Endif
End

########################################
Subprog AM_RSKWRK(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read [F:WAC]WAC0=VALEUR
 If !fstat
  Filter [F:WAR] Where CODWAC=[F:WAC]CODWAC & DATWAC<=[M:DAE2]XITDAT
  Read [F:WAR]WAR0 Last
  Filter [F:WAR]
  If !fstat
   [M:DAE2]=[F:WAC]
   [M:DAE2]RATWAC=[F:WAR]RATWAC
  Endif
 Endif
Else
 Effzo[M:DAE2]20
 Raz [M:DAE2]HRSWRK  :#80108
Endif
Affzo[M:DAE2]20
Raz [M:DAE2]HRSWRK  :#80108
End

########################################
Subprog C_STACAT2(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call CTRL_STATUT ([M]CATJOB, VALEUR)
Else
 For I=0 To [M:DAE4]NBRRGM-1
  If [M:DAE4]RGMCOD(I)<>""
   Read [ADI]CODE=10340;[M:DAE4]RGMCOD(I)
   If left$([F:ADI]A1,1)="A" | left$([F:ADI]A1,1)="C" | left$([F:ADI]A1,1)="G"
    #Zone obligatoire
    GMESSAGE=mess(10,123,1)
    mkstat=2 : Break
   Endif
  Endif
 Next
 If mkstat : End : Endif
Endif
End

########################################
Subprog CTRL_STATUT (CODPRO, CODIRC)
Value Char CODPRO()
Value Char CODIRC()
Local Char STAPRO(5)
Local Char STAIRC(5)

Read[F:ADI]CODE=10357;CODPRO : If !fstat : STAPRO=[F:ADI]A1 : Endif
Read[F:ADI]CODE=10368;CODIRC : If !fstat : STAIRC=[F:ADI]A1 : Endif
If STAIRC<>"" & STAPRO<>""
 If (STAIRC<>"01" & (STAPRO="12" |STAPRO="13" | (val(STAPRO)>=22 & val(STAPRO)<=25 )))
  #Statut IRC incompatible avec statut professionnel
  GMESSAGE=mess(61,10705,1)
  mkstat=2 : End
 Endif
Endif
End

