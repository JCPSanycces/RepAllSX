############ [DNA3]#############

#Tableau des Indemnités mensuelles
Subprog AS_DNAINDMTH(VALEUR)
Variable Integer VALEUR
For I=1 To len(mess(0,10969,1))
 If I<>5 & I<>6 & I<>15
  GMENLOC(I)=1
 Endif
Next
End

#Les valeurs 5 & 6 s'excluent
Subprog C_DNAINDMTH(VALEUR)
Variable Integer VALEUR
If nolign>1
 If (VALEUR=5 & [M]DNAINDMTH(nolign-2)=6) | (VALEUR=6 & [M]DNAINDMTH(nolign-2)=5)
  #Valeur incorrecte
  GMESSAGE=mess(83,123,1)
  mkstat=2 : End
 Endif
Endif
End

Subprog C_DNASTRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR>[M:DAE2]ETRDAT
 #Valeur incorrecte
 GMESSAGE=mess(83,123,1)
 mkstat=2 : End
Endif
End

Subprog C_DNAENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & VALEUR<[M:DAE2]XITDAT
 #Valeur incorrecte
 GMESSAGE=mess(83,123,1)
 mkstat=2 : End
Endif
End

Subprog AM_DNAENDDAT(VALEUR)
Variable Date    VALEUR
Call GRISE_SORTIE (VALEUR)
End

Subprog GRISE_SORTIE (VALEUR)
Value Date VALEUR
If VALEUR=[0/0/0]
 Effzo [M:DNA3]DNADATNTF,DNADATLIC,DNALSTDAY,DNANBRCNG, DNACLC,FLGINDSUP
 Effzo [M:DNA3]15-25
 Grizo [M:DNA3]DNADATNTF,DNADATLIC,DNALSTDAY,DNANBRCNG, DNACLC,FLGINDSUP
 Grizo [M:DNA3]15-25
Else
 Actzo [M:DNA3]DNADATNTF,DNADATLIC,DNALSTDAY,DNANBRCNG, DNACLC,FLGINDSUP
 Actzo [M:DNA3]15-25
Endif
End

Subprog C_DNADATNTF(VALEUR)
Variable Date    VALEUR
If clalev([F:HRNCT])=0  : Local File HRNATCON [HRNCT]  : Endif
Call SIMPLEREAD([M:DAE2]NATCON,GCURLEG,GERRHRM) From SUBHRNCT
If !GERRHRM
  Case [F:HRNCT]CODN4H
   When "11","12","14","15","20","25","34","36","41","83" :
    If VALEUR=[0/0/0]
     #Zone obligatoire
     GMESSAGE=mess(10,123,1)
     mkstat=2 : End
    Endif
  Endcase
 Endif
If VALEUR>[M]DNAENDDAT & [M]DNAENDDAT<>[0/0/0]
 #Valeur incorrecte
 GMESSAGE=mess(83,123,1)
 mkstat=2 : End
Endif
If [M]NBRPRV & VALEUR>min([M]DNASTRPRV(0..[M]NBRPRV-1)) & min([M]DNASTRPRV(0..[M]NBRPRV-1))<>[0/0/0]
 #Valeur incorrecte
 GMESSAGE=mess(83,123,1)
 mkstat=2 : End
Endif
End

Subprog C_DNADATLIC(VALEUR)
Variable Date    VALEUR
If clalev([F:HRNCT])=0  : Local File HRNATCON [HRNCT]  : Endif
Call SIMPLEREAD([M:DAE2]NATCON,GCURLEG,GERRHRM) From SUBHRNCT
If !GERRHRM
 Case [F:HRNCT]CODN4H
   When "11","12","14"
    If VALEUR=[0/0/0]
     #Zone obligatoire
     GMESSAGE=mess(10,123,1)
     mkstat=2 : End
    Endif
 Endcase
Endif
If VALEUR>[M]DNAENDDAT & [M]DNAENDDAT<>[0/0/0]
 #Valeur incorrecte
 GMESSAGE=mess(83,123,1)
 mkstat=2 : End
Endif
If [M]NBRPRV & VALEUR>min([M]DNASTRPRV(0..[M]NBRPRV-1)) & min([M]DNASTRPRV(0..[M]NBRPRV-1))<>[0/0/0]
 #Valeur incorrecte
 GMESSAGE=mess(83,123,1)
 mkstat=2 : End
Endif
End

Subprog C_DNALSTDAY(VALEUR)
Variable Date    VALEUR
If VALEUR>[M]DNAENDDAT & [M]DNAENDDAT<>[0/0/0]
 #Valeur incorrecte
 GMESSAGE=mess(83,123,1)
 mkstat=2 : End
Endif
End

Subprog C_DNANBRCNG(VALEUR)
Variable Decimal VALEUR
If !VALEUR & find(15,[M]DNACODIND(0..[M]NBRIND2-1))
 #Zone obligatoire
 GMESSAGE=mess(10,123,1)
 mkstat=2 : End
Endif
End

#Tableau des préavis #############
Subprog AS_DNASTRPRV(VALEUR)
Variable Date    VALEUR
If [M]DNACODPRV(nolign-1)>3
 mkstat=1 : End
Endif
End

Subprog C_DNASTRPRV(VALEUR)
Variable Date    VALEUR
If VALEUR>[M]DNAENDDAT & [M]DNAENDDAT<>[0/0/0]
 #Valeur incorrecte
 GMESSAGE=mess(83,123,1)
 mkstat=2 : End
Endif
# Chevauchement interdit
For I=0 To [M]NBRPRV-1
 If I<>nolign-1
  If VALEUR<DNAENDPRV(I) & VALEUR>=DNASTRPRV(I)
   #Valeur incorrecte
   GMESSAGE=mess(83,123,1)
   mkstat=2 : End
  Endif
 Endif
Next
End

Subprog AS_DNAENDPRV(VALEUR)
Variable Date    VALEUR
If [M]DNACODPRV(nolign-1)>3
 mkstat=1 : End
Endif
End

Subprog C_DNAENDPRV(VALEUR)
Variable Date    VALEUR
If VALEUR>[M]DNAENDDAT & [M]DNAENDDAT<>[0/0/0]
 #Valeur incorrecte
 GMESSAGE=mess(83,123,1)
 mkstat=2 : End
Endif
# Chevauchement interdit
For I=0 To [M]NBRPRV-1
 If I<>nolign-1
  If (VALEUR>[M]DNASTRPRV(I) & [M]DNASTRPRV(nolign-1)<=[M]DNASTRPRV(I))
   #Valeur incorrecte
   GMESSAGE=mess(83,123,1)
   mkstat=2 : End
  Endif
 Endif
Next
End

#IRC
Subprog C_RGMCOD1(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read[F:ADI]CODE=10340;VALEUR
 If fstat | toupper(left$([F:ADI]A1,1))<>"A" & toupper(left$([F:ADI]A1,1))<>"G"
  #Valeur incorrecte
  GMESSAGE=mess(83,123,1)
  mkstat=2 : End
 Endif
Endif
End

Subprog AS_RGMCOD2(VALEUR)
Variable Char    VALEUR()
#N4DS
#Read[F:ADI]CODE=364;[M:DAE2]STACAT :#79756
Read[F:ADI]CODE=10368;[M:DAE2]STACAT2
If fstat | val([F:ADI]A1)>1
 mkstat=1 : End
Endif
End

Subprog C_RGMCOD2(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read[F:ADI]CODE=10340;VALEUR
 If fstat | toupper(left$([F:ADI]A1,1))<>"C" & toupper(left$([F:ADI]A1,1))<>"G"
  #Valeur incorrecte
  GMESSAGE=mess(83,123,1)
  mkstat=2 : End
 Endif
Endif
End

