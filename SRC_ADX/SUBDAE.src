#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion du fichier DADEMP
################################################################################################
# Modifications :
#    MABOS - 11/04/13 - FQ71754 - US1516- Remove the control on the civility 2 (Mrs./Madame)
#                                          to give the possibility to add the birth Name in all cases.
################################################################################################

Raz GPILOBJ
GFLAG="1"
Call OBJET("DAE",GBIDC1,"") From GOBJET
End

###################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "SETBOUT"     : Gosub SETBOUT
 When "VERF_ANU"    : Gosub VERF_ANU
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "VERIF_CRE"   : Gosub VERIF
 When "VERIF_MOD"   : Gosub VERIF
 When "RAZCRE"      : Gosub RAZCRE
 When "FILTRE"      : Gosub FILTRE
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "STATUT"      : Gosub STATUT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "DEFTRANS"    : Gosub DEFTRANS
 When "FERME"       : Gosub FERME
Endcase
Return

###################################
$OUVRE
Gosub OUVRE From WPDEFTABLE
If clalev([F:HRDAE])=0  : Local File DADEMP   [HRDAE]  : Endif
If clalev([F:DAS])=0  : Local File DADEMP2  [DAS]  : Endif
If clalev([F:DAP])=0  : Local File DADEMP3  [DAP]  : Endif
If clalev([F:DAC])=0  : Local File DADEMP4  [DAC]  : Endif
If clalev([F:WAC])=0  : Local File TRVACC   [WAC]  : Endif
If clalev([F:WAR])=0  : Local File TRVACCRAT[WAR]  : Endif
If clalev([F:ADI])=0  : Local File ATABDIV  [ADI]  : Endif
If clalev([F:ADI2])=0 : Local File ATABDIV  [ADI2] : Endif
If clalev([F:ADI3])=0 : Local File ATABDIV  [ADI3] : Endif
If clalev([F:ORG])=0  : Local File ORGANISME[ORG]  : Endif
If clalev([F:DAE2])=0 : Local File DADEMP   [DAE2] : Endif
If clalev([F:DAG])=0  : Local File DADEMP5  [DAG]  : Endif
If clalev([F:DAH])=0  : Local File DADEMP6  [DAH]  : Endif
If clalev([F:DAI])=0  : Local File DADEMP7  [DAI]  : Endif
If clalev([F:DAJ])=0  : Local File DADEMP8  [DAJ]  : Endif
If clalev([F:DAK])=0  : Local File DADEMP9  [DAK]  : Endif
If clalev([F:DAL])=0  : Local File DADEMP10 [DAL]  : Endif

#DNA
If clalev([F:DNA])=0 : Local File DADDNA   [DNA] : Endif
If clalev([F:DNB])=0 : Local File DADDNA2  [DNB] : Endif
If clalev([F:DNC])=0 : Local File DADDNA3  [DNC] : Endif
If clalev([F:DND])=0 : Local File DADDNA4  [DND] : Endif
If clalev([F:DNE])=0 : Local File DADDNA5  [DNE] : Endif
If clalev([F:DNF])=0 : Local File DADDNA6  [DNF] : Endif
If clalev([F:DNG])=0 : Local File DADDNA7  [DNG] : Endif
If GINTMT=1
 If clalev([F:DNH])=0 : Local File DADDNA8  [DNH] : Endif
Endif

If clalev([F:DAM])=0  : Local File DADEMP11 [DAM]  : Endif
If clalev([F:DPE])=0 : Local File DADEMP31  [DPE] : Endif
If clalev([F:DPP])=0 : Local File DADEMP32  [DPP] : Endif
If clalev([F:DAQ])=0 : Local File DADEMP12  [DAQ]  : Endif
If clalev([F:DQE])=0 : Local File DADEMP121 [DQE]  : Endif
If clalev([F:DMU])=0  : Local File DADEMP33  [DMU]  : Endif
If clalev([F:DME])=0  : Local File DADEMP34  [DME]  : Endif
If clalev([F:DMP])=0  : Local File DADEMP35  [DMP]  : Endif

Local Integer VBPT , VNBT
Local Char VALPAR (10)
Local Char ANCOUR (4)
Local Integer LIBPRU, LIBTYPJOB, LIBTYPDAE
Local Date DEBANN, FINANN
Local Integer NBLOOPS, INDIC, INDIC2, TEMPO
Local Char  ORGCOURANT (GLONORG)

VBTP=func AFNC.ACTIV("BTP")

If val(GFLAG)=2
 [L]ANCOUR=num$(year(GMOIPAY))
Else
 Call PARAM("","DADYEA",VALPAR) From ADOVAL
 If VALPAR<>""
  [L]ANCOUR=VALPAR
 Endif
Endif

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

###################################
$FILGAUCHE
If [L]ANCOUR<>""
 If FILGAUSUP<>"" : FILGAUSUP += " & " : Endif
 FILGAUCHE = "[F:HRDAE]YEAEMPDDS='"+[L]ANCOUR+"'"
Else
 FILGAUCHE = ""
Endif
Return

###################################
$FILTRE
FILTRE = "FLGDNA=val(GFLAG)"
If GUSRACS<>2
 FILTSUP = '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
 FILTSUP -= "& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))"
Else
 FILTSUP ="1=1"
Endif
If [L]ANCOUR<>""
 FILTSUP -= "& [F:HRDAE]YEAEMPDDS='"+[L]ANCOUR+"'"
Endif
Return

###################################
$DEFTRANS
If TUNNEL=1 : GFLAG = SAVGFLAG : Endif
Return

###################################
$SETBOUT    #pour désactiver le bouton chgt clé
Call VIREBOUT (CHAINE,"H") From GOBJET
If GREP<>"" | !VERROU | [F:HRDAE]FLGNEWSAL=2
 Call VIREBOUT (CHAINE,"B") From GOBJET    :#Bouton extraction
Endif
#Objet à 4 éléments de clé : ajout du btn suppression après que GOBJET l'ait viré !
If CLECUR & VERROU : CHAINE+="A" : Endif
#Menu déroulant
If GREP="" & [F:HRDAE]FLGNEWSAL<>2
 CHMEN += "12"
Elsif GREP="M" | GREP="D"
 CHMEN=""
Endif
Gosub SET_BOUT_SPE From GSAISIE
Return

###################################
$STATUT
Case BOUT
 When "1" : Gosub REMPLIT From GOBJSUB
 When "2" : Gosub LECTURE From GOBJSUB
Endcase
Return

###################################
$LIENS
# Multi_leg & multi_société
Call LECTURE("FCY",[M:DAE0]ETRFCY,"") From CONTOBJ
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
GSOCIETE=[F:CPY]CPY
GCURLEG=[F:CPY]LEG

If [M:DAE0]TYPDAE>2
 VNBT=0
 Effzo [M:DAE4]10-15 : Grizo [M:DAE4]10-15
 Effzo [M:DAE5] : Grizo [M:DAE5]
 Effzo [M:DAE6] : Grizo [M:DAE6]
 Effzo [M:DAE8] : Grizo [M:DAE8]
 Effzo [M:DAEA] : Grizo [M:DAEA]
 If VBTP :  Actzo [M:DAE7] : Endif
Else
 VNBT=1
 If VBTP :  Effzo [M:DAE7] : Grizo [M:DAE7] : Endif
 Actzo [M:DAE4]10-15
 Actzo [M:DAE5]
 Actzo [M:DAE6]
 Actzo [M:DAE8]
 Actzo [M:DAEA]
Endif
Gosub CHARGE_DAS
If VNBT : Gosub CHARGE_PREVOY : Affzo [M:DAE5] : Endif
If VBTP : Gosub CHARGE_BTP : Affzo[M:DAE7] : Endif
Gosub CHARGE_SITPAR : Affzo[M:DAE9]
TEMPO=[F:HRDAE]WRKFLGADD
Call GRISE_WRKADD(TEMPO)
LIBTYPJOB=[F:HRDAE]TYPJOB
Call C_TYPJOB (LIBTYPJOB)
LIBPRU=[F:HRDAE]PRUCTR
Call AM_PRUCTR(LIBPRU)

# N4DS : Pas de FLGDNA dans ces tables donc only en dads-u !
If val(GFLAG)<>2
 Gosub CHARGE_DAG
 Gosub CHARGE_DAH
 Gosub CHARGE_DAI
 Gosub CHARGE_DAJ
 Gosub CHARGE_DAK
 Gosub CHARGE_DAL
 Gosub CHARGE_DAM
Endif

Gosub CHARGE_STK
Gosub CHARGE_DNA From TRTDNA


TEMPO=[F:HRDAE]AGFFLG
Call AM_AGFFLG(TEMPO)

If clalev([M:DNA3])>=0
 TEMPO=[F:DNA]DNASTAPAR
 Call AM_DNAFLGSTA(TEMPO)
 TEMPO=[F:DNA]DNACHOFLG
 Call AM_DNACHOFLG (TEMPO)
Endif

#Salarié importés absent de la base des salariés : on empêche le tunnel
If [F:HRDAE]FLGNEWSAL=2 : Grizo [M:DAE0]EMPDDS : Else : Actzo [M:DAE0]EMPDDS :  Endif

#N4DS
If val(GFLAG)<>2
 Grizo [M:DNA1]DNASTRCAE,DNAREFCAE
 Grizo [M:DNA1]30
 Grizo [M:DNA2]30
 If GINTMT : Grizo [M:DNA4]10 : Endif
Else
 # Heures Supp
 Diszo [M:DAE3]35
Endif

#80108
Call GRISE_AT(10357,[F:HRDAE]CATJOB)
Call GRISE_AT(10604,[F:HRDAE]PSNJOB)

Return

###################################
$INICRE
$INIMOD
[M:DAE0]FLGDNA=val(GFLAG)
[F:HRDAE]FLGDNA=val(GFLAG)
Gosub SAUVE_DAS
Gosub SAUVE_SITPAR
If VNBT : [F:HRDAE]=[M:DAE5] : Gosub SAUVE_PREVOY : Endif
If VBTP
 [F:HRDAE]=[M:DAE7]
 [F:HRDAE]BUINBRYEA(0)=[M:DAE7]BUINBRYEA1
 [F:HRDAE]BUINBRYEA(1)=[M:DAE7]BUINBRYEA2
 Gosub SAUVE_BTP
Endif

Read [F:WAC]WAC0=[M:DAE2]RSKWRK
If fstat : Raz [F:WAC] : Endif
#Toutes les zones ne sont pas dans l'écran
[F:HRDAE]=[F:WAC]
[F:HRDAE]RATWAC=[M:DAE2]RATWAC :#par sécurité

#80108
If [F:HRDAE]CATJOB<>""
 Read[F:ADI]CODE=10357;[F:HRDAE]CATJOB
 If !fstat & ([F:ADI]A1='07' | [F:ADI]A1='37')
  Raz[F:HRDAE]RSKWRK,SCTFCY,CODRSK,CODOFC,RATWAC,HRSWRK
 Endif
Endif
If [F:HRDAE]PSNJOB<>""
 Read[F:ADI]CODE=10604;[F:HRDAE]PSNJOB
 If !fstat & ([F:ADI]A1='07' | [F:ADI]A1='37')
  Raz[F:HRDAE]RSKWRK,SCTFCY,CODRSK,CODOFC,RATWAC,HRSWRK
 Endif
Endif

Raz [F:HRDAE]DADFCY
Read [F:FCY]FCY0=[M:DAE0]ETRFCY
If !fstat & [F:FCY]DADFCY<>""
 [F:HRDAE]DADFCY=[F:FCY]DADFCY
Else
 Read [F:FCY]FCY0=[M:DAE0]ETRFCY
 If !fstat & [F:FCY]DADFCY<>""
  [F:HRDAE]DADFCY=[F:FCY]DADFCY
 Else
  [F:HRDAE]DADFCY=[M:DAE0]ETRFCY
 Endif
Endif

# N4DS : Pas de FLGDNA dans ces tables donc only en dads-u !
If val(GFLAG)<>2
 Gosub SAUVE_DAG
 Gosub SAUVE_DAH
 Gosub SAUVE_DAI
 Gosub SAUVE_DAJ
 Gosub SAUVE_DAK
 Gosub SAUVE_DAL
 Gosub SAUVE_DAM
Endif

Gosub SAUVE_STK
Gosub SAUVE_DNA From TRTDNA

Return

###################################
$RAZCRE
[M:DAE0]TYPDAE=1
[M:DAE0]FLGDNA=val(GFLAG)
[M:DAE0]YEAEMPDDS=[L]ANCOUR
[M:DAE0]FLG=1
Affzo [M:DAE0]
Return

###################################
$VERF_ANU
Trbegin [HRDAE],[DAS],[DAP], [DAC], [DAG], [DAH], [DAI], [DAJ], [DAK], [DAL],[DNA],[DNB],[DNC],[DND],[DNE],[DAM],
&       [DPE],[DPP],[DAQ],[DQE],[DMU],[DME],[DMP]
Delete [HRDAE] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
& & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE & FLGDNA=[M:DAE0]FLGDNA
If fstat = 1  : # enreg locké
 GLOCK = "$DADEMP" : Goto ROLL_ANN
Elsif fstat
 Goto AB_ANN
Endif
Delete [DAS] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
& & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE & FLGDNA=[M:DAE0]FLGDNA
If fstat = 1  : # enreg locké
 GLOCK = "$DADEMP2" : Goto ROLL_ANN
Elsif fstat
 Goto AB_ANN
Endif
Delete [DAC] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE & FLGDNA=[M:DAE0]FLGDNA
& & (ETRDAT>=[M:DAE2]ETRDAT | (ETRDAT>=addmonth([M:DAE2]ETRDAT,-2) & OLDSPE>1)) & ETRDAT<=[M:DAE2]XITDAT
& & XITDAT<=[M:DAE2]XITDAT
If fstat = 1  : # enreg locké
 GLOCK = "$DADEMP4" : Goto ROLL_ANN
Elsif fstat
 Goto AB_ANN
Endif

# N4DS : Pas de FLGDNA dans ces tables donc only en dads-u !
If val(GFLAG)<>2
  Delete [DAP] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
&  & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE
  If fstat = 1  : # enreg locké
   GLOCK = "$DADEMP3" : Goto ROLL_ANN
  Elsif fstat
   Goto AB_ANN
  Endif
  Delete [DAG] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
&  & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE
  If fstat = 1  : # enreg locké
   GLOCK = "$DADEMP5" : Goto ROLL_ANN
  Elsif fstat
   Goto AB_ANN
  Endif
  Delete [DAH] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
&  & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE
  If fstat = 1  : # enreg locké
   GLOCK = "$DADEMP6" : Goto ROLL_ANN
  Elsif fstat
   Goto AB_ANN
  Endif
  Delete [DAI] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
&  & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE
  If fstat = 1  : # enreg locké
   GLOCK = "$DADEMP7" : Goto ROLL_ANN
  Elsif fstat
   Goto AB_ANN
  Endif
  Delete [DAJ] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
&  & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE
  If fstat = 1  : # enreg locké
   GLOCK = "$DADEMP8" : Goto ROLL_ANN
  Elsif fstat
   Goto AB_ANN
  Endif
  Delete [DAK] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
&  & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE
  If fstat = 1  : # enreg locké
   GLOCK = "$DADEMP9" : Goto ROLL_ANN
  Elsif fstat
   Goto AB_ANN
  Endif
  Delete [DAL] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
&  & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE
  If fstat = 1  : # enreg locké
   GLOCK = "$DADEMP10" : Goto ROLL_ANN
  Elsif fstat
   Goto AB_ANN
  Endif
  Delete [DAM] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
&  & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE
  If fstat = 1  : # enreg locké
   GLOCK = "$DADEMP11" : Goto ROLL_ANN
  Elsif fstat
   Goto AB_ANN
  Endif
  Delete [DPE] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
&  & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE
  If fstat = 1  : # enreg locké
   GLOCK = "$DADEMP31" : Goto ROLL_ANN
  Elsif fstat
   Goto AB_ANN
  Endif
  Delete [DPP] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
&  & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE
  If fstat = 1  : # enreg locké
   GLOCK = "$DADEMP32" : Goto ROLL_ANN
  Elsif fstat
   Goto AB_ANN
  Endif
  Delete [DAQ] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
&  & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE
  If fstat = 1  : # enreg locké
   GLOCK = "$DADEMP12" : Goto ROLL_ANN
  Elsif fstat
   Goto AB_ANN
  Endif
  Delete [DQE] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
&  & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE
  If fstat = 1  : # enreg locké
   GLOCK = "$DADEMP121" : Goto ROLL_ANN
  Elsif fstat
   Goto AB_ANN
  Endif
  Delete [DMU] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
&  & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE
  If fstat = 1  : # enreg locké
   GLOCK = "$DADEMP33" : Goto ROLL_ANN
  Elsif fstat
   Goto AB_ANN
  Endif
  Delete [DME] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
&  & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE
  If fstat = 1  : # enreg locké
   GLOCK = "$DADEMP34" : Goto ROLL_ANN
  Elsif fstat
   Goto AB_ANN
  Endif
  Delete [DMP] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
&  & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE
  If fstat = 1  : # enreg locké
   GLOCK = "$DADEMP35" : Goto ROLL_ANN
  Elsif fstat
   Goto AB_ANN
  Endif
 Endif

Delete [DNA] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
& & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE & FLGDNA=[M:DAE0]FLGDNA
If fstat = 1  : # enreg locké
 GLOCK = "$DADDNA" : Goto ROLL_ANN
Elsif fstat
 Goto AB_ANN
Endif
Delete [DNB] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
& & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE & FLGDNA=[M:DAE0]FLGDNA
If fstat = 1  : # enreg locké
 GLOCK = "$DADDNA2" : Goto ROLL_ANN
Elsif fstat
 Goto AB_ANN
Endif
Delete [DNC] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
& & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE & FLGDNA=[M:DAE0]FLGDNA
If fstat = 1  : # enreg locké
 GLOCK = "$DADDNA3" : Goto ROLL_ANN
Elsif fstat
 Goto AB_ANN
Endif
Delete [DND] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
& & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE & FLGDNA=[M:DAE0]FLGDNA
If fstat = 1  : # enreg locké
 GLOCK = "$DADDNA4" : Goto ROLL_ANN
Elsif fstat
 Goto AB_ANN
Endif
Delete [DNE] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
& & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE & FLGDNA=[M:DAE0]FLGDNA
If fstat = 1  : # enreg locké
 GLOCK = "$DADDNA5" : Goto ROLL_ANN
Elsif fstat
 Goto AB_ANN
Endif
Delete [DNF] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
& & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE & FLGDNA=[M:DAE0]FLGDNA
If fstat = 1  : # enreg locké
 GLOCK = "$DADDNA6" : Goto ROLL_ANN
Elsif fstat
 Goto AB_ANN
Endif
Delete [DNG] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
& & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE & FLGDNA=[M:DAE0]FLGDNA
If fstat = 1  : # enreg locké
 GLOCK = "$DADDNA7" : Goto ROLL_ANN
Elsif fstat
 Goto AB_ANN
Endif
If GINTMT=1
 Delete [DNH] Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS
&  & ETRDAT=[M:DAE0]ETRDAT & CTRNUM=[M:DAE0]CTRNUM & TYPDAE=[M:DAE0]TYPDAE & FLGDNA=[M:DAE0]FLGDNA
 If fstat = 1  : # enreg locké
  GLOCK = "$DADDNA8" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
Endif
Commit
Effzo
OK = 0 :# pour ne pas passer dans la suppression standard
Return

###################################
$ROLL_ANN
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto VERF_ANU : Endif

###################################
$AB_ANN
Rollback
Return

###################################
$CHARGE_DAS
Local Integer IJK

Read[DAS]DAS0=[F:HRDAE]YEAEMPDDS;[F:HRDAE]EMPDDS;[F:HRDAE]CTRNUM;[F:HRDAE]ETRDAT;[F:HRDAE]TYPDAE;[F:HRDAE]FLGDNA
If fstat=0

    # Bizarre comme écriture, on passe n fois sur des transclasses au final identique
    # en fait à chaque "tour" de boucle on retransfère plein de tableau n fois

    For nolign=0 To [F:DAS]NBRRGM-1
        [M:DAE4]=[F:DAS]
    Next
    [M:DAE4]NBRRGM = nolign

    For nolign=0 To [F:DAS]NBRSPEBAS-1
        [M:DAE4]=[F:DAS]
    Next
    [M:DAE4]NBRSPEBAS = nolign

    For nolign=0 To [F:DAS]NBRSPECLG-1
        [M:DAE4]=[F:DAS]
    Next
    [M:DAE4]NBRSPECLG = nolign

    For nolign=0 To [F:DAS]NBRALO-1
        [M:DAE4]=[F:DAS]
    Next
    [M:DAE4]NBRALO = nolign

    For nolign=0 To [F:DAS]NBRSPEEXO-1
        [M:DAE8]=[F:DAS]
    Next
    [M:DAE8]NBRSPEEXO = nolign

    # (C) PROSPER - N4DS - Base brute exceptionnelle URSSAF
    For nolign=0 To [F:DAS]NBRURSBBE-1
        [M:DAE8]=[F:DAS]
    Next
    [M:DAE8]NBRURSBBE = nolign

    # (C) PROSPER - N4DS - Base plafonnée exceptionnelle URSSAF
    For nolign=0 To [F:DAS]NBRURSBBP-1
        [M:DAE8]=[F:DAS]
    Next
    [M:DAE8]NBRURSBBP = nolign

Endif
Return

###################################
$SAUVE_DAS
Delete [DAS] Where YEAEMPDDS=[F:HRDAE]YEAEMPDDS & EMPDDS=[F:HRDAE]EMPDDS
&  & ETRDAT=[F:HRDAE]ETRDAT & CTRNUM=[F:HRDAE]CTRNUM & TYPDAE=[F:HRDAE]TYPDAE & FLGDNA=[F:HRDAE]FLGDNA
If fstat=1
 GOK =-1 : GLOCK = "$DADEMP2" : Return
Endif
[F:DAS]YEAEMPDDS=[F:HRDAE]YEAEMPDDS
[F:DAS]EMPDDS=[F:HRDAE]EMPDDS
[F:DAS]ETRDAT=[F:HRDAE]ETRDAT
[F:DAS]CTRNUM=[F:HRDAE]CTRNUM
[F:DAS]TYPDAE=[F:HRDAE]TYPDAE
[F:DAS]FLGDNA=[F:HRDAE]FLGDNA
[F:DAS]=[M:DAE4]
[F:DAS]=[M:DAE8]
Write [DAS]
If fstat<>0
 GOK = 0 : Call FSTA("DAS") From GLOCK
Endif
Return

###################################
$CHARGE_PREVOY
Raz[M:DAE5]
[M:DAE5]=[F:HRDAE]
[M:DAE5]DATANC1=[F:HRDAE]DATANC(0)
[M:DAE5]DATANC2=[F:HRDAE]DATANC(1)
nolign=0
For I=0 To dim([F:HRDAE]TYPANC)-1
 If ![F:HRDAE]TYPANC(I): Break : Endif
 nolign+=1
 [M:DAE5]TYPANC(nolign-1)=[F:HRDAE]TYPANC(I)
 [M:DAE5]UOMANC(nolign-1)=[F:HRDAE]UOMANC(I)
 [M:DAE5]AMTANC(nolign-1)=[F:HRDAE]AMTANC(I)
Next
[M:DAE5]NBRANC=nolign
Gosub PREVOY_CTR
Gosub PREVOY_DRT
Affzo[M:DAE5]
Return

###################################
$PREVOY_CTR
Effzo [M:DAE5]25
# Tableau des contrats prévoyance
nolign=0
For [DAP]DAP0 Where YEAEMPDDS=[F:HRDAE]YEAEMPDDS & EMPDDS=[F:HRDAE]EMPDDS
&  & ETRDAT=[F:HRDAE]ETRDAT & CTRNUM=[F:HRDAE]CTRNUM & TYPDAE=[F:HRDAE]TYPDAE
 nolign += 1
 [M:DAE5]REFCTR(nolign-1)=[F:DAP]REFCTR
 [M:DAE5]NUMDCS(nolign-1)=[F:DAP]NUMDCS
 [M:DAE5]CODOBJ(nolign-1)="DAP"
Next
# Tableau des contrats mutuelle
For [DMU]DMU0 Where YEAEMPDDS=[F:HRDAE]YEAEMPDDS & EMPDDS=[F:HRDAE]EMPDDS
&  & ETRDAT=[F:HRDAE]ETRDAT & CTRNUM=[F:HRDAE]CTRNUM & TYPDAE=[F:HRDAE]TYPDAE
 nolign += 1
 [M:DAE5]REFCTR(nolign-1)=[F:DMU]REFCTR
 [M:DAE5]NUMDCS(nolign-1)=[F:DMU]NUMDCS
 [M:DAE5]CODOBJ(nolign-1)="DMU"
Next
[M:DAE5]NBRCTRPRV = nolign
Return

###################################
$PREVOY_DRT
Effzo [M:DAE5]30
# Tableau des ayants droits
nolign=0
For [DAQ]DAQ0 Where YEAEMPDDS=[F:HRDAE]YEAEMPDDS & EMPDDS=[F:HRDAE]EMPDDS
&  & ETRDAT=[F:HRDAE]ETRDAT & CTRNUM=[F:HRDAE]CTRNUM & TYPDAE=[F:HRDAE]TYPDAE
 nolign += 1
 [M:DAE5]TYPBNF(nolign-1)=[F:DAQ]TYPBNF
 [M:DAE5]NAMBNF(nolign-1)=[F:DAQ]NAMBNF
 [M:DAE5]SRNBNF(nolign-1)=[F:DAQ]SRNBNF
 [M:DAE5]NUMLIG(nolign-1)=[F:DAQ]NUMLIG
Next
[M:DAE5]NBRBNFPRV = nolign
Return

###################################
$SAUVE_PREVOY
[F:HRDAE]=[M:DAE5]
[F:HRDAE]DATANC(0)=[M:DAE5]DATANC1
[F:HRDAE]DATANC(1)=[M:DAE5]DATANC2
nolign=0
For nolign=1 To [M:DAE5]NBRANC
 [F:HRDAE]TYPANC(nolign-1)=[M:DAE5]TYPANC(nolign-1)
 [F:HRDAE]UOMANC(nolign-1)=[M:DAE5]UOMANC(nolign-1)
 [F:HRDAE]AMTANC(nolign-1)=[M:DAE5]AMTANC(nolign-1)
Next
Return

