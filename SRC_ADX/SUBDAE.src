######################################################################################
Subprog AM_TYPJOB(VALEUR)
Variable Integer VALEUR
If VALEUR=6 & [M]WRKSTG=2 : [M]WRKSTG=1 : Affzo [M]WRKSTG : Endif
End

Subprog D_DNATYPMOD(VALEUR)
Variable Integer VALEUR
Case [M:DAE2]TYPJOB
    When 4,5
        # Intermittent & Domicile
        [L]VALEUR = [M:DAE2]TYPJOB-3
    When 9
        # Saisonnier
        [L]VALEUR = 3
    When 10
        #Vacataire
       [L]VALEUR = 4
    When 13
        # Occasionnel
        [L]VALEUR = 5
   When Default
        # non concerné
        [L]VALEUR = 6
Endcase
End

Subprog C_DNATYPMOD(VALEUR)
Variable Integer VALEUR
If  ([L]VALEUR=1 & [M:DAE2]TYPJOB<>4 ) | ([L]VALEUR=2 & [M:DAE2]TYPJOB<>5) | ([L]VALEUR=3 & [M:DAE2]TYPJOB<>9)
&  |([L]VALEUR=4 & [M:DAE2]TYPJOB<>10) | ([L]VALEUR=5 & [M:DAE2]TYPJOB<>13)
    #Modalité d'activité incompatible avec le type d'emploi
    GMESSAGE=mess(127,701,1)
    mkstat = 1 : End
Endif
End
