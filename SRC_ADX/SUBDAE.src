$CHARGE_STK
# Effzo[M:DAE6]5
# [M:DAE6]NBSTK=0
# nolign=0
# For I=0 To dim([F:HRDAE]NBRSTK)-1
# If ![F:HRDAE]NBRSTK(I): Break : Endif
# nolign+=1
# [M:DAE6]=[F:HRDAE]
# Next
# [M:DAE6]NBSTK=nolign

# N4DS - Chargement des BSPCE et on en profite pour modifier le chargement des stocks options
#        => Il faudrait revoir tous les modes de chargement pour faire quelque chose de simple et basique ...
# RANG 5 : Stock option
# RANG 10 : Actions gratuites - traitées dans CHARGE_DAH
# RANG 15 : BSPCE

Effzo[M:DAE6] 5, 15
Raz [M:DAE6]NBSTK, [M:DAE6]NBBSPCE

# Un seul transclasse général
nolign = 0
[M:DAE6] = [F:HRDAE]

For I=0 To dim([F:HRDAE]BSPCENBRTI)-1
    If ![F:HRDAE]BSPCENBRTI(I): Break : Endif
    [M:DAE6]NBBSPCE += 1
Next

For I=0 To dim([F:HRDAE]NBRSTK)-1
    If ![F:HRDAE]NBRSTK(I): Break : Endif
    [M:DAE6]NBSTK += 1
Next

Return

###################################
$SAUVE_STK
# For nolign=1 To [M:DAE6]NBSTK
# [F:HRDAE]=[M:DAE6]
# Next

nolign = 0
[F:HRDAE] = [M:DAE6]

Return

###############################################################################################################################

###################################
$APRES_MODIF
Case COUZON
 When "EMPDDS"
  Assign "[M:DAE0]"+COUZON With CZ
  Filter [F:HRDAE] Where EMPDDS=[M:DAE0]EMPDDS & YEAEMPDDS=[M:DAE0]YEAEMPDDS & TYPDAE=[M:DAE0]TYPDAE & FLGDNA=[M:DAE0]FLGDNA
  Read [F:HRDAE]DAE0 Last
  Filter [HRDAE]
  If fstat<=2
   [M:DAE0]=[F:HRDAE]
  Else
   GMODIF=1
   Gosub INIT_EMP
  Endif
Endcase
Return

###################################
$INIT_EMP
Raz[M:DAE1] : Raz[M:DAE2] : Raz[M:DAE3] : Raz[M:DAE4]
If VNBT : Raz [M:DAE5] : Endif
Raz[M:DAE6]
If VBTP : Raz [M:DAE7] : Endif
Raz[M:DAE8] : Raz[M:DAE9]
Read [F:ID]ID0=[M:DAE0]EMPDDS
If !fstat
 [M:DAE0]=[F:ID]
 [M:DAE0]YEAEMPDDS= [L]ANCOUR
 [M:DAE0]CTRNUM=[F:ID]FCY
 [M:DAE0]TYPDAE=1
 [M:DAE0]FLGDNA=val(GFLAG)
 [M:DAE0]FLG=1
 [M:DAE1]=[F:ID]
 Gosub DECALAGE
 MATRI=[M:DAE0]EMPDDS
 DATMAT=FINANN
 Gosub LECEMP From WPDEFTABLE
 [M:DAE6]=[F:AD]
 [M:DAE0]CTRNUM=[F:HRCTR]CTRNUM
 [M:DAE0]ETRFCY=[F:HRCTR]ETRFCY
 [M:DAE2]=[F:HRCTR]
 [M:DAE2]ETRDAT = [F:HRCTR]CTRDAT
 [M:DAE2]ETRGRD = [F:HRCTR]CTRGRD
 If [M:DAE2]ETRDAT<>[0/0/0] & [M:DAE2]ETRDAT<=FINANN
  If [M:DAE2]ETRDAT<DEBANN  : [M:DAE2]ETRDAT=DEBANN : [M:DAE2]ETRGRD="ACT"  : Endif
 Else
 #Salarié non présent sur xxxx
  Call ERREUR (mess(140,10702,1)-ANCOUR) From GESECRAN
  OK=0 : Return
 Endif
 If [M:DAE2]XITDAT=[0/0/0] | [M:DAE2]XITDAT>FINANN
  [M:DAE2]XITDAT=FINANN : [M:DAE2]XITGRD="ACT"
  #Si contrat droit privé alors contrat en vigueur coché !
  If [M:DAE6]PRUCTR=1  :  [M:DAE6]PRUFLG=2 : Else : [M:DAE6]PRUFLG=1 : Endif
 Endif
[M:DAE0]ETRDAT=[M:DAE2]ETRDAT
 Gosub INIT_JOB
Endif
Affzo [M:DAE0] : Affzo[M:DAE1] : Affzo[M:DAE2] : Affzo[M:DAE3] : Affzo[M:DAE4]
If VNBT : Affzo [M:DAE5] : Endif
Affzo[M:DAE6]
If VBTP : Affzo [M:DAE7] : Endif
Affzo [M:DAE8] : Affzo[M:DAE9]
Return

###################################
$INIT_JOB
Local Char VNUMAFF (50)
Local Char VNUMCTR (50)
If GREP="M" | GREP="D" : Return : Endif
Raz[M:DAE9]
MATRI=[M:DAE0]EMPDDS
DATMAT=[M:DAE2]ETRDAT
Gosub LECEMP From WPDEFTABLE
[M:DAE3]=[F:HRCTR]
Gosub INIT_IRC
If VNBT : Gosub INIT_IP : Endif
Return

###################################
$INIT_IRC
Raz [M:DAE4]NBRRGM
If [M:DAE0]TYPDAE<3
 If [F:HRCTR]STAEMP>1  : NBLOOPS=2 : Else : NBLOOPS=1 : Endif
 # Indices de travail pour l'ARRCO
 INDIC=GINDARR :  INDIC2=1
Else
 # Indices de travail pour l'ARRCO
 INDIC=GINDBTP :  INDIC2=1  : NBLOOPS=1
Endif
For J=0 To NBLOOPS-1
 #Indices de travail pour l'AGIRC
 If J=1 : INDIC=GINDAGI :  INDIC2=2 : Endif
 ORGCOURANT=""
 Call ORGANISME ([M:DAE0]EMPDDS,[M:DAE0]ETRFCY,[F:HRCTR]CTRNUM,ORGCOURANT,INDIC-1) From SUBORG
 If ORGCOURANT<>""
  Read [F:ORG]ORG0=GCURLEG;ORGCOURANT
  If fstat=0 & [F:ORG]NUMDCS<>""
   [M:DAE4]RGMCOD(J)=[F:ORG]NUMDCS :#Code Régime/Institution (Arrco/Agirc)
   Call ORGAFFIL (ORGCOURANT,[M:DAE0]ETRFCY,[M:DAE0]EMPDDS,[F:HRCTR]CTRNUM,VNUMAFF,VNUMCTR) From SUBORA
   [M:DAE4]RGMNUM(J)=VNUMCTR :#No contrat (Arrco/Agirc)
   [M:DAE4]NBRRGM+=1
  Else
   [M:DAE4]RGMCOD(J)="NON" :#Pas de régime complèmentaire
   [M:DAE4]RGMNUM(J)=""
   [M:DAE4]NBRRGM+=1
  Endif
 Endif
Next
Return

###################################
$INIT_IP
#Retraite
#N4DS - Changement d'écran
[M:DAE4]UOMTIMWRK=1
[M:DAE4]LNGWRK=0
[M:DAE4]AGFFLG=1
# Prevoyance
[M:DAE5]DATANC1=[F:HRCTR]DATCPY
If [F:HRCTR]CTRDAT>[F:HRCTR]DATCPY
 [M:DAE5]DATANC2=[F:HRCTR]CTRDAT
Else
 Raz [M:DAE5]DATANC2
Endif
[M:DAE5]CODSITFAM=[F:ID]SITFAM
[M:DAE5]ORGMAL=[F:HRCTR]ORGMAL
[M:DAE5]ROWBRN=0
Filter [F:RIB] Where REFNUM=[F:HRCTR]REFNUM & find(TYPPAY,"NP","")<>0
Read [F:RIB]RIB0 First
Filter [F:RIB]
If !fstat
 [M:DAE5]IBAN=[F:RIB]IBAN
 [M:DAE5]BIC=[F:RIB]BICCOD
 [M:DAE5]BID=[F:RIB]BIDNUM
Else
 [M:DAE5]IBAN=""
 [M:DAE5]BIC=""
 [M:DAE5]BID=""
Endif
# Ancienneté
If year([M:DAE0]ETRDAT)-year([F:HRCTR]DATANC)>0 & year([M:DAE0]ETRDAT)-year([F:HRCTR]DATANC)<50
 [M:DAE5]TYPANC(0)=1
 [M:DAE5]UOMANC(0)=4
 [M:DAE5]AMTANC(0)=year([M:DAE2]ETRDAT)-year([F:HRCTR]DATANC)
Endif
Return

###################################
$DECALAGE
If VBTP
 DEBANN=gdat$(01,04,val(ANCOUR))
 FINANN=gdat$(31,03,val(ANCOUR)+1)
 [M:DAE2]MOVPAY=1
 Return
Endif
Call PARAM([M:DAE0]ETRFCY,"DMA",VALPAR) From ADOVAL
If VALPAR="" : VALPAR="12" : Endif
If val(VALPAR)=12
 DEBANN=gdat$(01,01,val(ANCOUR))
 FINANN=gdat$(31,12,val(ANCOUR))
 [M:DAE2]MOVPAY=1
Else
 DEBANN=gdat$(01,val(VALPAR)+1,val(ANCOUR)-1)
 FINANN=gdat$(eomonth(gdat$(01,val(VALPAR),val(ANCOUR))),val(VALPAR),val(ANCOUR))
 [M:DAE2]MOVPAY=3
Endif
Return

###################################
$VERIF
For [DAE2]DAE0 Where YEAEMPDDS=[M:DAE0]YEAEMPDDS & EMPDDS=[M:DAE0]EMPDDS & CTRNUM=[M:DAE0]CTRNUM
&                   & (ETRDAT<>[M:DAE2]ETRDAT | ETRFCY<>[M:DAE0]ETRFCY) & TYPDAE=[M:DAE0]TYPDAE & FLGDNA=[M:DAE0]FLGDNA
 If [F:DAE2]ETRDAT<=[M:DAE2]ETRDAT & [F:DAE2]XITDAT>=[M:DAE2]ETRDAT
  #Opération imposible : Une fiche DADS-U existe déjà pour ce salarié à cette période.
  GMESSAGE = mess(45,10705,1)
  OK=0 : Break
 Endif
Next
If !OK : Return : Endif
Return

###################################
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return


##################################################################
# Année en cours
##################################################################
$INIT_DIA
Case GACTION
 When "DAEAN" :
  [M:DIA]ANNEE=PARAM(1)
 When "DAEANNULE"
  [M:DIA]YEA=PARAM(1)
  [M:DIA]CPY=GDEFSOC
Endcase
Return

###################################
$CONTROLE
If GOK<1
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
Return

###################################
$EXEC
Case GACTION
 When "DAEAN"
  PARAM(1) = [M:DIA]ANNEE
 When "DAEANNULE"
  Gosub ANNUL_DECL
Endcase
Return

###################################
$ANNUL_DECL
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:DAE2])=0 : Local File DADEMP    [DAE2] : Endif
If clalev([F:DAP2])=0 : Local File DADEMP3   [DAP2] : Endif
If clalev([F:DPP2])=0 : Local File DADEMP32  [DPP2] : Endif
If clalev([F:DAQ2])=0 : Local File DADEMP12  [DAQ2] : Endif
If clalev([F:DMU2])=0 : Local File DADEMP33  [DMU2] : Endif
If clalev([F:DMP2])=0 : Local File DADEMP35  [DMP2] : Endif

Local Char CRITFCY (250)
CRITFCY="1=1"
#78165
If clalev([F:DNA2])=0 : Local File DADDNA    [DNA2] : Endif
Local Char CRITDAT (250)

If val(GFLAG)<>2
 CRITDAT="ETRDAT   >=["+format$(GFMD,[M:DIA]REFSTR)+"] & XITDAT   <=["+format$(GFMD,[M:DIA]REFEND)+"]"
 If [M:DIA]FCY<>""
  CRITFCY -= '& [F:FCY]FCY="'+[M:DIA]FCY+'"'
 Endif
Else
 CRITDAT="DNAENDDAT>=["+format$(GFMD,[M:DIA]REFSTR)+"] & DNAENDDAT<=["+format$(GFMD,[M:DIA]REFEND)+"]"
 # Pas de critère sur le site ici cause mutation
Endif

Trbegin [DAE2],[DAP2],[DPP2],[DAQ2],[DMU2],[DMP2]
For [F:FCY] Where evalue(CRITFCY) & LEGCPY=[M:DIA]CPY
 If val(GFLAG)<>2
  Gosub ANNUL_DADS
  If GOK=0 : Break : Endif
 Else
  Gosub ANNUL_AED
  If GOK=0 : Break : Endif
 Endif
Next
If !GOK : Rollback : Else  : Commit : Endif
Return

#78165
################
$ANNUL_DADS
For [F:DAE2] Where YEAEMPDDS=[M:DIA]YEA & ETRFCY=[F:FCY]FCY & FLGDNA=val(GFLAG) & FLG=2 & evalue(CRITDAT)
 For [DAP2]DAP0 Where YEAEMPDDS=[F:DAE2]YEAEMPDDS & EMPDDS=[F:DAE2]EMPDDS
&                      & ETRDAT=[F:DAE2]ETRDAT & CTRNUM=[F:DAE2]CTRNUM & TYPDAE=[F:DAE2]TYPDAE
     [F:DAP2]FLG=1
     Rewrite [F:DAP2]
     If fstat<>0
      GOK = 0 : Call FSTA("DAP2") From GLOCK
     Endif
     If GOK=0 : Break 2 : Endif
 Next
 For [DPP2]DPP0 Where YEAEMPDDS=[F:DAE2]YEAEMPDDS & EMPDDS=[F:DAE2]EMPDDS
&                       & ETRDAT=[F:DAE2]ETRDAT & CTRNUM=[F:DAE2]CTRNUM & TYPDAE=[F:DAE2]TYPDAE
     [F:DPP2]FLG=1
     Rewrite [F:DPP2]
     If fstat<>0
      GOK = 0 : Call FSTA("DPP2") From GLOCK
     Endif
     If GOK=0 : Break 2 : Endif
 Next
 For [DAQ2]DAQ0 Where YEAEMPDDS=[F:DAE2]YEAEMPDDS & EMPDDS=[F:DAE2]EMPDDS
&                       & ETRDAT=[F:DAE2]ETRDAT & CTRNUM=[F:DAE2]CTRNUM & TYPDAE=[F:DAE2]TYPDAE
     [F:DAQ2]FLG=1
     Rewrite [F:DAQ2]
     If fstat<>0
      GOK = 0 : Call FSTA("DAQ2") From GLOCK
     Endif
     If GOK=0 : Break 2 : Endif
 Next
 For [DMU2]DMU0 Where YEAEMPDDS=[F:DAE2]YEAEMPDDS & EMPDDS=[F:DAE2]EMPDDS
&                       & ETRDAT=[F:DAE2]ETRDAT & CTRNUM=[F:DAE2]CTRNUM & TYPDAE=[F:DAE2]TYPDAE
     [F:DMU2]FLG=1
     Rewrite [F:DMU2]
     If fstat<>0
      GOK = 0 : Call FSTA("DMU2") From GLOCK
     Endif
     If GOK=0 : Break 2 : Endif
 Next
 For [DMP2]DMP0 Where YEAEMPDDS=[F:DAE2]YEAEMPDDS & EMPDDS=[F:DAE2]EMPDDS
&                      & ETRDAT=[F:DAE2]ETRDAT & CTRNUM=[F:DAE2]CTRNUM & TYPDAE=[F:DAE2]TYPDAE
     [F:DMP2]FLG=1
     Rewrite [F:DMP2]
     If fstat<>0
      GOK = 0 : Call FSTA("DMP2") From GLOCK
     Endif
     If GOK=0 : Break 2 : Endif
 Next

 [F:DAE2]FLG=1
 Rewrite [F:DAE2]
 If fstat<>0
  GOK = 0 : Call FSTA("DAE2") From GLOCK
 Endif
 If GOK=0 : Break   : Endif
Next
Return

#78165
################
$ANNUL_AED
For [F:DNA2] Where YEAEMPDDS=[M:DIA]YEA & FLGDNA=val(GFLAG) & evalue(CRITDAT)
 For [DAE2]DAE0 Where YEAEMPDDS=[F:DNA2]YEAEMPDDS & EMPDDS=[F:DNA2]EMPDDS & CTRNUM=[F:DNA2]CTRNUM & ETRFCY=[F:FCY]FCY
&                        & ETRDAT=[F:DNA2]ETRDAT  & TYPDAE=[F:DNA2]TYPDAE & FLGDNA=[F:DNA2]FLGDNA & FLG=2
  [F:DAE2]FLG=1
   Rewrite [F:DAE2]
   If fstat<>0
    GOK = 0 : Call FSTA("DAE2") From GLOCK
   Endif
   If GOK=0 : Break 2   : Endif
  Next
Next
Return


##################################################################
# Etiquettes écrans [DAE0]
##################################################################

########################################
Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M]CTRNUM : End : Endif
Local Integer TROUVE
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
Gosub DEBFIN
For [F:HRCTR]CTR1 Where REFNUM=[M:DAE0]EMPDDS & CTRDAT<=FINANN & CTRNUM=VALEUR
 If  [F:HRCTR]XITDAT=[0/0/0] | ([F:HRCTR]XITDAT<>[0/0/0] & [F:HRCTR]XITDAT>DEBANN)
  TROUVE=1 : Break
 Endif
Next
If !TROUVE
 #Salarié non présent sur
 GMESSAGE=mess(140,10702,1)-VALEUR
 mkstat=2 : End
Else
 [M:DAE0]CTRNUM=VALEUR
 [M:DAE2]=[F:HRCTR]
 If [M:DAE2]ETRDAT<DEBANN  : [M:DAE2]ETRDAT=DEBANN : [M:DAE2]ETRGRD="ACT"  : Endif
 If [M:DAE2]XITDAT=[0/0/0] | [M:DAE2]XITDAT>FINANN
  [M:DAE2]XITDAT=FINANN : [M:DAE2]XITGRD="ACT"
 Endif
 Gosub INIT_JOB
Endif
End

########################################
Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
#Si la fiche existe je la charge...
Read[F:HRDAE]DAE0=[M:DAE0]YEAEMPDDS;[M:DAE0]EMPDDS;VALEUR;[M:DAE0]ETRDAT;[M:DAE0]TYPDAE;[M:DAE0]FLGDNA
If !fstat : [M:DAE0]=[F:HRDAE] : Endif
End

##################################################################
# Etiquettes écrans [DAE1]
##################################################################

########################################
Subprog AS_OLDNAM(VALEUR)
Variable Char    VALEUR()
#MABOS-11/04/13-FQ71754-US1516
#If [M:DAE0]CIV <>2
If VALEUR =""
 VALEUR=[M:DAE0]NAM
 Affzo [M:DAE1]OLDNAM
Endif
End

########################################
Subprog AM_CTYBRN(VALEUR)
Variable Char    VALEUR()
#61590
VALEUR=toupper(VALEUR)
#
# 49894
If [M]CTYBRNSEE<>""
 Filter [POS] Where CRY=[M]CRYBRN & POSCTY=VALEUR & POSCTYCOD=[M]CTYBRNSEE
 Read [POS]POS0 First
 If fstat
  Filter [POS] Where CRY=[M]CRYBRN & POSCTY=VALEUR
 Endif
Else
 Filter [POS] Where CRY=[M]CRYBRN & POSCTY=VALEUR
Endif
#Read [POS]POS1(2) = [M]CRYBRN;VALEUR
Read [POS]POS0 First
Filter [POS]
#49894
If fstat<=2
 [M]CTYBRNSEE = [F:POS]POSCTYCOD
  #49599
  #[M]DEPBRN    = left$([F:POS]POSCOD,2)
  If left$([F:POS]POSCTYCOD,2)="2A" | left$([F:POS]POSCTYCOD,2)="2B"
   [M]DEPBRN    = left$([F:POS]POSCTYCOD,2)
  Else
   [M]DEPBRN    = left$([F:POS]POSCOD,2)
  Endif
  #49599
 Affzo CTYBRNSEE,DEPBRN
Endif
End

########################################
Subprog AM_ADD3(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 #61590
 VALEUR=toupper(VALEUR)
 #
 Read [POS]POS1(2) = [M]CRY;VALEUR
 If fstat<=2
  [M]CODSEE = [F:POS]POSCTYCOD
  Affzo CODSEE
 Endif
Endif
End

########################################
Subprog AM_CODPOS(VALEUR)
Variable Char    VALEUR()
Read [POS]POS0(3) = [M]CRY;VALEUR;[M]CTY
If fstat<=2
 [M]CODSEE = [F:POS]POSCTYCOD
 Affzo CODSEE
Endif
End

########################################
Subprog AM_CTY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 #61590
 VALEUR=toupper(VALEUR)
 #
 #49894
 #Read [POS]POS1(2) = [M]CRY;VALEUR
 Read [POS]POS1 = [M]CRY;VALEUR;[M]CODPOS
 If fstat<=2
  [M]CODSEE = [F:POS]POSCTYCOD
  Affzo CODSEE
 Endif
Endif
End

########################################
Subprog C_WRKFLGADD(VALEUR)
Variable Integer VALEUR
Call GRISE_WRKADD(VALEUR)
End

########################################
Subprog GRISE_WRKADD(VALEUR)
Variable Integer VALEUR
If VALEUR<>2
 Actzo [M:DAE1]15
Else
 Effzo [M:DAE1]15
 Grizo [M:DAE1]15
 [M:DAE1]WRKCRY = "" : [M:DAE1]WRKCRYNAM = ""
Endif
[M:DAE1]WRKFLGADD=VALEUR
Actzo [M:DAE1]WRKFLGADD
Affzo [M:DAE1]WRKFLGADD
End

## Obligée car un affzo est afit pour le type de données CRT !
###########################################
Subprog AV_WRKCRN(VALEUR)
Variable Char    VALEUR()
If [M:DAE1]WRKFLGADD=2 : Grizo [M:DAE1]WRKCRN : Endif
End

