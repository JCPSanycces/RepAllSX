Subprog C_NUMCON(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 If clalev([F:HRCSP])=0  : Local File HRCATCSP [HRCSP]  : Endif
 Call SIMPLEREAD([M:DAE2]CATCSP, GCURLEG, GERRHRM) From SUBHRCSP
 If GERRHRM | ([F:HRCSP]CODN4H>="354a" & [F:HRCSP]CODN4H<="354g") |  [F:HRCSP]CODN4H="637c" | [M:DAE2]SEVJOB=2 | [M:DAE2]NATCON="CTT"
  #Zone obligatoire
  GMESSAGE=mess(10,123,1)
  mkstat=2 : End
 Endif
Endif
End

Subprog AS_DNAENDCDD(VALEUR)
Variable Date    VALEUR
Local Integer I
If clalev([F:HRNCT])=0  : Local File HRNATCON [HRNCT]  : Endif
Call SIMPLEREAD([M:DAE2]NATCON,GCURLEG,GERRHRM) From SUBHRNCT
If !GERRHRM
 If [F:HRNCT]CODN4H<>"02"& [F:HRNCT]CODN4H<>"03" & [F:HRNCT]CODN4H<>"25" & [F:HRNCT]CODN4H<>"26" & [F:HRNCT]CODN4H<>"27"
&                   & [F:HRNCT]CODN4H<>"28" & [F:HRNCT]CODN4H<>"04" & [F:HRNCT]CODN4H<>"05"
  mkstat=1 : End
 Endif
Endif
End

