If VALEUR=""
 Read [ADI2]CODE=10340;[M:DAE4]RGMCOD(nolign-1)
 If ([F:ADI2]A1="I0001" | [F:ADI2]A1="I0002" | [F:ADI2]A1="CL001"
&  | [F:ADI2]A1="F0002" | [F:ADI2]A1="R0001")
  GMESSAGE=mess(10,123,1) #Zone obligatoire.
  mkstat=2 : End
 Endif
Endif
End

