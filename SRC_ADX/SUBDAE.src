########################################
Subprog C_SYSMAL(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 If clalev([F:ADI])=0 : Local File ATABDIV  [ADI] : Endif
 Read[ADI]CODE=10355;VALEUR
 If fstat | [ADI]A1="120" | [ADI]A1="121" | [ADI]A1="122" | [ADI]A1="139" | [ADI]A1="157" | [ADI]A1="158" | [ADI]A1="159" | [ADI]A1="160"
&    | [ADI]A1="900" | [ADI]A1="903"
  #Valeur non autorisée
  GMESSAGE=mess(100,10703,1)
  mkstat=2 : End
 Endif
Endif
End

