  mkstat=2 : End
 Endif
Endif
End

Subprog IB_NBRCTRPRV
If ![M]NBRCTRPRV
 GBOUT1=""
#59275
Elsif [M]CODOBJ(nolign-1)="DAP"
 # Contrats de prevoyance
 GBOUT1=mess(84,10705,1)
Else
 # Contrats de Mutuelle
 GBOUT1=mess(86,10705,1)
Endif
End

Subprog B1_NBRCTRPRV
Local Char MATRI (GLONEML)
Local Char CLE2 (250)
MATRI=[M:DAE0]EMPDDS
CLE2=[M:DAE0]YEAEMPDDS+"~"+[M:DAE0]CTRNUM+"~"+num$([M:DAE0]ETRDAT)+"~"+num$([M:DAE0]TYPDAE)+"~"+[M]REFCTR(nolign-1)
Call OBJET_CHAR(MATRI,[M]CODOBJ(nolign-1),CLE2) From GOBJET
Gosub PREVOY_CTR
Affzo [M:DAE5]25
End

Subprog IB_NBRBNFPRV
If ![M]NBRBNFPRV
 GBOUT1=""
Else
 #"Ayants droit"
 GBOUT1=mess(85,10705,1)
Endif
End

Subprog B1_NBRBNFPRV
Local Char MATRI (GLONEML)
Local Char CLE2 (250)
MATRI=[M:DAE0]EMPDDS
CLE2=[M:DAE0]YEAEMPDDS+"~"+[M:DAE0]CTRNUM+"~"+num$([M:DAE0]ETRDAT)+"~"+num$([M:DAE0]TYPDAE)+"~"+num$([M]NUMLIG(nolign-1))
Call OBJET_CHAR(MATRI,"DAQ",CLE2) From GOBJET
Gosub PREVOY_DRT
Affzo [M:DAE5]30
End

Subprog C_DATANC2(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & VALEUR<=[M]DATANC1
  #Valeur non autorisée
  GMESSAGE=mess(100,10703,1)
  mkstat=2 : End
Endif
End

Subprog C_TYPANC(VALEUR)
Variable Integer VALEUR
If VALEUR
 Call UNICITE(VALEUR,[M]TYPANC(0..[M]NBRANC-1)) From OBJDIV
 If mkstat=2 : End : Endif
Endif
End

Subprog C_AMTANC(VALEUR)
Variable Decimal VALEUR
Case [M]TYPANC(nolign-1)
When 1 :
 If VALEUR>18300
  #Valeur non autorisée
  GMESSAGE=mess(100,10703,1)
  mkstat=2 : End
Endif
When 3
 If VALEUR>600    :#mois
  #Valeur non autorisée
  GMESSAGE=mess(100,10703,1)
  mkstat=2 : End
Endif
When 4
 If VALEUR>50   :#ans
  #Valeur non autorisée
  GMESSAGE=mess(100,10703,1)
  mkstat=2 : End
 Endif
Endcase
End

