#<AdxTL>@(#)1.0.0.0 $Revision$
# Exécution en batch
# Trace de démarrage
If getenv$("TRA_ENTREP")<>""
 Call TRACE_LOG("Before EXEC",0,1) From SERVEUR
Endif
Global Integer GTEST
GTEST = val(getenv$("GTEST"))
If toupper(getenv$("GTEST")) = "SRV"
# dbgmode = 1 : Dbgaff
Endif
#109897
#Call EXEC
End

# Actions de lancement et d'interruption

$ACTION
#109897
Return

Case ACTION
 When "INIT"
  Case GACTION
   When "ABATRUN"
    TMP = 1
    TIT = mess(7,134,1) : # Activation du serveur
    If dim([S]secmod)>0 & [S]secmod=2 : # Kerberos
     Local Mask APWDKER [APWD]
     Call DIALWIN(OK,TIT-"(Kerberos)","APWDKER") From GESECRAN
     If OK=2
      TYPPRG = 1
      [S]adxcpw = XCRYPT([M:APWD]PWD)
     Else
      FIN = 1
     Endif
     Close Local Mask [APWD]
    Endif
   When "ABATSTOP"
    TIT = mess(8,134,1) : # Désactivation du serveur
  Endcase
 When "EXEC"
  Case GACTION
   When "ABATRUN"
    Call ACTIVE
    If dim([S]secmod)>0 & dim([S]adxcpw)>0
     If [S]secmod=2 : [S]adxcpw = "" : Endif : # Kerberos
    Endif
   When "ABATSTOP"
    Call DESACTIVE
  Endcase
Endcase
Return

################################
##  Activation Serveur batch  ##
################################
Subprog ACTIVE
End : #109897


Local File ABATPAR [ABP]

Local Integer OK, MORT, ERR , TT , TX
Local Char    PID(10), FICTRA(GDIMFIC) , PROCESS(30)
Local Char    MESSA(50) , ERRMES(50)

Read [ABP]SPOOL First
FICTRA = func SERVSYS.GET_FILE_SERVEUR("tra")

# Vérif paramètrage serveur
Gosub TST_SERV
If !OK : End : Endif

# Vérif si pas déjà actif
If [F:ABP]STOP=2
 ERR = 56000 : GERR = 1 : GMESSAGE = mess(5,134,1) : # Le serveur est en cours d'arrêt
Else
 # Test activité du serveur par création du fichier stat
 Call STRACE(FICTRA,55200,0,"Test of activity batch server")
 Call PRESENCE(MORT)
 Call STRACE(FICTRA,55200,0,"End test->dead="+mess(MORT+1,1,1))
 If !MORT
  ERR = 54000 : GERR = 1 : GMESSAGE = mess(1,134,1) : # Le serveur est déjà actif
 Endif
Endif
If ERR
 Call STRACE(FICTRA,ERR,0,GMESSAGE)
 End
Endif

# Recherche d'un processus planté du serveur batch
Call STRACE(FICTRA,55200,0,"Find process dead of batch server")
Call PROCLI([F:ABP]APPLI,"BATCH",adxtcp,3,PROCESS) From PSADX
Call STRACE(FICTRA,55200,0,"End find process="+PROCESS)
If PROCESS<>""
 Call KILLPROC(adxmac(0),PROCESS,MESSA,ERRMES) From PSADX
 TT = 0
 TX = 1
 Repeat
  Sleep TX
  TT += TX
 Until TT>=[F:ABP]TEMPS
 Call PROCLI([F:ABP]APPLI,"BATCH",adxtcp,3,PROCESS) From PSADX
 If PROCESS<>""
  ERR = 53000
  GERR = 2 : GMESSAGE = "The process"-PROCESS-"must be removed before the server can restart"
  Call STRACE(FICTRA,ERR,0,GMESSAGE)
  End
 Else
  Call STRACE(FICTRA,54200,0,"The process"-PROCESS-"has been removed")
 Endif
Endif

Call STRACE(FICTRA,55200,0,"Start batch server")
Call DEBTRANS From GLOCK
Gosub TR_START
If GOK<>1
 ERR = 53000 : GERR = 1 : Call STRACE(FICTRA,ERR,0,GMESSAGE) : End
Endif
Call STRACE(FICTRA,55200,0,"Update status batch server->"+num$([F:ABP]STOP))

# Exécution "adonix -a SERVX3" et tentative de lire le fichier serveur.pid pour récupérer le PID
Call SERVEUR([F:ABP]APPLI,PID) From SERVSYS

Call DEBTRANS From GLOCK
Gosub TR_ACTIVE
If GOK=1 & PID<>""
 Call CTLJOB From SERVJOB : # Ménage dans les fichiers job (.run .req .kil)
 ERR = 50000
 GERR = 2 : GMESSAGE = mess(2,134,1)+"\"+mess(3,134,1)-PID : # Le serveur est activé\Processus numéro #
Elsif GOK=1 & PID=""
 ERR = 53000 : GERR = 1 : GMESSAGE = mess(43,134,1) : # Le serveur n'est pas actif
Else
 ERR = 53000 : GERR = 1
Endif
Call STRACE(FICTRA,ERR,0,GMESSAGE)
End

$TR_ACTIVE
GOK=1
Trbegin [ABP]
 Readlock [ABP]SPOOL First With lockwait=5
 If fstat=1
  GOK=-1 : GMESSAGE = mess(30,100,1) : Goto AB_ACTIVE : # Opération en cours sur un autre poste
 Elsif fstat
  GOK=0 : GMESSAGE = mess(12,100,1)-"ABATPAR" : Goto AB_ACTIVE : # Erreur d'accès sur le fichier
 Endif
 If PID <> [F:ABP]PROCESS
  [F:ABP]PROCESS = PID
 Endif
 Rewrite [ABP]
 If fstat
  GOK=0 : GMESSAGE = mess(13,100,1)-"ABATPAR" : Goto AB_ACTIVE : # Erreur d'écriture sur le fichier
 Endif
Commit
Return

$AB_ACTIVE
Rollback
Return

$TR_START
GOK=1
Trbegin [ABP]
 Readlock [ABP]SPOOL First With lockwait=5
 If fstat=1
  GOK=-1 : GMESSAGE = mess(30,100,1) : Goto AB_START : # Opération en cours sur un autre poste
 Elsif fstat
  GOK=0 : GMESSAGE = mess(12,100,1)-"ABATPAR" : Goto AB_START : # Erreur d'accès sur le fichier
 Endif
 [F:ABP]STOP = 3
 Rewrite [ABP]
 If fstat
  GOK=0 : GMESSAGE = mess(13,100,1)-"ABATPAR" : Goto AB_START : # Erreur d'écriture sur le fichier
 Endif
Commit
Return

$AB_START
Rollback
Return

###################################################################
## Test de présence réelle du serveur par création d'un fichier
###################################################################
Subprog PRESENCE(MORT)
Variable Integer MORT
MORT=1
End : #109897

Local Integer I , TT , TX
Call PROCESS([F:ABP]PROCESS,MORT) From SERVSYS
If !MORT : # Une tache de même numéro tourne encore
 MORT = 1
 Openo filpath("FIL","stat","",[F:ABP]APPLI,"",adxmac(0))
 Wrseq "xxxxxxxxxxxxxxx"
 Openo
 For I=1 To 5
  TX = 1
  TT = 0
  Repeat
   Sleep TX
   If filinfo(filpath("FIL","stat","",[F:ABP]APPLI,"",adxmac(0)),0)<0
    MORT = 0 : Break 2 : # Il est là
   Endif
   TT += TX
  Until TT>=[F:ABP]TEMPS
 Next I
 If MORT
  Trbegin [ABP]
   Update [ABP] With PROCESS=""
  Commit
 Endif
Endif
End

###################################
##  Désactivation Serveur batch  ##
###################################
Subprog DESACTIVE
End : #109897

Local File ABATPAR [ABP]
Local Integer OK, MORT, ERR
Local Char    FICTRA(GDIMFIC)

Read [ABP]SPOOL First
FICTRA = func SERVSYS.GET_FILE_SERVEUR("tra")

Gosub TST_SERV
If !OK : End : Endif

Call PRESENCE(MORT)
If MORT
 ERR = 57000 : GERR = 1 : GMESSAGE = mess(4,134,1) : # Le serveur n'est pas actif
Elsif [F:ABP]STOP=2
 ERR = 56000 : GERR = 1 : GMESSAGE = mess(5,134,1) : # Le serveur est en cours d'arrêt
Else
 Call DEBTRANS From GLOCK
 Gosub TR_DESACTIVE
 If GOK=1
  ERR = 56000 : GERR = 2 : GMESSAGE = mess(6,134,1) : # Ordre d'arrêt transmis au serveur
 Else
  ERR = 58000 : GERR = 1
 Endif
Endif
Call STRACE(FICTRA,ERR,0,GUSER-":"-GMESSAGE)

End

$TR_DESACTIVE
GOK=1
Trbegin [ABP]
 Readlock [ABP]SPOOL First With lockwait=5
 If fstat=1
  GOK=-1 : GMESSAGE = mess(30,100,1) : Goto AB_DESACTIVE
 Elsif fstat
  GOK=0 : GMESSAGE = mess(12,100,1)-"ABATPAR" : Goto AB_DESACTIVE
 Endif
 [F:ABP]STOP = 2
 Rewrite [ABP]
 If fstat
  GOK=0 : GMESSAGE = mess(13,100,1)-"ABATPAR" : Goto AB_DESACTIVE
 Endif
Commit
Return

$AB_DESACTIVE
Rollback
Return

$TST_SERV
OK = 1
If [F:ABP]APPLI = ""
 GERR = 1 : GMESSAGE = mess(13,134,1) : # Le nom du serveur n'est pas défini
 OK = 0
Elsif filinfo(filpath("",".passwd","",[F:ABP]APPLI,"",adxmac(0)),0)<0
&   | filinfo(filpath("",".users","",[F:ABP]APPLI,"",adxmac(0)),0)<0
 GERR = 1 : GMESSAGE = mess(14,134,1) : # Le serveur n'est pas installé
 OK = 0
Endif
Return

###############################
##  Activation automatique   ##
###############################
Subprog ACTAUTO
End : #109897

Local File ABATPAR [ABP]

Local Integer OK, MORT

OK = 0
Read [ABP]SPOOL First
If !fstat & [F:ABP]APPLI<>"" & adxmac(0)=""
 If filinfo(filpath("",".passwd","",[F:ABP]APPLI),0)>=0
& & filinfo(filpath("",".users","",[F:ABP]APPLI),0)>=0
  OK = 1
 Endif
Endif
If OK
 Call PRESENCE(MORT)
 If MORT : Call ACTIVE : Endif
Endif
End

###############################
##  Exécution Serveur batch  ##
###############################
Subprog EXEC
End : #109897

Onerrgo ERREUR

# Trace de démarrage
If getenv$("TRA_ENTREP")<>""
 Call TRACE_LOG(mess(193,123,1)-nomap(0)+".SERVEUR",0,1) From SERVEUR : # Exécution traitement
Endif

# Arrêt s'il tourne déjà
If nbruser>1
 If getenv$("TRA_ENTREP")<>""
  Call TRACE_LOG(mess(1,134,1)-"(nbruser="+num$(nbruser)+")",0,1) From SERVEUR : # Le serveur est déjà actif
 Endif
 End
Endif

Global Char    GTRACE(255)
GTRACE = func SERVSYS.GET_FILE_SERVEUR("")      # Issue X3-70499 - 2018-03-05 by CCC : no extension file

Call DEFGLOBVAR1 From GLOBVAR

GTRACE = func SERVSYS.GET_FILE_SERVEUR("")      # Issue X3-70499 - 2018-03-05 by CCC : no extension file
Call INIGLOBVAR1 From GLOBVAR

GLANGUE = messname(0)

Local Char    CHAINE(250)
Local Integer K , L , TILDE , OKTRT

CHAINE = getenv$("USER_ENTREP")
TILDE  = instr(1,CHAINE,"~")
If CHAINE=""
 GUSER = "ADMIN"
 GLOGIN = "ADMIN"
Elsif TILDE
 GUSER  = left$(CHAINE,TILDE-1)
 GLOGIN = right$(CHAINE,TILDE+1)
Else
 GUSER = CHAINE
 GLOGIN = tolower(CHAINE)
Endif

# Utilisateur/Login
If getenv$("TRA_ENTREP")<>""
 Call TRACE_LOG(mess(103,124,1)+"="+GUSER-mess(24,151,1)+"="+GLOGIN,0,0) From SERVEUR
Endif

Global Integer GNBENTREE , GPE
If filinfo(filpath("FIL","AENTREE","fde"),0)>0
 Local File AENTREE [APE]
 K = nbrecord([APE])+1
 L = type([F:APE]TRTSTD)-10
 Global Char GENTSTD(L)(1..K) , GENTSPE(L)(1..K) , GPOINT(L)
 For [APE]APE0
  Call EXISTE_ADX("","",[F:APE]TRTSPE,OKTRT) From ORDSYS
  If OKTRT>0
   GNBENTREE += 1
   GENTSTD(GNBENTREE) = [F:APE]TRTSTD
   GENTSPE(GNBENTREE) = [F:APE]TRTSPE
  Endif
 Next APE
 Close Local File [APE]
Else
 Global Char GENTSTD(30)(1..1) , GENTSPE(30)(1..1)
 Global Char GPOINT(30)
Endif

If getenv$("TRA_ENTREP")<>""
 Call TRACE_LOG("Create file serveur.pid",0,0) From SERVEUR
Endif

## initialise GACTX and debugger
#Onerrgo ERR_DEBUG
#
#If getenv$("TRA_ENTREP")<>""
# Call TRACE_LOG("declare GACTX",0,1) From SERVEUR
#Endif
#
#Call DEFVAR From ASYRCONST
#
#Global Instance GACTX Using C_WMACONTEXT
#
#If getenv$("TRA_ENTREP")<>""
# Call TRACE_LOG("av NewInstance",0,1) From SERVEUR
#Endif
#GACTX = NewInstance [ASYRACTX] With C_WMACONTEXT
#
#If getenv$("TRA_ENTREP")<>""
# Call TRACE_LOG("ap NewInstance",0,1) From SERVEUR
#Endif
#
#Local Integer L_ERRCOD
#Local Char    L_DOSSIER(GLONADS)
#L_DOSSIER = func DOSCONT.DOSX3(nomap)
#
#If getenv$("TRA_ENTREP")<>""
# Call TRACE_LOG("L_DOSSIER:"-L_DOSSIER,0,1) From SERVEUR
#Endif
#[L]L_ERRCOD = fmet GACTX.ACTX_INIT_LAN(L_DOSSIER,GLANGUE,GLOGIN)
#If getenv$("TRA_ENTREP")<>""
# Call TRACE_LOG("ERRCOD:"-num$(L_ERRCOD),0,1) From SERVEUR
# Call TRACE_LOG("nomap:"-nomap-"GLOGIN:"-GLOGIN-"GLANGUE:"-GLANGUE,0,1) From SERVEUR
# Call TRACE_LOG("ERRCOD:"-num$(L_ERRCOD),0,1) From SERVEUR
# Call TRACE_LOG("GACTX.USER:"-GACTX.USER,0,1) From SERVEUR
# Call TRACE_LOG("GACTX.AFOLDER:"-GACTX.AFOLDER,0,1) From SERVEUR
#Endif
#
#Local Decimal AECLIPSE,AECLIDBG
#Local Char AECLIMAC(250), AECLIPRT(250)
#If GACTX.APARAM<>null
# AECLIPSE = fmet GACTX.APARAM.AGETUSER_NUM("AECLIPSE")
# AECLIDBG = fmet GACTX.APARAM.AGETUSER_NUM("AECLIDBG")
# AECLIMAC = fmet GACTX.APARAM.AGETUSER_CHAR("AECLIMAC")
# AECLIPRT = fmet GACTX.APARAM.AGETUSER_CHAR("AECLIPRT")
# If getenv$("TRA_ENTREP")<>""
#  Call TRACE_LOG("AECLIPSE:"-num$(AECLIPSE),0,1) From SERVEUR
#  Call TRACE_LOG("AECLIDBG:"-num$(AECLIDBG),0,1) From SERVEUR
#  Call TRACE_LOG("AECLIMAC:"-AECLIMAC,0,1) From SERVEUR
#  Call TRACE_LOG("AECLIPRT:"-AECLIPRT,0,1) From SERVEUR
#  Call TRACE_LOG("DEBUGPRG:"-func DEBUGGER.GET_DBG_PROG(),0,1) From SERVEUR
# Endif
#Endif
#
#If AECLIDBG = 2
# [S]adxdpg = "DEBUGGER"
# [S]dbgmode(0)=1
#Endif
#
#Onerrgo ERREUR

# Création du fichier serveur.pid avec le no du PID
Call SERV_PID From SERVSYS

# Ouverture des tables
If getenv$("TRA_ENTREP")<>""
 Call TRACE_LOG(mess(10,101,1)-"ABATRQT, ABATPAR ...",0,0) From SERVEUR
Endif

Local File ABATRQT   [ABR], ABATPAR  [ABP], ABATTAC  [ABT]
&        , ABATABT   [ABA], ABATABTD [ABD], ABATGRP  [ABG]
&        , ABATCAL   [ABC], ABATHOR  [ABH], ABATRQTL [ABL]

Read [ABP]SPOOL First

# Géode

If dim([F:ABR]FCY)>0
 Global Char GFCY(type([F:ABR]FCY)-10)
Endif
If dim([F:ABR]DEP)>0
 Global Char GDEP(type([F:ABR]DEP)-10)
Endif

Local Char    FICRUN(GDIMFIC)
Local Char    FICSTOP(GDIMFIC)
Local Char    FICKILL(GDIMFIC)
Local Char    FICSTAT(GDIMFIC)
Local Char    FICTRA(GDIMFIC)
Local Char    FICTRQ(GDIMFIC)
Local Char    FICJOB(GDIMFIC)

FICRUN  = filpath("FIL","run","",0)
FICSTOP = filpath("FIL","stop","",0)
FICKILL = filpath("FIL","kill","",0)
FICSTAT = filpath("FIL","stat","",0)
FICTRA  = func SERVSYS.GET_FILE_SERVEUR("tra")

Local Char    MESSA(250) , MESSTOP(80) , UTIL(10)
Local Char    PID(10)
Local Integer ENTREE, MORT, MINUTES, TEMPS, KILSRV, KILRQT, STAT, KILRECURRENT
Local Integer MAXPROC , NBPROC , FLG , GRPNUM(3) , CPT
Local Char    MACHINE(GDIMFIC)(1..2)
Local Char    RQTID(50)
Local Integer TT , TX , OKPAR , OKDOS , OKDAT , RETARD , KILJOB , ERR
Local Integer NUMLIG , REQNUM , CNTERR , NUMLOO , TRASRV , OKTRA
Local Char    HREQ(10),CRITERIA(250)

MESSTOP = mess(8,134,1) :  #  Désactivation du serveur

Read [ABP]SPOOL First
#87108
#Call LICENCE From GLOBSUP
#Call NOMBRA(6,MAXPROC) From GLOCK     : # Nb maxi de batchs dans la licence
#87108
#Local Char VALMAX(30)
#If fmet GACTX.AGETLICPAR("MAXBATCH",VALMAX)=[V]CST_ATRUE
# MAXPROC=val(VALMAX)
#Endif
#If MAXPROC>0
# MAXPROC = min(MAXPROC-1,[F:ABP]NBTACHE) : # Nb maximum de requêtes actives (- serveur batch)
#Else
 MAXPROC = [F:ABP]NBTACHE
#Endif

# Démarrage
If getenv$("TRA_ENTREP")<>""
 Call TRACE_LOG("OK",0,0) From SERVEUR
Endif

[L]CRITERIA = "FLAG=1"
If [F:ABP]FLGPATCH=2
 [L]CRITERIA += " and TACHE='PATCH'"
Endif
Filter [ABR] Where evalue(CRITERIA)

##  Flag serveur actif

#######################################################
$DEBUT
Call DEBTRANS From GLOCK
Gosub TR_DEB
If   GOK<0 : Goto DEBUT
Elsif !GOK
 Call STRACE(FICTRA,44000,0,GMESSAGE) : End
Else
 Call STRACE(FICTRA,55100,0,"new status batch server="+num$([F:ABP]STOP))
Endif

Openo FICRUN , 0
Openo
Call EFFACE(FICSTOP,STAT) From ORDSYS
Call EFFACE(FICKILL,STAT) From ORDSYS
KILSRV = 0

##  Trace de démarrage

MESSA  = mess(7,134,1) : # Activation du serveur
MESSA -= "(PID="+num$(adxpid)
MESSA -= ",USR="+GUSER
MESSA -= ",SRV="+num$(adxtcp)+")"
Call STRACE(FICTRA,50000,0,MESSA)

## Pour psadx

Call SET_CURFCT("SERVEUR",1,GLOGIN) From PSADX

##  On regarde où on en est, et on fait le ménage

Gosub ETAT_RQT

##  Boucle d'attente

TEMPS = 0
NUMLOO = 0
TRASRV = val(getenv$("TRA_ENTREP"))
If TRASRV>=3 : Call TRACE_LOG("Number loop"-num$(TRASRV-2),0,0) From SERVEUR : Endif

#######################################################
$BOUCLE

OKTRA = 0
If TRASRV>=3
 NUMLOO += 1
 If NUMLOO+2>=TRASRV
  NUMLOO = 1
  OKTRA = 1
 Endif
Endif
If OKTRA : Call TRACE_LOG("Server loop",0,0) From SERVEUR : Endif

##  Test d'arrêt

Read [ABP]SPOOL First
If filinfo(FICKILL,0)>=0 : # Kill toutes requêtes
 If OKTRA : Call TRACE_LOG("Kill all",0,0) From SERVEUR : Endif
 Call STRACE(FICTRA,55100,0,FICKILL)
 KILSRV = 1
 Gosub TIMOUT
 Call EFFACE(FICKILL,STAT) From ORDSYS
 Sleep 2
 KILSRV = 0
Endif
If [F:ABP]STOP=2 or filinfo(FICSTOP,0)>=0 : # Arrêt
 If OKTRA : Call TRACE_LOG("Stop server",0,0) From SERVEUR : Endif
 If filinfo(FICSTOP,0)>=0
  Call STRACE(FICTRA,55000,0,FICSTOP)
 Endif
 Call DEBTRANS From GLOCK
 Gosub TR_STOP
 If GOK<1
  Call STRACE(FICTRA,44000,0,GMESSAGE)
 Endif
 Gosub ARRET
 End
Endif
Gosub STATUT

##  Lecture des requêtes
GOK=1 : #119378
If OKTRA : Call TRACE_LOG("Read pending request ("+num$(NBPROC)+"/"+num$(MAXPROC)+")",0,0) From SERVEUR : Endif
[L]CRITERIA = "FLAG=1"
If [F:ABP]FLGPATCH=2
 [L]CRITERIA += " and TACHE='PATCH'"
Endif
Filter [ABR] Where evalue(CRITERIA)
If NBPROC < MAXPROC
 Gosub DATE_HEURE
 Read [ABR]PRIO First
 Filter [ABR] : #119378
 If fstat=0
  Gosub VERFKIL_JOB
  If KILJOB
   Gosub KIL_JOB
   Call MOVEJOB([F:ABR]JOB,"req","old") From SERVJOB
   Goto BOUCLE
  Elsif [F:ABR]DAT<DD or ([F:ABR]DAT=DD & [F:ABR]HEURE<=HH)
   Read [ABT]CODTAC = [F:ABR]TACHE
   Gosub RETARD
   If !RETARD
    If OKTRA : Call TRACE_LOG("Exec pending request"-num$([F:ABR]NUMREQ)-[F:ABR]TACHE-"("+[F:ABR]DOSSIER+")",0,0) From SERVEUR : Endif
    Gosub EXEC_RQT
   #118381
   ##Else
   ## Goto BOUCLE
   Endif
   If GOK>0 : #119378
     Goto BOUCLE :#118381
   Endif
  Endif
 Endif
Endif

If OKTRA : Call TRACE_LOG("Sleep server- Number of active batch process = "+num$(NBPROC),0,0) From SERVEUR : Endif
TT = 0
TX = 1
Repeat
 Gosub STATUT
 Sleep TX
 TT += TX
Until TT>=[F:ABP]TEMPS
TEMPS += TT
If OKTRA : Call TRACE_LOG("End sleep server"-string$(TEMPS>=[F:ABP]TIMOUT,"(time out)"),0,0) From SERVEUR : Endif
If TEMPS>=[F:ABP]TIMOUT
 Gosub STATUT
 Gosub TIMOUT
 Gosub STATUT
 Gosub AUTO
 Gosub TRTJOB From SERVJOB
 Gosub STATUT
 Gosub ETAT_RQT
 Gosub STATUT
 TEMPS = 0
Endif
Goto BOUCLE

#######################################################
$RETARD
If [F:ABR]DAT<DD & [F:ABR]FRQFIN<>""
 RETARD = [F:ABR]FRQ : # Cas des requêtes avec fréquence avec case "Une seule requête" décochée
Elsif [F:ABT]RETARD<>0
 RETARD = [F:ABT]RETARD
Elsif dim(ASYRB_MAXDELAY)>0
 RETARD = ASYRB_MAXDELAY
#ancien serveur batch
Elsif [F:ABP]RETARD<>0
 RETARD = [F:ABP]RETARD
Else
 RETARD = 0
Endif
If RETARD : # mb 31.1.6 maintenant en mn
 If OKTRA : Call TRACE_LOG("time-out request"-num$([F:ABR]NUMREQ),0,0) From SERVEUR : Endif
 Local Date    DAT, DATR
 Local Integer TIM, TIMR, TEMPS
 DAT  = DD
 DATR = [F:ABR]DAT
 TIM  = val(left$(HH,2))*60+val(mid$(HH,3,2))
 TIMR = val(left$([F:ABR]HEURE,2))*60+val(mid$([F:ABR]HEURE,3,2))
 If DAT=DATR
  TEMPS = TIM-TIMR
 Else
  TEMPS = (24*60-TIMR)+TIM+(((DAT-DATR)-1)*24*60)
 Endif
 If TEMPS>RETARD
  RETARD = 1
 Else
  RETARD = 0
 Endif
Endif
If RETARD
 Trbegin [ABR]
  [F:ABR]FLAG = 8 : # Hors délai
  [F:ABR]DFIN = DD
  [F:ABR]HFIN = HS
  Rewrite [ABR]
  If fstat
   Call STRACE(FICTRA,42000,[F:ABR]NUMREQ,mess(13,100,1)-"ABATRQT")
   Rollback
   Return
  Endif
 Commit
 If [F:ABR]JOB<>""
  Call MOVEJOB([F:ABR]JOB,"req","old") From SERVJOB
 Endif
 Gosub IDENT_RQT
 ERR = 21000
 MESSA = mess(50,134,1) : # Délai dépassé
 Call STRACE(FICTRA,ERR,[F:ABR]NUMREQ,"RETARD - Delay management:"-MESSA-"("+RQTID+")")
 Call RTRACE(FICTRQ,ERR,MESSA)
 Call MESSAGE(num$(ERR)-MESSA)
Endif
Return

############################################
$ERR_DEBUG
GERREUR = errn
GMESSAGE = errp+"("+num$(errl)+")"-mess(6,123,1)-num$(GERREUR)-":"-errmes$(GERREUR)-errm
If getenv$("TRA_ENTREP")<>""
 Call TRACE_LOG("error create instance GACTX"-GMESSAGE,0,1) From SERVEUR
Endif
Call STRACE(FICTRA,52000+GERREUR,0,GMESSAGE)
Resume

#######################################################
$VERFKIL_JOB
KILJOB = 0
If [F:ABR]JOB<>""
 Call SETFIC([F:ABR]JOB,"kil",FICJOB) From SERVJOB
 If FICJOB<>"" & filinfo(FICJOB,0)>0
  If OKTRA : Call TRACE_LOG("kill job"-[F:ABR]JOB-"("+num$([F:ABR]NUMREQ)+")",0,0) From SERVEUR : Endif
  Call RDJOB([F:ABR]JOB,"kil",MESSA,UTIL) From SERVJOB
  KILJOB = 1
 Endif
Endif
Return

#######################################################
$KIL_JOB
Trbegin [ABR]
 [F:ABR]FLAG = 6 : # Avortée
 [F:ABR]DFIN = DD
 [F:ABR]HFIN = HS
 [F:ABR]MOTINT = MESSA
 [F:ABR]USRINT = UTIL
 Rewrite [ABR]
 If fstat
  Call STRACE(FICTRA,42000,[F:ABR]NUMREQ,mess(13,100,1)-"ABATRQT")
  Rollback
  Return
 Endif
Commit
Call DELJOB([F:ABR]JOB,"kil") From SERVJOB
Gosub IDENT_RQT
MESSA = mess(51,134,1)-'"'+MESSA+'"' : # Requête interrompue par # pour le motif
I = instr(1,MESSA,"#")
If I : MESSA = left$(MESSA,I-1)+UTIL+right$(MESSA,I+1) : Endif
ERR = 31000
Call STRACE(FICTRA,ERR,[F:ABR]NUMREQ,"KIL_JOB - Killing job management:"-MESSA)
Call RTRACE(FICTRQ,ERR,MESSA)
Call MESSAGE(num$(ERR)-MESSA)
Return

## Demande de présence

$STATUT
If filinfo(FICSTAT,0)>=0
 If dim(OKTRA)>0 & OKTRA : Call TRACE_LOG("End sleep server"-"("+num$(TEMPS)+"/"+num$([F:ABP]TIMOUT)+")",0,0) From SERVEUR : Endif
 Call EFFACE(FICSTAT,STAT) From ORDSYS
Endif
Return

$TR_DEB
GOK=1
Trbegin [ABP]
 Readlock [ABP]SPOOL First With lockwait=5
 If fstat=1
  GOK=-1 : GMESSAGE = mess(60,100,1)-"ABATPAR" : Goto AB_TR_DEB
 Elsif fstat
  GOK=0 : GMESSAGE = mess(12,100,1)-"ABATPAR" : Goto AB_TR_DEB
 Endif
 [F:ABP]PROCESS = num$(adxpid)
 [F:ABP]STOP = 1
 Rewrite [ABP]
 If fstat
  GOK=0 : GMESSAGE = mess(13,100,1)-"ABATPAR" : Goto AB_TR_DEB
 Endif
Commit
Return

$AB_TR_DEB
Rollback
Return

$TR_STOP
GOK=1
Trbegin [ABP]
 Readlock [ABP]SPOOL First With lockwait=5
 If fstat=1
  GOK=-1 : GMESSAGE = mess(60,100,1)-"ABATPAR" : Goto AB_TR_STOP
 Elsif fstat
  GOK=0 : GMESSAGE = mess(12,100,1)-"ABATPAR" : Goto AB_TR_STOP
 Endif
 [F:ABP]STOP = 0
 Rewrite [ABP]
 If fstat
  GOK=0 : GMESSAGE = mess(13,100,1)-"ABATPAR" : Goto AB_TR_STOP
 Endif
Commit
Return

$AB_TR_STOP
Rollback
Return

#######################################################
$ARRET
Return : #109897

Call EFFACE(FICSTOP,STAT) From ORDSYS
Call EFFACE(FICRUN,STAT) From ORDSYS
Call EFFACE(FICKILL,STAT) From ORDSYS
Call STRACE(FICTRA,55000,0,MESSTOP)
Call RAZ_CURFCT(num$(adxuid(1))) From PSADX
Return

#######################################################
$DATE_HEURE     : # BATCH SERVER DATE/TIME DEPENDING ON ADXTYP SESSION AND WITH EVENTUAL DELAY AFTER 23:59
  Local Char HH(10), HS(10)
  Local Date DD
  # X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
  Call SCHEDULING_DATE_TIME    ( [L]DD, [L]HH, [L]HS)
Return

$DATE_HEURE_BDD : # DATABASE DATE/TIME ONLY
  Local Char    HH(10), HS(10)
  Local Date    DD
  # X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
  Call SCHEDULING_DATE_TIME_DB ( [L]DD, [L]HH, [L]HS)
Return

$INIT_PARENT_ACTION
  If dim(PARENT_ACTION)<0
    Local Char    PARENT_ACTION (50) : # Title of the ACTION where we come from
  Endif

  If dim(ACTION)>0
    [L]PARENT_ACTION=ACTION
  Else
    [L]PARENT_ACTION=""
  Endif
Return

#######################################################
$DEAD_SESSION
  # X3-55215 : If a session doesn't exist but the request is still with status "in progress" or "kill"
  #           => change the status to "Canceled"
  Local Integer NBDEL_ASM3         : # Number of records deleted in ASYSSMDBASSO session table
  Local Integer NBDEL_ASM0         : # Number of records deleted in ASYSSMINTERN session table
  Local Integer NBDEL_ASM1         : # Number of records deleted in ASYSSMEXTERN session table
  Local Integer NBDEL_ASM2         : # Number of records deleted in ASYSSMPROCES session table
  Local Integer ASTATUS
  Local Char    MESSAGE(250)       : # Message in case of error returned by Funprog

  Gosub INIT_PARENT_ACTION
  # Delete dead sessions for current folder which is a root folder
  [L]ASTATUS = func ASESSIONS.RAZ_DEAD_SESSION (nomap, [L]NBDEL_ASM3, [L]NBDEL_ASM0, [L]NBDEL_ASM1, [L]NBDEL_ASM2, [L]MESSAGE)
  If [L]NBDEL_ASM3>0 | [L]NBDEL_ASM0>0 | [L]NBDEL_ASM1>0 | [L]NBDEL_ASM2
# Comment this line to manage the log file correctly after 2018R02
#    Call STRACE(FICTRA,55500,0,[L]PARENT_ACTION+" - Dead session management:"-mess(246,100,1)+" :"+" ASYSSMDBASSO="+num$([L]NBDEL_ASM3) +
#&                                                                                                  " ASYSSMINTERN="+num$([L]NBDEL_ASM0) +
#&                                                                                                  " ASYSSMEXTERN="+num$([L]NBDEL_ASM1) +
#&                                                                                                  " ASYSSMPROCES="+num$([L]NBDEL_ASM2))
  Endif
  If [L]ASTATUS<>[V]CST_AOK
# Comment this line to manage the log file correctly after 2018R02
#    Call STRACE(FICTRA,57500,0,[L]PARENT_ACTION+" - Dead session management:"-mess(218,123,1)+" #"+num$([L]ASTATUS)+" : "+[L]MESSAGE)
  Endif
Return

#####################################################
##  Actualisation de l'état des requêtes en cours  ##
#####################################################

## 1: En attente
## 2: En cours
## 3: Terminée
## 4: Bloquée
## 5: A tuer
## 6: Avortée
## 7: Erreur
## 8: Hors délai
#######################################################
$ETAT_RQT
  # Retreiving DATE/TIME if we update the Request record
  Gosub DATE_HEURE

  # We remove Dead sessions in ASYS* session tables (ASYSSMDBASSO, ASYSSMINTERN, ASYSSMEXTERN, ASYSSMPROCES)
  Gosub DEAD_SESSION From SERVEUR
  # X3-76574 JPGA - CAREFUL : Make sure DEAD_SESSION is used before launching ETAT_RQT or TIMOUT

  # X3-64516 - JPGA - 2017-12-18 : Manage the kill of a session in Batch requests ( in multi-runtime environments with Load balancer such as Mindo : impossible to test adxmac(-1))
  Filter [ABR] Where (FLAG=2 or FLAG=5)
  For [ABR]NUMREQ
    # X3-76574 JPGA - CAREFUL : Make sure DEAD_SESSION has been launched before testing existence in ASYSSMDBASSO so as to remove dead sessions.
    MORT = ! func ASESSIONS.IS_SESSION_EXISTENT_IN_ASYSSMDBASSO([F:ABR]SESSIONID)
    If MORT=[V]CST_ATRUE       : # Dead session but Request still Pending or to kill
      Call STRACE(FICTRA,30010,[F:ABR]NUMREQ,"ETAT_RQT - Dead session management:"-func AFNC.MES1(mess(247,100,1), num$([F:ABR]SESSIONID))-"("+[F:ABR]PROCESS+")") : # Session $1$ does not exists
      Gosub UPDATE_QUERY_TO_ABORTED
      If GOK>0
        Gosub INTER_RQT
      Endif
    Else
      Case [F:ABR]FLAG
        When 2                         : # In progress
          Gosub VERFKIL_JOB
          If KILJOB                    : # If Kill job file present : The session has to be killed
            Call STRACE(FICTRA,30010,[F:ABR]NUMREQ,"ETAT_RQT - Killing job management:"-func AFNC.MES1(mess(130,134,1), num$([F:ABR]NUMREQ))) : # Request $1$ killed by Job file
            # We initiate the Session closure calling a SYRACUSE function
            [L]MESSAGE  = [F:ABR]SERVER-num$([F:ABR]PORT)-[F:ABR]PROCESS-[F:ABR]DOSSIER-[F:ABR]USER
            [L]LECTRACE = [V]CST_ANO
            Call CLOSE_SOCKET_WITH_LOG(num$([F:ABR]SESSIONID), null, [F:ABR]PROCESS, [L]MESSAGE, [L]LECTRACE, [L]OUTPUT_LOGNAME) From ASESSIONS

            # X3-76574 JPGA - CAREFUL : We check directly the Database existence to know if session is still ACTIVE
            MORT = ! func ASESSIONS.PROCESS_RUNNING([F:ABR]SESSIONID)
            If MORT=[V]CST_ATRUE       : # Dead session
              Gosub KIL_JOB
              Call DELJOB([F:ABR]JOB,"run") From SERVJOB
            Else                       : # Session still Alive
              MESSA = mess(42,134,1)-num$([F:ABR]PROCESS) : # Arrêt impossible du processus numéro
              Call STRACE(FICTRA,35000,[F:ABR]NUMREQ,"ETAT_RQT - Killing job management:"-MESSA)
              Call RTRACE(FICTRQ,35000,MESSA)
            Endif
          Elsif [F:ABR]TIMOUT<>0       : # Session Alive and a Timeout exists for this request
            MINUTES  = 24*60*(DD-[F:ABR]DAT)
            MINUTES += 60*(val(left$(HH,2))-val(left$([F:ABR]HEURE,2)))
            MINUTES += val(right$(HH,3))-val(right$([F:ABR]HEURE,3))
            If MINUTES>[F:ABR]TIMOUT   : # Session Alive - A timeout expired : we kill the socket of the request
              Call STRACE(FICTRA,30010,[F:ABR]NUMREQ,"ETAT_RQT - Timeout management:"-func AFNC.MES1(mess(251,100,1), num$([F:ABR]NUMREQ))-"("+num$(MINUTES)+">"+num$([F:ABR]TIMOUT)+")") : # Timeout
              KILRQT = 0
              Gosub KILL_RQT
            Endif
          Endif
        When 5                         : # To be killed
          Call STRACE(FICTRA,30010,[F:ABR]NUMREQ,"ETAT_RQT - Sessions to be killed management:"-mess(248,100,1)-num$([F:ABR]SESSIONID)) : # Closing session
          KILRQT = 1
          Gosub KILL_RQT
       Endcase
    Endif
  Next ABR
  Filter [ABR]
Return


#######################################################
#######################################################
$EXEC_RQT
#119378
PID=""
Raz X3SESSIONID  # X3-55215
##  Flag de la requête : flag à 2
Call DEBTRANS From GLOCK
Gosub TR_EXEC_RQT
If GOK<=0 : Return : Endif

#Call TRACE_LOG("[f:abr]numreq="+num$([F:ABR]NUMREQ)-"[f:abr]tache="+[F:ABR]TACHE,0,1) From SERVEUR

##  Lancement de la requête
#109897
#  Trace du serveur, activation requête
PID=num$(adxpid)
X3SESSIONID=adxuid(1)    # X3-55215
Call STRACE(FICTRA,51000,[F:ABR]NUMREQ,"EXEC_RQT - Query execution management:"-mess(15,134,1)-"("+RQTID-PID-num$(X3SESSIONID)+")") From SERVEUR

##  Création du fichier .run
If [F:ABR]JOB<>""
 MESSA = mess(15,134,1)-"(PID "+num$(PID)+" X3SESSIONID"-num$(X3SESSIONID)+")"
 Call WRJOB([F:ABR]JOB,"run",51000,[F:ABR]NUMREQ,[F:ABR]DOSSIER,[F:ABR]USER,[F:ABR]LAN,[F:ABR]TACHE,MESSA) From SERVJOB
Endif

##  Le .req devient .old
If [F:ABR]JOB<>""
 Call MOVEJOB([F:ABR]JOB,"req","old") From SERVJOB
Endif

##  Flag de la requête
Call DEBTRANS From GLOCK
Gosub TR_EXEC_RQT
Call TRACE_LOG("[f:abr]numreq="+num$([F:ABR]NUMREQ)-"[f:abr]tache="+[F:ABR]TACHE-"[f:abr]flag="+num$([F:ABR]FLAG),0,1) From SERVEUR

NBPROC += 1
Return

###################
$TR_EXEC_RQT
GOK = 1
Trbegin [ABR]
 #119378 : inutile
 #Read [ABT]CODTAC = [F:ABR]TACHE
 Readlock [ABR]NUMREQ=[F:ABR]NUMREQ With lockwait=0
 If fstat : GOK=-1 : Goto AB_EXEC_RQT : Endif
 [F:ABR]FLAG  = 2
 [F:ABR]PROCESS = PID
 [F:ABR]SESSIONID = X3SESSIONID   # X3-55215
 [F:ABR]DAT   = DD
 [F:ABR]HEURE = HH
 [F:ABR]HDEB  = HS
 Rewrite [ABR]
 If fstat
  GOK=0 : Call STRACE(FICTRA,42000,[F:ABR]NUMREQ,mess(13,100,1)-"ABATRQT") : Goto AB_EXEC_RQT
 Endif
Commit
Return

$AB_EXEC_RQT
Rollback
Return

$ERREUR
GERREUR = errn
GMESSAGE = errp+"("+num$(errl)+")"-mess(6,123,1)-num$(GERREUR)-":"-errmes$(GERREUR)-errm
Call STRACE(FICTRA,52000+GERREUR,0,GMESSAGE)
Gosub ARRET
End

# X3-76574 JPGA - CAREFUL : TIMOUT and ETAT_RQT has been joined in only one procedure
$TIMOUT
Return

#################################
##  Suppression d'une requête  ##
#################################
$KILL_RQT
  Gosub IDENT_RQT

  # Retreiving DATE/TIME if we update the Request record
  Gosub DATE_HEURE

  # We initiate the Session closure calling a SYRACUSE function
  [L]MESSAGE  = [F:ABR]SERVER-num$([F:ABR]PORT)-[F:ABR]PROCESS-[F:ABR]DOSSIER-[F:ABR]USER
  [L]LECTRACE = [V]CST_ANO
  Call CLOSE_SOCKET_WITH_LOG(num$([F:ABR]SESSIONID), null, [F:ABR]PROCESS, [L]MESSAGE, [L]LECTRACE, [L]OUTPUT_LOGNAME) From ASESSIONS
  If [L]OUTPUT_LOGNAME<>""
    MESSA=mess(250,100,1)-num$([F:ABR]SESSIONID)-"-"-func AFNC.MES1(mess(131,134,1), [L]OUTPUT_LOGNAME)  : # HTTP error encountered in session closure
    Call STRACE(FICTRA,32200,[F:ABR]NUMREQ,"KILL_RQT - Aborted query management:"-MESSA-"("+RQTID+")")
  Endif

  Gosub UPDATE_QUERY_TO_ABORTED
  If GOK<1 : Return : Endif
  Gosub INTER_RQT

  #109897
  If KILRQT & !KILRECURRENT
    MESSA = mess(51,134,1)-'"'+[F:ABR]MOTINT+'"' : # Requête interrompue par # pour le motif
    I = instr(1,MESSA,"#")
    If I : MESSA = left$(MESSA,I-1)+[F:ABR]USRINT+right$(MESSA,I+1) : Endif
    ERR = 32000
  #109897
  Elsif KILSRV | KILRECURRENT
    MESSA = mess(65,134,1)                       : # Interruption de toutes les requêtes
    ERR = 34000
  Else
    MESSA = mess(10,134,1)                       : # Requête interrompue par le serveur (time-out)
    ERR = 33000
  Endif

  Call STRACE(FICTRA,ERR,[F:ABR]NUMREQ,"KILL_RQT - Aborted query management:"-MESSA-"("+RQTID+")")
  Call RTRACE(FICTRQ,ERR,MESSA)
  Call MESSAGE(num$(ERR)-MESSA)

  ##  Suppression fichier .run
  If [F:ABR]JOB<>""
    Call DELJOB([F:ABR]JOB,"run") From SERVJOB
  Endif

  KILRQT = 0
Return

##################################
##  Interruption d'une requête  ##
##################################
$INTER_RQT
  Gosub IDENT_RQT
  Gosub INIT_PARENT_ACTION

  MESSA = func AFNC.MES3(mess(114,134,1),num$([F:ABR]NUMREQ),mess([L]PREVFLAG,21,1),mess([F:ABR]FLAG,21,1)) #   Modification of the request status $1$: $2$ -> $3$
  ERR = 30000

  Call STRACE(FICTRA,ERR,[F:ABR]NUMREQ,[L]PARENT_ACTION+" INTER_RQT - Interupted query management:"-MESSA-"("+RQTID+")")
  Call RTRACE(FICTRQ,ERR,MESSA)
  Call MESSAGE(num$(ERR)-MESSA)

  ##  Suppresion fichier .run
  If [F:ABR]JOB<>""
    Call DELJOB([F:ABR]JOB,"run") From SERVJOB
  Endif
Return

###########################
##  Identifiant requête  ##
###########################
$IDENT_RQT
RQTID  = [F:ABR]DOSSIER - [F:ABR]TACHE
RQTID -= left$(mess([F:ABR]TYPTAC,20,1),1) - [F:ABR]ETAT
#109897
FICTRQ = func SERVSYS.GET_FILE_RQT(format$("N0:8#",[F:ABR]NUMREQ),"tra")         # Issue X3-70499 - 2018-03-05 by CCC : whole path => with extension file
Return

$UPDATE_QUERY_TO_ABORTED
[L]PREVFLAG=[F:ABR]FLAG
GOK = 1
Trbegin [ABR]
 REQNUM = [F:ABR]NUMREQ
 [F:ABR]FLAG = 6
 [F:ABR]DFIN = DD
 [F:ABR]HFIN = HS
 Rewrite [ABR]
 If fstat
  GOK = 0
  Call STRACE(FICTRA,42000,[F:ABR]NUMREQ,mess(13,100,1)-"ABATRQT")
  Rollback
  Return
 Endif
Commit
NBPROC -= 1
Return

###################
##  Abonnements  ##
###################
$AUTO
Gosub DATE_HEURE
Call DEBTRANS From GLOCK
Gosub TR_AUTO
Return

$TR_AUTO
GPE = 0
GPOINT = "STRABA" : Gosub ENTREE From EXEFNC
If !GPE
 GOK=1
 Trbegin [ABA] , [ABD] , [ABR] , [ABP]
  For [ABA] Where [F:ABA]ENAFLG=2 & ([F:ABA]DJOUR<DD | [F:ABA]DREL=2) With Lock
   #109897 add DREL
   If fstat=0
    Gosub VERIF_DAT
    If OKDAT
     Gosub VERIF_PAR
     If OKPAR
      Readlock [ABP]SPOOL First With lockwait=5
      If fstat
       GOK=0
       Call STRACE(FICTRA,44000,0,mess(58,134,1)-"ABATPAR/ABA")
       Break
      Endif
      Raz HREQ
      GPE = 0
      GPOINT = "READABA" : Gosub ENTREE From EXEFNC
      If !GPE
       If [F:ABA]GRP=""
        NUMLIG = 1
        GRPNUM(0) = 0
        GRPSEQ = 0
        If dim([F:ABA]CNTERR)>0
         [L]CNTERR = [F:ABA]CNTERR
        Endif
        Read [ABT]CODTAC = [F:ABA]TACHE
        FLG = 1
        Gosub SETRQT
       Else
        Read [ABG]ABG0 = [F:ABA]GRP
        If fstat
            GOK = 0
            Call STRACE(FICTRA,27000,0,func GLOCK.GET_FSTAT_MSG(fstat)-"ABATGRP"-[F:ABG]CODGRP)
            Break
        Endif
        # Check that sequence number of tasks are all initialized
        If [F:ABG]NBTAC>0 & find(0,[F:ABG]SEQ(0..[F:ABG]NBTAC-1))>0
            Call INISEQ([F:ABG]SEQ, [F:ABG]NBTAC) From SUBABG
            Rewrite [ABG]
            If fstat
                GOK=0
                Call STRACE(FICTRA,27000,0,func GLOCK.GET_FSTAT_MSG(fstat)-"ABATGRP"-[F:ABG]CODGRP)
                Break
            Endif
        Endif

        GRPNUM(0) = [F:ABP]NUMREQ
        If dim([F:ABG]CNTERR)>0
         [L]CNTERR = [F:ABG]CNTERR
        Endif
        For NUMLIG=1 To [F:ABG]NBTAC
         Read [ABT]CODTAC = [F:ABG]CODTAC(NUMLIG-1)
         # Issue X3-59123 - 2018-05-28 by CCC : Use sequence number to run 1st set of tasks
         If NUMLIG=1 | [F:ABG]SEQ(NUMLIG-1)=[F:ABG]SEQ(0)
            FLG = 1
         Else
            FLG = 4
         Endif
         GRPSEQ = [F:ABG]SEQ(NUMLIG-1)
         Gosub SETRQT
         If GOK<1 : Break : Endif
        Next NUMLIG
       Endif
       If GOK<1
        GCLE = num$([F:ABR]NUMREQ) - "(" + [F:ABA]CODABT + ")"
        Call STRACE(FICTRA,42000,0,mess(13,100,1)-"ABATRQT"-GCLE)
        Break
       Elsif HREQ<>"" : # On a au moins lancé une requête !
        [F:ABA]DREL = 1 : #109897
        [F:ABA]DJOUR = DD
        Rewrite [ABA]
        If fstat
         GOK = 0
         GCLE = [F:ABA]CODABT - "(" + num$([F:ABR]NUMREQ) + ")"
         Call STRACE(FICTRA,42000,0,mess(13,100,1)-"ABATABT"-GCLE)
         Break
        Endif
       Endif
       Rewrite [ABP]
       If fstat
        GOK = 0
        Call STRACE(FICTRA,44000,0,mess(13,100,1)-"ABATPAR")
        Break
       Endif
      Endif
     Endif
    Endif
   Endif
  Next
  If GOK<1 : Goto AB_AUTO : Endif
 Commit
Endif
Return

$AB_AUTO
Rollback
Return

$SETRQT
Local Integer ABR_CREATED    # To know if a request has been create
Local Integer REQ_FORCED     # To know if a request has already been created because it has been forced
Raz [F:ABR]
[F:ABR] = [F:ABA]
[F:ABR] = [F:ABT]
[F:ABR]TACHE  = [F:ABT]CODTAC
[F:ABR]ETAT   = [F:ABT]TRAIT
[F:ABR]FLAG   = FLG
[F:ABR]DAT    = DD
If dim([F:ABR]CNTERR)>0
  [F:ABR]CNTERR = [L]CNTERR
Endif
HREQ = ""

If [F:ABA]HDEB<>""      # a frequency is defined
    If HH>=[F:ABA]HDEB & HH<=[F:ABA]HFIN
        HREQ = HH
        [F:ABR]HEURE  = HREQ
        [F:ABR]FRQ    = [F:ABA]FRQ
        [F:ABR]FRQFIN = [F:ABA]HFIN
        [F:ABR]HFIN   = ""
        H=0
        Gosub CREATE_ABR
    Endif
Else    # Fixed time scheduled
    REQ_FORCED = [V]CST_AFALSE
    For H=0 To dim([F:ABA]HEURE)-1
        If [F:ABA]GRP=""
            GRPNUM(H) = 0
        Elsif NUMLIG=1
            GRPNUM(H) = [F:ABP]NUMREQ
        Endif
        If [F:ABA]HEURE(H)<>"" & [F:ABA]HEURE(H)<>"0000"
            # Issue X3-107990 - 2018-09-17 by CCC
            # If the recurring task is scheduled later or must be forced (just once!)
            If [F:ABA]HEURE(H)>=HH | dim([F:ABA]FORCE)>0 & [F:ABA]FORCE=2 & REQ_FORCED=[V]CST_AFALSE
                HREQ = [F:ABA]HEURE(H)
                [F:ABR]HEURE = HREQ
                [F:ABR]HFIN  = ""
                Gosub CREATE_ABR
                If GOK=0 : Break : Endif
                If ABR_CREATED = [V]CST_ATRUE
&                & [F:ABA]HEURE(H)<HH & dim([F:ABA]FORCE)>0 & [F:ABA]FORCE=2 & REQ_FORCED=[V]CST_AFALSE
                    # store the fact that the creation of the request has been forced
                    REQ_FORCED = [V]CST_ATRUE
                Endif
            Endif
        Endif
    Next H
Endif
Return

# Issue X3-107990 - 2018-09-17 by CCC : group the way to create tha ABR record
$CREATE_ABR
ABR_CREATED = [V]CST_AFALSE
GPE = 0
GPOINT = "REQUETE" : Gosub ENTREE From EXEFNC
If !GPE
    For [ABD]ABD0(3) Where CODABT=[F:ABA]CODABT & CODTAC=[F:ABT]CODTAC & LIG=NUMLIG
        [F:ABR] = [F:ABD]
        [F:ABR]NUMREQ = [F:ABP]NUMREQ
        [F:ABP]NUMREQ += 1
        [F:ABR]NUMGRP = GRPNUM(H)
        [F:ABR]SEQGRP = [L]GRPSEQ     # Issue X3-59123 - 2018-05-29 by CCC : add sequence in group of tasks
        Write [ABR]
        If fstat : GOK = 0 : Break : Endif
        CPT = 0
        For [F:ABD]ABD0
            If [F:ABD]PARAM <> ""
                CPT+=1
                Raz [F:ABL]
                [F:ABL]NUMREQ = [F:ABR]NUMREQ
                [F:ABL]PARAM  = [F:ABD]PARAM
                [F:ABL]VALEUR = [F:ABD]VALEUR
                [F:ABL]NUM    = CPT
                Write [ABL]
                If fstat : GOK = 0 : Break 2 : Endif
            Endif
        Next ABD
        ABR_CREATED = [V]CST_ATRUE
    Next ABD
    Filter [ABD]
Endif
Return

$VERIF_DAT
OKDAT  = ([F:ABA]PERIO=1 & [F:ABA]JOUR(dayn(DD)-1)=2)
OKDAT += ([F:ABA]PERIO=2 & (find(day(DD),[F:ABA]QUANT) | (DD=eomonth(DD) & [F:ABA]FDM=2)))
If OKDAT
 If [F:ABA]CAL<>""
  Read [F:ABC]ABC0=[F:ABA]CAL
  If [F:ABC]NBRDAT>0
   If find(DD,[F:ABC]STRDAT) | find(DD,[F:ABC]ENDDAT)
    OKDAT = 0
   Else
    For K=0 To [F:ABC]NBRDAT-1
     If DD>=[F:ABC]STRDAT(K) & DD<=[F:ABC]ENDDAT(K)
      OKDAT = 0 : Break
     Endif
    Next K
   Endif
  Endif
 Endif
Endif
Return

$VERIF_PAR
OKPAR = 1
OKDOS = 1
If [F:ABA]GRP=""
 NUMLIG = 1
 Read [ABT]CODTAC = [F:ABA]TACHE
 Gosub VERFPAR
Else
 Read [ABG]ABG0 = [F:ABA]GRP
 For NUMLIG=1 To [F:ABG]NBTAC
  Read [ABT]CODTAC = [F:ABG]CODTAC(NUMLIG-1)
  Gosub VERFPAR
  If !OKPAR : Break : Endif
 Next NUMLIG
Endif
fstat = 0 : # A cause du For with lock
Return

$ERRDOS
OKDOS = 0
Resume

$VERFPAR
If [F:ABT]FONCTION<>""
 Onerrgo ERRDOS
 Local File =[F:ABA]DOSSIER+".AFONCTION" [AFC], =[F:ABA]DOSSIER+".ACTION" [ACT]
 Onerrgo ERREUR
 If !OKDOS : OKPAR = 0 : Return : Endif
 Read [AFC]CODINT = [F:ABT]FONCTION
 If !fstat & [F:AFC]ACTION<>""
  Read [ACT]ACTION = [F:AFC]ACTION
  If !fstat & [F:ACT]PARAM4<>""
   Look [ABD]ABD0 = [F:ABA]CODABT;[F:ABT]CODTAC;NUMLIG
   If fstat
    OKPAR = 0 : # mb 19.4.2 bug 14020 Les paramètres de l'abonnement doivent être saisis
   Endif
  Endif
 Endif
 Close Local File [AFC], [ACT]
Endif
Return

# X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
######################################################################################
##  BATCH SERVER DATE/TIME USED DEPENDING ON ADXTYP SESSION
######################################################################################
#**
#* SCHEDULING_DATE_TIME **** Function giving Date and Time for internal BATCH server management (functions and labels) depending on ADXTYP session
#*
#* @param OUTPUT_DD    : Date          returned.        : 20171207
#* @param OUTPUT_HH    : Time HHMM     returned. Format : 1532
#* @param OUTPUT_HS    : Time HHMMSS   returned. Format : 153201
#*
#*!
Subprog SCHEDULING_DATE_TIME( OUTPUT_DD, OUTPUT_HH, OUTPUT_HS)
Variable Date    OUTPUT_DD
Variable Char    OUTPUT_HH
Variable Char    OUTPUT_HS

Local Integer    SECOND_SS

  If adxtyp=33 | adxtyp=35                   : # For Syracuse and Batch type of sessions - Taking Database Date/Time
    Call SCHEDULING_DATE_TIME_DB ( OUTPUT_DD, OUTPUT_HH, OUTPUT_HS)
  Else                                       : # For other type of session - Taking Applicative Runtime Date/Time
    Call SCHEDULING_DATE_TIME_APP( OUTPUT_DD, OUTPUT_HH, OUTPUT_HS)
  Endif
End

######################################################################################
##  BATCH SERVER APPLICATIVE RUNTIME DATE/TIME ONLY WITH EVENTUAL WAITING
######################################################################################
#**
#* SCHEDULING_DATE_TIME_APP **** Function giving Date and Time retreived from Applicative Runtime with eventually a delay after 23H59
#*
#* @param OUTPUT_DD    : Date          returned.        : 20171207
#* @param OUTPUT_HH    : Time HHMM     returned. Format : 1532
#* @param OUTPUT_HS    : Time HHMMSS   returned. Format : 153201
#*
#*!
Subprog SCHEDULING_DATE_TIME_APP( OUTPUT_DD, OUTPUT_HH, OUTPUT_HS)
Variable Date    OUTPUT_DD
Variable Char    OUTPUT_HH
Variable Char    OUTPUT_HS

Local Integer    SECOND_SS

  Call GET_INSTANT_DATE_TIME_APP( OUTPUT_DD, OUTPUT_HH, OUTPUT_HS, [L]SECOND_SS)

  If OUTPUT_HH >= "2359"
    Sleep (60-[L]SECOND_SS+1)                : # Waiting till 00:00 to take Date/Time
    Call GET_INSTANT_DATE_TIME_APP( OUTPUT_DD, OUTPUT_HH, OUTPUT_HS, [L]SECOND_SS)
  Endif
End

######################################################################################
##  BATCH SERVER DATABASE DATE/TIME ONLY WITH EVENTUAL WAITING
######################################################################################
#**
#* SCHEDULING_DATE_TIME_DB **** Function giving Date and Time retreived from Database with eventually a delay after 23H59
#*
#* @param OUTPUT_DD    : Date          returned.        : 20171207
#* @param OUTPUT_HH    : Time HHMM     returned. Format : 1532
#* @param OUTPUT_HS    : Time HHMMSS   returned. Format : 153201
#*
#*!
Subprog SCHEDULING_DATE_TIME_DB( OUTPUT_DD, OUTPUT_HH, OUTPUT_HS)
Variable Date    OUTPUT_DD
Variable Char    OUTPUT_HH
Variable Char    OUTPUT_HS

Local Integer    SECOND_SS
Local    Char    REQSQL (250)

  Call GET_INSTANT_DATE_TIME_DB( OUTPUT_DD, OUTPUT_HH, OUTPUT_HS, [L]SECOND_SS)

  If OUTPUT_HH >= "2359"
    Sleep (60-[L]SECOND_SS+1)                : # Waiting till 00:00 to take Date/Time
    Call GET_INSTANT_DATE_TIME_DB( OUTPUT_DD, OUTPUT_HH, OUTPUT_HS, [L]SECOND_SS)
  Endif
End

######################################################################################
##  BATCH SERVER RUNTIME DATE/TIME ONLY
######################################################################################
#**
#* GET_INSTANT_DATE_TIME_APP **** Function giving instant Date and Time retreived currently from Runtime
#*
#* @param OUTPUT_DD    : Date          returned.        : 20171207
#* @param OUTPUT_HH    : Time HHMM     returned. Format : 1532
#* @param OUTPUT_HS    : Time HHMMSS   returned. Format : 153201
#* @param OUTPUT_SS    : Seconds       returned.        : 1
#*
#*!
Subprog GET_INSTANT_DATE_TIME_APP( OUTPUT_DD, OUTPUT_HH, OUTPUT_HS, OUTPUT_SS)
Variable Date    OUTPUT_DD
Variable Char    OUTPUT_HH
Variable Char    OUTPUT_HS
Variable Integer OUTPUT_SS

  OUTPUT_DD = date$
  OUTPUT_HH = left$(time$,2)+mid$(time$,4,2)
  OUTPUT_HS = left$(time$,2)+mid$(time$,4,2)+right$(time$,7)
  OUTPUT_SS = val(right$(time$,7))
End

######################################################################################
##  BATCH SERVER DATABASE DATE/TIME ONLY
######################################################################################
#**
#* GET_INSTANT_DATE_TIME_DB **** Function giving instant Date and Time retreived currently from Database
#*
#* @param OUTPUT_DD    : Date          returned.        : 20171207
#* @param OUTPUT_HH    : Time HHMM     returned. Format : 1532
#* @param OUTPUT_HS    : Time HHMMSS   returned. Format : 153201
#* @param OUTPUT_SS    : Seconds       returned.        : 1
#*
#*!
Subprog GET_INSTANT_DATE_TIME_DB( OUTPUT_DD, OUTPUT_HH, OUTPUT_HS, OUTPUT_SS)
Variable Date    OUTPUT_DD
Variable Char    OUTPUT_HH
Variable Char    OUTPUT_HS
Variable Integer OUTPUT_SS

Local    Char    REQSQL (250)

  #2015-12-11 11:28:11
  If GTYPDBA=1         : #ORACLE
    [L]REQSQL="SELECT to_char(SYSDATE,'YYYY-MM-DD HH24:MI:SS') FROM DUAL"
  Else                 : #SQLSERVER
    #select convert(varchar,GETDATE(),120)
    [L]REQSQL="SELECT CONVERT(VARCHAR(20),GETDATE(),120)"
  Endif

  For (Char VDATE(20)) From num$(GTYPDBA*2+1) Sql [L]REQSQL As [SQLREQ]
    OUTPUT_DD = gdat$(val(mid$([F:SQLREQ]VDATE,9,2)),val(mid$([F:SQLREQ]VDATE,6,2)),val(left$([F:SQLREQ]VDATE,4)))
    OUTPUT_HH = mid$([F:SQLREQ]VDATE,12,2)+mid$([F:SQLREQ]VDATE,15,2)
    OUTPUT_HS = mid$([F:SQLREQ]VDATE,12,2)+mid$([F:SQLREQ]VDATE,15,2)+mid$([F:SQLREQ]VDATE,18,2)
    OUTPUT_SS = val(mid$([F:SQLREQ]VDATE,18,2))
  Next
End

######################################################################################
##  BATCH SERVER DATE RETURNED FORMATED
######################################################################################
#**
#* GET_DATE_FROM_GLOBAL_FORMAT **** Function giving Date formatted from Global format variables
#*
#* @param  INPUT_DATE  : Date type as input. Format like : date$
#*
#* @return OUTPUT_DATE = Date formatted. Default : YY/MM/DD <br>
#*!
Funprog GET_DATE_FROM_GLOBAL_FORMAT ( INPUT_DATE)
Value    Date    INPUT_DATE

Local    Char    OUTPUT_DATE(20)

  If dim(GFMDAT)>0 & GFMDAT<>""
    [L]OUTPUT_DATE = format$("D:"+GFMDAT, INPUT_DATE)
  Elsif dim(GFMD)>0 & GFMD<>""
    [L]OUTPUT_DATE = format$(GFMD, INPUT_DATE)
  Else
    [L]OUTPUT_DATE = format$("D:YY[/]MM[/]DD", INPUT_DATE)
  Endif
End [L]OUTPUT_DATE

######################################################################################
##  Messages utilisateur envoyés par le serveur batch en cas de kill d'une requête
######################################################################################

Subprog MESSAGE(GMESSAGE)
Local Integer  I , J , K , L , C , D , F , OK
Local Char     USER(20)
Local Char     FORMULE(250)
Local Clbfile  TEXCLB(5) , TEXTMP(5)
Local Char     TEXLIG(200)(1..200)
Local Char     TEXOBJ(250)
Local Integer  DELEG , COND(1..10)
Local Char     DEST(80) , EMAIL(80) , TOP(80)
Local Char     USR_EMAIL(80)(1..99) , USR_CODE(20)(1..99) , USR_NATURE(20)(1..99)
Local Char     USR_TOP(20)(1..99)
Local Integer  USR_SUIVI(1..99) , USR_ENVOI(1..99) , USR_DEL(1..99) , USR_NB
Local Char     CHAINE(250)
Local Char     PCEJOI(200)(1..5)
Local Integer  NBJOI , TYPEVT
Local Integer  ERN , ERT , ERD , SIMUL
Local Char     ERM(250) , CODEVT(10)
Global Char    GSERMES(80)

GPOINT = "KILREQ" : Gosub ENTREE From EXEFNC : # mb 2.10.3 bug 18666

If [F:ABR]DOSSIER="" or [F:ABR]MESSAGE<>2 : End : Endif

Onerrgo ERR From AWRK
Local File =[F:ABR]DOSSIER+".AUTILIS"     [AUS2]
Local File =[F:ABR]DOSSIER+".AWRKPAR"     [AWA]
Local File =[F:ABR]DOSSIER+".AWRKPARH"    [AWH]
Local File =[F:ABR]DOSSIER+".AWRKUSR"     [AWU]
Local File =[F:ABR]DOSSIER+".ADOVAL"      [ADW]
If filinfo(filpath("FIL","CONTACTCRM","fde",[F:ABR]DOSSIER),0)>0
 Local File =[F:ABR]DOSSIER+".CONTACTCRM" [AIN]
Endif
If filinfo(filpath("FIL","CONTACT","fde",[F:ABR]DOSSIER),0)>0
 Local File =[F:ABR]DOSSIER+".CONTACT"    [CNT]
Elsif filinfo(filpath("FIL","CONTACT2","fde",[F:ABR]DOSSIER),0)>0
 Local File =[F:ABR]DOSSIER+".CONTACT2"   [CNT]
Endif
Onerrgo
If ERN : End : Endif

Call PARAM("","SERMES",GSERMES) From ADOVAL
Read [AUS2]CODUSR = GUSER
If !fstat : GNOMUSER = [F:AUS2]NOMUSR : Endif

For [AWA]AWA1 Where ENAFLG=2 & TYPEVT=6 & ENAMES=2
 ERD = 0
 If [F:AWA]CODEVT="" or [F:AWA]CODEVT=[F:ABR]TACHE
  Read [AWH]AWH0 = [F:AWA]CODE
  Gosub CTL_CONDIT From AWRK
  If OK
   Gosub TRT_DEST From AWRK
   If !ERN & USR_NB>0
    Gosub TRT_TEXTE From AWRK
    If !ERN
     Call ENVOI_MAIL([F:AWA]TYPMES,1,2,GUSER,"","",""
&                    ,num$([F:ABR]NUMREQ),ERD,USR_EMAIL,USR_ENVOI,USR_SUIVI,USR_NB,TEXCLB,TEXOBJ
&                    ,PCEJOI,NBJOI,[F:AWA]TYPJOI,[F:AWA]CATJOI,"") From AWRKMEL
    Endif
   Endif
  Endif
 Endif
Next AWA

End

####################################
##  Ecriture trace Serveur batch
####################################

Subprog STRACE(FICTRA,ERR,REQUETE,COMMENT)
Value Char    FICTRA
Value Integer ERR
Value Integer REQUETE
Value Char    COMMENT
Goto TRACE

$VERROU
Local Char    FICLCK(GDIMFIC)
Local Integer I , VERROU
FICLCK = FICTRA+".lck" : # Il n'y a qu'une trace serveur pour +sieurs applis
VERROU = 0
While I<20
 If filinfo(FICLCK,0)<0
  Openo FICLCK,0 Using [LCK_]
  Wrseq GUSER-date$-time$ Using [LCK_]
  Openo Using [LCK_]
  VERROU = 1
  Break
 Endif
 Sleep 1
 I += 1
Wend
Return

$DEVERROU
If dim([L]VERROU)>0 & [L]VERROU
 Call EFFACE([L]FICLCK,I) From ORDSYS
Endif
Return

#------------------------------------------------------------------#
Subprog TRACE_LOG(MESSAGE,NUMREQ,COMPLET)
Value Char    MESSAGE
Value Integer NUMREQ , COMPLET
Local Char FICHIER(255)
#Local File ABATPAR [ABP_]
#Read [ABP_]SPOOL First
If [L]NUMREQ>0
 #109897
 FICHIER=func SERVSYS.GET_ONEFILE_BATCH("tmp","RQT"+format$("N0:8#",[L]NUMREQ),"log")
Else
 FICHIER=func SERVSYS.GET_ONEFILE_BATCH("tmp","SRV","log")
Endif
Openo FICHIER Using [SS]
Wrseq date$-time$-format$("N0:8#",[L]NUMREQ)-ctrans(MESSAGE) Using [SS]
If COMPLET
 If dim([S]secmod)>0 & dim([S]adxcpw)>0
  If [S]adxcpw<>"" : # Passwd passé par le serveur batch
   Wrseq space$(27)+"passwd=";[S]adxcpw;" "; Using [SS]
   If [S]secmod=2 : # Kerberos
    Wrseq "Kerberos" Using [SS]
   Else
    Wrseq Using [SS]
   Endif
  Endif
 Endif
 If [L]NUMREQ<>0
  Wrseq space$(27)+ctrans(mess(150,124,1))-num$(nbruser) Using [SS] : # Nb d'utilisateurs connectés
 Endif
Endif
Openo Using [SS]
#Close Local File [ABP_]
End

##############################
##  Ecriture trace requête
##############################

Subprog RTRACE(FICTRA,ERR,COMMENT)
Value Char    FICTRA
Value Integer ERR
Value Char    COMMENT
Goto TRACE

#------------------------------------------------------------------------------------------------------------#
# Messages spécifiques requêtes
#------------------------------------------------------------------------------------------------------------#
# 00000 : Requête terminée (normal)
# 0xxxx : Requête terminée avec avertissements (xxxx = nb erreurs dans la trace)
# 10000 : Requête terminée avec erreur inconnue (gok=0)
# 1000x : Fin requête avec erreur (Table,Abréviation,clé) (x=fstat) (si gok=0 : Call RSTA/FSTA From GLOCK)
# 11xxx : Erreur adonix exécution requête @trt.adx(lig) erreur no:message_adx message_syst) (xxx=GERREUR,errn)
# 12000 : Erreur de verrouillage (gok=-1)
# 13xxx : Fin requête avec erreur spécifique (+ contenu de GMESSBATCH) (xxx=GERRBATCH)
# 14xxx : Fin requête avec erreur adonix (@trt.adx(ligne) no_erreur:message_adx message_syst) (xxx=errn)
# 21000 : Délai dépassé
# 22000 : Tâche inexistante
# 22100 : Tâche inactive
# 23000 : Accès aux fichiers batchs interdit
# 23100 : Utilisateur # inconnu
# 23200 : Mot de passe incorrect pour l'utilisateur #
# 23300 : Exécution refusée par point d'entrée
# 23400 : Niveau d'accès # non autorisé à l'utilisateur
# 23500 : Fonction non autorisée à l'utilisateur #
# 24xxx : Passage en mono impossible car # utilisateurs connectés (xxx = nbruser)
# 25000 : Traitement inexistant
# 2600x : Structure fichier incorrecte (x=nb zones manquantes dans entête(1-7), cr/lf(8), trop de zones(9)
# 26100 : Date incorrecte
# 26120 : Date dépassée
# 26200 : Heure incorrecte
# 27000 : Groupe inexistant
# 27100 : Groupe inactif
# 27200 : Tâche # non paramétrée dans le groupe
# 27300 : Tâche # en erreur dans le groupe
# 27400 : Exécution impossible suite à erreur dans le groupe #
# 28000 : Dossier inexistant
# 29000 : Site non renseigné (Géode)
# 29100 : Site inexistant (Géode)
# 29200 : Déposant non renseigné (Géode)
# 29300 : Déposant inexistant (Géode)
# 30000 : Interruption requête (raison inconnue) Processus non trouvé pendant vérification état requête
# 30010 : Interruption requête (raison inconnue) Session non trouvée pendant vérification état requête
# 31000 : Requête interrompue par # pour le motif # (fichier .kil)
# 32000 : Requête interrompue par # pour le motif # (gestion des tâches)
# 32200 : Erreur HTTP rencontrée en suppression de socket de session
# 33000 : Interruption requête par serveur (time-out)
# 34000 : Interruption de toutes les requêtes (par fichier kill)
# 35000 : Arrêt impossible du processus no (par fichier kill)
# 35002 : Processus vide (time-out requête)
# 35102 : Processus vide (état requête)
# 41000 : Désynchro tâche (récupération processus impossible au lancement de la requête)
# 42000 : Pb accès à la table tâche
# 43000 : No requête inexistante
# 43100 : Requête inexistante ou non lancée
# 44000 : Pb accès à la table paramètres batch
# 45000 : Pb accès fichier job
# 52xxx : Erreur traitement + errn
#------------------------------------------------------------------------------------------------------------#
# Messages spécifiques serveur
#------------------------------------------------------------------------------------------------------------#
# 50000 : Activation serveur
# 51000 : Activation requête
# 52xxx : Erreur adonix xxx du serveur (suivi de l'arrêt du serveur)
# 53000 : Autres erreurs au démarrage du serveur
# 54000 : Lancement serveur alors qu'il est déjà actif
# 54100 : Epurations des requêtes
# 54200 : Kill du process du serveur batch
# 55000 : Désactivation serveur
# 55500 : Result of dead session management
# 56000 : Demande d'arrêt du serveur
# 57000 : Demande d'arrêt serveur alors qu'il est désactivé
# 57500 : Error in dead session management
# 58000 : Autres erreurs à l'arrêt du serveur
#------------------------------------------------------------------------------------------------------------#

$TRACE
Local Char SEP(1), SIG(1), USR(20)
Local Char HH(10), HS(10)
Local Integer SS
Local Date DD

SEP = " "

If find([L]ERR,0,50000,51000) | ([L]ERR>=55000 & [L]ERR<=56000)
 SIG = "=" : # Messages
Elsif [L]ERR<10000 | ([L]ERR>13000 & [L]ERR<13100) | find([L]ERR,31000,32000,34000,54000,54100,57000)
 SIG = ">" : # Warning
Else
 SIG = "<" : # Erreurs bloquantes
Endif

If [L]FICTRA<>""
 Onerrgo RIEN
 Openo [L]FICTRA Using [TRA]
 Iomode adxifs "" Using [TRA]
 Iomode adxirs chr$(10) Using [TRA]
 Iomode adxium GUTF8 Using [TRA]
 If filinfo([L]FICTRA,7)<=0
  If dim([L]REQUETE)>0
   Wrseq "#<AdxV"+GADOVERS+">@(#)%I%"-mess(76,134,1) Using [TRA] : # Trace du serveur de requêtes batch
  Else
   Wrseq "#<AdxV"+GADOVERS+">@(#)%I%"-mess(12,134,1)-[F:ABR]TACHE Using [TRA] : # Trace requête batch
  Endif
 Endif
 Iomode adxium GTRAFOR Using [TRA]
 Wrseq SIG;format$("N0:4#",mod([L]ERR,10000)); Using [TRA]
 If dim([L]REQUETE)>0
  Wrseq SEP;format$("N0:8#",[L]REQUETE); Using [TRA]
 Endif

 Wrseq SEP;func SERVEUR.GET_DATE_FROM_GLOBAL_FORMAT (date$); Using [TRA]
 Wrseq SEP;time$; Using [TRA]
 Wrseq SEP;"("+mess(127,134,1)+")"; Using [TRA]

 # X3-59890 2017-12-12 JPGA : BatchServer DateTime is now the same in every internal function
 If dim([L]REQUETE)<=0                 : # FOR BATCH REQUEST LOG FILE : Displaying Database DateTime which can be different from Applicative Runtime DateTime
   Call GET_INSTANT_DATE_TIME_DB   ( [L]DD, [L]HH, [L]HS, [L]SS) From SERVEUR
   If left$(time$,2) <> left$([L]HH,2) : # If in a different timezone between Runtime and Database : Displaying Database DateTime
     Wrseq SEP;"-"; Using [TRA]
     Wrseq SEP;func SERVEUR.GET_DATE_FROM_GLOBAL_FORMAT ([L]DD); Using [TRA]
     Wrseq SEP;format$("hh[:]mm[:]ss",[L]HS); Using [TRA]
     Wrseq SEP;"("+mess(126,134,1)+")"; Using [TRA]
   Endif
 Endif
 Wrseq SEP;[L]COMMENT; Using [TRA]
 Wrseq SEP;"(";format$("N0:5#",[L]ERR)+")" Using [TRA]
 Openo Using [TRA]
 Onerrgo
Endif

# On ne gère dans le fichier trace requête (ou fichier .sta) que les erreurs < 50000
If dim([L]REQUETE)<=0 & dim([F:ABR]JOB)>0 & [F:ABR]JOB<>"" & [L]ERR<50000
 If [F:ABR]USRINT<>""
  [L]USR = [F:ABR]USRINT
 Else
  [L]USR = [F:ABR]USER
 Endif
 Call WRJOB([F:ABR]JOB,"sta",[L]ERR,[F:ABR]NUMREQ,[F:ABR]DOSSIER,[L]USR,[F:ABR]LAN,[F:ABR]TACHE,[L]COMMENT) From SERVJOB
Endif

End

$RIEN
Resume

