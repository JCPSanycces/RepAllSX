#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################################################################
## Section automatically added (Object DTT) 20.08.2014 12:57:22 (ANGRE)
########################################################################################################################
$ACTION
    Case ACTION
        When "LIENS"     : Gosub LIENS
        When "STYLE"     : Gosub STYLE
        When "SETBOUT"   : Gosub SETBOUT
        When "SEL_LISTE" : Gosub SEL_LISTE
        When Default
    Endcase
Return

########################################################################################################################

$LIENS
    [M:DTT]DTTISSDES(nolign - 1) = func GET_DESCRIPTION([M:DTT]DTTISSCOD(nolign - 1))
Return

$STYLE
    Local Integer I
    For [L]I = 0 To [M:DTT]NBLIG - 1
        Case [M:DTT]TAXDATEV([L]I)
            When 94, 95  : Actzo [M:DTT]DTTISSCOD([L]I)
            When Default : Diszo [M:DTT]DTTISSCOD([L]I)
        Endcase
    Next [L]I
Return

$SETBOUT
    If [M:DTT]LEG <> "" Then
        CHMEN += "1"
    Endif
Return

$SEL_LISTE
    Case LISTE
        When "DTTISSCOD" : Gosub SEL_LISTE_DTTISSCOD
        When Default
    Endcase
Return

$SEL_LISTE_DTTISSCOD
    Local Char TEX(5)(1..)
    Local Char TEXTE(120)(1.., 1..2)
    Local Char TIT(50)(1..)
    If clalev([F:AXX]) = 0 Then : Local File ATEXTRA [AXX] : Endif
    Local Integer I, J

    [L]NBTEX = 0
    For [F:AXX] Where [F:AXX]CODFIC = "ATABDIV" and [F:AXX]ZONE = "LNGDES" and [F:AXX]LANGUE = GLANGUE and [F:AXX]IDENT1 = num$(327)
        [L]NBTEX += 1 : [L]TEX([L]NBTEX) = [F:AXX]IDENT2 : [L]TEXTE([L]NBTEX, 2) = [F:AXX]TEXTE
    Next
    For [L]I = 1 To [L]NBTEX
        [L]TEXTE([L]I, 1) = [L]TEX([L]I)
    Next [L]I
    Sorta [L]NBTEX [L]TEX Order By val([L]TEX(indice + 1))
    For [L]I = 1 To [L]NBTEX
        [L]J = find([L]TEX([L]I), [L]TEXTE(1..[L]NBTEX, 1))
        If [L]J <> [L]I Then
            [L]TEXTE([L]J, 1) = [L]TEXTE([L]I, 2)
            [L]TEXTE([L]I, 2) = [L]TEXTE([L]J, 2)
            [L]TEXTE([L]J, 2) = [L]TEXTE([L]J, 1)
            [L]TEXTE([L]J, 1) = [L]TEXTE([L]I, 1)
            [L]TEXTE([L]I, 1) = [L]TEX([L]I)
        Endif
    Next [L]I

    [L]TIT(1) = mess(21,3653,1)
    [L]TIT(2) = mess(22,3653,1)
    [L]TIT(3) = mess(23,3653,1)
Return

########################################################################################################################

Subprog IB_NBLIG
    If find([M:DTT]TAXDATEV(nolign - 1), 94, 95) = 0 Then
        [M:DTT]DTTISSCOD(nolign - 1) = 0
        [M:DTT]DTTISSDES(nolign - 1) = func SUBDTT.GET_DESCRIPTION([M:DTT]DTTISSCOD(nolign - 1))
        Affzo [M:DTT]DTTISSCOD(nolign - 1)
        Diszo [M:DTT]DTTISSCOD(nolign - 1)
    Endif
End

########################################################################################################################

Subprog AM_TAXDATEV(VALEUR)
    Variable Decimal VALEUR

    Case VALEUR
        When 94, 95
            Actzo [M:DTT]DTTISSCOD(nolign - 1)
            [M:DTT]DTTISSDES(nolign - 1) = func SUBDTT.GET_DESCRIPTION([M:DTT]DTTISSCOD(nolign - 1))
        When Default
            [M:DTT]DTTISSCOD(nolign - 1) = 0
            [M:DTT]DTTISSDES(nolign - 1) = func SUBDTT.GET_DESCRIPTION([M:DTT]DTTISSCOD(nolign - 1))
            Diszo [M:DTT]DTTISSCOD(nolign - 1)
    Endcase
End

########################################################################################################################

Subprog AM_DTTISSCOD(VALEUR)
    Variable Decimal VALEUR

    [M:DTT]DTTISSDES(nolign - 1) = func GET_DESCRIPTION(VALEUR)
End

Funprog GET_DESCRIPTION(VKEY)
    Value Integer VKEY
    Local Char LRESULT(80)
    If clalev([F:AXX]) = 0 Then : Local File ATEXTRA [AXX] : Endif

    Filter [F:AXX] Where [F:AXX]CODFIC = "ATABDIV" and [F:AXX]ZONE = "LNGDES" and [F:AXX]LANGUE = GLANGUE
&       and [F:AXX]IDENT1 = num$(327) and [F:AXX]IDENT2 = num$(VKEY)
    Read [F:AXX] First
    If fstat = 0 Then
        [L]LRESULT = [F:AXX]TEXTE
    Endif
    Filter [F:AXX]
End [L]LRESULT

########################################################################################################################

