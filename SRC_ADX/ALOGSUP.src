#<AdxTL>@(#)10.0.0.0 $Revision$
# Génération trace support
# Ecrit par Dominique BOPP
#
# Mis à jour le 30 Septembre 2011
# Mis en livraison le 13 Février 2012
Call TRACE_SUPPORT
End

#----------------------------------#
Subprog TRACE_SUPPORT
Local Char    VALEUR(10), PARAM(10)(1..1)
Local Integer ERR
Onerrgo ERR
Local Mask ALOGSUP [ALS1]
Onerrgo
If ERR
 Call TRAITE_CHAR(VALEUR,PARAM,"","ALOGSUP","",1,"") From GTRAITE
Else
 Close Local Mask [ALS1]
 Call TRAITE_CHAR(VALEUR,PARAM,"","ALOGSUP","ALOGSUP",3,"") From GTRAITE
Endif
End

#----------------#
$ERR
ERR = errn
Resume

#----------------------------------#
$ACTION
Case ACTION
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
 When "TERMINE"  : Gosub TERMINE
Endcase
Return

#----------------------------------#
$CONTROLE
Local Char INCIDENT(20) , MAILSAGE(200)
If dim([M:ALS1]INCIDENT)>0
 [L] = [M:ALS1]
Elsif !GSERVEUR
 Call SAICAR(INCIDENT,"Mail to support","Incident #","A",0,20,"",OK) From GESECRAN
 INCIDENT = vireblc(INCIDENT,2)
 MAILSAGE = func AFNC.PARAM("MAILSAGE","")
 MAILSAGE = func VIRE_BY(MAILSAGE)
 If vireblc(MAILSAGE,2)=""
  Call SAICAR(MAILSAGE,"MAILSAGE parameter not filled","Email address","A",0,200,"",OK) From GESECRAN
  MAILSAGE = vireblc(MAILSAGE,2)
 Endif
Endif
If [L]INCIDENT=""
 Call ECR_TRACE("INCIDENT :"-mess(10,123,1),1) From GESECRAN
 FIN = 1 : Return
Endif
If [L]MAILSAGE=""
 Call ECR_TRACE("MAILSAGE :"-mess(10,123,1),1) From GESECRAN
 FIN = 1 : Return
Endif
Return

#----------------------------#
Funprog VIRE_BY(MAIL)
Value Char MAIL
Local Char MAILSAGE(250)
MAILSAGE = MAIL
If pat(toupper(MAILSAGE),"*YVINEC*SAGE*")
 MAILSAGE = ""
Endif
End MAILSAGE

#----------------------------------#
$EXEC
GFILPATH = filpath("","SUPPORT","xml",GDOSX3)
Call TEMPON("O") From GESECRAN
Call TRACE_XML(INCIDENT)
Call TEMPOFF From GESECRAN
If filinfo(GFILPATH,7)>0
 Call WORKFLOW(1,"DIV",[L]MAILSAGE,"ALOGSUP") From AWRK
Endif
Return

#----------------------------------#
$TERMINE
If GTEST
 TRA = 1
 Call OUVRE_TRACE("") From LECFIC
 Openi GFILPATH,0 Using [TTT]
 Rdseq GBIDC1 Using [TTT]
 While !fstat
  Call ECR_TRACE(GBIDC1,0) From GESECRAN
  Rdseq GBIDC1 Using [TTT]
 Wend
 Openi Using [TTT]
 Call FERME_TRACE From LECFIC
Endif
Return

#-------------------------------------------------------------------------#
Subprog TRACE_XML(INCIDENT)
Value Char INCIDENT()
#-------------------------------------------------------------------------#

Local Char SAVIFS , SAVIRS
Local Char VARAPL(20)(1..100),VALAPL(20)(1..100),BUFLEC(255), DEFLEG(5), CHAINE(250)
Local Integer NBAPL,II,JJ,KK,LL,MM,NN,PP,QQ,FIRSTNUM,LASTNUM
Local Integer DOSEX
Local Char PARAMCPY(GLONCPY)(1..1000),PARAMFCY(GLONFCY)(1..1000), PARAMVALUE(GLONADW)(1..1000), PARAMLEG(5)(1..1000)
Local Integer PARAMNB

Local Integer OK
Local Char MAIL_SAGE(200)
Local Char DBA_NAM(200), DBA_VER(200), DBA_VERDES(200)
Local Char WEBSERVER_NAME(100)(1..20), WEBSERVER_PATH(250)(1..20), WEBSERVER_ID(250)(1..20), WEBSERVER_OS(20)(1..20)
Local Integer NB_WEBSERVER
Local Char EDTSERVER_NAME(100)(1..20), EDTSERVER_PATH(250)(1..20), EDTSERVER_PORT(20)(1..20), EDTSERVER_ID(250)(1..20), EDTSERVER_OS(20)(1..20)
Local Integer NB_EDTSERVER
Local Date PATCHDATE

SAVIFS = adxifs
SAVIRS = adxirs
adxifs="" : adxirs=chr$(13)+chr$(10)

If dim([V]GADMINPORT)<0
    Global Integer GADMINPORT : GADMINPORT=1818
Endif

  Openo GFILPATH,0 Using [TTT]
  Wrseq '<?xml version="1.0" encoding="utf-8"?>' Using [TTT]

# Dernière liste de patch du dossier superviseur(à mettre dans l'en-tête)
  Gosub LIRE_PATCH_X3

# Infos d'en-tête
  Wrseq '<LOGFILE VERSION="1">' Using [TTT]
  Wrseq "<INFOS>" Using [TTT]
  Wrseq "  <DATE>"+format$("D:YYYY[/]MM[/]DD[T]hh[:]mm[:]ss",date$)+"</DATE>" Using [TTT]
  Wrseq "  <FOLD>"+nomap+"</FOLD>" Using [TTT]
  Wrseq "  <USER>"+GUSER+"</USER>" Using [TTT]
  Wrseq "  <RUNTIME>"+ver$(0)+"</RUNTIME>" Using [TTT]
  Wrseq "  <SOFTWARE_VERSION>"+func APRODUCT.AGETVERSION()+"</SOFTWARE_VERSION>" Using [TTT]
  Wrseq "  <PATCHLIST>"+num$(FIRSTNUM)+"</PATCHLIST>" Using [TTT]
  Wrseq "  <PATCHDATE>"+format$("D:YYYY[/]MM[/]DD",PATCHDATE)+"</PATCHDATE>" Using [TTT]
  Wrseq "  <INCIDENT_ID>"+INCIDENT+"</INCIDENT_ID>" Using [TTT]
  Wrseq "</INFOS>" Using [TTT]

# Client utilisé
  Wrseq "<CLIENT>" Using [TTT]
  Call PARCLI("X3Version",CHAINE) From GLOBVAR
  Wrseq "  <X3VERSION>"+CHAINE+"</X3VERSION>" Using [TTT]
  Call PARCLI("X3FileVersion",CHAINE) From GLOBVAR
  Wrseq "  <X3FILEVERSION>"+CHAINE+"</X3FILEVERSION>" Using [TTT]
  Call PARCLI("SafeX3CltFileVersion",CHAINE) From GLOBVAR
  Wrseq "  <X3CLTVERSION>"+CHAINE+"</X3CLTVERSION>" Using [TTT]

  Wrseq "</CLIENT>" Using [TTT]

# Commencer par récupérer FOLDERS.xml et solutions.xml s'ils existent
  For CHAINE="FOLDERS","solution"
    Gosub COPIE_XML
  Next

# Informations base de données
  OK=0
  Wrseq '<DATABASE TYPE="'+string$(GTYPDBA=1,"ORACLE")+string$(GTYPDBA=2,"Sql server") +'">' Using [TTT]
  If GTYPDBA=1
    Call VERS_ORA(DBA_NAM,DBA_VER,DBA_VERDES,OK) From ORAPROP
  Else
    Call VERS_SQL(DBA_NAM,DBA_VER,DBA_VERDES,OK) From SQLPROP
  Endif

  If OK=0
    If DBA_NAM<> ""
      Wrseq ' <NAME>'+DBA_NAM+'</NAME>' Using [TTT]
    Endif
    If DBA_VER<> ""
      Wrseq ' <VERSION>'+DBA_VER+'</VERSION>' Using [TTT]
    Endif
    If DBA_VERDES<> ""
      Wrseq ' <VERSION_DESC>'+DBA_VERDES+'</VERSION_DESC>' Using [TTT]
    Endif
  Endif
  Wrseq "</DATABASE>" Using [TTT]

# Informations server web
  Wrseq "<WEBSERVERCONF>" Using [TTT]
  Gosub WEBSERVER
  Wrseq "</WEBSERVERCONF>" Using [TTT]

# Informations serveurs d'édition
  Wrseq "<EDTSERVERCONF>" Using [TTT]
  Gosub EDTSERVER
  Wrseq "</EDTSERVERCONF>" Using [TTT]

# Informations par dossier
  Local File ADOSSIER
  For [ADS]DOSSIER
    If filinfo(filpath("","APL","ini",[ADS]DOSSIER),7)>0
        DOSEX=1
        Onerrgo PASDOS
        Local File =[ADS]DOSSIER+".APLSTD" [AZZ]
        Close Local File [AZZ]
        Onerrgo
        If DOSEX=1
            Wrseq '<FOLDER CODE="'+[ADS]DOSSIER+'">' Using [TTT]
            Gosub DOSSIER
            Gosub DATABASE
            Wrseq "</FOLDER>" Using [TTT]
        Endif
    Endif
  Next
  Wrseq "</LOGFILE>" Using [TTT]
  Openo Using [TTT]

  adxirs = SAVIRS
  adxifs = SAVIFS
End

#-------------------------------------------------------------------------#
$PASDOS
DOSEX=0
Resume

$COPIE_XML
 Local Char OADXIFS,OADXIRS
 Local Integer NB_MODULE,NB_SOLUTION
 OADXIFS=adxifs : OADXIRS=adxirs
 adxifs="" : adxirs=chr$(10)

 BUFLEC=filpath("","","") : BUFLEC=left$(BUFLEC,len(BUFLEC)-len(nomap))
 BUFLEC+=CHAINE+".xml"

 If filinfo(BUFLEC,0)>0
     Wrseq '<CONF_FILE NAME="'+CHAINE+'.xml">' Using [TTT]
     Openi BUFLEC Using [RRR]
     Rdseq BUFLEC Using [RRR]
     While fstat=0
        If pat(BUFLEC,"<*xml*version*")=0

#           Horrible bidouille pour fermer les modules qui ne le seraient pas
            If pat(vireblc(BUFLEC,2),"<module name=*")
                If NB_MODULE>=1
                    Wrseq "</module>" Using [TTT]
                Else
                    NB_MODULE+=1
                Endif
            Elsif pat(vireblc(BUFLEC,2),"</module*")
                NB_MODULE-=1
            Endif
#           Fin de la bidouille

#           Horrible bidouille pour fermer les solutions qui ne le seraient pas
            If pat(vireblc(BUFLEC,2),"<solution name=*")
                If NB_SOLUTION>=1
                    Wrseq "</solution>" Using [TTT]
                Else
                    NB_SOLUTION+=1
                Endif
            Elsif pat(vireblc(BUFLEC,2),"</solution*")
                NB_SOLUTION-=1
            Endif
#           Fin de la bidouille

# Recherche des noeuds donnant le nom des serveurs web et les chemins
            If CHAINE="solution" and pat(vireblc(BUFLEC,2),'<module name=*family="WEB"*')
                NB_WEBSERVER+=1
                WEBSERVER_ID(NB_WEBSERVER)=right$(BUFLEC,instr(1,BUFLEC,'="')+2)
                WEBSERVER_ID(NB_WEBSERVER)=left$(WEBSERVER_ID(NB_WEBSERVER),instr(1,WEBSERVER_ID(NB_WEBSERVER),'"')-1)
            Endif
            If CHAINE="solution" and pat(vireblc(BUFLEC,2),"<component.web.servername>*")
                WEBSERVER_NAME(NB_WEBSERVER)=right$(vireblc(BUFLEC,2),len("<component.web.servername>")+1)
                LENCH=instr(1,WEBSERVER_NAME(NB_WEBSERVER),"<")
                If LENCH>=1
                    WEBSERVER_NAME(NB_WEBSERVER)=left$(WEBSERVER_NAME(NB_WEBSERVER),LENCH-1)
                Else
                    WEBSERVER_NAME(NB_WEBSERVER)=""
                Endif
            Elsif CHAINE="solution" and pat(vireblc(BUFLEC,2),"<component.web.path>*")
                WEBSERVER_PATH(NB_WEBSERVER)=right$(vireblc(BUFLEC,2),len("<component.web.path>")+1)
                LENCH=instr(1,WEBSERVER_PATH(NB_WEBSERVER),"<")
                If LENCH>=1
                    WEBSERVER_PATH(NB_WEBSERVER)=left$(WEBSERVER_PATH(NB_WEBSERVER),LENCH-1)
                Else
                    WEBSERVER_PATH(NB_WEBSERVER)=""
                Endif
            Elsif CHAINE="solution" and pat(vireblc(BUFLEC,2),"<component.web.platform>*")
                WEBSERVER_OS(NB_WEBSERVER)=right$(vireblc(BUFLEC,2),len("<component.web.platform>")+1)
                LENCH=instr(1,WEBSERVER_OS(NB_WEBSERVER),"<")
                If LENCH>=1
                    WEBSERVER_OS(NB_WEBSERVER)=left$(WEBSERVER_OS(NB_WEBSERVER),LENCH-1)
                Else
                    WEBSERVER_OS(NB_WEBSERVER)=""
                Endif
            Endif

# Recherche des noeuds donnant le nom des serveurs d'édition et les chemins
            If CHAINE="solution" and pat(vireblc(BUFLEC,2),'<module name=*family="REPORT"*')
                NB_EDTSERVER+=1
                EDTSERVER_ID(NB_EDTSERVER)=right$(BUFLEC,instr(1,BUFLEC,'="')+2)
                EDTSERVER_ID(NB_EDTSERVER)=left$(EDTSERVER_ID(NB_EDTSERVER),instr(1,EDTSERVER_ID(NB_EDTSERVER),'"')-1)
            Endif
            If CHAINE="solution" and pat(vireblc(BUFLEC,2),"<component.report.servername>*")
                EDTSERVER_NAME(NB_EDTSERVER)=right$(vireblc(BUFLEC,2),len("<component.report.servername>")+1)
                LENCH=instr(1,EDTSERVER_NAME(NB_EDTSERVER),"<")
                If LENCH>=1
                    EDTSERVER_NAME(NB_EDTSERVER)=left$(EDTSERVER_NAME(NB_EDTSERVER),LENCH-1)
                Else
                    EDTSERVER_NAME(NB_EDTSERVER)=""
                Endif
            Elsif CHAINE="solution" and pat(vireblc(BUFLEC,2),"<component.report.path>*")
                EDTSERVER_PATH(NB_EDTSERVER)=right$(vireblc(BUFLEC,2),len("<component.report.path>")+1)
                LENCH=instr(1,EDTSERVER_PATH(NB_EDTSERVER),"<")
                If LENCH>=1
                    EDTSERVER_PATH(NB_EDTSERVER)=left$(EDTSERVER_PATH(NB_EDTSERVER),LENCH-1)
                Else
                    EDTSERVER_PATH(NB_EDTSERVER)=""
                Endif
            Elsif CHAINE="solution" and pat(vireblc(BUFLEC,2),"<component.report.platform>*")
                EDTSERVER_OS(NB_EDTSERVER)=right$(vireblc(BUFLEC,2),len("<component.report.platform>")+1)
                LENCH=instr(1,EDTSERVER_OS(NB_EDTSERVER),"<")
                If LENCH>=1
                    EDTSERVER_OS(NB_EDTSERVER)=left$(EDTSERVER_OS(NB_EDTSERVER),LENCH-1)
                Else
                    EDTSERVER_OS(NB_EDTSERVER)=""
                Endif
            Elsif CHAINE="solution" and pat(vireblc(BUFLEC,2),"<report.service.printport>*")
                EDTSERVER_PORT(NB_EDTSERVER)=right$(vireblc(BUFLEC,2),len("<report.service.printport>")+1)
                LENCH=instr(1,EDTSERVER_PORT(NB_EDTSERVER),"<")
                If LENCH>=1
                    EDTSERVER_PORT(NB_EDTSERVER)=left$(EDTSERVER_PORT(NB_EDTSERVER),LENCH-1)
                Else
                    EDTSERVER_PORT(NB_EDTSERVER)=""
                Endif
            Endif

            Wrseq ctrans(BUFLEC,chr$(13),"")+chr$(13) Using [TTT]
        Endif
        Rdseq BUFLEC Using [RRR]
     Wend

# Re-bidouille infâme
   If NB_SOLUTION=1 : Wrseq "</solution>" Using [TTT] : Endif

   Wrseq '</CONF_FILE>' Using [TTT]
 Endif
 Openi Using [RRR]
 adxifs=OADXIFS : adxirs=OADXIRS
Return

$LIRE_APL_INI
    adxirs=chr$(10)
    Openi filpath("","APL","ini",[ADS]DOSSIER) Using [AAA]
    NBAPL=0
    While fstat=0
        Rdseq BUFLEC Using [AAA]
        If pat(BUFLEC,"?*=*?")<>0 and left$(vireblc(BUFLEC,2),1)<>"#"
            NBAPL+=1
            VARAPL(NBAPL)=vireblc(ctrans(toupper(left$(BUFLEC,instr(1,BUFLEC,"=")-1)),"()","__"),2)
            VALAPL(NBAPL)=vireblc(right$(BUFLEC,instr(1,BUFLEC,"=")+1),2)
            If pat(VALAPL(NBAPL),'"*"') : VALAPL(NBAPL)=right$(left$(VALAPL(NBAPL),len(VALAPL(NBAPL))-1),2) : Endif
        Endif
        Break NBAPL=dim(VARAPL)
    Wend
    adxirs=chr$(13)+chr$(10)
    Openi Using [AAA]
Return

# Lecture de la dernière liste de patch dans X3
$LIRE_PATCH_X3
  Local File =GDOSX3+".APATCH" [APT]
  For [APT]APT2(1) Where TYP="P"
    For [APT]APT2(2) : # Boucle version
        FIRSTNUM=0 : PATCHDATE=[0/0/0]
        For [APT]APT2(3)
            If FIRSTNUM=0 or (FIRSTNUM<>[APT]PATNUM and [APT]PATNUM<>0) or PATCHDATE<>[APT]DAT
                If [APT]PATNUM<>0 : FIRSTNUM=[APT]PATNUM : Endif
                PATCHDATE=[APT]DAT
            Endif
        Next
    Next
  Next
  Close Local File [APT]
Return

$LIRE_PATCH
# Seulement pour le dossier X3, le dossier mère, et le dossier applicatif
  If find([ADS]DOSSIER,nomap,adxmother(0),GDOSX3)=0 : Return : Endif

  Local File =[ADS]DOSSIER+".APATCH" [APT] Where TYP="P", =[ADS]DOSSIER+".APATCH" [AP1]

# Etat actuel
  Wrseq "<CURRENT_STATUS>" Using [TTT]
  For [APT]APT2(1) Where TYP="P"
    LASTNUM=0
    Wrseq '<TYPE CODE="'+[APT]TYP+'">' Using [TTT]
    For [APT]APT2(2)
        #106969
        #Wrseq '<VERSION ID="'+num$([APT]VER)+'">' Using [TTT]
        Wrseq '<VERSION ID="'+[APT]FICRELABR+'">' Using [TTT]
        FIRSTNUM=-1
        For [APT]APT2(3)
            If FIRSTNUM<=0
                If pat([APT]FIC,"Version*") and FIRSTNUM=-1
                    Wrseq '<ORIGIN>'+[APT]FIC+'</ORIGIN>' Using [TTT]
                    FIRSTNUM=0
                Else
                    Wrseq '<FIRST NUM="'+num$([APT]NUMP)+'">' Using [TTT]
                    CHAINE=[APT]COMMENT : Gosub CHANGE_CHAINE
                    Wrseq "<COMMENT>"+CHAINE+"</COMMENT>" Using [TTT]
                    Wrseq "<FILE>"+[APT]FIC+"</FILE>" Using [TTT]
                    Wrseq "<PATCHNUM>"+num$([APT]PATNUM)+"</PATCHNUM>" Using [TTT]
                    Wrseq "</FIRST>" Using [TTT]
                    FIRSTNUM=[APT]NUMP
                Endif
            Elsif FIRSTNUM>[APT]NUMP-1
                Wrseq '<MISSING NUM="'+num$(FIRSTNUM+1)+string$(FIRSTNUM+1<>[APT]NUMP-1,"-"+num$([APT]NUMP-1))+'">' Using [TTT]
                Wrseq +"</MISSING>" Using [TTT]
                FIRSTNUM=[APT]NUMP
            Endif
        Next
        Wrseq '<LAST NUM="'+num$([APT]NUMP)+'">' Using [TTT]
        CHAINE=[APT]COMMENT : Gosub CHANGE_CHAINE
        Wrseq "<COMMENT>"+CHAINE+"</COMMENT>" Using [TTT]
        Wrseq "<FILE>"+[APT]FIC+"</FILE>" Using [TTT]
        Wrseq "<PATCHNUM>"+num$([APT]PATNUM)+"</PATCHNUM>" Using [TTT]
        LASTNUM=[APT]NUM
        Wrseq "</LAST>" Using [TTT]
        For [AP1]APT0 Where [AP1]NUM>LASTNUM and find(left$([AP1]FIC,3),"WX_","WP_","WG_")<>0
            Wrseq '<PREPATCH NUM="'+num$([AP1]NUMP)+'">' Using [TTT]
            CHAINE=[AP1]COMMENT : Gosub CHANGE_CHAINE
            Wrseq "<COMMENT>"+CHAINE+"</COMMENT>" Using [TTT]
            Wrseq "<FILE>"+[AP1]FIC+"</FILE>" Using [TTT]
            Wrseq "<PATCHNUM>"+num$([AP1]PATNUM)+"</PATCHNUM>" Using [TTT]
            Wrseq "</PREPATCH>" Using [TTT]
        Next
        Wrseq '</VERSION>' Using [TTT]
    Next
    Wrseq '</TYPE>' Using [TTT]
  Next
  Wrseq "</CURRENT_STATUS>" Using [TTT]

# Historique de passage des patches

  Wrseq "<INSTALL_HISTORY>" Using [TTT]
  For [APT]APT2(1) Where TYP="P"
    LASTNUM=0
    Wrseq '<TYPE CODE="'+[APT]TYP+'">' Using [TTT]
    For [APT]APT2(2)
        #106969
        #Wrseq '<VERSION ID="'+num$([APT]VER)+'">' Using [TTT]
        Wrseq '<VERSION ID="'+[APT]FICRELABR+'">' Using [TTT]
        FIRSTNUM=0 : PATCHDATE=[0/0/0]
        For [APT]APT2(3)
            If FIRSTNUM=0 or (FIRSTNUM<>[APT]PATNUM and [APT]PATNUM<>0) or PATCHDATE<>[APT]DAT
                Wrseq '<PATCHLIST NUM="'+num$([APT]PATNUM+FIRSTNUM*([APT]PATNUM=0))+'" DATE="'+format$("D:YYYY[-]MM[-]DD",[APT]DAT)+'">' Using [TTT]
                Wrseq "<USER>"+[APT]USR+"</USER>" Using [TTT]
                CHAINE=[APT]COMMENT : Gosub CHANGE_CHAINE
                Wrseq "<COMMENT>"+CHAINE+"</COMMENT>" Using [TTT]
                Wrseq "<FILE>"+[APT]FIC+"</FILE>" Using [TTT]
                Wrseq "<MAINTENANCE>"+num$([APT]NUMP)+"</MAINTENANCE>" Using [TTT]
                Wrseq "</PATCHLIST>" Using [TTT]
                If [APT]PATNUM<>0 : FIRSTNUM=[APT]PATNUM : Endif
                PATCHDATE=[APT]DAT
            Endif
        Next
        Wrseq '</VERSION>' Using [TTT]
    Next
    Wrseq '</TYPE>' Using [TTT]
  Next
  Wrseq "</INSTALL_HISTORY>" Using [TTT]

  Close Local File [APT]
  Close Local File [AP1]
Return

$LIRE_TRT
 If [ADS]DOSSIER=GDOSX3 : Return : Endif

 Local File (FICHE(30),A(30)) From System 'lsadx -a '+[ADS]DOSSIER+' TRT adx' As [FTR]

 Wrseq "<LOCALPRG>" Using [TTT]
 For [FTR]
   If FICHE<>"" and find(left$(FICHE,1),"W","X","Y","Z")=0  and find(left$(FICHE,3),"GES","SPE","AUT","IMP","exp")=0
&             and right$([F:FTR]FICHE,len([F:FTR]FICHE)-2)<>"SPE" and left$([F:FTR]FICHE,5)<>"AGLOB"
&             and (left$([F:FTR]FICHE,3)<>"CNS" or len([F:FTR]FICHE)<>6)
       Wrseq "<PRGNAME>"+FICHE+"</PRGNAME>" Using [TTT]
   Endif
 Next
 Wrseq "</LOCALPRG>" Using [TTT]
 Close Local File [FTR]
Return

$LIRE_TRTSPE
 Local File (FICHE(30),A(30)) From System 'lsadx -a '+[ADS]DOSSIER+' TRT adx' As [FTR]

 Wrseq "<SPEPRG>" Using [TTT]
 For [FTR]
   If FICHE<>"" and left$(FICHE,1)<>"W" and
&     (find(left$(FICHE,1),"X","Y","Z")<>0
&   or right$([F:FTR]FICHE,7)="SPE" or right$([F:FTR]FICHE,7)="SPV"
&   or pat([F:FTR]FICHE,'CNS*SPE')<>0
&     )
       Wrseq "<PRGNAME>"+FICHE+"</PRGNAME>" Using [TTT]
   Endif
 Next
 Wrseq "</SPEPRG>" Using [TTT]
 Close Local File [FTR]
Return

$LIRE_FCYCPY
 If [ADS]DOSSIER<>nomap : Return : Endif
 Local File =[ADS]DOSSIER+".COMPANY" Where CPYLEGFLG=2, =[ADS]DOSSIER+".FACILITY"
 Local Char FCYLIST(5)(1..max(nbrecord([FCY]),1))
 Local Char CPYFCY(5)(1..dim(FCYLIST))
 Local Char CPYLIST(5)(1..max(rowcount([CPY]),1))
 Local Char LEGCPY(5)(1..dim(CPYLIST))

 II=0 : JJ=0
 Wrseq "<CPYLIST>" Using [TTT]
 For [CPY]
    II+=1 : CPYLIST(II)=[CPY]CPY : LEGCPY(II)=[CPY]LEG
    Wrseq '<COMPANY CODE="'+[CPY]CPY+'">' Using [TTT]
    CHAINE=[CPY]CPYNAM : Gosub CHANGE_CHAINE
    Wrseq "<NAME>"+CHAINE+"</NAME>" Using [TTT]
    Wrseq "<LEGISLATION>"+[CPY]LEG+"</LEGISLATION>" Using [TTT]
    Wrseq "<SITLIST>" Using [TTT]
    For [FCY] Where LEGCPY=[CPY]CPY
        Wrseq "<SITE NAME="+'"'+[FCY]FCY+'"'+">" Using [TTT]
        Wrseq "<FINANCIAL>"+[FCY]FINRSPFCY+"</FINANCIAL>" Using [TTT]
        Wrseq "</SITE>" Using [TTT]
        JJ+=1 : FCYLIST(JJ)=[FCY]FCY : CPYFCY(JJ)=[FCY]LEGCPY
    Next
    Wrseq "</SITLIST>" Using [TTT]
    Wrseq "</COMPANY>" Using [TTT]
 Next
 Wrseq "</CPYLIST>" Using [TTT]
 Sorta LEGCPY,CPYLIST

 Close Local File [CPY],[FCY]
 Return

$LIRE_PARAM : # A exécuter après les sites

 If [ADS]DOSSIER<>nomap : Return : Endif

 Local File =[ADS]DOSSIER+".COMPANY" Where CPYLEGFLG=2, =[ADS]DOSSIER+".FACILITY",
&           =[ADS]DOSSIER+".ADOPAR", =[ADS]DOSSIER+".ADOVAL", =[ADS]DOSSIER+".ADOVALAUS"

 Wrseq "<PARAMVALUES>" Using [TTT]
 For [ADP]ADP0(1)
    Wrseq '<PARAMGRP NAME="'+[ADP]CHAPITRE+'">' Using [TTT]
    For [ADP]ADP0(2)
      Wrseq '<PARAM NAME="'+[ADP]PARAM+'">' Using [TTT]
      Wrseq "<VALUES>" Using [TTT]
      Wrseq "<FOLDERVALUE>"; Using [TTT]
      Read [ADW]ADW0="";"";[ADP]PARAM
      If fstat=0
        CHAINE=[ADW]VALEUR : Gosub PARAMVALUE
      Else
        CHAINE="(no value)" : Wrseq CHAINE Using [TTT]
      Endif
      Wrseq "</FOLDERVALUE>" Using [TTT]
      II=0
      For [ADW]ADW0 Where PARAM=[ADP]PARAM and (CPY<>"" or FCY<>"")
        II+=1
        PARAMCPY(II)=[ADW]CMP
        PARAMFCY(II)=[ADW]FCY
        PARAMVALUE(II)=[ADW]VALEUR
        If [ADW]CMP="*"
            PARAMLEG(II)=[ADW]FCY
            PARAMCPY(II)=""
            PARAMFCY(II)=""
        Elsif [ADW]CMP<>""
            PARAMLEG(II)=LEGCPY(find([ADW]CMP,CPYLIST(1..dim(CPYLIST))))
        Elsif [ADW]FCY<>""
            JJ=find([ADW]FCY,FCYLIST(1..dim(FCYLIST)))
            JJ=find(CPYFCY(JJ),CPYLIST(1..dim(CPYLIST)))
            PARAMLEG(II)=LEGCPY(JJ)
            PARAMCPY(II)=CPYFCY(JJ)
        Endif
      Next
      Sorta II PARAMLEG,PARAMCPY,PARAMFCY,PARAMVALUE
      KK=0 : LL=0 : MM=0 : # KK non nul si législation ouverte, LL non nul si société ouverte, MM non nul si site ouvert
      For JJ=1 To II
          # On change de législation, mais on en a déjà exploré une : if faut fermer les groupes ouverts
          If KK<>0 and PARAMLEG(KK)<>PARAMLEG(JJ)
              If MM : Wrseq "</FCY>" Using [TTT] : MM=0 : Endif
              If LL : Wrseq "</CPY>" Using [TTT] : LL=0 : Endif
              Wrseq "</LEG>" Using [TTT]
              KK=0
          Endif
          # On change de législation : il faut ouvrir le groupe
          If KK=0
              Wrseq '<LEG NAME="'+PARAMLEG(JJ)+'">' Using [TTT]
              KK=JJ
          Endif
          # La valeur est attachée à la législation
          If PARAMCPY(JJ)="" and PARAMFCY(JJ)=""
              Wrseq "<LEGVALUE>" Using [TTT]
              CHAINE=PARAMVALUE(JJ) : Gosub PARAMVALUE
              Wrseq "</LEGVALUE>" Using [TTT]
              Goto SUITE : # passer à la valeur suivante
          Endif
          # On change de société, mais on en a déjà exploré une : il faut fermer les groupes
          If LL<>0 and PARAMCPY(LL)<>PARAMLEG(JJ)
              If MM : Wrseq "</FCY>" Using [TTT] : MM=0 : Endif
              Wrseq "</CPY>" Using [TTT]
              LL=0
          Endif
          # On change de société : il faut ouvrir le groupe
          If LL=0
              Wrseq '<CPY NAME="'+PARAMCPY(JJ)+'">' Using [TTT]
              LL=JJ
          Endif

          # La valeur est attachée à la société
          If PARAMFCY(JJ)=""
              Wrseq "<CPYVALUE>" Using [TTT]
              CHAINE=PARAMVALUE(JJ) : Gosub PARAMVALUE
              Wrseq "</CPYVALUE>" Using [TTT]
              Goto SUITE : # passer à la valeur suivante
          Endif
          # Ici la valeur de paramètre est attachée au site
          Wrseq '<FCY NAME="'+PARAMCPY(JJ)+'">' Using [TTT]
          Wrseq "<FCYVALUE>" Using [TTT]
          CHAINE=PARAMVALUE(JJ) : Gosub PARAMVALUE
          Wrseq "</FCYVALUE>" Using [TTT]
          MM=JJ
$SUITE
      Next JJ

      # Il faut fermer ce qui a été ouvert
      If MM : Wrseq "</FCY>" Using [TTT] : MM=0 : Endif
      If LL : Wrseq "</CPY>" Using [TTT] : LL=0 : Endif
      If KK : Wrseq "</LEG>" Using [TTT] : KK=0 : Endif

      # Valeurs par utilisateur
      KK=0
      For [ADU]ADU1 Where PARAM=[ADP]PARAM
        If KK=0
            Wrseq "<USER_VALUES>" Using [TTT]
            KK=1
        Endif
        Wrseq '<USER CODE="'+[ADU]CODUSR+'">'; Using [TTT]
        CHAINE=[ADU]VALEUR : Gosub PARAMVALUE
        Wrseq '</USER>' Using [TTT]
      Next
      If KK : Wrseq "</USER_VALUES>" Using [TTT] : Endif

      # Ici on termine un paramètre
      Wrseq "</VALUES>" Using [TTT]
      Wrseq "</PARAM>" Using [TTT]
    Next

    # Ici on termine un groupe
    Wrseq "</PARAMGRP>" Using [TTT]
 Next
 Wrseq "</PARAMVALUES>" Using [TTT]

 Close Local File [CPY],[FCY],[ADP],[ADW],[ADU]
 Return

$PARAMVALUE
  Case [ADP]TYPVAL
    When 1 : Gosub CHANGE_CHAINE
             Wrseq CHAINE; Using [TTT]
    When 2 : Wrseq num$(CHAINE); Using [TTT]
    When 3 : Wrseq format$("D:YYYY[-]MM[-]DD",gdat$(format$("D:YYYYMMDD",CHAINE))); Using [TTT]
    When 4 : Read [AP0]CLE=[ADP]NOLIB;val(CHAINE);GLANGUE
             If fstat=0
                 CHAINE=[AP0]LANMES : Gosub CHANGE_CHAINE : Wrseq CHAINE; Using [TTT]
             Else
                 Gosub CHANGE_CHAINE : Wrseq "("+CHAINE+")"; Using [TTT]
             Endif
  Endcase
Onerrgo
Return

$CHANGE_CHAINE
  NN=1
  While NN
      NN=instr(NN,CHAINE,"&")
      If NN
          CHAINE=left$(CHAINE,NN-1)+"&amp;"+right$(CHAINE,NN+1)
          NN+=4
      Endif
  Wend
  NN=1
  While NN
      NN=instr(NN,CHAINE,"<")
      If NN
          CHAINE=left$(CHAINE,NN-1)+"&lt;"+right$(CHAINE,NN+1)
          NN+=3
      Endif
  Wend
  NN=1
  While NN
      NN=instr(NN,CHAINE,">")
      If NN
          CHAINE=left$(CHAINE,NN-1)+"&gt;"+right$(CHAINE,NN+1)
          NN+=3
      Endif
  Wend
Return

$LIRE_ACTIVITY
# Si le dossier est le dossier courant, on analyse la table ACTIV, sinon on reprend les paramètres de ADOSACT
  Local File ACTIV, ADOSACT
  Local Integer ACT_FLACT, NO_ACT, ACT_DIME
  Wrseq "<ACTIVITY_CODES>" Using [TTT]

  Wrseq "<FUNCTIONAL>" Using [TTT]
  For [ACV]ACV1(1) Where TYP=1
    Read [AP0]CLE=14;[ACV]MODULE;GLANGUE
    Wrseq '<MODULE NAME="'+[AP0]LANMES+'">' Using [TTT]
    For [ACV]ACV1
      If [ADS]DOSSIER=nomap
         ACT_FLACT=[ACV]FLACT
         NO_ACT=1
      Else
         Read [ADA]ADA0=[ADS]DOSSIER;[ACV]CODACT
         NO_ACT=(fstat=0)
         ACT_FLACT=[ADA]FLACT
      Endif
      If NO_ACT
        Wrseq '<ACTIVITY_CODE CODE="'+[ACV]CODACT+'">' Using [TTT]
        Wrseq "<ACTIVE>"+string$(ACT_FLACT=1,"No")+string$(ACT_FLACT=2,"Yes")+"</ACTIVE>" Using [TTT]
        Gosub DEPENDENCE
        Wrseq "</ACTIVITY_CODE>" Using [TTT]
      Endif
    Next
    Wrseq "</MODULE>" Using [TTT]
  Next
  Wrseq "</FUNCTIONAL>" Using [TTT]

  Wrseq "<SIZING>" Using [TTT]
  For [ACV]ACV1(1) Where TYP=2
    Read [AP0]CLE=14;[ACV]MODULE;GLANGUE
    Wrseq '<MODULE NAME="'+[AP0]LANMES+'">' Using [TTT]
    For [ACV]ACV1
      If [ADS]DOSSIER=nomap
         ACT_FLACT=[ACV]FLACT
         ACT_DIME=[ACV]DIME
         NO_ACT=1
      Else
         Read [ADA]ADA0=[ADS]DOSSIER;[ACV]CODACT
         NO_ACT=(fstat=0)
         ACT_FLACT=[ADA]FLACT
         ACT_DIME=[ADA]DIME
      Endif
      If NO_ACT
         Wrseq '<ACTIVITY_CODE CODE="'+[ACV]CODACT+'">' Using [TTT]
         Wrseq "<ACTIVE>"+string$(ACT_FLACT=1,"No")+string$(ACT_FLACT=2,"Yes")+"</ACTIVE>" Using [TTT]
         Wrseq "<DIMENSION>"+num$(ACT_DIME)+"</DIMENSION>" Using [TTT]
         Wrseq "<DIM_MIN>"+num$([ACV]DIMFIL)+"</DIM_MIN>" Using [TTT]
         Wrseq "<DIM_MAX>"+num$([ACV]DIMMAX)+"</DIM_MAX>" Using [TTT]
         Gosub DEPENDENCE
         Wrseq "</ACTIVITY_CODE>" Using [TTT]
      Endif
    Next
    Wrseq "</MODULE>" Using [TTT]
  Next

  Wrseq "</SIZING>" Using [TTT]

  Wrseq "<LOCALIZATION>" Using [TTT]

  For [ACV]ACV1(1) Where TYP=3
    Read [AP0]CLE=14;[ACV]MODULE;GLANGUE
    Wrseq '<MODULE NAME="'+[AP0]LANMES+'">' Using [TTT]
    For [ACV]ACV1
       If [ADS]DOSSIER=nomap
          ACT_FLACT=[ACV]FLACT
          NO_ACT=1
       Else
          Read [ADA]ADA0=[ADS]DOSSIER;[ACV]CODACT
          NO_ACT=(fstat=0)
          ACT_FLACT=[ADA]FLACT
       Endif
       If NO_ACT
          Wrseq '<ACTIVITY_CODE CODE="'+[ACV]CODACT+'">' Using [TTT]
          Wrseq "<ACTIVE>"+string$(ACT_FLACT=1,"No")+string$(ACT_FLACT=2,"Yes")+"</ACTIVE>" Using [TTT]
          Gosub DEPENDENCE
          Wrseq "</ACTIVITY_CODE>" Using [TTT]
       Endif
    Next
    Wrseq "</MODULE>" Using [TTT]
  Next
  Wrseq "</LOCALIZATION>" Using [TTT]

  Wrseq "</ACTIVITY_CODES>" Using [TTT]
  Close Local File [ACV],[ADA]
Return

$DEPENDENCE
  If [ACV]DEP>1
      Read [AP0]CLE=74;[ACV]DEP;GLANGUE
      Wrseq '<DEPENDENCE TYPE="'+[AP0]LANMES+'">' Using [TTT]
      If [ACV]DEP=4
          CHAINE=[ACV]ACTFOR
          Gosub CHANGE_CHAINE
          Wrseq "<FORMULA>"+CHAINE+"</FORMULA>" Using [TTT]
      Else
          Wrseq "<DEP_ACT>"+[ACV]ACTDEP+"</DEP_ACT>" Using [TTT]
      Endif
      Wrseq "</DEPENDENCE>" Using [TTT]
  Endif
Return

$LIRE_ENTRY_POINTS
 If [ADS]DOSSIER<>nomap : Return : Endif
 Local File =[ADS]DOSSIER+".AENTREE"
 Wrseq "<ENTRY_POINTS>" Using [TTT]
 For [APE]APE0
    Wrseq '<STD_TRT NAME="'+[APE]TRTSTD+'">' Using [TTT]
    Wrseq "<SPE_TRT>"+[APE]TRTSPE+"</SPE_TRT>" Using [TTT]
    Wrseq "<ACV_CODE>"+[APE]CODACT+"</ACV_CODE>" Using [TTT]
    If dim([ACV]TRTPAR)>0 and [ACV]TRTPAR<>""
        CHAINE=[ACV]TRTPAR
        Gosub CHANGE_CHAINE
        Wrseq "<PARAM>"+CHAINE+"</PARAM>" Using [TTT]
    Endif
    Wrseq "</STD_TRT>" Using [TTT]
 Next
 Wrseq "</ENTRY_POINTS>" Using [TTT]
 Close Local File [APE]
Return


$DOSSIER

  # On ne prend le détail que pour le dossier superviseur, le dossier mère, et le dossier courant
  If find([ADS]DOSSIER,nomap,GDOSX3,adxmother(0))=0 : Return : Endif

  Local File =[ADS]DOSSIER+".APLSTD" [AP0]
  Wrseq "<HEADER>" Using [TTT]
  Wrseq "<NAME>"+[ADS]NOMDOS+"</NAME>" Using [TTT]
  Wrseq "<REFFOLDER>"+[ADS]DOSREF+"</REFFOLDER>" Using [TTT]
  Wrseq "<TESTFOLDER>"+mess([ADS]TSTFLG,1,1)+"</TESTFOLDER>" Using [TTT]
  Wrseq "<SPEFOLDER>"+mess([ADS]SPEFLG,1,1)+"</SPEFOLDER>" Using [TTT]
  Wrseq "<DATABASE>"+mess([ADS]TYPDBA,57,1)+"</DATABASE>" Using [TTT]
  Wrseq "<LANGUAGE>"+sigma(0,[ADS]NBRLAN-1,[ADS]LAN(indcum)+string$(indcum<[ADS]NBRLAN-1,","))+"</LANGUAGE>" Using [TTT]
  Wrseq "<DEFLANGUAGE>"+[ADS]LANDEF+"</DEFLANGUAGE>" Using [TTT]
  Wrseq "<MODULES>"+sigma(0,19,string$([ADS]MODULE(indcum)=2,mess(indcum+1,14,1)+string$(sum([ADS]MODULE(indcum+1..19))>18-indcum,",")))+"</MODULES>" Using [TTT]
  Wrseq "<STARTDATE>"+format$("D:YYYY[-]MM[-]DD",[ADS]STRDAT)+"</STARTDATE>" Using [TTT]
  Wrseq "<RPTCURRENCY>"+[ADS]RPTCUR+"</RPTCURRENCY>" Using [TTT]
  Wrseq "<DEFCOUNTRY>"+[ADS]CRYDEF+"</DEFCOUNTRY>" Using [TTT]
  Wrseq "<APL_INI>" Using [TTT]
  Gosub LIRE_APL_INI
  For II=1 To NBAPL
    Wrseq "<"+VARAPL(II)+">"+VALAPL(II)+"</"+VARAPL(II)+">" Using [TTT]
  Next II
  Wrseq "</APL_INI>" Using [TTT]
  Wrseq "</HEADER>" Using [TTT]
  Gosub LIRE_ACTIVITY
  Gosub LIRE_ENTRY_POINTS
  Gosub LIRE_FCYCPY
  Gosub LIRE_PARAM
  Gosub LIRE_TRT
  Gosub LIRE_TRTSPE
  Wrseq "<PATCHES>" Using [TTT]
  Gosub LIRE_PATCH
  Wrseq "</PATCHES>" Using [TTT]
  Close Local File [AP0]

Return


$DATABASE

  # On ne met des infos que pour le dossier superviseur, le dossier mère, et le dossier courant
  If find([ADS]DOSSIER,nomap,GDOSX3,adxmother(0))=0 : Return : Endif

  Wrseq '<DATABASE TYPE="'+string$(GTYPDBA=1,"ORACLE")+string$(GTYPDBA=2,"Sql server") +'">' Using [TTT]

  # Les stats et index ne sont récupérables que dans le dossier courant
  If nomap=[ADS]DOSSIER
      Wrseq "<STATS>" Using [TTT]
      If GTYPDBA=1
          Gosub STATS_ORACLE
      Else
          Gosub STATS_SQL
      Endif
      Wrseq "</STATS>" Using [TTT]
      Wrseq "<INDEXES_VERIFICATION>" Using [TTT]
      Gosub TEST_INDEX
      Wrseq "</INDEXES_VERIFICATION>" Using [TTT]
  Endif
  Wrseq "</DATABASE>" Using [TTT]
Return

$STATS_ORACLE
  Local Mask ORASTA1
  Call CHARGE_STA1(II) From ORASTA : # II n'est pas renseigné en cas d'erreur !!!
  For II=1 To [M:STA1]NBTAB
    Wrseq '<TABLE NAME="'+[M:STA1]TAB(II-1)+'">' Using [TTT]
    Wrseq "<LAST_ANALYSIS>"+format$("D:YYYY[-]MM[-]DD",gdat$([M:STA1]STTDAT(II-1)))+"T"+[M:STA1]STTHOU(II-1)+"</LAST_ANALYSIS>" Using [TTT]
    NBROWS=0
    Onerrgo PASFIC
    Local File =[ADS]DOSSIER+"."+[M:STA1]TAB(II-1) [XXX]
    NBROWS=nbrecord([XXX])
    Close Local File [XXX]
    Onerrgo
    Wrseq "<NB_ROWS>"+num$(NBROWS)+"</NB_ROWS>" Using [TTT]
    Wrseq "</TABLE>" Using [TTT]
  Next II
  Close Local Mask [STA1]
Onerrgo
Return

$PASFIC
JJ=1
Resume

$STATS_SQL
  Local Mask SQLSTA1
  Call CHARGE_STA1(II) From SQLSTA : # II n'est pas renseigné en cas d'erreur !!!
  For II=1 To [M:STA1]NBINDEX
    Wrseq '<TABLE NAME="'+[M:STA1]TAB(II)+'">' Using [TTT]
    Wrseq "<LAST_ANALYSIS>"+format$("D:YYYY[-]MM[-]DD",gdat$([M:STA1]STTDAT(II)))+"T"+[M:STA1]STTHOU(II)+"</LAST_ANALYSIS>" Using [TTT]
    Wrseq "<NB_ROWS>"+num$([M:STA1]NBRLIN(II))+"</NB_ROWS>" Using [TTT]
    Wrseq "</TABLE>" Using [TTT]
  Next II
  Close Local Mask [STA1]
Return

# Copie un peu brutale de la fonction correspondante
$TEST_INDEX

Local Integer MAX_INDEX : MAX_INDEX=3000
Local Integer NB_INDEX,NB_IDICO,NB_INDBASE,NB_INDBLOB,NB_IPASDIC,NB_INDINT,NB_INDACT,NB_INDPASVAL
Local Integer NB_IDICOSPE,NB_INDSPEVAL

# Déclaration des variables
Local Char NOM_TABLES(20)(1..MAX_INDEX),NOM_INDEX(30)(1..MAX_INDEX),TYPE_BASE(1),CHAINE(255),NOM_BASE(30)
Local Integer INDEX_TROUVES(1..MAX_INDEX), I_I, I_J, I_K,SI_ERREUR,L_BLOB

############################################
# On aura dans INDEX_TROUVES(NB_INDEX)
# 0 : # Index "NOM_BASE" non décrits dans le dictionnaire X3
# 1 : # Index du dictionnaire X3 OK
# 2 : # Index non conforme à la règle de nommage ADONIX
# 3 : # Index interne adonix
# 4 : # Table non decrite dans dico
############################################

Local Char REQUETE(250)
Local Char Z_ADXIFS(1),Z_ADXIRS(2)
Local Libelle OCT_LUS(1..30)
Local Integer OK,NB_TMP

 Local Char REQUETE(250)
 If GTYPDBA=1
    TYPE_BASE="3"
    REQUETE="Select index_name, table_name from user_indexes Order By table_name"
 Else
    TYPE_BASE="5"
    Local Char WVERSSQL
    OK=0
    Call VERS_SQL(WVERSSQL,OK) From SQLDICO
    If OK<>0 : Return : Endif
    If WVERSSQL="8"
        REQUETE="Select i.name, o.name from sysindexes i, sysobjects o, sysusers u"
&                   +" Where o.id=i.id and o.uid=u.uid and i.name<>o.name"
&                   + " and i.name not like '%_ROWID' and (i.status=0 or i.status=2) and u.name='"+nomap+"'"
&                   +" Order By o.name, i.name "
    Else
        REQUETE="Select i.name, o.name from sysindexes i, sysobjects o"
&                   +" Where o.id=i.id and i.name<>o.name"
&                   + " and i.name not like '%_ROWID' and (i.status=0 or i.status=2) and SCHEMA_NAME(o.uid)='"+nomap+"'"
&                   +" Order By o.name, i.name "
    Endif
 Endif

# Parcours de la table des index et vérification croisée d'existence
  Local File =[ADS]DOSSIER+".ATABLE" [AT1]

# On parcourt les index de la base et on range le résultat dans les variables
  Raz NB_INDEX,NOM_TABLES,NOM_INDEX,INDEX_TROUVES, NB_IDICO,NB_IDICOSPE
  Raz NB_INDBASE,NB_INDBLOB,NB_IPASDIC,NB_INDINT,NB_INDACT,NB_INDPASVAL,NB_INDSPEVAL

  For (Char A(30)(0..1)) From TYPE_BASE Sql REQUETE As [AAA_]
    NB_INDEX+=1
    NOM_TABLES(NB_INDEX)=A(1)
    If ( TYPE_BASE="3" & (A(1)="SYSBLBK" | A(1)="SYSCLBK") )
      NOM_INDEX(NB_INDEX)=A : INDEX_TROUVES(NB_INDEX)=3 : # Index interne adonix
    Else
      Read [AT1]CODFIC=A(1)
      If fstat>1
         NOM_INDEX(NB_INDEX)=A : INDEX_TROUVES(NB_INDEX)=4 : # Table non decrite dans dico
      Else
          I_I=instr(1,toupper(A),toupper(A(1))+"_")
          If I_I=0
             NOM_INDEX(NB_INDEX)=A : INDEX_TROUVES(NB_INDEX)=2 : # Index non conforme à la règle de nommage ADONIX
          Else
             NOM_INDEX(NB_INDEX)=right$(toupper(A),len(A(1))+2)
          Endif
      Endif
    Endif
  Next

Local File =[ADS]DOSSIER+".ATABIND" [ATI], =[ADS]DOSSIER+".ATABLE" [ATB], =[ADS]DOSSIER+".ACTIV" [ACV],
&          =[ADS]DOSSIER+".ATABZON" [ATZ], =[ADS]DOSSIER+".ATYPE" [ATY]

  If [ADS]DOSSIER<>GDOSX3
     Link [ATI] With [ATB]CODFIC=[ATI]CODFIC As [ATD] Where [ATB]TYPFIC<>3 Order By Key CODIND
  Else
     Link [ATI] With [ATB]CODFIC=[ATI]CODFIC As [ATD] Order By Key CODIND
  Endif

  Raz SI_ERREUR : # Vaudra 1 si une erreur a déjà été rencontrée

For [ATD]
  NB_IDICO+=1
  I_K=0
  I_J=find([ATI]CODFIC,NOM_TABLES(1..NB_INDEX))
  If I_J
     For I_I=I_J To NB_INDEX
        If [ATI]CODFIC<>NOM_TABLES(I_I) : Break : Endif
        If [ATI]CODIND=NOM_INDEX(I_I) : I_K=I_I : Break : Endif
     Next I_I
  Endif
# Index non trouvé ? Vérifier d'abord si la table n'est pas protégée par un code activité non actif...
  If I_K=0
     If [ATB]CODACT<>""
        Read [ACV]CODACT=[ATB]CODACT
        If [ACV]FLACT=1 : NB_INDACT+=1 : Goto NO_ERROR : Endif
     Endif
     If [ATI]CODACT<>""
        Read [ACV]CODACT=[ATI]CODACT
        If [ACV]FLACT=1 : NB_INDACT+=1 : Goto NO_ERROR : Endif
     Endif
     If filinfo(filpath("FIL",[F:ATI]CODFIC,"fde",[ADS]DOSSIER),0)>0
         If SI_ERREUR=0
            Wrseq "<INDEXES_MISSING>" Using [TTT]
         Endif
         SI_ERREUR=1
         Wrseq '<INDEX TABLE="'+[ATI]CODFIC+'">' Using [TTT]
         Wrseq "<NAME>"+[ATI]CODIND+"</NAME>" Using [TTT]
         Wrseq "<DESCRIPT>"+[ATI]DESCRIPT+"</DESCRIPT>" Using [TTT]
         Wrseq "</INDEX>" Using [TTT]
         NB_IPASDIC+=1
     Endif
 Else
     #cet index est OK (sauf si Index non conforme)
     INDEX_TROUVES(I_K)=max(INDEX_TROUVES(I_K),1) : # S'il valait 2, on garde cette valeur
 Endif

$NO_ERROR

Next
If SI_ERREUR : Wrseq "</INDEXES_MISSING>" Using [TTT] : Endif

###########################################################
# Vérification des index inexistants du dico X3 car table inactives
###########################################################

Raz SI_ERREUR : # Vaudra 1 si une erreur a déjà été rencontrée

For [ATD]
  I_K=0
  I_J=find([ATI]CODFIC,NOM_TABLES(1..NB_INDEX))
  If I_J
     For I_I=I_J To NB_INDEX
        If [ATI]CODFIC<>NOM_TABLES(I_I) : Break : Endif
        If [ATI]CODIND=NOM_INDEX(I_I) : I_K=I_I : Break : Endif
     Next I_I
  Endif
# Index non trouvé ? Vérifier d'abord si la table n'est pas protégée par un code activité non actif...
  If I_K=0
     If [ATB]CODACT<>""
        Read [ACV]CODACT=[ATB]CODACT
        If [ACV]FLACT=1 : Goto NO_ERR_INACTIF : Endif
     Endif
     If [ATI]CODACT<>""
        Read [ACV]CODACT=[ATI]CODACT
        If [ACV]FLACT=1 : Goto NO_ERR_INACTIF : Endif
     Endif
     If filinfo(filpath("FIL",[F:ATI]CODFIC,"fde",[ADS]DOSSIER),0)<0
         NB_INDPASVAL+=1
         If SI_ERREUR=0
            # Liste des index inexistants car tables inactives
            Wrseq "<INDEXES_MISSING_ON_INACTIVE_TABLES>" Using [TTT]
         Endif
         SI_ERREUR=1
         Wrseq '<INDEX TABLE="'+[ATI]CODFIC+'">' Using [TTT]
         Wrseq "<NAME>"+[ATI]CODIND+"</NAME>" Using [TTT]
         Wrseq "<DESCRIPT>"+[ATI]DESCRIPT+"</DESCRIPT>" Using [TTT]
         Wrseq "</INDEX>" Using [TTT]
     Endif
  Endif

$NO_ERR_INACTIF

Next
If SI_ERREUR : Wrseq "</INDEXES_MISSING_ON_INACTIVE_TABLES>" Using [TTT] : Endif

####################################################################################
# Parcours de la table des index d'optimisation et vérification croisée d'existence
####################################################################################

Local File =[ADS]DOSSIER+".AINDEX" [ANX], =[ADS]DOSSIER+".ATABLE" [AT2]

# Est-on dans le superviseur ? Si non, on ne doit pas voir les tables de type Systeme X3
If [ADS]DOSSIER<>GDOSX3
  Link [ANX] With [ATB]CODFIC=[ANX]TABLE As [ANX2] Where [ATB]TYPFIC<>3 Order By Key ANX2
Else
  Link [ANX] With [ATB]CODFIC=[ANX]TABLE As [ANX2] Order By Key ANX2
Endif

Raz SI_ERREUR : # Vaudra 1 si une erreur a déjà été rencontrée

For [ANX2]
  NB_IDICOSPE+=1
  I_K=0
  I_J=find([ANX]TABLE,NOM_TABLES(1..NB_INDEX))
  If I_J
     For I_I=I_J To NB_INDEX
        If [ANX]TABLE<>NOM_TABLES(I_I) : Break : Endif
        If [ANX]CODIND=NOM_INDEX(I_I) : I_K=I_I : Break : Endif
     Next I_I
  Endif
# Index non trouvé ? Vérifier d'abord si la table n'est pas protégée par un code activité non actif...
  If I_K=0
     If [ATB]CODACT<>""
        Read [ACV]CODACT=[ATB]CODACT
        If [ACV]FLACT=1 : NB_INDACT+=1 : Goto NO_ERROR_SPE : Endif
     Endif
     If filinfo(filpath("FIL",[F:ANX]TABLE,"fde",[ADS]DOSSIER),0)>0 & [ANX]FLACT=2
         If SI_ERREUR=0
            # Liste des index du dictionnaire X3 non existants sous
            Wrseq "<OPTIMIZATION_INDEX_MISSING>" Using [TTT]
         Endif
         SI_ERREUR=1
         Wrseq '<INDEX TABLE="'+[ANX]TABLE+'">' Using [TTT]
         Wrseq "<NAME>"+[ANX]CODIND+"</NAME>" Using [TTT]
         Wrseq "<DESCRIPT>"+[ANX]DESCRIPT+"</DESCRIPT>" Using [TTT]
         Wrseq "</INDEX>" Using [TTT]
         NB_IPASDIC+=1
     Endif
  Else
     #cet index est OK (sauf si Index non conforme)
     INDEX_TROUVES(I_K)=max(INDEX_TROUVES(I_K),1) : # S'il valait 2, on garde cette valeur
  Endif

$NO_ERROR_SPE

Next
If SI_ERREUR : Wrseq "</OPTIMIZATION_INDEX_MISSING>" Using [TTT] : Endif


###
###########################################################
# Vérification des index d'optimisation inexistants du dico X3 car inactifs ou table inactives
Raz SI_ERREUR : # Vaudra 1 si une erreur a déjà été rencontrée

For [ANX2]
  I_K=0
  I_J=find([ANX]TABLE,NOM_TABLES(1..NB_INDEX))
  If I_J
     For I_I=I_J To NB_INDEX
        If [ANX]TABLE<>NOM_TABLES(I_I) : Break : Endif
        If [ANX]CODIND=NOM_INDEX(I_I) : I_K=I_I : Break : Endif
     Next I_I
  Endif
# Index non trouvé ? Vérifier d'abord si la table n'est pas protégée par un code activité non actif...
  If I_K=0
     If [ATB]CODACT<>""
        Read [ACV]CODACT=[ATB]CODACT
        If [ACV]FLACT=1 : Goto NO_ERR_SPEINACTIF: Endif
     Endif
     If filinfo(filpath("FIL",[F:ANX]TABLE,"fde",[ADS]DOSSIER),0)<0 | [ANX]FLACT<>2
         NB_INDSPEVAL+=1
         If SI_ERREUR=0
            # Liste des index inexistants car tables inactives
            Wrseq "<OPTIMIZATION_INDEX_INACTIVE_ON_TABLES>" Using [TTT]
         Endif
         SI_ERREUR=1
         Wrseq '<INDEX TABLE="'+[ANX]TABLE+'">' Using [TTT]
         Wrseq "<NAME>"+[ANX]CODIND+"</NAME>" Using [TTT]
         Wrseq "<DESCRIPT>"+[ANX]DESCRIPT+"</DESCRIPT>" Using [TTT]
         Wrseq "</INDEX>" Using [TTT]
     Endif
  Endif

$NO_ERR_SPEINACTIF

Next
If SI_ERREUR : Wrseq "</OPTIMIZATION_INDEX_INACTIVE_ON_TABLES>" Using [TTT] : Endif


###########################################################
# Vérification des index internes
###########################################################
Raz SI_ERREUR : # Vaudra 1 si une erreur a déjà été rencontrée

For I_I=1 To NB_INDEX
  If INDEX_TROUVES(I_I)=3
     If SI_ERREUR=0
        Wrseq "<INTERNAL_INDEXES>" Using [TTT]
     Endif
     SI_ERREUR=1
     Wrseq '<INDEX TABLE="'+NOM_TABLES(I_I)+'">' Using [TTT]
     Wrseq "<NAME>"+NOM_INDEX(I_I)+"</NAME>" Using [TTT]
     Wrseq "</INDEX>" Using [TTT]
     NB_INDINT+=1
  Endif
Next I_I
If SI_ERREUR : Wrseq "</INTERNAL_INDEXES>" Using [TTT] : Endif

###########################################################
# Vérification qu'aucun index de la base n'a été oublié
###########################################################
Raz SI_ERREUR : # Vaudra 1 si une erreur a déjà été rencontrée

For I_I=1 To NB_INDEX
  If INDEX_TROUVES(I_I)=0 |  INDEX_TROUVES(I_I)=4
&    | (INDEX_TROUVES(I_I)=2
&    & ((TYPE_BASE="3" & left$(NOM_INDEX(I_I),6)<>"SYS_IL")|(TYPE_BASE="5" & NOM_INDEX(I_I)<>"t"+NOM_TABLES(I_I))))
     If SI_ERREUR=0
        Wrseq "<INDEXES_NOT_DESCRIBED_IN_DICTIONARY>" Using [TTT]
     Endif
     SI_ERREUR=1
     Wrseq '<INDEX TABLE="'+NOM_TABLES(I_I)+'">' Using [TTT]
     Wrseq "<NAME>"+NOM_INDEX(I_I)+"</NAME>" Using [TTT]
     Wrseq "</INDEX>" Using [TTT]
     NB_INDBASE+=1
   Endif
Next I_I
If SI_ERREUR : Wrseq "</INDEXES_NOT_DESCRIBED_IN_DICTIONARY>" Using [TTT] : Endif

###########################################################
# Liste des index non conformes
###########################################################
Link [ATZ] With [ATY]CODTYP=[ATZ]CODTYP As [ATT] Order By CODZONE

SI_ERREUR=0 : # Vaudra 1 si une erreur a déjà été rencontrée
For I_I=1 To NB_INDEX
  L_BLOB=0
  If INDEX_TROUVES(I_I)=2
    # On vérifie s'il s'agit d'un Blob. Sous Oracle SYS_ILxxxx. Sous Sql Server tNOM_TABLE
    # On vérifie qu'au moins un Blob ou un Clob est aassocié à cette table
    Read [ATB]CODFIC=NOM_TABLES(I_I)
    If fstat<2
      For [ATT] Where ([ATY]TYPTYP=9 | [ATY]TYPTYP=10) & [ATZ]CODFIC=NOM_TABLES(I_I)
        L_BLOB=1 : Break
      Next
    Endif
    If (left$(NOM_INDEX(I_I),6)<>"SYS_IL" | TYPE_BASE<>"3" | L_BLOB=0)
&   & (NOM_INDEX(I_I)<>"t"+NOM_TABLES(I_I) | TYPE_BASE<>"5" | L_BLOB=0)
      If SI_ERREUR=0
         Wrseq "<INDEX_NOT_CONFORMANT>" Using [TTT]
      Endif
      SI_ERREUR=1
      Wrseq '<INDEX TABLE="'+NOM_TABLES(I_I)+'">' Using [TTT]
      Wrseq "<NAME>"+NOM_INDEX(I_I)+"</NAME>" Using [TTT]
      Wrseq "</INDEX>" Using [TTT]
    Endif
  Endif
  If (TYPE_BASE="3" & left$(NOM_INDEX(I_I),6)="SYS_IL" & L_BLOB=1)
     NB_INDBLOB+=1
  Endif
  If (TYPE_BASE="5" & NOM_INDEX(I_I)="t"+NOM_TABLES(I_I) & L_BLOB=1)
    NB_INDBLOB+=1
  Endif
Next I_I
If SI_ERREUR : Wrseq "</INDEX_NOT_CONFORMANT>" Using [TTT] : Endif
Close Local File [AT1],[ATI],[ATB],[ACV],[ATZ],[ATY],[ANX],[AT2]
Return

# Configuration du serveur Web
$WEBSERVER
  Local Char SECTIONS(250)(1..10), OLD_SECTIONS(250)(1..10), BUFSEC(200)
  Local Integer NUM_SECTIONS,ICAR,ISEC,MAXSEC,ISRWEB

  For ISRWEB=1 To NB_WEBSERVER
     Raz SECTIONS, OLD_SECTIONS, NUM_SECTIONS
     Wrseq '<WEBSERVER_ID name="'+WEBSERVER_ID(ISRWEB)+'">' Using [TTT]
     If WEBSERVER_NAME(ISRWEB)="" or WEBSERVER_PATH(ISRWEB)=""
        Wrseq "none" Using [TTT]
     Else
        Wrseq "<SERVER_NAME>"+WEBSERVER_NAME(ISRWEB)+"</SERVER_NAME>" Using [TTT]
        CHAINE=WEBSERVER_PATH(ISRWEB) : Gosub CHANGE_CHAINE
        Wrseq "<SERVER_PATH>"+CHAINE+"</SERVER_PATH>" Using [TTT]
        If filinfo(WEBSERVER_NAME(ISRWEB)+WEBSERVER_PATH(ISRWEB),7)<0
            Wrseq "<STATUS>not accessible</STATUS>" Using [TTT]
        Else
            CHAINE="\TOOLS\ADXADMIN\CONFIG\config.ini"
            If pat(toupper(WEBSERVER_OS(ISRWEB)),"WIN*")=0 : CHAINE=ctrans(CHAINE,"\","/") : Endif
            Openi WEBSERVER_NAME(ISRWEB)+"@"+WEBSERVER_PATH(ISRWEB)+CHAINE,0 Using [RRR]
            Rdseq BUFLEC Using [RRR]
            While fstat=0
              ICAR=instr(1,BUFLEC,"=")
              If ICAR
                  BUFSEC=left$(BUFLEC,ICAR-1)
                  BUFLEC=right$(BUFLEC,ICAR+1)
                  NUM_SECTIONS=1
                  ICAR=instr(1,BUFSEC,".")
                  While ICAR
                      SECTIONS(NUM_SECTIONS)=left$(BUFSEC,ICAR-1)
                      BUFSEC=right$(BUFSEC,ICAR+1)
                      NUM_SECTIONS+=1
                      ICAR=instr(1,BUFSEC,".")
                  Wend
                  SECTIONS(NUM_SECTIONS)=BUFSEC
                  SECTIONS(NUM_SECTIONS+1)=""

                  For ISEC=max(MAXSEC,NUM_SECTIONS) To 1 Step -1
                      If OLD_SECTIONS(ISEC)<>"" and sigma(1,ISEC,OLD_SECTIONS(indcum)+".")<>sigma(1,ISEC,SECTIONS(indcum)+".")
                          Wrseq "</"+toupper(OLD_SECTIONS(ISEC))+">" Using [TTT]
                          OLD_SECTIONS(ISEC)=""
                      Endif
                  Next ISEC

                  For ISEC=1 To max(MAXSEC,NUM_SECTIONS)
                      If SECTIONS(ISEC)<>"" and OLD_SECTIONS(ISEC)=""
                          Wrseq "<"+toupper(SECTIONS(ISEC))+">" Using [TTT]
                      Endif
                  Next ISEC

                  MAXSEC=NUM_SECTIONS
                  For ISEC=1 To NUM_SECTIONS
                      OLD_SECTIONS(ISEC)=SECTIONS(ISEC)
                  Next ISEC
                  Raz SECTIONS

                  CHAINE=BUFLEC : Gosub CHANGE_CHAINE
                  Wrseq CHAINE Using [TTT]
              Endif
              Rdseq BUFLEC Using [RRR]
            Wend

            For ISEC=max(MAXSEC,NUM_SECTIONS) To 1 Step -1
              If OLD_SECTIONS(ISEC)<>""
                  Wrseq "</"+toupper(OLD_SECTIONS(ISEC))+">" Using [TTT]
              Endif
            Next ISEC

            Openi Using [RRR]
        Endif
     Endif
     Wrseq '</WEBSERVER_ID>' Using [TTT]
  Next ISRWEB
Return

# Lecture de fichier XML sans séparateur de ligne
$LEC_BUFLEC
 BUFLEC=""
$LEC_BUFLEC1
  If ICARAC=0
    If ISIZE=0 : fstat=1 : Return : Endif
    MAXCARAC=min(ISIZE,dim(BUFFER))
    Getseq MAXCARAC, BUFFER Using [RRR]
    ISIZE-=MAXCARAC
  Endif
  While ICARAC<MAXCARAC
    ICARAC+=1
    BUFLEC+=chr$(BUFFER(ICARAC))
    If chr$(BUFFER(ICARAC))=">"
        Break
    Endif
  Wend
  If ICARAC>=MAXCARAC
    If chr$(BUFFER(ICARAC))<>">"
        ICARAC=0
        Goto LEC_BUFLEC1
    Endif
    ICARAC=0
  Endif
  fstat=0
Return

# Configuration du serveur d'édition : fichier xml sans fin de ligne, galère !
$EDTSERVER
  Local Integer ISREDT,ISIZE,ICARAC, MAXCARAC, RESEAU_OK
  Local Libelle BUFFER(1..2500)

  For ISREDT=1 To NB_EDTSERVER
     Wrseq '<EDTSERVER_ID name="'+EDTSERVER_ID(ISREDT)+'">' Using [TTT]
     If EDTSERVER_NAME(ISREDT)="" or EDTSERVER_PATH(ISREDT)=""
        Wrseq "none" Using [TTT]
     Else
        Wrseq "<SERVER_NAME>"+EDTSERVER_NAME(ISREDT)+"</SERVER_NAME>" Using [TTT]
        CHAINE=EDTSERVER_PATH(ISREDT) : Gosub CHANGE_CHAINE
        Wrseq "<SERVER_PATH>"+CHAINE+"</SERVER_PATH>" Using [TTT]
        RESEAU_OK=1 : Onerrgo ERR_RESEAU
        Getui CHAINE=EDTSERVER_NAME(ISREDT)+":"+EDTSERVER_PORT(ISREDT)+"@" With "X3ImpFileVersion"
        If RESEAU_OK=1
            CHAINE=right$(CHAINE,instr(1,CHAINE,chr$(1))+1)
            Wrseq "<SERVER_VERSION>"+CHAINE+"</SERVER_VERSION>" Using [TTT]
            CHAINE="\Config\adxeditionserverconfig.xml"
            If pat(toupper(EDTSERVER_OS(ISREDT)),"WIN*")=0 : CHAINE=ctrans(CHAINE,"\","/") : Endif
            ISIZE=filinfo(EDTSERVER_NAME(ISREDT)+":"+num$(GADMINPORT)+"@"+EDTSERVER_PATH(ISREDT)+CHAINE,7)
            If ISIZE<0
                Wrseq "<STATUS>not accessible</STATUS>" Using [TTT]
            Else
                Openi EDTSERVER_NAME(ISREDT)+":"+num$(GADMINPORT)+"@"+EDTSERVER_PATH(ISREDT)+CHAINE,0 Using [RRR]
                Gosub LEC_BUFLEC
                While fstat=0
                    If pat(BUFLEC,"<*xml*version*")=0
                        Wrseq ctrans(BUFLEC,chr$(13),"")+chr$(13) Using [TTT]
                    Endif
                    Gosub LEC_BUFLEC
                Wend

                CHAINE="\Config\adxeditionserversolutions.xml"
                If pat(toupper(EDTSERVER_OS(ISREDT)),"WIN*")=0 : CHAINE=ctrans(CHAINE,"\","/") : Endif
                Openi EDTSERVER_NAME(ISREDT)+":"+num$(GADMINPORT)+"@"+EDTSERVER_PATH(ISREDT)+CHAINE,0 Using [RRR]
                Gosub LEC_BUFLEC
                While fstat=0
                    If pat(BUFLEC,"<*xml*version*")=0
                        Wrseq ctrans(BUFLEC,chr$(13),"")+chr$(13) Using [TTT]
                    Endif
                    Gosub LEC_BUFLEC
                Wend
            Endif
        Else
            Wrseq "<STATUS>not available</STATUS>" Using [TTT]
        Endif
     Endif
     Wrseq '</EDTSERVER_ID>' Using [TTT]
 Next ISREDT
 Openi Using [RRR]
Return

ERR_RESEAU
    RESEAU_OK=0
Resume
######################################################################################
## Ecran ALOGSUP
######################################################################################
Subprog D_MAILSAGE(VALEUR)
Variable Char    VALEUR()
VALEUR = func AFNC.PARAM("MAILSAGE","")
VALEUR = func VIRE_BY(VALEUR)
If VALEUR<>""
 Grizo MAILSAGE
Endif
End

