#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion du fichier DECCHARGE
Raz GPILOBJ
Call OBJET("DCH",GBIDC1,"") From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "SETBOUT"   : Gosub SETBOUT
 When "LIENS"     : Gosub LIENS
 When "RAZCRE"    : Gosub RAZCRE
 When "SEL_TABLE" : Gosub SEL_TABLE
 When "FERME"     : Gosub FERME
 When "AP_CHANGE" : Gosub AP_CHANGE
 When "ANNULE"    : Gosub ANNULE
 When "CREATION"  : Gosub CREATION
 When "MODIF"     : Gosub MODIF
 When "AS_CODDCC" : Gosub AS_CODDCC
 When "BS_CODDCC" : Gosub BS_CODDCC
Endcase
Return

#Before selection on field CODDCC
#############
$AS_CODDCC
Raz GCURLEG
Return

#After selection on field COD
############
$BS_CODDCC
# To do nothing if the user doesn't select a record
If [F:DCH]CODDCC<>"" :
 mkstat=4                     # mkstat=4 to load again the record after selection
 If dim([M:DCH1]LEG)>=0 : [M:DCH1]LEG=[F:DCH]LEG: Endif
 GCURLEG=[F:DCH]LEG
 # Else we need to update GCURLEG becaude we erased it in $AS_COD
 If dim([M:DCH1]LEG)>=0
  GCURLEG=[M:DCH1]LEG
 Elsif GLEFIL<>""
  GCURLEG=GLEGFIL
 Else
  GCURLEG=GDOSLEG
 Endif
Endif
Return

$SETBOUT
If REP<>"" | CLECUR=0 | GHISTO=1
 Call VIREBOUT(CHAINE,"8") From GOBJET
Endif
Return

$OUVRE
If clalev([F:DCH])=0 : Local File DECCHARGE [DCH] : Endif
If clalev([F:RUB])=0 : Local File RUBRIQUE [RUB] : Endif
If clalev([F:DCH2])=0 : Local File DECCHARGE [DCH2] : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#87135
If clalev([F:ADI])=0 : Local File ATABDIV    [ADI] : Endif
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

########################################
# To change translated texts (data type AX3) when you change the main code
$AP_CHANGE
  Call CHGTEXTRA("DECCHARGE","DESDCC",SUPP,[L]OCODE,SUPP,[L]NCODE) From ATEXTRA
Return

########################################
# To delete translated texts (data type AX3)
$ANNULE
  Call SUPTEXTRA("DECCHARGE","DESDCC",SUPP,[L]CODE) From ATEXTRA
Return

########################################
$LIENS
GCURLEG=[F:DCH]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif

#To manage translated texts (data type AX3)
Call LECTEXTRA([M]DESDCC,"DECCHARGE","DESDCC",GCURLEG,[M]CODDCC) From ATEXTRA
#82898 : US 1068 & 1070 (DBA to help DLE;)

#MAPAD - 2016-03-22 - Req 114309 - START
Local Char LSTORG
Call PARAM (GCURLEG,"LSTORG",LSTORG) From ADOVAL
[M:DCH1]CAILIB = val(LSTORG)
Affzo [M:DCH1]CAILIB
#MAPAD - 2016-03-22  - Req 114309 - END

Call DISPLAY_HIDE() From SUBDCHLEG

Gosub GRISE_LNK
Gosub GRISE_TRS

#89241

If val([M]CAI)>0 & [M]CAILIB>0
  [M]CAIVAL=mess(val([M]CAI),[M]CAILIB,1)
Else
  [M]CAIVAL=""
Endif
Return

#82898 : US 1068 & 1070 (DBA to help DLE;)
$RAZCRE
GCURLEG = ""

#MAPAD - 2016-03-22 - Req 114309 - START
Local Char LSTORG
Call PARAM (GCURLEG,"LSTORG",LSTORG) From ADOVAL
[M:DCH1]CAILIB = val(LSTORG)
Affzo [M:DCH1]CAILIB
#MAPAD - 2016-03-22  - Req 114309 - END

Call DISPLAY_HIDE() From SUBDCHLEG
Return

# To manage translated texts (data type AX3) in creation and duplication
$TEXTRA
If GREP="D"
 ## In duplication mode we want to keep all translated texts
 Call DUPTEXTRA("DECCHARGE","DESDCC",CLECUR1,"","DECCHARGE","DESDCC",GCURLEG,[F:DCH]CODDCC)  From ATEXTRA
Endif
Call MAJTEXTRA([M]DESDCC,"DECCHARGE","DESDCC",GCURLEG,[F:DCH]CODDCC) From ATEXTRA
Return


########################################
#87653: Gestion de l'alphanumérique pour le cas des Corses dans le code INSEE
$MODIF
If ([F:DCH]OPTSAL=6 or [F:DCH]OPTSAL=7)
 If [F:DCH]OPTRAT=2
  If [F:DCH]FLGADD=2
   For [F:DCH2]DCH0 Where DCHRAT=[F:DCH]CODDCC and FLGADD<>2
    [F:DCH2]FLGADD=2
    [F:DCH2]CODVRA=""
    Rewrite [DCH2]
    If fstat<>0
     GOK = 0 : Call FSTA("DCH2") From GLOCK : Break
    Endif
   Next
   If GOK<1 : Return : Endif
  Else
   For [F:DCH2]DCH0 Where DCHRAT=[F:DCH]CODDCC and CODVRA<>[F:DCH]CODVRA
    [F:DCH2]FLGADD=1
    [F:DCH2]CODVRA=[F:DCH]CODVRA
    Rewrite [DCH2]
    If fstat<>0
     GOK = 0 : Call FSTA("DCH2") From GLOCK : Break
    Endif
   Next
   If GOK<1 : Return : Endif
  Endif
 Endif
Endif

Gosub TEXTRA
Return
#########################################
$CREATION
  Gosub TEXTRA
Return

################################################################################
#    Entête
################################################################################

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()

GCURLEG=VALEUR

Local Char LSTORG

Call PARAM (GCURLEG,"LSTORG",LSTORG) From ADOVAL
[M:DCH1]CAILIB = val(LSTORG)
Affzo [M:DCH1]CAILIB

#82898 : US 1068 & 1070 (DBA to help DLE;)
Call DISPLAY_HIDE() From SUBDCHLEG

#Initialize Petty cash and Headings list if we change the legislation
Effzo [M:DCH1]CAI, CAIVAL, NUMRUB
End

########################################
#89241
Subprog AM_CAIVAL(VALEUR)
Variable Char VALEUR

#MAPAD - 2016-03-22 - Req 114309 - START
#If val([M]CAI)<>GINDARR & val([M]CAI)<>GINDAGI
# Effzo [M]FLGAGF : Grizo [M]FLGAGF
#   If val([M]CAI)<>GINDPREV
#    Effzo [M]CODCSC,CODCPN : Grizo [M]CODCSC,CODCPN
#   Endif
#Else
# Actzo [M]CODCSC,CODCPN,FLGAGF
#Endif


If val([M]CAI)=GINDARR or val([M]CAI)=GINDAGI or val([M]CAI)=GINDPREV
   Actzo [M]CODCSC,CODCPN,FLGAGF
   If val([M]CAI)=GINDPREV
      Effzo [M]FLGAGF : Grizo [M]FLGAGF
   Endif
Else
   Effzo [M]CODCSC,CODCPN,FLGAGF : Grizo [M]CODCSC,CODCPN,FLGAGF
Endif
#MAPAD - 2016-03-22  - Req 114309 - END

End




########################################
Subprog AS_OPTSAL(VALEUR)
Variable Integer VALEUR
If val([M]CAI)=GINDURS
 GMENLOC(3)=1 :# Salaire Forfaitaire
 GMENLOC(4)=1 :# Forfait global
 GMENLOC(5)=1 :# Forfait unitaire
Elsif val([M]CAI)=GINDASS
 GMENLOC(2)=1 :# Base plafonnée
 GMENLOC(4)=1 :# Forfait global
 GMENLOC(5)=1 :# Forfait unitaire
 GMENLOC(6)=1 :# Trs
 GMENLOC(7)=1 :# Tat
 GMENLOC(8)=1 :# Réduction
Elsif val([M]CAI)=GINDARR | val([M]CAI)=GINDAGI | val([M]CAI)=GINDPREV
 GMENLOC(2)=1 :# Base plafonnée
 GMENLOC(3)=1 :# Salaire Forfaitaire
 GMENLOC(6)=1 :# Trs
 GMENLOC(7)=1 :# Tat
 GMENLOC(8)=1 :# Réduction
Else
 VALEUR=1 : mkstat=2 : End
Endif
End

########################################
Subprog AM_OPTSAL(VALEUR)
Variable Integer VALEUR
If (VALEUR=6 | VALEUR=7) & [M]OPTRAT=1
 [M]OPTRAT=2
Endif
[M]OPTSAL=VALEUR
Gosub GRISE_LNK
Gosub GRISE_TRS
End

########################################
Subprog AS_OPTRAT(VALEUR)
Variable Integer VALEUR
If [M]OPTSAL<>6 & [M]OPTSAL<>7
 VALEUR=1 : mkstat=2 : End
Else
 GMENLOC(1)=1 :#Aucun
Endif
End

########################################
Subprog AM_OPTRAT(VALEUR)
Variable Integer VALEUR
If VALEUR>2: Effzo [M]CODVRA : Else : Endif
[M]OPTRAT=VALEUR
Gosub GRISE_TRS
End

########################################
Subprog C_DCHRAT(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M]CODDCC
 GMESSAGE=mess(1,10702,1)  #: Valeur incorrecte
 mkstat=2 : End
Endif
If clalev([F:DCH2])=0 : Local File DECCHARGE [DCH2] : Endif
Read[F:DCH2]DCH0=VALEUR
If fstat | [F:DCH2]OPTRAT<>2 | [F:DCH2]OPTSAL<>[M]OPTSAL
 GMESSAGE=mess(1,10702,1)  #: Valeur incorrecte
 mkstat=2 : End
Endif
End

########################################
$GRISE_TRS
If [M]OPTSAL=6 | [M]OPTSAL=7
 Actzo [M]13
 If [M]OPTRAT>2
  Actzo [M]DCHRAT
  Grizo [M]CODVRA
  Grizo [M]FLGADD
 Else
  Effzo [M]DCHRAT :  Grizo [M]DCHRAT
  #87653: Gestion de l'alphanumérique pour le cas des Corses dans le code INSEE
  Actzo [M]FLGADD
  If [M]FLGADD=2
    Effzo [M]CODVRA
    Grizo [M]CODVRA
  Else
    Actzo [M]CODVRA
  Endif
 Endif
 Effzo [M]12 : Grizo[M]12
Else
 Actzo [M]12 : Actzo [M]FLGAGF
 [M]OPTRAT=1
 Effzo [M]CODVRA,DCHRAT : Grizo [M]13
 Effzo [M]FLGADD : Grizo [M]FLGADD
 If val([M]CAI)<>GINDARR & val([M]CAI)<>GINDAGI
  Effzo [M]FLGAGF : Grizo [M]FLGAGF
  If val([M]CAI)<>GINDPREV
   Effzo [M]CODCSC,CODCPN : Grizo [M]CODCSC, CODCPN
  Endif
 Endif
Endif
Affzo [M]12-13
Return

########################################
$GRISE_LNK
If [M]OPTSAL=2
 Actzo [M]DCHLNK
Else
 Effzo [M]DCHLNK : Grizo [M]DCHLNK
Endif
Return

########################################
Subprog C_DCHLNK(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M]CODDCC
 GMESSAGE=mess(1,10702,1)  #: Valeur incorrecte
 mkstat=2 : End
Endif
If clalev([F:DCH2])=0 : Local File DECCHARGE [DCH2] : Endif
Read[F:DCH2]DCH0=VALEUR
If fstat | [F:DCH2]OPTSAL<>1
 GMESSAGE=mess(1,10702,1)  #: Valeur incorrecte
 mkstat=2 : End
Endif
End

################################################################################
#    Tableau
################################################################################
Subprog C_CODRUB(VALEUR)
Variable Char    VALEUR()
Read [F:RUB]RUB0=GCURLEG;VALEUR
If !fstat
 If [F:RUB]TYPRUB=6 | [F:RUB]TYPRUB=10
  [M:DCH1]ROWRUB(nolign-1)=[F:RUB]ROW
  Call LECTEXTRA([M:DCH1]DESRUB(nolign-1),"RUBRIQUE","DES",GCURLEG,VALEUR) From ATEXTRA
  Affzo [M:DCH1]ROWRUB(nolign-1),DESRUB(nolign-1)
 Elsif [M:DCH1]CODDCS<>""
  Read[F:ADI]CODE=377;[M:DCH1]CODDCS
  If !fstat & [F:ADI]A2='400'
   [M:DCH1]ROWRUB(nolign-1)=[F:RUB]ROW
   Call LECTEXTRA([M:DCH1]DESRUB(nolign-1),"RUBRIQUE","DES",GCURLEG,VALEUR) From ATEXTRA
   Affzo [M:DCH1]ROWRUB(nolign-1),DESRUB(nolign-1)
  Else
   GMESSAGE= mess(46,10708,1)
   mkstat=2 : End
  Endif
 Else
  GMESSAGE= mess(46,10708,1)
  mkstat=2 : End
 Endif
Endif
End

########################################
Subprog D_ROWRUB(VALEUR)
Variable Decimal VALEUR
Read [F:RUB]RUB0=GCURLEG;[M:DCH1]CODRUB(nolign-1)
If fstat=0
 VALEUR=[F:RUB]ROW
Endif
End

########################################
Subprog D_DESRUB(VALEUR)
Variable Char    VALEUR()
Call LECTEXTRA(VALEUR,"RUBRIQUE","DES",GCURLEG,[M:DCH1]CODRUB(nolign-1)) From ATEXTRA
End

########################################
Subprog AS_TYPCAL(VALEUR)
Variable Integer VALEUR
End

########################################
Subprog AS_ACCWRK(VALEUR)
Variable Integer VALEUR
If val([M]CAI)<>GINDURS | [M]OPTSAL=6 | [M]OPTSAL=7 : VALEUR=1 : mkstat=2 : End : Endif
If [M:DCH1]CODDCS<>""
 Read[F:ADI]CODE=377;[M:DCH1]CODDCS
 If !fstat & [F:ADI]A2='400'
  VALEUR=1 : mkstat=2 : End
 Endif
Endif
#
End

########################################
$SEL_TABLE
Case TABLE
 When "SELDCH"
  OBJET="DCH"
    Case PARAM(2)
      When "2"
       CRITERE="[F:DCH]LEG='"+GCURLEG+"' & [F:DCH]CAI="+num$(GINDURS)+" & [F:DCH]CODDCC<>'"+PARAM(1)+"' & [F:DCH]OPTSAL=1"
      When Default
       CRITERE="[F:DCH]LEG='"+GCURLEG+"' & [F:DCH]CODDCC<>'"+PARAM(1)+"' & [F:DCH]OPTSAL="+ num$(PARAM(2))+" & [F:DCH]OPTRAT=2"
    Endcase
  #87135: CICE
 When "SELRUBDCH"
  OBJET="RUB"
  START="COD"
  CRITERE="[F:RUB]TYPRUB=6 | [F:RUB]TYPRUB=10"
  If [M:DCH1]CODDCS<>""
   Read[F:ADI]CODE=377;[M:DCH1]CODDCS
   If !fstat & [F:ADI]A2='400'
    Raz CRITERE
   Endif
  Endif
  ORDRE = "COD"
 When "SELRUBDCS"
  OBJET="RUB"
  START="COD"
  CRITERE="[F:RUB]TYPRUB=6 | [F:RUB]TYPRUB=10"
  If [M:DCH1]CODDCS<>""
   Read[F:ADI]CODE=377;[M:DCH1]CODDCS
   If !fstat & [F:ADI]A2='400'
    Raz CRITERE
   Endif
  Endif
  ORDRE = "COD"
Endcase
Return

########################################
Subprog AS_FLGQTY(VALEUR)
Variable Integer VALEUR
If val([M]CAI)<>GINDURS | ([M]OPTSAL<>2 & [M]OPTSAL<>8) | [M]ACCWRK(nolign-1)=2 : VALEUR=1 : mkstat=2 : End : Endif
End

########################################
Subprog AS_FLGAGF(VALEUR)
Variable Integer VALEUR
If val([M]CAI)<>GINDARR & val([M]CAI)<>GINDAGI
 VALEUR=1 : mkstat=1 : End
Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran DCH1) 18/03/2013 14:28:34 (LANEG)
######################################################################################
#87653: Gestion de l'alphanumérique pour le cas des Corses dans le code INSEE
Subprog AM_FLGADD(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Effzo[M]CODVRA
  Grizo[M]CODVRA
Else
  Actzo[M]CODVRA
Endif
End

Subprog AM_DCHRAT(VALEUR)
Variable Char    VALEUR()
Read[F:DCH2]DCH0=VALEUR
If !fstat
  If [F:DCH2]FLGADD=2
    [M]FLGADD=2
    Grizo [M:DCH1]FLGADD
    Affzo [M:DCH1]FLGADD
    Effzo[M]CODVRA
    Grizo[M]CODVRA
  Else
    [M]FLGADD=1
    Grizo [M:DCH1]FLGADD
    Affzo [M:DCH1]FLGADD
    [M]CODVRA=[F:DCH2]CODVRA
    Grizo[M]CODVRA
  Endif
Endif
End

######################################################################################

