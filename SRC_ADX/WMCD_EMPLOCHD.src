#<AdxTL>@(#)0.0.0.0 $Revision$Class Children
# Supervisor
## CRUD-CLASSE ## EMPLOCHD
# 2018-11-06 07:06:02 043


############################################################################################
### Subprog _ADELETE
############################################################################################
Subprog _ADELETE(EMPLOCHD,ASTATUS)
Variable Instance EMPLOCHD Using C_EMPLOCHD
Variable Integer ASTATUS

If EMPLOCHD = null : End : Endif

Gosub _AVARIABLES From WMC00EMPLOCHD

[L]A_STRSITE = ""
[L]A_STRACC = ""
Local Instance ALNKDELTAB Using C_ALNKDELTAB
Gosub ADELETE_EMPLOCHD

End

############################################################################################
### Subprog ADELETE
############################################################################################
Subprog ADELETE(EMPLOCHD,ASTATUS)
Variable Instance EMPLOCHD Using C_EMPLOCHD
Variable Integer ASTATUS

If EMPLOCHD = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOCHD
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

Local Instance ALNKDELTAB Using C_ALNKDELTAB

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub ADELETE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

If !adxlog
 Gosub ADELETE_TR_EMPLOCHD
Else
 Gosub ADELETE_EMPLOCHD
Endif

$ADELETE_END
End


$ADELETE_CONTROL
Gosub _ADELETE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Verification delete
[L]ASTATUS = max([L]ASTATUS,func ASYRSUB.VERIFY_INSTANCE(EMPLOCHD,ALNKDELTAB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _ADELETE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_BEFORE
If EMPLOCHD.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EMPLOCHD.ASTALIN = [V]CST_ADEL
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCHD.ACTION("ADELETE_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_AFTER

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCHD.ACTION("ADELETE_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_TR_EMPLOCHD
Trbegin [F:CHD]
 Gosub ADELETE_EMPLOCHD
 If [L]ASTATUS>=[V]CST_AERROR : Gosub ADELETE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$ADELETE_EMPLOCHD
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCHD.ACTION("ADELETE_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = func ASYRSUB.DELETE_LINKS(EMPLOCHD,ALNKDELTAB)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EMPLOCHD._MAJSQL_EMPLOCHD(EMPLOCHD))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOCHD.ACTION("ADELETE_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_ABORT
Rollback
$_ADELETE_ABORT
If EMPLOCHD.snapshotEnabled=1
 [L]A_RETIK = EMPLOCHD.revertUpdTick
Endif
[L]ASTATUS = max(fmet EMPLOCHD.ACTION("ADELETE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#

#-----------------------------------------------------#
$_ADELETE_AFTER
Return



