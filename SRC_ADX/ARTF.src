#<AdxTL>@(#)5.0.0.0 $Revision$

###################################################################
## Gestion des fichiers rtf
###################################################################

#########################################################################################
# Avant-Zone, on initialise le nom du fichier pour le client, en fonction du nom adonix
#########################################################################################

Subprog AVANT_ZONE(VALEUR,CLOB,NAMCLOB)
Variable Char VALEUR()
Value    Char CLOB()
Value    Char NAMCLOB()
If VALEUR=""
 Gosub OLDFIC
 VALEUR = OLDNUM
Endif
End

#########################################################################################
# Avant-saisie, idem + attribution d'un numéro si vide
#########################################################################################

Subprog AVANT_SAI(VALEUR,CLOB,NAMCLOB)
Variable Char VALEUR()
Value    Char CLOB()
Value    Char NAMCLOB()

If VALEUR=""
 Gosub OLDFIC
 If OK
  VALEUR = OLDNUM
 Else
  Gosub NEWFIC
  VALEUR = NEWNUM            : # Nom pour le client
  Assign CLOB    With NEWFIC : # Affectation du clob
  Assign NAMCLOB With NEWFIC : # Nom pour la relecture
 Endif
Elsif evalue(CLOB)=""
 Assign CLOB With evalue(NAMCLOB)
Endif
End

#########################################################################################
# Duplication
#########################################################################################

Subprog DUPLI(TXT,CLOB,NAMCLOB)
Value Char TXT
Value Char CLOB
Value Char NAMCLOB
Local Integer STAT

# Attribution nouveau numéro

Gosub NEWFIC

# Duplication du fichier

Gosub OLDFIC
If OK
 Call COPIE(filpath("TXT",OLDNUM,"rtf"),filpath("TXT",NEWNUM,"rtf",0),STAT) From ORDSYS
Endif
Assign CLOB    With NEWFIC
Assign NAMCLOB With NEWFIC
Assign TXT     With NEWNUM
End

#########################################################################################
$OLDFIC
Local Integer I , J , OK
Local Char    OLDFIC(50) , OLDNUM(30)
OLDFIC = evalue(NAMCLOB)
OK = 0
If OLDFIC<>"" & filinfo(OLDFIC,0)>=0
 I = instr(1,OLDFIC,"/")
 J = instr(1,OLDFIC,"$")
 If I & J
  OLDNUM = seg$(OLDFIC,I+1,J-1)
  OK = 1
 Endif
Endif
Return

$NEWFIC
Local Integer NUMERO
Local Char    NEWFIC(50) , NEWNUM(30)
If clalev([F:ACB])=0 : Local File ACLOB [ACB] : Endif
NUMERO = uniqid([F:ACB])
NEWNUM = "RTF"+num$(NUMERO)
NEWFIC = nomap+".TXT/"+NEWNUM+"$rtf"
Return

