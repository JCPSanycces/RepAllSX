#<AdxTL>@(#)0.0.0.0 $Revision$ 
#Handling all properties for ESSEMPKZA
$PROPERTIES
Case [L]CURPRO
  When "RSAID"                            : Gosub EMPESSSA_RSAID
  When "EMPADR.ADDPRI"                    : Gosub EMPESSSA_ADDPRI
  When "EMPADR.ADDSRVTYP"                 : Gosub EMPESSSA_ADDSRVTYP
  When "EMPADR.ADDPOSNUM"                 : Gosub EMPESSSA_ADDPOSNUM
  When "EMPADR.ADDPOSNAM"                 : Gosub EMPESSSA_ADDPOSNAM
  When "EMPADR.ADDSTRNAM"                 : Gosub EMPESSSA_ADDSTRNAM
  When "EMPADR.ADDTWN"                    : Gosub EMPESSSA_ADDTWN
  When "EMPADR.ADDPOSCDE"                 : Gosub EMPESSSA_ADDPOSCDE
  When "EMPADR.ADDCNTCDE"                 : Gosub EMPESSSA_ADDCNTCDE
  When "EMPADR.ADDCOR"                    : Gosub EMPESSSA_ADDCOR
  When "EMPADR.ADDPOSCOF"                 : Gosub EMPESSSA_ADDPOSCOF
Endcase
Return

$EMPESSSA_RSAID
Case [L]ARULE
  When "CONTROL"
    Gosub EMPLOIDSA_RSAID_CONTROL From EMPLOIDSA_CSTD_PRO
    Gosub EMPESSA_RSAID_DATBRN
Endcase
Return

$EMPESSA_RSAID_DATBRN
Local Char BIRTHYEAR(4),BIRTHMONTH(2),BIRTHDAY(2),IDYEAR(4),IDMONTH(2),IDDAY(2)

If len(num$(this.RSAID)) > 6
#get birthday elements
  Local File EMPLOID [ID7]
  Read [F:ID7]ID0 = this.REFNUM
  If fstat : Return : Endif

  BIRTHYEAR = mid$(num$(year([F:ID7]DATBRN)),3,2)
  BIRTHMONTH = format$("N0:2",num$(month([F:ID7]DATBRN)))
  BIRTHDAY= format$("N0:2",num$(day([F:ID7]DATBRN)))

#get ID number elements
  IDYEAR = num$(mid$(this.RSAID,1,2))
  IDMONTH =mid$(this.RSAID,3,2)
  IDDAY =mid$(this.RSAID,5,2)

#compare elements
  If BIRTHYEAR<>IDYEAR or BIRTHMONTH<>IDMONTH or BIRTHDAY<>IDDAY
    ASTATUS=fmet this.ASETERROR([L]CURPRO,mess(46,11662,1),[V]CST_AERROR)
  Endif
Endif
Return

$EMPESSSA_ADDPRI
Case [L]ARULE
  When "INIT"
   Gosub EMPLOIDSA_ADDPRI_INIT From EMPLOIDSA_CSTD_PRO
  When "PROPAGATE"
   Gosub EMPLOIDSA_ADDPRI_PROPOGATE From EMPLOIDSA_CSTD_PRO
Endcase
Return

