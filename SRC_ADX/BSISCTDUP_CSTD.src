######################################################################################################
# Module        : Finance
# Description   : Manages duplicate class for bank import segment (Class BSISCT)
######################################################################################################
# Updates       :
# Date          |Author |Version| Description
# 2018-03-28    |Bader  |2018.R4| Duplicate translatable texts
######################################################################################################

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_DUPLICATE"  : Gosub MET_DUPLICATE
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#    When "MYOPERATION" : Gosub OPE_MYOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "CODSCTNEW"
      Case [L]ARULE
        When "CONTROL"   : Gosub CODSCTNEW_CONTROL
      Endcase
    When Default
  Endcase
Return

####################################################################

$CODSCTNEW_CONTROL
  If this.CODSCTNEW <> ""
    If func CTRL_EXIST_SCT(this.CODSCTNEW) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("CODSCTNEW",mess(45,7779,1)-":"-this.CODSCTNEW,[V]CST_AERROR)
    Endif
  Endif
Return


####################################################################

$MET_DUPLICATE
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Char WERR(250)

  ASTATUS = fmet this.ADELETEERROR("")
  If this.CODSCTNEW <> ""
    ASTATUS = fmet this.ASETERROR("",mess(9,7983,1),[V]CST_AINFO)
    If func CTRL_EXIST_SCT(this.CODSCTNEW) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("BSISCTNEW",mess(45,7779,1)-":"-this.CODSCTNEW,[V]CST_AERROR)
      WRET_VALUE = [V]CST_AERROR
    Else
      If func COPY_SCT(this.CODSCT, this.CODSCTNEW, WERR) = [V]CST_AERROR
        ASTATUS = fmet this.ASETERROR("",mess(9,7983,1)-":"-mess(9,2007,1)-this.CODSCTNEW-WERR,[V]CST_AERROR)
        WRET_VALUE = [V]CST_AERROR
      Else
        ASTATUS = fmet this.ASETERROR("",mess(9,7983,1)-":"-mess(7,2007,1)-this.CODSCTNEW,[V]CST_AINFO)
        WRET_VALUE = [V]CST_AOK
      Endif
    Endif
  Else
    ASTATUS = fmet this.ASETERROR("",mess(141,105,1),[V]CST_AERROR)
    WRET_VALUE = [V]CST_AERROR
  Endif
  ARET_VALUE = WRET_VALUE
Return

Funprog CTRL_EXIST_SCT(WCODSCT)
Value Char WCODSCT

  Local Integer WOK : WOK = [V]CST_AFALSE
  If WCODSCT <> ""
    Local File BSISCT [BSISCT]
    Read [BSISCT]BSISCT0 = WCODSCT
    If !fstat
      WOK = [V]CST_ATRUE
    Endif
    LogicClose File [BSISCT]
  Else
    WOK = [V]CST_AFALSE
  Endif
End WOK

Funprog COPY_SCT(WCODSCT, WCODSCT_NEW, WERR)
Value Char WCODSCT
Value Char WCODSCT_NEW
Variable Char WERR
  Local Integer WOK : WOK = [V]CST_AOK
  Local File BSISCTD [BSISCTD]
  Local File BSISCTD [BSISCTD2]
  Local File BSISCT  [BSISCT]
  Local File BSISCT  [BSISCT2]
  Local File ATEXTRA [AXX]
  Local File ATEXTRA [AXX2]

  Trbegin [BSISCT2], [BSISCTD2], [AXX2]
  Filter [BSISCTD] Where CODSCT = WCODSCT
  For [BSISCTD]
    If WOK = [V]CST_AOK
      [BSISCTD2]          = [BSISCTD]
      [BSISCTD2]CODSCT    = WCODSCT_NEW
      Write [BSISCTD2]
      If !fstat             # everything ok > handle translatable texts
        Filter [F:AXX] Where CODFIC="BSISCTD" & ZONE="DESAXX" & IDENT1=[BSISCTD]CODSCT & IDENT2 = num$([F:BSISCTD]LIN)
        For [F:AXX]
          # check if the record we want to create already exists.
          Read [F:AXX2]AXX0 = "BSISCTD";"DESAXX";[F:AXX]LANGUE;WCODSCT_NEW;num$([F:AXX]IDENT2)
          If fstat          # Record doesn't exist > we move fields and write the record.
            Raz [F:AXX2]
            [F:AXX2]CODFIC = [F:AXX]CODFIC
            [F:AXX2]ZONE   = [F:AXX]ZONE
            [F:AXX2]LANGUE = [F:AXX]LANGUE
            [F:AXX2]IDENT1 = WCODSCT_NEW
            [F:AXX2]IDENT2 = [F:AXX]IDENT2
            [F:AXX2]TEXTE  = [F:AXX]TEXTE
            Write [F:AXX2]
            If fstat
                WOK = [V]CST_AERROR
                WERR = "BSISCTD/ATEXTRA ("+mess(1,7983,1)+")"
                Break
            Endif
          Endif
         Next
         Filter [F:AXX]
      Else
        WOK = [V]CST_AERROR
        WERR = "BSISCTD ("+mess(3,40,1)-num$([BSISCTD2]LIN)+")"
      Endif
    Else
    #
    Endif
  Next
  Filter [BSISCTD]

  If WOK = [V]CST_AOK
    Read [BSISCT]BSISCT0 = WCODSCT
    If !fstat
      [BSISCT2]          = [BSISCT]
      [BSISCT2]CODSCT    = WCODSCT_NEW
      Write [BSISCT2]
      If !fstat             # everything ok > handle translatable texts
        Filter [F:AXX] Where CODFIC="BSISCT" & ZONE="DESAXX" & IDENT1=[BSISCT]CODSCT
        For [F:AXX]
          # check if the record we want to create already exists.
          Read [F:AXX2]AXX0 = "BSISCT";"DESAXX";[F:AXX]LANGUE;WCODSCT_NEW;""
          If fstat          # Record doesn't exist > we move fields and write the record.
            Raz [F:AXX2]
            [F:AXX2]CODFIC = [F:AXX]CODFIC
            [F:AXX2]ZONE   = [F:AXX]ZONE
            [F:AXX2]LANGUE = [F:AXX]LANGUE
            [F:AXX2]IDENT1 = WCODSCT_NEW
            [F:AXX2]TEXTE  = [F:AXX]TEXTE
            Write [F:AXX2]
            If fstat
                WOK = [V]CST_AERROR
                WERR = "BSISCT/ATEXTRA ("+mess(1,7983,1)+")"
                Break
            Endif
          Endif
         Next
         Filter [F:AXX]
      Else
        WOK = [V]CST_AERROR
        WERR = "BSISCT ("+mess(1,7983,1)+")"
      Endif
    Else
      WOK = [V]CST_AERROR
      WERR = "BSISCT ("+mess(7,7983,1)+")"
    Endif
    Filter [BSISCT]
  Endif

  If WOK = [V]CST_AERROR
    Rollback
  Else
    Commit
  Endif

  LogicClose File [AXX]
  LogicClose File [AXX2]
  LogicClose File [BSISCT]
  LogicClose File [BSISCT2]
  LogicClose File [BSISCTD]
  LogicClose File [BSISCTD2]
End WOK

