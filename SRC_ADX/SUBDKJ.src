#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion objet DKJ
######################################################################################
## Etiquette ajoutée par le superviseur (Objet DKJ) 09/27/2010 15:19:27 (RMA)
######################################################################################
$ACTION
Case ACTION
 When "VERIF_MOD" : Gosub VERIF_MOD
 When "INICRE"    : Gosub INICRE
 When Default
Endcase
Return
######################################################################################
## 
######################################################################################
$VERIF_MOD
Local Char BID(80)
For I=0 To [M]NBLIG-1
 Read [DKJ]DKJ0 = [M]KEYCODE(I)
 If fstat
  [M]MODIF(I) = 2
 Else
  [M]MODIF(I) = 1
 Endif
Next I
Return
######################################################################################
## 
######################################################################################
$INICRE
Case [M]MODIF(nolign-1)
 When 2 : # Création
  [F:DKJ]CREUSR = GUSER  
  [F:DKJ]CREDAT = date$  
  [F:DKJ]CRETIM = time  
  [F:DKJ]UPDUSR = ""     
  [F:DKJ]UPDDAT = [0/0/0]
  [F:DKJ]UPDTIM = 0     
 When Default : # Modification
  [F:DKJ]UPDUSR = GUSER
  [F:DKJ]UPDDAT = date$
  [F:DKJ]UPDTIM = time  
Endcase
Return
######################################################################################
## 
######################################################################################

######################################################################################
## 
## Field Actions
## 
######################################################################################

Subprog C_KEYCODE(VALEUR)
Variable Char     VALEUR
Call UNICITE(VALEUR,[M]KEYCODE(0..[M]NBLIG-1)) From OBJDIV
End
######################################################################################
## 
######################################################################################
