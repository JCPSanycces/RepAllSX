#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIGPA51   Deletion parameters MRPECCSO* and MPSECCSO*                 #
##########################################################################
# Bug 48236 par GH le 05/06/2018
##########################################################################
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER="" : End : Endif
Call OUVRE_TRACE("UTIGPA51: Deletion parameters MRPECCSO* and MPSECCSO*") From LECFIC
Call EXE_UTIGPA51(DOSSIER)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

##########################################################################
Subprog EXE_UTIGPA51(DOSSIER)
Value Char DOSSIER

Local Integer I1, I2

If filinfo(filpath("FIL","ADOPAR","fde",DOSSIER),0)>0
&  & !func DOSVUE.ISVIEW(DOSSIER,"ADOPAR")
   I1=1
Endif

If filinfo(filpath("FIL","ADOVAL","fde",DOSSIER),0)>0
&  & !func DOSVUE.ISVIEW(DOSSIER,"ADOVAL")
   I2=1
Endif

If !I1 & !I2 : End : Endif

Call ECR_TRACE("UTIGPA51: Process Start on : "+DOSSIER,0) From GESECRAN

Call ECR_TRACE("Deletion parameters MRPECCSO* and MPSECCSO*",0) From GESECRAN
If I1 : Local File =DOSSIER+".ADOPAR"  [ADP] : Endif
If I2 : Local File =DOSSIER+".ADOVAL"  [ADW] : Endif

If I1 : Trbegin [ADP]
Else  : Trbegin [ADW]
Endif

  If I1
     Delete [ADP] Where find(PARAM,'MRPECCSOF','MRPECCSOP','MRPECCSOS','MPSECCSOF','MPSECCSOP','MPSECCSOS')<>0
  Endif
  If I2
     Delete [ADW] Where find(PARAM,'MRPECCSOF','MRPECCSOP','MRPECCSOS','MPSECCSOF','MPSECCSOP','MPSECCSOS')<>0
  Endif

Commit

Call ECR_TRACE("UTIGPA51 : Procces End on",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat : Raz [F:ADS] : Endif
Call EXE_UTIGPA51(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

Call EXE_UTIGPA51(APPLI)
End

