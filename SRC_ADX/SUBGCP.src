######################################################################################
## Etiquette ajoutée par le superviseur (écran GRPCPC2) 12/07/2012 15:19:35 (MABON)
######################################################################################
Subprog AS_NBRLIG

Case GFLAG
 When "1" :
 When "2" : Call AP_UOMGRP([M]UOMGRP)
 When "3" : Call AP_JOBGRP([M]JOBGRP)
 When "4" : Call AP_CPCFAM([M]CPCFAM)
Endcase
End


