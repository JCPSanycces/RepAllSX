#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################################
# Project       : Swiss Localization
# File          : SWIPAYIMPORT
# Version       : 1.0
# Author        : Ulrike Bader
# Creation Date : 02.04.15
######################################################################################################
# Module        : ACCOUNTING
# Description   : - Import ISR (import template SWIIMPBVR)
######################################################################################################
 # Updates :
 # Date    |Author|Version|Description
######################################################################################################

$ACTION
Case ACTION
Endcase
Return


#*****************************************************************************************************
#OUVRE: Ouverture des fichiers nécessaires à l'import
#*****************************************************************************************************
$OUVRE
    Gosub OUVRE From PAYIMPORT
Return
#*****************************************************************************************************

#*****************************************************************************************************
# RAZCRE: Initialisation de l'import
#*****************************************************************************************************
$RAZCRE
    Gosub RAZCRE From PAYIMPORT
Return
#*****************************************************************************************************

#*****************************************************************************************************
#SAIMSK: Simulation de la saisie des masques
#*****************************************************************************************************
$SAIMSK
    If dim(XGIMP6)<1 : Global Char XGIMP6(255) : Endif
    Gosub SAIMSK From PAYIMPORT
    XGIMP6 = GIMP(6)
Return
#*****************************************************************************************************

#*****************************************************************************************************
#VALID: Validation de l'import
#*****************************************************************************************************
$VALID
If dim([M:PAY1]NBLIG)>0
   If [M:PAY1]NBLIG=0 : Return : Endif
Elsif dim([M:PAY2]NBLIG)>0
   If [M:PAY2]NBLIG=0 : Return : Endif
Elsif dim([M:PAY3]NBLIG)>0
   If [M:PAY3]NBLIG=0 : Return : Endif
Endif

If OKPYH = 2
 Gosub DEFAULT_PAY From PAYIMPORT
 Gosub CONTROLE From PAYIMPORT
 If OKPYH = 2
  If GUSRFCY(1)<>"\"
   I= find([M]FCY,GUSRFCY(1..GNBAUZ))
  Else
   I=1
  Endif
  If I=0 | !(instr(1,GUSRAUZ(I),"C"))
   # Vous n'avez pas les droits pour ce site
   Call ECR_TRACE([M]FCY-":"-mess(2,104,1),1) From GESECRAN
   OKPYH = 1
  Endif
 Endif
Endif

If OKPYH=2
 Call DEBTRANS From GLOCK
 Gosub TR1 From PAYIMPORT
 If GOK>0
  Call TRACE(0,[F:PYH]NUM) From SUBIMPOBJ
  NBCRE += 1
  Gosub MAJFIC_
 Else
  OKPYH = 1
 Endif
Endif

If OKPYH<>2
 Call ECR_TRACE(mess(18,114,1),0) From GESECRAN : # Transation abandonnée
Endif
GMESSAGE=""
Return
#*****************************************************************************************************

#-----------------------------------------------------------------------------------------------------
# MAJFIC_: MISE à jour de la table SWIIMPBVR
#-----------------------------------------------------------------------------------------------------
$MAJFIC_
Trbegin [SWIIMP]
Delete [F:SWIIMP] Where [F:SWIIMP]NUMIMP=GIMP(5) and [F:SWIIMP]LINE=val(XGIMP6)
If fstat=0
    Commit
Else
    Rollback
    Call ECR_TRACE(mess(40,9014,1)+" [F:SWIIMP]! fstat="+num$(fstat)) From GESECRAN  # File writing Error
Endif
Return
#-----------------------------------------------------------------------------------------------------

