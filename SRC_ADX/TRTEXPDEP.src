#<AdxTL>@(#)1.0.0.0 $Revision$
########################################################################################################################
#
# EXPORT D'UN PLAN D'AMORTISSEMENT
# ================================
#
# @ver        1.0.0
# @date       xx/xx/xxxx
# @user       GBO
# @modif      xx/xx/xxxx
#
# Note : pour ajouter un champs en en-tÃªte (champs figurant en premier dans la liste des champs Ã  exporter), modifier
#        la variable LNBEXCFLD en ajoutant 1 et alimenter l'occurrence supplÃ©mentaire crÃ©Ã©e dans LLSTEXCFLD avec le
#        code de ce champ.
#
########################################################################################################################
# Modifications :
# -------------
#
# - CBO - 20.03.2014 - FQ97347  pouvoir exporter avec un spÃ©parateur dÃ©cimal = , (virgule)
# - CBO - 12.03.2012 - FQ80246  GFMDAT4 au lieu de DD[/]MM[/]YYYY
# - GLE - 05.10.2011 - FQ76668 - C'est toujours le plan comptable qui est exportÃ©
# - GLE - 13.07.2011 - FQ74967 - Plantage si utilisation de la fonction directement Ã  partir du menu "Plan d'amortissement"
#
########################################################################################################################
#CHECK IGNORE_BEGIN
 If GUSER="GBO"

  Local Char LCSVFILENAME
  Local Char LGENEXPTRT
  Local Integer LLNBFLD : LLNBFLD=13
  Local Char LLSTFLD(GLONFLD)(LLNBFLD)
  LCSVFILENAME = "#@D:\Test_export.csv"
  LGENEXPTRT   = "GX"+GUSER+num$(adxpid)
  LLSTFLD(01)  = "FIYSTRDAT"
  LLSTFLD(02)  = "FIYENDDAT"
  LLSTFLD(03)  = "PERSTRDAT"
  LLSTFLD(04)  = "PERENDDAT"
  LLSTFLD(05)  = "DPRPLN"
  LLSTFLD(06)  = "CPY"
  LLSTFLD(07)  = "FCY"
  LLSTFLD(08)  = "AASREF"
  LLSTFLD(09)  = "DPRBAS"
  LLSTFLD(10)  = "PERENDDPE"
  LLSTFLD(11)  = "DPEI"
  LLSTFLD(12)  = "DPET"

  # Test fonction comparaison date de modification table / traitement.
  # -----------------------------------------------------------------
  If 1=1
   Infbox "Date de modif DEPREC antÃ©rieure date modif traitement ? "+mess(func TRTEXPDEP.DEPREC_OLDER_TRT(nomap,LGENEXPTRT),1,1)
  Endif
  # Test gÃ©nÃ©ration du traitement d'export
  # --------------------------------------
  If 1=0
   #Call OUVRE_TRACE("Test s/p EXP_CRE_TRT") From LECFIC
   Call TEMPON("CrÃ©ation du traitement d'export. Veuillez patienter") From GESECRAN
   Call EXP_CRE_TRT(nomap, LGENEXPTRT, "DEPREC", LLSTFLD, G_OUI) From TRTEXPDEP
   Call TEMPOFF From GESECRAN
   #Call LEC_TRACE From LECFIC
  Endif
  # Test fonction d'export de plan d'amortissement
  # ----------------------------------------------
  If 1=0
   Call TEMPON("Export. Veuillez patienter") From GESECRAN
   Local Integer RCOD
   Local Char LLSTFLD(GLONFLD)(1)
   Call EXP_DPRPLN("001", 1,0, 0, LLSTFLD, LCSVFILENAME, LGENEXPTRT, RCOD) From TRTEXPDEP
   Call TEMPOFF From GESECRAN
  Endif
  # Test suppression du traitement gÃ©nÃ©rÃ© pour l'export
  # ---------------------------------------------------
  If 1=0
   Call DELTRT(LGENEXPTRT,nomap) From SUBADC
  Endif

 Endif
#CHECK IGNORE_END
End

############################################################
$ACTION
 Case ACTION
  When "DEBUT"   : Gosub DEBUT
  When "SETBOUT" : Gosub SETBOUT
  When "BOUTON"  : Gosub BOUTON
  When Default
 Endcase
Return

#=========================================================
# LISTE DES CHAMPS A METTRE EN EN-TETE
#=========================================================
$DEF_H_FIELD
 Local Integer LNBEXCFLD : LNBEXCFLD=08
 Local Char LLSTEXCFLD(GLONFLD)(1..LNBEXCFLD)
 LLSTEXCFLD(01)  = "FIYSTRDAT"
 LLSTEXCFLD(02)  = "FIYENDDAT"
 LLSTEXCFLD(03)  = "PERSTRDAT"
 LLSTEXCFLD(04)  = "PERENDDAT"
 LLSTEXCFLD(05)  = "DPRPLN"
 LLSTEXCFLD(06)  = "CPY"
 LLSTEXCFLD(07)  = "FCY"
 LLSTEXCFLD(08)  = "AASREF"
Return

#---------------------------------------------------------
$DEBUT
 If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
 If !clalev([F:ATX]) : Local File ATEXTE  [ATX] : Endif

 #> Chargement en-tÃªte EXPPLN0

 [M:EDP0]OBJREF=[M:DPP1]AASREF  : # FQ74967 : utilisation de DPP1 Ã  la place de FAS0
 [M:EDP0]OBJDES=[M:DPP1]AASDES1 : # FQ74967 : utilisation de DPP1 Ã  la place de FAS0
 [M:EDP0]OBJPLN=[M:DPP1]DPRPLN

 #> Chargement onglet EXPPLN1

 Gosub DEF_H_FIELD

 Local Integer I_EXCFLD
 For I_EXCFLD=1 To LNBEXCFLD
  [M:EDP1]NORD([M:EDP1]NBFLD)   = I_EXCFLD
  [M:EDP1]FLDNAM([M:EDP1]NBFLD) = LLSTEXCFLD(I_EXCFLD)
  Read [F:ATZ]CODZONE="DEPREC";LLSTEXCFLD(I_EXCFLD)
  Read [F:ATX]NUMERO=GLANGUE;[F:ATZ]NOLONG
  [M:EDP1]FLDDES([M:EDP1]NBFLD) = [F:ATX]TEXTE
  [M:EDP1]FLGEXP([M:EDP1]NBFLD) = G_OUI
  [M:EDP1]NBFLD+=1
 Next I_EXCFLD

 Filter [F:ATZ] Where CODFIC="DEPREC"
 For [F:ATZ]
  If !find([F:ATZ]CODZONE,LLSTEXCFLD)
   [M:EDP1]NORD([M:EDP1]NBFLD)   = [M:EDP1]NBFLD
   [M:EDP1]FLDNAM([M:EDP1]NBFLD) = [F:ATZ]CODZONE
   Read [F:ATX]NUMERO=GLANGUE;[F:ATZ]NOCOURT
   [M:EDP1]FLDDES([M:EDP1]NBFLD) = [F:ATX]TEXTE
   [M:EDP1]FLGEXP([M:EDP1]NBFLD) = G_OUI
   [M:EDP1]NBFLD+=1
  Endif
 Next
 Filter [F:ATZ]

 Affzo [M:EDP0]
 Affzo [M:EDP1]

Return

#---------------------------------------------------------
$SETBOUT
 If [M:EDP1]FICHIER="" & [M:EDP1]TYPEXP<>1
  Call VIREBOUT (CHMEN,"X") From GOBJET
 Endif
Return

#---------------------------------------------------------
$BOUTON
 Case BOUT
  When "X" : Gosub EXPORT
  When Default
 Endcase
Return

#---------------------------------------------------------
# Traitement d'export aprÃ¨s choix de l'utilisateur
#   - PrÃ©paration de la variable contenant les champs
#     Ã  exporter
#   - Appel du s/p de gÃ©nÃ©ration du traitement d'export
#   - Appel du s/p d'export
#   - Appel du s/p de suppression du traitement d'export
$EXPORT

  #> On vÃ©rifie d'abord qu'il y a au moins un champ sÃ©lectionnÃ©

  #FQ97347
  Local Char WSEPDEC(1), WSV_ADXSCA(30), WPARAM(10)
  WSV_ADXSCA = adxsca

  Call PARCLI("SDecimal", WSEPDEC) From GLOBVAR
  If WSEPDEC = ","
     Call PARAM("", "SCA", WPARAM) From ADOVAL
     adxsca = left$(WPARAM, 1) + ". " + WSEPDEC + right$(WPARAM,5)
  Endif

  Onerrgo ERR_EXPORT

  If !find(G_OUI,[M:EDP1]FLGEXP)
   Call MESSAGE(mess(16,GML_MSGMIS,1)) From GESECRAN #"Vous devez choisir au moins un champ Ã  exporter"
   Return
  Endif

  #> PrÃ©paration de l'export : alimentation des variables paramÃ¨tres d'appel des s/p

  Local Char    LAASREF
  Local Integer LDPRPLN
  Local Char    LCSVFILENAME(200)
  Local Char    URL(10)
  Local Char    LGENEXPTRT
  Local Integer LNBFLD
  Local Integer I_FLD, I_EXPFLD
  Local Integer STAT

  LAASREF=[M:EDP0]OBJREF
  LDPRPLN=[M:EDP0]OBJPLN

  For I_FLD=1 To [M:EDP1]NBFLD
   If [M:EDP1]FLGEXP(I_FLD-1)=G_OUI : LNBFLD+=1 : Endif
  Next I_FLD
  Local Char LLSTFLD(GLONFLD)(LNBFLD)

  If [M:EDP1]TYPEXP=1 : # Client
   Call SET_FICNAM([M:EDP1]FICHIER,LCSVFILENAME,URL) From ORDSYS
  Else
   LCSVFILENAME = [M:EDP1]FICHIER
  Endif

  LGENEXPTRT   = "GX"+GUSER+num$(adxpid)
  For I_FLD=1 To [M:EDP1]NBFLD
   If [M:EDP1]FLGEXP(I_FLD-1)=G_OUI
    LLSTFLD(I_EXPFLD)=[M:EDP1]FLDNAM(I_FLD-1)
    I_EXPFLD+=1
   Endif
  Next I_FLD

  #> Appel s/p gÃ©nÃ©ration traitement d'export

  If 1=1
   #Call OUVRE_TRACE("Test s/p EXP_CRE_TRT") From LECFIC
   Call TEMPON(mess(17,GML_MSGMIS,1)) From GESECRAN #"CrÃ©ation du traitement d'export. Patientez SVP."
   Call EXP_CRE_TRT(nomap, LGENEXPTRT, "DEPREC", LLSTFLD, G_OUI) From TRTEXPDEP
   Call TEMPOFF From GESECRAN
   #Call LEC_TRACE From LECFIC
  Endif

  #> Appel s/p export traitement d'export

  If 1=1
   Call TEMPON(mess(18,GML_MSGMIS,1)) From GESECRAN #"Export. Veuillez patienter"
   Local Integer RCOD
   Local Char LLSTFLD(GLONFLD)(1)
   # FQ76668 : remplacement ci-dessous de "1" par "LDPRPLN"
   Call EXP_DPRPLN(LAASREF, LDPRPLN, 0, 0, LLSTFLD, LCSVFILENAME, LGENEXPTRT, RCOD) From TRTEXPDEP
   Call TEMPOFF From GESECRAN
  Endif

  #> Appel s/p suppression traitement d'export

  If 1=1
   Call DELTRT(LGENEXPTRT,nomap) From SUBADC
  Endif

  #> Si fichier sur le client : copie du fichier gÃ©nÃ©rÃ© sur le client

  If [M:EDP1]TYPEXP=1
   [M:EDP1]FICHIER="export.csv"
   Call COPCLI(LCSVFILENAME,[M:EDP1]FICHIER,STAT) From ORDSYS
  Endif

$FIN_EXPORT

  #FQ97347
  adxsca = WSV_ADXSCA
  Kill WSEPDEC, WSV_ADXSCA, WPARAM

  Onerrgo
Return

#---------------------------------------------------------
$ERR_EXPORT
 Call MESSAGE(mess(19,GML_MSGMIS,1)) From GESECRAN #"Erreur - Export annulÃ©"
 Goto FIN_EXPORT
Return

#---------------------------------------------------------
# Test si la date de modification de la table DEPREC est
# postÃ©rieure Ã  la date du traitement passÃ© en paramÃ¨tre
#---------------------------------------------------------
Funprog DEPREC_OLDER_TRT(PAPPLI, PTRTNAM)
 Value Char PAPPLI
 Value Char PTRTNAM

 Local Integer ROLDER

 #> RÃ©cupÃ©ration des infos du traitement

 Local Decimal TAILLE , PROPRIO
 Local Date    DATMODTRT
 Local Char    HREMODTRT(10)
 Local Integer OK
 Call INFOFIC("TRT",PTRTNAM,"src",PROPRIO,TAILLE,DATMODTRT,HREMODTRT,OK) From SUBADC

 #> RÃ©cupÃ©ration des infos de la table

 Local Date    DATMODATB
 Local Char    HREMODATB(10)
 If clalev([F:ATB])=0 : Local File ATABLE [ATB] : Endif
 Read [F:ATB]CODFIC="DEPREC"
 If fstat=1
  LOCK_STATEMENTS
 Elsif fstat
  ERROR_STATEMENTS
 Else
  DATMODATB=[F:ATB]UPDDAT
  HREMODATB=num$([F:ATB]UPDTIM)
 Endif

 #> Comparaison date et heure de modification Traitement / Table DEPREC

 ROLDER=G_NON
 If DATMODATB<DATMODTRT
  ROLDER=G_OUI
 Elsif DATMODATB=DATMODTRT
  If HREMODATB<=HREMODTRT
   ROLDER=G_OUI
  Endif
 Endif

End ROLDER

#---------------------------------------------------------
# CrÃ©ation du traitement d'export
#---------------------------------------------------------
Subprog EXP_CRE_TRT(PAPPLI, PTRTNAM, PTABLE, PLSTFLD, PVALID)
 Value Char    PAPPLI
 Value Char    PTRTNAM
 Value Char    PTABLE
 Value Char    PLSTFLD()()
 Value Integer PVALID

 # Constantes

 Local Integer LDBGMODE : LDBGMODE = 0

 # Variables

 Local Integer I_FLD
 Local Char    LINE(115)
 Local Char    LDEPABR

 If PTRTNAM<>""
  NOMTRT = PTRTNAM
 Else
  NOMTRT = "GX"+PTABLE
 Endif

 # GÃ©nÃ©ration du traitement d'export
 # ---------------------------------

 If clalev([F:ATB])=0 : Local File =PAPPLI+".ATABLE"  [ATB] : Endif
 If clalev([F:AMZ])=0 : Local File =PAPPLI+".AMSKZON" [AMZ] : Endif
 If clalev([F:ATZ])=0 : Local File =PAPPLI+".ATABZON" [ATZ] : Endif
 If clalev([F:ATY])=0 : Local File =PAPPLI+".ATYPE"   [ATY] : Endif

 Read [F:ATB]CODFIC=PTABLE
 If !fstat
  LDEPABR="X"+[F:ATB]ABRFIC
 Endif

 FICSRC = filpath("TRT",NOMTRT,"src",PAPPLI)
 Openo FICSRC,0 Using [SRC]
 adxifs = ""
 adxirs = chr$(10)
 Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$" Using [SRC]
 Wrseq '# MODIFIE PAR :'-GUSER                     Using [SRC]
 Wrseq '# LE          :'-format$("DD4",date$)      Using [SRC]
 Wrseq ''                                          Using [SRC]

 #> Ligne d'en-tÃªte

 Wrseq '$ENREG_CSVFILE_HEADLINE'                   Using [SRC]
 Wrseq 'Wrseq'                                     Using [SRC]
 For I_FLD=0 To dim(PLSTFLD)-1
  Read [F:ATZ]CODZONE=PTABLE;PLSTFLD(I_FLD)
  If !fstat
   If I_FLD<>dim(PLSTFLD)-1
    Wrseq '& "'+PLSTFLD(I_FLD)+'",'                Using [SRC]
   Else
    Wrseq '& "'+PLSTFLD(I_FLD)+'"'                 Using [SRC]
   Endif
   Read [F:ATY]CODTYP=[F:ATZ]CODTYP
   Case [F:ATY]TYPTYP
   Endcase
    # Pour dÃ©veloppement et trace
   If LDBGMODE
    Call ECR_TRACE( left$([F:ATZ]CODZONE + space$(20),20)+
&                                left$([F:ATZ]CODTYP  + space$(10),10) +
&                                left$(mess([F:ATY]TYPTYP,30,1)+space$(15),15) +
&                                left$([F:ATZ]CODACT  + space$(5),5)
&                 ,0) From GESECRAN
   Endif

  Endif
 Next I_FLD
 Wrseq '& Using [FEX]'                             Using [SRC]
 Wrseq 'Return'                                    Using [SRC]
 Wrseq ''                                          Using [SRC]

 #> Ligne de donnÃ©es

 Wrseq '$ENREG_CSVFILE_LINE'                       Using [SRC]
 Wrseq 'Wrseq'                                     Using [SRC]
 For I_FLD=0 To dim(PLSTFLD)-1
  Read [F:ATZ]CODZONE=PTABLE;PLSTFLD(I_FLD)
  If !fstat
   Read [F:ATY]CODTYP=[F:ATZ]CODTYP
   Case [F:ATY]TYPTYP
    When 1,2,3 : LINE='& [F:'+LDEPABR+']'+PLSTFLD(I_FLD)
    When 4,5,6 : LINE='& Format$("N:'+num$([F:ATY]LNGTYP)+'",[F:'+LDEPABR+']'+PLSTFLD(I_FLD)+')'
    When 7     : LINE='& [F:'+LDEPABR+']'+PLSTFLD(I_FLD)
    When 8     : LINE='& Format$("D:" + GFMDAT4,[F:'+LDEPABR+']'+PLSTFLD(I_FLD)+')'
    When Default
   Endcase
   If I_FLD<>dim(PLSTFLD)-1
    LINE+=','
   Endif
   Wrseq LINE Using [SRC]
  Endif
 Next I_FLD
 Wrseq '& Using [FEX]'                             Using [SRC]
 Wrseq 'Return'                                    Using [SRC]

 Openo Using [SRC]

 # Validation du traitement
 # ------------------------

 If PVALID=G_OUI
  Local Integer OK
  Call VALID("TRT",NOMTRT,PAPPLI,OK) From VALMSKSUB
  If OK=0
   Local Char MESSAGE_ERR(50)
   MESSAGE_ERR=mess(20,GML_MSGMIS,1)-NOMTRT #"Erreur de compilation du traitement"
   If GTRACE<>""
     Call ECR_TRACE (MESSAGE_ERR,1) From GESECRAN
   Else
     Infbox MESSAGE_ERR
   Endif
   End
  Else
   If LDBGMODE : Call ECR_TRACE(mess(21,GML_MSGMIS,1)-NOMTRT-"OK",0) From GESECRAN : Endif #"GÃ©nÃ©ration du traitement"
  Endif
 Endif

End

#---------------------------------------------------------
# Export du plan d'amortissement
#---------------------------------------------------------
Subprog EXP_DPRPLN(PAASREF, PDPRPLN,PEXE, PPER, PLSTFLD, PFILENAME, PTRTNAM, RCOD)
  Value    Char    PAASREF
  Value    Integer PDPRPLN
  Value    Integer PEXE
  Value    Integer PPER
  Value    Char    PLSTFLD()()
  Value    Char    PFILENAME
  Value    Char    PTRTNAM
  Variable Integer RCOD

  Local Integer LLNGREQ : LLNGREQ=100

  Local Char    SAVADXIRS, SAVADXIFS
  Local Char    LREQBCO(LLNGREQ)
  Local Char    LREQPLN(LLNGREQ)
  Local Char    LREQEXE(LLNGREQ)
  Local Char    LREQPER(LLNGREQ)
  Local Char    LREQLIB(LLNGREQ)

  If clalev([F:XDEP])=0 : Local File DEPREC [XDEP] : Endif

  LREQBCO='AASREF="'+PAASREF+'"'
  LREQPLN='DPRPLN='+num$(PDPRPLN)
  Case PEXE
   When Default : LREQEXE="1=1"
  Endcase
  Case PPER
   When Default : LREQPER="1=1"
  Endcase
  If LREQLIB=""
   LREQLIB="1=1"
  Endif

  If PFILENAME=""
   RCOD=1 : End
  Endif

  Filter [F:XDEP] Where evalue(LREQBCO)&
&                       evalue(LREQPLN)&
&                       evalue(LREQEXE)&
&                       evalue(LREQPER)&
&                       evalue(LREQLIB)

  SAVADXIFS=adxifs :   SAVADXIRS=adxirs
  adxifs =";" : adxirs=chr$(13)+chr$(10)
  Openo PFILENAME,0 Using [FEX]
  Gosub ENREG_CSVFILE_HEADLINE From =PTRTNAM
  For [F:XDEP]
   Gosub ENREG_CSVFILE_LINE From =PTRTNAM
  Next
  Openo Using [FEX]

End

######################################################################################
## ACTIONS CHAMPS DE L'ECRAN EXPPLN1
######################################################################################

#--------------------------------------------
# Avant saisie - TYPEXP
#--------------------------------------------
Subprog AS_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Diszo FICHIER
Else
 Actzo FICHIER
Endif
End

#--------------------------------------------
# ContrÃ´le - TYPEXP
#--------------------------------------------
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat = 2 : End
Endif
If VALEUR=1 & VALEUR=[M]TYPEXP
 Call VERFCLI([M]FICHIER) From APATCH
Endif
End

#--------------------------------------------
# AprÃ¨s-modif - TYPEXP
#--------------------------------------------
Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
Local Char MACHINE(250) , REPERT(250) , OS(30) , SUF(30)
If GFICPATH<>""
 [M]FICHIER = GFICPATH
Endif
If VALEUR=1
 Call SET_NAMCLI([M]FICHIER) From ORDSYS
 Call VERFCLI([M]FICHIER) From APATCH
 Diszo FICHIER
Else
 Call MACHINE([M]FICHIER,MACHINE,REPERT) From ORDSYS
 Call GET_OS(MACHINE,OS) From ORDSYS
 If OS="unix"
  If (pat(left$(REPERT,3),"!:\") or left$(REPERT,1)="\")
   Call SETNAM(REPERT,[M]FICHIER,SUF) From GOBJTXT
   If SUF<>""
    [M]FICHIER += "."+SUF
   Endif
  Endif
 Else
  If left$(REPERT,1)="/"
   Call SETNAM(REPERT,[M]FICHIER,SUF) From GOBJTXT
   If SUF<>""
    [M]FICHIER += "."+SUF
   Endif
  Endif
 Endif
 Actzo FICHIER
 [M:EDP1]TYPEXP=VALEUR
Endif
Raz [M:EDP1]FICHIER : Affzo [M:EDP1]FICHIER
End

#--------------------------------------------
# ContrÃ´le - FICHIER
#--------------------------------------------
Subprog C_FICHIER(VALEUR)
Variable Char    VALEUR()

Local Integer ER , K , STAT , OK
Local Char    REPERT(GDIMFIC) , FICHIER(GDIMFIC)
Local Char    MACHINE(GDIMFIC) , OS(10)
Local Char    NAM(GDIMFIC) , SUF(30) , PARAM(30)
If VALEUR=""
 GMESSAGE = mess(35,126,1) : # Nom de fichier incorrect
 mkstat=1 : End
Elsif [M]TYPEXP=2 : # Serveur
 If left$(VALEUR,1)="#"
  GMESSAGE = mess(162,141,1) : # Le rÃ©pertoire doit Ãªtre indiquÃ© sur un serveur
  mkstat = 2 : End
 Endif
 Call MACHINE(VALEUR,MACHINE,REPERT) From ORDSYS
 Call GET_OS(MACHINE,OS) From ORDSYS
 If OS=""
  GMESSAGE = MACHINE-mess(90,141,1) : # Machine inexistante
  mkstat = 2 : End
 Elsif OS="unix"
  If pat(left$(REPERT,3),"!:\")
   GMESSAGE = mess(162,141,1) : # Le rÃ©pertoire doit Ãªtre indiquÃ© sur un serveur
   mkstat = 2 : End
  Elsif left$(REPERT,1)="\"
   GMESSAGE = mess(147,141,1) : # RÃ©pertoire inaccessible
   mkstat = 2 : End
  Endif
 Else
  If left$(REPERT,1)="/"
   GMESSAGE = mess(147,141,1) : # RÃ©pertoire inaccessible
   mkstat = 2 : End
  Endif
 Endif
 Raz ER
 Call EXISTE(VALEUR,ER) From ORDSYS
 Case ER
  When 2 : # rÃ©pertoire
   GMESSAGE = mess(55,141,1) : # Ce fichier est un rÃ©pertoire
   mkstat = 2 : End
  When 0 : # fichier
   Call ABSOLU(VALEUR,ER) From ORDSYS
   If ER
    GMESSAGE = mess(160,100,1) : # Le chemin doit Ãªtre indiquÃ© en absolu
    mkstat = 2 : End
   Endif
   Call SETNAM(VALEUR,NAM,SUF) From GOBJTXT
   If SUF<>""
    NAM += "."+SUF
   Endif
   REPERT = left$(VALEUR,instr(1,VALEUR,NAM)-1)
   Call EXISTE(REPERT,ER) From ORDSYS
   If ER<>2
    GMESSAGE = mess(9,141,1) : # RÃ©pertoire inexistant
    mkstat = 2 : End
   Endif
 Endcase
Endif
GFICPATH = VALEUR
End

#--------------------------------------------
# Bouton "Tous"
#--------------------------------------------
Subprog B1_NBFLD
 Local Char LACT : LACT="T"
 Gosub FILL_TAB
End

#--------------------------------------------
# Bouton "Aucun"
#--------------------------------------------
Subprog B2_NBFLD
 Local Char LACT : LACT="A"
 Gosub FILL_TAB
End

#--------------------------------------------
$FILL_TAB
 Local Integer I_FLD
 For I_FLD=1 To [M:EDP1]NBFLD
  Case LACT
   When "T" : [M:EDP1]FLGEXP(I_FLD-1)=G_OUI
   When "A" : [M:EDP1]FLGEXP(I_FLD-1)=G_NON
  Endcase
 Next I_FLD
 Affzo [M:EDP1]15
Return
