#<AdxTL>@(#)0.0.0.0 $Revision$
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AUPDATE_CONTROL_BEFORE"   : Gosub AUPDATE_CONTROL_BEFORE
      When "AREAD_AFTER"              : Gosub AREAD_AFTER
      When "ADELETE_AFTER"            : Gosub ADELETE_AFTER
    Endcase
Endcase
Return


$AUPDATE_CONTROL_BEFORE
#Call localisation scripts based on the legislation
#TODO: Handle legislation - V6 GCURLEG

#UK
Gosub AUPDATE_CONTROL_BEFORE From EMPLOIDSTG_CSTD_EVT_UKI

Return

$AREAD_AFTER
#Call localisation scripts based on the legislation
#TODO: Handle legislation - V6 GCURLEG

#UK
Gosub AREAD_AFTER From EMPLOIDSTG_CSTD_EVT_UKI
Return

$ADELETE_AFTER
Local Integer TRANSACTION_PENDING,DEL_OK

DEL_OK = [V]CST_AOK


Local File EMPLOCTRSTG  [HRCSG1]
Local File EMPUKISTG    [IDUSG1]
Local File EMPCTRUKISTG [CTRUSG1]
Local File EMPLORIBSTG  [RIBSG1]


#Detele all records from the table - EMPLOCTRSTG
  Delete [HRCSG1] Where [F:HRCSG1]REFNUM = this.REFNUM
  If fstat <> [V]CST_AOK
    DEL_OK = [V]CST_AERROR
  Endif

#Detele all records from the table - EMPUKISTG
  Delete [IDUSG1] Where [F:IDUSG1]REFNUM = this.REFNUM
  If fstat <> [V]CST_AOK
    DEL_OK = [V]CST_AERROR
  Endif

#Detele all records from the table - EMPCTRUKISTG
  Delete [CTRUSG1] Where [F:CTRUSG1]REFNUM = this.REFNUM
  If fstat <> [V]CST_AOK
    DEL_OK = [V]CST_AERROR
  Endif

#Detele all records from the table - EMPLORIBSTG
  Delete [RIBSG1] Where [F:RIBSG1]REFNUM = this.REFNUM
  If fstat <> [V]CST_AOK
    DEL_OK = [V]CST_AERROR
  Endif

LogicClose File     [HRCSG1]
LogicClose File     [IDUSG1]
LogicClose File     [CTRUSG1]
LogicClose File     [RIBSG1]
Return

