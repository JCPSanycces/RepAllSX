$ON_FLTDTACLC1
Onevent BEFORE_INPUT Call AS_FLTDTACLC1(zc) From W1HREXT1
Onevent CONTROL Call C_FLTDTACLC1(zc) From W1HREXT1
Return

Subprog AS_FLTDTACLC1(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1484,GBOUT1) From OBJDIV
Call TEXTE(27108,GBOUT2) From OBJDIV
Call TEXTE(29795,GBOUT3) From OBJDIV
If !GWEBSERV
 ## Action AFRIB
 Call IB_FORMULE From AFORMULE
 If mkstat=2
  [M]FLTDTACLC1(INDIC) = VALEUR
  Affzo FLTDTACLC1(INDIC) : mkstat = 2
 Endif
Endif
Onkey 129 Titled GBOUT1 Call B1_FLTDTACLC1(zc) From W1HREXT1
Onkey 130 Titled GBOUT2 Call B2_FLTDTACLC1(zc) From W1HREXT1
Onkey 131 Titled GBOUT3 Call B3_FLTDTACLC1(zc) From W1HREXT1
Gosub _AFF
End

Subprog C_FLTDTACLC1(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "FLTDTACLC1" : GZNUM = 10104 : Endif
If !GWEBSERV
 If !mkstat
  ## Action AFRCONT
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "AFRCONT"
  PARMSK(1) = ""
  Call S_AFF_CHAR(VALEUR,PARMSK,"AFRCONT","AFORMULE","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "FLTDTACLC1" : GZNUM = 10104 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog B1_FLTDTACLC1(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFRB1
 Call B1_FORMULE(VALEUR,"","","","","") From AFORMULE
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_FLTDTACLC1(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AFFMESS
 Call AFFMESS From AFORMULE
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B3_FLTDTACLC1(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ANAFOR
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ANAFOR"
 PARMSK(1) = ""
 PARMSK(2) = ""
 PARMSK(3) = ""
 PARMSK(4) = ""
 PARMSK(5) = ""
 Call TRAITE_CHAR(VALEUR,PARMSK,"","ANAFOR","ANAFOR",3,"") From GTRAITE
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

