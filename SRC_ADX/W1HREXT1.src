#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HREXT1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:37"
A_USER  = "DOC"
A_STAMP = "20181109230437"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "DTANBR"
  If [M]DTANBR=0
  Endif
 When "FLTNBR"
  If [M]FLTNBR=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HREXT1 [HREXT1]
Gosub HORODAT
Local Inpbox "HREXT1" From GFONCTION At A_STAMP With A_WINDPREV Mask [HREXT1] As [SIM_]
Grizo [HREXT1]5
Grizo [HREXT1]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [HREXT1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=13
X1(1)=1 : X2(1)=74 : Y1(1)=14 : Y2(1)=25
Return

$ON_DTALVL
Onevent BEFORE_INPUT Call AS_DTALVL(zc) From W1HREXT1
Onevent INIT_AREA Call D_DTALVL(zc) From W1HREXT1
Onevent CONTROL Call C_DTALVL(zc) From W1HREXT1
Return

Subprog D_DTALVL(VALEUR)
Variable Integer VALEUR
If varinit([M]DTALVL,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_DTALVL(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(11677) From COMBOS
## Action STD
Call AS_DTALVL(VALEUR) From SUBHREXT
If mkstat=2
 [M]DTALVL(INDIC) = VALEUR
 Affzo DTALVL(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,11677,1))))
Endif
If !mkstat
 Discombo 0 From DTALVL(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From DTALVL(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_DTALVL(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "DTALVL" : GZNUM = 5230 : Endif
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

$ON_DTATBL
Onevent CONTROL Call C_DTATBL(zc) From W1HREXT1
Onevent BEFORE_INPUT Call AS_DTATBL(zc) From W1HREXT1
Return

Subprog AS_DTATBL(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_DTATBL(zc) From W1HREXT1
Gosub _AFF
End

Subprog C_DTATBL(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "DTATBL" : GZNUM = 1176 : Endif
If !GWEBSERV
 If !mkstat
  ## Action ACTLAVWT
  Call ACTLAVWT(VALEUR,nomap) From SUBAVW
  If mkstat : GERR = 1 : GZONE = "DTATBL" : GZNUM = 1176 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_DTATBL(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action ASELVTAB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ASELVTAB"
 Call S_TAB_CHAR(VALEUR,PARMSK,"ASELVTAB","SUBAVW","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_DTALNKCLC
Onevent CONTROL Call C_DTALNKCLC(zc) From W1HREXT1
Return

Subprog C_DTALNKCLC(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_DTALNKCLC(VALEUR) From SUBHREXT
If mkstat : GERR = 1 : GZONE = "DTALNKCLC" : GZNUM = 988 : Endif
Gosub _AFF
End

