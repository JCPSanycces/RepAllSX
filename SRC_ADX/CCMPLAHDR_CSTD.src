#<AdxTL>@(#)0.0.0.0 $Revision$
# Class CCMPLAHDR - standard script which is used on all detail plans
#                   for updating Plan header, and also Change request status

$METHODS
  Case [L]CURPTH
    When ""
      Case [L]ACTION
        When "AUPDATE_CONTROL_AFTER" : Local Integer LOCALASTATUS : LOCALASTATUS = fmet this.UPDATE_STATUS()
        When "AUPDATE_AFTER"         : Gosub AUPDATE_AFTER
      Endcase
  Endcase
Return

#---------------------------------------------------
$AUPDATE_AFTER

  Local Instance PLAN Using C_CCMPLANH
  PLAN = NewInstance C_CCMPLANH AllocGroup null
  Local Integer LOCAL_ASTATUS

  LOCAL_ASTATUS = fmet PLAN.AREAD(this.CRID)
  If (LOCAL_ASTATUS = CST_AOK)
    LOCAL_ASTATUS = fmet PLAN.AUPDATE()
  Endif
  FreeGroup PLAN

Return

$PROPERTIES

  Local Integer LOCALASTATUS
  Local Char PROPERTYACTION(50)
  PROPERTYACTION = CURPRO +"." +ACTION

  Case PROPERTYACTION
    When "IMPLEMENT.CONTROL"   : ASTATUS = fmet this.VALIDATE_IMPLEMENT()
  Endcase

Return


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

