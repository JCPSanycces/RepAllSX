#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
Endcase

Return


$OUVRE

Return

$DEBUT
Local Char EMPCODE(GLONEML)
[L]EMPCODE=fmet GACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")

#Update header icon
#[M:ESSEV]WSTA2 = func ESS_FUNCTIONS.SET_ICON(2)
#[M:ESSEV]WSTADES2 = 2

#Update mask
Call UPDATE_ESSEV([L]EMPCODE,2)

Return

Subprog UPDATE_ESSEV(VEMPCODE,VSTA)
Value Char VEMPCODE
Value Integer VSTA
Local Integer PSTA
Local Char WORFKLOWCOD(1)

If clalev([F:ID])       = 0 : Local File EMPLOID            [ID]        : Endif
If clalev([F:ESWD2])    = 0 : Local File ESSWRKFLWDET       [ESWD2]     : Endif
If clalev([F:AWS3])     = 0 : Local File AWRKHISSUI         [AWS3]      : Endif

nolign =0

If VSTA <> 2
  Filter [F:ESWD2] Where REFNUM = VEMPCODE and MAIREC = 2 and STA <> 2 and STA <> 5
Else
  Filter [F:ESWD2] Where REFNUM = VEMPCODE and MAIREC = 2 and STA = 2 or STA = 5
Endif

For [F:ESWD2]ESWD0
  nolign+=1
  If nolign > dim([M:ESSEV]REFNUM) : Break : Endif
  [M:ESSEV] = [F:ESWD2]
  [M:ESSEV]WTEXSUI(nolign-1)= func ESS_FUNCTIONS.ESSGROUP([F:ESWD2]CODFIC)
  [L]WORFKLOWCOD = [F:ESWD2]WRK
  [M:ESSEV]WRKREQ(nolign-1) = func ESS_FUNCTIONS.WORKFLOWSTAT([L]WORFKLOWCOD)

  #Update icon
  #[M:ESSEV]WSTA(nolign-1) = func ESS_FUNCTIONS.SET_ICON([F:ESWD2]STA)
  Read [F:ID]ID0 = VEMPCODE
    If !fstat
    [M:ESSEV]NAM(nolign-1) = [F:ID]NAM
    [M:ESSEV]SRN(nolign-1) = [F:ID]SRN
  Endif
  Filter [F:AWS3] Where VALCTX1 = VEMPCODE and VALCTX5 = num$([F:ESWD2]UID)
  Read [F:AWS3] First
  Filter [F:AWS3]
  If !fstat
    [M:ESSEV]DATENV(nolign-1) = [F:AWS3]DATENV
  Endif
  [M:ESSEV]NBRLIN = nolign
Next
Filter [F:ESWD2]
Affzo [M:ESSEV]1-99
End

