# Classe COMPANY
#######################################################################################

#######################################################################################
$METHODS
  Case CURPTH
    When ""
      Case ACTION
        When "AREAD_AFTER"     :  Gosub AREAD_AFTER
        When Default
      Endcase
    When Default
  Endcase
Return

#######################################################################################
$PROPERTIES
Return

#######################################################################################
$AREAD_AFTER
Local Integer NI
Local Integer ILINE
Local Integer NE
Local Integer NFOUND

  NFOUND = [V]CST_ANO
  NE = 0
  For NI = 1 To maxtab(this.BPA)
    If this.BPA(NI).BPAADDFLG = [V]CST_AYES Then
      NE = NI
    Endif
    If this.BPA(NI).BPAADD = this.BPAADD Then
      #      If this.BPAPRI(1) = null Then
      #        ILINE = fmet this.ADDLINE("BPAPRI", [V]CST_ALASTPOS)
      #      Else
      #        ILINE = 1
      #      Endif
      this.BPAPRI(1) = this.BPA(NI)
      NFOUND = [V]CST_AYES
      Break
    Endif
  Next NI
  If NFOUND = [V]CST_ANO Then
    If NE = 0 Then
      If maxtab(this.BPA) > 0 Then
        NE = 1
      Endif
    Endif
    If NE > 0 Then
      #      If this.BPAPRI(1) = null Then
      #        ILINE = fmet this.ADDLINE("BPAPRI", [V]CST_ALASTPOS)
      #      Else
      #        ILINE = 1
      #      Endif
      this.BPAPRI(1) = this.BPA(NE)
    Endif
  Endif
Return

