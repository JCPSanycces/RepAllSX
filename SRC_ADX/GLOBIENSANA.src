#-----------------------------------------------------------------------------
# Chargement du tableau des axes et des sections analytiques 
#-----------------------------------------------------------------------------
Subprog LOAD_TAB_CCE(PFILE,PMSKFPC,PMSKCCE,NBRCCE)
Value    Char    PFILE 
Value    Char    PMSKFPC
Value    Char    PMSKCCE
Variable Integer NBRCCE

Local Integer I_DIE
Local Char    LDIE
Local Char    LSECTION
Local Char    LNOMCHAMP

For I_DIE=1 To evalue(PMSKFPC+"NBDIE")
 LDIE      = evalue(PMSKFPC+"DIE("+num$(I_DIE-1)+")")
 LNOMCHAMP = PMSKCCE+"DIE("+num$(I_DIE-1)+")"
 Assign  LNOMCHAMP With LDIE
 LSECTION  = func GENEVE.GET_CCE(PFILE,"","",LDIE)
 LNOMCHAMP = PMSKCCE+"CCE("+num$(I_DIE-1)+")"
 Assign  LNOMCHAMP With LSECTION
Next I_DIE
NBRCCE=evalue(PMSKFPC+"NBDIE")

End

#-----------------------------------------------------------------------------
# Contrôle si les axes analytique sont obligatoires et bien renseignés
#-----------------------------------------------------------------------------
$CTRL_TAB_CCE
 If [M]DSP = "" 
  # Contrôle de validité des axes analytiques
  Local Integer I_AXE, LERR
  GMESSAGE=mess(46,106,1)+space$(1) #"Axe obligatoire sur axe"
  For I_AXE=1 To dim([M]DIE)
   Local Integer IDX_AXE
   IDX_AXE=find([M]DIE(I_AXE-1),[M:FPC]DIE)
   If IDX_AXE
    If [M:FPC]OBYDIE(IDX_AXE-1)=G_OUI & [M]CCE(I_AXE-1)=""
     LERR=1
     GMESSAGE+=[M]DIE(I_AXE-1)+" "
    Endif
   Endif
  Next I_AXE
  If LERR
   GERR=1 : OK = 0
   zonsui = "[M]CCE"
   Return
  Else
   GMESSAGE=""
  Endif
 Endif
Return
