#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################
# UTITC01      Moulinette pour alimentation coût niveau     Module TC    #
# ---------------------------------------------------------------------- #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC

  Call MOULI_CSTLEV(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MOULI_CSTLEV(DOSSIER)
Value Char DOSSIER

# moulinette pour alimenter les coûts du niveau des coûts standard saisis

Local Integer NB, STOP
Local Char    ERR_TRA(200)
Local Char    CRITERE(240)
Local Char    CLE1(GLONFCY), CLE2(GLONITM)
Local Integer CLE3,CLE4,CLE5

If clalev([ITC]) = 0 Local File =DOSSIER+".ITMCOST"    [ITC] Endif
If clalev([ITF]) = 0 Local File =DOSSIER+".ITMFACILIT" [ITF] Endif
#

ERR_TRA = "Standard cost - Level cost update"
Call ECR_TRACE(ERR_TRA,0) From GESECRAN

$BOUCLEITC
Raz NB,STOP

Call DEBTRANS From GLOCK
Trbegin [ITC]

If STOP=1
   CRITERE = 'STOFCY="'+CLE1+'"&ITMREF="'+CLE2+'"&CSTTYP='+num$(CLE3)+'&YEA='+num$(CLE4)+'&CSTSEQ>'+num$(CLE5)
   STOP+=1
Elsif STOP=2
   CRITERE = 'STOFCY="'+CLE1+'"&ITMREF="'+CLE2+'"&CSTTYP='+num$(CLE3)+'&YEA>'+num$(CLE4)
   STOP+=1
Elsif STOP=3
   CRITERE = 'STOFCY="'+CLE1+'"&ITMREF="'+CLE2+'"&CSTTYP>'+num$(CLE3)
   STOP+=1
Elsif STOP=4
   CRITERE = 'STOFCY="'+CLE1+'"&ITMREF>"'+CLE2
   STOP+=1
Elsif STOP=5
   CRITERE = 'STOFCY>"'+CLE1+'"'
   STOP=0
Else
   CRITERE = "1=1"
Endif


For [ITC] Where evalue(CRITERE)
    If [F:ITF]ITMREF<>[F:ITC]ITMREF | [F:ITF]STOFCY<>[F:ITC]STOFCY
        Read [ITF]ITF0=[F:ITC]ITMREF;[F:ITC]STOFCY
        If fstat
            ERR_TRA = "ITMFACILIT : "+[F:ITC]ITMREF+";"+[F:ITC]STOFCY-"doesn't exist"
            Call ECR_TRACE(ERR_TRA,0) From GESECRAN
        Endif
    Endif
    If !fstat
       If [F:ITF]STDCSTUPD=2 & [F:ITC]CSTTYP=1
&       | [F:ITF]CUTCSTUPD=2 & [F:ITC]CSTTYP=2
&       | [F:ITF]BUDCSTUPD=2 & [F:ITC]CSTTYP=3
&       | [F:ITF]SIMCSTUPD=2 & [F:ITC]CSTTYP=4
            If sum([F:ITC]MATLEVCST,[F:ITC]MACLEVCST,[F:ITC]LABLEVCST,[F:ITC]SCOLEVCST,[F:ITC]OVELEVCST)=0 & [F:ITC]VLTTOT<>0
                Readlock [ITC] Curr
                If !fstat
                    For I=0 To dim([F:ITC]MATLEVCST)-1
                        [F:ITC]MATLEVCST(I) = [F:ITC]MATCST(I)
                    Next
                    For I=0 To dim([F:ITC]MACLEVCST)-1
                        [F:ITC]MACLEVCST(I) = [F:ITC]MACCST(I)
                    Next
                    For I=0 To dim([F:ITC]LABLEVCST)-1
                        [F:ITC]LABLEVCST(I) = [F:ITC]LABCST(I)
                    Next
                    [F:ITC]SCOLEVCST = [F:ITC]SCOCST
                    [F:ITC]OVELEVCST = [F:ITC]OVETOT
                    [F:ITC]OVEMATLEV = [F:ITC]OVETOT
                    Rewrite [ITC]
                    ERR_TRA = [F:ITC]ITMREF+";"+[F:ITC]STOFCY+";"+num$([F:ITC]CSTTYP)+";"+num$([F:ITC]YEA)+";"+num$([F:ITC]CSTSEQ)-"updated"
                    Call ECR_TRACE(ERR_TRA,0) From GESECRAN
                    NB+=1
                Else
                    ERR_TRA = "ITMCOST : "+[F:ITC]ITMREF+";"+[F:ITC]STOFCY+";"+num$([F:ITC]CSTTYP)+";"+num$([F:ITC]YEA)+";"+num$([F:ITC]CSTSEQ)-"locked"
                    Call ECR_TRACE(ERR_TRA,1) From GESECRAN
                Endif
            Elsif sum([F:ITC]MATLEVCST,[F:ITC]MACLEVCST,[F:ITC]LABLEVCST,[F:ITC]SCOLEVCST,[F:ITC]OVELEVCST) <> [F:ITC]VLTTOT
                ERR_TRA = [F:ITC]ITMREF+";"+[F:ITC]STOFCY+";"+num$([F:ITC]CSTTYP)+";"+num$([F:ITC]YEA)+";"+num$([F:ITC]CSTSEQ)-"difference between total cost and sum of level cost detail"
                Call ECR_TRACE(ERR_TRA,1) From GESECRAN
            Endif
        Endif
    Endif
    If NB>GMAXUPDTRS
        CLE1 = [F:ITC]STOFCY
        CLE2 = [F:ITC]ITMREF
        CLE3 = [F:ITC]CSTTYP
        CLE4 = [F:ITC]YEA
        CLE5 = [F:ITC]CSTSEQ
        STOP = 1
        Break
    Endif
Next

If GOK = 1
  Commit
  If STOP Goto BOUCLEITC Endif
Else
  Rollback
  Goto FIN_MOULI
Endif


$FIN_MOULI
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
# s'il n'y a pas le module stock ou le module compta, on ne fait rien
If [F:ADS]MODULE(8)<>2 End : Endif
Call MOULI_CSTLEV(APPLI)
End


#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif

# s'il n'y a pas le module stock ou le module compta, on ne fait rien
If [F:ADS]MODULE(8)<>2 End : Endif
Call MOULI_CSTLEV(APPLI)
End


