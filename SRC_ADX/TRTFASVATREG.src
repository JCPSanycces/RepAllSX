#*********************************************************************
# MDJ   17.03.2016 114131    Correction du compteur nombre de biens mis Ă  jour
# GLE   26.01.2010 FQ61931   Correction de la sĂŠlection pour exclure les biens sortis dans un exercice antĂŠrieur
# GBO   21.12.2009 FQ57157   ContrĂ´le la valeur des paramĂ¨tres REGBASDEV et REGVATDEV
# MWA   08.09.2009 FQ57635   EvenĂ¨ment d'annulation de rĂŠgularisation non gĂŠnĂŠrĂŠ.
# MWA   29.07.2009 FQ56815   Mise Ă  jour systĂŠmatique de la base pour les biens ultĂŠrieurs Ă  l'exercice courant.
# MWA   02.07.2009 FQ54210   Annulation 54210.
#*********************************************************************

# GTAMUNI unitaire ou GTAMMAS massif

 Raz GPILOBJ
 Call DEFVAR From GLOBIMM
 Call INIVAR From GLOBIMM
 Call LAUNCH_ACT(GTAMMAS)
End
#==============================================================#
#            Gestion de l'action mĂŠtier FASVATREG              #
#==============================================================#

####  Call ECR_TRACE("Informations Ă  tracer",0) From GESECRAN

######################################################################
# Etiquettes modĂ¨le Traitement standard / saisie fenĂŞtre / gobjet
######################################################################
$ACTION
 #Infbox "TRTFASVATREG /"-ACTION
 Case ACTION
  When "INIT"         : Gosub INIT
  When "INIT_DIA"     : Gosub INIT_DIA
  When "AVANT_PAR"    : Gosub AVANT_PAR
  When "OUVRE"        : Gosub OUVRE
  When "OUVRE_BATCH"  : Gosub OUVRE_BATCH
  When "DEBUT"        : Gosub DEBUT
  When "APRES_MODIF"  : Gosub APRES_MODIF
  When "SETBOUT"      : Gosub SETBOUT
  When "AP_CHOIX"     : Gosub AP_CHOIX
  When "BOUTON"       : Gosub BOUTON
  When "END"          : Gosub END_BOITE
  When "OK"           : Gosub OK
  When "EXEC"         : Gosub EXEC
  When "CONTROLE"     : Gosub CONTROLE
  When "FIN"          : Gosub FIN
  When "TERMINE"      : Gosub TERMINE
  When "SORTIE"       : Gosub SORTIE
  When Default
 Endcase
Return


#=====================================================================
$OUVRE_BATCH             # (Massif uniquement - Soumission batch uniquement)
  Gosub ACTION From =TRTMODACT
  Gosub OUVRE_TABLES
Return

#=====================================================================
$INIT_DIA                    # (Massif - Saisie des paramĂ¨tres)
 If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
 TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$INIT                    # (Massif uniquement - interactif et exĂŠcution batch)
 If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
 TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
 Gosub ACTION From =TRTMODACT

 If GSERVEUR
  #==> DĂŠclaration globales
  Gosub CREE_GLOBTRT
  #==> DĂŠclaration globales nĂŠcessaires Ă  la fonction
  Call GET_ELEM_REG_TVA("") From TRTFAS
 Endif


Return

#=====================================================================
$AVANT_PAR               # (Massif uniquement - Interactif et soumission batch)

  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT

  ##### Ouverture des masques de la fenĂŞtre de l'action massive pour pouvoir les garder jusqu'Ă 
  ##### EXEC - Ouverture manuelle des masques de la fenĂŞtre.
  ##### NĂŠcessaire jusqu'Ă  ce qu'une modif permette de lancer une action massive avec plus
  ##### d'un ĂŠcran de critĂ¨re.
  Local Char WINACT : WINACT=ACTMETNAM+""
  Local Integer I_MSK
  If !clalev([F:AWI]) : Local File AWINDOW : Endif
  If !clalev([F:AMK]) : Local File AMSK    : Endif
  Read [AWI]AWI0=WINACT
  If !fstat
   Local Mask =[F:AWI]MSKENT
   For I_MSK=0 To [F:AWI]NBMSK
     Read [AMK]CODMSK=[F:AWI]NOMMSK(I_MSK)
     Local Mask =[F:AMK]CODMSK
   Next I_MSK
  Endif
  ##### Fin spĂŠcificitĂŠ.

Return

#=====================================================================
$OUVRE                   # (Massif interactif et Unitaire)
  If dim(TRTMODACT)<0
   Global Char TRTMODACT
   TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Endif
  Gosub ACTION From =TRTMODACT


  #==> Ouverture des tables
  Gosub OUVRE_TABLES

  If !GSERVEUR
   Gosub CREE_GLOBTRT
  Endif

  #==> Trace du traitement
  G_TRACE       = G_NON
  #==> DĂŠclaration globales nĂŠcessaires Ă  la fonction
  Call GET_ELEM_REG_TVA("") From TRTFAS


  Local Char OLDCPY(GLONCPY)

Return

#=====================================================================
$CREE_GLOBTRT
  Global Integer    G_TRACE
  Global Integer    G_NBBCO
  Global Integer    G_NBBCO_TRT
  Global Integer    G_REGCOD, G_REGTRF
  Global Decimal    G_DPRBASO, G_DPRBASIO
  Global Decimal    G_TAUX, G_REGUL, G_REGULI
  Global Decimal    G_BASDEV, G_DEDVATAMT, G_DEDVATAMTI, G_DEDVATRAT, G_DEDVATRATI

  Global Date       G_FINPERCPF, G_FINPERIAS
Return

#=====================================================================
$DEBUT # (Massif et Unitaire)

  Gosub ACTION From =TRTMODACT

  #--> On rend le masque invalide pour faire tous les contrĂ´les
  # Setmok [M:FASR] With 0

Return

#=====================================================================
$APRES_MODIF

  Gosub ACTION From =TRTMODACT # A positionner ici car ce qui suit altĂ¨re la valeur de nolign...

  Case COUZON
    When "FLGCPY"
      If ( val(CZ) = G_OUI ) Then
        [M:FASR]STRDAT = GDEBEXECPF : Affzo [M:FASR]STRDAT
        [M:FASR]MVTDAT = GFINEXECPF : Affzo [M:FASR]MVTDAT
        Call INIT_PLAN_AMT([M:MHC]CPY(nolign-1))
      Endif
    When "FLGFCY"
      If ( val(CZ) = G_OUI and OLDCPY <> [M:MHC]FCYCPY(nolign-1) ) Then
        OLDCPY = [M:MHC]FCYCPY(nolign-1)
        [M:FASR]STRDAT = GDEBEXECPF : Affzo [M:FASR]STRDAT
        [M:FASR]MVTDAT = GFINEXECPF : Affzo [M:FASR]MVTDAT
        Call INIT_PLAN_AMT([M:MHC]FCYCPY(nolign-1))
      Endif
    When Default
  Endcase


Return

#=====================================================================
$SETBOUT                 # (Massif interactif et unitaire : )
  Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$AP_CHOIX                 # (Unitaire : )
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$BOUTON                  # (Massif interactif et unitaire)
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$END_BOITE               # (Massif interactif et unitaire)
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$OK                      # (Massif intĂŠractif et unitaire)
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$CONTROLE
If (GSERVEUR) Then
  Call ACTION_CPY ([M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1)) From GLOFCYCPY
 Endif
 Gosub CONT_PARM #FQ57157
Return

#=====================================================================
$EXEC                    # (Massif intĂŠractif et batch)
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$FIN                     # ()
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$TERMINE                  # ()
 Gosub ACTION From =TRTMODACT

  Call FERME_BOITE From GESECRAN

  #==> Suppression des globales nĂŠcessaires Ă  la fonction
  If dim(G_ECIMPBAS)   >0  : Kill G_ECIMPBAS   : Endif
  If dim(G_ECVARPRO)   >0  : Kill G_ECVARPRO   : Endif
  If dim(G_IMPBASVT)   >0  : Kill G_IMPBASVT   : Endif
  If dim(G_TENCOURS)   >0  : Kill G_TENCOURS   : Endif
  If dim(G_REGULIAS)   >0 : Kill G_REGULIAS  : Endif
  If dim(G_TVASITE)    >0  : Kill G_TVASITE    : Endif

  If dim(G_TRACE)      >0  : Kill G_TRACE      : Endif
  If dim(G_NBBCO)      >0  : Kill G_NBBCO      : Endif
  If dim(G_NBBCO_TRT)  >0  : Kill G_NBBCO_TRT  : Endif
  If dim(G_REGCOD)     >0  : Kill G_REGCOD     : Endif
  If dim(G_REGTRF)     >0  : Kill G_REGTRF     : Endif
  If dim(G_DPRBASO)    >0  : Kill G_DPRBASO    : Endif
  If dim(G_DPRBASIO)   >0  : Kill G_DPRBASIO   : Endif

  If dim(G_TAUX)       >0  : Kill G_TAUX       : Endif
  If dim(G_REGUL)      >0  : Kill G_REGUL      : Endif
  If dim(G_REGULI)     >0  : Kill G_REGULI     : Endif

  If dim(G_BASDEV)     >0  : Kill G_BASDEV     : Endif
  If dim(G_DEDVATAMT)  >0  : Kill G_DEDVATAMT  : Endif
  If dim(G_DEDVATAMTI) >0  : Kill G_DEDVATAMTI : Endif
  If dim(G_DEDVATRAT)  >0  : Kill G_DEDVATRAT  : Endif
  If dim(G_DEDVATRATI) >0  : Kill G_DEDVATRATI : Endif

  If dim(G_FINPERCPF)  >0  : Kill G_FINPERCPF  : Endif
  If dim(G_FINPERIAS)  >0  : Kill G_FINPERIAS  : Endif

Return

#=====================================================================
$SORTIE
 Gosub ACTION From =TRTMODACT
Return

######################################################################
# Points d'entrĂŠe de l'action mĂŠtier communs unitaire / massif
######################################################################

$ACTMET
 Case ACTMET

  When "SET_GLO_MAS"        :   Gosub SET_GLO_MAS
  When "SET_CRITACT"        :   Gosub SET_CRITACT          # UM - CRITACT critĂ¨re de sĂŠlection particulier Ă  l'action mĂŠtier
  When "FILL_HEA"           :   Gosub FILL_HEA             # U  - Alimentation partie spĂŠcifique en-tĂŞte

# Locker

  When "OUVR_LOCK"          :   Gosub OUVR_LOCK            # UM - Ouverture de tables annexes pour les lock
  When "MAS1_CONTROLE"      :   Gosub MAS1_CONTROLE        # UM  - Exclusion ĂŠlĂŠment de la population Ă  sĂŠlectionner
  When "MAS1_LOCK_AUTRE"    :   Gosub MAS1_LOCK_AUTRE      # UM - Lock objet liĂŠ Ă  l'enr en ligne de la population

# Charger

  When "OUVR_ALIM_TMP1"     :   Gosub OUVR_ALIM_TMP1       # UM - Ouverture de tables annexes pour l'alim des table tmp.
  When "MAS1_ALIM_TMP1"     :   Gosub MAS1_ALIM_TMP1       # UM - Transfert zones tables de donnĂŠes -> tables tempo

# Applique_temp

  When "OUVR_APPL_TMP1"     :   Gosub OUVR_APPL_TMP1       # UM - Ouverture de tables annexes
  When "TMP1_APPL_TMP1"     :   Gosub TMP1_APPL_TMP1       # UM - Application des paramĂ¨tres de l'action aux enr de la table temporaire principale
  When "TPF1_APPL_TPF1"     :   Gosub TPF1_APPL_TPF1       # UM - Application des paramĂ¨tres de l'action aux enr de la table temporaire annexe

# Report_mask Report objet principal dans les masques (unitaire uniquement)

  When "TMP1_ALIM_MASK"     :   Gosub TMP1_ALIM_MASK       # U  - Tansfert table temporaire principale -> masques de l'ĂŠcran
  When "TPF1_ALIM_MASK"     :   Gosub TPF1_ALIM_MASK       # U  - Tansfert table temporaire annexe     -> masques de l'ĂŠcran
  When "REAF_ALIM_MASK"     :   Gosub REAF_ALIM_MASK       # U  - Tansfert tables temporaires -> masques de l'ĂŠcran (pour rĂŠaffichage)

# Applique_dirt Mise Ă  jour directe (massif uniquement)

  When "OUVR_APPL_DIRT"     :   Gosub OUVR_APPL_DIRT       # M  - Ouverture de tables annexes pour la maj directe en massif
  When "MAS1_APPL_DIRT"     :   Gosub MAS1_APPL_DIRT       # M  - Mise Ă  jour directe des tables de donnĂŠes avec les paramĂ¨tres de l'action
  When "CLOS_APPL_DIRT"     :   Gosub CLOS_APPL_DIRT       # M  - Fin mise Ă  jour directe

# reporter

  When "OUVR_ALIM_TABLE"    :   Gosub OUVR_ALIM_TABLE      # UM - Ouverture tables annexes avant report tables tempo -> tables de donnĂŠes
  When "TMP1_ALIM_TABLE"    :   Gosub TMP1_ALIM_TABLE      # UM - Report table temporaire principale -> table de donnĂŠes
  When "TPF1_ALIM_TABLE"    :   Gosub TPF1_ALIM_TABLE      # UM - Report table temporaire par plan   -> table de donnĂŠes par plan

  When Default

 Endcase
Return


#=====================================================================
# Unitaire / massif :
$SET_GLO_MAS
  # Aucun bien susceptible de subir une rĂŠgularisation de TVA
  GMSGNOOBJLCK= mess(468,7773,1)
Return


#=====================================================================
# Unitaire / massif : CritĂ¨re de sĂŠlection particulier Ă  l'action mĂŠtier
$SET_CRITACT
  # CRITACT contient les critĂ¨res de sĂŠlection suppplĂŠmentaires Ă  appliquer Ă  la population Ă  sĂŠlectionner
  # Les biens modĂ¨les ou ceux ayant fait l'objet d'une sortie "rĂŠelle" sont exclus de la sĂŠlection
  # Nouvelles rĂ¨gles TVA 2008
  #CRITACT  =" OWNTYP <> GVML_TDMODEL AND OWNTYP <> GVML_TDLOCAT and OWNTYP <> GVML_TDPREVU and ASJCOE <> 0 and "
  #CRITACT +=" ( ( ISSDAT >= GDEBEXECPF and ISSDAT <= GFINEXECPF and EXTISSFLG = G_NON ) or "
  #CRITACT +="   ( ISSDAT <> [0/0/0] and EXTISSFLG = G_OUI ) or ( ISSDAT = [0/0/0] )  ) "

  # Non selection des biens antĂŠrieurs Ă  l'exercice
  #CRITACT=" OWNTYP <> GVML_TDMODEL AND OWNTYP <> GVML_TDLOCAT and OWNTYP <> GVML_TDPREVU and ASJCOE <> 0 "

  # FQ61931
  CRITACT  =" OWNTYP <> GVML_TDMODEL AND OWNTYP <> GVML_TDLOCAT and OWNTYP <> GVML_TDPREVU and ASJCOE <> 0 and "
  CRITACT +=" ( ( ISSDAT >= GDEBEXECPF ) or ( ISSDAT = [0/0/0] ) )"

Return

#=====================================================================
# Unitaire : Permet d'alimenter des zones spĂŠcifiques de l'en-tĂŞte de la fenĂŞtre
$FILL_HEA
Return

#=====================================================================
# Unitaire et massif : Sert Ă  ouvrir des tables utilisĂŠes dans MAS1_CONTROLE
#                      et MAS1_LOCK_AUTRE
$OUVR_LOCK
  Gosub OUVRE_TABLES
Return

#=====================================================================
# Unitaire / massif : contrĂ´le ĂŠlĂŠment pour retrait de la population
$MAS1_CONTROLE
  # Exclusion des sorties rĂŠelles en dehors de l'exercice courant
  If ( [F:MAS1]ISSDAT <> [0/0/0] and [F:MAS1]EXTISSFLG <> G_OUI ) Then
    If ( [F:MAS1]ISSDAT < GDEBEXECPF or [F:MAS1]ISSDAT > GFINEXECPF ) Then
      G_OK = 0
    Endif
  Endif
Return

#=====================================================================
# Unitaire / massif : Lock d'objet liĂŠ Ă  l'enregistrement en ligne
#                     Alimenter RMES si un message soit apparaĂŽtre
$MAS1_LOCK_AUTRE
Return

#=====================================================================
# Unitaire / massif : Sert Ă  ouvrir des tables utilisĂŠes dans MAS1_ALIM_TMP1
$OUVR_ALIM_TMP1
Return

#=====================================================================
# Unitaire / massif : Chargement de la population en table temporaire
#                     Etiquette appelĂŠe par le s/p CHARGER
#                     Si une erreur se produit dans cette ĂŠtiquette
#                     Alimenter RMES avec le message qui doit apparaĂŽtre
#                     dans une boĂŽte en unitaire ou en massif
$MAS1_ALIM_TMP1
Return

#=====================================================================
# Unitaire / massif : Ouverture de tables annexes
$OUVR_APPL_TMP1
Return

#=====================================================================
# Unitaire / massif : Application paramĂ¨tres action au contenu de la table temporaire principale
$TMP1_APPL_TMP1
Return

#=====================================================================
# Unitaire / massif : Application paramĂ¨tres action au contenu de la table temporaire annexe (par plan)
$TPF1_APPL_TPF1
Return

#=====================================================================
# Unitaire : Permet de reporter les infos de TMP1 dans les masques de l'objet mĂŠtier
#            Positionner ACTMODIF Ă  1 si des infos de l'objet mĂŠtier sont modifiĂŠes
$TMP1_ALIM_MASK
Return

#=====================================================================
# Unitaire : Permet de reporter les infos de TPF1 dans les masques de l'objet mĂŠtier
#            Positionner ACTMODIF Ă  1 si des infos de l'objet mĂŠtier sont modifiĂŠes
$TPF1_ALIM_MASK
Return

#=====================================================================
# Unitaire : Permet de rĂŠafficher les masques de l'objet mĂŠtier si des modifs
#            y ont ĂŠtĂŠ reportĂŠes.
REAF_ALIM_MASK
Return

#=====================================================================
# Massif : Sert Ă  ouvrir des tables utilisĂŠes dans MAS1_APPL_MAS1
$OUVR_APPL_DIRT
  Gosub OUVRE_TABLES
  # SociĂŠtĂŠ courante : rupture sociĂŠtĂŠ pour ĂŠmission en-tĂŞte trace
  Local Char    TRC_CPY
  Local Char    TXTPROG(40)
  Local Integer NBBCO


  TXTPROG = mess(292,7773,1)
  G_NBBCO   = NBOBJLCK
  Call TEMPOFF() From GESECRAN
  Call OUVRE_BOITE(TXTPROG, G_NBBCO) From GESECRAN
  Call SET_BOITE(TXTPROG, G_NBBCO) From GESECRAN

  NBMAJ_RECALC = G_NON

  # Nouvelles rĂ¨gles TVA
  If dim([V]G_AASBUSO)<0     : Global Char    G_AASBUSO      : Endif
  If dim([V]G_ASJCOERO)<0    : Global Decimal G_ASJCOERO     : Endif
  If dim([V]G_TAXCOERO)<0    : Global Decimal G_TAXCOERO     : Endif
  If dim([V]G_ADMCOERO)<0    : Global Decimal G_ADMCOERO     : Endif
  If dim([V]G_DEDCOERO)<0    : Global Decimal G_DEDCOERO     : Endif
  If dim([V]G_ASJCOEO)<0     : Global Decimal G_ASJCOEO      : Endif
  If dim([V]G_TAXCOEO)<0     : Global Decimal G_TAXCOEO      : Endif
  If dim([V]G_TAXCOEFLGO)<0  : Global Integer G_TAXCOEFLGO   : Endif
  If dim([V]G_ADMCOEO)<0     : Global Decimal G_ADMCOEO      : Endif
  If dim([V]G_DEDCOEO)<0     : Global Decimal G_DEDCOEO      : Endif
  If dim([V]G_VATREGDATO)<0  : Global Date    G_VATREGDATO   : Endif
  If dim([V]G_IVCVATAMTO)<0  : Global Decimal G_IVCVATAMTO   : Endif
  If dim([V]G_IVCVATIASO)<0  : Global Decimal G_IVCVATIASO   : Endif
  If dim([V]G_DEDVATAMTO)<0  : Global Decimal G_DEDVATAMTO   : Endif
  If dim([V]G_DEDVATIASO)<0  : Global Decimal G_DEDVATIASO   : Endif
  If dim([V]G_ASJCOEFO)<0    : Global Decimal G_ASJCOEFO     : Endif
  If dim([V]G_TAXCOEFO)<0    : Global Decimal G_TAXCOEFO     : Endif
  If dim([V]G_ADMCOEFO)<0    : Global Decimal G_ADMCOEFO     : Endif
  If dim([V]G_DEDCOEFO)<0    : Global Decimal G_DEDCOEFO     : Endif

Return

#=====================================================================
# Massif : Application paramĂ¨tres action aux tables de donnĂŠes : mise Ă  jour directe
$MAS1_APPL_DIRT
If ( G_TRACE = G_OUI) Then : Infbox "MAS1_APPL_DIRT" : Endif
Local Char    TXTPROG(40)
Local Integer NBBCO_TRT, LOK
Local Date    W_CNX_DATE(1..5)
Local Integer CDRET

Local Integer RTRN

  #-> A rupture sociĂŠtĂŠ on ĂŠmet un en-tĂŞte dans la trace
  If ( [F:MAS1]CPY<>TRC_CPY ) Then

    #==> DĂŠclaration globales nĂŠcessaires Ă  la fonction
    Call GET_ELEM_REG_TVA([F:MAS1]CPY) From TRTFAS

    Gosub ECR_ENTETE
    TRC_CPY=[F:MAS1]CPY
    Raz G_NBBCO_TRT

    # RĂŠcupĂŠration date de fin de pĂŠriode contexte fiscale & comptable pour gĂŠnĂŠration ĂŠvĂŠnement
    Call GET_CNX_DAT([F:MAS1]CPY, G300CPFI, W_CNX_DATE, CDRET) From GLOBIENS
    G_FINPERCPF = W_CNX_DATE(4)
    If ( G_FINPERCPF = [0/0/0] ) Then
      G_FINPERCPF = W_CNX_DATE(2)
    Endif
    # RĂŠcupĂŠration date de fin de pĂŠriode contexte IAS (si gĂŠrĂŠ)  pour gĂŠnĂŠration ĂŠvĂŠnement
    If ( GCNXPROIAS = G_OUI ) Then
      Call GET_CNX_DAT([F:MAS1]CPY, G300IAS, W_CNX_DATE, CDRET) From GLOBIENS
      G_FINPERIAS = W_CNX_DATE(4)
      If ( G_FINPERIAS = [0/0/0] ) Then
        G_FINPERIAS = W_CNX_DATE(2)
      Endif
    Endif

  Endif

  G_NBBCO_TRT += 1
  TXTPROG    = mess(293,7773,1)+[F:MAS1]AASREF+'['+num$(G_NBBCO_TRT)+'/'+num$(G_NBBCO)+']'
  Call AFF_BOITE(TXTPROG,G_NBBCO_TRT,LOK) From GESECRAN

  # RĂŠgularisation annuelle pour le secteur d'origine
  Gosub REGUL_ANNUEL_TRANSFERT


  Gosub REGUL_TVA

  If (RTRN > 0 ) Then
    # Erreur technique
    If (RTRN = 1 ) Then
    RMES= mess(294,7773,1)-[F:MAS1]AASREF- mess(295,7773,1)-[F:MAS1]AASBUS
    Endif
    If (RTRN = 2 ) Then
      RMES=mess(104,7773,1)-"DEPREC"-mess(105,7773,1)-" 02"-mess(106,7773,1)-[F:MAS1]AASREF+"/"+num$([F:DEPX]DPRPLN)
      GOK=0 : Return
    Endif
    If (RTRN = 3 ) Then
    RMES= mess(294,7773,1)-[F:MAS1]AASREF-mess(296,7773,1)
    Endif
    If (RTRN = 4 ) Then
    RMES= mess(294,7773,1)-[F:MAS1]AASREF-mess(297,7773,1)
    Endif
    GOK=0 : Return
  Endif

  # Seuls les biens rĂŠgularisables sont considĂŠrĂŠs comme mis Ă  jour.
  If ( RTRN = 0 ) Then
    # Issue 114131 NBCPYMAJ += 1
  Endif

  If ( FLGSIM = G_NON ) Then
    Rewrite [MAS1]
    If ( fstat ) Then
      # Erreur technique
      RMES= mess(104,7773,1)+" FXDASSETS"+mess(105,7773,1)+" 01"+mess(106,7773,1)-[F:MAS1]AASREF
      GOK=0 : Return
    Endif
  Endif

Return



########################################
$REGUL_TVA

# PrĂŠrequis : Le sous-programme GET_ELEM_TVA doit avoir ĂŠtĂŠ executĂŠ.

# Nouvelles rĂ¨gles TVA

#    RTRN = -1    #  Pas rĂŠgularisable
#    RTRN =  0    #  OK
#    RTRN =  1    #  Secteur d'activitĂŠ non trouvĂŠ dans la table 410
#    RTRN =  2    #  Erreur mise Ă  jour DEPREC
#    RTRN =  3    #  Erreur conversion  DEPREC
#    RTRN =  4    #  Erreur gĂŠnĂŠration ĂŠvĂŠnement
#    RTRN =  5    #  Erreur extourne ĂŠvĂŠnements
#    RTRN =  6    #  Erreur suppression amortissements
#    RTRN =  7    #  Erreur en gestion des flux
#    RTRN =  8    #  Erreur ĂŠcriture dans historique TVA

Local Decimal LMNTCONV

Local Decimal LTAUXPRO, LTAUXDEF, LMONTANT,  LTAUX, LRECDEF, LRECINI
Local Integer LERROR,   LREGTYP, LREGTYPI , LDURRES
Local Decimal SDEDVATAMT, SDPRBAS, SDEDVATRAT, SDEDVATAMTI, SDPRBASI, SDEDVATRATI
Local Integer LTRCTYP
Local Integer LMAJBASE

Local Decimal SDPRBASI
Local Decimal LDEDCOE, LASJCOE
Local Char    LFORMULE(50)
Local Integer LVATYEAFLG
Local Integer LTAUXDEFFLG

Local Integer LCDRET
Local Char    LCDINT(10)

Local Decimal MTDES
Local Integer STAT

  LMAJBASE = G_NON
  G_REGUL  = 0
  G_REGULI = 0
  G_BASDEV = 0
  RTRN = 0 :  # OK
  # RĂŠgularisation de TVA ( fixation prorata dĂŠfinitif ou variation dans le temps)
  # ------------------
  If not (func TRTFAS.FAS_IS_REGULARISABLE("[F:MAS1]") ) Then
    RTRN = -1 : Return : # Pas rĂŠgularisable
  Endif
  # Determination de type de rĂŠgularisation 0-Aucune 1-Exercice acquisition 2-Exercice antĂŠrieur.
  Call DETERM_TYPE_REGUL
&      ("[F:MAS1]", [F:MAS1]VATREGDAT, [M:FASR]MVTDAT, [F:MAS1]THESLI, LDURRES, LREGTYP, LREGTYPI) From TRTFAS
  # ----------------------
  If (LREGTYP = 0 and LREGTYPI = 0 ) Then
    RTRN = -1 : Return :   # Pas rĂŠgularisable
  Endif

  [F:MAS1]VATRSD = LDURRES
  G_REGCOD = LREGTYP

  # Avant de faire quoi que ce soit
  # Annulation d'une ĂŠventuelle rĂŠgularisation annuelle
  Call TVA_ANNULE_PCG( FLGSIM, RTRN ) From TRTFASVATREG
  If (RTRN) Then : Return : Endif

  # ----------------------
  # DĂŠterminaton du taux dĂŠfinitif de rĂŠcupĂŠration pour le secteur
  If ([F:MAS1]TAXCOEFLG = G_OUI) Then
    LTAUXDEF = [F:MAS1]TAXCOE
  Else
    If ( [F:MAS1]AASBUS = "" ) Then
      LTAUXDEF = [F:MAS1]TAXCOE
    Else
      # RĂŠcupĂŠration des taux provisoire, dĂŠfinitif de rĂŠcupĂŠration pour le secteur
      Call GET_COE_SECTEUR
&     ([F:MAS1]CPY, [F:MAS1]AASBUS, LASJCOE, LTAUXPRO, LTAUXDEF, LTAUXDEFFLG, LERROR) From TRTFAS
      # Si erreur lors de la lecture secteur d'activite
      If ( LERROR )               Then : RTRN = 1  : Return  : Endif
      # Si le taux dĂŠfinitif n'est pas fixĂŠ pas de rĂŠgularisation
      If ( LTAUXDEFFLG <> G_OUI ) Then : RTRN = -1 : Return  : Endif
    Endif
  Endif

  # ----------------------
  # DĂŠtermination du coefficient de dĂŠduction
  Call TVA_COE_DEDUCTION ( [F:MAS1]ASJCOE, LTAUXDEF, [F:MAS1]ADMCOE, LDEDCOE ) From TRTFAS
  G_TAUX = LDEDCOE * 100.

  # Sauvegarde
  G_DEDVATAMT  =  [F:MAS1]DEDVATAMT  : # Montant TVA rĂŠcupĂŠrĂŠe (ĂŠvĂŠnement)
  G_DEDVATRAT  =  [F:MAS1]DEDVATRAT  : # Taux TVA rĂŠcupĂŠrĂŠe
  LVATYEAFLG   =  [F:MAS1]VATYEAFLG

  G_AASBUSO      = [F:MAS1]AASBUS
  G_VATREGDATO   = [F:MAS1]VATREGDAT
  G_IVCVATAMTO   = [F:MAS1]IVCVATAMT
  G_DEDVATAMTO   = [F:MAS1]DEDVATAMT
  G_ASJCOERO     = [F:MAS1]ASJCOER
  G_TAXCOERO     = [F:MAS1]TAXCOER
  G_ADMCOERO     = [F:MAS1]ADMCOER
  G_DEDCOERO     = [F:MAS1]DEDCOER
  G_ASJCOEO      = [F:MAS1]ASJCOE
  G_TAXCOEO      = [F:MAS1]TAXCOE
  G_TAXCOEFLGO   = [F:MAS1]TAXCOEFLG
  G_ADMCOEO      = [F:MAS1]ADMCOE
  G_DEDCOEO      = [F:MAS1]DEDCOE
  G_ASJCOEFO     = [F:MAS1]ASJCOEF
  G_TAXCOEFO     = [F:MAS1]TAXCOEF
  G_ADMCOEFO     = [F:MAS1]ADMCOEF
  G_DEDCOEFO     = [F:MAS1]DEDCOEF


  # RĂŠgularisation - PCG -
  # ----

  # ----0-----------------
  If ( LREGTYP = 1 or LREGTYP = 3 ) Then : # ---------              Exercice d'acquisition


    [F:MAS1]VATYEAFLG = G_OUI

    # Nouveau Taux rĂŠcup PCG
    [F:MAS1]DEDVATRAT = G_TAUX
    [F:MAS1]TAXCOE    = LTAUXDEF
    [F:MAS1]DEDCOE    = LDEDCOE


    # Nouvelle TVA rĂŠcupĂŠrĂŠe
    LMONTANT = [F:MAS1]IVCVATAMT * ( G_TAUX / 100 )
    Call GET_MNT_ARRONDI(LMONTANT, GDEVSOC(find([F:MAS1]CPY,GSOC)), LMNTCONV) From GLOBIENS
    [F:MAS1]DEDVATAMT = LMNTCONV
    [F:MAS1]DEDVATFLG = G_NON

    # Calcul du Montant TVA rĂŠgularisĂŠe
    If ([F:MAS1]ISSDAT >= GDEBEXECPF and [F:MAS1]ISSDAT <= GFINEXECPF and [F:MAS1]EXTISSFLG = G_NON) Then
      # Sortie rĂŠelle dans l'exercice d'acquisition
      G_REGUL   = ([F:MAS1]DEDVATAMT - G_DEDVATAMT) / [F:MAS1]THESLI
      LFORMULE  = "(" - format$('N:'+GFMT3, [F:MAS1]DEDVATAMT) - "-" - format$('N:'+GFMT3, G_DEDVATAMT) - ")/" - num$([F:MAS1]THESLI)
      Call GET_MNT_ARRONDI(G_REGUL , GDEVSOC(find([F:MAS1]CPY,GSOC)), G_REGUL) From GLOBIENS
    Else
      # Calcul du Montant TVA rĂŠgularisĂŠe
      G_REGUL  =  [F:MAS1]DEDVATAMT - G_DEDVATAMT
      LFORMULE  = "(" - format$('N:'+GFMT3, [F:MAS1]DEDVATAMT) - "-" - format$('N:'+GFMT3, G_DEDVATAMT) - ")"
    Endif

    # Mise Ă  jour des coefficients de rĂŠfĂŠrence futur
    If ( [F:MAS1]ASJCOEFGLO <> G_OUI ) Then : [F:MAS1]ASJCOEF = [F:MAS1]ASJCOE : Endif
    If ( [F:MAS1]TAXCOEFGLO <> G_OUI ) Then : [F:MAS1]TAXCOEF = [F:MAS1]TAXCOE : Endif
    If ( [F:MAS1]ADMCOEFGLO <> G_OUI ) Then : [F:MAS1]ADMCOEF = [F:MAS1]ADMCOE : Endif
    Call TVA_COE_DEDUCTION ( [F:MAS1]ASJCOEF, [F:MAS1]TAXCOEF, [F:MAS1]ADMCOEF, [F:MAS1]DEDCOEF ) From TRTFAS


    # ContrĂ´le ĂŠcart Taux par rapport au seuil
    If (G_REGUL < 0 ) Then
      [M:FASR]DEDVAT = 0 : [M:FASR]CRBVAT = abs(G_REGUL)             : # EvĂŠnement
      [F:MAS1]VATREGAMT = [M:FASR]CRBVAT   : [F:MAS1]VATREGDED = 0   : # Fichier
    Else
      [M:FASR]CRBVAT = 0 : [M:FASR]DEDVAT = G_REGUL                  : # EvĂŠnement
      [F:MAS1]VATREGDED  = [M:FASR]DEDVAT  : [F:MAS1]VATREGAMT = 0   : # Fichier
    Endif

    # La base est-elle Ă  mettre Ă  jour ?
    # If ( abs(G_TAUX - G_DEDVATRAT )/100 > abs(G_ECIMPBAS) ) Then : LMAJBASE = G_OUI : Else :   LMAJBASE = G_NON  :  Endif
    # FQ56815
    LMAJBASE = G_NON
    If ( LREGTYP = 3 or ( LREGTYP = 1 and abs(G_TAUX - G_DEDVATRAT )/100 > abs(G_ECIMPBAS)) ) Then : LMAJBASE = G_OUI :  Endif

    # -----------------------
    Call TVA_MAJ_PCG(  GVML_TRPRDEF, LMAJBASE, FLGSIM, LFORMULE, RTRN )
    If (RTRN) Then : Return : Endif

  Endif
  # ----0-----------------

  # ----------------------
  If ( LREGTYP = 2 ) Then : # --------------------------------              Exercice antĂŠrieur
    #-1 ---------------------
    #  Non selection des biens antĂŠrieurs Ă  l'exercice
    If ( abs( ([F:MAS1]ASJCOE*LTAUXDEF)-([F:MAS1]ASJCOER*[F:MAS1]TAXCOER) ) > G_ECVARPRO )  Then
      # Il y aura rĂŠgularisation si l'ĂŠcart en valeur absolue du produit des coef. d'ASSUJ. et de TAXATION dĂŠpasse le seuil paramĂŠtrable
      # Calcul montant de la rĂŠgularisation
      G_REGUL = ([F:MAS1]IVCVATAMT * (LDEDCOE - [F:MAS1]DEDCOER)) / [F:MAS1]THESLI
      LFORMULE  = "(" - format$('N:'+GFMT3, [F:MAS1]IVCVATAMT) - "*(" - format$('N:'+GFMT3, LDEDCOE)
      LFORMULE -= "-" - format$('N:'+GFMT3, [F:MAS1]DEDCOER) - "))/" - num$([F:MAS1]THESLI)
      Call GET_MNT_ARRONDI(G_REGUL , GDEVSOC(find([F:MAS1]CPY,GSOC)), G_REGUL) From GLOBIENS

      [F:MAS1]VATYEAFLG = G_OUI
      [F:MAS1]TAXCOE = LTAUXDEF
      [F:MAS1]DEDCOE = LDEDCOE

      If (G_REGUL < 0 ) Then
        [M:FASR]DEDVAT = 0 : [M:FASR]CRBVAT = abs(G_REGUL)    : # EvĂ¨nement
        [F:MAS1]VATREGAMT += [M:FASR]CRBVAT                   : # Fichier
      Else
        [M:FASR]CRBVAT = 0 : [M:FASR]DEDVAT = G_REGUL         : # EvĂ¨nement
        [F:MAS1]VATREGDED += [M:FASR]DEDVAT                   : # Fichier
      Endif

      Call TVA_MAJ_PCG( GVML_TRVARPR, G_IMPBASVT, FLGSIM, LFORMULE, RTRN )
      If (RTRN) Then : Return : Endif

    Endif
    #-1 ---------------------
  Endif
  # -----------------------------------------------------

  # RĂŠgularisation - IAS -
  # ----
  G_REGCOD = LREGTYPI

  # Avant de faire quoi que ce soit
  # Annulation d'une ĂŠventuelle rĂŠgularisation annuelle
  Call TVA_ANNULE_IAS( FLGSIM, RTRN ) From TRTFASVATREG
  If (RTRN) Then : Return : Endif

  G_DEDVATIASO   = [F:MAS1]DEDVATAMTI
  G_IVCVATIASO   = [F:MAS1]IVCVATAMTI

  G_DEDVATAMTI =  [F:MAS1]DEDVATAMTI : # Ancien Montant TVA rĂŠcupĂŠrĂŠe
  G_DEDVATRATI =  [F:MAS1]DEDVATRATI : # Ancien Taux TVA rĂŠcupĂŠrĂŠe


  #---------------------
  If ( LREGTYPI = 1 or LREGTYPI = 3 ) Then : # ---------------              Exercice d'acquisition

    [F:MAS1]VATYEAFLG = G_OUI

    # Taux rĂŠcup IAS hĂŠrite du taux dĂŠfinitif du secteur
    [F:MAS1]DEDVATRAT  = G_TAUX  : # NĂŠcessaire pour la trace dans le cas d'un transfert.
    [F:MAS1]DEDVATRATI = G_TAUX

    # Nouvelle TVA rĂŠcupĂŠrĂŠe
    LMONTANT = [F:MAS1]IVCVATAMTI * ( G_TAUX / 100 )
    Call GET_MNT_ARRONDI(LMONTANT, GCNXCURIAS, LMNTCONV) From GLOBIENS
    [F:MAS1]DEDVATAMTI = LMNTCONV
    [F:MAS1]DEDVATFLGI = G_NON

    If ([F:MAS1]ISSDAT >= GDEBEXECPF and [F:MAS1]ISSDAT <= GFINEXECPF and [F:MAS1]EXTISSFLG = G_NON) Then
      # Sortie rĂŠelle dans l'exercice d'acquisition
      G_REGULI   = ([F:MAS1]DEDVATAMTI - G_DEDVATAMTI) / [F:MAS1]THESLI
      LFORMULE   = "(" - format$('N:'+GFMT3, [F:MAS1]DEDVATAMTI) - "-" - format$('N:'+GFMT3, G_DEDVATAMTI) - ")/" - num$([F:MAS1]THESLI)
      Call GET_MNT_ARRONDI(G_REGULI, GCNXCURIAS, G_REGULI) From GLOBIENS
    Else
      # Calcul du nouveau Montant TVA rĂŠgularisĂŠe
      G_REGULI = [F:MAS1]DEDVATAMTI - G_DEDVATAMTI
      LFORMULE  = "(" - format$('N:'+GFMT3, [F:MAS1]DEDVATAMTI) - "-" - format$('N:'+GFMT3, G_DEDVATAMTI) - ")"
    Endif

    # ContrĂ´le ĂŠcart Taux par rapport au seuil
    # -------
    If (G_REGULI < 0 ) Then
     [M:FASR]DEDVATI = 0 : [M:FASR]CRBVATI = abs(G_REGULI)            : # EvĂŠnement
     [F:MAS1]IASVATREG  = [M:FASR]CRBVATI  : [F:MAS1]VATREGDEDI = 0   : # Fichier
    Else
     [M:FASR]CRBVATI = 0 : [M:FASR]DEDVATI = G_REGULI                 : # EvĂŠnement
     [F:MAS1]VATREGDEDI = [M:FASR]DEDVATI  : [F:MAS1]IASVATREG  = 0   : # Fichier
    Endif

    # La base est-elle Ă  mettre Ă  jour ?
    # If ( abs(G_TAUX - G_DEDVATRATI )/100 > abs(G_ECIMPBAS) ) Then : LMAJBASE = G_OUI : Else :   LMAJBASE = G_NON  :  Endif
    # FQ56815
    LMAJBASE = G_NON
    If ( LREGTYPI = 3 or (LREGTYPI = 1 and abs(G_TAUX - G_DEDVATRATI )/100 > abs(G_ECIMPBAS)) ) Then : LMAJBASE = G_OUI :  Endif

    # -----------------------
    Call TVA_MAJ_IAS( GVML_TRPRDEF, LMAJBASE, FLGSIM, "", RTRN )
    If (RTRN) Then : Return : Endif
  Endif
  #---------------------


  # ----------------------
  If ( LREGTYPI = 2 ) Then : # -------------------------------------       Exercice antĂŠrieur
    #-1 ---------------------
    # Non selection des biens antĂŠrieurs Ă  l'exercice
    If ( abs( ([F:MAS1]ASJCOE*LTAUXDEF)-([F:MAS1]ASJCOER*[F:MAS1]TAXCOER) ) > G_ECVARPRO )  Then
      # Il y a rĂŠgularisation si l'ĂŠcart en valeur absolue du produit des coef. d'ASSUJ. et de TAXATION dĂŠpasse le seuil paramĂŠtrable
      # Calcul montant de la rĂŠgularisation
      G_REGULI  = ([F:MAS1]IVCVATAMTI * (LDEDCOE - [F:MAS1]DEDCOER)) / [F:MAS1]THESLI
      LFORMULE  = "(" - format$('N:'+GFMT3, [F:MAS1]IVCVATAMTI) - "*(" - format$('N:'+GFMT3, LDEDCOE)
      LFORMULE -= "-" - format$('N:'+GFMT3, [F:MAS1]DEDCOER) - "))/" - num$([F:MAS1]THESLI)
      Call GET_MNT_ARRONDI(G_REGULI ,GCNXCURIAS, G_REGULI) From GLOBIENS

      [F:MAS1]VATYEAFLG = G_OUI
      [F:MAS1]TAXCOE = LTAUXDEF
      [F:MAS1]DEDCOE = LDEDCOE

      If (G_REGULI < 0 ) Then
        [M:FASR]DEDVATI = 0 : [M:FASR]CRBVATI = abs(G_REGULI)  : # EvĂ¨nement
        [F:MAS1]IASVATREG  += [M:FASR]CRBVATI                  : # Fichier
      Else
        [M:FASR]CRBVATI = 0 : [M:FASR]DEDVATI = G_REGULI       : # EvĂ¨nement
        [F:MAS1]VATREGDEDI += [M:FASR]DEDVATI                  : # Fichier
      Endif

      Call TVA_MAJ_IAS( GVML_TRVARPR, G_IMPBASVT, FLGSIM, LFORMULE, RTRN )
      If (RTRN) Then : Return : Endif
    Endif
    #-1 ---------------------
  Endif
  # -----------------------------------------------------

  # Edition ligne
  # Non selection des biens antĂŠrieurs Ă  l'exercice
  If (  LREGTYP = 2 and ( G_REGUL <> 0 or G_REGULI <> 0 ) ) Then
      Gosub ECR_LIGNE_VAR
  Endif

Return


#=====================================================================
$CLOS_APPL_DIRT

  If dim([V]G_AASBUSO)>0    : Kill [V]G_AASBUSO     : Endif
  If dim([V]G_ASJCOERO)>0   : Kill [V]G_ASJCOERO    : Endif
  If dim([V]G_TAXCOERO)>0   : Kill [V]G_TAXCOERO    : Endif
  If dim([V]G_ADMCOERO)>0   : Kill [V]G_ADMCOERO    : Endif
  If dim([V]G_DEDCOERO)>0   : Kill [V]G_DEDCOERO    : Endif
  If dim([V]G_ASJCOEO)>0    : Kill [V]G_ASJCOEO     : Endif
  If dim([V]G_TAXCOEO)>0    : Kill [V]G_TAXCOEO     : Endif
  If dim([V]G_TAXCOEFLGO)>0 : Kill [V]G_TAXCOEFLGO : Endif
  If dim([V]G_ADMCOEO)>0    : Kill [V]G_ADMCOEO     : Endif
  If dim([V]G_DEDCOEO)>0    : Kill [V]G_DEDCOEO     : Endif
  If dim([V]G_VATREGDATO)>0 : Kill [V]G_VATREGDATO  : Endif
  If dim([V]G_IVCVATAMTO)>0 : Kill [V]G_IVCVATAMTO  : Endif
  If dim([V]G_IVCVATIASO)>0 : Kill [V]G_IVCVATIASO  : Endif
  If dim([V]G_DEDVATAMTO)>0 : Kill [V]G_DEDVATAMTO  : Endif
  If dim([V]G_DEDVATIASO)>0 : Kill [V]G_DEDVATIASO  : Endif
  If dim([V]G_ASJCOEFO)>0   : Kill [V]G_ASJCOEFO    : Endif
  If dim([V]G_TAXCOEFO)>0   : Kill [V]G_TAXCOEFO    : Endif
  If dim([V]G_ADMCOEFO)>0   : Kill [V]G_ADMCOEFO    : Endif
  If dim([V]G_DEDCOEFO)>0   : Kill [V]G_DEDCOEFO    : Endif

Return


#=====================================================================
# Unitaire / massif : Ouverture de tables annexes avant report du contenu des tables temporaires dans les tables de donnĂŠes
$OUVR_ALIM_TABLE
Return

#=====================================================================
# Unitaire / massif : Report du contenu de la table temporaire principale dans la table de donnĂŠes principale
$TMP1_ALIM_TABLE
Return

#=====================================================================
# Unitaire / massif : Report du contenu de la table temporaire annexe dans la table de donnĂŠes annexe
$TPF1_ALIM_TABLE
Return


#PPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPP
# Traitement du ou des masques de paramĂ¨tres de l'action massive               #
# -----> PARAMETRES  FASVATREG                                                 #
#PPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPPP

#===========================================#
# Actions de contrĂ´le sur champ  FASVATREG  #
#===========================================#
#

#==============================================================#
# Traitements appelĂŠs par Gosub, Call et Func                  #
#==============================================================#
#

#===================
$OUVRE_TABLES
#===================
  # Ouverture de tables liĂŠes Ă  explorer ou Ă  mettre Ă  jour  par l'action massive
  If !(clalev([F:CNX]))   : Local File CONTEXT   [CNX]   : Endif
  If !(clalev([F:FIS]))   : Local File FISCYEAR  [FIS]   : Endif
  If !(clalev([F:DEP]))   : Local File DEPREC    [DEP]   : Endif
  If !(clalev([F:HFAS]))  : Local File FXDASSETS [HFAS]  : Endif
  If !(clalev([F:HIS]))   : Local File VATHIS    [HIS]   : Endif  : # historique RĂŠgul. TVA
Return

#==============
Subprog INIT_PLAN_AMT(PCPY)
#==============
Value Char    PCPY
Local Integer ORIBASCPFI, CURTYPCPFI, ORIBAS, I
Local Char    CURCPFI
Local Date    FIYENDCPFI, PERENDCPFI



  # Le tableau est prĂŠchargĂŠ Ă  partir des contextes pour que l'on ait pour chaque plan gĂŠrĂŠ
  # la date de dĂŠbut de l'exercice courant et de la pĂŠriode courante
  # Ces dates peuvent diffĂŠrer selon que la date de clĂ´ture de chacun des contextes.

  # Lecture contexte FISCAL & COMPTABLE
  Read [CNX] CNX0=PCPY;G300CPFI
  If (fstat) Then : Raz [F:CNX] : Endif
  ORIBASCPFI=[F:CNX]ORIBASDPR(G301CPT-1)
  CURCPFI   =[F:CNX]CUR
  CURTYPCPFI=[F:CNX]CURTYP
  # Lecture exercice courant FISCAL & COMPTABLE
  Filter [FIS] Where CPY=PCPY and CNX = G300CPFI and STAFIY = GVML_TECOURA
  Read [FIS]First
  If (fstat) Then : Raz [F:FIS] : Endif
  Filter [FIS]
  FIYENDCPFI =[F:FIS]DATENDFIY
  PERENDCPFI =[F:FIS]DATENDPER([F:FIS]INDCURPER-1)

  nolign = 1
  # ====================
  For [CNX] Where CPY =PCPY
    # =============
    For I = 0 To [F:CNX]NBPLC-1
      [M:FASR]DPRPLN(nolign-1) = [F:CNX]PLNCAA(I)

      If ([F:CNX]PLNCAA(I)= G301CPT or [F:CNX]PLNCAA(I)= G301FIS or
&         [F:CNX]PLNCAA(I)= G301MIN or [F:CNX]PLNCAA(I)= G301SUB ) Then
        [M:FASR]ORIBAS(nolign-1)     = ORIBASCPFI
        [M:FASR]CUR(nolign-1)        = CURCPFI
        [M:FASR]CURTYP(nolign-1)     = CURTYPCPFI
        [M:FASR]FIYENDDAT(nolign-1)  = FIYENDCPFI
        [M:FASR]PERENDDAT(nolign-1)  = PERENDCPFI
      Else
        # Pas de rĂŠgularisation TVA IAS/IFRS si le plan IAS est rattachĂŠ Ă  un contexte autre que Comptable & Fiscal
        [M:FASR]ORIBAS(nolign-1)    =[F:CNX]ORIBASDPR(I)
        [M:FASR]CUR(nolign-1)       =[F:CNX]CUR
        [M:FASR]CURTYP(nolign-1)    =[F:CNX]CURTYP
        Filter [FIS] Where CPY=PCPY and CNX = [F:CNX]CNX and STAFIY = GVML_TECOURA
        Read [FIS]First
        If (fstat) Then : Raz [F:FIS] : Endif
        Filter [FIS]
        [M:FASR]FIYENDDAT(nolign-1) = [F:FIS]DATENDFIY
        [M:FASR]PERENDDAT(nolign-1) = [F:FIS]DATENDPER([F:FIS]INDCURPER-1)
      Endif
      nolign += 1
    Next I
    # =============
  Next
  # ====================

  [M:FASR]NBLIG1 = nolign-1

End





