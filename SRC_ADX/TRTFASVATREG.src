##FQ57157-GBN-Ajout contrĂ´le des valeurs paramĂ¨tres REGBASDEV et REGVATDEV
#=====================================================================
$CONT_PARM
Local Integer ICPY
Local Char    LCPY
ICPY=find(G_OUI,[M:MHC]FLGCPY)
If ICPY
 LCPY=[M:MHC]CPY(ICPY-1)
 Local Char    LMESS(254)
 Local Decimal LREGBASDEV, LREGVATDEV
 Call PARAM(LCPY,"REGBASDEV",PARAM) From ADOVAL : LREGBASDEV=val(PARAM)
 Call PARAM(LCPY,"REGVATDEV",PARAM) From ADOVAL : LREGVATDEV=val(PARAM)
 If LREGBASDEV<0 | LREGBASDEV>1 | LREGVATDEV<0 | LREGVATDEV>1
  GMESSAGE="La valeur des paramĂ¨tres REGBASDEV et REGVATDEV du chapitre AAS doit ĂŞtre comprise entre 0 et 1"+"\"+"(REGBASDEV="+num$(LREGBASDEV)-"/"-"REGVATDEV="+num$(LREGVATDEV)+")"
  GERR    = 1
  FIN     = 1
 Endif
Endif
Return

#=====================================================================
Subprog LAUNCH_ACT(PACTTYP)
Value Char PACTTYP

 Case PACTTYP
   When GTAMUNI
     Infbox mess(1,GML_MSGACT,1)
   When GTAMMAS
     Local Char PARAM(30)(1..5)
     Local Char VALEUR
     PARAM(1)=GTAMMAS            # Massif / unitaire
     PARAM(2)="FASVATREG"        # Nom de l'action mĂŠtier
     PARAM(3)=num$(GVML_OMBIEN)  # Objet mĂŠtier de rĂŠfĂŠrence
     PARAM(4)=num$(G_OUI)        # Mono sociĂŠtĂŠ
     PARAM(5)=num$(G_OUI)        # Plan d'amortissement
     #  Traitement      FenĂŞtre
     Call TRAITE_CHAR(VALEUR,PARAM,"","TRTFASVATREG","FASVATREG",4,"") From GTRAITE
   When Default
  Endcase
End



#
#########################################################
Subprog TVA_MAJ_PCG( PTYPREG, PMAJBAS, PFLGSIM, PFORMULE, RERROR )
# - Objet  : Mise Ă  jour
#
#               Nouvelles rĂ¨gles TVA
#
# - EntrĂŠe    :
#               PREGTVA     RĂŠgularisation TVA
#               PMAJBAS     Mise Ă  jour des base
#               PFLGSIM     Indicateur traitement simulĂŠ
#
# - Sortie    : RERROR
#                   3 Erreur de conversion
#                   4 Erreur gĂŠnĂŠration ĂŠvĂŠnement
#
# - ParamĂ¨tres en variables globales :
#
#               G_REGUL
#               G_REGCOD
#

Value    Integer PTYPREG
Value    Integer PMAJBAS
Value    Integer PFLGSIM
Value    Char    PFORMULE
Variable Integer RERROR

Local Integer STAT
Local Decimal MTDES, MNTDES2
Local Integer LCDRET
Local Char    LMESSAGE

Local Decimal SBSEVAL
Local Decimal SDPRBAS
Local Integer L_CPT

Local Integer B_MAJBAS
  B_MAJBAS = 0

  # Si la rĂŠgularisation est ĂŠgale Ă  0. On sort (n fois la mĂŞme variation dans le temps)
  If ( G_REGUL = 0 ) Then : End : Endif

  # Actualisation informations du bien comptable
  #-0 ---------------------------
  If ( PMAJBAS = G_OUI ) Then
    Case PTYPREG
      When GVML_TRPRDEF
        # Fixation du prorata dĂŠfinitif : Mise Ă  jour Base selon la TVA rĂŠcupĂŠrĂŠe initialement
        [F:MAS1]GALREFBAS  = [F:MAS1]ACGETRNOT + [F:MAS1]IVCVATAMT - [F:MAS1]DEDVATAMT
        [F:MAS1]TAXBAS     = [F:MAS1]ACGETRNOT + [F:MAS1]IVCVATAMT - [F:MAS1]DEDVATAMT
      When GVML_TRVARPR
        # Variation de prorata dans le temps : Mise Ă  jour des bases  avec la rĂŠgularisation
        [F:MAS1]GALREFBAS -= G_REGUL
        [F:MAS1]TAXBAS    -= G_REGUL
      When Default
    Endcase
  Endif
  #-0 ---------------------------

  # Mise Ă  jour des bases avec l'ĂŠcart selon oribas PCG (avec conversion ĂŠventuelle)
  If clalev([F:DEPX])=0  : Local File DEPREC [DEPX] : Endif

  L_CPT = find(G301CPT, [M:FASR]DPRPLN)
  Read [DEPX] DEP0=[F:MAS1]AASREF;[M:FASR]DPRPLN(L_CPT-1);
&                  [M:FASR]FIYENDDAT(L_CPT-1);[M:FASR]PERENDDAT(L_CPT-1)
  # Sauvegarde Bases d'amortissement comptable
  SBSEVAL = [F:DEPX]BSEVAL
  SDPRBAS = [F:DEPX]DPRBAS

  #>0 >>>>>>>>>>>>>>>>>>>>>>>>>>>
  For nolign = 1 To [M:FASR]NBLIG1
    #----1-------------------
    If ( [M:FASR]ORIBAS(nolign-1) = GVML_OBPCG  and [M:FASR]DPRPLN(nolign-1) <> G301SUB ) Then
      Read [DEPX] DEP0=[F:MAS1]AASREF;[M:FASR]DPRPLN(nolign-1);
&                      [M:FASR]FIYENDDAT(nolign-1);[M:FASR]PERENDDAT(nolign-1)
      If (PMAJBAS = G_OUI) Then
        B_MAJBAS = 0
        Case PTYPREG
          When GVML_TRPRDEF
            # Exercice d'acquisition
            B_MAJBAS       = 1
            [F:DEPX]BSEVAL = [F:MAS1]ACGETRNOT + [F:MAS1]IVCVATAMT - [F:MAS1]DEDVATAMT
            [F:DEPX]DPRBAS = [F:MAS1]ACGETRNOT + [F:MAS1]IVCVATAMT - [F:MAS1]DEDVATAMT
            # Conversion ĂŠventuelle dans la devise du plan
            If ([M:FASR]CUR(nolign-1) <> GCNXCURCPF) Then
              Call CONVERT3(GCNXCURCPF,[M:FASR]CUR(nolign-1), GDEVSOC(find([F:MAS1]CPY,GSOC)),
&             [M:FASR]CURTYP(nolign-1),[F:MAS1]PURDAT,[F:DEPX]BSEVAL,MTDES,[F:DEPX]RATCUR,STAT) From CPTSUB
              If (STAT = 0) Then
                Call GET_MNT_ARRONDI (MTDES, [M:FASR]CUR(nolign-1), MTDES) From GLOBIENS
                [F:DEPX]BSEVAL = MTDES
                [F:DEPX]DPRBAS = MTDES
              Else
                RERROR = 3 : End : # Erreur conversion
              Endif
            Endif
          When GVML_TRVARPR
            # Variation du prorata dans le temps
            If ( [M:FASR]CUR   (L_CPT-1) = [M:FASR]CUR   (nolign-1) and
&                [F:DEPX]BSEVAL = SBSEVAL  and
&                [F:DEPX]DPRBAS = SDPRBAS  ) Then
              B_MAJBAS        = 1
              [F:DEPX]BSEVAL -= G_REGUL
              [F:DEPX]DPRBAS -= G_REGUL
            Endif
          When Default
        Endcase
      Endif

      # FQ54343
      If ( B_MAJBAS ) Then
        If (  G_ACTCCN = G_OUI and G_CCNRPR = G_OUI and [F:MAS1]OWNTYP = GVML_TDCONCE and [F:DEPX]DPRPLN = G_CCNPLNCAD ) Then
          # Pas de mise Ă  jour de la base du plan gĂŠrant la caducitĂŠ lorsque transmis par renouvellement.
          B_MAJBAS = 0
        Endif
      Endif

      # Mise Ă  jour
      #----2-------------------
      If ( PFLGSIM = G_NON ) Then
        If ( PMAJBAS = G_OUI and B_MAJBAS ) Then
          [F:DEPX]DEPSTA                   = GVML_SCNOCAL
          [F:MAS1]FLGCLC                   = G_OUI
          [F:MAS1]FLGCNXCLC([F:DEPX]CNX-1) = G_OUI
          Rewrite [DEPX]
          If (fstat) Then : RTRN = 2 : End : Endif
        Endif
        # GĂŠnĂŠration ĂŠvĂŠnement de rĂŠgularisation de TVA pour le plan comptable
        If ( [F:DEPX]DPRPLN = G301CPT  ) Then
          If ( PMAJBAS = G_OUI and B_MAJBAS ) Then
            G_BASDEV = [F:DEPX]DPRBAS - SDPRBAS
          Else
            G_BASDEV = 0.
          Endif
          LCDINT= "FASVATREG1"
          Call GENER_EVE (GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,
&                         [F:MAS1]AASREF,0,LCDINT, G_FINPERCPF,[0/0/0],LCDRET) From GENEVE
          If (LCDRET > 20 ) Then : RERROR = 4 : End : Endif :   # Erreur ĂŠcriture gĂŠnĂŠration ĂŠvĂ¨nement
          # Ecriture dans HISVAT ( PCG )
          [F:HFAS] = [F:MAS1]
          [F:HFAS]VATREGDAT = G_FINPERCPF
          If (G_REGTRF) Then
            MNTDES = G_DPRBASO : MNTDES2 = G_DPRBASO       : G_BASDEV = 0
          Else
            MNTDES = SBSEVAL   : MNTDES2 = [F:DEPX]BSEVAL
          Endif
          Call TVA_ECR_HISTORIQUE (PTYPREG, G301CPT, MNTDES, MNTDES2, PFORMULE, LCDRET) From TRTFAS
          If (LCDRET) Then : RERROR = 8 : End : Endif :   # Erreur ĂŠcriture dans l'historique
        Endif
      Endif
      #----2-------------------
      # Trace
      #----2-------------------
      If ( [F:DEPX]DPRPLN = G301CPT ) Then
        If ( G_REGCOD = 1) Then
          LTRCTYP = GTRC_CRACTIO
          Gosub ECR_LIGNE
        Elsif ( G_REGCOD = 3 ) Then
          LTRCTYP = GTRC_CRACT1
          Gosub ECR_LIGNE
        Endif
      Endif
      #----2-------------------
    Endif
    #----1-------------------
  Next nolign
  #<0 <<<<<<<<<<<<<<<<<<<

End



#
#########################################################
Subprog TVA_MAJ_IAS( PTYPREG, PMAJBAS, PFLGSIM, PFORMULE, RERROR )
# - Objet  : Mise Ă  jour
#
#               Nouvelles rĂ¨gles TVA
#
# - EntrĂŠe    :
#               PTYPREG     Type de rĂŠgularisation TVA
#               PREGTVA     RĂŠgularisation TVA
#               PMAJBAS     Mise Ă  jour des base
#               PFLGSIM     Indicateur traitement simulĂŠ
#
# - Sortie    : RERROR
#                   3 Erreur de conversion
#                   4 Erreur gĂŠnĂŠration ĂŠvĂŠnement
#
# - PrĂŠrequis : Ce sous-programme utilise la classe [F:MAS1] qui doit ĂŞtre ouverte et alimentĂŠe
#

Value    Integer PTYPREG
Value    Integer PMAJBAS
Value    Integer PFLGSIM
Value    Char    PFORMULE
Variable Integer RERROR

Local Integer STAT
Local Decimal MTDES, MNTDES2
Local Integer LCDRET
Local Char    LMESSAGE

Local Decimal SBSEVALI
Local Decimal SDPRBASI
Local Integer L_IAS

Local Integer B_MAJBAS
  B_MAJBAS = 0

  # Si la rĂŠgularisation est ĂŠgale Ă  0. On sort (n fois la mĂŞme variation dans le temps)
  If ( G_REGULI = 0 ) Then : End : Endif

  # Actualisation informations du bien comptable
  #-0 ---------------------------
  If ( PMAJBAS = G_OUI ) Then
    Case PTYPREG
      When GVML_TRPRDEF
        # Fixation du prorata dĂŠfinitif : Mise Ă  jour Base selon la TVA rĂŠcupĂŠrĂŠe initialement
      When GVML_TRVARPR
        # Variation de prorata dans le temps : Mise Ă  jour des bases  avec la rĂŠgularisation
      When Default
    Endcase
  Endif
  #-0 ---------------------------

  # Mise Ă  jour des bases avec l'ĂŠcart selon oribas PCG (avec conversion ĂŠventuelle)
  If clalev([F:DEPX])=0  : Local File DEPREC [DEPX] : Endif
  # Lecture plan IAS
  L_IAS = find(G301IAS, [M:FASR]DPRPLN)
  Read [DEPX] DEP0=[F:MAS1]AASREF;[M:FASR]DPRPLN(L_IAS-1);
&                  [M:FASR]FIYENDDAT(L_IAS-1);[M:FASR]PERENDDAT(L_IAS-1)
  # Sauvegarde Bases d'amortissement comptable
  SBSEVALI = [F:DEPX]BSEVAL
  SDPRBASI = [F:DEPX]DPRBAS



  #>0 >>>>>>>>>>>>>>>>>>>>>>>>>>>
  For nolign = 1 To [M:FASR]NBLIG1
    #----1-------------------
    If ( [M:FASR]ORIBAS(nolign-1) = GVML_OBIAS  and [M:FASR]DPRPLN(nolign-1) <> G301SUB ) Then
      Read [DEPX] DEP0=[F:MAS1]AASREF;[M:FASR]DPRPLN(nolign-1);
&                      [M:FASR]FIYENDDAT(nolign-1);[M:FASR]PERENDDAT(nolign-1)
      #----2-------------------
      If (PMAJBAS = G_OUI) Then
        B_MAJBAS = 0
        Case PTYPREG
          When GVML_TRPRDEF
            # Exercice d'acquisition
            B_MAJBAS       = 1
            [F:DEPX]BSEVAL = [F:MAS1]IASETRNOT + [F:MAS1]IVCVATAMTI - [F:MAS1]DEDVATAMTI
            [F:DEPX]DPRBAS = [F:MAS1]IASETRNOT + [F:MAS1]IVCVATAMTI - [F:MAS1]DEDVATAMTI
            # Conversion ĂÂŠventuelle dans la devise du plan
            If ( [M:FASR]CUR(nolign-1) <> GCNXCURIAS ) Then
              Call CONVERT3(GCNXCURIAS, [M:FASR]CUR(nolign-1), GCNXCURIAS, [M:FASR]CURTYP(nolign-1),
&                           [F:MAS1]PURDAT, [F:DEPX]BSEVAL, MTDES, [F:DEPX]RATCUR, STAT) From CPTSUB
              If STAT = 0 Then
                Call GET_MNT_ARRONDI (MTDES, [M:FASR]CUR(nolign-1), MTDES) From GLOBIENS
                [F:DEPX]BSEVAL = MTDES
                [F:DEPX]DPRBAS = MTDES
              Else
                RTRN = 3 : Return :   # Erreur conversion
              Endif
            Endif
          When GVML_TRVARPR
            # Variation du prorata dans le temps
            If ( [M:FASR]CUR   (L_IAS-1) = [M:FASR]CUR   (nolign-1) and
&                [F:DEPX]BSEVAL = SBSEVALI  and
&                [F:DEPX]DPRBAS = SDPRBASI  ) Then
              B_MAJBAS        = 1
              [F:DEPX]BSEVAL -= G_REGULI
              [F:DEPX]DPRBAS -= G_REGULI
            Endif
          When Default
        Endcase
      Endif

      # FQ54343
      If ( B_MAJBAS ) Then
        If (  G_ACTCCN = G_OUI and G_CCNRPR = G_OUI and [F:MAS1]OWNTYP = GVML_TDCONCE and [F:DEPX]DPRPLN = G_CCNPLNCAD ) Then
          # Pas de mise Ă  jour de la base du plan gĂŠrant la caducitĂŠ lorsque transmis par renouvellement.
          B_MAJBAS = 0
        Endif
      Endif

      #----2-------------------
      # Mise Ă  jour
      #----2-------------------
      If ( PFLGSIM = G_NON ) Then
        If ( PMAJBAS = G_OUI and B_MAJBAS ) Then
          [F:DEPX]DEPSTA                   = GVML_SCNOCAL
          [F:MAS1]FLGCLC                   = G_OUI
          [F:MAS1]FLGCNXCLC([F:DEPX]CNX-1) = G_OUI
          Rewrite [DEPX]
          If (fstat) Then : RTRN = 2 : End : Endif
        Endif
        # GĂŠnĂŠration ĂŠvĂŠnement de rĂŠgularisation de TVA pour le plan IAS
        If ( [F:DEPX]DPRPLN = G301IAS  ) Then
          If ( PMAJBAS = G_OUI and B_MAJBAS ) Then
            G_BASDEV = [F:DEPX]DPRBAS - SDPRBASI
          Else
            G_BASDEV = 0.
          Endif
          LCDINT= "FASVATREG6"
          Call GENER_EVE (GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,
&                         [F:MAS1]AASREF,0,LCDINT,G_FINPERIAS,[0/0/0],LCDRET) From GENEVE
          If (LCDRET > 20 ) Then : RERROR = 4 : End : Endif :   # Erreur ĂŠcriture gĂŠnĂŠration ĂŠvĂ¨nement
          # Ecriture dans HISVAT ( IAS )
          [F:HFAS] = [F:MAS1]
          [F:HFAS]VATREGDAT = G_FINPERIAS
          If (G_REGTRF) Then
            MNTDES = G_DPRBASIO : MNTDES2 = G_DPRBASIO       : G_BASDEV = 0
          Else
            MNTDES = SBSEVALI   : MNTDES2 = [F:DEPX]BSEVAL
          Endif
          Call TVA_ECR_HISTORIQUE (PTYPREG, G301IAS, MNTDES, [F:DEPX]BSEVAL, PFORMULE, LCDRET) From TRTFAS
          If (LCDRET) Then : RERROR = 8 : End : Endif :   # Erreur ĂŠcriture dans l'historique
        Endif
      Endif
      #----2-------------------
      # Trace
      #----2-------------------
      If ( [F:DEPX]DPRPLN = G301IAS ) Then
        If ( G_REGCOD = 1) Then
          LTRCTYP = GTRC_CRACTIO
          Gosub ECR_LIGNE
        Elsif ( G_REGCOD = 3 ) Then
          LTRCTYP = GTRC_CRACT1
          Gosub ECR_LIGNE
        Endif
      Endif
      #----2-------------------
    Endif
    #----1-------------------
  Next nolign
  #<0 <<<<<<<<<<<<<<<<<<<

End

#
#########################################################
Subprog TVA_ANNULE_PCG( PFLGSIM,  RERROR )
# - Objet  : Mise Ă  jour
#
#               Nouvelles rĂ¨gles TVA
#
# - EntrĂŠe    :
#               PREGTVA     RĂŠgularisation TVA
#               PFLGSIM     Indicateur traitement simulĂŠ
#
# - Sortie    : RERROR
#                   3 Erreur de conversion
#                   4 Erreur gĂŠnĂŠration ĂŠvĂŠnement
#
# - PrĂŠrequis : Ce sous-programme utilise
#               la classe [F:MAS1] qui doit ĂŞtre ouverte et alimentĂŠe
#


Value    Integer PFLGSIM
Variable Integer RERROR

Local Integer STAT
Local Decimal MTDES
Local Integer LCDRET
Local Char    LMESSAGE

Local Decimal SBSEVAL
Local Decimal SDPRBAS
Local Integer LTYPREG
Local Integer L_CPT

Local Integer B_ANNBAS
Local Integer B_MAJBAS
Local Decimal SREGUL
Local Char    LTIMSTP1
Local Char    LTIMSTP2



  # Sauvegarde G_REGUL
  SREGUL = G_REGUL

  # Recherche d'une ĂŠventuelle rĂŠgularisation annuelle Ă  annuler
  If clalev([F:HIS]) = 0  : Local File VATHIS [HIS] : Endif

  If ( G_REGCOD = 1 or G_REGCOD = 3 ) Then
    # Recherche de la derniĂ¨re annulation rĂŠgularisation annuelle dans l'exercice (Fixation dĂŠfinitif)
    Filter [HIS] Where AASREF=[F:MAS1]AASREF and DPRPLN = G301CPT and VATREGTYP = GVML_TRANDEF and AASBUS = [F:MAS1]AASBUS and
&                    DATVATREG >= GDEBEXECPF and DATVATREG <= GFINEXECPF
    If (rowcount([F:HIS]) <> 0 ) Then
      Read [HIS]VAT1 Last
      Filter [HIS]   : LTIMSTP1 = [F:HIS]TIMSTP
    Else
      Filter [HIS]   : LTIMSTP1 = ""
    Endif

    # Recherche d'une ĂŠventuelle rĂŠgularisation annuelle dans l'exercice (Fixation dĂŠfinitif)
    Filter [HIS] Where AASREF=[F:MAS1]AASREF and DPRPLN = G301CPT and VATREGTYP = GVML_TRPRDEF and  AASBUS = [F:MAS1]AASBUS and
&                      DATVATREG >= GDEBEXECPF and DATVATREG <= GFINEXECPF
    If (rowcount([F:HIS]) <> 0 ) Then
      Read [HIS]VAT1 Last
      Filter [HIS]  : LTIMSTP2 = [F:HIS]TIMSTP
    Else
      Filter [HIS]  : LTIMSTP2 = ""
    Endif
  Endif

  If ( G_REGCOD = 2 ) Then
    # Recherche de la derniĂ¨re annulation rĂŠgularisation annuelle dans l'exercice (Variation dans le temps)
    Filter [HIS] Where AASREF=[F:MAS1]AASREF and DPRPLN = G301CPT and VATREGTYP = GVML_TRANVAR  and AASBUS = [F:MAS1]AASBUS and
&                    DATVATREG >= GDEBEXECPF and DATVATREG <= GFINEXECPF
    If (rowcount([F:HIS]) <> 0 ) Then
      Read [HIS]VAT1 Last
      Filter [HIS] : LTIMSTP1 = [F:HIS]TIMSTP
    Else
      Filter [HIS] : LTIMSTP1 = ""
    Endif
    # Recherche de la derniĂ¨re rĂŠgularisation annuelle dans l'exercice (variation dans le temps)
    Filter [HIS] Where AASREF=[F:MAS1]AASREF and DPRPLN = G301CPT and VATREGTYP = GVML_TRVARPR  and AASBUS = [F:MAS1]AASBUS and
&                      DATVATREG >= GDEBEXECPF and DATVATREG <= GFINEXECPF
    If (rowcount([F:HIS]) <> 0 ) Then
      Read [HIS]VAT1 Last
      Filter [HIS]  : LTIMSTP2 = [F:HIS]TIMSTP
    Else
      Filter [HIS]  : LTIMSTP2 = ""
    Endif
  Endif

  # Pas d'annulation de rĂŠgularisation a effectuĂŠ
  If ( LTIMSTP1 > LTIMSTP2 or ( LTIMSTP1 = "" and LTIMSTP2 = "" ) ) Then : End : Endif

  # Annulation rĂŠgularisation

  If ( [F:HIS]VATREGAMT <> 0 ) Then
    G_REGUL = [F:HIS]VATREGAMT
    [F:MAS1]VATREGAMT -= [F:HIS]VATREGAMT
  Else
    G_REGUL = -[F:HIS]VATREGDED
    [F:MAS1]VATREGDED -= [F:HIS]VATREGDED
  Endif

  # Cette rĂŠgularisation ayant fait l'objet d'une mise Ă  jour de base elle doit ĂŞtre annulĂŠe
  If ([F:HIS]BASDEV <> 0 ) Then : B_ANNBAS = 1 : Else :  B_ANNBAS = 0 : Endif

  # DĂŠtermination type rĂŠgularisation
  If ( G_REGCOD = 1 or G_REGCOD = 3) Then
    # Annulation Fixation coefficient de dĂŠduction dĂŠfinitif :
    LTYPREG = GVML_TRANDEF

    [F:MAS1]AASBUS     = [F:HIS]AASBUSO
    [F:MAS1]VATREGDAT  = [F:HIS]VATREGDATO
    [F:MAS1]IVCVATAMT  = [F:HIS]IVCVATAMTO
    [F:MAS1]DEDVATRAT  = [F:HIS]DEDCOEO * 100
    [F:MAS1]DEDVATAMT  = [F:HIS]DEDVATAMTO

    [F:MAS1]ASJCOER   = [F:HIS]ASJCOERO
    [F:MAS1]TAXCOER   = [F:HIS]TAXCOERO
    [F:MAS1]ADMCOER   = [F:HIS]ADMCOERO
    [F:MAS1]DEDCOER   = [F:HIS]DEDCOERO
    [F:MAS1]ASJCOE    = [F:HIS]ASJCOEO
    [F:MAS1]TAXCOE    = [F:HIS]TAXCOEO
    [F:MAS1]TAXCOEFLG = [F:HIS]TAXCOEFLGO
    [F:MAS1]ADMCOE    = [F:HIS]ADMCOEO
    [F:MAS1]DEDCOE    = [F:HIS]DEDCOEO
    [F:MAS1]ASJCOEF   = [F:HIS]ASJCOEFO
    [F:MAS1]TAXCOEF   = [F:HIS]TAXCOEFO
    [F:MAS1]ADMCOEF   = [F:HIS]ADMCOEFO
    [F:MAS1]DEDCOEF   = [F:HIS]DEDCOEFO

  Endif
  If ( G_REGCOD = 2 ) Then
    # Variation de prorata dans le temps : Mise Ă  jour des bases  avec la rĂŠgularisation
    LTYPREG = GVML_TRANVAR
  Endif

  # Actualisation informations du bien comptable
  If ( B_ANNBAS ) Then
       # Mise Ă  jour des bases avec la rĂŠgularisation
      [F:MAS1]GALREFBAS -= G_REGUL
      [F:MAS1]TAXBAS    -= G_REGUL
  Endif

  # Mise Ă  jour des bases avec l'ĂŠcart selon oribas PCG (avec conversion ĂŠventuelle)
  If clalev([F:DEPX])=0  : Local File DEPREC [DEPX] : Endif
  L_CPT = find(G301CPT, [M:FASR]DPRPLN)
  Read [DEPX] DEP0=[F:MAS1]AASREF;[M:FASR]DPRPLN(L_CPT-1);
&                  [M:FASR]FIYENDDAT(L_CPT-1);[M:FASR]PERENDDAT(L_CPT-1)
  # Sauvegarde Bases d'amortissement comptable
  SBSEVAL = [F:DEPX]BSEVAL
  SDPRBAS = [F:DEPX]DPRBAS
  #>0 >>>>>>>>>>>>>>>>>>>>>>>>>>>
  For nolign = 1 To [M:FASR]NBLIG1
    #----1-------------------
    If ( [M:FASR]ORIBAS(nolign-1) = GVML_OBPCG  and [M:FASR]DPRPLN(nolign-1) <> G301SUB ) Then
      B_MAJBAS = 0
      Read [DEPX] DEP0=[F:MAS1]AASREF;[M:FASR]DPRPLN(nolign-1);
&                      [M:FASR]FIYENDDAT(nolign-1);[M:FASR]PERENDDAT(nolign-1)
      #----2-------------------
      If (B_ANNBAS) Then
        # Variation du prorata dans le temps
        If ( [M:FASR]CUR(L_CPT-1) = [M:FASR]CUR(nolign-1) and [F:DEPX]BSEVAL = SBSEVAL  and
&            [F:DEPX]DPRBAS = SDPRBAS  ) Then
          B_MAJBAS        = 1
          [F:DEPX]BSEVAL -= G_REGUL
          [F:DEPX]DPRBAS -= G_REGUL
        Endif
      Endif
      #----2-------------------
      # Mise Ă  jour
      #----2-------------------
      If ( PFLGSIM = G_NON ) Then
        If ( B_ANNBAS and B_MAJBAS ) Then
          [F:DEPX]DEPSTA                   = GVML_SCNOCAL
          [F:MAS1]FLGCLC                   = G_OUI
          [F:MAS1]FLGCNXCLC([F:DEPX]CNX-1) = G_OUI
          Rewrite [DEPX]
          If (fstat) Then : RERROR = 2 : End : Endif : # Erreur eĂŠcriture DEPREC
        Endif
        # Extourne ĂŠvĂŠnement de rĂŠgularisation annuelle de TVA pour le plan comptable
        If ( [F:DEPX]DPRPLN = G301CPT  ) Then
          # FQ57635
#         If clalev([F:EVT0]) =0 : Local File EVEFAS    [EVT0]  : Endif
          If clalev([F:EVT0]) =0 : Local File EFASVATREG    [EVT0]  : Endif
          LCDINT= "FASVATREG1"
#         Filter [F:EVT0] Where CPY=[F:MAS1]CPY and EVT="FASVATREG" and PLN=G301CPT and
#&                              REF=[F:MAS1]AASREF and EVTDAT=[F:HIS]DATVATREG and SNSEVE <> GVML_TEAACT
          Filter [F:EVT0] Where CPY=[F:MAS1]CPY and EVTINT="FASVATREG1" and DPRPLN=G301CPT and
&                               REF=[F:MAS1]AASREF and EVTDAT=[F:HIS]DATVATREG and SNSEVE <> GVML_TEAACT
          If (rowcount([F:EVT0]) <> 0) Then
#           Filter [F:EVT0]
#           Read [F:EVT0]EFS0 Last
            Read [F:EVT0]EVE0 Last
            Filter [F:EVT0]
            Call EXTOURNE_EVE(GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,0,LCDINT,
&                            [F:HIS]DATVATREG,LCDRET) From GENEVE
            If (LCDRET ) Then : RERROR = 4 : End : Endif :   # Erreur annulation ĂŠvĂ¨nement
          Else
            Filter [F:EVT0]
          Endif
          # Ecriture dans HISVAT ( PCG )
          [F:HIS]VATREGTYP =  LTYPREG
          [F:HIS]VATREGAMT = -[F:HIS]VATREGAMT
          [F:HIS]VATREGDED = -[F:HIS]VATREGDED
          [F:HIS]FORMULE   = ""
          [F:HIS]TIMSTP    = func GENEVE.BUILD_TIMSTP(date$, time)
          [F:HIS]DPRBAS    -= [F:HIS]BASDEV
          [F:HIS]BASDEV    = -[F:HIS]BASDEV
          Write [HIS]
          If (fstat) Then : RERROR = 8 : End : Endif :   # Erreur ĂŠcriture dans l'historique
        Endif
      Endif
      #----2-------------------
    Endif
    #----1-------------------
  Next nolign
  #<0 <<<<<<<<<<<<<<<<<<<

  # Restauration G_REGUL
  G_REGUL = SREGUL

End

#
#########################################################
Subprog TVA_ANNULE_IAS( PFLGSIM, RERROR )
# - Objet  : Mise Ă  jour
#
#               Nouvelles rĂ¨gles TVA
#
# - EntrĂŠe    :
#               PREGTVA     RĂŠgularisation TVA
#               PFLGSIM     Indicateur traitement simulĂŠ
#
# - Sortie    : RERROR
#                   3 Erreur de conversion
#                   4 Erreur gĂŠnĂŠration ĂŠvĂŠnement
#
# - PrĂŠrequis : Ce sous-programme utilise
#               la classe [F:MAS1] qui doit ĂŞtre ouverte et alimentĂŠe
#

Value    Integer PFLGSIM
Variable Integer RERROR

Local Integer STAT
Local Decimal MTDES
Local Integer LCDRET
Local Char    LMESSAGE

Local Decimal SBSEVALI
Local Decimal SDPRBASI
Local Integer LTYPREG
Local Integer L_IAS

Local Integer B_ANNBAS
Local Integer B_MAJBAS

Local Decimal SREGULI
Local Char    LTIMSTP1
Local Char    LTIMSTP2

  # Sauvegarde G_REGULI
  SREGULI = G_REGULI
  # Recherche d'une ĂŠventuelle rĂŠgularisation annuelle Ă  annuler
  If clalev([F:HIS]) = 0  : Local File VATHIS [HIS] : Endif

  If ( G_REGCOD = 1 or G_REGCOD = 3 ) Then
    # Recherche de la derniĂ¨re annulation rĂŠgularisation annuelle dans l'exercice (Fixation dĂŠfinitif)
    If clalev([F:HIS])=0  : Local File VATHIS [HIS] : Endif
    Filter [HIS] Where AASREF=[F:MAS1]AASREF and DPRPLN = G301IAS and VATREGTYP = GVML_TRANDEF and AASBUS = [F:MAS1]AASBUS and
&                    DATVATREG >= GDEBEXEIAS and DATVATREG <= GFINEXEIAS
    If (rowcount([F:HIS]) <> 0 ) Then
      Read [HIS]VAT1 Last
      Filter [HIS]  : LTIMSTP1 = [F:HIS]TIMSTP
    Else
      Filter [HIS]  : LTIMSTP1 = ""
    Endif

    # Recherche d'une ĂŠventuelle rĂŠgularisation annuelle dans l'exercice (Fixation dĂŠfinitif)
    If clalev([F:HIS])=0  : Local File VATHIS [HIS] : Endif
    Filter [HIS] Where AASREF=[F:MAS1]AASREF and DPRPLN = G301IAS and VATREGTYP = GVML_TRPRDEF and AASBUS = [F:MAS1]AASBUS and
&                      DATVATREG >= GDEBEXEIAS and DATVATREG <= GFINEXEIAS
    If (rowcount([F:HIS]) <> 0 ) Then
      Read [HIS]VAT1 Last
      Filter [HIS]  : LTIMSTP2 = [F:HIS]TIMSTP
    Else
      Filter [HIS]  : LTIMSTP2 = ""
    Endif
  Endif


  If ( G_REGCOD = 2 ) Then
    # Recherche de la derniĂ¨re annulation rĂŠgularisation annuelle dans l'exercice (variation dans le temps)
    Filter [HIS] Where AASREF=[F:MAS1]AASREF and DPRPLN = G301IAS and VATREGTYP = GVML_TRANVAR and AASBUS = [F:MAS1]AASBUS and
&                    DATVATREG >= GDEBEXEIAS and DATVATREG <= GFINEXEIAS
    If (rowcount([F:HIS]) <> 0 ) Then
      Read [HIS]VAT1 Last
      Filter [HIS]  : LTIMSTP1 = [F:HIS]TIMSTP
    Else
      Filter [HIS]  : LTIMSTP1 = ""
    Endif
    # Recherche de la derniĂ¨re rĂŠgularisation annuelle dans l'exercice (variation dans le temps)
    Filter [HIS] Where AASREF=[F:MAS1]AASREF and DPRPLN = G301IAS and VATREGTYP = GVML_TRVARPR and AASBUS = [F:MAS1]AASBUS and
&                      DATVATREG >= GDEBEXEIAS and DATVATREG <= GFINEXEIAS
    If (rowcount([F:HIS]) <> 0 ) Then
      Read [HIS]VAT1 Last
      Filter [HIS]  : LTIMSTP2 = [F:HIS]TIMSTP
    Else
      Filter [HIS]  : LTIMSTP2 = ""
    Endif
  Endif

  # Pas d'annulation de rĂŠgularisation a effectuĂŠ
  If ( LTIMSTP1 > LTIMSTP2 or ( LTIMSTP1 = "" and LTIMSTP2 = "" ) ) Then : End : Endif

  # Annulation de rĂŠgularisation
  If ( [F:HIS]VATREGAMT <> 0 ) Then
    G_REGULI = [F:HIS]VATREGAMT
    [F:MAS1]IASVATREG  -= [F:HIS]VATREGAMT
  Else
    G_REGULI = -[F:HIS]VATREGDED
    [F:MAS1]VATREGDEDI -= [F:HIS]VATREGDED
  Endif

  # Cette rĂŠgularisation ayant fait l'objet d'une mise Ă  jour de base elle doit ĂŞtre annulĂŠe
  If ([F:HIS]BASDEV <> 0 ) Then : B_ANNBAS = 1 : Else :  B_ANNBAS = 0 : Endif

  # Mise Ă  jour des bases avec l'ĂŠcart selon oribas PCG (avec conversion ĂŠventuelle)
  If clalev([F:DEPX])=0  : Local File DEPREC [DEPX] : Endif
  L_IAS = find(G301IAS, [M:FASR]DPRPLN)
  Read [DEPX] DEP0=[F:MAS1]AASREF;[M:FASR]DPRPLN(L_IAS-1);
&                  [M:FASR]FIYENDDAT(L_IAS-1);[M:FASR]PERENDDAT(L_IAS-1)
  # Sauvegarde Bases d'amortissement comptable
  SBSEVALI = [F:DEPX]BSEVAL
  SDPRBASI = [F:DEPX]DPRBAS
  If ( G_REGCOD = 2                 ) Then : LTYPREG = GVML_TRANVAR : Endif
  If ( G_REGCOD = 1 or G_REGCOD = 3 ) Then
    LTYPREG = GVML_TRANDEF
    [F:MAS1]DEDVATRATI = [F:HIS]DEDCOEO * 100
    [F:MAS1]DEDVATAMTI = [F:HIS]DEDVATAMTO
  Endif
  #>0 >>>>>>>>>>>>>>>>>>>>>>>>>>>
  For nolign = 1 To [M:FASR]NBLIG1
    #----1-------------------
    If ( [M:FASR]ORIBAS(nolign-1) = GVML_OBIAS  and [M:FASR]DPRPLN(nolign-1) <> G301SUB ) Then
      B_MAJBAS = 0
      Read [DEPX] DEP0=[F:MAS1]AASREF;[M:FASR]DPRPLN(nolign-1);
&                      [M:FASR]FIYENDDAT(nolign-1);[M:FASR]PERENDDAT(nolign-1)
      #----2-------------------
      If (B_ANNBAS) Then
        # Variation du prorata dans le temps
        If ( [M:FASR]CUR(L_IAS-1) = [M:FASR]CUR(nolign-1) and [F:DEPX]BSEVAL = SBSEVALI  and
&            [F:DEPX]DPRBAS = SDPRBASI  ) Then
          B_MAJBAS        = 1
          [F:DEPX]BSEVAL -= G_REGULI
          [F:DEPX]DPRBAS -= G_REGULI
        Endif
      Endif
      #----2-------------------
      # Mise Ă  jour
      #----2-------------------
      If ( PFLGSIM = G_NON ) Then
        If ( B_ANNBAS and B_MAJBAS ) Then
          [F:DEPX]DEPSTA                   = GVML_SCNOCAL
          [F:MAS1]FLGCLC                   = G_OUI
          [F:MAS1]FLGCNXCLC([F:DEPX]CNX-1) = G_OUI
          Rewrite [DEPX]
          If (fstat) Then : RERROR = 2 : End : Endif : # Erreur ĂŠcriture DEPREC
        Endif
        # Extourne ĂŠvĂŠnement de rĂŠgularisation annuelle de TVA pour le plan IAS
        If ( [F:DEPX]DPRPLN = G301IAS  ) Then
          # FQ57635
#         If clalev([F:EVT0]) =0 : Local File EVEFAS    [EVT0]  : Endif
          If clalev([F:EVT0]) =0 : Local File EFASVATREG    [EVT0]  : Endif
          LCDINT= "FASVATREG6"
#         Filter [F:EVT0] Where CPY=[F:MAS1]CPY and EVT="FASVATREG" and PLN=G301IAS and
#&                              REF=[F:MAS1]AASREF and EVTDAT=[F:HIS]DATVATREG and SNSEVE <> GVML_TEAACT
          Filter [F:EVT0] Where CPY=[F:MAS1]CPY and EVTINT="FASVATREG6" and DPRPLN=G301IAS and
&                               REF=[F:MAS1]AASREF and EVTDAT=[F:HIS]DATVATREG and SNSEVE <> GVML_TEAACT
          If (rowcount([F:EVT0]) <> 0) Then
#           Filter [F:EVT0]
#           Read [F:EVT0]EFS0 Last
            Read [F:EVT0]EVE0 Last
            Filter [F:EVT0]
            Call EXTOURNE_EVE(GVML_OMBIEN,[F:MAS1]CPY,[F:MAS1]FCY,[F:MAS1]AASREF,0,LCDINT,
&                            [F:HIS]DATVATREG,LCDRET) From GENEVE
            If (LCDRET ) Then : RERROR = 4 : End : Endif :   # Erreur annulation ĂŠvĂ¨nement
          Else
            Filter [F:EVT0]
          Endif
          # Ecriture dans HISVAT ( IAS )
          [F:HIS]VATREGTYP =  LTYPREG
          [F:HIS]VATREGAMT = -[F:HIS]VATREGAMT
          [F:HIS]VATREGDED = -[F:HIS]VATREGDED
          [F:HIS]FORMULE   = ""
          [F:HIS]TIMSTP    = func GENEVE.BUILD_TIMSTP(date$, time)
          If not (G_REGTRF) Then
            [F:HIS]DPRBAS    -= [F:HIS]BASDEV
            [F:HIS]BASDEV    = -[F:HIS]BASDEV
          Endif
          Write [HIS]
          If (fstat) Then : RERROR = 8 : End : Endif :   # Erreur ĂŠcriture dans l'historique

        Endif
      Endif
      #----2-------------------
    Endif
    #----1-------------------
  Next nolign
  #<0 <<<<<<<<<<<<<<<<<<<

  # Restauration G_REGULI
  G_REGULI = SREGULI

End

#
#########################################################
$REGUL_ANNUEL_TRANSFERT
# - Objet  : Regul. annuelle suite Ă  transfert
#            Sauf pour la regul du dernier secteur de destination qui est traitĂŠ classiquement
#
#               Nouvelles rĂ¨gles TVA
#
# - EntrĂŠe    :
#               PREGTVA     RĂŠgularisation TVA
#               PFLGSIM     Indicateur traitement simulĂŠ
#
# - Sortie    : RERROR
#                   3 Erreur de conversion
#                   4 Erreur gĂŠnĂŠration ĂŠvĂŠnement
#
# - PrĂŠrequis : Ce sous-programme utilise
#               la classe [F:MAS1] qui doit ĂŞtre ouverte et alimentĂŠe
#
#

Local Integer I_TRF
Local Decimal L_ECIMPBAS
Local Decimal L_IMPBASVT
Local Integer L_DPRBASO
Local Integer L_DPRBASIASO


  # Concerne les biens acquis dans un exercice antĂŠrieur Ă  l'exercice courant
  #                    ayant subi un transfert
  ###############If not ([F:MAS1]PURDAT < GDEBEXECPF and [F:MAS1]VATREGDAT <> [F:MAS1]PURDAT) Then : Return : Endif


  If clalev([F:HIS])  = 0  : Local File VATHIS    [HIS]  : Endif
  If clalev([F:HI2])  = 0  : Local File VATHIS    [HI2]  : Endif
  If clalev([F:MAS2]) = 0  : Local File FXDASSETS [MAS2] : Endif

  #***
  # Sauvegarde
  [F:MAS2]   = [F:MAS1]
  L_ECIMPBAS = G_ECIMPBAS
  L_IMPBASVT = G_IMPBASVT
  G_REGTRF   = 1

  # Neutralisation mise Ă  jour de la base
  G_IMPBASVT = 100
  G_ECIMPBAS = 100

  # Recherche des ĂŠventuelles transferts pour le bien
  Filter [HIS] Where AASREF=[F:MAS1]AASREF and DPRPLN = G301CPT and VATREGTYP = GVML_TRSATRF and
&                    DATVATREG >= GDEBEXECPF and DATVATREG <= GFINEXECPF
  I_TRF = rowcount([F:HIS])
  # >>>>>>>>>>>>>
  For [HIS]VAT0
    I_TRF -=1
    # Secteur d'origine
    [F:MAS1] = [F:MAS2]
    [F:MAS1]AASBUS    = [F:HIS]AASBUSO
    [F:MAS1]VATREGDAT = [F:HIS]VATREGDATO
    [F:MAS1]IVCVATAMT = [F:HIS]IVCVATAMTO
    [F:MAS1]DEDVATAMT = [F:HIS]DEDVATAMTO
    G_DPRBASO  = [F:HIS]DPRBASO
    If (GCNXPROIAS = G_OUI) Then
       Filter [HI2] Where AASREF=[F:MAS1]AASREF and DPRPLN = G301IAS and VATREGTYP = GVML_TRSATRF and
&                    DATVATREG = [F:HIS]DATVATREG and TIMSTP > [F:HIS]TIMSTP
       Read[HI2] First
       [F:MAS1]IVCVATAMTI = [F:HI2]IVCVATAMTO
       [F:MAS1]DEDVATAMTI = [F:HI2]DEDVATAMTO
       [F:MAS1]DEDVATRATI = [F:HI2]DEDCOEO * 100
       G_DPRBASIO         = [F:HI2]DPRBASO
       Filter [HI2]
    Else
      [F:MAS1]IVCVATAMTI = 0
      [F:MAS1]DEDVATAMTI = 0
      G_DPRBASIO = 0
    Endif
    [F:MAS1]ASJCOER   = [F:HIS]ASJCOERO
    [F:MAS1]TAXCOER   = [F:HIS]TAXCOERO
    [F:MAS1]ADMCOER   = [F:HIS]ADMCOERO
    [F:MAS1]DEDCOER   = [F:HIS]DEDCOERO
    [F:MAS1]ASJCOE    = [F:HIS]ASJCOEO
    [F:MAS1]TAXCOE    = [F:HIS]TAXCOEO
    [F:MAS1]TAXCOEFLG = [F:HIS]TAXCOEFLGO
    [F:MAS1]ADMCOE    = [F:HIS]ADMCOEO
    [F:MAS1]DEDCOE    = [F:HIS]DEDCOEO
    [F:MAS1]DEDVATRAT = [F:HIS]DEDCOEO * 100
    Gosub REGUL_TVA
    # Secteur destination
    If ( I_TRF <> 0 ) Then
      # Ne pas traiter le dernier secteur destination
      [F:MAS1] = [F:MAS2]
      [F:MAS1]AASBUS    = [F:HIS]AASBUS
      [F:MAS1]IVCVATAMT = [F:HIS]IVCVATAMT
      [F:MAS1]DEDVATAMT = [F:HIS]DEDVATAMT
      If (GCNXPROIAS = G_OUI) Then
         Filter [HI2] Where AASREF=[F:MAS1]AASREF and DPRPLN = G301IAS and VATREGTYP = GVML_TRSATRF and
&                      DATVATREG = [F:HIS]DATVATREG and TIMSTP > [F:HIS]TIMSTP
         Read [HI2] First
         [F:MAS1]IVCVATAMTI = [F:HI2]IVCVATAMTO
         [F:MAS1]DEDVATAMTI = [F:HI2]DEDVATAMTO
         [F:MAS1]DEDVATRATI = [F:HI2]DEDCOEO * 100
         G_DPRBASIO         = [F:HI2]DPRBASO
      Else
        [F:MAS1]IVCVATAMTI = 0
        [F:MAS1]DEDVATAMTI = 0
      Endif
      Filter [HI2]
      [F:MAS1]ASJCOER   = [F:HIS]ASJCOER
      [F:MAS1]TAXCOER   = [F:HIS]TAXCOER
      [F:MAS1]ADMCOER   = [F:HIS]ADMCOER
      [F:MAS1]DEDCOER   = [F:HIS]DEDCOER
      [F:MAS1]ASJCOE    = [F:HIS]ASJCOE
      [F:MAS1]TAXCOE    = [F:HIS]TAXCOE
      [F:MAS1]TAXCOEFLG = [F:HIS]TAXCOEFLG
      [F:MAS1]ADMCOE    = [F:HIS]ADMCOE
      [F:MAS1]DEDCOE    = [F:HIS]DEDCOE
      Gosub REGUL_TVA
    Endif
  Next
  Filter [HIS]

  #***
  # Restoration
  [F:MAS1] = [F:MAS2]
  G_ECIMPBAS = L_ECIMPBAS
  G_IMPBASVT = L_IMPBASVT
  G_REGTRF   = 0
Return

