#<AdxTL>@(#)3.0.0.0 $Revision$
#<AdxTL>@(#)3.0.0.0 $Revision$
######################################################################
# Subprog for pivot of type : accounting entries
######################################################################

$OUVTAB_FAE
If !clalev([F:BPR])  : Local File BPARTNER   [BPR]  : Endif
If !clalev([F:HAE])  : Local File GACCENTRY  [HAE]  : Endif
If !clalev([F:DAE])  : Local File GACCENTRYD [DAE]  : Endif
If !clalev([F:GAC])  : Local File GACCOUNT   [GAC]  : Endif
If !clalev([F:JOU])  : Local File GJOURNAL   [JOU]  : Endif
If !clalev([F:JAX])  : Local File ATEXTRA    [JAX]  : Endif
If !clalev([F:JAX2]) : Local File ATEXTRA    [JAX2] : Endif
If !clalev([F:CAX])  : Local File ATEXTRA    [CAX]  : Endif
If !clalev([F:PER])  : Local File PERIOD     [PER]  : Endif
If !clalev([F:FIY])  : Local File FISCALYEAR [FIY]  : Endif
If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif
Return

Subprog TRT_FAE(ID, CLETRT, CODPIT, LTYP, CPY, FIYNUM, PERSTR, PEREND, NBRLIN, OK)
Value    Char       ID, CLETRT, CODPIT, CPY
Value    Integer    LTYP, FIYNUM
Value    Date       PERSTR, PEREND
Variable Integer    NBRLIN, OK

Local Integer SAVADXIUM : SAVADXIUM=adxium
Local Char    SAVADXIFS(1) : SAVADXIFS=adxifs
Local Char    SAVADXIRS(2) : SAVADXIRS=adxirs
adxium = GASCII
adxifs = ''
adxirs = chr$(13)+chr$(10)
Gosub INIT_FILE From CONNECTFCT
adxifs = chr$(9)

Gosub OUVTAB_FAE
Gosub OUVREPIVOT From CONNECTFCT

Local Integer I, ICPY
Local Char    FILTENT(250)(0..2)
Local Integer IFILE

Local Integer WPREFAE : Raz WPREFAE
Local Char    OPTFAE(GDIMFIC)
Local Integer WKNBZON        : Raz WKNBZON
Local Char    WKNORECMES (50): Raz WKNORECMES
Local Integer WKHEATYP       : Raz WKHEATYP
Local Char    WKHEADMES (250): Raz WKHEADMES
OPTFAE = filpath("tmp", tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)), "pitfae")

Call READPIT(CODPIT,WKNBZON,WKNORECMES,WKHEATYP ,WKHEADMES) From CONNECTFCT
Local Char    WKTABZON(GLONATB+GLONAVA+2)(1..WKNBZON) : Raz WKTABZON
Local Char    WKTABABR(GLONABR)(1..WKNBZON) : Raz WKTABABR
Local Char    WKZON(GLONAVA)(1..WKNBZON) : Raz WKTABZON
Local Char    WKFRM(150)(1..WKNBZON) : Raz WKFRM
Local Integer WKWRK(1..WKNBZON) : Raz WKWRK
Local Char    WKVAL(255)(1..WKNBZON) : Raz WKVAL
Local Char    WKVALFIC(GLONAVA)(1..WKNBZON) : Raz WKVALFIC
Local Date    FIYEND

Call LOADPIVZON(CODPIT,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK) From CONNECTFCT
Call WRPIVOT_HEAD(CODPIT,WKNBZON,WKTABZON,WKTABABR,WKZON,WKWRK,WKHEATYP,WKHEADMES,WPREFAE,OPTFAE) From CONNECTFCT

Raz FILTENT
Call ADDCRIT(FILTENT,IFILE,"CAT",'[HAE]CAT=1'," & ") From GOBJSUB
Call ADDCRIT(FILTENT,IFILE,"STA",'[HAE]STA=2'," & ") From GOBJSUB
Call ADDCRIT(FILTENT,IFILE,"CPY",'[F:DAE]CPY="'+[L]CPY+'"'," & ") From GOBJSUB
Call ADDCRIT(FILTENT,IFILE,"FIY",'[F:DAE]FIY='+num$([L]FIYNUM)," & ") From GOBJSUB
Call ADDCRIT(FILTENT,IFILE,"LEDTYP",'[F:DAE]LEDTYP='+num$([L]LTYP)," & ") From GOBJSUB
If [M:DIA]FIYPER=2
 Call ADDCRIT(FILTENT,IFILE,"ACCDAT1",'[F:DAE]ACCDAT>=['+format$(GFMD, [L]PERSTR)+']'," & ") From GOBJSUB
 Call ADDCRIT(FILTENT,IFILE,"ACCDAT2",'[F:DAE]ACCDAT<=['+format$(GFMD, [L]PEREND)+']'," & ") From GOBJSUB
Endif

Call LEC_CPY([L]CPY) From CPTLEC
Read [FIY]FIY0=[L]CPY;[L]LTYP;[L]FIYNUM
[L]FIYEND = [F:FIY]FIYEND

If CODPIT="ACCENTFILN"
 Link [DAE] With [HAE]HAE0=[F:DAE]TYP;[F:DAE]NUM,
&                [GAC]GAC0=[F:DAE]COA;[F:DAE]ACC,
&                [BPR]BPR0=[F:DAE]BPR,
&                [JAX]AXX0="GJOURNAL";"DESTRA";GLANGUE;[F:HAE]JOU;[F:CPY]LEG,
&                [JAX2]AXX0="GJOURNAL";"DESTRA";GLANGUE;[F:HAE]JOU;"",
&                [CAX]AXX0="GACCOUNT";"DESTRA";GLANGUE;[F:DAE]COA;[F:DAE]ACC
& As [LNK]
& Where evalue(FILTENT)
& Order By Key KEY1=[DAE]FCYLIN Asc;[HAE]ACCDAT Asc;[HAE]NUM Asc;[DAE]ACCNUM Asc
Else
 Link [DAE] With [HAE]HAE0=[F:DAE]TYP;[F:DAE]NUM,
&                [GAC]GAC0=[F:DAE]COA;[F:DAE]ACC,
&                [BPR]BPR0=[F:DAE]BPR,
&                [JAX]AXX0="GJOURNAL";"DESTRA";GLANGUE;[F:HAE]JOU;[F:CPY]LEG,
&                [JAX2]AXX0="GJOURNAL";"DESTRA";GLANGUE;[F:HAE]JOU;"",
&                [CAX]AXX0="GACCOUNT";"DESTRA";GLANGUE;[F:DAE]COA;[F:DAE]ACC
& As [LNK]
& Where evalue(FILTENT)
& Order By Key KEY1=[DAE]FCYLIN Asc;[HAE]FNLPSTNUM([L]LTYP-1) Asc;[DAE]ACCNUM Asc
Endif

For [LNK]KEY1 Where [F:HAE]FLGREP<>2 or ([F:HAE]FLGREP=2 & [F:HAE]ACCDAT<>[L]FIYEND)
 Gosub WR_FAE
Next

adxifs = chr$(9)
Call WRPIVOT_END(CODPIT,NBRLIN,WKNORECMES,WPREFAE,OPTFAE) From CONNECTFCT
adxium = SAVADXIUM
adxifs = SAVADXIFS
adxirs = SAVADXIRS
End

$WR_FAE
If WPREFAE = 0
 Openo OPTFAE, 0 Using [FPIV]
 WPREFAE = 1
Else
 Openo OPTFAE Using [FPIV]
Endif
NBRLIN += 1
adxifs = chr$(9)
Call RAZVALPIVOT(CODPIT, WKNBZON, WKVAL, WKVALFIC) From CONNECTFCT
Call EVALPIVOT(CODPIT, WKNBZON, WKTABZON, WKTABABR, WKZON, WKFRM, WKWRK, WKVAL, WKVALFIC) From CONNECTFCT
Call WRPIVOT(WKNBZON, WKTABZON, WKTABABR, WKZON, WKFRM, WKWRK, WKVAL, WKVALFIC) From CONNECTFCT
Openo Using [FPIV]
Return

