#<AdxTL>@(#)76.0.0.0 $Revision$
#######################################################################
#                       Traitements encours charge                    #
# ------------------------------------------------------------------- #
########################################################################
#  Mise a jour du fichier OPERATIONS (encours charge)                  #
#   MAJ   : Type de traitement                                         #
#           C = création ordre                                         #
#           M = modification ordre                                     #
#           A = suppression ordre                                      #
#           P = consommation ordre (PEC)                               #
#  GOK positionné à tester en retour ou pas                            #
#                                                  llc nov      1998   # 
########################################################################
Subprog ENCOURS_OPE(MAJ, WOPSNUM)
Value     Char    MAJ 
Variable  Char    WOPSNUM
Local     Integer STAT
Local     Date    TODAY : TODAY = date$
#
If clalev ([F:OPS]) = 0 : Local File OPERATIONS [OPS] : Endif
#
Case MAJ
    When "C"     : Goto CREATION
    When "M"     : Goto MODIFICATION
    When "A"     : Goto SUPPRESSION
    When Default : Goto FIN
Endcase
#
$CREATION
#
If [M:OPSK]OPSNUM = ""   
   Call NUMERO(GOPS,[M:OPSK]MFGFCY,TODAY,"",[M:OPSK]OPSNUM,STAT) From SUBANM
   If STAT <> 0 : GOK = 0 : Goto FIN : Endif
Endif
#
If num$([M:OPSK]OPSTYP)    = "" : GOK = 0 : Goto FIN : Endif
If      [M:OPSK]MFGNUM     = "" : GOK = 0 : Goto FIN : Endif
If num$([M:OPSK]OPENUM)    = "" : GOK = 0 : Goto FIN : Endif
If num$([M:OPSK]OPESPLNUM) = "" : GOK = 0 : Goto FIN : Endif
#------------------------------#
# creation encours charge      #
#------------------------------#
Raz [F:OPS]
[F:OPS]         = [M:OPSK]
[F:OPS]CREDAT   = date$
[F:OPS]CREUSR   = GUSER
[F:OPS]EXPNUM   = [C]EXPORT
#sr 09.03 point d'entrée  pour récup infos supplémentaires avant écriture ligne demande 19257
GPOINT = "OPSMAJ" : Gosub ENTREE From EXEFNC

Write [OPS]
If fstat GOK=0 : Call FSTA("OPS") From GLOCK : End : Endif
WOPSNUM = [M:OPSK]OPSNUM
Goto FIN

$MODIFICATION
#--------------------------------#
# Modification encours charge    #
#--------------------------------#
# si qté prévue = 0 ou qté restante = 0, on ne veut pas d'encours ...  
If ([M:OPSK]OPESTA = 6) | ([M:OPSK]EXTQTY <= [M:OPSK]CPLQTY) : Goto SUPPRESSION : Endif 
#
Readlock [OPS]OPS1=[M:OPSK]MFGNUM;[M:OPSK]OPENUM;[M:OPSK]OPESPLNUM
If fstat = 1
      GOK=-1
      GLOCK="$OPERATIONS"-[M:OPSK]MFGNUM-num$([M:OPSK]OPENUM)-num$([M:OPSK]OPESPLNUM)
      End
Elsif fstat Goto CREATION 
Endif
#
[M:OPSK]OPSNUM  = [F:OPS]OPSNUM        # llc 06.01
[F:OPS]         = [M:OPSK]
[F:OPS]UPDDAT   = date$
[F:OPS]UPDUSR   = GUSER
[F:OPS]EXPNUM   = [C]EXPORT
#

#sr 09.03 point d'entrée  pour récup infos supplémentaires avant écriture ligne demande 19257
GPOINT = "OPSMAJ" : Gosub ENTREE From EXEFNC

Rewrite [OPS]
If fstat GOK=0 : Call FSTA("OPS") From GLOCK : End : Endif
WOPSNUM = [M:OPSK]OPSNUM

Goto FIN

$SUPPRESSION
#--------------------------------#
# Suppression encours charge     #
#--------------------------------#
Readlock [OPS]OPS1=[M:OPSK]MFGNUM;[M:OPSK]OPENUM;[M:OPSK]OPESPLNUM
If fstat = 1
      GOK=-1
      GLOCK="$OPERATIONS"-[M:OPSK]MFGNUM-num$([M:OPSK]OPENUM)-num$([M:OPSK]OPESPLNUM)
      End
Elsif fstat : Goto FIN
Endif
#
#sr 09.03 point d'entrée  pour récup infos supplémentaires avant écriture ligne demande 19257
GPOINT = "OPSMAJ" : Gosub ENTREE From EXEFNC

Delete [OPS]
WOPSNUM = ""
Goto FIN
#
$FIN
End
