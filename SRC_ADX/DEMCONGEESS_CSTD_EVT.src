#STCAH - 2017-04-26 - REQUIREMENT nnn - US nnn
#Handling all events for DEMCONGEESS_CSTD
############################################################################################################
$EVENTS
#ASTATUS = fmet  this.ASETERROR("",[L]CURPTH-[L]AEVENT,CST_AINFO)
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AINIT"                    : Gosub AINIT
      When "AREAD_AFTER"              : Gosub AREAD_AFTER
      When "AINSERT_CONTROL_AFTER"    : Gosub AINSERT_CONTROL_AFTER
      When "AUPDATE_CONTROL_AFTER"    : Gosub AUPDATE_CONTROL_AFTER
      When "AINSERT_CONTROL_BEFORE"   : Gosub AINSERT_CONTROL_BEFORE
      When "AUPDATE_CONTROL_BEFORE"   : Gosub AUPDATE_CONTROL_BEFORE
      When "AINSERT_AFTER"            : Gosub AINSERT_AFTER
      When "AUPDATE_AFTER"            : Gosub AUPDATE_AFTER
      When Default : Return
    Endcase
Endcase

Return
############################################################################################################
$AINIT

Gosub AINIT From DEMCONGE_CSTD_EVT

Return
############################################################################################################
$AREAD_AFTER

Gosub AREAD_AFTER From DEMCONGE_CSTD_EVT



Return
############################################################################################################
$AINSERT_CONTROL_BEFORE

Gosub AINSERT_CONTROL_BEFORE From DEMCONGE_CSTD_EVT

Return
############################################################################################################
$AUPDATE_CONTROL_BEFORE

Gosub AUPDATE_CONTROL_BEFORE From DEMCONGE_CSTD_EVT

Return
############################################################################################################
$AINSERT_CONTROL_AFTER

Gosub AINSERT_CONTROL_AFTER From DEMCONGE_CSTD_EVT

#Setting the creation and update user to the user linked to the employee


Return
############################################################################################################
$AUPDATE_CONTROL_AFTER

Gosub AUPDATE_CONTROL_AFTER From DEMCONGE_CSTD_EVT

#Setting the creation and update user to the user linked to the employee


Return
############################################################################################################
$AINSERT_AFTER

Gosub AINSERT_AFTER From DEMCONGE_CSTD_EVT

Return
############################################################################################################
$AUPDATE_AFTER

Gosub AUPDATE_AFTER From DEMCONGE_CSTD_EVT

Return
############################################################################################################




