#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque LPNLBECRI


#CHECK UNUSED_BEGIN
Local Char PARAM(250)(1..20) , SAVACT(10)
PARAM(1) = "ALL"
Local Decimal VALEUR
#SAVACT = GACTION : GACTION = "SAILPNCRI"
Call SAISIE_NUM(VALEUR,PARAM,"ILPNCRI","TRTLPNCRI") From GSAISIE
#GACTION = SAVACT
End
#CHECK UNUSED_END

###################################################################################################
# TRTLPNCRI    Saisie des filtres pour la liste de picking des affectations de contenant interne  #
###################################################################################################

$ACTION
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "ENR"         : Gosub ENR
 When "ABA"         : Gosub ABA
Endcase
Return

#########################################################################
$OUVRE_BOITE


Return

#########################################################################
$DEBUT

Local Integer I,J

Raz[M:LPBR]
Transmask [M:LPB0] To [M:LPBR]

If [M:LPBR]STOFCY=""
    Call ERREUR(mess(215,193,1)) From GESECRAN
    FIN=1
    Return
Endif


Affzo [M:LPBR]

Return

#########################################################################
$SETBOUT

ETABOU(GENRE)=1
ETABOU(GABAN)=1

Return
#########################################################################
$ENR


Transmask [M:LPBR] To [M:LPB0]

Affzo [M:LPB0]
FIN = 1

Return

#########################################################################
$ABA

# Réalimentation avec les valeurs initiales
Gosub DEBUT

Return

Subprog AM_TCTRNUMSTR(VALEUR)
Variable Char    VALEUR()
If [M:LPBR]TCTRNUMEND=[M:LPBR]TCTRNUMSTR | [M:LPBR]TCTRNUMEND<VALEUR
   [M:LPBR]TCTRNUMEND = VALEUR
   Affzo [M:LPBR]TCTRNUMEND
Endif
End

Subprog C_TCTRNUMEND(VALEUR)
Variable Char    VALEUR()
If [M:LPBR]TCTRNUMSTR>VALEUR
   GMESSAGE = mess(44,199,1)
   mkstat=2
Endif
If VALEUR = ""
   VALEUR = [M:LPBR]TCTRNUMSTR
Endif
End

