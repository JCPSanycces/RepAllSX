Subprog AM_LPNSTAT1(VALEUR)
Variable Integer VALEUR
If VALEUR = 1 & [M:LPBR]LPNSTAT2 = 1
   [M:LPBR]LPNSTAT2 = 2
   Affzo [M:LPBR]LPNSTAT2
Endif
End

