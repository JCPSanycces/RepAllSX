    Readlock [SAP2]SAP0 = [F:PS2]UPDCOD;[M]CPY;[M]FCY;DATPER(P);
&                         [F:SAP]CRI1;[F:SAP]CRI2;[F:SAP]CRI3;"$$$";
&                         "$$$"
   When 4
    For [SAP2]SAP0 Where COD=[F:PS2]UPDCOD & CPY=[M]CPY & FCY=[M]FCY & DAT=DATPER(P)
&                      & CRI1=[F:SAP]CRI1 & CRI2=[F:SAP]CRI2 & CRI3=[F:SAP]CRI3 & CRI4<>"$$$"
     For I=0 To [M]NBRAMT-1
      TOTAL(I) += [F:SAP2]AMT(I)
     Next I
    Next SAP2
    Readlock [SAP2]SAP0 = [F:PS2]UPDCOD;[M]CPY;[M]FCY;DATPER(P);
&                         [F:SAP]CRI1;[F:SAP]CRI2;[F:SAP]CRI3;"$$$"
  Endcase
  If fstat=1
   GOK = -1 : GLOCK = "$STATPRV"-[F:PS2]UPDCOD-[M]CPY-[M]FCY : Break
  Elsif fstat
   [F:SAP2]COD = [F:PS2]UPDCOD
   [F:SAP2]CPY = [M]CPY
   [F:SAP2]FCY = [M]FCY
   [F:SAP2]DAT = DATPER(P)
   For I=1 To MAXCRI
    Case I
     When 1 : [F:SAP2]CRI1 = [F:SAP]CRI1
     When 2 : [F:SAP2]CRI2 = [F:SAP]CRI2
     When 3 : [F:SAP2]CRI3 = [F:SAP]CRI3
     When 4 : [F:SAP2]CRI4 = "$$$"
     When 5 : [F:SAP2]CRI5 = "$$$"
     When 6 : [F:SAP2]CRI6 = "$$$"
     When 7 : [F:SAP2]CRI7 = "$$$"
     When 8 : [F:SAP2]CRI8 = "$$$"
    Endcase
   Next I
   For I=0 To [M]NBRAMT-1
    If [M]FRTFLG(I)=2
     [F:SAP2]AMT(I) = TOTAL(I)
    Endif
   Next I
   Write [SAP2]
  Else
   For I=0 To [M]NBRAMT-1
    If [M]FRTFLG(I)=2
     [F:SAP2]AMT(I) = TOTAL(I)
    Endif
   Next I
   Rewrite [SAP2]
  Endif
  If fstat
   GOK = 0 : Call FSTA("SAP2") From GLOCK : Break
  Endif
  Raz INTCLENIV
  INTCLENIV(1) = [M]INTCLE1
  INTCLENIV(2) = [M]INTCLE2
  INTCLENIV(3) = [M]INTCLE3
  Gosub CRESTA2
  If GOK<1 : Break : Endif
 Next P
 If GOK<1 : Return : Endif
Endif

