$CRESTA
Case MAXCRI
 When 4 : Readlock [SAT0]SAT0 = [F:SAP]COD;[F:SAP]CPY;[F:SAP]FCY;[F:SAP]DAT
&                              ;[F:SAP]CRI1;[F:SAP]CRI2;[F:SAP]CRI3;[F:SAP]CRI4
 When 5 : Readlock [SAT0]SAT0 = [F:SAP]COD;[F:SAP]CPY;[F:SAP]FCY;[F:SAP]DAT
&                              ;[F:SAP]CRI1;[F:SAP]CRI2;[F:SAP]CRI3;[F:SAP]CRI4
&                              ;[F:SAP]CRI5
 When 6 : Readlock [SAT0]SAT0 = [F:SAP]COD;[F:SAP]CPY;[F:SAP]FCY;[F:SAP]DAT
&                              ;[F:SAP]CRI1;[F:SAP]CRI2;[F:SAP]CRI3;[F:SAP]CRI4
&                              ;[F:SAP]CRI5;[F:SAP]CRI6
 When 7 : Readlock [SAT0]SAT0 = [F:SAP]COD;[F:SAP]CPY;[F:SAP]FCY;[F:SAP]DAT
&                              ;[F:SAP]CRI1;[F:SAP]CRI2;[F:SAP]CRI3;[F:SAP]CRI4
&                              ;[F:SAP]CRI5;[F:SAP]CRI6;[F:SAP]CRI7
 When 8 : Readlock [SAT0]SAT0 = [F:SAP]COD;[F:SAP]CPY;[F:SAP]FCY;[F:SAP]DAT
&                              ;[F:SAP]CRI1;[F:SAP]CRI2;[F:SAP]CRI3;[F:SAP]CRI4
&                              ;[F:SAP]CRI5;[F:SAP]CRI6;[F:SAP]CRI7;[F:SAP]CRI8
Endcase
If fstat=1
 GOK = -1 : GLOCK = "$STAT"-[F:SAP]COD
Elsif fstat
 Raz [F:SAT0]
 [F:SAT0] = [F:SAP]
 For I=1 To MAXCRI
  Case I
   When 1 : [F:SAT0]DES1 = INTCLENIV(1)
   When 2 : [F:SAT0]DES2 = INTCLENIV(2)
   When 3 : [F:SAT0]DES3 = INTCLENIV(3)
   When 4 : [F:SAT0]DES4 = INTCLENIV(4)
   When 5 : [F:SAT0]DES5 = INTCLENIV(5)
   When 6 : [F:SAT0]DES6 = INTCLENIV(6)
   When 7 : [F:SAT0]DES7 = INTCLENIV(7)
   When 8 : [F:SAT0]DES8 = INTCLENIV(8)
  Endcase
 Next I
 Raz [F:SAT0]AMT
 Write [SAT0]
 If fstat
  GOK = 0 : Call FSTA("SAT0") From GLOCK
 Endif
Endif
Return

