#############################################################################
$CHARGE
Call LECTURE("PS2",[M]COD,"") From CONTOBJ
Call LECTURE("PS1",[F:PS2]RLG,"") From CONTOBJ
Raz [M]NBRAMT, [M]FRTFLG
For [PSL] Where COD=[F:PS2]COD
 [M]FRTFLG([M]NBRAMT) = [F:PSL]FRTFLG
 [M]NBRAMT += 1
 If [F:PSL]VARNAM<>""
  I = find([F:PSL]VARNAM,[F:PS1]VARNAM)
  If I
   Call LECTEXTRA(CHAINE,"PARSTA1","VARINTIT",[F:PS1]COD,num$(I)) From ATEXTRA
  Endif
 Else
  Call LECTEXTRA(CHAINE,"PARSTALIG","INTITVAR",[F:PS2]COD,num$([M]NBRAMT)) From ATEXTRA
 Endif
 Assign "[M]LIBAMT"+num$([M]NBRAMT) With CHAINE
Next
Call LECACC([F:PS2]ACS,DROIT) From SUBACS
[M]NIVEAU  = 1
Call LECTEXTRA([M]LIBCRIT,"PARSTA2","FLDINTIT",[PS2]COD,num$(1)) From ATEXTRA
Raz [M]TYP, CODTYP, LONG, NOLIB, FORMA, OBJ, OBJ2, INTIT, ABR
For I=1 To [F:PS2]NBRFLD
 Read [ATZ]CODZONE = [F:PS2]TBL(I-1);[F:PS2]FLDNAM(I-1)
 Read [ATY]CODTYP  = [F:ATZ]CODTYP
 [M]CODTYP(I) = [F:ATY]CODTYP
 [M]TYP(I) = [F:ATY]TYPTYP
 Case [M]TYP(I)
  When 1
   [M]FORMA(I) = "Nzf:3#"
   If [F:ATY]NOLIB<>0
    [M]NOLIB(I) = [F:ATY]NOLIB
   Else
    [M]NOLIB(I) = [F:ATZ]NOLIB
   Endif
  When 8
   [M]FORMA(I) = "DzZ:"+GFMDAT4
  When Default
   If [F:ATY]OBJLIEN="ADI"
    Gosub GETPAR
    J = instr(1,PARACT,"indice")
    While J<>0
     PARACT = left$(PARACT,J-1)+num$([F:PS2]FLDIND(I-1))+right$(PARACT,J+6)
     J = instr(J+1,PARACT,"indice")
    Wend
    If vireblc(PARACT,2)<>""
     [M]NOLIB(I) = val(num$(evalue(PARACT)))
    Endif
   Endif
   If [M]TYP(I)=7
    [M]LONG(I) = [F:PS2]FLDLON(I-1)-[F:PS2]FLDPOS(I-1)+1
   Elsif [F:ATY]LNGTYP<>0
    [M]LONG(I)  = [F:ATY]LNGTYP
   Else
    [M]LONG(I)  = [F:ATZ]LONG
   Endif
   Call FORMA(30,[F:ATY]TYPTYP,[M]LONG(I),[F:ATZ]NOLIB,[F:ATY]OPTION+[F:ATZ]OPTION,[F:ATY]FORTYP
&             ,TYPFMT,OPTFMT,CHFMT,NUMFMT)  From SUBFMT
   If left$(TYPFMT,1)="="
    Case [F:ATY]TYPTYP
     When 7       : [M]FORMA(I) = "K:"+num$([M]LONG(I))+"X"
     When Default : [M]FORMA(I) = "Nz:"+num$([M]LONG(I))
    Endcase
   Else
    [M]FORMA(I) = TYPFMT+OPTFMT+":"+CHFMT
   Endif
 Endcase
 If [F:PS2]FLDPOS(I-1)<=1 & [F:PS2]FLDLON(I-1)=[F:PS2]FLDLNG(I-1)
  If [F:ATY]FICLIEN<>""
   Read [ATB]CODFIC = [F:ATY]FICLIEN
   If [F:ATB]INTIT<>""
    Read [F:ATZ]CODZONE = [F:PS2]TBL(I-1);[F:PS2]FLDNAM(I-1)
    If [F:ATZ]EXPLIEN=""
     [M]OBJ2(I) = ""
     OKLIEN = 1
    Else
     OKLIEN = 0
     CHAINE = vireblc(format$("KT:120X",[F:ATZ]EXPLIEN),2)
     J = instr(1,CHAINE,";")
     If mid$(CHAINE,J+1,len([F:PS2]FLDNAM(I-1)))=[F:PS2]FLDNAM(I-1)
      CHAINE = left$(CHAINE,J-1)
      Repeat
       J = instr(1,CHAINE,"indice")
       If J
        CHAINE = left$(CHAINE,J-1)+num$([F:PS2]FLDIND(I-1))+right$(CHAINE,J+6)
       Endif
      Until J=0
      ERR = 0
      Onerrgo RIEN
      [M]OBJ2(I) = num$(evalue(CHAINE))
      Onerrgo
      If ERR=0 : OKLIEN = 1 : Endif
     Endif
    Endif
    If OKLIEN
     [M]OBJ(I)   = [F:ATY]OBJLIEN
     [M]INTIT(I) = [F:ATB]INTIT
     [M]ABR(I)   = [F:ATB]ABRFIC
     If evalue("clalev([F:"+[F:ATB]ABRFIC+"])")=0
      Local File =[F:ATY]FICLIEN
     Endif
    Endif
   Endif
  Endif
 Endif
Next I
Gosub LECTURE
zonsui = "NBLIG"
Return

$RIEN
ERR = errn
Resume

$GETPAR
Local Char PARACT(250)
Read [AMP]CODPAR(3) = 2;[F:PS2]TBL(I-1);[F:PS2]FLDNAM(I-1)
If !fstat
 PARACT = vireblc(format$("KT:80X",[F:AMP]VALPAR),2)    
 If num$(val(PARACT))=PARACT : PARACT = '"'+PARACT+'"'
 Elsif PARACT="" : PARACT = '""'
 Elsif left$(PARACT,4)<>"num$" and left$(PARACT,1)<>'"' and left$(PARACT,1)<>"'"
  PARACT = "num$("+PARACT+")"
 Endif
Else
 PARAM = "0"
Endif
Return

####################  remplissage normal
$LECTURE
CRITERE = 'COD="'+[F:PS2]UPDCOD+'"'
If [M]CPY<>""
 CRITERE -= '& CPY="'+[M]CPY+'"'
Endif
If [M]FCY<>""
 CRITERE -= '& FCY="'+[M]FCY+'"'
Endif
If [M]DATDEB<>[0/0/0]
 CRITERE -= '& DAT>=['+format$(GFMD,[M]DATDEB)+']'
Endif
If [M]DATFIN<>[0/0/0]
 CRITERE -= '& DAT<=['+format$(GFMD,[M]DATFIN)+']'
Endif
[M]NIVEAU = max(1,[M]NIVEAU) 
Case [M]NIVEAU
 When 1
  If [F:PS2]NBRFLD>7
   CRITERE -= '& CRI8="$$$" & CRI7="$$$" & CRI6="$$$" & CRI5="$$$" & CRI4="$$$" & CRI3="$$$" & CRI2="$$$"'
  Elsif [F:PS2]NBRFLD>6
   CRITERE -= '& CRI7="$$$" & CRI6="$$$" & CRI5="$$$" & CRI4="$$$" & CRI3="$$$" & CRI2="$$$"'
  Elsif [F:PS2]NBRFLD>5
   CRITERE -= '& CRI6="$$$" & CRI5="$$$" & CRI4="$$$" & CRI3="$$$" & CRI2="$$$"'
  Elsif [F:PS2]NBRFLD>4
   CRITERE -= '& CRI5="$$$" & CRI4="$$$" & CRI3="$$$" & CRI2="$$$"'
  Elsif [F:PS2]NBRFLD>3
   CRITERE -= '& CRI4="$$$" & CRI3="$$$" & CRI2="$$$"'
  Elsif [F:PS2]NBRFLD>2
   CRITERE -= '& CRI3="$$$" & CRI2="$$$"'
  Elsif [F:PS2]NBRFLD>1
   CRITERE -= '& CRI2="$$$"'
  Endif
  Filter [SAP] Where evalue(CRITERE) Order By Key CLE = CRI1
 When 2
  CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2<>"$$$"'
  If [F:PS2]NBRFLD>7
   CRITERE -= '& CRI8="$$$" & CRI7="$$$" & CRI6="$$$" & CRI5="$$$" & CRI4="$$$" & CRI3="$$$"'
  Elsif [F:PS2]NBRFLD>6
   CRITERE -= '& CRI7="$$$" & CRI6="$$$" & CRI5="$$$" & CRI4="$$$" & CRI3="$$$"'
  Elsif [F:PS2]NBRFLD>5
   CRITERE -= '& CRI6="$$$" & CRI5="$$$" & CRI4="$$$" & CRI3="$$$"'
  Elsif [F:PS2]NBRFLD>4
   CRITERE -= '& CRI5="$$$" & CRI4="$$$" & CRI3="$$$"'
  Elsif [F:PS2]NBRFLD>3
   CRITERE -= '& CRI4="$$$" & CRI3="$$$"'
  Elsif [F:PS2]NBRFLD>2
   CRITERE -= '& CRI3="$$$"'
  Endif
  Filter [SAP] Where evalue(CRITERE) Order By Key CLE = CRI2
 When 3
  CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3<>"$$$"'
  If [F:PS2]NBRFLD>7
   CRITERE -= '& CRI8="$$$" & CRI7="$$$" & CRI6="$$$" & CRI5="$$$" & CRI4="$$$"'
  Elsif [F:PS2]NBRFLD>6
   CRITERE -= '& CRI7="$$$" & CRI6="$$$" & CRI5="$$$" & CRI4="$$$"'
  Elsif [F:PS2]NBRFLD>5
   CRITERE -= '& CRI6="$$$" & CRI5="$$$" & CRI4="$$$"'
  Elsif [F:PS2]NBRFLD>4
   CRITERE -= '& CRI5="$$$" & CRI4="$$$"'
  Elsif [F:PS2]NBRFLD>3
   CRITERE -= '& CRI4="$$$"'
  Endif
  Filter [SAP] Where evalue(CRITERE) Order By Key CLE = CRI3
 When 4
  CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE3+'" & CRI4<>"$$$"'
  If [F:PS2]NBRFLD>7
   CRITERE -= '& CRI8="$$$" & CRI7="$$$" & CRI6="$$$" & CRI5="$$$"'
  Elsif [F:PS2]NBRFLD>6
   CRITERE -= '& CRI7="$$$" & CRI6="$$$" & CRI5="$$$"'
  Elsif [F:PS2]NBRFLD>5
   CRITERE -= '& CRI6="$$$" & CRI5="$$$"'
  Elsif [F:PS2]NBRFLD>4
   CRITERE -= '& CRI5="$$$"'
  Endif
  Filter [SAP] Where evalue(CRITERE) Order By Key CLE = CRI4
 When 5
  CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE3+'" & CRI4="'+[M]CLE4+'"'
  CRITERE -= '& CRI5<>"$$$"'
  If [F:PS2]NBRFLD>7
   CRITERE -= '& CRI8="$$$" & CRI7="$$$" & CRI6="$$$"'
  Elsif [F:PS2]NBRFLD>6
   CRITERE -= '& CRI7="$$$" & CRI6="$$$"'
  Elsif [F:PS2]NBRFLD>5
   CRITERE -= '& CRI6="$$$"'
  Endif
  Filter [SAP] Where evalue(CRITERE) Order By Key CLE = CRI5
 When 6
  CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE3+'" & CRI4="'+[M]CLE4+'"'
  CRITERE -= '& CRI5="'+[M]CLE5+'" & CRI6<>"$$$"'
  If [F:PS2]NBRFLD>7
   CRITERE -= '& CRI8="$$$" & CRI7="$$$"'
  Elsif [F:PS2]NBRFLD>6
   CRITERE -= '& CRI7="$$$"'
  Endif
  Filter [SAP] Where evalue(CRITERE) Order By Key CLE = CRI6
 When 7
  CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE3+'" & CRI4="'+[M]CLE4+'"'
  CRITERE -= '& CRI5="'+[M]CLE5+'" & CRI6="'+[M]CLE6+'" & CRI7<>"$$$"'
  If [F:PS2]NBRFLD>7
   CRITERE -= '& CRI8="$$$"'
  Endif
  Filter [SAP] Where evalue(CRITERE) Order By Key CLE = CRI7
 When 8
  CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE3+'" & CRI4="'+[M]CLE4+'"'
  CRITERE -= '& CRI5="'+[M]CLE5+'" & CRI6="'+[M]CLE6+'" & CRI7="'+[M]CLE7+'" & CRI8<>"$$$"'
  Filter [SAP] Where evalue(CRITERE) Order By Key CLE = CRI8
Endcase
NOL = 0
PLEIN = 0
Effzo 20
Raz [M]AMT1, AMT2, AMT3, AMT4, AMT5, LIBCLE, CLE, FLG
For [SAP]CLE(1)
 Gosub REMPLIT
 If PLEIN : Break : Endif
Next
[M]NBLIG = NOL
Case [M]NIVEAU
 When 1 : [M]LIBEL = ""
 When 2 : [M]LIBEL = [M]LIBCLE1
 When 3 : [M]LIBEL = [M]LIBCLE1-"/"-[M]LIBCLE2
 When 4 : [M]LIBEL = [M]LIBCLE1-"/"-[M]LIBCLE2-"/"+[M]LIBCLE3
 When 5 : [M]LIBEL = [M]LIBCLE1-"/"-[M]LIBCLE2-"/"+[M]LIBCLE3-"/"+[M]LIBCLE4
 When 6 : [M]LIBEL = [M]LIBCLE1-"/"-[M]LIBCLE2-"/"+[M]LIBCLE3-"/"+[M]LIBCLE4-"/"+[M]LIBCLE5
 When 7 : [M]LIBEL = [M]LIBCLE1-"/"-[M]LIBCLE2-"/"+[M]LIBCLE3-"/"+[M]LIBCLE4-"/"+[M]LIBCLE5-"/"+[M]LIBCLE6
 When 8 : [M]LIBEL = [M]LIBCLE1-"/"-[M]LIBCLE2-"/"+[M]LIBCLE3-"/"+[M]LIBCLE4-"/"+[M]LIBCLE5-"/"+[M]LIBCLE6
          [M]LIBEL -= "/"+[M]LIBCLE7
Endcase
Affzo LIBEL
Affzo 20
If PLEIN
 Call MESSAGE(mess(26,100,1)) From GESECRAN : # Tableau plein
Endif
Filter [SAP]
Return

#############################################################################
$REMPLIT
nolign = NOL+1
If nolign>dim([M]CLE)-1
 PLEIN = 1 : Return
Endif
Case [M]NIVEAU
 When 1 : [M]CLE(NOL) = [F:SAP]CRI1
 When 2 : [M]CLE(NOL) = [F:SAP]CRI2
 When 3 : [M]CLE(NOL) = [F:SAP]CRI3
 When 4 : [M]CLE(NOL) = [F:SAP]CRI4
 When 5 : [M]CLE(NOL) = [F:SAP]CRI5
 When 6 : [M]CLE(NOL) = [F:SAP]CRI6
 When 7 : [M]CLE(NOL) = [F:SAP]CRI7
 When 8 : [M]CLE(NOL) = [F:SAP]CRI8
Endcase

[M]LIBCLE(NOL) = [M]CLE(NOL)

Call CHARGE([M]LIBCLE(NOL),CODTYP([M]NIVEAU),[M]NOLIB([M]NIVEAU),[M]LONG([M]NIVEAU),[M]CLE(NOL))
&    From FMTVAR

Call LIBCLE([M]INTCLE(NOL),NOL)

For [SAP]CLE
 For I=1 To [M]NBRAMT
  Case I
   When 1 : [M]AMT1(NOL) += [F:SAP]AMT(0)
   When 2 : [M]AMT2(NOL) += [F:SAP]AMT(1)
   When 3 : [M]AMT3(NOL) += [F:SAP]AMT(2)
   When 4 : [M]AMT4(NOL) += [F:SAP]AMT(3)
   When 5 : [M]AMT5(NOL) += [F:SAP]AMT(4)
   When 6 : [M]AMT6(NOL) += [F:SAP]AMT(5)
   When 7 : [M]AMT7(NOL) += [F:SAP]AMT(6)
   When 8 : [M]AMT8(NOL) += [F:SAP]AMT(7)
   When 9 : [M]AMT9(NOL) += [F:SAP]AMT(8)
   When 10: [M]AMT10(NOL)+= [F:SAP]AMT(9)
  Endcase
 Next I
Next SAP

If [M]NIVEAU<MAXCRI
 CRITERE = 'COD="'+[F:PS2]UPDCOD+'" & CPY="'+[M]CPY+'" & FCY="'+[M]FCY+'"'
 Case [M]NIVEAU
  When 1
   CRITERE += '& CRI1="'+[M]CLE(NOL)+'" & CRI2<>"$$$"'
  When 2
   CRITERE += '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE(NOL)+'" & CRI3<>"$$$"'
  When 3
   CRITERE += '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE(NOL)+'" & CRI4<>"$$$"'
  When 4
   CRITERE += '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE3+'" & CRI4="'+[M]CLE(NOL)+'"'
   CRITERE += '& CRI5<>"$$$"'
  When 5
   CRITERE += '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE3+'" & CRI4="'+[M]CLE4+'"'
   CRITERE += '& CRI5="'+[M]CLE(NOL)+'"'
   CRITERE += '& CRI6<>"$$$"'
  When 6
   CRITERE += '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE3+'" & CRI4="'+[M]CLE4+'"'
   CRITERE += '& CRI5="'+[M]CLE5+'" & CRI6="'+[M]CLE(NOL)+'"'
   CRITERE += '& CRI7<>"$$$"'
  When 7
   CRITERE += '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE3+'" & CRI4="'+[M]CLE4+'"'
   CRITERE += '& CRI5="'+[M]CLE5+'" & CRI6="'+[M]CLE6+'" & CRI7="'+[M]CLE(NOL)+'"'
   CRITERE += '& CRI8<>"$$$"'
 Endcase
 Filter [SAP2] Where evalue(CRITERE)
 Read [SAP2]SAP0 First
 If !fstat : [M]FLG(NOL) = "*" : Endif
 Filter [SAP2]
Endif
NOL += 1
Return

#############################################################################
Subprog LIBCLE(VALEUR,NOL)
Variable Char    VALEUR
Value    Integer NOL
Local    Integer I, J, K, NBCLE
Local    Char    CLE(30)(1..16), CLE1(30), CLE2(250), WCLE(250)
If [M]OBJ([M]NIVEAU)<>""
 Call LECTURE("ATY",[M]CODTYP([M]NIVEAU),"") From CONTOBJ
 If [F:ATY]OBJLIEN="ADI"
  Call LECTURE([M]OBJ([M]NIVEAU),[M]CLE(NOL),num$([M]NOLIB([M]NIVEAU))) From CONTOBJ
 Else
  Call LECTURE([M]OBJ([M]NIVEAU),[M]CLE(NOL),"") From CONTOBJ
 Endif
 If !fstat
  Read [ATB]ABRFIC = [M]ABR([M]NIVEAU)
  Read [ATZ]CODZONE = [F:ATB]CODFIC;[M]INTIT([M]NIVEAU)
  Case [F:ATZ]CODTYP
   When "ATX"
    Call TEXTE(evalue("[F:"+[M]ABR([M]NIVEAU)+"]"+[M]INTIT([M]NIVEAU)),VALEUR) From OBJDIV
   When "AXX","AX1","AX2","AX3"
    Read [ATI]NUMLIG(2) = [F:ATB]CODFIC;1
    WCLE = [F:ATI]DESCRIPT
    Raz CLE, NBCLE
    While WCLE<>""
     K = instr(1,WCLE,"+")
     J = instr(1,WCLE,"-")
     If K & J
      K = min(K,J)
     Elsif J & !K
      K = J
     Endif
     NBCLE += 1
     If K
      CLE(NBCLE) = left$(WCLE,K-1)
      WCLE       = right$(WCLE,K+1)
     Else
      CLE(NBCLE) = WCLE
      WCLE       = ""
     Endif
    Wend
    CLE1 = num$(evalue("[F:"+[M]ABR([M]NIVEAU)+"]"+CLE(1)))
    CLE2 = ""
    If NBCLE>1
     For K=2 To NBCLE
      If CLE2<>"" : CLE2 += "~" : Endif
      CLE2 += num$(evalue("[F:"+[M]ABR([M]NIVEAU)+"]"+CLE(K)))
     Next K
    Endif
    Call LECTEXTRA(VALEUR,[F:ATB]CODFIC,[M]INTIT([M]NIVEAU),CLE1,CLE2) From ATEXTRA
   When Default
    VALEUR = evalue("[F:"+[M]ABR([M]NIVEAU)+"]"+[M]INTIT([M]NIVEAU))
  Endcase
 Endif
Elsif [M]TYP([M]NIVEAU)=1
 VALEUR = mess(val([M]CLE(NOL)),[M]NOLIB([M]NIVEAU),1)
Endif
End

#############################################################################
Subprog VERF_NIVEAU(OK)
Variable Integer OK
Local    Char    CRITERE(250)
OK = 1
CRITERE = 'COD="'+[F:PS2]UPDCOD+'"'
If [M]DATDEB<>[0/0/0]
 CRITERE -= '& DAT>=['+format$(GFMD,[M]DATDEB)+']'
Endif
If [M]DATFIN<>[0/0/0]
 CRITERE -= '& DAT<=['+format$(GFMD,[M]DATFIN)+']'
Endif
If [M]CPY<>""
 Filter [SAP] Where evalue(CRITERE) & CPY=""
 Read [SAP]SAP0 First
 Filter [SAP]
 If !fstat
  GMESSAGE = mess(48,101,1) : # Des prévisions ont déjà été saisi au niveau dossier
  mkstat = 1 : OK = 0 : End
 Endif
 CRITERE -= '& CPY="'+[M]CPY+'"'
Endif
If [M]FCY<>""
 Filter [SAP] Where evalue(CRITERE) & FCY=""
 Read [SAP]SAP0 First
 Filter [SAP]
 If !fstat
  GMESSAGE = mess(49,101,1) : # Des prévisions ont déjà été saisi au niveau société
  mkstat = 1 : OK = 0 : End
 Endif
Else
 Filter [SAP] Where evalue(CRITERE) & FCY<>""
 Read [SAP]SAP0 First
 Filter [SAP]
 If !fstat
  GMESSAGE = mess(50,101,1) : # Des prévisions ont déjà été saisi au niveau site
  mkstat = 1 : OK = 0 : End
 Endif
Endif
End

####################################################################
##  Etiquettes du masque SAISTA
####################################################################

Subprog C_COD(VALEUR)
Variable Char    VALEUR()
Local Integer I , OK
Read [PS2]PS20 = VALEUR
If fstat
 GMESSAGE = mess(84,141,1) : # Code inexistant
 mkstat = 2 : End
Endif
OK = 0
For [PSL] Where COD=[F:PS2]COD
 If [F:PSL]FRTFLG=2 : OK = 1 : Break : Endif
Next I
If !OK
 GMESSAGE = mess(185,124,1) : # Pas de prévision sur ce code
 mkstat = 2 : End
Endif
If [F:PS2]UPDLEV<2 : # Dossier
 If GNBAUZ<>GNBSITE & GUSRFCY<>"\"
  GMESSAGE = mess(4,104,1) : # Vous n'avez pas les droits pour ce code
  mkstat = 2 : End
 Endif
Endif
End

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
If [M]COD<>""
 Call LECTURE("PS2",[M]COD,"") From CONTOBJ
 If [F:PS2]UPDLEV<2 : mkstat = 1 : End : Endif
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If [F:PS2]UPDLEV=2
 If VALEUR=""
  GMESSAGE = mess(10,123,1)+"\"+mess(46,104,1)-":"-mess([F:PS2]UPDLEV,45,1) : # Zone obligatoire/Niveau x
  mkstat = 1 : End
 Else
  Call CONTALLFCY(VALEUR) From EXEFNC
 Endif
Endif
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If [M]COD<>""
 Call LECTURE("PS2",[M]COD,"") From CONTOBJ
 If [F:PS2]UPDLEV<3 : mkstat = 1 : End : Endif
Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]CPY=""
 GMESSAGE = mess(21,104,1) : # Société ou site inexistant
 mkstat = 2 : End
Endif
End

Subprog D_DATDEB(VALEUR)
Variable Date     VALEUR
If GDATEDEB<>[0/0/0]
 VALEUR = GDATEDEB
Else
 VALEUR = gdat$(1,1,year(datesyst))
Endif
End

Subprog D_DATFIN(VALEUR)
Variable Date     VALEUR
If GDATEFIN<>[0/0/0]
 VALEUR = GDATEFIN
Else
 VALEUR = gdat$(31,12,year(datesyst))
Endif
End

Subprog C_DATFIN(VALEUR)
Variable Date VALEUR
Local Integer OK
[M]DATFIN = VALEUR
Gosub SETPER
VALEUR = [M]DATFIN
Affzo DATDEB, DATFIN
Call VERF_NIVEAU(OK)
End

Subprog C_NBLIG
If find(status,65,68,83)
 Local Integer NOL , OK
 If status=65 : nolign1=nolign : Endif
 OK = 1
 For NOL=nolign-1 To nolign1-1
  If [M]FLG(NOL)<>"" : OK = 0 : Break : Endif
 Next NOL
 If !OK
  Call MESSAGE(mess(23,134,1)) From GESECRAN : # Annulation impossible
  mkstat = 2 : End
 Endif
Endif
End

Subprog AS_LIBCLE(VALEUR)
Variable Char VALEUR
If [M]FLG(nolign-1)<>"" : mkstat = 2 : End : Endif
End

Subprog C_LIBCLE(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If clalev([ATY])=0 : Local File ATYPE [ATY] : Endif
OK = 0
If [M]CODTYP([M]NIVEAU)<>""
 Read [ATY]CODTYP = [M]CODTYP([M]NIVEAU)
 If !fstat & [F:ATY]OBJLIEN<>""
  OK = 1
 Endif
Endif
If OK
 Local Char SUPP(10)
 If [F:ATY]OBJLIEN="ADI"
  SUPP = num$([M]NOLIB([M]NIVEAU))
  If SUPP="0" : End : Endif
 Elsif [F:ATY]OBJLIEN<>""
  SUPP = "" : End : # Pas géré pour le moment
 Endif
 Call CONTROLE([F:ATY]OBJLIEN,"!$",VALEUR,SUPP,mkstat) From CONTOBJ
 If mkstat : End : Endif
Endif
End

Subprog AM_LIBCLE(VALEUR)
Variable Char    VALEUR()
Call LIBCLE([M]INTCLE(nolign-1),nolign-1)
End

Subprog AS_AMT1(VALEUR)
Variable Decimal VALEUR
If [M]FLG(nolign-1)<>"" : mkstat = 2 : End : Endif
If [M]FRTFLG(0)<>2 : mkstat = 1 : End : Endif
End

