Variable Decimal VALEUR
If [M]FLG(nolign-1)<>"" : mkstat = 2 : End : Endif
If [M]FRTFLG(7)<>2 : mkstat = 1 : End : Endif
End

Subprog AS_AMT9(VALEUR)
Variable Decimal VALEUR
If [M]FLG(nolign-1)<>"" : mkstat = 2 : End : Endif
If [M]FRTFLG(8)<>2 : mkstat = 1 : End : Endif
End

Subprog AS_AMT10(VALEUR)
Variable Decimal VALEUR
If [M]FLG(nolign-1)<>"" : mkstat = 2 : End : Endif
If [M]FRTFLG(9)<>2 : mkstat = 1 : End : Endif
End

$VERIF
ALERTE = 0
Gosub SETPER
Read [PS2]PS20 = [M]COD
If !fstat
 If NBPER > 1
  ALERTE =0
  Filter [SAP] Where COD = [F:PS2]UPDCOD & CPY = [M]CPY & FCY = [M]FCY & DAT >= [M]DATDEB & DAT <= [M]DATFIN
&                    & sum(AMT) > 0
  For [SAP]SAP0
   ALERTE = 1 : Break
  Next
  DATA = [F:SAP]DAT
  Filter [SAP]
 Endif
Endif
Return
