#<AdxTL>@(#)11.0.0.0 $Revision$
Local Char PARAM(30)(1..3) , VALEUR(10)
PARAM(1) = "ZZMB2"
PARAM(2) = ""
PARAM(3) = ""
Call SAISIE_CHAR(VALEUR,PARAM,"FSAISTA","SAISTA","") From GSAISIE
End

#############################################################################
$ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "BOUTON"       : Gosub BOUTON
 When "OK"           : Gosub OK
 When "ENR"          : Gosub ENREG
 When "ABA"          : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When Default
Endcase    
Return

#############################################################################
$OUVRE
If clalev([F:SAP])=0  : Local File STATPRV   [SAP]  : Endif
If clalev([F:SAP2])=0 : Local File STATPRV   [SAP2] : Endif
If clalev([F:SAT0])=0 : Local File STAT      [SAT0] : Endif
If clalev([F:PS1])=0  : Local File PARSTA1   [PS1]  : Endif
If clalev([F:PS2])=0  : Local File PARSTA2   [PS2]  : Endif
If clalev([F:PSL])=0  : Local File PARSTALIG [PSL]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY  [FCY]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY   [CPY]  : Endif
If clalev([F:FGR])=0  : Local File FACGROUP  [FGR]  : Endif
If clalev([F:ATB])=0  : Local File ATABLE    [ATB]  : Endif
If clalev([F:ATZ])=0  : Local File ATABZON   [ATZ]  : Endif
If clalev([F:ATI])=0  : Local File ATABIND   [ATI]  : Endif
If clalev([F:ATY])=0  : Local File ATYPE     [ATY]  : Endif
If clalev([F:AOB])=0  : Local File AOBJET    [AOB]  : Endif
If clalev([F:ATX])=0  : Local File ATEXTE    [ATX]  : Endif
If clalev([F:ACS])=0  : Local File ACCES     [ACS]  : Endif
If clalev([F:AXX])=0  : Local File ATEXTRA   [AXX]  : Endif
If clalev([F:AMP])=0  : Local File AMSKPAR   [AMP]  : Endif
Return

#############################################################################
$DEBUT
Local Date    DAT1 , DAT2 , DATA
Local Decimal TOTAL(10), VALZON
Local Char    TYPFMT(5) , OPTFMT(20) , CHFMT(30) , NUMFMT(5) , CHAINE(80)
Local Integer I , J , K , P , NOL , PLEIN , ALERTE
Local Integer LNGFMT
Local Integer DROIT
Local Char    CRITERE(250)
Local Integer OKRECH
Local Char    CODE(30)
Local Integer MAXCRI : MAXCRI = dim([F:PS2]TBL)
Local Char    INTCLENIV(30)(1..MAXCRI)

Local Mask SAISTA  [SAP] , CRISTA [DIA]
Raz [M]

If PARAM(1)<>""
 Call C_COD(PARAM(1))
 If mkstat
  FIN = 1 : Return
 Else
  [M]COD = PARAM(1)
  [M]CPY = PARAM(2)
  [M]FCY = PARAM(3)
  Call AS_CPY([M]CPY)
  Call AS_FCY([M]FCY)
  Call D_DATDEB([M]DATDEB)
  Call D_DATFIN([M]DATFIN)
  Gosub SETPER
  Call VERF_NIVEAU(OK)
  If OK
   Gosub CHARGE
   Grizo [M]COD
   OKRECH = 1
  Endif
  CODE = PARAM(1)
 Endif
Endif
Return

#############################################################################
$SETBOUT
Local Char    INFO(30)
Local Integer DROIT
Call LECACC([F:PS2]ACS,DROIT) From SUBACS
Raz INFO
If REP="M"
 Call VIREBOUT(CHMEN,"CIAPS") From GOBJET
Else
 If [M]COD=""
  Call VIREBOUT(CHMEN,"C") From GOBJET : # Critères
 Endif
 If [M]COD="" | !DROIT
  Call VIREBOUT(CHMEN,"I") From GOBJET : # Init
  Call VIREBOUT(CHMEN,"A") From GOBJET : # Augment
 Endif
 If [M]NIVEAU>1
  INFO += "  -"-func AFNC.TEXTRA("PARSTA2","FLDINTIT",[F:PS2]COD,num$([M]NIVEAU-1))
 Endif
 If [M]NIVEAU<=1
  Call VIREBOUT(CHMEN,"P") From GOBJET : # Niveau -
 Endif
 If [F:PS2]NBRFLD>[M]NIVEAU
  INFO = "+"-func AFNC.TEXTRA("PARSTA2","FLDINTIT",[F:PS2]COD,num$([M]NIVEAU+1))
 Endif
 If [F:PS2]NBRFLD<=[M]NIVEAU
  Call VIREBOUT(CHMEN,"S") From GOBJET : # Niveau +
 Endif
Endif
Inftxt INFO At 2
Return

#############################################################################
$BOUTON
Case BOUT
 When "C" : Gosub LECTURE
 When "I" : Gosub LECTURE
 When "A" : Gosub LECTURE
 When "P" : Gosub PRECEDENT
 When "S" : Gosub SUIVANT
Endcase
Return

#############################################################################
$ABANDON
Gosub LECTURE
REP = ""
Gosub DEGRISE
zonsui = "NBLIG("+num$(SAVNOL-1)+")"
Return

#############################################################################
$OK
If REP="M"
 Gosub ENREG
Endif
Return

#############################################################################
$SETPER
DAT1 = [M]DATDEB
DAT2 = [M]DATFIN
## Tableau des périodes
Local Integer NBPER
Local Date    DATPER(1..1000) , DATF
Case [F:PS2]PERTYP
 When 2
  DAT1 = aweek(week(DAT1),year(DAT1))
 When 3
  If day(DAT1)>15
   DAT1 = gdat$(16,month(DAT1),year(DAT1))
  Else
   DAT1 = gdat$(1,month(DAT1),year(DAT1))
  Endif
 When 4
  DAT1 = gdat$(1,month(DAT1),year(DAT1))
 When 5
  DAT1 = gdat$(1,3*int((month(DAT1)-1)/3)+1,year(DAT1))
 When 6
  DAT1 = gdat$(1,1,year(DAT1))
 When 7
  If day(DAT1)>20
   DAT1 = gdat$(21,month(DAT1),year(DAT1))
  Elsif day(DAT1)>10
   DAT1 = gdat$(11,month(DAT1),year(DAT1))
  Else
   DAT1 = gdat$(01,month(DAT1),year(DAT1))
  Endif
Endcase
DATF = DAT2
DAT2 = DAT1
NBPER = 0
Repeat
 NBPER += 1
 If NBPER>dim(DATPER) : Break : Endif
 DATPER(NBPER) = DAT2
 Case [F:PS2]PERTYP
  When 1
   DAT2 += 1
  When 2
   DAT2 += 7
  When 3
   If day(DAT2)>15
    DAT2 = eomonth(DAT2)+1
   Else
    DAT2 = gdat$(16,month(DAT2),year(DAT2))
   Endif
  When 4
   DAT2 = addmonth(DAT2,1)
  When 5
   DAT2 = addmonth(DAT2,3)
  When 6
   DAT2 = addmonth(DAT2,12)
  When 7
   If day(DAT2)>20
    DAT2 = eomonth(DAT2)+1
   Elsif day(DAT2)>10
    DAT2 = gdat$(21,month(DAT2),year(DAT2))
   Else
    DAT2 = gdat$(11,month(DAT2),year(DAT2))
   Endif
 Endcase
Until DAT2>DATF
[M]DATDEB = DAT1
[M]DATFIN = DAT2-1
Return

#############################################################################
$APRES_MODIF
Case COUZON
 When "COD","CPY","FCY","DATDEB","DATFIN"
  Case evalue("type([M]"+COUZON+")")
   When 1,2,4,5,6,7
    Assign "[M]"+COUZON With val(CZ)
   When Default
    Assign "[M]"+COUZON With CZ
  Endcase
  If [M]COD<>"" & [M]DATDEB<>[0/0/0] & [M]DATFIN<>[0/0/0]
   Call LECTURE("PS2",[M]COD,"") From CONTOBJ
   If [F:PS2]UPDLEV=1 or [M]CPY<>""
    Call VERF_NIVEAU(OK)
    If OK
     Gosub SETPER
     Gosub CHARGE
     Gosub SETBOUT
     OKRECH = 1
    Else
     Call ERREUR(GMESSAGE) From GESECRAN
     OKRECH = 0
    Endif
   Endif
  Endif
 When Default
  SAVNOL = nolign
  If OKRECH
   If !DROIT
    Call ERREUR(mess(9,123,1)) From GESECRAN : # Modification interdite
    mkstat = 2 : Return
   Endif
   REP = "M"
   Gosub GRISE
   Gosub SETBOUT
  Else
   mkstat = 2
  Endif
Endcase
Return

$GRISE
Grizo [M]COD, CPY, FCY, DATDEB, DATFIN
Return

$DEGRISE
If CODE="" : Actzo [M]COD : Endif
Actzo  CPY, FCY, DATDEB, DATFIN
Return

#############################################################################
$SUIVANT
Local Integer LIG
LIG = nolign-1
If [M]NIVEAU<MAXCRI & [F:PS2]NBRFLD>[M]NIVEAU & nolign<=[M]NBLIG
 Case [M]NIVEAU
  When 1 : [M]CLE1 = [M]CLE(nolign-1) : [M]LIBCLE1 = [M]LIBCLE(nolign-1) : [M]INTCLE1 = [M]INTCLE(nolign-1)
  When 2 : [M]CLE2 = [M]CLE(nolign-1) : [M]LIBCLE2 = [M]LIBCLE(nolign-1) : [M]INTCLE2 = [M]INTCLE(nolign-1)
  When 3 : [M]CLE3 = [M]CLE(nolign-1) : [M]LIBCLE3 = [M]LIBCLE(nolign-1) : [M]INTCLE3 = [M]INTCLE(nolign-1)
  When 4 : [M]CLE4 = [M]CLE(nolign-1) : [M]LIBCLE4 = [M]LIBCLE(nolign-1) : [M]INTCLE4 = [M]INTCLE(nolign-1)
  When 5 : [M]CLE5 = [M]CLE(nolign-1) : [M]LIBCLE5 = [M]LIBCLE(nolign-1) : [M]INTCLE5 = [M]INTCLE(nolign-1)
  When 6 : [M]CLE6 = [M]CLE(nolign-1) : [M]LIBCLE6 = [M]LIBCLE(nolign-1) : [M]INTCLE6 = [M]INTCLE(nolign-1)
  When 7 : [M]CLE7 = [M]CLE(nolign-1) : [M]LIBCLE7 = [M]LIBCLE(nolign-1) : [M]INTCLE7 = [M]INTCLE(nolign-1)
 Endcase
 [M]NIVEAU += 1
 Call LECTEXTRA([M]LIBCRIT,"PARSTA2","FLDINTIT",[PS2]COD,num$([M]NIVEAU)) From ATEXTRA
 Gosub LECTURE
 REP = ""
 Gosub DEGRISE
 Gosub SETBOUT
 LIG = 0
Endif
zonsui = "[M]NBLIG("+num$(LIG)+")"
Return

#############################################################################
$PRECEDENT
Local Integer LIG
LIG = nolign-1
If [M]NIVEAU>1
 Local Char    OLD(30)
 Local Integer K
 [M]NIVEAU -= 1
 Call LECTEXTRA([M]LIBCRIT,"PARSTA2","FLDINTIT",[PS2]COD,num$([M]NIVEAU)) From ATEXTRA
 Gosub LECTURE
 REP = ""
 Gosub DEGRISE
 Gosub SETBOUT
 Case [M]NIVEAU
  When 1 : OLD = [M]CLE1
  When 2 : OLD = [M]CLE2
  When 3 : OLD = [M]CLE3
  When 4 : OLD = [M]CLE4
  When 5 : OLD = [M]CLE5
  When 6 : OLD = [M]CLE6
  When 7 : OLD = [M]CLE7
 Endcase
 K = find(OLD,[M]CLE(0..[M]NBLIG-1))
 If K
  LIG = K-1
 Endif
Endif
zonsui = "[M]NBLIG("+num$(LIG)+")"
Return

#########################################################################
$ENREG
Gosub VERIF
If ALERTE
 Call OUINON(mess(172,139,1)-":"-num$(DATA),ALERTE) From GESECRAN 
 # Attention vous allez écraser les valeurs de la periode
 If ALERTE <> 2
  #Gosub ABANDON
  OK = 0 : Return
 Endif
Endif
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=1
 REP = ""
 Gosub DEGRISE
Endif
zonsui = "NBLIG("+num$(SAVNOL-1)+")"
Return

$TR1
GOK = 1
Trbegin [SAP]
 CRITERE  = 'COD="'+[F:PS2]UPDCOD+'"'
 CRITERE -= '& CPY="'+[M]CPY+'"'
 CRITERE -= '& FCY="'+[M]FCY+'"'
 CRITERE -= '& DAT>=['+format$(GFMD,DATPER(1))+']'
 CRITERE -= '& DAT<=['+format$(GFMD,DATPER(NBPER))+']'
 Case NIVEAU
  When 1
   Case MAXCRI
    When 4 : CRITERE -= '& CRI2="$$$" & CRI3="$$$" & CRI4="$$$"'
    When 5 : CRITERE -= '& CRI2="$$$" & CRI3="$$$" & CRI4="$$$" & CRI5="$$$"'
    When 6 : CRITERE -= '& CRI2="$$$" & CRI3="$$$" & CRI4="$$$" & CRI5="$$$" & CRI6="$$$"'
    When 7 : CRITERE -= '& CRI2="$$$" & CRI3="$$$" & CRI4="$$$" & CRI5="$$$" & CRI6="$$$" & CRI7="$$$"'
    When 8 : CRITERE -= '& CRI2="$$$" & CRI3="$$$" & CRI4="$$$" & CRI5="$$$" & CRI6="$$$" & CRI7="$$$"'
             CRITERE -= '& CRI8="$$$"'
   Endcase
  When 2
   Case MAXCRI
    When 4 : CRITERE -= '& CRI1="'+[M]CLE1+'"& CRI3="$$$" & CRI4="$$$"'
    When 5 : CRITERE -= '& CRI1="'+[M]CLE1+'"& CRI3="$$$" & CRI4="$$$" & CRI5="$$$"'
    When 6 : CRITERE -= '& CRI1="'+[M]CLE1+'"& CRI3="$$$" & CRI4="$$$" & CRI5="$$$" & CRI6="$$$"'
    When 7 : CRITERE -= '& CRI1="'+[M]CLE1+'"& CRI3="$$$" & CRI4="$$$" & CRI5="$$$" & CRI6="$$$" & CRI7="$$$"'
    When 8 : CRITERE -= '& CRI1="'+[M]CLE1+'"& CRI3="$$$" & CRI4="$$$" & CRI5="$$$" & CRI6="$$$" & CRI7="$$$"'
             CRITERE -= '& CRI7="$$$" & CRI8="$$$"'
   Endcase
  When 3
   Case MAXCRI
    When 4 : CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI4="$$$"'
    When 5 : CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI4="$$$" & CRI5="$$$"'
    When 6 : CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI4="$$$" & CRI5="$$$" & CRI6="$$$"'
    When 7 : CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI4="$$$" & CRI5="$$$" & CRI6="$$$"'
             CRITERE -= '& CRI7="$$$"'
    When 8 : CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI4="$$$" & CRI5="$$$" & CRI6="$$$"'
             CRITERE -= '& CRI7="$$$" & CRI8="$$$"'
   Endcase
  When 4
   Case MAXCRI
    When 4 : CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE3+'"'
    When 5 : CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE3+'" & CRI5="$$$"'
    When 6 : CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE3+'" & CRI5="$$$"'
             CRITERE -= '& CRI6="$$$"'
    When 7 : CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE3+'" & CRI5="$$$"'
             CRITERE -= '& CRI6="$$$" & CRI7="$$$"'
    When 8 : CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE3+'" & CRI5="$$$"'
             CRITERE -= '& CRI6="$$$" & CRI7="$$$" & CRI8="$$$"'
   Endcase
  When 5
   Case MAXCRI
    When 5 : CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE3+'"'
             CRITERE -= '& CRI4="'+[M]CLE4+'"'
    When 6 : CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE3+'"'
             CRITERE -= '& CRI4="'+[M]CLE4+'" & CRI6="$$$"'
    When 7 : CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE3+'"'
             CRITERE -= '& CRI4="'+[M]CLE4+'" & CRI6="$$$" & CRI7="$$$"'
    When 8 : CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE3+'"'
             CRITERE -= '& CRI4="'+[M]CLE4+'" & CRI6="$$$"  & CRI7="$$$" & CRI8="$$$"'
   Endcase
  When 6
   Case MAXCRI
    When 6 : CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE3+'"'
             CRITERE -= '& CRI4="'+[M]CLE4+'" & CRI5="'+[M]CLE5+'"'
    When 7 : CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE3+'"'
             CRITERE -= '& CRI4="'+[M]CLE4+'" & CRI5="'+[M]CLE5+'" & CRI7="$$$"'
    When 8 : CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE3+'"'
             CRITERE -= '& CRI4="'+[M]CLE4+'" & CRI5="'+[M]CLE5+'" & CRI7="$$$" & CRI8="$$$"'
   Endcase
  When 7
   Case MAXCRI
    When 7 : CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE3+'"'
             CRITERE -= '& CRI4="'+[M]CLE4+'" & CRI5="'+[M]CLE5+'" & CRI6="'+[M]CLE6+'"'
    When 8 : CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE3+'"'
             CRITERE -= '& CRI4="'+[M]CLE4+'" & CRI5="'+[M]CLE5+'" & CRI6="'+[M]CLE6+'" & CRI8="$$$"'
   Endcase
  When 8
   Case MAXCRI
    When 8 : CRITERE -= '& CRI1="'+[M]CLE1+'" & CRI2="'+[M]CLE2+'" & CRI3="'+[M]CLE3+'"'
             CRITERE -= '& CRI4="'+[M]CLE4+'" & CRI5="'+[M]CLE5+'" & CRI6="'+[M]CLE6+'"'
             CRITERE -= '& CRI7="'+[M]CLE7+'"'
   Endcase
 Endcase
 Delete [SAP] Where evalue(CRITERE)
 If fstat=1
  GOK = -1 : GLOCK = "$STATPRV"-COD-CPY-FCY : Goto ROLL_TR1
 Endif
 For nolign=1 To [M]NBLIG
  [F:SAP]COD = [F:PS2]UPDCOD
  [F:SAP]CPY = [M]CPY
  [F:SAP]FCY = [M]FCY
  Case [M]NIVEAU
   When 1
    [F:SAP]CRI1 = [M]CLE(nolign-1)
    For I=2 To MAXCRI
     Case I
      When 2 : [F:SAP]CRI2 = "$$$"
      When 3 : [F:SAP]CRI3 = "$$$"
      When 4 : [F:SAP]CRI4 = "$$$"
      When 5 : [F:SAP]CRI5 = "$$$"
      When 6 : [F:SAP]CRI6 = "$$$"
      When 7 : [F:SAP]CRI7 = "$$$"
      When 8 : [F:SAP]CRI8 = "$$$"
     Endcase
    Next I    
   When 2
    [F:SAP]CRI1 = [M]CLE1
    [F:SAP]CRI2 = [M]CLE(nolign-1)
    For I=3 To MAXCRI
     Case I
      When 3 : [F:SAP]CRI3 = "$$$"
      When 4 : [F:SAP]CRI4 = "$$$"
      When 5 : [F:SAP]CRI5 = "$$$"
      When 6 : [F:SAP]CRI6 = "$$$"
      When 7 : [F:SAP]CRI7 = "$$$"
      When 8 : [F:SAP]CRI8 = "$$$"
     Endcase
    Next I    
   When 3
    [F:SAP]CRI1 = [M]CLE1
    [F:SAP]CRI2 = [M]CLE2
    [F:SAP]CRI3 = [M]CLE(nolign-1)
    For I=4 To MAXCRI
     Case I
      When 4 : [F:SAP]CRI4 = "$$$"
      When 5 : [F:SAP]CRI5 = "$$$"
      When 6 : [F:SAP]CRI6 = "$$$"
      When 7 : [F:SAP]CRI7 = "$$$"
      When 8 : [F:SAP]CRI8 = "$$$"
     Endcase
    Next I    
   When 4
    [F:SAP]CRI1 = [M]CLE1
    [F:SAP]CRI2 = [M]CLE2
    [F:SAP]CRI3 = [M]CLE3
    [F:SAP]CRI4 = [M]CLE(nolign-1)
    For I=5 To MAXCRI
     Case I
      When 5 : [F:SAP]CRI5 = "$$$"
      When 6 : [F:SAP]CRI6 = "$$$"
      When 7 : [F:SAP]CRI7 = "$$$"
      When 8 : [F:SAP]CRI8 = "$$$"
     Endcase
    Next I    
   When 5
    [F:SAP]CRI1 = [M]CLE1
    [F:SAP]CRI2 = [M]CLE2
    [F:SAP]CRI3 = [M]CLE3
    [F:SAP]CRI4 = [M]CLE4
    [F:SAP]CRI5 = [M]CLE(nolign-1)
    For I=6 To MAXCRI
     Case I
      When 6 : [F:SAP]CRI6 = "$$$"
      When 7 : [F:SAP]CRI7 = "$$$"
      When 8 : [F:SAP]CRI8 = "$$$"
     Endcase
    Next I    
   When 6
    [F:SAP]CRI1 = [M]CLE1
    [F:SAP]CRI2 = [M]CLE2
    [F:SAP]CRI3 = [M]CLE3
    [F:SAP]CRI4 = [M]CLE4
    [F:SAP]CRI5 = [M]CLE5
    [F:SAP]CRI6 = [M]CLE(nolign-1)
    For I=7 To MAXCRI
     Case I
      When 7 : [F:SAP]CRI7 = "$$$"
      When 8 : [F:SAP]CRI8 = "$$$"
     Endcase
    Next I    
   When 7
    [F:SAP]CRI1 = [M]CLE1
    [F:SAP]CRI2 = [M]CLE2
    [F:SAP]CRI3 = [M]CLE3
    [F:SAP]CRI4 = [M]CLE4
    [F:SAP]CRI5 = [M]CLE5
    [F:SAP]CRI6 = [M]CLE6
    [F:SAP]CRI7 = [M]CLE(nolign-1)
    For I=8 To MAXCRI
     Case I
      When 8 : [F:SAP]CRI8 = "$$$"
     Endcase
    Next I    
   When 8
    [F:SAP]CRI1 = [M]CLE1
    [F:SAP]CRI2 = [M]CLE2
    [F:SAP]CRI3 = [M]CLE3
    [F:SAP]CRI4 = [M]CLE4
    [F:SAP]CRI5 = [M]CLE5
    [F:SAP]CRI6 = [M]CLE6
    [F:SAP]CRI7 = [M]CLE7
    [F:SAP]CRI8 = [M]CLE(nolign-1)
  Endcase
  Raz TOTAL
  For P=1 To NBPER
   [F:SAP]DAT = DATPER(P)
   For K=0 To dim([F:SAP]AMT)-1
    If [M]FRTFLG(K)=2
     Case K
      When 0 : VALZON = [M]AMT1(nolign-1)
      When 1 : VALZON = [M]AMT2(nolign-1)
      When 2 : VALZON = [M]AMT3(nolign-1)
      When 3 : VALZON = [M]AMT4(nolign-1)
      When 4 : VALZON = [M]AMT5(nolign-1)
      When 5 : VALZON = [M]AMT6(nolign-1)
      When 6 : VALZON = [M]AMT7(nolign-1)
      When 7 : VALZON = [M]AMT8(nolign-1)
      When 8 : VALZON = [M]AMT9(nolign-1)
      When 9 : VALZON = [M]AMT10(nolign-1)
     Endcase
     [F:SAP]AMT(K) = arr(P*VALZON/NBPER,1)-arr((P-1)*VALZON/NBPER,1)
    Endif
   Next K
   Write [SAP]
   If fstat
    GOK = 0 : Call FSTA("SAP") From GLOCK : Break 2
   Endif
   Raz INTCLENIV
   Case [M]NIVEAU
    When 1
     INTCLENIV(1) = [M]INTCLE(nolign-1)
    When 2
     INTCLENIV(1) = [M]INTCLE1
     INTCLENIV(2) = [M]INTCLE(nolign-1)
    When 3
     INTCLENIV(1) = [M]INTCLE1
     INTCLENIV(2) = [M]INTCLE2
     INTCLENIV(3) = [M]INTCLE(nolign-1)
    When 4
     INTCLENIV(1) = [M]INTCLE1
     INTCLENIV(2) = [M]INTCLE2
     INTCLENIV(3) = [M]INTCLE3
     INTCLENIV(4) = [M]INTCLE(nolign-1)
    When 5
     INTCLENIV(1) = [M]INTCLE1
     INTCLENIV(2) = [M]INTCLE2
     INTCLENIV(3) = [M]INTCLE3
     INTCLENIV(4) = [M]INTCLE4
     INTCLENIV(5) = [M]INTCLE(nolign-1)
    When 6
     INTCLENIV(1) = [M]INTCLE1
     INTCLENIV(2) = [M]INTCLE2
     INTCLENIV(3) = [M]INTCLE3
     INTCLENIV(4) = [M]INTCLE4
     INTCLENIV(5) = [M]INTCLE5
     INTCLENIV(6) = [M]INTCLE(nolign-1)
    When 7
     INTCLENIV(1) = [M]INTCLE1
     INTCLENIV(2) = [M]INTCLE2
     INTCLENIV(3) = [M]INTCLE3
     INTCLENIV(4) = [M]INTCLE4
     INTCLENIV(5) = [M]INTCLE5
     INTCLENIV(6) = [M]INTCLE6
     INTCLENIV(7) = [M]INTCLE(nolign-1)
    When 8
     INTCLENIV(1) = [M]INTCLE1
     INTCLENIV(2) = [M]INTCLE2
     INTCLENIV(3) = [M]INTCLE3
     INTCLENIV(4) = [M]INTCLE4
     INTCLENIV(5) = [M]INTCLE5
     INTCLENIV(6) = [M]INTCLE6
     INTCLENIV(7) = [M]INTCLE7
     INTCLENIV(8) = [M]INTCLE(nolign-1)
   Endcase
   Gosub CRESTA
   If GOK<1 : Break 2 : Endif
  Next P
 Next nolign
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Gosub MAJ_NIVEAU
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$MAJ_NIVEAU
If [M]NIVEAU>=8
 For P=1 To NBPER
  Raz TOTAL
  For [SAP2]SAP0 Where COD=[F:PS2]UPDCOD & CPY=[M]CPY & FCY=[M]FCY & DAT=DATPER(P)
&                    & CRI1=[F:SAP]CRI1 & CRI2=[F:SAP]CRI2 & CRI3=[F:SAP]CRI3 & CRI4=[F:SAP]CRI4
&                    & CRI5=[F:SAP]CRI5 & CRI6=[F:SAP]CRI6 & CRI7=[F:SAP]CRI7 & CRI8<>"$$$"
   For I=0 To [M]NBRAMT-1
    TOTAL(I) += [F:SAP2]AMT(I)
   Next I
  Next
  Readlock [SAP2]SAP0 = [F:PS2]UPDCOD;[M]CPY;[M]FCY;DATPER(P);
&                       [F:SAP]CRI1;[F:SAP]CRI2;[F:SAP]CRI3;[F:SAP]CRI4;
&                       [F:SAP]CRI5;[F:SAP]CRI6;[F:SAP]CRI7;"$$$"
  If fstat=1
   GOK = -1 : GLOCK = "$STATPRV"-[F:PS2]UPDCOD-[M]CPY-[M]FCY : Break
  Elsif fstat
   [F:SAP2]COD = [F:PS2]UPDCOD
   [F:SAP2]CPY = [M]CPY
   [F:SAP2]FCY = [M]FCY
   [F:SAP2]DAT = DATPER(P)
   [F:SAP2]CRI1 = [F:SAP]CRI1
   [F:SAP2]CRI2 = [F:SAP]CRI2
   [F:SAP2]CRI3 = [F:SAP]CRI3
   [F:SAP2]CRI4 = [F:SAP]CRI4
   [F:SAP2]CRI5 = [F:SAP]CRI5
   [F:SAP2]CRI6 = [F:SAP]CRI6
   [F:SAP2]CRI7 = [F:SAP]CRI7
   [F:SAP2]CRI8 = "$$$"
   For I=0 To [M]NBRAMT-1
    If [M]FRTFLG(I)=2
     [F:SAP2]AMT(I) = TOTAL(I)
    Endif
   Next I
   Write [SAP2]
  Else
   For I=0 To [M]NBRAMT-1
    If [M]FRTFLG(I)=2
     [F:SAP2]AMT(I) = TOTAL(I)
    Endif
   Next I
   Rewrite [SAP2]
  Endif
  If fstat
   GOK = 0 : Call FSTA("SAP2") From GLOCK : Break
  Endif
  Raz INTCLENIV
  INTCLENIV(1) = [M]INTCLE1
  INTCLENIV(2) = [M]INTCLE2
  INTCLENIV(3) = [M]INTCLE3
  INTCLENIV(4) = [M]INTCLE4
  INTCLENIV(5) = [M]INTCLE5
  INTCLENIV(6) = [M]INTCLE6
  INTCLENIV(7) = [M]INTCLE7
  Gosub CRESTA2
  If GOK<1 : Break : Endif
 Next P
 If GOK<1 : Return : Endif
Endif

