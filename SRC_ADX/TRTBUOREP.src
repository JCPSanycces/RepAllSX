#<AdxTL>@(#)4.0.0.0 $Revision$
#------------------------------------------------------------------------------
#                         Budgets Opérationnels
#------------------------------------------------------------------------------
#   Fonction : BUOREP - Report de budgets
#   Action   : BUOREP
#   Fenêtre  : BUOREP
#   Ecran concerné : BUOREP [M:BRP]
#   Description :
#   *1-Report -> Pour une enveloppe budgétaire "Pluri-annuelle", il est
#                possible  de reporter sur le budget de l'exercice N+1,
#                le budget disponible de l'exercice N.
#------------------------------------------------------------------------------

Call TRAITE_CHAR(VALEUR,PARAM,"","BUOREP","TRTBUOREP",4,"") From GTRAITE
End

$ACTION
Case ACTION
 When "AVANT_PAR"   : Gosub AVANT_PAR
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 : GOK = 0
Endcase
Return

$AVANT_PAR
Raz [M:BRP]
Return

$INIT
# Tables utiles
If !clalev([GCM])  : Local File GACM       [GCM]  : Endif
If !clalev([LED])  : Local File GLED       [LED]  : Endif
If !clalev([CPY])  : Local File COMPANY    [CPY]  : Endif
If !clalev([FCY])  : Local File FACILITY   [FCY]  : Endif
If !clalev([FIY])  : Local File FISCALYEAR [FIY]  : Endif
If !clalev([FIY2]) : Local File FISCALYEAR [FIY2] : Endif
If !clalev([CCE])  : Local File CACCE      [CCE]  : Endif
If !clalev([BUT])  : Local File BUDTYP     [BUT]  : Endif
If !clalev([PRJ])  : Local File PROJET     [PRJ]  : Endif
If !clalev([ENV])  : Local File ENVELOPPE  [ENV]  : Endif
If !clalev([ENV2]) : Local File ENVELOPPE  [ENV2] : Endif
If !clalev([ENV3]) : Local File ENVELOPPE  [ENV3] : Endif
If !clalev([ENF])  : Local File ENVFIY     [ENF]  : Endif
If !clalev([ENF2]) : Local File ENVFIY     [ENF2] : Endif
If !clalev([ENF3]) : Local File ENVFIY     [ENF3] : Endif
If !clalev([BUD])  : Local File BUD        [BUD]  : Endif
If !clalev([BUD2]) : Local File BUD        [BUD2] : Endif
If !clalev([BUD3]) : Local File BUD        [BUD3] : Endif
If !clalev([BRV])  : Local File BUDREV     [BRV]  : Endif
If !clalev([BOA])  : Local File BUDAPP     [BOA]  : Endif
If !clalev([BAD])  : Local File BUDAPPDET  [BAD]  : Endif
If !clalev([BUP])  : Local File BUDPAR     [BUP]  : Endif


# Variable Globale
Global Char GAPPNIV(3)

# Variables Locales
Local Char CRITENV(250),CRITENVR(100)
Local Char TRACE_REP(250),TRACE_REC(250)
Local Decimal SOM_DISPO_LIG, DISPO_LIG
Local Decimal AMT_LB, SLD_LB, RAV_BUD, RES_BUD
Local Integer OK
Local Integer MAJ
Local Integer INDENV, INDENT, INDCCE3

Local Mask BUOREP [BRP]

If [M:BRP]ALLFCY=2 : Grizo [M:BRP]FCY : Else : Actzo
Endif
If [M]ALLPRJ=2
 Grizo CPRJ
Endif
If [M]ALLENV=2
 Grizo CENV
Endif
If [M]ALLENT=2
 Grizo ENTMNA
Endif
Affzo [M]
Return


$CONTROLE
TIT="C"
TMP=1
Return

$EXEC
# Trace/Tracking
If [M]TRC=2
 Local Integer TRCREP
 TRCREP=0
 # Report des enveloppes budgétaires pluriannuelles
 Call OUVRE_TRACE(mess(246,108,1)) From LECFIC
Endif

Gosub LOAD_FILTRE

For I=0 To [M]NBLIG-1
 If [M]NIV(I)=1 & [M]REPOR(I)=2
  Call DEBTRANS From GLOCK
  # Report des budgets
  Gosub TR_REPOR
 Endif
Next

If GOK=1 & [M]TRC=2
 If !TRCREP
  # Rien n'a été reporté
  Call ECR_TRACE(mess(205,108,1),0) From  GESECRAN
 Endif
 Call ECR_TRACE("---------------------------------------------",0) From  GESECRAN
Endif
Return

$LOAD_FILTRE
#---- Critères sur Enveloppe ----#
CRITENV="1=1"

# Société/site
If [M]ALLFCY=1
 CRITENV -= '& FCY="'+[M]FCY+'"'
Else
 Local Integer SOC,J
 Local Char LISTFCY(GLONFCY)(1..GNBSITE)
 SOC=find([M]CPY,GSOC(1..GNBSOC))
 J=1
 If SOC
  For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
   LISTFCY(J)=[F:FCY]FCY
   J+=1
  Next
 Endif
 CRITENV -='& (FCY="'+[M]CPY+'" | find(FCY,LISTFCY(1..J)))'
Endif

# Projet
If [M]ALLPRJ=1 : CRITENV -= '& PRJ="'+[M]CPRJ+'"' : Endif
# Entité
If [M]ALLENT=1 : CRITENV -= '& ENTMNA="'+[M]ENTMNA+'"' : Endif
# Enveloppe
If [M]ALLENV=1 : CRITENV -= '& ENV="'+[M]CENV+'"' : Endif

# Date exercice en cours
CRITENV -='& REASTR<=['+format$(GFMD,[M]FFIY)+'] & REAEND>=['+format$(GFMD,[M]DFIY)+']'
# Enveloppe non fermée
CRITENV -='& STA<>4'

Return


#------------------------------------ REPORT DE BUDGET -------------------------------------------------#

$TR_REPOR
Trbegin [ENV],[BUD],[ENF]
 GOK = 1
 Readlock [ENV]ENV0 = [M]ENV(I)
 If fstat=1
  GOK=-1 : GLOCK="$ENV"-[F:ENV]ENV : Return
 Elsif !fstat
  #------------------------------------------------------#
  # Ne pas reporter les enveloppes en cours de révision  #
  #------------------------------------------------------#
  Filter [BRV] Where ENV=[F:ENV]ENV & STA=2
  Look [BRV]BRV0 First
  If ! fstat
   GOK=0 :
   If [M]TRC=2
    TRCREP+=1
    # Enveloppe ENV - Révision en cours : Approuvez ou Refusez
    Call ECR_TRACE([F:ENV]ENV-"-"-mess(248,108,1),0) From  GESECRAN
   Endif
  Endif
  Filter [BRV]
  If !GOK : Goto AB_TR_REPOR : Endif
  #--------------------------------------------------------#
  # Ne pas reporter si les ojets suivant sont en cours d'approbation:  #
  # *l'enveloppe
  # *le budget exercice d'origine
  # *une ligne budgétaire de l'exercice d'origine
  #--------------------------------------------------------#
  Filter [BOA] Where ENV=[F:ENV]ENV & STA=2
  For [BOA]BOA0
   #enveloppe
   If [F:BOA]TYP=1 : GOK=0 : Break : Endif
   If [F:BOA]TYP<>4
    #Budget exe ou ligne
    If [F:BOA]FIY=[M]EFIY
     GOK=0 : Break
    Endif
   Else
    #Multiple
    Filter [BAD] Where NUMAPP=[F:BOA]NUM
    For [BAD]BAD0
     If [F:BAD]TYP=1 : GOK=0 : Break 2 : Endif
     If [F:BAD]FIY=[M]EFIY : GOK=0 : Break 2 : Endif
    Next
    Filter [BAD]
   Endif
  Next
  If !GOK & [M]TRC=2
   TRCREP+=1
   Local Char MSG(100)
   MSG = mess(249,108,1)
   Call DYNAMIC(MSG,"$1$",mess([F:BOA]TYP,2694,1)) From TEXTE
   # ENV/FIY - Approbation en cours : Approuvez ou Refusez
   Call ECR_TRACE([F:ENV]ENV-"/"-num$([M]EFIY)-"-"-MSG,0) From  GESECRAN
  Endif
  Filter [BOA]
  If !GOK : Goto AB_TR_REPOR : Endif

  #-----------------------------------------------------#
  # Ne pas reporter les enveloppes pour lesquelles les  #
  # dates de validité des entités/budget/projet ne sont #
  # pas ok sur la période de report                     #
  #-----------------------------------------------------#
   Call CTL_DAT2([F:ENV]ENTMNA,[F:ENV]ENTAPP,[F:ENV]ENTRAT,[F:ENV]BUD,[F:ENV]PRJ,
&                [M]TRC,[F:ENV]ENV,[M]DRFIY,[M]FRFIY,OK) From TRTBUOREC
   If OK=0 : GOK=0 : Goto AB_TR_REPOR : Endif

  #-----------------------------------------------------#
  # Ne pas reporter les enveloppes pour lesquelles des  #
  # lignes présentent des montants pré-engagé ou engagé #
  #-----------------------------------------------------#

  Call LEC_BUP([F:ENV]BUD) From CPTLEC
  Call GETGDDINDDIE([F:ENV]SOCIETE,[F:BUP]DIE(2),INDENV,INDENT,INDCCE3) From TRTGDD
  For [BUD]BUD0 Where FIY=[M]EFIY & evalue('CCE'+num$(INDENV))=[F:ENV]ENV
   If [F:BUD]AMTCMM<>0 | [F:BUD]AMTCMMPRP<>0
    GOK=0
    If [M]TRC=2
     TRCREP+=1
     # Report inexécuté : Budgets et lignes comportant des pré-engagements et des engagements en cours, à solder ou à reporter.
     Call ECR_TRACE(mess(250,108,1),0) From  GESECRAN
    Endif
    Break
   Endif

    If INDCCE3>0
    Call CTL_DAT([F:BUD]ACC,[F:BUD]COA,evalue('[F:BUD]DIE'+num$(INDENT)),evalue('[F:BUD]CCE'+num$(INDENT)),
&                evalue('[F:BUD]DIE'+num$(INDCCE3)),evalue('[F:BUD]CCE'+num$(INDCCE3)),
&                [M]TRC,[F:ENV]ENV,[M]DRFIY,[M]FRFIY,OK) From TRTBUOREC
   Else
    Call CTL_DAT([F:BUD]ACC,[F:BUD]COA,evalue('[F:BUD]DIE'+num$(INDENT)),evalue('[F:BUD]CCE'+num$(INDENT)),"","",
&                [M]TRC,[F:ENV]ENV,[M]DRFIY,[M]FRFIY,OK) From TRTBUOREC
   Endif
   If OK=0 : GOK=0 : Break : Endif

  Next
  If !GOK : Goto AB_TR_REPOR : Endif
  #-----------------------------------------------------#

  Call LECTURE("BUT",[F:ENV]BUDTYP,"") From CONTOBJ
  If [F:BUT]YEAFLG=2 :# Pluri-annuelle
   Readlock [ENF]ENF0=[F:ENV]ENV;[M]EFIY
   If fstat=1
    GOK=-1 : GLOCK="$ENVFIY"-[F:ENV]ENV-num$([M]EFIY) : Goto ROLL_TR_REPOR
   Elsif fstat
    GOK=0 : Call FSTA("BUD") From GLOCK : Goto AB_TR_REPOR
   Elsif !fstat & [F:ENF]STAFIY<>4
    SOM_DISPO_LIG=0
    AMT_LB=0
    SLD_LB=0
    For [BUD]BUD0 Where evalue('CCE'+num$(INDENV))=[F:ENV]ENV & FIY=[F:ENF]FIYNUM & STA<>4
     AMT_LB += [F:BUD]AMT
     SLD_LB += [F:BUD]AMTREA+[F:BUD]AMTCMM+[F:BUD]AMTCMMPRP
     DISPO_LIG=[F:BUD]AMT-[F:BUD]AMTREA-[F:BUD]AMTCMM-[F:BUD]AMTCMMPRP
     SOM_DISPO_LIG += DISPO_LIG
     If DISPO_LIG>0
      [F:BUD]AMT    = [F:BUD]AMT-DISPO_LIG
      [F:BUD]STA    = 4 :# Fermée/closed
      [F:BUD]UPDUSR = GUSER
      [F:BUD]UPDDAT = date$
      Rewrite [BUD]
      If fstat: GOK=0 : Call FSTA("BUD") From GLOCK : Break : Endif
      Local Char INTENV(30)
      Call LECTEXTRA(INTENV,"ENVELOPPE","DESTRA",[F:ENV]ENV,"") From ATEXTRA
      If [M]TRC=2
       TRCREP+=1
       # Mise à jour de la ligne
       Call ECR_TRACE(mess(195,108,1)-":"-[F:ENV]ENV-"/"-num$([F:ENF]FIYNUM)-"/"-[F:BUD]ACC-"/"-num$([F:BUD]ACCNUM),0) From  GESECRAN
      Endif
      Gosub REPORT_LIG
      If GOK<1 : Break : Endif
     Endif
    Next
    If GOK=-1 : Goto ROLL_TR_REPOR
    Elsif !GOK : Goto AB_TR_REPOR
    Endif
    RAV_BUD = ([F:ENF]AMTBUDFIY-[F:ENF]AMTRESFIY)-SLD_LB
    If SOM_DISPO_LIG>0 | RAV_BUD>0
     RES_BUD = [F:ENF]AMTRESFIY
     [F:ENF]AMTBUDFIY = [F:ENF]AMTBUDFIY-RAV_BUD-RES_BUD
     [F:ENF]AMTRESFIY =0
     [F:ENF]STAFIY = 4 :# Fermé/Closed
     Rewrite [ENF]
     If fstat: GOK=0 : Call FSTA("ENF") From GLOCK : Goto AB_TR_REPOR : Endif
     If [M]TRC=2
      TRCREP+=1
      # Mise à jour du budget exercice
      Call ECR_TRACE(mess(197,108,1)-":"-[F:ENF]ENV-"/"-num$([F:ENF]FIYNUM),0) From  GESECRAN
     Endif
     Gosub REPORT_BUDGET
     If GOK=-1 : Goto ROLL_TR_REPOR
     Elsif !GOK : Goto AB_TR_REPOR
     Endif
    Endif
   Endif
  Endif
 Endif
Commit
Return

$AB_TR_REPOR
Rollback
Return

$ROLL_TR_REPOR
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_REPOR : Endif

$REPORT_LIG
MAJ=0
Readlock [BUD2]BUD0=[F:BUD]LEDTYP;[F:BUD]BUD;[F:BUD]CPY;[F:BUD]FCY;[M]RFIY;[F:BUD]VER;[F:BUD]ACC;[F:BUD]CCE1;[F:BUD]CCE2;
& [F:BUD]CCE3;[F:BUD]CCE4;[F:BUD]CCE5;[F:BUD]CCE6;[F:BUD]CCE7;[F:BUD]CCE8;[F:BUD]CCE9
If !fstat
 [F:BUD2]AMT += DISPO_LIG
 If [F:BUD2]STA=3
  [F:BUD2]AMTAPP += DISPO_LIG
 Elsif [F:BUD2]STA=2
  #Recherche de l'approbation en cours et mise à jour du montant
  Filter [BOA] Where ENV=evalue('[F:BUD]CCE'+num$(INDENV))
  For [BOA]BOA0
   If [F:BOA]TYP=3
    [F:BOA]AMT += DISPO_LIG
    Rewrite [BOA]
    If fstat: GOK=0 : Call FSTA("BOA") From GLOCK : Break : Endif
   Elsif [F:BOA]TYP=4
    Filter [BAD] Where NUMERO=[F:BOA]NUM
    For [BAD]BAD0
     If [F:BAD]TYP=3 & [F:BAD]FIY=[M]RFIY
      [F:BAD]AMT += DISPO_LIG
      Rewrite [BAD]
      If fstat: GOK=0 : Call FSTA("BAD") From GLOCK : Break 2 : Endif
     Endif
    Next
    Filter [BAD]
   Endif
  Next
  Filter [BOA]
 Endif
 If GOK=0 : Return : Endif
 [F:BUD2]BUDRPT += DISPO_LIG
 [F:BUD2]UPDUSR = GUSER
 [F:BUD2]UPDDAT = date$
 Rewrite [BUD2]
 If fstat: GOK=0 : Call FSTA("BUD2") From GLOCK : Return : Endif
 If [M]TRC=2
  TRCREP+=1
  # Mise à jour de la ligne
  Call ECR_TRACE(mess(195,108,1)-":"-evalue('[F:BUD2]CCE'+num$(INDENV))-"/"-num$([F:BUD2]FIY)-"/"-[F:BUD2]ACC-"/"-
&               num$([F:BUD2]ACCNUM),0) From  GESECRAN
 Endif
Elsif fstat=1
 GOK=-1
 GLOCK="$BUD"-[F:BUD]BUD-[F:BUD]CPY-[F:BUD]FCY-[F:BUD]ACC-[F:BUD]CCE1-[F:BUD]CCE2-[F:BUD]CCE3-
&             [F:BUD]CCE4-[F:BUD]CCE5-[F:BUD]CCE6-[F:BUD]CCE7-[F:BUD]CCE8-[F:BUD]CCE9
 Return
Else
 # Si on passe là c'est que la ligne n'existait pas
 Raz [F:BUD3]
 [F:BUD3] = [F:BUD]
 Raz [F:BUD3]AMTCMM
 Raz [F:BUD3]AMTCMMPRP
 Raz [F:BUD3]AMTREA
 Raz [F:BUD3]AMTAPP
 Raz [F:BUD3]AMTATT
 Raz [F:BUD3]AMTCCA
 Raz [F:BUD3]AMTCAP
 [F:BUD3]ACCNUM = uniqid([F:BUD])
 [F:BUD3]FIY    = [F:BUD]FIY+1
 [F:BUD3]AMT    = DISPO_LIG
 [F:BUD3]BUDRPT = DISPO_LIG
 [F:BUD3]STA    = 1
 [F:BUD3]CREUSR = GUSER
 [F:BUD3]CREDAT = date$
 Write [BUD3]
 If fstat: GOK=0 : Call FSTA("BUD3") From GLOCK : Return : Endif
 If [M]TRC=2
  TRCREP+=1
  # Création de la ligne
  Call ECR_TRACE(mess(196,108,1)-":"-evalue('[F:BUD3]CCE'+num$(INDENV))-"/"-num$([F:BUD3]FIY)-"/"-
&                [F:BUD3]ACC-"/"-num$([F:BUD3]ACCNUM),0) From  GESECRAN
 Endif
Endif
Return

$REPORT_BUDGET
Readlock [ENF2]ENF0 = [F:ENF]ENV;[F:ENF]FIYNUM+1
If !fstat
 [F:ENF2]AMTBUDFIY += RAV_BUD+RES_BUD
 If [F:ENF2]STAFIY=3
  [F:ENF2]AMTAPPFIY += RAV_BUD+RES_BUD
 Elsif [F:ENF2]STAFIY=2
  #Recherche de l'aprobation en cours et mise à jour du montant
  Filter [BOA] Where ENV=evalue('[F:BUD]CCE'+num$(INDENV))
  For [BOA]BOA0
   If [F:BOA]TYP=2
    [F:BOA]AMTAPP += RAV_BUD+RES_BUD
    Rewrite [BOA]
    If fstat: GOK=0 : Call FSTA("BOA") From GLOCK : Break : Endif
   Elsif [F:BOA]TYP=4
    Filter [BAD] Where NUMERO=[F:BOA]NUM
    For [BAD]BAD0
     If [F:BAD]TYP=2 & [F:BAD]FIY=[M]RFIY
      [F:BAD]AMT += RAV_BUD+RES_BUD
      Rewrite [BAD]
      If fstat: GOK=0 : Call FSTA("BAD") From GLOCK : Break 2 : Endif
     Endif
    Next
    Filter [BAD]
   Endif
  Next
  Filter [BOA]
 Endif
 If GOK=0 : Return : Endif
 [F:ENF2]AMTRESFIY += RES_BUD
 [F:ENF2]BUDRPT    += RAV_BUD+RES_BUD
 Rewrite [ENF2]
 If fstat: GOK=0 : Call FSTA("ENF2") From GLOCK : Return : Endif
 If [M]TRC=2
  TRCREP+=1
  # Mise à jour du budget exercice
  Call ECR_TRACE(mess(197,108,1)-":"-[F:ENF2]ENV-"/"-num$([F:ENF2]FIYNUM),0) From  GESECRAN
 Endif
Elsif fstat=1
 GOK=-1 : GLOCK="$ENVFIY"-[F:ENF]ENV-num$([F:ENF]FIYNUM+1) : Return
Else
 # Si on passe là c'est que le budget N'existait pas
 Raz [ENF3]
 [F:ENF3]ENV = [F:ENF]ENV
 [F:ENF3]AMTBUDFIY = RAV_BUD+RES_BUD
 [F:ENF3]AMTRESFIY = RES_BUD
 [F:ENF3]BUDRPT    = RAV_BUD+RES_BUD
 [F:ENF3]FIYNUM = [F:ENF]FIYNUM+1
 [F:ENF3]FIYSTR = [M]DRFIY
 [F:ENF3]FIYEND = [M]FRFIY
 If GAPPNIV="121" | GAPPNIV="122" | GAPPNIV="221" | GAPPNIV="222"
  [F:ENF3]STAFIY = 1
 Else
  [F:ENF3]STAFIY = [F:ENV]STA
 Endif
 If [F:ENF3]STAFIY=3
  [F:ENF3]AMTAPPFIY=[F:ENF3]AMTBUDFIY
 Endif
 Write [ENF3]
 If fstat: GOK=0 : Call FSTA("ENF3") From GLOCK : Return : Endif
 # Maj date enveloppe
 [F:ENV]REAEND = [M]FRFIY
 Rewrite [ENV]
 If fstat: GOK=0 : Call FSTA("ENV") From GLOCK : Return : Endif
 # Trace
 If [M]TRC=2
  TRCREP+=1
  # Création du budget exercice
  Call ECR_TRACE(mess(198,108,1)-":"-[F:ENF3]ENV-"/"-num$([F:ENF3]FIYNUM),0) From  GESECRAN
 Endif
Endif
Return

$TERMINE
Local Integer INDREP : INDREP=0
For I=0 To [M]NBLIG-1
 If [M]REPOR(I)=2 : INDREP=1 : Break : Endif
Next
If !INDREP
 # Vous n'avez rien coché. Souhaitez vous quitter sans rien faire?
 Call OUINON(mess(105,108,1),OK) From GESECRAN
 If OK=1
  FOK=0
  FIN=0
 Endif
Else
 # Trace
 If [M]TRC=2
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
Endif
Return

$COLORIZE
Local Integer J,K : K=1
Local Char ENVCUR(GLONENV)
ENVCUR=[M]ENV(0)
For J=0 To [M]NBLIG-1
 If [M]ENV(J)<>ENVCUR
  If K<>3
   K+=1
  Else
   K=1
  Endif
  Chgstl [M]NBLIG(J)  With "GDD"+num$(K)
 Else
  Chgstl [M]NBLIG(J)  With "GDD"+num$(K)
 Endif
 ENVCUR=[M]ENV(J)
Next
Affzo [M]
Return

############################################
## Etiquette de l'écran REPRECBUD
############################################

Subprog IB_NBLIG
If [M]NIV(nolign-1)<>3
 Raz GBOUT2
Else
 Raz GBOUT1
Endif
End

Subprog CL_SEARCH(VALEUR)
Variable Char    VALEUR()
If [M]EFIY=0
 # Exercie incorrect
 GMESSAGE = mess(52,116,1)
 mkstat=2 : End
Endif
Gosub INIT
Local Libelle LEDTYPGEN, LEDTYPANA
# Filtre/Filter
Gosub LOAD_FILTRE
Local Integer ENVDONE,ENFLIN,NBLIN,I
Local Integer OKACS, CTLACS
Local Integer INDENV, INDENT, INDCCE3
CTLACS = 1

I=0
Raz [M]NBLIG
For [ENV]ENV0 Where evalue(CRITENV)
 OKACS = 1
 If [F:ENV]ACS<>""
  Call LECACC([F:ENV]ACS,OKACS) From CPTSUB
  If !OKACS : CTLACS=0 : Endif
 Endif
 If OKACS
  NBLIN=0
  #Pour intitulé exercice
  Call SETMAINREF([F:ENV]SOCIETE,LEDTYPGEN,LEDTYPANA) From CPTDIV
  Call LECTURE("BUT",[F:ENV]BUDTYP,"") From CONTOBJ
  If [F:BUT]YEAFLG=2 :# Pluri-annuelle
   Read [ENF]ENF0=[F:ENV]ENV;[M]EFIY
   If !fstat & [F:ENF]STAFIY<>4
    SOM_DISPO_LIG=0
    AMT_LB=0
    SLD_LB=0
    ENVDONE=0
    Call GETGDDINDDIE([F:ENV]SOCIETE,"",INDENV,INDENT,INDCCE3) From TRTGDD
    For [BUD]BUD0 Where evalue('CCE'+num$(INDENV))=[F:ENV]ENV & FIY=[F:ENF]FIYNUM & STA<>4
     #Alimentation des montants utiles
     AMT_LB += [F:BUD]AMT
     SLD_LB += [F:BUD]AMTREA+[F:BUD]AMTCMM+[F:BUD]AMTCMMPRP
     DISPO_LIG=[F:BUD]AMT-[F:BUD]AMTREA-[F:BUD]AMTCMM-[F:BUD]AMTCMMPRP
     SOM_DISPO_LIG += DISPO_LIG
     #
     If DISPO_LIG>0
      If !ENVDONE
       If I>0
        I+=1
        #----TB protection----
        If I>dim([M]REPOR)-1
         #Tableau Plein
         Call MESSAGE(mess(26,100,1)) From GESECRAN : I-=1 : Break 2
        Endif
        #--------------------
       Endif
       #Enveloppe
       [M]NIV(I)=1
       [M]ENV(I)=[F:ENV]ENV
       [M]CUR(I)=[F:ENV]CURENV
       [M]AMT(I)=[F:ENV]AMTENV
       [M]RES(I)=[F:ENV]AMTRES
       [M]REPOR(I)=1
       #Budget exercice
       I+=1
       #----TB protection----
       If I>dim([M]REPOR)-1
        #Tableau Plein
        Call MESSAGE(mess(26,100,1)) From GESECRAN : I-=1 : Break 2
       Endif
       #--------------------
       ENFLIN = I
       [M]NIV(I)=2
       [M]ENV(I)=[F:ENV]ENV
       [M]CUR(I)=[F:ENV]CURENV
       [M]AMT(I)=[F:ENF]AMTBUDFIY
       [M]RES(I)=[F:ENF]AMTRESFIY
       [M]REPOR(I)=1
       [M]FIY(I)=[F:ENF]FIYNUM
       [M]INTFIY(I) = num$([F:ENF]FIYNUM)
       Read [FIY]FIY0 = [F:ENV]SOCIETE;LEDTYPANA;[F:ENF]FIYNUM
       If !fstat
        [M]INTFIY(I) -= "-"-[F:FIY]DESSHO
       Endif
       ENVDONE=1
      Endif
      #ligne budgétaire
      I+=1
      #----TB protection----
      If I>dim([M]REPOR)-1
       #Tableau Plein
       Call MESSAGE(mess(26,100,1)) From GESECRAN : I-=1 : Break 2
      Endif
      #--------------------
      [M]NIV(I)=3
      [M]ENV(I)=[F:ENV]ENV
      [M]ACC(I)=[F:BUD]ACC
      [M]CUR(I)=[F:ENV]CURENV
      [M]AMT(I)=[F:BUD]AMT
      [M]AMTREP(I)=DISPO_LIG
      [M]ACCNUM(I)=[F:BUD]ACCNUM
      [M]REPOR(I)=1
      [M]FIY(I)=[F:BUD]FIY
      [M]INTFIY(I) = num$([F:BUD]FIY)
      Read [FIY]FIY0 = [F:ENV]SOCIETE;LEDTYPANA;[F:BUD]FIY
      If !fstat
       [M]INTFIY(I) -= "-"-[F:FIY]DESSHO
      Endif
      [M]RAV(I)=[F:BUD]AMT-([F:BUD]AMTREA+[F:BUD]AMTCMM+[F:BUD]AMTCMMPRP)
      [M]RAVREP(I)=[M]RAV(I)
      NBLIN+=1
     Endif
    Next
    If NBLIN=0
     If I>0
      I+=1
      #----TB protection----
      If I>dim([M]REPOR)-1
       #Tableau Plein
       Call MESSAGE(mess(26,100,1)) From GESECRAN : I-=1 : Break
      Endif
      #--------------------
     Endif
     #Enveloppe
     [M]NIV(I)=1
     [M]ENV(I)=[F:ENV]ENV
     [M]CUR(I)=[F:ENV]CURENV
     [M]AMT(I)=[F:ENV]AMTENV
     [M]RES(I)=[F:ENV]AMTRES
     [M]REPOR(I)=1
     #Budget exercice
     I+=1
     #----TB protection----
     If I>dim([M]REPOR)-1
      #Tableau Plein
      Call MESSAGE(mess(26,100,1)) From GESECRAN : I-=1 : Break
     Endif
     #--------------------
     ENFLIN = I
     [M]NIV(I)=2
     [M]ENV(I)=[F:ENV]ENV
     [M]CUR(I)=[F:ENV]CURENV
     [M]AMT(I)=[F:ENF]AMTBUDFIY
     [M]RES(I)=[F:ENF]AMTRESFIY
     [M]REPOR(I)=1
     [M]FIY(I)=[F:ENF]FIYNUM
     [M]INTFIY(I) = num$([F:ENF]FIYNUM)
     Read [FIY]FIY0 = [F:ENV]SOCIETE;LEDTYPANA;[F:ENF]FIYNUM
     If !fstat
      [M]INTFIY(I) -= "-"-[F:FIY]DESSHO
     Endif
    Endif
    If SOM_DISPO_LIG>0 | NBLIN=0
     [M]RAV(ENFLIN)=([F:ENF]AMTBUDFIY-[F:ENF]AMTRESFIY)-AMT_LB
     [M]AMTREP(ENFLIN)=[M]RAV(ENFLIN)+[F:ENF]AMTRESFIY+SOM_DISPO_LIG
     [M]RAVREP(ENFLIN)=([F:ENF]AMTBUDFIY-[F:ENF]AMTRESFIY)-SLD_LB
     [M]RESREP(ENFLIN)=[F:ENF]AMTRESFIY
    Endif
   Endif
  Endif
 Endif
Next
If I>=1
 [M]NBLIG=I+1
Else
 #Aucun enregistrement pour ces sélections
 Call MESSAGE(mess(104,199,1)) From GESECRAN
Endif
Affzo [M]
If CTLACS=0 : Call MESSAGE(mess(55,109,1)) From GESECRAN : Endif
Gosub COLORIZE
End

Subprog CL_COCHER(VALEUR)
Variable Char    VALEUR()
If [M]NBLIG>0
 Local Integer COCHE
 If [M]REPOR(0)=1
  COCHE=2
 Else
  COCHE=1
 Endif
 For I=0 To [M]NBLIG-1
  [M]REPOR(I)=COCHE
 Next
 Affzo [M]
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Local Char SOCIETE(GLONCPY)
 SOCIETE=VALEUR
 Local Integer SOC
 SOC = find(SOCIETE,GSOC(1..GNBSOC))
 If !SOC
  # Société inexistante
  GMESSAGE=mess(16,104,1)
  mkstat=2 : End
 Endif
 #06/10/09-Dmd54223:Autorisation site
 Call CONTCPY(VALEUR) From CPTSUB
 # Paramètrage approbation
 Call SETGLBAPP(SOCIETE,GAPPNIV) From TRTGDD
 # Variables locales
 Local Libelle LEDTYPGEN, LEDTYPANA
 Local Char    CODLED(GLONLED), DEVLED(GLONCUR)
 Local Decimal EXERCICE
 # Plan de compte
 Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
 Call SETMAINREF(SOCIETE,LEDTYPGEN,LEDTYPANA) From CPTDIV
 Call LECLED(SOCIETE,LEDTYPANA,CODLED,DEVLED) From CPTDIV
 Call LECTURE("LED",CODLED,"") From CONTOBJ
 [M]COA=[F:LED]COA
 # Exercice
 Call GETEXE(VALEUR,LEDTYPANA,date$,EXERCICE) From CPTSUB
 Read [FIY]FIY0 = SOCIETE;LEDTYPANA;EXERCICE
 If !fstat & [F:FIY]FIYSTA=2
#  If [F:FIY]FIYSTA<>2
#   GMESSAGE="Exercice courant non ouvert pour cette société"
#   mkstat=2 : End
#  Endif
  [M]EFIY=EXERCICE
  [M]INTEFIY=[F:FIY]DES
  [M]DFIY=[F:FIY]FIYSTR
  [M]FFIY=[F:FIY]FIYEND
  Read [FIY2]FIY0 = SOCIETE;LEDTYPANA;EXERCICE+1
  If !fstat & [F:FIY2]FIYSTA<>3
#   If [F:FIY2]FIYSTA=3
#     #Exercice budgétaire récepteur fermé
#     GMESSAGE=mess(204,108,1)
#     mkstat=2
#   Else
    [M]RFIY=EXERCICE+1
    [M]INTRFIY=[F:FIY2]DES
    [M]DRFIY=[F:FIY2]FIYSTR
    [M]FRFIY=[F:FIY2]FIYEND
#   Endif
#  Else
#   # Il n'existe pas d'exercice recepteur pour cet exercice sur cette société et son référentiel analytique principal
#   GMESSAGE=mess(202,108,1)
#   mkstat=2 : End
  Endif
# Else
#  # Exercice inexistant pour cette société sur le référentiel analytique principal
#  GMESSAGE=mess(203,108,1)
#  mkstat=2 : End
 Endif
Endif
Affzo [M]
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Raz [M]NBLIG
Affzo [M]
End

Subprog C_EFIY(VALEUR)
Variable Decimal VALEUR
If [M]CPY<>""
 # Variables locales
 Local Libelle LEDTYPGEN, LEDTYPANA
 # Plan de compte
 Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
 Call SETMAINREF([M]CPY,LEDTYPGEN,LEDTYPANA) From CPTDIV
 Read [FIY]FIY0 = [M]CPY;LEDTYPANA;VALEUR
 If !fstat
  If [F:FIY]FIYSTA=2
   [M]INTEFIY=[F:FIY]DES
   [M]DFIY=[F:FIY]FIYSTR
   [M]FFIY=[F:FIY]FIYEND
   Read [FIY2]FIY0 = [M]CPY;LEDTYPANA;VALEUR+1
   If !fstat
    If [F:FIY2]FIYSTA=3
     # Exercice budgétaire récepteur fermé
     GMESSAGE=mess(204,108,1)
     mkstat=2
    Else
     [M]RFIY=VALEUR+1
     [M]INTRFIY=[F:FIY2]DES
     [M]DRFIY=[F:FIY2]FIYSTR
     [M]FRFIY=[F:FIY2]FIYEND
    Endif
   Else
    # Il n'existe pas d'exercice recepteur pour cet exercice sur cette société et son référentiel analytique principal
    GMESSAGE=mess(202,108,1)
    mkstat=2 : End
   Endif
  Else
  # Exercice non ouvert
   GMESSAGE=mess(20,101,1)
   mkstat=2 : End
  Endif
 Else
  # Exercice inexistant pour cette société sur le référentiel analytique principal
  GMESSAGE=mess(203,108,1)
  mkstat=2 : End
 Endif
Endif
End

Subprog AM_EFIY(VALEUR)
Variable Decimal VALEUR
Raz [M]NBLIG
Affzo [M]
End

