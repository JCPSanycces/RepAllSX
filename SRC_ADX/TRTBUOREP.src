Subprog AS_CENV(VALEUR)
Variable Char    VALEUR()
If [M]ALLENV=2 : Raz VALEUR : Grizo [M]CENV : mkstat = 1 : End : Endif
End

Subprog C_CENV(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 # Zone Obligatoire
 GMESSAGE=mess(10,123,1)
 mkstat=2 : End
Else
 Call LECTURE("ENV",VALEUR,"") From CONTOBJ
 If !fstat
  Local Integer OKACC
  Call LECACC([F:ENV]ACS,OKACC) From CPTSUB
  If !OKACC
   Call MESSAGE(mess(4,104,1)) From GESECRAN
   mkstat = 2 : End
  Endif
  If [M]ALLPRJ=1
   If [F:ENV]PRJ<>[M]CPRJ
    # L'enveloppe n'est pas rattachée au projet
    GMESSAGE=mess(194,108,1)-[M]CPRJ
    mkstat=2 : End
   Endif
  Endif
  If [F:ENV]FCY<>[M]CPY
   Local Integer SOC,J
   Local Char LISTFCY(GLONFCY)(1..GNBSITE)
   SOC=find([M]CPY,GSOC(1..GNBSOC))
   J=1
   If SOC
    For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
     LISTFCY(J)=[F:FCY]FCY
     J+=1
    Next
   Endif
   If !find([F:ENV]FCY,LISTFCY(1..J))
    # L'enveloppe n'est pas définie sur cette société/site
    GMESSAGE=mess(183,108,1)
    mkstat=2 : End
   Endif
  Endif
  Read [BUT]BUT0=[F:ENV]BUDTYP
  If !fstat & [F:BUT]YEAFLG<>2
   # Fonction réservée aux enveloppes pluriannuelles
   GMESSAGE=mess(243,108,1)
   mkstat=2 : End
  Endif
 Endif
Endif
End

Subprog AM_REPOR(VALEUR)
Variable Integer VALEUR
For I=0 To [M]NBLIG-1
 If [M]ENV(I)=[M]ENV(nolign-1)
  [M]REPOR(I)=VALEUR
 Endif
Next
Affzo [M]
End

