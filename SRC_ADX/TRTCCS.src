#<AdxTL>@(#)4.0.0.0 $Revision$
# Gestion du masque TRTCCS
################################################################################
# SBA - 17/09/13 - FQ92041 - US1927  Extraction fichier
################################################################################
Local Char    PARAM(10)(1..2)
Local Integer VALEUR
Call TRAITE_LIB([L]VALEUR,[L]PARAM,"","TRTCCS","DTRTCCS",4,"") From GTRAITE
End

######################################################################################

$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
 When "SORTIE"   : Gosub SORTIE
 When "DEBUT"    : Gosub DEBUT
 # SBA FQ92041 - US1927
 When "BOUTON"   : Gosub BOUTON
Endcase
Return


# SBA FQ92041 - US1927
$GRISEFIL
# ajout pour griser le champ si erreur ou date non saise
If [M:TCCS]TYPEXP=1
  Grizo [M:TCCS]FIL
Else
  Actzo [M:TCCS]FIL
Endif
Affzo [M:TCCS]
Return

# SBA FQ92041 - US1927
$BOUTON
Case BOUT
  When "R" :
   # Button "Rappel MEMO"
   Gosub GRISEFIL
  Endcase
Return


$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Call DELOCK("CCS") From GLOCK
Return

$DEBUT
#Multi-legislation
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
# SBA FQ92041 - US1927
#Affzo [TCCS]
Gosub GRISEFIL
Return

$INIT
Gosub OUVFIC
Local Integer STAT
Local Char    CRITERE1(250), CRITERE2(250), SYMBOLE(30)
Local Mask TRTCCS
Raz [M:TCCS]
# SBA FQ92041 - US1927
[M:TCCS]TYPEXP=2
Call LECMEMO("STD","[M:TCCS]","tcs") From GMEMO
# Génération des déclarations des activités des artistes et techniciens du spectacle
[L]TIT=mess(198,10703,1)
Return

$OUVFIC
If clalev([F:CCS])=0 : Local File CERTIFCCS [CCS] : Endif
If clalev([F:HRPOA])=0 : Local File POPULA    [HRPOA] : Endif
If clalev([F:FCY])=0 : Local File FACILITY  [FCY] : Endif
If clalev([F:FEH])=0 : Local File FILEDIH   [FEH] : Endif
If clalev([F:FEL])=0 : Local File FILEDIL   [FEL] : Endif

Gosub OUVRE From WPDEFTABLE
Return

$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
  # FQ72138 - MABON 07/03/11 - Vérification saisie des dates
  If [M:TCCS]DATDEB=[0/0/0] | [M:TCCS]DATFIN=[0/0/0] Then
    SAI=1 : GERR=1
    GMESSAGE=mess(69,10702,1) : # Date obligatoire
    Return
  Endif

 TMP = 1
 TRA = 1
 If [M]FILFLG=1
  CRITERE1 = "STACCS=3" :# Certificats imprimés
 Else
  CRITERE1 = "STACCS=4" :# Certificats déjà générés
 Endif
 CRITERE2 = "1=1"
 # Borne CECS
 If [M:TCCS]CCSDEB<>"" : CRITERE1 -= '& [F:CCS]NUMCER>="'+[M:TCCS]CCSDEB+'"' : Endif
 If [M:TCCS]CCSFIN<>"" : CRITERE1 -= '& [F:CCS]NUMCER<="'+[M:TCCS]CCSFIN+'"' : Endif

 # Borne matricule
 If [M:TCCS]MATDEB<>"" : CRITERE1 -= '& [F:CCS]REFNUM>="'+[M:TCCS]MATDEB+'"' : Endif
 If [M:TCCS]MATFIN<>"" : CRITERE1 -= '& [F:CCS]REFNUM<="'+[M:TCCS]MATFIN+'"' : Endif

 # Borne date
 CRITERE1 -= '& [F:CCS]ENDDAT>=['+format$(GFMD,[M:TCCS]DATDEB)+']'
 CRITERE1 -= '& [F:CCS]ENDDAT<=['+format$(GFMD,[M:TCCS]DATFIN)+']'

 # Borne contrat
 If [M:TCCS]CTRDEB<>"" : CRITERE1 -= '& [F:CCS]CTRNUM>="'+[M:TCCS]CTRDEB+'"' : Endif
 If [M:TCCS]CTRFIN<>"" : CRITERE1 -= '& [F:CCS]CTRNUM<="'+[M:TCCS]CTRFIN+'"' : Endif

 # Service
 If [M:TCCS]ALLSRV<>2  : CRITERE2 -= '& [F:HRCTR]ETRSRV="'+[M:TCCS]SRV+'"'     : Endif

 # Profil
 If [M:TCCS]ALLPRF<>2  : CRITERE2 -= '& [F:HRCTR]PROPRF="'+[M:TCCS]PRF+'"'     : Endif

 # Site
 If [M:TCCS]ALLFCY<>2  : CRITERE2 -= '& [F:HRCTR]ETRFCY="'+[M:TCCS]FCY+'"'     : Endif

 # Société
 If [M:TCCS]ALLCPY<>2  : CRITERE2 -= '& [F:FCY]LEGCPY="'+[M:TCCS]CPY+'"'     : Endif

 # Population
 If [M:TCCS]POP<>""
  Link [CCS] With
&    [HRPOA]POA0 = [M:TCCS]POP;[F:CCS]REFNUM
& ,  [ID]ID0   = [F:CCS]REFNUM
& ,  [HRCTR]CTR2 = [F:CCS]REFNUM;[F:CCS]CTRNUM;1
& ,  [FCY]FCY0 = [F:HRCTR]ETRFCY
&    As [LNK]
&    Where evalue(CRITERE1) & evalue(CRITERE2) & [F:HRPOA]REFNUM<>""
 Else
  Link [CCS] With
&    [ID]ID0   = [F:CCS]REFNUM
& ,  [HRCTR]CTR2 = [F:CCS]REFNUM;[F:CCS]CTRNUM;1
& ,  [FCY]FCY0 = [F:HRCTR]ETRFCY
&    As [LNK]
&    Where evalue(CRITERE1) & evalue(CRITERE2)
 Endif

 Filter [LNK] Order By Key CLE=[CCS]NUMCPY
 For [LNK]CLE(1)
  Call EXISTE(filpath([V]GDIRBQE,[M:TCCS]FIL+num$([F:CCS]NUMCPY),"ccs",0),[L]OK) From ORDSYS
  If [L]OK
   # Fichier destination présent, effacement ?
   OK =2 : Call OUINON([M:TCCS]FIL+num$([F:CCS]NUMCPY)-mess(7,141,1),OK) From GESECRAN
   If OK<>2
    FIN = 1 : Break
   Endif
  Endif
 Next
 Filter [LNK]
Endif
Return

$EXEC
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

OK = 1
For [LNK]
 # ! bogue si [M]CRI porte sur EMPLOCTR
 Call CONTROLE([F:CCS]REFNUM,datesyst,[F:CCS]CTRNUM,[M:TCCS]CRI,[L]STAT,1) From DIVPAYE
 If [L]STAT
  [L]SYMBOLE="CCS"+[F:CCS]NUMCER
  Lock =[L]SYMBOLE
  If fstat
   Call QUILOCKE([L]SYMBOLE,1) From DIVPAYE
   Call ECR_TRACE([F:CCS]REFNUM+"\"+GMESSAGE,1) From GESECRAN
   Raz GMESSAGE
   OK = 0
  Endif
 Endif
Next

If OK=1
  # SBA FQ92041 - US1927 : pour ne pas afficher la trace si annuler sur l'enregistrement du fichier
  #Call EMISSION(1)
  Call EMISSION([L]TRA)
Endif

Call DELOCK("CCS") From GLOCK
Return

$TERMINE
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

################################################################################
#
# Routines
#
################################################################################

Subprog EMISSION(TRA)
Variable Integer TRA
# SBA FQ92041 - US1927
#value Integer TRA : passage de value à variable pour ne pas afficher la trace si bouton annuler.

Local Integer STAT, NBERR, I, NBPCE
Local Decimal TOTBASCNG
Local Char    MATRI([V]GLONEML), FEH([V]GLONADI)
Local Date    DATMAT

[L]FEH="CCS"
Gosub GENVAR From GENFEH
Gosub DEFVAR From =[L]FEHTRT
Gosub DEFVAR From GENFEH
Gosub DEFVAR

[L]EMISSION=1

# SBA FQ92041 - US1927
# ajout du calcul du nom de fichier
Local Char    FICHIER([V]GDIMFIC),CLI_FICHIER([V]GDIMFIC), FICCLI([V]GDIMFIC)
#[L]FICHIER=[M:TCCS]FIL
If [M:TCCS]TYPEXP=1
 Local Char W_FICHIER([V]GDIMFIC)
 Local Char W_REP([V]GDIMFIC)
 [L]FICCLI=[L]FICHIER
 Call SET_FICNAM([L]FICCLI,[L]CLI_FICHIER,[L]MATRI) From ORDSYS
Endif
# SBA fin
Call DEBTRANS From GLOCK

$TR_EMISSION
[V]GOK=1
Trbegin [CCS]
 Gosub ECRITURE
 If [V]GOK=-1
  Rollback
  Call ROLL From GLOCK
  If [V]GROLL : Goto FIN : Else Goto TR_EMISSION : Endif
 Elsif ![V]GOK
  Rollback
  Goto FIN
 Endif
Commit

#-------------------------------------------------------------------------------
$FIN
adxifs=[L]SAVIFS
adxirs=[L]SAVIRS
adxium=[L]SAVIUM
End

#-------------------------------------------------------------------------------
$DEFVAR
Local Char    DATFMT(8), SAVIRS(2), SAVIFS(1)
Local Libelle SAVIUM

[L]DATFMT  ="DDMMYYYY"
[L]SAVIRS  =adxirs
[L]SAVIFS  =adxifs
[L]SAVIUM  =adxium
adxirs     =chr$(13)+chr$(10)
adxifs     =""
adxium     =[V]GASCII
Return

#-------------------------------------------------------------------------------
$ECRITURE

Filter [LNK] Order By Key CLE=[CCS]NUMCPY
Columns [FEH] (LOC,LNG,ZON)
For [LNK]CLE(1)
# SBA FQ92041 - US1927
 If [M:TCCS]TYPEXP=2
  [L]FICHIER=filpath([V]GDIRBQE,[M:TCCS]FIL+num$([F:CCS]NUMCPY),"ccs",0)
 Else
  [L]FICHIER=[L]CLI_FICHIER
  Call SET_FICNAM([L]FICCLI,[L]FICHIER,[L]MATRI) From ORDSYS
  [L]FICHIER+=num$([F:CCS]NUMCPY)+".ccs"
 Endif
 #Openo filpath([V]GDIRBQE,[M:TCCS]FIL+num$([F:CCS]NUMCPY),"ccs",0), 0 Using [OPO]
 Openo [L]FICHIER, 0 Using [OPO]
 #SBA fin
 Raz NBPCE, TOTBASCNG

 For [LNK]CLE
  # ! bogue si [M]CRI porte sur EMPLOCTR
  Call CONTROLE([F:CCS]REFNUM,[F:HRCTR]CTRDAT,[F:CCS]CTRNUM,[M:TCCS]CRI,[L]STAT,1) From DIVPAYE
  If [L]STAT
   Readlock [CCS]CCS0 =
   If fstat=1
    GOK  =-1
    GLOCK="$CERTIFCCS"-[F:CCS]NUMCER
    Break 2
   Elsif fstat
    GOK=0
    Call RSTA("CCS",[F:CCS]NUMCER) From GLOCK
    Break 2
   Endif

   Gosub EMISSION From =[L]FEHTRT

   Call ECR_TRACE( [F:CCS]REFNUM-[F:CCS]NAM-[F:CCS]SRN-[F:CCS]NUMCER,0) From GESECRAN

   [L]NBERR=0
   Onerrgo ERREURWW
   Gosub CONTROLE From =[L]FEHTRT
   Onerrgo

   If ![L]NBERR
    I=adxseek("OPO")
    For [FEH]FEH0 Where FEH=[L]FEH
     If [F:FEH]ZON=""
      Wrseq space$([F:FEH]LNG); Using [OPO]
     Else
      If find([F:FEH]ZON,"NUMSSCSTR","NUMSSCKEY","NUMCCSSTR","NUMCCSKEY","NUMCERJOB","NUMCPYSTR")
       Wrseq format$("N0:"+num$([F:FEH]LNG)+"#",evalue("[L]"+[F:FEH]ZON)); Using [OPO]
      Else
       Case evalue("type([L]"+[F:FEH]ZON+")")
        When 1,2,4,5,6,7,8,9
         Wrseq format$("N0:"+num$([F:FEH]LNG)+"#",evalue("[L]"+[F:FEH]ZON)); Using [OPO]
        When 3
         Wrseq format$("D:"+[L]DATFMT,evalue("[L]"+[F:FEH]ZON)); Using [OPO]
        When Default
         Wrseq ctrans(toupper(left$(evalue("[L]"+[F:FEH]ZON),[F:FEH]LNG))); Using [OPO]
       Endcase
       Wrseq space$([F:FEH]LOC+[F:FEH]LNG-(adxseek("OPO")-I+1)); Using [OPO]
      Endif
     Endif
    Next
    Wrseq Using [OPO]
    Gosub MAJFIC From =[L]FEHTRT
    [F:CCS]STACCS=4 : # Emis
    Rewrite [CCS] Curr
    If fstat
     GOK=0 : Call FSTA("CCS") From GLOCK
     Break 2
    Endif
    NBPCE +=1
    TOTBASCNG += [F:CCS]BASLEA
   Endif

  Endif
 Next
 # SBA FQ92041 - US1927
# If NBPCE<>0
#  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
#  # Fichier généré xxxxx
#  # yy certificats d'emploi enregistrés
#  Call ECR_TRACE(mess(104,121,1)-filpath([V]GDIRBQE,[M:TCCS]FIL+num$([F:CCS]NUMCPY),"CCS",0)
#&                -"\"-num$(NBPCE)-mess(196,703,1)-"\"-mess(197,703,1)-num$(TOTBASCNG),0) From GESECRAN
#  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
#  Call ECR_TRACE("",0) From GESECRAN
# Endif
# Openo Using [OPO]

Openo Using [OPO]

#on sauve le fichier sur le poste local
If [M:TCCS]TYPEXP=1 and NBPCE<>0

  # on récupère le dernier répertoire sélectionné
  If W_REP=""
     W_FICHIER=[L]FICCLI
  Else
     W_FICHIER=W_REP
  Endif
  W_FICHIER+=num$([F:CCS]NUMCPY)+".ccs"
  Call COPCLI([L]FICHIER,W_FICHIER,[L]STAT) From ORDSYS
  If [L]STAT<>0 : [L]TRA = 0 :Break : Endif
  [L]FICHIER=W_FICHIER
  Local Integer WI
  WI=len([L]FICHIER)
  While WI>0
    If mid$([L]FICHIER,WI,1)="\" or mid$([L]FICHIER,WI,1)="/"
      W_REP=left$([L]FICHIER,WI)
      Break
    Endif
    WI-=1
  Wend
Endif
If NBPCE<>0
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  # Fichier généré xxxxx
  # yy certificats d'emploi enregistrés
  # SBA : modification de la trace en remplacant filpath par fichier
#  Call ECR_TRACE(mess(104,121,1)-filpath([V]GDIRBQE,[M:TCCS]FIL+num$([F:CCS]NUMCPY),"CCS",0)
  Call ECR_TRACE("|"+mess(104,121,1)-[L]FICHIER,0)From GESECRAN
  Call ECR_TRACE(""-num$(NBPCE)-mess(196,703,1)-"\"-mess(197,703,1)-num$(TOTBASCNG),0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN
 Endif
 # SBA fin
Next
Filter  [CCS]
Columns [FEH]
Return

#-------------------------------------------------------------------------------
$ERREURWW
Openo Using [OPO]
Rollback
Call ECR_TRACE(errp-num$(errl)-errmes$(errn)-errm,1) From GESECRAN
Goto FIN

######################################################################################
## Etiquette écran TRTCCS
######################################################################################
Subprog C_FIL(VALEUR)
Variable Char    VALEUR()
Local Char    FICHIER(250)
Local Integer OK

Call C_NOMEXP(VALEUR,"ccs") From TRTDUE
If mkstat=2 : End : Endif
End
Subprog AM_DATDEB(VALEUR)
Variable Date     VALEUR
[M]DATFIN = eomonth(VALEUR)
End
######################################################################################
## Section automatically added (screen TRTCCS) 24/05/2012 17:52:09 (ADW)
######################################################################################
Subprog AM_ALLCPY(VALEUR)
Variable Integer VALEUR

If VALEUR = 2
  GCURLEG = ''
Endif

End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

If dim([F:CPY]LEG)>0
  Call LECTURE("CPY",VALEUR,"") From CONTOBJ
  GCURLEG = [F:CPY]LEG
Endif

End

Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Local Integer TEMPO
Gosub GRISE From DIVPAYE
End
######################################################################################

# SBA FQ92041 - US1927
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR

If [V]GBATCH & [L]VALEUR<2
 [V]GMESSAGE=mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat     =2
 End
Endif

If [L]VALEUR=2 : Actzo [TCCS] FIL
Else             Grizo [TCCS] FIL
Endif
End

######################################################################################
Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR

Raz [M:TCCS]FIL
If [L]VALEUR<2
 Call SET_NAMCLI([M:TCCS]FIL) From ORDSYS
Endif
End

######################################################################################
# SBA fin
