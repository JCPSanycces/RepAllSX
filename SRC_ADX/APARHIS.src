#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"APARHIS","APARHIS","") From GSAISIE
End

$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "DEBUT"    : Gosub DEBUT
 When "OK"       : Gosub OK
Endcase
Return

$OUVRE
If clalev([F:AHI])=0 : Local File AHISTO  [AHI] : Endif
If clalev([F:AHD])=0 : Local File AHISTOD [AHD] : Endif
If clalev([F:ATX])=0 : Local File ATEXTE  [ATX] : Endif
Return

$DEBUT
Raz [M]
nolign = 0
For [AHI]AHI0 Where ENAFLG=2
 nolign += 1
 [M] = [F:AHI]
 Call TEXTE([F:AHI]DES,[M]DES(nolign-1)) From OBJDIV
Next
[M]NBLIG = nolign
Affzo
Return

$OK
Call DEBTRANS From GLOCK
Gosub TR1
Return

$TR1
GOK = 1
Trbegin [AHI]
 For [AHI]AHI0
  K = find([F:AHI]COD,[M]COD(0..[M]NBLIG-1))
  If K
   Readlock [AHI] Curr
   If fstat=1
    GOK = -1 : GLOCK = "$AHISTO"-[F:AHI]COD : Break
   Endif
   [F:AHI]FLG1 = [M]FLG1(K-1)
   [F:AHI]TIM1 = [M]TIM1(K-1)
   [F:AHI]FRQ1 = [M]FRQ1(K-1)
   [F:AHI]FLG2 = [M]FLG2(K-1)
   [F:AHI]TIM2 = [M]TIM2(K-1)
   [F:AHI]FRQ2 = [M]FRQ2(K-1)
   Rewrite [AHI]
   If fstat
    GOK = 0 : Call FSTA("AHI") From GLOCK : Break
   Endif
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

###########################################################
## Ecran AHI2
###########################################################
Subprog AS_TIM1(VALEUR)
Variable Decimal VALEUR
If [M]FLG1(nolign-1)<>2 : mkstat = 1 : End : Endif
End

Subprog AS_FRQ1(VALEUR)
Variable Decimal VALEUR
If [M]FLG1(nolign-1)<>2 : mkstat = 1 : End : Endif
End

Subprog AS_TIM2(VALEUR)
Variable Decimal VALEUR
If [M]FLG2(nolign-1)<>2 : mkstat = 1 : End : Endif
End

Subprog AS_FRQ2(VALEUR)
Variable Decimal VALEUR
If [M]FLG2(nolign-1)<>2 : mkstat = 1 : End : Endif
End




