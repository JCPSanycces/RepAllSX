#<AdxTL>@(#)2.0.0.0 $Revision$


#######################################################################
# SUBPBY : Transactions de saisie Assemblage / desassemblage          #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:SRT]STKTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                       [F:AWI]AWINDOW  Table des fenêtres            #
#                       [F:AWP]AWINPAR  Table des paramètres fenêtres #
#                       [F:AWP]AWINBRO  Table des browser fenêtres    #
#                       [F:AWP]AWINBOUT Table des boutons fenêtres    #
#                                                                     #
# Génération de 1 écran de saisie à partir des écrans de base BBY     #
#                                                                     #
# Nom des écrans générés : WT7yyy                                     #
#                          yyy = nom de la transaction (SRTNUM)       #
#                                                                     #
#######################################################################
Call OBJET("PBY",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
                      Local Char    WDIE_ABRFIC(3) : [L]WDIE_ABRFIC="SRT"
                      Local Integer WDIE_DTRTYP    : [L]WDIE_DTRTYP=7
                      Gosub TRT_DIETRS From SUBDST
 When "AFFMASK"     : Gosub TRT_DIETRS From SUBDST
 When "FILTRE"      : Gosub FILTRE
 When "EFFMASK"     : [M:PBY0]SRTTYP = 7
 When "SETBOUT"     : Gosub SETBOUT 
 When "EXEBOUT"     : Gosub EXEBOUT 
 When "LIENS"       : Gosub TRT_DIETRS From SUBDST : Gosub LIENS
 When "RAZCRE"      : Gosub TRT_DIETRS From SUBDST : Gosub RAZCRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "CREATION"    : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "MODIF"       : Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "ANNULE"      : Delete [AXX] Where CODFIC="STKTRS" & IDENT1=num$([F:SRT]SRTTYP) & IDENT2=[F:SRT]SRTNUM
                      Local Char    WDIE_ABRFIC(3) : [L]WDIE_ABRFIC="SRT"
                      Gosub TRT_DIETRS From SUBDST : Gosub TRT_ECRAN
 When "SEL_TABLE"   : Gosub SEL_TABLE  From SUBETR : # Sélection sur code pièce auto
 When "FERME"        : Call IMPSCR        From ATRTX3
 When Default
Endcase
Return

$PE_STKTRS
[F:SRT]STKFLG    = 2   # sorties toujours automatiques
[F:SRT]SRGWAIFLG = 1   # entrées à quai non autorisées

Gosub PE_STKTRS From SUBSKX
Return

############################################################

#-------------------------------------#
# Chargement nom application courante #
#-------------------------------------#
$OUVRE
GBIDI1=1 : # Valeur testée dans l'objet GAU pour sélection du type de pièce auto stock
Local Char     APPLI            : APPLI=nomap
Local Char     WMODU(3)         : WMODU="T"
Local Integer  WNUM(2)          : WNUM = 2
Local Char     WNOMOBJ(GLONAOB)
Local Char     WNOMTRS(GLONTRS)
Local Char     WACSCOD(GLONACS)
Local Char     WLIBEL(30)
Local Shortint WENAFLG
Local Char     WABR(5)
Return

#-----------------------------------------------------------#
#                                                           #
#-----------------------------------------------------------#
$FILTRE

    FILTSUP = "SRTTYP=7"
    
Return
 
#----------------------------------------------# 
# Désactivation bouton "Validation" et "Copie" # 
#----------------------------------------------# 
$SETBOUT 
    If GREP<>"" or !CLECUR Call VIREBOUT(CHAINE,"12") From GOBJET : Endif 
Return 
 
#-------------------------------------#
# Après appui sur bouton "Validation" #
#-------------------------------------#
$EXEBOUT 
Case BOUT 
  When "1" : Call DEBTRANS From GLOCK 
             Trbegin ADOVAL 
             Gosub TRT_ECRAN : If GOK<1 Rollback Else Commit : Endif 
  When "2" : 
  When Default 
Endcase 
Return 

#------------------------------------------------------------#
# Après lecture de chaque enregistrement chargement de NBAXE #
#------------------------------------------------------------#
$LIENS
#-- Positionnement des valeurs si non renseignées
#** Onglet entête
If [M:PBY0]ENAFLG=0 [M:PBY0]ENAFLG=2         : Endif



#** Onglet général
If [M:PBY1]ABYTYP   =0  [M:PBY1]ABYTYP   =1  : Endif : # code assemblage/desassemblage
If [M:PBY1]COBMVTCOD=0  [M:PBY1]COBMVTCOD=1  : Endif : # quantite composants          
If [M:PBY1]PJTCOD   =0  [M:PBY1]PJTCOD   =3  : Endif : # Affaire (invisible)
If [M:PBY1]TRSFAMCOD=0  [M:PBY1]TRSFAMCOD=1  : Endif : # Famille mouvement
If dim([M:PBY1]WRHCOD)>0
    If [M:PBY1]WRHCOD=0  [M:PBY1]WRHCOD=3  : Endif   : # dépôt (invisible)
Endif
If [M:PBY1]PNTMVTCOD=0  [M:PBY1]PNTMVTCOD=2  : Endif : # entrée / sortie composé   hcb 190505 28649

If dim([M:PBY1]WRHCOD)>0
  If [M:PBY1]WRHOBY = 2
    Diszo [M:PBY1]WRHCOD
  Else
    Actzo [M:PBY1]WRHCOD
  Endif
Endif


WMODU +=format$("N0:2",[M:PBY0]SRTTYP)

Gosub LIENS From SUBETR

Gosub PE_STKTRS
Return

#---------------------------------------#
# Initialisation des valeurs par défaut #
#---------------------------------------#
$RAZCRE
[M:PBY0]ENAFLG=2
#** Onglet général
[M:PBY1]ABYTYP=1     : # Assemblage/desassemblage
[M:PBY1]COBMVTCOD=1  : # quantite composants          
[M:PBY1]PNTMVTCOD=2  : # entrée / sortie composé   hcb 190505 28649

[M:PBY1]PJTCOD=3     : # Affaire 
[M:PBY1]TRSFAMCOD=3  : # Famille mouvement
If dim([M:PBY1]WRHCOD)>0
    [M:PBY1]WRHCOD=3  : # dépôt
Endif

Actzo [PBY0]
Actzo [PBY1]

WMODU +=format$("N0:2",[M:PBY0]SRTTYP)
Gosub RAZCRE From SUBETR

Gosub PE_STKTRS
Affzo [PBY0]1-99
Affzo [PBY1]1-99
Return

#-----------------------------------#
# Après modification de chaque zone #
#-----------------------------------#
$APRES_MODIF
Case COUZON
  When Default
       Gosub APRES_MODIF From SUBETR
       Gosub PE_STKTRS
Endcase

#Grizo [M:ETR1]SRGWAIFLG

Return

#---------------------------#
# Chargement avant le Write #
#---------------------------#
$INICRE
WABR = "PBY0"
Gosub CHARGE_ATEXTRA From SUBETR
Gosub PE_STKTRS
Return

#-----------------------------#
# Chargement avant le Rewrite #
#-----------------------------#
$INIMOD
WABR = "PBY0"
Gosub CHARGE_ATEXTRA From SUBETR
Gosub PE_STKTRS
Return

#------------------------------------------------#
# Génération ou suppression des écrans de saisie #
#------------------------------------------------#
$TRT_ECRAN
If dim(APPLI)<0 Local Char APPLI : Endif
If dim(WMODU)<0 Local Char WMODU(3) : Endif
If APPLI=""    APPLI=nomap      : Endif
If dim(OK)<0  : Local Integer OK : Endif
Local Char     MFROM(GLONAMK)
Local Char     MTO(GLONAMK), MTOB(GLONAMK)
Local Integer  TBLOC(15)
Local Char     TZONE(GLONAVA)(200)
Local Integer  TMOD(200)
Local Char     TINT(1)(200)
Local Char     TTAB(1)(1)
Local Char     TFLD(1)(1)
Local Integer  OPT1, OPT2, OPT3, RETOUR
Local Integer  IZON, I, FLAG
Local Char     BOUTONS(10)(4)
Local Char     TEXTE(40), LISTE(3), REPONS(1)  
Local Char     WNOMMSK(GLONAMK)
Local Shortint WFLGMSK


If WMODU=""
    WMODU = "T"+format$("N0:2",[M:PBY0]SRTTYP)
Endif

#---------------- Noms fenêtres et traitement entrées diverses ---------#
If [M:PBY1]ABYTYP = 1
   Local Char     WINREF1(GLONFEN) : WINREF1="OBBY"
   Local Char     NOMWIN1(GLONFEN) : NOMWIN1="WOBBY"+[M:PBY0]SRTNUM
   Local Char     NOMMSKENT(GLONAMK)    # Nom du masque d'entête de la fenêtre
   MFROM="BBY0"
Else
   Local Char     WINREF1(GLONFEN) : WINREF1="ODBY"
   Local Char     NOMWIN1(GLONFEN) : NOMWIN1="WODBY"+[M:PBY0]SRTNUM
   Local Char     NOMMSKENT(GLONAMK)    # Nom du masque d'entête de la fenêtre
   MFROM="DBY0"
Endif
#-------------------------- écran en-tête ---------------------------#
MTO="W"+WMODU+[M:PBY0]SRTNUM+"0"
NOMMSKENT=MTO
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"
# rubriques entete
   If [M:PBY1]PJTCOD>1     TZONE(IZON)="PJT"                : # Affaire
                           TMOD(IZON) =[M:PBY1]PJTCOD    
                           IZON+=1
   Endif
   If [M:PBY1]TRSFAMCOD>1  TZONE(IZON)="TRSFAM"             : # Famille mouvement
                           TMOD(IZON) =[M:PBY1]TRSFAMCOD
                           IZON+=1
   Endif
   If dim([M:PBY1]WRHCOD)>0
       If [M:PBY1]WRHCOD>1 TZONE(IZON)="WRHE"               : # dépôt
                           TMOD(IZON) =[M:PBY1]WRHCOD
                           IZON+=1
       Endif
   Endif

  If [M:DST]CCESCR>1
     For I=0 To 19
       TZONE(IZON)="CCE"+num$(I+1)
       TMOD(IZON) =9
       TINT(IZON) =num$([M:DST]CCESCR)
       IZON+=1
     Next I
   Endif

   OPT1=2
   Gosub PE_STKTRS
   Gosub TRT_CHAMP_HEADER From SUBETR
   Gosub TRT_CHAMP_DOC From SUBETR

Else OPT1=9
Endif

Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif


#-------------------------- 1er écran   Sortie  / entrée  ----------------------#
If [M:PBY1]ABYTYP = 1
   MFROM="BBY1"
Else
   MFROM="DBY1"
Endif

MTO="W"+WMODU+[M:PBY0]SRTNUM+"1"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"

   If [M:PBY1]ABYTYP = 2
# --------------------------- Desassemblage  composants = Mvt Entrées
         Gosub TRT_CHAMP_DOC From SUBETR

         If [M:DST]CCESCR>1
            For I=0 To 19
                TZONE(IZON)="CCE"+num$(I+1)
                TMOD(IZON) =9
                TINT(IZON) =num$([M:DST]CCESCR)
                IZON+=1
            Next I
         Endif

# les composants sont uniquement exprimes en US 
         TZONE(IZON)="PCUSTUCOE"          : # Coeff pcustu
         TMOD(IZON) =3
         IZON+=1
         TZONE(IZON)="PCU"                : # Coeff pcustu
         TMOD(IZON) =2
         IZON+=1
         TZONE(IZON)="STU"                : # Unité de stock
         TMOD(IZON) =3
         IZON+=1
         TZONE(IZON)="QTYSTU"             : # Quantité en unité de stock
         TMOD(IZON) =3
         IZON+=1
   Else
# --------------------------- Assemblage  composants = Mvt Sorties
         If [M:DST]CCESCR>1
            For I=0 To 19
                TZONE(IZON)="CCE"+num$(I+1)
                TMOD(IZON) =9
                TINT(IZON) =num$([M:DST]CCESCR)
                IZON+=1
            Next I
         Endif

# les composants sont uniquement exprimes en US 
         TZONE(IZON)="PCUSTUCOE"          : # Coeff pcustu
         TMOD(IZON) =3
         IZON+=1
         TZONE(IZON)="PCU"                : # Coeff pcustu
         TMOD(IZON) =2
         IZON+=1
         TZONE(IZON)="STU"                : # Unité de stock
         TMOD(IZON) =3
         IZON+=1
         TZONE(IZON)="QTYSTU"             : # Quantité en unité de stock
         TMOD(IZON) =3
         IZON+=1

         If dim([M:ETR2]LOTCOD)>0
            If [M:ETR2]LOTCOD>1     TZONE(IZON)="LOT"                : # Lot fournisseur
                             TMOD(IZON) =[M:ETR2]LOTCOD
                             IZON+=1
            Endif
            If [M:ETR2]LOTSCR>1     TZONE(IZON)="LOT"                : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]LOTSCR)
                             IZON+=1
            Endif
         Endif
         If dim([M:ETR2]SLOCOD)>0
            If [M:ETR2]SLOCOD>1     TZONE(IZON)="SLO"                : # Sous-Lot
                             TMOD(IZON) =[M:ETR2]SLOCOD
                             IZON+=1
            Endif
            If [M:ETR2]SLOSCR>1     TZONE(IZON)="SLO"                : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]SLOSCR)
                             IZON+=1
            Endif
         Endif
         If [M:ETR2]STACOD>1     TZONE(IZON)="STA"                  : # Statut
                           TMOD(IZON) =[M:ETR2]STACOD
                           IZON+=1
         Endif
         If [M:ETR2]STASCR>1     TZONE(IZON)="STA"                  : # Présentation tableau
                           TMOD(IZON) =9
                           TINT(IZON) =num$([M:ETR2]STASCR)
                           IZON+=1
         Endif
         If dim([M:ETR2]LOCCOD)>0
            If [M:ETR2]LOCCOD>1     TZONE(IZON)="LOCTYP"             : # Type Emplacement        
                             TMOD(IZON) =[M:ETR2]LOCCOD
                             IZON+=1

                             TZONE(IZON)="LOC"                : # Emplacement        
                             TMOD(IZON) =[M:ETR2]LOCCOD
                             IZON+=1
            Endif
            If [M:ETR2]LOCSCR>1     TZONE(IZON)="LOCTYP"             : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]LOCSCR)
                             IZON+=1

                             TZONE(IZON)="LOC"                : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]LOCSCR)
                             IZON+=1
            Endif
         Endif
         If dim([M:ETR2]SERCOD)>0
            If [M:ETR2]SERCOD>1     TZONE(IZON)="SERNUM"             : # Numéro de série
                             TMOD(IZON) =[M:ETR2]SERCOD
                             IZON+=1
            Endif
            If [M:ETR2]SERSCR>1     TZONE(IZON)="SERNUM"             : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]SERSCR)
                             IZON+=1
            Endif
            If [M:ETR2]SERECOD>1    TZONE(IZON)="SERNUMF"            : # Numéro série fin
                             TMOD(IZON) =3
                             IZON+=1
            Endif
            If [M:ETR2]SERESCR>1    TZONE(IZON)="SERNUMF"           : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]SERESCR)
                             IZON+=1
            Endif
         Endif
# hcb 27200 deb         
         If dim([M:ETR2]IDECOD01)>0
             If [M:ETR2]IDECOD01>1   TZONE(IZON)="PALNUM"             : # identifiant 1
                             TMOD(IZON) =[M:ETR2]IDECOD01
                             IZON+=1
             Endif
             If [M:ETR2]IDESCR01>1   TZONE(IZON)="PALNUM"             : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]IDESCR01)
                             IZON+=1
             Endif
             If [M:ETR2]IDECOD02>1   TZONE(IZON)="CTRNUM"             : # identifiant 2
                             TMOD(IZON) =[M:ETR2]IDECOD02
                             IZON+=1
             Endif
             If [M:ETR2]IDESCR02>1   TZONE(IZON)="CTRNUM"             : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]IDESCR02)
                             IZON+=1
             Endif
         Endif
# hcb 27200 fin
         If dim([M:ETR2]WRHCOD1)>0
            If [M:ETR2]WRHCOD1>1 TZONE(IZON)="WRH"                : # Dépôt
                                 TMOD(IZON) =[M:ETR2]WRHCOD1
                                 IZON+=1
            Endif
            If [M:ETR2]WRHSCR1>1 TZONE(IZON)="WRH"             : # Présentation tableau    # hcb 65404
                                 TMOD(IZON) =9
                                 TINT(IZON) =num$([M:ETR2]WRHSCR1)
                                 IZON+=1
            Endif
         Endif

         If [M:ETR2]MVTDESCOD>1  TZONE(IZON)="MVTDES"             : # Désignation mouvement
                             TMOD(IZON) =[M:ETR2]MVTDESCOD
                             IZON+=1
         Endif
         If [M:ETR2]MVTDESSCR>1  TZONE(IZON)="MVTDES"             : # Présentation tableau
                             TMOD(IZON) =9
                             TINT(IZON) =num$([M:ETR2]MVTDESSCR)
                             IZON+=1
         Endif
     Endif

   OPT1=2
   Gosub PE_STKTRS
Else
    OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Return : Endif
If ACTION="ANNULE" Gosub TRT_SUP_FEN Else Gosub TRT_GEN_FEN : Endif


#--- Génération des écrans et fenêtres de stock  Entrées
WNOMTRS = [M:PBY0]SRTNUM
If [M:PBY1]ABYTYP = 1
   WNOMOBJ = "BBY"
Else
   WNOMOBJ = "DBY"
Endif
ACSCOD  = [M:PBY0]ACSCOD
WLIBEL  = [M:PBY0]DESAXX
WENAFLG = [M:PBY0]ENAFLG
Gosub TRT_ECRAN_STO From SUBETR


Return


#-------------------------------------------------------------------------#
# Si action = "ANNULE"                                                    #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
#-------------------------------------------------------------------------#
$TRT_SUP_FEN
#----- Suppression ----#
Call DELWIN(NOMWIN1,APPLI) From MSKDIV
Return

#-------------------------------------------------------------------------#
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 1 (Non actif)           #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 2 (Actif)               #
# Génération fenêtre, traitement associé et mise à jour traitement objet  #
#-------------------------------------------------------------------------#
$TRT_GEN_FEN
If clalev([F:AWI])=0 Local File =APPLI+".AWINDOW"  [AWI] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWP])=0 Local File =APPLI+".AWINPAR"  [AWP] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWB])=0 Local File =APPLI+".AWINBRO"  [AWB] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWT])=0 Local File =APPLI+".AWINBOUT" [AWT] : Endif : # Si appel par le FUNSTKTRS
#----- Suppression fenêtre -------------#
Gosub TRT_SUP_FEN
If [M:PBY0]ENAFLG=1 : Return : Endif
#----- Génération fenêtre pour changement stock si transaction active -----#
Read [AWI] AWI0=WINREF1
If !fstat
  [F:AWI]WIN       = NOMWIN1
  [F:AWI]MSKENT    = NOMMSKENT
  WNOMMSK=MTO : Gosub ONGLET_INVISIBLE
If [M:PBY1]ABYTYP = 1
   I=find("BBY1",[F:AWI]NOMMSK(0..7))-1 : If I<0 I=0 : Endif
Else
   I=find("DBY1",[F:AWI]NOMMSK(0..7))-1 : If I<0 I=0 : Endif
Endif
 
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = WFLGMSK
  [F:AWI]ACS       = [M:PBY0]ACSCOD
  [F:AWI]LIBEL     = [M:PBY0]DESAXX
  [F:AWI]ENAFLG    = 2
  [F:AWI]TRN       = [M:PBY0]SRTNUM
  Write [AWI]
  If fstat GOK=0 : Call FSTA("AWI") From GLOCK : Return : Endif
  For [AWP] AWP0 Where WIN=WINREF1
    [F:AWP]WIN = NOMWIN1
    Write [AWP]
    If fstat GOK=0 : Call FSTA("AWP") From GLOCK : Break : Endif
  Next
  For [AWB] AWB0 Where WIN=WINREF1
    [F:AWB]WIN = NOMWIN1
    Write [AWB]
    If fstat GOK=0 : Call FSTA("AWB") From GLOCK : Break : Endif
  Next
  For [AWT] AWT0 Where WIN=WINREF1
    [F:AWT]WIN = NOMWIN1
    Write [AWT]
    If fstat GOK=0 : Call FSTA("AWT") From GLOCK : Break : Endif
  Next
  If GOK<1 Return : Endif
Endif
# Pour v140
Call VALID(NOMWIN1,APPLI,0,OK) From VALWIN
GOK = !!OK
Return



#---------------------------------------#
# Modification des écrans de base       #
# pour arranger l'esthétique si des     #
# blocs disparaissent                   #
#---------------------------------------#
$MODIF_ECRAN
Return

#---------------------------------------#
# Restauration des écrans de base       #
# suite à l'action MODIF_ECRAN          #
#---------------------------------------#
$RESTAUR_ECRAN
Return

#-------------------------------------------#
# Recherche si l'onglet doit être invisible #
# WNOMMSK = Nom de l'onglet (écran)         #
# WFLGMSK = 1 au retour si onglet invisible #
#-------------------------------------------#
$ONGLET_INVISIBLE
If clalev([F:AMK])<=0 Local File =APPLI+".AMSK"    [AMK] : Endif
If clalev([F:AMZ])<=0 Local File =APPLI+".AMSKZON" [AMZ] : Endif
Read [AMK] CODMSK=WNOMMSK
If fstat  Raz [F:AMK]  : WFLGMSK=2 : Return : Endif
WFLGMSK=1
For I=0 To [F:AMK]NBBLOC-1
  If [F:AMK]TYPBLOC(I)=1
    Read [AMZ] CODE=WNOMMSK;[F:AMK]BASPAG(I) : If fstat  Raz [F:AMZ] : Endif
    If [F:AMZ]SAIAFF<>3  WFLGMSK=2 : Break : Endif    
  Elsif [F:AMK]TYPBLOC(I)<>5
    WFLGMSK=2 : Break
  Endif
Next I
Return

#########################################################################
#                   Actions sur champs écran [M:PBY1]                   #
#########################################################################

########################################
Subprog AS_SRTNUM(VALEUR)
Variable Char    VALEUR()
[M:PBY0]SRTTYP = 7
End




Subprog AS_NBLIG
End


##########################################################################

#########################################################################
# Pour éxécution validation transaction en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call GENPATCH(7,APPLI) From FUNSTKTRS

End
###########################################################################
# Pour éxécution validation transaction par gestion de dossier            #
#                                       par l'utilitaire de revalidation  #                                          
#      à partir du dictionnaire des types de transaction (ATN)            #
###########################################################################
Subprog GENDOS(APPLI)
Value Char APPLI

Call GENDOS(7,APPLI) From FUNSTKTRS

End




#################################################
$TRTCOP
# TABLE contient la valeur du paramètre 2 de l'action ACOPIE (ici [M]TRUCOD)
If [M]DOSORG=nomap 
 Local File STKTRS [SRT1] 
Else 
 Local File =[M]DOSORG+".STKTRS" [SRT1]
Endif 
If [M]DOSDES=nomap 
 Local File STKTRS [SRT2] 
Else 
 Local File =[M]DOSDES+".STKTRS" [SRT2]
Endif
OK = 1
If GTRACE="" 
 Read [SRT2]SRT0 = 7;TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [SRT1], [SRT2]
Return

$TR_COP
GOK = 1
Trbegin [SRT2]
 Delete [SRT2] Where SRTTYP = 7 &
&                    SRTNUM = TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".STKTRS" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("SRT2","") From GLOCK : Goto AB_TR_COP
 Endif
 Read [SRT1]SRT0=7;TABLE
 If !fstat
  [F:SRT2] = [F:SRT1]
  If dim([F:SRT2]UPDUSR)>0 : [F:SRT2]UPDUSR = GUSER : Endif
  If dim([F:SRT2]UPDDAT)>0 : [F:SRT2]UPDDAT = date$ : Endif
  If dim([F:SRT2]UPDTIM)>0 : [F:SRT2]UPDTIM = time  : Endif
  Write [SRT2]
  If fstat
   GOK=0 : Call FSTA("SRT2") From GLOCK
  Endif
 Endif
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif


######################################################################################
## Etiquette ajoutée par le superviseur (écran PBY1) 09/06/2009 16:24:35 (MAE)
######################################################################################
Subprog AM_WRHOBY(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
    [M:PBY1]WRHCOD = 1
    Grizo [M:PBY1]WRHCOD
Else
    Actzo [M:PBY1]WRHCOD
Endif
Affzo [M:PBY1]WRHCOD
End

