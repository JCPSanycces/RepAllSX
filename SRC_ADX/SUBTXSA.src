Subprog AS_FRM99(VALEUR) : Variable Char VALEUR() : Goto AVS_FRM

$AVS_FRM
Local Integer I, NOL, COL
Local Char EXPR(250), CHAINE(20), CAR(1), CARP(1), CARS(1)
NOL = nolign-1
COL = val(right$(zoncou,4))
If find(mid$([M]FMTPRN(NOL),COL,1),"","0")
 [M]FMTPRN(NOL) = func SUBTXS.REPCAR([M]FMTPRN(NOL),num$([M:TXA1]FMTCOL(COL-1)),COL)
Endif
If find(mid$([M]EFFPRN(NOL),COL,1),"","0")
 [M]EFFPRN(NOL) = func SUBTXS.REPCAR([M]EFFPRN(NOL),num$([M:TXA1]EFFCOL(COL-1)),COL)
Endif
If find(mid$([M]DEC(NOL),COL,1),"")
 [M]DEC(NOL) = func SUBTXS.REPCAR([M]DEC(NOL),num$([M:TXA1]DECCOL(COL-1)),COL)
Endif
If COL>[M:TXA1]NBRCOL
 VALEUR = "" : [M]MODIF = 2
 mkstat = 2 : End
Endif
If [M:TXA1]COLNUM(COL-1)<>""
 If nolign=1
  CHAINE = [M:TXA1]COLNUM(COL-1)
  Gosub SET_FRM
  VALEUR = EXPR
 Else
  VALEUR = evalue("[M]FRM"+num$(COL)+"(nolign-2)")
 Endif
 mkstat = 2 : End
Endif
If COL>1 & VALEUR="" & [M:TXA1]COLNUM(COL-2)=""
 VALEUR = evalue("[M]FRM"+num$(COL-1)+"(NOL)")
 # LS
 [M]MODIF = 2
Endif
End

$SET_FRM
Raz EXPR
For I=1 To len(CHAINE)
 CAR = mid$(CHAINE,I,1) : CARP = mid$(CHAINE,I-1,1) : CARS = mid$(CHAINE,I+1,1)
 If CAR>="0" & CAR<="9"
  If CARP<"0" | CARP>"9"
   EXPR += "L("+CAR
  Else
   EXPR += CAR
  Endif
  If (CARS<"0" | CARS>"9")
   EXPR += ")"
  Endif
 Else
  EXPR += CAR
 Endif
Next I
If EXPR<>"" : EXPR = "R(" + EXPR + ")" : Endif
Return

