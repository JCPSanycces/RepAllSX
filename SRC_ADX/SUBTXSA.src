$MODIFIER
Local Integer I , J
Local Integer NBFRM
Local Char    VALTMP(250) , TBFRM(250)(1..100)
VALEUR = vireblc(toupper(VALEUR),2)
VALTMP = VALEUR
NBFRM  = 0
While VALTMP<>""
 NBFRM += 1
 I = instr(1,VALTMP," ")
 If I
  TBFRM(NBFRM) = left$(VALTMP,I-1)
  VALTMP       = vireblc(right$(VALTMP,I+1),2)
 Else
  TBFRM(NBFRM) = VALTMP
  VALTMP       = ""
 Endif
Wend
If NBFRM>1
 Selbox TBFRM(1..NBFRM) Titled mess(215,111,1) Using J : # Choix formule
 If status=7 : End : Endif
 VALTMP = TBFRM(J)
Elsif NBFRM=1
 J = 1
 VALTMP = TBFRM(1)
Else
 J = 0
 VALTMP = ""
Endif
Gosub ASSISTANT
If J
 TBFRM(J) = VALTMP
Else
 NBFRM = 1
 TBFRM(1) = VALTMP
Endif
VALEUR = TBFRM(1)
For I=2 To NBFRM
 VALEUR -= TBFRM(I)
Next I
End

$ASSISTANT
Local Char PARAM(30)(1..4)
PARAM(1) = [M:TXA0]TXSNAM
PARAM(2) = num$([M:TXA0]GENLEDTYP)
PARAM(3) = num$([M:TXA0]ANALEDTYP)
Call TRAITE_CHAR(VALTMP,PARAM,"","TXSWIZ","TXSWIZ",3,"") From GTRAITE
Return

