$CENTRAL
# Clic droit menu "Centralisable O/N"
Local Integer COL
Local Char    VALCEN(1) , STYLE(GLONASY)
COL = val(right$(zoncou,4))
VALCEN = mid$([M]CEN(nolign-1),COL,1)
If VALCEN="2"
 VALCEN = "1"
 STYLE  = ""
Else
 VALCEN = "2"
 STYLE  = "TDBBLU"
Endif
Case COL
 When  1 : Chgstl [M]FRM1(nolign-1)  With STYLE
 When  2 : Chgstl [M]FRM2(nolign-1)  With STYLE
 When  3 : Chgstl [M]FRM3(nolign-1)  With STYLE
 When  4 : Chgstl [M]FRM4(nolign-1)  With STYLE
 When  5 : Chgstl [M]FRM5(nolign-1)  With STYLE
 When  6 : Chgstl [M]FRM6(nolign-1)  With STYLE
