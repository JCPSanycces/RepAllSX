$CONTROLE_FRM
Local Integer COL
Local Char    FORMULE(250)
COL = val(right$(zoncou,4))
If COL   :# On ne touche pas à la colonne Intitulé
 VALEUR = toupper(VALEUR)
Endif
FORMULE = evalue("[M]FRM"+num$(COL)+"(nolign-1)")
If FORMULE<>VALEUR
 [M]MODIF = 2
Endif
# Contrôle de la formule saisie
If COL
 Call C_FORMULE(VALEUR) From SUBTXSB
Endif
End

