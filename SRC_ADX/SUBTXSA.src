$IB_FRM
# 1 Modifier
# 2 Ajouter
# 3 Format
# 4 Centralisable O/N
# 5 Recopie vers le bas
# 6 Choix variable
# 7 Signification
Local Integer COL
COL = val(right$(zoncou,4))
GBOUT3 = mess(113,105,1)   :# Format zone
Raz GBOUT4, GBOUT5, GBOUT6
If COL>0
 If mid$([M]CEN(nolign-1),COL,1)="2"
  GBOUT4 = mess(112,105,1)   :# Centralisable Non
 Else
  GBOUT4 = mess(111,105,1)   :# Centralisable Oui
 Endif
 GBOUT5 = mess(141,111,1)   :# Recopie vers le bas
 If [M:TXA3]NBVAR>0
  GBOUT6 = mess(4,124,1) : # Choix variable
 Endif
Endif
End

