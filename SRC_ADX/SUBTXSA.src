$RECOPIE
# Recopie de la formule vers le bas jusqu'à [M]NBLIG
Local Integer I, COL, DEB, FIN
Local Char CO(250), CC(250)   :# champ origine à copier, champ courant
COL = val(right$(zoncou,4))
DEB = nolign
FIN = [M]NBLIG-1
CO = evalue("[M]FRM"+num$(COL)+"(nolign-1)")
For I=DEB To FIN
 CC = evalue("[M]FRM"+num$(COL)+"("+num$(I)+")")
 Assign "[M]FRM"+num$(COL)+"(I)" With CO
Next I
Affzo ="FRM"+num$(COL)
[M]MODIF = 2
Assign "[M]FRM"+num$(COL)+"("+num$(DEB-1)+")" With CO
End

# Renumérotation en cas d'insertion/suppression

$PARCOURS
For IL=NOL To [M]NBLIG-1
 For IC=1 To [M:TXA1]NBRCOL
  OLDFOR = vireblc(evalue("[M]FRM"+num$(IC)+"(IL)"),2)
  NEWFOR = ""
  While OLDFOR<>""
   K = instr(1,OLDFOR," ")
   If K
    FORMULE = vireblc(left$(OLDFOR,K-1),2)
    OLDFOR  = vireblc(right$(OLDFOR,K+1),2)
   Else
    FORMULE = OLDFOR
    OLDFOR  = ""
   Endif
   Gosub MODIF_FRM
   NEWFOR -= FORMULE
  Wend
  Assign "[M]FRM"+num$(IC)+"(IL)" With vireblc(NEWFOR,2)
 Next IC
Next IL
Affzo [TXA2]
Return

$MODIF_FRM
J = 1
Repeat
 J = instr(J,FORMULE,"L")
 If J
  I = J+1
  LIG1 = 0
  LIG2 = 0
  DEUX = 0
  EXPR = "L"
  Repeat
   CAR = mid$(FORMULE,I,1)
   If CAR>='0' & CAR<='9'
    If DEUX
     LIG2 = LIG2*10+val(CAR)
    Else
     LIG1 = LIG1*10+val(CAR)
    Endif
   Elsif CAR=':'
    DEUX = 1
   Else
    Break
   Endif
   I += 1
  Until I>len(FORMULE)
  If LIG1<>0
   If INS
    If LIG1>NOL : LIG1 += 1 : Endif
    If LIG2>NOL : LIG2 += 1 : Endif
   Else
    If LIG1>=NOL : LIG1 = max(NOL,LIG1-NBL) : Endif
    If LIG2>=NOL : LIG2 = max(NOL,LIG2-NBL) : Endif
   Endif
   EXPR += num$(LIG1)
   If DEUX
    EXPR += ":"+num$(LIG2)
   Endif
   FORMULE = left$(FORMULE,J-1)+EXPR+right$(FORMULE,I)
  Endif
 J = I
 Endif
Until J=0
Return

# Bouton 6 Choix variable (action SELVARIA)

# Bouton 7 Signification (action TXSFRM)

####################
### Masque TXSA3
####################
Subprog C_NBVAR
Local Integer IC, IL, TR
Local Char    FORMULE(250), NOM(10)
If find(status,65,83)   :# suppressions
 NOM = [M]VARNAM(nolign-1)
 If NOM<>""
  TR = 0
  For IL=0 To [M:TXA2]NBLIG-1
   For IC=1 To [M:TXA1]NBRCOL
    FORMULE = evalue("[M:TXA2]FRM"+num$(IC)+"(IL)")
    If FORMULE<>""
     If instr(1,FORMULE,NOM)
      TR = 1 : Break 2
     Endif
    Endif
   Next IC
  Next IL
  If TR
   # Variable utilisée colonne ... ligne
   GMESSAGE = mess(121,105,1)-"'"+[M:TXA1]NAMCOL(IC-1)+"', "-mess(61,100,1)-num$(IL+1)
   mkstat=2
  Endif
 Endif
Endif
End

Subprog C_VARNAM(VALEUR)
Variable Char    VALEUR()
Local Integer I
Local Char C(1)
For I=1 To len(VALEUR)
 C = mid$(VALEUR,I,1)
 If !((C>="0" & C<="9") | (C>="A" & C<="Z") | C="_")
  GMESSAGE = mess(113,123,1)-":"-C
  mkstat = 2 : Break
 Endif
Next I
If mkstat : End : Endif
If left$(VALEUR,2)<>"V_"
 If len(VALEUR)>8
  GMESSAGE = mess(115,105,1)   :# Nom de variable limité à 8 caractères
  mkstat = 2 : End
 Else
  VALEUR = "V_"+VALEUR
 Endif
Else
 If len(right$(VALEUR,3))<1
  mkstat = 2 : End
 Endif
Endif
Call UNICITE(VALEUR,[M]VARNAM(0..[M]NBVAR-1)) From OBJDIV
End

Subprog AM_VARNAM(VALEUR)
Variable Char    VALEUR()
Local Char    ANCNOM(10), NOVNOM(10), NOMVAR(10), FORMULE(250)
Local Integer K, IC, IL, EXISTE

# Mise à jour du nom de la variable dans les formules saisies
ANCNOM = vireblc([M]VARNAM(nolign-1),2)
If ANCNOM="" : End : Endif
NOVNOM = VALEUR
For IL=0 To [M:TXA2]NBLIG-1
 If [M:TXA2]FRM0(IL)<>""
  For IC=1 To [M:TXA1]NBRCOL
    FORMULE = evalue("[M:TXA2]FRM"+num$(IC)+"(IL)")
    If FORMULE<>""
     K = instr(1,FORMULE,ANCNOM)
     If K
       NOMVAR = mid$(FORMULE,K,len(ANCNOM)+1)
       # ANCNOM a-t-il une racine commune avec une autre variable ?
       EXISTE = sigma(0,[M:TXA3]NBVAR-1,instr(1,[M:TXA3]VARNAM(indcum),NOMVAR))
       If !EXISTE
         FORMULE = left$(FORMULE,K-1) + NOVNOM + right$(FORMULE,K+len(ANCNOM))
         Assign "[M:TXA2]FRM"+num$(IC)+"(IL)" With FORMULE
       Endif
     Endif
    Endif
  Next IC
 Endif
Next IL
Affzo [TXA2]
End

Subprog C_VARTYP(VALEUR)
Variable Char    VALEUR()
If clalev([F:ATY])=0 : Local File ATYPE [ATY] : Endif
If VALEUR<>""
 Read [ATY]CODTYP = VALEUR
 If [F:ATY]OBJLIEN=""
  GMESSAGE = mess(83,123,1) : mkstat=2 : End
 Endif
Endif
End

Subprog AS_VARPAR(VALEUR)
Variable Char    VALEUR()
If [M]VARTYP(nolign-1)<>""
 Call LECTURE("ATY",[M]VARTYP(nolign-1),"") From CONTOBJ
 Read [AOB]ABREV = [F:ATY]OBJLIEN
 If [F:AOB]LIBPAR=0
  mkstat = 1
 Endif
Else
 mkstat = 1
Endif
End

Subprog C_VARPAR(VALEUR)
Variable Char    VALEUR()
Local Char OBJET(GLONAOB)
Case [M]VARTYP(nolign-1)
 When "CCE" : OBJET = "DIE"
 When "GAC" : OBJET = "COA"
 When "BUV" : OBJET = "BUP"
Endcase
If OBJET<>"" & VALEUR<>""
 Call CONTROLE(OBJET,"",VALEUR,"",mkstat) From CONTOBJ
Endif
End

Subprog C_VARDEF(VALEUR)
Variable Char    VALEUR()
Local Char ZONE(20), ABR(3)
Local Integer K
VALEUR = toupper(VALEUR)
ZONE = ctrans(VALEUR,'"','')
ABR = [M]VARTYP(nolign-1)
If ABR<>"" & ZONE<>"" & !instr(1,ZONE,"*") & !instr(1,ZONE,".") & !instr(1,ZONE,"?") & !instr(1,ZONE,"!") & !instr(1,ZONE,"#")
 Call CONTROLE(ABR,"",VALEUR,[M]VARPAR(nolign-1),mkstat) From CONTOBJ
Endif
End

## Mise à jour du NUMCOL en cas d'insertion de ligne dans le tableau
## pour bien gérer les intitulés traduisibles
## Update the NUMCOL field when inserting a line in the array
## in order to manage the translatable titles
Subprog AS_NAMCOL(VALEUR)
Variable Char    VALEUR()
If [M]NUMCOL(nolign-1)=0
 GMAXNUMCOL +=1
 [M]NUMCOL(nolign-1) = GMAXNUMCOL
Endif
End

## Mise à jour du LIG en cas d'insertion de ligne dans le tableau
## pour bien gérer les intitulés traduisibles
## Update the LIG field when inserting a line in the array
## in order to manage the translatable titles
Subprog AS_FRM0(VALEUR)
Variable Char    VALEUR()
If [M]LIG(nolign-1)=0
 GMAXLIG +=1
 [M]LIG(nolign-1) = GMAXLIG
Endif
End
