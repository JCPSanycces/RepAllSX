A_DATE  = [09/11/2018]
A_HEURE = "23:07:26"
A_USER  = "DOC"
A_STAMP = "20181109230726"
Return

$DEFAUT
Default File [CPC]
Return

$OUVFIC
Local File COMPETENCE [CPC]
Return

$NOMFIC
Local Integer NBLNK , TITLNK(1..20)
Local Char    OBJLNK(GLONAOB)(1..20) , CODLNK(GLONADI)(1..20)
Local Char    DESLNK(20)(1..20) , ABRLNK(GLONABR)(1..20)
Local Integer NUMLNK(1..20) , LIGLNK(1..20)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , ABTAB(GLONABR) , NOMINT(GLONAVA)
Local Integer TYPGES , FLGSTAT , SELORD , TYPOBJ
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA), FLDGRF(GLONAVA), FLDLEG(GLONAVA), FLDGRC(GLONAVA)
Local Char    REPORT1(GLONARP) , REPORT2(GLONARP) , NOMKEY(GLONAVA)
Local Integer DELDEF, FCYREQ
Local Char    SELIND(250) , ADDURL(250)
NOMFIC = "COMPETENCE"
ABFIC  = "CPC"
ABTAB  = "CPC"
NOMINT = "DES"
TYPGES = 1
SELORD = 1
ZSITE  = ""
ZACC   = ""
FLDGRF = ""
FLDGRC = ""
FLDLEG = "LEG"
FCYREQ = 0
PPAG   = 0
SELIND = ""
DELDEF = 0
ADDURL = ""
REPORT2 = "LISTCPC"
FLGSTAT = 0
TITOBJ = 22067
NBLNK = 0
Raz NUMLNK , LIGLNK
Return

$OUVRE
If clalev([F:HRSCA])=0 : Local File SCALE        [HRSCA] : Endif
If clalev([F:HRSDD])=0 : Local File SCALED       [HRSDD] : Endif
If clalev([F:CPD])=0 : Local File COMPETENCED  [CPD] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA      [AXX] : Endif
Return

$ESPION
NUMESPION = 1
Return

$TIT
