#<AdxTL>@(#)2.0.0.0 $Revision$
############################################################################################# 
#                   DECLARATIONS ECHANGES DE BIENS                                          #
#   A partir des RECEPTIONS facturees ou pas                                                #
#-------------------------------------------------------------------------------------------#  
#                                                                            cg juin 98     #
############################################################################################# 
 
$ACTION
Case ACTION
        When "EXPORT" : Gosub EXPORT
        When Default
Endcase
Return


$EXPORT

#-------------------------------------------------#
# GIMP (1) --->     departement  de destination effective à l intro  #
# GIMP (2) --->     Numéro TVA client             # 
# GIMP (3) --->     Pays origine                  #
# GIMP (4) --->     Pays provenance               #
# GIMP (5) --->     Nature transactionA           #
# GIMP (6) --->     Nature transactionB           #
# GIMP (7) --->     Valeur fiscale en dev recp    #
# GIMP (8) --->     Valeur stat  dev recp         #
#-------------------------------------------------#

If [F:PTD]QTYPUU = 0   : OK = 0 : Return : Endif

#----------------------------#
# voir si on active la ligne #
#----------------------------#
#If [F:PTD]LINEECFLG = 2  : OK = 0 : Return : Endif

#------------------------------------------------#
# si ok = 0 pas d'enreg dans le fichier d'export #
#------------------------------------------------#
If clalev ([F:BPR]) = 0 : Local File BPARTNER   [BPR] : Endif
If clalev ([F:BPS]) = 0 : Local File BPSUPPLIER [BPS] : Endif
If clalev ([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev ([F:BPA]) = 0 : Local File BPADDRESS  [BPA] : Endif

If clalev ([F:PTH]) = 0 : Local File PRECEIPT   [PTH] : Endif
If clalev ([F:TCY]) = 0 : Local File TABCOUNTRY [TCY] : Endif
If clalev ([F:PIH]) = 0 : Local File PINVOICE   [PIH] : Endif
If clalev ([F:PID]) = 0 : Local File PINVOICED  [PID] : Endif


Local Integer STAT
Local Decimal WMONTANT, WQUANTITY



Read [PTH]PTH0 = [F:PTD]PTHNUM
If fstat  : Raz  [F:PTH] : Endif

#------------------#
# lecture du tiers #
#------------------#
Read [BPR]BPR0 = [F:PTH]BPSNUM
If fstat  : Raz  [F:BPR] : Endif

GIMP(2) = [F:BPR]EECNUM

#-------------------------#
# lecture du fournisseur  #
#-------------------------#
Read [BPS]BPS0 = [F:PTH]BPSNUM
If fstat  : Raz  [F:BPS] : Endif


#---------------------------------------------#
# lecture de l adresse du site de reception   #
# recuperation  du departement                #
#---------------------------------------------#
Read [FCY]FCY0 = [F:PTH]PRHFCY
If fstat : Raz [F:FCY] : Endif
Read [BPA]BPA0= 3;[F:FCY]FCY ;[F:FCY]BPAADD 
If fstat : Raz [F:BPA]  : Endif
GIMP(1) = left$([F:BPA]POSCOD,2)


#--------------------------------------------#
# lecture table des pays recup code EEC pays #
#--------------------------------------------#
Read [TCY]TCY0 = [F:PTD]ORICRY
If fstat  : Raz  [F:TCY] : Endif
GIMP (3) = [F:TCY]EECCOD

Read [TCY]TCY0 = [F:BPR]CRY
If fstat  : Raz  [F:TCY] : Endif
#---------------------------------------------------------#
# si pays non CEE  ou même pays que site de rcp pas de DEB#
# si ok = 0 pas d'enreg dans le fichier d'export          #
#---------------------------------------------------------#
If [F:TCY]EECFLG <> 2  | [F:TCY]EECCOD = GIMP(3) : OK = 0 : Return : Endif

GIMP (4) = [F:TCY]EECCOD

GIMP (5) = mid$([F:PTH]EECNAT,2,1)
GIMP (6) = right$([F:PTH]EECNAT,3)

#-------------------------------------------------------------#
# lecture des factures sur la ligne pour recupérer le montant #
# attention la qté receptionnée n est pas forcement facturée  #
# entierement                                                 #
#-------------------------------------------------------------#

Filter [PID] Where TYPORI = 2 and  NUMORI = [F:PTD]PTHNUM    and LINORI = [F:PTD]PTDLIN 
&            and   SEQORI = 0 Order By Key PID1
WMONTANT = 0
WQUANTITY = [F:PTD]QTYPUU
For [PID] 
    Read [PIH]PIH0 = [F:PID]NUM
    If fstat = 0
        GBIDD2     = [F:PID]AMTNOTLIN
        WQUANTITY -= [F:PID]QTYPUU
        #--- conversion du montant facture dans la devise de la réception
        If [F:PIH]CUR <> [F:PTH]CUR
            Call CONVERT2([F:PIH]CUR,[F:PTH]CUR,GCUR,[F:PTH]CHGTYP,GHIDATE,GBIDD2,GBIDD2,STAT) From TRTDEV
            Call ARRDEV (GBIDD2,[F:PTH]CUR) From TRTDIV
        Endif
        WMONTANT += GBIDD2
    Endif
Next
Filter [PID]

If WQUANTITY > 0
        #------------------------------------------#
        # ajout du restant dans le prix NETPRIPUU  #
        #------------------------------------------#
        GBIDD2 = WQUANTITY * [F:PTD]NETPRIPUU
        #--- conversion du montant dans la devise de la réception
        If [F:PTH]CUR <> [F:PTD]NETCUR
            Call CONVERT2([F:PTD]NETCUR,[F:PTH]CUR,GCUR,[F:PTH]CHGTYP,GHIDATE,GBIDD2,GBIDD2,STAT) From TRTDEV
            Call ARRDEV (GBIDD2,[F:PTH]CUR) From TRTDIV
        Endif
        WMONTANT += GBIDD2
Endif

GIMP (7) = num$(WMONTANT)
If [F:PTD]EECINCRAT <> 0
        GIMP (8) = num$(WMONTANT *(1+[F:PTD]EECINCRAT/100))
Else    GIMP (8) = num$(WMONTANT)
Endif


GBIDC1 = [F:PTD]PTHNUM
GBIDI2 = [F:PTD]PTDLIN

Update [PTD] Where PTHNUM = GBIDC1 and PTDLIN = GBIDI2 With LINEECFLG = 2

Return
