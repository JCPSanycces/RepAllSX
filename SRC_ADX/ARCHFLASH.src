#<AdxTL>@(#)3.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"ARCHFLASH","ARCHFLASH","") From GSAISIE
End

$ACTION
Case ACTION
 When "DEBUT"       : Gosub DEBUT
Endcase
Return


$DEBUT
Local Char NAMEREP(GDIMFIC),NAMEREP1(GDIMFIC),MACHINE(GDIMFIC)
Local Char REP(GDIMFIC)
Local Integer POSK,LKF

Case toupper(GOS(1))
 When "DOS"   : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase

If adxmac(0)<>"" and adxmac(-1)<>"" and adxmac(0)<>adxmac(-1) : MACHINE=adxmac(0) : Endif

REP="X3_ROOT"+DIRSEP+"X3CLI"
Local Char RESULT(200)(1..20)
NAMEREP=filpath(REP,"xblock_coreflashcustcli","tar","X3_PUB","",MACHINE)
LKF=filinfo(NAMEREP,7)
If LKF>0
  [M]A0="xblock_coreflashcustcli.tar : "+mess(52,125,1)-num$(LKF)-mess(133,133,1)
Else
  [M]A0="xblock_coreflashcustcli.tar : "+mess(101,100,1)
Endif

Return


######################################################################################
## Etiquette ajoutée par le superviseur (écran ARCHFLASH) 08/12/2008 14:43:00 (CCORA)
######################################################################################
Subprog CL_A1(VALEUR)
Variable Char    VALEUR()
Local Integer STATF
Local Char MACHINE(GDIMFIC)
If adxmac(0)<>"" and adxmac(-1)<>"" and adxmac(0)<>adxmac(-1) : MACHINE=adxmac(0) : Endif

Call CREFLASHCUST(MACHINE,"","",STATF)
If STATF=0
 Local Char REP(GDIMFIC),DIRSEP
 Case toupper(GOS(1))
  When "DOS"   : DIRSEP="\"
  When Default : DIRSEP="/"
 Endcase
 Local Integer LKF
 REP="X3_ROOT"+DIRSEP+"X3CLI"
 NAMEREP=filpath(REP,"xblock_coreflashcustcli","tar","X3_PUB","",MACHINE)
 LKF=filinfo(NAMEREP,7)
 If LKF>0
   [M]A0="xblock_coreflashcustcli.tar : "+mess(52,125,1)-num$(LKF)-mess(133,133,1)
   Affzo [M]A0
   Infbox(mess(14,9011,1))
 Else
  Call ERREUR(mess(221,124,1)) From GESECRAN
 Endif
Else
 Call ERREUR(mess(221,124,1)) From GESECRAN
Endif
End


######################################################################################

Subprog CREFLASHCUST(MACH,BASE,TOZIP,STATF)
Value Char MACH()
Value Char BASE
Value Char TOZIP
Variable Integer STATF

#    Recrée une nouveau tar de l'arborescence FLASH_CUSTOM sous X3CLI .tar
#    MACHINE : si précisé nom de la machine distante  exemple gaile610:1941
#              si MACHINE est vide on considère que l'on travaille sur adxmac(0) ou adxmac(-1)

#    STATF = 0 on a effectué la création (on vérifie si le fichier est présent), 1 sinon (on restaure l'ancien si on peut)

Local Char NAMEREP(GDIMFIC),NAMEREP1(GDIMFIC),MACHINE(GDIMFIC)
Local Char OPT(200),ORDRE(200),DIRSEP,BASE1(100),TOZIP1(100)
Local Char REP(GDIMFIC),TYPOS
Local Integer STAT,POSK,LKF

TOZIP1=TOZIP
If TOZIP1="" : TOZIP1="FLASH_CUSTOM" : Endif

BASE1=BASE
If BASE1="" : BASE1="X3CLI" : Endif

MACHINE=MACH
Call GET_OS(MACHINE,TYPOS) From ORDSYS


#  Génération de l' archive TOZIP1
Call ECR_TRACE(mess(216,139,1)-TOZIP1-BASE1-MACHINE,0) From GESECRAN

Case toupper(TYPOS)
 When "DOS"   : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase


REP="X3_ROOT"+DIRSEP+BASE1
Local Char RESULT(200)(1..20)
NAMEREP=filpath(REP+DIRSEP+"XBLOCK","","","X3_PUB","",MACHINE)
POSK = instr(1,NAMEREP,"@")
If POSK<>0 : NAMEREP = right$(NAMEREP,POSK+1) : Endif
LKF=filinfo(NAMEREP,0)
If LKF>0
  NAMEREP1=filpath(REP,"xblock_coreflashcustcli","tar","X3_PUB","",MACHINE)
  POSK = instr(1,NAMEREP1,"@")
  If POSK<>0 : NAMEREP1 = right$(NAMEREP1,POSK+1) : Endif
  If toupper(TYPOS)="DOS"
    Gosub ECRCOM
  Else
    ORDRE="cd "+NAMEREP+";tar -cvf "+NAMEREP1-TOZIP1
  Endif

System RESULT = MACHINE+"@"+ORDRE
Sleep(1) :#SAM 112765 : give time to the system for unlocking the folder

Endif

End

$ECRCOM
Local Char FILOUT(250)
FILOUT=filpath("tmp","F"+num$(adxuid(1))+"_CRARCHI","bat",nomap,"",MACHINE)

Openo FILOUT,0 Using [O_ED]
Iomode adxifs "" Using [O_ED]
Iomode adxirs chr$(10) Using [O_ED]
Iomode adxium GASCII Using [O_ED]

Wrseq "@ECHO off" Using [O_ED]
Wrseq "SET ADXDIR="+adxdir Using [O_ED]
Wrseq "SET TMPDIR="+adxdir+"\tmp" Using [O_ED]
Wrseq "SET PATH=%ADXDIR%\ebin;%ADXDIR%\bin;%ADXDIR%\lib;%PATH%" Using [O_ED]
Wrseq "cd /D "+NAMEREP Using [O_ED]
Wrseq "del ..\xblock_coreflashcustcli.tar" Using [O_ED]
Wrseq '7za.exe a -ttar '+"..\xblock_coreflashcustcli.tar"-TOZIP1+"\*"+' -r -y' Using [O_ED]
Wrseq "cd .." Using [O_ED] :#SAM 112765 get out of XBLOCK in order to unlock it
Wrseq "cd .." Using [O_ED] :#SAM 112765 get out of DIRSEP in order to unlock it
Wrseq "exit" Using [O_ED]

Openo Using [O_ED]
ORDRE=FILOUT
POSK = instr(1,ORDRE,"@")
If POSK<>0 : ORDRE = right$(ORDRE,POSK+1) : Endif
Return

