##############################################################################
#fonction de contôle du cache des images ilog
Subprog CTRLCACHE(ERR)
Variable Integer ERR
Local File ILOGIMG [ILI]
Local Integer NBROW
Local Integer I
Local Integer NBBAD
Local Clbfile RETOUR
Local Integer POSITION,VERSION

POSITION=0
VERSION=0

POSITION=instr(0,GRELCLI,'.')
VERSION=val(right$(GRELCLI,POSITION+1))
If VERSION < 17
  End
Endif
NBBAD=0
#comptage des lignes de la table
NBROW = rowcount([ILI])
If NBROW = 0
  Close Local File [ILI]
  End
Endif
#Déclaration des tableaux
Local Integer TABTIMESTAMP(NBROW)
Local Char TABFICNAME(250)(NBROW)
Local Char TABBADFILE(250)(NBROW)
I=0
#alimentation des tableaux de nom de fichier et de timestamp
For [ILI]
  TABFICNAME(I)=[ILI]NOMFIC
  TABTIMESTAMP(I)=val([ILI]TIMESTAMP)
  I+=1
Next
#Appel de la fonction du client X3 qui va checker les fichiers du cache
# ICI appel de la fonction Funciu
RETOUR = Funciu "SESS_CLI:CHECK_CACHE" With("","SCALE-IMG",TABFICNAME,TABTIMESTAMP,TABBADFILE)
#Traitement du tableau retourné par la fonction du client X3
#comptage des fichiers bad
For I=0 To NBROW-1
  If TABBADFILE(I)=""
    Break
  Endif
  NBBAD+=1
Next
If NBBAD = 0
  #rien à faire pas de déphasage
  Close Local File [ILI]
  End
Endif
Kill TABTIMESTAMP
#Déclaration du tableau de blobs
Local Blbfile TABBLOB(9)(1)
Local Integer TABTIMESTAMP(1)
Local Char TABBADFILEUNIT(250)(1)
# Pour limiter la consommation de mémoire, on ne passe plus toutes les images
# dans le tableau, mais uniquement une image dans le tableau
For I=0 To NBBAD-1
  Read [ILI]ILO0=TABBADFILE(I)
  If fstat <>0
    ERR=1
    Break
  Endif
  TABBLOB(0)=[ILI]IMG
  TABTIMESTAMP(0)=val([ILI]TIMESTAMP)
  TABBADFILEUNIT(0)=[ILI]NOMFIC
  If ERR=0
#Appel de la fonction du client X3 qui va mettre à jour le cache en fonction du tableau de blobs
# et du tableau de nom de fichiers déphasés
# ICI appel de la fonction Funciu
      RETOUR = Funciu "SESS_CLI:UPDTLOB_CACHE" With("","SCALE-IMG",TABBADFILEUNIT,TABTIMESTAMP,TABBLOB)
  Endif
Next

Close Local File [ILI]
End

Onerrgo
ERR=1
Close Local File [ILI]
End

#CATUA X3-67237.sn
#Prompt for login and validate
##############################################################################
$LOAD_LOGIN
  Local Char X3USERID(GLONAUS)
  Local Integer OKLOGIN

  Raz X3USERID, OKLOGIN

  #While X3USERID = "" #Remove while loop to give user the ability to exit and close login prompt
  If func AFNC.CHECKSYRALOGIN(X3USERID)=[V]CST_AOK
    # Check permission for weighing
    # probably something like Call AUTORIS From EXEFNC
    # may also need to reset GVPROFIL and/or set/reset GFONCTION to FUNWEIGH
    OKLOGIN = 1
    GWEIUSER = X3USERID
  Else
    OKLOGIN = -1
    GWEIUSER = "FAIL"
  Endif

  Call XTRACT_PARAM(OKLOGIN) From SCALEXCHAN
Return
#CATUA X3-67237.en

