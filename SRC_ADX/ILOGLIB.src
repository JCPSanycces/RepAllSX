###########################################################################
$SOLDE_EMBALLAGE                                                   #   36
#  En emballage interne sur dernière pesée si restant dans l'emballage est < qté initiale * % solde emballage
#  Création d'un mouvement de sortie de type suivi et désignation
#  "Fin de contenant" sur un OF bidon mensuel
###########################################################################
LNUM         = WPAR(0)       # numero de l OF          MFGNUM
NUMCOMPOSANT = WPAR(1)       # numero du composant     ITMREF
LLOT         = WPAR(2)       # lot                     LOT
LSLO         = WPAR(3)       # sous-lot                SLO
LSEQSTA      = val(WPAR(4))  # sequence alloc          SEQ
QTE          = val(WPAR(5))  # quantité du mouvement
LOPT         = val(WPAR(6))  # option de pesée
LLIN         = val(WPAR(7))  # numero de ligne         MFGLIN
LSEQNOM      = val(WPAR(8))  # sequence nomenclature   BOMSEQ

# mm 109330 09.2015
# make optional sub-lot (rounding a prerequisite for Sothys customer)
# article managed with sub-lot?
Read [ITM]ITM0=NUMCOMPOSANT
If !fstat
  If  [F:ITM]LOTMGTCOD <> 4 &  LSLO="ZZZZZ"
    LSLO =""
  Endif
Endif

Call MAJ_FINCONTENANT (LNUM,NUMCOMPOSANT,LLOT,LSLO,LSEQSTA,QTE,LOPT,LLIN,LSEQNOM)  From SCALEXCHAN

Return

###########################################################################
$MAJ_EMBALLAGE                                                   #   39
#  Si la quantité physique est <> de la quantité informatique
#  Création d'un mouvement d'inventaire
###########################################################################
LNUM         = WPAR(0)       # numero de l OF          MFGNUM
NUMCOMPOSANT = WPAR(1)       # numero du composant     ITMREF
LLOT         = WPAR(2)       # lot                     LOT
LSLO         = WPAR(3)       # Sous-lot                SLO
QTE          = val(WPAR(4))  # delta pour nouvelle qté du stock   QTYSTU
LOPT         = val(WPAR(5))  # option de pesée
LLIN         = val(WPAR(6))  # numero de ligne         MFGLIN
LSEQNOM      = val(WPAR(7))  # sequence nomenclature   BOMSEQ
LSENS        = val(WPAR(8))  # sens de la mise à jour : 1= en +, 2 = en -  etc...

# mm 109330 09.2015
# make optional sub-lot (rounding a prerequisite for Sothys customer)
# article managed with sub-lot?
Read [ITM]ITM0=NUMCOMPOSANT
If !fstat
  If  [F:ITM]LOTMGTCOD <> 4 &  LSLO="ZZZZZ"
    LSLO =""
  Endif
Endif

# APCPRD-2753 mm 02.2013
#QTE = QTE / 1000
Call MAJ_CONTENANT (LNUM,NUMCOMPOSANT,LLOT,LSLO,QTE,LOPT,LLIN,LSEQNOM,LSENS)  From SCALEXCHAN

Return



###########################################################################
$CHGMN_OF_SANSPESE                                                  #   37
#             desallocation du composant
#             rewrite du mfhhead  avec WGGflg = 3 (plan pesee)
###########################################################################
LNUM_OLD     = WPAR(0)       # numero de l OF ancien   MFGNUM
NUMCOMPOSANT = WPAR(1)       # numero du composant     ITMREF
LLIN         = val(WPAR(2))  # numero de ligne         MFGLIN
LSEQ         = val(WPAR(3))  # sequence nomenclature   BOMSEQ
LNUM         = WPAR(4)       # numero de l OF          MFGNUM
PESEE_ART    = val(WPAR(5))  # si PESEE_ART = 2 -> pesée par article  - mm 10.10

Local    Integer WRET : WRET=0                    # 44043 mm 04.08
Local    Decimal QTYBESOIN  : QTYBESOIN=0         # 44043 mm 04.08
Local    Integer W_WGGBOX   : W_WGGBOX =1               # mm 12.10

Local Shortint  EXPITM    #X3-85848.n - added for call to XTRACT_NUMOF

# 44043 mm 04.08
If find(LALLSTA,1,2,3)
    Call DES_ALLOCATION_A (LNUM_OLD, NUMCOMPOSANT, LLIN, LSEQ)   From SCALEXCHAN
    If find (LALLSTA,2,3)
        Call ALLOC_MAT ("C",1,LNUM_OLD,1,1,WRET,NUMCOMPOSANT,LLIN,LSEQ,QTYBESOIN) From MFGALL
    Endif
Endif
Raz LALLSTA

Call DEBTRANS From GLOCK
Trbegin [MFG],[MFM]

# 44409 mm 06.08 -  on ne repasse en statut non pesé que si aucun suivi n'existe pour la matière
# 85521 mm 10.12 - Gérer WGGBOX pour la pesée par OF
Filter [MKM] Where MFGNUM=LNUM_OLD &
&     MFGLIN = LLIN                &
&     BOMSEQ = LSEQ                &
&     ITMREF = NUMCOMPOSANT
    Read [MKM] First
    If fstat
       Call MAJ_FICHIERS ("MFM",1,1,LNUM_OLD,NUMCOMPOSANT,LLIN,LSEQ) From SCALEXCHAN
    Else
       Call MAJ_FICHIERS ("MFM",0,1,LNUM_OLD,NUMCOMPOSANT,LLIN,LSEQ) From SCALEXCHAN
    Endif
Filter [MKM]

If PESEE_ART = 2
    # mm 12.10 - vérification qu'il ne reste plus de matière en cours de pesée
    # avant de remettre l'OF dans le plan de pesée
    For [MFM] Where MFGNUM= LNUM_OLD
       If [F:MFM]WGGBOX = 2   : W_WGGBOX = 2: Break : Endif
    Next
    # si aucune matière en cours de pesée, on remet l'OF dans le plan de pesée
    If  W_WGGBOX =1
      Call MAJ_FICHIERS ("MFG",3,0,LNUM_OLD,"",0,0) From SCALEXCHAN
    Endif
Else
   Call MAJ_FICHIERS ("MFG",3,0,LNUM_OLD,"",0,0) From SCALEXCHAN
Endif
# mm 01.11
#Commit
If GOK < 1 : Rollback : Return
Else : Commit
Endif

#X3-85848.o - replaced with new call      If LNUM <> ""  Call XTRACT_NUMOF (LNUM, "null")   From SCALEXCHAN
If LNUM <> ""  Call XTRACT_NUMOF (LNUM, "null", EXPITM)   From SCALEXCHAN      #X3-85848.n - New call
               Call TRF_PHA  From SCALEXCHAN
               Call TRF_MAT  From SCALEXCHAN
               Call TRF_HSH  From SCALEXCHAN
Endif
Return


