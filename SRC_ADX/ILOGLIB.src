###########################################################################
$REFRESH                                                                  #   46
#             rewrite du mfhhead  avec WGGflg = 3 (plan pesee)
###########################################################################
Local Char   NUMOF (15)
LNUM         = WPAR(0)       # numero de l OF          MFGNUM

If LNUM <> ""
    Call DEBTRANS From GLOCK
    Trbegin [MFG]
    Call MAJ_FICHIERS ("MFG",3,0,LNUM,"",0,0) From SCALEXCHAN
    Commit
Endif
Raz  NUMOF
# EXTRACTION initiale des données
Gosub XTRACT_DATA From SCALELIB

# transfert des données sur le client (on ne récupère que les données liées à l'OF)
Call TRF_MWG  From SCALEXCHAN
Call TRF_PHA  From SCALEXCHAN
Call TRF_MAT  From SCALEXCHAN
Call TRF_HSH  From SCALEXCHAN

Return

##########################################################################
$RELOAD_ALL                                                     #   47
