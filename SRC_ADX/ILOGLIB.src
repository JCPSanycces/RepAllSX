########################################################################
# tunnels
$ZOOM
Case WPAR(0)
    When "MWS":     If (len(WPAR(1)) > GLONWST)
                        WPAR(1) = left$(WPAR(1),GLONWST)
                        WPAR(1) = vireblc(WPAR(1),1)
                    Endif
                    WPAR(2) = GOPTFCY
                    #------------------------------------------------------------------------------------------------------------------
                    # point d'entrée ZOOMGANTT (28603)
                    GPE = 0
                    GPOINT = "ZOOMGANTT" : Gosub ENTREE From EXEFNC
                    If GPE : Return : Endif
                    #------------------------------------------------------------------------------------------------------------------
                    Call OBJET(WPAR(0), WPAR(2), WPAR(1)) From GOBJET
    When "TDUVAR":  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
                    PARBOUT(1) = ""
                    GACTION = "TRTTDUVAR"
                    Call TRAITE_CHAR(VALBOUT,PARBOUT,"FTDUVAR","FUNTDUVAR","DTDUVAR",3,"XYFUNTDUVAR") From GTRAITE
    When Default:   If WPAR(0) = "ITM"
                       # GH 03/01/2013 bug 95418
                       #WPAR(1) = vireblc(left$(WPAR(1), len(WPAR(1)) - 3),1)
                       I=instr(1,WPAR(1)," ")
                       If I : WPAR(1) = left$(WPAR(1),I-1) : Endif
                    Endif
                    #------------------------------------------------------------------------------------------------------------------
                    # point d'entrée ZOOMGANTT (28603)
                    GPE = 0
                    GPOINT = "ZOOMGANTT" : Gosub ENTREE From EXEFNC
                    If GPE : Return : Endif
                    #------------------------------------------------------------------------------------------------------------------
                    Call OBJET(WPAR(0), WPAR(1), WPAR(2)) From GOBJET
Endcase

Return

##############################################################################
##############################################################################
# Décodage du message contenu dans RETOUR
$PROCESS_ERR
Call ERREUR(mess(206,193,1)) From GESECRAN            # llc 09.02
Return



##############################################################################
# Décodage du message contenu dans RETOUR
$DECODE
# les trois premiers caractères correspondent au code retour
CODE = left$(RETOUR,3)
If CODE = "021" : SAVMESS = RETOUR : SAVMESS(1) = RETOUR(1) : Endif
# test sortie de la fonction
If CODE = "999" | CODE = "" : Return : Endif

# on a récupéré, le code, on peut ignorer la partie gauche
WPARAM   = right$(RETOUR,6)
# analyse de la description des paramètres
Raz C1, C2, WPAR, WTYP, WLON
NBPAR     = 0
POSITION  = 1
While (C1 <> IFORMAT)
      # plus de 11 paramètres, on sort
      If NBPAR >= 11 : Break : Endif            # 09.05 31916

      # analyse description paramètre (type, longueur)
      C1 = mid$(WPARAM, POSITION, 1)

      If C1 = "" : Break : Endif

      If C1 <> IFORMAT
          Case C1
              When "X","x":   WTYP(NBPAR) = 1    # alphanumérique
              When "N","n":   WTYP(NBPAR) = 2    # numérique
          Endcase
          # mémorisation de la longueur
          POSITION += 1
          C2 = mid$(WPARAM, POSITION, 1)
          WLON(NBPAR) = ascii(C2)

          POSITION += 1
          NBPAR    += 1
      Endif
Wend

# analyse des paramètres
WPARAM = right$(WPARAM, POSITION+1)
# 09.05 31916
For I = 0 To NBPAR-1
    WPAR(I) = left$(WPARAM, WLON(I))
    # si le paramètre faisait 10 caractères, on a ajouté "///" : Il faut les enlever
    If WLON(I) = 13 & mid$(WPAR(I),WLON(I)-2,3) = "///"
        WPAR(I) = left$(WPAR(I),WLON(I)-3)
    Endif
    WPARAM  = right$(WPARAM, WLON(I)+1)
Next I
Return



##############################################################################
# Décodage du message contenu dans RETOUR
$DECODE1

# les trois premiers caractères correspondent au code retour
CODE = left$(RETOUR,3)

# test sortie de la fonction
If CODE = "999" | CODE = "" : Return : Endif

If GUSER="MM"
 Call ECR_TRACE("code="+num$(CODE),1) From GESECRAN
Endif

#On a récupéré, le code, on peut ignorer la partie gauche
WPARAM   = right$(RETOUR,6)
# analyse de la description des paramètres
Raz C1, C2, WPAR, WTYP, WLON
NBPAR     = 0
POSITION  = 1
While (C1 <> IFORMAT)
      # plus de 11 paramètres, on sort
      If NBPAR >= 11 : Break : Endif                # 09.05 31916

      # analyse description paramètre (type, longueur)
      C1 = mid$(WPARAM, POSITION, 1)

      If C1 = "" : Break : Endif

      If C1 <> IFORMAT
          Case C1
              When "X","x":   WTYP(NBPAR) = 1    # alphanumérique
              When "N","n":   WTYP(NBPAR) = 2    # numérique
          Endcase
          # mémorisation de la longueur
          POSITION += 1
          C2 = mid$(WPARAM, POSITION, 1)
          WLON(NBPAR) = ascii(C2)

          POSITION += 1
          NBPAR    += 1
      Endif
Wend

# analyse des paramètres
WPARAM = right$(WPARAM, POSITION+1)

For I = 0 To NBPAR-1
    WPAR(I) = left$(WPARAM, WLON(I))
    # si le paramètre faisait 10 caractères, on a ajouté "///" : Il faut les enlever
    If WLON(I) = 13 & mid$(WPAR(I),WLON(I)-2,3) = "///"
        WPAR(I) = left$(WPAR(I),WLON(I)-3)
    Endif
    WPARAM  = right$(WPARAM, WLON(I)+1)

Next I
Return

##############################################################################
# Contrôles utilisateur si opération déplacée
$OPERATION_MOVED
Case CODE
    When "050" :     # controle changement de poste opération
                     Local Char     WMFGNUM(GLONVCR)
                     Local Integer  WOPENUM, WOPESPLNUM
                     Local Char     WWST (GLONWST)
                     Local Char     WSBB
                     Local Date     WDATE
                     WMFGNUM     = WPAR(0)
                     WOPENUM     = val(WPAR(1))
                     WOPESPLNUM  = val(WPAR(2))
                     WWST        = WPAR(3)
                     If WPAR(4) <> " " : WSBB        = WPAR(4) : Endif
                     If WPAR(5) <> ""  : WDATE       = WPAR(5) : Endif
                     Gosub OPERATION_MOVED_PE From OPTLIBB
    When Default:    Return
Endcase
Return

##############################################################################
# Infos disponibilité matières
$OPERATION_INVENTORY
Case CODE
    When "051" :
                     Local Char     WMFGNUM(GLONVCR)
                     Local Integer  WOPENUM, WOPESPLNUM
                     Local Char     WWST (GLONWST)
                     Local Char     WSBB
                     Local Date     WDATE
                     WMFGNUM     = WPAR(0)
                     WOPENUM     = val(WPAR(1))
                     WOPESPLNUM  = val(WPAR(2))
                     WWST        = WPAR(3)
                     If WPAR(4) <> " " : WSBB        = WPAR(4) : Endif
                     If WPAR(5) <> ""  : WDATE       = WPAR(5) : Endif
                     Gosub OPERATION_INVENTORY_PE From OPTLIBB
    When Default:    Return
Endcase
Return
# gbe 22/02/12 Ajout du stock projeté
##############################################################################
# Infos disponibilité matières
$STOCK_PROJETE
Case CODE
    When "052" :
       ## Action CONSSPR
       Local Decimal BASPAG_1
       Local Char    PARMSK_1(250)(1..20) , SAVACT_1(20)
       SAVACT_1 = GACTION : GACTION = "CONSSPR"
       PARMSK_1(1) = "0"
       PARMSK_1(2) = GOPTFCY
       PARMSK_1(3) = WPAR(0)
       PARMSK_1(4) = ""
       Call CONSULT_NUM(BASPAG_1,"SPR",PARMSK_1) From GCONSULT
       GACTION = SAVACT_1
    When Default:    Return
Endcase
Return


