#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################################                                                  I L O G L I B             #
# Communication avec les composants développés avec ILOG         GPAO        #
##############################################################################
#     X3SCHEDULE          Optimisation X3
#     X3SCALES            Poste de pesée graphique
##############################################################################
#     Principe de codage du paramètre RETOUR:
#     Format : AAA=1T1L1...TnLnFxxxxxxxxxxxxxxxxxxxxxxxxxxx...
#
#        ou:   "AAA"     = code retour de 001 à 999
#              "=1"      = est une constante
#              "T1"      = type premier paramètre (X = alpha, n = numérique)
#              "L1"      = longueur premier paramètre
#              "Tn"      = type paramètre n
#              "Ln"      = longueur paramètre n
#              "F"       = caractère constant de fin de description
#                          des paramètres attendus
#              "xxx..."  = chaine de caractère contenant les valeurs paramètres
#
#    Exemple:
#        Gantt: Pour le tunnel vers l'ordre de fabrication FCY01010001,
#               2 paramètres: le code objet MFG et le numéro d'OF.
#
#        RETOUR = 011=1X3X11FMFGFCY01010001
#               Attention, les valeurs numériques n'apparaissent pas en clair
#               en fait on reçoit:
#            RETOUR = 011=|X|X|FMFGFCY01010001
#
#    Pour le décodage, on prévoit un tableau de 11 paramètres, longueur 20
###############################################################################

##############################################################################
# Appel du Gantt
# Codes retour gérés:
#         011 = tunnel
#         014 = notification de sauvegarde ds résultats
#         015 = demande de lancement de l'aide en ligne
#         020 = réactualisation des données techniques
#         050 = appel PE sur déplacement opération
#         051 = appel PE pour récupération stock opération
#         999 = sortie
##############################################################################
Subprog X3SCHEDULE(IRESULT)
Variable Integer IRESULT

Local Char     GANTTNBR(255)
Local Char     RETOUR(255)
Local Char     WPARAM(255)
Local Char     WPAR(20)(11)
Local Integer  WLON(11)
Local Integer  WTYP(11)
Local Char     CODE, C1, C2
Local Char     IFORMAT : IFORMAT = "F"
Local Integer  NBPAR, POSITION, I

IRESULT = 0

# 07.05 31503
If [M:MOP1]OPTION <> 3 : Call RESET_FEEDBACK From OPTLIBB : Endif

#------------------------------------------------------------------------------------------------------------------
If [M:MOP1]OPTION <> 3 : Call RESET_INVENTORY From OPTLIBB : Endif

Global Char GSCHCUSTOM(200)
GSCHCUSTOM = func OPTLIB.FILNAM(GOPTFCY,"ilfeat",0)

Call RESET_CUSTOM From OPTLIBB

# point d'entrée CUSTOM_GANTT
GPOINT = "CUSTOM_GANTT" : Gosub ENTREE From EXEFNC

# transfert features
Call ILFIL2CSV(GOPTFCY,"ilfeat","v6_x3_features") From OPTLIB

#------------------------------------------------------------------------------------------------------------------

Callilog RETOUR="" With     "IAction=" + chr$(1) + "1",
&                           "IModule=" + chr$(1) + "Scheduling\v6\x3ilog.dll"

# retour de création
# on récupère l'identifiant du gantt pour appel ultérieur
CODE = left$(RETOUR,3)
Case CODE
  When "001" : GANTTNBR = mid$(RETOUR, 9, 1)
  When "990" : Gosub PROCESS_ERR : Goto FINGANTT
  When "999" : Goto FINGANTT : # GH 22/07/2015 bug 108630
Endcase

# on active le gantt : on n'a plus la main
Callilog RETOUR="" With     "INumber=" + chr$(1) + GANTTNBR,
&                           "IAction=" + chr$(1) + "2"
CODE = left$(RETOUR,3) : # GH 22/07/2015 bug 108630
If (CODE = "990") : Gosub PROCESS_ERR : Goto FINGANTT : Endif

# boucle de dialogue avec le gantt
While (!find(val(CODE),990,999))
    # appel traitement de décodage du paramètre RETOUR
    Gosub DECODE
    Case CODE
        When "011":     # effet tunnel, 3 paramètres possibles (code OBJ, cle1, cle2)
                        Gosub ZOOM
        When "014":     # notification de sauvegarde de résultats
                        IRESULT = 1
                        If GBROWS=1 & GFUSION=1 : # GH 24/11/2014 dm 103835
                           Call CSV2ILFIL(GOPTFCY,"ilres","v6_results") From OPTLIB
                        Endif
        When "015":     # appel de l'aide sur la fonction optimisation
                        Hlpbox WPAR(0)+chr$(7)+"FCT" #
        When "020":     Gosub UPDATE_TD
        When "050":     Gosub OPERATION_MOVED
        When "051":     Gosub OPERATION_INVENTORY
        When "052":     Gosub STOCK_PROJETE # gbe 22/02/12
        When "053":     Gosub COMPONENT_AVAILABILITY # gbe 10/05/12
        When "999","":  Goto ENDGANTT
    Endcase

    Callilog RETOUR="" With     "INumber=" + chr$(1) + GANTTNBR,
&                               "IAction=" + chr$(1) + "2"

$ENDGANTT
Wend

$FINGANTT
End

###############################################################################
# Appel du poste de pesée graphique
###############################################################################
Subprog X3SCALES
Local Char     SCALENBR(255)
Local Char     RETOUR(255)(0..5)
Local Char     WPARAM(255)
Local Char     WPAR(20)(11)
Local Integer  WLON(11)
Local Integer  WTYP(11)
Local Char     CODE, C1, C2
Local Char     IFORMAT : IFORMAT = "F"
Local Integer  NBPAR, POSITION, I

Local Char    LNUM         (GLONVCR)  # dimensionnement - mm .03.11
Local Char    LNUM_OLD     (GLONVCR)  # dimensionnement - mm .03.11
Local Char    NUMISM       (8)
Local Char    NUMCOMPOSANT (GLONITM)  # dimensionnement - mm .03.11
Local Integer LLIN
Local Integer LSEQ
Local Integer LOPE
Local Integer VAL1
Local Integer PESEE_ART
Local Char    F_CONTENU    (7)
Local Char    F_FORMAT     (7)
Local Char    NOMETA       (15)
Local Integer TYPETA
Local Decimal QTYBESOIN, WEIBESOIN
Local Integer LALLSTA        # 44043 mm 04.08
Local Integer ERR

#CATUA X3-67237.sn
Global Char GWEIUSER(GLONAUS)
Raz GWEIUSER
#CATUA X3-67237.en

# bug 75982 02/09/11 pour la récupération des informations du dossier
#Local Char    A1VERS , A1REL , A1PAT
#Local Char WCHEMIN(250)
#Local Integer FILEEXIST

ERR=0
#FILEEXIST = 0
Call CTRLCACHE(ERR)
If ERR=1
# Erreur lors de la mise à jour du cache des images
Endif

# llc test
Local Char    SAVMESS(255)(0..5)
Local Char    WBESOIN

# Numéro de version, release et patch du dossier
#Call VERSX3(nomap,A1VERS,A1REL,A1PAT) From INTRUTILA
# création du poste de pesée en fonction de la version et du niveau de patch

# client Classic : # dm 103835 GH 02/12/2014
# ou client lourd à partir de la version AKIRA - mm 12.2014
#If (GBROWS=1 & GFUSION=1) | ( val(A1VERS) >= 170)

# 109010 mm 06.2015
  Callilog RETOUR="" With     "IAction=" + chr$(1) + "6",
&                             "IModule=" + chr$(1) + "Scales\v6\x3scales.dll"
#Endif

# retour de création
# on récupère l'identifiant de la fenêtre pour appel ultérieur
CODE = left$(RETOUR,3)

If (CODE = "006") : SCALENBR = mid$(RETOUR, 9, 1) : Endif       # CMI
# sr 03.05 pas la peine pour le code 990, la centrale a normalement envoye un message clair du probleme rencontre
#If (CODE = "990") : End : Endif # SR
#If (CODE = "990") : Goto ENDSCALE : Endif # GH pour ne plus générer de trace vide
If find(CODE,"990","999") : Goto FINSCALE : Endif : # GH 22/07/2015 bug 108630

# on active le poste : on n'a plus la main
Callilog RETOUR="" With     "INumber=" + chr$(1) + SCALENBR,
&                           "IAction=" + chr$(1) + "7"
CODE = left$(RETOUR,3) : # GH 22/07/2015 bug 108630

# sr 03.05 pas la peine pour le code 990, la centrale a normalement envoye un message clair du probleme rencontre
#If (CODE = "990") : Gosub PROCESS_ERR             : End : Endif # CMI + LLC
#If (CODE = "990") : End : Endif # SR

# boucle de dialogue avec le poste
While (!find(val(CODE),990,999))

    # appel traitement de décodage du paramètre RETOUR
    Gosub DECODE1
    # traitement particulier de sortie de la fonction (LLC)
    Case CODE
        When "","990","999": Gosub ENDSCALE # SR
    Endcase

    Gosub OUV_FICHMASK

    Case CODE

        When "019":       Gosub PESEE_PAR_MATIERE
        When "020":       Gosub CHANGEMENT_OF
        When "021":       Gosub CHOIX_COMPOSANT
        When "022":       Gosub CHGMN_COMPOSANT_SANSPESE
        When "023":       Gosub CHGMN_COMPOSANT_AVECPESE
        When "024":       Gosub CHGMN_OF_AVECPESE
        When "025":       Gosub CHGMN_PHASE_AVECPESE
        When "026":       Gosub MAJ_ALLOCATION
        When "027":       Gosub PESE_PARTIELLE
        When "028":       Gosub FIN_LOT
        When "029":       Gosub FIN_COMPOSANT

        When "030":       Gosub PESE_PARTIELLE_FINPHASE
        When "031":       Gosub PESE_PARTIELLE_FINOF
        When "032":       Gosub MWM_HELP
        When "033":       Gosub RECONCILIATION
        When "034":       Gosub MAJ_ALLOCATION
        When "035":       Gosub SAI_PROCEDURES
        When "036":       Gosub SOLDE_EMBALLAGE
        When "037":       Gosub CHGMN_OF_SANSPESE
        When "038":       Gosub MAJ_ALLOCATION
        When "039":       Gosub MAJ_EMBALLAGE

        When "040":       Gosub RES_CALIBRAGE_OK
        When "041":       Gosub RES_CALIBRAGE_KO
        When "042":       Gosub RES_CALIBRAGE_KO_SUROK
        When "043":       Gosub SOLDE_MATIERE
        When "044":       Gosub FINPHASE_BIS
        When "045":       Gosub FINOF_BIS

        When "046":       Gosub REFRESH
        When "047":       Gosub RELOAD_ALL
        When "048":       Gosub STOCK_DETAILLE

        When "049":       Gosub CHANGEMENT_MAT_ART
        When "050":       Gosub CHANGEMENT_OF_ART
        When "051":       Gosub FIN_COMPOSANT_ART
        When "052":       Gosub ABANDON_PESEEMULTI

        When "100":       Gosub LOAD_LOGIN #CATUA X3-67237.n

    Endcase
    # Transfert fichier trace   (si pas d erreur il est vide)
    # sr 02.02 mise en commentaire car pose de gros problème et de plus ce fichier trace
    # n'est pas exploité côté DLL
#        Call TRF_TRA  From SCALEXCHAN
     Callilog RETOUR="" With     "INumber=" + chr$(1) + SCALENBR,
&                                "IAction=" + chr$(1) + "7"        # CMI

$ENDSCALE
Wend

$FINSCALE
# on supprime le fichier trace
# sr 06.05 : NON on ferme la trace
Call FERME_TRACE From LECFIC

GSERVEUR = 0

End

###########################################################################
$PESEE_PAR_MATIERE                                                  #   19
###########################################################################
LNUM         = WPAR(0)       # numero de l OF          MFGNUM
NUMCOMPOSANT = WPAR(1)       # numero du composant     ITMREF
LLIN         = val(WPAR(2))  # numero de ligne         MFGLIN
LSEQ         = val(WPAR(3))  # sequence nomenclature   BOMSEQ

Trbegin [MFG],[MFM]
  # Si [F:MFG]WGGFLG valait 8 -> passe à 4
  Call MAJ_FICHIERS ("MFG", 4, 0, LNUM, "", 0, 0) From SCALEXCHAN
  # [F:MFM]WGGBOX valait 1 -> passe à 2,
  # Pour ces valeurs de flags, la matière de cet OF pour cette phase n'est plus sélectionnable.
  Call MAJ_FICHIERS ("MFM", 0, 2, LNUM,NUMCOMPOSANT,LLIN,LSEQ) From SCALEXCHAN
  If GOK < 1  Gosub AB_TRT
  Else Commit
Endif

Return

###########################################################################
$CHANGEMENT_OF                                                      #   20
###########################################################################
Local Shortint EXPITM       #X3-85848.n - Added for call to XTRACT_NUMOF
LNUM_OLD = WPAR(0)         # numero de l OF ancien
LNUM     = WPAR(1)         # numero de l OF nouveau
LMAT     = WPAR(2)         # numero de matiere nouveau

# sr 05.02 FI n° 17
If LNUM_OLD <> ""
   If ( CODE = "020" & LNUM_OLD <> LNUM )
      Call MAJ_FICHIERS ("MFG",3,0,LNUM_OLD,"",0,0) From SCALEXCHAN         # 47764 mm 07.08 - val2=0
   Endif
Endif

#X3-85848 - Replaced with new call format     Call XTRACT_NUMOF (LNUM, LMAT)   From SCALEXCHAN
Call XTRACT_NUMOF (LNUM, LMAT, EXPITM)   From SCALEXCHAN    #X3-85848.n - New Call format
Call TRF_PHA  From SCALEXCHAN
Call TRF_MAT  From SCALEXCHAN
Call TRF_HSH  From SCALEXCHAN
Return

##########################################################################
$CHOIX_COMPOSANT                                                    #   21
#             allocation de toutes les matiere
#             generation du STO
#             transfert du STO
#             generation du CTN  par rapport a la fiche ISM du COMPOSANT
#             transfert du CTN
#             rewrite du mfhhead avec WGGFLG = 4 (en cours de pesee)
#                                     WGGSTA = 2 (pesee en box)
#             rewrite du mfhmat  avec WGGSTA = 2 (en cours de pesee)
###########################################################################
LNUM         = WPAR(0)       # numero de l OF          MFGNUM
NUMCOMPOSANT = WPAR(1)       # numero du composant     ITMREF
WEIBESOIN    = val(WPAR(2))  # quantite du composant   qtyret
LLIN         = val(WPAR(3))  # numero de ligne         MFGLIN
LSEQ         = val(WPAR(4))  # sequence nomenclature   BOMSEQ
NUMISM       = (WPAR(5))     # numero fiche ism
PESEE_ART    = val(WPAR(6))  # si PESEE_ART = 2 -> pesée par article - mm 10.10
# qtybesoin renseigné dans le cas d un excipient

# llc 03.02
Read [MFM]MFM0=LNUM;LLIN;LSEQ;NUMCOMPOSANT
If fstat : Raz [MFM] : Endif
# 44043 mm 04.08 - Sauvegarde du statut d'allocation initial de la matiere
If LALLSTA=0  : LALLSTA = [F:MFM]ALLSTA : Endif

If find([F:MFM]PKC,4,5,6,7,10)
    Call CAL_QUANTITE(NUMCOMPOSANT,QTYBESOIN,WEIBESOIN) From SCALEXCHAN
Else
    QTYBESOIN = 0
Endif

WBESOIN = num$(QTYBESOIN)

Call XTRACT_ALLOCATION (LNUM , NUMCOMPOSANT,QTYBESOIN, LLIN, LSEQ,2, [F:MFM]RETDAT)   From SCALEXCHAN

# sr 02.04 tests 140
Call TRF_STO  From SCALEXCHAN
Call XTRACT_CONTAINERS (NUMISM)   From SCALEXCHAN
Call TRF_CTN  From SCALEXCHAN
Call DEBTRANS From GLOCK
Trbegin [MFG]
# sr 05.02 plus la peine car c'est fait bien avant FI n° 17
#Call MAJ_FICHIERS ("MFG",4,2,LNUM,"",0,0) From SCALEXCHAN

# 85521 mm 10.12 - Gérer WGGBOX pour la pesée par OF
If PESEE_ART = 2
  Call MAJ_FICHIERS ("MFM",2,0,LNUM,NUMCOMPOSANT,LLIN,LSEQ) From SCALEXCHAN
Else
  Call MAJ_FICHIERS ("MFM",2,2,LNUM,NUMCOMPOSANT,LLIN,LSEQ) From SCALEXCHAN
Endif
If GOK < 1  Gosub AB_TRT
    Else Commit
Endif

Return

###########################################################################
$CHGMN_COMPOSANT_SANSPESE                                           #   22
#             desallocation du composant
#             rewrite du MFGMAT  avec WGGSTA = 1 (non pesee)
###########################################################################
LNUM         = WPAR(0)       # numero de l OF          MFGNUM
NUMCOMPOSANT = WPAR(1)       # numero du composant     ITMREF
LLIN         = val(WPAR(2))  # numero de ligne         MFGLIN
LSEQ         = val(WPAR(3))  # sequence nomenclature   BOMSEQ

Local    Integer WRET : WRET=0                    # 44043 mm 04.08
Local    Decimal QTYBESOIN  : QTYBESOIN=0         # 44043 mm 04.08

# 44043 mm 04.08
If find(LALLSTA,1,2,3)
    Call DES_ALLOCATION_A (LNUM , NUMCOMPOSANT, LLIN, LSEQ)   From SCALEXCHAN
    If find (LALLSTA,2,3)
        Call ALLOC_MAT ("C",1,LNUM,1,1,WRET,NUMCOMPOSANT,LLIN,LSEQ,QTYBESOIN) From MFGALL
    Endif
Endif
Raz LALLSTA

Call DEBTRANS From GLOCK
Trbegin [MFM]

# 44409 mm 06.08
# si aucun suivi n'existe pour la matière, on repasse en statut non pesé
# 85521 mm 10.12 - Gestion WGGBOX pour la pesée par OF : WGGBOX repasse à non
Filter [MKM] Where MFGNUM=LNUM     &
&     MFGLIN = LLIN                &
&     BOMSEQ = LSEQ                &
&     ITMREF = NUMCOMPOSANT
    Read [MKM] First
    If !fstat
      Call MAJ_FICHIERS ("MFM",0,1,LNUM,NUMCOMPOSANT,LLIN,LSEQ) From SCALEXCHAN
    Else
      Call MAJ_FICHIERS ("MFM",1,1,LNUM,NUMCOMPOSANT,LLIN,LSEQ) From SCALEXCHAN
    Endif
Filter [MKM]
#
If GOK < 1 : Rollback : Return
Else : Commit
Endif

Return

###########################################################################
$CHGMN_COMPOSANT_AVECPESE                                           #   23
#             desallocation reste à peser du composant
###########################################################################

# faire un modif dans alloc_mat de mfgall avec peut etre un type autre que a
# ou c pour caluler le reste à peser


LNUM         = WPAR(0)       # numero de l OF          MFGNUM
NUMCOMPOSANT = WPAR(1)       # numero du composant     ITMREF
LLIN         = val(WPAR(2))  # numero de ligne         MFGLIN
LSEQ         = val(WPAR(3))  # sequence nomenclature   BOMSEQ

# mm 02.11 - allocation et magasin avancé
Read [MFM]MFM0 = LNUM;LLIN;LSEQ;NUMCOMPOSANT
If fstat
 Raz [MFM]
Else
# 86183 mm 10.12 (suite du 85521)
# changement d'article  : l'article courant n'est plus en cours de pesée box
Call DEBTRANS From GLOCK
Trbegin [MFM]
Call MAJ_FICHIERS ("MFM",0,1,LNUM,NUMCOMPOSANT,LLIN,LSEQ) From SCALEXCHAN
If GOK < 1 : Rollback : Return
Else : Commit
Endif
# on n'est pas en situation std, on ne veut pas perdre les allocations
# réalisées depuis l'OF
 If find([F:MFM]PKC,2,3) & GALLAUT = 1 : Return : Endif
Endif

# 02.07 Demande 39524
#Call DES_ALLOCATION_R (LNUM , NUMCOMPOSANT, LLIN, LSEQ)   From SCALEXCHAN
Call DES_ALLOCATION_A (LNUM , NUMCOMPOSANT, LLIN, LSEQ)   From SCALEXCHAN
Return

###########################################################################
$CHGMN_OF_AVECPESE                                                  #   24
#             rewrite du MFGHEAD avec WGGFLG = 3 (plan de pese)
#             rewrite de MFGMAT avec  WGGSTA = 1 (non pesée) si aucun suivi existant pour la matière
#             document fin of partielle
###########################################################################
LNUM         = WPAR(0)        # numero de l OF          MFGNUM
NUMCOMPOSANT = WPAR(1)        # numero du composant     ITMREF
LLIN         = val(WPAR(2))   # numero de ligne         MFGLIN
LSEQ         = val(WPAR(3))   # sequence nomenclature   BOMSEQ
PESEE_ART    = val(WPAR(4))   # si PESEE_ART = 2 -> pesée par article, sinon =0 - mm 10.10
Local Integer W_WGGBOX : W_WGGBOX =1               # mm 01.11

# cas particulier de la pesée par article : on ne change plus la valeur de [F:MFG]WGGFLG si OF totalement pesé
If PESEE_ART = 2
  Readlock [F:MFG]MFG0 = LNUM
  If fstat = 0
    If [F:MFG]WGGFLG = 5 & [F:MFG]WGGSTA = 8 : Return  : Endif
  Endif
Endif

Call DEBTRANS From GLOCK
Trbegin [MFG],[MFM]
Read [MFM]MFM0 = LNUM;LLIN;LSEQ;NUMCOMPOSANT
If fstat : Raz [MFM] : Endif
Call MAJ_FICHIERS ("MFG",3,0,LNUM,"",0,0) From SCALEXCHAN
If [MFM]WGGSTA =2
  # 44409 mm 06.08-  on ne repasse en statut non pesé que si aucun suivi n'existe pour la matière
  Filter [MKM] Where MFGNUM=LNUM                  &
&                    MFGLIN = LLIN                &
&                    BOMSEQ = LSEQ                &
&                    ITMREF = NUMCOMPOSANT
       Read [MKM] First
       If fstat
          Call MAJ_FICHIERS ("MFM",1,0,LNUM,NUMCOMPOSANT,LLIN,LSEQ) From SCALEXCHAN
       Endif
  Filter [MKM]
Endif

If PESEE_ART = 2
  # mm 01.11 - vérification qu'il ne reste plus de matière en cours de pesée
  # avant de remettre l'OF dans le plan de pesée
  For [MFM] Where MFGNUM= LNUM
     If [F:MFM]WGGBOX = 2   : W_WGGBOX = 2: Break : Endif
  Next
  # si aucune matière en cours de pesée, on remet l'OF dans le plan de pesée
  If  W_WGGBOX =1
    Call MAJ_FICHIERS ("MFG",3,0,LNUM,"",0,0) From SCALEXCHAN
  Endif
Else
  Call MAJ_FICHIERS ("MFG",3,0,LNUM,"",0,0) From SCALEXCHAN
Endif
#
If GOK < 1 : Rollback : Return
Else : Commit
Endif

# impression fin of partielle  init du buffer WGG pour les parametres
Raz [F:WGG]
[F:WGG]WEIFLG    = 2
[F:WGG]MFGNUM    = LNUM
NOMETA = GWEIRPTOF
TYPETA = 4

Gosub PESE_IMPRESSION

Return

###########################################################################
$CHGMN_PHASE_AVECPESE                                               #   25
#             Etiquette fin phase partielle
###########################################################################

# impression fin phase partielle  init du buffer WGG pour les parametres
Raz [F:WGG]
[F:WGG]WEIFLG    = 2
[F:WGG]MFGNUM    = WPAR(0)
[F:WGG]BOMOPE    = val(WPAR(1))
NOMETA = GWEIRPTOPE
TYPETA = 3

Gosub PESE_IMPRESSION

Return


###########################################################################
$MAJ_ALLOCATION                                                     #   26
#                           + document allocation                   #   34
#                  uniquement document allocation                   #   38
###########################################################################

 If CODE = "026" Call MAJ_ALLOCATIONS ("26") From SCALEXCHAN  : Endif
 If CODE = "034" Call MAJ_ALLOCATIONS ("34") From SCALEXCHAN  : Endif
 If CODE = "038" Call MAJ_ALLOCATIONS ("38") From SCALEXCHAN  : Endif
Return

###########################################################################
$PESE_PARTIELLE                                                     #   27
###########################################################################
PESEE_ART    = val(WPAR(0))  # si PESEE_ART = 2 -> pesée par article - mm 10.10

Call MAJ_WEIGHING_SUIVI ("27", PESEE_ART )  From SCALEXCHAN

Return

###########################################################################
$FIN_LOT                                                            #   28
###########################################################################
PESEE_ART    = val(WPAR(0))  # si PESEE_ART = 2 -> pesée par article - mm 10.10

Call MAJ_WEIGHING_SUIVI ("28", PESEE_ART)  From SCALEXCHAN

Return

###########################################################################
$FIN_COMPOSANT                                                      #   29
###########################################################################
LNUM         = WPAR(0)       # numero de l OF          MFGNUM
NUMCOMPOSANT = WPAR(1)       # numero du composant     ITMREF
LLIN         = val(WPAR(2))  # numero de ligne         MFGLIN
LSEQ         = val(WPAR(3))  # sequence nomenclature   BOMSEQ

Call MAJ_WEIGHING_SUIVI ("29", 0)  From SCALEXCHAN
Return


###########################################################################
$PESE_PARTIELLE_FINPHASE                                            #   30
###########################################################################
LNUM         = WPAR(0)       # numero de l OF          MFGNUM
NUMCOMPOSANT = WPAR(1)       # numero du composant     ITMREF
LLIN         = val(WPAR(2))  # numero de ligne         MFGLIN
LSEQ         = val(WPAR(3))  # sequence nomenclature   BOMSEQ

Call MAJ_WEIGHING_SUIVI ("30", 0)  From SCALEXCHAN

Return

###########################################################################
$PESE_PARTIELLE_FINOF                                               #   31
###########################################################################
LNUM         = WPAR(0)       # numero de l OF          MFGNUM
NUMCOMPOSANT = WPAR(1)       # numero du composant     ITMREF
LLIN         = val(WPAR(2))  # numero de ligne         MFGLIN
LSEQ         = val(WPAR(3))  # sequence nomenclature   BOMSEQ

Call MAJ_WEIGHING_SUIVI ("31", 0)  From SCALEXCHAN
#CALL QUANTITE A 0
Return

###########################################################################
