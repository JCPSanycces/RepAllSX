######################################################################################

########################################
Subprog AM_MFGMODC(VALEUR)
Variable Integer VALEUR
[M:MFL1]TYPMODM = 1
[M:MFL1]TYPMODO = 1
Affzo [M:MFL1]TYPMODM
Affzo [M:MFL1]TYPMODO
End

########################################
Subprog AS_MFGMODM(VALEUR)
Variable Integer VALEUR
If [M:MFL1]TYPMODO = 2 : mkstat = 2 : End : Endif
End

########################################
Subprog AS_TYPMODM(VALEUR)
Variable Integer VALEUR
If [M:MFL1]MFGMODM = 1 : mkstat = 2 : End : Endif
If [M:MFL1]MFGMODC = 2 : mkstat = 2 : End : Endif
If [M:MFL1]MFGMODO = 2 : mkstat = 2 : End : Endif
End

########################################
Subprog AS_MFGMODO(VALEUR)
Variable Integer VALEUR
If [M:MFL1]TYPMODM = 2 : mkstat = 2 : End : Endif
End

########################################
Subprog AS_TYPMODO(VALEUR)
Variable Integer VALEUR
If [M:MFL1]MFGMODO = 1 : mkstat = 2 : End : Endif
If [M:MFL1]MFGMODC = 2 : mkstat = 2 : End : Endif
If [M:MFL1]MFGMODM = 2 : mkstat = 2 : End : Endif
End


########################################
Subprog AM_MFGSTA(VALEUR)
Variable Integer VALEUR
Case VALEUR
    When 1:    [M:MFL1]MODALL = 1
    When 2:    # rien
Endcase

If [M:MFL1]TRSAUTO = 1 & VALEUR = 1
    Grizo [M:MFL1]MODALL
Else
    Actzo [M:MFL1]MODALL
Endif
Affzo [M:MFL1]MODALL
End

########################################
Subprog AS_MODALL(VALEUR)
Variable Integer VALEUR
If [M:MFL1]MFGSTA  = 1 & [M:MFL1]TRSAUTO = 1 : mkstat = 2 : Endif
If [M:MFL1]MFGMODC = 1 & [M:MFL1]MFGMODM = 1 : mkstat = 2 : Endif
End

########################################
Subprog AS_MODJAL(VALEUR)
Variable Integer VALEUR
If [M:MFL1]TYPMODM = 2 : mkstat = 2 : Endif
If [M:MFL1]MFGMODC = 1 & [M:MFL1]MFGMODO = 1 : mkstat = 2 : Endif
End

########################################
# Production Scheduler project phase 1
# Enable or disable the optimisation mode based on scheduling mode
Subprog AM_MODJAL(VALEUR)
Variable Integer VALEUR
    If dim([M:MFL1]MODOPT) > 0
        If VALEUR = 1
            Grizo [M:MFL1]MODOPT
            [M:MFL1]MODOPT = 1
            Call MESSAGE (mess(355,193,1)) From GESECRAN
        Else
            Actzo [M:MFL1]MODOPT
        Endif
        Affzo [M:MFL1]MODOPT
    Endif
End

########################################
# Production Scheduler project phase 1
# Validate that scheduling mode is automatic if optimisation is set to automatic
Subprog C_MODOPT(VALEUR)
Variable Integer VALEUR
Case VALEUR
    When 2:
        If [M:MFL1]MODJAL = 1
            GMESSAGE = mess(353,193,1)
            GERR = 1
            mkstat = 2
        Endif
Endcase
End

########################################
Subprog AM_TYPMODM(VALEUR)
Variable Integer VALEUR
If VALEUR = 2 : [M:MFL1]MODALL = 1 : Affzo [M:MFL1]MODALL : Endif
End

########################################
Subprog AM_TYPMODO(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
    [M:MFL1]MODJAL = 1 : Affzo [M:MFL1]MODJAL
    If dim([M:MFL2]MWLFLG)>0 : [M:MFL2]MWLFLG = 1 : Grizo [M:MFL2]MWLFLG : Endif    # 40246 mm 03.07
Else
    Actzo [M:MFL2]MWLFLG
Endif
End

########################################
Subprog AM_MFGMODM(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
    If [M:MFL1]MFGMODC = 1
        [M:MFL1]MODALL = 1
        Affzo [M:MFL1]MODALL
    Endif
Endif
End

########################################
Subprog AM_MFGMODO(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
    If [M:MFL1]MFGMODC = 1
       [M:MFL1]MODJAL = 1
      Affzo [M:MFL1]MODJAL
    Endif
Endif
End

########################################
Subprog VERIF_REPORT(LCOD, LRET)
Value     Char    LCOD
Variable  Integer LRET

LRET = 0
If clalev ([F:ARP]) <= 0 : Local File AREPORT  [ARP] : Endif
Filter [ARP] Where RPTCOD = LCOD
Look [ARP] First
If fstat : LRET = 1 : Endif
Filter [ARP]
End

########################################
#-----------------------#
# Avant zone code actif #
#-----------------------#
Subprog AV_ENAFLG(VALEUR)
Variable Integer VALEUR
If GREP<>"C" & VALEUR=0 VALEUR=2 : Endif
End
########################################
Subprog B1_PICLISNAM(VALEUR)
Variable Char    VALEUR()
Local File AREPORT [ARP] Where MODULE = 8
Call OBJET("ARP", VALEUR, "") From GOBJET
End

########################################
Subprog AS_PICLISNAM(VALEUR)
Variable Char    VALEUR()
GBOUT1 = mess(347,198,1)
End

########################################
Subprog C_PICLISNAM(VALEUR)
Variable Char    VALEUR()
Local    Integer WRET
If [M:MFL2]PICLIS = 1 : End : Endif
If VALEUR = "" : GMESSAGE = mess(10,123,1) : mkstat = 2 : End : Endif
Call VERIF_REPORT(VALEUR, WRET)
If WRET
    GMESSAGE = mess(23,100,1)
    mkstat   = 2
Endif
End

