#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################
# SUBMFL : Transactions de saisie O.F                    LLC    01/99 #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:MTS]MFGTRS   Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                                                                     #
# Génération de 4 écrans de saisie à partir des écrans de base MFG0   #
#                                                              MFG1   #
#                                                              MFG2   #
#                                                              MFG3   #
#                                                                     #
# Nom des écrans de base générés : WRxyyyz                            #
#                                  x = 1 pour lancement               #
#                                      2 pour suivi                   #
#                                                                     #
#                                  yyy = nom de la transaction        #
#                                                                     #
#                                  z = numéro d'ordre de l'écran      #
# Nom des écrans fiches  générés : WQxyyyz                            #
#                                  x = numéro ordre écran de base     #
#                                      correspondant                  #
#                                                                     #
#                                  yyy = nom de la transaction        #
#                                                                     #
#                                  z = numéro d'ordre de l'écran      #
# Exemple:                                                            #
# écran de base MFG1 / écran généré WR1XXX1                           #
# fiche n liée à MFG1  / écran généré WQnXXX1                         #
#######################################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "AFFMASK"     : Gosub TRT_DIETRS From SUBDST
 When "FILTRE"      : Gosub FILTRE
 When "EFFMASK"     : [M]MTSTYP = 1
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "LIENS"       : Gosub LIENS
 When "RAZCRE"      : Gosub RAZCRE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INICRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "CREATION"    : Gosub TRT_ECRAN
 When "MODIF"       : Gosub TRT_ECRAN
 When "ANNULE"      : Gosub ANNULE
 When Default
Endcase
Return


#-------------------------------------------------------#
$OUVRE
If dim(APPLI)<0 Local Char APPLI : Endif
If APPLI=""     APPLI=nomap      : Endif
Local Char    WDIE_ABRFIC(GLONABR) : [L]WDIE_ABRFIC="MTS"
Local Integer WDIE_DTRTYP          : [L]WDIE_DTRTYP=1
Gosub TRT_DIETRS From SUBDST
Return


#-------------------------------------------------------#
# Ne traiter que les transactions de saisie OF          #
#-------------------------------------------------------#
$FILTRE
FILTSUP="MTSTYP=1"
Return

#------------------------------------------#
# Désactivation bouton validation et copie #
#------------------------------------------#
$SETBOUT
If GREP <>"" or !CLECUR Call VIREBOUT(CHAINE,"12") From GOBJET : Endif
Call VIREBOUT(CHAINE,"H") From GOBJET
Return

#-------------------------------------------------#
# Après appui sur bouton "Validation" ou  "copie" #
#-------------------------------------------------#
$EXEBOUT
Case REP
  When "1" :  Call DEBTRANS From GLOCK
              Trbegin ADOVAL
              Gosub TRT_ECRAN : If GOK<1 Rollback Else Commit : Endif
When Default
Endcase
Return

$LIENS
Gosub TRT_DIETRS From SUBDST # V6 analytique
# grizage si transaction auto
Case [F:MTS]TRSAUTO
    When 1:    Actzo [M:MFL1]10
               Actzo [M:MFL1]15
               Actzo [M:MFL3]QTYSAI
               Actzo [M:MFL3]ROUSAI
               Actzo [M:MFL3]10
    When 2:    Grizo [M:MFL1]10
               Grizo [M:MFL1]15
               Grizo [M:MFL3]QTYSAI
               Grizo [M:MFL3]ROUSAI
               Grizo [M:MFL3]10
Endcase

    # Set the value of Production Scheduler mode based on Scheduling mode
    If dim([M:MFL1]MODOPT) > 0
        If [M:MFL1]MODJAL = 1
            Grizo [M:MFL1]MODOPT
        Else
            Actzo [M:MFL1]MODOPT
        Endif
    Endif

# llc 03.02 12520
If !find([M:MFL3]SCDMODSAI,1,2,3)
    If [M:MFL1]TRSAUTO = 1
        [M:MFL3]SCDMODSAI = 3
    Else
        [M:MFL3]SCDMODSAI = 1
    Endif
Endif
If dim([M:MFL2]MWLFLG) > 0
    If [M:MFL2]MWLFLG = 0 : [M:MFL2]MWLFLG = 1 : Endif
    If [M:MFL1]MFGMODO = 2 & [M:MFL1]TYPMODO = 2
       [M:MFL2]MWLFLG = 1 : Grizo [M:MFL2]MWLFLG
    Else
       Actzo [M:MFL2]MWLFLG
    Endif
Endif
If clalev([M:DST])
  [M:DST]CCESCR  = 3
  [M:DST]CCESCR2 = 3
  [M:DST]CCESCR3 = 3
  Affzo [M:DST]
  Grizo [M:DST]10,20,30
Endif

# Issue 107513 - 2015-04-24 by JUSYN : ECC hidden fields by default
If dim([M:MFL3]ECCCOD)>0
    If [M:MFL3]ECCCOD=0
       [M:MFL3]ECCCOD=3 : [M:MFL3]ECCSCR=2
    Endif
    If [M:MFL3]ECCCOD=3  Grizo [M:MFL3]ECCSCR  Else Actzo [M:MFL3]ECCSCR  : Endif
Endif
If dim([M:MFL3]ECCCODMIN)>0
    If [M:MFL3]ECCCODMIN=0
       [M:MFL3]ECCCODMIN=3: [M:MFL3]ECCSCRMIN=2
    Endif
    If [M:MFL3]ECCCODMIN=3  Grizo [M:MFL3]ECCSCRMIN  Else Actzo [M:MFL3]ECCSCRMIN  : Endif
Endif
# End issue 107513

# Issue 110957 - 2015-09-17 by CCC : default value on old transactions is "hidden"
If dim([M:MFL3]CRAFF)>0 & [M:MFL3]CRAFF=0
    [M:MFL3]CRAFF = 2
Endif

# Issue 60258 GH 16/04/2018 - default value on old transactions is "displayed"
If [M:MFL3]FDMA = 0 : [M:MFL3]FDMA = 1 : Endif

Gosub PE_MFGTRS From SUBMFX
Return

$RAZCRE
If clalev([M:DST])
  [M:DST]CCESCR  = 3
  [M:DST]CCESCR2 = 3
  [M:DST]CCESCR3 = 3
  Affzo [M:DST]
  Grizo [M:DST]10,20,30
Endif
Gosub TRT_DIETRS From SUBDST # V6 analytique

Gosub PE_MFGTRS From SUBMFX
Affzo [M:MFL0]1-99
Affzo [M:MFL1]1-99
Affzo [M:MFL2]1-99
Affzo [M:MFL3]1-99
Return

#---------------------------#
# Chargement avant le Write #
#---------------------------#
$INICRE
Gosub CHARGE_ATEXTRA From SUBMFL
Gosub PE_MFGTRS From SUBMFX
Return

#----------------------------------------#
# Création ou modif du texte traductible #
#----------------------------------------#
$CHARGE_ATEXTRA
Call MAJTEXTRA([M:MFL0]DESAXX,"MFGTRS","DESAXX",num$([M:MFL0]MTSTYP),[M:MFL0]MTSNUM) From ATEXTRA
[F:MTS]MTSDES   =GLANGUE+"~"+[M:MFL0]DESAXX
[F:MTS]MTSTYPCAR=num$([F:MTS]MTSTYP)
Return

#################################################
$APRES_MODIF
# Issue 107513 - 2015-04-24 by JUSYN : ECC Major and minor version treatment
Case COUZON
    When "ECCCOD"
        If val(CZ) = 2 & [M:MFL3]ECCCODMIN=1
            [M:MFL3]ECCCODMIN = 2
            If !GIMPORT Affzo [M:MFL3]ECCCODMIN : Endif
        Endif
        If val(CZ)=3
            [M:MFL3]ECCSCR=2
            [M:MFL3]ECCCODMIN=3
            [M:MFL3]ECCSCRMIN=2
            If !GIMPORT Affzo [M:MFL3]ECCSCR,ECCCODMIN,ECCSCRMIN : Grizo [M:MFL3]ECCSCR,ECCCODMIN,ECCSCRMIN : Endif
        Elsif !GIMPORT
            Actzo [M:MFL3]ECCSCR,ECCCODMIN,ECCSCRMIN
        Endif
    When "ECCCODMIN"
        If val(CZ)=3
            [M:MFL3]ECCSCRMIN=2
            If !GIMPORT Affzo [M:MFL3]ECCSCRMIN : Grizo [M:MFL3]ECCSCRMIN : Endif
        Elsif !GIMPORT
            Actzo [M:MFL3]ECCSCRMIN
        Endif
# End issue 107513
  When Default
       Gosub PE_MFGTRS From SUBMFX
Endcase


Return

#################################################
$ANNULE
Local Char    WDIE_ABRFIC(GLONABR) : [L]WDIE_ABRFIC="MTS"
Gosub TRT_DIETRS From SUBDST # V6 analytique
Delete [AXX] Where CODFIC="MFGTRS" & IDENT1=num$([F:MTS]MTSTYP) & IDENT2=[F:MTS]MTSNUM
Gosub TRT_ECRAN
Return
#################################################

#------------------------------------------------#
# Génération ou suppression de l'écran de saisie #
#------------------------------------------------#
$TRT_ECRAN
Local Char    MFROM(GLONAMK)
Local Char    MTO(GLONAMK)
Local Integer TBLOC(15)
Local Char    TZONE(GLONAVA)(200)
Local Integer TMOD(200)
Local Char    TINT(1)(1)
Local Char    TTAB(1)(1)
Local Char    TFLD(1)(1)
Local Integer OPT1, OPT2, OPT3, RETOUR
Local Integer IZON, I, OK
Local Char    BOUTONS(10)(4), TEXTE(40), LISTE(3), REPONS(1)
Local Char    SAV_ACTION(type(ACTION)-10)
#---------------- Noms fenêtres et traitement ---------#
Local Char     WINREF1(GLONFEN) : WINREF1="OMFG"
Local Char     NOMWIN1(GLONFEN) : NOMWIN1="WOMFG"+[M:MFL0]MTSNUM
Local Char     NOMMSKENT(GLONAMK)    # Nom du masque d'entête de la fenêtre

#------------------------- Chargement -------------------------#
Gosub TRT_DIETRS From SUBDST # V6 analytique
# FQ 50852 pb en validation de masse
If ACTION<>"ANNULE"
    SAV_ACTION = ACTION
    ACTION = "LIENS"
    Gosub LIENS
    ACTION = SAV_ACTION
Endif

#------------------------- 1er écran --------------------------#
MFROM="MFG0"
MTO="WR"+num$([M:MFL0]MTSTYP)+[M:MFL0]MTSNUM+"0"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"
   OPT1=0
   OPT2=0
   Gosub PE_MFGTRS From SUBMFX
Else OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Endif

#------------------------- 2eme écran --------------------------#
MFROM="MFG1"
MTO="WR"+num$([M:MFL0]MTSTYP)+[M:MFL0]MTSNUM+"1"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"
   If [M:MFL1]MFGMODC = 1 & [M:MFL1]MFGMODM = 1 & [M:MFL1]MFGMODO = 1
        Call ERREUR(mess(73,193,1)) From GESECRAN
        GOK = 0
        Return
   Endif
   If [M:MFL3]UOMSAI = 1
       TZONE(IZON) = "UOM"
       TMOD(IZON)  = 3
       IZON       += 1
       TZONE(IZON) = "UOMEXTQTY"
       TMOD(IZON)  = 3
       IZON       += 1
       TZONE(IZON) = "UOMSTUCOE"
       TMOD(IZON)  = 3
       IZON       += 1
       TZONE(IZON) = "EXTQTY"
       TMOD(IZON)  = 1
       IZON       += 1
   Else
       TZONE(IZON) = "EXTQTY"
       TMOD(IZON)  = 2
       IZON       += 1
   Endif
   If [M:MFL3]LOTAFF > 1
       TZONE(IZON) = "LOT"
       TMOD(IZON)  = [M:MFL3]LOTAFF
       IZON       += 1
   Endif
   If [M:MFL3]DESAFF > 1
       TZONE(IZON) = "MFGDES"
       TMOD(IZON)  = [M:MFL3]DESAFF
       IZON       += 1
   Endif
   If [M:MFL3]DENAFF > 1
       TZONE(IZON) = "BPCTYPDEN"
       TMOD(IZON)  = [M:MFL3]DENAFF
       IZON       += 1
       TZONE(IZON) = "BPCNUM"
       TMOD(IZON)  = [M:MFL3]DENAFF
       IZON       += 1
       TZONE(IZON) = "BPCDES"
       TMOD(IZON)  = [M:MFL3]DENAFF
       IZON       += 1
       TZONE(IZON) = "VCRNUMORI"
       TMOD(IZON)  = [M:MFL3]DENAFF
       IZON       += 1
   Endif
   If [M:MFL3]PJTAFF > 1
       TZONE(IZON) = "PJT"
       TMOD(IZON)  = [M:MFL3]PJTAFF
       IZON       += 1
   Endif
   If [M:MFL3]REDAFF > 1
       TZONE(IZON) = "LTIREDCOE"
       TMOD(IZON)  = [M:MFL3]REDAFF
       IZON       += 1
   Endif
   If [M:MFL3]PIOAFF > 1
       TZONE(IZON) = "MFGPIO"
       TMOD(IZON)  = [M:MFL3]PIOAFF
       IZON       += 1
   Endif
   If [M:MFL3]ROUSAI = 1
       TZONE(IZON) = "ROUNUM"
       TMOD(IZON)  = 2
       IZON       += 1
       TZONE(IZON) = "ROUALT"
       TMOD(IZON)  = 2
       IZON       += 1
       # Issue 111414 - 2016-01-07 by CCC : Route version management
       TZONE(IZON) = "ROUECCMAJ"
       TMOD(IZON)  = 2
       IZON       += 1
       TZONE(IZON) = "ROUECCMIN"
       TMOD(IZON)  = 2
       IZON       += 1
   Endif
   # Issue 110957 - 2015-09-17 by CCC
   If dim([M:MFL3]CRAFF)>0
       TZONE(IZON) = "CRID"
       If [M:MFL3]CRAFF=1
          TMOD(IZON)  = 1   # enterable & diszo afterwards in order to have actions
       Else
          TMOD(IZON)  = 3
       Endif
       IZON       += 1
       TZONE(IZON) = "CRFLG"
       If [M:MFL3]CRAFF=1
          TMOD(IZON)  = 2
       Else
          TMOD(IZON)  = 3
       Endif
       IZON       += 1
   Endif

   OPT1=0
   # llc 12.02 11900
   OPT2=0
   Gosub PE_MFGTRS From SUBMFX
Else OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Endif
#------------------------- 3ème écran --------------------------#
MFROM="MFG2"
MTO="WR"+num$([M:MFL0]MTSTYP)+[M:MFL0]MTSNUM+"2"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON
If ACTION<>"ANNULE"
# Issue 107513 - 2015-04-24 by JUSYN : ECC for [M:MFG2] table MFGMAT
    If dim([M:MFL3]ECCCOD)>0
        If [M:MFL3]ECCCOD>0     TZONE(IZON)="ECCVALMAJ"
                                If [M:MFL3]ECCSCR=2 : # Hidden in table [M:MFG2], Displayed/Enter in [M:MFGW]
                                    TMOD(IZON) = 3
                                Else
                                    TMOD(IZON) = [M:MFL3]ECCCOD
                                Endif
                                IZON += 1
        Endif
        If [M:MFL3]ECCCODMIN>0  TZONE(IZON)="ECCVALMIN"
                                If [M:MFL3]ECCSCRMIN=2 : # Hidden in table [M:MFG2], Displayed/Enter in [M:MFGW]
                                    TMOD(IZON) = 3
                                Else
                                    TMOD(IZON) =[M:MFL3]ECCCODMIN
                                Endif
                                IZON += 1
        Endif
   Endif
# End issue 107513
   # Issue 110957 - 2015-09-17 by CCC
   If dim([M:MFL3]CRAFF)>0
       TZONE(IZON) = "CRID"
       If [M:MFL3]CRAFF=1
          TMOD(IZON)  = 1   # enterable & diszo afterwards in order to have actions
       Else
          TMOD(IZON)  = 3
       Endif
       IZON       += 1
       TZONE(IZON) = "CRFLG"
       If [M:MFL3]CRAFF=1
          TMOD(IZON)  = 2
       Else
          TMOD(IZON)  = 3
       Endif
       IZON       += 1
   Endif
   # Issue 60258 GH 16/04/2018 - FMDA field is displayed or hidden
   TZONE(IZON) = "FDMA"
   If [M:MFL3]FDMA=1
          TMOD(IZON)  = 2
   Else
          TMOD(IZON)  = 3
   Endif
   IZON       += 1
   OPT1= 2
   Gosub PE_MFGTRS From SUBMFX
Else OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Endif
#------------------------- 4ème écran --------------------------#
MFROM="MFG3"
MTO="WR"+num$([M:MFL0]MTSTYP)+[M:MFL0]MTSNUM+"3"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON
If ACTION<>"ANNULE"
   # Issue 60258 GH 16/04/2018 - FMDA field is displayed or hidden
   TZONE(IZON) = "FDMA"
   If [M:MFL3]FDMA=1
     TMOD(IZON)  = 2
   Else
     TMOD(IZON)  = 3
   Endif
   IZON       += 1
   OPT1= 2
   Gosub PE_MFGTRS From SUBMFX
Else OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Endif

#------------------------- 5ème écran --------------------------#
MFROM="MFG4"
MTO="WR"+num$([M:MFL0]MTSTYP)+[M:MFL0]MTSNUM+"4"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON,OPT1,OPT2,OPT3
If ACTION<>"ANNULE"
   OPT1=0
   OPT2=0
   Gosub PE_MFGTRS From SUBMFX
Else OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Endif

#------------------------- Fiche corresp.à MFG1 --------------------------#
MFROM="MFIW"
MTO="WQ"+"1"+[M:MFL0]MTSNUM+"1"
Raz TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,IZON
If ACTION<>"ANNULE"
   If [M:MFL3]UOMSAI = 1
       TZONE(IZON) = "UOM"
       TMOD(IZON)  = 3
       IZON       += 1
       TZONE(IZON) = "UOMEXTQTY"
       TMOD(IZON)  = 3
       IZON       += 1
       TZONE(IZON) = "UOMSTUCOE"
       TMOD(IZON)  = 3
       IZON       += 1
   Endif
   If [M:MFL3]LOTAFF > 1
       TZONE(IZON) = "LOT"
       TMOD(IZON)  = [M:MFL3]LOTAFF
       IZON       += 1
   Endif
   If [M:MFL3]DESAFF > 1
       TZONE(IZON) = "MFGDES"
       TMOD(IZON)  = [M:MFL3]DESAFF
       IZON       += 1
   Endif
   If [M:MFL3]DENAFF > 1
       TZONE(IZON) = "BPCTYPDEN"
       TMOD(IZON)  = [M:MFL3]DENAFF
       IZON       += 1
       TZONE(IZON) = "BPCNUM"
       TMOD(IZON)  = [M:MFL3]DENAFF
       IZON       += 1
       TZONE(IZON) = "BPCDES"
       TMOD(IZON)  = [M:MFL3]DENAFF
       IZON       += 1
   Endif
   If [M:MFL3]PJTAFF > 1
       TZONE(IZON) = "PJT"
       TMOD(IZON)  = [M:MFL3]PJTAFF
       IZON       += 1
   Endif
   # Issue 110957 - 2015-09-17 by CCC
   If dim([M:MFL3]CRAFF)>0
       TZONE(IZON) = "CRID"
       If [M:MFL3]CRAFF=1
          TMOD(IZON)  = 2   # only display in this screen
       Else
          TMOD(IZON)  = 3
       Endif
       IZON       += 1
   Endif
   OPT1=2
   Gosub PE_MFGTRS From SUBMFX
Else OPT1=9
Endif
Call GENECR(APPLI,MFROM,MTO,"",TBLOC,TZONE,TMOD,TINT,TTAB,TFLD,OPT1,OPT2,OPT3,RETOUR) From GENECR
If RETOUR<>0 GOK=0 : Endif

#---- suppression ou génération fenêtre AWINDOW
If ACTION="ANNULE"
  Gosub TRT_SUP_FEN
Else
  Gosub TRT_GEN_FEN
Endif
If GOK<1 : Return : Endif
Return

#-------------------------------------------------------------------------#
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 1 (Non actif)           #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 2 (Actif)               #
# Génération fenêtre, traitement associé et mise à jour traitement objet  #
#-------------------------------------------------------------------------#
$TRT_GEN_FEN
If clalev([F:AWI])=0 Local File =APPLI+".AWINDOW" [AWI] : Endif : # Si appel par le FUNMFGTRS
If clalev([F:AWP])=0 Local File =APPLI+".AWINPAR" [AWP] : Endif : # Si appel par le FUNMFGTRS
If clalev([F:AWB])=0 Local File =APPLI+".AWINBRO"  [AWB] : Endif : # Si appel par le FUNSTKTRS
If clalev([F:AWT])=0 Local File =APPLI+".AWINBOUT" [AWT] : Endif : # Si appel par le FUNSTKTRS

#----- Suppression fenêtre si transaction non active -----#
Gosub TRT_SUP_FEN
If [M:MFL0]ENAFLG=1 : Return : Endif
#----- Génération fenêtre pour suivi si transaction active -----#
Delete [AWI] Where WIN=NOMWIN1
If fstat=1  GOK=-1 : GLOCK="$AWINDOW"-NOMWIN1
Elsif fstat GOK=0  : Call RSTA ("AWI",NOMWIN1) From GLOCK
Endif
Delete [AWP] Where WIN=NOMWIN1
If fstat=1  GOK=-1 : GLOCK="$AWINPAR"-NOMWIN1
Elsif fstat GOK=0  : Call RSTA ("AWP",NOMWIN1) From GLOCK
Endif
Read [AWI] AWI0=WINREF1
If !fstat
  [F:AWI]WIN       = NOMWIN1
  [F:AWI]MSKENT    = "WR"+num$([M:MFL0]MTSTYP)+[M:MFL0]MTSNUM+"0"
  WNOMMSK="WR"+num$([M:MFL0]MTSTYP)+[M:MFL0]MTSNUM+"1"
  I=find("MFG1",[F:AWI]NOMMSK)-1 : If I<0 I=1 : Endif
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = 2
  WNOMMSK="WR"+num$([M:MFL0]MTSTYP)+[M:MFL0]MTSNUM+"2"
  I=find("MFG2",[F:AWI]NOMMSK)-1 : If I<0 I=2 : Endif
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = 2
  WNOMMSK="WR"+num$([M:MFL0]MTSTYP)+[M:MFL0]MTSNUM+"3"
  I=find("MFG3",[F:AWI]NOMMSK)-1 : If I<0 I=3 : Endif
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = 2

  WNOMMSK="WR"+num$([M:MFL0]MTSTYP)+[M:MFL0]MTSNUM+"4"
  I=find("MFG4",[F:AWI]NOMMSK)-1 : If I<0 I=4 : Endif
  [F:AWI]NOMMSK(I) = WNOMMSK
  [F:AWI]FLGMSK(I) = 2

  [F:AWI]ACS       = [M:MFL0]ACSCOD
  If dim([F:AWI]LIBEL)>0
    [F:AWI]LIBEL   = [M:MFL0]DESAXX
  Endif
  [F:AWI]ENAFLG    = 2
  [F:AWI]TRN       = [M:MFL0]MTSNUM
  [F:AWI]MDL       = 1            # !!

  # Issue 79269 - New entry Point to Hide/Show Specific Tab
  Gosub PE_MFGTRSWIN From SUBMFX

  Write [AWI]
  If fstat GOK=0 : Call FSTA("AWI") From GLOCK : Return : Endif
  For [AWP] AWP0 Where WIN=WINREF1
    [F:AWP]WIN = NOMWIN1
    Write [AWP]
    If fstat GOK=0 : Call FSTA("AWP") From GLOCK : Break : Endif
  Next
  If GOK<1 Return : Endif
  For [AWB] AWB0 Where WIN=WINREF1
    [F:AWB]WIN = NOMWIN1
    Write [AWB]
    If fstat GOK=0 : Call FSTA("AWB") From GLOCK : Break : Endif
  Next
  For [AWT] AWT0 Where WIN=WINREF1
    [F:AWT]WIN = NOMWIN1
    Write [AWT]
    If fstat GOK=0 : Call FSTA("AWT") From GLOCK : Break : Endif
  Next
  If GOK<1 Return : Endif

Endif
Call VALID(NOMWIN1,APPLI,1,OK) From VALWIN
If !OK  : GOK=0 : Return : Endif
Return

#-------------------------------------------------------------------------#
# Si action = "ANNULE"                                                    #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
#-------------------------------------------------------------------------#
$TRT_SUP_FEN
#----- Suppression ----#
Call DELWIN(NOMWIN1,APPLI) From MSKDIV
Return


