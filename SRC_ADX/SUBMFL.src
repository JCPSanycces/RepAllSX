########################################
Subprog AM_TRSAUTO(VALEUR)
Variable Integer VALEUR
Case VALEUR
    When 1:    Actzo [M:MFL1]10
               Actzo [M:MFL1]15
               Actzo [M:MFL3]QTYSAI
               Actzo [M:MFL3]ROUSAI
               Actzo [M:MFL3]10
    When 2:    [M:MFL1]MFGSTA = 3
               Grizo [M:MFL1]10
               Grizo [M:MFL1]15
               Grizo [M:MFL3]QTYSAI
               Grizo [M:MFL3]ROUSAI
               Grizo [M:MFL3]10
Endcase
Affzo [M:MFL1]10-15
Affzo [M:MFL3]QTYSAI
Affzo [M:MFL3]ROUSAI
Affzo [M:MFL3]10
End

