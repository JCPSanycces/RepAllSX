#<AdxTL>@(#)172.0.0.0 $Revision$
Call DEFVAR
Call INIVAR
End

###########################################################
# Définition des variables
###########################################################
Subprog DEFVAR

Call DEFVAR From WWAGLOBCPT

End

###########################################################
# Initialisation des variables
###########################################################
Subprog INIVAR
Local Char VALPAR(10)
If clalev([F:ADW])=0 : Local File ADOVAL  [ADW] : Endif 
If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif  

# Nb d'axes analytiques 
Read [ACV]CODACT = "ANA" 
GOPTCANA = max(1,[F:ACV]DIME) 
 
Call INIGLBGCM From SETGLBGCM
Call INIGLBLED From SETGLBLED
Call INIGLBCOA From SETGLBCOA
Call INIGLBDIE From SETGLBDIE

# Premier exercice possible 
Call PARAM("","STRDAT",VALPAR) From ADOVAL
GPERDEB  = gdat$(VALPAR) 
   
If GMODU(2)=2  :# Compta
 ## Reports à nouveaux
 Call EXEAN
Endif

## Schéma standard de saisie
GSCHSTD(1) = "STD"
GSCHSTD(2) = ""
GSCHSTD(3) = "STDL"

If GMODU(2)=2  :# Compta
 # Parametre Transaction de saisie Colonne
 Call PARAM("","SCHSTDC",GSCHSTDC) From ADOVAL
 # Parametre Transaction de saisie Ligne
 Call PARAM("","SCHSTDL",GSCHSTDL) From ADOVAL
Endif

End


# Exercices de report à nouveau général
# Version optimisée (BY 18/03/2009)
Subprog EXEAN
Local Integer I , J , EXE , NBFIY
Raz GEXEAN
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
Filter [FIY] Where FIYSTA=2 Order By Key CLE=CPY;LEDTYP;FIYNUM
For [FIY]CLE(2)
 I   = find([F:FIY]CPY,GSOC(1..GNBSOC))
 J   = [F:FIY]LEDTYP
 EXE = [F:FIY]FIYNUM
 Raz NBFIY
 For [FIY]CLE
  NBFIY +=1
  If I & J & [FIY]FIYNUM=EXE+1
   GEXEAN(I,J) = EXE
  Endif
 Next
 If I & J & GEXEAN(I,J)=0 & NBFIY=1
  GEXEAN(I,J) = EXE
 Endif
Next
Filter [FIY]
End

# Ancienne version (pour vérif s'il y a un pb)
Subprog OEXEAN
Local Integer I , J , EXE
Raz GEXEAN
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
For I=1 To GNBSOC
 For J=1 To len(mess(0,2644,1))
  Filter [FIY] Where CPY=GSOC(I) & LEDTYP=J & FIYSTA=2 : # 1er exercice ouvert
  Read [FIY]FIY0 First
  Filter [FIY]
  If !fstat
   EXE = [F:FIY]FIYNUM
   Read [FIY]FIY0 = GSOC(I);J;EXE+1
   If !fstat & [F:FIY]FIYSTA=2
    GEXEAN(I,J) = EXE
   Endif
  Endif
 Next J
Next I
End


