#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CHGEVADAT 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone EVATYP
mkstat = 0
zoncou = "EVATYP"
indice = 0
If varinit([M]EVATYP,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]EVATYP,"10464","") From SUBADI
 GACTION = SAVACT
Endif

## Zone EVADATSTR
mkstat = 0
zoncou = "EVADATSTR"
indice = 0
If varmode([M]EVADATSTR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EVADATSTR" : Gosub ACTION From =IMPTRT
 Endif
 If [M]EVADATSTR=[0/0/0]
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "EVADATSTR" : GZNUM = 51972 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_EVADATSTR([M]EVADATSTR) From CHGEVADAT
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "EVADATSTR" : GZNUM = 51972 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone EVADATEND
mkstat = 0
zoncou = "EVADATEND"
indice = 0
If varmode([M]EVADATEND,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EVADATEND" : Gosub ACTION From =IMPTRT
 Endif
 If [M]EVADATEND=[0/0/0]
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "EVADATEND" : GZNUM = 51973 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_EVADATEND([M]EVADATEND) From CHGEVADAT
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "EVADATEND" : GZNUM = 51973 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "DATDEBFIN"
   Call DATDEBFIN([M]EVADATEND,[M]EVADATSTR) From EXEFNC
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "EVADATEND" : GZNUM = 51973 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CHGEVADAT"
Return

