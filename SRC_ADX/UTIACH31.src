#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIACH31   Suppression du paramètre EOMALLMGT                          #
##########################################################################
# DM 79164 - 2012-03-15 by CCC
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call MAJ_UTIACH31(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIACH31(DOSSIER)
Value Char DOSSIER

If filinfo (filpath ("FIL", "ADOPAR" , "fde",DOSSIER ) ,0) < 0: End : Endif
If filinfo (filpath ("FIL", "ADOVAL" , "fde",DOSSIER ) ,0) < 0: End : Endif
If filinfo (filpath ("FIL", "AGLOBVAR" , "fde",DOSSIER ) ,0) < 0: End : Endif

Call ECR_TRACE("UTIACH31: Process Start on : "+DOSSIER,0) From GESECRAN

Local Char TRTSTD(30)
#----- Ouverture des fichiers -----#
Local File =DOSSIER + ".ADOCUMENT"[ADO]
Local File =DOSSIER + ".ADOCCLB"  [ADH]
Local File =DOSSIER + ".ADOPAR"  [ADP]
Local File =DOSSIER + ".ADOVAL"  [ADW]
Local File =DOSSIER + ".AGLOBVAR"[AGB]

Call DEBTRANS From GLOCK
Trbegin [ADW]
Delete [ADW] Where PARAM="EOMALLMGT"
If fstat
    Call ECR_TRACE("EOMALLMGT: can't delete parameter values",1) From GESECRAN
    GOK=0
Else
    Read [AGB]AGB0="GEOMALLMGT"
    [L]TRTSTD = [F:AGB]TRTSTD
    Delete [AGB]AGB0="GEOMALLMGT"
    If fstat
        Call ECR_TRACE("GEOMALLMGT: can't delete global",1) From GESECRAN
        GOK=0
    Else
        # Validation traitement WWGLOBACH
        Call EFFACE_DOC("AGB","GEOMALLMGT") From SUBADO
        Call VALIDATION(DOSSIER,[L]TRTSTD,0) From SUBAGB
        Read [ADP]ADP1 = "EOMALLMGT"
        Call VALCHAP(DOSSIER,[F:ADP]CHAPITRE,0) From SUBAGB
        Delete [ADP] Where PARAM="EOMALLMGT"
        If fstat
            Call ECR_TRACE("EOMALLMGT: can't delete parameter",1) From GESECRAN
            GOK=0
        Endif
    Endif
Endif
If GOK
    Commit
Else
    Rollback
Endif

Close Local File [ADW], [ADP]

Call ECR_TRACE("UTIACH31 : finish",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  Call MAJ_UTIACH31(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  Call MAJ_UTIACH31(APPLI)
End
