$ON_NBLIG
Onevent BEFORE_INPUT Call AS_NBLIG From W1PJMAUS
Onevent AFTER_LINE Call APRES_NBLIG From W1PJMAUS
Return

Subprog AS_NBLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(12490,GBOUT1) From OBJDIV
## Action STD
Call AS_NBLIG From SUBPAUS
Onkey 129 Titled GBOUT1 Call B1_NBLIG From W1PJMAUS
Gosub _AFF
End

Subprog B1_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action ACLOB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "ACLOB"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_NBLIG" : PROGSUB = "SUBPAUS" : PROGSPE = "SPEPAUS" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = [M:PAUS]VARTEX(nolign-1)
 PARMSK(2) = "CPV"
 PARMSK(3) = "TRTX3TEX"
 PARMSK(4) = "PAUS"
 PARMSK(5) = num$(nolign)
 PARMSK(6) = "1"
 Call TRAITE_NUM(BASPAG,PARMSK,"","ACLOB","ACLOB",3,"XYACLOB") From GTRAITE
 [M:PAUS]VARTEX(nolign-1) = PARMSK(1)
 ACTION = "BB1_NBLIG" : PROGSUB = "SUBPAUS" : PROGSPE = "SPEPAUS" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog APRES_NBLIG
Local Decimal BASPAG
## Action STD
Call APRES_NBLIG From SUBPAUS
If mkstat : End : Endif
Gosub _AFF
End

