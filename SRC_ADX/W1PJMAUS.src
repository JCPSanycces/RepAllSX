Raz mkstat
Call TEXTE(3514,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_VARTWD(zc) From W1PJMAUS
Onkey   2 Titled GBOUTS Call S_VARTWD(zc) From W1PJMAUS
Onkey 144 Titled GBOUTP Call P_VARTWD(zc) From W1PJMAUS
Onkey 146 Titled GBOUTA Call SA_VARTWD(zc) From W1PJMAUS
Gosub _AFF
End

Subprog C_VARTWD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "VARTWD" : GZNUM = 1809 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("TWD","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "VARTWD" : GZNUM = 1809 : Endif
Endif
Gosub _AFF
End

$AMM_VARTWD
Call AM_VARTWD(zc)
If !mkstat & GOBJET
 zoncou = "VARTWD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_VARTWD(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZVARTWD)")>indice
 [M]VARTWD(indice) = VALEUR
 Affzo ZVARTWD(indice)
Endif
Gosub _AFF
End

Subprog S_VARTWD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "TWD"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_VARTWD(VALEUR)
Variable Char    VALEUR()
Call OBJET("TWD",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_VARTWD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "TWD"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_VARTWD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("TWD",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZVARTWD
Onevent BEFORE_AREA Gosub AV_ZVARTWD From W1PJMAUS
Return

$AV_ZVARTWD
Call LECTEXTRA(zc,"TABWEEDIA","TWDDESAXX",num$([M]VARTWD(indice)),"") From ATEXTRA
Gosub _AFF
Return

$CHG_STY
Return


