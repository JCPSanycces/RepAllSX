If varinit([M]CODVAR,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"641","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_CODVAR(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"641") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CODVAR(zc) From W1PJMAUS
Onkey   2 Titled GBOUTS Call S_CODVAR(zc) From W1PJMAUS
Onkey 144 Titled GBOUTP Call P_CODVAR(zc) From W1PJMAUS
Onkey 146 Titled GBOUTA Call SA_CODVAR(zc) From W1PJMAUS
If VALEUR="" : Call INIADI(VALEUR,"641") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_CODVAR(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CODVAR" : GZNUM = 2675 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"641","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "CODVAR" : GZNUM = 2675 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"641",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CODVAR" : GZNUM = 2675 : Endif
 Endif
Endif
Gosub _AFF
End

