#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################
# Program Name: PPRIVAR
# Description : Purchase Price Variance Report
####################################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)

End

####################################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Global   Integer COST

Gosub OUVRE
If GERREUR : GERREUR=0 : End : Endif
Gosub DECLARE

[L]CRITERE  = "1=1"
[L]RCRITERE = "1=1"

For I=1 To NBPAR
  J=instr(1,[L]PARAMETRE(I),"=")
  If J
    [L]PARAM  = left$([L]PARAMETRE(I),J-1)
    [L]VALEUR = right$([L]PARAMETRE(I),J+1)
    Case [L]PARAM
      When "X3ETA"           : [L]ETAT = [L]VALEUR
      When "__REQUETE"       : [L]NUMREQ = val([L]VALEUR)
      When "datedeb"
        [L]DTEDEB=gdat$(val(right$([L]VALEUR,7)),val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
      When "datefin"
        [L]DTEFIN=gdat$(val(right$([L]VALEUR,7)),val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
      When "sitedeb"
        [L]CRITERE -= "& [PTD]PRHFCY>='"+[L]VALEUR+"'"
        [L]RCRITERE -= "& [PND]PNHFCY>='"+[L]VALEUR+"'"
      When "sitefin"
        [L]CRITERE -= "& [PTD]PRHFCY<='"+[L]VALEUR+"'"
        [L]RCRITERE -= "& [PND]PNHFCY<='"+[L]VALEUR+"'"
      When "itmrefdeb"
        [L]CRITERE -= "& ITMREF>='"+[L]VALEUR+"'"
        [L]RCRITERE -= "& ITMREF>='"+[L]VALEUR+"'"
      When "itmreffin"
        [L]CRITERE -= "& ITMREF<='"+[L]VALEUR+"'"
        [L]RCRITERE -= "& ITMREF<='"+[L]VALEUR+"'"
      When "clientdeb"
        [L]CRITERE -= "& [PTD]BPSNUM>='"+[L]VALEUR+"'"
        [L]RCRITERE -= "& [PND]BPSNUM>='"+[L]VALEUR+"'"
      When "clientfin"
        [L]CRITERE -= "& [PTD]BPSNUM<='"+[L]VALEUR+"'"
        [L]RCRITERE -= "& [PND]BPSNUM<='"+[L]VALEUR+"'"
      When "cost"
        COST = val([L]VALEUR)
      When "numedt"
        [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
      When "usr"
        [L]PARAMETRE(I) = "usr="+GUSER
      When "etat"
        [L]PARAMETRE(I) = "etat="+[L]ETAT
    Endcase
  Endif
Next

# Initialize the PPRIVARWRK table to prepare to load it with new information.
Lock [PPV]
Delete[PPV] Where PID=num$(adxpid) | CREDATTIM<date$-7
Unlock [PPV]

# Write the Receipt Records
Gosub PRECEIPTD_LOOP

# Write the Return Records
Gosub PRETURND_LOOP

End

####################################################################################
$OUVRE

If !clalev([F:ITC])  : Local File ITMCOST     [ITC]  : Endif
If !clalev([F:ITM])  : Local File ITMMASTER   [ITM]  : Endif
If !clalev([F:PTD])  : Local File PRECEIPTD   [PTD]  : Endif
If !clalev([F:PND])  : Local File PRETURND    [PND]  : Endif
If !clalev([F:PID])  : Local File PINVOICED   [PID]  : Endif
If !clalev([F:POH])  : Local File PORDER      [POH]  : Endif
If !clalev([F:POP])  : Local File PORDERP     [POP]  : Endif
If !clalev([F:STJ])  : Local File STOJOU      [STJ]  : Endif
If !clalev([F:MFO])  : Local File MFGOPE      [MFO]  : Endif
If !clalev([F:MFG])  : Local File MFGHEAD     [MFG]  : Endif
If !clalev([F:POQ])  : Local File PORDERQ     [POQ]  : Endif
If !clalev([F:BPS])  : Local File BPSUPPLIER  [BPS]  : Endif
If !clalev([F:PPV])  : Local File PPRIVARWRK  [PPV]  : Endif

Return

####################################################################################
$DECLARE

Local Char    CRITERE(255),RCRITERE(255),PARAM(30),VALEUR(30),ETAT(15)
Local Date    DTEDEB,DTEFIN
Local Integer NUMREQ,RFLAG

Return

####################################################################################
Funprog STKQTY(QTY,UOM,WBPSNUM)    # Convert all quantities to STK uom
Value Decimal QTY
Value Char UOM
Value Char WBPSNUM
Local Decimal RET, WCOEUOM

Read [ITM]ITM0=[PTD]ITMREF
If !fstat
  If [ITM]STU=UOM : End QTY :  Endif
  Call PCAL_QTY(QTY,UOM,RET,[ITM]STU,[ITM]ITMREF,WBPSNUM,1,WCOEUOM) From TRTACHQTE1    # Convert QTY to RET
Endif

End RET

####################################################################################
Funprog STKPRI(PRI,UOM,WBPSNUM)    # Convert all prices to STK uom
Value Decimal PRI
Value Char UOM
Value Char WBPSNUM
Local Decimal RET, WCOEUOM

Read [ITM]ITM0=[PTD]ITMREF
If !fstat
  If [ITM]STU=UOM : End PRI :  Endif
  Call PCAL_QTY(PRI,UOM,RET,[ITM]STU,[ITM]ITMREF,WBPSNUM,2,WCOEUOM) From TRTACHQTE1    # Convert PRI to RET
  RET=PRI * WCOEUOM
Endif

End RET

####################################################################################
$PRECEIPTD_LOOP

Local Integer RCP_IN_RANGE,INV_IN_RANGE,FORMFLG
Local Decimal TOTAL_RECEIPT_QTY,THIS_QTY

RFLAG = 0

Link [PID] With [PTD]PTD0=[F:PID]PTHNUM;[F:PID]PTDLIN As [LPPV]
& Where evalue([L]CRITERE) & ((([PTD]RCPDAT >= DTEDEB) & ([PTD]RCPDAT <= DTEFIN))
&                          |  (([PID]ACCDAT >= DTEDEB) & ([PID]ACCDAT <= DTEFIN)))


For [LPPV]
  TOTAL_RECEIPT_QTY = func STKQTY([PTD]QTYSTU,[PTD]STU,[PTD]BPSNUM)
  FORMFLG = 1  # Set to ensure a default if no invoice

  # BOTH RECEIPT and INVOICE WITHIN THE PERIOD.
  If ([PTD]RCPDAT>=DTEDEB & [PTD]RCPDAT<=DTEFIN)
&  & ([PID]ACCDAT>=DTEDEB & [PID]ACCDAT<=DTEFIN)

    FORMFLG = 2
  # Item received, but not invoiced in period.
  Elsif [PTD]RCPDAT>=DTEDEB & [PTD]RCPDAT<=DTEFIN
    FORMFLG = 1
  # ITEM RECEIVED PRIOR To PERIOD, INVOICED IN PERIOD.
  Else
    FORMFLG = 3
  Endif

  # Assign this invoice qty, write the record for this receipt/invoice, and
  # decrement this invoiced qty from the total receipt qty.  If the receipt
  # qty becomes 0 or less, set it to 0 and break out of the loop.  There is no
  # need to continue processing this receipt.  Only do this section if invoiced
  # within the period
  If FORMFLG<>1
    THIS_QTY = func STKQTY([PID]QTYUOM,[PID]UOM,[PID]BPSNUM)
    Gosub WRITE_RECORD
    TOTAL_RECEIPT_QTY -= THIS_QTY
  Endif

  # If there is a remaining receipt qty that was not invoiced at all, and the receipt
  # was within the period, write a record for the remaining receipt qty using the formula
  # for received but not invoiced within the period.  Otherwise, if the receipt was not
  # within the period specified, skip this record.
  If FORMFLG=1
    If TOTAL_RECEIPT_QTY & [PTD]RCPDAT>=DTEDEB & [PTD]RCPDAT<=DTEFIN
      THIS_QTY = TOTAL_RECEIPT_QTY
      Gosub WRITE_RECORD
    Endif
  Endif
Next

# Link above precludes receipt records with no invoice. Need one more loop on PTD for stand alone records.
FORMFLG = 1
For [PTD] Where evalue([L]CRITERE) & (([PTD]RCPDAT >= DTEDEB) & ([PTD]RCPDAT <= DTEFIN))
  Filter [PPV] Where [PPV]PNUM=[PTD]PTHNUM & [PPV]PLIN=[PTD]PTDLIN & [PPV]PID =num$(adxpid)
  Look [PPV] First
  If fstat  # No record on file for the receipt
    THIS_QTY = func STKQTY([PTD]QTYSTU,[PTD]STU,[PTD]BPSNUM)
    Gosub WRITE_RECORD
  Endif
  Filter [PPV]
Next

Return

####################################################################################
$PRETURND_LOOP

Local Integer RCP_IN_RANGE,INV_IN_RANGE,FORMFLG
Local Decimal TOTAL_RECEIPT_QTY,THIS_QTY

RFLAG = 1

Link [PID] With [PND]PND0=[F:PID]PNHNUM;[F:PID]PNDLIN As [LPPV2]
& Where evalue([L]RCRITERE) & ((([PND]RTNDAT >= DTEDEB) & ([PND]RTNDAT <= DTEFIN))
&                           |  (([PID]ACCDAT >= DTEDEB) & ([PID]ACCDAT <= DTEFIN)))

For [LPPV2]
  TOTAL_RECEIPT_QTY = func STKQTY([PND]QTYSTU,[PND]STU,[PND]BPSNUM)
  FORMFLG = 1  # Set to ensure a default if no invoice

  #  Both receipt and invoice within the period.
  If ([PND]RTNDAT>=DTEDEB & [PND]RTNDAT<=DTEFIN)
&  & ([PID]ACCDAT>=DTEDEB & [PID]ACCDAT<=DTEFIN)
    FORMFLG = 2
    # Item received, but not invoiced in period.
  Elsif [PND]RTNDAT>=DTEDEB & [PND]RTNDAT<=DTEFIN
    FORMFLG = 1
    # Item received prior to period, invoiced in period.
  Else
    FORMFLG = 3
  Endif

  # Assign this invoice qty, write the record for this receipt/invoice, and
  # decrement this invoiced qty from the total receipt qty.  If the receipt
  # qty becomes 0 or less, set it to 0 and break out of the loop.  There is no
  # need to continue processing this receipt. Only do this section if invoiced
  # within the period
  If FORMFLG<>1
    THIS_QTY = func STKQTY([PID]QTYUOM,[PID]UOM,[PID]BPSNUM)
    Gosub WRITE_RECORD
    TOTAL_RECEIPT_QTY -= THIS_QTY
  Endif

  # If there is a remaining receipt qty that was not invoiced at all, and the receipt
  # was within the period, write a record for the remaining receipt qty using the formula
  # for received but not invoiced within the period.  Otherwise, if the receipt was not
  # within the period specified, skip this record.
  If FORMFLG=1
    If TOTAL_RECEIPT_QTY & [PND]RTNDAT>=DTEDEB & [PND]RTNDAT<=DTEFIN
      THIS_QTY = TOTAL_RECEIPT_QTY
      FORMFLG = 1
      Gosub WRITE_RECORD
    Endif
  Endif

Next

# Link above precludes return records with no invoice. Need one more loop on PND for stand alone records.
FORMFLG = 1
For [PND] Where evalue([L]RCRITERE) & (([PND]RTNDAT >= DTEDEB) & ([PND]RTNDAT <= DTEFIN))
  Filter [PPV] Where [PPV]PNUM=[PND]PNHNUM & [PPV]PLIN=[PND]PNDLIN & [PPV]PID =num$(adxpid)
  Look [PPV] First
  If fstat  # No record on file for the receipt
    THIS_QTY = func STKQTY([PND]QTYSTU,[PND]STU,[PND]BPSNUM)
    Gosub WRITE_RECORD
  Endif
  Filter [PPV]
Next

Return

####################################################################################
$WRITE_RECORD

Local Decimal LPRI
Local Decimal TOTPRI
Local Integer LRET
Local Integer FILECOST

Read [ITM]ITM0=[PTD]ITMREF
If fstat : Return : Endif

Raz [POH],[POP],[PPV],[STJ],[MFO],[MFG],[POQ],[BPS]

If !RFLAG
  Read [POH]POH0=[PTD]POHNUM

  #117311.sn
  If [PTD]POHTYP = 2 #Contract POs
    Filter [POP] Where POHNUM=[PTD]POHNUM & POPLIN=[PTD]POPLIN
    Read [POP] First
    Filter [POP]
  #117311.en
  Else
    Read [POP]POP0=[PTD]POHNUM;[PTD]POPLIN;[PTD]POQSEQ
  Endif

  Read [POQ]POQ0=[PTD]POHNUM;[PTD]POPLIN;[PTD]POQSEQ
  Read [BPS]BPS0=[PTD]BPSNUM
Else
  Read [POH]POH0=[PND]POHNUM

  #117311.sn
  If [PND]POHTYP = 2 #Contract POs
    Filter [POP] Where POHNUM=[PND]POHNUM & POPLIN=[PND]POPLIN
    Read [POP] First
    Filter [POP]
  #117311.en
  Else
    Read [POP]POP0=[PND]POHNUM;[PND]POPLIN;[PND]POQSEQ
  Endif

  Read [POQ]POQ0=[PND]POHNUM;[PND]POPLIN;[PND]POQSEQ
  Read [BPS]BPS0=[PND]BPSNUM
Endif

Trbegin [PPV]


#105882.sn
# Map cost to filecost for STKVAL GETPRI call
Case COST
  When 1 : FILECOST=1   # Standard cost
  When 2 : FILECOST=2   # Revised standard cost
  When 3 : FILECOST=4   # Historical AUC
  When 4 : FILECOST=5   # FIFO cost
  When 5 : FILECOST=6   # Lot average cost
  When 6 : FILECOST=8   # LIFO price
Endcase
#105882.en


If !RFLAG
  [PPV]       = [PTD]
  [PPV]PNUM   = [PTD]PTHNUM
  [PPV]PLIN   = [PTD]PTDLIN
  [PPV]FCY    = [PTD]PRHFCY

  #105882.so
  #Case COST
  #      When 1 : FILECOST=1   # Standard cost
  #      When 2 : FILECOST=2   # Revised standard cost
  #      When 3 : FILECOST=4   # Historical AUC
  #      When 4 : FILECOST=5   # FIFO cost
  #      When 5 : FILECOST=6   # Lot average cost
  #      When 6 : FILECOST=8   # LIFO price
  #Endcase
  #105882.eo

  # Get the stock journal record
  #Filter [STJ] Where STOFCY=[PPV]FCY & VCRTYP=6 & VCRNUM=[PPV]PNUM & VCRLIN=[PPV]PLIN # Issue 118575.o
  Filter [STJ] Where STOFCY=[PPV]FCY & VCRTYP=6 & VCRNUM=[PPV]PNUM & VCRLIN=[PPV]PLIN & TRSTYP<>29 # Issue 118575.n
  Read [STJ] STJ1 First

  If FILECOST=1
    Call GETPRISTD([PTD]ITMREF,[F:STJ]ECCVALMAJ,[F:STJ]ECCVALMIN,[PTD]PRHFCY,[PTD]RCPDAT,0,1,LPRI,LRET) From STKVAL    # standard cost
    TOTPRI = LPRI
  Endif
  If FILECOST=2 or FILECOST=4
      Call GETPRI([PTD]ITMREF,[F:STJ]ECCVALMAJ,[F:STJ]ECCVALMIN,[PTD]PRHFCY,[PTD]RCPDAT,[STJ]QTYSTU,[STJ]LOT,[STJ]SLO,FILECOST,LPRI,LRET) From STKVAL
      TOTPRI = LPRI
  Endif
  If FILECOST>4
    TOTPRI = [STJ]PRIVAL
  Endif

  If FILECOST=1
    If !LRET & [F:ITC]ITMREF<>"" & [F:ITC]ITCSTRDAT<=[PTD]RCPDAT & [PTD]RCPDAT <=[F:ITC]ITCENDDAT
      [PPV]CSTTOT = TOTPRI
    Else Raz [PPV]CSTTOT
    Endif
  Else
    [PPV]CSTTOT = TOTPRI
  Endif


Else
  [PPV]       = [PND]
  [PPV]PNUM   = [PND]PNHNUM
  [PPV]PLIN   = [PND]PNDLIN
  [PPV]FCY    = [PND]PNHFCY

  # Get the stock journal record
  #Filter [STJ] Where STOFCY=[PPV]FCY & VCRTYP=8 & VCRNUM=[PPV]PNUM & VCRLIN=[PPV]PLIN # Issue 118575.o
  Filter [STJ] Where STOFCY=[PPV]FCY & VCRTYP=8 & VCRNUM=[PPV]PNUM & VCRLIN=[PPV]PLIN & TRSTYP<>29 # Issue 118575.n
  Read [STJ] STJ1 First

  If FILECOST=1
    #Read [STJ] STJ1 First
    Call GETPRISTD([PND]ITMREF,[F:STJ]ECCVALMAJ,[F:STJ]ECCVALMIN,[PND]PNHFCY,[PND]RTNDAT,0,1,LPRI,LRET) From STKVAL    # standard cost
    TOTPRI = LPRI
  Endif
  If FILECOST=2 or FILECOST=4
    #For [STJ]
      #Call GETPRI([PTD]ITMREF,[PTD]PRHFCY,[PTD]RCPDAT,[STJ]QTYSTU,[STJ]LOT,[STJ]SLO,FILECOST,LPRI,LRET) From STKVAL
      Call GETPRI([PND]ITMREF,[F:STJ]ECCVALMAJ,[F:STJ]ECCVALMIN,[PND]PRHFCY,[PND]RTNDAT,[STJ]QTYSTU,[STJ]LOT,[STJ]SLO,FILECOST,LPRI,LRET) From STKVAL
      TOTPRI = LPRI
      #TOTPRI = TOTPRI + LPRI
    #Next
  Endif
  If FILECOST>4
    #Read [STJ] First
    TOTPRI = [STJ]PRIVAL
  Endif

  If FILECOST=1
    If !LRET & [F:ITC]ITMREF<>"" & [F:ITC]ITCSTRDAT<=[PND]RTNDAT & [PND]RTNDAT <=[F:ITC]ITCENDDAT
      #[PPV]CSTTOT = LPRI
      [PPV]CSTTOT = TOTPRI
    Else Raz [PPV]CSTTOT
    Endif
  Else
    [PPV]CSTTOT = TOTPRI
  Endif

Endif

[PPV]BPSNAM = [BPS]BPSNAM
If [POH]CUR <> ""
  [PPV]CUR = [POH]CUR
Elsif [PTD]NETCUR<>""
  [PPV]CUR = [PTD]NETCUR
Else
  [PPV]CUR = [PID]NETCUR
Endif

Filter [STJ]

[PPV]PID = num$(adxpid)

If FORMFLG<>1
  [PPV]NUM    = [PID]NUM
  [PPV]PIDPRI = func STKPRI([PID]NETPRI,[PID]UOM,[PID]BPSNUM)
Endif
  [PPV]NETPRI = func STKPRI([POP]NETPRI,[POQ]UOM,[POQ]BPSNUM)

If RFLAG=1 & [ITM]PUUSTUCOE<>1
  [PPV]NETPRI = func STKPRI([POP]NETPRI,[POQ]UOM,[POQ]BPSNUM)
Endif

#105882.sn
If !RFLAG
    [PPV]QTYSTU = THIS_QTY
Else
    [PPV]QTYSTU = (-1) * THIS_QTY
Endif
#105882.en


Case FORMFLG
  When 1  # Item received, but not invoiced in period.
    [PPV]STKVAR = [PPV]QTYSTU * ([PPV]NETPRI - [PPV]CSTTOT)

  When 2  # Both receipt and invoice within the period.
    [PPV]STKVAR = [PPV]QTYSTU * ([PPV]PIDPRI - [PPV]CSTTOT)

  When 3  # Item not received in period, but invoiced in period.
    [PPV]STKVAR = [PPV]QTYSTU * ([PPV]PIDPRI - [PPV]NETPRI)
Endcase

# If this is subcontracted and the purchase order is on a work order operation, check to
# see if the work order is closed.  If the work order is closed, calculate the variance
# by subtracting the routing price from the invoiced price and multiply by the qty.
# Issue 112754 - 2016-11-28 by SR :Services
#If [ITM]SCPFLG=2 | [ITM]SCSFLG=2
If [ITM]SCPFLG=2 | [POQ]ITMKND=2
  Filter [MFO] Where POHNUM=[POP]POHNUM & POPLIN=[POP]POPLIN & POPSEQ=[POP]POPSEQ
  Read [MFO] First
  Filter [MFG] Where MFGNUM=[MFO]MFGNUM
  Read [MFG] First

  # If closed
  If [MFG]MFGSTA=4
    [PPV]STKVAR = [PPV]QTYSTU * ([PPV]PIDPRI - [MFO]REFPRI)
  Endif

  Filter [MFG]
  Filter [MFO]
Endif

Write [PPV]

If fstat
  Rollback
Else
  Commit
Endif

Return

