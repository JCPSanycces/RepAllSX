#<AdxTL>@(#)2.0.0.0 $Revision$
Subprog GLOBSTOFCY(SITE)
Value Char SITE
Onerrgo ERREUR
Local File ADOPAR [ADP]
Local File ADOVAL [ADW]
Local Char    PARAM(10)
# Livraison des qtés en rupture
Global Libelle GSHTDLV
Call PARAML(SITE,"SHTDLV",PARAM) From ADOVAL
GSHTDLV = val(PARAM)
# Marge alerte péremption jours (pour l'allocation)
#Global Decimal GSMARPER(10)                        # hcb v6per
#Call PARAML(SITE,"MARPER",PARAM) From ADOVAL       # hcb v6per
#GSMARPER = val(PARAM)                              # hcb v6per
End

$ERREUR
Call ERREUR("TRTVENGLOB"-mess(93,100,1)-num$(errl)-errmes$(errn)-errm) From GESECRAN
Resume
