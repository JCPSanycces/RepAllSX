#<AdxTL>@(#)0.0.0.0 $Revision$ Sélection avancée
Local Char PARBOUT(250)(1..4)
Local Char VALBOUT(30)
GACTION = "SELOBJAW" 
PARBOUT(1)="AOB" : # Objet
PARBOUT(2)=""    : # SUPP
PARBOUT(3)="#"   : # Options
PARBOUT(4)=""    : # Traitement
Call SAISIE_CHAR(VALBOUT,PARBOUT,"DSELOBJAW","SELOBJAW","XWSELOBJAW") From GSAISIE
End

##################################################################
$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "DEBUT"      : Gosub DEBUT
 When "FIN"        : Gosub FIN
 When "SETBOUT"    : Gosub SETBOUT
 When "BOUTON"     : Gosub BOUTON
 When "AVANT_OK"   : Gosub AVANT_OK
 When "OK"         : Gosub OK
 When "SEL_TABLE"  : Gosub SEL_TABLE
 When "CHX_TABLE"  : Gosub CHX_TABLE
 When "FIN_TABLE"  : Gosub FIN_TABLE
 When "SEL_LISTE"  : Gosub SEL_LISTE
 When "FIN_LISTE"  : Gosub FIN_LISTE
Endcase
Return

##################################################################
$OUVRE
Local Char     ABREV(GLONAOB), ABREV2(10), OPTIONS(10), SUPP(250)
Local Char     PROGSUB(GDIMFIC)
Local Char     SAVPROGSPE(GDIMFIC) , PROGSPV(GDIMFIC)(1..50) , SAVPROGSPV(GDIMFIC)(1..50)
Local Integer  SAVPSPE , SAVPSPV, PSPV , PSUB , PSTD
Local Char     TRTSELA(GLONADC), PROGOBJ(GDIMFIC)
Local Char     ZONSEL(30), MEMO(GLONAMM)
Local Integer  OUVRE, RELIT, FILT, SAVMXL, NOL
Local Char     VALSUPP(GLONID2)(0..16)

If GPRODUIT=1 : ## GEODE
 If type([M]DEP)>=10
  Local Char SAVDEP(GLONDEP)
  SAVDEP = GDEP
  If dim([M]DEP)>1 : GDEP = [M]DEP(nolign-1)
  Else             : GDEP = [M]DEP
  Endif
 Endif
 If type([M]FCY)>=10
  Local Char SAVFCY(GLONFCY)
  SAVFCY = GFCY 
  If dim([M]FCY)>1 : GFCY = [M]FCY(nolign-1)
  Else             : GFCY = [M]FCY
  Endif
 Endif
Endif

ABREV   = PARAM(1)
SUPP    = PARAM(2)
OPTIONS = PARAM(3)
TRTSELA = PARAM(4)

Call SETPROG(ABREV,PROGOBJ,PROGSUB,SAVPROGSPE,SAVPROGSPV,PSTD,PSUB,SAVPSPE,SAVPSPV) From CONTOBJ
If !PSTD : FIN = 1 : Return : Endif

If TYPARG<>1
 FIN = 1 : Return : # Sélection avancée sur zone alpha uniquement
Endif

Onerrgo ERREUR From CONTROLE
If clalev([ATB])=0 : Local File ATABLE  [ATB] : Endif
If clalev([ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([AMP])=0 : Local File AMSKPAR [AMP] : Endif
If clalev([AOT])=0 : Local File AOBJTAB [AOT] : Endif
If clalev([AOL])=0 : Local File AOBJLST [AOL] : Endif
Gosub NOMFIC From =PROGOBJ
Read [ATB]CODFIC = NOMFIC
I = instr(1,OPTIONS,"$")
If I
 OUVRE = 1
 OPTIONS = left$(OPTIONS,I-1)+right$(OPTIONS,I+1)
Endif
I = instr(1,OPTIONS,"#")
If I
 FILT = 0
Else
 FILT = 1
Endif

If find(ABREV,GABRCPT(1..GNBTABCPT)) & GDOSCPT<>""
 If NOMFIC=""
  GERR = 1 : GMESSAGE = ABREV-mess(11,123,1) : # Sélection non disponible
  GERREUR = 1
 Else
  If clalev([F:ACC]) : Close Local File [ACC] : Endif
  If clalev([F:ATX]) : Close Local File [ATX] : Endif 
  Local File =GTABCPT+"ATEXTE" [ATX] : # Pour avoir les bons textes dans les titres de colonnes
  Local File =GTABCPT+"ACCES"  [ACC] : # Pour le link dans OUVRE_LISTE : même base
  Local File =GTABCPT+NOMFIC
 Endif
Else
 If OUVRE | evalue("clalev([F:"+ABFIC+"])")=0
  If NOMFIC=""
   GERR = 1 : GMESSAGE = ABREV-mess(11,123,1) : # Sélection non disponible
   GERREUR = 1
  Else
   Gosub OUVFIC From =PROGOBJ
   Gosub OUVFIC_LISTE From =PROGOBJ
  Endif
  RELIT = 0
 Else
  RELIT = 1
 Endif
Endif
Onerrgo
If GERREUR : GERREUR = 0 : FIN = 1 : Return : Endif

Onerrgo CHUT From CONTROLE
If !clalev([ATZ]) : Local File ATABZON [ATZ] : Endif
If !clalev([ATY]) : Local File ATYPE   [ATY] : Endif
If !clalev([ATX]) : Local File ATEXTE  [ATX] : Endif
Onerrgo
If GERREUR : GERREUR=0 : Endif

Gosub DEFAUT From =PROGOBJ
Gosub SETCLE From =PROGOBJ
Gosub OUVRE_LISTE From =PROGOBJ
Gosub TIT From =PROGOBJ
If dim(CLEVALEUR)>0 : ## GEODE
 Call SUPPN(SUPP,VALSUPP) From CONTOBJ
Endif
Return

##################################################################
$DEBUT
NOL = nolign-1
MEMO = ABREV+"~sel2"
Gosub ACTION_SEL : # Appel action DEBUT dans le =TRTSELA
Raz [M:SOB]
Gosub PARMSK
For I=0 To dim([M:SOB]FMT)-1
 [M:SOB]FMT(I) = "Kf:15X"
Next I
I = 0
If dim([L]CLEVALEUR)>0 : ## GEODE
 If [L]CLEFCY<>"" & GFCY="" & !find("[F:"+ABFIC+"]"+[L]CLEFCY,[L]SELEXP(1..NBSEL))
  [M:SOB]ZONSEL(I)  = [L]CLEFCY
  [M:SOB]ZONE(I)    = "[F:"+ABFIC+"]"+[L]CLEFCY
  [M:SOB]LIBZONE(I) = mess(1,310,1) : # Site
  [M:SOB]OPE(I)     = 1
  [M:SOB]FMT(I)     = "K:"+num$(GLONFCY)+"X"
  [M:SOB]TYP(I)     = 7
  [M:SOB]TBL(I)     = NOMFIC
  Call TYPX3([M:SOB]TYP(I),[M:SOB]TYPX3(I))
  I+=1
 Endif
 If [L]CLEDEP<>"" & GDEP="" & !find("[F:"+ABFIC+"]"+[L]CLEDEP,[L]SELEXP(1..NBSEL))
  [M:SOB]ZONSEL(I)  = [L]CLEDEP
  [M:SOB]ZONE(I)    = "[F:"+ABFIC+"]"+[L]CLEDEP
  [M:SOB]LIBZONE(I) = mess(2,310,1) : # Déposant
  [M:SOB]OPE(I)     = 1
  [M:SOB]FMT(I)     = "K:"+num$(GLONDEP)+"X"
  [M:SOB]TYP(I)     = 7
  [M:SOB]TBL(I)     = NOMFIC
  Call TYPX3([M:SOB]TYP(I),[M:SOB]TYPX3(I))
  I+=1
 Endif
Endif

For J=1 To NBSEL
 OK = 1
 If dim([L]SELEXP)>0 & SELEXP(J)<>""
  OK = 0
 Endif
 If OK
  [M:SOB]ZONE(I)    = SELZON(J)
  [M:SOB]LIBZONE(I) = SELLIB(J)
  [M:SOB]OPE(I)     = 1
  If left$(SELFMT(J),2)="LA"
   [M:SOB]FMT(I)     = "Nzf:15#"
   [M:SOB]NOLIB(I)   = val(right$(SELFMT(J),3))
  Else
   [M:SOB]FMT(I)     = SELFMT(J)
  Endif
  [M:SOB]TYP(I)      = SELTYP(J)
  Call TYPX3([M:SOB]TYP(I),[M:SOB]TYPX3(I))
  ZONSEL = SELZON(J)
  K = instr(1,ZONSEL,"]")
  If K
   ABREV2  = seg$(ZONSEL,2,K-1)
   If left$(ABREV2,2)="F:" : ABREV2 = right$(ABREV2,3) : Endif
   Read [ATB]ABRFIC = ABREV2
   [M:SOB]TBL(I) = [F:ATB]CODFIC
   ZONSEL = right$(ZONSEL,K+1)
  Else
   ZONSEL = SELZON(J)
   [M:SOB]TBL(I) = NOMFIC
  Endif
  Read [ATZ]CODZONE=[M:SOB]TBL(I);ZONSEL
  If !fstat
   Case [F:ATZ]CODTYP
    When "ADI"
     Read [AMP]CODPAR=2;[M:SOB]TBL(I);ZONSEL;"ADI"
     If !fstat
      [M:SOB]SUP(I) = [F:AMP]VALPAR
      If left$([M:SOB]SUP(I),1)="'" or left$([M:SOB]SUP(I),1)='"'
       [M:SOB]SUP(I) = seg$([M:SOB]SUP(I),2,len([M:SOB]SUP(I))-1)
      Endif
      [M:SOB]SUP(I) = num$(val([M:SOB]SUP(I)))
     Endif
   Endcase 
  Endif
  If dim([L]CLEVALEUR)>0 : ## GEODE
   If ZONSEL=CLEVALEUR
    [M:SOB]OPE(I) = 5
    [M:SOB]VALEUR(I) = VALEUR
   Else
    K=find(ZONSEL,CLESUPP)
    If K & VALSUPP(K-1)<>""
     [M:SOB]OPE(I)    = 2
     [M:SOB]VALEUR(I) = VALSUPP(K-1)
    Elsif dim(VALZON)>0
     [M:SOB]OPE(I)    = 5
     [M:SOB]VALEUR(I) = VALZON(J)
    Endif
   Endif
  Else
   If ZONSEL=CLEPRIM
    [M:SOB]OPE(I)    = 5
    [M:SOB]VALEUR(I) = VALEUR
   Elsif CLESEC<>"" & ZONSEL=CLESEC & [L]SUPP<>""
    [M:SOB]OPE(I)    = 2
    [M:SOB]VALEUR(I) = [L]SUPP
   Elsif dim(VALZON)>0
    [M:SOB]OPE(I)    = 5
    [M:SOB]VALEUR(I) = VALZON(J)
   Endif
  Endif

  If SELZON(J)="[F:ATX]TEXTE"
   Read [ATB]CODFIC = NOMFIC
   [M:SOB]ZONSEL(I) = [F:ATB]INTIT
   [M:SOB]TBL(I) = NOMFIC
  Else
   [M:SOB]ZONSEL(I) = ZONSEL
   If [M:SOB]TBL(I)<>"" & [M:SOB]ZONSEL(I)<>""
    Read [ATZ]CODZONE = [M:SOB]TBL(I);[M:SOB]ZONSEL(I)
    If !fstat
     Read [ATY]CODTYP = [F:ATZ]CODTYP
     If [F:ATY]OBJLIEN<>""
      [M:SOB]TYPX3(I) = [F:ATY]CODTYP
     Endif
    Endif
   Endif
  Endif

  If [M:SOB]OPE(I)<>1
   Call CHARGE([M:SOB]VALEUR(I),[M:SOB]TYPX3(I),[M:SOB]NOLIB(I),0,[M:SOB]VALINT(I)) From FMTVAR
  Endif

  I+=1
 Endif
Next J
[M:SOB]NBZONE = I
[M:SOB]ORDTRI = SELORD
[M:SOB]NBREC  = GNBSEL
If ABREV="ADI" : # 116510
 For I=0 To [M:SOB]NBZONE-1
  For II=0 To [M:SOB]NBZONE-1       
   If [M:SOB]TBL(I)="ATABDIV" and instr(1,[M:SOB]ZONE(I),"CODE")>0
    If [M:SOB]TBL(II)="ATABDIV" and instr(1,[M:SOB]ZONE(II),"NUMTAB")>0
     [M:SOB]NOLIB(I) = val([M:SOB]VALEUR(II))
     Break
    Endif
   Endif
  Next
 Next
Endif
Affzo [SOB]
Return

$PARMSK
[M:SOB]NOMFIC = [L]NOMFIC
[M:SOB]OBJET = [L]ABREV
[M:SOB]NBTBL=0
For [AOT]ABREV Where ABREV=[L]ABREV & TABLIEN<>""
 [M:SOB]NBTBL += 1
 [M:SOB]TBTBL([M:SOB]NBTBL) = [F:AOT]TABFIC
Next
Return

Subprog TYPX3(TYP1,TYP2)
Value    Integer TYP1
Variable Char    TYP2()
Case TYP1
 When 1 : TYP2 = "M"
 When 2 : TYP2 = "C"
 When 3 : TYP2 = "L"
 When 4 : TYP2 = "DCB"
 When 7 : TYP2 = "A"
 When 8 : TYP2 = "D"
Endcase
End

#######################################################
$FIN
## GEODE
If dim(SAVFCY)>0 : GFCY=SAVFCY : Endif
If dim(SAVDEP)>0 : GDEP=SAVDEP : Endif
##
Gosub ACTION_SEL
If GSTATUT<>GSTAOK : mkstat=2 : Endif
Return

#######################################################
$ACTION_SEL
SAVPSPE    = PSPE
SAVPROGSPE = PROGSPE
SAVPSPV    = PSPV
For I=1 To min(dim(PROGSPV),dim(SAVPROGSPV))
 SAVPROGSPV(I) = PROGSPV(I)
Next I
Call SETPROG(ABREV,PROGOBJ,PROGSUB,PROGSPE,PROGSPV,PSTD,PSUB,PSPE,PSPV) From CONTOBJ
If PSTD
 If find(ABREV,GABRCPT(1..GNBTABCPT)) & GDOSCPT<>"" & !GCPT130
  If TRTSELA<>"" & TRTSELA<>"SELOBJAW"
   Gosub ACTION From =GTABCPT+TRTSELA
  Endif
 Else
  If TRTSELA<>"" & TRTSELA<>"SELOBJAW"
   Gosub ACTION From =TRTSELA
  Endif
 Endif
Endif
PSPE    = SAVPSPE
PROGSPE = SAVPROGSPE
PSPV    = SAVPSPV
For I=1 To min(dim(PROGSPV),dim(SAVPROGSPV))
 PROGSPV(I) =  SAVPROGSPV(I)
Next I
Return

#######################################################
$SETBOUT
If [L]MEMO="" : # pas de mémo
 Call VIREBOUT(CHMEN,"MRE") From GOBJET
Endif
Return

#######################################################
$BOUTON
Case BOUT
 When "R" : # Rappel mémo
  Gosub PARMSK
  If [M:SOB]ZONTRI<>""
   I=find([M:SOB]ZONTRI,[M:SOB]ZONE(0..[M:SOB]NBZONE-1))
   [M:SOB]LIBTRI = [M:SOB]LIBZONE(I-1)
  Else
   [M:SOB]LIBTRI = ""
  Endif
  Affzo [SOB]
Endcase
Return

#######################################################
$AVANT_OK
[M:SOB]CLE     = VALEUR
[M:SOB]OBJET   = [L]ABREV
[M:SOB]SUPP    = [L]SUPP
[M:SOB]OPTIONS = [L]OPTIONS
Return

#######################################################
$OK
If mkstat=2 : FIN = 0 : Return : Endif
VALEUR = VALBOUT
Return

#######################################################
$SEL_TABLE
Local Integer I, J, K, ICRITERE, ADDCOL
Local Char    ZONSEL(30), SUBCRIT(80)

VALEUR  = [M:SOB]CLE
OBJET   = [M:SOB]OBJET
OPTIONS = [M:SOB]OPTIONS
SUPP    = [M:SOB]SUPP
# ORDRE géré dans $CHX_TABLE
SENS    = [M:SOB]ORDTRI
SAVMXL  = adxmxl
adxmxl  = [M:SOB]NBREC
FIXSUPP = 0

# Critères saisis dans la fenêtre
For I=0 To [M:SOB]NBZONE-1
 If [M:SOB]OPE(I)>1
  Case [M:SOB]TYP(I)
   When 1,2,3,4,5,6 : # Numérique
    ZONSEL = [M:SOB]VALINT(I)
   When 7 : # Alpha
    ZONSEL = '"'+[M:SOB]VALINT(I)+'"'
   When 8 : # Date
    If gdat$([M:SOB]VALINT(I))=[0/0/0]
     ZONSEL = "[0/0/0]"
    Else
     ZONSEL = "["+format$(GFMD,gdat$([M:SOB]VALINT(I)))+"]"
    Endif
  Endcase
  Case [M:SOB]OPE(I)
   When 2 : SUBCRIT = [M:SOB]ZONE(I)+"="+ZONSEL
   When 3 : SUBCRIT = [M:SOB]ZONE(I)+"<>"+ZONSEL
   When 4 : SUBCRIT = [M:SOB]ZONE(I)+">"+ZONSEL
   When 5 : SUBCRIT = [M:SOB]ZONE(I)+">="+ZONSEL
   When 6 : SUBCRIT = [M:SOB]ZONE(I)+"<"+ZONSEL
   When 7 : SUBCRIT = [M:SOB]ZONE(I)+"<="+ZONSEL
   When 8
    ZONSEL = [M:SOB]VALINT(I)
    J = instr(1,ZONSEL,"*")
    K = instr(1,ZONSEL,"?")
    If J or K
     If K or J<>len(ZONSEL)
      If !instr(1,[M:SOB]ZONE(I),"(")
       SUBCRIT = 'pat('+[M:SOB]ZONE(I)+'(0),"'+ZONSEL+'")=1'
      Else
       SUBCRIT = 'pat('+[M:SOB]ZONE(I)+',"'+ZONSEL+'")=1'
      Endif
     Else
      SUBCRIT = ""
     Endif
     If     J & K : J = min(J,K)
     Elsif !J & K : J = K
     Endif
     If J>1
      If SUBCRIT<>"" : SUBCRIT -= '&' : Endif
      SUBCRIT -= [M:SOB]ZONE(I)+'>="'+left$(ZONSEL,J-1)+'"'
      SUBCRIT -= '&'
      SUBCRIT -= [M:SOB]ZONE(I)+'<"'+left$(ZONSEL,J-2)+chr$(ascii(mid$(ZONSEL,J-1,1))+1)+'"'
     Endif
    Else
     SUBCRIT = [M:SOB]ZONE(I)+'="'+ZONSEL+'"'
    Endif
  Endcase
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",SUBCRIT,"&") From GOBJSUB
 Endif
Next I
Return

#######################################################
$CHX_TABLE
Case COUZON
 When "OK"
  If !ADDCOL
   If [M:SOB]ZONTRI<>"" : ORDRE=[M:SOB]ZONTRI
   Else                 : ORDRE=""
   Endif
   If dim([L]CLEVALEUR)>0 : ## GEODE
    If [L]CLEFCY<>"" & find("[F:"+ABFIC+"]"+[L]CLEFCY,COL(1..NBCOL)) 
&                    & "[F:"+ABFIC+"]"+[L]CLEFCY<>[M:SOB]ZONTRI
     ORDRE+=";[F:"+ABFIC+"]"+CLEFCY
    Endif
    If [L]CLEDEP<>"" & find("[F:"+ABFIC+"]"+[L]CLEDEP,COL(1..NBCOL))
&                    & "[F:"+ABFIC+"]"+[L]CLEDEP<>[M:SOB]ZONTRI
     ORDRE+=";[F:"+ABFIC+"]"+CLEDEP
    Endif
    For I=0 To dim(CLESUPP)-1
     If CLESUPP(I)<>"" & "[F:"+ABFIC+"]"+CLESUPP(I)<>[M:SOB]ZONTRI
      ORDRE+=";[F:"+ABFIC+"]"+CLESUPP(I)
     Endif
    Next I
    If "[F:"+ABFIC+"]"+[L]CLEVALEUR<>[M:SOB]ZONTRI
     ORDRE+=";[F:"+ABFIC+"]"+CLEVALEUR
    Endif
   Else
    If [L]CLEPRIM<>[M:SOB]ZONTRI
     ORDRE+=";[F:"+ABFIC+"]"+CLEPRIM
    Endif
    If CLESEC<>"" & "[F:"+ABFIC+"]"+[L]CLESEC<>[M:SOB]ZONTRI
     ORDRE+=";[F:"+ABFIC+"]"+CLESEC
    Endif
   Endif
   If left$(ORDRE,1)=";" : ORDRE=right$(ORDRE,2) : Endif

   For I=0 To [M:SOB]NBZONE-1
    If NBCOL>=dim([L]COL) : Break : Endif
    If I=0
     If clalev([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
     If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
     If clalev([F:AOL])=0 : Local File AOBJLST [AOL] : Endif
    Endif
    Read [ATB]CODFIC  = [M:SOB]TBL(I)
    SUBCRIT="[F:"+[F:ATB]ABRFIC+"]"+[M:SOB]ZONSEL(I)
    Read [ATZ]CODZONE = [M:SOB]TBL(I);[M:SOB]ZONSEL(I)
    If [F:ATZ]NOLIB<>0 
     SUBCRIT="mess("+SUBCRIT+","+num$([F:ATZ]NOLIB)+",1)"
    Endif
    K = find(SUBCRIT,COL(1..NBCOL))
    If !K & [M:SOB]OBJET<>""
     Read [AOL]AOL0=[M:SOB]OBJET
     If !fstat
      For J=1 To [F:AOL]NBSEL
       If [M:SOB]TBL(I)=[F:AOL]SELFIC(J) & [M:SOB]ZONSEL(I)=[F:AOL]SELZON(J)
        K = 1 : Break
       Endif
      Next J
     Endif
    Endif
    If !K
     NBCOL+=1 : TIT(NBCOL)=[M:SOB]LIBZONE(I)
     COL(NBCOL)=SUBCRIT
    Endif
   Next I

   ADDCOL=1
  Endif
Endcase
Return

#######################################################
$FIN_TABLE
adxmxl = SAVMXL
Return

#######################################################
$SEL_LISTE
Case COUZON
 When "TBL" : # Table
  Read [ATB]CODFIC = [M]NOMFIC
  NBTEX += 1
  TEX(NBTEX) = [F:ATB]CODFIC
  Call TEXTE([F:ATB]INTITFIC,TEXTE(NBTEX)) From OBJDIV
  TEXTE(NBTEX) = TEX(NBTEX)-TEXTE(NBTEX)
  For I=1 To [M]NBTBL
   Read [ATB]CODFIC = [M]TBTBL(I)
   NBTEX += 1
   TEX(NBTEX) = [F:ATB]CODFIC
   Call TEXTE([F:ATB]INTITFIC,TEXTE(NBTEX)) From OBJDIV
   TEXTE(NBTEX) = TEX(NBTEX)-TEXTE(NBTEX)
  Next I

 When "TRI" : # Critère de tri
  Local Char OVALEUR(30) : OVALEUR=VALEUR
  I = find([M:SOB]ZONTRI,[M:SOB]ZONE(0..[M:SOB]NBZONE-1))
  If I>0 : VALEUR=num$(I) : Else VALEUR="1" : Endif
  TIT=mess(182,133,1) : # Critères
  For I=1 To [M]NBZONE
   NBTEX += 1
   TEX(NBTEX) = num$(NBTEX)
   TEXTE(NBTEX) = [M]LIBZONE(I-1)
  Next I
Endcase
Return

#######################################################
$FIN_LISTE
Case COUZON
 When "TRI" : # Critère de tri
  If mkstat 
   VALEUR=OVALEUR
  Else
   I=val(VALEUR)
   [M:SOB]ZONTRI=[M:SOB]ZONE(I-1)
   VALEUR = TEXTE(I)
  Endif
Endcase
Return

#######################################################
## Etiquettes de l'écran SELOBJAW
#######################################################

Subprog AV_VALEUR(VALEUR)
Variable Char    VALEUR()
If [M]OPE(nolign-1)=1 : mkstat = 1 : Endif
End

Subprog C_VALEUR(VALEUR)
Variable Char    VALEUR()
If [M:SOB]TYP(nolign-1)=7 & instr(1,VALEUR,'"') : # Alpha
 GMESSAGE = '" :'-mess(94,123,1) : mkstat = 2 
 # Caractère interdit
Endif
End
 
Subprog C_ZONSEL(VALEUR)
Variable Char    VALEUR()
Local Integer NOL : NOL = nolign-1
Local Integer K , DIME
Local Char    ZONE(15)
Local Char    FORMA(30) , CAR(1) , OPTION(10)
Local Integer NOLIB , LONG
If !clalev([ATB]) : Local File ATABLE  [ATB] : Endif
If !clalev([ATZ]) : Local File ATABZON [ATZ] : Endif
If !clalev([ATY]) : Local File ATYPE   [ATY] : Endif
If !clalev([ACV]) : Local File ACTIV   [ACV] : Endif
VALEUR = toupper(VALEUR)
K = instr(1,VALEUR,"(")
If K
 ZONE = left$(VALEUR,K-1)
 DIME = val(right$(VALEUR,K+1))
Else
 ZONE = VALEUR
 DIME = 0
Endif
Read [ATZ]CODZONE = [M]TBL(NOL);ZONE
If fstat
 GMESSAGE = mess(9,124,1) : mkstat = 2 : End
# Champ inexistant
Endif
Call TEXTE([F:ATZ]NOCOURT,[M]LIBZONE(NOL)) From OBJDIV
If [F:ATZ]CODACT<>""
 Read [ACV]CODACT = [F:ATZ]CODACT
 DIMMAX = [F:ACV]DIME
Else
 DIMMAX = [F:ATZ]DIME
Endif
If (DIME<>0 | DIMMAX<>0) & DIME>DIMMAX-1
 GMESSAGE = mess(46,105,1) : # Indice incorrect
 mkstat = 2 : End
Endif
VALEUR = ZONE
If DIME>0
 VALEUR += "("+num$(DIME)+")"
Endif
Read [ATB]CODFIC = [M]TBL(NOL)
Read [ATY]CODTYP = [F:ATZ]CODTYP
Read [AOL]AOL0   = [M]OBJET
NOLIB = 0
[M]SUP(NOL) = ""
Case [ATY]CODTYP
 When "ATX"
  If ZONE=[F:ATB]INTIT
   [M]FMT(NOL)   = "K:30X"
   [M]TYP(NOL)   = 7
   [M]NOLIB(NOL) = 0
   [M]ZONE(NOL)  = "[F:ATX]TEXTE"
  Else
   [M]FMT(NOL)   = "N:6#"
   [M]TYP(NOL)   = 4
   [M]NOLIB(NOL) = 0
   [M]ZONE(NOL)  = ZONE
   # Lien automatique non géré
   GMESSAGE = ZONE-":"-mess(133,141,1) : GERR = 2 : End
  Endif
 When "AXX","AX1","AX2","AX3"
  GMESSAGE = ZONE-":"-mess(198,139,1) : mkstat = 2 : End
  # Type de champ non géré
 When Default
  Case [F:ATY]TYPTYP
   When 1
    If [F:ATY]NOLIB<>0
     NOLIB = [F:ATY]NOLIB
    Else
     NOLIB = [F:ATZ]NOLIB
    Endif
    FORMA = "N:2#"
   When 7
    If [F:ATY]LNGTYP<>0
     LONG = [F:ATY]LNGTYP
    Else
     LONG = [F:ATZ]LONG
    Endif
    If LONG>15 : LONG = 15 : Endif
    OPTION = [F:ATY]OPTION+[F:ATZ]OPTION
    If instr(1,OPTION,"C")
     CAR = "c"
    Elsif instr(1,OPTION,"A")
     CAR = "B"
    Else
     CAR = "X"
    Endif
    FORMA = "K:"+num$(LONG)+CAR
   When 8
    FORMA = "D:"+GFMDAT
   When 2,3
    If [F:ATY]LNGTYP<>0
     LONG = [F:ATY]LNGTYP
    Else
     LONG = [F:ATZ]LONG
    Endif
    FORMA = "N:"+num$(LONG)+"#"
   When 4
    If [F:ATY]LNGTYP<>0
     LONG = [F:ATY]LNGTYP
    Else
     LONG = [F:ATZ]LONG
    Endif
    FORMA = "N:"+num$(LONG)+"#"
  Endcase
  If [F:ATY]CODTYP="ADI"
   Read [AMP]CODPAR=2;[M]TBL(NOL);ZONE;"ADI"
   If !fstat
    [M]SUP(NOL) = [F:AMP]VALPAR
    If left$([M]SUP(NOL),1)="'" or left$([M]SUP(NOL),1)='"'
     [M]SUP(NOL) = seg$([M]SUP(NOL),2,len([M]SUP(NOL))-1)
    Endif
    [M]SUP(NOL) = num$(val([M]SUP(NOL)))
   Endif
  Endif
  [M]FMT(NOL)   = FORMA
  [M]TYP(NOL)   = [F:ATY]TYPTYP
  Call TYPX3([M]TYP(NOL),[M]TYPX3(NOL))
  If [F:ATY]OBJLIEN<>""
   [M]TYPX3(NOL) = [F:ATY]CODTYP
  Endif
  [M]NOLIB(NOL) = NOLIB
  [M]ZONE(NOL)  = "[F:"+[F:ATB]ABRFIC+"]"+VALEUR
Endcase
End

Subprog AS_TBL(VALEUR)
Variable Char    VALEUR()
If [M]NBTBL=0
 VALEUR = [M]NOMFIC : mkstat=2 
Elsif VALEUR=""
 If indice=0
  VALEUR = [M]NOMFIC
 Else
  VALEUR = [M]TBL(indice-1)
 Endif
Endif
End

Subprog C_TBL(VALEUR)
Variable Char    VALEUR()
If !find(VALEUR,[M]NOMFIC,[M]TBTBL(1..[M]NBTBL))
 GMESSAGE = mess(5,124,1) : mkstat = 2 : End : # Table non accessible
Endif
End

Subprog C_LIBTRI(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : [M:SOB]ZONTRI="" : End : Endif
Local Integer VALNUM, I, J
VALNUM = val(VALEUR)
If VALEUR<>"" & (left$(VALEUR,1)<'0' or left$(VALEUR,1)>'9')
 VALNUM = 0
 For I=len(VALEUR) To 1 Step -1
  For J=0 To [M]NBZONE-1
   If toupper(left$(VALEUR,I))=toupper(left$([M:SOB]LIBZONE(J),I))
    VALNUM = J+1 : Break 2
   Endif
  Next J
 Next I
 If !VALNUM : VALNUM = 1 : Endif
Elsif VALNUM<1                  : VALNUM = 1
Elsif VALNUM>[M:SOB]NBZONE      : VALNUM = [M:SOB]NBZONE
Endif
VALEUR = [M:SOB]LIBZONE(VALNUM-1)
[M:SOB]ZONTRI=[M:SOB]ZONE(VALNUM-1)
End




