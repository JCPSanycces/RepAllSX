##########################################################################################################
# Gestion du masque HDKAGD0, HDKAGD1, HDKAGD2
##########################################################################################################
##########################################################################################################
Subprog AS_NBLIGSRE
  If nolign > 0 Then
    [M:HDK0]HDKSRE = [M:HDK1]SRENUM(nolign-1)
    [M:HDK0]HDKSALFCY = [M:HDK1]SALFCY(nolign-1)
    [M:HDK0]HDKBPR = [M:HDK1]SREBPC(nolign-1)
    [M:HDK0]HDKCCN = [M:HDK1]SRECCN(nolign-1)
  Endif
End

##########################################################################################################
Subprog IB_NBLIGSRE

  Raz GBOUT2
  #Droit de cloturer une demande
  If GAUSHDKG = 2 Then
    Call TEXTE(16102, GBOUT2) From OBJDIV      #Clôturer la demande
  Endif
  Raz GBOUT3
  Raz GBOUT4
  #Droit d'affectation
  #Cas d'une queue
  If [M:HDK1]SREASS(nolign-1) = 3 or [M:HDK1]SREASS(nolign-1) = 1 Then
    GBOUT3 = mess(316,196,1)   # M'affecter la demande
    GBOUT4 = mess(317,196,1)   # Affecter la demande à
  Endif
  If [M:HDK1]SREASS = 2 Then
    If [M:HDK1]SREDET(nolign-1) <> GUSER Then
      GBOUT3 = mess(316,196,1) # M'affecter la demande
    Endif
    GBOUT4 = mess(317,196,1)   # Affecter la demande à
  Endif
  #Historique Tiers
  If [M:HDK1]SREBPC(nolign-1) = "" Then
    Raz GBOUT7
  Else
    Call TEXTE(17626, GBOUT7) From OBJDIV
  Endif
  #Historique Interlocuteur
  If [M:HDK1]SRECCN(nolign-1) = "" Then
    Raz GBOUT8
  Else
    Call TEXTE(17627, GBOUT8) From OBJDIV
  Endif
  # FGR 06/05/2009 : Historique des escalades
  If [M:HDK1]SREESCCOD(nolign-1) = "" Then
    Raz GBOUT11
  Endif
End

##########################################################################################################
Subprog B1_NBLIGSRE
Local Char SZREFITN
  ## Action GOBJETC1
Local Char PARMSK(250)(1..20), SAVACT(20)

  SAVACT = GACTION
  GACTION = "GOBJETC1"
  Call OBJET_CHAR([M:HDK1]SRENUM(nolign-1),"SRE","") From GOBJET
  GACTION = SAVACT
  #
  #On recharge l'agenda
  Gosub ONLOAD From TRTHDKAGD
End

##########################################################################################################
Subprog B2_NBLIGSRE
Local Char SZREFITN
  ## Action GOBJETC1
Local Char PARMSK(250)(1..20), SAVACT(20)

  If [M:HDK1]SRENUM(nolign-1) = "" Then
    #La demande de service pour laquelle l'intervention est demandée n'a pas pu être identifiée.
    GMESSAGE = mess(416,182,1)
    GERR = 2
    End
  Endif
  Read [SRE]SRE0=[M:HDK1]SRENUM(nolign-1)
  If fstat Then
    #La demande de service pour laquelle l'intervention est demandée n'a pas pu être identifiée.
    GMESSAGE = mess(416,182,1)
  Else
    If [F:SRE]SREASS <> 2 Then
      #Une intervention ne peut être créé que sur une demande de service affectée à un collaborateur.
      GMESSAGE = mess(497,177,1)
      GERR = 2
    Endif
  Endif
  #On veut créer une intervention
  GBCRMFLGNEW = 1
  #
  SAVACT = GACTION
  GACTION = "GOBJETC1"
  Call OBJET_CHAR(SZREFITN,"ITN","") From GOBJET
  GACTION = SAVACT
  #
  #On recharge l'agenda
  Gosub ONLOAD From TRTHDKAGD
End

##########################################################################################################
Subprog B3_NBLIGSRE
  #M'affecter la demande 
  #Affecte la demande de service.à l'utilisateur connecté
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  Readlock [SRE]SRE0=[M:HDK1]SRENUM(nolign-1)
  If fstat Then
    GMESSAGE = mess(318,196,1) #L'affectation n'a pu être effectuée. Transaction abandonnée
    GERR = 1
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [SRE]
  #Ajoute un historique d'état de la demande
  Call CREHISTO([M:HDK1]SRENUM(nolign-1), [F:SRE]SRESAT, GUSER, 2,IERRINF,ICHAPTER,IBRETOUR) From SUBSREB1
  If IBRETOUR <> 0 Then
    [F:SRE]SREASS = 2
    [F:SRE]SREDATASS = date$
    [F:SRE]SREHOUASS = left$(time$, 2) + mid$(time$, 4, 2)
    [F:SRE]SREDET = GUSER
    Rewrite [SRE]
    If fstat Then
      #L'affectation n'a pu être effectuée. Transaction abandonnée
      IERRINF = 318
      ICHAPTER = 196
      IBRETOUR = 0
      Call FSTA("SRE") From GLOCK
      GOK = 0
    Endif
  Endif
  If IBRETOUR = 0 Then
    Rollback
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 1
    End
  Else
    Commit
  Endif
  Gosub LOAD_SRE From TRTHDKAGD
End

##########################################################################################################
Subprog B5_NBLIGSRE
Local Char SZREFITN
## Action GOBJETC1
Local Char PARMSK(250)(1..20), SAVACT(20)

  #Nouvelle intervention
  If [M:HDK1]SRENUM(nolign-1) = "" Then
    #La demande de service pour laquelle l'intervention est demandée n'a pas pu être identifiée.
    GMESSAGE = mess(416,182,1)
    GERR = 2
    End
  Endif
  Read [SRE]SRE0=[M:HDK1]SRENUM(nolign-1)
  If fstat Then
    #La demande de service pour laquelle l'intervention est demandée n'a pas pu être identifiée.
    GMESSAGE = mess(416,182,1)
  Else
    If [F:SRE]SREASS <> 2 Then
      #Une intervention ne peut être créé que sur une demande de service affectée à un collaborateur.
      GMESSAGE = mess(497,177,1)
      GERR = 2
    Endif
  Endif
  #On veut créer une intervention
  GBCRMFLGNEW = 1
  [M:HDK0]HDKSRE = [M:HDK1]SRENUM(nolign-1)
  #
  SAVACT = GACTION
  GACTION = "GOBJETC1"
  Call OBJET_CHAR(SZREFITN,"ITN","") From GOBJET
  GACTION = SAVACT
  #
  #On recharge l'agenda
  Gosub ONLOAD From TRTHDKAGD
End

##########################################################################################################
Subprog AS_NBLIGITN

  If nolign > 0 Then
    [M:HDK0]HDKSRE = [M:HDK2]SRENUM(nolign-1)
    [M:HDK0]HDKSALFCY = [M:HDK2]SALFCY(nolign-1)
    [M:HDK0]HDKBPR = [M:HDK2]BPC(nolign-1)
    [M:HDK0]HDKCCN = [M:HDK2]CCN(nolign-1)
  Endif
End

##########################################################################################################
Subprog IB_NBLIGITN
  #Historique Tiers
  If [M:HDK2]BPC(nolign-1) = "" Then
    Raz GBOUT7
  Else
    Call TEXTE(17626, GBOUT7) From OBJDIV
  Endif
  #Historique Interlocuteur
  If [M:HDK2]CCN(nolign-1) = "" Then
    Raz GBOUT8
  Else
    Call TEXTE(17627, GBOUT8) From OBJDIV
  Endif
End

