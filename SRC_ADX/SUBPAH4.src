#<AdxTL>@(#)8.0.0.0 $Revision$
GBIDI1 = 1
Call OBJET("PAH",GBIDC1,GBIDC2) From GOBJET
End


$ACTION
Case GACTION
 When "PAYPTHCRE"
  Case ACTION
   When "SEL_TABLE" : Gosub SEL_LISTE
  Endcase
 When Default
  Case ACTION
   When "INIT"      : Gosub INIT
   When "EXEC"      : Gosub EXEC
  Endcase 
Endcase
Return


#####
$INIT
#####
Local Integer TYP         : TYP=val(PARAM(1))
Local Char    NUM(20)     : NUM=PARAM(2)
Return

#####
$EXEC
##### 
Call PAYTRA(TYP,NUM)
TRA=9
Return


#################################################
## Zoom sur les règlements générés             ##
#################################################
$SEL_LISTE
Onerrgo ERREUR From CONTROLE
If clalev([F:PYH])=0 : Local File PAYMENTH  [PYH]  : Endif
Onerrgo
If GERREUR : GERREUR=0 : OK=0 : Return : Endif

Local Integer NBTEX
Local Char    TEX1(20)(1..[M:PAH1]NBLIG), TEX2(30)(1..[M:PAH1]NBLIG)
Local Integer TEX3(1..[M:PAH1]NBLIG)

# On présente les dernières pièces générées en premier GH 02/12/99
Filter [PYH] Where SNS = val(PARAM(1)) & NUMORD = PARAM(2) Order By NUM Desc
For [PYH]
 NBTEX += 1 : TEX3(NBTEX) = NBTEX
 TEX1(NBTEX) = [F:PYH]NUM
 TEX2(NBTEX) = mess([F:PYH]STA,689,1)
Next
Filter [PYH]

If NBTEX
 If clalev([F:ZZZ]) : Close Local File [ZZZ] : Endif

 ORDRE  = "NUM"
 Local File (Char AA(30), Char BB(30), Integer NUM) 
&      From Variable TEX1(1..NBTEX), TEX2(1..NBTEX), TEX3(1..NBTEX)
& As [ZZZ] Order With ORDRE

 COL(1)="AA"
 COL(2)="BB"
 NBCOL = 2
 TIT(1) = mess(47,109,1)  : # Règlement
 TIT(2) = mess(120,117,1) : # Etat
 Call TITOBJ("PYH","!",TIT) From CONTOBJ
Else  : # Pas de règlement générée
 OK=0
Endif
Return

##########################
Subprog PAYTRA(TYP,NUM) 
########################## 
Value Integer TYP 
Value Char    NUM() 
 
Local Char TITRA(250)
Onerrgo ERREUR From CONTROLE 
If !clalev([F:TPY]) : Local File TABPAYTYP  [TPY] : Endif
If !clalev([F:PYH]) : Local File PAYMENTH   [PYH] : Endif
If !clalev([F:PAN]) : Local File PAYACCNUM  [PAN] : Endif
If !clalev([F:DAE]) : Local File GACCENTRYD [DAE] : Endif
Onerrgo 
If GERREUR : GERREUR=0 : End : Endif 

# Trace règlements générés

Case TYP
 When 1
  TITRA = mess(14,8890,1)-[L]NUM-":"-mess(13,8890,1)
 When 2
  TITRA = mess(15,8890,1)-[L]NUM-":"-mess(13,8890,1)
Endcase 
Call OUVRE_TRACE(TITRA) From LECFIC

For I=0 To [M:PAH1]NBLIG-1
 Read [PYH]PYH0 = [M:PAH1]NUMREG(I)
 If !fstat
  # Règlement [F:PYH]NUM, [F:PYH]PAM,[F:PYH]AMTCUR [F:PYH]CUR : (Transaction  [F:PYH]PAYTYP)
  Call ECR_TRACE(mess(47,109,1)-[F:PYH]NUM-":"-[M:PAH1]PAM(I)-num$([M:PAH1]AMTLIN(I))-[M:PAH1]CUR(I)-"("+mess(4,36,1)-[F:PYH]PAYTYP+")",0) From GESECRAN
 Endif
Next

Call FERME_TRACE From LECFIC
End   
 

