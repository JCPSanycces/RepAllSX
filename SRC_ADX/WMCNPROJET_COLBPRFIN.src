# Supervisor
## ACLA-CLASSE ## PROJET_COLBPRFIN
# 2018-11-06 07:13:49 394

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0PROJET_COLBPRFIN
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_BPRFIN From WMC1PROJET_COLBPRFIN : Gosub TESTALLSTAT
Gosub INIT_AMTFIN From WMC1PROJET_COLBPRFIN : Gosub TESTALLSTAT
Gosub INIT_CURFIN From WMC1PROJET_COLBPRFIN : Gosub TESTALLSTAT
Gosub AINIT From WMC0PROJET_COLBPRFIN : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0PROJET_COLBPRFIN
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0PROJET_COLBPRFIN
Gosub LNKPRO_BPRFIN From WMC1PROJET_COLBPRFIN : Gosub TESTALLSTAT
Gosub LNKPRO_CURFIN From WMC1PROJET_COLBPRFIN : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



