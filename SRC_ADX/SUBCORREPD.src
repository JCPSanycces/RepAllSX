#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################################################
# Affectation des valeurs pour la création, modification, suppression d'une correspondant à partir
# des données d'un représentant.
# l'affectation se fait à partir des tables
#############################################################################
$COR_SET_HEA_INFO
  #CHECK FILE_DECLARE BPADDRESS [BPAA]
  #CHECK FILE_DECLARE BPADDRESS [BPAR]
  Case IMPZON
    When "CORNUM"
      #type interlocuteur
      [M:COR0]CORTYP = "REP"
      [M:COR0]UPDCNTNUM = 0
    When "LNA"
      #Nom
      [M:COR0]LNA = [F:BPR]BPRNAM
    When "BPRNUM"
      #Code tiers
      [M:COR2]BPRNUM = [F:REPC]REPNUM
      [M:COR2]UPDBPRNUM = 0
    When "BPRLIB"
      #Libellé tiers
      [M:COR2]BPRLIB = [F:BPR]BPRNAM
    # -----------------------------
    # DONNEES PERSONNELLES
    When "HOMADD"
      #Adresse rue (personnel)
      Case indice
        When 0
          [M:COR3]HOMADD(0) = [F:BPAA]BPAADDLIG(0)
        When 1
          [M:COR3]HOMADD(1) = [F:BPAA]BPAADDLIG(1)
        When 2
          [M:COR3]HOMADD(2) = [F:BPAA]BPAADDLIG(2)
      Endcase
   When "HOMCTY"
      #Ville (personnel)
      [M:COR3]HOMCTY = [F:BPAA]CTY
    When "HOMZIP"
      [M:COR3]HOMZIP = [F:BPAA]POSCOD
    When "HOMSAT"
      #Etat personnel
      [M:COR3]HOMSAT = [F:BPAA]SAT
    When "HOMCRY"
      #Pays (personnel)
      [M:COR3]HOMCRY = [F:BPAA]CRY
    When "HOMCRYNAM"
      #Libellé Pays (personnel)
      [M:COR3]HOMCRYNAM = [F:BPAA]CRYNAM
    When "HOMEML"
      #E-mail personnel
      [M:COR3]HOMEML = [F:BPAA]WEB(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPAA]WEB
    When "HOMTEL"
      #Téléphone (personnel)
      [M:COR3]HOMTEL = [F:BPAA]TEL(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPAA]TEL
    When "HOMFAX"
      #Fax (personnel)
      [M:COR3]HOMFAX = [F:BPAA]TEL(1)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPAA]FAX
    # -----------------------------
    # DONNEES PROFESSIONNELLES
    When "CPYBPADES"
      #code adresse
      [M:COR2]CPYBPANUM = [F:BPAR]BPAADD
      [M:COR2]CPYBPATYP = [F:BPAR]BPATYP
      #Inttitulé adresse
      [M:COR2]CPYBPADES = [F:BPAR]BPADES
    When "CPYADD"
      #Adresse rue (professionnel)
      Case indice
        When 0
          [M:COR2]CPYADD(0) = [F:BPAR]BPAADDLIG(0)
        When 1
          [M:COR2]CPYADD(1) = [F:BPAR]BPAADDLIG(1)
        When 2
          [M:COR2]CPYADD(2) = [F:BPAR]BPAADDLIG(2)
      Endcase
   When "CPYCTY"
      #Ville (professionnel)
      [M:COR2]CPYCTY = [F:BPAR]CTY
    When "CPYSAT"
      #Etat professionnel
      [M:COR2]CPYSAT = [F:BPAR]SAT
    When "CPYZIP"
      #Code postal professionnel
      [M:COR2]CPYZIP = [F:BPAR]POSCOD
    When "CPYCRY"
      #Pays (prodessionel)
      [M:COR2]CPYCRY = [F:BPAR]CRY
    When "CPYCRYNAM"
      #Libellé Pays (prodessionel)
      [M:COR2]CPYCRYNAM = [F:BPAR]CRYNAM
    When "CPYEML"
      #E-mail professionnel
      [M:COR2]CPYEML = [F:BPAR]WEB(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPAR]WEB
    When "CPYTEL"
      #Téléphone (professionnel)
      [M:COR2]CPYTEL = [F:BPAR]TEL(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPAR]TEL
    When "CPYFAX"
      #Fax (professionnel)
      [M:COR2]CPYFAX = [F:BPAR]TEL(1)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPAR]FAX
  Endcase
Return

#    When "FNA"
