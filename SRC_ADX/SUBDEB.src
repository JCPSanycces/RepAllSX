#-------------------------------------------------------------------------------------
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
Local Integer IJL
If VALEUR="" : End : Endif
#--- le site doit appartenir à la société renseignée
If find(GREP,"C","D")
  If [M]CPY<>""
    IJL=find(VALEUR,GSITE(1..GNBSITE))
    If IJL and GSOCSITE(IJL)<>[M]CPY : mkstat=1 : Endif
  Endif
Endif

End
