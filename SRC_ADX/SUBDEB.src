Subprog AV_NETMAS(VALEUR)
Variable Decimal VALEUR

#RMA * 83570
Local Integer I

I = find([M]CPY, GSOC(1..GNBSOC))
If I
  If GLEGSOC(I) = "POR"
    Chgfmt [M]NETMAS With "N:12.3"
  Else
    Chgfmt [M]NETMAS With "N:12.2"
  Endif
Endif

End
