#<AdxTL>@(#)3.0.0.0 $Revision$
Call OBJET ("DEB",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "LIENS"          : Gosub LIENS
 When "SETBOUT"        : Gosub SETBOUT
 When "APRES_CHOI"     : Gosub APRES_CHOI
 When "AB1_VCRNUM"     : Gosub AB1_VCRNUM
 When "AB2_NBLINVALO"  : Gosub AB2_NBLINVALO
 When "INICRE"         : Gosub INICRE
 When Default
Endcase
Return

############################# ACTIONS ##################################
$INICRE
#FQ 52782
If dim([F:DEB]EXPNUM)>0
  [F:DEB]EXPNUM=[C]EXPORT
Endif

Return
########################################################################
$SETBOUT
#--- Objet à 6 éléments de clé : ajout de la touche suppression  si autorisé ---#
If CLECUR CHAINE+="A" : Endif
#--- Si suppression non autorisée, grisage du bouton -----#
If GREP<>"C"
  GBIDC2="S" : Gosub AUTORIS_OPT From CONTX3
  If !GBIDI2
   Call VIREBOUT(CHAINE,"A") From GOBJET
  Endif
Endif
Return

########################################################################
$APRES_CHOI
If REPONSE=GSTAANU
  Gosub VERF_ANU
  REPONSE=0
Endif
Return

########################################################################
$VERF_ANU
#--- Début de la transaction de suppression
Call DEBTRANS From GLOCK
$TR_ANNUL
GOK=1
Trbegin [DEB]
Readlock [DEB] DEB0=[M]CPY;[M]DEBDAT;[M]FLO;[M]VCRTYP;[M]VCRNUM;[M]VCRLIN
If fstat=1
   GOK=-1
   GLOCK="$DEB"-[M]CPY-[M]DEBDAT-num$([M]FLO)-num$([M]VCRTYP)-[M]VCRNUM
   Goto TR_ROLL
Elsif fstat
   GOK=0
   Call RSTA("DEB",[M]CPY-[M]DEBDAT-num$([M]FLO)-num$([M]VCRTYP)-[M]VCRNUM) From GLOCK
   Goto AB_ANNUL
Endif
#--- Suppression de l'enregistrement (DEB)
Delete [DEB]
If fstat GOK=0 : Goto AB_ANNUL Endif
Commit
CLECUR = 0
Effzo [DEB]
Goto FIN_ANNUL

$TR_ROLL
Rollback
Call ROLL From GLOCK
If GROLL Goto FIN_ANNUL Else Goto TR_ANNUL : Endif

$AB_ANNUL
Rollback

$FIN_ANNUL
OK=0
Return
############################################################################
$LIENS
Local Integer I
[M]NBLINVALO=0

If [F:DEB]VCRNUMVALO(0) <> ""
    For I = 0 To dim([F:DEB]VCRNUMVALO)-1
        If [F:DEB]VCRNUMVALO(I) = "" : Break : Endif
        [M]VCRNUMVALO(I) = [F:DEB]VCRNUMVALO(I)
        [M]VCRLINVALO(I) = [F:DEB]VCRLINVALO(I)
        [M]NBLINVALO  = I+1
    Next I
Endif

Diszo [M]LINVALOFLG
Diszo [M]NBLINVALO
Diszo [M]EECNUMDEB,DEBLIN,DEBDAT,FLO,CPY,VCRNUM,VCRTYP,VCRLIN

#RMA * 83570
Gosub SHOW_HIDE_REGION

Return
######################################################################################
$SHOW_HIDE_REGION

If ! dim([M]REGION)>0       : Return : Endif

Local Shortint SHOWFIELD : SHOWFIELD = 0
Local Integer  K         : K         = 0
Local Char     CURSOC(GLONCPY)

If GREP<>"" & zoncou = "CPY"
  [L]CURSOC = VALEUR
Else
  [L]CURSOC = [M]CPY
Endif

#set flg to show or hide the field
If [L]CURSOC <> "" & func AFNC.ACTIV("KPO")
  K = find([L]CURSOC, GSOC(1..GNBSOC))
  If K
    If GLEGSOC(K) = "POR"
      SHOWFIELD = 1
    Endif
  Endif
Endif

#show/hide
If SHOWFIELD
  Chgfmt [M]REGION With "K:20X"
Else
  Chgfmt [M]REGION With "-K:20X"
Endif

Return
######################################################################################
## Etiquette ajoutée par le superviseur (écran DEB) 01/08/2008 13:54:29 (CPO)
######################################################################################
Subprog IB_VCRNUM

If [M]VCRNUM <> ""
    GBOUT1=mess(735,197,1)-[M]VCRNUM
Else
    Raz GBOUT1
Endif

End
######################################################################################
$AB1_VCRNUM
#------------------------------------------------------------------------------------#
# Tunnel vers la pièce à l'origine de la ligne de DEB
#------------------------------------------------------------------------------------#
Local Char WOBJET
If !clalev([F:SRH])  Local File SRETURN    [SRH]  Endif

Case [M]VCRTYP
    When 6  : WOBJET = "PTH"
    When 8  : WOBJET = "PNH"
    When 4  : WOBJET = "SDH"
    When 13 : Read [SRH]SRH0=[M]VCRNUM
              If !fstat
                If [F:SRH]LNDRTN=2 : WOBJET = "SRL"  :#Retour de prêt
                Else  WOBJET = "SRH"                 :#Retour client
                Endif
              Endif
    When 5  : WOBJET = "SIH"
    When 18 : WOBJET = "SIH"
    When 17 : WOBJET = "PIH" :# DM 52811
    When Default
Endcase

Return
######################################################################################
$AB2_NBLINVALO
#------------------------------------------------------------------------------------#
# Tunnel vers la pièce à l'origine de la valorisation de la ligne de DEB
#------------------------------------------------------------------------------------#
Local Shortint NOL : NOL = nolign-1
Local Char WOBJET
Local Char WCLE

Case [M]VCRTYP
    When 6  : WOBJET = "PIH"
    When 8  : WOBJET = "PIH"
    When 4  : WOBJET = "SIH"
    When 13 : WOBJET = "SIH"
    When 5  : WOBJET = "SIH"
    When 18 : WOBJET = "SIH"
    When Default
Endcase

WCLE = [M]VCRNUMVALO(NOL)

Return
######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran DEB) 01/08/2008 14:59:16 (CPO)
######################################################################################
Subprog IB_NBLINVALO
Local Shortint NOL : NOL = nolign-1

If [M]LINVALOFLG <> 2 and [M:DEB]VCRNUMVALO(NOL)=""
  Raz GBOUT2 : End
Endif
If [M]VCRNUMVALO(NOL) <> ""
  GBOUT2=mess(735,197,1)-[M]VCRNUMVALO(NOL)
Else
  Raz GBOUT2 : End
Endif

End
