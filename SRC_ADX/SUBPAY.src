Subprog AM_BID(VALEUR)
Variable Char    VALEUR()
Local Char       ECOCOD
Local Integer    STAT
If VALEUR<>[M]BID & [M]BPR<>"" & VALEUR<>""
 Call LECTURE("BPR",[M]BPR,"") From CONTOBJ
 If fstat : End : Endif
 If ([F:BPR]BPCFLG=2 | [F:BPR]BPSFLG=2)
  If clalev([F:BID])=0 : Local File BID [BID] : Endif
  Read [F:BID]BID0=1;[M]BPR;VALEUR
  If fstat=5
   #Vérifions que le RIB existe ds la table des Bids du tiers
   Filter [BID] Where BPATYP=1 & BPANUM=[M]BPR
   #Si la liste est vide on laisse le user saisir ce nouvreau RIB
   #Sinon message erreur RIB inexistant ds la liste.
   If rowcount([BID]) <> 0
    #RIB inexistant
    GMESSAGE = mess(27,199,1): mkstat=2 : End
   Endif
   Filter[BID]
  Endif
 Endif
Endif
# Whenever the RIB is changing of value , need to get back the Economic reason if Non Resident field
# of the Bank ID number (in BPs) is set to yes and the amount is >= to AMTVIR.
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If dim([F:CPY]BDFECOCOD)>0 Then
 Call CALC_BDFECOCOD(GFLAG,[M:PAY1]BPR,VALEUR,[M:PAY1]BPAINV,[M:PAY1]AMTCUR,[M:PAY1]CUR,[M:PAY1]ACCDAT,[M]CPY,ECOCOD,STAT) #CHECK IGNORE_LINE
 If STAT>0 Then
  [M]BDFECOCOD = ECOCOD
  If dim([M:PAY1]BDFECOCOD)>0 Then
   Affzo [M:PAY1]BDFECOCOD, ZBDFECOCOD #CHECK IGNORE_LINE
  Endif
  If dim([M:PAY2]BDFECOCOD)>0 Then
   Affzo [M:PAY2]BDFECOCOD, ZBDFECOCOD #CHECK IGNORE_LINE
  Endif
 Endif
Endif
End

######################################################################################
# Si société déclarante, seul le code 060 est autorisé
Subprog C_BDFECOCOD(VALEUR)
Variable Char    VALEUR()
Local    Integer DCLDIR
Local    Char    CURBANK
Local    Integer ACCNR, EEC
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If dim([F:CPY]BDFECOCOD)>0 Then
 Call SRC_DCLDIR([M]CPY,DCLDIR)
 Call SRC_ACCOUNT([M]BPR, [M]BID, [M:PAY1]BPAINV, CURBANK, ACCNR, EEC)
 If DCLDIR=G_OUI Then
  If ACCNR=G_NON and VALEUR<>"" Then
   GMESSAGE=mess(247,117,1) : # Compte tiers résident, code motif économique non requis
   mkstat=2
  Endif
 Else
  If ACCNR=G_NON and VALEUR<>"" Then
  Endif
 Endif
Endif
End

