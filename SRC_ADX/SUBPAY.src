AXE=18 : Goto DEFCCE
Subprog D_CCE19(VALEUR)
Variable Char     VALEUR
AXE=19 : Goto DEFCCE
Subprog D_CCE20(VALEUR)
Variable Char     VALEUR
AXE=20 : Goto DEFCCE


$DEFCCE
Local Integer NOL, IND, INDAXE, AXI, SUIVI
Local Integer NLED, TLED
Local Libelle BPRTYP
Local Char    BPR(GLONBPR), BPRSAC(GLONSAC), ACC(GLONGAC), OPT(5), SECTION(GLONCCE)
Gosub SETNOL
Gosub RECH_ACCANA From SUBPAY3
If CPTANA="" | [M]DSP(NOL)<>""
 End
Endif

# Cas des USA (Pas de zone DSP)
If dim([M]DSP)<0 | (VALEUR="" & [M]DSP(NOL)="")   :# bug 15970
 If [M]ACCTYP(NOL)=1
  OPT="2"
 Else
  OPT="1"
 Endif
 If OPT<>"1"
  If !clalev([F:DAE]) : Local File GACCENTRYD [DAE] : Endif
  If !clalev([F:DAA]) : Local File GACCENTRYA [DAA] : Endif
  Read [DAE]DAE2 = [M]DUDNUM(NOL)
  If !fstat & [F:DAE]DSP=""
   For [DAA]DAA0 Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LIN=[F:DAE]LIN & IDTLIN=[F:DAE]IDTLIN
    INDAXE = find(GAXE(AXE),[F:DAA]DIE(0..dim([F:DAA]DIE)-1))
    If INDAXE
     VALEUR = [F:DAA]CCE(INDAXE-1) : Break
    Endif
   Next
   If VALEUR<>"" : End : Endif
  Endif
 Endif
Endif
# Autre init selon le code PAYMENTD
If VALEUR=""
 [L]BPR=[M]BPR : [L]BPRSAC=[M]BPRSAC : [L]ACC=[M]ACC
 If [M]ACC=""
  Gosub SET_BPR
  If [M]BPRSAC<>"" : Call AS_ACC([M]ACC) : mkstat=0 : Endif
 Endif
 Call CLIFOU([M]BPR,GPLAN(1),[M]ACC,[M]SNS,[L]BPRTYP) From PAYDIV
 Call INISEC(VALEUR,"PAYMENTD",GAXE(AXE),[L]BPRTYP) From PAYDIV
 [M]BPR=[L]BPR : [M]BPRSAC=[L]BPRSAC : [M]ACC=[L]ACC
Endif
# Init selon entête de facture/commande
If VALEUR="" & [M]VCRNUM(NOL)<>""
 If [M]VCRTYP(NOL)=[M]BPSTYP    : OPT="4123"
 Elsif [M]VCRTYP(NOL)=[M]BPCTYP : OPT="3124"
 Elsif [M]SNS=1                 : OPT="2143"
 Else                           : OPT="1234"
 Endif
 For I=1 To 4
  Case mid$(OPT,I,1)
   When "1" : # Facture client
    Call LECTURE("BIC",[M]VCRNUM(NOL),"") From CONTOBJ
    If fstat=0 & [F:SIH]GTE=[M]VCRTYP(NOL)
     INDAXE = find(GAXE(AXE),[F:SIH]DIE(0..dim([F:SIH]DIE)-1))
     If INDAXE
      VALEUR = [F:SIH]CCE(INDAXE-1) : Break
     Endif
    Endif
   When "2" : # Facture fournisseur
    Call LECTURE("BIS",[M]VCRNUM(NOL),"") From CONTOBJ
    If fstat=0 & [F:PIH]GTE=[M]VCRTYP(NOL)
     INDAXE = find(GAXE(AXE),[F:PIH]DIE(0..dim([F:SIH]DIE)-1))
     If INDAXE
      VALEUR = [F:PIH]CCE(INDAXE-1) : Break
     Endif
    Endif
   When "3" : # Commande client
    If [M]VCRTYP(NOL)=[M]BPCTYP
     Call LECTURE("SOH",[M]VCRNUM(NOL),"") From CONTOBJ
     If fstat=0
      INDAXE = find(GAXE(AXE),[F:SOH]DIE(0..dim([F:SOH]DIE)-1))
      If INDAXE
       VALEUR = [F:SOH]CCE(INDAXE-1) : Break
      Endif
     Endif
    Endif
   When "4" : # Commande fournisseur
    If [M]VCRTYP(NOL)=[M]BPSTYP
     Call LECTURE("POH",[M]VCRNUM(NOL),"") From CONTOBJ
     If fstat=0
      INDAXE = find(GAXE(AXE),[F:POH]DIE(0..dim([F:POH]DIE)-1))
      If INDAXE
       VALEUR = [F:POH]CCE(INDAXE-1) : Break
      Endif
     Endif
    Endif
  Endcase
 Next I
Endif
If VALEUR<>"" : End : Endif
## On essaye d'initialiser la section selon le compte du référentiel qui gère l'axe
For NLED=1 To GNBTYPLED
 [L]TLED = GTYPLED(NLED) : Gosub LECLED From SUBPAY3
 Call INDLED([L]LED,GAXE(AXE),IND,AXI) From CPTDIV
 If IND & AXI
  If !instr(1,evalue("[M]ACC"+num$(NLED)+"("+num$(NOL)+")"),"x")
   Call LECTURE("GAC",evalue("[M]ACC"+num$(NLED)+"("+num$(NOL)+")"),GPLAN(NLED)) From CONTOBJ
   SUIVI = find(GAXE(AXE),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
   If SUIVI
    VALEUR = [F:GAC]CCEDEF(SUIVI-1)
    If VALEUR<>"" : Break : Endif
   Endif
  Endif
 Endif
Next
If VALEUR<>"" : End : Endif
## En dernier ressort, on initialise la section par celle de la ligne précédentes
For I=NOL-1 To 0 Step -1
 VALEUR=evalue("[M]CCE"+num$(AXE)+"("+num$(I)+")")
 If VALEUR<>"" : Break : Endif
Next I
End

