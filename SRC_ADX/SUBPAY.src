$CONTCCE
Gosub SETNOL
Local Char    COMPTE(GLONGAC)
Local Integer NLED, TLED
For NLED=1 To GNBTYPLED
 COMPTE = evalue("[M]ACC"+num$(NLED)+"("+num$(NOL)+")")
 If COMPTE<>"" & !instr(1,COMPTE,"x")
  [L]TLED = GTYPLED(NLED) : Gosub LECLED From SUBPAY3
  Call CONTCCE(VALEUR,[L]LED,GAXE(AXE),[M]FCYLIN(NOL),[M]ACCDAT,COMPTE,GAXE,"[M]CCE#",NOL) From CPTCNT
 Endif
Next
End

Subprog AV_NBLIG

# Issue 103268
#If func AFNC.ACTIV("KIT")
# GFMT = "NPz3:"+GDEVFM1(1)
# If func AFNC.PARAM("RTZPRW",[M:PAY1]CPY)<>"2" and func AFNC.PARAM("ARGRTZ",[M:PAY1]CPY)<>"2"
#  GFMT = "-NPz3:"+GDEVFM1(1)
# Endif
# Chgfmt [M]RITAMT With GFMT
#Endif
If func AFNC.ACTIV("KIT")
 GFMT = "NPz3:"+GDEVFM1(1)
 If func AFNC.PARAM("RTZPRW",[M:PAY1]CPY)<>"2" and
&   func AFNC.ACTIV("KAG") and func AFNC.PARAM("ARGRTZ",[M:PAY1]CPY)<>"2"
  GFMT = "-NPz3:"+GDEVFM1(1)
 Endif
 Chgfmt [M]RITAMT With GFMT
Endif
# End issue 103268
End

Subprog C_NBLIG
If find(status,65,68,83) : # Suppression d'une ligne
 If status=65 : nolign1=nolign : Endif
 Local Integer IND, X
 Gosub PYHCPT
 X=(nolign<>nolign1)
 For IND=nolign-1 To nolign1-1
  If CPTA & [M]ACCTYP(IND)<>2
   # Suppression impossible
   GMESSAGE=mess(54,123,1) : mkstat=1 : Break
  Elsif find([M]IPTTYP(IND),1,2) & [M]DUDNUM(IND)<>0
   Call LECDUD([M]DUDNUM(IND),[M]DUDLIG(IND)) From SUBPAY2
   If fstat=0 & [F:DUD]PAMTYP=1 & [F:DUD]DINAMT<>0
    # Commande NUM - Acompte déduit de DINAMT CUR
    GMESSAGE = mess([M]IPTTYP(IND),659,1)-[F:DUD]NUM+"\"
    GMESSAGE+= mess(59,117,1)-num$([F:DUD]DINAMT)-[F:DUD]CUR
    mkstat=1 : Break
   Endif
  Endif
 Next IND
 If mkstat & X
  # (Ligne IND+1) - Commande NUM - Acompte déduit de DINAMT CUR
  GMESSAGE="("+mess(47,116,1)-num$(IND+1)+")\"+GMESSAGE
  End
 Endif
 If dim([M]RITAMT)>0 & [M]RITAMT(nolign-1)<>0
  # Cas retenue - DmD52620 - il faut supprimer la 1ère échéance imputé en dernier...
  For I=nolign To [M]NBLIG
   If [M]DUDNUM(I)=[M]DUDNUM(nolign-1)
    # Annulation impossible :   Annuler d'abord les lignes d'imputations (Ligne...)
    GMESSAGE=mess(49,117,1)+"\"+mess(25,117,1)-"("+mess(47,116,1)-num$(I+1)+")"
    mkstat=1 : Break
   Endif
  Next I
 Endif
 #
 If !mkstat
  For IND=nolign-1 To nolign1-1
   If [M]PTF(IND)-[M]PTV(IND)>1
    Call ANUVENTIL([M]PTV,[M]PTF,[M]NBLIG,[M]PTV(IND),[M]PTF(IND)-[M]PTV(IND)+1) From VENTILE
   Endif
  Next
 Endif
Endif
End

$PYHCPT
Local Libelle CPTA
If [M]NUM<>"" & [M]STA<9
 If clalev([F:PYH])=0 : Local File PAYMENTH [PYH] : Endif
 Read [PYH]PYH0 = [M]NUM
 If fstat=0 & ([F:PYH]STAFLG(2)=2 or [F:PYH]STAFLG(7)=2) : CPTA=1 : Endif
Endif
Return

Subprog AVANT_NBLIG
 If find(status,73,75,82) : # Ajout / Insertion / Modif d'une ligne
  [M]OD1=[M]DUDNUM(nolign-1)
  [M]OD2=[M]DUDLIG(nolign-1)
  [M]OVCR=[M]VCRTYP(nolign-1)+"\"+[M]VCRNUM(nolign-1)
  If dim([M]RITAMT)>0 : [M]ORIT=[M]RITAMT(nolign-1) : Endif
  If [M]CURLIN(nolign-1)<>""
   Call LECTURE("TCU",[M]CURLIN(nolign-1),"") From CONTOBJ
  Endif
 Endif
 If dim([M]TOTIMPUT)>0
  [M]TOTIMPUT -= [M]AMTLIN2(nolign-1)
 Endif
 If dim([M]RSTIMPUT)>0 & [M]AMTCUR<>0
  [M]RSTIMPUT += [M]AMTLIN2(nolign-1)
 Endif

End

Subprog APRES_NBLIG
 If [M]ACC=""
  Local Integer NOL :  NOL=nolign-1
  Gosub SET_BPR
  If [M]BPRSAC<>""
   Call AS_ACC([M]ACC) : mkstat=0
   If [M]BPR<>"" & [M]ACC<>""
    Call CONTACC(GTYPGEN,GPLAN(1),[M]ACC,[M]FCY,[M]CUR,[M]ACCDAT) From CPTCNT
    If !mkstat
     Call LECTURE("BPR",[M]BPR,"") From CONTOBJ
     Gosub CONT_BPRACC From SUBPAY2
    Endif
    If !mkstat
     Call CONTBPRCPY([M]BPR,[M]FCY,[M]COA,[M]ACC,"") From CPTSUB
    Endif
    If mkstat
     Raz [M]ACC,[M]BPR,[M]BPRSAC : GMESSAGE="" : mkstat=0
     End
    Endif
   Endif
   Affzo [PAY1]BPR, BPRSAC, ACC, BPRNAM
   Call D_BIDCRY([M]BIDCRY)
   If dim([M:PAY1]BIDCRY)>0 : Affzo [PAY1]BIDCRY : Else Affzo [PAY2]BIDCRY : Endif
  Endif
 Endif
 If dim([M]TOTIMPUT)>0
  [M]TOTIMPUT += [M]AMTLIN2(nolign-1)
  [M]DEVISE = CUR
  Affzo TOTIMPUT, DEVISE
 Endif
 If dim([M]RSTIMPUT)>0 & [M]AMTCUR<>0
  [M]RSTIMPUT -= [M]AMTLIN2(nolign-1)
  Affzo RSTIMPUT
 Endif
End

#YYFIN_X3-4142/MDJ ##########################################
##        BP Balance calculation                           ##
#############################################################
Subprog SOLD_CALC(COLLECTIF,COMPTE,TIERS,SITE,DEVISE,DATESOL,SOLDE)
Value    Char    COLLECTIF
Value    Char    COMPTE
Value    Char    TIERS
Value    Char    SITE
Value    Char    DEVISE
Value    Date    DATESOL
Variable Decimal SOLDE
# Calculation of the current total of the BP (then current balance displayed)
 If SITE <>"" & TIERS <>"" & (COMPTE<>"" | COLLECTIF <>"") & DATESOL <> [0/0/0] & DEVISE <> ""
  If COLLECTIF <>""
   Call SOLDAT("",COLLECTIF,COMPTE,TIERS,GTYPGEN,[M]CPY,SITE,DEVISE,1,DATESOL,SOLDE) From CNSCPTSTD
  Elsif COMPTE<>""
    Call SOLDAT("","",COMPTE,TIERS,GTYPGEN,[M]CPY,SITE,DEVISE,1,DATESOL,SOLDE) From CNSCPTSTD
  Endif
 Endif
End
#YYFIN_X3-4142/MDJ End

$SET_BPR
Local Char CODCPT(GLONCAC)
If [M]DUDNUM(NOL)<>0
 Call LECDUD([M]DUDNUM(NOL),[M]DUDLIG(NOL)) From SUBPAY2
 If fstat=0 & [F:DUD]BPRPAY<>"" & [F:DUD]SAC<>""
  [M]BPR=[F:DUD]BPRPAY
  [M]BPRSAC=[F:DUD]SAC
 Endif
Elsif [M]IPTTYP(NOL)=2
 Call LECTURE("POH",[M]VCRNUM(NOL),"") From CONTOBJ
 If fstat=0
  Call LECTURE("BPS",[F:POH]BPSNUM,"") From CONTOBJ
  Call INIT_COMPTE([F:POH]BPSNUM,GSOCIETE,"F",CODCPT) From CPTSUB
  Call LECTURE("CAC",[L]CODCPT,"3~"+GPLAN(1)) From CONTOBJ
  Read [GAC]GAC0 = GPLAN(1);[F:CAC]ACC(0)
  If fstat=0
   [M]BPRSAC=[F:GAC]ACCSHO
   [M]BPR   =[F:POH]BPRPAY
  Endif
 Endif
Elsif [M]IPTTYP(NOL)=1
 Call LECTURE("SOH",[M]VCRNUM(NOL),"") From CONTOBJ
 If fstat=0
  Call LECTURE("BPC",[F:SOH]BPCINV,"") From CONTOBJ
  Call INIT_COMPTE([F:SOH]BPCINV,GSOCIETE,"C",CODCPT) From CPTSUB
  Call LECTURE("CAC",[L]CODCPT,"2~"+GPLAN(1)) From CONTOBJ
  Read [GAC]GAC0 = GPLAN(1);[F:CAC]ACC(0)
  If fstat=0
   [M]BPRSAC=[F:GAC]ACCSHO
   [M]BPR   =[F:SOH]BPCPYR
  Endif
 Endif
Elsif [M]IPTTYP(NOL)=4
 Call LECTURE("PIH",[M]VCRNUM(NOL),"") From CONTOBJ
 If fstat=0
  [M]BPRSAC=[F:PIH]BPRSAC
  [M]BPR   =[F:PIH]BPR
 Endif
Endif
Return

Subprog IB_NBLIG
Local Integer OK, NOL : NOL=nolign
If NOL=0 : End : Endif
GBOUT5 = ""
If [F:TPY]DENDEF<>""
 Call LEC_CDA_LEG(GCURLEG,[F:TPY]DENDEF) From CPTLEC
 If [F:CDA]ACCTYP=1
  If dim([F:CDA]ACS)>0
   Call CONTEXE([F:CDA]ACS) From CPTSUB
   If mkstat : mkstat=0 : GMESSAGE="" : OK=0 : Else OK=1 : Endif
  Else OK=1
  Endif
  If OK & [M]SOICPT<>2
   GBOUT5=mess(199,117,1) : # Relevé
  Endif
 Endif
Endif
# Facture/Commande
If [M]VCRTYP(NOL-1)<>""
 GBOUT3=mess(4,413,1)+"/"+mess(2,413,1)
Else
 GBOUT3=""
Endif
End

#######################################
## Onglet lot de saisie : Ecran PAY4 ##
#######################################
Subprog AS_NBPAY
mkstat = 2
End

Subprog AP_NBPAY
Local Integer NOL
NOL=nolign-1
If NOL>=0 & NOL<[M]NBPAY
 GDIV(0)=[M]PAYNUM(NOL)
 mkstat=4
Endif
End

Subprog B1_NBPAY
# sélection en mode intradon
Local Integer NOL
NOL=nolign-1
If NOL>=0 & NOL<[M]NBPAY
 GDIV(0)=[M]PAYNUM(NOL)
 mkstat=4
Endif
End
End

# Get back Non resident info and the currency, the EEC flag of th country.
Subprog SRC_ACCOUNT(TRS, BIDNUM, ADR, CUR, NR, EEC)
Value    Char    TRS, BIDNUM, ADR
Variable Char    CUR
Variable Integer NR, EEC
Local    Integer I, FOUNDADR
CUR = "" : NR = 0
If clalev([F:BID])=0 : Local File BID [BID] : Endif
If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif

Read [F:BID]BID0=1;TRS;BIDNUM
If !fstat Then
 FOUNDADR=G_NON
 If [F:BID]ACCNONREI=G_OUI Then
  FOUNDADR=G_OUI
 Endif
 NR = FOUNDADR
Endif
Read [F:TCY]TCY0=[F:BID]CRY
If !fstat Then
 CUR = [F:TCY]CUR
 EEC = [F:TCY]EECFLG
Endif
End

# Search if the check box "Direct declaring site to the payment balance" is ticked or not.
Subprog SRC_DCLDIR(CPY_T, DCLDIR)
Value    Char    CPY_T
Variable Integer DCLDIR
DCLDIR=0
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
 Read [F:CPY]CPY0=CPY_T
 If !fstat Then
  DCLDIR=[F:CPY]DCLDIRBALPAY
 Endif
End

# The Economic reason is calculated if Non Resident field of the Bank ID number (in BPs)
# is set to yes and the amount is >= to AMTVIR.
Subprog CALC_BDFECOCOD(PAYTYP, TRS, BIDNUM, ADR, AMTCUR, CURPAY, ACCDAT, CPY, BDFECOCOD, STAT)
Value Char       PAYTYP, TRS, BIDNUM, ADR, CURPAY, CPY
Value Decimal    AMTCUR
Value Date       ACCDAT
Variable Char    BDFECOCOD
Variable Integer STAT
Local Integer    OK, ACCNR, SAISIE_BDFE, STAT2, DCLDIR, EEC
Local Char       CURBANK, CRYSOC
Local Decimal    AMTCUR_D
# 2014-04-01 DNE MODIF INSERTED (SAM #85794)
Local Integer    I, LENGTH
Local Char       PBDDEFGRU(255)  : PBDDEFGRU = func AFNC.PARAM( "PBDDEFGRU", CPY )
Local Char       _BDFECOCOD(255) : Raz [L]_BDFECOCOD
# 2014-04-01 DNE MODIF END
STAT=0
#   DACSUP(I) = 1 ==> Ecocod is required
#   DACSUP(I) = 2 ==> Ecocod is not required but you should
#   DACSUP(I) = 3 ==> Ecocod is not filled in
Call LEC_TPY_LEG(GCURLEG,PAYTYP) From CPTLEC
For I=0 To dim([F:TPY]ZONSUP)-1
 If [F:TPY]ZONSUP(I)="BDFECOCOD" Then
  SAISIE_BDFE = [F:TPY]DACSUP(I)
  Break
 Endif
Next I
Call ACTIV("VII",OK) From SUBACV
If OK and find(SAISIE_BDFE, 1, 2)>0 Then
 STAT=SAISIE_BDFE
 BDFECOCOD=""
 # Here we check if Non resident or not
 Call SRC_ACCOUNT(TRS, BIDNUM, ADR, CURBANK, ACCNR, EEC)
 # Here we check Direct declaring site to the payment balance
 Call SRC_DCLDIR(CPY,DCLDIR)
 If DCLDIR=G_OUI Then
  If ACCNR=G_OUI Then
   If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
   Read [F:CPY]CPY0=CPY
   If !fstat Then
    BDFECOCOD=[F:CPY]BDFECOCOD
   Endif
  Else
   BDFECOCOD=""
  Endif
 Else
# 2014-04-02 DNE MODIF BEGIN (SAM #85794)
  If PBDDEFGRU <> ""
    # Get the payment declaration BP group as set in PBDDEFGRU parameter
    # for the current legislation ...
    If !clalev([F:PBDBPD]) : Local File PBDBPGRPD [PBDBPD] : Endif

    LENGTH = len( TRS )
    For I = LENGTH To 1 Step -1
      Read [F:PBDBPD]PBDBPD0 = PBDDEFGRU; GCURLEG; left$( left$( TRS, I ) + "*", LENGTH )
      If !fstat
          # ... and in the end the economic reason code.
          [L]_BDFECOCOD = [F:PBDBPD]ECOCOD
          Break
      Endif
    Next
  Endif
  If [L]_BDFECOCOD <> "" Then
# 2014-04-02 DNE MODIF ORIG
#  If [F:BPR]BDFECOCOD<>"" Then
# 2014-04-02 DNE MODIF END
   Call CONVERT(CURPAY,GCURSHR,CURBANK,1,ACCDAT,AMTCUR,AMTCUR_D, STAT2) From TRTDEV
   If STAT2<>0 Then AMTCUR_D=AMTCUR Endif
   If (CURPAY=GCURSHR and EEC=G_OUI and ACCNR=G_OUI and AMTCUR_D>=GAMTVIR1)
&    or (CURPAY=GCURSHR and EEC<>G_OUI and ACCNR=G_OUI and AMTCUR_D>=GAMTVIR2)
&    or (CURPAY<>GCURSHR and AMTCUR_D>=GAMTVIR3)
&    or (BIDNUM="" and AMTCUR=0 and SAISIE_BDFE=1) Then
    If clalev([F:BPR])=0 : Local File BPARTNER [BPR] : Endif
# 2014-04-01 DNE MODIF BEGIN (SAM #85794)
        BDFECOCOD = [L]_BDFECOCOD
# 2014-04-01 DNE MODIF ORIG
#    Read [F:BPR]BPR0=TRS
#    If !fstat Then
#     BDFECOCOD = [F:BPR]BDFECOCOD
#    Endif
# 2014-04-01 DNE MODIF END
   Endif
  Endif
 Endif
Endif
End

# Si code activité VII à Oui et champ Mode règlement activé,
# on renseigne le code Mode règlement
Subprog CALC_PAM(PAYTYP,TRS,PAM,STAT)
Value    Char    PAYTYP, TRS
Variable Char    PAM
Variable Integer STAT
Local    Integer OK, SAISIE_PAM
STAT=0
# Pour rappel :
#   DACPAM(I) = 1 ==> Saisi, obligatoire
#   DACPAM(I) = 2 ==> Saisi, pas obligatoire
#   DACPAM(I) = 3 ==> Pas saisi
Call LEC_TPY_LEG(GCURLEG,PAYTYP) From CPTLEC
SAISIE_PAM = [F:TPY]DACPAM
Call ACTIV("VII",OK) From SUBACV
If OK and find(SAISIE_PAM, 1, 2)>0 Then
 STAT = SAISIE_PAM
 PAM  = ""
 If clalev([F:BPR])=0 : Local File BPARTNER [BPR] : Endif
 Read [F:BPR]BPR0=TRS
 If !fstat Then
  PAM = [F:BPR]MODPAM
 Endif
Endif
End

Subprog AM_AMTCUR(VALEUR)
Variable Decimal VALEUR
If dim([M:PAY1]RSTIMPUT)>0
 Gosub INI_IMPUT
 Affzo [PAY1]RSTIMPUT
Elsif dim([M:PAY2]RSTIMPUT)>0
 Gosub INI_IMPUT
 Affzo [PAY2]RSTIMPUT
Endif

If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If dim([F:CPY]BDFECOCOD)>0 Then
# Calcul du code motif économique
 Local Char    ECOCOD
 Local Integer STAT
 Call CALC_BDFECOCOD(GFLAG,[M:PAY1]BPR,[M]BID,[M:PAY1]BPAINV,VALEUR,[M:PAY1]CUR,[M:PAY1]ACCDAT,[M]CPY,ECOCOD,STAT) #CHECK IGNORE_LINE
 If STAT>0 Then
 If ECOCOD="" or [M]BDFECOCOD="" Then
  [M]BDFECOCOD = ECOCOD
  If dim([M:PAY1]BDFECOCOD)>0 Then
   Affzo [M:PAY1]BDFECOCOD, ZBDFECOCOD #CHECK IGNORE_LINE
  Endif
  If dim([M:PAY2]BDFECOCOD)>0 Then
   Affzo [M:PAY2]BDFECOCOD, ZBDFECOCOD #CHECK IGNORE_LINE
  Endif
 Endif
 Endif
Endif
End

$INI_IMPUT
If VALEUR<>0
 [M]RSTIMPUT = VALEUR - sum([M]AMTLIN2)
Else
 [M]RSTIMPUT = 0
Endif
Return


$SETNOL
Local Integer NOL
NOL = nolign-1
Return

