#<AdxTL>@(#)0.0.0.0 $Revision$ Règlements
#----------------------------------------------------------------------------------------
# Changes:
# Issue X3-107197 - 2018-09-14 by CBO : PARAMETER AND ACTIVITY CODE
# MDJ-X3-36950 RTZ when creating a NEW payment on a NEW batch entry
#-----------------------------------------------------------------------------------------
#**********************************************************************#
#    Modification                                                      #
# XXXXX XX.XX.XXXX xxxxxx_x : XXXXXXXXXXXXXXXXXXXXXXXXXXXX             #
# FPE   14.11.2017 X3-61594 : Journal traceability displays wrong      #
#                             company currency.                        #
########################################################################

Raz GBIDC1, GBIDC2
Call OBJET("PAY",GBIDC2,GBIDC3) From GOBJET
End

$ACTION
Case ACTION
 When "TRT_DIV"    : Gosub TRT_DIV
 When "SEL_TABLE"  : Gosub SEL_TABLE
 When "VERF_TABLE" : Gosub VERF_TABLE
 When "CHX_TABLE"  : Gosub CHX_TABLE
 When "VERF_ANU"   : Gosub VERF_ANU From SUBPAY3
 When "AV_ANNULE"  : Gosub AV_ANNULE From SUBPAY3 : # parce que GIMPORT est positionné à 1 dans le ADELETE
 When Default
  If !GIMPORT
   Gosub ACTION From SUBPAY3
  Endif
Endcase
Return

$SEL_TABLE
Case COUZON
 When "PAYLOT" : Gosub S_PAYLOT : # Lot de saisie
 When "PAM"    : Gosub S_PAM    : # Mode de règlement
 When "BID"    : Gosub S_BID    : # RIB
 When "VCRNUM" : Gosub S_VCRNUM : # Numéro de pièce imputée
 When "DSP"    : Gosub S_DSP    : # Répartition ana
 When "REL"    : Gosub S_REL From SUBPAY2 : # Relevé
 When "BAN"    : Gosub S_BAN    : # Banque
Endcase
Return

$VERF_TABLE
Case COUZON
 When "BID"    : Gosub V_BID    : # RIB
 When "REL"    : Gosub V_REL From SUBPAY2  : # Relevé
 When "VCRNUM" : Gosub V_VCRNUM : # Numéro de pièce imputée
Endcase
Return

$CHX_TABLE
Case COUZON
 When "REL"    : Gosub C_REL From SUBPAY2  : # Relevé
Endcase
Return

$TRT_DIV
Case TRAIT
 When "CONSPAY1" : Gosub DATEXE
Endcase
Return

################################
## Etiquettes de l'écran PAY0 ##
################################

Subprog C_NUM(VALEUR)
Variable Char VALEUR
If VALEUR<>""
 Look [PYH]PYH0 = VALEUR
 If fstat : VALEUR="" : Endif
Endif
End

Subprog AP_NUM(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : mkstat=4 : Endif
End

Subprog AV_STA2(VALEUR)
Variable Char    VALEUR()
Case [M]STA
 When 0       : VALEUR=""
 When Default : VALEUR=mess([M]STA,689,1)
Endcase
End

Subprog C_PAYLOT(VALEUR)
Variable Char    VALEUR()
If [M]COMPTLOT = ""
 If clalev([F:TCA])=0  : Local File TABCOUAFF   [TCA] : Endif
 Local Integer OKTCA
 Call GETSOC([M]FCY) From DEVSUB
 Call LECTCA(3,OKTCA) From SUBTCA
 If OKTCA
  [M]COMPTLOT = [F:TCA]CODNUM(6)
 Endif
Endif
If VALEUR<>"" & !(VALEUR="*" & [M]COMPTLOT<>"")
 Raz [F:PYL] : # Pour forcer la relecture
 Call CONTROLE("PYL","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : mkstat=2 : End
 Elsif [F:PYL]PAYTYP<>GFONC1
  # Lot de saisie de transaction
  GMESSAGE=mess(111,121,1)-[F:PYL]PAYTYP  : mkstat=2 : End
 Elsif (VALEUR<>[M:PAY4]CODLOT | GREP="C" | GREP="D") & [F:PYL]NBRPAY>=dim([M:PAY4]PAYNUM)
  # Lot de saisie plein
  GMESSAGE = mess(107,121,1) : mkstat=2 : End
 Endif
 If GUSRFCY(1)<>"\"
     # Si un règlement est saisi... a priori, ce contrôle serait déjà effectué.
     If [M]NUM<>""
         Read [PYH]PYH2=[F:PYL]COD;[M]NBPAY # Dernier reglement du lot
     Else
         Read [F:PYH]PYH2(1)=[F:PYL]COD # Lot clické
     Endif
     If !find([PYH]FCY,GUSRFCY(1..GNBAUZ))
         Call ERREUR(mess(8,123,1)) From GESECRAN  #  Accès impossible à cette fiche
         mkstat=2 : End
     Endif
 Endif
 [M]CPY = [F:PYL]CPY
Endif
End
##############################
# SAM 81743: if transaction and bank have progressive balance control activated, load and disable [M:PAY1]BAN
Subprog AP_PAYLOT(VALEUR)
Variable Char VALEUR()
If VALEUR <> "" and VALEUR <> '*'
  #SAM 99661   angre 13.06.2014
  #Local Char P_PROBALCTL(1) : P_PROBALCTL = ""
  Local Char PARAM(255)  : PARAM  = "PROBALCTL"
  If clalev([F:TPY])=0 : Local File TABPAYTYP [TPY] : Endif
  If clalev([F:PYL])=0 : Local File PAYLOT [PYL] : Endif
  If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif
  #SAM 99661   angre 13.06.2014
  #Call PARAM([F:TPY]LEG,"PROBALCTL",P_PROBALCTL) From ADOVAL
 # If [F:TPY]LOTPROBALCTL = 2 and P_PROBALCTL = '2'
  If [F:TPY]LOTPROBALCTL = 2 and fmet GACTX.APARAM.AGETVALNUM( [V]CST_ALEVLEG, [F:TPY]LEG, PARAM) = 2
    Read [F:PYL]PYL0 = VALEUR
    # read bank entry from entry batch
    Read [F:BAN]BAN0 = [F:PYL]BAN
    If [BAN]BNKPROBALCTL = 2
      [M:PAY1]BAN = [F:PYL]BAN
      # init CURBAN field with bank currency
      [M]CURBAN = [F:BAN]CUR
      #SAM 99661   angre 13.06.2014
      Affzo [M:PAY1]BAN
      Grizo [M:PAY1]BAN
    Endif
  Endif
  # ISSUE 39256 - 2017-09-08 MRDAB - Enter payments from BCREG
Elsif GFONCTION1 <> 'GESBCREG'
  # ISSUE END
  Actzo [M:PAY1]BAN
Endif

#SAM 99661   angre 13.06.2014
#Affzo [M:PAY1]BAN
End
###########################
## X3-53802 08/24/2017 (MDJ)
##############################
Subprog AM_PAYLOT(VALEUR)
Variable Char    VALEUR()

 If GREP<> "C"  : End : Endif

 If  (VALEUR = '*' or VALEUR = "")
   #<*YYFIN-36950 RTZ when creating a NEW payment on a NEW batch entry (* character in the PAYLOT field)
   Raz [M:PAY1]FCY        :  Affzo [M:PAY1]FCY
   [M:PAY1]ACCDAT=[0/0/0] :  Affzo [M:PAY1]ACCDAT
   If dim([M:PAY2]BAN)>0
     Raz [M:PAY2]BAN
   Elsif dim([M:PAY1]BAN)>0
     [M:PAY1]BAN = "" :  Affzo [M:PAY1]BAN
     # ISSUE 39256 - 2017-09-08 MRDAB - Enter payments from BCREG
     If GFONCTION1 <> 'GESBCREG'
       Actzo [M:PAY1]BAN
     Endif
     # ISSUE END
   Endif
   Raz [M:PAY1]REF   :  Affzo [M:PAY1]REF
 Endif
 #*YYFIN-36950 >

End
##############################

$S_PAYLOT
OBJET="PYL"
CRITERE="PAYTYP='"+GFONC1+"'"
Return

Subprog AS_LOTDES(VALEUR)
Variable Char    VALEUR()
If [M]PAYLOT="" : mkstat=1 : Endif
End

##############################################################
## Etiquettes des infos d'entête de règlement : PAY1 & PAY2 ##
##############################################################

Subprog AS_FCY(VALEUR)
Variable Char     VALEUR
Local Char SITE(GLONFCY) : SITE=VALEUR
Call INIFCY(SITE,"") From CPTSUB
If mkstat
 mkstat=0 : Call AP_FCY(SITE)
 If mkstat : mkstat=0 : Else VALEUR=SITE : mkstat=2 : Endif
Elsif SITE<>""
 Call AP_FCY(SITE) : If !mkstat : VALEUR=SITE : Else mkstat=0 : Endif
Endif
End

Subprog AP_FCY(VALEUR)
Variable Char     VALEUR
Local Integer OK
Local Char    OPT(10), DEVLED(GLONCUR)
Local Char    DEPMOD(10)
If !clalev([F:TPY2]) : Local File TABPAYTYP [TPY2] : Endif
# Adaptation Multi-legislation pour transaction
If GFLAG<>""
 If clalev([F:FCY])=0 : Local File FACILITY  [FCY] : Endif
 If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
 Call LECTURE("FCY",VALEUR,"") From CONTOBJ
 Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
 If dim(GFLAGLEG)<1
  Global Char GFLAGLEG(GLONADI) : GFLAGLEG=[F:CPY]LEG
 Endif
 Call LEC_TPY_LEG(GFLAGLEG,GFLAG) From CPTLEC
 If [F:TPY]LEG<>""
  If [F:CPY]LEG<>[F:TPY]LEG
   # Réservé à la législation
   GMESSAGE += mess(198,117,1)-GFLAG+";"+GFLAGLEG+"\"+mess(62,127,1)-":"-[F:TPY]LEG
   mkstat = 2 : End
  Endif
 Else
  Read [TPY2]TPY0 = GFLAG;[F:CPY]LEG
  If !fstat
   If [F:TPY2]ENAFLG=2
    GMESSAGE +=func AFNC.MESNC(mess(264,117,1),GFLAG+"~"+[F:CPY]LEG)
    mkstat = 2 : End
   Else
    Gosub TIT From WOTPY
    GMESSAGE = TIT-":"-GFLAG-[F:CPY]LEG
    GMESSAGE += "\"+mess(2,126,1)
    mkstat = 2 : End
   Endif
  Endif
 Endif
Endif
GGRPFCY = [F:TPY]GFY
Call GETSOC(VALEUR) From DEVSUB
Call PARAM(GSOCIETE,"DEPMGTMOD",DEPMOD) From ADOVAL
GDEPMGTMOD=val(DEPMOD)
#----------------------------------------------#
#  Info : GCURLEG is set in this call GETSOC   #
#----------------------------------------------#
If dim([M]PAYLOT)>0 & [M]PAYLOT<>"" & [M]PAYLOT<>"*"
 Call LECTURE("FCY",VALEUR,"") From CONTOBJ
 If fstat=0 & [F:FCY]LEGCPY<>[M]CPY
  # Lot de saisie de société
  GMESSAGE=mess(110,121,1)-[M]CPY : mkstat=2 : End
 Endif
Endif
If VALEUR<>[M]FCY & [M]NBLIG
 OK=1 : Call LECTURE("FCY",VALEUR,"") From CONTOBJ
 If fstat=0 & [F:FCY]LEGCPY<>[M]CPY : OK=0
 Elsif sigma(0,[M]NBLIG-1,[M]FCYLIN(indcum)<>VALEUR)
  Call PARAM(VALEUR,"SEVFCYENT",OPT) From ADOVAL
  Case OPT
   When "1"
    OK=0
   When "3" : # Génération OD-sites
    OK=2 : Call AVERTIR(mess(18,117,1),OK) From GESECRAN
    If OK<>2 : mkstat=2 : End : Endif
  Endcase
 Endif
 If !OK : # Annuler d'abord les lignes d'imputations
  GMESSAGE=mess(25,117,1) : mkstat=2 : End
 Endif
Endif
[M]CURCPY=""
Call LECTURE("FCY",VALEUR,"") From CONTOBJ
If fstat
 [M]CPY=""
Else
 If [M]CPY<>[F:FCY]LEGCPY : Gosub INISTD : Endif
 [M]CPY=[F:FCY]LEGCPY
 Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
 Call SETCUR(1,[F:CPY]CPY,DEVLED) From CPTDIV
 [M]CURCPY=DEVLED
Endif
Affzo [PAY1]CPY
If OPT="" : Call PARAM(VALEUR,"SEVFCYENT",OPT) From ADOVAL : Endif
[M]FCYOPT=val(OPT) : # OD inter-sites
Call PARAM(VALEUR,"SEVBPRENT",OPT) From ADOVAL : [M]BPROPT=val(OPT) : # OD inter-tiers
Call PARAM(VALEUR,"PRCAMTCNV",OPT) From ADOVAL : [M]PRCAMTCNV=val(OPT)
Call PARAM([M]CPY,"SOICPT",OPT) From ADOVAL    : [M]SOICPT=val(OPT)
Call PARAM([M]CPY,"BPCORDTYP",[M]BPCTYP) From ADOVAL : # CCL
Call PARAM([M]CPY,"BPSORDTYP",[M]BPSTYP) From ADOVAL : # CCF
If dim([M]PROTYP)>0 and func AFNC.ACTIV("KIT")   # Issue X3-107197
 Call PARAM([M]CPY,"BPSPROTYP",[M]PROTYP) From ADOVAL : # PRO
Endif
#--- 1er règlement de la transaction... les valeurs du masque ont été RAZ (cf INIMSK) - Issue ${72475}
If dim([M]INIVAR)>0 & [M]INIVAR=0
 Local Char LLEVPAZ(3)
 Call PARAMUTIL("NIVBONPAYE",LLEVPAZ,"","") From SUBAUS
 [M]USRPAZ=val(LLEVPAZ)
 [M]MAXPAZ=len(mess(0,510,1))
 If dim([M]RTZCUR)>0 :
  Local Char    RTZCUR(GLONCUR)
  Call PARAM("","RTZCUR",[L]RTZCUR) From ADOVAL
  [M]RTZCUR=[L]RTZCUR
 Endif
 Local Char COMPTLOT(GLONANM)
 Local Integer OKTCA
 [L]COMPTLOT = ""
 Call LECTCA(3,OKTCA) From SUBTCA
 If OKTCA
  [L]COMPTLOT = [F:TCA]CODNUM(6)
 Endif
 [M]COMPTLOT=[L]COMPTLOT
 [M]INIVAR=1
Endif
If dim(GSDDMGT)>0
 Call PARAM([M]CPY,"SDDMGT",OPT) From ADOVAL
 GSDDMGT=val(OPT)
Endif
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
Call LECTURE("FCY",VALEUR,"") From CONTOBJ
If [M]CPY <> [F:FCY]LEGCPY | [M]COA=""  #F62255
 Gosub INISTD
Endif

# Localization Switzerland, 2015-06-24 Bader
Local Integer SOK
Call EXISTE_ADX("","","SUBPAYSWI",SOK) From ORDSYS
If SOK : Call AM_FCY(VALEUR) From SUBPAYSWI : Endif
# End Localization Switzerland

#YYFIN_X3-4142/MDJ BP balance calculation
If dim([M]SOLDE)>0
 Local Decimal RSOLDE
 Call SOLD_CALC([M]BPRSAC,[M]ACC,[M]BPR,VALEUR,[M]CUR,[M]ACCDAT,RSOLDE) From SUBPAY
 If dim([M:PAY2]SOLDE)>0
  [M:PAY2]SOLDE=RSOLDE : Affzo [M:PAY2]SOLDE
 Elsif dim([M:PAY1]SOLDE)>0
  [M:PAY1]SOLDE=RSOLDE : Affzo [M:PAY1]SOLDE
 Endif
Endif  #YYFIN_X3-4142/MDJ END

# Issue X3-61594
  [M:PAY1]FCY = VALEUR
  Gosub SET_GFCY From SUBPAY3
# End issue X3-61594

End

$INISTD
Local Integer OK
Local Integer AXE
Local Char    MODELE(GLONGCM)
[M]CPY = [F:FCY]LEGCPY
Raz [M]LSTAXE
Call SETGCM([M]CPY,MODELE) From CPTDIV
Call SETPLAN2(MODELE,GNBPLAN,GPLAN,GTYPLED,GNBAXE,GAXE,GOBLIG) From CPTDIV
[M]COA = GPLAN(1)
For AXE=1 To GNBAXE
 [M]DIE(AXE-1) = GAXE(AXE)
Next
GNBTYPLED = GNBPLAN
Call AFFCOL From SUBPAY3
Gosub SETCHPAXE From SUBPAY3

# Gestion des éditions
Local Char    ADI304(20)
Call LEC_TED(GCURLEG,[F:TPY]CODEDT) From CPTLEC
If !fstat : [L]ADI304 = [F:TED]TRT Else [L]ADI304="" : Endif
Filter [ARX] # cf CHKLIB
If [L]ADI304<>""
 Read [ARX]ARX0(1) ="PAY"+[L]ADI304
 If fstat=0 : GFLEDI=1 : Endif
 Read [ARX]ARX0(1) ="PAY"+[L]ADI304+"EUR"
 If fstat=0 : GFLEDIEUR=1 : Endif
Else
 GFLEDI = 0
 GFLEDIEUR = 0
Endif
Return

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
End

Subprog C_BPR(VALEUR)
Variable Char     VALEUR

Call LECTURE("BPR",VALEUR,"") From CONTOBJ
Call LEC_TPY_LEG(GCURLEG,GFLAG) From CPTLEC
If GREP="C" | GREP="D" | VALEUR<>[M]BPR
 If [F:TPY]SNS=1
  Call FOUBAP(VALEUR) From SUBPAY2
  If GMESSAGE<>"" : mkstat=2 : End : Endif
 Endif
 If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:TPY]SNS=2 & [F:TPY]EPACDTTRF=2 & VALEUR=""
  GMESSAGE=mess(10,123,1) : mkstat=2 : End
 Endif
Endif
End

Subprog AM_BPR(VALEUR)
Variable Char     VALEUR
Local Integer NOL, OK, STAT
Local Char    OBPR(GLONBPR)
If VALEUR<>""
 If [M]BPRSAC<>""
  OBPR=[M]BPR : [M]BPR=VALEUR
  Call D_BPRSAC([M]BPRSAC)
  Call C_BPRSAC([M]BPRSAC) : [M]BPR=OBPR
  If mkstat : mkstat=0 : STAT=1 : Endif
 Endif
 If find([M]BPROPT,1,3)
  OK=1
  For NOL=0 To [M]NBLIG-1
   If [M]DUDNUM(NOL)<>0
    Call LEC_CDA_LEG(GCURLEG,[M]DENCOD(NOL)) From CPTLEC
    Read [DUD]DUD1 = [M]DUDNUM(NOL);[M]DUDLIG(NOL)
    If fstat=0 & (([F:DUD]BPR<>VALEUR & [F:DUD]BPRPAY<>VALEUR) | (STAT & [F:CDA]ACCBPR=""))
     OK=0 : Break
    Endif
   Endif
  Next NOL
  If !OK
   If [M]BPROPT=1
    # Annuler d'abord les lignes d'imputation
    GMESSAGE=mess(25,117,1) : mkstat=2 : End
   Else
    # Génération OD-tiers
    OK=2 : Call AVERTIR(mess(19,117,1),OK) From GESECRAN
    If OK<>2 : mkstat=2 : End : Endif
   Endif
  Endif
 Endif
 If STAT | [M]BPRSAC="" : Effzo BPRSAC, ACC : GMESSAGE="" : Endif
Else
 Effzo ACC
Endif
Raz [M]BID, [M]PAB1, [M]PAB2, [M]BIDCRY , [M]BPAINV, [M]BPAADDLIG(0),[M]BPAADDLIG(1),[M]BPAADDLIG(2)
Raz [M]POSCOD, [M]SAT, [M]CTY
If clalev([M:PYB]) : Raz [M:PYB] : Endif
If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:TPY]SNS=2 & [F:TPY]EPACDTTRF=2
 If [M]NBLIG : GMESSAGE=mess(25,117,1) : mkstat=2 : End : Endif
 Raz [M]UMRNUM,UMRSEQ
Endif

#YYFIN_X3-4142/MDJ BP balance calculation
If dim([M]SOLDE)>0
 Local Decimal RSOLDE
 Call SOLD_CALC([M]BPRSAC,[M]ACC,VALEUR,[M]FCY,[M]CUR,[M]ACCDAT, RSOLDE)  From SUBPAY
 If dim([M:PAY2]SOLDE)>0
   [M:PAY2]SOLDE=RSOLDE : Affzo  [M:PAY2]SOLDE
 Elsif dim([M:PAY1]SOLDE)>0
  [M:PAY1]SOLDE=RSOLDE : Affzo  [M:PAY1]SOLDE
 Endif
Endif  #YYFIN_X3-4142/MDJ END

[M]BPR=VALEUR

If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If dim([F:CPY]BDFECOCOD)>0 Then
 # Calcul du code motif économique
 Local Char    ECOCOD
 Local Integer STAT
 Call CALC_BDFECOCOD(GFLAG,VALEUR,[M]BID,[M:PAY1]BPAINV,[M:PAY1]AMTCUR,[M:PAY1]CUR,[M:PAY1]ACCDAT,[M]CPY,ECOCOD,STAT) #CHECK IGNORE_LINE
 If STAT>0 Then
 If ECOCOD="" or [M]BDFECOCOD="" Then
  [M]BDFECOCOD = ECOCOD
  If dim([M:PAY1]BDFECOCOD)>0 Then
   Affzo [M:PAY1]BDFECOCOD, ZBDFECOCOD #CHECK IGNORE_LINE
  Endif
  If dim([M:PAY2]BDFECOCOD)>0 Then
   Affzo [M:PAY2]BDFECOCOD, ZBDFECOCOD #CHECK IGNORE_LINE
  Endif
Endif
 Endif
Endif

# Localization Switzerland, 2015-05-21 Bader
Local Integer SOK
If dim(GSWIPAYBVR) > 0 and GSWIPAYBVR = 2 : # parameter "Swiss checks in payments" = yes?
  Call EXISTE_ADX("","","SUBPAYSWI",SOK) From ORDSYS
  If SOK : Call AM_BPR(VALEUR) From SUBPAYSWI : Endif
Endif
# End Localization Switzerland



End

#--------------#
# code adresse #
#--------------#

#Init TYPADR utilisé pour passer en param de la sélection du BPAINV
Subprog AV_BPAINV(VALEUR)
Variable Char    VALEUR()
If [M]BPR<>"" : [M]TYPADR=1
Elsif [M]ACC<>"" : [M]TYPADR=5
Endif
End

Subprog D_BPAINV(VALEUR)
Variable Char    VALEUR()
If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:TPY]SNS=2 & [F:TPY]EPACDTTRF=2 & [M]UMRNUM<>""
 Call  INIT_ADD([M]UMRNUM,VALEUR) From PAYSDDLIB
 Gosub LECADR : Gosub AFFADR : End
Endif


##
#Initialise le code adresse avec adresse par defaut du Tiers ou du Compte
If [M]BPR<>""
 Call INIADR([M]BPR,VALEUR)
Elsif [M]BPR="" & [M]ACC<>""
 Call LECTURE("GAC",[M]ACC,GPLAN(1)) From CONTOBJ
 If fstat : End : Endif
 VALEUR = [F:GAC]BPAADD
Endif
End

#ATTENTION étiquette appelé par SUBPAY3 et TRTVENFACP.
#Ne pas modifier.

Subprog INIADR(TIERS,CODADR)
Value    Char TIERS()
Variable Char CODADR()
If clalev([F:TPY])=0 : Local File TABPAYTYP [TPY] : Endif
Call LECTURE("BPR",TIERS,"") From CONTOBJ
Call LEC_TPY_LEG(GCURLEG,GFLAG) From CPTLEC
#si tiers four. et client cde adr depend sns=recette alors client sns=depense alors four.
If [F:BPR]BPCFLG=2 & [F:BPR]BPSFLG=2
 If [F:TPY]SNS=2
  Call LECTURE("BPC",TIERS,"")  From CONTOBJ
  ##120883
  #CODADR = [F:BPC]BPAPYR
  If [F:BPC]BPCPYR<>TIERS
   Filter [BPA] Where BPATYP=1 & BPANUM=TIERS & BPAADDFLG=2
   Read [BPA]BPA0 First
   CODADR = [F:BPA]BPAADD
   Filter [BPA]
  Else
   CODADR = [F:BPC]BPAPYR
  Endif
 Else
  If [F:TPY]SNS=1
   Call LECTURE("BPS",TIERS,"")  From CONTOBJ
   ##120883
   #CODADR = [F:BPS]BPAPAY
   If [F:BPS]BPRPAY<>TIERS
    Filter [BPA] Where BPATYP=1 & BPANUM=TIERS & BPAADDFLG=2
    Read [BPA]BPA0 First
    CODADR = [F:BPA]BPAADD
    Filter [BPA]
   Else
    CODADR = [F:BPS]BPAPAY
   Endif
  Endif
 Endif
#si Tiers client alors adr client
Elsif [F:BPR]BPCFLG=2 & [F:BPR]BPSFLG<>2
 Call LECTURE("BPC",TIERS,"")  From CONTOBJ
 ##120883
 #CODADR = [F:BPC]BPAPYR
 If [F:BPC]BPCPYR<>TIERS
  Filter [BPA] Where BPATYP=1 & BPANUM=TIERS & BPAADDFLG=2
  Read [BPA]BPA0 First
  CODADR = [F:BPA]BPAADD
  Filter [BPA]
 Else
  CODADR = [F:BPC]BPAPYR
 Endif
#si tiers four alors adr four
Elsif [F:BPR]BPCFLG<>2 & [F:BPR]BPSFLG=2
 Call LECTURE("BPS",TIERS,"")  From CONTOBJ
 ##120883
 #CODADR = [F:BPS]BPAPAY
 If [F:BPS]BPRPAY<>TIERS
  Filter [BPA] Where BPATYP=1 & BPANUM=TIERS & BPAADDFLG=2
  Read [BPA]BPA0 First
  CODADR = [F:BPA]BPAADD
  Filter [BPA]
 Else
  CODADR = [F:BPS]BPAPAY
 Endif
#si Tiers ni four. ni client mais Tiers divers alors adr par défaut de tiers
Elsif [F:BPR]BPCFLG<>2 & [F:BPR]BPSFLG<>2 & [F:BPR]BPRACC=2
 Filter [BPA] Where BPATYP=1 & BPANUM=TIERS & BPAADDFLG=2
 Read [BPA]BPA0 First
 CODADR = [F:BPA]BPAADD
 Filter [BPA]
Endif
End

Subprog AS_BPAINV(VALEUR)
Variable Char    VALEUR()
If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:TPY]SNS=2 & [F:TPY]EPACDTTRF=2 & VALEUR<>""
 mkstat = 2 : End
Endif
End


Subprog C_BPAINV(VALEUR)
Variable Char    VALEUR()
Local Char BPA(GLONBPA)
If VALEUR<>"" & VALEUR<>[M]BPAINV
 If [M]TYPADR=1
  Read [BPA]BPA0 = 1;[M]BPR;VALEUR
  If fstat
   # Adresse inexistante
   GMESSAGE = mess(10,119,1)
   mkstat = 2 : End
  Endif
 Elsif [M]TYPADR = 5
  BPA = format$("K:3X",[M]COA)+[M]ACC
  Read [BPA]BPA0 = 5;BPA;VALEUR
  If fstat
   # Adresse inexistante
   GMESSAGE = mess(10,119,1)
   mkstat = 2 : End
  Endif
 Endif
Endif
End

Subprog AM_BPAINV(VALEUR)
Variable Char    VALEUR()
Gosub LECADR
Gosub AFFADR
#Si adresse modifiée en création alors il faut vérifier le RIB.
If [M]BID <> "" & GREP <> "C"
 #Adresse modifiée, vérifiez votre RIB
 Call MESSAGE(mess(248,117,1))From GESECRAN
Endif
# Calcul du code motif économique si la société
# est déclarante directe. Sinon, le changement d'adresse n'a pas d'impact
Local Char       ECOCOD
Local Integer    STAT, DCLDIR
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If dim([F:CPY]BDFECOCOD)>0 Then
 Call SRC_DCLDIR([M]CPY,DCLDIR)
 If DCLDIR=G_OUI Then
  Call CALC_BDFECOCOD(GFLAG,[M:PAY1]BPR,[M]BID,VALEUR,[M:PAY1]AMTCUR,[M:PAY1]CUR,[M:PAY1]ACCDAT,[M]CPY,ECOCOD,STAT) #CHECK IGNORE_LINE
  If STAT>0 Then
   If ECOCOD="" or [M]BDFECOCOD="" Then
    [M]BDFECOCOD = ECOCOD
    If dim([M:PAY1]BDFECOCOD)>0 Then
     Affzo [M:PAY1]BDFECOCOD, ZBDFECOCOD #CHECK IGNORE_LINE
    Endif
    If dim([M:PAY2]BDFECOCOD)>0 Then
     Affzo [M:PAY2]BDFECOCOD, ZBDFECOCOD #CHECK IGNORE_LINE
    Endif
   Endif
  Endif
 Endif
Endif
End

$LECADR
Local Char BPA(GLONBPA)
Raz [M]BPRNAM, [M]BPAADDLIG
Case [M]TYPADR
 When 1 : Read [BPA]BPA0 = 1;[M]BPR;VALEUR
 When 5 : BPA = format$("K:3X",[M]COA)+[M]ACC
          Read [BPA]BPA0 = 5;BPA;VALEUR
Endcase
If !fstat
 For I=0 To min(dim([M]BPAADDLIG),dim([F:BPA]BPAADDLIG))-1
  [M]BPAADDLIG(I) = [F:BPA]BPAADDLIG(I)
 Next I
 [M]POSCOD = [F:BPA]POSCOD
 [M]CTY    = [F:BPA]CTY
 [M]CRY    = [F:BPA]CRY
 [M]SAT    = [F:BPA]SAT
 If [F:BPA]CRYNAM<>"" : [M]CRYNAM = [F:BPA]CRYNAM
 Else [M]CRYNAM="" : Call INIPAYS([F:BPA]CRY,[M]CRYNAM) From TRTDIV
 Endif
Endif
Call LECTURE("BPC",[M]BPR,"") From CONTOBJ
For I=0 To min(dim([M]BPRNAM),dim([F:BPC]BPCNAM))-1
 [M]BPRNAM(I) = [F:BPC]BPCNAM(I)
Next I
Return

$AFFADR
If !GIMPORT : Affzo BPRNAM, BPAADDLIG, POSCOD, CTY, CRY, CRYNAM : Endif
Return

##################
Subprog D_BPRSAC(VALEUR)
Variable Char     VALEUR
If [M]BPR="" : End : Endif
Local Integer I
Local Char PRIO(2)
Local Char CODCPT(GLONCAC)
Call LECTURE("BPR",[M]BPR,"") From CONTOBJ
If fstat : End : Endif
Call LEC_TPY_LEG(GCURLEG,GFLAG) From CPTLEC
If [F:TPY]SNS=1 : PRIO="FC" : Else PRIO="CF" : Endif
For I=1 To 3
 Case mid$(PRIO,I,1)
  When "C" : # Client
   If [F:BPR]BPCFLG=2
    Call LECTURE("BPC",[M]BPR,"") From CONTOBJ
    Call INIT_COMPTE([M]BPR,GSOCIETE,"C",CODCPT) From CPTSUB
    If [L]CODCPT<>"" & [F:BPC]BPCSTA=2
     Call LECTURE("CAC",[L]CODCPT,"2~"+GPLAN(1)) From CONTOBJ
     Call LECTURE("GAC",[F:CAC]ACC(0),GPLAN(1)) From CONTOBJ
     If [F:GAC]AUZBPR(0)=2 : VALEUR=[F:GAC]ACCSHO : Break : Endif
    Endif
   Endif
  When "F" : # Fournisseur
   If [F:BPR]BPSFLG=2
    Call LECTURE("BPS",[M]BPR,"") From CONTOBJ
    Call INIT_COMPTE([M]BPR,GSOCIETE,"F",CODCPT) From CPTSUB
    If [L]CODCPT<>"" & [F:BPS]ENAFLG=2
     Call LECTURE("CAC",[L]CODCPT,"3~"+GPLAN(1)) From CONTOBJ
     Call LECTURE("GAC",[F:CAC]ACC(0),GPLAN(1)) From CONTOBJ
     If [F:GAC]AUZBPR(1)=2 : VALEUR=[F:GAC]ACCSHO : Break : Endif
    Endif
   Endif
  When Default
   If [F:BPR]ACCCOD<>""
    Call LECTURE("CAC",[F:BPR]ACCCOD,"17~"+GPLAN(1)) From CONTOBJ
    Call LECTURE("GAC",[F:CAC]ACC(0),GPLAN(1)) From CONTOBJ
    If [F:GAC]AUZBPR(5)=2 : VALEUR=[F:GAC]ACCSHO : Break : Endif
   Endif
 Endcase
Next I
End

Subprog AS_BPRSAC(VALEUR)
Variable Char     VALEUR
If [M]BPR="" : mkstat=1 : Endif
End

Subprog C_BPRSAC(VALEUR)
Variable Char     VALEUR
Local Integer OK, NOL
If VALEUR="" : End : Endif

If [F:GAC]ACCSHO<>VALEUR : Read [GAC]GAC1 = GPLAN(1);VALEUR : Else fstat=0 : Endif
If fstat | [F:GAC]SAC<>2
 # Collectif inexistant
 GMESSAGE = mess(9,106,1)
 mkstat = 2 : End
Else
 Call CONTACC(GTYPGEN,GPLAN(1),[F:GAC]ACC,[M]FCY,[M]CUR,[M]ACCDAT) From CPTCNT
 If mkstat : End : Endif
Endif
Call LECTURE("BPR",[M]BPR,"") From CONTOBJ
Gosub CONT_BPRACC From SUBPAY2 : If mkstat : End : Endif
If VALEUR<>[M]BPRSAC & VALEUR<>""
 Gosub CHG_ACC
 If mkstat=0 & find([M]BPROPT,1,3)
  OK=1
  For NOL=0 To [M]NBLIG-1
   If [M]DUDNUM(NOL)<>0
    Call LEC_CDA_LEG(GCURLEG,[M]DENCOD(NOL)) From CPTLEC
    Read [DUD]DUD1 = [M]DUDNUM(NOL);[M]DUDLIG(NOL)
    If fstat=0 & [F:CDA]ACCBPR="" & [F:DUD]SAC<>VALEUR : OK=0 : Break : Endif
   Endif
  Next NOL
  If !OK
   If [M]BPROPT=1 : # Annuler d'abord les lignes d'imputation
    GMESSAGE = mess(25,117,1) : mkstat=2 : End
   Else : # Génération OD-tiers
    OK=2 : Call AVERTIR(mess(19,117,1),OK) From GESECRAN
    If OK<>2 : mkstat=2 : End : Endif
   Endif
  Endif
 Endif
Endif
End

$CHG_ACC
For NOL=0 To [M]NBLIG-1
 Call LEC_CDA_LEG(GCURLEG,[M]DENCOD(NOL)) From CPTLEC
 If [F:CDA]ACCTYP=1 & [F:CDA]ACCBPR=""
  # Annuler d'abord les lignes d'imputation
   GMESSAGE = mess(25,117,1) : mkstat=2 : Break
 Endif
Next NOL
If mkstat=2 : Return : Endif
Raz [M]BID, [M]PAB1, [M]PAB2, [M]BIDCRY, [M]BPAINV
If clalev([M:PYB]) : Raz [M:PYB] : Endif

#YYFIN_X3-4142/MDJ BP balance calculation
If dim([M]SOLDE)>0 & VALEUR<>[M]ACC
 Local Decimal RSOLDE
 Call SOLD_CALC([M]BPRSAC,VALEUR,[M]BPR,[M]FCY,[M]CUR,[M]ACCDAT, RSOLDE)  From SUBPAY
 If dim([M:PAY2]SOLDE)>0
  [M:PAY2]SOLDE=RSOLDE : Affzo  [M:PAY2]SOLDE
 Elsif dim([M:PAY1]SOLDE)>0
  [M:PAY1]SOLDE=RSOLDE : Affzo  [M:PAY1]SOLDE
 Endif
Endif  #YYFIN_X3-4142/MDJ END

[M]ACC=VALEUR
Return

$DATEXE
Local Decimal EXE, PER
Call GETPER([M]FCY,GTYPGEN,[M]ACCDAT,EXE,PER) From CPTSUB
Call LECTURE("FIY",num$(GTYPGEN),[M]CPY+"~"+num$(EXE)) From CONTOBJ
Return


Subprog AS_ACC(VALEUR)
Variable Char    VALEUR()
If [M]BPRSAC<>""
 If ([F:GAC]ACCSHO<>[M]BPRSAC | [F:GAC]COA<>GPLAN(1)) : Read [GAC]GAC1 = GPLAN(1);[M]BPRSAC : Else fstat=0 : Endif
 If fstat<=2 : VALEUR=[F:GAC]ACC : mkstat=2 : End : Endif
Endif
End

Subprog C_ACC(VALEUR)
Variable Char VALEUR()
Local Integer NOL
If VALEUR="" : End : Endif
Call CONTACC(GTYPGEN,GPLAN(1),VALEUR,[M]FCY,[M]CUR,[M]ACCDAT) From CPTCNT
If VALEUR<>[M]ACC & [M]BPR=""
 For NOL=0 To [M]NBLIG-1
  If [M]VCRNUM(NOL)<>"" : # Annuler d'abord les lignes d'imputation
   GMESSAGE =mess(25,117,1) : mkstat=2 : Break
  Endif
 Next NOL
Endif
If mkstat=0 & VALEUR<>[M]ACC
 Gosub CHG_ACC
 If mkstat=0 & [M]BPR=""
  Raz [M]BPAADDLIG(0),[M]BPAADDLIG(1),[M]BPAADDLIG(2),[M]POSCOD, [M]SAT, [M]CTY
 Endif
Endif
End

Subprog AV_BPRNAM(VALEUR)
Variable Char     VALEUR
If [M]BPR<>""
 Local Integer BPRTYPBIS
 Call BPRTYP([M]BPR,[L]BPRTYPBIS) From SUBAFR
 If ![L]BPRTYPBIS or VALEUR=""
  Call LECTURE("BPR",[M]BPR,"") From CONTOBJ
  VALEUR=[F:BPR]BPRNAM
 Endif
Elsif [M]ACC<>""
 Call LECTURE("GAC",[M]ACC,GPLAN(1)) From CONTOBJ
 If fstat<=2
  Call LECTEXTRA(VALEUR,"GACCOUNT","DESTRA",GPLAN(1),[M]ACC) From ATEXTRA
 Endif
Endif
End

#<*YYFIN-36950
Subprog AS_ACCDAT(VALEUR)
Variable Date     VALEUR
If VALEUR = [0/0/0]
  [M]ACCDAT=datesyst
  Affzo [M]ACCDAT
Endif
End #<*YYFIN-36950 END

Subprog C_ACCDAT(VALEUR)
Variable Date     VALEUR
# dates par modules
If clalev([F:AOB])  = 0 : Local File AOBJET [AOB] : Endif
If find(GREP,"C","D")
 Call LECTURE("AOB",GABREV,"") From CONTOBJ
 Local Integer MODULE
 MODULE = [F:AOB]MODULE
 Call CTLDATMOD(MODULE,VALEUR,GSOCIETE) From CPTSUB
 If mkstat : End : Endif
Endif
#

Call CONTPER(VALEUR,GTYPGEN,[M]FCY) From CPTSUB
If mkstat : End : Endif
If [M]CUR<>''
 Call CONTDEV([M]CUR,VALEUR) From TRTDEV
 If fstat | mkstat : End : Endif
Endif
If [M]BAN<>'' & [M]CUR<>'' & VALEUR<>[M]ACCDAT
 Call CONTBAN(VALEUR,[M]BAN,[M]CUR) From CPTSUB
Endif

#YYFIN_X3-4142/MDJ BP balance calculation
If dim([M]SOLDE)>0 & VALEUR<>[M]ACCDAT
 Local Decimal RSOLDE
 Call SOLD_CALC([M]BPRSAC,[M]ACC,[M]BPR,[M]FCY,[M]CUR,VALEUR,RSOLDE)  From SUBPAY
 If dim([M:PAY2]SOLDE)>0
  [M:PAY2]SOLDE=RSOLDE : Affzo  [M:PAY2]SOLDE
 Elsif dim([M:PAY1]SOLDE)>0
  [M:PAY1]SOLDE=RSOLDE : Affzo  [M:PAY1]SOLDE
 Endif
Endif  #YYFIN_X3-4142/MDJ END

# ISSUE 39256 - 2017-07-18 MRDAB - Enter payments from BCREG
If func AFNC.ACTIV("REGBC") & GFONCTION1 = 'GESBCREG'
  Call LEC_CPY([M:BCREG0]CPY) From CPTLEC
  If func AFNC.PARAM("BCREG", [F:CPY]LEG) = "2"
    If VALEUR < [M:BCREG0]STARTDAT | [M:BCREG0]FINDAT < VALEUR
      Call ECR_TRACE(mess(17,7702,1), 1) From GESECRAN
      mkstat = 2
    Endif
  Endif
Endif
# ISSUE END

End

Subprog C_DUDDAT(VALEUR)
Variable Date     VALEUR
## Si la date d'échéance est inférieure à la date début du premier exercice défini, on met
## un message d'avertissement
Local Integer OK
If clalev([F:FIY2])=0 : Local File FISCALYEAR [FIY2] : Endif
Read [FIY2]FIY0 = [M]CPY ; 1
If !fstat & VALEUR < [F:FIY2]FIYSTR
 OK=2 : Call AVERTIR(mess(73,104,1),OK) From GESECRAN
 If OK<>2 : mkstat=2 : End : Endif
Endif
If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:TPY]SNS=2 & [F:TPY]EPACDTTRF=2
 If VALEUR=[0/0/0] : GMESSAGE=mess(10,123,1) : mkstat=2 : End : Endif
 If clalev([F:MDT])   = 0 : Local File MANDATE   [MDT]   : Endif
 Call LEC_MDT([M]CPY,[M]UMRNUM) From CPTLEC
 If VALEUR<[F:MDT]SIGDAT
  GMESSAGE=mess(289,117,1)-format$("D:"+GFMDAT,[F:MDT]SIGDAT) : mkstat = 2 : End
 Endif
 If VALEUR<>[M]DUDDAT
  If GREP="C" or GREP="D" : Raz [M]UMRSEQ : Endif
  Call CTLSEQ([M]CPY,[M]UMRNUM,[M]UMRSEQ,VALEUR,OK) From PAYSDDLIB
  If mkstat=2 : End : Endif
  If OK=1
   OK=2 : Call AVERTIR(GMESSAGE,OK) From GESECRAN : Raz GMESSAGE
   If OK<>2 : mkstat=2 : End : Endif
  Endif
 Endif
Endif
End

Subprog AS_PAM(VALEUR)
Variable Char     VALEUR
If VALEUR="" | [F:TPY]NBRPAM=1 | [F:TPY]DACPAM=3
 VALEUR=[F:TPY]PAM(0)
 If [F:TPY]NBRPAM=1 : mkstat=2 : Endif
Endif
End

Subprog C_PAM(VALEUR)
Variable Char     VALEUR
If !find(VALEUR,[F:TPY]PAM(0..[F:TPY]NBRPAM-1))
 # Mode de règlement incompatible
 GMESSAGE=mess(1,117,1) : mkstat=2
Endif
End

$S_PAM
OBJET="ADI"
SUPP="3"
CRITERE="find([F]CODE,[F:TPY]PAM(0.."+num$([F:TPY]NBRPAM-1)+"))"
Return

Subprog AV_SNS(VALEUR)
Variable Integer  VALEUR
Call LEC_TPY_LEG(GCURLEG,GFLAG) From CPTLEC
If VALEUR<>0 | [F:TPY]SNS<>3 : End : Endif
If [M]BPR<>""
 Call LECTURE("BPR",[M]BPR,"") From CONTOBJ
 If fstat=0
  If [F:BPR]BPCFLG=2 & [F:BPR]BPSFLG<>2    : VALEUR = 2 : # Recette
  Elsif [F:BPR]BPCFLG<>2 & [F:BPR]BPSFLG=2 : VALEUR = 1 : # Depense
  Endif
 Endif
Endif
If VALEUR=0 & [M]ACC<>""
 Call LECTURE("GAC",[M]ACC,GPLAN(1)) From CONTOBJ
 If fstat=0
  If [F:GAC]UPDBLC=2                             : VALEUR=2
  Elsif [F:GAC]UPDBLC=3                          : VALEUR=1
  Elsif [F:GAC]AUZBPR(0)=2 & [F:GAC]AUZBPR(1)<>2 : VALEUR=2
  Elsif [F:GAC]AUZBPR(0)<>2 & [F:GAC]AUZBPR(1)=2 : VALEUR=1
  Endif
 Endif
Endif
If VALEUR=0 : VALEUR=2 : Endif
[M]SNS = VALEUR
End

Subprog AS_SNS(VALEUR)
Variable Integer  VALEUR
If [M]NBLIG & ([F:TPY]SNS<>3 | sigma(I=0,[M]NBLIG,[M]ACCSNS(I))>[M]NBLIG)
 mkstat=2
Endif
End

Subprog C_SNS(VALEUR)
Variable Integer  VALEUR
If VALEUR=1 & (GREP="C" | GREP="D")
 Call FOUBAP([M]BPR) From SUBPAY2
 If GMESSAGE<>"" : mkstat=2  : #Mode de réglement incompatible
 Endif
Endif
End

Subprog D_BAN(VALEUR)
Variable Char     VALEUR
If [F:TPY]DACBAN=1 : # Obligatoire
 If [F:TPY]BANCSH<>1 : VALEUR=GCSHDEF : Gosub VERF_BAN : End : Endif
 Local Libelle BPRTYP
 Gosub SET_SNS
 Call CLIFOU([M]BPR,GPLAN(1),[M]ACC,[M]SNS,[L]BPRTYP) From PAYDIV
 If [M]BPR<>""
  If [L]BPRTYP=1
   Call LECTURE("BPC",[M]BPR,"") From CONTOBJ
   VALEUR=[F:BPC]PAYBAN
  Else
   Call LECTURE("BPS",[M]BPR,"") From CONTOBJ
   VALEUR=[F:BPS]PAYBAN
  Endif
  Gosub VERF_BAN
 Endif
 If VALEUR="" :
  VALEUR=GBANDEF : Gosub VERF_BAN
  If VALEUR=""
   Call LECTURE("FCY",[M]FCY,"") From CONTOBJ
   VALEUR=[F:FCY]PAYBAN : Gosub VERF_BAN
  Endif
 Endif
Endif
End

#<*YYFIN-36950
Subprog AS_BAN(VALEUR)
Variable Char    VALEUR()
If GREP="C" & VALEUR="" :  Call D_BAN(VALEUR) : Endif
End


$VERF_BAN
If VALEUR<>""
 Call LECTURE("BAN",VALEUR,"") From CONTOBJ
 If [F:BAN]CPY<>"" & [M]CPY<>[F:BAN]CPY    : VALEUR=""
 Elsif [F:BAN]FCY<>"" & [M]FCY<>[F:BAN]FCY : VALEUR=""
 Elsif dim([F:BAN]ACS)>0 & [F:BAN]ACS<>"" : # GH 02/11/99
  Call CONTEXE([F:BAN]ACS) From CPTSUB
  If mkstat : GMESSAGE="" : VALEUR="" : mkstat=0 : Endif
 Endif
Endif
Return

Subprog C_BAN(VALEUR)
Variable Char     VALEUR
If VALEUR=""
 [M]CURBAN=""
Else
 Raz [F:BAN] : # si par tunnel, on a changé la devise de banque
 Call LECTURE("BAN",VALEUR,"") From CONTOBJ
 If [F:BAN]FCY<>"" & [M]FCY<>[F:BAN]FCY
  # Banque/Caisse du site FCY
  GMESSAGE=mess([F:TPY]BANCSH,653,1)-mess(4,117,1)-[F:BAN]FCY : mkstat=2 : End
 Elsif [F:BAN]CPY<>"" & [M]CPY<>[F:BAN]CPY
  # Banque/Caisse de la société CPY
  GMESSAGE=mess([F:TPY]BANCSH,653,1)-mess(5,117,1)-[F:BAN]CPY : mkstat=2 : End
 Elsif dim([F:BAN]ACS)>0 & [F:BAN]ACS<>"" : # GH 02/11/99
  Call CONTEXE([F:BAN]ACS) From CPTSUB
  If mkstat : End : Endif
 Endif
 If func AFNC.ACTIV("SEPP") & func SEPPLIB.SEPP_DOC_PAY()
  If !clalev([F:SER]) : Local File SEPRC [SER] : Endif
  If func SEPPCDT.SEPP_OK(50+mod([M]SNS,2),[F:PYH]NUM,1) & [F:SER]BAN<>"" & VALEUR<>[F:SER]BAN
   GMESSAGE = mess(47,2092,1)
   mkstat = 2 : End
  Else : Raz fstat
  Endif
 Endif
 If [F:TPY]EPACDTTRF=2
  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY]  : Endif
  Call LEC_TCY([F:BAN]CRY) From CPTLEC
  If !fstat & [F:TCY]FLGSEPA<>2 : GMESSAGE=mess(267,117,1) : mkstat = 2 : End : Endif
 Endif
 Raz fstat #YYFIN_93805
 Call CONTDEV([F:BAN]CUR,[M]ACCDAT) From TRTDEV
 If fstat | mkstat : End : Endif
 [M]CURBAN=[F:BAN]CUR
 If [M]CUR<>'' & VALEUR<>[M]BAN
  Call CONTBAN([M]ACCDAT,VALEUR,[M]CUR) From CPTSUB
 Endif
Endif
[M:PAY1]CURAMTBAN = [M:PAY1]CURBAN
Affzo [M:PAY1]CURAMTBAN
#CHECK IGNORE_BEGIN
If dim([M:PAY1]TOTBQE)>0
  [M:PAY1]DEVBQE = [M]CURAMTBAN
  Affzo [M:PAY1]DEVBQE
Elsif dim([M:PAY2]TOTBQE)>0
  [M:PAY2]DEVBQE = [M]CURAMTBAN
  Affzo [M:PAY2]DEVBQE
Endif
#CHECK IGNORE_END
End

$S_BAN
Call LEC_TPY_LEG(GCURLEG,[M]PAYTYP) From CPTLEC
If [F:TPY]BANCSH=2
 OBJET="CAI"
Else
 OBJET="BAN"
Endif
If [M]CPY<>"" : CRITERE = "CPY='"+[M]CPY+"'" : Endif
Return

Subprog AM_BAN(VALEUR)
Variable Char VALEUR()
Call AM_BAN(VALEUR) From CHKLIB
#Issue 31729 – 2017-05-26  by MADOR - As a user I want to be able to compute
#payments with the new rate currency field
Call GET_CURATE(0,0)
#Issue end
End

# SAM 81743: Open Balance control dialog if activated in global parameter,
# transaction and bank account when a new entry batch is created (*)
Subprog AP_BAN(VALEUR)
Variable Char VALEUR()
# if PAYLOT accessible
If  dim([M:PAY0]PAYLOT)>0
  If clalev([F:TPY])=0 : Local File TABPAYTYP [TPY] : Endif
  Local Char P_PROBALCTL(1) : P_PROBALCTL = ""
  Call PARAM([F:TPY]LEG,"PROBALCTL",P_PROBALCTL) From ADOVAL
  If P_PROBALCTL = '2' and [M:PAY0]PAYLOT = '*' and [F:TPY]LOTPROBALCTL = 2
    If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif
    Read [BAN]BAN0 = VALEUR
    If [BAN]BNKPROBALCTL = 2
      Call OPEN_DIALOG( "BALPAY1" ) From CNSRSGSTDLIB
    Endif
  Endif
Endif
End

Subprog AS_CUR(VALEUR)
Variable Char     VALEUR
#70253
#If [M]NBLIG : mkstat=2 : End : Endif
#Gosub SET_SNS

#If clalev([F:TPY])=0 : Local File TABPAYTYP [TPY] : Endif
#If find(GREP,"C","D") & dim([F:TPY]EPACDTTRF)>0 & [F:TPY]EPACDTTRF=2
# VALEUR = GEURO : mkstat = 2 : End
#Endif

If [M]NBLIG=0 : Gosub SET_SNS : Endif

If clalev([F:TPY])=0 : Local File TABPAYTYP [TPY] : Endif
If find(GREP,"C","D") & dim([F:TPY]EPACDTTRF)>0 & [F:TPY]EPACDTTRF=2
 VALEUR = GEURO
 #YYFIN_X3-4142/MDJ
 If dim([M]SOLDE)> 0
  Call AP_CUR(VALEUR)
 Endif #YYFIN_X3-4142/MDJ END
 mkstat = 2 : End
Endif

If [M]NBLIG : mkstat=2 : End : Endif

If VALEUR="" & [M]BPR<>""
 If [M]SNS<>1
  Call LECTURE("BPC",[M]BPR,"") From CONTOBJ
  VALEUR=[F:BPC]CUR
 Else
  Call LECTURE("BPS",[M]BPR,"") From CONTOBJ
  VALEUR=[F:BPS]CUR
 Endif
Elsif VALEUR="" & [M]BPR="" & [M]ACC<>""
 Call LECTURE("GAC",[M]ACC,GPLAN(1)) From CONTOBJ
 VALEUR=[F:GAC]CUR
Endif
If VALEUR="" & [M]BAN<>""
 Call LECTURE("BAN",[M]BAN,"") From CONTOBJ
 VALEUR=[F:BAN]CUR
Endif
If VALEUR="" : VALEUR=[M]CURCPY : Endif

#YYFIN_X3-4142/MDJ
If dim([M]SOLDE)> 0
 Call AP_CUR(VALEUR)
Endif #YYFIN_X3-4142/MDJ END

End


$SET_SNS
Call LEC_TPY_LEG(GCURLEG,GFLAG) From CPTLEC
If [M]SNS=0 & [F:TPY]SNS<3 : [M]SNS=[F:TPY]SNS : Endif
Return

Subprog C_CUR(VALEUR)
Variable Char VALEUR()
If clalev([F:TPY])=0 : Local File TABPAYTYP [TPY] : Endif
If dim([F:TPY]EPACDTTRF)>0 & [F:TPY]EPACDTTRF=2 & VALEUR<>GEURO
 # Appel de AP_CUR
 Call AP_CUR(VALEUR)
 ## Devise incompatible avec un type de règlement SEPA : EUR obligatoire
 GMESSAGE = mess(245,117,1)-":"-GEURO-tolower(mess(4,65,1))
 mkstat = 2 : End
Endif
Call CONTDEV(VALEUR,[M]ACCDAT) From TRTDEV
If fstat | mkstat : End : Endif
If [M]BAN<>'' :#74818 & VALEUR<>[M]CUR
 Call CONTBAN([M]ACCDAT,[M]BAN,VALEUR) From CPTSUB
Endif
[M]CURAMTCUR = VALEUR : Affzo CURAMTCUR
#Issue 31729 – 2017-05-19  by MADOR - As a treasury administrator I want to enable
#and disable the fields regarding currency rates
[M:PAY1]CURCURRAT = [M:PAY1]CURCPY : Affzo [M:PAY1]CURCURRAT
#Issue end
End

Subprog AP_CUR(VALEUR)
Variable Char     VALEUR
Call LECTURE("TCU",VALEUR,"") From CONTOBJ
If fstat=0 : [M]DEVFMT=[F:TCU]CURFMT1 : Endif

#YYFIN_X3-4142/MDJ BP balance calculation
If dim([M]SOLDE)>0 and VALEUR<>[M]CUR
 Local Decimal RSOLDE
 Call SOLD_CALC([M]BPRSAC,[M]ACC,[M]BPR,[M]FCY,VALEUR,[M]ACCDAT,RSOLDE)  From SUBPAY
 If dim([M:PAY2]SOLDE)>0
  [M:PAY2]SOLDE=RSOLDE : Affzo [M:PAY2]SOLDE
 Elsif dim([M:PAY1]SOLDE)>0
  [M:PAY1]SOLDE=RSOLDE : Affzo [M:PAY1]SOLDE
 Endif
Endif  #YYFIN_X3-4142/MDJ END

End

Subprog AS_AMTBAN(VALEUR)
Variable Decimal  VALEUR
If [M]BAN="" | [M]AMTCUR=0 : # DACAMTBAN=3 => Mt banque invisible
 If [F:TPY]DACAMTBAN<>3 : mkstat=1 : Else VALEUR=0 : Endif
Elsif [M]CUR=[M]CURBAN : VALEUR=[M]AMTCUR : mkstat=2
Else
# Si les devises règlt et banque sont toutes 2 'in', le mt banque n'est pas saisi
 Call LECTURE("TCU",[M]CURBAN,"") From CONTOBJ
 If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=[M]ACCDAT)
  Call LECTURE("TCU",[M]CUR,"") From CONTOBJ
  If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=[M]ACCDAT)
   mkstat=1
  Endif
 Endif
Endif
End

Subprog C_AMTBAN(VALEUR)
Variable Decimal  VALEUR
If VALEUR<0 : mkstat=2
Elsif VALEUR<>0 & [M]PRCAMTCNV>0
 Local Decimal MT
 Local Integer STAT
 Local Char    LIBZON(20)
 #Issue 31729 – 2017-06-19  by MADOR - As a treasury administrator I want to enable
 #and disable the fields regarding currency rates
 If [M]CUR = [M]CURCPY
    Call CONVERT4([M]CUR,[M]CURBAN,[M]CURCPY,[F:TPY]RATTYP,[M]ACCDAT,[M]AMTCUR,MT,STAT,[M:PAY1]CURRAT) From TRTDEV
 Else
    Call CONVERT([M]CUR,[M]CURBAN,[M]CURCPY,[F:TPY]RATTYP,[M]ACCDAT,[M]AMTCUR,MT,STAT) From TRTDEV
 Endif
 #Issue end
 If !STAT & abs(VALEUR-MT)>abs(MT*[M]PRCAMTCNV/100)
  Onerrgo ERREUR From CONTROLE
  If !clalev([F:AMZ]) : Local File AMSKZON [AMZ] : Endif
  Onerrgo
  If GERREUR : GERREUR=0
  Else
   Read [AMZ]CODE = "PAY2";"AMTBAN"
   If fstat=0
    Call TEXTE([F:AMZ]INTIT,LIBZON) From OBJDIV
    If LIBZON<>"" : LIBZON-=":" : Endif
   Endif
  Endif
  STAT=1 : # Montant banque : MT1 DEV1 -> MT2 DEV2
  Call AVERTIR(LIBZON-num$([M]AMTCUR)-[M]CUR-"->"-num$(MT)-[M]CURBAN,STAT) From GESECRAN
  If STAT<>2 : mkstat=2 : Endif
 Endif
Endif
#Issue 31729 – 2017-05-19  by MADOR - As a treasury administrator I want to enable
#and disable the fields regarding currency rates
If ([M:PAY1]AMTBAN > 0 and VALEUR = 0) or ([M:PAY1]AMTBAN = 0 and VALEUR > 0)
    Call GET_CURATE(func AMTBAN_NOT_YET_CHANGED,0)
Endif
#Issue end
End

Subprog AS_CHQNUM(VALEUR)
Variable Char    VALEUR()
Call AS_CHQNUM(VALEUR) From CHKLIB
End

Subprog C_CHQNUM(VALEUR)
Variable Char    VALEUR()
Call C_CHQNUM(VALEUR) From CHKLIB
End

Subprog AM_CHQNUM(VALEUR)
Variable Char  VALEUR
VALEUR=vireblc(VALEUR,2)
Call AM_CHQNUM(VALEUR) From CHKLIB

If GREP<>"C" & GREP<>"D" & [F:TPY]EDTFLG=2 & VALEUR=""
 If !clalev([F:TED]) : Local File TABCODEDT [TED] : Endif
 Call LEC_TED(GCURLEG,[F:TPY]CODEDT) From CPTLEC
 If !fstat & [F:TED]TRT="CHE"
  Gosub SET_SNS
  If [M]SNS=1 : # chèque émis avec impression obligatoire avant remise en banque
   If clalev([F:PYH])=0 : Local File PAYMENTH [PYH] : Endif
   Read [PYH]PYH0 = [M]NUM
   If [F:PYH]STA>=9 | [F:PYH]STAFLG(8)=2
    # Zone obligatoire
    GMESSAGE=mess(10,123,1) : VALEUR=[M]CHQNUM : mkstat=2
   Endif
  Endif
 Endif
Endif
End

Subprog AS_FRMTYP(VALEUR)
Variable Integer  VALEUR
If !clalev([F:TED]) : Local File TABCODEDT [TED] : Endif
Call LEC_TED(GCURLEG,[F:TPY]CODEDT) From CPTLEC
If !fstat & [F:TED]TRT="CHE" : VALEUR=1 : mkstat=2 : Endif
End

Subprog D_VALDAT(VALEUR)
Variable Date VALEUR
If [F:TPY]DACDUDDAT=3 | [M]DUDDAT=[0/0/0]
 VALEUR=[M]ACCDAT
Else
 VALEUR=[M]DUDDAT
Endif
End

############ RIB bancaire        ###############

Subprog D_BIDCRY(VALEUR)
Variable Char     VALEUR
Local Integer OK
Local Char CRITBID (100) (0..2)
Local Char    BPA(GLONBPA)

 VALEUR=""
 If ([M]BPR<>"" | [M]ACC<>"") & ([F:TPY]DACBID<>3 | [F:TPY]DACPAB1<>3 | [F:TPY]DACPAB2<>3)
  Onerrgo ERREUR From CONTROLE
  If !clalev([F:BID]) : Local File BID [BID] : Endif
  Onerrgo
  If GERREUR : GERREUR=0 : End : Endif
  If [M]BPR<>""
   Call LECTURE("BPR",[M]BPR,"") From CONTOBJ
   If fstat : End : Endif

   If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:TPY]SNS=2 & [F:TPY]EPACDTTRF=2 & [M]UMRNUM<>""
    If clalev([F:MDT])   = 0 : Local File MANDATE   [MDT]   : Endif
    If [F:MDT]UMRNUM<>[M]UMRNUM | [F:MDT]CPY<>GSOCIETE
     Read [MDT]MDT0 = GSOCIETE;[M]UMRNUM
    Endif
    #Recherche du rib du mandat
    CRITBID (0)   = " [F:BID]BPATYP=1 & [F:BID]BPANUM='"+[M]BPR+"'"
    CRITBID (1)  -= " [F:BID]BPAADD ='"+[M]BPAINV+"' & [F:BID]BIDNUM='"+[F:MDT]BIDNUM+"'"
   Else
    #Recherche du rib par défaut associé au code adresse du Tiers; définit dans la
    #fiche Tiers (stocké dans la table BID)
    CRITBID (0)   = " [F:BID]BPATYP=1 & [F:BID]BPANUM='"+[M]BPR+"'"
    CRITBID (1)  -= " [F:BID]BPAADD ='"+[M]BPAINV+"' & [F:BID]BIDNUMFLG=2 "
   Endif
   Filter [BID] Where evalue (CRITBID(0)) & evalue(CRITBID(1))
   Read [BID]BID0 First
   Filter [BID]

  Elsif [M]ACC<>""
   Call LECTURE("GAC",[M]ACC,GPLAN(1)) From CONTOBJ
   If fstat : End : Endif
   Call BPA(GPLAN(1),[M]ACC,BPA) From SUBGAC
   Read [BID]BID0 = 5;[L]BPA;[F:GAC]BIDNUM : # Compte
   If fstat>2
    Read [BID]BID0(2) = 5;[L]BPA
   Endif
  Endif
  If fstat<2
   If [F:TPY]DACBID<>3
    VALEUR=[F:BID]CRY : [M]BID=[F:BID]BIDNUM
    If dim([M:PAY1]BID)>=0 : Affzo [PAY1]BID : Else Affzo [PAY2]BID : Endif
   Endif
   Gosub SET_PAB
   Gosub SET_VII From VISUBID
   If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:TPY]SNS=2 & [F:TPY]EPACDTTRF=2 & [M]UMRNUM<>"" & clalev([M:PYB])>0
    [M:PYB]BICCOD = [F:MDT]BICCOD
    [F:PYH]BICCOD = [F:MDT]BICCOD
   Endif
  Elsif [M]BPR<>"" & [F:TPY]DACBID<>3
   VALEUR=[F:BPR]BIDCRY
  Endif
 Endif
End

$SET_PAB
[M]PAB1=[F:BID]PAB1
If dim([M:PAY1]PAB1)>0 : Affzo [PAY1]PAB1 : Else Affzo [PAY2]PAB1 : Endif
[M]PAB2=[F:BID]PAB2
If dim([M:PAY1]PAB2)>0 : Affzo [PAY1]PAB2 : Else Affzo [PAY2]PAB2 : Endif
Return

Subprog AS_BIDCRY(VALEUR)
Variable Char     VALEUR
If [M]ACC="" : mkstat=1 : End : Endif
If !clalev([F:ACV]) : Local File ACTIV[ACV] : Endif
Read [ACV]CODACT="VII"
If !fstat & [F:ACV]FLACT<>2
 Raz GBOUT2
Endif
If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:TPY]SNS=2 & [F:TPY]EPACDTTRF=2
 mkstat = 2 : End
Endif
End

Subprog C_BIDCRY(VALEUR)
Variable Char    VALEUR()
If [F:TPY]EPACDTTRF=2
 If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY]  : Endif
 Call LEC_TCY(VALEUR) From CPTLEC
 If !fstat & [F:TCY]FLGSEPA<>2 : GMESSAGE=mess(267,117,1) : mkstat = 2 : End : Endif
Endif
End

Subprog D_BID(VALEUR)
Variable Char     VALEUR
Local Integer OK
Local Char CRITBID (100) (0..2)
Local Char    BPA(GLONBPA)

 VALEUR=""
 #Initialiser le RIB en fonction du code adresse Tiers ou du Compte
 If ([M]BPR<>"" | [M]ACC<>"") & ([F:TPY]DACBID<>3 | [F:TPY]DACPAB1<>3 | [F:TPY]DACPAB2<>3)
  Onerrgo ERREUR From CONTROLE
  If !clalev([F:BID]) : Local File BID [BID] : Endif
  Onerrgo
  If GERREUR : GERREUR=0 : End : Endif
  If [M]BPR<>""
   Call LECTURE("BPR",[M]BPR,"") From CONTOBJ
   If fstat : End : Endif

   If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:TPY]SNS=2 & [F:TPY]EPACDTTRF=2 & [M]UMRNUM<>""
    If clalev([F:MDT])   = 0 : Local File MANDATE   [MDT]   : Endif
    If [F:MDT]UMRNUM<>[M]UMRNUM | [F:MDT]CPY<>GSOCIETE
     Read [MDT]MDT0 = GSOCIETE;[M]UMRNUM
    Endif
    #Recherche du rib du mandat
    CRITBID (0)   = " [F:BID]BPATYP=1 & [F:BID]BPANUM='"+[M]BPR+"'"
    CRITBID (1)  -= " [F:BID]BPAADD ='"+[M]BPAINV+"' & [F:BID]BIDNUM='"+[F:MDT]BIDNUM+"'"
   Else
    #Recherche du rib par défaut associé au code adresse du Tiers; définit dans la
    #fiche Tiers (stocké dans la table BID)
    CRITBID (0)   = " [F:BID]BPATYP=1 & [F:BID]BPANUM='"+[M]BPR+"'"
    CRITBID (1)  -= " [F:BID]BPAADD ='"+[M]BPAINV+"' & [F:BID]BIDNUMFLG=2 "
   Endif
   Filter [BID] Where evalue (CRITBID(0)) & evalue(CRITBID(1))
   Read [BID]BID0 First
   Filter [BID]
  Elsif [M]ACC<>""
   #Ou recherche du rib par défaut associé au Compte.
   Call LECTURE("GAC",[M]ACC,GPLAN(1)) From CONTOBJ
   If fstat : End : Endif
   Call BPA(GPLAN(1),[M]ACC,BPA) From SUBGAC
   Read [BID]BID0 = 5;[L]BPA;[F:GAC]BIDNUM : # Compte
   If fstat
    Read [BID]BID0(2) = 5;[L]BPA
   Endif
  Endif
  If !fstat
   If [F:TPY]DACBID<>3
    If dim([M:PAY1]BIDCRY)<0 | [M]BIDCRY="" :  [M]BIDCRY =[F:BID]CRY : Endif
    VALEUR    =[F:BID]BIDNUM
    If dim([M:PAY1]BIDCRY)>=0 : Affzo [PAY1]BIDCRY : Else Affzo [PAY2]BIDCRY : Endif
   Endif
   Gosub SET_PAB
   Gosub SET_VII From VISUBID
   If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:TPY]SNS=2 & [F:TPY]EPACDTTRF=2 & clalev([M:PYB])>0
    [M:PYB]BICCOD = [F:MDT]BICCOD
    [F:PYH]BICCOD = [F:MDT]BICCOD
   Endif
  Elsif [M]BPR<>"" & [F:TPY]DACBID<>3
   If dim([M:PAY1]BIDCRY)<0 | [M]BIDCRY="" :  [M]BIDCRY=[F:BPR]BIDCRY : Endif
  Endif
 Endif
 If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:TPY]SNS=2 & [F:TPY]EPACDTTRF=2
  Call AM_BID(VALEUR)  # Init BDFECOCOD
 Endif
End

Subprog AS_BID(VALEUR)
Variable Char    VALEUR()
If GREP="C" & VALEUR="" :  Call D_BID(VALEUR) : Endif
If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:TPY]SNS=2 & [F:TPY]EPACDTTRF=2
 mkstat = 2 : End
Endif
End


$S_BID
Local Char CRYA(GLONCRY),CRYB(GLONCRY)
Local Integer OKA
#Clic droit: Sélection du Rib
If [M]BPR="" & [M]ACC="" : OK=0 : Return : Endif
Onerrgo ERREUR From CONTROLE
If !clalev([F:BID]) : Local File BID [BID] : Endif
Onerrgo
If GERREUR : GERREUR=0 : OK=0 : Return : Endif
Local Integer I
Local Char FMTBID(30)
Local Char LCOA(GLONCOA)

# Be careful , if the COA is created with two char then it is saved in table BID with a blank
# So if we want to select Bidnum from this COA we should select it with this blank .
LCOA=[M]COA
For I=1 To GLONCOA
 If len([M]COA)>1
  LCOA=[M]COA+" "
 Endif
Next

OBJET=""
If [M]BPR<>""
 CRITERE = "BPATYP=1 & BPANUM='"+[M]BPR+"'"
Else
 CRITERE = "BPATYP=5 & BPANUM='"+LCOA+[M]ACC+"'"
Endif
FMTBID = "30X"

#Parcourir le Pays(CRY) de tous les RIB de la liste : si différents alors le format reste à 30X
#sinon on prend celui du RIB : FMTBID
CRYA=[M]BIDCRY
CRYB=[M]BIDCRY
OKA=1
For [BID]BID0 Where evalue(CRITERE)
 CRYA=[F:BID]CRY
 If CRYA<>CRYB : OKA=0: Break : Endif
 CRYB=CRYA
Next
If OKA
 Call LECTURE("TCY",[M]BIDCRY,"") From CONTOBJ
 If !fstat
  FMTBID = [F:TCY]BIDFMT
 Endif
Endif

Call TITOBJ("BID","",TIT(0)) From CONTOBJ
If [M]BPR<>""
 NBCOL=10
 COL(1)  = "CRY"                        : TIT(1)  = ""
 COL(2)  = "format$(FMTBID,BIDNUM)"     : TIT(2)  = "BIDCRY"
 COL(3)  = "BPAADD"                     : TIT(3)  = mess(33,102,1) # Adresse du RIB
 COL(4)  = "mess([F:BID]ACCNONREI,1,1)" : TIT(4)  = mess(250,117,1) : COLTYP(4)=1 # Non résident
 COL(5)  = "PAB1"                       : TIT(5)  = "PAB1"
 COL(6)  = "PAB2"                       : TIT(6)  = "PAB2"
 COL(7)  = "BPANUM"                     : TIT(7)  = mess(31,105,1)
 COL(8)  = "BPATYP"                     : TIT(8)  = ""
 COL(9)  = "BIDNUM"                     : TIT(9)  = ""
 COL(10) = "CUR"                        : TIT(10) = "CUR"
Else
 NBCOL=11
 COL(1)  = "BNF"                        : TIT(1)  = mess(132,102,1) # Bénéficiaire
 COL(2)  = "CRY"                        : TIT(2)  = ""
 COL(3)  = "BPAADD"                     : TIT(3)  = mess(33,102,1) # Adresse du RIB
 COL(4)  = "mess([F:BID]ACCNONREI,1,1)" : TIT(4)  = mess(250,117,1) : COLTYP(4)=1 # Non résident
 COL(5)  = "format$(FMTBID,BIDNUM)"     : TIT(5)  = "BIDCRY"
 COL(6)  = "PAB1"                       : TIT(6)  = "PAB1"
 COL(7)  = "PAB2"                       : TIT(7)  = "PAB2"
 COL(8)  = "BPANUM"                     : TIT(8)  = mess(30,105,1)
 COL(9)  = "BPATYP"                     : TIT(9)  = ""
 COL(10) = "BIDNUM"                     : TIT(10) = ""
 COL(11) = "CUR"                        : TIT(11) = "CUR"
Endif
Onerrgo CHUT From CONTROLE
If !clalev([F:AMZ]) : Local File AMSKZON [AMZ] : Endif
Onerrgo
If GERREUR : GERREUR=0 : OK=0 : Return : Endif
For I=1 To NBCOL
 Read [AMZ]CODE = "PAY2";TIT(I)
 If fstat=0
  Call TEXTE([F:AMZ]INTIT,TIT(I)) From OBJDIV
 Endif
Next I
If [M]BPR=""
 TIT(8)  = mess(30,105,1)   :# Compte
 TIT(10) = TIT(3)
Else
 TIT(9)  = TIT(2)
Endif
SIZCOL=160 : SIZLIG=80 : START="BIDNUM" : ORDRE="BIDNUM;BPAADD"
Default File [BID]
Return

$V_BID
[M]BIDCRY = [F:BID]CRY
If dim([M:PAY1]BIDCRY)>0 : Affzo [PAY1]BIDCRY : Else Affzo [PAY2]BIDCRY : Endif
Gosub SET_PAB
Gosub SET_VII From VISUBID
Return

