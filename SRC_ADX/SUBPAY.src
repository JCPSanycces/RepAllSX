######################################################################################
Subprog AM_UMRNUM(VALEUR)
Variable Char    VALEUR()
If [M]NBLIG
 # Annuler d'abord les lignes d'imputation
 GMESSAGE=mess(25,117,1) : mkstat=2 : End
Endif
Raz [M]UMRSEQ
End

######################################################################################
Subprog C_UMRNUM(VALEUR)
Variable Char    VALEUR()
If GSDDMGT<>2 | [M]SNS<>2 : End : Endif
If clalev([F:MDT])=0    : Local File MANDATE [MDT] : Endif

If GREP="C" or GREP="D"  or GIMPORT
 If VALEUR=""
  GMESSAGE=mess(10,123,1) : mkstat=2 : End
 Else
  If [F:MDT]UMRNUM<>VALEUR | [F:MDT]CPY<>GSOCIETE
   Read [MDT]MDT0 = GSOCIETE;VALEUR
  Endif
  If fstat or [F:MDT]STA<>2
   GMESSAGE=VALEUR-":"-mess(1125,196,1) : mkstat=2 : End
  Endif
 Endif
Endif
Call CTL_UMRNUM(VALEUR,GSOCIETE,[M]BPR) From INVSDDLIB
If mkstat : End : Endif

If clalev([F:BID])=0 : Local File BID [BID] : Endif
Read [F:BID]BID0=1;[M]BPR;[F:MDT]BIDNUM;[F:MDT]BPCADD
If fstat
 GMESSAGE = mess(27,199,1): mkstat=2 : End
Endif

If VALEUR<>[M]UMRNUM
 Raz [M]UMRSEQ
 Raz [M]BID, [M]BIDCRY , [M]BPAINV
Endif
End
