$SAICCE
Local Char    COMPTE(GLONGAC)
Local Integer NLED, TLED
Local Integer AXI, IND

Gosub SETNOL
If [M]DSP(NOL)<>""
 mkstat=1 : End
Endif
mkstat = 1
For NLED=1 To GNBTYPLED
 [L]TLED = GTYPLED(NLED) : Gosub LECLED From SUBPAY3
 Call INDLED([L]LED,GAXE(AXE),IND,AXI) From CPTDIV
 If AXI
  COMPTE = evalue("[M]ACC"+num$(NLED)+"("+num$(NOL)+")")
  If COMPTE<>"" & !instr(1,COMPTE,"x")
   Call LECTURE("GAC",COMPTE,GPLAN(NLED)) From CONTOBJ
   If find(GAXE(AXE),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1)) : Raz mkstat : Break : Endif
  Endif
 Endif
Next
End

