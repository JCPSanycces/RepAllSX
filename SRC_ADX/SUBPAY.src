Endif
#Issue end
End

######################################################################################
Subprog AM_CURRAT(VALEUR)
Variable Decimal VALEUR
#Issue 91611 – 2018-06-26  by MADOR - Currency rate manually entered in payment is not use in accounting document
Local Char FROCUR(3)
Local Decimal OLD_CURRAT : [L]OLD_CURRAT = [M:PAY1]CURRAT
Local Integer STAT : [L]STAT = 2

[M:PAY1]CURRAT = 0
Call GET_CURATE(0,0)

If [L]VALEUR <> 0
  If [M:PAY1]CURRAT = 0
    [L]FROCUR = seg$([M:PAY1]FROCURRAT, instr(1, [M:PAY1]FROCURRAT, " ") + 1, len([M:PAY1]FROCURRAT)-2)
    Call AVERTIR(func AFNC.MES2(mess(70,109,1), [L]FROCUR, [M]CURCPY), [L]STAT) From GESECRAN
  Endif

  If [L]STAT <> 2
    [M:PAY1]CURRAT = [L]OLD_CURRAT
    [L]VALEUR = [L]OLD_CURRAT
  Else
    [M:PAY1]CURRAT = [L]VALEUR
  Endif

  Affzo [M:PAY1]CURRAT
Endif
#Issue 91611 end
End

######################################################################################
Subprog GET_CURATE(VALEUR,ONSTART)
#Issue 31729 – 2017-05-26  by MADOR - As a user I want to be able to compute
#payments with the new rate currency field
Value Decimal VALEUR              # Current value of CURRAT (Currency rate) field
Value Integer ONSTART             # Flag forcing subrog to check values from currency rate table
                                  # and pass them to labels even if VALUER is not equal 0

Local Integer USE_MAIN_CURRENCY
Local Decimal CURRAT(0..1)
Local Integer STAT
Local Char    FROCURRENCY(10)     # Currency from which we exchange to target currency

USE_MAIN_CURRENCY = ([M]CURBAN = [M:PAY1]CUR or ([M]AMTBAN = 0 and VALEUR <> func AMTBAN_NOT_YET_CHANGED()) or
&                   ([M]AMTBAN <> 0 and VALEUR = func AMTBAN_NOT_YET_CHANGED()))

If VALEUR = func AMTBAN_NOT_YET_CHANGED()
  [L]CURRAT(0) = 0
  VALEUR = 0
Else
  [L]CURRAT(0) = VALEUR
Endif

If [L]CURRAT(0) = 0 or ONSTART = 1
  If USE_MAIN_CURRENCY and [M:PAY1]CUR <> [M]CURCPY
      FROCURRENCY = [M:PAY1]CUR
      Call CONVERT4([M:PAY1]CUR,[M]CURCPY,[M]CURCPY,[F:TPY]RATTYP,[F:PYH]ACCDAT,
&                   [F:PYD]AMTBANFRC,[F:PYD]AMTBANFRC1,STAT,[L]CURRAT) From TRTDEV
  Else
      FROCURRENCY = [M]CURBAN
      Call CONVERT4([M]CURBAN,[M]CURCPY,[M]CURCPY,[F:TPY]RATTYP,[F:PYH]ACCDAT,
&                   [F:PYD]AMTBANFRC,[F:PYD]AMTBANFRC1,STAT,[L]CURRAT) From TRTDEV
  Endif
  If !STAT
    [M:PAY1]FROCURRAT = num$([L]CURRAT(1)) + " " + FROCURRENCY + " ="
    If VALEUR = 0 and [L]CURRAT(0) <> 0
        Actzo [M:PAY1]CURRAT
        [M:PAY1]CURRAT = [L]CURRAT(0)
        Affzo [M:PAY1]CURRAT
    Elsif [L]CURRAT(1) = 0
        If [M:PAY1]CURRAT <> 0
            [M:PAY1]CURRAT = 0
            Affzo [M:PAY1]CURRAT
        Endif
        Grizo [M:PAY1]CURRAT
    Endif
  Else
    [M:PAY1]FROCURRAT = "1 " + FROCURRENCY + " ="
  Endif
  Affzo [M:PAY1]FROCURRAT
Endif
#Issue end
End

######################################################################################
Funprog AMTBAN_NOT_YET_CHANGED()
End -1

