Subprog AV_LIN(VALEUR)
Variable Decimal  VALEUR
VALEUR=nolign
End


Subprog AS_DENCOD(VALEUR)
Variable Char     VALEUR
Gosub SETNOL
If VALEUR="" & [F:TPY]DENDEF<>""
 Call C_DENCOD([F:TPY]DENDEF)
 If mkstat : mkstat=0 : Else VALEUR=[F:TPY]DENDEF : Endif
Endif
End

Subprog C_DENCOD(VALEUR)
Variable Char     VALEUR
Gosub SETNOL
Gosub PYHCPT
If [M]DENCOD(NOL)<>"" & [M]ACCTYP(NOL)<>2 & CPTA : mkstat=2 : End : Endif
Call LEC_CDA_LEG(GCURLEG,VALEUR) From CPTLEC
If fstat : End : Endif
If dim([F:CDA]ACS)>0
 Call CONTEXE([F:CDA]ACS) From CPTSUB
 If mkstat : End : Endif
Endif
If [F:CDA]IPTDAC<>2 & [M]DUDNUM(NOL)<>0 & find([M]IPTTYP(NOL),1,2)
 Call LECDUD([M]DUDNUM(NOL),[M]DUDLIG(NOL)) From SUBPAY2
 If fstat=0 & [F:DUD]PAMTYP=1 & [F:DUD]DINAMT<>0
  # Destination non imputable
  GMESSAGE=mess(60,117,1) : mkstat=2
 Endif
Endif
# Si rglt comptabilisé, seuls autorisés modif/ajout/annul des lignes Bq<=>Cpte
If CPTA & [F:CDA]ACCTYP<>2
 GMESSAGE = mess([F:CDA]ACCTYP,612,1) : mkstat=2
Endif
End

Subprog AP_DENCOD(VALEUR)
Variable Char     VALEUR
Gosub SETNOL
[M]ACCTYP(NOL) = [F:CDA]ACCTYP
[M]ACCSNS(NOL) = [F:CDA]ACCSNS
If GDEPMGTMOD<>4 | VALEUR<>[M]DENCOD(NOL)
 [M]DENCOD(NOL) = VALEUR
 Gosub SET_ACCLIN
Endif
End

$SET_ACCLIN
Local Integer GAIN, SIGN
Call LEC_CDA_LEG(GCURLEG,[M]DENCOD(NOL)) From CPTLEC
If [M]ACCTYP(NOL)<>1
 # GDEPVATLIN & [M]EARDISMGT  : Initialize on PAYDEPLIB3 (DEPMGTMOG=4 & !ECLAT_TVA)
 # GDEPVATLIN   : Using to pick (call SET_ACCLIN in SUBPAY4)
 # [M]EARDISMGT : Using to manage the update of line when creating of payment (Call AP_DENCOD & AP_AMTLIN)
 If (dim(GDEPVATLIN)>0 & GDEPVATLIN<>"") or (dim([M]EARDISMGT)>0 & [M]EARDISMGT(NOL)=4)
  If clalev([F:TVT])=0 : Local File TABVAT [TVT] : Endif
  If dim(GDEPVATLIN)>0 & GDEPVATLIN<>""
   Call LEC_TVT_LEG([F:CPY]LEG,GDEPVATLIN) From CPTLEC
  Else
   Call LEC_TVT_LEG([F:CPY]LEG,[M]VATLIN(NOL)) From CPTLEC
  Endif
  If [F:TVT]ACCCOD<>""
   Call LEC_CAC(10,[F:TVT]ACCCOD,GPLAN(1)) From CPTLEC
   If !fstat
    Case [F:CDA]ACCSNS
     When 2 :# Dépense
      If [M]AMTLIN>0 : GAIN = 1 : Else : GAIN = 2 : Endif
     When 3 :# Recette
      If [M]AMTLIN>0 : GAIN = 2 : Else : GAIN = 1 : Endif
     When Default :# Sens du règlement
      If [M]SNS=1 : GAIN = 2 : Else : GAIN = 1 : Endif
      Call SIGN2([F:CDA]ACCSNS,[M]SNS,[M]DUDNUM(NOL),[M]DUDLIG(NOL),[M]IPTTYP(NOL),SIGN) From PAYDIV
      If SIGN*sgn([M]AMTLIN(NOL))=-1 : GAIN=3-GAIN : Endif
    Endcase
    For I=1 To GNBPLAN
     Call LEC_CAC(10,[F:TVT]ACCCOD,GPLAN(I)) From CPTLEC
     If GAIN=2 : Assign "[M]ACC"+num$(I)+"("+num$(NOL)+")" With [F:CAC]ACC(25)
     Else      : Assign "[M]ACC"+num$(I)+"("+num$(NOL)+")" With [F:CAC]ACC(26)
     Endif
    Next
   Endif
  Elsif [F:TVT]ACCCOD="" & [M]LSTACC(NOL)<>""
   ## Si un code comptable n'est pas défini dans la destination comptable, il se peut que les comptes aient été saisis
   ## (dans l'écran d'imputation comptable)
   Gosub LSTACC
  Endif
  ## Destination Cpt->Tiers et Bq->Cpt : Initialisation des comptes des x référentiels
 Elsif [F:CDA]ACCCOD<>""
  ##  Si un code comptable est défini dans la destination comptable, on initialise
  ##  les comptes des x référentiels saisissables par les comptes définis dans le code comptable
  ##  (et pour le plan comptable correspondant au référentiels, bien entendu....)
  Case [F:CDA]ACCSNS
   When 2 : # Dépense
    If [M]AMTLIN(NOL)>0 : GAIN=1 : Else GAIN=2 : Endif
   When 3 : # Recette
    If [M]AMTLIN(NOL)>0 : GAIN=2 : Else GAIN=1 : Endif
   When Default : # Sens du reglement
    If [M]SNS=1 : GAIN=2 : Else GAIN=1 : Endif
    Call SIGN2([F:CDA]ACCSNS,[M]SNS,[M]DUDNUM(NOL),[M]DUDLIG(NOL),[M]IPTTYP(NOL),SIGN) From PAYDIV
    If SIGN*sgn([M]AMTLIN(NOL))=-1 : GAIN=3-GAIN : Endif
  Endcase
  For I=1 To GNBPLAN
   Call LECTURE("CAC",[F:CDA]ACCCOD,"14~"+GPLAN(I)) From CONTOBJ
   If GAIN=2 : Assign "[M]ACC"+num$(I)+"("+num$(NOL)+")" With [F:CAC]ACC(0)
   Else      : Assign "[M]ACC"+num$(I)+"("+num$(NOL)+")" With [F:CAC]ACC(1)
   Endif
   If [M]BPRLIN(NOL)=""
    Call LECTURE("GAC",evalue("[M]ACC"+num$(I)+"("+num$(NOL)+")"),GPLAN(I)) From CONTOBJ
    If [F:GAC]SAC = 2 : [M]BPRLIN(NOL) = [M]BPR : Endif
   Endif
  Next
 Elsif [F:CDA]ACCCOD="" & [M]LSTACC(NOL)<>""
  ## Si un code comptable n'est pas défini dans la destination comptable, il se peut que les comptes aient été saisis
  ## (dans l'écran d'imputation comptable)
  Gosub LSTACC
 Endif
Elsif [M]ACCTYP(NOL)=1
 ## Destination Bq->Tiers : Initialisation des comptes des x référentiels
 ## 1/ Si un code comptable 'Acompte' est défini dans la destination comptable, on initialise
 ##    les comptes des x référentiels saisissables par les comptes définis dans le code
 ##    comptable 'Acompte' (et pour le plan comptable correspondant au référentiels, bien entendu....)
 ## 2/ Si pas de code comptable 'Acompte' défini dans la destination comptable, le compte
 ##    du référentiel général principal (défini dans [M]ACC1(NOL)) est initialisé par le compte
 ##    saisi en en-tête. Les comptes des autres référentiels sont initialisés par propagation
 If [F:CDA]ACCBPR<>""
  Local Libelle BPRTYP
  Gosub SET_SNS
  Call CLIFOU([M]BPR,GPLAN(1),[M]ACC,[M]SNS,[L]BPRTYP) From PAYDIV
  For I=1 To GNBPLAN
   Call LECTURE("CAC",[F:CDA]ACCBPR,"14~"+GPLAN(I)) From CONTOBJ
   If BPRTYP=1 : Assign "[M]ACC"+num$(I)+"("+num$(NOL)+")" With [F:CAC]ACC(2)
   Else        : Assign "[M]ACC"+num$(I)+"("+num$(NOL)+")" With [F:CAC]ACC(3)
   Endif
  Next
 Elsif [M]ACC<>""
  Assign "[M]ACC"+num$(GTYPGEN)+"("+num$(NOL)+")" With [M]ACC
  [M]BPRLIN(NOL) = [M]BPR
  Gosub INI_OTHACC
 Else
  Local Char BPRSAC(GLONSAC), BPR(GLONBPR)
  [L]BPR=[M]BPR : [L]BPRSAC=[M]BPRSAC
  Gosub SET_BPR
  If [M]BPRSAC<>""
   If [F:GAC]ACCSHO<>[M]BPRSAC
    Read [GAC]GAC1 = GPLAN(1);[M]BPRSAC
    If fstat=0
     Assign "[M]ACC"+num$(GTYPGEN)+"("+num$(NOL)+")" With [M]ACC
    Endif
   Else
    Assign "[M]ACC"+num$(GTYPGEN)+"("+num$(NOL)+")" With [F:GAC]ACC
   Endif
   [M]BPRLIN(NOL) = [M]BPR
   Gosub INI_OTHACC
  Endif
  [M]BPR=[L]BPR : [M]BPRSAC=[L]BPRSAC
 Endif
Endif
Gosub SETCHPLST From SUBPAY3
Return

$INI_OTHACC
Local Char    CRIBLE(20)
Local Char    ACCORG(GLONGAC), ACCDES(GLONGAC)
Local Integer IREF
For I=2 To GNBPLAN
 For IREF=1 To GNBPLAN
  [L]ACCORG = evalue("[M]ACC"+num$(IREF)+"("+num$(NOL)+")")
  If [L]ACCORG<>""
   Call LECTURE("GAC",ACCORG,GPLAN(IREF)) From CONTOBJ
   If find(GPLAN(I),[F:GAC]OTHCOA(0..[F:GAC]COANBR-1))
    Call INIACC(GPLAN(IREF),[L]ACCORG,GPLAN(I),ACCDES,[L]CRIBLE) From CPTINI
    If [L]ACCDES<>""
     ## Le compte du type référentiel I a été initialisé par le type référentiel IREF -> On sort
     Break
    Endif
   Elsif GPLAN(IREF)=GPLAN(I) : # Plans de comptes identiques
    [L]ACCDES = [L]ACCORG
    Break
   Else
    [L]ACCDES = "" : Break
   Endif
  Endif
 Next
 Assign "[M]ACC"+num$(I)+"("+num$(NOL)+")" With [L]ACCDES
Next
Return

$LSTACC
Local Char    LSTCPT(250)
Local Integer X, NBCPT
[L]LSTCPT = [M]LSTACC(NOL)
X = instr(1,[L]LSTCPT,";")
If !X
 Assign "[M]ACC"+num$(1)+"("+num$(NOL)+")" With [L]LSTCPT
Else
 NBCPT = 0
 While [L]LSTCPT<>""
  X = instr(1,[L]LSTCPT,";")
  If X
   Assign "[M]ACC"+num$(NBCPT+1)+"("+num$(NOL)+")" With left$([L]LSTCPT,X-1) : [L]LSTCPT = vireblc(right$([L]LSTCPT,X+1),2)
  Else
   Assign "[M]ACC"+num$(NBCPT+1)+"("+num$(NOL)+")" With [L]LSTCPT : [L]LSTCPT = ""
  Endif
  NBCPT += 1
 Wend
Endif
Return
Subprog D_VCRTYP(VALEUR)
Variable Char     VALEUR
Gosub SETNOL
Call LEC_CDA_LEG(GCURLEG,[M]DENCOD(NOL)) From CPTLEC
If fstat=0 & [F:CDA]IPTDAC=2
 If NOL>0 & [M]ACCTYP(NOL)=3 : # Tiers<=>Compte
  VALEUR=[M]VCRTYP(NOL-1)
 Else
  Case [F:CDA]IPTTYP
   When 1 : VALEUR=[M]BPCTYP
   When 2 : VALEUR=[M]BPSTYP
   When 3 : VALEUR=[F:CDA]IPTCOD
   When 4 : If dim([M]PROTYP)>0 : VALEUR=[M]PROTYP : Endif
  Endcase
 Endif
Endif
End

Subprog AS_VCRTYP(VALEUR)
Variable Char     VALEUR
Gosub SETNOL
If [M]ACC<>"" & [M]BPR="" : [M]IPTTYP(NOL)=0 : mkstat=1 : End : Endif
If [M]DUDNUM(NOL)<>0 & find([M]IPTTYP(NOL),1,2)
 Call LECDUD([M]DUDNUM(NOL),[M]DUDLIG(NOL)) From SUBPAY2
 If fstat=0 & [F:DUD]PAMTYP=1 & [F:DUD]DINAMT<>0 : mkstat=2 : End : Endif
Endif
Call LEC_CDA_LEG(GCURLEG,[M]DENCOD(NOL)) From CPTLEC
If fstat | [F:CDA]IPTDAC<>2 : [M]IPTTYP(NOL)=0 : mkstat=1 : End : Endif
End

Subprog C_VCRTYP(VALEUR)
Variable Char     VALEUR
If VALEUR=""
 Raz [M]BPRINV(indice),[M]BPRSACINV(indice)
 [M]IPTTYP(indice)=0 : End
Endif
Call LEC_GTE_LEG(GCURLEG,VALEUR) From CPTLEC
If fstat
 Case VALEUR
  When [M]BPCTYP : [M]IPTTYP(indice)=1
  When [M]BPSTYP : [M]IPTTYP(indice)=2
  When Default
   If dim([M]PROTYP)>0 & [M]PROTYP=VALEUR : [M]IPTTYP(indice)=4
   Else
    Call CONTGTE(VALEUR,GCURLEG,"") From SUBGTE
    If mkstat = 2 : End : Endif
   Endif
 Endcase
Else
 Call CONTEXE([F:GTE]ACS) From CPTSUB
 If mkstat : End : Endif
 Call LEC_CDA_LEG(GCURLEG,[M]DENCOD(indice)) From CPTLEC
 If [F:CDA]ACCBPR<>""
  # Type de pièce incorrecte
  GMESSAGE = mess(43,106,1)
  mkstat = 2 : End
 Else [M]IPTTYP(indice)=3
 Endif
Endif
End

Subprog AS_VCRNUM(VALEUR)
Variable Char     VALEUR
Gosub SETNOL
If [M]VCRTYP(NOL)=""
 [M]DUDNUM(NOL)=0 : [M]DUDLIG(NOL)=0
 If dim([M]RITAMT)>0 & func AFNC.PARAM("ITARTZ",[M]CPY)="2" : [M]RITAMT2(NOL)=0 : Effzo [M]RITAMT(NOL) : Endif
 mkstat=1 : End
Elsif [M]DUDNUM(NOL)<>0 & find([M]IPTTYP(NOL),1,2)
 Call LECDUD([M]DUDNUM(NOL),[M]DUDLIG(NOL)) From SUBPAY2
 If fstat=0 & [F:DUD]PAMTYP=1 & [F:DUD]DINAMT<>0 : mkstat=2 : End : Endif
Endif
If NOL>0 & [M]ACCTYP(NOL)=3 & [M]VCRTYP(NOL)=[M]VCRTYP(NOL-1)
 VALEUR=[M]VCRNUM(NOL-1) : # Tiers<=>Compte
Endif
# Facture/Commande
GBOUT3 = mess(4,413,1)+"/"+mess(2,413,1)
End

Subprog B3_VCRNUM(VALEUR)
Variable Char     VALEUR
Gosub B3_FACCDE From SUBPAY2
End

Subprog C_VCRNUM(VALEUR)
Variable Char     VALEUR
Local Char SITE(GLONFCY)
Local Char BPRPAY(GLONBPR)
Gosub SETNOL

[M]VCRNUM(NOL)=VALEUR

Case [M]IPTTYP(NOL)
 When 1 : # Cde cli
  Call LECTURE("SOH",VALEUR,"") From CONTOBJ
  If fstat=0
   [L]SITE=[F:SOH]SALFCY
   [L]BPRPAY = [F:SOH]BPCPYR
  Endif
 When 2 : # Cde fou
  Call LECTURE("POH",VALEUR,"") From CONTOBJ
  If fstat=0
   If [F:POH]POHTYP<>1 : GMESSAGE=mess([F:POH]POHTYP,506,1) : mkstat=2 : End : Endif
   [L]SITE=[F:POH]POHFCY
  Endif
 When 4 : # Proforma fournisseur
  Read [PIH]PIH0 = VALEUR
  If fstat | [F:PIH]INVTYP<>5
   GMESSAGE=mess(15,131,1) : mkstat=2 : End : # Proforma fournisseur inexistante
  Elsif [F:PIH]CPY<>[M]CPY
   GMESSAGE=mess(78,119,1)-[F:PIH]CPY : mkstat=2 : End : # Facture passée sur la société
  Elsif [F:PIH]STA<>3
   GMESSAGE=mess(36,119,1) : mkstat=2 : End : # Facture non validée
  Elsif [F:PIH]RITPAY<>"" & [F:PIH]RITPAY<>[M]NUM
   GMESSAGE=mess(16,131,1)-[F:PIH]RITPAY : mkstat=2 : End : # Facture imputée sur le règlement
  Endif
 When Default : # Pièce comptable
  Onerrgo ERREUR From CONTROLE
  If !clalev([F:HAE]) : Local File GACCENTRY [HAE] : Endif
  Onerrgo
  If GERREUR : GERREUR=0 : mkstat=2 : End : Endif
  Call LECTURE("GAS",VALEUR,[M]VCRTYP(NOL)) From CONTOBJ
  If fstat : # Pièce comptable inexistante
   Read [DUD]DUD0(2) = [M]VCRTYP(NOL);VALEUR
   If fstat : GMESSAGE = mess(3,659,1)-mess(20,117,1) : mkstat=2 : End
   Else [L]SITE=[F:DUD]CPY
   Endif
  Else [L]SITE=[F:HAE]CPY
  Endif
  If [L]SITE<>[M]CPY : # Pièce comptable de la societe
   GMESSAGE = mess(3,659,1)-mess(5,117,1)-[L]SITE : mkstat=2 : End
  Endif
Endcase
If find([M]IPTTYP(NOL),1,2)
 If fstat : # Commande client/fournisseur inexistante
  GMESSAGE = mess([M]IPTTYP(NOL),659,1)-mess(20,117,1) : mkstat=2 : End
 Endif
 Call LECTURE("FCY",[L]SITE,"") From CONTOBJ
 If [F:FCY]LEGCPY<>[M]CPY
  # Commande client/fournisseur de la société CPY
  GMESSAGE=mess([M]IPTTYP(NOL),659,1)-mess(5,117,1)-[F:FCY]LEGCPY : mkstat=2 : End
 Elsif ([M]FCYOPT=1  & [F:FCY]FINRSPFCY<>[M]FCY)
&    | ([M]FCYOPT=2 & GUSRFCY(1)<>"\" & !find([F:FCY]FINRSPFCY,GUSRFCY(1..GNBAUZ)))
  # Commande client/fournisseur du site FCY
  GMESSAGE=mess([M]IPTTYP(NOL),659,1)-mess(4,117,1)-[F:FCY]FINRSPFCY : mkstat=2 : End
 Endif
 If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:TPY]SNS=2 & [F:TPY]EPACDTTRF=2 & [M]UMRNUM<>"" & [L]BPRPAY<>[M]BPR
  GMESSAGE=mess(83,123,1)+"\"+mess(143,121,1)-[L]BPRPAY+"<>"+[M]BPR : mkstat=2 : End
 Endif
Endif
If [M]IPTTYP(NOL)=3
 Call ANOUV([M]VCRTYP(NOL),VALEUR) From SUBPAY2
 If GMESSAGE<>"" : mkstat=2 : End : Endif
Endif
End

Subprog AP_VCRNUM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If clalev([F:TPD])=0  : Local File TMPPAYDUD [TPD] : Endif
If [M]DUDNUM(NOL)<>0
 # Vérifier que l'échéance n'est pas en cours de lettrage,
 # pour ne pas la régler une 2eme fois
 Filter [MTB] Where ACCNUM=[M]DUDNUM(NOL) & DUDLIG=[M]DUDLIG(NOL)
 Look [MTB]MTB0 First
 Filter [MTB]
 If !fstat
  GMESSAGE=mess(70,119,1) : mkstat=2 : End   :# Echéance en cours de lettrage
 Endif
 # Vérifier que l'échéance n'est pas en cours de proposition automatique de règlement,
 # pour ne pas la régler une 2eme fois
 Read [TPD]TPD1 = [M]DUDNUM(NOL);DUDLIG=[M]DUDLIG(NOL)
 If !fstat
  GMESSAGE = mess(50,119,1) : mkstat=2 : End   :# Echéance en cours de règlement
 Endif
 Read [DUD]DUD1 = [M]DUDNUM(NOL);[M]DUDLIG(NOL)
 If !fstat
  [M]BPRINV(NOL)    = [F:DUD]BPR
  [M]BPRSACINV(NOL) = [F:DUD]SAC
 Endif

 # PRD05
 If [F:DUD]DEP <> '' # Issue X3-29143
   [M]DISDAT(NOL) = func PAYDEPLIB3.SETDISDAT([M:PAY1]ACCDAT)
 Endif # Issue X3-29143
 Affzo [M]DISDAT(NOL)
 # PRD05

 If dim(GSDDMGT)>0 & GSDDMGT=2 & [M]SNS=2 & [M]UMRNUM<>"" & [M]UMRNUM<>[F:DUD]UMRNUM & [M]IPTTYP(NOL)>2
  GMESSAGE = mess(279,117,1)-[M]UMRNUM : mkstat=2 : End
 Endif
Endif
End

$S_VCRNUM
Case [M]IPTTYP(nolign-1)
 When 1 : # cde cli # dans la table SORDER, pas de champs société, dommage
  OBJET="SOH"
  OPTIONS="#"
  If [M]BPR<>"" : CRITERE= "BPCPYR='"+[M]BPR+"'" : Endif : # GH 09/03/01 bug 8314
 When 2 : # cde fou # dans la table PORDER, pas de champs société, dommage
  OBJET="POH"
  OPTIONS="#"
  If [M]BPR<>"" : CRITERE= "BPRPAY='"+[M]BPR+"'" : Endif : # GH 09/03/01 bug 8314
 When 4 : # proforma fou
  OBJET="PIH"
  OPTIONS="#"
  CRITERE="INVTYP=5 & CPY='"+[M]CPY+"'"
  If [M]NUM<>"" : CRITERE += " & (RITPAY='' | RITPAY='"+[M]NUM+"')"
  Else          : CRITERE += " & RITPAY=''"
  Endif
  If [M]BPR<>"" : CRITERE+= " & BPRPAY='"+[M]BPR+"'" : Endif : # GH 09/03/01 bug 8314
 When Default : # Pièce comptable
  Local File GACCDUDATE [DUD] # NG 05/06/00 Pour eviter que le link de SELDUD1 n'ecrase celui de WOPAY
  Filter [DUD] Where CPY=[M]CPY & TYP=[M]VCRTYP(nolign-1) &
&                     FLGCLE=1 & BPRFCT=''
  Local Char SITE(GLONFCY), TIERS(GLONBPR)
  SITE=[M]FCY : TIERS=[M]BPR
  Gosub SEL_DUD From SELDUD1
Endcase
Return

$V_VCRNUM
Local Decimal MT
If [F:DUD]NUM<>"" & !find([M]IPTTYP(nolign-1),1,2,4)
 Read [DUD]DUD1 = [F:DUD]ACCNUM;[F:DUD]DUDLIG
 If !fstat
  [M]DUDNUM(nolign-1) = [F:DUD]ACCNUM
  [M]DUDLIG(nolign-1) = [F:DUD]DUDLIG
  [M]FCYLIN(nolign-1) = [F:DUD]FCY
  [M]CURLIN(nolign-1) = [F:DUD]CUR
  Call LEC_CDA_LEG(GCURLEG,[M]DENCOD(nolign-1)) From CPTLEC
  If [F:CDA]IPTDEP = 2 : Call MTAGIO([L]MT,nolign-1) From SUBPAY2
  Else                 : Call MTECHE([L]MT,nolign-1) From SUBPAY2
  Endif
  Call AP_AMTLIN([L]MT) From SUBPAY
  If mkstat : MT=0 : [M]AMTLIN2(nolign-1)=0 : mkstat=0 : Endif
  [M]AMTLIN(nolign-1)=MT
 Endif
Endif
Return

$SELECH
Gosub SELECH From SUBPAY2
Return

Subprog AS_FCYLIN(VALEUR)
Variable Char     VALEUR
If VALEUR<>"" & [M]DUDNUM(indice)<>0
 If !find([M]IPTTYP(indice),1,2) : mkstat=2
 Else
  Call LECDUD([M]DUDNUM(indice),[M]DUDLIG(indice)) From SUBPAY2
  If fstat=0 & (([F:DUD]PAMTYP=1 & [F:DUD]DINAMT<>0) | [F:DUD]PAMTYP<>1)
   mkstat=2
  Endif
 Endif
Elsif [M]IPTTYP(indice)<>4 & ([M]FCYOPT=1 | (GUSRFCY(1)<>"\" & GNBAUZ=1))
 VALEUR=[M]FCY : mkstat=2
Elsif VALEUR=""
 Local Char SITE(GLONFCY)
 Case [M]IPTTYP(indice)
  When 1 : # Cde cli
   Call LECTURE("SOH",[M]VCRNUM(indice),"") From CONTOBJ
   If fstat=0 : [L]SITE=[F:SOH]SALFCY : Endif
  When 2 : # Cde fou
   Call LECTURE("POH",[M]VCRNUM(indice),"") From CONTOBJ
   If fstat=0 : [L]SITE=[F:POH]POHFCY : Endif
  When 4 : # Proforma fou
   Call LECTURE("PIH",[M]VCRNUM(indice),"") From CONTOBJ
   If fstat=0 : [L]SITE=[F:PIH]FCY : Endif
 Endcase
 If [L]SITE<>""
  Call LECTURE("FCY",[L]SITE,"") From CONTOBJ
  If fstat=0 : VALEUR=[F:FCY]FINRSPFCY : Endif
 Endif
 If VALEUR="" : VALEUR=[M]FCY : Endif
 If [M]IPTTYP(indice)=4 : mkstat=2 : Endif
Endif
End

Subprog C_FCYLIN(VALEUR)
Variable Char     VALEUR
Local Integer OK, IND : IND=indice
Call LECTURE("FCY",VALEUR,"") From CONTOBJ
If [F:FCY]LEGCPY<>[M]CPY : # Ce site est dans la société CPY
 GMESSAGE=mess(30,106,1)-[F:FCY]LEGCPY : mkstat=2
Elsif [M]FCYOPT=3 & VALEUR<>[M]FCY & VALEUR<>[M]FCYLIN(IND)
 OK=2 : Call AVERTIR(mess(18,117,1)-[M]FCY-"->"-VALEUR,OK) From GESECRAN
 If OK<>2 : mkstat=2 : Endif :  # Génération OD-sites
Elsif [F:FCY]FINFLG<>2
 GMESSAGE = [L]SITE-mess(217,107,1) : mkstat=2
Endif
End

Subprog AS_CURLIN(VALEUR)
Variable Char     VALEUR
Local Integer IND : IND=indice
If VALEUR=""
 Case [M]IPTTYP(IND)
  When 1 : # Cde cli
   Call LECTURE("SOH",[M]VCRNUM(IND),"") From CONTOBJ
   If fstat=0 : VALEUR=[F:SOH]CUR : Endif
  When 2 : # Cde fou
   Call LECTURE("POH",[M]VCRNUM(IND),"") From CONTOBJ
   If fstat=0 : VALEUR=[F:POH]CUR : Endif
  When 4 : # Proforma tiers fournisseur
   Call LECTURE("PIH",[M]VCRNUM(IND),"") From CONTOBJ
   If fstat=0 : VALEUR=[F:PIH]CUR : Endif
  Endcase
  If [M]ACCTYP(IND)=2 : # Banque<=>Compte
   If [M]CURBAN<>"" : VALEUR=[M]CURBAN : Else VALEUR=[M]CURCPY : Endif
  Endif
  If VALEUR="" : VALEUR=[M]CUR : Endif
Endif
If [M]DUDNUM(IND)<>0
 If !find([M]IPTTYP(IND),1,2) : mkstat=2
 Else
  Call LECDUD([M]DUDNUM(IND),[M]DUDLIG(IND)) From SUBPAY2
  If fstat=0 & (([F:DUD]PAMTYP=1 & [F:DUD]DINAMT<>0) | [F:DUD]PAMTYP<>1)
   mkstat=2
  Endif
 Endif
Elsif !find([M]IPTTYP(IND),1,2) & [M]ACCTYP(IND)<>2
 If [M]IPTTYP(IND)=0 : VALEUR=[M]CUR : Endif
 mkstat=2
Endif
End

Subprog C_CURLIN(VALEUR)
Variable Char     VALEUR
#Local Integer IND : IND=indice
## Demande de modif 31922
#Call LECTURE("CDA",[M]DENCOD(IND),"") From CONTOBJ
#If [M]BAN<>""
# Call LECTURE("BAN",[M]BAN,"") From CONTOBJ
#Endif
#If [F:CDA]ACCTYP=2  & [F:CDA]ACCVCRFLG<>2 & ([M]BAN="" | VALEUR<>[F:BAN]CUR)
# # Utiliser une destination comptable avec pièce séparée
# GMESSAGE = mess(217,117,1)
# mkstat = 2 : End
#Endif
End


Subprog IB_AMTLIN
Call LEC_CDA_LEG(GCURLEG,[M]DENCOD(nolign-1)) From CPTLEC
If fstat | [F:CDA]IPTDEP<>2 : Raz GBOUT2 : Endif
End

Subprog D_AMTLIN(VALEUR)
Variable Decimal  VALEUR
Local Integer IND : IND=indice
If [M]VCRTYP(IND)=""
 Local Integer I
 Local Decimal MT, MT2
 Gosub SET_AMTLIN From SUBPAY2 : VALEUR = [M]AMTLIN(IND) : Affzo AMTLIN2(IND)
Endif
End

Subprog C_AMTLIN(VALEUR)
Variable Decimal  VALEUR


#Call LECTURE("CDA",[M]DENCOD(indice),"") From CONTOBJ
#If [M]VCRNUM(indice)="" & [F:CDA]ACCTYP=1 & [F:CDA]ACCVCRFLG<>2 & VALEUR<0
# GMESSAGE=mess(141,121,1) : mkstat= 2 : End
# # Saisie en montant négatif interdite. Revoir le paramétrage de la destination comptable
#Endif
#
If [M]VCRNUM(indice)="" : End : Endif
Local Decimal MT, MT2
Local Integer I, K, IND : IND=indice
Local Char DEV(GLONCUR)
If [M]DUDNUM(IND)<>0
 Call LECDUD([M]DUDNUM(IND),[M]DUDLIG(IND)) From SUBPAY2
 If fstat=0
  If !find([M]IPTTYP(IND),1,2) | [F:DUD]PAMTYP<>1
   I=1 : # Call MTECHE(MT,IND) From SUBPAY2 : K=[F:DUD]SNS : DEV=[F:DUD]CUR : # GH 20/04/99
  Elsif [F:DUD]DINAMT<>0
   Call SNSPAYECH([M]ACCSNS(IND),[M]SNS,[F:DUD]SNS,I) From SUBPAY2
   If VALEUR*I<[F:DUD]DINAMT : # Acompte déduit de DINAMT CUR
    GMESSAGE=mess(59,117,1)-num$([F:DUD]DINAMT)-[F:DUD]CUR : mkstat=2 : End
   Endif
   I=0
  Endif
 Endif
Endif
If !I
 Case [M]IPTTYP(IND)
  When 2
   Call LECTURE("POH",[M]VCRNUM(IND),"") From CONTOBJ
   If !fstat : MT=[F:POH]TTVORD : K=-1 : DEV=[F:POH]CUR : I=1 : Endif
  When 1
   Call LECTURE("SOH",[M]VCRNUM(IND),"") From CONTOBJ
   If !fstat : MT=[F:SOH]ORDATI : K=1 : DEV=[F:POH]CUR : I=1 : Endif
 Endcase
Else I=0 : # On permet le sur-règlement momentanément en saisie
Endif
If !I | MT<0 : End : Endif
Call SNSPAYECH([M]ACCSNS(IND),[M]SNS,K,I) From SUBPAY2
Call CONVERT(DEV,[M]CURLIN(IND),[M]CURCPY,[F:TPY]RATTYP,[M]ACCDAT
&           ,VALEUR,MT2,K) From TRTDEV
If !K & MT-MT2*I<0 :  # Sur-règlement non autorisé
 GMESSAGE=mess(56,117,1)-"("+num$(MT*I)-[M]CURLIN(IND)+")" : mkstat=2
Endif
End

Subprog AP_AMTLIN(VALEUR)
Variable Decimal  VALEUR
Local Decimal MT
Local Integer SIGN, SIGN2, STAT, I, NOL : # +1 => Débit, -1 => Crédit
Local Integer MAJRATINV : MAJRATINV = 0    # Application du cours facture
Local Decimal MTC, WRAT : Raz WRAT

Gosub SETNOL
If VALEUR=0 | [M]ACCTYP(NOL)<>1 : SIGN=0
Else
 If [M]AMTLIN(NOL)<>VALEUR | [M]CURLIN2(NOL)<>[M]CURLIN(NOL)
  If [M]DUDNUM(NOL)<>0 & [M]CUR<>[M]CURLIN(NOL) & ([M]CUR=[M]CURCPY)
   Call LECTURE("TCU",[M]CURLIN(NOL),"") From CONTOBJ
   If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=[M]ACCDAT)
    Call LECTURE("TCU",[M]CUR,"") From CONTOBJ
     If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=[M]ACCDAT)
     Call LECDUD([M]DUDNUM(NOL),[M]DUDLIG(NOL)) From SUBPAY2
     Call MTECHE(MT,NOL) From SUBPAY2
     If VALEUR=MT
      If [M]CUR=[M]CURCPY : MT=[F:DUD]AMTLOC-[F:DUD]PAYLOC-[F:DUD]TMPLOC : Endif
      For I=0 To [M]NBLIG-1
       If I<>NOL & [M]DUDNUM(NOL)=[M]DUDNUM(I) & [M]DUDLIG(NOL)=[M]DUDLIG(I)
        Call SNSPAYECH([M]ACCSNS(I),[M]SNS,[F:DUD]SNS,SIGN) From SUBPAY2
        MT-=sgn([M]AMTLIN(I))*abs([M]AMTLIN2(I))*SIGN
       Endif
      Next I
      If GREP="M"
       For [PYD]PYD1 Where NUM=[M]NUM & DUDNUM=[M]DUDNUM(NOL) & DUDLIG=[M]DUDLIG(NOL)
        If [M]CUR=[M]CURCPY : MT+=[F:PYD]PAYLOCLIN
        #Else                : MT+=[F:PYD]PAYRPTLIN
        Endif
       Next : # [PYD]
      Endif
      [M]REGAMT2(NOL)=MT : STAT=1
     Endif
    Endif
   Endif
  Endif
  If !STAT
   MAJRATINV = 0
   # Transaction est elle flaguée "Application cours facture"
   If clalev([F:TPY])=0  : Local File TABPAYTYP   [TPY] : Endif
   Call LEC_TPY_LEG(GCURLEG,GFLAG) From CPTLEC
   If VALEUR<>0 & [M]ACCTYP(NOL)=1 & [M]CURLIN(NOL)<>[M]CUR & [F:TPY]RATINV=2
    If clalev([F:HAE3])=0 : Local File GACCENTRY   [HAE3] : Endif
    Read [HAE3]HAE0 = [M]VCRTYP(NOL);[M]VCRNUM(NOL)
    If !fstat
     If [M]CUR=[M]CURCPY
      WRAT  = [F:HAE3]RATMLT(GTYPGEN-1)/[F:HAE3]RATDIV(GTYPGEN-1)
     Endif
     Call CONVERT3([M]CURLIN(NOL),[M]CUR,[M]CURCPY,[F:HAE3]TYPRAT,[F:HAE3]RATDAT,VALEUR,MTC,
&                  WRAT,STAT) From CPTSUB
     If !STAT
      [M]REGAMT2(NOL)=MTC
      MAJRATINV=1

      # Ritenzione
      If dim([M]RITAMT)>0 & func AFNC.PARAM("ITARTZ",[M]CPY)="2"
       If find([F:PIH]INVTYP,2,4) : SIGN2=3 : Else SIGN2=2 : Endif
       Call SIGN2(SIGN2,[M]SNS,0,0,0,SIGN2) From PAYDIV
       If [M]RITAMT(NOL)<>[M]ORIT | [M]CURLIN2(NOL)<>[M]CURLIN(NOL)
        Call CONVERT3([M]RTZCUR,[M]CUR,[M]CURCPY,[F:HAE3]TYPRAT,[F:HAE3]RATDAT,[M]RITAMT(NOL),MTC,
&                     WRAT,STAT) From CPTSUB
        If !STAT
         [M]RITAMT2(NOL)=MTC
         [M]ORIT=[M]RITAMT(NOL)
        Endif
       Endif
      Endif
     Endif
    Endif
   Endif
  Endif
  If STAT or !MAJRATINV
   Call CONVERT([M]CURLIN(NOL),[M]CUR,[M]CURCPY,[F:TPY]RATTYP,[M]ACCDAT
&               ,VALEUR,[M]REGAMT2(NOL),STAT) From TRTDEV
   If STAT : # Pas de cours de devises CURLIN -> CUR (ACCDAT)
    GMESSAGE=mess(16,114,1)-[M]CURLIN(NOL)-"->"-[M]CUR-"("+format$("D:"+GFMDAT,[M]ACCDAT)-")"
    mkstat=2 : End
   Endif
  Endif
 Endif
 If dim([M]RITAMT)>0 & !MAJRATINV & func AFNC.PARAM("ITARTZ",[M]CPY)="2"
  If find([F:PIH]INVTYP,2,4) : SIGN2=3 : Else SIGN2=2 : Endif
  Call SIGN2(SIGN2,[M]SNS,0,0,0,SIGN2) From PAYDIV
  If [M]RITAMT(NOL)<>[M]ORIT | [M]CURLIN2(NOL)<>[M]CURLIN(NOL)
   Call CONVERT([M]RTZCUR,[M]CUR,[M]CURCPY,[F:TPY]RATTYP,[M]ACCDAT
&              ,[M]RITAMT(NOL),[M]RITAMT2(NOL),STAT) From TRTDEV
   If STAT : # Pas de cours de devises CURLIN -> CUR (ACCDAT)
    GMESSAGE=mess(16,114,1)-[M]RTZCUR-"->"-[M]CUR-"("+format$("D:"+GFMDAT,[M]ACCDAT)-")"
    mkstat=2 : End
   Endif
   [M]ORIT=[M]RITAMT(NOL)
  Endif
 Endif
 Call SIGN2([M]ACCSNS(NOL),[M]SNS,[M]DUDNUM(NOL),[M]DUDLIG(NOL),[M]IPTTYP(NOL),SIGN) From PAYDIV
Endif
[M]REGAMT2(NOL)=SIGN*sgn(VALEUR)*abs([M]REGAMT2(NOL))
[M]AMTLIN2(NOL)=[M]REGAMT2(NOL)
If dim([M]RITAMT)>0 & func AFNC.PARAM("ITARTZ",[M]CPY)="2"
 [M]RITAMT2(NOL)=SIGN2*sgn([M]RITAMT(NOL))*abs([M]RITAMT2(NOL))
 [M]AMTLIN2(NOL)+=[M]RITAMT2(NOL)
Endif
[M]CURLIN2(NOL)=[M]CURLIN(NOL)
If GDEPMGTMOD<>4 | sgn(VALEUR)<>sgn([M]AMTLIN(NOL)) | (dim(GDEPVATLIN)>0 & GDEPVATLIN="") | dim(GDEPVATLIN)<=0
 [M]AMTLIN(NOL)=VALEUR
 Gosub SET_ACCLIN
Endif
End

Subprog AS_AMTLIN2(VALEUR)
Variable Decimal  VALEUR
If [M]AMTLIN(indice)=0 | [M]ACCTYP(indice)<>1 : VALEUR=0 : mkstat=2
Elsif [M]CURLIN(indice)=[M]CUR : mkstat=2
Else
 # si les devises de règlement et de ligne sont toutes 2 'in', le montant2 est imposé
 Call LECTURE("TCU",[M]CURLIN(indice),"") From CONTOBJ
 If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=[M]ACCDAT)
  Call LECTURE("TCU",[M]CUR,"") From CONTOBJ
  If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=[M]ACCDAT): mkstat=2 : Endif
 Endif
Endif
End

Subprog C_AMTLIN2(VALEUR)
Variable Decimal  VALEUR
If VALEUR=0 : End : Endif
Local Integer SIGN, IND : IND=indice
Call SIGN2([M]ACCSNS(IND),[M]SNS,[M]DUDNUM(IND),[M]DUDLIG(IND),[M]IPTTYP(IND),SIGN) From PAYDIV
If sgn(VALEUR)<>sgn([M]AMTLIN(IND))*SIGN : mkstat=2
Elsif [M]PRCAMTCNV>0
 Local Integer STAT
 Local Decimal MT
 Call CONVERT([M]CURLIN(IND),[M]CUR,[M]CURCPY,[F:TPY]RATTYP,[M]ACCDAT
&            ,[M]AMTLIN(IND),MT,STAT) From TRTDEV
 If !STAT & abs(VALEUR-MT)>abs(MT*[M]PRCAMTCNV/100)
  STAT=1 : # Ligne NOL : MT1 DEV1 -> MT2 DEV2
  Call AVERTIR(mess(47,116,1)-num$(IND+1)-":"-num$([M]AMTLIN(IND))-[M]CURLIN(IND)-"->"-num$(MT)-[M]CUR,STAT) From GESECRAN
  If STAT<>2 : mkstat=2 : Endif
 Endif
Endif
End

Subprog D_VATLIN(VALEUR)
Variable Char    VALEUR()
Local Integer OK,NOL : NOL=indice
If [M]DUDNUM(NOL)<>0
 Call LECDUD([M]DUDNUM(NOL),[M]DUDLIG(NOL)) From SUBPAY2
 If fstat=0 & find([M]IPTTYP(NOL),1,2) & [F:DUD]PAMTYP<>1 : # acompte attendu
  VALEUR=[F:DUD]VAT : End
 Elsif fstat=0 & find([M]IPTTYP(NOL),1,2) & [F:DUD]DINAMT<>0 : # acompte déduit
  End
 Elsif fstat=0
  VALEUR=[F:DUD]VAT
 Endif
Endif
OK=0 : Gosub SET_TVA
If !OK : VALEUR="" : Endif
End

$SET_TVA
If [M]EARDISFLG(NOL)=2 & [M]VATLIN(NOL)<>"" : OK = 1 : Return : Endif
Call LEC_CDA_LEG(GCURLEG,[M]DENCOD(NOL)) From CPTLEC
If [F:CDA]RPCVAT<2 : OK=0
Elsif GCPTVAT=2
 Local Integer NLED
 For NLED=1 To GNBPLAN
  Local Char ACCLIN(GLONGAC)
  [L]ACCLIN = evalue("[M]ACC"+num$(NLED)+"("+num$(NOL)+")")
  If [L]ACCLIN<>"" & !instr(1,[L]ACCLIN,"x")
   Call LECTURE("GAC",[L]ACCLIN,GPLAN(NLED)) From CONTOBJ
   If !([F:GAC]FLGVAT<2)
    OK = 1
    If [F:GAC]VAT(0)<>""
     If GDEPMGTMOD<>4
      VALEUR = [F:GAC]VAT(0) : Break
     Else
      If VALEUR = "" : VALEUR = [F:GAC]VAT(0) : Endif
      Break
     Endif
    Endif
   Endif
  Endif
 Next
Endif
Return

Subprog AS_VATLIN(VALEUR)
Variable Char    VALEUR()
Local Integer OK,NOL : NOL=indice
If [M]DUDNUM(NOL)<>0 & find([M]IPTTYP(NOL),1,2)
 Call LECDUD([M]DUDNUM(NOL),[M]DUDLIG(NOL)) From SUBPAY2
 If fstat=0 & [F:DUD]PAMTYP<>1
  VALEUR=[F:DUD]VAT : mkstat=2 : End
 Elsif fstat=0 & [F:DUD]DINAMT<>0
  mkstat=2 : End
 Endif
Endif
OK=2 : Gosub SET_TVA
If !OK : mkstat=1 : Endif
End

Subprog D_DESLIN(VALEUR)
Variable Char     VALEUR
If [F:TPY]DACDESLIN<>3
 If indice>0 : VALEUR=[M]DESLIN(indice-1)
 Elsif [F:TPY]DACDES<>3 : VALEUR=[M]DES
 Endif
Endif
End

Subprog D_QTYLIN(VALEUR)
Variable Decimal  VALEUR
Gosub SETNOL
Gosub RECH_ACCANA From SUBPAY3
Call LECTURE("GAC",CPTANA,PLANA) From CONTOBJ
If fstat=0 & [F:GAC]FLGUOM=2
 [M]UOM(NOL)=[F:GAC]UOM
Endif
If [M]UOM(NOL)<>"" & [F:GAC]VALUOM<>0
 Local Integer STAT
 Local Decimal MT
  Call CONVERT([M]CURLIN(NOL),GCURSHR,[M]CURCPY,[F:TPY]RATTYP,[M]ACCDAT,[M]AMTLIN(NOL),MT,STAT) From TRTDEV
  If !STAT
   VALEUR=MT/[F:GAC]VALUOM : Call AROQTE(VALEUR,[F:GAC]UOM) From CPTINI
  Endif
Endif
End

Subprog AS_QTYLIN(VALEUR)
Variable Decimal  VALEUR
Gosub SETNOL
If [M]UOM(NOL)=""
 mkstat=1 : End
Endif
End

Subprog D_DSP(VALEUR)
Variable Char VALEUR()
Gosub SETNOL
Gosub RECH_ACCANA From SUBPAY3
If CPTANA = ""
 mkstat = 1 : End
Elsif [M]ACCTYP(NOL)<>1
 End
Endif
If [M]DUDNUM(NOL)<>0
 Local Integer OK, K, I, J
 Local Decimal SMT, MT, ARD, SQTE, QTE, ARQ
 Local Char    SEC(GLONCCE)
 Onerrgo ERREUR From CONTROLE
 If !clalev([F:DAE]) : Local File GACCENTRYD [DAE] : Endif
 Onerrgo
 If GERREUR : GERREUR=0 : End : Endif
 Read [DAE]DAE2 = [M]DUDNUM(NOL)
 If !fstat & [F:DAE]DSP<>""
  VALEUR=[F:DAE]DSP : End
 Endif
Else
 Call LECTURE("GAC",CPTANA,PLANA) From CONTOBJ
 VALEUR = [F:GAC]DSP
Endif
End

Subprog AS_DSP(VALEUR)
Variable Char     VALEUR
Gosub SETNOL
Local Integer SUIVI, I
Local Char TPLAN(GLONCOA)(1..dim([M]FMTCOA)), TCOMPTE(GLONGAC)(1..dim([M]FMTCOA))
For I=1 To GNBPLAN
 TPLAN(I)   = GPLAN(I)
 TCOMPTE(I) = evalue("[M]ACC"+num$(I)+"("+num$(NOL)+")")
Next
Call SUIVI_ANA([M]CPY,GTYPLED,GNBTYPLED,TPLAN,TCOMPTE,GAXE,GNBAXE,SUIVI) From CPTDIV
If !SUIVI
 mkstat=1 : End
Endif
If dim(GNBSTR)>=0 : GNBSTR=0 : Endif #F84062
End

Subprog C_DSP(VALEUR)
Variable Char     VALEUR
Gosub SETNOL
Case VALEUR
 When "" : End
 When "$"
  OK=1
  OK*=([M]AMTLIN(NOL)=sum([M:VT2]TBAMT([M]PTV(NOL)..[M]PTF(NOL))))
  OK*=([M]QTYLIN(NOL)=sum([M:VT2]TBQTY([M]PTV(NOL)..[M]PTF(NOL))))
  If !OK
   # Répartition déséquilibrée
   GMESSAGE=mess(28,106,1) : mkstat=2 : End
  Endif
 When Default
  Local Integer I
  Gosub RECH_ACCANA From SUBPAY3
  Raz [M]LSTAXE
  Call CONTDSP(VALEUR,[M]FCYLIN(NOL),[M]ACCDAT) From SUBGA1
  If mkstat : End : Endif
  [M:VTL]TOTREP=[M]AMTLIN(NOL) : [M:VTL]QTOTREP=[M]QTYLIN(NOL)
  Call LECTURE("TCU",[M]CURLIN(NOL),"") From CONTOBJ
  Gosub SETCHPLST From SUBPAY3
  Call CHARGE_VTE_STR(VALEUR,[M]UOM(NOL),[M]LSTLED(NOL),[M]LSTACC(NOL),[M]LSTAXE) From VENTILE
  Call CONTVENT([M]FCYLIN(NOL),[M]ACCDAT) From SAIVENTILE
  [M]PTV(NOL)=0 : [M]PTF(NOL)=0
 Endcase
End


Subprog AM_DSP(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Gosub RECH_ACCANA From SUBPAY3
If CPTANA="" | [M]DUDNUM(NOL)=0 : End
Elsif [M]ACCTYP(NOL)<>1
 End
Endif
Local Integer INDAXE, INDLED
Local Integer OK, K, I, J
Local Decimal SMT, MT, ARD, SQTE, QTE, ARQ
Local Char    SEC(GLONCCE)
If !clalev([F:DAE]) : Local File GACCENTRYD [DAE] : Endif
If !clalev([F:TUN]) : Local File TABUNIT    [TUN] : Endif
If !clalev([F:DAA]) : Local File GACCENTRYA [DAA] : Endif
Call LECTURE("TCU",[M]CURLIN(NOL),"") From CONTOBJ
ARD=[F:TCU]CURRND
If [M]UOM(NOL)<>""
 Call LECTURE("TUN",[M]UOM(NOL),"") From CONTOBJ
 If [F:TUN]UOMDEC=0 : ARQ = 1
 Else ARQ = val("0."+string$([F:TUN]UOMDEC-1,"0")+"1")
 Endif
Endif
Call LECTURE("GAC",CPTANA,PLANA) From CONTOBJ
If [M:VT2]PTVENT=0 : K=1 : Else K=[M:VT2]PTVENT-1 : Endif
Read [DAE]DAE2 = [M]DUDNUM(NOL)
For [DAA]DAA0 Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LIN=[F:DAE]LIN & IDTLIN=[F:DAE]IDTLIN
 MT=0 : QTE=0
 If [F:DAE]AMTCUR=[M]AMTLIN(NOL)
  MT=[F:DAA]AMTCUR
 Elsif [F:DAE]AMTCUR<>0
  MT = arr(([F:DAA]AMTCUR+SMT)*[M]AMTLIN(NOL)/[F:DAE]AMTCUR,ARD)
&      -arr(SMT*[M]AMTLIN(NOL)/[F:DAE]AMTCUR,ARD)
  SMT += [F:DAA]AMTCUR
 Endif
 If [M]UOM(NOL)<>""
  If [F:DAE]UOM=[M]UOM(NOL) & [F:DAE]QTY=[M]QTYLIN(NOL)
   QTE=[F:DAA]QTY
  Elsif [M]AMTLIN(NOL)<>0
   QTE = arr((MT+SQTE)*[M]QTYLIN(NOL)/[M]AMTLIN(NOL),ARQ)
&       -arr(SQTE*[M]QTYLIN(NOL)/[M]AMTLIN(NOL),ARQ)
   SQTE += [F:DAA]QTY
  Endif
 Endif
 If MT<>0 | QTE<>0
  K += 1
  If !OK : OK = K : Endif
  [M:VT2]TBAMT(K) = MT
  [M:VT2]TBQTY(K) = QTE
  For AXE=1 To GNBAXE
   Call INDLED([F:DAA]LED,GAXE(AXE),INDLED,INDAXE) From CPTDIV
   #If INDAXI
   If INDAXE
    VU = find(GAXE(AXE),[F:DAA]DIE(0..dim([F:SIA]DIE)-1))
    If VU
     Assign "[M:VT2]TBCCE"+num$(AXE)+"("+num$(K)+")" With [F:DAA]CCE(VU-1)
    Endif
   Endif
  Next
 Endif
Next : # [DAA]
If OK
 If OK=K
  For I=1 To GNBAXE
   Assign "[M]CCE"+num$(I)+"("+num$(NOL)+")"
&         With evalue("[M:VT2]TBCCE"+num$(I)+"("+num$(K)+")")
   Assign "[M:VT2]TBCCE"+num$(I)+"("+num$(K)+")" With ""
  Next I
 Else
  [M]PTV(NOL) = OK
  [M]PTF(NOL) = K
  [M:VT2]PTVENT = K+1
  VALEUR = "$"
 Endif
Endif
End

$S_DSP
OBJET="DSP"
If [M]ACCDAT<>[0/0/0]
 CRITERE = '([F:DSP]VLYSTR=[0/0/0] | [F:DSP]VLYSTR<=['+format$(GFMD,[M]ACCDAT)+'])'
 CRITERE -= '& ([F:DSP]VLYEND=[0/0/0] | [F:DSP]VLYEND>=['+format$(GFMD,[M]ACCDAT)+'])'
Endif
Return

