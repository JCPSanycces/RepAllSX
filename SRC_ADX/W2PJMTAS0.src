#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMTAS0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_PRCCPLADI
Onevent INIT_AREA Call D_PRCCPLADI(zc) From W2PJMTAS0
Onevent CONTROL Call C_PRCCPLADI(zc) From W2PJMTAS0
Onevent AFTER_CHANGE Gosub AMM_PRCCPLADI From W2PJMTAS0
Onevent BEFORE_INPUT Call AS_PRCCPLADI(zc) From W2PJMTAS0
Return

Subprog D_PRCCPLADI(VALEUR)
Variable Char    VALEUR()
If varinit([M]PRCCPLADI,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"387","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_PRCCPLADI(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"387") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_PRCCPLADI(zc) From W2PJMTAS0
Onkey   2 Titled GBOUTS Call S_PRCCPLADI(zc) From W2PJMTAS0
Onkey 144 Titled GBOUTP Call P_PRCCPLADI(zc) From W2PJMTAS0
Onkey 146 Titled GBOUTA Call SA_PRCCPLADI(zc) From W2PJMTAS0
Gosub _AFF
End

Subprog C_PRCCPLADI(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"387","") From SUBADI
If mkstat : GERR = 1 : GZONE = "PRCCPLADI" : GZNUM = 1003476 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"387",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "PRCCPLADI" : GZNUM = 1003476 : Endif
Endif
Gosub _AFF
End

$AMM_PRCCPLADI
Call AM_PRCCPLADI(zc)
If !mkstat & GOBJET
 zoncou = "PRCCPLADI" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PRCCPLADI(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_PRCCPLADI(VALEUR) From SUBPJTA
If mkstat : GERR = 1 : GZONE = "PRCCPLADI" : GZNUM = 1003476 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZPRCCPLADI)")>indice
 [M]PRCCPLADI(indice) = VALEUR
 Affzo ZPRCCPLADI(indice)
Endif
Gosub _AFF
End

Subprog S_PRCCPLADI(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "387"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_PRCCPLADI(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"387") From GOBJET
Gosub _AFF
End

Subprog SA_PRCCPLADI(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "387"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_PRCCPLADI(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "387"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZPRCCPLADI
Onevent BEFORE_AREA Gosub AV_ZPRCCPLADI From W2PJMTAS0
Return

$AV_ZPRCCPLADI
Call LECTEXTRA(zc,"ATABDIV","LNGDES","387",num$([M]PRCCPLADI(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_PBUCOD
Onevent AFTER_CHANGE Gosub AMM_PBUCOD From W2PJMTAS0
Onevent BEFORE_INPUT Call AS_PBUCOD(zc) From W2PJMTAS0
Return

Subprog IB_PBUCOD(VALEUR)
Variable Char    VALEUR()
## Action IBUPJMBUD
Call IBUPJMBUD([M:PJTA0]OPPNUM) From PJMSELECT
Gosub _AFF
End

Subprog AS_PBUCOD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(5262,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call IB_PBUCOD(VALEUR)
Onkey 129 Titled GBOUT1 Call B1_PBUCOD(zc) From W2PJMTAS0
Onkey   2 Titled GBOUTS Call S_PBUCOD(zc) From W2PJMTAS0
Gosub _AFF
End

$AMM_PBUCOD
Call AM_PBUCOD(zc)
If !mkstat & GOBJET
 zoncou = "PBUCOD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_PBUCOD(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_PBUCOD(VALEUR) From SUBPJTA
If mkstat : GERR = 1 : GZONE = "PBUCOD" : GZNUM = 6380 : Endif
Gosub _AFF
End

Subprog S_PBUCOD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELPJMBUD
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPJMBUD"
 PARMSK(1) = [M:PJTA0]OPPNUM
 PARMSK(2) = num$([V]CST_AYES)
 Call S_LIS_CHAR(VALEUR,PARMSK,"SELPJMBUD","PJMSELECT","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_PBUCOD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNPJMBUD
 Call TUNPJMBUD(VALEUR,[M:PJTA0]OPPNUM) From PJMSELECT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_TASBUDAUT
Onevent AFTER_CHANGE Gosub AMM_TASBUDAUT From W2PJMTAS0
Onevent INIT_AREA Call D_TASBUDAUT(zc) From W2PJMTAS0
Onevent BEFORE_INPUT Call AS_TASBUDAUT(zc) From W2PJMTAS0
Onevent CONTROL Call C_TASBUDAUT(zc) From W2PJMTAS0
Return

Subprog D_TASBUDAUT(VALEUR)
Variable Integer VALEUR
If varinit([M]TASBUDAUT,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TASBUDAUT(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_TASBUDAUT(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "TASBUDAUT" : GZNUM = 55422 : Endif
Gosub _AFF
End

$AMM_TASBUDAUT
Call AM_TASBUDAUT(zc)
If !mkstat & GOBJET
 zoncou = "TASBUDAUT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TASBUDAUT(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_TASBUDAUT(VALEUR) From SUBPJTA
If mkstat : GERR = 1 : GZONE = "TASBUDAUT" : GZNUM = 55422 : Endif
Gosub _AFF
End

$ON_BTNTAC
Onevent BEFORE_INPUT Call AS_BTNTAC(zc) From W2PJMTAS0
Onevent INIT_AREA Call D_BTNTAC(zc) From W2PJMTAS0
Return

Subprog D_BTNTAC(VALEUR)
Variable Char    VALEUR()
If varinit([M]BTNTAC,indice)=0
 VALEUR = "138"
Endif
Gosub _AFF
End

Subprog AS_BTNTAC(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(454,GBOUTI) From OBJDIV
Onkey 178 Titled GBOUTI Call CL_BTNTAC(zc) From W2PJMTAS0
Gosub _AFF
End

Subprog CL_BTNTAC(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action PJMTXTCLB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "PJMTXTCLB"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "ACL_BTNTAC" : PROGSUB = "SUBPJTA" : PROGSPE = "SPEPJTA" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = "PJTA0"
 PARMSK(2) = "0"
 Call SAISIE_CHAR(VALEUR,PARMSK,"PJMTXTCLB","SUBPJMC","") From GSAISIE
 ACTION = "BCL_BTNTAC" : PROGSUB = "SUBPJTA" : PROGSPE = "SPEPJTA" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_CPY
Return

$ON_FINRSPFCY
Return

$ON_TASDATP
Onevent BEFORE_AREA Gosub AV_TASDATP From W2PJMTAS0
Return

$AV_TASDATP
Chgfmt [M]TASDATP(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

