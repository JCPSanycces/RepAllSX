#<AdxTL>@(#)8.0.0.0 $Revision$
Local File ADOSSIER [ADS]
Read [ADS]DOSSIER = nomap
If fstat : End : Endif
Call  TEMPON("F") From GESECRAN
Call OUVRE_TRACE("") From LECFIC
Call AMAJAXX([F:ADS]DOSSIER)            
Call FERME_TRACE From LECFIC
Call TEMPOFF From GESECRAN
Call LEC_TRACE From LECFIC
End
#################################################

Subprog PATCH_X3(APPLI)
Value Char APPLI
Call AMAJAXX(APPLI)   
End

Subprog PATCH(APPLI)
Value Char APPLI
Call AMAJAXX(APPLI)   
End

#################################################
# Mise à jour objet pour gestion AXX
#################################################
Subprog AMAJAXX(DOSSIER)
Value Char DOSSIER
Local File =DOSSIER+".AOBJET"  [AOB] 
Local File =DOSSIER+".AOBJTAB" [AOT]  
Local File =DOSSIER+".ATABLE"  [ATB] 
Local File =DOSSIER+".ATABZON" [ATZ]
Local File =DOSSIER+".ATYPE"   [ATY] 
Local File =DOSSIER+".AMSKPAR" [AMP]
Local File =DOSSIER+".ATABZON" [ATZ2]

# Mise à jour objet pour gestion AXX
Call ECR_TRACE(mess(81,125,1)-"AOBJTAB:"-time$,0) From GESECRAN

Local Char    TABLE(GLONATB)
Local Char    FLDAXX(GLONAVA)(0..20),LIENAXX(250)(0..20)
Local Char    CLECUR1(250),CLECUR2(250),ZONE(250),TABLE1(250)
Local Integer NBAXX,I,OKAXX,OK,NBAXX,NBLIG,OKOBJ,NBLIEN
Local Char    ABRTAB(GLONABR)(0..20),WCLECUR(250),VERSION(20)
Local Integer NBABR,J

VERSION = func AFNC.PARTSEP(ver$(0),2," ")

Trbegin [AOT]

For [AOB] Where find(TYPGES,1,4) & ABREV="ADV"   :  # gestion simple et browser
 TABLE = [F:AOB]NOMFIC
 Read [F:ATB]CODFIC = TABLE
 Gosub TAB_AXX
 Filter [F:AOT] Where ABREV = [F:AOB]ABREV
 Read [AOT]ABREV  Last
 Filter
 NBLIG = [F:AOT]NUMLIG
 Raz ABRTAB,NBABR,NBLIEN
 For [AOT] Where ABREV = [F:AOB]ABREV & TABFIC ="ATEXTRA"
  If [F:AOT]TABABR <>""
   ABRTAB(NBABR) = [F:AOT]TABABR
   NBABR += 1
  Endif
  NBLIEN += 1
 Next AOT
 J=3 : OKOBJ=0
 For I=0 To NBAXX-1
  OKAXX = 0
  For [AOT] Where ABREV = [F:AOB]ABREV & TABFIC ="ATEXTRA"
   If instr(1,[F:AOT]TABLIEN,TABLE) & instr(1,[F:AOT]TABLIEN,FLDAXX(I))
    OKAXX =1
    Break
   Endif
  Next AOT  
  If !OKAXX & TABLE=evalue(TABLE1)
   NBLIG += 1
   If NBLIEN < 13
    Raz [F:AOT]
    [F:AOT]ABREV    = [F:AOB]ABREV
    [F:AOT]NUMLIG   = NBLIG
    [F:AOT]TABFIC   = "ATEXTRA"
    [F:AOT]TABCLE   = ""
    [F:AOT]TABLIEN  = LIENAXX(I)
    While find("AX"+num$(J),[L]ABRTAB(0..NBABR-1))
     J+=1
    Wend
    [F:AOT]TABABR   = "AX"+num$(J) : [L]ABRTAB(NBABR) =   "AX"+num$(J) : NBABR+=1
    [F:AOT]TABACT   = ""
    OKOBJ =1
    NBLIEN += 1
    Write [AOT]
    If fstat
     Call ERREUR("AOBJTAB"-[F:AOB]ABREV-"--"-num$(NBLIG),1) From DOSDIC
    Endif
   Else
    Call ECR_TRACE([F:AOT]ABREV-" : Liens vers ATEXTRA impossible("+FLDAXX(I)+") :"-LIENAXX(I),-1) From GESECRAN
    OKOBJ =0
   Endif
  Endif 
 Next I
 If OKOBJ
  Call VALID([F:AOB]ABREV,DOSSIER,1,OK) From VALOBJ
 Endif
Next AOB

Commit
Close Local File [AOB],[AOT],[ATB],[ATZ],[ATY],[AMP]
End

$TAB_AXX
Raz NBAXX,FLDAXX,LIENAXX
For [ATZ] Where CODFIC =TABLE & find(CODTYP,"AXX","AX1","AX2","AX3") & DIME=1
 OK=0
 For [AMP] Where TYPAFF =2 & CODAFF=TABLE & CODZON=[F:ATZ]CODZONE
  OK =1
  Case [AMP]CODPAR
    When "CLECUR1"  : CLECUR1 = [AMP]VALPAR 
    When "CLECUR2"  : CLECUR2 = [AMP]VALPAR
    When "ZONE"     : ZONE    = [AMP]VALPAR
    When "TABLE1"   : TABLE1  = [AMP]VALPAR
  Endcase
 Next AMP
 If OK
  LIENAXX(NBAXX) = TABLE1+';'+ZONE+';GLANGUE;'
  #### Verif clecur1
  If instr(1,CLECUR1,"(")
   WCLECUR = left$(CLECUR1,instr(1,CLECUR1,"(")-1)
  Else
   WCLECUR = CLECUR1
  Endif
  Read [F:ATZ2]CODZONE = [F:ATZ]CODFIC;toupper(WCLECUR)
  If !fstat
   If VERSION>="16r.113"
    LIENAXX(NBAXX) += "Num$([F:"+[F:ATB]ABRFIC+"]"+CLECUR1+");"
   Else
    LIENAXX(NBAXX) += "[F:"+[F:ATB]ABRFIC+"]"+CLECUR1+";"
   Endif
  Else
   If VERSION>="16r.113" & !instr(1,CLECUR1,"um$(")
    LIENAXX(NBAXX) += "Num$("+CLECUR1+');'
   Else
    LIENAXX(NBAXX) += CLECUR1+';'
   Endif
  Endif
  #### Verif clecur2
  If instr(1,CLECUR2,"(")
   WCLECUR = left$(CLECUR2,instr(1,CLECUR2,"(")-1)
  Else
   WCLECUR = CLECUR2
  Endif
  Read [F:ATZ2]CODZONE = [F:ATZ]CODFIC;toupper(WCLECUR)
  If !fstat
   If VERSION>="16r.113"
    LIENAXX(NBAXX) += "Num$([F:"+[F:ATB]ABRFIC+"]"+CLECUR2+")"
   Else
    LIENAXX(NBAXX) += "[F:"+[F:ATB]ABRFIC+"]"+CLECUR2+""
   Endif
  Else
   If VERSION>="16r.113" & !instr(1,CLECUR2,"um$(")
    LIENAXX(NBAXX) += "Num$("+CLECUR2+')'
   Else
    LIENAXX(NBAXX) += CLECUR2
   Endif
  Endif
  FLDAXX(NBAXX)  = [F:ATZ]CODZONE
  NBAXX +=1
 Endif
Next ATZ
Return

