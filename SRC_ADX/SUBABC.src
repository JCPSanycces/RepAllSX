#<AdxTL>@(#)10.0.0.0 $Revision$  Gestion objet ABC
$ACTION
Case ACTION
 When default
Endcase
Return

#############################################
Subprog C_STRDAT(VALEUR)
Variable Date VALEUR
If nolign>1 & [M]ENDDAT(nolign-2)>=VALEUR
 Gosub ERRDAT
Endif
If nolign<dim([M]STRDAT) & [M]STRDAT(nolign)<>[0/0/0]  & [M]STRDAT(nolign)<=VALEUR
 Gosub ERRDAT
Endif
End

Subprog C_ENDDAT(VALEUR)
Variable Date VALEUR
If nolign<dim([M]STRDAT) & [M]STRDAT(nolign)<>[0/0/0]  & [M]STRDAT(nolign)<=VALEUR
 Gosub ERRDAT
Endif
End

$ERRDAT
GMESSAGE = mess(109,133,1) : # Les heures doivent être dans l'odre croissant
mkstat   = 1
Return

