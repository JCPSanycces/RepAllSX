#<AdxTL>@(#)3.0.0.0 $Revision$
#-------------------------------------------------------------------------------------------------------------#
# Regeneration des trigers
#-------------------------------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Regeneration des trigers") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Validation du dossier"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End
#-------------------------------------------------------------------------------------------------------------#

Subprog PATCH(APPLI)
Value Char APPLI
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
If [F:ADS]DOSSIER<>APPLI
 Read [ADS]DOSSIER=APPLI
Endif
Local File =APPLI+".ATABLE" [ATB] , =APPLI+".ACTIV" [ACV]
Read [ATB]CODFIC First
While fstat<=2
 If filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",APPLI),0)>0
  Call MAJTRIG([F:ATB]CODFIC)
 Endif
 Read [ATB]CODFIC Next
Wend
Filter [ATB]
Close Local File
End

#-----------------------------------------------#
Subprog MAJTRIG(TABLE)
Value Char TABLE
Local Char    APPLI(GLONADS) , MACHINE(GDIMFIC) , VOLUME(GDIMFIC)
Local Integer K , L

Read [ATB]CODFIC = TABLE
If fstat
 End
Elsif [F:ATB]CODACT<>""
 Read [ACV]CODACT = [F:ATB]CODACT
 If fstat | [F:ACV]FLACT<>2
  End
 Endif
Endif
If GPRODUIT=-1 & dim([F:SAPD]FDR)>0 & [F:SAPD]FDR<>""
 Call MACHINE([F:SAPD]FDR,MACHINE,APPLI) From ORDSYS
 Call VOLUME(MACHINE,APPLI,VOLUME) From ORDSYS
Else
 APPLI   = [F:ADS]DOSSIER
 VOLUME  = [F:ADS]VOLUME
 MACHINE = adxmac(0)
Endif
If filpath("","","","",VOLUME,MACHINE)=""
 End
Endif
K = 1
If find(TABLE,"ALOGIN","AUDITH","AUDITL") : # Les triggers utilisent ces tables
 K = 0
Elsif [F:ATB]TYPFIC=3 : # Tables système
 K = 0
Endif  
If K & (GPRODUIT<>-1 or dim([F:SAPD]FDR)<=0 or (dim([F:SAPD]FDR)>0 & [F:SAPD]FDR=""))
 K = 0
 If filinfo(filpath("FIL","ACTIV","fde",APPLI),0)>0
  Local File =APPLI+".ACTIV" [ACV_]
  Read [ACV_]CODACT = "AUDIT"
  If !fstat & [F:ACV_]FLACT=2
   K = 1
  Endif
  Close Local File [ACV_]
 Endif
 If K 
  Read [ATB]CODFIC=TABLE
  If dim([F:ATB]AUDBI)>0 & [F:ATB]AUDBI=2   
   Call ECR_TRACE("--- AUDBI"-TABLE,0) From GESECRAN
   Call TRIGGER(APPLI,TABLE,"I") From ATRIGGER
   Call TRIGGER(APPLI,TABLE,"U") From ATRIGGER
   Call TRIGGER(APPLI,TABLE,"D") From ATRIGGER
  Else
   If dim([F:ATB]AUDCRE)>0 & [F:ATB]AUDCRE=2 
    Call ECR_TRACE("--- AUDCRE"-TABLE,0) From GESECRAN
    Call TRIGGER(APPLI,TABLE,"I") From ATRIGGER
   Endif
   If dim([F:ATB]AUDUPD)>0 & [F:ATB]AUDUPD=2 
    Call ECR_TRACE("--- AUDUPD"-TABLE,0) From GESECRAN
    Call TRIGGER(APPLI,TABLE,"I") From ATRIGGER
   Endif
   If dim([F:ATB]AUDDEL)>0 & [F:ATB]AUDDEL=2 
    Call ECR_TRACE("--- AUDDEL"-TABLE,0) From GESECRAN
    Call TRIGGER(APPLI,TABLE,"I") From ATRIGGER
   Endif
  Endif
 Endif
Endif
End





