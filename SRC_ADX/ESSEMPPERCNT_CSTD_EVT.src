#<AdxTL>@(#)0.0.0.0 $Revision$ 
#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AREAD_AFTER"                      : Gosub AREAD_AFTER
    Endcase
Endcase
Return


$AREAD_AFTER

Local Integer READSTATUS
Local Integer NI
#Legislation
this.TCH_LEG = func DIVPAYE_SOA.GET_LEG_EMP(this.REFNUM, 1)


If this.PERCNT <> null
  For NI = 1 To maxtab(this.PERCNT)
    If this.PERCNT(NI) <> null and find(this.PERCNT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      this.PERCNT(NI).TCH_NUMLIG = NI
      this.PERCNT(NI).TCH_CNTSTA = "T"
    Endif
  Next
Endif


#Relationship type
#KGZA
If func DIVPAYE.IS_AFRICA_LEG(this.TCH_LEG)>0 or func DIVPAYE.IS_KZA(this.TCH_LEG)>0 or func DIVPAYE.IS_MIDDLEEAST_LEG(this.TCH_LEG)>0
  Local Instance I_EMPLOIDSA Using C_EMPLOIDSA
  If (I_EMPLOIDSA <> null) : FreeGroup I_EMPLOIDSA : Endif
  I_EMPLOIDSA = NewInstance C_EMPLOIDSA AllocGroup null


  [L]READSTATUS = fmet I_EMPLOIDSA.AREAD(this.REFNUM)
  If ([L]READSTATUS  >= [V]CST_AERROR)
    #Error not handled - no class transfer will be performed
    #ASTATUS=fmet this.ASETERROR("",func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(I_EMPLOIDSA),[V]CST_AERROR)
  Else
    #Persons to contact
    If I_EMPLOIDSA.PERCNT <> null
      For K = 1 To maxtab(I_EMPLOIDSA.PERCNT)
        If this.PERCNT(K) <> null
          If this.PERCNT(K).ESSUIDCNT = I_EMPLOIDSA.PERCNT(K).ESSUIDCNT or this.PERCNT(K).ESSUIDCNT = 0
            this.PERCNT(K).CNTTYP = I_EMPLOIDSA.PERCNT(K).CNTTYP
          Endif
        Endif
      Next
    Endif
  Endif
Endif



If func ESSEMPPERCNT_CSTD_EVT.ASSIGNESSUIDCNT(this) = [V]CST_AERROR

  ASTATUS=fmet this.ASETERROR("","UID Assignment error",[V]CST_AERROR)
Endif
Return

#**
#* Check and assign unique ESS ID to the record for persons to contact
#* @param ESSEMPPERCNT Variable class instance (ESSEMPPERCNT)
#* @return ESS_UPDATE Local Integer - Default [V]CST_AOK
#*!
Funprog ASSIGNESSUIDCNT(V_ESSEMPPERCNT)
Variable Instance V_ESSEMPPERCNT Using C_ESSEMPPERCNT
Local Integer ESS_UPDATE_NEWREC,ESS_UPDATE
Local Integer K, NEW_ESSUID

Local File EMPLOID    [ID4]
Local File EMPLOID    [ID5]
Local File EMPLOIDSA  [IDES5]

ESS_UPDATE_NEWREC = [V]CST_AOK
ESS_UPDATE        = [V]CST_AOK

If V_ESSEMPPERCNT.PERCNT <> null
  For K = 1 To maxtab(V_ESSEMPPERCNT.PERCNT)
    If V_ESSEMPPERCNT.PERCNT(K) <> null
      If V_ESSEMPPERCNT.PERCNT(K).ESSUIDCNT = 0
        ESS_UPDATE_NEWREC = [V]CST_ANEW
        NEW_ESSUID = uniqid([F:ID5])
        V_ESSEMPPERCNT.PERCNT(K).ESSUIDCNT = NEW_ESSUID
        #Update existing records only - New records will be updated after approval
        If V_ESSEMPPERCNT.PERCNT(K).TCH_CNTSTA = "T"
          Update [F:ID5] Where REFNUM = V_ESSEMPPERCNT.REFNUM  With ESSUIDCNT(K-1) = NEW_ESSUID
        Endif
        If fstat <> [V]CST_AOK
          ESS_UPDATE = [V]CST_AERROR #Variable declared in $DECLARE_ESS_UID_STAT
          Break
        Else
          If func DIVPAYE.IS_AFRICA_LEG(V_ESSEMPPERCNT.TCH_LEG)>0 or func DIVPAYE.IS_KZA(V_ESSEMPPERCNT.TCH_LEG)>0 or func DIVPAYE.IS_MIDDLEEAST_LEG(V_ESSEMPPERCNT.TCH_LEG)>0
            If V_ESSEMPPERCNT.PERCNT(K).TCH_CNTSTA = "T"
              Update [IDES5] Where REFNUM = V_ESSEMPPERCNT.REFNUM  With ESSUIDCNT(K-1) = NEW_ESSUID
            Endif
            If fstat <> [V]CST_AOK
              ESS_UPDATE = [V]CST_AERROR #Variable declared in $DECLARE_ESS_UID_STAT
              Break
            Endif
          Endif
        Endif
      Endif
    Endif
  Next K
Endif
End ESS_UPDATE

