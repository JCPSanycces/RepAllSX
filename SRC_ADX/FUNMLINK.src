#<AdxTL>@(#)11.0.0.0 $Revision$
# Gestion du masque MTOLINKB
#---------------------------------------------------------------------------#
# Action FMLB Affectation (à la commande)
#---------------------------------------------------------------------------#
$ACTION
If pat(ACTION,"BB*_NBLIG")
   Gosub RECHARG_PARAM
   Gosub LECTURE_BTS : # Issue 96456 GH 14/06/2018 - More general than before (button 5)
Endif
Case ACTION
    When "INIT"          : Gosub INIT
    When "SEL_LISTE"     : Gosub SEL_LISTE
    When "FIN_LISTE"     : Gosub FIN_LISTE
    When "CONTROLE"      : Gosub CONTROLE
    When "OUVRE"         : Gosub OUVRE
    When "TITRE"         : Gosub TIT
    When "DEBUT"         : Gosub DEBUT
    When "APRES_MODIF"   : Gosub APRES_MODIF
    When "SETBOUT"       : Gosub SETBOUT
    When "ENR"           : Gosub ENR
    When "BOUTON"        : Gosub BOUTON
    When "MEN"           : Gosub BOUTON
    When "AP_CHOIX"      : Gosub AP_CHOIX
    When "ABA"           : Gosub ABANDON
    When "EDI"           : Gosub EDITION
    When "TERMINE"       : Gosub TERMINE
    When "SORTIE"        : Gosub SORTIE
    When "AB11_NBLIG"    : Gosub AB11_NBLIG
    When "BB11_NBLIG"    : Gosub BB11_NBLIG
    When "AB13_NBLIG"    : Gosub MEM_VCR From BENCHLIB
    When "AB14_NBLIG"    : Gosub MEM_VCR From BENCHLIB
    When "END"           : Gosub FIN
Endcase
Return

##########################################################################
$INIT
## GH 28/03/12 bug 79361
Local Char OFONCTION(GLONAFC)
OFONCTION=[V]GFONCTION

If GFONCTION<>"FUNMLINK"
 [V]GFONCTION = "FUNMLINK"
 Call AUTORIS From EXEFNC
 If GNBAUZ=0
  If GNBSITE=0
   Call ERREUR(mess(33,104,1)) From GESECRAN : # Vous devez d'abord créer un site dans le dossier
  Else
   Call ERREUR(GFONCTION-":"-mess(1,123,1)) From GESECRAN  : # Fonction non autorisée
  Endif
  FIN=1 : Return
 Elsif [L]PARAM(1)<>"" & GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE & !find([L]PARAM(1),GUSRFCY(1..GNBAUZ))
  Call ERREUR([L]PARAM(1)-":"-mess(2,104,1)) From GESECRAN : # Vous n'avez pas les droits pour ce site
  FIN=1 : Return
 Endif
Endif
##

If dim(GMDLNUM) < 0 : Global Char    GMDLNUM(GLONTRS) : GMDLNUM = "" : Endif
Return

#########################################################################
$SORTIE
## GH 28/03/12 bug 79361
If OFONCTION<>"FUNMLINK"
 [V]GFONCTION =  OFONCTION
 Call AUTORIS From EXEFNC : # pour recharger GUSRFCY, GUSRAUZ, GNBAUZ
Endif
Return

###########################################################################
# selection de la transaction
$SEL_LISTE
Local Char     TABACS(10)(100)
Local Integer  NBACS
Local Char    TEX(30)(0..100) , TEXTE(50)(0..100)
Local Char    TIT(30)
Local Integer NBTEX

If clalev ([F:BTS])=0  : Local File BENCHTRS [BTS] : Endif

# si on vient du planning global, on vérifie si un code transaction est passé
If (left$(GFONCTION,9) = "FUNGBENCH" | left$(GFONCTION,8) = "FUNMPICK")
    # si on vient accidentellement (on a pas fait de sélection dans zoom encours associé mais l'action
    # suite s'exécute quand même ...
    If GSTATUT = 7 : OK = 0 : GSTATUT = 0 : Return : Endif
    If [M:MGB]TRS <> ""
        Read [BTS]BTS0=52;[M:MGB]TRS
        If fstat | [F:BTS]ENAFLG=1  : Return : Endif
        GMDLNUM = [F:BTS]BTSNUM
        Return
    Endif
Endif

If left$(GFONCTION,9) = "FUNDBENCH" : GMDLNUM = [F:BTS]BTSNUM : Return : Endif

If clalev([F:ACC]) = 0 : Local File ACCES [ACC] : Endif

CRITERE = "BTSTYP=52&ENAFLG=2"

#---------
# PE pour initialisation
GPOINT = "FILTER_TRS"
Gosub  ENTREE From EXEFNC
#---------

If GPROFIL <> GSUPER
    For [ACC]CODACC Where USR=GUSER
       If [F:ACC]EXEC=2 : [L]TABACS(NBACS)=vireblc([F:ACC]CODACC,1) : NBACS +=1 : Endif
       If NBACS > 99 : Break : Endif
    Next
    CRITERE += "& (ACSCOD = ''  | find(ACSCOD,TABACS(0..99)))"
Endif

For [F:BTS] Where evalue(CRITERE)
    NBTEX+= 1
    TEX(NBTEX)   =[F:BTS]BTSNUM
    Call LECTEXTRA(TEXTE(NBTEX),"BENCHTRS","DESAXX",num$([F:BTS]BTSTYP),[F:BTS]BTSNUM) From ATEXTRA
    TEXTE(NBTEX) = TEX(NBTEX)-TEXTE(NBTEX)
Next
TIT(0) = mess(3,126,1) # Choix transactions
Return

###########################################################################
$FIN_LISTE
If GSTATUT = 7  : GMDLNUM = "" : Return : Endif
GMDLNUM = TEX(CHOIX)
Return

#########################################################################
$CONTROLE
If GMDLNUM = "" : FIN = 1 : Return : Endif
Return

###########################################################################
# Initialisation/ouverture tables/substitution fenêtre
#########################################################################
$OUVRE
Global Integer GDLRET :               GDLRET = 0
Global Integer GBMAX
Global Integer GBMAX1
Global Char    GSYMBOLE(30)
Global Integer GIACTIVE
Global Integer GKILL
If dim(GVCR) < 0
    Global Char    GVCR(GLONVCR)
    Global Integer GLIN
    Global Integer GSEQ
    Kill GKILL
Endif

Local Char    WFCY(GLONFCY)
Local Char    WPLN(GLONAUS)  : # Planificateur
Local Date    WDAT
Local Char    WITM(GLONITM)
Local Char    WTRS(GLONTRS)
Local Char    WORI
Local Integer WSRT
Local Integer WRET : WRET = 0
Local Char    WDATC
Local Char    CODE(3)
Local Integer RETOUR, OK
Local Integer L, I, J, K, IRET
Local Integer REPONSE
Local Date    WDATBES
Local Integer WSRT
Local Char    WPJT(GLONPJT)
Local Char    WVCR(GLONVCR)
Local Char    WBPR(GLONBPR)
Local Date    WSTRDAT
Local Date    WENDDAT
Local Integer WFLT
Local Integer STA
Local Integer WSTA
Local Integer WTYPE, WAPP, WPRO, WINT, WSCO
Local Integer WSOSCOD
Local Char    IMPMSK
Local Integer WCTLCOD
Local Char    WMASQUE
Local Integer ISINTERCPY
Local Integer WTRI
Local Decimal WWRK
Local Integer IOK
Local Integer SAVISSEL
Local Integer WVCRTYP, WVCRLIN, WVCRSEQ
Local Char    WVCRNUM(GLONVCR)
Local Integer CLECUR : CLECUR = 0
Local Char    WECCMAJ(GLONICVVAL), WECCMIN(GLONICVVAL) # Issue 104943 - 2015-07-02 by BEEBE : implementing versioning ECC

# ouverture des tables
If clalev ([F:PTO])  = 0 : Local File PARMTO     [PTO] : Endif
If clalev ([F:MLK]) <= 0 : Local File MTOLINK    [MLK] : Endif
If clalev ([F:ORD]) <= 0 : Local File ORDERS     [ORD] : Endif
If clalev ([F:ORD1])<= 0 : Local File ORDERS     [ORD1]: Endif
If clalev ([F:ITM]) <= 0 : Local File ITMMASTER  [ITM] : Endif
If clalev ([F:ITF]) <= 0 : Local File ITMFACILIT [ITF] : Endif
If clalev ([F:ITS]) <= 0 : Local File ITMSALES   [ITS] : Endif
If clalev ([F:ITV]) <= 0 : Local File ITMMVT     [ITV] : Endif
If clalev ([F:ATZ]) <= 0 : Local File ATABZON    [ATZ] : Endif
If clalev ([F:TUN]) <= 0 : Local File TABUNIT    [TUN] : Endif
If clalev ([F:FCY]) <= 0 : Local File FACILITY   [FCY] : Endif
If clalev ([F:BTS]) <= 0 : Local File BENCHTRS   [BTS] : Endif
If clalev ([F:TFO]) <= 0 : Local File TABFOR     [TFO] : Endif
If clalev ([F:TRP]) <= 0 : Local File TABREOPOL  [TRP] : Endif
If clalev ([F:PCB]) <= 0 : Local File PARMRP     [PCB] : Endif

If clalev ([F:BPD]) <= 0  : Local File BPDLVCUST  [BPD] : Endif
If clalev ([F:BPR]) <= 0  : Local File BPARTNER   [BPR] : Endif
If clalev ([F:BPC]) <= 0  : Local File BPCUSTOMER [BPC] : Endif
If clalev ([F:FCY]) <= 0  : Local File FACILITY   [FCY] : Endif
If clalev ([F:STA]) <= 0  : Local File STOALL     [STA] : Endif
If clalev ([F:EVL]) <= 0  : Local File ECCVAL     [EVL] : Endif # Issue 111122 - 2015-10-19 by GH

If dim(GRCPFCY)<0 : Global Char GRCPFCY(GLONFCY) : Endif

Gosub OPEN_HL_TABLIN From HLIGHTLIB

If GMODU(8) = 2
    If clalev ([F:MTS]) <= 0 : Local File MFGTRS    [MTS] : Endif
    If clalev ([F:MFG]) <= 0 : Local File MFGHEAD   [MFG] : Endif
    If clalev ([F:MFI]) <= 0 : Local File MFGITM    [MFI] : Endif

    If clalev ([F:TCA]) <= 0 : Local File TABCOUAFF [TCA] : Endif
    ## GH 19/05/2014 bug 100108 société et législation non encore déterminées ici
    #Call LECTCA(8,OK) From SUBTCA
    #If OK=0 : Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN : Return : Endif
    #GOPS    = [F:TCA]CODNUM(4)   # compteur suggestion opérations

    # masque pour paramètres mises à jour
    Local Mask MFGK [MFGK]
Endif

If GMODU(6) = 2
    If clalev ([F:POH]) <= 0 : Local File PORDER     [POH] : Endif
    If clalev ([F:POP]) <= 0 : Local File PORDERP    [POP] : Endif
    If clalev ([F:POQ]) <= 0 : Local File PORDERQ    [POQ] : Endif
    If clalev ([F:PSD]) <= 0 : Local File PREQUISD   [PSD] : Endif
    If clalev ([F:POC]) <= 0 : Local File PORDERC    [POC] : Endif
    If clalev ([F:SCO]) <= 0 : Local File SCOHEAD    [SCO] : Endif
    If clalev ([F:SCI]) <= 0 : Local File SCOITM     [SCI] : Endif
    If clalev ([F:PTR]) <= 0 : Local File PURTRS     [PTR] : Endif
Endif

If GMODU(5) = 2
    If clalev ([F:SOH]) <= 0 : Local File SORDER     [SOH] : Endif
    If clalev ([F:SOP]) <= 0 : Local File SORDERP    [SOP] : Endif
    If clalev ([F:SOQ]) <= 0 : Local File SORDERQ    [SOQ] : Endif
    If clalev ([F:SOC]) <= 0 : Local File SORDERC    [SOC] : Endif
Endif

Local Mask SCOK [SCOK]  : # GH 08/04/2014 bug 99003
Local Mask ORCK [ORCK]
Local Mask MLIK [MLIK]

# pour memo
If clalev ([M:MFB4]) <= 0 :  Local Mask MFGBCRIT4   [MFB4] : Endif

# chargement des paramètres action
WFCY    = PARAM(1)
WPLN    = PARAM(2)
WDATC   = PARAM(3)
WITM    = PARAM(4)
WTRS    = PARAM(5)
WORI    = PARAM(6)
WSRT    = val(PARAM(7))

# Issue 104943 - 2015-07-02 by BEEBE : implementing versioning ECC
If dim(PARAM(9))>0  : WECCMAJ=PARAM(9)  : Endif
If dim(PARAM(10))>0 : WECCMIN=PARAM(10) : Endif

# si zoom encours associé depuis planning global
If dim(GZOOM) > 0
    If GZOOM
        WFCY = GZOOMFCY
        WITM = GZOOMITM
    Endif
Endif

Gosub LECTURE_BTS

# initialisations
Gosub ROLES_INIT

# substitution fenêtre
BOITE     = "WFMLKB"+GMDLNUM
WMASQUE   = "WT52"+GMDLNUM+"K"
Gosub CHANGE_AWI From BENCHLIB

Return

#########################################################################
$TIT
Call LECTEXTRA(TIT,"BENCHTRS","DESAXX",num$([F:BTS]BTSTYP),[F:BTS]BTSNUM) From ATEXTRA
Call TITAWI(BOITE,GMESSAGE) From OBJDIV
TIT = GMESSAGE-[F:BTS]BTSNUM-":"-TIT
GMESSAGE=""
Return

#########################################################################
# alimentation initiale écran
$DEBUT
Raz [M:MLB]

# FQ 74895 GA 07/2011 déplacé avant recopie des autres critères et déclenché de façon systématique, même si appel en tunnel
# application memo STD
# If WORI=""
    Raz [M:MFB4]
    If filinfo(filpath("ETM",GUSER+"_"+GMDLNUM+"_"+"STD","mfd",0),0)>=0
        Call LECMEMO("STD","[M:MFB4]",GMDLNUM+"~mfd") From GMEMO
        # On applique le code mémo STD si c'est la transaction à laquelle il se rapporte
        [M:MLB]        = [M:MFB4]
    Endif
# Endif

If WFCY <> "" : GFCY = WFCY : Else Call FIND_GFCYDEF(7) From TRTX3 : Endif
[M:MLB]FCY = GFCY : Gosub CHARG_PARAM
If GMODU(8)=2 & GOPS="" : Raz [M:MLB]FCY : Endif : ## GH 19/05/2014 bug 100108
If WPLN <> "" : [M:MLB]PLANNER = WPLN : Else : [M:MLB]PLANNER = GUSER      : Endif
If WDATC <> ""
    If instr(1,WDATC,"/")
        WDAT = "["+WDATC+"]"
    Else
        WDAT = WDATC
    Endif
Endif
If WDAT <> [0/0/0] : [M:MLB]MSTDAT = WDAT : Else : [M:MLB]MSTDAT = date$+(GPLNHOR*7) : Endif

If WITM <> ""
    [M:MLB]ITMREF     = WITM
    Call C_ITMREF([M:MLB]ITMREF)
    Call AM_ITMREF([M:MLB]ITMREF)
Elsif dim([M:MLB]IECCVALMAJ)>0
    Diszo [M:MLB]IECCVALMIN
    Diszo [M:MLB]IECCVALMAJ
Endif

If WSRT<>0 : # GH 05/12/12 bug 86277
    [M:MLB]SRTCOD     = WSRT
Endif
If [M:MLB]SRTCOD  = 0 : [M:MLB]SRTCOD = 5 : Endif


# Issue 104943 - 2015-08-04 by BEEBE : implementing versioning ECC
If dim([M:MLB]IECCVALMAJ)>0
    If varmode([M:MLB]IECCVALMAJ)=0 : [M:MLB]IECCVALMAJ=WECCMAJ : Endif
    If varmode([M:MLB]IECCVALMIN)=0 : [M:MLB]IECCVALMIN=WECCMIN : Endif
Endif

# mémorisation contexte habilitation suivant transaction
Gosub ANALYSE_CTX

# mémorisation nombre de ligne maxi
GBMAX  = dim([M:MLB]WIPTYPSTA)
GBMAX1 = dim([M:MLB]XTYP1)

GIACTIVE = 0
Gosub GET_ENTRY_VCR
If WFCY <> "" & WITM <> ""
    If dim(GDLRET) > 0 : IRET = GDLRET : Endif
    [M:MLB]REACT = 2
    Gosub REACTUALISATION
    [M:MLB]REACT = 1
    If dim(GDLRET) > 0 : GDLRET = IRET : Endif
    If [M:MLB]ISSEL>0 : SUIZON = "[M:MLB]NBLIG("+num$([M:MLB]ISSEL-1)+")" : Endif
Endif

# Issue 110957 - 2015-10-07 by GH
If dim([M:MLB]ICRID)>0
   Diszo [MLB]ICRID
   If func ECCLIB.NBRCPN([M:MLB]ITMREF)>0 : # already done via AM_ITMREF for a product with no version
      [M:MLB]ICRID = func TRTX3FNC.CCMID([M:MLB]ITMREF,[M:MLB]IECCVALMAJ,[M:MLB]IECCVALMIN)
      If dim([M:MLB]ICRFLG)>0
         [M:MLB]ICRFLG = string$([M:MLB]ICRID<>"","151")
      Endif
   Endif
Endif
If dim([M:MLB]CRID)>0
   Diszo [MLB]CRID
Endif

Diszo [M:MLB]15
Affzo [M:MLB]5-15
Return

#########################################################################
$APRES_MODIF
# pour la détermination de [M:MLB]PENDING dans $SETBOUT
Case COUZON
 When "FRCFLG"  : [M]FRCFLG(COUIND)=zc
 When "LIKQTY1" : [M]LIKQTY1(COUIND)=zc
Endcase
Return

#########################################################################
# état des boutons
$SETBOUT
If [M:MLB]ISSEL > 0
    Call VIREBOUT(CHMEN,"12") From GOBJET             # recherche + critères
Endif

If (WAPP < 2 & WINT < 2) | GMODU(6) <> 2              # achat
   Call VIREBOUT(CHMEN,"5") From GOBJET
Endif
If WPRO < 2 | GMODU(8) <> 2                           # fabrication - 14102 mm 06.06
    Call VIREBOUT(CHMEN,"6") From GOBJET
Endif
If WSCO < 2 | GMODU(6) <> 2                           # sous-traitance
    Call VIREBOUT(CHMEN,"7") From GOBJET
Endif

# affectations en attente d'enregistrement ?
[M:MLB]PENDING = 1
If [M:MLB]ISSEL > 0
    For I = 0 To [M:MLB]NBLIG1 - 1
      If [M:MLB]RECORDED1(I) = 1 | [M:MLB]LIKQTY1(I)<>[M:MLB]ORILIKQTY1(I) | [M:MLB]FRCFLG(I)<>[M:MLB]ORIFRCFLG(I)
         [M:MLB]PENDING = 2 : Break
      Endif
    Next I
    If [M:MLB]NBLINK([M:MLB]ISSEL-1) <> [M:MLB]NBLIG1 : [M:MLB]PENDING = 2 : Endif
Endif

# activation boutons
If [M:MLB]PENDING = 2
    ETABOU(GENRE) = 1
    ETABOU(GABAN) = 1
Else
    ETABOU(GENRE) = 0
    ETABOU(GABAN) = 0
Endif

# activation du bouton raz, si le tableau contient des icônes de désaffectations
If sigma(0, [M:MLB]NBLIG1-1, [M:MLB]ICOUNLINK(indcum) = "168")=0
  Call VIREBOUT(CHMEN,"4") From GOBJET
Endif

# activation bouton proposition si reste à affecter > 0
If [M:MLB]ISSEL > 0 & ETABOU(GENRE) = 0
    WWRK = [M:MLB]RMNEXTQTY([M:MLB]ISSEL - 1) - [M:MLB]MTOQTY([M:MLB]ISSEL - 1) - [M:MLB]ALLQTY([M:MLB]ISSEL - 1)
    If WWRK <= 0 | [M:MLB]FMI([M:MLB]ISSEL - 1) <> 1 : Call VIREBOUT(CHMEN,"3") From GOBJET : Endif
Else
    Call VIREBOUT(CHMEN,"3") From GOBJET
Endif

If [M:MLB]ITMREF = "" : Call VIREBOUT(CHMEN, "AGSDLFR") From GOBJET : Endif
If [M:MLB]PENDING = 2 : Call VIREBOUT(CHMEN, "LF") From GOBJET : Endif
# si article saisi et règle exclut l'auto, pas de lien vers traitement auto
If [M:MLB]ITMREF <> "" & [F:PTO]PTOAUT <> 2 : Call VIREBOUT(CHMEN, "LF") From GOBJET : Endif

IMGFLG(3) = ([M:MLB]XLOCKED = 2)    # Cadenas pour documents lockés
Return

########################################################################
$BOUTON
Case BOUT
    When "1"       :     Gosub RECHERCHER
    When "2"       :     Gosub CRITERES
    When "3"       :     Gosub PROPOSITION
    When "4"       :     Gosub RESET
    When "5"       :     Gosub ACHAT
    When "6"       :     Gosub FABRICATION
    When "7"       :     Gosub SOUSTRAIT
    When "L","F"   :     Gosub LECTURE_BTS
                         Gosub GET_ACTIVE_VCR
                         Gosub REACTUALISATION
    When "T"       :     Gosub LECTURE_BTS                # rechargement BTS après visualisation
Endcase
FIN=0
Return

########################################################################
$PROPOSITION
Raz [M:MLIK]
[M:MLIK]MAJCOD = "P"
[M:MLIK]PRPTYP = 2
[M:MLIK]PRPMOD = 3
[M:MLIK]STOFCY = [M:MLB]FCY
K = [M:MLB]ISSEL - 1
If [M:MLB]ISDEM = 2   # avant ISDEM = 2
    [M:MLIK]DEMTYP = [M:MLB]VCRTYP(K)
    [M:MLIK]DEMNUM = [M:MLB]VCRNUM(K)
    [M:MLIK]DEMLIN = [M:MLB]VCRLIN(K)
    [M:MLIK]DEMSEQ = [M:MLB]VCRSEQ(K)
    [M:MLIK]DWIPTYP = [M:MLB]WIPTYP(K)
Else
    [M:MLIK]RESSTYP = [M:MLB]VCRTYP(K)
    [M:MLIK]RESSNUM = [M:MLB]VCRNUM(K)
    [M:MLIK]RESSLIN = [M:MLB]VCRLIN(K)
    [M:MLIK]RESSSEQ = [M:MLB]VCRSEQ(K)
Endif
[M:MLIK]ITMREF = [M:MLB]ITMREF
[M:MLIK]TRTNAM = "FUNMLINK"
Call UPDMTOLINK From MTOLINKLIB
Return

########################################################################
# attention section appelée par MTOLINKLIB avec classe ORDB
#
$TRT_LINK
If IMOD
    For L = 0 To [M:MLB]NBLIG1 - 1
        If [M:MLB]VCRTYP1(L) = [F:ORDB]VCRTYP &
&          [M:MLB]VCRNUM1(L) = [F:ORDB]VCRNUM &
&          [M:MLB]VCRLIN1(L) = [F:ORDB]VCRLIN &
&          [M:MLB]VCRSEQ1(L) = [F:ORDB]VCRSEQ
            If [M:MLB]LIN1(L) <> -1 : [M:MLB]MTOQTY([M:MLB]LIN1(L)) -= [M:MLB]LIKQTY1(L) : Endif
            [M:MLB]MTOQTY([M:MLB]ISSEL - 1) -= [M:MLB]LIKQTY1(L)
            [M:MLB]MTOQTY1(L) -= [M:MLB]LIKQTY1(L)
            [M:MLB]LIKQTY1(L) += [M:MLIK]LIKQTY
            If [M:MLB]LIN1(L) <> -1 : [M:MLB]MTOQTY([M:MLB]LIN1(L)) += [M:MLB]LIKQTY1(L) : Endif
            [M:MLB]MTOQTY([M:MLB]ISSEL - 1) += [M:MLB]LIKQTY1(L)
            [M:MLB]MTOQTY1(L) += [M:MLB]LIKQTY1(L)
            [M:MLB]AVAQTY1(L)  = [M:MLB]RMNEXTQTY1(L) - [M:MLB]MTOQTY1(L)
            [M:MLB]RECORDED1(L)  = 1
            [M:MLB]PENDING       = 2
            Break
         Endif
    Next L
Else
    If [M:MLB]NBLIG1 < 1 : L = 0 : Else : L = [M:MLB]NBLIG1 : Endif

    # Ajout affectation issue de MTOLINKLIB (buffer ORDB chargé)
    [M:MLB]WIPSTA1(L)    = [F:ORDB]WIPSTA
    [M:MLB]WIPTYP1(L)    = [F:ORDB]WIPTYP
    [M:MLB]XTYP1(L)      = mess([M:MLB]WIPTYP1(L),341,1)+mess([M:MLB]WIPSTA1(L),342,1)
    [M:MLB]VCRTYP1(L)    = [F:ORDB]VCRTYP
    [M:MLB]XVCRTYP1(L)   = mess([M:MLB]VCRTYP1(L),701,1)
    [M:MLB]VCRNUM1(L)    = [F:ORDB]VCRNUM
    [M:MLB]VCRLIN1(L)    = [F:ORDB]VCRLIN
    [M:MLB]VCRSEQ1(L)    = [F:ORDB]VCRSEQ
    [M:MLB]LIKQTY1(L)    = [M:MLIK]LIKQTY
    [M:MLB]ENDDAT1(L)    = [F:ORDB]ENDDAT
    [M:MLB]XMESS1(L)     = ""
    [M:MLB]RECORDED1(L)  = 1
    [M:MLB]ORILIKQTY1(L) = 0
    [M:MLB]WIPNUM1(L)    = [F:ORDB]WIPNUM
    [M:MLB]RMNEXTQTY1(L) = [F:ORDB]RMNEXTQTY - [F:ORDB]ALLQTY
    [M:MLB]MTOQTY1(L)    = [F:ORDB]MTOQTY
    [M:MLB]AVAQTY1(L)    = [F:ORDB]RMNEXTQTY - [F:ORDB]MTOQTY - [F:ORDB]ALLQTY
    If [M:MLB]LIKQTY1(L) > [M:MLB]AVAQTY1(L) : [M:MLB]LIKQTY1(L) = [M:MLB]AVAQTY1(L) : Endif
    [M:MLB]MTOQTY1(L)   += [M:MLB]LIKQTY1(L)
    [M:MLB]AVAQTY1(L)    = [M:MLB]RMNEXTQTY1(L) - [M:MLB]MTOQTY1(L)
    [M:MLB]FRCFLG(L)     = 1
    [M:MLB]ORIFRCFLG(L)  = 0
    [M:MLB]ABBFIL1(L)    = [F:ORDB]ABBFIL
    If [F:ORDB]CPLQTY = 0
        [M:MLB]XTRKFLG(L) = mess(1,339,1) : # En attente
        Raz [M:MLB]XPROGRESS(L)
    Else
        [M:MLB]XTRKFLG(L) = mess(4,339,1) : # En cours
        [M:MLB]XPROGRESS(L) = num$(int(([F:ORDB]CPLQTY / [F:ORDB]EXTQTY) * 100)) - "%"
        [M:MLB]XTYP1(L) += ">"
    Endif
    If [M:MLB]ISDEM = 2
        If [M:MLB]ENDDAT1(L) > [M:MLB]ENDDAT([M:MLB]ISSEL-1) : [M:MLB]XMESS1(L) = mess(60,190,1) : Endif : # Retard
    Else
        If [M:MLB]ENDDAT([M:MLB]ISSEL-1) > [M:MLB]ENDDAT1(L) : [M:MLB]XMESS1(L) = mess(60,190,1) : Endif : # Retard
    Endif
    [M:MLB]NBLIG1 += 1
    [M:MLB]PENDING       = 2
    [M:MLB]MTOQTY([M:MLB]ISSEL - 1)        += [M:MLB]LIKQTY1(L)

    [M:MLB]LIN1(L) = -1

    # l'ordre est-il présent dans le tableau principal ?
    For K = 0 To [M:MLB]NBLIG - 1
        If [M:MLB]VCRTYP(K) = [M:MLB]VCRTYP1(L) &
&          [M:MLB]VCRNUM(K) = [M:MLB]VCRNUM1(L) &
&          [M:MLB]VCRLIN(K) = [M:MLB]VCRLIN1(L) &
&          [M:MLB]VCRSEQ(K) = [M:MLB]VCRSEQ1(L)
            [M:MLB]MTOQTY(K) += [M:MLB]LIKQTY1(L)
            [M:MLB]LIN1(L)    = K
            [M:MLB]BPRNUM1(L) = [M:MLB]BPRNUM(K)
            [M:MLB]UOM1(L)    = [M:MLB]UOM(K)
            [M:MLB]FMI1(L)    = [M:MLB]FMI(K)
            Break
        Endif
    Next K

    If [M:MLB]LIN1(L)=-1
       [M:MLB]BPRNUM1(L) = [F:ORDB]BPRNUM
       [M:MLB]FMI1(L)    = [F:ORDB]FMI
       If ISDEM : [M:MLB]UOM1(L) = TRESS_UOM(J) : Else [M:MLB]UOM1(L) = TDEM_UOM(I)  : Endif
    Endif
Endif

Gosub HIGHLIGHT
mkstat = 4

Return

########################################################################
## Bouton RAZ annulation des affectations
########################################################################
$RESET
K = [M:MLB]ISSEL - 1
I = 0
While I<[M:MLB]NBLIG1
    If [M:MLB]ICOUNLINK(I) = "168" : # icone "désaffecter"
       If [M:MLB]LIN1(I) >= 0
            [M:MLB]MTOQTY([M:MLB]LIN1(I)) -= [M:MLB]LIKQTY1(I)
            If [M:MLB]MTOQTY([M:MLB]LIN1(I)) < 0 : [M:MLB]MTOQTY([M:MLB]LIN1(I)) = 0 : Endif
        Endif
        [M:MLB]MTOQTY(K)              -= [M:MLB]LIKQTY1(I)
        If [M:MLB]MTOQTY(K) < 0 : [M:MLB]MTOQTY(K) = 0 : Endif
        Dela I,1 [M:MLB]NBLIG1
        [M:MLB]NBLIG1-=1
        [M:MLB]PENDING = 2
    Else I+=1
    Endif
Wend

Gosub HIGHLIGHT
Return

########################################################################
$ENR
K  = [M:MLB]ISSEL - 1

If [M:MLB]XLOCKED = 2
   GERR=1 : GMESSAGE = mess(10,100,1) : # Modification en cours sur un autre poste
   Return
Endif

## GH 09/07/2014 bug 101361 gestion de la vraie fausse contremarque
J  = 2
If [M:MLB]ISDEM=2 & [M:MLB]VCRTYP(K)=2 & [M:MLB]FMI(K)<>1 : # Ordre sélectionné = SOF de CTM
    For I = 0 To [M:MLB]NBLIG1 - 1
      If [M:MLB]RECORDED1(I)=1 & [M:MLB]LIN1(I)<>-2 : # Ressource à affecter
        J=1 : Break
     Endif
    Next I
Elsif [M:MLB]ISRESS=2 & [M:MLB]FMI(K)=1 : # Ordre sélectionné = ressource sans CTM
     For I = 0 To [M:MLB]NBLIG1 - 1
      If [M:MLB]RECORDED1(I)=1 & [M:MLB]LIN1(I)<>-2 & [M:MLB]VCRTYP1(I)=2 & [M:MLB]FMI1(I)<>1 : #  SOF de CTM à affecter
        J=1 : Break
     Endif
    Next I
Endif
If J<>2
   Call OUINON(mess(61,191,1),J) From GESECRAN : # Contremarque à générer
   If J<>2 : Return : Endif
Endif
##

Call DEBTRANS From GLOCK
$ENR_MLK
GOK= 1
Trbegin [MLK]
# purge MLK, on fonctionne en annule et remplace dans cette fonction
# on en profite pour mettre à jour les ordres en cas d'affectations supprimées
If [M:MLB]ISDEM = 2
    Filter [MLK] Where DEMTYP  = [M:MLB]VCRTYP(K)
&                    & DEMNUM  = [M:MLB]VCRNUM(K)
&                    & DEMLIN  = [M:MLB]VCRLIN(K)
&                    & DEMSEQ  = [M:MLB]VCRSEQ(K)
&                    & DWIPTYP = [M:MLB]WIPTYP(K)
&                Order By Key MLK0
Else
    Filter [MLK] Where RESSTYP = [M:MLB]VCRTYP(K)
&                    & RESSNUM = [M:MLB]VCRNUM(K)
&                    & RESSLIN = [M:MLB]VCRLIN(K)
&                    & RESSSEQ = [M:MLB]VCRSEQ(K)
&                Order By Key MLK1
Endif

For [MLK] Where STOFCY=[M:MLB]FCY & ITMREF=[M:MLB]ITMREF
    J = 0
    # l'ordre concerné est-il toujours affecté
    For I = 0 To [M:MLB]NBLIG1 - 1
        # on saute la ligne d'allocation
        If [M:MLB]LIN1(I) <> -2
            If [M:MLB]ISDEM = 2
                If [M:MLB]VCRTYP1(I) = [F:MLK]RESSTYP
&                & [M:MLB]VCRNUM1(I) = [F:MLK]RESSNUM
&                & [M:MLB]VCRLIN1(I) = [F:MLK]RESSLIN
&                & [M:MLB]VCRSEQ1(I) = [F:MLK]RESSSEQ
                   J = 1 : Break
                Endif
            Else
                If [M:MLB]VCRTYP1(I) = [F:MLK]DEMTYP
&                & [M:MLB]VCRNUM1(I) = [F:MLK]DEMNUM
&                & [M:MLB]VCRLIN1(I) = [F:MLK]DEMLIN
&                & [M:MLB]VCRSEQ1(I) = [F:MLK]DEMSEQ
&                & [M:MLB]WIPTYP1(I) = [F:MLK]DWIPTYP
                   J = 1 : Break
                Endif
            Endif
        Endif
    Next I

    # l'affectation n'est plus là, mise à jour ORDERS
    If !J
        If [M:MLB]ISDEM = 2
            Filter [ORD] Where VCRTYP = [F:MLK]RESSTYP
&                            & VCRNUM = [F:MLK]RESSNUM
&                            & VCRLIN = [F:MLK]RESSLIN
&                            & VCRSEQ = [F:MLK]RESSSEQ
        Else
            Filter [ORD] Where VCRTYP = [F:MLK]DEMTYP
&                            & VCRNUM = [F:MLK]DEMNUM
&                            & VCRLIN = [F:MLK]DEMLIN
&                            & VCRSEQ = [F:MLK]DEMSEQ
&                            & WIPTYP = [F:MLK]DWIPTYP
        Endif
        For [ORD]ORD3 Where STOFCY=[M:MLB]FCY & ITMREF=[M:MLB]ITMREF
            Readlock [ORD] Curr
            If fstat
             If [M:MLB]ISDEM = 2 : GCLE = [M:MLB]FCY-[F:MLK]RESSNUM-num$([F:MLK]RESSLIN)-num$([F:MLK]RESSSEQ)
             Else                : GCLE = [M:MLB]FCY-[F:MLK]DEMNUM-num$([F:MLK]DEMLIN)-num$([F:MLK]DEMSEQ)
             Endif
            Endif
            If fstat = 1  : GOK = -1 : GLOCK ="$ORDERS"-GCLE : Break
            Elsif fstat   : GOK = 0 : Call RSTA ("ORD", GCLE) From GLOCK : Break
            Endif

            [F:ORD]MTOQTY -= [F:MLK]LIKQTY
            If [F:ORD]MTOQTY < 0 : [F:ORD]MTOQTY = 0 : Endif

            [F:ORD]UPDDAT = date$
            [F:ORD]UPDUSR = GUSER
            Rewrite [ORD]
            If fstat : GOK=0  : Call FSTA("ORD") From GLOCK : Break : Endif

           # si désaffectation d'une cde de vente avec contremarque, raz infos FMI de la ligne de document
            If find([F:ORD]WIPTYP,1,8) & [F:ORD]FMI<>1
               Call MAJFMI("",0,0,WRET)
               #Call MAJFMISOQ([F:ORD]VCRNUM, [F:ORD]VCRLIN, [F:ORD]VCRSEQ, "", 0, 0, 2, WRET) From TRTVENMAJ
               If WRET
                  If GLOCK<>"" : GOK=-1 : Else GOK=0 : Endif
                  Break
               Endif
               [M:MLB]REACT=2
            Endif

            Break
        Next
        Filter [ORD]
        If GOK<1 : Break : Endif
    Endif

    # suppression de l'affectation
    Raz [M:MLIK]
    [M:MLIK]MAJCOD = "A"
    [M:MLIK] = [F:MLK]
    Call UPDMTOLINK From MTOLINKLIB
    If GOK<1 : Break : Endif

Next
Filter [MLK]
If GOK=0    : Goto AB_MOD
Elsif GOK<0 : Goto ROLL_MOD
Endif

# on repart du tableau des affectations pour les liens nouveaux ou modifiés
For I = 0 To [M:MLB]NBLIG1 - 1
    If [M:MLB]LIN1(I) <> -2
        Raz [M:MLIK]
        [M:MLIK]MAJCOD = "C"
        [M:MLIK]STOFCY = [M:MLB]FCY
        [M:MLIK]ITMREF = [M:MLB]ITMREF
        If [M:MLB]ISDEM = 2
            # la demande
            [M:MLIK]DEMTYP  = [M:MLB]VCRTYP(K)
            [M:MLIK]DEMNUM  = [M:MLB]VCRNUM(K)
            [M:MLIK]DEMLIN  = [M:MLB]VCRLIN(K)
            [M:MLIK]DEMSEQ  = [M:MLB]VCRSEQ(K)
            [M:MLIK]DWIPTYP = [M:MLB]WIPTYP(K)
            J=[M:MLB]FMI(K)
            # la ressource
            [M:MLIK]RESSTYP = [M:MLB]VCRTYP1(I)
            [M:MLIK]RESSNUM = [M:MLB]VCRNUM1(I)
            [M:MLIK]RESSLIN = [M:MLB]VCRLIN1(I)
            [M:MLIK]RESSSEQ = [M:MLB]VCRSEQ1(I)
        Else
            # la demande
            [M:MLIK]DEMTYP  = [M:MLB]VCRTYP1(I)
            [M:MLIK]DEMNUM  = [M:MLB]VCRNUM1(I)
            [M:MLIK]DEMLIN  = [M:MLB]VCRLIN1(I)
            [M:MLIK]DEMSEQ  = [M:MLB]VCRSEQ1(I)
            [M:MLIK]DWIPTYP = [M:MLB]WIPTYP1(I)
            J=[M:MLB]FMI1(I)
            # la ressource
            [M:MLIK]RESSTYP = [M:MLB]VCRTYP(K)
            [M:MLIK]RESSNUM = [M:MLB]VCRNUM(K)
            [M:MLIK]RESSLIN = [M:MLB]VCRLIN(K)
            [M:MLIK]RESSSEQ = [M:MLB]VCRSEQ(K)
        Endif
        [M:MLIK]LIKQTY  = [M:MLB]LIKQTY1(I)
        [M:MLIK]FRCFLG  = [M:MLB]FRCFLG(I)

        # une demande avec contremarque génère un lien de contremarque
        [M:MLIK]FMIFLG = 1 + (J<>1)

        # un lien de contremarque est forcé
        If [M:MLIK]FMIFLG = 2 : [M:MLIK]FRCFLG = 2 : Endif

        Call UPDMTOLINK From MTOLINKLIB
        If GOK<1 : Break : Endif

        # mise à jour encours
        Readlock [ORD]ORD0=[M:MLB]WIPTYP1(I);[M:MLB]WIPNUM1(I);[M:MLB]ITMREF
        If fstat = 1
         GOK = -1 : GLOCK ="$ORDERS"-num$([M:MLB]WIPTYP1(I))-[M:MLB]WIPNUM1(I)-[M:MLB]ITMREF : Break
        Elsif fstat
         GOK = 0 : Call RSTA ("ORD",num$([M:MLB]WIPTYP1(I))-[M:MLB]WIPNUM1(I)-[M:MLB]ITMREF) From GLOCK : Break
        Endif
        If [M:MLB]LIN1(I) >= 0
            [F:ORD]MTOQTY = [M:MLB]MTOQTY([M:MLB]LIN1(I))
        Else
            [F:ORD]MTOQTY -= [M:MLB]ORILIKQTY1(I)
            [F:ORD]MTOQTY += [M:MLB]LIKQTY1(I)
        Endif
        If [F:ORD]MTOQTY < 0 : [F:ORD]MTOQTY = 0 : Endif

        [F:ORD]UPDDAT = date$
        [F:ORD]UPDUSR = GUSER
        Rewrite [ORD]
        If fstat : GOK=0  : Call FSTA("ORD") From GLOCK : Break : Endif

        # si affectation d'une cde de vente avec contremarque, maj infos FMI de la ligne de document
        If [M:MLB]ISRESS = 2 & find([M:MLIK]DWIPTYP,1,8) & [F:ORD]FMI<>1
#           Call MAJFMISOQ([F:ORD]VCRNUM, [F:ORD]VCRLIN, [F:ORD]VCRSEQ,
#&                         [M:MLIK]RESSNUM, [M:MLIK]RESSLIN, [M:MLIK]RESSSEQ, 1, WRET) From TRTVENMAJ
           Call MAJFMI([M:MLIK]RESSNUM, [M:MLIK]RESSLIN, [M:MLIK]RESSSEQ,WRET)
           If WRET
              If GLOCK<>"" : GOK=-1 : Else GOK=0 : Endif
              Break
           Endif
           [M:MLB]REACT=2
        Endif
    Endif
Next I
If GOK=0    : Goto AB_MOD
Elsif GOK<0 : Goto ROLL_MOD
Endif

# mise à jour encours
Readlock [ORD]ORD0=[M:MLB]WIPTYP(K);[M:MLB]WIPNUM(K);[M:MLB]ITMREF
If fstat = 1
    GOK = -1 : GLOCK ="$ORDERS"-num$([M:MLB]WIPTYP(K))-[M:MLB]WIPNUM(K)-[M:MLB]ITMREF
    Goto ROLL_MOD
Elsif fstat
    GOK = 0
    Call RSTA ("ORD",num$([M:MLB]WIPTYP(K))-[M:MLB]WIPNUM(K)-[M:MLB]ITMREF)From GLOCK
    Goto AB_MOD
Endif

# modification quantité affectée
[F:ORD]MTOQTY = [M:MLB]MTOQTY(K)
If [F:ORD]MTOQTY < 0 : [F:ORD]MTOQTY = 0 : Endif

[F:ORD]UPDDAT = date$
[F:ORD]UPDUSR = GUSER
Rewrite [ORD]
If fstat : GOK=0  : Call FSTA("ORD") From GLOCK : Goto AB_MOD : Endif

# si affectation d'une cde de vente avec contremarque, maj infos FMI de la ligne de document
# le tableau des affectations ne peut contenir qu'une ligne, on peut utiliser l'indice 0 ou 1 (1 si une allocation existe)
If [M:MLB]ISDEM = 2 & find([F:ORD]WIPTYP,1,8) & [F:ORD]FMI<>1
   If [M:MLB]NBLIG1 = 1 : I=0 : Else I=1 : Endif
   If [M:MLB]LIN1(I)=-2
#      Call MAJFMISOQ([F:ORD]VCRNUM, [F:ORD]VCRLIN, [F:ORD]VCRSEQ, "", 0, 0, 2, WRET) From TRTVENMAJ
      Call MAJFMI("",0,0,WRET)
   Else
#      Call MAJFMISOQ([F:ORD]VCRNUM, [F:ORD]VCRLIN, [F:ORD]VCRSEQ,
#&                    [M:MLB]VCRNUM1(I), [M:MLB]VCRLIN1(I), [M:MLB]VCRSEQ1(I), 1, WRET) From TRTVENMAJ
      Call MAJFMI([M:MLB]VCRNUM1(I), [M:MLB]VCRLIN1(I), [M:MLB]VCRSEQ1(I),WRET)
   Endif
   If WRET
      If GLOCK<>"" : GOK=-1 : Goto ROLL_MOD
      Else         : GOK=0  : Goto AB_MOD
      Endif
   Endif
   [M:MLB]REACT=2
Endif
Commit

[M:MLB]PENDING=1

# réactualisation tableau des affectations
Dela 0,[M:MLB]NBLIG1+1 [M:MLB]NBLIG1
[M:MLB]NBLIG1 = 0 : [M:MLB]NBLINK(K) = 0

If [M:MLB]REACT=2
   Gosub GET_ACTIVE_VCR
   Goto REACTUALISATION
Else
   Gosub LOAD_LINK
   Gosub HIGHLIGHT
Endif
Return

#######################################################################
## GH 09/07/2014 bug 101361 gestion de la vraie fausse contremarque

Subprog MAJFMI(RESSNUM,RESSLIN,RESSSEQ,RET)
Value    Char    RESSNUM()
Value    Integer RESSLIN, RESSSEQ
Variable Integer RET

# ici [F:ORD] chargé pour la cde de vente
If !clalev([F:SOQ]) : Local File SORDERQ [SOQ] : Endif

If RESSNUM=""
   Readlock [SOQ]SOQ0 = [F:ORD]VCRNUM;[F:ORD]VCRLIN;[F:ORD]VCRSEQ
   If fstat
      Call RSTA("SOQ",[F:ORD]VCRNUM-num$([F:ORD]VCRLIN)-num$([F:ORD]VCRSEQ)) From GLOCK : RET=1 : End
   Endif
   If [F:SOQ]FMINUM="" : End : Endif

   Local Char    DEMNUM(GLONVCR) : DEMNUM = [F:ORD]VCRNUM
   Local Integer DEMLIN          : DEMLIN = [F:ORD]VCRLIN
   Local Integer DEMSEQ          : DEMSEQ = [F:ORD]VCRSEQ
   Case [F:ORD]FMI
      When 3 : Call RAZFMIPOH([F:SOQ]FMINUM, [F:SOQ]FMILIN, [F:SOQ]FMISEQ, RET) From TRTACHCDE1
      When 5 : Call RAZFMIMFG([F:SOQ]FMINUM, [F:SOQ]FMILIN, RET) From MFGAUTLIB
      When 6 : Call RAZFMISCO([F:SOQ]FMINUM, [F:SOQ]FMILIN, RET) From SCOAUTLIB
     When Default : RET=0
   Endcase
   If RET : End : Endif

   Call MAJFMISOQ(DEMNUM, DEMLIN, DEMSEQ, "", 0, 0, 2, RET) From TRTVENMAJ
   If RET : End : Endif

Else
   Call MAJFMISOQ([F:ORD]VCRNUM, [F:ORD]VCRLIN, [F:ORD]VCRSEQ, RESSNUM, RESSLIN, RESSSEQ, 1, RET) From TRTVENMAJ
   If RET : End : Endif

   Case [F:ORD]FMI
      When 3
        If !clalev ([F:POQ]) : Local File PORDERQ [POQ] : Endif
        Readlock [POQ]POQ0 = RESSNUM;RESSLIN;RESSSEQ
        If fstat
           Call RSTA("POQ",RESSNUM-num$(RESSLIN)-num$(RESSSEQ)) From GLOCK : RET=1 : End
        Endif

        [F:POQ]SOHNUM = [F:SOQ]SOHNUM
        [F:POQ]SOPLIN = [F:SOQ]SOPLIN
        [F:POQ]SOQSEQ = [F:SOQ]SOQSEQ
        [F:POQ]ORI = 3

        Rewrite [POQ]
        If fstat : Call FSTA("POQ") From GLOCK : RET=1 : End : Endif

        If [F:POQ]WIPNUM <> ""
           Readlock [ORD]ORD0 = 2;[F:POQ]WIPNUM;[F:POQ]ITMREF
           If fstat
              Call RSTA("ORD","2"-[F:POQ]WIPNUM-[F:POQ]ITMREF) From GLOCK : RET=1 : End
           Endif

           [F:ORD]FMI = 3

           Rewrite [ORD]
           If fstat : Call FSTA("ORD") From GLOCK : RET=1 : End : Endif
        Endif

      When 5
        If !clalev ([F:MFI]) : Local File MFGITM [MFI]   : Endif
        Readlock [MFI]MFI0 = RESSNUM;RESSLIN
        If fstat
           Call RSTA("MFI",RESSNUM-num$(RESSLIN)) From GLOCK : RET=1 : End
        Elsif [F:MFI]MFGSTA = 4 : # Si l'OF est clos, on n'y touche plus
           End
        Endif

        [F:MFI]FMI = 5
        [F:MFI]BPCTYPDEN = 2
        [F:MFI]BPCNUM    = [F:ORD]BPRNUM
        [F:MFI]VCRTYPORI = [F:ORD]VCRTYP
        [F:MFI]VCRNUMORI = [F:ORD]VCRNUM
        [F:MFI]VCRLINORI = [F:ORD]VCRLIN
        [F:MFI]VCRSEQORI = [F:ORD]VCRSEQ

        Rewrite [MFI]
        If fstat : Call FSTA("MFI") From GLOCK : RET=1 : End : Endif

        If [F:MFI]WIPNUM<>"" & [F:MFI]MFITRKFLG<=4  & [F:MFI]CPLQTY < [F:MFI]EXTQTY     # 38020 mm 10.06
           Readlock [ORD]ORD0 = 5;[F:MFI]WIPNUM;[F:MFI]ITMREF
           If fstat
              Call RSTA("ORD","5"-[F:MFI]WIPNUM-[F:MFI]ITMREF) From GLOCK : RET=1 : End
           Endif

           [F:ORD]FMI = 5
           [F:ORD]BPRNUM = [F:MFI]BPCNUM
           [F:ORD]VCRTYPORI = [F:MFI]VCRTYPORI
           [F:ORD]VCRNUMORI = [F:MFI]VCRNUMORI
           [F:ORD]VCRLINORI = [F:MFI]VCRLINORI
           [F:ORD]VCRSEQORI = [F:MFI]VCRSEQORI

           Rewrite [ORD]
           If fstat : Call FSTA("ORD") From GLOCK : RET=1 : End : Endif
        Endif

      When 6
        If !clalev ([F:SCI])  : Local File SCOITM [SCI]   : Endif
        Readlock [SCI]SCI0 = RESSNUM;RESSLIN
        If fstat
           Call RSTA("SCI",RESSNUM-num$(RESSLIN)) From GLOCK : RET=1 : End
        Endif

        [F:SCI]VCRTYPORI = [F:ORD]VCRTYP
        [F:SCI]VCRNUMORI = [F:ORD]VCRNUM
        [F:SCI]VCRLINORI = [F:ORD]VCRLIN
        [F:SCI]VCRSEQORI = [F:ORD]VCRSEQ

        Rewrite [SCI]
        If fstat : Call FSTA("SCI") From GLOCK : RET=1 : End : Endif

        If [F:SCI]WIPNUM<>"" & [F:SCI]WIPTYP=13
           Readlock [ORD]ORD0 = 13;[F:SCI]WIPNUM;[F:SCI]ITMREF
           If fstat
              Call RSTA("ORD","13"-[F:SCI]WIPNUM-[F:SCI]ITMREF) From GLOCK : RET=1 : End
           Endif

           [F:ORD]FMI = 6

           Rewrite [ORD]
           If fstat : Call FSTA("ORD") From GLOCK : RET=1 : End : Endif
        Endif
   Endcase
Endif
End

#######################################################################
$ROLL_MOD
Rollback : Call ROLL From GLOCK
If !GROLL : Goto ENR_MLK : Endif                 # llc 11.03

#######################################################################
$AB_MOD
Rollback
Return

#########################################################################
$AP_CHOIX
Case REPONSE
 When GSTARET : # interception de la touche return
   Gosub RECHERCHER

 When GSTACLK+3 : # Qui locke quoi ?
   SUIZON = "NBLIG("+num$([M:MLB]ISSEL-1)+")"
   nolign=[M:MLB]ISSEL
   Gosub LCKTST
   If [M:MLB]XLOCKED = 1 : REPONSE=0 : Return : Endif
   SYMBOLE=GSYMBOLE : GSYMBOLE=""
Endcase
Return

#########################################################################
$RECHERCHER
IOK = 0
Gosub RAZ_LINK
If IOK = 1 : Return : Endif

Gosub LECTURE_BTS
[M:MLB]REACT = 2
GIACTIVE = 0
Gosub REACTUALISATION
[M:MLB]REACT = 1
Return

#########################################################################
$ABANDON
SAVISSEL = [M:MLB]ISSEL
IOK=0
Gosub RAZ_LINK
If IOK = 1 : Return : Endif
[M:MLB]ISSEL = SAVISSEL
[M:MLB]REACT = 2
Gosub GET_ACTIVE_VCR
Gosub REACTUALISATION
[M:MLB]REACT = 1
Return

#########################################################################
$CRITERES
IOK=0
Gosub RAZ_LINK
If IOK = 1 : Return : Endif

GIACTIVE = 0
Gosub REACTUALISATION
Return

#########################################################################
$ACHAT
$FABRICATION
$SOUSTRAIT   : # pour BENCHLIBS/SAIMODEOX
Gosub RECHARG_PARAM
Gosub LECTURE_BTS
Gosub GET_ACTIVE_VCR
Gosub REACTUALISATION
Return

#########################################################################
$REACTUALISATION
If [M:MLB]REACT = 2
    Gosub CHARGE_MLB
    If nolign = GBMAX : GMESSAGE = mess(168,190,1) : GERR = 2 : Endif
    [M:MLB]REACT = 1
    Gosub HIGHLIGHT
Endif
Return

#########################################################################
$GET_ENTRY_VCR
WVCRNUM = ""
WVCRTYP = 0
WVCRLIN = 0
WVCRSEQ = 0

If GVCR = "" : Return : Endif

WVCRNUM = GVCR
WVCRLIN = GLIN
WVCRSEQ = GSEQ
GIACTIVE = 1
Return

#########################################################################
$GET_ACTIVE_VCR
WVCRNUM = ""
WVCRTYP = 0
WVCRLIN = 0
WVCRSEQ = 0
If [M:MLB]ISSEL = 0 : Return : Endif

WVCRNUM = [M:MLB]VCRNUM([M:MLB]ISSEL - 1)
WVCRLIN = [M:MLB]VCRLIN([M:MLB]ISSEL - 1)
WVCRSEQ = [M:MLB]VCRSEQ([M:MLB]ISSEL - 1)
GIACTIVE = 1
Return

############################################################################
$EDITION
Call PRTSCR(WMASQUE,"MLB","",0,0) From ATRTX3
Return

#########################################################################
$TERMINE
PARAM(7) = num$(GDLRET)
If GDLRET = 2 & left$(GFONCTION,9) = "FUNGBENCH"
    [M:MGB]REACT = 2
    Gosub FABRICATION From FUNGBENCH
Endif
If dim(GKILL) < 0
    If dim(GVCR) > 0 : Kill GVCR : Endif
    If dim(GLIN) > 0 : Kill GLIN : Endif
    If dim(GSEQ) > 0 : Kill GSEQ : Endif
Else
    Kill GKILL
Endif
GBNOACH = 1
GBNOPROD = 1
If dim(GZOOM) > 0
    If GZOOM
        GZOOM = 0
        Raz GZOOMFCY
        Raz GZOOMITM
    Endif
Endif
Call IMPSCR From ATRTX3
Return

#########################################################################
$FIN

Gosub DEVERROU

# si affectations en attente d'enregistrement ... Question
If [M:MLB]PENDING = 2
    IOK=1 :  # Des modifications sont en attente d'enregistrement.\Confirmer l'abandon ?
    Call OUINON(mess(218,190,1),IOK) From GESECRAN
    If IOK = 1 : FIN = 0 : Return : Endif
Endif
Return

########################################################################
# Analyse et mémorisation contexte
########################################################################
$ANALYSE_CTX
[M:MLB]PLNHAB = WPRO
[M:MLB]APPHAB = WAPP
[M:MLB]INTHAB = WINT
[M:MLB]SCOHAB = WSCO

# pour les sélections article/site
If [F:BTS]PLANNER = 2 & [F:BTS]BUYER = 1
    [M:MLB]ITMCAT = "2"
Endif
If [F:BTS]PLANNER = 1 & [F:BTS]BUYER = 2
    [M:MLB]ITMCAT = "1349"
Endif
If [F:BTS]PLANNER = 2 & [F:BTS]BUYER = 2
    [M:MLB]ITMCAT = "12349"
Endif

#   filtre sur planificateur
If [F:BTS]APPLAN = 1 | GBUYFLT = 1
    Case GPLNFLT
        When 2: [M:MLB]ITMFILTER = 'PLANNER=[M:MLB]PLANNER|PLANNER=""'
        When 3: [M:MLB]ITMFILTER = 'PLANNER=[M:MLB]PLANNER'
    Endcase
Else
    # GH 11/03/2014 bug 75840
    # Case GPLNFLT
    #    When 2: [M:MLB]ITMFILTER = 'PLANNER=[M:MLB]PLANNER|PLANNER=""|BUY=[M:MLB]PLANNER'
    #    When 3: [M:MLB]ITMFILTER = 'PLANNER=[M:MLB]PLANNER|BUY=[M:MLB]PLANNER'
    # Endcase
    Case GPLNFLT
        When 1: [M:MLB]ITMFILTER = 'BUY=[M:MLB]PLANNER|BUY=""'
        When 2: [M:MLB]ITMFILTER = 'PLANNER=[M:MLB]PLANNER|PLANNER=""|BUY=[M:MLB]PLANNER|BUY=""'
        When 3: [M:MLB]ITMFILTER = 'PLANNER=[M:MLB]PLANNER|BUY=[M:MLB]PLANNER|BUY=""'
    Endcase
Endif

If [M:MLB]MEMO="" : # GH 05/12/12 bug 86277
    [M:MLB]FORMULE = [F:BTS]DEFFOR

    # filtre "origine des suggestions" provenant de la transaction, appliqué par défaut
    [M:MLB]MRPFLG = [F:BTS]MRPFLG
Endif
Return

###########################################################################
# Chargement du masque
$CHARGE_MLB
Local Char    XCRITERE(255)
Local Char    XCRITERE1(255)
Local Char    XCRITERE2(255)
Local Char    XCRITERE3(255)
Local Char    XCRITERE4(255)
Local Char    FORMULE1(255)
Local Char    CUSFLT(255)
Local Decimal WQSOS             # Quantité ordres prévisions
Local Char    ECCFLTMAJ # Issue 104943 - implementing versioning
Local Char    ECCFLTMIN # Issue 104943 - implementing versioning

Dela 0,[M:MLB]NBLIG+1 [M:MLB]NBLIG

If GIACTIVE : Dela 0,[M:MLB]NBLIG1+1 [M:MLB]NBLIG1 : [M:MLB]NBLIG1 = 0 : Endif

Gosub LOAD_FILTER From BENCHLIB

If XCRITERE1  = "" : XCRITERE1  = "1=2" : Endif
If XCRITERE2  = "" : XCRITERE2  = "1=2" : Endif
If XCRITERE3  = "" : XCRITERE3  = "1=2" : Endif
If XCRITERE4  = "" : XCRITERE4  = "1=2" : Endif

# analyse présence formule de sélection
If [M:MLB]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
Else
    Read [F:TFO]TFO0=10;[M:MLB]FORMULE
    If fstat
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
    Else
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif

# Issue 104943 - 2015-07-02 by BEEBE : implementing versioning ECC
ECCFLTMAJ="1=1"
ECCFLTMIN="1=1"
If dim([M:MLB]IECCVALMAJ)>0
    If [M:MLB]IECCVALMAJ<>""
        ECCFLTMAJ="ECCVALMAJ = [M:MLB]IECCVALMAJ"
        If [M:MLB]IECCVALMIN<>""
            ECCFLTMIN="ECCVALMIN = [M:MLB]IECCVALMIN"
        Endif
    Endif
Endif

# Point d'entrée pour permettre à l'utilisateur de rajouter des sélections
Raz CUSFLT
GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
If CUSFLT = "" : CUSFLT = "1=1" : Endif

Filter [ORD] Where STOFCY = [M:MLB]FCY & ITMREF = [M:MLB]ITMREF & ENDDAT <= [M:MLB]MSTDAT
&                & (evalue(XCRITERE1) | evalue(XCRITERE2) | evalue(XCRITERE3) | evalue(XCRITERE4))
&                & evalue(FORMULE1) & evalue(CUSFLT) & evalue(ECCFLTMAJ) & evalue(ECCFLTMIN)
&            Order By Key ORD1

# unification chargement du tableau entre plan de travail et affectations ...
Default Mask [MLB]
Gosub LOAD_MGD_MLB From BENCHLIB

Filter [ORD]

# Affichage du plan de travail selon les règles du MRP - 38764 mm 12.06
If [F:BTS]HORDEM = 2 & WQSOS <>0
    WQSOS = 0
    Gosub DISPLAY_MRP From BENCHLIB
Endif

Gosub TRI_TAB
Gosub LOAD_EXTQTY From BENCHLIB

# activation par défaut
If GIACTIVE
    # Issue 85224 GH 30/08/2018 - it should not crash if variables VCR... not exist
    For I = 0 To [M:MLB]NBLIG - 1
        If dim([L]WVCRNUM)=1 &
&          [M:MLB]VCRNUM(I) = WVCRNUM &
&          [M:MLB]VCRLIN(I) = WVCRLIN &
&          [M:MLB]VCRSEQ(I) = WVCRSEQ
            [M:MLB]PECFLG(I) = "210"
            [M:MLB]ISSEL = I + 1
            K = [M:MLB]ISSEL - 1
            If (func CBNLIB.ISRESS([M:MLB]WIPTYP(K))) : [M:MLB]ISRESS = 2 : [M:MLB]ISDEM = 1  : Endif
            If (func CBNLIB.ISDEM ([M:MLB]WIPTYP(K))) : [M:MLB]ISDEM  = 2 : [M:MLB]ISRESS = 1 : Endif
            If [M:MLB]ISDEM=2 | [M:MLB]ISRESS=2 : Gosub LOAD_LINK : Endif
            Break
        Else
            [M:MLB]PECFLG(I) = ""
            If [M:MLB]ISSEL = I+1 : [M:MLB]ISSEL=0 : Endif
        Endif
    Next I
Endif
Return

###########################################################################
# tri selon date besoin
$TRI_TAB
If [M:MLB]NBLIG <> 0
    #----------------------------------------------------------------------------------------------
    GPOINT = "CUSSRT"
    WTRI = 0
    Gosub  ENTREE From EXEFNC
    If !WTRI
        Case [M:MLB]SRTCOD
            When 5 : Sorta [M:MLB]NBLIG [M:MLB]NBLIG Order By [M:MLB]ENDDAT(indice), [M:MLB]WIPTYP(indice), [M:MLB]VCRNUM(indice)    # date fin
            When 6 : Sorta [M:MLB]NBLIG [M:MLB]NBLIG Order By [M:MLB]REQDAT(indice), [M:MLB]WIPTYP(indice), [M:MLB]VCRNUM(indice)    # date besoin
        Endcase
    Endif
Endif
Return

############################################################
$AFF_DES
Local Integer    WSEM      : WSEM = 1  : # Premier jour ouvré semaine
Local Integer    WCOR
Local Decimal    WDEL
Local Integer    WCOD
Local Date       WDAT
Local Decimal    WDMYI
Local Date       WDMYD
Local Char       WPAR(1)
Call PARAM([MLB]FCY,"FIRWRKDAY",WPAR) From ADOVAL
If val(WPAR) < 1 | val(WPAR) > 7
   WSEM = 1
Else
   WSEM = val(WPAR)
Endif

[M:MLB]STU     = [F:ITM]STU
[M:MLB]PURFLG  = [F:ITM]PURFLG
[M:MLB]MFGFLG  = [F:ITM]MFGFLG
[M:MLB]SCPFLG  = [F:ITM]SCPFLG
[M:MLB]SCSFLG  = [F:ITM]SCSFLG
[M:MLB]PHAFLG  = [F:ITM]PHAFLG
[M:MLB]GENFLG  = [F:ITM]GENFLG
[M:MLB]TOOFLG  = [F:ITM]TOOFLG
[M:MLB]DLVFLG  = [F:ITM]DLVFLG
[M:MLB]SALFLG  = [F:ITM]SALFLG
[M:MLB]INTFLG  = [F:ITM]INTFLG
[M:MLB]SHR     = [F:ITF]SHR

# calcul date fin horizon demande arrondi fin semaine
If [F:ITF]FOH = 0
   [M:MLB]FOHDAT = [0/0/0]
Else
   If WSEM = 1
      WCOR = 7
   Else
      WCOR = WSEM-1
   Endif
   WCOD = [F:ITF]FOHUOT
   WDEL = [F:ITF]FOH
   WDAT = date$
   Call CALDAT("+",WCOR,WDAT,WCOD,WDEL,WDMYI,WDMYD,[M:MLB]FOHDAT) From CBNLIB
Endif

# calcul date fin horizon ferme
If [F:ITF]PLH = 0
  [M:MLB]PLHDAT = [0/0/0]
Else
  WCOR = 0
  WCOD = [F:ITF]PLHUOT
  WDEL = [F:ITF]PLH
  WDAT = date$
  Call CALDAT("+",WCOR,WDAT,WCOD,WDEL,WDMYI,WDMYD,[M:MLB]PLHDAT) From CBNLIB
Endif
[M:MLB]PLH     = [F:ITF]PLH
[M:MLB]PLHUOT  = [F:ITF]PLHUOT
[M:MLB]FOH     = [F:ITF]FOH
[M:MLB]FOHUOT  = [F:ITF]FOHUOT
[M:MLB]SAFSTO  = [F:ITF]SAFSTO
[M:MLB]REOMINQTY = [F:ITF]REOMINQTY

Affzo [M:MLB]5-10
Return

######################################################################################
$RAZ_LINK
K = [M:MLB]ISSEL - 1

If [M:MLB]NBLIG = 0 : Return : Endif

# si affectations en attente d'enregistrement ... Question
[M:MLB]REACT = 1
If [M:MLB]PENDING = 2
    IOK=1 : # Des modifications sont en attente d'enregistrement.\Confirmer l'abandon ?
    Call OUINON(mess(218,190,1),IOK) From GESECRAN
    If IOK = 1 : mkstat = 1 : Return : Endif
    [M:MLB]REACT = 2
Endif

Gosub DEVERROU
[M:MLB]ISRESS = 1 : [M:MLB]ISDEM = 1
[M:MLB]ISSEL = 0

# raz des affectations
For I = 0 To [M:MLB]NBLIG1 - 1
    If [M:MLB]RECORDED1(I) = 1
        # si la ligne est dans le tableau
        If [M:MLB]LIN1(I) >= 0
            [M:MLB]MTOQTY([M:MLB]LIN1(I)) -= [M:MLB]LIKQTY1(I)
            [M:MLB]MTOQTY([M:MLB]LIN1(I)) += [M:MLB]ORILIKQTY1(I)
            If [M:MLB]MTOQTY([M:MLB]LIN1(I)) < 0 : [M:MLB]MTOQTY([M:MLB]LIN1(I)) = 0 : Endif
        Endif
        [M:MLB]MTOQTY(K)    -= [M:MLB]LIKQTY1(I)
        [M:MLB]MTOQTY(K)    += [M:MLB]ORILIKQTY1(I)
        If [M:MLB]MTOQTY(K)  < 0 : [M:MLB]MTOQTY(K) = 0 : Endif
        [M:MLB]REACT = 2
    Endif
Next I
Dela 0,[M:MLB]NBLIG1+1 [M:MLB]NBLIG1
[M:MLB]NBLIG1 = 0
[M:MLB]PENDING = 1
If K >= 0 : [M:MLB]NBLINK(K) = 0 : Endif
Return

######################################################################################
$LOAD_LINK
Local Decimal WNETPRI
Local Char    WUOM(GLONUOM), WCUR(GLONCUR)
Local Char    WNUMORI(GLONVCR)
Local Integer WLINORI, WSEQORI

I = 0
# chargement allocation
If [M:MLB]ISDEM = 2 & [M:MLB]ALLQTY(K) <> 0
    # lecture allocation(s)
    IOK = 0
    For [STA]STA2 Where ITMREF = [M:MLB]ITMREF
&                     & VCRTYP = [M:MLB]VCRTYP(K)
&                     & VCRNUM = [M:MLB]VCRNUM(K)
&                     & VCRLIN = [M:MLB]VCRLIN(K)
&                     & VCRSEQ = [M:MLB]VCRSEQ(K)
        If find([F:STA]ALLTYP,1,2) : IOK = 1 : Break : Endif
    Next

    [M:MLB]VCRNUM1(I)    = mess(102,198,1) : # Stock
    # si on a trouvé une allocation, on affiche son type, sinon on est en cours de livraison
    If IOK : [M:MLB]XVCRTYP1(I) = mess([F:STA]ALLTYP,349,1) : Else : [M:MLB]XVCRTYP1(I) = mess(328,197,1) : Endif
    [M:MLB]LIKQTY1(I)    = [M:MLB]ALLQTY(K)
    [M:MLB]XMESS1(I)     = ""
    [M:MLB]RECORDED1(I)  = 2
    [M:MLB]ORILIKQTY1(I) = [M:MLB]LIKQTY1(I)
    [M:MLB]LIN1(I)       = -2
    [M:MLB]FRCFLG(I)     = 0
    [M:MLB]ORIFRCFLG(I)  = [M:MLB]FRCFLG(I)
    [M:MLB]NBLINK(K)    += 1
    [M:MLB]NBLIG1       += 1
    I                   += 1
Endif

# chargement des liens existants en référence à une demande
If [M:MLB]ISDEM = 2
    Filter [MLK] Where DEMTYP  = [M:MLB]VCRTYP(K)
&                    & DEMNUM  = [M:MLB]VCRNUM(K)
&                    & DEMLIN  = [M:MLB]VCRLIN(K)
&                    & DEMSEQ  = [M:MLB]VCRSEQ(K)
&                    & DWIPTYP = [M:MLB]WIPTYP(K)
&                Order By Key MLK0
Else
# chargement des liens existants en référence à une ressource
    Filter [MLK] Where RESSTYP = [M:MLB]VCRTYP(K)
&                    & RESSNUM = [M:MLB]VCRNUM(K)
&                    & RESSLIN = [M:MLB]VCRLIN(K)
&                    & RESSSEQ = [M:MLB]VCRSEQ(K)
&                Order By Key MLK1
Endif
For [MLK] Where STOFCY=[M:MLB]FCY & ITMREF=[M:MLB]ITMREF
    If I = GBMAX1 - 1 : Break : Endif
    If [M:MLB]ISDEM = 2
        [M:MLB]WIPSTA1(I)    = [F:MLK]RWIPSTA
        [M:MLB]WIPTYP1(I)    = [F:MLK]RWIPTYP
        [M:MLB]VCRTYP1(I)    = [F:MLK]RESSTYP
        [M:MLB]VCRNUM1(I)    = [F:MLK]RESSNUM
        [M:MLB]VCRLIN1(I)    = [F:MLK]RESSLIN
        [M:MLB]VCRSEQ1(I)    = [F:MLK]RESSSEQ
    Else
        [M:MLB]WIPSTA1(I)    = [F:MLK]DWIPSTA
        [M:MLB]WIPTYP1(I)    = [F:MLK]DWIPTYP
        [M:MLB]VCRTYP1(I)    = [F:MLK]DEMTYP
        [M:MLB]VCRNUM1(I)    = [F:MLK]DEMNUM
        [M:MLB]VCRLIN1(I)    = [F:MLK]DEMLIN
        [M:MLB]VCRSEQ1(I)    = [F:MLK]DEMSEQ
    Endif
    [M:MLB]XTYP1(I)      = mess([M:MLB]WIPTYP1(I),341,1)+mess([M:MLB]WIPSTA1(I),342,1)
    [M:MLB]XVCRTYP1(I)   = mess([M:MLB]VCRTYP1(I),701,1)
    [M:MLB]LIKQTY1(I)    = [F:MLK]LIKQTY
    [M:MLB]XMESS1(I)     = ""
    [M:MLB]RECORDED1(I)  = 2
    [M:MLB]ORILIKQTY1(I) = [M:MLB]LIKQTY1(I)
    [M:MLB]LIN1(I)       = -1
    [M:MLB]FRCFLG(I)     = [F:MLK]FRCFLG
    [M:MLB]ORIFRCFLG(I)  = [M:MLB]FRCFLG(I)

    # l'ordre est-il présent dans le tableau principal ?
    For J = 0 To [M:MLB]NBLIG - 1
        If [M:MLB]VCRTYP(J) = [M:MLB]VCRTYP1(I) &
&          [M:MLB]VCRNUM(J) = [M:MLB]VCRNUM1(I) &
&          [M:MLB]VCRLIN(J) = [M:MLB]VCRLIN1(I) &
&          [M:MLB]VCRSEQ(J) = [M:MLB]VCRSEQ1(I)
            [M:MLB]LIN1(I)  = J
            [M:MLB]WIPNUM1(I)     = [M:MLB]WIPNUM(J)
            [M:MLB]AVAQTY1(I)     = [M:MLB]RMNEXTQTY(J) - [M:MLB]MTOQTY(J) - [M:MLB]ALLQTY(J)
            [M:MLB]ENDDAT1(I)     = [M:MLB]ENDDAT(J)
            [M:MLB]RMNEXTQTY1(I)  = [M:MLB]RMNEXTQTY(J) - [M:MLB]ALLQTY(J)
            [M:MLB]MTOQTY1(I)     = [M:MLB]MTOQTY(J)
            [M:MLB]BPRNUM1(I)     = [M:MLB]BPRNUM(J)
            [M:MLB]UOM1(I)        = [M:MLB]UOM(J)
            [M:MLB]FMI1(I)        = [M:MLB]FMI(J)
            [M:MLB]VCRNUMORI1(I)  = [M:MLB]VCRNUMORI(J)
            [M:MLB]VCRLINORI1(I)  = [M:MLB]VCRLINORI(J)
            [M:MLB]VCRSEQORI1(I)  = [M:MLB]VCRSEQORI(J)
            [M:MLB]ABBFIL1(I)     = [M:MLB]ABBFIL(J)
            If [M:MLB]CPLQTY(J) = 0
                [M:MLB]XTRKFLG(I) = mess(1,339,1) : # En attente
                Raz [M:MLB]XPROGRESS(I)
            Else
                [M:MLB]XTRKFLG(I) = mess(4,339,1) : # En cours
                [M:MLB]XPROGRESS(I) = num$(int(([M:MLB]CPLQTY(J) / [M:MLB]EXTQTY(J)) * 100)) - "%"
                [M:MLB]XTYP1(I) += ">"
            Endif
        Endif
    Next J

    # l'ordre n'est pas dans le tableau
    If [M:MLB]LIN1(I) = -1
        For [ORD]ORD3 Where STOFCY = [M:MLB]FCY
&                         & VCRTYP = [M:MLB]VCRTYP1(I)
&                         & VCRNUM = [M:MLB]VCRNUM1(I)
&                         & VCRLIN = [M:MLB]VCRLIN1(I)
&                         & VCRSEQ = [M:MLB]VCRSEQ1(I)
            [M:MLB]WIPNUM1(I) = [F:ORD]WIPNUM
            [M:MLB]AVAQTY1(I) = [F:ORD]RMNEXTQTY - [F:ORD]MTOQTY - [F:ORD]ALLQTY
            [M:MLB]ENDDAT1(I) = [F:ORD]ENDDAT
            [M:MLB]RMNEXTQTY1(I)  = [F:ORD]RMNEXTQTY - [F:ORD]ALLQTY
            [M:MLB]MTOQTY1(I)     = [F:ORD]MTOQTY
            [M:MLB]FMI1(I)        = [F:ORD]FMI
            [M:MLB]BPRNUM1(I)     = [F:ORD]BPRNUM
            [M:MLB]ABBFIL1(I)     = [F:ORD]ABBFIL
            If [F:ORD]CPLQTY = 0
                [M:MLB]XTRKFLG(I) = mess(1,339,1) : # En attente
                Raz [M:MLB]XPROGRESS(I)
            Else
                [M:MLB]XTRKFLG(I) = mess(4,339,1) : # En cours
                [M:MLB]XPROGRESS(I) = num$(int(([F:ORD]CPLQTY / [F:ORD]EXTQTY) * 100)) - "%"
                [M:MLB]XTYP1(I) += ">"
            Endif
            [M:MLB]VCRNUMORI1(I)  = [F:ORD]VCRNUMORI
            [M:MLB]VCRLINORI1(I)  = [F:ORD]VCRLINORI
            [M:MLB]VCRSEQORI1(I)  = [F:ORD]VCRSEQORI
            If find([F:ORD]WIPTYP,1,2,4,5,7,8,9,13) : # GH 14/11/12 bug 85907 ajout de WIPTYP=8
                 # pour déterminer [M:MLB] UOM1(I), VCRNUMORI1(I), VCRLINORI1(I), VCRSEQORI1(I)
                 J=nolign
                 If dim([M:MLB]NETPRI)>0     : WNETPRI = [M:MLB]NETPRI(0)       : Endif
                 If dim([M:MLB]CUR)>0        : WCUR    = [M:MLB]CUR(0)          : Endif
                 WNUMORI = [M:MLB]VCRNUMORI(0)
                 WLINORI = [M:MLB]VCRLINORI(0)
                 WSEQORI = [M:MLB]VCRSEQORI(0)
                 WUOM    = [M:MLB]UOM(0)

                 nolign = 1 : [M:MLB]UOM(0)=""
                 Gosub GET_DOCUMENT_DATA From BENCHLIB
                 [M:MLB]UOM1(I)        = [M:MLB]UOM(0)
                 [M:MLB]VCRNUMORI1(I)  = [M:MLB]VCRNUMORI(0)
                 [M:MLB]VCRLINORI1(I)  = [M:MLB]VCRLINORI(0)
                 [M:MLB]VCRSEQORI1(I)  = [M:MLB]VCRSEQORI(0)

                 [M:MLB]UOM(0)       = WUOM
                 [M:MLB]VCRNUMORI(0) = WNUMORI
                 [M:MLB]VCRLINORI(0) = WLINORI
                 [M:MLB]VCRSEQORI(0) = WSEQORI
                 If dim([M:MLB]NETPRI)>0     : [M:MLB]NETPRI(0)    = WNETPRI : Endif
                 If dim([M:MLB]CUR)>0        : [M:MLB]CUR(0)       = WCUR    : Endif
                 nolign = J
            Endif
            Break
        Next
    Endif

    If [M:MLB]ISDEM = 2
        If [M:MLB]ENDDAT1(I) > [M:MLB]ENDDAT(K) : [M:MLB]XMESS1(I) = mess(60,190,1) : Endif : # Retard
    Else
        If [M:MLB]ENDDAT(K) > [M:MLB]ENDDAT1(I) : [M:MLB]XMESS1(I) = mess(60,190,1) : Endif : # Retard
    Endif
    [M:MLB]NBLINK(K) += 1
    [M:MLB]NBLIG1 += 1
    I             += 1
Next
Filter [MLK]
[M:MLB]PENDING       = 1

# Point d'entrée pour intervenir sur la liste des affectations pour un ordre sélectionné
If find("FUNMLINK",GENTSTD(1..GNBENTREE))
    GPOINT = "LOAD_LINK"
    Gosub  ENTREE From EXEFNC
Endif
Return

####################################################################
$HIGHLIGHT
Local    Integer K : K = [M:MLB]ISSEL - 1
Raz [M:MLB]ICOLINK

If [M:MLB]ISSEL>0
 # GH 04/07/2012
 Local Integer WTYP2, WLIN2, WSEQ2
 Local Char    WNUM2(GLONVCR)
 Call GET_DIRECT_ORDER([M:MLB]FCY, [M:MLB]ITMREF, [M:MLB]VCRTYP(K), [M:MLB]VCRNUM(K), [M:MLB]VCRLIN(K), [M:MLB]VCRSEQ(K), [M:MLB]WIPTYP(K),
&                      WTYP2, WNUM2, WLIN2, WSEQ2) From MTOLINKLIB
 If WNUM2<>"" : [M:MLB]ICOLINK(K) = "211" : Endif
Endif

# icone affecter
For I=0 To [M:MLB]NBLIG - 1
    If [M:MLB]ISSEL > 0  & I<>K

        If [M:MLB]WIPSTA(I)=1 & !sigma(0,[M:MLB]NBLIG1-1,[M:MLB]WIPTYP1(indcum)=[M:MLB]WIPTYP(I) & [M:MLB]WIPNUM1(indcum)=[M:MLB]WIPNUM(I))
            If [M:MLB]ISDEM = 2 & func CBNLIB.ISRESS([M:MLB]WIPTYP(I)) : [M:MLB]ICOLINK(I) = "167" : Endif
            If [M:MLB]ISRESS = 2 & func CBNLIB.ISDEM([M:MLB]WIPTYP(I)) : [M:MLB]ICOLINK(I) = "167" : Endif
        Endif

        If [M:MLB]ICOLINK(I) <> ""
         # Sont affectables
         # - les ordres fermes
         # - les ordres ressources si l'ordre sélectionné est une demande, et inversement
         # - les ordres avec une qté restant à affecter
         # - les ordres sans qté déjà affectée si la règle d'affectation est en mode contremarque (1 à 1)

         If [M:MLB]MTOQTY(K) >= ([M:MLB]RMNEXTQTY(K) - [M:MLB]ALLQTY(K))                                           : [M:MLB]ICOLINK(I) = ""
         Elsif [M:MLB]MTOQTY(I) >= ([M:MLB]RMNEXTQTY(I) - [M:MLB]ALLQTY(I))                                        : [M:MLB]ICOLINK(I) = ""
         Elsif [F:PTO]PTODIR = 2 & ([M:MLB]MTOQTY(K)>0 | [M:MLB]MTOQTY(I)>0)                                       : [M:MLB]ICOLINK(I) = ""
         Elsif [M:MLB]ICOLINK(K) <>""                                                                              : [M:MLB]ICOLINK(I) = ""
         Elsif [M:MLB]FMI(I)>1 & [M:MLB]MTOQTY(I) > 0                                                              : [M:MLB]ICOLINK(I) = ""
         Elsif [M:MLB]FMI(K)>1 & [M:MLB]MTOQTY(K) > 0                                                              : [M:MLB]ICOLINK(I) = ""
         # GH 18/06/2012 cde d'achat ouverte non affectable avec une demande en CTM
         Elsif [M:MLB]ISRESS=2 & [M:MLB]ABBFIL(K)="POC" & [M:MLB]FMI(I)>1                                          : [M:MLB]ICOLINK(I) = ""
         Elsif [M:MLB]ISDEM=2  & [M:MLB]ABBFIL(I)="POC" & [M:MLB]FMI(K)>1                                          : [M:MLB]ICOLINK(I) = ""
         # GH 09/07/2014 bug 101631 ressource de FMI>1 non affectable
         Elsif [M:MLB]ISRESS=2 & [M:MLB]FMI(K)>1                                                                   : [M:MLB]ICOLINK(I) = ""
         Elsif [M:MLB]ISDEM=2  & [M:MLB]FMI(I)>1                                                                   : [M:MLB]ICOLINK(I) = ""
         # GH 09/07/2014 bug 101631 ressource compatible avec le FMI de la demande en CTM
         Elsif [M:MLB]ISDEM=2 & [M:MLB]FMI(K)>1 & [M:MLB]VCRTYP(I)<>func MTOLINKLIB.FMITYP([M:MLB]FMI(K))          : [M:MLB]ICOLINK(I) = ""
         Elsif [M:MLB]ISRESS=2 & [M:MLB]FMI(I)>1 & [M:MLB]VCRTYP(K)<>func MTOLINKLIB.FMITYP([M:MLB]FMI(I))         : [M:MLB]ICOLINK(I) = ""
         Endif
        Endif

#        If find([M:MLB]FMI(I),3,5) & [M:MLB]VCRNUM(I) = [M:MLB]VCRNUMORI(K)
#&          & [M:MLB]VCRLIN(I) = [M:MLB]VCRLINORI(K) & [M:MLB]VCRSEQ(I) = [M:MLB]VCRSEQORI(K)
#            [M:MLB]ICOLINK(I) = "211"
#        Endif
        If  [M:MLB]ICOLINK(K)="211" & [M:MLB]VCRTYP(I)=WTYP2 & [M:MLB]VCRNUM(I)=WNUM2 & [M:MLB]VCRLIN(I)=WLIN2 & [M:MLB]VCRSEQ(I)=WSEQ2
            [M:MLB]ICOLINK(I) = "211"
        Endif
    Endif
Next I

# icone désaffecter
For I=0 To [M:MLB]NBLIG1 - 1
    [M:MLB]ICOUNLINK(I) = "168"
    If [M:MLB]LIN1(I) = -2 : [M:MLB]ICOUNLINK(I) = "" : Endif

    If [M:MLB]ISSEL>0 & (([M:MLB]ISDEM=2 & [M:MLB]FMI(K)<>1) | ([M:MLB]ISRESS=2 & [M:MLB]FMI1(I)<>1))
       If [M:MLB]LIN1(I)>-1 : [M:MLB]ICOLINK([M:MLB]LIN1(I))="211" : Endif
       If [M:MLB]VCRTYP1(I)=WTYP2 & [M:MLB]VCRNUM1(I)=WNUM2 & [M:MLB]VCRLIN1(I)=WLIN2 & [M:MLB]VCRSEQ1(I)=WSEQ2
&       & [M:MLB]RECORDED1(I)=2
          [M:MLB]ICOUNLINK(I) = ""
       Endif
    Endif
Next I

# icone sélectionner
If [M:MLB]ISSEL>0 : [M:MLB]PECFLG(K) = "210" : Endif

Sorta [M:MLB]NBLIG1 [M:MLB]NBLIG1 Order By [M:MLB]ENDDAT1(indice)

# Point d'entrée pour intervenir sur les propositions d'affectation notamment
# pour les performances d'affichage, si aucun PE actif pour ce traitement on évite l'appel
If find("FUNMLINK",GENTSTD(1..GNBENTREE))
    GPOINT = "CUS_ASSIGN_PRP"
    Gosub  ENTREE From EXEFNC
Endif

Affzo [MLB]20-25

# affectations
[M:HLIK]ABB          = "MLB"
[M:HLIK]VARABS       = "NBLIG"
[M:HLIK]EXCLUDE(0)   = "PECFLG"
[M:HLIK]EXCLUDE(1)   = "ICOLINK"
[M:HLIK]NBREX        = 0
[M:HLIK]VARABS2      = "NBLIG1"
[M:HLIK]EXCLUDE2(0)  = "ICOUNLINK"
[M:HLIK]NBREX2       = 0

Chgstl [M:MLB]NBLIG With ""

# application style
For I =0 To [M:MLB]NBLIG - 1
    [M:HLIK]LINNUM = I
    [M:HLIK]STYLE = ""

    # navigation
    If [M:MLB]VCRNUM(I) = GVCR
        [M:HLIK]STYLE = "MTOLINKD"
        Goto NXT_HIGH
    Endif
    # ruptures
    If [M:MLB]SHTQTY(I) > 0 & ([M:MLB]SHTQTY(I) > [M:MLB]MTOQTY(I))
        [M:HLIK]STYLE = "MTOLINKC"
        Goto NXT_HIGH
    Endif
    # couverture partielle ou totale
    If ([M:MLB]MTOQTY(I) > 0 | [M:MLB]ALLQTY(I) > 0)
        If [M:MLB]RMNEXTQTY(I) <= [M:MLB]MTOQTY(I) + [M:MLB]ALLQTY(I)
            [M:HLIK]STYLE = "MTOLINKA"
        Else
            [M:HLIK]STYLE = "MTOLINKB"
        Endif
        Goto NXT_HIGH
    Endif
$NXT_HIGH
    GPOINT = "STYLE" : Gosub ENTREE From EXEFNC : # GH 19/01/12 dm 78713
    If [M:HLIK]STYLE<>""
       Gosub STYLE_HL_TABLIN From HLIGHTLIB
    Endif
Next I

Chgstl [M:MLB]NBLIG1 With ""
For I = 0 To [M:MLB]NBLIG1 - 1
    [M:HLIK]LINNUM = I
    [M:HLIK]STYLE = ""

    If [M:MLB]WIPTYP1(I) <> 0
        If [M:MLB]AVAQTY1(I) <= 0
            [M:HLIK]STYLE = "MTOLINKA"
        Else
            [M:HLIK]STYLE = "MTOLINKB"
        Endif
    Endif

    GPOINT = "STYLE2" : Gosub ENTREE From EXEFNC : # GH 19/01/12 dm 78713
    If [M:HLIK]STYLE<>""
       Gosub STYLE_HL_TABLIN2 From HLIGHTLIB
    Endif
Next I

If [M:MLB]ISSEL > 0
    Local Decimal WWRK
    WWRK = [M:MLB]RMNEXTQTY(K) - [M:MLB]MTOQTY(K) - [M:MLB]ALLQTY(K)
    If [M:MLB]ISRESS = 2 : # Disponible pour affectation
        Chgtbk [M:MLB]25 With mess(467,198,1)-"-"-mess([M:MLB]WIPTYP(K),306,1)-[M:MLB]VCRNUM(K)-"-"-mess(468,198,1)-"="-num$(WWRK)
    Endif
    If [M:MLB]ISDEM  = 2 : # Reste à affecter
        Chgtbk [M:MLB]25 With mess(467,198,1)-"-"-mess([M:MLB]WIPTYP(K),306,1)-[M:MLB]VCRNUM(K)-"-"-mess(469,198,1)-"="-num$(WWRK)
    Endif
Else
    Chgtbk [M:MLB]25 With mess(467,198,1) : # Affectation(s)
Endif

Return

####################################################################
$CHARG_PARAM
Call GETDEV(GFCY)     From DEVSUB # pour récupérer GSOCIETE

#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
#----- Variables globales Achat
Call GLOBVAR(GFCY)    From WWGLOBACH

## GH 19/05/2014 bug 100108
If GMODU(8) = 2
    If clalev ([F:TCA]) <= 0 : Local File TABCOUAFF [TCA] : Endif
    Local Integer WOK
    Call LECTCA(8,WOK) From SUBTCA
    If WOK=0 : GOPS = "" : Else GOPS = [F:TCA]CODNUM(4) : Endif  # compteur suggestion opérations
Endif
Return

## GH 12/03/2013 bug 76100
$RECHARG_PARAM
If GFCY<>[M:MLB]FCY
 GFCY=[M:MLB]FCY : Gosub CHARG_PARAM
Endif
Return

########################################################################
$LECTURE_BTS
# Issue 96456 GH 14/06/2016 - Optimisation
#----- Relecture transaction de saisie  -----#
If [F:BTS]BTSTYP <> 52 | [F:BTS]BTSNUM <> GMDLNUM
    Read [BTS]BTS0=52;GMDLNUM
    If fstat : Raz [F:BTS] : Endif
Endif
# 09.05 31994
If GMODU(8) = 2
    If clalev ([F:MTS]) <= 0 : Local File MFGTRS    [MTS] : Endif
    If [F:BTS]MFGTRS<>""
       If [F:MTS]MTSTYP<>1 | [F:MTS]MTSNUM<>[F:BTS]MFGTRS
          Read [MTS]MTS0=1;[F:BTS]MFGTRS
          If fstat : Raz [F:MTS] : Endif
       Endif
    Else
       If [F:MTS]MTSTYP<>1 | [F:MTS]MTSNUM<>GMFGMTSNUM
          Read [MTS]MTS0=1;GMFGMTSNUM
          If fstat : Raz [F:MTS] : Endif
        Endif
    Endif
Endif
# Achats de sous-traitance: transaction de maj auto d'EO
If GMODU(6) = 2
    If clalev ([F:PTR]) <= 0 : Local File PURTRS     [PTR] : Endif
    If dim([F:BTS]SCOTRS)>0 & [F:BTS]SCOTRS<>""
       If [F:PTR]PTRTYP<>9 | [F:PTR]PTRNUM<>[F:BTS]SCOTRS
          Read [PTR]PTR0=9;[F:BTS]SCOTRS
          If fstat : Raz [F:PTR] : Endif
       Endif
    Else
       If [F:PTR]PTRTYP<>9 | [F:PTR]PTRNUM<>GSCOPTRNUM
          Read [PTR]PTR0=9;GSCOPTRNUM
          If fstat : Raz [F:PTR] : Endif
       Endif
    Endif
Endif
Return

###########################################################################
# Etiquettes (écran MTOLINKB)                                             #
###########################################################################

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

# selection active, message
If [M:MLB]ISSEL <> 0
    Local Integer K : K = [M:MLB]ISSEL - 1
    Call CL_PECFLG([M:MLB]PECFLG(K))
    If mkstat = 1 : VALEUR = [M:MLB]FCY : Affzo [MLB]FCY :  End : Endif
    mkstat = 0
Endif

GFCY = VALEUR
Gosub CHARG_PARAM

## GH 19/05/2014 bug 100108
If GMODU(8)=2 & GOPS="" : # compteur suggestion opérations
   GMESSAGE = mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1) : mkstat=2 : End
Endif

Call CHGITF(GFCY,[M:MLB]ITMREF)
End

########################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
Local    Char    WFCY(GLONFCY) : WFCY = [M:MLB]FCY
Local    Char    WART(GLONITM) : WART = VALEUR
Local    Char    WUSR(GLONAUS) : WUSR = [M:MLB]PLANNER

If VALEUR = ""
    GBNOACH  = 1
    GBNOPROD = 1
    End
Endif

If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0=VALEUR
Endif

If [F:BTS]APPLAN = 1
    Call CTLPLNFLT(WFCY, WART, WUSR) From MFGLIB
    If GMESSAGE <> ""
        mkstat = 2
        End
    Endif
Else
    Call CTLPLNACH(WFCY, WART, WUSR) From MFGLIB
    If GMESSAGE <> ""
        mkstat = 2
        End
    Endif
Endif

Call CONTMFGITM(WFCY, 0) From MFGLIB
If mkstat <> 0
    GBNOPROD = 1
    mkstat = 0
Else
    GBNOPROD = 0
Endif
If [M:MLB]PURFLG <> 2 : GBNOACH = 1 : Else : GBNOACH = 0 : Endif

End

########################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

# selection active, message
If [M:MLB]ISSEL <> 0
    Local Integer K : K = [M:MLB]ISSEL - 1
    Call CL_PECFLG([M:MLB]PECFLG(K))
    If mkstat = 1 : VALEUR = [M:MLB]ITMREF : Affzo [M:MLB]ITMREF :  End : Endif
    [M:MLB]ITMREF = VALEUR
Endif

Call CHGITF([M:MLB]FCY,VALEUR)

# Issue 104943 - 2015-07-02 by BEEBE : implementing versioning ECC
If dim([M:MLB]IECCVALMAJ)>0
    Effzo [MLB]IECCVALMAJ, IECCVALMIN
    If VALEUR<>""
        Local Integer I
        I=func ECCLIB.NBRCPN(VALEUR)
        If I>0
           Actzo [M:MLB]IECCVALMAJ
        Else
           Diszo [M:MLB]IECCVALMAJ
        Endif
        If I>1
           Actzo [M:MLB]IECCVALMIN
        Else
           Diszo [M:MLB]IECCVALMIN
        Endif
    Else
        Diszo [M:MLB]IECCVALMIN
        Diszo [M:MLB]IECCVALMAJ
    Endif
Endif

# Issue 110957 - 2015-10-07 by GH
If dim([M:MLB]ICRID)=1 & func ECCLIB.NBRCPN(VALEUR)<1
    [M:MLB]ICRID = func TRTX3FNC.CCMID(VALEUR,"","")
    Affzo [MLB]ICRID
    If dim([M:MLB]ICRFLG)>0
       [M:MLB]ICRFLG = string$([M:MLB]ICRID<>"","151") : Affzo [MLB]ICRFLG
    Endif
Endif
End

########################################
## GH 19/11/2013 bug 94564
Subprog CHGITF(FCY,ITM)
Variable Char    FCY
Variable Char    ITM

If [L]FCY="" | [L]ITM="" : End : Endif

If [F:ITM]ITMREF <> [L]ITM
    Read [ITM]ITM0=[L]ITM
    If fstat : mkstat = 2 : End : Endif
Endif

If [F:ITS]ITMREF <>  [L]ITM
    Read [ITS]ITS0=[L]ITM
    If fstat : Raz [F:ITS] : End : Endif
Endif

If [F:ITF]ITMREF <> [L]ITM | [F:ITF]STOFCY<>[L]FCY
    Read [ITF]ITF0=[L]ITM;[L]FCY
    If fstat : Raz [F:ITF] : End : Endif
Endif

# règle d'affectation
If [F:ITF]PTOCOD = "" : [M:MLB]PTOCOD = GDEFPTO : Else : [M:MLB]PTOCOD = [F:ITF]PTOCOD : Endif
If [F:PTO]PTOCOD <> [M:MLB]PTOCOD
    Read [PTO]PTO0=[M:MLB]PTOCOD
    If fstat : Raz [F:PTO] : Endif
Endif

# mode contremarque (1 à 1)
If [F:PTO]PTODIR = 2                    # GH 25/04/2014 bug 84573 : # If [F:PTO]PTODIR = 2 | [F:ITS]CTMFLG = 2
   [M:MLB]XPTODIR = mess(651,197,1)
Else
  Raz [M:MLB]XPTODIR
Endif

Gosub AFF_DES
End

######################################################################################
## Tableau 1 : Stock projeté
######################################################################################

Subprog IB_NBLIG
Local Integer L     : L = nolign-1
Local Integer WAPP, WPRO, WINT, WSCO, WRET

mkstat = 0

GBOUT1 = ""
GBOUT2 = ""
GBOUT3 = ""
GBOUT4 = ""
GBOUT5 = ""
GBOUT6 = ""
GBOUT7 = ""
GBOUT8 = ""
GBOUT9 = ""
GBOUT10 = ""
GBOUT11 = ""
GBOUT12 = ""
GBOUT13 = ""
GBOUT14 = ""
GBOUT15 = ""

If [M:MLB]NBLIG = 0 : End : Endif

#----------------------------------------

WAPP = 0
WPRO = 0
WINT = 0
WSCO = 0
If [F:BTS]APPSUG = 2 : WAPP += 1 : Endif
If [F:BTS]APPPLN = 2 : WAPP += 2 : Endif
If [F:BTS]APPLAN = 2 : WAPP += 4 : Endif
If [F:BTS]PLNSUG = 2 : WPRO += 1 : Endif
If [F:BTS]PLNPLN = 2 : WPRO += 2 : Endif
If [F:BTS]PLNLAN = 2 : WPRO += 4 : Endif
If [F:BTS]INTSUG = 2 : WINT += 1 : Endif
If [F:BTS]INTPLN = 2 : WINT += 2 : Endif
If [F:BTS]INTLAN = 2 : WINT += 4 : Endif
If [F:BTS]SCOSUG = 2 : WSCO += 1 : Endif
If [F:BTS]SCOPLN = 2 : WSCO += 2 : Endif
If [F:BTS]SCOLAN = 2 : WSCO += 4 : Endif

# réajustement suivant habilitation achat + interX
If GBUYFLT = 2 & [M:MLB]PLANNER <> [M:MLB]BUY(L) & [M:MLB]BUY(L) <> ""
    If find(WAPP,4,5,6,7) : WAPP -= 4 : Endif
    If find(WINT,4,5,6,7) : WINT -= 4 : Endif
Endif

# GH 16/05/2014 bug 75840
# réajustement suivant habilitation fabrication + sous-traitance
If (GPLNFLT = 2 & !find([M:MLB]PLANNER2(L),[M:MLB]PLANNER,"")) |
&  (GPLNFLT = 3 & [M:MLB]PLANNER2(L)<>[M:MLB]PLANNER)
    If find(WPRO,4,5,6,7) : WPRO -= 4 : Endif
    If find(WSCO,4,5,6,7) : WSCO -= 4 : Endif
Endif

# réajustement si module absent
If GMODU(6) < 2 : WAPP = 0 : WINT = 0 : WSCO = 0 : Endif
If GMODU(8) < 2 : WPRO = 0 : Endif

# si DA obligatoire, l'action commander n'est dispo que sur les DA
If [F:ITM]ITMREF <> [M:MLB]ITMREF
    Read [ITM]ITM0=[M:MLB]ITMREF
    If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITM]PRQFLG = 2 & WAPP>=4 & ([M:MLB]WIPTYP(L) <> 2 |  [M:MLB]WIPSTA(L) = 3)
    WAPP -= 4
Endif

# Issue 86810 GH 12/06/2018 - MTx considered (WIPTYP=14)
If [M:MLB]WIPTYPSTA(L) <> ""
    Case [M:MLB]WIPTYP(L)
      When 1,3,6,8,14 : # Customer order + Subcontracted material + Material requirements + Transfer request + Project demand
              If find([M:MLB]WIPTYP(L),3,6,14)
                  GBOUT13 = mess(384,198,1)
                  If [M:MLB]WIPSTA(L) = 1
                      Call HAB_ACT([M:MLB]FCY, "M", WRET) From BENCHLIB
                      If WRET : GBOUT11 = mess(33,191,1) : Endif    # allocation manuelle
                  Endif
              Endif
              If [M:MLB]WIPSTA(L) = 1 & ([M:MLB]RMNEXTQTY(L) > ([M:MLB]ALLQTY(L) + [M:MLB]MTOQTY(L)))
                  If [M:MLB]PURFLG = 2
                      Case WAPP
                          When 2,3: GBOUT2 = mess(337,198,1)  # demander
                          When 4,5: GBOUT2 = mess(363,198,1)  # commander
                          When 6,7: GBOUT2 = mess(364,198,1)  # demander/commander
                      Endcase
                      If GBOUT2 = ""
                          Case WINT
                              When 2,3: GBOUT2 = mess(337,198,1)  # demander
                              When 4,5: GBOUT2 = mess(363,198,1)  # commander
                              When 6,7: GBOUT2 = mess(364,198,1)  # demander/commander
                          Endcase
                      Endif
                  Endif
                  If [M:MLB]MFGFLG = 2
                      Case WPRO
                          When 2,3:   GBOUT3 = mess(495,198,1)  # planifier (fabrication)
                      #   When 2,3:   GBOUT3 = mess(279,198,1)  # planifier                ## GH 07/09/11 bug 76098
                          When 4,5:   GBOUT3 = mess(280,198,1)  # lancer
                          When 6,7:   GBOUT3 = mess(333,198,1)  # planifier/lancer
                      Endcase
                      #If GBOUT3 = ""
                      #    Case WINT
                      #        When 2,3: GBOUT2 = mess(337,198,1)  # demander
                      #        When 4,5: GBOUT2 = mess(363,198,1)  # commander
                      #        When 6,7: GBOUT2 = mess(364,198,1)  # demander/commander
                      #    Endcase
                      #Endif
                  Endif
                  If [M:MLB]SCPFLG = 2
                      Case WSCO
                          When 2,3: GBOUT4 = mess(496,198,1)    # planifier (sous-traitance)
                      #   When 2,3: GBOUT4 = mess(279,198,1)    # planifier                ## GH 07/09/11 bug 76098
                          When 4,5: GBOUT4 = mess(239,198,1)    # sous-traiter
                          When 6,7: GBOUT4 = mess(474,198,1)    # planifier/sous-traiter
                      Endcase
                  Endif
## GH 25/04/2014 bug 84573
#                  If [M:MLB]WIPTYP(L) = 1 & [M:MLB]FMI(L) = 5
#                      Read [SOQ]SOQ0=[M:MLB]VCRNUM(L);[M:MLB]VCRLIN(L);[M:MLB]VCRSEQ(L)
#                      If !fstat & [F:SOQ]FMINUM <> ""
#                          GBOUT3  = ""
#                      Endif
#                  Endif
                  If find([M:MLB]WIPTYP(L),1,8)
                      Read [SOQ]SOQ0=[M:MLB]VCRNUM(L);[M:MLB]VCRLIN(L);[M:MLB]VCRSEQ(L)
                      If fstat | [F:SOQ]FMINUM <> ""
                         # ctm déjà effectuée
                         Raz GBOUT2, GBOUT3, GBOUT4
                      Elsif (find([F:SOQ]FMI,3,5) | [F:PTO]PTODIR=2)
&                          & func MTOLINKLIB.LINK_EXISTS([M:MLB]FCY,[M:MLB]VCRTYP(L),[M:MLB]VCRNUM(L)
&                                                       ,[M:MLB]VCRLIN(L),[M:MLB]VCRSEQ(L),[M:MLB]WIPTYP(L))
                         # ctm à effectuer ou affectation 1<=>1 & demande déjà affectée
                         Raz GBOUT2, GBOUT3, GBOUT4
                      Else
                         Case [F:SOQ]FMI
                           When 3               # ctm = achat
                             Raz GBOUT3, GBOUT4
                           When 5               # ctm = production
                             Raz GBOUT2, GBOUT4
                         Endcase
                      Endif
                  Endif
##
              Endif
              Case [M:MLB]WIPTYP(L)
                When 6,14 : GBOUT8  = mess(273,198,1) : # Encours charge
                When 8    : GBOUT14 = mess(384,198,1) : # Zoom encours associés
              Endcase
      When 2: # commande achat
              Case [M:MLB]WIPSTA(L)
                  When 1:    Case WAPP
                                    When 4,5,6,7: GBOUT2 = mess(335,198,1)  # modifier
                             Endcase
                             If GBOUT2 = ""
                                 If WINT >= 4 : GBOUT2 = mess(335,198,1) : Endif
                             Endif
                  When 2:    Case WAPP
                                    When 2,3 :    GBOUT2 = mess(335,198,1)  # modifier
                                    When 4,5 :    GBOUT2 = mess(363,198,1)  # commander
                                    When 6,7 :    GBOUT2 = mess(362,198,1)  # modifier/commander
                             Endcase
                             If GBOUT2 = ""
                                 If WINT >= 2 : GBOUT2 = mess(362,198,1) : Endif
                             Endif
                  When 3:    Case WAPP
                                    When 1:   GBOUT2 = mess(335,198,1)  # modifier
                                    When 2:   GBOUT2 = mess(337,198,1)  # demander
                                    When 3:   GBOUT2 = mess(346,198,1)  # modifier/demander
                                    When 4:   GBOUT2 = mess(363,198,1)  # commander
                                    When 5:   GBOUT2 = mess(362,198,1)  # modifier/commander
                                    When 6,7: GBOUT2 = mess(364,198,1)  # demander/commander
                              Endcase
                              If GBOUT2 = ""
                                  If WINT >= 1 : GBOUT2 = mess(364,198,1) : Endif
                              Endif
                              If [M:MLB]MFGFLG = 2
                                  Case WPRO
                                        When 2,3:   GBOUT3 = mess(495,198,1)  # planifier (fabrication)
                                  #     When 2,3:   GBOUT3 = mess(279,198,1)  # planifier            ## GH 07/09/11 bug 76098
                                        When 4,5:   GBOUT3 = mess(280,198,1)  # lancer
                                        When 6,7:   GBOUT3 = mess(333,198,1)  # planifier/lancer
                                  Endcase
                              Endif
                              If [M:MLB]SCPFLG = 2
                                  Case WSCO
                                        When 2,3:   GBOUT4 = mess(496,198,1)  # planifier (sous-traitance)
                                  #     When 2,3:   GBOUT4 = mess(279,198,1)  # planifier            ## GH 07/09/11 bug 76098
                                        When 4,5:   GBOUT4 = mess(239,198,1)  # sous-traiter
                                        When 6,7:   GBOUT4 = mess(474,198,1)  # planifier/sous-traiter
                                  Endcase
                              Endif
                              If find(WAPP,1,3,5,7) : GBOUT15=mess(2,24,1)-[M:MLB]WIPTYPSTA(L) : Endif
              Endcase
      When 4: # sous-traitance
              # si SCF et commande autorisée
              If [M:MLB]WIPSTA(L) = 1
                  If find(WAPP,4,5,6,7)
                      GBOUT2  = mess(363,198,1)  # commander
                  Endif
                  If GBOUT2 = ""
                      If WINT >= 4 : GBOUT2 = mess(362,198,1) : Endif
                  Endif
              Endif
              GBOUT13 = mess(384,198,1)
      When 5: # ordre de fabrication
              Case [M:MLB]WIPSTA(L)
                  When 1: If WPRO >= 4
                              GBOUT3 = mess(335,198,1)    # modifier
                          Endif
                  When 2: Case WPRO
                              When 2,3: GBOUT3 = mess(335,198,1)  # modifier
                              When 4,5: GBOUT3 = mess(280,198,1)  # lancer
                              When 6,7: GBOUT3 = mess(334,198,1)  # modifier/lancer
                          Endcase
                  When 3: If !find([M:MLB]ORI(L),5,6) # FQ 61344
                            # Encours WOS hors CBN/PDP
                            Case WPRO
                              When 1:   GBOUT3 = mess(335,198,1)  # modifier
                              When 2:   GBOUT3 = mess(279,198,1)  # planifier
                              When 3:   GBOUT3 = mess(345,198,1)  # modifier/planifier
                              When 4:   GBOUT3 = mess(280,198,1)  # lancer
                              When 5:   GBOUT3 = mess(334,198,1)  # modifier/lancer
                              When 6,7: GBOUT3 = mess(333,198,1)  # planifier/lancer
                            Endcase
                          Else
                            # Encours WOS provenant du CBN/PDP: pas de maj autorisée
                            Case WPRO
                              When 2,3: GBOUT3 = mess(279,198,1)  # planifier
                              When 4,5: GBOUT3 = mess(280,198,1)  # lancer
                              When 6,7: GBOUT3 = mess(333,198,1)  # planifier/lancer
                            Endcase
                          Endif
                          If [M:MLB]PURFLG = 2
                              Case WAPP
                                    When 2,3: GBOUT2 = mess(337,198,1)  # demander
                                    When 4,5: GBOUT2 = mess(363,198,1)  # commander
                                    When 6,7: GBOUT2 = mess(364,198,1)  # demander/commander
                              Endcase
                              If GBOUT2 = ""
                                    Case WINT
                                        When 2,3,4,5,6,7: GBOUT2 = mess(362,198,1)  # demander/commander
                                    Endcase
                              Endif
                          Endif
                          If [M:MLB]SCPFLG = 2
                              Case WSCO
                                    When 2,3:   GBOUT4 = mess(496,198,1)  # planifier (sous-traitance)
                              #     When 2,3:   GBOUT4 = mess(279,198,1)  # planifier                ## GH 07/09/11 bug 76098
                                    When 4,5:   GBOUT4 = mess(239,198,1)  # sous-traiter
                                    When 6,7:   GBOUT4 = mess(474,198,1)  # planifier/sous-traiter
                              Endcase
                          Endif
                          If find(WPRO,1,3,5,7) : GBOUT15=mess(2,24,1)-[M:MLB]WIPTYPSTA(L) : Endif
              Endcase
              GBOUT6 = mess(282,198,1)
              GBOUT7 = mess(423,198,1)
              GBOUT8 = mess(273,198,1)
              GBOUT13 = mess(384,198,1)
              If [M:MLB]WIPSTA(L) = 1
                  Call HAB_ACT([M:MLB]FCY, "A", WRET) From BENCHLIB
                  If WRET : GBOUT9 = mess(56,198,1) : Endif       # allocation OF
              Endif
              If find([M:MLB]WIPSTA(L),1,2)
                  Call HAB_ACT([M:MLB]FCY, "J", WRET) From BENCHLIB
                  If WRET : GBOUT12 = mess(158,198,1) : Endif          # jalonnement
              Endif
      When 7: # ordre inter-site
              Case [M:MLB]WIPSTA(L)
                  When 1:  If WINT >= 4
                               GBOUT2 = mess(335,198,1)  # modifier
                           Endif
                           If GBOUT2 = ""
                               If WAPP >= 4 : GBOUT2 = mess(335,198,1) : Endif
                           Endif
                  When 2:  Case WINT
                              When 2,3: GBOUT2 = mess(335,198,1)  # modifier
                              When 4,5: GBOUT2 = mess(363,198,1)  # commander
                              When 6,7: GBOUT2 = mess(362,198,1)  # modifier/commander
                           Endcase
                           If GBOUT2 = ""
                               If WAPP >= 2 : GBOUT2 = mess(362,198,1) : Endif
                           Endif
                  When 3:  Case WINT
                              When 1:   GBOUT2 = mess(335,198,1)  # modifier
                              When 2:   GBOUT2 = mess(279,198,1)  # demander
                              When 3:   GBOUT2 = mess(345,198,1)  # modifier/demander
                              When 4:   GBOUT2 = mess(363,198,1)  # commander
                              When 5:   GBOUT2 = mess(362,198,1)  # modifier/commander
                              When 6,7: GBOUT2 = mess(364,198,1)  # demander/commander
                           Endcase
                           If GBOUT2 = ""
                               If WAPP >= 1 : GBOUT2 = mess(364,198,1) : Endif
                           Endif
                           If find(WINT,1,3,5,7) : GBOUT15=mess(2,24,1)-[M:MLB]WIPTYPSTA(L) : Endif
              Endcase
              GBOUT14 = mess(384,198,1)                      # 11295 MM 03.06
      When 9: # sous-produits
              GBOUT8 = mess(273,198,1)
              GBOUT13 = mess(384,198,1)
      When 13: # ordre de sous-traitance
              Case [M:MLB]WIPSTA(L)
                  When 1: If WSCO >= 4
                              GBOUT4 = mess(335,198,1)    # modifier
                          Endif
                  When 2: Case WSCO
                              When 2,3: GBOUT4 = mess(335,198,1)  # modifier
                              When 4,5: GBOUT4 = mess(239,198,1)  # sous-traiter
                              When 6,7: GBOUT4 = mess(475,198,1)  # modifier/sous-traiter
                          Endcase
                  When 3: Case WSCO
                              When 1:   GBOUT4 = mess(335,198,1)  # modifier
                              When 2:   GBOUT4 = mess(279,198,1)  # planifier
                              When 3:   GBOUT4 = mess(345,198,1)  # modifier/planifier
                              When 4:   GBOUT4 = mess(239,198,1)  # sous-traiter
                              When 5:   GBOUT4 = mess(475,198,1)  # modifier/sous-traiter
                              When 6,7: GBOUT4 = mess(474,198,1)  # planifier/sous-traiter
                          Endcase
                          If [M:MLB]MFGFLG = 2
                              Case WPRO
                                    When 2,3:   GBOUT3 = mess(495,198,1)  # planifier (fabrication)
                              #     When 2,3:   GBOUT3 = mess(279,198,1)  # planifier            ## GH 07/09/11 bug 76098
                                    When 4,5:   GBOUT3 = mess(280,198,1)  # lancer
                                    When 6,7:   GBOUT3 = mess(333,198,1)  # planifier/lancer
                              Endcase
                          Endif
                          If [M:MLB]PURFLG = 2
                              Case WAPP
                                    When 2,3: GBOUT2 = mess(337,198,1)  # demander
                                    When 4,5: GBOUT2 = mess(363,198,1)  # commander
                                    When 6,7: GBOUT2 = mess(364,198,1)  # demander/commander
                              Endcase
                              If GBOUT2 = ""
                                    Case WINT
                                        When 2,3,4,5,6,7: GBOUT2 = mess(362,198,1)  # demander/commander
                                    Endcase
                              Endif
                          Endif
                          If find(WSCO,1,3,5,7) : GBOUT15=mess(2,24,1)-[M:MLB]WIPTYPSTA(L) : Endif
              Endcase
              GBOUT6 = mess(282,198,1)
              GBOUT7 = mess(423,198,1)
              GBOUT13 = mess(384,198,1)
              If [M:MLB]WIPSTA(L) = 1
                  Call HAB_ACT([M:MLB]FCY, "A", WRET) From BENCHLIB
                  If WRET : GBOUT10 = mess(56,198,1) : Endif       # allocation sous-traitance
              Endif
    Endcase

    If find([M:MLB]WIPSTA(L),1,2)
        Case [M:MLB]WIPTYP(L)
            When 1:       Case [M:MLB]CODOBJ(L)
                           When "SOH"   : GBOUT5 = mess(191,198,1)-[M:MLB]CODCLE(L)   # commande
                           When Default : GBOUT5 = mess(191,198,1)-[M:MLB]CODCLE2(L)  # commande
                          Endcase
            When 2,7:     Case [M:MLB]CODOBJ(L)
                            When "PSH": GBOUT5 = mess(332,198,1)-[M:MLB]CODCLE(L)     # Demande/commande
                            When "POH": GBOUT5 = mess(332,198,1)-[M:MLB]CODCLE(L)     # Demande/commande
                            When "POD": GBOUT5 = mess(332,198,1)-[M:MLB]CODCLE2(L)    # Demande/commande
                          Endcase
            When 5,6,9:   GBOUT5 = mess(336,198,1)-[M:MLB]CODCLE(L)                   # ordre de fabrication
            When 4:       Case [M:MLB]ABBFIL(L)
                            When "MFO" : GBOUT5 = mess(336,198,1)-[M:MLB]CODCLE(L)    # ordre de fabrication
                            When "SCS" : GBOUT5 = mess(473,198,1)-[M:MLB]CODCLE(L)    # ordre de sous-traitance
                          Endcase
            When 3,13:    GBOUT5 = mess(473,198,1)-[M:MLB]CODCLE(L)                   # ordre de sous-traitance
            When 14:      GBOUT5 = mess(274,197,1)-[M:MLB]CODCLE(L)                   # Project demand
        Endcase
    Endif
Endif

If [M:MLB]PECFLG(L) = "210" | [M:MLB]PENDING = 2
    Raz GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT13
Endif

# GH 19/10/2015 bug 111812
#If [M:MLB]WIPSTA(L) = 3
#   GBOUT15 = mess(2,24,1)-[M:MLB]WIPTYPSTA(L) : # suppression
#Endif
End

######################################################################################
Subprog B15_NBLIG
If [M:MLB]WIPSTA(nolign-1) <> 3
   mkstat=2 : GMESSAGE=mess(1,115,1) : End : # Supression impossible
Endif

Local Integer WOK : WOK=2
Call OUINON(mess(123,105,1),WOK) From GESECRAN : # Confirmez-vous la suppression ?
If WOK<>2 : End : Endif

Case [M:MLB]WIPTYP(nolign-1)
   When 2: # POS
       Trbegin [ORD]
       Readlock [ORD]ORD0=[M:MLB]WIPTYP(nolign-1);[M:MLB]WIPNUM(nolign-1);[M:MLB]ITMREF
       If !fstat : Delete [ORD] : Commit : Endif
   When 5: # WOS
       Raz [M:MFGK]
       [M:MFGK]CODMAJ = "A"
       [M:MFGK]CODTRS = 2
       [M:MFGK]MFGNUM = [M:MLB]VCRNUM(nolign-1)
       [M:MFGK]MFGFCY = [M:MLB]FCY
       [M:MFGK]MFGSTA = [M:MLB]WIPSTA(nolign-1)
       [M:MFGK]MFGLIN = [M:MLB]VCRLIN(nolign-1)
       [M:MFGK]ITMREF = [M:MLB]ITMREF
       Call MAJ_OF From MFGAUTLIB
   When 7: # TRS
       Trbegin [ORD]
       Readlock [ORD]ORD0=[M:MLB]WIPTYP(nolign-1);[M:MLB]WIPNUM(nolign-1);[M:MLB]ITMREF
       If !fstat : Delete [ORD] : Endif
       For [ORD]ORD0 Where WIPTYP=8 & ORIFCY=[M:MLB]FCY & (VCRNUM=[M:MLB]VCRNUM(nolign-1) | VCRNUMORI=[M:MLB]VCRNUM(nolign-1))
           Readlock [ORD]  Curr
           If !fstat : Delete [ORD] : Endif
       Next
       Commit
   When 13: # EOS
      Raz [M:SCOK]
      [M:SCOK]CODMAJ = "A"
      [M:SCOK]SCONUM = [M:MLB]VCRNUM(nolign-1)
      [M:SCOK]STOFCY = [M:MLB]FCY
      [M:SCOK]SCOSTA = [M:MLB]WIPSTA(nolign-1)
      [M:SCOK]SCILIN = [M:MLB]VCRLIN(nolign-1)
      [M:SCOK]ITMREF = [M:MLB]ITMREF
      Call MAJ_SCO From SCOAUTLIB
Endcase

Local Integer IOK, K, I
Gosub RECHERCHER # Recharger le tableau ...
End

######################################################################################
Subprog AV_NBLIG
GUNT1(1) = [M:MLB]STU : # GH 12/03/2013 bug 76100
End

######################################################################################
Subprog AP_NBLIG
Gosub RECHARG_PARAM
End

######################################################################################
Subprog AS_PECFLG(VALEUR)
Variable Char VALEUR

If [M]WIPTYP(nolign-1) = 4 : mkstat = 2 : # service de sous-traitance
Elsif [M]WIPSTA(nolign-1) <> 1 : mkstat = 2
Elsif !(func CBNLIB.ISDEM([M]WIPTYP(nolign-1))) & !(func CBNLIB.ISRESS([M]WIPTYP(nolign-1))) : mkstat = 2
Endif
End

######################################################################################
Subprog C_PECFLG(VALEUR)
Variable Char VALEUR

If !(func CBNLIB.ISRESS([M:MLB]WIPTYP(nolign-1))) & !(func CBNLIB.ISDEM([M:MLB]WIPTYP(nolign-1))) : mkstat = 2 : Endif
End

######################################################################################
Subprog CL_PECFLG(VALEUR)
Variable Char VALEUR
Local    Integer OK, I, J
Local    Integer K : K = [M:MLB]ISSEL - 1
Local Integer I
Local Integer IOK

If [M:MLB]SCSFLG = 2 : mkstat = 99 : End : Endif

Case VALEUR
    When "210": Gosub RAZ_LINK
                If mkstat : End : Endif
                VALEUR = ""
                [M:MLB]PECFLG(nolign-1) = VALEUR
                Gosub DEVERROU
                [M:MLB]ISRESS = 1 : [M:MLB]ISDEM = 1
                [M:MLB]ISSEL = 0
                GIACTIVE = 0
                Gosub REACTUALISATION

                VALEUR = ""
                [M:MLB]PECFLG(nolign-1) = VALEUR
                If [M:MLB]REACT = 1 : Gosub HIGHLIGHT : Else [M:MLB]REACT = 1 : Endif

    When "": # si cochage nouvelle ligne, raz des affectations de la ligne précédemment traitée
                If [M:MLB]ISSEL <> 0 : Gosub DEVERROU : Gosub RAZ_LINK : Endif
                If mkstat : End : Endif

                For I = 0 To [M:MLB]NBLIG - 1
                    If I <> nolign - 1 : [M:MLB]PECFLG(I) = "" : Endif
                Next I
                [M:MLB]ISSEL = nolign
                K = [M:MLB]ISSEL - 1
                If (func CBNLIB.ISRESS([M:MLB]WIPTYP(nolign-1))) : [M:MLB]ISRESS = 2 : [M:MLB]ISDEM = 1  : Endif
                If (func CBNLIB.ISDEM ([M:MLB]WIPTYP(nolign-1))) : [M:MLB]ISDEM  = 2 : [M:MLB]ISRESS = 1 : Endif
                Gosub LOAD_LINK
                Gosub VERROU
                VALEUR = "210"
                [M:MLB]PECFLG(nolign-1) = VALEUR
                Gosub HIGHLIGHT
                # GH 06/07/2012 pour valider la ligne, et que click sur icone "verrou" n'enlève les icones posées sur la ligne
                zonsui="VCRNUM("+num$(nolign-1)+")"
Endcase
mkstat = 99
End

#-----------------------------------------------------------------------#
# Positionnement d'un verrou                                            #
#-----------------------------------------------------------------------#
$LCKTST
Case [M:MLB]VCRTYP(nolign-1)
    When 2  :    GSYMBOLE = "SOH"
    When 10 :    GSYMBOLE = "MFG"
    When 14 :    GSYMBOLE = "POH"
    When 36 :    GSYMBOLE = "SCO"
    When Default : Return
Endcase
GSYMBOLE += [M:MLB]VCRNUM(nolign-1)
Lock = GSYMBOLE With lockwait = 0
If fstat
    [M:MLB]XLOCKED = 2
Else
    [M:MLB]XLOCKED = 1
Endif
Return

$VERROU
Gosub LCKTST
If [M:MLB]XLOCKED = 2
   GYSMBOLE=""
Endif
Return

#-----------------------------------------------------------------------#
# Suppression du verrou                                                 #
#-----------------------------------------------------------------------#
$DEVERROU
If GSYMBOLE<>""
   Unlock = GSYMBOLE
   GSYMBOLE = ""
   [M:MLB]XLOCKED = 1
Endif
Return

######################################################################################
Subprog AS_ICOLINK(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" : mkstat = 2 : Endif
End

######################################################################################
Subprog CL_ICOLINK(VALEUR)
Variable Char    VALEUR()

If VALEUR = "211" : End : Endif

Local Integer NOL : NOL = nolign - 1

Local Integer L
Local Integer K : K = [M:MLB]ISSEL - 1

If [M:MLB]NBLIG1 < 1 : L = 0 : Else : L = [M:MLB]NBLIG1 : Endif

# ajout d'une ligne d'affectation
[M:MLB]WIPSTA1(L)    = [M:MLB]WIPSTA(NOL)
[M:MLB]WIPTYP1(L)    = [M:MLB]WIPTYP(NOL)
[M:MLB]XTYP1(L)      = mess([M:MLB]WIPTYP1(L),341,1)+mess([M:MLB]WIPSTA1(L),342,1)
[M:MLB]VCRTYP1(L)    = [M:MLB]VCRTYP(NOL)
[M:MLB]XVCRTYP1(L)   = mess([M:MLB]VCRTYP1(L),701,1)
[M:MLB]VCRNUM1(L)    = [M:MLB]VCRNUM(NOL)
[M:MLB]VCRLIN1(L)    = [M:MLB]VCRLIN(NOL)
[M:MLB]VCRSEQ1(L)    = [M:MLB]VCRSEQ(NOL)
[M:MLB]LIKQTY1(L)    = [M:MLB]RMNEXTQTY(K) - [M:MLB]MTOQTY(K) - [M:MLB]ALLQTY(K)
[M:MLB]ENDDAT1(L)    = [M:MLB]ENDDAT(NOL)
[M:MLB]BPRNUM1(L)    = [M:MLB]BPRNUM(NOL)
[M:MLB]UOM1(L)       = [M:MLB]UOM(NOL)
[M:MLB]FMI1(L)       = [M:MLB]FMI(NOL)
[M:MLB]VCRNUMORI1(L) = [M:MLB]VCRNUMORI(NOL)
[M:MLB]VCRLINORI1(L) = [M:MLB]VCRLINORI(NOL)
[M:MLB]VCRSEQORI1(L) = [M:MLB]VCRSEQORI(NOL)
[M:MLB]XMESS1(L)     = ""
[M:MLB]RECORDED1(L)  = 1
[M:MLB]ORILIKQTY1(L) = 0
[M:MLB]LIN1(L)       = NOL
[M:MLB]WIPNUM1(L)    = [M:MLB]WIPNUM(NOL)
[M:MLB]RMNEXTQTY1(L) = [M:MLB]RMNEXTQTY(NOL) - [M:MLB]ALLQTY(NOL)
[M:MLB]MTOQTY1(L)    = [M:MLB]MTOQTY(NOL)
[M:MLB]AVAQTY1(L)    = [M:MLB]RMNEXTQTY(NOL) - [M:MLB]MTOQTY(NOL) - [M:MLB]ALLQTY(NOL)
If [M:MLB]LIKQTY1(L) > [M:MLB]AVAQTY1(L) : [M:MLB]LIKQTY1(L) = [M:MLB]AVAQTY1(L) : Endif
[M:MLB]MTOQTY1(L)   += [M:MLB]LIKQTY1(L)
[M:MLB]AVAQTY1(L)    = [M:MLB]RMNEXTQTY1(L) - [M:MLB]MTOQTY1(L)

# pour une demande avec contremarque, le lien est toujours généré forcé
If [M:MLB]ISDEM=2  : [M:MLB]FRCFLG(L) = 1 + ([M:MLB]FMI(K)<>1)
Else               : [M:MLB]FRCFLG(L) = 1 + ([M:MLB]FMI(NOL)<>1)
Endif

[M:MLB]ORIFRCFLG(L)  = 0
[M:MLB]ABBFIL1(L)    = [M:MLB]ABBFIL(NOL)

If [M:MLB]CPLQTY(NOL) = 0
    [M:MLB]XTRKFLG(L) = mess(1,339,1) : # En attente
    Raz [M:MLB]XPROGRESS(L)
Else
    [M:MLB]XTRKFLG(L) = mess(4,339,1) : # En cours
    [M:MLB]XPROGRESS(L) = num$(int(([M:MLB]CPLQTY(NOL) / [M:MLB]EXTQTY(NOL)) * 100)) - "%"
    [M:MLB]XTYP1(L) += ">"
Endif
If [M:MLB]ISDEM = 2
    If [M:MLB]ENDDAT1(L) > [M:MLB]ENDDAT(K) : [M:MLB]XMESS1(L) = mess(60,190,1) : Endif : # Retard
Else
    If [M:MLB]ENDDAT(K) > [M:MLB]ENDDAT1(L) : [M:MLB]XMESS1(L) = mess(60,190,1) : Endif : # Retard
Endif

# point d'entrée pour alimenter des champs spécifiques
GPOINT = "ADDLIN1" : Gosub ENTREE From EXEFNC

[M:MLB]NBLIG1 += 1
[M:MLB]PENDING       = 2

[M:MLB]MTOQTY(NOL) += [M:MLB]LIKQTY1(L)
[M:MLB]MTOQTY(K)   += [M:MLB]LIKQTY1(L)

Gosub HIGHLIGHT
VALEUR = [M]ICOLINK(NOL)
mkstat = 99
zonsui = "[MLB]NBLIG1("+num$(L)+")"
End

######################################################################################
## Tableau des affectations
######################################################################################

Subprog C_NBLIG1
# pour bug moteur
If [M:MLB]NBLIG1>0 & [M:MLB]VCRNUM1([M:MLB]NBLIG1-1) = ""
    status=65 : nolign=[M:MLB]NBLIG1
    Dela [M:MLB]NBLIG1-1,1,[M:MLB]NBLIG1-1 [M:MLB]NBLIG1 : [M:MLB]NBLIG1-=1
    Affzo [MLB]25
Endif
End

######################################################################################
Subprog AS_ICOUNLINK(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" : mkstat = 2 : Endif
End

######################################################################################
Subprog CL_ICOUNLINK(VALEUR)
Variable Char    VALEUR()

Local Integer K : K = [M:MLB]ISSEL - 1
Local Integer L : L = nolign - 1

If K < 0 | L < 0 : End : Endif

# annulation d'une affectation
[M:MLB]MTOQTY(K) -= [M:MLB]LIKQTY1(L)
If [M:MLB]LIN1(L) >= 0
    [M:MLB]MTOQTY([M:MLB]LIN1(L)) -= [M:MLB]LIKQTY1(L)
Endif

Dela L, 1 [M:MLB]NBLIG1
If [M:MLB]NBLIG1>0 : [M:MLB]NBLIG1 -= 1 : Endif

[M:MLB]PENDING       = 2

Gosub HIGHLIGHT
mkstat = 4
If [M:MLB]NBLIG1=0 : VALEUR="" : Endif
zonsui = "[M:MLB]NBLIG1"
End

######################################################################################
Subprog AS_LIKQTY1(VALEUR)
Variable Decimal VALEUR

If nolign<=0 | nolign>[M:MLB]NBLIG1 | [M:MLB]LIN1(nolign-1)=-2
   mkstat=2
Elsif ([M:MLB]ISRESS=2 & [M:MLB]FMI1(nolign-1)<>1) | ([M:MLB]ISDEM=2 & [M:MLB]FMI([M:MLB]ISSEL-1)<>1)
   # pour une demande avec contremarque, pas de qté saisie
   mkstat=2
Endif

End

######################################################################################
Subprog C_LIKQTY1(VALEUR)
Variable Decimal VALEUR

Local Integer K       : K = [M:MLB]ISSEL - 1
Local Decimal WLIKQTY : WLIKQTY = [M:MLB]LIKQTY1(nolign-1)
Local Decimal WTOT, WDIFF, WWRK

# quantité > reste à affecter
WWRK = [M:MLB]RMNEXTQTY1(nolign-1) - [M:MLB]MTOQTY1(nolign-1) + [M:MLB]LIKQTY1(nolign-1)

If VALEUR > WWRK
 GMESSAGE = mess([M:MLB]WIPTYP1(nolign-1),306,1)-[M:MLB]VCRNUM1(nolign-1)
 GMESSAGE+= "\"+mess(253,193,1) - num$(WWRK) - [M:MLB]STU : # La quantité restante à affecter est
 mkstat = 2 : End
Endif

# on met à jour le champ pour pouvoir faire un total (sigma)
[M:MLB]LIKQTY1(nolign-1) = VALEUR
WTOT = sigma(0, [M:MLB]NBLIG1-1, [M:MLB]LIKQTY1(indcum))

# quantité > besoin
If WTOT > [M:MLB]RMNEXTQTY(K)

    # on détermine la diférence pour l'afficher
    [M:MLB]LIKQTY1(nolign-1) = WLIKQTY
    WTOT  = sigma(0, [M:MLB]NBLIG1-1, [M:MLB]LIKQTY1(indcum))
    WTOT -= [M:MLB]LIKQTY1(nolign-1)

    WDIFF =  [M:MLB]RMNEXTQTY(K) - WTOT
    GMESSAGE = mess([M:MLB]WIPTYP(K),306,1)-[M:MLB]VCRNUM(K)
    GMESSAGE+= "\"+mess(253,193,1) - num$(WDIFF) - [M:MLB]STU : # La quantité restante à affecter est
    mkstat = 2
    End
Endif

# on remet la valeur comme à l'origine
[M:MLB]LIKQTY1(nolign-1) = WLIKQTY

End

######################################################################################
Subprog AM_LIKQTY1(VALEUR)
Variable Decimal VALEUR
Local Integer K : K = [M:MLB]ISSEL - 1
Local Integer L : L = nolign - 1

[M:MLB]MTOQTY(K) -= [M:MLB]LIKQTY1(L)
[M:MLB]MTOQTY(K) += VALEUR
If [M:MLB]LIN1(L) >= 0
    [M:MLB]MTOQTY([M:MLB]LIN1(L)) -= [M:MLB]LIKQTY1(L)
    [M:MLB]MTOQTY([M:MLB]LIN1(L)) += VALEUR
Endif

[M:MLB]MTOQTY1(L) -= [M:MLB]LIKQTY1(L)
[M:MLB]MTOQTY1(L) += VALEUR
[M:MLB]AVAQTY1(L)  = [M:MLB]RMNEXTQTY1(L) - [M:MLB]MTOQTY1(L)

[M:MLB]LIKQTY1(L) = VALEUR
# [M:MLB]RECORDED1(L) = 1
# If [M:MLB]LIKQTY1(L) = [M:MLB]ORILIKQTY1(L) : [M:MLB]RECORDED1(L) = 2 : Endif
Gosub HIGHLIGHT
End

######################################################################################
Subprog AS_FRCFLG(VALEUR)
Variable Integer VALEUR

If nolign<=0 | nolign>[M:MLB]NBLIG1 | [M:MLB]LIN1(nolign-1)=-2
  VALEUR=0 : mkstat=2
Elsif ([M:MLB]ISRESS=2 & [M:MLB]FMI1(nolign-1)<>1) | ([M:MLB]ISDEM=2 & [M:MLB]FMI([M:MLB]ISSEL-1)<>1)
 # pour une demande avec contremarque, le lien est toujours généré forcé
  mkstat=2
Elsif find([M:MLB]ABBFIL1(nolign-1),"SOC","POC") | find([M:MLB]ABBFIL([M:MLB]ISSEL-1),"SOC","POC")
 # GH 18/06/12 une affectation associée à une demande de livraison achat/vente ne peut pas être forcée
  mkstat=2
Endif
End

#---------------------------------------------------------------------- #
# Action apres bouton                                                   #
#---------------------------------------------------------------------- #
$BB11_NBLIG
# Suppression du verrou sur la commande
Unlock=SYMBOLE
Return

#---------------------------------------------------------------------- #
$ROLES_INIT
WAPP = 0
WPRO = 0
WINT = 0
WSCO = 0
If [F:BTS]APPSUG = 2 : WAPP += 1 : Endif
If [F:BTS]APPPLN = 2 : WAPP += 2 : Endif
If [F:BTS]APPLAN = 2 : WAPP += 4 : Endif
If [F:BTS]PLNSUG = 2 : WPRO += 1 : Endif
If [F:BTS]PLNPLN = 2 : WPRO += 2 : Endif
If [F:BTS]PLNLAN = 2 : WPRO += 4 : Endif
If [F:BTS]INTSUG = 2 : WINT += 1 : Endif
If [F:BTS]INTPLN = 2 : WINT += 2 : Endif
If [F:BTS]INTLAN = 2 : WINT += 4 : Endif
If [F:BTS]SCOSUG = 2 : WSCO += 1 : Endif
If [F:BTS]SCOPLN = 2 : WSCO += 2 : Endif
If [F:BTS]SCOLAN = 2 : WSCO += 4 : Endif
Return

# --------------------------------------------------------------------- #
#     ETIQUETTES UTILISEES PAR ACTION SAISTOALL (ALLOCATIONS MANUELLES) #
#                                                                       #
#                Appelées depuis TRTSTOALLA                             #
# --------------------------------------------------------------------- #

#---------------------------------------------------------------------- #
# Action avant bouton  : Vérifications au préalable                     #
# Si GNOTALL=1 Pas d'ouverture de la fenêtre allocations manuelles      #
#---------------------------------------------------------------------- #
$AB11_NBLIG
Local Integer WOK, NOL : NOL=nolign-1
If [M:MLB]VCRTYP(NOL) = 36
   Gosub VERIF_EO
Else : # IF [M:MLB]VCRTYP(NOL) = 10
   Gosub VERIF_OF
Endif
Return

#--------------------------------------------------#
# Contrôle de l'OF                                 #
#--------------------------------------------------#
$VERIF_OF
Local Char    SYMBOLE(50)

If clalev([F:MFG])=0 : Local File MFGHEAD    [MFG] : Endif
If clalev([F:MFM])=0 : Local File MFGMAT     [MFM] : Endif

# -- Verrouillage de l'OF
SYMBOLE = "MFG"+[M:MLB]VCRNUM(NOL)
Lock = SYMBOLE
If fstat
   # modification en cours sur un autre poste
   GERR=1 : GMESSAGE=[M:MLB]VCRNUM(NOL)-":"-mess(10,100,1) : GNOTALL=1 : Return
Endif
Return

#--------------------------------------------------#
# Contrôle de l'EO                                 #
#--------------------------------------------------#
$VERIF_EO
Local Char    SYMBOLE(50)

If clalev([F:SCO])=0 : Local File SCOHEAD    [SCO] : Endif
If clalev([F:SCM])=0 : Local File SCOMAT     [SCM] : Endif

# -- Verrouillage de l'EO
SYMBOLE = "SCO"+[M:MLB]VCRNUM(NOL)
Lock = SYMBOLE
If fstat
   # modification en cours sur un autre poste
   GERR=1 : GMESSAGE=[M:MLB]VCRNUM(NOL)-":"-mess(10,100,1) : GNOTALL=1 : Return
Endif
Return

#---------------------------------------------------------------------- #
# Chargement des paramètres dans masque STOALL                          #
# Cette étiquette est appelée depuis CHARGE_PARAM From TRTSTOALLA       #
#---------------------------------------------------------------------- #
$CHARGE_STOALL
#Local Char    LWRH(GLONWRH)
#Local Integer LEXC
If clalev([M:ORDK])=0 : Local Mask ORDK      [ORDK] : Endif
Default Mask [ALL]
Local Integer WOK, NOL : NOL=nolign-1
If [M:MLB]VCRTYP(LNOL) = 36
   Gosub CHARGE_EO
Else : # IF [M:MLB]VCRTYP(LNOL) = 10
   Gosub CHARGE_OF
Endif
Return

#--------------------------------------------------#
# Chargement de l'OF                               #
#--------------------------------------------------#
$CHARGE_OF
# lecture de l'OF
If [F:MFG]MFGNUM<>[M:MLB]VCRNUM(LNOL)
    Read [MFG]MFG0=[M:MLB]VCRNUM(LNOL)
    If fstat : Return : Endif
Endif
# lecture matière
If [F:MFM]MFGNUM <> [M:MLB]VCRNUM(LNOL) |
&  [F:MFM]MFGLIN <> [M:MLB]VCRLIN(LNOL) |
&  [F:MFM]BOMSEQ <> [M:MLB]VCRSEQ(LNOL) |
&  [F:MFM]ITMREF <> [M:MLB]ITMREF
    Read [MFM]MFM0=[M:MLB]VCRNUM(LNOL);[M:MLB]VCRLIN(LNOL);[M:MLB]VCRSEQ(LNOL);[M:MLB]ITMREF
    If fstat  : Return : Endif
Endif
# Chargement du masque [M:ALL]
Raz [M:ALL]
[M:ALL]VCRTYP    = 10
[M:ALL]VCRNUM    = [F:MFM]MFGNUM
[M:ALL]VCRLIN    = [F:MFM]MFGLIN
[M:ALL]VCRSEQ    = [F:MFM]BOMSEQ
[M:ALL]PCU       = [F:MFM]STU
[M:ALL]STU       = [F:MFM]STU
# 11.05 demande 33011
[M:ALL]STOLOC    = [F:MFM]LOC
[M:ALL]PCUSTUCOE = 1
[M:ALL]RETQTY    = [F:MFM]RETQTY - [F:MFM]USEQTY
If [M:ALL]RETQTY < 0 : [M:ALL]RETQTY = 0 : Endif
[M:ALL]OLDALLQTY = [F:MFM]ALLQTY
[M:ALL]SHTQTY    = [F:MFM]SHTQTY
[M:ALL]QTYTOALL  = [M:ALL]RETQTY
[M:ALL]ALLTYP    = 2
[M:ALL]RETDAT    = [F:MFM]RETDAT
[M:ALL]DLVDAT    = [F:MFM]RETDAT
[M:ALL]PECINTLOC = 2
[M:ALL]PECPLFLOC = 2    : # Prise en cpte empl quai : Oui
[M:ALL]XLOT      = [F:MFM]LOT
[M:ALL]XLOC      = [F:MFM]LOC
[M:ALL]XSTA      = [F:MFM]STA

If [F:MFM]SCOFLG = 2    : # Prise en compte emplacements sous-traitants
    [M:ALL]PECSCOLOC = 2
    # on renseigne le tiers et l'adresse, on prend le premier tiers trouvé (approximation en cas de splittage)
    If [F:MFM]BOMOPE <> 0
        If clalev([F:MFO])  = 0 : Local File MFGOPE [MFO] : Endif
        Filter [MFO] Where MFGNUM=[F:MFM]MFGNUM & OPENUM=[F:MFM]BOMOPE
&                    Order By Key MFO0
        For [MFO]
            [M:ALL]BPCORD = [F:MFO]BPRNUM
            [M:ALL]BPAADD = [F:MFO]BPAADD
            If [M:ALL]BPCORD <> "" : Break : Endif
        Next
        Filter [MFO]
    Endif
Else
    [M:ALL]PECSCOLOC = 1
Endif
#Call WRHAUTO([F:MFM]MFGFCY,[F:MFM]ITMREF,10,0,[M:ALL]PECSCOLOC-1,LWRH,LEXC) From STKWRH
#If LEXC=1 [M:ALL]XWRH=LWRH Endif

# sr 05.05
If find([F:MFM]ALLSTA,2,3)
     [M:ALL]GLOALLQTY = [F:MFM]ALLQTY
Else
     Raz [M:ALL]GLOALLQTY
Endif

Diszo [M:ALL]QTYTOALL
Return

#--------------------------------------------------#
# Chargement de l'EO                               #
#--------------------------------------------------#
$CHARGE_EO
# lecture de l'EO
If [F:SCO]SCONUM<>[M:MLB]VCRNUM(LNOL)
    Read [SCO]SCO0=[M:MLB]VCRNUM(LNOL)
    If fstat : Return : Endif
Endif
# lecture matière
If [F:SCM]SCONUM <> [M:MLB]VCRNUM(LNOL) |
&  [F:SCM]SCILIN <> [M:MLB]VCRLIN(LNOL) |
&  [F:SCM]SCMLIN <> [M:MLB]VCRSEQ(LNOL) |
&  [F:SCM]CPNITMREF <> [M:MLB]ITMREF
    Read [SCM]SCM0=[M:MLB]VCRNUM(LNOL);[M:MLB]VCRLIN(LNOL);[M:MLB]VCRSEQ(LNOL)
    If fstat  : Return : Endif
Endif
# Chargement du masque [M:ALL]
Raz [M:ALL]
[M:ALL]VCRTYP    = 36
[M:ALL]VCRNUM    = [F:SCM]SCONUM
[M:ALL]VCRLIN    = [F:SCM]SCILIN
[M:ALL]VCRSEQ    = [F:SCM]SCMLIN
[M:ALL]PCU       = [F:SCM]STU
[M:ALL]STU       = [F:SCM]STU
# 11.05 demande 33011
[M:ALL]STOLOC    = [F:SCM]LOC
[M:ALL]PCUSTUCOE = 1
[M:ALL]RETQTY    = [F:SCM]RETQTY - [F:SCM]USEQTY
If [M:ALL]RETQTY < 0 : [M:ALL]RETQTY = 0 : Endif
[M:ALL]OLDALLQTY = [F:SCM]ALLQTY
[M:ALL]SHTQTY    = [F:SCM]SHTQTY
[M:ALL]QTYTOALL  = [M:ALL]RETQTY
[M:ALL]ALLTYP    = 2
[M:ALL]RETDAT    = [F:SCM]DLVDAT
[M:ALL]DLVDAT    = [F:SCM]DLVDAT
[M:ALL]PECINTLOC = 2
[M:ALL]PECPLFLOC = 2    : # Prise en cpte empl quai : Oui
[M:ALL]XLOT      = [F:SCM]LOT
[M:ALL]XLOC      = [F:SCM]LOC
[M:ALL]XSTA      = [F:SCM]STA
[M:ALL]PECSCOLOC = 2
#Call WRHAUTO([F:SCM]STOFCY,[F:SCM]CPNITMREF,36,0,1,LWRH,LEXC) From STKWRH
#If LEXC=1 [M:ALL]XWRH=LWRH Endif

# sr 05.05
If find([F:SCM]ALLSTA,2,3)
     [M:ALL]GLOALLQTY = [F:SCM]ALLQTY
Else
     Raz [M:ALL]GLOALLQTY
Endif

Diszo [M:ALL]QTYTOALL
Return

#---------------------------------------------------------------------- #
# Contrôle avant enregistrement                                         #
# Si contrôle non OK, mettre OK=0 pour ne pas enregister                #
# Cette étiquette est appelée depuis AVANT_ENR From TRTSTOALLA          #
#---------------------------------------------------------------------- #
$AVANT_STOALL
If [M:MLB]VCRTYP(LNOL) = 36         #Issue X3-98762 14/08/2018 by GEBIL: Manual allocation from planning: tables desynch =>LNOL not, NOL !
 # allocation matières sous-traitance
   Gosub AVANT_EO
Else : # IF [M:MLB]VCRTYP(NOL) = 10
 # allocation matières OF
   Gosub AVANT_OF
Endif
Return

#--------------------------------------------------#
# Contrôle avant enregistrement                    #
#--------------------------------------------------#
$AVANT_OF
Return

#--------------------------------------------------#
# Contrôle avant enregistrement                    #
#--------------------------------------------------#
$AVANT_EO
Return

#---------------------------------------------------------------------- #
# Mise à jour complémentaires après enregistrement                      #
# Si problème mettre GOK=0 pour annuler l'enregistrement                #
#---------------------------------------------------------------------- #
# WALLQTY contient la quantité allouée                                  #
# WSHTQTY contient la quantité en rupture                               #
#---------------------------------------------------------------------- #
$APRES_STOALL
If [M:MLB]VCRTYP(LNOL) = 36          #Issue X3-98762 14/08/2018 by GEBIL
 # allocation matières sous-traitance
   Gosub APRES_EO
Else : # IF [M:MLB]VCRTYP(NOL) = 10
 # allocation matières OF
   Gosub APRES_OF
Endif
Return

#--------------------------------------------------#
# Mise à jour de l'OF                              #
#--------------------------------------------------#
$APRES_OF
Local Integer WRET
Local Decimal WDIS

Call MAJALLMAT([M:ALL]VCRNUM, [M:ALL]VCRLIN, [M:ALL]VCRSEQ, [M:ALL]ITMREF, WALLQTY, WSHTQTY, [M:ALL]ALLTYP, WRET) From MFGALL
If WRET <> 0 : GOK = 0 : Return : Endif

[M:MLB]REACT = 2
Gosub FABRICATION From FUNMLINK

Return

#--------------------------------------------------#
# Mise à jour de l'EO                              #
#--------------------------------------------------#
$APRES_EO
Local Integer WRET
Local Decimal WDIS

Call MAJALLMAT([M:ALL]VCRNUM, [M:ALL]VCRLIN, [M:ALL]VCRSEQ, [M:ALL]ITMREF, WALLQTY, WSHTQTY, [M:ALL]ALLTYP, WRET) From SCOALL
If WRET <> 0 : GOK = 0 : Return : Endif

[M:MLB]REACT = 2
Gosub SOUSTRAIT From FUNMLINK

Return

######################################################################################
## Section automatically added (screen MTOLINKB) 07/02/2015 09:50:11 (BEEBE)
######################################################################################

Subprog C_IECCVALMAJ(VALEUR)
Variable Char    VALEUR()

If VALEUR<>""
   # Issue 111122 - 2015-10-19 by GH
   #Call CTRECC([M:MLB]ITMREF,"MLB","ECCVALMAJ",VALEUR,[M:MLB]IECCVALMIN,[0/0/0],GERR,GMESSAGE) From ECCLIB
   # # Only Warning Message
   # If find(GERR,1,4)
   #     GERR=2
   # Endif
   Filter [EVL] Where ECCTYP=4
   Look [EVL]EVL1(2) = [M:MLB]ITMREF;VALEUR
   Filter [EVL]
   If fstat>2
      GMESSAGE = mess(308,193,1) # Non-existing version
      mkstat=2 : End
   Endif
Endif

# Issue 110957 - 2015-10-07 by GH
If dim([M:MLB]ICRID)=1 & (VALEUR="" | func ECCLIB.NBRCPN([M:MLB]ITMREF)=1)
    [M:MLB]ICRID = func TRTX3FNC.CCMID([M:MLB]ITMREF,VALEUR,"")
    Affzo [MLB]ICRID
    If dim([M:MLB]ICRFLG)>0
       [M:MLB]ICRFLG = string$([M:MLB]ICRID<>"","151") : Affzo [MLB]ICRFLG
    Endif
Endif
End

######################################################################################
Subprog AS_IECCVALMIN(VALEUR)
Variable Char    VALEUR()

If [M:MLB]IECCVALMAJ=""
    mkstat=1
Endif
End

######################################################################################
Subprog C_IECCVALMIN(VALEUR)
Variable Char    VALEUR()

If VALEUR<>""
   # Issue 111122 - 2015-10-19 by GH
   #Call CTRECC([M:MLB]ITMREF,"MLB","ECCVALMIN",[M:MLB]IECCVALMAJ,VALEUR,[0/0/0],GERR,GMESSAGE) From ECCLIB
   ## Only Warning Message
   #If find(GERR,1,4)
   #    GERR=2
   #Endif
   Look [EVL]EVL1(3) = [M:MLB]ITMREF;[M:MLB]IECCVALMAJ;VALEUR;4
   If fstat>2
      GMESSAGE = mess(308,193,1) : # Non-existing version
      mkstat=2 : End
   Endif
Endif

# Issue 110957 - 2015-10-07 by GH
If dim([M:MLB]ICRID)=1 & func ECCLIB.NBRCPN([M:MLB]ITMREF)=2
    [M:MLB]ICRID = func TRTX3FNC.CCMID([M:MLB]ITMREF,[M:MLB]IECCVALMAJ,VALEUR)
    Affzo [MLB]ICRID
    If dim([M:MLB]ICRFLG)>0
       [M:MLB]ICRFLG = string$([M:MLB]ICRID<>"","151") : Affzo [MLB]ICRFLG
    Endif
Endif
End

