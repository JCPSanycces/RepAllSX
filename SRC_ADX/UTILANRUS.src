#<AdxTL>@(#)0.0.0.0 $Revision$ 
######################################################################################
# UTILANRUS                                                                          #
#                                                                                    #
# X3-67176 : Supervisor process to remove russian texts                              #
#                                                                                    #
######################################################################################
Call MAJ_UTILANRUS
End

#-------------------------------------------------------------------------------#
Subprog MAJ_UTILANRUS
Local Char DOSSIER(30)
Local Integer LRET
Local Integer LFORCE
Local Integer LDELAXX

DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTILANRUS - Delete Russian texts") From SAIDOS
If DOSSIER <> "" Then
    LDELAXX=[V]CST_AFALSE
    LFORCE=[V]CST_AFALSE

    If DOSSIER<>GDOSX3
        LRET=[V]CST_ANO
        Call OUINON("This folder is not the mother folder. Do you confirm deletion of Russian texts ?",LRET) From GESECRAN
        If LRET=[V]CST_AYES
            LFORCE=[V]CST_ATRUE
        Else
            End
        Endif
    Endif

    LRET=[V]CST_ANO
    Call OUINON("Do you want to delete ATEXTRA records linked to supervisor tables ?",LRET) From GESECRAN
    If LRET=[V]CST_AYES
        LDELAXX=[V]CST_ATRUE
    Endif

    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTILANRUS - Delete Russian texts") From LECFIC
    Call EXE_UTILANRUS(DOSSIER,LFORCE,LDELAXX)

    Call CREFOLDERS From VALCSTWEB  # Update FOLDERS.xml & FOLDERS.json (automatically done in PATCH and VALDOS)

    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
Endif
End

#-------------------------------------------------------------------------------#
#**
#* Remove all russian texts in root folder
#*
#* @param DOSSIER : Folder in which remove texts
#* @param FORCE   : If DOSSIER is not the root folder, set [V]CST_ATRUE to force deletion
#* @param DELAXX  : If DOSSIER is not the root folder, set [V]CST_ATRUE to delete records in ATEXTRA linked to Supervisor tables
#*!
Subprog EXE_UTILANRUS(DOSSIER,FORCE,DELAXX)
Value Char    DOSSIER
Value Integer FORCE
Value Integer DELAXX
# Is it a folder where the texts have to be removed ?
# Only root folder must be updated except if it has been confirmed by user
If DOSSIER<>GDOSX3 & FORCE<>[V]CST_ATRUE
    End
Endif

Call ECR_TIME("UTILANRUS : Start folder's process"-DOSSIER) From DOSSUB

Call ECR_TIME("Clean tables start") From DOSSUB
Call CLEAN_TABLES([L]DOSSIER,DELAXX)
Call ECR_TIME("Clean tables end") From DOSSUB
Call ECR_TIME("Clean folders start") From DOSSUB
Call CLEAN_DOSSIER([L]DOSSIER)
Call ECR_TIME("Clean folders end") From DOSSUB
Call ECR_TIME("Clean generated files start") From DOSSUB
Call CLEAN_GENERATED_FILES([L]DOSSIER)
Call ECR_TIME("Clean generated files end") From DOSSUB

Call ECR_TIME("UTILANRUS : End folder's process"-[L]DOSSIER) From DOSSUB
End

#**
#* Remove russian texts in predefined tables :<br>
#* ADOCBLB - ADOCCLB - ADOCFLD - ADOCUMENT - APLSTD<br>
#* APROCTEXTE - AREPORT - AREPORTX - ATEXTE<br>
#* @param DOSSIER : folder name where to remove records
#* @param DELAXX  : If DOSSIER is not the root folder, set [V]CST_ATRUE to delete records in ATEXTRA linked to Supervisor tables
#*!
Subprog CLEAN_TABLES(DOSSIER,DELAXX)
Value Char DOSSIER
Value Integer DELAXX

Local Char LTABLES(GLONATB)(1..)
Local Char LLANFLD(GLONAVA)(1..)
Local Integer NBTABLES
Local Integer LNB

# List of tables to clean
NBTABLES += 1 : LTABLES(NBTABLES) = "ADOCBLB"    : LLANFLD(NBTABLES)="LAN"
NBTABLES += 1 : LTABLES(NBTABLES) = "ADOCCLB"    : LLANFLD(NBTABLES)="LAN"
NBTABLES += 1 : LTABLES(NBTABLES) = "ADOCFLD"    : LLANFLD(NBTABLES)="LAN"
NBTABLES += 1 : LTABLES(NBTABLES) = "ADOCUMENT"  : LLANFLD(NBTABLES)="LAN"
NBTABLES += 1 : LTABLES(NBTABLES) = "APROCTEXTE" : LLANFLD(NBTABLES)="LANG"
NBTABLES += 1 : LTABLES(NBTABLES) = "AREPORT"    : LLANFLD(NBTABLES)="LAN"
NBTABLES += 1 : LTABLES(NBTABLES) = "APLSTD"     : LLANFLD(NBTABLES)="LAN"
NBTABLES += 1 : LTABLES(NBTABLES) = "AREPORTX"   : LLANFLD(NBTABLES)="LAN"
NBTABLES += 1 : LTABLES(NBTABLES) = "ATEXTE"     : LLANFLD(NBTABLES)="LAN"

# Clean each table
For I=1 To NBTABLES
    If filinfo(filpath("FIL",LTABLES(I),"fde",DOSSIER),0) > 0
        Local File =DOSSIER+"."+LTABLES(I) [_RUS]
        Trbegin [_RUS]
        Delete [_RUS] Where evalue(LLANFLD(I)+"='RUS'")
        If fstat<>[V]CST_AOK
            Call ERREUR(LTABLES(I), 3) From DOSDIC
            Rollback
        Else
            Call ECR_TRACE (num$(adxdlrec)-"deleted in"-LTABLES(I),0) From GESECRAN
            Commit
        Endif
        LogicClose File [_RUS]
    Endif
Next

# Clean ATEXTRA for Supervisor module only
If DOSSIER=GDOSX3 | DELAXX=[V]CST_ATRUE
    Call ECR_TRACE ("Deletion of ATEXTRA records linked to Supervisor tables",0) From GESECRAN
    Local File =DOSSIER+".ATEXTRA" [ZAXX]
    Local File =DOSSIER+".ATABLE"  [ZATB]

    Raz LNB
    For [ZATB] Where [ZATB]MODULE=1
        Trbegin [ZAXX]
        Delete [ZAXX] Where CODFIC=[F:ZATB]CODFIC & LANGUE='RUS'
        If fstat<>[V]CST_AOK
            Call ECR_TRACE ("Deletion error in ATEXTRA for table"-[F:ZATB]CODFIC,1) From GESECRAN
            Rollback
        Else
            LNB += adxdlrec
            Commit
        Endif
    Next
    Call ECR_TRACE (num$(LNB)-"records deleted",0) From GESECRAN
    LogicClose File [ZAXX]
    LogicClose File [ZATB]
Endif

End

#**
#* Change settings concerning RUS language :<br>
#* - Set it as not standard language in root folder<br>
#* - Set it as not standard language in child folder if the process has been called with DOSSIER=root folder<br>
#* - Remove it from root folder settings<br>
#*
#* @param DOSSIER : folder name where to change settings
#*!
Subprog CLEAN_DOSSIER(DOSSIER)
Value Char DOSSIER

Local File ADOSSIER [ZADS]

# Uncheck the connection language checkbox for Russian
Local File =DOSSIER+".TABLAN" [TLAN]
Trbegin [TLAN]
Update [TLAN] Where LAN='RUS'
&             With  LANCON=1,
&                   LANSTD=1
If fstat<>[V]CST_AOK
    Call ERREUR("TABLAN", 2) From DOSDIC
    Rollback
Else
    Commit
Endif
LogicClose File [TLAN]

# Set as "not standard" for RUS language in child folders
If DOSSIER=GDOSX3
    For [ZADS] Where [F:ZADS]DOSSIER<>[L]DOSSIER
        Local File =[F:ZADS]DOSSIER+".TABLAN" [TLAN]
        Trbegin [TLAN]
        Update [TLAN] Where LAN='RUS'
&                     With  LANSTD=1
        If fstat<>[V]CST_AOK
            Call ERREUR([F:ZADS]DOSSIER+".TABLAN", 2) From DOSDIC
            Rollback
        Else
            Commit
        Endif
        LogicClose File [TLAN]
    Next
Endif

# Remove RUS in the folder setup
Read [ZADS]DOSSIER=[L]DOSSIER
If fstat=[V]CST_AOK
    I=find("RUS",[F:ZADS]LAN)
    # If Russian is present & not alone we can remove RUS and change LANDEF if it's RUS
    If I>0
        # shift following languages
        While I<dim([F:ZADS]LAN)
            [F:ZADS]LAN(I-1)    = [F:ZADS]LAN(I)
            [F:ZADS]LANREF(I-1) = [F:ZADS]LANREF(I)
            I+=1
        Wend
        # As a value has been deleted, the last one is empty
        [F:ZADS]LAN(I-1)=""
        [F:ZADS]LANREF(I-1)=0
        [F:ZADS]NBRLAN -=1

        Rewrite [ZADS]
        If fstat<>[V]CST_AOK
            Call ERREUR("ADOSSIER"-[L]DOSSIER, 2) From DOSDIC
        Endif
    Endif
Else
    Call ERREUR("ADOSSIER"-[L]DOSSIER, 4) From DOSDIC
Endif
End

#**
#* remove generated files that are linked to language RUS: <br>
#* - directory : DOSSIER/X3_PUB/FOLDEV/GEN/RUS <br>
#* - directory : DOSSIER/X3_PUB/FOLDEV/GEN/SYR/RU-* <br>
#* - files : menurus, jsonmenurus & textrarus <br>
#*
#* @param DOSSIER : folder name where to remove files
#*!
Subprog CLEAN_GENERATED_FILES(DOSSIER)
Value Char DOSSIER

Local Char DIRSEP(1)
Local Char DIR(250)
Local Integer LSTATUS
Local Char MACHINE(250)
Local Shortint NBDIR
Local Char LISTDIR(250)(1..)
Local Char FIL(250)(3)
Local Char LMES(250)
Local Integer LEXIST

# Delete generated files in X3_PUB directory
Case GOS(1)
 When "dos"   : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase

#---- Remove directory MRUS in /folder_name/
DIR = filpath("MRUS","","",[L]DOSSIER)
LSTATUS = func ASYRSYS.REMOVE_DIRECTORY(DIR)
If LSTATUS=[V]CST_AOK
    Call ECR_TRACE ("Directory deletion:|"-DIR,0) From GESECRAN
Else
    Call ECR_TRACE ("Error during directory deletion:|"-DIR,1) From GESECRAN
Endif

#---- Remove directory RUS in /X3_PUB/folder_name/GEN
DIR = filpath(DOSSIER+DIRSEP+"GEN"+DIRSEP+"RUS","","","X3_PUB")
LSTATUS = func ASYRSYS.REMOVE_DIRECTORY(DIR)
If LSTATUS=[V]CST_AOK
    Call ECR_TRACE ("Directory deletion:|"-DIR,0) From GESECRAN
Else
    Call ECR_TRACE ("Error during directory deletion:|"-DIR,1) From GESECRAN
Endif

# Issue X3-78756 - 2018-02-28 by CCC : Deletion impossible in cloud environment
##---- Remove directory RU-RU in /X3_PUB/folder_name/GEN/SYR
#DIR = filpath(DOSSIER+DIRSEP+"GEN"+DIRSEP+"SYR"+DIRSEP+"RU-RU","","","X3_PUB")
#LSTATUS = func ASYRSYS.REMOVE_DIRECTORY(DIR)
#If LSTATUS=[V]CST_AOK
#    Call ECR_TRACE ("Directory deletion:|"-DIR,0) From GESECRAN
#Else
#    Call ECR_TRACE ("Error during directory deletion:|"-DIR,1) From GESECRAN
#Endif

# As we should clean only for root folder, this part is in comment because this directory is shared by all folders
##---- Remove directory RUS in /X3_PUB/X3_ROOT/GEN
#DIR = filpath("X3_ROOT"+DIRSEP+"GEN"+DIRSEP+"RUS","","","X3_PUB")
#LSTATUS = func ASYRSYS.REMOVE_DIRECTORY(DIR)
#If LSTATUS=[V]CST_AOK
#    Call ECR_TRACE ("Directory deletion:"-DIR,0) From GESECRAN
#Else
#    Call ECR_TRACE ("Error during directory deletion:"-DIR,1) From GESECRAN
#Endif

#---- Remove generated files in directory "Folder_name" : menurus, jsonmenurus & textrarus
FIL(0) = filpath("","menurus","",[L]DOSSIER)
FIL(1) = filpath("","jsonmenurus","",[L]DOSSIER)
FIL(2) = filpath("","textrarus","",[L]DOSSIER)
For I=0 To dim(FIL)-1
    Raz LMES
    Call EXIST(FIL(I),LEXIST) From ASYRSYS
    If LEXIST=1 & func ASYRSYS.DELETEFILE(FIL(I), LMES) = 0
        Call ECR_TRACE ("Deletion of file |"-FIL(I)-":"-LMES,1) From GESECRAN
    Endif
Next

End


#-------------------------------------------------------------------------------#
Subprog PATCH(APPLI)
Value Char    APPLI

  Local File =APPLI+".ADOVAL" [ZADW]
  Look [ZADW]ADW1(1)="ADEMO"

  If fstat<>[V]CST_AOK
    # Not a DEMO folder
    Call EXE_UTILANRUS(APPLI,[V]CST_AFALSE,[V]CST_AFALSE)
  Else
    # It's a DEMO folder
    Call EXE_UTILANRUS(APPLI,[V]CST_ATRUE,[V]CST_ATRUE)
  Endif

  LogicClose File [ZADW]
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  Local File =APPLI+".ADOVAL" [ZADW]
  Look [ZADW]ADW1(1)="ADEMO"

  If fstat<>[V]CST_AOK
    # Not a DEMO folder
    Call EXE_UTILANRUS(APPLI,[V]CST_AFALSE,[V]CST_AFALSE)
  Else
    # It's a DEMO folder
    Call EXE_UTILANRUS(APPLI,[V]CST_ATRUE,[V]CST_ATRUE)
  Endif

  LogicClose File [ZADW]
End

