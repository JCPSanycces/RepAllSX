#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque MIGX0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone MIGSRCFLD
mkstat = 0
zoncou = "MIGSRCFLD"
indice = 0
If varmode([M]MIGSRCFLD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "MIGSRCFLD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]MIGSRCFLD,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "MIGSRCFLD" : GZNUM = 1002551 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTDOS"
  Call C_DOSSIER([M]MIGSRCFLD) From DOSCONT
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "MIGSRCFLD" : GZNUM = 1002551 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "ACCESDOS"
   Call CTL_DROIT_DOSSIER([M]MIGSRCFLD,"") From DOSCONT
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "MIGSRCFLD" : GZNUM = 1002551 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone MIGTRGFLD
mkstat = 0
zoncou = "MIGTRGFLD"
indice = 0
If varmode([M]MIGTRGFLD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "MIGTRGFLD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]MIGTRGFLD,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "MIGTRGFLD" : GZNUM = 1002553 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTDOS"
  Call C_DOSSIER([M]MIGTRGFLD) From DOSCONT
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "MIGTRGFLD" : GZNUM = 1002553 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "ACCESDOS"
   Call CTL_DROIT_DOSSIER([M]MIGTRGFLD,"") From DOSCONT
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "MIGTRGFLD" : GZNUM = 1002553 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone MIGMOD
mkstat = 0
zoncou = "MIGMOD"
indice = 0
IMPENT = [M]MIGMOD
If varinit([M]MIGMOD,indice)=0
 IMPENT = 1
Endif
If varmode([M]MIGMOD,indice)=0
 [M]MIGMOD(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "MIGMOD" : Gosub ACTION From =IMPTRT
  IMPENT = [M]MIGMOD(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "MIGMOD" : GZNUM = 943 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]MIGMOD = IMPENT

####################################
## Bloc liste 3
####################################
IMPTBL = 0

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "MIGX0"
Return

