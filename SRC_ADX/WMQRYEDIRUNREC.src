# Supervisor
## WMREP REPRESENTATION ## EDIRUNREC
# 2018-10-17 07:54:26 665

#-------------------------------------------------------------------#
# Tables list to open
#-------------------------------------------------------------------#
$AQUERY_OPEN
If clalev([F:EDR])=0 : Local File EDIRUN [EDR] : Endif
If clalev([F:A_])=0 : Local File EDIRUN [A_] : Endif
ACTION = "AQUERY_OPEN_AFTER" : Gosub AQUERY_ACTION
Return
 
#-------------------------------------------------------------------#
# Tables list to close
#-------------------------------------------------------------------#
$AQUERY_CLOSE
LogicClose File [EDR]
LogicClose File [A_]
ACTION = "AQUERY_CLOSE_AFTER" : Gosub AQUERY_ACTION
Return
 
#-------------------------------------------------------------------#
# Link for the query
#-------------------------------------------------------------------#
$AQUERY_JOIN
Link [EDR] With
& [A_]EDR0~=[EDR]NUM
& As [LNK_]
& Where ( (1=1)
&  )
ACTION = "AQUERY_JOIN_AFTER" : Gosub AQUERY_ACTION
Return
 
#-------------------------------------------------------------------#
# Link for the lookup
#-------------------------------------------------------------------#
$AQUERY_JOIN_LOOKUP
Link [EDR] With
& [A_]EDR0~=[EDR]NUM
& As [LNK_]
& Where ( (1=1)
&  )
Return
 
#-------------------------------------------------------------------#
# Default filter for the query
#-------------------------------------------------------------------#
$AQUERY_FILTER_DEF
QFILTER='CATACT'
Return
 
#-------------------------------------------------------------------#
# Transclass of fields of query
#-------------------------------------------------------------------#
$AQUERY_TRANS
# EDR --- EDIRUN(EDR)
QRY(NBREP) = NewInstance R_EDIRUNREC AllocGroup PQRY
QRY(NBREP).setAccessorEnabled = 0
If dim([F:EDR]AUUID)>0 & [F:EDR]AUUID=NullUuid
 [F:EDR]AUUID = getUuid
Endif
SetInstance QRY(NBREP).EDR With [F:EDR]
[L]ASTATUS = fmet QRY(NBREP).ACTION("AQUERY_TRANS_AFTER")
 
QRY(NBREP).setAccessorEnabled = 1
Gosub AQUERY_LNKPRO
Return

#-------------------------------------------------------------------#
# Create instance
#-------------------------------------------------------------------#
$AQUERY_CREATEINSTANCE
# EDR --- EDIRUN(EDR)
QRY = NewInstance R_EDIRUNREC AllocGroup PQRY
QRY.setAccessorEnabled = 0
Return

#-------------------------------------------------------------------#
# Create instance
#-------------------------------------------------------------------#
$AQUERY_SETINSTANCE
If dim([F:EDR]AUUID)>0 & [F:EDR]AUUID=NullUuid
 [F:EDR]AUUID = getUuid
Endif
SetInstance QRY.EDR With [F:EDR]
[L]ASTATUS = fmet QRY.ACTION("AQUERY_TRANS_AFTER")
Return

#-------------------------------------------------------------------#
# Additionnal criteria of query
#-------------------------------------------------------------------#
$AQUERY_CRITERIA
Gosub DECLARE_VAR From WMC0EDIRUN
CURQRY = "R_EDIRUNREC"
ACTION = "AQUERY_CRITERIA_AFTER" : Gosub AQUERY_ACTION
Return

#-------------------------------------------------------------------#
# LNKPRO of query 
#-------------------------------------------------------------------#
$AQUERY_LNKPRO
Callmet QRY(NBREP).EDR.PARCOD.LNKPRO
Callmet QRY(NBREP).EDR.CATCOD.LNKPRO
Return

#-------------------------------------------------------------------#
# LNKPRO of query INSTANCE
#-------------------------------------------------------------------#
$AQUERY_LNKPRO_INSTANCE
Callmet QRY.EDR.PARCOD.LNKPRO
Callmet QRY.EDR.CATCOD.LNKPRO
Return

#-------------------------------------------------------------------#
# LOAD_PROPERTIES of query
#-------------------------------------------------------------------#
$AQUERY_DECODE_CRITERIA
NBPRO = 0
NBPRO += 1 : TBPRO(NBPRO) = "NUM" : TBFIL(NBPRO) = "[F:EDR]NUM"
           : TBTYP(NBPRO) = 2 : TBPTH(NBPRO) = "EDR.NUM"
NBPRO += 1 : TBPRO(NBPRO) = "RUNDES" : TBFIL(NBPRO) = "[F:EDR]RUNDES"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "EDR.RUNDES"
NBPRO += 1 : TBPRO(NBPRO) = "LASRUNDAT" : TBFIL(NBPRO) = "[F:EDR]LASRUNDAT"
           : TBTYP(NBPRO) = 12 : TBPTH(NBPRO) = "EDR.LASRUNDAT"
NBPRO += 1 : TBPRO(NBPRO) = "PARCOD" : TBFIL(NBPRO) = "[F:EDR]PARCOD"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "EDR.PARCOD"
NBPRO += 1 : TBPRO(NBPRO) = "PARDES" : TBFIL(NBPRO) = "[F:EDR]PARDES"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "EDR.PARDES"
NBPRO += 1 : TBPRO(NBPRO) = "CATCOD" : TBFIL(NBPRO) = "[F:EDR]CATCOD"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "EDR.CATCOD"
NBPRO += 1 : TBPRO(NBPRO) = "CATDES" : TBFIL(NBPRO) = "[F:EDR]CATDES"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "EDR.CATDES"
NBPRO += 1 : TBPRO(NBPRO) = "CATTYP" : TBFIL(NBPRO) = "[F:EDR]CATTYP"
           : TBTYP(NBPRO) = 1 : TBPTH(NBPRO) = "EDR.CATTYP"
NBPRO += 1 : TBPRO(NBPRO) = "CATOPE" : TBFIL(NBPRO) = "[F:EDR]CATOPE"
           : TBTYP(NBPRO) = 1 : TBPTH(NBPRO) = "EDR.CATOPE"
NBPRO += 1 : TBPRO(NBPRO) = "CATACT" : TBFIL(NBPRO) = "[F:EDR]CATACT"
           : TBTYP(NBPRO) = 1 : TBPTH(NBPRO) = "EDR.CATACT"
NBPRO += 1 : TBPRO(NBPRO) = "DUPLICATEFLG" : TBFIL(NBPRO) = "[F:EDR]DUPLICATEFLG"
           : TBTYP(NBPRO) = 1 : TBPTH(NBPRO) = "EDR.DUPLICATEFLG"
NBPRO += 1 : TBPRO(NBPRO) = "TESTFLG" : TBFIL(NBPRO) = "[F:EDR]TESTFLG"
           : TBTYP(NBPRO) = 1 : TBPTH(NBPRO) = "EDR.TESTFLG"
NBPRO += 1 : TBPRO(NBPRO) = "DIRECTFLG" : TBFIL(NBPRO) = "[F:EDR]DIRECTFLG"
           : TBTYP(NBPRO) = 1 : TBPTH(NBPRO) = "EDR.DIRECTFLG"
ACTION = "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_ACTION
Return

#-------------------------------------------------------------------#
# Standard key of query
#-------------------------------------------------------------------#
$AQUERY_PRIMARYKEYS
Local Char ASTDKEY(250)
ASTDKEY = ""
ASTDKEY += "[F:EDR]NUM"
ACTION = "AQUERY_PRIMARYKEYS_AFTER" : Gosub AQUERY_ACTION
Return

#-------------------------------------------------------------------#
# ACTIONS
#-------------------------------------------------------------------#
$AQUERY_ACTION
Local Char CURPRO(250),CURPTH(250),AMETHOD(50),AEVENT(50)
[L]AEVENT = [L]ACTION
Gosub METHODS From EDIRUNREC_RSTD
Gosub EVENTS From EDIRUNREC_RSTD
Return
 


