# Superviseur
# Gestion du masque GENHREXT3 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone DFNNBR
mkstat = 0
zoncou = "DFNNBR"
indice = 0
status = 1
zoncou = "DFNNBR"
If varmode([M]DFNNBR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DFNNBR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]DFNNBR
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]DFNNBR = nolign
   status = 75
   Call SAI_DFNNBR(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone GRPNBR
mkstat = 0
zoncou = "GRPNBR"
indice = 0
status = 1
zoncou = "GRPNBR"
If varmode([M]GRPNBR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GRPNBR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]GRPNBR
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]GRPNBR = nolign
   status = 75
   Call SAI_GRPNBR(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

