#<AdxTL>@(#)8.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Update activity codes TRU & FAL
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update activity codes TRU & FAL") From LECFIC
Local File ADOSSIER [ADS2]
Local File ADOSSIER [ADS]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub UPDATE_ACV
End

#-------------------#
$UPDATE_ACV
Local Char COD(20)

# Update activity codes TRU & FAL
Call ECR_TRACE("Update activity codes TRU & FAL"-time$,0) From GESECRAN

Local File =DOSSIER+".ACTIV" [ACVX]

Trbegin [ACVX]
 For COD="TRU","FAL"
  Read [ACVX]CODACT=COD
  If !fstat
   Case COD
    When "TRU" : [F:ACVX]FLACT = 2 : [F:ACVX]DEP = 4 : [F:ACVX]ACTFOR = "1"
    When "FAL" : [F:ACVX]FLACT = 1 : [F:ACVX]DEP = 4 : [F:ACVX]ACTFOR = "0"
   Endcase
   Rewrite [ACVX]
   If fstat
    Call ERREUR("ACTIV"-[F:ACVX]CODACT-COD,2) From DOSDIC
   Endif
  Endif
 Next COD
Commit

Close Local File [ACVX]
Return

