    [M:CQU1]STRVAL    = ""
    [M:CQU1]ENDVAL    = ""
    [M:CQU1]TCT       = ""
    [M:CQU1]SHACAT    = ""
    Affzo [M:CQU1]STRVAL
    Affzo [M:CQU1]ENDVAL
    Affzo [M:CQU1]TCT
    Affzo [M:CQU1]SHACAT
 When 4 :
    [M:CQU1]ALPSTRVAL = ""
