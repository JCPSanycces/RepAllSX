############################################################
Subprog AS_ASWCHA(VALEUR)
Variable Integer VALEUR
If [M:CQU1]ASWTYP = 5
  VALEUR = 3
  mkstat = 2
  End
Elsif find ([M:CQU1]ASWTYP,6,7)     # FQ 50451 GA 11/2008
    mkstat = 2
    VALEUR = 0
    [M:CQU1]ASWCHA = 0
    End
Endif
# Issue 82300 GA 06/2012 Add new dedicated symbols
If [M:CQU1]QSTORI <> 1                |
&  left$([M:CQU1]QSTNUM,5) = "NOLNK"  |
&  left$([M:CQU1]QSTNUM,6) = "FCYITF" |
&  left$([M:CQU1]QSTNUM,4) = "RCMP"   |
&  find(left$([M:CQU1]QSTNUM,6),"ITUBPR","ITUITM","ITUDES") |
&  find(left$([M:CQU1]QSTNUM,6),"ITPBPR","ITPITM","ITPDES")
  If [M:CQU1]ASWTYP <> 1
    VALEUR = 0
  Endif
  mkstat = 2
Else
  If [M:CQU1]ASWTYP <> 1
    VALEUR = 0
    mkstat = 2
    End
  Endif
Endif
End
############################################################
Subprog AM_ASWCHA(VALEUR)
Variable Integer VALEUR
[M:CQU1]STRVAL = toupper([M:CQU1]STRVAL)
[M:CQU1]ENDVAL = toupper([M:CQU1]ENDVAL)
[M:CQU1]DEFVAL = toupper([M:CQU1]DEFVAL)
Affzo [M:CQU1]STRVAL
Affzo [M:CQU1]ENDVAL
Affzo [M:CQU1]DEFVAL
End
############################################################
Subprog AS_STRVAL(VALEUR)
Variable  Char VALEUR
If [M:CQU1]CTLTYP <> 5
  mkstat = 2
  VALEUR = ""
Endif
End
############################################################
Subprog C_STRVAL(VALEUR)
Variable Char VALEUR
Call SAI_VARIABLE(VALEUR,[M:CQU1]ASWTYP,[M:CQU1]ASWCHA,[M:CQU1]ALPSTRVAL,[M:CQU1]NUMSTRVAL,
&                 [M:CQU1]DATSTRVAL,mkstat) From CFGLIBD
End
############################################################
Subprog AS_ENDVAL(VALEUR)
Variable Char VALEUR
If [M:CQU1]CTLTYP <> 5
  mkstat = 2
  VALEUR = ""
Endif
End
############################################################
Subprog C_ENDVAL(VALEUR)
Variable Char VALEUR
Call SAI_VARIABLE(VALEUR,[M:CQU1]ASWTYP,[M:CQU1]ASWCHA,[M:CQU1]ALPENDVAL,[M:CQU1]NUMENDVAL,
&                [M:CQU1]DATENDVAL,mkstat) From CFGLIBD
If mkstat = 0
  Case [M:CQU1]ASWTYP
    When 1 :
      If [M:CQU1]ALPENDVAL < [M:CQU1]ALPSTRVAL
        mkstat = 2
        GMESSAGE = mess(44,199,1)
      Endif
    When 2 :
      If [M:CQU1]NUMENDVAL < [M:CQU1]NUMSTRVAL
        mkstat = 2
        GMESSAGE = mess(44,199,1)
      Endif
    When 3 :
      If [M:CQU1]DATENDVAL < [M:CQU1]DATSTRVAL
        mkstat = 2
        GMESSAGE = mess(44,199,1)
      Endif
  Endcase
Endif
End
############################################################
Subprog AS_DEFVAL(VALEUR)
Variable Char VALEUR
# Issue 82300 GA 06/2012 Add new dedicated symbols
If [M:CQU1]ASWTYP > 4                 |
&  [M:CQU1]QSTNUM = "UPDLEV"          |
&  left$([M:CQU1]QSTNUM,5) = "NOLNK"  |
&  left$([M:CQU1]QSTNUM,6) = "FCYITF" |
&  left$([M:CQU1]QSTNUM,4) = "RCMP"   |
&  find(left$([M:CQU1]QSTNUM,6),"ITUBPR","ITUITM","ITUDES") |
&  find(left$([M:CQU1]QSTNUM,6),"ITPBPR","ITPITM","ITPDES")
  mkstat = 2
Endif
End
############################################################
Subprog C_DEFVAL(VALEUR)
Variable Char VALEUR
Call SAI_VARIABLE(VALEUR,[M:CQU1]ASWTYP,[M:CQU1]ASWCHA,[M:CQU1]ALPDEFVAL,[M:CQU1]NUMDEFVAL,
&                [M:CQU1]DATDEFVAL,mkstat) From CFGLIBD
End
############################################################
Subprog AS_SALTXT(VALEUR)
Variable Char    VALEUR()
# FQ 50451 GA 11/2008 If [M:CQU1]ASWTYP = 5
If find([M:CQU1]ASWTYP,5,6,7)         |
&  [M:CQU1]QSTNUM          = "UPDLEV" |
&  left$([M:CQU1]QSTNUM,5) = "NOLNK"  |
&  left$([M:CQU1]QSTNUM,6) = "FCYITF" |
&  left$([M:CQU1]QSTNUM,4) = "RCMP"   |
&  find(left$([M:CQU1]QSTNUM,6),"ITUBPR","ITUITM","ITUDES") |
&  find(left$([M:CQU1]QSTNUM,6),"ITPBPR","ITPITM","ITPDES")
  mkstat = 2
Else
  If VALEUR <> ""
    GBOUT1 = mess(200,198,1)
  Else
    Raz GBOUT1
  Endif
Endif
End
############################################################
Subprog AM_SALTXT(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  [M:CQU1]QUOFLG = 1
  [M:CQU1]ORDFLG = 1
  Affzo [M:CQU1]QUOFLG
  Affzo [M:CQU1]ORDFLG
  Grizo [M:CQU1]QUOFLG
  Grizo [M:CQU1]ORDFLG
Else
  If [M:CQU1]SALTXT = ""
    [M:CQU1]QUOFLG = 2
    [M:CQU1]ORDFLG = 2
    Affzo [M:CQU1]QUOFLG
    Affzo [M:CQU1]ORDFLG
    Actzo [M:CQU1]QUOFLG
    Actzo [M:CQU1]ORDFLG
  Endif
Endif
End
