#<AdxTL>@(#)6.0.0.0 $Revision$
# Sous programme de regeneration des traitements configurateur
Subprog PATCH(LMAP)
Value Char LMAP
If LMAP <> "X3"
  Global Char  S_DOSSIER(10)   : S_DOSSIER = LMAP
  Local Char   W_APPLI(10)     : W_APPLI   = LMAP
  Local File  =W_APPLI+".ACTIV" [ACV]
  Read [ACV]CODACT="CFG"
  If fstat = 0 & [F:ACV]FLACT = 2
    If clalev([F:CQU])  = 0 : Local File =W_APPLI+".CFGQST" [CQU]  : Endif
    If clalev([F:CQU0]) = 0 : Local File =W_APPLI+".CFGQST" [CQU0] : Endif
    # Issue 88129 GA 02/2013
    #Call GEN_VARSYS      From CFGLIBA
    #Gosub CFG_CONSTANTES From CFGLIB
    #Gosub CFG_SYMBOLES   From CFGLIB
    Call ECR_TRACE(W_APPLI-mess(76,188,1),0) From GESECRAN
    Call GEN_WUVAR(W_APPLI,"","") From CFGLIBA
    adxmbm = adxmbm
    Gosub SUP_GLOBALES From =W_APPLI+".WUVAR"
  Endif
Endif
End
############################################################
$ACTION
Case ACTION
  When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
  When "AVANT_OUVRE"  : Gosub AVANT_OUVRE
  When "FILTRE"       : Gosub FILTRE
  When "FILGAUCHE"    : Gosub FILGAUCHE
  When "OUVRE"        : Gosub OUVRE
  When "LIENS"        : Gosub LIENS
  When "SETBOUT"      : Gosub SETBOUT
  When "EXEBOUT"      : Gosub EXEBOUT
  When "AVANT_MODFIC" : Gosub AVANT_MODFIC
  When "RAZCRE"       : Gosub RAZCRE
  When "INICRE"       : Gosub INICRE
  When "INIMOD"       : Gosub INICRE
  When "VERIF_CRE"    : Gosub VERIF_CRE
  When "VERF_ANU"     : Gosub VERF_ANU
  When "ANNULE"       : Gosub ANNULE
  When "AV_IMPRIME"   : Gosub COP_ECRAN
                        OK = 0
  When "AV_LISTE"     : Gosub LIS_SYMBOLES
                        OK = 0
  When "FERME"        : Gosub FERME
  When "CHANGE"       : Call CHANGE_AXX ("CFGQST", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
  When "APRES_CRE","APRES_MOD","AP_ANNULE","AP_CHANGE"
    GCFG_GENTRT=1
  When Default
Endcase
Return
###########################################################
$OUVRE_BOITE
Local Char    BOXCQV(10)
Local Char    BOXCQW(10)
BOXCQV = "GAU_CHE"+num$(find("CQV",OBJLIS(1..8)))
BOXCQW = "GAU_CHE"+num$(find("CQW",OBJLIS(1..8)))
Return
###########################################################
$AVANT_OUVRE
Local Integer W_I
Call ACT_CFGUSR(GFONCTION,W_I) From CFGLIBD
If W_I <> 0
  OK = 0
Endif
Return
###########################################################
$FILTRE
Return
###########################################################
$FILGAUCHE
# FQ 60150 GA 11/2009 afficher tout dans "Derniers lus"
#FILTSUP      = "[F:CQU]QSTORI=1&[F:CQU]QSTTYP=1"
Case currbox
  When BOXCQV    : FILGAUSUP(0) = "[F:CQU]QSTORI=1&[F:CQU]QSTTYP<>1"
  When BOXCQW    : FILGAUSUP(0) = "[F:CQU]QSTORI<>1"
# FQ 60150 GA 11/2009 afficher tout dans "Derniers lus"
  When "GAU_CHE" : FILTSUP      = "[F:CQU]QSTORI=1&[F:CQU]QSTTYP=1"
  When "GAU_CHE9": FILGAUSUP(0) = "" : FILTSUP = ""
Endcase
Return
############################################################
$OUVRE
Local Integer W_UPD : W_UPD = 0
Local Char    W_PAR(1)
Local Char    WMSG (250)
Local Char    WMSG1(250)
Local Char    WMSG2(250)
Local Integer WNBRMAX
#
Local Char    W_LAN(03)(dim([M:CQU1]QSTLAN))
Local Char    W_INT(20)(dim([M:CQU1]QSTLAN))
Local Integer W_I, W_J
Global Integer GCFG_GENTRT    # Flag de gestion de génération automatique
#
# Chargement du nombre maximum de symboles a partir du masque CQU2 de liste des symboles
If clalev([M:CQU2]) = 0 : Local Mask CQU2   [CQU2] : Endif
WNBRMAX = dim([M:CQU2]QSTNUM)
#
Trbegin [CQU]
GOK = 1
Call GEN_VARSYS From CFGLIBA
If GOK = 1
  Commit
  Gosub OPEN_FILES     From CFGLIB
  Gosub CFG_CONSTANTES From CFGLIB
  Gosub CFG_SYMBOLES   From CFGLIB
  Call DESSHOLNG From TEXTE
Else
  Rollback
  FIN = 1
Endif
Return
############################################################
$SETBOUT
# Annulation interdite si l'on vient d'ailleur que l'objet
Call VIREBOUT(CHAINE,"H") From GOBJET
If GFONC1 <> "GESCQU"
  Call VIREBOUT(CHAINE,"A") From GOBJET
Endif
If [M:CQU1]QSTORI = 2
  Call VIREBOUT(CHAINE,"A") From GOBJET
Endif
If [M:CQU1]QSTORI <> 1
  Call VIREBOUT(CHAINE,"D2") From GOBJET
Endif
Return
############################################################
$EXEBOUT
Case REP
  When "1"
     Gosub GEN_TRT : GCFG_GENTRT=0
  When "2" :
     Call COPIE([M:CQU1]QSTNUM)
Endcase
Return
############################################################
$LIENS
Call PARAM("","CFGADV",W_PAR) From ADOVAL
[M:CQU1]CFGADV = val(W_PAR)
Gosub SET_VAL1
Gosub SET_SHO
Affzo [M:CQU1]5-90
Gosub GRISAGE_QSTNUM
Gosub GRISAGE_QSTTYP
Gosub GRISAGE_ASWTYP
Gosub GRISAGE_CTLTYP
Raz [M:CQU1]FILTAB
Raz [M:CQU1]TEXCON
Call CFGSETFOR(7,"","",[M:CQU1]FILTAB,[M:CQU1]TEXCON,[M:CQU1]VARSUP) From CFGLIB
# JPJ E26155 ->
If [M:CQU1]CTLTYP=3    # table
    Call TEXTFIC([M:CQU1]CODFIC,[M:CQU1]CODFLD,2,[M:CQU1]FLDTXT) From OBJDIV
Endif        # JPJ E26155
If [M:CQU1]CTLTYP=6 & [M:CQU1]OBJET=""   # Issue 95386 GA 01/2014 ctrl Table diverse
   [M:CQU1]OBJET="ADI"
Endif
If [M:CQU1]CTLTYP=3 & [M:CQU1]CODFIC="ATABDIV" & [M:CQU1]OBJET=""   # Issue 95386 GA 01/2014 ctrl Table diverse
   [M:CQU1]OBJET="ADI"
Endif

# Issue 79301 GA 02/2012 Image
Read [CBB]CBB0="CQU";[M:CQU1]QSTNUM;""
If !fstat
    [M:CQU1]CQUPIC = [F:CBB]BLOB
Endif

Return
############################################################
$COP_ECRAN
Call PRTSCR("CQU1","CQU1","",0,0) From ATRTX3
Return
###########################################################
$INICRE
#--- Creation / Modif de ATEXTRA
Call MAJTEXTRA ([M:CQU1]SALTXT,"CFGQST","SALTXT",[M:CQU1]QSTNUM,"") From ATEXTRA
Call MAJTEXTRA ([M:CQU1]QSTAXX,"CFGQST","QSTAXX",[M:CQU1]QSTNUM,"") From ATEXTRA

# Issue 79301 GA 02/2012 Image
If len([M:CQU1]CQUPIC)<>0
    Readlock [CBB]CBB0="CQU";[M:CQU1]QSTNUM;""
    Case fstat
        When 0 :
            [F:CBB]BLOB = [M:CQU1]CQUPIC
            Call REWCBB From TRTX3BLB
        When 5 :
            Raz [F:CBB]
            [F:CBB]CODBLB = "CQU"
            [F:CBB]IDENT1 = [M:CQU1]QSTNUM
            [F:CBB]TYPBLB = 3
            [F:CBB]BLOB = [M:CQU1]CQUPIC
            Call ECRCBB From TRTX3BLB
    Endcase
Else
    Delete [CBB] Where CODBLB="CQU" & IDENT1=[M:CQU1]QSTNUM
Endif
Return
############################################################
$RAZCRE
Gosub SET_SHO
[M:CQU1]QSTORI = 1
Affzo [M:CQU1]10
Affzo [M:CQU1]QSTORI
Actzo [M:CQU1]
Call PARAM("","CFGADV",W_PAR) From ADOVAL
[M:CQU1]CFGADV = val(W_PAR)
Raz [M:CQU1]FILTAB
Raz [M:CQU1]TEXCON
Call CFGSETFOR(7,"","",[M:CQU1]FILTAB,[M:CQU1]TEXCON,[M:CQU1]VARSUP) From CFGLIB
Return
############################################################
$LIS_SYMBOLES
If clalev([F:TCT])  = 0 : Local File TABCTL [TCT]  : Endif
If clalev([F:ATB])  = 0 : Local File ATABLE [ATB]  : Endif
If clalev([F:ATX])  = 0 : Local File ATEXTE [ATX]  : Endif
If clalev([F:CQU1]) = 0 : Local File CFGQST [CQU1] : Endif
If clalev([M:CQU2]) = 0 : Local Mask CQU2   [CQU2] : Endif
Raz [M:CQU2]
#
nolign = 0
Filter [CQU1] Order By Key CQU1
For [CQU1]
  If nolign < dim([M:CQU2]QSTNUM)-1
    nolign  += 1
    [M:CQU2] = [F:CQU1]
    Case [F:CQU1]ASWTYP
      When 1 :
        [M:CQU2]STRVAL(nolign-1) = [F:CQU1]ALPSTRVAL
        [M:CQU2]ENDVAL(nolign-1) = [F:CQU1]ALPENDVAL
        [M:CQU2]DEFVAL(nolign-1) = [F:CQU1]ALPDEFVAL
      When 2, 4 :
        If [F:CQU1]NUMSTRVAL = 0
          [M:CQU2]STRVAL(nolign-1) = ""
        Else
          [M:CQU2]STRVAL(nolign-1) = num$([F:CQU1]NUMSTRVAL)
        Endif
        If [F:CQU1]NUMENDVAL = 0
          [M:CQU2]ENDVAL(nolign-1) = ""
        Else
          [M:CQU2]ENDVAL(nolign-1) = num$([F:CQU1]NUMENDVAL)
        Endif
        If [F:CQU1]NUMDEFVAL = 0
          [M:CQU2]DEFVAL(nolign-1) = ""
        Else
          [M:CQU2]DEFVAL(nolign-1) = num$([F:CQU1]NUMDEFVAL)
        Endif
      When 3 :
        [M:CQU2]STRVAL(nolign-1) = format$("DfZz:"+GFMDAT,[F:CQU1]DATSTRVAL)
        [M:CQU2]ENDVAL(nolign-1) = format$("DfZz:"+GFMDAT,[F:CQU1]DATENDVAL)
        [M:CQU2]DEFVAL(nolign-1) = format$("DfZz:"+GFMDAT,[F:CQU1]DATDEFVAL)
    Endcase
    # FQ 53410 V6 Remplacé par lien court
    #If [F:CQU1]TCT <> ""
    #  Read [TCT]TCT0=[F:CQU1]TCT;1
    #  If fstat = 0
    #    #[M:CQU2]TCTDES(nolign-1) = [F:TCT]TCTDES  # V6 GA 03/2009 Texte traduit CRPOP
    #    Call LECTEXTRA([M:CQU2]TCTDES(nolign-1),"TABCTL","TCTDESAXX",[F:CQU]TCT,"") From ATEXTRA
    #  Endif
    #Endif
    # FQ 53410 V6 Remplacé par lien court
    #If [F:CQU1]CODFIC <> ""
    #  Read [ATB]CODFIC=[F:CQU1]CODFIC
    #  If fstat = 0
    #    Call TEXTE([F:ATB]INTITFIC,[M:CQU2]INTITFIC(nolign-1)) From OBJDIV
    #  Endif
    #Endif
    Call LECTEXTRA([M:CQU2]SALTXT(nolign-1),"CFGQST","SALTXT",[F:CQU1]QSTNUM,"") From ATEXTRA
    [M:CQU2]NBLIG = nolign
  Else
    Break
  Endif
Next
Filter [CQU1]
Call PRTSCR("CQU2","CQU2","",0,0) From ATRTX3
Return
############################################################
$AVANT_MODFIC
Gosub SET_VAL2
#
# Desactivation des scenarios utilisant cette question si modification des contrôles
If [F:CQU]QSTTYP = 1 &
& ([F:CQU]CTLTYP    <> [M:CQU1]CTLTYP    |
&  [F:CQU]TCT       <> [M:CQU1]TCT       |
&  [F:CQU]CODFIC    <> [M:CQU1]CODFIC    |
&  [F:CQU]MOTCLE    <> [M:CQU1]MOTCLE    |
&  [F:CQU]EVADEFVAL <> [M:CQU1]EVADEFVAL)
  Raz WMSG, WMSG1, WMSG2
  Filter [CSC]
  For [CSC]
    If find([F:CQU]QSTNUM,[F:CSC]QSTNUM(0..[F:CSC]QSTNBR-1))
      Readlock [CSC] Curr
      Case fstat
        When 1 :
          GOK = -1
          Break
        When 0 :
          [F:CSC]ENAFLG = 1
          Rewrite [CSC]
          If fstat
            GOK = 0
            Call FSTA("CSC") From GLOCK
            Break
          Endif
          WMSG += [F:CSC]SCENUM+" "
        When Default :
          GOK = 0
          Call FSTA("CSC") From GLOCK
          Break
      Endcase
    Endif
  Next
  Filter [CSC]
  If WMSG <> ""
    WMSG1 = mess(145,188,1)+"\"+WMSG
  Endif
# Recherche des formes & modeles utilisant cette question
  WMSG = ""
  Filter [CSH]
  For [CSH]
    If find([F:CQU]QSTNUM,[F:CSH]SYMNUM(0..[F:CSH]SYMNBR-1))
      WMSG += [F:CSH]SHACAT+"-"+[F:CSH]SHANUM+" "
    Endif
  Next
  Filter [CSH]
  If WMSG <> ""
    WMSG2 = mess(146,188,1)+"\"+WMSG
  Endif
  If WMSG1 <> ""
    GMESSAGE = WMSG1
    If WMSG2 <> ""
      GMESSAGE += "\"+WMSG2
    Endif
  Else
    GMESSAGE = WMSG2
  Endif
  If GMESSAGE <> ""
    GERR = 2
  Endif
Endif
Return
############################################################
$VERIF_CRE
Local Integer WNBR    : WNBR = nbrecord([F:CQU])
If WNBR > WNBRMAX
  OK = 0
  Call ERREUR(mess(155,188,1)-"("-num$(WNBRMAX)+")") From GESECRAN
Else
  Gosub SET_VAL2
Endif
Return
############################################################
$VERF_ANU
If clalev([F:CLN]) = 0 : Local File CFGLNK [CLN] : Endif
Filter [CLN] Where SYMTYP = [M:CQU1]QSTTYP &
&                  SYMNUM = [M:CQU1]QSTNUM
&            Order By Key CLN1
For [CLN]
  Call ERREUR(mess(174,188,1)-mess([F:CLN]SYMTYPWUS,752,1)-[F:CLN]SYMNUMWUS) From GESECRAN
  OK = 0
  Break
Next
Filter [CLN]
Return
############################################################
$ANNULE
Case [M:CQU1]QSTTYP
  When 1       : Call PURCLN(1,[M:CQU1]QSTNUM,0) From CFGLIBE
  When Default : Call PURCLN(2,[M:CQU1]QSTNUM,0) From CFGLIBE
Endcase
Delete [AXX] Where CODFIC="CFGQST" & IDENT1=[M:CQU1]QSTNUM
Return
############################################################
$FERME
If GCFG_GENTRT : Gosub GEN_TRT : Endif
Call IMPSCR From ATRTX3
If GFONC1 = "GESCQU"
  Gosub SUP_GLOBALES From =S_DOSSIER+".WUVAR" # Issue 88129 GA 02/201 before WUVAR
Endif
Call DEA_CFGUSR(GFONCTION) From CFGLIBD
Return
############################################################
$GEN_TRT
Call TEMPON(mess(76,188,1)) From GESECRAN
Call CFGWUS(1,"*",0) From CFGLIBE
Call CFGWUS(2,"*",0) From CFGLIBE
Call CFGWUS(30,"*",0) From CFGLIBE
Call GEN_WUVAR(S_DOSSIER,"","") From CFGLIBA # Issue 88129 GA 02/2013 before nomap
adxmbm = adxmbm
Call TEMPOFF From GESECRAN
Return
############################################################
$SET_SHO
If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
If [F:ADS]DOSSIER <> nomap
  Read [ADS]DOSSIER = nomap
  If fstat
    Raz [F:ADS]
  Endif
Endif
# V7 Issue 107138 GA 03/2015 [F:ADS]NBRLAN was increased for V7
Local Integer WNBRLAN : WNBRLAN=10
If [F:ADS]NBRLAN>0 & [F:ADS]NBRLAN<WNBRLAN  WNBRLAN=[F:ADS]NBRLAN Endif

If [M:CQU1]QSTSHONBR = 0
  # V7 Issue 107138 GA 03/2015 need to check before that
  #For W_I = 0 To [F:ADS]NBRLAN-1
  For W_I = 0 To WNBRLAN-1
    #If W_I >= dim([M:CQU1]QSTLAN) Break Endif  # Issue 105687 GA 01/2015
    [M:CQU1]QSTLAN(W_I) = [F:ADS]LAN(W_I)
    If [M:CQU1]QSTSHO(W_I) = ""
      [M:CQU1]QSTSHO(W_I) = [M:CQU1]QSTSHO(0)
    Endif
  Next W_I
  [M:CQU1]QSTSHONBR = WNBRLAN # V7 Issue 107138 GA 03/2015 before [F:ADS]NBRLAN
Else
  Raz W_LAN,W_INT
  For W_I = 0 To [M:CQU1]QSTSHONBR-1
    W_LAN(W_I) = [M:CQU1]QSTLAN(W_I)
    W_INT(W_I) = [M:CQU1]QSTSHO(W_I)
  Next W_I
  Effzo [M:CQU1]10
  [M:CQU1]QSTSHONBR = 0
  # V7 Issue 107138 GA 03/2015 need to check before that
  #For W_I = 0 To [F:ADS]NBRLAN-1
  For W_I = 0 To WNBRLAN-1
    #If W_I >= dim([M:CQU1]QSTLAN) Break Endif  # Issue 105687 GA 01/2015
    W_J = find([F:ADS]LAN(W_I),W_LAN)
    If W_J = 0
      [M:CQU1]QSTLAN(W_I) = [F:ADS]LAN(W_I)
      [M:CQU1]QSTSHO(W_I) = W_INT(0)
    Else
      [M:CQU1]QSTLAN(W_I) = [F:ADS]LAN(W_I)
      [M:CQU1]QSTSHO(W_I) = W_INT(W_J-1)
    Endif
  Next W_I
  [M:CQU1]QSTSHONBR = WNBRLAN # V7 Issue 107138 GA 03/2015 before [F:ADS]NBRLAN
Endif
Return
############################################################
$SET_VAL1
Case [M:CQU1]ASWTYP
  When 1 :
    [M:CQU1]STRVAL = [M:CQU1]ALPSTRVAL
    [M:CQU1]ENDVAL = [M:CQU1]ALPENDVAL
    [M:CQU1]DEFVAL = [M:CQU1]ALPDEFVAL
  When 2, 4 :
    If [M:CQU1]NUMSTRVAL = 0
      [M:CQU1]STRVAL = ""
    Else
      [M:CQU1]STRVAL = num$([M:CQU1]NUMSTRVAL)
    Endif
    If [M:CQU1]NUMENDVAL = 0
      [M:CQU1]ENDVAL = ""
    Else
      [M:CQU1]ENDVAL = num$([M:CQU1]NUMENDVAL)
    Endif
    If [M:CQU1]NUMDEFVAL = 0
      [M:CQU1]DEFVAL = ""
    Else
      [M:CQU1]DEFVAL = num$([M:CQU1]NUMDEFVAL)
    Endif
  When 3 :
    [M:CQU1]STRVAL = format$("DfZz:"+GFMDAT,[M:CQU1]DATSTRVAL)
    [M:CQU1]ENDVAL = format$("DfZz:"+GFMDAT,[M:CQU1]DATENDVAL)
    [M:CQU1]DEFVAL = format$("DfZz:"+GFMDAT,[M:CQU1]DATDEFVAL)
Endcase
Return
############################################################
$SET_VAL2
[M:CQU1]OBJET  = ""
[M:CQU1]FCYFLD = ""
If [M:CQU1]CODFIC <> ""
    If !clalev([F:ATB]) : Local File ATABLE [ATB] : Endif
    Raz [F:ATB],[F:AOB]
    Read [ATB]CODFIC=[M:CQU1]CODFIC
    # On cherche en priorité un objet dont le nom correspond à l'abréviation de la table
    Read [AOB]NOMFIC=[F:ATB]CODFIC;[F:ATB]ABRFIC
    If fstat
        Filter [AOB] Where NOMFIC = [M:CQU1]CODFIC
&                    Order By Key ABREV
        For [AOB]
            Break
        Next
        Filter [AOB]
    Endif
    [M:CQU1]OBJET  = [F:AOB]ABREV
    [M:CQU1]FCYFLD = [F:AOB]ZSITE
Endif
Return
############################################################
$GRISAGE_QSTNUM
Case [M:CQU1]QSTORI
  When 1 :
    If (left$([M:CQU1]QSTNUM,5) = "NOLNK"  |
&       left$([M:CQU1]QSTNUM,6) = "FCYITF" |
&       left$([M:CQU1]QSTNUM,4) = "RCMP"   |
&       find(left$([M:CQU1]QSTNUM,6),"ITUBPR","ITUITM","ITUDES") |
&       find(left$([M:CQU1]QSTNUM,6),"ITPBPR","ITPITM","ITPDES") )
      Grizo [M:CQU1]QSTAXX
      Grizo [M:CQU1]QSTSHO
      Grizo [M:CQU1]QSTTYP
      Grizo [M:CQU1]ASWTYP
      Grizo [M:CQU1]ASWCHA
      Grizo [M:CQU1]HISFLG
      Grizo [M:CQU1]SEAFLG
      Grizo [M:CQU1]CTLTYP
      Grizo [M:CQU1]CODNUM
      Grizo [M:CQU1]SALTXT
      Grizo [M:CQU1]QUOFLG
      Grizo [M:CQU1]ORDFLG
      Grizo [M:CQU1]DEFVAL
      Grizo [M:CQU1]EVADEFVAL
      Grizo [M:CQU1]CODNUM
    Else
      Actzo [M:CQU1]QSTAXX
      Actzo [M:CQU1]QSTSHO
      Actzo [M:CQU1]QSTTYP
      Actzo [M:CQU1]ASWTYP
      Actzo [M:CQU1]ASWCHA
      Actzo [M:CQU1]HISFLG
      Actzo [M:CQU1]SEAFLG
      Actzo [M:CQU1]CTLTYP
      Actzo [M:CQU1]CODNUM
      Actzo [M:CQU1]SALTXT
      Actzo [M:CQU1]QUOFLG
      Actzo [M:CQU1]ORDFLG
      Actzo [M:CQU1]DEFVAL
      Actzo [M:CQU1]EVADEFVAL
      Actzo [M:CQU1]CODNUM
    Endif
  When 2 :
    Grizo [M:CQU1]
    If [M:CQU1]QSTNUM = "DYNAMT"
      Actzo [M:CQU1]QSTSHO
    Endif
    Actzo [M:CQU1]QSTNUM
    Actzo [M:CQU1]HISFLG
    Actzo [M:CQU1]SEAFLG
    Actzo [M:CQU1]DEFVAL
    Actzo [M:CQU1]EVADEFVAL
    Actzo [M:CQU1]SALTXT
    Actzo [M:CQU1]MOTCLE
  When Default :
    Grizo [M:CQU1]
    Actzo [M:CQU1]QSTNUM
    Actzo [M:CQU1]HISFLG
    Actzo [M:CQU1]SEAFLG
    Actzo [M:CQU1]DEFVAL
    Actzo [M:CQU1]EVADEFVAL
    Actzo [M:CQU1]SALTXT
Endcase
If [M:CQU1]CFGADV <> 2
  Grizo [M:CQU1]EVADEFVAL
Endif
Return
############################################################
$GRISAGE_QSTTYP
Case [M:CQU1]QSTORI
  When 1 :
    Case [M:CQU1]QSTTYP
      When 1 :
        #Actzo [M:CQU1]QSTPIC
        Actzo [M:CQU1]MOTCLE
        Grizo [M:CQU1]CODNUM
      When Default :
        #Grizo [M:CQU1]QSTPIC
        Grizo [M:CQU1]MOTCLE
        If [M:CQU1]QSTNUM          = "UPDLEV" |
&          left$([M:CQU1]QSTNUM,5) = "NOLNK"  |
&          left$([M:CQU1]QSTNUM,6) = "FCYITF" |
&          left$([M:CQU1]QSTNUM,4) = "RCMP"   |
&          find(left$([M:CQU1]QSTNUM,6),"ITUBPR","ITUITM","ITUDES") |
&          find(left$([M:CQU1]QSTNUM,6),"ITPBPR","ITPITM","ITPDES")
          Grizo [M:CQU1]CODNUM
        Else
          Actzo [M:CQU1]CODNUM
        Endif
    Endcase
  When Default :
    #Grizo [M:CQU1]QSTPIC
    Grizo [M:CQU1]MOTCLE
    Grizo [M:CQU1]CODNUM
Endcase
If [M:CQU1]CFGADV <> 2
  Grizo [M:CQU1]EVADEFVAL
Endif
Return
############################################################
$GRISAGE_ASWTYP
If [M:CQU1]ASWTYP          > 4        |
&  [M:CQU1]QSTNUM          = "UPDLEV" |
&  left$([M:CQU1]QSTNUM,5) = "NOLNK"  |
&  left$([M:CQU1]QSTNUM,6) = "FCYITF" |
&  left$([M:CQU1]QSTNUM,4) = "RCMP"   |
&  find(left$([M:CQU1]QSTNUM,6),"ITUBPR","ITUITM","ITUDES") |
&  find(left$([M:CQU1]QSTNUM,6),"ITPBPR","ITPITM","ITPDES")
  Grizo [M:CQU1]DEFVAL
  Grizo [M:CQU1]EVADEFVAL
Else
  Actzo [M:CQU1]DEFVAL
  Actzo [M:CQU1]EVADEFVAL
Endif
#
If find([M:CQU1]ASWTYP,2,3,4)    # JPJ suite pb duplication (num, date, bool)
    [M:CQU1]ASWCHA=0
    Grizo [M:CQU1]ASWCHA
Endif
#
# FQ 50451 GA 11/2008 If [M:CQU1]ASWTYP = 5
If find([M:CQU1]ASWTYP,5,6,7)         |
&  [M:CQU1]QSTNUM          = "UPDLEV" |
&  left$([M:CQU1]QSTNUM,5) = "NOLNK"  |
&  left$([M:CQU1]QSTNUM,6) = "FCYITF" |
&  left$([M:CQU1]QSTNUM,4) = "RCMP"   |
&  find(left$([M:CQU1]QSTNUM,6),"ITUBPR","ITUITM","ITUDES") |
&  find(left$([M:CQU1]QSTNUM,6),"ITPBPR","ITPITM","ITPDES")
  Grizo [M:CQU1]SALTXT
  Grizo [M:CQU1]ORDFLG
  Grizo [M:CQU1]QUOFLG
Else
  Actzo [M:CQU1]SALTXT
  Actzo [M:CQU1]ORDFLG
  Actzo [M:CQU1]QUOFLG
Endif
If [M:CQU1]CFGADV <> 2
  Grizo [M:CQU1]EVADEFVAL
Endif
Return
############################################################
$GRISAGE_CTLTYP
Actzo [M:CQU1]STRVAL
Actzo [M:CQU1]ENDVAL
Actzo [M:CQU1]TCT
Actzo [M:CQU1]CODFIC
Actzo [M:CQU1]CODFLD
Actzo [M:CQU1]FLDTXT
Actzo [M:CQU1]FILFIC
Actzo [M:CQU1]SHACAT
Actzo [M:CQU1]CTLBLO
Case [M:CQU1]CTLTYP
  When 1 :
    Grizo [M:CQU1]STRVAL
    Grizo [M:CQU1]ENDVAL
    Grizo [M:CQU1]TCT
    Grizo [M:CQU1]CODFIC
    Grizo [M:CQU1]CODFLD
    Grizo [M:CQU1]FLDTXT
    Grizo [M:CQU1]FILFIC
    Grizo [M:CQU1]SHACAT
    Grizo [M:CQU1]CTLBLO
  When 2 :
    Grizo [M:CQU1]STRVAL
    Grizo [M:CQU1]ENDVAL
    Grizo [M:CQU1]CODFIC
    Grizo [M:CQU1]CODFLD
    Grizo [M:CQU1]FLDTXT
    Grizo [M:CQU1]SHACAT
  When 3 :
    Grizo [M:CQU1]TCT
    Grizo [M:CQU1]SHACAT
  When 4 :
    Grizo [M:CQU1]STRVAL
    Grizo [M:CQU1]ENDVAL
    Grizo [M:CQU1]TCT
    Grizo [M:CQU1]CODFIC
    Grizo [M:CQU1]CODFLD
#    Grizo [M:CQU1]FILFIC
  When 5 :
    Grizo [M:CQU1]TCT
    Grizo [M:CQU1]CODFIC
    Grizo [M:CQU1]CODFLD
    Grizo [M:CQU1]FLDTXT
    Grizo [M:CQU1]FILFIC
    Grizo [M:CQU1]SHACAT
  When 6 :    # FQ 72873 GA 04/2011 Type de contrôle Table diverse (alphanumérique)
    Grizo [M:CQU1]STRVAL
    Grizo [M:CQU1]ENDVAL
    Grizo [M:CQU1]TCT
    Grizo [M:CQU1]CODFLD
    Grizo [M:CQU1]FLDTXT
    Grizo [M:CQU1]SHACAT
Endcase
If [M:CQU1]ASWTYP <> 1
  Grizo [M:CQU1]CODFIC
Endif
# FQ 50451 GA 11/2008 If [M:CQU1]ASWTYP = 5
If find([M:CQU1]ASWTYP,5,6,7)
  Grizo [M:CQU1]SALTXT
  Grizo [M:CQU1]QUOFLG
  Grizo [M:CQU1]ORDFLG
Endif
If [M:CQU1]CFGADV <> 2
  Grizo [M:CQU1]EVADEFVAL
Endif
Return
############################################################
############################################################
Subprog COPIE(LPAR)
Value Char    LPAR
#
Local Char    W_TRA(100)
Local Integer W_OK
Local Integer W_ERR
Local Integer W_I, W_J, W_K
#
If GTRACE = ""
  Call OUVRE_TRACE(mess(115,188,1)-LPAR) From LECFIC
Endif
W_ERR = 0
If clalev([M:DIA]) = 0
  GMODIF = 0
  Local Mask ACOPIE [DIA]
  Raz [M:DIA]
  [M:DIA]OBJET = mess(77,188,1)+" : "+LPAR
  W_OK = 2
  zonsui = "DOSDES"
  Call DIALWIN(W_OK,mess(115,188,1),"ACOPIE") From GESECRAN
  If W_OK <> 2
   Goto COPIE_FIN
  Endif
Endif
# Tables en lecture (From)
If [M:DIA]DOSORG <> nomap
  Call ERREUR(mess(94,188,1)) From GESECRAN
  Goto COPIE_FIN
Else
  Local File CFGQST    [CQU1]
  Local File TABCTL    [TCT1]
  Local File ATEXTRA   [AXX1]
  Local File CBLOB     [CBB1]       # FQ 75119 GA 09/2011 copie de symbole
  Local File TABFOR    [TFO1]       # FQ 75119 GA 09/2011 copie de symbole
Endif
# tables en ecriture (To)
If [M:DIA]DOSDES = nomap
  Call ERREUR(mess(94,188,1)) From GESECRAN
  Goto COPIE_FIN
Else
  Local File =[M:DIA]DOSDES+".CFGQST"    [CQU2]
  Local File =[M:DIA]DOSDES+".TABCTL"    [TCT2]
  Local File =[M:DIA]DOSDES+".ATEXTRA"   [AXX2]
  Local File =[M:DIA]DOSDES+".CBLOB"     [CBB2]       # FQ 75119 GA 09/2011 copie de symbole
  Local File =[M:DIA]DOSDES+".TABFOR"    [TFO2]       # FQ 75119 GA 09/2011 copie de symbole
Endif
# Contrôle copie possible (les elements existants doivent etre de meme nature)
Read [CQU1]CQU0=LPAR
If fstat
  Goto COPIE_FIN
Endif
Read [CQU2]CQU0=LPAR
If fstat = 0
  W_TRA = LPAR-mess(116,188,1)
  W_ERR = 1
  Call ECR_TRACE(W_TRA,1) From GESECRAN
Endif
Gosub OUVDOS From ATEXTRA
If W_ERR <> 0
  Goto COPIE_FIN
Endif
# Tout est ok on copie
#
Call TEMPON("T") From GESECRAN
Call DEBTRANS    From GLOCK
Gosub TRT_COPIE
Call TEMPOFF From GESECRAN
# Fin de copie
$COPIE_FIN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End
############################################################
$TRT_COPIE
Trbegin [CQU2]
Read [CQU1]CQU0=LPAR
If fstat
  GOK = 0
  Call FSTA("CQU1") From GLOCK
Else
  Read [CQU2]CQU0=LPAR
  If fstat
    [F:CQU2] = [F:CQU1]
    [F:CQU2]CREUSR = GUSER
    [F:CQU2]CREDAT = date$
    [F:CQU2]UPDUSR = ""
    [F:CQU2]UPDDAT = [0/0/0]
    Write [CQU2]
    If fstat
      GOK = 0
      Call FSTA("CQU2") From GLOCK
    Else
      Call COPTEXTRA("CFGQST","QSTAXX",[F:CQU1]QSTNUM,"") From ATEXTRA
      Read [CBB1]CBB0="CQU";[F:CQU1]QSTNUM;""
      If !fstat
        Read [CBB2]CBB0="CQU";[F:CQU1]QSTNUM;""
        If fstat
            [F:CBB2] = [F:CBB1]
            Raz [F:CBB2]UPDUSR, [F:CBB2]UPDDAT, [F:CBB2]UPDTIM
            #Call ECRCBB From TRTX3BLB # utilise le buffer [F:CBB]
            [F:CBB2]CREUSR = GUSER
            [F:CBB2]CREDAT = date$
            Write [CBB2]
            If fstat
               GOK = 0
               Call FSTA("CBB2") From GLOCK
            Endif
        Endif
      Endif
      W_TRA = mess(91,123,1)-mess([F:CQU2]QSTTYP,752,1)-[F:CQU2]QSTNUM
      Call ECR_TRACE(W_TRA,0) From GESECRAN
    Endif
    If [F:CQU1]TCT <> ""
      Read [TCT2]TCT0=[F:CQU1]TCT;1
      If fstat
        Filter [TCT1] Where TCT = [F:CQU1]TCT
        For [TCT1]
          [F:TCT2] = [F:TCT1]
          [F:TCT2]CREUSR = GUSER
          [F:TCT2]CREDAT = date$
          [F:TCT2]UPDUSR = ""
          [F:TCT2]UPDDAT = [0/0/0]
          Write [TCT2]
          If fstat
            GOK = 0
            Call FSTA("TCT2") From GLOCK
            Break
          Endif
          If [F:TCT2]TCTLIN = 1
            W_TRA = mess(91,123,1)-mess(105,188,1)-[F:TCT2]TCT
            Call ECR_TRACE(W_TRA,0) From GESECRAN
          Endif
        Next
        Filter [TCT1]
      Endif
    Endif
    If [F:CQU1]FILFIC <> ""  # Formule Configurateur # FQ 75119 GA 09/2011
      Read [TFO2]TFO0=7;[F:CQU1]FILFIC
      If fstat
        Filter [TFO1] Where FORTYP=7 & FORCOD = [F:CQU1]FILFIC
        For [TFO1]
          [F:TFO2] = [F:TFO1]
          [F:TFO2]CREUSR = GUSER
          [F:TFO2]CREDAT = date$
          [F:TFO2]UPDUSR = ""
          [F:TFO2]UPDDAT = [0/0/0]
          Write [TFO2]
          If fstat
            GOK = 0
            Call FSTA("TFO2") From GLOCK
            Break
          Endif
          W_TRA = mess(91,123,1)-mess(12,47,1)-[F:TFO2]FORCOD
          Call ECR_TRACE(W_TRA,0) From GESECRAN
        Next
        Filter [TFO1]
      Endif
    Endif
  Endif
Endif
If GOK <> 1
  Goto AB_COPIE
Else
  Commit
Endif
Return
############################################################
$AB_COPIE
Rollback
Return
############################################################
$ROLL_COPIE
Rollback
Call ROLL From GLOCK
If !GROLL
  Goto TRT_COPIE
Endif
Return
############################################################
Subprog AS_QSTNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  GBOUT2 = ""
Endif
End
############################################################
Subprog C_QSTNUM(VALEUR)
Variable Char    VALEUR()
Local Char    WUPP(10)
Local Char    WCHI(10) : WCHI = "0123456789"
Local Char    WCAR(36) : WCAR = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ"
Local Integer I
#
WUPP = vireblc(toupper(VALEUR),1)
For I = 0 To len(WUPP)
  If !instr(1,WCAR,mid$(WUPP,I,1))
    mkstat = 2
    Break
  Endif
Next I
If mkstat
  GMESSAGE = mess(94,123,1)+" ("+mid$(WUPP,I,1)+")"
Else
  Call CTR_SYMRES(WUPP) From CFGLIBA
  If mkstat
    mkstat = 2
    GMESSAGE = mess(169,188,1)
  Else
    If left$(VALEUR,4) = "RCMP"
      If mid$(WUPP,5,1) = "0" & len(WUPP) > 5
        mkstat = 2
        GMESSAGE = mess(83,123,1)
      Else
        For I = 5 To len(WUPP)
          If !instr(1,WCHI,mid$(WUPP,I,1))
            mkstat = 2
            GMESSAGE = mess(83,123,1)
            Break
          Endif
        Next I
      Endif
    Endif
    If left$(VALEUR,5) = "NOLNK"
      If mid$(VALEUR,6,1) < "1" | mid$(VALEUR,6,1) > "9"
        mkstat = 2
        GMESSAGE = mess(83,123,1)
      Endif
    Endif
    If left$(VALEUR,6) = "FCYITF"
      If mid$(VALEUR,7,1) < "1" |mid$(VALEUR,7,1) > "9"
        mkstat = 2
        GMESSAGE = mess(83,123,1)
      Endif
    Endif
    # Issue 82300 GA 06/2012 Add new dedicated symbols
    Case left$([M:CQU1]QSTNUM,6)
      When "ITUBPR"
            If mid$(VALEUR,10,1) < "1" |mid$(VALEUR,10,1) > "9" mkstat = 2 Endif
      When "ITUDES"
            If mid$(VALEUR,10,1) < "1" |mid$(VALEUR,10,1) > "9" mkstat = 2 Endif
      When "ITUITM"
            If mid$(VALEUR,10,1) < "1" |mid$(VALEUR,10,1) > "9" mkstat = 2 Endif
      When "ITPBPR"
            If mid$(VALEUR,10,1) < "1" |mid$(VALEUR,10,1) > "9" mkstat = 2 Endif
      When "ITPDES"
            If mid$(VALEUR,10,1) < "1" |mid$(VALEUR,10,1) > "9" mkstat = 2 Endif
      When "ITPITM"
            If mid$(VALEUR,10,1) < "1" |mid$(VALEUR,10,1) > "9" mkstat = 2 Endif
    Endcase
    If mkstat = 0
      [M:CQU1]QSTLEN = 99-len(VALEUR)
      If GREP = "C" | GREP = "D"
        [M:CQU1]QSTORI = 1
        [M:CQU1]QSTDIM = 1
        Affzo [M:CQU1]QSTORI
      Endif
    Endif
  Endif
Endif
End
############################################################
Subprog AM_QSTNUM(VALEUR)
Variable Char    VALEUR()
[M:CQU1]QSTNUM = VALEUR
If left$(VALEUR,4) = "RCMP"
  [M:CQU1]QSTAXX = mess(157,188,1)
  [M:CQU1]QSTTYP = 2
  [M:CQU1]CTLTYP = 1
  [M:CQU1]ASWCHA = 1
Endif
If left$(VALEUR,5) = "NOLNK"
  [M:CQU1]QSTAXX = mess(143,188,1)
  [M:CQU1]QSTTYP = 2
  [M:CQU1]CTLTYP = 1
  [M:CQU1]ASWCHA = 3
Endif
If left$(VALEUR,6) = "FCYITF"
  [M:CQU1]QSTAXX = mess(3,45,1)-"ITMFACILIT"
  [M:CQU1]QSTTYP = 2
  [M:CQU1]CTLTYP = 1
  [M:CQU1]ASWCHA = 1
Endif
# Issue 82300 GA 06/2012 Add new dedicated symbols
If find(left$(VALEUR,6),"ITUBPR","ITUITM","ITUDES") |
&  find(left$(VALEUR,6),"ITPBPR","ITPITM","ITPDES")
  # Issue 82300 GA 06/2012 Add new dedicated symbols
  Case left$(VALEUR,6)
    When "ITUBPR"
          [M:CQU1]QSTAXX = mess(78,117,1)-"ITU"
    When "ITUDES"
          [M:CQU1]QSTAXX = mess(63,154,1)-"ITU"
    When "ITUITM"
          [M:CQU1]QSTAXX = mess(6,159,1)-"ITU"
    When "ITPBPR"
          [M:CQU1]QSTAXX = mess(17,7,1)-"ITP"
    When "ITPDES"
          [M:CQU1]QSTAXX = mess(63,154,1)-"ITP"
    When "ITPITM"
          [M:CQU1]QSTAXX = mess(6,159,1)-"ITP"
  Endcase
  [M:CQU1]QSTTYP = 2
  [M:CQU1]CTLTYP = 1
  [M:CQU1]ASWCHA = 1
Endif
# Issue 82300 GA 06/2012 Add new dedicated symbols
If left$(VALEUR,4) = "RCMP"  |
&  left$(VALEUR,5) = "NOLNK" |
&  left$(VALEUR,6) = "FCYITF" |
&  find(left$(VALEUR,6),"ITUBPR","ITUITM","ITUDES") |
&  find(left$(VALEUR,6),"ITPBPR","ITPITM","ITPDES")
  Affzo [M:CQU1]QSTAXX
  Affzo [M:CQU1]QSTTYP
  Affzo [M:CQU1]CTLTYP
  Affzo [M:CQU1]ASWCHA
  Gosub GRISAGE_QSTNUM
  Gosub GRISAGE_QSTTYP
  Gosub GRISAGE_ASWTYP
  Gosub GRISAGE_CTLTYP
#  mkstat = 4
Else
  Gosub GRISAGE_QSTNUM
Endif
End
############################################################
Subprog AS_TCT(VALEUR)
Variable Char    VALEUR()
If [M:CQU1]CTLTYP <> 2 | [M:CQU1]CODFIC <> ""
  mkstat = 2
Endif
End
############################################################
Subprog C_TCT(VALEUR)
Variable Char    VALEUR()
If ([M:CQU1]CTLTYP <> 2 & VALEUR <> "") | [M:CQU1]CODFIC <> ""
  mkstat = 2
Else
  Read [TCT]TCT0=VALEUR
  If fstat
    mkstat = 2
  Else
    If [F:TCT]TCTTYP <> [M:CQU1]ASWTYP
      mkstat = 2
    Endif
  Endif
Endif
If mkstat
  GMESSAGE = mess(162,188,1)
Endif
End
############################################################
Subprog AS_CODFIC(VALEUR)
Variable Char    VALEUR()
# FQ 72873 GA 04/2011 Type de contrôle Table diverse (alphanumérique)
#If [M:CQU1]CTLTYP <> 3 | [M:CQU1]ASWTYP > 2
If !find([M:CQU1]CTLTYP,3,6) | [M:CQU1]ASWTYP > 2
  mkstat = 2
Endif
End
############################################################
Subprog S_CODFIC(VALEUR)
Variable Char    VALEUR()
# FQ 72873 GA 04/2011 Type de contrôle Table diverse (alphanumérique)
If  [M:CQU1]CTLTYP=6
 ## Action SELADII
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 Local Decimal WNUMTAB : WNUMTAB=val(VALEUR)
 SAVACT = GACTION : GACTION = "SELADII"
 Call S_TAB_NUM(WNUMTAB,PARMSK,"SELADII","SUBADI","") From GACTION
 GACTION = SAVACT
 VALEUR=num$(WNUMTAB)
Elsif  [M:CQU1]CTLTYP=3
 ## Action SELOBJET sur ATB
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELOBJET"
 PARMSK(1) = "ATB"
 PARMSK(2) = "CODFIC"
 Filter [ATB] Where CODFIC>"B"  # ne pas montrer les tables Superviseur
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJET","SELOBJ","") From GACTION
 GACTION = SAVACT
 Filter [ATB]
Endif
End
############################################################
Subprog C_CODFIC(VALEUR)
Variable Char    VALEUR()
Local Integer W_I
# FQ 72873 GA 04/2011 Type de contrôle Table diverse (alphanumérique)
If find([M:CQU1]CTLTYP,3,6) & VALEUR = ""
  mkstat = 2
Elsif  [M:CQU1]CTLTYP=6
# FQ 72873 GA 08/2011 Type de contrôle Table diverse (alphanumérique)
  If !clalev([F:ADV]) : Local File ATABTAB [ADV] : Endif
  Read [ADV]CODE=val(VALEUR)
  If fstat mkstat = 2 Endif
Elsif  [M:CQU1]CTLTYP=3
# FQ 72873 GA 08/2011 Type de contrôle Table X3 (alphanumérique)
  If !clalev([F:ATB]) : Local File ATABLE [ATB] : Endif
  Read [ATB]CODFIC=VALEUR
  If fstat mkstat = 2 Endif
Endif
End
############################################################
Subprog AM_CODFIC(VALEUR)
Variable Char    VALEUR()
Call CFG_MASFLD(nomap,VALEUR,[M:CQU1]CODFLD,[M:CQU1]FLDTXT) From CFGLIBD
[M:CQU1]FILFIC = ""
If [M:CQU1]CODFLD <> ""
  Affzo [M:CQU1]CODFLD
  Affzo [M:CQU1]FLDTXT
  Affzo [M:CQU1]FILFIC
Endif
End
############################################################
Subprog AS_CODFLD(VALEUR)
Variable Char    VALEUR()
If [M:CQU1]CTLTYP <> 3 | [M:CQU1]ASWTYP <> 1
  mkstat = 2
Else
  If VALEUR = ""
    Call CFG_MASFLD(nomap,[M:CQU1]CODFIC,VALEUR,[M:CQU1]FLDTXT) From CFGLIBD
    If [M:CQU1]CODFLD <> ""
      Affzo [M:CQU1]FLDTXT
    Endif
  Endif
Endif
End
############################################################
Subprog C_CODFLD(VALEUR)
Variable Char    VALEUR()
Call TEXTFIC([M:CQU1]CODFIC,VALEUR,2,[M:CQU1]FLDTXT) From OBJDIV
If [M:CQU1]FLDTXT = ""
  mkstat = 2
Else
  Affzo [M:CQU1]FLDTXT
Endif
End
############################################################
Subprog AS_FILFIC(VALEUR)
Variable Char    VALEUR()
If !(([M:CQU1]CTLTYP = 3 & [M:CQU1]ASWTYP = 1) | [M:CQU1]CTLTYP = 2 | [M:CQU1]CTLTYP = 4)
  mkstat = 2
Endif
End
############################################################
Subprog C_FILFIC(VALEUR)
Variable Char    VALEUR()
End
############################################################
Subprog C_ASWTYP(VALEUR)
Variable Integer VALEUR
End
############################################################
Subprog AM_ASWTYP(VALEUR)
Variable Integer VALEUR
Case VALEUR
  When 1 :
    [M:CQU1]NUMSTRVAL = 0
    [M:CQU1]NUMENDVAL = 0
    [M:CQU1]NUMDEFVAL = 0
    [M:CQU1]DATSTRVAL = [0/0/0]
    [M:CQU1]DATENDVAL = [0/0/0]
    [M:CQU1]DATDEFVAL = [0/0/0]
  When 2 :
    [M:CQU1]ALPSTRVAL = ""
    [M:CQU1]ALPENDVAL = ""
    [M:CQU1]ALPDEFVAL = ""
    [M:CQU1]DATSTRVAL = [0/0/0]
    [M:CQU1]DATENDVAL = [0/0/0]
    [M:CQU1]DATDEFVAL = [0/0/0]
 When 3 :
    [M:CQU1]NUMSTRVAL = 0
    [M:CQU1]NUMENDVAL = 0
    [M:CQU1]NUMDEFVAL = 0
    [M:CQU1]ALPSTRVAL = ""
    [M:CQU1]ALPENDVAL = ""
    [M:CQU1]ALPDEFVAL = ""
Endcase
[M:CQU1]ASWTYP = VALEUR
[M:CQU1]STRVAL = ""
[M:CQU1]ENDVAL = ""
[M:CQU1]DEFVAL = ""
[M:CQU1]EVADEFVAL= ""
#
Affzo [M:CQU1]STRVAL
Affzo [M:CQU1]ENDVAL
Affzo [M:CQU1]DEFVAL
Affzo [M:CQU1]EVADEFVAL
Gosub GRISAGE_ASWTYP
End
############################################################
Subprog AS_CTLTYP(VALEUR)
Variable Integer VALEUR
If [M:CQU1]QSTORI <> 1
  mkstat = 2
Else
# Issue 82300 GA 06/2012 Add new dedicated symbols
  If find ([M:CQU1]ASWTYP,4,5)          |
&    left$([M:CQU1]QSTNUM,5) = "NOLNK"  |
&    left$([M:CQU1]QSTNUM,6) = "FCYITF" |
&    left$([M:CQU1]QSTNUM,4) = "RCMP"   |
&    find(left$([M:CQU1]QSTNUM,6),"ITUBPR","ITUITM","ITUDES") |
&    find(left$([M:CQU1]QSTNUM,6),"ITPBPR","ITPITM","ITPDES")
    mkstat = 2
    VALEUR = 1
    [M:CQU1]CTLTYP = 1
    Gosub GRISAGE_CTLTYP
  Elsif find ([M:CQU1]ASWTYP,6,7)     # FQ 50451 GA 11/2008
    mkstat = 2
    Gosub GRISAGE_CTLTYP
  Else
    Case [M:CQU1]ASWTYP
      When 2 :
        GMENLOC(3) = 1
        GMENLOC(4) = 1
      When 3 :
        GMENLOC(2) = 1
        GMENLOC(3) = 1
        GMENLOC(4) = 1
      When Default :
        GMENLOC(4) = 1
    Endcase
  Endif
Endif
End
