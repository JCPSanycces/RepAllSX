    Affzo [M:CQU1]ENDVAL
    Affzo [M:CQU1]TCT
    Affzo [M:CQU1]CODFIC
  When 5 :
    [M:CQU1]TCT    = ""
    [M:CQU1]CODFIC = ""
    [M:CQU1]CODFLD    = ""
    [M:CQU1]FLDTXT    = ""
    [M:CQU1]FILFIC    = ""
    [M:CQU1]OBJET  = ""
    [M:CQU1]SHACAT = ""
    Affzo [M:CQU1]TCT
    Affzo [M:CQU1]CODFIC
    Affzo [M:CQU1]CODFLD
    Affzo [M:CQU1]FLDTXT
    Affzo [M:CQU1]FILFIC
    Affzo [M:CQU1]SHACAT
  When 6 :                # Issue 95386 GA 01/2014 ctrl Table diverse
    [M:CQU1]ALPSTRVAL = ""
    [M:CQU1]ALPENDVAL = ""
    [M:CQU1]NUMSTRVAL = 0
    [M:CQU1]NUMENDVAL = 0
