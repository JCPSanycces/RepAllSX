Subprog AS_QUOFLG(VALEUR)
Variable Integer VALEUR
If [M:CQU1]SALTXT = ""
  VALEUR = 1
  mkstat = 2
Endif
End
###########################################################
Subprog AS_ORDFLG(VALEUR)
Variable Integer VALEUR
If [M:CQU1]SALTXT = ""
  VALEUR = 1
  mkstat = 2
Endif
End
############################################################
Subprog AV_QSTSHO(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M:CQU1]QSTAXX
Endif
End
############################################################
Subprog AS_QSTTYP(VALEUR)
Variable Integer VALEUR
If !(GREP="C" | GREP = "D")
  mkstat =2
Else
  If left$([M:CQU1]QSTNUM,5) = "NOLNK"  |
&    left$([M:CQU1]QSTNUM,6) = "FCYITF" |
&    left$([M:CQU1]QSTNUM,4) = "RCMP"   |
&    find(left$([M:CQU1]QSTNUM,6),"ITUBPR","ITUITM","ITUDES") |
&    find(left$([M:CQU1]QSTNUM,6),"ITPBPR","ITPITM","ITPDES")
    VALEUR = 2
    mkstat = 2
  Else
    Local Integer I
    For I = 3 To len(mess(0,752,1))
      GMENLOC(I) = 1
    Next I
  Endif
Endif
End
############################################################
Subprog AM_QSTTYP(VALEUR)
Variable Integer VALEUR
[M:CQU1]QSTTYP = VALEUR
Gosub GRISAGE_QSTTYP
End
############################################################
Subprog AS_ASWTYP(VALEUR)
Variable Integer VALEUR
If [M:CQU1]QSTORI <> 1
  mkstat = 2
Else
  If left$([M:CQU1]QSTNUM,5) = "NOLNK"  |
&    left$([M:CQU1]QSTNUM,6) = "FCYITF" |
&    left$([M:CQU1]QSTNUM,4) = "RCMP"   |
&    find(left$([M:CQU1]QSTNUM,6),"ITUBPR","ITUITM","ITUDES") |
&    find(left$([M:CQU1]QSTNUM,6),"ITPBPR","ITPITM","ITPDES")
    VALEUR = 1
    mkstat = 2
  Else
    If !(GREP="C" | GREP = "D")
      mkstat =2
      End
    Endif
  Endif
Endif
End
