############################################################
Subprog AS_CODNUM(VALEUR)
Variable Char    VALEUR()
If [M:CQU1]DEFVAL <> ""               |
&  [M:CQU1]QSTTYP <> 2                |
&  [M:CQU1]ASWTYP <> 1                |
&  [M:CQU1]CTLTYP <> 1                |
&  [M:CQU1]QSTORI <> 1                |
&  left$([M:CQU1]QSTNUM,5) = "NOLNK"  |
&  left$([M:CQU1]QSTNUM,6) = "FCYITF" |
&  left$([M:CQU1]QSTNUM,4) = "RCMP"   |
&  find(left$([M:CQU1]QSTNUM,6),"ITUBPR","ITUITM","ITUDES") |
&  find(left$([M:CQU1]QSTNUM,6),"ITPBPR","ITPITM","ITPDES")
  VALEUR = ""
  mkstat = 2
Endif
End
############################################################
Subprog C_CODNUM(VALEUR)
Variable Char    VALEUR()
If dim(GCFG) > 0 & VALEUR = GCFG
  mkstat = 2
Else
  If find(9,[F:ANM]POSTYP(0..[F:ANM]NBPOS-1))
    mkstat = 2
  Endif
Endif
End
############################################################
Subprog AS_HISFLG(VALEUR)
Variable Integer VALEUR
If [M:CQU1]QSTNUM = "UPDLEV" |
&  left$([M:CQU1]QSTNUM,5) = "NOLNK"  |
&  left$([M:CQU1]QSTNUM,6) = "FCYITF" |
&  left$([M:CQU1]QSTNUM,4) = "RCMP"   |
&  find(left$([M:CQU1]QSTNUM,6),"ITUBPR","ITUITM","ITUDES") |
&  find(left$([M:CQU1]QSTNUM,6),"ITPBPR","ITPITM","ITPDES")
  VALEUR = 1
  mkstat = 2
Else
  If GREP = "C"
    If[M:CQU1]QSTTYP = 1
      VALEUR = 2
    Else
      VALEUR = 1
    Endif
  Endif
Endif
End
############################################################
Subprog AS_QSTAXX(VALEUR)
Variable Char    VALEUR()
If [M:CQU1]QSTORI <> 1
  mkstat = 2
Else
  If left$([M:CQU1]QSTNUM,4) = "RCMP"
    VALEUR = mess(157,188,1)
    mkstat = 2
  Endif
  If left$([M:CQU1]QSTNUM,5) = "NOLNK"
    VALEUR = mess(143,188,1)
    mkstat = 2
  Endif
  If left$([M:CQU1]QSTNUM,6) = "FCYITF"
    VALEUR = mess(3,45,1)-"ITMFACILIT"
    mkstat = 2
  Endif
  # Issue 82300 GA 06/2012 Add new dedicated symbols
  Case left$([M:CQU1]QSTNUM,6)
    When "ITUBPR"
          VALEUR = mess(28,159,1)-mess(78,117,1)-"ITMBPC"
          mkstat = 2
    When "ITUDES"
          VALEUR = mess(28,159,1)-mess(63,154,1)-"ITMBPC"
          mkstat = 2
    When "ITUITM"
          VALEUR = mess(28,159,1)-mess(6,159,1)-"ITMBPC"
          mkstat = 2
    When "ITPBPR"
          VALEUR = mess(23,198,1)-mess(17,7,1)-"ITMBPS"
          mkstat = 2
    When "ITPDES"
          VALEUR = mess(23,198,1)-mess(63,154,1)-"ITMBPS"
          mkstat = 2
    When "ITPITM"
          VALEUR = mess(23,198,1)-mess(6,159,1)-"ITMBPS"
          mkstat = 2
  Endcase
Endif
End
############################################################
Subprog AS_QSTSHO(VALEUR)
Variable Char    VALEUR()
If [M:CQU1]QSTORI <> 1 & [M:CQU1]QSTNUM <> "DYNAMT"
  mkstat = 2
Else
  If left$([M:CQU1]QSTNUM,5) = "NOLNK"
    VALEUR = mess(144,188,1)
    mkstat = 2
  Endif
  If left$([M:CQU1]QSTNUM,6) = "FCYITF"
    VALEUR = mess(3,45,1)
    mkstat = 2
  Endif
  If left$([M:CQU1]QSTNUM,4) = "RCMP"
    VALEUR = mess(157,188,1)
    mkstat = 2
  Endif
  # Issue 82300 GA 06/2012 Add new dedicated symbols
  Case left$([M:CQU1]QSTNUM,6)
    When "ITUBPR"
          VALEUR = mess(78,117,1)-"ITU"
          mkstat = 2
    When "ITUDES"
          VALEUR = mess(63,154,1)-"ITU"
          mkstat = 2
    When "ITUITM"
          VALEUR = mess(6,159,1)-"ITU"
          mkstat = 2
    When "ITPBPR"
          VALEUR = mess(17,7,1)-"ITP"
          mkstat = 2
    When "ITPDES"
          VALEUR = mess(63,154,1)-"ITP"
          mkstat = 2
    When "ITPITM"
          VALEUR = mess(6,159,1)-"ITP"
          mkstat = 2
  Endcase
Endif
End
############################################################
Subprog AM_HISFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 1
  [M:CQU1]SEAFLG = 1
  Affzo [M:CQU1]SEAFLG
  Grizo [M:CQU1]SEAFLG
Else
  Actzo [M:CQU1]SEAFLG
Endif
End
############################################################
Subprog AS_SEAFLG(VALEUR)
Variable Integer VALEUR
# FQ 50451 GA 11/2008 If [M:CQU1]ASWTYP = 5
If find([M:CQU1]ASWTYP,5,6,7) | [M:CQU1]HISFLG = 1
  mkstat = 2
  VALEUR = 1
Endif
End
