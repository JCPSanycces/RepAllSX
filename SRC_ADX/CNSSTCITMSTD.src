#<AdxTL>@(#)3.0.0.0 $Revision$
# Gestion du masque CONSSTCITM1
#############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : Raz [M:CSTI]:Transmask [M:STI1] To [M:CSTI] # Issue 25606_Transmask [M:CSTI] = [M:STI1]
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When Default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITV]) = 0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:ACV]) = 0 : Local File ACTIV      [ACV] : Endif

#
Local Char    WFIL(250), WFILS(250), WFILSPE(250)
Local Integer WFSTAT, WREAD, WSKIP, WLIG
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I

Local Char    WCUNLISNUM(GLONVCR)   # hcb 62371
#
Gosub LOAD_SCREEN
#
NAVIG="CONSSTCITM"
SUITE  = 1
RETOUR = 1
Return

############################################################
$FIN_CRIT
[M:STI1]    = [M:CSTI]
Return

############################################################
$AP_MAGNETO
Return

############################################################
$FERME
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return

############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("STC",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:STI1]STCNUM = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:STI1]ITMREFSTR = [F:ITM]ITMREF
        Endif
      Endif
    When 4 :
      If PARAM(I) <> ""
        Call LECTURE("ITM",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:STI1]ITMREFEND = [F:ITM]ITMREF
        Endif
      Endif
  Endcase
Next I
If clalev([M:CSTI]) <> 0 & [M:CSTI]MEMO = "STD"
  [M:STI1] = [M:CSTI]
Endif
Return

############################################################
$LECTURE
#If [M:STI1]FLG = 2
#  [M:STI1]FLG = 0
#  NBLU = 0
#  Goto LECTURE_FIN
#Endif
Gosub TRT_FILTER
SUITE  = 0
RETOUR = 0
NBLU   = 1
Case CHGPAG
  When 1 :
    Raz [M:STI2]
    nolign = 1
    WPAGE  = 0
    #Raz GAGGFLG    # hcb 84951
    For [ITM]
      If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    += 1
        Else
          Break
        Endif
    Next
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    # Bug 38845 - 12/12/2006 - Début
    Effzo [M:STI2]
    # Bug 38845 - 12/12/2006 - fin
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0
    For [ITM]
        If WLIG >= WSKIP
          If nolign <= MAXLIG
            Gosub LOA_LIGNE
            NBLU    = 2
            nolign += 1
            NOL    += 1
          Else
            Break
          Endif
        Else
          WLIG += 1
        Endif
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :

    Effzo [M:STI2]
    WLIG = 0
    For [ITM]

        WLIG += 1
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [ITM]
        If WLIG >= WSKIP
          If nolign <= MAXLIG
            Gosub LOA_LIGNE
            NBLU    = 2
            nolign += 1
            NOL    -= 1
          Else
            Break
          Endif
        Else
          WLIG += 1
        Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 :
    # Bug 38845 - 12/12/2006 - Début
    Effzo [M:STI2]
    # Bug 38845 - 12/12/2006 - fin
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0
    For [ITM]
        If WLIG >= WSKIP
          If nolign <= MAXLIG
            Gosub LOA_LIGNE
            NBLU    = 2
            nolign += 1
          Else
            Break
          Endif
        Else
          WLIG += 1
        Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
Endcase
$LECTURE_FIN
Filter[F:ITM]
Return

############################################################
$TRT_FILTER
#If [M:STI1]FLG = 0
#  [M:STI1]FLG = 1
  Raz [M:STI2]
  Gosub LOAD_FILTER
  WFILSPE="1=1"
  If PROGSPE<>""
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif

  Filter [ITM] Where evalue(WFIL)
&              Order By Key ITM0

[M:STI1]NBRITM = rowcount([F:ITM])
#Endif
Return

############################################################
$LOAD_FILTER
WFIL="1=1"
# Filtre structure de couts
If [M:STI1]STCNUM <> ""
    WFIL = "[F:ITM]STCNUM=[M:STI1]STCNUM"
Endif

# Filtre article
If [M:STI1]ITMREFSTR <> "" | [M:STI1]ITMREFEND <> ""
  If [M:STI1]ITMREFSTR = [M:STI1]ITMREFEND
    WFIL += "&[F:ITM]ITMREF=[M:STI1]ITMREFSTR"
  Else
    WFIL += "&[F:ITM]ITMREF>=[M:STI1]ITMREFSTR&[F:ITM]ITMREF<=[M:STI1]ITMREFEND"
  Endif
Endif

# filtre catégorie article
If [M:STI1]TCLCODSTR <> "" | [M:STI1]TCLCODEND <> ""
  If [M:STI1]TCLCODSTR = [M:STI1]TCLCODEND
    WFIL += " & [F:ITM]TCLCOD=[M:STI1]TCLCODSTR"
  Else
    WFIL += " & [F:ITM]TCLCOD>=[M:STI1]TCLCODSTR & [F:ITM]TCLCOD<=[M:STI1]TCLCODEND"
  Endif
Endif
Return

############################################################
$LOA_LIGNE
[M:STI2] = [F:ITM]
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:STI2]DES1AXX(nolign-1), "[F:ITM]") From TRTX3 # hcb 68703

Return

############################################################
$SETBOUT
Return

############################################################
$EXEBOUT
Return

############################################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
#[M:STI1]FLG = 0
If [M]ITMREFEND = "" [M]ITMREFEND = VALEUR : Affzo [M]ITMREFEND : Endif
If [M]ITMREFEND < VALEUR [M]ITMREFEND = VALEUR : Affzo [M]ITMREFEND : Endif
End

############################################################
Subprog AM_ITMREFEND(VALEUR)
Variable Char    VALEUR()
#[M:STI1]FLG = 0
End
############################################################
Subprog AV_ITMREFEND(VALEUR)
Variable Char     VALEUR
If VALEUR = ""
  VALEUR = [M]ITMREFSTR
Endif
End


##########################################################################
#MAE, bg 57749
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"STI") From SUBGTC

End

Subprog C_ITMREFEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]ITMREFSTR
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End

Subprog AM_TCLCODSTR(VALEUR)
Variable Char    VALEUR()
If [M]TCLCODEND="" [M]TCLCODEND=VALEUR : Affzo [M]TCLCODEND : Endif
If [M]TCLCODEND < VALEUR [M]TCLCODEND = VALEUR : Affzo [M]TCLCODEND : Endif
End

Subprog C_TCLCODEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]TCLCODSTR
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End


######################################################################################

