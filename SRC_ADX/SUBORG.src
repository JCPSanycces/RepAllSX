## 24/04/12 - DKA - Refresh screen after legislation changed.
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
Call DISPLAY_HIDE() From SUBORGLEG
End

Subprog CONTORG(COD)
Variable Char    COD()

##MIPEA - 2016-10-17 - X3PEOP-907 - START
#If GFONCTION = "GESEML"
#  If clalev([F:ORG])=0 : Local File ORGANISME [ORG] : Endif
#
#  Read [ORG]ORG0 = LEG;COD
#  For I=0 To 2 : [M]MEDADD(I)=[F:ORG]ADD(I) : Next
#  [M]MEDCTY=[F:ORG]CTY
#  [M]MEDPOS=[F:ORG]POS
#  End
#Endif
##MIPEA - 2016-10-17 - X3PEOP-907 - END

If GFONCTION = "GESORG" | COD="" : End : Endif

  If clalev([F:ORG])=0 : Local File ORGANISME [ORG] : Endif

  If COD <> ""
    Filter [F:ORG] Where COD=[L]COD
    Read [F:ORG] First
    Filter [F:ORG]
    If fstat
        GMESSAGE = COD-":"-mess(23,100,1)
        mkstat = 2 : End
    Else
        #Filter [F:NAT]
        #Read [F:NAT]NAT0 = [L]COD
        Read [F:ORG]ORG0 = GCURLEG;[L]COD

        If fstat
          #Filter [F:NAT] Where COD=[L]COD
          Filter [F:ORG] Where COD=[L]COD & LEG=GCURLEG
          Read [F:ORG] First
          Filter [F:ORG]
          If [F:ORG]LEG<>""
            GMESSAGE = COD-":"-mess(62,127,1)-":"-[F:ORG]LEG
            mkstat = 2 : End
          Endif
        Endif
    Endif
  Endif
  Filter [F:ORG]

End

Subprog TUNORG(COD)
Variable Char    COD()

#JASMI - 2016-10-28 - START
#Local Integer TOKILL
#TOKILL = 0
#If dim(VCOD)<1
# Global Char VCOD(GLONORG)
# TOKILL = 1
#Endif
#
#If clalev([F:ORG])=0 : Local File ORGANISME [ORG] : Endif
#
#VCOD = COD
#
#If GNBLEG = 1
# LEG = GDOSLEG
#Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
# LEG = GCURLEG
#Elsif LEG=""
# Read [ORG]ORG0 = LEG;VCOD
# If fstat
#  Read [ORG]ORG0(2)=VCOD
#   If !fstat
#     LEG = [F:ORG]LEG
#   Endif
# Endif
#Endif
#
#
#If VCOD="" & GLECOBJ=2
#  #If no code is specified, it's better to select one of the curent legislation
#  Filter [ORG] Where LEG=[L]LEG
#  Read [F:ORG] First
#  Filter [ORG]
#  If !fstat : VCOD=[F:ORG]COD : Endif
#Else
#  Read [ORG]ORG0 = LEG;VCOD
#Endif
#
#If fstat : LEG = "" : Endif
#
#Call OBJET("ORG",GCURLEG,VCOD) From GOBJET
#
#COD = VCOD
#
#If TOKILL : Kill VCOD : Endif

Local Integer TOKILL
TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONORG)
 TOKILL = 1
Endif

If clalev([F:ORG])=0 : Local File ORGANISME [ORG] : Endif

VCOD = COD

If VCOD="" & GLECOBJ=2
  Filter [ORG] Where LEG=GCURLEG
  Read [F:ORG] First
  Filter [ORG]
  If !fstat : VCOD=[F:ORG]COD : Endif
Else
  Read [ORG]ORG0 = GCURLEG;VCOD
Endif

Call OBJET("ORG",VCOD,GCURLEG) From GOBJET

COD = VCOD

If TOKILL : Kill VCOD : Endif
#JASMI - 2016-10-28 - END

End

