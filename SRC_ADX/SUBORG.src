# saisir ENAFLG sauf pour la saisie organisme de formation ou de financement
# on l'initialise à Oui
######################################################################################
Raz GPILOBJ
Call OBJET("ORG",GBIDC1,"") From GOBJET
End

#########################################JOJAC - 2016-09-08 - X#PEOP-741 - STA
$ACTION

Case ACTION
 When "OUVRE"      : Gosub OUVRE
 #JOJAC - 2016-08-11 - X3PEOP-1047 - START
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "STYLE"      : Gosub STYLE
 #JOJAC - 2016-08-11 - X3PEOP-1047 - END
 When "LIENS"      : Gosub LIENS
 When "INIMOD"     : Gosub SAUVE_ECRAN
 When "INICRE"     : Gosub SAUVE_ECRAN
 When "FILTRE"     : Gosub FILTRE
 When "SEL_TABLE"  : Gosub SEL_TABLE
 When "FERME"      : Gosub FERME
 When "ABANDON"    : Gosub ABANDON
 When "RAZCRE"     : Gosub RAZCRE
 When "CREATION"   : Gosub CREATION
 When "MODIF"      : Gosub MODIF
 When "ANNULE"     : Gosub ANNULE
 When "AS_COD"      : Gosub AS_COD
 When "BS_COD"      : Gosub BS_COD
Endcase
Return

#Before selection on field COD
#############
$AS_COD
Raz GCURLEG
Return

#After selection on field COD
############
$BS_COD
# To do nothing if the user doesn't select a record
If [F:ORG]COD<>"" :
 mkstat=4                     # mkstat=4 to load again the record after selection
 If dim([M:ORG0]LEG)>=0 : [M:ORG0]LEG=[F:ORG]LEG: Endif
 GCURLEG=[F:ORG]LEG
 # Else we need to update GCURLEG becaude we erased it in $AS_COD
 If dim([M:ORG0]LEG)>=0
  GCURLEG=[M:ORG0]LEG
 Elsif GLEFIL<>""
  GCURLEG=GLEGFIL
 Else
  GCURLEG=GDOSLEG
 Endif
Endif
Return

########################################
$OUVRE
If clalev([F:ORG])=0 : Local File ORGANISME  [ORG] : Endif
If clalev([F:ACV])=0 : Local File ACTIV      [ACV] : Endif
If clalev([F:ORG2])=0 : Local File ORGANISME  [ORG2] : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#JOJAC - 2016-08-11 - X3PEOP-1047 - START
Call MANAGE_LOCALISATION("OORG") From DIVPAYE
#JOJAC - 2016-08-11 - X3PEOP-1047 - END

Return

#JOJAC - 2016-08-11 - X3PEOP-1047 - START
$OUVRE_BOITE

#JOJAC - 2016-09-08 - X#PEOP-741 - START
##MAPAD - TEMP AS STYLE NOT FIRING - START
#  #If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
#  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
#    If dim([M:ORG1]CRN)>0
#      Chgtzn [M:ORG1]CRN With mess(43,11662,1)
#    Endif
#    #DEHEN  2016-02-15 - Requirement TBA US xxx - START
#    #If func AFNC.ACTIV("KSZ") or func AFNC.ACTIV("KSAU") Then
#    If func DIVPAYE.IS_KSZ_LEG(GCURLEG) | func DIVPAYE.IS_KSAU_LEG(GCURLEG)
#      Actzo [M:ORG1]CRN
#    Endif
#  Endif
#  #MAPAD - TEMP AS STYLE NOT FIRING - END
Gosub STYLE
#JOJAC - 2016-09-08 - X#PEOP-741 - END

Return


#JASMI - 2015-10-30 - Req 110018 - START
########################################
$STYLE

  #If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
  #raname field
    If dim([M:ORG1]CRN)>0
      Chgtzn [M:ORG1]CRN With mess(43,11662,1)
    Endif
  Endif
  #DEHEN  2016-02-15 - Requirement TBA US xxx - START
  #If func AFNC.ACTIV("KSZ") or func AFNC.ACTIV("KSAU") Then
  If func DIVPAYE.IS_KSZ_LEG(GCURLEG) | func DIVPAYE.IS_KSAU_LEG(GCURLEG)
    Actzo [M:ORG1]CRN
  Endif

  #JOJAC - 2016-09-08 - X3PEOP-741 - START
  #If !func DIVPAYE.IS_KSZ_LEG(GCURLEG) | !func DIVPAYE.IS_KSAU_LEG(GCURLEG)
  #  Grizo [M:ORG1]CRN
 # Endif
  #JOJAC - 2016-09-08 - X3PEOP-741 - END

  #DESNY - 2017-09-20 - X3-54174 - START
  If func DIVPAYE.IS_KZM_LEG(GCURLEG)
      Chgfmt [M:ORG1]CRN With "K:20"
  Endif
  #DESNY - 2017-09-20 - X3-54174 - END

  #JOJAC - 2016-09-08 - X3PEOP-741 - START
  If !func DIVPAYE.IS_KPO_LEG(GCURLEG) | !func DIVPAYE.IS_KAO_LEG(GCURLEG)
    Chgfmt [M:ORG1]NSSCOD With "-K:20"
  Endif

  If func DIVPAYE.IS_KPO_LEG(GCURLEG) | func DIVPAYE.IS_KAO_LEG(GCURLEG)
    Chgfmt [M:ORG1]NSSCOD With "K:20"
  Endif
  #JOJAC - 2016-09-08 - X3PEOP-741 - END

  #DEHEN  2016-02-15 - Requirement TBA US xxx - END





Return
#JASMI - 2015-10-30 - Req 110018 - END
#JOJAC - 2016-08-11 - X3PEOP-1047 - END

########################################
$FILTRE
#JOJAC - 2016-08-11 - X3PEOP-1047 - START
# BRBAN 12/02/2015 #106196
# Issue 110164 - 2016-02-11 by BRBAN : Need to pass this control if KAO is active
#Local Integer ACTKPO  : [L]ACTKPO = func AFNC.ACTIV("KPO")
#Local Integer ACTKAO  : [L]ACTKAO = func AFNC.ACTIV("KAO")
#Local Integer ACTKFR  : [L]ACTKFR = func AFNC.ACTIV("KFR")
#Local Integer ACTKSA  : [L]ACTKSA = func AFNC.ACTIV("KSA")
Local Integer ACTKPO  : [L]ACTKPO = func DIVPAYE.IS_KPO_LEG(GCURLEG)
Local Integer ACTKAO  : [L]ACTKAO = func DIVPAYE.IS_KAO_LEG(GCURLEG)
Local Integer ACTKFR  : [L]ACTKFR = func DIVPAYE.IS_KFR_LEG(GCURLEG)
Local Integer ACTKSA  : [L]ACTKSA = func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)

If ([L]ACTKPO>0 & [L]ACTKAO=0 & [L]ACTKFR=0 & [L]ACTKSA=0) | ([L]ACTKPO=0 & [L]ACTKAO>0 & [L]ACTKFR=0 & [L]ACTKSA>0)
  Return
Endif
#JOJAC - 2016-08-11 - X3PEOP-1047 - END

If clalev([F:ACV])=0 : Local File ACTIV      [ACV] : Endif
#Si j'ai le module formation, je ne veux pas voir les organismes de formation ici...
Read [ACV]CODACT="FRT"
If !fstat & [F:ACV]FLACT=2
#--STA_EXI 66191 LOT 1
#SEGAY pour V6.1 Formation organisme financeur
 FILTSUP = "TYP<>1 & TYP<>6" :#<>Organisme de formation et financeur uniquement
Endif
If GPILNAV>1 & find(GNAVIG(GPILNAV-1),"GESCTR")
#JOJAC - 2016-08-11 - X3PEOP-1047 - START
#FILTRE = "TYP=2" : # Orgnaisme Intérim
 #104178
 Case GACTION
  When 'MATPCA' : FILTSUP = "TYP>2 & TYP<6" :# Caisse\Groupe de caisse\Divers
  When Default  : FILTSUP = "TYP=2"         :# Intérim
 Endcase
#JOJAC - 2016-08-11 - X3PEOP-1047 - END

Endif

# Clear the filter for Pension scheme lookup, so that the meta data configuration is used,
# otherwise FILTSUP is set to "TYP=2" which is incorrect.
If maskcou = "CTRPEN" and zoncou = "ORG"
  FILTSUP = ""
Endif

Return

########################################
$LIENS
Gosub CHARGE_ECRAN
# 24/04/12 - DKA - Show\hide fields based on legislation
GCURLEG = [F:ORG]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
Call DISPLAY_HIDE() From SUBORGLEG
Call LECTEXTRA([M]DES,"ORGANISME","DES",GCURLEG,[M]COD) From ATEXTRA
Gosub GRISE
Return

########################################
$CHARGE_ECRAN
[M:ORG1]ADD1=[F:ORG]ADD(0)
[M:ORG1]ADD2=[F:ORG]ADD(1)
[M:ORG1]ADD3=[F:ORG]ADD(2)
Return

########################################
$GRISE
#MIPEA - 2016-09-27 - X3PEOP-752 - START
If func DIVPAYE.IS_KFR_LEG(GCURLEG)
#If GCURLEG="FRA"
#MIPEA - 2016-09-27 - X3PEOP-752 - END
 If [M:ORG1]TYP=4      :#Organisme divers (Medecine du W)
  Actzo [ORG1] DEP, MEW
 Else
  Effzo [ORG1] DEP, MEW : Grizo [ORG1] DEP, MEW
 Endif
 If GPAYE
  If [M:ORG1]TYP<>3  &  [M:ORG1]TYP<>5   :#Pas une caisse ni un groupe de caisse
   Effzo [M:ORG3]   : Grizo [M:ORG3]
  Else
   Actzo [M:ORG3]5,15
   If [M:ORG3]KEYORG=1
    Effzo [M:ORG3]LIBKEYORG  : Grizo [M:ORG3]LIBKEYORG
   Else
     Actzo [M:ORG3]LIBKEYORG
   Endif
   #Case [M:ORG3]TYPIRC
    #When 1 :  Effzo [M:ORG3]25-35 : Grizo [M:ORG3]25-35 : Actzo [M:ORG3]15-20
    #When 2 :  Effzo [M:ORG3]20,30,35  : Grizo [M:ORG3]20,30,35  : Actzo [M:ORG3]15,25
    #When 3,4,5 :  Effzo [M:ORG3]20,25,35  : Grizo [M:ORG3]20,25,35  : Actzo [M:ORG3]15,30
    #When 6,7 :  Effzo [M:ORG3]20-25  : Grizo [M:ORG3]20-25  : Actzo [M:ORG3]15,30,35
    #When 8 :  Effzo [M:ORG3]20,25,35  : Grizo [M:ORG3]20,25,35  : Actzo [M:ORG3]15 : Actzo [M:ORG3]NUMDCS : Grizo [M:ORG3]TYPFRM2
    Case [M:ORG3]TYPIRC
    When 1,9,10      : Effzo [M:ORG3]25-35    : Grizo [M:ORG3]25-35    : Actzo [M:ORG3]15-20
     When 2           : Effzo [M:ORG3]20,30,35 : Grizo [M:ORG3]20,30,35 : Actzo [M:ORG3]15,25
     When 3,4,5,11,12 : Effzo [M:ORG3]20,25,35 : Grizo [M:ORG3]20,25,35 : Actzo [M:ORG3]15,30
     When 6,7         : Effzo [M:ORG3]20-25    : Grizo [M:ORG3]20-25    : Actzo [M:ORG3]15,30,35
     When 8           : Effzo [M:ORG3]20,25,35 : Grizo [M:ORG3]20,25,35 : Actzo [M:ORG3]15
     Actzo [M:ORG3]NUMDCS : Grizo [M:ORG3]TYPFRM2
   Endcase
  Endif
 Endif
Endif
Return


########################################
$SAUVE_ECRAN
[F:ORG]ADD(0)=[M:ORG1]ADD1
[F:ORG]ADD(1)=[M:ORG1]ADD2
[F:ORG]ADD(2)=[M:ORG1]ADD3
[F:ORG]ENAFLG = 2
If GCURLEG<>'FRA' : [F:ORG]TYPIRC=0 : Endif
Return


$CREATION
$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

########################################
# To manage translated texts (data type AX3 & AX1) in cretion and duplication
$TEXTRA
If GREP="D"
 ## In duplication mode we want to keep all translated texts
 Call DUPTEXTRA("ORGANISME","DES",CLECUR1,"","ORGANISME","DES",GCURLEG,[F:ORG]COD)  From ATEXTRA
Endif
Call MAJTEXTRA([M]DES,"ORGANISME","DES",GCURLEG,[F:ORG]COD) From ATEXTRA
Return

########################################
# To change translated texts (data type AX3 & AX1) when you change the main code
$AP_CHANGE
Call CHGTEXTRA("ORGANISME","DES",SUPP,[L]OCODE,SUPP,[L]NCODE) From ATEXTRA
Return


########################################
# To delete translated texts (data type AX3 & AX1)
$ANNULE
Call SUPTEXTRA("ORGANISME","DES",SUPP,[L]CODE) From ATEXTRA
Return

########################################
# Action GETORG
# pour Worklow : avoir en ligne l'organisme pour mettre son adresse dans le message
Subprog GETORG(REFNUM,SITE,IND)
Value    Char    REFNUM
Value    Char    SITE
Value    Integer IND
Local    Char    CONTRAT
If !clalev([F:ORG]) : End : Endif
Local Char VALEUR([V]GLONORG)
Gosub ORGANISME2
If [L]VALEUR=""
 Raz [F:ORG]
Else
 Read [ORG]ORG0=GCURLEG;[L]VALEUR
 If fstat : Raz [F:ORG] : Endif
Endif
End


########################################
Subprog ORGANISME (REFNUM,SITE,CONTRAT,VALEUR,IND)
Value    Char    REFNUM ()
Value    Char    SITE ()
Value    Char    CONTRAT ()
Value    Integer IND
Variable Char    VALEUR ()
Gosub ORGANISME2
End

#Need it in MATPCA source
########################################
Subprog ORGANISME_LEV (REFNUM,SITE,CONTRAT,VALEUR,IND,LEVEL)
Value    Char    REFNUM ()
Value    Char    SITE ()
Value    Char    CONTRAT ()
Value    Integer IND
Variable Char    VALEUR ()
Variable Integer LEVEL
Gosub ORGANISME2
LEVEL=[F:PCA]LEV
End

