########################################
Subprog C_KEYORG(VALEUR)
Variable Integer VALEUR
If VALEUR=1 & [M:ORG1]CRN=""
 #Type d'identification impossible - Zone Siret non renseignée
 GMESSAGE=mess(16,10714,1)
 mkstat=2 : End
Endif
End

########################################
Subprog AM_KEYORG(VALEUR)
Variable Integer    VALEUR
If VALEUR<>1 :#Siret
 Actzo [M:ORG3]LIBKEYORG
Else
 Effzo [M:ORG3]LIBKEYORG
 Grizo [M:ORG3]LIBKEYORG
Endif
End

########################################
Subprog AM_MODPAY(VALEUR)
Variable Integer  VALEUR
#MIPEA - 2016-09-27 - X3PEOP-752 - START
If func DIVPAYE.IS_KFR_LEG(GCURLEG)
  If VALEUR<>3 :#télérèglement
   Effzo [M:ORG3]BANFCY1,BANFCY2
   Grizo [M:ORG3]BANFCY1,BANFCY2
  Else
   Actzo [M:ORG3]BANFCY1,BANFCY2
  Endif
Endif
#MIPEA - 2016-09-27 - X3PEOP-752 - START
End

########################################
Subprog C_BANFCY2(VALEUR)
Variable Char    VALEUR()
#MIPEA - 2016-09-27 - X3PEOP-752 - START
If func DIVPAYE.IS_KFR_LEG(GCURLEG)
  If VALEUR=[M:ORG3]BANFCY1
   #Code banque déjà saisi
   GMESSAGE=mess(99,10703,1)
   mkstat=2 : End
  Endif
Endif
#MIPEA - 2016-09-27 - X3PEOP-752 - START
End

########################################
Subprog C_TYPIRC(VALEUR)
Variable Integer VALEUR
If VALEUR>5 & VALEUR<8 & [M:ORG1]TYP<>5
 GMESSAGE=mess(1,10702,1)  #: Valeur incorrecte
 mkstat=2 : End
Endif
If (VALEUR<6 | VALEUR=8) & [M:ORG1]TYP=5
 GMESSAGE=mess(1,10702,1)  #: Valeur incorrecte
 mkstat=2 : End
Endif
If !func AFNC.ACTIV("BTP") & VALEUR=8
 #Valeur non autorisée
 GMESSAGE=mess(100,10703,1)
 mkstat=2 : End
Endif
End


########################################
Subprog AM_TYPIRC(VALEUR)
Variable Integer VALEUR
[M:ORG3]TYPIRC=VALEUR
Gosub GRISE
End


########################################
Subprog AS_DUECOD(VALEUR)
Variable Char    VALEUR()

If [L]VALEUR>"" : End : Endif

Filter [ADI] Where NUMTAB=10561 & left$(CODE,2)=left$([M:ORG1]POS,2)
Read [ADI] First
If !fstat : [L]VALEUR=[F:ADI]CODE : Endif
Filter [ADI]

End

########################################
Subprog AS_NBRLIG
#JOJAC - 2016-08-11 - X3PEOP-1047 - START
#If [M:ORG3]TYPIRC<6 : mkstat=2 : End : Endif
If [M:ORG3]TYPIRC<6 | [M:ORG3]TYPIRC>8 : mkstat=2 : End : Endif
#JOJAC - 2016-08-11 - X3PEOP-1047 - End
End
########################################
Subprog C_GRPORG(VALEUR)
Variable Char    VALEUR()

Local Char LEG(GLONLEG)

If VALEUR=[M:ORG0]COD
 GMESSAGE=mess(1,10702,1)  #: Valeur incorrecte
 mkstat=2 : End
Endif
Call UNICITE(VALEUR,[M:ORG3]GRPORG(0..[M:ORG3]NBRLIG-1)) From OBJDIV
If mkstat=2 : End : Endif

If clalev([F:ORG2])=0 : Local File ORGANISME  [ORG2] : Endif


Read [ORG2]ORG0=GCURLEG;VALEUR
If fstat
 Filter [ORG2] Where COD=VALEUR
 Look [ORG2]ORG0 First
 Filter [ORG2]
 If !fstat
  # Fiche inexistante pour la législation courante
  GMESSAGE = VALEUR-":"-mess(14,10712,1)-"["+GCURLEG+"]"
 Else
  # Fiche inexistante
  GMESSAGE = VALEUR-":"-mess(23,100,1)
 Endif
 mkstat = 2 : End
Endif

#Il faut que cela soit une caisse de type prev ou arrco ou agirc
 #MIPEA - 2016-08-12 - X3PEOP-1047 - START
 If fstat | [F:ORG2]TYP<>3 |[F:ORG2]TYPIRC<3 | ([F:ORG2]TYPIRC>5 & [F:ORG2]TYPIRC<11)
 GMESSAGE=mess(1,10702,1)  #: Valeur incorrecte
#If !fstat & ([F:ORG2]TYP<>3 |[F:ORG2]TYPIRC<3 |[F:ORG2]TYPIRC>5)
# GMESSAGE=mess(1,10702,1)  #: Valeur incorrecte
 #MIPEA - 2016-08-12 - X3PEOP-1047 - START
 mkstat=2 : End
Endif
End

########################################
$SEL_TABLE
Case TABLE
 When "SELORG"
  OBJET="ORG"
  START="COD"
  #JOJAC - 2016-08-11 - X3PEOP-1047 - START
  #CRITERE="[F:ORG]TYP=3 & [F:ORG]TYPIRC>2 & [F:ORG]TYPIRC<6"
  # Prev, Arrco, AGIRC + Conges spectacle, IRCANTEC
  CRITERE="[F:ORG]TYP=3 & ( ([F:ORG]TYPIRC>2 & [F:ORG]TYPIRC<6) | [F:ORG]TYPIRC>10) & [F:ORG]LEG='"+GCURLEG+"'"
  #JOJAC - 2016-08-11 - X3PEOP-1047 - END
  ORDRE = "COD"
  When "SELORGNAT"
  OBJET="ORG"
  START="COD"
  CRITERE="([F:ORG]TYP=3 | [F:ORG]TYP=5 )& [F:ORG]TYPIRC="+PARAM(1)
  ORDRE = "COD"
Endcase
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif

If dim(VCOD)<1 : Global Char VCOD(GLONORG) : Endif
VCOD = CLE1

Return

$ABANDON
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$RAZCRE
# 26/04/12 - DKA - Clear fields until FRA legislation selected
GCURLEG = ""
Call DISPLAY_HIDE() From SUBORGLEG
Return

