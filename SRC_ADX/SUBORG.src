########################################
Subprog AS_TYP(VALEUR)
Variable Integer VALEUR

If clalev([F:ACV])=0 : Local File ACTIV    [ACV]         : Endif
#Si j'ai le module formation, je ne veux pas voir les organismes de formation + financeur ici...
Read [ACV]CODACT="FRT"
If !fstat & [F:ACV]FLACT=2
 GMENLOC(1)=1
# SEGAY - 19/07/10 - EXI 66191 LOT P24 LOT 1
 GMENLOC(6)=1
Endif

End

########################################
Subprog AM_TYP(VALEUR)
Variable Integer    VALEUR
#60442
If GPAYE
#JOJAC - 2016-08-11 - X3PEOP-1047 - START
  #If func AFNC.ACTIV("KFR")
  If func DIVPAYE.IS_KFR_LEG(GCURLEG)
#JOJAC - 2016-08-11 - X3PEOP-1047 - END
   Case VALEUR
    When 3 : [M:ORG3]TYPIRC=1
    When 5 : [M:ORG3]TYPIRC=6
    When Default : [M:ORG3]TYPASS=0 : [M:ORG3]TYPIRC=0
   Endcase
  #JOJAC - 2016-08-11 - X3PEOP-1047 - START
  Endif
  #JOJAC - 2016-08-11 - X3PEOP-1047 - END
Endif
[M:ORG1]TYP=VALEUR
Gosub GRISE
End

########################################
Subprog AM_MEW(VALEUR)
Variable Char    VALEUR()

Call LECTURE("MEW",[L]VALEUR,[M:ORG1]DEP) From CONTOBJ
[M:ORG1]=[F:MEW]
[M:ORG1]ADD1=[F:MEW]ADD(0)
[M:ORG1]ADD2=[F:MEW]ADD(1)
[M:ORG1]ADD3=[F:MEW]ADD(2)
Affzo [ORG1] 5-15 : # Adresse

End

