# Endif
#Endif
#
#If VALEUR="" & [L]REFNUM<>"" : # Recherche au niveau population
# If !clalev([F:HRPOA]) : Local File POPULA [HRPOA] : Endif
# Link [HRPOA] With [PCA]PCA0~=2;GCURLEG;COD;"";"";"";""
#&             As [CAK]
#&          Where REFNUM=[L]REFNUM & COD>"" & [F:PCA]ORG([L]IND)>""
# Read [CAK]POA1 First
# If !fstat
#  VALEUR = [F:PCA]ORG([L]IND)
# Else
#  Read [PCA]PCA0=2;GCURLEG;[L]REFNUM;"";"";"";""
#  If !fstat
#   VALEUR = [F:PCA]ORG([L]IND)
#  Endif
# Endif
#Endif
#
#If VALEUR=""
# ## Recherche au niveau Dossier
# Read[PCA]PCA0=1;GCURLEG;"";"";"";"";""
# If !fstat
#  VALEUR = [F:PCA]ORG(IND)
# Endif
#Endif
#Return

###############################################################################
#
# Removed the GCURLEG for all the index read expect the level 1 : Legislation
#
###############################################################################
$ORGANISME2
If clalev([F:PCA])=0  : Local File CAISSE   [PCA]   : Endif
If clalev([F:FCYO])=0 : Local File FACILITY [FCYO]  : Endif :# 109449 US3829 P21US2 abréviation FCY peut-être utilisé en amont
If !clalev([F:HRPOAO])  : Local File POPULA   [HRPOAO]  : Endif :# 109449 US3829 P21US2 abréviation POA peut-être utilisée en amont
VALEUR = ""

 If IND>dim([F:PCA]ORG)-1
  VALEUR=""
  IND=0
  Return
 Endif

## Recherche au niveau contrat
If CONTRAT<>""
 Read[PCA]PCA0=6;"";"";"";"";"";CONTRAT
 If !fstat
  VALEUR = [F:PCA]ORG(IND)
 Endif
Endif
## Recherche au niveau Salarié
If VALEUR="" & [L]REFNUM<>""
 Read[PCA]PCA0=5;"";"";"";"";REFNUM;""
 If !fstat
  VALEUR = [F:PCA]ORG(IND)
 Endif
Endif
## Recherche au niveau Site ou Société
If VALEUR="" & SITE<>""
 If find(SITE,GSOC(1..GNBSOC)) : # C'est une société
  Read[PCA]PCA0=3;"";"";SITE;"";"";""
  If !fstat
   VALEUR = [F:PCA]ORG(IND)
  Endif
 Else : # C'est un site
  Read[PCA]PCA0=4;"";"";"";SITE;"";""
  If !fstat
   VALEUR = [F:PCA]ORG(IND)
  Endif
  If VALEUR=""
    Read[FCYO]FCY0=SITE
    If !fstat
     Read[PCA]PCA0=3;"";"";[F:FCYO]LEGCPY;"";"";""
     If !fstat
      VALEUR = [F:PCA]ORG(IND)
     Endif
    Endif
  Endif
 Endif
Endif

# Recherche au niveau population contrat 122019 X3-28708
If VALEUR="" & [L]CONTRAT<>""& [L]REFNUM<>"" : # Recherche au niveau population contrat 122019 X3-28708
 If !clalev([F:HRPOAO]) : Local File POPULA [HRPOAO] : Endif
 Link [HRPOAO] With [PCA]PCA0~=2;"";COD;"";"";"";""
&             As [CAK]
&          Where REFNUM=[L]REFNUM & CTRNUM=[L]CONTRAT & COD>"" & [F:PCA]ORG([L]IND)>""
 Read [CAK]POA1 First
 If !fstat
  VALEUR = [F:PCA]ORG([L]IND)
 Endif
Endif

If VALEUR="" & [L]REFNUM<>"" : # Recherche au niveau population
 If !clalev([F:HRPOAO]) : Local File POPULA [HRPOAO] : Endif :# 109449 US3829 P21US2 abréviation POA peut-être utilisée en amont
 Link [HRPOAO] With [PCA]PCA0~=2;"";COD;"";"";"";""
&             As [CAK]
&          Where REFNUM=[L]REFNUM & COD>"" & [F:PCA]ORG([L]IND)>""
 Read [CAK]POA1 First
 If !fstat
  VALEUR = [F:PCA]ORG([L]IND)
 Else
  Read [PCA]PCA0=2;"";"";"";"";[L]REFNUM;""
  If !fstat
   VALEUR = [F:PCA]ORG([L]IND)
  Endif
 Endif
Endif

#X3_23133 : Recherche au niveau Population/Site sans infos salarié
If VALEUR="" & SITE<>"" & [L]REFNUM=""
 If !clalev([F:HRPOAO]) : Local File POPULA [HRPOAO] : Endif
 If !clalev([F:HRCTRAO]): Local File EMPLOCTR  [HRCTRAO] : Endif
 If !clalev([F:IDAO]) : Local File EMPLOID   [IDAO]  : Endif

  ## Recherche au niveau Population  sans infos salarié
 Link [HRPOAO] With [PCA]PCA0~=2;"";COD;"";"";"";"",
&  [HRCTRAO]CTR0 = [F:HRPOAO]REFNUM;[F:HRPOAO]CTRNUM;[F:HRPOAO]CTRDAT,
&  [IDAO]ID0 = [F:HRCTRAO]REFNUM
&             As [CAK]
&      Where COD>"" & [F:PCA]ORG([L]IND)>"" & [F:HRCTRAO]ETRFCY=SITE
 Columns [CAK]([F:HRCTRAO]REFNUM,[F:HRPOAO]REFNUM,[F:HRPOAO]CTRNUM,[F:HRPOAO]CTRDAT
&             ,[IDAO],[HRCTRAO],[PCA])

 Read [CAK]POA1 First
 If !fstat
   VALEUR = [F:PCA]ORG([L]IND)
 Endif
 Columns [CAK]
Endif

If VALEUR=""
 ## Recherche au niveau Dossier
 Read[PCA]PCA0=1;GCURLEG;"";"";"";"";""
 If !fstat
  VALEUR = [F:PCA]ORG(IND)
 Endif
Endif
Return
#LIPET - 2018-08-03 - X3-103478 - END
########################################
# Création d'une caisse pour un contrat.
# Sous prog appelable à partir d'une transaction
Subprog CRE_CAISSE(CONTRAT,VALEUR,IND)
Value Char    CONTRAT
Value Char    VALEUR
Value Integer IND
If clalev([F:PCA])=0 : Local File CAISSE   [PCA] : Endif
If CONTRAT<>""
#LIPET - 2018-08-03 - X3-103478 - START
 #Read[PCA]PCA0=6;GCURLEG;"";"";"";"";CONTRAT
 Read[PCA]PCA0=6;"";"";"";"";"";CONTRAT
#LIPET - 2018-08-03 - X3-103478 - END
 If !fstat
  [F:PCA]ORG(IND) = VALEUR
  [F:PCA]UPDDAT   = date$
  [F:PCA]UPDUSR   = GUSER
  [F:PCA]UPDTIM   = time
  [F:PCA]EXPNUM   = [C]EXPORT
  Rewrite [PCA]
  If fstat : Call FSTA("PCA") From GLOCK : GOK=0 : Endif
 Else
  Raz [F:PCA]
  [F:PCA]LEV      = 6
  [F:PCA]LEG      = GCURLEG
  [F:PCA]CTR      = CONTRAT
  [F:PCA]ORG(IND) = VALEUR
  [F:PCA]CREDAT   = date$
  [F:PCA]CREUSR   = GUSER
  [F:PCA]CRETIM   = time
  [F:PCA]EXPNUM   = [C]EXPORT
  Write [PCA]
  If fstat : Call FSTA("PCA") From GLOCK : GOK=0 : Endif
 Endif
Endif
End


