$INIT_SEX
Gosub DECLARE_VAR From WMC0ESSWRKEMP
[L]CURPRO = "SEX"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.SEX=0 and fmet this.AGETATTRIBUTE("SEX","$isMandatory")="true"
 this.SEX = 1
Endif
Return
 
$CONTROL_SEX
Gosub DECLARE_VAR From WMC0ESSWRKEMP
[L]CURPRO = "SEX"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_SEX                   : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_SEX                   : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_SEX
[L]CURPRO = "SEX"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.SEX=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_SEX
[L]CURPRO = "SEX"
If this.SEX<0 or this.SEX>len(mess(0,314,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"314 ->"-num$(this.SEX)-mess(99,123,1)):  Return : # Local menu "314 -> Invalid option
Endif
Return

$_AOTHERS_SEX
[L]CURPRO = "SEX"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_SEX
[L]CURPRO = "SEX"
Return

