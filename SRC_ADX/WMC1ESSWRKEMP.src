#<AdxTL>@(#)0.0.0.0 $Revision$Class Employee
# Supervisor
## ACLA-CLASSE ## ESSWRKEMP
# 2018-10-23 06:53:20 706


####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 1 : REFNUM Employee ID ( Field EML 15)
####################################################################

$SET_REFNUM
If [L]_AOLDVAL<>this.REFNUM
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_REFNUM
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.REFNUM
 Gosub PROPAGATE_REFNUM
Endif
Return

$INIT_REFNUM
Gosub DECLARE_VAR From WMC0ESSWRKEMP
[L]CURPRO = "REFNUM"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_REFNUM
Gosub DECLARE_VAR From WMC0ESSWRKEMP
[L]CURPRO = "REFNUM"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_REFNUM                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_REFNUM                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_REFNUM
[L]CURPRO = "REFNUM"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.REFNUM,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_REFNUM
[L]CURPRO = "REFNUM"
If vireblc(this.REFNUM,2)<>vireblc(format$("K:15c",this.REFNUM),2)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(149,100,1)) :  Return : # Incorrect Format
Endif
Return

$_AOTHERS_REFNUM
[L]CURPRO = "REFNUM"
If vireblc(this.REFNUM,2)<>""
 If fmet this.AGETATTRIBUTE([L]CURPRO,"$namProParent")=""
  [L]ASTATUS =  func WMTYPEML.ACTRLREF(this,"REFNUM",this.REFNUM,this.REFNUM,2,"")
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Else
  If this.REFNUM<>evalue("this.APARENT."+fmet this.AGETATTRIBUTE([L]CURPRO,"$namProParent"))
   [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(83,123,1)) :  Return : # Invalid value
  Endif
 Endif
Endif
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_REFNUM
[L]CURPRO = "REFNUM"
Return

$PROPAGATE_REFNUM
this.isReadonly = 0
[L]CURPRO = "REFNUM"
Gosub _LNKPRO_REFNUM
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_REFNUM
Gosub DECLARE_VAR From WMC0ESSWRKEMP
[L]CURPRO = "REFNUM"
$_LNKPRO_REFNUM
If vireblc(this.REFNUM,2)<>""
 # Link EMPLOID
 Local File EMPLOID [WID]
 Read [F:WID]ID0 = this.REFNUM
 If !fstat
  [L]ASTATUS = fmet this.ASETATTRIBUTE("REFNUM","$description",[F:WID]NAM)
 Endif
 LogicClose File [WID]
Endif
Return

$_ALOADATTRIBUTE_REFNUM
[L]ASTATUS = fmet this.ASETATTRIBUTE("REFNUM","$isMandatory","true")
Return


