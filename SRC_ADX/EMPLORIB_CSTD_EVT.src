#<AdxTL>@(#)0.0.0.0 $Revision$ 
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AINIT"                      : Gosub AINIT
      When "AINSERT_CONTROL_BEFORE"     : Gosub AINSERT_CONTROL_BEFORE
      When "AUPDATE_CONTROL_BEFORE"     : Gosub AUPDATE_CONTROL_BEFORE
    Endcase
Endcase
Return


$AINIT
#Gosub SET_LIGNUM

Return

$AINSERT_CONTROL_BEFORE
$AUPDATE_CONTROL_BEFORE
#Set correct value for CPYBAN
###Call DEBUG_TRACE(1, "ESS", "EMPLORIB $AUPDATE_CONTROL_BEFORE") From DEBUGTRACE
#If this.TCH_BANCAI="CAI"
#  this.CPYBAN = this.CPYBANCAI
#Endif

#Set the line number
Gosub SET_LIGNUM

###Call DEBUG_TRACE(1, "ESS", "EMPLORIB AFTER SET_LIGNUM") From DEBUGTRACE

Return



$SET_LIGNUM

###Call DEBUG_TRACE(1, "ESS", "EMPLORIB this.NUMLIG: " + num$(this.NUMLIG)) From DEBUGTRACE

If this.NUMLIG <> 0 : Return: Endif

Local Integer MAXLIGNUM
Local File EMPLORIB [RIB2]
Filter [F:RIB2] Where REFNUM = this.REFNUM
For [F:RIB2]RIB0
  If [F:RIB2]NUMLIG > MAXLIGNUM
    MAXLIGNUM = [F:RIB2]NUMLIG
  Endif
Next
###Call DEBUG_TRACE(1, "ESS", "EMPLORIB v: " + num$(this.NUMLIG)) From DEBUGTRACE

MAXLIGNUM+=1
this.NUMLIG = MAXLIGNUM
LogicClose File [RIB2]
Return





