#<AdxTL>@(#)9.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Local Mask APATCH [DIA]
Call TRAITE_CHAR(VALEUR,PARAM,"","APATCHR","APATCHR",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "EXEC"     : Gosub EXEC
 When "INIT_DIA" : Gosub INIT_DIA
 When "CONTROLE" : Gosub CONTROLE
Endcase
Return

$INIT_DIA
If clalev([M:DIA])>0
 [M] = [M:DIA]
Endif
If [M]FICPATCH="" & GFICPATH<>""
 [M]FICPATCH = GFICPATH
Endif

Affzo [M]VOLFIL , TYPEXP
If TYPEXP=1
 Grizo [M]VOLFIL
Else
 Actzo [M]VOLFIL
Endif
Return

$CONTROLE
If clalev([M:DIA])=0 : FIN = 1 : Return : Endif
Return

$EXEC
Local Char    FICORG(GDIMFIC) , FICHIER(GDIMFIC) , URL(10)
Local Integer STAT , TYPFIC
FICORG = [M]FICPATCH
TYPFIC = [M]TYPEXP
If [M]TYPEXP=1
 Call SET_FICNAM(FICORG,FICHIER,URL) From ORDSYS
 Call COPSRV(FICORG,FICHIER,STAT) From ORDSYS
 If STAT : Return : Endif
Else
 Call EXISTE(FICORG,STAT) From ORDSYS
 If STAT<>1 : Return : Endif
 FICHIER = FICORG
Endif
Default Mask [DIA]
[M]FICPATCH = FICHIER
Gosub CHARGE From APATCH
[M]TYPEXP= [APR]TYPEXP
If [M]TYPEXP=1 :#Client #VVVVV
 Raz [M]VOLFIL
 Raz [M]FICPATCH
Else
 [M]VOLFIL= [APR]VOLFIL
Endif
Affzo [M]VOLFIL , TYPEXP
Return

######################################################################################
## Etiquettes du masque APATCHR
######################################################################################

Subprog AS_TYPEXP(VALEUR)
Variable Integer VALEUR
Call AM_TYPEXP(VALEUR)
End

Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
Call C_TYPEXP(VALEUR) From APATCH
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Diszo [M]VOLFIL
Else
 Actzo [M]VOLFIL
Endif
End


Subprog C_FICHIER(VALEUR)
Variable Char    VALEUR()
GFICPATH = VALEUR
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran APATCHR) 23/09/2013 13:24:15 (ERB)
######################################################################################
Subprog IB_FICPATCH
If [M]TYPEXP=1
 GBOUTS = ""
Endif
End

######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran APATCHR) 23/09/2013 13:25:58 (ERB)
######################################################################################
Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP, VALEUR,[M]FICPATCH,E_TYPE_FILEREAD,GMESSAGE)
End


######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran APATCHR) 17/10/2013 09:56:42 (ERB)
######################################################################################
Subprog AS_VOLFIL(VALEUR)
Variable Char    VALEUR()
End


