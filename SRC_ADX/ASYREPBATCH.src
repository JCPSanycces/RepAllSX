#<AdxTL>@(#)1.0.0.0 $Revision$
# Batch request execution

$EXECREQ
Onerrgo ERREUR

# Only for log generation in debug mode
Local Integer IF_TRACE
Local Char FIC_TRACE(100)

# Set to 1 if log is requested, and set the logfile name
  IF_TRACE=0
  FIC_TRACE="/home/dbopp/batch.test"

  If IF_TRACE
    Openo FIC_TRACE,0 Using [THR]
    Wrseq format$("D:YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss",date$) Using [THR]
    Wrseq "" Using [THR]
    Openo Using [THR]
  Endif

# Parameter linked to batch tasks
Local  Char    FICTRA(250)
Local  Integer NUMREQ, I
Local Char PROGNAME(20)
Local Integer ERR

# Parameter for execution
Local Char VALBEG(250)(1..100),VALEND(250)(1..100)
Local Libelle STRICTBEG(1..100),STRICTEND(1..100)
Local Char REQUID(36),UUIREQ(36)
Local Integer OK, LIMITS(1..2),NBLIG(1..20)
Local Libelle FORCED_EXEC

  #109897
  #[L]NUMREQ = val(getenv$("RQT_ENTREP"))
  [L]NUMREQ = val(GBATCHRQT)

  If IF_TRACE

    Openo FIC_TRACE Using [THR]
    Wrseq "NUMREQ="+num$(NUMREQ) Using [THR]
    Openo Using [THR]
  Endif

#Local File ABATRQT [ABR] , ABATPAR [ABP], ABATRQTL [ABL]
Local File ABATRQT [ABR] , ABATRQTL [ABL]

#  Read [ABP]SPOOL First
  FICTRA = func SERVSYS.GET_FILE_SERVEUR("tra") : #109897 # Issue X3-70499 - 2018-03-05 by CCC : whole path => with extension file

##  Let's read the request
  Read [ABR]NUMREQ = [L]NUMREQ

# Wait until the flag in progress has been set
  Raz I
  While !fstat & [F:ABR]FLAG<>2 :  I += 1 :  If I>20 : Break : Endif
    Read [ABR]NUMREQ = [L]NUMREQ :  Sleep 2
  Wend
  If fstat
    GOK = 2 : End
  Endif

  If IF_TRACE
    ZZZ=fstat : Openo FIC_TRACE Using [THR]
    Wrseq "fstat after update ABR="+num$(ZZZ) Using [THR]
    Openo Using [THR]
  Endif

# Define the program and check if it exists
  Read [ABL]NUMREQ=[L]NUMREQ;1;"TRTNAM"
  PROGNAME=[ABL]VALEUR

  If IF_TRACE
    ZZZ=fstat : Openo FIC_TRACE Using [THR]
    Wrseq "fstat after read PROGNAME="+num$(ZZZ) Using [THR]
    Openo Using [THR]
  Endif

  If fstat<>0
    GOK=3 : End
  Endif

  If IF_TRACE
    Openo FIC_TRACE Using [THR]
    Wrseq "PROGNAME="+PROGNAME Using [THR]
    Openo Using [THR]
  Endif

# Get the UUIREC if it exists
  Read [ABL]NUMREQ(2)=[L]NUMREQ;2
  If left$([ABL]PARAM,7)="UUIREQ "
    UUIREQ=right$([ABL]PARAM,8)+[ABL]VALEUR
  Endif

  If IF_TRACE
    ZZZ=fstat : Openo FIC_TRACE Using [THR]
    Wrseq "fstat after read NUMREQ="+num$(ZZZ) Using [THR]
    Openo Using [THR]
  Endif

  If filinfo(filpath('TRT',PROGNAME,"adx"),7)<=0
     If IF_TRACE
       Openo FIC_TRACE Using [THR]
       Wrseq PROGNAME-"not found" Using [THR]
       Openo Using [THR]
     Endif
     GOK=3 : End
  Endif

# Let's Force the additional parameters
  FORCED_EXEC = 1
  LIMITS(1) = 0
  LIMITS(2) = 0
  REQUID = ""

# Let's find the execution parameter of the request
  I=evalue("func"-PROGNAME+".RD_CRIT(STRICTBEG,STRICTEND,VALBEG,VALEND,UUIREQ)")

  If IF_TRACE
    Openo FIC_TRACE Using [THR]
    For ZZ=1 To 5
      Wrseq "Beg: "+format$("N:5#",STRICTBEG(ZZ))+VALBEG(ZZ) Using [THR]
      Wrseq "End: "+format$("N:5#",STRICTEND(ZZ))+VALEND(ZZ) Using [THR]
    Next ZZ
    Wrseq "UUIREQ="+UUIREQ Using [THR]
    Openo Using [THR]
  Endif

# Nom let's execute the request with the right parameters
  Call EXEC_RQT(GACTX,VALBEG,VALEND,STRICTBEG,STRICTEND,LIMITS,NBLIG,REQUID,UUIREQ) From =PROGNAME
End

$ERREUR
Local Char CHERR(200)

  If IF_TRACE
    CHERR="Erreur"-num$(errn)-errmes$(errn)-"line"-num$(errl)
    Openo FIC_TRACE Using [THR]
    Wrseq CHERR Using [THR]
    Openo Using [THR]
  Endif
End

