#<AdxTL>@(#)5.0.0.0 $Revision$
###############################################################
## SUBAMK6    Blocs bureautique compléments
###############################################################

$ACTION
Case ACTION
  When "OUVRE"       : Gosub OUVRE
  When "DEBUT"       : Gosub DEBUT
  When "SETBOUT"     : Gosub SETBOUT
  When "FIN"         : Gosub FIN
  When "OK"          : Gosub OK
  When "ABANDON"     : Gosub ABANDON
  When "APRES_MODIF" : Gosub APMODIF
Endcase
Return


$APMODIF
  REP="M"
Return

$OUVRE
If zoncou="TYPBLOC" 
  If VALEUR<>7 : FIN=1 : Endif
Else
  If [M:AMK1]TYPBLOC(val(PARAM(1)))<>7 : FIN=1 : Endif
Endif
Return

$DEBUT
[M:AMK6]NOLTBL=val(PARAM(1))
$RECHARG
Local Integer NLI : NLI=[M:AMK6]NOLTBL
# Charge les champs stockés dans AMK1
[M:AMK6]TYPOFF=[M:AMK1]BLOCTYPG(NLI)
Affzo [M:AMK6]
Return



$OK
#   On recharge les valeurs dans AMK1
Local Integer NLI : NLI=[M:AMK6]NOLTBL
[M:AMK1]BLOCTYPG(NLI)=[M:AMK6]TYPOFF
If REP="M" : mkstat=4 : Endif
Return


$SETBOUT
Return

$ABANDON
REP=""
Gosub RECHARG
Return

$FIN
  REP=""
Return
