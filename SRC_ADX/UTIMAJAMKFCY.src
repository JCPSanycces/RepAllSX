#<AdxTL>@(#)2.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Invalidation des écrans FCY2 et FCY4
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Screens FCY2 and FCY4") From LECFIC
Local File ADOSSIER [ADS2]
Local File ADOSSIER [ADS]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER

  Local File ADOSSIER [ADS]
  Read [F:ADS]DOSSIER=DOSSIER
  Gosub FCYINVALID
End

#-------------------#
$FCYINVALID
#CHECK IGNORE_BEGIN
Local Integer OK

  # ------------------------------
  Local File =DOSSIER+".AMSK" [WAMK]
  # ------------------------------
  For [WAMK] Where find(CODMSK,"FCY2","FCY4")<>0
      Call ECR_TRACE(mess(2,9043,1) - "CODMSK :" - [F:WAMK]CODMSK - "at" - time$,0) From GESECRAN
      Call VALID([F:WAMK]CODMSK, DOSSIER, [F:ADS]NBRLAN, [F:ADS]LAN, 1, OK) From VALMSK
  Next
  Filter [WAMK]
  Close Local File [WAMK]
  #CHECK IGNORE_END
Return

