#<AdxTL>@(#)0.0.0.0 $Revision$Class Process launch
# Supervisor
## ACLA-CLASSE ## EDIRUN
# 2018-10-17 07:54:24 579

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0EDIRUN
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_NUM From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub INIT_RUNDES From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub INIT_LASRUNDAT From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub INIT_PARCOD From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub INIT_PARDES From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub INIT_PARTYP From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub INIT_CATCOD From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub INIT_CATDES From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub INIT_CATTYP From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub INIT_CATOPE From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub INIT_CATACT From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub INIT_ALLFLO From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub INIT_FLOCOD From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub INIT_FLOREL From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub INIT_FLODES From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub INIT_DUPLICATEFLG From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub INIT_TESTFLG From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub INIT_DIRECTFLG From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub INIT_PROBATCH From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub AINIT From WMC0EDIRUN : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EDIRUN
Gosub _ALOADATTRIBUTE_PARCOD From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_PARTYP From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_CATCOD From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_CATTYP From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_CATACT From WMC1EDIRUN : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EDIRUN
Gosub LNKPRO_PARCOD From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub LNKPRO_CATCOD From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub LNKPRO_FLOCOD From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub LNKPRO_FLOREL From WMC1EDIRUN : Gosub TESTALLSTAT
For AINDCLA=1 To maxtab(this.EDRD)
 If this.EDRD(AINDCLA)<>null& find(this.EDRD(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.EDRD(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
Gosub LNKPRO_CREUSR From WMC1EDIRUN : Gosub TESTALLSTAT
Gosub LNKPRO_UPDUSR From WMC1EDIRUN : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



