#<AdxTL>@(#)9.0.0.0 $Revision$
Call OBJET("CDS",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE # Réalisé une fois à l'ouverture de la fonction
 When "RAZCRE"   : Gosub RAZCRE # Lorsqu'on va créer une nouvelle fiche
 When "LIENS"    : Gosub LIENS # Après la lecture d'une fiche, pour lire des informations liées
 When "CREATION" : Gosub CREATION # Durant la transaction de création (fiche déjà créée sans erreur)
 When default
Endcase
Return

$CREATION
Return

$OUVRE
 Grizo DSPORI1, DSPORI2
Return

$RAZCRE
Call GRISER([M]TYPSCT, [M]DSPORI1, [M]DSPORI2, [M]DSPTYP)
Return

$LIENS
Call GRISER([M]TYPSCT, [M]DSPORI1, [M]DSPORI2, [M]DSPTYP)
# correction bug 25617 : suppression de code inutile
Affzo DSPSCT, DES, DESSHO, ACS, VLYSTR, VLYEND, ACC, DSPPRC, DSPORI1, DSPORI2, DSPTYP, SCTDEN1, SCTDEN2, COE, DSPACC
Return

########################################
# réalise le grisage des champs et des blocs en fonction des valeurs de TYPSCT et DSPTYP
Subprog GRISER(TYPSCT, DSPORI1, DSPORI2, DSPTYP)
Value Integer TYPSCT   # FGR 01/02/2010 : X3SUIVI60986
Variable    Char    DSPORI1()
Variable    Char    DSPORI2()
Variable    Integer DSPTYP
If DSPTYP = 1
 # griser zone 7
 Raz DSPACC
 Grizo DSPACC
 Actzo COE, NBLIG
 If TYPSCT=1
  Actzo DSPORI1, SCTDEN1
  Raz DSPORI2, SCTDEN2
  Grizo DSPORI2, SCTDEN2
 Elsif TYPSCT=2 Then
  Actzo DSPORI2, SCTDEN2
  Raz SCTDEN1
  Grizo DSPORI1, SCTDEN1
 Else
  Actzo DSPORI1, DSPORI2
 Endif
Else
 # griser zone 6
 Raz SCTDEN1, SCTDEN2, COE, NBLIG
 Grizo SCTDEN1, SCTDEN2, COE, NBLIG
 Actzo DSPACC
 If TYPSCT=1
  Actzo DSPORI1
  Raz DSPORI2
  Grizo DSPORI2
 Elsif TYPSCT=2 Then
  Actzo DSPORI2
  Raz DSPORI1
  Grizo DSPORI1
 Else # DSPORI1 = "" AND DSPORI2 = ""
  Actzo DSPORI1, DSPORI2
 Endif
# correction bug 27961
  [M]NBLIG=0
  Affzo [M]
# fin correction bug 27961
Endif
End

########################################
# réalise le grisage des champs et des blocs en fonction des valeurs de DSPORI1, DSPORI2 et DSPTYP
Subprog GRISER2(DSPORI1, DSPORI2, DSPTYP)
Variable    Char    DSPORI1()
Variable    Char    DSPORI2()
Variable    Integer DSPTYP
If DSPTYP = 1
 # griser zone 7
 Raz DSPACC
 Grizo DSPACC
 Actzo COE, NBLIG
 If DSPORI1 <> ""
  Actzo DSPORI1, SCTDEN1
  Raz DSPORI2, SCTDEN2
  Grizo DSPORI2, SCTDEN2
 Elsif DSPORI2 <> "" Then
  Actzo DSPORI2, SCTDEN2
  Raz SCTDEN1
  Grizo DSPORI1, SCTDEN1
 Else
  Actzo DSPORI1, DSPORI2
 Endif
Else
 # griser zone 6
 Raz SCTDEN1, SCTDEN2, COE, NBLIG
 Grizo SCTDEN1, SCTDEN2, COE, NBLIG
 Actzo DSPACC
 If DSPORI1 <> ""
  Actzo DSPORI1
  Raz DSPORI2
  Grizo DSPORI2
 Elsif DSPORI2 <> "" Then
  Actzo DSPORI2
  Raz DSPORI1
  Grizo DSPORI1
 Else # DSPORI1 = "" AND DSPORI2 = ""
  Actzo DSPORI1, DSPORI2
 Endif
Endif
End

Subprog VERIFIER_SAISIE(VALEUR, OK)
Variable Char    VALEUR()
Variable Integer OK
 VALEUR = toupper(VALEUR)
 OK=1
 For N=1 To len(VALEUR)
  C = mid$(VALEUR, N, 1)
  If (C<"A" or C>"Z") and (C<"0" or C>"9") AND C<>"*" and C<>" "
   OK=0
   Break
  Endif
 Next
End

########################################
Subprog AP_DSPORI1(VALEUR)
Variable Char    VALEUR()
Local Integer    OK
Call VERIFIER_SAISIE(VALEUR, OK)
If OK=0
 mkstat = 2
Else
 Call GRISER([M]TYPSCT, VALEUR, [M]DSPORI2, [M]DSPTYP)
 Call TEST(VALEUR, 1)
Endif
End

########################################
Subprog AP_DSPORI2(VALEUR)
Variable Char    VALEUR()
Local Integer    OK
Call VERIFIER_SAISIE(VALEUR, OK)
If OK=0
 mkstat = 2
Else
 Call GRISER([M]TYPSCT, [M]DSPORI1, VALEUR, [M]DSPTYP)
 Call TEST(VALEUR, 2)
Endif
End

########################################
Subprog AM_DSPPRC(VALEUR)
Variable Decimal VALEUR
If VALEUR < 0 or VALEUR > 100
mkstat=1
Endif
End

########################################
Subprog AP_COE(VALEUR)
Variable Decimal VALEUR
If VALEUR < 0 or VALEUR > 100
mkstat=1
Endif
End

########################################
Subprog AP_DSPTYP(VALEUR)
Variable Integer VALEUR
Call GRISER([M]TYPSCT, [M]DSPORI1, [M]DSPORI2, VALEUR)
End

########################################
Subprog AP_ACC(VALEUR)
Variable Char VALEUR
Local Integer OK
Local Char    MESSA(80)
Call C_BASCALC(VALEUR,MESSA,OK)
If !OK
 GMESSAGE = MESSA
 mkstat=2
Endif
End

########################################
Subprog C_BASCALC(VALEUR,MESSA,OK)
Variable Char    VALEUR()
Variable Char    MESSA()
Variable Integer OK
Local Char    CHAINE(80), COMPTE(80), SCOMPTE(80), CPT(80)
Local Char    TCOLL(80)(1..10)
Local Integer K, ERR, NBCOLL, I
# efface les espaces en début et fin de chaîne
CHAINE=vireblc(VALEUR,2)

OK=1 : ERR=0
 While CHAINE<>""
  K=instr(1,CHAINE," ")
  If K
   If !instr(1,"0123456789",mid$(CHAINE,K+1,1))
    OK=0 : Break
   Else
    COMPTE=left$(CHAINE,K-1) : CHAINE=right$(CHAINE,K+1)
   Endif
  Else
   COMPTE=CHAINE : CHAINE=""
  Endif
  K=instr(1,COMPTE,"(")
  If K
   SCOMPTE=right$(COMPTE,K)
   COMPTE=left$(COMPTE,K-1)
   If mid$(SCOMPTE,len(SCOMPTE),1)<>")" | instr(1,COMPTE,"-")
    OK =0 : Break
   Endif
   For K=2 To len(SCOMPTE)-1
    If !instr(1,"0123456789",mid$(SCOMPTE,K,1)) : OK=0 : Break : Endif
   Next K
   If !OK : Break : Endif
   If len(COMPTE)+len(SCOMPTE)-2 > 10
    OK=0 : ERR=1 : CPT=COMPTE+seg$(SCOMPTE,2,len(SCOMPTE)-1) : Break
   Endif
  Endif
  For K=1 To len(COMPTE)
   If !instr(1,"0123456789",mid$(COMPTE,K,1)) & (mid$(COMPTE,K,1)<>"-")
    OK=0 : Break 2
   Elsif mid$(COMPTE,K,1)="-"
    If K=len(COMPTE) & CHAINE<>""
     OK=0 : Break 2
    Elsif instr(K+1,COMPTE,"-")
     OK=0 : Break 2
    Elsif len(COMPTE)-1>10
     OK=0 : ERR=1 : CPT=seg$(COMPTE,1,K-1) : Break 2
    Endif
   Elsif len(COMPTE)>10
    OK=0 : ERR=1 : CPT=COMPTE : Break 2
   Endif
  Next K
 Wend
If !OK
 If ERR=1 : # Si la racine de compte saisi est plus longue que la longueur du compte
  # Racine de compte trop longue
  MESSA = CPT-":"-mess(72,107,1)
 Elsif ERR=2
  # Compte non collectif
  MESSA = CPT-":"-mess(6,106,1)
 Else
  # Valeur incorrecte
  MESSA = mess(83,123,1) # correction bug 25686
 Endif
Endif
End

########################################
Subprog C_VLYSTR(VALEUR)
Variable Date    VALEUR
Call DATDEBFIN([M]VLYEND,VALEUR) From CPTSUB
End

########################################
Subprog C_VLYEND(VALEUR)
Variable Date    VALEUR
Call DATDEBFIN(VALEUR, [M]VLYSTR) From CPTSUB
End

########################################
Subprog C_DSPORI2(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" and [M]DSPORI1 = ""
#    GMESSAGE = mess()
 Call GRISER([M]TYPSCT, [M]DSPORI1, VALEUR, [M]DSPTYP) : mkstat = 2 : End
Else
 VALEUR = toupper(VALEUR)
Endif
End

########################################
Subprog C_DSPORI1(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 VALEUR = toupper(VALEUR)
Endif
End

########################################
Subprog AP_DSPACC(VALEUR)
Variable Char VALEUR
Local Integer OK
Local Char    MESSA(80)
Call C_BASCALC(VALEUR,MESSA,OK)
If !OK
 GMESSAGE = MESSA
 mkstat=2
Endif
End

########################################
# recherche des jockers *?# dans la chaine
Subprog VERIFJOKERS(CHAINE, JOKER)
Variable Char    CHAINE()
Variable Integer JOKER
    JOKER = 0
    # liste de caractères jokers autorisés
    CAR_OK = "*?"
    # vérifier si la chaine contient des jokers
    For N=1 To len(CAR_OK)
        If instr(1, CHAINE, mid$(CAR_OK, N, 1))
            JOKER = 1
            Break
        Endif
    Next
End

########################################
Subprog TEST(CHAINE, SECTEUR)
Variable Char CHAINE()
Value Integer SECTEUR    # FGR 01/02/2010 : X3SUIVI60986

Local Char    CHAINE2(80)
Local Integer JOKER, OK, N
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
# efface les espaces en début et fin de chaîne
CHAINE2 = CHAINE
OK = 1
While len(CHAINE2) <> 0
    CHAINE2=vireblc(CHAINE2,2)
    FINMOT = instr(1, CHAINE2, " ")
    If FINMOT = 0
        FINMOT = len(CHAINE2)+1
    Endif
    MOT = left$(CHAINE2, FINMOT-1)
    Call VERIFJOKERS(MOT, JOKER)
    If SECTEUR=1
        N = 360
    Else
        N = 361
    Endif
    If !JOKER
        Look [ADI]CODE=N;MOT
        If fstat
            OK = 0 : Break 
        Endif
    Endif
    CHAINE2 = mid$(CHAINE2, FINMOT, len(CHAINE2))
Wend
If !OK 
    GMESSAGE = MOT+" : secteur inexistant."
    mkstat = 2 : End
Endif
End

########################################
Subprog AM_TYPSCT(VALEUR)
Variable Integer VALEUR
 If VALEUR=1
  Actzo DSPORI1
  Effzo DSPORI2
  Grizo DSPORI2
 Else
  Actzo DSPORI2
  Effzo DSPORI1
  Grizo DSPORI1
 Endif
End
