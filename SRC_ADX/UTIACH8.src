#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################
# UTIACH8        Utilitaire de récupération du bug 16994    Module ACHAT #
# ---------------------------------------------------------------------- #
# Problème à résoudre :                                                  #
#   Resynchroniser les totaux commandes HT et TTC avec les montants      #
#                  lignes HT et TTC commandes standard ou DL fermes      #
#   [F:POH]TOTORD = cumul [F:POQ]LINAMT                                  #
#   [F:POH]TTVORD = cumul [F:POQ]LINATIAMT                               #
##########################################################################

Call MAJ_UTIACH8
End

Subprog MAJ_UTIACH8
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIACH8") From SAIDOS
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTIACH8 : Utilitaire de recalcul des totaux commandes d'achat") From LECFIC
If DOSSIER<>"" Call EXE_UTIACH8(DOSSIER) : Endif
Call TEMPOFF From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC

End

#######################################################################
# Pour exécution depuis dosmaj7 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif

If [F:ADS]MODULE(5) <> 2 : End : Endif
Call EXE_UTIACH8(APPLI)
End



Subprog EXE_UTIACH8(DOSSIER)
Value Char DOSSIER
#----- Variables locales -----#
Local Char     WMSG(80), WMSG2(90), WNUM(GLONPOH), CLE1(GLONPOH), CRITERE(50)
Local Decimal  WTOTORD,  WTTVORD, WLINAMT, WLINATIAMT, WRND
Local Integer COMPTEUR, STOP
Local Integer  NBENR,    NBCOR,   WLIN,    WSEQ
#-----
Call ECR_TRACE("UTIACH8 : Début traitement du dossier "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:POH]) =0  Local File =DOSSIER+".PORDER"     [POH] : Endif
If clalev([F:POQ]) =0  Local File =DOSSIER+".PORDERQ"    [POQ] : Endif
If clalev([F:TCU]) =0  Local File =DOSSIER+".TABCUR"     [TCU] : Endif
#----- Début du traitement -----#
Call DEBTRANS From GLOCK
Raz CLE1, NBENR, NBCOR
#-----
$BOUCLE_POH
STOP=0
CRITERE='POHNUM>"'+CLE1+'"'
Raz COMPTEUR
Trbegin [POH]
  For [POH] Where evalue(CRITERE)
    If [F:TCU]CUR<>[F:POH]CUR
      Read [TCU] TCU0=[F:POH]CUR
      If !fstat WRND=[F:TCU]CURRND Else WRND=0.01 : Endif
    Endif
    WNUM =[F:POH]POHNUM
    If COMPTEUR=0
      Call ECR_TRACE("----- Début de transaction ("+WNUM+")",0) From GESECRAN
    Endif
    NBENR+=1
    Raz WTOTORD, WTTVORD
    For [POQ] POQ0 Where POHNUM=[F:POH]POHNUM & WIPSTA<2
      WLIN=[F:POQ]POPLIN
      WSEQ=[F:POQ]POQSEQ
      WLINAMT=arr([F:POQ]LINAMT,WRND)
      WLINATIAMT=arr([F:POQ]LINATIAMT,WRND)
      If WLINAMT<>[F:POQ]LINAMT | WLINATIAMT<>[F:POQ]LINATIAMT
        Update [POQ] Where POHNUM=[F:POH]POHNUM & POPLIN=WLIN & POQSEQ=WSEQ
&                    With LINAMT=WLINAMT, LINATIAMT=WLINATIAMT
        If fstat  GOK=0 : Call FSTA("POQ") From GLOCK : Break 2 : Endif
        WMSG ="Commande"-WNUM-num$(WLIN)-num$(WSEQ)
        WMSG-="Correction d'arrondi"
        If WLINAMT<>[F:POQ]LINAMT
          WMSG-=num$([F:POQ]LINAMT)-"-->"-num$(WLINAMT)
        Else
          WMSG-=num$([F:POQ]LINATIAMT)-"-->"-num$(WLINATIAMT)
        Endif
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      WTOTORD+=WLINAMT
      WTTVORD+=WLINATIAMT
    Next
    If WTOTORD<>[F:POH]TOTORD
      WMSG ="Commande"-WNUM
      WMSG-="Rectification total HT ("+[F:POH]CUR+")"
      WMSG-=num$([F:POH]TOTORD)-"-->"-num$(WTOTORD)
    Endif
    If WTTVORD<>[F:POH]TTVORD
      WMSG2 ="Commande"-WNUM
      WMSG2-="Rectification total TTC ("+[F:POH]CUR+")"
      WMSG2-=num$([F:POH]TTVORD)-"-->"-num$(WTTVORD)
    Endif
    If WTOTORD<>[F:POH]TOTORD | WTTVORD<>[F:POH]TTVORD
      Update [POH] Where POHNUM=WNUM
&                  With  TOTORD=WTOTORD, TTVORD=WTTVORD
      If fstat
        GOK=0 : Call FSTA("POH") From GLOCK
      Else
        NBCOR+=1 
        If WTOTORD<>[F:POH]TOTORD
          Call ECR_TRACE(WMSG,1) From GESECRAN
        Endif
        If WTTVORD<>[F:POH]TTVORD
          Call ECR_TRACE(WMSG2,1) From GESECRAN
        Endif
      Endif
    Endif
    If GOK=1
      COMPTEUR+=1
      If COMPTEUR>GMAXUPDTRS : CLE1=[F:POH]POHNUM : STOP=1 : Break : Endif
    Else
      Break
    Endif
  Next
  If GOK=0
    Rollback
    Call ECR_TRACE("----- Transaction abandonnée ("+WNUM+")",1) From GESECRAN
    Goto FIN_UTIACH8
  Endif
Commit
If COMPTEUR>0
  Call ECR_TRACE("----- Transaction validée ("+WNUM+")",0) From GESECRAN
Endif
If STOP  Goto BOUCLE_POH : Endif
#----- Fin du traitement -----#
$FIN_UTIACH8
WMSG ="UTIACH8 : Nbre d'enregistrements traités :"-num$(NBENR)
WMSG+=" dont corrigés :"-num$(NBCOR)
Call ECR_TRACE(WMSG,0) From GESECRAN
Close Local File [POH]
Close Local File [POQ]
Close Local File [TCU]
End

