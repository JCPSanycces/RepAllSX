######################################################################

$ACTION
Case ACTION
 When "OUVRE"   		: Gosub OUVRE
 When "INICRE"  		: Gosub INICRE
 When "INIMOD"  		: Gosub INIMOD
 When "LIENS"   		: Gosub LIENS
 When "RAZCRE"      : Gosub RAZCRE
 When "AFFMASK" 		:	Gosub AFFMASK  #MAE, bg 52848
 When "ANNULE"  		:	Gosub ANNULE
 When "SETBOUT"     : Gosub SETBOUT
# When "CHANGE"  	  :	#Call CHANGE_AXX ("TABDEPAGIO", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX :#--CPO 71937 TABDEPAGIO Fait en AP_CHANGE
 When "FERME"       : Gosub FERME
 When "CHGCOD"      : Gosub CHGCOD    :#--CPO 71937	TABDEPAGIO
 When "AP_CHANGE"   : Gosub AP_CHANGE :#--CPO 71937	TABDEPAGIO
 When "SEL_TABLE"
   Case TABLE
     When "SELTDA"  : Gosub SELTDA	  :#--CPO 71937	TABDEPAGIO
   Endcase
 When Default
Endcase
Return

######################################################################
$OUVRE
If !clalev([F:DIE])  Local File GDIE     [DIE] : Endif
If !clalev([F:CDI])  Local File CADIEDEF [CDI] : Endif
#----- Pour faire disparaitre dynamiquement les champs éléments de facturation -----#
If !clalev([F:AMZ])  Local File AMSKZON  [AMZ] : Endif
If !clalev([F:ATY])  Local File ATYPE    [ATY] : Endif
If !clalev([F:ADW])  Local File ADOVAL   [ADW] : Endif    : # Dde 70328
Global Char GWLIBPFI(25), GWLIBSFI(25), GWFMTPFI(10), GWFMTSFI(10)    #105537.n - Text review. Increase the length to accommodate with new text
#Global Char GWLIBPFI(20), GWLIBSFI(20), GWFMTPFI(10), GWFMTSFI(10)   #10537.o - Text review

#--CPO 71937 TABDEPAGIO
#-----------------------------------#
# Sauvegarde des variables globales #
#-----------------------------------#
Gosub SAUV_GLOB From TRTX3GLOB

#--Lors d'un tunnel depuis un document (exemple : livraison)
Raz GCURFCY  :#--Ici pas de contexte et on veut éviter le filtrage des groupes de sites
Raz GSOCIETE :#--Ici pas de contexte et on veut éviter le filtrage des groupes de societes
#--/CPO

#----- Traitement des libellés à partir des champs de l'écran -----#
Read [AMZ]CODE="TDA1";"PFINUM"
If !fstat
  Call TEXTE([F:AMZ]INTIT,[V]GWLIBPFI) From OBJDIV
Else
  Raz [F:AMZ]
  [V]GWLIBPFI=mess(860,196,1)
Endif
Read [AMZ]CODE="TDA1";"SFINUM"
If !fstat
  Call TEXTE([F:AMZ]INTIT,[V]GWLIBSFI) From OBJDIV
Else
  Raz [F:AMZ]
  [V]GWLIBSFI=mess(861,196,1)
Endif
#----- Traitement des formats à partir des types de donnée -----#
Read [ATY]CODTYP="PFI"
If !fstat
  [V]GWFMTPFI="N:"+[F:ATY]FORTYP
Else
  Raz [F:ATY]
  [V]GWFMTPFI="N:5#"
Endif
Read [ATY]CODTYP="SFI"
If !fstat
  [V]GWFMTSFI="N:"+[F:ATY]FORTYP
Else
  Raz [F:ATY]
  [V]GWFMTSFI="N:5#"
Endif
#-----
Return

######################################################################
$FERME
Kill GWLIBPFI, GWLIBSFI, GWFMTPFI, GWFMTSFI
#--CPO 71937 TABDEPAGIO
#------------------------------------#
# Restitution des variables globales #
#------------------------------------#
Gosub REST_GLOB From TRTX3GLOB

# To manage the button Tunnel
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONTDA) : Endif

VCOD = CLE2
#--/CPO
Return

######################################################################
$LIENS
#--CPO 71937 TABDEPAGIO
GCURLEG = [F:TDA]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
GGRPFCY = [F:TDA]GFY
#--/CPO

#----- Traitement des champs éléments de facturation -----#
Gosub TRT_CHAMPS_ELT
#-----
[M]BASTAB = dim([M]DEPRAT)                                      : # nombre fixe de taux
#If dim([M]BASTAB2) > 0 [M]BASTAB2 = GOPTCANA  : Endif  : # nombre d'axes analytiques
#--- Chargement tableau des axes
If dim([M:TDA1]BASTAB2)>0
   If dim([M:TDA1]SOC)>0 & [M:TDA1]SOC<>""
      Call CHARG_DIE(11,[M:TDA1]SOC,"TDA1","BASTAB2") From TRTX3CPT
    Else
      Call CHARG_DIE(11,"","TDA1","BASTAB2") From TRTX3CPT
   Endif
Endif

Return

######################################################################

$AFFMASK
Call FMTLEG From TRTX3 : # Pour rendre invisible si nécessaire le champ "Législation"
Gosub GRILEG
Return

######################################################################

$GRILEG
If func AFNC.ACTIV("LEG")=0 : # Dossier mono-législation
  Diszo [TDA1]LEG
  [M:TDA1]LEG=GDOSLEG(1)
  Affzo [TDA1]LEG : If dim([M:TDA1]ZLEG)>0  Affzo [TDA1]ZLEG : Endif
Endif
Return

######################################################################

$RAZCRE
#----- Traitement des champs éléments de facturation -----#
Gosub TRT_CHAMPS_ELT
#--- Initialisation tableau des axes
If dim([M:TDA1]BASTAB2)>0
   If dim([M:TDA1]SOC)>0 & [M:TDA1]SOC<>""
      Call INIT_DIE(11,[M:TDA1]SOC,"TDA1","BASTAB2") From TRTX3CPT
    Else
      Call INIT_DIE(11,"","TDA1","BASTAB2") From TRTX3CPT
   Endif
Endif
Gosub GRILEG
[M:TDA1]DEPTYP=2
Affzo [M]1-99
Return
######################################################################
# force les postes suivants à 999 pour l'algorithme de recherche
# sinon les lignes vides sont écrites avec 0

$INIMOD

#--CPO 71937 TABDEPAGIO
#--Il faut le faire avant l'init par 999 car il y a un return si les occurences sont déjà init (cas de la duplication) !
Gosub MAJ_ATEXTRA
#--/CPO

Local Integer I, NBOCCUR,NBOCCUR2
NBOCCUR = find(0,[F]DEPDAY(0..dim([F]DEPDAY)-1))
If NBOCCUR = 0 : Return : Endif
NBOCCUR2 = find(0,[F]DEPDAY(NBOCCUR..dim([F]DEPDAY)-1))
If NBOCCUR2 <> 0
   For I = (NBOCCUR+NBOCCUR2-1) To dim([F]DEPDAY)-1
      [F]DEPDAY (I) = 999
   Next I
Endif

#--CPO 71937 TABDEPAGIO
##--- Creation / Modif de ATEXTRA
#Call MAJTEXTRA ([M:TDA1]DESAXX,"TABDEPAGIO","DESAXX",[M:TDA1]DEP,"") From ATEXTRA
#Call MAJTEXTRA ([M:TDA1]SHOAXX,"TABDEPAGIO","SHOAXX",[M:TDA1]DEP,"") From ATEXTRA
#
##    SOS libellés
#If dim([F:TDA]LANDESSHO)>0
#   [F:TDA]LANDESSHO=GLANGUE+"~"+[M:TDA1]DESAXX+"~"+[M:TDA1]SHOAXX
#Endif
#--/CPO

Return
######################################################################
$SETBOUT
If CLECUR=0 | GREP<>""
  Call VIREBOUT(CHAINE,"1") From GOBJET
Endif

Return
######################################################################

$INICRE
Local Integer I
For I=[M]BASTAB To dim([F]DEPDAY)-1
  [F]DEPDAY(I) = 999
Next

#--CPO 71937 TABDEPAGIO
##--- Creation / Modif de ATEXTRA
#Call MAJTEXTRA ([M:TDA1]DESAXX,"TABDEPAGIO","DESAXX",[M:TDA1]DEP,"") From ATEXTRA
#Call MAJTEXTRA ([M:TDA1]SHOAXX,"TABDEPAGIO","SHOAXX",[M:TDA1]DEP,"") From ATEXTRA
#
##    SOS libellés
#If dim([F:TDA]LANDESSHO)>0
#   [F:TDA]LANDESSHO=GLANGUE+"~"+[M:TDA1]DESAXX+"~"+[M:TDA1]SHOAXX
#Endif
Gosub MAJ_ATEXTRA
#--/CPO

Return

######################################################################

$ANNULE
#--CPO 71937 TABDEPAGIO
#Delete [AXX]Where CODFIC="TABDEPAGIO" & IDENT1=[F:TDA]DEP
Delete [AXX]Where CODFIC="TABDEPAGIO" & IDENT1=[F:TDA]DEP & IDENT2=[F:TDA]LEG
#--/CPO

Return

#--CPO 71937 TABDEPAGIO
