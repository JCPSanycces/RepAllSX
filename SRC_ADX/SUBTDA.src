######################################################################################
Subprog C_DEPDAY(VALEUR)
Variable Decimal  VALEUR
# controle de l'ordre croissant
If nolign > 1 & VALEUR <>0
  If [M]DEPDAY(nolign-2)  >= VALEUR
    GERR = 1
    GMESSAGE = mess(2,199,1)        # "Les délais doivent être croissants"
    mkstat = 2
  Endif
Endif
End

#############################################
Subprog C_DEPRAT(VALEUR)
Variable Decimal  VALEUR

# Controle du sens du taux
If ([M]DEPDAY(nolign-1) <= 0 & VALEUR > 0) |
&  ([M]DEPDAY(nolign-1) > 0 & VALEUR < 0 )
   GERR = 3
   GMESSAGE = mess(3,199,1)    # "Délai et Taux sont de signes différents (<0 = esc)"
Endif
End

#############################################
#Subprog AS_BASTAB2
#If [M]BASTAB2 = 0 : [M]BASTAB2 = GOPTCANA : Affzo [M]BASTAB2 : Endif
#End

###########################################################################
$TRTCOP
#-----------------------------------------------------------#
# Etiquette appelée depuis le traitement superviseur ACOPIE #
# --------------------------------------------------------- #
# Traitement de la copie d'un escompte/agio                 #
#-----------------------------------------------------------#
If [M]DOSORG=nomap
  Local File TABDEPAGIO [TDA1]
  Local File ATEXTRA    [AXX1]
Else
  Local File =[M]DOSORG+".TABDEPAGIO" [TDA1]
  Local File =[M]DOSORG+".ATEXTRA"    [AXX1]
Endif
If [M]DOSDES=nomap
  Local File TABDEPAGIO [TDA2]
  Local File ATEXTRA    [AXX2]
  Local File ACTIV      [ACV2]
Else
  Local File =[M]DOSDES+".TABDEPAGIO" [TDA2]
  Local File =[M]DOSDES+".ATEXTRA"    [AXX2]
  Local File =[M]DOSDES+".ATABDIV"    [ADI2] :#--CPO 71937 TABDEPAGIO
  Local File =[M]DOSDES+".ACTIV"      [ACV2]
  Local File =func DOSCONT.DOSX3([M]DOSDES)+".ADOSSIER"  [ADS2]
Endif
OK=1
#--CPO 71937 TABDEPAGIO
#Look [TDA2]TDA0=TABLE
#If !fstat
#  OK= 2 : Call AVERTIR([M]DOSDES-TABLE-mess(148,196,1),OK) From GESECRAN
#  If OK<>2  OK=0 : Endif
#Endif
#--/CPO
If OK
  Gosub OUVDOS  From ATEXTRA
  #--CPO 71937 TABDEPAGIO
  # Multi-Lég... Vérifier que la législation existe dans le dossier destination
  # Sous OUVDOS, le fichier ADOSSIER ADS2 du dossier destination est déjà en ligne
  #If TABLE2<>"" & clalev([F:ADS2])>0 & !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1))
  #  Call MESSAGE(TABLE2 - ':' - mess(249,133,1) ) From GESECRAN
  #   Return
  #Endif
  #--/CPO
  Call DEBTRANS From GLOCK
  Gosub TRT_COPIE
Endif
Close Local File [TDA1], [AXX1], [TDA2], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
If clalev([F:ADI2])>0 : Close Local File [ADI2] : Endif
If clalev([F:ACV2])>0 : Close Local File [ACV2] : Endif

Return

$TRT_COPIE
#--------------------------------------------------#
# Transaction de copie d'un escompte/agio          #
#--------------------------------------------------#
Local Char    LEGDES
Local Integer WMONOLEGDES
# Par défaut : Leg destination=leg de l'enregistrement à copier
LEGDES=TABLE2
GOK=1
#--CPO 71937 TABDEPAGIO
#--Quelques vérifications...
#If TABLE2<>''
# If [M]DOSDES<>nomap
#  Local Char SZDOSSIER(GLONADS)
#  Local Integer LG
#  Read [ADI2]CODE=909; TABLE2
#  If fstat
#   Call MESSAGE (TABLE2 - ':'- mess(173,187,1)  ) From GESECRAN : #-- Législation inexistante sur ce dossier --#
#   Return
#  Endif
# Endif
#Endif

If [M]DOSDES<>nomap
    # Le dossier destination est-il mono-leg ?
    If [F:ACV2]CODACT<>"LEG"
     Read [ACV2]CODACT = "LEG"
     If fstat Raz [F:ACV2] : Endif
    Endif
    If [F:ACV2]FLACT<>2
     WMONOLEGDES=0
    Else
     WMONOLEGDES=1
    Endif

    If WMONOLEGDES =0
        # Dossier destination mono-leg
        LG = instr(1, [M]DOSDES, "@")
        If LG = 0 Then
          SZDOSSIER = [M]DOSDES
        Else
          SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
        Endif
        Read [ADS2]DOSSIER=SZDOSSIER
        If fstat
            # Pb lecture dossier
            Call MESSAGE(SZDOSSIER-":"-mess(78,133,1) ) From GESECRAN  #-- Dossier inexistant --#
            Return
        Endif
        If [F:ADS2]DOSLEG(0)=""
            # Pas de législation pour le dossier
            Call MESSAGE(SZDOSSIER-":"-mess(241,133,1) ) From GESECRAN  #-- Il doit y avoir au moins une législation  --#
            Return
        Endif
        If TABLE2<>[F:ADS2]DOSLEG(0) & TABLE2<>''
            # La leg de l'enreg. à copier n'est pas tte leg et elle est <> Leg dossier mono-leg
            # Pas de copie
            Call MESSAGE(mess(617,199,1)-"("-[F:ADS2]DOSLEG(0)-") :"-mess(618,199,1)) From GESECRAN
            Return
        Elsif TABLE2=''
            # La leg de l'enreg. à copier est toute leg
            # On peut copier l'enreg : Leg destination=leg du dossier mono-leg
            LEGDES=[F:ADS2]DOSLEG(0)
        Endif
    Else
        # Dossier destination multi-leg
        If TABLE2<>''
          # Enregistrement à copier avec leg<>""
          Local Char SZDOSSIER(GLONADS)
          Local Integer LG
          Read [ADI2]CODE=909; TABLE2
          If fstat
           Call MESSAGE (TABLE2 - ':'- mess(173,187,1)  ) From GESECRAN : #-- Législation inexistante sur ce dossier --#
           Return
          Endif

          LG = instr(1, [M]DOSDES, "@")
          If LG = 0 Then
            SZDOSSIER = [M]DOSDES
          Else
            SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
          Endif
          Read [ADS2]DOSSIER=SZDOSSIER
          If !fstat Then
              If !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
                Call MESSAGE(TABLE2 - ':' - mess(249,133,1) ) From GESECRAN  #-- Législation non gérée par ce dossier --#
                Return
              Endif
          Endif
        Endif
    Endif
Endif

Read [TDA2]TDA0=TABLE ;LEGDES
If !fstat
    Local Integer WOK : WOK=1
    Call AVERTIR (mess(197,133,1), WOK) From GESECRAN : #-- enregistrement existe déjà --#
    If WOK=1 Return : Endif
Endif
#--/vérifications
#--/CPO
Trbegin [TDA2]
  #--CPO 71937 TABDEPAGIO
  #Delete [TDA2] Where DEP=TABLE
  Delete [TDA2] Where DEP=TABLE & LEG=LEGDES
  #If fstat=1 GOK=-1 : GLOCK="$"+[M]DOSDES+".TABDEPAGIO"-TABLE : Goto ROLL_COPIE
  If fstat=1 GOK=-1 : GLOCK="$"+[M]DOSDES+".TABDEPAGIO"-TABLE-LEGDES : Goto ROLL_COPIE
  Elsif fstat GOK=0 : Call RSTA("TDA2",TABLE) From GLOCK    : Goto AB_COPIE
  Endif
  #--- copie des textes traduits
  #Read [TDA1]TDA0=TABLE
  Read [TDA1]TDA0=TABLE;TABLE2
  If !fstat
    #--- copie des données
    [F:TDA2]=[F:TDA1]
    [F:TDA2]LEG = LEGDES
    If TABLE2=LEGDES
        Call COPTEXTRA("TABDEPAGIO","DESAXX",TABLE,TABLE2) From ATEXTRA
        If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
        Call COPTEXTRA("TABDEPAGIO","SHOAXX",TABLE,TABLE2) From ATEXTRA
        If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
    Else
        Call COPTEXTRA1("TABDEPAGIO","DESAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
        If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
        Call COPTEXTRA1("TABDEPAGIO","SHOAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
        If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
    Endif
    If dim([F:TDA2]UPDUSR)>0 : [F:TDA2]UPDUSR = GUSER : Endif :#--CPO 71937 TABDEPAGIO
    If dim([F:TDA2]UPDDAT)>0 : [F:TDA2]UPDDAT = date$ : Endif :#--CPO 71937 TABDEPAGIO
    Write [TDA2]
    If fstat GOK=0 : Call FSTA("TDA2") From GLOCK : Endif
  Endif
  #--/CPO
  If GOK=0 : Goto AB_COPIE : Endif
Commit
Return


#----- Abandon de la copie -----#
$AB_COPIE
Rollback

Return
#----- Nouvel essai si nécessaire -----#
$ROLL_COPIE
Rollback : Call ROLL From GLOCK : If !GROLL Goto TRT_COPIE : Endif
Return

