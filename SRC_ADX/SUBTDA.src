######################################################################################
## Section automatically added (screen TDA1) 05/24/2012 21:23:02 (DFY)
######################################################################################
Subprog C_DEPTYP(VALEUR)
Variable Integer VALEUR

# 81683 - Early discounts - Tax excluded & either footer element entered
If VALEUR=1 & ([M:TDA1]PFINUM>0 | [M:TDA1]SFINUM>0)
  GMESSAGE = mess(591,199,1)  # Tax exclusion inconsistent with discount reduction on tax amount
  mkstat = 2 : End
Endif

End
#--CPO 71937 TABDEPAGIO Nouvelle définition avec paramètre WLEG en plus
Subprog ALIDISVAT_LEG (WMODULE, WDEP,WLEG, WDTA, WDISVAT)
Value    Integer WMODULE
Value    Char    WDEP
Value    Char    WLEG
Variable Integer WDTA
Variable Decimal WDISVAT

Gosub ALIDISVAT2

End
######################################################################################
# V6.2 : 60763 Settlements Discounts
#---------------------------------------------------------------------#
# ALIDISVAT : S/P d'alimentation de la remise sur taxe                #
#   - A partir d'un code escompte (lié à un document achat/vente) :   #
#     Récupère dans la table des escomptes :                          #
#     - Le taux positif le + élevé (qui devient la remise sur taxe    #
#     - Le n°élément de facturation associé                           #
#---------------------------------------------------------------------#
# Entrée   WMODULE    : Code module (5=Vente/6=Achat)                 #
#          WDEP       : Code escompte                                 #
# Sortie   WDTA       : N°élément de facturation                      #
#          WDISVAT    : Montant de la remise sur taxe                 #
#---------------------------------------------------------------------#
Subprog ALIDISVAT (WMODULE, WDEP, WDTA, WDISVAT)
Value    Integer WMODULE
Value    Char    WDEP
Variable Integer WDTA
Variable Decimal WDISVAT

Local Char       WLEG(GLONADI)  :#--CPO 71937 TABDEPAGIO

Raz WDISVAT                     :# 102423 : Belgium Early discounts : Init discount rate

WLEG=GCURLEG										:#--CPO 71937 TABDEPAGIO
Gosub ALIDISVAT2                :#--CPO 71937 TABDEPAGIO

End

$ALIDISVAT2
If WMODULE=0 | WDEP="" Return Endif
If clalev([F:TDA])=0 : Local File TABDEPAGIO [TDA] : Endif

Local Integer    WRET
#If [F:TDA]DEP<>WDEP
#    Read [TDA] TDA0=WDEP
#    If fstat Raz [F:TDA] Endif
#Endif
Call LEC_TDA_LEG(WLEG,WDEP,WRET) From TRTLECLEG
If WRET : Raz [F:TDA] : Endif
#--/CPO

If (WMODULE=5 & [F:TDA]SFINUM=0) | (WMODULE=6 & [F:TDA]PFINUM=0) Return Endif
# 102423 : Belgium Early discounts
# The elt is returned only if it is "Rebate on vat"
# If not, elt="" and no Rebate on vat is calculated
#WDISVAT=abs(min([F:TDA]DEPRAT))
#If WMODULE=5 WDTA=[TDA]SFINUM Endif
If WMODULE=5
  Local File SFOOTINV [SFI]
  Read [F:SFI]SFI0 = [TDA]SFINUM
  If fstat Raz [F:SFI] : Endif
  If [F:SFI]MISRULSTD=2
      WDTA=[TDA]SFINUM
      WDISVAT=abs(min([F:TDA]DEPRAT))
  Endif
Endif

#If WMODULE=6 WDTA=[TDA]PFINUM Endif
If WMODULE=6
  Local File PFOOTINV [PFI]
  Read [F:PFI]PFI0 = [TDA]PFINUM
  If fstat Raz [F:PFI] : Endif
  If [F:PFI]DISVATFLG=2
      WDTA=[TDA]PFINUM
      WDISVAT=abs(min([F:TDA]DEPRAT))
  Endif
Endif
# 102423

Return
# V6.2 : 60763 Settlements Discounts
#--/CPO

#----------------------------------------------------------------------------------#
# Faire apparaitre/disparaitre les champs éléments de facturation (MBT 07/10/2010) #
#----------------------------------------------------------------------------------#
$TRT_CHAMPS_ELT

# 102423 : Belgium Early discounts
#If [M:TDA1]LEG="" | func AFNC.PARAM("DEPMGTMOD",[M:TDA1]LEG)="1"  # 81683 Early discount
#  If GMODU(6)=2 : # Module achat actif
#    Chgtzn [M:TDA1]PFINUM With GWLIBPFI
#    Chgfmt [M:TDA1]PFINUM With GWFMTPFI
#    If dim([M:TDA1]ZPFINUM)>0  Chgfmt [M:TDA1]ZPFINUM With  "K:20X" : Endif
#  Else
#    Chgtzn [M:TDA1]PFINUM With ""
#    Chgfmt [M:TDA1]PFINUM With "-"+GWFMTPFI
#    If dim([M:TDA1]ZPFINUM)>0  Chgfmt [M:TDA1]ZPFINUM With "-K:20X" : Endif
#  Endif
#  If GMODU(5)=2 : # module Ventes actif
#    Chgtzn [M:TDA1]SFINUM With GWLIBSFI
#    Chgfmt [M:TDA1]SFINUM With GWFMTSFI
#    If dim([M:TDA1]ZSFINUM)>0  Chgfmt [M:TDA1]ZSFINUM With  "K:20X" : Endif
#  Else
#    Chgtzn [M:TDA1]SFINUM With ""
#    Chgfmt [M:TDA1]SFINUM With "-"+GWFMTSFI
#    If dim([M:TDA1]ZSFINUM)>0  Chgfmt [M:TDA1]ZSFINUM With "-K:20X" : Endif
#  Endif
#Else
#  Chgtzn [M:TDA1]PFINUM With ""
#  Chgfmt [M:TDA1]PFINUM With "-"+GWFMTPFI
#  If dim([M:TDA1]ZPFINUM)>0  Chgfmt [M:TDA1]ZPFINUM With "-K:20X" : Endif
#  Chgtzn [M:TDA1]SFINUM With ""
#  Chgfmt [M:TDA1]SFINUM With "-"+GWFMTSFI
#  If dim([M:TDA1]ZSFINUM)>0  Chgfmt [M:TDA1]ZSFINUM With "-K:20X" : Endif
#Endif
Gosub GRILEG  # FGR 27/01/2015 : X3SUIVI105766
If [M:TDA1]LEG="" | find(func AFNC.PARAM("DEPMGTMOD",[M:TDA1]LEG), "1","5")
  Chgtzn [M:TDA1]PFINUM With GWLIBPFI
  Chgfmt [M:TDA1]PFINUM With GWFMTPFI
  If dim([M:TDA1]ZPFINUM)>0  Chgfmt [M:TDA1]ZPFINUM With  "K:20X" : Endif

  Chgtzn [M:TDA1]SFINUM With GWLIBSFI
  Chgfmt [M:TDA1]SFINUM With GWFMTSFI
  If dim([M:TDA1]ZSFINUM)>0  Chgfmt [M:TDA1]ZSFINUM With  "K:20X" : Endif
Else
  Chgtzn [M:TDA1]PFINUM With ""
  Chgfmt [M:TDA1]PFINUM With "-"+GWFMTPFI
  If dim([M:TDA1]ZPFINUM)>0  Chgfmt [M:TDA1]ZPFINUM With "-K:20X" : Endif
  Chgtzn [M:TDA1]SFINUM With ""
  Chgfmt [M:TDA1]SFINUM With "-"+GWFMTSFI
  If dim([M:TDA1]ZSFINUM)>0  Chgfmt [M:TDA1]ZSFINUM With "-K:20X" : Endif
Endif
# 102423
Return

#--CPO 71937 TABDEPAGIO
#################################################################################
$CHGCOD
Call CHGCOD(ABREV,CLECUR1,CLECUR2,OK) From CHGCLELEG
Return
######################################################################################
$AP_CHANGE
Call CHGTEXTRA("TABDEPAGIO","DESAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Call CHGTEXTRA("TABDEPAGIO","SHOAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Return

$MAJ_ATEXTRA
#--CPO 71937 21.02.2013
#If GREP="D"
# ## En duplication, on veut récupérer tous les intitulés traduisibles...
# Call DUPTEXTRA("TABDEPAGIO","DESAXX",CLECUR1,"","TABDEPAGIO","DESAXX",[F:TDA]DEP,[F:TDA]LEG)  From ATEXTRA
# Call DUPTEXTRA("TABDEPAGIO","SHOAXX",CLECUR1,"","TABDEPAGIO","DESAXX",[F:TDA]DEP,[F:TDA]LEG)  From ATEXTRA
#Endif
#----- Création/Modification des textes traduisibles (ATEXTRA) -----#
Call MAJTEXTRA ([M:TDA1]DESAXX,"TABDEPAGIO","DESAXX",[M:TDA1]DEP,[M:TDA1]LEG) From ATEXTRA  #MAE, multiLEG
Call MAJTEXTRA ([M:TDA1]SHOAXX,"TABDEPAGIO","SHOAXX",[M:TDA1]DEP,[M:TDA1]LEG) From ATEXTRA  #MAE, multiLEG
#----- SOS libellés -----#
If dim([F:TDA]LANDESSHO)>0
  [F:TDA]LANDESSHO=GLANGUE+"~"+[M:TDA1]DESAXX+"~"+[M:TDA1]SHOAXX
Endif
#-----
Return

##################################################
## Actions of the data type TDA
##################################################

# Control
Subprog CONTTDA(DEP,LEG,CODMSK,CHAMPCOD,FCY,GROUPE,CPY)
Variable Char    DEP()
Value    Char    LEG()
Value    Char    CODMSK()
Value    Char    CHAMPCOD()
Value    Char    FCY
Value    Char    GROUPE
Value    Char    CPY

Local Integer WRET

Local    Integer CAS
Local    Char    OPTIONS(30)

If GFONCTION = "GESTDA" | DEP="" : End : Endif

If clalev([F:TDA]) =0 : Local File TABDEPAGIO [TDA] : Endif
If clalev([F:AMZZ])=0 : Local File AMSKZON   [AMZZ] : Endif :#Pour déterminer les options de sélection
If clalev([F:CPY])=0  : Local File COMPANY    [CPY] : Endif :#--CPO 71937
If clalev([F:FCY])=0  : Local File FACILITY   [FCY] : Endif :#--CPO 71937

If func AFNC.ACTIV("LEG")=0
 [L]LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 [L]LEG = GCURLEG
Endif
CAS = 1 : # Legislation is empty

#--CPO 71937 TABDEPAGIO
#--Cas particulier : pas de GCURLEG mais société ou site en ligne
If [L]LEG="" and ([L]CPY<>"" | [L]FCY<>"")
	If [L]FCY<>""
		If [F:FCY]FCY<>[L]FCY
			Read [F:FCY]FCY0=[L]FCY
			If fstat : Raz [F:FCY] Endif
		Endif
		If [L]CPY="" : [L]CPY=[F:FCY]LEGCPY : Endif
	Endif
	If [L]CPY<>""
		If [F:CPY]CPY<>[L]CPY
			Read [F:CPY]CPY0=[L]CPY
			If fstat : Raz [F:CPY] Endif
		Endif
		[L]LEG=[F:CPY]LEG
	Endif
Endif
#--/CPO

If LEG<>""
 Read [TDA]TDA0=DEP;LEG
 If fstat
  Read [TDA]TDA0=DEP;""
 Else
  CAS = 2 : # Legislation isn't empty
 Endif
Else
 Read [TDA]TDA0(1)=DEP
 If !fstat
  LEG = [F:TDA]LEG
  CAS = 2
 Endif
Endif
If fstat
 Filter [TDA] Where DEP=[L]DEP
 Look [TDA]TDA0 First
 If !fstat
  # Fiche inexistante pour la législation courante
  GMESSAGE = [L]DEP-":"-mess(232,107,1)-"["+[L]LEG+"]"
 Else
  # Fiche inexistante
  GMESSAGE = [L]DEP-":"-mess(23,100,1)
 Endif
 Filter [TDA]
 mkstat = 2 : End
Endif

#--Filtrage par groupe de société
#--Dans ce cas particulier ou nous pouvons avoir que le CPY de renseigné (paramètrage pour une société)
#--Du fait du type de donné AGF sur le champ GFY de TABDEPAGIO, il n'y aura que le filtrage sur site ! (en fonction de GCURFCY)
#If [L]CPY<>""
If [L]CPY<>"" and [L]FCY="" :#--CPO 71937
  If [F:TDA]GFY<>""
  	#--CPO 71937
  	If clalev([F:AGF])=0 : Local File AGRPFCY    [AGF]  : Endif
		Read [AGF]AGF0=[F:TDA]GFY
		If !fstat
  		If [F:AGF]FLGLEG=2
    		#--Société
				If [F:TDA]GFY<>[L]CPY
          GMESSAGE += DEP+"\"+mess(63,127,1)-":"-[F:TDA]GFY : # Réservé au groupe de société
          mkstat = 2 : End
				Endif
  		Elsif [F:AGF]FLGCPY=2
  	#--CPO
        If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
        Look [AGC]AGC0 = [F:TDA]GFY;[L]CPY
        If fstat
          GMESSAGE += DEP+"\"+mess(63,127,1)-":"-[F:TDA]GFY : # Réservé au groupe de société
          mkstat = 2 : End
        Endif
      Endif :#--CPO 71937
    Endif
  Endif
Endif
#--

#--Contrôle de cohérence entre le groupe de la taxe et la législation
If [F:TDA]GFY<>"" and LEG<>""
	Call CTLGFYLEG([F:TDA]GFY,LEG,"","") From TRTVENCTL
	If mkstat : End : Endif
Endif
#--Contrôle de cohérence entre le groupe passé en paramètre et la législation de l'entrée retenue
If GROUPE <> "" and [F:TDA]LEG <> "" Then
  Call CTLGFYLEG(GROUPE, [F:TDA]LEG, "", "") From TRTVENCTL
  If mkstat : End : Endif
Endif
#--Contrôle de la cohérence entre le groupe passé en param et celui de l'escompte courant
#--uniquement si pas de contexte site ou société !
#--Il faut que le groupe de la taxes et celui du paramétrage aient au moins une soc en commun
If GROUPE<>""
	If CPY="" & FCY="" & [F:TDA]GFY<>"" & [F:TDA]GFY<>GROUPE
  	#--Les groupes doivent avoir au moins une société en commun
  	Gosub CTLGFYGRP
		If mkstat : End : Endif
	Endif
Endif

#--On charge les options définies sur le type de données du champ du masque
OPTIONS=""
If CODMSK<>"" & CHAMPCOD<>""
  Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
  If fstat=0 : OPTIONS=[F:AMZZ]OPTOBJ : Endif
Endif

If CAS=2
 Call CONTROLE("TDA",OPTIONS,LEG,DEP,mkstat) From CONTOBJ
Else
 Call CONTROLE("TDA",OPTIONS,"",DEP,mkstat) From CONTOBJ
Endif

End
#-------------------------------
$CTLGFYGRP
Local Integer ERR
Local Char    SZVIEW(GLONAVW)
If [F:TDA]LEG=""
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTDAZGRP"
    Local File =SZVIEW [TDAZ]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, pas de contrôle
    Return
  Endif

  Read [F:TDAZ]TDAZ0 = [L]GROUPE;[F:TDA]DEP;[F:TDA]GFY;[F:TDA]LEG
  If fstat
  	GMESSAGE = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:TDA]GFY-":"-mess(178,187,1)
  	mkstat=1
  	Return
  Endif
Else
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTDAYGRP"
    Local File =SZVIEW [TDAY]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, pas de contrôle
    Return
  Endif

  Read [F:TDAY]TDAZ0 = [L]GROUPE;[F:TDA]DEP;[F:TDA]GFY;[F:TDA]LEG
  If fstat
  	GMESSAGE = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:TDA]GFY-":"-mess(178,187,1)
  	mkstat=1
  	Return
  Endif
Endif
Return
## Tunnel Escomptes / Agios
Subprog TUNTDA(COD,LEG)
Variable Char    COD()
Value    Char    LEG()
Local Integer TOKILL

TOKILL = 0
If dim(VCOD)<1
  Global Char VCOD(GLONTDA)
  TOKILL = 1
Endif

If clalev([F:TDA])=0 : Local File TABDEPAGIO [TDA] : Endif

VCOD = COD

If GNBLEG=1
  LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>""
  LEG = GCURLEG
#--If LEG="" then firstly we search a TDA record with LEG="" secondly a TDA record with TDA<>""
Elsif LEG=""
  Read [TDA]TDA0 = VCOD;LEG
  If fstat
    Read [TDA]TDA0(1)=VCOD
    If !fstat
      LEG = [F:TDA]LEG
    Endif
  Endif
Endif

Read [TDA]TDA0 = COD;LEG
If fstat : LEG = "" : Endif

Call OBJET("TDA",LEG,VCOD) From GOBJET

COD = VCOD
If TOKILL : Kill VCOD : Endif

End
#--------------------------------------------------------------------------------
#--Called from ADPVAL fonction "Parameter values"
#--Also called from the SELTDA selection action (Throughout the SELTDAA subprog)
#--------------------------------------------------------------------------------
$SELTDA

If clalev([F:TDA])=0 : Local File TABDEPAGIO  [TDA] : Endif

If clalev([F:FCY])=0  : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY] : Endif
If clalev([F:FGR])=0  : Local File FACGROUP   [FGR] : Endif
If clalev([F:AXX])=0  : Local File ATEXTRA    [AXX] : Endif
If clalev([F:AMZZ])=0 : Local File AMSKZON   [AMZZ] : Endif :#--CPO 71937 Pour déterminer les options de sélection
If clalev([F:AGF])=0  : Local File AGRPFCY 	  [AGF] : Endif :#--CPO 71937

Local Char    FCY(GLONFCY)
Local Char    CPY(GLONCPY)
Local Char    LEG(GLONADI)
Local Char    GFY(GLONAGC)
Local Integer WNOL
Local Integer ERR
Local Char    AUTRE_CRIT(250)
Local Char    SZVIEW(GLONAVW)

#--CPO 71937 Pour déterminer les options de sélection
If dim(OPTIONS)<0 : Local Char OPTIONS(30) Endif
Local Char CODMSK   (GLONAMK)
Local Char CHAMPCOD (GLONAVA)
CODMSK  =PARAM(2)
CHAMPCOD=PARAM(3)

#--CPO 98053 et 98275 Sélection depuis "ADPVAL" et prise en compte des OPTIONS
#--On charge les options définies sur le type de données du champ du masque
#OPTIONS=""
#If CODMSK<>"" & CHAMPCOD<>""
#  Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
#  If fstat=0 : OPTIONS =[F:AMZZ]OPTOBJ : Endif
#Endif
#--/CPO
#--------------------------------------------------------------------------------------------------
If GFONCTION = "GESTDA" Then
  # Si on est sur l'objet de paramétrage, pas de filtre on part sur la sélection standard
  OBJET = "TDA"
  Return
Endif

#--------------------------------------------------------------------------------------------------
# Identifying the parameters
#--------------------------------------------------------------------------------------------------
AUTRE_CRIT = '1=1'

If GFONCTION="ADPVAL"     :#--"Parameter values". Data type = ???
  FCY  = [M:ADWP]FCY
  CPY  = [M:ADWP]CMP
  If dim([M:ADWP]LEG)>0
    LEG = [M:ADWP]LEG
  Else
    LEG = GDOSLEG
  Endif
Else
  LEG  = PARAM(1)
  FCY  = PARAM(4)
  GFY  = PARAM(5)
  CPY  = PARAM(6)
  If dim(PARAM(7))>0 & PARAM(7)<>"" : AUTRE_CRIT -= '& '+PARAM(7) Endif
  #--CPO 98053 et 98275 Sélection depuis "ADPVAL" et prise en compte des OPTIONS
  #--On charge les options définies sur le type de données du champ du masque
  OPTIONS=""
  If CODMSK<>"" & CHAMPCOD<>""
    Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
    If fstat=0 : OPTIONS =[F:AMZZ]OPTOBJ : Endif
  Endif
  #--/CPO
Endif

#--Init. of legislation
If func AFNC.ACTIV("LEG")=0
 [L]LEG = GDOSLEG
Endif
If [L]LEG=""
 If [L]FCY<>""
  Call LEC_FCY([L]FCY) From CPTLEC
  Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
  [L]LEG = [F:CPY]LEG
 Elsif [L]CPY<>""
  Call LEC_CPY([L]CPY) From CPTLEC
  [L]LEG = [F:CPY]LEG
 Endif
Endif

If [L]LEG=""
 [L]LEG = GCURLEG
Endif
#--------------------------------------------------------------------------------------------------
## Position and dimension of the window
#--------------------------------------------------------------------------------------------------
Gosub OUVRE_LISTE From WOTDA
For I=1 To NBSEL
 If SELEXP(I)<>""
  COL(I) = SELEXP(I)
 Else
  COL(I) = SELZON(I)
 Endif
 TIT(I)  = SELLIB(I)
 If left$(SELFMT(I),2)="LA"
  COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
 Endif
Next I
NBCOL   = NBSEL
SIZCOL  = 240
SIZLIG  = 100
TIT(0)  = mess(12,123,1)
Call TITOBJ("TDA","",TIT(1)) From CONTOBJ
TIT(0) -= TIT(1)
START   = "[F:TDA]DEP"
ORDRE   = "[F:TDA]DEP;[F:TDA]LEG"
OBJET   = ""

#--------------------------------------------------------------------------------------------------
## Standard selection criteria
#--------------------------------------------------------------------------------------------------

CRITERE(1) = '1=1'
#--Groupe de soc/sites
If [L]FCY="" & [L]CPY="" & [L]GFY<>""
	#--Cas du groupe étant une société
 	Read [F:AGF]AGF0=[L]GFY
 	If !fstat
 		If [F:AGF]FLGLEG=2 : [L]CPY=[L]GFY : Endif
 	Endif
 	#--Le filtrage sur les groupes sites/sociétés sont fait dans le link directement
Endif
#--Facility
If    [L]FCY<>""
  CRITERE(1) -= '& ([F:TDA]GFY="" | ([F:TDA]GFY<>"" & [F:FGR]FCY="'+[L]FCY+'"))'
#--Company
Elsif [L]CPY<>""
  CRITERE(1) -= '& ([F:TDA]GFY="" | ([F:TDA]GFY<>"" & [F:TDAC]LEGCPY="'+[L]CPY+'"))'
Endif

#--Legislation
If LEG<>""
  CRITERE(2) -= '& ([F:TDA]LEG="'+[L]LEG+'" | [F:TDA]LEG="")'
Endif
#--First selection character
If dim(SELCAR)>0 & SELCAR<>0
  CRITERE(2) -= '& left$([F:TDA]DEP,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
Endif

CRITERE(2) -= '&'-[L]AUTRE_CRIT

ICRITERE = 3
Call FILROLE(OBJET,FILROLE) From SUBARL
If FILROLE<>"" & FILROLE<>"1=1"
 For I=0 To dim(FILROLE)-1
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILROLE(I),"&") From GOBJSUB
 Next I
Endif

#--------------------------------------------------------------------------------------------------
#--Views calls
#--------------------------------------------------------------------------------------------------
If ([L]CPY="" and [L]FCY="" and [L]GFY<>"")
	If [L]LEG<>""
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTDAYGRP"
      Local File =SZVIEW [TDAY]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "TDA"
      Return
    Endif
	Else
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTDAZGRP"
      Local File =SZVIEW [TDAZ]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "TDA"
      Return
    Endif
	Endif
Endif

ERR = 0
Repeat
	# -----------------------------------------------------------------------------------------------
	# ERR=0  : Pas d'erreur, on sort
	# ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
	# ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
	# Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
	# -----------------------------------------------------------------------------------------------
	Onerrgo ERRVUE
	SZVIEW = "LEGTDACPY"
	Local File =SZVIEW [TDAC]
	Onerrgo
Until ERR <> -1
If ERR Then
	# Si problème, on se déroute sur le select standard
	OBJET = "TDA"
	Return
Endif
If [L]LEG<>""
  #--View throughout GCURLEG
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTDASEL"
    Local File =SZVIEW [TDAS]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, on se déroute sur le select standard
    OBJET = "TDA"
    Return
  Endif
  If ([L]CPY="" and [L]FCY="" and [L]GFY<>"")
  	Link [TDA] With [F:AXX]AXX0    = "TABDEPAGIO";"DESAXX";GLANGUE;[F:TDA]DEP;[F:TDA]LEG,
&                		[F:TDAY]TDAY0 ~= [L]GFY;[F:TDA]DEP;[F:TDA]GFY;[F:TDA]LEG,
&              			[F:TDAS]TDA0  ~= [F:TDA]DEP;[F:TDA]LEG;[L]LEG
&            		 As [LTDA]
	Else
 		Link [TDA] With [F:AXX]AXX0    = "TABDEPAGIO";"DESAXX";GLANGUE;[F:TDA]DEP;[F:TDA]LEG,
&           	      [F:FGR]FGR1    = [L]FCY;[F:TDA]GFY,
&               	  [F:TDAC]TDA0   = [F:TDA]DEP;[F:TDA]LEG;[F:TDA]GFY;[L]CPY,
&           	     	[F:TDAS]TDA0  ~= [F:TDA]DEP;[F:TDA]LEG;[L]LEG
&   						 As [LTDA]
	Endif
Else
	#--View without legislation
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTDAPAR"
    Local File =SZVIEW [TDAP]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, on se déroute sur le select standard
    OBJET = "TDA"
    Return
  Endif
  If ([L]CPY="" and [L]FCY="" and [L]GFY<>"")
  	Link [TDA] With [F:AXX]AXX0    = "TABDEPAGIO";"DESAXX";GLANGUE;[F:TDA]DEP;[F:TDA]LEG,
&                 	[F:TDAZ]TDAZ0 ~= [L]GFY;[F:TDA]DEP;[F:TDA]GFY;[F:TDA]LEG
&             	 As [LTDA]
	Else
 	  Link [TDA] With [F:AXX]AXX0    = "TABDEPAGIO";"DESAXX";GLANGUE;[F:TDA]DEP;[F:TDA]LEG,
&                		[F:FGR]FGR1    = [L]FCY;[F:TDA]GFY,
&                		[F:TDAC]TDA0   = [F:TDA]DEP;[F:TDA]LEG;[F:TDA]GFY;[L]CPY,
&                		[F:TDAP]TDA0  ~= [F:TDA]DEP;[F:TDA]LEG
&   						 As [LTDA]
	Endif
Endif

# Options de sélection
If OPTIONS<>""
  Gosub OPTIONS From WOTDA
  ICRITERE=2
  For I=1 To NBCOND
   If instr(1,OPTIONS,OPT(I))
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","("+CONDIT(I)+")","&") From GOBJSUB
   Endif
  Next I
Endif

Default File [LTDA]
DEFPAG = 1

Return

$ERRVUE
  If ERR = 0 Then
    ERR = -1
    Call MAJVUE(SZVIEW, nomap) From DOSVUE
  Else
    ERR = errn
  Endif
Resume
#--------------------------------------------------------------------------------
#--Call from SELTDA Action
#--------------------------------------------------------------------------------
Subprog SELTDAA(DEP,LEG,CODMSK,CHAMPCOD,FCY,GROUPE,CPY)
Variable Char    DEP()
Value    Char    LEG()
Value    Char    CODMSK()
Value    Char    CHAMPCOD()
Value    Char    FCY
Value    Char    GROUPE
Value    Char    CPY

Local Char PARMSK(30)(1..10)
PARMSK(1)=[L]LEG
PARMSK(2)=[L]CODMSK
PARMSK(3)=[L]CHAMPCOD
PARMSK(4)=[L]FCY
PARMSK(5)=[L]GROUPE
PARMSK(6)=[L]CPY

If clalev([F:TDA])=0 : Local File TABDEPAGIO [TDA] : Endif
Call S_TAB_CHAR(DEP,PARMSK,"SELTDA","SUBTDA","") From GACTION

End
#################################################################################

