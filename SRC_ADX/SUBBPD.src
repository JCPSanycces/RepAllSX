########################################
Subprog C_CRY(VALEUR)
Variable Char    VALEUR()
Gosub TITRES From W1BPD2
If dim([M]SAT)>0
 #If [F:TCY]ETAT<>2 #X3-38357 Field State in a new address from Sales order
 If [F:TCY]ETAT<2 #X3-38357 LCC 03/01/18
  Effzo SAT
  Grizo SAT
 Else
  Actzo SAT
 Endif
Endif
End

##########################################################################
