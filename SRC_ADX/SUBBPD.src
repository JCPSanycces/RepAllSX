###############################################################
$RAZDUP

Local Integer WRET

Call RAZ_CLOB From ACLOB

If [M]PRPTEX<>""
   Call DUP_CLOB("BPD",[M:BPD1]PRPTEX,WRET) From TRTX3TEX
   If WRET<1 Raz [M]PRPTEX Endif
Endif
If [M]DLVTEX<>""
   Call DUP_CLOB("BPD",[M:BPD1]DLVTEX,WRET) From TRTX3TEX
   If WRET<1 Raz [M]DLVTEX Endif
Endif

If [M:BPD1]FFWNUM="" Diszo [M:BPD1]FFWADD Else Actzo [M:BPD1]FFWADD Endif : # Bug 66945

[M:BPD2]BPAADDFLG = 1 # FGR 20/04/2012 : X3SUIVI81054

Affzo [M:BPD1]1-99
Affzo [M:BPD2]1-99
Return

########################################
$VERIFCRE_MOD

# Si le tiers est un site : le site réception doit être renseigné
# Bug 33874
If [M]FCY <> "" & [M]RCPFCY="" GERR=1 : GMESSAGE = mess(544,197,1) : OK = 0 : Return : Endif

Return
###################################################################
$INICRE
#----------------------------------------------------#
# duplication des textes si pas accès a ces derniers #
# duplication sans saisie                            #
#----------------------------------------------------#

If [M]PRPTEX<>""
   Call CRE_CLOB([M:BPD1]PRPTEX,GOK) From TRTX3TEX
   If GOK<1 Return Endif
   [F:BPD]PRPTEX = [M:BPD1]PRPTEX
Endif
If [M]DLVTEX<>""
   Call CRE_CLOB([M:BPD1]DLVTEX,GOK) From TRTX3TEX
   If GOK<1 Return Endif
   [F:BPD]DLVTEX = [M:BPD1]DLVTEX
Endif

Return

###############################################################
$CREATION
#----------------------------------#
# creation enregistrement adresse  #
#----------------------------------#
Gosub CREBPA
Return

###################################################################
$INIMOD

If [M]PRPTEX<>""
   Call CRE_CLOB([M:BPD1]PRPTEX,GOK) From TRTX3TEX
   If GOK<1 Return Endif
   [F:BPD]PRPTEX = [M:BPD1]PRPTEX
Endif
If [M]DLVTEX<>""
   Call CRE_CLOB([M:BPD1]DLVTEX,GOK) From TRTX3TEX
   If GOK<1 Return Endif
   [F:BPD]DLVTEX = [M:BPD1]DLVTEX
Endif
If [M]PRPTEX="" & [F:BPD]PRPTEX<>""
   Call SUP_CLOB([F:BPD]PRPTEX,WRET) From TRTX3TEX
Endif
If [M]DLVTEX="" & [F:BPD]DLVTEX<>""
   Call SUP_CLOB([F:BPD]DLVTEX,WRET) From TRTX3TEX
Endif

Return

###############################################################
$MODIF
#----------------------------------#
# creation enregistrement adresse  #
#----------------------------------#
Gosub CREBPA
Return
###############################################################
$AVANTMOD
#----------------------------------#
# verrouillage sysmbole BPA        #
#----------------------------------#
Local Char SYMBOLE2 (20) : # cg le 28/01/98
SYMBOLE2 ="BPA"+num$(1)+num$([M:BPD0]BPCNUM)+num$([M:BPD0]BPAADD) :# cg 28/01/98
Lock = SYMBOLE2 With lockwait = 0
OK = 1
If fstat
#     Call ERREUR(mess(10,100,1)) From GESECRAN
     GERR=1:GMESSAGE=mess(10,100,1) : OK = 0
Endif

Return
###############################################################
$FINMODIF
Gosub DEVERROU
Return
###############################################################
$DEVERROU
#----------------------------------#
# Deverrouillage symbole BPA       #
#----------------------------------#
Local Char SYMBOLE2 (20) : # cg le 28/01/98
SYMBOLE2 ="BPA"+num$(1)+num$([M:BPD0]BPCNUM)+num$([M:BPD0]BPAADD) : #cg LE 28/01/98
Unlock = SYMBOLE2
Return
###############################################################
$CREBPA
Read [BPA]BPA0 = 1;[M:BPD0]BPCNUM;[M:BPD0]BPAADD
If fstat <> 0
    Raz [F:BPA]
    [F:BPA]       = [M:BPD2]
    [F:BPA]BPADES = [M:BPD2]BPADES
    Gosub INITBPA
    Call FLDCRE("BPA") From OBJDIV  # FGR 27/04/2012 : X3SUIVI81768
    #[F:BPA]CREUSR = GUSER          # FGR 27/04/2012 : X3SUIVI81768
    #[F:BPA]CREDAT = date$          # FGR 27/04/2012 : X3SUIVI81768
    #[F:BPA]CRETIM = time           # FGR 27/04/2012 : X3SUIVI81768
    Write [BPA]
    If fstat
           GOK = 0 : Call FSTA("BPA") From GLOCK
    Endif
Else
    Readlock [BPA]BPA0 = 1;[M:BPD0]BPCNUM;[M:BPD0]BPAADD
    If fstat = 1
        GOK = -1 : GLOCK = "$BPADDRESS"-[M:BPD0]BPCNUM-[M:BPD0]BPAADD : Return
    Endif

    [F:BPA]       = [M:BPD2]
    Gosub INITBPA
    Call FLDUPD("BPA") From OBJDIV  # FGR 27/04/2012 : X3SUIVI81768
    #[F:BPA]UPDUSR = GUSER          # FGR 27/04/2012 : X3SUIVI81768
    #[F:BPA]UPDDAT = date$          # FGR 27/04/2012 : X3SUIVI81768
    #[F:BPA]CRETIM = time           # FGR 27/04/2012 : X3SUIVI81768
    Rewrite [BPA]
    If fstat
           GOK = 0 : Call FSTA("BPA") From GLOCK
    Endif
Endif

Return
###################################################################
$INITBPA
  [F:BPA]BPATYP = 1
  [F:BPA]BPANUM = [F:BPD]BPCNUM
  [F:BPA]BPAADD = [F:BPD]BPAADD
  [F:BPA]BPAADDLIG(0) = [M]ADDLIG1
  [F:BPA]BPAADDLIG(1) = [M]ADDLIG2
  [F:BPA]BPAADDLIG(2) = [M]ADDLIG3
  # FGR 27/04/2012 : X3SUIVI81768 (début)
  If dim([F:BPA]FAX) >= 0 Then
    [F:BPA]FAX = [F:BPA]TEL(1)
  Endif
  If dim([F:BPA]MOB) >= 0 Then
    [F:BPA]MOB = [F:BPA]TEL(4)
  Endif
  # FGR 27/04/2012 : X3SUIVI81768 (fin)
  Gosub ECRIT_BPA From TRTADRLIB      #LTA.n
Return

###################################################################
$ABANDON
Gosub DEVERROU

Local Integer WRET

If GREP = "D"
   If [M:BPD1]PRPTEX<>""
      Call SUP_CLOB([M:BPD1]PRPTEX,WRET) From TRTX3TEX
   Endif
   If [M:BPD1]DLVTEX<>""
      Call SUP_CLOB([M:BPD1]DLVTEX,WRET) From TRTX3TEX
   Endif
Else
   Call RAZ_CLOB From ACLOB
Endif
Return

