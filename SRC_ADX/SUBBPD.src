#<AdxTL>@(#)227.0.0.0 $Revision$
####################################################################
#   GESTION DES CLIENTS LIVRES
#
# DEFBOUT   : Suppression des boutons #code et annulation
# LIENS     : Lecture  table BPADDRESS + chargement masque BPD2
# CREATION  : Creation table BPADDRESS si besoin est
# MODIF     : Modif    table BPADDRESS
# AVANT_MOD : Verouillage   du symbole bpa
# FIN_MOD   : Deverouillage du symbole bpa
#
####################################################################
$ACTION

# Pour gestion multi-société
# Gosub ACTION From GSOCIETE

Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "FILTRE"      : Gosub FILTRE
 When "SETBOUT"     : Gosub SETBOUT
 When "AFFMASK"     : Gosub AFFMASK
 When "AVANTBOUT"   : Gosub AVANTBOUT
 When "STATUT"      : Gosub STATUT
 When "LIENS"       : Gosub LIENS
 When "RAZCRE"      : Gosub RAZCRE
 When "RAZDUP"      : Gosub RAZDUP
 When "VERIF_CRE"   : Gosub VERIFCRE_MOD
 When "INICRE"      : Gosub INICRE
 When "CREATION"    : Gosub CREATION
 When "VERIF_MOD"   : Gosub VERIFCRE_MOD
 When "INIMOD"      : Gosub INIMOD
 When "MODIF"       : Gosub MODIF
 When "AVANT_MOD"   : Gosub AVANTMOD
 When "FIN_MOD"     : Gosub FINMODIF   : # modif le 28/01/98 cg
 When "ABANDON"     : Gosub ABANDON
 When Default
Endcase
Return

#######################################################################
$OUVRE
If clalev ([F:BPA])<= 0  Local File BPADDRESS [BPA]  Endif
If clalev ([F:BPT])<= 0  Local File BPCARRIER [BPT]  Endif
#MAE, bg 79449
If clalev ([F:BPR])<= 0  Local File BPARTNER [BPR]  Endif
  If clalev ([F:BCG])<= 0  Local File BPCCATEG [BCG]  Endif   # FGR 27/04/2012 : X3SUIVI81767
Return

####################################################################
$FILTRE
#MAE, bg 79449
If GWEBSERV<>1
  FILTSUP = "[F:BPD]BPCNUM = GBPCNUM"
Endif
Return

####################################################################
$SETBOUT
#----------------------------------------------#
# Suppression bouton changement de code        #
# Suppression bouton annulation                #
#----------------------------------------------#
Call VIREBOUT(CHAINE, "AH") From GOBJET

# ---------------------------------------------------------------------------------------#
# Activation/Désactivation des menus                                                     #
# ---------------------------------------------------------------------------------------#
# C,D : Texte                 : Actif si client en ligne ou création ou duplication      #
# ---------------------------------------------------------------------------------------#
If find(GREP,"C","D")| CLECUR CHMEN += "CD"      Endif
Gosub SET_BOUT_SPE From GSAISIE
Return
####################################################################
$AFFMASK
Diszo [M:BPD0]BPCNUM
Return
###########################################################################################
#    Avant l'execution des boutons et des menus                                           #
###########################################################################################
$AVANTBOUT
#Local Integer  WRETOUR
#Local Char     WNUMTEX(12), WCLE1, WCLE2
#Local Integer  WMODULE : WMODULE=9
#Local Char     WTYP(4)
#Case BOUT
#    When "C" :  WRETOUR = 0        : # texte bon préparation
#                WTYP="BPD1"
#                WNUMTEX = [M]PRPTEX
#-- Si duplication, recuperation du texte du client que l'on duplique
#                   ("D" : Duplication sans saisie)
#                If GREP = "D"
#                    If ANC_PRPTEX = [M]PRPTEX & WNUMTEX <> ""
#                        Call TEX(9,"BPD1","","","",WNUMTEX,"X",WRETOUR) From TRTX3TEX
#                    Endif
#                Elsif GREP <> "C"
#                    WCLE1 = [M]BPCNUM
#                    WCLE2 = [M]BPAADD
#                Endif
#    When "D" :  WRETOUR = 0        : # texte bon livraison
#                WTYP="BPD2"
#                WNUMTEX = [M]DLVTEX
#-- Si duplication, recuperation du texte du client que l'on duplique
#                   ("D" : Duplication sans saisie)
#                If GREP = "D"
#                    If ANC_DLVTEX = [M]DLVTEX & WNUMTEX <> ""
#                        Call TEX(9,"BPD2","","","",WNUMTEX,"X",WRETOUR) From TRTX3TEX
#                    Endif
#                Elsif GREP <> "C"
#                    WCLE1 = [M]BPCNUM
#                    WCLE2 = [M]BPAADD
#                Endif
#Endcase
Return
###########################################################################################
#    Après execution des menus;;                                                          #
###########################################################################################
$STATUT

Case BOUT
    When "C"    : If mkstat=4 & GREP=""
                    #MAE, bg 50938
                    #GREP="M" : REP="M"
                    #Gosub SETBOUT From GOBJSUB
                    Gosub ENTRE_MODIF From GOBJSUB
                  Endif
                  If [M]PRPTEX <> ""
                     #MAE, bg51481 [M]WPRPTEX = 2
                     [M]TWPRPTEX = 2
                  Else
                     #MAE, bg51481 [M]WPRPTEX = 1
                    [M]TWPRPTEX = 1

                  Endif
                  Affzo [M:BPD1]20
    When "D"    : If mkstat=4 & GREP=""
                     #MAE, bg 50938
                     #GREP="M" : REP="M"
                     #Gosub SETBOUT From GOBJSUB
                     Gosub ENTRE_MODIF From GOBJSUB
                  Endif
                  If [M]DLVTEX <> ""
                     #MAE, bg51481 [M]WDLVTEX = 2
                    [M]TWDLVTEX = 2
                  Else
                     #MAE, bg51481 [M]WDLVTEX = 1
                    [M]TWDLVTEX = 1
                  Endif
                  Affzo [M:BPD1]20
Endcase

Return
####################################################################
$LIENS
#-----------------------------------------------------------#
# A CHAQUE LECTURE ENREGISTREMENT CLIENT LIVRE (BPDLVCUST)  #
#    --> il faut lire l'enregistrement addresse (BPADDRESS) #
#-----------------------------------------------------------#
####################################################################

If GFONC1="GESBPD" Call RAZ_CLOB From ACLOB Endif
#MAE, bg 51481
#[M]WPRPTEX = 2
#If [M]PRPTEX = "" [M]WPRPTEX = 1 Endif
#[M]WDLVTEX = 2
#If [M]DLVTEX = "" [M]WDLVTEX = 1 Endif

[M]TWPRPTEX = 2
If [M]PRPTEX = "" [M]TWPRPTEX = 1 Endif
[M]TWDLVTEX = 2
If [M]DLVTEX = "" [M]TWDLVTEX = 1 Endif

Read [BPA]BPA0 = 1;[M:BPD0]BPCNUM;[M:BPD0]BPAADD
If fstat = 0
    [M:BPD2] = [F:BPA]
    [M:BPD2]ADDLIG1 = [F:BPA]BPAADDLIG(0)
    [M:BPD2]ADDLIG2 = [F:BPA]BPAADDLIG(1)
    [M:BPD2]ADDLIG3 = [F:BPA]BPAADDLIG(2)
    [M:BPD1]BPAADD  = [F:BPA]BPAADD
    [M:BPD1]BPADES  = [F:BPA]BPADES
Else
    Raz [M:BPD2]
Endif
If [F:TCY]CRY<>[M:BPD2]CRY
    Read [TCY]TCY0 = [M:BPD2]CRY
    If fstat Raz [F:TCY] Endif
Endif
#If [F:TCY]ETAT<>2 #X3-38357 Field State in a new address from Sales order
If [F:TCY]ETAT<2 #X3-38357 LCC 03/01/18
    Grizo [M:BPD2]SAT
Else
    Actzo [M:BPD2]SAT
Endif
Gosub TITRES From W1BPD2

If [F:BPR]BPRNUM<>[M:BPD0]BPCNUM
    Read [BPR]BPR0 = [M:BPD0]BPCNUM
    If fstat Raz [F:BPR] Endif
Endif
[M:BPD1]FCY=[F:BPR]FCY
If [M]FCY = "" Grizo [M:BPD1]RCPFCY
Else           Actzo [M:BPD1]RCPFCY : Endif

If [F:BPC]BPCNUM<>[M:BPD0]BPCNUM
    Read [BPC]BPC0 = [M:BPD0]BPCNUM
    If fstat Raz [F:BPC] Endif
Endif
If [F:BPC]BPDADD=[M]BPAADD [M]BPDADDFLG=2 Else [M]BPDADDFLG=1 Endif

# Le régime de taxe ne doit pas être initialisé à partir du client
#If [M]VACBPR="" [M]VACBPR= [F:BPC]VACBPR Endif

If [M:BPD1]FFWNUM="" Diszo [M:BPD1]FFWADD Else Actzo [M:BPD1]FFWADD Endif

If [M:BPD1]STOFCY=""
    If dim([M:BPD1]BPCLOC)>0 : Diszo [M:BPD1]BPCLOC  : Endif
    If dim([M:BPD1]SCOLOC)>0 : Diszo [M:BPD1]SCOLOC  : Endif
Else
    If dim([M:BPD1]BPCLOC)>0 : Actzo [M:BPD1]BPCLOC  : Endif
    If dim([M:BPD1]SCOLOC)>0 : Actzo [M:BPD1]SCOLOC  : Endif
Endif

If dim([M:BPD1]SSTENTCOD) > 0                 #LTA.sn
    [M:BPD1]SSTENTCOD = [F:BPD]SSTENTCOD
    Call SHOW_HIDE_ENTCOD([M:BPD2]CRY)
Endif                                         #LTA.en

Return

###############################################################
#LTA.sn
Subprog SHOW_HIDE_ENTCOD(SCRY)
Value Char SCRY

  If dim([M:BPD1]SSTENTCOD) > 0 Then
    #When ENTCOD field exists, hide it and ShortDescript if the country is unsupported by SST
    If !(func TRTADRLIB.CHKADR_CRY(SCRY))
      # Hide enterable
      #116311.so - JOBRO
      #Chgfmt [M:BPD1]SSTENTCOD    With "-K:5B"
      #If dim([M:BPD1]ZSSTENTCOD) >= 0 Then
      #  Chgfmt [M:BPD1]ZSSTENTCOD With "-KP:12X"
      #Endif
      #116311.eo - JOBRO
      Chgfmt [M:BPD2]ADRVAL       With "-K:10X"
      Chgfmt [M:BPD2]VALADR       With "-K:3X"
    Else
      # Show enterable
      #116311.so - JOBRO
      #Chgfmt [M:BPD1]SSTENTCOD    With "K:" + num$(type([M:BPD1]SSTENTCOD)-10) + "B"
      #If dim([M:BPD1]ZSSTENTCOD) >= 0 Then
      #  Chgfmt [M:BPD1]ZSSTENTCOD With "KP:" + num$(type([M:BPD1]ZSSTENTCOD)-10) + "X"
      #Endif
      #116311.eo - JOBRO
      Chgfmt [M:BPD2]ADRVAL       With "LA:" + "1"
      Chgfmt [M:BPD2]VALADR       With "K:" + num$(GLONICO) + "X"
    Endif
  Endif
End
#LTA.en
###############################################################
$RAZCRE
  Call RAZ_CLOB From ACLOB
  [M:BPD0]BPCNUM=GBPCNUM
  #
  Read [BPR]BPR0=[M:BPD0]BPCNUM
  # FGR 27/04/2012 : X3SUIVI81767 (début)
  Read [BPC]BPC0=[M:BPD0]BPCNUM
  If fstat
    Raz [F:BPC]
  Endif
  If [F:BPC]BCGCOD = "" Then
    Raz [F:BCG]
  Else
    Read [BCG]BCG0=[F:BPC]BCGCOD
    If fstat Then
      Raz [F:BCG]
    Endif
  Endif
  # FGR 27/04/2012 : X3SUIVI81767 (fin)
  #
  [M:BPD1]BPDNAM(0)    = [F:BPR]BPRNAM(0)
  [M:BPD1]BPDNAM(1)    = [F:BPR]BPRNAM(1)
  [M:BPD1]LAN          = [F:BPR]LAN
  [M:BPD1]FCY          = [F:BPR]FCY
  # FGR 27/04/2012 : X3SUIVI81767 (début)
  #  [M:BPD1]STOFCY       = GFCYDEF(7)
  #  [M:BPD1]NPRFLG       = 1
  #  [M:BPD1]NDEFLG       = 2
  #  [M:BPD1]DRN          = 1
  #  [M:BPD1]DLVPIO       = 1
  #  [M:BPD1]UVYDAY1      = 2
  #  [M:BPD1]UVYDAY2      = 2
  #  [M:BPD1]UVYDAY3      = 2
  #  [M:BPD1]UVYDAY4      = 2
  #  [M:BPD1]UVYDAY5      = 2
  #  [M:BPD1]UVYDAY6      = 2
  #  [M:BPD1]UVYDAY7      = 2
  #  [M:BPD1]PRPTEX       = ""
  #  [M:BPD1]DLVTEX       = ""
  #  #MAE, bg 51481
  #  #[M:BPD1]WPRPTEX      = 1
  #  #[M:BPD1]WDLVTEX      = 1
  #  [M:BPD1]TWPRPTEX      = 1
  #  [M:BPD1]TWDLVTEX      = 1
  #  If dim([M:BPD1]EECINCRAT)>0 [M:BPD1]EECINCRAT=1 Endif
  #  Call LECTURE("FCY",[M:BPD1]STOFCY,"") From CONTOBJ
  #  [M:BPD1]BPTNUM       = [F:FCY]BPTNUM
  [M:BPD1]TWPRPTEX     = 1
  [M:BPD1]TWDLVTEX     = 1
  If [F:BCG]BCGCOD <> "" Then
    [M:BPD1] = [F:BCG]
    # ----------------------
    If [M:BPD1]PRPTEX <> "" Then
      [M:BPD1]TWPRPTEX = 2
    Endif
    If [M:BPD1]DLVTEX <> "" Then
      [M:BPD1]TWDLVTEX = 2
    Endif
  Endif
  #
  If [M:BPD1]STOFCY = "" Then
    [M:BPD1]STOFCY = GFCYDEF(7)
  Endif
  # FGR 27/04/2012 : X3SUIVI81767 (fin)

  [M:BPD2]BPADES       = [F:BPR]BPRSHO
  [M:BPD2]CRY          = [F:BPR]CRY
  Call INIPAYS([M:BPD2]CRY, [M:BPD2]CRYNAM) From TRTDIV    # FGR 20/01/2013 : X3SUIVI95536

  If [M]FCY = "" Grizo [M:BPD1]RCPFCY
  Else           Actzo [M:BPD1]RCPFCY : Endif

#  If [F:BPC]BPCNUM<>[M:BPD0]BPCNUM
#      Read [BPC]BPC0 = [M:BPD0]BPCNUM
#      If fstat Raz [F:BPC] Endif
#  Endif
  # Le régime de taxe ne doit pas être initialisé à partir du client (note FGR 27/04/2012 : X3SUIVI81767 il arrive de la catégorie)
  #[M:BPD1]VACBPR=[F:BPC]VACBPR

  If [M:BPD1]STOFCY=""
      If dim([M:BPD1]BPCLOC)>0 : Diszo [M:BPD1]BPCLOC  : Endif
      If dim([M:BPD1]SCOLOC)>0 : Diszo [M:BPD1]SCOLOC  : Endif
  Else
      If dim([M:BPD1]BPCLOC)>0 : Actzo [M:BPD1]BPCLOC  : Endif
      If dim([M:BPD1]SCOLOC)>0 : Actzo [M:BPD1]SCOLOC  : Endif
  Endif

  If [M:BPD1]FFWNUM="" Diszo [M:BPD1]FFWADD Else Actzo [M:BPD1]FFWADD Endif : # Bug 66945

  Affzo [M:BPD1]1-99
  Affzo [M:BPD2]1-99
Return

