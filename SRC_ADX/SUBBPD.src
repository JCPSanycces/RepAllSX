######################################################################################
## Etiquette ajoutée par le superviseur (écran BPD1) 07/11/2005 09:51:21 (LD)
######################################################################################
Subprog C_ENAFLG(VALEUR)
Variable Integer VALEUR
# Le client livré par défaut ne doit pas être inactif
If VALEUR<>2 & [M]BPDADDFLG=2 mkstat=2 : GMESSAGE=mess(511,199,1) : End : Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran BPD1) 07/12/2005 09:16:58 (LD)
######################################################################################
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR="" End Endif
If [M]RCPFCY<>"" & VALEUR=[M]RCPFCY mkstat=2 : GMESSAGE=mess(259,194,1) : End Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran BPD1) 28/11/2005 10:58:06 (LD)
######################################################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
    If dim([M:BPD1]BPCLOC)>0 : Raz [M:BPD1]BPCLOC : Diszo [M:BPD1]BPCLOC  : Endif
    If dim([M:BPD1]SCOLOC)>0 : Raz [M:BPD1]SCOLOC : Diszo [M:BPD1]SCOLOC  : Endif
Else
    If dim([M:BPD1]BPCLOC)>0 : Actzo [M:BPD1]BPCLOC  : Endif
    If dim([M:BPD1]SCOLOC)>0 : Actzo [M:BPD1]SCOLOC  : Endif
Endif
End
######################################################################################
########################################
Subprog C_RCPFCY(VALEUR)
Variable Char    VALEUR()

Local    Char    WLEGCPY
# Bug 33874
#If VALEUR="" | [M]FCY="" End Endif
If [M]FCY="" End Endif
If VALEUR="" mkstat=2 : GMESSAGE=mess(10,123,1) : End Endif
If [M]STOFCY<>"" & VALEUR=[M]STOFCY mkstat=2 : GMESSAGE=mess(259,194,1) : End Endif
# Le site de réception peut être référencé sur un autre client mais
# il ne doit pas être référencé sur une autre adresse de livraison de ce client
Columns [BPD] (BPCNUM, BPAADD, RCPFCY)
Filter [BPD] Where [BPD]RCPFCY=VALEUR & [BPD]BPCNUM=[M:BPD0]BPCNUM & [BPD]BPAADD<>[M:BPD0]BPAADD
Read [BPD]BPD0 First
Filter [BPD]
Columns [BPD]
If !fstat
    GMESSAGE = mess(350,198,1)-":"-mess(414,199,1)-":"-[F:BPD]BPCNUM-[F:BPD]BPAADD : mkstat=2 : End
Endif
If [M]FCY=VALEUR End Endif
# Site de réception et Site rattaché au client (Site de commande)
# doivent être sur la même société juridique
WLEGCPY=[F:FCY]LEGCPY
# Récup de la société juridique du site rattaché au client
Read [FCY]FCY0=[M]FCY
If fstat Raz [FCY] Endif
If [F:FCY]LEGCPY<>WLEGCPY mkstat=2 : GMESSAGE=mess(401,199,1) : Endif

End

##########################################################################
## Etiquette ajoutée par le superviseur 21/06/2004 16:01:24 (LD)
##########################################################################
Subprog AV_BPCLOC(VALEUR)
Variable Char    VALEUR()
GLOCSEL = "[F:STC]LOCCAT=3"
End
##########################################################################
## Etiquette ajoutée par le superviseur 12/08/2004 10:16:21 (LD)
##########################################################################
Subprog AV_SCOLOC(VALEUR)
Variable Char    VALEUR()
GLOCSEL = "[F:STC]LOCCAT=4"
End
########################################
Subprog C_SCOLOC(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If VALEUR="" End Endif

Columns [BPD] (BPCNUM,BPAADD,BPDNAM,SCOLOC)
For [BPD] Where SCOLOC=VALEUR
   If [F:BPD]BPCNUM<>[M:BPD0]BPCNUM | [F:BPD]BPAADD<>[M:BPD0]BPAADD
      GMESSAGE=mess(470,199,1)-":"-[F:BPD]BPCNUM-[F:BPD]BPAADD-"-"-[F:BPD]BPDNAM
      Call AVERTIR(GMESSAGE,OK) From GESECRAN
      Raz GMESSAGE
      If OK=1 OK=0 : mkstat=2 : Break : Endif
   Endif
Next
Columns [BPD]
End
########################################
Subprog AM_MDL(VALEUR)
Variable Char    VALEUR()
If clalev ([F:TMD]) <= 0 Local File TABMODELIV [TMD] Endif

[M]EECICT = [F:TMD]EECICT
If dim([M]EECLOC)>0
   [M]EECLOC = [F:TMD]EECLOC
   Affzo [M]EECLOC
Endif
Affzo [M]EECICT
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran BPD1) 09/05/2005 11:35:18 (LD)
######################################################################################
Subprog AM_FFWNUM(VALEUR)
Variable Char    VALEUR()

If VALEUR="" Raz [M]FFWADD : Affzo [M]FFWADD : Diszo [M]FFWADD : End : Endif

[M:BPD1]FFWADD=[F:BPT]BPAADD
Affzo [M:BPD1]FFWADD : Actzo [M:BPD1]FFWADD

End
########################################
Subprog C_FFWADD(VALEUR)
Variable Char    VALEUR()

If [M:BPD1]FFWNUM<>"" : # Bug 66945
    Look [BPA]BPA0 = 1;[M:BPD1]FFWNUM;VALEUR
    If   fstat : GMESSAGE = mess(16,199,1) : mkstat = 2 : Endif
Endif

End
