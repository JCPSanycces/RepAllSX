#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PLN1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:00"
A_USER  = "DOC"
A_STAMP = "20181109230600"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRWEK"
  If [M]NBRWEK=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PLN1 [PLN1]
Gosub HORODAT
Local Inpbox "PLN1" From GFONCTION At A_STAMP With A_WINDPREV Mask [PLN1] As [SIM_]
Grizo [PLN1]10
Grizo [PLN1]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PLN1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=4
X1(1)=1 : X2(1)=74 : Y1(1)=5 : Y2(1)=28
Return

$ON_COD
Onevent CONTROL Call C_COD(zc) From W1PLN1
Onevent BEFORE_INPUT Call AS_COD(zc) From W1PLN1
Return

Subprog AS_COD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(46606,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_COD(zc) From W1PLN1
Onkey   2 Titled GBOUTS Call S_COD(zc) From W1PLN1
Gosub _AFF
End

Subprog C_COD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
If !mkstat
 ## Action CONTPLN
 Call CONTPLN(VALEUR) From SUBPLN
 If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
  If !mkstat
   ## Action CONTOBJW
   Local Char    PARMSK(250)(1..20) , SAVACT(20)
   SAVACT = GACTION : GACTION = "CONTOBJW"
   PARMSK(1) = "PLN"
   Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJW","CONTOBJ","") From GACTION
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_COD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELOBJW
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELOBJW"
 PARMSK(1) = "PLN"
 PARMSK(2) = ""
 PARMSK(3) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_COD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNPLN
 Call TUNPLN(VALEUR) From SUBPLN
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_FIRDAY
Onevent AFTER_CHANGE Gosub AMM_FIRDAY From W1PLN1
Onevent INIT_AREA Call D_FIRDAY(zc) From W1PLN1
Onevent BEFORE_INPUT Call AS_FIRDAY(zc) From W1PLN1
Onevent CONTROL Call C_FIRDAY(zc) From W1PLN1
Return

Subprog D_FIRDAY(VALEUR)
Variable Integer VALEUR
If varinit([M]FIRDAY,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_FIRDAY(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog C_FIRDAY(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "FIRDAY" : GZNUM = 45280 : Endif
Gosub _AFF
End

$AMM_FIRDAY
Call AM_FIRDAY(zc)
If !mkstat & GOBJET
 zoncou = "FIRDAY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_FIRDAY(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_FIRDAY(VALEUR) From SUBPLN
If mkstat : GERR = 1 : GZONE = "FIRDAY" : GZNUM = 45280 : Endif
Gosub _AFF
End

$ON_YEA
Onevent CONTROL Call C_YEA(zc) From W1PLN1
Onevent AFTER_CHANGE Gosub AMM_YEA From W1PLN1
Onevent INIT_AREA Call D_YEA(zc) From W1PLN1
Return

Subprog D_YEA(VALEUR)
Variable Decimal VALEUR
If varinit([M]YEA,indice)=0
 VALEUR = year(date$)
Endif
Gosub _AFF
End

Subprog C_YEA(VALEUR)
Variable Decimal VALEUR
If !GWEBSERV
 ## Action STD
 Call C_YEA(VALEUR) From SUBPLN
 If mkstat : GERR = 1 : GZONE = "YEA" : GZNUM = 1879 : Endif
Endif
Gosub _AFF
End

$AMM_YEA
Call AM_YEA(zc)
If !mkstat & GOBJET
 zoncou = "YEA" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_YEA(VALEUR)
Variable Decimal VALEUR
## Action STD
Call AM_YEA(VALEUR) From SUBPLN
If mkstat : GERR = 1 : GZONE = "YEA" : GZNUM = 1879 : Endif
Gosub _AFF
End

$ON_LEG
Onevent INIT_AREA Call D_LEG(zc) From W1PLN1
Onevent CONTROL Call C_LEG(zc) From W1PLN1
Onevent AFTER_CHANGE Gosub AMM_LEG From W1PLN1
Onevent BEFORE_INPUT Call AS_LEG(zc) From W1PLN1
Return

Subprog D_LEG(VALEUR)
Variable Char    VALEUR()
If varinit([M]LEG,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"909","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_LEG(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"909") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_LEG(zc) From W1PLN1
Onkey   2 Titled GBOUTS Call S_LEG(zc) From W1PLN1
Onkey 144 Titled GBOUTP Call P_LEG(zc) From W1PLN1
Onkey 146 Titled GBOUTA Call SA_LEG(zc) From W1PLN1
If VALEUR="" : Call INIADI(VALEUR,"909") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"909","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"909",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_LEG
Call AM_LEG(zc)
If !mkstat & GOBJET
 zoncou = "LEG" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_LEG(VALEUR) From SUBPLN
If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZLEG)")>indice
 [M]LEG(indice) = VALEUR
 Affzo ZLEG(indice)
Endif
Gosub _AFF
End

Subprog S_LEG(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "909"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_LEG(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"909") From GOBJET
Gosub _AFF
End

Subprog SA_LEG(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "909"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_LEG(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "909"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZLEG
Onevent BEFORE_AREA Gosub AV_ZLEG From W1PLN1
Return

$AV_ZLEG
Call LECTEXTRA(zc,"ATABDIV","LNGDES","909",num$([M]LEG(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_DAT1
Onevent BEFORE_AREA Gosub AV_DAT1 From W1PLN1
Return

$AV_DAT1
Chgfmt [M]DAT1(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_DAT2
Onevent BEFORE_AREA Gosub AV_DAT2 From W1PLN1
Return

$AV_DAT2
Chgfmt [M]DAT2(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_WEKTYP
Onevent CONTROL Call C_WEKTYP(zc) From W1PLN1
Onevent BEFORE_INPUT Call AS_WEKTYP(zc) From W1PLN1
Return

Subprog AS_WEKTYP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(55957,GBOUT1) From OBJDIV
Call TEXTE(47557,GBOUT2) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_WEKTYP(zc) From W1PLN1
Onkey 130 Titled GBOUT2 Call B2_WEKTYP(zc) From W1PLN1
Onkey   2 Titled GBOUTS Call S_WEKTYP(zc) From W1PLN1
Onkey 144 Titled GBOUTP Call P_WEKTYP(zc) From W1PLN1
Onkey 146 Titled GBOUTA Call SA_WEKTYP(zc) From W1PLN1
Gosub _AFF
End

Subprog C_WEKTYP(VALEUR)
Variable Char    VALEUR()
## Action CONTOBJN
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "CONTOBJN"
Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "WEKTYP" : GZNUM = 55957 : Endif
If !mkstat
 ## Action CONTSTY
 Call CONTSTY(VALEUR) From SUBSTY
 If mkstat : GERR = 1 : GZONE = "WEKTYP" : GZNUM = 55957 : Endif
 If !mkstat
  ## Action STD
  Call C_WEKTYP(VALEUR) From SUBPLN
  If mkstat : GERR = 1 : GZONE = "WEKTYP" : GZNUM = 55957 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_WEKTYP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELSTY
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELSTY"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELSTY","SUBSTY","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_WEKTYP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNSTY
 Call TUNSTY(VALEUR) From SUBSTY
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_WEKTYP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STD
 Call B2_WEKTYP(VALEUR) From SUBPLN
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_WEKTYP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "STY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_WEKTYP(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("STY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$CHG_STY
Return


