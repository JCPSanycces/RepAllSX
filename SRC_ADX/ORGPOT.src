#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"ORGPOT","ORGPOT","DORGPOT",3,"") From GTRAITE
End
##########################################################################

$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "INIT_DIA" : Raz [M:DIA]
 When "DEBUT"    : Gosub DEBUT
 When "BOUTON"   : Gosub BOUTON
 When "TERMINE"  : Gosub TERMINE
Endcase
Return

# FQ61463 - SBA 26/06/2013 - Homogénéisation nom prénom
$INIT
If clalev([F:ID])=0     : Local File EMPLOID  [ID]    : Endif
If clalev([F:ID3])=0    : Local File EMPLOID  [ID3]   : Endif # FQ61463 - SEGAY 29/07/2013 - Homogénéisation nom prénom
Return

$DEBUT
If clalev([F:POT])=0    : Local File POSTE    [POT]   : Endif
If clalev([F:EPO])=0    : Local File EMPLOPOT [EPO]   : Endif
If clalev([F:EPOB])=0   : Local File EMPLOPOT [EPOB]  : Endif
If clalev([F:ID])=0     : Local File EMPLOID  [ID]    : Endif
If clalev([F:BBB])=0    : Local File BBLOB    [BBB]   : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR [HRCTR] : Endif
If clalev([F:ASB])=0    : Local File ABLBSYS  [ASB]   : Endif
If clalev([F:ACV])=0    : Local File ACTIV    [ACV]   : Endif

Local Integer I, J, K, COMPTEUR, ARRET, TROUVE
Local Char    POSTE(GLONPOT), CRITERE(250)
If [M:DIA]CPY<>""
 CRITERE = "[POT]CPYPOT='"+[M:DIA]CPY+"'"
Else
 CRITERE = "1=1"
Endif

## Récupération sous le répertoire RES de X3_PUB des photos inconnus
Read [ASB]ASB0="MIS";"INCONNUH"
If !fstat
 Local Char PHOTO(250)
 PHOTO = filpath(nomap+"\RES","inconnuh","jpg","X3_PUB")
 If (filinfo(PHOTO,0)<0 | filinfo(PHOTO,7)=0) and len([F:ASB]BLOB)>0
  Openo PHOTO,0
  Putseq 1,[F:ASB]BLOB
  Openo
 Endif
Endif

Read [ASB]ASB0="MIS";"INCONNUF"
If !fstat
 Local Char PHOTO(250)
 PHOTO = filpath(nomap+"\RES","inconnuf","jpg","X3_PUB")
 If (filinfo(PHOTO,0)<0 | filinfo(PHOTO,7)=0) and len([F:ASB]BLOB)>0
  Openo PHOTO,0
  Putseq 1,[F:ASB]BLOB
  Openo
 Endif
Endif

Read [ASB]ASB0="MIS";"VACANT"
If !fstat
 Local Char PHOTO(250)
 PHOTO = filpath(nomap+"\RES","vacant","jpg","X3_PUB")
 If (filinfo(PHOTO,0)<0 | filinfo(PHOTO,7)=0) and len([F:ASB]BLOB)>0
  Openo PHOTO,0
  Putseq 1,[F:ASB]BLOB
  Openo
 Endif
Endif

Raz [M:OPOT]
nolign = 0
If [M:DIA]POT=""
 For [POT] Where evalue(CRITERE)
  Gosub REMPLIT
 Next
 # On efface les postes non rattachés hiérarchiquement
 [M]NBROPOT = nolign
 J = nolign
 For I=J-1 To 0 Step -1
  If [M:OPOT]PARENT(I)="" & !find([M:OPOT]KEYC(I),[M:OPOT]PARENT)
   Dela I,1 [M:OPOT]NBROPOT
   [M:OPOT]NBROPOT -=1
  Endif
 Next
Else
 Read [POT]POT0=[M:DIA]POT
 Gosub REMPLIT
 [M:OPOT]PARENT(0) = "" : # Pour l'organigramme
 I = 0
 While [M:OPOT]KEYC(I)<>""
  POSTE = [M:OPOT]KEYC(I)
  For [POT]POT3 Where POT2=POSTE
   Gosub REMPLIT
  Next
  I +=1
 Wend
 [M]NBROPOT = nolign
Endif
Gosub AFFECT_NUM
Sorta [M]NBROPOT [M]NBROPOT Order By [M]NUM([S]indice)
Affzo [M:OPOT]
If [M:OPOT]NBROPOT<>0
 REPORT1 = "ORGPOT"
Endif
If find("",[M]PARENT(1..[M]NBROPOT-1))
 # L'organigramme ne peut représenter qu'une seule hiérarchie alors qu'il y en a plusieurs.
 Call AVERTIR(mess(40,10720,1),OK) From GESECRAN
Endif
# Titre
GMESSAGE = mess(43,10720,1) : # Organigramme
If [M:DIA]POT<>""
 GMESSAGE -= mess(44,10720,1)-[M:DIA]POT-"("+mess(26,113,1)-[M:DIA]CPY+")" : # Poste, société
Else
 GMESSAGE -= mess(26,113,1)-[M:DIA]CPY
Endif
Chgtbk [OPOT]5 With GMESSAGE
GMESSAGE=""
Return

$REMPLIT
Raz OK
# Liste des salariés rattachés au poste : un poste peut être multi salariés
Filter [EPO] Where POT=[F:POT]COD
For [EPO]EPO1
 Filter [EPOB] Where REFNUM=[F:EPO]REFNUM & CTRNUM=[F:EPO]CTRNUM
 Read [EPOB]EPO1 Last
 Filter [EPOB]
 If [F:EPOB]POT=[F:EPO]POT & [F:EPOB]DATPOT=[F:EPO]DATPOT
  # On ne retient que les salariés pour lesquels ce poste est le dernier
  Filter [HRCTR] Where REFNUM=[F:EPO]REFNUM & CTRNUM=[F:EPO]CTRNUM & CTRDAT<=[F:EPO]DATPOT
  Read [HRCTR]CTR1 Last
  Filter [HRCTR]
  If [F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>date$
  # On ne retient que les salariés encore dans la société
   [M:OPOT]PARENT(nolign) = [F:POT]POT2
   [M:OPOT]KEYC(nolign)   = [F:POT]COD
#  SEGAY 03/08/12 To manage translated texts (data type AX3 & AX1)
#   [M]LIBSHORT(nolign)    = [F:POT]DESSHO
#   [M]DESLIB(nolign)      = [F:POT]DES
   Call LECTEXTRA([M]LIBSHORT(nolign),"POSTE","DESSHO",[F:POT]COD,"") From ATEXTRA
   Call LECTEXTRA([M]DESLIB(nolign),"POSTE","DES",[F:POT]COD,"") From ATEXTRA
   [M]LIBL(nolign)        = [F:EPO]REFNUM
   Read [ID]ID0=[F:EPO]REFNUM
   [M]NOM(nolign)         = [F:ID]NAM-[F:ID]SRN
   If [F:ID]SEX=1 : # Masculin
    [M]IMG(nolign)        = "inconnuh.jpg"
   Else
    [M]IMG(nolign)        = "inconnuf.jpg"
   Endif
   Read [BBB]BBB0="EMPPIC";[F:ID]REFNUM;"";"";""
   If !fstat
    Local Char PHOTO(250)
    PHOTO = filpath(nomap+"\RES",[F:ID]REFNUM,"","X3_PUB")
    If ( filinfo(PHOTO,0)<0 | filinfo(PHOTO,7)=0
&      | filinfo(PHOTO,9)<=([F:BBB]CREDAT-[1/1/1970])*86400+[F:BBB]CRETIM
&      )
&    & len([F:BBB]BLOB)>0
     Openo PHOTO,0
     Putseq 1,[F:BBB]BLOB
     Openo
    Endif
    If len([F:BBB]BLOB)>0
##PEVAN 2017-11-29 X3-66274 START
##JOJAC - 2016-03-23 - REQ114309 US93 - START
#     [M]IMG(nolign) = [F:ID]REFNUM
#     #[M]IMG(nolign) = [F:ID]REFNUM+".jpg" - AS PER U9 - reverted back to original source
##JOJAC - 2016-03-23 - REQ114309 US93 - END
     [M]IMG(nolign) = [F:ID]REFNUM+".jpg"
##PEVAN 2017-11-29 X3-66274 END
    Endif
   Endif
   nolign +=1
   OK =1
  Endif
 Endif
Next
If OK=0
 # Personne n'occupe ce poste
 [M:OPOT]PARENT(nolign) = [F:POT]POT2
 [M:OPOT]KEYC(nolign)   = [F:POT]COD
#  SEGAY 03/08/12 To manage translated texts (data type AX3 & AX1)
# [M]LIBSHORT(nolign)    = [F:POT]DESSHO
# [M]DESLIB(nolign)      = [F:POT]DES
 Call LECTEXTRA([M]LIBSHORT(nolign),"POSTE","DESSHO",[F:POT]COD,"") From ATEXTRA
 Call LECTEXTRA([M]DESLIB(nolign),"POSTE","DES",[F:POT]COD,"") From ATEXTRA
 [M]NOM(nolign)         = mess(45,10720,1) : # Vacant
 [M]IMG(nolign)         = "vacant.jpg"
 nolign += 1
Endif
Filter [EPO]
Return

$AFFECT_NUM
J = find("",[M:OPOT]PARENT)
J -=1
[M:OPOT]NUM(J) = 1
COMPTEUR = 1
ARRET = 0
Repeat
 TROUVE = 0
 For I=0 To [M:OPOT]NBROPOT-1
  If [M:OPOT]PARENT(I)=[M:OPOT]KEYC(J) & [M:OPOT]NUM(I)=0
   J = I
   COMPTEUR +=1
   [M:OPOT]NUM(J) = COMPTEUR
   TROUVE = 1
   Break
  Endif
 Next
 If TROUVE=0
  For I=0 To [M:OPOT]NBROPOT-1
   If [M:OPOT]PARENT(I)=[M:OPOT]KEYC(J) & [M:OPOT]NUM(I)=0
    J = I
    COMPTEUR +=1
    [M:OPOT]NUM(J) = COMPTEUR
    TROUVE = 1
    Break
   Endif
  Next
 Endif
 If TROUVE=0
  # On chercher le père pour redescendre une branche
  For K=0 To [M:OPOT]NBROPOT-1
   If [M:OPOT]PARENT(J)=[M:OPOT]KEYC(K)
    J = K
    TROUVE = 1
    Break
   Endif
  Next
  If TROUVE=0 : ARRET = 1 : Endif
 Endif
Until ARRET=1
Return

$BOUTON
If BOUT="O" : # Bouton Critères
 FIN = 1
Endif
Return

$TERMINE
If GSTATUT=GSTAESC : # Bouton Fin
 FIN = 1
Else : # Bouton critères
 SAI = 1
Endif
Return

######################################################################################
## Etiquette écran DORGPOT
######################################################################################
Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()

If clalev([F:EPO])=0  : Local File EMPLOPOT    [EPO] : Endif
If clalev([F:POT])=0  : Local File POSTE       [POT] : Endif
 # FQ61463 - SBA 26/06/2013 - Homogénéisation nom prénom
Call UPD_NAMSRN(VALEUR,"[M:DIA]","NAM","SRN",0,0) From DIVPAYE

If VALEUR<>""
 Filter [EPO] Where REFNUM=VALEUR
 Read[EPO]EPO1 Last
 Filter [EPO]
 If !fstat
  [M:DIA]POT = [F:EPO]POT
  Read[POT]POT0=[F:EPO]POT
  If !fstat
   [M:DIA]CPY = [F:POT]CPYPOT
#   Infbox([F:POT]CPYPOT)
  Else
   # Poste inexistant
   GMESSAGE = mess(33,10720,1)
   mkstat = 2 : End
  Endif
 Else
  # Pas de poste défini pour ce salarié
  GMESSAGE = mess(34,10720,1)
  mkstat = 2 : End
 Endif
 Grizo POT,CPY
Else
 Effzo POT,CPY
 Actzo POT,CPY
Endif
Affzo
End

Subprog AM_POT(VALEUR)
Variable Char    VALEUR()

If clalev([F:EPO])=0  : Local File EMPLOPOT    [EPO] : Endif
If clalev([F:POT])=0  : Local File POSTE       [POT] : Endif

If VALEUR<>""
 Read[POT]POT0=VALEUR
 If !fstat
  [M:DIA]CPY = [F:POT]CPYPOT
 Endif
 Filter [EPO] Where POT=VALEUR
 Read[EPO]EPO2 Last
 Filter [EPO]
 If !fstat
  [M:DIA]REFNUM = [F:EPO]REFNUM
 Endif
 Grizo REFNUM,CPY
Else
 Effzo REFNUM,CPY
 Actzo REFNUM,CPY
Endif
Affzo
End

######################################################################################
## Impression état ORGPOT
######################################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Local Char    PARAM(GDIMFIC), ETAT(GLONARP)
Local Integer NUMREQ

If clalev([F:ARM])=0 : Local File AREPORTM   [ARM] : Endif

Call GETPARAM("X3ETA",NBPAR,PARAMETRE,[L]ETAT) From ETAT
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) From ETAT
[L]NUMREQ = val(PARAM)
PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

Gosub TR1
Raz [F:ARM]
Call DEBTRANS From GLOCK
Gosub TR2
End

$TR1
GOK = 1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=[L]ETAT & USR=GUSER & CREDAT<date$
 If fstat=1
  GOK = -1 : GLOCK = "AREPORTM"-GUSER : Goto ROLL_TR1
 Endif
Commit
Return

$TR2
Trbegin [ARM]
 [F:ARM]USR     = GUSER
 [F:ARM]RPTCOD  = [L]ETAT
 [F:ARM]NUMREQ  = [L]NUMREQ
 For I=0 To [M:OPOT]NBROPOT-1
  [F:ARM]NUMLIG = I+1
  [F:ARM]CLEA1  = [M:OPOT]KEYC(I)
  [F:ARM]CLEA2  = [M:OPOT]PARENT(I)
  [F:ARM]CLEA3  = [M:OPOT]LIBL(I)
  [F:ARM]CREDAT = date$
  Write [F:ARM]
  If fstat
   GOK = 0 : Call FSTA("ARM") From GLOCK : Break
  Endif
 Next
 If !GOK : Goto AB_TR2 : Endif
Commit
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

$AB_TR2
Rollback
Return

######################################################################################
## Tunnel vers carrière (BY)
######################################################################################
Subprog IB_NBROPOT
#LIMAS 09/12/2017  X3-54462 START
#If [M]LIBL(nolign-1)=""
# Raz GBOUT1
#Endif
If [M:OPOT]NBROPOT >0 Then
 If [M]LIBL(nolign-1)=""
   Raz GBOUT1
  Endif
Else
  If [M]LIBL(nolign)=""
   Raz GBOUT1
 Endif
Endif
#LIMAS 09/12/2017  X3-54462 END
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran ORGPOT) 17/09/2010 16:52:53 (JML)
######################################################################################
Subprog B1_NBROPOT
If !GWEBSERV
 Read [ACV]CODACT="CAR"
 If !fstat & [F:ACV]FLACT=2
  ## Action GOBJETC
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "GOBJETC"
  Call OBJET_CHAR([M]LIBL(nolign-1),"ECP","") From GOBJET
  GACTION = SAVACT
 Else
  ## Action GOBJETC
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "GOBJETC"
  Call OBJET_CHAR([M]LIBL(nolign-1),"HRCTR","") From GOBJET
  GACTION = SAVACT
 Endif
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub AFF From GSAISIE
End
######################################################################################

# FQ81085 - MABON 19/07/12 - Reload GCURLEG if the company changes, in order to do the right selection of employees
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

  GCURLEG=""
  If VALEUR<>"" Then
    Read [F:CPY]CPY0=VALEUR
    If !fstat Then
      GCURLEG=[F:CPY]LEG
    Endif
  Endif
End
# End MABON
######################################################################################

