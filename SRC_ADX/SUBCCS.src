#<AdxTL>@(#)4.0.0.0 $Revision$
# Gestion du masque CERTIFCCS

Call OBJET("CCS",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "RAZCRE"      : Gosub RAZCRE
 When "LIENS"       : Call SETSTYLE([L]FEH,"AERROR") From GENFEH
 When "APRES_MODIF" : Call CONTZON([L]FEH,"AERROR",[L]COUZON,[L]CZ,[L]OK) From GENFEH
 When "EXEBOUT"     : If [L]BOUT="B" : Call CHGTZON([L]FEH,[L]LIBFLG) From GENFEH : Endif
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "CREATION"    : Gosub CREATION
 When "ANNULE"      : Gosub ANNULE
 When "ABANDON"     : Actzo [M]NUMCER
 When "SETBOUT"     : Gosub SETBOUT
 When "AP_IMPRIME"  : Affzo [M]STACCS
 When "FILTRE"      : Gosub FILTRE
 When "AAM_REFNUM","AB2_REFNUM"  : Gosub AAM_REFNUM : #US1840 81085 01/08/2013 Selection DISPLAY columns and title
 When "BAM_REFNUM","BB2_REFNUM"  : Gosub BAM_REFNUM : #US1840 81085 01/08/2013 Selection DISPLAY columns and title
 When Default
Endcase
Return

$FILTRE
If GUSRACS<>2
 FILTSUP = '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
 FILTSUP -= "& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))"
Else
 FILTSUP = "1=1"
Endif
Return

$OUVRE
If clalev([F:HRCTR])=0  : Local File EMPLOCTR   [HRCTR] : Endif
If clalev([F:FCY])=0    : Local File FACILITY   [FCY]   : Endif
If clalev([F:FCY2])=0   : Local File FACILITY   [FCY2]  : Endif
If clalev([F:FCY3])=0   : Local File FACILITY   [FCY3]  : Endif
If clalev([F:BPA])=0    : Local File BPADDRESS  [BPA]   : Endif
If clalev([F:AIN])=0    : Local File CONTACTCRM [AIN]   : Endif
If clalev([F:CNT])=0    : Local File CONTACT    [CNT]   : Endif
If clalev([F:PSN])=0    : Local File PRESTATION [PSN]   : Endif
If clalev([F:HSP])=0    : Local File HISTOPAYE  [HSP]   : Endif
If clalev([F:VEP])=0    : Local File VALEMP     [VEP]   : Endif
If clalev([F:FEL])=0    : Local File FILEDIL    [FEL]   : Endif
If clalev([F:FEH])=0    : Local File FILEDIH    [FEH]   : Endif
If clalev([F:AMZ])=0    : Local File AMSKZON    [AMZ]   : Endif

Local Libelle LIBFLG
Local Char    FEH([V]GLONADI)
FEH="CCS"
Gosub GENVAR From GENFEH
Return

$RAZCRE
Gosub GRISE_CLE From =[L]WINPROG
Call SETSTYLE([L]FEH,"AERROR") From GENFEH
[M]STACCS=1 : # Incorrect
Return

$INICRE
Local Integer NB
## Affectation du no de certificat
If [F:CCS]NUMCER=""
 Local Integer STAT
 # FQ71863 - MABON 28/02/11 - Le CTR0 référence le matricule en premier
# Read [HRCTR]CTR0=[F:CCS]CTRNUM
 Filter [HRCTR] Where REFNUM=[F:CCS]REFNUM & CTRNUM= [F:CCS]CTRNUM
 Read [F:HRCTR]CTR0 Last
 Filter [HRCTR]
 # Fin MABON
 If !fstat
  Read[FCY2]FCY0=[F:HRCTR]ETRFCY
  If !fstat
   Call NUMERO("CCS",[F:FCY2]CCSFCY,datesyst,"",[M]NUMCER,STAT) From SUBANM
   If STAT
    GMESSAGE = mess(4,10702,1)-"CCS" : # "ERREUR sur compteur"
    GOK = 0 : Return
   Endif
   [F:CCS]NUMCER = [M]NUMCER
   NB = len(ctrans([M]NUMCER,"0123456789",""))
   [F:CCS]NUMCERJOB = right$([M]NUMCER,NB+1)
   Affzo [M]NUMCER
  Endif
 Endif
Else
 NB = len(ctrans([M]NUMCER,"0123456789",""))
 [F:CCS]NUMCERJOB = right$([M]NUMCER,NB+1)
Endif
Gosub INIMOD
Return

$INIMOD
Call SETSTA([L]FEH,[F:CCS]STACCS)
[M]STACCS = [F:CCS]STACCS
Affzo [M]STACCS
Return

$SETBOUT
Call VIREBOUT(CHAINE,"HD") From GOBJET
If GREP="C"
 Actzo [M]REFNUM
Else
 Diszo [M]REFNUM
Endif
Return

$CREATION
Update [PSN] Where CTRNUM=[M]CTRNUM & BUL<>"" & NUMCER="" With NUMCER=[M]NUMCER
If fstat
 GOK = 0 : Call FSTA("PSN") From GLOCK : Return
Endif
Return

$ANNULE
Update [PSN] Where NUMCER=[M]NUMCER With NUMCER=""
If fstat
 GOK = 0 : Call FSTA("PSN") From GLOCK : Return
Endif
Return

#########################################################################
Subprog SETSTA(FEH,STA)
Value    Char    FEH()
Variable Libelle STA

Local Libelle NBERR

Gosub GENVAR From GENFEH
Gosub DEFVAR From GENFEH

Gosub DEFVAR From =[L]FEHTRT
Gosub LECMASQ  From =[L]FEHTRT

Onerrgo ERREURSTA
Gosub CONTROLE From =[L]FEHTRT
Onerrgo

If [L]NBERR
 If [L]STA>=2 : [L]STA=1 : Endif # Saisi -> Incorrect
Elsif [L]STA=1
 [L]STA=2 : # Incorrect -> Saisi
Elsif [L]STA=3
 [L]STA=2 : # Imprimé -> Saisi
Endif

End

#-------------------------------------------------------------------------------
$ERREURSTA
Call ERREUR(errp-num$(errl)-errmes$(errn)-errm) From GESECRAN
[L]NBERR+=1
Resume

######################################################################################
## Etiquette Ecran CCS0
######################################################################################
Subprog C_NUMCER(VALEUR)
Variable Char    VALEUR()
If !clalev([F:CCS]) : Local File CERTIFCCS [CCS] : Endif
If VALEUR="" : End : Endif
Read [F:CCS]CCS0=VALEUR
If fstat : Raz VALEUR : Endif
End


Subprog AP_NUMCER(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & !GIMPORT : mkstat=4 : Endif
[M]NUMCERJOB = VALEUR
End


Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
Read [F:ID]ID0=VALEUR
If !fstat
 If [F:ID]FLGINT<>2
  GMESSAGE = mess(50,10701,1) : # Ce salarié n'est pas un intermittent
  mkstat = 2 : End
 Endif
 [M:CCS0] = [F:ID]
 #MABOS-11/04/13-FQ71754-US1516
# If [F:ID]CIV=1 | [F:ID]NAM=[F:ID]OLDNAM
 If [F:ID]NAM=[F:ID]OLDNAM
  Raz [F:ID]NAM
 Endif
 Affzo [CCS0]
 Call AM_NUMCCS([M:CCS0]NUMCCS)
 Call AM_NUMSSC([M:CCS0]NUMSSC)
Endif
#US1840 81085 01/08/2013 Selection DISPLAY columns and title
#Call B2_REFNUM(VALEUR)
End


Subprog B2_REFNUM_OLD(VALEUR)
Variable Char    VALEUR()
Local Integer  NBCTR, NUMCTR, I, FLGCAC, OK
Local Decimal  NBCAC, NBJOU
Local Char     TBCTR(GLONVCR)(0..100) , LIBCTR(80)(0..100), TBUL(GLONVCR)(0..100)
Local Char     RUB(GLONRUB)
For [HRCTR]CTR2 Where REFNUM=VALEUR & STACTR=2
 OK = 0
 For [PSN] Where CTRNUM=[F:HRCTR]CTRNUM & BUL<>"" & NUMCER=""
  OK = 1 : Break
 Next
 If OK=1
  Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
  NBCTR += 1
  TBCTR(NBCTR)  = [F:HRCTR]CTRNUM
  LIBCTR(NBCTR) = [F:HRCTR]CTRNUM-":"-format$(GFMD,[F:HRCTR]CTRDAT)-format$(GFMD,[F:HRCTR]XITDAT)
&                -[F:FCY]FCY-[F:FCY]FCYNAM
 Endif
Next

If NBCTR=0
 GMESSAGE = mess(150,10702,1) : # Pas de contrat pour ce salarié
 mkstat = 2 : End
Elsif NBCTR>1
 Call SAITEX(NBCTR,LIBCTR,NUMCTR,mess(151,10702,1)) From GESECRAN : # Choix du contrat
 If NUMCTR=0 : mkstat = 2 : End : Endif
Else
 NUMCTR = 1
Endif
If [M]CTRNUM<>TBCTR(NUMCTR)
 [M]CTRNUM = TBCTR(NUMCTR)
 Gosub CHARGE_CONTRAT
Endif
End


#
#US1840 81085 01/08/2013 Selection DISPLAY columns and title
# Max 5 columns selection in list
Subprog B2_REFNUMBIS(VALEUR)
Variable Char    VALEUR()
Local Integer  NBCTR, NUMCTR, I, FLGCAC, OK
Local Decimal  NBCAC, NBJOU
Local Char     TBCTR(GLONVCR)(0..100) , LIBCTR(80)(0..100), TBUL(GLONVCR)(0..100)
Local Char     RUB(GLONRUB)

Local Integer CHOI, OK , I
Local Char    TEX(GLONDES)(1..100,1..5) , TIT(GLONDES)(0..5)


For [HRCTR]CTR2 Where REFNUM=VALEUR & STACTR=2
 OK = 0
 For [PSN] Where CTRNUM=[F:HRCTR]CTRNUM & BUL<>"" & NUMCER=""
  OK = 1 : Break
 Next
 If OK=1
  Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
  NBCTR += 1
  TBCTR(NBCTR)  = [F:HRCTR]CTRNUM
  TEX(NBCTR,1) = [F:HRCTR]CTRNUM
  TEX(NBCTR,2) = format$(GFMD,[F:HRCTR]CTRDAT)
  TEX(NBCTR,3) = format$(GFMD,[F:HRCTR]XITDAT)
  TEX(NBCTR,4) = [F:FCY]LEGCPY
  TEX(NBCTR,5) = [F:FCY]FCY+"-"+[F:FCY]FCYNAM
#  TEX(NBCTR,6) = [F:FCY]LEG
#  TEX(NBCTR,7) = [F:HRCTR]ETRSRV
#  TEX(NBCTR, 8) = [F:HRCTR]PROPRF

 Endif
Next

CHOI = 1
TIT(0) = mess(151,10702,1) : # Choix du contrat
Call TEXTE(5481,TIT(1)) From OBJDIV     : # Contrat
Call TEXTE(212,TIT(2)) From OBJDIV      : # Date
Call TEXTE(7830,TIT(3)) From OBJDIV     : # Date sortie
Call TEXTE(1343,TIT(4)) From OBJDIV     : # Société
Call TEXTE(1344,TIT(5)) From OBJDIV     : # Site
#Call TEXTE(26213,TIT(6)) From OBJDIV    : # Législation
#Call TEXTE(18735,TIT(7)) From OBJDIV    : # Service
#Call TEXTE(8750,TIT(8)) From OBJDIV    : # Profil

If NBCTR=0
 GMESSAGE = mess(150,10702,1) : # Pas de contrat pour ce salarié
 mkstat = 2 : End
Elsif NBCTR>1
 #Call SAITEX_COL_MAX(NBCTR,TEX,CHOI,TIT,240,150) From GESECRAN
 Call SAITEX_COL(NBCTR,TEX,CHOI,TIT) From GESECRAN
 If !(status<>7 & CHOI<>0)
   mkstat = 2
 Endif
Else
 CHOI = 1
Endif

If [M]CTRNUM<>TBCTR(CHOI)
 [M]CTRNUM = TBCTR(CHOI)
 Gosub CHARGE_CONTRAT
Endif
End

#US1840 81085 01/08/2013 Selection DISPLAY columns and title
$AAM_REFNUM
Call INI_VALCTR([M]CTRNUM) From SELMAT: #US1840 81085 01/08/2013 Selection DISPLAY columns and title
Return
#US1840 81085 01/08/2013 Selection DISPLAY columns and title
$BAM_REFNUM
If [V]GW_VALCTR<>[M]CTRNUM
   Gosub CHARGE_CONTRAT
Endif
Call KILL_VALCTR() From SELMAT
End

$CHARGE_CONTRAT
Local Char  TBUL(GLONVCR)(0..100) : #US1840 81085 01/08/2013 Selection DISPLAY columns and title
Local Char  RUB(GLONRUB)
Local Integer I, FLGCAC
Local Decimal  NBCAC, NBJOU

 # FQ71863 - MABON 28/02/11 - Le CTR0 référence le matricule en premier
#Read [HRCTR]CTR0=[M]CTRNUM
Filter [HRCTR] Where REFNUM=[M]REFNUM & CTRNUM= [M]CTRNUM
Read [F:HRCTR]CTR0 Last
Filter [HRCTR]
If fstat : Return : Endif
[M]PSNJOB = [F:HRCTR]PSNJOB
Call LECTEXTRA([M]PSNJOBDES,"ATABDIV","LNGDES","10604",[F:HRCTR]PSNJOB) From ATEXTRA
If [F:HRCTR]STAEMP>1
 [M]FLGCAD  = "O"
 [M]FLGCAD2 = 2
Else
 [M]FLGCAD  = "N"
 [M]FLGCAD2 = 1
Endif
FLGCAC=1
Filter [PSN] Where CTRNUM=[M]CTRNUM & BUL<>"" & NUMCER=""
I = 0
For [PSN]
 If [M]STRDAT=[0/0/0] | [M]STRDAT>[F:PSN]PSNSTRDAT : [M]STRDAT = [F:PSN]PSNSTRDAT : Endif
 If [M]ENDDAT=[0/0/0] | [M]ENDDAT<[F:PSN]PSNENDDAT : [M]ENDDAT = [F:PSN]PSNENDDAT : Endif
 If !find([F:PSN]BUL,TBUL)
  I +=1
  TBUL(I) = [F:PSN]BUL
  Call PARAM([F:HRCTR]ETRFCY,"CCSBASCNG",RUB) From ADOVAL
  Read [HSP]HSP3=[F:PSN]BUL;RUB;6
  If !fstat
   [M]BASLEA = [F:HSP]BAS-[F:HSP]AMT
  Endif
  Call PARAM([F:HRCTR]ETRFCY,"CCSSALBRU",RUB) From ADOVAL
  Read [HSP]HSP3=[F:PSN]BUL;RUB;6
  If !fstat
   [M]SAL = [F:HSP]BAS-[F:HSP]AMT
  Endif
  If [F:PSN]NBRCAC=0
   FLGCAC = 0
  Endif
  NBCAC += [F:PSN]NBRCAC
  NBJOU += [F:PSN]PSNENDDAT-[F:PSN]PSNSTRDAT
  Read [VEP]VEP5=[F:PSN]BUL
  If !fstat & [M]DATPAY<[F:VEP]PAYDAT
   [M]DATPAY = [F:VEP]PAYDAT
  Endif
 Endif
Next
Filter [PSN]
## Si le contrat est exclusivement au cachet(pas de ligne de prestation avec un nombre de cachets à zéro)
## déclarer un nombre de cachets
## Si le contrat est à l'heure ou mixte(heures+cachets), déclarer un nombre de jours)
## déclarer un nombre de cachets.
If FLGCAC=1
 [M]NBRDAYCAC = NBCAC
Else
 [M]NBRDAYCAC = NBJOU
Endif

Read [FCY2]FCY0=[F:HRCTR]ETRFCY
If !fstat & [F:FCY2]CCSFLG=2
 [M]NUMCPY = [F:FCY2]NUMCCS
Else
 Read [FCY3]FCY0=[F:FCY2]CCSFCY
 If !fstat
  [M]NUMCPY = [F:FCY3]NUMCCS
 Endif
Endif

[M]NUMCPYSTR = left$([M]NUMCPY,8)
[M]NUMCPYKEY = mid$([M]NUMCPY,9,1)

Filter [BPA] Where BPATYP=3 & BPANUM=[F:FCY2]CCSFCY & BPAADDFLG=2
Read [BPA]BPA0 First
Filter [BPA]
If !fstat
 [M]PLCREF = [F:BPA]CTY
Endif

[M]DATREF = date$

###69272
Call LECTURE("FCY",[F:FCY2]CCSFCY,"") From CONTOBJ
If [F:FCY]CNTNAM<>""
 Read [CNT]CNT0=3;[F:FCY2]CCSFCY;[F:FCY]CNTNAM
Else
 Filter [CNT] Where BPATYP = 3 & BPANUM = [F:FCY2]CCSFCY  #& CNTFLG=2
 ###
 Read [CNT]CNT0 First
 Filter [CNT]
Endif
Read [AIN]AIN0 = [F:CNT]CCNCRM
If !fstat
 [M]FCYRPB = [F:AIN]CNTFNA-[F:AIN]CNTLNA
Endif

If NBJOU>([M]ENDDAT-[M]STRDAT) | NBCAC>([M]ENDDAT-[M]STRDAT)
 [M]FLD = mess(154,10702,1) : # Nombre de cachets supérieur au nombre de jours
Endif

Call SETSTYLE("CCS","AERROR") From GENFEH
Affzo
End


Subprog D_FLGCAD2(VALEUR)
Variable Integer VALEUR
If [M]FLGCAD="O"
 VALEUR = 2
Else
 VALEUR = 1
Endif
End


Subprog AM_FLGCAD2(VALEUR)
Variable Integer VALEUR
Case VALEUR
 When 0,1 : [M]FLGCAD = "N"
 When 2   : [M]FLGCAD = "O"
Endcase
End


Subprog AM_NUMCCS(VALEUR)
Variable Char    VALEUR()
[M]NUMCCSSTR = left$(VALEUR,7)
[M]NUMCCSKEY = mid$(VALEUR,8,1)
End


Subprog AM_NUMSSC(VALEUR)
Variable Char    VALEUR()
[M]NUMSSCSTR = left$(VALEUR,13)
[M]NUMSSCKEY = mid$(VALEUR,14,2)
End


Subprog C_NUMSSC(VALEUR)
Variable Char    VALEUR()
If len(VALEUR)<13
 While len(VALEUR)<13
  VALEUR +="0"
 Wend
 #Call CONTSS (VALEUR,[M]NTT,[M]CRYBRN,[M]SEX,[M]DATBRN,[M]DEPBRN,[M]CTYBRNSEE) From CONTNUM
Endif
End


Subprog AM_NUMCPY(VALEUR)
Variable Char    VALEUR()
[M]NUMCPYSTR = left$(VALEUR,8)
[M]NUMCPYKEY = mid$(VALEUR,9,1)
End


Subprog AM_PSNJOB(VALEUR)
Variable Char    VALEUR()
Call LECTEXTRA([M]PSNJOBDES,"ATABDIV","SHODES","10604",VALEUR) From ATEXTRA
[M]PSNJOBDES = toupper([M]PSNJOBDES)
End
