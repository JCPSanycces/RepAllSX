#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion du masque TRTCALPAS
########################################
Subprog AV_ZSRV(VALEUR)
Variable Char    VALEUR()
Call LECTEXTRA(VALEUR,"SERVICE","DES",[M]SRV(indice),"") From ATEXTRA
End

########################################
Subprog AV_ZPRF(VALEUR)
Variable Char    VALEUR()
Call LECTEXTRA(VALEUR,"PROFIL","PRFDES",GCURLEG,[M]PRF(indice)) From ATEXTRA
End

########################################
Subprog AV_ZCPY(VALEUR)
Variable Char    VALEUR()
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
Call LECTURE("CPY",[M]CPY(indice),"") From CONTOBJ
VALEUR = [F:CPY]CPYNAM
End

########################################
Subprog AM_COD(VALEUR)
Variable Char    VALEUR()
If clalev([F:RUB])=0 : Local File RUBRIQUE [RUB] : Endif
Read [F:RUB]RUB0=GCURLEG;VALEUR
If !fstat
 [M:PAS]ROW = [F:RUB]ROW
 Affzo [M:PAS]ROW
Endif
End

########################################
Subprog AM_ROW(VALEUR)
Variable Decimal VALEUR
If clalev([F:RUB])=0 : Local File RUBRIQUE [RUB] : Endif
Read [F:RUB]RUB1=GCURLEG;VALEUR
If !fstat
 [M:PAS]COD = [F:RUB]COD
 Affzo [M:PAS]COD
Endif
End

########################################
Subprog AV_BAS(VALEUR)
Variable Decimal VALEUR
# Si PLAFOND ou TRANCHE modifié pour 1 rubrique de type assiette, zone BAS non accessible
If [M:PAS]TYPRUB=5 & [M:PAS]OLDRUB=[M:PAS]COD
 mkstat=2
Endif
If [M:PAS]TYPRUB<>5
 Grizo [M:PAS]BAS
Else
 Actzo [M:PAS]BAS
Endif
End

########################################
Subprog AV_RAT(VALEUR)
Variable Decimal VALEUR
If [M:PAS]TYPRUB<>5
 Grizo [M:PAS]RAT
Else
 Actzo [M:PAS]RAT
Endif
End

########################################
Subprog C_EXPR(VALEUR)
Variable Char    VALEUR()
[M]EXPR(nolign-1) = VALEUR
End
