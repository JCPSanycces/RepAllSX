#<AdxTL>@(#)0.0.0.0 $Revision$Class EDI category
# Supervisor
## ATY-ATYPE ## CAT
# 2018-11-09 07:13:51 952

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,CATCOD,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char CATCOD
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File EDICAT [ECA]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".EDICAT" [ECA]
Endif

Default File [F:ECA]
Read [F:ECA]ECA0 = [L]CATCOD
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]CATCOD)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When "VALID"
  [L]ATSTFILTER = ([F:ECA]VALID = [V]CST_AYES) : [L]AMESFILTER= func ASYRFNC.TEXTE(50676)
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]CATCOD)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


