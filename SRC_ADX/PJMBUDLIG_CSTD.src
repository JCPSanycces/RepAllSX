#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe PJMBUDLIG
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "ACONTROL"                : Gosub ACONTROL                        From PJMBUDLIG_CSTD_EVENTS
        When "AINSERT_CONTROL_BEFORE"  : Gosub AINSERT_CONTROL_BEFORE          From PJMBUDLIG_CSTD_EVENTS
        When "AUPDATE_CONTROL_BEFORE"  : Gosub AUPDATE_CONTROL_BEFORE          From PJMBUDLIG_CSTD_EVENTS
        When "ADELETE_CONTROL_BEFORE"  : Gosub ADELETE_CONTROL_BEFORE          From PJMBUDLIG_CSTD_EVENTS
    Endcase
  Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "SETERROR"                    : Gosub SETERROR                        From PJMBUDLIG_CSTD_METHODS
    When "COPY"                        : Gosub COPY                            From PJMBUDLIG_CSTD_METHODS
    When "COPY_LOAD_PROPERTIES"        : Gosub COPY_LOAD_PROPERTIES            From PJMBUDLIG_CSTD_METHODS
  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
  Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "KEYCONCAT"                   : Gosub KEYCONCAT                       From PJMBUDLIG_CSTD_PROPERTIES
    When "ORI"                         : Gosub ORI                             From PJMBUDLIG_CSTD_PROPERTIES
    When "PLBU"                        : Gosub PLBU                            From PJMBUDLIG_CSTD_PROPERTIES
    When "PCCCOD"                      : Gosub PCCCOD                          From PJMBUDLIG_CSTD_PROPERTIES
    When "PLBQTY"                      : Gosub PLBQTY                          From PJMBUDLIG_CSTD_PROPERTIES
    When "PLBPRI"                      : Gosub PLBPRI                          From PJMBUDLIG_CSTD_PROPERTIES
    When "PLBPRIFRC"                   : Gosub PLBPRIFRC                       From PJMBUDLIG_CSTD_PROPERTIES     # Issue X3-105813 - 2018-08-29 by FGR : was missing
    When "PLBAMT"                      : Gosub PLBAMT                          From PJMBUDLIG_CSTD_PROPERTIES
    When "PLBFLGREM"                   : Gosub PLBFLGREM                       From PJMBUDLIG_CSTD_PROPERTIES
    When "PLBQTYREM"                   : Gosub PLBQTYREM                       From PJMBUDLIG_CSTD_PROPERTIES
    When "PLBPRIREM"                   : Gosub PLBPRIREM                       From PJMBUDLIG_CSTD_PROPERTIES
    When "PLBAMTREM"                   : Gosub PLBAMTREM                       From PJMBUDLIG_CSTD_PROPERTIES
    When "PLBQTYREC"                   : Gosub PLBQTYREC                       From PJMBUDLIG_CSTD_PROPERTIES
    When "PLBAMTREC"                   : Gosub PLBAMTREC                       From PJMBUDLIG_CSTD_PROPERTIES
    When "PLBDATBUD"                   : Gosub PLBDATBUD                       From PJMBUDLIG_CSTD_PROPERTIES
    #
    When "TCHFINOVSESS"                : Gosub TCHFINOVSESS                    From PJMBUDLIG_CSTD_PROPERTIES
    When "TCHACTION"                   : Gosub TCHACTION                       From PJMBUDLIG_CSTD_PROPERTIES
  Endcase
Return

