#<AdxTL>@(#)0.0.0.0 $Revision$
  # Gestion du masque AWRKCLASSIC
Local Char PARAM(250)(1..20) , VALEUR(GLONAWA)
PARAM(1)="2"
PARAM(2)="TCY"
PARAM(3)="M"
PARAM(5)="DZ"
PARAM(4)= "DD~2~2~2~G"     :# CODE,SIMUL,DIFFERE,TYPDEC,GRPDEB
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBAWRKC","AWRKCLASSIC",3,"") From GTRAITE
End


$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
Endcase
Return

######################################################################################
$INIT
Local File AWRKPAR [AWA]
Local Mask AWRKCLASSIC [AWRKC]
Local Char CHAINE(250)
Local Integer J,I,JJ

[M]ATYPEVT = val(PARAM(1))
[M]ACODEVT= PARAM(2)
[M]AOPERATION =  PARAM(3)
CHAINE=PARAM(4)
If CHAINE<>""
 JJ= instr(1,CHAINE,"~")
 Raz J
 While JJ>0
  J+=1
  Case J
   When 1 : [M]PCODE =   left$(CHAINE,JJ-1)
   When 2 : [M]PSIMUL =  max(1,min(2,val(left$(CHAINE,JJ-1))))
   When 3 : [M]PDIFFERE =  max(1,min(2,val(left$(CHAINE,JJ-1))))
   When 4 : [M]PTYPDEC = max(1,min(2,val(left$(CHAINE,JJ-1))))
  Endcase
  CHAINE =right$(CHAINE,JJ+1)
  JJ= instr(1,CHAINE,"~")
 Wend
 [M]PGRPDEB = CHAINE
 [M]PLUS = 2
Endif
[M]VALCLE=[L]PARAM(5)
Return

######################################################################################
$CONTROLE
If find([M]ATYPEVT,1,2,10)=0
 GMESSAGE = num$([M]ATYPEVT)-":"-mess(203,75,1)
 GERR=1 : Return
Endif
Return

######################################################################################
$EXEC
TRA = 1

Call TITAWI("AWRKCLASSIC",TIT) From OBJDIV
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
 Call TEMPON(TIT) From GESECRAN
Endif

Local Char SAVCLE1(250),SAVCLE2(250),CLEOBJ(250),WVALCLE(250)(1..16)
Local Char PREF(10) , ERM(250), NOMPROG(GLONADC)
Local Integer ERN,OK

Gosub READ_FIRST_AWA

If OK
 Call SET_PREF([F:AWA]CODE,PREF) From SUBAWA
 NOMPROG = PREF+[F:AWA]CODE

 # Lecture de la table principale
 Gosub OUVREF From =NOMPROG
 If TABREF=""
  GMESSAGE = mess(80,75,1) : # Table de référence inexistante
  GERR = 1 :Return
 Endif
 Gosub LNKREF From =NOMPROG
 Call SPLIT(WVALCLE,[M]VALCLE,"~") From ASYRSUB
 For I=1 To dim(DEFREF)
  If DEFREF(I)<>""
   ERN = 0
   Onerrgo ERR
   Case TYPREF(I)
    When 1,2,3,4,5,6 : Assign ("[F]"+DEFREF(I)) With val([L]WVALCLE(I))
    When Default     : Assign ("[F]"+DEFREF(I)) With [L]WVALCLE(I)
   Endcase
   If GERR : Break : Endif
   Onerrgo
  Endif
 Next I
 If GERR : Return : Endif
 Read [F] =
 If fstat
  GMESSAGE = TABREF-"("+[M]VALCLE+")"-mess(81,75,1) : # Enregistrement non trouvé
  GERR=1 : Return
 Endif
 CLEOBJ = [M]VALCLE
 If [M]PLUS=2
  Call WORKPLUS( [M]ATYPEVT,[M]ACODEVT,[M]AOPERATION,CLEOBJ,[M]PCODE,([M]PSIMUL=2),([M]PDIFFERE=2),([M]PTYPDEC=2),[M]PGRPDEB) From AWRK
 Else
  Call WORKFLOW( [M]ATYPEVT,[M]ACODEVT,[M]AOPERATION,CLEOBJ) From AWRK
 Endif
Endif
If !GSERVEUR
 Call TEMPOFF From GESECRAN
 Call FERME_TRACE From LECFIC
Endif
Return


$ERR
ERN = errn
GMESSAGE = "|"+errp-"("+num$(errl)+")"-mess(6,123,1)-num$(ERN)-":"-errmes$(ERN)-errm+"|"
GERR =1
Resume

$READ_FIRST_AWA
Local Char CODEVT(30),CODE(50),OPERAT(50)
Local Integer TYPDEC
[L]CODEVT= [M]ACODEVT
[L]CODE = [M]PCODE
[L]TYPDEC=[M]PTYPDEC
[L]OPERAT = [M]AOPERATION

Local File AWRKPAR [AWAX]
Filter [AWAX] Where [F]TYPEVT=[M]ATYPEVT & ENAFLG=2
Read [AWAX]AWA1 First
While !fstat
 [F:AWA] = [F:AWAX]
 Gosub TEST_WORK From AWRK
 If OK
  Break
 Endif
 Read [AWAX]AWA1 Next
Wend
Close Local File [AWAX]
Return



######################################################################################
## Etiquette ajoutée par le superviseur (écran AWRKCLASSIC) 08/09/2015 10:48:25 (CCL)
######################################################################################
Subprog C_CODE(VALEUR)
Variable Char    VALEUR()
End

######################################################################################
Subprog S_CODE(VALEUR)
Variable Char    VALEUR()
End
Local Integer NBTEX, CHOI,I
Local Char    TEX(GLONDES)(1..500,1..3) , TIT(GLONDES)(0..3) , CRITERE(250)


For [AWA] Where find([AWA]TYPEVT,2,10)>0 or (TYPEVT=1 and MODELE<>"")
 NBTEX+= 1
 TEX(NBTEX,1) = [F:AWA]CODE
 TEX(NBTEX,2) = func AFNC.TEXTRA("AWRKPAR","INTIT",[F:AWA]CODE,"")
 TEX(NBTEX,3) = mess([AWA]TYPEVT,988,1)
Next
CHOI = 0
TIT(0) = mess(22,123,1) # Sélection
TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("AWA0", "CODE")
TIT(2) = mess(30,109,1) : # INTITULé
TIT(3) = func AMK_TOOL.GET_FIELD_LABEL("AWA1", "TYPEVT")
If NBTEX=1
 VALEUR = TEX(1,1)
Elsif NBTEX>0
 Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
 If status<>7 & CHOI<>0
  VALEUR = TEX(CHOI,1)
 Endif
Endif
End

######################################################################################
Subprog AS_PCODE(VALEUR)
Variable Char    VALEUR()
If [M]PLUS<>2
  Effzo [M]PCODE : Grizo [M]PCODE
Else
 Actzo [M]PCODE
Endif
End

Subprog AS_PGRPDEB(VALEUR)
Variable Char    VALEUR()
If [M]PLUS<>2
  Effzo [M]PGRPDEB : Grizo [M]PGRPDEB
Else
 Actzo [M]PGRPDEB
Endif
End

Subprog AS_PSIMUL(VALEUR)
Variable Integer VALEUR
If [M]PLUS<>2
  Effzo [M]PSIMUL : Grizo [M]PSIMUL
Else
 Actzo [M]PSIMUL
Endif
End

Subprog AS_PDIFFERE(VALEUR)
Variable Integer VALEUR
If [M]PLUS<>2
  Effzo [M]PDIFFERE : Grizo [M]PDIFFERE
Else
 Actzo [M]PDIFFERE
Endif
End

Subprog AS_PTYPDEC(VALEUR)
Variable Integer VALEUR
If [M]PLUS<>2
  Effzo [M]PTYPDEC : Grizo [M]PTYPDEC
Else
 Actzo [M]PTYPDEC
Endif
End

Subprog AM_PLUS(VALEUR)
Variable Integer VALEUR
If VALEUR<>2
  Effzo [M]PCODE : Grizo [M]PCODE
  Effzo [M]PSIMUL : Grizo [M]PSIMUL
  Effzo [M]PDIFFERE : Grizo [M]PDIFFERE
  Effzo [M]PTYPDEC : Grizo [M]PTYPDEC
  Effzo [M]PGRPDEB :Grizo [M]PGRPDEB
Else
 Actzo [M]PCODE
 Actzo [M]PSIMUL
 Actzo [M]PDIFFERE
 Actzo [M]PTYPDEC
 Actzo [M]PGRPDEB
Endif
End

Subprog AS_ATYPEVT(VALEUR)
Variable Integer VALEUR
GMENLOC(3) = 1
GMENLOC(4) = 1
GMENLOC(5) = 1
GMENLOC(6) = 1
GMENLOC(7) = 1
GMENLOC(8) = 1
GMENLOC(9) = 1
End


######################################################################################

