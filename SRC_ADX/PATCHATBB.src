#<AdxTL>@(#)9.0.0.0 $Revision$
$ACTION
Case ACTION
 When "PATCH"     : Gosub PATCH
Endcase
Return

##MAJ dico Employé ou dico Dads-u
$PATCH
Call MAJDICO(NOMOBJ,APPLI)
Return

Subprog MAJDICO(CODFIC,DOSSIER)
Value Char CODFIC ()
Value Char DOSSIER ()
#47019 : 08/01/09
#If clalev([F:DXX])=0  : Local File =DOSSIER+".DICOEMP"  [DXX] : Endif
If clalev([F:ATZ])=0  : Local File =DOSSIER+".ATABZON"  [ATZ] : Endif
If clalev([F:ATX])=0  : Local File =DOSSIER+".ATEXTE"   [ATX] : Endif

Local Integer N , AXE
Local Char    TEXTE(80)

Local Integer TYP
Local Char CRITERE (100)
#47019 : 08/01/09
#Default File [F:DXX]

TYP=0

#JASMI - 2017-05-02 - Issue 122738 - START
#If left$(CODFIC,5)="EMPLO"
# #47019 : 08/01/09
# If clalev([F:DXX])=0  : Local File =DOSSIER+".DICOEMP"  [DXX] : Endif
# Default File [F:DXX]
# # fin 47019
# TYP=1
# CRITERE="left$(CODFIC,5)='EMPLO'"
#Elsif left$(CODFIC,6)="DADEMP" | left$(CODFIC,6)="DADFCY"
# #47019 : 08/01/09
# If clalev([F:DXX])=0  : Local File =DOSSIER+".DICODAD"  [DXX] : Endif
# Default File [F:DXX]
# # fin 47019
# TYP=2
# CRITERE="left$(CODFIC,6)='DADEMP' | left$(CODFIC,6)='DADFCY'"
#Endif
If (GMODU(15)=2 | GMODU(20)=2)
  If left$(CODFIC,5)="EMPLO"
   #47019 : 08/01/09
   If clalev([F:DXX])=0  : Local File =DOSSIER+".DICOEMP"  [DXX] : Endif
   Default File [F:DXX]
   # fin 47019
   TYP=1
   CRITERE="left$(CODFIC,5)='EMPLO'"
  Elsif left$(CODFIC,6)="DADEMP" | left$(CODFIC,6)="DADFCY"
   #47019 : 08/01/09
   If clalev([F:DXX])=0  : Local File =DOSSIER+".DICODAD"  [DXX] : Endif
   Default File [F:DXX]
   # fin 47019
   TYP=2
   CRITERE="left$(CODFIC,6)='DADEMP' | left$(CODFIC,6)='DADFCY'"
  Endif
Endif
#JASMI - 2017-05-02 - Issue 122738 - END


If TYP
 #A lancer 2 fois car au 1er tour il supprime les champs qui ont été déplacés de table
 #mais ne les recrée pas...au 2ième tour il les crée !
 Gosub TR1 From GENDICO
 Gosub TR1 From GENDICO
 #47019 : 08/01/09
 Close Local File [DXX]
Endif

#47019 : 08/01/09
#Close Local File [DXX], [ATZ], [ATX]
Close Local File [ATZ], [ATX]
End

