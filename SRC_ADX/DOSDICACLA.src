#<AdxTL>@(#)2.0.0.0 $Revision$
#------------------------------------------------------------#
# DOSDICACLA   Filling the dictionary of data classes
#------------------------------------------------------------#

$DICACLA
Call ECR_TIME(mess(15,125,1)-mess(254,125,1)) From DOSSUB
# MAJ dictionnaire - Classes données

Local File =GDOSREF+".ACLASSE"    [ACLA]
&         ,=GDOSREF+".ACLAFLD"    [ACLAF]
&         ,=GDOSREF+".ACLAPARFLD" [ACLFP]
&         ,=GDOSREF+".ACLAMET"    [ACLAM]
&         ,=GDOSREF+".ACLAPARDEF" [ACLPD]
&         ,=GDOSREF+".ACLAMETSTD" [ACLAT]
&         ,=GDOSREF+".ACLALNK"    [ACLAK]
&         ,=GDOSREF+".ACLACOL"    [ACLAC]
&         ,=GDOSREF+".ACLAOPT"    [ACLAO]
&         ,=GDOSREF+".ACLAMAP"    [ACLAKP]
Local File =[F:ADS]DOSSIER+".ACLASSE"    [DACLA]
&         ,=[F:ADS]DOSSIER+".ACLASSE"    [DACLA2]
&         ,=[F:ADS]DOSSIER+".ACLASSE"    [DACLA3]
&         ,=[F:ADS]DOSSIER+".ACLAFLD"    [DACLAF]
&         ,=[F:ADS]DOSSIER+".ACLAFLD"    [DACLAF2]
&         ,=[F:ADS]DOSSIER+".ACLAPARFLD" [DACLFP]
&         ,=[F:ADS]DOSSIER+".ACLAMET"    [DACLAM]
&         ,=[F:ADS]DOSSIER+".ACLAPARDEF" [DACLPD]
&         ,=[F:ADS]DOSSIER+".ACLAMETSTD" [DACLAT]
&         ,=[F:ADS]DOSSIER+".ACLALNK"    [DACLAK]
&         ,=[F:ADS]DOSSIER+".ACTIV"      [DACV]
&         ,=[F:ADS]DOSSIER+".ACLACOL"    [DACLAC]
&         ,=[F:ADS]DOSSIER+".ACLAOPT"    [DACLAO]
&         ,=[F:ADS]DOSSIER+".ACLAMAP"    [DACLAKP]
Local File =[F:ADS]DOSSIER+".AOBJET" [DAOB]
#95271
Local Char    RES_COD(80)(0..),RES_CLA(GLONACLA)(0..), RES_TIT(30)(0..)
Local Integer RES_TYP(0..), RES_MOD(0..), RES_ORD(0..), RES_NBR, RES_NO
Local Char    WWCODPAR(80)(0..),WWCODCLAPAR(GLONACLA)(0..),WWCODCUR(80)(0..),WWFLDCLE(250)(0..), WWINTITPAR(30)(0..)
Local Integer WWTYPINTPAR(0..), WWADRVAL(0..), WWTYPKEY(0..), WWNUMPAR(0..),WWTYPPAR(0..),WWNOLIB(0..),WWLNG(0..),WWTYPAFF(0..), WWNBRPARALL
#
Local Integer NBACLAKSPE,NBACLAKSTD
Local Integer B,J
Local Char WCODEPARDEF(GLONASM)
If GINFO
 Call AFF_VLC(mess(15,125,1)-mess(254,125,1),"") From GESECRAN
Endif

GNBACLA = 0

## Deleting old data classes

If !GCRE
 Trbegin [DACLA] , [DACLAF], [DACLFP], [DACLAM], [DACLPD], [DACLAT], [DACLAK] , [DACLAO] , [DACLAC]
  For [DACLA]ACLA0 Where CODCLA<GXX
   Call SPEC([F:DACLA]CODACT,SPEC) From DOSSUB
   If !SPEC
    Read [ACLA]ACLA0 = [F:DACLA]CODCLA
    If fstat
     Call EFFACE([F:DACLA]CODCLA)
    Endif
   Endif
  Next
 Commit
Endif

## Update of data classes

Filter [ACLA] Where CODCLA<GXX
Read [ACLA]ACLA0 First
While fstat<=2
 If GINFO
  Call AFF_VLC(mess(15,125,1)-mess(254,125,1),[F:ACLA]CODCLA) From GESECRAN
 Endif
 ACTIV = 0
 Trbegin [DACLA] , [DACLAF], [DACLFP], [DACLAM], [DACLPD], [DACLAT], [DACLAK] , [DACLAO] , [DACLAC]
  OLD  = 0
  SPEC = 0
  RWO  = 0
  Read [DACLA]ACLA0 = [F:ACLA]CODCLA
  If !fstat
   OLD = 1
   Call SPEC([F:DACLA]CODACT,SPEC) From DOSSUB
  Endif
  Call NEWREC([F:ADS]DOSSIER,[F:ACLA]CODACT,[F:ACLA]MODULE,NEWREC) From DOSSUB
  If !SPEC

   If OLD & !NEWREC

    Call EFFACE([F:ACLA]CODCLA)

   Elsif NEWREC & !OLD

    Raz [F:DACLA]
    RWO = 1
    [F:DACLA] = [F:ACLA]
    #93648
    If [F:DACLA]LNKOBJ<>""
     Read [DAOB]ABREV = [F:DACLA]LNKOBJ
     If fstat
      [F:DACLA]LNKOBJ=""
     Endif
    Endif
    [F:DACLA]UPDFLG = 1
    If dim([F:DACLA]CREDAT)>0 : [F:DACLA]CREDAT = date$ : Endif
    [F:DACLA]CREUSR = GUSER
    GNBACLA += 1
    Write [DACLA]
    If fstat : Call ERREUR("ACLASSE"-[F:DACLA]CODCLA,1) From DOSDIC : Endif
    For [ACLAO]ACLAO0 Where CODCLA=[F:ACLA]CODCLA
     [F:DACLAO] = [F:ACLAO]
     Write [DACLAO]
     If fstat : Call ERREUR("ACLAOPT"-[F:DACLAO]CODCLA-[F:DACLAO]OPTCOD,1) From DOSDIC : Endif
    Next
    For [ACLAC]ACLAC0 Where CODCLA=[F:ACLA]CODCLA
     [F:DACLAC] = [F:ACLAC]
     Write [DACLAC]
     If fstat : Call ERREUR("ACLACOL"-[F:DACLAO]CODCLA-[F:DACLAC]CODCOL,1) From DOSDIC : Endif
    Next
    #
    For [ACLAF]ACLAF0 Where CODCLA=[F:ACLA]CODCLA
     #96528
     If [ACLAF]ACTFLD<>""
      Read [DACV]CODACT = [F:ACLAF]ACTFLD
      If fstat or [DACV]FLACT<>2
       Goto SUITEACLAF
      Endif
     Endif
     #
     [F:DACLAF] = [F:ACLAF]
     Write [DACLAF]
     If fstat : Call ERREUR("ACLAFLD"-[F:DACLAF]CODCLA-[F:DACLAF]FLDCLA,1) From DOSDIC : Endif
     For [ACLFP]ACLFP0 Where CODCLA=[F:ACLAF]CODCLA & FLDCLA=[F:ACLAF]FLDCLA
      [F:DACLFP] = [F:ACLFP]
      Write [DACLFP]
      If fstat : Call ERREUR("ACLAPARFLD"-[F:DACLFP]CODCLA-[F:DACLFP]FLDCLA,1) From DOSDIC : Endif
     Next
$SUITEACLAF
    Next
    For [ACLAM]ACLAM0 Where CODCLA=[F:ACLA]CODCLA
     [F:DACLAM] = [F:ACLAM]
     Write [DACLAM]
     If fstat : Call ERREUR("ACLAMET"-[F:DACLAM]CODCLA-[F:DACLAM]CODMET,1) From DOSDIC : Endif
    Next
    For [ACLPD]ACLPD0 Where CODCLA=[F:ACLA]CODCLA
     [F:DACLPD] = [F:ACLPD]
     Write [DACLPD]
     If fstat : Call ERREUR("ACLAPARDEF"-[F:DACLPD]CODCLA-[F:DACLPD]CODE-[F:DACLPD]CODPAR,1) From DOSDIC : Endif
    Next
    For [ACLAT]ACLAT0 Where CODCLA=[F:ACLA]CODCLA
     [F:DACLAT] = [F:ACLAT]
     Write [DACLAT]
     If fstat : Call ERREUR("ACLAMETSTD"-[F:DACLAT]CODCLA-[F:DACLAT]CODMETSTD,1) From DOSDIC : Endif
    Next
    For [ACLAK]ACLAK0 Where CODCLA=[F:ACLA]CODCLA
     [F:DACLAK] = [F:ACLAK]
     #96528
     If [ACLAK]ACVLNK<>""
      Read [DACV]CODACT = [F:ACLAK]ACVLNK
      If fstat or [DACV]FLACT<>2
       Delete [DACLFP] Where CODCLA=[DACLAK]CODCLA & FLDCLA=[DACLAK]REFLNK
       If fstat=1 : Call ERREUR("ACLAPARFLD"-[DACLAK]CODCLA-[DACLAK]REFLNK,3) From DOSDIC : Endif
       Delete [DACLAF]  Where CODCLA=[DACLAK]CODCLA & FLDCLA=[DACLAK]REFLNK
       If fstat=1 : Call ERREUR("ACLAFLD"-[DACLAK]CODCLA-[DACLAK]REFLNK,3) From DOSDIC : Endif
       Goto SUITEACLAK
      Endif
     Endif
     #
     Write [DACLAK]
     If fstat : Call ERREUR("ACLALNK"-[F:DACLAK]CODCLA-[F:DACLAK]REFLNK,1) From DOSDIC : Endif
     For [ACLAKP]ACLAKP0 Where CODCLA=[F:ACLA]CODCLA & REFLNK=[F:ACLAK]REFLNK
      [F:DACLAKP] = [F:ACLAKP]
      Write [DACLAKP]
      If fstat : Call ERREUR("ACLAMAP"-[F:DACLAKP]CODCLA-[F:DACLAKP]REFLNK-[F:DACLAKP]KEYMAP,1) From DOSDIC : Endif
     Next
$SUITEACLAK
    Next

   Elsif NEWREC & OLD

    DIFF = 0

    ## Compare the header
    #93648
    If [F:ACLA]LNKOBJ<>""
     Read [DAOB]ABREV = [F:ACLA]LNKOBJ
     If fstat
      [F:ACLA]LNKOBJ=""
     Endif
    Endif

    If [F:ACLA]CODACT     <>  [F:DACLA]CODACT     : DIFF = 1 : Endif
    If [F:ACLA]INTCLA     <>  [F:DACLA]INTCLA     : DIFF = 1 : Endif
    If [F:ACLA]TYPCLA     <>  [F:DACLA]TYPCLA     : DIFF = 1 : Endif
    If [F:ACLA]MODULE     <>  [F:DACLA]MODULE     : DIFF = 1 : Endif
    If [F:ACLA]TYPCLA     <>  [F:DACLA]TYPCLA     : DIFF = 1 : Endif
    If [F:ACLA]TABREF     <>  [F:DACLA]TABREF     : DIFF = 1 : Endif
    If [F:ACLA]INDREF     <>  [F:DACLA]INDREF     : DIFF = 1 : Endif
    If [F:ACLA]FLGCREF    <>  [F:DACLA]FLGCREF    : DIFF = 1 : Endif
    If [F:ACLA]FLGUREF    <>  [F:DACLA]FLGUREF    : DIFF = 1 : Endif
    If [F:ACLA]FLGDREF    <>  [F:DACLA]FLGDREF    : DIFF = 1 : Endif
    If [F:ACLA]FLGRREF    <>  [F:DACLA]FLGRREF    : DIFF = 1 : Endif
    If [F:ACLA]FCYSTR     <>  [F:DACLA]FCYSTR     : DIFF = 1 : Endif
    If [F:ACLA]LEGSTR     <>  [F:DACLA]LEGSTR     : DIFF = 1 : Endif
    If [F:ACLA]CPYSTR     <>  [F:DACLA]CPYSTR     : DIFF = 1 : Endif
    If [F:ACLA]ACCSTR     <>  [F:DACLA]ACCSTR     : DIFF = 1 : Endif
    If [F:ACLA]LNKOBJ     <>  [F:DACLA]LNKOBJ     : DIFF = 1 : Endif
    If [F:ACLA]RAW        <>  [F:DACLA]RAW        : DIFF = 1 : Endif
    If [F:ACLA]FLGSEARCH  <>  [F:DACLA]FLGSEARCH  : DIFF = 1 : Endif
    If [F:ACLA]FLGACTX    <>  [F:DACLA]FLGACTX    : DIFF = 1 : Endif
    If [F:ACLA]FLGCONSULT <>  [F:DACLA]FLGCONSULT : DIFF = 1 : Endif
    If [F:ACLA]FLGSYSTEM  <>  [F:DACLA]FLGSYSTEM  : DIFF = 1 : Endif
    If [F:ACLA]KEYINT     <>  [F:DACLA]KEYINT     : DIFF = 1 : Endif
    If [F:ACLA]FLGBUFFER <>  [F:DACLA]FLGBUFFER : DIFF = 1 : Endif
    If [F:ACLA]FLGTR        <>  [F:DACLA]FLGTR        : DIFF = 1 : Endif
    If [F:ACLA]NBRTRT     <> [F:DACLA]NBRTRT      : DIFF = 1 : Endif

    If !DIFF : Call TXT([F:ACLA]INTCLA,DIFF) From DOSSUB : Endif

    ## Comparison of treatments
    If !DIFF
     For B=0 To [F:ACLA]NBRTRT-1
      If [F:ACLA]CODTRT(B) <> [F:DACLA]CODTRT(B) | !find([F:DACLA]ACTTRT(B),GSPE(1..GNBSPE))
       If [F:ACLA]CODTRT(B) <> [F:DACLA]CODTRT(B)     : DIFF = 1 : Endif
       If [F:ACLA]TYPTRT(B) <> [F:DACLA]TYPTRT(B)     : DIFF = 1 : Endif
       If [F:ACLA]ACTTRT(B) <> [F:DACLA]ACTTRT(B)     : DIFF = 1 : Endif
       If [F:ACLA]RANTRT(B) <> [F:DACLA]RANTRT(B)     : DIFF = 1 : Endif
      Endif
      Call DIFFACT([F:ADS]DOSSIER,[F:ACLA]ACTTRT(B),ACTIV) From DOSSUB
     Next B
    Endif

    # --------------------------------#
    ## Comparison and update fields

    NBZONE = 0
    For [ACLAF]ACLAF0 Where CODCLA=[F:ACLA]CODCLA
     NBZONE += 1
     TBZONE(NBZONE) = [F:ACLAF]FLDCLA
     Read [DACLAF]ACLAF0 = [F:ACLAF]CODCLA;[F:ACLAF]FLDCLA

     If fstat
      DIFF = 1
      [F:DACLAF] = [F:ACLAF]
      Write [DACLAF]
      If fstat : Call ERREUR("ACLAFLD"-[F:DACLAF]CODCLA-[F:DACLAF]FLDCLA,1) From DOSDIC : Endif
      Gosub CREPARFLD

     Elsif !find([F:DACLAF]ACTFLD,GSPE(1..GNBSPE))

      # non-specific field, comparison

      RW = 0
      Call DIFFACT([F:ADS]DOSSIER,[F:ACLAF]ACTFLD,ACTIV) From DOSSUB
      If [F:ACLAF]NUMLIG   <> [F:DACLAF]NUMLIG       : RW = 1 : Endif
      If [F:ACLAF]NUMFLD   <> [F:DACLAF]NUMFLD       : RW = 1 : Endif
      If [F:ACLAF]INTFLD   <> [F:DACLAF]INTFLD       : RW = 1 : Endif
      If [F:ACLAF]INTSHTFLD<> [F:DACLAF]INTSHTFLD    : RW = 1 : Endif
      If [F:ACLAF]ACTFLD   <> [F:DACLAF]ACTFLD       : RW = 1 : Endif
      If [F:ACLAF]CODTYP   <> [F:DACLAF]CODTYP       : RW = 1 : Endif
      If [F:ACLAF]LNKCLA   <> [F:DACLAF]LNKCLA       : RW = 1 : Endif
      If [F:ACLAF]LONG     <> [F:DACLAF]LONG         : RW = 1 : Endif
      If [F:ACLAF]NOLIB    <> [F:DACLAF]NOLIB        : RW = 1 : Endif
      If [F:ACLAF]OBLIG    <> [F:DACLAF]OBLIG        : RW = 1 : Endif
      If [F:ACLAF]ACS      <> [F:DACLAF]ACS          : RW = 1 : Endif
      If [F:ACLAF]CODCTL   <> [F:DACLAF]CODCTL       : RW = 1 : Endif
      If [F:ACLAF]TABCONT  <> [F:DACLAF]TABCONT      : RW = 1 : Endif
      If [F:ACLAF]FLDGRP   <> [F:DACLAF]FLDGRP       : RW = 1 : Endif
      If [F:ACLAF]FLDSEARCH<> [F:DACLAF]FLDSEARCH    : RW = 1 : Endif
      If [F:ACLAF]CATSEARCH<> [F:DACLAF]CATSEARCH    : RW = 1 : Endif
      If [F:ACLAF]FLGACCGET<> [F:DACLAF]FLGACCGET    : RW = 1 : Endif
      If [F:ACLAF]INTEVAL  <> [F:DACLAF]INTEVAL      : RW = 1 : Endif
      If [F:ACLAF]LOBTAB   <> [F:DACLAF]LOBTAB       : RW = 1 : Endif
      If [F:ACLAF]LOBFLD   <> [F:DACLAF]LOBFLD       : RW = 1 : Endif
      If [F:ACLAF]LOBCNT   <> [F:DACLAF]LOBCNT       : RW = 1 : Endif
      If !RW : Call TXT([F:ACLAF]INTFLD,RW) From DOSSUB : Endif
      If !RW : Call TXT([F:ACLAF]INTSHTFLD,RW) From DOSSUB : Endif
      If RW
       DIFF  = 1
       [F:DACLAF2] = [F:DACLAF]
       [F:DACLAF] = [F:ACLAF]
       If [F:DACLAF2]CODCTL<>""
        [F:DACLAF]CODCTL  = [F:DACLAF2]CODCTL
        [F:DACLAF]TABCONT  = [F:DACLAF2]TABCONT
       Endif : # Table de contrôle
       # On conserve le code d'accès sauf s'il commence par un "/"
       If left$([F:DACLAF2]ACS,1)<>"/"
        [F:DACLAF]ACS  = [F:DACLAF2]ACS
       Endif
       Rewrite [DACLAF]
       If fstat : Call ERREUR("ACLAFLD"-[F:DACLAF]CODCLA-[F:DACLAF]FLDCLA,2) From DOSDIC : Endif
      Endif

      # update or creation of field parameters

      For [ACLFP]ACLFP0 Where CODCLA=[F:ACLAF]CODCLA & FLDCLA=[F:ACLAF]FLDCLA
       Read [DACLFP]ACLFP0 = [F:ACLFP]CODCLA;[F:ACLFP]TYPPAR;[F:ACLFP]TYPKEY;[F:ACLFP]FLDCLA;[F:ACLFP]CODPAR
       If fstat
        DIFF = 1
        [F:DACLFP] = [F:ACLFP]
        Write [DACLFP]
        If fstat : Call ERREUR("ACLAPARFLD"-[F:DACLFP]CODCLA-[F:DACLFP]FLDCLA-[F:DACLFP]CODPAR,1) From DOSDIC : Endif
       Else
        RW = 0
        If [F:ACLFP]ADRVAL   <> [F:DACLFP]ADRVAL   : RW = 57 : Endif
        If [F:ACLFP]VALEUR   <> [F:DACLFP]VALEUR   : RW = 57 : Endif
        If [F:ACLFP]TYPINT   <> [F:DACLFP]TYPINT   : RW = 57 : Endif
        If [F:ACLFP]NUMPAR   <> [F:DACLFP]NUMPAR   : RW = 57 : Endif
        If RW
         DIFF = RW
         [F:DACLFP] = [F:ACLFP]
         Rewrite [DACLFP]
         If fstat : Call ERREUR("ACLAPARFLD"-[F:DACLFP]CODCLA-[F:DACLFP]FLDCLA-[F:DACLFP]CODPAR,2) From DOSDIC : Endif
        Endif
       Endif
      Next ACLFP

      #95271
      Gosub FILL_FLD_PAR

      # removal of excess field parameters

      For [DACLFP]ACLFP0 Where CODCLA=[F:ACLAF]CODCLA & FLDCLA=[F:ACLAF]FLDCLA
       Read [ACLFP]ACLFP0 = [F:DACLFP]CODCLA;[F:DACLFP]TYPPAR;[F:DACLFP]TYPKEY;[F:DACLFP]FLDCLA;[F:DACLFP]CODPAR
       #95271
       If fstat & ([F:DACLFP]TYPPAR=2
&          | ([F:DACLFP]TYPPAR=1 & [F:DACLFP]TYPKEY=2 & !find([F:DACLFP]CODPAR,WWCODPAR(0..[L]WWNBRPARALL-1)))
&          | ([F:DACLFP]TYPPAR=1 & [F:DACLFP]TYPKEY<>2 & !find([F:DACLFP]CODPAR,RES_COD(0..[L]RES_NBR-1)))
&                 )
        Delete [DACLFP]
        If fstat=1 : Call ERREUR("ACLAPARFLD"-[F:DACLFP]CODCLA-[F:DACLFP]FLDCLA-[F:DACLFP]CODPAR,3) From DOSDIC : Endif
       Endif
      Next DACLFP

     Endif
    Next ACLAF

    # removal of excess fields

    For [DACLAF]ACLAF0 Where CODCLA=[F:ACLA]CODCLA
     If !find([F:DACLAF]ACTFLD,GSPE(1..GNBSPE))
      If !find([F:DACLAF]FLDCLA,TBZONE(1..NBZONE))
       DIFF = 1
       Delete [DACLFP] Where CODCLA=[F:ACLA]CODCLA & FLDCLA=[F:DACLAF]FLDCLA
       If fstat=1 : Call ERREUR("ACLAPARFLD"-[F:ACLA]CODCLA-[F:DACLAF]FLDCLA,3) From DOSDIC : Endif
       Delete [DACLAF]
       If fstat=1 : Call ERREUR("ACLAFLD"-[F:DACLAF]CODCLA-[F:DACLAF]FLDCLA,3) From DOSDIC : Endif
      Else
       #96528
       If [DACLAF]ACTFLD<>""
        Read [DACV]CODACT = [F:DACLAF]ACTFLD
        If fstat or [DACV]FLACT<>2
         DIFF = 1
         Delete [DACLFP] Where CODCLA=[F:ACLA]CODCLA & FLDCLA=[F:DACLAF]FLDCLA
         If fstat=1 : Call ERREUR("ACLAPARFLD"-[F:ACLA]CODCLA-[F:DACLAF]FLDCLA,3) From DOSDIC : Endif
         Delete [DACLAF]
         If fstat=1 : Call ERREUR("ACLAFLD"-[F:DACLAF]CODCLA-[F:DACLAF]FLDCLA,3) From DOSDIC : Endif
        Endif
       Endif
       #
      Endif
     Endif
     Call DIFFACT([F:ADS]DOSSIER,[F:DACLAF]ACTFLD,ACTIV) From DOSSUB
    Next DACLAF

    # --------------------------------#
    # Comparison and update methods

    For [ACLAM]ACLAM0 Where CODCLA=[F:ACLA]CODCLA
     Read [DACLAM]ACLAM0=[F:ACLAM]CODCLA;[F:ACLAM]CODMET
     If fstat
      DIFF = 1
      [F:DACLAM] = [F:ACLAM]
      Write [DACLAM]
      If fstat : Call ERREUR("ACLAMET"-[F:ACLAM]CODCLA-[F:ACLAM]CODMET,1) From DOSDIC : Endif
      WCODEPARDEF = [F:ACLAM]CODMET
      Gosub CREPARDEF
     Elsif !find([F:DACLAM]ACTMET,GSPE(1..GNBSPE))
      Call DIFFACT([F:ADS]DOSSIER,[F:ACLAM]ACTMET,ACTIV) From DOSSUB
      RW = 0
      If [F:ACLAM]NOMET    <> [F:DACLAM]NOMET    : RW = 58 : Endif
      If [F:ACLAM]DONMET   <> [F:DACLAM]DONMET   : RW = 58 : Endif
      If [F:ACLAM]INTMET   <> [F:DACLAM]INTMET   : RW = 58 : Endif
      If [F:ACLAM]ACTMET   <> [F:DACLAM]ACTMET   : RW = 58 : Endif
      If [F:ACLAM]FLGOPE   <> [F:DACLAM]FLGOPE   : RW = 58 : Endif
      If [F:ACLAM]ACSOPE   <> [F:DACLAM]ACSOPE   : RW = 58 : Endif
      If [F:ACLAM]INDOPE   <> [F:DACLAM]INDOPE   : RW = 58 : Endif
      #If [F:ACLAM]HLPMET   <> [F:DACLAM]HLPMET   : RW = 58 : Endif
      If !RW : Call TXT([F:ACLAM]INTMET,RW) From DOSSUB : Endif
      If RW
       DIFF = RW
       [F:DACLAM] = [F:ACLAM]
       Rewrite [DACLAM]
       If fstat : Call ERREUR("ACLAMET"-[F:ACLAM]CODCLA-[F:ACLAM]CODMET,2) From DOSDIC : Endif
      Endif

      # update or creation of method parameters

      For [ACLPD]ACLPD0 Where CODCLA=[F:ACLAM]CODCLA & CODE=[F:ACLAM]CODMET
       Read [DACLPD]ACLPD0 = [F:ACLPD]CODCLA;[F:ACLPD]CODE;[F:ACLPD]CODPAR
       If fstat
        DIFF = 1
        [F:DACLPD] = [F:ACLPD]
        Write [DACLPD]
        If fstat : Call ERREUR("ACLAPARDEF"-[F:DACLPD]CODCLA-[F:DACLPD]CODE-[F:DACLPD]CODPAR,1) From DOSDIC : Endif
       Else
        RW = 0
        If [F:ACLPD]NOPAR    <> [F:DACLPD]NOPAR    : RW = 59 : Endif
        If [F:ACLPD]TYPINTPAR<> [F:DACLPD]TYPINTPAR: RW = 59 : Endif
        If [F:ACLPD]TYPKEY   <> [F:DACLPD]TYPKEY   : RW = 59 : Endif
        If [F:ACLPD]INTPAR   <> [F:DACLPD]INTPAR   : RW = 59 : Endif
        If [F:ACLPD]CLAPAR   <> [F:DACLPD]CLAPAR   : RW = 59 : Endif
        If [F:ACLPD]MODPAR   <> [F:DACLPD]MODPAR   : RW = 59 : Endif
        If [F:ACLPD]DIMPAR   <> [F:DACLPD]DIMPAR   : RW = 59 : Endif
        If !RW : Call TXT([F:ACLPD]INTPAR,RW) From DOSSUB : Endif
        If RW
         DIFF = RW
         [F:DACLPD] = [F:ACLPD]
         Rewrite [DACLPD]
         If fstat : Call ERREUR("ACLAPARDEF"-[F:DACLPD]CODCLA-[F:DACLPD]CODE-[F:DACLPD]CODPAR,2) From DOSDIC : Endif
        Endif
       Endif
      Next ACLPD

      # removal of excess method parameters

      For [DACLPD]ACLPD0  Where CODCLA=[F:ACLAM]CODCLA & CODE=[F:ACLAM]CODMET
       Read [ACLPD]ACLPD0 = [F:DACLPD]CODCLA;[F:DACLPD]CODE;[F:DACLPD]CODPAR
       If fstat
        Delete [DACLPD]
        If fstat=1 : Call ERREUR("ACLAPARDEF"-[F:DACLPD]CODCLA-[F:DACLPD]CODE-[F:DACLPD]CODPAR,3) From DOSDIC : Endif
       Endif
      Next DACLPD

     Endif
    Next ACLAM

    # removal of excess methods

    For [DACLAM]ACLAM0 Where CODCLA=[F:ACLA]CODCLA
     If !find([F:DACLAM]ACTMET,GSPE(1..GNBSPE))
      Read [ACLAM]ACLAM0=[F:DACLAM]CODCLA;[F:DACLAM]CODMET
      If fstat
       Delete [DACLPD] Where CODCLA=[F:DACLAM]CODCLA & CODE=[F:DACLAM]CODMET
       If fstat=1 : Call ERREUR("ACLAPARDEF"-[F:DACLAM]CODCLA-[F:DACLAM]CODMET,3) From DOSDIC : Endif
       Delete [DACLAM]
       If fstat=1 : Call ERREUR("ACLAMET"-[F:DACLAM]CODCLA-[F:DACLAM]CODMET,3) From DOSDIC : Endif
      Endif
     Endif
    Next DACLAM


    # --------------------------------#
    # Comparison and update standard methods

    For [ACLAT]ACLAT0 Where CODCLA=[F:ACLA]CODCLA
     Read [DACLAT]ACLAT0=[F:ACLAT]CODCLA;[F:ACLAT]CODMETSTD
     If fstat
      DIFF = 1
      [F:DACLAT] = [F:ACLAT]
      Write [DACLAT]
      If fstat : Call ERREUR("ACLAMETSTD"-[F:ACLAT]CODCLA-[F:ACLAT]CODMETSTD,1) From DOSDIC : Endif
     Elsif !find([F:DACLAT]ACTMETSTD,GSPE(1..GNBSPE))
      Call DIFFACT([F:ADS]DOSSIER,[F:ACLAT]ACTMETSTD,ACTIV) From DOSSUB
      RW = 0
      If [F:ACLAT]NOMETSTD    <> [F:DACLAT]NOMETSTD    : RW = 58 : Endif
      If [F:ACLAT]ENAMETSTD   <> [F:DACLAT]ENAMETSTD   : RW = 58 : Endif
      If [F:ACLAT]ACTMETSTD   <> [F:DACLAT]ACTMETSTD   : RW = 58 : Endif
      If [F:ACLAT]ACSMETSTD   <> [F:DACLAT]ACSMETSTD   : RW = 58 : Endif
      If RW
       DIFF = RW
       [F:DACLAT] = [F:ACLAT]
       Rewrite [DACLAT]
       If fstat : Call ERREUR("ACLAMETSTD"-[F:ACLAT]CODCLA-[F:ACLAT]CODMETSTD,2) From DOSDIC : Endif
      Endif

     Endif
    Next ACLAT

    # removal of excess standard methods

    For [DACLAT]ACLAT0 Where CODCLA=[F:ACLA]CODCLA
     If !find([F:DACLAT]ACTMETSTD,GSPE(1..GNBSPE))
      Read [ACLAT]ACLAT0=[F:DACLAT]CODCLA;[F:DACLAT]CODMETSTD
      If fstat
       Delete [DACLAT]
       If fstat=1 : Call ERREUR("ACLAMETSTD"-[F:DACLAT]CODCLA-[F:DACLAT]CODMETSTD,3) From DOSDIC : Endif
      Endif
     Endif
    Next DACLAT

    # --------------------------------#
    # Comparison and update Links

    NBACLAKSTD=0
    NBACLAKSPE=0
    For [ACLAK]ACLAK1 Where CODCLA=[F:ACLA]CODCLA
     Read [DACLAK]ACLAK0=[F:ACLAK]CODCLA;[F:ACLAK]REFLNK
     If fstat
      DIFF = 1
      NBACLAKSTD=max(NBACLAKSTD,[F:ACLAK]NUMLIG)
      [F:DACLAK] = [F:ACLAK]
      Write [DACLAK]
      If fstat : Call ERREUR("ACLALNK"-[F:ACLAK]CODCLA-[F:ACLAK]REFLNK,1) From DOSDIC : Endif
     Elsif !find([F:DACLAK]ACVLNK,GSPE(1..GNBSPE))
      NBACLAKSTD=max(NBACLAKSTD,[F:ACLAK]NUMLIG)
      Call DIFFACT([F:ADS]DOSSIER,[F:DACLAK]ACVLNK,ACTIV) From DOSSUB
      RW = 0
      If [F:ACLAK]TABLNK    <> [F:DACLAK]TABLNK    : RW = 58 : Endif
      If [F:ACLAK]ABRLNK    <> [F:DACLAK]ABRLNK    : RW = 58 : Endif
      If [F:ACLAK]TABORI    <> [F:DACLAK]TABORI    : RW = 58 : Endif
      If [F:ACLAK]ABRORI    <> [F:DACLAK]ABRORI    : RW = 58 : Endif
      If [F:ACLAK]TYPLNK    <> [F:DACLAK]TYPLNK    : RW = 58 : Endif
      If [F:ACLAK]CLELNK    <> [F:DACLAK]CLELNK    : RW = 58 : Endif
      If [F:ACLAK]CLESORT   <> [F:DACLAK]CLESORT    : RW = 58 : Endif
      If [F:ACLAK]EXPLNK    <> [F:DACLAK]EXPLNK    : RW = 58 : Endif
      If [F:ACLAK]EXPSEL    <> [F:DACLAK]EXPSEL    : RW = 58 : Endif
      If [F:ACLAK]NUMLIG    <> [F:DACLAK]NUMLIG    : RW = 58 : Endif
      If [F:ACLAK]CLALNK    <> [F:DACLAK]CLALNK    : RW = 58 : Endif
      If [F:ACLAK]FLGR      <> [F:DACLAK]FLGR      : RW = 58 : Endif
      If [F:ACLAK]FLGC      <> [F:DACLAK]FLGC      : RW = 58 : Endif
      If [F:ACLAK]FLGU      <> [F:DACLAK]FLGU      : RW = 58 : Endif
      If [F:ACLAK]FLGD      <> [F:DACLAK]FLGD      : RW = 58 : Endif
      If [F:ACLAK]FLGA      <> [F:DACLAK]FLGA      : RW = 58 : Endif
      If [F:ACLAK]ACVLNK    <> [F:DACLAK]ACVLNK    : RW = 58 : Endif
      If [F:ACLAK]FLGV      <> [F:DACLAK]FLGV     : RW = 58 : Endif
      If RW
       DIFF = RW
       [F:DACLAK] = [F:ACLAK]
       Rewrite [DACLAK]
       If fstat : Call ERREUR("ACLALNK"-[F:ACLAK]CODCLA-[F:ACLAK]REFLNK,2) From DOSDIC : Endif
      Endif
     Endif

     For [ACLAKP]ACLAKP0 Where CODCLA=[F:ACLAK]CODCLA & REFLNK=[F:ACLAK]REFLNK
      Read [DACLAKP]ACLAKP0 = [F:ACLAKP]CODCLA;[F:ACLAKP]REFLNK;[F:ACLAKP]KEYMAP
      If fstat
       DIFF = 1
       [F:DACLAKP] = [F:ACLAKP]
       Write [DACLAKP]
       If fstat : Call ERREUR("ACLAMAP"-[F:DACLAKP]CODCLA-[F:DACLAKP]REFLNK-[F:DACLAKP]KEYMAP,1) From DOSDIC : Endif
      Else
       RW = 0
       If [F:ACLAKP]PROMAP    <> [F:DACLAKP]PROMAP    : RW = 59 : Endif
       If [F:ACLAKP]VALDEFMAP<> [F:DACLAKP]VALDEFMAP: RW = 59 : Endif
       If RW
        DIFF = RW
        [F:DACLAKP] = [F:ACLAKP]
        Rewrite [DACLAKP]
        If fstat : Call ERREUR("ACLAMAP"-[F:DACLAKP]CODCLA-[F:DACLAKP]REFLNK-[F:DACLAKP]KEYMAP,2) From DOSDIC : Endif
       Endif
      Endif
     Next ACLAKP

    Next ACLAK

    # removal of excess Links

    For [DACLAK]ACLAK1 Where CODCLA=[F:ACLA]CODCLA
     If !find([F:DACLAK]ACVLNK,GSPE(1..GNBSPE))
      Read [ACLAK]ACLAK0=[F:DACLAK]CODCLA;[F:DACLAK]REFLNK
      If fstat
       For [DACLAKP]ACLAKP0 Where CODCLA=[DACLAK]CODCLA & REFLNK=[DACLAK]REFLNK
        Delete [DACLAKP] Curr
        If fstat=1 : Call ERREUR("ACLAMAP"-[F:DACLAKP]CODCLA-[F:DACLAKP]REFLNK-[F:DACLAKP]KEYMAP,3) From DOSDIC : Endif
       Next
       Delete [DACLAK]
       If fstat=1 : Call ERREUR("ACLALNK"-[F:DACLAK]CODCLA-[F:DACLAK]REFLNK,3) From DOSDIC : Endif
      Else
       #96528
       If [DACLAK]ACVLNK<>""
        Read [DACV]CODACT = [F:DACLAK]ACVLNK
        If fstat or [DACV]FLACT<>2
         Delete [DACLFP] Where CODCLA=[DACLAK]CODCLA & FLDCLA=[DACLAK]REFLNK
         If fstat=1 : Call ERREUR("ACLAPARFLD"-[DACLAK]CODCLA-[DACLAK]REFLNK,3) From DOSDIC : Endif
         Delete [DACLAF]  Where CODCLA=[DACLAK]CODCLA & FLDCLA=[DACLAK]REFLNK
         If fstat=1 : Call ERREUR("ACLAFLD"-[DACLAK]CODCLA-[DACLAK]REFLNK,3) From DOSDIC : Endif
         Delete [DACLAKP] Where CODCLA=[DACLAK]CODCLA & REFLNK=[DACLAK]REFLNK
         If fstat=1 : Call ERREUR("ACLAMAP"-[DACLAK]CODCLA-[DACLAK]REFLNK,3) From DOSDIC : Endif
         Delete [DACLAK]
         If fstat=1 : Call ERREUR("ACLALNK"-[F:DACLAK]CODCLA-[F:DACLAK]REFLNK,3) From DOSDIC : Endif
        Endif
       Endif
      Endif
     Else : #SPE
      DIFF = 1
      NBACLAKSPE+=1
      [F:DACLAK]NUMLIG=NBACLAKSTD+NBACLAKSPE
      Rewrite [DACLAK]
      If fstat : Call ERREUR("ACLALNK"-[F:ACLAK]CODCLA-[F:ACLAK]REFLNK,2) From DOSDIC : Endif
     Endif
    Next DACLAK

    #--------------------------------#
    # Comparison and update options

    For [ACLAO]ACLAO0 Where CODCLA=[F:ACLA]CODCLA
     Read [DACLAO]ACLAO0=[F:ACLAO]CODCLA;[F:ACLAO]OPTCOD
     If fstat
      DIFF = 1
      [F:DACLAO] = [F:ACLAO]
      Write [DACLAO]
      If fstat : Call ERREUR("ACLAOPT"-[F:ACLAO]CODCLA-[F:ACLAO]OPTCOD,1) From DOSDIC : Endif
     Elsif !find([F:DACLAO]OPTACT,GSPE(1..GNBSPE))
      Call DIFFACT([F:ADS]DOSSIER,[F:ACLAO]OPTACT,ACTIV) From DOSSUB
      RW = 0

       If [F:ACLAO]OPTLIB <> [F:DACLAO]OPTLIB     : RW = 54 : Endif
       If [F:ACLAO]OPTCOD <> [F:DACLAO]OPTCOD     : RW = 54 : Endif
       If [F:ACLAO]OPTCND <> [F:DACLAO]OPTCND     : RW = 54 : Endif
       If [F:ACLAO]OPTERR <> [F:DACLAO]OPTERR     : RW = 54 : Endif
       If [F:ACLAO]OPTACT <> [F:DACLAO]OPTACT     : RW = 54 : Endif
       If !RW : Call TXT([F:ACLAO]OPTLIB,RW) From DOSSUB : Endif
       If !RW : Call TXT([F:ACLAO]OPTERR,RW) From DOSSUB : Endif

      If RW
       DIFF = RW
       [F:DACLAO] = [F:ACLAO]
       Rewrite [DACLAO]
       If fstat : Call ERREUR("ACLAOPT"-[F:ACLAO]CODCLA-[F:ACLAO]OPTCOD,2) From DOSDIC : Endif
      Endif
     Endif
    Next ACLAO

    # removal of excess options

    For [DACLAO]ACLAO0 Where CODCLA=[F:ACLA]CODCLA
     If !find([F:DACLAO]OPTACT,GSPE(1..GNBSPE))
      Read [ACLAO]ACLAO0=[F:DACLAO]CODCLA;[F:DACLAO]OPTCOD
      If fstat
       Delete [DACLAO]
       If fstat=1 : Call ERREUR("ACLAOPT"-[F:DACLAO]CODCLA-[F:DACLAO]OPTCOD,3) From DOSDIC : Endif
      Endif
     Endif
    Next DACLAO

    #--------------------------------#
    # Comparison and update collections

    For [ACLAC]ACLAC0 Where CODCLA=[F:ACLA]CODCLA
     Read [DACLAC]ACLAC0=[F:ACLAC]CODCLA;[F:ACLAC]CODCOL
     If fstat
      DIFF = 1
      [F:DACLAC] = [F:ACLAC]
      Write [DACLAC]
      If fstat : Call ERREUR("ACLACOL"-[F:ACLAC]CODCLA-[F:ACLAC]CODCOL,1) From DOSDIC : Endif
     Elsif !find([F:DACLAC]ACTCOL,GSPE(1..GNBSPE))
      Call DIFFACT([F:ADS]DOSSIER,[F:ACLAC]ACTCOL,ACTIV) From DOSSUB
      RW = 0

       If [F:ACLAC]CODCOL <> [F:DACLAC]CODCOL     : RW = 55 : Endif
       If [F:ACLAC]ACTCOL <> [F:DACLAC]ACTCOL     : RW = 55 : Endif
       If [F:ACLAC]MINCOL <> [F:DACLAC]MINCOL     : RW = 55 : Endif
       If [F:ACLAC]MAXCOL <> [F:DACLAC]MAXCOL     : RW = 55 : Endif
       If [F:ACLAC]PROCOL <> [F:DACLAC]PROCOL     : RW = 55 : Endif
       If [F:ACLAC]INTCOL <> [F:DACLAC]INTCOL     : RW = 55 : Endif
       If [F:ACLAC]FLGINSCOL <> [F:DACLAC]FLGINSCOL     : RW = 55 : Endif
       If [F:ACLAC]FLGSUPCOL <> [F:DACLAC]FLGSUPCOL     : RW = 55 : Endif
       If [F:ACLAC]FLGTRICOL <> [F:DACLAC]FLGTRICOL     : RW = 55 : Endif
       If [F:ACLAC]FLGAPDCOL <> [F:DACLAC]FLGAPDCOL     : RW = 55 : Endif
       If !RW : Call TXT([F:ACLAC]INTCOL,RW) From DOSSUB : Endif

      If RW
       DIFF = RW
       [F:DACLAC] = [F:ACLAC]
       Rewrite [DACLAC]
       If fstat : Call ERREUR("ACLACOL"-[F:ACLAC]CODCLA-[F:ACLAC]CODCOL,2) From DOSDIC : Endif
      Endif
     Endif
    Next ACLAC

    # removal of excess collections
     #delete non-used collections
    For [DACLAC]ACLAC0 Where CODCLA=[F:ACLA]CODCLA
     J=0
     For [DACLAF] Where CODCLA=[F:DACLA]CODCLA & FLDGRP=[F:DACLAC]CODCOL
        J=1
        Break
     Next
     If J=0
       Delete [DACLAC]
       If fstat=1 : Call ERREUR("ACLACOL"-[F:DACLAC]CODCLA-[F:DACLAC]CODCOL,3) From DOSDIC : Endif
#     Elsif !find([F:DACLAC]ACTCOL,GSPE(1..GNBSPE))
#      Read [ACLAC]ACLAC0=[F:DACLAC]CODCLA;[F:DACLAC]CODCOL
#      If fstat
#       Delete [DACLAC]
#       If fstat=1 : Call ERREUR("ACLACOL"-[F:DACLAC]CODCLA-[F:DACLAC]CODCOL,3) From DOSDIC : Endif
#      Endif
     Endif
    Next DACLAC

    #########################
    # Update header
    #########################
    If DIFF
     If GTSTDOS
      Call ECR_TRACE("Diff"-mess(254,125,1)-[F:ACLA]CODCLA-num$(DIFF),0) From GESECRAN
     Endif
     RWO = 1
     [F:DACLA2] = [F:DACLA]
     [F:DACLA] = [F:ACLA]

     # Get specifics treatments
     For B=0 To [F:DACLA2]NBRTRT-1
      If find([F:DACLA2]ACTTRT(B),GSPE(1..GNBSPE))
       J=find([F:DACLA2]CODTRT(B),[F:DACLA]CODTRT(0..[F:DACLA]NBRTRT-1))
       If J
          [F:DACLA]CODTRT(J-1) = [F:DACLA2]CODTRT(B)
          [F:DACLA]TYPTRT(J-1) = [F:DACLA2]TYPTRT(B)
          [F:DACLA]ACTTRT(J-1) = [F:DACLA2]ACTTRT(B)
          [F:DACLA]RANTRT(J-1) = [F:DACLA2]RANTRT(B)
       Else
          J=[F:DACLA]NBRTRT
          [F:DACLA]NBRTRT +=1
          [F:DACLA]CODTRT(J) = [F:DACLA2]CODTRT(B)
          [F:DACLA]TYPTRT(J) = [F:DACLA2]TYPTRT(B)
          [F:DACLA]ACTTRT(J) = [F:DACLA2]ACTTRT(B)
          [F:DACLA]RANTRT(J) = [F:DACLA2]RANTRT(B)
       Endif
      Endif
     Next B


     GNBACLA += 1
     If dim([F:DACLA]UPDDAT)>0 : [F:DACLA]UPDDAT = date$ : Endif
     [F:DACLA]UPDUSR = GUSER
     [F:DACLA]UPDFLG = 1
     Rewrite [DACLA]
     If fstat : Call ERREUR("ACLASSE"-[F:DACLA]CODCLA,2) From DOSDIC : Endif

    Elsif ACTIV : # Change of activity code

     RWO = 1
     If dim([F:DACLA]UPDDAT)>0 : [F:DACLA]UPDDAT = date$ : Endif
     [F:DACLA]UPDUSR = GUSER
     [F:DACLA]UPDFLG = 1
     GNBACLA += 1
     Rewrite [DACLA]
     If fstat : Call ERREUR("ACLASSE"-[F:DACLA]CODCLA,2) From DOSDIC : Endif

    Endif

   Endif : # (new & old)
  Endif : # (spec)

 Commit

 Read [ACLA]ACLA0 Next
Wend

Close Local File [DACLA], [DACLA2], [DACLA3], [DACLAF], [DACLAF2], [DACLFP],[DACLAM], [DACLPD], [DACLAT], [DACLAK], [DACLAO], [DACLAC]
Close Local File [DACV] , [DACLAKP]
Close Local File [ACLA], [ACLAF], [ACLFP],[ACLAM], [ACLPD], [ACLAT], [ACLAK], [ACLAO], [ACLAC] ,[ACLAKP]
Close Local File [DAOB]
Return

#-----------------------------------#
$CREPARFLD
For [ACLFP]ACLFP0 Where CODCLA=[F:ACLA]CODCLA & FLDCLA=[F:ACLAF]FLDCLA
 [F:DACLFP] = [F:ACLFP]
 Write [DACLFP]
 If fstat : Call ERREUR("CREPARFLD/ACLAPARFLD"-[F:DACLFP]CODCLA-[F:DACLFP]FLDCLA-[F:DACLFP]CODPAR,1) From DOSDIC : Endif
Next
Return

#-----------------------------------#
$CREPARDEF
For [ACLPD]ACLPD0 Where CODCLA=[F:ACLA]CODCLA & CODE=WCODEPARDEF
 [F:DACLPD] = [F:ACLPD]
 Write [DACLPD]
 If fstat : Call ERREUR("CREPARDEF/ACLAPARDEF"-[F:DACLPD]CODCLA-[F:DACLPD]CODE-[F:DACLPD]CODPAR,1) From DOSDIC : Endif
Next
Return

#------------------------------------------------------
$FILL_FLD_PAR
#95271
Raz RES_COD,RES_CLA, RES_TIT
Raz RES_TYP, RES_MOD, RES_ORD, RES_NBR
Raz WWCODPAR,WWCODCLAPAR,WWCODCUR,WWFLDCLE, WWINTITPAR
Raz WWTYPINTPAR, WWADRVAL, WWTYPKEY, WWNUMPAR,WWTYPPAR,WWNOLIB,WWLNG,WWTYPAFF, WWNBRPARALL


If filinfo(filpath("FIL","AVIEWIND","fde",[F:ADS]DOSSIER),0)<0
 Local File =[F:ADS]DOSSIER+".ATABIND" [ATI]
Else
  Local File =[F:ADS]DOSSIER+".AVIEWIND" [ATI]
Endif
Local File =[F:ADS]DOSSIER+".ATYPE"      [ATY]

If [F:ACLAF]CODTYP<>""
 Read [ATY]CODTYP = [F:ACLAF]CODTYP
 If !fstat
  Call LOAD_TYPE_PARAM([F:ADS]DOSSIER,[F:ACLAF]CODTYP,RES_COD,RES_TYP,RES_TIT,RES_MOD,RES_CLA,RES_ORD,RES_NBR) From AFNC
 Endif
 If [F:ACLAF]LOBTAB<>""
  Read [ATI]NUMLIG = [F:ACLAF]LOBTAB;1
  If !fstat
   Call CHARGE_CLE([F:ATI]CODFIC,[F:ATI]DESCRIPT,[F:ADS]DOSSIER,[F:ATY]CODCLA,[F:ACLAF]FLDCLA,1,WWCODPAR,WWCODCUR,WWTYPPAR,
& WWFLDCLE,WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,
& WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,WWNBRPARALL) From SUBACLA
  Endif
 Elsif [F:ATY]CODCLA<>""
  Call CHARGE_CLA_ATI_CLE([F:ADS]DOSSIER,[F:ATY]CODCLA,[F:ACLAF]FLDCLA,1,WWCODPAR,WWCODCUR,WWTYPPAR,WWFLDCLE,WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,
& WWNBRPARALL) From SUBACLA
 Endif
Endif
LogicClose File [ATI],[ATY]
Return

## Deleting a data class
#-----------------------------------#
Subprog EFFACE(WCLA)
Value Char WCLA
Call ECR_TRACE(mess(256,125,1)-WCLA,0) From GESECRAN  : # Suppression classe

Call DELETE_ALLSTC([F:ADS]DOSSIER,WCLA) From ACLAVALSUB

Delete [DACLA] Where CODCLA=WCLA
If fstat=1 : Call ERREUR("ACLASSE"-WCLA,3) From DOSDIC : Endif
Delete [DACLAF] Where CODCLA=WCLA
If fstat=1 : Call ERREUR("ACLAFLD"-WCLA,3) From DOSDIC : Endif
Delete [DACLFP] Where CODCLA=WCLA
If fstat=1 : Call ERREUR("ACLAPARFLD"-WCLA,3) From DOSDIC : Endif
Delete [DACLAC] Where CODCLA=WCLA
If fstat=1 : Call ERREUR("ACLACOL"-WCLA,3) From DOSDIC : Endif
Delete [DACLAO] Where CODCLA=WCLA
If fstat=1 : Call ERREUR("ACLAOPT"-WCLA,3) From DOSDIC : Endif
Delete [DACLAM] Where CODCLA=WCLA
If fstat=1 : Call ERREUR("ACLAMET"-WCLA,3) From DOSDIC : Endif
Delete [DACLPD] Where CODCLA=WCLA
If fstat=1 : Call ERREUR("ACLAPARDEF"-WCLA,3) From DOSDIC : Endif
Delete [DACLAT] Where CODCLA=WCLA
If fstat=1 : Call ERREUR("ACLAMETSTD"-WCLA,3) From DOSDIC : Endif
Delete [DACLAK] Where CODCLA=WCLA
If fstat=1 : Call ERREUR("ACLALNK"-WCLA,3) From DOSDIC : Endif
Delete [DACLAKP] Where CODCLA=WCLA
If fstat=1 : Call ERREUR("ACLAMAP"-WCLA,3) From DOSDIC : Endif
End
