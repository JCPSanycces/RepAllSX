#<AdxTL>@(#)3.0.0.0 $Revision$

$METHODS
Case [L]CURPTH
   When ""
      Case [L]ACTION
        When "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_DECODE_CRITERIA_AFTER
#        When "AQUERY_PRIMARY_KEYS"          : Gosub AQUERY_PRIMARY_KEYS
#        When "AQUERY_OPEN_AFTER"            : Gosub AQUERY_OPEN_AFTER
#        When "AQUERY_CRITERIA_AFTER"        : Gosub AQUERY_CRITERIA_AFTER
#        When "AQUERY_JOIN_AFTER"            : Gosub AQUERY_JOIN_AFTER
#        When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
#        When "AQUERY_CLOSE_AFTER"           : Gosub AQUERY_CLOSE_AFTER

        When "AREAD_AFTER"                  : Gosub AREAD_AFTER

      Endcase
Endcase
Return

$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

$PROPERTIES
  Case [L]CURPRO
    When "PHY.LCTCOD"            : Gosub LCTCOD
    When "PHY.FCY"               : Gosub FCY
    When "PHY.CPY"               : Gosub CPY
  Endcase
Return

#------------------------
$AQUERY_DECODE_CRITERIA_AFTER
Return

#------------------------
$AREAD_AFTER
#  # Physical element is disposed.
#  If (ISSDAT <> AVOID.ADATE) Then
#    [L]ASTATUS = fmet this.ASETERROR("", "L'élément physique est sorti", [V]CST_AINFO)
#  Endif

   # LCTCOD - Cannot be modified
   ASTATUS = fmet this.PHY.ASETATTRIBUTE("LCTCOD","$isDisabled","true")
   # BUICOD - Cannot be modified
   ASTATUS = fmet this.PHY.ASETATTRIBUTE("BUICOD","$isDisabled","true")
   # CPY - Cannot be modified
   ASTATUS = fmet this.PHY.ASETATTRIBUTE("CPY","$isDisabled","true")
   # FCY - Cannot be modified
   ASTATUS = fmet this.PHY.ASETATTRIBUTE("FCY","$isDisabled","true")
   # AASREF - No modification if the physical asset is linked to a fixedasset
   If (this.PHY.AASREF <> AVOID.ACHAR)
     ASTATUS = fmet this.PHY.ASETATTRIBUTE("AASREF","$isDisabled","true")
   Else
     ASTATUS = fmet this.PHY.ASETATTRIBUTE("AASREF","$isDisabled","false")
   Endif

Return


#-----
$LCTCOD
  Case ACTION
    When "PROPAGATE"
      # facility is inhereted from the location and company from facility
        Local Instance LCT Using C_PHYLCT : LCT = NewInstance C_PHYLCT AllocGroup null
        If fmet LCT.AREAD(this.LCTCOD) = [V]CST_AOK
          this.CPY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(LCT.FCY,"LEGCPY")
          this.FCY = LCT.FCY
        Endif
        FreeGroup LCT
  Endcase
Return

#-----
$FCY
  Case ACTION
    When "INIT"
      ASTATUS = fmet this.ASETATTRIBUTE("FCY","$isDisabled","true")
  Endcase
Return

#-----
$CPY
  Case ACTION
    When "INIT"
      ASTATUS = fmet this.ASETATTRIBUTE("CPY","$isDisabled","true")
  Endcase
Return

