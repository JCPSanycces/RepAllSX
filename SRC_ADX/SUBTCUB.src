#<AdxTL>@(#)2.0.0.0 $Revision$
#
# SUBTCUB
#
Raz GPILOBJ
Call OBJET("TCU",GBIDC1,GBIDC2) From GOBJET
End


$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "LIENS"    : Gosub LIENS
 When "RAZCRE"   : Gosub RAZCRE
Endcase
Return

$OUVRE
#MAE, 15/01/09, bg 51681
If clalev([F:CAC])=0  Local File GACCCODE   [CAC]  Endif
If clalev([F:CDI])=0 : Local File CADIEDEF   [CDI] : Endif
Local Integer NUMDIE
NUMDIE = 8 : # Rang dans le menu 2230
Read [CDI]CDI0 = NUMDIE
Return  

$LIENS
Gosub INIDIE
Return

$RAZCRE
Gosub INIDIE
Affzo [TCU2]20
Return

$INIDIE
If dim([M]DIE)<=0 : Return : Endif
Raz [M]DIE
Raz [M]CCE
[M]NBLIG = [F:CDI]NBRDIE
For I=0 To [F:CDI]NBRDIE-1
 [M]DIE(I) = [F:CDI]DIE(I)
 For J=0 To dim([F:TCU]DIE)-1
  If [F:TCU]DIE(J)=[F:CDI]DIE(I)
   [M]CCE(I) = [F:TCU]CCE(J)
   Break
  Endif
 Next J 
Next I
Return

