#<AdxTL>@(#)1.0.0.0 $Revision$
######################################################################
# Sous-pro pour pivot de type : fournisseurs
#                             cf AML 2240 : 25/26
###################################################
# FQ 64773 GA 05/2010 préfixe des noms de variables BPSWPIV    devient WK, 
#                                                   CNTBPSWPIV devient CNTWK
#                                                   CLSBPSWPIV devient CLSWK
######################################################################
$OUVTAB_BPS
If !clalev([F:TFO]) Local File TABFOR    [TFO] Endif
If !clalev([F:AXX]) Local File ATEXTRA   [AXX] Endif
If !clalev([F:BPR]) Local File BPARTNER  [BPR] Endif
If !clalev([F:BPS]) Local File BPSUPPLIER[BPS] Endif
If !clalev([F:CNT]) Local File CONTACT   [CNT] Endif
If !clalev([F:AIN]) Local File CONTACTCRM[AIN] Endif

If clalev([F:BPA])  = 0 : Local File BPADDRESS   [BPA]  : Endif   
Return

######################################################################
Subprog TRT_BPS(ID,CLETRT,PITBPS,P_CRITERE,PITCNTBPS,PITCLSBPS,OK)
Value Char ID()
Value Char CLETRT () 
Value Char PITBPS () 
Value Char P_CRITERE() 
Value Char PITCNTBPS () 
Value Char PITCLSBPS () 
Variable Integer OK

If PITBPS="" & PITCNTBPS="" : Return : Endif

Local Char     WCLASS (255) : Raz WCLASS
Local Char     WCLASSTMP (255) : Raz WCLASS
Local Char     FORMULE1(255) : Raz FORMULE1

Local Integer SAVADXIUM : SAVADXIUM=adxium
Local Char    SAVADXIFS : SAVADXIFS=adxifs
Local Char    SAVADXIRS : SAVADXIRS=adxirs
adxium = GUTF8
adxifs = ''
adxirs = chr$(13)+chr$(10)
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs

Gosub OUVTAB_BPS
Gosub OUVREPIVOT From CONNECTFCT


If PITBPS<>""
    Local Integer WNBBPS : Raz WNBBPS 
    Local Integer WPREBPS : Raz WPREBPS
    Local Char    OPTBPS(GDIMFIC)
    OPTBPS = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitbps")
    Local Integer WKNBZON : Raz WKNBZON
    Local Char WKNORECMES (50): Raz WKNORECMES 
    Local Integer WKHEATYP : Raz WKHEATYP 
    Local Char WKHEADMES (250): Raz WKHEADMES 
    
    Call READPIT(PITBPS,WKNBZON,WKNORECMES,WKHEATYP ,WKHEADMES ) From CONNECTFCT
    Local Char WKTABZON(GLONATB+GLONAVA+2)(1..WKNBZON) : Raz WKTABZON
    Local Char WKTABABR(GLONABR)(1..WKNBZON) : Raz WKTABABR
    Local Char WKZON(GLONAVA)(1..WKNBZON) : Raz WKTABZON
    Local Char WKFRM(150)(1..WKNBZON) : Raz WKFRM
    Local Integer WKWRK(1..WKNBZON) : Raz WKWRK
    Local Char WKVAL(255)(1..WKNBZON) : Raz WKVAL
    Local Char WKVALFIC(GLONAVA)(1..WKNBZON) : Raz WKVALFIC
    Call LOADPIVZON(PITBPS,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITBPS,WKNBZON,WKTABZON,WKTABABR,WKZON,WKWRK,WKHEATYP,WKHEADMES,WPREBPS,OPTBPS) From CONNECTFCT
Endif
If PITCNTBPS<>""
    Local Integer WNBCNTBPS : Raz WNBCNTBPS
    Local Integer WPRECNTBPS : Raz WPRECNTBPS
    Local Char    OPTCNTBPS(GDIMFIC)
    OPTCNTBPS = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitcntbps")
    Local Integer CNTWKNBZON : Raz CNTWKNBZON
    Local Char CNTWKNORECMES (50): Raz CNTWKNORECMES 
    Local Integer CNTWKHEATYP : Raz CNTWKHEATYP 
    Local Char CNTWKHEADMES (250): Raz CNTWKHEADMES 
    
    Call READPIT(PITCNTBPS,CNTWKNBZON,CNTWKNORECMES,CNTWKHEATYP ,CNTWKHEADMES ) From CONNECTFCT
    Local Char CNTWKTABZON(GLONATB+GLONAVA+2)(1..CNTWKNBZON) : Raz CNTWKTABZON
    Local Char CNTWKTABABR(GLONABR)(1..CNTWKNBZON) : Raz CNTWKTABABR
    Local Char CNTWKZON(GLONAVA)(1..CNTWKNBZON) : Raz CNTWKTABZON
    Local Char CNTWKFRM(150)(1..CNTWKNBZON) : Raz CNTWKFRM
    Local Integer CNTWKWRK(1..CNTWKNBZON) : Raz CNTWKWRK
    Local Char CNTWKVAL(255)(1..CNTWKNBZON) : Raz CNTWKVAL
    Local Char CNTWKVALFIC(GLONAVA)(1..CNTWKNBZON) : Raz CNTWKVALFIC
    Call LOADPIVZON(PITCNTBPS,CNTWKNBZON,CNTWKTABZON,CNTWKTABABR,CNTWKZON,CNTWKFRM,CNTWKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITCNTBPS,CNTWKNBZON,CNTWKTABZON,CNTWKTABABR,CNTWKZON,CNTWKWRK,CNTWKHEATYP,CNTWKHEADMES,WPRECNTBPS,OPTCNTBPS) From CONNECTFCT
Endif
If PITCLSBPS<>""
    Local Integer WNBCLSBPS : Raz WNBCLSBPS
    Local Integer WPRECLSBPS : Raz WPRECLSBPS
    Local Char    OPTCLSBPS(GDIMFIC)
    OPTCLSBPS = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitclsbps")
    OPTCLSBPSTMP = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitclsbpstmp")
    Openo OPTCLSBPSTMP ,0 Using [FPIV]
    Openo Using [FPIV]
    Local Integer CLSWKNBZON : Raz CLSWKNBZON
    Local Char CLSWKNORECMES (50): Raz CLSWKNORECMES 
    Local Integer CLSWKHEATYP : Raz CLSWKHEATYP 
    Local Char CLSWKHEADMES (250): Raz CLSWKHEADMES 
    
    Call READPIT(PITCLSBPS,CLSWKNBZON,CLSWKNORECMES,CLSWKHEATYP ,CLSWKHEADMES ) From CONNECTFCT
    Local Char CLSWKTABZON(GLONATB+GLONAVA+2)(1..CLSWKNBZON) : Raz CLSWKTABZON
    Local Char CLSWKTABABR(GLONABR)(1..CLSWKNBZON) : Raz CLSWKTABABR
    Local Char CLSWKZON(GLONAVA)(1..CLSWKNBZON) : Raz CLSWKTABZON
    Local Char CLSWKFRM(150)(1..CLSWKNBZON) : Raz CLSWKFRM
    Local Integer CLSWKWRK(1..CLSWKNBZON) : Raz CLSWKWRK
    Local Char CLSWKVAL(255)(1..CLSWKNBZON) : Raz CLSWKVAL
    Local Char CLSWKVALFIC(GLONAVA)(1..CLSWKNBZON) : Raz CLSWKVALFIC
    Call LOADPIVZON(PITCLSBPS,CLSWKNBZON,CLSWKTABZON,CLSWKTABABR,CLSWKZON,CLSWKFRM,CLSWKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITCLSBPS,CLSWKNBZON,CLSWKTABZON,CLSWKTABABR,CLSWKZON,CLSWKWRK,CLSWKHEATYP,CLSWKHEADMES,WPRECLSBPS,OPTCLSBPS) From CONNECTFCT
Endif
#######
Link [BPS] With [BPR]BPR0~=[F:BPS]BPSNUM
& As [LNK]
& Where [F:BPR]BPSFLG=2

For [LNK]BPS0  Where evalue(P_CRITERE)
    Raz [BPA]
    Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
    Gosub WR_BPS

    If PITCNTBPS<>""
        Raz [CNT]
        Read [CNT]CNT0=1;[F:BPR]BPRNUM;[F:BPR]CNTNAM
        If !fstat
            Raz[F:AIN]
            Read [AIN]AIN0=[F:BPR]CNTNAM
            Gosub WR_CNTBPS
        Endif
    Endif

    If PITCLSBPS<>""
        WCLASS=func CONNECTFCT.GETVALZON ("WCLASS",WKNBZON,WKZON,WKVAL)
         If WCLASS<>""
           Gosub WR_CLSBPS
        Endif
    Endif
Next
#######
If PITBPS<>"" : Call WRPIVOT_END(PITBPS ,WNBBPS ,WKNORECMES ,WPREBPS ,OPTBPS) From CONNECTFCT : Endif
If PITCNTBPS<>"" : Call WRPIVOT_END(PITCNTBPS ,WNBCNTBPS ,CNTWKNORECMES ,WPRECNTBPS ,OPTCNTBPS) From CONNECTFCT : Endif
If PITCLSBPS<>"" : Call WRPIVOT_END(PITCLSBPS ,WNBCLSBPS ,CLSWKNORECMES ,WPRECLSBPS ,OPTCLSBPS) From CONNECTFCT : Endif
adxium = SAVADXIUM
adxifs = SAVADXIFS
adxirs = SAVADXIRS
End

######################################################################
$WR_BPS
If PITBPS<>""
    ################################
    # fichiers BPS
    ################################
    #     Ouverture du fichier OPTBPS en écriture
    If WPREBPS = 0
      Openo OPTBPS,0 Using [FPIV]
      WPREBPS = 1
    Else
      Openo OPTBPS Using [FPIV]
    Endif
    WNBBPS += 1
    Call RAZVALPIVOT(PITBPS,WKNBZON,WKVAL,WKVALFIC) From CONNECTFCT
    Call EVALPIVOT(PITBPS,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    Call WRPIVOT(WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    #     fermeture du fichier
    Openo Using [FPIV]
Endif
Return
######################################################################
$WR_CNTBPS
If PITCNTBPS<>""
    ################################
    # fichiers CNTBPS
    ################################
    #     Ouverture du fichier OPTCNTBPS en écriture
    If WPRECNTBPS = 0
      Openo OPTCNTBPS,0 Using [FPIV]
      WPRECNTBPS = 1
    Else
      Openo OPTCNTBPS Using [FPIV]
    Endif
    WNBCNTBPS += 1
    Call RAZVALPIVOT(PITCNTBPS,CNTWKNBZON,CNTWKVAL,CNTWKVALFIC) From CONNECTFCT
    Call EVALPIVOT(PITCNTBPS,CNTWKNBZON,CNTWKTABZON,CNTWKTABABR,CNTWKZON,CNTWKFRM,CNTWKWRK,CNTWKVAL,CNTWKVALFIC) From CONNECTFCT
    Call WRPIVOT(CNTWKNBZON,CNTWKTABZON,CNTWKTABABR,CNTWKZON,CNTWKFRM,CNTWKWRK,CNTWKVAL,CNTWKVALFIC) From CONNECTFCT
    #     fermeture du fichier
    Openo Using [FPIV]
Endif
Return
######################################################################
$WR_CLSBPS
If PITCLSBPS<>""
    ECRCLS=1
    ################################
    # fichiers CLSBPS
    ################################
    #     Ouverture du fichier OPTCLSBPS en écriture
    If WPRECLSBPS = 0
      Openo OPTCLSBPS,0 Using [FPIV]
      WPRECLSBPS = 1
    Else
      Openi OPTCLSBPSTMP Using [FPIV]
      Rdseq WCLASSTMP Using [FPIV]
      While fstat=0
            If WCLASSTMP =WCLASS
                ECRCLS=0
                Break
            Endif
            Rdseq WCLASSTMP Using [FPIV]
      Wend
      Openi Using [FPIV]
      ##
      Openo OPTCLSBPS Using [FPIV]
    Endif
    If ECRCLS
        Openo OPTCLSBPSTMP Using [FTMP]
        Wrseq WCLASS Using [FTMP]
        Openo Using [FTMP]
        ##
        WNBCLSBPS += 1

        Call RAZVALPIVOT(PITCLSBPS,CLSWKNBZON,CLSWKVAL,CLSWKVALFIC) From CONNECTFCT
        Call SETVAL("BPSUPPLIER","WCOD",CLSWKNBZON,CLSWKTABZON,CLSWKVAL,CLSWKVALFIC,WCLASS) From CONNECTFCT

        Call EVALPIVOT(PITCLSBPS,CLSWKNBZON,CLSWKTABZON,CLSWKTABABR,CLSWKZON,CLSWKFRM,CLSWKWRK,CLSWKVAL,CLSWKVALFIC) From CONNECTFCT
        Call WRPIVOT(CLSWKNBZON,CLSWKTABZON,CLSWKTABABR,CLSWKZON,CLSWKFRM,CLSWKWRK,CLSWKVAL,CLSWKVALFIC) From CONNECTFCT
    Endif
    #     fermeture du fichier
    Openo Using [FPIV]
Endif
Return
######################################################################

