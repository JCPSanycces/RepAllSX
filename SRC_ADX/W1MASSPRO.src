#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque MASSPRO 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:19"
A_USER  = "DOC"
A_STAMP = "20181109230519"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask MASSPRO [MPS]
Gosub HORODAT
Local Inpbox "MASSPRO" From GFONCTION At A_STAMP With A_WINDPREV Mask [MPS] As [SIM_]
Grizo [MPS]5
Grizo [MPS]3
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [MPS]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=110 : Y1(0)=8 : Y2(0)=22
X1(1)=1 : X2(1)=110 : Y1(1)=1 : Y2(1)=7
Return

$ON_NBLIG
Onevent BEFORE_INPUT Call AS_NBLIG From W1MASSPRO
Return

Subprog AS_NBLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(14442,GBOUT1) From OBJDIV
Call TEXTE(5481,GBOUT2) From OBJDIV
Call TEXTE(8255,GBOUT3) From OBJDIV
Call TEXTE(18111,GBOUT4) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_NBLIG From W1MASSPRO
Onkey 130 Titled GBOUT2 Call B2_NBLIG From W1MASSPRO
Onkey 131 Titled GBOUT3 Call B3_NBLIG From W1MASSPRO
Onkey 132 Titled GBOUT4 Call B4_NBLIG From W1MASSPRO
Gosub _AFF
End

Subprog B1_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action GOBJETC1
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC1"
 Call OBJET_CHAR([M]REFNUM(nolign-1),"EML","") From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B2_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action GOBJETC2
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC2"
 Call OBJET_CHAR([M]CTRNUM(nolign-1),"CTR",[M]REFNUM(nolign-1)+"~"+[M]CTRDAT(nolign-1)) From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B3_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call B3_NBLIG From MASSPRO
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog B4_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action STD
 Call B4_NBLIG From MASSPRO
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_UPD
Onevent AFTER_CHANGE Gosub AMM_UPD From W1MASSPRO
Onevent INIT_AREA Call D_UPD(zc) From W1MASSPRO
Onevent BEFORE_INPUT Call AS_UPD(zc) From W1MASSPRO
Return

Subprog D_UPD(VALEUR)
Variable Integer VALEUR
If varinit([M]UPD,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_UPD(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_UPD
Call AM_UPD(zc)
If !mkstat & GOBJET
 zoncou = "UPD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_UPD(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_UPD(VALEUR) From MASSPRO
If mkstat : GERR = 1 : GZONE = "UPD" : GZNUM = 47882 : Endif
Gosub _AFF
End

$ON_REFNUM
Return

$ON_CPY
Return

$ON_ETRFCY
Onevent CONTROL Call C_ETRFCY(zc) From W1MASSPRO
Onevent AFTER_CHANGE Gosub AMM_ETRFCY From W1MASSPRO
Onevent BEFORE_INPUT Call AS_ETRFCY(zc) From W1MASSPRO
Return

Subprog AS_ETRFCY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(47557,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_ETRFCY(zc) From W1MASSPRO
Onkey   2 Titled GBOUTS Call S_ETRFCY(zc) From W1MASSPRO
Onkey 144 Titled GBOUTP Call P_ETRFCY(zc) From W1MASSPRO
Onkey 146 Titled GBOUTA Call SA_ETRFCY(zc) From W1MASSPRO
Gosub _AFF
End

Subprog C_ETRFCY(VALEUR)
Variable Char    VALEUR()
## Action ACONTFCY
Call CONTSITE(VALEUR) From SUBAGF
If mkstat : GERR = 1 : GZONE = "ETRFCY" : GZNUM = 1344 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("FCY","!",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "ETRFCY" : GZNUM = 1344 : Endif
Endif
Gosub _AFF
End

$AMM_ETRFCY
Call AM_ETRFCY(zc)
If !mkstat & GOBJET
 zoncou = "ETRFCY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_ETRFCY(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_ETRFCY(VALEUR) From MASSPRO
If mkstat : GERR = 1 : GZONE = "ETRFCY" : GZNUM = 1344 : Endif
Gosub _AFF
End

Subprog S_ETRFCY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "FCY"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_ETRFCY(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action STD
 Call B1_ETRFCY(VALEUR) From MASSPRO
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_ETRFCY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "FCY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_ETRFCY(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("FCY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

