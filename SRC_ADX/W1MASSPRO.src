Subprog AS_CTRGRD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(47557,GBOUT1) From OBJDIV
Call TEXTE(47557,GBOUT2) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action DEFHRCGD
Call DEFHRCGD(VALEUR,[M]LEG(nolign),GSOCIETE) From SUBHRCGD
If mkstat=2
 [M]CTRGRD(INDIC) = VALEUR
 Affzo CTRGRD(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_CTRGRD(zc) From W1MASSPRO
Onkey 130 Titled GBOUT2 Call B2_CTRGRD(zc) From W1MASSPRO
Onkey   2 Titled GBOUTS Call S_CTRGRD(zc) From W1MASSPRO
Onkey 144 Titled GBOUTP Call P_CTRGRD(zc) From W1MASSPRO
Onkey 146 Titled GBOUTA Call SA_CTRGRD(zc) From W1MASSPRO
Gosub _AFF
End

Subprog C_CTRGRD(VALEUR)
Variable Char    VALEUR()
## Action CONTHRCGD
Call CONTHRCGD(VALEUR,[M]LEG(nolign),GSOCIETE) From SUBHRCGD
If mkstat : GERR = 1 : GZONE = "CTRGRD" : GZNUM = 47295 : Endif
If !mkstat
 ## Action CONTOBJN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CTRGRD" : GZNUM = 47295 : Endif
Endif
Gosub _AFF
End

Subprog S_CTRGRD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELHRCGD
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELHRCGD"
 PARMSK(1) = [M]LEG(nolign)
 PARMSK(2) = GSOCIETE
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELHRCGD","SUBHRCGD","SPEHRCGD") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CTRGRD(VALEUR)
Variable Char    VALEUR()
Call OBJET("HRCGD",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog B2_CTRGRD(VALEUR)
