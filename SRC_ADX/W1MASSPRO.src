Subprog S_POT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELPOT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPOT"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AS_POT" : PROGSUB = "MASSPRO" : PROGSPE = "XYMASSPRO" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = [M]LEG(nolign)
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPOT","SUBPOT","") From GACTION
 ACTION = "BS_POT" : PROGSUB = "MASSPRO" : PROGSPE = "XYMASSPRO" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
Gosub _AFF
End

