#<AdxTL>@(#)7.0.0.0 $Revision$
###############################################################################
# TRTACHSCO1   Traitements liés aux achats de sous-traitance     Module Achat #
# --------------------------------------------------------------------------- #
# Pré-requis:                                                                 #
# [M] est un masque écran contenant les lignes de commandes d'achat           #
# - [M:POH2] si appel depuis SUBPOHB                                          #
# - [M:POI1] si appel depuis TRTACHPOH1 (CREATION_POH1) ou SUBPOIA            #
# NOL est l'indice de la ligne en cours de traitement de cette classe [M]     #
# --------------------------------------------------------------------------- #
# Etiquettes appelées par Gosub depuis les trts SUBPOHB, SUBPOI et TRTACHPOH1 #
#                                                                             #
# - CHARG_LIG_STT : Suite chargement ligne pour sous-traitance                #
#                                                                             #
#$NEW_LINE          déclenche      NEW_LINE du traitement WTRAIT              #
#$CHARG_LIG_MFG     est appelé par CHARG_LIG_SUPPLEMENT  de l'écran [M] si OF #
#$CHARG_LIG_SCO     est appelé par CHARG_LIG_SUPPLEMENT  de l'écran [M] si EO #
###############################################################################
# Calcul du montant total article lancé dans les différents cas:              #
# Subprog CALC_POQ_LINAMT(LAMT) somme des montants des lignes détail POQ      #
# Subprog CALC_PTD_LINAMT(LAMT) somme des montants des lignes détail PTD      #
# Subprog CALC_PND_LINAMT(LAMT) somme des montants des lignes détail PND      #
# Subprog CALC_PID_LINAMT(LAMT) somme des montants des lignes détail PID      #
###############################################################################

############################################################################
# 02/2007 dans SCOSRV CPNITMREF devient SRVITMREF                          #
############################################################################

$CHARG_LIG_STT
#-------------------------------------------------#
#   Suite chargement ligne pour sous-traitance    #
# ----------------------------------------------- #
# Après prise en compte d'un besoin SCx ou EOx    #
# Appelé depuis  :                                #
#   - SUBPOHB    Gestion des commandes classiques #
#   - SUBPOIA    Gestion du plan de l'acheteur    #
#   - TRTACHPOH1 Gestion des autres plans         #
# Nota : Le buffer [F:PWO] est chargé !           #
#        NOL est l'indice de la ligne en cours    #
#-------------------------------------------------#
Local Date    WORDDAT, WRCPDAT # Issue 88261 GA 03/2013 changt date réception en génération de commande
If     clalev([M:POH0])>0
   WORDDAT = [M:POH0]ORDDAT
   WRCPDAT = [M:POH2]EXTRCPDAT(NOL) # Issue 88261 GA 03/2013
   WBPRNUM = [M:POH0]BPSNUM
Elsif  clalev([M:SCO1])>0
   WORDDAT = [M:SCO1]ORDDAT
   WRCPDAT = [M:SCO3]OPEEND         # Issue 88261 GA 03/2013
   WBPRNUM = [M:SCO0]BPRNUM
Elsif clalev([M:POI1])
   WORDDAT = [M:POI1]ORDDAT
   WRCPDAT = [M:POI1]EXTRCPDAT(NOL) # Issue 88261 GA 03/2013
   WBPRNUM = [M:POI1]BPSNUM(NOL)
Endif
#----- Récupération des caractéristiques OF ou sous-traitance -----#
Raz [M:SBCK]
[M:SBCK] = [F:PWO]
[M:SBCK]MAJCOD="G" : Call MAJ_SBC From SBCLIB
[M]VCRTYPORI(NOL)=[M:SBCK]VCRTYPORI
[M]VCRNUMORI(NOL)=[M:SBCK]VCRNUMORI
[M]VCRLINORI(NOL)=[M:SBCK]VCRLINORI
[M]VCRSEQORI(NOL)=[M:SBCK]VCRSEQORI
[M]ITMREFORI(NOL)=[M:SBCK]ITMREFORI
#----- Prise en compte d'ordres suggérés SCS ou EOS, création SCP ou EOP -----#
If [F:PWO]WIPSTA=3
  # Issue 86434 GA 12/2012 The user must acknowledge (or not)
  GMESSAGE=mess(438,194,1)-"\"-mess([F:PWO]WIPTYP,306,1)
  OK=2 : Call AVERTIR(GMESSAGE,OK) From GESECRAN
  If OK=1  GOK=-1 : Return : Endif

  If [F:PWO]WIPTYP=13 | [M:SBCK]VCRTYPORI=36
    Gosub CREATION_SCO From TRTACHSCO1 : If GOK<=0 | mkstat  Return : Endif
  Else
    Gosub CREATION_MFG From TRTACHSCO1 : If GOK<=0 | mkstat  Return : Endif
  Endif
  [F:PWO]WIPSTA=2
Endif
#----- Achat de sous-traitance encours EOx -----#
If [F:PWO]WIPTYP=13
  Gosub OPEN_FILES_SCO From SCOLIB
  [M]LINTYP(NOL)=2  : # Produit fini (article sous-traité)
  If [F:SCI]SCONUM<>[M:SBCK]VCRNUMORI |
&    [F:SCI]SCILIN<>[M:SBCK]VCRLINORI
    Read [SCI] SCI0=[M:SBCK]VCRNUMORI;[M:SBCK]VCRLINORI
    If fstat  Raz [F:SCI] : GOK=0 : Return : Endif
  Endif
  #-----
  If [F:SCS]SCONUM<>[M:SBCK]VCRNUMORI |
&    [F:SCS]SCILIN<>[M:SBCK]VCRLINORI
&   Read [SCS] SCS0(2)=[M:SBCK]VCRNUMORI;[M:SBCK]VCRLINORI
    [G:SCS]currind=1 : [G:SCS]currlen=0 : # Réinitialisation clé par défaut
    If fstat  Raz [F:SCS] : GOK=0 : Return : Endif
  Endif
  #-----
  [M]SCOADD(NOL)   =[F:SCI]BPAADD
  [M]FCYADD(NOL)   =[F:SCI]PRHADD  # Issue 86974 GA 01/2013
  [M]OFS(NOL)      =[F:SCS]SCOLTI
  [M]LIKQTYCOE(NOL)=0
  #----- Chargement comptes et sections analytiques -----#
  If clalev([M:POH2])
    Call CHARG_ACCCCE(NOL,"[M:POH2]LINACC","","[M:POH2]CCE",
&                    "SCI",36,[F:SCI]SCONUM,[F:SCI]SCILIN,0,"") From TRTX3CPT
  Elsif clalev([M:POI1])
    Call CHARG_ACCCCE(NOL,"[M:POI1]LINACC","","[M:POI1]CCE",
&                    "SCI",36,[F:SCI]SCONUM,[F:SCI]SCILIN,0,"") From TRTX3CPT
  Endif
#----- Achat de sous-traitance encours SCx -----#
Elsif [F:PWO]WIPTYP=4
  #----- Ordre de fabrication -----#
  If [M:SBCK]VCRTYPORI=10
    Gosub OPEN_FILES_MFG From MFGLIB
  # FQ 54159 sur les SCF on n'a que VCRNUMORI de renseigné: pas Read direct sur MFO
    If [F:MFO]MFGNUM   <>[M:SBCK]VCRNUMORI
        For [MFO]MFO0 Where MFGNUM = [M:SBCK]VCRNUM & WIPNUM = [M:SBCK]WIPNUM
           Break
        Next
    Endif
    #-----
    [M]SCOADD(NOL)   =[F:MFO]BPAADD
    [M]OFS(NOL)      =[F:MFO]SCOLTI
    [M]LINTYP(NOL)=3  : # Service (détail de l'article sous-traité)
    #----- Chargement comptes et sections analytiques -----#
    If clalev([M:POH2])
      Call CHARG_ACCCCE(NOL,"[M:POH2]LINACC","","[M:POH2]CCE",
&                      "MFO",0,[F:MFO]MFGNUM,[F:MFO]OPENUM,[F:MFO]OPESPLNUM,"EXTWST") From TRTX3CPT
    Elsif clalev([M:POI1])
    # FQ 56128 avant [M:MFO]OPESPLNUM
      Call CHARG_ACCCCE(NOL,"[M:POI1]LINACC","","[M:POI1]CCE",
&                      "MFO",0,[F:MFO]MFGNUM,[F:MFO]OPENUM,[F:MFO]OPESPLNUM,"EXTWST") From TRTX3CPT
    Endif
    #-----
    # GA ?????????????????????????????????????????????????????????????????????????????
    #
    # Il reste :
    #   - à charger  [M]LIKQTYCOE(NOL)
    #   - il faudra réajuster la quantité du service si plusieurs articles lancés ?
    #
    # GA ?????????????????????????????????????????????????????????????????????????????
  #----- Ordre de sous-traitance -----#
  Elsif [M:SBCK]VCRTYPORI=36
    Gosub OPEN_FILES_SCO From SCOLIB
    [M]LINTYP(NOL)=3  : # Service (article sous-traitance)
    If [F:SCI]SCONUM<>[M:SBCK]VCRNUMORI |
&      [F:SCI]SCILIN<>[M:SBCK]VCRLINORI
      Read [SCI] SCI0=[M:SBCK]VCRNUMORI;[M:SBCK]VCRLINORI
      If fstat  Raz [F:SCI] : GOK=0 : Return : Endif
    Endif
    #-----
    If [F:SCS]SCONUM<>[M:SBCK]VCRNUMORI |
&      [F:SCS]SCILIN<>[M:SBCK]VCRLINORI |
&      [F:SCS]SCSLIN<>[M:SBCK]VCRSEQORI
      Read [SCS] SCS0=[M:SBCK]VCRNUMORI;[M:SBCK]VCRLINORI;[M:SBCK]VCRSEQORI
      If fstat  Raz [F:SCS] : GOK=0 : Return : Endif
    Endif
    #-----
    [M]SCOADD(NOL)   =[F:SCI]BPAADD
    [M]FCYADD(NOL)   =[F:SCI]PRHADD  # Issue 86974 GA 01/2013
    [M]OFS(NOL)      =[F:SCS]SCOLTI
    # Issue 93144 GA 10/2013 détail du tarif + loin (après maj de la qté)
    #If dim([M]PRIREN(NOL))>0 [M]PRIREN(NOL)=[F:SCS]PRIREN Endif # GA 01/2009
    #If dim([M]NETPRI(NOL))>0 [M]NETPRI(NOL)=[F:SCS]NETPRI Endif # GA 01/2009
    #If dim([M]GROPRI(NOL))>0 [M]GROPRI(NOL)=[F:SCS]GROPRI Endif # GA 01/2009
    #If dim([M]LINAMT(NOL))>0 [M]LINAMT(NOL)=[F:SCS]LINAMT Endif # GA 01/2009
    If [F:SCS]STRQTYCOD=2
      [M]LIKQTYCOE(NOL)=0
    Else
      [M]LIKQTYCOE(NOL)=arr([F:SCS]EXTQTY/[F:SCI]EXTQTY,10^-6)
    Endif
    #----- Chargement comptes et sections analytiques -----#
    If clalev([M:POH2])
      Call CHARG_ACCCCE(NOL,"[M:POH2]LINACC","","[M:POH2]CCE",
&                      "SCS",36,[F:SCS]SCONUM,[F:SCS]SCILIN,[F:SCS]SCSLIN,"") From TRTX3CPT
    Elsif clalev([M:POI1])
      Call CHARG_ACCCCE(NOL,"[M:POI1]LINACC","","[M:POI1]CCE",
&                      "SCS",36,[F:SCS]SCONUM,[F:SCS]SCILIN,[F:SCS]SCSLIN,"") From TRTX3CPT
    Endif
    #-----
  Endif
  #-----
Endif

# FQ 72083 GA 03/2011 Ctrl présence du Client livré extrait de SUBPOH/AM_ITMREF, si achat de sous-traitance
Gosub CTL_BPC

Return


$CHARG_LIG_SUPPLEMENT
#-------------------------------------------------------------------------------------#
# Chargement lignes service ou produit fini et matières fournies par le sous-traitant #
#-------------------------------------------------------------------------------------#
If !find([F:PWO]WIPTYP,4,13) | [F:PWO]WIPSTA <> 1 : Return : Endif

If [M]VCRTYPORI(NOL)=10
  Gosub CHARG_LIG_MFG
Elsif [M]VCRTYPORI(NOL)=36
  Gosub CHARG_LIG_SCO
Endif
Return


$NEW_LINE
#----------------#
# Nouvelle ligne #
#----------------#
Gosub NEW_LINE From =WTRAIT
NBRGR+=1
Return


$CHARG_LIG_MFG
#---------------------------------------------------------------------------------------#
# Articles lancés et matières fournies par le sous-traitant avec l'ordre de fabrication #
#---------------------------------------------------------------------------------------#
Local Char    WLAN (GLONLAN)
Local Char    WBPRNUM (GLONBPR)
Local Char    WPOHFCY (GLONFCY)
Local Char    WTRAIT  (GLONREF)
Local Integer WRET  : WRET=0
Local Integer WMFI  : WMFI=0
Local Integer SAVNOL: SAVNOL=NOL
Local Decimal COEFF_MFI
Local Decimal COEFF_MFO
Local Decimal WPICQTYSTU : WPICQTYSTU = [M]QTYSTU(NOL)
Local Decimal WPICQTYPUU : WPICQTYPUU = [M]QTYPUU(NOL)
Local Decimal WQTYSTU, WQTYPUU
Local Decimal WTOTQTYSTU, WTOTQTYPUU
Local Integer WNEXOPENUM
Local Integer WOPE_PROD
Local Date    WORDDAT
#-----
# GA 03/2008 à faire toujours
Gosub OPEN_FILES_MFG From MFGLIB
#-----
If     clalev([M:POH0])>0
   WLAN    = [M:POH0]LAN
   WBPRNUM = [M:POH0]BPSNUM
   WPOHFCY = [M:POH0]POHFCY
   WORDDAT = [M:POH0]ORDDAT
 # Source dans lequel se trouvent $NEW_LINE et $FIN_CHARG_LIG_CDE
   WTRAIT  = "SUBPOHB"

# Issue 86801 GA 12/2012 have to use information stored in [M:POI1]
#Elsif  clalev([M:MFG0])>0
# ###  WLAN    = [F:BPR]LAN
# ###  WBPRNUM = [F:MFO]BPRNUM
# ###  WPOHFCY = [F:MFO]MFGFCY
#   WORDDAT = [M:POI1]ORDDAT
# # Source dans lequel se trouvent $NEW_LINE et $FIN_CHARG_LIG_CDE
#   WTRAIT  = "SUBPOIA"

Elsif clalev([M:POI1])
   WLAN    = [F:BPR]LAN
   WBPRNUM = [M:POI1]BPSNUM(NOL)
   WPOHFCY = [M:POI1]POHFCY
   WORDDAT = [M:POI1]ORDDAT
   WTRAIT  = "SUBPOIA"
Endif

#----- Lecture entête ordre de fabrication si nécessaire -----#
If [F:MFG]MFGNUM<>[M]VCRNUMORI(NOL)
   Read [MFG] MFG0=[M]VCRNUMORI(NOL)
   If fstat  Raz [F:MFG] : Endif
Endif
# [M]VCRLINORI(NOL) contient OPENUM, [M]VCRSEQORI(NOL) contient OPESPLNUM
Read [MFO] MFO0=[M]VCRNUMORI(NOL);[M]VCRLINORI(NOL);[M]VCRSEQORI(NOL)
If fstat  Raz [F:MFO] : Endif
# Issue 91309 GA 09/2013
If [F:MFI]MFGNUM<>[M]VCRNUMORI(NOL)
   For [MFI] MFI0 Where MFGNUM=[M]VCRNUMORI(NOL)
       Break
   Next
Endif

If WBPRNUM=""
   WBPRNUM = [F:MFO]BPRNUM
Endif
Gosub READ_BPR From BPRLIB
WLAN    = [F:BPR]LAN
If WLAN="" WLAN=GLANGUE Endif # Issue 82494 GA 06/2012
WPOHFCY = [F:MFO]MFGFCY

# Issue 86425 GA 12/2012 Supplier code is mandatory
If WBPRNUM=""
   Call ERREUR(mess(11,194,1)-[F:PWO]ITMREF) From GESECRAN
   GOK=0 : Return
Endif

# ------------------------------------------------------------ #
# L'encours porte toujours sur le Service dans le cas des OF   #
# ------------------------------------------------------------ #
# Génération de la commande à partir de l'encours SCF          #
# courant qui a déjà été chargé dans [F:PWO]                   #
# ------------------------------------------------------------ #
# cette OP est-elle productive ?
WOPE_PROD  = 0
For [SCH]SCH0 Where MFGNUM=[F:MFO]MFGNUM and OPENUM=[F:MFO]OPENUM
    If fstat : GOK=0 : Break : Endif
    WNEXOPENUM = [F:SCH]NEXOPENUM
    If [F:SCH]MFGMST = 2 : WOPE_PROD =2 : Endif
Next
If GOK = 0 : Return : Endif

 # Issue 84830 GA 10/2012 il faut utiliser CHARG_LIG_MFO
 # Issue 82310 GA 06/2012 extrait de CHARG_LIG_MFO
 #----- Type d'achat "Service" -----#
 #[M]LINPURTYP(NOL)=3
 #Call D_LINPURTYP ([M]LINPURTYP(NOL)) : # Chargement type d'achat
 Gosub CHARG_LIG_MFO

 # Issue 93533 GA 12/2013 déjà fait sur la ligne courante
 #GVACFLG=1 # Issue 93038 GA 09/2013 Tax informations have to be read
 #Gosub FIN_CHARG_LIG_CDE From =WTRAIT
 #If mkstat | GOK=0  Return : Endif

 # si l'opération n'est pas productive, la cde porte uniquement sur le service
 # on passe le type de ligne à 1=normal
 If WOPE_PROD<>2 : [M]LINTYP(NOL)=1 : Return : Endif

# FQ 60079 GA 11/2009 Continuer à commander uniquement l'op de sous-traitance
##################### TEMPORAIRE ##############################
If WOPE_PROD=2 : [M]LINTYP(NOL)=1 : Return : Endif
##################### TEMPORAIRE ##############################

Raz WTOTQTYSTU,WTOTQTYPUU : # Totaliser les qtés réparties sur les opérations
#----- Article(s) lancé(s) -----#
For [MFI] MFI0 Where MFGNUM=[F:MFG]MFGNUM
  WMFI +=1

  If [F:MFG]EXTQTY = [F:MFI]EXTQTY | [F:MFG]EXTQTY = 0
  # OF mono-article la qté totale = qté article lancé
    COEFF_MFI = 1
  Else
    COEFF_MFI = [F:MFI]EXTQTY / [F:MFG]EXTQTY
  Endif
  If WPICQTYSTU = [F:MFO]EXTQTY | [F:MFO]EXTQTY = 0
  # lancement global qté totale = qté opération (STU article lancé)
    COEFF_MFO = 1
  Else
    COEFF_MFO = WPICQTYSTU / [F:MFO]EXTQTY
  Endif
  WQTYSTU = WPICQTYSTU * COEFF_MFI * COEFF_MFO
  WQTYPUU = WPICQTYPUU * COEFF_MFI * COEFF_MFO

  # complèter la ligne courante
  #[M]SCOADD(NOL)   =[F:MFO]BPAADD
  #----- Ligne de commande relative à l'article lancé -----#
  Gosub NEW_LINE From TRTACHSCO1 : If mkstat  Break : Endif
  Gosub CHARG_LIG_MFI
  GVACFLG=0 # Issue 93038 GA 09/2013 Tax informations don't have to be read
  Gosub FIN_CHARG_LIG_CDE From =WTRAIT

  #----- Ligne de commande relative au Service(s) -----#
  # uniquement si OF multi-articles, sinon cette ligne est déjà dans [M]
  If WMFI > 1
    Gosub NEW_LINE From TRTACHSCO1 : If mkstat  Break : Endif
    Gosub CHARG_LIG_MFO
    #----- Chargement et écriture fichier de travail -----#
    [F:PWO]QTYSTU=[M]RETQTYSTU(NOL)
    Call PCAL_QTY([F:PWO]QTYSTU,[F:PWO]STU,[F:PWO]QTYPUU,[F:PWO]PUU,
&                 [F:PWO]ITMREF,WBPRNUM,1,GBIDD1) From TRTACHQTE1
    # autant de lignes dans [F:PWO] que de lignes [F:POQ] sur le service (appel de MAJ_SBC)
    # sinon pb de report de la mise à jour sur l'opération MFO (MAJ_SBC appelé depuis PWO)
    If dim([M]POILIN)> 0 & WTRAIT="SUBPOIA" : [F:PWO]LINNUM=[M]POILIN(NOL) : Endif
    If dim([M]POHLIN)> 0 & WTRAIT="SUBPOHB" : [F:PWO]LINNUM=[M]POHLIN(NOL) : Endif
    Write [PWO]
    If fstat  GOK=0 : Break : Endif
    #-----
    GVACFLG=1 # Issue 93038 GA 09/2013 Tax informations have to be read
    Gosub FIN_CHARG_LIG_CDE From =WTRAIT
    WTOTQTYSTU += [M]QTYSTU(NOL)
    WTOTQTYPUU += [M]QTYPUU(NOL)
  Endif
  If mkstat | GOK=0  Break : Endif

  #----- Génération lignes matières fournies -----#
  For [MFM] MFM0 Where MFGNUM=[F:MFI]MFGNUM & MFGLIN=[F:MFI]MFGLIN & SCOFLG=3 & CPNTYP=1
    Gosub NEW_LINE From TRTACHSCO1 : If mkstat  Break : Endif
    GVACFLG=1 # Issue 93038 GA 09/2013 Tax informations have to be read
    Gosub CHARG_LIG_MFM
    Gosub FIN_CHARG_LIG_CDE From =WTRAIT
  Next
Next
If GOK<1 : Return : Endif
# ------------------------------------------------ #
# si OF multi-articles,                            #
# on réajuste les qtés de la ligne initiale        #
# ------------------------------------------------ #
If WMFI > 1
  [M]QTYSTU(SAVNOL) = WPICQTYSTU - WTOTQTYSTU
  [M]QTYPUU(SAVNOL) = WPICQTYPUU - WTOTQTYPUU
  [M]RETQTYSTU(SAVNOL) = [M]QTYSTU(SAVNOL)
  [M]QTYUOM(SAVNOL) = [M]QTYPUU(SAVNOL)*(1/[M]UOMPUUCOE(SAVNOL))
  Call QTEARR([M]QTYUOM(SAVNOL),[M]UOM(SAVNOL)) From TRTDIV
#
# à vérifier MBT: recalcul du tarif sur cette ligne ?
#  NOL = SAVNOL
#  Gosub FIN_CHARG_LIG_CDE From =WTRAIT
Endif
Return


$CHARG_LIG_SCO
#---------------------------------------------------------------------------------------#
# Articles lancés et matières fournies par le sous-traitant avec l'ordre de ss-traitance#
#---------------------------------------------------------------------------------------#
Local Char    WLAN (GLONLAN)
Local Char    WBPRNUM (GLONBPR)
Local Char    WPOHFCY (GLONFCY)
Local Char    WTRAIT  (GLONREF)
Local Integer WRET  : WRET=0
Local Integer SAVNOL: SAVNOL=NOL
Local Decimal COEFF_SCI
Local Decimal COEFF_SCS
Local Decimal WPICQTYSTU : WPICQTYSTU = [M]QTYSTU(NOL)
Local Decimal WPICQTYPUU : WPICQTYPUU = [M]QTYPUU(NOL)
Local Decimal WQTYSTU, WQTYPUU
Local Decimal WTOTQTYSTU, WTOTQTYPUU
Local Date    WORDDAT
# GA 03/2008 à faire toujours
Gosub OPEN_FILES_SCO From SCOLIB
If     clalev([M:POH0])>0
   WLAN    = [M:POH0]LAN
   WBPRNUM = [M:POH0]BPSNUM
   WPOHFCY = [M:POH0]POHFCY
   WORDDAT = [M:POH0]ORDDAT
 # Source dans lequel se trouvent $NEW_LINE et $FIN_CHARG_LIG_CDE
   WTRAIT  = "SUBPOHB"
Elsif  clalev([M:SCO0])>0
   WLAN    = [M:SCO1]LAN
   WBPRNUM = [M:SCO0]BPRNUM
   WPOHFCY = [M:SCO0]POHFCY
   WORDDAT = [M:SCO1]ORDDAT
 # Source dans lequel se trouvent $NEW_LINE et $FIN_CHARG_LIG_CDE
   WTRAIT  = "SUBPOIA"
Elsif clalev([M:POI1])
   WLAN    = [F:BPR]LAN
   WBPRNUM = [M:POI1]BPSNUM(NOL)
   WPOHFCY = [M:POI1]POHFCY
   WORDDAT = [M:POI1]ORDDAT
   WTRAIT  = "SUBPOIA"
Endif

# Issue 86425 GA 12/2012 Supplier code is mandatory
If WBPRNUM=""
   Call ERREUR(mess(11,194,1)-[F:PWO]ITMREF) From GESECRAN
   GOK=-1 : mkstat=1 : Return
Endif

If WLAN="" WLAN=GLANGUE Endif # Issue 82494 GA 06/2012

# ------------------------------------
# COEFF_SCI: ratio c/qté article lancé
# ------------------------------------
If [F:PWO]WIPTYP=4 | WPICQTYSTU = [F:SCI]EXTQTY | [F:SCI]EXTQTY = 0
# lancement global qté totale = qté STU article lancé
  COEFF_SCI = 1
Else
# si on a pické un encours EOx partiellement
  COEFF_SCI = WPICQTYSTU / [F:SCI]EXTQTY
Endif

# ------------------------------------
# COEFF_SCS: ratio c/qté de service
# ------------------------------------
If [F:PWO]WIPTYP=13 | WPICQTYSTU = [F:SCS]EXTQTY | [F:SCS]EXTQTY = 0 | [F:SCS]STRQTYCOD=2
# lancement global qté totale = qté STU article lancé
  COEFF_SCS = 1
Else
# si on a pické un encours SCx partiellement
  COEFF_SCS = WPICQTYSTU / [F:SCS]EXTQTY
Endif
WQTYSTU = WPICQTYSTU * COEFF_SCI
WQTYPUU = WPICQTYPUU * COEFF_SCI

# Cas particulier:                         #
# - en saisie directe POH2                 #
#   un ordre EOS a été pické               #
# => on crée l'ordre de sous-traitance     #
# ---------------------------------------- #
If [F:PWO]WIPTYP = 13 & [F:PWO]WIPSTA = 3
    Gosub CREATION_SCO
    If WRET=1 : Return : Endif
    [F:PWO]WIPSTA = 1
Endif

# Cas particulier:                         #
# - en saisie directe POH2                 #
#   un ordre EOP ou SCP a été pické        #
# => on màj l'ordre de sous-traitance      #
# pris en compte par MAJ_SBC ssi validation#
# ---------------------------------------- #

#----------------------------------------------------------------------------------#
# Service et matières fournies par le sous-traitant avec l'ordre de sous-traitance #
#----------------------------------------------------------------------------------#
#----- Lecture entête ordre de sous-traitance si nécessaire -----#
If [F:SCO]SCONUM<>[M]VCRNUMORI(NOL)
   Read [SCO] SCO0=[M]VCRNUMORI(NOL)
   If fstat  Raz [F:SCO] : Endif
Endif
#----- Lecture article lancé si nécessaire -----#
If  [F:SCI]SCONUM<>[M]VCRNUMORI(NOL) | [F:SCI]SCILIN<>[M]VCRLINORI(NOL)
   Read [SCI] SCI0=[M]VCRNUMORI(NOL);[M]VCRLINORI(NOL)
   If fstat  Raz [F:SCI] : Endif
Endif

#----- Génération lignes produit fini ou service -----#
If [M]LINTYP(NOL)=2

  # Raz Issue 83761 GA 08/2012 remplacement de la boucle For
  #----- Lecture du service courant si nécessaire -----#
  If [F:SCS]SCONUM<>[M]VCRNUMORI(NOL) | [F:SCS]SCILIN<>[M]VCRLINORI(NOL)
    Raz [F:SCS]
    For [SCS] Where SCONUM=[M]VCRNUMORI(NOL) & SCILIN=[M]VCRLINORI(NOL)
       Break
    Next
  Endif
  # complèter la ligne courante
  #[M]SCOADD(NOL)=[F:SCI]BPAADD
  Gosub CHARG_LIG_SCI   # Issue 83761 GA 08/2012 added
  # Issue 112057 - 2016-02-17 by MUARN : Gestion erreur
  If GOK<1 : Return : Endif

    Gosub NEW_LINE : If mkstat | GOK=0 : Return : Endif
    Gosub CHARG_LIG_SCS
    #GA 06/2006 à faire même si [F:SCS]WIPTYP=2 (POF)
    #----- Chargement et écriture fichier de travail -----#
    If [F:SCS]WIPTYP=4      : # cas d'un SCP le statut WIPSTA passe à 1=Ferme + tard
      [F:PWO]WIPTYP=[F:SCS]WIPTYP
      [F:PWO]WIPSTA=[F:SCS]WIPSTA
      [F:PWO]WIPNUM=[F:SCS]WIPNUM
    Else
      [F:PWO]WIPTYP=0
      [F:PWO]WIPSTA=0
      [F:PWO]WIPNUM=""
    Endif
    [F:PWO]ITMREF=[F:SCS]SRVITMREF
    [F:PWO]PUU   =[M]UOM(NOL)         # FQ 69609 GA 12/2010 avant [F:SCS]SCOPUU
    [F:PWO]STU   =[M]STU(NOL)         # FQ 69609 GA 12/2010 avant [F:SCS]OPESTU
    [F:PWO]PSDLIN=0
    [F:PWO]QTYPUU=[M]QTYUOM(NOL)      # FQ 69609 GA 12/2010 avant [F:SCS]EXTSTRQTY
    [F:PWO]QTYSTU=[M]RETQTYSTU(NOL)   # FQ 69609 GA 12/2010 avant [F:SCS]EXTQTY
    # autant de lignes dans [F:PWO] que de lignes [F:POQ] sur le service (appel de MAJ_SBC)
    # sinon pb de report de la mise à jour sur l'opération MFO (MAJ_SBC appelé depuis PWO)
    If dim([M]POILIN)> 0 & WTRAIT="SUBPOIA" : [F:PWO]LINNUM=[M]POILIN(NOL) : Endif
    If dim([M]POHLIN)> 0 & WTRAIT="SUBPOHB" : [F:PWO]LINNUM=[M]POHLIN(NOL) : Endif
    Write [PWO]
    If fstat  GOK=0 : Return : Endif
    #-----
    GVACFLG=0 # Issue 93038 GA 09/2013 Tax informations don't have to be read
    Gosub FIN_CHARG_LIG_CDE From =WTRAIT
  If mkstat | GOK=0  Return : Endif

Elsif [M]LINTYP(NOL)=3
  #----- Lecture du service courant si nécessaire -----#
  If [F:SCS]SCONUM<>[M]VCRNUMORI(NOL)
&  | [F:SCS]SCILIN<>[M]VCRLINORI(NOL)
&  | [F:SCS]SCSLIN<>[M]VCRSEQORI(NOL)
    Read [SCS] SCS0=[M]VCRNUMORI(NOL);[M]VCRLINORI(NOL);[M]VCRSEQORI(NOL)
    If fstat  Raz [F:SCS] : Endif
  Endif

  #----- Lecture article lancé si nécessaire -----#
  If  [F:SCI]SCONUM<>[M]VCRNUMORI(NOL) | [F:SCI]SCILIN<>[M]VCRLINORI(NOL)
     Read [SCI] SCI0=[M]VCRNUMORI(NOL);[M]VCRLINORI(NOL)
     If fstat  Raz [F:SCI] : Endif
  Endif

  # complèter la ligne courante
  #[M]SCOADD(NOL)=[F:SCI]BPAADD
  Gosub CHARG_LIG_SCS   # Issue 83761 GA 08/2012 added
  # Issue 117494 - 2016-07-12 by SR : Rechargement des valeurs par défaut perdues après CHARG_LIG_SCS
  Gosub INIT_ACCCCE

  #----- Produit fini (article sous-traité) -----#
  Gosub NEW_LINE : If mkstat | GOK=0 : Return : Endif
  Gosub CHARG_LIG_SCI
  #GA 06/2006 à faire même si [F:SCI]WIPTYP=2 (POF)
  #----- Chargement et écriture fichier de travail -----#
  If [F:SCI]WIPTYP=13      : # cas d'un EOP le statut WIPSTA passe à 1=Ferme + tard
    [F:PWO]WIPTYP=[F:SCI]WIPTYP
    [F:PWO]WIPSTA=[F:SCI]WIPSTA
    [F:PWO]WIPNUM=[F:SCI]WIPNUM
  Else
    [F:PWO]WIPTYP=0
    [F:PWO]WIPSTA=0
    [F:PWO]WIPNUM=""
  Endif
  [F:PWO]ITMREF=[F:SCI]ITMREF
  [F:PWO]PUU   =[F:SCI]PUU
  [F:PWO]STU   =[F:SCI]STU
  [F:PWO]PSDLIN=0
  [F:PWO]QTYSTU=[M]RETQTYSTU(NOL)
  Call PCAL_QTY([F:PWO]QTYSTU,[F:PWO]STU,[F:PWO]QTYPUU,[F:PWO]PUU,
&               [F:PWO]ITMREF,WBPRNUM,1,GBIDD1) From TRTACHQTE1
  If dim([M]POILIN)> 0 & WTRAIT="SUBPOIA" : [F:PWO]LINNUM=[M]POILIN(NOL) : Endif
  If dim([M]POHLIN)> 0 & WTRAIT="SUBPOHB" : [F:PWO]LINNUM=[M]POHLIN(NOL) : Endif
  Write [PWO]
  If fstat  GOK=0 : Return : Endif
  #-----
  GVACFLG=0 # Issue 93038 GA 09/2013 Tax informations have to be read
  Gosub FIN_CHARG_LIG_CDE From =WTRAIT
  If mkstat | GOK=0  Return : Endif
Endif
#----- Génération lignes matières fournies -----#
For [SCM] SCM0 Where SCONUM=[F:SCI]SCONUM & SCILIN=[F:SCI]SCILIN & SCOFLG=3 & CPNTYP=1
  Gosub NEW_LINE : If mkstat | GOK=0 : Break : Endif
  Gosub CHARG_LIG_SCM
  #----- Chargement et écriture fichier de travail -----#
  [F:PWO]WIPTYP=[F:SCM]WIPTYP        : # non renseigné sur ces composants car pas d'encours
  [F:PWO]WIPSTA=[F:SCM]WIPSTA        : # non renseigné sur ces composants car pas d'encours
  [F:PWO]WIPNUM=[F:SCM]WIPNUM        : # non renseigné sur ces composants car pas d'encours
  [F:PWO]ITMREF=[F:SCM]CPNITMREF
  [F:PWO]PUU   =[F:SCM]BOMUOM
  [F:PWO]STU   =[F:SCM]STU
  [F:PWO]PSDLIN=0
  [F:PWO]QTYSTU=[M]RETQTYSTU(NOL)
  Call PCAL_QTY([F:PWO]QTYSTU,[F:PWO]STU,[F:PWO]QTYPUU,[F:PWO]PUU,
&               [F:PWO]ITMREF,WBPRNUM,1,GBIDD1) From TRTACHQTE1
  If dim([M]POILIN)> 0 & WTRAIT="SUBPOIA" : [F:PWO]LINNUM=[M]POILIN(NOL) : Endif
  If dim([M]POHLIN)> 0 & WTRAIT="SUBPOHB" : [F:PWO]LINNUM=[M]POHLIN(NOL) : Endif
  Write [PWO]
  If fstat  GOK=0 : Break : Endif
  #-----
  GVACFLG=1 # Issue 93038 GA 09/2013 Tax informations have to be read
  Gosub FIN_CHARG_LIG_CDE From =WTRAIT
Next
Return


$CREATION_MFG
#--------------------------------#
# Nouvel ordre de fabrication ?? #
#--------------------------------#
Return

$CREATION_SCO
#--------------------------------#
# Nouvel ordre de sous-traitance #
#--------------------------------#
Gosub OPEN_FILES_SCO From SCOLIB
If clalev ([F:ORD1])<= 0 : Local File ORDERS     [ORD1]: Endif
Read [ORD1]ORD0=[F:PWO]WIPTYP;[F:PWO]WIPNUM;[F:PWO]ITMREF
If fstat : Raz [F:ORD1] : Endif
Raz [M:SCOK]
[M:SCOK]CODMAJ    = "P"               : # Création d'EO avec prise en compte de besoin
#[M:SCOK]CODTRS    = 2                : # inutilise
[M:SCOK]SCONUM    = [M]VCRNUMORI(NOL)
[M:SCOK]SCILIN    = [M]VCRLINORI(NOL)
[M:SCOK]WIPTYP    = [F:PWO]WIPTYP     : # Type Encours 13=EOS ou 4=SCS
[M:SCOK]WIPNUM    = [F:PWO]WIPNUM     : # N° Encours EOP ou SCP
[M:SCOK]BPRNUM    = [F:ORD1]BPRNUM
[M:SCOK]STOFCY    = [F:ORD1]STOFCY
[M:SCOK]SCOSTA    = 1                 : # Statut de l'EO=Ferme
[M:SCOK]ITMREF    = [F:PWO]ITMREF     : # Sous-traité ou Service selon WIPTYP
[M:SCOK]ITMREFORI = [M]ITMREFORI(NOL) : # Issue 80507 pour FUNMPICKA avant [F:ORD1]ITMREFORI
[M:SCOK]BOMALT    = [F:ORD1]BOMALT    : # à reprendre dans l'encours EOS ou SCS
[M:SCOK]PJT       = [F:ORD1]PJT
[M:SCOK]PRVQTY    = 0
[M:SCOK]EXTQTY    = [F:PWO]QTYSTU
[M:SCOK]STRDAT    = WORDDAT           : #  avant [F:ORD1]STRDAT
[M:SCOK]ENDDAT    = [F:ORD1]ENDDAT
[M:SCOK]FMI       = 1
[M:SCOK]PIO       = 1
#[M:SCOK]VCRTYPORI = 0                : # Renseigner ici la ref cde si on la connait ???
#[M:SCOK]VCRNUMORI = ""
#[M:SCOK]VCRLINORI = 0
#[M:SCOK]VCRSEQORI = 0
Call MAJ_SCO From SCOAUTLIB
If [M:SCOK]CODRET = 0
    If [M]VCRNUMORI(NOL)<>[M:SCOK]SCONUM
       [M]VCRTYPORI(NOL)= 36            # Issue 83183 GA 06/2012 PEC d'un EOS
       [M]VCRNUMORI(NOL)= [M:SCOK]SCONUM
       [M]VCRLINORI(NOL)= [M:SCOK]SCILIN
       [M]VCRSEQORI(NOL)= 0
    Endif
    If [M:SBCK]VCRNUMORI<>[M:SCOK]SCONUM
       [M:SBCK]VCRTYPORI= 36
       [M:SBCK]VCRNUMORI= [M:SCOK]SCONUM
       [M:SBCK]VCRLINORI= [M:SCOK]SCILIN
       [M:SBCK]VCRSEQORI= 0
    Endif
    WRET = 0
Else
    WRET = 1 : GOK=0 : Return : # cas d'Erreur à traiter ...
Endif
Return


$MODIFICATION_SCO
#-----------------------------#
# Maj ordre de sous-traitance #
#-----------------------------#
Gosub OPEN_FILES_SCO From SCOLIB
If clalev ([F:ORD1])<= 0 : Local File ORDERS     [ORD1]: Endif
Read [ORD1]ORD0=[F:PWO]WIPTYP;[F:PWO]WIPNUM;[F:PWO]ITMREF
If fstat : Raz [F:ORD1] : Endif
Raz [M:SCOK]
[M:SCOK]CODMAJ    = "M"               : # Modification d'EO
#[M:SCOK]CODTRS    = 2                : # inutilise
[M:SCOK]SCONUM    = [M]VCRNUMORI(NOL)
[M:SCOK]SCILIN    = [M]VCRLINORI(NOL)
[M:SCOK]WIPTYP    = [F:PWO]WIPTYP     : # Type Encours 13=EOP ou 4=SCP
[M:SCOK]WIPNUM    = [F:PWO]WIPNUM     : # N° Encours EOP ou SCP
[M:SCOK]BPRNUM    = [F:ORD1]BPRNUM
[M:SCOK]STOFCY    = [F:ORD1]STOFCY
[M:SCOK]SCOSTA    = 1                 : # Statut de l'EO=Ferme
[M:SCOK]ITMREF    = [F:PWO]ITMREF     : # Sous-traité ou Service selon WIPTYP
[M:SCOK]ITMREFORI = [M]ITMREFORI(NOL) : # Issue 80507 pour FUNMPICKA avant [F:ORD1]ITMREFORI
[M:SCOK]BOMALT    = [F:ORD1]BOMALT    : # à reprendre dans l'encours EOP ou SCP
[M:SCOK]PJT       = [F:ORD1]PJT
[M:SCOK]PRVQTY    = 0
[M:SCOK]EXTQTY    = [F:PWO]QTYSTU       # FQ 65646
[M:SCOK]STRDAT    = WORDDAT           : # avant [F:ORD1]STRDAT
[M:SCOK]ENDDAT    = [F:ORD1]ENDDAT
[M:SCOK]FMI       = 1
[M:SCOK]PIO       = 1
Call MAJ_SCO From SCOAUTLIB
If [M:SCOK]CODRET = 0
    WRET = 0
Else
    WRET = 1 : GOK=0 : Return : # cas d'Erreur à traiter ...
Endif
Return


# ----- Chargement de la classe [M] depuis une ligne [F:SCI] SCOITM ----- #
$CHARG_LIG_SCI
  [M]ITMREF(NOL)   =[F:SCI]ITMREF
  [M]ITMREFORI(NOL)=[F:SCI]ITMREF   : # nécessaire pour le tri des lignes
  # Issue 112754 - 2016-09-27 by SR : Services
  [M]ITMKND(NOL)   = 1
  #----- Chargement des désignations article -----#
  If [F:ITM]ITMREF<>[M]ITMREF(NOL)
    Read [ITM] ITM0=[M]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
  Endif
  #Call CHARGE_ITMDES("DES1AXX",WLAN,[F:ITM]ITMREF,[M]ITMDES(NOL)) From TRTX3
  #If [M]ITMDES(NOL)=""  [M]ITMDES(NOL)=[F:ITM]ITMDES1 : Endif
  Call CHARGE_DEFITMDES("DES1AXX",WLAN,[F:ITM]ITMREF,[M]ITMDES(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
  # Issue 119168 - 2016-10-21 by SR
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M]ITMDES1(NOL), "[F:ITM]") From TRTX3
  If [M]ITMDES1(NOL)="" [M]ITMDES1(NOL)=[M]ITMDES(NOL) Endif
  #-----
  [M]SCOADD(NOL)   =[F:SCI]BPAADD
  [M]OFS(NOL)      =[F:SCS]SCOLTI
  [M]UOM(NOL)      =[F:SCI]PUU
  [M]PUU(NOL)      =[F:SCI]PUU
  [M]STU(NOL)      =[F:SCI]STU
  [M]PRHFCY(NOL)   =[F:SCI]PRHFCY
  [M]FCYADD(NOL)   =[F:SCI]PRHADD   : # GA 04/11/2008 adresse du site de réception
  Gosub CTL_BUY_EO                    # Issue 87637 GA 02/2013 Code acheteur si GFLTBUY=2
  # Issue 112057 - 2016-02-17 by MUARN : Gestion erreur
  If GOK<1 : Return : Endif
  Gosub CTL_RCPDAT_EO                 # Issue 88261 GA 03/2013
  # Issue 85528 GA 2012 Ko : cela empêche de changer le site de commande plus tard
  # Issue 84787 GA 10/2012 pour Regroupement
  #If dim([M:POI1]POHFCY)>0 [M:POI1]POHFCY=[F:SCO]POHFCY : Endif
  If dim([M:POI1]POHFCY)>0 & [M:POI1]POHFCY=""  [M:POI1]POHFCY=[F:SCO]POHFCY : Endif
  [M]UOMPUUCOE(NOL)=1
  [M]LINTYP(NOL)   =2 : # Composé
  [M]VCRTYPORI(NOL)=36
  [M]VCRNUMORI(NOL)=[F:SCI]SCONUM
  [M]VCRLINORI(NOL)=[F:SCI]SCILIN
  [M]VCRSEQORI(NOL)=0
  #----- Chargement comptes et sections analytiques -----#
  If clalev([M:POH2])
    Call CHARG_ACCCCE(NOL,"[M:POH2]LINACC","","[M:POH2]CCE",
&                    "SCI",36,[F:SCI]SCONUM,[F:SCI]SCILIN,0,"") From TRTX3CPT
  Elsif clalev([M:POI1])
    Call CHARG_ACCCCE(NOL,"[M:POI1]LINACC","","[M:POI1]CCE",
&                    "SCI",36,[F:SCI]SCONUM,[F:SCI]SCILIN,0,"") From TRTX3CPT
  Endif
  #----- Type d'achat "Achats" -----#
  [M]LINPURTYP(NOL)=1
  Call D_LINPURTYP ([M]LINPURTYP(NOL)) : # Chargement type d'achat
  # EO mono-article: on passe ici si on a pické tout ou partie de la qté de service
  [M]LIKQTYCOE(NOL)=0
  [M]QTYSTU(NOL)   =[F:SCI]EXTQTY * COEFF_SCI * COEFF_SCS  # Issue 85154 GA 10/2012 avant COEFF_SCS
  Call QTEARR([M]QTYSTU(NOL),[M]STU(NOL)) From TRTDIV
  [M]RETQTYSTU(NOL)=[M]QTYSTU(NOL)
  Call PCAL_QTY([M]QTYSTU(NOL),[M]STU(NOL),[M]QTYPUU(NOL),[M]PUU(NOL),
&               [M]ITMREF(NOL),WBPRNUM,1,GBIDD1) From TRTACHQTE1

  # Issue 107513/US15 GA 07/2015
  If dim([M]ECCVALMAJ)>0 & [F:ITM]ECCFLG>1
      [M]ECCVALMAJ(NOL)=[F:SCI]ECCVALMAJ
      [M]ECCVALMIN(NOL)=[F:SCI]ECCVALMIN
      If dim([M]ECCSAIFLG)>0
          [M]ECCSAIFLG(NOL)=9    # from BOM
      Endif
      If dim([M]ECCVALMAJORI)>0
          [M]ECCVALMAJORI(NOL)=[F:SCI]ECCVALMAJ
          [M]ECCVALMINORI(NOL)=[F:SCI]ECCVALMIN
      Endif
  Endif

Return


# ----- Chargement de la classe [M] depuis une ligne [F:SCS] SCOSRV ----- #
$CHARG_LIG_SCS
  [M]ITMREF(NOL)   =[F:SCS]SRVITMREF
  [M]ITMREFORI(NOL)=[F:SCS]ITMREF
  # Issue 112754 - 2016-09-27 by SR : Services
  [M]ITMKND(NOL)   = 2
  #----- Chargement des désignations article -----#
  If [F:ITM]ITMREF<>[M]ITMREF(NOL)
    Read [ITM] ITM0=[M]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
  Endif
  #Call CHARGE_ITMDES("DES1AXX",WLAN,[F:ITM]ITMREF,[M]ITMDES(NOL)) From TRTX3
  #If [M]ITMDES(NOL)=""  [M]ITMDES(NOL)=[F:ITM]ITMDES1 : Endif
  Call CHARGE_DEFITMDES("DES1AXX",WLAN,[F:ITM]ITMREF,[M]ITMDES(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
  # Issue 119168 - 2016-10-21 by SR
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M]ITMDES1(NOL), "[F:ITM]") From TRTX3
  If [M]ITMDES1(NOL)="" [M]ITMDES1(NOL)=[M]ITMDES(NOL) Endif
  #-----
  [M]SCOADD(NOL)   =[F:SCI]BPAADD
  [M]OFS(NOL)      =[F:SCS]SCOLTI
  [M]UOM(NOL)      =[F:SCS]SCOPUU
  [M]PUU(NOL)      =[F:SCS]OPESTU    # FQ 69609 GA 12/2010 avant SCOPUU
  [M]STU(NOL)      =[F:SCS]OPESTU    # FQ 69609 GA 12/2010 avant SCOPUU
  # Issue 85528 GA 2012 Ko : cela empêche de changer le site de commande plus tard
  # Issue 84787 GA 10/2012 pour Regroupement
  #If dim([M:POI1]POHFCY)>0 [M:POI1]POHFCY=[F:SCO]POHFCY : Endif
  If dim([M:POI1]POHFCY)>0 & [M:POI1]POHFCY=""  [M:POI1]POHFCY=[F:SCO]POHFCY : Endif
  [M]PRHFCY(NOL)   =[F:SCI]PRHFCY   : # Issue 84787 GA 10/2012 pour Regroupement
  [M]FCYADD(NOL)   =[F:SCI]PRHADD   : # Issue 84787 GA 10/2012 pour Regroupement
  Gosub CTL_BUY_EO                    # Issue 87637 GA 02/2013 Code acheteur si GFLTBUY=2
  Gosub CTL_RCPDAT_EO                 # Issue 88261 GA 03/2013
  # Issue 85916 GA 11/2012 si qté forfaitaire, pas de commande en UO
  If [F:SCS]OPESTRCOE<>0 & [F:SCS]STRQTYCOD<>2
     [M]UOMPUUCOE(NOL)=1/[F:SCS]OPESTRCOE # FQ 73520 GA 05/2011 - FQ 69609 GA 12/2010 avant 1
  Else
     [M]UOMPUUCOE(NOL)=1
     [M]UOM(NOL)      = [F:SCS]OPESTU
  Endif
  [M]LINTYP(NOL)   =3             : # Composant Service
  [M]VCRTYPORI(NOL)=36
  [M]VCRNUMORI(NOL)=[F:SCI]SCONUM
  [M]VCRLINORI(NOL)=[F:SCI]SCILIN
  [M]VCRSEQORI(NOL)=[F:SCS]SCSLIN
  # Issue 93144 GA 10/2013 détail du tarif + loin (après maj de la qté)
  #If dim([M]PRIREN(NOL))>0 [M]PRIREN(NOL)=[F:SCS]PRIREN Endif # Issue 86122 GA 11/2012
  #If dim([M]NETPRI(NOL))>0 [M]NETPRI(NOL)=[F:SCS]NETPRI Endif # Issue 86122 GA 11/2012
  #If dim([M]GROPRI(NOL))>0 [M]GROPRI(NOL)=[F:SCS]GROPRI Endif # Issue 86122 GA 11/2012
  #If dim([M]LINAMT(NOL))>0 [M]LINAMT(NOL)=[F:SCS]LINAMT Endif # Issue 86122 GA 11/2012
  #----- Chargement comptes et sections analytiques -----#
  If clalev([M:POH2])
    # Issue 117079 - 2016-06-15 by MUARN : alimentation code taxe
    Call ALIVATCOD(2,[M:POH0]BPSNUM,[M:POH2]ITMREF(NOL),"POH2",NOL) From TRTX3
    Call CHARG_ACCCCE(NOL,"[M:POH2]LINACC","","[M:POH2]CCE",
&                    "SCS",36,[F:SCS]SCONUM,[F:SCS]SCILIN,[F:SCS]SCSLIN,"") From TRTX3CPT
  Elsif clalev([M:POI1])
    # Issue 117079 - 2016-06-15 by MUARN : alimentation code taxe
    Call ALIVATCOD(2,[M:POI1]BPSNUM(NOL),[M:POI1]ITMREF(NOL),"POI1",NOL) From TRTX3
    Call CHARG_ACCCCE(NOL,"[M:POI1]LINACC","","[M:POI1]CCE",
&                    "SCS",36,[F:SCS]SCONUM,[F:SCS]SCILIN,[F:SCS]SCSLIN,"") From TRTX3CPT
  Endif
  #----- Type d'achat "Service" -----#
  [M]LINPURTYP(NOL)=3
  # Issue 71069 - 2015-12-15 by MUARN : pjt
  [M]PJT(NOL)=[F:SCI]PJT
  Call D_LINPURTYP ([M]LINPURTYP(NOL)) : # Chargement type d'achat
  # EO: on passe ici si on a pické tout ou partie de la qté d'article lancé
  # Issue 84679 GA 09/2012 on a besoin de LIKQTYCOE
  # If [F:SCS]STRQTYCOD=2 | COEFF_SCI=1
  If [F:SCS]STRQTYCOD=2
     [M]LIKQTYCOE(NOL)=0
     [M]QTYPUU(NOL)   =[F:SCS]EXTQTY        # FQ 69609 GA 12/2010 avant EXTSTRQTY
     [M]QTYSTU(NOL)   =[F:SCS]EXTQTY        # FQ 69609 GA 12/2010 avant EXTSTRQTY
     [M]QTYUOM(NOL)   =[F:SCS]EXTSTRQTY     # FQ 69609 GA 12/2010 qté UOM
     [M]RETQTYSTU(NOL)=[M]QTYSTU(NOL)
  Else
     [M]LIKQTYCOE(NOL)=arr([F:SCS]EXTQTY/[F:SCI]EXTQTY,10^-6)
     [M]QTYSTU(NOL)   =[F:SCS]EXTQTY * COEFF_SCI * COEFF_SCS  # Issue 84500 GA 10/2012 avant COEFF_SCI
     Call QTEARR([M]QTYSTU(NOL),[M]STU(NOL)) From TRTDIV
     [M]RETQTYSTU(NOL)=[M]QTYSTU(NOL)
# Issue 80045
#     Call PCAL_QTY([M]QTYSTU(NOL),[M]STU(NOL),[M]QTYPUU(NOL),[M]PUU(NOL),
#&                  [M]ITMREF(NOL),WBPRNUM,1,GBIDD1) From TRTACHQTE1
     [M]QTYPUU(NOL)   =[M]QTYSTU(NOL)
   # FQ 73520 GA 05/2011 - FQ 69609 GA 12/2010
     If [M]UOMPUUCOE(NOL)<>0
        [M]QTYUOM(NOL)   =[M]QTYPUU(NOL) / [M]UOMPUUCOE(NOL)
     Else
        [M]QTYUOM(NOL)   =[M]QTYPUU(NOL)
     Endif
     Call QTEARR([M]QTYUOM(NOL),[M]UOM(NOL)) From TRTDIV
  Endif
  # FQ 73520 GA 05/2011
  If dim([M]UOMFLG)>0 & [M]UOM(NOL)<>[M]PUU(NOL)
     [M]UOMFLG(NOL)=2   # Commande en UC pour le Service
     If dim(WUOMFLG)<1  Local Libelle WUOMFLG : Endif
     WUOMFLG=2
  Endif
  # Issue 93144 GA 10/2013 détail du tarif après maj de la qté
  If clalev([M:POH2])
    Call INI_TARIF(NOL,"ITMREF") From SUBPOHB # Issue 93144 GA 10/2013 Différence V8/V7
  Elsif clalev([M:POI1])
    Call INI_TARIF(NOL) From SUBPOI
  Endif
  # Issue 93144 GA 10/2013 pas de tarif : on garde les données de l'EO
  If dim([M]NETPRI(NOL))>0 & [M]NETPRI(NOL)=0
      [M]PRIREN(NOL)=[F:SCS]PRIREN
      [M]NETPRI(NOL)=[F:SCS]NETPRI
      [M]GROPRI(NOL)=[F:SCS]GROPRI
      [M]LINAMT(NOL)=[F:SCS]LINAMT
  Endif
Return


# ----- Chargement de la classe [M] depuis une ligne [F:SCM] SCOMAT ----- #
$CHARG_LIG_SCM
  [M]ITMREF(NOL)   =[F:SCM]CPNITMREF
  [M]ITMREFORI(NOL)=[F:SCM]ITMREF
  # Issue 112754 - 2016-09-27 by SR : Services
  [M]ITMKND(NOL)   = 1
  #----- Chargement des désignations article -----#
  If [F:ITM]ITMREF<>[M]ITMREF(NOL)
    Read [ITM] ITM0=[M]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
  Endif
  #Call CHARGE_ITMDES("DES1AXX",WLAN,[F:ITM]ITMREF,[M]ITMDES(NOL)) From TRTX3
  #If [M]ITMDES(NOL)=""  [M]ITMDES(NOL)=[F:ITM]ITMDES1 : Endif
  Call CHARGE_DEFITMDES("DES1AXX",WLAN,[F:ITM]ITMREF,[M]ITMDES(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
  # Issue 119168 - 2016-10-21 by SR
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M]ITMDES1(NOL), "[F:ITM]") From TRTX3
  If [M]ITMDES1(NOL)="" [M]ITMDES1(NOL)=[M]ITMDES(NOL) Endif
  #-----
  [M]SCOADD(NOL)   =[F:SCI]BPAADD
  [M]OFS(NOL)      =[F:SCM]BOMOFS
  [M]UOM(NOL)      =[F:SCM]BOMUOM
  [M]PUU(NOL)      =[F:SCM]STU       # Issue 79859 GA 04/2012 before BOMUOM
  [M]STU(NOL)      =[F:SCM]STU
  [M]UOMPUUCOE(NOL)=[F:SCM]BOMSTUCOE # Issue 79859 GA 04/2012 before 1
  [M]LINTYP(NOL)   =4 : # Composant Matière
  [M]PRHFCY(NOL)   =[F:SCI]PRHFCY
  [M]FCYADD(NOL)   =[F:SCI]PRHADD   : # Issue 84787 GA 10/2012 pour Regroupement
  Gosub CTL_BUY_EO                    # Issue 87637 GA 02/2013 Code acheteur si GFLTBUY=2
  Gosub CTL_RCPDAT_EO                 # Issue 88261 GA 03/2013
  # Issue 85528 GA 2012 Ko : cela empêche de changer le site de commande plus tard
  # Issue 84787 GA 10/2012 pour Regroupement
  #If dim([M:POI1]POHFCY)>0 [M:POI1]POHFCY=[F:SCO]POHFCY : Endif
  If dim([M:POI1]POHFCY)>0 & [M:POI1]POHFCY=""  [M:POI1]POHFCY=[F:SCO]POHFCY : Endif
  [M]VCRTYPORI(NOL)=36
  [M]VCRNUMORI(NOL)=[F:SCI]SCONUM
  [M]VCRLINORI(NOL)=[F:SCI]SCILIN
  [M]VCRSEQORI(NOL)=[F:SCM]SCMLIN
  # Issue 71069 - 2015-12-15 by MUARN : pjt
  [M]PJT(NOL)=[F:SCI]PJT
  # Issue 93144 GA 10/2013 détail du tarif + loin (après maj de la qté)
  #If dim([M]PRIREN(NOL))>0 [M]PRIREN(NOL)=[F:SCM]PRIREN Endif # Issue 86122 GA 11/2012
  #If dim([M]NETPRI(NOL))>0 [M]NETPRI(NOL)=[F:SCM]NETPRI Endif # Issue 86122 GA 11/2012
  #If dim([M]GROPRI(NOL))>0 [M]GROPRI(NOL)=[F:SCM]GROPRI Endif # Issue 86122 GA 11/2012
  #If dim([M]LINAMT(NOL))>0 [M]LINAMT(NOL)=[F:SCM]LINAMT Endif # Issue 86122 GA 11/2012
  #----- Chargement comptes et sections analytiques -----#
  If clalev([M:POH2])
    # Issue 117079 - 2016-06-15 by MUARN : alimentation code taxe
    Call ALIVATCOD(2,[M:POH0]BPSNUM,[M:POH2]ITMREF(NOL),"POH2",NOL) From TRTX3
    Call CHARG_ACCCCE(NOL,"[M:POH2]LINACC","","[M:POH2]CCE",
&                    "SCM",36,[F:SCM]SCONUM,[F:SCM]SCILIN,[F:SCM]SCMLIN,"") From TRTX3CPT
  Elsif clalev([M:POI1])
    # Issue 117079 - 2016-06-15 by MUARN : alimentation code taxe
    Call ALIVATCOD(2,[M:POI1]BPSNUM(NOL),[M:POI1]ITMREF(NOL),"POI1",NOL) From TRTX3
    Call CHARG_ACCCCE(NOL,"[M:POI1]LINACC","","[M:POI1]CCE",
&                    "SCM",36,[F:SCM]SCONUM,[F:SCM]SCILIN,[F:SCM]SCMLIN,"") From TRTX3CPT
  Endif
  #----- Type d'achat "Achats" -----#
  [M]LINPURTYP(NOL)=1
  Call D_LINPURTYP ([M]LINPURTYP(NOL)) : # Chargement type d'achat
  # Issue 84679 GA 09/2012 on a besoin de LIKQTYCOE
  # If [F:SCM]LIKQTYCOD=2 | COEFF_SCI=1       # Issue 80045 idem si on a tout commandé
  If [F:SCM]LIKQTYCOD=2
     [M]LIKQTYCOE(NOL)=0
     [M]QTYSTU(NOL)   =[F:SCM]RETQTY
   # Issue 85916 GA 11/2012 si qté forfaitaire, pas de commande en UO
     [M]UOM(NOL)      =[F:SCM]STU
     [M]UOMPUUCOE(NOL)=1
  Else
     [M]LIKQTYCOE(NOL)=arr([F:SCM]RETQTY/[F:SCI]EXTQTY,10^-6)
     [M]QTYSTU(NOL)   =[F:SCM]RETQTY * COEFF_SCI * COEFF_SCS  # Issue 84500 GA 10/2012 avant COEFF_SCI
     Call QTEARR([M]QTYSTU(NOL),[M]STU(NOL)) From TRTDIV
  Endif
# Issue 79859 GA 04/2012 - idem Issue 80045
#  Call PCAL_QTY([M]QTYSTU(NOL),[M]STU(NOL),[M]QTYPUU(NOL),[M]PUU(NOL),
#&               [M]ITMREF(NOL),WBPRNUM,1,GBIDD1) From TRTACHQTE1
  [M]RETQTYSTU(NOL)=[M]QTYSTU(NOL)
  [M]QTYPUU(NOL)   =[M]QTYSTU(NOL)
  If [M]UOMPUUCOE(NOL)<>0
     [M]QTYUOM(NOL)   =[M]QTYPUU(NOL) / [M]UOMPUUCOE(NOL)
  Else
     [M]QTYUOM(NOL)   =[M]QTYPUU(NOL)
  Endif
  Call QTEARR([M]QTYUOM(NOL),[M]UOM(NOL)) From TRTDIV
  If dim([M]UOMFLG)>0 & [M]UOM(NOL)<>[M]PUU(NOL)
     [M]UOMFLG(NOL)=2   # Commande en UC pour le Composant
     If dim(WUOMFLG)<1  Local Libelle WUOMFLG : Endif
     WUOMFLG=2
  Endif
  # Issue 93144 GA 10/2013 détail du tarif après maj de la qté
  If clalev([M:POH2])
    Call INI_TARIF(NOL,"ITMREF") From SUBPOHB # Issue 93144 GA 10/2013 Différence V8/V7
  Elsif clalev([M:POI1])
    Call INI_TARIF(NOL) From SUBPOI
  Endif
  # Issue 93144 GA 10/2013 pas de tarif : on garde les données de l'EO
  If dim([M]NETPRI(NOL))>0 & [M]NETPRI(NOL)=0
      [M]PRIREN(NOL)=[F:SCM]PRIREN
      [M]NETPRI(NOL)=[F:SCM]NETPRI
      [M]GROPRI(NOL)=[F:SCM]GROPRI
      [M]LINAMT(NOL)=[F:SCM]LINAMT
  Endif
  # Issue 107513/US15 GA 07/2015
  If dim([M]ECCVALMAJ)>0 & [F:ITM]ECCFLG>1
      [M]ECCVALMAJ(NOL)=[F:SCM]ECCVALMAJ
      [M]ECCVALMIN(NOL)=[F:SCM]ECCVALMIN
      If dim([M]ECCSAIFLG)>0
          [M]ECCSAIFLG(NOL)=9    # from BOM
      Endif
      If dim([M]ECCVALMAJORI)>0  # not used is POx ?
          [M]ECCVALMAJORI(NOL)=[F:SCM]ECCVALMAJ
          [M]ECCVALMINORI(NOL)=[F:SCM]ECCVALMIN
      Endif
  Endif
  Return


# ----- Chargement de la classe [M] depuis une ligne [F:MFI] MFGITM ----- #
$CHARG_LIG_MFI
  [M]ITMREF(NOL)   =[F:MFI]ITMREF
  [M]ITMREFORI(NOL)=[F:MFI]ITMREF   : # nécessaire pour le tri des lignes
  # Issue 112754 - 2016-09-27 by SR : Services
  [M]ITMKND(NOL)   = 1
  #----- Chargement des désignations article -----#
  If [F:ITM]ITMREF<>[M]ITMREF(NOL)
    Read [ITM] ITM0=[M]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
  Endif
  #Call CHARGE_ITMDES("DES1AXX",WLAN,[F:ITM]ITMREF,[M]ITMDES(NOL)) From TRTX3
  #If [M]ITMDES(NOL)=""  [M]ITMDES(NOL)=[F:ITM]ITMDES1 : Endif
  Call CHARGE_DEFITMDES("DES1AXX",WLAN,[F:ITM]ITMREF,[M]ITMDES(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
  # Issue 119168 - 2016-10-21 by SR
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M]ITMDES1(NOL), "[F:ITM]") From TRTX3
  If [M]ITMDES1(NOL)="" [M]ITMDES1(NOL)=[M]ITMDES(NOL) Endif
  #-----
  [M]SCOADD(NOL)   =[F:MFO]BPAADD
  [M]OFS(NOL)      =[F:MFO]SCOLTI
  [M]UOM(NOL)      =[F:MFI]STU   : # UOM ?
  [M]PUU(NOL)      =[F:MFI]STU   : # UOM ?
  [M]STU(NOL)      =[F:MFI]STU
  [M]UOMPUUCOE(NOL)=1
  [M]LINTYP(NOL)   =2 : # Composé
  Gosub CTL_RCPDAT_OF                 # Issue 88261 GA 03/2013
  [M]PRHFCY(NOL)   =[F:MFI]MFGFCY  : # ou PLNFCY ???
  [M]VCRTYPORI(NOL)=10
  [M]VCRNUMORI(NOL)=[F:MFI]MFGNUM
  [M]VCRLINORI(NOL)=[F:MFO]OPENUM    # ou [F:MFI]MFGLIN ????
  [M]VCRSEQORI(NOL)=[F:MFO]OPESPLNUM
  #----- Chargement comptes et sections analytiques -----#
  If clalev([M:POH2])
    Call CHARG_ACCCCE(NOL,"[M:POH2]LINACC","","[M:POH2]CCE",
&                    "MFI",0,[F:MFI]MFGNUM,[F:MFI]MFGLIN,0,"") From TRTX3CPT
  Elsif clalev([M:POI1])
    Call CHARG_ACCCCE(NOL,"[M:POI1]LINACC","","[M:POI1]CCE",
&                    "MFI",0,[F:MFI]MFGNUM,[F:MFI]MFGLIN,0,"") From TRTX3CPT
  Endif
  #----- Type d'achat "Achats" -----#
  [M]LINPURTYP(NOL)=1
  Call D_LINPURTYP ([M]LINPURTYP(NOL)) : # Chargement type d'achat
  #- Qté
  [M]LIKQTYCOE(NOL)=1
  Call QTEARR([M]QTYPUU(NOL),[M]PUU(NOL)) From TRTDIV
  [M]QTYSTU(NOL)   =WQTYSTU
  [M]RETQTYSTU(NOL)=WQTYSTU
  Call QTEARR([M]QTYSTU(NOL),[M]STU(NOL)) From TRTDIV
  Call PCAL_QTY([M]QTYSTU(NOL),[M]STU(NOL),[M]QTYPUU(NOL),[M]PUU(NOL),
&               [M]ITMREF(NOL),WBPRNUM,1,GBIDD1) From TRTACHQTE1
Return


# ----- Chargement de la classe [M] depuis une ligne [F:MFO] MFGOPE ----- #
$CHARG_LIG_MFO
  [M]ITMREF(NOL)   =[F:PWO]ITMREF : # ou [F:MFO]SCOITMREF
  [M]ITMREFORI(NOL)=[F:MFI]ITMREF
  # Issue 112754 - 2016-09-27 by SR : Services
  [M]ITMKND(NOL)   = 2
  #----- Chargement des désignations article -----#
  If [F:ITM]ITMREF<>[M]ITMREF(NOL)
    Read [ITM] ITM0=[M]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
  Endif
  #Call CHARGE_ITMDES("DES1AXX",WLAN,[F:ITM]ITMREF,[M]ITMDES(NOL)) From TRTX3
  #If [M]ITMDES(NOL)=""  [M]ITMDES(NOL)=[F:ITM]ITMDES1 : Endif
  Call CHARGE_DEFITMDES("DES1AXX",WLAN,[F:ITM]ITMREF,[M]ITMDES(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
  # Issue 119168 - 2016-10-21 by SR
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M]ITMDES1(NOL), "[F:ITM]") From TRTX3
  If [M]ITMDES1(NOL)="" [M]ITMDES1(NOL)=[M]ITMDES(NOL) Endif
  #-----
  [M]SCOADD(NOL)   =[F:MFO]BPAADD
  [M]OFS(NOL)      =[F:MFO]SCOLTI
  [M]UOM(NOL)      =[F:PWO]PUU  :
  [M]PUU(NOL)      =[F:PWO]PUU  : # Issue 85813 & 86889 GA 01/2013
  [M]STU(NOL)      =[F:PWO]STU
  # Issue 107472 - 2015-11-10 by MUARN : PUU et UOM alimenté par la même zone pas de coeff
  #If [F:MFO]OPESTUCOE<>0          # Issue 79859 ?
  #   [M]UOMPUUCOE(NOL)=1/[F:MFO]OPESTUCOE
  #Else
  #   [M]PUU(NOL)      =[F:PWO]PUU
  #   [M]UOMPUUCOE(NOL)=1
  #Endif
  [M]UOMPUUCOE(NOL)=1

  Gosub CTL_RCPDAT_OF                 # Issue 88261 GA 03/2013
  [M]LINTYP(NOL)   =3 : # Composant Service
  [M]VCRTYPORI(NOL)=10
  [M]VCRNUMORI(NOL)=[F:MFO]MFGNUM
  [M]VCRLINORI(NOL)=[F:MFO]OPENUM    # ou [F:MFI]MFGLIN ????
  [M]VCRSEQORI(NOL)=[F:MFO]OPESPLNUM
  #----- Chargement comptes et sections analytiques -----#
  If clalev([M:POH2])
    Call CHARG_ACCCCE(NOL,"[M:POH2]LINACC","","[M:POH2]CCE",
&                    "MFO",0,[F:MFO]MFGNUM,[F:MFO]OPENUM,[F:MFO]OPESPLNUM,"EXTWST") From TRTX3CPT
  Elsif clalev([M:POI1])
    # FQ 56128 avant [M:MFO]OPESPLNUM
    Call CHARG_ACCCCE(NOL,"[M:POI1]LINACC","","[M:POI1]CCE",
&                    "MFO",0,[F:MFO]MFGNUM,[F:MFO]OPENUM,[F:MFO]OPESPLNUM,"EXTWST") From TRTX3CPT
  Endif
  #----- Type d'achat "Service" -----#
  [M]LINPURTYP(NOL)=3
  Call D_LINPURTYP ([M]LINPURTYP(NOL)) : # Chargement type d'achat
  # pas qté forfaitaire pour les opérations d'OF
  # => on est toujours proportionnel
  [M]LIKQTYCOE(NOL)=arr(COEFF_MFI*COEFF_MFO,10^-6)
  # Issue 109883 - 2015-12-07 by MUARN : ne pas faire déjà géré en amont
  If WQTYSTU <> 0
    If WQTYSTU<>0     # Issue 84830 GA 10/2012
       [M]QTYSTU(NOL)=WQTYSTU
    Else
       [M]QTYSTU(NOL)=[F:PWO]QTYSTU
    Endif
    [M]RETQTYSTU(NOL)=[M]QTYSTU(NOL)
    Call QTEARR([M]QTYSTU(NOL),[M]STU(NOL)) From TRTDIV
    # Issue 85813 & 86889 GA 01/2013 pb si cde partielle
  #  Call PCAL_QTY([M]QTYSTU(NOL),[M]STU(NOL),[M]QTYPUU(NOL),[M]PUU(NOL),
  #&               [M]ITMREF(NOL),WBPRNUM,1,GBIDD1) From TRTACHQTE1
    If [M]PUU(NOL)=[M]STU(NOL)
       [M]QTYPUU(NOL)=[M]QTYSTU(NOL)
    Else
       [M]QTYPUU(NOL)=[F:PWO]QTYPUU
    Endif
  Endif
Return

# ----- Chargement de la classe [M] depuis une ligne [F:MFM] MFGMAT ----- #
$CHARG_LIG_MFM
  [M]ITMREF(NOL)   =[F:MFM]ITMREF
  [M]ITMREFORI(NOL)=[F:MFI]ITMREF
  # Issue 112754 - 2016-09-27 by SR : Services
  [M]ITMKND(NOL)   = 1
  #----- Chargement des désignations article -----#
  If [F:ITM]ITMREF<>[M]ITMREF(NOL)
    Read [ITM] ITM0=[M]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
  Endif
  #Call CHARGE_ITMDES("DES1AXX",WLAN,[F:ITM]ITMREF,[M]ITMDES(NOL)) From TRTX3
  #If [M]ITMDES(NOL)=""  [M]ITMDES(NOL)=[F:ITM]ITMDES1 : Endif
  Call CHARGE_DEFITMDES("DES1AXX",WLAN,[F:ITM]ITMREF,[M]ITMDES(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
  # Issue 119168 - 2016-10-21 by SR
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M]ITMDES1(NOL), "[F:ITM]") From TRTX3
  If [M]ITMDES1(NOL)="" [M]ITMDES1(NOL)=[M]ITMDES(NOL) Endif
  #-----
  [M]SCOADD(NOL)   =[F:MFO]BPAADD
  [M]OFS(NOL)      =[F:MFM]BOMOFS
  [M]UOM(NOL)      =[F:MFM]STU    : # BOMUOM ?
  [M]PUU(NOL)      =[F:MFM]STU    : # BOMUOM ?
  [M]STU(NOL)      =[F:MFM]STU
  [M]UOMPUUCOE(NOL)=1
  [M]LINTYP(NOL)   =4 : # Composant Matière
  Gosub CTL_RCPDAT_OF                 # Issue 88261 GA 03/2013
  [M]PRHFCY(NOL)   =[F:MFI]MFGFCY  : # ou PLNFCY ???
  [M]VCRTYPORI(NOL)=10
  [M]VCRNUMORI(NOL)=[F:MFI]MFGNUM
  [M]VCRLINORI(NOL)=[F:MFO]OPENUM    # ou [F:MFI]MFGLIN ????
  [M]VCRSEQORI(NOL)=[F:MFM]BOMSEQ
  #----- Chargement comptes et sections analytiques -----#
  If clalev([M:POH2])
    Call CHARG_ACCCCE(NOL,"[M:POH2]LINACC","","[M:POH2]CCE",
&                    "MFM",0,[F:MFM]MFGNUM,[F:MFM]MFGLIN,[F:MFM]BOMSEQ,[F:MFM]ITMREF) From TRTX3CPT
  Elsif clalev([M:POI1])
    Call CHARG_ACCCCE(NOL,"[M:POI1]LINACC","","[M:POI1]CCE",
&                    "MFM",0,[F:MFM]MFGNUM,[F:MFM]MFGLIN,[F:MFM]BOMSEQ,[F:MFM]ITMREF) From TRTX3CPT
  Endif
  #----- Type d'achat "Achats" -----#
  [M]LINPURTYP(NOL)=1
  Call D_LINPURTYP ([M]LINPURTYP(NOL)) : # Chargement type d'achat
  #- Qté
  If [F:MFM]LIKQTYCOD=2
     [M]LIKQTYCOE(NOL)=0
     [M]QTYSTU(NOL)   =[M:MFM]RETQTY
  Else
     [M]LIKQTYCOE(NOL)=arr([F:MFM]RETQTY/[F:MFI]EXTQTY,10^-6)
     [M]QTYSTU(NOL)   =[F:MFM]RETQTY*COEFF_MFI*COEFF_MFO
     Call QTEARR([M]QTYSTU(NOL),[M]STU(NOL)) From TRTDIV
  Endif
  Call PCAL_QTY([M]QTYSTU(NOL),[M]STU(NOL),[M]QTYPUU(NOL),[M]PUU(NOL),
&               [M]ITMREF(NOL),WBPRNUM,1,GBIDD1) From TRTACHQTE1
Return

Subprog D_LINPURTYP(VALEUR)
#------------------------------------#
# Après modification du type d'achat #
#------------------------------------#
Variable Integer VALEUR

# renseigner [M]LINACC1, [M]LINACC2 ????
# Issue 87878 GA 02/2013 # Utiliser $INIT_COMPTES_LIGNE et $PREP_INIT_CCE
#--------------------------------------------------------------#
# Initialisation du type d'achat en fonction du compte général #
#--------------------------------------------------------------#
Local    Shortint NOL : NOL=nolign-1
Local    Char     WACC(GLONGAC)
#-----
#----- Initialisation des comptes et du type d'achat -----#
If clalev([M:POI1])
  Call INIT_COMPTES_LIGNE (NOL) From SUBPOI
  Gosub INIT_LINPURTYP
  #-----
  GBIDI2=0 : Gosub PREP_INIT_CCE From SUBPOI
Else
  # Issue 84130 - 2013-05-24 by MUARN : Landed cost déplacé de SUBPOH en SUBPOHB
  Call INIT_COMPTES_LIGNE (NOL) From SUBPOHB
  Gosub INIT_LINPURTYP
  #-----
  GBIDI2=0 : Gosub PREP_INIT_CCE From SUBPOH
Endif
End

$INIT_LINPURTYP
#--------------------------------------------------------------#
# Initialisation du type d'achat en fonction du compte général #
#--------------------------------------------------------------#
Call RECH_ACC(1,"[M]LINACC",nolign-1,WACC) From TRTX3CPT
If WACC<>""
  If [F:GAC]VATIPT=5
    VALEUR=3
  Elsif [F:GAC]VATIPT=4
    VALEUR=2
  Else
    VALEUR=1
  Endif
Elsif VALEUR=0  # sauf si déjà renseignée à 3
  VALEUR=1
Endif
Return

#-----------------------------------------#
# Calcul du prix d'achat sous-traité      #
# [F:POQ] contient la ligne article lancé #
#-----------------------------------------#
Subprog CALC_POQ_LINAMT(LAMT)
Variable Decimal LAMT

Local Decimal  WAMTL

Call CALC_POQ_LINAMTL(LAMT,WAMTL)

End
#-----------------------------------------#
# Calcul du prix d'achat sous-traité      #
# [F:POQ] contient la ligne article lancé #
#-----------------------------------------#
Subprog CALC_POQ_LINAMTL(LAMT,LAMTL)
Variable Decimal LAMT
Variable Decimal LAMTL
Local Char     WITMREF(GLONITM) : WITMREF=[F:POQ]ITMREF
Local Char     WPOHNUM(GLONVCR) : WPOHNUM=[F:POQ]POHNUM
Local Integer  WPOPLIN          : WPOPLIN=[F:POQ]POPLIN
Local Decimal  WAMT             : Raz WAMT
Local Decimal  WPRI,WPRIL,WQTY  : Raz WPRI,WPRIL,WQTY

# Issue 101179 & 100967 GA 07/2014
Local Char     WCPRCUR(GLONCUR),WCUR(GLONCUR)
If [F:POH]POHNUM<>WPOHNUM
   Read [F:POH]POH0=WPOHNUM : If fstat : Raz [F:POH] : Endif
Endif
WCUR = [F:POH]CUR
WCPRCUR = GLOCALDEV

Local File PORDERQ [F:POQW]

# Issue 100671 GA 12/2014 WOF subcontracted operation
Local Char     WVCRNUM(GLONVCR) : WVCRNUM=[F:POQ]VCRNUMORI   # Issue 100671 GA 12/2014
Local Integer  WVCRTYP          : WVCRTYP=[F:POQ]VCRTYPORI   # Issue 100671 GA 12/2014
Case WVCRTYP   # Issue 100671 GA 12/2014
  When 36
     Filter [F:POQW] Where POHNUM=WPOHNUM & POPLIN>WPOPLIN & LINTYP>2 & VCRNUMORI=WVCRNUM
  When 10
     Filter [F:POQW] Where POHNUM=WPOHNUM & POPLIN=WPOPLIN
Endcase

For [F:POQW]POQ0
   #If [F:POQW]ITMREFORI=WITMREF & [F:POQW]LINTYP>2   # Issue 100671 GA 12/2014
   If [F:POQW]ITMREFORI=WITMREF | [F:POQW]VCRTYPORI=10
   # On parcourt le Service et matières fournies par le sous-traitant
      WAMT +=[F:POQW]LINAMT
   Else
   # Autre article commandé, on sort
      Break
   Endif
Next
If WCPRCUR<>WCUR & WCUR<>""  # Issue 101179 & 100967 GA 07/2014 amount in purchase currency
   LAMT =WAMT
   Local Integer WSTAT
   Call CONVERT2(WCUR,WCPRCUR,WCPRCUR,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                 WAMT,WAMT,WSTAT) From TRTDEV
   LAMTL=WAMT
Else
   LAMTL=WAMT
   LAMT=WAMT
Endif
Filter [F:POQW]
Close File [F:POQW]
End


#-----------------------------------------#
# Calcul du prix d'achat sous-traité      #
# [F:POQ] contient la ligne article lancé #
#-----------------------------------------#
Subprog CALC_PTD_LINAMT(LAMT)
Variable Decimal LAMT

Local Decimal  WAMTL

Call CALC_PTD_LINAMTL(LAMT,WAMTL)

End
#-----------------------------------------#
# Calcul du prix d'achat sous-traité      #
# [F:PTD] contient la ligne article lancé #
#-----------------------------------------#
Subprog CALC_PTD_LINAMTL(LAMT,LAMTL)
Variable Decimal LAMT
Variable Decimal LAMTL
Local Char     WITMREF(GLONITM) : WITMREF=[F:PTD]ITMREF
Local Char     WPTHNUM(GLONVCR) : WPTHNUM=[F:PTD]PTHNUM
Local Integer  WPTDLIN          : WPTDLIN=[F:PTD]PTDLIN
Local Char     WPOHNUM(GLONVCR) : WPOHNUM=[F:PTD]POHNUM    # Issue 100671 GA 01/2015
Local Integer  WPOPLIN          : WPOPLIN=[F:PTD]POPLIN    # Issue 100671 GA 01/2015
Local Decimal  WAMT             : Raz WAMT
Local Decimal  WPRI,WPRIL,WQTY  : Raz WPRI,WPRIL,WQTY

# Issue 101179 & 100967 GA 07/2014
Local Char     WCPRCUR(GLONCUR),WCUR(GLONCUR)
If [F:POH]POHNUM<>[F:PTD]POHNUM
   Read [F:POH]POH0=[F:PTD]POHNUM : If fstat Raz [F:POH] Endif
Endif
WCUR = [F:POH]CUR
WCPRCUR = GLOCALDEV

Local File PRECEIPTD [F:PTDW]

# Issue 100671 GA 12/2014 WOF subcontracted operation
Local Char     WVCRNUM(GLONVCR) : WVCRNUM=[F:PTD]VCRNUMORI   # Issue 100671 GA 12/2014
Local Integer  WVCRTYP          : WVCRTYP=[F:PTD]VCRTYPORI   # Issue 100671 GA 12/2014
Case WVCRTYP   # Issue 100671 GA 12/2014
  When 36
     # Issue 100671 GA 01/2015 + WPOHNUM in case current receipt summarizes 2 or more PO for the same EO
     Filter [F:PTDW] Where PTHNUM=WPTHNUM & PTDLIN>WPTDLIN & LINTYP>2 & VCRNUMORI=WVCRNUM & POHNUM=WPOHNUM
  When 10
     Filter [F:PTDW] Where PTHNUM=WPTHNUM & PTDLIN=WPTDLIN
Endcase

For [F:PTDW]PTD0
   #If [F:PTDW]ITMREFORI=WITMREF & [F:PTDW]LINTYP>2    # Issue 100671 GA 12/2014
   If [F:PTDW]ITMREFORI=WITMREF | [F:PTDW]VCRTYPORI=10
   # On parcourt le Service et matières fournies par le sous-traitant
      WAMT +=[F:PTDW]LINAMT
   Else
   # Autre article commandé, on sort
      Break
   Endif
Next
If WCPRCUR<>WCUR & WCUR<>""  # Issue 101179 & 100967 GA 07/2014 amount in purchase currency
   LAMT =WAMT
   Local Integer WSTAT
   Call CONVERT2(WCUR,WCPRCUR,WCPRCUR,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                 WAMT,WAMT,WSTAT) From TRTDEV
   LAMTL=WAMT
Else
   LAMTL=WAMT
   LAMT=WAMT
Endif
Filter [F:PTDW]
Close File [F:PTDW]
End

#-----------------------------------------#
# Calcul du prix d'achat sous-traité      #
# [F:POQ] contient la ligne article lancé #
#-----------------------------------------#
Subprog CALC_PND_LINAMT(LAMT)
Variable Decimal LAMT

Local Decimal  WAMTL

Call CALC_PND_LINAMTL(LAMT,WAMTL)

End
#-----------------------------------------#
# Calcul du prix d'achat sous-traité      #
# [F:PND] contient la ligne article lancé #
#-----------------------------------------#
Subprog CALC_PND_LINAMTL(LAMT,LAMTL)
Variable Decimal LAMT
Variable Decimal LAMTL
Local Char     WITMREF(GLONITM) : WITMREF=[F:PND]ITMREF
Local Char     WPNHNUM(GLONVCR) : WPNHNUM=[F:PND]PNHNUM
Local Integer  WPNDLIN          : WPNDLIN=[F:PND]PNDLIN
Local Decimal  WAMT             : Raz WAMT
Local Decimal  WPRI,WPRIL,WQTY  : Raz WPRI,WPRIL,WQTY

# Issue 101179 & 100967 GA 07/2014
Local Char     WCPRCUR(GLONCUR),WCUR(GLONCUR)    : WCPRCUR = GLOCALDEV
If [F:POH]POHNUM<>[F:PND]POHNUM
   Read [F:POH]POH0=[F:PND]POHNUM : If fstat Raz [F:POH] Endif
Endif
WCUR = [F:POH]CUR
WCPRCUR = GLOCALDEV

Local File PRETURND [F:PNDW]

# Issue 100671 GA 12/2014 WOF subcontracted operation
If [F:PTD]PTHNUM<>[F:PND]PTHNUM
   Read [F:PTD]PTD0=[F:PND]PTHNUM;[F:PND]PTDLIN : If fstat Raz [F:PTD] Endif
Endif
If [F:POQ]POHNUM<>[F:PTD]POHNUM
   Read [F:POQ]POQ0=[F:PTD]POHNUM;[F:PTD]POPLIN : If fstat Raz [F:POQ] Endif
Endif
Local Char     WVCRNUM(GLONVCR) : WVCRNUM=[F:POQ]VCRNUMORI   # Issue 100671 GA 12/2014
Local Integer  WVCRTYP          : WVCRTYP=[F:POQ]VCRTYPORI   # Issue 100671 GA 12/2014

Case WVCRTYP   # Issue 100671 GA 12/2014
  When 36
     Filter [F:PNDW] Where PNHNUM=WPNHNUM & PNDLIN>WPNDLIN & LINTYP>2 & PTHNUM=[F:PND]PTHNUM & PTDLIN=[F:PND]PTDLIN
  When 10
     Filter [F:PNDW] Where PNHNUM=WPNHNUM & PNDLIN=WPNDLIN & PTHNUM=[F:PND]PTHNUM & PTDLIN=[F:PND]PTDLIN
Endcase

For [F:PNDW]PND0
   # FQ 54651 If [F:PNDW]ITMREFORI=WITMREF & [F:PNDW]LINTYP>2
   #If [F:PNDW]PTHNUM=[F:PND]PTHNUM & [F:PNDW]PTDLIN=[F:PND]PTDLIN & [F:PNDW]LINTYP>2
   #If [F:PNDW]PTHNUM=[F:PND]PTHNUM & [F:PNDW]PTDLIN=[F:PND]PTDLIN & [F:PNDW]LINTYP>2 # Issue 100671 GA 12/2014
   #Issue X3-51804 by GEBIL 19/09/17 : File nonexistent ITMREFORI - change by ITMREF
   #If [F:PNDW]ITMREFORI=WITMREF | [F:PTD]VCRTYPORI=10
   If [F:PNDW]ITMREF=WITMREF | [F:PTD]VCRTYPORI=10
   # On parcourt le Service et matières fournies par le sous-traitant
      WAMT +=[F:PNDW]LINAMT
   Else
   # Autre article commandé, on sort
      Break
   Endif
Next
If WCPRCUR<>WCUR & WCUR<>"" # Issue 101179 & 100967 GA 07/2014 amount in purchase currency
   LAMT =WAMT
   Local Integer WSTAT
   Call CONVERT2(WCUR,WCPRCUR,WCPRCUR,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                 WAMT,WAMT,WSTAT) From TRTDEV
   LAMTL=WAMT
Else
   LAMTL=WAMT
   LAMT=WAMT
Endif
Filter [F:PNDW]
Close File [F:PNDW]
End

#-----------------------------------------#
# Calcul du prix d'achat sous-traité      #
# [F:POQ] contient la ligne article lancé #
#-----------------------------------------#
Subprog CALC_PID_LINAMT(LAMT)
Variable Decimal LAMT

Local Decimal  WAMTL

Call CALC_PID_LINAMTL(LAMT,WAMTL)

End
#-----------------------------------------#
# Calcul du prix d'achat sous-traité      #
# [F:PID] contient la ligne article lancé #
#-----------------------------------------#
Subprog CALC_PID_LINAMTL(LAMT,LAMTL)
Variable Decimal LAMT
Variable Decimal LAMTL
Local Char     WITMREF(GLONITM) : WITMREF=[F:PID]ITMREF
Local Char     WPIHNUM(GLONVCR) : WPIHNUM=[F:PID]NUM
Local Integer  WPIDLIN          : WPIDLIN=[F:PID]PIDLIN
Local Decimal  WAMT,WAMTL       : Raz WAMT,WAMTL
Local Decimal  WPRI,WPRIL,WQTY  : Raz WPRI,WPRIL,WQTY

# Issue 101179 & 100967 GA 07/2014
Local Char     WCPRCUR(GLONCUR),WCUR(GLONCUR)
If [F:PIH]NUM<>WPIHNUM
   Read [F:PIH]PIH0=WPIHNUM : If fstat : Raz [F:PIH] : Endif
Endif
WCUR = [F:PIH]CUR
WCPRCUR = GLOCALDEV

Local File PINVOICED [F:PIDW]

# Issue 100671 GA 12/2014 WOF subcontracted operation
Local Char     WCRITPID(250)
Local Char     WVCRNUM(GLONVCR)
Local Integer  WVCRTYP

If [F:PID]PIHTYP>2
# Credit note on purchase invoice/return: read original invoice
  WCRITPID="INVNUM=[F:PID]NUM & INVLIN>[F:PID]PIDLIN"
  Read [F:PIDW]PID0=[F:PID]INVNUM;[F:PID]INVLIN : If fstat Raz [F:PIDW] Endif
Else
  [F:PIDW]=[F:PID]
  If [F:PIDW]POHNUM<>""
  # Invoice on purchase order
    WCRITPID="POHNUM=[F:PID]POHNUM & POPLIN>[F:PID]POPLIN"
  Elsif[F:PIDW]PTHNUM<>""
  # Invoice on purchase receipt
    WCRITPID="PTHNUM=[F:PID]PTHNUM & PTDLIN>[F:PID]PTDLIN"
  Endif
Endif
If [F:PIDW]POHNUM<>""
  If [F:POQ]POHNUM<>[F:PIDW]POHNUM
     Read [F:POQ]POQ0=[F:PIDW]POHNUM;[F:PIDW]POPLIN : If fstat Raz [F:POQ] Endif
  Endif
  WVCRNUM=[F:POQ]VCRNUMORI
  WVCRTYP=[F:POQ]VCRTYPORI
Elsif [F:PIDW]PTHNUM<>""
  If [F:PTD]PTHNUM<>[F:PIDW]PTHNUM
     Read [F:PTD]PTD0=[F:PIDW]PTHNUM;[F:PIDW]PTDLIN : If fstat Raz [F:PTD] Endif
  Endif
  WVCRNUM=[F:PTD]VCRNUMORI
  WVCRTYP=[F:PTD]VCRTYPORI
Else
  LAMT=0 : LAMTL=0
  Filter [F:PIDW]
  Close File [F:PIDW]
  End
Endif

Case WVCRTYP   # Issue 100671 GA 12/2014
  When 36
     Filter [F:PIDW] Where NUM=WPIHNUM & PIDLIN>WPIDLIN & LINTYP>2 & evalue(WCRITPID)
  When 10
     Filter [F:PIDW] Where NUM=WPIHNUM & PIDLIN=WPIDLIN & evalue(WCRITPID)
Endcase

For [F:PIDW]PID0
   #If [F:PIDW]ITMREFORI=WITMREF & [F:PIDW]LINTYP>2
   #If [F:PIDW]LINTYP>2                      # Issue 100671 GA 12/2014
   If [F:PIDW]LINTYP<>2 | WVCRTYP=10
   # On parcourt le Service et matières fournies par le sous-traitant
      WAMT += [F:PIDW]AMTNOTLIN
      # Issue 101179 GA 07/2014 need unit price in company currency
      If [F:PIDW]QTYSTU<>0
         WQTY=[F:PIDW]QTYSTU
      Elsif [F:PIDW]POHNUM<>""
         Read [F:POQW]POQ0=[F:PIDW]POHNUM;[F:PIDW]POPLIN;[F:PIDW]POQSEQ
         WQTY=[F:POQW]QTYSTU
      Elsif [F:PIDW]PTHNUM<>""
         Read [F:PTDW]PTD0=[F:PIDW]PTHNUM;[F:PIDW]PTDLIN
         WQTY=[F:PTDW]QTYSTU
      Else
         WQTY=1
      Endif
      # Issue 102605 GA 12/2014
      If WCPRCUR<>WCUR & WCUR<>"" # & WQTY<>0
         #WPRI=arr([F:PIDW]AMTNOTLIN / WQTY,10^-GDECPRI)
         #Call CONVERT_PIH(WPRI,WPRIL) From SBCLIB
         #WAMTL +=arr(WPRIL*WQTY,10^-GDECPRI)
         Call CONVERT_PIH(WAMT,WAMTL) From SBCLIB
      Else
         WAMTL=WAMT
      Endif
   Else
   # Autre article commandé, on sort
      Break
   Endif
Next

LAMT =WAMT
If [F:PID]CPR*[F:PID]QTYSTU<>0
   LAMTL=[F:PID]CPR*[F:PID]QTYSTU
Else
   LAMTL=WAMTL
Endif
Filter [F:PIDW]
Close File [F:PIDW]
End

#-----------------------------------------------------
# FQ 72083 GA 03/2011 ne pas renvoyer ce message si aucune matière mise à dispo du sous-traitant
# de plus, ce contrôle ne sera effectif que si on connait la réf d'OF ou d'EO, sinon pas de contrôle
#-----------------------------------------------------
$CTL_BPC   # Extrait de SUBPOH GA 03/2011
#If [F:ITM]SCSFLG=2
#  #----- Si article sous-traitance, vérif si client existe ! -----#
#  If [F:BPC]BPCNUM<>[M:POH0]BPSNUM
#    Read [BPC] BPC0=[M:POH0]BPSNUM : If fstat Raz [F:BPC] : Endif
#  Endif
#  If [F:BPC]BPCNUM=""
#    OK=2 : Call AVERTIR(mess(313,194,1),OK) From GESECRAN
#    If OK=1  Goto RETOURITMREF : Endif
#  Endif
#Endif
If dim([M]LINTYP(NOL))<=0 | [M]LINTYP(NOL)<=2 Return Endif
Case [M:SBCK]VCRTYPORI
  When 10 : Gosub CTL_BPC_OF
  When 36 : Gosub CTL_BPC_EO
Endcase
Return

#-----------------------------------------------------
# Cas d'un OF: on fait le ctrl si au moins une matière
#              mise à dispo du sous-traitant
#-----------------------------------------------------
# La ligne [F:MFG] est déjà chargée
#-----------------------------------------------------
$CTL_BPC_OF
Local Integer WMAT : WMAT=1
If [F:MFG]MATLINNBR>0
    For [MFM]MFM0 Where MFGNUM = [M:SBCK]VCRNUM & MATSTA<>4 & SCOFLG=2
       WMAT=2
       Break
    Next
Endif
If WMAT=2 Gosub EXIST_BPC Endif
Return

#-----------------------------------------------------
# Cas d'un EO: on fait le ctrl si au moins une matière
#              mise à dispo du sous-traitant
#-----------------------------------------------------
# La ligne [F:SCO] est déjà chargée
#-----------------------------------------------------
$CTL_BPC_EO
Local Integer WMAT : WMAT=1
If [F:SCO]MATLINNBR>0
    For [SCM]SCM0 Where SCONUM = [M:SBCK]VCRNUM & MATSTA<>4 & SCOFLG=2
       WMAT=2
       Break
    Next
Endif
If WMAT=2 Gosub EXIST_BPC Endif
Return

#----------------------------------------------------#
#----- Vérifier si client livré existe !        -----#
#----------------------------------------------------#
$EXIST_BPC
Local Char WBPRNUM (GLONBPR)
If     clalev([M:POH0])>0
   WBPRNUM = [M:POH0]BPSNUM
Elsif clalev([M:POI1])
   WBPRNUM = [M:POI1]BPSNUM(NOL)
Endif
If [F:BPC]BPCNUM<>WBPRNUM
  Read [BPC] BPC0=WBPRNUM : If fstat Raz [F:BPC] : Endif
Endif
If [F:BPC]BPCNUM=""
  Call AVERTIR(mess(313,194,1)-WBPRNUM,OK) From GESECRAN
Endif
Return

#-----------------------------------------------------
# Consommation des encours suite picking des besoins
#-----------------------------------------------------
# Lignes [F:PWO] et [F:POQ] sont chargées
#-----------------------------------------------------
# Issue 84764 & 84500 GA consommation encours EOF/SCF - Extrait de SUBPOHB
$EXPLOITE_PWO
# Rien à faire ici:
# les encours EOF/SCF sont mis à jour par l'appel à MAJ_SBC (dans CRELIG de SUBPOHA)
Return

$CTLORD
# ----------------------------------------------------
# Issue 86425 GA 12/2012 Supplier code is mandatory
# ----------------------------------------------------
If [F:ORD]BPRNUM=""
   # Issue X3-55891 - 2018-09-17 by MUARN : exploitation table article/fournisseur/site
   # peut-on proposer un fournisseur par défaut ?
   #Call FIND_BPRNUM ([F:ORD]ITMREF,[F:ORD]BOMALT,[F:ORD]BPRNUM) From SCOLIB
   Call FIND_BPRNUM ([F:ORD]ITMREF,[F:ORD]BOMALT,[F:ORD]STOFCY,[F:ORD]STOFCY,[F:ORD]BPRNUM) From SCOLIB
Endif
If [F:ORD]BPRNUM="" & [F:ORD]VCRTYP=36
   # Pas de fournisseur pour cet article.
   GMESSAGE=mess(11,194,1)-[F:PWO]ITMREF
   WRET=2 : Return
Endif
# ----------------------------------------------------
# Issue 86433 GA 12/2012 Bom alternative is mandatory
# ----------------------------------------------------
If [F:ORD]BOMALT=0 & [F:ORD]VCRTYP=36
   Local Integer WBOMALT
   # peut-on proposer une alternative par défaut ?
   Call FIND_BOMALT ([F:ORD]ITMREF,[F:ORD]BPRNUM,WBOMALT) From SCOLIB
    [F:ORD]BOMALT=WBOMALT
Endif
If [F:ORD]BOMALT=0 & [F:ORD]VCRTYP=36
   # Aucune alternative de nomenclature trouvée
   GMESSAGE=mess(130,197,1)
   WRET=2 : Return
Endif
If find([F:ORD]WIPSTA,1,2) & [F:ORD]VCRTYP=36
# ----------------------------------------------------
# EO status and orders must be clean
# ----------------------------------------------------
   If !clalev([F:SCOW]) :Local File SCOHEAD [SCOW] Endif
   If !clalev([F:ORDW]) :Local File ORDERS  [ORDW] Endif
   Local Shortint TROUVE : TROUVE=0
   Read [SCOW]SCO0=[F:ORD]VCRNUM
   If fstat | [F:SCOW]SCOSTA<>[F:ORD]WIPSTA
      WRET=3 : Return
   Endif
   Case [F:ORD]WIPTYP
     When 13 : # EOF Seek corresponding SCF
        For [ORDW] Where WIPTYP=4 & VCRTYP=[F:ORD]VCRTYP & VCRNUM=[F:ORD]VCRNUM & VCRLIN=[F:ORD]VCRLIN
            TROUVE=1 : Break
        Next
     When 4  : # SCF Seek corresponding EOF
        For [ORDW] Where WIPTYP=13 & VCRTYP=[F:ORD]VCRTYP & VCRNUM=[F:ORD]VCRNUM & VCRLIN=[F:ORD]VCRLIN
            TROUVE=1 : Break
        Next
   Endcase
   If !TROUVE : WRET=3 : Return : Endif

   If GBUYFLT=2  # Suite Issue 87637 GA 09/2013 control buyer
     TROUVE=0
     If !clalev([F:SCIW]) :Local File SCOITM  [SCIW] Endif
     If !clalev([F:SCSW]) :Local File SCOSRV  [SCSW] Endif
     Read [SCIW]SCI0=[F:ORD]VCRNUM;[F:ORD]VCRLIN
     If fstat Raz [F:SCIW] Endif
     If [F:ORD]VCRSEQ>0
        Read [SCSW]SCS0=[F:ORD]VCRNUM;[F:ORD]VCRLIN;[F:ORD]VCRSEQ
        If fstat Raz [F:SCSW] Endif
     Else
        Read [SCSW]SCS0(2)=[F:ORD]VCRNUM;[F:ORD]VCRLIN
        If fstat Raz [F:SCSW] Endif
     Endif
     # Issue 93367 GA 10/2013 pb avec WRET, mauvais type de paramètre
     Local Shortint WSTAT : Raz WSTAT
     Call CTLITMBUY([F:SCIW]ITMREF,GUSER,WSTAT) From TRTACHCTL1
     If WSTAT : Return : Endif
     Call CTLITMBUY([F:SCSW]SRVITMREF,GUSER,WSTAT) From TRTACHCTL1
     If WSTAT : Return : Endif
   Endif
Endif
Return

# --------------------------------------------------------------------------
# Issue 87637 GA 02/2013 Code acheteur de l'article sous-traité si GFLTBUY=2
# --------------------------------------------------------------------------
$CTL_BUY_EO
  If GBUYFLT<2 | dim([M]LINTYP(NOL))<0 Return Endif
  If !clalev([F:ITMW]) Local File ITMMASTER  [ITMW] Endif
  If !clalev([F:ITFW]) Local File ITMFACILIT [ITFW] Endif
  Raz [F:ITMW] :  Raz [F:ITFW]
  # Suite Issue 87637 GA 09/2013
  Case [M]LINTYP(NOL)
    When 2  :  # Subcontracted item
      If [F:ITMW]ITMREF<>[F:SCI]ITMREF
        Read [F:ITMW]ITM0=[F:SCI]ITMREF : If fstat Raz [F:ITMW] : Endif
      Endif
      If [F:ITFW]ITMREF<>[F:SCI]ITMREF | [F:ITFW]STOFCY<>[F:SCI]PRHFCY
        Read [F:ITFW]ITF0=[F:SCI]ITMREF;[F:SCI]PRHFCY : If fstat Raz [F:ITFW] : Endif
      Endif
    When 3  :  # Service
      If [F:ITMW]ITMREF<>[F:SCS]SRVITMREF
        Read [F:ITMW]ITM0=[F:SCS]SRVITMREF : If fstat Raz [F:ITMW] : Endif
      Endif
      If [F:ITFW]ITMREF<>[F:SCS]SRVITMREF | [F:ITFW]STOFCY<>[F:SCS]PRHFCY
        Read [F:ITFW]ITF0=[F:SCS]SRVITMREF;[F:SCS]PRHFCY : If fstat Raz [F:ITFW] : Endif
      Endif
    When 4  :  # Composant
      If [F:ITMW]ITMREF<>[F:SCM]CPNITMREF
        Read [F:ITMW]ITM0=[F:SCM]CPNITMREF : If fstat Raz [F:ITMW] : Endif
      Endif
      If [F:ITFW]ITMREF<>[F:SCM]CPNITMREF | [F:ITFW]STOFCY<>[F:SCM]STOFCY
        Read [F:ITFW]ITF0=[F:SCM]CPNITMREF;[F:SCS]PRHFCY : If fstat Raz [F:ITFW] : Endif
      Endif
  Endcase
  If dim([M]LINBUY(NOL))>0 & [M]LINBUY(NOL)=""
    If [F:ITMW]BUY<>"" [M]LINBUY(NOL)=[F:ITMW]BUY : Endif
    If [F:ITFW]BUY<>"" [M]LINBUY(NOL)=[F:ITFW]BUY : Endif
  Endif
  If [M]LINBUY(NOL)<>"" & [M]LINBUY(NOL)<>GUSER
    GOK=0   # Suite Issue 87637 GA 09/2013
    # Issue 112057 - 2015-10-28 by MUARN : positionner GMESSAGE et WMSG
    GMESSAGE = [M]ITMREF(NOL) - " : " - mess(27,194,1)
    WMSG = GMESSAGE
  Endif
Return

# --------------------------------------------------------------------------
# Issue 88261 GA 03/2013
# --------------------------------------------------------------------------
$CTL_RCPDAT_EO
If [M]EXTRCPDAT(NOL)<>[0/0/0]
   [M]RETRCPDAT(NOL)=[M]EXTRCPDAT(NOL)
Elsif WRCPDAT<>[0/0/0]
   [M]RETRCPDAT(NOL)=WRCPDAT
Else
   [M]RETRCPDAT(NOL)=[F:SCS]OPEEND
Endif
Return
$CTL_RCPDAT_OF
If [M]EXTRCPDAT(NOL)<>[0/0/0]
   [M]RETRCPDAT(NOL)=[M]EXTRCPDAT(NOL)
Elsif WRCPDAT<>[0/0/0]
   [M]RETRCPDAT(NOL)=WRCPDAT
Else
   [M]RETRCPDAT(NOL)=[F:MFO]OPEEND
Endif
Return

######################################################################################
$CHECK_ECCVALMAJ                    # Issue 107513 by GA 08/2015: keep EO BOM version
If [M:POH2]VCRTYPORI(nolign-1)=36 & [M:POH2]LINTYP(nolign-1)=2
   VALEUR=[M:POH2]ECCVALMAJ(nolign-1)
   GMESSAGE=func AFNC.MES1 (mess(643,199,1),mess([M:POH2]VCRTYPORI(nolign-1),701,1)-[M:POH2]VCRNUMORI(nolign-1))
   mkstat=2
Endif
Return
######################################################################################
$CHECK_ECCVALMIN                    # Issue 107513 by GA 08/2015: keep EO BOM version
If [M:POH2]VCRTYPORI(nolign-1)=36 & [M:POH2]LINTYP(nolign-1)=2
   VALEUR=[M:POH2]ECCVALMIN(nolign-1)
   GMESSAGE=func AFNC.MES1 (mess(643,199,1),mess([M:POH2]VCRTYPORI(nolign-1),701,1)-[M:POH2]VCRNUMORI(nolign-1))
   mkstat=2
Endif
Return


######################################################################################
  # Issue 117494 - 2016-07-12 by SR : Rechargement des valeurs par défaut perdues après CHARG_LIS_SCS
$INIT_ACCCCE
Local Integer WI
Case WTRAIT
  When "SUBPOHB" :
    #----- Initialisation des comptes et du type d'achat -----#
    If [M:POH2]LINACC1(NOL)="" & [M:POH2]LINACC2(NOL)="" & [M:POH2]LINACC3(NOL)=""
       Call INIT_COMPTES_LIGNE(NOL) From SUBPOHB
    Endif
    #----- Initialisation sections analytiques si nécessaire -----#
    If GNBDIE>0
      For WI=1 To GNBDIE
        If evalue("[M:POH2]CCE"+num$(WI)+"(NOL)")=""
          Call INIT_CCE(SECTION,WI,"POP","[M:POH2]LINACC",NOL) From TRTX3CPT
          Assign "[M:POH2]CCE"+num$(WI)+"(NOL)" With SECTION
        Endif
      Next WI
    Endif
  When "SUBPOIA" :
     #----- Initialisation des comptes et du type d'achat -----#
    If [M:POI1]LINACC1(NOL)="" & [M:POI1]LINACC2(NOL)="" & [M:POI1]LINACC3(NOL)=""
      Call INIT_COMPTES_LIGNE(NOL) From SUBPOI
    Endif
    #----- Initialisation sections analytiques si nécessaire -----#
    If GNBDIE>0
      #----- Lecture ligne commande vente contremarque à cause de l'INISEC "POID" -----#
      If GMODU(5)=2 & [M:POI1]SOHNUM(NOL)<>""
        If [F:SOP]SOHNUM<>[M:POI1]SOHNUM(NOL) |
&          [F:SOP]SOPLIN<>[M:POI1]SOPLIN(NOL) |
&          [F:SOP]SOPSEQ<>[M:POI1]SOQSEQ(NOL)
           Read [SOP] SOP0=[M:POI1]SOHNUM(NOL);[M:POI1]SOPLIN(NOL);[M:POI1]SOQSEQ(NOL)
           If fstat  Raz [F:SOP] : Endif
        Endif
      Elsif GMODU(5)=2
        Raz [F:SOP]
      Endif
      #----- Lecture de l'opération si sous-traitance à cause de l'INISEC "POID" -----#
      If clalev([F:MFO]) & GMODU(8)=2 & find([M:POI1]LINTYP(NOL),1,3)
        If [M:POI1]VCRTYPORI(NOL)=10
          If [F:MFO]MFGNUM   <>[M:POI1]VCRNUMORI(NOL) |
&            [F:MFO]OPENUM   <>[M:POI1]VCRLINORI(NOL) |
&            [F:MFO]OPESPLNUM<>[M:POI1]VCRSEQORI(NOL)
             Read [MFO] MFO0=[M:POI1]VCRNUMORI(NOL);[M:POI1]VCRLINORI(NOL);[M:POI1]VCRSEQORI(NOL)
             If fstat  Raz [F:MFO] : Endif
          Endif
        Else
          Raz [F:MFO]
        Endif
      Endif
      #----- Lecture de l'article sous-traité si sous-traitance à cause de l'INISEC "POID" -----#
      If clalev([F:SCI]) & [M:POI1]LINTYP(NOL)=2
        If [M:POI1]VCRTYPORI(NOL)=36
          If [F:SCI]SCONUM <>[M:POI1]VCRNUMORI(NOL) |
&            [F:SCI]SCILIN <>[M:POI1]VCRLINORI(NOL)
             Read [SCI] SCI0=[M:POI1]VCRNUMORI(NOL);[M:POI1]VCRLINORI(NOL)
             If fstat  Raz [F:SCI] : Endif
          Endif
        Endif
      Endif
      #----- Lecture de l'opération si sous-traitance à cause de l'INISEC "POID" -----#
      If clalev([F:SCS]) & [M:POI1]LINTYP(NOL)=3
        If [M:POI1]VCRTYPORI(NOL)=36
          If [F:SCS]SCONUM <>[M:POI1]VCRNUMORI(NOL) |
&            [F:SCS]SCILIN <>[M:POI1]VCRLINORI(NOL) |
&            [F:SCS]SCSLIN <>[M:POI1]VCRSEQORI(NOL)
             Read [SCS] SCS0=[M:POI1]VCRNUMORI(NOL);[M:POI1]VCRLINORI(NOL);[M:POI1]VCRSEQORI(NOL)
             If fstat  Raz [F:SCS] : Endif
          Endif
         Endif
      Endif
      #----- Lecture du composant si sous-traitance à cause de l'INISEC "POID" -----#
      If clalev([F:SCM]) & [M:POI1]LINTYP(NOL)=4
        If [M:POI1]VCRTYPORI(NOL)=36
          If [F:SCM]SCONUM <>[M:POI1]VCRNUMORI(NOL) |
&            [F:SCM]SCILIN <>[M:POI1]VCRLINORI(NOL) |
&            [F:SCM]SCMLIN <>[M:POI1]VCRSEQORI(NOL)
             Read [SCM] SCM0=[M:POI1]VCRNUMORI(NOL);[M:POI1]VCRLINORI(NOL);[M:POI1]VCRSEQORI(NOL)
             If fstat  Raz [F:SCM] : Endif
          Endif
        Else
          Raz [F:SCM]
        Endif
      Endif
      #-----
      For WI=1 To GNBDIE
        If evalue("[M:POI1]CCE"+num$(WI)+"(NOL)")=""
          Call INIT_CCE(SECTION,WI,"POID","[M:POI1]LINACC",NOL) From TRTX3CPT
          Assign "[M:POI1]CCE"+num$(WI)+"(NOL)" With SECTION
        Endif
      Next WI
    Endif
  Endcase
Return
# End issue 117494

