#<AdxTL>@(#)0.0.0.0 $Revision$
# Representation CCMIMPSCH - Sub contract orders Impact Analysis 'header'

$METHODS
  Case CURPTH
    When ""
      Case ACTION
        When "AREAD_AFTER"
          Gosub GET_CHANGE_REQUEST_DETAILS
          Gosub IS_IMPACT_AVAILABLE
          Gosub DISABLE_LINK
      Endcase
  Endcase
Return

# --------------------------------------------------
# Get Change Request data - populate representation-only properties ...
$GET_CHANGE_REQUEST_DETAILS
  Local Instance SELCHGREQ Using C_CCMCHGREQ
  SELCHGREQ = NewInstance C_CCMCHGREQ AllocGroup null
  ASTATUS = fmet SELCHGREQ.AREAD(this.CCMSCH.CRID)
  If (ASTATUS <> CST_AOK)
    ASTATUS = fmet  this.ASETERROR ("", "", [V]CST_AERROR)
  Else
    this.PRODUCT     = SELCHGREQ.PRODUCT
    this.ECCVALMAJ   = SELCHGREQ.ECCVALMAJ
    this.ECCVALMIN   = SELCHGREQ.ECCVALMIN
    this.CRSTATUS    = SELCHGREQ.CRSTATUS
    this.CCMUSRID    = SELCHGREQ.CCMUSRID
  Endif
  FreeGroup SELCHGREQ
Return

# ------------------------------------------------------
# Subroutine: DISABLE_LINK
#
# Called from this Script.
# Disable Update link if not allowed to update
#
$DISABLE_LINK

  Local Integer LOCSTATUS
  If (this.CCMSCH.IMPACTANAL <> 1 and this.CRSTATUS = 2 and this.CCMUSRID = this.ACTX.USER)
    LOCSTATUS = fmet this.ASETLINKENABLE("UPDATE",[V]CST_AFFLNKREC)
  Else
    LOCSTATUS = fmet this.ASETLINKDISABLE("UPDATE",[V]CST_AFFLNKREC)
  Endif

Return

# ------------------------------------------------------
# Subroutine: IS_IMPACT_AVAILABLE
#
# Called from this Script.
# Is Impact Analysis available?
#
$IS_IMPACT_AVAILABLE

  Local Integer LOCSTATUS
  If (this.CCMSCH.IMPACTANAL = 0)
    LOCSTATUS = fmet this.ASETERROR("", mess(69,2038,1), CST_AWARNING)
  Elsif (this.CCMSCH.IMPACTANAL = 1)
    LOCSTATUS = fmet this.ASETERROR("", mess(68,2038,1), CST_AWARNING)
  Endif

Return

$PROPERTIES
  Case [L]CURPRO
  Endcase
Return


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

