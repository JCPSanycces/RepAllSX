######################################################################################
## Etiquette ajout├®e par le superviseur (├®cran AWSDL0) 05/04/2006 14:28:34 (CCORA)
######################################################################################
Subprog C_ABRWSDL(VALEUR)
Variable Char    VALEUR()
# V├®rifie que l'abr├®viation est unique
If clalev([F:AXL])=0 : Local File AWSDL [AXL] : Endif
Filter [AXL] Where ABRWSDL=VALEUR
For [AXL]
  If [F:AXL]CWSDL<>[M]CWSDL
    GMESSAGE=mess(32,100,1)-[F:AXL]CWSDL
    mkstat=2
    Break 1
  Endif
Next
Filter [AXL]

End


