#<AdxTL>@(#)6.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
Raz GPILOBJ
Call OBJET("AXL",GBIDC1,GBIDC2) From GOBJET
End

#  Syntaxe instruction Web services
#"callws url action Using 3 masques (entete,parametres in, retour) et eventuellement user : mopass @ proxy"


# Gestion du masque AWSDL0


######################################################################################
## Etiquette ajout├®e par le superviseur (├®cran AWSDL0) 19/12/2005 14:46:15 (CCORA)
######################################################################################
$ACTION
Case ACTION
 When "LIENS"   : Gosub LIENS
 When "SETBOUT"  : Gosub SETBOUT
 When "VERIF_CRE","VERIF_MOD"  : Gosub MAJZONE
 When "EXEBOUT" : Gosub EXEBOUT
 When default
Endcase
Return

$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"ab") From GOBJET
Endif
Return

$EXEBOUT
If REP="a"
# V├®rifie que tous les noms, format, .. sont renseign├®s sinon cr├®ation automatique
  Local Integer I,ERR
  For I=0 To [M:AWL5]NBMT-1
    Case [M:AWL5]ADELT(I)
      When 1 : If [M:AWL5]ADMSK(I)="" or [M:AWL5]ADABR(I)="" : ERR=1 : Break 1 : Endif 
      When 2 : If [M:AWL5]ADNAM(I)="" or [M:AWL5]ADFORM(I)="" or [M:AWL5]ADLON(I)=0 : ERR=1 : Break 1 : Endif  
      When 3 : # Rien ├Ā saisir pour les blocs
      When 4 : If [M:AWL5]ADCONT(I)="" or [M:AWL5]ADDIM(I)=0 : ERR=1 : Break 1 : Endif 
    Endcase
  Next I
  If ERR=1
# Donn├®es incompl├©tes ligne
    Call ERREUR(mess(230,123,1)-num$(I+1)) From GESECRAN
    Return
  Endif
# Cr├®e les masques et les compile
  Call CREMSK(OK)
Endif
If REP="b" : Gosub DELWS : Endif
Return




$DELWS
Local Integer OKO
Local Char NOMFC(200)
# Confirmez vous la suppression ?
Call OUINON(mess(123,105,1),OKO) From GESECRAN
If OKO<>2 : Return : Endif
If clalev([F:AX1])=0 : Local File AWSDL1 [AX1] : Endif
If clalev([F:AXL])=0 : Local File AWSDL  [AXL] : Endif
Delete [AX1] Where CWSDL=[M:AWL0]CWSDL
Delete [AXL] Where CWSDL=[M:AWL0]CWSDL
#  Supprime les masques dans le r├®pertoire ECR sur disque
For I=0 To [M:AWL5]NBMT-1
  If [M:AWL5]ADELT(I)=1 and [M:AWL5]ADMSK(I)<>""
    NOMFC=filpath("ECR","W_"+[M:AWL5]ADMSK(I),"*")
    Call EFFACE(NOMFC,OKO) From ORDSYS
  Endif
Next I
Gosub RELIT From GOBJSUB
Return

$MAJZONE
#  [F:AX1]TWSDL   = "W" pour le source WSDL
#                 = "D" pour les donn├®es
#                 = "M" pour les messages
#                 = "S" pour les services
#                 = "T" pour les masques
Delete [AX1] Where CWSDL=[M:AWL0]CWSDL

#  Ecriture WSDL
Raz [F:AX1]
[F:AX1]CWSDL=[M:AWL0]CWSDL
[F:AX1]TWSDL="W"
For I=1 To [M:AWL2]NBWS
  [F:AX1]NWSDL=I
  [F:AX1]VWSDL=[M:AWL2]LIG(I-1)
  Write [F:AX1]
Next I

# Ecriture donn├®es
Raz [F:AX1]
[F:AX1]CWSDL=[M:AWL0]CWSDL
[F:AX1]TWSDL="D"
For I=1 To [M:AWL1]NBLIG
  [F:AX1]NWSDL=I
  [F:AX1]NOMAF=[M:AWL1]NOMAF(I-1)
  [F:AX1]NOM=[M:AWL1]NOM(I-1)
  [F:AX1]NIV=[M:AWL1]NIV(I-1)
  [F:AX1]TYP=[M:AWL1]TYP(I-1)
  [F:AX1]LON=[M:AWL1]LON(I-1)
  Write [F:AX1]
Next I

# Ecriture messages
Raz [F:AX1]
[F:AX1]CWSDL=[M:AWL0]CWSDL
[F:AX1]TWSDL="M"
For I=1 To [M:AWL4]NBMES
  [F:AX1]NWSDL=I
  [F:AX1]NAMMES=[M:AWL4]NAMMES(I-1)
  [F:AX1]PARTMES=[M:AWL4]PARTMES(I-1)
  [F:AX1]ELTMES=[M:AWL4]ELTMES(I-1)
  Write [F:AX1]
Next I

# Ecriture services
Raz [F:AX1]
[F:AX1]CWSDL=[M:AWL0]CWSDL
[F:AX1]TWSDL="S"
For I=1 To [M:AWL4]NBSERV
  [F:AX1]NWSDL=I
  [F:AX1]NAMSERV=[M:AWL4]NAMSERV(I-1)
  [F:AX1]OPERSERV=[M:AWL4]OPERSERV(I-1)
  [F:AX1]TYPSERV=[M:AWL4]TYPSERV(I-1)
  [F:AX1]MESSERV=[M:AWL4]MESSERV(I-1)
  Write [F:AX1]
Next I

# Ecriture masques
Raz [F:AX1]
[F:AX1]CWSDL=[M:AWL0]CWSDL
[F:AX1]TWSDL="T"
For I=1 To [M:AWL5]NBMT
  [F:AX1]NWSDL=I
  [F:AX1]NAMMES=[M:AWL5]LELT(I-1)
  [F:AX1]LNIV=[M:AWL5]LNIV(I-1)
  [F:AX1]PARTMES=[M:AWL5]NOMW(I-1)
  [F:AX1]ADELT=[M:AWL5]ADELT(I-1)
  [F:AX1]ADMSK=[M:AWL5]ADMSK(I-1)
  [F:AX1]ADABR=[M:AWL5]ADABR(I-1)
  [F:AX1]ADDIM=[M:AWL5]ADDIM(I-1)
  [F:AX1]ADCONT=[M:AWL5]ADCONT(I-1)
  [F:AX1]ADNAM=[M:AWL5]ADNAM(I-1)
  [F:AX1]ADTYP=[M:AWL5]ADTYP(I-1)
  [F:AX1]ADLON=[M:AWL5]ADLON(I-1)
  [F:AX1]ADFORM=[M:AWL5]ADFORM(I-1)
  Write [F:AX1]
Next I



Return

$LIENS
Local Char SWSDL(150)(1..2000)
Local Integer IWSDL,IZON,IMES,ISERV,INBMT,OK
Filter [AX1] Where CWSDL=[M:AWL0]CWSDL
For [AX1]
  Case [F:AX1]TWSDL
    When "W"
        IWSDL+=1
        [M:AWL2]LIG(IWSDL-1)=[F:AX1]VWSDL
        SWSDL(IWSDL)=[F:AX1]VWSDL
    When "D"
        IZON+=1
        [F:AX1]NWSDL=I
        [M:AWL1]NOMAF(IZON-1)=[F:AX1]NOMAF
        [M:AWL1]NOM(IZON-1)=[F:AX1]NOM
        [M:AWL1]NIV(IZON-1)=[F:AX1]NIV
        [M:AWL1]TYP(IZON-1)=[F:AX1]TYP
        [M:AWL1]LON(IZON-1)=[F:AX1]LON
    When "M"
        IMES+=1
        [M:AWL4]NAMMES(IMES-1)=[F:AX1]NAMMES
        [M:AWL4]PARTMES(IMES-1)=[F:AX1]PARTMES
        [M:AWL4]ELTMES(IMES-1)=[F:AX1]ELTMES
    When "S"
        ISERV+=1
        [M:AWL4]NAMSERV(ISERV-1)=[F:AX1]NAMSERV
        [M:AWL4]OPERSERV(ISERV-1)=[F:AX1]OPERSERV
        [M:AWL4]TYPSERV(ISERV-1)=[F:AX1]TYPSERV
        [M:AWL4]MESSERV(ISERV-1)=[F:AX1]MESSERV
    When "T"
        INBMT+=1
        [M:AWL5]LELT(INBMT-1)=[F:AX1]NAMMES
        [M:AWL5]LNIV(INBMT-1)=[F:AX1]LNIV
        [M:AWL5]NOMW(INBMT-1)=[F:AX1]PARTMES
        [M:AWL5]ADELT(INBMT-1)=[F:AX1]ADELT
        [M:AWL5]ADMSK(INBMT-1)=[F:AX1]ADMSK
        [M:AWL5]ADABR(INBMT-1)=[F:AX1]ADABR
        [M:AWL5]ADDIM(INBMT-1)=[F:AX1]ADDIM
        [M:AWL5]ADCONT(INBMT-1)=[F:AX1]ADCONT
        [M:AWL5]ADNAM(INBMT-1)=[F:AX1]ADNAM
        [M:AWL5]ADTYP(INBMT-1)=[F:AX1]ADTYP
        [M:AWL5]ADLON(INBMT-1)=[F:AX1]ADLON
        [M:AWL5]ADFORM(INBMT-1)=[F:AX1]ADFORM
 Endcase
Next 

$SUIT1:
Filter [AX1]
[M:AWL2]NBWS=IWSDL
[M:AWL1]NBLIG=IZON
[M:AWL4]NBMES=IMES
[M:AWL4]NBSERV=ISERV
[M:AWL5]NBMT=INBMT
#Call READWSDL(SWSDL,IWSDL,OK)
Affzo [M:AWL1]
Affzo [M:AWL4]
Affzo [M:AWL2]
Affzo [M:AWL5]
#Call CREMWSDL(OK)
Return


Subprog CL_IWSDL(VALEUR)
Variable Char    VALEUR()
Local Char NAMEF(200),NAMEF1(100),EXT1(100)
Local Integer OK,I1

#   On importe un fichier local au poste de travail
#   en le transf├®rant sur le r├®pertoire tmp du serveur

Local Integer I,J,K,L
Local Char RETOUR (250)
Askui RETOUR = ""  With   "UIAsk=" + chr$(1) + "AskPutFile",
& "UILocalFileName=" + chr$(1) + "",
& "UILocalFileExts=" + chr$(1) + "wsdl",
& "UILocalPath=" + chr$(1) + "C:\",
& "UIRemoteFileName=" + chr$(1) + "",  
& "UIRemotePath=" + chr$(1) + "tmp,,,"+nomap,
& "UIRemoteOverWrite=" + chr$(1) + "1"

If left$(RETOUR,1)<>"1" : Infbox(mess(393,9137,1)) : End : Endif
I=instr(1,RETOUR,",")
J=instr(I+1,RETOUR,",")
K=instr(J+1,RETOUR,",")
L=instr(K+1,RETOUR,",")
NAMEF1=mid$(RETOUR,J+1,K-J-1)
EXT1=mid$(RETOUR,K+1,L-K-1)
NAMEF=filpath("tmp",NAMEF1,EXT1)
Openi NAMEF,0 Using [BLF1]
If fstat<>0 : Goto WSDLINEX : Endif
Iomode adxifs ""  Using [BLF1]
Iomode adxirs chr$(10)  Using [BLF1]
Iomode adxium GUTF8  Using [BLF1]
Local Char SWSDL(150)(1..2000)
Local Integer IWSDL
While fstat=0
  IWSDL+=1
  Rdseq SWSDL(IWSDL)  Using [BLF1]
  If len(SWSDL(IWSDL))=0 : IWSDL-=1 : Goto SUITCLIL : Endif
  For I1=1 To len(SWSDL(IWSDL))
    If ascii(mid$(SWSDL(IWSDL),I1,1))<20
      If I1>1 
        SWSDL(IWSDL)=left$(SWSDL(IWSDL),I1-1)+" "+right$(SWSDL(IWSDL),I1+1)
      Else
        SWSDL(IWSDL)=" "+right$(SWSDL(IWSDL),I1+1)
      Endif
    Endif
  Next I1
  [M:AWL2]LIG(IWSDL-1)=SWSDL(IWSDL)
$SUITCLIL
Wend
Openi Using [BLF1]
[M:AWL2]NBWS=IWSDL
[M:AWL0]NAMWSDL=NAMEF1+"."+EXT1
Call READWSDL(SWSDL,IWSDL,OK)
Affzo [M:AWL1]
Affzo [M:AWL4]
Affzo [M:AWL2]
Affzo [M:AWL0]NAMWSDL
Call CREMWSDL(OK)
mkstat=4
End

$WSDLINEX
  GMESSAGE=mess(101,100,1)-NAMEF
  mkstat=2
End

######################################################################################


Subprog READWSDL(STWSDL,IWSDL,OK)
Value Char STWSDL()(1..)
Value Integer IWSDL
Variable Integer OK

#NAME="Getnexttour.wsdl"
#NAME="SPROG.wsdl"
#NAME="testdenis.wsdl"

Effzo [M:AWL1]
Effzo [M:AWL4]

Local Char NOMFIC(200),VALL1(200)
Local Char REF(100)
Local Char NELT(100)(1..300),TELT(30)(1..300)
Local Integer NIVELT(1..300),LELT(1..300),COMPLEX(1..20)
Local Integer NBELT,I,J,K,K1,L,A1,A2,A3,TAGFERM,NIVCOU
Local Integer DEBS,FINS

For I=1 To IWSDL
  VALL1=toupper(vireblc(STWSDL(I),2))
  Gosub ANLTAGFERM
  J=instr(1,VALL1,"DEFINITIONS ")
  If J<>0 and DEBS=0 
    DEBS=I 
    Gosub RECHFINS
  Endif 
  J=instr(1,VALL1,"TYPES>")
  If J<>0 and TAGFERM=1
    Break 1
  Endif
  J=instr(1,VALL1,"ELEMENT") 
  If J>0 and find(mid$(VALL1,J+7,1)," ",">")
    If TAGFERM<>1  
      REF=left$(VALL1,J+6)
      Gosub NEWELEMENT 
      If TAGFERM=2 : NIVCOU-=1 : Endif
    Else
      NIVCOU-=1
    Endif
  Endif
  If instr(1,VALL1,"COMPLEXTYPE")<>0
    If TAGFERM=1       : # Si TAGFERM=2 on ne fait rien
      Gosub ENDCOMPL   
    Elsif TAGFERM=0
      Gosub NEWCOMPL 
    Endif
  Endif
Next I

#  Recherche des messages et des ports
#For J=I+1 To IWSDL
For J=1 To IWSDL
  VALL1=toupper(vireblc(STWSDL(J),2))
  Gosub ANLTAGFERM
  I=instr(1,VALL1,"MESSAGE ") 
  If I>0 and TAGFERM<>1
    Gosub NEWMESSAGE
  Endif
  I=instr(1,VALL1,"PORTTYPE ") 
  If I>0 and TAGFERM<>1
    Gosub NEWPORT
  Endif
Next J


#Call OUVRE_TRACE("Liste des ├®l├®ments ") From LECFIC
For J=1 To NBELT
 [M:AWL1]NOM(J-1)=NELT(J)
 Case NIVELT(J)
   When 0,1 : [M:AWL1]NOMAF(J-1)=NELT(J)
   When 2   : [M:AWL1]NOMAF(J-1)="..."+NELT(J)
   When Default[M:AWL1]NOMAF(J-1)="......"+NELT(J)
 Endcase
  
 [M:AWL1]NIV(J-1)=NIVELT(J)
 [M:AWL1]TYP(J-1)=TELT(J)
 [M:AWL1]LON(J-1)=LELT(J)
 #Call ECR_TRACE(NELT(J)-" :: "-TELT(J)-" : "-num$(LELT(J))-" : "-num$(NIVELT(J)),0) From GESECRAN
Next J

[M:AWL1]NBLIG=NBELT
Setlob [M:AWL2]WSDLDEF With STWSDL(DEBS..FINS)
#Call FERME_TRACE From LECFIC
#Call LEC_TRACE From LECFIC
    
#Openo WE_NOMFIC,0 Using [HTO_]
End



$ANLTAGFERM
  If instr(1,VALL1,"</")<>0
    TAGFERM=1 
  Elsif instr(1,VALL1,"/>")<>0
    TAGFERM=2
  Else
    TAGFERM=0 
  Endif
Return

$NEWMESSAGE
  K1=instr(1,toupper(STWSDL(J)),'NAME="')
  K=instr(K1+6,STWSDL(J),'"')
  [M:AWL4]NBMES+=1
  [M:AWL4]NAMMES([M:AWL4]NBMES-1)=mid$(STWSDL(J),K1+6,K-K1-6)
  For K2=J+1 To IWSDL
    VALL1=toupper(vireblc(STWSDL(K2),2))
    Gosub ANLTAGFERM
    I=instr(1,VALL1,"MESSAGE") 
    If I>0 and TAGFERM=1 : Break 1 : Endif
    I=instr(1,VALL1,"PART ") 
    If I>0 : Gosub NEWPART : Endif
  Next K2   
Return

$NEWPART
  K1=instr(1,toupper(STWSDL(K2)),'NAME="')
  K=instr(K1+6,STWSDL(K2),'"')
  [M:AWL4]NBMES+=1
  [M:AWL4]PARTMES([M:AWL4]NBMES-1)=mid$(STWSDL(K2),K1+6,K-K1-6)
  K1=instr(1,toupper(STWSDL(K2)),'TYPE="')
  If K1>0
    K=instr(K1+6,STWSDL(K2),'"')
    [M:AWL4]ELTMES([M:AWL4]NBMES-1)=mid$(STWSDL(K2),K1+6,K-K1-6)
    K3=instr(1,[M:AWL4]ELTMES([M:AWL4]NBMES-1),':')
    If K3>0
      [M:AWL4]ELTMES([M:AWL4]NBMES-1)=right$([M:AWL4]ELTMES([M:AWL4]NBMES-1),K3+1)
    Endif
  Endif
  K1=instr(1,toupper(STWSDL(K2)),'ELEMENT="')
  If K1>0
    K=instr(K1+9,STWSDL(K2),'"')
    [M:AWL4]ELTMES([M:AWL4]NBMES-1)=mid$(STWSDL(K2),K1+9,K-K1-9)
    K3=instr(1,[M:AWL4]ELTMES([M:AWL4]NBMES-1),':')
    If K3>0
      [M:AWL4]ELTMES([M:AWL4]NBMES-1)=right$([M:AWL4]ELTMES([M:AWL4]NBMES-1),K3+1)
    Endif
  Endif
Return


$NEWPORT
  K1=instr(1,toupper(STWSDL(J)),'NAME="')
  K=instr(K1+6,STWSDL(J),'"')
  [M:AWL4]NBSERV+=1
  [M:AWL4]NAMSERV([M:AWL4]NBSERV-1)=mid$(STWSDL(J),K1+6,K-K1-6)
  For K2=J+1 To IWSDL
    VALL1=toupper(vireblc(STWSDL(K2),2))
    Gosub ANLTAGFERM
    I=instr(1,VALL1,"PORTTYPE") 
    If I>0 and TAGFERM=1 : Break 1 : Endif
    I=instr(1,VALL1,"OPERATION ") 
    If I>0 
      K1=instr(1,toupper(STWSDL(K2)),'NAME="')
      K=instr(K1+6,STWSDL(K2),'"')
      [M:AWL4]NBSERV+=1
      [M:AWL4]OPERSERV([M:AWL4]NBSERV-1)=mid$(STWSDL(K2),K1+6,K-K1-6)
    Endif
    I=instr(1,VALL1,"INPUT ") 
    If I>0 
      K1=instr(1,toupper(STWSDL(K2)),'MESSAGE="')
      K=instr(K1+9,STWSDL(K2),'"')
      [M:AWL4]NBSERV+=1
      [M:AWL4]MESSERV([M:AWL4]NBSERV-1)=mid$(STWSDL(K2),K1+9,K-K1-9)
      K3=instr(1,[M:AWL4]MESSERV([M:AWL4]NBSERV-1),':')
      If K3>0
        [M:AWL4]MESSERV([M:AWL4]NBSERV-1)=right$([M:AWL4]MESSERV([M:AWL4]NBSERV-1),K3+1)
      Endif
      [M:AWL4]TYPSERV([M:AWL4]NBSERV-1)="INPUT"
    Endif
    I=instr(1,VALL1,"OUTPUT ") 
    If I>0 
      K1=instr(1,toupper(STWSDL(K2)),'MESSAGE="')
      K=instr(K1+9,STWSDL(K2),'"')
      [M:AWL4]NBSERV+=1
      [M:AWL4]MESSERV([M:AWL4]NBSERV-1)=mid$(STWSDL(K2),K1+9,K-K1-9)
      K3=instr(1,[M:AWL4]MESSERV([M:AWL4]NBSERV-1),':')
      If K3>0
        [M:AWL4]MESSERV([M:AWL4]NBSERV-1)=right$([M:AWL4]MESSERV([M:AWL4]NBSERV-1),K3+1)
      Endif
      [M:AWL4]TYPSERV([M:AWL4]NBSERV-1)="OUTPUT"
    Endif
  Next K2   
Return


$RECHFINS
  For K=I+1 To IWSDL
    If instr(1,STWSDL(K),">") 
      FINS=K
      Break 1
    Endif
  Next K
Return

$NEWELEMENT
  NIVCOU+=1
  J=instr(1,toupper(STWSDL(I)),'NAME="')
  K=instr(J+6,STWSDL(I),'"')
  NBELT+=1
  NELT(NBELT)=mid$(STWSDL(I),J+6,K-J-6)
  NIVELT(NBELT)=NIVCOU
  J=instr(1,toupper(STWSDL(I)),'TYPE="')
  If J>0
    K=instr(J+6,STWSDL(I),'"')
    TELT(NBELT)=mid$(STWSDL(I),J+6,K-J-6)
    K=instr(1,TELT(NBELT),":")
    If K>0
      TELT(NBELT)=right$(TELT(NBELT),K+1)
    Endif
  Else
    If right$(VALL1,len(VALL1)-2)<>"/>"
      Gosub RECHTYP
    Endif
  Endif
Return


$RECHTYP
  For K=I+1 To IWSDL
    If instr(1,toupper(vireblc(STWSDL(K),4)),"ELEMENT") or instr(1,toupper(vireblc(STWSDL(K),4)),"COMPLEXTYPE")
      Break 1
    Endif
    J=instr(1,toupper(STWSDL(K)),'BASE="')
    If J>0
      L=instr(J+6,STWSDL(K),'"')
      TELT(NBELT)=mid$(STWSDL(K),J+6,L-J-6)
      K1=instr(1,TELT(NBELT),":")
      If K1>0
        TELT(NBELT)=right$(TELT(NBELT),K1+1)
      Endif
    Endif
    A1=instr(1,toupper(vireblc(STWSDL(K),4)),"LENGTHVALUE")
    If A1>0
      A2=instr(A1+5,toupper(STWSDL(K)),'"')
      A3=instr(A2+1,toupper(STWSDL(K)),'"')
      LELT(NBELT)=val(mid$(STWSDL(K),A2+1,A3-A2-1))  
      Break 1
    Endif
  Next K
Return


$NEWCOMPL
  J=instr(1,toupper(STWSDL(I)),'NAME="')
  If J=0 
#    NBELT+=1
     COMPLEX(NIVCOU)=NBELT
#    NELT(NBELT)="UNNAMED"
#    TELT(NBELT)="COMPLEX"    
    Return
  Endif
  K=instr(J+6,STWSDL(I),'"')
  NBELT+=1
  NIVCOU+=1
  NELT(NBELT)=mid$(STWSDL(I),J+6,K-J-6)
  TELT(NBELT)="COMPLEX"
  NIVELT(NBELT)=NIVCOU
Return

$ENDCOMPL
 # NBELT+=1
 # TELT(NBELT)="ENDCOMPLEX"
  If COMPLEX(NIVCOU)=0
    NIVCOU-=1
  Else
    COMPLEX(NIVCOU)=0
  Endif
Return

######################################################################################
## Etiquette ajout├®e par le superviseur (├®cran AWSDL0) 19/12/2005 15:20:47 (CCORA)
######################################################################################
Subprog AP_CWSDL(VALEUR)
Variable Char    VALEUR()
End


######################################################################################

Subprog CREMWSDL(OK)
Variable Integer OK
Raz [M:AWL5]
Local Integer NBLIM,NBMK,I1,I2,I3,I4,I5,K,IELT,ILIG,INIV,NEWGR,NL,GRISEC
Local Char TYPANA(30)
NBLIM=-1
Dbgaff
For I1=0 To [M:AWL4]NBSERV-1
  If [M:AWL4]MESSERV(I1)<>"" 
    NBLIM+=1
    NBMK+=1
    [M:AWL5]ADELT(NBLIM)=1
    [M:AWL5]LELT(NBLIM)=[M:AWL4]MESSERV(I1)
    [M:AWL5]ADTYP(NBLIM)=0
    Gosub CREMS1
  Endif
Next I1
[M:AWL5]NBMT=NBLIM+1
Affzo [M:AWL5]
End

$CREMS1
ILIG=-1
For I2=0 To [M:AWL4]NBMES
  If [M:AWL4]NAMMES(I2)=[M:AWL4]MESSERV(I1)
    ILIG=I2
    Break 1
  Endif
Next I2
If ILIG=-1 : Return : Endif

#  Examine chaque partie de message
For I2=ILIG+1 To [M:AWL4]NBMES
  If [M:AWL4]NAMMES(I2)<>"" or [M:AWL4]PARTMES(I2)="" : Break 1 : Endif
  NBLIM+=1
 [M:AWL5]LELT(NBLIM)=[M:AWL4]PARTMES(I2)
 [M:AWL5]NOMW(NBLIM)=[M:AWL4]ELTMES(I2)
 Gosub CREELT
 If IELT=-1
   If GRISEC=0 : Gosub CREGRISOLE : Endif
   [M:AWL5]NOMW(NBLIM)=[M:AWL4]PARTMES(I2)  : # Element local 
   [M:AWL5]ADELT(NBLIM)=2
   [M:AWL5]LNIV(NBLIM)=2
   TYPANA=toupper([M:AWL4]ELTMES(I2))
   Gosub RECHTYPM
   NL=NBLIM : Gosub CREFORMAD
   [M:AWL5]ADFORM(NBLIM)=FORMADO
   If [M:AWL5]ADLON(NBLIM)=0 : [M:AWL5]ADLON(NBLIM)=LZON : Endif
 Endif
 
Next I2
Return



$CREGRISOLE
 GRISEC=1
 [M:AWL5]ADELT(NBLIM)=3
 [M:AWL5]LNIV(NBLIM)=1
 [M:AWL5]NOMW(NBLIM)=[M:AWL4]MESSERV(I1)
 [M:AWL5]LELT(NBLIM)=""
  NBLIM+=1
 [M:AWL5]LELT(NBLIM)=[M:AWL4]PARTMES(I2)
 [M:AWL5]NOMW(NBLIM)=[M:AWL4]ELTMES(I2)
Return


$RECHTYPM
Case TYPANA
  When "STRING","CHAR"                   : [M:AWL5]ADTYP(NBLIM)=7
  When "DECIMAL"                         : [M:AWL5]ADTYP(NBLIM)=4
  When "DOUBLE"                          : [M:AWL5]ADTYP(NBLIM)=6
  When "FLOAT"                           : [M:AWL5]ADTYP(NBLIM)=5
  When "INT","LONG"                      : [M:AWL5]ADTYP(NBLIM)=3
  When "BYTE","UNSIGNEDBYTE"             : [M:AWL5]ADTYP(NBLIM)=1
  When "BOOLEAN","SHORT","UNSIGNEDSHORT" : [M:AWL5]ADTYP(NBLIM)=2
Endcase
Return


$CREELT
# If left$(toupper([M:AWL4]ELTMES(I2))="ARRAYOF"   voir avec minoccurs et maxoccurs + nom avec []
IELT=-1
For I3=0 To [M:AWL1]NBLIG
  If [M:AWL1]NOMAF(I3)=[M:AWL4]ELTMES(I2)
    IELT=I3 : INIV=[M:AWL1]NIV(I3)
    Break 1
  Endif
Next I3
If IELT=-1 : Return : Endif
GRISEC=0
[M:AWL5]ADELT(NBLIM)=3
[M:AWL5]LNIV(NBLIM)=[M:AWL1]NIV(I3)

#  Examine chaque partie de message
For I3=IELT+1 To [M:AWL1]NBLIG
  If [M:AWL1]NIV(I3)<=INIV : Break 1 : Endif
  NBLIM+=1
 [M:AWL5]LELT(NBLIM)=[M:AWL1]NOMAF(I3)
 Gosub CRENOMW
 [M:AWL5]LNIV(NBLIM)=[M:AWL1]NIV(I3)
#   Est-ce un groupe ?
  NEWGR=0
  Gosub EXPANDGR
  If NEWGR=0 
    [M:AWL5]ADELT(NBLIM)=2 
    TYPANA=toupper([M:AWL1]TYP(I3))
    Gosub RECHTYPM
    NL=NBLIM : Gosub CREFORMAD
    [M:AWL5]ADFORM(NBLIM)=FORMADO
    If [M:AWL5]ADLON(NBLIM)=0 : [M:AWL5]ADLON(NBLIM)=LZON : Endif
  Endif
Next I3
Return


$EXPANDGR
Local Char AGRP(30) : AGRP=[M:AWL1]TYP(I3)
Local Integer ISTABL
If left$(toupper(AGRP),7)="ARRAYOF"
  AGRP=right$(AGRP,8)
  ISTABL=1
Endif
For I4=0 To [M:AWL1]NBLIG-1
  If [M:AWL1]NOMAF(I4)=AGRP
    NEWGR=1
    Gosub ADDGR
    Break 1
  Endif
Next I4
Return

$ADDGR
[M:AWL5]ADELT(NBLIM)=3
If ISTABL=1 : [M:AWL5]ADELT(NBLIM)=4 : Endif
For I5=I4+1 To [M:AWL1]NBLIG
  If [M:AWL1]NIV(I5)<=[M:AWL1]NIV(I4) : Break 1 : Endif
  NBLIM+=1
 [M:AWL5]LELT(NBLIM)=[M:AWL1]NOMAF(I5)
 Gosub CRENOMW
 TYPANA=toupper([M:AWL1]TYP(I5))
 Gosub RECHTYPM
 NL=NBLIM : Gosub CREFORMAD
 If [M:AWL5]ADLON(NBLIM)=0 : [M:AWL5]ADLON(NBLIM)=LZON : Endif
 [M:AWL5]ADFORM(NBLIM)=FORMADO
 [M:AWL5]LNIV(NBLIM)=[M:AWL1]NIV(I5)+[M:AWL1]NIV(I4)
 [M:AWL5]ADELT(NBLIM)=2
Next I5
Return

$CRENOMW
#  enleve les ... dans le nom
 For K=1 To len([M:AWL5]LELT(NBLIM))
   If mid$([M:AWL5]LELT(NBLIM),K,1)<>"." : Break 1 : Endif
 Next K
 [M:AWL5]NOMW(NBLIM)=right$([M:AWL5]LELT(NBLIM),K)
If [M:AWL2]PREFSP<>""
  [M:AWL5]NOMW(NBLIM)=[M:AWL2]PREFSP+":"+[M:AWL5]NOMW(NBLIM)
Endif
Return


#  ADELT
#       1 : Masque
#       2 : Champ
#       3 : Bloc liste
#       4 : Bloc tableau

$CRENL
Local Integer NL
NL=nolign-1
Return

Subprog AV_ADMSK(VALEUR)
Variable Char    VALEUR()
Gosub CRENL
If [M:AWL5]ADELT(NL)<>1
  mkstat=1  
Endif
End

Subprog AV_ADABR(VALEUR)
Variable Char    VALEUR()
Gosub CRENL
If [M:AWL5]ADELT(NL)<>1
  mkstat=1  
Endif
End

