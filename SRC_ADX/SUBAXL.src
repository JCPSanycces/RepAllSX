Subprog CL_NOMAUT(VALEUR)
Variable Char    VALEUR()
# V├®rifie que tous les noms, format, .. sont renseign├®s sinon cr├®ation automatique
#Gosub RAZNAMMSK
Call CRENAMMSK
End

$RAZNAMMSK
 Local Integer I
 For I=0 To [M:AWL5]NBMT-1
  Case [M:AWL5]ADELT(I)
    When 1 : [M:AWL5]ADMSK(I)="" 
             [M:AWL5]ADABR(I)="" 
    When 2 : [M:AWL5]ADNAM(I)="" 
             [M:AWL5]ADFORM(I)="" 
    When 3 : # Rien ├Ā saisir pour les blocs
    When 4 : [M:AWL5]ADCONT(I)=""
             [M:AWL5]ADDIM(I)=0
  Endcase
 Next I
Return

