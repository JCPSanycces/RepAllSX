Gosub CRENL
Raz [M]ADFORM(NL)
End


Subprog C_ADELT(VALEUR)
Variable Integer VALEUR
End

Subprog AV_ADNAM(VALEUR)
Variable Char    VALEUR()
Gosub CRENL
If [M:AWL5]ADELT(NL)<>2 
  mkstat=1  
Endif
End

Subprog C_ADNAM(VALEUR)
Variable Char    VALEUR()
