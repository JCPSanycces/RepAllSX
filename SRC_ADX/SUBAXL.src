Variable Char    VALEUR()
End

Subprog C_ADABR(VALEUR)
Variable Char    VALEUR()
End

Subprog AV_ADDIM(VALEUR)
Variable Decimal VALEUR
Gosub CRENL
If [M:AWL5]ADELT(NL)=1 or [M:AWL5]ADELT(NL)=3 
  mkstat=1  
Endif
End

Subprog AV_ADCONT(VALEUR)
