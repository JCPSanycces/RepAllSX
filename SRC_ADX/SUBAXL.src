######################################################################################
## Etiquette ajout├®e par le superviseur (├®cran AWSDL5) 06/04/2006 10:25:49 (CCORA)
######################################################################################
Subprog IB_NBMT
If [M:AWL5]ADMSK(nolign-1)="" : GBOUT2="" : GBOUT3="" : End : Endif
Local Char NOMFC(200)
NOMFC=filpath("ECR","W_"+[M:AWL5]ADMSK(nolign-1),"srm")
If filinfo(NOMFC,7)<0 : GBOUT2="" : GBOUT3="" : Endif
End

Subprog B2_NBMT
Local Char NOMFC(200),VALL1(200)
NOMFC=filpath("ECR","W_"+[M:AWL5]ADMSK(nolign-1),"srm")
If filinfo(NOMFC,7)<0 : End : Endif
Call OUVRE_TRACE(" ") From LECFIC
Openi NOMFC,0 Using [VIS_]
Iomode adxifs "" Using [VIS_]
Iomode adxirs chr$(10) Using [VIS_]
Iomode adxium GUTF8 Using [VIS_]
While fstat=0
  Rdseq VALL1 Using [VIS_]
  If fstat=0
    VALL1=ctrans(VALL1,tab$," ")
    Call ECR_TRACE(VALL1,0) From GESECRAN 
  Endif
Wend
Openi Using [VIS_]

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
 
End

Subprog B3_NBMT
#  Validation masque
Local Char RESULT(200)(1..10)
System RESULT = "valmsk "+nomap-"W_"+[M:AWL5]ADMSK(nolign-1)
If RESULT(1)<>""
  Call ERREUR(mess(21,123,1)-[M:AWL5]ADMSK(nolign-1)-RESULT(1)) From GESECRAN
Else
#  Validation masque OK
  Infbox(mess(139,123,1)-[M:AWL5]ADMSK(nolign-1))
Endif
End

