Subprog AV_ADFORM(VALEUR)
Variable Char    VALEUR()
Gosub CRENL
If [M:AWL5]ADELT(NL)<>2 
  mkstat=1  
Endif
End

Subprog D_ADFORM(VALEUR)
Variable Char    VALEUR()
Gosub CRENL
Gosub CREFORMAD
VALEUR=FORMADO
End

$CREFORMAD
Local Integer LZON
Local Char FORMADO(30)
LZON=[M:AWL5]ADLON(NL)
If LZON=0 
 Case [M]ADTYP(NL)
  When  1        : LZON=2
  When  2        : LZON=5
  When  3        : LZON=10
  When  4,5,6    : LZON=15
  When  7        : LZON=30
  When  8        : LZON=10
  When  9,10     : LZON=6
 Endcase
Endif
Case [M]ADTYP(NL)
  When  1,2,3    : FORMADO="N:"+num$(LZON)+"#"
  When  4,5,6    : FORMADO="N:"+num$(max(LZON-4,1))+".4#"
  When  7        : FORMADO="K:"+num$(LZON)+"X"
  When  8        : FORMADO=GFMDAT
  When  9,10     : FORMADO="KR:80X"
Endcase
Return



######################################################################################

Subprog CREMSK(OK)
Variable Integer OK

Local Integer NIVCOU,STAT
Local Integer I,J,K,OKBL
Local Char DL : DL='"'
Local Integer AADTYPA   : #  Type Adonix
Local Char TYPSP(10)    : #  Pr├®fixe du namespace
Local Char NOMFC(200),RESULT(200)(1..10)
#TYPSP=[M:AWL2]PREFSP
#If TYPSP<>"" and left$(TYPSP,len(TYPSP))<>":"
#  TYPSP+=":"
#Endif
For I=0 To [M:AWL5]NBMT-1
  If [M:AWL5]ADELT(I)=1
    NOMFC=filpath("ECR","W_"+[M:AWL5]ADMSK(I),"srm")
    Openo NOMFC,0 Using [M_OU]
    Iomode adxifs tab$ Using [M_OU]
    Iomode adxirs chr$(10) Using [M_OU]
    Iomode adxium GUTF8 Using [M_OU]
    Gosub CREMSK1
    Openo Using [M_OU]
    Gosub COMPMSK
  Endif
Next I

[M:AWL0]DGENWSDL=date$
[M:AWL0]HGENWSDL=num$(time$)
[M:AWL0]PGENWSDL=GUSER
Affzo [M:AWL0]DGENWSDL,HGENWSDL,PGENWSDL

End

$COMPMSK
#  Ecriture sur disque et compilation

System RESULT = "valmsk "+nomap-"W_"+[M:AWL5]ADMSK(I)
If RESULT(1)<>""
  Call ERREUR(mess(21,123,1)-"W_"+[M:AWL5]ADMSK(I)-RESULT(1)) From GESECRAN
Endif
#Call EFFACE(NOMFC,STAT) From ORDSYS
Return

$CREMSK1
Dbgaff
Local Integer TYBLOC(1..20) : # type de bloc par niveau - 0 liste , 1 tableau
Local Integer NBBL,RANG
NIVCOU=0
Wrseq "#<AdxVJ>@(#)%I%"-[M:AWL5]ADMSK(I) Using [M_OU]
Wrseq "#"+[M:AWL5]ADABR(I) Using [M_OU]
Wrseq "8,0"; Using [M_OU]
Wrseq "96,204" Using [M_OU]
For J=I+1 To [M:AWL5]NBMT-1
  Case [M:AWL5]ADELT(J)
    When 1 : Break 1
    When 2 : Gosub CREFLD1
    When 3 : Gosub CREBL1
    When 4 : Gosub CRETAB1
  Endcase
Next J

For K=NIVCOU To 1 Step -1
  If TYBLOC(K)=1 
    Gosub FINTAB1
  Elsif TYBLOC(K)=2
    Gosub FINBL1
  Endif
Next K

Return

$CONTNIV
  If [M:AWL5]LNIV(J)<=NIVCOU
    For K=NIVCOU To [M:AWL5]LNIV(J) Step -1
      If TYBLOC(K)=1 
        Gosub FINTAB1
      Elsif TYBLOC(K)=2
        Gosub FINBL1
      Endif
    Next K
  Endif
Return


$CREBL1
  Gosub CONTNIV
#    V├®rification que le groupe n'est pas vide, auquel cas il faut l'ignorer
#    Pour cela il faut qu'il y ait un enreg suivant et de niveau sup├®rieur
  Gosub VERIFBLNVID
  If OKBL=0 : Return : Endif
  NIVCOU=[M:AWL5]LNIV(J)
  TYBLOC(NIVCOU)=2
  NBBL+=1
  Wrseq "<" Using [M_OU]
  Wrseq "0,0"; Using [M_OU]
  Wrseq "32,200"; Using [M_OU]
  Wrseq '"'+TYPSP+[M:AWL5]NOMW(J)+'"' Using [M_OU]
Return

$FINBL1
  Wrseq ">" Using [M_OU]
Return

$FINTAB1
  Wrseq "%" Using [M_OU]
Return

$VERIFBLNVID
  OKBL=1
  If [M:AWL5]LNIV(J+1)<=[M:AWL5]LNIV(J) : OKBL=0 : Return : Endif
  If [M:AWL5]ADELT(J+1)=2 : Return : Endif
  If [M:AWL5]ADELT(J+1)<>3 and [M:AWL5]ADELT(J+1)<>4 : OKBL=0 : Return : Endif
  For JJ=J+2 To [M:AWL5]NBMT-1
    If [M:AWL5]ADELT(JJ)=2 and [M:AWL5]LNIV(JJ)>[M:AWL5]LNIV(J+1)  : Break 1 : Endif
    If [M:AWL5]LNIV(JJ)<[M:AWL5]LNIV(J+1) : OKBL=0 : Break 1 : Endif
  Next JJ
Return

$CREFLD1
  If [M:AWL5]LNIV(J)<NIVCOU
    For K=NIVCOU To [M:AWL5]LNIV(J) Step -1
      If TYBLOC(K)=1 
        Gosub FINTAB1
        TYBLOC(K)=2
      Elsif TYBLOC(K)=2
        Gosub FINBL1
      Endif
    Next K
  Endif

  NIVCOU=[M:AWL5]LNIV(J)
  Wrseq "{" Using [M_OU]
  AADTYPA=0
  Case [M:AWL5]ADTYP(J)
    When 1,2,3,4,5,6,8 : AADTYPA=299+[M:AWL5]ADTYP(J)
    When 7  : AADTYPA=378
    When 9  : AADTYPA=380
    When 10 : AADTYPA=381
  Endcase
# Si colonne tableau --> autre syntaxe
  If TYBLOC(NIVCOU-1)=1 : Goto CREFLTAB1 : Endif

  Wrseq [M:AWL5]ADNAM(J); Using [M_OU]
  Wrseq num$(AADTYPA); Using [M_OU]
  Wrseq num$([M:AWL5]ADLON(J)); Using [M_OU]
  Wrseq num$([M:AWL5]ADDIM(J)) Using [M_OU]
  RANG=NBBL*10
  Wrseq "3,40"; Using [M_OU]
  Wrseq '"'+[M:AWL5]ADFORM(J)+'"'; Using [M_OU]
  Wrseq num$(RANG); Using [M_OU]
  Wrseq "0" Using [M_OU]
  Wrseq '""'; Using [M_OU]
  Wrseq '"'+TYPSP+[M:AWL5]NOMW(J)+'"' Using [M_OU]
  Wrseq "}" Using [M_OU]
Return

$CREFLTAB1 
  Wrseq '""'; Using [M_OU]
  Wrseq '"'+[M:AWL5]ADFORM(J)+'"'; Using [M_OU]
  Wrseq "62" Using [M_OU]
  Wrseq [M:AWL5]ADNAM(J); Using [M_OU]
  Wrseq num$(AADTYPA); Using [M_OU]
  Wrseq num$([M:AWL5]ADLON(J)); Using [M_OU]
  Wrseq "1" Using [M_OU]
  Wrseq '""'; Using [M_OU]
  Wrseq '"'+TYPSP+[M:AWL5]NOMW(J)+'"' Using [M_OU]
  Wrseq "}" Using [M_OU]
Return


$CRETAB1
  Gosub CONTNIV
  NIVCOU=[M:AWL5]LNIV(J)
  NBBL+=1
  TYBLOC(NIVCOU)=1
  Wrseq "%" Using [M_OU]
  Wrseq "0,0"; Using [M_OU]
  Wrseq "32,200" Using [M_OU]
  RANG=NBBL*10
  Wrseq "10,5"; Using [M_OU]
  Wrseq '""'; Using [M_OU]
  Wrseq  [M:AWL5]ADCONT(J); Using [M_OU]
  Wrseq num$(RANG); Using [M_OU]
  Wrseq "0" Using [M_OU]
Return


# ---------------------------------------------------------

Subprog CRENAMMSK

Local Integer I,IMSKCOU,ICHCOU,NL,MODIF
Local Char NOMFC(200),MASKC,ABRC
If vireblc([M:AWL0]ABRWSDL,2)=""
  Errbox(mess(144,125,1))
  End
Endif
For I=0 To [M:AWL5]NBMT-1
  Case [M:AWL5]ADELT(I)
    When 1 : If [M:AWL5]ADMSK(I)=""  : Gosub ADNAMMSK  : Endif
             MASKC=[M:AWL5]ADMSK(I)
             If [M:AWL5]ADABR(I)=""  : Gosub ADNAMABR  : Endif
             ABRC=[M:AWL5]ADABR(I) : ICHCOU=0
    When 2 : If [M:AWL5]ADNAM(I)=""  : Gosub ADNAMNAM  : Endif
             If [M:AWL5]ADFORM(I)="" : Gosub ADNAMFORM : Endif
    When 3 : # Rien ├Ā saisir pour les blocs
    When 4 : If [M:AWL5]ADCONT(I)="" : Gosub ADNAMCONT : Endif
             If [M:AWL5]ADDIM(I)=0  : Gosub ADNAMDIM  : Endif
  Endcase
Next I
If MODIF>0
  mkstat=4
  Affzo [M:AWL5]
Endif
End

$ADNAMMSK
  MODIF=1
  IMSKCOU+=1
  [M:AWL5]ADMSK(I)=[M:AWL0]ABRWSDL+format$("N0:##",IMSKCOU)
  If [M:AWL5]ADABR(I)=""
    If IMSKCOU<=9
      [M:AWL5]ADABR(I)=[M:AWL0]ABRWSDL+format$("N0:#",IMSKCOU)
    Else
      [M:AWL5]ADABR(I)=left$([M:AWL0]ABRWSDL,2)+format$("N0:##",IMSKCOU)
    Endif
  Endif 
Return


$ADNAMABR  
  MODIF=1
  IMSKCOU+=1
  If IMSKCOU<=9
    [M:AWL5]ADABR(I)=[M:AWL0]ABRWSDL+format$("N0:#",IMSKCOU)
  Else
    [M:AWL5]ADABR(I)=left$([M:AWL0]ABRWSDL,2)+format$("N0:##",IMSKCOU)
  Endif
Return

$ADNAMNAM  
  MODIF=1
  ICHCOU+=1
  [M:AWL5]ADNAM(I)=ABRC+num$(ICHCOU)
Return

$ADNAMFORM 
  MODIF=1
  NL=I
  Gosub CREFORMAD
  [M:AWL5]ADFORM(I)=FORMADO
  [M:AWL5]ADLON(I)=LZON
Return

$ADNAMCONT 
  MODIF=1
  ICHCOU+=1
  [M:AWL5]ADCONT(I)=ABRC+num$(ICHCOU)
Return

$ADNAMDIM  
  MODIF=1
  [M:AWL5]ADDIM(I)=100
Return


######################################################################################
## Etiquette ajout├®e par le superviseur (├®cran AWSDL5) 05/04/2006 09:25:42 (CCORA)
######################################################################################
Subprog AM_ADMSK(VALEUR)
Variable Char    VALEUR()
Local Integer I

#  V├®rifie si le nom du masque n'a pas d├®j├Ā ├®t├® donn├® dans la page
For I=0 To [M:AWL5]NBMT-1
  If [M:AWL5]ADELT(I)=1 and I<>nolign-1 and [M:AWL5]ADMSK(I)=VALEUR
    GMESSAGE=mess(24,123,1)-num$(I+1)
    mkstat=2
    End
  Endif
Next I

#  V├®rifie si le srm du masque existe sur disque et demande une confirmation
Local Char NOMFC(200)
Local Integer OK
NOMFC=filpath("ECR","W_"+VALEUR,"srm")
If filinfo(NOMFC,7)>0 
  Call OUINON(mess(170,115,1),OK) From GESECRAN
  If OK<>2 : mkstat=2 : End : Endif
Endif

End

Subprog AM_ADABR(VALEUR)
Variable Char    VALEUR()
#  V├®rifie si l'abr├®viation du masque n'a pas d├®j├Ā ├®t├® donn├®e dans la page
Local Integer I
For I=0 To [M:AWL5]NBMT-1
  If [M:AWL5]ADELT(I)=1 and I<>nolign-1 and [M:AWL5]ADABR(I)=VALEUR
    GMESSAGE=mess(24,123,1)-num$(I+1)
    mkstat=2
    Break 1
  Endif
Next I
End

Subprog AM_ADNAM(VALEUR)
Variable Char    VALEUR()
#  V├®rifie si le nom du champ n'a pas d├®j├Ā ├®t├® donn├® dans le masque
Local Integer I,LIGDM
#  Recherche le num├®ro de ligne du masque d'appartenance

For I=0 To nolign-1
  If [M:AWL5]ADELT(I)=1 
    LIGDM=I
  Endif
Next I

For I=LIGDM+1 To [M:AWL5]NBMT-1
  If [M:AWL5]ADELT(I)=1 : Break 1 : Endif
  If ([M:AWL5]ADELT(I)=2 and I<>nolign-1 and [M:AWL5]ADNAM(I)=VALEUR)
& or ([M:AWL5]ADELT(I)=4 and I<>nolign-1 and [M:AWL5]ADCONT(I)=VALEUR)
    GMESSAGE=mess(24,123,1)-num$(I+1)
    mkstat=2
    Break 1
  Endif
Next I
End

Subprog AM_ADCONT(VALEUR)
Variable Char    VALEUR()
#  V├®rifie si le nom du champ n'a pas d├®j├Ā ├®t├® donn├® dans le masque
Local Integer I,LIGDM
#  Recherche le num├®ro de ligne du masque d'appartenance

For I=0 To nolign-1
  If [M:AWL5]ADELT(I)=1 
    LIGDM=I
  Endif
Next I

For I=LIGDM+1 To [M:AWL5]NBMT-1
  If [M:AWL5]ADELT(I)=1 : Break 1 : Endif
  If ([M:AWL5]ADELT(I)=2 and I<>nolign-1 and [M:AWL5]ADNAM(I)=VALEUR)
& or ([M:AWL5]ADELT(I)=4 and I<>nolign-1 and [M:AWL5]ADCONT(I)=VALEUR)
    GMESSAGE=mess(24,123,1)-num$(I+1)
    mkstat=2
    Break 1
  Endif
Next I
End

