End

Subprog AV_ADLON(VALEUR)
Variable Decimal VALEUR
Gosub CRENL
If [M:AWL5]ADELT(NL)<>2 
  mkstat=1  
Endif
End

Subprog C_ADLON(VALEUR)
Variable Decimal VALEUR
End

Subprog AV_ADTYP(VALEUR)
Variable Integer VALEUR
Gosub CRENL
If [M:AWL5]ADELT(NL)<>2 
  mkstat=1  
Endif
End

Subprog AM_ADTYP(VALEUR)
