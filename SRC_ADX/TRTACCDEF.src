#<AdxTL>@(#)9.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("COA",GBIDC1,GBIDC2) From GOBJET
End


$ACTION
Case ACTION
 When "EXEC"     : Gosub EXEC
 When "CONTROLE" : Gosub CONTROLE
 When "TERMINE"  : Gosub FIN
Endcase
Return

$CONTROLE
TMP = 1 : # Pour afficher des tempon/tempoff
Return

$FIN
TRA = 1 : # Pour lire la trace
Return

$EXEC
Call OUVRE_VLC(mess(133,107,1),"","") From GESECRAN
Call OUVRE_TRACE(mess(133,107,1)) From LECFIC : # Comptes par défaut
Gosub STR_TRA
Call DEBTRANS From GLOCK
Gosub TR_EXEC
Call FERME_TRACE From LECFIC
Call FERME_VLC From GESECRAN
Return

$TR_EXEC
Local Char CPTSTR(30)
Local Char DESIG(GLONAX3), DESIG2(GLONAX3)
Local Char    MESSA(250)
Local Integer ADDCPT,SUPCPT,MODCPT,FLACPT

GOK=1
Trbegin [GAC]
 Lock [GAC]
 If fstat
  GOK=-1 : GLOCK="$GACCOUNT" : Goto ROLL_EXEC
 Endif
 GOK=1
 RW=0
 CPTSTR=""
 For [GAC]GAC0 Where COA=[M:COA0]COA
  Call AFF_VLC(mess(8,104,1),[F:GAC]ACC) From GESECRAN : # Table
  Raz MODCPT,ADDCPT,SUPCPT,FLACPT
  P = find([M:COA6]COADEN,[F:GAC]OTHCOA(0..[F:GAC]COANBR-1))
  For [GCF]GCF0 Where COAORI=[M:COA0]COA & COADEN=[M:COA6]COADEN
   If [F:GCF]COASTR="*" or left$([F:GAC]ACC,len([F:GCF]COASTR))=[F:GCF]COASTR
    If  P>0  # valeur trouvée, on la met à jour selon l'option "Affectation des comptes renseignés"
     If [M:DIA]AFFECT=2
      [F:GAC]OTHCOA(P-1) = [F:GCF]COADEN
      [F:GAC]DEFACC(P-1) = [F:GCF]ACC
      If [F:GCF]ACC<>""
       [F:GAC]SCRACC(P-1) = [F:GCF]ACC
      Else
       [F:GAC]SCRACC(P-1) = "*"
      Endif
      If [F:GAC]DEFACC(P-1)<>""
       [F:GAC]OBYIPT(P-1) = 2
      Else
       [F:GAC]OBYIPT(P-1) = 1  
      Endif
      # If [M:DIA]RAZACC=2 : [F:GAC]COANBR+=1 : Endif
      RW=1 : MODCPT = 1 : FLACPT = 1
     Else
      FLACPT = 1 
     Endif
    Else # valeur non trouvée, on l'ajoute
     [F:GAC]OTHCOA([F:GAC]COANBR) = [F:GCF]COADEN
     [F:GAC]DEFACC([F:GAC]COANBR) = [F:GCF]ACC
     If [F:GCF]ACC<>""
      [F:GAC]SCRACC([F:GAC]COANBR) = [F:GCF]ACC
     Else
      [F:GAC]SCRACC([F:GAC]COANBR) = "*"
     Endif
     If [F:GAC]DEFACC([F:GAC]COANBR)<>""
      [F:GAC]OBYIPT([F:GAC]COANBR) = 2
     Else
      [F:GAC]OBYIPT([F:GAC]COANBR) = 1
     Endif
     [F:GAC]COANBR+=1
     RW=1 : ADDCPT = 1 : FLACPT = 1
     P = [F:GAC]COANBR  #DdM53378
    Endif 
   Endif
  Next
  If P>0 and [M:DIA]RAZACC=2 & FLACPT=0
   # on écrase l'ancienne valeur avec la dernière valeur des tableaux (décalage vers la gauche)
   [F:GAC]OTHCOA(P-1) = [F:GAC]OTHCOA([F:GAC]COANBR-1)
   [F:GAC]DEFACC(P-1) = [F:GAC]DEFACC([F:GAC]COANBR-1)
   [F:GAC]SCRACC(P-1) = [F:GAC]SCRACC([F:GAC]COANBR-1)
   [F:GAC]OBYIPT(P-1) = [F:GAC]OBYIPT([F:GAC]COANBR-1)
   [F:GAC]COANBR-=1
   Raz [F:GAC]OTHCOA([F:GAC]COANBR)
   Raz [F:GAC]DEFACC([F:GAC]COANBR)
   Raz [F:GAC]SCRACC([F:GAC]COANBR)
   Raz [F:GAC]OBYIPT([F:GAC]COANBR)
   RW=1 : SUPCPT = 1
  Endif
  If RW=1
   If MODCPT or ADDCPT or SUPCPT
    # Trace...
    Call LECTEXTRA([L]DESIG,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
    MESSA = [F:GAC]ACC-"'"+[L]DESIG+"'"
    If ADDCPT
     MESSA -= "\ "-mess(125,102,1) : # Plan ajouté
    Endif
    If MODCPT
     MESSA -= "\ "-mess(126,102,1)-":"-[F:GAC]ACC : # Compte modifié
     If [F:GA2]COA<>[M:COA6]COADEN or [F:GA2]ACC<>[F:GAC]DEFACC(P-1) : Read [GA2]GAC0 = [M:COA6]COADEN;[F:GAC]DEFACC(P-1) : Endif
     Call LECTEXTRA([L]DESIG2,"GACCOUNT","DESTRA",[F:GA2]COA,[F:GA2]ACC) From ATEXTRA
     MESSA -= [F:GAC]ACC-"'"+[L]DESIG+"'"
    Endif
    If SUPCPT
     MESSA -= "\ "-mess(127,102,1) : # Plan supprimé
    Endif
    Call ECR_TRACE(MESSA,0) From GESECRAN
   Endif
   If [M:DIA]SIMUL<>2
    Rewrite [GAC]
    If fstat
     GOK=0 : Call FSTA("GAC") From GLOCK : Break 2
    Endif
   Endif
  Endif
 Next
 If GOK=0 : Goto AB_EXEC : Endif
Commit
Return

$AB_EXEC
Rollback
Return

$ROLL_EXEC
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_EXEC : Endif
Return

$STR_TRA
# Détail inscrit dans la trace
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
# Plan de compte ... vers ... 
Call LECTURE("COA",[M:COA0]COA,"") From CONTOBJ
Call ECR_TRACE(mess(36,113,1)-[M:COA0]COA-[F:COA]DES,0) From GESECRAN
Call ECR_TRACE(mess(167,115,1),0) From GESECRAN 
Call LECTURE("COA",[M:COA6]COADEN,"") From CONTOBJ
Call ECR_TRACE(mess(36,113,1)-[M:COA6]COADEN-[F:COA]DES,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Onerrgo ERREUR From CONTROLE
 If !clalev([F:AMZ]) : Local File AMSKZON [AMZ] : Endif
Onerrgo
If GERREUR : GERREUR=0
Else
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 Local Char    LIBZON(80)
 Read [AMZ]CODE = "ACCDEF";"AFFECT"
 If fstat=0
  Call TEXTE([F:AMZ]INTIT,LIBZON) From OBJDIV
  If LIBZON<>""
   LIBZON-=":"-mess([M]AFFECT,1,1)
   Call ECR_TRACE(LIBZON,0) From GESECRAN
  Endif
 Endif
 Read [AMZ]CODE = "ACCDEF";"RAZACC"
 If fstat=0
  Call TEXTE([F:AMZ]INTIT,LIBZON) From OBJDIV
  If LIBZON<>""
   LIBZON-=":"-mess([M]RAZACC,1,1)
   Call ECR_TRACE(LIBZON,0) From GESECRAN
  Endif
 Endif
 Call ECR_TRACE(mess(27,107,1)-":"-mess([M]SIMUL,1,1),0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif
If clalev([GA2]) = 0 : Local File GACCOUNT [GA2] : Endif
Return
