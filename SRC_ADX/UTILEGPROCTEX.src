#<AdxTL>@(#)10.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour de la législation de la table APROCTEXTE par rapport à la table APROCESSUS
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update APROCTEXTE file") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub UPDLEG
End

#-------------------#
$UPDLEG

Local Integer MONOLEG
MONOLEG = !func AFNC.ACVDOSACT(DOSSIER,"LEG")
If !MONOLEG : End : Endif

Local Char    PRO(50) , LEG(20)
Local Integer VIDE

Local File =DOSSIER+".APROCTEXTE" [AXP] , =DOSSIER+".APROCESSUS"    [APR]

# Mise à jour de la table
Call ECR_TRACE(mess(81,125,1)-"APROCTEXTE :"-time$,0) From GESECRAN

Trbegin [AXP]
 For [APR]APR2(1)
  VIDE = 0
  For [APR]APR2
   If [F:APR]CODLEG=""
    VIDE = 1
    Break
   Else
    LEG = [F:APR]CODLEG
    PRO = [F:APR]CODPRO
   Endif
  Next APR
  If !VIDE
   Update [AXP] Where CODPRO=[L]PRO With CODLEG=[L]LEG
  Endif
 Next APR(1)
Commit

Close Local File

Return
