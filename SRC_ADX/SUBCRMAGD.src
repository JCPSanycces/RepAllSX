#<AdxTL>@(#)11.0.0.0 $Revision$
# Gestion des masques CRMAGD0, CRMAGD1, CRMAGD2, CRMAGD3, CRMAGD4, CRMAGD6
##########################################################################################################
$ACTION
  Case ACTION
    When "AB6_NBLIGOPP"  : Gosub AB6_NBLIGOPP
    When "BB6_NBLIGOPP"  : Gosub BB6_NBLIGOPP
    When "AB6_NBLIGCLL"  : Gosub AB6_NBLIGCLL
    When "BB6_NBLIGCLL"  : Gosub BB6_NBLIGCLL
    When "AB6_NBLIGTSK"  : Gosub AB6_NBLIGTSK
    When "BB6_NBLIGTSK"  : Gosub BB6_NBLIGTSK
    When "APRES_MODIF"   : Gosub APRES_MODIF     # FGR 14/10/2013 : X3SUIVI92220
    When Default
  Endcase
Return

##########################################################################################################
$APRES_MODIF
  # FGR 14/10/2013 : X3SUIVI92220
  If dim(GCRMAGDZONSUI) > 0 Then
    If GCRMAGDZONSUI <> "" Then
      zonsui = GCRMAGDZONSUI
    Endif
    Kill GCRMAGDZONSUI
  Endif
Return

##########################################################################################################
Subprog IB_NBLIGOPP
  #Historique Tiers
  If [M:CRM4]OPPCMP(nolign-1) = "" Then
    Raz GBOUT7
  Else
    Call TEXTE(17626, GBOUT7) From OBJDIV
  Endif
  #Historique Interlocuteur
  If [M:CRM4]OPPCNT(nolign-1) = "" Then
    Raz GBOUT8
  Else
    Call TEXTE(17627, GBOUT8) From OBJDIV
  Endif
End

##########################################################################################################
Subprog AS_NBLIGAGD
  If nolign > 0 Then
    [M:CRM0]CRMCMP = [M:CRM1]BPR(nolign-1)
    [M:CRM0]CRMCCN = [M:CRM1]CCN(nolign-1)
  Endif
End

##########################################################################################################
Subprog B1_NBLIGAGD
Local Char GCRMAGDZONSUI(250)          # FGR 14/10/2013 : X3SUIVI92220

  #On recharge l'agenda
  Gosub ONLOAD From TRTCRMAGD
  mkstat = 4                           # FGR 14/10/2013 : X3SUIVI92220
  GCRMAGDZONSUI = "[M:CRM1]NBLIGAGD"   # FGR 14/10/2013 : X3SUIVI92220
End

##########################################################################################################
$AB6_NBLIGOPP
  GBCRMFLGNEW = 1
  [M:CRM0]CRMCMP = [M:CRM4]OPPCMP(nolign-1)
  [M:CRM0]CRMCCN = [M:CRM4]OPPCNT(nolign-1)
  [M:CRM0]CRMOPP = ""
Return

##########################################################################################################
$BB6_NBLIGOPP
  #On recharge l'agenda
  Gosub ONLOAD From TRTCRMAGD
Return

##########################################################################################################
Subprog AM_DATMIN(VALEUR)
Variable Date    VALEUR

  If VALEUR <> [00/00/00] and [M:CRM0]DATMAX <> [00/00/00] Then
    If VALEUR > [M:CRM0]DATMAX Then
      mkstat = 2
      #Erreur : la date de début doit être inférieur à la date de fin.
      GMESSAGE = mess (489,177,1)
      End
    Endif
  Endif
End

##########################################################################################################
Subprog AM_DATMAX(VALEUR)
Variable Date    VALEUR

  If VALEUR <> [00/00/00] and [M:CRM0]DATMIN <> [00/00/00] Then
    If VALEUR < [M:CRM0]DATMIN Then
      mkstat = 2
      #Erreur : la date de début doit être inférieur à la date de fin.
      GMESSAGE = mess (489,177,1)
      End
    Endif
  Endif
End

##########################################################################################################
Subprog AS_NBLIGCLL
  If nolign > 0 Then
    [M:CRM0]CRMCMP = [M:CRM2]CLLCMP(nolign-1)
    [M:CRM0]CRMCCN = [M:CRM2]CLLCNT(nolign-1)
  Endif
End

##########################################################################################################
Subprog IB_NBLIGCLL
  #Historique Tiers
  If [M:CRM2]CLLCMP(nolign-1) = "" Then
    Raz GBOUT7
  Else
    Call TEXTE(17626, GBOUT7) From OBJDIV
  Endif
  #Historique Interlocuteur
  If [M:CRM2]CLLCNT(nolign-1) = "" Then
    Raz GBOUT8
  Else
    Call TEXTE(17627, GBOUT8) From OBJDIV
  Endif
  # FGR 27/04/2009 : X3SUIVI54714
  Call TEXTE(5562, GBOUT1) From OBJDIV       #Détail
  Call TEXTE(14438, GBOUT2) From OBJDIV      #Compte-rendu
  Call TEXTE(15312, GBOUT3) From OBJDIV      #Numéros de téléphone
  Call TEXTE(15163, GBOUT5) From OBJDIV      #Reporter l'appel
  #Script
  If [M:CRM2]CLLSCP(nolign-1) = "" Then
    Raz GBOUT4
  Else
    Call TEXTE(17264, GBOUT4) From OBJDIV
  Endif
End

