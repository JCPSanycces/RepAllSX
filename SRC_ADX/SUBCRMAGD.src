  Affzo [M:CRM7]SEAAPTTYP
End

##########################################################################################################
Subprog AM_SEABCS(VALEUR)
Variable Integer VALEUR

End

##########################################################################################################
Subprog AS_NBLIGAPP
  If nolign > 0 Then
    [M:CRM0]CRMCMP = [M:CRM7]APTCMPX(nolign-1)
    [M:CRM0]CRMCCN = [M:CRM7]APTCCNX(nolign-1)
  Endif
End

##########################################################################################################
Subprog IB_NBLIGAPP

  Raz GBOUT1
  Raz GBOUT2
  Raz GBOUT7
  Raz GBOUT8
  If nolign-1 < 0 Then
    End
  Endif
  If [M:CRM7]APTNUM(nolign-1) <> "" Then
    Call TEXTE(5562, GBOUT1) From OBJDIV           #Détail
    Read [BAP]APP0=[M:CRM7]APTNUM(nolign-1)
    If !fstat Then
      If [F:BAP]APTDON <> 2 Then
        Call TEXTE(14438, GBOUT2) From OBJDIV      #Compte-rendu
      Endif
    Endif
    If [M:CRM7]APTCMPX(nolign-1) <> "" Then
      Call TEXTE(17626, GBOUT7) From OBJDIV        #Historique Tiers
    Endif
    If [M:CRM7]APTCCNX(nolign-1) <> "" Then
      Call TEXTE(17627, GBOUT8) From OBJDIV        #Historique Interlocuteur
    Endif
  Endif
End

##########################################################################################################
Subprog IB_NBLIGCMG
  [M:CRM0]CRMCMP = ""
  [M:CRM0]CRMCCN = ""
End

##########################################################################################################
Subprog AS_NBLIGCMG
Local Integer ILIGNE
Local Integer ILIGNESAVE

  ILIGNESAVE = nolign-1
  If nolign >[M:CRM8]NBLIGCMG Then
    End
  Endif
  If [M:CRM8]TTROPG(nolign-1) = [M:CRM8]TTROPGSAVE(nolign-1) Then
    [M:CRM8]TTROPG(nolign-1) = "-> " + left$([M:CRM8]TTROPG(nolign-1), 37)
    ILIGNE = 0
    While ILIGNE < [M:CRM8]NBLIGCMG
      If ILIGNE <> ILIGNESAVE Then
        If [M:CRM8]TTROPG(ILIGNE) <> [M:CRM8]TTROPGSAVE(ILIGNE) Then
          [M:CRM8]TTROPG(ILIGNE) = [M:CRM8]TTROPGSAVE(ILIGNE)
        Endif
      Endif
      ILIGNE += 1
    Wend
  Endif
  If [M:CRM8]EVRCLL <> 2 Then
    Call LOPGCLL([M:CRM8]OPGMKGNUM(nolign-1)) From TRTCRMAGD
  Endif
  Affzo [M:CRM8]1-99
End

##########################################################################################################
Subprog AM_EVRCLL(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    Call LALLCLL From TRTCRMAGD
  Else
    If [M:CRM8]NBLIGCMG > 0 Then
      Call LOPGCLL([M:CRM8]OPGMKGNUM(nolign-1)) From TRTCRMAGD
    Endif
  Endif
  [M:CRM8]EVRCLL = VALEUR
  Affzo [M:CRM8]
End

##########################################################################################################
Subprog IB_NBLIGCLLX

  Call TEXTE(5562, GBOUT1) From OBJDIV       #Détail
  Call TEXTE(14438, GBOUT2) From OBJDIV      #Compte-rendu
  Call TEXTE(15312, GBOUT3) From OBJDIV      #Numéros de téléphone
  Call TEXTE(17264, GBOUT4) From OBJDIV      #Script
  Call TEXTE(15163, GBOUT5) From OBJDIV      #Reporter l'appel
  #Historique Tiers
  If [M:CRM8]CMPX(nolign-1) = "" Then
    Raz GBOUT7
  Else
    Call TEXTE(17626, GBOUT7) From OBJDIV
  Endif
  #Historique Interlocuteur
  If [M:CRM8]CCNX(nolign-1) = "" Then
    Raz GBOUT8
  Else
    Call TEXTE(17627, GBOUT8) From OBJDIV
  Endif
End
