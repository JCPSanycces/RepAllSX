#<AdxTL>@(#)12.0.0.0 $Revision$ 
  
# Traitement contenant le point d'entrée du portail : "MONITEUR"
# Ce point d'entrée sollicité par une action ACK_CALL depuis le serveur Web
#
# 2004 04 29 OG création


# ------------------------------------------------------------
# Traitement de test du sous programme "MONITEUR". Appel via F5
# ------------------------------------------------------------

  Local Char WPARAMID(50)(1..4)
  Local Char WPARAMVALUE(250)(1..4)
  Local Integer WI,WNBPARAM


  Local Clbfile WCLOBOUT(10)

  # "HTCPRVTYP=PORTALPAGE&ACTION=FIRST&PAGECODE=" + "HTCCLBSIZ=10"
  [L]WPARAMID(1) = "HTCCLBSIZ"
  [L]WPARAMID(2) = "HTCPRVTYP"
  [L]WPARAMID(3) = "ACTION"
  [L]WPARAMID(4) = "PAGECODE"
  [L]WPARAMVALUE(1) = "10"
  [L]WPARAMVALUE(2) = "PORTALPAGE"
  [L]WPARAMVALUE(3) = "FIRST"
  [L]WPARAMVALUE(4) = ""
  [L]WNBPARAM = 4

  #Visualisation des paramètres envoyés
  Local Char WMESS(250)
  [L]WMESS = "paramètres fournis.  Nb=["+ num$(WNBPARAM ) +"]"
  For [L]WI = 1 To [L]WNBPARAM
    [L]WMESS += chr$(13) + [L]WPARAMID(WI) +"=["+ [L]WPARAMVALUE(WI) + "]"
  Next [L]WI
  Infbox([L]WMESS)


  #Appel du point d'entrée du portail 
  Call MONITEUR( [L]WNBPARAM ,[L]WPARAMID ,[L]WPARAMVALUE, [L]WCLOBOUT)

  #Visualisation du flux Xml retourné
  Local Char WSTROUT(250)(1..100) :# 25 Ko Max !
  Setlob [L]WSTROUT With [L]WCLOBOUT
  Infbox("Taille de ClobOut=["+ num$(len([L]WCLOBOUT)) +"]"+ chr$(13) +"Contenu de ClobOut" + chr$(13) + [L]WSTROUT )
End

# ------------------------------------------------------------
# MONITEUR
#
# Point d'entrée des appels du portail via un ACK_CALL depuis
# le serveur "Adonix Web Serveur
#
# Reçoit un liste de n paramètres avec leur
# valeur sous la forme :
#  - ANBPARAM   : nombre de paramÃ¨tres
#  - APARAMID   : tableau des n identifiants
#  - APARAMVALUE: tableau des n valeurs
#
# Retourne dans ACLOBOUT un flot XML sans header et ayant la forme:
# <X3PORTAL>
#   <Data>
#   ...
#   </Data>
#   <Technical>
#   ...
#   </Technical>
# </X3PORTAL>
#
# le paramètre variable "ACLOBOUT" à  une size fixé par le
# traitement d'appel javascript.
# Voir la constante KCLOBOUTZIZE déclarée dans les "js" du portail
#
# ------------------------------------------------------------

Subprog MONITEUR( ANBPARAM, APARAMID , APARAMVALUE, ACLOBOUT)
  Value Integer ANBPARAM
  Value Char APARAMID ()(1..)
  Value Char APARAMVALUE()(1..)
  Variable Clbfile ACLOBOUT

  Local Char WNOMFIC (250)
  #  Dbgaff

  # construction d'un fichier Xml dans ./tmp
  Call TESTXMLBUILD (ANBPARAM,APARAMID,APARAMVALUE ,WNOMFIC )

  # lecture du fichier Xml et chargement du ClobOut
  Call TESTXMLREAD (WNOMFIC,ACLOBOUT)

End

# ------------------------------------------------------------
# TESTXMLBUILD
#
# Ecrit dans le fichier ./tmp/WEBCALL.XML un flot XML ayant
# la structure :
# <X3PORTAL>
#   <Data>
#   ...
#   </Data>
#   <Technical>
#   ...
#   </Technical>
# </X3PORTAL>
# ------------------------------------------------------------
Subprog TESTXMLBUILD ( ANBPARAM, APARAMID, APARAMVALUE, ANOMFIC )
  Value Integer ANBPARAM
  Value Char APARAMID ()(1..)
  Value Char APARAMVALUE()(1..)
  Variable Char ANOMFIC()

  Local Integer WI
  Local Char WQUOTE(1)

  [L]WQUOTE = chr$(34)
  [L]ANOMFIC = filpath("tmp","CALLWEB","XML","")

  Openo ANOMFIC,0 Using [AXML]
  Iomode adxifs "" Using [AXML]
  Iomode adxirs "" Using [AXML]
  Iomode adxium  GUTF8  Using [AXML] :# GUTF8  ou GUCS

  Wrseq "<X3PORTAL>" Using [AXML]
  Wrseq "<Data>" Using [AXML]
  For [L]WI = 1 To [L]ANBPARAM
    Wrseq "<param id=" + WQUOTE  + [L]APARAMID (WI) + WQUOTE + ">" + [L]APARAMVALUE(WI) + "</param >" Using [AXML]
  Next [L]WI
  Wrseq "</Data>" Using [AXML]
  Wrseq "<Technical>" Using [AXML]
  Wrseq "<date>"+date$()+"</date>" Using [AXML]
  Wrseq "<time>"+time$()+"</time>" Using [AXML]
  Wrseq "</Technical>" Using [AXML]
  Wrseq "</X3PORTAL>" Using [AXML]

  Openo Using [AXML]
End

# ------------------------------------------------------------
# TESTXMLREAD
#
# Retourne dans ACLOBOUT le flot de caractère contenu dans le
# fichier "ANOMFIC "
# ------------------------------------------------------------

Subprog TESTXMLREAD ( ANOMFIC , ACLOBOUT)
  Value Char ANOMFIC()
  Variable Clbfile ACLOBOUT

  Openi ANOMFIC Using [OUT]
  Iomode adxifs "" Using [OUT]
  Iomode adxirs "" Using [OUT]
  Iomode adxium GUTF8  Using [OUT] :# GUTF8  ou GUCS2

  Rdseq [L]ACLOBOUT Using [OUT] : 

  Openi Using [OUT]
End


