$_GET_RES_STRING
Local Char RES(250)
Case _LAN
 When "FRA":
  Case _ID
   When 7438: RES='Destination comptable'
   When 7537: RES='Code destination'
   When 26213: RES='Législation'
   When 71: RES='Code d'+"'"+'accès'
  Endcase
 When "ENG":
  Case _ID
   When 7438: RES='Payment attribute'
   When 7537: RES='Destination code'
   When 26213: RES='Legislation'
   When 71: RES='Access code'
  Endcase
 When "ITA":
  Case _ID
   When 7438: RES='Destinazione contabile'
   When 7537: RES='Codice destinazione'
   When 26213: RES='Legislazione'
   When 71: RES='Codice accesso'
  Endcase
 When "POR":
  Case _ID
   When 7438: RES='Destino contabilístico'
   When 7537: RES='Código destino'
   When 26213: RES='Legislação'
   When 71: RES='Código acesso'
  Endcase
 When "SPA":
  Case _ID
   When 7438: RES='Destino contable'
   When 7537: RES='Código destino'
   When 26213: RES='Legislación'
   When 71: RES='Cód. de acceso'
  Endcase
 When "BRI":
  Case _ID
   When 7438: RES='Payment Attributes'
   When 7537: RES='Destination Code'
   When 26213: RES='Legislation'
   When 71: RES='Access code'
  Endcase
 When "GER":
  Case _ID
   When 7438: RES='Zahlungsattribut'
   When 7537: RES='Druckercode'
   When 26213: RES='Rechtsordnung'
   When 71: RES='Zugriffscode'
  Endcase
 When "POL":
  Case _ID
   When 7438: RES='Typy płatności / wpłat'
   When 7537: RES='Kod miejsca docelowego'
   When 26213: RES='Legislacja'
   When 71: RES='Kod dostępu'
  Endcase
 When "CHI":
  Case _ID
   When 7438: RES='会计代码'
   When 7537: RES='目的地代码'
   When 26213: RES='准则'
   When 71: RES='访问代码'
  Endcase
 When "ARB":
  Case _ID
   When 7438: RES='سمة الدفع'
   When 7537: RES='رمز الوجهة'
   When 26213: RES='تشريعات'
   When 71: RES='رمز الدخول'
  Endcase
Endcase
Return
#---------------------------------------------------------------------------------------------------#
$_GET_RES_MENU
Local Char RES(250)
Case _LAN
 When "FRA":
  Case _ID
  Endcase
 When "ENG":
  Case _ID
  Endcase
 When "ITA":
  Case _ID
  Endcase
 When "POR":
  Case _ID
  Endcase
 When "SPA":
  Case _ID
  Endcase
 When "BRI":
  Case _ID
  Endcase
 When "GER":
  Case _ID
  Endcase
 When "POL":
  Case _ID
  Endcase
 When "CHI":
  Case _ID
  Endcase
 When "ARB":
  Case _ID
  Endcase
Endcase
Return


