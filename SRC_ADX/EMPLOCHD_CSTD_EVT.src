#<AdxTL>@(#)0.0.0.0 $Revision$
# Class EMPLOCHD


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AINIT"                      : Gosub AINIT
      When "AINSERT_CONTROL_BEFORE"      : Gosub AINSERT_CONTROL_BEFORE
    Endcase
Endcase
Return

$AINIT

Return


$AINSERT_CONTROL_BEFORE
#Set the line number
Gosub SET_LIGNUM
Return

$SET_LIGNUM
If this.NUMLIG <> 0 : Return: Endif
Local Integer MAXLIGNUM
Local File EMPLOCHD [CHD2]
Filter [CHD2] Where REFNUM = this.REFNUM
For [CHD2]
  If [F:CHD2]NUMLIG > MAXLIGNUM
    MAXLIGNUM = [F:CHD2]NUMLIG
  Endif
Next

MAXLIGNUM+=1
this.NUMLIG = MAXLIGNUM
LogicClose File [CHD2]
Return

