#<AdxTL>@(#)0.0.0.0 $Revision$
#CHECK MIGRATE_SOURCE
################################################################################
# Mise à jour du champ NUMDCS dans la table ORGANISME                          #
################################################################################

##################################################################
#Comments(1)                                                     #
# Manips à faire                                                 #
#   1. Remplacer UTIXXX par le nom de votre programme            #
#   2. Action OUVRE_TRACE : mettre un titre                      #
#   3. cf Comments(2)                                            #
#   4. cf Comments(3)                                            #
##################################################################

Local Char DOSSIER(30)
DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>""
 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UTIORG2: Mise à jour des tables ORGANISME & ORGAFFIL") From LECFIC
 Call EXE_UTIORG2(DOSSIER)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

###################################################################################################
#Comments(2)                                                                                      #
# Pour exécution automatique en gestion de patch de EXE_UTIXXX                                    #
#   1. Ne pas faire de ouvre_trace/ferme_trace/lec_trace dans cette partie de programme           #
#      (le fichier trace est déjà ouvert / l'intégration de patch peut se faire en batch )        #
#                                             
#   2. Pour les ecr_trace :                                                                       #
#         Utiliser des messages avec l'instruction mess(nnn,ccc,1) ou alors des textes en anglais #
#                                             
#   3. Attention à la déclaration des fichiers : pensez que le client n'a pas forcémment activer  #
#      tous les modules dans ses dossiers
#                                             
#   4. Attention aux moulinettes sur de gros volumes (Erreur Rollback en Oracle)                  #
###################################################################################################

Subprog EXE_UTIORG2(APPLI)
Value Char APPLI
Local Integer OK ,I

If filinfo(filpath("FIL","ORGANISME","fde",APPLI),0)<=0 : End : Endif  
If filinfo(filpath("FIL","ORGAFFIL","fde",APPLI),0)<=0 : End : Endif  

Call ECR_TRACE("UTIORG2: Process Start on : "+APPLI,0) From GESECRAN

#### Corps de la moulinette - début
#### attention moulinette a executer une seule fois..
Local File  =APPLI+".ORGAFFIL" [ORA]
Local File  =APPLI+".ORGANISME" [ORG]

Call DEBTRANS From GLOCK
Gosub MAJORG

#### Corps de la moulinette - fin 

Call ECR_TRACE("UTIORG2: Process End on : "+APPLI,0) From GESECRAN

Close Local File [ORG],[ORA]
End

################################
$MAJORG
Trbegin [ORA],[ORG]
GOK = 1

###46714 : Réinit de TYPIRC ici car retiré dans le TRCMAJ25 afin de garder l'ordre chronologique
### A faire uniquement si pas déjà fait càd si pas d'enreg dans ORGAFFIL !!!
If nbrecord ([ORA])=0
 For[F:ORG]ORG0 
  If dim([F:ORG]CODASS)<0 : Break : Endif
  If [F:ORG]TYP<>3 & [F:ORG]TYP<>5   :#Pas une caisse, ni un groupe de caisse
   [F:ORG]TYPIRC=0
   [F:ORG]TYPASS=0
  Else
   Raz [F:ORA]
   [F:ORA]LEV=1
   [F:ORA]ORG=[F:ORG]COD
   If [F:ORG]CODSSC<>""        :#Urssaf
    [F:ORG]TYPIRC=1 
    [F:ORG]TYPASS=0
    [F:ORA]NUMAFF=[F:ORG]ACCSSC 
   Elsif [F:ORG]NUMASS<>"" | [F:ORG]CODASS<>""   :#Assedic 
    [F:ORG]TYPIRC=2 
    [F:ORA]NUMAFF=[F:ORG]CODASS 
    #48915 : Pb si [F:ORG]TYPIRC<0
    If [F:ORG]TYPIRC>0
     [F:ORG]TYPIRC+=2        :#IRC (Décalage de 2 car Urssaf et Assedic en position 1 & 2)
     [F:ORG]TYPASS=0
     [F:ORA]NUMAFF=[F:ORG]NUMIRC([F:ORG]TYPIRC-3)
     [F:ORA]NUMCTR=[F:ORG]RGMNUM([F:ORG]TYPIRC-3)
    Else
     Call ECR_TRACE("No d'affiliation inexistant :"-[F:ORG]COD-": Récupération impossible",-1) From GESECRAN
    Endif
   Endif
   Write [ORA]
   If fstat
    GOK = 0 : Call FSTA("ORA") From GLOCK : Break 
   Endif
   Call ECR_TRACE("Affiliation organisme :"-[F:ORG]COD-": Mise à jour effectuée",0) From GESECRAN
  Endif
  Rewrite [ORG]
  If fstat
   GOK = 0 : Call FSTA("ORG") From GLOCK : Break 
  Endif
  Call ECR_TRACE("Organisme :"-[F:ORG]COD-": Mise à jour effectuée",0) From GESECRAN
 Next
Endif 
If GOK=0 : Goto AB_MAJORG : Endif
Commit
Return

$AB_MAJORG
Rollback
Return



###################################################################################################
#Comments(3)                                                                                      #
# Pour exécution automatique  en gestion de patch                                                 #
#   1. Si le traitement ne doit pas s'éxécuter dans le dossier X3 (moulinette applicative)        #
#        ==> Décocher la ligne 1                                                                  #
#                                                                                                 #
#   2. Si le traitement doit s'éxécuter uniquement dans les dossiers ayant activé un module donné #
#        ==> Décocher la ligne 2  et renseigner le n° de module                                   #
#            attention à la numérotation du module qui commence à 0 :                             #
#             (0=superviseur / 1= compta / 2= tiers ... etc ... )                                 #
###################################################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If filinfo(filpath("FIL","ORGANISME","fde",APPLI),0)<=0 : End : Endif  
If filinfo(filpath("FIL","ORGAFFIL","fde",APPLI),0)<=0 : End : Endif  
Call EXE_UTIORG2(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If filinfo(filpath("FIL","ORGANISME","fde",APPLI),0)<=0 : End : Endif  
If filinfo(filpath("FIL","ORGAFFIL","fde",APPLI),0)<=0 : End : Endif  
Call EXE_UTIORG2(APPLI)
End

