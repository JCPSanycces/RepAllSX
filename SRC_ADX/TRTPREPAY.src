Subprog C_DAT(VALEUR)
Variable Date    VALEUR
#LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#**If [M]ALLFCY=2
#**    Call CADRE_PYRDAT(VALEUR,"") From TPSSUB
#**    If mkstat
#**        Filter [HRPEO] Where PYRDAT=VALEUR
#**        Read [HRPEO] First
#**        Filter [HRPEO]
#**        If fstat>2
#**            GMESSAGE = mess(12,10709,1) : # Pas de paye définie à cette date
#**            mkstat = 2 : End
#**        Endif
#**    Endif
#**Else
#**    Call CADRE_PYRDAT(VALEUR,[M]FCY) From TPSSUB
#**    If mkstat : End : Endif
#**Endif
#**[M]DATDEB = [F:HRPEO]PERSTR(0)
#**[M]DATFIN = [F:HRPEO]PEREND(0)
#**[M]FMOIS  = [F:HRPEO]PEREND(1)
#*!
If [M]ALLFCY=2
    Call CADRE_PYRDAT(VALEUR,"") From TPSSUB
    If mkstat
        Filter [HRPEOD] Where PYRDAT=VALEUR
        Read [HRPEOD] First
        Filter [HRPEOD]
        If fstat>2
            GMESSAGE = mess(12,10709,1) : # Pas de paye définie à cette date
            mkstat = 2 : End
        Endif
    Endif
Else
    Call CADRE_PYRDAT(VALEUR,[F:HRCTR]PERCOD) From TPSSUB
    If mkstat : End : Endif
Endif
[M]DATDEB = [F:HRPEOD]PERSTR(0)
[M]DATFIN = [F:HRPEOD]PEREND(0)
[M]FMOIS  = [F:HRPEOD]PEREND(1)
#LIPET - 2017-05-20 - END
If VALEUR<>[0/0/0] Then
  [M]DATDEB = addmonth(eomonth(VALEUR),-1)+1
  [M]DATFIN = eomonth(VALEUR)
  [M]FMOIS  = eomonth(VALEUR)
Endif
#**
Affzo DATDEB,DATFIN,FMOIS
End

Subprog C_ALLPPH(VALEUR)
Variable Integer VALEUR
If [L]VALEUR = 2
    Effzo PPHNUM : Diszo PPHNUM
    Actzo FLGALL
Else
    Actzo PPHNUM
    FLGALL = 1 : Affzo  FLGALL : Diszo FLGALL
Endif
End

Subprog AS_PPHNUM(VALEUR)
Variable Char    VALEUR()
If [M]ALLPPH = 2
    mkstat = 1
    End
Endif
End
