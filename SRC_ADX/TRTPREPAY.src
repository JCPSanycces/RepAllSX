Subprog AM_MGR(VALEUR)
Variable Char    VALEUR()
If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
Read [ID]ID0=VALEUR
If !fstat
 [M]SRN1 = [F:ID]NAM-[F:ID]SRN
Endif
End


