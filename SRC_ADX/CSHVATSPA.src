#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "OUVRE"    : Gosub OUVRE_CASH
  When "AV_CHOIX" : Affzo [M:CVAT]
  When "OK"       : Gosub OK_CASH
  When "END"      : Gosub END_CASH
Endcase
Return

$OUVRE_CASH
If clalev([M:CVAT])=0: Local Mask CSHVATSPA [CVAT]: Endif

Raz [M:CVAT]

Readlock[F:DVS]DVS0 = [M:VSP2]TAXTYP(GNL);[M:VSP2]TYP(GNL);[M:VSP2]NUM(GNL);[M:VSP2]VAT(GNL);[M:VSP2]REGTYP(GNL)

If !fstat
 [M:CVAT]BIDNUM=[F:DVS]BIDNUM
 [M:CVAT]PAM=[F:DVS]PAM
Endif

Return

$OK_CASH
Trbegin [DVS]
  [F:DVS]BIDNUM = [M:CVAT]BIDNUM
  [F:DVS]PAM    = [M:CVAT]PAM
  Rewrite [DVS]
Commit
Return

$END_CASH
GNL=-1
Return
