#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion du masque DSC1
########################################
Subprog AM_DSCFCY(VALEUR)
Variable Char    VALEUR()

  [M:DSC1]DSCFCY = VALEUR
  Gosub RAZDSC1 From TRTDSC1
  Gosub LOADDISP From TRTDSC1
  If [M:DSC1]DSCFCY = "" and VALEUR <> "" Then
    VALEUR = ""
    GMESSAGE = mess(322,196,1) #Aucune demande n'est affectée à ce site. Toutes les demandes vont être affichées.
    GERR = 2
  Endif
End

########################################
Subprog AS_NBSRE

  If nolign > 0 Then
    GDSCNOL = nolign-1
    GDSCKEY = [M:DSC1]DSCNUM(GDSCNOL)
  Else
    GDSCNOL = 0
    GDSCKEY = [M:DSC1]DSCNUM(GDSCNOL)
  Endif
End

########################################
Subprog C_NBSRE

  If nolign > 0 Then
    GDSCNOL = nolign-1
    GDSCKEY = [M:DSC1]DSCNUM(GDSCNOL)
  Else
    GDSCNOL = 0
    GDSCKEY = [M:DSC1]DSCNUM(GDSCNOL)
  Endif
End
