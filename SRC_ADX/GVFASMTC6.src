#<AdxTL>@(#)0.0.0.0 $Revision$
# MODIFIE PAR : CBO
# LE          : 11 Mai       2015 13:53:17

$OUVRE_TABLE
 If dim(APPLI)<0 : Local Char APPLI(30) : APPLI=nomap : Endif
 If !clalev([F:EVT0]) : Local File =APPLI+".EFASMTC" [EVT0] : Endif
 If !clalev([F:EVT1]) : Local File =APPLI+".EFASMTC" [EVT1] : Endif
Return

$CONDITION_EVE
 LCNDREQEVT="CPY=PCPY & REF=PREF & DPRPLN=LPLN & EVTINT=CODEVTINT & SNSEVE=PSNSEVE"
Return

$RAZ_F_EVT0_1
 Raz [F:EVT0]
 Raz [F:EVT1]
Return

$AIGUILLAGE
 Gosub OUVRE_TABLE
 Gosub RAZ_F_EVT0_1
 Gosub FASMTC6
 [F:EVT0]CPY       = PCPY
 [F:EVT0]FCY       = PFCY
 [F:EVT0]REF       = PREF
 [F:EVT0]CURPERSTR = LCURPERSTR
 [F:EVT0]CREUSR    = GUSER
 [F:EVT0]CREDAT    = date$
 [F:EVT0]CRETIM    = time
 [F:EVT0]UPDUSR    = ""
 [F:EVT0]UPDDAT    = [0/0/0]
 [F:EVT0]DPRPLN    = LPLN
 [F:EVT0]EVTINT    = CODEVTINT
 [F:EVT0]EVTDAT    = PDAT
 [F:EVT0]CPTFLG    = 1
 [F:EVT0]SNSEVE    = 1
 [F:EVT0]CREUSRO   = ""
 [F:EVT0]TIMSTPO   = ""
 If PACCDAT<>[0/0/0]
  [F:EVT0]CPTDATINT = PACCDAT
 Else
  [F:EVT0]CPTDATINT = PDAT
 Endif
 Gosub CALCUL_TIMSTP
 Gosub ALIM_CUR
Return
 
$CALCUL_TIMSTP
 [F:EVT0]TIMSTP = func GENEVE.BUILD_TIMSTP([F:EVT0]CREDAT, [F:EVT0]CRETIM)
Return

$ALIM_CUR
 [F:EVT0]CUR=Func GLOFCYCPY.GET_DEVISE_PLN([F:EVT0]CPY,[F:EVT0]DPRPLN)
Return

$ANNULE_EVE
 [F:EVT0]SNSEVE = 2
 [F:EVT0]CREUSRO = [F:EVT0]CREUSR
 [F:EVT0]TIMSTPO = [F:EVT0]TIMSTP
 [F:EVT0]CPTDATINTO = [F:EVT0]CPTDATINT
 [F:EVT0]CREUSR = GUSER
 [F:EVT0]CREDAT = date$
 [F:EVT0]CRETIM = time
 [F:EVT0]UPDUSR = ""
 [F:EVT0]UPDDAT = [0/0/0]
 [F:EVT0]CPTFLG = 1
 [F:EVT0]EVTDAT = PDAT
 Gosub CALCUL_TIMSTP
Return

$FASMTC6
 #--> Désignation
 [F:EVT0]DES        = evalue(GFAS+"AASDES1")
 #--> Menus locaux
 If G_ACTCCN=G_OUI
  [F:EVT0]RNWFLG     = evalue(GFAS+"RNWFLG")
 Endif
 [F:EVT0]ALWCODO    = evalue(GDPO+"ALWCOD")
 [F:EVT0]ALWCODD    = evalue(GDPN+"ALWCOD")
 [F:EVT0]PRATYPO    = evalue(GDPO+"PRATYP")
 [F:EVT0]PRATYPD    = evalue(GDPN+"PRATYP")
 [F:EVT0]MTCDEVADJ  = evalue(GDPN+"MTCDEVADJ")
 #--> Zones numériques
 [F:EVT0]USRFLDM1   = evalue(GFAS+"USRFLDM1")
 [F:EVT0]USRFLDM2   = evalue(GFAS+"USRFLDM2")
 [F:EVT0]USRFLDM3   = evalue(GFAS+"USRFLDM3")
 [F:EVT0]USRFLDM4   = evalue(GFAS+"USRFLDM4")
 [F:EVT0]USRFLDM5   = evalue(GFAS+"USRFLDM5")
 [F:EVT0]USRFLDM6   = evalue(GFAS+"USRFLDM6")
 [F:EVT0]USRFLDC1   = evalue(GFAS+"USRFLDC1")
 [F:EVT0]USRFLDC2   = evalue(GFAS+"USRFLDC2")
 [F:EVT0]DPRDURO    = evalue(GDPO+"DPRDUR")
 [F:EVT0]DPRDURD    = evalue(GDPN+"DPRDUR")
 [F:EVT0]DPRRATO    = evalue(GDPO+"DPRRAT")
 [F:EVT0]DPRRATD    = evalue(GDPN+"DPRRAT")
 [F:EVT0]RSDVALO    = evalue(GDPO+"RSDVAL")
 [F:EVT0]RSDVALD    = evalue(GDPN+"RSDVAL")
 [F:EVT0]DPRRAT2O   = evalue(GDPO+"DPRRAT2")
 [F:EVT0]DPRRAT2D   = evalue(GDPN+"DPRRAT2")
 #--> Zones alphanumériques
 [F:EVT0]ACCCOD     = evalue(GFAS+"ACCCOD")
 [F:EVT0]CUR        = Func GLOFCYCPY.GET_DEVISE_PLN([F:EVT0]CPY,[F:EVT0]DPRPLN)
 [F:EVT0]USRFLDA1   = evalue(GFAS+"USRFLDA1")
 [F:EVT0]USRFLDA2   = evalue(GFAS+"USRFLDA2")
 [F:EVT0]USRFLDA3   = evalue(GFAS+"USRFLDA3")
 [F:EVT0]USRFLDA4   = evalue(GFAS+"USRFLDA4")
 [F:EVT0]USRFLDA5   = evalue(GFAS+"USRFLDA5")
 [F:EVT0]USRFLDA6   = evalue(GFAS+"USRFLDA6")
 [F:EVT0]USRFLDA7   = evalue(GFAS+"USRFLDA7")
 [F:EVT0]USRFLDA8   = evalue(GFAS+"USRFLDA8")
 [F:EVT0]USRFLDA9   = evalue(GFAS+"USRFLDA9")
 [F:EVT0]USRFLDA10  = evalue(GFAS+"USRFLDA10")
 [F:EVT0]DPMO       = evalue(GDPO+"DPM")
 [F:EVT0]DPMD       = evalue(GDPN+"DPM")
 [F:EVT0]CRBVEHCODO = evalue(GDPO+"CRBVEHCOD")
 [F:EVT0]CRBVEHCODD = evalue(GDPN+"CRBVEHCOD")
 #--> Dates
 [F:EVT0]USRFLDD1   = evalue(GFAS+"USRFLDD1")
 [F:EVT0]USRFLDD2   = evalue(GFAS+"USRFLDD2")
 [F:EVT0]USRFLDD3   = evalue(GFAS+"USRFLDD3")
 [F:EVT0]USRFLDD4   = evalue(GFAS+"USRFLDD4")
 [F:EVT0]STRDPRDATO = evalue(GDPO+"STRDPRDAT")
 [F:EVT0]STRDPRDATD = evalue(GDPN+"STRDPRDAT")
 [F:EVT0]ENDDPRDATO = evalue(GDPO+"ENDDPRDAT")
 [F:EVT0]ENDDPRDATD = evalue(GDPN+"ENDDPRDAT")
Return

$ECLATE_NBFLD
 LNBFLD=2
Return

$ECLATE_STATUS
  T_INTNOMZON(0)    = "RSDVALD"
  T_INTNOMZON(1)    = "RSDVALO"
Return

$INFO_EVTINT
 EVT = "FASMTC"
 LPLN= 6
Return

