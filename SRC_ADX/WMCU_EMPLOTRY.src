# Supervisor
## CRUD-CLASSE ## EMPLOTRY
# 2018-11-06 07:06:19 105


############################################################################################
### Subprog _AUPDATE
############################################################################################
Subprog _AUPDATE(EMPLOTRY,ASTATUS)
Variable Instance EMPLOTRY Using C_EMPLOTRY
Variable Integer ASTATUS

If EMPLOTRY = null : End : Endif

Gosub _AVARIABLES From WMC00EMPLOTRY

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AUPDATE_EMPLOTRY

End

#-----------------------------------------------------#

############################################################################################
### Subprog AUPDATE
############################################################################################
Subprog AUPDATE(EMPLOTRY,ASTATUS)
Variable Instance EMPLOTRY Using C_EMPLOTRY
Variable Integer ASTATUS

If EMPLOTRY = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOTRY
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
EMPLOTRY.ASTALIN = [V]CST_AUPD
Gosub AUPDATE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

If !adxlog
 Gosub AUPDATE_TR_EMPLOTRY
Else
 Gosub AUPDATE_EMPLOTRY
Endif
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

Gosub _AUPDATE_AFTER
[L]A_I = EMPLOTRY.freeSnapshot
EMPLOTRY.snapshotEnabled = 1
$AUPDATE_END
End


$AUPDATE_CONTROL
Gosub _AUPDATE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOTRY._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOTRY._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOTRY._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AUPDATE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_BEFORE
If EMPLOTRY.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EMPLOTRY.ASTALIN = [V]CST_AUPD
If [V]CST_ASTALIN(EMPLOTRY.ASTALIN)<>""
 [L]A_ASTALIN = EMPLOTRY.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOTRY.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif

Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_AFTER

If [V]CST_ASTALIN(EMPLOTRY.ASTALIN)<>""
 [L]A_ASTALIN = EMPLOTRY.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOTRY.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
Return

#-----------------------------------------------------#
$AUPDATE_TR_EMPLOTRY
Trbegin [F:TRY]
 Gosub AUPDATE_EMPLOTRY
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AUPDATE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AUPDATE_EMPLOTRY
[L]A_ASTALIN = EMPLOTRY.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOTRY.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EMPLOTRY._MAJSQL_EMPLOTRY(EMPLOTRY))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


[L]A_ASTALIN = EMPLOTRY.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOTRY.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AUPDATE_ABORT
Rollback
$_AUPDATE_ABORT
If EMPLOTRY.snapshotEnabled=1
 [L]A_RETIK = EMPLOTRY.revertUpdTick
Endif

[L]ASTATUS = max(fmet EMPLOTRY.ACTION("AUPDATE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AUPDATE_AFTER
If find(EMPLOTRY.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 EMPLOTRY.ASTALIN = [V]CST_ALL
Endif
Return



