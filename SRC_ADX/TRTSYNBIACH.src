#<AdxTL>@(#)0.0.0.0 $Revision$
#############################################################################
# TRTSYNBIACH      Fonctions pour la Business Intelligence           Achats #
#############################################################################

###################################################################################
# 12/01/2010 (SYMEU) : Problème dans la requête sql avec les demandes de livraison#
# Fiche 61511          fermes quand on est sous sql                               #
###################################################################################

###################################################################
## ACTION Mise à jour des tables de faits X3                      #
###################################################################
$ACTION
Case ACTION
 When "AVANT_FAT"  : Gosub AVANT_FAT
 When "DEBUT_FAT"  : Gosub DEBUT_FAT
 When "FIN_FAT"    : Gosub FIN_FAT
Endcase
Return

#############################################################################
# Ouverture des tables qui sont appelées par les fonctions alimentant les
# champs de la table de faits
#############################################################################
$AVANT_FAT
GDOSSIER=left$(TBAPP(R),K-1)

Gosub AVANT_FAT_COMMUN

Case [F:ABV]CODREG
  When "PORDER"                   : Gosub AVANT_FAT_PORDER
  When "PORDERINV"                : Gosub AVANT_FAT_PORDERINV
  When "PRECEIPT"                 : Gosub AVANT_FAT_PRECEIPT
  When "PRECEIPTIN"               : Gosub AVANT_FAT_PRECEIPTIN
  When "PREQUIS", "PREQUISO"      : Gosub AVANT_FAT_PREQUIS_PREQUISO
  When "PRETURN"                  : Gosub AVANT_FAT_PRETURN
  When "PINVOICE"                 : Gosub AVANT_FAT_PINVOICE
  When "PINVOICEDU", "PINVOICEIN" : Gosub AVANT_FAT_PINVOICEDU_PINVOICEIN
Endcase

Return

#############################################################################
$AVANT_FAT_COMMUN
  #--- Méthode SETLEG de ADOVAL, TRTX3BI.SETACC, TRTX3BI.GETCUR
  If !clalev([F:CPY])   : Local File =GDOSSIER+".COMPANY"   [CPY] : Endif
  #--- Méthode TRTX3BI.GETSYSCUR
  If !clalev([F:ADW])   : Local File =GDOSSIER+".ADOVAL"    [ADW] : Endif
  If !clalev([F:ADP])   : Local File =GDOSSIER+".ADOPAR"    [ADP] : Endif
  #--- Méthode TRTX3BI.CNVAMT
  If !clalev([F:TCH])   : Local File =GDOSSIER+".TABCHANGE" [TCH] : Endif
  If dim([V]GEURODEV)<1 Then
    If !clalev([F:TCU]) : Local File =GDOSSIER+".TABCUR"    [TCU] : Endif
  Endif
  #--- Méthode TRTX3BI.GETCUR
  If !clalev([F:FCY])   : Local File =GDOSSIER+".FACILITY"  [FCY] : Endif
  #--- Méthode TRTX3BI.CNVQTY
  If !clalev([F:ITM])   : Local File =GDOSSIER+".ITMMASTER" [ITM] : Endif
  #--- Méthode TRTX3BI.SETCOA et SETACC
  If !clalev([F:GCM])   : Local File =GDOSSIER+".GACM"      [GCM] : Endif
  If !clalev([F:LED])   : Local File =GDOSSIER+".GLED"      [LED] : Endif
  #--- Méthode TRTX3BI.SETACC
  If !clalev([F:GAC])   : Local File =GDOSSIER+".GACCOUNT"  [GAC] : Endif

Return

#############################################################################
$AVANT_FAT_PORDER
  #--- Méthode TRTACHBI.GETPOHCPR, GETPURDCA, GETPFIDCA
  If !clalev([F:POH]) : Local File =GDOSSIER+".PORDER"     [POH] : Endif
  If !clalev([F:POQ]) : Local File =GDOSSIER+".PORDERQ"    [POQ] : Endif
  If !clalev([F:POP]) : Local File =GDOSSIER+".PORDERP"    [POP] : Endif
  If !clalev([F:BPS]) : Local File =GDOSSIER+".BPSUPPLIER" [BPS] : Endif
  If !clalev([F:PRS]) : Local File =GDOSSIER+".PRICSTRUCT" [PRS] : Endif
  If !clalev([F:PFI]) : Local File =GDOSSIER+".PFOOTINV"   [PFI] : Endif
Return

#############################################################################
$AVANT_FAT_PORDERINV
  #--- Méthode TRTX3BI.GETLASTLIN
  If !clalev([F:POQ])  : Local File =GDOSSIER+".PORDERQ"   [POQ]  : Endif
Return

#############################################################################
$AVANT_FAT_PRECEIPT
  #--- Méthode TRTACHBI.GETPURDCA, GETPFICA
  If !clalev([F:PTH])  : Local File =GDOSSIER+".PRECEIPT"  [PTH]  : Endif
  If !clalev([F:PTD])  : Local File =GDOSSIER+".PRECEIPTD" [PTD]  : Endif
Return

#############################################################################
$AVANT_FAT_PRECEIPTIN
  #--- Méthode TRTX3BI.GETLASTLIN
  If !clalev([F:PTD])  : Local File =GDOSSIER+".PRECEIPTD" [PTD]  : Endif
Return

#############################################################################
$AVANT_FAT_PREQUIS_PREQUISO
  #--- Méthode TRTACHBI.GETPURDCA
  If !clalev([F:PSH])  : Local File =GDOSSIER+".PREQUIS"  [PSH]   : Endif
  If !clalev([F:PSD])  : Local File =GDOSSIER+".PREQUISD" [PSD]   : Endif
Return

#############################################################################
$AVANT_FAT_PRETURN
  #--- Méthode TRTACHBI.GETPURDCA
  If !clalev([F:PNH])  : Local File =GDOSSIER+".PRETURN"    [PNH] : Endif
  If !clalev([F:PND])  : Local File =GDOSSIER+".PRETURND"   [PND] : Endif
  If !clalev([F:BPS])  : Local File =GDOSSIER+".BPSUPPLIER" [BPS] : Endif
Return

#############################################################################
$AVANT_FAT_PINVOICE
  #--- Méthode TRTACHBI.GETPIHFCY, GETPFIDCA
  If !clalev([F:PID])  : Local File =GDOSSIER+".PINVOICED" [PID]  : Endif
  If !clalev([F:PIDB]) : Local File =GDOSSIER+".PINVOICED" [PIDB] : Endif
  If !clalev([F:PID2]) : Local File =GDOSSIER+".PINVOICED" [PID2] : Endif
  If !clalev([F:POQ])  : Local File =GDOSSIER+".PORDERQ"   [POQ]  : Endif
  If !clalev([F:PTD])  : Local File =GDOSSIER+".PRECEIPTD" [PTD]  : Endif
  If !clalev([F:PND])  : Local File =GDOSSIER+".PRETURND"  [PND]  : Endif
  If !clalev([F:FCY2]) : Local File =GDOSSIER+".FACILITY"  [FCY2] : Endif
  #--- Méthode TRTACHBI.GETPURDCA, GETPFICA
  If !clalev([F:PIH])  : Local File =GDOSSIER+".PINVOICE"  [PIH]  : Endif
  #--- Méthode TRTACHBI.GETPFIDCA
  If !clalev([F:PIV])  : Local File =GDOSSIER+".PINVOICEV" [PIV]  : Endif
Return

#############################################################################
$AVANT_FAT_PINVOICEDU_PINVOICEIN
  #--- Méthode TRTACHBI.GETPFIFCY, TRTX3BI.GETLASTLIN
  If !clalev([F:PID])  : Local File =GDOSSIER+".PINVOICED" [PID]  : Endif
Return

#############################################################################
$DEBUT_FAT
  #  Variable globale pour récupérer la devise dossier
  If dim(GBICURFOLD)<=0 Then
    Global Char GBICURFOLD(GLONCUR)
  Endif
  GBICURFOLD = func TRTX3BI.GETSYSCUR()
#Case TABLE
#Endcase
Return

#############################################################################
$FIN_FAT
Gosub DECL_VAR

Case TABLE
 When "F_PURCHASE"     : Gosub FIN_PURCHASE  # Table Faits PURCHASE
Endcase
#Gosub KILL_GLOBALES
Return

#############################################################################
$KILL_GLOBALES
If dim(GBICURFOLD)>0 Then Kill GBICURFOLD Endif
Return

#############################################################################
# Alimentation de la table de faits PURCHASE avec des données supplémentaires
#############################################################################
$FIN_PURCHASE
If [F:ABV]CODREG = "PORDER" Then
  Local File =DOSSIER+"."+TABLE [BBB_]
  Gosub FIN_PURCHASE_ORDER
  Close Local File [BBB_]
Endif
Return

##############################################################################################
# Alimentation de la table de faits PURCHASE avec les demandes de livraison issues de PORDERQ
##############################################################################################
$FIN_PURCHASE_ORDER
  Local Char WREQ3 (255)(2) : Raz WREQ3 # Requete pour lire PORDERP
  Local Char STU(GLONUOM), SSU(GLONUOM), POHFCY_CUR(GLONCUR), BPSGRU(GLONBPR), BPSRSK(GLONBPR), FINRSPFCY(GLONFCY)  # FGR 09/10/2014 : X3SUIVI102999 : manquait les longueurs
  Decimal MONTANT

  # Pour que, dans les fonctions BICPT.SETDIE(...), BICPT.SETCCE(...), la variable globale soit rechargée
  # avec les données du bon dossier et que les tables soient ouvertes sur le bon dossier
  If dim([V]GBIDIELIST)>0 : Kill [V]GBIDIELIST : Endif

  If filinfo(filpath("FIL","PORDERQ","fde",GDOSSIER),0)>0
    Call ECR_TRACE("**   TRTSYNBIACH : PORDERQ"-mess(6,2246,1)-"PORDER",0) From GESECRAN
    # Requête de sélection des enregistrements de PORDERQ
    WREQ(0)= "select POQ.POHNUM_0, POQ.POPLIN_0, POQ.POQSEQ_0, POQ.PRHFCY_0, POQ.ITMREF_0, POQ.LINPURTYP_0, "
    WREQ(0)+="POQ.QTYSTU_0, POQ.RCPQTYSTU_0, POQ.LINAMT_0, POQ.LINATIAMT_0, POQ.DEDTAXLIN1_0, POQ.DEDTAXLIN2_0, "
    WREQ(0)+="POQ.DEDTAXLIN3_0, POQ.DEDTAXRCP_0, POQ.DEDTAXISS_0, "
    WREQ(1)= "POQ.DEDTAXOTH1_0, POQ.DEDTAXOTH2_0, POQ.DISCRGAMT1_0, POQ.DISCRGAMT2_0, POQ.DISCRGAMT3_0, "
    WREQ(1)+="POQ.DISCRGAMT4_0, POQ.DISCRGAMT5_0, POQ.DISCRGAMT6_0, POQ.DISCRGAMT7_0, POQ.DISCRGAMT8_0, "
    WREQ(1)+="POQ.DISCRGAMT9_0, POQ.DEMRCPDAT_0, POH.ORDDAT_0, POH.CPY_0, "
    WREQ(2)= "POH.BETCPY_0, POH.POHFCY_0, POH.BETFCY_0, POH.BPSNUM_0, POH.BPSINV_0, POH.BPRPAY_0, POH.CUR_0, POH.CHGTYP_0 "
    WREQ(2)+="From "+GDOSSIER+".PORDERQ POQ,"+GDOSSIER+".PORDER POH "
    WREQ(2)+="Where POQ.POHTYP_0=2 and POQ.WIPSTA_0=1 and POH.POHNUM_0=POQ.POHNUM_0 "
# FGR 10/10/2014 : X3SUIVI102999
#    For (Char POHNUM(20), Integer POPLIN, Integer POQSEQ, Char PRHFCY(5), Char ITMREF(20), Integer LINPURTYP,
#&       Decimal QTYSTU, Decimal RCPQTYSTU, Decimal LINAMT, Decimal LINATIAMT, Decimal DEDTAXLIN1,
#&       Decimal DEDTAXLIN2, Decimal DEDTAXLIN3, Decimal DEDTAXRCP, Decimal DEDTAXISS, Decimal DEDTAXOTH1,
#&       Decimal DEDTAXOTH2, Decimal DISCRGAMT1, Decimal DISCRGAMT2, Decimal DISCRGAMT3, Decimal DISCRGAMT4,
#&       Decimal DISCRGAMT5, Decimal DISCRGAMT6, Decimal DISCRGAMT7, Decimal DISCRGAMT8, Decimal DISCRGAMT9,
#&       Date DEMRCPDAT, Date ORDDAT, Char CPY(5), Integer BETCPY, Char POHFCY(5), Integer BETFCY,
#&       Char BPSNUM(15), Char BPSINV(15), Char BPRPAY(15), Char CUR(3), Integer CHGTYP)
#&       From WBASE Sql WREQ(0..2) As [REQ_]
    For (Char POHNUM(GLONPOH), Integer POPLIN, Integer POQSEQ, Char PRHFCY(GLONFCY), Char ITMREF(GLONITM), Integer LINPURTYP,
&       Decimal QTYSTU, Decimal RCPQTYSTU, Decimal LINAMT, Decimal LINATIAMT, Decimal DEDTAXLIN1,
&       Decimal DEDTAXLIN2, Decimal DEDTAXLIN3, Decimal DEDTAXRCP, Decimal DEDTAXISS, Decimal DEDTAXOTH1,
&       Decimal DEDTAXOTH2, Decimal DISCRGAMT1, Decimal DISCRGAMT2, Decimal DISCRGAMT3, Decimal DISCRGAMT4,
&       Decimal DISCRGAMT5, Decimal DISCRGAMT6, Decimal DISCRGAMT7, Decimal DISCRGAMT8, Decimal DISCRGAMT9,
&       Date DEMRCPDAT, Date ORDDAT, Char CPY(GLONCPY), Integer BETCPY, Char POHFCY(GLONFCY), Integer BETFCY,
&       Char BPSNUM(GLONBPR), Char BPSINV(GLONBPR), Char BPRPAY(GLONBPR), Char CUR(GLONCUR), Integer CHGTYP)
&       From WBASE Sql WREQ(0..2) As [REQ_]
      Read [BBB_]PIH0 = GDOSSIER;[F:ABV]CODREG;0;[REQ_]POHNUM+"~"+num$([REQ_]POPLIN)+"~"+num$([REQ_]POQSEQ)
      If fstat
        # Lecture de l'article
        Call GET_ITM_UNITS([REQ_]ITMREF,STU,SSU) From TRTX3BI
        # Lecture de la devise du site
        POHFCY_CUR = func TRTX3BI.GETCUR([REQ_]POHFCY)
        # Lecture du fournisseur groupe et du fournisseur risque
        Call GET_BPS_GRU_RSK([REQ_]BPSNUM,BPSGRU,BPSRSK) From TRTX3BI
        Raz [BBB_]
        # Alimentation de la clé primaire PIH0
        [BBB_]ADOS=GDOSSIER
        [BBB_]AREG=[F:ABV]CODREG
        [BBB_]AIND=0
        [BBB_]ACLE=[REQ_]POHNUM+"~"+num$([REQ_]POPLIN)+"~"+num$([REQ_]POQSEQ)
        # Alimentation de la dimension PORDER avec les demandes de livraison
        [BBB_]DOC=3
        [BBB_]LINDOC=1
        [BBB_]DOSSIER=GDOSSIER
        [BBB_]DAT=[REQ_]ORDDAT
        [BBB_]CPY=[REQ_]CPY
        # Lecture de LEGCPY de F:FCY
        Call GET_FINRSPFCY([REQ_]POHFCY,FINRSPFCY) From TRTX3BI
        [BBB_]FCY=FINRSPFCY
        #--CPO 80479 - Rajout de if dim(), en plus des CCE,COA,DIE et ACC
        If dim([BBB_]PURFCY)>0    :[BBB_]PURFCY=[REQ_]POHFCY        : Endif
        If dim([BBB_]STOFCY)>0    :[BBB_]STOFCY=[REQ_]PRHFCY        : Endif
        If dim([BBB_]BPSORD)>0    :[BBB_]BPSORD=[REQ_]BPSNUM        : Endif
        If dim([BBB_]BPSINV)>0    :[BBB_]BPSINV=[REQ_]BPSINV        : Endif
        If dim([BBB_]BPSPAY)>0    :[BBB_]BPSPAY=[REQ_]BPRPAY        : Endif
        If dim([BBB_]BPSGRU)>0    :[BBB_]BPSGRU=BPSGRU              : Endif
        If dim([BBB_]BPSRSK)>0    :[BBB_]BPSRSK=BPSRSK              : Endif
        If dim([BBB_]CUR)>0       :[BBB_]CUR=[REQ_]CUR              : Endif
        If dim([BBB_]CURLOC)>0    :[BBB_]CURLOC=POHFCY_CUR          : Endif
        If dim([BBB_]CURFOLD)>0   :[BBB_]CURFOLD=GBICURFOLD         : Endif
        If dim([BBB_]ITMREF)>0    :[BBB_]ITMREF=[REQ_]ITMREF        : Endif
        If dim([BBB_]AMTSIG)>0    :[BBB_]AMTSIG=1                   : Endif
        If dim([BBB_]LINPURTYP)>0 :[BBB_]LINPURTYP=[REQ_]LINPURTYP  : Endif
        #--/CPO
        [BBB_]POHNUM=[REQ_]POHNUM
        [BBB_]POPLIN=[REQ_]POPLIN
        [BBB_]POQSEQ=[REQ_]POQSEQ
        # Attention : champs soumis à code activité
        If dim([BBB_]DIE1)>0 : [BBB_]DIE1=func BICPT.SETDIE(1,"CAL") : Endif
        If dim([BBB_]DIE2)>0 : [BBB_]DIE2=func BICPT.SETDIE(2,"CAL") : Endif
        If dim([BBB_]DIE3)>0 : [BBB_]DIE3=func BICPT.SETDIE(3,"CAL") : Endif
        If dim([BBB_]DIE4)>0 : [BBB_]DIE4=func BICPT.SETDIE(4,"CAL") : Endif
        If dim([BBB_]DIE5)>0 : [BBB_]DIE5=func BICPT.SETDIE(5,"CAL") : Endif
        If dim([BBB_]DIE6)>0 : [BBB_]DIE6=func BICPT.SETDIE(6,"CAL") : Endif
        If dim([BBB_]DIE7)>0 : [BBB_]DIE7=func BICPT.SETDIE(7,"CAL") : Endif
        If dim([BBB_]DIE8)>0 : [BBB_]DIE8=func BICPT.SETDIE(8,"CAL") : Endif
        If dim([BBB_]DIE9)>0 : [BBB_]DIE9=func BICPT.SETDIE(9,"CAL") : Endif
        If dim([BBB_]DIE10)>0 : [BBB_]DIE10=func BICPT.SETDIE(10,"CAL") : Endif
        If dim([BBB_]CCE1)>0 : [BBB_]CCE1=func BICPT.SETCCE(1,"CAL") : Endif
        If dim([BBB_]CCE2)>0 : [BBB_]CCE2=func BICPT.SETCCE(2,"CAL") : Endif
        If dim([BBB_]CCE3)>0 : [BBB_]CCE3=func BICPT.SETCCE(3,"CAL") : Endif
        If dim([BBB_]CCE4)>0 : [BBB_]CCE4=func BICPT.SETCCE(4,"CAL") : Endif
        If dim([BBB_]CCE5)>0 : [BBB_]CCE5=func BICPT.SETCCE(5,"CAL") : Endif
        If dim([BBB_]CCE6)>0 : [BBB_]CCE6=func BICPT.SETCCE(6,"CAL") : Endif
        If dim([BBB_]CCE7)>0 : [BBB_]CCE7=func BICPT.SETCCE(7,"CAL") : Endif
        If dim([BBB_]CCE8)>0 : [BBB_]CCE8=func BICPT.SETCCE(8,"CAL") : Endif
        If dim([BBB_]CCE9)>0 : [BBB_]CCE9=func BICPT.SETCCE(9,"CAL") : Endif
        If dim([BBB_]CCE10)>0 : [BBB_]CCE10=func BICPT.SETCCE(10,"CAL") : Endif
        If dim([BBB_]COA1)>0 : [BBB_]COA1=func TRTX3BI.SETCOA(1,[REQ_]CPY) : Endif
        If dim([BBB_]COA2)>0 : [BBB_]COA2=func TRTX3BI.SETCOA(2,[REQ_]CPY) : Endif
        If dim([BBB_]COA3)>0 : [BBB_]COA3=func TRTX3BI.SETCOA(3,[REQ_]CPY) : Endif
        If dim([BBB_]ACC1)>0 : [BBB_]ACC1=func TRTX3BI.SETACC(1,[REQ_]CPY) : Endif
        If dim([BBB_]ACC2)>0 : [BBB_]ACC2=func TRTX3BI.SETACC(2,[REQ_]CPY) : Endif
        If dim([BBB_]ACC3)>0 : [BBB_]ACC3=func TRTX3BI.SETACC(3,[REQ_]CPY) : Endif
        #--CPO 80479 - Rajout de if dim(), en plus des CCE,COA,DIE et ACC
        If dim([BBB_]FLOW)>0
          [BBB_]FLOW=([REQ_]BETCPY - 1) * 2 + !( [REQ_]BETCPY - 1) * ( ([REQ_]BETFCY - 1) * 3 + !( [REQ_]BETFCY - 1))
        Endif
        If dim([BBB_]QTYPOH_US)>0 : [BBB_]QTYPOH_US=[REQ_]QTYSTU : Endif
        If dim([BBB_]QTYPOH_ST)>0
          [BBB_]QTYPOH_ST=func TRTX3BI.CNVQTY([REQ_]QTYSTU, STU, SSU, [REQ_]ITMREF, "POQ", [REQ_]POHNUM, [REQ_]POPLIN, [REQ_]POQSEQ, 1, 0)
        Endif
        If dim([BBB_]QTYPOD_US)>0 : [BBB_]QTYPOD_US=[REQ_]QTYSTU-[REQ_]RCPQTYSTU : Endif
        If dim([BBB_]QTYPOD_ST)>0
          [BBB_]QTYPOD_ST=func TRTX3BI.CNVQTY([REQ_]QTYSTU-[REQ_]RCPQTYSTU, STU, SSU, [REQ_]ITMREF, "POQ", [REQ_]POHNUM, [REQ_]POPLIN, [REQ_]POQSEQ, 1, 0)
        Endif

        MONTANT = [REQ_]LINAMT
        If dim([BBB_]AMTNOT_POH)  >0 : [BBB_]AMTNOT_POH=MONTANT : Endif
        If dim([BBB_]AMTNOT_POH_C)>0
          [BBB_]AMTNOT_POH_C=func TRTX3BI.CNVAMT([REQ_]CUR, POHFCY_CUR, POHFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif
        If dim([BBB_]AMTNOT_POH_F)>0
          [BBB_]AMTNOT_POH_F=func TRTX3BI.CNVAMT([REQ_]CUR, [BBB_]CURFOLD, POHFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif

        MONTANT = [REQ_]LINATIAMT
        If dim([BBB_]AMTATI_POH)  >0 : [BBB_]AMTATI_POH=MONTANT : Endif
        If dim([BBB_]AMTATI_POH_C)>0
          [BBB_]AMTATI_POH_C=func TRTX3BI.CNVAMT([REQ_]CUR, POHFCY_CUR, POHFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif
        If dim([BBB_]AMTATI_POH_F)>0
          [BBB_]AMTATI_POH_F=func TRTX3BI.CNVAMT([REQ_]CUR, [BBB_]CURFOLD, POHFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif

        MONTANT = [REQ_]DEDTAXLIN1 + [REQ_]DEDTAXLIN2 + [REQ_]DEDTAXLIN3 + [REQ_]DEDTAXRCP + [REQ_]DEDTAXISS + [REQ_]DEDTAXOTH1 + [REQ_]DEDTAXOTH2
        If dim([BBB_]AMTDED_POH)  >0 : [BBB_]AMTDED_POH=MONTANT : Endif
        If dim([BBB_]AMTDED_POH_C)>0
          [BBB_]AMTDED_POH_C=func TRTX3BI.CNVAMT([REQ_]CUR, POHFCY_CUR, POHFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif
        If dim([BBB_]AMTDED_POH_F)>0
          [BBB_]AMTDED_POH_F=func TRTX3BI.CNVAMT([REQ_]CUR, [BBB_]CURFOLD, POHFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif

        MONTANT = func TRTACHBI.GETPOHCPR([REQ_]POHNUM, [REQ_]POPLIN, [REQ_]POQSEQ, POHFCY_CUR)
        If dim([BBB_]CPR_POH)  >0 : [BBB_]CPR_POH=MONTANT : Endif
        If dim([BBB_]CPR_POH_C)>0
          [BBB_]CPR_POH_C=func TRTX3BI.CNVAMT([REQ_]CUR, POHFCY_CUR, POHFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif
        If dim([BBB_]CPR_POH_F)>0
          [BBB_]CPR_POH_F=func TRTX3BI.CNVAMT([REQ_]CUR, [BBB_]CURFOLD, POHFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif

        MONTANT=func TRTACHBI.GETPURDCA(1,[REQ_]POHNUM,[REQ_]POPLIN,[REQ_]POQSEQ, [REQ_]CUR,2)
        If dim([BBB_]DISAMT_POH)  >0 : [BBB_]DISAMT_POH=MONTANT : Endif
        If dim([BBB_]DISAMT_POH_C)>0
          [BBB_]DISAMT_POH_C=func TRTX3BI.CNVAMT([REQ_]CUR, POHFCY_CUR, POHFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif
        If dim([BBB_]DISAMT_POH_F)>0
          [BBB_]DISAMT_POH_F=func TRTX3BI.CNVAMT([REQ_]CUR, [BBB_]CURFOLD, POHFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif

        MONTANT=func TRTACHBI.GETPURDCA(1,[REQ_]POHNUM,[REQ_]POPLIN,[REQ_]POQSEQ, [REQ_]CUR,1)
        If dim([BBB_]EXPAMT_POH)  >0 : [BBB_]EXPAMT_POH=MONTANT : Endif
        If dim([BBB_]EXPAMT_POH_C)>0
          [BBB_]EXPAMT_POH_C=func TRTX3BI.CNVAMT([REQ_]CUR, POHFCY_CUR, POHFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif
        If dim([BBB_]EXPAMT_POH_F)>0
          [BBB_]EXPAMT_POH_F=func TRTX3BI.CNVAMT([REQ_]CUR, [BBB_]CURFOLD, POHFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif

        MONTANT=func TRTACHBI.GETPFIDCA(1,[REQ_]POHNUM,[REQ_]POPLIN,[REQ_]POQSEQ, [REQ_]CUR,2)
        If dim([BBB_]DISDTA_POH)  >0 : [BBB_]DISDTA_POH=MONTANT : Endif
        If dim([BBB_]DISDTA_POH_C)>0
          [BBB_]DISDTA_POH_C=func TRTX3BI.CNVAMT([REQ_]CUR, POHFCY_CUR, POHFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif
        If dim([BBB_]DISDTA_POH_F)>0
          [BBB_]DISDTA_POH_F=func TRTX3BI.CNVAMT([REQ_]CUR, [BBB_]CURFOLD, POHFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif

        MONTANT=func TRTACHBI.GETPFIDCA(1,[REQ_]POHNUM,[REQ_]POPLIN,[REQ_]POQSEQ, [REQ_]CUR,1)
        If dim([BBB_]EXPDTA_POH)  >0 : [BBB_]EXPDTA_POH=MONTANT : Endif
        If dim([BBB_]EXPDTA_POH_C)>0
          [BBB_]EXPDTA_POH_C=func TRTX3BI.CNVAMT([REQ_]CUR, POHFCY_CUR, POHFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif
        If dim([BBB_]EXPDTA_POH_F)>0
          [BBB_]EXPDTA_POH_F=func TRTX3BI.CNVAMT([REQ_]CUR, [BBB_]CURFOLD, POHFCY_CUR, [REQ_]CHGTYP, 0, 0, [REQ_]ORDDAT, MONTANT)
        Endif

        # Pour chaque demande de livraison, je vais rechercher le bon enregistrement dans PORDERP
        If dim([BBB_]PJT)>0
          WREQ3(0)= "select POP.PJT_0 From "+GDOSSIER+".PORDERP POP "
          WREQ3(1)= "Where POP.POHNUM_0='"+[REQ_]POHNUM+"' and POP.POPLIN_0="+num$([REQ_]POPLIN)+" and POP.STRDAT_0<="
          If WBASE = "3" Then # Oracle
             WREQ3(1)+="TO_DATE('"+[REQ_]DEMRCPDAT+"','YYYYMMDD')"
          Else
            #WREQ3(1)+="'"+num$([REQ_]DEMRCPDAT)+"'"       # SYMEU 61511
             WREQ3(1)+="convert(char,"+[REQ_]DEMRCPDAT+")" # SYMEU 61511
          Endif
          WREQ3(1)+= " Order by POP.STRDAT_0 desc"
          For (Char PJT(20)) From WBASE Sql WREQ3(0..1) As [RE3_]
            # Issue 78039 - 2016-08-09 by CPO : PJT management in BI
            #[BBB_]PJT=[RE3_]PJT
            [BBB_]PJT=func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT_OPPNUM(GACTX, [RE3_]PJT)
            # End issue 78039
            Break # On ne prend que le premier enregistrement de PORDERP
          Next
        Endif :#--/CPO
        CHAINE = [BBB_]POHNUM-num$([BBB_]POPLIN)-num$([BBB_]POQSEQ)
        Write [BBB_]
        If fstat
          Call ERREUR(TABLE-CHAINE,1) From DOSDIC
        Else
          CRE += 1
          If [L]DET=2
            Call ECR_TRACE("**   "+mess(59,123,1)-CHAINE,0) From GESECRAN
          Endif
        Endif
      Endif
    Next
  Endif

Return

###################################################################
# Déclarations des variables de travail communes
###################################################################
$DECL_VAR
Local Char WREQ (255)(3) : Raz WREQ : # Requete générique pour base Oracle et SqlServer 7
Local Integer D
Local Integer NB_ENREG : NB_ENREG=0
Local Char WBASE(1)       : WBASE=" "  # FGR 09/10/2014 : X3SUIVI102999 : Manquait (1)
# Alimentation du type de Database
Gosub ALIM_WBASE

Return

###################################################################
## ALIM_WBASE alimentation de la variable donnant le type de       #
## DATABASE à partir de GTYPDBA                                   #
###################################################################
$ALIM_WBASE
Case GTYPDBA
  When 1 : WBASE = "3" : # Oracle
  When 2 : WBASE = "5" : # Sql
  When 3 : WBASE = "2" : # Cisam
  When 4 : WBASE = "4" : # DB2
Endcase
Return

