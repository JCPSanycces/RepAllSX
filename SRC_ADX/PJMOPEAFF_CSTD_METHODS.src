#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe PJMOPEAFF (Operation Assignments)
###################################################################################################
# METHODS
###################################################################################################
$SETERROR
#Value Char PRO ()
#Value Char MES ()
#Value Integer STA
#Local Integer ARET_VALUE

Local Char SLEVEL(250)

  # Issue X3-51863 - 2017-08-07 by FGR
  SLEVEL = func AFNC.MES4(mess(946,2260,1), this.OPPNUM, this.TASCOD, num$(this.OPENUM), num$(this.POANUM))  # + "/" + num$(this.OPESPLNUM) this part of the PK is still =1 not visible to the end user
  #[L]ARET_VALUE = fmet this.ASETERROR (PRO, SLEVEL + "\" + MES, STA)                                                    # Issue X3-85933 - 2018-06-19 by FGR
  [L]ARET_VALUE = fmet this.ASETERROR (func OPPOR_CSTD_PROGS_COM.GET_PROPERTY_TITLE(this, PRO), SLEVEL + "\" + MES, STA) # Issue X3-85933 - 2018-06-19 by FGR
Return

###################################################################################################
$COPY   # Issue X3-24095/121425 - 2017-03-15 by EUHAV : BEGIN
#Variable Instance TARGET Using C_PJMOPEAFF
#Variable Instance TECCLA Using C_PJMACOPY
#Value Integer TECIDX
#Local Integer ARET_VALUE

Local Instance TECPJMCOPY Using C_TECPJMCOPY     # Issue X3-29531 - 2017-04-21 by FGR

  # Issue X3-29531 - 2017-04-21 by FGR : BEGIN
  [L]ARET_VALUE = [V]CST_AOK
  # --------------------
  TECPJMCOPY = NewInstance C_TECPJMCOPY AllocGroup null
  [L]ARET_VALUE = fmet this.COPY_LOAD_PROPERTIES(TECPJMCOPY, TECCLA, TECIDX)
  If [L]ARET_VALUE >= [V]CST_AERROR Then
    Call MSGSTACK_COPY_TO(TECPJMCOPY, this) From SYRSTACKTOOLS  # Get the error from the TARGET class into the this class
    Goto COPY_END
  Endif
  # --------------------
  # 1°) copy properties and translated texts
  [L]ARET_VALUE = func TECPJMCOPY_CSTD.DO_COPY_CHAIN(TECPJMCOPY, TECCLA, this, TARGET)
  If [L]ARET_VALUE >= [V]CST_AERROR Then
    Call MSGSTACK_COPY_TO(TECPJMCOPY, this) From SYRSTACKTOOLS  # Get the error from the TARGET class into the this class
    Goto COPY_END
  Endif
  # --------------------
$COPY_END
  If TECPJMCOPY <> null Then
    FreeGroup TECPJMCOPY
  Endif
Return

###################################################################################################
$COPY_LOAD_PROPERTIES
#Variable Instance TECPJMCOPY Using C_TECPJMCOPY : #
#Variable Instance TECCLA Using C_PJMACOPY : #
#Value Integer TECIDX
#Local Integer ARET_VALUE

  # Issue X3-29531 - 2017-04-21 by FGR
  [L]ARET_VALUE = [V]CST_AOK
  # --------------------
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("POACLB", AVOID.ACHAR))
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("POADES", AVOID.ACHAR))
  If TECCLA.TASASSDAT = [V]CST_ANO Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("POASTR", AVOID.ACHAR))
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("POASTRHM", AVOID.ACHAR))
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("POAEND", AVOID.ACHAR))
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("POAENDHM", AVOID.ACHAR))
  Endif
  #Copy all descriptions
  If TECCLA.TASASSDES = [V]CST_AYES Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("POALGDES", AVOID.ACHAR))
  Endif
  #Copy all comments (CLOB)
  If TECCLA.TASASSCOM = [V]CST_AYES Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("POALGCOM", AVOID.ACHAR))
  Endif
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet TECPJMCOPY.LOAD("POASTDQTY", AVOID.ACHAR))
Return

###################################################################################################
# Issue X3-28427/122128 - 2017-03-21 by FGR : BEGIN
$LOAD_POACST_POACSTLAB
#Local Integer ARET_VALUE

Local Decimal NPAUSCST
Local Integer ISTAT
Local Char SDIMUOM(GLONUOM)

  # Issue X3-17556/120812 - 2017-01-10 by FGR
  # ---------------------------
  [L]ARET_VALUE = [V]CST_AOK
  # ---------------------------
  Local File PJMAUS [PAUS]
  If this.ASTALIN = [V]CST_ANEW or (this.ASTALIN = [V]CST_AUPD and this.POACLB <> this.snapshot.POACLB) Then
    # ---------------------------
    Read [PAUS]PAUS=this.POACLB
    # ---------------------------
    If [F:PAUS]PAUSCUR <> AVOID.ACHAR and [F:PAUS]PAUSCST > 0 Then
      NPAUSCST = [F:PAUS]PAUSCST
      If this.CUR <> [F:PAUS]PAUSCUR Then
        Call CONVERT(this.ACTX, [F:PAUS]PAUSCUR, this.CUR, this.CUR, this.TCHCHGTYP, this.POASTR, NPAUSCST, NPAUSCST, ISTAT) From TRTDEV_SYRA
        If ISTAT <> 0 Then
          [L]ARET_VALUE = fmet this.SETERROR("", func AFNC.MES2(mess(491,2260,1), [F:PAUS]PAUSCUR, this.CUR), [V]CST_AERROR)
          Return
        Endif
      Endif
      this.POACST = NPAUSCST
      # ---------------------------
      SDIMUOM = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, this.ACTX.AFOLDER, "HOURLYUNIT")
      If this.POUOM <> SDIMUOM Then
        Call CONVERT_QTY(this.ACTX, this.POUOM, SDIMUOM, NPAUSCST) From TRTX3_SYRA
      Endif
      this.POACSTLAB = NPAUSCST
    Else
      this.POACST = this.TCHOPECST
      this.POACSTLAB = this.TCHOPECST2
    Endif
  Elsif this.ASTALIN = [V]CST_AUPD Then
    Read [PAUS]PAUS=this.POACLB
    If [F:PAUS]PAUSCUR = AVOID.ACHAR or [F:PAUS]PAUSCST = 0 Then
      If this.TCHOPECST <> this.snapshot.TCHOPECST Then
        this.POACST = this.TCHOPECST
      Endif
      If this.TCHOPECST2 <> this.snapshot.TCHOPECST2 Then
        this.POACSTLAB = this.TCHOPECST2
      Endif
    Endif
  Endif
Return

###################################################################################################
$PROGRESS
# Issue X3-29489 - 2017-04-04 by SINGC
#Value Decimal CSMQTY
#Value Decimal RMNQTY
#Local Decimal ARET_VALUE

  [L]ARET_VALUE = 0
  # ----------------------------------------
  If CSMQTY <> 0 Then
    [L]ARET_VALUE = ar2(CSMQTY / (CSMQTY + RMNQTY) * 100)
  Endif
  # ----------------------------------------
Return

