Gosub TEST From ACLAVAL
End

#-------------------------------------------------------#
$ADDCLB
Append CLOB,space$(DIF)+LIGNE+chr$(10)
Return

#-------------------------------------------------------#
$ADDCLB0
Append CLOB,LIGNE+chr$(10)
Return

#-------------------------------------------------------#
Subprog CREATE_STC(VALP,TYPAGE,MACHINE,APPLI,DOSSIER,ACLA,AERR): # fichier STC
Value Integer VALP
Variable Integer TYPAGE
Value Char MACHINE
Value Char APPLI
Value Char DOSSIER
Variable Instance ACLA Using OBJECT
Variable  Instance  AERR(1..) Using C_AERROR

Local Clbfile     CLOB(9)
Local Integer   DIF,OK
Local Char       LIGNE(250)

If ACLA.TEST : Call ECR_TRACE("- Create STC"-ACLA.ACLAV.NOMSTC,0) From GESECRAN  : Endif

Gosub STC_FIELD
Gosub SUB_COM_STD From ACLAVALTRT
Call   STC_CONSTRUCTOR(ACLA,[L]LIGNE,[L]CLOB,[L]DIF)
Call   STC_CONSTRUCTOR_CLA(ACLA,[L]LIGNE,[L]CLOB,[L]DIF)
Call   STC_MET_GLO(ACLA,[L]LIGNE,[L]CLOB,[L]DIF)
Call   STC_INIT(ACLA,[L]LIGNE,[L]CLOB,[L]DIF)
Call   STC_CONTROL(ACLA,[L]LIGNE,[L]CLOB,[L]DIF)
Call   STC_METHODES(ACLA,[L]LIGNE,[L]CLOB,[L]DIF)
Call   STC_OPERATION(ACLA,[L]LIGNE,[L]CLOB,[L]DIF)
Call   STC_MTD_STD(ACLA.ACLAV,ACLA,"",[L]LIGNE,[L]CLOB,[L]DIF)
Call   STC_ALL(ACLA,[L]LIGNE,[L]CLOB,[L]DIF)
If find(ACLA.TYPCLA,1,2,3,5)>0 & ACLA.NBRGRP>0
 Call STC_METHODES_TAB(ACLA,[L]LIGNE,[L]CLOB,[L]DIF)
Endif
Call STC_ADELINSTANCE(ACLA,[L]LIGNE,[L]CLOB,[L]DIF)
Call STC_ADDINSTANCE_BOUND(ACLA,[L]LIGNE,[L]CLOB,[L]DIF)
Call STC_DEB([L]APPLI,[L]MACHINE,ACLA.ACLAV.NOMSTC,ACLA.ACLAV.IDENTSTC,ACLA.CODECLA,ACLA.INTITCLA,ACLA.ACLAV.MAGIC,ACLA.ACLAV.TITETA,"STC") From ACLASUB
Call STC_FIN([L]CLOB,ACLA.ACLAV.NOMSTC,ACLA.FLGACTX,[L]DOSSIER,"STC",[L]VALP,[L]TYPAGE,[L]OK,AERR) From ACLASUB
If maxtab(AERR)>0  : End : Endif
End

#-------------------------------------------------------#
$STC_FIELD
DIF = 0
Call SUB_DEF_TRT(ACLA) From ACLAVALTRT
LIGNE = "" : Gosub ADDCLB
Gosub SUB_COM_TRT From ACLAVALTRT
For F=1 To maxtab(ACLA.ACLAF)
 If  !find(ACLA.TYPCLA,3,4) : Call SUB_COM_FIELD(F,ACLA.ACLAF(F),CLOB,DIF) From ACLAVALTRT : Endif
 If ACLA.ACLAF(F).LNKCLA<>""
  Call STC_DEFCLA(ACLA.ACLAF(F),func SUBACLA.PREFIX_CLA,ACLA,LIGNE,CLOB,DIF) : # Déclaration de la sous-classe
 Elsif ACLA.ACLAF(F).ATY<>null & ACLA.ACLAF(F).ATY.CODTYP<>""
  Call STC_FIELD_DECLARE(ACLA.ACLAF(F),LIGNE,CLOB,DIF)         : # Déclaration du champ
  LIGNE -= "{" : Gosub ADDCLB
  WFLD  = ACLA.ACLAF(F).FLDCLA
  WTYPTYP = ACLA.ACLAF(F).ATY.TYPTYP
  If ACLA.ACLAF(F).FLGACCGET=2 : Call STC_FIELD_GET(ACLA.ACLAF(F),ACLA,LIGNE,CLOB,DIF) : Endif
  If ACLA.ACLAF(F).FLGACCSET=2 : Call STC_FIELD_SET(ACLA.ACLAF(F),ACLA,LIGNE,CLOB,DIF) : Endif
  If ACLA.ACLAF(F).FLGACCINI=2  : Call STC_FIELD_INIT(ACLA.ACLAF(F),ACLA,LIGNE,CLOB,DIF)  : Endif
  If ACLA.ACLAF(F).FLGACCCTL=2
   Call STC_FIELD_CONTROL(ACLA.ACLAF(F),ACLA,LIGNE,CLOB,DIF)
   Call STC_FIELD_LNKPRO(ACLA.ACLAF(F),ACLA,LIGNE,CLOB,DIF)
  Endif
  If find(ACLA.TYPCLA,1,2,5)>0
   Call STC_FIELD_ATEXTRA(ACLA.ACLAF(F),LIGNE,CLOB,DIF)
   Call STC_FIELD_ATEXTE(ACLA.ACLAF(F),LIGNE,CLOB,DIF)
  Endif
  LIGNE = "}"  : Gosub ADDCLB
  LIGNE = ""  : Gosub ADDCLB
 Endif
 If mod(F,func ACLAVALLEC.MAXPRO)=0 : Call SUB_DEF_TRT(ACLA) From ACLAVALTRT :  Endif : #  #  find(F,30,60,90,120,150,180,210,240,270,300)>0
Next
LIGNE = ""   : Gosub ADDCLB
Call STC_FIELD_OBLIG(ACLA,LIGNE,CLOB,DIF)
LIGNE = "%% # End Classe" : Gosub ADDCLB
LIGNE = ""   : Gosub ADDCLB
Return

#------------------------------------------------------------------------------#
Subprog STC_CONSTRUCTOR(ACLA,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
LIGNE = "# Method constructor" : Gosub ADDCLB
LIGNE = "Method CONSTRUCTOR" : Gosub ADDCLB
If ACLA.FLGACTX=2  &  ACLA.FLGBUFFER<>2
 LIGNE = "this.AINF = NewInstance C_AINFO"-[V]CST_ALLOCGROUP-"this" : Gosub ADDCLB
 LIGNE = "Local Integer ASTATUS"  : Gosub ADDCLB
 LIGNE = "[L]ASTATUS = fmet this._ADDTRT" : Gosub ADDCLB
Else
 LIGNE = 'If dim(GACTX)>0' : Gosub ADDCLB
 DIF +=1
 LIGNE = 'Callmet this.'+ACLA.ACLAV.NOMSTC+'(GACTX,NullUuid,0,null,"")' : Gosub ADDCLB
 DIF -= 1
 LIGNE = "Endif" : Gosub ADDCLB
Endif
LIGNE = "End" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End


Subprog STC_CONSTRUCTOR_CLA(ACLA,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
If ACLA.FLGACTX=2 &  ACLA.FLGBUFFER<>2 : End : Endif : #
LIGNE = "Method "+ACLA.ACLAV.NOMSTC+"(_GLO,_UID,_LIN,_IPA,_PPA)" : Gosub ADDCLB
LIGNE = "Variable Instance _GLO Using C_"+[V]CST_NAME_CLASS_CONTEXT : Gosub ADDCLB
LIGNE = "Value    Uuident  _UID" : Gosub ADDCLB
LIGNE = "Value    Integer  _LIN" : Gosub ADDCLB
LIGNE = "Value    Instance _IPA Using OBJECT" : Gosub ADDCLB
LIGNE = "Value    Char     _PPA" : Gosub ADDCLB
LIGNE = "Local Integer ASTATUS"  : Gosub ADDCLB
If ACLA.CODECLA<>"AINFO" & find(ACLA.TYPCLA,-1,1,2,3,5)>0
 LIGNE = "Gosub AINFO_INSTANCE From ASYRSUB" : Gosub ADDCLB
Endif
LIGNE = "Gosub CREATE_INSTANCE From ASYRSUB" : Gosub ADDCLB
LIGNE = "If this.APARENT=null" : Gosub ADDCLB
DIF +=1
If find(ACLA.TYPCLA,-1,1,2,5)>0
 LIGNE = "this.getAccessorEnabled = 1" : Gosub ADDCLB
 LIGNE = "this.setAccessorEnabled = 1" : Gosub ADDCLB
 LIGNE = "[L]ASTATUS = fmet this.ADDINSTANCE_BOUND" : Gosub ADDCLB
 DIF -=1
 LIGNE = "Else" : Gosub ADDCLB
 DIF += 1
 LIGNE = "If this.APARENT.getAccessorEnabled>0 : this.getAccessorEnabled=this.APARENT.getAccessorEnabled : Endif" : Gosub ADDCLB
 LIGNE = "If this.APARENT.setAccessorEnabled>0 : this.setAccessorEnabled=this.APARENT.setAccessorEnabled : Endif" : Gosub ADDCLB
Else
 LIGNE = "[L]ASTATUS = fmet this.ADDINSTANCE_BOUND" : Gosub ADDCLB
Endif
DIF -=1
LIGNE = "Endif" : Gosub ADDCLB
If ACLA.CODECLA<>"" & find(ACLA.TYPCLA,2,5)>0
 LIGNE = "Gosub _ALOAD_KEYS From "+ACLA.ACLAV.CTLPRG  : Gosub ADDCLB
Endif
If  (!find(ACLA.TYPCLA,3,4) or ACLA.FLGACTX=2) and ACLA.FLGBUFFER<>2  : #  _attributs
 LIGNE = "[L]ASTATUS = fmet this."+ACLA.ACLAV.TBMET(9) : Gosub ADDCLB
Endif
LIGNE = "End" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End

#------------------------------------------------------------------------------#

Subprog STC_FIELD_OBLIG(ACLA,LIGNE,CLOB,DIF)
Variable  Instance  ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF

If find(ACLA.TYPCLA,-1)>0 : # Représenation
 Gosub INTERLINE  From ACLAVALTRT
 LIGNE = "# _APARAMURL (Parametres représentation)" : Gosub ADDCLB : #
 Gosub INTERLINE From ACLAVALTRT
 LIGNE = "" : Gosub ADDCLB
 LIGNE = "Instance _APARAMURL(1..) Using C_APARAMURL" : Gosub ADDCLB
 LIGNE = "" : Gosub ADDCLB

 Gosub INTERLINE  From ACLAVALTRT
 LIGNE = "# _AFCRIGHT (Authorization function)" : Gosub ADDCLB : #
 Gosub INTERLINE From ACLAVALTRT
 LIGNE = "" : Gosub ADDCLB
 LIGNE = "Char _AFCRIGHT("+num$(GLONAFC)+")" : Gosub ADDCLB
 LIGNE = "" : Gosub ADDCLB

 Gosub INTERLINE  From ACLAVALTRT
 LIGNE = "# _ASTADETLNK (array of status of links)" : Gosub ADDCLB : #
 Gosub INTERLINE From ACLAVALTRT
 LIGNE = "" : Gosub ADDCLB
 LIGNE = "Instance _ASTADETLNK(1..) Using C_ASTATUSLINK" : Gosub ADDCLB
 LIGNE = "" : Gosub ADDCLB

Endif

If ACLA.FLGACTX=2 & ACLA.CODECLA=[V]CST_NAME_CLASS_CONTEXT
  Gosub INTERLINE From ACLAVALTRT
  LIGNE = "# AINFOS (Class AINFO)" : Gosub ADDCLB
  Gosub INTERLINE From ACLAVALTRT
  LIGNE = "" : Gosub ADDCLB
  LIGNE = "Instance AINFOS (1..) Using C_AINFO" : Gosub ADDCLB
  LIGNE = "" : Gosub ADDCLB
Endif

If ACLA.CODECLA<>"ATXTTRA"
 For I=1 To maxtab(ACLA.ACLAF)
  If ACLA.ACLAF(I).ATY<>null &  find(ACLA.ACLAF(I).ATY.CODTYP,"AXX","AX1","AX2","AX3")
   Gosub INTERLINE From ACLAVALTRT
   LIGNE = "# AXX (Class ATXTTRA)" : Gosub ADDCLB
   Gosub INTERLINE From ACLAVALTRT
   LIGNE = "" : Gosub ADDCLB
   LIGNE = "Instance AXX (1..) Using C_ATXTTRA" : Gosub ADDCLB
   LIGNE = "" : Gosub ADDCLB
   Break
  Endif
 Next
Endif

If ACLA.CODECLA<>"ATXTSUP"
 For I=1 To maxtab(ACLA.ACLAF)
  If ACLA.ACLAF(I).ATY<>null &  find(ACLA.ACLAF(I).ATY.CODTYP,"ATX")
   Gosub INTERLINE From ACLAVALTRT
   LIGNE = "# ATX (Class ATXTSUP)" : Gosub ADDCLB
   Gosub INTERLINE From ACLAVALTRT
   LIGNE = "" : Gosub ADDCLB
   LIGNE = "Instance ATX (1..) Using C_ATXTSUP" : Gosub ADDCLB
   LIGNE = "" : Gosub ADDCLB
   Break
  Endif
 Next
Endif

If (ACLA.CODECLA<>"AERROR" & find(ACLA.TYPCLA,-1,0,1,2,3,5)>0) or ACLA.FLGACTX=2
 Gosub INTERLINE From ACLAVALTRT
 LIGNE = "# AERROR (Class AERROR)" : Gosub ADDCLB
 Gosub INTERLINE From ACLAVALTRT
 LIGNE = "" : Gosub ADDCLB
 LIGNE = "Instance AERROR(1..) Using C_AERROR" : Gosub ADDCLB
 LIGNE = "" : Gosub ADDCLB
Endif

 Gosub INTERLINE From ACLAVALTRT
 LIGNE = "# APARENT (Class OBJECT : Link to parent class)" : Gosub ADDCLB
 Gosub INTERLINE From ACLAVALTRT
 LIGNE = "" : Gosub ADDCLB
 LIGNE = "Instance APARENT Using OBJECT" : Gosub ADDCLB
 LIGNE = "" : Gosub ADDCLB

If !find(ACLA.TYPCLA,4)
 Gosub INTERLINE From ACLAVALTRT
 LIGNE = "# ASTALIN (Status of the line )" : Gosub ADDCLB
 Gosub INTERLINE From ACLAVALTRT
 LIGNE = "" : Gosub ADDCLB
 LIGNE = "Integer ASTALIN {" : Gosub ADDCLB
 LIGNE = "}" : Gosub ADDCLB
 LIGNE = "" : Gosub ADDCLB
Endif

If !find(ACLA.TYPCLA,4)
 Gosub INTERLINE From ACLAVALTRT
 LIGNE = "# AORDER (Line Order )" : Gosub ADDCLB
 Gosub INTERLINE From ACLAVALTRT
 LIGNE = "" : Gosub ADDCLB
 LIGNE = "Integer AORDER {" : Gosub ADDCLB
 LIGNE = "}" : Gosub ADDCLB
 LIGNE = "" : Gosub ADDCLB
Endif

If find(ACLA.TYPCLA,2,5)>0
 Gosub INTERLINE From ACLAVALTRT
 LIGNE = "# AKEYS (Key in the linked table to the class )" : Gosub ADDCLB
 Gosub INTERLINE From ACLAVALTRT
 LIGNE = "" : Gosub ADDCLB
 LIGNE = "Char AKEYS(12)(1..) {" : Gosub ADDCLB
 LIGNE = "}" : Gosub ADDCLB
 LIGNE = "" : Gosub ADDCLB
Endif

If !find("AUUID",ACLA.ACLAF(1..maxtab(ACLA.ACLAF)).FLDCLA)
 Gosub INTERLINE From ACLAVALTRT
 LIGNE = "# AUUID (Property AUUID)" : Gosub ADDCLB
 Gosub INTERLINE From ACLAVALTRT
 LIGNE = "" : Gosub ADDCLB
 LIGNE = "Uuident AUUID{" : Gosub ADDCLB
 LIGNE = "}" : Gosub ADDCLB
 LIGNE = "" : Gosub ADDCLB
Endif

If ACLA.CODECLA<>"ATTRIBUTE"
 If find(ACLA.TYPCLA,1,2,5)>0 or ACLA.FLGACTX>0
  Gosub INTERLINE From ACLAVALTRT
  LIGNE = "# AATTRIBUTES (Class ATTRIBUTES)" : Gosub ADDCLB
  Gosub INTERLINE From ACLAVALTRT
  LIGNE = "" : Gosub ADDCLB
  LIGNE = "Instance AATTRIBUTES(1..) Using C_ATTRIBUTES" : Gosub ADDCLB
  LIGNE = "" : Gosub ADDCLB
 Endif
Endif

If ACLA.FLGACTX<>2 or ACLA.FLGBUFFER=2
 Gosub INTERLINE From ACLAVALTRT
 LIGNE = "# ACTX (Class "+[V]CST_NAME_CLASS_CONTEXT+")" : Gosub ADDCLB
 Gosub INTERLINE From ACLAVALTRT
 LIGNE = "" : Gosub ADDCLB
 LIGNE = "Instance ACTX Using C_"+[V]CST_NAME_CLASS_CONTEXT : Gosub ADDCLB
 LIGNE = "" : Gosub ADDCLB
Endif

If ACLA.CODECLA<>"AINFO"
 Gosub INTERLINE From ACLAVALTRT
 LIGNE = "# AINFO (Class AINFO)" : Gosub ADDCLB
 Gosub INTERLINE From ACLAVALTRT
 LIGNE = "" : Gosub ADDCLB
 LIGNE = "Instance AINF Using C_AINFO" : Gosub ADDCLB
 LIGNE = "" : Gosub ADDCLB
Endif

If !find(ACLA.TYPCLA,4)
 Gosub INTERLINE From ACLAVALTRT
 LIGNE = "# ATABINFOS class" : Gosub ADDCLB
 Gosub INTERLINE From ACLAVALTRT
 LIGNE = "" : Gosub ADDCLB
 LIGNE = "Instance _AINFOS Using C_ATABINFOS" : Gosub ADDCLB
 LIGNE = "" : Gosub ADDCLB
 Gosub INTERLINE From ACLAVALTRT
 LIGNE = "# Path instance" : Gosub ADDCLB
 Gosub INTERLINE From ACLAVALTRT
 LIGNE = "" : Gosub ADDCLB
 LIGNE = "Char _AINSPTH(250) {" : Gosub ADDCLB
 LIGNE = "}" : Gosub ADDCLB
 LIGNE = "" : Gosub ADDCLB
Endif

End

#------------------------------------------------------------------------------#
Subprog STC_FIELD_DECLARE(ACLAF,LIGNE,CLOB,DIF)
Variable  Instance  ACLAF Using C_ACLAFLD
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
LIGNE = func ACLAVALTRT.DECLARE_TYPTYP(ACLAF.ATY.TYPTYP)-ACLAF.FLDCLA
If find(ACLAF.ATY.TYPTYP,7,9,10) & ACLAF.LON>0
 LIGNE += "("+num$(ACLAF.LON)+")"
Endif
If ACLAF.FLDGRP<>""
 If ACLAF.DIME>1
  LIGNE += "(1.."+num$(ACLAF.DIME)+")"
 Elsif ACLAF.DIME=0
  LIGNE += "(1..)"
 Endif
Endif
End


#------------------------------------------------------------------------------#
Subprog STC_FIELD_GET(ACLAF,ACLA,LIGNE,CLOB,DIF)
Variable  Instance  ACLAF Using OBJECT
Variable  Instance  ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
LIGNE = "" : Gosub ADDCLB
LIGNE = "Method GET" : Gosub ADDCLB
LIGNE = "Gosub GET_"+ ACLAF.FLDCLA-"From"-ACLA.ACLAV.NOMPRG : Gosub ADDCLB
LIGNE = "End" : Gosub ADDCLB
End

#------------------------------------------------------------------------------#
Subprog STC_FIELD_SET(ACLAF,ACLA,LIGNE,CLOB,DIF)
Variable  Instance  ACLAF Using OBJECT
Variable  Instance  ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
LIGNE = "" : Gosub ADDCLB
LIGNE = "Method SET("+ACLA.ACLAV.VAROLD+")" : Gosub ADDCLB
LIGNE = "Variable"-func ACLAVALTRT.DECLARE_TYPTYP(ACLAF.ATY.TYPTYP)-ACLA.ACLAV.VAROLD : Gosub ADDCLB
LIGNE = "Gosub SET_"+ ACLAF.FLDCLA-"From"-ACLA.ACLAV.NOMPRG : Gosub ADDCLB
LIGNE = "End" : Gosub ADDCLB
End

#------------------------------------------------------------------------------#
Subprog STC_FIELD_INIT(ACLAF,ACLA,LIGNE,CLOB,DIF)
Variable  Instance  ACLAF Using OBJECT
Variable  Instance  ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
LIGNE = "" : Gosub ADDCLB
LIGNE = "Fmethod INIT"
Gosub ADDCLB
LIGNE = "Gosub INIT_"+ACLAF.FLDCLA-"From"-ACLA.ACLAV.NOMPRG : Gosub ADDCLB
LIGNE = "End "+ACLA.ACLAV.VARCTL : Gosub ADDCLB
End

#------------------------------------------------------------------------------#
Subprog STC_FIELD_CONTROL(ACLAF,ACLA,LIGNE,CLOB,DIF)
Variable  Instance  ACLAF Using OBJECT
Variable  Instance  ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
LIGNE = "" : Gosub ADDCLB
LIGNE = "Fmethod CONTROL"
Gosub ADDCLB
LIGNE = "Gosub CONTROL_"+ ACLAF.FLDCLA-"From"-ACLA.ACLAV.NOMPRG : Gosub ADDCLB
LIGNE = "End "+ACLA.ACLAV.VARCTL : Gosub ADDCLB
End

#------------------------------------------------------------------------------#
Subprog STC_FIELD_LNKPRO(ACLAF,ACLA,LIGNE,CLOB,DIF)
Variable  Instance  ACLAF Using OBJECT
Variable  Instance  ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
LIGNE = "" : Gosub ADDCLB
LIGNE = "Fmethod "+ACLA.ACLAV.TBMET(10)
Gosub ADDCLB
LIGNE = "Gosub "+ACLA.ACLAV.TBMET(10)+"_"+ACLAF.FLDCLA-"From"-ACLA.ACLAV.NOMPRG : Gosub ADDCLB
LIGNE = "End "+ACLA.ACLAV.VARCTL : Gosub ADDCLB
End

#------------------------------------------------------------------------------#
Subprog STC_FIELD_ATEXTRA(ACLAF,LIGNE,CLOB,DIF)
Variable  Instance  ACLAF Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
If !find(ACLAF.CODTYP,"AXX","AX1","AX2","AX3") : End : Endif
LIGNE = "" : Gosub ADDCLB
LIGNE = "Fmethod AGETTEXT" : Gosub ADDCLB
LIGNE = 'End fmet this.AGETTEXTRA("'+ACLAF.FLDCLA+'")': Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
LIGNE = "Fmethod ASETTEXT(_INTIT)" : Gosub ADDCLB
LIGNE = "Value Char     _INTIT"  : Gosub ADDCLB
LIGNE = 'End fmet this.ASETTEXTRA("'+ACLAF.FLDCLA+'",[L]_INTIT)' : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
LIGNE = "Fmethod AGETTEXTLAN(_LAN)" : Gosub ADDCLB
LIGNE = "Value Char     _LAN"  : Gosub ADDCLB
LIGNE = 'End fmet this.AGETTEXTRALAN("'+ACLAF.FLDCLA+'",[L]_LAN)': Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
LIGNE = "Fmethod ASETTEXTLAN(_INTIT,_LAN)" : Gosub ADDCLB
LIGNE = "Value Char     _INTIT"  : Gosub ADDCLB
LIGNE = "Value Char     _LAN"  : Gosub ADDCLB
LIGNE = 'End fmet this.ASETTEXTRALAN("'+ACLAF.FLDCLA+'",[L]_INTIT,[L]_LAN)' : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End

#------------------------------------------------------------------------------#
Subprog STC_FIELD_ATEXTE(ACLAF,LIGNE,CLOB,DIF)
Variable  Instance  ACLAF Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
If !find(ACLAF.CODTYP,"ATX") : End : Endif
LIGNE = "" : Gosub ADDCLB
LIGNE = "Fmethod AGETTEXT" : Gosub ADDCLB
LIGNE = 'End fmet this.AGETTEXT("'+ACLAF.FLDCLA+'")': Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
LIGNE = "Fmethod ASETTEXT(_INTIT)" : Gosub ADDCLB
LIGNE = "Value Char     _INTIT"  : Gosub ADDCLB
LIGNE = 'End fmet this.ASETTEXT("'+ACLAF.FLDCLA+'",[L]_INTIT,this.'+ACLAF.FLDCLA+')' : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
LIGNE = "Fmethod AGETTEXTLAN(_LAN)" : Gosub ADDCLB
LIGNE = "Value Char     _LAN"  : Gosub ADDCLB
LIGNE = 'End fmet this.AGETTEXTLAN("'+ACLAF.FLDCLA+'",[L]_LAN)': Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
LIGNE = "Fmethod ASETTEXTLAN(_INTIT,_LAN)" : Gosub ADDCLB
LIGNE = "Value Char     _INTIT"  : Gosub ADDCLB
LIGNE = 'End fmet this.ASETTEXT("'+ACLAF.FLDCLA+'",[L]_INTIT,this.'+ACLAF.FLDCLA+',[L]_LAN)' : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End


Subprog STC_MET_WRIGHT(ACLA,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
Gosub INTERLINE From ACLAVALTRT


End

#------------------------------------------------------------------------------#
Subprog STC_MET_GLO(ACLA,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
Gosub INTERLINE From ACLAVALTRT
If ACLA.TYPCLA=-1 : # represenation
 Gosub STC_ASETLINK
 Gosub STC_AGETPARAMURL
Endif
If !find(ACLA.TYPCLA,3,4)
 Gosub STC_AGETTEXTRA
 Gosub STC_SETTEXTRA
 Gosub STC_AGETTEXT
 Gosub STC_ASETTEXT
Endif
If  !find(ACLA.TYPCLA,3,4) or ACLA.FLGACTX=2
 Gosub STC_ASETATTRIBUTE
 Gosub STC_AGETATTRIBUTE
Endif
Gosub STC_AGETMAXERROR
Gosub STC_AGETMAXERRORALL
Gosub STC_AGETMAXERRORTXT
Gosub STC_AGETNEXTINFOS
Gosub STC_ASETERROR
If !find(ACLA.TYPCLA,4)
 Gosub STC_ASETERRORCAT
Endif
Gosub STC_ADELETEERROR
Gosub STC_ADELETERROR
Gosub STC_ADELETERRORALL
Gosub STC_ASTAMP
Gosub STC_GETTYPCLA
Gosub STC_ACTION
Gosub STC_ACTION_PARAM
Gosub STC_ACTION_LINE_BEFORE
#Gosub STC_ACTION_PRO
Call STC_RICHMEDIA(ACLA,LIGNE,CLOB,DIF)
End

#------------------------------------------------------------------------------#
$STC_ASETLINK
LIGNE = "# Fmethod ASETLINKDISABLE " : Gosub ADDCLB
LIGNE = "Fmethod ASETLINKDISABLE(_CODLNK,_AFFLNK)" : Gosub ADDCLB
LIGNE = "Value Char _CODLNK" : Gosub ADDCLB
LIGNE = "Value Integer _AFFLNK" : Gosub ADDCLB
LIGNE = "Local Integer ASTATUS"  : Gosub ADDCLB
LIGNE = "Local Integer _ISDISABLED : [L]_ISDISABLED=[V]CST_AYES"  : Gosub ADDCLB
LIGNE = "Gosub ASETLINK From ASYRSUB"  : Gosub ADDCLB
LIGNE = "End [L]ASTATUS" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
