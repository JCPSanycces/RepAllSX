#------------------------------------------------------------------------------#
Subprog STC_ALL(ACLA,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
Call SUB_COM_INIT_CONT(ACLA.ACLAV.NOMSTC,LIGNE,CLOB,DIF) From ACLAVALTRT
Gosub STC_A_ADDTRT
Gosub STC_A_ERROR
Gosub STC_A_DELERROR
Gosub STC_A_SEARCHINFOS
Gosub STC_A_AGETERRORSFROM
If ACLA.TYPCLA=-1 or (ACLA.TYPCLA>0 & !find(ACLA.TYPCLA,3,4)>0 & ACLA.FLGBUFFER<>2)
 Gosub STC_A_INIT
 Gosub STC_A_LNKPRO
 Gosub STC_A_ATTRIBUTE_LOAD
 Gosub STC_A_CONTROL
 Gosub STC_A_MANDATORY_CONTROL
 Gosub STC_A_FORMAT_CONTROL
 Gosub STC_A_OTHERS_CONTROL
Endif
End

#------------------------------------------------------------------------------#
$STC_A_INIT
LIGNE = "Fmethod "+ACLA.ACLAV.TBMET(5) : Gosub ADDCLB
LIGNE = "Gosub"-ACLA.ACLAV.TBMET(5)-" From"-ACLA.ACLAV.INICTLPRG : Gosub ADDCLB
LIGNE = "End"-ACLA.ACLAV.VARCTLALL : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Return

#------------------------------------------------------------------------------#
