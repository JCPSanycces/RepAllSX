#------------------------------------------------------------------------------#
Subprog STC_DEFCLA(ACLAF,PREFIXCLA,ACLA,LIGNE,CLOB,DIF)
Variable  Instance  ACLAF Using C_ACLAFLD
Value Char PREFIXCLA
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
LIGNE = "" : Gosub ADDCLB
LIGNE = "Instance"-ACLAF.FLDCLA
If ACLAF.FLDGRP=""
 LIGNE += ""
Elsif ACLAF.DIME=0
 LIGNE +=  "(1..)"
Elsif ACLAF.DIME=1
 Local Integer J
 For G=1 To ACLA.NBRGRP
  If ACLA.MAXGRP(G)=1 & ACLA.MINGRP(G)=2 & ACLAF.FLDGRP=ACLA.CODGRP(G)
   J =1
   Break
  Endif
 Next
 If J=1
  LIGNE += "(1..1)"
 Else
  LIGNE += "(1..)"
 Endif
Elsif  ACLAF.DIME>1
 LIGNE += "(1..)"
Endif
LIGNE -= "Using "
If ACLAF.LNKCLA<>"OBJECT"
 LIGNE += PREFIXCLA
Endif
LIGNE += ACLAF.LNKCLA
Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End


#------------------------------------------------------------------------------#
Subprog STC_INIT(ACLA,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
If find(ACLA.TYPCLA,-1,1,2,5) or ACLA.FLGACTX=2
 Gosub INTERLINE From ACLAVALTRT
 LIGNE = "# Init Global" : Gosub ADDCLB
 LIGNE = "Fmethod AINIT" : Gosub ADDCLB
 LIGNE = "Gosub AINIT From "+ACLA.ACLAV.INICTLPRG  : Gosub ADDCLB
 LIGNE = "End "+ACLA.ACLAV.VARCTL : Gosub ADDCLB
 LIGNE = "" : Gosub ADDCLB
Endif
End



#------------------------------------------------------------------------------#
Subprog STC_CONTROL(ACLA,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
If find(ACLA.TYPCLA,-1,1,2,5)>0
 LIGNE = "# Control Global" : Gosub ADDCLB
 LIGNE = "Fmethod ACONTROL" : Gosub ADDCLB
 LIGNE = "Gosub ACONTROL From "+ACLA.ACLAV.CTLPRG  : Gosub ADDCLB
 LIGNE = "End "+ACLA.ACLAV.VARCTL : Gosub ADDCLB
 LIGNE = "" : Gosub ADDCLB
Endif
End

#------------------------------------------------------------------------------#
Subprog STC_MTD_STD(ACLAV,ACLA,CODREP,LIGNE,CLOB,DIF)
Variable Instance ACLAV Using OBJECT
Variable Instance ACLA Using OBJECT
Value Char CODREP
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
If find(ACLA.TYPCLA,3,4)>0 : End : Endif
Gosub INTERLINE From ACLAVALTRT
Gosub SUB_COM_MTDSTD From ACLAVALTRT
For MT=1 To maxtab(ACLA.ACLAT)
 Case ACLA.ACLAT(MT).CODMETSTD
  When "C"
   Call PROG_INSTANCE(ACLA,ACLA.CODCLA,ACLA.ACLAV.CTLPRG,ACLA.TYPCLA,ACLA.ACLAT(MT).NAMMETSTD,ACLAV.TRTCRUDCRE,LIGNE,CLOB,DIF)
   If find(ACLA.TYPCLA,1)=0 & [L]CODREP=""
    Call PROG_INSTANCE(ACLA,ACLA.CODCLA,ACLA.ACLAV.CTLPRG,ACLA.TYPCLA,"_"+ACLA.ACLAT(MT).NAMMETSTD,ACLAV.TRTCRUDCRE,LIGNE,CLOB,DIF)
   Endif
  When "R" :
   Gosub READ_INSTANCE
  When "U" :
   Call PROG_INSTANCE(ACLA,ACLA.CODCLA,ACLA.ACLAV.CTLPRG,ACLA.TYPCLA,ACLA.ACLAT(MT).NAMMETSTD,ACLAV.TRTCRUDUPD,LIGNE,CLOB,DIF)
   If find(ACLA.TYPCLA,1)=0 & [L]CODREP=""
    Call PROG_INSTANCE(ACLA,ACLA.CODCLA,ACLA.ACLAV.CTLPRG,ACLA.TYPCLA,"_"+ACLA.ACLAT(MT).NAMMETSTD,ACLAV.TRTCRUDUPD,LIGNE,CLOB,DIF)
   Endif
  When "D" :
   Call PROG_INSTANCE(ACLA,ACLA.CODCLA,ACLA.ACLAV.CTLPRG,ACLA.TYPCLA,ACLA.ACLAT(MT).NAMMETSTD,ACLAV.TRTCRUDDEL,LIGNE,CLOB,DIF) :
   If find(ACLA.TYPCLA,1)=0 & [L]CODREP=""
    Call PROG_INSTANCE(ACLA,ACLA.CODCLA,ACLA.ACLAV.CTLPRG,ACLA.TYPCLA,"_"+ACLA.ACLAT(MT).NAMMETSTD,ACLAV.TRTCRUDDEL,LIGNE,CLOB,DIF)
   Endif
 Endcase
Next
End


#------------------------------------------------------------------------------#
Subprog  PROG_INSTANCE(ACLA,ACLASSE,CTLPRG,TYPCLA,PROGRAM,TRTCRUD,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Value Char ACLASSE
Value Char CTLPRG
Value Integer TYPCLA
Value Char PROGRAM
Value Char TRTCRUD
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
LIGNE = "# Fmethod "-tolower(PROGRAM) : Gosub ADDCLB
LIGNE = "Fmethod "+toupper(PROGRAM) : Gosub ADDCLB
LIGNE = "Local Integer ASTATUS"  : Gosub ADDCLB
Case TYPCLA
 When 2,5
  LIGNE = "Call "+toupper(PROGRAM)+"(this,[L]ASTATUS) From "+TRTCRUD : Gosub ADDCLB
 When 1
  LIGNE = "Gosub "+toupper(PROGRAM)+" From "+CTLPRG  : Gosub ADDCLB
Endcase
LIGNE = "End [L]ASTATUS" : Gosub ADDCLB
LIGNE = " " : Gosub ADDCLB
If PROGRAM<>"" & left$(PROGRAM,1)<>"_"
 Local Char PRGCRUD(30)
 For PRGCRUD="_CONTROL_BEFORE","_CONTROL_AFTER","_AFTER","_ABORT"
  LIGNE = "Fmethod _"+PROGRAM+PRGCRUD : Gosub ADDCLB
  LIGNE = "Local    Integer     ASTATUS,A_I"
  For I=1 To min(8,maxtab(ACLA.ACLAK))
   LIGNE += ",A_N"+num$(I)+",A_S"+num$(I)
  Next
  Gosub ADDCLB
  Raz LIGNE
  For I=9 To maxtab(ACLA.ACLAK)
   If I=9 : LIGNE ="Local    Integer A_N"+num$(I)+",A_S"+num$(I)
   Else LIGNE += ",A_N"+num$(I)+",A_S"+num$(I)
   Endif
  Next
  If LIGNE<>"" : Gosub ADDCLB : Endif
  LIGNE = "Local    Integer    A_RETIK,A_TYPMAJ,A_ABORT,A_ASTALIN" : Gosub ADDCLB
  LIGNE = "Local Instance "+ACLASSE+" Using C_"+ACLASSE : Gosub ADDCLB
  LIGNE = ACLASSE+" = this" : Gosub ADDCLB
  LIGNE = "Gosub _"+PROGRAM+PRGCRUD+" From "+TRTCRUD : Gosub ADDCLB
  LIGNE = "End ASTATUS" : Gosub ADDCLB
  LIGNE = " " : Gosub ADDCLB
 Next
Endif
End

#------------------------------------------------------------------------------#
$READ_INSTANCE
Case ACLA.TYPCLA
 When 2,5 :
  Gosub READ_PERSITENT
 When 1 :
  Call PROG_INSTANCE(ACLA,ACLA.CODCLA,ACLA.ACLAV.CTLPRG,ACLA.TYPCLA,ACLA.ACLAT(MT).NAMMETSTD,ACLAV.TRTCRUDREAD,LIGNE,CLOB,DIF)
Endcase
Return

$READ_PERSITENT
LIGNE = "# Fmethod "+ACLA.ACLAT(MT).NAMMETSTD : Gosub ADDCLB
LIGNE = "Fmethod "+ACLA.ACLAT(MT).NAMMETSTD+" ("
For I=1 To ACLA.NBCLEREF
 If I>1 : LIGNE += "," : Endif
 LIGNE += ACLA.ACLAI(I).CLEREF
Next
LIGNE += ")"  : Gosub ADDCLB
For I=1 To ACLA.NBCLEREF
 J=find(ACLA.ACLAI(I).CLEREF ,ACLA.ACLAF(1..maxtab(ACLA.ACLAF)).FLDCLA)
 If J
  LIGNE = "Value"-func ACLAVALTRT.DECLARE_TYPTYP(ACLA.ACLAF(J).ATY.TYPTYP)-ACLA.ACLAI(I).CLEREF : Gosub ADDCLB : # ACLA.ACLAK(1).TYPIND(I)
 Endif
Next
LIGNE = "Local Integer ASTATUS"  : Gosub ADDCLB
LIGNE = "Call "+ACLA.ACLAT(MT).NAMMETSTD+"(This"
For I=1 To ACLA.NBCLEREF
 LIGNE += ",[L]"+ACLA.ACLAI(I).CLEREF
Next
LIGNE += ",[L]ASTATUS) From "+ACLAV.TRTCRUDREAD  : Gosub ADDCLB
LIGNE ="End [L]ASTATUS" : Gosub ADDCLB
LIGNE = " " : Gosub ADDCLB
Return

