#------------------------------------------------------------------------------#
Subprog STC_METHODES(ACLA,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
For M=1 To maxtab(ACLA.ACLAM)
 If M=1 : Gosub INTERLINE From ACLAVALTRT : Gosub SUB_COM_METHOD From ACLAVALTRT : Endif
 Call STC_MET(ACLA,ACLA.ACLAM(M),LIGNE,CLOB,DIF)
Next
LIGNE = "" : Gosub ADDCLB
End

Subprog STC_OPERATION(ACLA,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
For O=1 To maxtab(ACLA.ACLAO)
 If O=1 : Gosub INTERLINE From ACLAVALTRT : Gosub SUB_COM_OPERATION From ACLAVALTRT : Endif
 Call STC_MET(ACLA,ACLA.ACLAO(O),LIGNE,CLOB,DIF)
Next
LIGNE = "" : Gosub ADDCLB
End

#-------------------------------------------------#
Subprog STC_MET(ACLA,ACLAM,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable  Instance  ACLAM Using C_ACLAMET
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF

Local Integer MP
LIGNE = "# Fmethod"-ACLAM.INTITMET  : Gosub ADDCLB
LIGNE = "Fmethod "+ACLAM.CODMET+"("
For MP=1 To maxtab(ACLAM.ACLMP)
 If MP>1 : LIGNE += "," : Endif
 LIGNE += ACLAM.ACLMP(MP).CODPAR
Next
LIGNE += ")" : Gosub ADDCLB
For MP=1 To maxtab(ACLAM.ACLMP)
 LIGNE = func ACLAVALTRT.DECLARE_MODE(ACLAM.ACLMP(MP).MODPAR)-func ACLAVALTRT.DECLARE_TYPTYP(ACLAM.ACLMP(MP).TYPINTPAR)
 LIGNE -= ACLAM.ACLMP(MP).CODPAR
 If ACLAM.ACLMP(MP).TYPINTPAR=13
  If ACLAM.ACLMP(MP).DIMPAR>1
   LIGNE += "(1..)"
  Endif
  LIGNE -=  "Using "
  If  ACLAM.ACLMP(MP).CLAPAR<>"OBJECT" : LIGNE += "C_" : Endif
  LIGNE += ACLAM.ACLMP(MP).CLAPAR+" : # "-mess(ACLAM.ACLMP(MP).TYPINTPAR,33,1)
 Else
  LIGNE -= func ACLAVALTRT.DECLARE_DIME(ACLAM.ACLMP(MP).DIMPAR,ACLAM.ACLMP(MP).TYPINTPAR,ACLAM.ACLMP(MP).MODPAR)
 Endif
 Gosub ADDCLB
Next
LIGNE = func ACLAVALTRT.DECLARE_MODE(0)-func DECLARE_TYPDON(ACLAM.DONMET)
LIGNE -= ACLA.ACLAV.VARRET(ACLAM.DONMET)
LIGNE += ACLA.ACLAV.LENRET(ACLAM.DONMET)
Gosub ADDCLB
LIGNE = "Gosub "+ACLAM.CODMET+" From "+ACLA.ACLAV.CTLPRG  : Gosub ADDCLB
LIGNE = "End"
LIGNE -=  "[L]"+ACLA.ACLAV.VARRET(ACLAM.DONMET)
Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End

#------------------------------------------------------------------------------#
Funprog DECLARE_TYPDON(TYPDON)
Value Integer TYPDON
Case TYPDON
 When 1       : End "Date    "
 When 2       : End "Char    "
 When 3       : End "Integer "
 When 4       : End "Decimal "
 When 5       : End "Clbfile "
 When 6       : End "Blbfile "
 When Default : End "Char    "
Endcase
End

