LIGNE = "Value Char ACOLLECTION" : Gosub ADDCLB
LIGNE = "Local Integer ASTATUS"  : Gosub ADDCLB
LIGNE = "Local Char    "+ACLA.ACLAV.VARPRO+"(50)"  : Gosub ADDCLB
LIGNE = "Local Char    "+ACLA.ACLAV.VARPTH+"(50)"  : Gosub ADDCLB
LIGNE = "Local Char AEVENT(50) :  [L]AEVENT = [L]ACTION" : Gosub ADDCLB
LIGNE = "[L]"+ACLA.ACLAV.VARPRO+' = "" : Gosub ACTION From '+ACLA.ACLAV.TRTACT  : Gosub ADDCLB
