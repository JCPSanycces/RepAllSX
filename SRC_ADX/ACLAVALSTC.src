#------------------------------------------------------------------------------#
$STC_ACTION_PRO
LIGNE = "# Fmethod action properties" : Gosub ADDCLB
LIGNE = "Fmethod _ACTION(ACTION,TRAITMENT,CURPRO,CURPTH)" : Gosub ADDCLB
LIGNE = "Value Char ACTION" : Gosub ADDCLB
LIGNE = "Value Char TRAITMENT" : Gosub ADDCLB
LIGNE = "Variable Char CURPRO" : Gosub ADDCLB
LIGNE = "Variable Char CURPTH" : Gosub ADDCLB
LIGNE = "Local Integer ASTATUS"  : Gosub ADDCLB
LIGNE = 'Case [L]CURPRO' : Gosub ADDCLB
DIF +=1  : LIGNE = 'When ""           : Gosub METHODS From =[L]TRAITMENT' : Gosub ADDCLB : DIF -= 1
DIF +=1  : LIGNE = 'When Default    : Gosub PROPERTIES From =[L]TRAITMENT' : Gosub ADDCLB : DIF -= 1
LIGNE = 'Endcase' : Gosub ADDCLB
LIGNE = "End [L]ASTATUS" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
Return


#------------------------------------------------------------------------------#
Subprog STC_RICHMEDIA(ACLA,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
Local Integer C,B
For I=1 To maxtab(ACLA.ACLAF)
 If ACLA.ACLAF(I).ATY<>null & find(ACLA.ACLAF(I).ATY.TYPTYP,10)>0 : C=1 : Endif
 If ACLA.ACLAF(I).ATY<>null & find(ACLA.ACLAF(I).ATY.TYPTYP,9)>0 : B=1 : Endif
Next
If !C & !B : End : Endif
If C
 LIGNE = "# Fmethod AREAD_CLB " : Gosub ADDCLB
 LIGNE = "Fmethod AREAD_CLB(_PRONAME,_KEYVAL,_CNT,_CLB)" : Gosub ADDCLB
 LIGNE = "Value Char _PRONAME" : Gosub ADDCLB
 LIGNE = "Value Char _KEYVAL" : Gosub ADDCLB
 LIGNE = "Variable Char _CNT" : Gosub ADDCLB
 LIGNE = "Variable Clbfile _CLB" : Gosub ADDCLB
 LIGNE = "Local Integer ASTATUS" : Gosub ADDCLB
 LIGNE = "Gosub AREAD_CLB From "+ ACLA.ACLAV.CTLPRG : Gosub ADDCLB
 LIGNE = "End [L]ASTATUS" : Gosub ADDCLB
 LIGNE = "" : Gosub ADDCLB
Endif
If B
 LIGNE = "# Fmethod AREAD_BLB " : Gosub ADDCLB
 LIGNE = "Fmethod AREAD_BLB(_PRONAME,_KEYVAL,_CNT,_BLB)" : Gosub ADDCLB
 LIGNE = "Value Char _PRONAME" : Gosub ADDCLB
 LIGNE = "Value Char _KEYVAL" : Gosub ADDCLB
 LIGNE = "Variable Char _CNT" : Gosub ADDCLB
 LIGNE = "Variable Blbfile _BLB" : Gosub ADDCLB
 LIGNE = "Local Integer ASTATUS" : Gosub ADDCLB
 LIGNE = "Gosub AREAD_BLB From "+ ACLA.ACLAV.CTLPRG : Gosub ADDCLB
 LIGNE = "End [L]ASTATUS" : Gosub ADDCLB
 LIGNE = "" : Gosub ADDCLB
Endif
End

