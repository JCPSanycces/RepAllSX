  LIGNE = "Value Char  _PRO" : Gosub ADDCLB
  LIGNE = "Value Char  _LAN" : Gosub ADDCLB
  LIGNE = "Local Char _INTIT_TRAD(250)" : Gosub ADDCLB
  LIGNE = "[L]_INTIT_TRAD = func ASYRSUB.AGETTEXTRA(this.AXX,[L]_PRO,[L]_LAN)" : Gosub ADDCLB
  LIGNE = "End [L]_INTIT_TRAD" : Gosub ADDCLB
  LIGNE = "" : Gosub ADDCLB
  Break
 Endif
Next
Return

#------------------------------------------------------------------------------#
$STC_SETTEXTRA
For I=1 To maxtab(ACLA.ACLAF)
 If ACLA.ACLAF(I).ATY<>null &  find(ACLA.ACLAF(I).ATY.CODTYP,"AXX","AX1","AX2","AX3")
  LIGNE = "# Set text" : Gosub ADDCLB
  LIGNE = "Fmethod ASETTEXTRA(_PRO,_INTIT)" : Gosub ADDCLB
  LIGNE = "Value Char      _PRO" : Gosub ADDCLB
  LIGNE = "Value Char      _INTIT" : Gosub ADDCLB
  LIGNE = "Local Integer  RO,STA" : Gosub ADDCLB
  LIGNE = "[L]RO = isReadonly" : Gosub ADDCLB
  LIGNE = "If [L]RO : isReadonly = 0 : Endif" : Gosub ADDCLB
  LIGNE = "Call ASETTEXTRA(this.AXX,this.AllocGrp,[L]_PRO,[L]_INTIT,this.ACTX.LAN) From ASYRSUB" : Gosub ADDCLB
  LIGNE = "If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_AUPD : Endif" : Gosub ADDCLB
  LIGNE = "If [L]RO : isReadonly = 1 : Endif" : Gosub ADDCLB
  LIGNE = "End [L]STA" : Gosub ADDCLB
  LIGNE = "" : Gosub ADDCLB
  LIGNE = "# Set text by lan" : Gosub ADDCLB
