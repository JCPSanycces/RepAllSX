$STC_AGETTEXTRA
For I=1 To maxtab(ACLA.ACLAF)
 If ACLA.ACLAF(I).ATY<>null &  find(ACLA.ACLAF(I).ATY.CODTYP,"AXX","AX1","AX2","AX3")
  LIGNE = "" : Gosub ADDCLB
  LIGNE = "# Get text" : Gosub ADDCLB
  LIGNE = "Fmethod AGETTEXTRA(_PRO)" : Gosub ADDCLB
  LIGNE = "Value Char  _PRO" : Gosub ADDCLB
  LIGNE = "Local Char _INTIT_TRAD(250)" : Gosub ADDCLB
  LIGNE = "[L]_INTIT_TRAD = func ASYRSUB.AGETTEXTRA(this.AXX,[L]_PRO,this.ACTX.LAN)" : Gosub ADDCLB
  LIGNE = "End [L]_INTIT_TRAD" : Gosub ADDCLB
  LIGNE = "" : Gosub ADDCLB
  LIGNE = "# Get text by lan" : Gosub ADDCLB
