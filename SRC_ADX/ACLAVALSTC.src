#------------------------------------------------------------------------------#
Subprog  STC_METHODES_TAB(ACLA,LIGNE,CLOB,DIF)
Variable Instance ACLA Using OBJECT
Variable Char LIGNE
Variable Clbfile CLOB
Variable Integer DIF
Local Integer J,G
Gosub INTERLINE From ACLAVALTRT
Gosub SUB_METHODES_TAB From ACLAVALTRT
LIGNE = "Fmethod ADDLINE(_ACOLLECTION,ALINE)" : Gosub ADDCLB
LIGNE = "Value Char _ACOLLECTION" : Gosub ADDCLB
LIGNE = "Value Integer ALINE" : Gosub ADDCLB
LIGNE = "Local Integer _ALINE" : Gosub ADDCLB
LIGNE = "Gosub ADDLINE From "+ACLA.ACLAV.CTLPRG : Gosub ADDCLB
LIGNE = "End [L]_ALINE" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
LIGNE = "Fmethod ADELLINE(_ACOLLECTION,ALINE)" : Gosub ADDCLB
LIGNE = "Value Char _ACOLLECTION" : Gosub ADDCLB
LIGNE = "Value Integer ALINE" : Gosub ADDCLB
LIGNE = "Local Integer _ALINE" : Gosub ADDCLB
LIGNE = "Gosub ADELLINE From "+ACLA.ACLAV.CTLPRG : Gosub ADDCLB
LIGNE = "End [L]_ALINE" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
LIGNE = "Fmethod AGETINDBYLINE(_AINS,ALINE)" : Gosub ADDCLB
LIGNE = "Value Char _AINS" : Gosub ADDCLB
LIGNE = "Value Integer ALINE" : Gosub ADDCLB
LIGNE = 'End func ASYRSUBTAB.GETINDBYLINE([L]ALINE,[L]_AINS,this)' : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
LIGNE = "Fmethod AGETDIM(_ACOLLECTION)" : Gosub ADDCLB
LIGNE = "Value Char _ACOLLECTION" : Gosub ADDCLB
LIGNE = "Local Integer _ALINE" : Gosub ADDCLB
LIGNE = "Gosub AGETDIM From "+ACLA.ACLAV.CTLPRG : Gosub ADDCLB
LIGNE = "End [L]_ALINE" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
LIGNE = "Fmethod AGETMIN(_ACOLLECTION)" : Gosub ADDCLB
LIGNE = "Value Char _ACOLLECTION" : Gosub ADDCLB
LIGNE = "Local Integer _ALINE" : Gosub ADDCLB
LIGNE = "Gosub AGETMIN From "+ACLA.ACLAV.CTLPRG : Gosub ADDCLB
LIGNE = "End [L]_ALINE" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
LIGNE = "Fmethod SORT3(_AINS,_PRO1,_PRO2,_PRO3)" : Gosub ADDCLB
LIGNE = "Value Char _AINS" : Gosub ADDCLB
LIGNE = "Value Char _PRO1" : Gosub ADDCLB
LIGNE = "Value Char _PRO2" : Gosub ADDCLB
LIGNE = "Value Char _PRO3" : Gosub ADDCLB
LIGNE = "Local Integer _STA" : Gosub ADDCLB
LIGNE = "Call SORT3(this,_STA,_AINS,_PRO1,_PRO2,_PRO3) From ASYRSUBTAB" : Gosub ADDCLB
LIGNE = "End [L]_STA" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
LIGNE = "Fmethod SORT(_AINS,_PRO)" : Gosub ADDCLB
LIGNE = "Value Char _AINS" : Gosub ADDCLB
LIGNE = "Value Char _PRO()(0..)" : Gosub ADDCLB
LIGNE = "Local Integer _STA" : Gosub ADDCLB
LIGNE = "Call SORT(this,_STA,_AINS,_PRO) From ASYRSUBTAB" : Gosub ADDCLB
LIGNE = "End [L]_STA" : Gosub ADDCLB
LIGNE = "" : Gosub ADDCLB
End
