#<AdxTL>@(#)48.0.0.0 $Revision$
Call OBJET("AFO",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "SETBOUT"   : Gosub SETBOUT
 When "FERME"     : Gosub FERME
 When "VERIF_MOD" : Gosub VERIF_MOD
 When "INICRE"    : Gosub INICRE
 When Default
Endcase
Return

$SETBOUT
Lock [AFO]
If fstat
 Grizo
Endif
Return

$FERME
Unlock [AFO]
Return

$VERIF_MOD
Local Char BID(80)
For I=0 To [M]NBLIG-1
 Read [AFO]AFO0 = [M]CODFIC(I)
 If fstat
  [M]MODIF(I) = 2
 Elsif [F:AFO]FORDIM<>[M]FORDIM(I)
  [M]MODIF(I) = 1
 Else
  [M]MODIF(I) = 0
 Endif
Next I
Return

$INICRE
Case [M]MODIF(nolign-1)
 When 0
  If dim([F:AFO]CREUSR)>0 & dim([M]CREUSR)>0 : [F:AFO]CREUSR = [M]CREUSR(nolign-1) : Endif
  If dim([F:AFO]CREDAT)>0 & dim([M]CREDAT)>0 : [F:AFO]CREDAT = [M]CREDAT(nolign-1) : Endif
 When 1 : # Modification
  If dim([F:AFO]CREUSR)>0 & dim([M]CREUSR)>0 : [F:AFO]CREUSR = [M]CREUSR(nolign-1) : Endif
  If dim([F:AFO]CREDAT)>0 & dim([M]CREDAT)>0 : [F:AFO]CREDAT = [M]CREDAT(nolign-1) : Endif
  If dim([F:AFO]UPDUSR)>0 : [F:AFO]UPDUSR = GUSER   : Endif
  If dim([F:AFO]UPDDAT)>0 : [F:AFO]UPDDAT = date$   : Endif
 When 2 : # Création
  If dim([F:AFO]CREUSR)>0 : [F:AFO]CREUSR = GUSER   : Endif
  If dim([F:AFO]CREDAT)>0 : [F:AFO]CREDAT = date$   : Endif
  If dim([F:AFO]UPDUSR)>0 : [F:AFO]UPDUSR = ""      : Endif
  If dim([F:AFO]UPDDAT)>0 : [F:AFO]UPDDAT = [0/0/0] : Endif
Endcase
Return

########################################
Subprog B2_NBLIG 
Local Integer MODU
Call SAILIB(14,MODU) From GESECRAN 
If MODU<>0 
 local File ATABLE 
 For [ATB]CODFIC Where MODULE=MODU 
  If !find([F:ATB]CODFIC,[M]CODFIC(0..[M]NBLIG-1)) 
   [M]CODFIC([M]NBLIG) = [F:ATB]CODFIC 
   [M]NBLIG += 1 
  Endif 
 Next 
 Affzo 
Endif 
End

