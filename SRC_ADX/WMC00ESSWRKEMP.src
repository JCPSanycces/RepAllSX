Gosub TEST From WMCR_ESSWRKEMP : End

############################################################################################
## C : Subprog AINSERT(INSTANCE)
## D : Subprog ADELETE(INSTANCE)
## R : Subprog AREAD(INSTANCE,UID)
## U : Subprog AUPDATE(INSTANCE)
############################################################################################
# ESSWRKEMP : ESSWRKEMP
############################################################################################

############################################################################################
### AVARIABLES
############################################################################################
$AVARIABLES
[L]ASTATUS =max([L]ASTATUS,fmet ESSWRKEMP._ADELERRORS([V]CST_ALLERRORS))
$_AVARIABLES
Local    Integer     A_LEVEL,A_I,A_NEWCOL,A_N1
Local    Integer    ASTATUS,A_RETIK,A_TYPMAJ,A_ASTALIN
Local    Char        A_STRSITE(GLONFCY),A_STRACC(GLONACS),CURPRO(50),A_PARENT(50),A_PATH(200),A_ABR(GLONABR),A_ERROR(250)
Local    Uuident    A_UUID

[L]A_LEVEL    = ESSWRKEMP.ACTX.LEVWML
[L]ASTATUS  = 0

Onerrgo ERR_OPENTAB
If find(ESSWRKEMP.ACTX.AFOLDER,nomap,"")>0
 Local File ESSWRKEMP [EWID]
 Local File ESSWRKEMP [AAA_]
Else
 Local File =ESSWRKEMP.ACTX.AFOLDER+".ESSWRKEMP" [EWID]
 Local File =ESSWRKEMP.ACTX.AFOLDER+".ESSWRKEMP" [AAA_]
Endif
Onerrgo
Return

$ERR_OPENTAB
[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKEMP.ASETERROR("",errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,[V]CST_AERROR))
Resume

############################################################################################
### Link
############################################################################################
$AOPEN_LINK
Gosub AVARIABLES
Link [EWID] With
& [AAA_]EWID0 = UID
& As [LNK_]
Return

############################################################################################
### ESSWRKEMP(WEWID)
############################################################################################
Funprog  _MAJSQL_ESSWRKEMP(WEWID)
Variable Instance WEWID Using C_ESSWRKEMP
Local Integer ASTATUS,A_I,A_J
Default File [F:EWID]
If WEWID.ASTALIN=[V]CST_ANEW
 Call INICRE(WEWID) From ASYRSUB
 SetInstance [F:EWID] With WEWID
 Write [F:EWID]
 If fstat
  Call FSTA("EWID",WEWID,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WEWID.updTick = [F:EWID]updTick
Elsif WEWID.ASTALIN=[V]CST_ALL or WEWID.ASTALIN=[V]CST_AUPD
 Call INIUPD(WEWID) From ASYRSUB
 SetInstance [F:EWID] With WEWID
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WEWID,"ESSWRKEMP")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 RewriteByKey [F:EWID]EWID0 = [F:EWID]UID
 If fstat
  Call FSTA("EWID",WEWID,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
 WEWID.updTick = [F:EWID]updTick
Elsif WEWID.ASTALIN=[V]CST_ADEL
 SetInstance [F:EWID] With WEWID
 [L]ASTATUS = func ASYRFNC._ACONTROL_DATASTABLE(WEWID,"ESSWRKEMP")
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
 DeleteByKey [F:EWID]EWID0 = [F:EWID]UID
 If fstat
  Call FSTA("EWID",WEWID,[L]ASTATUS) From ASYRSUB
  End [L]ASTATUS
 Endif
Endif
End [V]CST_AOK



