#<AdxTL>@(#)10.0.0.0 $Revision$
############################################################
## CHGCOD Webisé...
############################################################
$ACTION
Case ACTION
 When "INIT"     : Gosub INIT
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
Endcase
Return

$INIT
Local Char    OCODE(250), NCODE(250), TEXTE(250), ACTION(15)
Local Char    OFMT(250), NFMT(250), FMT2(250), NOMDOS(20)(1..255)
Local Integer OK, I , NDOS, LG , OKTRT
Local Char    PROGOBJ(GLONADC) , PROGSUB(GLONADC) , PROGSPE(GLONADC) , PROGSPV(GLONADC)(1..50)
Local Integer PSUB , PSPE , PSPV , PSTD
Local Char    SVSUPP(250), SAVFONC(GLONAFC) , IDENT(250), OIDENT(250), DEFMSK(250)
Local Char    TYP(GLONAOB), ABREV(GLONAOB) , APPLI(GLONADS)
Local Char    CODE(250), SUPP(250)(16), SVSUPP(250)
Local Char    PCLE1(250), PCLE2(250) , NEWCOD(250)
Local Integer SILENCE

TYP       = PARAM(1)
CODE      = PARAM(2)
Call SUPPN(PARAM(3),SUPP) From CONTOBJ
SVSUPP    = SUPP(0)
PARAM(4)  = "0"           : # Status de retour
If dim(PARAM)>4
 NEWCOD   = PARAM(5)      : # Nouveau code - Paramètre optionnel
 SILENCE  = val(PARAM(6)) : # Pour ne pas afficher la boîte de tempo - Paramètre optionnel
 APPLI    = PARAM(7)      : # Nom du dossier - Paramètre optionnel
Endif
If TYP="" : FIN = 1 : Return : Endif

Call SETPROG(TYP,PROGOBJ,PROGSUB,PROGSPE,PROGSPV,PSTD,PSUB,PSPE,PSPV) From CONTOBJ
If APPLI<>""
 Call EXISTE_ADX("",APPLI,PROGOBJ,OKTRT) From ORDSYS
 If OKTRT
  PROGOBJ = APPLI+"."+PROGOBJ
 Endif
Endif

I = dim(NOMDOS)
If APPLI<>""
 NDOS = 1 : NOMDOS(NDOS) = APPLI
 Local File =APPLI+".ADOVAL" [ADWX]
 Read [ADWX]ADW0 = "";"";"HISDOS"
 If !fstat & [F:ADWX]VALEUR<>""
  NDOS += 1 : NOMDOS(NDOS) = [F:ADWX]VALEUR
 Endif
 Close Local File [ADWX]
Else
 NDOS = 1 : NOMDOS(NDOS) = nomap(0)
 If GDOSH<>""
  NDOS += 1 : NOMDOS(NDOS) = GDOSH
 Endif
Endif

If clalev([F:AXX])>0 : Close Local File [AXX] : Endif
If clalev([F:ATX])>0 : Close Local File [ATX] : Endif

If APPLI<>""
 Local File =APPLI+".AOBJET" [AOB_] , =APPLI+".ATABLE" [ATB_] , =APPLI+".ATABZON" [ATZ_]
&         , =APPLI+".ATEXTE" [ATX] , =APPLI+".ATEXTRA" [AXX]
Else
 Local File AOBJET [AOB_] , ATABLE [ATB_] , ATABZON [ATZ_] , ATEXTE [ATX] , ATEXTRA [AXX]
Endif

ABREV = TYP
Read [AOB_]ABREV = TYP
If fstat : FIN=1 : Return : Endif
Read [ATB_]CODFIC = [F:AOB_]NOMFIC
If fstat : FIN=1 : Return : Endif

Gosub NOMFIC From =PROGOBJ
Gosub TIT    From =PROGOBJ
Gosub SETCLE From =PROGOBJ

If APPLI<>""
 Local File =APPLI+"."+NOMFIC [AN__]
 Local File =APPLI+"."+NOMFIC
Else
 Local File =NOMFIC [AN__]
 Gosub OUVFIC From =PROGOBJ
Endif
Call LECTURE(TYP,CODE,SUPP) From CONTOBJ
If fstat : FIN=1 : Return : Endif
[F:AN__] = [F]

DEFMSK = dbgstr(1)
Local Mask CHGCOD [DIAX]
Default Mask DEFMSK

Call FORMCLE(NFMT,LG,TEXTE) From =PROGOBJ
If (dim([L]CLEVALEUR)<0 & CLESEC(0)<>"") | (dim([L]CLEVALEUR)>0 & CLESUPP(0)<>"")
 Call FORMCLE2(FMT2) From =PROGOBJ
Endif
I=instr(1,NFMT,":")
If I & !instr(1,left$(NFMT,I-1),"P") : OFMT=left$(NFMT,I-1)+"P"+right$(NFMT,I) : Endif
Call IDENT3(TYP,OIDENT,CODE,SUPP) From GOBJTXT

Raz [M:DIAX]
[M:DIAX]TYP    = TYP    : # Objet
[M:DIAX]LIBOBJ = TIT    : # Intitulé objet
[M:DIAX]OFMT   = OFMT   : # Format ancien  code
[M:DIAX]NFMT   = NFMT   : # Format nouveau code
[M:DIAX]NCODE  = NEWCOD : # Nouveau code
#CHECK UNUSED_BEGIN
If dim([L]CLEVALEUR)>0 : ## GEODE
 If CLEFCY<>""
  I=find(CLEFCY,CLEPRIM,CLESEC)
  If I=1 : [M:DIAX]FCY=CODE
  Else   : [M:DIAX]FCY=SUPP(I-2)
  Endif
  [M:DIAX]INTIT=[M:DIAX]FCY
 Endif
 If CLEDEP<>""
  I=find(CLEDEP,CLEPRIM,CLESEC)
  If I=1 : [M:DIAX]DEP=CODE
  Else   : [M:DIAX]DEP=SUPP(I-2)
  Endif
  [M:DIAX]INTIT-=[M:DIAX]DEP
 Endif
 I=find(CLEVALEUR,CLEPRIM,CLESEC)
 If I=1 : [M:DIAX]OCODE=CODE
 Else   : [M:DIAX]OCODE=SUPP(I-2)
 Endif
 If CLESUPP(0)<>"" & TYPGES<>3
  [M:DIAX]CLE2 = 1
  I=find(CLESUPP(0),CLEPRIM,CLESEC)
  If I=1 : [M:DIAX]SUPP=CODE
  Else   : [M:DIAX]SUPP=SUPP(I-2)
  Endif
 Endif
Else
 [M:DIAX]OCODE = num$(evalue("[F:"+[L]ABFIC+"]"+CLEPRIM))
 If CLESEC<>"" & ((dim(CLESEC)=1 & TYPGES<>3) or (dim(CLESEC)=2 & TYPGES=3))
  [M:DIAX]CLE2 = 1
  [M:DIAX]SUPP = SUPP(0)
 Endif
Endif
#CHECK UNUSED_END
# Intitulé paramètre
If [M:DIAX]CLE2
 If [M:DIAX]INTIT<>"" : [M:DIAX]INTIT += " " : Endif
 If left$(FMT2,1)="L"
  [M:DIAX]INTIT += mess(val([M:DIAX]SUPP),val(right$(FMT2,3)),1)
 Else
  [M:DIAX]INTIT += [M:DIAX]SUPP
 Endif
Endif
If [M:DIAX]INTIT<>""
 [M:DIAX]INTIT ="("+[M:DIAX]INTIT+")"
Endif
# Intitulé de l'ancien code
If [F:ATB_]INTIT<>""
 If evalue("type([F:"+[L]ABFIC+"]"+[F:ATB_]INTIT+")")>10
  [M:DIAX]INTIT -= evalue("[F:"+[L]ABFIC+"]"+[F:ATB_]INTIT)
 Else
  TEXTE=""
  Read [ATZ_]CODZONE = [F:ATB_]CODFIC ; [F:ATB_]INTIT
  If !fstat
   If [F:ATZ_]CODTYP="ATX"
    Call TEXTE(evalue("[F:"+[L]ABFIC+"]"+[F:ATB_]INTIT),TEXTE) From OBJDIV
   Elsif find([F:ATZ_]CODTYP,"AXX","AX1","AX2","AX3")
    If dim([L]CLEVALEUR)>0 : ## GEODE
     If CLEFCY<>""  : PCLE1 = [M:DIAX]FCY : Endif
     If CLEDEP<>""  : PCLE2 = [M:DIAX]DEP : Endif
     If [M:DIAX]CLE2 : PCLE2+="~"+[M:DIAX]SUPP : Endif
     PCLE2+="~"+[M:DIAX]OCODE
     If left$(PCLE2,1)="~" : PCLE2 = right$(PCLE2,2) : Endif
    Elsif [M:DIAX]CLE2
     PCLE1 = SUPP(0)
     PCLE2 = CODE
    Else
     PCLE1 = CODE
    Endif
    Call LECTEXTRA(TEXTE,[F:ATB_]CODFIC,[F:ATB_]INTIT,PCLE1,PCLE2) From ATEXTRA
   Endif
  Endif
  If TEXTE<>""
   If [M:DIAX]INTIT<>"" : [M:DIAX]INTIT-= TEXTE
   Else                : [M:DIAX]INTIT = TEXTE
   Endif
  Endif
 Endif
Endif
Return

$CONTROLE
OCODE = num$([M:DIAX]OCODE)
NCODE = num$([M:DIAX]NCODE)
SUPP(0) = num$([M:DIAX]SUPP)
If !SILENCE
 Call TEMPON("F") From GESECRAN
Endif
OK = 1 : ACTION = "VERF_CHG" : Gosub ACTION From GOBJET
If !SILENCE
 Call TEMPOFF From GESECRAN
Endif
If !OK
 If NEWCOD<>""
  FIN = 1
 Else
  SAI = 1
 Endif
Endif
Return

$EXEC
GOK=1
For I=NDOS To 1 Step -1
 Call CHANGE(NOMDOS(I),TYP,OCODE,NCODE,SUPP(0),SILENCE)
 If GOK<1 : Break : Endif
Next I
If GOK<1 : FIN=1 : Return : Endif

SUPP(0) = SVSUPP
If dim([L]CLEVALEUR)>0 : ## GEODE
 I=find(CLEVALEUR,CLEPRIM,CLESEC)
 If I=1 : CODE = NCODE
 Else   : SUPP(I-2)= NCODE
 Endif
Else
 CODE = NCODE
Endif
SAVFONC = GFONCTION
GFONCTION = "GES"+TYP
Call IDENT3(TYP,IDENT,CODE,SUPP) From GOBJTXT
Call ESPION(NOMFIC,6,OIDENT,IDENT) From ESPION
Call WORKFLOW(2,TYP,"H",IDENT) From AWRK
GFONCTON = SAVFONC
PARAM(2) = CODE
PARAM(3) = ""
For I=0 To dim(CLESEC)-1
 If PARAM(3)<>"" : PARAM(3) += "~" : Endif
 PARAM(3) += SUPP(I)
Next I
PARAM(4) = "1"
Return

##########################################################
Subprog CHANGE(APPLI,ABREV,OCODE,NCODE,SUPP,SILENCE)
##########################################################
Value Char APPLI()
Value Char ABREV()
Value Char OCODE()
Value Char NCODE()
Value Char SUPP()
Value Integer SILENCE

Gosub DEFVAR
Onerrgo ERRCHG

If nomap=APPLI or filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)<0
 Local File ADOVAL [ADW]
Else
 Local File =APPLI+".ADOVAL" [ADW]
Endif
Read [ADW]ADW0 = "";"";"TYPDBA"
Close Local File [ADW]

Gosub OUVFIC

If !SILENCE
 Call OUVRE_VLC(mess(2,115,1)-APPLI,"","") From GESECRAN : # Changement de code
 Call AFF_VLC(mess(56,123,1),"") From GESECRAN : # Table
Endif
Call CHANGE2(APPLI,ABREV,OCODE,NCODE,SUPP,SILENCE)
If APPLI<>HISDOS
 ACTION = "AP_CHANGE" : Gosub ACTION From GOBJET
Endif
If !SILENCE
 Call FERME_VLC From GESECRAN
Endif
End

$DEFVAR
Local Char    FICHIER(GLONATB) , FICANU(GLONATB) , FICDEB(GLONATB) , TABCHG(GLONATB)
Local Char    ZONE(GLONAVA)(1..99) , SZONE(30)(1..99,1..16)
Local Integer TYPZ(1..99,1..16) , INDZ(1..99)
Local Char    CLE1(250)
Local Integer NBCLE , I1 , I2 , I3
Local Char    SUBCLE(GLONAVA)(1..16)
Local Integer I , J , K , NBZ , OK , REW
Local Integer NOCRIT , NOLIEN , MAXFIC , NTYP
Local Integer DIME(1..99) , ICRITERE
Local Char    CRITERE(255)(1..3) , SUBCRIT(250)
Local Char    ACTION(15) , HISDOS(GLONADS)
Local Char    VALEUR(250)
Local Char    CHAINE(250) , CLE(250)
Local Char    ANCIEN(250) , NOUVEAU(250)
Local Char    PROGSUB(GLONADC) , PROGSPE(GLONADC) , PROGSPV(GLONADC)(1..50) , PROGOBJ(GLONADC)
Local Integer PSUB , PSPE , PSPV , PSTD
Local Integer TRANS , NBCRIT , HISTO

Call SETPROG(ABREV,PROGOBJ,PROGSUB,PROGSPE,PROGSPV,PSTD,PSUB,PSPE,PSPV) From CONTOBJ
Gosub NOMFIC From =PROGOBJ
Gosub SETCLE From =PROGOBJ : #106801
If APPLI<>""
 Local File =APPLI+".ADOVAL" [ADWX]
 Read [ADWX]ADW0 = "";"";"HISDOS"
 If !fstat & [F:ADWX]VALEUR<>""
  HISDOS = [F:ADWX]VALEUR
 Endif
 Close Local File [ADWX]
Else
 HISDOS = GDOSH
Endif

HISTO = (filinfo(filpath("","histo","",APPLI),0)>0)
#MAXFIC = 1000 : #  113660 CCL : 25 : # Pour toutes les bases
MAXFIC = 25 : # replace with the old value because with the current algo Too many tables is open. New US to see the fisrt issue.
TRANS = adxlog
Return

$OUVFIC
If nomap=APPLI or filinfo(filpath("FIL","ATABLE","fde",APPLI),0)<0
 Local File ATABLE  [ATB_]
&         , ATABZON [ATZ_]
&         , ATABIND [ATI_]
&         , ATABZON [AT2_]
&         , AOBJET  [AOB_]
Else
 Local File =APPLI+".ATABLE"  [ATB_]
&         , =APPLI+".ATABZON" [ATZ_]
&         , =APPLI+".ATABIND" [ATI_]
&         , =APPLI+".ATABZON" [AT2_]
&         , =APPLI+".AOBJET"  [AOB_]
Endif
Return

Subprog CHANGE2(APPLI,ABREV,OCODE,NCODE,SUPP,SILENCE)
Value Char APPLI()
Value Char ABREV()
Value Char OCODE()
Value Char NCODE()
Value Char SUPP()
Value Integer SILENCE

Gosub DEFVAR

Read [AOB_]ABREV = ABREV
TABCHG =  [F:AOB_]NOMFIC
Read [ATB_]CODFIC = [F:AOB_]NOMFIC
If fstat : GOK=0 : End : Endif
FICANU = [F:ATB_]CODFIC
Read [ATI_]NUMLIG(2) = [F:ATB_]CODFIC;1
If fstat : GOK=0 : End : Endif

NBCLE = 0
CLE1 = [F:ATI_]DESCRIPT
While CLE1<>""
 I1 = instr(1,CLE1,"+")
 I2 = instr(1,CLE1,"-")
 If I2
  If I1 : I1 = min(I1,I2) : Else : I1 = I2 : Endif
 Endif
 NBCLE += 1
 If I1
  SUBCLE(NBCLE) = left$(CLE1,I1-1)
  CLE1 = right$(CLE1,I1+1)
 Else
  SUBCLE(NBCLE) = CLE1
  CLE1 = ""
 Endif
Wend

If ![L]TRANS : Call DEBTRANS From GLOCK : Endif
FICDEB = "" : Gosub TR1
End

$TR1
FICOUV=0 : CONTINUE=0 : GOK=1
If ![L]TRANS : Trbegin [ATZ_] : Endif
 For [ATZ_]LIEN(2) Where LIEN=FICANU & CODFIC>FICDEB
  FICHIER = [F:ATZ_]CODFIC
  Read [ATB_]CODFIC = FICHIER
  If !SILENCE
   Call AFF_VLC(mess(56,123,1),[F:ATZ_]CODFIC) From GESECRAN : # Table
  Endif
  K = 0
  If [F:ATB_]TYPFIC=3 & nomap=APPLI & filinfo(filpath("FIL",FICHIER,"fde"),0)>0 : # Table système
   K = 1
  Elsif filinfo(filpath("FIL",FICHIER,"fde",APPLI),0)>0
   K = 1
  Endif
  If K & APPLI=HISDOS
   Call VUE_OK(FICHIER,APPLI,"FIL",K) From DOSVUE
   K = !K
  Endif
  If K
   If nomap=APPLI
    Local File =FICHIER
   Else
    Local File =APPLI+"."+FICHIER
   Endif
   ANCIEN = OCODE : NOUVEAU = NCODE
   Raz NBZ , INDZ  , NOCRIT , CRITERE , ICRITERE , NBCRIT
   For [ATZ_]LIEN
    If FICHIER<>TABCHG or !find([F:ATZ_]CODZONE,SUBCLE)
     NOLIEN = 0
     NBZ += 1
     ZONE(NBZ) = [F:ATZ_]CODZONE
     DIME(NBZ) = evalue("dim([F:"+[ATB_]ABRFIC+"]"+[F:ATZ_]CODZONE+")")
     # If DIME(NBZ)>1 : NOCRIT = 1 : Endif
     SUBCRIT = ""
     If [F:ATZ_]EXPLIEN=""
      Case evalue("type([F:AN__]"+SUBCLE(1)+")")
       When 1,2,4,5,6,7,8,9
        VALEUR = num$(evalue("[F:AN__]"+SUBCLE(1)))
       When 3
        VALEUR = '['+num$(evalue("[F:AN__]"+SUBCLE(1)))+']'
       When Default
        VALEUR = '"'+evalue("[F:AN__]"+SUBCLE(1))+'"'
      Endcase
      If DIME(NBZ)=1
       SUBCRIT = [F:ATZ_]CODZONE+'='+VALEUR
      Endif
      SZONE(NBZ,1) = [F:ATZ_]CODZONE
      TYPZ(NBZ,1) = 1
     Else
      CLE1 = vireblc(format$("KT:80X",[F:ATZ_]EXPLIEN),2)
      I1 = 0
      I2 = 0
      While CLE1<>""
       I1 += 1
       K = instr(1,CLE1,";")
       If K
        SZONE(NBZ,I1) = left$(CLE1,K-1) : CLE1 = right$(CLE1,K+1)
       Else
        SZONE(NBZ,I1) = CLE1 : CLE1 = ""
       Endif
       # zone CTRLVL de dim>1, on fait ici comme si l’expression de lien n’est pas FCY;DEP;ITM;CTRLVL mais FCY;DEP;ITM;CTRLVL(indice)
       If DIME(NBZ)>1 & SZONE(NBZ,I1)=ZONE(NBZ) : SZONE(NBZ,I1)+="(indice)" : Endif
      Wend
      For I1=1 To NBCLE
       Read [AT2_]CODZONE = FICHIER;SZONE(NBZ,I1)
       If !fstat
        TYPZ(NBZ,I1) = 1
        Case evalue("type([F:AN__]"+SUBCLE(I1)+")")
         When 1,2,4,5,6,7,8,9
          VALEUR = num$(evalue("[F:AN__]"+SUBCLE(I1)))
         When 3
          VALEUR = '['+num$(evalue("[F:AN__]"+SUBCLE(I1)))+']'
         When Default
          VALEUR = '"'+evalue("[F:AN__]"+SUBCLE(I1))+'"'
        Endcase
        If SUBCRIT<>"" : SUBCRIT += " & " : Endif
        SUBCRIT += SZONE(NBZ,I1)+'='+VALEUR
        If NBCRIT=1 & CRITERE="("+SUBCRIT+")" : Break : Endif
        # optimisation du critere pour éviter des ‘or’ inutiles
       Else
        TYPZ(NBZ,I1) = 0
       Endif
      Next I1
     Endif
     If NOLIEN
      NBZ -= 1
     Elsif NOCRIT=0
      If SUBCRIT=""
       NOCRIT=1
      Else
       K = 0
       For I3=1 To dim(CRITERE)
        K = instr(1,CRITERE(I3),"("+SUBCRIT+")")
        If K : Break : Endif
       Next I3
       If !K
        If NBCRIT
         For I3=1 To dim(CRITERE)
          # optimisation du critere pour éviter des ‘or’ inutiles
          If pat(CRITERE(I3),string$(NBCRIT-1,"("+SUBCRIT+" & *) | ")+"("+SUBCRIT+" & *)")
           Raz CRITERE , ICRITERE , NBCRIT
           Break
          Endif
         Next I3
        Endif
        Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","("+SUBCRIT+")","|") From GOBJSUB
        NBCRIT += 1
       Endif
      Endif
     Endif
    Endif
   Next ATZ_
   If NBZ<>0
    If NOCRIT : Raz CRITERE : Endif
    Gosub TRT_NORM
    If GOK<1 : Break : Endif
   Endif
   If MAXFIC
    FICOUV += 1
    If FICOUV>=MAXFIC
     CONTINUE = 1 : FICDEB = FICHIER : Break
    Endif
   Endif
  Endif
 Next ATZ_(2)
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Elsif !CONTINUE
  If !HISTO :#APPLI<>HISDOS
   Gosub NOMFIC From ="WO"+ABREV
   Gosub SETCLE From ="WO"+ABREV
   If APPLI=nomap
    Local File =NOMFIC [CHGT]
   Else
    Local File =APPLI+"."+NOMFIC [CHGT]
   Endif
   Raz CRITERE , ICRITERE
   If dim([L]CLEVALEUR)<0
    Case evalue("type([F:CHGT]"+CLEPRIM+")")
     When 1,2,4,5,6,7,8,9 : Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CLEPRIM+'='+OCODE,"") From GOBJSUB
     When 3               : Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CLEPRIM+'=['+num$(OCODE)+']',"") From GOBJSUB
     When Default         : Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CLEPRIM+'="'+OCODE+'"',"") From GOBJSUB
    Endcase
    If CLESEC<>"" & SUPP<>""
     Case evalue("type([F:CHGT]"+CLESEC+")")
      When 1,2,4,5,6,7,8,9 : Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CLESEC+'='+SUPP,"&") From GOBJSUB
      When 3               : Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CLESEC+'=['+num$(SUPP)+']',"&") From GOBJSUB
      When Default         : Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CLESEC+'="'+SUPP+'"',"&") From GOBJSUB
     Endcase
    Endif
   Else : ## GEODE
    Case evalue("type([F:CHGT]"+CLEVALEUR+")")
     When 1,2,4,5,6,7,8,9 : Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CLEVALEUR+'='+OCODE,"") From GOBJSUB
     When 3               : Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CLEVALEUR+'=['+num$(OCODE)+']',"") From GOBJSUB
     When Default         : Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CLEVALEUR+'="'+OCODE+'"',"") From GOBJSUB
    Endcase
    If CLESUPP(0)<>"" & SUPP<>""
     Case evalue("type([F:CHGT]"+CLESUPP(0)+")")
      When 1,2,4,5,6,7,8,9 : Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CLESUPP(0)+'='+SUPP,"&") From GOBJSUB
      When 3               : Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CLESUPP(0)+'=['+num$(SUPP)+']',"&") From GOBJSUB
      When Default         : Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CLESUPP(0)+'="'+SUPP+'"',"&") From GOBJSUB
     Endcase
    Endif
    If CLEFCY<>""
     Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CLEFCY+'="'+evalue("[F:AN__]"+CLEFCY)+'"',"&") From GOBJSUB
    Endif
    If CLEDEP<>""
     Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CLEDEP+'="'+evalue("[F:AN__]"+CLEDEP)+'"',"&") From GOBJSUB
    Endif
   Endif
   For [CHGT] Where evalue(CRITERE)
    If dim([L]CLEVALEUR)<0
     Case evalue("type([F:CHGT]"+CLEPRIM+")")
      When 1,2,4,5,6,7,8,9
       Assign "[F:CHGT]"+CLEPRIM With val(NCODE)
      When 3
       Assign "[F:CHGT]"+CLEPRIM With gdat$(NCODE)
      When Default
       Assign "[F:CHGT]"+CLEPRIM With NCODE
     Endcase
    Else
     Case evalue("type([F:CHGT]"+CLEVALEUR+")")
      When 1,2,4,5,6,7,8,9
       Assign "[F:CHGT]"+CLEVALEUR With val(NCODE)
      When 3
       Assign "[F:CHGT]"+CLEVALEUR With gdat$(NCODE)
      When Default
       Assign "[F:CHGT]"+CLEVALEUR With NCODE
     Endcase
    Endif
    If APPLI<>HISDOS
     ACTION = "CHANGE" : Gosub ACTION From GOBJET
    Endif
    If   GOK<1 : Break : Endif
    Rewrite [CHGT]
    If fstat
     GOK=0 : Call FSTA("CHGT") From GLOCK : Break
    Endif
   Next CHGT
   If   GOK<0 : Goto ROLL_TR1
   Elsif !GOK : Goto AB_TR1
   Endif
  Endif
 Endif
If ![L]TRANS : Commit : Endif
If CONTINUE
 Close Local File
 Gosub OUVFIC
 Goto TR1
Endif

## Vérif dans les paramètres

If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)<=0 or HISTO :#APPLI=HISDOS
 Return
Endif
If nomap=APPLI
 Local File ADOPAR [ADP]
&         , ADOVAL [ADW]
Else
 Local File =APPLI+".ADOPAR" [ADP]
&         , =APPLI+".ADOVAL" [ADW]
Endif
If ![L]TRANS : Trbegin [ADW] : Endif
 For [ADP] Where OBJET=ABREV
  OK = 1
  If SUPP<>"" & [F:ADP]VALUES(0)<>"" & SUPP<>[F:ADP]VALUES(0)
   OK = 0
  Endif
  If OK
   For [ADW] Where PARAM=[F:ADP]PARAM & VALEUR=OCODE
    [F:ADW]VALEUR = NCODE
    Rewrite [ADW]
    If fstat
     GOK=0 : Call FSTA("ADW") From GLOCK : Break 2
    Endif
   Next ADW
  Endif
 Next ADP
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
If ![L]TRANS : Commit : Endif
Close Local File [ADP] , [ADW]
Return

$TRT_NORM
If CRITERE<>""
 Filter [F] Where evalue(CRITERE)
Endif
For [F]
 REW = 0
 For I=1 To NBZ
  For J=0 To DIME(I)-1
   indice = J
   Gosub TEST
  Next J
 Next I
 If REW
  Rewrite [F]
  If fstat
   For I=1 To adxmto
    If FICHIER=filename(I) | instr(1,filename(I),"/"+FICHIER)
     Break
    Endif
   Next
   GOK=0 : Call FSTA(fileabre(I)) From GLOCK : Break
  Endif
 Endif
Next
Filter [F]
Return

$TEST
OK = 1
For K=1 To NBCLE
 If TYPGES=3 & SUBCLE(K)=CLELIG : Break : Endif : #106801
 If TYPZ(I,K)=1
  If instr(1,SZONE(I,K),"(")
   If evalue("[F:"+[F:ATB_]ABRFIC+"]"+SZONE(I,K))<>evalue("[F:AN__]"+SUBCLE(K))
    OK=0 : Break
   Endif
  Elsif J=0 | evalue("dim([F:"+[F:ATB_]ABRFIC+"]"+SZONE(I,K)+")")>J
   If evalue("[F:"+[F:ATB_]ABRFIC+"]"+SZONE(I,K)+"("+num$(J)+")")<>evalue("[F:AN__]"+SUBCLE(K))
    OK = 0 :Break
   Endif
  Endif
 Else
  If left$(SZONE(I,K),1)>="A" & left$(SZONE(I,K),1)<="Z"
   If evalue("[F:"+[F:ATB_]ABRFIC+"]"+SZONE(I,K))<>evalue("[F:AN__]"+SUBCLE(K))
    OK = 0 : Break
   Endif
  Else
   If evalue(SZONE(I,K))<>evalue("[F:AN__]"+SUBCLE(K))
    OK = 0 : Break
   Endif
  Endif
 Endif
Next K
If OK
 NTYP = evalue("type([F:"+[F:ATB_]ABRFIC+"]"+ZONE(I)+"("+num$(J)+"))")
 Case NTYP
  When 1,2,4,5,6,7,8,9
   Assign "[F:"+[F:ATB_]ABRFIC+"]"+ZONE(I)+"("+num$(J)+")" With val(NOUVEAU)
  When Default
   Assign "[F:"+[F:ATB_]ABRFIC+"]"+ZONE(I)+"("+num$(J)+")" With NOUVEAU
 Endcase
 REW = 1
Endif
Return

$ROLL_TR1
If ![L]TRANS
 Rollback
 Call ROLL From GLOCK
 If GROLL : Return : Else : Goto TR1 : Endif
Else
 Return
Endif

$AB_TR1
If ![L]TRANS : Rollback : Endif
Return

$ERRCHG
Call ECR_TRACE(errp+"("+num$(errl)+")"-":"-errmes$(errn)-errm,1) From GESECRAN
If adxlog & ![L]TRANS : Rollback : Endif
If !SILENCE
 Call FERME_VLC From GESECRAN
Endif
GOK = 0 : # 113660 CCL case or transaction is open before
End

#########################################################################
## Etiquettes du masque CHGCOD
#########################################################################
Subprog C_NCODE(VALEUR)
Variable Char VALEUR()

Call CONTROLE([M]TYP,"",VALEUR,[M]SUPP,mkstat) From CONTOBJ
If mkstat
 mkstat=0 : GMESSAGE=""
Else
 GMESSAGE = mess(22,100,1) : # Fiche déjà existante
 mkstat=2
Endif
End

