# Structure AVARLOCD

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#  When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "COD"    : Gosub COD
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return



$COD
Case [L]ARULE
    When "CONTROL"       : Gosub COD_CONTROL
Endcase
Return


$COD_CONTROL
  Local Integer I
  Local Char    CHAINE(250)
  Case this.TYP
   When 1                           # Global variables
    Local File AGLOBVAR [AGB]
    CHAINE = this.COD
    I = instr(1,CHAINE,"]")
    If I>0
     CHAINE = right$(CHAINE,I+1)
    Endif
    If CHAINE<="a" : # On ne vérifie pas les variables systèmes
     Read [AGB]AGB0=CHAINE
     If !fstat
       this.INTIT = [AGB]INTIT
     Else
      # Undefined variable
      [L]ASTATUS = fmet this.ASETERROR("COD",mess(3,124,1),[V]CST_AERROR)
     Endif
    Endif
    LogicClose File[AGB]
   When 2                           # Local variables
    Local File AGLOBVAR [AGB]
    Read [AGB]AGB0=this.COD
    If !fstat
     this.INTIT = [F:AGB]INTIT
    Endif
    LogicClose File[AGB]
   When 3                          # Subprograms (functions)
    Local File ASUBPROG [ASU]
    I = instr(1,this.COD,"/")
    If I
     Read [ASU]ASU0=left$(this.COD,I-1);right$(this.COD,I+1)
    Else
     fstat = 5
    Endif
    If !fstat
     If [F:ASU]FONCTION<>[V]CST_AYES
       # This subprogram does not correspond to a function
       [L]ASTATUS = fmet this.ASETERROR("COD",mess(201,139,1),[V]CST_AERROR)
     Else
      this.INTIT = [F:ASU]INTIT
     Endif
    Else
     # Non-existent sub-program
     [L]ASTATUS = fmet this.ASETERROR("COD",mess(71,150,1),[V]CST_AERROR)
    Endif
    LogicClose File [ASU]
  Endcase
Return

