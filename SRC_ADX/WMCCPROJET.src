####################################################################
# OTHERS
####################################################################

$_AOTHERS
Gosub DECLARE_VAR From WMC0PROJET
Local Integer ALLSTAT
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_PRJ From WMC1PROJET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_PRJ From WMC1PROJET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_DESTRA From WMC1PROJET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_DESTRA From WMC1PROJET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_SHOTRA From WMC1PROJET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_SHOTRA From WMC1PROJET : Gosub TESTALLSTAT :  Endif
