If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_STUEND From WMC1PROJET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_STUEND From WMC1PROJET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_REASTR From WMC1PROJET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_REASTR From WMC1PROJET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_REAEND From WMC1PROJET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_REAEND From WMC1PROJET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_ACS From WMC1PROJET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_ACS From WMC1PROJET : Gosub TESTALLSTAT :  Endif
For AINDCLA=1 To 10
 If this.COLBPRFIN(AINDCLA)<>null& find(this.COLBPRFIN(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.COLBPRFIN(AINDCLA)._AOTHERS : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To 24
 If this.COLPER(AINDCLA)<>null& find(this.COLPER(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.COLPER(AINDCLA)._AOTHERS : Gosub TESTALLSTAT
 Endif
Next AINDCLA
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_TYP From WMC1PROJET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_TYP From WMC1PROJET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CREUSR From WMC1PROJET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CREUSR From WMC1PROJET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CREDAT From WMC1PROJET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CREDAT From WMC1PROJET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CRETIM From WMC1PROJET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CRETIM From WMC1PROJET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UPDUSR From WMC1PROJET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UPDUSR From WMC1PROJET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UPDDAT From WMC1PROJET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UPDDAT From WMC1PROJET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UPDTIM From WMC1PROJET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UPDTIM From WMC1PROJET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_EXPNUM From WMC1PROJET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_EXPNUM From WMC1PROJET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CREDATTIM From WMC1PROJET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CREDATTIM From WMC1PROJET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UPDDATTIM From WMC1PROJET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UPDDATTIM From WMC1PROJET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_AUUID From WMC1PROJET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_AUUID From WMC1PROJET : Gosub TESTALLSTAT :  Endif
For AINDCLA=1 To 10
 If this.LOT(AINDCLA)<>null& find(this.LOT(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.LOT(AINDCLA)._AOTHERS : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To 10
 If this.FAS(AINDCLA)<>null& find(this.FAS(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.FAS(AINDCLA)._AOTHERS : Gosub TESTALLSTAT
 Endif
Next AINDCLA
[L]ASTATUS = fmet this.ACONTROL
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



