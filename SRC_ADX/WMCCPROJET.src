If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_INTGCF From WMC1PROJET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_INTGCF From WMC1PROJET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_INVTYP From WMC1PROJET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_INVTYP From WMC1PROJET : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_AIM From WMC1PROJET : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_AIM From WMC1PROJET : Gosub TESTALLSTAT :  Endif
