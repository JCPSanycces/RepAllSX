#<AdxTL>@(#)7.0.0.0 $Revision$ Gestion du masque STKSPL
$ACTION
Case ACTION
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : REP="M"
# When "INIT"        : Gosub INIT
# When "SETBOUT"     : Gosub SETBOUT
# When "ENR"         : Gosub ENR
# When "ABA"         : Gosub ABA
 When "OK"          : Gosub OK
# When "END"         : Gosub ACTEND
# When "FIN"         : Gosub FIN
When "FINSAI"      : Gosub FINSAI
Endcase
Return


$OUVRE_BOITE
Local Integer W_OK
Return

$OUVRE

Return
###########################################################
$DEBUT
    Raz W_OK
    Local Integer  LLIN : LLIN = val(PARAM(1))-1
    Local Decimal  LQTE : LQTE = val(PARAM(2))
    Raz    [M:STSP]
    [M:STSP]WABRECR = "[M:"+PARAM(3)+"]"
    [M:STSP]WQUAFLG = evalue([M:STSP]WABRECR+"QUAFLG")

    [M:STSP]SPLLINNUM = LLIN+1
    [M:STSP]PCU       = evalue([M:STSP]WABRECR+"PCU(LLIN)")
    [M:STSP]PCUSTUCOE = evalue([M:STSP]WABRECR+"PCUSTUCOE(LLIN)")
    [M:STSP]STA       = evalue([M:STSP]WABRECR+"STA(LLIN)")
    [M:STSP]STOCOU    = evalue([M:STSP]WABRECR+"STOCOU(LLIN)")
    [M:STSP]QTYPCU    = LQTE

    Local Char    LUSCAV(5)
    Local Integer LMODIF
    Local Char    LLBEFMT(GLONARP)
    Local Decimal LCOE
    Call CTLUOM (evalue([M:STSP]WABRECR +"ITMREF"),3,evalue([M:STSP]WABRECR +"BPRNUM"), [M:STSP]PCU, LCOE, LUSCAV, LLBEFMT, LMODIF) From STKACT

    If LMODIF<>2 | evalue("varmode("+[M:STSP]WABRECR+"PCU,LLIN)")<>0
        Diszo [M:STSP]PCUSTUCOE
    Else
        Actzo [M:STSP]PCUSTUCOE
    Endif

    If [F:ITM]SERMGTCOD = 3 & clalev([ENM])
        [M:STSP]PCU        = [M:ENM]STU
        [M:STSP]QTYPCU     = 1
        [M:STSP]PCUSTUCOE  = 1
        Diszo [M:STSP]QTYPCU
        Diszo [M:STSP]PCU
        Diszo [M:STSP]PCUSTUCOE
    Endif

    Affzo [M:STSP]

    # X3-80367 - STWIL - Before we add a stock transaction line if it is a customer return, purchase receipt or
    # production tracking check if this document is in any non-conformances
    If func AFNC.ACTIV ("NCS") & clalev([ENM])
        Local Integer LDOCTYP
        Local Integer LOK
        Local Integer EXISTS
        Local Char NCSMESS(255)
        Case GFONCTION
            When "GESPTH" : LDOCTYP = 1
            When "GESSRH" : LDOCTYP = 2
            When "GESMTK" : LDOCTYP = 3
            When Default : LDOCTYP = 0
        Endcase
        If LDOCTYP > 0
            [L]EXISTS = func NCSDOCHDR_CSTD.NON_CONFORMANCE_EXISTS (LDOCTYP, [M:ENM]VCRNUM, [M:ENM]VCRLIN, [L]NCSMESS, 0)
            If [L]EXISTS > 0 & GNCSLINFLG = 0
                Call OUINON([L]NCSMESS,LOK) From GESECRAN
                GNCSLINFLG = 1
                If LOK = 1
                    # If the user does not want to continue, close the window
                    GMESSAGE = ""
                    FIN = 1
                    Return
                Endif
            Endif
        Endif
    Endif

Return
###########################################################
$SETBOUT
Return
###########################################################
$BOUTON
Return
###########################################################
$OK
Local Integer LRET : Raz LRET
Local Integer I, J
Local Decimal LQTYSTU
#insertion nouvelles lignes
Default Mask "["+PARAM(3)+"]"

LLIN = max([M]NBLIG>0,LLIN)            # On ajoute les lignes toujours en dessous de la première
[M]NBLIG += [M:STSP]LINNBR
Insa LLIN,[M:STSP]LINNBR,[M]NBLIG [M]NBLIG

#chargement lignes
For I = 0 To [M:STSP]LINNBR-1
    J = I + LLIN
    nolign = J+1

    If clalev([ENM])
        Call AVANT_NBLIG From TRTSTOENM
    Else
        Call AVANT_NBLIG From TRTSTOENT
    Endif
    [M]PCU(J)       = [M:STSP]PCU
    [M]QTYPCU(J)    = [M:STSP]QTYPCU
    [M]PCUSTUCOE(J) = [M:STSP]PCUSTUCOE
    If varmode([M:STSP]PCUSTUCOE)<>0
        Diszo [M]PCUSTUCOE(J)
    Else
        Actzo [M]PCUSTUCOE(J)
    Endif
    LQTYSTU = [M:STSP]QTYPCU * [M:STSP]PCUSTUCOE
    Call QTEARR(LQTYSTU,[M]STU) From TRTDIV
    [M]QTYSTU(J)    =  LQTYSTU

    [M]STA(J)       = [M:STSP]STA
    [M]STOCOU(J)    = [M:STSP]STOCOU
    # Contrôles
    If clalev([ENM])
        Call APRESNBLIGM (J, LRET) From TRTSTOENTB
    Else
        Call APRESNBLIG  (J, LRET) From TRTSTOENTB
    Endif

    If GMESSAGE="" & mkstat=0 & evalue("dim([M:"+PARAM(3)+"]WFLG)")>0
        [M]WFLG(J)    = 2
    Else
        Raz GMESSAGE
        Raz mkstat
        #----- On efface l'emplacement si celui-ci n'est pas correct -----#
        If mod(LRET,8192)>=4096
            Raz [M]LOC(J)
        Endif
        If dim([M]WFLG)>0
            [M]WFLG(J)    = 1
        Endif
    Endif
Next I
J=sigma(LLIN,LLIN+[M:STSP]LINNBR-1,indcum*([M]WFLG(indcum)=1 & sigma(LLIN+[M:STSP]LINNBR,LLIN+[M:STSP]LINNBR,1)))
If J>0
    Call MESSAGE(mess(48,184,1)+num$(J+1)) From GESECRAN
Endif
PARAM(1) = num$(I)
Affzo [M]
Default Mask "[STSP]"
FIN = 1
If dim(GMAJLIGDOC)>0 : GMAJLIGDOC=1 : Endif
W_OK=1
Return
###########################################################
$ACTEND
FIN = 1
Return
###########################################################
$FIN
Return
###########################################################
$FINSAI
If W_OK<>0
  mkstat=4
Endif
Return
###########################################################


###########################################################
Subprog AP_LINNBR(VALEUR)
Variable Decimal  VALEUR

    [M:STSP]QTYPCUTOT = ([M:STSP]QTYPCU * VALEUR)
    Affzo [M:STSP]QTYPCUTOT

End
###########################################################
Subprog C_LINNBR(VALEUR)
Variable Decimal  VALEUR

    If VALEUR < 1 | ( (VALEUR+evalue([M:STSP]WABRECR +"NBLIG")) > evalue("dim("+[M:STSP]WABRECR +"PCU)") )
      mkstat = 2
    Endif

End
###########################################################
Subprog AM_PCU(VALEUR)
Variable Char  VALEUR

    Local Char    LUSCAV(5)
    Local Integer LMODIF
    Local Char    LLBEFMT(GLONARP)

    Call CTLUOM (evalue([M:STSP]WABRECR +"ITMREF"),3,evalue([M:STSP]WABRECR +"BPRNUM"), VALEUR, [M:STSP]PCUSTUCOE, LUSCAV, LLBEFMT, LMODIF) From STKACT
    If LUSCAV<>"S" & LUSCAV<>"C"
        mkstat=2
        End
    Endif

    If LMODIF<>2 | evalue("varmode("+[M:STSP]WABRECR+"PCU,[M:STSP]SPLLINNUM)")<>0
        Diszo [M:STSP]PCUSTUCOE
    Else
        Actzo [M:STSP]PCUSTUCOE
    Endif
    Affzo [M:STSP]PCUSTUCOE

End

###########################################################
Subprog AM_QTYPCU(VALEUR)
Variable Decimal  VALEUR

    [M:STSP]QTYPCUTOT = ([M:STSP]LINNBR * VALEUR)
    Affzo [M:STSP]QTYPCUTOT

End

