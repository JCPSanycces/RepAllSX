#<AdxTL>@(#)0.0.0.0 $Revision$
################################################################################
# Sélection pour Suppression service 
# seul le masque numero 0 est différent, le masque de
# validation est le même que pour le remplacement (BOSRPL1)
# GA 24/11/2005 supression d'un service nomenclature de sous-traitance
# GA 22/03/2006 table BOMS remplacée par BOMD avec CPNTYP=7
################################################################################
$ACTION
Case ACTION
    When "INIT":     Gosub INIT
    When "CONTROLE": Gosub CONTROLE
    When "EXEC":     Gosub EXEC
    When "TERMINE":  Gosub TERMINE
    When "SORTIE":   Gosub SORTIE
    When "DEBUT":    If BOITE = "FBOSSUP" : Gosub DEBUTSUP : Else : Gosub DEBUT : Endif
    When "END":      PARAM(1) = "END"
Endcase
Return

################################################################################
$INIT
Local    Integer OK
Local    Char    TEX(15)(30), ERR_TRA(132)

If clalev([F:ACC]) = 0 : Local File ACCES     [ACC] : Endif
If clalev([F:TBO]) = 0 : Local File TABBOMALT [TBO] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER [ITM] : Endif
If clalev([F:BOH]) = 0 : Local File BOM       [BOH] : Endif
If clalev([F:BOD]) = 0 : Local File BOMD      [BOD] : Endif : # GA 03/2006 avant BOMS
If clalev ([F:TFO])= 0 : Local File TABFOR    [TFO] : Endif 

Local Mask BOSSUP0 [BOS0]

[M:BOS0]APPDAT = date$ 
Return

################################################################################
$CONTROLE
# paramètre en retour de la fenêtre initiale
If PARAM(1) = "END"
  FIN = 1
  Return
Endif

# ouverture préalable des masques pour le chargement
If clalev([M:BOSH]) = 0 : Local Mask BOSSUPH [BOSH] : Endif : # pour entête d'écran résultat
If clalev([M:BOS1]) = 0 : Local Mask BOSRPL1 [BOS1] : Endif : # pour alternatives de prod 
Raz [BOS1]

Default Mask [BOS0]
OK = 1
Call EXTRACT(OK)

# "Erreur d'accès sur fichier Entête de nomenclature ..."
If OK = 0
    GMESSAGE=mess(12,100,1)-"BOM:"-[F:BOD]ITMREF-num$([F:BOD]BOMALT)
    GERR = 1
    Return 
Endif

If [M:BOS1]NBLIG = 0 
    GMESSAGE = mess(113,199,1)
    GERR = 1
Endif

If GERR <> 1  TMP = 1  Endif

Return

################################################################################
$EXEC
# si on a cliqué 'Fin' dans la fenêtre principale, on ne fait rien  :
If PARAM(1) = "END"
  SAI = 1
  Raz PARAM(1)
Else
  Gosub VALID
Endif
Return

################################################################################
$TERMINE
Close Local Mask [BOSH], [BOS1]
Raz [M:BOS0]
[M:BOS0]APPDAT = date$  
TRA = 1 
SAI = 1
Return

################################################################################
$SORTIE
Raz GFONBOD
Return

#######################################################################
$DEBUT
[M:BOS0]APPDAT = date$ 
Affzo [M:BOS0]
Return

################################################################################
$DEBUTSUP
# Affichage des ecrans de validation  "Résultat remplacement"  
[M:BOSH] = [M:BOS0] 
Affzo [BOSH] 
Affzo [BOS1] 

Diszo [BOSH]SUPCPN  
If [M:BOS1]NBLIG = 0 : Grizo [M:BOS1] : Endif  
Return

###################################################################################
$FILTRE

Raz XCRITERE
Raz XCRITERE1
Raz XCRITERE2

XCRITERE1 = "1=1"

If [M]ITMREFDEB <> "" 
    XCRITERE = "[F:BOH]ITMREF >= [M]ITMREFDEB"
    Gosub LOAD_CRITERE
Endif

If [M]ITMREFFIN <> "" 
    XCRITERE = "[F:BOH]ITMREF <= [M]ITMREFFIN"
    Gosub LOAD_CRITERE
Endif

If ([M]ALTDEB <> 0 | [M]ALTFIN <> 0)
    XCRITERE = "[F:BOH]BOMALT >= [M]ALTDEB & [F:BOH]BOMALT <= [M]ALTFIN"
    Gosub LOAD_CRITERE
Endif
Return


############################################################
$LOAD_CRITERE
If len(XCRITERE)+len(XCRITERE1)+1 < 250
  If XCRITERE1 <> ""
      XCRITERE1 += "&"
  Endif
  XCRITERE1 += XCRITERE  
Else
  If XCRITERE2 <> ""
     XCRITERE2 += "&"
  Endif
  XCRITERE2 += XCRITERE
Endif
Return

################################################################################
# filtre les liens selon les sélections
Subprog EXTRACT(OK) 
Variable Integer OK
Local Integer    ILIG, NBTEX
Local    Char    XCRITERE(255)
Local    Char    XCRITERE1(255)
Local    Char    XCRITERE2(255)
Local    Char    FORMULE1(255)


Gosub FILTRE
If XCRITERE2 = "" : XCRITERE2 = "1=1" : Endif

# analyse présence formule de sélection
If [M]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif      
Else
    Read [F:TFO]TFO0=31;[M]FORMULE
    If fstat 
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif  
    Else  
        If FORMULE1 = "" 
            FORMULE1  = [F:TFO]FORFOR                 
        Else
            FORMULE1 += "&" 
            FORMULE1 += [F:TFO]FORFOR                 
        Endif
    Endif
Endif

ILIG=0 : JLIG=0 : KLIG=0

Link [BOD] With [BOH]BOH0=[F:BOD]ITMREF;[F:BOD]BOMALT;[F:BOD]BOMALTTYP, [ITM]ITM0=[F:BOD]ITMREF, 
&               [TBO]TBO0=[F:BOD]BOMALTTYP;[F:BOD]BOMALT As [BODX]
&          Where CPNITMREF = [M:BOS0]SUPCPN &
&                BOMSTRDAT < [M:BOS0]APPDAT &
&               (BOMENDDAT > [M:BOS0]APPDAT-1 | BOMENDDAT=[0/0/0]) &
&               evalue(XCRITERE1) & evalue(XCRITERE2) & evalue(FORMULE1)

For [BODX]
   Gosub CHARG_ECR
   If OK = 0 : Break : Endif
Next

[M:BOS1]NBLIG = ILIG
End

################################################################################
$CHARG_ECR
Raz mkstat 

# vérifier droit de modif sur alternative
Call CTLMODALT([F:BOD]BOMALT,[F:BOD]BOMALTTYP) From TRTBOM   
Raz GMESSAGE 
If mkstat : Return : Endif

ILIG += 1
nolign = ILIG
If ILIG > dim([M:BOS1]VALID)  
    ILIG -= 1  
    GMESSAGE = mess(512,199,1)
    GERR = 2
Else   
    [M:BOS1] = [F:BOD]
    [M:BOS1]VALID(nolign-1)  = 2
#    [M:BOS1]ITMDES1(nolign-1)= [F:ITM]ITMDES1
Endif  

Return

################################################################################
$VALID

Call OUVRE_TRACE(mess(117,199,1)) From LECFIC
Call PRTSCR("BOSSUP0","BOS0","",0,1) From ATRTX3
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
Call ECR_TRACE(" ",0) From GESECRAN 
ERR_TRA = mess(35,197,1) - [M:BOS0]SUPCPN
ERR_TRA -= mess(38,197,1) - format$("D:DD[/]MM[/]YY",[M:BOS0]APPDAT)
Call ECR_TRACE(ERR_TRA,0) From GESECRAN

# Màj du lien existant en changeant la fin de validité
# pas de mise à jour de code de plus bas niveau car le lien n'est pas oté physiquement

Call DEBTRANS From GLOCK
Trbegin [BOD]

# Alternatives de sous-traitance
For nolign = 1 To [M:BOS1]NBLIG
    If [M:BOS1]VALID(nolign-1) = 2
        Default Mask [BOS1]
        Gosub MODI
    Endif
Next

Commit
Call FERME_TRACE From LECFIC
Return

################################################################################
$MODI
ERR_TRA = ""
Readlock [BOD]BOD0=[M]ITMREF(nolign-1);[M]BOMALT(nolign-1);[M]BOMSEQ(nolign-1);[M:BOS0]SUPCPN;3
If fstat = 1  # enreg déjà locké 
   ERR_TRA = "BOMS:"-[F:BOD]ITMREF-num$([F:BOD]BOMALT)-[F:BOD]CPNITMREF-mess(60,100,1)
Elsif [F:BOD]BOMENDDAT > [M:BOS0]APPDAT - 1 | [F:BOD]BOMENDDAT = [0/0/0]
   [F:BOD]BOMENDDAT = [M:BOS0]APPDAT - 1
   [F:BOD]UPDDAT    = date$
   [F:BOD]UPDUSR    = GUSER
   [F:BOD]EXPNUM    = [C]EXPORT
   # point d'entrée  pour mise à jour supplémentaires sur l'ancien lien, ou avertir si un OF l'utilise
   GPOINT = "BOSMAJ" : Gosub ENTREE From EXEFNC
   
   Rewrite [BOD]
   If fstat
     ERR_TRA = "BOD:"-[M]ITMREF(nolign-1)-num$([M]BOMALT(nolign-1))-num$([M]BOMSEQ(nolign-1))
     ERR_TRA -= mess(13,100,1)
   Endif
Endif

#  ecrire la trace d'eventuelle erreur
If ERR_TRA <> ""
   Call ECR_TRACE(ERR_TRA,1) From GESECRAN
Else
   # écriture trace de la modification
   ERR_TRA  = mess(153,198,1)+":" - [F:BOD]ITMREF+"/"+num$([F:BOD]BOMALT)+"/"+num$([F:BOD]BOMSEQ) - mess([F:BOD]BOMALTTYP,224,1)
   Call ECR_TRACE(ERR_TRA,0) From GESECRAN
   Raz ERR_TRA
Endif
Return

################################################################################
# ETIQUETTES SUR ZONES
################################################################################
Subprog C_APPDAT(VALEUR)
Variable Date     VALEUR
If VALEUR < date$
   mkstat = 2 : GMESSAGE = mess(114,199,1)
Endif
End

################################################################################ 
## Etiquette ajoutée par le superviseur (écran BOSSUP0) 07/04/2006 15:47:51 (LLCX)
################################################################################
Subprog AM_ITMREFDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]ITMREFFIN = VALEUR : Endif
End

################################################################################
Subprog AM_ALTDEB(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0 : [M]ALTFIN = VALEUR : Endif
End

################################################################################
Subprog C_ALTFIN(VALEUR)
Variable Decimal VALEUR
If VALEUR < [M]ALTDEB : mkstat = 2 : Endif
End


######################################################################################

