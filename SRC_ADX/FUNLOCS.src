#<AdxTL>@(#)3.0.0.0 $Revision$
############################################################
# Resynchronisation emplacements
# action SAILOCS
############################################################
$ACTION
Case ACTION
  When "OUVRE_BATCH"  : Gosub OUVRE_BATCH_SYNLOC
  When "INIT"         : Gosub INIT_SYNLOC
  When "EXEC"         : Gosub EXEC_SYNLOC
  When "TERMINE"      : Gosub TERMINE_SYNLOC
  When "INIT_DIA"     : Gosub INIT_DIA_SYNLOC
  When "OK"           : Gosub OK_SYNLOC
  When "END"          : Gosub END_SYNLOC
Endcase 
Return
############################################################
$OUVRE_BATCH_SYNLOC
Gosub OPEN_FILE
Return
############################################################
$INIT_SYNLOC
Gosub OPEN_FILE
Return
#############################################################
$EXEC_SYNLOC
Local Char    WFIL(250) : WFIL = "1=1"
Local Integer LRET
#
If GSERVEUR
  Onerrgo ERRBATCH
  Call ECR_TRACE(mess(133,196,1)-[M:DIA]STOFCY,0) From GESECRAN
Else
  Call OUVRE_TRACE(mess(133,196,1)-[M:DIA]STOFCY) From LECFIC 
  Call ECR_TRACE(mess(133,196,1)-[M:DIA]STOFCY,0) From GESECRAN
Endif
If [M:DIA]STOFCY <> ""
    WFIL = "STOFCY=[M:DIA]STOFCY"
Endif
If [M:DIA]FILTLO <> "" & [M:DIA]FILTLO<>"*"
    WFIL += " & pat(LOCTYP,[M:DIA]FILTLO)=1"
Endif
Call TEMPON ("O") From GESECRAN
Call TRAITEMENT(WFIL,[M:DIA]FILMGTFLG,[M:DIA]MONITMFLG,[M:DIA]DEDFLG,[M:DIA]STAFLG,[M:DIA]STATFLG,LRET)
Call TEMPOFF      From GESECRAN

Onerrgo
Return
#############################################################
$TERMINE_SYNLOC
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
  Return
Endif
Return
#############################################################
$INIT_DIA_SYNLOC
Raz [M:DIA]
[M:DIA]STOFCY = GFCYDEF(0)
Return
#############################################################
$OK_SYNLOC
FIN  = 1
Return
#############################################################
$END_SYNLOC
Raz [M:DIA]
FIN = 1
Return
############################################################
$OPEN_FILE
If clalev([F:TST])  = 0 : Local File TABSTASTO [TST]  : Endif
If clalev([F:STO])  = 0 : Local File STOCK     [STO]  : Endif
If clalev([F:STO1]) = 0 : Local File STOCK     [STO1] : Endif
If clalev([F:TLO])  = 0 : Local File TABLOCTYP [TLO]  : Endif
If clalev([F:STC])  = 0 : Local File STOLOC    [STC]  : Endif
If clalev([F:STF])  = 0 : Local File STOLOCAFF [STF]  : Endif
Return
############################################################
#Recalcul des statuts occupes / libres
###########################################################
Subprog TRAITEMENT(LFIL,PCTLFIL,PCTLMON,PCTLDED,PCTLSTA,PMAJSTAT,PRET)
Value Char    LFIL
Value Integer PCTLFIL
Value Integer PCTLMON
Value Integer PCTLDED
Value Integer PCTLSTA
Value Integer PMAJSTAT
Variable Integer PRET
#
Gosub OPEN_FILE
#
Local Char WFCY(GLONFCY)
Local Char WLOC(GLONLOC)
Local Char WTLO(GLONTLO)
Local Integer WNBTLO
Local Integer WNBLOC
Local Char TABITMAFF(GLONITM)(100) # 100 vient de la dimension du tableau de saisie des affectations
Local Integer WCOMPTEUR
Local Char LTLOMSG(50), LTOTMSG(50)
Local Char    WPCU
Local Decimal WCOE
Local Decimal WQTYPCU
Local Integer I
Raz WFCY, WLOC, WTLO, WCOMPTEUR
Raz [F:TLO]
Raz PRET
#--- Bug 55451
If !GSERVEUR Inter 1 Endif
$BOUCLE
Trbegin [STC]
Columns [STC] (PCU,PCUSTUCOE,QTYPCU,STOFCY,LOC,FILMGTFLG,OCPCOD,LOCTYP,LOKSTA,MONITMFLG,DEDFLG,AUZSST)
For [STC]STC3 Where (  STOFCY = WFCY & LOCTYP=WTLO & LOC>WLOC
&                    | STOFCY = WFCY & LOCTYP>WTLO
&                    | STOFCY > WFCY)
&                 & evalue(LFIL)
    Readlock [STC] Curr
    WCOMPTEUR += 1
    WFCY=[F:STC]STOFCY
    WLOC=[F:STC]LOC
    WTLO=[F:STC]LOCTYP
    If [F:TLO]LOCTYP<>[F:STC]LOCTYP | [F:TLO]STOFCY<>[F:STC]STOFCY
        Readlock [TLO]TLO0=[F:STC]STOFCY;[F:STC]LOCTYP
        If !fstat
            Raz [F:TLO]OCPLOC,[F:TLO]FRGLOC,[F:TLO]FULLOC,[F:TLO]LOKLOC,[F:TLO]PERLOA
            WNBTLO+=1
        Endif
    Endif
    If !fstat
        WNBLOC +=1
        Look [STO]STO4=[F:STC]STOFCY;[F:STC]LOC
        If !fstat
            If PCTLFIL=2
                If !([F:STC]FILMGTFLG=2 & [F:TLO]PCUNBR>0)    #--- Si l'emplacement n'est pas géré en remplissage ou qu'il n'a pas de quantité maxi ----#
                    [F:STC]OCPCOD = 2
                    Call ECR_TRACE([F:STC]STOFCY+" - "+[F:STC]LOC-"-->"-mess([F:STC]OCPCOD,757,1),0) From GESECRAN
                Else 
                    [F:STC]OCPCOD    = 1
                    Read [STO]STO4=[STC]STOFCY;[STC]LOC
                    If find([F:STO]PCU,[F:TLO]PCU)    #------ Est-ce que l'unité est permise dans l'emplacement ----#
                        WPCU=[F:STO]PCU
                        WCOE=[F:STO]PCUSTUCOE
                        If [F:STO]QTYSTU <> 0         # hcb 30947
                           [F:STC]OCPCOD = 2
                        Endif                         # hcb 30947
                        Filter [STO] Where STOFCY    = [F:STC]STOFCY
&                                  & LOC       = [F:STC]LOC   
&                                  & (PCU<>WPCU | PCUSTUCOE<>WCOE)
                        Look [STO]STO4 First    #----- S'il y a des UC ou des coef différents => plein -----#
                        Filter [STO]
                        If !fstat
                            [F:STC]OCPCOD=3
                            Call ECR_TRACE([F:STC]STOFCY+" - "+[F:STC]LOC-"-->"-mess([F:STC]OCPCOD,757,1),1) From GESECRAN
                            PRET = 1
                        Else
                            Columns [STO] (QTYPCU)
                            Raz WQTYPCU
                            For [STO]STO4 Where STOFCY    = [F:STC]STOFCY
&                                             & LOC       = [F:STC]LOC
                                WQTYPCU += [F:STO]QTYPCU
                            Next
                            Columns [STO]
                            [F:STC]QTYPCU    = WQTYPCU
                            [F:STC]PCU       = WPCU
                            [F:STC]PCUSTUCOE = WCOE
                            If WQTYPCU>[F:TLO]MAXQTYPCU(find(WPCU,[F:TLO]PCU)-1)    #---- Si qté maxi dépassée -----#
                                [F:STC]OCPCOD = 3
                                #-- erreur, trop rempli ---#
                                Call ECR_TRACE([F:STC]STOFCY+" - "+[F:STC]LOC-num$(WQTYPCU)+">"+num$([F:TLO]MAXQTYPCU(find(WPCU,[F:TLO]PCU)-1))-"-->"-mess([F:STC]OCPCOD,757,1),1) From GESECRAN
                                PRET = 1
                            Elsif WQTYPCU=[F:TLO]MAXQTYPCU(find(WPCU,[F:TLO]PCU)-1)    #---- Si qté maxi atteinte -----#
                                [F:STC]OCPCOD = 3
                                Call ECR_TRACE([F:STC]STOFCY+" - "+[F:STC]LOC-num$(WQTYPCU)+"="+num$([F:TLO]MAXQTYPCU(find(WPCU,[F:TLO]PCU)-1))-"-->"-mess([F:STC]OCPCOD,757,1),0) From GESECRAN
                            Else
                                Call ECR_TRACE([F:STC]STOFCY+" - "+[F:STC]LOC-"-->"-mess([F:STC]OCPCOD,757,1)-"("+num$(WQTYPCU)-WPCU+")",0) From GESECRAN
                            Endif
                        Endif
                    Else    #----- L'unité n'est pas autorisée sur l'emplacement => plein -------#
                        [F:STC]OCPCOD = 3
                        Call ECR_TRACE([F:STC]STOFCY+" - "+[F:STC]LOC-mess(254,199,1)-"-->"-mess([F:STC]OCPCOD,757,1),1) From GESECRAN
                        PRET = 1
                    Endif
                    Columns [STO]
                Endif
            Endif
            #----- Contrôle mono-article      ----#
            If PCTLMON=2 & [F:STC]MONITMFLG = 2
                Gosub CTL_MON
            Endif
            #----- Contrôle emplacement dédié ----#
            If PCTLDED=2 & [F:STC]DEDFLG = 2
                Gosub CTL_DED
            Endif
            #----- Contrôle statuts           ----#
            If PCTLSTA = 2
                Gosub CTL_STA
            Endif
        Else
#            If [F:STC]OCPCOD = 1                                                                              # CCC + Hcb 105464
            If [F:STC]OCPCOD = 1 & [F:STC]QTYPCU=0 & [F:STC]PCU="" & [F:STC]MAXQTYPCU=0 & [F:STC]PCUSTUCOE = 0 # CCC + Hcb 105464

        
      Call ECR_TRACE([F:STC]STOFCY+" - "+[F:STC]LOC-"-->"-mess([F:STC]OCPCOD,757,1),0) From GESECRAN
            Else
               Call ECR_TRACE([F:STC]STOFCY+" - "+[F:STC]LOC-":"-mess([F:STC]OCPCOD,757,1)-"-->"-mess(1,757,1),1) From GESECRAN

               [F:STC]OCPCOD    = 1
#                                         #  # CCC + Hcb 105464  deb
               [F:STC]QTYPCU    = 0
               [F:STC]PCU       = ""
               [F:STC]PCUSTUCOE = 0
               [F:STC]MAXQTYPCU = 0
#                                         #  # CCC + Hcb 105464  deb
            Endif
        Endif
        #------------- màj des statistiques -----------#
        If PMAJSTAT=2
            Gosub MAJ_STAT
        Endif
        
        GPOINT="SYNREWSTC" 
        Gosub ENTREE From EXEFNC

        Rewrite [STC]
        If WCOMPTEUR>500
            Break
        Endif
    Else
        If PCTLFIL=2
            [F:STC]OCPCOD    = 1
            Call ECR_TRACE([F:STC]STOFCY+" - "+[F:STC]LOCTYP-"-->"-mess(245,192,1),1) From GESECRAN
            PRET = 1
        Endif
    Endif
Next

If WCOMPTEUR>500
    Commit
    Columns [STC]
    Raz WCOMPTEUR
    Goto $BOUCLE
Endif
Commit

Call TEXTE (5860,LTLOMSG) From OBJDIV 
Call TEXTE (3569,LTOTMSG) From OBJDIV
Call ECR_TRACE(LTOTMSG-":"-num$(WNBTLO)-LTLOMSG-"&"-num$(WNBLOC)-mess(9,198,1),0) From GESECRAN

Columns [STO]
Columns [STC]
Filter [STO]
End
###########################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
PRET = 1
End

#################################################
$CTL_MON
    Columns [STO] (ITMREF)
    Filter [STO] Where STOFCY    = [F:STC]STOFCY
&                    & LOC       = [F:STC]LOC
    For [STO]STO4
        Break
    Next
    Columns [STO]
    Filter [STO1] Where STOFCY    = [F:STC]STOFCY
&                     & LOC       = [F:STC]LOC
&                     & ITMREF    <> [F:STO]ITMREF
    Look [STO1]STO4 First
    If !fstat
        Call ECR_TRACE([F:STC]STOFCY+" - "+[F:STC]LOC-" : "-mess(53,196,1),1) From GESECRAN
        PRET = 1
    Endif
    Filter [STO1]
    Filter [STO]
Return

#################################################
$CTL_DED
    Raz TABITMAFF
    Raz I
    For [STF] Where STOFCY=[STC]STOFCY
&                 & LOC=[STC]LOC
        If I>=100
            Break    # ne devrait pas arriver
        Endif
        TABITMAFF(I) = [F:STF]ITMREF
        I += 1
    Next
    Filter [STO] Where STOFCY=[STC]STOFCY
&                    & LOC=[STC]LOC
&                    & !find(ITMREF,TABITMAFF)
    Look [STO]STO4 First
    If !fstat
        Call ECR_TRACE([F:STC]STOFCY+" - "+[F:STC]LOC-" : "-mess(86,184,1),1) From GESECRAN
        PRET = 1
    Endif
    Filter [STO]
Return

#################################################
$CTL_STA
Local Char LLIS(250)
Local Integer I,J, LIND
Local Char LCRIT(255)(3)
Raz I, J, LIND
Raz LCRIT
LLIS = [F:STC]AUZSST
    I = 1
    J = instr(I,LLIS,",")
    While J <> 0
        W_STA = seg$(LLIS,I,J-1)
        Call ADDCRIT(LCRIT,LIND,"",'pat(STA,"'+W_STA+'")<>1',"&") From GOBJSUB
        I = J +1
        J = instr(I,LLIS,",")
    Wend
    W_STA = seg$(LLIS,I,len(LLIS))
    Call ADDCRIT(LCRIT,LIND,"",'pat(STA,"'+W_STA+'")<>1',"&") From GOBJSUB

    Filter [STO] Where STOFCY=[STC]STOFCY & LOC=[STC]LOC & evalue(LCRIT)
    Look [STO]STO4 First
    If !fstat
        Call ECR_TRACE([F:STC]STOFCY+" - "+[F:STC]LOC-" : '"+[F:STO]STA+"'"-mess(832,196,1),1) From GESECRAN
        PRET = 1
    Endif
    Filter [STO]
Return

#################################################
$MAJ_STAT
    Case [F:STC]OCPCOD
        When 1: [F:TLO]FRGLOC += 1
        When 2: [F:TLO]OCPLOC += 1
        When 3: [F:TLO]FULLOC += 1
    Endcase
    [F:TLO]PERLOA = ([F:TLO]OCPLOC+[F:TLO]FULLOC)/([F:TLO]FRGLOC+[F:TLO]OCPLOC+[F:TLO]FULLOC)
    [F:TLO]LOKLOC += ([F:STC]LOKSTA=2)
    [F:TLO]ANYDAT = date$
    [F:TLO]ANYTIM = mid$(time$,1,2)+mid$(time$,4,2)
    Rewrite [TLO]
Return

