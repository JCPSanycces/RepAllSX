#<AdxTL>@(#)0.0.0.0 $Revision$
#<gen>
# MAJPMP : ?
# NEWLASPRI : ?
# MAJFIFO : ?
# MAJVALLOT : met à jour la valeur du lot
# MAJITH : Met à jour les champs YEARCPAMT,MONRCPAMT, YEAISSAMT et MONRCPAMT
#</gen>

######################################
Subprog MAJPMP(PIO, PAMTDEV)
Value    Integer PIO
Variable Decimal PAMTDEV(,)

Local Decimal LOLDQTY
Local Integer WPMP
Local Integer LSIGN
Local Char    LMAJTYP(1)
Local Integer LRET
Local Char    WTCM(GLONTCM)
Local Integer LNUMVLT
Local Char    WTCM(GLONTCM)
Local Decimal WQTYTRA, WAMTTRA

Local Decimal LTABVAL(dim(PAMTDEV,2))

Local Integer I


If [M:STW]TRFFCY<>"" & [M:STW]TRFFCY<>[M:STW]STOFCY
    LSENS = func STKLIB.SENSTRS([M:STW]TRSTYP)
    If PIO=1
        LMAJTYP="E"
        LSIGN=-1
    Else
        LMAJTYP="S"
        LSIGN=1
    Endif
    If find(LSENS,2,-1) | ([M:STW]TRSTYP=12 & [M:STW]VCRNUMORI2="")
        Read [ITV]ITV0=[M:STW]ITMREF;[M:STW]STOFCY
        If [F:ITV]TRASTO=0
            Raz [F:ITV]TRAAMT
        Else
            [F:ITV]TRAAMT += sigma(0,[M:STW]NBLIG-1,[M:SVW]AMTORD(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN
        Endif
        Rewrite [ITV]
    Elsif LSENS=1 | LSENS=-2
        Read [ITV]ITV0=[M:STW]ITMREF;[M:STW]TRFFCY
        If [F:ITV]TRASTO=0
            Raz [F:ITV]TRAAMT
        Else
            If [M:STW]VCRTYPORI <> 0 | [M:STW]VCRTYPORI2 <> 0
                If [M:STW]VCRTYPORI2 <> 0
                    Call VALVCR2([M:STW]TRFFCY,[M:STW]VCRTYPORI2,[M:STW]VCRNUMORI2,[M:STW]VCRLINORI2,WAMTTRA,WQTYTRA,LRET) From STKVAL
                Else
                    Call VALVCR2([M:STW]TRFFCY,[M:STW]VCRTYPORI,[M:STW]VCRNUMORI,[M:STW]VCRLINORI,WAMTTRA,WQTYTRA,LRET) From STKVAL
                Endif
                # Cela peut se produire avec les livraisons /s-trait ou livraisons de prêt qui font une sortie & une entrée
                If WQTYTRA<>0
                  [F:ITV]TRAAMT+=WAMTTRA
&                               *sigma(0,[M:STW]NBLIG-1,[M:STW]QTYSTUACT(indcum)
&                                                   *(-2*([M:STW]MAJCOD(indcum)="A")+1)
&                                                   *([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(indcum)))
&                               /WQTYTRA
&                               *LSIGN
                Endif
            Else
                [F:ITV]TRAAMT += sigma(0,[M:STW]NBLIG-1,[M:SVW]AMTORD(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)="E"))*LSIGN
            Endif
        Endif
        Rewrite [ITV]
    Endif
Endif

Raz WPMP
# Ce P.E. doit charger WPMP <> 0 pour court-circuiter le calcul std
GPOINT="MAJPMP"
Gosub ENTREE From EXEFNC
If WPMP=0

    If (mod([M:SVW]FILUPD,4)<2)
        End
    Endif

    # Issue 86700 - 2012-12-17 by CCC : Les mouvements internes n'ont pas à modifier les tables de cumul
    If !(find([M:STW]TRSTYP,13,14) | find(func STKLIB.SENSTRS([M:STW]TRSTYP),-2,-1,1,2))
&    | find([M:STW]TRSTYP,16,32)   # Issue 89623 - 2013-06-26 by CCC : Les réceptions pour sous-traitance n'ont pas d'impact
                                   # Issue 93525 - 2013-06-26 by CCC : Les retours de réceptions pour sous-traitance n'ont pas d'impact
        End
    Endif

    #----- Pas de mise à jour si que des mouvements non valorisés ----#
    If sigma(0,[M:STW]NBLIG-1,func STKVALMAJ.VALAUZ(indcum))=0
        End
    Endif

    If [M:STW]TRSTYP=14 & PIO=1
        Readlock [ITV]ITV0=[M:STW]ITMREF;[M:STW]TRFFCY
    Else
        Readlock [ITV]ITV0=[M:STW]ITMREF;[M:STW]STOFCY
    Endif

    LOLDQTY = [F:ITV]AVCBASQTY

#1- Calcul de la quantité de base --------------------#
    Gosub UPDQTY

    If (LOLDQTY=[F:ITV]AVCBASQTY & LOLDQTY=0)
        Unlock [ITV]
        End
    Endif

#2- Calcul du montant de base -------------------------#
    If [M:STW]VCRTYP<>35
        Gosub UPDAMT
    Endif

#3- Calcul du PMP -------------------------#
    Gosub UPDAVC

Endif


Call REWITV From STKLIB
If fstat
    Call RSTA("ITV",[F:ITV]ITMREF+";"+[F:ITV]STOFCY) From GLOCK
    GOK=0
    End
Endif

End

######################################
$UPDQTY
    If PIO=2
        LSIGN = -1
        If [M:STW]TRSTYP=14
            LMAJTYP = "C"
        Else
            LMAJTYP = "S"
        Endif
        [F:ITV]AVCBASQTY  += -sigma(0,[M:STW]NBLIG-1,[M:STW]QTYSTUACT(indcum)
&                                                   *(-2*([M:STW]MAJCOD(indcum)="A")+1)
&                                                   *([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(indcum)))
    Else
        LSIGN = 1
        If [M:STW]TRSTYP=14
            LMAJTYP = "C"
        Else
            LMAJTYP = "E"
        Endif
        [F:ITV]AVCBASQTY  += sigma(0,[M:STW]NBLIG-1,[M:STW]QTYSTUACT(indcum)
&                                                  *(-2*([M:STW]MAJCOD(indcum)="A")+1)
&                                                  *([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(indcum)))
    Endif
Return

######################################
$UPDAMT
    # Issue 112077 - 2017-01-25 by ERMIL : Use correct value for GRNDVAL to reduce rounding errors
    Local Decimal RNDVAL_SAV
    RNDVAL_SAV = GRNDVAL
    Call INIRNDVAL("ITMMVT","AVCBASAMT") From STKVALECR

    # Si création sortie non valorisée au PMP : la valeur du PMP ne doit pas changer
    If [M:STW]MAJCODH="C" & PIO=2 & LOLDQTY>[F:ITV]AVCBASQTY & [M:SVW]PRINAT(0)<>5 & [M:SVW]PRINAT2(0)<>5
&    & !([M:STW]VCRTYP=32 & [M:STW]VCRLINORI<>0)    # 112836.n - and not a disassembly with an origin (assembly)
        If LOLDQTY<=0
            If GTRACE<>""
                Call ECR_TRACE(mess(264,197,1)-":"-[F:ITV]ITMREF-";"-[F:ITV]STOFCY,1) From GESECRAN
            Else
                Call ERREUR(mess(264,197,1)-":"-[F:ITV]ITMREF-";"-[F:ITV]STOFCY) From GESECRAN
            Endif
            GOK = 0
            End
        Endif
        [F:ITV]AVCBASAMT  = arr([F:ITV]AVCBASAMT*[F:ITV]AVCBASQTY/LOLDQTY, GRNDVAL)
        If GACTDECCST
# Issue 92701 - 2013-10-21 by CCC
#            For I=0 To GACTMAT-1
#                [F:ITV]AMATCST(I) = arr([F:ITV]AMATCST(I)*[F:ITV]AVCBASQTY/LOLDQTY, GRNDVAL)
#            Next
#
#            [F:ITV]AOVEMATCST = arr([F:ITV]AOVEMATCST*[F:ITV]AVCBASQTY/LOLDQTY, GRNDVAL)
#
#            For I=0 To GACTMAC-1
#                [F:ITV]AMACCST(I) = arr([F:ITV]AMACCST(I)*[F:ITV]AVCBASQTY/LOLDQTY, GRNDVAL)
#            Next
#
#            [F:ITV]AOVEMACCST = arr([F:ITV]AOVEMACCST*[F:ITV]AVCBASQTY/LOLDQTY, GRNDVAL)
#
#            For I=0 To GACTLAB-1
#                [F:ITV]ALABCST(I) = arr([F:ITV]ALABCST(I)*[F:ITV]AVCBASQTY/LOLDQTY, GRNDVAL)
#            Next
#
#            [F:ITV]AOVELABCST = arr([F:ITV]AOVELABCST*[F:ITV]AVCBASQTY/LOLDQTY, GRNDVAL)
#
#            [F:ITV]ASCOCST    = arr([F:ITV]ASCOCST*[F:ITV]AVCBASQTY/LOLDQTY, GRNDVAL)
#            [F:ITV]AOVESCOCST = arr([F:ITV]AOVESCOCST*[F:ITV]AVCBASQTY/LOLDQTY, GRNDVAL)
#
#            [F:ITV]AINVDTACST = arr([F:ITV]AINVDTACST*[F:ITV]AVCBASQTY/LOLDQTY, GRNDVAL)
            Call LOADVAR(LTABVAL, "[F:ITV]", 0, "A", [F:ITV]AVCBASQTY/LOLDQTY, 0, 0) From STKVALECR
            Call REPVAL([F:ITV]AVCBASAMT,LTABVAL, GRNDVAL, LTABVAL) From STKVALECR
            Call LOADFIC("[F:ITV]", LTABVAL, "A", "CST", 1, 0) From STKVALECR
        Endif

    Else
        # Si sortie et 2ème méthode au PMP, on utilise les valeurs V2xxx
        If PIO=2 & GACTVLT2 & [M:SVW]PRINAT2(0)=5
            If GACTDECCST
                For I=0 To GACTMAT-1
                    [F:ITV]AMATCST(I) += sigma(0,[M:STW]NBLIG-1,[M:SVW]V2MATCST(indcum*GACTMAT+I)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN
                Next

                [F:ITV]AOVEMATCST += sigma(0,[M:STW]NBLIG-1,[M:SVW]V2OVEMAT(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN

                For I=0 To GACTMAC-1
                    [F:ITV]AMACCST(I) += sigma(0,[M:STW]NBLIG-1,[M:SVW]V2MACCST(indcum*GACTMAC+I)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN
                Next

                [F:ITV]AOVEMACCST += sigma(0,[M:STW]NBLIG-1,[M:SVW]V2OVEMAC(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN

                For I=0 To GACTLAB-1
                    [F:ITV]ALABCST(I) += sigma(0,[M:STW]NBLIG-1,[M:SVW]V2LABCST(indcum*GACTLAB+I)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN
                Next

                [F:ITV]AOVELABCST += sigma(0,[M:STW]NBLIG-1,[M:SVW]V2OVELAB(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN

                [F:ITV]ASCOCST    += sigma(0,[M:STW]NBLIG-1,[M:SVW]V2SCOTOT(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN
                [F:ITV]AOVESCOCST += sigma(0,[M:STW]NBLIG-1,[M:SVW]V2OVESCO(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN

                [F:ITV]AINVDTACST += sigma(0,[M:STW]NBLIG-1,[M:SVW]V2INVDTA(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN
            Endif
            [F:ITV]AVCBASAMT  += sigma(0,[M:STW]NBLIG-1,[M:SVW]AMTVAL2(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN

        # Sinon on prend les valeurs d'ordre (si sortie au PMP, la valeur d'ordre contient la valeur au PMP)
        Elsif [M:STW]TRSTYP=14 & PIO=1    # Si entrée transfert inter-sites, on prend les valeurs dans SVWD
            If GACTDECCST
                For I=0 To GACTMAT-1
                    [F:ITV]AMATCST(I) += sigma(0,[M:STW]NBLIG-1,[M:SVWD]OMATCST(indcum*GACTMAT+I)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN
                Next

                [F:ITV]AOVEMATCST += sigma(0,[M:STW]NBLIG-1,[M:SVWD]OOVEMATTOT(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN

                For I=0 To GACTMAC-1
                    [F:ITV]AMACCST(I) += sigma(0,[M:STW]NBLIG-1,[M:SVWD]OMACCST(indcum*GACTMAC+I)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN
                Next

                [F:ITV]AOVEMACCST += sigma(0,[M:STW]NBLIG-1,[M:SVWD]OOVEMACTOT(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN

                For I=0 To GACTLAB-1
                    [F:ITV]ALABCST(I) += sigma(0,[M:STW]NBLIG-1,[M:SVWD]OLABCST(indcum*GACTLAB+I)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN
                Next

                [F:ITV]AOVELABCST += sigma(0,[M:STW]NBLIG-1,[M:SVWD]OOVELABTOT(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN

                [F:ITV]ASCOCST    += sigma(0,[M:STW]NBLIG-1,[M:SVWD]OSCOTOT(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN
                [F:ITV]AOVESCOCST += sigma(0,[M:STW]NBLIG-1,[M:SVWD]OOVESCOTOT(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN

                [F:ITV]AINVDTACST += sigma(0,[M:STW]NBLIG-1,[M:SVWD]OINVDTA(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN
            Endif
            [F:ITV]AVCBASAMT  += sigma(0,[M:STW]NBLIG-1,[M:SVWD]AMTORD(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN
        Else
            If GACTDECCST
                For I=0 To GACTMAT-1
                    [F:ITV]AMATCST(I) += sigma(0,[M:STW]NBLIG-1,[M:SVW]OMATCST(indcum*GACTMAT+I)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN
                Next

                [F:ITV]AOVEMATCST += sigma(0,[M:STW]NBLIG-1,[M:SVW]OOVEMATTOT(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN

                For I=0 To GACTMAC-1
                    [F:ITV]AMACCST(I) += sigma(0,[M:STW]NBLIG-1,[M:SVW]OMACCST(indcum*GACTMAC+I)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN
                Next

                [F:ITV]AOVEMACCST += sigma(0,[M:STW]NBLIG-1,[M:SVW]OOVEMACTOT(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN

                For I=0 To GACTLAB-1
                    [F:ITV]ALABCST(I) += sigma(0,[M:STW]NBLIG-1,[M:SVW]OLABCST(indcum*GACTLAB+I)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN
                Next

                [F:ITV]AOVELABCST += sigma(0,[M:STW]NBLIG-1,[M:SVW]OOVELABTOT(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN

                [F:ITV]ASCOCST    += sigma(0,[M:STW]NBLIG-1,[M:SVW]OSCOTOT(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN
                [F:ITV]AOVESCOCST += sigma(0,[M:STW]NBLIG-1,[M:SVW]OOVESCOTOT(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN

                [F:ITV]AINVDTACST += sigma(0,[M:STW]NBLIG-1,[M:SVW]OINVDTA(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN
            Endif
            [F:ITV]AVCBASAMT  += sigma(0,[M:STW]NBLIG-1,[M:SVW]AMTORD(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP))*LSIGN
        Endif

        If [F:ITV]AVCBASQTY=0 & [F:ITV]AVCBASAMT<>0 | [F:ITV]AVCBASAMT<0
            If !clalev([F:TCM]) : Local File TABCOSTMET [TCM] : Endif
            Call GETTCM([F:ITV]ITMREF,[F:ITV]STOFCY,WTCM,LRET) From STKVAL
            If !LRET & !fstat
                LNUMVLT = -1
                If [F:TCM]ISSVLTCOD(0)=4
                    LNUMVLT = 0
                Endif
                If [F:TCM]ISSVLTCOD(1)=4
                    LNUMVLT = 1
                Endif
                If LNUMVLT>-1
                    PAMTDEV(LNUMVLT,0)=[F:ITV]AVCBASAMT
                    If GACTDECCST
                        I=1
                        For J=0 To GACTMAT-1
                            PAMTDEV(LNUMVLT,I)=[F:ITV]AMATCST(J)
                            Raz [F:ITV]AMATCST(J)
                            I+=1
                        Next
                        For J=0 To GACTMAC-1
                            PAMTDEV(LNUMVLT,I)=[F:ITV]AMACCST(J)
                            Raz [F:ITV]AMACCST(J)
                            I+=1
                        Next
                        For J=0 To GACTLAB-1
                            PAMTDEV(LNUMVLT,I)=[F:ITV]ALABCST(J)
                            Raz [F:ITV]ALABCST(J)
                            I+=1
                        Next
                        PAMTDEV(LNUMVLT,I)=[F:ITV]ASCOCST
                        Raz [F:ITV]ASCOCST
                        I+=1
                        PAMTDEV(LNUMVLT,I)=[F:ITV]AINVDTACST
                        Raz [F:ITV]AINVDTACST
                        I+=1
                        PAMTDEV(LNUMVLT,I)=[F:ITV]AOVEMATCST
                        Raz [F:ITV]AOVEMATCST
                        I+=1
                        PAMTDEV(LNUMVLT,I)=[F:ITV]AOVEMACCST
                        Raz [F:ITV]AOVEMACCST
                        I+=1
                        PAMTDEV(LNUMVLT,I)=[F:ITV]AOVELABCST
                        Raz [F:ITV]AOVELABCST
                        I+=1
                        PAMTDEV(LNUMVLT,I)=[F:ITV]AOVESCOCST
                        Raz [F:ITV]AOVESCOCST
                    Endif
                # Issue 92701 - 2013-10-21 by CCC
                Else
                    If GACTDECCST
                        Raz LTABVAL
                        Call LOADFIC("[F:ITV]", LTABVAL, "A", "CST", 0, 0) From STKVALECR
                    Endif
                Endif
            Endif
            [F:ITV]AVCBASAMT = 0
        Endif
    Endif

    # Issue 112077 - 2017-01-25 by ERMIL : Reset GRNDVAL to previous value
    GRNDVAL = RNDVAL_SAV

Return

######################################
# Variables nécessaires:
# Integer I pour boucle

# Decimal GRNDVAL initialisé avec le nb de décimales désiré
# !!!!! Utilisé dans STOMAJ30 !!!!!
$UPDAVC

    # Issue 112077 - 2017-01-25 by ERMIL : Use correct value for GRNDVAL to reduce rounding errors
    Local Decimal RNDVAL_SAV
    RNDVAL_SAV = GRNDVAL
    Call INIRNDVAL("ITMMVT","AVC") From STKVALECR

    # Issue 73043 - 2011-05-13 by CCC : dans le cas des entrées négatives, il faut recalculer le PMP
    #If [F:ITV]AVCBASQTY>0 & [F:ITV]AVCBASAMT>0
    If [F:ITV]AVCBASQTY>0 & ([F:ITV]AVCBASAMT>0 | dim(PIO)<=0 | PIO=1)
        [F:ITV]AVC=arr([F:ITV]AVCBASAMT/[F:ITV]AVCBASQTY,GRNDVAL)
        If GACTDECCST
# Issue 92701 - 2013-10-21 by CCC
#            For I=0 To dim([F:ITV]AMATAVC)-1
#                [F:ITV]AMATAVC(I) = arr([F:ITV]AMATCST(I)/[F:ITV]AVCBASQTY,GRNDVAL)
#            Next
#            [F:ITV]AOVEMATAVC = arr([F:ITV]AOVEMATCST/[F:ITV]AVCBASQTY,GRNDVAL)
#
#            For I=0 To dim([F:ITV]AMACAVC)-1
#                [F:ITV]AMACAVC(I) = arr([F:ITV]AMACCST(I)/[F:ITV]AVCBASQTY,GRNDVAL)
#            Next
#            [F:ITV]AOVEMACAVC = arr([F:ITV]AOVEMACCST/[F:ITV]AVCBASQTY,GRNDVAL)
#
#            For I=0 To dim([F:ITV]ALABAVC)-1
#                [F:ITV]ALABAVC(I) = arr([F:ITV]ALABCST(I)/[F:ITV]AVCBASQTY,GRNDVAL)
#            Next
#            [F:ITV]AOVELABAVC = arr([F:ITV]AOVELABCST/[F:ITV]AVCBASQTY,GRNDVAL)
#
#            [F:ITV]ASCOAVC = arr([F:ITV]ASCOCST/[F:ITV]AVCBASQTY,GRNDVAL)
#            [F:ITV]AOVESCOAVC = arr([F:ITV]AOVESCOCST/[F:ITV]AVCBASQTY,GRNDVAL)
#
#            [F:ITV]AINVDTAAVC = arr([F:ITV]AINVDTACST/[F:ITV]AVCBASQTY,GRNDVAL)
            Call LOADVAR(LTABVAL, "[F:ITV]", 0, "A", 1/[F:ITV]AVCBASQTY, 0, 0) From STKVALECR
            Call REPVAL([F:ITV]AVC,LTABVAL, GRNDVAL, LTABVAL) From STKVALECR
            Call LOADFIC("[F:ITV]", LTABVAL, "A", "AVC", 1, 0) From STKVALECR
        Endif
    Endif

    # Issue 112077 - 2017-01-25 by ERMIL : Reset GRNDVAL to previous value
    GRNDVAL = RNDVAL_SAV

Return


######################################
Subprog NEWLASPRI(PORI)
Value    Integer PORI

Local Integer I

    # Issue 112077 - 2017-01-25 by ERMIL : Use correct value for GRNDVAL to reduce rounding errors
    If dim(LTABVAL)<=0
      Local Decimal LTABVAL(1+GACTMAT+GACTLAB+GACTMAC+1+1+4)
    Endif
    Local Decimal RNDVAL_SAV
    RNDVAL_SAV = GRNDVAL
    Call INIRNDVAL("ITMMVT","LASRCPPRI") From STKVALECR

  Case PORI
    When 1 : # STOVALWORK
        If [M:STW]TRSTYP=14
            # Issue 112077 - 2017-01-27 by ERMIL : Move detail calc to use LOADVAR, REPVAL and LOADFIC
            #If GACTDECCST
            #    For I=0 To GACTMAT-1
            #        [F:ITV]LMATCST(I) = arr([M:SVWD]OMATCST(I)/[M:STW]QTYSTUACT(0), GRNDVAL)
            #    Next
            #    [F:ITV]LOVEMATCST = arr([M:SVWD]OOVEMATTOT(0)/[M:STW]QTYSTUACT(0), GRNDVAL)
            #    For I=0 To GACTMAC-1
            #        [F:ITV]LMACCST(I) = arr([M:SVWD]OMACCST(I)/[M:STW]QTYSTUACT(0), GRNDVAL)
            #    Next
            #    [F:ITV]LOVEMACCST = arr([M:SVWD]OOVEMACTOT(0)/[M:STW]QTYSTUACT(0), GRNDVAL)
            #    For I=0 To GACTLAB-1
            #        [F:ITV]LLABCST(I) = arr([M:SVWD]OLABCST(I)/[M:STW]QTYSTUACT(0), GRNDVAL)
            #    Next
            #    [F:ITV]LOVELABCST = arr([M:SVWD]OOVELABTOT(0)/[M:STW]QTYSTUACT(0), GRNDVAL)
            #    [F:ITV]LSCOCST    = arr([M:SVWD]OSCOTOT(0)/[M:STW]QTYSTUACT(0), GRNDVAL)
            #    [F:ITV]LOVESCOCST = arr([M:SVWD]OOVESCOTOT(0)/[M:STW]QTYSTUACT(0), GRNDVAL)
            #    [F:ITV]LINVDTACST = arr([M:SVWD]OINVDTA(0)/[M:STW]QTYSTUACT(0), GRNDVAL)
            #Endif

            [F:ITV]LASRCPPRI  = [M:SVWD]PRIORD(0)
            #If GACTDECCST #CATUA X3-38294.o
            If GACTDECCST & [M:STW]QTYSTUACT(0)<>0 #CATUA X3-38294.n Check QTYSTUACT field to prevent division by zero
              Call LOADVAR(LTABVAL, "[M:SVWD]", 0, "O", 1/[M:STW]QTYSTUACT(0), 0, 0) From STKVALECR
              Call REPVAL([F:ITV]LASRCPPRI,LTABVAL, GRNDVAL, LTABVAL) From STKVALECR
              Call LOADFIC("[F:ITV]", LTABVAL, "L", "CST", 1, 0) From STKVALECR
            Endif
            # End issue 112077
        Else
            # Issue 112077 - 2017-01-27 by ERMIL : Move detail calc to use LOADVAR, REPVAL and LOADFIC
            #If GACTDECCST
            #    For I=0 To GACTMAT-1
            #        [F:ITV]LMATCST(I) = arr([M:SVW]OMATCST(I)/[M:STW]QTYSTUACT(0), GRNDVAL)
            #    Next
            #    [F:ITV]LOVEMATCST = arr([M:SVW]OOVEMATTOT(0)/[M:STW]QTYSTUACT(0), GRNDVAL)
            #    For I=0 To GACTMAC-1
            #        [F:ITV]LMACCST(I) = arr([M:SVW]OMACCST(I)/[M:STW]QTYSTUACT(0), GRNDVAL)
            #    Next
            #    [F:ITV]LOVEMACCST = arr([M:SVW]OOVEMACTOT(0)/[M:STW]QTYSTUACT(0), GRNDVAL)
            #    For I=0 To GACTLAB-1
            #        [F:ITV]LLABCST(I) = arr([M:SVW]OLABCST(I)/[M:STW]QTYSTUACT(0), GRNDVAL)
            #    Next
            #    [F:ITV]LOVELABCST = arr([M:SVW]OOVELABTOT(0)/[M:STW]QTYSTUACT(0), GRNDVAL)
            #    [F:ITV]LSCOCST    = arr([M:SVW]OSCOTOT(0)/[M:STW]QTYSTUACT(0), GRNDVAL)
            #    [F:ITV]LOVESCOCST = arr([M:SVW]OOVESCOTOT(0)/[M:STW]QTYSTUACT(0), GRNDVAL)
            #    [F:ITV]LINVDTACST = arr([M:SVW]OINVDTA(0)/[M:STW]QTYSTUACT(0), GRNDVAL)
            #Endif
            [F:ITV]LASRCPPRI  = [M:SVW]PRIORD(0)
            #If GACTDECCST #CATUA X3-38294.o
            If GACTDECCST & [M:STW]QTYSTUACT(0)<>0 #CATUA X3-38294.n Check QTYSTUACT field to prevent division by zero
              Call LOADVAR(LTABVAL, "[M:SVW]", 0, "O", 1/[M:STW]QTYSTUACT(0), 0, 0) From STKVALECR
              Call REPVAL([F:ITV]LASRCPPRI,LTABVAL, GRNDVAL, LTABVAL) From STKVALECR
              Call LOADFIC("[F:ITV]", LTABVAL, "L", "CST", 1, 0) From STKVALECR
            Endif
            # End issue 112077
        Endif
    When 2 : # STOJOUVAL
            [F:SJV] = [F:STJ]    # Récupération de la clé
            Read [SJV] =

            # Issue 112077 - 2017-01-27 by ERMIL : Move detail calc to use LOADVAR, REPVAL and LOADFIC
            #If [F:STJ]ACTQTY<>0 & GACTDECCST
            #    #---- Matière ----#
            #    For I=0 To GACTMAT-1
            #        [F:ITV]LMATCST(I) = arr([F:SJV]OMATCST(I)/[F:STJ]ACTQTY, GRNDVAL)
            #    Next
            #    [F:ITV]LOVEMATCST = arr([F:SJV]OOVEMATTOT/[F:STJ]ACTQTY, GRNDVAL)
            #    #---- Machine ----#
            #    For I=0 To GACTMAC-1
            #        [F:ITV]LMACCST(I) = arr([F:SJV]OMACCST(I)/[F:STJ]ACTQTY, GRNDVAL)
            #    Next
            #    [F:ITV]LOVEMACCST = arr([F:SJV]OOVEMACTOT/[F:STJ]ACTQTY, GRNDVAL)
            #    #---- Main d'oeuvre ----#
            #    For I=0 To GACTLAB-1
            #        [F:ITV]LLABCST(I) = arr([F:SJV]OLABCST(I)/[F:STJ]ACTQTY, GRNDVAL)
            #    Next
            #    [F:ITV]LOVELABCST = arr([F:SJV]OOVELABTOT/[F:STJ]ACTQTY, GRNDVAL)
            #    #---- Sous-traitance ----#
            #    [F:ITV]LSCOCST    = arr([F:SJV]OSCOTOT/[F:STJ]ACTQTY, GRNDVAL)
            #    [F:ITV]LOVESCOCST = arr([F:SJV]OOVESCOTOT/[F:STJ]ACTQTY, GRNDVAL)
            #
            #    [F:ITV]LINVDTACST = arr([F:SJV]OINVDTATOT/[F:STJ]ACTQTY, GRNDVAL)
            #Endif

            #---- Total ----#
            [F:ITV]LASRCPPRI  = [F:STJ]PRIORD
            If GACTDECCST & [F:STJ]ACTQTY<>0
              Call LOADVAR(LTABVAL, "[F:SJV]", 0, "O", 1/[F:STJ]ACTQTY, 0, 0) From STKVALECR
              Call REPVAL([F:ITV]LASRCPPRI,LTABVAL, GRNDVAL, LTABVAL) From STKVALECR
              Call LOADFIC("[F:ITV]", LTABVAL, "L", "CST", 1, 0) From STKVALECR
            Endif
            # End issue 112077
Endcase

    # Issue 112077 - 2017-01-25 by ERMIL : Reset GRNDVAL to previous value
    GRNDVAL = RNDVAL_SAV

End

####################################################
Subprog MAJFIFO(PIO,PAMTDEV)
Value    Integer PIO
Variable Decimal PAMTDEV(,)

Local Char    LFCY(GLONFCY)
Local Decimal LQTYTRT, LQTYSTP
Local Char    WPARAM(15)
Local Char    WTIME(8)
Local Integer WRET
Local Char    WCTEUR(GLONANM)
Local Char    LCRIT(250)
Local Char    WCLE(60)
Local Date    LCSTDAT
Local Char    LCSTTIM(8)
Local Decimal LCSTCOU
Local Char    WMESSAGE(250)
Local Decimal WQTEMAX
Local Decimal WCUMQTE, WCUMMT(dim(PAMTDEV,2))
Local Char    WFIC(20)
Local Integer LSIGN
Local Char    LMAJTYP(1)    # Nécessaire pour distinguer les lignes d'entrées ou de sorties lors d'un inventaire
Local Char    WTCM(GLONTCM)
Local Integer LNUMVLT, LNUMLIG
Local Integer I, J, K
Local Decimal LDELTASTP(1+(GACTMAT+GACTMAC+GACTLAB+1+4+1)*GACTDECCST)
Local Integer LINV  # Indique si on est en train de traiter un inventaire (cas particulier)
Local Decimal LQTYSMC  # Issue 119696

If mod([M:SVW]FILUPD,2)<1
    End
Endif

# Issue 114528 & 112666 09.2016 CCC: update active quantity in STOCOST table when potency changes
If [M:STW]VCRTYP=35
& | [M:STW]TRSTYP=8 & PIO=1

    Call UPDQTY_FIFO([M:STW]ITMREF, [M:STW]STOFCY)

    If  GOK=0 :  Call FSTA("STP") From GLOCK  : Endif
    End
Endif

# Issue 86700 - 2012-12-17 by CCC : Les mouvements internes n'ont pas à modifier les tables de cumul
If !(find([M:STW]TRSTYP,13,14) | find(func STKLIB.SENSTRS([M:STW]TRSTYP),-2,-1,1,2))
&    | find([M:STW]TRSTYP,16,32)   # Issue 89623 - 2013-06-26 by CCC : Les réceptions pour sous-traitance n'ont pas d'impact
                                   # Issue 93525 - 2013-06-26 by CCC : Les retours de réceptions pour sous-traitance n'ont pas d'impact
    End
Endif

#----- Pas de mise à jour si que des mouvements non valorisés ----#
If sigma(0,[M:STW]NBLIG-1,func STKVALMAJ.VALAUZ(indcum))=0
    End
Endif

# On teste MAJTYP pour le cas des inventaires
If PIO=2
    If [M:STW]TRSTYP=14
        LMAJTYP="C"
    Else
        LMAJTYP="S"
    Endif
    LSIGN = -1
    LQTYTRT = -sigma(0,[M:STW]NBLIG-1,[M:STW]QTYSTUACT(indcum)
&                                    *(-2*([M:STW]MAJCOD(indcum)="A")+1)
&                                    *([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(indcum)) )
Else
    If [M:STW]TRSTYP=14
        LMAJTYP="C"
    Else
        LMAJTYP="E"
    Endif
    LSIGN = 1
    LQTYTRT = sigma(0,[M:STW]NBLIG-1,[M:STW]QTYSTUACT(indcum)
&                                   *(-2*([M:STW]MAJCOD(indcum)="A")+1)
&                                   *([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(indcum)) )

Endif
LFCY = [M:STW]STOFCY
If PIO=1 & [M:STW]TRSTYP=14
    LFCY=[M:STW]TRFFCY
Endif

#----- Particularité pour l'inventaire ------#
If [M:STW]TRSTYP=13 & [M:STW]VCRTYP=9
    LINV=1
Else
    LINV=0
Endif

For LNUMLIG=0 To LINV*([M:STW]NBLIG-1)
    If LINV
        If [M:STW]MAJTYP(LNUMLIG)=LMAJTYP & func STKVALMAJ.VALAUZ(LNUMLIG)
            LQTYTRT=[M:STW]QTYSTUACT(LNUMLIG)*LSIGN
            [M:STW]VCRLIN=[M:STW]MVTSEQ(LNUMLIG)  # Pour les inventaires, le n° de ligne se trouve dans MVTSEQ (voir STKINT)
        Else
            Goto NEXT_NUMLIG
        Endif
    Endif
    If LQTYTRT>0    # Création ou ajout dans pile fifo
        Raz [F:STP], [F:STJ]
        # Issue 77123 - 2011-10-14 by CCC
        Raz LCSTCOU, LCSTDAT, LCSTTIM
        # Issue 119696 - 2016-12-01 by ERMIL : Modified this If to look for MAJCODH M or A first (flipped the If with the Else)
        If find([M:STW]MAJCODH,"M","A")
            # 118579.c - add TRSTYP to the filter
            # X3-38643.n 07/21/2017 MJH. added ( | PIO = 2)
            Filter [STJ] Where STOFCY  = LFCY
&                            & VCRTYP  = [M:STW]VCRTYP
&                            & VCRNUM  = [M:STW]VCRNUM
&                            & VCRLIN  = [M:STW]VCRLIN
&                            & ITMREF  = [M:STW]ITMREF
&                            & (TRSTYP<>29 | PIO=2)
&                            & CSTCOU <> 0
            Read [STJ]STJ0 First Hint Key STJ1
            Filter [STJ]
            If !fstat
                Readlock [STP]STP0=[F:STJ]ITMREF;[F:STJ]STOFCY;[F:STJ]CSTDAT;[F:STJ]CSTTIM;[F:STJ]CSTCOU
            Endif
            LCSTDAT = [F:STJ]CSTDAT
            LCSTTIM = [F:STJ]CSTTIM
            LCSTCOU = [F:STJ]CSTCOU
        Elsif PIO=2 & [M:STW]VCRNUMORI<>"" & [M:STW]MAJCODH="C"    # Si sortie négative (retour,réintégration...) avec origine
            Filter [STJ] Where STOFCY=LFCY
&                            & VCRTYP=[M:STW]VCRTYPORI
&                            & VCRNUM=[M:STW]VCRNUMORI
&                            & VCRLIN=[M:STW]VCRLINORI
&                            & ITMREF=[M:STW]ITMREF
&                            & REGFLG<>2
            Read [STJ]STJ1 First
            Filter [STJ]
            # Issue 118956 - 2016-12-13 by CCC : we have to create a new layer at the same time than origin but with different CSTCOU
            #If !fstat
            #    Readlock [STP]STP0=[F:STJ]ITMREF;[F:STJ]STOFCY;[F:STJ]CSTDAT;[F:STJ]CSTTIM;[F:STJ]CSTCOU
            #Endif
            #LCSTCOU = [F:STJ]CSTCOU
            LCSTDAT = [F:STJ]CSTDAT
            LCSTTIM = [F:STJ]CSTTIM
        Endif
        If [F:STP]ITMREF<>""
            Gosub ALIMSTP
            Call REWSTP From STKLIB
            Raz LQTYTRT
        Else
            If LCSTDAT=[0/0/0] | LCSTTIM="" | LCSTCOU=0
                # Issue 118956 - 2016-12-13 by CCC : calculate LCSTxxx if not known yet
                If LCSTCOU=0
                    #----- Attribution du chrono couts -----#
                    Call NUMERO(GSTKCPT(2),LFCY,[M:STW]IPTDAT,"",WPARAM,WRET) From SUBANM
                    If GOK<0
                      [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : End
                    Elsif GOK<1 | WRET<>0
                      [M:STW]ERRCOD=50 : WCTEUR=GSTKCPT(2) : Gosub TRT_ERR From STKMAJ : End
                    Endif
                    LCSTCOU=val(WPARAM)
                Endif
                If LCSTDAT=[0/0/0]
                    LCSTDAT=[M:STW]IPTDAT
                Endif
                If LCSTTIM=""
                    #X3-35580/122720 MJH 5/3/2017.sn
                    #When backdating a receipt the time to be used needs to be the last moment of the day
                    If LCSTDAT = date$
                      WTIME = time$ #original
                      LCSTTIM=left$(WTIME,2)+mid$(WTIME,4,2)+right$(WTIME,len(WTIME)-1) #original
                    Else
                      LCSTTIM = '235959'
                    Endif#X3-35580.en
                Endif
                WCLE=LFCY-num$([M:STW]VCRTYP)-[M:STW]VCRNUM-num$([M:STW]VCRLIN)
                # 118579.c - check for TRSTYP<>29
                Update [STJ] Where STOFCY=LFCY
&                                & VCRTYP=[M:STW]VCRTYP
&                                & VCRNUM=[M:STW]VCRNUM
&                                & VCRLIN=[M:STW]VCRLIN
&                                & ITMREF=[M:STW]ITMREF
&                                & TRSTYP <> 29
&                                & REGFLG<>2
&                            With CSTDAT = LCSTDAT,
&                                 CSTTIM = LCSTTIM,
&                                 CSTCOU = LCSTCOU
                If fstat=1
                  GLOCK="$STOJOU"-WCLE
                  [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : End
                Elsif fstat
                  Call RSTA("STJ",WCLE) From GLOCK
                  [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : End
                Endif
            Endif
            nolign=1
            [F:STP] = [M:STW]
            [F:STP]STOFCY = LFCY
            [F:STP]CSTDAT = LCSTDAT
            [F:STP]CSTTIM = LCSTTIM
            [F:STP]CSTCOU = LCSTCOU
            Raz [F:STP]QTYSTUACT
            Gosub ALIMSTP
            Call ECRSTP From STKLIB
        Endif
    Else            # purge pile fifo
        LQTYTRT = abs(LQTYTRT)
        # On essaie d'abord de purger ce qui a pu être créé précédemment par le document lui-même
        If LQTYTRT>0
            # 118579.c - Add TRSTYP to the filter
            Filter [STJ] Where STOFCY=LFCY
&                            & ITMREF=[M:STW]ITMREF
&                            & VCRTYP=[M:STW]VCRTYP
&                            & VCRNUM=[M:STW]VCRNUM
&                            & VCRLIN=[M:STW]VCRLIN
&                            & TRSTYP=[M:STW]TRSTYP
&                            & UPDCOD=2
            Read [STJ]STJ0 First Hint Key STJ1
            Filter [STJ]
            If !fstat
                LCRIT ="ITMREF=[F:STJ]ITMREF&STOFCY=[F:STJ]STOFCY"
                LCRIT+="&CSTDAT=[F:STJ]CSTDAT&CSTTIM=[F:STJ]CSTTIM&CSTCOU=[F:STJ]CSTCOU"
                Gosub PURGE_FIFO
            Endif
        Endif
        If LQTYTRT>0 & [M:STW]VCRTYP=8 & [M:STW]VCRNUMORI<>""    # Retour fournisseur
            LCRIT ="ITMREF=[M:STW]ITMREF & STOFCY=LFCY"
            LCRIT+="& VCRTYP=[M:STW]VCRTYPORI"
            LCRIT+="& VCRNUM=[M:STW]VCRNUMORI"
            LCRIT+="& VCRLIN=[M:STW]VCRLINORI"
            LCRIT+="& QTYSTUACT>0"
            Gosub PURGE_FIFO
        Endif
        If LQTYTRT>0
            LCRIT ="ITMREF=[M:STW]ITMREF"
            LCRIT+="&STOFCY=LFCY"
            LCRIT+="&QTYSTUACT>0"
            Gosub PURGE_FIFO
        Endif

        # X3-58152 - 2017-10-06 MJH update CSTCOU for deleted receipts
        #If [M:STW]MAJCODH="C" & LCSTDAT<>[0/0/0] & LCSTTIM<>"" & LCSTCOU>0
        If ([M:STW]MAJCODH="C" | ([F:STJ]VCRTYP = 6 & [M:STW]MAJCODH = 'A') ) & LCSTDAT<>[0/0/0] & LCSTTIM<>"" & LCSTCOU>0
            WCLE=LFCY-num$([M:STW]VCRTYP)-[M:STW]VCRNUM-num$([M:STW]VCRLIN)
            # 118579.c - Add TRSTYP to the filter
            # X3-58152 - 2017-10-06 MJH add MVTSEQ to the filter
            Update [STJ] Where STOFCY=LFCY
&                            & VCRTYP=[M:STW]VCRTYP
&                            & VCRNUM=[M:STW]VCRNUM
&                            & VCRLIN=[M:STW]VCRLIN
&                            & ITMREF=[M:STW]ITMREF
&                            & TRSTYP=[M:STW]TRSTYP
&                            & MVTSEQ=[M:STW]MVTSEQ
&                            & UPDCOD=2
&                        With CSTDAT = LCSTDAT,
&                             CSTTIM = LCSTTIM,
&                             CSTCOU = LCSTCOU
            If fstat=1
              GLOCK="$STOJOU"-WCLE
              [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : End
            Elsif fstat
              Call RSTA("STJ",WCLE) From GLOCK
              [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : End
            Endif
        Endif
        # CCC (12/11/04) On alimente l'écart non absorbé dans le cas où la méthode de valo est FIFO ou LIFO
        If !clalev([F:TCM]) : Local File TABCOSTMET [TCM] : Endif
        Call GETTCM([M:STW]ITMREF,LFCY,WTCM,WRET) From STKVAL
        If !WRET & !fstat
            For LNUMVLT = 0 To GACTVLT2
                If find([F:TCM]ISSVLTCOD(LNUMVLT),5,7)
                    PAMTDEV(LNUMVLT,0)=WCUMMT(0)-abs(sigma(0,[M:STW]NBLIG-1,[M:SVW]AMTORD(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(indcum))))
                    If GACTDECCST
                        I=1
                        For J=0 To GACTMAT-1
                            PAMTDEV(LNUMVLT,I)=WCUMMT(I)-abs(sigma(0,[M:STW]NBLIG-1,[M:SVW]OMATCST(indcum*GACTMAT+J)
&                                                                                  *(-2*([M:STW]MAJCOD(indcum)='A')+1)
&                                                                                  *([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(indcum))))
                            I+=1
                        Next
                        For J=0 To GACTMAC-1
                            PAMTDEV(LNUMVLT,I)=WCUMMT(I)-abs(sigma(0,[M:STW]NBLIG-1,[M:SVW]OMACCST(indcum*GACTMAC+J)
&                                                                                  *(-2*([M:STW]MAJCOD(indcum)='A')+1)
&                                                                                  *([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(indcum))))
                            I+=1
                        Next
                        For J=0 To GACTLAB-1
                            PAMTDEV(LNUMVLT,I)=WCUMMT(I)-abs(sigma(0,[M:STW]NBLIG-1,[M:SVW]OLABCST(indcum*GACTLAB+J)
&                                                                                  *(-2*([M:STW]MAJCOD(indcum)='A')+1)
&                                                                                  *([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(indcum))))
                            I+=1
                        Next
                        PAMTDEV(LNUMVLT,I)=WCUMMT(I)-abs(sigma(0,[M:STW]NBLIG-1,[M:SVW]OSCOTOT(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(indcum)
& )))
                        I+=1
                        PAMTDEV(LNUMVLT,I)=WCUMMT(I)-abs(sigma(0,[M:STW]NBLIG-1,[M:SVW]OINVDTA(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(indcum)
& )))
                        I+=1
                        PAMTDEV(LNUMVLT,I)=WCUMMT(I)-abs(sigma(0,[M:STW]NBLIG-1,[M:SVW]OOVEMATTOT(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(
& indcum))))
                        I+=1
                        PAMTDEV(LNUMVLT,I)=WCUMMT(I)-abs(sigma(0,[M:STW]NBLIG-1,[M:SVW]OOVEMACTOT(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(
& indcum))))
                        I+=1
                        PAMTDEV(LNUMVLT,I)=WCUMMT(I)-abs(sigma(0,[M:STW]NBLIG-1,[M:SVW]OOVELABTOT(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(
& indcum))))
                        I+=1
                        PAMTDEV(LNUMVLT,I)=WCUMMT(I)-abs(sigma(0,[M:STW]NBLIG-1,[M:SVW]OOVESCOTOT(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(
& indcum))))
                    Endif
                Endif
            Next
        Endif
    Endif
    If LQTYTRT<>0 & [M:STW]TRAFLG>1
      WMESSAGE=LFCY-[M:STW]ITMREF-mess(449,197,1)-num$(LQTYTRT)-mess(216,197,1)
      Call ECR_TRACE([L]WMESSAGE,0) From GESECRAN
      If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
    Endif
    $NEXT_NUMLIG
Next
If LINV
    [M:STW]VCRLIN=0
Endif
End

$ALIMSTP
  # Issue 119696 - 2016-12-22 by ERMIL : Added if - we will handled this case later
  If !(find([M:STW]MAJCODH,"M","A") & LSIGN<0)
    [F:STP]QTYSTUACT    += LQTYTRT
  Endif
    Raz J
    # Issue 121360 - 2017-02-03 by ERMIL : This case not needed, handled properly in cases below
    #If PIO=2 & GACTVLT2 & find([M:SVW]PRINAT2(0),6,9)
    #    LDELTASTP(J) = sigma(0,[M:STW]NBLIG-1,[M:SVW]AMTVAL2(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(indcum)))*LSIGN
    #    If GACTDECCST
    #        For I=0 To [M:STW]NBLIG-1
    #            If func STKVALMAJ.VALAUZ(I) & ([M:STW]MAJTYP(I)=LMAJTYP)
    #                K=1
    #                For J=0 To GACTMAT-1
    #                    LDELTASTP(J+K) += [M:SVW]V2MATCST(I*GACTMAT+J)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
    #                Next
    #                K+=GACTMAT
    #
    #                For J=0 To GACTMAC-1
    #                    LDELTASTP(J+K) += [M:SVW]V2MACCST(I*GACTMAC+J)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
    #                Next
    #                K+=GACTMAC
    #
    #                For J=0 To GACTLAB-1
    #                    LDELTASTP(J+K) += [M:SVW]V2LABCST(I*GACTLAB+J)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
    #                Next
    #                K+=GACTLAB
    #
    #                LDELTASTP(K) += [M:SVW]V2SCOTOT(I)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
    #                K+=1
    #                LDELTASTP(K) += [M:SVW]V2INVDTA(I)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
    #                K+=1
    #                LDELTASTP(K) += [M:SVW]V2OVEMAT(I)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
    #                K+=1
    #                LDELTASTP(K) += [M:SVW]V2OVEMAC(I)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
    #                K+=1
    #                LDELTASTP(K) += [M:SVW]V2OVELAB(I)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
    #                K+=1
    #                LDELTASTP(K) += [M:SVW]V2OVESCO(I)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
    #                K+=1
    #            Endif
    #        Next
    #    Endif
    #Elsif [M:STW]TRSTYP=14 & PIO=1    # Si entrée d'un transfert inter-sites on prend les valeurs dans SVWD
    If [M:STW]TRSTYP=14 & PIO=1    # Si entrée d'un transfert inter-sites on prend les valeurs dans SVWD
        LDELTASTP(J) = sigma(0,[M:STW]NBLIG-1,[M:SVWD]AMTORD(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(indcum)))*LSIGN
        J+=1

        If GACTDECCST
            For I=0 To [M:STW]NBLIG-1
                If func STKVALMAJ.VALAUZ(I) & ([M:STW]MAJTYP(I)=LMAJTYP)
                    K=1
                    For J=0 To GACTMAT-1
                        LDELTASTP(J+K) += [M:SVWD]OMATCST(I*GACTMAT+J)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
                    Next
                    K+=GACTMAT

                    For J=0 To GACTMAC-1
                        LDELTASTP(J+K) += [M:SVWD]OMACCST(I*GACTMAC+J)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
                    Next
                    K+=GACTMAC

                    For J=0 To GACTLAB-1
                        LDELTASTP(J+K) += [M:SVWD]OLABCST(I*GACTLAB+J)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
                    Next
                    K+=GACTLAB

                    LDELTASTP(K) += [M:SVWD]OSCOTOT(I)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
                    K+=1
                    LDELTASTP(K) += [M:SVWD]OINVDTA(I)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
                    K+=1
                    LDELTASTP(K) += [M:SVWD]OOVEMATTOT(I)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
                    K+=1
                    LDELTASTP(K) += [M:SVWD]OOVEMACTOT(I)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
                    K+=1
                    LDELTASTP(K) += [M:SVWD]OOVELABTOT(I)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
                    K+=1
                    LDELTASTP(K) += [M:SVWD]OOVESCOTOT(I)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
                    K+=1
                Endif
            Next
        Endif
    Elsif find([M:STW]MAJCODH,"M","A") & LSIGN<0
        # Issue 119696 - 2016-12-22 by ERMIL : handling putting back FIFO items via issue modification
        # In this case - we are modifying a previous issue to remove items.
        # So we need to look at the original STOMVTCOST and get those costs and tiers
        LCRIT ="ITMREF=[F:STP]ITMREF & STOFCY=[F:STP]STOFCY"
        LCRIT+="& VCRTYP=[M:STW]VCRTYP & VCRNUM=[M:STW]VCRNUM"
        LCRIT+="& VCRLIN=[M:STW]VCRLIN"

        # We are putting back items here - so we want newest to oldest for LIFO and
        # and oldest to newest for FIFO (opposite of normal)
        If [M:SVW]PRINAT(0)=9
          Filter [SMC] Where evalue(LCRIT) Order By CSTDAT Asc; CSTTIM Asc; CSTCOU Asc
        Else
          Filter [SMC] Where evalue(LCRIT) Order By CSTDAT Desc; CSTTIM Desc; CSTCOU Desc
        Endif

        # Make sure we have the correct valuation method
        Call GETTCM([F:STJ]ITMREF,[F:STJ]STOFCY,WTCM,WRET) From STKVAL

        # Loop through the SMC records to determine the cost difference and which tiers to return to
        For [SMC]

          If LQTYTRT=0 : Break : Endif
          LQTYSMC = min([F:SMC]QTYSTU,LQTYTRT)
          Raz LDELTASTP

          # Lock the SMC record for update
          Readlock [SMC] Curr

          If [F:SMC]QTYSTU > LQTYSMC
            WAMTORD       =arr([F:SMC]CST*LQTYSMC/[F:SMC]QTYSTU,GRNDVAL) * -1
            WCUMQTE      -=LQTYTRT
            WCUMMT(0)    +=WAMTORD
            LDELTASTP(0)  =arr([F:SMC]CST*LQTYSMC/[F:SMC]QTYSTU,GRNDVAL) * -1
            If GACTDECCST
              Call LOADVAR(LDELTASTP,"[F:SMC]",0, "", LQTYSMC/[F:SMC]QTYSTU*-1, 0, GRNDVAL) From STKVALECR
              For J=1 To dim(LDELTASTP)-1
                WCUMMT(J)   += LDELTASTP(J)
              Next

              Call LOADFIC("[F:SMC]",LDELTASTP, "", "CST",  1, 1) From STKVALECR
            Endif

            #Update Qty and Cost in STOMVTCOST
            [F:SMC]QTYSTU     -= [L]LQTYSMC
            [F:SMC]CST        += WAMTORD

            Call REWSMC From STKLIB : WMESSAGE=mess(232,197,1) # Record modified

            # Read the STOCOST record that corresponds with the movement and update
            Readlock [STP]STP0=[F:STJ]ITMREF;[F:STJ]STOFCY;[F:SMC]CSTDAT;[F:SMC]CSTTIM;[F:SMC]CSTCOU
            Case fstat
              When 0 :
                [F:STP]QTYSTUACT  += [L]LQTYSMC
                [F:STP]CST        -= WAMTORD
                If GACTDECCST
                  Call LOADFIC("[F:STP]",LDELTASTP, "", "CST", -1, 1) From STKVALECR
                Endif

                Call REWSTP From STKLIB : WMESSAGE=mess(232,197,1) # Record modified

              When 4,5 :
                [F:STP] = [F:SMC]

                # Attempt to look up the original VCRNUM that created this tier
                If clalev([F:STJ2])=0 : Local File STOJOU [STJ2] : Endif
                Filter [F:STJ2] Where ITMREF=[F:STP]ITMREF
&                                   & STOFCY=[F:STP]STOFCY
&                                   & CSTDAT=[F:STP]CSTDAT
&                                   & CSTTIM=[F:STP]CSTTIM
&                                   & CSTCOU=[F:STP]CSTCOU
&                                   & REGFLG=1 & QTYSTU > 0
                Read [F:STJ2]STJ4 First
                Filter [F:STJ2]
                If !fstat
                  [F:STP]VCRNUM = [F:STJ2]VCRNUM
                  [F:STP]VCRTYP = [F:STJ2]VCRTYP
                  [F:STP]VCRLIN = [F:STJ2]VCRLIN
                Endif

                [F:STP]QTYSTUACT  = [L]LQTYSMC
                [F:STP]CST        = WAMTORD * -1
                If GACTDECCST
                  Call LOADFIC("[F:STP]",LDELTASTP, "", "CST", -1, 0) From STKVALECR
                Endif
                Write [STP]
            Endcase

            Raz LQTYTRT
          Else
            WCUMQTE       -= [F:SMC]QTYSTU
            WCUMMT(0)     -= [F:SMC]CST
            LQTYTRT       -= [F:SMC]QTYSTU
            LDELTASTP(0)  -= [F:SMC]CST
            If GACTDECCST
              Call LOADVAR(LDELTASTP,"[F:SMC]",0, "", -1, 0, 0) From STKVALECR
              Call LOADVAR(WCUMMT,"[F:SMC]",0, "", -1, 1, 0) From STKVALECR
            Endif

            #Update Qty and STOMVTCOST (no need to update rest - just deleting the record)
            [F:SMC]QTYSTU = 0

            # Read the STOCOST record that corresponds with the movement and update
            Readlock [STP]STP0=[F:STJ]ITMREF;[F:STJ]STOFCY;[F:SMC]CSTDAT;[F:SMC]CSTTIM;[F:SMC]CSTCOU
            Case fstat
              When 0 :
                [F:STP]QTYSTUACT  += [L]LQTYSMC
                [F:STP]CST        += [F:SMC]CST
                If GACTDECCST
                  Call LOADFIC("[F:STP]",LDELTASTP, "", "CST", -1, 1) From STKVALECR
                Endif

                Call REWSTP From STKLIB : WMESSAGE=mess(232,197,1) # Record modified

              When 4,5 :
                [F:STP] = [F:SMC]

                # Attempt to look up the original VCRNUM that created this tier
                If clalev([F:STJ2])=0 : Local File STOJOU [STJ2] : Endif
                Filter [F:STJ2] Where ITMREF=[F:STP]ITMREF
&                                   & STOFCY=[F:STP]STOFCY
&                                   & CSTDAT=[F:STP]CSTDAT
&                                   & CSTTIM=[F:STP]CSTTIM
&                                   & CSTCOU=[F:STP]CSTCOU
&                                   & REGFLG=1 & QTYSTU > 0
                Read [F:STJ2]STJ4 First
                Filter [F:STJ2]
                If !fstat
                  [F:STP]VCRNUM = [F:STJ2]VCRNUM
                  [F:STP]VCRTYP = [F:STJ2]VCRTYP
                  [F:STP]VCRLIN = [F:STJ2]VCRLIN
                Endif

                [F:STP]QTYSTUACT  = [L]LQTYSMC
                [F:STP]CST        = [F:SMC]CST
                If GACTDECCST
                  Call LOADFIC("[F:STP]",LDELTASTP, "", "CST", -1, 0) From STKVALECR
                Endif
                Write [STP]
            Endcase

            Call REWSMC From STKLIB : WMESSAGE=mess(175,197,1) # Record deleted

          Endif
        Next
        Filter [SMC]

        # Deal with the AMTDEV for the Type 35 that may need to be created
        For LNUMVLT = 0 To GACTVLT2
          If find([F:TCM]ISSVLTCOD(LNUMVLT),5,8)
            PAMTDEV(LNUMVLT,0)=WCUMMT(0)+abs(sigma(0,[M:STW]NBLIG-1,[M:SVW]AMTORD(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(indcum))))
            If GACTDECCST
              I=1
              For J=0 To GACTMAT-1
                PAMTDEV(LNUMVLT,I)=WCUMMT(I)+abs(sigma(0,[M:STW]NBLIG-1,[M:SVW]OMATCST(indcum*GACTMAT+J)*(-2*([M:STW]MAJCOD(indcum)='A')+1)*([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(
& indcum))))
                I+=1
              Next
              For J=0 To GACTMAC-1
                PAMTDEV(LNUMVLT,I)=WCUMMT(I)+abs(sigma(0,[M:STW]NBLIG-1,[M:SVW]OMACCST(indcum*GACTMAC+J)*(-2*([M:STW]MAJCOD(indcum)='A')+1)*([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(
& indcum))))
                I+=1
              Next
              For J=0 To GACTLAB-1
                PAMTDEV(LNUMVLT,I)=WCUMMT(I)+abs(sigma(0,[M:STW]NBLIG-1,[M:SVW]OLABCST(indcum*GACTLAB+J)*(-2*([M:STW]MAJCOD(indcum)='A')+1)*([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(
& indcum))))
                I+=1
              Next
              PAMTDEV(LNUMVLT,I)=WCUMMT(I)+abs(sigma(0,[M:STW]NBLIG-1,[M:SVW]OSCOTOT(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(indcum))))
              I+=1
              PAMTDEV(LNUMVLT,I)=WCUMMT(I)+abs(sigma(0,[M:STW]NBLIG-1,[M:SVW]OINVDTA(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(indcum))))
              I+=1
              PAMTDEV(LNUMVLT,I)=WCUMMT(I)+abs(sigma(0,[M:STW]NBLIG-1,[M:SVW]OOVEMATTOT(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(indcum))))
              I+=1
              PAMTDEV(LNUMVLT,I)=WCUMMT(I)+abs(sigma(0,[M:STW]NBLIG-1,[M:SVW]OOVEMACTOT(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(indcum))))
              I+=1
              PAMTDEV(LNUMVLT,I)=WCUMMT(I)+abs(sigma(0,[M:STW]NBLIG-1,[M:SVW]OOVELABTOT(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(indcum))))
              I+=1
              PAMTDEV(LNUMVLT,I)=WCUMMT(I)+abs(sigma(0,[M:STW]NBLIG-1,[M:SVW]OOVESCOTOT(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(indcum))))
            Endif
          Endif
        Next
        Goto ENDSMTP  #Skip the final update to SMC, we have handled that properly in here
        # End issue 119696
    Else
        # Issue 77123 - 2011-10-14 by CCC : Dans le cas d'un iventaire, on crée un élément de pile par ligne STW
        If LINV
            LDELTASTP(J) = [M:SVW]AMTORD(LNUMLIG)*(-2*([M:STW]MAJCOD(LNUMLIG)="A")+1)*LSIGN
        Else
            LDELTASTP(J) = sigma(0,[M:STW]NBLIG-1,[M:SVW]AMTORD(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(indcum)))*LSIGN
        Endif
        J+=1

        If GACTDECCST
            For I=0 To (LINV<>1)*([M:STW]NBLIG-1)
                If func STKVALMAJ.VALAUZ(I) & ([M:STW]MAJTYP(I)=LMAJTYP)
                    K=1
                    For J=0 To GACTMAT-1
                        LDELTASTP(J+K) += [M:SVW]OMATCST(I*GACTMAT+J)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
                    Next
                    K+=GACTMAT

                    For J=0 To GACTMAC-1
                        LDELTASTP(J+K) += [M:SVW]OMACCST(I*GACTMAC+J)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
                    Next
                    K+=GACTMAC

                    For J=0 To GACTLAB-1
                        LDELTASTP(J+K) += [M:SVW]OLABCST(I*GACTLAB+J)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
                    Next
                    K+=GACTLAB

                    LDELTASTP(K) += [M:SVW]OSCOTOT(I)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
                    K+=1
                    LDELTASTP(K) += [M:SVW]OINVDTA(I)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
                    K+=1
                    LDELTASTP(K) += [M:SVW]OOVEMATTOT(I)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
                    K+=1
                    LDELTASTP(K) += [M:SVW]OOVEMACTOT(I)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
                    K+=1
                    LDELTASTP(K) += [M:SVW]OOVELABTOT(I)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
                    K+=1
                    LDELTASTP(K) += [M:SVW]OOVESCOTOT(I)*(-2*([M:STW]MAJCOD(I)="A")+1)*LSIGN
                    K+=1
                Endif
            Next
        Endif
    Endif
    [F:STP]CST += LDELTASTP(0)
    If GACTDECCST
        Call LOADFIC("[F:STP]",LDELTASTP, "", "CST", 1, 1) From STKVALECR
    Endif
    LQTYTRT -= [F:STP]QTYSTUACT

    # Alimentation de la table STOMVTCOST [SMC] pour régul de sortie
    If PIO=2
        Filter [SMC] Where CSTCOU = [F:STP]CSTCOU
&                        & CSTTIM = [F:STP]CSTTIM
&                        & CSTDAT = [F:STP]CSTDAT
&                        & ITMREF = [F:STP]ITMREF
&                        & STOFCY = [F:STP]STOFCY
&                        & VCRTYP = [M:STW]VCRTYP
&                        & VCRNUM = [M:STW]VCRNUM
&                        & VCRLIN = [M:STW]VCRLIN

        Readlock [SMC] First
        Filter [SMC]
        If !fstat
            [F:SMC]QTYSTU -= LQTYTRT
            If [F:SMC]QTYSTU<=0
                Delete [SMC]
            Else
                [F:SMC]CST -= LDELTASTP(0)
                If GACTDECCST
                    Call LOADFIC("[F:SMC]",LDELTASTP, "", "CST", -1, 1) From STKVALECR
                Endif
                Rewrite [SMC]
            Endif
            If fstat
                Call FSTA("SMC") From GLOCK : [M:STW]ERRCOD=70 : Gosub TRT_ERR From STKMAJ : Return
            Endif
        Endif
    Endif
    $ENDSMTP
Return


#-----------------------------------------#
# Purge coûts stock FIFO (STOCOST)        #
#-----------------------------------------#
# - sortie                                #
# - entrée négative                       #
#-----------------------------------------#
$PURGE_FIFO
    If [M:SVW]PRINAT(0)=9
      Filter [STP] Where evalue(LCRIT)
&                  Order By Key STP0 Desc
    Else
      Filter [STP] Where evalue(LCRIT)
&                  Order By Key STP0 Asc
    Endif
    Gosub PURGE_FIFO_LOOP
    Filter [STP]
Return

#--------------------------------------------
$PURGE_FIFO_LOOP
For [STP]
    If LQTYTRT=0  Break : Endif
    WCLE =[F:STP]ITMREF-[F:STP]STOFCY-num$([F:STP]CSTDAT)
    WCLE-=[F:STP]CSTTIM-num$([F:STP]CSTCOU)
    Readlock [STP] Curr
    If fstat=1
      GLOCK="$STOCOST"-WCLE
      [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Break
    Elsif fstat
      Call RSTA("STP",WCLE) From GLOCK
      [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Break
    Endif

      LQTYSTP = min([F:STP]QTYSTUACT,LQTYTRT)

    If [F:STP]QTYSTUACT>LQTYTRT
      WAMTORD    =arr([F:STP]CST*LQTYTRT/[F:STP]QTYSTUACT,GRNDVAL)
      WCUMQTE   +=LQTYTRT
      WCUMMT(0) +=WAMTORD
      LDELTASTP(0)=WAMTORD
      If GACTDECCST
          Call LOADVAR(LDELTASTP,"[F:STP]",0, "", LQTYTRT/[F:STP]QTYSTUACT, 0, GRNDVAL) From STKVALECR

          For J=1 To dim(LDELTASTP)-1
              WCUMMT(J)   += LDELTASTP(J)
          Next
          Call LOADFIC("[F:STP]",LDELTASTP, "", "CST", -1, 1) From STKVALECR

      Endif

      [F:STP]QTYSTUACT-=LQTYTRT
      [F:STP]CST   -=WAMTORD
      #----- Récupération clé pile FIFO de la plus grande quantité traitée -----#
      If LCSTCOU=0 | WQTEMAX<LQTYTRT
        LCSTDAT=[F:STP]CSTDAT
        LCSTTIM=[F:STP]CSTTIM
        LCSTCOU=[F:STP]CSTCOU
        WQTEMAX=LQTYTRT
      Endif
      #-----
      Raz LQTYTRT
      Call REWSTP From STKLIB : WMESSAGE=mess(232,197,1) : # Réécriture
    Else
      WCUMQTE   +=[F:STP]QTYSTUACT
      WCUMMT(0) +=[F:STP]CST
      LQTYTRT   -=[F:STP]QTYSTUACT
      LDELTASTP(0) = [F:STP]CST
      If GACTDECCST
          Call LOADVAR(LDELTASTP,"[F:STP]",0, "", 1, 0, 0) From STKVALECR
          Call LOADVAR(WCUMMT,"[F:STP]",0, "", 1, 1, 0) From STKVALECR
      Endif

      #----- Récupération clé pile FIFO de la plus grande quantité traitée -----#
      If LCSTCOU=0 | WQTEMAX<[F:STP]QTYSTUACT
        LCSTDAT=[F:STP]CSTDAT
        LCSTTIM=[F:STP]CSTTIM
        LCSTCOU=[F:STP]CSTCOU
        WQTEMAX=[F:STP]QTYSTUACT
      Endif
      #-----
      # CCC (2009-10-30) PE 53988
      [F:STP]QTYSTUACT=0
      Call REWSTP From STKLIB : [L]WMESSAGE=mess(175,197,1) : # Suppression
    Endif
    If fstat
      Call FSTA("STP") From GLOCK : [M:STW]ERRCOD=70 : Gosub TRT_ERR From STKMAJ : Break
    Endif
    If [M:STW]TRAFLG>2  WFIC="STOCOST" : Gosub TRACE_DETAILLEE From STKMAJSUP : Endif
# Issue 94844 - 2014-02-05 by CCC : Enregistrer les retours dans STOMVTCOST
    # X3-58152 - 2017-10-06 MJH Create STOMVTCOST records for receipts that are deleted
#    If PIO=2
#    If PIO=2 | [F:STJ]VCRTYP=8 #X3-58152.o
    If PIO=2 | [F:STJ]VCRTYP=8 | ([F:STJ]VCRTYP = 6 & [M:STW]MAJCODH = 'A')
        # Alimentation de la table STOMVTCOST [SMC] pour régul de sortie
        Filter [SMC] Where CSTCOU = [F:STP]CSTCOU
&                        & CSTTIM = [F:STP]CSTTIM
&                        & CSTDAT = [F:STP]CSTDAT
&                        & ITMREF = [F:STP]ITMREF
&                        & STOFCY = [F:STP]STOFCY
&                        & VCRTYP = [M:STW]VCRTYP
&                        & VCRNUM = [M:STW]VCRNUM
&                        & VCRLIN = [M:STW]VCRLIN

        Readlock [SMC] First
        Filter [SMC]
        Case fstat
            When 0 :
                [F:SMC]QTYSTU += LQTYSTP
                [F:SMC]CST += LDELTASTP(0)
                If GACTDECCST
                    Call LOADFIC("[F:SMC]",LDELTASTP, "", "CST", 1, 1) From STKVALECR
                Endif
                Rewrite [SMC]

            When 4,5 :
                [F:SMC] = [F:STP]
                [F:SMC]VCRTYP = [M:STW]VCRTYP
                [F:SMC]VCRNUM = [M:STW]VCRNUM
                [F:SMC]VCRLIN = [M:STW]VCRLIN
                [F:SMC]QTYSTU = LQTYSTP
                [F:SMC]CST    = LDELTASTP(0)
                If GACTDECCST
                    Call LOADFIC("[F:SMC]",LDELTASTP, "", "CST", 1, 0) From STKVALECR
                Endif
                Write [SMC]
        Endcase
        If fstat
            Call FSTA("SMC") From GLOCK : [M:STW]ERRCOD=70 : Gosub TRT_ERR From STKMAJ : Break
        Endif
    Endif

Next
Return

################################################
# MAJVALLOT : met à jour la valeur du lot
################################################
# Paramètres E : PIO        = 1:Entrée 2:Sortie
#                PIND       = Indice dans SVW
#                POLDQTYSTL = qté lot avant mouvement
#                PAMTDEV    = montant non absorbé
################################################
Subprog MAJVALLOT(PIO,PIND,PAMTDEV)
Value Integer PIO
Value Integer PIND
Variable Decimal PAMTDEV(,)

Local Char    WDEVORI(GLONCUR)
Local Char    WDEVDES(GLONCUR)
Local Integer LRET, I
Local Char    LMAJTYP(1)
Local Integer LNUMVLT
Local Integer LSIGN
Local Char    WTCM(GLONTCM)
Local Decimal LOLDQTYSLF

Local Decimal LTABVAL(dim(PAMTDEV,2))

    If mod([M:SVW]FILUPD,8)<4
        End
    Endif

    # Issue 93525 - 2013-06-26 by CCC : Les retours de réceptions pour sous-traitance n'ont pas d'impact
    # Issue 89623 - 2013-06-26 by CCC : Les réceptions pour sous-traitance n'ont pas d'impact
    If find([M:STW]TRSTYP,16,32)
        End
    Endif

    #----- Pas de mise à jour si mouvements en attente ou pas propriétaire ----#
    If func STKVALMAJ.VALAUZ(PIND)=0
        End
    Endif

    LOLDQTYSLF = [F:SLF]AVCBASQTY

    If PIO=2
        LSIGN=-1
# Issue 77372 - 2011-10-25 by CCC
#        If [M:STW]TRSTYP=14
        If find([M:STW]TRSTYP,14,22)
            LMAJTYP = "C"
        Else
            LMAJTYP = "S"
        Endif
        [F:SLF]AVCBASQTY  += -[M:STW]QTYSTUACT(PIND)
&                            *(-2*([M:STW]MAJCOD(PIND)="A")+1)
&                            *([M:STW]MAJTYP(PIND)=LMAJTYP & func STKVALMAJ.VALAUZ(PIND))
    Else
        LSIGN=1
# Issue 77372 - 2011-10-25 by CCC
#        If [M:STW]TRSTYP=14
        If find([M:STW]TRSTYP,14,22)
            LMAJTYP = "C"
        Else
            LMAJTYP = "E"
        Endif
        [F:SLF]AVCBASQTY  += [M:STW]QTYSTUACT(PIND)
&                            *(-2*([M:STW]MAJCOD(PIND)="A")+1)
&                            *([M:STW]MAJTYP(PIND)=LMAJTYP & func STKVALMAJ.VALAUZ(PIND))
    Endif

    # Issue 114528 & 112666 09.2016 CCC : For potency modification, we just need to update quantity and unit price
    # With VCRTYP=35 we need to update the amount for the case of renumbering/mix
    If [M:STW]VCRTYP<>35 | find(GFONCTION,"GESSMX","FUNSMXUPD")=0
        Gosub UPDLOTAMT
    Endif
    Gosub UPDLOTAVC
End

######################################
$UPDLOTAMT

    # Issue 112077 - 2017-01-25 by ERMIL : Use correct value for GRNDVAL to reduce rounding errors
    Local Decimal RNDVAL_SAV
    RNDVAL_SAV = GRNDVAL
    Call INIRNDVAL("STOLOTFCY","AVCBASAMT") From STKVALECR

    # Si création sortie (saus sortie négative) non valorisée au PMP : la valeur du PMP ne doit pas changer
    If [M:STW]MAJCODH="C" & PIO=2 & LOLDQTYSLF>[F:SLF]AVCBASQTY & [M:SVW]PRINAT(0)<>7 & [M:SVW]PRINAT2(0)<>7
&    & !([M:STW]VCRTYP=32 & [M:STW]VCRLINORI<>0)    # 112836.n - and not a disassembly with an origin (assembly)
        If LOLDQTYSLF<=0
            If GTRACE<>""
                Call ECR_TRACE(mess(26,196,1)-":"-[M:STW]ITMREF-";"-[M:STW]STOFCY,1) From GESECRAN
            Else
                Call ERREUR(mess(26,196,1)-":"-[M:STW]ITMREF-";"-[M:STW]STOFCY) From GESECRAN
            Endif
            GOK = 0
            End
        Endif
        [F:SLF]AVCBASAMT  = arr([F:SLF]AVCBASAMT*[F:SLF]AVCBASQTY/LOLDQTYSLF, GRNDVAL)
        If GACTDECCST
# Issue 92701 - 2013-10-21 by CCC
#            For I=0 To GACTMAT-1
#                [F:SLF]AMATCST(I) = arr([F:SLF]AMATCST(I)*[F:SLF]AVCBASQTY/LOLDQTYSLF, GRNDVAL)
#            Next
#
#            [F:SLF]AOVEMATCST = arr([F:SLF]AOVEMATCST*[F:SLF]AVCBASQTY/LOLDQTYSLF, GRNDVAL)
#
#            For I=0 To GACTMAC-1
#                [F:SLF]AMACCST(I) = arr([F:SLF]AMACCST(I)*[F:SLF]AVCBASQTY/LOLDQTYSLF, GRNDVAL)
#            Next
#
#            [F:SLF]AOVEMACCST = arr([F:SLF]AOVEMACCST*[F:SLF]AVCBASQTY/LOLDQTYSLF, GRNDVAL)
#
#            For I=0 To GACTLAB-1
#                [F:SLF]ALABCST(I) = arr([F:SLF]ALABCST(I)*[F:SLF]AVCBASQTY/LOLDQTYSLF, GRNDVAL)
#            Next
#
#            [F:SLF]AOVELABCST = arr([F:SLF]AOVELABCST*[F:SLF]AVCBASQTY/LOLDQTYSLF, GRNDVAL)
#
#            [F:SLF]ASCOCST    = arr([F:SLF]ASCOCST*[F:SLF]AVCBASQTY/LOLDQTYSLF, GRNDVAL)
#            [F:SLF]AOVESCOCST = arr([F:SLF]AOVESCOCST*[F:SLF]AVCBASQTY/LOLDQTYSLF, GRNDVAL)
#
#            [F:SLF]AINVDTACST    = arr([F:SLF]AINVDTACST*[F:SLF]AVCBASQTY/LOLDQTYSLF, GRNDVAL)
            Call LOADVAR(LTABVAL, "[F:SLF]", 0, "A", [F:SLF]AVCBASQTY/LOLDQTYSLF, 0, 0) From STKVALECR
            Call REPVAL([F:SLF]AVCBASAMT,LTABVAL, GRNDVAL, LTABVAL) From STKVALECR
            Call LOADFIC("[F:SLF]", LTABVAL, "A", "CST", 1, 0) From STKVALECR
        Endif
    Else
        # Si sortie et 2ème méthode au PM lot, on utilise les valeurs V2xxx
        If PIO=2 & GACTVLT2 & [M:SVW]PRINAT2(0)=7
            If GACTDECCST

                For I=0 To GACTMAT-1
                    [F:SLF]AMATCST(I) += [M:SVW]V2MATCST(PIND*GACTMAT+I)*(-2*([M:STW]MAJCOD(PIND)="A")+1)*LSIGN
                Next

                For I=0 To GACTMAC-1
                    [F:SLF]AMACCST(I) += [M:SVW]V2MACCST(PIND*GACTMAC+I)*(-2*([M:STW]MAJCOD(PIND)="A")+1)*LSIGN
                Next

                For I=0 To GACTLAB-1
                    [F:SLF]ALABCST(I) += [M:SVW]V2LABCST(PIND*GACTLAB+I)*(-2*([M:STW]MAJCOD(PIND)="A")+1)*LSIGN
                Next

                [F:SLF]ASCOCST += [M:SVW]V2SCOTOT(PIND)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*LSIGN
                [F:SLF]AINVDTACST += [M:SVW]V2INVDTA(PIND)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*LSIGN
                [F:SLF]AOVEMATCST += [M:SVW]V2OVEMAT(PIND)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*LSIGN
                [F:SLF]AOVEMACCST += [M:SVW]V2OVEMAC(PIND)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*LSIGN
                [F:SLF]AOVELABCST += [M:SVW]V2OVELAB(PIND)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*LSIGN
                [F:SLF]AOVESCOCST += [M:SVW]V2OVESCO(PIND)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*LSIGN

            Endif
            [F:SLF]AVCBASAMT  += [M:SVW]AMTVAL2(PIND)*(-2*([M:STW]MAJCOD(PIND)="A")+1)*([M:STW]MAJTYP(PIND)=LMAJTYP)*LSIGN
        # Sinon on prend les valeurs d'ordre (si sortie au PMP, la valeur d'ordre contient la valeur au PMP)
# Issue 77372 - 2011-10-25 by CCC
#        Elsif [M:STW]TRSTYP=14 & PIO=1    # Si entrée transfert inter-sites, on prend les valeurs dans SVWD
        Elsif find([M:STW]TRSTYP,14,22) & PIO=1    # Si entrée transfert inter-sites, on prend les valeurs dans SVWD
            If GACTDECCST
                For I=0 To GACTMAT-1
                    [F:SLF]AMATCST(I) += [M:SVWD]OMATCST(PIND*GACTMAT+I)*(-2*([M:STW]MAJCOD(PIND)="A")+1)*([M:STW]MAJTYP(PIND)=LMAJTYP)*LSIGN
                Next

                [F:SLF]AOVEMATCST += [M:SVWD]OOVEMATTOT(PIND)*(-2*([M:STW]MAJCOD(PIND)="A")+1)*([M:STW]MAJTYP(PIND)=LMAJTYP)*LSIGN

                For I=0 To GACTMAC-1
                    [F:SLF]AMACCST(I) += [M:SVWD]OMACCST(PIND*GACTMAC+I)*(-2*([M:STW]MAJCOD(PIND)="A")+1)*([M:STW]MAJTYP(PIND)=LMAJTYP)*LSIGN
                Next

                [F:SLF]AOVEMACCST += [M:SVWD]OOVEMACTOT(PIND)*(-2*([M:STW]MAJCOD(PIND)="A")+1)*([M:STW]MAJTYP(PIND)=LMAJTYP)*LSIGN

                For I=0 To GACTLAB-1
                    [F:SLF]ALABCST(I) += [M:SVWD]OLABCST(PIND*GACTLAB+I)*(-2*([M:STW]MAJCOD(PIND)="A")+1)*([M:STW]MAJTYP(PIND)=LMAJTYP)*LSIGN
                Next

                [F:SLF]AOVELABCST += [M:SVWD]OOVELABTOT(PIND)*(-2*([M:STW]MAJCOD(PIND)="A")+1)*([M:STW]MAJTYP(PIND)=LMAJTYP)*LSIGN

                [F:SLF]ASCOCST    += [M:SVWD]OSCOTOT(PIND)*(-2*([M:STW]MAJCOD(PIND)="A")+1)*([M:STW]MAJTYP(PIND)=LMAJTYP)*LSIGN
                [F:SLF]AOVESCOCST += [M:SVWD]OOVESCOTOT(PIND)*(-2*([M:STW]MAJCOD(PIND)="A")+1)*([M:STW]MAJTYP(PIND)=LMAJTYP)*LSIGN

                [F:SLF]AINVDTACST += [M:SVWD]OINVDTA(PIND)*(-2*([M:STW]MAJCOD(PIND)="A")+1)*([M:STW]MAJTYP(PIND)=LMAJTYP)*LSIGN
            Endif
            [F:SLF]AVCBASAMT  += [M:SVWD]AMTORD(PIND)*(-2*([M:STW]MAJCOD(PIND)="A")+1)*([M:STW]MAJTYP(PIND)=LMAJTYP)*LSIGN
        Else
            If GACTDECCST
                For I=0 To GACTMAT-1
                    [F:SLF]AMATCST(I) += [M:SVW]OMATCST(PIND*GACTMAT+I)*(-2*([M:STW]MAJCOD(PIND)="A")+1)*([M:STW]MAJTYP(PIND)=LMAJTYP)*LSIGN
                Next

                [F:SLF]AOVEMATCST += [M:SVW]OOVEMATTOT(PIND)*(-2*([M:STW]MAJCOD(PIND)="A")+1)*([M:STW]MAJTYP(PIND)=LMAJTYP)*LSIGN

                For I=0 To GACTMAC-1
                    [F:SLF]AMACCST(I) += [M:SVW]OMACCST(PIND*GACTMAC+I)*(-2*([M:STW]MAJCOD(PIND)="A")+1)*([M:STW]MAJTYP(PIND)=LMAJTYP)*LSIGN
                Next

                [F:SLF]AOVEMACCST += [M:SVW]OOVEMACTOT(PIND)*(-2*([M:STW]MAJCOD(PIND)="A")+1)*([M:STW]MAJTYP(PIND)=LMAJTYP)*LSIGN

                For I=0 To GACTLAB-1
                    [F:SLF]ALABCST(I) += [M:SVW]OLABCST(PIND*GACTLAB+I)*(-2*([M:STW]MAJCOD(PIND)="A")+1)*([M:STW]MAJTYP(PIND)=LMAJTYP)*LSIGN
                Next

                [F:SLF]AOVELABCST += [M:SVW]OOVELABTOT(PIND)*(-2*([M:STW]MAJCOD(PIND)="A")+1)*([M:STW]MAJTYP(PIND)=LMAJTYP)*LSIGN

                [F:SLF]ASCOCST    += [M:SVW]OSCOTOT(PIND)*(-2*([M:STW]MAJCOD(PIND)="A")+1)*([M:STW]MAJTYP(PIND)=LMAJTYP)*LSIGN
                [F:SLF]AOVESCOCST += [M:SVW]OOVESCOTOT(PIND)*(-2*([M:STW]MAJCOD(PIND)="A")+1)*([M:STW]MAJTYP(PIND)=LMAJTYP)*LSIGN

                [F:SLF]AINVDTACST += [M:SVW]OINVDTA(PIND)*(-2*([M:STW]MAJCOD(PIND)="A")+1)*([M:STW]MAJTYP(PIND)=LMAJTYP)*LSIGN
            Endif
            [F:SLF]AVCBASAMT  += [M:SVW]AMTORD(PIND)*(-2*([M:STW]MAJCOD(PIND)="A")+1)*([M:STW]MAJTYP(PIND)=LMAJTYP)*LSIGN
        Endif

        # Issue 109924 - 2015-09-30 by CCC : add test (with sigma...) to calculate not absorbed amount only on the last movement
        If ([F:SLF]AVCBASQTY=0 & [F:SLF]AVCBASAMT<>0 | [F:SLF]AVCBASAMT<0)
&        & !sigma(PIND+1,[M:STW]NBLIG-1,[M:STW]LOT(indcum)=[M:STW]LOT(PIND) & [M:STW]SLO(indcum)=[M:STW]SLO(PIND) )
            If !clalev([F:TCM]) : Local File TABCOSTMET [TCM] : Endif
            Call GETTCM([F:SLF]ITMREF,[F:SLF]STOFCY,WTCM,LRET) From STKVAL
            If !LRET & !fstat
                LNUMVLT = -1
                If [F:TCM]ISSVLTCOD(0)=6
                    LNUMVLT = 0
                Endif
                If [F:TCM]ISSVLTCOD(1)=6
                    LNUMVLT = 1
                Endif
                If LNUMVLT>-1
                    PAMTDEV(LNUMVLT,0)=[F:SLF]AVCBASAMT
                    If GACTDECCST
                        I=1
                        For J=0 To GACTMAT-1
                            PAMTDEV(LNUMVLT,I)=[F:SLF]AMATCST(J)
                            Raz [F:SLF]AMATCST(J)
                            I+=1
                        Next
                        For J=0 To GACTMAC-1
                            PAMTDEV(LNUMVLT,I)=[F:SLF]AMACCST(J)
                            Raz [F:SLF]AMACCST(J)
                            I+=1
                        Next
                        For J=0 To GACTLAB-1
                            PAMTDEV(LNUMVLT,I)=[F:SLF]ALABCST(J)
                            Raz [F:SLF]ALABCST(J)
                            I+=1
                        Next
                        PAMTDEV(LNUMVLT,I)=[F:SLF]ASCOCST
                        Raz [F:SLF]ASCOCST
                        I+=1
                        PAMTDEV(LNUMVLT,I)=[F:SLF]AINVDTACST
                        Raz [F:SLF]AINVDTACST
                        I+=1
                        PAMTDEV(LNUMVLT,I)=[F:SLF]AOVEMATCST
                        Raz [F:SLF]AOVEMATCST
                        I+=1
                        PAMTDEV(LNUMVLT,I)=[F:SLF]AOVEMACCST
                        Raz [F:SLF]AOVEMACCST
                        I+=1
                        PAMTDEV(LNUMVLT,I)=[F:SLF]AOVELABCST
                        Raz [F:SLF]AOVELABCST
                        I+=1
                        PAMTDEV(LNUMVLT,I)=[F:SLF]AOVESCOCST
                        Raz [F:SLF]AOVESCOCST
                    Endif
                # Issue 92701 - 2013-10-21 by CCC
                Else
                    If GACTDECCST
                        Raz LTABVAL
                        Call LOADFIC("[F:SLF]", LTABVAL, "A", "CST", 0, 0) From STKVALECR
                    Endif
                Endif
            Endif
            [F:SLF]AVCBASAMT = 0
        Endif
    Endif

    # Issue 112077 - 2017-01-25 by ERMIL : Reset GRNDVAL to previous value
    GRNDVAL = RNDVAL_SAV

Return

######################################
# Variables nécessaires:
# Integer I pour boucle
# Decimal GRNDVAL initialisée avec le nb de décimales désiré
# !!!!! Utilisé dans STOMAJ30 & STKVALREG !!!!!
$UPDLOTAVC

    # Issue 112077 - 2017-01-25 by ERMIL : Use correct value for GRNDVAL to reduce rounding errors
    Local Decimal RNDVAL_SAV
    RNDVAL_SAV = GRNDVAL
    Call INIRNDVAL("STOLOTFCY","AVC") From STKVALECR

    # Issue 115583 - 2016-04-22 by ERMIL : Ensure Avg calculated if Qty > 0 on a receipt
    If [F:SLF]AVCBASQTY>0 & ([F:SLF]AVCBASAMT>0 | dim(PIO)<=0 | PIO=1)
    #If [F:SLF]AVCBASQTY>0 & [F:SLF]AVCBASAMT>0
        [F:SLF]AVC=arr([F:SLF]AVCBASAMT/[F:SLF]AVCBASQTY,GRNDVAL)

        If GACTDECCST
# Issue 92701 - 2013-10-21 by CCC
#            For I=0 To dim([F:SLF]AMATAVC)-1
#                [F:SLF]AMATAVC(I) = arr([F:SLF]AMATCST(I)/[F:SLF]AVCBASQTY,GRNDVAL)
#            Next
#            [F:SLF]AOVEMATAVC = arr([F:SLF]AOVEMATCST/[F:SLF]AVCBASQTY,GRNDVAL)
#
#            For I=0 To dim([F:SLF]AMACAVC)-1
#                [F:SLF]AMACAVC(I) = arr([F:SLF]AMACCST(I)/[F:SLF]AVCBASQTY,GRNDVAL)
#            Next
#            [F:SLF]AOVEMACAVC = arr([F:SLF]AOVEMACCST/[F:SLF]AVCBASQTY,GRNDVAL)
#
#            For I=0 To dim([F:SLF]ALABAVC)-1
#                [F:SLF]ALABAVC(I) = arr([F:SLF]ALABCST(I)/[F:SLF]AVCBASQTY,GRNDVAL)
#            Next
#            [F:SLF]AOVELABAVC = arr([F:SLF]AOVELABCST/[F:SLF]AVCBASQTY,GRNDVAL)
#
#            [F:SLF]ASCOAVC = arr([F:SLF]ASCOCST/[F:SLF]AVCBASQTY,GRNDVAL)
#            [F:SLF]AOVESCOAVC = arr([F:SLF]AOVESCOCST/[F:SLF]AVCBASQTY,GRNDVAL)
#
#            [F:SLF]AINVDTAAVC = arr([F:SLF]AINVDTACST/[F:SLF]AVCBASQTY,GRNDVAL)
            If dim(LTABVAL)<=0
                Local Decimal LTABVAL(1+GACTMAT+GACTLAB+GACTMAC+1+1+4)
            Endif
            Raz LTABVAL
            Call LOADVAR(LTABVAL, "[F:SLF]", 0, "A", 1/[F:SLF]AVCBASQTY, 0, 0) From STKVALECR
            Call REPVAL([F:SLF]AVC,LTABVAL, GRNDVAL, LTABVAL) From STKVALECR
            Call LOADFIC("[F:SLF]", LTABVAL, "A", "AVC", 1, 0) From STKVALECR
        Endif
    Endif

    # Issue 112077 - 2017-01-25 by ERMIL : Reset GRNDVAL to previous value
    GRNDVAL = RNDVAL_SAV

Return

################################################################
# MAJITH : Met à jour les champs YEARCPAMT,MONRCPAMT, YEAISSAMT et MONRCPAMT
################################################################
# Paramètres E : PIO        = 1:Entrée 2:Sortie
#                PAMTDEV    = Montant non absorbé dû au PMP ou la pile FIFO
#                PSEQ1, PSEQ2 = bornes MVTSEQ des mouvements concernés par l'écart non absorbé
################################################################
Subprog MAJITH(PIO, PAMTDEV, PAMTDEVITC, PSEQ1, PSEQ2)
Value Integer PIO
Value Decimal PAMTDEV(,)
Value Decimal PAMTDEVITC(,)
Value Integer PSEQ1
Value Integer PSEQ2

Local Integer LSIGN
Local Char    LMAJTYP(1)

Local Integer CCRET

If mod([M:SVW]FILUPD,16)<8
    End
Endif

#----- Pas de mise à jour si inventaire -----#
If [M:STW]TRSTYP=13 : End : Endif

# Issue 93525 - 2013-06-26 by CCC : Les retours de réceptions pour sous-traitance n'ont pas d'impact
# Issue 89623 - 2013-06-26 by CCC : Les réceptions pour sous-traitance n'ont pas d'impact
If find([M:STW]TRSTYP,16,32)
    End
Endif

#----- Pas de mise à jour si que des mouvements en attente ----#
If sigma(0,[M:STW]NBLIG-1,func STKVALMAJ.VALAUZ(indcum))=0
    End
Endif

# PE pour ne pas gérer l'historique cumuls article-site
GPE = 0
GPOINT = "MAJ_ITH"
Gosub ENTREE From EXEFNC
If GPE<>0  End  Endif
#---

If PIO=2
    LSIGN = -1
    If [M:STW]TRSTYP=14
        LMAJTYP = "C"
    Else
        LMAJTYP = "S"
    Endif
Else
    LSIGN = 1
    If [M:STW]TRSTYP=14
        LMAJTYP = "C"
    Else
        LMAJTYP = "E"
    Endif
Endif

If PIO=1 & [M:STW]TRSTYP=14
    LFCY = [M:STW]TRFFCY
    LAMT = sigma(0,[M:STW]NBLIG-1,[M:SVWD]AMTVAL(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(indcum)))*LSIGN
Else
    LFCY = [M:STW]STOFCY
    LAMT = sigma(0,[M:STW]NBLIG-1,[M:SVW]AMTVAL(indcum)*(-2*([M:STW]MAJCOD(indcum)="A")+1)*([M:STW]MAJTYP(indcum)=LMAJTYP & func STKVALMAJ.VALAUZ(indcum)))*LSIGN
Endif

If  LAMT = 0
& & PAMTDEV(0,0)=0
& & PAMTDEVITC(0,0)=0
& & sum([M:SVW]AMTDEV)=0
& & !(clalev([M:SVWD]) & sum([M:SVWD]AMTDEV)<>0)
& & !(GACTVLT2 & PAMTDEV(1,0)<>0)
& & !(GACTVLT2 & PAMTDEVITC(1,0)<>0)
    End
Endif

If  [F:ITH]STOFCY<>LFCY
& | [F:ITH]ITMREF<>[M:STW]ITMREF
& | [F:ITH]PERSTR >[M:STW]IPTDAT
& | [F:ITH]PEREND <[M:STW]IPTDAT
    Filter [ITH] Where STOFCY =LFCY
&                    & ITMREF =[M:STW]ITMREF
&                    & PERSTR<=[M:STW]IPTDAT
&                    & PEREND>=[M:STW]IPTDAT
    Readlock [F:ITH] First
Else
    #Readlock [F:ITH] Curr #121552.o MJH There is a look before this that changes the table pointer
    Readlock [F:ITH]= #121552.n MJH
Endif
Filter [ITH]
If fstat
    Call RSTA("ITH",LFCY+";"+[M:STW]ITMREF+";<"+[M:STW]IPTDAT) From GLOCK
    GOK = 0
    End
Endif

Case PIO
    When 1:
        [F:ITH]MONRCPAMT += LAMT
        [F:ITH]YEARCPAMT += LAMT
    When 2:
        [F:ITH]MONISSAMT += LAMT
        [F:ITH]YEAISSAMT += LAMT
Endcase

# Cumul des écarts non absorbés des mouvements
If PIO=1 & [M:STW]TRSTYP=14
    [F:ITH]AMTDEV += sum([M:SVWD]AMTDEV)
    If GACTVLT2
        [F:ITH]AMTDEV2+= sum([M:SVWD]AMTDEV2)
    Endif
Else
    [F:ITH]AMTDEV += sum([M:SVW]AMTDEV)
    If GACTVLT2
        [F:ITH]AMTDEV2+= sum([M:SVW]AMTDEV2)
    Endif
Endif



[F:ITH]AMTDEV += PAMTDEV(0,0)+PAMTDEVITC(0,0)
If GACTVLT2
    [F:ITH]AMTDEV2+= PAMTDEV(1,0)+PAMTDEVITC(1,0)
Endif
Call REWITH From STKLIB
If fstat
    Call RSTA("ITH",[F:ITH]STOFCY+";"+[F:ITH]ITMREF+";"+[F:ITH]PERSTR) From GLOCK
    GOK=0
    End
Endif

# Attention: (VARORD-VARVAL) a déjà été comptabilisé dans les STJ il ne faut donc pas le rajouter une 2ème fois à AMTDEV
If sigma(1,dim(PAMTDEV,2)-1,abs(PAMTDEV(0,indcum)))<>0
    # Issue 71240 & 78854 - 2012-06-13 by CCC
    #Call UPDSTJDEV(PAMTDEV, PSEQ1, PSEQ2) From STKVALMAJ
    Call UPDSTJDEV(PAMTDEV, [M:STW]ITMREF, LFCY, [M:STW]IPTDAT, [M:STW]VCRTYP, [M:STW]VCRNUM, [M:STW]VCRLIN, PSEQ1) From STKVALMAJ
    PSEQ1+=1
Endif

# Issue 84744 - 2013-04-08 by CCC
If  sigma(1,dim(PAMTDEVITC,2)-1,abs(PAMTDEVITC(0,indcum)))<>0
& | (GACTVLT2 & sigma(1,dim(PAMTDEVITC,2)-1,abs(PAMTDEVITC(1,indcum)))<>0)
    Call UPDSTJDEV2(PAMTDEVITC, "V", [M:STW]ITMREF, LFCY, [M:STW]IPTDAT, [M:STW]VCRTYP, [M:STW]VCRNUM, [M:STW]VCRLIN, PSEQ1) From STKVALMAJ
Endif

#--- Mise à jour des périodes suivantes ----#
LEXE = [F:ITH]FIYNUM
Case PIO
    When 1:
        Update [ITH] Where STOFCY = LFCY
&                        & ITMREF = [M:STW]ITMREF
&                        & PERSTR > [M:STW]IPTDAT
&                        & FIYNUM = LEXE
&                    With YEARCPAMT += LAMT
    When 2:
        Update [ITH] Where STOFCY = LFCY
&                        & ITMREF = [M:STW]ITMREF
&                        & PERSTR > [M:STW]IPTDAT
&                        & FIYNUM = LEXE
&                    With YEAISSAMT += LAMT
Endcase
If fstat
    GOK=0
    End
Endif

End

######################################################################
# FQ 84744
######################################################################
Subprog AMTDEVITC(PIO, PIND, PAMTDEV)
Value    Integer PIO
Value    Integer PIND
Variable Decimal PAMTDEV(,)

If [M:STW]IPTDAT=date$
    End
Endif

Local Char LFCY(GLONFCY)
Local Integer LSIGN, LRET
Local Char    LMAJTYP(1)
Local Decimal LPRI

If clalev([F:TCM])=0 : Local File TABCOSTMET [TCM] : Endif
If clalev([F:ITC])=0 : Local File ITMCOST [ITC] : Endif
If clalev([F:ITCO])=0 : Local File ITMCOST [ITCO] : Endif
If clalev([F:ITCN])=0 : Local File ITMCOST [ITCN] : Endif

# 1- tester qu'il faut faire le calcul
LFCY = [M:STW]STOFCY
# Issue 93040 - 2013-10-02 by CCC
#If [M:STW]TRFFCY<>"" & [M:STW]TRFFCY<>[M:STW]STOFCY
#    LSENS = func STKLIB.SENSTRS([M:STW]TRSTYP)
#    If find(LSENS,2,-1) | ([M:STW]TRSTYP=12 & [M:STW]VCRNUMORI2="")
#        LFCY = [M:STW]STOFCY
#    Elsif LSENS=1 | LSENS=-2
#        LFCY = [M:STW]TRFFCY
#    Endif
#Endif
    If PIO=2
        LSIGN = -1
        If [M:STW]TRSTYP=14
            LMAJTYP = "C"
        Else
            LMAJTYP = "S"
        Endif
    Else
        LSIGN = 1
        If [M:STW]TRSTYP=14
            LFCY = [M:STW]TRFFCY    # Issue 93040 - 2013-10-02 by CCC
            LMAJTYP = "C"
        Else
            LMAJTYP = "E"
        Endif
    Endif

If sigma(0,PIND-1,[M:STW]MAJTYP(indcum)=LMAJTYP
&                & [M:STW]ECCVALMAJ(PIND)=[M:STW]ECCVALMAJ(indcum)
&                & [M:STW]ECCVALMIN(PIND)=[M:STW]ECCVALMIN(indcum)
&                & func STKVALMAJ.VALAUZ(indcum))
    End
Endif

LQTY  = sigma(PIND,[M:STW]NBLIG-1,[M:STW]QTYSTUACT(indcum)
&                                 *(-2*([M:STW]MAJCOD(indcum)="A")+1)
&                                 *( [M:STW]MAJTYP(indcum)=LMAJTYP
&                                  & [M:STW]ECCVALMAJ(PIND)=[M:STW]ECCVALMAJ(indcum)
&                                  & [M:STW]ECCVALMIN(PIND)=[M:STW]ECCVALMIN(indcum)
&                                  & func STKVALMAJ.VALAUZ(indcum)))

# Issue 93040 - 2013-10-02 by CCC : consider sign of movement
LQTY *= LSIGN

Call GETTCM([M:STW]ITMREF,LFCY,GBIDC1,GBIDI1) From STKVAL    #GETTCM se positionne sur [F:TCM], nécessaire pour conditionner le mvt chgt valeur

# 2- Calculer la différence entre le coût du jour et celui à date des mouvements
For LNUMVLT=0 To GACTVLT2
    If find([F:TCM]ISSVLTCOD(LNUMVLT),1,2)
        Call GETPRISTD([M:STW]ITMREF, [M:STW]ECCVALMAJ(PIND), [M:STW]ECCVALMIN(PIND), LFCY, [M:STW]IPTDAT, 0, [F:TCM]ISSVLTCOD(LNUMVLT), LPRI, LRET) From STKVAL
        Call LOADVAR(PAMTDEV(LNUMVLT), "[F:ITC]", 0, "", -LQTY, 1, 0) From STKVALECR
        PAMTDEV(LNUMVLT,0) += LPRI*(-LQTY)
        Call GETPRISTD([M:STW]ITMREF, [M:STW]ECCVALMAJ(PIND), [M:STW]ECCVALMIN(PIND), LFCY, date$, 0, [F:TCM]ISSVLTCOD(LNUMVLT), LPRI, LRET) From STKVAL
        Call LOADVAR(PAMTDEV(LNUMVLT), "[F:ITC]", 0, "", LQTY, 1, 0) From STKVALECR
        PAMTDEV(LNUMVLT,0) += LPRI*LQTY
    Endif
Next

#MJH X3-47253. 2 July 2018
[M:STW]ITCSTRDAT = [F:ITC]ITCSTRDAT

End

#**
#* UPDQTYACT : Update [ITV]AVCBASQTY & [SLF]AVCBASQTY
#*             and update unit cost
#*             This is needed by potency change during QC
#*
#* @param PITM = product
#* @param PFCY = site
#* @param PLOT = lot number
#* @param PSLO = sub-lot number
#* @return 0 if OK - 1 if ITV update failed - 2 if SLF update failed
#*!
Funprog UPDQTYACT(PITM,PFCY,PLOT, PSLO)
Value Char PITM
Value Char PFCY
Value Char PLOT
Value Char PSLO

Local Decimal LSTOACTQTY
Local Char    REQ(250)
Local Decimal LTABVAL(GACTMAT+GACTMAC+GACTLAB+6+1)

Raz REQ, GBIDI1
Call ADDCRIT(REQ,GBIDI1,"","SELECT sum(QTYSTUACT_0)"," ") From GOBJSUB
Call ADDCRIT(REQ,GBIDI1,"","From STOCK"," ") From GOBJSUB
Call ADDCRIT(REQ,GBIDI1,"","Where ITMREF_0='"+PITM+"'"," ") From GOBJSUB
Call ADDCRIT(REQ,GBIDI1,"",  "and STOFCY_0='"+PFCY+"'"," ") From GOBJSUB
For (Decimal ACTQTY) From num$(GTYPDBA*2+1) Sql REQ As [SQLX]
    LSTOACTQTY = [SQLX]ACTQTY
Next

If [F:ITV]ITMREF<>PITM | [F:ITF]STOFCY<>PFCY
    Read [ITV]ITV0=PITM;PFCY
Endif
[F:ITV]AVCBASQTY=LSTOACTQTY
Gosub UPDAVC
Rewrite [ITV]
If fstat
    End 1
Endif

Raz REQ, GBIDI1
Call ADDCRIT(REQ,GBIDI1,"","SELECT sum(QTYSTUACT_0)"," ") From GOBJSUB
Call ADDCRIT(REQ,GBIDI1,"","From STOCK"," ") From GOBJSUB
Call ADDCRIT(REQ,GBIDI1,"","Where ITMREF_0='"+PITM+"'"," ") From GOBJSUB
Call ADDCRIT(REQ,GBIDI1,"",  "and STOFCY_0='"+PFCY+"'"," ") From GOBJSUB
If PLOT<>""
    Call ADDCRIT(REQ,GBIDI1,"",  "and LOT_0='"+PLOT+"'"," ") From GOBJSUB
    If PSLO<>""
        Call ADDCRIT(REQ,GBIDI1,"",  "and SLO_0='"+PSLO+"'"," ") From GOBJSUB
    Endif
Endif
For (Decimal ACTQTY) From num$(GTYPDBA*2+1) Sql REQ As [SQLX]
    LSTOACTQTY = [SQLX]ACTQTY
Next

If [F:SLF]ITMREF<>PITM | [F:SLF]STOFCY<>PFCY | [F:SLF]LOT<>PLOT | [F:SLF]SLO<>PSLO
    Read [F:SLF]SLF0=PITM;PLOT;PSLO;PFCY
Endif
[F:SLF]AVCBASQTY=LSTOACTQTY
Gosub UPDLOTAVC
Rewrite [F:SLF]
If fstat
    End 2
Endif

End 0

#**
#* UPDQTY_FIFO : adjust quantity of FIFO table with quantity in STOCK
#*               Proportion of quantity are kept
#*
#* @param PITM : Product
#* @param PFCY : Site
#*!
Subprog UPDQTY_FIFO(PITM, PFCY)
Value Char PITM
Value Char PFCY

    If clalev([F:TUN]) = 0 : Local File TABUNIT [TUN] : Endif
    If [F:ITM]ITMREF<>PITM
        Read [ITM]ITM0=PITM
    Endif
    If [F:ITM]STU<>[F:TUN]UOM
        Read [TUN]TUN0 = [F:ITM]STU : If fstat Raz [F:TUN] Endif
    Endif

    Local Decimal LSTPACTQTY, LSTOACTQTY
    Local Decimal LCUMREP, LCUMCLE
    Local Decimal LRND
    Local Char    REQ(250)
    LRND = 10^-[F:TUN]UOMDEC
    Raz REQ, GBIDI1
    Call ADDCRIT(REQ,GBIDI1,"","SELECT sum(QTYSTUACT_0)"," ") From GOBJSUB
    Call ADDCRIT(REQ,GBIDI1,"","From STOCOST"," ") From GOBJSUB
    Call ADDCRIT(REQ,GBIDI1,"","Where ITMREF_0='"+PITM+"'"," ") From GOBJSUB
    Call ADDCRIT(REQ,GBIDI1,"",  "and STOFCY_0='"+PFCY+"'"," ") From GOBJSUB
    For (Decimal ACTQTY) From num$(GTYPDBA*2+1) Sql REQ As [SQLX]
        LSTPACTQTY = [SQLX]ACTQTY
    Next
    Raz REQ, GBIDI1
    Call ADDCRIT(REQ,GBIDI1,"","SELECT sum(QTYSTUACT_0)"," ") From GOBJSUB
    Call ADDCRIT(REQ,GBIDI1,"","From STOCK"," ") From GOBJSUB
    Call ADDCRIT(REQ,GBIDI1,"","Where ITMREF_0='"+PITM+"'"," ") From GOBJSUB
    Call ADDCRIT(REQ,GBIDI1,"",  "and STOFCY_0='"+PFCY+"'"," ") From GOBJSUB
    For (Decimal ACTQTY) From num$(GTYPDBA*2+1) Sql REQ As [SQLX]
        LSTOACTQTY = [SQLX]ACTQTY
    Next
    If LSTPACTQTY <> LSTOACTQTY
        Raz LCUMREP, LCUMCLE
        For [STP] Where STOFCY=PFCY & ITMREF=PITM
            If [F:STP]QTYSTUACT<>0
                LCUMCLE += [F:STP]QTYSTUACT
                [F:STP]QTYSTUACT = LSTOACTQTY*LCUMCLE/LSTPACTQTY-LCUMREP
                If LRND<>0
                    [F:STP]QTYSTUACT = arr([F:STP]QTYSTUACT,LRND)
                Endif
                LCUMREP+=[F:STP]QTYSTUACT
                Rewrite [F:STP]
                If fstat
                    GOK=0
                    Break
                Endif
            Endif
        Next
    Endif
End

