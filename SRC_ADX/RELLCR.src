#<AdxTL>@(#)2.0.0.0 $Revision$
Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
Local Char OFONCTION(20)
OFONCTION=GFONCTION
If GFONCTION<>"RELLCR"
 GFONCTION="RELLCR" : Call AUTORIS From EXEFNC
Endif
GACTION = "RELLCR"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","RELLCR","DRELLCR",3,"") From GTRAITE
If OFONCTION<>GFONCTION
 GFONCTION=OFONCTION : Call AUTORIS From EXEFNC
Endif
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub FIN
 When "OUVRE_BATCH" : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "SORTIE"      : Gosub SORTIE
Endcase
Return

$INIT
Onerrgo CONTROLE From CONTROLE
If !clalev([M:RLA])  : Local Mask RAPLCRAUT [RLA] : Endif
Onerrgo
If GERREUR : GERREUR=0 : FIN=1 : Return : Endif
Return

$INIT_DIA
Local Char    DIR_FICBAN(GDIMFIC)
Local Char    MACHIN(GDIMFIC)                      : # Machine
Local Char    IRS(2)                               : # Separator
Local Char    OS(20)
Local Integer OK

Raz [M]

# Initialized with value of globale : GDIRBQR (initialized in GLOBVAR)
[M:DIA]VOLFIL = "["+GDIRBQR+"]"

Call LECMEMO("STD","[M:RLA]","lcr") From GMEMO
Raz [M:RLA]BAN
If dim([M:RLA]ZBAN)>0 : Raz [M:RLA]ZBAN : Endif

Onerrgo CHUT From CONTROLE
If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif
If !clalev([F:FCY])  : Local File FACILITY   [FCY]  : Endif
If !clalev([F:BAN])  : Local File BANK       [BAN]  : Endif
Onerrgo
If GERREUR : GERREUR=0 : Endif
Return

$CONTROLE
Return

$EXEC
Onerrgo ERREUR From CONTROLE
If !clalev([F:BES]) : Local File BILSTA  [BES] : Endif
Onerrgo
If GERREUR : GERREUR=0 : FIN=1 : Return : Endif

Local Char TAB_BAN(GLONBAN)(10)
Local Integer I

If !GSERVEUR
 Call TITAWI(BCRIT,GMESSAGE) From OBJDIV
 If [M]TYPEXP=1
  Call OUVRE_TRACE(GMESSAGE) From LECFIC
 Elsif [M]TYPEXP=2
  Call OUVRE_TRACE(GMESSAGE-[M:DIA]VOLFIL) From LECFIC
 Endif
 GMESSAGE=""
Endif

# Variables pour Poste Client
Local Char FICDON(GDIMFIC),URL(GDIMFIC)
Local Integer STAT

If [M]TYPEXP=1 : # Client
 Call COPSRV([M:DIA]FILNAM,[L]FICDON,STAT) From ORDSYS
 If STAT=1
  # Fichier non copié sur le poste client
  Call ERREUR(mess(164,141,1)) From GESECRAN
  FIN = 1 : Return
 Elsif STAT>1
  # Fichier inexistant
  Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
  FIN = 1 : Return
 Endif
Else
 [L]FICDON = [M:DIA]FILNAM
Endif

Call IMPORT([L]FICDON,[M:DIA]BAN,[M:DIA]FCY,[M:DIA]CPY,[L]TAB_BAN,OS)

# Rapprochement automatique
If [M:DIA]RAPLCRFLG=2
 For I=0 To [M:DIA]NB-1
  [M:RLA]FICPAY(I) = [M:DIA]FICPAY(I)
  [M:RLA]FICBAN(I) = [M:DIA]FICBAN(I)
  [M:RLA]NBRCAR(I) = [M:DIA]NBCAR(I)
  [M:RLA]FLG(I)    = [M:DIA]FLG(I)
  [M:RLA]TYPTYP(I) = [M:DIA]TYPTYP(I)
 Next I
 [M:RLA]NB=[M:DIA]NB
 For I=0 To 9
  If [L]TAB_BAN(I)<>""
   If I=0
    # Rapprochement automatique
    Call ECR_TRACE(mess(153,117,1),0) From GESECRAN
   Endif
   [M:RLA]BAN = [L]TAB_BAN(I)
   Gosub EXEC From RAPLCRAUT
  Else
   Break
  Endif
 Next I
Endif
Return

#######################################################
## Traitement de fin (lecture trace)
#######################################################
$FIN
If !GSERVEUR
 Call FERME_TRACE From LECFIC
 TRA=1
Endif
Return

$SORTIE
Return

###############################################
Subprog IMPORT(FICHIER,BAN,FCY,CPY,TAB_BAN,OS)
###############################################
Value Char    FICHIER() , BAN() , FCY() , CPY(), OS()
Variable Char TAB_BAN()()

Onerrgo ERREUR From CONTROLE
If !clalev([F:TFB1]) : Local File TABFILBAN [TFB1] : Endif
If !clalev([F:TFB2]) : Local File TABFILBAN [TFB2] : Endif
If !clalev([F:TFB3]) : Local File TABFILBAN [TFB3] : Endif
If !clalev([F:TFB4]) : Local File TABFILBAN [TFB4] : Endif
If !clalev([F:TCA])  : Local File TABCOUAFF [TCA]  : Endif
If !clalev([F:TPY])  : Local File TABPAYTYP [TPY]  : Endif
If !clalev([F:BES])  : Local File BILSTA    [BES]  : Endif
If !clalev([F:BES2]) : Local File BILSTA    [BES2] : Endif
If !clalev([F:BAN])  : Local File BANK      [BAN]  : Endif
If !clalev([F:CPY])  : Local File COMPANY   [CPY]  : Endif
Onerrgo
If GERREUR : GERREUR=0 : End : Endif

Local Char    COMPTREG(GLONANM), CODE(10), COMPL(GLONTPY), RECTYP(2)(1..4)
Local Schar   CTEST(1)
Local Char    INDCUR(1), INDIC(2), NUMSEQ(6), ZONE(255), MESSA(80), NUMAVIS(GLONVCR)
Local Char    PROCEN(6), CPT(11), BQ(5), GUI(5), CPTBAN(21), SEPDOS(1), FICIMP(20)
Local Integer OK, I, J, K, LONG, RANG, STAT, REL_ENCOURS, NUMLIG, IND_BAN, OKTCA
Local Integer MNTREL , MNTGEN , NBREL
Local Date    CREDAT
Local Char    DEVLED(GLONCUR)
Local Char    PLAN(GLONCOA),VLEG(GLONADI)

Call LECTURE("CPY",[L]CPY,"") From CONTOBJ
[L]VLEG=[F:CPY]LEG
Call SETMAINREF([L]CPY,GTYPGEN,GTYPANA) From CPTDIV
Call SETCUR(1,[L]CPY,DEVLED) From CPTDIV
Call LECPLAN([L]CPY,GTYPGEN,PLAN) From CPTDIV

# Recherche éventuel type de règlement
Raz [L]COMPL
For [TPY] Where STA7=2 & ENAFLG=2
 If [L]COMPL=""
  If dim([F:TPY]ACS)>0
   Call CONTEXE([F:TPY]ACS) From CPTSUB
   If !mkstat : OK=0 : Else mkstat=0 : GMESSAGE="" : OK=1 : Endif
  Else OK=1
  Endif
  If OK
   [L]COMPL=[F:TPY]PAYTYP
  Endif
 Else
  Raz [L]COMPL : Break
 Endif
Next

If [L]BAN<>""
 Call LECTURE("BAN",[L]BAN,"") From CONTOBJ
 [L]CPTBAN = left$([F:BAN]BIDNUM,21)
Endif

## Pourquoi ????
[L]CODE = "RELLCRBOR"
If [L]CODE=""
 # Fichier import non paramétré
 Call ECR_TRACE("RELLCRBOR"-mess(154,117,1),1) From GESECRAN
 End
Endif

# Somme des Longueurs d'un enregistrement
Raz [L]LONG

Filter [TFB1] Where COD=[L]CODE & BAN=[L]BAN & RECTYP=1 & LEG=[L]VLEG
If rowcount([TFB1]) <= 0
 Filter [TFB1] Where COD=[L]CODE & BAN=[L]BAN & RECTYP=1 & LEG=""
  If rowcount([TFB1]) <= 0
  Filter [TFB1] Where COD=[L]CODE & BAN="" & RECTYP=1 & LEG=[L]VLEG
  If rowcount([TFB1]) <= 0
   Filter [TFB1] Where COD=[L]CODE & BAN="" & RECTYP=1 & LEG=""
   If rowcount([TFB1]) <= 0 : Raz [TFB1] : Endif
  Endif
 Endif
Endif
For [TFB1]TFB0
 [L]LONG += [F:TFB1]LNG
Next
Filter [TFB1]

# Problème paramétrage fichier bancaire
[L]MESSA = mess(155,117,1)-[L]CODE

Filter [TFB1] Where COD=[L]CODE & BAN=[L]BAN & RECTYP=1 & LEG=[L]VLEG
Read [TFB1]TFB0 First
If fstat
 Filter [TFB1] Where COD=[L]CODE & BAN=[L]BAN & RECTYP=1 & LEG=""
 Read [TFB1]TFB0 First
 If [L]BAN <> "" & fstat
  Filter [TFB1] Where COD=[L]CODE & BAN="" & RECTYP=1 & LEG=[L]VLEG
  Read [TFB1]TFB0 First
  If fstat
   Filter [TFB1] Where COD=[L]CODE & BAN="" & RECTYP=1 & LEG=""
   Read [TFB1]TFB0 First
  Endif
 Endif
Endif
If fstat
 # Enregistrement en-tête
 Call ECR_TRACE([L]MESSA+"\"+mess(156,117,1),1) From GESECRAN
 End
Endif
[L]RECTYP(1) = [F:TFB1]FRM

Filter [TFB2] Where COD=[L]CODE & BAN=[L]BAN & RECTYP=2 & LEG=[L]VLEG
Read [TFB2]TFB0 First
If fstat
 Filter [TFB2] Where COD=[L]CODE & BAN=[L]BAN & RECTYP=2 & LEG=""
 Read [TFB2]TFB0 First
 If [L]BAN <> "" & fstat
  Filter [TFB2] Where COD=[L]CODE & BAN="" & RECTYP=2 & LEG=[L]VLEG
  Read [TFB2]TFB0 First
  If fstat
   Filter [TFB2] Where COD=[L]CODE & BAN="" & RECTYP=2 & LEG=""
   Read [TFB2]TFB0 First
  Endif
 Endif
Endif
If fstat
 # Enregistrement détail
 Call ECR_TRACE([L]MESSA+"\"+mess(157,117,1),1) From GESECRAN
 End
Endif
[L]RECTYP(2) = [F:TFB2]FRM

Filter [TFB3] Where COD=[L]CODE & BAN=[L]BAN & RECTYP=3 & LEG=[L]VLEG
Read [TFB3]TFB0 First
If fstat
 Filter [TFB3] Where COD=[L]CODE & BAN=[L]BAN & RECTYP=3 & LEG=""
 Read [TFB3]TFB0 First
 If [L]BAN <> "" & fstat
  Filter [TFB3] Where COD=[L]CODE & BAN="" & RECTYP=3 & LEG=[L]VLEG
  Read [TFB3]TFB0 First
  If fstat
   Filter [TFB3] Where COD=[L]CODE & BAN="" & RECTYP=3 & LEG=""
   Read [TFB3]TFB0 First
  Endif
 Endif
Endif
If fstat
 # Enregistrement total général
 Call ECR_TRACE([L]MESSA+"\"+mess(158,117,1),1) From GESECRAN
 End
Endif
[L]RECTYP(3) = [F:TFB3]FRM

Filter [TFB4] Where COD=[L]CODE & BAN=[L]BAN & RECTYP=4 & LEG=[L]VLEG
Read [TFB4]TFB0 First
If fstat
 Filter [TFB4] Where COD=[L]CODE & BAN=[L]BAN & RECTYP=4 & LEG=""
 Read [TFB4]TFB0 First
 If [L]BAN <> "" & fstat
  Filter [TFB4] Where COD=[L]CODE & BAN="" & RECTYP=4 & LEG=[L]VLEG
  Read [TFB4]TFB0 First
  If fstat
   Filter [TFB4] Where COD=[L]CODE & BAN="" & RECTYP=4 & LEG=""
   Read [TFB4]TFB0 First
  Endif
 Endif
Endif
If fstat
 # Enregistrement total relevé
 Call ECR_TRACE([L]MESSA+"\"+mess(159,117,1),1) From GESECRAN
 End
Endif
[L]RECTYP(4) = [F:TFB4]FRM

# Save the name of file imported
Gosub NOMFIC

Gosub IMPORTATION

Filter [TFB1]
Filter [TFB2]
Filter [TFB3]
Filter [TFB4]
End


$IMPORTATION
Openi FICHIER,0

# Caractères pourris du début
J=0 : Gosub LECTEST
While ascii(CTEST)<32 & !fstat
 J +=1 : Gosub LECTEST
Wend

Openi FICHIER,J
I = [L]LONG
Local Schar FILLER(I)
Gosub LECTURE

# Séparateur d'enregistrement
K=0 : Gosub LECTEST
While ascii(CTEST)<32 & !fstat
 K +=1 : Gosub LECTEST
Wend

Openi FICHIER,J
I = [L]LONG + K
Local Schar FILLER(I)
Gosub LECTURE

[L]OK=1
Raz [L]NBREL
While fstat=0
 Case left$([L]FILLER,2)
  When [L]RECTYP(1)          :# Emetteur
   Gosub TRT_TETE
   If [L]OK
    [L]INDIC = [L]RECTYP(1)
    If ![L]REL_ENCOURS : Gosub DEB_TR : Endif
   Endif
  When [L]RECTYP(2)          :# Détail
   If find([L]INDIC,[L]RECTYP(1),[L]RECTYP(2),[L]RECTYP(4)) :# OK
    [L]INDIC = [L]RECTYP(2)
    If ![L]REL_ENCOURS : Gosub DEB_TR : Endif
    If GOK
     Gosub TRT_DET
     If !GOK
      Rollback
      # Relevé non créé
      Call ECR_TRACE(mess(160,117,1),0) From GESECRAN
     Endif
    Endif
   Else
    If [L]INDIC="" :
     # Pas d'enregistrement émetteur
     Call ECR_TRACE(mess(161,117,1),1) From GESECRAN
    Elsif [L]INDIC=[L]RECTYP(3) :
     # Ligne détail après total général
     Call ECR_TRACE(mess(162,117,1),1) From GESECRAN
    Endif
    [L]OK=0
   Endif
  When [L]RECTYP(3)          :# Total général
   If find([L]INDIC,[L]RECTYP(1),[L]RECTYP(4))  :# OK
    [L]INDIC = [L]RECTYP(3)
    Gosub TRT_GEN
   Else
    If [L]INDIC=""
     # Pas d'enregistrement émetteur
     Call ECR_TRACE(mess(161,117,1),1) From GESECRAN
    Elsif [L]INDIC=[L]RECTYP(1)
     # Pas de lignes détail
     Call ECR_TRACE(mess(163,117,1),1) From GESECRAN
    Elsif [L]INDIC=[L]RECTYP(2)
     # Pas de total relevé
     Call ECR_TRACE(mess(164,117,1),1) From GESECRAN
    Elsif [L]INDIC=[L]RECTYP(3)
     # Plusieurs enregistrements total général
     Call ECR_TRACE(mess(165,117,1),1) From GESECRAN
    Endif
    [L]OK=0
   Endif
  When [L]RECTYP(4)          :# Total relevé
   If [L]INDIC=[L]RECTYP(2)  :# OK
    [L]INDIC = [L]RECTYP(4)
    Gosub TRT_REL
    [L]REL_ENCOURS=0
    If !GOK : Rollback
              # Relevé non créé
              Call ECR_TRACE(mess(160,117,1),0) From GESECRAN
    Else    : Commit
              If [L]IND_BAN<10
               I=find([F:BAN]BAN,[L]TAB_BAN)
               If I=0
                [L]TAB_BAN([L]IND_BAN) = [F:BAN]BAN
                [L]IND_BAN += 1
               Endif
              Endif
              [L]NBREL += 1
              # Création relevé xx Nombre de lignes =
              Call ECR_TRACE(mess(166,117,1)-[L]NUMAVIS-mess(167,117,1)+num$([L]NUMLIG-1),0) From GESECRAN
    Endif
   Else
    If [L]INDIC=""
     # Pas d'enregistrement émetteur
     Call ECR_TRACE(mess(161,117,1),1) From GESECRAN
    Elsif [L]INDIC=[L]RECTYP(1)
     # Pas de lignes détail
     Call ECR_TRACE(mess(163,117,1),1) From GESECRAN
    Elsif [L]INDIC=[L]RECTYP(3)
     # Total relevé après total général
     Call ECR_TRACE(mess(168,117,1),1) From GESECRAN
    Elsif [L]INDIC=[L]RECTYP(4)
     # Plusieurs enregistrements total relevé
     Call ECR_TRACE(mess(169,117,1),1) From GESECRAN
    Endif
    [L]OK=0
   Endif
  When Default
   # Code enregistrement inexistant
   Call ECR_TRACE(mess(170,117,1)-left$([L]FILLER,2),1) From GESECRAN
   [L]OK=0
 Endcase
 If ![L]OK : Break : Endif
 # Problème sur un enreg détail -> on passe au relevé suivant
 If !GOK & [L]REL_ENCOURS
  [L]REL_ENCOURS = 0
  Repeat
   Gosub LECTURE
  Until fstat | find(left$([L]FILLER,2),[L]RECTYP(4))
  [L]INDIC = [L]RECTYP(4)
 Endif
 Gosub LECTURE
Wend
If [L]REL_ENCOURS
 Rollback
 # Pas de total relevé
 Call ECR_TRACE(mess(164,117,1),1) From GESECRAN
 # Relevé non créé
 Call ECR_TRACE(mess(160,117,1),1) From GESECRAN
Endif
Return


$NOMFIC
# The separator is the same each time "/"
[L]SEPDOS = "/"
For I=len(FICHIER) To 1 Step -1
 If mid$(FICHIER,I,1)=[L]SEPDOS : Break : Endif
Next I
[L]FICIMP = right$(FICHIER,I+1)
Return


$DEB_TR
Call DEBTRANS From GLOCK
Trbegin [BES]
Gosub RECH_NUM
If !GOK
 Rollback : [L]OK=0
Endif
Return


# N° d'avis de domiciliation
$RECH_NUM
COMPTREG = ""
Call GETSOC([L]FCY) From DEVSUB
Call LECTCA(3,OKTCA) From SUBTCA
If OKTCA : COMPTREG = [F:TCA]CODNUM(3) : Endif
If COMPTREG="" : COMPTREG = "PY7" : Endif
Call NUMERO(COMPTREG,[L]FCY,datesyst,[L]COMPL,[L]NUMAVIS,[L]STAT) From SUBANM
If [L]STAT
 # Problème lors de la récupération du compteur
 Gosub MESSAGE From SUBANM
 Call ECR_TRACE(mess(104,117,1)-"("+COMPTREG+") : "+MESSA,1) From GESECRAN
 GOK=0 : Return
Endif
[L]NUMLIG=1
[L]REL_ENCOURS=1
Raz [L]MNTREL, [L]GUI, [L]CPT
Return


$LECTURE
Getseq 1, FILLER
# Fin de fichier
If mid$(FILLER,len(FILLER),1)="" : fstat = 4 : Endif
Return


$LECTEST
Getseq 1, CTEST
Return


# Enregistrement émetteur
$TRT_TETE
Raz MNTGEN
[L]RANG = 1
For [TFB1]TFB0
 [L]ZONE = mid$([L]FILLER,[L]RANG,[F:TFB1]LNG)
 Case [F:TFB1]FRM
  When "CREDAT" :# Date de création
   [L]CREDAT = gdat$(val(left$([L]ZONE,2)),val(mid$([L]ZONE,3,2)),val(mid$([L]ZONE,5,2)))
  When "INDCUR"    :# Devise
   If !find([L]ZONE," ","F","E")
    [L]OK = 0
    # Devise d'en-tête inconnue
    Call ECR_TRACE(mess(171,117,1)-[L]ZONE,1) From GESECRAN
   Else
    [L]INDCUR = [L]ZONE
   Endif
  When "PROCEN" :# Centre de traitement
   [L]PROCEN = [L]ZONE
  When "PABFCY"   :# Code etablissement domiciliataire
   If [L]BAN<>""
    If [L]ZONE<>left$([L]CPTBAN,5)
     [L]OK=0
     # Releve(s) concernant l'etablissement
     Call ECR_TRACE(mess(172,117,1)-[L]ZONE,1) From GESECRAN
    Endif
   Else
    [L]CPTBAN=[L]ZONE
   Endif
 Endcase
 If ![L]OK : Break : Endif
 [L]RANG += [F:TFB1]LNG
Next
Return


# Enregistrement détail
$TRT_DET
Raz [F:BES]
[L]RANG=1
For [TFB2]TFB0
 [L]ZONE = mid$([L]FILLER,[L]RANG,[F:TFB2]LNG)
 Case [F:TFB2]FRM
  When "NUMSEQ" :# Numero sequentiel
   [L]NUMSEQ = [L]ZONE
  When "NAMCDT" :# Nom du tireur
   [F:BES]NAMCDT = [L]ZONE
  When "PAYDAT" :# Date de règlement
   [F:BES]PAYDAT = gdat$(val(left$([L]ZONE,2)),val(mid$([L]ZONE,3,2)),val(mid$([L]ZONE,5,2)))
  When "SENLEA" :# Chef de file émetteur
   [F:BES]SENLEA = [L]ZONE
  When "SENFCY" :# Etablissement émetteur
   [F:BES]SENFCY = [L]ZONE
  When "SENCOT" :# Guichet émetteur
   [F:BES]SENCOT = [L]ZONE
  When "CDTACC" :# Compte du cédant
   [F:BES]CDTACC = [L]ZONE
  When "DUDDAT" :# Date d'échéance
   [F:BES]DUDDAT = gdat$(val(left$([L]ZONE,2)),val(mid$([L]ZONE,3,2)),val(mid$([L]ZONE,5,2)))
  When "PABFCY" :# Code établissement domiciliataire
   [L]BQ = [L]ZONE
   If [L]BQ<>left$([L]CPTBAN,5)
    # Etablissement domiciliataire
    GOK=0 : [L]MESSA = mess(173,117,1)-[L]BQ
    Gosub ERR_DET
   Endif
  When "PABCOT" :# Code guichet domiciliataire
   If [L]GUI<>""
    If [L]GUI<>[L]ZONE
     # Guichet domiciliataire
     GOK=0 : [L]MESSA = mess(174,117,1)-[L]ZONE
     Gosub ERR_DET
    Endif
   Else
    [L]GUI = [L]ZONE
   Endif
  When "DEBACC"    :# Numéro compte du tire
   If [L]CPT<>""
    If [L]CPT<>[L]ZONE
     # Compte du tiré
     GOK=0 : [L]MESSA = mess(175,117,1)-[L]ZONE
     Gosub ERR_DET
    Endif
   Else
    [L]CPT = [L]ZONE
    Gosub LECBANK
   Endif
  When "ACP"       :# Code acceptation
   If !find([L]ZONE,"0","1","2")
    # Code acceptation
    [L]MESSA = mess(176,117,1)-[L]ZONE
    Gosub ERR_DET
   Endif
   [F:BES]ACP = val([L]ZONE)
  When "REFDEB"    :# Référence du tiré
   [F:BES]REFDEB = [L]ZONE
  When "REFCDT"    :# Référence du tireur
   [F:BES]REFCDT = [L]ZONE
  When "INDCUR"    :# Indice monnaie d'origine
   [F:BES]INDCUR = [L]ZONE
  When "AMT"    :# Montant initial
   If val([L]ZONE)=0
    # Montant nul
    [L]MESSA = mess(177,117,1)
    Gosub ERR_DET
   Else
    Case [L]INDCUR
     When " ","F"  :# Montants en Franc
      Case [F:BES]INDCUR
       When "E"
        [F:BES]CUR = GEURO
        Call CONVERT(DEVLED,GEURO,"",0,datesyst,val([L]ZONE)/100,[F:BES]AMTCUR,STAT)
&            From TRTDEV
       When "F"
        [F:BES]CUR = DEVLED
        [F:BES]AMTCUR = val([L]ZONE)/100
       When Default  :# Devise d'origine inconnue
        # A REVOIR : pour les tests
        [F:BES]CUR    = DEVLED
        [F:BES]AMTCUR = val([L]ZONE)/100
      Endcase
     When "E"  :# Montants en Euro
      Case [F:BES]INDCUR
       When "E"
        [F:BES]CUR = GEURO
        [F:BES]AMTCUR = val([L]ZONE)/100
       When "F","2","3","4","6","7","8"
        [F:BES]CUR = DEVLED
        Call CONVERT(GEURO,DEVLED,"",0,datesyst,val([L]ZONE)/100,[F:BES]AMTCUR,STAT)
&            From TRTDEV
        If [F:BES]INDCUR<>"F"
         [F:BES]AMTCUR += (val([F:BES]INDCUR)-5)
        Endif
       When Default  :# Devise d'origine inconnue
        # A REVOIR : pour les tests
        [F:BES]CUR = DEVLED
        [F:BES]AMTCUR = val([L]ZONE)/100
      Endcase
    Endcase
    [F:BES]AMT = val([L]ZONE)/100
    [L]MNTREL += val([L]ZONE)
   Endif
  When "CREDAT"
   [F:BES]CREDAT = gdat$(val(left$([L]ZONE,2)),val(mid$([L]ZONE,3,2)),val(mid$([L]ZONE,5,2)))
  When "REFPRE"
   [F:BES]REFPRE = [L]ZONE
  When "PABNAM"
   [F:BES]PABNAM = [L]ZONE
  When "ENTDAT"
   [F:BES]ENTDAT = gdat$(val(left$([L]ZONE,2)),val(mid$([L]ZONE,3,2)),val(mid$([L]ZONE,5,2)))
  When "PABORD"
   [F:BES]PABORD = [L]ZONE
 Endcase
 If !GOK : Break : Endif
 [L]RANG += [F:TFB2]LNG
Next
If !GOK : Return : Endif
[F:BES]FRMNUM = [L]NUMAVIS
[F:BES]LIN    = [L]NUMLIG
[F:BES]BAN    = [F:BAN]BAN
[F:BES]CPY    = [L]CPY
[F:BES]FCY    = [L]FCY
[F:BES]PABFLG = 1
[F:BES]FLGANO = 1
[F:BES]IMPFIL = [L]FICIMP
[F:BES]IMPDAT = datesyst
Write [BES]
If fstat
 GOK=0 : Call FSTA("BES") From GLOCK : Return
Endif
[L]NUMLIG+=1
Return


$ERR_DET
If GOK<1
 # Enregistrement détail
 Call ECR_TRACE(mess(157,117,1)-[L]NUMSEQ-":"-[L]MESSA,1) From GESECRAN
Else
 # Enregistrement détail
 Call ECR_TRACE(mess(157,117,1)-[L]NUMSEQ-":"-[L]MESSA,0) From GESECRAN
Endif
Return


# Enregistrement total relevé
$TRT_REL
Raz [F:BES]
[L]RANG=1
For [TFB4]TFB0
 [L]ZONE = mid$([L]FILLER,[L]RANG,[F:TFB4]LNG)
 Case [F:TFB4]FRM
  When "NUM"    :# Numéro de relevé
   [F:BES]NUM = [L]ZONE
  When "VALDAT" :# Date de valeur
   [F:BES]VALDAT = gdat$(val(left$([L]ZONE,2)),val(mid$([L]ZONE,3,2)),val(mid$([L]ZONE,5,2)))
  When "AMT"
   [F:BES]AMT = val([L]ZONE)/100
   # Vérification du montant du relevé
   If [L]MNTREL<>val([L]ZONE)
    # Montant relevé ... différent somme détails
    Call ECR_TRACE(mess(178,117,1)-[F:BES]NUM-"("+[L]ZONE+")"-mess(179,117,1)-num$([L]MNTREL),1) From GESECRAN
   Endif
   [L]MNTGEN += val([L]ZONE)
  When "PAYDAT"   :# Date de reglement
   [F:BES]PAYDAT = gdat$(val(left$([L]ZONE,2)),val(mid$([L]ZONE,3,2)),val(mid$([L]ZONE,5,2)))
  When "ADELEA"
   [F:BES]ADELEA = [L]ZONE
  When "PABFCY"
   [F:BES]PABFCY = [L]ZONE
  When "PABCOT"
   [F:BES]PABCOT = [L]ZONE
  When "DEBACC"
   [F:BES]DEBACC = [L]ZONE
  When "NAMDEB"
   [F:BES]NAMDEB = [L]ZONE
  When "INSDAT"
   [F:BES]INSDAT = gdat$(val(left$([L]ZONE,2)),val(mid$([L]ZONE,3,2)),val(mid$([L]ZONE,5,2)))
 Endcase
 If !GOK : Break : Endif
 [L]RANG += [F:TFB4]LNG
Next
If !GOK : Return : Endif
# Vérification que le relevé n'a pas été déjà importé
Filter [BES2] Where CREDAT=[L]CREDAT & PROCEN=[L]PROCEN
&      & NUM=[F:BES]NUM & AMTCUR=[F:BES]AMTCUR & LIN=0
Look [BES2] First
Filter [BES2]
If fstat=0
 # Relevé déjà importé
 Call ECR_TRACE(mess(180,117,1)-[F:BES]NUM,1) From GESECRAN
 GOK=0 : Return
Endif
[F:BES]FRMNUM = [L]NUMAVIS
[F:BES]LIN    = 0
[F:BES]PROCEN = [L]PROCEN
[F:BES]CREDAT = [L]CREDAT
[F:BES]INDCUR = [L]INDCUR
Case [L]INDCUR
 When " ","F" : [F:BES]CUR = DEVLED
 When "E"     : [F:BES]CUR = GEURO
Endcase
[F:BES]BAN    = [F:BAN]BAN
[F:BES]CPY    = [L]CPY
[F:BES]FCY    = [L]FCY
[F:BES]FLGEXP = 1
[F:BES]IMPFIL = [L]FICIMP
[F:BES]IMPDAT = datesyst
Write [BES]
If fstat
 GOK=0 : Call FSTA("BES") From GLOCK : Return
Endif
Raz [L]MNTREL
Return


# Enregistrement total général
$TRT_GEN
[L]RANG=1
For [TFB3]TFB0
 [L]ZONE = mid$([L]FILLER,[L]RANG,[F:TFB3]LNG)
 Case [F:TFB3]FRM
  When "AMT"
   # Vérification du montant général
   If [L]MNTGEN<>val([L]ZONE)
    # Montant général ... différent somme relevés
    Call ECR_TRACE(mess(181,117,1)-"("+[L]ZONE+")"-mess(182,117,1)-"("+num$([L]MNTGEN)+")",0) From GESECRAN
   Endif
 Endcase
 [L]RANG += [F:TFB3]LNG
Next
Return


$LECBANK
If [L]BAN = ""
 Filter [BAN] Where left$(BIDNUM,21)=[L]BQ+[L]GUI+[L]CPT
Else
 Filter [BAN] Where BAN=[L]BAN & left$(BIDNUM,21)=[L]BQ+[L]GUI+[L]CPT
Endif
Read [BAN]BAN0 First
If !fstat
 If [F:BAN]CPY<>[L]CPY
  # Banque ... Société
  GOK=0 : [L]MESSA = mess(1,653,1)-[F:BAN]BAN-mess(2,116,1)-[F:BAN]CPY
  Gosub ERR_DET
 Elsif [L]BAN<>"" & [L]CPTBAN<>[L]BQ+[L]GUI+[L]CPT
  # Banque
  [L]MESSA = mess(1,653,1)-[F:BAN]BAN
  Gosub ERR_DET
 Endif
Else
 # Rib du relevé inexistant dans fichier BANK
 GOK=0 : [L]MESSA = mess(5,120,1)-[L]BQ+[L]GUI+[L]CPT
 Gosub ERR_DET
Endif
Filter [BAN]
Return


##################################
## Etiquettes de l'écran RELLCR ##
##################################

Subprog AM_BAN(VALEUR)
Variable Char     VALEUR
If VALEUR="" : End : Endif
Call LECTURE("BAN",VALEUR,"") From CONTOBJ
[M:DIA]CPY = [F:BAN]CPY
[M:DIA]FCY = [F:BAN]FCY
End

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
If [M:DIA]BAN<>"" : mkstat=2 : Endif
End

Subprog AP_RAPLCRFLG(VALEUR)
Variable Integer VALEUR
Local Integer I
For I=0 To [M:DIA]NB-1
  [M:DIA]FICPAY(I) = [M:RLA]FICPAY(I)
  [M:DIA]FICBAN(I) = [M:RLA]FICBAN(I)
  [M:DIA]NBCAR(I) = [M:RLA]NBRCAR(I)
  [M:DIA]FLG(I)    = [M:RLA]FLG(I)
  [M:DIA]TYPTYP(I) = [M:RLA]TYPTYP(I)
Next I
[M:DIA]NB=[M:DIA]NB
End

Subprog D_INI(VALEUR)
Variable Decimal VALEUR
# Initialiser par défaut le serveur
[M]TYPEXP=2
Call AM_TYPEXP([M]TYPEXP)
End

Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat = 2 : End
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Raz [DIA]VOLFIL, [DIA]FILNAM
 Grizo [M]VOLFIL
 End
Else
 [M:DIA]VOLFIL = "["+GDIRBQR+"]"
 Actzo [M]VOLFIL
 Affzo [M]VOLFIL
Endif
End

Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
#Control that the file exists :
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FILNAM,E_TYPE_FILEREAD,GMESSAGE)
End

