#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$

######################################################################################################
# Project       : Australian GST report
# File          : DCLVATAUSPER
# Version       : 1.0
# Authors       : A. Gregolec
# Creation Date : 2018-03-03
######################################################################################################
# Module        : Finance
# Description   : Data collection of the Australian GST-Report based on GST-Groups and periods
######################################################################################################
# Updates       :
# Date          | Author | Version | Description
# 2018-03-09    | Bader  | 2018.R4 | FINALIZEPERIOD: Parameter PERIOD Char > Integer & rename CODGSTPER1 to CODGSTPER
# 2018-04-06    | angre  | 2018.R4 | Additional parameter when calling DCLVATDEB from DCLVATBOXDEB
# 2018-04-06    | angre  | 2018.R4 | X3-83077 log - WARNING ON TEMPORARY JOURNALS
######################################################################################################

$ACTION
Case ACTION
 When "INIT" : Gosub INIT
 When "EXEC" : Gosub GSTPERIODREP
Endcase
Return

##################################################################
# Initalize tables and variables
#################################################################
$INIT
  # if report generation is started for a member company, PARAM(1) contains the membercompany
  Local Char MEMCPY(GLONCPY) : [L]MEMCPY = PARAM(1)
  Gosub OPEN_FIL
  Gosub DECLARE

Return


$OPEN_FIL
If !clalev([F:GSTPERD]): Local File GSTPERD      [GSTPERD] : Endif
If !clalev([F:DLVB])   : Local File DCLVATBOXH   [DLVB]   : Endif
If !clalev([F:DLVB1])  : Local File DCLVATBOXH   [DLVB1]  : Endif
If !clalev([F:DLVBD])  : Local File DCLVATBOXDBD [DLVBD]  : Endif
If !clalev([F:DLVBD1]) : Local File DCLVATBOXDBD [DLVBD1] : Endif
If !clalev([F:VTB])    : Local File VATBOX       [VTB]    : Endif
If !clalev([F:VTD])    : Local File VATBOXD      [VTD]    : Endif
If !clalev([F:FGR])    : Local File FACGROUP     [FGR]    : Endif
If !clalev([F:CPY])    : Local File COMPANY      [CPY]    : Endif
If !clalev([F:FCY])    : Local File FACILITY     [FCY]    : Endif
If !clalev([F:TCA])    : Local File TABCOUAFF    [TCA]    : Endif
If !clalev([F:GTE])    : Local File GTYPACCENT   [GTE]    : Endif
If !clalev([F:TVT])    : Local File TABVAT       [TVT]    : Endif
If !clalev([F:TCU])    : Local File TABCUR       [TCU]    : Endif
If !clalev([F:HAE])    : Local File GACCENTRY    [HAE]    : Endif
If !clalev([F:HAE2])   : Local File GACCENTRY    [HAE2]   : Endif
If !clalev([F:DAE])    : Local File GACCENTRYD   [DAE]    : Endif
If !clalev([F:DAE2])   : Local File GACCENTRYD   [DAE2]   : Endif
If !clalev([F:TRA])    : Local File TABRATVAT    [TRA]    : Endif
If !clalev([F:GAC])    : Local File GACCOUNT     [GAC]    : Endif
If !clalev([F:GAC2])   : Local File GACCOUNT     [GAC2]   : Endif
If !clalev([F:TVTD])   : Local File LEGTVTDEB    [TVTD]   : Endif

If clalev([F:AOE])=0  : Local File AOBJEXT    [AOE]  : Endif
If clalev([F:AOD])=0  : Local File AOBJEXTD   [AOD]  : Endif
If clalev([F:AOR])=0  : Local File AOBJEXTR   [AOR]  : Endif
If clalev([F:ATB])=0  : Local File ATABLE     [ATB]  : Endif
If clalev([M:AOE0])=0 : Local Mask AOE0       [AOE0] : Endif
If clalev([M:AOE1])=0 : Local Mask AOE1       [AOE1] : Endif
If clalev([M:AOE2])=0 : Local Mask AOE2       [AOE2] : Endif
If clalev([M:EXP1])=0 : Local Mask EXPOBJ     [EXP1] : Endif : # to load the template
If clalev([M:EXP2])=0 : Local Mask EXPOBJ2    [EXP2] : Endif : # Ecran référence (export + export enchaîné)


Return

$DECLARE
Local Integer  I, ERR_STOP, OK
Local Integer  NBLOCK                     : # Number of locks
Local Char     TSYMBOLE(50)(1..GNBSITE)   : # Lock
Global Integer GNUMRPT                    : # Period number used to print VAT declaration
Local Integer  INDCPY, NBRLEG             : # Number of companies that belong to a group- Number of legislations
Local Char     TABCPY(GLONCPY)(1..GNBSOC) : # List of the legal companies that belong to a group
Local Char     TABLEG(GLONADI)(1..GNBSOC) : # List of the legislations of the legal companies that belong to a group
Local Char     WLEG(GLONADI)              : # Current legislation of the company
Local Char     CURLEG(GLONADI)            : # Legislation used to select the right record in the VATBOX table

Local Integer  NBTYPDEB                   : # Number of document types (GTE) defined with tax/debits
Filter [GTE] Where VAT=2
NBTYPDEB = rowcount([F:GTE])
Filter [GTE]
Local Char     TTYPDEB(GLONGTE)(1..NBTYPDEB) # List of of document types (GTE) defined with tax/debits

Local Char     OPT(1)                     : # Take into account the "1"=accounting date or "2"=source document date
Local Char     CRITERE(250)               : # Criteria
Local Char     TCOA(GLONCOA)              : # Chart of account
Local Char     DEVLED(GLONCUR)            : # Currency of the general main ledger
Local Char     MESSAGE(250)               : # error message in case export fails

Local Integer  SAVGPARTRABTC              : # The value of the GPARTRABTC parameter is saved
Return




######################################################################################
$READ_PARAM

GNUMRPT = [M:GSTPH]CODGSTPER
CURLEG = "AUS"
Call LEGCPY(TABCPY,NBRLEG,TABLEG) From CPTDIV
If NBRLEG=1
 WLEG   = TABLEG(1)
 Gosub LECPARAM_GTE
Endif

Return

#############################################################################
$LECPARAM_GTE
# Load the list of the  document types (GTE) defined with tax on issue
Filter [GTE] Where LEG=[L]WLEG | LEG="" Order By Key CLE=TYP Asc ; LEG Desc
Raz NBTYPDEB, TTYPDEB
For [GTE]CLE(1)
 If [F:GTE]VAT = 2
  NBTYPDEB += 1
  TTYPDEB(NBTYPDEB) = [F:GTE]TYP
 Endif
Next
Filter [GTE]
Return






#########################################################################################
# Start generating the report
#########################################################################################
$GSTPERIODREP
  Local Tinyint ERRCOD
  Local Char LEG(3) : LEG = "AUS"
  Local Char CUR(3) : CUR = "AUD"
  Local Char COMP(GLONCPY) : COMP = ""
  Call CHECKGSTGROUPCOMPANYMEMBER(LEG, CUR ,COMP, 1, 1, ERRCOD) From GSTAUSLIB # check if every company for a given legislation (in our case "AUS") and currrency (AUD) is member of an active
  If ERRCOD : Return : Endif


  #angre US X3-82839
 Call OUVRE_TRACE(mess(71,107,1)) From LECFIC
 Call ECR_TRACE(mess(71,107,1),0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 ## Display the criteria in the log file
 Call ECR_TRACE(mess(14,103,1)-":",0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 Call ECR_TRACE(mess(38,114,1)-":"-num$([M:GSTPH]CODGSTPER),0) From GESECRAN
 Call ECR_TRACE(mess(50,7704,1)-":"-[M:GSTPH]CODGSTGRP,0) From GESECRAN
 Call ECR_TRACE(mess(14,119,1)-":"-format$(GFMDAT,[M:GSTPH]DATSTR)-mess(95,100,1)-format$(GFMDAT,[M:GSTPH]DATEND),0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN



  Gosub READ_PARAM
  Call DEBTRANS From GLOCK
  Gosub TR_DELDLV
  If GOK<1 : Return : Endif
  Gosub DECLARATION
  #trace
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Return


##** #############################################################################################
##*  Call the report with the given reportnumber which is the period code
##*! #############################################################################################
$GENRPT

Local Integer NBPAR1
Local Char    TBPAR1(20)(1..10) , TBVAL1(50)(1..10)
Local Char    NAM_PRT(GLONADP)

# Print the report if the declaration is run in simulation mode or in actual mode and no error occurs
 If GSERVEUR=1
  # Batch
  NBPAR1 = 0
  NBPAR1 +=1 : TBPAR1(NBPAR1) = "numrpt"        : TBVAL1(NBPAR1) = num$(GNUMRPT)
  NBPAR1 +=1 : TBPAR1(NBPAR1) = "detail_piece"  : TBVAL1(NBPAR1) = num$(2)
  NBPAR1 +=1 : TBPAR1(NBPAR1) = "impselections" : TBVAL1(NBPAR1) = num$(1)

   Call PARAML("","VATRPTBAT",NAM_PRT) From ADOVAL
#  Endif
  Call ETAT("DCLVATDEBBEL1",NAM_PRT,"",0,"",TBPAR1,TBVAL1) From AIMP3
 Else
  Call IMPRIME("DCLVATDEBBEL1","DCLVATBEL") From ETAT
 Endif

End



# We begin to delete the simulations that matches the execution criteria
$TR_DELDLV
GOK = 1
  Trbegin [DLVB],[DLVBD]

  Filter [F:GSTPERD] Where [F:GSTPERD]GSTMEMSTA = 1 and [F:GSTPERD]CODGSTPER = [M:GSTPH]CODGSTPER
  For [F:GSTPERD]
     Delete [DLVB] Where NUMRPT=[M:GSTPH]CODGSTPER & VATFNC="DCLVATAUS" and CPY = [F:GSTPERD]CPY
     If fstat=1 | fstat>5
      GOK = 0 : Call RSTA("DLVB",[F:GSTPERD]CPY-num$([M:GSTPH]CODGSTPER)) From GLOCK : Break
     Endif
     # To check that the request has deleted a DCLVATAUS recording and not a DCLVATFRA recording
     If adxdlrec>0
      Delete [DLVBD] Where NUMRPT=[M:GSTPH]CODGSTPER and CPY = [F:GSTPERD]CPY
      If fstat=1 | fstat>5
      GOK = 0 : Call RSTA("DLVBD",[F:GSTPERD]CPY-num$([M:GSTPH]CODGSTPER)) From GLOCK : Break
      Else
        For [HAE] Where NUMDCL = [M:GSTPH]CODGSTPER and CPY = [F:GSTPERD]CPY
          Raz [F:HAE]NUMDCL
          Rewrite [F:HAE]
          If fstat
           GOK  = 0 : FIN = 0 : ERRCOD = 3 :Call FSTA("HAE") From GLOCK
           Break
          Endif
          Update [F:DAE] Where [F:DAE]NUM = [F:HAE]NUM  With [F:DAE]AMTVAT = 0 # angre US X3-82831
          If fstat
            GOK  = 0 : FIN = 0 : ERRCOD = 4 :Call FSTA("DAE") From GLOCK
            Break
          Endif
        Next
      Endif
     Endif
    If GOK<1 : Goto AB_TR : Endif
  Next
  Filter [F:GSTPERD]
  Commit
Return
$AB_TR
Rollback
Return

######################################################################################
# start vat declaration for the selected gst period
######################################################################################
$DECLARATION
  Local Integer SIMUL : SIMUL = 2
  Local Date DATSTRP
  Gosub TR_DELDLV
 # Only VAT boxes created in the VATBOXD table (<=> that match TYPBOX=2 or TYPBOX=4)
Link [VTD] With [VTB]VTB1~=[F:VTD]VATFNC;[F:VTD]LEG;[F:VTD]VATBOX
& As [LNK_V]
& Where VATFNC="DCLVATAUS" & LEG="AUS"

  ERR_STOP = 0

  [L]CRITERE="1=1"

#link period detail table with company table
Filter [F:GSTPERD] Where CODGSTPER = [M:GSTPH]CODGSTPER
Link [F:GSTPERD] With
&  [F:CPY]CPY0 = [F:GSTPERD]CPY
& As [LNK_PER]
& Where [F:GSTPERD]GSTMEMSTA = 1


If [M:GSTPH]FLGPRE = 2
  DATSTRP = [M:GSTPH]PREDAT
Else
  DATSTRP = [M:GSTPH]DATSTR
Endif

#loop throug companies of gst period
For [LNK_PER]
  TABCPY(1) = [F:CPY]CPY
  Gosub READ_PARAM
 # Accounting date or  source document date ?
 Call PARAML([F:CPY]CPY,"DCLVATDAT",OPT) From ADOVAL

 # Load document type and tax code that are available for the legislation of the company
 If NBRLEG>1 & WLEG<>[F:CPY]CPYLEGFLG
  WLEG=[F:CPY]LEG
  Gosub LECPARAM_GTE
 Endif

 # general ledger
 Call SETCUR(1,[F:CPY]CPY,DEVLED)From CPTDIV # Runs Call SETMAINREF([F:CPY]CPY,GTYPGEN,GTYPANA) From CPTDIV
 Call LECPLAN([F:CPY]CPY,GTYPGEN,TCOA) From CPTDIV

 For [FCY]FCY1 Where LEGCPY=[F:CPY]CPY & FINFLG=2 & evalue(CRITERE)

 Call DCLVATDEB([F:CPY]CPY,[F:FCY]FCY,DATSTRP,[M:GSTPH]DATEND,SIMUL,OPT,TTYPDEB,NBTYPDEB,TCOA,DEVLED,ERR_STOP,2,2,"","",[F:FCY]FCY) From DCLVATBOXDEB

  If GOK<1 : Break 2 : Endif
#  If [M:DIA]TRCFLG=2
#   Call ECR_TRACE (mess(363,107,1)-[F:FCY]FCY-mess(26,113,1)-[F:CPY]CPY,0) From GESECRAN
#  Endif
 Next
Next

#US X3-83077 Log - Warning on temporary journals
  If !clalev([F:HAE])    : Local File GACCENTRY    [HAE]    : Endif
  Filter [F:HAE] Where [F:HAE]NUMDCL= [M:GSTPH]CODGSTPER and [F:HAE]STA = 1
  If rowcount([F:HAE]) > 0
    Call ECR_TRACE(mess(308,107,1) - mess(424,107,1),0) From GESECRAN
  Endif
Filter [F:HAE]
Filter [F:GSTPERD]
If ERR_STOP : GOK = 0 : Endif
If GOK<1 : Return : Endif
Return

############################################
# Rollback database transaction
############################################
$AB_TR1
Rollback
Return


#** #############################################################################################
#*  finalize period entries for the given period by setting the field SIM to 1
#*
#*  @param PERIOD            Variable Char      GST-Period code
#*
#*  @param ERRCOD            Variable Tinyint  Error code in case of error
#*
#*! #############################################################################################
Subprog FINALIZEPERIOD(PERIOD,ERRCOD)
  Variable Integer PERIOD
  Variable Tinyint ERRCOD

  Local Libelle RETC

  If !clalev([F:DLVB])   : Local File DCLVATBOXH   [DLVB]   : Endif
  If !clalev([F:DLVBD])  : Local File DCLVATBOXDBD [DLVBD]  : Endif
  If !clalev([F:GSTPERD]): Local File GSTPERD [GSTPERD]     : Endif

    Filter [F:DLVB] Where NUMRPT = PERIOD and VATFNC = "DCLVATAUS"
    If fstat
      GMESSAGE = mess(2,7704,1)
      GERR = 1
      FIN = 0
      ERRCOD = 1
      Filter [F:DLVB]
      End
    Endif

  Filter [F:DLVB]

  Trbegin[F:DLVB],[F:DLVBD]
  Update [F:DLVB] Where [F:DLVB]NUMRPT = PERIOD and [F:DLVB]VATFNC = "DCLVATAUS" With [F:DLVB]SIM = 1
  If fstat
    GOK = 0 : FIN = 0 :  Call FSTA("DLVB") From GLOCK : Goto AB_TR
  Else
    For [F:GSTPERD] Where [F:GSTPERD]CODGSTPER = PERIOD
      For [F:DLVBD] Where [F:DLVBD]NUMRPT = PERIOD and [F:DLVBD]CPY = [F:GSTPERD]CPY
        [F:DLVBD]SIM = 1
        Rewrite [F:DLVBD]
        If fstat
         GOK  = 0 : FIN = 0 :Call FSTA("DLVBD") From GLOCK : Goto AB_TR
         End
        Endif
      Next
    Next
    Commit
  Endif

End

