#<AdxTL>@(#)0.0.0.0 $Revision$
# Representation Class script: CCMPLANH_RSTD, Change request plan header
###############################################################################
# Issue 110210/8 - 2015-12-15 by JUSYN : New labels for supervisor update
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AQUERY_JOIN_AFTER"  : Gosub AQUERY_JOIN_AFTER
        When "AQUERY_TRANS_AFTER" : Gosub FILL_FROM_NCSRECENT
        When "AREAD_AFTER"
          Gosub FILL_FROM_NCSRECENT
          Gosub ACTIVATE_FIELDS
      Endcase
  Endcase
Return

$METHODS
  Case [L]AMETHOD
    When "IS_PLANNER_USER"    : Gosub IS_PLANNER_USER
  Endcase
Return

$PROPERTIES
  Case [L]CURPRO
    When "CCMPH.IMPLEMENT"
      Case [L]ARULE
        When "PROPAGATE"
          Gosub IMPLEMENT_PROPAGATE
      Endcase
  Endcase
Return
###############################################################################

# --------------------------------------------------
# Custom Method
#
# Is the logged-in user the planner ?
# Return true or false.
$IS_PLANNER_USER

  Local Instance NCSRECENT Using C_NCSRECENT
  NCSRECENT = NewInstance C_NCSRECENT AllocGroup null
  Local Integer LOCAL_ASTATUS

  LOCAL_ASTATUS = fmet NCSRECENT.AREAD(REQUESTID)

  If (this.ACTX.USER = NCSRECENT.NCSPLANNER)
    ARET_VALUE = CST_ATRUE
  Else
    ARET_VALUE = CST_AFALSE
  Endif

  FreeGroup NCSRECENT

Return

# --------------------------------------------------
# FUNCTION NAME:        AQUERY_JOIN_AFTER,
# FUNCTION DESCRIPTION: Join CCMCHGREQ Class With this CCMPLANH Class to filter by
 #                      NCSREC = 2 and CRSTATUS (4-PLAN, 5-IMPLEMENT and 6-COMPLETED).
# FUNCTION TYPE:        Subroutine,
# PARAMETERS:           N/A
# RETURN_VALUE:         N/A
#
$AQUERY_JOIN_AFTER

  Local File CCMCHGREQ [CCMCR]
  Link [CCMCR] With [CCMPH]CCMPH_0=[F:CCMCR]CRID
&   As [LNK_]
&   Where [F:CCMCR]NCSREC = 2 and [F:CCMCR]CRSTATUS >= 4 and [F:CCMCR]CRSTATUS <= 6

Return

# --------------------------------------------------
# Populate the Representation only Change Request data properties.
$FILL_FROM_NCSRECENT

  Local Instance MYNCSRECENT Using C_NCSRECENT
  MYNCSRECENT = NewInstance C_NCSRECENT AllocGroup null
  Local Integer LOCAL_ASTATUS

  LOCAL_ASTATUS = fmet MYNCSRECENT.AREAD(this.CCMPH.CRID)

  If (LOCAL_ASTATUS = CST_AOK)
    this.CRSTATUS    = MYNCSRECENT.CRSTATUS
    this.PRODUCT     = MYNCSRECENT.PRODUCT
    this.ECCVALMAJ   = MYNCSRECENT.ECCVALMAJ
    this.ECCVALMIN   = MYNCSRECENT.ECCVALMIN
    this.NCSMANAGER  = MYNCSRECENT.NCSMANAGER
    this.NCSPLANNER  = MYNCSRECENT.NCSPLANNER
    this.NCSID       = MYNCSRECENT.CRID
    this.NCSPLANID   = MYNCSRECENT.CRID
  Endif

  FreeGroup MYNCSRECENT

Return

# --------------------------------------------------
# Enable / disable fields at a class level.
$ACTIVATE_FIELDS

  Local Integer DUMMY_RTV
  Local Integer LOCAL_STATUS

  DUMMY_RTV = fmet this.CCMPH.SET_ATTRIBUTES()
  DUMMY_RTV = fmet this.CCMPH.SET_ATTRIBUTES_IMPLEMENT()

  # Disable all other read-only properties ...
  LOCAL_STATUS = fmet this.ASETATTRIBUTE("NCSID",            "$isDisabled", "true")
  LOCAL_STATUS = fmet this.ASETATTRIBUTE("CRSTATUS",         "$isDisabled", "true")
  LOCAL_STATUS = fmet this.ASETATTRIBUTE("PRODUCT",          "$isDisabled", "true")
  LOCAL_STATUS = fmet this.ASETATTRIBUTE("ECCVALMAJ",        "$isDisabled", "true")
  LOCAL_STATUS = fmet this.ASETATTRIBUTE("ECCVALMIN",        "$isDisabled", "true")
  LOCAL_STATUS = fmet this.ASETATTRIBUTE("NCSMANAGER",       "$isDisabled", "true")
  LOCAL_STATUS = fmet this.ASETATTRIBUTE("NCSPLANNER",       "$isDisabled", "true")
  LOCAL_STATUS = fmet this.CCMPH.ASETATTRIBUTE("PLANSTATUS", "$isDisabled", "true")
  LOCAL_STATUS = fmet this.CCMPH.ASETATTRIBUTE("UPDDATTIM",  "$isDisabled", "true")
  LOCAL_STATUS = fmet this.CCMPH.ASETATTRIBUTE("UPDUSR",     "$isDisabled", "true")

  # if Change request Closed or not allowed to amend, then disable edit link
  If (this.CRSTATUS <> 4 and this.CRSTATUS <> 5)
    LOCSTATUS = fmet this.ASETLINKDISABLE("AEDIT",[V]CST_AFFLNKREC)
  Endif

Return

# --------------------------------------------------
# IMPLEMENT property propagate actions ...
$IMPLEMENT_PROPAGATE

  Local Integer DUMMY_RTV
  ASTATUS = CST_AOK
  For LINE = 1 To maxtab(this.CCMPLAND)
    If (this.IMPLEMENT = 2 and
&      (this.CCMPLAND(LINE).ACTIONER = "" or
&       this.CCMPLAND(LINE).COMPLETEDATE = AVOID.ADATE))
      ASTATUS = fmet this.ASETERROR ("IMPLEMENT", mess(27,2038,1), [V]CST_AERROR)
      this.IMPLEMENT = 1
      Break
    Endif
  Next LINE

  If (ASTATUS = CST_AOK)
    # Enable / disable other properties ...
    DUMMY_RTV = fmet this.SET_ATTRIBUTES()
  Endif

Return

