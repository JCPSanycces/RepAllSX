#<AdxTL>@(#)0.0.0.0 $Revision$
# représentation STKCNSSDI

# Issue 113105 - 2016-01-13 by MAE : Refactoring code
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AINIT"         :  Gosub INIT_PARAM
    Endcase
Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
  When "CNSSDI_MET"          Gosub CNSSDI
Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  #Case CURPRO
  #Endcase
Return



#$METHODS
##Callmet this.ASETERROR ("", "Représentation STKCNSSDI : ACTION="+ACTION-"/"-"CURPTH="+CURPTH+"*", [V]CST_AINFO)
#Case [L]CURPTH
#   When ""
#      Case [L]ACTION
#      When "AINIT"         :  Gosub INIT_PARAM
#      When "CNSSDI_MET" :
#         Gosub CNSSDI
#      Endcase
#Endcase
#Return



#------------------------------------------------------------------------------
$INIT_PARAM
this.REFPER = date$
this.PERCOD = 2
Return
#------------------------------------------------------------------------------
$CNSSDI
Local Decimal H1,H2
Local Integer WERR
Local Char  ERRMSG(100)
Local File ITMMASTER  [ITM]
Local File FACILITY  [FCY]
Local File ITMFACILIT [ITF]

#Probléme mémoire
#--Heap Memory before launching the search
#     H1 = arr(freeheap/1024,0.0001)

    #[L]ASTATUS =  fmet this.ASETERROR ("", "Classe STKSCNSDI : $CNSSDI", [V]CST_AINFO)
    #--New instance W_CNSSDI
    Local Instance W_CNSSDI Using C_CNSSDI
    W_CNSSDI = NewInstance C_CNSSDI  AllocGroup null

    #controle sur les paramétres
    #si l'article ou le site ne sont pas renseignés=>erreur
    If this.ITMREF = ""
      [L]ERRMSG = mess(152,190,1)
      WERR = [V]CST_AERROR
      Goto FIN
      Return
    Else
      Read [F:ITM]ITM0=this.ITMREF
        If fstat
          [L]ERRMSG = mess(134,100, 1)
          WERR = [V]CST_AERROR
          Goto FIN
          Return
        Endif
    Endif
    If this.FCY = ""
      [L]ERRMSG = mess(5,180,1)
      WERR = [V]CST_AERROR
      Goto FIN
      Return
    Else
      Read [F:FCY]FCY0=this.FCY
        If fstat
          [L]ERRMSG = mess(15,104, 1)
          WERR = [V]CST_AERROR
          Goto FIN
          Return
        Elsif [F:FCY]WRHFLG<>2
          [L]ERRMSG = mess(358,184, 1)
          WERR = [V]CST_AERROR
          Goto FIN
          Return
        Endif
    Endif

    Read [F:ITF]ITF0=this.ITMREF;this.FCY
    If fstat
      [L]ERRMSG = mess(139,197,1)
      WERR = [V]CST_AERROR
      Goto FIN
    Endif

    #--Call to CNSSDI method
    #--We pass a pointer to the local document
    WERR = fmet W_CNSSDI.CNSSDI(this.ITMREF, this.FCY, this.PERCOD, this.REFPER, this.STKCNS)
    Goto FIN
Return

$FIN
If WERR > [V]CST_AINFO
  [L]ASTATUS = fmet this.ASETERROR("", [L]ERRMSG, [V]CST_AERROR)
  ARET_VALUE= WERR
  Gosub INIT
Endif
#--We must free the instance
FreeInstance =W_CNSSDI.AllocGrp #équivalent à Freegroup W_CNSSDI
Return

$INIT
this.STKCNS.PHYSTO    = AVOID.ADEC
this.STKCNS.FIRAVADAT = AVOID.ADATE
this.STKCNS.ORDSTO    = AVOID.ADEC

For WLINE=maxtab(this.STKCNS.C_STODISPO)  To 1 Step -1
        WRET = fmet this.STKCNS.ADELLINE("C_STODISPO",WLINE)
Next WLINE

Return

