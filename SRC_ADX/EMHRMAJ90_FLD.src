##########################################################################
# EMHRMAJ90_FLD  UTI process                                    PAY Module
#                Migration To U12 - Vnext version
#
# ==>  Update FOLDER with correct modules and activity codes
#
##########################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  If GPRODUIT<>2 : End : Endif #not X3 People

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Update "+WDOSSIER+" with correct modules and activity codes") From LECFIC

  Call AMAJ_EMHRMAJ90_FLD(WDOSSIER)

  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

Subprog AMAJ_EMHRMAJ90_FLD(LDOSSIER)
Value Char LDOSSIER

  Onerrgo CYCLECHECKERROR
  If clalev([HRADA]) = 0 : Local File ADOSACT [HRADA] : Endif
  If clalev([HRACT]) = 0 : Local File ACTIV   [HRACT] : Endif
  If clalev([F:WADS])= 0 : Local File ADOSSIER [WADS] : Endif

#  Call ECR_TRACE("EMHRMAJ90_FLD: Update FOLDER with correct modules and activity codes",0) From GESECRAN
#  Call ECR_TRACE("EMHRMAJ90_FLD: Start of process on : "+LDOSSIER,0) From GESECRAN

  Local Integer COUNTER, NBRTAB
  Local Integer STAT : STAT = 1
  Local Char DOSLEGMIG(5)
  DOSLEGMIG = func EMHRMAJ90_LEG.GET_LEG(LDOSSIER)

  Read [F:WADS]DOSSIER= LDOSSIER
#  If !fstat
