#        [F:WADS]MODULE(COUNTER) = 2
#      Else
#  #      Call ECR_TRACE("********** Setting MODULE("+num$(COUNTER+1)+") = 1 ***********",0) From GESECRAN
#        [F:WADS]MODULE(COUNTER) = 1
#      Endif
#    Next
#    Rewrite [F:WADS]
#    If !fstat : Commit : Else : Call FSTA("WADS") From GLOCK : Rollback : Endif
#  Endif

#  Gosub SET_ACTIVITY_ADOSACT From EMHRMAJ90_ACT_1

#  Gosub U9_ACTIVITY_CODES

  Close Local File [F:HRADA], [F:HRACT]

  Gosub CREATE_WMIGR_ACTIV

  Gosub PERIOD_DATA_MIGRATION

  Gosub MISC_TABLES_OBJECTS_ARRAY

  Gosub CREATE_HR_OBJECT_TABLES

  Gosub LOOP_TABLE_ARRAY_LEG

  Gosub UPDATE_WMPLFSTD_MODULE
#  Call ECR_TRACE("EMHRMAJ90_FLD : End of process on : "+LDOSSIER,0) From GESECRAN

End

$CYCLECHECKERROR
#  Call ECR_TRACE("Error in EMHRMAJ90_FLD: " + num$(errn)-errmes$(errn)-errm, -1) From GESECRAN
Resume

$FHRPA_ACTIVITY
#  Call ECR_TRACE("EMHRMAJ90_FLD : Updating FHRPA activtiy code to ON in folder : "+LDOSSIER,0) From GESECRAN
  If clalev([F:HRACV]) = 0 : Local File = LDOSSIER + ".ACTIV" [HRACV] : Endif

  Read [F:HRADA]ADA0 = LDOSSIER;"FHRPA"
  [F:HRADA]MODULE = 9
  [F:HRADA]FLACT = 2
  If !fstat
    Rewrite [F:HRADA]
  Else
    Write [F:HRADA]
  Endif

  Read [F:HRACV]CODACT = "FHRPA"

  [F:HRACV]ACTFOR = "HRPAY | HRHRM"
  [F:HRACV]DEP = 4
  [F:HRACV]FLACT = 2
  [F:HRACV]LIBACT = 56127
  [F:HRACV]MODULE = 9
  [F:HRACV]ORDRE = 1010
  [F:HRACV]TYP = 1

  If !fstat
    Rewrite [F:HRACV]
  Else
    Write [F:HRACV]
  Endif

  Close Local File [F:HRACV]
#  Call ECR_TRACE("EMHRMAJ90_FLD : DONE with FHRPA : "+LDOSSIER,0) From GESECRAN
Return

