$CLEAN_TRA
  Local Char DIR(GDIMFIC), FILELIST(GDIMFIC)(1..)
  Local Integer LNGTH

  DIR = func AVOLUME_CSTD._GETFULLPATH(num$("TRA"),"")

  Call SYSTEME2(adxmac(0), "lsadx"-DIR,"",LNGTH,FILELIST) From ORDSYS

  For I=3 To LNGTH
    STAT = func ASYRSTO.DELETEFILE("TRA", FILELIST(I))
  Next

Return

$FIND_FILES
  Call OUVRE_TRACE("File list") From LECFIC
  Local Char DIR(GDIMFIC), FILELIST(GDIMFIC)(1..)
  Local Integer LNGTH

  DIR = func AVOLUME_CSTD._GETFULLPATH(num$("REPORT/FRA"),"")

  Call SYSTEME2(adxmac(0), "lsadx"-DIR,"",LNGTH,FILELIST) From ORDSYS
  Infbox num$(LNGTH)
  For I=1 To LNGTH
    Call ECR_TRACE(FILELIST(I),0) From GESECRAN
  Next

Return

$CREATE_WMIGR_ACTIV
  If clalev([ACVHR])=0 : Local File =LDOSSIER+".ACTIV" [ACVHR] : Endif
  Read [F:ACVHR]CODACT = "WMIGR"
  If fstat
    Raz [F:ACVHR]
    [F:ACVHR]CODACT = "WMIGR"
    [F:ACVHR]FLACT = 2
    [F:ACVHR]MODULE = 9
    [F:ACVHR]DEP = 1
    [F:ACVHR]TYP = 1
    Write [F:ACVHR]
    Call ECR_TRACE("EMHRMAJ90_FLD: Creating Activity Code WMIGR",0) From GESECRAN
  Endif
  Read [F:ACVHR]CODACT = "MIG"
  If !fstat
    [F:ACVHR]FLACT = 2
    Rewrite [F:ACVHR]
  Endif
  Close File [ACVHR]
Return

##PEVAN - 2017-01-29 - X3-47660 - START
$PERIOD_DATA_MIGRATION
  If clalev([WATB])=0   : Local File =LDOSSIER+".ATABLE"  [WATB]   : Endif
  If clalev([WTAB])=0   : Local File =LDOSSIER+".ATABZON" [WTAB]   : Endif
  If clalev([WIND])=0   : Local File =LDOSSIER+".ATABIND" [WIND]   : Endif
  If clalev([WATB_D])=0 : Local File =LDOSSIER+".ATABLE"  [WATB_D] : Endif
  If clalev([WTAB_D])=0 : Local File =LDOSSIER+".ATABZON" [WTAB_D] : Endif
  If clalev([WIND_D])=0 : Local File =LDOSSIER+".ATABIND" [WIND_D] : Endif
  If clalev([WPER_D])=0 : Local File =LDOSSIER+".PERIOD"  [WPER_D] : Endif

  Read [F:WATB]CODFIC = "PERIOD"
  If !fstat
    Read [F:WATB_D]CODFIC = "WTEMPPERIOD"
    If !fstat
      Delete [F:WIND_D] Where [F:WIND_D]CODFIC = "WTEMPPERIOD"
      Delete [F:WTAB_D] Where [F:WTAB_D]CODFIC = "WTEMPPERIOD"
      Delete [F:WATB_D] Where [F:WATB_D]CODFIC = "WTEMPPERIOD"
    Endif
    Raz [F:WATB_D]
    [F:WATB_D] = [F:WATB]
    [F:WATB_D]CODFIC = "WTEMPPERIOD"
    [F:WATB_D]ABRFIC = "WTMPPEO"
    [F:WATB_D]CODACT = ""
    [F:WATB_D]MODULE = 9
    Write [F:WATB_D]
      Call ECR_TRACE("--EMHRMAJ90_FLD: Created table: WTEMPPERIOD",0) From GESECRAN

    Filter [F:WTAB] Where [F:WTAB]CODFIC = "PERIOD"
    For [F:WTAB]
      Raz [F:WTAB_D]
      [F:WTAB_D] = [F:WTAB]
      [F:WTAB_D]CODFIC = "WTEMPPERIOD"
      Write [F:WTAB_D]
    Next
    Filter [F:WTAB]

    Filter [F:WIND] Where [F:WIND]CODFIC = "PERIOD"
    For [F:WIND]
      Raz [F:WIND_D]
      [F:WIND_D] = [F:WIND]
      [F:WIND_D]CODFIC = "WTEMPPERIOD"
      Write [F:WIND_D]
    Next
    Filter [F:WIND]

    Close Local File [F:WATB], [F:WTAB], [F:WIND], [F:WATB_D], [F:WTAB_D], [F:WIND_D]

    Call TEMPON("V") From GESECRAN
    Call MAJFIC("WTEMPPERIOD",LDOSSIER,1) From VALDIC
    Call MAJTRIG("WTEMPPERIOD",LDOSSIER) From VALDIC
    Call TEMPOFF From GESECRAN

    If clalev([WATB_D])=0 : Local File =LDOSSIER+".ATABLE"  [WATB_D] : Endif
    Update [F:WATB_D] Where [F:WATB_D]CODFIC = "WTEMPPERIOD" With [F:WATB_D]CODACT="MIG"
    Close Local File [F:WATB_D]
  Else
    Close Local File [F:WATB], [F:WTAB], [F:WIND], [F:WATB_D], [F:WTAB_D], [F:WIND_D]
  Endif

  If clalev([WPER_D])=0 : Local File =LDOSSIER+".PERIOD"      [WPER_D] : Endif
  If clalev([WTPER])=0  : Local File =LDOSSIER+".WTEMPPERIOD" [WTPER]  : Endif
  Local Integer TMPCOUNTER: TMPCOUNTER = 0

  For [F:WPER_D]
    [F:WTPER] = [F:WPER_D]
    Write [F:WTPER]
    TMPCOUNTER += 1
  Next

  Delete [F:WPER_D] Where 1=1

  Close Local File [WPER_D], [WTPER]

Return
##PEVAN - 2017-01-29 - X3-47660 - END

$MISC_TABLES_OBJECTS_ARRAY
  Local Char NUMTABARRAY(GLONATB)(1..)
  Local Char NEWTABLEARRAY(GLONATB)(1..)
  Local Char OLDTABLEARRAY(GLONATB)(1..)
  Local Char U9TABLEARRAY(GLONATB)(1..)
  Local Integer I
  #Add the tables here needed to migrate for legislation
  #Index start at 1
#PEVAN - 2018-07-30 - X3-102579 - START
#  I += 1 :  NUMTABARRAY(I) = "354" : NEWTABLEARRAY(I) = "WHRNATCON" : OLDTABLEARRAY(I) = "HRNATCON"
#  I += 1 :  NUMTABARRAY(I) = "358" : NEWTABLEARRAY(I) = "WHRCLLCVT" : OLDTABLEARRAY(I) = "HRCLLCVT"
#  I += 1 :  NUMTABARRAY(I) = "359" : NEWTABLEARRAY(I) = "WHRXITGRD" : OLDTABLEARRAY(I) = "HRXITGRD"
#  I += 1 :  NUMTABARRAY(I) = "395" : NEWTABLEARRAY(I) = "WHRMEDTYP" : OLDTABLEARRAY(I) = "HRMEDTYP"
#  I += 1 :  NUMTABARRAY(I) = "386" : NEWTABLEARRAY(I) = "WHRCTRGRD" : OLDTABLEARRAY(I) = "HRCTRGRD"
#  I += 1 :  NUMTABARRAY(I) = "" : NEWTABLEARRAY(I) = "WHREXPENSES"  : OLDTABLEARRAY(I) = "HREXPENSES"
#  I += 1 :  NUMTABARRAY(I) = "" : NEWTABLEARRAY(I) = "WHREXSKMETRE" : OLDTABLEARRAY(I) = "HREXSKMETRE"
#  I += 1 :  NUMTABARRAY(I) = "" : NEWTABLEARRAY(I) = "WHRFILTDS"    : OLDTABLEARRAY(I) = "HRFILTDS"
#  I += 1 :  NUMTABARRAY(I) = "" : NEWTABLEARRAY(I) = "WHRFRMPAY"    : OLDTABLEARRAY(I) = "HRFRMPAY"
#  I += 1 :  NUMTABARRAY(I) = "" : NEWTABLEARRAY(I) = "WHRPARVAREXP" : OLDTABLEARRAY(I) = "HRPARVAREXP"
#  I += 1 :  NUMTABARRAY(I) = "" : NEWTABLEARRAY(I) = "WHRPAYTMP"    : OLDTABLEARRAY(I) = "HRPAYTMP"
#  I += 1 :  NUMTABARRAY(I) = "" : NEWTABLEARRAY(I) = "WHRTABEXPENS" : OLDTABLEARRAY(I) = "HRTABEXPENS"
#  I += 1 :  NUMTABARRAY(I) = "" : NEWTABLEARRAY(I) = "WHRTABFILBAN" : OLDTABLEARRAY(I) = "HRTABFILBAN"
  I  = 0
  I += 1 :  NUMTABARRAY(I) = "354" : NEWTABLEARRAY(I) = "WHRNATCON" : OLDTABLEARRAY(I) = "HRNATCON" : U9TABLEARRAY(I) = ""
  I += 1 :  NUMTABARRAY(I) = "358" : NEWTABLEARRAY(I) = "WHRCLLCVT" : OLDTABLEARRAY(I) = "HRCLLCVT" : U9TABLEARRAY(I) = ""
  I += 1 :  NUMTABARRAY(I) = "359" : NEWTABLEARRAY(I) = "WHRXITGRD" : OLDTABLEARRAY(I) = "HRXITGRD" : U9TABLEARRAY(I) = ""
  I += 1 :  NUMTABARRAY(I) = "395" : NEWTABLEARRAY(I) = "WHRMEDTYP" : OLDTABLEARRAY(I) = "HRMEDTYP" : U9TABLEARRAY(I) = ""
  I += 1 :  NUMTABARRAY(I) = "386" : NEWTABLEARRAY(I) = "WHRCTRGRD" : OLDTABLEARRAY(I) = "HRCTRGRD" : U9TABLEARRAY(I) = ""
  I += 1 :  NUMTABARRAY(I) = "" : NEWTABLEARRAY(I) = "WHREXPENSES"  : OLDTABLEARRAY(I) = "HREXPENSES" : U9TABLEARRAY(I) = "EXPENSES"
  I += 1 :  NUMTABARRAY(I) = "" : NEWTABLEARRAY(I) = "WHREXSKMETRE" : OLDTABLEARRAY(I) = "HREXSKMETRE" : U9TABLEARRAY(I) = "EXSKMETRE"
  I += 1 :  NUMTABARRAY(I) = "" : NEWTABLEARRAY(I) = "WHRFILTDS"    : OLDTABLEARRAY(I) = "HRFILTDS" : U9TABLEARRAY(I) = "FILTDS"
  I += 1 :  NUMTABARRAY(I) = "" : NEWTABLEARRAY(I) = "WHRFRMPAY"    : OLDTABLEARRAY(I) = "HRFRMPAY" : U9TABLEARRAY(I) = "FRMPAY"
  I += 1 :  NUMTABARRAY(I) = "" : NEWTABLEARRAY(I) = "WHRPARVAREXP" : OLDTABLEARRAY(I) = "HRPARVAREXP" : U9TABLEARRAY(I) = "PARVAREXP"
  I += 1 :  NUMTABARRAY(I) = "" : NEWTABLEARRAY(I) = "WHRPAYTMP"    : OLDTABLEARRAY(I) = "HRPAYTMP" : U9TABLEARRAY(I) = "PAYTMP"
  I += 1 :  NUMTABARRAY(I) = "" : NEWTABLEARRAY(I) = "WHRTABEXPENS" : OLDTABLEARRAY(I) = "HRTABEXPENS" : U9TABLEARRAY(I) = "TABEXPENS"
  I += 1 :  NUMTABARRAY(I) = "" : NEWTABLEARRAY(I) = "WHRTABFILBAN" : OLDTABLEARRAY(I) = "HRTABFILBAN" : U9TABLEARRAY(I) = "TABFILBAN"
  #... add
#PEVAN - 2018-07-30 - X3-102579 - END

  #store the number of rows in the tablearray array
  [L]NBRTAB = I

Return ##############################################################################################################

$CREATE_HR_OBJECT_TABLES
  If clalev([HRATB1])=0  : Local File ATABLE  [HRATB1]  : Endif
  If clalev([HRTAB1])=0  : Local File ATABZON [HRTAB1]  : Endif
  If clalev([HRIND1])=0  : Local File ATABIND [HRIND1]  : Endif
  If clalev([HRATY])=0  : Local File ATYPE   [HRATY]  : Endif
  If clalev([HRATB2])=0 : Local File =LDOSSIER+".ATABLE"  [HRATB2] : Endif
  If clalev([HRTAB2])=0 : Local File =LDOSSIER+".ATABZON" [HRTAB2] : Endif
  If clalev([HRIND2])=0 : Local File =LDOSSIER+".ATABIND" [HRIND2] : Endif
  If clalev([HRATY2])=0 : Local File =LDOSSIER+".ATYPE"   [HRATY2] : Endif

  For I = 1 To [L]NBRTAB
    Call ECR_TRACE("EMHRMAJ90_FLD: Creating table: " + NEWTABLEARRAY(I),0) From GESECRAN
    Read [F:HRATB1]CODFIC = [L]OLDTABLEARRAY(I)
    Delete [F:HRATB2] Where [F:HRATB2]CODFIC = [L]NEWTABLEARRAY(I)
    Raz [F:HRATB2]
    [F:HRATB2] = [F:HRATB1]
    [F:HRATB2]CODFIC = [L]NEWTABLEARRAY(I)
    [F:HRATB2]ABRFIC = "WTMP"+num$(I)
    [F:HRATB2]CODACT = ""
    [F:HRATB2]MODULE = 9
    Write [F:HRATB2]
    Call ECR_TRACE("--EMHRMAJ90_FLD: Created table: " + NEWTABLEARRAY(I) - ", fstat" - num$(fstat),0) From GESECRAN

    Call ECR_TRACE("EMHRMAJ90_FLD: Creating data type " - [L]NEWTABLEARRAY(I) - " fields",0) From GESECRAN
    Filter [F:HRATY] Where find([F:HRATY]CODTYP, "HRNCT", "HRCGD", "HRXGD", "HRMDT", "HRTES", "HRCTR", "EML", "HRFRM", "HRCLV") > 0
    For [F:HRATY]
      Delete [F:HRATY2] Where [F:HRATY2]CODTYP=[F:HRATY]CODTYP
      Raz [F:HRATY2]
      [F:HRATY2] = [F:HRATY]
      Write [F:HRATY2]
      Call ECR_TRACE("--EMHRMAJ90_FLD: Created data type: " + [F:HRATY]CODTYP - ", fstat" - num$(fstat),0) From GESECRAN
    Next

    Call ECR_TRACE("EMHRMAJ90_FLD: Creating table " - [L]NEWTABLEARRAY(I) - " fields",0) From GESECRAN
    Filter [F:HRTAB1] Where [F:HRTAB1]CODFIC = [L]OLDTABLEARRAY(I)
    Delete [F:HRTAB2] Where [F:HRTAB2]CODFIC = [L]NEWTABLEARRAY(I)
    For [F:HRTAB1]
      Raz [F:HRTAB2]
      [F:HRTAB2] = [F:HRTAB1]
      [F:HRTAB2]CODFIC = [L]NEWTABLEARRAY(I)
      If [F:HRTAB1]CODACT <> ""
        [F:HRTAB2]CODACT = ""
      Endif
      Write [F:HRTAB2]
      Call ECR_TRACE("--EMHRMAJ90_FLD: Created field, fstat" - num$(fstat),0) From GESECRAN
    Next
    Filter [F:HRTAB1]

    Call ECR_TRACE("EMHRMAJ90_FLD: Creating " - [L]NEWTABLEARRAY(I) - " indices",0) From GESECRAN
    Filter [F:HRIND1] Where [F:HRIND1]CODFIC = [L]OLDTABLEARRAY(I)
    Delete [F:HRIND2] Where [F:HRIND2]CODFIC = [L]NEWTABLEARRAY(I)
    For [F:HRIND1]
      Raz [F:HRIND2]
      [F:HRIND2] = [F:HRIND1]
      [F:HRIND2]CODFIC = [L]NEWTABLEARRAY(I)
      Write [F:HRIND2]
      Call ECR_TRACE("--EMHRMAJ90_FLD: Created index, fstat" - num$(fstat),0) From GESECRAN
    Next
    Filter [F:HRIND1]
  Next

  Close File [HRATB1], [HRTAB1], [HRIND1], [HRATB2], [HRTAB2], [HRIND2], [HRATY], [HRATY2]

  For I = 1 To [L]NBRTAB
    Call ECR_TRACE("EMHRMAJ90_FLD: Validating table " - [L]NEWTABLEARRAY(I),0) From GESECRAN
    Call TEMPON("V") From GESECRAN
    Call MAJFIC([L]NEWTABLEARRAY(I),LDOSSIER,1) From VALDIC
    Call MAJTRIG([L]NEWTABLEARRAY(I),LDOSSIER) From VALDIC
    Call TEMPOFF From GESECRAN
    Call ECR_TRACE("----------------------------------EMHRMAJ90_FLD: Done validating table " - [L]NEWTABLEARRAY(I),0) From GESECRAN

    If clalev([HRATB2])=0 : Local File =LDOSSIER+".ATABLE"  [HRATB2] : Endif
    Update [F:HRATB2] Where [F:HRATB2]CODFIC = [L]NEWTABLEARRAY(I) With [F:HRATB2]CODACT="MIG"
    Close File [F:HRATB2]
  Next

Return
##PEVAN - 2018-02-21 - X3-75523 - END

$LOOP_TABLE_ARRAY_LEG
#Looping through NUMTABARRAY
  For I = 1 To [L]NBRTAB
    Call ECR_TRACE("EMHRMAJ90_FLD: Miscellaneous Table migration: " + NEWTABLEARRAY(I) + " - Starting on folder: "+LDOSSIER,0) From GESECRAN


#PEVAN - 2018-07-30 - X3-102579 - START
#    If NUMTABARRAY(I) <> ""
#      #call the procedure to migrate the table data
#      Call MIGRATE_TABLE(DOSLEGMIG, STAT, LDOSSIER, NUMTABARRAY(I), NEWTABLEARRAY(I))
#    Endif
    If NUMTABARRAY(I) <> ""
      #call the procedure to migrate the table data
      Call MIGRATE_TABLE(DOSLEGMIG, STAT, LDOSSIER, NUMTABARRAY(I), NEWTABLEARRAY(I))
    Else
      Call MIGRATE_HR_TABLE(DOSLEGMIG, STAT, LDOSSIER, U9TABLEARRAY(I), NEWTABLEARRAY(I))
    Endif
#PEVAN - 2018-07-30 - X3-102579 - END
  Next

Return

#PEVAN - 2018-07-30 - X3-102579 - START
###########################################################################################################
Subprog MIGRATE_HR_TABLE(DOSLEGMIG, STAT, LDOSSIER, U9TABLE, TEMPTABLE)
Value Char LDOSSIER, DOSLEGMIG, U9TABLE, TEMPTABLE
Value Integer STAT : STAT = 1
Local Integer COMPTEUR
Local Char MSG(100)

  Call ECR_TRACE("EMHRMAJ90_HRTABLE: Copy data from"+ U9TABLE +" to table "+ TEMPTABLE,0) From GESECRAN
  #PEVAN - 2018-09-12 - X3-107824 - START
  #If !clalev([F:WWWW_N]): Local File = DOSLEGMIG+"."+TEMPTABLE [F:WWWW_N] : Endif
  #If !clalev([F:WWWW_O]): Local File = DOSLEGMIG+"."+U9TABLE [F:WWWW_O] : Endif
  If !clalev([F:WWWW_N]): Local File = LDOSSIER+"."+TEMPTABLE [F:WWWW_N] : Endif
  If !clalev([F:WWWW_O]): Local File = LDOSSIER+"."+U9TABLE [F:WWWW_O] : Endif
  #PEVAN - 2018-09-12 - X3-107824 - END
  Filter [F:WWWW_O]
  For [F:WWWW_O]
    Raz [F:WWWW_N]
    [F:WWWW_N] = [F:WWWW_O]
    Write [F:WWWW_N]
    Call ECR_TRACE("Row result = " - num$(fstat),0) From GESECRAN
  Next

  Close Local File [F:WWWW_N], [F:WWWW_O]
End
#PEVAN - 2018-07-30 - X3-102579 - END

###########################################################################################################
Subprog MIGRATE_TABLE(DOSLEGMIG, STAT, LDOSSIER, NUMTAB, TABLE)
Value Char LDOSSIER, DOSLEGMIG, NUMTAB, TABLE
Value Integer STAT : STAT = 1
Local Integer COMPTEUR
Local Char MSG(100)
Local Char LNGDES(GLONAX3)
Local Char SHODES(GLONAX1)
Local Char DESAXX(GLONAX3)
Local Char SHOAXX(GLONAX1)

Local Integer NEW_NUMTAB
Local Integer UPD_OK : UPD_OK = 2

  #open the miscellaneous table header setup (header) table for reading
  If clalev([F:WADV])  = 0 : Local File =LDOSSIER+".ATABTAB" [WADV] : Endif
  #open the miscellaneous table records for reading
  If clalev([F:WADI])  = 0 : Local File =LDOSSIER+".ATABDIV" [WADI] : Endif
  #dynamic open of files writing
  If clalev([F:WTABNEW]) = 0 : Local File =LDOSSIER+"."+TABLE [WTABNEW] : Endif
  #open the "Entry Reason" table for reading
  If clalev([F:MOE])   = 0 : Local File =LDOSSIER+".MOTENT"     [MOE]  : Endif

  #check if the misc table header exists
  Read [F:WADV]CODE = val([L]NUMTAB)
  If fstat
    Call ECR_TRACE("EMHRMAJ90_FLD: Unable to read definition for table - "-num$([L]NUMTAB),0) From GESECRAN
    UPD_OK = 1
  Endif

    Call ECR_TRACE("EMHRMAJ90_FLD: UPD_OK - "-num$(UPD_OK),0) From GESECRAN
  If UPD_OK = 2
    #get the misc table messages for looping through and processing
    Filter [F:WADI] Where [F:WADI]NUMTAB = val([L]NUMTAB)
    Call ECR_TRACE("EMHRMAJ90_FLD: Number of rows to loop through - "-num$(rowcount([F:WADI])),0) From GESECRAN
    For [F:WADI]

      #Call ECR_TRACE(": " + NUMTAB + " : "+num$([F:WADI]CODE) + " : "+num$([F:WADI]LEG),0) From GESECRAN
      MSG = ": " + [L]NUMTAB + " : "+num$([F:WADI]CODE) + " : "+num$([F:WADI]LEG)
      UPD_OK = 2
      #reset the translation variables
      Raz [L]LNGDES
      Raz [L]SHODES

      #get the translations for the long and short message descriptions
      Call LECTEXTRA([L]LNGDES, "ATABDIV", "LNGDES", [L]NUMTAB, [F:WADI]CODE) From ATEXTRA
      Call LECTEXTRA([L]SHODES, "ATABDIV", "SHODES", [L]NUMTAB, [F:WADI]CODE) From ATEXTRA

      #check if the first message on the target misc table is the same
#      Filter [F:WTAB] Where [F:WTAB]COD = [F:WADI]CODE & [F:WTAB]LEG = [F:WADI]LEG
      Filter [F:WTABNEW] Where [F:WTABNEW]COD = [F:WADI]CODE & [F:WTABNEW]LEG = DOSLEGMIG
##PEVAN - 2017-01-30 - X3-47660 - START
#      Read [F:WTAB] First
#      If fstat
      If rowcount([F:WTABNEW]) = 0
        Call ECR_TRACE("Starting with NUMTAB: " - num$([L]NUMTAB),0) From GESECRAN
##PEVAN - 2017-01-30 - X3-47660 - END
        [F:WTABNEW]COD = [F:WADI]CODE
##PEVAN - 2017-01-30 - X3-47660 - START
#        [F:WTAB]LEG = [F:WADI]LEG
        [F:WTABNEW]LEG = DOSLEGMIG
##PEVAN - 2017-01-30 - X3-47660 - END
        [F:WTABNEW]GRP=""
        [F:WTABNEW]ENAFLG=2
        #[F:WTAB]DEFVAL= (CHK_DEF & [F:WADI]DEFVAL=2)+1
#        Write [F:WTAB]
##PEVAN - 2017-01-30 - X3-47660 - START
#        If fstat
#          UPD_OK = 1
##          Break
#        Else
#          Filter [F:WTAB] Where [F:WTAB]COD = [F:WADI]CODE & [F:WTAB]LEG = DOSLEGMIG
#        Endif
#      Endif
#      Filter [F:WTAB]
##PEVAN - 2017-01-30 - X3-47660 - END

        #write the misc table message detail from the source to the target
        If UPD_OK = 2
          If TABLE = "WHRNATCON"
            If dim([F:WTABNEW]CODN4H) > 0 : [F:WTABNEW]CODN4H = [F:WADI]A1 : Endif
            If dim([F:WTABNEW]CODDUE) > 0 : [F:WTABNEW]CODDUE = [F:WADI]A2 : Endif
            If dim([F:WTABNEW]TYPCDD) > 0 : [F:WTABNEW]TYPCDD = [F:WADI]N2 : Endif
            If dim([F:WTABNEW]TYPCON) >= 0
              [F:WTABNEW]TYPCON = [F:WADI]N1

              If[F:WTABNEW]TYPCON = 0
                [F:WTABNEW]TYPCON = 5
              Endif
            Endif
          Endif

          #write the misc table message detail from the source to the target
          If TABLE = "WHRCTRGRD"
            Filter [F:MOE] Where COD = [F:WADI]CODE
            Read [F:MOE]First
            If fstat : Raz [F:MOE] : Endif

            If dim([F:WTABNEW]CODN4H)     >= 0                                : [F:WTABNEW]CODN4H    = [F:WADI]A1       : Endif
            If dim([F:WTABNEW]CODMVT)     >= 0                                : [F:WTABNEW]CODMVT    = [F:WADI]A2       : Endif
            If dim([F:WTABNEW]DETN4H)     >= 0                                : [F:WTABNEW]DETN4H    = num$([F:WADI]N1) : Endif
            If dim([F:WTABNEW]REGSTR)     >= 0                                : [F:WTABNEW]REGSTR    = [F:WADI]N2       : Endif
            If (dim([F:WTABNEW]CTRXITAUT) >= 0 & dim([F:MOE]CTRXITAUT) >= 0 ) : [F:WTABNEW]CTRXITAUT = [F:MOE]CTRXITAUT : Endif
            If (dim([F:WTABNEW]CTRDATFCY) >= 0 & dim([F:MOE]CTRDATFCY) >= 0 ) : [F:WTABNEW]CTRDATFCY = [F:MOE]CTRDATFCY : Endif
            If (dim([F:WTABNEW]CTRXITGRD) >= 0 & dim([F:MOE]CTRXITGRD) >= 0 ) : [F:WTABNEW]CTRXITGRD = [F:MOE]CTRXITGRD : Endif
            If (dim([F:WTABNEW]FLGCREBUL) >= 0 & dim([F:MOE]FLGCREBUL) >= 0 ) : [F:WTABNEW]FLGCREBUL = [F:MOE]FLGCREBUL : Endif
            If (dim([F:WTABNEW]FLGDSN)    >= 0 & dim([F:MOE]FLGDSN)    >= 0 ) : [F:WTABNEW]FLGDSN    = [F:MOE]FLGDSN    : Endif
            If (dim([F:WTABNEW]RENMUT)    >= 0 & dim([F:MOE]RENMUT)    >= 0 ) : [F:WTABNEW]RENMUT    = [F:MOE]RENMUT    : Endif
            If (dim([F:WTABNEW]SSPGRD)    >= 0 & dim([F:MOE]SSPGRD)    >= 0 ) : [F:WTABNEW]SSPGRD    = [F:MOE]SSPGRD    : Endif
          Endif

          #write the misc table message detail from the source to the target
          If TABLE = "WHRCATCSP"
            If dim([F:WTABNEW]CODN4H) >= 0 : [F:WTABNEW]CODN4H=[F:WADI]A1 : Endif
            If dim([F:WTABNEW]VALNUM) >= 0 : [F:WTABNEW]VALNUM=[F:WADI]N1 : Endif
            If dim([F:WTABNEW]LEVNUM) >= 0 : [F:WTABNEW]LEVNUM=[F:WADI]N2 : Endif
          Endif

          #write the misc table message detail from the source to the target
          If TABLE = "WHRXITGRD"
            If dim([F:WTABNEW]CODN4H) >= 0 : [F:WTABNEW]CODN4H = [F:WADI]A1 : Endif
            If dim([F:WTABNEW]CODMVT) >= 0 : [F:WTABNEW]CODMVT = [F:WADI]A2 : Endif
            If dim([F:WTABNEW]POLEMP) >= 0 : [F:WTABNEW]POLEMP = [F:WADI]N1 : Endif
            If dim([F:WTABNEW]REGSTR) >= 0 : [F:WTABNEW]REGSTR = [F:WADI]N2 : Endif
            If dim([F:WTABNEW]CODDSN) >= 0 : [F:WTABNEW]REGSTR = [F:WADI]N2 : Endif
          Endif

          #write the misc table message detail from the source to the target
          If TABLE = "WHRMEDTYP"
            If dim([F:WTABNEW]NBRMON) >= 0 : [F:WTABNEW]NBRMON = [F:WADI]N1 : Endif
          Endif

          #write the misc table message detail from the source to the target
          If TABLE = "WHRCLLCVT"
            If dim([F:WTABNEW]CODN4H) >= 0 : [F:WTABNEW]CODN4H = [F:WADI]A1 : Endif
            If dim([F:WTABNEW]HERDIF) >= 0 : [F:WTABNEW]HERDIF = [F:WADI]N1 : Endif
          Endif

          Call ECR_TRACE("------------------------------REWRITING, UPD_OK = " + num$(UPD_OK),0) From GESECRAN
          ##PEVAN - 2017-01-30 - X3-47660 - START
#          Rewrite [F:WTAB]
          Write [F:WTABNEW]
          ##PEVAN - 2017-01-30 - X3-47660 - END
          If fstat
            UPD_OK = 1
          ##PEVAN - 2017-01-30 - X3-47660 - START
#            Break
          ##PEVAN - 2017-01-30 - X3-47660 - END
          Endif
          #write the translation for the description and short description
          If UPD_OK = 2
            Call MAJTEXTRA([L]DESAXX, TABLE, "DESAXX", [F:WADI]CODE, [F:WADI]LEG) From ATEXTRA
            Call MAJTEXTRA([L]SHOAXX, TABLE, "SHOAXX", [F:WADI]CODE, [F:WADI]LEG) From ATEXTRA
          Endif
        Endif
##PEVAN - 2017-01-30 - X3-47660 - START
#        Rewrite [F:WTAB]
#        If fstat
#          UPD_OK = 1
#          Break
#        Endif
##PEVAN - 2017-01-30 - X3-47660 - END

        #write the transaction status to the error log
        If UPD_OK = 2
          Call ECR_TRACE("Successful: " + MSG,-1) From GESECRAN
        Else
          Call ECR_TRACE("Failed: " + MSG,-1) From GESECRAN
        Endif
      Endif
    Next
  Endif

  #Close the misc tables header and messages table used for reading and writing
  Close Local File [F:WADV], [F:WADI], [F:WTABNEW], [F:MOE]

  #Raz COMPTEUR
  Call DEBTRANS From GLOCK

End #end subprog MIGRATE_TABLE ###########################################################################

$UPDATE_WMPLFSTD_MODULE
  If clalev([AWIHR])=0 : Local File =LDOSSIER+".AWINDOW" [AWIHR] : Endif
  If clalev([AMKHR])=0 : Local File =LDOSSIER+".AMSK" [AMKHR] : Endif

  Update [F:AWIHR] Where [F:AWIHR]WIN = "WFPLFSTD" With [F:AWIHR]MODULE = 20
  Update [F:AMKHR] Where [F:AMKHR]CODMSK = "WMPLFSTD" With [F:AMKHR]MODULE = 20

  Close File [F:AWIHR]
  Close File [F:AMKHR]
Return

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT90 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif
If GPRODUIT<>2 : End : Endif #not X3 People
Call AMAJ_EMHRMAJ90_FLD(APPLI)
End

#######################################################################
# To execute during DOSMAJ90 process (validation of folder)
# call by DOSMAJ90
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If APPLI=GDOSX3: End : Endif
If GPRODUIT<>2 : End : Endif #not X3 People
Call AMAJ_EMHRMAJ90_FLD(APPLI)
End

