Subprog C_LVEACCLSTDEB(VALEUR)
Variable Char    VALEUR()

Call UNICITE(VALEUR,[M]LVEACCLSTDEB(0..[M]NBRLIG-1)) From OBJDIV
If mkstat : End : Endif

If VALEUR <> ""
 Call LECTEXTRA([M]LVELSTDESDEB(nolign-1),"HRLVESUBHEA","DES",GCURLEG,VALEUR) From ATEXTRA
Endif
End
######################################################################################
$BAL_AFT_TRF
 [M]LVEBALAFTDEB(nolign-1) = VALEUR + [M]LVEBALDAYDEB(nolign-1)
Return
######################################################################################

Subprog C_LVETRFDEB(VALEUR)
Variable Decimal VALEUR
If VALEUR < 0 :GERR1:GMESSAGE="This value can only be between 0 - 999.9999" :mkstat=2:Endif
Gosub BAL_AFT_TRF
End

######################################################################################
Subprog C_LVEACCLSTFIN(VALEUR)
Variable Char    VALEUR()

Call UNICITE(VALEUR,[M]LVEACCLSTFIN(0..[M]NBRLIG1-1)) From OBJDIV
If mkstat : End : Endif

If VALEUR <> ""
 Call LECTEXTRA([M]LVELSTDESDEB(nolign-1),"HRLVESUBHEA","DES",GCURLEG,VALEUR) From ATEXTRA
Endif
End

Subprog AM_LVEACCLSTFIN(VALEUR)
Variable Char    VALEUR()
Local Decimal  BALANCE, ACCRUAL, TAKENINCYCLE
Local Date DAT
Local Integer CHKOK,CHOK
BALANCE = 0
ACCRUAL = 0

Call CNTRL_TRF_TO(VALEUR,CHOK)
If CHOK=1:mkstat=2:Affzo [M]25:End:Endif
Gosub DSP_TIM_FIN
Call CHARGE_LAST_ACC_DAT([M]CTRNUMFIN, CHKOK,DAT) From SUBHRLAF
#MIPEA 2018-02-27 X3-74480 - START
Call GET_BALANCE([M]CTRNUMFIN,VALEUR,DAT,BALANCE,ACCRUAL,TAKENINCYCLE, 0, GCURLEG) From SUBHRBAL
#Call GET_BALANCE([M]CTRNUMFIN,VALEUR,DAT,BALANCE,ACCRUAL,TAKENINCYCLE) From SUBHRBAL
#MIPEA 2018-02-27 X3-74480 - END
[M]LVEBALDAYFIN([M]NBRLIG1) = BALANCE
[M]LVETRFFIN([M]NBRLIG1)  = [M]LVETRFDEB([M]NBRLIG-1)
Gosub BAL_AFT_TRANS_EMPTO
End
######################################################################################
$DSP_TIM_FIN
Local Char TIM(GLONTPS)
TIM = ""
For [HRACCR1] Where CTR=[M]CTRNUMFIN
 If [F:HRACCR1]LVEACCLST=VALEUR
  TIM = [F:HRACCR1]LVEACCTIM
 Break
 Endif
Next
[M]LVEACCTIMFIN([M]NBRLIG1) = TIM
Affzo [M]LVEACCTIMFIN([M]NBRLIG1)
Return
