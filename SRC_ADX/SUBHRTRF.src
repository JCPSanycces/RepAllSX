Subprog AS_LVEACCLSTDEB(VALEUR)
Variable Char    VALEUR()
Raz GCURLEG
GCURLEG = [M]LEG
End

Subprog AS_LVEACCLSTFIN(VALEUR)
Variable Char    VALEUR()
Raz GCURLEG
GCURLEG = [M]LEGFIN
End

######################################################################################
$EMP_TRF

If [M]EMPDIF <> 2 Then
 [M]REFNUMFIN = [M]REFNUMDEB
 [M]CTRNUMFIN = [M]CTRNUMDEB
 [M]LEGFIN = [M]LEG
 [M]SRVFIN = [M]SRVDEB
 [M]FCYFIN = [M]FCYDEB
 [M]NAMFIN = [M]NAMDEB
 [M]FNAMEFIN = [M]FNAMEDEB
 Affzo [M]10
Else
Affzo [M]10
Endif

Return
######################################################################################
$LVEBALAFTFIN
[M]LVEBALAFTFIN(nolign-1) = ([M]LVEBALDAYFIN(nolign-1) + [M]LVETRFFIN(nolign-1))
Return
######################################################################################

Subprog AS_EMPDIF(VALEUR)
Variable Integer VALEUR
Gosub EMP_TRF
End


