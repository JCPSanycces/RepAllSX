#<AdxTL>@(#)0.0.0.0 $Revision$
#####################################################################################
# GESHRLAF - LEAVE TRANSFER - 2017-07-12 - JIRA: X3-39436
#
#
######################################################################################
GUSRAUZ(1) = "123456"
GFONCTION = "GESHRTRF"
Local Char PARAM(30)(1..3) ,  VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"OHRTRF","SUBHRTRF","",5,"XWHRTRF") From GTRAITE
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "ABA"         : Gosub ABANDON
 When "BOUTON"      : Gosub BOUTON
Endcase
Return
###################################################################
$OUVRE
Local Mask HRTRF [TRF]
Case GACTION
 When "HRTRF" : GFONCTION = "GESHRTRF"
Endcase

If clalev([F:HRCTR])=0  : Local File EMPLOCTR [HRCTR]  : Endif
If clalev([F:HRCTR1])=0  : Local File EMPLOCTR [HRCTR1]  : Endif
If clalev([F:ID])=0  : Local File EMPLOID [ID]  : Endif
If clalev([F:ID1])=0  : Local File EMPLOID [ID1]  : Endif
If clalev([F:HRACCR])=0  : Local File HRLVEACCRU [HRACCR]  : Endif
If clalev([F:HRACCR1])=0  : Local File HRLVEACCRU [HRACCR1]  : Endif
If clalev([F:TIM])=0  : Local File TIMCOD [TIM]  : Endif
Raz [TRF]
Return
####################################################################

$ABANDON
GREP = "" : REP = ""
Effzo [TRF]
Return
###################################################################
$BOUTON
##Button Transfer
If [M]LVEACCLSTFIN(nolign-1) <> "" Then
  Gosub CHARGE_TRANS_FROM
  Gosub CHARGE_TRANS_TO
Else
 zonsui = "[M]LVEACCLSTFIN(nolign-1)"
 GERR = 1
 #GMEESAGE =
Endif
Return
#########################################################################
$DEBUT
If [M]EMPDIF <> 2 Then
Diszo [M]REFNUMFIN
Diszo [M]CTRNUMFIN
Endif
Return
######################################################################################

Subprog AM_REFNUMDEB(VALEUR)
Variable Char    VALEUR()
Read [ID]ID0 = VALEUR
[M]NAMDEB = [F:ID]NAM
[M]FNAMEDEB = [F:ID]SRNCNT
Affzo NAMDEB,FNAMEDEB
Raz [M]CTRNUMDEB
If [F:ID]FLGMULCTR<>2
 Effzo CTRNUMDEB
 Diszo CTRNUMDEB
 Affzo CTRNUMDEB
Else
 Actzo CTRNUMDEB
 Affzo CTRNUMDEB
Endif

If [F:ID]FLGMULCTR<>2 Then
  Filter [HRCTR] Where REFNUM=VALEUR
  Read[HRCTR]CTR1 Last
  Filter [HRCTR]
  If !fstat
   [M]FCYDEB= [F:HRCTR]ETRFCY
   [M]SRVDEB= [F:HRCTR]ETRSRV
   [M]CTRNUMDEB = [F:HRCTR]CTRNUM
   Call GET_LEG([M]CTRNUMDEB,[M]LEG) From SUBHRLAF
   #[M]LEG = GCURLEG
   #Gosub CHARGE_TR_FROM
  Endif
  Affzo FCYDEB, SRVDEB,CTRNUMDEB,LEG
Else
  Filter [HRCTR] Where REFNUM=VALEUR
  Read [HRCTR]CTR1 Last
  Filter [HRCTR]
  If !fstat
   [M]FCYDEB    = [F:HRCTR]ETRFCY
   [M]SRVDEB    = [F:HRCTR]ETRSRV
  Endif
  Affzo FCYDEB, SRVDEB
Endif

Affzo [M]5-20
End

Subprog AM_REFNUMFIN(VALEUR)
Variable Char    VALEUR()
Read [ID1]ID0 = VALEUR
[M]NAMFIN = [F:ID1]NAM
[M]FNAMEFIN = [F:ID1]SRNCNT
Affzo NAMFIN,FNAMEFIN
Raz [M]CTRNUMFIN
If [F:ID1]FLGMULCTR<>2
 Effzo CTRNUMFIN
 Diszo CTRNUMFIN
 Affzo CTRNUMFIN
Else
 Actzo CTRNUMFIN
 Affzo CTRNUMFIN
Endif

If [F:ID1]FLGMULCTR<>2 Then
  Filter [HRCTR1] Where REFNUM=VALEUR
  Read[HRCTR1]CTR1 Last
  Filter [HRCTR1]
  If !fstat
   [M]FCYFIN= [F:HRCTR1]ETRFCY
   [M]SRVFIN= [F:HRCTR1]ETRSRV
   [M]CTRNUMFIN = [F:HRCTR1]CTRNUM
   Call GET_LEG([M]CTRNUMFIN,[M]LEGFIN) From SUBHRLAF
  # [M]LEGFIN = GCURLEG
  #Gosub CHARGE_TR_TO
  Endif
  Affzo FCYFIN, SRVFIN,CTRNUMFIN,LEGFIN
Else
  Filter [HRCTR1] Where REFNUM=VALEUR
  Read [HRCTR1]CTR1 Last
  Filter [HRCTR1]
  If !fstat
   [M]FCYFIN    = [F:HRCTR1]ETRFCY
   [M]SRVFIN    = [F:HRCTR1]ETRSRV
  Endif
  Affzo FCYFIN, SRVFIN
Endif
Gosub EMP_TRF
Affzo [M]10-25
End


######################################################################################

Subprog C_CTRNUMDEB(VALEUR)
Variable Char    VALEUR()
Call GET_LEG(VALEUR,[M]LEG) From SUBHRLAF
#[M]LEG = GCURLEG
Affzo [M]LEG
#Gosub CHARGE_TR_FROM
End

Subprog C_CTRNUMFIN(VALEUR)
Variable Char    VALEUR()
Call GET_LEG([M]CTRNUMFIN,[M]LEGFIN) From SUBHRLAF
#[M]LEGFIN = GCURLEG
Affzo [M]LEGFIN
#Gosub CHARGE_TR_TO
End

Subprog AM_EMPDIF(VALEUR)
Variable Integer VALEUR
If VALEUR <> 1 Then
  Actzo [M]REFNUMFIN
  Actzo [M]CTRNUMFIN
  Affzo [M]10-25
  Actzo [M]25
  Raz GCURLEG
Else
  Diszo [M]REFNUMFIN
  Diszo [M]CTRNUMFIN
  Effzo [M]10
  Effzo [M]25

Endif
End


######################################################################################
$DSP_TIM_DEB
Local Char TIM(GLONTPS)
TIM = ""
For [HRACCR] Where CTR=[M]CTRNUMDEB
 If [F:HRACCR]LVEACCLST=VALEUR
  TIM = [F:HRACCR]LVEACCTIM
 Break
 Endif
Next
[M]LVEACCTIMDEB(nolign-1) = TIM
Affzo [M]LVEACCTIMDEB(nolign-1)
Return
######################################################################################
Subprog AM_LVEACCLSTDEB(VALEUR)
Variable Char    VALEUR()
Local Decimal  BALANCE, ACCRUAL, TAKENINCYCLE
Local Date DAT
Local Integer CHKOK
BALANCE = 0
ACCRUAL = 0
TAKENINCYCLE = 0

Gosub DSP_TIM_DEB
Call CHARGE_LAST_ACC_DAT([M]CTRNUMDEB, CHKOK,DAT) From SUBHRLAF
#MIPEA 2018-02-27 X3-74480 - START
Call GET_BALANCE([M]CTRNUMDEB,VALEUR,DAT,BALANCE,ACCRUAL,TAKENINCYCLE, 0, GCURLEG) From SUBHRBAL
#Call GET_BALANCE([M]CTRNUMDEB,VALEUR,DAT,BALANCE,ACCRUAL,TAKENINCYCLE) From SUBHRBAL
#MIPEA 2018-02-27 X3-74480 - END
[M]LVEBALDAYDEB(nolign-1) = BALANCE

End

