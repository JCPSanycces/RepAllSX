######################################################################################

Subprog AM_LVETRFDEB(VALEUR)
Variable Decimal VALEUR
Gosub BAL_AFT_TRANS_EMPFROM
End
######################################################################################

Subprog CNTRL_TRF_TO(VALEUR,CHOK)
Variable Char VALEUR()
Variable Integer CHOK
#If [M]CTRNUMDEB = [M]CTRNUMFIN and [M]LVEACCLSTDEB(nolign-1) = VALEUR and VALEUR<>"" Then
If [M]CTRNUMDEB = [M]CTRNUMFIN and VALEUR<>"" Then
For nolign=1 To [M]NBRLIG
  If [M]LVEACCLSTDEB(nolign-1) = VALEUR
  GERR=1
  GMESSAGE = "The leave sub type to cannot be the same as the entered leave sub type from"
  CHOK=1
  Affzo [M]25
  Endif
Next

Endif

End
######################################################################################

$BAL_AFT_TRANS_EMPTO
[M]LVEBALAFTFIN([M]NBRLIG1) = [M]LVEBALDAYFIN([M]NBRLIG1) + [M]LVETRFFIN([M]NBRLIG1)
Return
######################################################################################

$BAL_AFT_TRANS_EMPFROM
[M]LVEBALAFTDEB(nolign-1) = [M]LVEBALDAYDEB(nolign-1) - VALEUR
Return
######################################################################################

Subprog CONTLSTCTR(VALEUR,CTR)
Variable Char VALEUR
Value Char CTR

    If clalev([TIM]) = 0      : Local File TIMCOD [TIM] Endif
    If clalev([HRLSTD]) = 0      : Local File HRLVESUBDET [HRLSTD] Endif
    If clalev([HRLSTH]) = 0      : Local File HRLVESUBHEA [HRLSTH] Endif
    If clalev([HRLSTH1]) = 0      : Local File HRLVESUBHEA [HRLSTH1] Endif
    If clalev([HRCTR]) = 0    : Local File EMPLOCTR [HRCTR] Endif
    If clalev ([ID]) = 0      : Local File EMPLOID [ID] Endif
    If clalev ([FCY]) = 0     : Local File FACILITY [FCY] Endif
    If clalev ([CPY]) = 0     : Local File COMPANY [CPY] Endif
    If clalev ([HRPOA]) = 0   : Local File POPULA [HRPOA] Endif
    If clalev ([HRACCR]) = 0   : Local File HRLVEACCRU [HRACCR] Endif
    If clalev ([HRACCR1]) = 0   : Local File HRLVEACCRU [HRACCR1] Endif
    If clalev([F:HRPEOD])=0 : Local File HRPEODET   [HRPEOD] : Endif
    If clalev([F:VEP2])=0   : Local File VALEMP     [VEP2]  : Endif
    If clalev([F:DCG])=0 : Local File DEMCONGE   [DCG] : Endif

    Local Integer S(1),L
    Local Char CRITACC(250)
    Local Char LIS_HRLST(GLONHRLST)(0..100)
    Filter [TIM] Where ([TIM]CATTIM=3 |[TIM]CATTIM=2)  and [TIM]ENAFLG=2
#Looping 1. HRTIM 2. HRLST 3.HRCTR/HRMAT
    For [TIM]
      For S=1 To dim([TIM]LVESUBTYP)
        If [TIM]LVESUBTYP(S-1) <> ""
          CRITACC = "1=0"
          For [HRLSTD] Where [HRLSTD]COD = [TIM]LVESUBTYP(S-1)
            Case [HRLSTD]LEV
              When 1  : CRITACC = CRITACC - " | 1=1"  #Folder
              When 2  : CRITACC = CRITACC - " | ([F:CPY]LEG = '"+[F:HRLSTD]LEG+"')" #[F:HRLSTD]LEG)"  #Legislation
              When 3  : CRITACC = CRITACC - " | ([HRPOA]COD = '"+[F:HRLSTD]POP+"')" #[F:HRLSTD]POP)"  #Population
              When 4  : CRITACC = CRITACC - " | ([F:CPY]CPY = '"+[F:HRLSTD]CPY+"')" #[F:HRLSTD]CPY)"  #Company
              When 5  : CRITACC = CRITACC - " | ([F:FCY]FCY = '"+[F:HRLSTD]FCY+"')" #[F:HRLSTD]FCY)"  #Site
              When 6  : CRITACC = CRITACC - " | ([F:ID]REFNUM = '"+[F:HRLSTD]REFNUM+"')"  #Employee
              When 7  : CRITACC = CRITACC - " | ([F:HRCTR]CTRNUM = '"+[F:HRLSTD]CTRNUM+"')" #[F:HRLSTD]CTRNUM)"  #Contract
              When 8  : CRITACC = CRITACC - " | ([F:SRV]COD = '"+[F:HRLSTD]SERVICE+"')" #[F:HRLSTD]SERVICE)"  #Department
              When 9  : CRITACC = CRITACC - " | ([F:HRCLV]COD = '"+[F:HRLSTD]CLLCVT+"')" #[F:HRLSTD]CLLCVT)"  #Collective agreement
              When 10 : CRITACC = CRITACC - " | ([F:PRF]COD = '"+[F:HRLSTD]PRFCOD+"')" #[F:HRLSTD]PRFCOD)"  #Profile
            Endcase
           Next

If [HRLSTD]LEV=3
           Link [HRCTR] With
&             [ID]ID0=[F:HRCTR]REFNUM,
&             [FCY]FCY0=[F:HRCTR]ETRFCY,
&             [CPY]CPY0=[F:FCY]LEGCPY,
&             [HRPOA]POA0=[F:HRLSTD]POP;[F:HRCTR]REFNUM;[F:HRCTR]CTRNUM;[F:HRCTR]CTRDAT
&          As [LNK]
&          Where evalue(CRITACC)
Else
           Link [HRCTR] With
&             [ID]ID0=[F:HRCTR]REFNUM,
&             [FCY]FCY0=[F:HRCTR]ETRFCY,
&             [CPY]CPY0=[F:FCY]LEGCPY
& As [LNK]
&          Where evalue(CRITACC)
Endif

Filter [LNK] Where CTRNUM=CTR
If rowcount([LNK])>0 & !find([TIM]LVESUBTYP(S-1),LIS_HRLST(0..100)) : LIS_HRLST(L) = [TIM]LVESUBTYP(S-1) : L+=1 : Endif
Filter [LNK]
            Endif
        Next
      Next
If !find(VALEUR,LIS_HRLST)>0 Then
GERR=1
GMESSAGE = "The leave sub type is not compatible to the contract you have entered"
mkstat = 2 :End
Endif
End

###############################################################################################################

Subprog CHARGE_LAST_EXP_DAT(VALEUR,FLD,LVE)
Variable Char    VALEUR()
Variable Char    LVE
Variable Date FLD

Filter [HRACCR] Where CTR = VALEUR and LVEACCLST = LVE
Read [HRACCR] Last
Filter [HRACCR]
If !fstat
  FLD = [F:HRACCR]LVEACCEXP
Endif

End

###############################################################################################################
$CHARGE_TRANS_FROM

Local Date FLDXP,FLDAT

For nolign=1 To [M]NBRLIG
   Call CHARGE_LAST_ACC_DAT([M]CTRNUMDEB,FLDAT,[M]LVEACCLSTDEB(nolign-1))
   Call CHARGE_LAST_EXP_DAT([M]CTRNUMDEB,FLDXP,[M]LVEACCLSTDEB(nolign-1))
   Gosub GET_TRANSNR From SUBHRLAF
   [F:HRACCR]LVEACCTRS        = [L]ACC
   [F:HRACCR]CTR              = [M]CTRNUMDEB
   [F:HRACCR]LVEACCEXP        = FLDXP
   [F:HRACCR]LVEACCDAT        = FLDAT
   [F:HRACCR]LVEACCLST        = [M]LVEACCLSTDEB(nolign-1)
   [F:HRACCR]LVEACCTIM        = [M]LVEACCTIMDEB(nolign-1)
   [F:HRACCR]LVEACCAMT        = "-"+num$([M]LVETRFDEB(nolign-1))
   [F:HRACCR]SYSDAT           = datesyst
   [F:HRACCR]LVEACCTYP        = "Transfer"
  Write [HRACCR]
   If fstat<>0
    GOK = 0 : Call FSTA("HRACCR") From GLOCK : Gosub AB_TR1 From SUBHRLAF
   Endif
   Raz FLDXP
   Raz FLDAT
Next

Return

###############################################################################################################
$CHARGE_TRANS_TO

Local Date FLDXP,FLDAT
For nolign=1 To [M]NBRLIG1
   Call CHARGE_LAST_ACC_DAT([M]CTRNUMFIN,FLDAT,[M]LVEACCLSTFIN(nolign-1))
   Call CHARGE_LAST_EXP_DAT([M]CTRNUMFIN,FLDXP,[M]LVEACCLSTFIN(nolign-1))
   Gosub GET_TRANSNR From SUBHRLAF
   [F:HRACCR1]LVEACCTRS        = [L]ACC
   [F:HRACCR1]CTR              = [M]CTRNUMFIN
   [F:HRACCR1]LVEACCEXP        = FLDXP
   [F:HRACCR1]LVEACCDAT        = FLDAT
   [F:HRACCR1]LVEACCLST        = [M]LVEACCLSTFIN(nolign-1)
   [F:HRACCR1]LVEACCTIM        = [M]LVEACCTIMFIN(nolign-1)
   [F:HRACCR1]LVEACCAMT        = num$([M]LVETRFFIN(nolign-1))
   [F:HRACCR1]SYSDAT           = datesyst
   [F:HRACCR1]LVEACCTYP        = "Transfer"
  Write [HRACCR1]
   If fstat<>0
    GOK = 0 : Call FSTA("HRACCR1") From GLOCK : Gosub AB_TR1 From SUBHRLAF
   Endif
   Raz FLDXP
   Raz FLDAT
Next

Return

###############################################################################################################

Subprog CHARGE_LAST_ACC_DAT(VALEUR,FLDAT,LVE)
Variable Char    VALEUR()
Variable Char    LVE
Variable Date FLDAT

Filter [HRACCR] Where CTR = VALEUR and LVEACCLST = LVE
Read [HRACCR] Last
Filter [HRACCR]
If !fstat
  FLDAT = [F:HRACCR]LVEACCDAT
Endif

End
###############################################################################################################
Subprog CHK_EMPCTR(EMP,OK)
Variable Char EMP
Variable Integer OK
OK=0

Filter [HRCTR] Where REFNUM = EMP
Read [HRCTR] First
Filter [HRCTR]
If fstat
 GMESSAGE = mess(00150,10702,1)
 OK=1
Endif
End
