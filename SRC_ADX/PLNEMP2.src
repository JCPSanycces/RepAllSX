#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOS(DOSSIER,"") From SAIDOS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("PLNEMP2") From LECFIC
  Endif

  Call PATCH(DOSSIER) From PLNEMP2

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End

$AVANT_OUVRE
#GBOITE = "WFPLE"
GBOITE = "WFPLET"
BOITE = GBOITE
# FQ92876 - 27/05/14 - Choix de la transaction de saisie des axes
Gosub DEFTRANS From PLNEMP2
Return

$DEFTRANS
If clalev([F:CDT])=0 : Local File CADIETPS    [CDT] : Endif
Local  Integer  XVARINB  : XVARINB = 0
Local  Integer  XVARIREP : XVARIREP = 0
Local  Char     XVARITEX(40)(200)
Local  Char     XVARITEXTRA(40)
Local  Char     XVARICOD(10)(200)
Global Char     GXFLAG(10)

#If GFLAG="" : GXFLAG=GSCHCDT : Endif
#If GXFLAG<>""
# XVARIREP = 1
# Read [F:CDT]CDT0=GXFLAG
# If !fstat Then
#  XVARITEX(XVARIREP) = GXFLAG-[F:CDT]DES
#  XVARICOD(XVARIREP) = GXFLAG
# Endif
# Return
#Endif

GOK = 1
For [CDT]CDT0
 XVARINB += 1
 XVARITEX(XVARINB) = [F:CDT]COD-[F:CDT]DES
 XVARICOD(XVARINB) = [F:CDT]COD
Next

If XVARINB=0
 OK=0
Elsif XVARINB=1
 GXFLAG  = [F:CDT]COD
Else
 If XVARIREP=0 : XVARIREP=1 :Endif
 Call SAITEX(XVARINB,XVARITEX,XVARIREP,mess(3,126,1)) From GESECRAN : # Choix transaction
 If status<>7 & XVARIREP<>0
  GXFLAG  = XVARICOD(XVARIREP)
 Endif
Endif
If GXFLAG="" : OK=0 : Endif

Return

$BOUTON
If BOUT="B" & [M:PLE0]REFNUM<>"" & [M:PLE0]YEA<>0 & [M:PLE0]NUMWEK<>0 & [M:PLE0]CTRNUM<>""
 # Raffraichissement de l'écran après calcul du calendrier
 Gosub REMPLIT
 Gosub MASK_CCE From PLNEMP2
Endif
If BOUT="C" & GSTATUT=GSTAOK
 # Raffraichissement de l'écran après Recopie Jour
 Gosub REMPLIT
 Gosub MASK_CCE From PLNEMP2
Endif
# 50000
If BOUT="D"
 # Raffraichissement de l'écran après Annulation
 Gosub REMPLIT
 Gosub MASK_CCE From PLNEMP2
Endif
Return

$OUVRE
# FQ92876 - 27/05/14 - Si aucune transaction de saisie des axes n'a été sélectionnée, on sort de la fonction
If GXFLAG="" Then
  FIN=1
Else
  # FQ92876 - 27/05/14 - La transaction de saisie des axes sélectionnée doit avoir au plus 9 axes
  Read [F:CDT]CDT0 = GXFLAG
  If !fstat & [F:CDT]NBRDIE>9 Then
    # Cette transaction de saisie comporte un nombre d’axes analytique supérieur à 9.
    # Elle ne peut pas être utilisée.
    #ADNGO - 2017-01-13 - X3-11992 - START
    #Infbox GXFLAG-":"-mess(206,709,1)+chr$(10)+mess(209,709,1)
    Infbox GXFLAG-":"-mess(206,10709,1)+chr$(10)+mess(209,10709,1)
    #ADNGO - 2017-01-13 - X3-11992 - END
    FIN=1
  Endif

  If clalev([F:PLE])=0 : Local File PLANEMP         [PLE] : Endif
  If clalev([F:ID])=0  : Local File EMPLOID         [ID]  : Endif
  If clalev([F:ACC])=0 : Local File ACCES           [ACC] : Endif
  If clalev([F:FCY])=0 : Local File FACILITY        [FCY] : Endif
  #ADNGO - 2017-01-13 - X3-11992 - START
  #If clalev([F:CTR])=0 : Local File EMPLOCTR        [CTR] : Endif
  If clalev([F:HRCTR])=0 : Local File EMPLOCTR        [HRCTR] : Endif
  #ADNGO - 2017-01-13 - X3-11992 - END
  If clalev([F:ECT])=0 : Local File EMPCTR          [ECT] : Endif
  If clalev([F:CPY])=0 : Local File COMPANY         [CPY] : Endif
  #41724
  #ADNGO - 2017-01-13 - X3-11992 - START
  #If clalev([F:PEO])=0 : Local File PERIOD          [PEO] : Endif
  If clalev([F:HRPEOD])=0 : Local File HRPEODET          [HRPEOD] : Endif
  #ADNGO - 2017-01-13 - X3-11992 - END
  # 92876
  If clalev([F:DIE])=0 : Local File =GTABCPT+"GDIE" [DIE] : Endif
  If clalev([F:AXX])=0 : Local File ATEXTRA         [AXX] : Endif
Endif
Return

$DEBUT
Local Integer I, J, K, L, COL, OK, DEFILE
Local Char    SYMBOLE(50), SITE(GLONFCY)
Raz [M]
DEFILE = 1
#MAXCCE = GOPTCANA
# FQ92876 - 02/06/14 - Répartition sur GNBHOR onglets, donc plus de limitation
#If GNBHOR=2 & MAXCCE>8 : MAXCCE = 8 : Endif
#If GNBHOR=3 & MAXCCE>4 : MAXCCE = 4 : Endif
#ADNGO - 2017-01-13 - X3-11992 - START
#[M]LIB1 = mess(131,709,1) : # Type de jour
[M]LIB1 = mess(131,10709,1) : # Type de jour
#ADNGO - 2017-01-13 - X3-11992 - END
J = 1
#MAXPLG = max(GNBHOR,1)
#If MAXPLG=0 : MAXPLG = 1 : Endif
#For K=1 To L
# If GNBHOR>0
#  J +=1
#  Assign "[M]LIB"+num$(J) With mess(134,709,1)-num$(K) : # Plage
#  J +=1
#  Assign "[M]LIB"+num$(J) With mess(135,709,1) : # Pause
# Endif
# J +=1
# Assign "[M]LIB"+num$(J) With mess(136,709,1) : # Activité
# For I=1 To MAXCCE
#  J +=1
#  Assign "[M]LIB"+num$(J) With mess(I,601,1)
# Next
#Next
#J +=1
#Assign "[M]LIB"+num$(J) With mess(132,709,1) : # Nb heures
#Chgstl [PLE] ="LIB"+num$(J)  With "RELIEF"
#J +=1
#Assign "[M]LIB"+num$(J) With mess(133,709,1) : # Nb jours
#Chgstl [PLE] ="LIB"+num$(J)  With "RELIEF"

Read [F:CDT]CDT0=GXFLAG
If !fstat Then
  [M:PLE0]NBRDIE=[F:CDT]NBRDIE
  Local Char INTITDIE(30)(0..[M:PLE0]NBRDIE-1)
  For I=0 To [M:PLE0]NBRDIE-1
    If [F:CDT]DIE(I)<>"" Then
      Call LECTEXTRA(INTITDIE(I),"GDIE","SHOTRA",[F:CDT]DIE(I),"") From ATEXTRA
      If INTITDIE(I)="" Then INTITDIE(I)=[F:CDT]DIE(I) : Endif
      [M:PLE0]DIE(I)=[F:CDT]DIE(I)
    Endif
  Next
Endif
Gosub DEF_VAR_CCE
For K=1 To MAXPLG
 J = 1
 If GNBHOR>0
  J +=1
#ADNGO - 2017-01-13 - X3-11992 - START
#  Assign "[M:PLE"+num$(K)+"]LIB"+num$(J) With mess(134,709,1)-num$(K) : # Plage
#  J +=1
#  Assign "[M:PLE"+num$(K)+"]LIB"+num$(J) With mess(135,709,1) : # Pause
#Endif
# J +=1
# Assign "[M:PLE"+num$(K)+"]LIB"+num$(J) With mess(136,709,1) : # Activité
  Assign "[M:PLE"+num$(K)+"]LIB"+num$(J) With mess(134,10709,1)-num$(K) : # Plage
  J +=1
  Assign "[M:PLE"+num$(K)+"]LIB"+num$(J) With mess(135,10709,1) : # Pause
Endif
 J +=1
 Assign "[M:PLE"+num$(K)+"]LIB"+num$(J) With mess(136,10709,1) : # Activité
#ADNGO - 2017-01-13 - X3-11992 - END
# 114841 : authoring if GNBHOR=0. forced J+1
If GNBHOR>0
   J +=1
#ADNGO - 2017-01-13 - X3-11992 - START
#  Assign "[M:PLE"+num$(K)+"]LIB"+num$(J) With mess(208,709,1) : # Total plages
#  Chgstl ="[M:PLE"+num$(K)+"]LIB"+num$(J)  With "RELIEF"
#Endif#
# J +=1
# Assign "[M:PLE"+num$(K)+"]LIB"+num$(J) With mess(132,709,1) : # Nb heures
## Chgstl ="[M:PLE"+num$(K)+"]LIB"+num$(J)  With "RELIEF"
# J +=1
# Assign "[M:PLE"+num$(K)+"]LIB"+num$(J) With mess(133,709,1) : # Nb jours
## Chgstl ="[M:PLE"+num$(K)+"]LIB"+num$(J)  With "RELIEF"
  Assign "[M:PLE"+num$(K)+"]LIB"+num$(J) With mess(208,10709,1) : # Total plages
  Chgstl ="[M:PLE"+num$(K)+"]LIB"+num$(J)  With "RELIEF"
Endif#
 J +=1
 Assign "[M:PLE"+num$(K)+"]LIB"+num$(J) With mess(132,10709,1) : # Nb heures
# Chgstl ="[M:PLE"+num$(K)+"]LIB"+num$(J)  With "RELIEF"
 J +=1
 Assign "[M:PLE"+num$(K)+"]LIB"+num$(J) With mess(133,10709,1) : # Nb jours
# Chgstl ="[M:PLE"+num$(K)+"]LIB"+num$(J)  With "RELIEF"
#ADNGO - 2017-01-13 - X3-11992 - END
 J +=1
 Assign "[M:PLE"+num$(K)+"]LIB"+num$(J) With ""
 For I=1 To min(GOPTCANA,9)
  J +=1
  If I<=[M:PLE0]NBRDIE Then
#  Assign "[M:PLE"+num$(K)+"]LIB"+num$(J) With mess(I,601,1)
    Assign "[M:PLE"+num$(K)+"]LIB"+num$(J) With INTITDIE(I-1)
  Else
    Assign "[M:PLE"+num$(K)+"]LIB"+num$(J) With ""
  Endif
 Next
Next
Gosub INIPAR
Gosub MASK_CCE
#Affzo [PLE]PREWEK,SUIWEK
#Affzo 10
Affzo [M:PLE0]PREWEK,SUIWEK
If MAXPLG>=1 Then Affzo [M:PLE1]10 : Endif
If MAXPLG>=2 Then Affzo [M:PLE2]10 : Endif
If MAXPLG>=3 Then Affzo [M:PLE3]10 : Endif
Return

$DEF_VAR_CCE
Local Integer MAXCCE,MAXPLG

  MAXPLG = max(GNBHOR,1)
  MAXCCE = GOPTCANA
  If [M:PLE0]NBRDIE>0 Then MAXCCE=[M:PLE0]NBRDIE : Endif
Return

# FQ92876 - 03/06/14 - Il faut masquer les axes non affichés car pas dans la transaction, et l'instruction Chgftm ="[M:PLE"+num$(K)+"]CCE"+num$... ne fonctionne pas
$MASK_CCE
Local Integer I
Local Char    W_FMT(5) : W_FMT="-K:1X"

  Gosub DEF_VAR_CCE

  If [M:PLE0]NBRDIE<GOPTCANA Then
    For I=[M:PLE0]NBRDIE+1 To GOPTCANA
      Case I
        When 2 :
          Chgfmt [M:PLE1]CCE211 With W_FMT : Chgfmt [M:PLE1]CCE221 With W_FMT : Chgfmt [M:PLE1]CCE231 With W_FMT : Chgfmt [M:PLE1]CCE241 With W_FMT
          Chgfmt [M:PLE1]CCE251 With W_FMT : Chgfmt [M:PLE1]CCE261 With W_FMT : Chgfmt [M:PLE1]CCE271 With W_FMT
          If MAXPLG>=2 Then
            Chgfmt [M:PLE2]CCE212 With W_FMT : Chgfmt [M:PLE2]CCE222 With W_FMT : Chgfmt [M:PLE2]CCE232 With W_FMT : Chgfmt [M:PLE2]CCE242 With W_FMT
            Chgfmt [M:PLE2]CCE252 With W_FMT : Chgfmt [M:PLE2]CCE262 With W_FMT : Chgfmt [M:PLE2]CCE272 With W_FMT
          Endif
          If MAXPLG>=3 Then
            Chgfmt [M:PLE3]CCE213 With W_FMT : Chgfmt [M:PLE3]CCE223 With W_FMT : Chgfmt [M:PLE3]CCE233 With W_FMT : Chgfmt [M:PLE3]CCE243 With W_FMT
            Chgfmt [M:PLE3]CCE253 With W_FMT : Chgfmt [M:PLE3]CCE263 With W_FMT : Chgfmt [M:PLE3]CCE273 With W_FMT
          Endif
        When 3 :
          Chgfmt [M:PLE1]CCE311 With W_FMT : Chgfmt [M:PLE1]CCE321 With W_FMT : Chgfmt [M:PLE1]CCE331 With W_FMT : Chgfmt [M:PLE1]CCE341 With W_FMT
          Chgfmt [M:PLE1]CCE351 With W_FMT : Chgfmt [M:PLE1]CCE361 With W_FMT : Chgfmt [M:PLE1]CCE371 With W_FMT
          If MAXPLG>=2 Then
            Chgfmt [M:PLE2]CCE312 With W_FMT : Chgfmt [M:PLE2]CCE322 With W_FMT : Chgfmt [M:PLE2]CCE332 With W_FMT : Chgfmt [M:PLE2]CCE342 With W_FMT
            Chgfmt [M:PLE2]CCE352 With W_FMT : Chgfmt [M:PLE2]CCE362 With W_FMT : Chgfmt [M:PLE2]CCE372 With W_FMT
          Endif
          If MAXPLG>=3 Then
            Chgfmt [M:PLE3]CCE313 With W_FMT : Chgfmt [M:PLE3]CCE323 With W_FMT : Chgfmt [M:PLE3]CCE333 With W_FMT : Chgfmt [M:PLE3]CCE343 With W_FMT
            Chgfmt [M:PLE3]CCE353 With W_FMT : Chgfmt [M:PLE3]CCE363 With W_FMT : Chgfmt [M:PLE3]CCE373 With W_FMT
          Endif
        When 4 :
          Chgfmt [M:PLE1]CCE411 With W_FMT : Chgfmt [M:PLE1]CCE421 With W_FMT : Chgfmt [M:PLE1]CCE431 With W_FMT : Chgfmt [M:PLE1]CCE441 With W_FMT
          Chgfmt [M:PLE1]CCE451 With W_FMT : Chgfmt [M:PLE1]CCE461 With W_FMT : Chgfmt [M:PLE1]CCE471 With W_FMT
          If MAXPLG>=2 Then
            Chgfmt [M:PLE2]CCE412 With W_FMT : Chgfmt [M:PLE2]CCE422 With W_FMT : Chgfmt [M:PLE2]CCE432 With W_FMT : Chgfmt [M:PLE2]CCE442 With W_FMT
            Chgfmt [M:PLE2]CCE452 With W_FMT : Chgfmt [M:PLE2]CCE462 With W_FMT : Chgfmt [M:PLE2]CCE472 With W_FMT
          Endif
          If MAXPLG>=3 Then
            Chgfmt [M:PLE3]CCE413 With W_FMT : Chgfmt [M:PLE3]CCE423 With W_FMT : Chgfmt [M:PLE3]CCE433 With W_FMT : Chgfmt [M:PLE3]CCE443 With W_FMT
            Chgfmt [M:PLE3]CCE453 With W_FMT : Chgfmt [M:PLE3]CCE463 With W_FMT : Chgfmt [M:PLE3]CCE473 With W_FMT
          Endif
        When 5 :
          Chgfmt [M:PLE1]CCE511 With W_FMT : Chgfmt [M:PLE1]CCE521 With W_FMT : Chgfmt [M:PLE1]CCE531 With W_FMT : Chgfmt [M:PLE1]CCE541 With W_FMT
          Chgfmt [M:PLE1]CCE551 With W_FMT : Chgfmt [M:PLE1]CCE561 With W_FMT : Chgfmt [M:PLE1]CCE571 With W_FMT
          If MAXPLG>=2 Then
            Chgfmt [M:PLE2]CCE512 With W_FMT : Chgfmt [M:PLE2]CCE522 With W_FMT : Chgfmt [M:PLE2]CCE532 With W_FMT : Chgfmt [M:PLE2]CCE542 With W_FMT
            Chgfmt [M:PLE2]CCE552 With W_FMT : Chgfmt [M:PLE2]CCE562 With W_FMT : Chgfmt [M:PLE2]CCE572 With W_FMT
          Endif
          If MAXPLG>=3 Then
            Chgfmt [M:PLE3]CCE513 With W_FMT : Chgfmt [M:PLE3]CCE523 With W_FMT : Chgfmt [M:PLE3]CCE533 With W_FMT : Chgfmt [M:PLE3]CCE543 With W_FMT
            Chgfmt [M:PLE3]CCE553 With W_FMT : Chgfmt [M:PLE3]CCE563 With W_FMT : Chgfmt [M:PLE3]CCE573 With W_FMT
          Endif
        When 6 :
