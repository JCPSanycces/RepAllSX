$INIPAR
Local Integer K ,L
Local Date    DD
If PARAM(1)<>""
 [M:PLE0]REFNUM = PARAM(1)
 Call AM_REFNUM([M:PLE0]REFNUM) From PLNEMP
 Affzo [PLE0]REFNUM
Endif
If PARAM(3)<>""
 [M:PLE0]CTRNUM = PARAM(3)
 Call AM_CTRNUM([M:PLE0]CTRNUM) From PLNEMP
 Affzo [PLE0]CTRNUM
Endif
If PARAM(2)<>""
 DD = PARAM(2)
#MIPEA - 2017-11-20- US X3-63170- START
 If clalev([F:HRCTR8])=0 : Local File EMPLOCTR [HRCTR8] : Endif
 Filter [F:HRCTR8] Where [F:HRCTR8]REFNUM = [M:PLE0]REFNUM & [F:HRCTR8]CTRNUM = [M:PLE0]CTRNUM
 Read [F:HRCTR8] Last
 Filter [F:HRCTR8]
 Call SET_GFIRDAY([F:HRCTR8]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-20- US X3-63170- END
 Call DAT(DD,K,L) From SUBPLN
 [M:PLE0]YEA = K
 [M:PLE0]NUMWEK = L
 Call C_NUMWEK([M:PLE0]NUMWEK) From PLNEMP
 Call AM_NUMWEK([M:PLE0]NUMWEK) From PLNEMP
 If [M:PLE0]NUMWEK<>0 & [M:PLE0]REFNUM<>"" & [M:PLE0]CTRNUM<>""
  Grizo [PLE0] 5
  Affzo [PLE0] 5
 Endif
 GTUNCPT(1)=1
Endif
Return

$APRES_MODIF
If COUZON<>"REFNUM" & COUZON<>"YEA" & COUZON<>"NUMWEK" & COUZON<>"CTRNUM"
 If GREP=""
  Gosub VERROU
  If OK
   GREP = "M" : REP = "M"
   Gosub GRISE
  Else
   GMESSAGE = mess(10,100,1) : # Modif en cours...
   GERR = 1
  Endif
 Endif
Endif
# Recalcul du nombre d'heures en fonction des plages horaires
If find(left$(COUZON,6),"STRTIM","ENDTIM","BRKTIM")
 Gosub DEF_VAR_CCE
# Local Integer MAXPLG
# MAXPLG = GNBHOR
# If MAXPLG=0 : MAXPLG = 1 : Endif
 Assign COUZON With zc
 Local Integer I
 I=val(mid$(COUZON,7,1))
 Local Decimal HRS
 Call SUMHRS(num$(I),HRS)
 If MAXPLG>=1 Then Assign "[M:PLE1]NBRHOU"+num$(I) With HRS : Affzo ="[M:PLE1]NBRHOU"+num$(I) : Endif
 If MAXPLG>=2 Then Assign "[M:PLE2]NBRHOU"+num$(I) With HRS : Affzo ="[M:PLE2]NBRHOU"+num$(I) : Endif
 If MAXPLG>=3 Then Assign "[M:PLE3]NBRHOU"+num$(I) With HRS : Affzo ="[M:PLE3]NBRHOU"+num$(I) : Endif
 If HRS=0 Then
  If MAXPLG>=1 Then Effzo ="[M:PLE1]NBRDAY"+num$(I) : Endif
  If MAXPLG>=2 Then Effzo ="[M:PLE2]NBRDAY"+num$(I) : Endif
  If MAXPLG>=3 Then Effzo ="[M:PLE3]NBRDAY"+num$(I) : Endif
 Endif
# Case mid$(COUZON,7,1)
#  When "1" : Call SUMHRS("1",[M:PLE]NBRHOU1) : Affzo [M:PLE]NBRHOU1
#             If [M:PLE]NBRHOU1=0 : Effzo [M:PLE]NBRDAY1 : Endif
#  When "2" : Call SUMHRS("2",[M:PLE]NBRHOU2) : Affzo [M:PLE]NBRHOU2
#             If [M:PLE]NBRHOU2=0 : Effzo [M:PLE]NBRDAY2 : Endif
#  When "3" : Call SUMHRS("3",[M:PLE]NBRHOU3) : Affzo [M:PLE]NBRHOU3
#             If [M:PLE]NBRHOU3=0 : Effzo [M:PLE]NBRDAY3 : Endif
#  When "4" : Call SUMHRS("4",[M:PLE]NBRHOU4) : Affzo [M:PLE]NBRHOU4
#             If [M:PLE]NBRHOU4=0 : Effzo [M:PLE]NBRDAY4 : Endif
#  When "5" : Call SUMHRS("5",[M:PLE]NBRHOU5) : Affzo [M:PLE]NBRHOU5
#             If [M:PLE]NBRHOU5=0 : Effzo [M:PLE]NBRDAY5 : Endif
#  When "6" : Call SUMHRS("6",[M:PLE]NBRHOU6) : Affzo [M:PLE]NBRHOU6
#             If [M:PLE]NBRHOU6=0 : Effzo [M:PLE]NBRDAY6 : Endif
#  When "7" : Call SUMHRS("7",[M:PLE]NBRHOU7) : Affzo [M:PLE]NBRHOU7
#             If [M:PLE]NBRHOU7=0 : Effzo [M:PLE]NBRDAY7 : Endif
# Endcase
Endif
Return

Subprog SUMHRS(COL,SUMHRS)
Value    Char COL
Variable Decimal SUMHRS
Local Decimal VALHMDEB, VALHMFIN
If GNBHOR>0
 Call CONVERTHM(evalue("[M]STRTIM"+COL+"1"),VALHMDEB) From SUBSTY
 Call CONVERTHM(evalue("[M]ENDTIM"+COL+"1"),VALHMFIN) From SUBSTY
 If VALHMDEB<=VALHMFIN
  SUMHRS = VALHMFIN-VALHMDEB-evalue("[M]BRKTIM"+COL+"1")
 Else
  SUMHRS = 24-VALHMDEB+VALHMFIN-evalue("[M]BRKTIM"+COL+"1")
 Endif
 If GNBHOR>1
  Call CONVERTHM(evalue("[M]STRTIM"+COL+"2"),VALHMDEB) From SUBSTY
  Call CONVERTHM(evalue("[M]ENDTIM"+COL+"2"),VALHMFIN) From SUBSTY
  If VALHMDEB<=VALHMFIN
   SUMHRS += VALHMFIN-VALHMDEB-evalue("[M]BRKTIM"+COL+"2")
  Else
   SUMHRS += 24-VALHMDEB+VALHMFIN-evalue("[M]BRKTIM"+COL+"2")
  Endif
  If GNBHOR>2
   Call CONVERTHM(evalue("[M]STRTIM"+COL+"3"),VALHMDEB) From SUBSTY
   Call CONVERTHM(evalue("[M]ENDTIM"+COL+"3"),VALHMFIN) From SUBSTY
   If VALHMDEB<=VALHMFIN
    SUMHRS += VALHMFIN-VALHMDEB-evalue("[M]BRKTIM"+COL+"3")
   Else
    SUMHRS += 24-VALHMDEB+VALHMFIN-evalue("[M]BRKTIM"+COL+"3")
   Endif
  Endif
 Endif
Endif
SUMHRS = ar2(SUMHRS)
End

$SETBOUT
If GTUNCPT(1)=1
 CHBOU = ""
 CHMEN = ""
Else
 CHMEN = ""
 REPORT1 = GREPORT1
 REPORT2 = ""
 If GREP=""
  # Bouton "Initialisation"
  CHMEN +="B"
  # Bouton "Annulation"
  CHMEN +="D"
 Endif
 If [M]REFNUM<>"" & GREP=""
  # Bouton "Recopie jour"
  CHMEN +="C"
 Endif
 Case DEFILE
  When 1 : CHMEN += "2"
  When 2 : CHMEN += "1"
  When 3 : CHMEN += "2"
 Endcase
Endif
Gosub SET_BOUT_STD From GSAISIE
Gosub SET_BOUT_SPE From GSAISIE
Return

$MENU
Case BOUT
 When "1"
  DEFILE = 1
 When "2"
  DEFILE = 2
Endcase
Return

$SUI
Case DEFILE
 When 1 : # Par matricule
  Gosub FILTRE From TPSSUB
  Read [LID]ECT0 > [M:PLE0]REFNUM;[M:PLE0]CTRNUM
 When 2 : # Par site/service
  Gosub FILTRE From TPSSUB
  Read [LID]ECT1 > [M:PLE0]FCY;[M:PLE0]SRV;[M:PLE0]REFNUM;[M:PLE0]CTRNUM
 When 3 : # Par semaine
  Local Integer K ,L
#MIPEA - 2017-11-20- US X3-63170- START
  If clalev([F:HRCTR8])=0 : Local File EMPLOCTR [HRCTR8] : Endif
  Filter [F:HRCTR8] Where [F:HRCTR8]REFNUM = [M:PLE0]REFNUM & [F:HRCTR8]CTRNUM = [M:PLE0]CTRNUM
  Read [F:HRCTR8] Last
  Filter [F:HRCTR8]
  Call SET_GFIRDAY([F:HRCTR8]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-20- US X3-63170- END
  Call DAT([M:PLE0]DAT(0)+7,K,L) From SUBPLN
  [M:PLE0]YEA    = K
  [M:PLE0]NUMWEK = L
  Affzo [M:PLE0]YEA, NUMWEK
  Raz fstat
Endcase
Goto SUIVPREC
Return

$PRE
Case DEFILE
 When 1
  Gosub FILTRE From TPSSUB
  Read [LID]ECT0 < [M:PLE0]REFNUM;[M:PLE0]CTRNUM
 When 2
  Gosub FILTRE From TPSSUB
  Read [LID]ECT1 < [M:PLE0]FCY;[M:PLE0]SRV;[M:PLE0]REFNUM;[M:PLE0]CTRNUM
 When 3
  Local Integer K ,L
#MIPEA - 2017-11-20- US X3-63170- START
 If clalev([F:HRCTR8])=0 : Local File EMPLOCTR [HRCTR8] : Endif
 Filter [F:HRCTR8] Where [F:HRCTR8]REFNUM = [M:PLE0]REFNUM & [F:HRCTR8]CTRNUM = [M:PLE0]CTRNUM
 Read [F:HRCTR8] Last
 Filter [F:HRCTR8]
 Call SET_GFIRDAY([F:HRCTR8]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-20- US X3-63170- END
  Call DAT([M:PLE0]DAT(0)-7,K,L) From SUBPLN
  [M:PLE0]YEA    = K
  [M:PLE0]NUMWEK = L
  Affzo [M:PLE0]YEA, NUMWEK
  Raz fstat
Endcase
Goto SUIVPREC
Return

$FIR
Case DEFILE
 When 1
  Gosub FILTRE From TPSSUB
  Read [LID]ECT0 First
 When 2
  Gosub FILTRE From TPSSUB
  Read [LID]ECT1 First
Endcase
Goto SUIVPREC

$LAS
Case DEFILE
 When 1
  Gosub FILTRE From TPSSUB
  Read [LID]ECT0 Last
 When 2
  Gosub FILTRE From TPSSUB
  Read [LID]ECT1 Last
Endcase
Goto SUIVPREC

$SUIVPREC
If fstat<=2
 If DEFILE<3
  [M:PLE0]REFNUM = [F:ID]REFNUM
  [M:PLE0]CTRNUM = [F:ECT]CTRNUM
  [M:PLE0]NAM    = [F:ID]NAM-[F:ID]SRN
  If [F:ID]FLGMULCTR<>2
   Diszo [M:PLE0]CTRNUM
  Else
   Actzo [M:PLE0]CTRNUM
  Endif
  Affzo [M:PLE0]REFNUM, CTRNUM, NAM
  #Call AM_REFNUM([M]REFNUM) From PLNEMP
  Call AM_CTRNUM([M:PLE0]CTRNUM) From PLNEMP
 Else
  Call AM_NUMWEK([M:PLE0]NUMWEK) From PLNEMP
 Endif
Endif
Return

$GRISE
Diszo [M:PLE0]REFNUM, YEA, NUMWEK, CTRNUM
Return

$DEGRISE
Actzo [M:PLE0]REFNUM, YEA, NUMWEK
If [F:ID]FLGMULCTR=2
  Actzo [M:PLE0]CTRNUM
Endif
Return

$VERROU
SYMBOLE = "PLE"+num$([M:PLE0]YEA)+"\"+[M:PLE0]REFNUM+"\"+num$([M:PLE0]NUMWEK)+"\"+[M:PLE0]CTRNUM
Lock =SYMBOLE
If fstat
 OK = 0
Else
 OK = 1
Endif
Return

$DEVERROU
If SYMBOLE<>""
 Unlock =SYMBOLE
 SYMBOLE = ""
Endif
Return

$ENREGISTRE
Call DEBTRANS From GLOCK
Gosub TR_ENR
GREP = "" : REP = ""
Gosub DEGRISE
Gosub DEVERROU
Gosub CHARGE
Return

$TR_ENR
Local Integer OKDIE
GOK = 1
Trbegin [PLE]
 For I=0 To 6
  Delete [PLE]PLE0=[M:PLE0]REFNUM;[M:PLE0]DAT(I);[M:PLE0]CTRNUM
 Next
 L = GNBHOR
 If L=0 : L = 1 : Endif
 Raz [F:PLE]
 [F:PLE]REFNUM = [M:PLE0]REFNUM
 [F:PLE]YEA    = [M:PLE0]YEA
 [F:PLE]CTRNUM = [M:PLE0]CTRNUM
 If dim([F:PLE]CREDAT)>0 : [F:PLE]CREDAT = date$ : Endif
 If dim([F:PLE]CREUSR)>0 : [F:PLE]CREUSR = GUSER : Endif
 If dim([F:PLE]CRETIM)>0 : [F:PLE]CRETIM = time  : Endif
 For I=0 To 6
  [F:PLE]DAT = [M:PLE0]DAT(I)
#  Case I
#   When 0
#    [F:PLE]TYPDAY = [M]TYPDAY1
#    [F:PLE]NBRDAY = [M]NBRDAY1
#    [F:PLE]NBRHOU = [M]NBRHOU1
#   When 1
#    [F:PLE]TYPDAY = [M]TYPDAY2
#    [F:PLE]NBRDAY = [M]NBRDAY2
#    [F:PLE]NBRHOU = [M]NBRHOU2
#   When 2
#    [F:PLE]TYPDAY = [M]TYPDAY3
#    [F:PLE]NBRDAY = [M]NBRDAY3
#    [F:PLE]NBRHOU = [M]NBRHOU3
#   When 3
#    [F:PLE]TYPDAY = [M]TYPDAY4
#    [F:PLE]NBRDAY = [M]NBRDAY4
#    [F:PLE]NBRHOU = [M]NBRHOU4
#   When 4
#    [F:PLE]TYPDAY = [M]TYPDAY5
#    [F:PLE]NBRDAY = [M]NBRDAY5
#    [F:PLE]NBRHOU = [M]NBRHOU5
#   When 5
#    [F:PLE]TYPDAY = [M]TYPDAY6
#    [F:PLE]NBRDAY = [M]NBRDAY6
#    [F:PLE]NBRHOU = [M]NBRHOU6
#   When 6
#    [F:PLE]TYPDAY = [M]TYPDAY7
#    [F:PLE]NBRDAY = [M]NBRDAY7
#    [F:PLE]NBRHOU = [M]NBRHOU7
#  Endcase
  [F:PLE]TYPDAY = evalue("[M:PLE1]TYPDAY"+num$(I+1))
  [F:PLE]NBRDAY = evalue("[M:PLE1]NBRDAY"+num$(I+1))
  [F:PLE]NBRHOU = evalue("[M:PLE1]NBRHOU"+num$(I+1))
  For K=1 To GOPTCANA
   [F:PLE]DIE(K-1)=[M:PLE0]DIE(K-1)
  Next
  For J=1 To L
   If GNBHOR>0
    [F:PLE]STRTIM(J-1) = evalue("[M:PLE"+num$(J)+"]STRTIM"+num$(I+1)+num$(J))
    [F:PLE]ENDTIM(J-1) = evalue("[M:PLE"+num$(J)+"]ENDTIM"+num$(I+1)+num$(J))
    [F:PLE]BRKTIM(J-1) = evalue("[M:PLE"+num$(J)+"]BRKTIM"+num$(I+1)+num$(J))
   Endif
   [F:PLE]NATCOD(J-1) = evalue("[M:PLE"+num$(J)+"]NATCOD"+num$(I+1)+num$(J))
   For K=1 To min(GOPTCANA,9)
    Call CPY_AXE (K, [M:PLE0]FCYD(I), OKDIE) From TPSDIV
    If OK
      If evalue("dim([M:PLE"+num$(J)+"]CCE"+num$(K)+num$(I+1)+num$(J)+")")>0
       Assign "[F:PLE]CCE"+num$(K)+"(J-1)" With evalue("[M:PLE"+num$(J)+"]CCE"+num$(K)+num$(I+1)+num$(J))
      Else
       Assign "[F:PLE]CCE"+num$(K)+"(J-1)" With evalue("[M:PLE0]ICCE"+num$(K)+"("+num$(7*(J-1)+I+1)+")")
      Endif
    Endif
   Next
  Next
  Write [PLE]
  If fstat
   GOK = 0 : Call FSTA("PLE") From GLOCK
   Break
  Endif
 Next
 If GOK=0 : Goto AB_TR_ENR : Endif
Commit
Return

$AB_TR_ENR
Rollback
Return

$ABANDON
Gosub CHARGE
GREP = "" : REP = ""
Gosub DEGRISE
Gosub DEVERROU
Return

$FIN
Gosub DEVERROU
Raz [M:PLE0]
Return

$CHARGE
Local Integer I,J,L,COL
Local Date    DATFIN
Gosub TITBLOC
Gosub REMPLIT
Gosub MASK_CCE From PLNEMP2
Return

$TITBLOC
#MIPEA - 2017-11-20- US X3-63170- START
If clalev([F:HRCTR8])=0 : Local File EMPLOCTR [HRCTR8] : Endif
Filter [F:HRCTR8] Where [F:HRCTR8]REFNUM = [M:PLE0]REFNUM & [F:HRCTR8]CTRNUM = [M:PLE0]CTRNUM
Read [F:HRCTR8] Last
Filter [F:HRCTR8]
Call SET_GFIRDAY([F:HRCTR8]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-20- US X3-63170- END
Call SEMAINE([M:PLE0]YEA,[M:PLE0]NUMWEK,DAT,DATFIN) From SUBPLN
# FQ92876
#Chgtbk [PLE]15 With day$(DAT)-format$("D:DD[/]MM[/]YY",DAT)
#Chgtbk [PLE]20 With day$(DAT+1)-format$("D:DD[/]MM[/]YY",DAT+1)
#Chgtbk [PLE]25 With day$(DAT+2)-format$("D:DD[/]MM[/]YY",DAT+2)
#Chgtbk [PLE]30 With day$(DAT+3)-format$("D:DD[/]MM[/]YY",DAT+3)
#Chgtbk [PLE]35 With day$(DAT+4)-format$("D:DD[/]MM[/]YY",DAT+4)
#Chgtbk [PLE]40 With day$(DAT+5)-format$("D:DD[/]MM[/]YY",DAT+5)
#Chgtbk [PLE]45 With day$(DAT+6)-format$("D:DD[/]MM[/]YY",DAT+6)
#[M]DAT(0) = DAT
#[M]DAT(1) = DAT+1
#[M]DAT(2) = DAT+2
#[M]DAT(3) = DAT+3
#[M]DAT(4) = DAT+4
#[M]DAT(5) = DAT+5
#[M]DAT(6) = DAT+6
Gosub DEF_VAR_CCE
If MAXPLG>=1 Then
  Chgtbk [M:PLE1]15 With day$(DAT)-format$("D:DD[/]MM[/]YY",DAT)
  Chgtbk [M:PLE1]20 With day$(DAT+1)-format$("D:DD[/]MM[/]YY",DAT+1)
  Chgtbk [M:PLE1]25 With day$(DAT+2)-format$("D:DD[/]MM[/]YY",DAT+2)
  Chgtbk [M:PLE1]30 With day$(DAT+3)-format$("D:DD[/]MM[/]YY",DAT+3)
  Chgtbk [M:PLE1]35 With day$(DAT+4)-format$("D:DD[/]MM[/]YY",DAT+4)
  Chgtbk [M:PLE1]40 With day$(DAT+5)-format$("D:DD[/]MM[/]YY",DAT+5)
  Chgtbk [M:PLE1]45 With day$(DAT+6)-format$("D:DD[/]MM[/]YY",DAT+6)
  Affzo [M:PLE1]
Endif
If MAXPLG>=2 Then
  Chgtbk [M:PLE2]15 With day$(DAT)-format$("D:DD[/]MM[/]YY",DAT)
  Chgtbk [M:PLE2]20 With day$(DAT+1)-format$("D:DD[/]MM[/]YY",DAT+1)
  Chgtbk [M:PLE2]25 With day$(DAT+2)-format$("D:DD[/]MM[/]YY",DAT+2)
  Chgtbk [M:PLE2]30 With day$(DAT+3)-format$("D:DD[/]MM[/]YY",DAT+3)
  Chgtbk [M:PLE2]35 With day$(DAT+4)-format$("D:DD[/]MM[/]YY",DAT+4)
  Chgtbk [M:PLE2]40 With day$(DAT+5)-format$("D:DD[/]MM[/]YY",DAT+5)
  Chgtbk [M:PLE2]45 With day$(DAT+6)-format$("D:DD[/]MM[/]YY",DAT+6)
  Affzo [M:PLE2]
Endif
If MAXPLG>=3 Then
  Chgtbk [M:PLE3]15 With day$(DAT)-format$("D:DD[/]MM[/]YY",DAT)
  Chgtbk [M:PLE3]20 With day$(DAT+1)-format$("D:DD[/]MM[/]YY",DAT+1)
  Chgtbk [M:PLE3]25 With day$(DAT+2)-format$("D:DD[/]MM[/]YY",DAT+2)
  Chgtbk [M:PLE3]30 With day$(DAT+3)-format$("D:DD[/]MM[/]YY",DAT+3)
  Chgtbk [M:PLE3]35 With day$(DAT+4)-format$("D:DD[/]MM[/]YY",DAT+4)
  Chgtbk [M:PLE3]40 With day$(DAT+5)-format$("D:DD[/]MM[/]YY",DAT+5)
  Chgtbk [M:PLE3]45 With day$(DAT+6)-format$("D:DD[/]MM[/]YY",DAT+6)
  Affzo [M:PLE3]
Endif
[M:PLE0]DAT(0) = DAT
[M:PLE0]DAT(1) = DAT+1
[M:PLE0]DAT(2) = DAT+2
[M:PLE0]DAT(3) = DAT+3
[M:PLE0]DAT(4) = DAT+4
[M:PLE0]DAT(5) = DAT+5
[M:PLE0]DAT(6) = DAT+6
Local Integer AFFDATA : AFFDATA=0
Gosub PRESENCE From TPSJOU
Return


Subprog INIT_TYPDAY(TYPJOU,JOU)
Variable Integer TYPJOU
Value    Integer JOU
Local    Integer ANNEE, SEMAINE
#ADNGO - 2017-01-13 - X3-11992 - START
#If clalev([F:CTR])=0 : Local File EMPLOCTR [CTR] : Endif
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
#ADNGO - 2017-01-13 - X3-11992 - END
If clalev([F:PLN])=0 : Local File PLANTYP  [PLN] : Endif
If clalev([F:WTY])=0 : Local File TYPWEEK  [WTY] : Endif
#57346
If clalev([F:HLY])=0 : Local File HLYDAY   [HLY] : Endif

# SEGAY 06/12/12 78403
# Si la date de l'écran = 00/00/00 on gardait le dernier enregistrement de CTR
#ADNGO - 2017-01-13 - X3-11992 - START
#Raz [F:CTR] : # SEGAY 06/12/12 78403
Raz [F:HRCTR] : # SEGAY 06/12/12 78403
#ADNGO - 2017-01-13 - X3-11992 - END
# FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat
#Filter [CTR] Where REFNUM=[M:PLE]REFNUM & CTRNUM=[M]CTRNUM & CTRDAT<=[M:PLE]DAT(JOU-1)
#Filter [CTR] Where REFNUM=[M:PLE]REFNUM & CTRNUM=[M]CTRNUM & (CTRDAT<=[M:PLE]DAT(JOU-1) | (FLGRET=2 & RETDATEFF<=[M:PLE]DAT(JOU-1)))
#ADNGO - 2017-01-13 - X3-11992 - START
#Filter [CTR] Where REFNUM=[M:PLE0]REFNUM & CTRNUM=[M:PLE0]CTRNUM & (CTRDAT<=[M:PLE0]DAT(JOU-1) | (FLGRET=2 & RETDATEFF<=[M:PLE0]DAT(JOU-1)))
Filter [HRCTR] Where REFNUM=[M:PLE0]REFNUM & CTRNUM=[M:PLE0]CTRNUM & (CTRDAT<=[M:PLE0]DAT(JOU-1) | (FLGRET=2 & RETDATEFF<=[M:PLE0]DAT(JOU-1)))
#ADNGO - 2017-01-13 - X3-11992 - END
# Fin MABON
#ADNGO - 2017-01-13 - X3-11992 - START
#Read [CTR]CTR0 Last
#Filter [CTR]
Read [HRCTR]CTR0 Last
Filter [HRCTR]
#ADNGO - 2017-01-13 - X3-11992 - END
# FQ85820 - 29/04/13 - On cherche si on a une fiche de rétroactivité relative au champ PLNTYP
#Read [PLN]PLN0=[M:PLE]YEA;[F:CTR]PLNTYP
Local Char CTRPLNTYP(GLONPLN)
#ADNGO - 2017-01-13 - X3-11992 - START
#CTRPLNTYP=func SUBCTRRET.FIND_RETRO_FLD([M:PLE0]REFNUM,[M:PLE0]CTRNUM,[F:CTR]CTRDAT,[M:PLE0]DAT(6),"PLNTYP","CTR")
CTRPLNTYP=func SUBCTRRET.FIND_RETRO_FLD([M:PLE0]REFNUM,[M:PLE0]CTRNUM,[F:HRCTR]CTRDAT,[M:PLE0]DAT(6),"PLNTYP","HRCTR")
#Read [PLN]PLN0=[M:PLE0]YEA;CTRPLNTYP
Read [PLN]PLN0=[M:PLE0]YEA;CTRPLNTYP;GCURLEG
#ADNGO - 2017-01-13 - X3-11992 - END
# Fin FQ85820
#MIPEA - 2017-11-20- US X3-63170- START
 Call SET_GFIRDAY([F:HRCTR]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-20- US X3-63170- END
If !fstat
 ANNEE = [M:PLE0]YEA
 Call DAT([M:PLE0]DAT(JOU-1),ANNEE,SEMAINE) From SUBPLN
 #ADNGO - 2017-01-26 - X3-11992 - START
 #Call LECTURE("STY",[F:PLN]WEKTYP(SEMAINE-1),"") From CONTOBJ
 Call LECTURE("STY",[F:PLN]WEKTYP(SEMAINE-1),GCURLEG) From CONTOBJ
 #ADNGO - 2017-01-26 - X3-11992 - END
 TYPJOU = [F:WTY]TYPDAY(JOU-1)
Else
 Case mod(GFIRDAY+JOU-1,7)
  When 6       : TYPJOU = 1
  When 0       : TYPJOU = 3
  When Default : TYPJOU = 2
 Endcase
Endif
#57346 : prendre year([M:PLE]DAT(JOU-1)) au lieu de ANNEE (cas du 01/01/2010 sur année 2009)
#ADNGO - 2017-01-26 - X3-11992 - START
#Read [HLY]HLY0 = year([M:PLE0]DAT(JOU-1));[M:PLE0]FCY
Read [HLY]HLY0 = year([M:PLE0]DAT(JOU-1));[M:PLE0]FCY;GCURLEG
#ADNGO - 2017-01-26 - X3-11992 - END
If fstat
#ADNGO - 2017-01-26 - X3-11992 - START
 #Read [HLY]HLY0 = year([M:PLE0]DAT(JOU-1));""
 Read [HLY]HLY0 = year([M:PLE0]DAT(JOU-1));"";GCURLEG
#ADNGO - 2017-01-26 - X3-11992 - END
Endif
If !fstat & find([M:PLE0]DAT(JOU-1),[F:HLY]HLYDAY(0..[F:HLY]NBRDAY-1))
 TYPJOU = 3 : # Chômé
Endif
#fin 57346
End

$REMPLIT
Local Integer NBPLG, I
Local Integer TYPJOU
Actzo 15-45
Effzo 15-45
If [M]PRE(1)=0 : Diszo 15 : Endif
If [M]PRE(2)=0 : Diszo 20 : Endif
If [M]PRE(3)=0 : Diszo 25 : Endif
If [M]PRE(4)=0 : Diszo 30 : Endif
If [M]PRE(5)=0 : Diszo 35 : Endif
If [M]PRE(6)=0 : Diszo 40 : Endif
If [M]PRE(7)=0 : Diszo 45 : Endif
L = GNBHOR
If L=0 : L=1 : Endif
If L>=1 Then Actzo [M:PLE1]15-45 : Effzo [M:PLE1]15-45 : Endif
If L>=2 Then Actzo [M:PLE2]15-45 : Effzo [M:PLE2]15-45 : Endif
If L>=3 Then Actzo [M:PLE3]15-45 : Effzo [M:PLE3]15-45 : Endif
Filter [PLE] Where REFNUM=[M:PLE0]REFNUM & CTRNUM=[M:PLE0]CTRNUM & YEA=[M:PLE0]YEA & DAT>=[M:PLE0]DAT(0) & DAT<=[M:PLE0]DAT(6)
For [PLE]PLE0
 If find([F:PLE]DAT,[M:PLE0]DAT)>0 Then
  COL=find([F:PLE]DAT,[M:PLE0]DAT)
  For NBPLG=1 To L
    Assign "[M:PLE"+num$(NBPLG)+"]TYPDAY"+num$(COL) With [F:PLE]TYPDAY
    Assign "[M:PLE"+num$(NBPLG)+"]NBRHOU"+num$(COL) With [F:PLE]NBRHOU
    Assign "[M:PLE"+num$(NBPLG)+"]NBRDAY"+num$(COL) With [F:PLE]NBRDAY
    If [F:PLE]TYPDAY=0 Then
      Call INIT_TYPDAY(TYPJOU,COL)
      Assign "[M:PLE"+num$(NBPLG)+"]TYPDAY"+num$(COL) With TYPJOU
    Endif
  Next
  Gosub REMP_PLG
 Endif
Next
#If [M]TYPDAY1=0 : Call INIT_TYPDAY([M]TYPDAY1,1) : Endif
#If [M]TYPDAY2=0 : Call INIT_TYPDAY([M]TYPDAY2,2) : Endif
#If [M]TYPDAY3=0 : Call INIT_TYPDAY([M]TYPDAY3,3) : Endif
#If [M]TYPDAY4=0 : Call INIT_TYPDAY([M]TYPDAY4,4) : Endif
#If [M]TYPDAY5=0 : Call INIT_TYPDAY([M]TYPDAY5,5) : Endif
#If [M]TYPDAY6=0 : Call INIT_TYPDAY([M]TYPDAY6,6) : Endif
#If [M]TYPDAY7=0 : Call INIT_TYPDAY([M]TYPDAY7,7) : Endif
Filter [PLE]
If L>=1 Then Affzo [M:PLE1]15-45 : Endif
If L>=2 Then Affzo [M:PLE2]15-45 : Endif
If L>=3 Then Affzo [M:PLE3]15-45 : Endif

For I=0 To 6
  #ADNGO - 2017-01-13 - X3-11992 - START
  #Filter [F:CTR] Where REFNUM=[M:PLE0]REFNUM & CTRNUM=[M:PLE0]CTRNUM & CTRDAT<=[M:PLE0]DAT(I) Order By CTRDAT Desc
  Filter [F:HRCTR] Where REFNUM=[M:PLE0]REFNUM & CTRNUM=[M:PLE0]CTRNUM & CTRDAT<=[M:PLE0]DAT(I) Order By CTRDAT Desc
  #Read [F:CTR] First
  Read [F:HRCTR] First
  #ADNGO - 2017-01-13 - X3-11992 - END
  If !fstat Then
    #ADNGO - 2017-01-13 - X3-11992 - START
    #[M:PLE0]FCYD(I)=func SUBCTRRET.FIND_RETRO_FLD([M:PLE0]REFNUM,[M:PLE0]CTRNUM,[F:CTR]CTRDAT,[M:PLE0]DAT(I),"ETRFCY","CTR")
    [M:PLE0]FCYD(I)=func SUBCTRRET.FIND_RETRO_FLD([M:PLE0]REFNUM,[M:PLE0]CTRNUM,[F:HRCTR]CTRDAT,[M:PLE0]DAT(I),"ETRFCY","HRCTR")
    #ADNGO - 2017-01-13 - X3-11992 - END
  Endif
  #ADNGO - 2017-01-13 - X3-11992 - START
  #Filter [F:CTR]
  Filter [F:HRCTR]
  #ADNGO - 2017-01-13 - X3-11992 - END
Next
Return

$REMP_PLG
Local Integer K,LI
# Parcours sur les plages horaires
# Suivant le nombre d'axes et de plages horaires, toutes les sections ne peuvent pas être affichées
# sur le même écran. Celles qui ne sont pas saisissables à l'écran sont saisies par clic droit.
# Les variables écran ICCE stockent les valeurs des sections qui sont saisies par clic droit
#MABOS-13/08/13-FQ91804-ajout de - If evalue("dim([M]ICCEn("+num$(J+COL-1)+"))")>0 - n=5..9
For I=1 To L
 J = 7*(I-1)
 If GNBHOR>0
  Assign "[M:PLE"+num$(I)+"]STRTIM"+num$(COL)+num$(I) With [F:PLE]STRTIM(I-1)
  Assign "[M:PLE"+num$(I)+"]ENDTIM"+num$(COL)+num$(I) With [F:PLE]ENDTIM(I-1)
  Assign "[M:PLE"+num$(I)+"]BRKTIM"+num$(COL)+num$(I) With [F:PLE]BRKTIM(I-1)
 Endif
 Assign "[M:PLE"+num$(I)+"]NATCOD"+num$(COL)+num$(I) With [F:PLE]NATCOD(I-1)
 # FQ92876 - 05/06/14 - Simplification du code
# If dim([M:PLE1]CCE111)>0 & [F:PLE]DIE(I-1)=[M:PLE0]DIE(I-1)
#  Assign "[M:PLE"+num$(I)+"]CCE1"+num$(COL)+num$(I) With [F:PLE]CCE1(I-1)
# Endif
# If dim([M:PLE1]CCE211)>0 & [F:PLE]DIE(I-1)=[M:PLE0]DIE(I-1)
#  Assign "[M:PLE"+num$(I)+"]CCE2"+num$(COL)+num$(I) With [F:PLE]CCE2(I-1)
# Endif
# If dim([M:PLE1]CCE311)>0 & [F:PLE]DIE(I-1)=[M:PLE0]DIE(I-1)
#  Assign "[M:PLE"+num$(I)+"]CCE3"+num$(COL)+num$(I) With [F:PLE]CCE3(I-1)
# Endif
# If dim([M:PLE1]CCE411)>0 & [F:PLE]DIE(I-1)=[M:PLE0]DIE(I-1)
#  Assign "[M:PLE"+num$(I)+"]CCE4"+num$(COL)+num$(I) With [F:PLE]CCE4(I-1)
# Endif
# If dim([M:PLE1]CCE511)>0 & [F:PLE]DIE(I-1)=[M:PLE0]DIE(I-1)
#  Assign "[M:PLE"+num$(I)+"]CCE5"+num$(COL)+num$(I) With [F:PLE]CCE5(I-1)
# Elsif GOPTCANA>=5
#  If evalue("dim([M:PLE0]ICCE5("+num$(J+COL-1)+"))")>0 : #91804
#   Assign "[M:PLE0]ICCE5("+num$(J+COL-1)+")" With [F:PLE]CCE5(I-1)
#  Endif
# Endif
# If dim([M:PLE1]CCE611)>0 & [F:PLE]DIE(I-1)=[M:PLE0]DIE(I-1)
#  Assign "[M:PLE"+num$(I)+"]CCE6"+num$(COL)+num$(I) With [F:PLE]CCE6(I-1)
# Elsif GOPTCANA>=6
#  If evalue("dim([M:PLE0]ICCE6("+num$(J+COL-1)+"))")>0 : #91804
#   Assign "[M:PLE0]ICCE6("+num$(J+COL-1)+")" With [F:PLE]CCE6(I-1)
#  Endif
# Endif
# If dim([M:PLE1]CCE711)>0 & [F:PLE]DIE(I-1)=[M:PLE0]DIE(I-1)
#   Assign "[M:PLE"+num$(I)+"]CCE7"+num$(COL)+num$(I) With [F:PLE]CCE7(I-1)
# Elsif GOPTCANA>=7
#  If evalue("dim([M:PLE0]ICCE7("+num$(J+COL-1)+"))")>0 : #91804
#   Assign "[M:PLE0]ICCE7("+num$(J+COL-1)+")" With [F:PLE]CCE7(I-1)
#  Endif
# Endif
# If dim([M:PLE1]CCE811)>0 & [F:PLE]DIE(I-1)=[M:PLE0]DIE(I-1)
#  Assign "[M:PLE"+num$(I)+"]CCE8"+num$(COL)+num$(I) With [F:PLE]CCE8(I-1)
# Elsif GOPTCANA>=8
#  If evalue("dim([M:PLE0]ICCE8("+num$(J+COL-1)+"))")>0 : #91804
#   Assign "[M:PLE0]ICCE8("+num$(J+COL-1)+")" With [F:PLE]CCE8(I-1)
#  Endif
# Endif
# If dim([M:PLE1]CCE911)>0 & [F:PLE]DIE(I-1)=[M:PLE0]DIE(I-1)
#  Assign "[M:PLE"+num$(I)+"]CCE9"+num$(COL)+num$(I) With [F:PLE]CCE9(I-1)
# Elsif GOPTCANA>=9
#  If evalue("dim([M:PLE0]ICCE9("+num$(J+COL-1)+"))")>0 : #91804
#   Assign "[M:PLE0]ICCE9("+num$(J+COL-1)+")" With [F:PLE]CCE9(I-1)
#  Endif
# Endif
 For K=1 To min(GOPTCANA,9)
  LI=find([M:PLE0]DIE(K-1),[F:PLE]DIE)
  If LI>0 & LI<=9 Then
#   If evalue("dim([M:PLE"+num$(I)+"]CCE"+num$(K)+"1"+num$(I)+")")>0 & [F:PLE]DIE(I-1)=[M:PLE0]DIE(I-1)
#     Assign "[M:PLE"+num$(I)+"]CCE"+num$(K)+num$(COL)+num$(I) With evalue("[F:PLE]CCE"+num$(K)+"(I-1)")
   If evalue("dim([M:PLE"+num$(I)+"]CCE"+num$(K)+"1"+num$(I)+")")>0
     Assign "[M:PLE"+num$(I)+"]CCE"+num$(K)+num$(COL)+num$(I) With evalue("[F:PLE]CCE"+num$(LI)+"(I-1)")
   Endif
  Endif
 Next
Next
Return


######################################################################################
## Génération de l'écran
######################################################################################
Subprog GENDOS(APPLI)
Value Char APPLI()
If clalev([F:AMK])=0  : Local File =APPLI+".AMSK"       [AMK]  : Endif
If clalev([F:AMZ])=0  : Local File =APPLI+".AMSKZON"    [AMZ]  : Endif
If clalev([F:AMA])=0  : Local File =APPLI+".AMSKACT"    [AMA]  : Endif
If clalev([F:AMP])=0  : Local File =APPLI+".AMSKPAR"    [AMP]  : Endif
Local File =APPLI+".AWINDOW"    [AWI]
If clalev([F:AWP])=0  : Local File =APPLI+".AWINPAR"    [AWP]  : Endif
If clalev([F:AWT])=0  : Local File =APPLI+".AWINBOUT"   [AWT]  : Endif
If clalev([F:AMK2])=0 : Local File =APPLI+".AMSK"       [AMK2] : Endif
If clalev([F:AMZ2])=0 : Local File =APPLI+".AMSKZON"    [AMZ2] : Endif
If clalev([F:AMA2])=0 : Local File =APPLI+".AMSKACT"    [AMA2] : Endif
If clalev([F:AMP2])=0 : Local File =APPLI+".AMSKPAR"    [AMP2] : Endif
If clalev([F:AWI2])=0 : Local File =APPLI+".AWINDOW"    [AWI2] : Endif
If clalev([F:AWP2])=0 : Local File =APPLI+".AWINPAR"    [AWP2] : Endif
If clalev([F:AWT2])=0 : Local File =APPLI+".AWINBOUT"   [AWT2] : Endif
If clalev([F:ACV])=0  : Local File =APPLI+".ACTIV"      [ACV]  : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER   [ADS]  : Endif

Local Char    MASKDES(GLONAMK)(0..3) , MASKREF(GLONAMK)(0..3)
Local Char    WINREF(GLONFEN) , WINDES(GLONFEN)
Local Integer NOLIG, OLDBLOC, OK, BOUTCLIC : # Bouton clic droit pour saisir section ana
Local Decimal COL
Local Integer I
#Si on valide la transaction à partir d'un autre dossier les globales ne sont pas correctes
Local Integer IOPTCANA, INBHOR, INBPLG

Read [ACV]CODACT = "ANA"
IOPTCANA = max(0,[F:ACV]DIME)
Read [ACV]CODACT = "HOR"
# 114841 : min à 1 pour générer l'écran
# Ajout de la variable INBPLG
If !fstat & [F:ACV]FLACT=2
 INBHOR = max(1,[F:ACV]DIME)
 INBPLG=max(0,[F:ACV]DIME)
Else
 INBHOR=1
 INBPLG=0
Endif

MASKREF(0) = "PLNEMP0" : MASKREF(1) = "PLNEMP1" : MASKREF(2) = "PLNEMP2" : MASKREF(3) = "PLNEMP3"
MASKDES(0) = "WMPLE0"  : MASKDES(1) = "WMPLE1"  : MASKDES(2) = "WMPLE2"  : MASKDES(3) = "WMPLE3"
WINREF  = "PLNEMPT"
WINDES  = "WFPLET"

GOK=1
For I=0 To min(INBHOR,dim(MASKREF)-1)
  Call TR_DELMSK(MASKDES(I),APPLI) From MSKDIV
  If GOK=0 : Break : Endif
Next
If GOK=0 : End : Endif

Call TR_DELWIN(WINDES,APPLI) From MSKDIV
If GOK=0 : End : Endif

Call DEBTRANS From GLOCK
Gosub TR1
If GOK=0 : End : Endif

## Validation des écrans
Read [ADS]DOSSIER = APPLI
For I=0 To min(INBHOR,dim(MASKREF)-1)
  Call VALID(MASKDES(I),APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,1,OK) From VALMSK
  If !OK : GOK = 0 : End : Endif
Next

## Validation fenêtre
Call VALID(WINDES,APPLI,0,OK) From VALWIN
If !OK : GOK = 0 : End : Endif
End


$TR1
Local Integer I
Local Integer NUM
Local Char    INTONG(20)
If clalev([F:ATX])=0 : Local File ATEXTE [ATX] : Endif
GOK = 1
Trbegin [AMK]
For I=0 To min(INBHOR,dim(MASKREF)-1)
 Read [AMK2]CODMSK = MASKREF(I)
 [F:AMK] = [F:AMK2]
 [F:AMK]CODMSK = MASKDES(I)
 [F:AMK]MDL    = 1
 Write [AMK]
 If fstat : GOK=0 : Call FSTA("AMK") From GLOCK : Goto AB_TR1 : Endif
 Raz NOLIG, OLDBLOC
 For [AMZ2]CODZON Where CODMSK=MASKREF(I)
  Raz BOUTCLIC
  If OLDBLOC<>[F:AMZ2]NUMBLOC
   COL     = 0
   OLDBLOC = [F:AMZ2]NUMBLOC
  Endif
#  If [F:AMZ2]NUMBLOC=1 | [F:AMZ2]NUMBLOC=2 | [F:AMZ2]NUMBLOC=10
  If (I=0) | (I>0 & ([F:AMZ2]NUMBLOC=1 | [F:AMZ2]NUMBLOC=9))
   NOLIG += 1
   [F:AMZ] = [F:AMZ2]
   [F:AMZ]CODMSK = MASKDES(I)
   [F:AMZ]NUMLIG = NOLIG
   Write [AMZ]
   If fstat : GOK=0 : Call FSTA("AMZ") From GLOCK : Goto AB_TR1 : Endif
   Gosub COPIE_ACTION
   If GOK<1 : Break : Endif
  Else
#   Case INBHOR
#     When 0
#      If ([F:AMZ2]NOZONE<=13 & [F:AMZ2]NOZONE<>2.1 & [F:AMZ2]NOZONE<>2.2 & [F:AMZ2]NOZONE<>3)
#&       | [F:AMZ2]NOZONE=38 | [F:AMZ2]NOZONE=39
#       If left$([F:AMZ2]CODZON,3)<>"CCE" | val(mid$([F:AMZ2]CODZON,4,1))<=IOPTCANA
#        Gosub DUPLIC
#        Write [AMZ]
#        If fstat : GOK=0 : Call FSTA("AMZ") From GLOCK : Goto AB_TR1 : Endif
#        Gosub COPIE_ACTION
#        If GOK<1 : Break : Endif
#       Endif
#      Endif
#     When 1
#      If [F:AMZ2]NOZONE<=13 | [F:AMZ2]NOZONE=38 | [F:AMZ2]NOZONE=39
#       If left$([F:AMZ2]CODZON,3)<>"CCE" | val(mid$([F:AMZ2]CODZON,4,1))<=IOPTCANA
#        Gosub DUPLIC
#        Write [AMZ]
#        If fstat : GOK=0 : Call FSTA("AMZ") From GLOCK : Goto AB_TR1 : Endif
#        Gosub COPIE_ACTION
#        If GOK<1 : Break : Endif
#       Endif
#      Endif
#     When 2
#      # On peut afficher au maximum 8 axes analytiques. On ne prend pas CCE9
#      If ([F:AMZ2]NOZONE<25 & [F:AMZ2]NOZONE<>13) | [F:AMZ2]NOZONE=38 | [F:AMZ2]NOZONE=39
#       If left$([F:AMZ2]CODZON,3)<>"CCE" | val(mid$([F:AMZ2]CODZON,4,1))<=IOPTCANA
#        Gosub DUPLIC
#        Write [AMZ]
#        If fstat : GOK=0 : Call FSTA("AMZ") From GLOCK : Goto AB_TR1 : Endif
#        If IOPTCANA=9
#         # Copie de l'action clic-droit pour saisir le 9ème axe
#         BOUTCLIC = 8
#        Endif
#        Gosub COPIE_ACTION
#        If GOK<1 : Break : Endif
#       Endif
#      Endif
#     When 3
#      # On peut afficher au maximum 4 axes analytiques
#      If [F:AMZ2]NOZONE<=8 | ([F:AMZ2]NOZONE>=14 & [F:AMZ2]NOZONE<=20)
#&                          | ([F:AMZ2]NOZONE>=26 & [F:AMZ2]NOZONE<=32)
#&                          | [F:AMZ2]NOZONE=38 | [F:AMZ2]NOZONE=39
#       If left$([F:AMZ2]CODZON,3)<>"CCE" | val(mid$([F:AMZ2]CODZON,4,1))<=IOPTCANA
#        Gosub DUPLIC
#        Write [AMZ]
#        If fstat : GOK=0 : Call FSTA("AMZ") From GLOCK : Goto AB_TR1 : Endif
#        If IOPTCANA>4
#         # Copie de l'action clic-droit pour saisir les axes supplémentaires
#         BOUTCLIC = 4
#        Endif
#        Gosub COPIE_ACTION
#        If GOK<1 : Break : Endif
#       Endif
#      Endif
#   Endcase

   # 114841 : supression des lignes temps si
   If!(INBPLG=0 & ([F:AMZ2]NOZONE=2.1 | [F:AMZ2]NOZONE=2.2 | [F:AMZ2]NOZONE=3 | [F:AMZ2]NOZONE=5))

    If left$([F:AMZ2]CODZON,3)<>"CCE" | val(mid$([F:AMZ2]CODZON,4,1))<=IOPTCANA
      Gosub DUPLIC
      Write [AMZ]
      If fstat : GOK=0 : Call FSTA("AMZ") From GLOCK : Goto AB_TR1 : Endif
      Gosub COPIE_ACTION
      If GOK<1 : Break : Endif
    Endif
   Endif
  Endif
 Next
Next

 If GOK<1 : Goto AB_TR1 : Endif
# Création de la fenêtre de saisie
 Read [AWI2]AWI0 = WINREF
 [F:AWI] = [F:AWI2]
 [F:AWI]WIN       = WINDES
 [F:AWI]MSKENT = MASKDES(0)
 Raz [F:AWI]NOMMSK
 For I=1 To min(INBHOR,dim(MASKREF)-1)
  [F:AWI]NOMMSK(I-1) = MASKDES(I)
  #ADNGO - 2017-01-13 - X3-11992 - START
  #INTONG = mess(122,709,1)-num$(I) : # Plage horaire x
  INTONG = mess(122,10709,1)-num$(I) : # Plage horaire x
  #ADNGO - 2017-01-13 - X3-11992 - END

  #105054 : Not create text dynamically !
  #Call TXTCONT(INTONG,"",NUM,len(mess(134,709,1)-num$(I)),11,[F:AWI]WIN,"ONG"+num$(I-1)) From OBJDIV
  #[F:AWI]INTMSK(I-1)=NUM
  Call NUMTEXLAN(INTONG,GLANGUE,NUM) From OBJDIV
  If !NUM
  #ADNGO - 2017-01-13 - X3-11992 - START
   #INTONG = mess(122,709,1) : # Plage horaire
   INTONG = mess(122,10709,1) : # Plage horaire
  #ADNGO - 2017-01-13 - X3-11992 - END
   Call NUMTEXLAN(INTONG,GLANGUE,NUM) From OBJDIV
  Endif
  [F:AWI]INTMSK(I-1)=NUM
 Next
 [F:AWI]NBMSK     = min(INBHOR,dim(MASKREF)-1)
 [F:AWI]ENAFLG    = 2
 [F:AWI]MDL       = 1
 Write [AWI]
 If fstat
  GOK = 0 : Call FSTA("AWI") From GLOCK : Goto AB_TR1
 Endif
 For [AWP2]AWP0 Where WIN=WINREF
  [F:AWP] = [F:AWP2]
  [F:AWP]WIN = WINDES
  Write [AWP]
  If fstat
   GOK = 0 : Call FSTA("AWP") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR1 : Endif
 For [AWT2]AWT0 Where WIN=WINREF
  [F:AWT] = [F:AWT2]
  [F:AWT]WIN = WINDES
  Write [AWT]
  If fstat
   GOK = 0 : Call FSTA("AWT") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$DUPLIC
NOLIG +=1
[F:AMZ] = [F:AMZ2]
[F:AMZ]CODMSK = MASKDES(I)
[F:AMZ]NUMLIG = NOLIG
If left$([F:AMZ2]CODZON,6)<>"ENDTIM"
 COL +=1
 [F:AMZ]NOZONE = COL
Else
 [F:AMZ]NOZONE = COL+0.2
Endif
Return


$COPIE_ACTION
For [AMA2] Where TYPAFF=1 & CODAFF=MASKREF(I) & CODZON=[F:AMZ]CODZON
 If (BOUTCLIC=0 & [F:AMA2]ACTION<>"PLNSAICCE") |
&   (BOUTCLIC=4 & (left$([F:AMA2]CODZON,4)<>"CCE8" | [F:AMA2]ACTION<>"PLNSAICCE")) |
&   (BOUTCLIC=8 & (left$([F:AMA2]CODZON,4)<>"CCE4" | [F:AMA2]ACTION<>"PLNSAICCE"))
  [F:AMA] = [F:AMA2]
  [F:AMA]CODAFF = MASKDES(I)
  Write [AMA]
  If fstat
   GOK=0 : Call FSTA("AMA") From GLOCK : Break
  Endif
 Endif
Next
If GOK<1 : Return : Endif
For [AMP2] Where TYPAFF=1 & CODAFF=MASKREF(I) & CODZON=[F:AMZ]CODZON
 [F:AMP] = [F:AMP2]
 [F:AMP]CODAFF = MASKDES(I)
 Write [AMP]
 If fstat
  GOK=0 : Call FSTA("AMP") From GLOCK : Break
 Endif
Next
If   GOK<1 : Return : Endif
Return

$AB_TR1
Rollback
Return

Subprog PATCH(APPLI)
Value Char APPLI
# Validation transactions depuis génération des patchs
If [F:ADS]MODULE(3) <> 2 : End : Endif : # Module temps non implémenté
Call GENDOS(APPLI)
End

$REMP_CTR
Local Date DEBUT,FIN
#MIPEA - 2017-11-20- US X3-63170- START
#If clalev([F:HRCTR8])=0 : Local File EMPLOCTR [HRCTR8] : Endif
#Read [F:HRCTR8]CTRO(2) = [M:PLE0]REFNUM;[M:PLE0]CTRNUM
#Call SET_GFIRDAY([F:HRCTR8]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-20- US X3-63170- END
Call SEMAINE([M:PLE0]YEA,[M:PLE0]NUMWEK,DEBUT,FIN) From SUBPLN
# FQ85820 - MABON 12/11/12 - On doit prendre la date de rétroactivité au lieu de la date du contrat
#Filter [CTR] Where REFNUM=[M]REFNUM & CTRDAT<=FIN
#Filter [CTR] Where REFNUM=[M:PLE0]REFNUM & (CTRDAT<=FIN | (FLGRET=2 & RETDATEFF<=FIN))
#ADNGO - 2017-01-13 - X3-11992 - START
#Filter [CTR] Where REFNUM=[M:PLE0]REFNUM & (CTRDAT<=FIN | (FLGRET=2 & RETDATEFF<=FIN))
Filter [HRCTR] Where REFNUM=[M:PLE0]REFNUM & (CTRDAT<=FIN | (FLGRET=2 & RETDATEFF<=FIN))
# Fin MABON
#Read[CTR]CTR1 Last
Read[HRCTR]CTR1 Last
#Filter [CTR]
Filter [HRCTR]
#ADNGO - 2017-01-13 - X3-11992 - END
If !fstat
 # FQ85820 - 29/04/13 - On cherche si on a une fiche de rétroactivité relative aux champs ETRFCY et ETRSRV
# [M]FCY    = [F:CTR]ETRFCY
# [M]SRV    = [F:CTR]ETRSRV
 #ADNGO - 2017-01-13 - X3-11992 - START
 #[M:PLE0]FCY    = func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[F:CTR]CTRNUM,[F:CTR]CTRDAT,FIN,"ETRFCY","CTR")
 #[M:PLE0]SRV    = func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[F:CTR]CTRNUM,[F:CTR]CTRDAT,FIN,"ETRSRV","CTR")
 [M:PLE0]FCY    = func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,FIN,"ETRFCY","HRCTR")
 [M:PLE0]SRV    = func SUBCTRRET.FIND_RETRO_FLD([M]REFNUM,[F:HRCTR]CTRNUM,[F:HRCTR]CTRDAT,FIN,"ETRSRV","HRCTR")
 #ADNGO - 2017-01-13 - X3-11992 - END
 # Fin FQ85820
 #ADNGO - 2017-01-13 - X3-11992 - START
 #[M:PLE0]CTRNUM = [F:CTR]CTRNUM
 [M:PLE0]CTRNUM = [F:HRCTR]CTRNUM
    #ADNGO - 2017-01-25 - X3-11992 - START
      If !clalev([F:FCY]) : Local File FACILITY [FCY]  : Endif
      Read [FCY]FCY0 = [M:PLE0]FCY
       If !fstat
          GCURLEG = [F:FCY]LEG
          [M:PLE0]LEG = GCURLEG
          Affzo [M:PLE0]LEG
       Endif
     #ADNGO - 2017-01-13 - X3-11992 - END
 #ADNGO - 2017-01-13 - X3-11992 - END
 Affzo [M:PLE0]FCY, SRV, CTRNUM
Endif
Return

