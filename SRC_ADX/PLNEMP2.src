            Chgfmt [M:PLE2]CCE652 With W_FMT : Chgfmt [M:PLE2]CCE662 With W_FMT : Chgfmt [M:PLE2]CCE672 With W_FMT
          Endif
          If MAXPLG>=3 Then
            Chgfmt [M:PLE3]CCE613 With W_FMT : Chgfmt [M:PLE3]CCE623 With W_FMT : Chgfmt [M:PLE3]CCE633 With W_FMT : Chgfmt [M:PLE3]CCE643 With W_FMT
            Chgfmt [M:PLE3]CCE653 With W_FMT : Chgfmt [M:PLE3]CCE663 With W_FMT : Chgfmt [M:PLE3]CCE673 With W_FMT
          Endif
        When 7 :
          Chgfmt [M:PLE1]CCE711 With W_FMT : Chgfmt [M:PLE1]CCE721 With W_FMT : Chgfmt [M:PLE1]CCE731 With W_FMT : Chgfmt [M:PLE1]CCE741 With W_FMT
          Chgfmt [M:PLE1]CCE751 With W_FMT : Chgfmt [M:PLE1]CCE761 With W_FMT : Chgfmt [M:PLE1]CCE771 With W_FMT
          If MAXPLG>=2 Then
