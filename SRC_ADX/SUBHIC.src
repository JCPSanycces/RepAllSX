#<AdxTL>@(#)2.0.0.0 $Revision$
# VOIR L'INTERET DE GERER CELA PAR UN OBJET ?! Objet HIC sur ITMCOST
# Visualisation seulement  (seuls les critères de l'entête sont saisis)

$ACTION
Case ACTION
 When "LIENS"     Gosub LIENS
 When "OUVRE"     Gosub OUVRE
 When "END"       Gosub ACT_END
 When "SETBOUT"   Gosub SETBOUT
 When "APRES_MODIF" Gosub APRES_MODIF
 When "GAU"       Gosub GAU
 When "FILGAUCHE" Gosub FILGAUCHE
 When "FILTRE"    Gosub FILTRE
 When Default
Endcase
Return

$OUVRE
Local Char CRI_FLT(160)
# pour conserver les critères
If dim(GTRI_HIC)<=0
    Global Integer GTRI_HIC
Endif
If GTRI_HIC = 0
    GTRI_HIC = 1
Endif
If dim(GSENS_HIC)<=0
    Global Integer GSENS_HIC
Endif
If GSENS_HIC = 0
    GSENS_HIC = 2
Endif
If !clalev([F:ITC]) : Local File ITMCOST [ITC] : Endif
If !clalev([F:TCU]) : Local File TABCUR  [TCU] : Endif
If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
Local File ITMCOST [ITC2] :# pour les lignes
If !clalev([F:ITF]) : Local File ITMFACILIT [ITF] : Endif

Return

$ACT_END
Raz [M:HIC0], [M:HIC1], [M:HIC2], [M:HIC3]
Return


$SETBOUT
# Attention on doit pouvoir modifier les critères de sélection supplémentaires
#Call VIREBOUT(CHAINE,"CDAHM") From GOBJET
Return

$LIENS
Read [ITM]ITM0 = [M]ITMREF
[M:HIC0] = [F:ITM]  # zones d'article toujours affichées
Raz [M:HIC1]
# Filtrer la table et charger le tableau
# Selon les types de cout STD et BUD, on ne filtre pas sur l'année
If [M:HIC0]TRI = 0  [M:HIC0]TRI  = GTRI_HIC : Endif
If [M:HIC0]SENS = 0 [M:HIC0]SENS = GSENS_HIC : Endif

CRI_FLT = "STOFCY=[M:HIC0]STOFCY & ITMREF=[M:HIC0]ITMREF & CSTTYP=[M:HIC0]CSTTYP & UID=0"
If [M:HIC0]TRI = 1
  If [M:HIC0]SENS = 1
    Filter [ITC2] Where evalue(CRI_FLT)  Order By ITCSTRDAT; ITCSEQ
  Else
    Filter [ITC2] Where evalue(CRI_FLT)  Order By ITCSTRDAT Desc; ITCSEQ Desc
  Endif
Elsif [M:HIC0]TRI = 2
  If [M:HIC0]SENS = 1
    Filter [ITC2] Where evalue(CRI_FLT)  Order By CLCQTY
  Else
    Filter [ITC2] Where evalue(CRI_FLT)  Order By CLCQTY Desc
  Endif
Endif

# Issue 111084 - 2015-12-17 by BEEBE : get the (max) dimension of the table screen
Local Integer MAXOCC : MAXOCC=dim([M:HIC1]ITCSEQ)

If [M:HIC0]TRI<> 0 & [M:HIC0]SENS <> 0
  [M:HIC1]NBLIG = 0
  nolign = 0
  For [ITC2]
     # Issue 111084 - 2015-12-17 by BEEBE : when max dimension then break before cancel with syntaxerror
     If nolign < MAXOCC
        nolign += 1
     Else
        Call ECR_TRACE(mess(649,199,1),0) From GESECRAN # Issue 111084 - 2015-12-21 by BEEBE : new message, activity code NHI will be used
        Break
     Endif
     [M:HIC1] = [F:ITC2]
  Next
  [M:HIC1]NBLIG = nolign
  Filter [ITC2] : # pour annuler le filtre
  If [M:HIC1]NBLIG = 0
     Call MESSAGE(mess(99,100,1)) From GESECRAN
  Endif
Endif
Gosub CHARG_GRAPHE From SUBHICG
Return

$APRES_MODIF
# (re)charger le tableau quand une des zones du 1er bloc est modifiée.
# OK=-1 pour ne pas passer en mode modif
If [M]TRI=0 | [M]SENS = 0 : Return : Endif
Case COUZON
 When "ITMREF"
     If [M]STOFCY="" : Return : Endif
     [M]ITMREF = zc
     OK = -1
     Gosub LIENS   :# relire les détails et charger l'écran
     Affzo [HIC1]
 When "STOFCY"
     [M]STOFCY = zc
     OK = -1
     Gosub LIENS   :# relire les détails et charger l'écran
     Affzo [HIC1]
 When "YEA"
     [M]YEA = zc
     OK = -1
     Gosub LIENS   :# relire les détails et charger l'écran
     Affzo [HIC1]
 When "CSTTYP"
     [M]CSTTYP = zc
     OK = -1
     Gosub LIENS   :# relire les détails et charger l'écran
     Affzo [HIC1]
 When "TRI"
     [M]TRI = zc
     OK = -1
     Gosub LIENS   :# relire les détails et charger l'écran
     Affzo [HIC1]
 When "SENS"
     [M]SENS = zc
     OK = -1
     Gosub LIENS   :# relire les détails et charger l'écran
     Affzo [HIC1]
 When "ECH", "STRDAT", "ENDDAT"
     # Issue X3-86892 - 2018-09-06 by ERMIL : Allow updating of period, start and end dates in graph
     OK = -1
 When Default
Endcase
Return

$FILGAUCHE    # Pour la liste gauche
If dim(SAVCLE1)>0
    Call SETFILTER(FILGAUSUP,SAVCLE1,SAVCLE2)
Endif
Return

$FILTRE    # Pour le chargement auto de l'article site passé en paramètre
If dim(SAVCLE1)>0
    Call SETFILTER(FILTSUP,SAVCLE1,SAVCLE2)
Endif
Return

Subprog SETFILTER(PFILTER,PITM,PFCY)
Variable Char PFILTER
Value Char PITM  # FGR 01/02/2010 : X3SUIVI60986
Value Char PFCY  # FGR 01/02/2010 : X3SUIVI60986

Local Integer I
Raz PFILTER, I

# Si l'objet est appelé par programme (depuis Saisie-couts)
If PITM <> "" : # (positionnée avant le call OBJET)
    Call ADDCRIT(PFILTER,I,"", "ITMREF = '"+PITM+"'", "&") From GOBJSUB
Endif
If PFCY <> "" : # (positionnée avant le call OBJET)
    Call ADDCRIT(PFILTER,I,"", "STOFCY = '"+PFCY+"'", "&") From GOBJSUB
Endif
If clalev([M:ICD0])
    Call ADDCRIT(PFILTER,I,"", "CSTTYP = "+num$([M:ICD0]CSTTYP), "&") From GOBJSUB
Elsif clalev([M:ICA0])
    Call ADDCRIT(PFILTER,I,"", "CSTTYP = "+num$([M:ICA0]CSTTYP), "&") From GOBJSUB
Endif

Call ADDCRIT(PFILTER,I,"","UID=0","&") From GOBJSUB

End

$GAU
Read [ITC]ITC0=[F:ITC]ITMREF;[F:ITC]STOFCY;[F:ITC]CSTTYP;[F:ITC]ITCSEQ;[F:ITC]UID
[M:HIC0]=[F:ITC]
[M:HIC0]TRI = max([M:HIC0]TRI,1)
[M:HIC0]SENS = max([M:HIC0]SENS,1)
Gosub LIENS
Affzo [M:HIC0]
Affzo [M:HIC1]
Return

########################################

Subprog AS_NBLIG
# Bouton détail
GBOUT1 = mess(65,198,1)
End

Subprog AV_CUR(VALEUR)
Variable Char     VALEUR
Call GETDEV([M]STOFCY) From DEVSUB
VALEUR = [F:TCU]CUR
End

Subprog C_CSTTYP(VALEUR)
Variable Integer  VALEUR
Look [ITC]ITC0(3) = [M]STOFCY;[M]ITMREF;VALEUR
If fstat
  mkstat=2 : GMESSAGE = mess(23,100,1)
Endif
End

Subprog D_SENS(VALEUR)
Variable Integer  VALEUR
# initialisé à Tri par Date décroissante
If [M:HIC0]TRI = 1 : VALEUR = 2 : Else VALEUR = 1 : Endif
End

Subprog AP_TRI(VALEUR)
Variable Integer  VALEUR
GTRI_HIC = VALEUR :# pour conserver les critères après clic sur le browse
End

Subprog AP_SENS(VALEUR)
Variable Integer  VALEUR
GSENS_HIC = VALEUR
End

Subprog AS_ITMREF(VALEUR)
Variable Char     VALEUR
If GFLTITM <> ""
  mkstat = 2
  VALEUR = GFLTITM
Endif
End

######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
    If [M:HIC0]STOFCY<>""
        Look [ITF]ITF0=VALEUR;[M:HIC0]STOFCY
        If fstat
            Effzo [M:HIC0]STOFCY
        Endif
    Endif
End

Subprog AS_STOFCY(VALEUR)
Variable Char     VALEUR
If GFLTFCY <> ""
  mkstat = 2
  VALEUR = GFLTFCY
Endif
End

Subprog C_STOFCY(VALEUR)
Variable Char     VALEUR
Look [ITF]ITF0=[M:HIC0]ITMREF;VALEUR
If fstat
    mkstat=2
    GMESSAGE=mess(139,197,1)
    End
Endif

Look [ITC]ITC0(2) = VALEUR;[M]ITMREF
[G:ITC]currlen=0
If fstat
  mkstat=2 : GMESSAGE = mess(23,100,1)
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran HISCOST1) 05/09/2008 09:21:16 (CCC)
######################################################################################
Subprog B1_NBLIG
Raz [F:ITC]
Read [ITC]ITC0=[M:HIC0]STOFCY;[M:HIC0]ITMREF;[M:HIC0]CSTTYP;[M:HIC1]ITCSEQ(nolign-1);0
End


######################################################################################

