#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ABIMOVETA","ABIMOVETA",3,"") From GTRAITE
End

##############################################################################################################
$ACTION
Case ACTION
 When "INIT"         : Gosub INIT
 When "INIT_DIA"     : Gosub INIT_DIA
 When "EXEC"         : Gosub EXEC
Endcase
Return

$INIT
GBIDC1 = nomap
If find(GBIDC1,"X3IND150","X3INDV6","X3INDV7")>0
 Call MESSAGE (mess(00127,00100,1) ) From GESECRAN : #  Fonction impossible dans le contexte
 FIN = 1
 Return
Endif
Local File ABIDATWRH [ABW]
Local File ABIDATMRT [ABM]
Local Integer STAT
Return

$INIT_DIA
If !GSERVEUR & !GIMPORT
 GINFO = 1
Else
 GINFO = 0
Endif
Return

$EXEC
If GINFO
 Call OUVRE_VLC(mess(137,148,1),"","") From GESECRAN   : # Mise en livraison
Endif
Call MOVETA([M:DIA]DATAW,[M:DIA]DATAM,[M:DIA]LAN,[M:DIA]SIMU,STAT)
If GINFO
 Call FERME_VLC From GESECRAN
Endif
TRA=1
Return

Subprog MOVETA(DATAW,DATAM,DATALAN,SIMU,STAT)
Value Char       DATAW
Value Char       DATAM
Value Char       DATALAN
Value Integer    SIMU
Variable Integer STAT
Local Char LIGNE(250),PORT(250),SERVEUR(250)
Local Char APPLI(250) : APPLI = nomap
Local Integer OK,ERR,SPEC
Call RECHPROP("busobj.adxadmin.port",PORT,ERR) From INTRUTILA
If PORT="" or ERR : End : Endif
Call RECHPROP("component.busobj.servername",SERVEUR,ERR) From INTRUTILA
If SERVEUR="" or ERR : End : Endif
If !GSERVEUR
 Call OUVRE_TRACE(mess(137,148,1)) From LECFIC : # Mise en livraison
Else
 Call ECR_TRACE(mess(137,148,1),0) From GESECRAN
Endif
OK =1
Gosub OUVRE_TABLE From ABICREUNV                 : # Ouverture tables
Gosub TEST_ETAT
If OK=0 : Goto ERREUR : Endif
Gosub INIT_PARAMETRE                             : # initialisation des parametres
If OK=0 : Goto ERREUR : Endif
Gosub CREE_TOOL                                  : # CRéATION du fichier Tool
BALISE = 1 : OK =1
Gosub CRE_LIST_ETA From SUBATV2                  : # Mise en variable des etats du refrentiel
Gosub LISTE_SOLUTION                             : # Liste  des etats du repertoire lan de la solution
If [L]I_NBETATS =0
 Call ECR_TRACE(mess(92,148,1),0) From GESECRAN  : #  : Aucun états trouvés dans l'Infoview
Else
 Gosub LISTE_ALL                                  : # Liste  des etats du repertoire ALL de la livraison
 Gosub LISTE_SPE                                  : # Liste  des etats du repertoire SPE de la livraison
 BALISE = 1 : OK =1
 Gosub FOLD_UNIV_ALL                              : # Mis ene variable des univers
 Gosub FIND_FOLD_MOVE                             : # recherche des cuid des repertoire mis en jeux
 Gosub MOV_ETA                                    : # Deplacement des etats et repertoire
 If OK=0 : Goto ERREUR : Endif
Endif
Gosub EFF_FICHIER From SUBATV2                   : # Suppresion des fichier temporaire de travail
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
End

$TEST_ETAT
Local Integer EXISTE_ETAT
For [ABO]ABO0 Where [F:ABO]DATAM=[L]DATAM
 EXISTE_ETAT += 1
 Break
Next
If [L]EXISTE_ETAT=0 :
 Call ECR_TRACE(mess(92,148,1),0) From GESECRAN  : #  : Aucun états trouvés dans l'Infoview
 OK =0 : Return : Endif
Return

$MOV_ETA
IMPPRO  = [M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'ImpBiar_'+num$(adxuid(1))+'.properties'

# Initialisations
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

## Ecriture fichier ImpBiar
Onerrgo ERREURS

Openo [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+IMPPRO , 0  Using [D1]
Iomode adxifs  ""  Using [D1]
Iomode adxirs  chr$(13)+chr$(10)  Using [D1]
Iomode adxium  GUTF8  Using [D1]

## Ecriture fichier liste documents
Openo [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+DOCPRO , 0  Using [E1]
Iomode adxifs  ""  Using [E1]
Iomode adxirs  chr$(13)+chr$(10)  Using [E1]
Iomode adxium  GUTF8  Using [E1]

If [L]EDOSALL<>""
 J=0
 ## Delete des documents présents dans le repertoire ALL
 For I=0 To [L]A_NBETATS-1
  Wrseq "e;del;"+[L]A_ETATID(I)+';0;'+[L]A_ETATS(I) Using [D1]
  If !find([L]A_ETAUNVID(I),UNVDEL(0..dim(UNVDEL)-1))
   Wrseq "u;del;"+[L]A_ETAUNVID(I)+";0;"+[L]A_ETATUNV(I) Using [D1]
   [L]UNVDEL(J)   = [L]A_ETAUNVID(I)
   J+=1
  Endif
 Next I

 ## Delete des documents présents dans le repertoire SPE
 For I=0 To [L]S_NBETATS-1
  Wrseq "e;del;"+[L]S_ETATID(I)+';0;'+[L]S_ETATS(I) Using [D1]
  If !find([L]S_ETAUNVID(I),UNVDEL(0..dim(UNVDEL)-1))
   Wrseq "u;del;"+[L]S_ETAUNVID(I)+";0;"+[L]S_ETATUNV(I) Using [D1]
   [L]UNVDEL(J)   = [L]S_ETAUNVID(I)
   J+=1
  Endif
 Next I

 #J=0 : Raz UNVDEL
 #For I=0 To dim([L]I_ETATS)-1
 # If !find([L]I_ETATUNV(I),UNVDEL(0..dim(UNVDEL)-1)) : # all
 #  [L]UNVDEL(J)   = [L]I_ETATUNV(I)
 #  J+=1
 # Endif
 #Next I

 I =0
 For K=0 To J-1
  For M=0 To dim([L]ETAT)-1
   If [L]UNVDEL(K)=[L]ETAT_UNV(M) & [L]ETAT_UNV(M) & !find([L]ETAT_UNVID(M),UNVDELID(0..dim(UNVDELID)-1))
&   & find([L]ETAT_UNVID(M),TAB_ID(0..NBUNV-1))
    [L]UNVDEL(I)   = [L]ETAT_UNV(M)
    [L]UNVDELID(I) = [L]ETAT_UNVID(M)
    I+=1
   Endif
  Next
 Next

 ## delete des etats qui sont basé sur l'univers qui est present dans le repertoire langue de la ALL
 For K=0 To J-1
  M = 0
  For I=0 To dim([L]ETAT)-1
   If [L]ETAT_UNVID(I) = [L]UNVDELID(K) & [L]ETAT_UNVID(I)<>"" & !find([L]ETAT_ID(I),[L]A_ETATID(0..dim([L]A_ETATS)-1))
    Wrseq "e;del;"+[L]ETAT_ID(I)+";0;"+[L]ETAT(I) Using [D1]
    Call ECR_TRACE("Des états hors production sont basés sur l'univers "-[L]UNVDEL(K)-" le référentiel n'est pas synchronisé",-1) From GESECRAN
    SIMU = 2
    M = 1
   Endif
  Next
  If M
   Wrseq "u;del;"+[L]UNVDELID(K)+";0;"+[L]UNVDEL(K) Using [D1]
  Endif
 Next

 ## Copie des etats vers le repertoire ALL

 J=0
 DOCPRO  = [M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'DocList_'+num$(adxuid(1))+'.properties'
 UNIPRO  = [M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'UnivList_'+num$(adxuid(1))+'.properties'

 If UDOSSPE="" : UDOSSPE = UDOSALL : Endif
 For I=0 To [L]I_NBETATS-1
  SPEC = 0
  Wrseq "e;mov"+';'+[L]I_ETATID(I)+';'; Using [D1]
  Filter [F:ABO] Where DATAM = [L]DATAM & REPCOD=[L]I_ETATS(I)
  For [ABO]
   If [F:ABO]ACV>="X" or [F:ABO]COD>="X"
    If [L]SEDOSALL="" : SEDOSALL = EDOSALL : Endif
    Wrseq [L]SEDOSALL+";"+[L]I_ETATS(I) Using [D1]
    SPEC = 1
    Wrseq [L]I_ETATS(I)+';'+[L]I_ETATS(I)+';'+[L]I_ETATID(I)+';'+[L]SEDOSALL Using [E1]
   Else
    Wrseq [L]EDOSALL+";"+[L]I_ETATS(I) Using [D1]
   Endif
   Break
  Next
  Filter [F:ABO]
  If !find([L]I_ETATUNV(I),UNVCOP(0..dim(UNVCOP)-1)) or SPEC
   If !SPEC
    Wrseq "u;mov;"+[L]I_ETAUNVID(I)+";"+UDOSALL+";"+[L]I_ETATUNV(I)  Using [D1]
    UNVSPE   = [L]I_ETATUNV(I)
    UNVSPEID = [L]I_ETAUNVID(I)
   Else
    Wrseq "u;cop;"+[L]I_ETAUNVID(I)+";"+UDOSSPE+";"+[L]I_ETATUNV(I)  Using [D1]
   Endif
   UNVCOP(J) = [L]I_ETATUNV(I)
   J += 1
  Endif
 Next I

Endif

Openo Using [E1]
Openo Using [D1]

If SIMU = 2 : Goto TRACES : Endif

ORDRE = ''+chr$(10)
& +'"'+[M:ATV2]BOTOOL+[M:ATV2]SREP+IMPCMD+'" '
& +'-t "'+[M:ATV2]BOTOOL+'" '
& +'-bo "'+[M:ATV2]BOFILE+'" '
& +'-u "'+[M:ATV2]BOTOOL+'\BO_BASE\shared\lib" '
& +'-param "'+[M:ATV2]FICPARAM +'" '
& +'-logdir "'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'" '
& +'-logname "'+'ImpBiar_'+num$(adxuid(1))+'" '
& +'1> "'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'ImpBiar_'+num$(adxuid(1))+'.out" '
& +'2> "'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\'+'ImpBiar_'+num$(adxuid(1))+'.err"'

ORDSYS(1) = [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\X3Imp_'+num$(adxuid(1))+'.cmd'
If !MAC64
 Call ECRITURE_COMMANDE(ORDSYS(1),ORDRE) From SUBATV2
Else
 CMDTXT= [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\CMDX3Imp_'+num$(adxuid(1))+'.cmd'
 Call ECRITURE_COMMANDE(CMDTXT,ORDRE)  From SUBATV2
 ORDRE = CMD64+'"'+right$(CMDTXT,instr(1,CMDTXT,"@")+1)+'"'
 Call ECRITURE_COMMANDE(ORDSYS(1),ORDRE)  From SUBATV2
Endif
If GINFO
 Call AFF_VLC(mess(138,148,1),"") From GESECRAN  : # Déplacement des états et univers dans le répertoire de livraison
Endif
Call SYSTEME([M:ATV2]MACHINE+':'+[M:ATV2]SERV,ORDSYS,"f",ERR) From ORDSYS

If GTRACE <> ""
 Call FICHIER_OUT([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\ImpBiar_'+num$(adxuid(1))+'.out',OUT) From SUBATV2
 Call ECR_TRACE('',0) From GESECRAN
 Call ECR_TRACE (mess(4,139,1)-'ImpBiar_'+num$(adxuid(1))+'.out'-":",OUT) From GESECRAN
 Call AJOUT_TRACE([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\ImpBiar_'+num$(adxuid(1))+'.out') From ABICREUNV
 If OUT : OK=0 : Endif
Endif

If filinfo([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]REPADXDIR+'\tmp\'+[M:ATV2]COMPBONAM+'\ImpBiar_'+num$(adxuid(1))+'.err',7)>0
 If GTRACE <> ""
  Call ECR_TRACE('ImpBiar_'+num$(adxuid(1))-":"-mess(00505,00153,1),1) From GESECRAN
 Else
  Call ERREUR('ImpBiar_'+num$(adxuid(1))-":"-mess(00505,00153,1)) From GESECRAN
 Endif
 OK =0
 Return
Endif

Gosub RECHID_UNIVERSPE
Onerrgo
Return


$RECHID_UNIVERSPE
Gosub CREE_TOOL
Gosub LIT_TOOL From ABIMAP
Gosub TAB_UNV From ABIMAP
J=0
For I=0 To U_NBUNV-1
 If U_UNV(I)=UNVSPE & U_UNV_FAT(I)=UDOSSPE
  Break
 Endif
Next
## Ecriture fichier liste univers
Openo [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+UNIPRO ,0  Using [U1]
Iomode adxifs  ""  Using [U1]
Iomode adxirs  chr$(13)+chr$(10)  Using [U1]
Iomode adxium  GUTF8  Using [U1]
Wrseq UNVSPE +";"+UNVSPE +";"+UNVSPEID+';'+U_UNV_ID(I) Using [U1]
Openo Using [U1]
Gosub GENE_UNIV2 From SUBATV2
Return

$TRACES
If GTRACE<>""
 Local Char LIGNE(250)
 Call ECR_TRACE("",0) From GESECRAN
 Call ECR_TRACE("Fichier properties",0) From GESECRAN : # Création de l'univers
 Call ECR_TRACE("",0) From GESECRAN
 Openi [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+IMPPRO
 Rdseq LIGNE
 While fstat=0
  If left$(LIGNE,6)="Erreur"
   ERREURS = 1
   Call ECR_TRACE(right$(LIGNE,7),1) From GESECRAN
  Else
   Call ECR_TRACE(LIGNE,0) From GESECRAN
  Endif
  Rdseq LIGNE
 Wend
 Openi
 Call ECR_TRACE("Fichier DOCLIST properties",0) From GESECRAN : # Création de l'univers
 Call ECR_TRACE("",0) From GESECRAN
 Openi [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+DOCPRO
 Rdseq LIGNE
 While fstat=0
  If left$(LIGNE,6)="Erreur"
   ERREURS = 1
   Call ECR_TRACE(right$(LIGNE,7),1) From GESECRAN
  Else
   Call ECR_TRACE(LIGNE,0) From GESECRAN
  Endif
  Rdseq LIGNE
 Wend
 Openi
 If filinfo( [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+UNIPRO,0) <0 : Return : Endif
 Call ECR_TRACE("Fichier UNIV properties",0) From GESECRAN : # Création de l'univers
 Call ECR_TRACE("",0) From GESECRAN
 Openi [M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+UNIPRO
 Rdseq LIGNE
 While fstat=0
  If left$(LIGNE,6)="Erreur"
   ERREURS = 1
   Call ECR_TRACE(right$(LIGNE,7),1) From GESECRAN
  Else
   Call ECR_TRACE(LIGNE,0) From GESECRAN
  Endif
  Rdseq LIGNE
 Wend
 Openi
Endif
Return

$ERREURS
ER = errn
If GTRACE
 Call ECR_TRACE(errm-errmes$(errn),errn) From GESECRAN
Endif
Resume

$FIND_FOLD_MOVE
### Calcul du cuid du folder d'univers de destination
N=find(GREPBI,U_DOSSIER(0..U_NBDOS))
If N = 0 : Return : Endif
UDOS_0 = U_DOS_ID(N-1)
UDOS   = U_DOS_P_ID(N-1)
For J=0 To U_NBDOS-1
 If U_DOSSIER(J) = GREPSOLIND & U_DOS_P_ID(J) =UDOS_0
  UDOS_1 = U_DOS_ID(J)
  Break
 Endif
Next J
For I=0 To U_NBDOS-1
 If U_DOSSIER(I) = GREPBOPROD & U_DOS_P_ID(I) =  UDOS_1
   UDOS_2 = U_DOS_ID(I)
  Break
 Endif
Next I
For K=0 To U_NBDOS-1
 If U_DOSSIER(K) = "ALL" & U_DOS_P_ID(K) = UDOS_2
  FOLDDES = U_DOS_CUID(K)
  UDOSALL = U_DOS_ID(K)
  Break
 Endif
Next K
For K=0 To U_NBDOS-1
 If U_DOSSIER(K) = "SPE" & U_DOS_P_ID(K) = UDOS_2
  FOLDDESSPE = U_DOS_CUID(K)
  UDOSSPE = U_DOS_ID(K)
  Break
 Endif
Next K

### Calcul du cuid du folder d'univers origine
Raz UFOLD_0,UFOLD_1,UFOLD_2,UFOLDALL
For J=0 To U_NBDOS-1
 If U_DOSSIER(J) = GREPBI
  UFOLD_0 = U_DOS_ID(J)
  Break
 Endif
Next J
For J=0 To U_NBDOS-1
 If U_DOSSIER(J) = GINSTID  & U_DOS_P_ID(J) = UFOLD_0
  UFOLD_1= U_DOS_ID(J)
  Break
 Endif
Next J
For J=0 To U_NBDOS-1
 If U_DOSSIER(J) = [L]DATAW  & U_DOS_P_ID(J) = UFOLD_1
  UFOLD_2=U_DOS_ID(J)
  Break
 Endif
Next J
For I=0 To U_NBDOS-1
 If U_DOSSIER(I) = [L]DATALAN & U_DOS_P_ID(I) = UFOLD_2
  FOLDORI   = U_DOS_CUID(I)
  UFOLDALL  = U_DOS_ID(I)
  Break
 Endif
Next I
If UFOLD_0=""
 Call ECR_TRACE(GREPBI-mess(125,148,1)-": KO",0) From GESECRAN
 Goto ERREUR
Endif
Return

$FOLD_UNIV_ALL
Gosub LIT_TOOL From ABIMAP

If filinfo([L]FICHIER,7)<0
 OK =0
Endif
OK = 1
DEB = instr(0,CLOB,"<Folders_And_Universes")
CLOB = right$(CLOB,DEB)

DEB = instr(0,CLOB,'Folder CUID="')
While DEB>0
 FIN = instr(DEB+13,CLOB,'"')
 U_DOS_CUID(U_NBDOS) = seg$(CLOB,DEB+13,FIN-1)

 DEB = instr(FIN,CLOB,'Id="')
 FIN = instr(DEB+4,CLOB,'"')
 U_DOS_ID(U_NBDOS) = seg$(CLOB,DEB+4,FIN-1)

 DEB = instr(FIN,CLOB,'Name="')
 FIN = instr(DEB+6,CLOB,'"')
 U_DOSSIER(U_NBDOS) = seg$(CLOB,DEB+6,FIN-1)

 DEB = instr(FIN,CLOB,'ParentID="')
 FIN = instr(DEB+10,CLOB,'"')
 U_DOS_P_ID(U_NBDOS) = seg$(CLOB,DEB+10,FIN-1)

 U_NBDOS +=1
 DEB = instr(FIN,CLOB,'Folder CUID="')
Wend
Return

$LISTE_ALL

N=find(GREPBI,[L]DOSSIER(0..NBDOSSIER))
If N = 0 : Return : Endif
EDOS_0 =  [L]DOS_ID(N-1)
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = GREPSOLIND & [L]DOS_P_ID(I) = EDOS_0
  EDOS_1 = [L]DOS_ID(I)
  Break
 Endif
Next I
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = GREPBOPROD  & [L]DOS_P_ID(I) = EDOS_1
  EDOS_2 = [L]DOS_ID(I)
  Break
 Endif
Next I
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = "ALL" & [L]DOS_P_ID(I) = EDOS_2
  EDOSALL = [L]DOS_ID(I)
  Break
 Endif
Next I
J=0
Call ECR_TRACE(mess(113,148,1)-":",0) From GESECRAN
For I=0 To NBETAT-1
 If [L]ETAT_F_CUID(I) = EDOSALL & [L]ETAT_UNVID(I) <> "" & J< dim([L]ETAT) : # & find([L]ETAT(I),[L]I_ETATS(0..[L]I_NBETATS))
  [L]A_ETATS(J)    = [L]ETAT(I)
  [L]A_ETATID(J)   = [L]ETAT_ID(I)
  [L]A_ETAIDFAT(J) = [L]ETAT_F_CUID(I)
  [L]A_ETATUNV(J)  = [L]ETAT_UNV(I)
  [L]A_ETAUNVID(J) = [L]ETAT_UNVID(I)
  Call ECR_TRACE(" -"-[L]A_ETATS(J),0) From GESECRAN
  J+=1
 Endif
Next I
[L]A_NBETATS = J
Return

$LISTE_SPE

N=find(GREPBI,[L]DOSSIER(0..NBDOSSIER))
If N = 0 : Return : Endif
SEDOS_0 =  [L]DOS_ID(N-1)
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = GREPSOLIND & [L]DOS_P_ID(I) = SEDOS_0
  SEDOS_1 = [L]DOS_ID(I)
  Break
 Endif
Next I
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = GREPBOPROD  & [L]DOS_P_ID(I) = SEDOS_1
  SEDOS_2 = [L]DOS_ID(I)
  Break
 Endif
Next I
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = "SPE" & [L]DOS_P_ID(I) = SEDOS_2
  SEDOSALL = [L]DOS_ID(I)
  Break
 Endif
Next I
J=0
Call ECR_TRACE(mess(141,148,1)-":",0) From GESECRAN : # Etats présents dans le repertoire SPE
For I=0 To NBETAT-1
 If [L]ETAT_F_CUID(I) = SEDOSALL & [L]ETAT_UNVID(I) <> "" & J< dim([L]ETAT) : # & find([L]ETAT(I),[L]I_ETATS(0..[L]I_NBETATS))
  [L]S_ETATS(J)    = [L]ETAT(I)
  [L]S_ETATID(J)   = [L]ETAT_ID(I)
  [L]S_ETAIDFAT(J) = [L]ETAT_F_CUID(I)
  [L]S_ETATUNV(J)  = [L]ETAT_UNV(I)
  [L]S_ETAUNVID(J) = [L]ETAT_UNVID(I)
  Call ECR_TRACE(" -"-[L]S_ETATS(J),0) From GESECRAN
  J+=1
 Endif
Next I
[L]S_NBETATS = J
Call ECR_TRACE("",0) From GESECRAN
Return


$LISTE_SOLUTION
N=find(GREPBI,[L]DOSSIER(0..NBDOSSIER))
If N = 0 : Return : Endif
EFOLD_0 =  [L]DOS_ID(N-1)
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = GINSTID & [L]DOS_P_ID(I) = EFOLD_0
  EFOLD_1 = [L]DOS_ID(I)
 Endif
Next I
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = [L]DATAW  & [L]DOS_P_ID(I) = EFOLD_1
  EFOLD_2 = [L]DOS_ID(I)
 Endif
Next I
For I=0 To NBDOSSIER-1
 If [L]DOSSIER(I) = [L]DATALAN & [L]DOS_P_ID(I) = EFOLD_2
  EFOLDALL = [L]DOS_ID(I)
 Endif
Next I
J=0
Call ECR_TRACE(func AFNC.MES2(mess(139,148,1),[L]DATALAN,[L]DATAM)-":",0) From GESECRAN
For I=0 To NBETAT-1
 If [L]ETAT_F_CUID(I) = EFOLDALL & [L]ETAT_UNVID(I) <> "" & J< dim([L]ETAT)
  [L]I_ETATS(J)    = [L]ETAT(I)
  [L]I_ETATID(J)   = [L]ETAT_ID(I)
  [L]I_ETAIDFAT(J) = [L]ETAT_F_CUID(I)
  [L]I_ETATUNV(J)  = [L]ETAT_UNV(I)
  [L]I_ETAUNVID(J) = [L]ETAT_UNVID(I)
  Call ECR_TRACE(" -"-[L]I_ETATS(J),0) From GESECRAN
  J+=1
 Endif
Next I
[L]I_NBETATS = J
Return


$ERREUR
Gosub COP_FICHIER From SUBATV2
Gosub EFF_FICHIER From SUBATV2
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
End

$CREE_TOOL
Raz [M:ATV2]
[M:ATV2]DATAW    = [L]DATAW
[M:ATV2]LANGORI  = "FRA"
[M:ATV2]LANGDES  = "FRA"
[M:ATV2]DATAMORI = [L]DATAM
[M:ATV2]USRBI    ="Admin"
[M:ATV2]LANGDES  = GLANGUE
[M:ATV2]LANGORI  = GLANGUE
[M:ATV2]SREP     = '\TOOLS\BO\'

### init user et mdp BO
Call RECHPROP("busobj.login.adminusr",[M:ATV2]USRBI,GBIDI1) From INTRUTILA
Call INCRYPT([M:ATV2]USRBI,RETOUR) From INTRUTILA
[M:ATV2]USRBI="CRYPT:"+RETOUR
Call RECHPROP("busobj.login.adminpwd",[M:ATV2]PWDBI,GBIDI1) From INTRUTILA
OK=1
Gosub INIT_SOLUTION From SUBATV2
If !OK : Goto ERREUR : Endif
WEBILIST = "TRUE"
WEBIUNV  = "TRUE"
SOLCREA  = "FALSE"
UNIVLIST = "TRUE"
REPBIS   = GREPBI      : # Critere repertoire de recherche niveau 1
REPBIS21 = GREPSOLIND  : # Critere repertoire de recherche niveau 2
REPBIS22 = GINSTID     : # Critere repertoire de recherche niveau 2
IMPORT   = GREPBI
Gosub CRE_PARAM From SUBATV2
Gosub CRE_DOCLISTFILT From SUBATV2
If !OK
 Goto ERREUR
Endif
Gosub GENE_TOOL From SUBATV2
If !OK
 Goto ERREUR
Elsif filinfo([M:ATV2]MACHINE+':'+[M:ATV2]SERV+'@'+[M:ATV2]FICTOOL,7)<0
 Call ECR_TRACE("|"+[M:ATV2]FICTOOL+"|"-":"-mess(101,100,1),1) From GESECRAN
 Goto ERREUR
Endif
Return

