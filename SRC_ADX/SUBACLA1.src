#<AdxTL>@(#)2.0.0.0 $Revision$
########################################################################
# Fenêtres de saisie                                                   #
# ------------------                                                   #
# ACLALNKCLA: CLasses liées (Arborescence)                             #
########################################################################

$ACTION
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "OK"            : Gosub OK
 When "FIN"           : Gosub FIN
Endcase
Return

#########################################################################
#    Actions liés au type fenêtre de saisie                             #
#########################################################################
$OUVRE
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
Return

$FIN
nolign=SAVNOLIGN
Return

$DEBUT
Case GACTION
 When "ACLALNKCLA"     : Gosub DEB_ACLALNKCLA
Endcase
Return

$OK
Case GACTION
Endcase
Return



#----------------------------------------------------------
$DEB_ACLALNKCLA
Raz [M:ACLA1B]
Affzo [M:ACLA1B]
If GFONCTION="GESACLA"
Call _LOAD_CLASSE(0,1,nomap,[M:ACLA0]CODCLA)
Elsif GFONCTION="GESASW"
Call _LOAD_REP(0,1,nomap,[M:ASW0]CODREP)
Endif
Affzo [M:ACLA1B]
Return

#--------------#
$DECL_CONST
#Local Char CST_ICO_TRT(30)     : [L]CST_ICO_TRT="css.gif"
Local Char CST_ICO_TRT(30)     : [L]CST_ICO_TRT="txt.gif"
Local Char CST_ICO_UNTRT(30)   : [L]CST_ICO_UNTRT="mvt2.gif"
#---
#Local Char CST_ICO_LNK(30)     : [L]CST_ICO_LNK="Table.gif"
Local Char CST_ICO_LNK(30)     : [L]CST_ICO_LNK="presse.gif"
Local Char CST_ICO_UNLNK(30)   : [L]CST_ICO_UNLNK="mvt2.gif"
#---
Local Char CST_ICO_COL(30)     : [L]CST_ICO_COL="asp.gif"
Local Char CST_ICO_UNCOL(30)   : [L]CST_ICO_UNCOL="mvt2.gif"
#Local Char CST_ICO_NOCOL(30)   : [L]CST_ICO_NOCOL="mvt0.gif"
Local Char CST_ICO_NOCOL(30)   : [L]CST_ICO_NOCOL="moins1.gif"
#---
Local Char CST_ICO_REP(30)      : [L]CST_ICO_REP="Folder.gif"
#---
Local Char CST_ICO_CLA(30)      : [L]CST_ICO_CLA="produitsoustraite.gif"
Local Char CST_ICO_CLARECURS(30): [L]CST_ICO_CLARECURS="boussole.gif"
#Local Char CST_ICO_UNCLA(30)    : [L]CST_ICO_UNCLA="produit.gif"
Local Char CST_ICO_UNCLA(30)    : [L]CST_ICO_UNCLA="produit.png"
Return

######################################################################################
Subprog _LOAD_REP(TEST,SILENCE,DOSSIER,CODREP)
Value Integer TEST,SILENCE
Value Char    DOSSIER
Value Char    CODREP

Gosub OPEN_FILE From ASHWVALLEC

Read [F:ASW]ASW0 = [L]CODREP
If fstat : End : Endif

Gosub DECL_CONST

Local Char TBCLAPARENT(250)(1..)
Local Integer I,J
Local Char    L_ERR_MSG(250)
Local Integer NOCLA
Local Integer WLEV : WLEV=1
Local Integer ERR

Gosub ADD_REP

Call FIND_SUBCLASS([L]DOSSIER,[F:ASW]CODCLA,"",num$(NOCLA)+[F:ASW]CODREP,WLEV,[F:ASW]CODCLA,[F:ASW]ABRCLA,"","","",[L]TBCLAPARENT)

[M:ACLA1B]NBACLA=[M:ACLA1B]NBC
[M:ACLA1B]DTH=max([M:ACLA1B]CLEV)

Gosub CLOSE_FILE From ASHWVALLEC
End

######################################################################################
Subprog _LOAD_CLASSE(TEST,SILENCE,DOSSIER,CODCLA)
Value Integer TEST,SILENCE
Value Char    DOSSIER
Value Char    CODCLA

Gosub OPEN_FILE From ACLAVALLEC
Local Char TBCLAPARENT(250)(1..)

Call FIND_SUBCLASS([L]DOSSIER,[L]CODCLA,"","",0,[L]CODCLA,"","","","",[L]TBCLAPARENT)

[M:ACLA1B]NBACLA=[M:ACLA1B]NBC
[M:ACLA1B]DTH=max([M:ACLA1B]CLEV)

Gosub CLOSE_FILE From ACLAVALLEC
End


#--------------#
Subprog FIND_SUBCLASS(DOSSIER,ORICLA,PARCLA,PARKEY,PARLEV,CURCLA,CURABR,CURGRP,CURACT,CURCOLCAR,TBCLAPARENT)
Value Char       DOSSIER,ORICLA,PARCLA,PARKEY
Value Integer    PARLEV
Value Char       CURCLA,CURABR,CURGRP,CURACT,CURCOLCAR
Variable Char TBCLAPARENT ()(1..)

Gosub DECL_CONST

Local Integer I,J
Local Char    L_ERR_MSG(250)
Local Integer NOCLA
Local Integer WLEV : WLEV=[L]PARLEV+1
Local Integer ERR

Read [F:ACLA]ACLA0 = [L]CURCLA
If fstat : End : Endif

If find(CURCLA,[L]TBCLAPARENT)>0
 If [F:ACLA]TYPCLA<>4
  For I=1 To maxtab(TBCLAPARENT)
   If [L]TBCLAPARENT(I)<>""
    If L_ERR_MSG=""
     L_ERR_MSG=[L]TBCLAPARENT(I)
    Else
     L_ERR_MSG+="/"+[L]TBCLAPARENT(I)
    Endif
   Endif
  Next
  Call  ERREUR([L]ORICLA-":"-mess(67,140,1)-"("+CURCLA+")"+"\"+L_ERR_MSG+"/"+CURCLA) From GESECRAN  : # Problème de récursivité des classes
 Endif
 [L]ERR=1
Endif

Gosub ADD_CLA
Gosub ADD_CCLA
If [L]ERR : End : Endif

Local Integer NOCLAFIND
NOCLAFIND=maxtab(TBCLAPARENT)+1
[L]TBCLAPARENT(NOCLAFIND) = CURCLA

Local File =DOSSIER+".ACLAFLD"    [ACLAF9]
Local Integer N_ACLAF9,N_USED,IS_USED
Local Char USED_FLDGRP(GLONAVA) (1..)
Local Char ACLAF9_FLDGRP(GLONAVA) (1..)
Local Char ACLAF9_ACTFLD(GLONACV) (1..)
Local Char ACLAF9_LNKCLA(GLONACLA) (1..)
Local Char ACLAF9_PARKEY(100) (1..)
Local Char ACLAF9_COLCAR(50) (1..)

For [ACLAF9]ACLAF1 Where CODCLA=[L]CURCLA & FLDGRP<>""
 If find([F:ACLAF9]FLDGRP,USED_FLDGRP(1..N_USED))=0
  N_USED+=1
  USED_FLDGRP(N_USED)=[F:ACLAF9]FLDGRP
 Endif
Next
For [ACLAF9]ACLAF1 Where CODCLA=[L]CURCLA & LNKCLA<>""
 N_ACLAF9+=1
 ACLAF9_FLDGRP(N_ACLAF9)=[F:ACLAF9]FLDGRP
 ACLAF9_ACTFLD(N_ACLAF9)=[F:ACLAF9]ACTFLD
 ACLAF9_LNKCLA(N_ACLAF9)=[F:ACLAF9]LNKCLA
Next
Close Local File [ACLAF9]

I=0
IS_USED=0
#collections without properties
For [ACLAC] Where CODCLA=[L]CURCLA
 If I=0
  Gosub ADD_CLA_COL
  I+=1
 Endif
 If find([F:ACLAC]CODCOL,USED_FLDGRP(1..N_USED))=0
  J=0
  Gosub ADD_CLA_LIG_COL
 Endif
Next

IS_USED=1
#collections without classe
For [ACLAC] Where CODCLA=[L]CURCLA
 If I=0
  Gosub ADD_CLA_COL
  I+=1
 Endif
 If find([F:ACLAC]CODCOL,ACLAF9_FLDGRP(1..N_ACLAF9))=0 & find([F:ACLAC]CODCOL,USED_FLDGRP(1..N_USED))<>0
  J=0
  Gosub ADD_CLA_LIG_COL
 Endif
Next

#collections with classe 1-1
For [ACLAC] Where CODCLA=[L]CURCLA & MINCOL=2 & MAXCOL=1
 If I=0
  Gosub ADD_CLA_COL
  I+=1
 Endif
 J=find([F:ACLAC]CODCOL,ACLAF9_FLDGRP(1..N_ACLAF9))
 If J<>0 & find([F:ACLAC]CODCOL,USED_FLDGRP(1..N_USED))<>0
  Gosub ADD_CLA_LIG_COL
 Endif
Next
For J=1 To N_ACLAF9
 If ACLAF9_PARKEY(J)<>""
  Call FIND_SUBCLASS([L]DOSSIER,[L]ORICLA,[L]CURCLA,ACLAF9_PARKEY(J),WLEV,ACLAF9_LNKCLA(J),"",ACLAF9_FLDGRP(J),ACLAF9_ACTFLD(J),ACLAF9_COLCAR(J),[L]TBCLAPARENT)
  ACLAF9_PARKEY(J)=""
 Endif
Next

#collections with classe other than 1-1
For [ACLAC] Where CODCLA=[L]CURCLA & !(MINCOL=2 & MAXCOL=1)
 If I=0
  Gosub ADD_CLA_COL
  I+=1
 Endif
 J=find([F:ACLAC]CODCOL,ACLAF9_FLDGRP(1..N_ACLAF9))
 If J<>0 & find([F:ACLAC]CODCOL,USED_FLDGRP(1..N_USED))<>0
  Gosub ADD_CLA_LIG_COL
 Endif
Next
For J=1 To N_ACLAF9
 If ACLAF9_PARKEY(J)<>""
  Call FIND_SUBCLASS([L]DOSSIER,[L]ORICLA,[L]CURCLA,ACLAF9_PARKEY(J),WLEV,ACLAF9_LNKCLA(J),"",ACLAF9_FLDGRP(J),ACLAF9_ACTFLD(J),ACLAF9_COLCAR(J),[L]TBCLAPARENT)
 Endif
Next
#On ne doit garder que les parents
[L]TBCLAPARENT(NOCLAFIND) = ""
End


#--------------#
$ADD_CLA
Local Integer NO
NO=[M:ACLA1B]NBR
NOCLA=NO+1
[M:ACLA1B]NBR+=1
[M:ACLA1B]ORD(NO)=[M:ACLA1B]NBR
[M:ACLA1B]LEV(NO)=WLEV
#---
[M:ACLA1B]CODE(NO)=[F:ACLA]CODCLA
[M:ACLA1B]LIB(NO)=[F:ACLA]INTCLA
If [L]CURGRP<>""
[M:ACLA1B]INTITLIB(NO)=[L]CURGRP-[L]CURCOLCAR+" "
Elsif [L]CURABR<>""
[M:ACLA1B]INTITLIB(NO)="["+[L]CURABR+"] "
Endif
[M:ACLA1B]INTITLIB(NO)+=[F:ACLA]CODCLA-func ASYRFNC.TEXTE([F:ACLA]INTCLA)
#---
If [L]PARLEV=0
[M:ACLA1B]PARKEY(NO)=""
[M:ACLA1B]ICO(NO)=[L]CST_ICO_CLA
Else
[M:ACLA1B]PARKEY(NO)=[L]PARKEY
[M:ACLA1B]ICO(NO)=[L]CST_ICO_UNCLA
Endif
If WLEV=1 | maxtab(TBCLAPARENT)=0
[M:ACLA1B]EXPFLG(NO)=2 : #Déplier à Oui
Else
[M:ACLA1B]EXPFLG(NO)=1 : #Déplier à Non
Endif
[M:ACLA1B]KEYC(NO)=num$(NOCLA)+[F:ACLA]CODCLA
#---
If [L]CURACT<>"" : [M:ACLA1B]ACV(NO)="("+[L]CURACT+")" : Endif
[M:ACLA1B]TYP(NO)="-"-mess([F:ACLA]TYPCLA,7986,1)
If [F:ACLA]CODACT<>"" : [M:ACLA1B]ACTCLA(NO)="("+[F:ACLA]CODACT+")" : Endif
If [F:ACLA]TABREF<>"" : [M:ACLA1B]TABREF(NO)="-"-mess(131,133,1)-[F:ACLA]TABREF : Endif

If [L]ERR=1
 Gosub ADD_CLA_NEXT
Else
 For I=0 To [F:ACLA]NBRTRT-1
  If [F:ACLA]CODTRT(I)<>""
   If I=0
    Gosub ADD_CLA_TRT
   Endif
   Gosub ADD_CLA_LIG_TRT
  Endif
 Next
 I=0
 For [ACLAK]ACLAK1 Where CODCLA=[F:ACLA]CODCLA
  If I=0
   Gosub ADD_CLA_LNK
   I+=1
  Endif
  Gosub ADD_CLA_LIG_LNK
 Next
Endif
Return

#--------------#
$ADD_CLA_TRT
[M:ACLA1B]ICO(NOCLA-1)=[L]CST_ICO_CLA
Local Integer NO
NO=[M:ACLA1B]NBR
[M:ACLA1B]NBR+=1
[M:ACLA1B]ORD(NO)=[M:ACLA1B]NBR
[M:ACLA1B]LEV(NO)=WLEV+1
#---
[M:ACLA1B]CODE(NO)=num$(NOCLA)+[F:ACLA]CODCLA+"/TRT"
[M:ACLA1B]LIB(NO)=0
[M:ACLA1B]INTITLIB(NO)=mess(262,143,1)
#---
[M:ACLA1B]PARKEY(NO)=num$(NOCLA)+[F:ACLA]CODCLA
[M:ACLA1B]KEYC(NO)=num$(NOCLA)+[F:ACLA]CODCLA+"/TRT"
[M:ACLA1B]ICO(NO)=[L]CST_ICO_TRT
[M:ACLA1B]EXPFLG(NO)=1 : #Déplier à Non
Return

$ADD_CLA_LIG_TRT
Local Integer NO
NO=[M:ACLA1B]NBR
[M:ACLA1B]NBR+=1
[M:ACLA1B]ORD(NO)=[M:ACLA1B]NBR
[M:ACLA1B]LEV(NO)=WLEV+2
#---
[M:ACLA1B]CODE(NO)=num$(NOCLA)+[F:ACLA]CODCLA+"/TRT/"+[F:ACLA]CODTRT(I)
[M:ACLA1B]LIB(NO)=0
[M:ACLA1B]INTITLIB(NO)=num$([F:ACLA]RANTRT(I))-mess([F:ACLA]TYPTRT(I),7844,1)-[F:ACLA]CODTRT(I)
#---
[M:ACLA1B]PARKEY(NO)=num$(NOCLA)+[F:ACLA]CODCLA+"/TRT"
[M:ACLA1B]KEYC(NO)=num$(NOCLA)+[F:ACLA]CODCLA+"/TRT/"+[F:ACLA]CODTRT(I)
[M:ACLA1B]ICO(NO)=[L]CST_ICO_UNTRT
[M:ACLA1B]EXPFLG(NO)=1 : #Déplier à Non
#---
If [F:ACLA]ACTTRT(I)<>"" : [M:ACLA1B]ACV(NO)="("+[F:ACLA]ACTTRT(I)+")" : Endif
Return

#--------------#
$ADD_CLA_COL
[M:ACLA1B]ICO(NOCLA-1)=[L]CST_ICO_CLA
Local Integer NO
NO=[M:ACLA1B]NBR
[M:ACLA1B]NBR+=1
[M:ACLA1B]ORD(NO)=[M:ACLA1B]NBR
[M:ACLA1B]LEV(NO)=WLEV+1
#---
[M:ACLA1B]CODE(NO)=num$(NOCLA)+[F:ACLAC]CODCLA+"/COL"
[M:ACLA1B]LIB(NO)=0
[M:ACLA1B]INTITLIB(NO)=mess(261,143,1)
#---
[M:ACLA1B]PARKEY(NO)=num$(NOCLA)+[F:ACLAC]CODCLA
[M:ACLA1B]KEYC(NO)=num$(NOCLA)+[F:ACLAC]CODCLA+"/COL"
[M:ACLA1B]ICO(NO)=[L]CST_ICO_COL
If WLEV=1 | maxtab(TBCLAPARENT)=1
[M:ACLA1B]EXPFLG(NO)=2 : #Déplier à Oui
Else
[M:ACLA1B]EXPFLG(NO)=1 : #Déplier à Non
Endif
Return

$ADD_CLA_LIG_COL
If J<>0 : #Store Parent values
  ACLAF9_PARKEY(J)=num$(NOCLA)+[F:ACLAC]CODCLA+"/COL"
  ACLAF9_COLCAR(J)="["+mess([F:ACLAC]MINCOL,7966,1)-"-"
  #---
  If [F:ACLAC]ACTCOL<>""
     ACLAF9_COLCAR(J)-=[F:ACLAC]ACTCOL
  Elsif [F:ACLAC]MAXCOL=0
     ACLAF9_COLCAR(J)-=".."
  Else
     ACLAF9_COLCAR(J)-=num$([F:ACLAC]MAXCOL)
  Endif
  If [F:ACLAC]PROCOL<>""
     ACLAF9_COLCAR(J)-="("+[F:ACLAC]PROCOL+")"
  Endif
  ACLAF9_COLCAR(J)+="]"
  #---
Else
  Local Integer NO
  NO=[M:ACLA1B]NBR
  [M:ACLA1B]NBR+=1
  [M:ACLA1B]ORD(NO)=[M:ACLA1B]NBR
  [M:ACLA1B]LEV(NO)=WLEV+2
  #---
  [M:ACLA1B]CODE(NO)=num$(NOCLA)+[F:ACLAC]CODCLA+"/COL/"+[F:ACLAC]CODCOL
  [M:ACLA1B]LIB(NO)=0

  #---
  [M:ACLA1B]INTITLIB(NO)=[F:ACLAC]CODCOL-"["+mess([F:ACLAC]MINCOL,7966,1)-"-"
  If [F:ACLAC]ACTCOL<>""
   [M:ACLA1B]INTITLIB(NO)-=[F:ACLAC]ACTCOL
  Elsif [F:ACLAC]MAXCOL=0
   [M:ACLA1B]INTITLIB(NO)-=".."
  Else
   [M:ACLA1B]INTITLIB(NO)-=num$([F:ACLAC]MAXCOL)
  Endif
  If [F:ACLAC]PROCOL<>""
   [M:ACLA1B]INTITLIB(NO)-="("+[F:ACLAC]PROCOL+")"
  Endif
  [M:ACLA1B]INTITLIB(NO)+="]"-func ASYRFNC.TEXTE([F:ACLAC]INTCOL)
  #---
  [M:ACLA1B]PARKEY(NO)=num$(NOCLA)+[F:ACLAC]CODCLA+"/COL"
  [M:ACLA1B]KEYC(NO)=num$(NOCLA)+[F:ACLAC]CODCLA+"/COL/"+[F:ACLAC]CODCOL
  # -- ??
  If IS_USED=0
   [M:ACLA1B]ICO(NO)=[L]CST_ICO_NOCOL
  Else
   [M:ACLA1B]ICO(NO)=[L]CST_ICO_UNCOL
  Endif
  [M:ACLA1B]EXPFLG(NO)=1 : #Déplier à Non
Endif
Return

#--------------#
$ADD_CLA_LNK
[M:ACLA1B]ICO(NOCLA-1)=[L]CST_ICO_CLA
Local Integer NO
NO=[M:ACLA1B]NBR
[M:ACLA1B]NBR+=1
[M:ACLA1B]ORD(NO)=[M:ACLA1B]NBR
[M:ACLA1B]LEV(NO)=WLEV+1
#---
[M:ACLA1B]CODE(NO)=num$(NOCLA)+[F:ACLA]CODCLA+"/LNK"
[M:ACLA1B]LIB(NO)=0
[M:ACLA1B]INTITLIB(NO)=mess(101,142,1)
#---
[M:ACLA1B]PARKEY(NO)=num$(NOCLA)+[F:ACLA]CODCLA
[M:ACLA1B]KEYC(NO)=num$(NOCLA)+[F:ACLA]CODCLA+"/LNK"
[M:ACLA1B]ICO(NO)=[L]CST_ICO_LNK
[M:ACLA1B]EXPFLG(NO)=1 : #Déplier à Non
Return

$ADD_CLA_LIG_LNK
Local Integer NO
NO=[M:ACLA1B]NBR
[M:ACLA1B]NBR+=1
[M:ACLA1B]ORD(NO)=[M:ACLA1B]NBR
[M:ACLA1B]LEV(NO)=WLEV+2
#---
[M:ACLA1B]CODE(NO)=num$(NOCLA)+[F:ACLA]CODCLA+"/LNK/"+[F:ACLAK]REFLNK
[M:ACLA1B]LIB(NO)=0
#---
[M:ACLA1B]INTITLIB(NO)=[F:ACLAK]REFLNK+":"-mess(263,143,1)-[F:ACLAK]TABORI
If [F:ACLAK]ABRORI<>""
 [M:ACLA1B]INTITLIB(NO)-="["+[F:ACLAK]ABRORI+"]"
Endif
[M:ACLA1B]INTITLIB(NO)-="/"-[F:ACLAK]TABLNK
If [F:ACLAK]ABRLNK<>""
 [M:ACLA1B]INTITLIB(NO)-="["+[F:ACLAK]ABRLNK+"]"
Endif
#---
[M:ACLA1B]PARKEY(NO)=num$(NOCLA)+[F:ACLA]CODCLA+"/LNK"
[M:ACLA1B]KEYC(NO)=num$(NOCLA)+[F:ACLA]CODCLA+"/LNK/"+[F:ACLAK]REFLNK
[M:ACLA1B]ICO(NO)=[L]CST_ICO_UNLNK
[M:ACLA1B]EXPFLG(NO)=1 : #Déplier à Non
#---
If [F:ACLAK]ACVLNK<>"" : [M:ACLA1B]ACV(NO)="("+[F:ACLAK]ACVLNK+")" : Endif
[M:ACLA1B]CLA(NO)=mess(3,140,1)-[F:ACLAK]CLALNK
[M:ACLA1B]TYP(NO)="["+mess([F:ACLAK]TYPLNK,2916,1)+"]"
Return

#--------------#
$ADD_CLA_NEXT
[M:ACLA1B]ICO(NOCLA-1)=[L]CST_ICO_CLA
Local Integer NO
NO=[M:ACLA1B]NBR
[M:ACLA1B]NBR+=1
[M:ACLA1B]ORD(NO)=[M:ACLA1B]NBR
[M:ACLA1B]LEV(NO)=WLEV+1
#---
[M:ACLA1B]CODE(NO)=num$(NOCLA)+[F:ACLA]CODCLA+"/..."
[M:ACLA1B]LIB(NO)=0
[M:ACLA1B]INTITLIB(NO)="..."
#---
[M:ACLA1B]PARKEY(NO)=num$(NOCLA)+[F:ACLA]CODCLA
[M:ACLA1B]KEYC(NO)=num$(NOCLA)+[F:ACLA]CODCLA+"/..."
[M:ACLA1B]ICO(NO)=[L]CST_ICO_CLARECURS
If WLEV=1
[M:ACLA1B]EXPFLG(NO)=2 : #Déplier à Oui
Else
[M:ACLA1B]EXPFLG(NO)=1 : #Déplier à Non
Endif
Return
#--------------#

$ADD_CCLA
Local Integer WNBC
WNBC=[M:ACLA1B]NBC
[M:ACLA1B]NBC+=1
[M:ACLA1B]CORD(WNBC)=[M:ACLA1B]NBC
[M:ACLA1B]CCLA(WNBC)=[F:ACLA]CODCLA
[M:ACLA1B]CINTITLIB(WNBC)=func ASYRFNC.TEXTE([F:ACLA]INTCLA)
[M:ACLA1B]CCLAPAR(WNBC)=[L]PARCLA
[M:ACLA1B]CTAB(WNBC)=[F:ACLA]TABREF

[M:ACLA1B]CCOL(WNBC)=[L]CURGRP
[M:ACLA1B]CCOLCAR(WNBC)=[L]CURCOLCAR

[M:ACLA1B]CLEV(WNBC)=WLEV
Return
#--------------#

$ADD_REP
Local Integer NO
NO=[M:ACLA1B]NBR
NOCLA=NO+1
[M:ACLA1B]NBR+=1
[M:ACLA1B]ORD(NO)=[M:ACLA1B]NBR
[M:ACLA1B]LEV(NO)=WLEV
#---
[M:ACLA1B]CODE(NO)=[F:ASW]CODREP
[M:ACLA1B]LIB(NO)=[F:ASW]INTREP
[M:ACLA1B]INTITLIB(NO)=[F:ASW]CODREP-func ASYRFNC.TEXTE([F:ASW]INTREP)
#---
[M:ACLA1B]PARKEY(NO)=""
[M:ACLA1B]ICO(NO)=[L]CST_ICO_REP

[M:ACLA1B]EXPFLG(NO)=2 : #Déplier à Oui

[M:ACLA1B]KEYC(NO)=num$(NOCLA)+[F:ASW]CODREP
#---
#If [L]CURACT<>"" : [M:ACLA1B]ACV(NO)="("+[L]CURACT+")" : Endif
[M:ACLA1B]TYP(NO)="-"-mess([F:ASW]TYPMSKREP,7963,1)
If [F:ASW]CODACT<>"" : [M:ACLA1B]ACTCLA(NO)="("+[F:ASW]CODACT+")" : Endif

For I=0 To [F:ASW]NBRTRT-1
 If [F:ASW]CODTRT(I)<>""
  If I=0
   Gosub ADD_REP_TRT
  Endif
  Gosub ADD_REP_LIG_TRT
 Endif
Next


Local File =DOSSIER+".ASHWFLD"    [ASWF9]
Local Integer N_USED,IS_USED,UN_USED
Local Char USED_FLDGRP(GLONAVA) (1..)
Local Char UNUSED_FLDGRP(GLONAVA) (1..)

For [ASWF9]ASWF1 Where CODREP=[F:ASW]CODREP & FLDGRP<>""
 If find([F:ASWF9]FLDGRP,USED_FLDGRP(1..N_USED))=0
  N_USED+=1
  USED_FLDGRP(N_USED)=[F:ASWF9]FLDGRP
 Endif
Next
Close Local File [ASWF9]

Local Integer ICOL
ICOL=0
IS_USED=0
#collections without properties
For [ASWC] Where CODREP=[F:ASW]CODREP
 If ICOL=0
  Gosub ADD_REP_COL
  ICOL+=1
 Endif
 If instr(0,[F:ASWC]CODCOL,".")=0 & find([F:ASWC]CODCOL,USED_FLDGRP(1..N_USED))=0
  UN_USED+=1
  UNUSED_FLDGRP(UN_USED)=[F:ASWC]CODCOL
  J=0
  Gosub ADD_REP_LIG_COL
 Elsif instr(0,[F:ASWC]CODCOL,".")<>0
 #verification collection existante
  Gosub CHARGE_GRP2 From SUBASW2
  If !find([F:ASWC]CODCOL,TEX)
   UN_USED+=1
   UNUSED_FLDGRP(UN_USED)=[F:ASWC]CODCOL
   J=0
   Gosub ADD_REP_LIG_COL
  Endif
 Endif
Next

IS_USED=1
#collections with classe 1-1
For [ASWC] Where CODREP=[F:ASW]CODREP & MINCOL=2 & MAXCOL=1
 If ICOL=0
  Gosub ADD_REP_COL
  ICOL+=1
 Endif
 J=0
 If find([F:ASWC]CODCOL,UNUSED_FLDGRP(1..UN_USED))=0
  Gosub ADD_REP_LIG_COL
 Endif
Next

#collections with classe other than 1-1
For [ASWC] Where CODREP=[F:ASW]CODREP & !(MINCOL=2 & MAXCOL=1)
 If ICOL=0
  Gosub ADD_REP_COL
  ICOL+=1
 Endif
 J=0
 If find([F:ASWC]CODCOL,UNUSED_FLDGRP(1..UN_USED))=0
  Gosub ADD_REP_LIG_COL
 Endif
Next

Return

#--------------#
$ADD_REP_TRT
Local Integer NO
NO=[M:ACLA1B]NBR
[M:ACLA1B]NBR+=1
[M:ACLA1B]ORD(NO)=[M:ACLA1B]NBR
[M:ACLA1B]LEV(NO)=WLEV+1
#---
[M:ACLA1B]CODE(NO)=num$(NOCLA)+[F:ASW]CODCLA+"/TRT"
[M:ACLA1B]LIB(NO)=0
[M:ACLA1B]INTITLIB(NO)=mess(262,143,1)
#---
[M:ACLA1B]PARKEY(NO)=num$(NOCLA)+[F:ASW]CODREP
[M:ACLA1B]KEYC(NO)=num$(NOCLA)+[F:ASW]CODREP+"/TRT"
[M:ACLA1B]ICO(NO)=[L]CST_ICO_TRT
[M:ACLA1B]EXPFLG(NO)=1 : #Déplier à Non
Return

$ADD_REP_LIG_TRT
Local Integer NO
NO=[M:ACLA1B]NBR
[M:ACLA1B]NBR+=1
[M:ACLA1B]ORD(NO)=[M:ACLA1B]NBR
[M:ACLA1B]LEV(NO)=WLEV+2
#---
[M:ACLA1B]CODE(NO)=num$(NOCLA)+[F:ASW]CODREP+"/TRT/"+[F:ASW]CODTRT(I)
[M:ACLA1B]LIB(NO)=0
[M:ACLA1B]INTITLIB(NO)=num$([F:ASW]RANTRT(I))-mess([F:ASW]TYPTRT(I),7844,1)-[F:ASW]CODTRT(I)
#---
[M:ACLA1B]PARKEY(NO)=num$(NOCLA)+[F:ASW]CODREP+"/TRT"
[M:ACLA1B]KEYC(NO)=num$(NOCLA)+[F:ASW]CODREP+"/TRT/"+[F:ASW]CODTRT(I)
[M:ACLA1B]ICO(NO)=[L]CST_ICO_UNTRT
[M:ACLA1B]EXPFLG(NO)=1 : #Déplier à Non
#---
If [F:ASW]ACTTRT(I)<>"" : [M:ACLA1B]ACV(NO)="("+[F:ASW]ACTTRT(I)+")" : Endif
Return

#--------------#
$ADD_REP_COL
Local Integer NO
NO=[M:ACLA1B]NBR
[M:ACLA1B]NBR+=1
[M:ACLA1B]ORD(NO)=[M:ACLA1B]NBR
[M:ACLA1B]LEV(NO)=WLEV+1
#---
[M:ACLA1B]CODE(NO)=num$(NOCLA)+[F:ASWC]CODREP+"/COL"
[M:ACLA1B]LIB(NO)=0
[M:ACLA1B]INTITLIB(NO)=mess(261,143,1)
#---
[M:ACLA1B]PARKEY(NO)=num$(NOCLA)+[F:ASWC]CODREP
[M:ACLA1B]KEYC(NO)=num$(NOCLA)+[F:ASWC]CODREP+"/COL"
[M:ACLA1B]ICO(NO)=[L]CST_ICO_COL
If WLEV=1
[M:ACLA1B]EXPFLG(NO)=2 : #Déplier à Oui
Else
[M:ACLA1B]EXPFLG(NO)=1 : #Déplier à Non
Endif
Return

$ADD_REP_LIG_COL
Local Integer NO
NO=[M:ACLA1B]NBR
[M:ACLA1B]NBR+=1
[M:ACLA1B]ORD(NO)=[M:ACLA1B]NBR
[M:ACLA1B]LEV(NO)=WLEV+2
#---
[M:ACLA1B]CODE(NO)=num$(NOCLA)+[F:ASWC]CODREP+"/COL/"+[F:ASWC]CODCOL
[M:ACLA1B]LIB(NO)=0

#---
[M:ACLA1B]INTITLIB(NO)=[F:ASWC]CODCOL-"["+mess([F:ASWC]MINCOL,7966,1)-"-"
If [F:ASWC]ACTCOL<>""
 [M:ACLA1B]INTITLIB(NO)-=[F:ASWC]ACTCOL
 If J<>0 : #Coll Parent info
   ACLAF9_COLCAR(J)-=[F:ASWC]ACTCOL
 Endif
Elsif [F:ASWC]MAXCOL=0
 [M:ACLA1B]INTITLIB(NO)-=".."
 If J<>0 : #Coll Parent info
   ACLAF9_COLCAR(J)-=".."
 Endif
Else
 [M:ACLA1B]INTITLIB(NO)-=num$([F:ASWC]MAXCOL)
 If J<>0 : #Coll Parent info
   ACLAF9_COLCAR(J)-=num$([F:ASWC]MAXCOL)
 Endif
Endif
If [F:ASWC]PROCOL<>""
 [M:ACLA1B]INTITLIB(NO)-="("+[F:ASWC]PROCOL+")"
 If J<>0 : #Coll Parent info
   ACLAF9_COLCAR(J)-="("+[F:ASWC]PROCOL+")"
 Endif
Endif
[M:ACLA1B]INTITLIB(NO)+="]"-func ASYRFNC.TEXTE([F:ASWC]INTCOL)
If J<>0 : #Coll Parent info
  ACLAF9_COLCAR(J)+="]"
Endif
#---
[M:ACLA1B]PARKEY(NO)=num$(NOCLA)+[F:ASWC]CODREP+"/COL"
[M:ACLA1B]KEYC(NO)=num$(NOCLA)+[F:ASWC]CODREP+"/COL/"+[F:ASWC]CODCOL
If IS_USED=0
 [M:ACLA1B]ICO(NO)=[L]CST_ICO_NOCOL
Else
 [M:ACLA1B]ICO(NO)=[L]CST_ICO_UNCOL
Endif
[M:ACLA1B]EXPFLG(NO)=1 : #Déplier à Non

Return
