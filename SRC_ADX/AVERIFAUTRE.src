#<AdxTL>@(#)4.0.0.0 $Revision$
######################################################
#  Différents contrôles :
#  
#  Attention : pour la recherche des subprog non finis, ou vides : le traitement est complémentaire
#  de VERIFDAC qui va (entre autres vérifier par rapport aux dico des actions si un subprog est
#  vide ou non)
#
#-----------------------------------------------------------------------------------------------------------#

Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
    Call TRAITE_CHAR(VALBOUT,PARBOUT, "", "AVERIFSRC", "AVERIFSRC", 3, "") From GTRAITE
End
 
Subprog AVERIFAUTRE(CHEMINTRA, PATCH, SRCPATCH, NOMTRT, DOSSIER, PMODULE, OWNER, EXCLSUP,
&     PORT, MACHINE, CHEMINTRAW, PNUMERREURSEL, NBERRTOT, NBWARTOT, PDEMANDEUR,
&     PBLISTETRT, PLIBVERIF, PLANGUE)

Value Char CHEMINTRA    :  # Chemin où seront créés les fichiers de trace
Value Char PATCH        :  # Si patch, on ne vérifie que les traitement modifiés
Value Char SRCPATCH     :  # Si patch, chemin où sont les traitements patchés
Value Char NOMTRT       :  # Nom du source à analyser (jokers autorisés)
Value Char DOSSIER      :  # Si non patch, dossier analysé

Value Integer PMODULE    :  # Si travail sur sources d'un module particulier
Value Integer OWNER     :  # Si on veut travailler sur les sources d'un owner particulier
Value Integer EXCLSUP   :  # exclure le module superviseur
Value Integer PORT      :  # port du dossier
Value Char MACHINE      :  # machine du dossier
Value Char CHEMINTRAW
Value Integer PNUMERREURSEL : # uniquement cette erreur sélectionnée
Variable Integer NBERRTOT, NBWARTOT
Value Integer PDEMANDEUR
Variable Integer PBLISTETRT
Value Char PLIBVERIF
Value Char PLANGUE

# bidouille pour ne sortir que les erreurs de doc PE en batch
#If GSERVEUR
#PNUMERREURSEL = 23
#Endif

Local Char NOMPROG(20), NOMCALL(20)
Local Char TXTERR(200)
Local Integer MAX_ERRCALL, TITAECRIRE, TITAECRIREW, NBERREUR, NBWARNING
Local Integer TERREUR(50)
Local Char DOSSIER2(100), YWNOMET(50)

Local Integer IP, IP2, IQ, IQ2PTS, WIGNWRSEQ, WIGNWRTRT, NSK, NSKLEC, NLIGSAV, IB, WMIGRATE

Local Integer NBTRAITES, NLIG, INDERREUR
Local Char TERRMES(100)(46)
Local Shortint SAUVEMODULE

Local Integer BCHAINELEC, FST, BOK
Local Char WFILE(10), WABREV(5)

Local Clbfile CHAINE(3), CHAINE1(3), CHAINELEC(3), CHAININS(3), CHAINECPT(3)
Local Clbfile CHBOUCLE(3), CHIF(3), CHCASE(3), CHWHILE(3)
Local Integer NLIGFW, NLIGIF, NLIGCASE, NLIGWHILE

#Local Char ALPHA(27) : ALPHA="ABCDEFGHIJKLMNOPQRSTUVWXYZ_"
#Local Char ALPHAN(37) : ALPHAN=ALPHA+"0123456789"
#Local Char SPACEN(37) : SPACEN=space$(len(ALPHAN))
Local Char WTACTION(10)(50)



Local Integer WBFUNP, WNBACTION, WBACTION, NIVFORREAD
Local Char TXTPROG(20), WNOMSUB(30), WSAVSUB(30), ZADXIFS, ZADXIRS, WTEXTE(80), WSAVTXTPROG(20)

Local Integer YIPET, WCODETRVE, YCODETIQTRV, YIPET, BETQAPRES, NLIGENDRT, IR, ILF, IB, WFINSUBPROG, WFINTRV, TRV

# compteurs

Local Integer CPTRFOR, CPTRIF, CPTRCASE, CPTRWHILE, WDSSUBOUFUN


# ----------------------------------------------------------------------------------------------------------

    MAX_ERRCALL = GNBERREUR(GNUMMOUL)
    ZADXIFS = adxifs
    ZADXIRS = adxirs
    adxifs  = chr$(0)
    adxirs  = chr$(10)


    Call TEMPON("VERIFAUTRE Initialisation du traitement...") From GESECRAN
    SAUVEMODULE = -1
    
    If MACHINE = ""
        DOSSIER2 = DOSSIER
    Else
        DOSSIER2 = MACHINE + ":" + num$(PORT) + "@" + DOSSIER
    Endif
    
    If clalev ([F:ADC])
        Close File [ADC]
    Endif
    If clalev ([F:AST])
        Close File [AST]
    Endif
    If clalev ([F:ADO])
        Close File [ADO]
    Endif


    Local File = DOSSIER2 + ".ADICTRT"   [ADC] : # table des traitements 
    Local File = DOSSIER2 + ".APLSTD"    [AST]
    Local File = DOSSIER2 + ".ADOCUMENT" [ADO]

    
    Openo CHEMINTRA, -1
    Wrseq
    Wrseq
    Wrseq
    Wrseq "-------------------------###" - func AVERIFSRC.MESNUM(48, 144, PLIBVERIF, "", "", "", "") - ". ###---------------------------"
    Wrseq
    Wrseq

    Openo
    
    Openo CHEMINTRAW, -1
    Wrseq
    Wrseq
    Wrseq
    Wrseq "-------------------------###" - func AVERIFSRC.MESNUM(48, 144, PLIBVERIF, "", "", "", "") - ". ###---------------------------"
    Wrseq
    Wrseq

    Openo
    
    Openo CHEMINTRA, -1  Using [FER]
    Openo CHEMINTRAW, -1  Using [FWR]

    Call CHGACT(WNBACTION, WTACTION) From AVERIFDAC
    
#--------------------------------#
# Tableau des traitements adx
#--------------------------------#

    If NOMTRT = "" or instr(1, NOMTRT, "*")
        If PBLISTETRT = 0
            Call LISTETRT(PDEMANDEUR, PORT, MACHINE, DOSSIER) From AVERIFSRC
            PBLISTETRT = 1
        Endif
    Else
        GTTRAITEMENTS(1) = NOMTRT
        GNBTRTADX = 1
    Endif

    Call TEMPON("VERIFAUTRE") From GESECRAN

    For NF=1 To GNBTRTADX
        If NF > GMAX_TRT
            Wrseq Using [FER]
            Wrseq Using [FER]
            Wrseq "Attention : nombre de traitements" - num$(GNBTRTADX) - "supérieur au max" - num$(GMAX_TRT)  Using [FER]
            Break
        Endif

        If PATCH = "" | filinfo(SRCPATCH + "/" + GTTRAITEMENTS(NF) + ".src", 0) > 0
          Gosub ANALYSE
        Endif
    Next NF
 
    Wrseq Using [FER]
    Wrseq Using [FER]
    Wrseq func AVERIFSRC.MESNUM(45, 144, num$(NBERREUR), num$(NBTRAITES), "", "", "")  Using [FER]
    Wrseq Using [FER]
 
    Wrseq Using [FWR]
    Wrseq Using [FWR]
    Wrseq func AVERIFSRC.MESNUM(45, 144, num$(NBWARNING), num$(NBTRAITES), "", "", "")  Using [FWR]
    Wrseq Using [FWR]


    NBERRTOT += NBERREUR
    NBWARTOT += NBWARNING
 
    If PNUMERREURSEL
        If PNUMERREURSEL = 7
            IR = 7
            ILF = 8
        Else
            IR = PNUMERREURSEL
            ILF = PNUMERREURSEL
        Endif
    Else    
        IR = 1
        ILF = MAX_ERRCALL
    Endif

    Call RECAPMOUL(IR, ILF, TERREUR) From AVERIFSRC
 
 
 
    
    Wrseq Using [FER]
    Wrseq Using [FER]

    Wrseq func AVERIFSRC.MESNUM(46, 144, PLIBVERIF, "", "", "", "") - time$  Using [FER]
    Wrseq Using [FER]

    Wrseq func AVERIFSRC.MESNUM(46, 144, PLIBVERIF, "", "", "", "") - time$ Using [FWR]
    Wrseq Using [FWR]

    adxifs=ZADXIFS
    adxirs=ZADXIRS

    Openo  Using [FER]
    Openo  Using [FWR]

    Call TEMPOFF From GESECRAN

    Close File [ADC]
    Close File [AST]
    Close File [ADO]


    Goto FINCALL


#------------------------------------------------------------------------------------------------------------------------#


$ANALYSE

    If mod(NF,100) = 0
        Call TEMPON("VERIFAUTRE :" - num$(NF) + "/" + num$(GNBTRTADX) - GTTRAITEMENTS(NF) + ".src" -
&        "nb :" - num$(NBERREUR)) From GESECRAN
    Endif    

    If func AVERIFSRC.SRCAPASTRAITER (GTTRAITEMENTS(NF), NOMTRT, DOSSIER2, PMODULE, EXCLSUP, PATCH, SRCPATCH,
&           OWNER, TXTERR, PDEMANDEUR)
        Return
    Endif


    TITAECRIRE = 1
    NBTRAITES += 1
    
    If PATCH <>"" and filinfo(SRCPATCH + "/" + GTTRAITEMENTS(NF) + ".src", 0) > 0
       Openi SRCPATCH + "/" + GTTRAITEMENTS(NF) + ".src", 0
    Else
       Openi filpath("TRT", GTTRAITEMENTS(NF), "src", DOSSIER2), 0
    Endif
    
    Raz WIGNWRSEQ, WIGNWRTRT, WMIGRATE
    FST=0
    NLIG = -1
    CHAINELEC = ""
    BCHAINELEC = 0
    TITAECRIRE = 1
    TITAECRIREW = 1
    

    WFINSUBPROG = 1
    WFINTRV = 0       # on a trouvé RETURN ou END mais il faut voir si on n'est pas dans un test
                      # si instruction suivante contient Subprog ou Funprog : cela en est bien 1
    WSAVSUB = ""
    WNOMSUB = ""
    WBACTION = 0

    WCODETRVE = 0

    # cas des étiquettes BETQAPRES
    YCODETIQTRV = 0
    YWNOMET = ""
    YIPET = 0

    NIVFORREAD = 0
    CPTRFOR   = 0
    CPTRIF    = 0
    CPTRCASE  = 0
    CPTRWHILE = 0
    WDSSUBOUFUN = 0

    While FST=0
        GCPTDBG = 0
        Call LIREETFMT(CHAINE, CHAINELEC, BCHAINELEC, FST, NLIG, NSK, NSKLEC) From AVERIFSRC

        Call VIRECOMCHK (CHAINE, 1, 0, WFILE, WABREV, WIGNWRSEQ, WIGNWRTRT, WMIGRATE) From AVERIFSRC
        # CBO 20110124 FQ70150
        If WIGNWRTRT >= 20 and WIGNWRTRT < 30
            WIGNWRTRT -= 20
        Elsif WIGNWRTRT >= 30 and WIGNWRTRT < 40
            WIGNWRTRT -= 30
        Endif

        If WIGNWRTRT = 1 or WIGNWRTRT = 3
            Return
        Endif

        CHAININS = CHAINE
        CHAINE = func AVERIFSRC.DECOUPCH (CHAININS, WIGNWRSEQ)
        While CHAINE <> ""
            GCPTDBG += 1

            #__________________________________________________________________________________________________
            # partie réservée à des contrôles courts (et/ou temporaires)

            CHAINECPT = vireblc(CHAINE, 4)
            
            # message imprécis
            INDERREUR = 21
            If PNUMERREURSEL = 0 or PNUMERREURSEL = INDERREUR
                Gosub ANAC01
            Endif
                
            #instruction obsolette
            If INDERREUR
                INDERREUR = 22
                If PNUMERREURSEL = 0 or PNUMERREURSEL = INDERREUR
                    Gosub ANAC02
                Endif
            Endif
            
            #doc PE manquante
            If INDERREUR
                INDERREUR = 23
                If PNUMERREURSEL = 0 or PNUMERREURSEL = INDERREUR
                    Call FGPOINTDOCPE(CHAINE, TXTERR, GTTRAITEMENTS(NF), PLANGUE)
                    If TXTERR <> ""
                        TERRMES(1) = TXTERR

                        Call ECRERREUR(23, PMODULE, GTTRAITEMENTS(NF),
&                            TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHBOUCLE,
&                            NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                            NLIGSAV, PATCH, WMIGRATE)               

                        CHAINE = ""
                        # INDERREUR à 0 veut dire que le cas est trouvé et que les suivants ne sont pas à traiter
                        INDERREUR = 0

                    Endif
                Endif
            Endif

            # If evalue("dim([F:ABV]CHP")) : inutile, suffisant : If dim([F:ABV]CHP)
            If INDERREUR
                INDERREUR = 24
                If PNUMERREURSEL = 0 or PNUMERREURSEL = INDERREUR
                    Gosub ANAC03
                Endif
            Endif


            #__________________________________________________________________________________________________
            # partie sur la cinématique des sources (pas de End...)            

            Gosub SUBFUNEND
            
            #__________________________________________________________________________________________________
            CHAINE = func AVERIFSRC.DECOUPCH (CHAININS, WIGNWRSEQ)
        Wend
    Wend 

    # traitement de fin du source
    If WNOMSUB <> ""
    
        If WFINTRV = 0 and WBACTION = 0
            TERRMES(2) = WNOMSUB - ":" - mess(1805, 144, 1)
            Call ECRERREUR(5, PMODULE, GTTRAITEMENTS(NF),
&                TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHBOUCLE,
&                NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                NLIGSAV, PATCH, WMIGRATE)               

        Endif

        If WCODETRVE = 0 and WBACTION = 0
            TERRMES(3) = WNOMSUB - ":" - mess(1806, 144, 1)
            Call ECRERREUR(6, PMODULE, GTTRAITEMENTS(NF),
&                TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHBOUCLE,
&                NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                NLIGSAV, PATCH, WMIGRATE)               

        Endif
    Endif

    # boucle non finie (jamais ?)
    If CPTRFOR
        TERRMES(1) = mess(1801, 144, 1) #- ":" - num$(CPTRFOR) 
                Call ECRERREUR(1, PMODULE, GTTRAITEMENTS(NF),
&                TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHBOUCLE,
&                NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                NLIGSAV, PATCH, WMIGRATE)               
    Endif

    # If non fini (jamais ?)
    If CPTRIF
        TERRMES(1) = mess(1802, 144, 1) #- ":" - num$(CPTRIF) 
                Call ECRERREUR(2, PMODULE, GTTRAITEMENTS(NF),
&                TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHIF,
&                NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                NLIGSAV, PATCH, WMIGRATE)               
    Endif

    # Case non fini (jamais ?)
    If CPTRCASE
        TERRMES(1) = mess(1803, 144, 1) #- ":" - num$(CPTRCASE) 
                Call ECRERREUR(3, PMODULE, GTTRAITEMENTS(NF),
&                TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHCASE,
&                NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                NLIGSAV, PATCH, WMIGRATE)               
    Endif

    # While non fini (jamais ?)
    If CPTRWHILE
        TERRMES(1) = mess(1804, 144, 1) #- ":" - num$(CPTRWHILE) 
                Call ECRERREUR(4, PMODULE, GTTRAITEMENTS(NF),
&                TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHWHILE,
&                NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                NLIGSAV, PATCH, WMIGRATE)               
    Endif




Return   
    
# verifie les subprog funprog non finis vides ...
$SUBFUNEND                

    WBFUNP = 0
    IP = func CHERCHEETQUOTE(1, CHAINE, "Subprog", IP)
    If IP = 0
        IP = func CHERCHEETQUOTE(1, CHAINE, "Funprog", IP)
        If IP
            WBFUNP = 1
            WDSSUBOUFUN = 1
            TXTPROG = "Funprog"
        Endif
    Else
        TXTPROG = "Subprog"
        WDSSUBOUFUN = 2
    Endif
    # On commence un nouveau Subprog (ou funprog)
    If IP
        WNOMSUB = right$(CHAINE, IP + 7)
        IP2 = instr(1, WNOMSUB, "(")
        If IP2
            WNOMSUB = left$(WNOMSUB, IP2 - 1)
        Endif
        WNOMSUB = vireblc(WNOMSUB, 4)


        If WSAVSUB <> ""

            # boucle non finie (jamais ?)
            If CPTRFOR
                TERRMES(1) = WSAVSUB - ":" - mess(1801, 144, 1) - ":" - num$(CPTRFOR)
                Call ECRERREUR(1, PMODULE, GTTRAITEMENTS(NF),
&                TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHBOUCLE,
&                NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                NLIGSAV, PATCH, WMIGRATE)
                CPTRFOR = 0
            Endif

            # If non fini (jamais ?)
            If CPTRIF
                TERRMES(1) = WSAVSUB - ":" - mess(1802, 144, 1) - ":" - num$(CPTRIF) 
                Call ECRERREUR(2, PMODULE, GTTRAITEMENTS(NF),
&                TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHIF,
&                NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                NLIGSAV, PATCH, WMIGRATE)
                CPTRIF = 0
            Endif

            # Case non fini (jamais ?)
            If CPTRCASE
                TERRMES(1) = WSAVSUB - ":" - mess(1803, 144, 1) - ":" - num$(CPTRCASE) 
                Call ECRERREUR(3, PMODULE, GTTRAITEMENTS(NF),
&                TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHCASE,
&                NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                NLIGSAV, PATCH, WMIGRATE)
                CPTRCASE = 0
            Endif

            # While non fini (jamais ?)
            If CPTRWHILE
                TERRMES(1) = WSAVSUB - ":" - mess(1804, 144, 1) - ":" - num$(CPTRWHILE) 
                Call ECRERREUR(4, PMODULE, GTTRAITEMENTS(NF),
&                TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHWHILE,
&                NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                NLIGSAV, PATCH, WMIGRATE)
                CPTRWHILE = 0
            Endif

            If NOMTRT = GTTRAITEMENTS(NF) and PNUMERREURSEL = 2
                Wrseq GTTRAITEMENTS(NF) - num$(NLIG)  - "________________ :" - WSAVTXTPROG - WSAVSUB Using [FER]
            Endif   


            # on n'a pas fini le précédent subprog
            If WFINTRV = 0 and WBACTION = 0
                TERRMES(2) = WNOMSUB - ":" - mess(1805, 144, 1) - ":" - WSAVSUB
                        Call ECRERREUR(5, PMODULE, GTTRAITEMENTS(NF),
&                       TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHBOUCLE,
&                       NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                       NLIGSAV, PATCH, WMIGRATE)               
            Endif

            # le précédent n'a pas de code
            If WCODETRVE = 0 and WBACTION = 0
                TERRMES(3) = WSAVSUB - ":" - mess(1806, 144, 1)
                        Call ECRERREUR(6, PMODULE, GTTRAITEMENTS(NF),
&                       TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHBOUCLE,
&                       NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                       NLIGSAV, PATCH, WMIGRATE)               

            Endif
        Endif


        Raz NLIGFW, NLIGENDRT, NIVFORREAD
        Raz CPTRFOR, CPTRIF, CPTRCASE, CPTRWHILE
        WSAVSUB = WNOMSUB
        WSAVTXTPROG = TXTPROG
        YWNOMET = ""
            
        WFINTRV = 0
        WCODETRVE = 0
        If WBFUNP
            WBACTION = 0
        Else
            WBACTION = func ESTACTION(WNOMSUB, WNBACTION, WTACTION)
        Endif
        YWNOMET = ""
        YCODETIQTRV = 0

        Return
    Endif

    # Décomposition des lignes à étudier :
    #on recherche si fin de subprog
    If func CHERCHEETQUOTE(1, CHAINE, "End", IP)
        NLIGENDRT = NLIG
        WFINTRV = 1
     
        If CPTRFOR and (NIVFORREAD and NIVFORREAD <= CPTRFOR)
            TERRMES(1) = mess(1807, 144, 1)
            Call ECRERREUR(7, PMODULE, GTTRAITEMENTS(NF),
&                TERRMES, TITAECRIRE, TITAECRIREW, "", CHBOUCLE,
&                NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                NLIGSAV, PATCH, WMIGRATE)
        Endif

        If WDSSUBOUFUN
            If CPTRFOR = 0 and CPTRIF = 0 and CPTRCASE = 0 and CPTRWHILE = 0 
                WDSSUBOUFUN = 0
            Endif       
        Else
            # test pour éviter les End au début (lors de l'appel via le source)
            If NLIG > 20
                TERRMES(1) = mess(1812, 144, 1)
                Call ECRERREUR(12, PMODULE, GTTRAITEMENTS(NF),
&                   TERRMES, TITAECRIRE, TITAECRIREW, "", CHBOUCLE,
&                   NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                   NLIGSAV, PATCH, WMIGRATE)
            Endif
        Endif

    Elsif func CHERCHEETQUOTE(1, CHAINE, "Return", IP2)
        NLIGENDRT = NLIG
        
        If CPTRFOR and (NIVFORREAD and NIVFORREAD <= CPTRFOR)
            TERRMES(1) = mess(1808, 144, 1)
            Call ECRERREUR(8, PMODULE, GTTRAITEMENTS(NF),
&                TERRMES, TITAECRIRE, TITAECRIREW, "", CHBOUCLE,
&                NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                NLIGSAV, PATCH, WMIGRATE)               
        Endif
         
        If WNOMSUB <> ""
            If YWNOMET = ""
                TERRMES(1) = WNOMSUB - ":" - mess(1811, 144, 1)
                Call ECRERREUR(11, PMODULE, GTTRAITEMENTS(NF),
&                        TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHBOUCLE,
&                       NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                       NLIGSAV, PATCH, WMIGRATE)
            
            Elsif YCODETIQTRV = 0
            # moins ou pas grave
                TERRMES(1) = func AVERIFSRC.MESNUM(92, 144, WNOMSUB, YWNOMET,  "", "", "")
                Call ECRERREUR(11, PMODULE, GTTRAITEMENTS(NF),
&                        TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHBOUCLE,
&                        NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                        NLIGSAV, PATCH, WMIGRATE)
            Endif
        Endif
#____________________________________________________________________________________
    Elsif func CHERCHEETQUOTE(1, CHAINE, "For", IP2)
        CPTRFOR += 1
        NLIGFW = NLIG
        If NOMTRT  = GTTRAITEMENTS(NF) and PNUMERREURSEL = 1
            Wrseq GTTRAITEMENTS(NF) - func FDECAL(NLIG, CPTRFOR) - "For   :" - CHAINE Using [FER]
        Endif                
                
        # recherche si for read ou for = 1 to n
        If NIVFORREAD = 0
            If func TYPEFORLEC(CHAINE, IP2)
                NIVFORREAD = CPTRFOR
                CHBOUCLE = "(For :" - mess(57, 144, 1) - num$(NLIGFW) + ")" - CHAINE
            Endif
        Endif

    Elsif func CHERCHEETQUOTE(1, CHAINE, "Next", IP2)   
        CPTRFOR -= 1
        If NOMTRT  = GTTRAITEMENTS(NF) and PNUMERREURSEL = 1
            Wrseq GTTRAITEMENTS(NF) - func FDECAL(NLIG, CPTRFOR + 1) - "Next  :" - CHAINE Using [FER]
        Endif                
        If CPTRFOR < NIVFORREAD
            NIVFORREAD = 0
        Endif
        If CPTRFOR < 0
            TERRMES(1) = func AVERIFSRC.MESNUM(93, 144, "For/Next", num$(CPTRFOR), num$(NLIG), "For", num$(NLIGFW))
            Call ECRERREUR(1, PMODULE, GTTRAITEMENTS(NF),
&                TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHIF,
&                NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                NLIGSAV, PATCH, WMIGRATE)               

            CPTRFOR += 1
        Endif
#____________________________________________________________________________________
    Elsif func CHERCHEETQUOTE(1, CHAINE, "While", IP2)
        CPTRWHILE += 1
        NLIGWHILE = NLIG

        If NOMTRT  = GTTRAITEMENTS(NF) and PNUMERREURSEL = 4
            Wrseq GTTRAITEMENTS(NF) - func FDECAL(NLIG, CPTRWHILE) - "While  :" - CHAINE Using [FER]
        Endif                
                
    Elsif func CHERCHEETQUOTE(1, CHAINE, "Wend", IP2)   
        CPTRWHILE -= 1
        If NOMTRT  = GTTRAITEMENTS(NF) and PNUMERREURSEL = 4
            Wrseq GTTRAITEMENTS(NF) - func FDECAL(NLIG, CPTRWHILE + 1) - "Wend   :" - CHAINE Using [FER]
        Endif                
        If CPTRWHILE < 0
            TERRMES(1) = func AVERIFSRC.MESNUM(93, 144, "While/Wend", num$(CPTRWHILE), num$(NLIG), "While", num$(NLIGWHILE))
            Call ECRERREUR(4, PMODULE, GTTRAITEMENTS(NF),
&                TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHIF,
&                NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                NLIGSAV, PATCH, WMIGRATE)               

            CPTRWHILE += 1
        Endif
#____________________________________________________________________________________

    Elsif pat(CHAINE, "Variable*")
        IP2 = IP2 :# rien...

    Elsif pat(CHAINE, "Value Char*")
        If pat(CHAINE, "*()()*")
            TERRMES(1) = WNOMSUB - ":" - mess(1809, 144, 1)
            Call ECRERREUR(9, PMODULE, GTTRAITEMENTS(NF),
&                                 TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHBOUCLE,
&                                 NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                                 NLIGSAV, PATCH, WMIGRATE)               
        Endif

    Elsif pat(CHAINE, "Value*")
        If pat(CHAINE, "*()*") :#or pat(CHAINE, "*()")
            TERRMES(1) = WNOMSUB - ":" - mess(1809, 144, 1)
            Call ECRERREUR(9, PMODULE, GTTRAITEMENTS(NF),
&                                 TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHBOUCLE,
&                                 NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                                 NLIGSAV, PATCH, WMIGRATE)               
        Endif

    Elsif left$(CHAINE, 1) = "$"
        # si l'instruction précédente est un End et que l'on a $etiquette...
        # c'est qu'on quitte un Subprog et on attaque 1 étiquette (Gosub)
        If WFINTRV
            # le subprog n'a pas de code
            If WCODETRVE = 0 and WNOMSUB <> "" and WBACTION = 0

                TERRMES(1) = WNOMSUB - ":" - mess(1806, 144, 1)
                Call ECRERREUR(6, PMODULE, GTTRAITEMENTS(NF),
&                                     TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHBOUCLE,
&                                     NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                                     NLIGSAV, PATCH, WMIGRATE)
    
            Endif

                # avant $ACTION, il y a souvent le call du traitement même

#            If BETQAPRES
                # Anomalie supprimée dans un 1° temps :
                # mais cela induit des erreurs lors de l'analyse des CAL
                # les tableaux de var locales sont réinitialisées à chaque subprog ou funprog :
                # Un jour, il serait bien de mettre les sources dans l'ordre

            If instr(1, CHAINE, "$ACTION") = 0
                TERRMES(1) = mess(1810, 144, 1)
                Call ECRERREUR(10, PMODULE, GTTRAITEMENTS(NF),
&                                 TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHBOUCLE,
&                                 NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                                 NLIGSAV, PATCH, WMIGRATE)
            Endif


            WNOMSUB = ""
            WSAVSUB = ""
 
            WFINTRV = 0
            WCODETRVE = 0
        Endif
        
        YWNOMET = right$(CHAINE, 2)
        YCODETIQTRV = 0

    Elsif left$(CHAINE, 1) = "&"
        # on ne devrait jamais y passer
    Else
        # 1 instruction différente : c'est du code !!!
        WFINTRV = 0
        WCODETRVE = 1
        
        If YWNOMET <> ""
            YCODETIQTRV = 1
        Endif
    Endif


#____________________________________________________________________________________
    If func CHERCHEETQUOTE(1, CHAINE, "If", IP2)
        WFINTRV = 0
        WCODETRVE = 1

        CPTRIF += 1
        NLIGIF = NLIG
        If NOMTRT  = GTTRAITEMENTS(NF) and PNUMERREURSEL = 2
            Wrseq GTTRAITEMENTS(NF) - func FDECAL(NLIG, CPTRIF) - "If    :" - CHAINE Using [FER]
        Endif                
    Elsif func CHERCHEETQUOTE(1, CHAINE, "Endif", IP2)   
        WFINTRV = 0
        WCODETRVE = 1

        CPTRIF -= 1
        If NOMTRT  = GTTRAITEMENTS(NF) and PNUMERREURSEL = 2
            Wrseq GTTRAITEMENTS(NF) - func FDECAL(NLIG, CPTRIF + 1) - "Endif :" - CHAINE Using [FER]
        Endif                

        If CPTRIF < 0
            TERRMES(1) = func AVERIFSRC.MESNUM(93, 144, "If/Endif", num$(CPTRIF), num$(NLIG), "If", num$(NLIGIF))
            Call ECRERREUR(2, PMODULE, GTTRAITEMENTS(NF),
&                TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHIF,
&                NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                NLIGSAV, PATCH, WMIGRATE)               

            CPTRIF += 1
        Endif
#____________________________________________________________________________________
    Elsif func CHERCHEETQUOTE(1, CHAINE, "Case", IP2)
        WFINTRV = 0
        WCODETRVE = 1

        CPTRCASE += 1
        NLIGCASE = NLIG
        If NOMTRT  = GTTRAITEMENTS(NF) and PNUMERREURSEL = 3
            Wrseq GTTRAITEMENTS(NF) - func FDECAL(NLIG, CPTRCASE) - "Case  :" - CHAINE Using [FER]
        Endif                
                
    Elsif func CHERCHEETQUOTE(1, CHAINE, "Endcase", IP2)   
        WFINTRV = 0
        WCODETRVE = 1

        CPTRCASE -= 1
        If NOMTRT  = GTTRAITEMENTS(NF) and PNUMERREURSEL = 3
            Wrseq GTTRAITEMENTS(NF) - func FDECAL(NLIG, CPTRCASE + 1) - "Endcase :" - CHAINE Using [FER]
        Endif                

        If CPTRCASE < 0
            TERRMES(1) = func AVERIFSRC.MESNUM(93, 144, "Case/Endcase", num$(CPTRCASE), num$(NLIG), "Case", num$(NLIGCASE))
            Call ECRERREUR(3, PMODULE, GTTRAITEMENTS(NF),
&                TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHIF,
&                NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                NLIGSAV, PATCH, WMIGRATE)               

            CPTRCASE += 1
        Endif
    Endif

Return




# erreur sur les compteurs : mess(60,199,1) = Problème lors de la récupération du compteur
#mess(60,199,1) est mieux si on concatène avec "(" + [L]COMPTEUR - num$([L]STAT) + ")"

$ANAC01

    IP = instr(1, CHAINECPT, "mess(60,199,1)")
    If IP = 0
        Return
    Endif
    
    CHAINECPT = right$(CHAINECPT, IP + len("mess(60,199,1)"))

    If left$(CHAINECPT, 1) = "+" or left$(CHAINECPT, 1) = "-"
        Return
    Endif

    TERRMES(1) = mess(1821, 144, 1)
    Call ECRERREUR(INDERREUR, PMODULE, GTTRAITEMENTS(NF),
&                  TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHBOUCLE,
&                  NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                  NLIGSAV, PATCH, WMIGRATE)


    # INDERREUR à 0 veut dire que le cas est trouvé et que les suivants ne sont pas à traiter
    INDERREUR = 0
Return


# instruction obsolète :#@

$ANAC02

    IP = instr(1, CHAINECPT, "#@")    #CHECK IGNORE_LINE
    If IP = 0
        Return
    Endif

    TERRMES(1) = mess(1822, 144, 1)
    Call ECRERREUR(INDERREUR, PMODULE, GTTRAITEMENTS(NF),
&                                 TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHBOUCLE,
&                                 NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                                 NLIGSAV, PATCH, WMIGRATE)


    # INDERREUR à 0 veut dire que le cas est trouvé et que les suivants ne sont pas à traités
    INDERREUR = 0
Return


$ANAC03

    If pat(CHAINECPT, "*If*evalue*dim*") or pat(toupper(CHAINECPT), "*IF*evalue*DIM*") #CHECK IGNORE_LINE
      IP = instr(1, CHAINECPT, "evalue")
      If instr(IP + 6, CHAINECPT, "-") = 0 and  instr(IP + 6, CHAINECPT, "+") = 0

          TERRMES(1) = mess(1824, 144, 1)
          Call ECRERREUR(INDERREUR, PMODULE, GTTRAITEMENTS(NF),
&                                 TERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHBOUCLE,
&                                 NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&                                 NLIGSAV, PATCH, WMIGRATE)
      Endif
    Endif  #CHECK IGNORE_LINE
Return


$FINCALL
End


#------------------------------------------------------------------------------------------------------------------------#
#
Funprog FDECAL(PNLIG, PNB)
Value Integer PNLIG, PNB

Local Integer I
Local Char WCC(50)

    WCC = func AVERIFSRC.TITREFMT(num$(PNLIG), 6)
    If PNB = 0
        End WCC + "0"
    Endif
    
    For I = 1 To PNB
        WCC += "  "
    Next I
    End WCC + num$(PNB)
End


Subprog ECRERREUR(PINDERREUR, PMODULE, PTRAITEMENT,
&       ERRMES, TITAECRIRE, TITAECRIREW, CHAINE, CHBOUCLE,
&       NBERREUR, NBWARNING, NLIG, TERREUR, SAUVEMODULE, PNUMERREURSEL,
&       NLIGSAV, PATCH, PMIGRATE)
Value Integer PINDERREUR
Value Integer PMODULE
Variable Char PTRAITEMENT
Variable Char ERRMES()
Variable Integer TITAECRIRE, TITAECRIREW
Value Clbfile CHAINE, CHBOUCLE
Variable Integer NBERREUR, NBWARNING
Variable Integer NLIG
Variable Integer TERREUR()
Variable Shortint SAUVEMODULE
Value Integer PNUMERREURSEL
Variable Integer NLIGSAV
Value Char PATCH
Value Integer PMIGRATE

Local Integer IB, IC

    If PNUMERREURSEL <> 0 and (PNUMERREURSEL <> PINDERREUR and (PNUMERREURSEL <> 4 or (PINDERREUR <> 4 and PINDERREUR <> 5)))
        Raz ERRMES
        End
    Endif

    If GBTDESACTIVE(GNUMMOUL, PINDERREUR) or (PMIGRATE and GTMIGRATE(GNUMMOUL, PINDERREUR))
        Raz ERRMES
        End
    Endif
    
    Call ECRIRETITRE(TITAECRIRE, TITAECRIREW, PINDERREUR, PMODULE, PTRAITEMENT, SAUVEMODULE,
&       NBERREUR, NBWARNING, NLIG, NLIGSAV) From AVERIFSRC
    
    TERREUR(PINDERREUR) += 1
    GTRECAPERR(GNUMMOUL, [F:ADC]MODULE, PINDERREUR) += 1
    
    If GBTWARNING(GNUMMOUL, PINDERREUR)
        Wrseq "  *** (" - mess(57, 144, 1) - num$(NLIG) - mess(55, 144, 1) - num$(PINDERREUR + 500) + ")" - ERRMES(1) Using [FWR]
    Else
        Wrseq "  *** (" - mess(57, 144, 1) - num$(NLIG) - mess(56, 144, 1) - num$(PINDERREUR + 500) + ")" - ERRMES(1) Using [FER]
        If (PINDERREUR= 4 or PINDERREUR = 5) and CHBOUCLE <> ""
            Wrseq "  ***" - CHBOUCLE Using [FER]
        Endif
    Endif
        
    # Ecrire les autres lignes
    ERRMES(1) = ""
    IC = 2
    While IC <= 20
        If ERRMES(IC) <> ""
            If GBTWARNING(GNUMMOUL, PINDERREUR)
                Wrseq "  ***" - ERRMES(IC) Using [FWR]
            Else
                Wrseq "  ***" - ERRMES(IC) Using [FER]
            Endif
            ERRMES(IC) = ""
        Endif
        IC += 1
    Wend
    
    If CHAINE <> "" and PATCH <> ""
        If GBTWARNING(GNUMMOUL, PINDERREUR)
            Wrseq "  -->" - CHAINE Using [FWR]
        Else
            Wrseq "  -->" - CHAINE Using [FER]
        Endif
    Endif

End


Funprog ESTACTION(WNOMSUB, WNBACTION, WTACTION)
Value Char WNOMSUB
Value Integer WNBACTION
Value Char WTACTION()

Local Integer IP, WBACTION
Local Char NOMACTION(10)

    WBACTION = 0
    IP = instr(1, WNOMSUB, "_")
    If IP = 0
        End WBACTION
    Endif
    
    NOMACTION = left$(WNOMSUB, IP - 1)

    If NOMACTION = ""
        End WBACTION
    Endif
    
    If find(NOMACTION, WTACTION(1..WNBACTION))
        WBACTION = 1
    Endif
End WBACTION

Funprog TYPEFORLEC(CHAINE, POS)
Value Clbfile CHAINE
Value Integer POS

Local Integer WTYPELEC, II

    WTYPELEC = 0

    # mots trouvés uniquement en For Fic
    If instr(POS + 3, CHAINE, "Where") or
&      instr(POS + 3, CHAINE, "With") or
&      instr(POS + 3, CHAINE, "From") or
&      instr(POS + 3, CHAINE, "Hint") or
&      pat(CHAINE, "For [*]")

        WTYPELEC = 1
        End WTYPELEC
    Endif

    # on n'a pas de From donc le To ==> que c'est un For Var
    If instr(POS + 3, CHAINE, "To")
        WTYPELEC = 0
        End WTYPELEC
    Endif
    
    # on a For x = "a" , "b" , "c"
    II = instr(POS + 3, CHAINE, "=")
    If II
        II = instr(II + 1, CHAINE, ",")
        If II
            WTYPELEC = 0
            End WTYPELEC
        Endif
    Endif

    # les cas restants sont (?) des for Fic   
    WTYPELEC = 1

End WTYPELEC


Funprog CHERCHEETQUOTE(PPOS, PCHAINE, PCHERCHE, TRV)
Value Integer PPOS
Value Clbfile PCHAINE
Value Char PCHERCHE()
Variable Integer TRV

    Local Integer IP2

    TRV = instr(PPOS, PCHAINE, PCHERCHE)


    # Quand on cherche un End : pas de Endif ou Endcase
    If TRV and PCHERCHE = "End"
        If instr(1, PCHAINE, "Endif") = TRV
            TRV = 0
        Else
            If instr(1, PCHAINE, "Endcase")  = TRV
                TRV = 0
            Endif   
        Endif             
    Endif

    # Quand on cherche un If : pas de Endif
    If TRV and PCHERCHE = "If"
        If instr(1, PCHAINE, "Endif") = TRV
            TRV = 0
        Endif
    Endif

    # Quand on cherche un For : pas de Formula ou format$ ou [Titcol xxx For]
    If TRV and PCHERCHE = "For"
        If instr(1, PCHAINE, "Formula")= TRV
            TRV = 0
        Elsif instr(1, PCHAINE, "format$") = TRV
            TRV = 0
        Else
            IP2 = instr(1, PCHAINE, "Titcol")
            If (IP2 and IP2 < TRV)
                TRV = 0
            Endif
        Endif
    Endif
    
    #Quand on cherche un Next : pas de read Next ou Look Next
    If TRV and PCHERCHE = "Next"
        If instr(1, PCHAINE, "Read") or instr(1, PCHAINE, "Look")
            TRV = 0
        Endif
    Endif
      
    # vérifie que pas dans une chaine genre Wrseq "Subprog toto(x)"
    If TRV
        If func AVERIFSRC.DANSQUOTE (PCHAINE, TRV)
            TRV = 0
        Endif
    Endif
    
    
End TRV

# contrôle de l'affectation de la variable point d'entrée
Subprog FGPOINTDOCPE(PCHAINE, PTXTERR, PTRAITEMENT, PLANGUE)

Variable Char PCHAINE, PTXTERR
Value Char PTRAITEMENT, PLANGUE

Local Char WCH(50)
Local Integer I, J, BTROUVE

    PTXTERR = ""
    If instr(1, PCHAINE, "GPOINT") = 0
        End
    Endif

    If instr(1, PCHAINE, "'GPOINT") or instr(1, PCHAINE, '"GPOINT')
        End
    Endif
    
    If pat(PCHAINE, "If GPOINT*")
        End
    Endif
    # migrations intégrales
    If left$(PTRAITEMENT, 3) = "SIX"
        PCHAINE = ""
        End
    Endif

    I = instr(1, PCHAINE, "=")
    If I = 0
        End
    Endif
    J = instr(1, PCHAINE, "'")
    If J and J < I
        End
    Endif
    J = instr(1, PCHAINE, '"')
    If J and J < I
        End
    Endif

    WCH= right$(PCHAINE, I + 1)

    # on cherchera un titre commençant par la partie constante de la chaîne
    I = instr(1, WCH, "+")
    If I
        PCHAINE = left$(PCHAINE, I - 1)
    Endif

    # non analysé : trop complexe ou variable:
    If instr(1, WCH, "(") or instr(1, WCH, "[") or instr(1, WCH, "-")
        PCHAINE = ""
        End
    Endif

    I = instr(1, WCH, "'")
    If I
        WCH= right$(WCH, I + 1)
        I = instr(1, WCH, "'")
        If I = 0
            PTXTERR = "Problème de quote sur l'instruction :"
            End
        Endif

        WCH= left$(WCH, I - 1)
    Else
        I = instr(1, WCH, '"')
        If I
            WCH= right$(WCH, I + 1)
            I = instr(1, WCH, '"')
            If I = 0
                PTXTERR = "Problème de quote sur l'instruction :"
                End
            Endif
            WCH= left$(WCH, I - 1)
        Else
            End
        Endif    
    Endif

    # spécifiques intégrés (demande des argentins pour ne pas les perdre...)
    If left$(WCH, 1) = "X"
        PCHAINE = ""
        End
    Endif

    # FQ71965 2011.02.28
    If WCH = ""
        End
    Endif
        
    BTROUVE = 0
    Filter [ADO] Where LAN = PLANGUE and TYP = "ADC" and COD  = PTRAITEMENT and PAR = "APE"
    For [ADO]ADO1
        BTROUVE += 1
#        If WCH = left$([F:ADO]TIT, len(WCH))
        If instr(1, [F:ADO]TIT, WCH)
            PCHAINE = ""
#            PTXTERR = "Documentations de point d'entrée Ok OK OK"
            Break
        Endif
    Next
    Filter [ADO]

    If PCHAINE <> ""
        PTXTERR = mess(1823, 144, 1) - ' GPOINT = "' + WCH + '"'  #CHECK IGNORE_LINE
    Endif
End
