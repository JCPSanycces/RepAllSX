#<AdxTL>@(#)0.0.0.0 $Revision$
Call OUINON(mess(72,127,1)+"\"+mess(75,127,1),GBIDI1) From GESECRAN
If GBIDI1=2 : Call LECPAR : Endif
End

Close Mask
Raz GPILOBJ , GNBMASKOUV
GBIDC1 = "SUPERV"
Call OBJET("ADS",GBIDC1,GBIDC2) From GOBJET
End

Call OUINON(mess(72,127,1)+"\"+mess(75,127,1),GBIDI1) From GESECRAN
If GBIDI1=2 : Call LECPAR : Endif
End

$ACTION
Case ACTION
  When "INIT"
   TMP = 1
   # Import du fichier BATCH.tmp\Attention les paramètres d'abonnements importés seront perdus
   TIT = mess(72,127,1)+"\"+mess(75,127,1)
  When "EXEC"
   Call LECPAR
Endcase
Return

Subprog LECPAR
Local Char    FICPAR(GDIMFIC)
Local Integer IUM,ER,NUMERO,L,NBLAN, LL
Local Char    DIME(5) , VARIA(GLONAVA) , VALEUR(GDIMFIC) , LIGNE(GDIMFIC) , CLASSE(5)
Local Integer MAXLIG  : MAXLIG = 500
Local Char    TACHE(20)(0..500),ABO(20)(0..500),GROUPE(20)(0..500),CODABC(20)(0..500),CODABH(20)(0..500)
Local Integer NBTAC,NBABO,NBGRP,NBABC,NBABH,NUM
Local Char    CHAINE(250), RETOUR(250) , TABLE(GLONATB) , LANGUE(GLONLAN)(1..50),TEXTE(250)(1..50)

Local File ABATTAC  [ABT]
Local File ABATGRP  [ABG]
Local File ABATABT  [ABA]
Local File ABATCAL  [ABC]
Local File ABATHOR  [ABH]
Local File ABATABTD [ABD]
Local File ATEXTE   [ATX]
Local File ATABZON  [ATZ]
Local File ADOSSIER [ADS]

Read [ADS]DOSSIER = GDOSX3

FICPAR = filpath("","BATCH","tmp",GDOSX3,"")
If filinfo(FICPAR,0)<0
 Call ECR_TRACE("|"+FICPAR-":"-mess(101,100,1),1) From GESECRAN : # Fichier inexistant
 End
Endif
IUM = GUTF8
Gosub VERSION
If ER
 Call ECR_TRACE(mess(76,127,1)-"|"+FICPAR,1) From GESECRAN : # Erreur de lecture sur le fichier
 End
Endif

# Import parametres batch dans le dossier
Call DEBTRANS From GLOCK
Gosub TR_BATCH
Openi Using [P]
#Call EFFACE(FICPAR,ER) From ORDSYS
End

$TR_BATCH
GOK = 1
Trbegin [ABT], [ABA] , [ABG] , [ABH] ,[ABC]
 Gosub DELETES
 Openi FICPAR Using [P]
 Iomode adxifs "" Using [P]
 Iomode adxirs chr$(10) Using [P]
 Iomode adxium IUM Using [P]
 Rdseq LIGNE Using [P]
 While fstat=0
  If left$(LIGNE,1)="#"
   Gosub LECFIC
   Gosub CREA
   If GOK<1 : Break : Endif
  Endif
  Rdseq LIGNE Using [P]
 Wend
 If GOK<1 : Goto AB_TR_BATCH : Endif
Commit
Return

# Parcours du fichier param pour déterminer IUM
$VERSION
ER=0
Onerrgo ERR
Openi FICPAR Using [P]
Iomode adxifs "" Using [P]
Iomode adxirs chr$(10) Using [P]
Iomode adxium IUM Using [P]
Rdseq LIGNE Using [P]
Openi Using [P]
Onerrgo
If ER & IUM=GUTF8
 IUM = GASCII
 Goto VERSION
Endif
Return

$DELETES
Openi FICPAR Using [P]
Iomode adxifs "" Using [P]
Iomode adxirs chr$(10) Using [P]
Iomode adxium IUM Using [P]
Rdseq LIGNE Using [P]
While fstat=0
 If left$(LIGNE,1)="#"
  Gosub LECFIC
  Case CLASSE
     When "ABT"
      GBIDC1 = [F:ABT]CODTAC
      Delete [F:ABT] Where CODTAC = GBIDC1
     When "ABA"
      GBIDC1 = [F:ABA]CODABT
      If 0
       For [F:ABD] Where CODABT = GBIDC1
        Delete [F:ABD] Curr
       Next ABD
      Endif
      Delete [F:ABA] Where CODABT = GBIDC1
     When "ABG"
      GBIDC1 = [F:ABG]CODGRP
      Delete [F:ABG] Where CODGRP = GBIDC1
     When "ABC"
      GBIDC1 = [F:ABC]COD
      Delete [F:ABC] Where COD = GBIDC1
     When "ABH"
      GBIDC1 = [F:ABH]COD
      Delete [F:ABH] Where COD = GBIDC1
    Endcase
 Endif
 Rdseq LIGNE Using [P]
Wend
Openi Using [P]
Return

$LECFIC
CLASSE = right$(LIGNE,2)
Case CLASSE
 When "ABT" : TABLE = "ABATTAC"
 When "ABA" : TABLE = "ABATABT"
 When "ABG" : TABLE = "ABATGRP"
 When "ABC" : TABLE = "ABATCAL"
 When "ABH" : TABLE = "ABATHOR"
Endcase
Raz [F:ABT],[F:ABA],[F:ABH],[F:ABC],[F:ABG]
Repeat
 Rdseq VARIA Using [P]
 If VARIA<>"#"
  Rdseq DIME Using [P]
  J = val(DIME)
  Rdseq VALEUR Using [P]
  Read [ATZ]CODZONE = TABLE;VARIA
  If !fstat & [F:ATZ]CODTYP="ATX"
   TYP = 99
  Endif
  If evalue("dim([F:"+CLASSE+"]"+VARIA+")")>=J
   TYP = evalue("type([F:"+CLASSE+"]"+VARIA+")")
   If find(CLASSE,"ABT","ABG") & VARIA ="DES"
    TYP =99
   Endif
   Case TYP
    When 1,2,4,5,6,7,8,9
     Assign "[F:"+CLASSE+"]"+VARIA+"("+num$(J-1)+")" With val(VALEUR)
    When 3
     Assign "[F:"+CLASSE+"]"+VARIA+"("+num$(J-1)+")" With gdat$(VALEUR)
    When 99
     Raz [L]LANGUE,NBLAN,[L]TEXTE
     Repeat
      If VALEUR ="***" : Break : Endif
      If instr(1,VALEUR,"~")
       NUMTXT = val(left$(VALEUR,instr(1,VALEUR,"~")-1))
       VALEUR = right$(VALEUR,instr(1,VALEUR,"~")+1)
       LANGUE = left$(VALEUR,instr(1,VALEUR,"~")-1)
       CHAINE = right$(VALEUR,instr(1,VALEUR,"~")+1)
       NBLAN += 1
       [L]LANGUE(NBLAN)  = LANGUE
       [L]TEXTE(NBLAN)   = CHAINE
      Else
       Assign "[F:"+CLASSE+"]"+VARIA+"("+num$(J-1)+")" With VALEUR
      Endif
      Rdseq VALEUR Using [P]
     Until VALEUR="***"
     If NBLAN
      Gosub TEXTES
      If !GOK : Break : Endif
     Endif
    When Default
     Assign "[F:"+CLASSE+"]"+VARIA+"("+num$(J-1)+")" With VALEUR
   Endcase
  Endif
 Endif
Until VARIA="#"
Return

$CREA
Case CLASSE
 When "ABT"
  Write [ABT] : If fstat : GOK = 0 : Call FSTA("ABT") From GLOCK : Endif
 When "ABA"
  [F:ABA]ENAFLG = 1
  Write [ABA] : If fstat : GOK = 0 : Call FSTA("ABA") From GLOCK : Endif
 When "ABG"
  Write [ABG] : If fstat : GOK = 0 : Call FSTA("ABG") From GLOCK : Endif
 When "ABC"
  Write [ABC] : If fstat : GOK = 0 : Call FSTA("ABC") From GLOCK : Endif
 When "ABH"
  Write [ABH] : If fstat : GOK = 0 : Call FSTA("ABH") From GLOCK : Endif
Endcase
Return

$AB_TR_BATCH
Rollback
Return

$ERR
ER = errn
Resume

$TEXTES
Local Integer ASTATUS
Local Char MESSAGE(250)
 L = find([F:ADS]LAN(0),LANGUE(1..NBLAN))
 If L & [L]TEXTE(L)<>"" & NUMTXT<>0 & (NUMTXT<GMAXTXTSTD | NUMTXT>GNEWTXTSTD) :#115210/6
  [L]NUMERO = [L]NUMTXT
 Endif
 For LL=0 To [F:ADS]NBRLAN-1
  L = find([F:ADS]LAN(LL),LANGUE(1..NBLAN))
  If L
   If NUMERO=0 & [L]TEXTE(L)<>"" : # La première langue qui se présente
    # On patche dans la zone 0..100000 si le texte d'origine est <100000
    If NUMTXT<>0 & (NUMTXT<GMAXTXTSTD | NUMTXT>GNEWTXTSTD) :#115210/6
     If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" :#115210/6
      ASTATUS = func ATXTSVC.CREATE_TEXT_CHAR(GPRODUIT,LANGUE(L),LANGUE,[L]TEXTE(L), "",NUMERO,MESSAGE)
      If ASTATUS<>[V]CST_AOK
       GMESSAGE=MESSAGE : GOK=0
      Endif
     Else
      Filter [ATX] Where NUMERO<GMAXTXTSTD Order By Key CLE=NUMERO;LAN
      Read [ATX] Last
      Filter [ATX]
      If fstat>2 : NUMERO = 1 : Else : NUMERO = [F:ATX]NUMERO+1 : Endif
     Endif
    # On patche au-delà de 100000 si le texte d'origine est >100000
    Else
     #115210/6
     Filter [ATX] Where NUMERO>GMAXTXTSTD & NUMERO<GNEXTXTSTD Order By Key CLE=NUMERO;LAN
     Read [ATX] Last
     Filter [ATX]
     If fstat>2 : NUMERO = GMAXTXTSTD+1 : Else : NUMERO = [F:ATX]NUMERO+1 : Endif
     If NUMERO>0
      Raz [F:ATX]
      [F:ATX]LAN     = LANGUE(L)
      [F:ATX]NUMERO  = NUMERO
      [F:ATX]TEXTE   = [L]TEXTE(L)
      [F:ATX]COMMENT = ""
      [F:ATX]CLEREC = left$(vireblc(toupper(ctrans([F:ATX]TEXTE)),4),20)
      Write [ATX]
      If fstat
       Call ERREUR("ATEXTE",1) From DOSDIC
       GOK = 0
      Endif
     Endif
    Endif
   Elsif NUMERO<>0 : # On a déjà attribué un numéro, il faut le respecter
    Read [ATX]NUMERO = LANGUE(L);[L]NUMERO
    If fstat
     Raz [F:ATX]
     [F:ATX]LAN     = LANGUE(L)
     [F:ATX]NUMERO  = NUMERO
     [F:ATX]TEXTE   = [L]TEXTE(L)
     [F:ATX]COMMENT = ""
     [F:ATX]CLEREC = left$(vireblc(toupper(ctrans([F:ATX]TEXTE)),4),20)
     Write [ATX]
    Elsif LL>0 or [F:ATX]TEXTE<>[L]TEXTE(L)
     [F:ATX]TEXTE   = [L]TEXTE(L)
     [F:ATX]COMMENT = ""
     [F:ATX]CLEREC = left$(vireblc(toupper(ctrans([F:ATX]TEXTE)),4),20)
     Rewrite [ATX]
    Endif
    If fstat
     Call ERREUR("ATEXTE",1) From DOSDIC
     GOK = 0
    Endif
    If (NUMERO<GMAXTXTSTD | NUMERO>GNEWTXTSTD) & func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" :#115210/6
      ASTATUS = func ATXTSVC.UPDATE_ONETEXT_CHAR(GPRODUIT,NUMERO,[F:ATX]LAN,[F:ATX]TEXTE, [F:ATX]COMMENT,[F:ATX]LANORI,MESSAGE)
      If ASTATUS<>[V]CST_AOK
       GMESSAGE=MESSAGE : GOK=0
      Endif
    Endif
   Endif
  Endif
 Next LL
 Assign "[F:"+CLASSE+"]"+VARIA+"("+num$(J-1)+")" With NUMERO
Return

