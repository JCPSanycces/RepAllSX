#<AdxTL>@(#)0.0.0.0 $Revision$
# Representation CCMPLAROH - Detail Plan Routing
###############################################################################
# Issue 110210/8 - 2015-12-15 by JUSYN : New labels for supervisor update
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"
          Gosub GET_CHANGE_REQUEST_DETAILS # Change request details
          Gosub ACTIVATE_FIELDS
        When "AUPDATE_CONTROL_AFTER"
          Gosub ASSIGN_TO_ALL_LINES
      Endcase
  Endcase
Return

$METHODS
  Case [L]AMETHOD
  Endcase
Return

$PROPERTIES
  Case [L]CURPRO
  Endcase
Return
###############################################################################

# Using CRID, get change request details
$GET_CHANGE_REQUEST_DETAILS
  Local Char MESSAGE(100)
  Local Instance SELNCSRECENT Using C_NCSRECENT
  SELNCSRECENT = NewInstance C_NCSRECENT AllocGroup null
  ASTATUS = fmet SELNCSRECENT.AREAD(this.CCMROH.CRID)
  If  ASTATUS<>[V]CST_AOK
    MESSAGE = func ASYRFNC.MES1(mess(20,3702,1),this.CCMROH.CRID)
    ASTATUS = fmet  this.ASETERROR ("", MESSAGE, [V]CST_AERROR)
  Else
    this.NCSID = SELNCSRECENT.CRID
    this.PRODUCT = SELNCSRECENT.PRODUCT
    this.ECCVALMAJ   = SELNCSRECENT.ECCVALMAJ
    this.ECCVALMIN   = SELNCSRECENT.ECCVALMIN
    this.CRSTATUS = SELNCSRECENT.CRSTATUS
    this.NCSMANAGER = SELNCSRECENT.NCSMANAGER
    this.NCSPLANNER = SELNCSRECENT.NCSPLANNER
  Endif
  FreeGroup SELNCSRECENT
Return

# --------------------------------------------------
# Enable / disable fields at a class level.
$ACTIVATE_FIELDS

  Local Integer LOCAL_ASTATUS

  If (this.CCMROH.ROHPLASTA = 3) or
&    (this.CCMROH.ROHPLASTA = 4 and this.CCMROH.NUMROU = 0)
    LOCAL_ASTATUS = fmet this.CCMROH.ASETATTRIBUTE("IMPLEMENT", "$isHidden", "true")
  Elsif (this.ACTX.USER = this.NCSPLANNER)
    LOCAL_ASTATUS = fmet this.CCMROH.ASETATTRIBUTE("IMPLEMENT", "$isHidden", "false")
    LOCAL_ASTATUS = fmet this.CCMROH.ASETATTRIBUTE("IMPLEMENT", "$isDisabled", "false")
  Else
    LOCAL_ASTATUS = fmet this.CCMROH.ASETATTRIBUTE("IMPLEMENT",   "$isHidden", "true")
  Endif

  If (this.ACTX.USER = this.NCSPLANNER and this.CCMROH.IMPLEMENT = 1)
    LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("DEFACTIONID", "$isHidden",   "false")
    LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("DEFCOMPDATE", "$isHidden",   "false")
    LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("DEFACTIONER", "$isHidden",   "false")
  Else

    LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("DEFACTIONID", "$isHidden",   "true")
    LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("DEFCOMPDATE", "$isHidden",   "true")
    LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("DEFACTIONER", "$isHidden",   "true")
  Endif

  # Disable all other read-only properties ...
  LOCAL_ASTATUS = fmet this.CCMROH.ASETATTRIBUTE("CRID",      "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.CCMROH.ASETATTRIBUTE("ROHPLASTA", "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.CCMROH.ASETATTRIBUTE("UPDDATTIM", "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.CCMROH.ASETATTRIBUTE("UPDUSR",    "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("CRSTATUS",         "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("PRODUCT",          "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("ECCVALMAJ",        "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("ECCVALMIN",        "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("NCSMANAGER",       "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("NCSPLANNER",       "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("NCSID",            "$isDisabled", "true")

  # if Change request Closed or not allowed to amend, then disable edit link
  If (this.NCSPLANNER <> this.ACTX.USER or (this.CRSTATUS <> 4 and this.CRSTATUS <> 5))
    LOCAL_ASTATUS = fmet this.ASETLINKDISABLE("AEDIT",[V]CST_AFFLNKREC)
  Endif

Return
# --------------------------------------------------
# Assign default ACTIONID, ACTIONER and COMPleteByDATE to all detail records ...
$ASSIGN_TO_ALL_LINES

  Local File CCMIMPROD [CCMROD]

  If (this.DEFACTIONID <> "")

    If (this.DEFACTIONER = "" or
&       this.DEFCOMPDATE = AVOID.ADATE)
      ASTATUS = fmet this.ASETERROR("", mess(64,2038,1), CST_AERROR)
    Else

      Update [CCMROD] Where CRID = this.CCMROH.CRID With
&       ACTIONID = this.DEFACTIONID,
&       ACTIONER = this.DEFACTIONER,
&       COMPLETEDATE = this.DEFCOMPDATE

      # Set action lines to total lines and update status
      LOCAL_ASTATUS = fmet this.CCMROH.UPDATE_STATUS()

    Endif

  Endif

  LogicClose File [CCMROD]

Return

