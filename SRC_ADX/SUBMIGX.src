#<AdxTL>@(#)0.0.0.0 $Revision$ Object management MIGX
######################################################################################
## Section automatically added (Object MIGX) 07/12/2017 06:56:23 (PHVEN)
######################################################################################
$ACTION
Case ACTION
  When "LIENS"    : Gosub LIENS
  When "RAZCRE"      : Gosub RAZCRE
  When "AVANTBOUT"   : Gosub BEFORE_ACT
  When "INIMOD"      : Gosub INIMOD
Endcase
Return

######################################################################################

$LIENS
  Call LOAD_DATA()
Return

######################################################################################

$RAZCRE
  Call INIT()
Return

######################################################################################

$BEFORE_ACT
  Case BOUT
    When "a" : Gosub SCHEMA_COMPARE
  Endcase
Return

######################################################################################

$INIMOD

  nolign = 0
  For [F:MIGXTM]MIGTM0 Where [F:MIGXTM]MIGREFNUM=[M:MIGX0]MIGREFNUM & [F:MIGXTM]TMSTATCOD = 0
     nolign += 1
     If [F:MIGXTM]TMINCLUDE <> [M:MIGX1]TMINCLUDE(nolign - 1) | [F:MIGXTM]TMCLSMAP <> [M:MIGX1]TMCLSMAP(nolign - 1)
       [F:MIGXTM]TMINCLUDE = [M:MIGX1]TMINCLUDE(nolign - 1)
       [F:MIGXTM]TMCLSMAP = [M:MIGX1]TMCLSMAP(nolign - 1)

       Rewrite [F:MIGXTM]

       If fstat > 0
         Infbox "Error: " + num$(fstat)
         Break
       Endif
     Endif
  Next

Return

######################################################################################

$SCHEMA_COMPARE
  Call COMPARE_FOLDERS()
Return

######################################################################################

$MIGRATION
  Call MSG("Do migrations")

Return

######################################################################################

Subprog INIT()
  [M:MIGX0]MIGREFNUM = "MIG-" + format$("YYMMDDhhmmss", date$) + "-" + num$(uniqid([F:MIGX]))
  [M:MIGX0]MIGSTAT = "Configuration"
End

######################################################################################

Subprog LOAD_DATA()

  Local Integer SELALL : SELALL = 2

  #Identical Init
  nolign = 0
  For [F:MIGXTM]MIGTM0 Where [F:MIGXTM]MIGREFNUM=[M:MIGX0]MIGREFNUM & [F:MIGXTM]TMSTATCOD = 0
     nolign += 1
     [M:MIGX1]TMNBR += 1
     [M:MIGX1]TMINCLUDE(nolign - 1) = [F:MIGXTM]TMINCLUDE
     [M:MIGX1]TMMOD(nolign - 1) = [F:MIGXTM]TMMOD
     [M:MIGX1]TMSRCTBL(nolign - 1) = [F:MIGXTM]TMSRCTBL
     [M:MIGX1]TMSRCRC(nolign - 1) = [F:MIGXTM]TMSRCRC
     [M:MIGX1]TMTRGTBL(nolign - 1) = [F:MIGXTM]TMTRGTBL
     [M:MIGX1]TMTRGRC(nolign - 1) = [F:MIGXTM]TMTRGRC
     [M:MIGX1]TMSTAT(nolign - 1) = [F:MIGXTM]TMSTAT
     [M:MIGX1]TMSTATMSG(nolign - 1) = [F:MIGXTM]TMSTATMSG
     [M:MIGX1]TMCLSMAP(nolign - 1) = [F:MIGXTM]TMCLSMAP

     If [F:MIGXTM]TMINCLUDE < 2 & SELALL = 2
       SELALL = 1
     Endif
  Next

  [M:MIGX1]TMOSELALL = SELALL

  #Only in source Init
  nolign = 0
  For [F:MIGXTM]MIGTM0 Where [F:MIGXTM]MIGREFNUM=[M:MIGX0]MIGREFNUM & [F:MIGXTM]TMSTATCOD = 1
    nolign += 1
    [M:MIGX2]TMNBR += 1
    [M:MIGX2]TMMOD(nolign - 1) = [F:MIGXTM]TMMOD
    [M:MIGX2]TMSRCTBL(nolign - 1) = [F:MIGXTM]TMSRCTBL
    [M:MIGX2]TMSRCRC(nolign - 1) = [F:MIGXTM]TMSRCRC
    [M:MIGX2]TMSTAT(nolign - 1) = [F:MIGXTM]TMSTAT
    [M:MIGX2]TMSTATMSG(nolign - 1) = [F:MIGXTM]TMSTATMSG
  Next

  #Only in target Init
  nolign = 0
  For [F:MIGXTM]MIGTM0 Where [F:MIGXTM]MIGREFNUM=[M:MIGX0]MIGREFNUM & [F:MIGXTM]TMSTATCOD = 2
    nolign += 1
    [M:MIGX3]TMNBR += 1
    [M:MIGX3]TMMOD(nolign - 1) = [F:MIGXTM]TMMOD
    [M:MIGX3]TMTRGTBL(nolign - 1) = [F:MIGXTM]TMTRGTBL
    [M:MIGX3]TMTRGRC(nolign - 1) = [F:MIGXTM]TMTRGRC
    [M:MIGX3]TMSTAT(nolign - 1) = [F:MIGXTM]TMSTAT
    [M:MIGX3]TMSTATMSG(nolign - 1) = [F:MIGXTM]TMSTATMSG
  Next

  #In both but diff Init
  nolign = 0
  For [F:MIGXTM]MIGTM0 Where [F:MIGXTM]MIGREFNUM=[M:MIGX0]MIGREFNUM & [F:MIGXTM]TMSTATCOD = 3
    nolign += 1
    [M:MIGX4]TMNBR += 1
    [M:MIGX4]TMMOD(nolign - 1) = [F:MIGXTM]TMMOD
    [M:MIGX4]TMSRCTBL(nolign - 1) = [F:MIGXTM]TMSRCTBL
    [M:MIGX4]TMSRCRC(nolign - 1) = [F:MIGXTM]TMSRCRC
    [M:MIGX4]TMTRGTBL(nolign - 1) = [F:MIGXTM]TMTRGTBL
    [M:MIGX4]TMTRGRC(nolign - 1) = [F:MIGXTM]TMTRGRC
    [M:MIGX4]TMSTAT(nolign - 1) = [F:MIGXTM]TMSTAT
    [M:MIGX4]TMSTATMSG(nolign - 1) = [F:MIGXTM]TMSTATMSG
  Next

  #Source errors Init
  nolign = 0
  For [F:MIGXTM]MIGTM0 Where [F:MIGXTM]MIGREFNUM=[M:MIGX0]MIGREFNUM & [F:MIGXTM]TMSTATCOD = 4
    nolign += 1
    [M:MIGX5]TMNBR += 1
    [M:MIGX5]TMMOD(nolign - 1) = [F:MIGXTM]TMMOD
    [M:MIGX5]TMSRCTBL(nolign - 1) = [F:MIGXTM]TMSRCTBL
    [M:MIGX5]TMSTAT(nolign - 1) = [F:MIGXTM]TMSTAT
    [M:MIGX5]TMSTATMSG(nolign - 1) = [F:MIGXTM]TMSTATMSG
  Next

  #Target errors Init
  nolign = 0
  For [F:MIGXTM]MIGTM0 Where [F:MIGXTM]MIGREFNUM=[M:MIGX0]MIGREFNUM & [F:MIGXTM]TMSTATCOD = 5
    nolign += 1
    [M:MIGX6]TMNBR += 1
    [M:MIGX6]TMMOD(nolign - 1) = [F:MIGXTM]TMMOD
    [M:MIGX6]TMTRGTBL(nolign - 1) = [F:MIGXTM]TMTRGTBL
    [M:MIGX6]TMSTAT(nolign - 1) = [F:MIGXTM]TMSTAT
    [M:MIGX6]TMSTATMSG(nolign - 1) = [F:MIGXTM]TMSTATMSG
  Next

  Call INIT_TABLES()
End

######################################################################################

Subprog INIT_TABLES()
  Chgtfd [M:MIGX1] "Identical (" + num$([M:MIGX1]TMNBR) + ")"
  Chgtfd [M:MIGX2] "Only In Source (" + num$([M:MIGX2]TMNBR) + ")"
  Chgtfd [M:MIGX3] "Only In Target (" + num$([M:MIGX3]TMNBR) + ")"
  Chgtfd [M:MIGX4] "IN BOTH BUT DIFF (" + num$([M:MIGX4]TMNBR) + ")"
  Chgtfd [M:MIGX5] "Source errors (" + num$([M:MIGX5]TMNBR) + ")"
  Chgtfd [M:MIGX6] "Target errors (" + num$([M:MIGX6]TMNBR) + ")"

  Affzo [M:MIGX1]
  Affzo [M:MIGX2]
  Affzo [M:MIGX3]
  Affzo [M:MIGX4]
  Affzo [M:MIGX5]
  Affzo [M:MIGX6]
End

######################################################################################

Subprog CLEAR_TABLES()
  Raz [M:MIGX1]
  Raz [M:MIGX2]
  Raz [M:MIGX3]
  Raz [M:MIGX4]
  Raz [M:MIGX5]
  Raz [M:MIGX6]
End

######################################################################################

Subprog COMPARE_FOLDERS()

   #Only used in "try-catch", and onerrgo requires a gosub to provide err details
   #TODO: Might need a better solution, try to avoid global variables if possible
   Global Integer ERRVAL : ERRVAL = 0
   Global Integer ERRNUM : ERRNUM = 0
   Global Char ERRMSG(250) : ERRMSG = ""

   Local Char SRCFLD(30)
   Local Char TRGFLD(30)

   Local Char TDEF_NAME(30) : TDEF_NAME = ".ATABLE" #Table dictionary
   Local Char FDEF_NAME(30) : FDEF_NAME = ".ATABZON" #Table field dictionary
   Local Char TIDX_NAME(30) : TIDX_NAME = ".ATABIND" #Table index dictionary
   Local Char DT_NAME(30) : DT_NAME = ".ATYPE" #Date type dictionary

   SRCFLD = [F:MIGX]MIGSRCFLD #Selected source folder
   TRGFLD = [F:MIGX]MIGTRGFLD #Selected target folder

   #Set the selected module to filter dictionaries
   Local Integer TRGMOD : TRGMOD = [F:MIGX]MIGMOD

   #Just a check to see if something was actually selected
   If SRCFLD <> "" & TRGFLD <> ""

      If clalev([T_SRC])=0 : Local File = SRCFLD + TDEF_NAME [T_SRC] : Endif
      If clalev([T_TRG])=0 : Local File = TRGFLD + TDEF_NAME [T_TRG] : Endif

      If clalev([F_SRC])=0 : Local File = SRCFLD + FDEF_NAME [F_SRC] : Endif
      If clalev([F_TRG])=0 : Local File = TRGFLD + FDEF_NAME [F_TRG] : Endif

      If clalev([I_SRC])=0 : Local File = SRCFLD + TIDX_NAME [I_SRC] : Endif
      If clalev([I_TRG])=0 : Local File = TRGFLD + TIDX_NAME [I_TRG] : Endif

      If clalev([DT_SRC])=0 : Local File = SRCFLD + DT_NAME [DT_SRC] : Endif
      If clalev([DT_TRG])=0 : Local File = TRGFLD + DT_NAME [DT_TRG] : Endif

      Filter [T_SRC] Where MODULE = TRGMOD Order By CODFIC
      Filter [T_TRG] Where MODULE = TRGMOD Order By CODFIC

      #Clear the mapping records
      Delete [F:MIGXTM] Where [F:MIGXTM]MIGREFNUM = [F:MIGX]MIGREFNUM
      Delete [F:MIGXTDF] Where [F:MIGXTDF]MIGREFNUM = [F:MIGX]MIGREFNUM

      If fstat > 0
         Infbox "Error: " + num$(fstat)
      Endif

      #Clear the view models
      Call CLEAR_TABLES()

      #Refresh the tab title counts and tables
      Call INIT_TABLES()

      #Initialize variables to for progress popup screen
      Local Char THISOPP(100) : THISOPP=""
      Local Char OPPDES(100) : OPPDES = ""
      Local Decimal PCOPP
      Local Integer NBOPP : NBOPP = rowcount([T_TRG])

      #Initialize variables to for progress popup screen
      Local Integer I : I = 1

      #Open progress popup and set the title
      Call OUVRE_VLC("Comparing folders - Target perspective - " + num$(NBOPP) + " tables", "", "") From GESECRAN

      #Iterate through target tables first
      For [T_TRG]

        #Populate the fields
        [F:MIGXTM]MIGREFNUM = [F:MIGX]MIGREFNUM
        [F:MIGXTM]TMNBR = I
        [F:MIGXTM]TMMOD = mess([T_TRG]MODULE,14,1) #Module of the table
        [F:MIGXTM]TMTRGTBL = [T_TRG]CODFIC #Table code

        #Update the progress in percentage variables
        PCOPP = arr((I/NBOPP)*100, 1)
        THISOPP = "Table: [" + num$([T_TRG]CODFIC) + "]"
        OPPDES = "Checking existance..."

        #Refresh the progress window with new values
        Call AFF_VLC(THISOPP-"-"-OPPDES, num$(PCOPP)-"%") From GESECRAN

        #Get matching source table
        Filter [T_SRC] Where CODFIC = [T_TRG]CODFIC
        Read [T_SRC] First

        If fstat > 0
           [F:MIGXTM]TMSTATCOD = 2
           [F:MIGXTM]TMSTAT = "Not Found"
           [F:MIGXTM]TMSTATMSG = "Not Found In Source"
           [F:MIGXTM]TMSRCTBL = ""
        Else
           OPPDES = "Checking indexes..."
           Call AFF_VLC(THISOPP-"-"-OPPDES, num$(PCOPP)-"%") From GESECRAN

           Filter [I_SRC] Where CODFIC = [T_TRG]CODFIC Order By NUMLIG
           Read [I_SRC] First

           Filter [I_TRG] Where CODFIC = [T_TRG]CODFIC Order By NUMLIG
           Read [I_TRG] First

           Local Char SRC_INDX(200) : SRC_INDX = [I_SRC]DESCRIPT
           Local Char TRG_INDX(200) : TRG_INDX = [I_TRG]DESCRIPT

           Local Char IDX_VAL(200)
           Local Char I_SRC_VAL(200)
           Local Char I_TRG_VAL(200)
           Local Integer SRC_IDX_COUNT : SRC_IDX_COUNT = 0
           Local Integer TRG_IDX_COUNT : TRG_IDX_COUNT = 0

           Call CONSTRUCT_KEY_QUERY(SRCFLD, [T_TRG]CODFIC, SRC_INDX, SRC_IDX_COUNT, I_SRC_VAL)
           Call CONSTRUCT_KEY_QUERY(TRGFLD, [T_TRG]CODFIC, TRG_INDX, TRG_IDX_COUNT, I_TRG_VAL)

           [F:MIGXTM]TMSTAT = "Found In Both"
           [F:MIGXTM]TMSRCTBL = [T_SRC]CODFIC
           [F:MIGXTM]TMIDXVAL = TRG_INDX

           Local Integer K : K = 1
           Local Integer MATCH : MATCH = 0

           If SRC_IDX_COUNT = TRG_IDX_COUNT
              If I_SRC_VAL <> I_TRG_VAL
                MATCH = 1
                [F:MIGXTM]TMSTATMSG = "Mismatch in index (" + SRC_INDX + ":" + TRG_INDX + ") definition"
              Endif
           Else
              MATCH = 1
              [F:MIGXTM]TMSTATMSG = "Mismatch in index (" + SRC_INDX + ":" + TRG_INDX + ") count"
           Endif

           OPPDES = "Checking schema..."
           Call AFF_VLC(THISOPP-"-"-OPPDES, num$(PCOPP)-"%") From GESECRAN

           Local Integer DIFF_INDEX : DIFF_INDEX = 0

           #From target perspective
           For [F_TRG]CODZONE Where CODFIC = [T_TRG]CODFIC
              Filter [F_SRC] Where [F_SRC]CODFIC = [T_SRC]CODFIC & [F_SRC]CODZONE = [F_TRG]CODZONE
              Read [F_SRC] First
              Filter [F_SRC]

              If fstat > 0
                  [F:MIGXTM]TMSTATMSG = "Column [" - num$([F_TRG]CODZONE) - "] not found in source table."

                  DIFF_INDEX += 1
                  [F:MIGXTDF]MIGREFNUM = [F:MIGXTM]MIGREFNUM
                  [F:MIGXTDF]TNNBR = [F:MIGXTM]TNNBR
                  [F:MIGXTDF]TDFNBR = DIFF_INDEX
                  [F:MIGXTDF]TDFDIFFMSG = [F:MIGXTM]TMSTATMSG
                  [F:MIGXTDF]TDFORIGIN = 2 #Target
                  [F:MIGXTDF]TDFTABCOD = [T_TRG]CODFIC
                  [F:MIGXTDF]TDFSRCVAL = num$([F_SRC]LONG)
                  [F:MIGXTDF]TDFTRGVAL = num$([F_TRG]LONG)
                  Write [F:MIGXTDF]

                  MATCH = 1
              Else
                  #Comparing length
                  If [F_TRG]LONG < [F_SRC]LONG
                    [F:MIGXTM]TMSTATMSG = "Column [" + num$([F_TRG]CODZONE) + "] target length is less than source length."

                    DIFF_INDEX += 1
                    [F:MIGXTDF]MIGREFNUM = [F:MIGXTM]MIGREFNUM
                    [F:MIGXTDF]TNNBR = [F:MIGXTM]TNNBR
                    [F:MIGXTDF]TDFNBR = DIFF_INDEX
                    [F:MIGXTDF]TDFDIFFMSG = [F:MIGXTM]TMSTATMSG
                    [F:MIGXTDF]TDFORIGIN = 2 #Target
                    [F:MIGXTDF]TDFTABCOD = [T_TRG]CODFIC
                    [F:MIGXTDF]TDFSRCVAL = num$([F_SRC]LONG)
                    [F:MIGXTDF]TDFTRGVAL = num$([F_TRG]LONG)
                    Write [F:MIGXTDF]

                    MATCH = 1
                  Endif

                  #Comparing Data Type
                  If !([F_TRG]CODTYP = [F_SRC]CODTYP)
                    [F:MIGXTM]TMSTATMSG = "Column [" + num$([F_TRG]CODZONE) + "] data type mismatch."

                    DIFF_INDEX += 1
                    [F:MIGXTDF]MIGREFNUM = [F:MIGXTM]MIGREFNUM
                    [F:MIGXTDF]TNNBR = [F:MIGXTM]TNNBR
                    [F:MIGXTDF]TDFNBR = DIFF_INDEX
                    [F:MIGXTDF]TDFDIFFMSG = [F:MIGXTM]TMSTATMSG
                    [F:MIGXTDF]TDFORIGIN = 2 #Target
                    [F:MIGXTDF]TDFTABCOD = [T_TRG]CODFIC
                    [F:MIGXTDF]TDFSRCVAL = num$([F_SRC]CODTYP)
                    [F:MIGXTDF]TDFTRGVAL = num$([F_TRG]CODTYP)
                    Write [F:MIGXTDF]

                    MATCH = 1
                  Endif

                  #Comparing Dimension
                  If !([F_TRG]DIME = [F_SRC]DIME)
                    [F:MIGXTM]TMSTATMSG = "Column [" + num$([F_TRG]CODZONE) + "] dimensions mismatch."

                    DIFF_INDEX += 1
                    [F:MIGXTDF]MIGREFNUM = [F:MIGXTM]MIGREFNUM
                    [F:MIGXTDF]TNNBR = [F:MIGXTM]TNNBR
                    [F:MIGXTDF]TDFNBR = DIFF_INDEX
                    [F:MIGXTDF]TDFDIFFMSG = [F:MIGXTM]TMSTATMSG
                    [F:MIGXTDF]TDFORIGIN = 2 #Target
                    [F:MIGXTDF]TDFTABCOD = [T_TRG]CODFIC
                    [F:MIGXTDF]TDFSRCVAL = num$([F_SRC]DIME)
                    [F:MIGXTDF]TDFTRGVAL = num$([F_TRG]DIME)
                    Write [F:MIGXTDF]

                    MATCH = 1
                  Endif
              Endif
           Next

           #From source perspective
           For [F_SRC]CODZONE Where CODFIC = [T_SRC]CODFIC
              Filter [F_TRG] Where [F_TRG]CODFIC = [T_TRG]CODFIC & [F_TRG]CODZONE = [F_SRC]CODZONE
              Read [F_TRG] First
              Filter [F_TRG]

              If fstat > 0
                  [F:MIGXTM]TMSTATMSG = "Column [" - num$([F_SRC]CODZONE) - "] not found in target table."

                  DIFF_INDEX += 1
                  [F:MIGXTDF]MIGREFNUM = [F:MIGXTM]MIGREFNUM
                  [F:MIGXTDF]TNNBR = [F:MIGXTM]TNNBR
                  [F:MIGXTDF]TDFNBR = DIFF_INDEX
                  [F:MIGXTDF]TDFDIFFMSG = [F:MIGXTM]TMSTATMSG
                  [F:MIGXTDF]TDFORIGIN = 1 #Source
                  [F:MIGXTDF]TDFTABCOD = [T_SRC]CODFIC
                  Write [F:MIGXTDF]

                  MATCH = 1
              Endif
           Next

           If MATCH = 0
               [F:MIGXTM]TMSTATCOD = 0
               [F:MIGXTM]TMSTAT = "Compatible"
               [F:MIGXTM]TMSTATMSG = "Found In Both And Identical"
               [F:MIGXTM]TMINCLUDE = 1
               [F:MIGXTM]TMIDXQUERY = I_TRG_VAL
               [F:MIGXTM]TMIDXCOUNT = TRG_IDX_COUNT
           Else
               [F:MIGXTM]TMSTATCOD = 3
               [F:MIGXTM]TMSTAT = "Found In Both But Different"
           Endif

        Endif

        #Reset error handling variables
        ERRVAL = 0
        ERRNUM = 0
        ERRMSG = ""

        #Target table check
        #Error handling, check if we can actually open the table\file, to get the row count aswell
        #Serves as a way to check that the actual table file exists, makes the data compare process less complex
        Onerrgo FILECHECKERR #try

          Local File = TRGFLD + "." + [T_TRG]CODFIC [TRG_TOBJ]

          If ERRVAL = 0
             Look [TRG_TOBJ] First


             If fstat = 5 #No record corresponds to the specified criteria (Record not found)
                [F:MIGXTM]TMSTATCOD = 5 #Target Error
                [F:MIGXTM]TMSTAT = "Error"-num$(fstat)
                [F:MIGXTM]TMSTATMSG = "Could not read table"
             Else
                [F:MIGXTM]TMTRGRC = rowcount([TRG_TOBJ])
             Endif
          Else #catch
             [F:MIGXTM]TMSTATCOD = 5 #Target Error
             [F:MIGXTM]TMSTAT = "Error"-num$(ERRNUM)
             [F:MIGXTM]TMSTATMSG = ERRMSG
          Endif
          Close File [TRG_TOBJ]
        ERRVAL = 0 #finally

        #Reset error handling variables
        ERRNUM = 0
        ERRMSG = ""

        If [F:MIGXTM]TMSTATCOD <> 2 #Is found in source table dictionary
          #Source table check
          #Error handling, check if we can actually open the table\file, to get the row count aswell
          #Serves as a way to check that the actual table file exists, makes the data compare process less complex
          Onerrgo FILECHECKERR #try
            Local File = SRCFLD + "." + [T_TRG]CODFIC [SRC_TOBJ]
            If ERRVAL = 0
               Look [SRC_TOBJ] First

               If fstat = 5 #No record corresponds to the specified criteria (Record not found)
                  [F:MIGXTM]TMSTATCOD = 4 #Source Error
                  [F:MIGXTM]TMSTAT = "Error"-num$(fstat)
                  [F:MIGXTM]TMSTATMSG = "Could not read table"
               Else
                  [F:MIGXTM]TMSRCRC = rowcount([SRC_TOBJ])
               Endif
            Else #catch
               [F:MIGXTM]TMSTATCOD = 4 #Source Error
               [F:MIGXTM]TMSTAT = "Error"-num$(ERRNUM)
               [F:MIGXTM]TMSTATMSG = ERRMSG
            Endif
            Close File [SRC_TOBJ]
          ERRVAL = 0 #finally
        Endif

        Write [F:MIGXTM]

        If fstat > 0
          Infbox "Error: " + num$(fstat)
          Break
        Endif

        I += 1

      Next

      #Close progress window, to start the new process
      Call FERME_VLC From GESECRAN

      #Reset the filters on the table dictionary
      Filter [T_SRC] Where MODULE = TRGMOD Order By CODFIC
      Filter [T_TRG] Where MODULE = TRGMOD Order By CODFIC

      #Need a new index to keep track of progress
      Local Integer K : K = 1

      #Get the total rows to measure progress against
      NBOPP = rowcount([T_SRC])

      #Open the progress window with a new title
      Call OUVRE_VLC("Comparing folders - Source Perspective - " + num$(NBOPP) + " tables", "", "") From GESECRAN

      #Second part of the compare, checks only source tables
      #Loop through source table dictionary
      For [T_SRC]

        #Update progress
        PCOPP = arr((K/NBOPP)*100, 1)
        THISOPP = "Table: [" + num$([T_SRC]CODFIC) + "]"
        OPPDES = "Checking existance..."
        Call AFF_VLC(THISOPP-"-"-OPPDES, num$(PCOPP)-"%") From GESECRAN

        #Get the matching target table
        Filter [T_TRG] Where CODFIC = [T_SRC]CODFIC
        Read [T_TRG] First

        #We are only interrested in tables that does not exist on the target side, otherwise, skip
        If fstat > 0
           [F:MIGXTM]MIGREFNUM = [F:MIGX]MIGREFNUM
           [F:MIGXTM]TMNBR = I
           [F:MIGXTM]TMMOD = mess([T_SRC]MODULE,14,1)
           [F:MIGXTM]TMSTATCOD = 1
           [F:MIGXTM]TMSTAT = "Not Found"
           [F:MIGXTM]TMSTATMSG = "Not Found In Target"
           [F:MIGXTM]TMTRGTBL = ""
           [F:MIGXTM]TMSRCTBL = [T_SRC]CODFIC

           #Reset error handling variables
           ERRVAL = 0
           ERRNUM = 0
           ERRMSG = ""

           #Source table check
           #Error handling, check if we can actually open the table\file, to get the row count aswell
           #Serves as a way to check that the actual table file exists, makes the data compare process less complex
            Onerrgo FILECHECKERR #try
              Local File = SRCFLD + "." + [T_SRC]CODFIC [SRC_TOBJ]
              If ERRVAL = 0
                 Look [SRC_TOBJ] First

                 If fstat = 5 #No record corresponds to the specified criteria (Record not found)
                    [F:MIGXTM]TMSTATCOD = 4 #Source Error
                    [F:MIGXTM]TMSTAT = "Error"-num$(fstat)
                    [F:MIGXTM]TMSTATMSG = "Could not read table"
                 Else
                    [F:MIGXTM]TMSRCRC = rowcount([SRC_TOBJ])
                 Endif
              Else #catch
                 [F:MIGXTM]TMSTATCOD = 4 #Source Error
                 [F:MIGXTM]TMSTAT = "Error"-num$(ERRNUM)
                 [F:MIGXTM]TMSTATMSG = ERRMSG
              Endif
              Close File [SRC_TOBJ]
            ERRVAL = 0 #finally

           Write [F:MIGXTM]

           If fstat > 0
             Infbox "Error: " + num$(fstat)
             Break
           Endif

           I += 1
        Endif

        K += 1
      Next

      Infbox "Compare Done"

      Call FERME_VLC From GESECRAN

      Close Local File [F_SRC]
      Close Local File [F_TRG]

      Close Local File [T_SRC]
      Close Local File [T_TRG]

      Call LOAD_DATA()
  Else
    Infbox "Could not load folders."
  Endif
End

######################################################################################

$FILECHECKERR
  ERRVAL = 1
  ERRNUM = errn
  ERRMSG = errmes$(errn)-errm
Resume

######################################################################################

Subprog CONSTRUCT_KEY_QUERY(FLD, I_SRC_TBL, SRC_INDX, IDX_COUNT, I_SRC_VAL)
  Variable Char FLD
  Variable Char I_SRC_TBL
  Variable Char SRC_INDX
  Variable Integer IDX_COUNT
  Variable Char I_SRC_VAL

  Local Char INDEXES(100)(1..)
  Local Char FDEF_NAME(30) : FDEF_NAME = ".ATABZON"
  Local Char TIDX_NAME(30) : TIDX_NAME = ".ATABIND"
  Local Char DT_NAME(30) : DT_NAME = ".ATYPE"

  If clalev([FDEF_SRC]) = 0 : Local File = FLD + FDEF_NAME [FDEF_SRC] : Endif
  If clalev([DT_SRC]) = 0 : Local File = FLD + DT_NAME [DT_SRC] : Endif

  Call SPLIT([I_SRC]DESCRIPT, "+", INDEXES, IDX_COUNT)
  I_SRC_VAL = func REPLACE(SRC_INDX, "+", " = * & ", 1)
  I_SRC_VAL += " = *"

  For I = 1 To IDX_COUNT
    Filter [FDEF_SRC] Where CODFIC = I_SRC_TBL & CODZONE = INDEXES(I)
    Read [FDEF_SRC] First

    If fstat = 0
      If [FDEF_SRC]CODTYP = "A" | [FDEF_SRC]CODTYP = "DCB"
        I_SRC_VAL = func REPLACE(I_SRC_VAL, "*", "'#'", 0)
      Elsif [FDEF_SRC]CODTYP = "D"
        I_SRC_VAL = func REPLACE(I_SRC_VAL, "*", "[#]", 0)
      Else
        Filter [DT_SRC] Where CODTYP = [FDEF_SRC]CODTYP
        Read [DT_SRC] First
        If fstat = 0
          If [DT_SRC]TYPTYP = 7 | [DT_SRC]TYPTYP = 8
            I_SRC_VAL = func REPLACE(I_SRC_VAL, "*", "'#'", 0)
          Else
            I_SRC_VAL = func REPLACE(I_SRC_VAL, "*", "#", 0)
          Endif
        Else
          I_SRC_VAL = func REPLACE(I_SRC_VAL, "*", "'#'", 0)
        Endif
      Endif
    Else
      I_SRC_VAL = func REPLACE(I_SRC_VAL, "*", "'#'", 0)
    Endif
  Next

End

######################################################################################

Subprog MSG(MSG)
  Value Char MSG
  Infbox MSG
End

######################################################################################

Subprog AM_TMOSELALL(VALEUR)
Variable Integer VALEUR
  Call UPDATE_SELECT(VALEUR)
End

######################################################################################

Subprog UPDATE_SELECT(SELVAL)
Value Integer SELVAL

  nolign = 0
  For [F:MIGXTM]MIGTM0 Where [F:MIGXTM]MIGREFNUM=[M:MIGX0]MIGREFNUM & [F:MIGXTM]TMSTATCOD = 0
     nolign += 1
     [M:MIGX1]TMINCLUDE(nolign - 1) = SELVAL
  Next

  Affzo [M:MIGX1]

End

######################################################################################

Funprog REPLACE(STRVAL, OLDSTR, NEWSTR, ALLOCCR)
  Value Char STRVAL
  Value Char OLDSTR
  Value Char NEWSTR
  Value Integer ALLOCCR #1 - true
  Local Char RESULT(200)

  Local Integer S_IX : S_IX = 1
  Local Integer F_IX : F_IX = 1

  Repeat
    F_IX = instr(S_IX, STRVAL, OLDSTR)

    If F_IX > 0
      RESULT = seg$(STRVAL, 1, F_IX - 1) + NEWSTR + seg$(STRVAL, F_IX + len(OLDSTR), len(STRVAL))

      S_IX = (F_IX - 1 - S_IX) + len(NEWSTR) + 1

      STRVAL = RESULT

      If ALLOCCR < 1
        Break
      Endif
    Else
      RESULT = STRVAL
    Endif

  Until F_IX <= 0

End RESULT

######################################################################################

Subprog SPLIT(STRVAL, SPLITCHAR, INDEXES, COUNT)
  Value Char STRVAL
  Value Char SPLITCHAR
  Variable Char INDEXES
  Variable Integer COUNT

  Local Integer F_IX : F_IX = 1
  Local Integer I : I = 0

  Repeat
    F_IX = instr(1, STRVAL, SPLITCHAR)
    If F_IX > 0
      INDEXES(I) = seg$(STRVAL, 1, F_IX - 1)
      STRVAL = seg$(STRVAL, F_IX + 1, len(STRVAL))
    Else
      INDEXES(I) = STRVAL
    Endif

    I += 1
  Until F_IX <= 0

  COUNT = I

End

######################################################################################

