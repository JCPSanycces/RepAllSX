#<AdxTL>@(#)0.0.0.0 $Revision$
# Class BSIIMPTCDUP


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
   Case CURPRO
    When "CODNEW"
      Case [L]ARULE
        When "CONTROL"   : Gosub CODNEW_CONTROL
      Endcase
    When Default
  Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_DUPLICATE"  : Gosub MET_DUPLICATE
  Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

####################################################################

$CODNEW_CONTROL
  If this.CODNEW <> ""
    If func CTRL_EXIST_TYPCOD(this.CODNEW, this.BANNEW) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("CODNEW",mess(45,7779,1)-":"-this.CODNEW,[V]CST_AERROR)
      ASTATUS = fmet this.ASETERROR("Bank",mess(45,7779,1)-":"-this.BANNEW,[V]CST_AERROR)
    Endif
  Endif
Return


####################################################################

$MET_DUPLICATE
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Char WERR(250)

  ASTATUS = fmet this.ADELETEERROR("")
  If this.CODNEW <> ""
    ASTATUS = fmet this.ASETERROR("",mess(9,7983,1),[V]CST_AINFO)
    If func CTRL_EXIST_TYPCOD(this.CODNEW, this.BANNEW) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("Bank type code",mess(45,7779,1)-":"-this.CODNEW,[V]CST_AERROR)
      ASTATUS = fmet this.ASETERROR("Bank",mess(45,7779,1)-":"-this.BANNEW,[V]CST_AERROR)
      WRET_VALUE = [V]CST_AERROR
    Else
      If func COPY_TYPCOD(this.BSICODTC, this.BAN, this.CODNEW, this.BANNEW, this.ACTX.LAN, WERR) = [V]CST_AERROR
        ASTATUS = fmet this.ASETERROR("",mess(9,7983,1)-":"-mess(9,2007,1)-this.CODNEW-WERR,[V]CST_AERROR)
        WRET_VALUE = [V]CST_AERROR
      Else
        ASTATUS = fmet this.ASETERROR("",mess(9,7983,1)-":"-mess(7,2007,1)-this.CODNEW,[V]CST_AINFO)
        WRET_VALUE = [V]CST_AOK
      Endif
    Endif
  Else
    ASTATUS = fmet this.ASETERROR("",mess(141,105,1),[V]CST_AERROR)
    WRET_VALUE = [V]CST_AERROR
  Endif
  ARET_VALUE = WRET_VALUE
Return

Funprog CTRL_EXIST_TYPCOD(WCOD, WBAN)
Value Char WCOD
Value Char WBAN
  Local Integer WOK : WOK = [V]CST_AFALSE
  If WCOD <> ""
    Local File BSIIMPTC [BSITC]
    Read [BSITC]BSITC0 = WCOD;WBAN
    If !fstat
      WOK = [V]CST_ATRUE
    Endif
    LogicClose File [BSITC]
  Else
    WOK = [V]CST_AFALSE
  Endif
End WOK

Funprog COPY_TYPCOD(WCOD, WBAN, WCOD_NEW, WBAN_NEW, WLAN_NEW, WERR)
  Value Char WCOD, WBAN, WBAN_NEW, WLAN_NEW, WCOD_NEW, WERR : WERR = ""
  # Issue 77700
  Local Char WCODFIC(12) : WCODFIC = ""
  Local Char WZONE(12)   : WZONE   = ""
  Local Char WIDENT1(80) : WIDENT1 = ""
  Local Char WIDENT2(80) : WIDENT2 = ""
  Local Char WLANORI(03) : WIDENT2 = ""
  Local Char WTEXTE(80)  : WTEXTE = ""
  # End issue 77700
  Local Integer WOK : WOK = [V]CST_AOK
  Local File BSIIMPTC [BSITC]
  Local File BSIIMPTC [BSITC2]
  Local File BSIITCD [BSITCD]
  Local File BSIITCD [BSITCD2]
  # Issue 77700
  Local File ATEXTRA [AXX]
  Local File ATEXTRA [AXX2]
  # Trbegin [BSITC2], [BSITCD2]
  Trbegin [BSITC2], [BSITCD2], [AXX2]
  # End issue 77700

  Read [BSITC]BSITC0 = WCOD;WBAN
  If !fstat
    [BSITC2]         = [BSITC]
    [BSITC2]BSICODTC = WCOD_NEW
    [BSITC2]BAN      = WBAN_NEW
    Write [BSITC2]
#Dbgaff
    # Issue 77700
    If fstat = [V]CST_AOK # Operation succeeded.
      # First of all we recover the ATEXTRA record of the Bank import type code header to be copied to recover the text.
      WCODFIC = 'BSIIMPTC' : WZONE = 'DESAXX' : WIDENT1 = [BSITC]BSICODTC : WIDENT2 = ""
      Filter [AXX] Where CODFIC=WCODFIC & ZONE=WZONE & IDENT1=WIDENT1 & IDENT2=WIDENT2
      For [AXX]
      # For each record we check if already exists.
        WTEXTE = [AXX]TEXTE : WCODFIC = 'BSIIMPTC' : WZONE = 'DESAXX' : WIDENT1 = WCOD_NEW : WIDENT2 = ""
        Read [AXX]AXX0 = WCODFIC;WZONE;[AXX]LANGUE;WIDENT1;WIDENT2
        If fstat = [V]CST_ANOREC # Record not read (no current record exists). We move fields and write the record.
          Raz [AXX2]
          [AXX2]CODFIC = WCODFIC
          [AXX2]ZONE   = WZONE
          [AXX2]LANGUE = [AXX]LANGUE
          [AXX2]LANORI = WLANORI
          [AXX2]IDENT1 = WIDENT1
          [AXX2]IDENT2 = WIDENT2
          [AXX2]TEXTE  = WTEXTE
          Write [AXX2]
        Endif
      Next
      Filter [AXX]
    Endif
    # End issue 77700

    If fstat
      WOK = [V]CST_AERROR
      WERR = "BSIIMPTC ("+mess(1,7983,1)+")"
    Endif
  Else
    WOK = [V]CST_AERROR
    WERR = "BSIIMPTC ("+mess(7,7983,1)+")"
  Endif

  If WOK = [V]CST_AOK
    Filter [BSITCD] Where BSICODTC = WCOD
    For [BSITCD]
      [BSITCD2]         = [BSITCD]
      [BSITCD2]BSICODTC = WCOD_NEW
      [BSITCD2]BAN      = WBAN_NEW
      Write [BSITCD2]

      # Issue 77700
      If fstat = [V]CST_AOK # Operation succeeded.
        # First of all we recover the ATEXTRA record of the Bank import type code detail to be copied to recover the text
        WCODFIC = 'BSIIMPTC' : WZONE = 'DESAXX' : WIDENT1 = [BSITC]BSICODTC : WIDENT2 = [BSITCD]COD
        Filter [AXX] Where CODFIC=WCODFIC & ZONE=WZONE & IDENT1=WIDENT1 & IDENT2=WIDENT2
        For [AXX]
        # For each record we check if already exists.
          WTEXTE = [AXX]TEXTE : WCODFIC = 'BSIIMPTC' : WZONE = 'DESAXX' : WIDENT1 = WCOD_NEW : WIDENT2 = [BSITCD]COD
          Read [AXX]AXX0 = WCODFIC;WZONE;[AXX]LANGUE;WIDENT1;WIDENT2
          If fstat = [V]CST_ANOREC # Record not read (no current record exists). We move fields and write the record.
            Raz [AXX2]
            [AXX2]CODFIC = WCODFIC
            [AXX2]ZONE   = WZONE
            [AXX2]LANGUE = [AXX]LANGUE
            [AXX2]LANORI = WLANORI
            [AXX2]IDENT1 = WIDENT1
            [AXX2]IDENT2 = WIDENT2
            [AXX2]TEXTE  = WTEXTE
            Write [AXX2]
          Endif
        Next
        Filter [AXX]
      Endif
      # End issue 77700

      If fstat
          WOK = [V]CST_AERROR
          Break
      Endif
    Next
    Filter [BSITCD]
  Endif

  If WOK = [V]CST_AERROR
    If WERR = "" : WERR = "BSIITCD ("+mess(3,40,1)-num$([BSITCD2]LIN)+")" : Endif
    Rollback
  Else
    Commit
  Endif

  LogicClose File [BSITCD2]
  LogicClose File [BSITCD]
  LogicClose File [BSITC2]
  LogicClose File [BSITC]
  LogicClose File [AXX2] # Issue 77700 - 2018-03-23 by JMR
End WOK

