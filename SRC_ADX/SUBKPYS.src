##################################################
# Incoming values can be converted (transcribed)
# to valid X3 values)
#
# Transcribe TYP 1 = Site Transcribe
# Transcribe TYP 2 = Account Transcribe
#
# Screen to manage basic CRUD functioanlity
##################################################

$ACTION
  Case ACTION
      When Default                                           : #
  Endcase
Return


######################################################################################
# FIELD (SCREEN) SUBPROGS
######################################################################################
Subprog C_INVALUE(VALEUR)
Variable Char    VALEUR()
    # Prevent duplicate site transcribe value from being entered
    If [M]TYP(nolign-1) = 1
        Call IS_DUPLICATE_SITE_LINE([M]TYP(nolign-1), VALEUR)
    Endif
End


Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
    # Check value being entered is not duplicate transcribe
    Call IS_DULICATE_ACC ([M]TYP(nolign-1), [M]INVALUE(nolign-1), VALEUR)
    # Get the legal COA for the entered site - Account transcribe only
    If [M]TYP(nolign-1) < 3
      Call GET_LEGAL_COA(VALEUR)
    Endif
End


Subprog AS_GTE(VALEUR)
Variable Char    VALEUR()
    # Prevent value from being entered if transcibe type = account or Contra
    # If [M]TYP(nolign-1) = 2 or [M]TYP(nolign-1) = 3 GH CHANGED 12/08/2014, NO type 3 (CONTRA)
    If [M]TYP(nolign-1) > 1
        mkstat = 2
    Endif
    # Set GCURLEG For current line to control
    # which doc type can be selected by user
    Call GETSOC([M:KPYS]FCY(nolign -1)) From DEVSUB
End


Subprog C_GTE(VALEUR)
Variable Char    VALEUR()
    # Force user to enter values if site record being enterd
    If [M]TYP(nolign-1) = 1
        If VALEUR = ""
            GMESSAGE = mess(10,123,1)
            mkstat = 1
        Endif
    Endif
End


Subprog AS_GAU(VALEUR)
Variable Char    VALEUR()
    # Prevent value from being entered if transcibe type = account
    #If [M]TYP(nolign-1) = 2 or [M]TYP(nolign-1) = 3 GH CHANGED 12/08/2014, NO type 3 (CONTRA)
    If [M]TYP(nolign-1) > 1
        mkstat = 2
    Endif
End


Subprog C_GAU(VALEUR)
Variable Char    VALEUR()
    # Force user to enter values if site record being enterd
    If [M]TYP(nolign-1) = 1
        If VALEUR = ""
            GMESSAGE = mess(10,123,1)
            mkstat = 1
        Endif
    Endif
End

######################################################################################
## Section automatically added (screen KPYTRAN) 09/10/2014 13:56:45 (JAMCC)
######################################################################################
Subprog C_CDE(VALEUR)
Variable Char    VALEUR()
Local Char    COD(30)
Local Char    CPY(30)

    COD = VALEUR
    If GFONCTION = "GESCDE" | COD="" : End : Endif
    If clalev([F:CDE])=0 : Local File CACCEDEF [CDE] : Endif

    fstat=0 # US104
        If CPY<>""
            Read [CDE]CDE0 = COD;CPY
            If fstat
                Read [CDE]CDE0(1) = COD
            Endif
        Else
            Filter [CDE] Where COD=[L]COD
            Read  [CDE]CDE0 First
        Endif

        If fstat
            GMESSAGE = mess(23,100,1)
            mkstat = 2
        Endif

    Filter [CDE]
End

Subprog AS_CDE(VALEUR)
Variable Char    VALEUR()
    # Prevent value from being entered if transcibe type = account
    If [M]TYP(nolign-1) > 1
        mkstat = 2
    Endif
End


Subprog AS_ACCDAT(VALEUR)
Variable Integer VALEUR
    # Prevent value from being entered if transcibe type = account
    # If [M]TYP(nolign-1) = 2 or [M]TYP(nolign-1) = 3 GH Changed 12/08/2014, no type 3 (contra)
    If [M]TYP(nolign-1) > 1
      mkstat = 2
    Endif
End


Subprog AS_ACC(VALEUR)
Variable Char    VALEUR()
    # Prevent value from being entered if transcibe type = site and not contra GH 12/08/2014
    If [M]TYP(nolign-1) <> 2 and [M:KPYS]CONTRA(nolign-1) <> 2
        mkstat = 2
    Endif
End


Subprog C_ACC(VALEUR)
Variable Char    VALEUR()
    # Force user to enter values if account record being enterd
    If VALEUR = ""
        GMESSAGE = mess(10,123,1)
        mkstat = 1
    Endif
End


# Code added 12/08/2014 GH
Subprog C_CONTRA(VALEUR)
Variable Integer VALEUR

  # is this a site type record?
  If [M]TYP(nolign-1) = 1
    # if the user has entered yes for contra entries, retrieve the COA
    If VALEUR = 2
      Call GET_LEGAL_COA([M]FCY(nolign-1))
    Else
      # GH 22/08/14 - Reset the COA, account code and dimension information
      Raz [M]COA(nolign-1)
      Raz [M]ACC(nolign-1)
    Endif
  Endif
End


Subprog AS_CONTRA(VALEUR)
Variable Integer VALEUR
  # Prevent value from being entered if transcribe type = account
  If [M:KPYS]TYP(nolign-1) > 1
    [M:KPYS]CONTRA(nolign-1) = 1
    mkstat = 2
  Endif
End
Subprog AS_CCE(VALEUR)
Variable Char    VALEUR()
  If [M:KPYS]TYP(nolign-1) < 3
    mkstat = 2
  Endif
End

# End of added code 12/08/2014 GH

######################################################################################
# SUBPROGS
######################################################################################

#############################################################
# Check if duplicate site transcibe line from being entered
Subprog IS_DUPLICATE_SITE_LINE(INTYP, INVAL)
Value Integer  INTYP
Value Char     INVAL

  For COUNTER = 0 To NBLIG-1
    If [M]TYP(COUNTER) = INTYP and [M]INVALUE(COUNTER) = INVAL
      # if condition added to prevent current line checking itself
      If (COUNTER+1) <> nolign
        GMESSAGE = mess(1,3701, 1) - num$(COUNTER+1)
        mkstat = 2
      Endif
      Break
    Endif
  Next COUNTER
End

##############################################################
# Check if duplicate account transcibe line from being entered
Subprog IS_DULICATE_ACC (INTYP, INVAL, INFCY)
Value Integer  INTYP
Value Char     INVAL
Value Char     INFCY

    For COUNTER = 0 To NBLIG-1
        If [M]TYP(COUNTER) = INTYP and [M]INVALUE(COUNTER) = INVAL and [M]FCY(COUNTER) = INFCY
            If (COUNTER+1) <> nolign : # Prevent current line finding itself as a duplicate
                GMESSAGE = mess(1,3701, 1) - num$(COUNTER+1)
                mkstat = 2
            Endif
            Break
        Endif
    Next COUNTER
End

##############################################################
# Find and insert legal COA for selected site
Subprog GET_LEGAL_COA(INFCY)
Value Char     INFCY

    Call GETSOC(INFCY) From DEVSUB
    Read[CPY]CPY0 = GSOCIETE
    Read [GCM]GCM0 = [F:CPY]ACM

    If clalev([F:LED])=0  : Local File GLED[LED]  : Endif    : # Ledgers
    Read [LED]LED0 = [F:GCM]LED(0)

    [M]COA(nolign-1) = [F:LED]COA

End

