#<AdxTL>@(#)4.0.0.0 $Revision$
##################################################################################################
#  Sous-programmes pour la gestion des solutions trouvées        Module CRM     12 février 2004  #
##################################################################################################
#                                                                                                #
#  DISPICON   : Affichage des icônes
#  LOADHD3    : Chargement des CLOBs
#  SETNEWSOL  : Gestion des solutions associées
#                                                                                                #
##################################################################################################

######################################################
#Affichage des icônes
######################################################
$DISPICON

#Gosub DEFICONNUM From SUBITNB1
Gosub DEFICONNUM From CRMUTIL150

#Synthèse description demande de service
Local Char SZDESCTL(250)
Raz SZDESCTL
Setlob SZDESCTL With [M:SSO1]PBLFULDES
If SZDESCTL = ""
    [M:SSO1]PBLDESICO = ""
    [M:SSO1]PBLDES = ""
Else
    If len(SZDESCTL) > GLONCLE
        If [M:SSO1]PBLDESFLG
            [M:SSO1]PBLDESICO = SZICOSYNDON
        Else
            [M:SSO1]PBLDESICO = SZICOSYN
            [M:SSO1]PBLDES = SZDESCTL
        Endif
    Else    
        [M:SSO1]PBLDES = SZDESCTL
        [M:SSO1]PBLDESICO = ""    
    Endif
Endif

#Synthèse solution
Raz SZDESCTL
Setlob SZDESCTL With [M:SSO2]SOLFULDES
If SZDESCTL = ""
    [M:SSO2]SOLDESICO = ""
    [M:SSO2]SOLDES = ""
Else
    If len(SZDESCTL) > GLONCLE
        If [M:SSO2]SOLDESFLG
            [M:SSO2]SOLDESICO = SZICOSYNDON
        Else
            [M:SSO2]SOLDESICO = SZICOSYN
            [M:SSO2]SOLDES = SZDESCTL
        Endif
    Else    
        [M:SSO2]SOLDES = SZDESCTL
        [M:SSO2]SOLDESICO = ""    
    Endif
Endif
Return

######################################################
# Chargement des CLOBs
######################################################
$LOADHD3

Local Integer ILOOKFORCLOB
ILOOKFORCLOB = 1

If [M:SSO1]NUMPBLDES = ""
    Raz [M:SSO1]PBLFULDES
    ILOOKFORCLOB = 0
Endif

If [M:SSO1]TYPPBLDES = ""
    Raz [M:SSO1]PBLFULDES
    ILOOKFORCLOB = 0
Endif

If ILOOKFORCLOB
    Read [HD3] HD30 = [M:SSO1]NUMPBLDES;[M:SSO1]TYPPBLDES
    If fstat
        Raz [M:SSO1]PBLFULDES
    Else
        [M:SSO1]PBLFULDES = [F:HD3]CLOB
    Endif
Endif

ILOOKFORCLOB = 1

If [M:SSO2]NUMSOLDES = ""
    Raz [M:SSO2]SOLFULDES
    ILOOKFORCLOB = 0
Endif

If [M:SSO2]TYPSOLDES = ""
    Raz [M:SSO2]SOLFULDES
    ILOOKFORCLOB = 0
Endif

If ILOOKFORCLOB
    Read [HD3] HD30 = [M:SSO2]NUMSOLDES;[M:SSO2]TYPSOLDES
    If fstat
        Raz [M:SSO2]SOLFULDES
    Else
        [M:SSO2]SOLFULDES = [F:HD3]CLOB
    Endif
Endif

Return


#######################################################################################
# Gestion des solutions associées
#######################################################################################
$SETNEWSOL
Local Integer ITER
ITER = 0

GSZSOLKEY = [M:SSO0]SOLNUM
G8 = [M:SSO0]SOLNUM
Raz G9
For ITER = 0 To [M:SSO4]NBLIG - 1
    If [M:SSO4]CODSOL(ITER) <> ""
        G9(ITER) = [M:SSO4]CODSOL(ITER)
    Endif
Next

Return
