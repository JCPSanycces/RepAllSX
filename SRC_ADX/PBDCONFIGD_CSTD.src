######################################################################################################
# Module        : Finance
# Description   : - Payment balance declaration configuration details (Class PBDCONFIGD)
######################################################################################################
 # Updates :
 # Date       |Author |Version| Description
 # 2015-06-30 |Bader  |U9     | Init ORIENT
 # 2015-08-27 |DNE    |U9     | Improved checks on the root account.
 # 2015-12-21 |ANGRE  |U10    | SAM # 111399 changed ACTION to ARULE in $PROPERTIES
######################################################################################################


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

$METHODS
  Case [L]CURPTH
    When ""
      Case [L]AMETHOD
      Endcase
  Endcase
Return

# SAM # 111399 changed ACTION to ARULE
$PROPERTIES
  Case [L]CURPRO
    When "CROOTACC"
      Case [L]ARULE
        When "CONTROL"   : Gosub CTRL_CROOTACC
        When "PROPAGATE" : Gosub PROP_CROOTACC
      Endcase
    When "ACCSIGN"
      Case [L]ARULE
        When "INIT"   : this.ACCSIGN = 3
      Endcase
    When "BALAMT"
      Case [L]ARULE
        When "INIT"   : this.BALAMT = [V]CST_ANO
      Endcase
    When "ISINCLUDED"
      Case [L]ARULE
        When "INIT"   : this.ISINCLUDED = [V]CST_AYES
      Endcase
    When "ORIENT"
      Case [L]ARULE
        When "INIT"   : this.ORIENT = 1
      Endcase
  Endcase
Return


############################################################################################
# Implementation of the PROPERTIES
############################################################################################

$CTRL_CROOTACC
  If len(this.CROOTACC) > 0
# 2015-08-27 DNE MODIF BEGIN
    Local Integer POS : POS = instr( 1, this.CROOTACC, "*" )

    If ( POS > 0 ) and ( POS <> len( this.CROOTACC ) )
      ASTATUS = fmet this.ASETERROR( "CROOTACC", mess(275,139,1), [V]CST_AERROR ) # "The type of this column only authorizes a single wildcard character '*' at the end of the string"
    Else
      ASTATUS = func CHECK_ACC(this.APARENT.ROOTACC,this.CROOTACC,this)
    Endif
# 2015-08-27 DNE MODIF ORIG
#    ASTATUS = func CHECK_ACC(this.APARENT.ROOTACC,this.CROOTACC,this)
# 2015-08-27 DNE MODIF END
    If ASTATUS = [V]CST_AOK
      Local Char TMP (20)
      Local File GACCOUNT [GAC]  # accounts

      TMP = right$(this.CROOTACC,len(this.CROOTACC))   # get last character of account to check for "*"
      If TMP <> "*"                                    # only check single accounts (without wildcard *)
        If this.COA = ""
          ASTATUS = fmet this.ASETERROR( "CROOTACC", func AFNC.MES1( mess(352,107,1)), CST_AERROR )
                                      # "Please choose a ledger type first."
        Else
          Read [F:GAC]GAC0 = this.COA;this.CROOTACC    # try to find account
          If fstat                                     # not found
             ASTATUS = fmet this.ASETERROR( "CROOTACC", func AFNC.MES1( mess(353,107,1), this.CROOTACC), CST_AERROR )
                                      # "Invalid account $1$."
          Endif
        Endif
      Endif
      LogicClose File [GAC]
    Endif
  Endif
Return


Funprog CHECK_ACC (ROOTACC, CROOTACC, MYINST)
   Value Char ROOTACC
   Value Char CROOTACC
   Value Instance MYINST Using OBJECT
   Local Integer I
   Local Integer OKACC : OKACC = 1
   Local Char TMPROOTACC (200)
   Local Char TMPACC (20)
   Local Char TMP (20)
   Local Integer ASTATUS

# 2015-08-27 DNE MODIF BEGIN
   I = instr(1, " " + ROOTACC + " ", " " + CROOTACC + " ")   # search, if this.CROOTACC is included in PBDCONFIG.ROOTACC
# 2015-08-27 DNE MODIF ORIG
#   I = instr(1,ROOTACC,CROOTACC)   # search, if this.CROOTACC is included in PBDCONFIG.ROOTACC
# 2015-08-27 DNE MODIF END
   If I > 0
     ASTATUS = fmet MYINST.ASETERROR( "CROOTACC", func AFNC.MES1( mess(354,107,1), CROOTACC), CST_AERROR )
   Else
     TMP = right$(CROOTACC,len(CROOTACC))   # get last character of account to check for "*"
     If TMP = "*"
       TMP = left$(CROOTACC,len(CROOTACC)-1) # remove "*"
     Else
       TMP = CROOTACC                             # no "*" -> keep original account
     Endif

     TMPROOTACC = ROOTACC
     I=1
     While (I > 0 and OKACC)             # look for next blank as separator
       I = instr(1,TMPROOTACC," ")
       If I>0                            # blank found -> check account
         TMPACC = left$(TMPROOTACC,I-1)  # get next root account
         TMPROOTACC = right$(TMPROOTACC,I+1)
       Else
         TMPACC = TMPROOTACC             # no more blank -> get last account
       Endif
       Gosub CHECK_ACCOUNT
     Wend
   Endif
End ASTATUS


$CHECK_ACCOUNT
   Local Integer J, K, FOUND
   Local Char TMP1 (20)
   Local Char TMP2 (20)
   FOUND = 0
   J = instr(1,TMPACC,TMP)   # search, if this.CROOTACC is included in act. segment of PBDCONFIG.ROOTACC
   If J = 1                  # if found at the beginning, error
     OKACC = 0
     ASTATUS = fmet MYINST.ASETERROR( "CROOTACC", func AFNC.MES1( mess(354,107,1), MYINST.CROOTACC), CST_AERROR )
                                                     # "The account $1$ is included in the triggering account."
   Else
     TMP2 = left$(TMP,len(TMP)-1)        # remove last character and check if included
     While (len(TMP2) > 0 and not FOUND)
       K = instr(1,TMPACC,TMP2)   # search, if TMP2 is included in act. segment of PBDCONFIG.ROOTACC
       FOUND = K = 1
       If not FOUND : TMP2 = left$(TMP2,len(TMP2)-1) : Endif # if not, cut next char at the end
     Wend
     If FOUND   # found -> check if CROOTACC OK with exception in brackets
       TMP1 = right$(TMPACC,len(TMPACC))   # get last character of segment to check for "*"
       If TMP1 = "*"
         TMP1 = left$(TMPACC,len(TMPACC)-1) # remove "*"
       Else
         TMP1 = TMPACC                      # restore
       Endif
       K = instr(1,TMP1,"(")   # search, if segment contains opening bracket "("
       If K > 0
         TMP1 = left$(TMP1,K-1) + right$(TMP1,K+1)
         TMP1 = left$(TMP1,len(TMP1)-1) # remove closing bracket ")" at the end
         If len(TMP) > len(TMP1)
           TMP2 = left$(TMP,len(TMP1))
         Else
           TMP2 = TMP
         Endif
         OKACC = TMP2 = TMP1              # OK if prefix + exception in brackets are same as CROOTACC
         If !OKACC and len(TMP1) > 1      # if not OK, remove last char and check again -> OK if not equal
           TMP1 = left$(TMP1,len(TMP1)-1) # remove last char
           TMP2 = left$(TMP2,len(TMP2)-1) # remove last char
           OKACC = TMP2 <> TMP1
         Endif
       Else
         If len(TMP2) >= len(TMP1) # not OK if this.CROOTACC is only included when shorter than act. segment (cutted until smaller)
           OKACC = 0
         Endif
       Endif

       If !OKACC
         ASTATUS = fmet MYINST.ASETERROR( "CROOTACC", func AFNC.MES1( mess(354,107,1), MYINST.CROOTACC), CST_AERROR )
                                                     # "The account $1$ is included in the triggering account."
       Endif
     Endif
   Endif
Return



$PROP_CROOTACC
If this.CROOTACC <> ""
   Local Char TMP (20)
   Local File GACCOUNT [GAC] # accounts

   TMP = right$(this.CROOTACC,len(this.CROOTACC))   # get last character of account to check for "*"
   If TMP <> "*"                                    # only check single accounts (without wildcard *)
     Read [F:GAC]GAC0 = this.COA;this.CROOTACC      # try to find account
     If !fstat                                      # found
       If [F:GAC]MTC <> 2                           # non collective account: set BPGROUP to blank
          this.BPGROUP = ""
       Endif
     Endif
   Endif
Endif
Return

