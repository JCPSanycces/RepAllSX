[L]DCLFLD = "102" : [L]SUF = ""  : [L]CRIT = "1=1" : Gosub GETMAXDIM From CALVATPOR : Local Char VAT102(GLONCPY)(1..3,1..[L]RCOUNT)  : Gosub FEEDVATVAR From CALVATPOR
[L]DCLFLD = "103" : [L]SUF = ""  : [L]CRIT = "1=1" : Gosub GETMAXDIM From CALVATPOR : Local Char VAT103(GLONCPY)(1..3,1..[L]RCOUNT)  : Gosub FEEDVATVAR From CALVATPOR
[L]DCLFLD = "104" : [L]SUF = ""  : [L]CRIT = "1=1" : Gosub GETMAXDIM From CALVATPOR : Local Char VAT104(GLONCPY)(1..3,1..[L]RCOUNT)  : Gosub FEEDVATVAR From CALVATPOR
[L]DCLFLD = "104" : [L]SUF = "G" : [L]CRIT = "[F:DVPT]GOODAQU = 2" : Gosub GETMAXDIM From CALVATPOR : Local Char VAT104G(GLONCPY)(1..3,1..[L]RCOUNT) : Gosub FEEDVATVAR From CALVATPOR
[L]DCLFLD = "104" : [L]SUF = "S" : [L]CRIT = "[F:DVPT]SERVAQU = 2" : Gosub GETMAXDIM From CALVATPOR : Local Char VAT104S(GLONCPY)(1..3,1..[L]RCOUNT) : Gosub FEEDVATVAR From CALVATPOR
[L]DCLFLD = "105" : [L]SUF = ""  : [L]CRIT = "1=1" : Gosub GETMAXDIM From CALVATPOR : Local Char VAT105(GLONCPY)(1..3,1..[L]RCOUNT)  : Gosub FEEDVATVAR From CALVATPOR
Return
####################################################################################
####################################################################################
$KILL_CONTEXT

Kill VAT001, VAT002, VAT003, VAT004, VAT005, VAT006, VAT007, VAT008, VAT008T, VAT009
Kill VAT012, VAT012T, VAT013, VAT014, VAT015, VAT016, VAT017, VAT018, VAT019
Kill VAT020, VAT021, VAT022, VAT023, VAT024
Kill VAT040, VAT041
Kill VAT065, VAT066, VAT067, VAT068, VAT069
Kill VAT070, VAT071, VAT072, VAT072G, VAT072S, VAT073
Kill VAT097, VAT098, VAT099
Kill VAT100, VAT101, VAT102, VAT103, VAT104, VAT104G, VAT104S, VAT105

Return
####################################################################################
####################################################################################
$SET_RC_EECNUM

If find([L]DCLFLD,"20","21","22","23","24")

  If [L]CEEFLG <> 2 & [L]CRY <> ""
    [F:DVPB]CRY = "IM"
    [F:DVPB]EECNUM = [F:CPY]EECNUM #VAVIL X3-88879
  Else

    If [F:HAE]RVSORINUM=""

      If [F:PIH]NUM <> [F:HAE]NUM
        Read [F:PIH]PIH0 = [F:HAE]NUM
        If fstat : Raz [F:PIH] : Endif
      Endif
      If [F:PIH]NUM = [F:HAE]NUM
        Call LEC_TVB_LEG([F:CPY]LEG,[F:PIH]VAC,I) From TRTLECLEG
        If I : Raz [F:TVB] : Endif
        If [F:TVB]REGVAC = 4
          #X3-95168 - Rule is the same independent of VATIPT: should only apply to PT
          #If [L]BORI = 1
          #  [L]ACCVATIPT = [F:GACP]VATIPT
          #Else
          #  [L]ACCVATIPT = [F:GAC2]VATIPT
          #Endif
          #If find([L]ACCVATIPT,5,8)
          #  [F:DVPB]EECNUM    = [F:CPY]EECNUM
          #  [F:DVPB]CRY       = "RC"
          #Else
            If [F:BPR]BPRNUM <> [F:PIH]BPR
              Read [F:BPR]BPR0 = [F:PIH]BPR
              If fstat : Raz [F:BPR] : Endif
            Endif
            If [F:BPR]CRY = "PT"
              [F:DVPB]EECNUM    = [F:CPY]EECNUM
              [F:DVPB]CRY       = "RC"
            Endif
          #Endif
        Endif
      Endif

    Else

      If !clalev([F:PIHR]) : Local File PINVOICE   [PIHR] : Endif
      Read [F:PIHR]PIH0 = [F:HAE]RVSORINUM
      If fstat : Raz [F:PIHR] : Endif
      If [F:PIHR]NUM = [F:HAE]RVSORINUM
        Call LEC_TVB_LEG([F:CPY]LEG,[F:PIHR]VAC,I) From TRTLECLEG
        If I : Raz [F:TVB] : Endif
        If [F:TVB]REGVAC = 4
          If find([F:GAC2]VATIPT,5,8)
            [F:DVPB]EECNUM    = [F:CPY]EECNUM
            [F:DVPB]CRY       = "RC"
          Else
            If [F:BPR]BPRNUM <> [F:PIH]BPR
              Read [F:BPR]BPR0 = [F:PIH]BPR
              If fstat : Raz [F:BPR] : Endif
            Endif
            If [F:BPR]CRY = "PT"
              [F:DVPB]EECNUM    = [F:CPY]EECNUM
              [F:DVPB]CRY       = "RC"
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
Endif

Return
######################################################################################
######################################################################################
$RAZ_AMT

[L]AMTBAS = 0
[L]AMTVAT = 0

Return

######################################################################################
######################################################################################
Subprog GET_DATDOC(DOC,FLD40REN,DAT,CTLORIMOD)
Value Char    DOC
Value Char    FLD40REN #Issue X3-99930 - 2018-08-02 by VAVIL - POR: Portuguese legislation (VAT modifications with law 166/2018)
Variable Date DAT
Value Integer CTLORIMOD

Local Char    INVNUM(GLONVCR)
Local Date    DOCDAT

If CTLORIMOD = 5

  If !clalev([F:SID])  : Local File SINVOICED    [SID]   : Endif
  If !clalev([F:SIHA]) : Local File SINVOICE     [SIHA]  : Endif #VAVIL

  If [F:SIH]NUM <> DOC
    Read [F:SIH]SIH0 = DOC
    If fstat : Raz [F:SIH] : Endif
  Endif

  If [F:SIH]NUM = DOC
    If [F:SIH]INVNUM <> ""
      INVNUM = [F:SIH]INVNUM
      If FLD40REN <> "1A1" #Issue X3-99930 - 2018-08-02 by VAVIL - POR: Portuguese legislation (VAT modifications with law 166/2018)
        Read [F:SIH]SIH0 = INVNUM
        If fstat : Raz [F:SIH] : Endif
      Endif
      DOCDAT = [F:SIH]ACCDAT
    Else
      If [F:SIH]ORIMOD = 5
        Link [F:SID] With [F:SIHA]SIH0 = [F:SID]SIHORINUM As [LSID] Where [F:SID]NUM= DOC
        For [LSID]
          DOCDAT = [F:SIHA]ACCDAT
          Break
        Next
        If FLD40REN = "1A1" : DOCDAT = [F:SIH]ACCDAT  : Endif #Issue X3-99930 - 2018-08-02 by VAVIL - POR: Portuguese legislation (VAT modifications with law 166/2018)
      Endif
    Endif
    If [F:SIH]PERDEB <> [0/0/0] & DOCDAT = [0/0/0]
      DOCDAT = [F:SIH]PERDEB
    Endif
  Endif
Close Local File [SIHA] #VAVIL
Elsif CTLORIMOD = 6

  If !clalev([F:PID])  : Local File PINVOICED    [PID]   : Endif
  If !clalev([F:PIHA]) : Local File PINVOICE     [PIHA]  : Endif #VAVIL

  If [F:PIH]NUM <> DOC
    Read [F:PIH]PIH0 = DOC
    If fstat : Raz [F:PIH] : Endif
  Endif

  If [F:PIH]NUM = DOC
    If [F:PIH]INVNUM <>""
      INVNUM = [F:PIH]INVNUM
      Read [F:PIH]PIH0 = INVNUM
      If fstat : Raz [F:PIH] : Endif
      DOCDAT = [F:PIH]ACCDAT
    Else
      If [F:PIH]ORIMOD = 6
        Link [F:PID] With [F:PIHA]PIH0 = [F:PID]NUMORI  As [LPID] Where [F:PID]NUM= DOC
        For [LPID]
          DOCDAT = [F:PIHA]ACCDAT
          Break
        Next
      Endif
    Endif
  Endif
Close Local File [PIHA] #VAVIL
Endif

If DOCDAT <> [0/0/0]
  DAT = DOCDAT
Endif

End
######################################################################################
######################################################################################
$SET_CTLORIMOD

# 5 - customers
# 6 - suppliers

CTLORIMOD = 0

If find([F:HAE]ORIMOD, 5, 6)
  CTLORIMOD = [F:HAE]ORIMOD
Elsif [F:HAE]ORIMOD = 3
  If [F:SIH]NUM <> [F:HAE]NUM
    Read [F:SIH]SIH0 = [F:HAE]NUM
    If fstat : Raz [F:SIH] : Endif
  Endif
  If [F:SIH]NUM = [F:HAE]NUM
    CTLORIMOD = 5
  Else
    If [F:PIH]NUM <> [F:HAE]NUM
      Read [F:PIH]PIH0 = [F:HAE]NUM
      If fstat : Raz [F:PIH] : Endif
    Endif
    If [F:PIH]NUM = [F:HAE]NUM
      CTLORIMOD = 6
    Endif
  Endif
Endif

Return
######################################################################################
######################################################################################
#Issue 54535 – 2017-09-07 by MRDAB - Law 221/2017
Funprog CAL_TOT41()
Local Decimal TOTAL
Local Integer I

TOTAL = [M:DVPHP9]FLDAN4104A + [M:DVPHP9]FLDAN4104B + [M:DVPHP9]FLDAN4104C + [M:DVPHP9]FLDAN4104D
For I = 0 To [M:DVPHP9]NBLIG - 1
  TOTAL += [M:DVPHP9]AMTVAT41(I)
Next

End TOTAL
#Issue end
######################################################################################
######################################################################################
#Issue 54535 – 2017-09-11 by MRDAB - Law 221/2017
Funprog CAL_MAIN_TOT41()
Local Decimal TOTAL
Local Integer I

For I=0 To maxtab([M:DVPHP2]DCLFLD1)
  If [M:DVPHP2]DCLFLD1(I) = '041'
    [L]TOTAL = [M:DVPHP2]AMT1(I)
    Break
  Endif
Next

End TOTAL
#Issue end
######################################################################################
######################################################################################
### This Funprog returns the minimal value for a business partner to be mentioned
### on the annexes. It depend on the annex type.
### DCLVATPORB should be open
######################################################################################
######################################################################################
Funprog GET_MAXANEVAL(LINTYP, DCLNUM)
Value Integer LINTYP
Value Char    DCLNUM

Local Decimal ANETOT
Local Decimal RETVAL

Case LINTYP
  When 1
    For [F:DVPB] Where [F:DVPB]DCLNUM = [L]DCLNUM & [F:DVPB]CRY = "PT" & find([F:DVPB]DCLFLD, "008")
      ANETOT += [F:DVPB]AMTBAS
    Next
  When 3 #3 is used for 3, 4, 5, 6 and 7
    For [F:DVPB] Where [F:DVPB]DCLNUM = [L]DCLNUM & find([F:DVPB]DCLFLD, "020", "021", "022", "023", "024")
      ANETOT += [F:DVPB]AMTBAS
    Next
Endcase

RETVAL = ANETOT * 0.05

End RETVAL
######################################################################################
######################################################################################

