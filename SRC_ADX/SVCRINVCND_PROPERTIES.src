#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------------- PROPERTIES --------------------------------
#---------------------------------------------------------------
$INIT_VCRTYP
  this.VCRTYP=10 :#--Normal orders
Return
#-----------------------
$CONTROL_VCRTYP
  #--Only Order type documents for now
  #--VCRTYP=10
  If this.VCRTYP<>10
    [L]ASTATUS = fmet this.ASETERROR("VCRTYP",func AFNC.MES1(mess(471,192,1),"'"+mess(10,432,1)+"'"),[V]CST_AERROR)
  Endif
Return
#---------------------------------------------------------------
$PROPAGATE_SALFCY
  Gosub SET_CURLEG From SVCRINVCND_PROPERTIES
Return
#-----------------------
$SET_CURLEG
Local File FACILITY [FCY]
Local File COMPANY  [CPY]

  this.CURLEG = ""
  If this.SALFCY<>""
    Read [FCY]FCY0=this.SALFCY
    If fstat>0 : Raz [F:FCY] : Endif
    Read [CPY]CPY0=[FCY]LEGCPY
    If fstat>0 : Raz [F:CPY] : Endif
    this.CURLEG = [CPY]LEG
  Endif
Return
#---------------------------------------------------------------
$PROPAGATE_VCRTYP
  #--Here, only executed if DO_PROPAGATE=[v]cst_AYES
  If this.DO_PROPAGATE=[V]CST_ANO : Return : Endif

  If find(this.VCRTYP,10)>0
    #--For Orders, the SEQORI is mandatory
    [L]ASTATUS = fmet this.ASETATTRIBUTE("VCRSEQORI" ,"$isMandatory","true")
  Else
    [L]ASTATUS = fmet this.ASETATTRIBUTE("VCRSEQORI" ,"$isMandatory","false")
  Endif
Return
#---------------------------------------------------------------
$CONTROL_VCRNUMORI

  this.VCRNUMORI=toupper(this.VCRNUMORI)

Return
#---------------------------------------------------------------
$CONTROL_VCRLINORI

Return
#---------------------------------------------------------------
$CONTROL_VCRSEQORI

Return
#---------------------------------------------------------------
$CONTROL_VCRINVCNDDAT
#--The date cannot be changed if a list one line having a status different then 'To be invoiced'
If maxtab(this.VCRINVCNDLIN)<1 : Return : Endif
If this.snapshot=null or this.snapshot.VCRINVCNDDAT = AVOID.ADATE : Return : Endif

Local Integer WSIGMA,WTEMPSIGMA
  #--Does the schedule invoice have ohter lines than 'To be invoiced' ?
  WTEMPSIGMA = sigma(1,maxtab(this.VCRINVCNDLIN),
&   (     this.VCRINVCNDLIN(indcum)<>null and
&         this.VCRINVCNDLIN(indcum).INVCNDSTA>1 and
&    find(this.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0)
&  &( WSIGMA=0 and sigma(WSIGMA=1,1,1)))

  If WTEMPSIGMA>0
    this.VCRINVCNDDAT = this.snapshot.VCRINVCNDDAT
  Endif

Return
#---------------------------------------------------------------
$PROPAGATE_CUR
Local File TABCUR       [TCU]

  this.CUR_DECNBR = 0
  Read [F:TCU]TCU0=this.CUR
  If fstat : Raz [F:TCU] : Endif
  this.CUR_DECNBR = [F:TCU]DECNBR

Return
#---------------------------------------------------------------
$PROPAGATE_SAU
Local File TABUNIT      [TUNSAU]

  this.SAU_UOMDEC = 0
  Read [TUNSAU]TUN0=this.SAU
  If fstat : Raz [F:TUNSAU] : Endif
  this.SAU_UOMDEC = [F:TUNSAU]UOMDEC

Return
#---------------------------------------------------------------
$PROPAGATE_VCRINVCNDLIN_INVCNDAMTATI

  If this.IS_PROP_CHG<=[V]CST_ANO and find(this.INVCNDSTA,2,3,4)=0
    this.IS_PROP_CHG=[V]CST_AYES
    Gosub _AMTNOT_AMTATI_PROPAGATE_VCRINVCNDLIN
    this.IS_PROP_CHG=[V]CST_ANO
  Endif
Return
#---------------------------------------------------------------
$_AMTNOT_AMTATI_PROPAGATE_VCRINVCNDLIN

  If this.APARENT.QTY>0
    If this.APARENT.PRITYP = 2
      #--Only +Vat fields filled
      this.INVCNDAMTNOT = 0
      this.DNETPRINOT   = 0
      If this.INVCNDSTA<=1
        this.DNETPRIATI   = this.APARENT.NETPRIATI
        If this.DNETPRIATI<>0
          this.INVCNDQTY    = arr(this.INVCNDAMTATI/this.DNETPRIATI,10^(-this.APARENT.SAU_UOMDEC))
          #--As the QTY is the <main> info, we'll adapt the amount according to the rounded QTY
          this.INVCNDAMTATI = arr(this.INVCNDQTY*this.DNETPRIATI,10^(-this.APARENT.CUR_DECNBR))
        Else
          this.INVCNDQTY    = 0
          this.INVCNDAMTATI = 0
        Endif
      Endif
      If this.APARENT.QTY<>0
        this.INVPERCENT = arr((this.INVCNDQTY*100/this.APARENT.QTY),0.01)
      Else
        this.INVPERCENT = 0
      Endif
    Else
      #--Only -Vat fields filled
      this.INVCNDAMTATI = 0
      this.DNETPRIATI   = 0
      If this.INVCNDSTA<=1
        this.DNETPRINOT   = this.APARENT.NETPRINOT
        If this.DNETPRINOT<>0
          this.INVCNDQTY    = arr(this.INVCNDAMTNOT/this.DNETPRINOT,10^(-this.APARENT.SAU_UOMDEC))
          #--As the QTY is the <main> info, we'll adapt the amount according to the rounded QTY
          this.INVCNDAMTNOT = arr(this.INVCNDQTY*this.DNETPRINOT,10^(-this.APARENT.CUR_DECNBR))
        Else
          this.INVCNDQTY    = 0
          this.INVCNDAMTNOT = 0
        Endif
      Endif
      If this.APARENT.QTY<>0
        this.INVPERCENT = arr((this.INVCNDQTY*100/this.APARENT.QTY),0.01)
      Else
        this.INVPERCENT = 0
      Endif
    Endif
  Else
    #--It is not the QTY, but the AMTNOT/AMTATI that has to drive the calculation
    #TODO CPO
  Endif

Return
#---------------------------------------------------------------
$PROPAGATE_VCRINVCNDLIN_INVCNDAMTNOT

  If this.IS_PROP_CHG<=[V]CST_ANO  and find(this.INVCNDSTA,2,3,4)=0
    this.IS_PROP_CHG=[V]CST_AYES
    Gosub _AMTNOT_AMTATI_PROPAGATE_VCRINVCNDLIN
    this.IS_PROP_CHG=[V]CST_ANO
  Endif
Return
#---------------------------------------------------------------
$PROPAGATE_VCRINVCNDLIN_INVCNDQTY

  If this.IS_PROP_CHG<=[V]CST_ANO and find(this.INVCNDSTA,2,3,4)=0
    this.IS_PROP_CHG=[V]CST_AYES
    #--After changing the qunatity, a calculation is done on the
    #--percentage and/or amounts part comming from the original document

    #--The second test on snapshot is because of circle modification that calculate values identical to snapshot
    #--Exp. modifying qty to something, that induces recalculation of invpercent
    #--after that, modifying invpercent to same value as in snapshot.invpercent
    #--in this case, if we only test invpercent and it's snapshot, we will not recalculate the qty according to the new value NOK
    If this.APARENT.QTY>0
      this.INVPERCENT = arr((this.INVCNDQTY*100/this.APARENT.QTY),0.01)
      If this.APARENT.PRITYP = 2
        #--Only +Vat fields filled
        this.DNETPRINOT    = 0
        If this.INVCNDSTA<=1
          this.DNETPRIATI    = this.APARENT.NETPRIATI
        Endif
        this.INVCNDAMTNOT  = 0
        this.INVCNDAMTATI  = arr((this.INVCNDQTY*this.DNETPRIATI),10^(-this.APARENT.CUR_DECNBR))
      Else
        #--Only -Vat fields filled
        If this.INVCNDSTA<=1
          this.DNETPRINOT    = this.APARENT.NETPRINOT
        Endif
        this.DNETPRIATI    = 0
        this.INVCNDAMTNOT  = arr((this.INVCNDQTY*this.DNETPRINOT),10^(-this.APARENT.CUR_DECNBR))
        this.INVCNDAMTATI  = 0
      Endif
    Else
      #--It is not the QTY, but the AMTNOT/AMTATI that has to drive the calculation
      #TODO CPO
    Endif

    this.IS_PROP_CHG=[V]CST_ANO
  Endif
Return
#---------------------------------------------------------------
$PROPAGATE_VCRINVCNDLIN_INVPERCENT

  If this.IS_PROP_CHG<=[V]CST_ANO and find(this.INVCNDSTA,2,3,4)=0
    this.IS_PROP_CHG=[V]CST_AYES
    #--After changing the percentage, a calculation is done on the
    #--Quantities and/or amounts part comming from the original document

    #--The second test on snapshot is because of circle modification that calculate values identical to snapshot
    #--Exp. modifying qty to something, that induces recalculation of invpercent
    #--after that, modifying invpercent to same value as in snapshot.invpercent
    #--in this case, if we only test invpercent and it's snapshot, we will not recalculate the qty according to the new value NOK
    If this.APARENT.QTY>0
      this.INVCNDQTY = arr((this.INVPERCENT*this.APARENT.QTY)/100,10^(-this.APARENT.SAU_UOMDEC))
      this.INVPERCENT= arr((this.INVCNDQTY*100/this.APARENT.QTY),0.01)

      If this.APARENT.PRITYP = 2
        #--Only +Vat fields filled
        this.DNETPRINOT   = 0
        If this.INVCNDSTA<=1
          this.DNETPRIATI   = this.APARENT.NETPRIATI
        Endif
        this.INVCNDAMTNOT = 0
        this.INVCNDAMTATI = arr((this.INVCNDQTY*this.DNETPRIATI),10^(-this.APARENT.CUR_DECNBR))
      Else
        #--Only -Vat fields filled
        If this.INVCNDSTA<=1
          this.DNETPRINOT   = this.APARENT.NETPRINOT
        Endif
        this.DNETPRIATI   = 0
        this.INVCNDAMTNOT = arr((this.INVCNDQTY*this.DNETPRINOT),10^(-this.APARENT.CUR_DECNBR))
        this.INVCNDAMTATI = 0
      Endif
    Else
      #--It is not the QTY, but the AMTNOT/AMTATI that has to drive the calculation
      this.INVCNDQTY = 0
      #TODO CPO
    Endif
    this.IS_PROP_CHG=[V]CST_ANO
  Endif

Return
#---------------------------------------------------------------
$PROPAGATE_VCRINVCNDLIN_VCRTYP
  #--Here, only executed if DO_PROPAGATE=[v]cst_AYES
  If this.DO_PROPAGATE=[V]CST_ANO : Return : Endif

  If find(this.VCRTYP,10)>0
    #--For Orders, the SEQORI is mandatory
    [L]ASTATUS = fmet this.ASETATTRIBUTE("VCRSEQORI" ,"$isMandatory","true")
  Else
    [L]ASTATUS = fmet this.ASETATTRIBUTE("VCRSEQORI" ,"$isMandatory","false")
  Endif
Return
#---------------------------------------------------------------

