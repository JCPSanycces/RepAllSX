#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
#########################################################################
###
### Generates digital signature regarding French anti-fraud law
### SIH should have the current record to sign
###
#########################################################################
#########################################################################
$SIGN_SIH

Local Char     MESTOSIGN(255)(3)
Local Shortint CUR_MES_IDX

Gosub BUILD_MESSAGE_SIH

Gosub GENERATE_SIGNATURE

If DIG_SIGNATURE(0) <> ""
  Gosub SAVE_SIGNATURE
Else
  GOK = 0
  GMESSAGE = OUT_MESSAGE
  If GTRACE <> ""
      Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  Endif
Endif

Return
#########################################################################
#########################################################################
$BUILD_MESSAGE_SIH

If !clalev([F:CPY]) : Local File COMPANY    [CPY] : Endif
If !clalev([F:BPA]) : Local File BPADDRESS  [BPA] : Endif
If !clalev([F:DKF]) : Local File DKSDATAFRA [DKF] : Endif

Local Integer I
Local Char    DSTIMESTAMP(30)

Raz [F:DKF]
[F:DKF]KEYCODE = "FRADSI"
[F:DKF]ORIDOC = 1
[F:DKF]KEYVER = 1
[F:DKF]DOCTYP = [F:SIH]SIVTYP
[F:DKF]CPY    = [F:SIH]CPY
[F:DKF]FCY    = [F:SIH]FCY

DSTIMESTAMP = format$("D:YYYYMMDDhhmmss",date$)

For I = 0 To dim ([F:SIH]AMTTAX)-1
  If [F:SIH]AMTTAX(I)<>0 or [F:SIH]BASTAX(I)<>0
    [F:DKF]AMTTAX(I) = [F:SIH]AMTTAX(I)
    [F:DKF]BASTAX(I) = [F:SIH]BASTAX(I)
    Call ADD_VAL(num$([F:SIH]BASTAX(I))+":"+num$([F:SIH]AMTTAX(I))+"|",MESTOSIGN,CUR_MES_IDX)
  Endif
Next
[F:DKF]ACCDAT = [F:SIH]ACCDAT
[F:DKF]AMTATI = [F:SIH]AMTATI
Call ADD_VAL(num$([F:SIH]AMTATI)+"|",MESTOSIGN,CUR_MES_IDX)

[F:DKF]DSIDATTIM = DSTIMESTAMP
Call ADD_VAL(DSTIMESTAMP+"|",MESTOSIGN,CUR_MES_IDX)

[F:DKF]DOCNUM = [F:SIH]NUM
Call ADD_VAL([F:SIH]NUM+"|",MESTOSIGN,CUR_MES_IDX)

[F:DKF]SNS = [F:SIH]SNS
If [F:SIH]SNS = 1
  Call ADD_VAL("FACTURE|",MESTOSIGN,CUR_MES_IDX)
Else
  Call ADD_VAL("AVOIR|",MESTOSIGN,CUR_MES_IDX)
Endif
#Issue 86309 – 2018-08-14  by MADOR - Digital signature log trace
Call LEC_CPY([F:SIH]CPY) From CPTLEC
[F:DKF]CPYNAM = [F:CPY]CPYNAM
#Issue end
Call ADD_VAL([F:CPY]CPYNAM+"|",MESTOSIGN,CUR_MES_IDX)

Filter [F:BPA] Where [F:BPA]BPANUM = [F:CPY]CPY & [F:BPA]BPAADDFLG = 2 & [F:BPA]BPATYP = 2
Read [F:BPA] First
If !fstat
  [F:DKF]CPYPOSCOD = [F:BPA]POSCOD
  Call ADD_VAL([F:BPA]POSCOD + "|",MESTOSIGN,CUR_MES_IDX)
Endif

[F:DKF]CPYEECNUM = [F:CPY]EECNUM
Call ADD_VAL([F:CPY]EECNUM+"|",MESTOSIGN,CUR_MES_IDX)

[F:DKF]BPR       = [F:SIH]BPR
[F:DKF]BPRNAM(0) = [F:SIH]BPRNAM(0)
[F:DKF]BPRNAM(1) = [F:SIH]BPRNAM(1)
Call ADD_VAL([F:SIH]BPRNAM(0)+string$([F:SIH]BPRNAM(1)<>""," "+[F:SIH]BPRNAM(1))+"|",MESTOSIGN,CUR_MES_IDX)

[F:DKF]POSCOD = [F:SIH]POSCOD
Call ADD_VAL([F:SIH]POSCOD,MESTOSIGN,CUR_MES_IDX)

[F:DKF]MES(0) = MESTOSIGN(0)
[F:DKF]MES(1) = MESTOSIGN(1)
[F:DKF]MES(2) = MESTOSIGN(2)

Return
#########################################################################
#########################################################################
$SIGN_GAS

Local Char     MESTOSIGN(255)(3)
Local Char     JOUDES(GLONDES)
Local Char     AUXLEG(GLONADI)
Local Shortint CUR_MES_IDX
Local Integer  LEDT

If !clalev([F:BPR]) : Local File BPARTNER   [BPR] : Endif
If !clalev([F:DKF]) : Local File DKSDATAFRA [DKF] : Endif
If !clalev([F:DAE]) : Local File GACCENTRYD [DAE] : Endif
If !clalev([F:JOU]) : Local File GJOURNAL   [JOU] : Endif

Call LECLEDMAIN(1, [F:HAE]CPY, [L]LEDT) From CPTDIV
If [F:HAE]FNLPSTNUM([L]LEDT-1) = "" : Return : Endif

Read [F:DKF]DKF0 = "FRADSI";2;[F:HAE]TYP;[F:HAE]NUM;1
If !fstat : Return : Endif

Call LEC_CPY([F:HAE]CPY) From CPTLEC
Call LEC_JOU([F:HAE]JOU) From CPTLEC
If GNBLEG=1 : AUXLEG = GDOSLEG(1) : Else : AUXLEG = [F:JOU]LEG : Endif
Call LECTEXTRA([L]JOUDES,"GJOURNAL","DESTRA",[F:HAE]JOU,[L]AUXLEG) From ATEXTRA

For [F:DAE] Where [F:DAE]NUM = [F:HAE]NUM & [F:DAE]TYP = [F:HAE]TYP & [F:DAE]LEDTYP = [L]LEDT

  Gosub BUILD_MESSAGE_GAS

  Gosub GENERATE_SIGNATURE

  If DIG_SIGNATURE <> ""
      Gosub SAVE_SIGNATURE
  Else
    GOK = 0
    GMESSAGE = OUT_MESSAGE
    If GTRACE <> ""
        Call ECR_TRACE(GMESSAGE,1) From GESECRAN
    Endif
  Endif

Next

Return
#########################################################################
#########################################################################
$BUILD_MESSAGE_GAS

Raz [F:DKF]
[F:DKF]KEYCODE = "FRADSI"
[F:DKF]ORIDOC = 2
[F:DKF]KEYVER = 1
[F:DKF]DOCTYP = [F:HAE]TYP
[F:DKF]CPY    = [F:HAE]CPY

[L]MESTOSIGN = ""
[L]CUR_MES_IDX = 0

[F:DKF]JOU = [F:HAE]JOU
Call ADD_VAL([F:HAE]JOU+"|",MESTOSIGN,CUR_MES_IDX)

[F:DKF]JOUDES = [L]JOUDES
Call ADD_VAL([L]JOUDES+"|",MESTOSIGN,CUR_MES_IDX)

[F:DKF]FNLPSTNUM = [F:HAE]FNLPSTNUM([L]LEDT-1)
Call ADD_VAL([F:HAE]FNLPSTNUM([L]LEDT-1)+"|",MESTOSIGN,CUR_MES_IDX)

[F:DKF]ACCDAT = [F:HAE]ACCDAT
Call ADD_VAL(format$("D:YYYYMMDD",[F:HAE]ACCDAT)+"|",MESTOSIGN,CUR_MES_IDX)

[F:DKF]ACC = [F:DAE]ACC
Call ADD_VAL([F:DAE]ACC+"|",MESTOSIGN,CUR_MES_IDX)

[F:DKF]BPR = [F:DAE]BPR
Call ADD_VAL([F:DAE]BPR+"|",MESTOSIGN,CUR_MES_IDX)

If [F:DAE]BPR <> ""
  If [F:BPR]BPRNUM <> [F:DAE]BPR
    Read [F:BPR]BPR0 = [F:DAE]BPR
  Endif
Endif
[F:DKF]BPRNAM(0) = [F:BPR]BPRNAM(0)
[F:DKF]BPRNAM(1) = [F:BPR]BPRNAM(1)
Call ADD_VAL([F:BPR]BPRNAM(0)+string$([F:BPR]BPRNAM(1)<>""," "+[F:BPR]BPRNAM(1))+"|",MESTOSIGN,CUR_MES_IDX)

[F:DKF]DOCNUM = [F:HAE]NUM
Call ADD_VAL([F:HAE]NUM+"|",MESTOSIGN,CUR_MES_IDX)

[F:DKF]LIN = [F:DAE]LIN
Call ADD_VAL(num$([F:DAE]LIN)+"|",MESTOSIGN,CUR_MES_IDX)

[F:DKF]DES = string$([F:DAE]DES<>"", [F:DAE]DES)+string$([F:DAE]DES="","NA")
Call ADD_VAL(string$([F:DAE]DES<>"", [F:DAE]DES)+string$([F:DAE]DES="","NA")+"|",MESTOSIGN,CUR_MES_IDX)

[F:DKF]AMTLED = [F:DAE]AMTLED
Call ADD_VAL(func GET_MONFLD([F:DAE]AMTLED)+"|",MESTOSIGN,CUR_MES_IDX)

[F:DKF]SNS = [F:DAE]SNS
Call ADD_VAL(string$([F:DAE]SNS=-1,"-1")+string$([F:DAE]SNS=1,"+1")+"|",MESTOSIGN,CUR_MES_IDX)

[F:DKF]FNLPSTDAT = [F:HAE]FNLPSTDAT([L]LEDT-1)
Call ADD_VAL(format$("D:YYYYMMDD",[F:HAE]FNLPSTDAT([L]LEDT-1))+"|",MESTOSIGN,CUR_MES_IDX)

[F:DKF]AMTCUR = [F:DAE]AMTCUR*[F:DAE]SNS
Call ADD_VAL(string$([F:DAE]CUR<>[F:CPY]ACCCUR, func GET_MONFLD([F:DAE]AMTCUR*[F:DAE]SNS))+"|",MESTOSIGN,CUR_MES_IDX)

[F:DKF]CUR = [F:DAE]CUR
Call ADD_VAL(string$([F:DAE]CUR<>[F:CPY]ACCCUR, [F:DAE]CUR)+"|",MESTOSIGN,CUR_MES_IDX)

[F:DKF]FCY = [F:DAE]FCYLIN
Call ADD_VAL([F:DAE]FCYLIN,MESTOSIGN,CUR_MES_IDX)

[F:DKF]MES(0) = MESTOSIGN(0)
[F:DKF]MES(1) = MESTOSIGN(1)
[F:DKF]MES(2) = MESTOSIGN(2)

Return
#########################################################################
#########################################################################
Funprog GET_MONFLD(MON_VAL)
Value Decimal MON_VAL

End vireblc(format$("N:12.2",ar2(MON_VAL)),2)
#########################################################################
#########################################################################
Subprog ADD_VAL(VAL_TO_ADD,MESSAGE,IDX)
Value    Char     VAL_TO_ADD
Variable Char     MESSAGE
Variable Shortint IDX

If len(MESSAGE(IDX)+VAL_TO_ADD)>255
  IDX += 1
Endif

MESSAGE(IDX)+=VAL_TO_ADD

End
#########################################################################
#########################################################################
$GENERATE_SIGNATURE

Local Char    MODULE(100)  : MODULE   = 'bundle-sage-fr/frLegislation'
Local Char    FONCTION(30) : FONCTION = 'generateSignature'
Local Char    MODE(10)     : MODE     = 'wait'
Local Char    RETURNS(30)
Local Clbfile RESHEAD(0)
Local Clbfile RESBODY(0)
Local Integer STATUSCODE
Local Char    DIG_SIGNATURE(250)(2)
Local Clbfile OUT_VAL
Local Char    OUT_CODE(10)
Local Char    OUT_MESSAGE(255)

#------- data object -------
Local Clbfile DATA(0) :
DATA = '{'
Append DATA, '"message": "' + MESTOSIGN(0) + MESTOSIGN(1) + MESTOSIGN(2) + '"'
Append DATA, '}'
#------- data object -------

#------- context object -------
Local Char PROP02(255) : PROP02 = "VVRDUBMGET0WLzUxIkcHU1VXVDEWFwIG"
PROP02 = num$(len(PROP02))+"-"+PROP02
PROP02 = func BYTOP(PROP02,mid$(MESTOSIGN,6,45))
Local Clbfile CTX(0) : CTX = '{'
Append CTX, '"pvKeyName": "",'
Append CTX, '"operation": "generateSignature",'
Append CTX, '"prop01": "",'
Append CTX, '"prop02": "'+PROP02+'"'
Append CTX, '}'
#------- context object -------

#------- options object -------
Local Char DEBUGMODE(10) : DEBUGMODE = 'false'
If GTEST = 1 : DEBUGMODE = 'true' : Endif
Local Clbfile OPT(0) : OPT = '{'
Append OPT, '"debugMode": '+DEBUGMODE
Append OPT, '}'
#------- options object -------

Local Clbfile ARGUMENTS(0)
ARGUMENTS = DATA + ',' + CTX + ',' + OPT

STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, MODE, ARGUMENTS, '', 0, RETURNS, '0', RESHEAD, RESBODY)

If STATUSCODE = 200
  [L]OUT_CODE = func AJSONLIB.GET_PROP(RESBODY,"code")
  If [L]OUT_CODE = "0"
    [L]OUT_VAL = func AJSONLIB.GET_PROP(RESBODY,"value")
    Setlob [L]DIG_SIGNATURE With [L]OUT_VAL
  Else
    [L]OUT_MESSAGE = func AJSONLIB.GET_PROP(RESBODY,"message")
  Endif
Else
  [L]OUT_MESSAGE = num$(STATUSCODE)+": " + func AJSONLIB.GET_PROP(RESHEAD,"message")
Endif

Return
#########################################################################
#########################################################################
$VERIFY_SIGNATURE

Local Char    MODULE(100)  : MODULE   = 'bundle-sage-fr/frLegislation'
Local Char    FONCTION(30) : FONCTION = 'verifyDigitalSignature'
Local Char    MODE(10)     : MODE     = 'wait'
Local Char    RETURNS(30)
Local Clbfile RESHEAD(0)
Local Clbfile RESBODY(0)
Local Integer STATUSCODE
Local Clbfile OUT_VAL
Local Char    OUT_CODE(10)
Local Char    OUT_MESSAGE(255)


#------- data object -------
Local Clbfile DATA(0) :
DATA = '{'
Append DATA, '"message": "' + MESTOSIGN(0) + MESTOSIGN(1) + MESTOSIGN(2) + '", '
Append DATA, '"digSign": "' + [L]DIG_SIGNATURE(0) + [L]DIG_SIGNATURE(1) + '"'
Append DATA, '}'
#------- data object -------
#------- context object -------
Local Clbfile CTX(0)
CTX = '{'
Append CTX, '"pvKeyName": "",'
Append CTX, '"operation": "verifySignature",'
Append CTX, '"prop01": "",'
Append CTX, '"prop02": ""'
Append CTX, '}'
#------- context object -------

#------- options object -------
Local Char DEBUGMODE(10) : DEBUGMODE = 'false'
If GTEST = 1 : DEBUGMODE = 'true' : Endif
Local Clbfile OPT(0) : OPT = '{'
Append OPT, '"debugMode": '+DEBUGMODE
Append OPT, '}'
#------- options object -------

Local Clbfile ARGUMENTS(0)
ARGUMENTS = DATA + ',' + CTX + ',' + OPT

STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, MODE, ARGUMENTS, '', 0, RETURNS, '0', RESHEAD, RESBODY)

If STATUSCODE = 200
  [L]OUT_CODE = func AJSONLIB.GET_PROP(RESBODY,"code")
  If [L]OUT_CODE = "0"
    [L]OUT_VAL = func GET_LOGICAL(RESBODY,"value")
  Else
    [L]OUT_MESSAGE = func AJSONLIB.GET_PROP(RESBODY,"message")
  Endif
Else
  [L]OUT_MESSAGE = num$(STATUSCODE)+": " + func AJSONLIB.GET_PROP(RESHEAD,"message")
Endif

Return
#########################################################################
#########################################################################
$SAVE_SIGNATURE

[F:DKF]DIGSIGN(0) = DIG_SIGNATURE(0)
[F:DKF]DIGSIGN(1) = DIG_SIGNATURE(1)
Write [F:DKF]
If fstat
  GOK = 0
  GMESSAGE = mess(13,7711,1)+" (fstat="+num$(fstat)+")."
Endif

Return
#########################################################################
#########################################################################
Funprog DSFRA(ORI, CPY)
Value Char ORI
Value Char CPY

Local Integer RETVAL : RETVAL = 0
If !clalev([F:CPY]) : Local File COMPANY [F:CPY] : Endif

Call LEC_CPY([L]CPY) From CPTLEC

If [F:CPY]LEG = "FRA"
  Case ORI
    When "SIH"
      If func AFNC.ACTIV("DSFR") & func AFNC.PARAM("DSFRAINV",CPY)="2"
        RETVAL = 1
      Endif
    When "GAS"
      If func AFNC.ACTIV("DSFR") & func AFNC.PARAM("DSFRAGL",CPY)="2"
        RETVAL = 1
      Endif
  Endcase
Endif

End RETVAL
#########################################################################
#########################################################################
###
### Encode functions
###
#########################################################################
#########################################################################
### Two strings - starting point
#########################################################################
Funprog BYTOP(STI1, STI2)
Value    Char    STI1
Value    Char    STI2

Local Char    BYS(255)
Local Clbfile CLBO
Local Clbfile CLBOUT
Local Shortint K, W

K = 1
For W = 1 To len(STI1)
  If K > len(STI2) : K = 1 : Endif
  BYS = func INTXOR(ascii(mid$(STI1,W,1)),ascii(mid$(STI2,K,1)))
  K += 1
  If len(BYS) < 8 : BYS = string$(8-len(BYS),"0")+BYS: Endif
  Append CLBO, BYS
Next

CLBOUT = func BITSTR2B64(CLBO)

End CLBOUT
#########################################################################
#########################################################################
### Xor of 2 integers - returns the resulting integer
#########################################################################
Funprog INTXOR(BYI1, BYI2)
Value    Integer BYI1
Value    Integer BYI2

Local Char     BYS(255)
Local Shortint J, D

Local Integer BI1
Local Integer BI2

Local Char BIS1(255)
Local Char BIS2(255)

BI1 = func INT_TO_BIN(BYI1)
BI2 = func INT_TO_BIN(BYI2)

D = max(len(num$(BI1)),len(num$(BI2)))

BIS1 = format$("N0:"+num$(D), BI1)
BIS2 = format$("N0:"+num$(D), BI2)

For J = 1 To D
  BYS += num$(val(mid$(BIS1,J,1)) xor val(mid$(BIS2,J,1)))
Next

End BYS
#########################################################################
#########################################################################
### b64 encode - input as string of 0's and 1's
#########################################################################
Funprog BITSTR2B64(CLBIN)
Value    Clbfile CLBIN

Local Integer K, I, J, INT64, INT64B
Local Char    STR6BIT(6)
Local Clbfile CLBOUT

If mod(len(CLBIN),8) <> 0 or len(CLBIN) = 0 : Goto END_BITSTR2B64 : Endif
K = mod(len(CLBIN),6)

If K <> 0
  Append CLBIN, string$(6-K,"0")
Endif

K = 0
I = 0
While 6*I<len(CLBIN)
  STR6BIT = mid$(CLBIN, K+1, 6)
  I += 1
  K = 6*I
  INT64  = 0
  INT64B = 0
  INT64 = func BIN_TO_INT(val(STR6BIT))

  If INT64>=0 & INT64<=25
    INT64B = INT64 + 65
  Elsif INT64>25 & INT64<=51
    INT64B = INT64 + 71
  Elsif INT64>51 & INT64<=61
    INT64B = INT64 - 4
  Elsif INT64=62
    INT64B=43
  Elsif INT64=63
    INT64B=47
  Endif

  Append CLBOUT, chr$(INT64B)
Wend

K = mod(I,4)
If K > 0
  Append CLBOUT, string$(4-K,"=")
Endif

$END_BITSTR2B64
End CLBOUT
#########################################################################
#########################################################################
Funprog INT_TO_BIN(K)
Value Integer K

Local Integer RET

Case K
    When 0
        RET = 0
    When 1
        RET = 1
    When Default
        RET = mod(K,2) + 10 * func INT_TO_BIN(K/2)
Endcase

End RET
#########################################################################
#########################################################################
Funprog BIN_TO_INT(K)
Value Integer K

Local Integer RET, N, REM, I
While K<>0
  REM = mod(K,10)
  K = K/10
  RET += REM*2^I
  I+=1
Wend

End RET
#########################################################################
#########################################################################
Funprog GET_LOGICAL(JSONSTRING,VARNAME)
#Issue 86309 – 2018-08-14  by MADOR - Digital signature log trace
Value Clbfile JSONSTRING
Value Char VARNAME
Local Integer I,J
  I=instr(1,JSONSTRING,'"'+VARNAME+'"')
  If I
    I=instr(I+len(VARNAME)+2,JSONSTRING,":")
    If I
      J=instr(I+1,JSONSTRING,',')
      If J
        End seg$(JSONSTRING,I+1,J-1)
      Endif
    Endif
  Endif
#Issue end
End ""
#########################################################################
#########################################################################

