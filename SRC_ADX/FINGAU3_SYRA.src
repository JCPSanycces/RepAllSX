#<AdxTL>@(#)7.0.0.0 $Revision$
##############################################################################################################
# ROUTINES ABOUT AUTOMATIC JOURNALS
##############################################################################################################
#
# CRE_ACC : Creates account
# CTL_PYR : Controls linked to a reference pyramid defined in the chart of accounts
#
# Private routines :
# _CLASS  : Initialization of account class
##############################################################################################################


########################################################################################################
## CRE_ACC
########################################################################################################
#**
#* Account creation
#*
#* @param ACTX     Context
#* @param COMPANY  Company
#* @param COA      Chart of accounts
#* @param ACC      Accounts
#* @param DES      Description
#* @param TVT      Tax
#* @param ERRMES   Error message
#*!
Funprog CRE_ACC(ACTX,COMPANY,COA,ACC,DES,TVT,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     COMPANY       : # Company
Value    Char     COA()         : # Chart of accounts
Value    Char     ACC()         : # Accounts
Value    Char     DES()         : # Description
Value    Char     TVT()         : # Tax
Variable Char     ERRMES()      : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

#
Local Integer I, J, DUPLI, ILED, NBRLED, FINDACC
Local Char    LSTLED(GLONLED)(1..len(mess(0,2644,1))), LSTCUR(GLONCUR)(1..len(mess(0,2644,1))), COADEN(GLONCOA)
#

If adxtyp=33 | !clalev([F:GAC])  : Local File =ACTX.ACPT.TABCPT+"GACCOUNT"   [GAC]  : Endif
If adxtyp=33 | !clalev([F:GAC2]) : Local File =ACTX.ACPT.TABCPT+"GACCOUNT"   [GAC2] : Endif
If adxtyp=33 | !clalev([F:GRY])  : Local File =ACTX.ACPT.TABCPT+"GACCGRUPYM" [GRY]  : Endif
If adxtyp=33 | !clalev([F:COA])  : Local File =ACTX.ACPT.TABCPT+"GCOA"       [COA]  : Endif
If adxtyp=33 | !clalev([F:CLS])  : Local File =ACTX.ACPT.TABCPT+"GACCCLS"    [CLS]  : Endif
If adxtyp=33 | !clalev([F:GCF])  : Local File =ACTX.ACPT.TABCPT+"GACCDEF"    [GCF]  : Endif
If adxtyp=33 | !clalev([F:GCD])  : Local File =ACTX.ACPT.TABCPT+"GACCDIM"    [GCD]  : Endif
If adxtyp=33 | !clalev([F:LED])  : Local File =ACTX.ACPT.TABCPT+"GLED"       [LED]  : Endif


If ACTX.AFOLD.AMODULE(2)=2      #** Instead of  GCOMPTA<>3
 If adxtyp=33 | !clalev([F:PBS])   : Local File =ACTX.ACPT.TABCPT+"GAPARBSE"    [PBS]  : Endif
Endif

[L]ASTATUS = func CTL_PYR(ACTX,COA,ACC,1,0,ERRMES)
If [L]ASTATUS=[V]CST_AERROR : End [L]ASTATUS : Endif

If adxlog
 Gosub TR1
Else
 Trbegin [GAC]
 Gosub TR1
 If [L]ASTATUS<>[V]CST_AOK
  Rollback
  End [L]ASTATUS
 Else
  Commit
  [L]ASTATUS = fmet ACTX.ASETERROR("",mess(91,107,1)-[L]COA-[L]ACC-[L]DES,[V]CST_AINFO)
 Endif
Endif

End [L]ASTATUS


$TR1

# Try to find a same account
DUPLI   = 0
FINDACC = 0
For I=len([L]ACC) To 1 Step -1
 Filter [GAC] Where [F]COA=[L]COA & [F]ACC>=left$([L]ACC,I) & SAC<>2
 For [GAC]GAC0 : FINDACC=1 :  Break : Next
 If [L]FINDACC & left$([F:GAC]ACC,I)=left$([L]ACC,I)
  DUPLI = 1 : Break
 Endif
Next I
Filter [GAC]
If !DUPLI
 Raz [F:GAC]
Endif

# Updating fields
[F:GAC]COA    = [L]COA
[F:GAC]ACC    = [L]ACC
[F:GAC]SAC    = 1

# Account Class initialization (If the data is a duplication, the origin Account Class must be saved)
If  [F:GAC]CLSCOD=""
 [F:GAC]CLSCOD = func _CLASS([L]COA,[L]ACC)
Endif
If [F:GAC]CLSCOD=""
 Call LEC_COA([L]COA) From CPTLEC
 Filter [CLS] Where LEG=[F:COA]LEGCLS Order By Key CLS0 Desc
 For [CLS]CLS0
  [F:GAC]CLSCOD=[F:CLS]CLSCOD : Break
 Next
 Filter [CLS]
Endif

# Reporting Codes initialization
If ACTX.AFOLD.AMODULE(2)=2      #**  Instead of GCOMPTA<>3
 For J=0 To dim([F:GAC]RPTCODDEB)-1
  For I=len([L]ACC) To 1 Step -1
   Read [PBS]PBS0 = [L]COA ; num$(J+1) ; left$([L]ACC,I)
   If fstat=[V]CST_AOK
    [F:GAC]RPTCODDEB(J) = [F:PBS]CODDEB
    [F:GAC]RPTCODCDT(J) = [F:PBS]CODCDT
    Break
   Endif
  Next I
 Next J
Endif

# Default accounts initialization
For I=0 To [F:GAC]COANBR-1
 [F:GAC]OTHCOA(I) = ""
 [F:GAC]DEFACC(I) = ""
 [F:GAC]SCRACC(I) = ""
Next
[F:GAC]COANBR = 0
Call GET_LSTLED(ACTX,COMPANY,NBRLED,LSTLED,LSTCUR,ERRMES) From FINACM_SYRA
For J = 1 To NBRLED
 ILED = fmet ACTX.ACACHE.LED.AGETINDEX(LSTLED(J))
 If ILED = [V]CST_ANOTDEFINED : Break : Endif
 [L]COADEN = fmet ACTX.ACACHE.LED.AGETVALCHAR(LSTLED(J),"LEDCOA")
 If [L]COA<>[L]COADEN
  For I=len([L]ACC) To 1 Step -1
   Read [GCF]GCF0 = [L]COA ; [L]COADEN ; left$([L]ACC,I)
   If fstat=[V]CST_AOK & [F:GAC]COANBR<dim([F:GAC]OTHCOA)
    [F:GAC]OTHCOA([F:GAC]COANBR) = [F:GCF]COADEN
    [F:GAC]DEFACC([F:GAC]COANBR) = [F:GCF]ACC
    [F:GAC]SCRACC([F:GAC]COANBR) = "*"
    [F:GAC]COANBR += 1
    Break
   Endif
  Next I
 Endif
Next ILED

# Default dimension types initialization
For I=0 To [F:GAC]DACDIENBR-1
 [F:GAC]DIE(I) = ""
 [F:GAC]CCEDEF(I) = ""
Next
[F:GAC]DACDIENBR = 0
For [GCD]GCD0 Where [F]COA=[L]COA
 If left$([F:GAC]ACC,len([F:GCD]ACCSTR))=[F:GCD]ACCSTR
  I = find([F:GCD]DIE,[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
  If !I
   If [F:GAC]DACDIENBR<dim([F:GAC]DIE)
    [F:GAC]DIE([F:GAC]DACDIENBR)    = [F:GCD]DIE
    [F:GAC]CCEDEF([F:GAC]DACDIENBR) = [F:GCD]CCE
    [F:GAC]DACDIENBR += 1
   Endif
  Elsif [F:GAC]CCEDEF(I-1)=""
   [F:GAC]CCEDEF(I-1) = [F:GCD]CCE
  Endif
 Endif
Next

# Others re-initialization
[F:GAC]ACS    = ""
[F:GAC]ACCSHO = ""
[F:GAC]SUBACC = ""
[F:GAC]SUBBPR = ""
[F:GAC]FCY    = ""
[F:GAC]VLYSTR = [0/0/0]
[F:GAC]VLYEND = [0/0/0]
If [F:GAC]FLGVAT>1 : [F:GAC]VAT = [L]TVT : Endif

Call FLDCRE("GAC") From OBJDIV    #** New call

#If adxtyp<>33
# Call MAJTEXTRA([F:GAC]DES,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
# Call MAJTEXTRA([F:GAC]DESSHO,"GACCOUNT","DESSHO",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
#Endif
Call MAJTEXTRALAN(ACTX,[L]DES,"GACCOUNT","DESTRA",ACTX.LAN,[F:GAC]COA,[F:GAC]ACC,[L]ASTATUS) From ASYRSUB
Call MAJTEXTRALAN(ACTX,[F:GAC]ACC,"GACCOUNT","SHOTRA",ACTX.LAN,[F:GAC]COA,[F:GAC]ACC,[L]ASTATUS) From ASYRSUB


# Others initialization if the data is NOT a duplication
If !DUPLI
 [F:GAC]CEN = 1
 [F:GAC]DAS = 1
 [F:GAC]DIF = 1
 [F:GAC]FLGVAT = 1
 Call LEC_COA([L]COA) From CPTLEC
 Call LEC_CLS([F:COA]LEGCLS,[F:GAC]CLSCOD) From CPTLEC
 [F:GAC]SNSBLC = [F:CLS]DEFSNS
 [F:GAC]SNSDEF = [F:CLS]DEFSNS
Endif

# Creating of account
Write [GAC]
If fstat<>[V]CST_AOK
 Call FSTA("GAC",0,ERRMES) From GLOCK_SYRA
 [L]ASTATUS = [V]CST_AERROR : Return
Endif
Return


########################################################################################################
## CTL_PYR
########################################################################################################
#**
#* Controls linked to a reference pyramid defined in the chart of accounts
#*
#* @param ACTX   Context
#* @param COA    Chart of account
#* @param ACC    Account
#* @param FLGSAC Control Account
#* @param FCTGAC 1 = If the funprog is called from GESGAC / 0 = otherwise (here CPTAUTO)
#* @param ERRMES Error message
#*!
Funprog CTL_PYR(ACTX,COA,ACC,FLGSAC,FCTGAC,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Char     COA()       : # Chart of account
Value    Char     ACC()       : # Account
Value    Integer  FLGSAC      : # Control Account
Value    Integer  FCTGAC      : # 1 = If the funprog is called from GESGAC / 0 = otherwise (here CPTAUTO)
Variable Char     ERRMES()    : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK
If adxtyp=33 | !clalev([F:COA])  : Local File GCOA       [COA]  : Endif
Call LEC_COA([L]COA) From CPTLEC
If [F:COA]PYRREF="" : End [L]ASTATUS : Endif

If adxtyp=33 | !clalev([F:GRY])  : Local File GACCGRUPYM [GRY]  : Endif
If adxtyp=33 | !clalev([F:GAC2]) : Local File GACCOUNT   [GAC2] : Endif

#Local Char    GROUPE(GLONGRY)
#Local Integer RANG , NIVEAU

Local Integer I, OK

# Check Account Groups
For [GRY]GRY0(2) Where [F:GRY]PYM=[F:COA]PYRREF & left$([F:GRY]GRU,len([L]ACC))=[L]ACC
 # Account pyramid xxx : There is a group yyyy
 ERRMES = mess(38,113,1)-[F:COA]PYRREF-":"-mess(43,113,1)-[F:GRY]GRU
 [L]ASTATUS = [V]CST_AERROR : Break
Next
If [L]ASTATUS = [V]CST_AERROR : End [L]ASTATUS : Endif

# Check Control account (SAC field)
If [L]FLGSAC=2
 For I=len([L]ACC) To 1 Step-1
  fstat = [V]CST_AOK
  If [F:GAC2]COA<>[L]COA or [F:GAC2]ACC<>left$([L]ACC,I)
   Read [GAC2]GAC0 = [L]COA;left$([L]ACC,I)
  Endif
  If fstat=[V]CST_AOK & [F:GAC2]SAC<>2
   # There is an account
   ERRMES = mess(9,113,1)-[F:GAC2]ACC
   [L]ASTATUS = [V]CST_AERROR : Break
  Endif
 Next I
 If [L]ASTATUS = [V]CST_AERROR : End [L]ASTATUS : Endif
 For [GAC2]GAC0 Where COA=[L]COA & left$(ACC,len([L]ACC))=[L]ACC
  # There is an account
  ERRMES = mess(9,113,1)-[F:GAC2]ACC
  [L]ASTATUS = [V]CST_AERROR : Break
 Next
 If [L]ASTATUS = [V]CST_AERROR : End [L]ASTATUS : Endif
Else
 For I=len([L]ACC) To 1 Step -1
  fstat = [V]CST_AOK
  If [F:GAC2]COA<>[L]COA or [F:GAC2]ACC<>left$([L]ACC,I)
   Read [GAC2]GAC0 = [L]COA;left$([L]ACC,I)
  Endif
  If fstat=[V]CST_AOK
   If [F:GAC2]SAC=2
    # There is a control account
    ERRMES = mess(8,113,1)-[F:GAC2]ACC
    [L]ASTATUS = [V]CST_AERROR : Break
   Elsif [L]FCTGAC
    # There is an account
    [L]ASTATUS = fmet ACTX.ASETERROR("",mess(9,113,1)-[F:GAC2]ACC,[V]CST_AWARNING)
    Break
   Endif
  Endif
 Next I
Endif
#** SYRA => No Stop for a Warning
#If !OK : End [L]ASTATUS : Endif
#*!


# Check Account Groups
OK = 0
For I=len([L]ACC)-1 To 1 Step -1
 Read [GRY]GRY0(2) = [F:COA]PYRREF;left$([L]ACC,I)
 If fstat=[V]CST_AOK
  OK = 1
#  GROUPE = [F:GRY]GRU
#  NIVEAU = [F:GRY]LEV
#  RANG   = [F:GRY]PRNROW
  Break
 Endif
Next I
If !OK
 # Account pyramid xxx : There is no accumulation account starting with xxx
 ERRMES = mess(38,113,1)-[F:COA]PYRREF-":"-mess(44,113,1)-left$([L]ACC,2)
 [L]ASTATUS = [V]CST_AERROR : End [L]ASTATUS
Else
 If FCTGAC
#  K = find([F:COA]PYRREF,[M:GAC5]PYM(0..[M:GAC5]NRPYR-1))
#  If K=0
#   [M:GAC5]NRPYR += 1
#   K = [M:GAC5]NRPYR
#  Endif
#  [M:GAC5]PYM(K-1)    = [F:COA]PYRREF
#  [M:GAC5]GRU(K-1)    = GROUPE
#  [M:GAC5]LEV(K-1)    = NIVEAU
#  [M:GAC5]PRNROW(K-1) = RANG
#  [M:GAC5]FLGGES(K-1) = 1
#  Affzo [GAC5]
 Endif
Endif
End [L]ASTATUS


########################################################################################################
## _CLASS
########################################################################################################
#**
#* Initialization of account class
#*
#* @private
#* @param COA Chart of accounts
#* @param ACC Account
#*!
Funprog _CLASS(COA,ACC)
Value    Char     COA()       : # Chart of accounts
Value    Char     ACC()       : # Account

Local Char     CLS(GLONCLA)   : # Class
Local Integer  I,J

If adxtyp=33 | !clalev([F:COA])  : Local File GCOA       [COA]  : Endif
Call LEC_COA([L]COA) From CPTLEC

For I=len([L]ACC) To 1 Step -1
 J = find(left$([L]ACC,I),[F:COA]PFX(0..[F:COA]PFXNBR-1))
 If J
  [L]CLS = [F:COA]CLSCOD(J-1) :  Break
 Endif
Next
End [L]CLS
