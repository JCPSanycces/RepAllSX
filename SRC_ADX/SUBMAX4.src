#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion du masque MAX4
########################################
Subprog AS_NBXOPG
If nolign - 1 >= dim([M:MAX4]OPGNUM)
    End
Endif
If nolign > 0
    GIMAX4NOL = nolign - 1
    If GSZPREOPG <> [M:MAX4]OPGNUM(nolign - 1)
        GSZPREOPG = [M:MAX4]OPGNUM(nolign - 1)
        Call LOADOPGINF([M:MAX4]OPGNUM(nolign - 1)) From TRTMAX4
        Affzo [M:MAX4]
    Endif
Endif
End

########################################
Subprog C_NBXOPG
If nolign - 1 >= dim([M:MAX4]OPGNUM)
    End
Endif
If nolign > 0
    GIMAX4NOL = nolign - 1
    If GSZPREOPG <> [M:MAX4]OPGNUM(nolign - 1)
        GSZPREOPG = [M:MAX4]OPGNUM(nolign - 1)
        Call LOADOPGINF([M:MAX4]OPGNUM(nolign - 1)) From TRTMAX4
        Affzo [M:MAX4]
    Endif
Endif
End

