#<AdxTL>@(#)2.0.0.0 $Revision$
######################################################################################
######################################################################################
$ACTION

Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "FILTRE"     : Gosub FILTRE
  When "RAZCRE"     : Gosub RAZCRE
  When "INICRE"     : Gosub INICRE
  When "CREATION"   : Gosub CREATION
  When "MODIF"      : Gosub MODIF
  When "APRES_CRE"  : Gosub APRES_CRE
  When "APRES_MOD"  : Gosub APRES_MOD
  When "EXEBOUT"    : Gosub EXEBOUT
  When "LIENS"      : Gosub LIENS
  When "ANNULE"     : Gosub ANNULE
  When "MODIF"      : Gosub MODIF
  When "SETBOUT"    : Gosub SETBOUT
Endcase

Return
######################################################################################
######################################################################################
$OUVRE

If !clalev([F:CPY])   :  Local File COMPANY    [CPY]          : Endif
If !clalev([F:DVPB])  :  Local File DCLVATPORB [DVPB]         : Endif
If !clalev([F:DVPF])  :  Local File DCLVATPORF [DVPF]         : Endif
If !clalev([F:DVPL])  :  Local File DCLVATPORL [DVPL]         : Endif
If !clalev([F:DVPP])  :  Local File DCLVATPORP [DVPP]         : Endif
If !clalev([F:TCA])   :  Local File TABCOUAFF  [TCA]          : Endif
If !clalev([F:TCY])   :  Local File TABCOUNTRY [TCY]          : Endif

Local Char LNUM(GLONVCR)
Local Char SITE(GLONFCY)

Local Integer I, RCOUNT, STAT

Gosub DEC_COM_VARS From CALVATPOR

Return
######################################################################################
######################################################################################
$FILTRE

FILTSUP = "[F:DVPH]DCLTYP = 2"

Return
######################################################################################
######################################################################################
$RAZCRE

[M:DVPHA0]DCLTYP = 2

Return
######################################################################################
######################################################################################
$INICRE

Gosub GET_CPYVARS

Call LECTCA(2,OK) From SUBTCA
If fstat | !OK
  GERR=1 : GMESSAGE=mess(58,105,1)-mess(2,14,1)-mess(250,199,1) : Return
Endif
GMANCOU = [F:TCA]MANCOU(12)
GCPT    = [F:TCA]CODNUM(12)
STAT    = 0

If  GMANCOU <> 2 | (GMANCOU=2 & vireblc([M:DVPHA0]DCLNUM,2)="")
  Call NUMERO (GCPT,SITE,[F:DVPH]STRDAT,"",LNUM,STAT) From SUBANM
  If GOK>0 & STAT=0
      [F:DVPH]DCLNUM   = LNUM
      [M:DVPHA0]DCLNUM = LNUM
      Affzo [M:DVPHA0]DCLNUM
  Else
     Local Char MESSA(80)
     GMESSAGE=mess(60,199,1)-"("+GCPT+") : "
     Gosub MESSAGE From SUBANM
     GMESSAGE-=MESSA : GERR=1 : GOK=0 : Return
  Endif
Endif

Return
######################################################################################
######################################################################################
$EXEBOUT

Case BOUT
  When "1"
    Gosub RELIT From GOBJSUB
Endcase

Return
######################################################################################
######################################################################################
$LIENS

GSOCIETE = [F:DVPH]CPY

Gosub GET_CPYVARS

Gosub LOAD_FIELDS

Gosub LOAD_LISTS

[M:DVPHA0]CUR          = [F:CPY]ACCCUR

Call SHOW_HIDE_ANLOC ([M:DVPHA1]AN1LOC, [M:DVPHA1]AN2LOC)

Return
######################################################################################
######################################################################################
$LOAD_FIELDS

Raz [M:DVPHA2]
For [F:DVPF] Where [F:DVPF]DCLNUM = [M:DVPHA0]DCLNUM
  Assign "[M:DVPHA2]DCLFLD"+num$([F:DVPF]DCLPAG)+"("+num$(evalue("[M:DVPHA2]NBLIG"+num$([F:DVPF]DCLPAG)))+")" With [F:DVPF]DCLFLD
  Assign "[M:DVPHA2]AMT"+num$([F:DVPF]DCLPAG)   +"("+num$(evalue("[M:DVPHA2]NBLIG"+num$([F:DVPF]DCLPAG)))+")" With [F:DVPF]AMT
  Assign "[M:DVPHA2]NBLIG"+num$([F:DVPF]DCLPAG) With evalue("[M:DVPHA2]NBLIG"+num$([F:DVPF]DCLPAG)) + 1
Next

Return
######################################################################################
######################################################################################
$LOAD_LISTS

Raz [M:DVPHA3]
Filter [F:DVPL] Where [F:DVPL]DCLNUM = [F:DVPH]DCLNUM & [F:DVPL]LINTYP = 21 Order By Key DVPL0
For [F:DVPL]
  [M:DVPHA3]EECNUM([M:DVPHA3]NBLIG) = [F:DVPL]EECNUM
  #[M:DVPHA3]BPRNUM([M:DVPHA3]NBLIG) = [F:DVPL]BPRNUM
  [M:DVPHA3]AMTBAS([M:DVPHA3]NBLIG) = [F:DVPL]AMTBAS
  [M:DVPHA3]NBLIG                  += 1
Next
Filter [F:DVPL]

Raz [M:DVPHA4]
Filter [F:DVPL] Where [F:DVPL]DCLNUM = [F:DVPH]DCLNUM & [F:DVPL]LINTYP = 22 Order By Key DVPL0
For [F:DVPL]
  [M:DVPHA4]EECNUM([M:DVPHA4]NBLIG) = [F:DVPL]EECNUM
  #[M:DVPHA4]BPRNUM([M:DVPHA4]NBLIG) = [F:DVPL]BPRNUM
  [M:DVPHA4]AMTBAS([M:DVPHA4]NBLIG) = [F:DVPL]AMTBAS
  [M:DVPHA4]NBLIG                  += 1
Next

Filter [F:DVPL]

Return
######################################################################################
######################################################################################
$CREATION

Gosub COMMON_SAVE

Return
######################################################################################
######################################################################################
$MODIF

Gosub COMMON_SAVE

Return
######################################################################################
######################################################################################
$COMMON_SAVE

Gosub SAVE_FIELDS

Gosub SAVE_LISTS

Return
######################################################################################
######################################################################################
$SAVE_FIELDS

For I = 0 To [M:DVPHA2]NBLIG1-1
  Read [F:DVPF]DVPF0 = [M:DVPHA0]DCLNUM;1;[M:DVPHA2]DCLFLD1(I)
  If fstat
    [F:DVPF]DCLNUM = [M:DVPHA0]DCLNUM
    [F:DVPF]DCLPAG = 1
    [F:DVPF]DCLFLD = [M:DVPHA2]DCLFLD1(I)
    [F:DVPF]AMT    = [M:DVPHA2]AMT1(I)
    Write [F:DVPF]
  Else
    [F:DVPF]AMT = [M:DVPHA2]AMT1(I)
    Rewrite [F:DVPF]
  Endif
  If fstat
    GOK = 0 : Call FSTA("DVPF") From GLOCK : Break
  Endif
Next

If GOK=0 : Return : Endif

For I = 0 To [M:DVPHA2]NBLIG2-1
  Read [F:DVPF]DVPF0 = [M:DVPHA0]DCLNUM;2;[M:DVPHA2]DCLFLD2(I)
  If fstat
    [F:DVPF]DCLNUM = [M:DVPHA0]DCLNUM
    [F:DVPF]DCLPAG = 2
    [F:DVPF]DCLFLD = [M:DVPHA2]DCLFLD2(I)
    [F:DVPF]AMT    = [M:DVPHA2]AMT2(I)
    Write [F:DVPF]
  Else
    [F:DVPF]AMT = [M:DVPHA2]AMT2(I)
    Rewrite [F:DVPF]
  Endif
  If fstat
    GOK = 0 : Call FSTA("DVPF") From GLOCK : Break
  Endif
Next

If GOK=0 : Return : Endif

For I = 0 To [M:DVPHA2]NBLIG3-1
  Read [F:DVPF]DVPF0 = [M:DVPHA0]DCLNUM;3;[M:DVPHA2]DCLFLD3(I)
  If fstat
    [F:DVPF]DCLNUM = [M:DVPHA0]DCLNUM
    [F:DVPF]DCLPAG = 3
    [F:DVPF]DCLFLD = [M:DVPHA2]DCLFLD3(I)
    [F:DVPF]AMT    = [M:DVPHA2]AMT3(I)
    Write [F:DVPF]
  Else
    [F:DVPF]AMT = [M:DVPHA2]AMT3(I)
    Rewrite [F:DVPF]
  Endif
  If fstat
    GOK = 0 : Call FSTA("DVPF") From GLOCK : Break
  Endif
Next

Return
######################################################################################
######################################################################################
$SAVE_LISTS

#--- lists
[L]RCOUNT = 1
Delete [F:DVPL] Where [F:DVPL]DCLNUM = [M:DVPHA0]DCLNUM
If fstat=1 : GOK=-1 : GLOCK="$DVPL" : Return : Endif

For I = 0 To [M:DVPHA3]NBLIG-1
  [F:DVPL]DCLNUM = [M:DVPHA0]DCLNUM
  #[F:DVPL]RECTYP = 2
  [F:DVPL]LSTLIN = [L]RCOUNT
  [F:DVPL]EECNUM = [M:DVPHA3]EECNUM(I)
  #[F:DVPL]BPRNUM = [M:DVPHA3]BPRNUM(I)
  [F:DVPL]AMTBAS = [M:DVPHA3]AMTBAS(I)
  [F:DVPL]LINTYP = 21
  Write [F:DVPL]
  If fstat
    GOK = 0 : Call FSTA("DVPL") From GLOCK : Break
  Endif
  [L]RCOUNT += 1
Next

If GOK=0 : Return : Endif

For I = 0 To [M:DVPHA4]NBLIG-1
  [F:DVPL]DCLNUM = [M:DVPHA0]DCLNUM
  #[F:DVPL]RECTYP = 3
  [F:DVPL]LSTLIN = [L]RCOUNT
  [F:DVPL]EECNUM = [M:DVPHA4]EECNUM(I)
  #[F:DVPL]BPRNUM = [M:DVPHA4]BPRNUM(I)
  [F:DVPL]AMTBAS = [M:DVPHA4]AMTBAS(I)
  [F:DVPL]LINTYP = 22
  Write [F:DVPL]
  If fstat
    GOK = 0 : Call FSTA("DVPL") From GLOCK : Break
  Endif
  [L]RCOUNT += 1
Next

Return
######################################################################################
######################################################################################
$APRES_CRE

Gosub COMMON_APRESAV

Return
######################################################################################
######################################################################################
$APRES_MOD

Gosub COMMON_APRESAV

Return
######################################################################################
######################################################################################
$COMMON_APRESAV

[L]DCLNUM = [M:DVPHA0]DCLNUM

Call DEBTRANS From GLOCK
Trbegin [F:DVPF]

Gosub FIELD_TOTALS From CALVATPORA

If !GOK = 0
  Goto AB_APRESSAV
Endif

Commit

Gosub LOAD_FIELDS

Affzo [M:DVPHA2]
Affzo [M:DVPHA3]
Affzo [M:DVPHA4]

Return
######################################################################################
######################################################################################
$AB_APRESSAV

Rollback

Return
######################################################################################
######################################################################################
$ANNULE

Delete [F:DVPB] Where [F:DVPB]DCLNUM=[M:DVPHA0]DCLNUM
If fstat = 1 : GOK = -1 : GLOCK = "$DCLVATPORB" - [M:DVPHA0]DCLNUM : Return : Endif
Delete [F:DVPF] Where [F:DVPF]DCLNUM=[M:DVPHA0]DCLNUM
If fstat = 1 : GOK = -1 : GLOCK = "$DCLVATPORF" - [M:DVPHA0]DCLNUM : Return : Endif
Delete [F:DVPL] Where [F:DVPL]DCLNUM=[M:DVPHA0]DCLNUM
If fstat = 1 : GOK = -1 : GLOCK = "$DCLVATPORL" - [M:DVPHA0]DCLNUM : Return : Endif

Return
######################################################################################
######################################################################################
$SETBOUT

If GREP <> "" | !CLECUR
  Call  VIREBOUT(CHAINE,"1")  From GOBJET
Endif

Return
######################################################################################
######################################################################################
$GET_CPYVARS

If [F:CPY]CPY <> GSOCIETE
  Read [F:CPY]CPY0 = GSOCIETE
  If fstat : Raz [F:CPY] : Endif
Endif

GCURLEG = [F:CPY]LEG
SITE   = [F:CPY]MAIFCY
If SITE = "" : SITE = GSOCIETE : Endif #RMA * 102701

Return
######################################################################################
######################################################################################
Subprog SHOW_HIDE_ANLOC (AN1LOC, AN2LOC)
Value Integer AN1LOC
Value Integer AN2LOC

If [L]AN1LOC = 4
  Chgfmt [M:DVPHA2]NBLIG2 With "-P"
Else
  Chgfmt [M:DVPHA2]NBLIG2 With "N"
Endif
If [L]AN2LOC = 4
  Chgfmt [M:DVPHA2]NBLIG3 With "-P"
Else
  Chgfmt [M:DVPHA2]NBLIG3 With "N"
Endif

End
######################################################################################
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

GSOCIETE = VALEUR

Gosub GET_CPYVARS

[M:DVPHA0]CUR          = [F:CPY]ACCCUR
Affzo [M:DVPHA0]CUR

End
######################################################################################
######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()

If func AFNC.PARAM("PORVAT",VALEUR)<>"2"
  mkstat = 2
  GMESSAGE = func AFNC.MES2(mess(218,125,1), "PORVAT", mess(1,1,1))
Endif

End
######################################################################################
######################################################################################
Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR

[M:DVPHA1]HQRLOC = [F:DVPP]HQRLOC
[M:DVPHA1]AN1LOC = [F:DVPP]AN1LOC
[M:DVPHA1]AN2LOC = [F:DVPP]AN2LOC
[M:DVPHA1]DCLYEA = year([M:DVPHA0]STRDAT)

Call SHOW_HIDE_ANLOC ([M:DVPHA1]AN1LOC, [M:DVPHA1]AN2LOC)

Affzo [M:DVPHA1]

End
######################################################################################
######################################################################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR

Read [F:DVPP]DVPP0 = [M:DVPHA0]CPY;year(VALEUR)
If fstat
  mkstat = 2
  GMESSAGE = mess(13,7710,1)
  End
Endif

End
######################################################################################
######################################################################################
Subprog AM_AN1LOC(VALEUR)
Variable Integer VALEUR

Call SHOW_HIDE_ANLOC (VALEUR, [M:DVPHA1]AN2LOC)

End
######################################################################################
######################################################################################
Subprog AM_AN2LOC(VALEUR)
Variable Integer VALEUR

Call SHOW_HIDE_ANLOC ([M:DVPHA1]AN1LOC, VALEUR)

End
######################################################################################
######################################################################################
Subprog AS_AN1LOC(VALEUR)
Variable Integer VALEUR

For I = 1 To 3
  If I = [M:DVPHA1]HQRLOC | I = [M:DVPHA1]AN2LOC
    GMENLOC(I) = 1
  Else
    GMENLOC(I) = 0
  Endif
Next

GMENLOC(4) = 0 : # Non applicable OK

End
######################################################################################
######################################################################################
Subprog AS_AN2LOC(VALEUR)
Variable Integer VALEUR

For I = 1 To 3
  If I = [M:DVPHA1]HQRLOC | I = [M:DVPHA1]AN1LOC
    GMENLOC(I) = 1
  Else
    GMENLOC(I) = 0
  Endif
Next

GMENLOC(4) = 0 : # Non applicable OK

End
######################################################################################
######################################################################################

