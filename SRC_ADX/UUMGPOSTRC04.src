#<AdxTL>@(#)4.0.0.0 $Revision$
############################################################################
# UUMGPOSTRC04                                         Module Common Data  #
#                                                                          #
#              Post-migration of Open item                                 #
#                                                                          #
# Management of news fields : FIY/PER                                      #
#                                                                          #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPOSTRC04") From LECFIC
  Endif

  #Call RAZ_UUMGPOSTRC04(DOSSIER)
  Call MAJ_UUMGPOSTRC04(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End

########################################################################
Subprog RAZ_UUMGPOSTRC04(DOSSIER)
Value Char DOSSIER

Local Integer ERR
If [F:ADS]MODULE(8)<>2 : End : Endif

Call MIGRAZKEY (DOSSIER,"UUMGPOSTRC04",ERR) From TRTMIG

End

###################################################################################
Subprog MAJ_UUMGPOSTRC04(DOSSIER)
Value Char DOSSIER
Local Integer NBLUS, NBCOMMIT, ERR, OK

If [F:ADS]MODULE(8)<>2 or func DOSSUB.ISHISTFOLD(DOSSIER)
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC04",3,ERR) From TRTMIG : End
Endif

#----- Starting process  -----#
Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC04",2,ERR) From TRTMIG
#----- n°version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC04",7,ERR) From TRTMIG : End : Endif
If val(VERSION)>=GMIGX3VER60
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC04",3,ERR) From TRTMIG : End
Endif


Call ECR_TIME("UUMGPOSTRC04 Open items Process : Update GACCDUDATE - Fields : FIY/PER") From DOSSUB
Call ECR_TRACE("UUMGPOSTRC04 : Process Start on : "+DOSSIER,0) From GESECRAN

#--------------- Index addition  ----------#
Call MIGINDCRE (DOSSIER,"GACCDUDATE","CPY+DUDDAT+NUMDUD","","",0,ERR) From TRTMIG
If ERR
 Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC04",7,ERR) From TRTMIG : Goto FIN
Endif

#--------------- Opening of files  -----#
If clalev([F:DUD]) : Close File [DUD] : Endif
If clalev([F:DUD])  = 0 : Local File =DOSSIER+".GACCDUDATE"  [DUD]  : Endif      # Open item
If clalev([F:GCM])  = 0 : Local File =DOSSIER+".GACM"        [GCM]  : Endif      # Account core model
If clalev([F:CPY])  = 0 : Local File =DOSSIER+".COMPANY"     [CPY]  : Endif      # Company
If clalev([F:PER])  = 0 : Local File =DOSSIER+".PERIOD"      [PER]  : Endif      # Fiscal periods

#-----  Declaration of Variables
# Variables to Handle Loops Ruptures
Local Integer STOP, NB
Local Char CRITERE(250)
Local Char ACLE1(30), ACLE2(30), ACLE3(30), ACLE4(30)
Local Integer ICLE1, ICLE2, ICLE3
Local Date DCLE1

# Common variable declaration
Local Char COMPANY(GLONCPY)
Local Libelle LEDGENMAIN
Local Decimal EXERCICE, PERIODE
Local Date    DAT

Raz NBLUS, NBCOMMIT, STOP, CRITERE

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_TRC04
Raz NB
If STOP=1
 STOP = 2
 CRITERE = "[F:DUD]PER=0 & [F:DUD]CPY='"+ACLE1+"' & [F:DUD]DUDDAT=["+format$(GFMD,DCLE1)+"] & [F:DUD]NUMDUD>'"+ACLE2+"'"
Elsif STOP=2
 STOP = 3
 CRITERE = "[F:DUD]PER=0 & [F:DUD]CPY='"+ACLE1+"' & [F:DUD]DUDDAT>["+format$(GFMD,DCLE1)+"]"
Elsif STOP=3
 STOP = 0
 CRITERE = "[F:DUD]PER=0 & [F:DUD]CPY>'"+ACLE1+"'"
Else
 CRITERE = "[F:DUD]PER=0 & 1=1"
Endif

Trbegin [DUD]
GOK = 1

For [DUD]MIG(1) Where evalue(CRITERE)

 # By company - Reading of Main General Ledger
 [L]COMPANY = [F:DUD]CPY
 If [F:CPY]CPY<>[L]COMPANY
  Read [CPY]CPY0 =  [L]COMPANY
  # Non-existent Company
  If fstat : GOK = 0 : Call ERREUR("GACCDUDATE"-[L]COMPANY-mess(16,104,1),4) From DOSDIC : Break : Endif
 Endif
 If [F:CPY]ACM <> [F:GCM]GCM
  Read [F:GCM]GCM0 = [F:CPY]ACM
 Endif
 LEDGENMAIN = [F:GCM]GENLEDTYP

 For [DUD]MIG(2)

  # By due date - Reading of Fiscalyear and Fiscal Period
  [L]DAT = [F:DUD]DUDDAT
  Gosub GETPERSOC
  If [L]EXERCICE=0 or [L]PERIODE=0
   # Incorrect Period
   Call ECR_TRACE("GACCDUDATE"-[L]COMPANY-num$([L]LEDGENMAIN)-format$(GFMD,[L]DAT)-mess(10,116,1),-1) From GESECRAN : Goto NEXT1
  Endif


  For [DUD]MIG

   NBLUS += 1

   #--- New field assignation
   [F:DUD]FIY=[L]EXERCICE
   [F:DUD]PER=[L]PERIODE

   Rewrite [F:DUD]
   If fstat
    Call ECR_TRACE("File GACCDUDATE(NUMDUD)"-[F:DUD]NUMDUD+", Error ="-num$(fstat),1) From GESECRAN
    GOK=0 : Break 3
   Endif

   NBCOMMIT += 1
   NB+=1
   If NB>GMAXUPDTRS
    ACLE1 = [F:DUD]CPY
    DCLE1 = [F:DUD]DUDDAT
    ACLE2 = [F:DUD]NUMDUD
    STOP=1
    Break 3
   Endif
  Next
 $NEXT1
 Next
Next

If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGPOSTRC04",7,ERR) From TRTMIG
Else
  Commit
  Call MIGSTKPROGRESS (DOSSIER,"UUMGPOSTRC04",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_TRC04
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST
Close Local File [DUD]

#--------------- Deleting an index ----------#
Call MIGINDDEL (DOSSIER,"GACCDUDATE",ERR) From TRTMIG


$FIN
Call MIGTRTEND (DOSSIER,"UUMGPOSTRC04") From TRTMIG
Call ECR_TIME("UUMGPOSTRC04 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End


#############################################################################################################
$GETPERSOC
If [L]DAT>=[F:PER]PERSTR & [L]DAT<=[F:PER]PEREND &  [L]COMPANY=[F:PER]CPY & [L]LEDGENMAIN=[F:PER]LEDTYP
 [L]EXERCICE = [F:PER]FIYNUM
 [L]PERIODE  = [F:PER]PERNUM
 Return
Endif
For [PER]PER0 Where [F:PER]CPY=[L]COMPANY & [F:PER]PERSTR<=[L]DAT & [F:PER]PEREND>=[L]DAT & [F:PER]LEDTYP=[L]LEDGENMAIN
 [L]EXERCICE = [F:PER]FIYNUM
 [L]PERIODE  = [F:PER]PERNUM
Next
Return

