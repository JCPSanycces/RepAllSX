#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################################################
#   Programmes utilitaires pour la gestion du planning marketing.
#
#   FILLPLG   : Alimentation de la table de gestion des campagnes marketing.
#   CHKOPG    : Test l'existence d'opérations pour une campagne marketing.
#   LOADMKG   : Charge le planning marketing avec des campagnes marketing.
#   FILLPLO   : Alimentation de la table de gestion des opérations marketing.
#   LOADOPG   : Charge le planning marketing avec des opérations marketing.
#   SETBUD    : Conversion d'une somme dans la devise du planning marketing
#   RAZ_PLG   : Vide les tables de gestion associées au planning marketing
#   SETDASH   : Affecte - ou un + à l'enregistrement PLG pour lequel l'arborescence doit être déployée.
#   ONCLOCMG  : Clôture une campagne marketing et toutes ses opérations.
#   (LSE 17/10/2005 sup) ONCLOOPG  : Clôture une opération marketing.
#   CLEANPLG  : Nettoie les tables d'éventuelles sorties intempestives de X3.
#
##########################################################################################################
Subprog INIT_ICONE

  # FGR 23/07/2009 : X3SUIVI56686
  Raz WICOOMP
  # (x,0) = Icone On
  # (x,1) = Icone Off
  WICOOMP(0,0) = "Folder.gif"  # Icone dossier par défaut
  WICOOMP(0,1) = "Folder.gif"  # Icone dossier par défaut
  WICOOMP(1,0) = "mvt0.gif"     # Icone par défaut
  WICOOMP(1,1) = "mvt1.gif"     # Icone par défaut
  # Planning marketing
  If func VISUBOMG.CTL_FIC_ICONE("calendrier.png") = 2 Then
    WICOOMP(2,0) = "calendrier.png"
    WICOOMP(2,1) = "calendrier.png"
  Else
    WICOOMP(2,0) = WICOOMP(0,0)
    WICOOMP(2,1) = WICOOMP(0,1)
  Endif
  # Site
  If func VISUBOMG.CTL_FIC_ICONE("maindoeuvre.gif") = 2 Then
    WICOOMP(3,0) = "maindoeuvre.gif"
    WICOOMP(3,1) = "maindoeuvre.gif"
  Else
    WICOOMP(3,0) = WICOOMP(0,0)
    WICOOMP(3,1) = WICOOMP(0,1)
  Endif
  # Campagne marketing
  If func VISUBOMG.CTL_FIC_ICONE("marketing.gif") = 2 Then
    WICOOMP(4,0) = "marketing.gif"
    WICOOMP(4,1) = "marketing.gif"
  Else
    WICOOMP(4,0) = WICOOMP(0,0)
    WICOOMP(4,1) = WICOOMP(0,1)
  Endif
  # Publipostage
  If func VISUBOMG.CTL_FIC_ICONE("publipostage.gif") = 2 Then
    WICOOMP(5,0) = "publipostage.gif"
  Else
    WICOOMP(5,0) = WICOOMP(1,0)
  Endif
  If func VISUBOMG.CTL_FIC_ICONE("publipostageoff.gif") = 2 Then
    WICOOMP(5,1) = "publipostageoff.gif"
  Else
    WICOOMP(5,1) = WICOOMP(1,1)
  Endif
  # Campagne d'appels
  If func VISUBOMG.CTL_FIC_ICONE("campagneappels.gif") = 2 Then
    WICOOMP(6,0) = "campagneappels.gif"
  Else
    WICOOMP(6,0) = WICOOMP(1,0)
  Endif
  If func VISUBOMG.CTL_FIC_ICONE("campagneappelsoff.gif") = 2 Then
    WICOOMP(6,1) = "campagneappelsoff.gif"
  Else
    WICOOMP(6,1) = WICOOMP(1,1)
  Endif
  # Salong professionnels
  If func VISUBOMG.CTL_FIC_ICONE("salon.gif") = 2 Then
    WICOOMP(7,0) = "salon.gif"
  Else
    WICOOMP(7,0) = WICOOMP(1,0)
  Endif
  If func VISUBOMG.CTL_FIC_ICONE("salonoff.gif") = 2 Then
    WICOOMP(7,1) = "salonoff.gif"
  Else
    WICOOMP(7,1) = WICOOMP(1,1)
  Endif
  # Campagne de presse
  If func VISUBOMG.CTL_FIC_ICONE("presse.gif") = 2 Then
    WICOOMP(8,0) = "presse.gif"
  Else
    WICOOMP(8,0) = WICOOMP(1,0)
  Endif
  If func VISUBOMG.CTL_FIC_ICONE("presseoff.gif") = 2 Then
    WICOOMP(8,1) = "presseoff.gif"
  Else
    WICOOMP(8,1) = WICOOMP(1,1)
  Endif
End

##########################################################################################################
# Alimentation de la table de gestion des campagnes marketing.
##################################################################
Subprog FILLPLG(ITRB)
Variable Integer ITRB

Local Integer ICLSNUM
Local Decimal ICMMPRC
Local Char CODDEVSOC
Local Integer IT_IS_OK
Local Integer IT_IS_NOT_OK
Local Decimal IBUD
Local Decimal ITOTBUD
Local Decimal IBUD1
Local Decimal IBUD2
Local Integer IERRDEV

  If GHISTO = 1 Then
    #On est dans le dossier historique
    End
  Endif
  ITOTBUD = 0
  IBUD1 = 0
  IBUD2 = 0
  ICLSNUM = 0
  ICMMPRC = 0
  IT_IS_OK = 0
  IT_IS_NOT_OK = 0
  IBUD = 0
  CODDEVSOC = ""
  ICLSNUM = 0
  IERRDEV = 0
  Filter [CMG] Where [F:CMG]CLO <> 2
  Call DEBTRANS From GLOCK
  Trbegin [PLG]
  For [CMG]CMG1
    [F:PLG]SSS = GIDENT
    [F:PLG]CMGNUM = [F:CMG]NUM
    [F:PLG]CLSNUM = ICLSNUM
    [F:PLG]DAT = date$
    Call CHKOPG([F:CMG]NUM, [F:PLG]MOR)
    Write [PLG]
    If fstat Then
      ITRB = 1
      Break
    Endif
    #Calcul des budgets prévus et engagés
    IBUD = 0
    #Conversion du montant à facturer dans une devise unique pour tout le tableau
    If [M:PLG0]CUR <> [F:CMG]CUR Then
      Call GETDEVCPY("", [F:CMG]FCY, CODDEVSOC, IT_IS_OK) From CRM_UTIL
      # Devise d'origine
      # Devise destination
      # Devise de la société
      # Type de cours
      # Date du cours
      # Montant origine
      # Montant destination
      # Status de retour (0 = OK)
      Call CONVERT([F:CMG]CUR,[M:PLG0]CUR,CODDEVSOC,2,date$,[F:CMG]BUD,IBUD,IT_IS_NOT_OK) From TRTDEV
      If IT_IS_NOT_OK Then
        #Certains montants n'ont pas pus être calculés correctement en raison
        # d'une mauvaise qualification de la table des devises.
        If !IERRDEV Then
          GMESSAGE = mess(278,196,1)
          GERR = 3
          IERRDEV = 1
        Endif
      Endif
    Else
      IBUD = [F:CMG]BUD
    Endif
    #Busget prévu
    [M:PLG0]TOTBUDEXT += IBUD
    #Budget engagé
    Filter [OMM] Where [F:OMM]CMGNUM = [F:CMG]NUM Order By [F:OMM]CREDAT Desc
    For [OMM] Hint Key OMM1
      Call SETBUD([M:PLG0]CUR, [F:OMM]CUR, [F:OMM]FCY, [F:OMM]BUD, IBUD1)
      [M:PLG0]TOTBUDCMM += IBUD1
    Next
    Filter [OMM]
    Filter [OMP] Where [F:OMP]CMGNUM = [F:CMG]NUM Order By [F:OMP]OMPSTR Desc
    For [OMP] Hint Key OMP1
      Call SETBUD([M:PLG0]CUR, [F:OMP]CUR, [F:OMP]FCY, [F:OMP]BUD, IBUD1)
      [M:PLG0]TOTBUDCMM += IBUD1
    Next
    Filter [OMP]
    Filter [OMT] Where [F:OMT]CMGNUM = [F:CMG]NUM Order By [F:OMT]OMTSTR Desc
    For [OMT] Hint Key OMT1
      Call SETBUD([M:PLG0]CUR, [F:OMT]CUR, [F:OMT]FCY, [F:OMT]BOOCST, IBUD1)
      Call SETBUD([M:PLG0]CUR, [F:OMT]CUR, [F:OMT]FCY, [F:OMT]OTHCST, IBUD2)
      ITOTBUD = IBUD1 + IBUD2
      [M:PLG0]TOTBUDCMM += ITOTBUD
    Next
    Filter [OMT]
    Filter [OMN] Where [F:OMN]CMGNUM = [F:CMG]NUM Order By [F:OMN]OMNSTR Desc
    For [OMN] Hint Key OMN1
      Call SETBUD([M:PLG0]CUR, [F:OMN]CUR, [F:OMN]FCY, [F:OMN]BUD, IBUD1)
      [M:PLG0]TOTBUDCMM += IBUD1
    Next
    Filter [OMN]
    ICLSNUM += 1
  Next
  Filter [CMG]
  #Si une écriture a échoué. On arrête tout.
  If ITRB Then
    Rollback
    End
  Else
    Commit
  Endif
End

##########################################################################################################
# Test l'existence d'opérations pour une campagne
##############################################################
Subprog CHKOPG(SZCMGCOD, SZMOR)
Value Char SZCMGCOD
Variable Char SZMOR

  Read [OMM]OMM1=SZCMGCOD
  If !fstat Then
    SZMOR = "+"
    End
  Endif
  Read [OMP]OMP1=SZCMGCOD
  If !fstat Then
    SZMOR = "+"
    End
  Endif
  Read [OMT]OMT1=SZCMGCOD
  If !fstat Then
    SZMOR = "+"
    End
  Endif
  Read [OMN]OMN1=SZCMGCOD
  If !fstat Then
    SZMOR = "+"
    End
  Endif
  SZMOR = ""
End

##########################################################################################################
# Charge le planning marketing avec des campagnes marketing.
##################################################################
Subprog LOADMKG(ICMGCLS, INUMLIN, ITRB)
Value Integer ICMGCLS
Variable Integer INUMLIN
Variable Integer ITRB

Local Decimal IBUD
Local Char CODDEVSOC
Local Integer IT_IS_OK
Local Integer IT_IS_NOT_OK
Local Integer IERRDEV
Local Char SZSVSITE(GLONFCY)  # FGR 23/07/2009 : X3SUIVI56686
Local Integer ILINSITE        # FGR 23/07/2009 : X3SUIVI56686

  SZSVSITE = "###"  # FGR 23/07/2009 : X3SUIVI56686
  ILINSITE = 0      # FGR 23/07/2009 : X3SUIVI56686
  IBUD = 0
  IT_IS_OK = 0
  IT_IS_NOT_OK = 0
  IERRDEV = 0
  Filter [PLG] Where [F:PLG]SSS = GIDENT and [F:PLG]CLSNUM >= ICMGCLS
  For [PLG]PLG2
    If INUMLIN >= GIMAXLIG Then
      Break
    Endif
    # FGR 23/07/2009 : X3SUIVI56686 (début)
    If INUMLIN = 0 Then
      [M:PLG1]PLGKEY(INUMLIN) = "CMG"
      [M:PLG1]CMG(INUMLIN) = mess(635,177,1)
      [M:PLG1]BUD(INUMLIN) = [M:PLG0]TOTBUDEXT
      [M:PLG1]ICO(INUMLIN) = WICOOMP(2,0)
      [M:PLG1]EXPFLG(INUMLIN) = 1
      [M:PLG1]TECH(INUMLIN) = "CMG"
      INUMLIN += 1
    Endif
    # FGR 23/07/2009 : X3SUIVI56686 (fin)
    If GINEWPGC Then
      GIFIRCMG = [F:PLG]CLSNUM
      GINEWPGC = 0
    Endif
    Read [CMG]CMG0=[F:PLG]CMGNUM
    If fstat Then
      ITRB = 1
      Break
    Endif
    # FGR 23/07/2009 : X3SUIVI56686 (début)
    If SZSVSITE = "###" or SZSVSITE <> [F:CMG]FCY Then
      [M:PLG1]PLGKEY(INUMLIN) = [F:CMG]FCY
      [M:PLG1]CMG(INUMLIN) = mess(3,45,1) - [F:CMG]FCY
      [M:PLG1]ICO(INUMLIN) = WICOOMP(3,0)
      [M:PLG1]PARKEY(INUMLIN) = [M:PLG1]PLGKEY(0)
      [M:PLG1]EXPFLG(INUMLIN) = 2
      [M:PLG1]FCY(INUMLIN) = [F:CMG]FCY
      [M:PLG1]TECH(INUMLIN) = "FCY"
      SZSVSITE = [F:CMG]FCY
      ILINSITE = INUMLIN
      INUMLIN += 1
    Endif
    # FGR 23/07/2009 : X3SUIVI56686 (fin)
    [M:PLG1]CMGNUM(INUMLIN) = [F:CMG]NUM
    [M:PLG1]NUM(INUMLIN) = [F:CMG]NUM   # FGR 23/07/2009 : X3SUIVI56686 (fin)
    [M:PLG1]OPGNUM(INUMLIN) = ""
    [M:PLG1]CLSNUM(INUMLIN) = [F:PLG]CLSNUM
    [M:PLG1]CMG(INUMLIN) = left$([F:CMG]TTR, 53)
    [M:PLG1]TYPOPG(INUMLIN) = mess(636,177,1)
    [M:PLG1]TYPOPGX(INUMLIN) = 0
    [M:PLG1]DATSTR(INUMLIN) = [F:CMG]DATSTR
    [M:PLG1]DATEND(INUMLIN) = [F:CMG]DATEND
    [M:PLG1]FCY(INUMLIN) = [F:CMG]FCY
    #Gestion des tunnels
    #Tunnel vers campagne marketing
    If [M:PLG1]CMGNUM(INUMLIN) <> "" and [M:PLG1]OPGNUM(INUMLIN) = "" Then
      [M:PLG1]PLGTYP(INUMLIN) = "CMG"
      [M:PLG1]PLGKEY(INUMLIN) = [M:PLG1]CMGNUM(INUMLIN)
    Endif
    IBUD = 0
    #Conversion du budget dans une devise unique pour tout le tableau
    If [M:PLG0]CUR <> [F:CMG]CUR Then
      Call GETDEVCPY("", [F:CMG]FCY, CODDEVSOC, IT_IS_OK) From CRM_UTIL
      # Devise d'origine
      # Devise destination
      # Devise de la société
      # Type de cours
      # Date du cours
      # Montant origine
      # Montant destination
      # Status de retour (0 = OK)
      Call CONVERT([F:CMG]CUR,[M:PLG0]CUR,CODDEVSOC,2,date$,[F:CMG]BUD,IBUD,IT_IS_NOT_OK) From TRTDEV
      If IT_IS_NOT_OK Then
        #Certains montants n'ont pas pus être calculés correctement en raison d'une mauvaise qualification de la table des devises.
        If !IERRDEV Then
          GMESSAGE = mess(278,196,1)
          GERR = 3
          IERRDEV = 1
        Endif
      Endif
    Else
      IBUD = [F:CMG]BUD
    Endif
    [M:PLG1]BUD(INUMLIN) = IBUD
    [M:PLG1]MOR(INUMLIN) = [F:PLG]MOR
    # FGR 23/07/2009 : X3SUIVI56686 (début)
    [M:PLG1]ICO(INUMLIN) = WICOOMP(4,0)
    [M:PLG1]PARKEY(INUMLIN) = [M:PLG1]PLGKEY(ILINSITE)
    [M:PLG1]EXPFLG(INUMLIN) = 1
    # FGR 23/07/2009 : X3SUIVI56686 (fin)
    If [M:PLG1]MOR(INUMLIN) = "+" Then
      If INUMLIN+1 >= GIMAXLIG Then
        GILASOPG = 0
      Endif
      Call LOADOPG([F:PLG]CMGNUM, GILASOPG, INUMLIN, ITRB)
    Else
      GILASOPG = 0
    Endif
    GILASCMG = [F:PLG]CLSNUM
    INUMLIN += 1
  Next
  Filter [PLG]
  #Traitement de l'erreur de lecture de campagne.
  If ITRB Then
    GMESSAGE = mess(344,196,1) #Erreur lors du chargement du planning marketing.
    GERR = 1
    End
  Endif
End

##########################################################################################################
# Alimentation de la table de gestion des opérations marketing.
##################################################################
Subprog FILLPLO(SZCMG,ITRB)
Value Char SZCMG
Variable Integer ITRB

Local Integer ICLSNUM

  ICLSNUM = 0
  Call DEBTRANS From GLOCK
  Trbegin [PLO]
  #Charge les mailing
  Filter [OMM] Where [F:OMM]CMGNUM = SZCMG
  For [OMM]OMM1
    Read [PLO]PLO2=SZCMG;[F:OMM]OMMNUM;GIDENT
    If fstat Then
      [F:PLO]SSS = GIDENT
      [F:PLO]CLSNUM = 0
      [F:PLO]CMGNUM = [F:OMM]CMGNUM
      [F:PLO]OPGNUM = [F:OMM]OMMNUM
      [F:PLO]DATOPG = [F:OMM]SHIDAT
      [F:PLO]TYPOPG = 1
      [F:PLO]DAT = date$
      Write [PLO]
      If fstat Then
        ITRB = 1
        Break
      Endif
    Endif
  Next
  Filter [OMM]
  #Si une écriture de mailing a échoué. On arrête tout.
  If ITRB Then
    GMESSAGE = mess(343,196,1) #Erreur lors de la recherche des opérations marketing.
    GERR = 1
    Rollback
    FIN = 1
    End
  Endif
  #Charge les campagnes d'appels
  Filter [OMP] Where [F:OMP]CMGNUM = SZCMG
  For [OMP]OMP1
    Read [PLO]PLO2=SZCMG;[F:OMP]OMPNUM;GIDENT
    If fstat Then
      [F:PLO]SSS = GIDENT
      [F:PLO]CLSNUM = 0
      [F:PLO]CMGNUM = [F:OMP]CMGNUM
      [F:PLO]OPGNUM = [F:OMP]OMPNUM
      [F:PLO]DATOPG = [F:OMP]OMPSTR
      [F:PLO]TYPOPG = 2
      [F:PLO]DAT = date$
      Write [PLO]
      If fstat Then
        ITRB = 1
        Break
      Endif
    Endif
  Next
  Filter [OMP]
  #Si une écriture de mailing a échoué. On arrête tout.
  If ITRB Then
    GMESSAGE = mess(343,196,1) #Erreur lors de la recherche des opérations marketing.
    GERR = 1
    Rollback
    FIN = 1
    End
  Endif
  #Charge les salons professionnels
  Filter [OMT] Where [F:OMT]CMGNUM = SZCMG
  For [OMT]OMT1
    Read [PLO]PLO2=SZCMG;[F:OMT]OMTNUM;GIDENT
    If fstat Then
      [F:PLO]SSS = GIDENT
      [F:PLO]CLSNUM = 0
      [F:PLO]CMGNUM = [F:OMT]CMGNUM
      [F:PLO]OPGNUM = [F:OMT]OMTNUM
      [F:PLO]DATOPG = [F:OMT]OMTSTR
      [F:PLO]TYPOPG = 3
      [F:PLO]DAT = date$
      Write [PLO]
      If fstat Then
        ITRB = 1
        Break
      Endif
    Endif
  Next
  Filter [OMT]
  #Si une écriture de mailing a échoué. On arrête tout.
  If ITRB Then
    GMESSAGE = mess(343,196,1) #Erreur lors de la recherche des opérations marketing.
    GERR = 1
    Rollback
    FIN = 1
    End
  Endif
  #Charge les campagnes presse
  Filter [OMN] Where [F:OMN]CMGNUM = SZCMG
  For [OMN]OMN1
    Read [PLO]PLO2=SZCMG;[F:OMN]OMNNUM;GIDENT
    If fstat Then
      [F:PLO]SSS = GIDENT
      [F:PLO]CLSNUM = 0
      [F:PLO]CMGNUM = [F:OMN]CMGNUM
      [F:PLO]OPGNUM = [F:OMN]OMNNUM
      [F:PLO]DATOPG = [F:OMN]OMNSTR
      [F:PLO]TYPOPG = 4
      [F:PLO]DAT = date$
      Write [PLO]
      If fstat Then
        ITRB = 1
        Break
      Endif
    Endif
  Next
  Filter [OMN]
  #Si une écriture de mailing a échoué. On arrête tout.
  If ITRB Then
    GMESSAGE = mess(343,196,1) #Erreur lors de la recherche des opérations marketing.
    GERR = 1
    Rollback
    FIN = 1
    End
  Else
    Commit
  Endif
  #Affecte les numéros d'ordre aux opérations sélectionnées.
  Filter [PLO] Where [F:PLO]SSS = GIDENT and [F:PLO]CMGNUM = SZCMG Order By [F:PLO]DATOPG Asc
  Call DEBTRANS From GLOCK
  Trbegin [PLO]
  ICLSNUM = 0
  For [PLO] Hint Key PLO2
    [F:PLO]CLSNUM = ICLSNUM
    Rewrite [PLO]
    If fstat Then
      ITRB = 1
      Break
    Endif
    ICLSNUM += 1
  Next
  Filter [PLO]
  #Si une réécriture a échoué. On arrête tout.
  If ITRB Then
    GMESSAGE = mess(343,196,1) #Erreur lors de la recherche des opérations marketing.
    GERR = 1
    Rollback
    End
  Else
    Commit
  Endif
End

##########################################################################################################
# Charge le planning marketing avec des opérations marketing.
##################################################################
Subprog LOADOPG(SZCMG, IOPGCLS, ILINNUM, ITRB)
Value Char SZCMG
Value Integer IOPGCLS
Variable Integer ILINNUM
Variable Integer ITRB

Local Integer OI
Local Decimal IOMTTOTBUD

  OI = 0
  IOMTTOTBUD = 0
  Call FILLPLO(SZCMG, ITRB)
  #Si echec. On arrête tout.
  If ITRB Then
    End
  Endif
  If GINEWPGO Then
    Filter [PLO] Where [F:PLO]CMGNUM = SZCMG and [F:PLO]SSS = GIDENT and [F:PLO]CLSNUM >= IOPGCLS
  Else
    Filter [PLO] Where [F:PLO]CMGNUM = SZCMG and [F:PLO]SSS = GIDENT
  Endif
  For [PLO]PLO1 Hint Key PLO2
    OI = ILINNUM + 1
    If OI >= GIMAXLIG Then
      Break
    Endif
    If GINEWPGO Then
      GIFIROPG = [F:PLO]CLSNUM
      GINEWPGO = 0
    Endif
    [M:PLG1]CMGNUM(OI) = ""
    [M:PLG1]OPGNUM(OI) = [F:PLO]OPGNUM
    [M:PLG1]NUM(OI) = [F:PLO]OPGNUM   # FGR 23/07/2009 : X3SUIVI56686 (fin)
    [M:PLG1]MOR(OI) = ""
    [M:PLG1]CLSNUM(OI) = [F:PLO]CLSNUM
    Case [F:PLO]TYPOPG
      When 1
        [M:PLG1]TYPOPGX(OI) = [F:PLO]TYPOPG
        [M:PLG1]TYPOPG(OI) = mess([M:PLG1]TYPOPGX(OI),969,1)
        Read [OMM]OMM0=[F:PLO]OPGNUM
        If !fstat Then
          [M:PLG1]CMG(OI) = "     -----" - left$([F:OMM]DES, 42)
          [M:PLG1]DATSTR(OI) = [F:OMM]SHIDAT
          [M:PLG1]DATEND(OI) = [00/00/00]
          [M:PLG1]FCY(OI) = [F:OMM]FCY
          Call SETBUD([M:PLG0]CUR, [F:OMM]CUR, [F:OMM]FCY, [F:OMM]BUD, [M:PLG1]BUD(OI))
          # FGR 23/07/2009 : X3SUIVI56686 (début)
          If [F:OMM]CLO = 2 Then
            [M:PLG1]ICO(OI) = WICOOMP(5,1)
          Else
            [M:PLG1]ICO(OI) = WICOOMP(5,0)
          Endif
          # FGR 23/07/2009 : X3SUIVI56686 (fin)
        Endif
      When 2
        [M:PLG1]TYPOPGX(OI) = [F:PLO]TYPOPG
        [M:PLG1]TYPOPG(OI) = mess([M:PLG1]TYPOPGX(OI),969,1)
        Read [OMP]OMP0=[F:PLO]OPGNUM
        If !fstat Then
          [M:PLG1]CMG(OI) = "     -----" - left$([F:OMP]DES, 42)
          [M:PLG1]DATSTR(OI) = [F:OMP]OMPSTR
          [M:PLG1]DATEND(OI) = [F:OMP]OMPEND
          [M:PLG1]FCY(OI) = [F:OMP]FCY
          Call SETBUD([M:PLG0]CUR, [F:OMP]CUR, [F:OMP]FCY, [F:OMP]BUD, [M:PLG1]BUD(OI))
          # FGR 23/07/2009 : X3SUIVI56686 (début)
          If [F:OMM]CLO = 2 Then
            [M:PLG1]ICO(OI) = WICOOMP(6,1)
          Else
            [M:PLG1]ICO(OI) = WICOOMP(6,0)
          Endif
          # FGR 23/07/2009 : X3SUIVI56686 (fin)
        Endif
      When 3
        [M:PLG1]TYPOPGX(OI) = [F:PLO]TYPOPG
        [M:PLG1]TYPOPG(OI) = mess([M:PLG1]TYPOPGX(OI),969,1)
        Read [OMT]OMT0=[F:PLO]OPGNUM
        If !fstat Then
          [M:PLG1]CMG(OI) = "     -----" - left$([F:OMT]DES, 42)
          [M:PLG1]DATSTR(OI) = [F:OMT]OMTSTR
          [M:PLG1]DATEND(OI) = [F:OMT]OMTEND
          [M:PLG1]FCY(OI) = [F:OMT]FCY
          IOMTTOTBUD = [F:OMT]BOOCST + [F:OMT]OTHCST
          Call SETBUD([M:PLG0]CUR, [F:OMT]CUR, [F:OMT]FCY, IOMTTOTBUD, [M:PLG1]BUD(OI))
          # FGR 23/07/2009 : X3SUIVI56686 (début)
          If [F:OMM]CLO = 2 Then
            [M:PLG1]ICO(OI) = WICOOMP(7,1)
          Else
            [M:PLG1]ICO(OI) = WICOOMP(7,0)
          Endif
          # FGR 23/07/2009 : X3SUIVI56686 (fin)
        Endif
      When 4
        [M:PLG1]TYPOPGX(OI) = [F:PLO]TYPOPG
        [M:PLG1]TYPOPG(OI) = mess([M:PLG1]TYPOPGX(OI),969,1)
        Read [OMN]OMN0=[F:PLO]OPGNUM
        If !fstat Then
          [M:PLG1]CMG(OI) = "     -----" - left$([F:OMN]DES, 42)
          [M:PLG1]DATSTR(OI) = [F:OMN]OMNSTR
          [M:PLG1]DATEND(OI) = [F:OMN]OMNEND
          [M:PLG1]FCY(OI) = [F:OMN]FCY
          Call SETBUD([M:PLG0]CUR, [F:OMN]CUR, [F:OMN]FCY, [F:OMN]BUD, [M:PLG1]BUD(OI))
          # FGR 23/07/2009 : X3SUIVI56686 (début)
          If [F:OMM]CLO = 2 Then
            [M:PLG1]ICO(OI) = WICOOMP(8,1)
          Else
            [M:PLG1]ICO(OI) = WICOOMP(8,0)
          Endif
          # FGR 23/07/2009 : X3SUIVI56686 (fin)
        Endif
      When Default
    Endcase
    #Gestion des tunnels
    #Tunnel vers opération marketing
    If [M:PLG1]CMGNUM(OI) = "" and [M:PLG1]OPGNUM(OI) <> "" Then
      If [M:PLG1]TYPOPGX(OI) = 1 Then
        [M:PLG1]PLGTYP(OI) = "OMM"
      Elsif [M:PLG1]TYPOPGX(OI) = 2 Then
        [M:PLG1]PLGTYP(OI) = "OMP"
      Elsif [M:PLG1]TYPOPGX(OI) = 3 Then
        [M:PLG1]PLGTYP(OI) = "OMT"
      Elsif [M:PLG1]TYPOPGX(OI) = 4 Then
        [M:PLG1]PLGTYP(OI) = "OMN"
      Endif
      [M:PLG1]PLGKEY(OI) = [M:PLG1]OPGNUM(OI)
    Endif
    GILASOPG = [F:PLO]CLSNUM
    # FGR 23/07/2009 : X3SUIVI56686 (début)
    [M:PLG1]PARKEY(OI) = SZCMG
    [M:PLG1]EXPFLG(OI) = 1
    # FGR 23/07/2009 : X3SUIVI56686 (fin)
    ILINNUM += 1    
  Next
  Filter [PLO]
End

##########################################################################################################
# Conversion d'une somme dans la devise du planning marketing
####################################################
Subprog SETBUD(IPLGCUR, IOPGCUR, SZOPGFCY, IOPGBUD, IRESULT)
Value Char IPLGCUR
Value Char IOPGCUR
Value Char SZOPGFCY
Value Decimal IOPGBUD
Variable Decimal IRESULT

Local Char CDEVSOC
Local Integer IT_IS_OK
Local Integer IT_IS_NOT_OK

  CDEVSOC = ""
  IT_IS_OK = 0
  IT_IS_NOT_OK = 0
  #Conversion du montant à facturer dans une devise unique pour tout le tableau
  If IPLGCUR <> IOPGCUR Then
    Call GETDEVCPY("", SZOPGFCY, CDEVSOC, IT_IS_OK) From CRM_UTIL
    # Devise d'origine
    # Devise destination
    # Devise de la société
    # Type de cours
    # Date du cours
    # Montant origine
    # Montant destination
    # Status de retour (0 = OK)
    Call CONVERT(IOPGCUR,IPLGCUR,CDEVSOC,2,date$,IOPGBUD,IRESULT,IT_IS_NOT_OK) From TRTDEV
    If IT_IS_NOT_OK Then
      #Certains montants n'ont pas pus être calculés correctement en raison
      # d'une mauvaise qualification de la table des devises.
      GMESSAGE = mess(278,196,1)
      GERR = 3
    Endif
  Else
    IRESULT = IOPGBUD
  Endif
End

##########################################################################################################
# Vide les tables de gestion associées au planning marketing
#########################################################
Subprog RAZ_PLG
  If GHISTO = 1 Then
    #On est dans le dossier historique
    End
  Endif
  Call DEBTRANS From GLOCK
  Trbegin [PLG], [PLO]
  Delete [PLG] Where [F:PLG]SSS = GIDENT
  If fstat Then
    Rollback
    End
  Endif
  Delete [PLO] Where [F:PLO]SSS = GIDENT
  If fstat Then
    Rollback
    End
  Endif
  Commit
End

##########################################################################################################
# Affecte - ou + à l'enregistrement PLG pour lequel l'arborescence doit être déployée.
#########################################################
Subprog SETDASH(SZDASH, ICLSNUM, ITRB)
Value Char SZDASH
Value Integer ICLSNUM
Variable Integer ITRB

  Call DEBTRANS From GLOCK
  Trbegin [PLG]
  Read [PLG]PLG2=ICLSNUM;GIDENT
  If fstat Then
    GMESSAGE = mess(343,196,1) #Erreur lors de la recherche des opérations marketing.
    GERR = 1
    ITRB = 1
    End
  Endif
  [F:PLG]MOR = SZDASH
  Rewrite [PLG]
  If fstat Then
    GMESSAGE = mess(343,196,1) #Erreur lors de la recherche des opérations marketing.
    GERR = 1
    ITRB = 1
    Rollback
    End
  Else
    Commit
  Endif
End

##########################################################################################################
# Traitement des boutons Dernier et Précédent. (Campagnes)
##################################################################
Subprog LASTMKG(SZACT, ICMGCLS, ITESTLIN, ITRB)
Value Char SZACT
Value Integer ICMGCLS
Variable Integer ITESTLIN
Variable Integer ITRB

Local Integer INUMLIN
Local Integer ILOCALFIROPG
Local Decimal IBUD
Local Char CODDEVSOC
Local Integer IT_IS_OK
Local Integer IT_IS_NOT_OK
Local Integer IERRDEV

  IBUD = 0
  IT_IS_OK = 0
  IT_IS_NOT_OK = 0
  INUMLIN = 0
  ILOCALFIROPG = GIFIROPG
  IERRDEV = 0
  If SZACT = "PREV" Then
    Filter [PLG] Where [F:PLG]SSS = GIDENT and [F:PLG]CLSNUM <= ICMGCLS Order By [F:PLG]CLSNUM Desc
  Elsif SZACT = "LAST" Then
    Filter [PLG] Where [F:PLG]SSS = GIDENT Order By [F:PLG]CLSNUM Desc
  Endif
  ITESTLIN = 0
  For [PLG]
    If ITESTLIN >= GIMAXLIG Then
      Break
    Endif
    If [F:PLG]MOR = "-" Then
      Call LOADOPG([F:PLG]CMGNUM, 0, ITESTLIN, ITRB)
      GIFIROPG = ILOCALFIROPG
    Endif
    ITESTLIN += 1
  Next
  INUMLIN = ITESTLIN - 1
  For [PLG]
    If INUMLIN < 0 Then
      Break
    Endif
    If GINEWPGC Then
      GILASCMG = [F:PLG]CLSNUM
      GINEWPGC = 0
    Endif
    If [F:PLG]MOR = "-" Then
      If SZACT = "PREV" Then
        Call LASTOPG("PREV", [F:PLG]CMGNUM, GIFIROPG, INUMLIN, ITRB)
      Elsif SZACT = "LAST" Then
        Call LASTOPG("LAST", [F:PLG]CMGNUM, GIFIROPG, INUMLIN, ITRB)
      Endif
    Endif
    GIFIRCMG = [F:PLG]CLSNUM
    If INUMLIN < 0 Then
      Break
    Endif
    Read [CMG]CMG0=[F:PLG]CMGNUM
    If fstat Then
      ITRB = 1
      Break
    Endif
    [M:PLG1]CMGNUM(INUMLIN) = [F:CMG]NUM
    [M:PLG1]OPGNUM(INUMLIN) = ""
    [M:PLG1]CLSNUM(INUMLIN) = [F:PLG]CLSNUM
    [M:PLG1]CMG(INUMLIN) = left$([F:CMG]TTR, 53)
    [M:PLG1]TYPOPG(INUMLIN) = ""
    [M:PLG1]TYPOPGX(INUMLIN) = 0
    [M:PLG1]DATSTR(INUMLIN) = [F:CMG]DATSTR
    [M:PLG1]DATEND(INUMLIN) = [F:CMG]DATEND
    [M:PLG1]FCY(INUMLIN) = [F:CMG]FCY
    IBUD = 0
    #Conversion du montant à facturer dans une devise unique pour tout le tableau
    If [M:PLG0]CUR <> [F:CMG]CUR Then
      Call GETDEVCPY("", [F:CMG]FCY, CODDEVSOC, IT_IS_OK) From CRM_UTIL
      # Devise d'origine
      # Devise destination
      # Devise de la société
      # Type de cours
      # Date du cours
      # Montant origine
      # Montant destination
      # Status de retour (0 = OK)
      Call CONVERT([F:CMG]CUR,[M:PLG0]CUR,CODDEVSOC,2,date$,[F:CMG]BUD,IBUD,IT_IS_NOT_OK) From TRTDEV
      If IT_IS_NOT_OK Then
        #Certains montants n'ont pas pus être calculés correctement en raison
        # d'une mauvaise qualification de la table des devises.
        If !IERRDEV Then
          GMESSAGE = mess(278,196,1)
          GERR = 3
          IERRDEV = 1
        Endif
      Endif
    Else
      IBUD = [F:CMG]BUD
    Endif
    [M:PLG1]BUD(INUMLIN) = IBUD
    [M:PLG1]MOR(INUMLIN) = [F:PLG]MOR
    If SZACT = "PREV" Then
      GIFLOPG = 0
    Endif
    INUMLIN -= 1
  Next
  Filter [PLG]
  #Traitement de l'erreur de lecture de campagne.
  If ITRB Then
    GMESSAGE = mess(344,196,1) #Erreur lors du chargement du planning marketing.
    GERR = 1
    End
  Endif
End

##########################################################################################################
# Traitement des boutons Dernier et Précédent. (Opérations)
##################################################################
Subprog LASTOPG(SZACT, SZCMG, IOPGCLS, ILINNUM, ITRB)
Value Char SZACT
Value Char SZCMG
Value Integer IOPGCLS
Variable Integer ILINNUM
Variable Integer ITRB

Local Integer OI
Local Decimal IOMTTOTBUD

  OI = 0
  IOMTTOTBUD = 0
  Call FILLPLO(SZCMG,ITRB)
  #Si echec. On arrête tout.
  If ITRB Then
    End
  Endif
  If SZACT = "PREV" Then
    If !GIFLOPG Then
      Filter [PLO] Where [F:PLO]CMGNUM = SZCMG and [F:PLO]SSS = GIDENT Order By [F:PLO]CLSNUM Desc
    Elsif GIFLOPG Then
      Filter [PLO] Where [F:PLO]CMGNUM = SZCMG and [F:PLO]SSS = GIDENT and [F:PLO]CLSNUM <= IOPGCLS Order By [F:PLO]CLSNUM Desc
      GIFLOPG = 0
    Endif
  Elsif SZACT = "LAST" Then
    Filter [PLO] Where [F:PLO]CMGNUM = SZCMG and [F:PLO]SSS = GIDENT Order By [F:PLO]CLSNUM Desc
  Endif
  For [PLO] Hint Key PLO2
    OI = ILINNUM
    If OI < 1 Then
      Break
    Endif
    If GILNEWPGO Then
      GILASOPG = [F:PLO]CLSNUM
      GILNEWPGO = 0
    Endif
    [M:PLG1]CMGNUM(OI) = ""
    [M:PLG1]OPGNUM(OI) = [F:PLO]OPGNUM
    [M:PLG1]MOR(OI) = ""
    [M:PLG1]CLSNUM(OI) = [F:PLO]CLSNUM
    Case [F:PLO]TYPOPG
      When 1
        [M:PLG1]TYPOPG(OI) = mess(1,969,1)
        [M:PLG1]TYPOPGX(OI) = 1
        Read [OMM]OMM0=[F:PLO]OPGNUM
        If !fstat Then
          [M:PLG1]CMG(OI) = "     -----" - left$([F:OMM]DES, 42)
          [M:PLG1]DATSTR(OI) = [F:OMM]SHIDAT
          [M:PLG1]DATEND(OI) = [00/00/00]
          [M:PLG1]FCY(OI) = [F:OMM]FCY
          Call SETBUD([M:PLG0]CUR, [F:OMM]CUR, [F:OMM]FCY, [F:OMM]BUD, [M:PLG1]BUD(OI))
        Endif
      When 2
        [M:PLG1]TYPOPG(OI) = mess(2,969,1)
        [M:PLG1]TYPOPGX(OI) = 2
        Read [OMP]OMP0=[F:PLO]OPGNUM
        If !fstat Then
          [M:PLG1]CMG(OI) = "     -----" - left$([F:OMP]DES, 42)
          [M:PLG1]DATSTR(OI) = [F:OMP]OMPSTR
          [M:PLG1]DATEND(OI) = [F:OMP]OMPEND
          [M:PLG1]FCY(OI) = [F:OMP]FCY
          Call SETBUD([M:PLG0]CUR, [F:OMP]CUR, [F:OMP]FCY, [F:OMP]BUD, [M:PLG1]BUD(OI))
        Endif
      When 3
        [M:PLG1]TYPOPG(OI) = mess(3,969,1)
        [M:PLG1]TYPOPGX(OI) = 3
        Read [OMT]OMT0=[F:PLO]OPGNUM
        If !fstat Then
          [M:PLG1]CMG(OI) = "     -----" - left$([F:OMT]DES, 42)
          [M:PLG1]DATSTR(OI) = [F:OMT]OMTSTR
          [M:PLG1]DATEND(OI) = [F:OMT]OMTEND
          [M:PLG1]FCY(OI) = [F:OMT]FCY
          IOMTTOTBUD = [F:OMT]BOOCST + [F:OMT]OTHCST
          Call SETBUD([M:PLG0]CUR, [F:OMT]CUR, [F:OMT]FCY, IOMTTOTBUD, [M:PLG1]BUD(OI))
        Endif
      When 4
        [M:PLG1]TYPOPG(OI) = mess(4,969,1)
        [M:PLG1]TYPOPGX(OI) = 4
        Read [OMN]OMN0=[F:PLO]OPGNUM
        If !fstat Then
          [M:PLG1]CMG(OI) = "     -----" - left$([F:OMN]DES, 42)
          [M:PLG1]DATSTR(OI) = [F:OMN]OMNSTR
          [M:PLG1]DATEND(OI) = [F:OMN]OMNEND
          [M:PLG1]FCY(OI) = [F:OMN]FCY
          Call SETBUD([M:PLG0]CUR, [F:OMN]CUR, [F:OMN]FCY, [F:OMN]BUD, [M:PLG1]BUD(OI))
        Endif
      When Default
    Endcase
    GIFIROPG = [F:PLO]CLSNUM
    ILINNUM -= 1    
  Next
  Filter [PLO]
End

##########################################################################################################
# Clôture une campagne marketing et toutes ses opérations.
#########################################################
Subprog ONCLOCMG(SZCMGNUM, INUMMES, ICHAPTER, IBRETOUR)
Value Char SZCMGNUM
Variable Integer INUMMES
Variable Integer ICHAPTER
Variable Integer IBRETOUR

  Call CLOCMG (SZCMGNUM, INUMMES, ICHAPTER, IBRETOUR) From SUBCMGB
End

##########################################################################################################
# Nettoie les tables d'éventuelles sorties intempestives de X3.
#########################################################
Subprog CLEANPLG
Local Date DMON

  If GHISTO = 1 Then
    #On est dans le dossier historique
    End
  Endif
  DMON = date$ - 15
  Call DEBTRANS From GLOCK
  Trbegin [PLG], [PLO]
  Delete [PLG] Where [F:PLG]DAT <= DMON
  If fstat Then
    Rollback
    End
  Endif
  Delete [PLO] Where [F:PLO]DAT <= DMON
  If fstat Then
    Rollback
    End
  Endif
  Commit
End
