#<AdxTL>@(#)3.0.0.0 $Revision$
##############################################################################################################
# FASPHY : Etat physique des Biens
# Modifications :
# FHA   18.09.17 X3-54960 : Correction of the .rpt report. Inclusion of AREPORTM in the report.
# CBO   08.09.17 X3-54960 : Gestion des mouvements en attente et reprise des sel.
# MDJ   12.06.15 FQXXXXXX : Adaptation états inventaire à la Syracusation
##############################################################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

  Call EXEC(NBPAR,PARAMETRE)
End

#########################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
Local    Date    DATREF
Global   Integer MVTATT

  Gosub OUVRE   : # Ouverture des tables / Open tables
  If GERREUR  GERREUR=0 : End : Endif

  Gosub DECLARE : # Déclaration des variables globales / Globals delerarions

  [L]CRITERE  = "1=1"
  [L]CRITERE2 = "1=1"

  For I=1 To NBPAR
    J=instr(1,[L]PARAMETRE(I),"=")
    If J
      [L]PARAM  = left$([L]PARAMETRE(I),J-1)
      Call GETPARAM([L]PARAM,NBPAR,PARAMETRE,[L]VALEUR) From ETAT
      Case [L]PARAM
        When "X3ETA"
          [L]ETAT     = [L]VALEUR
        When "__REQUETE"
          [L]NUMREQ   = val([L]VALEUR)
        When "cpydeb"
          If VALEUR <> ""
            [L]CRITERE -= "& CPY>='" + [L]VALEUR + "'"
          Endif
        When "cpyfin"
          [L]CRITERE -= "& CPY<='" + [L]VALEUR + "'"
        When "fcydeb"
          If VALEUR <> ""
            [L]CRITERE -= "& FCY>='" + [L]VALEUR + "'"
          Endif
        When "fcyfin"
          [L]CRITERE -= "& FCY<='" + [L]VALEUR + "'"
        When "datachdeb"
          If VALEUR >= [01/01/1900]
            DATREF =  gdat$(val(right$([L]VALEUR,7)),val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
            [L]CRITERE -= "& PURDAT >=[" + format$(GFMD,[L]DATREF) + ']'
          Endif
        When "datachfin"
          DATREF =  gdat$(val(right$([L]VALEUR,7)),val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
          [L]CRITERE -= "& PURDAT <=[" + format$(GFMD,[L]DATREF) + ']'
        When "bcodeb"
          If VALEUR <> ""
            [L]CRITERE -= "& AASREF>='" + [L]VALEUR + "'"
          Endif
        When "bcofin"
          [L]CRITERE -= "& AASREF<='" + [L]VALEUR + "'"
        When "sorti"
          If    VALEUR="1"
            [L]CRITERE2 -= "& ISSDAT=[0/0/0]"
          Elsif VALEUR="2"
            [L]CRITERE2 -= "& ISSDAT<>[0/0/0]"
          Endif
        When "actif"
          If    VALEUR="1"
            [L]CRITERE2 -= "& ENAFAS=2"
          Elsif VALEUR="0"
            [L]CRITERE2 -= "& ENAFAS=1"
          Endif
        When "mvtatt"
          MVTATT=val(VALEUR)

        When "numedt"
          [L]PARAMETRE(I) = "numedt=" + num$([L]NUMREQ)
        When "usr"
          [L]PARAMETRE(I) = "usr=" + GUSER
        When "etat"
          [L]PARAMETRE(I) = "etat=" + [L]ETAT
      Endcase
    Endif
  Next
# Issue X3-54960 - 2017-09-08 by CBO
#  Link [FAS] With [PHY]PHY5(1)=AASREF As [FAS_]
#  Filter [FAS_] Where [F:PHY]AASREF<>'' & evalue([L]CRITERE) & evalue([L]CRITERE2)
  Link [FAS] With [PHY]PHY5(1) ~= AASREF As [FAS_]
  Filter [FAS_] Where evalue([L]CRITERE) & evalue([L]CRITERE2)
  Gosub TRT_FAS
# End issue X3-54960
End

#FQXXXXXX                       If VALEUR="1"      [L]CRITERE2 -= "& [F:PHY]MVT(0)<=" + num$(GVMLPMVNONE)
#FQXXXXXX                        Elsif VALEUR="2"   [L]CRITERE2 -= "& [F:PHY]MVT(0)>" + num$(GVMLPMVNONE)
#FQXXXXXX                        Endif
#########################################################################

$TRT_FAS
Local Integer EDIT

  Raz WNUMLIG
  Default File [FAS_]

# Issue X3-54960 - 2017-09-08 by CBO : Gestion du paramètre "mvt en attente" MVTATT
# Issue X3-54960 - 2017-09-08 by CBO : Managing the 3 values of "with pending element" parameter MVTATT
# 1 = Non / No
# 2 = Oui / Yes
# 3 = Tous / All

  #If MVTATT= G_OUI
    If !clalev([PHYT])      Local File PHYELT [PHYT] Endif
    If !clalev([PMVT])      Local File PHYMVT [PMVT] Endif
  #Endif

    Link [PHYT] With
&            [PMVT]PMVT0(1)  ~= [F:PHYT]PHYREF
&     As [PHYTM]

  For [FAS_]FAS0
    EDIT = G_OUI
    # Dans le cas où on veut exclure les biens qui ont au moins un élément physique avec mvt en attente (mvtatt=1),
    # il faut regarder l'ensemble des elts phy rattachés à chacun des biens déjà filtrés, et voir si au moins un a un
    # mvt en attente. Si oui, on n'édite pas ce bien.

    If MVTATT <> 3 # DIFFERENT OF all
      If MVTATT = 2 # yes
        EDIT = G_NON
      Endif
      Read  [PHYTM]PHY5(1) = [F:FAS_]AASREF
      If fstat = 0 and MVTATT = 1 # found and we don't want
        EDIT = G_NON
      Endif
      If fstat = 0 and MVTATT = 2 # found and we want
        EDIT = G_OUI
      Endif
    Endif
#    If MVTATT <> 3 # DIFFERENT OF all
#
#      If MVTATT = 2 # yes
#        EDIT = G_NON
#      Endif
#      Filter [PHYT] Where AASREF=[F:FAS_]AASREF
#      For [PHYT]
#        Read  [PMVT]PMVT0(1) = [F:PHYT]PHYREF
#        If fstat = 0 and MVTATT = 1 # found and we don't want : break -> NOk
#            EDIT = G_NON
#            Break
#          Endif
#        If fstat = 0 and MVTATT = 2 # found and we want : break -> Ok
#            EDIT = G_OUI
#            Break
#          Endif
#      Next
#      Filter [PHYT]
#    Endif
    If EDIT = G_OUI
      Gosub TR
    Endif
  Next
  Filter [FAS_]
# End issue X3-54960

  #If MVTATT= G_OUI
    Close Local File [PHYT]
    Close Local File [PMVT]
  #Endif

  If dim(MVTATT)>0      Kill MVTATT Endif

Return

#########################################################################

$TR

  Trbegin [ARM]
  #----- Création d'un enregistrement dans la table AREPORTM -----#
  WNUMLIG += 1
  Raz [F:ARM]
  [F:ARM]USR    = GUSER
  [F:ARM]RPTCOD = [F:ARP]RPTCOD
  [F:ARM]NUMREQ = [L]NUMREQ
  [F:ARM]NUMLIG = WNUMLIG
  [F:ARM]CLEA1  = [F:FAS_]AASREF
  [F:ARM]CLEA2  = [F:PHY]PHYREF :# Issue X3-54960 - 2017-09-18 by FHA : Inclusion of ARM in the report
  [F:ARM]CREDAT = date$
  Write [F:ARM]
  If fstat  Goto ROLL_TR : Endif
  #-----
  Commit
Return

$ROLL_TR
  Rollback : Call ROLL From GLOCK
  If GROLL : Return : Else : Goto TR : Endif

#########################################################################

$OUVRE
#FQXXXXXX Local File FXDASSETS [FAS], PHYELT [PHY], AREPORTM [ARM]
Local File FXDASSETS [FAS], PHYELT [PHY], AREPORTM [ARM], PHYMVT [PMVT]
Return

$DECLARE
Local Char    CRITERE(255), CRITERE2(255), PARAM(30) , VALEUR(30) , ETAT(GLONARP)
Local Integer WNUMLIG, NUMREQ(8), I, J
Return

