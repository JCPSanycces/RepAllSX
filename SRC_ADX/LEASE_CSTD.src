#<AdxTL>@(#)1.0.0.0 $Revision$
# Classe LEASE

###############
# CLASS LEASE
###############
$ACTION
  Case CURPRO
    When ""         : Gosub METHODS    : # If CURPRO is empty, we are on class methods
    When Default    : Gosub PROPERTIES : # Otherwise it is a hook called on properties
  Endcase
Return
###############
# METHODS
###############
$METHODS
  Case CURPTH
     When ""
       Case ACTION
          When "AREAD_AFTER"  : Gosub AREAD_AFTER_LEA
       Endcase
  Endcase
Return

#===========================================================
$AREAD_AFTER_LEA

  Local Integer I, N
  Local Integer CNXPROIAS
  Local Decimal MTDES
  Local Integer STAT

  ## Récupération des biens rattachés au contrat
  Local File FXDASSETS [FAS]
  For [FAS]FAS12 Where LEAREF=this.LEAREF
    N = fmet this.ADDLINE("FASSETS",-1)
    SetInstance this.FASSETS(N) With [F:FAS]
  Next

  ## Récupération des informations pour le bloc Valorisation
  CNXPROIAS = 1
  Local File CONTEXT   [CNX]
  For [CNX] Where CPY=this.CPY
     I= find(6,[F:CNX]PLNCAA(0..14)) : # G301IAS = 6
     If ( I > 0 ) Then
       CNXPROIAS = 2
       Break
     Endif
  Next

  Local File ELEACRT  [F:E42]
  Local File ELEAACTU [F:E41]

  For[E42] Where (CPY=this.CPY & REF=this.LEAREF & DPRPLN = 1)  : # Plan comptable
    N = fmet this.ADDLINE("FE41E42",-1)
    this.FE41E42(N).VCUTDAT    = [F:E42]EVTDAT
    this.FE41E42(N).VLEAAMT    = [F:E42]LEAAMT
    this.FE41E42(N).VRATCUR    = this.RATCUR

    If (this.FE41E42(N).VLEAAMT <> 0) Then
      # ------------- Conversion en devise société
      Call CONVERT3(this.LEACUR, this.CUR, this.CUR, this.CURTYP, this.STRLEADAT,
&                   [F:E42]LEAAMT, MTDES,0 , STAT) From CPTSUB
      If STAT = 0 Then
        Call GET_MNT_ARRONDI (MTDES, this.CUR, MTDES) From GLOBIENS
        this.FE41E42(N).VLEAAMTDEV = MTDES
      Endif
      If ( CNXPROIAS = 2 ) Then
        this.FE41E42(N).VIASRATCUR  = this.IASRATCUR
        # ------------- Conversion en devise IAS
        Call CONVERT3(this.LEACUR, this.IASCUR, this.IASCUR, this.IASCURTYP, this.STRLEADAT,
&                     [F:E42]LEAAMT, MTDES, 0 , STAT) From CPTSUB
        If (STAT=0) Then
          Call GET_MNT_ARRONDI (MTDES, this.IASCUR, MTDES) From GLOBIENS
          this.FE41E42(N).VLEAAMTIAS = MTDES
        Endif
      Endif
    Endif
    Break
  Next

  For[E41] Where (CPY=this.CPY & REF=this.LEAREF & DPRPLN = 1)
    N = fmet this.ADDLINE("FE41E42",-1)
    this.FE41E42(N).VCUTDAT    = [F:E41]EVTDAT
    this.FE41E42(N).VLEAAMT    = [F:E41]LEAAMTN
    this.FE41E42(N).VRATCUR    = this.RATCUR

    If (this.FE41E42(N).VLEAAMT <> 0) Then
      # ------------- Conversion en devise société
      Call CONVERT3(this.LEACUR, this.CUR, this.CUR, this.CURTYP, this.STRLEADAT,
&                 this.FE41E42(N).VLEAAMT, MTDES, this.RATCUR, STAT) From CPTSUB
      If STAT = 0 Then
        Call GET_MNT_ARRONDI (MTDES, this.CUR, MTDES) From GLOBIENS
        this.FE41E42(N).VLEAAMTDEV = MTDES
      Endif


      If ( CNXPROIAS = 2 ) Then
        this.FE41E42(N).VIASRATCUR  = this.IASRATCUR
        # ------------- Conversion en devise IAS
        Call CONVERT3(this.LEACUR, this.IASCUR, this.CUR, this.IASCURTYP, this.STRLEADAT,
&                     this.FE41E42(N).VLEAAMT, MTDES, this.IASRATCUR, STAT) From CPTSUB
        If (STAT = 0) Then
          Call GET_MNT_ARRONDI (MTDES, this.IASCUR, MTDES) From GLOBIENS
          this.FE41E42(N).VLEAAMTIAS = MTDES
        Endif
      Endif
    Endif
  Next


Return

#############
# PROPERTIES
#############
$PROPERTIES
  Case CURPRO
    When Default
  Endcase
Return

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

