  Gosub SPECIFIC_AFRICA
  Gosub SPECIFIC_KIMEA
  #Gosub SPECIFIC_FRANCE
  #Gosub SPECIFIC_PORTUGAL

Return
#End

$RESET_BLOCK_TITLES

Return
