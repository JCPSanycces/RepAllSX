#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
    When ""
        Case [L]AEVENT
            When "AINSERT_CONTROL_BEFORE" : Gosub EVENT_CONTROL_BEFORE
            When "AUPDATE_CONTROL_BEFORE" : Gosub EVENT_CONTROL_BEFORE
        Endcase
    Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
    Case [L]CURPRO
        When "CPY"    : Gosub PROPERTY_CPY
        When "FCY"    : Gosub PROPERTY_FCY
        When "CPYFCY" : Gosub PROPERTY_CPYFCY
    Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

########################################################################################################################

$EVENT_CONTROL_BEFORE
    Local Integer I, J, N
    [L]N = 0

    # loop through all lines
    For [L]I = 1 To maxtab(this.LINES)
        If this.LINES([L]I) <> null
&           and this.LINES([L]I).ASTALIN <> [V]CST_ADEL
&           and this.LINES([L]I).ASTALIN <> [V]CST_ANEWDEL
&       Then
            [L]N += 1
            If this.LINES([L]I).AORDER  <> this.LINES([L]I).LIN Then
                # delete the line
                ASTATUS = fmet this.ADELLINE("LINES", this.LINES([L]I).AORDER)
                # add new line
                [L]J = fmet this.ADDLINE("LINES", this.LINES([L]I).AORDER)
                If [L]J <> [V]CST_ANOTDEFINED Then
                    # copy contents
                    this.LINES([L]J).CPY       = this.CPY
                    this.LINES([L]J).FCY       = this.FCY
                    this.LINES([L]J).FILFMT    = this.FILFMT
                    this.LINES([L]J).LIN       = this.LINES([L]I).AORDER
                    this.LINES([L]J).PFXINV    = this.LINES([L]I).PFXINV
                    this.LINES([L]J).LENINVSTR = this.LINES([L]I).LENINVSTR
                    this.LINES([L]J).LENINVEND = this.LINES([L]I).LENINVEND
                    this.LINES([L]J).PFXTYP    = this.LINES([L]I).PFXTYP
                    this.LINES([L]J).DIR       = this.LINES([L]I).DIR
                    this.LINES([L]J).OPT       = this.LINES([L]I).OPT
                    this.LINES([L]J).LNG       = this.LINES([L]I).LNG
                    this.LINES([L]J).STRPOS    = this.LINES([L]I).STRPOS
                Endif
            Endif
        Endif
    Next [L]I
    If [L]N = 0 Then
        ASTATUS = fmet this.ASETERROR("", mess(32,7703,1), [V]CST_AERROR)
    Endif
Return


$PROPERTY_CPY
    Case [L]ARULE
        When "CONTROL"
            Gosub CHECK_FCY_VS_CPY From BSILIB
    Endcase
Return

$PROPERTY_FCY
    Case [L]ARULE
        When "CONTROL"
            Gosub CHECK_FCY_VS_CPY From BSILIB
    Endcase
Return

$PROPERTY_CPYFCY
    Case [L]ARULE
        When "GET"
            this.CPYFCY = this.CPY + "~" + this.FCY
    Endcase
Return

