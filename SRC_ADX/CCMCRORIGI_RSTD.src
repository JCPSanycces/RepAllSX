#<AdxTL>@(#)0.0.0.0 $Revision$
# Representation script: CCMCRORIGI_RSTD, Change Request - Originator User Collection
# Issue 109094/19 - 2015-11-27 by BAKHA : For non-conformance, check for QA manager

#####################
# METHODS           #
#####################
$METHODS

  Case CURPTH
    When "CCMCR.CCMCRORIGI" , "NCSREC.CCMCRORIGI" # Issue 109094/19
     Case ACTION
        When "AREAD_AFTER"
          Gosub POPULATE_ORIGINATOR_USER
          Gosub ACTIVATE_FIELDS
       When "ADDLINE_BEFORE"
          Gosub CHECK_STATUS
       When "ADELLINE_BEFORE"
          Gosub CHECK_ADELLINE
      Endcase
  Endcase

Return

# --------------------------------------------------
# Populate originator user display only properties.
$POPULATE_ORIGINATOR_USER
  Local Integer LOCSTATUS
  Local Instance SELUSER Using C_AUTILIS

  SELUSER = NewInstance C_AUTILIS AllocGroup null
  LOCSTATUS = fmet SELUSER.AREAD(this.USER)
  If (LOCSTATUS = [V]CST_AOK)
    this.TELEP = SELUSER.TELEP
    this.ADDEML = SELUSER.ADDEML
    this.USERNAME = SELUSER.NOMUSR
  Endif
  FreeGroup SELUSER

Return

# --------------------------------------------------
# Enable / disable external fields at a child class level.
$ACTIVATE_FIELDS

  Local Integer LOCSTATUS, MANAGER

  # Issue 109094/19 - check for either Change manager or QA Manager
  MANAGER = CST_AFALSE
  If (this.APARENT.NCSREC = 2)
    If (this.ACTX.USER = this.APARENT.NCSMANAGER)
      MANAGER = CST_ATRUE
    Endif
  Else
    If (this.ACTX.USER = this.APARENT.CCMUSRID)
      MANAGER = CST_ATRUE
    Endif
  Endif
  # End issue 109094/19

  LOCSTATUS = fmet this.ASETATTRIBUTE("ADDEML",   "$isDisabled",  "true")
  LOCSTATUS = fmet this.ASETATTRIBUTE("USERNAME",   "$isDisabled",  "true")
  LOCSTATUS = fmet this.ASETATTRIBUTE("TELEP",   "$isDisabled",  "true")
  # disable or enable fields depending on who can amend
  # Issue 109094/19
  If (this.APARENT.CRSTATUS = 7 or (MANAGER = CST_AFALSE and this.ACTX.USER <> this.CREUSR))
  # End issue 109094/19
    LOCSTATUS = fmet this.ASETATTRIBUTE("USER", "$isDisabled",  "true")
  Else
    LOCSTATUS = fmet this.ASETATTRIBUTE("USER", "$isDisabled",  "false")
  Endif

Return

# --------------------------------------------------
# Clear (any) errors.
$CLEAR_ERRORS

  ASTATUS = fmet this.ADELETEERROR ("")

Return

# --------------------------------------------------
# Check the change request is not Rejected (3), Completed (6) or Closed (7).
$CHECK_STATUS

  Gosub CLEAR_ERRORS

  If (this.CRSTATUS = 7)
      ASTATUS = fmet this.ASETERROR ("", mess(8,2038,1), [V]CST_AERROR)
  Endif

Return

# --------------------------------------------------
# Internal user collection: before ADELLINE check the logged-in user is the Change Manager ...
$CHECK_ADELLINE

  Local Char MESSAGE(100)

  Gosub CLEAR_ERRORS
  If (this.CRSTATUS = 7)
      ASTATUS = fmet this.ASETERROR ("", mess(8,2038,1), [V]CST_AERROR)
  Else
    # Issue 109094/19 - check for either Change manager or QA Manager
    If (this.NCSREC = 2)
      If (this.ACTX.USER <> this.NCSMANAGER and this.ACTX.USER <> this.CCMCRORIGI.CREUSR)
        ASTATUS = fmet this.ASETERROR ("", mess(76,2038,1), [V]CST_AERROR)
      Endif
    Else
      If (this.ACTX.USER <> this.CCMUSRID and this.ACTX.USER <> this.CCMCRORIGI.CREUSR)
        ASTATUS = fmet this.ASETERROR ("", mess(76,2038,1), [V]CST_AERROR)
      Endif
    Endif
    # End issue 109094/19
  Endif
Return

#####################
# PROPERTIES        #
#####################
$PROPERTIES

  Case CURPRO
    When "CCMCR.CCMCRORIGI.USER" , "NCSREC.CCMCRORIGI.USER"      # Issue 109094/19
      Case ACTION
        When "PROPAGATE"
          Gosub POPULATE_ORIGINATOR_USER
      Endcase
  Endcase

Return


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

