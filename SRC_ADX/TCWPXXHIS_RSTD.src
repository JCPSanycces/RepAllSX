#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe TCWPXXHIS_RSTD

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AQUERY_DECODE_CRITERIA_AFTER" : Gosub DECLARE : Gosub AQUERY_DECODE_CRITERIA_AFTER  From TCWPXX_RSTD_EVENTS
        When "AQUERY_PRIMARYKEYS_AFTER"     : Gosub DECLARE : Gosub AQUERY_PRIMARYKEYS_AFTER      From TCWPXX_RSTD_EVENTS
        When "AQUERY_OPEN_AFTER"            : Gosub DECLARE : Gosub AQUERY_OPEN_AFTER             From TCWPXX_RSTD_EVENTS
        When "AQUERY_TRANS_AFTER"           : Gosub DECLARE : Gosub AQUERY_TRANS_AFTER            From TCWPXX_RSTD_EVENTS
        When "AQUERY_CLOSE_AFTER"           : Gosub DECLARE : Gosub AQUERY_CLOSE_AFTER            From TCWPXX_RSTD_EVENTS
        When "AREAD_AFTER"                  : Gosub DECLARE : Gosub AREAD_AFTER                   From TCWPXX_RSTD_EVENTS
      Endcase
  Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################

$DECLARE
  Local Char WREP(10)    : WREP    = ""
  Local Char WCODOBJ(3)  : WCODOBJ = "PXX"
Return

