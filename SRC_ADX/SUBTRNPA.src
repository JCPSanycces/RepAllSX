#-------------------------------------------------------------#
$OUVRE
#------------------------------------------------------------#
# Ouverture masques de critères picking                      #
#------------------------------------------------------------#
#Pour utiliser le CRUD de la classe et  pas celui de l'objet
ANOWRITE = 1
#Local File TRANSPORT  [TRNP]
Local File TABPLACE [TPC]
Local File BPADDRESS [BPA]
Local File TABPLACETIME [TPCT]
Local File SHIPMENT [SHH]
Local File SHIPMENTD [SHD]
Local File SHIPDOC [SHIPD]  #111257 US 20
Local File SHIPTRACK [SHIPT]  #111257 US 43
Local Char WTIT(150)
#----- Variables locales pour gestion picking liste de gauche, etc ... -----#
Gosub DECL_VAR_LOCAL
#----- Déclaration des variables pour tableau lignes -----#
Gosub DECLARE From TABLEAUX
#gestion de la classe des TRANSPORT
Global Instance WTRANSPORT Using C_TRANSPORT
Local Char WMESS(250)
Local Integer MY_STATUS, WRET, I, WTRKCMP, WNBLIG # Issue 111257 US 43
Return

#-------------------------------------------------------------#
$VALLIG
#-------------------------------------------------------------#
Case TRTLIG
  When "C"   Gosub CRELIG
  When "M"   If SIGN = -1 Gosub MODLIG Endif
  When "A"   Gosub SUPLIG
Endcase

Return


#-------------------------------------------------------------#
#Insertion d'une ligne dans la classe des transport           #
#-------------------------------------------------------------#
$CRELIG
Local Integer WPOS
WPOS = fmet WTRANSPORT.ADDLINE("EVT",[V]CST_ALASTPOS)
If WPOS = [V]CST_ANOTDEFINED
  #--The insertion was not possible
  GMESSAGE = func ASYRFNC.MES2(mess(266,133,1),'EVT','TRANSPORT')
  GOK=0 : GERR=1
  Return
Endif
WTRANSPORT.EVT(WPOS).TRNNUM = [M:TRNP0]TRNNUM
WTRANSPORT.EVT(WPOS).EVTNUM = [M:TRNP2]EVTNUM(nolign-1)
WTRANSPORT.EVT(WPOS).EVTCOD = [M:TRNP2]EVTCOD(nolign-1)
WTRANSPORT.EVT(WPOS).DAT    = [M:TRNP2]DAT(nolign-1)
WTRANSPORT.EVT(WPOS).CMT    = [M:TRNP2]CMT(nolign-1)
# Issue 111257-US39 - 2016-01-21 by MAE
WTRANSPORT.EVT(WPOS).EVTLTI = [M:TRNP2]EVTLTI(nolign-1)

Return

#-------------------------------------------------------------#
#Mise à jour d'une ligne de la classe des transports          #
#-------------------------------------------------------------#
$MODLIG
Local Integer WPOS
#recherche de l'AUUID de la ligne modifiée : classe F
WPOS = find([F:EVT]AUUID, WTRANSPORT.EVT(1..maxtab(WTRANSPORT.EVT)).AUUID)
If WPOS <>0
  WTRANSPORT.EVT(WPOS).TRNNUM = [M:TRNP0]TRNNUM
  WTRANSPORT.EVT(WPOS).EVTNUM = [M:TRNP2]EVTNUM(nolign-1)
  WTRANSPORT.EVT(WPOS).EVTCOD = [M:TRNP2]EVTCOD(nolign-1)
  WTRANSPORT.EVT(WPOS).DAT    = [M:TRNP2]DAT(nolign-1)
  WTRANSPORT.EVT(WPOS).CMT    = [M:TRNP2]CMT(nolign-1)
  # Issue 111257-US39 - 2016-01-21 by MAE
  WTRANSPORT.EVT(WPOS).EVTLTI = [M:TRNP2]EVTLTI(nolign-1)
Endif

Return

#-------------------------------------------------------------#
#Suppression d'une ligne dans la classe des transports        #
#-------------------------------------------------------------#
$SUPLIG
Local Integer WPOS
Raz WRET
If (TRTLIG = "A" & GREP<>"A")
  WPOS = find([F:EVT]AUUID, WTRANSPORT.EVT(1..maxtab(WTRANSPORT.EVT)).AUUID)
  If WPOS <> 0
    WRET=fmet WTRANSPORT.ADELLINE ("EVT", WTRANSPORT.EVT(WPOS).AORDER)
    If WRET<>[V]CST_AOK
      GMESSAGE = func ASYRFNC.MES2(mess(273,133,1),'EVT','TRANSPORT')
      GOK=0 : GERR=1
      Return
    Endif
  Endif
Endif

Return

$SETBOUT
#-------------------------------------------#
# pas de duplication                        #
#-------------------------------------------#

# A VOIR AVEC TS JAM SI ON FAIT OU PAS ...
#Call VIREBOUT (CHAINE,"D")    From GOBJET

If !find(GREP,"C","D") and !find("CONSPIA",GNAVIG(1..GPILNAV)) Then CHMEN += "O" Endif # FGR 01/06/2015 : X3SUIVI104697
Return

#-------------------------------------------------------------#
# Issue 111257 US3
$RAZCRE
#MAE, landed cost 110325
If WTRANSPORT<> null : FreeGroup WTRANSPORT :Endif
WTRANSPORT = NewInstance C_TRANSPORT AllocGroup null
[L]MY_STATUS = fmet WTRANSPORT.AINIT()
If [L]MY_STATUS >= [V]CST_AERROR
  #--- Header errors
  GMESSAGE = func LCCLIB.MAXMSG(WSHIPMENT)
  If GMESSAGE <> AVOID.ACHAR :  GOK=0 : GERR=1: Return
  Endif
   #Erreurs des lignes
  For I=1 To maxtab(WTRANSPORT.EVT)
    GMESSAGE = func LCCLIB.MAXMSG(WTRANSPORT.EVT(I))
    If GMESSAGE <> AVOID.ACHAR :   GOK=0 : GERR=1: Break
    Endif
  Next I
  # Issue 111257 US 20
  #Erreurs des lignes de documents
  For I=1 To maxtab(WTRANSPORT.SHIPD)
    GMESSAGE = func LCCLIB.MAXMSG(WTRANSPORT.SHIPD(I))
    If GMESSAGE <> AVOID.ACHAR :   GOK=0 : GERR=1: Break
    Endif
  Next I
  # End issue 111257 US 20
Endif
# Les champs initialisés par la classe sont remis dans la classe et dans la classe F
SetInstance [F:TRNP] With WTRANSPORT
[M:TRNP1]=[F:TRNP]
Affzo [M:TRNP1]
Return
