#-------------------------------------------------------------#
$INICRE
Gosub SEARCHARVEXPDAT
# Issue 111257 : remis en RAZCRE
#WTRANSPORT = NewInstance C_TRANSPORT AllocGroup null
Return

$LIENS
#------------------------------------#
#lecture de la classe
WTRANSPORT = NewInstance C_TRANSPORT AllocGroup null

WTRANSPORT.TRNNUM=[M:TRNP0]TRNNUM
WRET = fmet WTRANSPORT.AREAD([M:TRNP0]TRNNUM)
If WRET <> [V]CST_AOK
  #Erreurs de l'entete
  GMESSAGE = func LCCLIB.MAXMSG(WTRANSPORT)
  If GMESSAGE <> AVOID.ACHAR :  GOK=0 : GERR=1: Return
  Endif
  #Erreurs des lignes
  For I=1 To maxtab(WTRANSPORT.EVT)
    GMESSAGE = func LCCLIB.MAXMSG(WTRANSPORT.EVT(I))
    If GMESSAGE <> AVOID.ACHAR :   GOK=0 : GERR=1: Break
    Endif
  Next I
  # Issue 111257 US 20
  #Erreurs des lignes de documents
  For I=1 To maxtab(WTRANSPORT.SHIPD)
    GMESSAGE = func LCCLIB.MAXMSG(WTRANSPORT.SHIPD(I))
    If GMESSAGE <> AVOID.ACHAR :   GOK=0 : GERR=1: Break
    Endif
  Next I
  # End issue 111257 US 43
   #Erreurs des lignes de STEP TRACKING
  For I=1 To maxtab(WTRANSPORT.SHIPT)
    GMESSAGE = func LCCLIB.MAXMSG(WTRANSPORT.SHIPT(I))
    If GMESSAGE <> AVOID.ACHAR :   GOK=0 : GERR=1: Break
    Endif
  Next I
  # End issue 111257 US 43
  If GOK=0 : Return : Endif
Endif
Gosub LIENS From TABLEAUX

# recherche des pays
#départ
Filter [F:BPA] Where BPATYP=8 & BPANUM = [M:TRNP1]DPETPC
Read [F:BPA] First
If fstat = 0
  [M:TRNP1]DPECRY = [F:BPA]CRY
Else
  [M:TRNP1]DPECRY = AVOID.ACHAR
Endif

#arrivée
Filter [F:BPA] Where BPATYP=8 & BPANUM = [M:TRNP1]ARVTPC
Read [F:BPA] First
If fstat = 0
  [M:TRNP1]ARVCRY = [F:BPA]CRY
Else
  [M:TRNP1]ARVCRY = AVOID.ACHAR
Endif

Gosub GESTRNP

#Call LECTEXTRA([M:TRNP0]DESAXX,"TRANSPORT","DESAXX",[M:TRNP0]TRNNUM,"") From ATEXTRA
[M:TRNP0]DESAXX = WTRANSPORT.DESAXX
# Issue 112979 : remplissage de l'onglet des expéditions
Filter [SHH] Where TRNNUM = [M:TRNP0]TRNNUM
For [SHH]
  Gosub CHARG_EXP
Next
Filter [SHH]
# Issue 111257 US 20
#affichage de l'onglet documents
nolign = 1
Filter[SHIPD] Where [F:SHIPD]VCRNUM = [F:TRNP]TRNNUM & [F:SHIPD]VCRTYP = 39
For [SHIPD]
  [M:TRNPD] = [F:SHIPD]
   If [F:SHIPD]SDFILNAM <> AVOID.ACHAR
    [M:TRNPD]SDDOC(nolign-1) = "175"
   Endif
  nolign += 1
Next
[M:TRNPD]NBLIG = nolign - 1
# End issue 111257 US 20
# Issue 111257 US 43
#affichage de l'onglet suivi
WNBLIG = 0 : WTRKCMP = 0
nolign = 1
Filter[SHIPT] Where [F:SHIPT]VCRNUM = [F:TRNP]TRNNUM & [F:SHIPT]VCRTYP = 39
& Order By [F:SHIPT]TRKSORT Asc
For [SHIPT]
  [M:TRNPT] = [F:SHIPT]
  [M:TRNPT]COLLIN(nolign-1) = fmet WTRANSPORT.SHIPT_GET_INDEX([F:SHIPT]STLIN)
  If [M:TRNPT]TRKMDY(nolign-1) = CST_AYES
    WNBLIG += 1
    If [M:TRNPT]TRKENDDAT(nolign-1) <> AVOID.ADATE
      #[M:TRNPT]TRKLIGSTAT(nolign-1) = 2
      WTRKCMP += 1
    Else
      #[M:TRNPT]TRKLIGSTAT(nolign-1) = 1
    Endif
  Endif
  nolign += 1
Next
If WTRKCMP = WNBLIG & WNBLIG <> 0
   [M:TRNPT]TRKSTAT = 3
Else  [M:TRNPT]TRKSTAT = 1
Endif
[M:TRNPT]NBLIGNE = nolign - 1
# End issue 111257 US 43
Affzo [M:TRNP0]
Affzo [M:TRNP1]
Affzo [M:TRNP2]
Affzo [M:TRNPD] #111257 US 20
Affzo [M:TRNPT] #111257 US 43
Return

#-------------------------------------------------------------#
$APRES_MOD
Gosub LIENS From TABLEAUX
Return

#-------------------------------------------------------------#
$APRES_CRE
Gosub LIENS From TABLEAUX
Return

#-------------------------------------------------------------#
$DEFLIG
#----------------------------------#
# Définition du fichier des lignes #
#----------------------------------#
Default Mask [TRNP2]
Default File [EVT]
CRIT   = 'TRNNUM="'+[M:TRNP0]TRNNUM+'"'
FICLIG = "EVENTTRNP"
ABLIG  = "EVT"
ZONLIG = "EVTNUM"
Return


#-------------------------------------------------------------#
$AV_ANNULE
#--------------------------------------------#
# avant annulation des lignes de transport   #
#--------------------------------------------#
Local Integer ANOWRITE
#gestion de la classe des TRANSPORT
Global Instance WTRANSPORT Using C_TRANSPORT
Local Char WMESS(250)
Local Integer MY_STATUS, WRET

WTRANSPORT = NewInstance C_TRANSPORT AllocGroup null
ANOWRITE = 1

WTRANSPORT.TRNNUM=[M:TRNP0]TRNNUM
WRET = fmet WTRANSPORT.AREAD([M:TRNP0]TRNNUM)
If WRET <> [V]CST_AOK
  #Erreurs de l'entete
  GMESSAGE = func LCCLIB.MAXMSG(WTRANSPORT)
  If GMESSAGE <> AVOID.ACHAR :  GOK=0 : GERR=1: Return
  Endif
  #Erreurs des lignes
  For I=1 To maxtab(WTRANSPORT.EVT)
    GMESSAGE = func LCCLIB.MAXMSG(WTRANSPORT.EVT(I))
    If GMESSAGE <> AVOID.ACHAR :   GOK=0 : GERR=1: Break
    Endif
  Next I
  If GOK=0 : Return : Endif
Endif

Return

#-------------------------------------------------------------#
$ANNULE
#--------------------------------------#
# Annulation des lignes de transport   #
#--------------------------------------#
Local Integer I,MY_STATUS
Gosub ANNULE From TABLEAUX
MY_STATUS = fmet WTRANSPORT.ADELETE()
If [L]MY_STATUS <> [V]CST_AOK
  #Erreurs de l'entete
  GMESSAGE = func LCCLIB.MAXMSG(WTRANSPORT)
  If GMESSAGE <> AVOID.ACHAR :  GOK=0 : GERR=1: Return
  Endif
  #Erreurs des lignes
  For I=1 To maxtab(WTRANSPORT.EVT)
    GMESSAGE = func LCCLIB.MAXMSG(WTRANSPORT.EVT(I))
    If GMESSAGE <> AVOID.ACHAR :   GOK=0 : GERR=1: Break
    Endif
  Next I
  # Issue 111257 US 20
  #Erreurs des lignes de documents
  For I=1 To maxtab(WTRANSPORT.SHIPD)
    GMESSAGE = func LCCLIB.MAXMSG(WTRANSPORT.SHIPD(I))
    If GMESSAGE <> AVOID.ACHAR :   GOK=0 : GERR=1: Break
    Endif
  Next I
  # Issue 111257 US 43
  #Erreurs des lignes de tracking
  For I=1 To maxtab(WTRANSPORT.SHIPT)
    GMESSAGE = func LCCLIB.MAXMSG(WTRANSPORT.SHIPT(I))
    If GMESSAGE <> AVOID.ACHAR :   GOK=0 : GERR=1: Break
    Endif
  Next I
  # End issue 111257 US 43
  If GOK=0 : Return : Endif
Endif
Return

#-------------------------------------------------------------#
$ABANDON
#----- Mise à jour des listes de gauche picking -----#
If GREP="C" & !GIMPORT & BOUT="A"
  Raz [M:TRNP0], [M:TRNP1], [M:TRNP2]
  Actzo [TRNP0] : Actzo [TRNP1]10-99 :Actzo [TRNP2]
Endif
Return

#-------------------------------------------------------------#
$CREATION
#----------------------------------#
# Création des lignes de INCIDENT #
#----------------------------------#
Gosub CREATION From TABLEAUX
If GOK<1 : Return : Endif
SetInstance WTRANSPORT With [F:TRNP]
WTRANSPORT.DESAXX = [M:TRNP0]DESAXX
# Issue 111257 US20 - 2016-01-11 by MAE : REMPLISSAGE DE LA COLLECTION DES DOCUMENTS
Gosub CREATE_DOCUMENTS
# Issue 111257 US 43 - 2016-04-25 by MAE : remplissage de la collection des STEP TRACKING
Call COPY_SCREEN_TO_CLASS()
If GERR=1
  Return
Endif
#SHIPSLAG n'est pas ds la classe F et est utilisé ds AINSERT_CONTROL
WTRANSPORT.SHIPSLAG = [M:TRNP1]SHIPSLAG
# End issue 111257
MY_STATUS = fmet WTRANSPORT.AINSERT()
If [L]MY_STATUS <> [V]CST_AOK
   #Erreurs de l'entete
  GMESSAGE = func LCCLIB.MAXMSG(WTRANSPORT)
  If GMESSAGE <> AVOID.ACHAR :  GOK=0 : GERR=1: Return
  Endif
  #Erreurs des lignes
  For I=1 To maxtab(WTRANSPORT.EVT)
    GMESSAGE = func LCCLIB.MAXMSG(WTRANSPORT.EVT(I))
    If GMESSAGE <> AVOID.ACHAR :   GOK=0 : GERR=1: Break
    Endif
  Next I
  # Issue 111257 US 20
  #Erreurs des lignes de document
  For I=1 To maxtab(WTRANSPORT.SHIPD)
    GMESSAGE = func LCCLIB.MAXMSG(WTRANSPORT.SHIPD(I))
    If GMESSAGE <> AVOID.ACHAR :   GOK=0 : GERR=1: Break
    Endif
  Next I
  # End issue 111257 US 20
   # Issue 111257 US 43
  #Erreurs des lignes de STEP TRACKING
  For I=1 To maxtab(WTRANSPORT.SHIPT)
    GMESSAGE = func LCCLIB.MAXMSG(WTRANSPORT.SHIPT(I))
    If GMESSAGE <> AVOID.ACHAR :   GOK=0 : GERR=1: Break
    Endif
  Next I
  # End issue 111257 US 20

  If GOK=0 : Return : Endif
Endif

[M:TRNP0]TRNNUM = WTRANSPORT.TRNNUM
[F:TRNP]TRNNUM = [M:TRNP0]TRNNUM
# Issue 111257
SetInstance [M:TRNP1] With WTRANSPORT

Gosub LIENS
Return

#-------------------------------------------------------------#
$MODIF
#--------------------------------------#
# Modification des lignes de TRANSPORT #
#--------------------------------------#
Gosub MODIF From TABLEAUX : If GOK<1  Return : Endif

# Issue 111257
SetInstance WTRANSPORT With [M:TRNP1]
WTRANSPORT.TRNUID     = [M:TRNP0]TRNUID
WTRANSPORT.DESAXX     = [M:TRNP0]DESAXX

# Issue 111257-US20 - 2016-01-11 by MAE : modification de l'onglet documents
Gosub MODIF_DOCUMENTS

# Issue 111257 US 43 - 2016-04-25 by MAE : modification de l'onglet "Suivi"
# Issue 53822, suppression du IF
#If [M:TRNPT]TRKNUM = AVOID.ACHAR
  Gosub MODIF_TRACKING
#Endif

MY_STATUS = fmet WTRANSPORT.AUPDATE()
If [L]MY_STATUS <> [V]CST_AOK
 #Erreurs de l'entete
  GMESSAGE = func LCCLIB.MAXMSG(WTRANSPORT)
  If GMESSAGE <> AVOID.ACHAR :  GOK=0 : GERR=1: Return
  Endif
  #Erreurs des lignes
  For I=1 To maxtab(WTRANSPORT.EVT)
    GMESSAGE = func LCCLIB.MAXMSG(WTRANSPORT.EVT(I))
    If GMESSAGE <> AVOID.ACHAR :   GOK=0 : GERR=1: Break
    Endif
  Next I
  # Issue 111257 US 20
  #Erreurs des lignes de documents
  For I=1 To maxtab(WTRANSPORT.SHIPD)
    GMESSAGE = func LCCLIB.MAXMSG(WTRANSPORT.SHIPD(I))
    If GMESSAGE <> AVOID.ACHAR :   GOK=0 : GERR=1: Break
    Endif
  Next I
  # End issue 111257 US 20
   # Issue 111257 US 43
  #Erreurs des lignes de STEP TRACKING
  For I=1 To maxtab(WTRANSPORT.SHIPT)
    GMESSAGE = func LCCLIB.MAXMSG(WTRANSPORT.SHIPT(I))
    If GMESSAGE <> AVOID.ACHAR :   GOK=0 : GERR=1: Break
    Endif
  Next I
  # End issue 111257 US 43
  If GOK=0 : Return : Endif
Endif

If GOK<1 Return : Endif
# Issue 111257
SetInstance [M:TRNP1] With WTRANSPORT

Gosub LIENS
Return

#-------------------------------------------------------------#
$INICRE_LIG
#----------------------------#
# Avant le Write de la ligne #
#----------------------------#
[F:EVT]=[M:TRNP2]
Return

#------------------------------------#
#Lecture des lignes                  #
#------------------------------------#
$LIENS_LIG
#------------------------------------#
NOL = nolign-1
I = nolign
#Lecture de l'incident
If WTRANSPORT.EVT(I)<>null and find(WTRANSPORT.EVT(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)<1
  Read [EVT] EVT0=WTRANSPORT.TRNNUM;WTRANSPORT.EVT(I).EVTNUM
  If fstat Raz [F:EVT] : Endif
  [M:TRNP2]EVTNUM(NOL) = WTRANSPORT.EVT(I).EVTNUM
  [M:TRNP2]EVTCOD(NOL) = WTRANSPORT.EVT(I).EVTCOD
  [M:TRNP2]DAT(NOL)    = WTRANSPORT.EVT(I).DAT
  [M:TRNP2]CMT(NOL)    = WTRANSPORT.EVT(I).CMT
  # Issue 111257-US39 - 2016-01-21 by MAE
  [M:TRNP2]EVTLTI(NOL) = WTRANSPORT.EVT(I).EVTLTI
Endif
Return

#-------------------------------------------------------------#
$FERME
#--------------------------------------#
# Annulation des lignes de transport   #
#--------------------------------------#
If WTRANSPORT<> null
  FreeGroup WTRANSPORT
Endif
Return


#-------------------------------------------------------------#
$SEARCHARVEXPDAT
Read [TPCT]TPCT0 = [M:TRNP1]DPETPC;[M:TRNP1]ARVTPC;[M:TRNP1]TRNMOD; [M:TRNP1]BPTNUM
If fstat
  Read [TPCT]TPCT0 = [M:TRNP1]DPETPC;[M:TRNP1]ARVTPC;[M:TRNP1]TRNMOD
  If fstat : Raz [F:TPCT] : Endif
Endif

Read [TPC]TPC0 = [M:TRNP1]ARVTPC
If fstat Raz [F:TPC] : Endif

If [M:TRNP1]ARVEXPDAT =[00/00/00]
  [M:TRNP1]ARVEXPDAT = [M:TRNP1]DPEDAT + [F:TPCT]LTITPC + [F:TPC]LTITPC
Endif

Return

#-------------------------------------------------------------#
#Gestion des champs de l'écrans
$GESTRNP
# Issue 110353 - 2015-08-26 by MUARN : ajout nouveaux champs
If [M:TRNP1]TRNMOD = 1
  Raz [M:TRNP1]MBOL, HBOL, WAGNUM, CIM, CMR, CTBL, VESNAM, VESSEL, VOYNUM, ROANAM, REGNUM, WAGNAM, TRANUM
  Affzo [M:TRNP1]1-99
  Diszo [M:TRNP1]20, 30, 35, 40
  Actzo [M:TRNP1]25
Elsif  [M:TRNP1]TRNMOD = 2
  Raz [M:TRNP1]FLINUM, AWB, HAWB, WAGNUM, CIM, CMR, CTBL, FLYNAM, ROANAM, REGNUM, WAGNAM, TRANUM
 Affzo [M:TRNP1]1-99
  Diszo [M:TRNP1]25, 30, 35, 40
  Actzo [M:TRNP1]20
 Elsif  [M:TRNP1]TRNMOD = 3
  Raz [M:TRNP1]MBOL, HBOL, FLINUM, AWB, HAWB, WAGNUM, CIM, CTBL, FLYNAM, VESNAM, VESSEL, VOYNUM, WAGNAM, TRANUM
  Affzo [M:TRNP1]1-99
  Diszo [M:TRNP1]25, 20, 35, 40
  Actzo [M:TRNP1]30
Elsif  [M:TRNP1]TRNMOD = 4
  Raz [M:TRNP1]MBOL, HBOL, FLINUM, AWB, HAWB, CMR, CTBL, FLYNAM, VESNAM, VESSEL, VOYNUM, ROANAM, REGNUM
  Affzo [M:TRNP1]1-99
  Diszo [M:TRNP1]25, 20, 30, 40
  Actzo [M:TRNP1]35
Else
  Affzo [M:TRNP1]1-99
  Actzo [M:TRNP1]25, 20, 30, 35, 40
Endif
Return

# Issue 112979 : remplissage de l'onglet des expéditions
#-------------------------------------------------------------#
# Chargement de l'écran des expéditions                      #
#-------------------------------------------------------------#
$CHARG_EXP
#-----
Local Integer WNBRECEPT,WNBPRECEPT,WNBCREE
WNBRECEPT=0:WNBPRECEPT=0:WNBCREE=0
# Ouverture de la ligne
SAVNOLIGN = nolign
nolign = [M:TRNP3]NBEXPE
# Issue X3-86303
If nolign >= 100
  GMESSAGE = mess(26,100,1)
  GOK = 0 : GERR = 1
  Return
Endif
# End issue X3-86303
Insa nolign,1,[M:TRNP3]NBEXPE [M:TRNP3]NBEXPE
[M:TRNP3]NBEXPE += 1
nolign = [M:TRNP3]NBEXPE
status = 0
#lecture des lignes d'expé pour calculer le statut
#ISSUE 6079 : le statut est stocké dans la table SHIPMENT
#Filter [SHD] Where SHIPNUM=[F:SHH]SHIPNUM
#For [SHD]
#  If ([F:SHD]CLEFLG = 2) & ([F:SHD]RCPQTYPUU<>0) #receptionné
#    WNBRECEPT += 1
#   Elsif ([F:SHD]PRCPFLG=2)  #pre receptionné
#    WNBPRECEPT += 1
#   Else
#    WNBCREE += 1
#   Endif
#Next
#If WNBRECEPT <> 0 and WNBPRECEPT = 0 and WNBCREE = 0:  [M:TRNP3]SHIPSTAT(nolign-1) = 3
#Elsif WNBRECEPT = 0 and WNBPRECEPT<> 0 and WNBCREE = 0:  [M:TRNP3]SHIPSTAT(nolign-1) = 2
#Else  [M:TRNP3]SHIPSTAT(nolign-1) = 1
#Endif
[M:TRNP3]=[F:SHH]
Filter[SHD]
nolign = SAVNOLIGN
Return
# End Issue 112979

# Issue 111257 US 20
#**
#* Gére la création des lignes de l'onglet "Documents"
#*!
$CREATE_DOCUMENTS
#clean the collection
Local Integer I, INDEX
For I=1 To maxtab(WTRANSPORT.SHIPD)
  If (fmet WTRANSPORT.ADELLINE("SHIPD", WTRANSPORT.SHIPD(I).AORDER) <> [V]CST_AOK)
    GMESSAGE = func ASYRFNC.MES2(mess(273,133,1),'SHIPD','TRANSPORT')
    GOK = 0 : GERR = 1
    Return
  Endif
Next

#fill the collection with the screen
For I = 0 To [M:TRNPD]NBLIG - 1
  INDEX = fmet WTRANSPORT.ADDLINE("SHIPD", [V]CST_ALASTPOS)
  If (INDEX = [V]CST_ANOTDEFINED)
    #--The insertion was not possible
    GMESSAGE = func ASYRFNC.MES2(mess(266,133,1),'SHIPD','TRANSPORT')
    GOK = 0 : GERR = 1
    Break
  Endif

  nolign = I + 1
  NOL = nolign-1
  # Issue 55127 - 2017-09-07 by MAE
  #mise à jour du numéro de ligne
  Call LINNUM("SDLIN") From TABLEAUX
  # End issue 55127
  Call FILL_CLASS_DOC(WTRANSPORT,INDEX,NOL)

Next
If (GERR = 1) : Return : Endif
Return

#**
#* gere la modification des lignes de l'onglet "documents"
#*!
$MODIF_DOCUMENTS
Local Integer I, INDEX
Local Shortint NOL, WENDL, WBEGL

For I = 0 To [M:TRNPD]NBLIG - 1
  nolign = I + 1
  NOL = nolign-1
  # Retrieve the element using the screen's AUUID
  If [M:TRNPD]AUUID(I)<>""
    INDEX = find(toUuid([M:TRNPD]AUUID(I)), WTRANSPORT.SHIPD(1..maxtab(WTRANSPORT.SHIPD)).AUUID)
  Else
    INDEX=0
  Endif
  If (INDEX = 0)
    # We did not find the element matching with the array line.
    # We add a line.
    INDEX = fmet WTRANSPORT.ADDLINE("SHIPD", [V]CST_ALASTPOS)
    If (INDEX = [V]CST_ANOTDEFINED)
        #--The insertion was not possible
        GMESSAGE = func ASYRFNC.MES2(mess(266,133,1),'SHIPD','TRANSPORT')
        GOK = 0 : GERR = 1
        Break
    Endif
    #gestion du numéro de ligne
    #on ne peut pas utiliser LINNUM de Tableaux, car il modifie tous les nums de ligne
    #insertion en première ligne, debut = 0
    If NOL-1<=0
      WBEGL = 0
    Else
      WBEGL = NOL-1
    Endif
    #insertion en derniére ligne
    If [M:TRNPD]SDLIN(NOL+1) = 0
      [M:TRNPD]SDLIN(NOL) = [M:TRNPD]SDLIN(WBEGL) + 1000
      Goto NEXTL
    Else
      WENDL = NOL+1
    Endif
    [M:TRNPD]SDLIN(NOL) = [M:TRNPD]SDLIN(WBEGL) + int(([M:TRNPD]SDLIN(WENDL) - [M:TRNPD]SDLIN(WBEGL))/2)

  Endif
$NEXTL
Call FILL_CLASS_DOC(WTRANSPORT,INDEX,NOL)
Next


If (GERR = 1) : Return : Endif

# Now, all elements that don't have the status Updated or Created must be deleted, because it means they don't match with lines in the array
For I=1 To maxtab(WTRANSPORT.SHIPD)
  If !(find(WTRANSPORT.SHIPD(I).ASTALIN, [V]CST_ANEW, [V]CST_AUPD))
&   and      num$(WTRANSPORT.SHIPD(I).AUUID)<>""
&   and find(num$(WTRANSPORT.SHIPD(I).AUUID),[M:TRNPD]AUUID(0..[M:TRNPD]NBLIG-1))=0
    If (fmet WTRANSPORT.ADELLINE("SHIPD", WTRANSPORT.SHIPD(I).AORDER) <> [V]CST_AOK)
      #--The insertion was not possible
      GMESSAGE = func ASYRFNC.MES2(mess(273,133,1),'SHIPD','TRANSPORT')
      GOK = 0 : GERR = 1
      Break
    Endif
  Endif
Next
If (GERR = 1) : Return : Endif
Return

#**
#* Remplit une ligne de la collection SHD par une ligne du tableau écran
#* @param WTRANSPORT : classe des transports
#* @param WPOS : Position dans la collection
#* @param NOL : numéro de ligne du tableau
#*!
Subprog FILL_CLASS_DOC(WTRANSPORT, WPOS, NOL)
Variable Instance WTRANSPORT Using C_TRANSPORT
Variable Integer WPOS
Variable Shortint NOL
If WPOS = 0 : End : Endif
# Issue 49737 - 2017-09-04 by MAE : setinstance instead of filling fiel by field
SetInstanceNoSys WTRANSPORT.SHIPD(WPOS) With [M:TRNPD] 5
WTRANSPORT.SHIPD(WPOS).VCRNUM = [M:TRNP0]TRNNUM
WTRANSPORT.SHIPD(WPOS).VCRTYP = 39
#WTRANSPORT.SHIPD(WPOS).SDLIN = [M:TRNPD]SDLIN(NOL)
#WTRANSPORT.SHIPD(WPOS).SDTYPE = [M:TRNPD]SDTYPE(NOL)
#WTRANSPORT.SHIPD(WPOS).SDORI = [M:TRNPD]SDORI(NOL)
#WTRANSPORT.SHIPD(WPOS).SDDATE = [M:TRNPD]SDDATE(NOL)
#WTRANSPORT.SHIPD(WPOS).SDREF1 = [M:TRNPD]SDREF1(NOL)
#WTRANSPORT.SHIPD(WPOS).SDREF2 = [M:TRNPD]SDREF2(NOL)
#WTRANSPORT.SHIPD(WPOS).SDBP = [M:TRNPD]SDBP(NOL)
#WTRANSPORT.SHIPD(WPOS).SDNTYP = [M:TRNPD]SDNTYP(NOL)
#WTRANSPORT.SHIPD(WPOS).SDFILNAM = [M:TRNPD]SDFILNAM(NOL)
#WTRANSPORT.SHIPD(WPOS).SDCMT = [M:TRNPD]SDCMT(NOL)
# End issue 49737

End
# End issue 111257 US 20
#-------------------------------------------------------------#
# Issue 111257 US 43
#**
#* gere la modification des lignes de l'onglet "Suivi"
#*!
$MODIF_TRACKING
Local Integer I, INDEX
Local Shortint NOL, WENDL, WBEGL
For I = 0 To [M:TRNPT]NBLIGNE - 1
  nolign = I + 1
  NOL = nolign-1
  # Retrieve the element using the screen's AUUID
  If [M:TRNPT]AUUID(I)<>""
    INDEX = find(toUuid([M:TRNPT]AUUID(I)), WTRANSPORT.SHIPT(1..maxtab(WTRANSPORT.SHIPT)).AUUID)
  Else
    INDEX=0
  Endif

  Call FILL_CLASS_TRACK(WTRANSPORT,INDEX,NOL)
Next
# Now, all elements that don't have the status Updated or Created must be deleted, because it means they don't match with lines in the array
For I=1 To maxtab(WTRANSPORT.SHIPT)
  # Issue 53822 - 2017-10-06 by MAE : Suppression du CST_ANEW
  #If WTRANSPORT.SHIPT(I)<>null & !(find(WTRANSPORT.SHIPT(I).ASTALIN, [V]CST_ANEW,[V]CST_ADEL, [V]CST_ANEWDEL ))
  If WTRANSPORT.SHIPT(I)<>null & !(find(WTRANSPORT.SHIPT(I).ASTALIN,[V]CST_ADEL, [V]CST_ANEWDEL ))
&   and      num$(WTRANSPORT.SHIPT(I).AUUID)<>""
&   and find(num$(WTRANSPORT.SHIPT(I).AUUID),[M:TRNPT]AUUID(0..[M:TRNPT]NBLIGNE-1))=0
    If (fmet WTRANSPORT.ADELLINE("SHIPT", WTRANSPORT.SHIPT(I).AORDER) <> [V]CST_AOK)
      #--The insertion was not possible
      GMESSAGE = func ASYRFNC.MES2(mess(273,133,1),'SHIPT','TRANSPORT')
      GOK = 0 : GERR = 1
      Break
    Endif
  Endif
Next

Return
#-------------------------------------------------------------#
#**
#* Remplit une ligne de la collection SHIPT par une ligne du tableau écran
#* @param WTRANSPORT : classe des transports
#* @param WPOS : Position dans la collection
#* @param NOL : numéro de ligne du tableau
#*!
Subprog FILL_CLASS_TRACK(WTRANSPORT, WPOS, NOL)
Variable Instance WTRANSPORT Using C_TRANSPORT
Variable Integer WPOS
Variable Shortint NOL

Local Integer WTRKDEPLIN  # Issue 49737
If WPOS = 0 : End : Endif
WTRANSPORT.SHIPT(WPOS).VCRNUM = [M:TRNP0]TRNNUM
WTRANSPORT.SHIPT(WPOS).VCRTYP = 39
# Issue 49737 - 2017-09-04 by MAE : setinstance instead of filling fiel by field
WTRKDEPLIN = WTRANSPORT.SHIPT(WPOS).TRKDEPLIN
SetInstanceNoSys WTRANSPORT.SHIPT(WPOS) With [M:TRNPT] 10
WTRANSPORT.SHIPT(WPOS).TRKDEPLIN = WTRKDEPLIN
#WTRANSPORT.SHIPT(WPOS).TRKNUM = [M:TRNPT]TRKNUM
#WTRANSPORT.SHIPT(WPOS).TRKCOD = [M:TRNPT]TRKCOD(NOL)
#WTRANSPORT.SHIPT(WPOS).TRKPLNDAT = [M:TRNPT]TRKPLNDAT(NOL)
#WTRANSPORT.SHIPT(WPOS).TRKENDDAT = [M:TRNPT]TRKENDDAT(NOL)
#WTRANSPORT.SHIPT(WPOS).TRKMDY = [M:TRNPT]TRKMDY(NOL)
#WTRANSPORT.SHIPT(WPOS).TRKDEPCOD = [M:TRNPT]TRKDEPCOD(NOL)
#WTRANSPORT.SHIPT(WPOS).TRKCMT = [M:TRNPT]TRKCMT(NOL)
#WTRANSPORT.SHIPT(WPOS).TRKUSR = [M:TRNPT]TRKUSR(NOL)
#WTRANSPORT.SHIPT(WPOS).TRKLIGSTAT = [M:TRNPT]TRKLIGSTAT(NOL)
End
#-------------------------------------------------------------#
Subprog COPY_SCREEN_TO_CLASS
Local Integer ASTATUS                            # Hybrid part
Local Integer ILINE
Local Integer NI

  Local File SHIPTRACK [SHIPT]
  # ----------------------------------------------------------
  # Hybrid part (begin)
  # Lignes step tracking
  # 1°) On reprend les valeurs des lignes à l'écran dans la classe
  For NI = 0 To [M:TRNPT]NBLIGNE-1
    nolign = NI + 1
    Raz [F:SHIPT]
    [F:SHIPT] = [M:TRNPT]
    [F:SHIPT]VCRNUM = [M:TRNP0]TRNNUM
    ILINE = 0
    If [M:TRNPT]AUUID(nolign-1) <> ""
      ILINE = find([F:SHIPT]AUUID,WTRANSPORT.SHIPT(1..maxtab(WTRANSPORT.SHIPT)).AUUID)
      If ILINE<> 0  # Issue 53829
        If WTRANSPORT.SHIPT(ILINE) <> null and find(WTRANSPORT.SHIPT(ILINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) <> 0
          ILINE = 0
        Endif
      Endif # Issue 53829
    Endif
    If ILINE = 0
      ILINE = fmet WTRANSPORT.ADDLINE("SHIPT", [V]CST_ALASTPOS)
      If ILINE = [V]CST_ANOTDEFINED Then
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WTRANSPORT)
        GOK = 0
        GERR = 1
        Break
      Endif
    Endif
    SetInstance WTRANSPORT.SHIPT(ILINE) With [F:SHIPT]
  Next NI
  If GERR = 1 Then
    End
  Endif
  # ------------------
  # 2°) Celles qui sont nouvelles dans la classe et pas a l'écran : c'est que l'utilisateur à fait ECHAP sur la ligne : on la supprime
  For NI = 1 To maxtab(WTRANSPORT.SHIPT)
    If WTRANSPORT.SHIPT(NI) <> null and find(WTRANSPORT.SHIPT(NI).ASTALIN,[V]CST_ANEW) <> 0 Then
      ILINE = find(num$(WTRANSPORT.SHIPT(NI).AUUID), [M:TRNPT]AUUID(0..[M:TRNPT]NBLIGNE-1))
      If ILINE = 0
        [L]ASTATUS = fmet WTRANSPORT.ADELLINE("SHIPT", WTRANSPORT.SHIPT(NI).AORDER)
        If [L]ASTATUS >= [V]CST_AERROR Then
          GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WTRANSPORT)
          GOK = 0
          GERR = 1
          Break
        Endif
      Endif
    Endif
  Next NI
  If GERR = 1 Then
    End
  Endif
  # ------------------
  # 3°) Celles qui ne sont pas touchées sont détruites
  For NI = 1 To maxtab(WTRANSPORT.SHIPT)
    If WTRANSPORT.SHIPT(NI) <> null and find(WTRANSPORT.SHIPT(NI).ASTALIN,[V]CST_ANEW,[V]CST_AUPD) = 0
&   and      num$(WTRANSPORT.SHIPT(NI).AUUID)<>""
&   and find(num$(WTRANSPORT.SHIPT(NI).AUUID),[M:TRNPT]AUUID(0..[M:TRNPT]NBLIGNE-1))=0
      [L]ASTATUS = fmet WTRANSPORT.ADELLINE("SHIPT", WTRANSPORT.SHIPT.AORDER)
      If [L]ASTATUS >= [V]CST_AERROR Then
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WTRANSPORT)
        GOK = 0
        GERR = 1
        Break
      Endif
     Endif
  Next NI
  If GERR = 1 Then
    End
  Endif
  # Hybrid part (end)
  # ----------------------------------------------------------
End
#-------------------------------------------------------------#
Subprog SHOW_TRACK_LINE(VNLINE)
Value Integer VNLINE

Local Integer NI

  Local File SHIPTRACK [SHIPT]
  SetInstance [F:SHIPT] With WTRANSPORT.SHIPT(VNLINE)
  [M:TRNPT] = [F:SHIPT]
  [M:TRNPT]COLLIN(nolign-1) = VNLINE   # Line index in the collection
  #
  For NI = nolign To [M:TRNPT]NBLIGNE-1
    If [M:TRNPT]COLLIN(NI) > 0 Then
      [M:TRNPT]TRKSORT(NI) = WTRANSPORT.SHIPT([M:TRNPT]COLLIN(NI)).TRKSORT
      Affzo [M:TRNPT]TRKSORT(NI)
    Endif
  Next NI
End
# End issue 111257 US 43

