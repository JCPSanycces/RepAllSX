#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char VALBOUT(30)
Local Char PARBOUT(250)(1..2)
#PARBOUT(1) = "1"           : # 1:Bordereau de remise, 2:Avis de domiciliation, 3:Règlement
#PARBOUT(2) = "REM00000483" : # Numéro de bordereau, d'avis ou de règlement
GACTION = "PAYCPTTRA"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","PAYCPTTRA","DPAYTRA",3,"") From GTRAITE
End

$ACTION
Case GACTION
 When "PAYGAS"
  Case ACTION
   When "SEL_TABLE" : Gosub SEL_LISTE
  Endcase
 When Default
  Case ACTION
   When "INIT"      : Gosub INIT
   When "EXEC"      : Gosub EXEC
   When "SEL_TABLE" : Gosub SEL_TABLE
  Endcase
Endcase
Return

#####
$INIT
#####
Local Integer TYP         : TYP=val(PARAM(1))
Local Char    NUM(20)     : NUM=PARAM(2)
If PARAM(2)<>"" & TYP<4 & TYP>0 : TYPPRG=1 : Endif
Return

#####
$EXEC
#####
If TYPPRG<>1
 [L]TYP = [M:DIA]TYPNUM
 [L]NUM = [M:DIA]NUM
Endif
Call PAYCPTTRA(TYP,NUM)
TRA=9
Return

##########################
Subprog PAYCPTTRA(TYP,NUM)
##########################
Value Integer TYP
Value Char    NUM()

Local Integer OK, I, STACUR, ACCCUR, ERR
Local Libelle EXISTE
Local Char    OMESSAGE(255), ADI304(20), MESSA(250)

Onerrgo ERREUR From CONTROLE
If !clalev([F:TPY]) : Local File TABPAYTYP  [TPY] : Endif
If !clalev([F:PYH]) : Local File PAYMENTH   [PYH] : Endif
If !clalev([F:PAN]) : Local File PAYACCNUM  [PAN] : Endif
If !clalev([F:DAE]) : Local File GACCENTRYD [DAE] : Endif
If !clalev([F:DAT]) : Local File GACCTMPD   [DAT] : Endif
If !clalev([F:ADI]) : Local File ATABDIV    [ADI] : Endif
If !clalev([F:BES]) : Local File BILSTA     [BES] : Endif
If !clalev([F:CPY]) : Local File COMPANY    [CPY] : Endif
If !clalev([F:TED]) : Local File TABCODEDT  [TED] : Endif
Onerrgo
If GERREUR : GERREUR=0 : End : Endif

# Suivi Règlement NUM
Call OUVRE_TRACE(mess(61,117,1)-mess(TYP,685,1)-NUM) From LECFIC

Case [L]TYP
 When 3 : # Règlement
  Call LECTURE("PAY",[L]NUM,"") From CONTOBJ
 When Default
  Read [PYH]PYH1(2)=[L]TYP;[L]NUM
Endcase
If fstat<=2
 EXISTE=1

 Call LECTURE("CPY",[F:PYH]CPY,"") From CONTOBJ
 Call LEC_TPY_LEG([F:CPY]LEG,[F:PYH]PAYTYP) From CPTLEC
 Call LEC_TED([F:CPY]LEG,[F:TPY]CODEDT) From CPTLEC
 If !fstat : [L]ADI304 = [F:TED]TRT : Else [L]ADI304="" : Endif
Else
 EXISTE=0
Endif
ACCCUR=0 : STACUR=0

OK=0
If [L]TYP=3 & [F:TPY]DACBID=1 & [F:PYH]BID="" : # RIB obligatoire
 If [F:PYH]BPR<>""
  Call ECR_TRACE(mess(27,199,1)-"("+[F:PYH]BPR+")",0) From GESECRAN
 Else
  Call ECR_TRACE(mess(27,199,1),0) From GESECRAN
 Endif
 OK=1
Elsif [L]TYP=1 & [F:TPY]DACBID=1
 For [PYH]PYH1 Where FRMFLG=[L]TYP & FRMNUM=[L]NUM & BID=""
  If [F:PYH]BPR<>""
   Call ECR_TRACE(mess(27,117,1)-[F:PYH]NUM-"("+mess(47,116,1)-num$([F:PYH]FRMLIN)+") :"-mess(27,199,1)-"("+[F:PYH]BPR+")",0) From GESECRAN
  Else
   Call ECR_TRACE(mess(27,117,1)-[F:PYH]NUM-"("+mess(47,116,1)-num$([F:PYH]FRMLIN)+") :"-mess(27,199,1),0) From GESECRAN
  Endif
  OK=1
 Next : # [PYH]
 Read [PYH]PYH1(2) = [L]TYP;[L]NUM
Endif

If [F:TPY]DACCHQNUM=1 & [PYH]CHQNUM="" & [F:TPY]SNS=1 & ([F:TPY]EDTFLG=2| [F:TPY]CODEDT="")
 Call ECR_TRACE(mess(27,117,1)-[F:PYH]NUM-":"-mess(17,121,1),0) From GESECRAN
 OK=1
Endif

If [L]TYP=3 & [F:PYH]EDTNUM<>0 : # GH 23/04/99
 # Impression Requête numéro EDTNUM
 Call ECR_TRACE(toupper(ctrans(mess(61,123,1)))-":"-mess(38,114,1)-num$([F:PYH]EDTNUM),0) From GESECRAN
 OK=1
Elsif ([L]TYP=1 & [F:PYH]STAFLG(5)=2) | [L]TYP=2  : # GH 11/06/99
 If [L]TYP=2 & [F:TPY]STA6=2   : # GB 13/02/01
  Read [BES]BES0 = [F:PYH]FRMNUM;0
  If !fstat
   # Relevé
   Call ECR_TRACE(toupper(ctrans(mess(42,117,1)-":"-[F:BES]FRMNUM)),0) From GESECRAN
   # Nom du fichier importé
   Call ECR_TRACE(toupper(ctrans(mess(124,121,1)-":"-[F:BES]IMPFIL-format$(GFMDAT,[F:BES]IMPDAT))),0) From GESECRAN
   OK=1 : Gosub SAUTL
  Endif
 Endif
 If [F:PYH]TFBFIL<>""
  If [L]TYP=1 | [F:TPY]STA6=2
   # Fichier banque
   Call ECR_TRACE(toupper(ctrans(mess(101,117,1)))-":"-[F:PYH]TFBFIL-format$(GFMDAT,[F:PYH]TFBDAT),0) From GESECRAN
   OK=1
  Endif
 Endif
Endif

Filter [PAN] Where TYPNUM=[L]TYP & NUM=[L]NUM & STA>0
&              Order By Key CLE = TYPNUM ; NUM ; ACCSTA; ACCNUM
Gosub LECPAN
Filter [PAN]
If [F:PYH]FRMNUM<>"" & [L]TYP=3
 GMESSAGE=""
 If ACCCUR<5 & [F:PYH]FRMFLG=1
  GMESSAGE=mess(1,685,1)-[F:PYH]FRMNUM
 Elsif ACCCUR<7 & [F:PYH]FRMFLG=2
  GMESSAGE=mess(2,685,1)-[F:PYH]FRMNUM
 Endif
 If GMESSAGE<>""
  If [F:PYH]FRMFLG=2 & [F:TPY]STA6=2  :# Trace du fichier magnétique demandée pour les avis dom
   Filter [BES] Where PAYNUM=[F:PYH]NUM
   Read [BES]BES1 First
   If !fstat
    Gosub SAUTL
    # Rapprochement avec relevé
    Call ECR_TRACE(toupper(ctrans(mess(123,121,1)-":"-[F:BES]FRMNUM)),0) From GESECRAN
    # Nom du fichier importé
    Call ECR_TRACE(toupper(ctrans(mess(124,121,1)-":"-[F:BES]IMPFIL-format$(GFMDAT,[F:BES]IMPDAT))),0) From GESECRAN
    OK=1 : Gosub SAUTL
   Endif
   Filter [BES]
  Endif
  Gosub SAUTL
  Call ECR_TRACE(toupper(ctrans(GMESSAGE)),0) From GESECRAN
  OK=1
 Endif
Endif

If EXISTE & [L]TYP<>3
 Read [PYH]PYH1(2) = [L]TYP;[L]NUM
 If fstat>2 : EXISTE=0 : Endif
Endif
If EXISTE
 If [F:PYH]STA<2 & [F:TPY]STA2=2 : # Retour d'acceptation
  Gosub TIT
  Call ECR_TRACE(mess(95,117,1),0) From GESECRAN
 Endif
 # Impression règlement
 If [L]TYP=3 & [F:PYH]SNS=1 & [F:TPY]EDTFLG=2 &
& (([L]ADI304="CHE" & [F:PYH]CHQNUM="") | ([L]ADI304="TRE" & [F:PYH]EDTNUM=0))
  Gosub TIT
  Call ECR_TRACE(mess(61,123,1)-tolower(mess(27,117,1)),0) From GESECRAN
 Elsif [L]TYP<>3 & [F:TPY]EDTFLG=2 & find([L]ADI304,"CHE","TRE")
  I=0
  For [PYH]PYH1 Where FRMFLG=[L]TYP & FRMNUM=[L]NUM & SNS=1 &
&                     (([L]ADI304="CHE" & CHQNUM="") | ([L]ADI304="TRE" & EDTNUM=0))
   If !I : Gosub TIT : I=1 : Endif
   Call ECR_TRACE(mess(61,123,1)-tolower(mess(27,117,1))-[F:PYH]NUM,0) From GESECRAN
  Next : # [PYH]
  Read [PYH]PYH1(2) = [L]TYP;[L]NUM
 Endif
 If [F:PYH]STA<3 & [F:TPY]STA3=2 : # Comptabilisation portefeuille
  Gosub TIT
  Call ECR_TRACE(mess(55,117,1),0) From GESECRAN
 Endif
 If [F:PYH]STA<11 & [F:PYH]BAN="" : # Affectation de banque
  Gosub TIT
  Call ECR_TRACE(mess(115,117,1),0) From GESECRAN
 Endif
 If [F:PYH]STA<5 & [F:TPY]STA5=2 : # Bordereau de remise
  Gosub TIT
  Call ECR_TRACE(mess(1,685,1),0) From GESECRAN
 Endif
 If [F:PYH]STA<6 & ([F:TPY]STA6=2 | [F:TPY]EPACDTTRF=2) & [F:TPY]STA5=2 : # Remise magnétique
  Gosub TIT
  Call ECR_TRACE(mess(98,117,1),0) From GESECRAN
 Endif
 If [F:PYH]STA<7 & [F:TPY]STA7=2 : # Avis de domiciliation
  Gosub TIT
  Call ECR_TRACE(mess(2,685,1),0) From GESECRAN
 Endif
 If [F:PYH]STA<8 & [F:TPY]STA8=2 : # Comptabilisation intermédiaire
  Gosub TIT
  Call ECR_TRACE(mess(132,117,1),0) From GESECRAN
 Endif
 If [F:PYH]STA<9 & [F:TPY]STA9=2 : # Comptabilisation en banque
  Gosub TIT
  Call ECR_TRACE(mess(133,117,1),0) From GESECRAN
 Endif
 # Dévalorisation portefeuille
 If [L]TYP=3 & [F:PYH]STAFLG(9)<>2 & ([F:PYH]AMTNYTBIL<>0 | [F:TPY]AUTACE10<>"")
  Gosub TIT
  Call ECR_TRACE(mess(113,117,1),0) From GESECRAN
 Elsif [L]TYP<>3
  For [PYH]PYH1 Where FRMFLG=[L]TYP & FRMNUM=[L]NUM & STAFLG(9)<>2
&                     & (AMTNYTBIL<>0 | [F:TPY]AUTACE10<>"")
   Gosub TIT
   Call ECR_TRACE(mess(113,117,1),0) From GESECRAN
   Break
  Next : # [PYH]
  Read [PYH]PYH1(2) = [L]TYP;[L]NUM
 Endif
Endif

GMESSAGE=""
Call FERME_TRACE From LECFIC
End

$LECPAN
For [PAN]CLE
 If ACCCUR<>[F:PAN]ACCSTA
  Gosub SAUTL
  If [F:PYH]FRMNUM<>"" & [L]TYP=3
   GMESSAGE=""
   If [F:PAN]ACCSTA>5 & ACCCUR<5 & [F:PYH]FRMFLG=1
    GMESSAGE=mess(1,685,1)-[F:PYH]FRMNUM
   Elsif [F:PAN]ACCSTA>7 & ACCCUR<7 & [F:PYH]FRMFLG=2
    GMESSAGE=mess(2,685,1)-[F:PYH]FRMNUM
   Endif
   If GMESSAGE<>""
    Call ECR_TRACE(toupper(ctrans(GMESSAGE))+"\ ",0) From GESECRAN
   Endif
   If GMESSAGE<>""    : # GB 12/02/01
    If [F:PYH]FRMFLG=2 & [F:TPY]STA6=2  :# Trace du fichier magnétique demandée pour les avis dom
     Filter [BES] Where PAYNUM=[F:PYH]NUM
     Read [BES]BES1 First
     If !fstat
      # Rapprochement avec relevé
      Call ECR_TRACE(toupper(ctrans(mess(123,121,1)-":"-[F:BES]FRMNUM)),0) From GESECRAN
      # Nom du fichier importé
      Call ECR_TRACE(toupper(ctrans(mess(124,121,1)-":"-[F:BES]IMPFIL-format$(GFMDAT,[F:BES]IMPDAT))),0) From GESECRAN
      OK=1 : Gosub SAUTL
     Endif
     Filter [BES]
     Call ECR_TRACE(toupper(ctrans(GMESSAGE))+"\ ",0) From GESECRAN
     Gosub SAUTL
    Endif
    If [F:PYH]TFBFIL<>""
      # Fichier banque
      Call ECR_TRACE(toupper(ctrans(mess(101,117,1)))-":"-[F:PYH]TFBFIL-format$(GFMDAT,[F:PYH]TFBDAT),0) From GESECRAN
      OK=1 : Gosub SAUTL
    Endif
   Endif
  Endif
  Gosub STAVCR
  Call ECR_TRACE(toupper(ctrans(GMESSAGE)),0) From GESECRAN : OK=1
  ACCCUR=[F:PAN]ACCSTA
 Endif

 If STACUR<>[F:PAN]STA & [F:PAN]STA=11 & [F:PAN]ACCSTA<>11
  Gosub SAUTL
  Call ECR_TRACE(toupper(ctrans(mess(135,117,1))),0) From GESECRAN : OK=1
 Endif
 STACUR=[F:PAN]STA

 ERR=0
 If [F:PAN]RENCOD<>"" : GMESSAGE=mess(27,117,1)-right$([F:PAN]RENCOD,2)-":"
 Else GMESSAGE=""
 Endif
 GCLE=""
 Read [DAE]DAE2 = [F:PAN]ACCNUM
 If fstat=0
  GCLE=[F:DAE]TYP-[F:DAE]NUM
  GMESSAGE-=GCLE
  If [F:PAN]CPTBAN=2 | [F:PAN]TYPVCR="G"
   If [F:PAN]STA<>11 : GMESSAGE+=" ->"
   Else              : GMESSAGE+=" <-"
   Endif
   GMESSAGE-=[F:DAE]SAC-[F:DAE]ACC-[F:DAE]BPR
  Endif
 Else
  Read [DAT]DAT1 = [F:PAN]ACCNUM
  If fstat=0
   GCLE=[F:DAT]TYP-[F:DAT]NUM
   GMESSAGE-=GCLE-"("+mess(128,117,1)+")" : # En cours de validation
   If [F:PAN]CPTBAN=2 | [F:PAN]TYPVCR="G"
    If [F:PAN]STA<>11 : GMESSAGE+=" ->"
    Else              : GMESSAGE+=" <-"
    Endif
    GMESSAGE-=[F:DAT]SAC-[F:DAT]ACC-[F:DAT]BPR
   Endif
  Else
   ERR=1 : GCLE=num$([F:PAN]ACCNUM)
   GMESSAGE-="ACCNUM="+num$([F:PAN]ACCNUM)-"("+mess(23,100,1)+")" : # Fiche inexistante
  Endif
 Endif
 MESSA=GMESSAGE : Gosub TYPVCR
 If GMESSAGE<>"" : GMESSAGE=MESSA-"-"-GMESSAGE : Else GMESSAGE=MESSA : Endif
 If OMESSAGE<>GMESSAGE
  OMESSAGE=GMESSAGE
  Call ECR_TRACE(vireblc(GMESSAGE,2),ERR) From GESECRAN : OK=1

  # Extourne
  ERR=0
  If [F:PAN]RVSACCNUM<>0
   Read [DAE]DAE2 = [F:PAN]RVSACCNUM
   If fstat=0
    GMESSAGE=[F:DAE]TYP-[F:DAE]NUM
   Else
    Read [DAT]DAT1 = [F:PAN]RVSACCNUM
    If fstat=0
     GMESSAGE=[F:DAT]TYP-[F:DAT]NUM-"("+mess(128,117,1)+")" : # En cours de validation
    Else
     ERR=1
     GMESSAGE="ACCNUM="+num$([F:PAN]ACCNUM)-"("+mess(23,100,1)+")" : # Fiche inexistante
    Endif
   Endif
   GMESSAGE-="-"-mess(55,105,1)-GCLE : # Extourne
   Call ECR_TRACE(GMESSAGE,ERR) From GESECRAN : OK=1
   Endif
  Endif
 Next : # [PAN]
Return

$SAUTL
If OK
 Call ECR_TRACE(" ",0) From GESECRAN
 OK=0
Endif
Return

$TIT
If OK=1
 Call ECR_TRACE(" ",0) From GESECRAN
Endif
If OK<>2
 # Prochaines étapes ...
 Call ECR_TRACE(toupper(ctrans(mess(144,117,1))),0) From GESECRAN
 OK=2
Endif
Return

$STAVCR
Case [F:PAN]ACCSTA
 When 3  : GMESSAGE=mess(55,117,1)  : # Comptabilisation portefeuille
 When 8  : GMESSAGE=mess(132,117,1) : # Comptabilisation intermédiaire
 When 9  : GMESSAGE=mess(133,117,1) : # Comptabilisation en banque
 When 10 : GMESSAGE=mess(113,117,1) : # Dévalorisation portefeuille
 When 11 : GMESSAGE=mess(135,117,1) : # Saisie des impayés
 When 99 : GMESSAGE=mess(3,953,1)-":"-mess(135,117,1): # Frais : Saisie des impayés
 When Default : GMESSAGE=mess([F:PAN]ACCSTA,689,1)
  If GMESSAGE=""
   GMESSAGE=mess(120,117,1)-num$([F:PAN]ACCSTA) : # Etape #
  Endif
Endcase
Return

$TYPVCR
GMESSAGE=""
Case [F:PAN]TYPVCR
 When "C"         : GMESSAGE=mess(147,117,1)    : # OD devise
 When "D"         : GMESSAGE=mess(148,117,1)    : # OD tiers
 When "E"         : GMESSAGE=mess(149,117,1)    : # Ecart change
 When "8","9"     : # Transfert compte
 When "4"         : GMESSAGE=mess(143,117,1)    : # Prorogation
 When "G"         : GMESSAGE=mess(114,121,1)    : # Effets à l'escompte
 When "H"         : # Dévalorisation portefeuille
 ## <Begin> TAX STAMP
 When "S"         : GMESSAGE=mess(10,2626,1)    : #102289 RICAR 2014/11/06 - Angola tax stamp
 ## <End> TAX STAMP
 When Default     : #"A","B","L","N","M","O"
                    If [F:PAN]CPTBAN=1
                     GMESSAGE=mess(146,117,1)   : # OD devise trésorerie
                    Endif
Endcase
Return

#####################################
## Etiquettes de l'écran PAYCPTTRA ##
#####################################
$SEL_TABLE
Case COUZON
 When "NUM"
  Case [M]TYPNUM
   When 1 : # Remise
    OBJET="FRM"
    SUPP="1"

   When 2 : # Domiciliation
    OBJET="PAB"
    SUPP="2"

   When 3 : # Règlement
    OBJET="PAY"
    OPTIONS="#"
  Endcase
Endcase
Return

Subprog C_NUM(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If !clalev([F:PYH]) : Local File PAYMENTH [PYH] : Endif
Case [M]TYPNUM
 When 1,2 : # Remise, Domiciliation
  Read [PYH]PYH1(2) = [M]TYPNUM;VALEUR
 When 3 : # Règlement
  Call LECTURE("PAY",VALEUR,"") From CONTOBJ
Endcase
If fstat>2 : # VALEUR - Fiche inexistante
 OK=1 : Call AVERTIR(mess([M]TYPNUM,685,1)-VALEUR+"\"+mess(23,100,1),OK) From GESECRAN
 If OK<>2 : mkstat=2 : Endif
Endif
End

#################################################
## Zoom sur les pièces comptables de règlement ##
#################################################
$SEL_LISTE
Onerrgo ERREUR From CONTROLE
If clalev([F:PAN])=0 : Local File PAYACCNUM   [PAN]  : Endif
If clalev([F:DAE])=0 : Local File GACCENTRYD  [DAE]  : Endif
Onerrgo
If GERREUR : GERREUR=0 : OK=0 : Return : Endif

Local Integer LNGTEX1 : LNGTEX1 = GLONGTE+GLONVCR+1
Local Integer MAXPCE, NBTEX1, I : MAXPCE=100   :# GB 03/05/01  Ne pas utiliser NBTEX pour le web
Local Char    TEX1(LNGTEX1)(1..MAXPCE), TEX2(30)(1..MAXPCE), TEX3(50)(1..MAXPCE)
Local Integer TEX4(1..MAXPCE)

# On présente les dernières pièces générées en premier GH 02/12/99
Filter [PAN] Where NUM=PARAM(2) & TYPNUM=val(PARAM(1)) & STA>0 Order By ACCNUM Desc
For [PAN]
 EXTOURNE=0
 If [F:PAN]RVSACCNUM<>0
  Read [DAE]DAE2 = [F:PAN]RVSACCNUM
  If fstat=0
   If NBTEX1=MAXPCE : Break : Endif
   If !find([F:DAE]TYP-[F:DAE]NUM, TEX1(1..NBTEX1))
    NBTEX1 += 1 : TEX4(NBTEX1) = -NBTEX1
    TEX1(NBTEX1) = [F:DAE]TYP-[F:DAE]NUM
    Gosub STAVCR : TEX2(NBTEX1)=GMESSAGE
    EXTOURNE=NBTEX1
   Endif
  Endif
 Endif

 Read [DAE]DAE2 = [F:PAN]ACCNUM
 If fstat=0
  If EXTOURNE : TEX3(EXTOURNE)=mess(55,105,1)-[F:DAE]TYP-[F:DAE]NUM : Endif
  I=find([F:DAE]TYP-[F:DAE]NUM, TEX1(1..NBTEX1))
  If I & TEX4(I)<0
   Dela I, 1 TEX1, TEX2, TEX3, TEX4 : I=NBTEX1 : NBTEX1-=1
  Elsif !I & NBTEX1<MAXPCE
   I=NBTEX1+1
  Else I=0
  Endif
  If I
   NBTEX1 += 1
   TEX1(I) = [F:DAE]TYP-[F:DAE]NUM
   Gosub STAVCR : TEX2(I)=GMESSAGE
   Gosub TYPVCR : TEX3(I)=GMESSAGE
   TEX4(I) = I
   If [F:PAN]RVSACCNUM<>0
    Read [DAE]DAE2 = [F:PAN]RVSACCNUM
    If fstat=0
     I=find([F:DAE]TYP-[F:DAE]NUM, TEX1(1..NBTEX1-1))
     If I : TEX3(I)=mess(55,105,1)-TEX1(NBTEX1) : Endif
    Endif
   Endif
  Endif
 Endif
Next : # [PAN]
Filter [PAN]
GMESSAGE=""

If NBTEX1
 For I=1 To NBTEX1
  If TEX4(I)<0 : TEX4(I)=-TEX4(I) : Endif
 Next I
 If clalev([F:ZZZ]) : Close Local File [ZZZ] : Endif

 ORDRE  = "NUM"
 Local File (Char AA(LNGTEX1), Char BB(30), Char CC(50), Integer NUM)
&      From Variable TEX1(1..NBTEX1), TEX2(1..NBTEX1), TEX3(1..NBTEX1), TEX4(1..NBTEX1)
& As [ZZZ] Order With ORDRE
 COL(1)="AA"
 COL(2)="BB"
 COL(3)="CC"
 NBCOL = 3
 TIT(1) = mess(11,105,1)  : # Numéro de pièce
 TIT(2) = mess(120,117,1) : # Etape
 TIT(3) = mess(97,117,1)  : # Schéma comptable
 Call TITOBJ("GAS","!",TIT) From CONTOBJ
Else  : # Pas de pièce générée
 OK=0
Endif
Return
