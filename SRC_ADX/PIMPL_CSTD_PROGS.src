###################################################################################################
Funprog PJM_KEY_SPLIT_OPPNUM(ACTX, INPKEY)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char INPKEY ()

If dim(GLONPBU) >= 0 Then  # Issue X3-81014 - 2018-03-06 by FGR : Case of activity code "PJM" is disable
  Local Char BUDGET(GLONPBU)
  Local Char TASK(GLONTAC)
Else
  Local Char BUDGET(GLONVCR)
  Local Char TASK(GLONVCR)
Endif
Local Char PROJECT(GLONOPP)
Local Integer IRET

  Raz PROJECT
  If INPKEY <> AVOID.ACHAR Then
    IRET = func PJM_KEY_SPLIT(ACTX, INPKEY, PROJECT, BUDGET, TASK)
  Endif
End PROJECT

