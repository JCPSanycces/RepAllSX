Funprog GET_PIMDESAXX(CTX, PIMNUM)
Variable Instance CTX Using OBJECT
Value Char PIMNUM

Local Char SARENDRE(GLONDCO)

  Raz SARENDRE
  Call LECTEXTRA_SYR(CTX, AVOID.ACHAR, SARENDRE, "PIMPL", "PIMDESAXX", PIMNUM, AVOID.ACHAR) From ATEXTRA
End SARENDRE

###################################################################################################
Funprog GET_PIMNUM_PJM(ACTX, SOPPNUM)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SOPPNUM

Local Char SARENDRE(250)

  SARENDRE = SOPPNUM
End SARENDRE

###################################################################################################
Funprog GET_PIMNUM_TASK(ACTX, SOPPNUM, STASCOD)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SOPPNUM
Value Char STASCOD

Local Char SARENDRE(250)
Local Char SSEPARCODE(1)

  SSEPARCODE = fmet ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, ACTX.AFOLDER, "SEPARCODE")
  SARENDRE = SOPPNUM + SSEPARCODE + STASCOD
End SARENDRE

###################################################################################################
Funprog GET_PIMNUM_BUDGET(ACTX, SOPPNUM, SPBUCOD)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SOPPNUM
Value Char SPBUCOD

Local Char SARENDRE(250)
Local Char SSEPARCODE(1)

  SSEPARCODE = fmet ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, ACTX.AFOLDER, "SEPARCODE")
  SARENDRE = SOPPNUM + SSEPARCODE + SSEPARCODE + SPBUCOD
End SARENDRE

###################################################################################################
Funprog STRING_SPLIT(ACTX, INPKEY, SEPARATOR, STBOUTLST)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char INPKEY ()
Value Char SEPARATOR ()
Variable Char STBOUTLST()(1..)

Local Integer IARENDRE
Local Integer NI
Local Integer NE
Local Integer NSTART
Local Integer NTBOUTLST

  # Issue X3-56789 - 2018-07-04 by FGR
  IARENDRE = [V]CST_AOK
  Raz STBOUTLST
  TBOUTLST = 0
  If SEPARATOR = AVOID.ACHAR Then
    IARENDRE = [V]CST_AERROR
  Else
    If instr(1,INPKEY,SEPARATOR) = 0 Then
      TBOUTLST += 1
      STBOUTLST(TBOUTLST) = INPKEY
    Else
      TBOUTLST += 1
      STBOUTLST(TBOUTLST) = left$(INPKEY,instr(1,INPKEY,SEPARATOR)-1)
      NSTART = 1
      Repeat
        NI = instr(NSTART,INPKEY,SEPARATOR)
        If NI > 0 Then
          NE = instr(NI+1,INPKEY,SEPARATOR)
          If !NE Then
            TBOUTLST += 1
            STBOUTLST(TBOUTLST) = right$(INPKEY,NI+1)
          Else
            TBOUTLST += 1
            STBOUTLST(TBOUTLST) = seg$(INPKEY,NI+1,NE-1)
          Endif
          NSTART = NI + 1
        Endif
      Until NI = 0
    Endif
  Endif
End IARENDRE

###################################################################################################
Funprog STRING_SPLIT_STD(ACTX, INPKEY, STBOUTLST)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char INPKEY ()
Variable Char STBOUTLST()(1..)

Local Integer IARENDRE

  # Issue X3-56789 - 2018-07-04 by FGR
  IARENDRE = func STRING_SPLIT(ACTX, INPKEY, "~", STBOUTLST)
End IARENDRE

###################################################################################################
# Issue X3-56789 - 2018-07-04 by FGR : BEGIN
Funprog PJM_KEY_SPLIT(ACTX, INPKEY, PROJECT, BUDGET, TASK)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char INPKEY ()
Variable Char PROJECT ()
Variable Char BUDGET ()
Variable Char TASK ()

Local Char SOUTKEY(250)(1..)

  IARENDRE = func STRING_SPLIT(ACTX, INPKEY, fmet ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, ACTX.AFOLDER, "SEPARCODE"), SOUTKEY)
  PROJECT = SOUTKEY(1)
  BUDGET = SOUTKEY(3)        # Issue X3-100249 - 2018-07-26 by FGR : not 2 but 3
  TASK = SOUTKEY(2)          # Issue X3-100249 - 2018-07-26 by FGR : not 3 but 2
End [V]CST_AOK

