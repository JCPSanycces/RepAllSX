###################################################################################################
Funprog PJM_KEY_SPLIT_PBUCOD(ACTX, INPKEY)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char INPKEY ()

Local Char BUDGET(GLONPBU)
Local Char TASK(GLONTAC)
