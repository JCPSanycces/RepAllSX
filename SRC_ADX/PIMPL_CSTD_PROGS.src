###################################################################################################
Funprog IS_PIMNUM_EXIST(ACTX, PROJECT)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char PROJECT

Local Integer IARENDRE

  # Issue X3-26991/X3-43920 - 2017-06-30 by FGR/TEJAC
  IARENDRE = [V]CST_AYES
  Local File PIMPL [PIM]
  # -------------------------
  Read [PIM]PIM0=PROJECT
  If fstat Then
    IARENDRE = [V]CST_ANO
  Endif
End IARENDRE

###################################################################################################
Funprog GET_TASSTATE_VALUE(ACTX, PROJECT, TASK, SMESSAGE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char PROJECT
Value Char TASK
Variable Char SMESSAGE

Local Integer IARENDRE
Local Char SPIMPL(GLONPIM)

  # Issue X3-26991/X3-43920 - 2017-06-30 by FGR
  Raz IARENDRE
  Raz SMESSAGE
  If TASK <> AVOID.ACHAR or PROJECT = AVOID.ACHAR Then
    SMESSAGE = mess(9,135,1)
  Else
    If TASK <> AVOID.ACHAR Then
      SPIMPL = func GET_PIMNUM_TASK(ACTX, PROJECT, TASK)
    Else
      SPIMPL = func GET_PIMNUM_PJM(ACTX, PROJECT)
    Endif
    Local File PIMPL [PIM]
    # -------------------------
    Read [PIM]PIM0=SPIMPL
    If fstat Then
      SMESSAGE = mess(243,107,1) - SPIMPL
    Else
      IARENDRE = [F:PIM]TASSTATE
    Endif
  Endif
End IARENDRE

