End

#fin test




Subprog ACTION(AXPARCOD,AXPARVAL,AACTION,REFNUM,NAMCNT,SRNCNT,TELCNT,MOBCNT,EMLCNT)
    Value    Char     AXPARCOD()()
    Value    Char     AXPARVAL()()
    Value    Char     AACTION()
    Value    Char     REFNUM()    
    Variable Char     NAMCNT ()()
    Variable Char     SRNCNT ()()
    Variable Char     TELCNT()()
    Variable Char     MOBCNT()()
    Variable Char     EMLCNT ()()
    
If vireblc(REFNUM,0)="" 
#ON NE FAIT RIEN

Else
    If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif    

    Case AACTION
        When "R"
             Gosub ACTION_LECTURE 
        When "W"
             Gosub ACTION_ECRITURE   
         When Default
             Gosub ACTION_LECTURE 
    Endcase
    
Endif

End
  
$ACTION_LECTURE   # valeur action R

Read [ID]ID0 = REFNUM
# si non trouvÃ©, on affiche une erreur...
If fstat : Call ADDMESSERR(mess(18,7905,1)) From AWEB : Return: Endif
# Sinon on remplit les valeurs
# on suppose que les champs ont la mÃªme dimension...
Local Integer I: I=0
Local Integer INDICEMAX: INDICEMAX=dim(NAMCNT)
For I=0 To dim([ID]NAMCNT)-1
 #step Ã  1 en automatique
    NAMCNT(I)=[ID]NAMCNT(I)
    SRNCNT(I)=[ID]SRNCNT(I)
    TELCNT(I)=[ID]TELCNT(I)
    MOBCNT(I)=[ID]MOBCNT(I)
    EMLCNT(I)=[ID]EMLCNT(I)
    If I=INDICEMAX : Call ADDMESSERR ("nombre d'enregistrement supÃ©rieur au paramÃ©trage") From AWEB: Break : Endif
Next


Return 

$ACTION_ECRITURE   # valeur action R
Read [ID]ID0 = REFNUM
# si non trouvÃ©, on affiche une erreur...
If fstat : Call ADDMESSERR(mess(18,7905,1)) From AWEB : Return: Endif
# Sinon on remplit les valeurs

# on locke la ligne
Trbegin [ID]
Readlock [F:ID]Curr
If  fstat                                    # Unable to re-read or lock account
    Rollback
    Call ADDMESSERR("ProblÃ¨me lors de l'enregistrement") From AWEB
Else
#on ecrit....
Local Integer I: I=0
Local Integer INDICEMAX: INDICEMAX=dim(NAMCNT)
For I=0 To dim([ID]NAMCNT)-1
 #step Ã  1 en automatique
    [F:ID]NAMCNT(I)=NAMCNT(I)
    [F:ID]SRNCNT(I)=SRNCNT(I)
    [F:ID]TELCNT(I)=TELCNT(I)
    [F:ID]MOBCNT(I)=MOBCNT(I)
    [F:ID]EMLCNT(I)=EMLCNT(I)
Next
  Rewrite [ID]
  If  fstat
        Rollback
        Call ADDMESSERR("ProblÃ¨me lors de l'enregistrement")From AWEB
  Else
         Commit    
        # Rollback
       Call ADDMESSINF("Modifications effectuÃ©es")From AWEB
    Endif


Endif
End



  

Subprog ASPGPERSCONT(AXPARCOD,AXPARVAL,AXWHRLFTBRK,AXWHRCOD,AXWHROPE,AXWHRCODVAL,AXWHRRGTBRK
&                ,AXWHRANDOR,AXORDCOD,AXORDTYP
&                ,NAMCNT,SRNCNT,TELCNT,MOBCNT,EMLCNT)

    # variable appel par defaut    
    Value Char    AXPARCOD()(1..20)
    Variable Char    AXPARVAL()(1..20)
    Value Integer AXWHRLFTBRK(1..14)
    Value Char    AXWHRCOD()(1..14)
    Value Integer AXWHROPE(1..14)
    Value Char    AXWHRCODVAL()(1..14)
    Value Integer AXWHRRGTBRK(1..14)
    Value Integer AXWHRANDOR(1..14)
    Value Char    AXORDCOD()(1..10)
    Value Integer AXORDTYP(1..10)

    # Variable sous programme 
    Variable Char     NAMCNT ()()
    Variable Char     SRNCNT ()()
    Variable Char     TELCNT()()
    Variable Char     MOBCNT()()
    Variable Char     EMLCNT ()()
    Local Char REFNUM(30)
    Local Char AACTION(30)



REFNUM="7101"
AACTION="R"
Call ADDMESSINF("On passe")From AWEB

Call ACTION(AXPARCOD,AXPARVAL,AACTION,REFNUM,NAMCNT,SRNCNT,TELCNT,MOBCNT,EMLCNT)

End





