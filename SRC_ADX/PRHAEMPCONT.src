# test 
Local Char     AXPARCOD(30)(0..10)
Local Char     AXPARVAL(30)(0..10)
Local Char     AACTION(20): AACTION="R"
Local Char     REFNUM(10) : REFNUM="7101"
Local Char NAMCNT(30)(0..10)
Local Char SRNCNT(30)(0..10)
Local Char TELCNT(30)(0..10)
Local Char MOBCNT(30)(0..10)
Local Char EMLCNT(30)(0..10)


Call OUVRE_TRACE("Test: PRHAEMPCONT/LECTURE") From LECFIC

#REFNUM="TESTCLE"
Call ECR_TRACE("lecture "+REFNUM ,0) From GESECRAN
Call ACTION(AXPARCOD,AXPARVAL,AACTION,REFNUM,NAMCNT,SRNCNT,TELCNT,MOBCNT,EMLCNT)

Local Integer I:I=0
For I=0 To 10
If NAMCNT(I)<>"" or TELCNT(I)<>"" or TELCNT(I)<>"" or MOBCNT(I)<>"" or EMLCNT(I)<>"" 
  Call ECR_TRACE("NAMCNT(" + num$(I) + ")          =" + num$(NAMCNT(I)) ,0) From GESECRAN
  Call ECR_TRACE("SRNCNT(" + num$(I) + ")          =" + num$(SRNCNT(I)) ,0) From GESECRAN
  Call ECR_TRACE("TELCNT(" + num$(I) + ")          =" + num$(TELCNT(I)) ,0) From GESECRAN
  Call ECR_TRACE("MOBCNT(" + num$(I) + ")          =" + num$(MOBCNT(I)) ,0) From GESECRAN
  Call ECR_TRACE("EMLCNT(" + num$(I) + ")          =" + num$(EMLCNT(I)) ,0) From GESECRAN
Endif
Next
Call ECR_TRACE("fin lecture "+REFNUM ,0) From GESECRAN

REFNUM="7101"
Call ECR_TRACE("lecture "+REFNUM ,0) From GESECRAN
Call ACTION(AXPARCOD,AXPARVAL,AACTION,REFNUM,NAMCNT,SRNCNT,TELCNT,MOBCNT,EMLCNT)
For I=0 To 10
If NAMCNT(I)<>"" or TELCNT(I)<>"" or TELCNT(I)<>"" or MOBCNT(I)<>"" or EMLCNT(I)<>"" 
  Call ECR_TRACE("NAMCNT(" + num$(I) + ")          =" + num$(NAMCNT(I)) ,0) From GESECRAN
  Call ECR_TRACE("SRNCNT(" + num$(I) + ")          =" + num$(SRNCNT(I)) ,0) From GESECRAN
  Call ECR_TRACE("TELCNT(" + num$(I) + ")          =" + num$(TELCNT(I)) ,0) From GESECRAN
  Call ECR_TRACE("MOBCNT(" + num$(I) + ")          =" + num$(MOBCNT(I)) ,0) From GESECRAN
  Call ECR_TRACE("EMLCNT(" + num$(I) + ")          =" + num$(EMLCNT(I)) ,0) From GESECRAN
Endif
Next
Call ECR_TRACE("fin lecture "+REFNUM ,0) From GESECRAN



# AACTION="W"
# REFNUM="TESTCLE"
Call ECR_TRACE("Ecriture "+REFNUM ,0) From GESECRAN
Call ACTION(AXPARCOD,AXPARVAL,AACTION,REFNUM,NAMCNT,SRNCNT,TELCNT,MOBCNT,EMLCNT)
Call ECR_TRACE("Fin ecriture "+REFNUM ,0) From GESECRAN

# AACTION="R"
Call ECR_TRACE("lecture "+REFNUM ,0) From GESECRAN
Call ACTION(AXPARCOD,AXPARVAL,AACTION,REFNUM,NAMCNT,SRNCNT,TELCNT,MOBCNT,EMLCNT)
Local Integer I:I=0
For I=0 To 10
If NAMCNT(I)<>"" or TELCNT(I)<>"" or TELCNT(I)<>"" or MOBCNT(I)<>"" or EMLCNT(I)<>"" 
  Call ECR_TRACE("NAMCNT(" + num$(I) + ")          =" + num$(NAMCNT(I)) ,0) From GESECRAN
  Call ECR_TRACE("SRNCNT(" + num$(I) + ")          =" + num$(SRNCNT(I)) ,0) From GESECRAN
  Call ECR_TRACE("TELCNT(" + num$(I) + ")          =" + num$(TELCNT(I)) ,0) From GESECRAN
  Call ECR_TRACE("MOBCNT(" + num$(I) + ")          =" + num$(MOBCNT(I)) ,0) From GESECRAN
  Call ECR_TRACE("EMLCNT(" + num$(I) + ")          =" + num$(EMLCNT(I)) ,0) From GESECRAN
Endif
Next
Call ECR_TRACE("fin lecture "+REFNUM ,0) From GESECRAN
Call FERME_TRACE From LECFIC
