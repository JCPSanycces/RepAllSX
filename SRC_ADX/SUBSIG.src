#<AdxTL>@(#)5.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBSIG","SITINTEGR",3,"") From GTRAITE
End

######################################################################################
$ACTION
Case ACTION
 When "EXEC"        : Gosub EXEC
Endcase
Return

######################################################################################
$EXEC
If clalev([F:ADS])=0 : Local File ADOSSIER  [ADS] : Endif
If clalev([F:ATB])=0 : Local File ATABLE    [ATB] : Endif 
If clalev([F:ATZ])=0 : Local File ATABZON   [ATZ] : Endif 
If clalev([F:ATI])=0 : Local File ATABIND   [ATI] : Endif 
If clalev([F:ATY])=0 : Local File ATYPE     [ATY] : Endif
If clalev([F:ANX])=0 : Local File AINDEX    [ANX] : Endif

Global Decimal GCOEFTAB : GCOEFTAB = 0.5

Local Char    ORDSYS(250), REPERT(50),OS(10)
Local Char    MACHINE(GDIMFIC)
Local Char    FICHIER(250)
Local Integer K
Local Integer NBFIC, NFIC
Local Integer MAXFIC
Local Integer NBCHAMP
Local Integer NBINDEX
Local Char    SAVIFS(5), SAVIRS(5)
Local Integer SAVIUM
Local Integer NBCHPBIN, FLGINDEX
Local Char    CHPBIN(60)(0..100)

MAXFIC  = 500
Local Char    LISFIC(100)(1..MAXFIC)
Local Char    FICINT(100)                                    : # Nom table intégrale
Local Char    FICX3(10)                                      : # Nom table X3
Local Char    CODFLD(50), TYPFLD(10), LNGFLD(10), DIMFLD(10) : # Champs fichiers ascii .srf
Local Char    INDEX(10), CMPIND(150), HOMONY(10)             : # Champs fichiers ascii .ind 
Local Char    XXX(10)
Local Char    TIT(250)

Local Char    REPERTOIRE(50) : REPERTOIRE = [M:SIG]FIC
Local Integer OPTION         : OPTION     = [M:SIG]OPT
Local Char    EXTENSION(10)  : EXTENSION  = "srf"

Call MACHINE(REPERTOIRE,MACHINE,REPERT) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS

Case OS
 When "unix"
  ORDSYS = "lsadx -a"-nomap-REPERT-EXTENSION
 When "dos"
  ORDSYS = "lsadx "-REPERT-EXTENSION
Endcase

Call SYSTEME2(MACHINE,ORDSYS,"",NBFIC,LISFIC) From ORDSYS
If NBFIC<=0 : End : Endif

TIT = "Migration Intégrale -> X3 : création tables Intégrale dans X3"

Call OUVRE_TRACE(TIT) From LECFIC
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
Call OUVRE_VLC("Migration Intégrale -> X3","","") From GESECRAN 

GOK=1
Read [ADS]DOSSIER = nomap
If OPTION=2
 For NFIC = 1 To NBFIC
  Gosub NOMFIC
  Call SUPP([L]FICX3,GOK)
  #Call SUPP_BIS([L]FICX3,GOK)
  If !GOK : Break : Endif
  Call AFF_VLC("Reprise des données",FICX3) From GESECRAN
  Call MAJDDB([L]FICX3,REPERTOIRE,LISFIC(NFIC))
 Next
Else
 Call AFF_VLC("Création des tables","") From GESECRAN
 Gosub TR_CR_ATBX3
 Call DEBTRANS From GLOCK
 For NFIC = 1 To NBFIC
  Gosub NOMFIC
  Call AFF_VLC("Validation des tables",FICX3) From GESECRAN
  Call MAJTAB([L]FICX3,1) From DOSTAB
  Call AFF_VLC("Suppression des données",FICX3) From GESECRAN
  Call SUPP([L]FICX3,GOK)
  If !GOK : Break : Endif
  Call AFF_VLC("Reprise des données",FICX3) From GESECRAN
  Call MAJDDB([L]FICX3,REPERTOIRE,LISFIC(NFIC))
 Next
Endif

Call FERME_VLC From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
Return


######################################################################################
$TR_CR_ATBX3
Trbegin [ATB], [ATZ], [ATI]

 ## 1) On efface les tables Intégrales créées dans X3 au cas où elles existeraient déjà...
 ## Les tables intégrale ont toutes le préfixe 'XI'
 For NFIC=1 To NBFIC
  Gosub NOMFIC
  If OPTION=5 : Call AFF_VLC("Supression des tables",FICX3) From GESECRAN : Endif
  Delete [ATB] Where left$([F:ATB]CODFIC,2)="XI"
  If fstat=1 | fstat>5
   GOK = 0 : Call ECR_TRACE("Erreur en suppression table"-FICX3,1) From GESECRAN : Break
  Endif
  Delete [ATZ] Where left$([F:ATZ]CODFIC,2)="XI"
  If fstat=1 | fstat>5
   GOK = 0 : Call ECR_TRACE("Erreur en suppression table"-FICX3,1) From GESECRAN : Break
  Endif
  Delete [ATI] Where left$([F:ATI]CODFIC,2)="XI"
  If fstat=1 | fstat>5
   GOK = 0 : Call ECR_TRACE("Erreur en suppression table"-FICX3,1) From GESECRAN : Break
  Endif
 Next
 If GOK<0   : Goto ROLL_TR_ATBX3
 Elsif !GOK : Goto AB_TR_ATBX3
 Endif

 ## 2) On crée les tables Intégrale dans X3
 ## Nom de tables : XI + les 4 premiers caractères du nom de table Intégrale + les 4 derniers 
 For NFIC=1 To NBFIC
  Gosub NOMFIC
  If OPTION=5 : Call AFF_VLC("Création des tables",FICX3) From GESECRAN : Endif
  ## 1) On s'occupe de la création de l'en-tête de table (ATABLE)
  Raz [F:ATB]
  [F:ATB]ABRFIC = num$(NFIC)
  [F:ATB]CODFIC = [L]FICX3
  [F:ATB]MODULE = 16
  [F:ATB]TYPFIC = 1
  [F:ATB]CRE    = 1
  [F:ATB]TYPDLV = 1
  [F:ATB]NBENREG = 10000
  Write [ATB]
  If fstat
   GOK = 0 : Call ECR_TRACE("Erreur en création table"-FICX3-"("+LISFIC(NFIC)+")",1) From GESECRAN : Break
  Else
   Call ECR_TRACE("Création table"-FICX3-"("+LISFIC(NFIC)+")",0) From GESECRAN
  Endif

  ## 3) On s'occupe maintenant des champs de la table (ATABZON)
  FICHIER = REPERTOIRE+"/"+LISFIC(NFIC)+".srf"
  Openi FICHIER
  adxifs = ";"
  adxirs = chr$(13)+chr$(10)
  adxium = GUTF8
  NBCHAMP = 0  : NBCHPBIN = 0
  Repeat
   Rdseq CODFLD, TYPFLD, LNGFLD, DIMFLD, XXX
   If CODFLD<>""
    NBCHAMP += 1
    Raz [F:ATZ]
    [F:ATZ]CODFIC  = [L]FICX3
    [F:ATZ]NUMLIG  = NBCHAMP
    [F:ATZ]CODZONE = ctrans([L]CODFLD,"_","")
    If find([F:ATZ]CODZONE,"PRD","EXP","NAP","REB","VAR") :  [F:ATZ]CODZONE+="9" : Endif  # Mots réservés X3
    [F:ATZ]CODTYP  = [L]TYPFLD
    ## Pb NUMSIRET
    If [F:ATZ]CODZONE="NUMSIRET"
     [F:ATZ]CODTYP = "A"
    Endif
    If [F:ATZ]CODTYP = "DCB"
     K = instr(1,LNGFLD,",")
     If K
      #LNGFLD = left$(LNGFLD,K-1)+"."+right$(LNGFLD,K+1)
     [F:ATZ]LONG    = val(left$(LNGFLD,K-1)+"."+right$(LNGFLD,K+1))
     Endif
    ## Voir avec l'équipe Intégrale...
    Elsif [F:ATZ]CODTYP = "B"
     [F:ATZ]CODTYP  = "A"
     [F:ATZ]LONG    = val([L]LNGFLD)*2
     CHPBIN(NBCHPBIN) =  [L]CODFLD
     If NBCHPBIN<100 : NBCHPBIN+=1 : Endif
    Elsif [F:ATZ]CODTYP = "D" & val([L]LNGFLD)<>8
     [F:ATZ]CODTYP  = "L"
     [F:ATZ]LONG    = val([L]LNGFLD)
    ##
    Elsif [F:ATZ]CODTYP<>"D"
     [F:ATZ]LONG    = val([L]LNGFLD)
    Endif
    If [L]DIMFLD = ""
     [F:ATZ]DIME = 1
    Else
     [F:ATZ]DIME = val([L]DIMFLD)
    Endif
    [F:ATZ]NUMLIG = NBCHAMP
    Write [ATZ]
    If fstat
     GOK = 0 : Call ECR_TRACE("Erreur en création champ"-[F:ATZ]CODZONE-"("+FICX3+")",1) From GESECRAN : Break 2
    Endif
   Endif  
  Until fstat<>0
  ## On rajoute à la fin de chaque table un flag 'Repris'
  NBCHAMP += 1
  Raz [F:ATZ]
  [F:ATZ]CODFIC  = [L]FICX3
  [F:ATZ]NUMLIG  = NBCHAMP
  [F:ATZ]CODZONE = "FLGREP"
  [F:ATZ]CODTYP  = "M"
  [F:ATZ]NOLIB   = 1  
  [F:ATZ]LONG    = 4
  [F:ATZ]DIME    = 1
  [F:ATZ]NUMLIG = NBCHAMP
  Write [ATZ]
  If fstat
   GOK = 0 : Call ECR_TRACE("Erreur en création champ"-[F:ATZ]CODZONE-"("+FICX3+")",1) From GESECRAN : Break 2
  Endif
  ## Rajout également d'un champ X3CLE (servira pour traiter les problèmes de clés liés à la codification)
  NBCHAMP += 1
  Raz [F:ATZ]
  [F:ATZ]CODFIC  = [L]FICX3
  [F:ATZ]NUMLIG  = NBCHAMP
  [F:ATZ]CODZONE = "X3CLE"
  [F:ATZ]CODTYP  = "A"
  [F:ATZ]LONG    = 30
  [F:ATZ]DIME    = 1
  [F:ATZ]NUMLIG = NBCHAMP
  Write [ATZ]
  If fstat
   GOK = 0 : Call ECR_TRACE("Erreur en création champ"-[F:ATZ]CODZONE-"("+FICX3+")",1) From GESECRAN : Break 2
  Endif
  ## & d'un champ X3DAT (servira uniquement pour la table XIHISCBGNR et XIHISANA)
  If [L]FICX3="XIHISCBGNR" | [L]FICX3="XIHISANA"
   NBCHAMP += 1
   Raz [F:ATZ]
   [F:ATZ]CODFIC  = [L]FICX3
   [F:ATZ]NUMLIG  = NBCHAMP
   [F:ATZ]CODZONE = "X3DAT"
   [F:ATZ]CODTYP  = "D"
   [F:ATZ]DIME    = 1
   [F:ATZ]NUMLIG = NBCHAMP
   Write [ATZ]
   If fstat
    GOK = 0 : Call ECR_TRACE("Erreur en création champ"-[F:ATZ]CODZONE-"("+FICX3+")",1) From GESECRAN : Break 2
   Endif
  Endif

  ## 3) Enfin, on s'occupe des index de table (ATABIND)
  FICHIER = REPERTOIRE+"/"+LISFIC(NFIC)+".ind"
  Openi FICHIER
  adxifs = ";"
  adxirs = chr$(13)
  adxium = GUTF8
  NBINDEX = 0 : FLGINDEX = 0 
  Repeat
   Rdseq INDEX, CMPIND, HOMONY, XXX
   If INDEX<>""
    Raz [F:ATI]
    NBINDEX += 1
    # Condition pour supprimer les index contenant des champs binaire.
    If !NBCHPBIN
      FLGINDEX = 1
    Else
     FLGINDEX = 1
     For I=0 To NBCHPBIN-1
      If instr(1,[L]CMPIND,"+"+CHPBIN(I)+"+") : FLGINDEX = 0 : Break : Endif
      If instr(1,[L]CMPIND,"+"+CHPBIN(I))     : FLGINDEX = 0 : Break : Endif
      If instr(1,[L]CMPIND,CHPBIN(I)+"+")     : FLGINDEX = 0 : Break : Endif
     Next
    Endif
    If FLGINDEX
     [F:ATI]CODFIC   = [L]FICX3
     [F:ATI]NUMLIG   = NBINDEX
     [F:ATI]CODIND   = "IND"+num$(NBINDEX-1)
     [F:ATI]DESCRIPT = ctrans([L]CMPIND,"_","")
     # Mots réservés X3
     If find(left$([F:ATI]DESCRIPT,4),"PRD+","EXP+","NAP+","REB+","VAR+")
      [F:ATI]DESCRIPT = left$([F:ATI]DESCRIPT,3)+"9"+right$([F:ATI]DESCRIPT,len([F:ATI]DESCRIPT)+2)
     Elsif find(right$([F:ATI]DESCRIPT,len([F:ATI]DESCRIPT)-3),"+PRD","+EXP","+NAP","+REB","+VAR")
      [F:ATI]DESCRIPT += "9"
     Else 
      For WRDX3 = "PRD","EXP","NAP","REB","VAR"
       I = instr(1,[F:ATI]DESCRIPT,"+"+WRDX3+"+") 
       If I
        [F:ATI]DESCRIPT = left$([F:ATI]DESCRIPT,I)+WRDX3+"9+"+right$([F:ATI]DESCRIPT,I+5)
       Endif
      Next
     Endif
     #
     [F:ATI]HOMONYM  = val([L]HOMONY)
     Write [ATI]
     If fstat
      GOK = 0 : Call ECR_TRACE("Erreur en création index"-"IND"+num$(NBINDEX-1)-"("+FICX3+")",1) From GESECRAN : Break 2
     Endif
    Endif
   Endif
  Until fstat<>0

 Next

 If GOK<0   : Goto ROLL_TR_ATBX3
 Elsif !GOK : Goto AB_TR_ATBX3
 Endif
 
 Call ECR_TRACE("",0) From GESECRAN 
 Call ECR_TRACE("Nombre de tables créées :"-num$(NBFIC),0) From GESECRAN

Commit
Return

$AB_TR_ATBX3
Rollback
Return

$ROLL_TR_ATBX3
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_CR_ATBX3 : Endif

$NOMFIC  
FICINT = ctrans(LISFIC(NFIC),"_","")
FICX3 = "XI"+left$(FICINT,4)
FICX3+= string$(len(FICINT)>7,right$(FICINT,len(FICINT)-3))+string$(len(FICINT)=7,right$(FICINT,len(FICINT)-2))
&       +string$(len(FICINT)=6,right$(FICINT,len(FICINT)-1))+string$(len(FICINT)=5,right$(FICINT,len(FICINT)))
Return


######################################################################################
Subprog MAJDDB(TBL,RPT,FIC)
Value Char TBL()
Value Char RPT()
Value Char FIC()
Local Integer NBSEQ, LONG, LNGCHP, FLGEND, NBENR, FLGOK, VIDE
Local Char    FICHIER(250), CTLX3(250)

If !clalev([F:ATZ])  : Local File ATABZON   [ATZ]  : Endif 
If !clalev([F:SIT])  : Local File SITRACOD  [SIT]  : Endif
If !clalev([F:XTBL]) : Local File =[L]TBL   [XTBL] : Endif 

# Longueur d'un enregsitrement
Raz LONG 
For [ATZ]NUMLIG Where CODFIC=[L]TBL
 If [ATZ]CODZONE="FLGREP" : Break: Endif
  Case  [F:ATZ]CODTYP
   When "D"     :     LONG += 8
   When "DCB"   :     LONG += fix([F:ATZ]LONG)+1+val(right$(num$([F:ATZ]LONG),len(num$([F:ATZ]LONG))))
   When Default :     LONG += [F:ATZ]LONG
  Endcase
Next

adxifs = ""
adxirs = chr$(13)+chr$(10)
adxium = GASCII

LONG = LONG + 2        # Ajout de 2 cractères pour la fin d'enregistrement (adxirs)
Local Schar BUFFER(1)(1..LONG)

FICHIER = RPT+"/"+FIC+".dta"
I=0
Raz FLGEND, NBENR
GOK = 1
Trbegin [XTBL]
Openi FICHIER
Getseq LONG,BUFFER
While !fstat
 Gosub TRT1
 Getseq LONG,BUFFER
 If !GOK : Break : Endif
Wend
If !GOK : Rollback : End : Endif
FLGEND = 1 : Gosub TRT1
If !GOK : Rollback : End : Endif
Commit
Call ECR_TRACE("Données reprises :"-TBL-"("+num$(NBENR)-"enregistrements)",0) From GESECRAN
End

$TRT1
#If !FLGEND & ascii([L]BUFFER(LONG))<>10
# Call ECR_TRACE("Problème de longueur d'enregistrement : "-TBL-"("+num$(LONG)+")",0) From GESECRAN 
# GOK=0 : Return
#Endif
NBSEQ=1 : GOK=1
Raz [F:XTBL]
Raz FLGOK, CTLX3, VIDE
For [ATZ]NUMLIG Where CODFIC=[L]TBL
 If [ATZ]CODZONE="FLGREP" : Break: Endif
 Case  [F:ATZ]CODTYP
  When "A"   :    
   Onerrgo ERR_A
    [L]LNGCHP = [F:ATZ]LONG
    Assign "[F:XTBL]"+[F:ATZ]CODZONE With vireblc(sum([L]BUFFER(NBSEQ..NBSEQ+LNGCHP-1)),1)
    If !VIDE & sum([L]BUFFER(NBSEQ..NBSEQ+LNGCHP-1))<>"" : VIDE=1 : Endif
   Onerrgo
  When "D"   :  
   [L]LNGCHP = 8
   Onerrgo ERR_D
    If len(sum([L]BUFFER(NBSEQ..NBSEQ+LNGCHP-1)))=8
     Assign "[F:XTBL]"+[F:ATZ]CODZONE With sum([L]BUFFER(NBSEQ..NBSEQ+LNGCHP-1))
     If !VIDE & sum([L]BUFFER(NBSEQ..NBSEQ+LNGCHP-1))<>"" : VIDE=1 : Endif
    Endif
   Onerrgo
  When "DCB" :  
   Onerrgo ERR_DCB
    [L]LNGCHP = fix([F:ATZ]LONG)+1+val(right$(num$([F:ATZ]LONG),len(num$([F:ATZ]LONG))))
    Assign "[F:XTBL]"+[F:ATZ]CODZONE With val(sum([L]BUFFER(NBSEQ..NBSEQ+LNGCHP-1)))
    If !VIDE & sum([L]BUFFER(NBSEQ..NBSEQ+LNGCHP-1))<>"" : VIDE=1 : Endif
   Onerrgo
  When "L"  :
   [L]LNGCHP = [F:ATZ]LONG
   Onerrgo ERR_L
    Assign "[F:XTBL]"+[F:ATZ]CODZONE With val(sum([L]BUFFER(NBSEQ..NBSEQ+LNGCHP-1)))
    If !VIDE & sum([L]BUFFER(NBSEQ..NBSEQ+LNGCHP-1))<>"" : VIDE=1 : Endif
   Onerrgo
  When Default
   [L]LNGCHP = [F:ATZ]LONG
   Onerrgo ERR
    Assign "[F:XTBL]"+[F:ATZ]CODZONE With sum([L]BUFFER(NBSEQ..NBSEQ+LNGCHP-1))
    If !VIDE & sum([L]BUFFER(NBSEQ..NBSEQ+LNGCHP-1))<>"" : VIDE=1 : Endif
   Onerrgo ERR
 Endcase
 NBSEQ += [L]LNGCHP
Next
# Contrôle de l'enregistrement et Initialisation du champs X3CLE
Onerrgo ERR_X3CLE
 If func SUBSIT.CTLCOD([L]TBL,"XTBL",[L]CTLX3)
  [F:XTBL]X3CLE = [L]CTLX3
 Else
  FLGOK=1
 Endif 
Onerrgo
If !FLGOK & VIDE
 Write [XTBL]
 If fstat
  GOK = 0 : Call ECR_TRACE("Erreur en reprise des données "-"("+TBL+")"-num$(fstat),1) From GESECRAN
 Endif
 NBENR+=1
Endif
Return

######################################################################################
Subprog SUPP(TBL,OK)
Value    Char TBL()
Variable Integer OK
OK = 1
If clalev([F:XTBL])=0 : Local File =[L]TBL  [XTBL] : Endif 
Trbegin [XTBL]
Delete [XTBL] Where 1=1
If fstat=1 | fstat>5
 GOK = 0 : Call ECR_TRACE("Erreur en suppression des données de la table"-TBL,1) From GESECRAN : Rollback
Endif
Commit 
End

######################################################################################
$ERR_A
If GTRACE<>""
 Call ECR_TRACE("Problème zone alphanumérique "-TBL-"("+[F:ATZ]CODZONE+") : "-sum([L]BUFFER(NBSEQ..NBSEQ+[L]LNGCHP-1)),0) From GESECRAN
Endif
Resume

$ERR_D
If GTRACE<>""
 Call ECR_TRACE("Problème de date "-TBL-"("+[F:ATZ]CODZONE+") : "-sum([L]BUFFER(NBSEQ..NBSEQ+[L]LNGCHP-1)),0) From GESECRAN
Endif
Resume

$ERR_DCB
If GTRACE<>""
 Call ECR_TRACE("Problème de décimal "-TBL-"("+[F:ATZ]CODZONE+") : "-sum([L]BUFFER(NBSEQ..NBSEQ+[L]LNGCHP-1)),0) From GESECRAN
Endif
Resume

$ERR_L
If GTRACE<>""
 Call ECR_TRACE("Problème de numérique "-TBL-"("+[F:ATZ]CODZONE+") : "-sum([L]BUFFER(NBSEQ..NBSEQ+[L]LNGCHP-1)),0) From GESECRAN
Endif
Resume

$ERR
If GTRACE<>""
 Call ECR_TRACE("Erreur en récupération de zone "-TBL-"("+[F:ATZ]CODZONE+") : "-sum([L]BUFFER(NBSEQ..NBSEQ+[L]LNGCHP-1)),0) From GESECRAN
Endif
Resume

$ERR_X3CLE
If GTRACE<>""
 Call ECR_TRACE("Erreur en récupération de X3CLE "-TBL,0) From GESECRAN : FLGOK=1
Endif
Resume


######################################################################################
Subprog AS_FIC(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR="/home/cp/INTEGRALE/000"
Endif
End

Subprog C_FIC(VALEUR)
Variable Char    VALEUR()

#-- Contrôle d'un répertoire
Local Integer OK : Raz OK
Call CTLFIC(2,VALEUR,GMESSAGE,OK)
If OK : mkstat=2 : End : Endif

#-- Est ce le bon répertoire...
Local Char    FICHIER(250) , FIC(250), REPERT(250), MACHINE(30) , OS(10)

Call MACHINE(VALEUR,MACHINE,REPERT) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS

Local Integer NBFIC  : Raz NBFIC
Local Integer MAXFIC : MAXFIC  = 500
Local Char    LISFIC(100)(1..MAXFIC)
Local Char    ORDSYS(250)
Local Char    EXTENSION(10) : EXTENSION = "srf"

Case OS
 When "unix"
  ORDSYS = "lsadx -a"-nomap-VALEUR-EXTENSION
  Call SYSTEME2(adxmac(0),ORDSYS,"",NBFIC,LISFIC) From ORDSYS
 When "dos"
  ORDSYS = "lsadx "-REPERT-EXTENSION
  Call SYSTEME2("#",ORDSYS,"",NBFIC,LISFIC) From ORDSYS
Endcase

If NBFIC<=0
 Call ERREUR("Aucun fichier ASCII") From GESECRAN : mkstat=2 : End
Else
 OK = 2
 Call OUINON("Importation Table intégrale : "-num$(NBFIC),OK) From GESECRAN  
 If OK<>2 : mkstat = 2 : End : Endif
Endif
End


Subprog CTLFIC(FLG,VLR,MES,GOK)
Value    Integer FLG      : # FLG=1 Fichier, FLG=2 Répertoire
Value    Char VLR()       : # Valeur saisie
Variable Char MES()       : # Message d'erreur 
Variable Integer GOK      : # Statut d'erreur


Local Integer TYPFIC, OK
Local Char    FICHIER(250) , FIC(250), REPERT(250), MACHINE(30) , OS(10)

Call MACHINE(VLR,MACHINE,REPERT) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
If OS=""
 # Machine inexistante
 GMESSAGE = MACHINE-mess(90,141,1)
 GOK = 2 : End
Endif
Call EXISTE(VLR,TYPFIC) From ORDSYS

# TYPFIC vaut :
#  0 => Inexistant
#  1 => Fichier
#  2 => Répertoire

Case TYPFIC
 When 0 :
  Case num$(FLG)
   When "1" :
    # Fichier inexistant
    GMESSAGE = mess(101,100,1) : GOK=2 : End
   When "2" :
    # Répertoire inexistant
    GMESSAGE = "|"+REPERT-"|:"-mess(9,141,1) : GOK=2 : End
  Endcase
 When 1 : 
  Case num$(FLG)
   When "1" :
    OK = 2
    # Fichier existant, souhaitez-vous l'écraser ?
    Call OUINON(mess(127,105,1),OK) From GESECRAN  
    If OK<>2 : GOK = 2 : End : Endif
   When "2" :
    # Répertoire inexistant
    GMESSAGE = "|"+REPERT-"|:"-mess(9,141,1) : GOK=2 : End
   Endcase
 When 2 : 
   If FLG=1
    GMESSAGE = mess(55,141,1)   :# Ce fichier est un répertoire
    GOK = 2 : End
   Endif
Endcase
End



######################################################################################
Subprog SUPP_BIS(TABLE,OK2)
Value    Char TABLE()
Variable Integer OK2
OK2 = 1 

Local Integer OK , STAT
Local Char    ORDSYS(250)(1..2)
Local Char    FICTRA(GDIMFIC)
Local Char    MESSAGE(80)(1..5)

#OK=1 : Call OUINON(mess(52,123,1)-TABLE,OK) From GESECRAN : # Remise à zéro de la table
#If OK<>2 : End : Endif
FICTRA  = filpath("tmp",TABLE,"tra",0)
If filinfo(FICTRA,0)>=0
 Call EFFACE(FICTRA ,STAT) From ORDSYS
Endif
ORDSYS(1) = "valfil -s -z"
ORDSYS(1) -= nomap-TABLE
ORDSYS(2) = FICTRA
Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS
adxifs = ""
adxirs = chr$(10)
Openi FICTRA
Raz MESSAGE
Rdseq MESSAGE(1)
Rdseq MESSAGE(2)
Rdseq MESSAGE(3)
Openi
If MESSAGE(1)<>""
 OK2 = 0 : # Erreur en validation de la table
 Call ECR_TRACE(mess(51,123,1)-TABLE+"\|"+MESSAGE(1)+"|\|"+MESSAGE(2)+"|\|"+MESSAGE(3),1) From GESECRAN
Endif
End


