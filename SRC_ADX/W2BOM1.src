#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque BOM1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_ITMTOLNEG
Onevent BEFORE_INPUT Call AS_ITMTOLNEG(zc) From W2BOM1
Return

Subprog AS_ITMTOLNEG(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action PASECCUSE2
Call PASECCUSE2 From ECCLIB
If mkstat=2
 [M]ITMTOLNEG(INDIC) = VALEUR
 Affzo ITMTOLNEG(INDIC) : mkstat = 2
Endif
If !mkstat
 ## Action STD
 Call AS_ITMTOLNEG(VALEUR) From SUBBOD
 If mkstat=2
  [M]ITMTOLNEG(INDIC) = VALEUR
  Affzo ITMTOLNEG(INDIC) : mkstat = 2
 Endif
Endif
Gosub _AFF
End

$CHG_STY
Return


