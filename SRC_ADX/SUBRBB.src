#<AdxTL>@(#)4.0.0.0 $Revision$
Raz GBIDC1
Call OBJET("RBB",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "LIENS"       : Gosub LIENS
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "RAZCRE"      : Gosub RAZCRE
 When "INICRE"      : Gosub INICRE
 When "CREATION"    : Gosub CREATION
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "APRES_CRE"   : Gosub APRES_CRE
 When "APRES_MOD"   : Gosub APRES_MOD
 When "INIMOD"      : Gosub INIMOD
 When "MODIF"       : Gosub MODIF
 When "RAZDUP"      : Gosub RAZDUP
 When "ANNULE"      : Gosub ANNULE
 When "ABANDON"     : Gosub ABANDON
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "TIROIR"      : Gosub TIROIR
 When "PICKE"       : Gosub PICKE
 When "DEPICK"      : Gosub DEPICK
 When "DEB_PICK"    : Gosub DEB_PICK
 When "FIN_PICK"    : Gosub FIN_PICK
 When "FIN_ACTION"  : Gosub FIN_ACTION
 When "AVANT_CHOI"  : Gosub AVANT_CHOI
 When "APRES_CHOI"  : Gosub APRES_CHOI
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "VERF_TABLE"  : Gosub VERF_TABLE
 When "SELECH"      : Gosub SELECH
 When "BB4_NBDET"   : Gosub BB4_NBDET
 When "FERME"       : Gosub FERME
 When Default
Endcase
Return
######################################################################################

######################################################################################
$OUVRE
#------------------------------------------------------------------------------------#
If !clalev([F:CPY])    : Local File COMPANY     [CPY]  : Endif
If !clalev([F:GTE])    : Local File GTYPACCENT  [GTE]  : Endif
If !clalev([F:BAN])    : Local File BANK        [BAN]  : Endif
If !clalev([F:BPR])    : Local File BPARTNER    [BPR]  : Endif
If !clalev([F:DUD])    : Local File GACCDUDATE  [DUD]  : Endif
If !clalev([F:HAE])    : Local File GACCENTRY   [HAE]  : Endif
If !clalev([F:SIH])    : Local File SINVOICE    [SIH]  : Endif
If !clalev([F:PIH])    : Local File PINVOICE    [PIH]  : Endif
If !clalev([F:TPD])    : Local File TMPPAYDUD   [TPD]  : Endif
If !clalev([F:TPY])    : Local File TABPAYTYP   [TPY]  : Endif
If !clalev([F:MTB])    : Local File MTCBATCH    [MTB]  : Endif
If !clalev([F:TYC])    : Local File TYPCOMBEL   [TYC]  : Endif
If !clalev([F:CDA])    : Local File GACCDENCOD  [CDA]  : Endif
If !clalev([F:GAC])    : Local File GACCOUNT    [GAC]  : Endif
If !clalev([F:TCA])    : Local File TABCOUAFF   [TCA]  : Endif

If !clalev([F:FRM])    : Local File PAYFRM      [FRM]  : Endif
If !clalev([F:PYH])    : Local File PAYMENTH    [PYH]  : Endif
If !clalev([F:PYD])    : Local File PAYMENTD    [PYD]  : Endif

If !clalev([F:RBH2])   : Local File RBKBELHEA   [RBH2] : Endif

#-- globals
If dim(GCURR_RBKNUM) < 0 : Global Char    GCURR_RBKNUM(GLONVCR) : Endif :#-- current stattment
If dim(GCURR_NOLIGN) < 0 : Global Integer GCURR_NOLIGN          : Endif :#-- current line statement
If dim(GLAST_WINDEX) < 0 : Global Integer GLAST_WINDEX          : Endif :#-- last index line
If dim(GL_INSERT)    < 0 : Global Integer GL_INSERT             : Endif :#-- pour gerer l'insertion sans valider la saisie

Global Integer GNBTYPLED                             : #
Global Integer GNBPLAN                               : # Nb de plans comptables (max 10)
Global Integer GNBAXE                                : # Nb d'axes à saisir (max 20)
Global Char    GPLAN(GLONCOA)(1..10)                 : # Plans (COA)
Global Char    GAXE(GLONDIE)(1..max(GOPTCANA,20))    : # Axes (DIE)
Global Integer GOBLIG(1..max(GOPTCANA,20))           : # Obligatoire (O/N)
Global Integer GTYPLED(1..10)                        : # Types référentiels
Global Char    GL_DEVLED(GLONCUR)                    : # Devise du référentiel


#--Destinations comptables par défaut
If dim(G_DENSPG) < 0 : Global Char G_DENSPG(GLONCDA) : Endif :# Dépense
If dim(G_DENTAK) < 0 : Global Char G_DENTAK(GLONCDA) : Endif :# Recette

If dim(G_BPCTYP) < 0 : Global Char G_BPCTYP(GLONGTE) : Endif :# Dépense
If dim(G_BPSTYP) < 0 : Global Char G_BPSTYP(GLONGTE) : Endif :# Recette

#-- pour gestion picking en action champ et normal
Global Integer GL_FLG_AM
Global Integer GL_POST_PICK :#-- memo apres action de picking
                             #-- pour repositionner sur la bonne ligne et eviter les refresh intempestifs
Global Char GBOX_RBB(8)   :#-- tiroir releve
Global Char GBOX_RB1(8)   :#-- tiroir echeances
Global Char GBOX_RB2(8)   :#-- tiroir bordereaux de remise

Global Integer G_BELRBK    :#-- parameter value for "BELRBK"

#-- pour sauvegarde contexte ligne saisie relevé
Global Char GL_FCY(GLONFCY), GL_BPRPAY(GLONBPR), GL_ACCTMP(GLONGAC), GL_FRMNUM(GLONFRM),GL_PAYTYP(GLONTPY)
Global Date GL_ACCDAT,GL_VALDAT
Global Decimal GL_AMTCUR
Global Integer GL_SNS
#--

# -- divers locals
Local Integer W_AFF_DEPICK  :#-- pour re-affichage apres depick des echeances
Local Integer WI, WJ, WK, W_STAT, STAT, SAV_NOLIGN, WNOL, WADXLOG, SAV_GCONSULT
Local Decimal W_MT, W_MTBAN, W_COURS

Local Char     WS_GREP(1)  :#-- save GREP avant refresh
Local Integer  WL_SIGN    :#-- pour gestion signe montants
Local  Integer WL_NBDET_ORI  :#-- nombre de lignes origines dans le releve

SAV_GCONSULT=GCONSULT
Return

######################################################################################
$OUVRE_BOITE
#------------------------------------------------------------------------------------#
GBOX_RBB="GAU_CHE"
GBOX_RB1="GAU_CHE"+num$(find("RB1",OBJLIS)-1) :#-- echeances
GBOX_RB2="GAU_CHE"+num$(find("RB2",OBJLIS)-1) :#-- bordereaux de remise
Return

######################################################################################
FILGAUCHE
#------------------------------------------------------------------------------------#
Local Integer WI
Local Char W_OPT(1)
[L]WI=[V]GCURR_NOLIGN-1
If find(currbox, GBOX_RB1,GBOX_RB2)
  FILGAUSUP="2=1"
  If [V]GCURR_NOLIGN>0
    If [V]GL_FLG_AM=0
      Gosub SAVE_LINE_VALUE :## sauvegarde des elements modifiables de la ligne courante du releve
    Endif
    If [V]GL_FCY="" or [M:RBK1]STATUT([L]WI)=3  : Return : Endif
    If currbox=GBOX_RB1
      If [V]GL_BPRPAY<>"" & [M:RBK1]FRMNUM([L]WI)=""
        FILGAUSUP ="[F:DUD]FLGCLE=1 & [F:DUD]DUDSTA=2 & !find([F:DUD]TYP,'*SO','*PO') & [F:DUD]BPRPAY=[V]GL_BPRPAY & [F:DUD]BPRFCT=''"
        FILGAUSUP-="& [F:DUD]FLGPAZ>3 & [F:HAE]FLGREP<>2 & [F:HAE]CAT=1"
        Call PARAM([V]GL_FCY,"SEVFCYENT", W_OPT) From ADOVAL    :## inter-sites
        If [L]W_OPT<>"2"
          FILGAUSUP-="& [F:DUD]FCY=[V]GL_FCY"
        Else
          ## WX=instr(1, CRITERE(0),"[F:FUD]FCY")
          ## If WX > 0
            FILGAUSUP-="& [F:DUD]CPY=[M:RBK0]CPY"
          ##Else
          ##  FILGAUSUP-="& [F:DUD]FCY=[V]GL_FCY"
          ## Endif
        Endif
        If GUSRFCY(1)<>"\" : FILGAUSUP-="& find([F:DUD]FCY,GUSRFCY(1..GNBAUZ))" : Endif
      Endif
    Else #--GBOX_RB2
      If [V]G_BELRBK=2
        If  [V]GL_BPRPAY="" & [V]GL_ACCTMP="" # & [M]FRMNUM([L]WI)="" & [M:RBK1]PAYTYP([L]WI)=""
          FILGAUSUP="CPY=[M]CPY & BAN=[M]BAN & STA=8 & FRMFCY=[V]GL_FCY" # & LEG=[V]GCURLEG"
        Endif
      Endif
    Endif
  Endif
Endif
Return

######################################################################################
$APRES_MODIF
#------------------------------------------------------------------------------------#
If !find(COUZON,"NBDET","FCYLIN","FRMNUM","BPRNUM","ACCDAT","VALDAT","SNS","AMTCUR","PAYTYP","ACCTMP") : Return : Endif
#-- positionnement de critères pour les listes gauches
Gosub SAVE_LINE_VALUE :## sauvegarde des elements modifiables de la ligne courante du releve
Case COUZON
  When "FCYLIN"
    [V]GL_FCY=CZ
    [V]GL_FLG_AM=2
  When "BPRNUM"
    [V]GL_BPRPAY=CZ
    [V]GL_FLG_AM=2
  When "ACCTMP" :
    [V]GL_ACCTMP=CZ
    [V]GL_FLG_AM=2
  When "FRMNUM"
    [V]GL_FRMNUM=CZ
    [V]GL_FLG_AM=2
  When "ACCDAT" : [V]GL_ACCDAT=CZ
  When "VALDAT" : [V]GL_VALDAT=CZ
  When "SNS"    : [V]GL_SNS=val(CZ)
  When "AMTCUR" : [V]GL_AMTCUR=val(CZ)
  When "PAYTYP" : [V]GL_PAYTYP=CZ
  When "NBDET"  : Gosub RAZ_LINE_VALUE
Endcase
If [V]GL_FLG_AM=2
  Gosub TIROIR
  [V]GL_FLG_AM=0
Endif
Return

#**
#* sauvegarde des elements modifiables de la ligne courante du releve
#*!
$SAVE_LINE_VALUE
If [V]GCURR_NOLIGN > 0
  Local Integer WK
  [L]WK=[V]GCURR_NOLIGN-1
  [V]GL_FCY   =[M]FCYLIN([L]WK)
  [V]GL_FRMNUM=[M]FRMNUM([L]WK)
  [V]GL_BPRPAY=[M]BPRNUM([L]WK)
  [V]GL_ACCDAT=[M]ACCDAT([L]WK)
  [V]GL_VALDAT=[M]VALDAT([L]WK)
  [V]GL_SNS   =[M]SNS([L]WK)
  [V]GL_AMTCUR=[M]AMTCUR([L]WK)
  [V]GL_PAYTYP=[M]PAYTYP([L]WK)
  [V]GL_ACCTMP=[M]ACCTMP([L]WK)
Endif
Return

#**
#* reset des elements modifiables de la ligne courante du releve
#*!
$RAZ_LINE_VALUE
Raz [V]GL_FCY,[V]GL_BPRPAY,[V]GL_ACCDAT,[V]GL_VALDAT,[V]GL_SNS,[V]GL_AMTCUR,[V]GL_PAYTYP,[V]GL_ACCTMP,[V]GL_FRMNUM
Return

######################################################################################
$TIROIR
#------------------------------------------------------------------------------------#
Case currbox
  When GBOX_RB1,GBOX_RB2
    ILIS = val(right$(currbox,8))
    Gosub REMP_LISGAU From GOBJSUB
    Gosub REFRESH_PICK
Endcase
Return

######################################################################################
$FERME
#------------------------------------------------------------------------------------#
Gosub CLEAN_WORK
Kill GCURR_RBKNUM, GCURR_NOLIGN, GLAST_WINDEX
Kill G_BPCTYP, G_BPSTYP, G_BELRBK, GL_DEVLED, G_DENSPG, G_DENTAK
Kill GBOX_RBB, GBOX_RB1, GBOX_RB2
Kill GL_FLG_AM, GL_POST_PICK, GL_INSERT
Kill GL_FCY, GL_BPRPAY,GL_ACCDAT,GL_VALDAT,GL_AMTCUR,GL_PAYTYP,GL_SNS,GL_ACCTMP,GL_FRMNUM

GCONSULT=SAV_GCONSULT
Return

#----------
$CLEAN_WORK
#----------
[L]WADXLOG=adxlog
If [V]GCURR_RBKNUM<>""
  If [L]WADXLOG <> 1 : Trbegin [F:RBW] : Endif
  Delete [F:RBW]  Where  RBKNUM=[V]GCURR_RBKNUM
  If [L]WADXLOG <> 1 : Commit : Endif
Endif
Return

#----------
$SET_GLOBAL
#----------
Call GETSOC([M:RBK0]FCY) From DEVSUB      :#--@backporting@ ?
Call SETPLAN([M:RBK0]CPY,GNBPLAN,GPLAN,GTYPLED,GNBAXE,GAXE,GOBLIG) From CPTDIV
[M:RBK0]COA = GPLAN(1)
Call SETCUR(1,[M:RBK0]CPY,[V]GL_DEVLED) From CPTDIV

 #--Destinations comptables par défaut
Call PARAM([M:RBK0]CPY,"DENSPG", [V]G_DENSPG) From ADOVAL     :# Dépense
Call PARAM([M:RBK0]CPY,"DENTAK", [V]G_DENTAK) From ADOVAL     :# Recette

Call PARAM([M:RBK0]CPY,"BPCORDTYP",[V]G_BPCTYP) From ADOVAL   :# CCL
Call PARAM([M:RBK0]CPY,"BPSORDTYP",[V]G_BPSTYP) From ADOVAL   :# CCF

Local Char STEMP_CHAR(10)
Call PARAM([M:RBK0]CPY,"BELRBK",[L]STEMP_CHAR) From ADOVAL  :#-- flag select bordereaux
[V]G_BELRBK=val([L]STEMP_CHAR)

Return

######################################################################################
$SETBOUT
#------------------------------------------------------------------------------------#
If REP="" & CLECUR
  [L]W_STAT=0
  ##-- duplication is forbidden
  Call VIREBOUT(CHAINE,"D") From GOBJET
  ##-- annulation interdite si ce n'est pas le dernier releve
  ##   ou si au moins une ligne du relevé a até validée
  ##   ou si un releve fait reference au meme nom de fichier avec des lignes validées
  If [M:RBK0]WLASTFLG<>2
    [L]W_STAT=1
  Else
    For WI=0 To [M:RBK1]NBDET-1
      If [M:RBK1]STATUT(WI)=3
        [L]W_STAT=1 : Break
      Endif
    Next
    If [M:RBK0]FILNAM<>"" and [L]W_STAT=0
      Link [RBH2] With [RBD]RBD0(1)=[F:RBH2]RBKNUM As [WRB_]
&               Where [F:RBH2]FILNAM=[M:RBK0]FILNAM & [F:RBH2]RBKNUM<>[M:RBK0]RBKNUM
&                   & [F:RBD]STATUT=3
      [L]W_STAT=rowcount([WRB_])
      Close File [WRB_]
    Endif
  Endif
  If [L]W_STAT>0 : Call VIREBOUT(CHAINE,"A") From GOBJET : Endif
Endif

If GREP<>"" or !VERROU
  Call VIREBOUT(CHAINE,"V") From GOBJET
Else
  If find(2,[M:RBK1]VALFLG(0..[M:RBK1]NBDET-1))<1
    Call VIREBOUT(CHAINE,"V") From GOBJET
  Endif
Endif

Return

######################################################################################
$EXEBOUT
#------------------------------------------------------------------------------------#
Case BOUT
  When "V" : Gosub AFTER_VALIDATION
  When Default
Endcase
Return

$AFTER_VALIDATION
Raz BOUT  :## pour eviter revalidation
[L]WS_GREP = GREP : GREP=""
Gosub REFRESH_CURR_RBK
GREP=[L]WS_GREP
BOUT="V"
Return


######################################################################################
$LIENS
#------------------------------------------------------------------------------------#
Local Integer WNUM, K
[V]GL_POST_PICK  = 0
[V]GL_INSERT =0

Gosub SET_GLOBAL

Grizo [M:RBK0]BAN,FCY
Actzo [M:RBK0]OLDDAT,OLDAMT,OLDSNS

#-- set bank account
Call GET_BANACC([M:RBK0]BAN,[M:RBK0]BANACC)

#-- free comment
Raz [M:RBK2]WFRETXT
Setlob [M:RBK2]WFRETXT With sigma(K=0,dim([F:RBH]FRETXT )-1,[F:RBH]FRETXT(K)+chr$(13))

#--statement lines
[M:RBK0]AMTCDT=0 : [M:RBK0]AMTDEB=0
Raz [M:RBK1]

SAV_NOLIGN=nolign
nolign = 0
For [F:RBD]RBD0 Where  RBKNUM=[F:RBH]RBKNUM
  nolign+=1
  [M:RBK1] = [F:RBD]
  [M:RBK1]RBKLIN(nolign-1)=[F:RBD]RBKLIN
  [M:RBK1]WINDEX(nolign-1)=[F:RBD]RBKLIN
  Case [F:RBD]SNS
    When 1
      [M:RBK0]AMTCDT+= [F:RBD]AMTCUR
    When 2
      [M:RBK0]AMTDEB+= [F:RBD]AMTCUR
    When Default
  Endcase
  GLAST_WINDEX  = [F:RBD]RBKLIN
Next
[M:RBK1]NBDET   = nolign
[L]WL_NBDET_ORI = [M:RBK1]NBDET
Affzo [M:RBK1]10
GLAST_WINDEX+=1000
nolign=SAV_NOLIGN

Gosub CALC_WNEWAMT  :#-- calc new solde

#--statement detail by line
Gosub CLEAN_WORK
GOK = 1
Trbegin [F:RBW]
[V]GCURR_RBKNUM = num$(adxuid(2)) :#-- set temporary statement number ? num$(uniqid([F:RBW]))
For [F:RBU]RBU0 Where  RBKNUM=[F:RBH]RBKNUM
  [F:RBW] = [F:RBU]
  [F:RBW]RBKNUM=GCURR_RBKNUM
  [F:RBW]DUDNUMORI=[F:RBU]DUDNUM  ##-- memo origine pour traitement modif
  [F:RBW]DUDLIGORI=[F:RBU]DUDLIG
  ##[F:RBW]AMTLINORI=[F:RBU]AMTLIN
  [F:RBW]AMTLINCURORI=[F:RBU]AMTLINCUR
  Write [F:RBW]
  If fstat
   GOK=0 : Call FSTA("RBW") From GLOCK : Break
  Endif
Next
If GOK : Commit : Else Rollback : Endif

#-- first line statement detail
If GCURR_NOLIGN>0 : Chgstl [M:RBK1]NBDET(GCURR_NOLIGN-1) With "" : Endif :#-- reset style
SAV_NOLIGN=nolign
[V]GCURR_NOLIGN=0
nolign=1
Call AS_NBDET
nolign=SAV_NOLIGN
Return

#**
#* calcul nouveau solde théorique
#*!
$CALC_WNEWAMT
#------------
[M:RBK0]WNEWAMT=[M:RBK0]AMTDEB-[M:RBK0]AMTCDT
If  [M:RBK0]OLDSNS = 1 :#--debit
  [M:RBK0]WNEWAMT+=[M:RBK0]OLDAMT
Else
  [M:RBK0]WNEWAMT-=[M:RBK0]OLDAMT
Endif
Affzo [M:RBK0]AMTDEB,AMTCDT,WNEWAMT
Return
#

#**
#* Affectation du compte banque
#*
#* @param IN_BANK
#* @param OUT_BANACC
#*!
Subprog GET_BANACC(IN_BANK,OUT_BANACC)
Value Char IN_BANK
Variable Char OUT_BANACC
Local Integer K
Call LEC_BAN(IN_BANK) From CPTLEC
OUT_BANACC = [F:BAN]BANACC
For K=0 To dim([F:BAN]JOUTYP)-1
  If [F:BAN]JOUTYP(K)=1 :## journal de banque
    OUT_BANACC = [F:BAN]TREACC(K)
    Break
  Endif
Next K
End

######################################################################################
$RAZCRE
#------------------------------------------------------------------------------------#
Raz [M:RBK0]RBKNUM
Diszo [M:RBK0]RBKNUM
[M:RBK0]RELTYP=2    :#-- rlv saisi
[M:RBK0]FILTYP=2    :#-- manuel
[M:RBK0]OLDSNS= 1
[M:RBK0]NEWSNS= 1
[M:RBK0]CREDAT=date$
Affzo [M:RBK0]RBKNUM,CREDAT,FILTYP,OLDSNS,NEWSNS
GCURR_RBKNUM  = num$(adxuid(2)) :#-- set temporary statement number ? num$(uniqid([F:RBW]))
Gosub CLEAN_WORK
[V]GLAST_WINDEX=0
[V]GCURR_NOLIGN=0
[V]GL_POST_PICK=0
[L]WL_NBDET_ORI=0
Gosub RAZ_LINE_VALUE
Gosub CLEAN_WORK

#-- si on est sur une liste de picking --> reinit liste gauche
If find(currbox, GBOX_RB1,GBOX_RB2)
  If currbox = GBOX_RB1
    Filter [F:DUD_] Where 2=1
    Fillbox [RBK1] GAU_CHE1
    Filter [F:DUD_]
  Else  :#--GBOX_RB2
    Filter [F:FRM] Where 2=1
    Fillbox [RBK1] GAU_CHE2
    Filter [F:FRM]
  Endif
Endif

Return

######################################################################################
$RAZDUP
#------------------------------------------------------------------------------------#
# la duplication est inhibée
Return

######################################################################################
$INICRE
#------------------------------------------------------------------------------------#
Call LECTCA(3,STAT) From SUBTCA
If STAT : GCODNUM= [F:TCA]CODNUM(5) : Endif
If GCODNUM="" : GCODNUM = "BERBK"   : Endif

Call NUMERO(GCODNUM,[M:RBK0]FCY,date$,[M:RBK0]BAN,[M:RBK0]RBKNUM ,STAT) From SUBANM
If GOK<0
  Return
Elsif GOK<1 | STAT<>0
  Local Char MESSA(80)
  GMESSAGE=mess(60,199,1)-"("+GCODNUM+") : "
  Gosub MESSAGE From SUBANM
  GMESSAGE-=MESSA : GOK=0 : GERR=1
  Return
Endif
[M:RBK0]RBKNUM=vireblc([M:RBK0]RBKNUM,4)
[F:RBH]RBKNUM=[M:RBK0]RBKNUM
[F:RBH]ACCNUM=uniqid([F:RBH])
If [M:RBK1]NBDET > 0
  [F:RBH]STATUT=min ([M:RBK1]STATUT(0..[M:RBK1]NBDET-1))
Else
  [F:RBH]STATUT=1
Endif
Affzo [M:RBK0]RBKNUM
Return

######################################################################################
$VERIF_CRE
#------------------------------------------------------------------------------------#
Local Decimal W_MT
Local Integer WOK
Raz [L]W_MT
If  [M:RBK0]NEWSNS = 1  :#--debit
  [L]W_MT=[M:RBK0]NEWAMT
Else
  [L]W_MT-=[M:RBK0]NEWAMT
Endif

Gosub CALC_WNEWAMT  :#-- calcul nouveau solde théorique

If [M:RBK0]WNEWAMT<>[L]W_MT
  # Nouveau solde <> Ancien solde + Total des mouvements
  GMESSAGE=mess(13,120,1)+"\"+mess(187,121,1)
  Call OUINON(GMESSAGE,WOK) From GESECRAN
  GMESSAGE=""
  If WOK=2
    [M:RBK0]NEWAMT=abs([M:RBK0]WNEWAMT)
    If [M:RBK0]WNEWAMT>0
      [M:RBK0]NEWSNS = 1  :#--debit
    Else
      [M:RBK0]NEWSNS = 2  :#--credit
    Endif
    Affzo [M:RBK0]NEWAMT, NEWSNS
  Else
    GERR=1 : [L]OK=0
 Endif
Endif
Return

######################################################################################
$VERIF_MOD
#------------------------------------------------------------------------------------#
Gosub VERIF_CRE
If !OK : Return : Endif

#-- cas : modification d'un relevé alors qu'un relevé suivant existe
#-- controle que le nouveau solde du releve est egal a l'ancien solde du relevé suivant
If [M:RBK0]WLASTFLG<>2
  If [M:RBK0]WLASTOLDAMT<>[M:RBK0]NEWAMT
    ## Le nouveau solde n'est pas égal à l'ancien solde du relevé suivant
    Call OUINON(mess(190,121,1)+"\"+mess(205,100,1), WOK) From GESECRAN
    If WOK<>2 : GERR=1 : [L]OK=0 : Endif
  Endif
Endif

Return

######################################################################################
$CREATION
#------------------------------------------------------------------------------------#
#--statement lines
[L]WL_SIGN=1
SAV_NOLIGN=nolign
For nolign=1 To [M:RBK1]NBDET
  Raz [F:RBD]
  [F:RBD] = [M:RBK1]
  [F:RBD]RBKNUM=[F:RBH]RBKNUM
  [F:RBD]RBKLIN=nolign
  [F:RBD]COA   =[M:RBK0]COA
  Write [F:RBD]
  If fstat
   GOK=0 : Call FSTA("RBD") From GLOCK : Break
  Endif
  #--statement detail by line
  [L]WJ=0
  For [F:RBW]RBW0 Where  RBKNUM=[V]GCURR_RBKNUM & RBKLIN=[M:RBK1]WINDEX(nolign-1) & AMTLIN<>0
    [L]WJ+=1
    [F:RBU]      = [F:RBW]
    [F:RBU]RBKNUM=[F:RBD]RBKNUM
    [F:RBU]RBKLIN=[F:RBD]RBKLIN
    [F:RBU]LIN   =[L]WJ
    [F:RBU]COA   =[M:RBK0]COA
    If [F:RBD]FRMNUM="" & [F:RBD]STATUT<>3
      If [F:RBU]VCRNUM=""  : [F:RBU]AMTLINCUR=[F:RBU]AMTLIN : Endif
      Gosub CALC_AMTLINLOC : If GOK < 1 : Break 2 : Endif
      If [F:RBU]DUDNUM>0 & [F:RBU]DUDLIG>0
        Gosub UPDATE_DUD : If GOK<1 : Break 2 : Endif
      Endif
    Endif
    Write [F:RBU]
    If fstat
     GOK=0 : Call FSTA("RBU") From GLOCK : Break 2
    Endif
  Next
  [M:RBK1]RBKLIN(nolign-1)=[F:RBD]RBKLIN
  Affzo  [M:RBK1]RBKLIN(nolign-1),WINDEX(nolign-1)  :#--//
Next
If GOK<1 : Return : Endif
nolign = SAV_NOLIGN
Return

#--------------
$CALC_AMTLINLOC
#--------------
If [F:RBU]AMTLIN=0
  [F:RBU]AMTLINLOC=0
  Return
Endif
If [V]GL_DEVLED=[F:RBH]CUR
  [F:RBU]AMTLINLOC = [F:RBU]AMTLIN
  Return
Endif

Call LEC_TPY_LEG([V]GCURLEG,[F:RBD]PAYTYP) From CPTLEC
[L]W_COURS=0
If [F:RBU]DUDNUM<>0 & [F:RBU]VCRNUM<>""
  Read [HAE]HAE0 = [F:RBU]VCRTYP;[F:RBU]VCRNUM
  If fstat : GOK=0 : Call RSTA("HAE",[F:RBU]VCRTYP+"/"+[F:RBU]VCRNUM) From GLOCK : Return : Endif
  If [V]GL_DEVLED = [F:HAE]CUR
    [F:RBU]AMTLINLOC = [F:RBU]AMTLINCUR
    Return
  Endif
Endif

Call CONVERT3([F:RBH]CUR,[V]GL_DEVLED,[V]GL_DEVLED,[F:TPY]RATTYP,[F:RBD]ACCDAT,[F:RBU]AMTLIN,[F:RBU]AMTLINLOC,
&                   [L]W_COURS,STAT) From CPTSUB
If STAT
  ## Pas de cours de devises [F:DUD]CUR -> [F:RBH]CUR
  GMESSAGE=mess(16,114,1)-[F:RBH]CUR-"->"-[V]GL_DEVLED-"("+format$("D:"+GFMDAT,[F:RBD]ACCDAT)-")"
  GOK=0
Endif
Return

#----------
$UPDATE_DUD
#----------
Readlock [DUD]DUD1 = [F:RBU]DUDNUM;[F:RBU]DUDLIG
If fstat=1
  GOK=-1 : GLOCK="$GACCDUDATE"-num$([F:RBU]DUDNUM)-num$([F:RBU]DUDLIG)
Elsif fstat
  GOK=0 : Call RSTA("DUD",num$([F:RBU]DUDNUM)-num$([F:RBU]DUDLIG)) From GLOCK
  Return
Endif
[F:DUD]TMPCUR+=[L]WL_SIGN*[F:RBU]AMTLINCUR
[F:DUD]TMPLOC+=[L]WL_SIGN*[F:RBU]AMTLINLOC
Call SLDECH("DUD")From MODECHE
Rewrite [F:DUD]
If fstat : GOK=0 : Call FSTA("DUD") From GLOCK : Endif
Return

######################################################################################
$APRES_CRE
#------------------------------------------------------------------------------------#
Grizo [M:RBK0]BAN,FCY
Actzo [M:RBK0]RBKNUM,NEWDAT,NEWAMT,NEWSNS
Affzo [M:RBK0]RBKNUM,BAN,FCY,NEWDAT,NEWAMT,NEWSNS
[L]WS_GREP = GREP : GREP=""
Gosub REFRESH_CURR_RBK
GREP=[L]WS_GREP
Return

######################################################################################
$APRES_MOD
#------------------------------------------------------------------------------------#
Gosub REFRESH_CURR_RBK
Return

#**
#* Refresh current rbk after changes
#*
#*!
$REFRESH_CURR_RBK
If GCURR_NOLIGN>0 : Chgstl [M:RBK1]NBDET([V]GCURR_NOLIGN-1) With "" : Endif
[V]GCURR_NOLIGN=0
Gosub RELIT From GOBJSUB
Return

######################################################################################
$INIMOD
#------------------------------------------------------------------------------------#
If [M:RBK1]NBDET > 0
  [F:RBH]STATUT=min ([M:RBK1]STATUT(0..[M:RBK1]NBDET-1))
Else
  [F:RBH]STATUT=1
Endif
Return

######################################################################################
$MODIF
#------------------------------------------------------------------------------------#
#-- dans le cas ou on le meme nombre de lignes qu'a l'origine et que le statut global
#   du relevé est "validé" --> on evite la mise a jour des lignes
#   --> on tient compte du nb de lignes car on peut supprimer les lignes non validées
#   pour ne conserver que les lignes vlaidées
If [F:RBH]STATUT=3 & ([L]WL_NBDET_ORI=[M:RBK1]NBDET) : Return : Endif

Gosub RESTORE_DUD : If GOK<1 : Return : Endif
Delete [F:RBD] Where  RBKNUM=[M:RBK0]RBKNUM
Delete [F:RBU] Where  RBKNUM=[M:RBK0]RBKNUM
Gosub CREATION
Return

#**
#* restauration du montant en cours de reglement sur les lignes non validées du relevé
#*!
$RESTORE_DUD
Local Integer  WL_SIGN
[L]WL_SIGN=-1
For [F:RBD] Where RBKNUM=[M:RBK0]RBKNUM & STATUT<> 3 & FRMNUM=""
  For [F:RBU] Where RBKNUM=[M:RBK0]RBKNUM & RBKLIN=[F:RBD]RBKLIN & DUDNUM>0 & DUDLIG>0
    Gosub UPDATE_DUD
    If GOK<1 : Break 2 : Endif
  Next
Next
Return

######################################################################################
$ANNULE
#------------------------------------------------------------------------------------#
Gosub RESTORE_DUD : If GOK<1 : Return : Endif
Delete [F:RBD] Where  RBKNUM=[M:RBK0]RBKNUM
Delete [F:RBU] Where  RBKNUM=[M:RBK0]RBKNUM
Delete [F:RBW] Where  RBKNUM=[V]GCURR_RBKNUM
Return

######################################################################################
$ABANDON
Gosub CLEAN_WORK
Actzo [M:RBK0]RBKNUM,BAN,FCY,NEWDAT
If GCURR_NOLIGN>0 : Chgstl [M:RBK1]NBDET(GCURR_NOLIGN-1) With "" : Endif
[V]GCURR_NOLIGN=0
Return

######################################################################################
$DEB_PICK
#------------------------------------------------------------------------------------#
#-- pas de picking si rien en cours ou incompatibilité avec données ligne en cours
[L]WI=[V]GCURR_NOLIGN-1
If [L]WI<0 : OK = 0 : Return : Endif

Gosub STORE_CURR_LINE :#-- creation eventuelle de la ligne si pas totalement saisie
If [M:RBK1]FCYLIN([L]WI)="" & [V]GL_FCY = "" :  OK = 0 : Endif
Return

######################################################################################
FIN_PICK
#------------------------------------------------------------------------------------#
GL_POST_PICK = 2    :#-- pour action post-pick
If [L]W_AFF_DEPICK = 2 : Affzo [M:RBK1]20 : Endif
Return

######################################################################################
PICKE
#------------------------------------------------------------------------------------#
[L]W_AFF_DEPICK = 0
Case currbox
  When GBOX_RB1 : Gosub PICKE_DUD
  When GBOX_RB2 : Gosub PICKE_FRM
Endcase
Return

#---------
$PICKE_DUD
#---------
If [M:RBK1]FRMNUM([V]GCURR_NOLIGN-1)<>"" : OK = 0 : Return : Endif
If [M:RBK1]NBDUD = dim([M:RBK1]DENCOD)
  ## Limite en nombre de lignes atteinte
  GMESSAGE=func AFNC.MESN(mess(22,146,1),num$([M:RBK1]NBDUD)) : OK = 0
  Return
Endif
Gosub STORE_CURR_LINE :#-- creation eventuelle de la ligne si pas totalement saisie

#-- gestion de la ligne pickée
## controles inutiles --> voir filtre
#Read [F:HAE]HAE0=[F:DUD]NUM;[F:DUD]TYP
##If !fstat
##  If [F:HAE]CAT = 2 | [F:HAE]CAT = 3
     # Pièces de simulation interdites
##     GMESSAGE = mess(6,107,1) : OK=0
##  Elsif [F:HAE]CAT = 5
     # Pièces modèles interdites
##     GMESSAGE = mess(55,106,1) : OK=0
##  Elsif [F:HAE]FLGREP=2
    # Pièce de fin d'exercice
##    GMESSAGE = mess(20,121,1) : OK=0
##  Endif
##Endif
If !OK : Return : Endif

Filter [MTB] Where ACCNUM=[F:DUD]ACCNUM & DUDLIG=[F:DUD]DUDLIG
Look [MTB]MTB0 First
Filter [MTB]
If !fstat
  ## Echéance en cours de lettrage
  GMESSAGE=mess(70,119,1) : OK=0 : Return
Endif

#-- verif disponible ok sur echeance
Call MTECHE([L]W_MT, [L]W_MTBAN, [M:RBK1]NBDUD, [L]W_STAT) From SUBRBB2
If [L]W_STAT : OK=0 : Return : Endif
If [F:DUD]AMTCUR*[L]W_MT<=0
  ## Echéance déjà soldée
  GMESSAGE=mess(15,117,1) : OK=0 : Return
Endif

#-- chargement nouvelle ligne echeance
[L]SAV_NOLIGN=nolign
[L]WI = [M:RBK1]NBDUD
[M:RBK1]NBDUD += 1
nolign=[M:RBK1]NBDUD
Raz [M:RBK1]DENCOD([L]WI),[M:RBK1]ACC([L]WI),[M:RBK1]VCRTYP([L]WI),[M:RBK1]VCRNUM([L]WI),[M:RBK1]AMTLIN([L]WI),[M:RBK1]VATLIN([L]WI),
& [M:RBK1]REFINT([L]WI),[M:RBK1]BELVCS([L]WI),[M:RBK1]BIDNUM([L]WI),[M:RBK1]BICCOD([L]WI),[M:RBK1]OFFACCNAM([L]WI),
& [M:RBK1]NUMSEQ([L]WI),[M:RBK1]TYP([L]WI),[M:RBK1]CODOP([L]WI),[M:RBK1]RUB([L]WI),[M:RBK1]COMFLG([L]WI),[M:RBK1]TYPCOM([L]WI),
& [M:RBK1]COMFLD([L]WI),[M:RBK1]LIN([L]WI),[M:RBK1]DUDNUM([L]WI),[M:RBK1]DUDLIG([L]WI),[M:RBK1]DUDDAT([L]WI)

Call AS_DENCOD([M:RBK1]DENCOD([L]WI))
Call AS_VATLIN([M:RBK1]VATLIN([L]WI))

[M:RBK1]VCRNUM([L]WI)=[F:DUD]NUM
[M:RBK1]VCRTYP([L]WI)=[F:DUD]TYP

[M:RBK1]DUDNUM([L]WI)=[F:DUD]ACCNUM
[M:RBK1]DUDLIG([L]WI)=[F:DUD]DUDLIG
[M:RBK1]DUDDAT([L]WI)=[F:DUD]DUDDAT
## [M:RBK1]AMTLIN([L]WI) = [L]W_MT
[M:RBK1]AMTLIN([L]WI) = [L]W_MTBAN
[M:RBK1]AMTLINCUR([L]WI) = [L]W_MT

#-- montant non saisi avant pickings --> alimentation montant ligne relevé
#-- suppression code suite remontee du PBA
## If [V]GL_AMTCUR=0
##   [L]WK=[V]GCURR_NOLIGN-1
##   [M:RBK1]AMTCUR([L]WK)+=[L]W_MT
##   Affzo [M:RBK1]AMTCUR([L]WK)
##   Case [M:RBK1]SNS([L]WK)
##     When 1
##       [M:RBK0]AMTCDT+= [M:RBK1]AMTCUR([L]WK)
##     When 2
##       [M:RBK0]AMTDEB+= [M:RBK1]AMTCUR([L]WK)
##     When Default
##   Endcase
##   Gosub CALC_WNEWAMT  :#-- calc new solde
## Endif

#Affzo [M:RBK1]20
Affzo [M:RBK1]DENCOD([L]WI),ACC([L]WI),VCRTYP([L]WI),VCRNUM([L]WI),AMTLIN([L]WI),VATLIN([L]WI),
& REFINT([L]WI),BELVCS([L]WI),BIDNUM([L]WI),BICCOD([L]WI),OFFACCNAM([L]WI),
& NUMSEQ([L]WI),TYP([L]WI),CODOP([L]WI),RUB([L]WI),COMFLG([L]WI),TYPCOM([L]WI),COMFLD([L]WI),
& LIN([L]WI),DUDNUM([L]WI),DUDLIG([L]WI),DUDDAT([L]WI)

nolign=[L]SAV_NOLIGN
Return

#---------
$PICKE_FRM
#---------
[L]WI=[V]GCURR_NOLIGN-1
If  [M]BPRNUM([L]WI)<>"" or  [M]ACCTMP([L]WI)<>"" : OK=0 : Return : Endif
[V]GL_BPRPAY="" : [M:RBK1]BPRNUM([L]WI) = ""
Gosub STORE_CURR_LINE :#-- creation eventuelle de la ligne si pas totalement saisie

#-- verif qu'un bordereau n'est pas deja affecté à la ligne en cours
If [M]FRMNUM([L]WI)<> ""
  ## Bordereau déjà imputé sur la ligne
  GMESSAGE=mess(185,121,1)
  OK=0 : Return
Endif
#-- verif que le bordereau n'est pas deja affecté - sur le relevé en cours
For [L]WK=0 To [M]NBDET-1
  If [M]FRMNUM([L]WK)=[F:FRM]FRMNUM & [L]WK<>([V]GCURR_NOLIGN-1)
    ## Bordereau déjà imputé sur la ligne
    GMESSAGE=mess(185,121,1) - num$([L]WK+1)
    OK=0 : Break
  Endif
Next [L]WK
If !OK : Return : Endif
#-- verif que le bordereau n'est pas deja affecté - sur un autre relevé
Read [F:RBD]RBD1=[F:FRM]FRMNUM
If !fstat & [M:RBK0]RBKNUM<>[F:RBD]RBKNUM
  ## Bordereau déjà imputé sur releve
  GMESSAGE=mess(186,121,1) - [F:RBD]RBKNUM
  OK=0 : Return
Endif

#-- on peut affecter le borderau
[V]GL_FRMNUM=[F:FRM]FRMNUM

$PICKE_FRM_RAZ
[L]SAV_NOLIGN=nolign
nolign=[V]GCURR_NOLIGN
[L]WI=[V]GCURR_NOLIGN-1
## -- mise a jour des cumuls CA avant resultat du picking
Case [M:RBK1]SNS([L]WI)
  When 1
    [M:RBK0]AMTCDT-= [M:RBK1]AMTCUR([L]WI)
  When 2
    [M:RBK0]AMTDEB-= [M:RBK1]AMTCUR([L]WI)
  When Default
Endcase

Call AM_FRMNUM([V]GL_FRMNUM)
[M:RBK1]FRMNUM([L]WI)=[V]GL_FRMNUM : Affzo [M:RBK1]FRMNUM([L]WI)
Call APRES_NBDET    :#-- pour cumuls et statuts
nolign=[L]SAV_NOLIGN
Return

#**
#* création de la ligne de relevé en cours et non totalement saisie
#* avant picking ou autre (sinon infos sont perdus)
#*!
$STORE_CURR_LINE
#--------------

If [V]GCURR_NOLIGN<1 or [V]GL_FCY="" : Return : Endif
[L]WK=[V]GCURR_NOLIGN-1

If [V]GL_INSERT ## on est en mode insertion et on passe sur autre liste gauche ans avoir fini la saisie de la ligne
  Insa [L]WK,1, [M:RBK1]NBDET [M:RBK1]NBDET
Endif

If [M:RBK1]WINDEX([L]WK)=0 : [M:RBK1]NBDET+=1 : Endif :## new forced line

[M:RBK1]FCYLIN([L]WK)=[V]GL_FCY
[M:RBK1]BPRNUM([L]WK)=[V]GL_BPRPAY
[M:RBK1]FRMNUM([L]WK)=[V]GL_FRMNUM
[M:RBK1]ACCTMP([L]WK)=[V]GL_ACCTMP
If [V]GL_ACCDAT <> [0/0/0]
  [M:RBK1]ACCDAT([L]WK)=[V]GL_ACCDAT
Else
  [M:RBK1]ACCDAT([L]WK)=date$
Endif
If [V]GL_VALDAT <> [0/0/0]
  [M:RBK1]VALDAT([L]WK)=[V]GL_VALDAT
Else
  [M:RBK1]VALDAT([L]WK)=[M:RBK1]ACCDAT([L]WK)
Endif

If [V]GL_AMTCUR<>0 : [M:RBK1]AMTCUR([L]WK)=[V]GL_AMTCUR : Endif

If [M:RBK1]WINDEX([L]WK)=0
  [M:RBK1]STATUT([L]WK)=1
  [M:RBK1]VALFLG([L]WK)=1
  [M:RBK1]ACCBAN([L]WK)=[M:RBK0]BANACC
  GLAST_WINDEX+=1
  [M:RBK1]WINDEX([L]WK)=GLAST_WINDEX
Endif

If [M:RBK1]BPRNUM([L]WK)<>"" and [M:RBK1]BPRNAM([L]WK)=""
  Call LEC_BPR([V]GL_BPRPAY) From CPTLEC
  If !fstat : [M:RBK1]BPRNAM([L]WK)=[F:BPR]BPRNAM : Else [M:RBK1]BPRNAM([L]WK)="" : Endif
  [M:RBK1]BPRNUM([L]WK)=[V]GL_BPRPAY
Endif

If [V]GL_SNS<>0
  ## cas du passage d'un sens indeterminé à dépense/recette et qu'on n'a pas été jusqu'au bout de la
  ## saisie de la ligne de relevé --> faut réajuster les CA
  If [V]GL_SNS<>3 & [M:RBK1]SNS([L]WK)=3 & [M:RBK1]FRMNUM([L]WK)=""
    Case [V]GL_SNS
      When 1
        [M:RBK0]AMTCDT+= [M:RBK1]AMTCUR([L]WK)
      When 2
        [M:RBK0]AMTDEB+= [M:RBK1]AMTCUR([L]WK)
      When Default
    Endcase
    Gosub CALC_WNEWAMT  :#-- calc new solde
  Endif
  [M:RBK1]SNS([L]WK)=[V]GL_SNS
Endif

If [V]GL_PAYTYP<>""
  [M:RBK1]PAYTYP([L]WK) = [V]GL_PAYTYP
Else
  Call PARAM([M:RBK1]FCYLIN([L]WK),"BELTRSDEF",[M:RBK1]PAYTYP([L]WK)) From ADOVAL
  Call LEC_TPY_LEG(GCURLEG,[M:RBK1]PAYTYP([L]WK)) From CPTLEC
  If [M:RBK1]SNS([L]WK)= 0 : [M:RBK1]SNS([L]WK) = [F:TPY]SNS : Endif
Endif

If [V]GL_INSERT
    Affzo [M:RBK1]10
    Gosub SET_LINE_STYLE_INSA
Else
  Affzo [M:RBK1]FCYLIN([L]WK),FRMNUM([L]WK),BPRNUM([L]WK),BPRNAM([L]WK),ACCDAT([L]WK),VALDAT([L]WK),ACCBAN([L]WK),
&       SNS([L]WK),AMTCUR([L]WK),PAYTYP([L]WK),ACCTMP([L]WK),VALFLG([L]WK),STATUT([L]WK)
Endif
Affzo [M:RBK1]WINDEX([L]WK) :#//
[V]GL_INSERT=0
Return

######################################################################################
DEPICK
#------------------------------------------------------------------------------------#
Case currbox
  When GBOX_RB1 : Gosub DEPICK_DUD
  When GBOX_RB2 : Gosub DEPICK_FRM
Endcase
Return

#----------
$DEPICK_DUD
#----------
[L]W_AFF_DEPICK = 2
[L]SAV_NOLIGN=nolign
For [L]WI=[M:RBK1]NBDUD-1 To 0 Step -1
  If [M:RBK1]DUDNUM([L]WI)=[F:DUD]ACCNUM & [M:RBK1]DUDLIG([L]WI)=[F:DUD]DUDLIG
    K=[L]WI+1
    If K   :# Echéance en ligne K
      nolign=K : status=65
      Call AVANT_NBDUD
      Dela K-1 [M:RBK1]NBDUD
      [M:RBK1]NBDUD-=1 : OK=1
    Endif
  Endif
Next [L]WI
nolign=[L]SAV_NOLIGN
Return

#----------
$DEPICK_FRM
#----------
[L]W_AFF_DEPICK = 0
[V]GL_FRMNUM=""
Gosub PICKE_FRM_RAZ
Return


######################################################################################
$AVANT_CHOI
#------------------------------------------------------------------------------------#
#-- positionnement sut la bonne ligne apres pick/depick
If GL_POST_PICK=2
  Case currbox
    When GBOX_RB1
      [L]WI=0
      If [M:RBK1]NBDUD>0
        SUIZON="DENCOD("+num$(max(0,[M:RBK1]NBDUD-1))+")"
      Else
        SUIZON="DENCOD(0)"
      Endif
    When GBOX_RB2
      SUIZON="NBDET(" + num$([V]GCURR_NOLIGN-1)+ ")"
    When Default
      SUIZON="NBDET(0)"
  Endcase
Endif
Return

######################################################################################
$APRES_CHOI
#------------------------------------------------------------------------------------#
#-- gestion des cas ou n'on pas encore fini de saisir la ligne en cours et qu'on va sur une
#   liste gauche ou qu'on active la slection rapide sur liste gauche ...
Case REPONSE
  When GSTASRA
    Gosub STORE_CURR_LINE  :#-- save eventuel de la ligne non totalement saisie
    GL_POST_PICK =2       :#-- pour eviter rafraichissement liste gauche
  When GSTATIR
    If currbox<>BOXCURR     :#-- changement d'écran
      Gosub STORE_CURR_LINE  :#-- save eventuel de la ligne non totalement saisie
      If BOXCURR = GBOX_RB1 :#-- titoir en cours=échénaces
        If [V]GCURR_NOLIGN > 0 : Call STORE_NBDUD(W_STAT) : Endif
      Endif
    Endif
  When Default
Endcase
Return

######################################################################################
$FIN_ACTION
#------------------------------------------------------------------------------------#
Case REPONSE
  When GSTARAF, GSTAPRG, GSTASVG     :#-- Rafraichissement des listes gauches
    If find(currbox, GBOX_RB1, GBOX_RB2)
      GL_POST_PICK=2  :#-- pour eviter double refresh
      Gosub AVANT_CHOI
      Gosub REFRESH_PICK
    Endif
  When Default
Endcase
Return

#------------
$REFRESH_PICK
#------------
Case currbox
  When GBOX_RB1 : Gosub REFRESH_PICK_DUD
  When GBOX_RB2 : Gosub REFRESH_PICK_FRM
Endcase

#----------------
$REFRESH_PICK_DUD
#----------------
For [L]WI=0 To [M:RBK1]NBDUD-1
  If [M:RBK1]DUDNUM(WI)<>0 & [M:RBK1]DUDLIG(WI)<>0
    Read [DUD]DUD1 = [M:RBK1]DUDNUM(WI);[M:RBK1]DUDLIG(WI)
    If !fstat : Gosub REPICK From GOBJSUB
    Else :      Gosub DEPICK From GOBJSUB
    Endif
  Endif
Next WI
Return

#----------------
$REFRESH_PICK_FRM
#----------------
If  [V]GCURR_NOLIGN>0
  If [V]GL_FLG_AM=0 : [V]GL_FRMNUM=[M:RBK1]FRMNUM([V]GCURR_NOLIGN-1) : Endif
  If [V]GL_FRMNUM <>""
    Read [F:FRM]FRM0=1;[V]GL_FRMNUM
    If !fstat : Gosub REPICK From GOBJSUB
    Else :      Gosub DEPICK From GOBJSUB
    Endif
  Endif
Endif
Return

######################################################################################
######################################################################################
## Gestion écran RBKBEL0
######################################################################################
#-- RBKNUM
Subprog C_RBKNUM(VALEUR)
Variable Char    VALEUR()
Look [F:RBH]RBH0=VALEUR
If fstat
 ## Rélevé inexistant
 GMESSAGE = mess(191,117,1)
 mkstat = 2 : End
Endif
End

#--BAN
Subprog AS_BAN(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Call BANDEF(VALEUR) From SUBCHK
 If VALEUR<>""
  Call LECTURE("BAN",VALEUR,"") From CONTOBJ
  [M:RBK0]CPY = [F:BAN]CPY
  [M:RBK0]FCY = [F:BAN]FCY
  [M:RBK0]CUR = [F:BAN]CUR
  Affzo [M:RBK0]CPY,CUR,FCY
 Endif
Endif
End

Subprog AP_BAN(VALEUR)
Variable Char    VALEUR()
Call GET_BANACC(VALEUR,[M:RBK0]BANACC) :##-- set bank account
[M:RBK0]CPY = [F:BAN]CPY
[M:RBK0]FCY = [F:BAN]FCY
[M:RBK0]CUR = [F:BAN]CUR
Affzo [M:RBK0]CPY,CUR,FCY
If find(GREP,'C','D')
  Actzo [M:RBK0]OLDDAT,OLDAMT,OLDSNS
Endif
End

Subprog AP_FCY(VALEUR)
Variable Char    VALEUR()
[M:RBK0]FCY = VALEUR
Gosub SET_GLOBAL
If find(GREP,'C','D')
  Actzo [M:RBK0]OLDDAT,OLDAMT,OLDSNS
Endif
End

#-- solde precedent
Subprog AM_OLDAMT(VALEUR)
Variable Decimal VALEUR
If  [M:RBK0]OLDSNS = 1 :#--debit
  [M:RBK0]WNEWAMT+=(VALEUR-[M:RBK0]OLDAMT)
Else
  [M:RBK0]WNEWAMT-=(VALEUR-[M:RBK0]OLDAMT)
Endif
Affzo [M:RBK0]WNEWAMT :#-- solde calcule
End

Subprog AM_OLDSNS(VALEUR)
Variable Integer VALEUR
If  [M:RBK0]OLDSNS = 1 :#--debit
  [M:RBK0]WNEWAMT-=([M:RBK0]OLDAMT*2)
Else
  [M:RBK0]WNEWAMT+=([M:RBK0]OLDAMT*2)
Endif
Affzo [M:RBK0]WNEWAMT :#-- solde calcule
End

Subprog AV_OLDDAT(VALEUR)
Variable Date    VALEUR
Filter [F:RBH2] Where BAN=[M:RBK0]BAN & FCY=[M:RBK0]FCY
# Issue 121174: Belgium Bank statement (CODA) - Control statement Balance
Read [F:RBH2]RBH1 = [F:RBH]ACCNUM
Read [F:RBH2]RBH1 Next
If fstat = 4 Then
    Read [F:RBH2]RBH1 Last
Endif
# End issue 121174
If !find(GREP,'C','D')
  If !fstat & [F:RBH2]ACCNUM >[F:RBH]ACCNUM
    Diszo [M:RBK0]NEWDAT,NEWAMT,NEWSNS
    [M:RBK0]WLASTFLG=1
    [M:RBK0]WLASTOLDAMT=[F:RBH2]OLDAMT  :#-- last oldamt must be equal to newamt
  Else
    Actzo [M:RBK0]NEWDAT,NEWAMT,NEWSNS
    [M:RBK0]WLASTFLG=2  :#-- flag last rbk
  Endif
  If rowcount([F:RBH2])>1 : Diszo [M:RBK0]OLDDAT,OLDAMT,OLDSNS : Endif
Else # (GREP='C'/'D'
  [M:RBK0]WLASTFLG=2  :#-- flag last rbk
  If fstat
    Actzo [M:RBK0]OLDDAT,OLDAMT,OLDSNS
  Else
    Diszo [M:RBK0]OLDDAT,OLDAMT,OLDSNS
    VALEUR=[F:RBH2]NEWDAT
    [M:RBK0]OLDAMT=[F:RBH2]NEWAMT
    [M:RBK0]OLDSNS=[F:RBH2]NEWSNS
    [M:RBK0]WLASTOLDAMT=[F:RBH2]OLDAMT
  Endif
  Affzo [M:RBK0]OLDAMT,OLDSNS
Endif

Filter [F:RBH2]
End

#-- nouveau solde
Subprog C_NEWDAT(VALEUR)
Variable Date    VALEUR
If VALEUR < [M:RBK0]OLDDAT
  # La date de nouveau solde doit être postérieure à la date ancien solde
  GMESSAGE=mess(181,121,1)
  mkstat=2
Endif
End

######################################################################################
######################################################################################
## Etiquette slection de l'écran RBKBEL1
######################################################################################
$SEL_TABLE
Case COUZON
 When "FRMNUM"    :#-- no bordereau
  GBIDC1=""
  OBJET="FRM"
  SUPP="1"
  CRITERE  ="STA=8 & BAN='"+ [M:RBK0]BAN + "'" :#-- STA=8 : sur compte intermédiaire
  CRITERE -= "& CPY='" +[M:RBK0]CPY+"' & FRMFCY='"+[M:RBK1]FCYLIN([V]GCURR_NOLIGN-1)+"'"
 When "VCRNUM"
  Gosub SEL_VCRNUM :#--Numéro pièce
 When "PAYTYP"     :#--Type de règlement
  OBJET = "TPY"
  CRITERE="STA3=1 & STA5=1 & STA7=1 & STA8=1 & STA9=2"
Endcase
Return

#----------
$VERF_TABLE
#----------
#Case COUZON
#When "VCRNUM" : Gosub VERF_VCRNUM :#--Numéro pièce
#Endcase
Return

$SEL_VCRNUM
If [M:RBK1]VCRTYP(nolign-1)<>""
  Local File GACCDUDATE [DUD]
  Filter [DUD] Where CPY=[M:RBK0]CPY & TYP=[M:RBK1]VCRTYP(nolign-1) & FLGCLE=1 & BPRFCT=''
&                    & DUDSTA=2 & !find(TYP,'*SO','*PO') & FLGPAZ>3
  Local Char SITE(GLONFCY), TIERS(GLONBPR), W_OPT(1)
  ## SITE =[M:RBK1]FCYLIN([V]GCURR_NOLIGN-1)
  TIERS=[M:RBK1]BPRNUM([V]GCURR_NOLIGN-1)
  SITE =""
  Call PARAM([M:RBK1]FCYLIN([V]GCURR_NOLIGN-1),"SEVFCYENT", [L]W_OPT) From ADOVAL    :## inter-sites
  If [L]W_OPT<>"2" : SITE =[M:RBK1]FCYLIN([V]GCURR_NOLIGN-1) : Endif
  Gosub SEL_DUD From SELDUD1
Endif
Return

#-----------
$VERF_VCRNUM
#-----------
If [F:DUD]NUM<>""
  Read [DUD]DUD1 = [F:DUD]ACCNUM;[F:DUD]DUDLIG
  If !fstat
    [M:RBK1]DUDNUM(nolign-1) = [F:DUD]ACCNUM
    [M:RBK1]DUDLIG(nolign-1) = [F:DUD]DUDLIG
    [M:RBK0]OD1=[M:RBK1]DUDNUM(nolign-1)
    [M:RBK0]OD2=[M:RBK1]DUDLIG(nolign-1)
  Endif
Endif
Return

#------
$SELECH
#------
Gosub SELECH From SUBRBB2
Return

######################################################################################
######################################################################################
## Gestion écran RBKBEL1  - 1ier tableau
######################################################################################
$SETNOL
Local Integer NOL
NOL=nolign-1
Return

#--NBDET --
Subprog IB_NBDET
Gosub SETNOL
If [M:RBK1]STATUT(NOL)<>2  : Raz GBOUT2 : Endif  :#-- maj colonne
If [M:RBK1]FRMNUM(NOL)=""  : Raz GBOUT3 : Endif  :#-- visu bordereau remise
If [M:RBK1]STATUT(NOL)<>2 or GREP <> "" : Raz GBOUT4 : Endif  :#-- validation
If [M:RBK1]PYHNUM(NOL)=""  : Raz GBOUT5 : Endif  :#-- visu reglement
End

#-- bouton maj colonne
Subprog B2_NBDET
Call B2_VALFLG([M:RBK1]VALFLG(nolign-1))
End

#-- visu bordereau remise
Subprog B3_NBDET
Local Char WFRMNUM(GLONVCR)
[L]WFRMNUM=[M:RBK1]FRMNUM(nolign-1)
Call B3_FRMNUM([L]WFRMNUM)
End

#-- Bouton validation : action apres execution de la validation - bouton B4 -
$BB4_NBDET
Local Integer WNOL
[L]WNOL=[V]GCURR_NOLIGN-1
Read [F:RBD]RBD0=[M:RBK0]RBKNUM;[M:RBK1]RBKLIN([L]WNOL)
If fstat
  Call RSTA("RBD",[M:RBK0]RBKNUM-[M:RBK1]RBKLIN([L]WNOL)) From GLOCK
Else
  [M:RBK1]VALFLG([L]WNOL)=[F:RBD]VALFLG
  [M:RBK1]STATUT([L]WNOL)=[F:RBD]STATUT
  [M:RBK1]PYHNUM([L]WNOL)=[F:RBD]PYHNUM
  Affzo [M:RBK1]VALFLG([L]WNOL),PYHNUM([L]WNOL),STATUT([L]WNOL)
  ## pour eviter de rafraichir tout le relevé (RELIT)
  If [M:RBK1]STATUT([L]WNOL)=3    :##-- la ligne est validée
    Disable GSTAANU               :##-- grisage bouton supprimer
    If find(2,[M:RBK1]VALFLG(0..[M:RBK1]NBDET-1))<1
      Disable GSTABOU+1           :##-- grisage bouton validation si plus rien a valider
    Endif
    mkstat=99 : zonsui="RBKNUM"
  Endif
Endif
Return

#-- actions NBDET
Subprog AVANT_NBDET
Gosub SETNOL
If status=73 : Gosub SET_LINE_STYLE : Endif :##-- insert line

#-- cumul mt
Case [M:RBK1]SNS(NOL)
  When 1
    [M:RBK0]AMTCDT-= [M:RBK1]AMTCUR(NOL)
  When 2
    [M:RBK0]AMTDEB-= [M:RBK1]AMTCUR(NOL)
  When Default
Endcase
Gosub SAVE_LINE_VALUE :## sauvegarde des elements modifiables de la ligne courante du releve
End

#**
#* init style d'une ligne de releve : raz style ligne prec, raz bloc nouveau detail
#*!
$SET_LINE_STYLE
If status=73
  Chgstl [M:RBK1]NBDET(GCURR_NOLIGN) With "" :#-- en mode insert c'est la ligne suivante
Else
  If GCURR_NOLIGN>0 : Chgstl [M:RBK1]NBDET(GCURR_NOLIGN-1) With "" : Endif
Endif
$SET_LINE_STYLE_INSA
GCURR_NOLIGN = nolign
Chgstl [M:RBK1]NBDET(nolign-1) With "AMKACT"  :#??? style ligne en cours a valider
Chgtbk [M:RBK1]20 With func AFNC.MES(mess(182,121,1),num$(GCURR_NOLIGN))
Effzo [M:RBK1]20
[M:RBK1]NBDUD=0
#Affzo [M:RBK1]20
Return
#----

Subprog APRES_NBDET
Local Char WZONSUI(30)
Gosub SETNOL
Raz WZONSUI
#-- cumul mt
Case [M:RBK1]SNS(NOL)
  When 1
    [M:RBK0]AMTCDT+= [M:RBK1]AMTCUR(NOL)
  When 2
    [M:RBK0]AMTDEB+= [M:RBK1]AMTCUR(NOL)
  When Default
Endcase

Gosub CALC_WNEWAMT  :#-- calc new solde

If [M:RBK1]FRMNUM(NOL)="" & [M:RBK1]AMTCUR(NOL)<>0
  If GCURR_NOLIGN<>0 & [M:RBK1]WINDEX(NOL)=0  :#--new line
    Effzo [M:RBK1]20
    GLAST_WINDEX+=1
    [M:RBK1]WINDEX(NOL)=GLAST_WINDEX
    Affzo [M:RBK1]WINDEX(NOL) :#//
    WZONSUI="DENCOD(0)"  :#???--> ne se positionne pas en saisie
 Endif
Endif

#-- calcul du statut de la ligne
If [M:RBK1]STATUT(NOL)<3
  If [M:RBK1]FRMNUM(NOL) <> ""
      [M:RBK1]STATUT(NOL) = 2
  Else
    If ([M:RBK1]BPRNUM(NOL)="" and [M:RBK1]ACCTMP(NOL)="")
&   or [M:RBK1]AMTCUR(NOL)=0 or [M:RBK1]SNS(NOL)=3 or [M:RBK1]PAYTYP(NOL)=""
        [M:RBK1]STATUT(NOL)=1
    Else
    # Issue 121291: Belgium Bank statement (CODA) - Status issue
#        If [M:RBK1]AMTCUR(NOL)=sum([M:RBK1]AMTLIN(0..[M:RBK1]NBDUD-1))
        Gosub WMT_DUD
        If [M:RBK1]AMTCUR([L]NOL) = abs([L]WMT_DUD) Then  # The amounts are always displayed positive
          [M:RBK1]STATUT(NOL)=2
        Else
          [M:RBK1]STATUT(NOL)=1
        Endif
    # End issue 121291
    Endif
  Endif
  If [M:RBK1]STATUT(NOL)=1
     [M:RBK1]VALFLG(NOL)=1
  Endif
  Affzo [M:RBK1]VALFLG(NOL),STATUT(NOL)
Endif
If WZONSUI<>"" : zonsui=WZONSUI : Endif
End

# Issue 121291: Belgium Bank statement (CODA) - Status issue
$WMT_DUD
    # F&R - Take into account ACCTYP of the destination in order to exclude ACCTYP=3 of the detail sum
    # Detail calculation [DUD]
    Local Integer SIGN, I
    Local Decimal WMT_DUD
    For [L]I = 0 To [M:RBK1]NBDUD - 1
        If [M:RBK1]DENCOD([L]I) = "" Then : Break : Endif
        Call LEC_CDA_LEG([V]GCURLEG, [M:RBK1]DENCOD([L]I)) From CPTLEC
        If [F:CDA]ACCTYP <> 3 Then # the bank amount
            # Transaction sign and payment attribute sign differ
            [L]SIGN = 1
            If ([F:CDA]ACCSNS = 2 and [M:RBK1]SNS([L]I) = 2) or ([F:CDA]ACCSNS = 3 and [M:RBK1]SNS([L]I) = 1) Then
                [L]SIGN = -1
            Else
                [L]SIGN = 1
            Endif
            If [M:RBK1]DUDNUM([L]I) <> 0 Then
                If [F:DUD]ACCNUM <> [M:RBK1]DUDNUM([L]I) or [F:DUD]DUDLIG <> [M:RBK1]DUDLIG([L]I) Then
                    Read [F:DUD]DUD1 = [M:RBK1]DUDNUM([L]I);[M:RBK1]DUDLIG([L]I)
                    If fstat = 0 Then
                        # The amounts are always displayed positive
                        Case [F:DUD]BPRTYP
                            When 1 : [L]SIGN = [F:DUD]SNS * [L]SIGN        # Customer
                            When 2 : [L]SIGN = [F:DUD]SNS * (-1) * [L]SIGN # Supplier
                        Endcase
                    Endif
                Endif
            Endif
            [L]WMT_DUD += ([L]SIGN * [M:RBK1]AMTLIN([L]I))
        Endif
    Next [L]I
Return
# End issue 121291

Subprog AS_NBDET
Local Integer WPREV_CURR, SAV_NOLIGN, SAV_RBKLIN
Gosub SETNOL
If GL_POST_PICK=2 :#-- repositionnement apres action de picking
   GL_POST_PICK=0
   End
Endif

If [M:RBK1]STATUT(NOL)=3 : mkstat = 2 : Endif
SAV_NOLIGN=nolign
WPREV_CURR= GCURR_NOLIGN
#-- set current index detail for indexing sub-details
Gosub SET_LINE_STYLE  :#-- raz bloc detail & style

nolign = 0
For [F:RBW]RBW0 Where  RBKNUM=[V]GCURR_RBKNUM & RBKLIN=[M:RBK1]WINDEX([V]GCURR_NOLIGN-1)
  nolign+=1
  If nolign<=[M:RBK1]NBDET : [L]SAV_RBKLIN=[M:RBK1]RBKLIN(nolign-1) : Endif :##-- save before scratching by transclass
  [M:RBK1] = [F:RBW]
  If nolign<=[M:RBK1]NBDET : [M:RBK1]RBKLIN(nolign-1)=[L]SAV_RBKLIN : Endif : ## restore after scratching by transclass
Next
[M:RBK1]NBDUD = nolign
Affzo [M:RBK1]RBKLIN(GCURR_NOLIGN-1) :##//
Affzo [M:RBK1]20

nolign=SAV_NOLIGN

####
If WPREV_CURR<>nolign : Gosub REFRESH_LISGAU : Endif :## --> rafraichir listes gauche
####
If GREP="C"
  If [M:RBK1]NBDET=0 : Actzo  [M:RBK0]BAN,FCY : Affzo  [M:RBK0]BAN,FCY : Endif
Endif
[V]GL_FCY=""  :## pour eviter creation ligne a blanc
End


Subprog C_NBDET
Gosub SETNOL
If status=73 or (status=20 & adxgtb & [V]GL_INSERT=1) :#-- insert line
  [V]GL_INSERT=1
Endif

If status = 65  :#-- suppression possible uniquement si ligne non validée
  If [M:RBK1]STATUT(NOL)=3
    ## Suppression impossible : la ligne a eté validée
    GMESSAGE=mess(184,121,1) : mkstat=2 : End
  Endif
Endif

If GREP="C"
  If [M:RBK1]NBDET=0 : Actzo  [M:RBK0]BAN,FCY : Affzo  [M:RBK0]BAN,FCY
  Elsif NOL=0 : Grizo [M:RBK0]BAN,FCY : Affzo  [M:RBK0]BAN,FCY
  Endif
Endif
End

#-- AS_VALFLG --
Subprog AS_VALFLG(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If [M:RBK1]STATUT(NOL)<>2 : mkstat = 1 : Endif
End

Subprog B2_VALFLG(VALEUR)
Variable Integer VALEUR
Local    Integer  I, WMOD
Gosub SETNOL
[L]WMOD=0
# bouton Maj_colonne
[M:RBK1]VALFLG(NOL)=VALEUR
For I=NOL+1 To [M:RBK1]NBDET-1
  If [M:RBK1]STATUT(I)=2  :#--uniquement si statut a valider
    [M:RBK1]VALFLG(I)=VALEUR
    WMOD=1
  Endif
Next I
Affzo [M:RBK1]VALFLG
If [L]WMOD>0 & GREP="" : mkstat=4 : Endif
End

#--FCYLIN --
Subprog AS_FCYLIN(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If [M:RBK1]STATUT(NOL)=3 : mkstat = 2 : End : Endif
## on autorise la modification du site pour reglements multi-sites
## Gosub VERIF_BRD_DUD :#-- verif qu'aucun bordereau/echeance n'est affectée
##If mkstat=2: End : Endif
If [M:RBK1]FRMNUM(NOL)<>"" : mkstat=2 : End : Endif
If VALEUR=""  : VALEUR = [M:RBK0]FCY : Endif
End

#-- verif qu'aucun bordereau/echeance n'est affectée
$VERIF_BRD_DUD
Local Integer W_I
If [M:RBK1]FRMNUM(NOL)<>""
  mkstat=2
Else
  For [L]W_I=0 To [M:RBK1]NBDUD-1
      If [M:RBK1]VCRNUM([L]W_I)<>"" : mkstat=2 : Break : Endif
  Next
Endif
Return

#---FRMNUM --
Subprog B3_FRMNUM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
GBIDC1=""
Local Char VCR_NUM(GLONVCR)
VCR_NUM=VALEUR
Call OBJET_CHAR(VCR_NUM,"FRM","1") From GOBJET
Call LECTURE("FRM",VCR_NUM,"1") From CONTOBJ
If [F:FRM]BAN=[M:RBK0]BAN and [F:FRM]FRMFCY=[M:RBK1]FCYLIN(NOL)
  VALEUR=VCR_NUM
Endif
End

Subprog AS_FRMNUM(VALEUR)
Variable Char    VALEUR()
If [V]G_BELRBK <> 2 : mkstat=2 : End : Endif
Gosub SETNOL
If [M:RBK1]BPRNUM(NOL)<>"" | [M:RBK1]ACCTMP(NOL)<>"" | [M:RBK1]STATUT(NOL)=3 : mkstat=2 : Endif
End

Subprog C_FRMNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" : End : Endif
Call UNICITE(VALEUR,[M]FRMNUM) From OBJDIV
If mkstat=2 : End : Endif
#-- verif que le bordereau n'est pas deja affecté - sur un autre relevé
Read [F:RBD]RBD1=VALEUR
If !fstat & [M:RBK0]RBKNUM<>[F:RBD]RBKNUM
  ## Bordereau déjà imputé sur relevé
  GMESSAGE=mess(186,121,1) - [F:RBD]RBKNUM
  mkstat=2 : End
Endif
#-- verifs sur borderau
Read [F:FRM]FRM0=1;VALEUR
If fstat
  ## Bordereau non trouvé
  GMESSAGE=mess(193,121,1) : mkstat=2 : End
Endif
If [F:FRM]STA>8
  ## Bordereau # déjà validé
  GMESSAGE=func AFNC.MES(mess(194,121,1),[F:RBD]FRMNUM)
  mkstat=2 : End
Endif
If [F:FRM]STA<>8
  ## La comptabilisation intermédiaire n'a pas été réalisée sur le bordereau
  GMESSAGE=mess(188,121,1)
  mkstat=2 : End
Endif
If [F:FRM]FRMFCY<> [M:RBK1]FCYLIN(nolign-1)
  ## Site du bordereau incompatible
  GMESSAGE=mess(189,121,1)
  mkstat=2 : End
Endif
End

Subprog AM_FRMNUM(VALEUR)
Variable Char    VALEUR()
Local Integer I, SAV_NOLIGN, SIGN, SAV_RBKLIN
Local Decimal MONTANT

Gosub SETNOL
SAV_NOLIGN=nolign
Effzo [M:RBK1]20
Raz [M:RBK1]NBDUD
Raz MONTANT
If  [M:RBK1]WINDEX(NOL) = 0
  GLAST_WINDEX+=1
  [M:RBK1]WINDEX(NOL)=GLAST_WINDEX
   Affzo [M:RBK1]WINDEX(NOL) :#//
Endif

GOK=1
Trbegin [F:RBW]
Delete [F:RBW] Where  RBKNUM=[V]GCURR_RBKNUM & RBKLIN=[M:RBK1]WINDEX(NOL)
nolign=0
If VALEUR <> ""
  #-- chargement infos issues du bordereau et detail des echeances
  Call LEC_TPY_LEG(GCURLEG,[F:FRM]PAYTYP) From CPTLEC
  For [F:PYH]PYH0 Where [F:PYH]FRMNUM=VALEUR
    If [F:TPY]SNS<3
     If [F:PYH]SNS=[F:TPY]SNS : SIGN=1 : Else : SIGN=-1 : Endif
    Elsif [F:PYH]SNS=1 : SIGN=-1 :# Dépense
    Else               : SIGN=1  :# Recette
    Endif
    MONTANT+=[F:PYH]AMTCUR*SIGN
    ## a la demande des PBA on ne charge plus le detail des reglement, mais uniquement l'entete
    ##For [F:PYD]PYD0 Where NUM=[F:PYH]NUM
      nolign+=1
      Raz [F:RBW]
      ##[F:RBW] = [F:PYD]
      ##[F:RBW]ACC = [F:PYD]ACC(0)
      [F:RBW]RBKNUM=[V]GCURR_RBKNUM
      [F:RBW]RBKLIN= [M:RBK1]WINDEX(NOL)
      [F:RBW]LIN=nolign
      [F:RBW]REFINT= [F:PYH]NUM
      [F:RBW]AMTLIN= [F:PYH]AMTCUR ##??AMTBAN
      Write [F:RBW]
      If fstat
       GOK=0 : Call FSTA("RBW") From GLOCK : Break 2
      Endif
      If nolign<=[M:RBK1]NBDET : [L]SAV_RBKLIN=[M:RBK1]RBKLIN(nolign-1) : Endif :##-- save before scratching by transclass
      [M:RBK1] = [F:RBW]
      If nolign<=[M:RBK1]NBDET : [M:RBK1]RBKLIN(nolign-1)=[L]SAV_RBKLIN : Endif : ## restore after scratching by transclass
    ##Next
  Next
  [M:RBK1]AMTCUR(NOL) = MONTANT
  [M:RBK1]SNS(NOL)    = [F:TPY]SNS
  [M:RBK1]PAYTYP(NOL) = [F:TPY]PAYTYP
  [V]GL_SNS           = [M:RBK1]SNS(NOL)
  [V]GL_AMTCUR        = [M:RBK1]AMTCUR(NOL)
  [V]GL_PAYTYP        = [M:RBK1]PAYTYP(NOL)
  Affzo [M:RBK1]RBKLIN(GCURR_NOLIGN-1)  :##//
Else
  Raz [M:RBK1]AMTCUR(NOL),PAYTYP  :#--,SNS
  Raz [V]GL_AMTCUR,[V]GL_PAYTYP
Endif
If GOK<1
  Rollback : mkstat=2
Else
  Commit
Endif
[M:RBK1]NBDUD = nolign
Affzo [M:RBK1]20
nolign=SAV_NOLIGN
Affzo [M:RBK1]SNS(NOL),AMTCUR(NOL),PAYTYP(NOL)
End

#--BPRNUM --
Subprog AS_BPRNUM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If [M:RBK1]STATUT(NOL)=3 : mkstat = 2 : End : Endif
Gosub VERIF_BRD_DUD :#-- verif qu'aucun bordereau/echeance n'est affectée
If mkstat=2: End : Endif
If [M:RBK1]ACCTMP(NOL)<>"" : mkstat=2 : Endif
End

Subprog AM_BPRNUM(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If VALEUR=""
  [M:RBK1]BPRNAM(NOL)=""
Else
  Call LEC_BPR(VALEUR) From CPTLEC
  If !fstat
    [M:RBK1]BPRNAM(NOL)=[F:BPR]BPRNAM
  Else
    [M:RBK1]BPRNAM(NOL)=""
  Endif
Endif
Affzo [M:RBK1]BPRNAM(NOL)
End

#-- ACCDAT
Subprog AS_ACCDAT(VALEUR)
Variable Date    VALEUR
If [M:RBK1]STATUT(nolign-1)=3 : mkstat=2 : Endif
End

#-- VALDAT
Subprog AS_VALDAT(VALEUR)
Variable Date    VALEUR
Gosub SETNOL
If [M:RBK1]STATUT(NOL)=3 : mkstat = 2 : End : Endif
If VALEUR=[0/0/0] : VALEUR=[M:RBK1]ACCDAT(NOL) : Endif
End
Subprog AM_VALDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : VALEUR=[M:RBK1]ACCDAT(nolign-1) : Endif
End

#-- SNS - Sens releve
Subprog AS_SNS(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If [M:RBK1]FRMNUM(NOL)<>"" | [M:RBK1]STATUT(NOL)=3 : mkstat=2 : Endif
End

Subprog AM_SNS(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If [M:RBK1]SNS(NOL)<> 3 : End : Endif
Local Integer I, WUPDATE
Local Char WDENCOD(GLONCDA)
If VALEUR=1 : WDENCOD=[V]G_DENSPG : Else : WDENCOD=[V]G_DENTAK : Endif
## pour reaffection du sens sur les lignes detail si indeterminé
WUPDATE=0
For I=0 To [M:RBK1]NBDUD-1
 If [M:RBK1]DENCOD(I)=""
  WUPDATE = 2
  [M:RBK1]DENCOD(I)=WDENCOD
  Affzo [M:RBK1]DENCOD(I)
 Endif
Next I
If WUPDATE=2
  Trbegin [F:RBW]
  Update [F:RBW] Where RBKNUM=[V]GCURR_RBKNUM & RBKLIN=[M:RBK1]WINDEX(GCURR_NOLIGN-1) & DENCOD=""
&                With DENCOD=WDENCOD
  Commit
Endif
[V]GL_SNS=VALEUR
End

#-- AMTCUR
Subprog AS_AMTCUR(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
If [M:RBK1]FRMNUM(NOL)<>""  | [M:RBK1]STATUT(NOL)=3 : mkstat=2 : Endif
End

#-- ACCBAN
Subprog AV_ACCBAN(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : VALEUR=[M:RBK0]BANACC : Endif
End

#-- ACCTMP
Subprog AS_ACCTMP(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If [M:RBK1]STATUT(NOL)=3 : mkstat = 2 : End : Endif
Gosub VERIF_BRD_DUD :#-- verif qu'aucun bordereau/echeance n'est affectée
If mkstat=2: End : Endif
If [M:RBK1]BPRNUM(NOL)<>"" : mkstat=2 : Endif
End

#-- PAYTYP
Subprog AS_PAYTYP(VALEUR)
Variable Char    VALEUR()
Local Char W_PAYTYP(GLONTPY)
Gosub SETNOL
If [M:RBK1]FRMNUM(NOL)<>"" | [M:RBK1]STATUT(NOL)=3 : mkstat=2 : End : Endif
If VALEUR=""
  Call PARAM([M:RBK1]FCYLIN(NOL),"BELTRSDEF",W_PAYTYP) From ADOVAL
  VALEUR=W_PAYTYP
Endif
End

Subprog C_PAYTYP(VALEUR)
Variable Char    VALEUR()
Call LEC_TPY_LEG(GCURLEG,VALEUR) From CPTLEC
If fstat
  Raz [F:TPY]
  ## Valeur invalide
  GMESSAGE = mess(126,143,1) : mkstat=2
Elsif [F:TPY]STA9=1 or [F:TPY]STA3=2 or [F:TPY]STA5=2 or [F:TPY]STA7=2 or [F:TPY]STA8=2
 ## Type de règlement non paramétré pour cette fonction
 GMESSAGE = mess(29,117,1) : mkstat=2
Endif
End

###############################
# controle  parametre BELTRSDEF
###############################
Subprog VERF_PARAM(PARAM,VALPAR,OK)
Value    Char     PARAM()
Value    Char     VALPAR()
Variable Integer  OK

If PARAM <> "BELTRSDEF" : End : Endif

Local Char WPAYTYP(GLONTPY)
Local Char WLEG(GLONADI)

[L]WLEG=GCURLEG
Raz GCURLEG

If !clalev([F:CPY]) : Local File COMPANY   [CPY]  : Endif
If !clalev([F:FCY]) : Local File FACILITY  [FCY]  : Endif
If !clalev([F:TPY]) : Local File TABPAYTYP [TPY]  : Endif
If [M:ADWP]CMP<>""
  Call LEC_CPY([M:ADWP]CMP)  From CPTLEC
  Call GETSOC([F:CPY]MAIFCY) From DEVSUB
Else
  If GNBLEG=1
    GCURLEG = GDOSLEG(1)
  Elsif dim([M:ADWP]LEG)>0
    GCURLEG = [M:ADWP]LEG
  Endif
Endif

[L]WPAYTYP=VALPAR
Call C_PAYTYP([L]WPAYTYP)
If mkstat=2 : OK=0 : Else OK=1 : Endif
GCURLEG=[L]WLEG
End

######################################################################################
######################################################################################
## Gestion écran RBKBEL1  - 2ieme tableau
######################################################################################
Subprog AVANT_NBDUD
If nolign > dim([M:RBK1]DENCOD) :  End : Endif
Gosub SETNOL
[M:RBK0]OD1=[M:RBK1]DUDNUM(NOL)
[M:RBK0]OD2=[M:RBK1]DUDLIG(NOL)
End

Subprog AS_NBDUD
If [M:RBK1]FRMNUM([V]GCURR_NOLIGN-1)<>"" & [M:RBK1]DENCOD(nolign-1)=""
  mkstat=2
Endif
End

$TEST_AS_NBDUD
Local Integer WNOL
WNOL=[V]GCURR_NOLIGN-1
If WNOL<0
  mkstat=2
Elsif [M:RBK1]FRMNUM(WNOL)<>"" or [M:RBK1]WINDEX(WNOL)=0 or [M:RBK1]STATUT(WNOL)=3
  mkstat=2
Endif
Return

Subprog C_NBDUD
If [V]GCURR_NOLIGN=0:  mkstat=2 : End : Endif :##-- pas de ligne de releve en cours
If [M:RBK1]FRMNUM([V]GCURR_NOLIGN-1)<>""
  If status=65 or status=73   :#-- annulation/insertion
    ## Action impossible
    GMESSAGE=mess(186,123,1) : mkstat=2
  Endif
  End
Endif

If status = 65  :#-- suppression uniquement si ligne non validée
  If [M:RBK1]STATUT([V]GCURR_NOLIGN-1)=3
    # Suppression impossible : la ligne a eté validée
    GMESSAGE=mess(184,121,1) : mkstat=2 : End
  Elsif [M:RBK1]FRMNUM([V]GCURR_NOLIGN-1)<>""
    ## suppression interdite
    GMESSAGE=mess(184,193,1)  : mkstat=2 : End
  Endif
Endif

If !adxgtb : End : Endif
Local Integer WSTAT, WNOL
Call STORE_NBDUD(WSTAT)
WNOL=[V]GCURR_NOLIGN-1
If WSTAT=0
  If [M:RBK1]STATUT(WNOL)=2
    [M:RBK1]STATUT(WNOL)=1
    [M:RBK1]VALFLG(WNOL)=1
    Affzo [M:RBK1]VALFLG(WNOL),STATUT(WNOL)
  Endif
  mkstat=2
Endif
End

#**
#* Controle puis sauvegarde du detail de la ligne de releve
#* si pb detecte -->  OUT_STAT=0 , sinon OUT_STAT>0
#*!
Subprog STORE_NBDUD(OUT_STAT)
Variable Integer OUT_STAT
OUT_STAT=1
If  [M:RBK1]FRMNUM([V]GCURR_NOLIGN-1)<> "" : End : Endif
Local Integer SAV_NOLIGN, WNOL, I, WOK
Local Decimal W_MT

SAV_NOLIGN=nolign

WNOL=[V]GCURR_NOLIGN-1
If [M:RBK1]STATUT(WNOL)=3 or [M:RBK1]FRMNUM(WNOL)<>"" : End : Endif

## save detail de la ligne releve
GOK=1
Trbegin [F:RBW]
Delete [F:RBW] Where  RBKNUM=[V]GCURR_RBKNUM & RBKLIN=[M:RBK1]WINDEX(WNOL)
For nolign=1 To [M:RBK1]NBDUD
  [F:RBW] = [M:RBK1]
  [F:RBW]RBKNUM=[V]GCURR_RBKNUM
  [F:RBW]RBKLIN=[M:RBK1]WINDEX(WNOL)
  If [M:RBK1]BPRNUM(WNOL)=""
    Raz [F:RBW]VCRTYP,VCRNUM
  Endif
  [F:RBW]LIN=nolign
  Write [F:RBW]
  If fstat
   GOK=0 : Call FSTA("RBW") From GLOCK : Break
  Endif
Next
If GOK<1
  Rollback : OUT_STAT=0 : End
Else
  Commit
Endif

#-- controle total detail = total ligne releve
MT=0

Local Integer SIGN
For I=0 To [M:RBK1]NBDUD-1
 If [M:RBK1]DENCOD(I)="" : Break : Endif
 Call LEC_CDA_LEG(GCURLEG,[M:RBK1]DENCOD(I)) From CPTLEC
 If [F:CDA]ACCTYP<>3 # On veut le montant banque
  # Sens du mouvement et sens de la destination comptable différent
  SIGN = 1
  If ([F:CDA]ACCSNS=2 & [M:RBK1]SNS(WNOL)=2) or ([F:CDA]ACCSNS=3 & [M:RBK1]SNS(WNOL)=1)
   SIGN = -1
  Else
   SIGN = 1
  Endif
  If [M:RBK1]DUDNUM(I)<>0
   If [F:DUD]ACCNUM<>[M:RBK1]DUDNUM(I) | [F:DUD]DUDLIG<>[M:RBK1]DUDLIG(I)
    Read [DUD]DUD1 = [M:RBK1]DUDNUM(I);[M:RBK1]DUDLIG(I)
    If !fstat
     # Les montants sont toujours affichés en positif
     Case [F:DUD]BPRTYP
      When 1 : SIGN = [F:DUD]SNS*SIGN : # Client
      When 2 : SIGN = [F:DUD]SNS*(-1)*SIGN : # Fournisseur
     Endcase
    Endif
    Endif
  Endif
  W_MT += (SIGN*[M:RBK1]AMTLIN(I))
 Endif
Next

If W_MT <> [M:RBK1]AMTCUR(WNOL)
  # Le cumul des lignes ($1) est différent du montant de la ligne de règlement ($2$)
  GMESSAGE=func AFNC.MES2(mess(183,121,1),format$("N:10.2",W_MT),format$("N:10.2",[M:RBK1]AMTCUR(WNOL)))
  GMESSAGE +="\"+mess(187,121,1)
  Call OUINON(GMESSAGE,WOK) From GESECRAN
  GMESSAGE=""
  If WOK<>2
   #--[M:RBK1]STATUT(WNOL)=1  :#-- statut en attente
   OUT_STAT=0 : nolign=SAV_NOLIGN : End #mkstat=2 : End
  Else
   Case [M:RBK1]SNS(WNOL)
    When 1
      [M:RBK0]AMTCDT = [M:RBK0]AMTCDT -[M:RBK1]AMTCUR(WNOL) + W_MT
    When 2
      [M:RBK0]AMTDEB = [M:RBK0]AMTDEB - [M:RBK1]AMTCUR(WNOL) + W_MT
    When Default
   Endcase
   [M:RBK1]AMTCUR(WNOL)=W_MT : Affzo [M:RBK1]AMTCUR(WNOL)
   Gosub CALC_WNEWAMT  :#-- calc new solde
  Endif
Endif

#-- new status
If ([M:RBK1]BPRNUM(WNOL)<>"" or [M:RBK1]ACCTMP(WNOL)<>"")
&   and [M:RBK1]AMTCUR(WNOL)<>0 and [M:RBK1]SNS(WNOL)<>3 and [M:RBK1]PAYTYP(WNOL)<>""
  [M:RBK1]STATUT(WNOL)=2  :#-- statut a valider
Else
  [M:RBK1]STATUT(WNOL)=1
Endif
If [M:RBK1]STATUT(WNOL)=1
   [M:RBK1]VALFLG(WNOL)=1
Endif
Affzo [M:RBK1]VALFLG(WNOL),STATUT(WNOL)

nolign=SAV_NOLIGN
End

#--
Subprog AS_DENCOD(VALEUR)
Variable Char    VALEUR()
Gosub TEST_AS_NBDUD : If mkstat=2 : End : Endif
Gosub SETNOL
If VALEUR=""
  Case [M:RBK1]SNS([V]GCURR_NOLIGN-1)
    When 1
      VALEUR=[V]G_DENSPG
    When 2
      VALEUR=[V]G_DENTAK
    When Default
  Endcase
Endif
End

Subprog AP_DENCOD(VALEUR)
Variable Char    VALEUR()
If !clalev([F:CAC]) : Local File GACCCODE   [CAC] : Endif
Local Integer GAIN, SIGN
# alimentation montant ligne uniquement si premiere ligne et mt <>0
If [M:RBK1]NBDUD < 2
  Gosub SETNOL
  If [M:RBK1]AMTLIN(NOL) = 0 & NOL=0
    Gosub TEST_AS_NBDUD : If mkstat=2 : Raz mkstat : End : Endif
    [M:RBK1]AMTLIN(NOL)=[M:RBK1]AMTCUR([V]GCURR_NOLIGN-1)
    Affzo [M:RBK1]AMTLIN(NOL)
  Endif
Endif
If [F:CDA]ACCTYP<>1
 ## Destination Cpt->Tiers et Bq->Cpt
 If [F:CDA]ACCCOD<>""
  Gosub SETNOL
  PLAN = GPLAN(1)
  Call LEC_CAC(14,[F:CDA]ACCCOD,PLAN) From CPTLEC
  If !fstat
   Case [F:CDA]ACCSNS
    When 1 : # Sens du règlement
     If [M]SNS=1 : GAIN=2 : Else GAIN=1 : Endif
     Call SIGN2([F:CDA]ACCSNS,[M:RBK1]SNS([V]GCURR_NOLIGN-1),[M]DUDNUM(NOL),[M]DUDLIG(NOL),0,SIGN) From PAYDIV
     If SIGN*sgn([M]AMTLIN(NOL))=-1 : GAIN=3-GAIN : Endif
    When 2 : # Dépense
     If [M]AMTLIN(NOL)>0 : GAIN=1 : Else GAIN=2 : Endif
    When 3 : # Recette
     If [M]AMTLIN(NOL)>0 : GAIN=2 : Else GAIN=1 : Endif
   Endcase
   If GAIN=2
    [M]ACC(NOL) = [F:CAC]ACC(0)
   Else
    [M]ACC(NOL) = [F:CAC]ACC(1)
   Endif
  Endif
 Endif
Endif
End

Subprog AS_VCRTYP(VALEUR)
Variable Char    VALEUR()
Gosub TEST_AS_NBDUD : If mkstat=2 : End : Endif
If [M:RBK1]BPRNUM([V]GCURR_NOLIGN-1)=""
  mkstat=1
Endif
End

Subprog C_VCRTYP(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LEC_GTE_LEG([F:CPY]LEG,VALEUR) From CPTLEC
 If fstat
  #--Type de pièce inexistant
  GMESSAGE=mess(17,114,1)
  mkstat=2 : End
 Endif
Endif
End

Subprog AS_VCRNUM(VALEUR)
Variable Char    VALEUR()
Gosub TEST_AS_NBDUD : If mkstat=2 : End : Endif
Gosub SETNOL
If [M:RBK1]VCRTYP(NOL)="" or  [M:RBK1]BPRNUM([V]GCURR_NOLIGN-1)=""
 mkstat = 1
 Raz [M:RBK1]DUDNUM(NOL), [M:RBK1]DUDLIG(NOL), [M:RBK1]DUDDAT(NOL)
 End
Endif
End

Subprog C_VCRNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" : End : Endif
Local Char SOCIETE(GLONCPY)
Gosub SETNOL
Call LECTURE("GAS",VALEUR,[M:RBK1]VCRTYP(NOL)) From CONTOBJ
If fstat
 Read [DUD]DUD0(2)=[M:RBK1]VCRTYP(NOL);VALEUR
 If fstat
  # Pièce comptable inexistante
  GMESSAGE = mess(3,659,1)-mess(20,117,1)
  mkstat=2 : End
 Else
  [L]SOCIETE=[F:DUD]CPY
 Endif
Else
 [L]SOCIETE=[F:HAE]CPY
Endif
If [L]SOCIETE<>[M:RBK0]CPY
 # Pièce comptable de la societe
 GMESSAGE = mess(3,659,1)-mess(5,117,1)-[L]SOCIETE
 mkstat=2 : End
Endif
End

Subprog AP_VCRNUM(VALEUR)
Variable Char    VALEUR()
If [M:RBK1]FRMNUM([V]GCURR_NOLIGN-1)<>"" : End : Endif
Gosub SETNOL
If [M]DUDNUM(NOL)<>0
 #--vérifier que l'échéance n'est pas en cours de lettrage
 Filter [MTB] Where ACCNUM=[M]DUDNUM(NOL) & DUDLIG=[M]DUDLIG(NOL)
 Look [MTB]MTB0 First
 Filter [MTB]
 If !fstat
  ## Echéance en cours de lettrage
  GMESSAGE=mess(70,119,1) : mkstat=2 : End
 Endif
 #--Vérifier que l'échéance n'est pas en cours de proposition automatique de règlement
 Read [TPD]TPD1 = [M]DUDNUM(NOL);DUDLIG=[M]DUDLIG(NOL)
 If !fstat
  ## Echéance en cours de règlement
  GMESSAGE = mess(50,119,1) : mkstat=2 : End
 Endif
 VALEUR=[M:RBK1]VCRNUM(NOL)
 Affzo [M:RBK1]AMTLIN(NOL)
Endif
End

Subprog AS_ACC(VALEUR)
Variable Char    VALEUR()
Gosub TEST_AS_NBDUD
End

Subprog AS_AMTLIN(VALEUR)
Variable Decimal VALEUR
Gosub TEST_AS_NBDUD
End

Subprog AM_AMTLIN(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL

If  [M:RBK1]DUDNUM(NOL)=0 : End : Endif
Local Decimal W_MT, W_MTBAN, W_COURS
Local Integer W_STAT

Read [DUD]DUD1 = [M]DUDNUM(NOL);[M]DUDLIG(NOL)
If fstat
  Call RSTA("DUD",num$([M:RBK1]DUDNUM(NOL))-num$([M:RBK1]DUDLIG(NOL))) From GLOCK
  mkstat=2 : End
Endif

[L]W_MT=0 : [L]W_MTBAN=0
##calcul du disponible sur l'echeance
Call MTECHE([L]W_MT, [L]W_MTBAN, NOL, [L]W_STAT) From SUBRBB2
If [L]W_STAT : mkstat=2 : End : Endif

If VALEUR > [L]W_MTBAN
  ## Montant supérieur au montant restant à règler
  GMESSAGE=mess(206,117,1)
  mkstat=2 : End
Endif

## conversion du montant devise banque en devise echeance
If [F:DUD]CUR=[M:RBK0]CUR : [M:RBK1]AMTLINCUR(NOL)=VALEUR : End : Endif

Call LEC_TPY_LEG([V]GCURLEG,[M:RBK1]PAYTYP([V]GCURR_NOLIGN-1)) From CPTLEC
[L]W_COURS=0
[L]W_MTBAN = VALEUR
[L]W_MT=0
If [F:TPY]RATINV=2 and [M:RBK0]CUR=[V]GL_DEVLED :##--application taux de la facture
  Read [HAE]HAE0 = [M:RBK1]VCRTYP(NOL);[M:RBK1]VCRNUM(NOL)
  If fstat
    GMESSAGE=mess(49,125,1)-mess(12,107,1)-[M:RBK1]VCRTYP(NOL)+"/"+[M:RBK1]VCRNUM(NOL)
    mkstat=2 : End
  Endif
  If [F:HAE]RATMLT(GTYPGEN-1)<>0
    [L]W_COURS  = [F:HAE]RATDIV(GTYPGEN-1)/[F:HAE]RATMLT(GTYPGEN-1)
  Endif
  Call CONVERT3([M:RBK0]CUR,[F:DUD]CUR,[V]GL_DEVLED,[F:HAE]TYPRAT,[F:HAE]RATDAT,
&               [L]W_MTBAN,[L]W_MT,[L]W_COURS,[L]W_STAT) From CPTSUB
  If  [L]W_STAT
    ## Pas de cours de devises [F:DUD]CUR -> [M:RBK0]CUR
    GMESSAGE=mess(16,114,1)-[M:RBK0]CUR-"->"-[F:DUD]CUR-"("+format$("D:"+GFMDAT,[F:HAE]RATDAT)-")"
    mkstat=2 : End
  Endif
Else
  Call CONVERT3([M:RBK0]CUR,[F:DUD]CUR,[V]GL_DEVLED,[F:TPY]RATTYP,[M:RBK1]ACCDAT([V]GCURR_NOLIGN-1),
&               [L]W_MTBAN,[L]W_MT,[L]W_COURS,[L]W_STAT) From CPTSUB
  If  [L]W_STAT
    ## Pas de cours de devises [F:DUD]CUR -> [M:RBK0]CUR
    GMESSAGE=mess(16,114,1)-[M:RBK0]CUR-"->"-[F:DUD]CUR-"("+format$("D:"+GFMDAT,[M:RBK1]ACCDAT([V]GCURR_NOLIGN-1))-")"
    mkstat=2 : End
  Endif
Endif
[M:RBK1]AMTLINCUR(NOL)=[L]W_MT  :## mt en devise echeance
End

Subprog AS_VATLIN(VALEUR)
Variable Char    VALEUR()
Gosub TEST_AS_NBDUD : If mkstat=2 : End : Endif
Gosub SETNOL
Call LEC_CDA_LEG(GCURLEG,[M:RBK1]DENCOD(NOL)) From CPTLEC
If [F:CDA]RPCVAT<2 : mkstat = 1 : End : Endif

If [M:RBK1]ACC(NOL) = "" : End : Endif
Call LEC_GAC([M:RBK1]ACC(NOL),[M:RBK0]COA)From CPTLEC
If !fstat
  If [F:GAC]FLGVAT=1
    mkstat=1
  Else
    If VALEUR=""
      VALEUR=[F:GAC]VAT(0)
    Endif
  Endif
Endif
End

######################################################################################
######################################################################################
Subprog IB_NBDUD
Gosub SETNOL
If [M:RBK1]TYPCOM(NOL)="" or [M:RBK1]COMFLD(NOL)="" : Raz GBOUT2 : Endif :#-- visu communication structuree
If [M:RBK1]VCRNUM(NOL)="" : Raz GBOUT3 : Endif :#-- visu Facture
End

Subprog B3_NBDUD
Local Char  VALC2(GLONVCR)
Gosub SETNOL
[L]VALC2=[M:RBK1]VCRNUM(NOL)
Gosub AB3_FACTURE
If [L]VALC1<>"" : Call OBJET([L]VALC1,[L]VALC2,[L]VALC3) From GOBJET : Endif
End

Subprog IB_VCRNUM
#-- visu Facture
If [M:RBK1]VCRNUM(nolign-1)=""
  Raz GBOUT3
Else
  ## Facture
  GBOUT3 = mess(4,413,1)
Endif
End

Subprog B3_VCRNUM(VALEUR)
Variable Char    VALEUR()
Local Char VALC2(GLONVCR)
Gosub SETNOL
[L]VALC2=VALEUR
Gosub AB3_FACTURE
If [L]VALC1<>"" : Call OBJET([L]VALC1,[L]VALC2,[L]VALC3) From GOBJET : Endif
End

$AB3_FACTURE
Local Integer K, I
Local Char    OPT(5), VALC1(GLONVCR), VALC3(GLONVCR)

NOL=nolign-1
If [M]SNS=1 :OPT="213"
Else        :OPT="123"
Endif
For I=1 To 3
 Case mid$(OPT,I,1)
  When "1" : # Facture client
   Call LECTURE("BIC",[L]VALC2,"") From CONTOBJ
   If fstat=0 & [F:SIH]GTE=[M:RBK1]VCRTYP(NOL)
    If [F:SIH]ORIMOD=3
     [L]VALC1 = "BIC"
    Else
     [L]VALC1 = "SIH"
    Endif
    Break
   Endif
  When "2" : # Facture fournisseur
   Call LECTURE("BIS",[L]VALC2,"") From CONTOBJ
   If fstat=0 & [F:PIH]GTE=[M:RBK1]VCRTYP(NOL)
    If [F:PIH]ORIMOD=3
     [L]VALC1 = "BIS"
    Elsif [F:PIH]ORIMOD=6
     [L]VALC1 = "PIH"
    Endif
    Break
   Endif
  When "3" : # Pièce comptable
   Onerrgo ERREUR From CONTROLE
   If !clalev([F:HAE]) : Local File GACCENTRY [HAE] : K=1 : Endif
   Onerrgo
   If !GERREUR
    Call LECTURE("GAS",[L]VALC2,[M:RBK1]VCRTYP(NOL)) From CONTOBJ
    If fstat=0 : [L]VALC1 = "GAS" :  [L]VALC3=[M:RBK1]VCRTYP(NOL) : Endif
    If K : Close Local File [HAE] : K=0 : Endif
   Else GERREUR=0
   Endif
 Endcase
Next I
Return
######################################################################################
######################################################################################
#**
#* Rafraichissement des listes gauches en "action champ" sur une ligne
#*!
$REFRESH_LISGAU
Local Char ABREV(3) : ABREV="RBB"
If !find(currbox, GBOX_RB1,GBOX_RB2) : Return : Endif
If [M]FCYLIN(GCURR_NOLIGN-1)<>""
  Gosub DEFVAR From GOBJET
  Gosub FILGAUCHE
Else
  FILGAUSUP="2=1"
Endif
If  FILGAUSUP="2=1"
  If currbox = GBOX_RB1
    Filter [F:DUD_] Where 2=1
    Fillbox [RBK1] GAU_CHE1
    Filter [F:DUD_]
  Else  #--GBOX_RB2
    Filter [F:FRM] Where 2=1
    Fillbox [RBK1] GAU_CHE2
    Filter [F:FRM]
  Endif
  Return
Endif

Local Char ABREV(3) : ABREV="RBB"
Gosub DEFVAR From GOBJET

Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(30)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 1
AFOLDEF = 1
ABRENA = ""
BOX1 = "GAU_CHE"
OBJLIS(0) = "RBB"
CHGLIS(0) = 2
BROLIS(0) = 2
TRELIS(0) = 1
DESLIS(0) = "RBKNUM"
OBJLIS(1) = "RB1"
CHGLIS(1) = 1
BROLIS(1) = 0
TRELIS(1) = 5
DESLIS(1) = "TYP+NUM+LIG+DUDLIG"
OBJLIS(2) = "RB2"
CHGLIS(2) = 1
BROLIS(2) = 0
TRELIS(2) = 5
DESLIS(2) = "FRMFLG+FRMNUM"

WINPROG="WGORBB"  :#-- gestion fenetre RBB

ILIS=val(right$(currbox,8))
Gosub REMP_LISGAU From GOBJSUB
Gosub REFRESH_PICK
Return

