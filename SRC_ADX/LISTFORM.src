#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Modifications :
#     SEGAY - 07/04/11 - Bug 72871 - V6.2 , rajout du critère Dispostifs, suivant Tous dispositifs
######################################################################################


$ACTION
Case ACTION
 When "OUVRE" Gosub OUVRE2
 When "CONT1" Gosub CONT1
 When "MEMO"  Gosub MEMO
Endcase
Return

$OUVRE2
# Test que Tous dispositifs = Oui/Non
# Si Oui on grise Dispostif
# Si Non on dégrise Dispostif
GBIDI2=find("tdis",[M:RPT]PARCOD)
If GBIDI2
    If[M]VALEUR1(GBIDI2-1) =mess(1,1,1) Then
      [M]VALEUR1(GBIDI2)=mess(1,10455,1)
      [M]VALINT1(GBIDI2)="1"
      Actzo [M]VALEUR1(GBIDI2)
    Else 
      [M]VALEUR1(GBIDI2)=""
      [M]VALINT1(GBIDI2)='"'+num$(len(mess(0,10455,1)))+'"' : # ML 455 Non définie
      Diszo [M]VALEUR1(GBIDI2)
    Endif
    Affzo [M]VALEUR1(GBIDI2)
Endif
Return

$CONT1
# If GUSER="CCLs" : Infbox VALEUR : Endif
# Test que Tous dispositifs = Oui/Non
# Si Oui on grise Dispostif
# Si Non on dégrise Dispostif
If [M]PARCOD(nolign-1)="tdis" Then
    If VALEUR =mess(1,1,1) Then
        If [M]VALEUR1(nolign-1) <> VALEUR Then
            [M]VALEUR1(nolign)=mess(1,10455,1)
            [M]VALINT1(nolign)="1"
            Actzo [M]VALEUR1(nolign)
        Endif
    Elsif VALEUR =mess(2,1,1) Then
        If [M]VALEUR1(nolign-1) <> VALEUR Then
            [M]VALEUR1(nolign)=""
            [M]VALINT1(nolign)='"'+num$(len(mess(0,10455,1)))+'"' : # ML 455 Non définie
            Diszo [M]VALEUR1(nolign)
        Endif
    Endif
    Affzo [M]VALEUR1(nolign)
Endif
Return

# Exécuté suite au rappel d'un mémo
$MEMO
Local Integer I
Local Char VAL1(250),VAL2(250)
For I=1 To dim([M:RPT]PARCOD)
    If [M:RPT]PARCOD(I)="" : Break : Endif
    If [M:RPT]PARCOD(I)="tdis" Then
        # on relit la variable ordre de tri
        Call  LECMEMO_COD([M:RPT]RPTCOD,"rpt",[M:MEM]CODE,"dis",VAL1,VAL2)  From AIMP4
        # on récupère la variable ordre de tri
        [M:RPT]VALEUR1(I+1) = VAL1
        # on refait le contrôle de la variable ordre de tri
        Call CONTROLE([M:RPT]VALEUR1(I+1),[M:RPT]PARTYP(I+1),[M:RPT]NOLIB(I+1),[M:RPT]LONG(I+1)
& ,[M:RPT]VALINT1(I+1)) From FMTVAR
        If [M:RPT]VALEUR1(I) = mess(1,1,1)
            Actzo [M:RPT]VALEUR1(I+1)
        Else
            [M:RPT]VALEUR1(I+1)=""
            [M:RPT]VALINT1(I+1)='"'+num$(len(mess(0,10455,1)))+'"' : # ML 455 Non définie
            Diszo [M:RPT]VALEUR1(I+1)
        Endif
        Affzo [M:RPT]VALEUR1(I+1)
        Break
    Endif
Next
Return

Subprog IMPRIME(NBPAR,PARAMETRE)
        Value Integer NBPAR
        Variable Char PARAMETRE() ()
End


