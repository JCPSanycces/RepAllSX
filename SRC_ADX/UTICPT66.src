#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
# UTICPT66   UTI process                                    Module CPT   #
#            correction utility
#    CPT for module :  must be replaced (GPA ACH STO ...)
#    66  number of sequence : must be replaced (01 02 ...)
##########################################################################
#
# Team FINANCE-Sophia - X3 menu reorganization - ML97 : New groups of reports - 90405
#
##########################################################################

If clalev([F:ADS])=0
    Local File ADOSSIER [ADS]
Endif

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOS(WDOSSIER,"") From SAIDOS

If WDOSSIER <> ""
  Read [ADS]DOSSIER=WDOSSIER
  If fstat <> 0
        Raz [F:ADS]
  Endif
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction") From LECFIC
  Call MAJ_UTICPT66(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTICPT66(DOSSIER)
Value Char DOSSIER

Local Integer WCOMPTEUR
Call ECR_TRACE("UTICPT66 : Start of process on : "+DOSSIER,0) From GESECRAN


########################################################################## Update ML97
Local File ADOSSIER [ADS6]
Read [ADS6]DOSSIER = DOSSIER

Local File =[F:ADS6]DOSSIER+".APLSTD" [APL]
Local File =[F:ADS6]DOSCOP +".APLSTD" [APLC]


WCOMPTEUR = 0
Call DEBTRANS From GLOCK

GOK=1
Trbegin [APL]

Filter [APLC] Where LANCHP=97

For [F:APLC]
 Read [F:APL]CLE = [F:APLC]LANCHP;[F:APLC]LANNUM;[F:APLC]LAN
 [F:APL] = [F:APLC]
 If !fstat
  Rewrite [F:APL]
 Else
  Write [F:APL]
 Endif
 If !fstat
  WCOMPTEUR += 1
 Else
  GOK = 0 : Call ECR_TRACE(mess(13,100,1)-"APLSTD"-":"-num$([F:APLC]LANCHP)-num$([F:APLC]LANNUM)-[F:APLC]LAN,1) From GESECRAN
 Endif
Next

If !GOK
 Rollback
Else
 Call ECR_TRACE("UTICPT66 : APLSTD (97) "+num$(WCOMPTEUR)+" records processed",0) From GESECRAN
 Commit
Endif
Filter [APLC]
Close Local File [APL], [APLC]

########################################################################## Update GRP.AREPORT

If clalev([F:ARP])  =0  Local File =DOSSIER+".AREPORT"  [ARP] : Endif

WCOMPTEUR = 0
Call DEBTRANS From GLOCK

GOK=1
Trbegin [ARP]


Update [ARP] Where RPTCOD="CONTVAENC"       With GRP=60 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8/V7
Update [ARP] Where RPTCOD="CONTVAPCE"       With GRP=60 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8/V7
Update [ARP] Where RPTCOD="DCLESD2"         With GRP=60 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8/V7
Update [ARP] Where RPTCOD="DCLVATDEB2"      With GRP=60 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8/V7
Update [ARP] Where RPTCOD="DCLVATENC2"      With GRP=60 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8/V7
Update [ARP] Where RPTCOD="GLVATGEN"        With GRP=60 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8/V7

Update [ARP] Where RPTCOD="TRG"             With GRP=61 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8
Update [ARP] Where RPTCOD="TRGVAL1"         With GRP=61 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8
Update [ARP] Where RPTCOD="TRGVAL2"         With GRP=61 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8
Update [ARP] Where RPTCOD="TRGVAL3"         With GRP=61 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8
Update [ARP] Where RPTCOD="TRGVAL4"         With GRP=61 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8

Update [ARP] Where RPTCOD="S-LIBROREP"      With GRP=62 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8/V7
Update [ARP] Where RPTCOD="S-LIBROREPCAJA"  With GRP=62 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8/V7
Update [ARP] Where RPTCOD="S-LIBROSOP"      With GRP=62 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8/V7
Update [ARP] Where RPTCOD="S-LIBROSOPCAJA"  With GRP=62 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8/V7
Update [ARP] Where RPTCOD="S-RETENCION"     With GRP=62 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8/V7
Update [ARP] Where RPTCOD="S-RESIVA"        With GRP=62 : If !fstat : WCOMPTEUR+=adxuprec : Endif  ###/V7

Update [ARP] Where RPTCOD="P-PERVAT"        With GRP=63 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8/V7
Update [ARP] Where RPTCOD="P-VATPORBAS"     With GRP=63 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8/V7
Update [ARP] Where RPTCOD="P-YEAVAT"        With GRP=63 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8/V7

Update [ARP] Where RPTCOD="DADSU"           With GRP=64 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8/V7
Update [ARP] Where RPTCOD="DAS2"            With GRP=64 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8/V7
Update [ARP] Where RPTCOD="LETTREDAS"       With GRP=64 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8/V7

Update [ARP] Where RPTCOD="HON281"          With GRP=65 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8/V7

Update [ARP] Where RPTCOD="1099ACT"         With GRP=66 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8/V7

Update [ARP] Where RPTCOD="AUTRS"           With GRP=67 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8/V7
Update [ARP] Where RPTCOD="AUTRSVAL"        With GRP=67 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8/V7

Update [ARP] Where RPTCOD="HONPRV"          With GRP=68 : If !fstat : WCOMPTEUR+=adxuprec : Endif  #V8/V7

If !GOK
 Rollback
Else
 Call ECR_TRACE("UTICPT66 : AREPORT (GRP) "+num$(WCOMPTEUR)+" records processed",0) From GESECRAN
 Commit
Endif

Close Local File [ARP]


Call GENMENU(DOSSIER,1,1,GLANGUE) From GENMENULOC
End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT66 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI
If fstat : Raz [F:ADS] : Endif
Call MAJ_UTICPT66(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
Call MAJ_UTICPT66(APPLI)
End
