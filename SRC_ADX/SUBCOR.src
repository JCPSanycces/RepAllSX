#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion objet COR
Call OBJET ("COR", GBIDC1, GBIDC2) From GOBJET
End
##########################################################################################################

##########################################################################################################
# Gestion des correspondants                 Module CRM 2006
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "OUVRE"        : Gosub OUVRE
    When "FERME"        : Gosub FERME
    When "SETBOUT"      : Gosub SETBOUT
    When "AVANTBOUT"    : Gosub AVANTBOUT
    When "LIENS"        : Gosub LIENS
    When "RAZCRE"       : Gosub RAZCRE
    When "RAZDUP"       : Gosub RAZDUP
    When "INICRE"       : Gosub INICRE
    When "VERIF_CRE"    : Gosub VERIF_CRE
    When "AVANT_MODFIC" : Gosub AVANT_MODFIC
    When "VERIF_MOD"    : Gosub VERIF_MOD
    When "CREATION"     : Gosub CREATION
    When "MODIF"        : Gosub MODIF
    When "AV_ANNULE"    : Gosub AV_ANNULE
    When "ANNULE"       : Gosub ANNULE
    When "APRES_CRE"    : Gosub APRES_CRE
    When "APRES_MOD"    : Gosub APRES_MOD
    When "AP_ANNULE"    : Gosub AP_ANNULE
    When "FILTRE"       : Gosub FILTRE
    When "FILGAUCHE"    : Gosub FILGAUCHE
    When "STATUT"       : Gosub STATUT
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Char GSZCPTCOR(GLONANM)  #Code compteur COR
Global Integer GIMANCOUCOR
Global Char GSZCPTCRC(GLONANM)  #Code compteur CRC
Global Integer GIMANCOUCRC

Global Char GTBCORFIELDSYL(30)(50)
Global Char GTBCORVALSYL(250)(50)
Global Char GTBCORCHRONOSYL(30)(50)
Global Integer GICORNBSYL

Global Char GTBCORVALREP(30)(dim([M:COR4]COPREP))
Global Char GTBCORVALUSR(30)(dim([M:COR4]COPREP))
Global Integer GICORNBREP

  Local Mask COR0 [CR0S]
  Local Mask COR2 [CR2S]
  Local Mask COR3 [CR3S]
  Raz [M:CR0S]
  Raz [M:CR2S]
  Raz [M:CR3S]

  Raz GTBCORFIELDSYL
  Raz GTBCORVALSYL
  Raz GTBCORCHRONOSYL
  GICORNBSYL = 0

  Raz GTBCORVALREP
  Raz GTBCORVALUSR
  GICORNBREP = 0

  If !clalev([F:SYL]) : Local File SYNCLINK [SYL] : Endif
  If !clalev([F:BR1]) : Local File BPARTNER [BR1] : Endif
  #------------------------------------------------------------#
  # --> Récupération du code compteur correspondant            #
  #------------------------------------------------------------#
  # ----------------------------------------------------------
  # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
  #  If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
  #  Read [TCA]TCA0=13
  #  If fstat Then
  #    GERR = 1
  #    GMESSAGE = mess(64,199,1)
  #    OK = 0
  #    Return
  #  Endif
  #  GMANCOUCRC = [F:TCA]MANCOU(10)
  #  GSZCPTCRC = [F:TCA]CODNUM(10)
  #  GMANCOUCOR = [F:TCA]MANCOU(11)
  #  GSZCPTCOR = [F:TCA]CODNUM(11)
  GSOCIETE = ""
  GCURLEG = ""
  Call READ_COUNTER("", 13, 10, "", "", GSZCPTCRC, GIMANCOUCRC) From CRM_UTIL
  Call READ_COUNTER("", 13, 11, "", "", GSZCPTCOR, GIMANCOUCOR) From CRM_UTIL
  # FGR 20/12/2012 : X3SUIVI71937 (fin)
  # ----------------------------------------------------------
  GFCY = ""
  GSOCIETE = ""
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$FERME
  If GPILNAV > 0  Then  # FGR 23/12/2010 : X3SUIVI70191 : Pb en synchro outlook
    # FGR 16/07/2010 : X3SUIVI66053 : Ajout du IF
    If GNAVIG(GPILNAV) = "GESCOR" Then
      Kill GSZCPTCOR
      Kill GIMANCOUCOR
      Kill GSZCPTCRC
      Kill GIMANCOUCRC
      Kill GTBCORFIELDSYL
      Kill GTBCORVALSYL
      Kill GTBCORCHRONOSYL
      Kill GICORNBSYL
      Kill GTBCORVALREP
      Kill GTBCORVALUSR
      Kill GICORNBREP
      Close Local Mask [CR0S]
      Close Local Mask [CR2S]
      Close Local Mask [CR3S]
    Endif
  Endif
Return

##########################################################################################################
$SETBOUT
  Call VIREBOUT(CHAINE,"H") From GOBJET # FGR 14/06/2010 : X3SUIVI65270
  #Menu Actions   Module Action Co
  #  )    Planifier Rendez-vous
  #  (    Planifier Appel
  #  £    Planifier Tâche
  #  }    Enregistrer Rendez-vous
  #  {    Enregistrer Appel
  #  ~    Enregistrer Tâche
  If REP = "" and [M:COR0]CORTYP <> "REP" Then
    CHMEN += "{}~()£"
  Endif
  If REP = "" and [M:COR0]CNTNUM = "" and [M:COR0]CORTYP = "AIN" Then
    # Générer interlocuteur
    CHMEN += "N"
  Endif
  If REP = "" and [M:COR0]CNTNUM = "" and [M:COR0]CORTYP = "AIN" Then
    # Générer leads
    CHMEN += "V"
  Endif
  #----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
  Gosub SET_BOUT_SPE From GSAISIE
Return

##########################################################################################################
$AVANTBOUT
  [M:COR0]NVGCOD = BOUT
  Case BOUT
    When ")"
      #Planifier Rendez-vous
      GBCRMFLGNEW = 1
    When "("
      #Planifier Appel
      GBCRMFLGNEW = 1
    When "£"
      #Planifier tache
      GBCRMFLGNEW = 1
    When "}"
      #Enregistrer Rendez-vous
      GBCRMFLGNEW = 1
    When "{"
      #Enregistrer Appel
      GBCRMFLGNEW = 1
    When "~"
      #Enregistrer tache
      GBCRMFLGNEW = 1
    When "N"
      #générer interlocuteur
      GBCRMFLGNEW = 1
    When "V"
      #générer lead
      GBCRMFLGNEW = 1
  Endcase
Return

##########################################################################################################
$STATUT
  Case BOUT
    When "N"
      #retour générer interlocuteur
      REPONSE = GSTARAF
      Gosub RAFFRAICHIR From GOBJSUB
      Gosub SETBOUT From GOBJSUB
    When "V"
      #retour générer lead
      REPONSE = GSTARAF
      Gosub RAFFRAICHIR From GOBJSUB
      Gosub SETBOUT From GOBJSUB
  Endcase
Return

##########################################################################################################
$RAZCRE
  Raz GTBCORFIELDSYL
  Raz GTBCORVALSYL
  Raz GTBCORCHRONOSYL
  GICORNBSYL = 0
  Raz GTBCORVALREP
  Raz GTBCORVALUSR
  GICORNBREP = 0
  Raz [M:CR0S]
  Raz [M:CR2S]
  Raz [M:CR3S]
  [M:COR2]CPYBPATYP = 1
  [M:COR0]CORTYP = "AIN"
  [M:COR0]CORTYPMEN = 2
  [M:COR0]UPDCNTNUM = 1
  [M:COR2]UPDBPRNUM = 1
  Actzo [M:COR0]CORTYPMEN
  Actzo [M:COR0]CNTNUM
  Actzo [M:COR2]BPRNUM
  Affzo [M:COR0]CORTYPMEN
  Gosub SET_CORTYPMEN From SUBCORB
  # FGR 04/07/2008 : X3SUIVI48214 : Initialisation du représentant (courant) par défaut s'il existe
  Gosub INIT_COPREP From SUBCORB
Return

##########################################################################################################
$RAZDUP
  Raz GTBCORFIELDSYL
  Raz GTBCORVALSYL
  Raz GTBCORCHRONOSYL
  GICORNBSYL = 0
  Raz [M:CR0S]
  Raz [M:CR2S]
  Raz [M:CR3S]
  [M:COR2]CPYBPATYP = 1
  [M:COR0]UPDCNTNUM = 1
  [M:COR2]UPDBPRNUM = 1
  Actzo [M:COR0]CORTYPMEN
  Actzo [M:COR0]CNTNUM
  Actzo [M:COR2]BPRNUM
  Affzo [M:COR0]CORTYPMEN
  Gosub SET_CORTYPMEN From SUBCORB
  # FGR 04/07/2008 : X3SUIVI48214 : Initialisation du représentant (courant) par défaut s'il existe
  Gosub INIT_COPREP From SUBCORB
Return

##########################################################################################################
$INICRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  If not (GSYNCOUTLOOK = 1 and vireblc([M:COR0]CORNUM, 2) <> "") Then
    # On n'est pas en restauration de synchro
    # Récupération du compteur correspondant
    If func CRM_UTIL.GET_NUMERO_CHRONO ("ACT", "", GSZCPTCOR, date$, "", [M:COR0]CORNUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
      If IBRETOUR = 1 Then
        [F:COR]CORNUM = [M:COR0]CORNUM
        Affzo [M:COR0]CORNUM
      Else
        # problème lors de la récupération du compteur
        GERR = 1
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GOK = 0
        Return
      Endif
    Endif
  Endif
Return

##########################################################################################################
$VERIF_CRE_MOD
  GOK = 1
  If [M:COR2]BPRNUM = "" Then
    [M:COR2]CPYBPANUM = ""
  Endif
  Gosub VERIFALLCOP From SUBCORB
  If GOK < 1 Then
    OK = 0
    GERR = 1
  Endif
Return

##########################################################################################################
$VERIF_CRE
  Gosub VERIF_CRE_MOD
  If GERR = 1 Then
    Return
  Endif
Return

##########################################################################################################
$VERIF_MOD
  Gosub VERIF_CRE_MOD
  If GERR = 1 Then
    Return
  Endif
Return

##########################################################################################################
$CREATION
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBCORB
  If GOK < 1 Then
    Return
  Endif
  #Enregistrement des représentants avec données synchronisations
  Gosub CREALLCOP From SUBCORB
  #Mise à jour des tables liées
  Gosub MAJTABLES From SUBCORB
  If GOK < 1 Then
    Return
  Endif
  # Maj des statistiques
  Call VALSTA("COR",1) From SUBPS2
Return

##########################################################################################################
$AVANT_MODFIC
Return

##########################################################################################################
$MODIF
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBCORB
  If GOK < 1 Then
    Return
  Endif
  If [M:COR0]FORCAGEREP <> "" Then
    #cas du forçage
    Gosub FORCECOR From SUBCORB
  Else
    #Enregistrement des représentants
    Gosub SAVEALLCOP From SUBCORB
  Endif
  If GOK < 1 Then
    Return
  Endif
  #traitement des erreurs de transcodification
  If GICORNBSYL > 0 Then
    While IINDICE < GICORNBSYL
      If GTBCORVALSYL(IINDICE) <> evalue ("[M]" + GTBCORFIELDSYL(IINDICE)) Then
        #On a une modification du champs, on estime transcodif faite
        Read [SYL]SYL0=GTBCORCHRONOSYL(IINDICE)
        If fstat = 0
          [F:SYL]SYLFLGDPT = 0
          Rewrite [SYL]
        Endif
      Endif
      IINDICE += 1
    Wend
  Endif
  #Mise à jour des tables liées
  Gosub MAJTABLES From SUBCORB
  If GOK < 1 Then
    Return
  Endif
  # Maj des statistiques
  Call VALSTA("COR",-1) From SUBPS2
  Call VALSTA("COR",1) From SUBPS2
Return

##########################################################################################################
$AV_ANNULE
Return

##########################################################################################################
$ANNULE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  #Suppression des clobs
  Gosub DELCLOB From SUBCORB
  If GOK < 1 Then
    Return
  Endif
  #Suppression de tous les relations représenatants
  Gosub DELLALLCOP From SUBCORB
  #Suppression donnée transcodif
  Call SYLDELETE("COR", [M:COR0]CORNUM, IERRINF, ICHAPTER, IBRETOUR) From SUBSYLB
  # Maj des statistiques
  Call VALSTA("COR",-1) From SUBPS2
Return

##########################################################################################################
$APRES_CRE
Return

##########################################################################################################
$APRES_MOD
Return

##########################################################################################################
$AP_ANNULE
Return

##########################################################################################################
$FILTRE
  Default File [COR]
Return

##########################################################################################################
$FILGAUCHE
Return

##########################################################################################################
$LIENS
  Call AM_FNC([M:COR2]FNC)
  #
  Gosub SET_CORTYPMEN From SUBCORB
  #---------------------------------------------------#
  #Lecture des clobs
  #---------------------------------------------------#
  Gosub LOADCLOB From SUBCORB
  #---------------------------------------------------#
  #Chargement des représentants
  Gosub LOADCOP From SUBCORB
  #---------------------------------------------------#
  #Gestion de la transcodif
  Raz GTBCORFIELDSYL
  Raz GTBCORVALSYL
  Raz GTBCORCHRONOSYL
  GICORNBSYL = 0
  For [SYL] Where [F:SYL]SYLTYP = "COR" and [F:SYL]SYLKEY = [M:COR0]CORNUM and [F:SYL]SYLFLGDPT = 1
    GTBFIELDSYL(GICORNBSYL) = [F:SYL]SYLFIE
    GTBVALINITSYL(GICORNBSYL) = evalue("[M]"+[F:SYL]SYLFIE)
    GTBCHRONOSYL(GICORNBSYL) = [F:SYL]SYLNUM
    GICORNBSYL += 1
  Next
  If [M:COR0]UPDCNTNUM = 0 Then
    Diszo [M:COR0]CNTNUM
  Else
    Actzo [M:COR0]CNTNUM
  Endif
  If [M:COR2]UPDBPRNUM = 0 Then
    Diszo [M:COR2]BPRNUM     # FGR 24/03/2010 : X3SUIVI63506 : Diszo, c'est mieux que Grizo
  Else
    Actzo [M:COR2]BPRNUM
  Endif
  If [M:COR2]BPRNUM = "" Then
    Diszo [M:COR2]CPYBPANUM  # FGR 24/03/2010 : X3SUIVI63506 : Diszo, c'est mieux que Grizo
  Else
    Actzo [M:COR2]CPYBPANUM
  Endif
  Grizo [M:COR0]CORTYPMEN
  # Issue X3-35454 - 2017-05-03 by FGR : BEGIN
  #[M:CR0S] = [M:COR0]
  #[M:CR2S] = [M:COR2]
  #[M:CR3S] = [M:COR3]
  Raz [M:CR0S] : Transmask [M:COR0] To [M:CR0S]
  Raz [M:CR2S] : Transmask [M:COR2] To [M:CR2S]
  Raz [M:CR3S] : Transmask [M:COR3] To [M:CR3S]
  # Issue X3-35454 - 2017-05-03 by FGR : END
Return

##########################################################################################################
Subprog AM_COPREP(VALEUR)
Variable Char    VALEUR()

  If VALEUR= "" Then
    [M:COR4]REPNAM(nolign-1) = ""
    [M:COR4]AUSNUM(nolign-1) = ""
    Affzo [M:COR4]REPNAM(nolign-1)
    End
  Else
    Read [REP]REP0=VALEUR
    If fstat = 0 Then
      [M:COR4]REPNAM(nolign-1) = [F:REP]REPNAM
      [M:COR4]AUSNUM(nolign-1) = [F:REP]AUSNUM
      Affzo [M:COR4]REPNAM(nolign-1)
    Endif
  Endif
End

##########################################################################################################
Subprog AM_FNC(VALEUR)
Variable Decimal VALEUR

  If VALEUR <= 0 Then
    Raz [M:COR2]FNCX
  Elsif VALEUR <= len(mess(0,233,1)) Then
    [M:COR2]FNCX = mess(VALEUR,233,1)
  Else
    GMESSAGE = mess(618,177,1) - "(" + num$(VALEUR) + ")"
    mkstat = 1
    End
  Endif
End

##########################################################################################################
Subprog AM_BPRNUM(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    Read [BR1]BPR0=VALEUR
    If fstat = 0 Then
      [M:COR2]BPRLIB = [F:BR1]BPRNAM
    Endif
  Endif
  If VALEUR = "" Then
    Grizo [M:COR2]CPYBPANUM
  Else
    Actzo [M:COR2]CPYBPANUM
  Endif
End

##########################################################################################################
Subprog IB_CNTNUM
  If [M:COR2]BPRNUM = "" Then
    Raz GBOUT2
  Endif
  # FGR 08/04/2008 : X3SUIVI46645 Débranchement sur leads quand il faut
  If [M:COR0]CORTYPMEN <> 2 Then
    Raz GBOUT4
  Endif
End

##########################################################################################################
Subprog AM_CORTYPMEN(VALEUR)
Variable Integer VALEUR

  If GREP = "C" Then
    If VALEUR = 3 Then
      GMESSAGE = mess(427,177,1)
      mkstat = 1
      End
    Endif
  Endif
  Case VALEUR
    When 1
      [M:COR0]CORTYP = "AIN"
    When 2
      [M:COR0]CORTYP = "LDS"
    When 3
      [M:COR0]CORTYP = "REP"
  Endcase
End

######################################################################################
Subprog AV_CPYSAT(VALEUR)
Variable Char    VALEUR()
  If GFMT<>"" Then
    Chgfmt [M:COR2]CPYSAT With "K:"+GFMT
  Else
    Chgfmt [M:COR2]CPYSAT With "-K:1X"
  Endif
End

######################################################################################
Subprog AV_HOMSAT(VALEUR)
Variable Char    VALEUR()
  If GFMT<>"" Then
    Chgfmt [M:COR3]HOMSAT With "K:"+GFMT
  Else
    Chgfmt [M:COR3]HOMSAT With "-K:1X"
  Endif
End

