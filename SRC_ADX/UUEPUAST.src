#<AdxTL>@(#)4.0.0.0 $Revision$
################################################################################################
# UUEPUAST   Moulinette Indus.                                                                 #
# - Suppression chapitres et menus locaux non définis dans AMENLOC                             #
################################################################################################

################################################################################################
# Moulinette proprement dite
################################################################################################
Subprog MAJ_UUEPUAST(DOSSIER)
Value Char DOSSIER

  Local Integer COMPTEUR
  Local Integer WCHP
  
  Call ECR_TRACE("UUEPUAST : Process Start on : "+DOSSIER,0) From GESECRAN

  Local File =DOSSIER+".APLSTD"      [AST]
  Local File =DOSSIER+".AMENLOC"     [AML]

  Trbegin [AST]
    For [AST]CLE(1)
      If !find([F:AST]LANCHP,0,200) :  # ne pas supprimer les chapitres 0 et 200 (intitulés des menus locaux)
        WCHP = [F:AST]LANCHP
        Look [AML]MENLOC = WCHP
        If fstat
          Delete [AST] Where LANCHP=WCHP
          COMPTEUR += adxdlrec
        Endif
      Endif
    Next
  Commit

  Close Local File [AST], [AML]

  Call ECR_TRACE("UUEPUAST : "+num$(COMPTEUR)+" rows deleted",0) From GESECRAN

End

########################################################################
# Pour exécution automatique en integration dans les dossiers filles   #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI
  Call MAJ_UUEPUAST(APPLI)
End

########################################################################
# Pour exécution automatique en integration dans le dossier racine     #
########################################################################
Subprog PATCH_X3(APPLI)
Value Char APPLI
  Call MAJ_UUEPUAST(APPLI)
End

