#<AdxTL>@(#)0.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Workflow validation
#----------------------------------------------------------------------------------------#

Subprog GENE
Call OUVRE_TRACE("Validate Workflows linked to UPDFLD & AFCTFCT data model") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub VALID
End

#-------------------#
$VALID

Local Integer OK
Local File =DOSSIER+".AWRKREG" [UAWR]
For [UAWR]AWR1(1) Where find(MODELE,'UPDFLD','AFCTFCT')<>0
    Call ECR_TRACE ("Validation of assignment rule"-[F:UAWR]REGLE,0) From GESECRAN
    Call VALID([F:UAWR]REGLE,DOSSIER,1,OK) From SUBAWR
Next
Filter [UAWR]

Local File =DOSSIER+".AWRKPAR" [UAWA]
For [UAWA] Where find(MODELE,'UPDFLD','AFCTFCT')<>0
    Call ECR_TRACE ("Validation of workflow rule"-[F:UAWA]CODE,0) From GESECRAN
    Call VALID([F:UAWA]CODE,DOSSIER,1,OK) From AWRKGEN
Next

Close Local File

Return

