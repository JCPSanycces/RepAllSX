#<AdxTL>@(#)0.0.0.0 $Revision$

# Issue 105932 6.16
########################################################################################
# UTICPT81   UTI process                                                 FIN module
#            Migration From U10 to U11
#
#  The migration must take into account the changes in Account parameterization :
#  ==> New fields must be initialized :
#    1-     [F:GAC]CSLFLGBPR (partner)
#    2-     [F:GAC]CSLBPRACE (Entry partner)
#
########################################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS
#
If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif
  If [F:ADS]MODULE(1)<>2 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Update GACCOUNT table for CSLBPR updates") From LECFIC

  Call MAJ_UTICPT81(WDOSSIER)

  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

Subprog MAJ_UTICPT81(DOSSIER)
Value Char DOSSIER()

If filinfo(filpath("FIL","GACCOUNT","fde",DOSSIER),0)<=0 or func DOSVUE.ISVIEW(DOSSIER,"GACCOUNT")<>0 : End : Endif

Call ECR_TRACE("UTICPT81 : Start of process on : "+DOSSIER,0) From GESECRAN

If clalev([F:GAC]) > 0
  Close File [GAC]
Endif
Local File =DOSSIER+".GACCOUNT"  [GAC]

Call DEBTRANS From GLOCK
Trbegin [GAC]
Update [GAC] Where CSLFLGBPR < 1 With CSLFLGBPR = 1
Call ECR_TRACE("UTICPT81 / CSLFLGBPR : " + num$(adxuprec) + "[GAC] records processed", 0) From GESECRAN

Update [GAC] Where CSLBPRACE < 1 With CSLBPRACE = SAC
Call ECR_TRACE("UTICPT81 / CSLBPRACE : " + num$(adxuprec) + "[GAC] records processed", 0) From GESECRAN

Update [GAC] Where CSLFLGFLW < 1 With CSLFLGFLW = 1
Call ECR_TRACE("UTICPT81 / CSLFLGFLW : " + num$(adxuprec) + "[GAC] records processed", 0) From GESECRAN

Commit

Close Local File [GAC]
Call ECR_TRACE("UTICPT81 : End of process on : "+DOSSIER,0) From GESECRAN

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT81 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif

If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif

# Check Finance Module
If [F:ADS]MODULE(1)<>2 : End : Endif
Call MAJ_UTICPT81(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3: End : Endif
# Check Finance Module
If [F:ADS]MODULE(1)<>2 : End : Endif
Call MAJ_UTICPT81(APPLI)
End

