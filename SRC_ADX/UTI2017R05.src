##########################################################################
# UTI2017R05 UTI process for 2017R5 of X3
# ---------------------------------------------------------------------- #
#      moulinettes à passer en fin du patch de la 2017R5 - passage de R4 vers R5
#
#      correction utility to be done at the end of the patch - move from R4 to R5
#
##########################################################################
#JASMI - 2017-08-04 - X3-50913 - START
#  Infbox "only update folder by patch"
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTI2017R05 Processing") From LECFIC
  Call PATCH(nomap)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
#JASMI - 2017-08-04 - X3-50913 - END

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
# -----------------------------------------------------------------    #
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

#-------------------------------------------------------------#
# le test du dossier mère doit etre fait dans chaque uti.. pas ici
# Test of the mother folder must be done in each utixxx.. not HERE
#-------------------------------------------------------------#
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

Call EXE_UTI2017R05 (APPLI)

End

###################################################
Subprog EXE_UTI2017R05(LDOSSIER)
Value Char LDOSSIER

Call ECR_TRACE("START : UTI2017R05-Phase for folder "+LDOSSIER,0) From GESECRAN

#-------------------------------------------------------------#
# implementer ici l'appel de chaque uti necessaire
# le test du dossier mère doit etre fait dans chaque uti..
#
# implement here the call of each necessary uti
# Test of the mother folder must be done in each utixxx..
#-------------------------------------------------------------#

# Issue X3-49112 - 2017-07-20 by CCC
Call PATCH(LDOSSIER) From SUBALH1     # Requests validation
Call PATCH(LDOSSIER) From SUBALT1     # Graphical requests validation

# Issue X3-47140 - 2017-07-18 by SR : Receipt inquiries validation
If [F:ADS]MODULE(5)=2
  Call PATCH(LDOSSIER) From CNSCPRSTD
Endif

# Issue X3-38615 - 2017-09-12 by MUARN : Receipts entry transaction validation
If [F:ADS]MODULE(5)=2
  Call PATCH(LDOSSIER) From SUBPTR
Endif

#                                            # hcb x3-47481 deb
If [F:ADS]MODULE(6)=2
  Call PATCH(LDOSSIER) From CNSSIISTD
Endif
#                                            # hcb x3-47481 end

# Issue X3-38672 - 2017-07-26 by GH : Production tracking validation
If [F:ADS]MODULE(7)=2
  Call PATCH(LDOSSIER) From SUBMTL
Endif

#JASMI - 2017-08-02 - X3-50913 - START
  Call PATCH  (LDOSSIER) From UTIHRM002
#JASMI - 2017-08-02 - X3-50913 - END

#Issue X3-38254 24/08/17 by GEBIL : filter display inoperative
If [F:ADS]MODULE(7)=2
  Call PATCH(LDOSSIER) From SUBMIL
Endif

# X3FEAT-300 - 2017-08-01 by MJH : Point in time
Call PATCH(LDOSSIER) From UTIPIT

# Issue 50247 - 2017-08-29 by MAE : Stock sortage validation
If [F:ADS]MODULE(6)=2
  Call PATCH(LDOSSIER) From CNSSMQSTD
Endif
# End issue 50247

# Issue X3-51971 - LOWMTCGEN
  Call PATCH  (LDOSSIER) From UTICPT92
# End issue X3-51971 - LOWMTCGEN

Call ECR_TRACE("END : UTI2017R05-Phase for folder "+LDOSSIER,0) From GESECRAN
#----- Fin du traitement -----#
$FIN_UTI2017R05
End

