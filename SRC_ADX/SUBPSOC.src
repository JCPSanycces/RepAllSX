#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# SUBPSOC : Saleable Items Picking List                                                                  #
##########################################################################################################
$HINT_KEY
  Case currbox
    When GBOXPSO1
      HINTLIS(val(right$(GBOXPSO1,8))) = "PSPLD1"
    When Default
      Return
  Endcase
Return

##########################################################################################################
$TIROIR
  ILIS = val(right$(currbox,8))
  Gosub REMP_LISGAU From GOBJSUB
  WPICK = 2
  Gosub RAFFRAICHI
Return

##########################################################################################################
$FILGAUCHE
  If currbox = GBOXPSO1 Then
    If dim([M:PSO0]OPPNUM) > 0 Then
      Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "[F:PSPLD]OPPNUM = '" + [M:PSO0]OPPNUM + "'&([F:PSPLD]PSONUM = '" + [M:PSO0]PSONUM + "' | [F:PSPLD]PSONUM = '')", "&") From GOBJSUB
    Endif
  Elsif currbox = GBOXPSO2
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "([F:PSOH]HDOCNUM = AVOID.ACHAR)", "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, AVOID.ACHAR) From CRMUTIL150
  Elsif currbox = GBOXPSO3
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "([F:PSOH]HDOCNUM <> AVOID.ACHAR)", "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, AVOID.ACHAR) From CRMUTIL150
  Endif
Return

##########################################################################################################
$AP_FILGAUCHE
  If currbox = GBOXPSO1 Then
    WPICK = 2
    Gosub RAFFRAICHI
  Endif
Return

##########################################################################################################
$DEB_PICK
Local Integer NI, NJ, FUNCTION, NOL
Local Char    SYMBOLE2(200)

  FUNCTION = 2
Return

##########################################################################################################
$PICKE
  If REP = AVOID.ACHAR Then
    If !CLECUR or !VERROU or !ACTMOD or GCONSULT Then
      OK = 0
      Return
    Endif
  Endif
  Case currbox
    When GBOXPSO1
      Gosub SEL
  Endcase
  [M:PSO0]CHGFLG = [V]CST_AYES
Return

##########################################################################################################
$DEPICK
  Case currbox
    When GBOXPSO1
      Gosub DESEL
  Endcase
  [M:PSO0]CHGFLG = [V]CST_AYES
Return

##########################################################################################################
$FIN_PICK
  If REP = AVOID.ACHAR Then
    If !VERROU Then
      GMESSAGE = mess(10,100,1)
      GERR = 1
      OK = 0
      Return
    Elsif !CLECUR or !ACTMOD or GCONSULT Then
      GMESSAGE = mess(9,123,1)
      GERR = 1
      OK = 0
      Return
    Endif
  Endif
  Case currbox
    When GBOXPSO1
      Affzo [M:PSO2]1-99
  Endcase
Return

##########################################################################################################
$REMPBOX
  ILIS = val(right$(currbox,8))
  Gosub REMP_LISGAU From GOBJSUB
  Case currbox
    When GBOXPSO1
      Gosub FILGAUCHE
      IBOX = val(right$(GBOXPSO1,8))
  Endcase
Return

##########################################################################################################
$SEL
  Call REVISION_MANAGEMENT() From SUBPSOA
  SYMBOLE2 = "PSPLD" + [F:PSPLD]OPPNUM + [F:PSPLD]PBUCOD + [F:PSPLD]TASCOD + num$([F:PSPLD]SEQNUM)
  Lock = SYMBOLE2
  If fstat Then
    GERR = 1
    GMESSAGE = mess(10,100,1) # Change in progress on another workstation
    OK = 0
    Return
  Endif
  If [M:PSO2]NBLIG2+1 >= dim([M:PSO2]ITMREF)-1 Then
    GERR = 1
    GMESSAGE = mess(122,199,1) # Insertion not possible
    OK = 0
    Return
  Endif
  # -----------------------------
  nolign = [M:PSO2]NBLIG2
  NOL = nolign-1
  status = 0
  Filter [F:PSPLD1] Where [F:PSPLD1]OPPNUM = [F:PSPLD]OPPNUM and
&                        ([F:PSPLD1]PSONUM = [F:PSPLD]PSONUM or [F:PSPLD1]PSONUM = AVOID.ACHAR) and
&                        ([F:PSPLD1]SEQNUM = [F:PSPLD]SEQNUM and [F:PSPLD1]PBUCOD = [F:PSPLD]PBUCOD and [F:PSPLD1]TASCOD = [F:PSPLD]TASCOD)
  For [F:PSPLD1]
    [F:PSPLD] = [F:PSPLD1]
    If [M:PSO2]NBLIG2+1 >= dim([M:PSO2]ITMREF)-1 Then
      GERR = 1
      GMESSAGE = mess(122,199,1)    # Insertion not possible
      Break
    Endif
    # -----------------------------
    Insa nolign,1,[M:PSO2]NBLIG2 [M:PSO2]NBLIG2
    [M:PSO2]NBLIG2 += 1
    nolign = [M:PSO2]NBLIG2
    NOL = nolign-1
    status = 0
    # Fill selection to grid line
    [M:PSO2] = [F:PSPLD]
    [M:PSO2]UPDLIG(nolign-1) = [V]CST_AYES       # Issue X3-49776 - 2018-06-25 by FGR
    [M:PSO2]KEYCONCAT(nolign-1) = func SUBPSOA.GET_PSO2_KEYCONCAT([M:PSO2]PBUCOD(nolign-1), [M:PSO2]TASCOD(nolign-1), [M:PSO2]SEQNUM(nolign-1))       # Issue X3-49776 - 2018-06-25 by FGR
  Next
  Filter [F:PSPLD1]
  If GERR = 1 Then
    Return
  Endif
  For NI = 0 To [M:PSO2]NBLIG2-1
    If [M:PSO2]ITMREF(nolign-1) <> AVOID.ACHAR Then
      Actzo [M:PSO2]ITMDES(nolign-1)
      Actzo [M:PSO2]QTY(nolign-1)
      Actzo [M:PSO2]BASPRI(nolign-1)
    Endif
  Next
  Affzo [M:PSO2]1-99
  Raz GMODIF
  Raz GMESSAGE
Return

##########################################################################################################
$DESEL
  Call REVISION_MANAGEMENT() From SUBPSOA
  SYMBOLE2 = "PSPLD" + [F:PSPLD]OPPNUM + [F:PSPLD]PBUCOD + [F:PSPLD]TASCOD + num$([F:PSPLD]SEQNUM)
  Unlock = SYMBOLE2
  Raz NI
  Raz NJ
  OK = 0
  If [M:PSO2]NBLIG2 <> 0 Then
    While OK <> 1
      NI = find([F:PSPLD]SEQNUM,[M:PSO2]SEQNUM(NJ..[M:PSO2]NBLIG2-1))
      If !NI Then
        Break
      Endif
      If [M:PSO2]CREFLG(NJ+NI-1) = 0 and ([F:PSPLD]SEQNUM = [M:PSO2]SEQNUM(NJ+NI-1) and [F:PSPLD]PBUCOD = [M:PSO2]PBUCOD(NJ+NI-1) and [F:PSPLD]TASCOD = [M:PSO2]TASCOD(NJ+NI-1)) Then
        GMODIF = 1
        NOL    = NJ + NI - 1
        Dela NOL,1,[M:PSO2]NBLIG2-1 [M:PSO2]NBLIG2
        [M:PSO2]NBLIG2 -= 1
        Affzo [M:PSO2]1-99
        Raz GMESSAGE
        OK = 1
      Else
        NJ = NJ+NI
      Endif
    Wend
  Endif
  Raz GMODIF
Return

##########################################################################################################
$RAFFRAICHI
Local Integer NI

  If [M:PSO2]NBLIG2 <> 0 Then
    For NI = 0 To [M:PSO2]NBLIG2-1
      Read [F:PSPLD]PSPLD0=[M:PSO0]OPPNUM;[M:PSO2]PBUCOD(NI);[M:PSO2]TASCOD(NI);[M:PSO2]SEQNUM(NI)
      If WPICK = 1 Then
        Gosub DEPICK From GOBJSUB
      Elsif WPICK = 2 Then
        Gosub REPICK From GOBJSUB
      Endif
    Next NI
  Endif
Return

