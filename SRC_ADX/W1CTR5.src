#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR5 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:45"
A_USER  = "DOC"
A_STAMP = "20181109230345"
Return

$TITRES
Chgtzn [M:CTR5]ZON1 With func AFNC.PARAM("FLDCTR1","")
Chgtzn [M:CTR5]ZON2 With func AFNC.PARAM("FLDCTR2","")
Chgtzn [M:CTR5]CUM1 With mess(2,10349,1)
Chgtzn [M:CTR5]CUM19 With mess(20,10349,1)
Chgtzn [M:CTR5]CUM2 With mess(3,10349,1)
Chgtzn [M:CTR5]CUM20 With mess(21,10349,1)
Chgtzn [M:CTR5]CUM21 With mess(22,10349,1)
Chgtzn [M:CTR5]CUM3 With mess(4,10349,1)
Chgtzn [M:CTR5]CUM22 With mess(23,10349,1)
Chgtzn [M:CTR5]CUM4 With mess(5,10349,1)
Chgtzn [M:CTR5]CUM23 With mess(24,10349,1)
Chgtzn [M:CTR5]CUM5 With mess(6,10349,1)
Chgtzn [M:CTR5]CUM24 With mess(25,10349,1)
Chgtzn [M:CTR5]CUM6 With mess(7,10349,1)
Chgtzn [M:CTR5]CUM25 With mess(26,10349,1)
Chgtzn [M:CTR5]CUM7 With mess(8,10349,1)
Chgtzn [M:CTR5]CUM8 With mess(9,10349,1)
Chgtzn [M:CTR5]CUM9 With mess(10,10349,1)
Return

$CHG_FMT
Case zoncou
 When "NBRSAL"
  If [M]NBRSAL=0
   If [M:CTR5]FRMSAL(0)<>""
    Chgfmt SALVAL With [M:CTR5]FRMSAL(0)
   Else
    Chgfmt SALVAL With "-K:1X"
   Endif
   If [M:CTR5]FRMSAL(1)<>""
    Chgfmt SALVAL1 With [M:CTR5]FRMSAL(1)
   Else
    Chgfmt SALVAL1 With "-K:1X"
   Endif
   If [M:CTR5]FRMSAL(2)<>""
    Chgfmt SALVAL2 With [M:CTR5]FRMSAL(2)
   Else
    Chgfmt SALVAL2 With "-K:1X"
   Endif
   If [M:CTR5]FRMSAL(3)<>""
    Chgfmt SALRUB With [M:CTR5]FRMSAL(3)
   Else
    Chgfmt SALRUB With "-K:1X"
   Endif
   If [M:CTR5]FRMSAL(4)<>""
    Chgfmt SALRUB1 With [M:CTR5]FRMSAL(4)
   Else
    Chgfmt SALRUB1 With "-K:1X"
   Endif
   If [M:CTR5]FRMSAL(5)<>""
    Chgfmt SALRUB2 With [M:CTR5]FRMSAL(5)
   Else
    Chgfmt SALRUB2 With "-K:1X"
   Endif
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CTR5 [CTR5]
Gosub HORODAT
Local Inpbox "CTR5" From GFONCTION At A_STAMP With A_WINDPREV Mask [CTR5] As [SIM_]
Grizo [CTR5]5
Grizo [CTR5]10
Grizo [CTR5]15
Grizo [CTR5]20
Grizo [CTR5]25
Grizo [CTR5]30
Grizo [CTR5]35
Grizo [CTR5]40
Grizo [CTR5]50
Grizo [CTR5]55
Grizo [CTR5]60
Grizo [CTR5]65
Grizo [CTR5]70
Grizo [CTR5]75
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CTR5]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=85 : Y1(0)=1 : Y2(0)=3
X1(1)=1 : X2(1)=85 : Y1(1)=4 : Y2(1)=5
X1(2)=86 : X2(2)=205 : Y1(2)=1 : Y2(2)=5
X1(3)=1 : X2(3)=85 : Y1(3)=6 : Y2(3)=10
X1(4)=86 : X2(4)=205 : Y1(4)=6 : Y2(4)=10
X1(5)=1 : X2(5)=104 : Y1(5)=11 : Y2(5)=20
X1(6)=105 : X2(6)=205 : Y1(6)=11 : Y2(6)=20
X1(7)=1 : X2(7)=85 : Y1(7)=21 : Y2(7)=27
X1(8)=1 : X2(8)=104 : Y1(8)=28 : Y2(8)=40
X1(9)=1 : X2(9)=85 : Y1(9)=41 : Y2(9)=54
X1(10)=1 : X2(10)=85 : Y1(10)=55 : Y2(10)=57
X1(11)=86 : X2(11)=205 : Y1(11)=55 : Y2(11)=57
X1(12)=105 : X2(12)=205 : Y1(12)=28 : Y2(12)=40
X1(13)=86 : X2(13)=224 : Y1(13)=41 : Y2(13)=54
Return

$ON_RPTBUL
Onevent BEFORE_INPUT Call AS_RPTBUL(zc) From W1CTR5
Onevent CONTROL Call C_RPTBUL(zc) From W1CTR5
Onevent AFTER_CHANGE Gosub AMM_RPTBUL From W1CTR5
Return

Subprog AS_RPTBUL(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(11937,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action STD
Call AS_RPTBUL(VALEUR) From SUBCTR
If mkstat=2
 [M]RPTBUL(INDIC) = VALEUR
 Affzo RPTBUL(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_RPTBUL(zc) From W1CTR5
Onkey   2 Titled GBOUTS Call S_RPTBUL(zc) From W1CTR5
Onkey 144 Titled GBOUTP Call P_RPTBUL(zc) From W1CTR5
Onkey 146 Titled GBOUTA Call SA_RPTBUL(zc) From W1CTR5
Gosub _AFF
End

Subprog C_RPTBUL(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("ARP","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "RPTBUL" : GZNUM = 45790 : Endif
If !mkstat
 ## Action STD
 Call C_RPTBUL(VALEUR) From SUBCTR
 If mkstat : GERR = 1 : GZONE = "RPTBUL" : GZNUM = 45790 : Endif
Endif
Gosub _AFF
End

$AMM_RPTBUL
Call AM_RPTBUL(zc)
If !mkstat & GOBJET
 zoncou = "RPTBUL" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_RPTBUL(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZRPTBUL)")>indice
 [M]RPTBUL(indice) = VALEUR
 Affzo ZRPTBUL(indice)
Endif
Gosub _AFF
End

Subprog S_RPTBUL(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action GSELECT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GSELECT"
 PARMSK(1) = "RPT"
 PARMSK(2) = "VEPFIL"
 Call S_TAB_CHAR(VALEUR,PARMSK,"GSELECT","ASELGEN","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_RPTBUL(VALEUR)
Variable Char    VALEUR()
Call OBJET("ARP",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_RPTBUL(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ARP"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_RPTBUL(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("ARP",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZRPTBUL
Onevent BEFORE_AREA Gosub AV_ZRPTBUL From W1CTR5
Return

$AV_ZRPTBUL
If clalev([F:ARP])=0 : Local File AREPORT [ARP] : Endif
Call LECTURE("ARP",[M]RPTBUL(indice),"") From CONTOBJ
Call TEXTE([F:ARP]RPTDES,zc) From OBJDIV
Gosub _AFF
Return

