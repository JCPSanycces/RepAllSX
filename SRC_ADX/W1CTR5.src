Subprog AS_OBJRUB(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(18525,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_OBJRUB(zc) From W1CTR5
Onkey   2 Titled GBOUTS Call S_OBJRUB(zc) From W1CTR5
Onkey 144 Titled GBOUTP Call P_OBJRUB(zc) From W1CTR5
Onkey 146 Titled GBOUTA Call SA_OBJRUB(zc) From W1CTR5
Gosub _AFF
End

Subprog C_OBJRUB(VALEUR)
Variable Char    VALEUR()
## Action CONTRUB
Call CONTRUB(VALEUR) From SUBRUB
If mkstat : GERR = 1 : GZONE = "OBJRUB" : GZNUM = 46602 : Endif
If !mkstat
 ## Action CONTOBJN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "OBJRUB" : GZNUM = 46602 : Endif
Endif
Gosub _AFF
End

$AMM_OBJRUB
Call AM_OBJRUB(zc)
If !mkstat & GOBJET
 zoncou = "OBJRUB" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_OBJRUB(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZOBJRUB)")>indice
 [M]OBJRUB(indice) = VALEUR
 Affzo ZOBJRUB(indice)
Endif
Gosub _AFF
