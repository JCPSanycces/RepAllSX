#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################################################
# Traitement de gestion de la saisie des compétences       Module CRM  10 Avril 2003
#              couvertes d'un contrat de service
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "RAF"          : Gosub REFRESH
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
$REFRESH
  Call TEMPON("L") From GESECRAN
  Call LOADPBL
  Call TEMPOFF From GESECRAN
  Affzo [M:CONF]
Return

##########################################################################################################
$OUVRE
#PARAM(1) = Code contrat
#PARAM(2) = Flag modèle
#PARAM(3) = Code client
#PARAM(4) = Devise
#PARAM(5) = Flag tout le parc
#PARAM(6) = Couverture croisée identique

Local File CONTCOV [CCVW]
Global Char GSZCONFTPLEVAL

  If !clalev([F:PBL]) : Local File FAMPB [PBL] : Endif
  If val(PARAM(2)) = 2 Then
    Call TEXTE(15810, GSZCONFTPLEVAL) From OBJDIV      #Modèle de contrat
  Else
    Call TEXTE(5481, GSZCONFTPLEVAL) From OBJDIV      #Contrat
  Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If [M:CONF]DIRTYFLG Then
    ETABOU(GVALI) = 1
  Else
    ETABOU(GVALI) = 0
  Endif
  #Menu Rafraichissement
  ETABOU(GRAFF) = 1
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  [M:CONF]CONNUM = PARAM(1)
  [M:CONF]TPL = val(PARAM(2))
  [M:CONF]CONBPC = PARAM(3)
  [M:CONF]CUR = PARAM(4)
  [M:CONF]EVRMACFLG = val(PARAM(5))
  [M:CONF]CRSCOVSAM = val(PARAM(6))
  If [M:CONF]TPL = 2 Then
    [M:CONF]PBL3BPCFLG = 0
  Else
    [M:CONF]PBL3BPCFLG = 2
  Endif
  #Charge les familles de compétences couvertes
  Call LOADPBL
  Affzo [M:CONF]
  # FGR 06/06/2012 : X3SUIVI60482 (début)
  If GCONSULT = 2 Then
    Diszo [M:CONF]
  Endif
  # FGR 06/06/2012 : X3SUIVI60482 (fin)
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  Close Local File [CCVW]
  #Nettoie l'écran avant de partir.
  Raz [M:CONF]
  Kill GSZCONFTPLEVAL
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
  [M:CONF]DIRTYFLG = 1
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
$ONOK
  Gosub ONSAVE
  FIN = 0
Return

#########################################################
# Sous-programmes
#########################################################
##########################################################################################################
$ONSAVE
Local Integer ZI

  #On commence par tout supprimer
  Call DEBTRANS From GLOCK
  Trbegin [CCV]
  If [M:CONF]TPL = 2 Then
    Delete [CCV] Where [F:CCV]CONNUM = [M:CONF]CONNUM and [F:CCV]TPL = 2 and [F:CCV]RECTYP = "PBL"
  Else
    Delete [CCV] Where [F:CCV]CONNUM = [M:CONF]CONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "PBL"
  Endif
  If fstat Then
    #L'enregistrement des compétences couvertes a échoué. Transaction abandonnée
    GMESSAGE = mess(141,182,1)
    GERR = 1
    Rollback
    Return
  Else
    Commit
  Endif
  #Enregistrement des compétences
  Call DEBTRANS From GLOCK
  Trbegin [CCV]
  For ZI = 0 To [M:CONF]NBPBL-1
    If [M:CONF]PBLGRPCOV(ZI) <> "" Then
      Raz [F:CCV]
      [F:CCV]CONNUM = [M:CONF]CONNUM
      [F:CCV]TPL = [M:CONF]TPL
      [F:CCV]BPC = [M:CONF]CONBPC
      [F:CCV]RECTYP = "PBL"
      [F:CCV]SBBRECTYP = ""
      [F:CCV]RECNUM = [M:CONF]PBLGRPCOV(ZI)
      [F:CCV]CPNSRT = "DPBL"
      [F:CCV]ITMICDFLG = [M:CONF]PBLITMICD(ZI)
      [F:CCV]HEIPRC(0) = [M:CONF]PBLIHEIPRC(ZI)
      [F:CCV]MINCOV(0) = [M:CONF]PBLIMINCOV(ZI)
      [F:CCV]MAXCOV(0) = [M:CONF]PBLIMAXCOV(ZI)
      [F:CCV]LABICDFLG = [M:CONF]PBLLABICD(ZI)
      [F:CCV]HEIPRC(1) = [M:CONF]PBLLHEIPRC(ZI)
      [F:CCV]MINCOV(1) = [M:CONF]PBLLMINCOV(ZI)
      [F:CCV]MAXCOV(1) = [M:CONF]PBLLMAXCOV(ZI)
      [F:CCV]EXSICDFLG = [M:CONF]PBLEXSICD(ZI)
      [F:CCV]HEIPRC(2) = [M:CONF]PBLEHEIPRC(ZI)
      [F:CCV]MINCOV(2) = [M:CONF]PBLEMINCOV(ZI)
      [F:CCV]MAXCOV(2) = [M:CONF]PBLEMAXCOV(ZI)
      Write [CCV]
      If fstat Then
        #L'enregistrement des compétences couvertes a échoué. Transaction abandonnée
        GMESSAGE = mess(141,182,1)
        GERR = 1
        Rollback
        Break
      Endif
    Endif
  Next
  If GERR Then
    Return
  Endif
  Commit
  #Couverture croisée identique
  If [M:CONF]CRSCOVSAM = 2 Then
    Call DOCRSCOVSAM([M:CONF]CONNUM, [M:CONF]TPL, GERR)
    If GERR Then
      #L'enregistrement des couvertures croisées a échoué.
      GMESSAGE = mess(515,182,1)
    Endif
  Endif
  If GERR Then
    Return
  Endif
  [M:CONF]DIRTYFLG = 0
Return

##########################################################################################################
# Chargement du tableau des compétences couvertes
#########################################################################
Subprog LOADPBL
Local Integer I

  Raz [M:CONF]NBPBL
  Raz [M:CONF]PBLGRPCOV
  I = 0
  If [M:CONF]TPL = 2 Then
    Filter [CCV] Where [F:CCV]CONNUM = [M:CONF]CONNUM and [F:CCV]TPL = 2 and [F:CCV]RECTYP = "PBL" Order By [F:CCV]RECNUM Asc
  Else
    Filter [CCV] Where [F:CCV]CONNUM = [M:CONF]CONNUM and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "PBL" Order By [F:CCV]RECNUM Asc
  Endif
  For [CCV]
    [M:CONF]PBLGRPCOV(I) = [F:CCV]RECNUM
    If [M:CONF]PBLGRPCOV(I) = "" Then
      [M:CONF]PBLCLA(I) = ""
    Else
      Read [PBL]PBL0=[M:CONF]PBLGRPCOV(I)
      If fstat Then
        [M:CONF]PBLCLA(I) = ""
      Else
        # FGR 23/09/2009 : X3SUIVI58024
        #[M:CONF]PBLCLA(I) = [F:PBL]GRPPBLDES
        Call LECTEXTRA([M:CONF]PBLCLA(I),"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
      Endif
    Endif
    #Inclusion/Exclusion détail couverture
    #Pièces
    [M:CONF]PBLITMICD(I) = [F:CCV]ITMICDFLG
    If [M:CONF]PBLITMICD(I) = 0 Then
      [M:CONF]PBLITMICD(I) = GITMICD
      If [M:CONF]PBLITMICD(I) = 0 Then
        [M:CONF]PBLITMICD(I) = 1
      Endif
    Endif
    [M:CONF]PBLIHEIPRC(I) = [F:CCV]HEIPRC(0)
    [M:CONF]PBLIMINCOV(I) = [F:CCV]MINCOV(0)
    [M:CONF]PBLIMAXCOV(I) = [F:CCV]MAXCOV(0)
    #Main d'oeuvre
    [M:CONF]PBLLABICD(I) = [F:CCV]LABICDFLG
    If [M:CONF]PBLLABICD(I) = 0 Then
      [M:CONF]PBLLABICD(I) = GLABICD
      If [M:CONF]PBLLABICD(I) = 0 Then
        [M:CONF]PBLLABICD(I) = 1
      Endif
    Endif
    [M:CONF]PBLLHEIPRC(I) = [F:CCV]HEIPRC(1)
    [M:CONF]PBLLMINCOV(I) = [F:CCV]MINCOV(1)
    [M:CONF]PBLLMAXCOV(I) = [F:CCV]MAXCOV(1)
    #Frais de mission
    [M:CONF]PBLEXSICD(I) = [F:CCV]EXSICDFLG
    If [M:CONF]PBLEXSICD(I) = 0 Then
      [M:CONF]PBLEXSICD(I) = GEXSICD
      If [M:CONF]PBLEXSICD(I) = 0 Then
        [M:CONF]PBLEXSICD(I) = 1
      Endif
    Endif
    [M:CONF]PBLEHEIPRC(I) = [F:CCV]HEIPRC(2)
    [M:CONF]PBLEMINCOV(I) = [F:CCV]MINCOV(2)
    [M:CONF]PBLEMAXCOV(I) = [F:CCV]MAXCOV(2)
    #Champs indicateur de la présence d'un détail de couverture
    [M:CONF]MORCOVPBL(I) = ""
    If [M:CONF]PBLIHEIPRC(I) > 0 Then
      [M:CONF]MORCOVPBL(I) = "+"
    Else
      If [M:CONF]PBLITMICD(I) = 2 Then
        If [M:CONF]PBLIHEIPRC(I) = 0 Then
          [M:CONF]MORCOVPBL(I) = "+"
        Endif
      Endif
    Endif
    If [M:CONF]MORCOVPBL(I) = "" Then
      If [M:CONF]PBLIMINCOV(I) > 0 Then
        [M:CONF]MORCOVPBL(I) = "+"
      Endif
    Endif
    If [M:CONF]MORCOVPBL(I) = "" Then
      If [M:CONF]PBLIMAXCOV(I) > 0 Then
        [M:CONF]MORCOVPBL(I) = "+"
      Endif
    Endif
    If [M:CONF]MORCOVPBL(I) = "" Then
      If [M:CONF]PBLLHEIPRC(I) > 0 Then
        [M:CONF]MORCOVPBL(I) = "+"
      Else
        If [M:CONF]PBLLABICD(I) = 2 Then
          If [M:CONF]PBLLHEIPRC(I) = 0 Then
            [M:CONF]MORCOVPBL(I) = "+"
          Endif
        Endif
      Endif
    Endif
    If [M:CONF]MORCOVPBL(I) = "" Then
      If [M:CONF]PBLLMINCOV(I) > 0 Then
        [M:CONF]MORCOVPBL(I) = "+"
      Endif
    Endif
    If [M:CONF]MORCOVPBL(I) = "" Then
      If [M:CONF]PBLLMAXCOV(I) > 0 Then
        [M:CONF]MORCOVPBL(I) = "+"
      Endif
    Endif
    If [M:CONF]MORCOVPBL(I) = "" Then
      If [M:CONF]PBLEHEIPRC(I) > 0 Then
        [M:CONF]MORCOVPBL(I) = "+"
      Else
        If [M:CONF]PBLEXSICD(I) = 2 Then
          If [M:CONF]PBLEHEIPRC(I) = 0 Then
            [M:CONF]MORCOVPBL(I) = "+"
          Endif
        Endif
      Endif
    Endif
    If [M:CONF]MORCOVPBL(I) = "" Then
      If [M:CONF]PBLEMINCOV(I) > 0 Then
        [M:CONF]MORCOVPBL(I) = "+"
      Endif
    Endif
    If [M:CONF]MORCOVPBL(I) = "" Then
      If [M:CONF]PBLEMAXCOV(I) > 0 Then
        [M:CONF]MORCOVPBL(I) = "+"
      Endif
    Endif
    If [M:CONF]MORCOVPBL(I) = "" Then
      If [M:CONF]TPL = 2 Then
        Filter [CCVW] Where [F:CCVW]CONNUM = [M:CONF]CONNUM
&                       and [F:CCVW]TPL = 2
&                       and [F:CCVW]RECTYP = "AAA"
&                       and [F:CCVW]PAEKEY(0) = [M:CONF]PBLGRPCOV(I)
&                       and [F:CCVW]PAEKEY(1) = ""
&                       and [F:CCVW]PAEKEY(2) = ""
      Else
        Filter [CCVW] Where [F:CCVW]CONNUM = [M:CONF]CONNUM
&                       and [F:CCVW]TPL <> 2
&                       and [F:CCVW]RECTYP = "AAA"
&                       and [F:CCVW]PAEKEY(0) = [M:CONF]PBLGRPCOV(I)
&                       and [F:CCVW]PAEKEY(1) = ""
&                       and [F:CCVW]PAEKEY(2) = ""
      Endif
      For [CCVW]
        [M:CONF]MORCOVPBL(I) = "+"
        Break
      Next
      Filter [CCVW]
    Endif
    I += 1
  Next
  Filter [CCV]
  [M:CONF]NBPBL = I
End
##########################################################################################################
# Enregistrement de la couverture croisée
##########################################################################
Subprog DOCRSCOVSAM(SZCONNUM, ITPL, IERRINF)
Value Char SZCONNUM
Value Integer ITPL
Variable Integer IERRINF

  Local File CONTCOV [CCV2]
  Local File CONTCOV [CCV3]
  #On commence par supprimer toutes les couvertures croisées
  Trbegin [CCV]
  If ITPL = 2 Then
    Delete [CCV] Where [F:CCV]CONNUM = SZCONNUM
&                  and [F:CCV]TPL = 2
&                  and [F:CCV]RECTYP <> "PBL"
&                  and [F:CCV]PAEKEY(0) <> ""
&                  and [F:CCV]CPNSRT <> "DAAAPBL"
  Else
    Delete [CCV] Where [F:CCV]CONNUM = SZCONNUM
&                  and [F:CCV]TPL <> 2
&                  and [F:CCV]RECTYP <> "PBL"
&                  and [F:CCV]PAEKEY(0) <> ""
&                  and [F:CCV]CPNSRT <> "DAAAPBL"
  Endif
  If fstat Then
    IERRINF = 1
    Rollback
    Close Local File [CCV2]
    Close Local File [CCV3]
    End
  Else
    Commit
  Endif
  #Ensuite, on régénère toutes es couvertures croisées sur la base de couverture simple
  Trbegin [CCV]
  If ITPL = 2 Then
    Filter [CCV3] Where [F:CCV3]CONNUM = SZCONNUM and [F:CCV3]TPL = 2 and [F:CCV3]RECTYP = "PBL"
  Else
    Filter [CCV3] Where [F:CCV3]CONNUM = SZCONNUM and [F:CCV3]TPL <> 2 and [F:CCV3]RECTYP = "PBL"
  Endif
  For [CCV3]
    If ITPL = 2 Then
      #Modèle de contrat
      Filter [CCV2] Where [F:CCV2]CONNUM = SZCONNUM and [F:CCV2]TPL = 2 and [F:CCV2]RECTYP <> "PBL" and [F:CCV2]PAEKEY(0) = ""
    Else
      #Contrat
      Filter [CCV2] Where [F:CCV2]CONNUM = SZCONNUM and [F:CCV2]TPL <> 2 and [F:CCV2]RECTYP <> "PBL" and [F:CCV2]PAEKEY(0) = ""
    Endif
    For [CCV2]
      Raz [F:CCV]
      [F:CCV] = [F:CCV2]
      [F:CCV]PAEKEY(0) = [F:CCV3]RECNUM
      Write [CCV]
      If fstat Then
        IERRINF = 1
        Break
      Endif
    Next
    Filter [CCV2]
    If IERRINF Then
      Break
    Endif
  Next
  Filter [CCV3]
  If IERRINF Then
    Rollback
    Close Local File [CCV2]
    Close Local File [CCV3]
    End
  Else
    Commit
    Close Local File [CCV2]
    Close Local File [CCV3]
  Endif
End
