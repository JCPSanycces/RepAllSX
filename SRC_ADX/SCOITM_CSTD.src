#<AdxTL>@(#)0.0.0.0 $Revision$
# Class SCOITM_CSTD

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#  Case [L]CURPTH
#     When ""
#      Case [L]AEVENT
#      Endcase
#  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "BOMDES" :
      Case [L]ARULE
        When "GET"     : Gosub BOMDES_GET
      Endcase
    When "PRHADDDES" :
      Case [L]ARULE
        When "GET"     : Gosub PRHADDDES_GET
      Endcase
    When "PUUDES" :
      Case [L]ARULE
        When "GET"     : Gosub PUUDES_GET
      Endcase
    When "STUDES" :
      Case [L]ARULE
        When "GET"     : Gosub STUDES_GET
      Endcase
  Endcase
Return


#######################################################################################
$BOMDES_GET
  # Populate BOM description from ATEXTRA file (3 = sub-contract)
  Call LECTEXTRA_SYR(this, AVOID.ACHAR, this.BOMDES, "TABBOMALT", "TBODESAXX", "3", num$(this.BOMALT)) From ATEXTRA
Return

#######################################################################################
$PRHADDDES_GET
  # Populate address description from BPADDRESS class
    Local Instance BPADDRESS Using C_BPADDRESS
    BPADDRESS = NewInstance C_BPADDRESS AllocGroup null
    [L]ASTATUS = fmet BPADDRESS.AREAD(3, this.PRHFCY, this.PRHADD)    # 3 = site
    If [L]ASTATUS=[V]CST_AOK
      this.PRHADDDES = BPADDRESS.BPADES
    Endif
    FreeGroup BPADDRESS
    BPADDRESS = null
Return

#######################################################################################
$PUUDES_GET
  # Populate UOM description from TABUNIT file
  Call LECTEXTRA_SYR(this, AVOID.ACHAR, this.PUUDES, "TABUNIT", "DESSHO", this.PUU, AVOID.ACHAR) From ATEXTRA
Return

#######################################################################################
$STUDES_GET
  # Populate UOM description from TABUNIT file
  Call LECTEXTRA_SYR(this, AVOID.ACHAR, this.STUDES, "TABUNIT", "DESSHO", this.STU, AVOID.ACHAR) From ATEXTRA
Return

