#<AdxTL>@(#)4.0.0.0 $Revision$
# Second and third steps of Syracuse transition for objects : use the data model named SY_xxx for each object
# and generate : the persistent class for it, the other children classes, and the representation
#
# ==== DESCRIPTION OF THE MAIN STEPS OF THE ALGORITHM =====
# For each object :  Call ANALYZE : Next : END
#
# Subprog ANALYZE
# Analyze the main table (Gosub ANA_TBL : TABANA is the table, returns ITB=current index of table in TABLE array)
# For each linked table : Manage the link properties : Analyse the linked tables (Gosub ANA_TBL) : Next
#
# Get the main window associated to the object
# For each mask in the window
#   Analyse the mask (Gosub ANA_MSK : MASKANA is the mask, returns IMK=current index of mask in MASKS array
# Next
#
# Analyse the fields in the main table (Gosub ANA_FIELDS, TABANA is the current table and ITB the current index
# For each linked table : Add a field that references the child class : Next
#
# For each linked table : Analyse the fields (Gosub ANA_FIELDS) : Next
#
# For each mask analyzed previously : Analyse the field masks (Gosub ANA_MSKFLD) : Next
#
# Print the log and generate the classes (one per table if persistent, at least one for the main table of the object)
# Print the log and generate the main representation only
# END
#
# $ANA_TBL fills the TABLE array and the associated arrays (key definition, persistence flag)
#  Returns ITB as current index in the TABLE array.
#
# $ANA_MSK fills the MASKS array and also the block array. Manages blocks homonyms and renames them
#  Returns IMK as the current index in the MASKS array
#
# $ANA_FIELDS
#  For each field in the table
#    Fill the FIELDS array and also the associated properties.
#    If multi-valuated field: manage the REGCODE array that stores the groups, assigns FGROU array with group : Endif
#    Analyze parameters (Gosub ANA_PAR, IMZ is the current index in the FIELDS array)
#  Next
#  Manage also a pointer array on first/last field and groups of the table
#  FIRST_FIELDS(ITB) is the index of the first field of table # ITB, FIRST_GROUP(ITB) the first group
# Return
#
# $ANA_PAR : Analyzes the link parameter if they exist
#
# $ANA_MSKFLD
# For each field present in the mask defined by MASKS(IMK)
#   Fill the representation fields mapping structure : NUMFIELD(1..NB_MKFLD) is the pointer array on FIELDS
#   add the fields not yet encountered in the FIELDS array (except some cases) : manage the groups, the hierarchy...
# Next
# Return
#
# Modification done 28th of November 2012 by DOM : added dummy parameter TYPAGE for validations


  Call OUVRE_TRACE("Syracuse transition phase 2") From LECFIC
  Call GENE(nomap,"GAC","GAC",2,2,2,2,2,2)
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
End

Subprog CLOSE_FILE : # In order to manage call for several folders
  If clalev([AOB]) : Close Local File [AOB] : Endif
  If clalev([AOL]) : Close Local File [AOL] : Endif
  If clalev([AOB1]) : Close Local File [AOB1] : Endif
  If clalev([ATB]) : Close Local File [ATB] : Endif
  If clalev([ATX]) : Close Local File [ATX] : Endif
  If clalev([ATB1]) : Close Local File [ATB1] : Endif
  If clalev([ATZ]) : Close Local File [ATZ] : Endif
  If clalev([ATZ1]) : Close Local File [ATZ1]: Endif
  If clalev([ATI]) : Close Local File [ATI] : Endif
  If clalev([AMK]) : Close Local File [AMK] : Endif
  If clalev([AMK1]) : Close Local File [AMK1]: Endif
  If clalev([AMZ]) : Close Local File [AMZ] : Endif
  If clalev([AMZ1]) : Close Local File [AMZ1]: Endif
  If clalev([ATY]) : Close Local File [ATY] : Endif
  If clalev([ATY1]) : Close Local File [ATY1] : Endif
  If clalev([ACV]) : Close Local File [ACV] : Endif
  If clalev([ACT]) : Close Local File [ACT] : Endif
  If clalev([ATR]) : Close Local File [ATR] : Endif
  If clalev([AAR]) : Close Local File [AAR] : Endif
  If clalev([AMP]) : Close Local File [AMP] : Endif
  If clalev([ASU]) : Close Local File [ASU] : Endif
  If clalev([ASP]) : Close Local File [ASP] : Endif
  If clalev([AOT]) : Close Local File [AOT] : Endif
  If clalev([AWI]) : Close Local File [AWI] : Endif
  If clalev([AWM]) : Close Local File [AWM] : Endif
  If clalev([AZZ]) : Close Local File [AZZ] : Endif
  If clalev([AWK]) : Close Local File [AWK] : Endif

# Classes
  If clalev([ACLA]) : Close Local File [ACLA] : Endif
  If clalev([ACLAF]) : Close Local File [ACLAF] : Endif
  If clalev([ACLAK]) : Close Local File [ACLAK] : Endif
  If clalev([ACLAT]) : Close Local File [ACLAT] : Endif
  If clalev([ACLFP]) : Close Local File [ACLFP] : Endif
  If clalev([ACLAM]) : Close Local File [ACLAM] : Endif
  If clalev([ACLPD]) : Close Local File [ACLPD] : Endif
  If clalev([ACLAO]) : Close Local File [ACLAO] : Endif
  If clalev([ACLAC]) : Close Local File [ACLAC] : Endif

# Representations
  If clalev([ASW]) : Close Local File [ASW] : Endif
  If clalev([ASWF]) : Close Local File [ASWF] : Endif
  If clalev([ASWK]) : Close Local File [ASWK] : Endif
  If clalev([ASWM]) : Close Local File [ASWM] : Endif
  If clalev([ASWO]) : Close Local File [ASWO] : Endif
  If clalev([ASWC]) : Close Local File [ASWC] : Endif
  If clalev([ASWS]) : Close Local File [ASWS] : Endif
  If clalev([ASWB]) : Close Local File [ASWB] : Endif
  If clalev([ASWP]) : Close Local File [ASWP] : Endif
  If clalev([ASWMP]) : Close Local File [ASWMP] : Endif
  If clalev([ASWR]) : Close Local File [ASWR] : Endif
End

Subprog GENE(DOSSIER,STARTOBJ,ENDOBJ,GENECLA,SUPPCLA,GENEREP,SUPPREP,MAJTYP,MAJSUB)
Value Char DOSSIER
Value Char STARTOBJ,ENDOBJ
Value Libelle GENECLA,SUPPCLA
Value Libelle GENEREP,SUPPREP
Value Libelle MAJTYP,MAJSUB

Local Char CHAINE(255)
Local Integer OK,I,J,K
Local Char OBJDONE(5)(1..100)
Local Char OBJTODO(5)(1..100)
Local Char OBJTOADD(5)(1..100)
Local Integer NBDONE,NBTODO,FIRSTCHILD

  If !clalev([AOB2]) : Local File =DOSSIER+".AOBJET" [AOB2] : Endif

# If we are not in supervisor type folder, A* objects are not handled
  If left$(STARTOBJ,1)="A" and ( (dim(GPRODUIT)>0 and GPRODUIT<>-1) or dim(GPRODUIT)<0)
    Errbox "A starting objects cannot be handled in a not supervisor environment"
    End
  Endif

# Get the list of objects to be done
  For [AOB2] Where [AOB2]TYPGES<=2 and [AOB2]ABREV>=STARTOBJ and [AOB2]ABREV<=ENDOBJ
    NBTODO+=1 : OBJTODO(NBTODO)=[AOB2]ABREV
  Next
  FIRSTCHILD=NBTODO+1

  I=1
  While I<=NBTODO
    If find(OBJTODO(I),OBJDONE(1..NBDONE))=0
      Raz OBJTOADD
      Call ECR_TRACE("",0) From GESECRAN
      If MAJSUB=2 or I<FIRSTCHILD
        If I=FIRSTCHILD
          Call ECR_TRACE("Generation of the additional persistent children classes",0) From GESECRAN
        Endif
        Call ECR_TRACE("",0) From GESECRAN
        Call ANALYZE(DOSSIER,OBJTODO(I),GENECLA,SUPPCLA,GENEREP,SUPPREP,MAJTYP,OBJTOADD)
        NBDONE+=1 : OBJDONE(NBDONE)=OBJTODO(I)
        J=1
        While J<dim(OBJTOADD) and OBJTOADD(J)<>""
          If find(OBJTOADD(J),OBJTODO,OBJDONE(1..NBDONE))=0
            If NBTODO<dim(OBJTODO) : NBTODO+=1 : OBJTODO(NBTODO)=OBJTOADD(J) : Endif
          Endif
          J+=1
        Wend
      Endif
    Endif
    I+=1
  Wend
End

# Program analyzing an object
# Fills the following variable from data model SY_xxx :
# TABLES, ABREV, TABABREV : name of the tables found, abbreviation name+abbreviation concatenation, level
# LEVEL=link level : 0=indetermined, 1=0-1 link, 2=1-1 link, 3=0-N ink, -1=link found only on references
# CLELNK=link key if not the first and if LEVEL>=1, EXPLNK=link expression
# PERSOBJ will return a list of the objects detected as persistent classes that need to be re-analyzed in a second step

Subprog ANALYZE(DOSSIER,OBJECT,GENECLA,SUPPCLA,GENEREP,SUPPREP,MAJTYP,PERSOBJ)
Value Char DOSSIER
Value Char OBJECT
Value Libelle GENECLA,SUPPCLA
Value Libelle GENEREP,SUPPREP
Value Libelle MAJTYP
Variable Char PERSOBJ()(1..)

# Miscellaneous variables
Local Integer I, J, K, L, M, N, P, Q, ITB, IMK, IMZ, MAXT, MAXR, MAXF, MAXM, MAXB, MAXP, MAXO,OK

Local Char TEXTLEVEL(10)(1..4)
Local Integer OLDVER

OLDVER=pat(GVERSION,"1.6*")

# Constants
  MAXT=100 : MAXF=2000 : MAXR=50 : MAXM=50 : MAXB=200 : MAXP=1500 : MAXO=100
  TEXTLEVEL(1)="(0,1)" : TEXTLEVEL(2)="(1,1)" :   TEXTLEVEL(3)="(0,N)" :   TEXTLEVEL(4)="(1,N)" :

Local Integer IFDETAIL
  IFDETAIL=1

# Open the tables

# V6 dictionary tables
  If !clalev([AOB]) : Local File =DOSSIER+".AOBJET" : Endif
  If !clalev([AOL]) : Local File =DOSSIER+".AOBJLST" : Endif
  If !clalev([AOB1]) : Local File =DOSSIER+".AOBJET" [AOB1] : Endif
  If !clalev([ATB]) : Local File =DOSSIER+".ATABLE" : Endif
  If !clalev([ATX]) : Local File =DOSSIER+".ATEXTE" : Endif
  If !clalev([ATB1]) : Local File =DOSSIER+".ATABLE" [ATB1] : Endif
  If !clalev([ATZ]) : Local File =DOSSIER+".ATABZON" : Endif
  If !clalev([ATZ1]) : Local File =DOSSIER+".ATABZON" [ATZ1]: Endif
  If !clalev([ATI]) : Local File =DOSSIER+".ATABIND" : Endif
  If !clalev([AMK]) : Local File =DOSSIER+".AMSK" : Endif
  If !clalev([AMK1]) : Local File =DOSSIER+".AMSK" [AMK1]: Endif
  If !clalev([AMZ]) : Local File =DOSSIER+".AMSKZON" : Endif
  If !clalev([AMZ1]) : Local File =DOSSIER+".AMSKZON" [AMZ1]: Endif
  If !clalev([ATY]) : Local File =DOSSIER+".ATYPE" : Endif
  If !clalev([ATY1]) : Local File =DOSSIER+".ATYPE" [ATY1] : Endif
  If !clalev([ACV]) : Local File =DOSSIER+".ACTIV" : Endif
  If !clalev([ACT]) : Local File =DOSSIER+".ACTION" : Endif
  If !clalev([ATR]) : Local File =DOSSIER+".ACTPAR" : Endif
  If !clalev([AAR]) : Local File =DOSSIER+".ACTCODPAR" : Endif
  If !clalev([AMP]) : Local File =DOSSIER+".AMSKPAR" : Endif
  If !clalev([ASU]) : Local File =DOSSIER+".ASUBPROG" : Endif
  If !clalev([ASP]) : Local File =DOSSIER+".ASUBPROGD" : Endif
  If !clalev([AOT]) : Local File =DOSSIER+".AOBJTAB" : Endif
  If !clalev([AWI]) : Local File =DOSSIER+".AWINDOW" : Endif
  If !clalev([AWM]) : Local File =DOSSIER+".AWRKLNK" : Endif
  If !clalev([AZZ]) : Local File =DOSSIER+".ATEXTE" [AZZ] : Endif
  If OLDVER=0 : If !clalev([AWK]) : Local File =DOSSIER+".AWRKTAB" : Endif : Endif

# Classes
  If !clalev([ACLA]) : Local File =DOSSIER+".ACLASSE" [ACLA] : Endif
  If !clalev([ACLAF]) : Local File =DOSSIER+".ACLAFLD" [ACLAF]: Endif
  If !clalev([ACLAK]) : Local File =DOSSIER+".ACLALNK" [ACLAK]: Endif
  If !clalev([ACLAT]) : Local File =DOSSIER+".ACLAMETSTD"[ACLAT]: Endif
  If !clalev([ACLFP]) : Local File =DOSSIER+".ACLAPARFLD" [ACLFP]: Endif
  If !clalev([ACLAM]) : Local File =DOSSIER+".ACLAMET" [ACLAM]: Endif
  If !clalev([ACLPD]) : Local File =DOSSIER+".ACLAPARDEF" [ACLPD] : Endif
  If !clalev([ACLAO]) : Local File =DOSSIER+".ACLAOPT" [ACLAO]: Endif
  If !clalev([ACLAC]) : Local File =DOSSIER+".ACLACOL" [ACLAC]: Endif

# Representations
  If !clalev([ASW]) : Local File =DOSSIER+".ASHW" : Endif
  If !clalev([ASWF]) : Local File =DOSSIER+".ASHWFLD" : Endif
  If !clalev([ASWK]) : Local File =DOSSIER+".ASHWLNK" : Endif
  If !clalev([ASWM]) : Local File =DOSSIER+".ASHWMET" : Endif
  If !clalev([ASWO]) : Local File =DOSSIER+".ASHWOPT" : Endif
  If !clalev([ASWC]) : Local File =DOSSIER+".ASHWCOL" : Endif
  If !clalev([ASWS]) : Local File =DOSSIER+".ASHWSEC" : Endif
  If !clalev([ASWB]) : Local File =DOSSIER+".ASHWBLC" : Endif
  If !clalev([ASWP]) : Local File =DOSSIER+".ASHWPAR" : Endif
  If !clalev([ASWMP]) : Local File =DOSSIER+".ASHWPARMET" : Endif
  If !clalev([ASWR]) : Local File =DOSSIER+".ASHWEXPPRO" : Endif


# Buffers for analyzing
# Tables found (a table may be repeated if the abbreviation is different)
Local Integer NB_TABLES
Local Char TABLES(GLONATB)(1..MAXT), ABREV(GLONABV)(1..MAXT),TABABREV(GLONATB+GLONABV+1)(1..MAXT), FIRSTKEYS(GLONABV)(1..MAXT)
Local Char TABANA(GLONATB+GLONABV+5)
Local Char ELTCLES(20)(1..MAXT,1..16)
Local Integer NB_ELT(1..MAXT)
Local Libelle PERSISTENT(1..MAXT)
Local Char CODWIN(GLONFEN)(1..MAXT)
Local Char CODOBJ(GLONAOB)(1..MAXT)
Local Char TABPATH(80)(1..MAXT)
Local Integer TABOPT(1..MAXT)
Local Char FLDLEG(GLONAVA)(1..MAXT), FLDCPY(GLONAVA)(1..MAXT), FLDFCY(GLONAVA)(1..MAXT), FLDACS(GLONAVA)(1..MAXT)

# Link characteristics
Local Char CLELNK(GLONANX)(1..MAXT), TBLLNK(100)(1..MAXT), ORILINK(GLONATB)(1..MAXT), ORIABREV(GLONABV)(1..MAXT)
Local Char EXPLNK(100)(1..MAXT)
Local Char EXPSEL(100)(1..MAXT)
Local Integer DEPTHLNK(1..MAXT)
Local Integer LEVEL(1..MAXT)

# Fields management
Local Integer FIRST_FIELDS(1..MAXT), FIRST_FIELD, FIRST_GROUPS(1..MAXT), FIRST_GROUP

# Fields (properties)
Local Integer NB_FIELDS
Local Char FIELDS(GLONAVA)(1..MAXF)
Local Integer FORDER(1..MAXF), FINTIT(1..MAXF),FMENU(1..MAXF), FINTMSK(1..MAXF) : # Added FINTMSK for representation
Local Integer FINTITCOURT(1..MAXF) : # Added FINTITCOURT for short label
Local Decimal FLONG(1..MAXF)
Local Char FTYPE(GLONATY)(1..MAXF),FCLAS(25)(1..MAXF), FACTI(GLONACV)(1..MAXF),FGROU(80)(1..MAXF), FMOTCLE(10)(1..MAXF)
Local Libelle FTYPINT(1..MAXF)
Local Char FCONTROLE(GLONACL)(1..MAXF),FACCES(10)(1..MAXF)
Local Libelle FOBLI(1..MAXF)
Local Integer FTABL(1..MAXF) : # Pointer on the field table
Local Integer MORDER(1..MAXF) : # Order in the masks
Local Integer NBRPAR(1..MAXF) : # Number of parameters
Local Integer FIRSTPAR(1..MAXF) : # The first one

# Parameters array
Local Char CODPAR(GLONAAR)(1..MAXP)
Local Integer INTITPAR(1..MAXP)
Local Libelle TYPKEY(1..MAXP) : # for parameters stored in ACLAPARFLD : 2 if key values of persistent class, 1 if parameters of action
Local Libelle TYPINTPAR(1..MAXP) : # Internal data type for parameter (local menu 33, corresponds to [AAR]TYPPAR
Local Libelle ADRVAL(1..MAXP) : # Menu local 34 (Address/Value/Constant), corresponds to [ATR]ADRVAL
Local Char VALEUR_PAR(80)(1..MAXP)
Local Integer NB_PARAMS

# Options array
Local Char REPOPTCOD(10)(1..MAXO), REPOPTCND(50)(1..MAXO)
Local Integer REPOPTLIB(1..MAXO), REPOPTERR(1..MAXO)
Local Integer NB_REPOPT

# Screen masks characteristics (a mask will correspond to a section)
Local Integer NB_MASKS
Local Char MASKS(GLONAMK)(1..MAXM), ABRMSK(GLONABV)(1..MAXM),MSKABREV(GLONAMK+GLONABV+1)(1..MAXM), ACTMSK(GLONACV)(1..MAXM)
Local Char MASKANA(GLONATB+GLONABV+5)
Local Char SECANA(20)
Local Integer INTSEC(1..MAXM)
Local Char CODESEC(10)(1..MAXM)

# Screen blocks characteristics
Local Integer NB_BLOCKS
Local Char CODEBLK(80)(1..MAXB), GRPBLK(80)(1..MAXB), ACTBLK(GLONACV)(1..MAXB)
Local Integer BLKMSK(1..MAXB) : # Pointer on the MASKS array
Local Integer BLKRNK(1..MAXB)
Local Integer INTBLK(1..MAXB), TYPBLK(1..MAXB)

# Mask fields mapping structure
Local Char REPFIELDS(80)(1..MAXF)
Local Integer NUMFIELD(1..MAXF) : # Pointer on the FIELDS array
Local Integer NUMMSK(1..MAXF) : # Pointer on the MASKS array
Local Integer NUMBLK(1..MAXF) : # Pointer on the BLOCKS array
Local Integer NB_MKFLD : # Pointer on the last field pointer
Local Char ALIAS(80)(1..MAXF)
Local Libelle TYPEFIELD(1..MAXF) : # 1=normal, 2=displayed only, 3=invisible, 4=array indicator
Local Libelle SITIT(1..MAXF),SIDES(1..MAXF) : # If title / description are available
Local Char INTFLDEVAL(60)(1..MAXF) : # Evaluated title if any exist

# Groups (definition)
Local Integer NB_REGROUPS, NB_REGMSK
Local Char REGCODE(GLONAVA)(1..MAXR)
Local Integer REGTBL(1..MAXR) : # 0 if the group is only associated to representation fields, otherwise the index of first table
Local Char REGACTIV(GLONACV)(1..MAXR)
Local Shortint REGMINI(1..MAXR), REGMAXI(1..MAXR), REGFIL(1..MAXR), REGDIM(1..MAXR)
Local Integer REGINT(1..MAXR)
Local Char GROUPRO(GLONAVA)(1..MAXR) : # Group associated property if there is any
Local Char MASKBLK(20)(1..MAXR) : # Stores the mask name followed by a space and the rank number to avoid group collisions

# Data associated to the main type if converted
Local Char MAIN_TYPE(GLONATY), OBJLIEN_TYPE(GLONAOB), CODCLA_TYPE(GLONACLA), TRTRUL_TYPE(GLONADC)(1..30), PRGRUL_TYPE(30)(1..30),
&          ACTRUL_TYPE(GLONACV)(1..30)
Local Integer ORDRUL_TYPE(1..30),NBRRUL_TYP
Local Libelle FMTSYR_TYPE, MEDSYR_TYPE, TYPRUL_TYPE(1..30)

# Miscallaneous
Local Char CHAINE(250), CHAINE1(250)
Local Integer CRECLAS : # 1 if class has to be created
Local Integer TYPAGE : # Useless (?) info returned after class validation

# Local menu 33 to 30 codification
Local Libelle ML30(1..10)
Local Libelle ML33(1..12)
ML30(1)=7 : ML30(2)=3 : ML30(3)=4 : ML30(4)=8 : ML30(5)=1 : ML30(6)=9 : ML30(7)=10 : ML30(8)=0 : ML30(9)=11 : ML30(10)=12
ML33(1)=5 : ML33(2)=2 : ML33(3)=2 : ML33(4)=3 : ML33(5)=3 : ML33(6)=3 : ML33(7)=1  : ML33(8)=4 : ML33(9)=6  : ML33(10)=7
ML33(11)=9 : ML33(12)=10

# Read the main object record, verify it exists with the right type
  Read [AOB]ABREV=OBJECT
  If fstat<>0 or [AOB]TYPGES>2
    Call ECR_TRACE("The object"-[AOB]ABREV-"does not exist or is not a complex object",2) From GESECRAN
    End
  Elsif [AOB]TYPGES=2
    I=0
    For [AWI] Where TRN="" and OBJ=[AOB]ABREV
      If [AWI]MSKENT<>"" or [AWI]NBMSK>1
        I=1 : Break
      Else
        Read [AMK]CODMSK=[AWI]NOMMSK(0)
        If [AMK]NBBLOC>1
          I=1
          Break
        Endif
      Endif
    Next
    If I
      Call ECR_TRACE("The object"-[AOB]ABREV-"is a too complex array object",2) From GESECRAN
      End
    Endif
  Endif

# Read the main data model record
  Read [AWM]AWM0="SY_"+OBJECT
  If fstat<>0
    Call ECR_TRACE("The data model SY_"+[AOB]ABREV-"does not exist",2) From GESECRAN
    End
  Endif

# Read and analyze the data model
# Version 6 is managed only for testing purpose (this program was written on a V6 in log mode only)

  # Analyze the header table
  TABANA=[AWM]TABREF : Gosub ANA_TBL : TABPATH(ITB)=ABREV(ITB)

  # Analyze the linked tables
  If OLDVER
    For I=1 To [AWM]NBRLNK
        TABANA=[AWM]TABLNK(I-1)+string$([AWM]ABRLNK(I-1)<>""," "+[AWM]ABRLNK(I-1)) : Gosub ANA_TBL
        [L]ORILINK(ITB)=[AWM]TABORI(I-1)
        [L]ORIABREV(ITB)=[AWM]ABRORI(I-1)
        [L]EXPLNK(ITB)=[AWM]EXPLNK(I-1)
        [L]CLELNK(ITB)=[AWM]CLELNK(I-1)
        [L]LEVEL(ITB)=[AWM]TYPLNK(I-1)+(find([AWM]TYPLNK(I-1),2,3)<>0)*(5-2*[AWM]TYPLNK(I-1))
        [L]EXPSEL(ITB)=[AWM]EXPSEL(I-1)
        If (ITB=1)
          TABPATH(ITB)=ABREV(ITB)
        Else
          Read [ATB]CODFIC=ORILINK(ITB)
          I=find(ORILINK(ITB)-ORIABREV(ITB)+string$(ORIABREV(ITB)="",[ATB]ABRFIC),TABABREV(1..NB_TABLES))
          If I
            TABPATH(ITB)=TABPATH(I)+"."+ABREV(ITB)
          Else
            TABPATH(ITB)=""
          Endif
        Endif
    Next I
  Else
    For [AWK]AWK0 Where MODELE=[AWM]MODELE
        TABANA=[AWK]TABLNK+string$([AWK]ABRLNK<>""," "+[AWK]ABRLNK) : Gosub ANA_TBL
        [L]ORILINK(ITB)=[AWK]TABORI
        [L]ORIABREV(ITB)=[AWK]ABRORI
        [L]EXPLNK(ITB)=[AWK]EXPLNK
        [L]CLELNK(ITB)=[AWK]CLELNK
        [L]LEVEL(ITB)=[AWK]TYPLNK+(find([AWK]TYPLNK,2,3)<>0)*(5-2*[AWK]TYPLNK)
        [L]EXPSEL(ITB)=[AWK]EXPSEL
        If (ITB=1)
          TABPATH(ITB)=ABREV(ITB)
        Else
          Read [ATB]CODFIC=ORILINK(ITB)
          I=find(ORILINK(ITB)-ORIABREV(ITB)+string$(ORIABREV(ITB)="",[ATB]ABRFIC),TABABREV(1..NB_TABLES))
          If I
            TABPATH(ITB)=TABPATH(I)+"."+ABREV(ITB)
          Else
            TABPATH(ITB)=""
          Endif
        Endif
    Next
  Endif

# Pointer on the last table for options
  TABOPT(NB_TABLES+1)=NB_REPOPT+1

# Analyse the screens and the blocks
  I=0
  Read [AOB]ABREV=OBJECT
  For [AWI]AWI2 Where OBJ=OBJECT and TRN=""
    I=1
    Break
  Next I
  If I=0
    Call ECR_TRACE("The object"-[AOB]ABREV-"does not have a main windows suitable for generation",2) From GESECRAN
    End
  Endif

  For I=1 To [AWI]NBMSK+([AWI]MSKENT<>"")+[AOB]NBSCR
    J=I-([AWI]MSKENT<>"")
    If I=1 and [AWI]MSKENT<>""
      MASKANA=[AWI]MSKENT : SECANA="HEADER"
    Elsif I<=[AWI]NBMSK+([AWI]MSKENT<>"")
      MASKANA=[AWI]NOMMSK(I-1-([AWI]MSKENT<>""))
      If [AWI]INTMSK(J-1)<>0
        Read [AZZ]NUMERO='ENG';[AWI]INTMSK(J-1)
        If fstat=0
          SECANA=vireblc(ctrans(toupper(ctrans([AZZ]TEXTE)),"-.,;:/()!*<>$+=|£%\#'"+'"',"_"),3)
        Else
          SECANA=MASKANA
        Endif
      Else
        SECANA=MASKANA
      Endif
    Else
      MASKANA=vireblc([AOB]SCRNAM(I-1-([AWI]MSKENT<>"")-[AWI]NBMSK)-[AOB]SCRABR(I-1-([AWI]MSKENT<>"")-[AWI]NBMSK),2)
      SECANA=ctrans(MASKANA," ","_")
    Endif
    # Added June 19th : if the activity code defined on the tab array is inactive, don't analyze the mask
    If J<>0 and [AWI]ACTMSK(J-1)<>""
      Read [ACV]CODACT=[AWI]ACTMSK(J-1)
      If fstat=0 and [ACV]FLACT=2
        Gosub ANA_MSK
      Endif
    Else
      Gosub ANA_MSK
    Endif
  Next I

# Now analyze the table fields

  # Header table
  ITB=1 : TABANA=TABLES(ITB) : Gosub ANA_FIELDS : FIRST_FIELDS(1)=FIRST_FIELD : FIRST_GROUPS(1)=FIRST_GROUP

  # Add a field for every linked table (child classes)
  Gosub ADD_CHILDFIELDS

  For ITB=2 To NB_TABLES
    TABANA=TABLES(ITB)
    Gosub ANA_FIELDS
    Gosub ADD_CHILDFIELDS
    FIRST_FIELDS(ITB)=FIRST_FIELD : FIRST_GROUPS(ITB)=FIRST_GROUP
  Next ITB
  FIRST_FIELDS(NB_TABLES+1)=NB_FIELDS
  FIRST_GROUPS(NB_TABLES+1)=NB_REGROUPS
  NB_REGMSK=NB_REGROUPS

# Analyze the fields in the masks
  For IMK=1 To NB_MASKS
    Read [AMK]CODMSK=MASKS(IMK)
    Gosub ANA_MSKFLD
  Next IMK

# Additional pass : cleanup the dimensional activity codes in fields description (Sept. 6th 2012)
# This is done at the end because in an intermediate step, we need to know the value of FACTI(I)
  For I=1 To  NB_FIELDS
    If FACTI(I)<>""
      Read [ACV]CODACT=FACTI(I)
      If fstat<>0 or [ACV]TYP=2
        For J=NB_FIELDS To I Step -1
          If FACTI(J)=FACTI(I)
            FACTI(I)=""
          Endif
        Next J
      Endif
    Endif
  Next I

# Log file generation
  NOTPERSISTONLY=1 : # Becomes mandatory now (June 21th)
  adxium=GASCII
  Call ECR_TRACE("*** Object : "+OBJECT+"     --"+format$("D:DD[/]MM[/]YYYY[ ]hh[:]mm[:]ss",date$),0) From GESECRAN
  If NOTPERSISTONLY : Call ECR_TRACE("",0) From GESECRAN : Endif
  J=1
  Read [AZZ]NUMERO=GLANGUE;[AOB]LIBEL
  If NOTPERSISTONLY=1
    J=1 : Gosub PRINT_CLASS
    If sigma(2,NB_TABLES,PERSISTENT(indcum))>NB_TABLES-1
      Call ECR_TRACE("Data model for non persistent children of "+[AOB]ABREV,0) From GESECRAN
    Endif
  Endif
  For J=2 To NB_TABLES
    If PERSISTENT(J)=1
      Read [ATB]CODFIC=TABLES(J)
      Read [AZZ]NUMERO=GLANGUE;[ATB]INTITFIC
      Gosub PRINT_CLASS
    Endif
  Next J

Gosub PRINT_REPRES

  If GENECLA=2
    # Now let's perform the classes generation, only if nor persistent for the table over the first
    For ITB=1 To NB_TABLES
      If ITB=1 or PERSISTENT(ITB)=1
        Read [ACLA]ACLA0=TABLES(ITB)
        If fstat=0
          If SUPPCLA=2
            Gosub CRE_CLASSES
          Else
            Call ECR_TRACE("Class"-TABLES(ITB)-"already exists, won't be recreated",-2) From GESECRAN
          Endif
        Else
          Gosub CRE_CLASSES
        Endif
      Elsif ITB>1 : # This persistent class will be generated in a second step, update the todo list
        J=1
        While J<=dim(PERSOBJ) and PERSOBJ(J)<>CODOBJ(ITB) and PERSOBJ(J)<>"" : J+=1 : Wend
        If J<=dim(PERSOBJ) and PERSOBJ(J)=""
          PERSOBJ(J)=CODOBJ(ITB)
        Endif
      Endif
    Next ITB
  Endif

  If GENEREP=2
    # Now let's perform the representation generation
    Read [ASW]ASW0=TABLES(1)
    If fstat=0
      If SUPPREP=2
        Gosub CRE_REPRES
      Else
        Call ECR_TRACE("Representation"-TABLES(1)-"already exists, won't be recreated",-2) From GESECRAN
      Endif
    Else
      SUPPREP=1
      Gosub CRE_REPRES
    Endif
  Endif

End

# Classes creation
$CRE_CLASSES
  CRECLAS=1
  Trbegin [ACLA],[ACLAF],[ACLAK],[ACLAT],[ACLFP],[ACLAM],[ACLPD],[ACLAO],[ACLAC],[ATY]

# Preliminary suppression if needed and accepted
  If SUPPCLA=2
    Read [ACLA]ACLA0=TABLES(ITB)
    If fstat=0
      J=1
      Call OUINON("Replace the"-TABLES(ITB)-"class",J) From GESECRAN
      If J=2
        Delete [ACLA] Where CODCLA=TABLES(ITB)
        Delete [ACLAF] Where CODCLA=TABLES(ITB)
        Delete [ACLAK] Where CODCLA=TABLES(ITB)
        Delete [ACLAT] Where CODCLA=TABLES(ITB)
        Delete [ACLFP] Where CODCLA=TABLES(ITB)
        Delete [ACLAM] Where CODCLA=TABLES(ITB)
        Delete [ACLPD] Where CODCLA=TABLES(ITB)
        Delete [ACLAO] Where CODCLA=TABLES(ITB)
        Delete [ACLAC] Where CODCLA=TABLES(ITB)
      Else
        CRECLAS=0
      Endif
    Endif
  Endif

  Raz [ACLA]
  [ACLA]CODCLA=TABLES(ITB)
  Read [ATB]CODFIC=TABLES(ITB)
  [ACLA]INTCLA=[ATB]INTITFIC
  [ACLA]MODULE=[ATB]MODULE
  If PERSISTENT(ITB)=2
   [ACLA]TYPCLA=PERSISTENT(ITB)
  Else
   [ACLA]TYPCLA = 1
  Endif
  [ACLA]CODACT=[ATB]CODACT
  [ACLA]NBRTRT=1
  [ACLA]CODTRT(0)=TABLES(ITB)+"_CSTD"
  [ACLA]TYPTRT(0)=1
  [ACLA]RANTRT(0)=1000
  [ACLA]ACTTRT(0)=""
  [ACLA]TABREF=TABLES(ITB)
  [ACLA]INDREF=FIRSTKEYS(ITB)
  If PERSISTENT(ITB)=2
    [ACLA]LNKOBJ=CODOBJ(ITB)
    If CODWIN(ITB)<>""
      Read [AWI]AWI0=CODWIN(ITB)
      [ACLA]FLGCREF=[AWI]BSTD(1)
      [ACLA]FLGUREF=[AWI]BSTD(0)
      [ACLA]FLGDREF=[AWI]BSTD(2)
      ACLA_PRINT=[AWI]BSTD(12)
    Endif
    [ACLA]FLGRREF=2
# Could have been set to 2, but the scope is only Syrapedia
    [ACLA]FLGCREF=1
    [ACLA]FLGUREF=1
    [ACLA]FLGDREF=1
    ACLA_PRINT=1
    Read [AOB]ABREV=CODOBJ(ITB)
    [ACLA]FCYSTR=FLDFCY(ITB)
    [ACLA]LEGSTR=FLDLEG(ITB)
    [ACLA]CPYSTR=FLDCPY(ITB)
    [ACLA]ACCSTR=FLDACS(ITB)
    For I=0 To [AOB]NBOPT-1
      Raz [ACLAO]
      [ACLAO]CODCLA=[ACLA]CODCLA
      [ACLAO]OPTLIB=[AOB]OPTLIB(I)
      [ACLAO]OPTCOD=[AOB]OPTCOD(I)
      [ACLAO]OPTCND=[AOB]OPTCND(I)
      [ACLAO]OPTERR=[AOB]OPTERR(I)
      If CRECLAS
        Write [ACLAO]
        If fstat
          If fstat=3
            Call ECR_TRACE( "Duplicate filter code on class "+[ACLA]CODCLA-"(filter "+[ACLAO]OPTCOD+')',1) From GESECRAN
          Else
            Call ECR_TRACE( "Error while writing class filter ("+[ACLA]CODCLA-[ACLAO]OPTCOD+")"-'fstat='+num$(fstat),1) From GESECRAN
          Endif
          fstat=1
          Break
        Endif
      Endif
    Next I
    If CRECLAS=1 and fstat<>0
      Rollback
      Return
    Endif
  Else
      [ACLA]FLGCREF=1
      [ACLA]FLGUREF=1
      [ACLA]FLGDREF=1
       ACLA_PRINT=1
  Endif
  For I=FIRST_GROUPS(ITB)+1 To FIRST_GROUPS(ITB+1)
    Raz [ACLAC]
    [ACLAC]CODCLA=[ACLA]CODCLA
    [ACLAC]CODCOL=REGCODE(I)
    [ACLAC]ACTCOL=REGACTIV(I)
    # Sept 6,2012 : if PROGRP is filled, minimum value will be forced to 0
    [ACLAC]MINCOL=1+(GROUPRO(I)="")*((REGFIL(I)>=1)+(REGFIL(I)>1))
    [ACLAC]MAXCOL=REGMAXI(I)
    # Sep 6,2012 : if dimension typed activity code , max=0 in the ACLA table
    If REGACTIV(I)<>""
      Read [ACV]CODACT=REGACTIV(I)
      If fstat=0 and [ACV]TYP=2
        [ACLAC]MAXCOL=0
      Endif
    Endif
    [ACLAC]PROCOL=GROUPRO(I)
    If CRECLAS
      Write [ACLAC]
      If fstat
        If fstat=3
          Call ECR_TRACE( "Duplicate collection on class "+[ACLA]CODCLA-"(filter "+[ACLAC]CODCOL+')',1) From GESECRAN
        Else
          Call ECR_TRACE( "Error while writing class collection ("+[ACLA]CODCLA-[ACLAC]CODCOL+")"-'fstat='+num$(fstat),1) From GESECRAN
        Endif
        fstat=1
        Break
      Endif
    Endif
  Next I
  If CRECLAS=1 and fstat<>0
    Rollback
    Return
  Endif
  [ACLA]FLGSEARCH=2
  [ACLA]FLGCONSULT=1
  [ACLA]CREUSR=GUSER
  [ACLA]UPDFLG=1

# If CRECLAS=0, we won't create the class (although all the preliminary work was done...)
  If CRECLAS
    Write [ACLA]
    If fstat
      Call ECR_TRACE( "Error while writing class header for"-[ACLA]CODCLA-'fstat='+num$(fstat),1) From GESECRAN
      Rollback
      Return
    Endif
  Endif

# Lines
  J=0
  For I=FIRST_FIELDS(ITB)+1 To FIRST_FIELDS(ITB+1)
    Raz [ACLAF]
    J+=1
    [ACLAF]CODCLA=TABLES(ITB)
    [ACLAF]NUMLIG=J
    [ACLAF]FLDCLA=FIELDS(I)
    [ACLAF]NUMFLD=FORDER(I)
    [ACLAF]INTFLD=FINTIT(I)
    [ACLAF]INTSHTFLD=FINTITCOURT(I)
    K=find(I,NUMFIELD(1..NB_MKFLD))
    If K<>0 and INTFLDEVAL(K)<>""
      [ACLAF]INTEVAL=INTFLDEVAL(K)
    Endif
    [ACLAF]ACTFLD=FACTI(I)
    [ACLAF]CODTYP=FTYPE(I)
    [ACLAF]LNKCLA=FCLAS(I)
    [ACLAF]LONG=FLONG(I)
    [ACLAF]NOLIB=FMENU(I)
    [ACLAF]OBLIG=FOBLI(I)
    [ACLAF]ACS="" : # We can do better
    ##[ACLAF]MOTCLE=FMOTCLE(I): # Not fed yet, we can do better
    [ACLAF]CODCTL="" : # We can do better
    [ACLAF]TABCONT="" : # We can do better
    Read [ATY]CODTYP=FTYPE(I)
    If [ATY]OBJLIEN<>""
      Read [AOB]ABREV=[ATY]OBJLIEN
      Read [ATB]CODFIC=[AOB]NOMFIC
#     Obsolete, modified the 28th of October 2012 by Dom
#     [ACLAF]FLGDES=([ATB]INTIT<>"")
#     [ACLAF]FLGTIT=([ATB]INTITC<>"")
    Endif
#   Modified the 28th of October 2012 by Dom but for the moment supplied as a comment (dictionary not updated)
#   [ACLAF]FLACCGET=1

    [ACLAF]FLDGRP=FGROU(I)
    [ACLAF]FLDSEARCH=1+([ATY]TYPTYP=7)
    [ACLAF]CREUSR=GUSER
    If CRECLAS
      Write [ACLAF]
      If fstat
        If fstat=3
          Call ECR_TRACE( "Duplicate property name on class "+[ACLA]CODCLA-"(field "+FIELDS(I)+')',1) From GESECRAN
        Else
          Call ECR_TRACE( "Error while writing class line ("+[ACLA]CODCLA-num$(J)+")"-'fstat='+num$(fstat),1) From GESECRAN
        Endif
        fstat=1
        Break
      Endif
    Endif
  Next I
  If CRECLAS=1 and fstat<>0
    Rollback
    Return
  Endif

# Parameters
# Call ECR_TRACE("+-+-------------------------+------+------+----------------------------------------+----------+",0) From GESECRAN
# Call ECR_TRACE("! !           CODCLA        !TYPPAR!TYPKEY!                    FLDCLA              !  CODPAR  !",0) From GESECRAN
# Call ECR_TRACE("+-+-------------------------+------+------+----------------------------------------+----------+",0) From GESECRAN
  For I=FIRST_FIELDS(ITB)+1 To FIRST_FIELDS(ITB+1)
    If FIRSTPAR(I)<>0
      For J=FIRSTPAR(I) To FIRSTPAR(I)+NBRPAR(I)-1
        Raz [ACLFP]
        [ACLFP]CODCLA=TABLES(ITB)
        [ACLFP]TYPPAR=1
        [ACLFP]TYPKEY=[L]TYPKEY(J)
        [ACLFP]CODPAR=[L]CODPAR(J)
        [ACLFP]FLDCLA=FIELDS(I)
        [ACLFP]TYPINT=FTYPINT(I)
        [ACLFP]VALEUR=[L]VALEUR_PAR(J)
        [ACLFP]CREUSR=GUSER
#       Call ECR_TRACE("! !"+format$("K:25X",TABLES(ITB))+"!"+format$("N:6",1)+"!"+format$("N:6",TYPKEY(J))+"!"
#&                          +format$("K:40X",FIELDS(I))+"!"+format$("K:10X",CODPAR(J))+"!",0) From GESECRAN
        If CRECLAS
          Write [ACLFP]
          If fstat
            Call ECR_TRACE( "Error while writing parameter ("+[ACLA]CODCLA+"."+[ACLFP]FLDCLA+"."+[ACLFP]CODPAR+")"-'fstat='+num$(fstat),1) From GESECRAN
            Call ECR_TRACE( "Additional details",1) From GESECRAN
            Call ECR_TRACE("",0) From GESECRAN
            Call ECR_TRACE("+-+-------------------------+------+------+----------------------------------------+----------+",0) From GESECRAN
            Call ECR_TRACE("! !           CODCLA        !TYPPAR!TYPKEY!                    FLDCLA              !  CODPAR  !",0) From GESECRAN
            Call ECR_TRACE("+-+-------------------------+------+------+----------------------------------------+----------+",0) From GESECRAN
            For K=1 To NB_PARAMS
              L=0 : Repeat L+=1 Until K>=FIRSTPAR(L) and K<FIRSTPAR(L)+NBRPAR(L)
              M=0 : Repeat M+=1 Until M>NB_TABLES or (FIRST_FIELDS(M)<L and FIRST_FIELDS(M+1)>=L)
              Call ECR_TRACE("!"+chr$(32+10*((M=ITB)&(TYPKEY(K)=TYPKEY(J))&(FIELDS(I)=FIELDS(L))&(CODPAR(J)=CODPAR(K))))+"!"
&                           +format$("K:25X",TABLES(M))+"!"+format$("N:6",1)+"!"+format$("N:6",TYPKEY(K))+"!"
&                           +format$("K:40X",FIELDS(K))+"!"+format$("K:10X",CODPAR(K))+"!",0) From GESECRAN
            Next K
            Call ECR_TRACE("+-+-------------------------+------+------+----------------------------------------+----------+",0) From GESECRAN
            fstat=1
            Break 3
          Endif
        Endif
      Next J
    Endif
  Next I
  If CRECLAS=1 and fstat<>0
    Rollback
    Return
  Endif

# Tables
  J=0
  # The table will be present in the link array only if it is a Nth child class
  # where all the intermediate classes aren't persistent
  For I=ITB+1 To NB_TABLES
    K=(ORILINK(I)=TABLES(ITB))
    If K=0
      K=I
      Repeat
        K=find(ORILINK(K),TABLES(ITB..I-1))
        If K>1
          K+=ITB-1
          If PERSISTENT(K)=2
            K=0
          Endif
        Endif
      Until K<=1
    Endif

    If K : # And no more ORILINK(I)=TABLES(ITB) : # or find(ORILINK(I),TABLES(ITB..I-1))<>0 : # Modification May 23 2012
      Raz [ACLAK]
      J+=1
      [ACLAK]CODCLA=TABLES(ITB)
      [ACLAK]NUMLIG=J
      [ACLAK]TYPLNK=LEVEL(I)+(find(LEVEL(I),2,3)<>0)*(5-2*LEVEL(I))
      [ACLAK]TABLNK=TABLES(I)
      [ACLAK]ABRLNK=ABREV(I)
      [ACLAK]TABORI=ORILINK(I)
      [ACLAK]ABRORI=ORIABREV(I)
      [ACLAK]CLELNK=CLELNK(I)
      [ACLAK]EXPLNK=EXPLNK(I)
      [ACLAK]EXPSEL=EXPSEL(I)
      K=I
      Repeat
        Read [ATB]CODFIC=TABLES(K)
        [ACLAK]REFLNK=string$(ABREV(K)="",[ATB]ABRFIC)+ABREV(K)+string$([ACLAK]REFLNK<>"","."+[ACLAK]REFLNK)
        K=ITB-1+(ORIABREV(K)<>"")*find(ORILINK(K)-ORIABREV(K),TABABREV(ITB..NB_TABLES))
&              +(ORIABREV(K)="")*find(ORILINK(K),TABLES(ITB..NB_TABLES))
      Until K<=ITB
      [ACLAK]CLALNK=TABLES(I)
      # The following code (flag assignment) is useless because the scope is only Syrapedia
      If PERSISTENT(I)=2
        [ACLAK]FLGA=2
        If CODWIN(I)<>""
          Read [AWI]AWI0=CODWIN(I)
          [ACLAK]FLGC=[AWI]BSTD(1)
          [ACLAK]FLGU=[AWI]BSTD(0)
          [ACLAK]FLGD=[AWI]BSTD(2)
        Endif
      Endif
      [ACLAK]FLGA=1
      [ACLAK]FLGC=1
      [ACLAK]FLGR=2
      [ACLAK]FLGU=1
      [ACLAK]FLGD=1
      [ACLAK]CREUSR=GUSER
      If CRECLAS
        Write [ACLAK]
        If fstat
          Call ECR_TRACE( "Error while writing link line ("+[ACLA]CODCLA+")"-'fstat='+num$(fstat),1) From GESECRAN
          fstat=1
          Break
        Endif
      Endif
    Endif
  Next I

  If CRECLAS=1 and fstat<>0
    Rollback
    Return
  Endif

# Methods
  J=0
  For CHAINE="C","R","U","D","P"
    Raz [ACLAT]
    J+=1
    [ACLAT]CODCLA=TABLES(ITB)
    [ACLAT]NOMETSTD=J
    [ACLAT]CODMETSTD=CHAINE
    [ACLAT]ENAMETSTD=(J=1)*[ACLA]FLGCREF+(J=2)*2+(J=3)*[ACLA]FLGUREF+(J=4)*[ACLA]FLGDREF+(J=5)*ACLA_PRINT
    If CRECLAS=1
      Write [ACLAT]
      If fstat
        Call ECR_TRACE( "Error while writing methods line ("+[ACLAT]CODCLA+")"-'fstat='+num$(fstat),1) From GESECRAN
        fstat=1
        Break
      Endif
    Endif
  Next

  If CRECLAS=1 and fstat<>0
    Rollback
    Return
  Endif

# Data type if not already done : only the persistent classes will be done
  If PERSISTENT(ITB)=2 and MAJTYP=2
    For [ATY] Where FICLIEN=TABLES(ITB)
      If [ATY]CODCLA=""
        [ATY]CODCLA=TABLES(ITB)
        Rewrite [ATY]
        If fstat
          Call ECR_TRACE( "Error while rewriting data type ("+[ATY]CODTYP+")"-'fstat='+num$(fstat),1) From GESECRAN
          fstat=1
          Break
        Endif
      Endif
    Next
  Endif

  If fstat
    Rollback
  Else
    Commit
  Endif

# Now validate the class
  If CRECLAS
    Call VALIDATION(0,TABLES(ITB),nomap,1,0,GBIDI1,TYPAGE,OK) From ACLAVAL
    If OK=0
      Call ECR_TRACE( "Class validation failed",1) From GESECRAN
    Endif
  Endif
Return

$PRINT_CLASS
  Call ECR_TRACE( "Class "+TABLES(J)+" associated to : "+[AZZ]TEXTE-"("+string$(PERSISTENT(J)=1,"not ")+"persistent)",0) From GESECRAN
  Call ECR_TRACE( "  Main table="+TABLES(J)+string$(PERSISTENT(J)=2," Associated object="+CODOBJ(J)),0) From GESECRAN
  If J=1
    For I=1 To NB_TABLES
      For K=1 To NB_TABLES
        If DEPTHLNK(K)=I and LEVEL(K)<>0
          Call ECR_TRACE( "     "+ORILINK(K)+" ["+ORIABREV(K)+"] +--"+TEXTLEVEL(LEVEL(K))+"--> "+format$("K:12X",TABLES(K))+"["+ABREV(K)+"]"+CLELNK(K)+"="+EXPLNK(K),0) From GESECRAN
        Endif
      Next K
    Next I
  Endif
  Call ECR_TRACE("",0) From GESECRAN
  If IFDETAIL=0 : Return : Endif
  Call ECR_TRACE("Fields :",0) From GESECRAN
  Call ECR_TRACE("+------------+-----+------------------------------+------------+------------+----+--------+------------+----+",0) From GESECRAN
  Call ECR_TRACE("!Property    !Order!Label                         !Type        !Classe      !MenL!Activity!Group       !Mand!",0) From GESECRAN
  Call ECR_TRACE("+------------+-----+------------------------------+------------+------------+----+--------+------------+----+",0) From GESECRAN
  For I=FIRST_FIELDS(J)+1 To FIRST_FIELDS(J+1)
    Read [AZZ]NUMERO=GLANGUE;FINTIT(I)
    Call ECR_TRACE("!"+format$("K:12X",FIELDS(I))+"!"+format$("N:5#",FORDER(I))+"!"+format$("K:30X",[AZZ]TEXTE)
&        +"!"+format$("K:12X",FTYPE(I)-string$(FLONG(I)<>0,num$(FLONG(I))))+"!"+format$("K:12X",FCLAS(I))+"!"+format$("K:4X",string$(FMENU(I)<>0,format$("N:4#",FMENU(I))))
&        +"!"+format$("K:8X",FACTI(I))+"!"+format$("K:12X",FGROU(I))+"!"+format$("LA1:4X",FOBLI(I))+"!",0) From GESECRAN
  Next I
  Call ECR_TRACE("+------------+-----+------------------------------+------------+------------+----+--------+------------+----+",0) From GESECRAN

  Call ECR_TRACE("",0) From GESECRAN
  If FLDLEG(J)<>"" :  Call ECR_TRACE("Legislation Field : "+FLDLEG(J),0) From GESECRAN : Endif
  If FLDCPY(J)<>"" :  Call ECR_TRACE("Company Field : "+FLDCPY(J),0) From GESECRAN : Endif
  If FLDFCY(J)<>"" :  Call ECR_TRACE("Site Field : "+FLDFCY(J),0) From GESECRAN : Endif
  If FLDACS(J)<>"" :  Call ECR_TRACE("Access code Field : "+FLDACS(J),0) From GESECRAN : Endif

  K=0

  For I=FIRST_FIELDS(J)+1 To FIRST_FIELDS(J+1)
    If FIRSTPAR(I)<>0 & TYPKEY(FIRSTPAR(I))=1
      If K=0
        Call ECR_TRACE("Parameters for action linked to fields for table"-TABLES(J),0) From GESECRAN
        Call ECR_TRACE("+------------+----------------------------------------------------------------------------------------------+",0) From GESECRAN
        Call ECR_TRACE("!  Field     !    Code    !        Label           !    Type   !   Mode   !          Value                  !",0) From GESECRAN
        Call ECR_TRACE("+------------+------------+------------------------+-----------+----------+---------------------------------!",0) From GESECRAN
      Endif
      For K=FIRSTPAR(I) To FIRSTPAR(I)+NBRPAR(I)-1
        Read [AZZ]NUMERO=GLANGUE;INTITPAR(K)
        Call ECR_TRACE("!"+format$("K:12X",FIELDS(I))+"!"+format$("K:12X",CODPAR(K))+"!"+format$("K:24X",string$(fstat=0,[AZZ]TEXTE))+"!"+
&                      format$("LA33:11X",TYPINTPAR(K))+"!"+format$("LA34:10X",ADRVAL(K))+"!"+format$("K:33X",VALEUR_PAR(K))+"!",0) From GESECRAN
      Next K
      Call ECR_TRACE("+------------+------------+------------------------+-----------+----------+---------------------------------!",0) From GESECRAN
    Endif
  Next I

  Call ECR_TRACE("",0) From GESECRAN
  K=0
  For I=FIRST_FIELDS(J)+1 To FIRST_FIELDS(J+1)
    If FIRSTPAR(I)<>0 & TYPKEY(FIRSTPAR(I))=2
      If K=0
        Call ECR_TRACE("Parameters for key linked to fields",0) From GESECRAN
        Call ECR_TRACE("+------------+----------------------------------------------------------------------------------------------+",0) From GESECRAN
        Call ECR_TRACE("!  Field     !    Code    !        Label           !         Value                                          !",0) From GESECRAN
        Call ECR_TRACE("+------------+------------+------------------------+--------------------------------------------------------!",0) From GESECRAN
      Endif
      For K=FIRSTPAR(I) To FIRSTPAR(I)+NBRPAR(I)-1
        Read [AZZ]NUMERO=GLANGUE;INTITPAR(K)
        Call ECR_TRACE("!"+format$("K:12X",FIELDS(I))+"!"+format$("K:12X",CODPAR(K))+"!"+format$("K:24X",string$(fstat=0,[AZZ]TEXTE))+"!"+
&                      format$("K:56X",VALEUR_PAR(K))+"!",0) From GESECRAN
      Next K
      Call ECR_TRACE("+------------+------------+------------------------+--------------------------------------------------------!",0) From GESECRAN
    Endif
  Next I

  Call ECR_TRACE("",0) From GESECRAN
  Call ECR_TRACE("Groups :",0) From GESECRAN
  Call ECR_TRACE("+------------+--------------------+--------+--------+--------+----------------+----------------!",0) From GESECRAN
  Call ECR_TRACE("!Group       ! Description        !Activity!Dim mini!Dim maxi! Numbering start!Group property  !",0) From GESECRAN
  Call ECR_TRACE("+------------+--------------------+--------+--------+--------+----------------+----------------!",0) From GESECRAN
  For I=FIRST_GROUPS(J)+1 To FIRST_GROUPS(J+1)
    Read [AZZ]NUMERO=GLANGUE;REGINT(I) : If fstat : Raz [AZZ] : Endif
    Call ECR_TRACE("!"+format$("K:12X",REGCODE(I))+"!"+format$("K:20X",[AZZ]TEXTE)+"!"+format$("K:8X",REGACTIV(I))+"!"
&        +format$("K:8X",string$(REGFIL(I)<>0,format$("N:8#",REGFIL(I))))+"!"
&        +format$("K:8X",string$(REGMAXI(I)<>0,format$("N:8#",REGMAXI(I))))+"!"+format$("LA7984:16X",REGDIM(I))+"!"
&        +format$("K:16X",GROUPRO(I))+"!",0) From GESECRAN
  Next I
  Call ECR_TRACE("+------------+--------------------+--------+--------+--------+----------------+----------------+",0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN

  If PERSISTENT(J)=2
    If TABOPT(J) & TABOPT(J)<TABOPT(J+1)
      Call ECR_TRACE("+----------+--------------------+----------------------------------------+----------------------------+",0) From GESECRAN
      Call ECR_TRACE("!  Code    !        Label       !               Condition                !           Error message    !",0) From GESECRAN
      Call ECR_TRACE("+----------+--------------------+----------------------------------------+----------------------------+",0) From GESECRAN
      For I=TABOPT(J) To TABOPT(J+1)-1
        Read [AZZ]NUMERO=GLANGUE;REPOPTLIB(I)
        CHAINE=string$(fstat=0,[AZZ]TEXTE)
        Read [AZZ]NUMERO=GLANGUE;REPOPTERR(I)
        Call ECR_TRACE("!"+format$("K:10X",REPOPTCOD(I))+"!"+format$("K:20X",CHAINE)+"!"+format$("K:30X",REPOPTCND(I))+"!"
&                         +format$("K:28X",string$(fstat=0,[AZZ]TEXTE))+"!",0) From GESECRAN
      Next I
      Call ECR_TRACE("+----------+--------------------+----------------------------------------+----------------------------+",0) From GESECRAN
    Else
      Call ECR_TRACE("No filtering options found",0) From GESECRAN
      Call ECR_TRACE("",0) From GESECRAN
    Endif
  Endif

  If PERSISTENT(J)=2
    For [ATY] Where FICLIEN=TABLES(J)
      If [ATY]CODCLA=""
        Call ECR_TRACE( "Data type"-[ATY]CODTYP+string$(MAJTYP=1," could be")+string$(MAJTYP=2," has been")-"updated with class"-TABLES(J),0) From GESECRAN
      Endif
    Next
  Endif


Return

# Representation creation
$CRE_REPRES

  Trbegin [ASW],[ASWF],[ASWK],[ASWM],[ASWO],[ASWC],[ASWS],[ASWB],[ASWP],[ASWMP],[ASWR]

# Preliminary suppression if needed
  If SUPPREP=2
    Read [ASW]ASW0=TABLES(1)
    If fstat=0
      J=1
      Call OUINON("Replace the"-TABLES(1)-"representation",J) From GESECRAN
      If J=2
        Delete [ASW] Where CODREP=TABLES(1)
        Delete [ASWF] Where CODREP=TABLES(1)
        Delete [ASWK] Where CODREP=TABLES(1)
        Delete [ASWM] Where CODREP=TABLES(1)
        Delete [ASWO] Where CODREP=TABLES(1)
        Delete [ASWC] Where CODREP=TABLES(1)
        Delete [ASWS] Where CODREP=TABLES(1)
        Delete [ASWB] Where CODREP=TABLES(1)
        Delete [ASWP] Where CODREP=TABLES(1)
        Delete [ASWMP] Where CODREP=TABLES(1)
        Delete [ASWR] Where CODREP=TABLES(1)
      Endif
    Endif
  Endif

# Header
  Raz [ASW]
  Read [ATB]CODFIC=TABLES(1)
  Read [AOB]ABREV=OBJECT
  [ASW]CODREP = TABLES(1)
  [ASW]ABRCLA = ABREV(1)
  [ASW]INTREP = [ATB]INTITFIC
  [ASW]CODACT = [AOB]CODACT
  [ASW]MODULE = [AOB]MODULE
  [ASW]TYPREP = 1 : # Main
  [ASW]DEFREP = 2 : # Yes
  [ASW]TYPMSKREP = 1 : # Desktop
  [ASW]CODCLA = TABLES(1)
  [ASW]FONCTION = "GES"+OBJECT
  [ASW]NBRTRT = 1
  [ASW]CODTRT(0) = TABLES(1)+"_RSTD"
  [ASW]TYPTRT(0) = 1 : # Standard
  [ASW]ACTTRT(0) = ""
  [ASW]RANTRT(0) = 1000
  [ASW]NBRFAC = 5
  For I=1 To [ASW]NBRFAC : [ASW]CODFAC(I-1) = I : Next I
  [ASW]ENAFAC(0) = 2 : [ASW]ENAFAC(1) = 1 : [ASW]ENAFAC(2) = 2 : [ASW]ENAFAC(3) = 2 : [ASW]ENAFAC(4)=1

  # The scope is only Syrapedia, behaviors have been disabled except printing
  [ASW]NBRCOM = 4
  For I=1 To [ASW]NBRCOM : [ASW]CODCOM(I-1) = I : Next I
  [ASW]ENACOM(0) = 1 :[ASW]ENACOM(1) = 1 :[ASW]ENACOM(3) = 1 :[ASW]ENACOM(4) = 1

  [ASW]CREUSR = GUSER

  Write [ASW]
  If fstat
    Call ECR_TRACE( "Error while writing representation header for"-[ASW]CODREP-'fstat='+num$(fstat),1) From GESECRAN
    Rollback
    Return
  Endif

  #Options
  # Only the options associated to the main class are used
  If TABOPT(1) & TABOPT(1)<TABOPT(2)
    For I=TABOPT(1) To TABOPT(2)-1
      Raz [ASWO]
      [ASWO]=[ASW]
      [ASWO]OPTCOD = REPOPTCOD(I)
      [ASWO]CREUSR = GUSER
      Write [ASWO]
      If fstat
        Call ECR_TRACE( "Error while writing representation option for"-[ASW]CODREP-REPOPTCOD(I)-'fstat='+num$(fstat),1) From GESECRAN
        Rollback
        Return
      Endif
    Next I
  Endif

  If fstat
    Rollback
    Return
  Endif

# Collections

  For I=1 To NB_REGMSK-NB_REGROUPS
    Raz [ASWC]
    [ASWC]=[ASW]
    [ASWC]CODCOL = [L]REGCODE(NB_REGROUPS+I)
    [ASWC]ACTCOL = [L]REGACTIV(NB_REGROUPS+I)
    # Sept 6, 2012 : minimum set to 0 if a group property exists
    [ASWC]MINCOL = 1+([L]GROUPRO(NB_REGROUPS+1)="")*((REGMINI(NB_REGROUPS+I)>=1)+(REGMINI(NB_REGROUPS+I)>1))
    [ASWC]MAXCOL = [L]REGMAXI(NB_REGROUPS+I)
    [ASWC]PROCOL=[L]GROUPRO(NB_REGROUPS+I)
    [ASWC]CREUSR = GUSER
    Write [ASWC]
    If fstat
      Call ECR_TRACE( "Error while writing representation collection for"-[ASW]CODREP-[L]REGCODE(NB_REGROUPS+I)-'fstat='+num$(fstat),1) From GESECRAN
      Rollback
      Return
    Endif
  Next I

  If fstat
    Rollback
    Return
  Endif

# Properties lines
  J=0
  For I=1 To NB_MKFLD
    Raz [ASWF]
    If pat(REPFIELDS(I),"*.*")=0
      J+=1
      [ASWF]CODREP = [ASW]CODREP
      [ASWF]NUMLIG = J
      [ASWF]INTEVAL=INTFLDEVAL(I)
      [ASWF]CODFLD = ALIAS(I)
      [ASWF]NUMFLD = J*10
      If FINTMSK(NUMFIELD(I))=0
        [ASWF]INTFLD = FINTIT(NUMFIELD(I))
      Else
        [ASWF]INTFLD = FINTMSK(NUMFIELD(I))
      Endif
      [ASWF]INTSHTFLD=FINTITCOURT(NUMFIELD(I))
      [ASWF]ACTFLD = FACTI(NUMFIELD(I))
      [ASWF]CODTYP = FTYPE(NUMFIELD(I))
      [ASWF]LONG = FLONG(NUMFIELD(I))
      [ASWF]OBLIG = FOBLI(NUMFIELD(I))
      [ASWF]NOLIB = FMENU(NUMFIELD(I))
      [ASWF]ACS = ""
      ##[ASWF]MOTCLE = FMOTCLE(NUMFIELD(I))
      [ASWF]CODCTL = ""
      [ASWF]TABCONT = ""
      [ASWF]FLDGRP = FGROU(NUMFIELD(I))
      If [ASWF]FLDGRP<>""
        K=find([ASWF]FLDGRP,REGCODE(1..NB_REGMSK))
        If REGTBL(K)
          If LEVEL(REGTBL(K))>=3 : # link 01-N
            [ASWF]FLDGRP=TABPATH(REGTBL(K))
          Else
            [ASWF]FLDGRP=TABPATH(REGTBL(K))+"."+[ASWF]FLDGRP
          Endif
        Endif
      Endif
#     Obsolete, modified the 28th of October 2012 by Dom
#     [ASWF]FLGTIT = SITIT(NUMFIELD(I))
#     [ASWF]FLGDES = SIDES(NUMFIELD(I))
      [ASWF]CREUSR = GUSER
      Write [ASWF]
      If fstat
        Call ECR_TRACE( "Error while writing representation fields for"-[ASW]CODREP-"line"-num$(J)-'fstat='+num$(fstat),1) From GESECRAN
        Break
      Endif
      # Update the representation parameter if there are some
      If NBRPAR(NUMFIELD(I))
        For K=FIRSTPAR(NUMFIELD(I)) To FIRSTPAR(NUMFIELD(I))+NBRPAR(NUMFIELD(I))-1
          [ASWP]CODREP = [ASW]CODREP
          [ASWP]TYPPAR = 1
          [ASWP]AFFLNK = 1
          [ASWP]CODFLD = ALIAS(I)
          [ASWP]CODPAR = [L]CODPAR(K)
          [ASWP]TYPKEY = TYPKEY(K)
          [ASWP]VALEUR = VALEUR_PAR(K)
          [ASWP]TYPINT = FTYPINT(NUMFIELD(I))
          [ASWP]CREUSR = GUSER
          Write [ASWP]
          If fstat
            Call ECR_TRACE( "Error while writing representation fields properties for"-[ASW]CODREP-ALIAS(I)-"property"-CODPAR(K)-'fstat='+num$(fstat),1) From GESECRAN
            Break
          Endif
        Next K
      Endif
    Endif
  Next I

  If fstat
    Rollback
    Return
  Endif

# Nothing is written in this table, maybe later ???
# [ASWK]CODREP =
# [ASWK]CODLNK =
# [ASWK]NUMLNK =
# [ASWK]INTLNK =
# [ASWK]FACLNK =
# [ASWK]TYPLNK =
# [ASWK]TARLNK =
# [ASWK]CODOPELNK =
# [ASWK]CODMETLNK =
# [ASWK]CODFNCLNK =
# [ASWK]CLALNK =
# [ASWK]OPELNK =
# [ASWK]REPLNK =
# [ASWK]ACVLNK =
# [ASWK]AFFLNK =
## [ASWK]BCKLNK =
# [ASWK]DETLNK =
# [ASWK]QRYLNK =
# [ASWK]EDILNK =
# [ASWK]LOKLNK =
# [ASWK]SUMLNK =
# [ASWK]CREUSR =

# Nothing is written in this table, maybe later ???
# [ASWM]CODREP =
# [ASWM]NOMET =
# [ASWM]CODMET =
# [ASWM]DONMET =
# [ASWM]INTMET =
# [ASWM]ACTMET =
# [ASWM]HLPMET =
# [ASWM]CREUSR =

# Organization in blocks and sections
  For I=1 To NB_BLOCKS
    Raz [ASWB]
    [ASWB]=[ASW]
    [ASWB]CODBLC = CODEBLK(I)
    [ASWB]SECBLC = CODESEC(BLKMSK(I))
    [ASWB]INTBLC = INTBLK(I)
    [ASWB]NIVBLC = I*10
    [ASWB]ACTBLC = ACTBLK(I)
    [ASWB]CREUSR = GUSER
    Write [ASWB]
    If fstat
      Call ECR_TRACE( "Error while writing representation block for"-[ASW]CODREP-CODEBLK(I)-'fstat='+num$(fstat),1) From GESECRAN
      Rollback
      Return
    Endif
  Next I
  If fstat
    Rollback
    Return
  Endif

  For I=1 To NB_MASKS
    Raz [ASWS]
    [ASWS]=[ASW]
    [ASWS]CODSEC = CODESEC(I)
    [ASWS]INTSEC = [L]INTSEC(I)
    [ASWS]NIVSEC = I*10
    [ASWS]ACTSEC = ACTMSK(I)
    Write [ASWS]
    If fstat
      Call ECR_TRACE( "Error while writing representation section for"-[ASW]CODREP-CODESEC(I)-'fstat='+num$(fstat),1) From GESECRAN
      Rollback
      Return
    Endif
  Next I
  If fstat
    Rollback
    Return
  Endif


# Nothing is written in this table, there is probably something to do later
# [ASWMP]CODREP =
# [ASWMP]CODMET =
# [ASWMP]CODPARMET =
# [ASWMP]NOPARMET =
# [ASWMP]TYPPARMET =
# [ASWMP]INTPARMET =
# [ASWMP]CLAPARMET =
# [ASWMP]MODPARMET =
# [ASWMP]DIMPARMET =
# [ASWMP]CREUSR =

# Exposed properties
  Read [AOB]ABREV=OBJECT
  Read [AOL]AOL0=OBJECT
  J=0
  For I=1 To NB_MKFLD
    # Evolution : the invisible fields are no more exposed, although they remain in the representation
    If TYPEFIELD(I)<>3
      J+=1
      Raz [ASWR]
      [ASWR]CODREP = [ASW]CODREP
      [ASWR]ALIAS = ALIAS(I)
      [ASWR]NUMPRO = J
  #   [ASWR]TAGPRO =
      [ASWR]BLCPRO = CODEBLK(NUMBLK(I))
      [ASWR]CODPRO = REPFIELDS(I)
  #   [ASWR]LNKPRO =
      [ASWR]ORDPRO = MORDER(NUMFIELD(I))-10*(J-I) : # Additional hack to avoid a jump in 10 interval numbering
      If FINTMSK(NUMFIELD(I))=0
        [ASWR]INTPRO = FINTIT(NUMFIELD(I))
      Else
        [ASWR]INTPRO = FINTMSK(NUMFIELD(I))
      Endif
      [ASWR]INTSHTPRO = FINTITCOURT(I)
      [ASWR]INTEVALPRO = INTFLDEVAL(I)
      # For table objects, all the fields are present in queries
      [ASWR]QRYPRO = 1+(find(FIELDS(NUMFIELD(I)),[AOL]SELZON(0..[AOL]NBSEL))<>0 or [AOB]TYPGES=2)
      [ASWR]DETPRO = 2
      [ASWR]EDIPRO = 1 : # +(TYPEFIELD(I)=1) For the moment, Syrapedia mode only
      [ASWR]LOKPRO = [ASWR]QRYPRO
      [ASWR]SUMPRO = 1
      [ASWR]TYPAFFPRO = [ASWR]EDIPRO
      #
      #[ASWR]STAINIPRO = 1+(TYPEFIELD(I)>2)
      [ASWR]STAQRYPRO = 1+(TYPEFIELD(I)>2)
      [ASWR]STAEDIPRO = 1+(TYPEFIELD(I)>2)
      [ASWR]STADETPRO = 1+(TYPEFIELD(I)>2)
      [ASWR]STALOKPRO = 1+(TYPEFIELD(I)>2)
      [ASWR]STASUMPRO = 2
      #
      [ASWR]PARENTPRO = 1
      [ASWR]PARFILPRO = 1
      [ASWR]CREUSR = GUSER
      Write [ASWR]
      If fstat
        If [ASWR]ALIAS<>[ASWR]CODPRO
          [ASWR]CODPRO=[ASWR]ALIAS
          Write [ASWR]
        Endif
        If fstat
          Call ECR_TRACE("Error while writing representation exposed properties for"-[ASW]CODREP-"line"-num$(I)-'fstat='+num$(fstat),1) From GESECRAN
          Call ECR_TRACE("   Field name="+[ASWR]ALIAS,1) From GESECRAN
          fstat=0 : # Continue
        Endif
      Endif
    Endif
  Next I

  If fstat
    Rollback
    Return
  Endif


# Nothing is written in this table, that will probably disappear
# [AFJ]CODTAG =
# [AFJ]INTTAG =
# [AFJ]CREUSR =

  Commit

# Now validate the representation
  Call VALIDATION(0,TABLES(1),nomap,1,0,GBIDI1,TYPAGE,OK) From ASHWVAL
  If OK=0
    Call ECR_TRACE( "Representation validation failed",1) From GESECRAN
  Endif

Return

$PRINT_REPRES
  Call ECR_TRACE( "Representation "+OBJECT,0) From GESECRAN
  Call ECR_TRACE('',0) From GESECRAN
  Call ECR_TRACE("First tab (General)",0) From GESECRAN
  Call ECR_TRACE("Module="+format$("LA14:20X",[AOB]MODULE),0) From GESECRAN
  Call ECR_TRACE("Main table="+TABLES(1),0) From GESECRAN
  Call ECR_TRACE("Instance="+[AOB]ABREV,0) From GESECRAN
  Call ECR_TRACE("Type="+format$("LA7967:10X",1)+"(field TYPREV)",0) From GESECRAN
  Call ECR_TRACE("Type="+format$("LA7963:10X",1)+"(field TYPMSKREP)",0) From GESECRAN
  Call ECR_TRACE("Active facets=Detail, Query, Lookup (field ENAFAC(0,2,3))",0) From GESECRAN
  Call ECR_TRACE("Active behavior=List (field ENACOM(1))",0) From GESECRAN
  If NB_REGROUPS<NB_REGMSK
    Call ECR_TRACE("Groups :",0) From GESECRAN
    Call ECR_TRACE("+--------------+--------------------+-----------------+------------+------------+----------------!----------------!",0) From GESECRAN
    Call ECR_TRACE("!Group (CODGRP)! Description        !Activity (ACTGRP)!Min (MINGRP)!Max (MAXGRP)! Group numbering! Group property !",0) From GESECRAN
    Call ECR_TRACE("+--------------+--------------------+-----------------+-------------------------+----------------!----------------!",0) From GESECRAN
    For I=NB_REGROUPS+1 To NB_REGMSK
    Read [AZZ]NUMERO=GLANGUE;REGINT(I) : If fstat : Raz [AZZ] : Endif
      Call ECR_TRACE("!"+format$("K:14X",REGCODE(I))+"!"+format$("K:20X",[AZZ]TEXTE)+"!"+format$("K:17X",REGACTIV(I))
&                   +"!"+format$("LA7966:12X",1+(GROUPRO(I)="")*((REGMINI(I)>1)+(REGMINI(I)=REGMAXI(I))))+"!"
&                   +format$("K:12X",num$(REGMAXI(I))+string$(REGMAXI(I)>10,"==>0"))+"!"+format$("LA7984:16X",REGDIM(I))+"!"
&                   +format$("K:16X",GROUPRO(I))+"!",0) From GESECRAN
    Next I
    Call ECR_TRACE("+--------------+--------------------+-----------------+-------------------------+----------------+----------------+",0) From GESECRAN
  Else
    Call ECR_TRACE("No group found",0) From GESECRAN
  Endif
  Call ECR_TRACE('',0) From GESECRAN
  Call ECR_TRACE("Files (CODTRT(0))="+TABLES(1)+"_RSTD"+" Type(TYPTRT(0))=Standard(1), Rank(RANTRT(0))=1000, Act code(ACTTRT(0))= ''",0) From GESECRAN
  Call ECR_TRACE("No parameter (???)",0) From GESECRAN

  J=0
  For I=1 To NB_MKFLD
    If pat(REPFIELDS(I),"*.*")=0
      J+=1
      If J=1
        Call ECR_TRACE("Properties :",0) From GESECRAN
        Call ECR_TRACE("+------------+----+------------------------------+------------+----+-----+------------+----+---------+-----+",0) From GESECRAN
        Call ECR_TRACE("!Property    !Ordr!Label                         !Type        !MenL!Act. !Group       !Mand!Display  !Ti/De!",0) From GESECRAN
        Call ECR_TRACE("+------------+----+------------------------------+------------+----+-----+------------+----+---------+-----+",0) From GESECRAN
      Endif
      If INTFLDEVAL(I)<>""
        [AZZ]TEXTE="** "+INTFLDEVAL(I)
      Else
        If FINTMSK(NUMFIELD(I))=0
          Read [AZZ]NUMERO=GLANGUE;FINTIT(NUMFIELD(I))
        Else
          Read [AZZ]NUMERO=GLANGUE;FINTMSK(NUMFIELD(I))
        Endif
      Endif
      CHAINE=FGROU(NUMFIELD(I))
      If CHAINE<>""
        K=find(CHAINE,REGCODE(1..NB_REGMSK))
        If REGTBL(K)
          If LEVEL(REGTBL(K))>=3 : # link 01-N
            CHAINE=TABPATH(REGTBL(K))
          Else
            CHAINE=TABPATH(REGTBL(K))+"."+CHAINE
          Endif
        Endif
      Endif
      Call ECR_TRACE("!"+format$("K:12X",ALIAS(I))+"!"+format$("N:4#",J*10)+"!"+format$("K:30X",[AZZ]TEXTE)
&                   +"!"+format$("K:12X",FTYPE(NUMFIELD(I))-string$(FLONG(NUMFIELD(I))<>0,num$(FLONG(NUMFIELD(I)))))
&                   +"!"+format$("K:4X",string$(FMENU(NUMFIELD(I))<>0,format$("N:4#",FMENU(NUMFIELD(I)))))
&                   +"!"+format$("K:5X",FACTI(NUMFIELD(I)))+"!"+format$("K:12X",CHAINE)+"!"+format$("LA1:4X",FOBLI(NUMFIELD(I)))
&                   +"!"+format$("K:9X",mid$("Input    Display  InvisibleTechnich.Array    ",9*TYPEFIELD(I)-8,9))
&                   +"!"+format$("K:2X",mid$("NoYe",2*SITIT(NUMFIELD(I))-1,2))
&                   +"!"+format$("K:2X",mid$("NoYe",2*SIDES(NUMFIELD(I))-1,2))+"!",0) From GESECRAN
    Endif
  Next I
  If J
    Call ECR_TRACE("+------------+----+------------------------------+------------+----+-----+------------+----+---------+-----+",0) From GESECRAN
  Endif

  Call ECR_TRACE("",0) From GESECRAN
  Call ECR_TRACE("No methods and parameters",0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN
  Read [AOB]ABREV=OBJECT
  Read [AOL]AOL0=OBJECT
  Call ECR_TRACE("Exposed properties :",0) From GESECRAN
  Call ECR_TRACE("+------------+-----------------------------+------------+----+---------------------+-----+------+---------+",0) From GESECRAN
  Call ECR_TRACE("!Alias       !Property                     !Block       !Ordr!Label                !Query!Detail!Display  !",0) From GESECRAN
  Call ECR_TRACE("+------------+-----------------------------+------------+----+---------------------+-----+------+---------+",0) From GESECRAN
  For I=1 To NB_MKFLD
    If INTFLDEVAL(I)<>""
      [AZZ]TEXTE="** "+INTFLDEVAL(I)
    Else
      If FINTMSK(NUMFIELD(I))=0
        Read [AZZ]NUMERO=GLANGUE;FINTIT(NUMFIELD(I))
      Else
        Read [AZZ]NUMERO=GLANGUE;FINTMSK(NUMFIELD(I))
      Endif
    Endif
    K=1+(find(FIELDS(NUMFIELD(I)),[AOL]SELZON(0..[AOL]NBSEL))<>0)
    Call ECR_TRACE("!"+format$("K:12X",ALIAS(I)) +"!" +format$("K:29X",REPFIELDS(I)) + "!" + format$("K:12X",CODEBLK(NUMBLK(I)))
&                 +"!"+format$("N:4#",MORDER(NUMFIELD(I)))+"!"+format$("K:21X",[AZZ]TEXTE)
&                 +"!"+format$("K:5X",string$(K=2,"Yes")+string$(K=1,"No"))+"!"+format$("K:6X","Yes")
&                 +"!"+format$("K:9X",mid$("Input    Display  InvisibleTechnichlArray    ",9*TYPEFIELD(I)-8,9))+"!",0)
&                   From GESECRAN
  Next I
  Call ECR_TRACE("+------------+-----------------------------+------------+----+---------------------+-----+------+---------+",0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN
  Call ECR_TRACE("Organization : Sections",0) From GESECRAN
  Call ECR_TRACE("+-------------+-------------+-------------------------------+----------------------+",0) From GESECRAN
  Call ECR_TRACE("!Code (CODSEC)!Activity code!Description (INTSEC)           !Display order (NIVSEC)!",0) From GESECRAN
  Call ECR_TRACE("+-------------+-------------+-------------------------------+----------------------+",0) From GESECRAN
  For I=1 To NB_MASKS
    Read [AZZ]NUMERO=GLANGUE;INTSEC(I)
    Call ECR_TRACE("!"+format$("K:13X",CODESEC(I))+"!"+format$("K:13X",ACTMSK(I))+"!"+format$("K:31X",[AZZ]TEXTE)+"!"+format$("N:22",I*10)+"!",0) From GESECRAN
  Next I
  Call ECR_TRACE("+-------------+-------------+-------------------------------+----------------------+",0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN

  Call ECR_TRACE("",0) From GESECRAN
  Call ECR_TRACE("Organization : Blocks",0) From GESECRAN
  Call ECR_TRACE("+-------------+------------------------------+--------------------+-------------+----------------------+",0) From GESECRAN
  Call ECR_TRACE("!Code (CODBLC)!Description (INTBLC)          !Section (SECBLC)    !Activity code!Display order (NIVBLC)!",0) From GESECRAN
  Call ECR_TRACE("+-------------+------------------------------+--------------------+-------------+----------------------+",0) From GESECRAN
  For I=1 To NB_BLOCKS
    Read [AZZ]NUMERO=GLANGUE;INTBLK(I)
    Call ECR_TRACE("!"+format$("K:13X",CODEBLK(I))+"!"+format$("K:30X",[AZZ]TEXTE)+"!"
&                 +format$("K:20X",CODESEC(BLKMSK(I)))+"!"+format$("K:13X",ACTBLK(I))+"!"+format$("N:22",I*10)+"!",0) From GESECRAN
  Next I
  Call ECR_TRACE("+-------------+------------------------------+--------------------+-------------+----------------------+",0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN

Return

# Mask storage
# Returns IMK as mask number
$ANA_MSK
  CHAINE1=vireblc(MASKANA,3)
  If CHAINE1<>MASKANA
    CHAINE=right$(MASKANA,len(CHAINE1)+2)
    MASKANA=CHAINE1
  Else CHAINE=""
  Endif

  If NB_MASKS>0
    If CHAINE=""
      IMK=find(MASKANA,MASKS(1..NB_MASKS))
    Else
      IMK=find(MASKANA-CHAINE,MSKABREV(1..NB_MASKS))
    Endif
  Else
    IMK=0
  Endif

  If IMK
    Return
  Else
    Read [AMK]CODMSK=MASKANA
    If fstat
      Return
    Endif
    # Added June 19th : if a mask is associated to an activity code, it must be enabled
    If [AMK]CODACT<>""
      Read [ACV]CODACT=[AMK]CODACT
      If [ACV]FLACT=1
        Return
      Endif
    Endif
    NB_MASKS+=1 : IMK=NB_MASKS
  Endif

# Fill the masks arrays
  MASKS(IMK)=MASKANA : ABRMSK(IMK)=string$(CHAINE<>"",CHAINE)+string$(CHAINE="",[AMK]ABRMSK)
  MSKABREV(IMK)=MASKS(IMK)-ABRMSK(IMK) : INTSEC(IMK)=[AMK]INTMSK : ACTMSK(IMK)=[AMK]CODACT
  If find(SECANA,CODESEC(1..IMK-1))
    CODESEC(IMK)="TAB_"+num$(IMK)
  Else
    CODESEC(IMK)=SECANA
  Endif

# Fill the blocks arrays
  For J=1 To [AMK]NBBLOC
    NB_BLOCKS+=1
    BLKMSK(NB_BLOCKS)=IMK
    BLKRNK(NB_BLOCKS)=J
    TYPBLK(NB_BLOCKS)=[AMK]TYPBLOC(J-1)
    INTBLK(NB_BLOCKS)=[AMK]TITBLOC(J-1)
    ACTBLK(NB_BLOCKS)=[AMK]ACTBLOC(J-1)
    # Added June 19th : an activity code carrying a dimension must not be associated to a block
    If [AMK]ACTBLOC(J-1)<>""
      Read [ACV]CODACT=[AMK]ACTBLOC(J-1)
      If fstat<>0 or [ACV]TYP=2
        ACTBLK(NB_BLOCKS)=""
      Endif
    Endif
    GRPBLK(NB_BLOCKS)=""
    If [AMK]TITBLOC(J-1)<>0
      Read [AZZ]NUMERO='ENG';[AMK]TITBLOC(J-1)
      # Limit the size of the block to 8 : done the 25th of February
      If fstat=0
        CODEBLK(NB_BLOCKS)=left$(vireblc(ctrans(toupper(ctrans([AZZ]TEXTE)),"-.,;:/()!*<>$+=|£%\#'"+'"',"_"),3),8)
      Else
        CODEBLK(NB_BLOCKS)="B"+num$(IMK)+"_"+num$(J)
      Endif
    Else
      CODEBLK(NB_BLOCKS)="B"+num$(IMK)+"_"+num$(J)
    Endif
    L=0
    M=find(CODEBLK(NB_BLOCKS),CODEBLK(1..NB_BLOCKS-1))
    While M
      L+=1
      M=find(CODEBLK(NB_BLOCKS)+"_"+num$(L),CODEBLK(M+1..NB_BLOCKS-1))
    Wend
    CODEBLK(NB_BLOCKS)+=string$(L<>0,"_"+num$(L))
  Next J
Return

# Add the fields linked to children classes (not only in the main table, but in table #ITB)
# But avoid to do it if the child field points on the first table (infinite nesting) Added July 30,2012
$ADD_CHILDFIELDS
  For I=ITB+1 To NB_TABLES
    If ORILINK(I)=TABLES(ITB) and TABLES(I)<>TABLES(1)
      NB_FIELDS+=1
      FORDER(NB_FIELDS)=(NB_FIELDS-1)*10
      Read [ATB]CODFIC=TABLES(I)
      FINTIT(NB_FIELDS)=[ATB]INTITFIC
      FINTITCOURT(NB_FIELDS)=[ATB]INTITFIC
      FIELDS(NB_FIELDS)=TABPATH(I)
      J=instr(1,FIELDS(NB_FIELDS),".")
      While J
        FIELDS(NB_FIELDS)=right$(FIELDS(NB_FIELDS),J+1)
        J=instr(1,FIELDS(NB_FIELDS),".")
      Wend
      FTYPE(NB_FIELDS)=""
      FTYPINT(NB_FIELDS)=0
      FCLAS(NB_FIELDS)=TABLES(I)
      FMENU(NB_FIELDS)=0
      FLONG(NB_FIELDS)=0
      FACTI(NB_FIELDS)="" : # Can we get it ???
      FOBLI(NB_FIELDS)=1 : # To redefine
      FTABL(NB_FIELDS)=0 : # The structures are not linked to the table (only the normal fields)

      FGROU(NB_FIELDS)=ABREV(I) : # I hope no field with abbreviation name is in the child class
      If find(FGROU(NB_FIELDS),REGCODE(1..NB_REGROUPS))=0 : # Should be always the case
        NB_REGROUPS+=1
        REGCODE(NB_REGROUPS)=FGROU(NB_FIELDS)
        REGACTIV(NB_REGROUPS)=FACTI(NB_FIELDS)
        REGMINI(NB_REGROUPS)=0
        REGFIL(NB_REGROUPS)=0
        REGTBL(NB_REGROUPS)=I
        REGMAXI(NB_REGROUPS)=0 : # To be filled at mask analysis
        REGDIM(NB_REGROUPS)=1 : # Children class numbering starts with 1
        # The name of the group will be the name of the table
#       If REGCODE(NB_REGROUPS)="NAM" : Dbgaff : Endif
        REGINT(NB_REGROUPS)=[ATB]INTITFIC
      Endif
    Endif
  Next I
Return

# Mask fields analysis
# Uses IMK as mask number
# Fill the fields indirection table and add the new fields
# [AMK] is online
# Returns IMZ as field number
# July 27, 2012 : added a filter on "fillers" screens fields
$ANA_MSKFLD
  For [AMZ]CODZON Where CODMSK=[AMK]CODMSK and CODTYP<>"W"
    NB_MKFLD+=1
    # Check if the field exists and is not already mapped
    IMZ=0
    Repeat
      I=find([AMZ]CODZON,FIELDS(IMZ+1..NB_FIELDS))
      IMZ+=I
      If find(IMZ,NUMFIELD(1..NB_MKFLD-1))=0
        Break
      Elsif I=0
        IMZ=0
      Endif
    Until I=0

    # Additional hack
    # If the field is not known, but if it starts with Z, if it corresponds to another field of the class
    # without the Z, then drop it (in order to manage these dummy fields for translatable texts)
    # but set the parameter associated to it to the origin field
    If IMZ=0 and left$([AMZ]CODZON,1)="Z"
      J=find(right$([AMZ]CODZON,2),FIELDS(1..FIRST_FIELDS(NB_TABLES+1)))
      If J and [AMZ]CODTYP="ATT" and FTYPE(J)="ATX"
        NB_MKFLD-=1
        # Get the name of the first subprogram used by ATX type control (normally PARAMATEXTE.OBJDIV)
        # (just to get the parameter names for the log)
        Read [ATY]CODTYP="ATX"
        For K=[L]FIRSTPAR(J) To [L]FIRSTPAR(J)+3
          Case [L]CODPAR(K)
            When "LNG"
              Read [AMP]CODPAR=1;[AMK]ABRMSK;[AMZ]CODZON;"LNGMESS"
              If fstat=0
                [L]VALEUR_PAR(K)=[AMP]VALPAR
              Endif
            When "OBJTYP"
              Read [AMP]CODPAR=1;[AMK]ABRMSK;[AMZ]CODZON;[L]CODPAR(K)
              If fstat=0
                [L]VALEUR_PAR(K)='"'+[AMP]VALPAR+'"'
              Endif
            When "OBJNOM"
              Read [AMP]CODPAR=1;[AMK]ABRMSK;[AMZ]CODZON;[L]CODPAR(K)
              If fstat=0
                If pat([AMP]VALPAR,"[?*]?*")
                  [L]VALEUR_PAR(K)='"'+right$([AMP]VALPAR,instr(1,[AMP]VALPAR,"]")+1)+'"'
                Else
                  [L]VALEUR_PAR(K)='"'+[AMP]VALPAR+'"'
                Endif
              Endif
            When "ZONE"
              Read [AMP]CODPAR=1;[AMK]ABRMSK;[AMZ]CODZON;"NOMESS"
              If fstat=0
                If pat([AMP]VALPAR,"[?*]?*")
                  [L]VALEUR_PAR(K)='"'+right$([AMP]VALPAR,instr(1,[AMP]VALPAR,"]")+1)+'"'
                Else
                  [L]VALEUR_PAR(K)='"'=[AMP]VALPAR+'"'
                Endif
              Endif
          Endcase
          # Read the parameter name for the log
          # For [ASP] Where SUBPRG=[ATY]PRGRUL(0) and PRG=[ATY]TRTRUL(0) and PARAM=[L]CODPAR(K)
          #   [L]INTITPAR(K)=[ASP]INTITPAR
          #   Break
          # Next
        Next K
        Goto NEXT_FIELD
      Endif

    # Additional hack again
    # Drop also the fields named "W" without any corresponding field in classes
    Elsif IMZ=0 and [AMZ]CODZON="W"
      NB_MKFLD-=1
      Goto NEXT_FIELD

    # Also if the field is "ABS" typed and not known as a table field, drop it
    Elsif IMZ=0 and [AMZ]CODTYP="ABS"
      NB_MKFLD-=1
      Goto NEXT_FIELD
    Endif

    If [AMZ]CODZON="TYP"
      IMZ=IMZ
    Endif

    # If the field is not yet known or repeated, it will be added as a representation field
    If IMZ=0
      NB_FIELDS+=1
      IMZ=NB_FIELDS
      FIELDS(IMZ)=[AMZ]CODZON
      FINTIT(IMZ)=[AMZ]INTIT
      FINTITCOURT(IMZ)=[AMZ]INTIT
      FTYPE(IMZ)=[AMZ]CODTYP
      Read [ATY]CODTYP=[AMZ]CODTYP
      If fstat=0
        FTYPINT(IMZ)=ML33([ATY]TYPTYP)
      Else
        FTYPINT(IMZ)=0
      Endif
      FMENU(IMZ)=[AMZ]NOLIB
      FLONG(IMZ)=[AMZ]LONG
      FACTI(IMZ)=[AMZ]CODACT
      FOBLI(IMZ)=[AMZ]OBLIG

      # Define the group if there is one
      If [AMK]TYPBLOC([AMZ]NUMBLOC-1)=1 and [AOB]TYPGES=1 : # If array objet, manage it as a single block
        # Search if another field in the same block has already a group associated with
        J=0
        For [AMZ1]CODZON Where NUMBLOC=[AMZ]NUMBLOC and [AMZ1]CODMSK=[AMK]CODMSK: # not sure for additional condition :  and CODTYP<>"ABS"
          # J is set to a not null value only if the field exists only once
          J=find([AMZ1]CODZON,FIELDS(1..NB_FIELDS))
          # Manage approximately the fields present two times (a nightmare...)
          K=find([AMZ1]CODZON,FIELDS(J+1..NB_FIELDS))
          If K and NUMMSK(J)<>0 and NUMMSK(J)<>IMK : # If the mask number is already known and does not fit the first choice, use the second
            J+=K
          Endif
          # If the field is associated to a 01-N link, use the abbreviation table
          If J
            # K gives the table name if K<=NB_TABLES
            K=sigma(1,NB_TABLES+1,J>FIRST_FIELDS(indcum))
            If K>=1 and K<=NB_TABLES : # Field present in a table
              # If the group is empty but the table is a 1-N linked table, force the group to the abbreviation name of the table
              If FGROU(IMZ)="" and LEVEL(K)>=3
                FGROU(IMZ)=ABREV(K)
              Endif
            Endif
          Endif
        # Use MASKBLK to avoid fields collisions (NUMLIG for instance)
          If J and FGROU(J)<>""
            K=find(FGROU(J),REGCODE(1..NB_REGMSK))
            If K=0 or MASKBLK(K)="" or MASKBLK(K)=[AMK]CODMSK-num$([AMZ]NUMBLOC)
              FGROU(IMZ)=FGROU(J)
            Endif
            Break FGROU(IMZ)<>""
          Endif
        Next

        # If the group is not known, or not declared as a group for the representation, add it
        J=find(FGROU(IMZ),REGCODE(1..NB_REGMSK))
        If J=0 : # Replaces the following condition : If J<=NB_REGROUPS and find(FGROU(IMZ),REGCODE(NB_REGROUPS+1..NB_REGMSK))=0
          # Create a new group named with the name of the property (this is a property that is not in the class)
          NB_REGMSK+=1
          REGCODE(NB_REGMSK)="L_"+[AMZ]CODZON : # and no more string$(J=0,[AMZ]CODZON)+string$(J<>0,FGROU(IMZ))
          FGROU(IMZ)=REGCODE(NB_REGMSK)
          REGTBL(NB_REGMSK)=0 : # Group not associated to a table
          REGACTIV(NB_REGMSK)=[AMZ]CODACT
          Read [ACV]CODACT=[AMZ]CODACT
          If [ACV]TYP=2
            REGMINI(NB_REGMSK)=[ACV]DIME
            REGFIL(NB_REGMSK)=[ACV]DIMFIL
            REGMAXI(NB_REGMSK)=[ACV]DIMMAX
          Else
            REGMINI(NB_REGMSK)=[AMZ]DIME
            REGFIL(NB_REGMSK)=[AMZ]DIME
            REGMAXI(NB_REGMSK)=[AMZ]DIME
          Endif
          REGDIM(NB_REGMSK)=2 : # For multi-valuated fields, numbering starts with 0
#         If REGCODE(NB_REGMSK)="NAM" : Dbgaff : Endif
          REGINT(NB_REGMSK)=[AMK]TITBLOC([AMZ]NUMBLOC-1) : # The title used is the block title
          If REGINT(NB_REGMSK)=0
            REGINT(NB_REGMSK)=[AMZ]INTIT
          Endif
          J=NB_REGMSK
        Endif
        If MASKBLK(J)="" : MASKBLK(J)=[AMK]CODMSK-num$([AMZ]NUMBLOC) : Endif
      Endif
    Else
      # if the field is already known Find the hierarchy for the field
      For J=1 To NB_TABLES
        If IMZ<=FIRST_FIELDS(J+1)
          Break
        Endif
      Next J

      # Modification Nov 30, 2012: collection management
      If IMZ<=FIRST_FIELDS(NB_TABLES+1)
        REPFIELDS(NB_MKFLD)=TABPATH(J)+"."+string$(FGROU(IMZ)<>"",FGROU(IMZ)+".")+[AMZ]CODZON
      Else
        REPFIELDS(NB_MKFLD)=TABPATH(J)+"."+[AMZ]CODZON
      Endif

      # If a label exist in the screen, use it instead of the class label
      FINTMSK(IMZ)=[AMZ]INTIT
    Endif

   # Fill the long / short description flag according to data type
    Read [ATY]CODTYP=FTYPE(IMZ)
    If [ATY]OBJLIEN<>""
      Read [AOB1]ABREV=[ATY]OBJLIEN
      If fstat=0
        Read [ATB1]CODFIC=[AOB1]NOMFIC
      Else
        Raz [ATB1]
      Endif
    Elsif dim([ATY]CODCLA)>0 and [ATY]CODCLA<>""
      Read [ACLA]ACLA0=[ATY]CODCLA
      If [ACLA]TYPCLA=2 and [ACLA]TABREF<>""
        Read [ATB1]CODFIC=[ACLA]TABREF
      Else
        Raz [ATB1]
      Endif
    Elsif [ATY]OBJLIEN<>""
      Read [AOB1]ABREV=[ATY]OBJLIEN
      If fstat=0
        Read [ATB1]CODFIC=[AOB1]NOMFIC
        If fstat=0
          Raz [ATB1]
        Endif
      Else
        Raz [ATB1]
      Endif
    Else
      Raz[ATB1]
    Endif

    SITIT(IMZ)=1+([ATB1]INTITC<>"")
    SIDES(IMZ)=1+([ATB1]INTIT<>"")

    FCONTROLE(IMZ)=[AMZ]CODCTL
    FACCES(IMZ)=[AMZ]CODACC
    NUMFIELD(NB_MKFLD)=IMZ
    TYPEFIELD(NB_MKFLD)=[AMZ]SAIAFF
    INTFLDEVAL(NB_MKFLD)=[AMZ]INTEVAL
    If [AMZ]CODTYP="ABS" : TYPEFIELD(NB_MKFLD)=5 : Endif
    NUMMSK(NB_MKFLD)=IMK
    For J=1 To NB_BLOCKS
      Break BLKMSK(J)=IMK and BLKRNK(J)=[AMZ]NUMBLOC
    Next J
    NUMBLK(NB_MKFLD)=J
    MORDER(IMZ)=10*NB_MKFLD
    REPFIELDS(NB_MKFLD)+=string$(REPFIELDS(NB_MKFLD)="",[AMZ]CODZON)

    # To set the alias, verify if other fields with the same name exist
    J=sigma(1,NB_MKFLD-1,FIELDS(NUMFIELD(indcum))=[AMZ]CODZON or pat(FIELDS(NUMFIELD(indcum)),"*."+[AMZ]CODZON)<>0)
    ALIAS(NB_MKFLD)=[AMZ]CODZON+string$(J<>0,"_"+num$(J))

    # Analyze the parameters only if the field has been added
    If IMZ>FIRST_FIELDS(NB_TABLES+1)
      Gosub ANA_PAR1
    Endif

#   If the fieldname is the same, display a warning
#   If J<>0 and sigma(1,NB_MKFLD-1,FIELDS(NUMFIELD(indcum))=[AMZ]CODZON)>0
#     Call ECR_TRACE("The field"-[AMZ]CODZON-"has been renamed to"-ALIAS(NB_MKFLD),-2) From GESECRAN
#     FIELDS(IMZ)=ALIAS(NB_MKFLD) : # It must be a new field (the previous one has already been mapped)
#   Endif

$NEXT_FIELD
# Assignment of group property : must be done only if the field exists in a table
    If IMZ<>0 and IMZ<=FIRST_FIELDS(NB_TABLES+1) and [AMK]TYPBLOC([AMZ]NUMBLOC-1)=1 and FGROU(IMZ)<>""
      J=find(FGROU(IMZ),REGCODE(1..NB_REGMSK))
      If J<>0 and GROUPRO(J)=""
        For [AMZ1]CODZON Where CODMSK=[AMZ]CODMSK and NUMBLOC=[AMZ]NUMBLOC and CODTYP="ABS"
          If find([AMZ1]CODZON,FIELDS(1..FIRST_FIELDS(NB_TABLES+1)))
            GROUPRO(J)=[AMZ1]CODZON
          Endif
          Break
        Next
      Endif
    Endif

  Next

Return

# Table analysis
# Returns ITB as table number
$ANA_TBL
  CHAINE1=vireblc(TABANA,3)
  If CHAINE1<>TABANA
    CHAINE=right$(TABANA,len(CHAINE1)+2)
    TABANA=CHAINE1
  Else CHAINE=""
  Endif

  If NB_TABLES>0
    If CHAINE=""
      ITB=find(TABANA,TABLES(1..NB_TABLES))
    Else
      ITB=find(TABANA-CHAINE,TABABREV(1..NB_TABLES))
    Endif
  Else
    ITB=0
  Endif

  If ITB
    Return
  Else
    NB_TABLES+=1 : ITB=NB_TABLES
  Endif

  Read [ATB1]CODFIC=TABANA
  TABLES(ITB)=TABANA : ABREV(ITB)=string$(CHAINE<>"",CHAINE)+string$(CHAINE="",[ATB1]ABRFIC)
  TABABREV(ITB)=TABLES(ITB)-ABREV(ITB)

  PERSISTENT(ITB)=1

# First check if an object named "abbv" exists (otherwise, AUTILIS will be associated to AIA object for instance)
  Read [AOB1]ABREV=[ATB1]ABRFIC
  If fstat or [AOB1]TYPGES=4 or [AOB1]NOMFIC<>TABANA
    Filter [AOB1] Where NOMFIC=TABANA and TYPGES<>4
    For [AOB1]
      PERSISTENT(ITB)=2
      CODOBJ(ITB)=[AOB1]ABREV
      Break
    Next
    Filter [AOB1]
  Else
    PERSISTENT(ITB)=2
    CODOBJ(ITB)=[AOB1]ABREV
  Endif

# Even if an object has not be found, the main table is persistent (should not be the case !!!)
If PERSISTENT(ITB)=1 and ITB=1
  Raz [AOB1]
  PERSISTENT(ITB)=2
Endif

# If table is persistent, manage site and access code field, and search the main window if any exist
  If PERSISTENT(ITB)=2
    If [AOB1]ZSITE<>""
      FLDFCY(ITB)=[AOB1]ZSITE
    Endif
    If [AOB1]ZACC<>""
      FLDACS(ITB)=[AOB1]ZACC
    Endif
    Filter [AWI] Where OBJ=[AOB1]ABREV and TRN=""
    For [AWI]
        CODWIN(ITB)=[AWI]WIN
        Break
    Next
    Filter [AWI]
  Else
    CODWIN(ITB)=""
  Endif

# First, get the key elements (whithout dimensions)
  Read [ATI]NUMLIG>=TABANA;1;""
  If [ATI]NUMLIG=1 : # & [ATI]HOMONYM=1  # ACCES for instance is not a table with an unique key
    FIRSTKEYS(ITB)=[ATI]CODIND
    CHAINE=vireblc(vireblc(ctrans([ATI]DESCRIPT,"+-","  "),5),2)
    NB_ELT(ITB)=1
    While vireblc(CHAINE,3)<>CHAINE
        ELTCLES(ITB,NB_ELT(ITB))=vireblc(CHAINE,3)
        CHAINE=right$(CHAINE,len(ELTCLES(ITB,NB_ELT(ITB)))+2)
        NB_ELT(ITB)+=1
    Wend
    ELTCLES(ITB,NB_ELT(ITB))=CHAINE
    For P=1 To NB_ELT(ITB)
      Q=instr(1,ELTCLES(ITB,P),"(") : If Q : ELTCLES(ITB,P)=left$(ELTCLES(ITB,P),Q-1) : Endif
    Next P
  Endif

# Search also the options if the table is persistent
  TABOPT(ITB)=NB_REPOPT
  For P=1 To [AOB1]NBOPT
    NB_REPOPT+=1
    REPOPTCOD(NB_REPOPT)=[AOB1]OPTCOD(P-1)
    REPOPTLIB(NB_REPOPT)=[AOB1]OPTLIB(P-1)
    REPOPTERR(NB_REPOPT)=[AOB1]OPTERR(P-1)
    REPOPTCND(NB_REPOPT)=[AOB1]OPTCND(P-1)
  Next P
Return

$ANA_FIELDS
# Get the characteristics of the fields for the table TABANA (rank ITB)
  FIRST_FIELD=NB_FIELDS
  FIRST_GROUP=NB_REGROUPS
  For [ATZ]NUMLIG Where CODFIC=TABANA
    NB_FIELDS+=1
    IMZ=NB_FIELDS
    FIELDS(IMZ)=[ATZ]CODZONE
    FORDER(IMZ)=(IMZ-FIRST_FIELD)*10
    FINTIT(IMZ)=[ATZ]NOCOURT
    FINTITCOURT(IMZ)=[ATZ]NOABREG
    FTYPE(IMZ)=[ATZ]CODTYP
    Read [ATY]CODTYP=[ATZ]CODTYP
    If fstat=0
      FTYPINT(IMZ)=ML33([ATY]TYPTYP)
    Else
      FTYPINT(IMZ)=0
    Endif
    FCLAS(IMZ)=""
    FMENU(IMZ)=[ATZ]NOLIB
    FLONG(IMZ)=[ATZ]LONG
    FACTI(IMZ)=[ATZ]CODACT
    FGROU(IMZ)=""
    FTABL(IMZ)=ITB
    If [ATZ]CODACT<>""
      Read [ACV]CODACT=[ATZ]CODACT
      If [ACV]TYP=2
        If (IMZ>1) and (NB_REGROUPS>0)
&       and FACTI(IMZ-1)=[ATZ]CODACT
          FGROU(IMZ)=FGROU(IMZ-1)
        Else
          FGROU(IMZ)="L_"+FIELDS(IMZ)
          NB_REGROUPS+=1
          REGCODE(NB_REGROUPS)=FGROU(IMZ)
          REGACTIV(NB_REGROUPS)=FACTI(IMZ)
          REGMINI(NB_REGROUPS)=[ACV]DIME
          REGMAXI(NB_REGROUPS)=[ACV]DIMMAX
          REGFIL(NB_REGROUPS)=[ACV]DIMFIL
          REGTBL(NB_REGROUPS)=ITB
          REGDIM(NB_REGROUPS)=2 : # For tables, numbering starts with 0
          Read [ATB1]CODFIC=TABANA
#         If REGCODE(NB_REGROUPS)="NAM" : Dbgaff : Endif
          REGINT(NB_REGROUPS)=[ATB1]INTITFIC
        Endif
      Endif
    Endif

    # Management of multi-dimensioned fields
    If [ATZ]DIME>1
      # Check if the field is already associated to a array block
      J=0
      For [AMZ]DICO Where CODZON=[ATZ]CODZONE and find([AMZ]CODMSK,MASKS(1..NB_MASKS))<>0
        I=find([AMZ]CODMSK,MASKS(1..NB_MASKS))
        For J=1 To NB_BLOCKS
          If BLKMSK(J)=I and TYPBLK(J)=1 and BLKRNK(J)=[AMZ]NUMBLOC
            # No group name associated yet
            If GRPBLK(J)=""
              GRPBLK(J)="L_"+FIELDS(IMZ) : # ABREV(ITB)+"."+FIELDS(IMZ)
            Endif
            FGROU(IMZ)=GRPBLK(J)
            Break 2
           Endif
        Next J
        J=0 : # no such a block found
      Next

      # If the field is an array in a normal block
      If J=0 and (IMZ>1) and (NB_REGROUPS>0)
&       and REGMAXI(NB_REGROUPS)=[ATZ]DIME
&       and FACTI(IMZ-1)=[ATZ]CODACT : # REGMINI(NB_REGROUPS)>=1 is no more a condition
        FGROU(IMZ)=FGROU(IMZ-1)
      Endif

      # If no existing group name found, the name of the group will be the name of the field
      If FGROU(IMZ)=""
        FGROU(IMZ)="L_"+FIELDS(IMZ) : # And no more ABREV(ITB)+"."+FIELDS(IMZ)
      Endif

      # If the group name found is not yet known in the group array, store it
      If find(FGROU(IMZ),REGCODE(1..NB_REGROUPS))=0
        NB_REGROUPS+=1
        REGCODE(NB_REGROUPS)=FGROU(IMZ)
        REGACTIV(NB_REGROUPS)=""
        REGMINI(NB_REGROUPS)=0 : # Minimum dimension
        REGFIL(NB_REGROUPS)=1 : # Minimum dimension in the table ?
        REGMAXI(NB_REGROUPS)=[ATZ]DIME
        REGTBL(NB_REGROUPS)=ITB
        REGDIM(NB_REGROUPS)=2 : # For tables, numbering starts with 0
        # Group naming is got from field or from array block name
#       If REGCODE(NB_REGROUPS)="NAM" : Dbgaff : Endif
        If J<>0
          Read [AMK1]CODMSK=[AMZ]CODMSK
          REGINT(NB_REGROUPS)=[AMK1]TITBLOC([AMZ]NUMBLOC-1)
        Else
          REGINT(NB_REGROUPS)=[ATZ]NOCOURT
        Endif
      Endif
    Else
      # Check on mono-dimensioned fields if they might by a company, an access code, or a legislation field
      # The site field defined here will be used only if ZSITE is not defined on AOB
      # The access code field defined here will be used only if ZACC is not defined on AOB
      If FIELDS(IMZ)="LEG"
        FLDLEG(ITB)=FIELDS(IMZ)
      Elsif [ATZ]CODTYP="CPY" and FLDCPY(ITB)=""
        FLDCPY(ITB)=FIELDS(IMZ)
      Elsif [ATZ]CODTYP="FCY" and FLDFCY(ITB)=""
        FLDFCY(ITB)=FIELDS(IMZ)
      Elsif [ATZ]CODTYP="ACS" and FLDACS(ITB)=""
        FLDACS(ITB)=FIELDS(IMZ)
      Endif
    Endif

    FOBLI(IMZ)=[ATZ]OBLIG
    FCONTROLE(IMZ)="" : FACCES(IMZ)="": # To be done in a second pass with the screen analysis

    # Members of the main key should be mandatory, aren't they ?
    If FOBLI(IMZ)=1 and find(FIELDS(IMZ),ELTCLES(ITB,1..NB_ELT(ITB)))
      FOBLI(IMZ)=2
    Endif

    # Help keyword, if not found in table, will be assigned by searching the field in the screens associated to the window
#    FMOTCLE(IMZ)=[ATZ]MOTCLE
#    If [ATZ]MOTCLE="" and CODWIN(ITB)<>""
#      Read [AWI]AWI0=CODWIN(ITB)
#      For [AMZ] Where find(CODMSK,[AWI]MSKENT,[AWI]NOMMSK(0..[AWI]NBMSK))<>0 and CODZON=FIELDS(IMZ)
#        FMOTCLE(IMZ)=[AMZ]MOTCLE
#        Break
#      Next
#    Endif

    # Now call the parameter analysis
    Gosub ANA_PAR
  Next
Return

# Analysis of parameters and key parameters
# ITB is the current table, IMZ the current field
$ANA_PAR
  Read [ATY]CODTYP=FTYPE(IMZ)
  If fstat : Return : Endif

  If pat(FTYPE(IMZ),"AX*")
    For CHAINE="CODFIC","ZONE","LANGUE","IDENT1","IDENT2"
      NB_PARAMS+=1
      [L]NBRPAR(IMZ)+=1
      If [L]NBRPAR(IMZ)=1
        [L]FIRSTPAR(IMZ)=NB_PARAMS
        [L]VALEUR_PAR(NB_PARAMS)=FIELDS(IMZ)
      Endif
      TYPKEY(NB_PARAMS)=2
      [L]CODPAR(NB_PARAMS)=CHAINE
      Case CHAINE
        When "CODFIC" : [L]VALEUR_PAR(NB_PARAMS)='"'+TABLES(ITB)+'"'
        When "ZONE"   : [L]VALEUR_PAR(NB_PARAMS)='"'+FIELDS(IMZ)+'"'
        When "LANGUE" : [L]VALEUR_PAR(NB_PARAMS)='ACTX.LAN'
        When "IDENT1" : [L]VALEUR_PAR(NB_PARAMS)=ELTCLES(ITB,1)
        When "IDENT2" : [L]VALEUR_PAR(NB_PARAMS)='""'
      Endcase
    Next
    Return
  # The ATX data type associated parameters will be filled later when the ATT typed field will be found
  Elsif FTYPE(IMZ)="ATX"
    For CHAINE="LNG","OBJTYP","OBJNOM","ZONE"
      NB_PARAMS+=1
      [L]NBRPAR(IMZ)+=1
      If [L]NBRPAR(IMZ)=1
        [L]FIRSTPAR(IMZ)=NB_PARAMS
      Endif
      TYPKEY(NB_PARAMS)=1
      [L]CODPAR(NB_PARAMS)=CHAINE
    Next
    Return
  Endif

  If FIELDS(IMZ)='POSCOD' & TABLES(ITB)='BPADDRESS'
    L=L
  Endif

  If [ATY]OBJLIEN<>""
    # The algorithm is a little bit more complicated than expected
    # First, verify if there is a linked object that has its first key with an unique component
    # If this condition is fulfilled, then link is obvious
    # Otherwise, search for the control actions
    Raz [AOB1] : # Avoid a buffering side effect
    Read [AOB1]ABREV=[ATY]OBJLIEN
    If [AOB1]NOMFIC<>TABLES(ITB) or 1<>0 : # You can avoid auto-links by cancelling the "or 1<>0" piece of code
      If fstat=0
        Filter [ATI] Where CODFIC=[AOB1]NOMFIC
        Read [ATI]NUMLIG First
        Filter [ATI]
        If instr(1,[ATI]DESCRIPT,"+")=0 and instr(1,[ATI]DESCRIPT,"-")=0
          # Unique component : type=key, value defined by the field name
          NB_PARAMS+=1
          [L]NBRPAR(IMZ)+=1
          If [L]NBRPAR(IMZ)=1
            [L]FIRSTPAR(IMZ)=NB_PARAMS
            [L]VALEUR_PAR(NB_PARAMS)=string$(FGROU(IMZ)<>"",FGROU(IMZ)+".")+FIELDS(IMZ)
          Endif
          [L]CODPAR(NB_PARAMS)=[ATI]DESCRIPT
          Read [ATZ1]CODZONE=[AOB1]NOMFIC;vireblc(ctrans([ATI]DESCRIPT,"("," "),3)
          [L]INTITPAR(NB_PARAMS)=(fstat=0)*[ATZ1]NOCOURT
          TYPKEY(NB_PARAMS)=2
          Return
        Endif
      Endif
    Endif
  Endif

  # Multiple key or no table link : analyze all the relevant actions
  # (change made  the 15th of June)
  # No more particular case must be managed for "ADI" data type
  # The same type of algorithm is used if the field is only present on a screen (see ANA_PAR1)
  If [ATY]CODTYP="ADI"
    # For other types, it should be better to make a loop from 0 to [ATY]NBTYP-1
    Read [ACT]ACTION=[ATY]ACTION(1)
    If [ACT]TYPACT=2
        [L]NB_PARAMS+=1
        [L]NBRPAR(IMZ)=1
        [L]TYPKEY(NB_PARAMS)=1
        [L]FIRSTPAR(IMZ)=NB_PARAMS
        [L]CODPAR(NB_PARAMS)="VALEUR"
        [L]VALEUR_PAR(NB_PARAMS)=string$(FGROU(IMZ)<>"",FGROU(IMZ)+".")+FIELDS(IMZ) : # Current value
    Endif
    For J=[ACT]TYPACT To [ACT]NBPAR
      [L]NB_PARAMS+=1
      [L]NBRPAR(IMZ)+=1
      If [L]NBRPAR(IMZ)=1
        [L]FIRSTPAR(IMZ)=NB_PARAMS
      Endif
      Read [ATR]NOPAR=[ACT]ACTION;J
      If fstat=0
        # Hard-coded transformation, but there is no other way to do it
        Case [ATR]CODPAR
          When "ADI" : [L]CODPAR(NB_PARAMS)="NUMTAB"
          When "TABDIV" : [L]CODPAR(NB_PARAMS)="DEPCOD"
        Endcase
        [L]TYPKEY(NB_PARAMS)=1
        Read [AAR]CODPAR=[ATR]CODPAR
        If fstat=0
          [L]INTITPAR(NB_PARAMS)=[AAR]INTITPAR
          Read [AMP]CODPAR=2;TABLES(ITB);FIELDS(IMZ);[ATR]CODPAR
          If fstat=0
            If pat(toupper([AMP]VALPAR),"*[M]*")
              K=instr(1,toupper([AMP]VALPAR),"[M]")
              While K
                [AMP]VALPAR=left$([AMP]VALPAR,K-1)+right$([AMP]VALPAR,K+3)
                K=instr(1,toupper([AMP]VALPAR),"[M]")
              Wend
            Endif
            [L]VALEUR_PAR(NB_PARAMS)=[AMP]VALPAR
          Endif
        Endif
        # Correct the bug concerning NUMTAB that should be a string and not a number
        If [L]CODPAR(NB_PARAMS)="NUMTAB" and (instr(1,[L]VALEUR_PAR(NB_PARAMS),'"')=0 or instr(1,[L]VALEUR_PAR(NB_PARAMS),"'")=0)
          [L]VALEUR_PAR(NB_PARAMS)='"'+[L]VALEUR_PAR(NB_PARAMS)+'"'
        Endif
      Endif
    Next J

   # THIS CODE SHOULD ALSO BE USED FOR ADI data type
   Else
    Read [ACT]ACTION=[ATY]ACTION(0)
    For J=0 To [ATY]NBTYP-1
      # TO BE VALIDATED
      # Only some actions might be managed : local menu 31 : before field, init, control, after update
      If find([ATY]ACTTYP(J),2,4,5,7)
        Read [ACT]ACTION=[ATY]ACTION(J)
        If [ACT]TYPACT=2 & [L]NBRPAR(IMZ)=0
          [L]NB_PARAMS+=1
          [L]NBRPAR(IMZ)=1
          [L]FIRSTPAR(IMZ)=NB_PARAMS
          [L]CODPAR(NB_PARAMS)="VALEUR"
          [L]TYPKEY(NB_PARAMS)=1
          [L]VALEUR_PAR(NB_PARAMS)=string$([L]FGROU(IMZ)<>"",[L]FGROU(IMZ)+".")+[L]FIELDS(IMZ) : # Current value
        Endif
      Endif
    Next J
    For J=0 To [ATY]NBTYP-1
      # TO BE VALIDATED
      # Only some actions might be managed : local menu 31 : before field, init, control, after update
      If find([ATY]ACTTYP(J),2,4,5,7)
        Read [ACT]ACTION=[ATY]ACTION(J)
        For K=[ACT]TYPACT To [ACT]NBPAR
          Read [ATR]NOPAR=[ACT]ACTION;K
          # Only add the parameter if not already encountered
          If fstat=0 & ([L]NBRPAR(IMZ)=0 or find([ATR]CODPAR,[L]CODPAR([L]FIRSTPAR(IMZ)..[L]FIRSTPAR(IMZ)+[L]NBRPAR(IMZ)))=0)
            [L]NB_PARAMS+=1
            [L]NBRPAR(IMZ)+=1
            [L]TYPKEY(NB_PARAMS)=1
            If [L]NBRPAR(IMZ)=1
              [L]FIRSTPAR(IMZ)=NB_PARAMS
            Endif
            [L]CODPAR(NB_PARAMS)=[ATR]CODPAR
            Read [AAR]CODPAR=[ATR]CODPAR
            If fstat=0
              [L]INTITPAR(NB_PARAMS)=[AAR]INTITPAR
              Read [AMP]CODPAR=2;TABLES(ITB);FIELDS(IMZ);[ATR]CODPAR
              If fstat=0
                If pat(toupper([AMP]VALPAR),"*[M]*")
                  L=instr(1,toupper([AMP]VALPAR),"[M]")
                  While L
                    [AMP]VALPAR=left$([AMP]VALPAR,L-1)+right$([AMP]VALPAR,L+3)
                    L=instr(1,toupper([AMP]VALPAR),"[M]")
                  Wend
                Endif
                [L]VALEUR_PAR(NB_PARAMS)=[AMP]VALPAR
              Endif
            Endif
          Endif
        Next K
      Endif
    Next J
  Endif

Return

# Analysis of parameters and key parameters for the additional fields not present in a table
# ITB is the current table, IMZ the current field
$ANA_PAR1
  Read [ATY]CODTYP=FTYPE(IMZ)
  If fstat : Return : Endif

  If pat(FTYPE(IMZ),"AX*")
    For CHAINE="CODFIC","ZONE","LANGUE","IDENT1","IDENT2"
      NB_PARAMS+=1
      [L]NBRPAR(IMZ)+=1
      If [L]NBRPAR(IMZ)=1
        [L]FIRSTPAR(IMZ)=NB_PARAMS
        [L]VALEUR_PAR(NB_PARAMS)=string$(FGROU(IMZ)<>"",FGROU(IMZ)+".")+FIELDS(IMZ)
      Endif
      TYPKEY(NB_PARAMS)=2
      [L]CODPAR(NB_PARAMS)=CHAINE
      Case CHAINE
        When "CODFIC" : [L]VALEUR_PAR(NB_PARAMS)='"'+TABLES(ITB)+'"'
        When "ZONE"   : [L]VALEUR_PAR(NB_PARAMS)='"'+FIELDS(IMZ)+'"'
        When "LANGUE" : [L]VALEUR_PAR(NB_PARAMS)='ACTX.LAN'
        When "IDENT1" : [L]VALEUR_PAR(NB_PARAMS)=ELTCLES(ITB,1)
        When "IDENT2" : [L]VALEUR_PAR(NB_PARAMS)='""'
      Endcase
    Next
    Return
  Endif


  If [ATY]OBJLIEN<>""
    # The algorithm is a little bit more complicated than expected
    # First, verify if there is a linked object that has its first key with an unique component
    # If this condition is fulfilled, then link is obvious
    # Otherwise, search for the control actions
    Raz [AOB1] : # Avoid a buffering side effect
    Read [AOB1]ABREV=[ATY]OBJLIEN
    If [AOB1]NOMFIC<>TABLES(ITB) or 1<>0 : # You can avoid auto-links bu cancelling the "or 1<>0" piece of code
      If fstat=0
        Filter [ATI] Where CODFIC=[AOB1]NOMFIC
        Read [ATI]NUMLIG First
        Filter [ATI]
        If instr(1,[ATI]DESCRIPT,"+")=0 and instr(1,[ATI]DESCRIPT,"-")=0
          # Unique component : type=key, value defined by the field name
          NB_PARAMS+=1
          [L]NBRPAR(IMZ)+=1
          If [L]NBRPAR(IMZ)=1
            [L]FIRSTPAR(IMZ)=NB_PARAMS
            [L]VALEUR_PAR(NB_PARAMS)=string$(FGROU(IMZ)<>"",FGROU(IMZ)+".")+FIELDS(IMZ)
          Endif
          [L]CODPAR(NB_PARAMS)=[ATI]DESCRIPT
          Read [ATZ1]CODZONE=[AOB1]NOMFIC;vireblc(ctrans([ATI]DESCRIPT,"("," "),3)
          [L]INTITPAR(NB_PARAMS)=(fstat=0)*[ATZ1]NOCOURT
          TYPKEY(NB_PARAMS)=2
          Return
        Endif
      Endif
    Endif
  Endif

  # Multiple key or no table link : analyze the first the control or init action
  # But update the action and parameter only if the subprogram dictionary is filled
  # A particular case managed is "ADI" data type
  If [ATY]CODTYP="ADI"
    Read [ASU]ASU0="SUBADI";"CONTADI"
    For J=0 To [ASU]NBRPAR-1
      NB_PARAMS+=1
      [L]NBRPAR(IMZ)+=1
      If [L]NBRPAR(IMZ)=1
        [L]FIRSTPAR(IMZ)=NB_PARAMS
      Endif
      Read [ASP]ASP0=[ASU]PRG;[ASU]SUBPRG;J+1
      If fstat=0
        [L]CODPAR(NB_PARAMS)=[ASP]PARAM
        [L]INTITPAR(NB_PARAMS)=[ASP]INTITPAR
        Case J
          When 0 : [L]VALEUR_PAR(NB_PARAMS)=string$(FGROU(IMZ)<>"",FGROU(IMZ)+".")+FIELDS(IMZ)
          When 1 : Read [AMP]CODPAR=1;MASKS(IMK);FIELDS(IMZ);"ADI"
                   If fstat=0
                     [L]VALEUR_PAR(NB_PARAMS)=string$(val([AMP]VALPAR)<>0,'"')+[AMP]VALPAR+string$(val([AMP]VALPAR)<>0,'"')
                   Endif
          When 2 : Read [AMP]CODPAR=1;MASKS(IMK);FIELDS(IMZ);"TABDIV"
                   If fstat=0
                     [L]VALEUR_PAR(NB_PARAMS)=[AMP]VALPAR
                   Endif
        Endcase
        [L]TYPINTPAR(NB_PARAMS)=[ASP]TYPPAR : # Local menu 33 value transcoding
        [L]ADRVAL(NB_PARAMS)=[ASP]ADRVAL : # Local menu 34
        TYPKEY(NB_PARAMS)=1
      Endif
    Next J
  Else : # Not sure this will give good results
    For [ATR]NOPAR Where ACTION=[ACT]ACTION and NOPAR>[ACT]TYPACT : # Skip the first line if current field is managed
      NB_PARAMS+=1
      [L]NBRPAR(IMZ)+=1
      If [L]NBRPAR(IMZ)=1
        [L]FIRSTPAR(IMZ)=NB_PARAMS
       Endif
      [L]CODPAR(NB_PARAMS)=[ATR]CODPAR
      [L]INTITPAR(NB_PARAMS)=[ATR]INTITPAR
      Read [AMP]CODPAR=2;TABLES(ITB);FIELDS(IMZ);[ATR]CODPAR
      If fstat=0
        If pat(toupper([AMP]VALPAR),"*[M]*")
          K=instr(1,toupper([AMP]VALPAR),"[M]")
          While K
            [AMP]VALPAR=left$([AMP]VALPAR,K-1)+right$([AMP]VALPAR,K+3)
            K=instr(1,toupper([AMP]VALPAR),"[M]")
          Wend
        Endif
        [L]VALEUR_PAR(NB_PARAMS)=[AMP]VALPAR
      Endif
      [L]TYPINTPAR(NB_PARAMS)=[ATR]TYPPAR : # Local menu 33 value transcoding
      [L]ADRVAL(NB_PARAMS)=[ATR]ADRVAL : # Local menu 34
      TYPKEY(NB_PARAMS)=1
    Next
  Endif

Return



# Main data type analysis (OBJECT object)
$CONVERT_TYP
  Read [AOB]ABREV=OBJECT
  For [ATY] Where OBJLIEN=OBJECT
    Gosub ANA_TYPE
    If I
      Call ECR_TRACE("",0) From GESECRAN
      Read [AZZ]NUMERO=GLANGUE;[ATY]INTITTYP
      Call ECR_TRACE("Data type rewritten :"+[ATY]CODTYP-[AZZ]TEXTE,0) From GESECRAN
      Call ECR_TRACE("Class code : "+CODCLA_TYPE,0) From GESECRAN
      Call ECR_TRACE("Format : "+format$("LA7875:20X",FMTSYR_TYPE),0) From GESECRAN
      Call ECR_TRACE("Format : "+format$("LA7879:20X",MEDSYR_TYPE),0) From GESECRAN
      If NBRRUL_TYP
        Call ECR_TRACE("+-------------+--------------------+------------------------------+-------------+-------------+",0) From GESECRAN
        Call ECR_TRACE("!Type (TYPRUL)!  Program (TRTRUL)  !  Subprogram (PRGRUL)         !Rank (ORDRUL)!Activ(ACTRUL)!",0) From GESECRAN
        Call ECR_TRACE("+-------------+--------------------+------------------------------+-------------+-------------+",0) From GESECRAN
        For I=1 To NBRRUL_TYP
          Call ECR_TRACE("!"+format$("LA7961:13X",TYPRUL_TYPE(I))+"!"+format$("K:20X",TRTRUL_TYP(I))+"!"
&                           +format$("K:30X",PRGRUL_TYP(I))+"!"+format$("N:13",ORDRUL_TYP(I))+"!"+format$("K:13X",ACTRUL_TYP(I))+"!",0)
&                       From GESECRAN
        Next I
        Call ECR_TRACE("+-------------+--------------------+------------------------------+-------------+-------------+",0) From GESECRAN
      Endif
    Endif
  Next

# Finally, convert the data type
 Gosub ANA_TYPE

Return

$ANA_TYPE
  If type([ATY]CODCLA)>0 and [ATY]CODCLA<>""
    I=0 : # Nothing to rewrite
    Return
  Endif

  CODCLA_TYPE=TABLE(1)
  Read [ATZ]CODZONE=TABLE(1);ELTCLES(1,1)
  Read [ATY1]CODTYP=[ATZ]CODTYP
  MEDSYR_TYPE=1
  Case [ATY1]TYPTYP
    When 1     : FMTSYR_TYPE=1+9*([ATZ]NOLIB<>1) : # Boolean (Local menu 1), else enumeration
    When 2,3   : FMTSYR_TYPE=2
    When 4     : FMTSYR_TYPE=3
    When 5,6   : FMTSYR_TYPE=4
    When 7     : FMTSYR_TYPE=7 : MEDSYR_TYPE=2
    When 8     : FMTSYR_TYPE=5
    When 9     : FMTSYR_TYPE=9
    When 10    : FMTSYR_TYPE=8
    When 11    : FMTSYR_TYPE=7 : MEDSYR_TYPE=2 : # Uuid as a string ?
    When 12    : FMTSYR_TYPE=12
  Endcase

  NBRRUL_TYP=0
  For I=1 To [ATY]NBRTYP
    If find([ATY]ACTTYP(I-1),2,5) : # And no more 3, modification done June 19th
      NBRRUL_TYP+=1
      TYPRUL_TYPE(NBRUL_TYP)=1+([ATY]ACTTYP(I-1)=5)
      Read [ACT]ACTION=[ATY]ACTION(I-1)
      TRTRUL_TYPE(NBRUL_TYPE)=[ACT]CODTRT
      PRGRUL_TYPE(NBRUL_TYPE)=[ACT]SUBPRG
      ORDRUL_TYPE(NBRUL_TYPE)=10*NBRUL_TYPE
      ACTRUL_TYPE(NBRUL_TYPE)=[ACT]CODACT
    Endif
  Next I

# Here, the code associated to the update of the data type must be inserted

  I=1
Return
