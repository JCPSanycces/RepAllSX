#<AdxTL>@(#)0.0.0.0 $Revision$
#################################################################################
#################################################################################
### RMA * 03-02-2015 * report controls for POR Legislation
#################################################################################
#################################################################################
$OUVRE_CTR_VARS

#ATENTION : Do not declare tables here because of INDUS TOOLS
Local Integer OBJI, RPTI, STAT
Local Tinyint PORCPY       #is there a portuguese company?
Local Tinyint DEVMOD       #is the report being printed in report development mode?
Local Char    CRYPATH(255) #crystal report file full path

Local Integer NUMCAR : NUMCAR = 4    #number of characteristics
Local Integer NUMOBJ : NUMOBJ = 19   #number of objects (18 + 1 exception)
Local Integer MAXRPT : MAXRPT = 100  #maximum number or rpt files

Local Char    OBJ_CTR_LST(GLONAFC)(1..NUMOBJ,1..NUMCAR) #Object list where reports need to be controlled
Local Char    RPT_CTR_LST(GLONACR)(1..MAXRPT,1..2)      #Report list (rpt files) to control, based on objects

Return
#################################################################################
#################################################################################
$CLOSE_CTR_VARS

Kill OBJI, RPTI
Kill PORCPY

Kill OBJ_CTR_LST
Kill RPT_CTR_LST

Return
#################################################################################
#################################################################################
# Creates an array of all crystal reports that should be controlled,
# based on the predefined object list (defined at Funprog GET_OBJ_CTR_LST)
# ATENTION: There's a copy of this funtion on INDUS TOOLShttp://scmx3-dev-red.sagefr.adinternal.com:8124/auth/login/page
#################################################################################
#################################################################################
Subprog GET_RPT_CTR_LST(RET_OBJ_CTR_LST, RET_RPT_CTR_LST)
Variable Char RET_OBJ_CTR_LST()(1..,1..)
Variable Char RET_RPT_CTR_LST()(1..,1..)

Local Integer I, J, K

Local File AOBJET    [F:AOB]
Local File AREPORTX  [F:ARX]
Local File AREPORT   [F:ARP]
Local File TABPRTMOD [F:TPM]

#Get the list of object that should be controlled
Call GET_OBJ_CTR_LST(RET_OBJ_CTR_LST)

#Set the list of reports (rpt files) that should be controlled
For [F:AOB] Where find([F:AOB]ABREV, RET_OBJ_CTR_LST(1..maxtab(RET_OBJ_CTR_LST),1)) #for each function
  If [F:AOB]RPT1 <> ""
    For [F:ARX] Where [F:ARX]INTCOD = [F:AOB]RPT1
      If [F:ARX]EXTCOD <> ""
        Read [F:ARP]ARP0 = [F:ARX]EXTCOD
        If !fstat
          For J = 0 To dim([F:ARP]CRYCOD)-1
            If [F:ARP]CRYCOD(J) <> "" & !find([F:ARP]CRYCOD(J),RET_RPT_CTR_LST(1..max(1,K),1)) & [F:ARP]CRYCOD(J)<>"ATRACE"
              K += 1
              RET_RPT_CTR_LST(K,1) = [F:ARP]CRYCOD(J)
              RET_RPT_CTR_LST(K,2) = [F:AOB]ABREV
            Endif
          Next
        Endif
      Endif
    Next
    Read [F:ARP]ARP0 = [F:AOB]RPT1
    If !fstat
      For J = 0 To dim([F:ARP]CRYCOD)-1
        If [F:ARP]CRYCOD(J) <> "" & !find([F:ARP]CRYCOD(J),RET_RPT_CTR_LST(1..max(1,K),1))
          K += 1
          RET_RPT_CTR_LST(K,1) = [F:ARP]CRYCOD(J)
          RET_RPT_CTR_LST(K,2) = [F:AOB]ABREV
         Endif
      Next
    Endif
  Endif
Next

For [F:TPM]
  #Priting templates
  If [F:TPM]SALQUO <> "" & find("SQH", RET_OBJ_CTR_LST(1..maxtab(RET_OBJ_CTR_LST),1)) & !find([F:TPM]SALQUO,RET_RPT_CTR_LST(1..max(1,K),1))
    K += 1
    RET_RPT_CTR_LST(K,1) = [F:TPM]SALQUO
    RET_RPT_CTR_LST(K,2) = "SQH"
  Endif
  If [F:TPM]SALORD <> "" & find("SOH", RET_OBJ_CTR_LST(1..maxtab(RET_OBJ_CTR_LST),1)) & !find([F:TPM]SALORD,RET_RPT_CTR_LST(1..max(1,K),1))
    K += 1
    RET_RPT_CTR_LST(K,1) = [F:TPM]SALORD
    RET_RPT_CTR_LST(K,2) = "SOH"
  Endif
  If [F:TPM]SALORC <> "" & find("SOR", RET_OBJ_CTR_LST(1..maxtab(RET_OBJ_CTR_LST),1)) & !find([F:TPM]SALORC,RET_RPT_CTR_LST(1..max(1,K),1))
    K += 1
    RET_RPT_CTR_LST(K,1) = [F:TPM]SALORC
    RET_RPT_CTR_LST(K,2) = "SOR"
  Endif
  If [F:TPM]SALDLV <> "" & find("SDH", RET_OBJ_CTR_LST(1..maxtab(RET_OBJ_CTR_LST),1)) & !find([F:TPM]SALDLV,RET_RPT_CTR_LST(1..max(1,K),1))
    K += 1
    RET_RPT_CTR_LST(K,1) = [F:TPM]SALDLV
    RET_RPT_CTR_LST(K,2) = "SDH"
  Endif
  If [F:TPM]SALCRE <> "" & find("SIH", RET_OBJ_CTR_LST(1..maxtab(RET_OBJ_CTR_LST),1)) & !find([F:TPM]SALCRE,RET_RPT_CTR_LST(1..max(1,K),1))
    K += 1
    RET_RPT_CTR_LST(K,1) = [F:TPM]SALCRE
    RET_RPT_CTR_LST(K,2) = "SIH"
  Endif
  If [F:TPM]SALINV <> "" & find("SIH", RET_OBJ_CTR_LST(1..maxtab(RET_OBJ_CTR_LST),1)) & !find([F:TPM]SALINV,RET_RPT_CTR_LST(1..max(1,K),1))
    K += 1
    RET_RPT_CTR_LST(K,1) = [F:TPM]SALINV
    RET_RPT_CTR_LST(K,2) = "SIH"
  Endif
Next

#Exception for P-RECIBO
RET_RPT_CTR_LST(K+1,1) = "P-RECIBO"
RET_RPT_CTR_LST(K+1,2) = "PAY"

RET_OBJ_CTR_LST(19,1) = "PAY"
RET_OBJ_CTR_LST(19,2) = "3"
RET_OBJ_CTR_LST(19,3) = "E"
RET_OBJ_CTR_LST(19,4) = "PYH"
#End of Exception - for P-RECIBO

Close File [F:AOB]
Close File [F:ARX]
Close File [F:ARP]
Close File [F:TPM]

End
#################################################################################
#################################################################################
# Creates an array of object codes. All reports associated with these
# objects must be controlled
#################################################################################
#################################################################################
Funprog GET_OBJ_CTR_LST(RET_OBJ_CTR_LST)
Variable Char RET_OBJ_CTR_LST()(1..,1..)

#characteristics:
# 1 - object code
# 2 - module  - as local menu 14: 3 (A/P-A/R accounting), 5 (Sales), 6 (Purchasing), 7 (Stocks), 9 (Common data), 12 (Help-Desk)
# 3 - invoice/transportdoc/other - I, T, O
# 4 - base table

#Phase 1
RET_OBJ_CTR_LST(1,1)  = "BIC" : RET_OBJ_CTR_LST(1,2)  = "3"  : RET_OBJ_CTR_LST(1,3)  = "I" : RET_OBJ_CTR_LST(1,4)  = "SIH"
RET_OBJ_CTR_LST(11,1) = "SIH" : RET_OBJ_CTR_LST(11,2) = "5"  : RET_OBJ_CTR_LST(11,3) = "I" : RET_OBJ_CTR_LST(11,4) = "SIH"
RET_OBJ_CTR_LST(14,1) = "SQH" : RET_OBJ_CTR_LST(14,2) = "5"  : RET_OBJ_CTR_LST(14,3) = "O" : RET_OBJ_CTR_LST(14,4) = "SQH"

#Phase 2
RET_OBJ_CTR_LST(2,1)  = "TNH" : RET_OBJ_CTR_LST(2,2)  = "9"  : RET_OBJ_CTR_LST(2,3)  = "T" : RET_OBJ_CTR_LST(2,4)  = "TNH"
RET_OBJ_CTR_LST(5,1)  = "PNH" : RET_OBJ_CTR_LST(5,2)  = "6"  : RET_OBJ_CTR_LST(5,3)  = "T" : RET_OBJ_CTR_LST(5,4)  = "PNH"
RET_OBJ_CTR_LST(10,1) = "SDH" : RET_OBJ_CTR_LST(10,2) = "5"  : RET_OBJ_CTR_LST(10,3) = "T" : RET_OBJ_CTR_LST(10,4) = "SDH"
RET_OBJ_CTR_LST(15,1) = "SRH" : RET_OBJ_CTR_LST(15,2) = "5"  : RET_OBJ_CTR_LST(15,3) = "T" : RET_OBJ_CTR_LST(15,4) = "SRH"
RET_OBJ_CTR_LST(16,1) = "SRL" : RET_OBJ_CTR_LST(16,2) = "5"  : RET_OBJ_CTR_LST(16,3) = "T" : RET_OBJ_CTR_LST(16,4) = "SRH"
RET_OBJ_CTR_LST(17,1) = "SRS" : RET_OBJ_CTR_LST(17,2) = "5"  : RET_OBJ_CTR_LST(17,3) = "T" : RET_OBJ_CTR_LST(17,4) = "SRH"
RET_OBJ_CTR_LST(18,1) = "SCS" : RET_OBJ_CTR_LST(18,2) = "7"  : RET_OBJ_CTR_LST(18,3) = "T" : RET_OBJ_CTR_LST(18,4) = "SGH"

#Phase 3
RET_OBJ_CTR_LST(12,1) = "SOH" : RET_OBJ_CTR_LST(12,2) = "5"  : RET_OBJ_CTR_LST(12,3) = "O" : RET_OBJ_CTR_LST(12,4) = "SOH"
RET_OBJ_CTR_LST(13,1) = "SOR" : RET_OBJ_CTR_LST(13,2) = "5"  : RET_OBJ_CTR_LST(13,3) = "O" : RET_OBJ_CTR_LST(13,4) = "SOH"
RET_OBJ_CTR_LST(3,1)  = "CON" : RET_OBJ_CTR_LST(3,2)  = "9"  : RET_OBJ_CTR_LST(3,3)  = "O" : RET_OBJ_CTR_LST(3,4)  = "CON"
RET_OBJ_CTR_LST(4,1)  = "SRE" : RET_OBJ_CTR_LST(4,2)  = "9"  : RET_OBJ_CTR_LST(4,3)  = "O" : RET_OBJ_CTR_LST(4,4)  = "SRE"
RET_OBJ_CTR_LST(6,1)  = "POC" : RET_OBJ_CTR_LST(6,2)  = "6"  : RET_OBJ_CTR_LST(6,3)  = "O" : RET_OBJ_CTR_LST(6,4)  = "POH"
RET_OBJ_CTR_LST(7,1)  = "POH" : RET_OBJ_CTR_LST(7,2)  = "6"  : RET_OBJ_CTR_LST(7,3)  = "O" : RET_OBJ_CTR_LST(7,4)  = "POH"
RET_OBJ_CTR_LST(8,1)  = "PQH" : RET_OBJ_CTR_LST(8,2)  = "6"  : RET_OBJ_CTR_LST(8,3)  = "O" : RET_OBJ_CTR_LST(8,4)  = "PQH"
RET_OBJ_CTR_LST(9,1)  = "PTH" : RET_OBJ_CTR_LST(9,2)  = "6"  : RET_OBJ_CTR_LST(9,3)  = "O" : RET_OBJ_CTR_LST(9,4)  = "PTH"

End
#################################################################################
#################################################################################
# Checks if there's a portuguese company in the printing request
#################################################################################
#################################################################################
$PORCPY

PORCPY = 0

If !clalev([F:CPY]) : Local File COMPANY  [CPY] : Endif
If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif

Local Integer NREQ
If dim([V]GWNUMREQ)
  If [V]GWNUMREQ > 0
    [L]NREQ = [V]GWNUMREQ
  Endif
Endif

If [L]NREQ = 0 : [L]NREQ = [L]NUMREQ : Endif

Case OBJ_CTR_LST(OBJI,2) #Module
  When "3" #A/P-A/R accounting
    If !clalev([F:TARPT]) : Local File TMPARPT [TARPT] : Endif
    Case OBJ_CTR_LST(OBJI,4) #Base table
      When "PYH"
        If !clalev([F:PYH])   : Local File PAYMENTH [PYH]   : Endif
        Link [F:TARPT] With [F:PYH]PYH0 = [F:TARPT]VCRNUM, [F:CPY]CPY0 = [F:PYH]CPY As [PRTLK]
&       Where [F:TARPT]NUMREQ = [L]NREQ & [F:TARPT]USR = GUSER & [F:TARPT]RPTCOD = [F:ARP]RPTCOD
      When "SIH"
        If !clalev([F:SIH]) : Local File SINVOICE [SIH] : Endif
        Link [F:TARPT] With [F:SIH]SIH0 = [F:TARPT]VCRNUM, [F:FCY]FCY0 = [F:SIH]FCY, [F:CPY]CPY0 = [F:SIH]CPY As [PRTLK]
&       Where [F:TARPT]NUMREQ = [L]NREQ & [F:TARPT]USR = GUSER & [F:TARPT]RPTCOD = [F:ARP]RPTCOD
    Endcase
  When "5" #Sales
    If !clalev([F:TRPT]) : Local File TMPSRPT [TRPT] : Endif
    Case OBJ_CTR_LST(OBJI,4) #Base table
      When "SDH"
        If !clalev([F:SDH]) : Local File SDELIVERY [SDH] : Endif
        Link [F:TRPT] With [F:SDH]SDH0 = [F:TRPT]VCRNUM, [F:CPY]CPY0 = [F:SDH]CPY As [PRTLK]
&       Where [F:TRPT]NUMREQ = [L]NREQ & [F:TRPT]USR = GUSER & [F:TRPT]RPTCOD = [F:ARP]RPTCOD
      When "SIH"
        If !clalev([F:SIH]) : Local File SINVOICE [SIH] : Endif
        Link [F:TRPT] With [F:SIH]SIH0 = [F:TRPT]VCRNUM, [F:FCY]FCY0 = [F:SIH]FCY, [F:CPY]CPY0 = [F:SIH]CPY As [PRTLK]
&       Where [F:TRPT]NUMREQ = [L]NREQ & [F:TRPT]USR = GUSER & [F:TRPT]RPTCOD = [F:ARP]RPTCOD
      When "SOH"
        If !clalev([F:SOH]) : Local File SORDER [SOH] : Endif
        Link [F:TRPT] With [F:SOH]SOH0 = [F:TRPT]VCRNUM, [F:CPY]CPY0 = [F:SOH]CPY As [PRTLK]
&       Where [F:TRPT]NUMREQ = [L]NREQ & [F:TRPT]USR = GUSER & [F:TRPT]RPTCOD = [F:ARP]RPTCOD
      When "SQH"
        If !clalev([F:SQH]) : Local File SQUOTE [SQH] : Endif
        Link [F:TRPT] With [F:SQH]SQH0 = [F:TRPT]VCRNUM, [F:CPY]CPY0 = [F:SQH]CPY As [PRTLK]
&       Where [F:TRPT]NUMREQ = [L]NREQ & [F:TRPT]USR = GUSER & [F:TRPT]RPTCOD = [F:ARP]RPTCOD
      When "SRH"
        If !clalev([F:SRH]) : Local File SRETURN [SRH] : Endif
        Link [F:TRPT] With [F:SRH]SRH0 = [F:TRPT]VCRNUM, [F:CPY]CPY0 = [F:SRH]CPY As [PRTLK]
&       Where [F:TRPT]NUMREQ = [L]NREQ & [F:TRPT]USR = GUSER & [F:TRPT]RPTCOD = [F:ARP]RPTCOD
    Endcase
  When "6" #Purchasing
    If !clalev([F:TPRPT]) : Local File TMPPRPT [TPRPT] : Endif
    Case OBJ_CTR_LST(OBJI,4) #Base table
      When "PNH"
        If !clalev([F:PNH]) : Local File PRETURN [PNH] : Endif
        Link [F:TPRPT] With [F:PNH]PNH0 = [F:TPRPT]VCRNUM, [F:CPY]CPY0 = [F:PNH]CPY As [PRTLK]
&       Where [F:TPRPT]NUMREQ = [L]NREQ & [F:TPRPT]USR = GUSER & [F:TPRPT]RPTCOD = [F:ARP]RPTCOD
      When "POH"
        If !clalev([F:POH]) : Local File PORDER [POH] : Endif
        Link [F:TPRPT] With [F:POH]POH0 = [F:TPRPT]VCRNUM, [F:CPY]CPY0 = [F:POH]CPY As [PRTLK]
&       Where [F:TPRPT]NUMREQ = [L]NREQ & [F:TPRPT]USR = GUSER & [F:TPRPT]RPTCOD = [F:ARP]RPTCOD
      When "PQH"
        If !clalev([F:PQH]) : Local File PQUOTAT [PQH] : Endif
        Link [F:TPRPT] With [F:PQH]PQH0 = [F:TPRPT]VCRNUM, [F:CPY]CPY0 = [F:PQH]CPY As [PRTLK]
&       Where [F:TPRPT]NUMREQ = [L]NREQ & [F:TPRPT]USR = GUSER & [F:TPRPT]RPTCOD = [F:ARP]RPTCOD
      When "PTH"
        If !clalev([F:PTH]) : Local File PRECEIPT [PTH] : Endif
        Link [F:TPRPT] With [F:PTH]PTH0 = [F:TPRPT]VCRNUM, [F:CPY]CPY0 = [F:PTH]CPY As [PRTLK]
&       Where [F:TPRPT]NUMREQ = [L]NREQ & [F:TPRPT]USR = GUSER & [F:TPRPT]RPTCOD = [F:ARP]RPTCOD
    Endcase
  When "7" #Stocks
    If !clalev([F:TKRPT]) : Local File TMPKRPT [TKRPT] : Endif
    Case OBJ_CTR_LST(OBJI,4) #Base table
      When "SGH"
        If !clalev([F:SGH]) : Local File SCHGH [SGH] : Endif
        Link [F:TKRPT] With [F:SGH]SGH0 = [F:TKRPT]VCRNUM, [F:FCY]FCY0 = [F:SGH]STOFCY, [F:CPY]CPY0 = [F:FCY]LEGCPY As [PRTLK]
&       Where [F:TKRPT]NUMREQ = [L]NREQ & [F:TKRPT]USR = GUSER & [F:TKRPT]RPTCOD = [F:ARP]RPTCOD
    Endcase
  When "9" #Common data
    If !clalev([F:TCRPT]) : Local File TMPCRPT [TCRPT] : Endif
    Case OBJ_CTR_LST(OBJI,4) #Base table
      When "CON"
        If !clalev([F:CON]) : Local File CONTSERV [CON] : Endif
        Link [F:TCRPT] With [F:CON]CON0 = [F:TCRPT]VCRNUM, [F:CPY]CPY0 = [F:CON]CPY As [PRTLK]
&       Where [F:TCRPT]NUMREQ = [L]NREQ & [F:TCRPT]USR = GUSER & [F:TCRPT]RPTCOD = [F:ARP]RPTCOD
      When "TNH"
        If !clalev([F:TNH]) : Local File TRANNOTEH [TNH] : Endif
        Link [F:TCRPT] With [F:TNH]TNH0 = [F:TCRPT]VCRNUM, [F:CPY]CPY0 = [F:TNH]CPY As [PRTLK]
&       Where [F:TCRPT]NUMREQ = [L]NREQ & [F:TCRPT]USR = GUSER & [F:TCRPT]RPTCOD = [F:ARP]RPTCOD
      When "SRE"
        If !clalev([F:SRE]) : Local File SERREQUEST [SRE] : Endif
        Link [F:TCRPT] With [F:SRE]SRE0 = [F:TCRPT]VCRNUM, [F:FCY]FCY0 = [F:SRE]SALFCY, [F:CPY]CPY0 = [F:FCY]LEGCPY As [PRTLK]
&       Where [F:TCRPT]NUMREQ = [L]NREQ & [F:TCRPT]USR = GUSER & [F:TCRPT]RPTCOD = [F:ARP]RPTCOD
    Endcase
Endcase

If clalev([PRTLK])
  Read [PRTLK] First
  If fstat
    GOK = 0
    # Issue 115969 - 2016-04-13 by RICAR : Can't print non validated purchase return
    # Issue 115969
    #Call ECR_TRACE(mess(182,7711,1)-"-"-mess(183,7711,1),1) From GESECRAN
    Call ECR_TRACE(mess(182,7711,1)-"-"-mess(238,7711,1),1) From GESECRAN
    # End issue 115969
    Return
  Else
    If OBJ_CTR_LST(OBJI,4) = "SIH"
      Filter [PRTLK] Where [F:CPY]LEG = 'POR' & ([F:FCY]CRY='' | [F:FCY]CRY='PT')
    Else
      Filter [PRTLK] Where [F:CPY]LEG = 'POR'
    Endif
    Read [PRTLK] First
    If !fstat
      PORCPY = 1
    Endif
    Filter [PRTLK]
  Endif
Else
  GOK = 0
  Call ECR_TRACE(mess(182,7711,1)-"-"-mess(184,7711,1),1) From GESECRAN
Endif

Return
#################################################################################
#################################################################################
# Checks if the crystal report being used is valid and sets the correct
# data in the temporary printing table
#################################################################################
#################################################################################
$CHECK_REPORT

Gosub GET_RPT_INFO
If GOK = 0 : Return : Endif

#--------------------------------------------------------------------------------
# Check the digital signature
#--------------------------------------------------------------------------------
If CRYPATH <> "" & RPTDEV = ""

  STAT = 0

  Gosub CHECK_ON_CURRENT_FOLDER

  If DOSSIER=adxmother & DOSSIER<>nomap & GOK = 0
    Gosub CHECK_ON_REPORT_FOLDER
  Endif

  If GOK = 0
    Case STAT
      When 1
        Call ECR_TRACE(mess(182,7711,1)-"-"-mess(186,7711,1)+":"-RPTNAM-"-"-RPTLAN,1) From GESECRAN
      When 2
        Call ECR_TRACE(mess(182,7711,1)-"-"-mess(185,7711,1)+":"-RPTNAM-"-"-RPTLAN,1) From GESECRAN
    Endcase
  Endif

  STAT = 0

Endif

#--------------------------------------------------------------------------------
# If crystal report is ok, we'll update the temporary printing table with data
#--------------------------------------------------------------------------------
If GOK

  Filter [PRTLK] Where [F:CPY]LEG = 'POR'
  For [PRTLK]
    Call SET_PORLEG_INFO(OBJ_CTR_LST(OBJI))
    If !GOK : Break : Endif
  Next

Endif

Return
#################################################################################
#################################################################################
$CHECK_ON_CURRENT_FOLDER

If clalev([F:RDS]) = 1 : Close File [RDS] : Endif
Local File RPTDS [RDS]

Gosub CHECK_DIG_SIGN

Return
#################################################################################
#################################################################################
$CHECK_ON_REPORT_FOLDER

If clalev([F:RDS]) = 1 : Close File [RDS] : Endif
Local File = DOSSIER+".RPTDS" [RDS]

Gosub CHECK_DIG_SIGN

Return
#################################################################################
#################################################################################
$CHECK_DIG_SIGN

GOK  = 1

Read [F:RDS]RDS0 = RPTNAM;RPTLAN

If fstat<>0

  STAT = 1
  GOK = 0

Else

  Local Integer D, BDIM, FILEDIM : FILEDIM = filinfo(CRYPATH,7)
  While FILEDIM > 1024*(2^D)-4
    D+= 1
  Wend
  Local Blbfile CRYFIL(D)

  Openi CRYPATH Using [CRY]
  Getseq FILEDIM, CRYFIL Using [CRY]
  Openi         Using [CRY]

  Local Integer STATUSCODE

  STATUSCODE = func TEST_DIGITAL_SIGNATURE([L]CRYFIL, [F:RDS]DIGSIGN)
  If STATUSCODE <> 1
    STAT = 2
    GOK = 0
  Else
    STAT = 0
  Endif
Endif

Return
#################################################################################
#################################################################################
# Gets information about the rpt file: full path and file name; devmode
#################################################################################
#################################################################################
$GET_RPT_INFO

CRYPATH = ""

# Get report full path and name
If filinfo(filpath(filpath("REPORT",RPTLAN,"",DOSSIER),RPTNAM,"rpt",DOSSIER),0)>=0
  CRYPATH = filpath(filpath("REPORT",RPTLAN,"",DOSSIER),RPTNAM,"rpt",DOSSIER)
Else
  Call ECR_TRACE(RPTNAM+".rpt"-":"-mess(101,100,1),1) From GESECRAN : # Fichier inexistant
  GOK = 0
Endif

Return
#################################################################################
#################################################################################
Funprog TEST_DIGITAL_SIGNATURE(BLB_DATA, BLB_DS)
Variable Blbfile BLB_DATA()
Variable Blbfile BLB_DS()

Local Char    MODULE(100)
Local Char    FUNCTION(30)
Local Char    MODE(10)
Local Char    ENCODINGS(40)
Local Integer CALLBACKINDEX
Local Char    RETURNS(50)
Local Char    RETURNS_ENC(3)
Local Clbfile RESHEAD(0)
Local Clbfile RESBODY(0)

Local Integer STATUSCODE
Local Char    RETCOD(1)
Local Char    RETVAL(10)
Local Char    RETMES(255)

Local Integer VALRES : VALRES = -1

#Clob for base64 encoded digital signature
Local Clbfile CLB_DS(0)

#Clob for base64 encoded data (report)
Local Integer J, K, D
K = (len(BLB_DATA)*4)/3
J = arr(K,8)+((arr(K,8)<K)*8)

While J > 1024*(2^D)-4
  D+= 1
Wend
Local Clbfile CLB_DATA(D)

#base64 encoding of the arguments
J  = b64Encode(BLB_DATA, CLB_DATA)
J += b64Encode(BLB_DS, CLB_DS)
J += 5

Raz D
While J > 1024*(2^D)-4
  D+= 1
Wend
Local Clbfile ARGUMENTS(D)

#module call preparation
MODULE = 'bundles/sage-pt-print'
FUNCTION = 'verifyReport'
MODE = 'wait'
Append ARGUMENTS, '"' + CLB_DATA + '"'
Append ARGUMENTS, ',"' + CLB_DS + '"'

#module call
STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FUNCTION, MODE, ARGUMENTS, ENCODINGS, CALLBACKINDEX, RETURNS, RETURNS_ENC, RESHEAD, RESBODY)

#process the return
If STATUSCODE = 200 #status ok - get the values
  RETCOD = func AJSONLIB.GET_PROP(RESBODY,"code")
  RETVAL = func AJSONLIB.GET_PROP(RESBODY,"value")
  RETMES = func AJSONLIB.GET_PROP(RESBODY,"message")
Else #status not ok, get error message
  RETMES = func AJSONLIB.GET_PROP(RESHEAD,"message")
  Call ECR_TRACE   ("message:"-RETMES,1)   From GESECRAN
Endif
If tolower(RETVAL)="true" : VALRES = 1 : Endif

End VALRES
#################################################################################
#################################################################################
# Sets the legal mentions
#################################################################################
#################################################################################
#Case 1 – Documents subject to a digital signature, originally created in X3
#Case 2 – Documents subject to a digital signature, originally created manually, as backup reposition or by an external software
#Case 3 – Documents not subject to a digital signature
#Case 4 - Procedure to training environment
#Case 5 – Documents that potentially can be confused with invoices
#Case 6 – Documents that potentially can be confused with Transports or shippings
#Case 7 – Final consumer
#Case 8 – Invoice cancelation documents
#Case 9 – Documents referencing other documents not originally created in X3
#################################################################################
#################################################################################
Subprog SET_PORLEG_INFO(OBJ_CTR)#, PM1, PM2, PM3, PM4, PM5, PM6, CPYN, CPYA, CPYP, CPYS, CPYC)
Value    Char OBJ_CTR()(1..)

#--------------------------------------------------------------------------------
# Declares variables and table buffers
#--------------------------------------------------------------------------------
Local Integer STAT

Local Char    VNUM(GLONVCR), VDOCTYP(GLONTSV), VORIDOC(30)
Local Integer VRECTYP
Local Tinyint SIGNEDDOC
Local Tinyint CANCELINVSTA # 1 - ; 2 -
Local Decimal WWHOLDTAX #WithHoldingTax

# Issue 113779 - 2016-04-08 by RICAR : Missing control on the reports
# Issue 113779
Local Char PM01(100), PM02(100), PM03(100), PM04(100), PM05(100), PM06(100), PM07(100)
Local Integer V_SAFTTRNTYP, INVCAFLG

INVCAFLG = 1
If func AFNC.ACTIV("INVCA")
  INVCAFLG = 2
Endif

# End issue 113779
Local Char CPYN(40), CPYA(35)(1..3), CPYP(10), CPYS(35), CPYC(30)
Local Char ATCOD(50)

If !clalev([F:ADS]) Local File ADOSSIER [ADS] : Endif
If !clalev([F:BPR]) Local File BPARTNER [BPR] : Endif
If !clalev([F:DKD]) Local File DKSDATA  [DKD] : Endif

#--------------------------------------------------------------------------------
# Folder information (for the trainning test case)
#--------------------------------------------------------------------------------
If [F:ADS]DOSSIER <> nomap : Read [F:ADS]DOSSIER = nomap : Endif

#--------------------------------------------------------------------------------
# Stock exception
#--------------------------------------------------------------------------------
If OBJ_CTR(4) = "SGH"
  If !find([F:SGH]BETFCYCOD, 2, 4, 5)
    End
  Endif
Endif

#--------------------------------------------------------------------------------
# Set a flag SIGNEDDOC (document subject to digital signature)
#--------------------------------------------------------------------------------
[L]SIGNEDDOC = 0

If OBJ_CTR(3) = "I"
  If [F:SIH]INVTYP <> 5 : [L]SIGNEDDOC = 1 : Endif
  If INVCAFLG = 2
    [L]CANCELINVSTA = [F:SIH]REVCANSTA
  Endif
Elsif OBJ_CTR(3) = "T"
  [L]SIGNEDDOC = 1
Endif

#--------------------------------------------------------------------------------
# Sets the legal mentions
#--------------------------------------------------------------------------------

If [L]SIGNEDDOC         #Cases 1, 2, 4 and 9
  Gosub SIGNED_DOCS
Else                    #Cases 3 and 6
  Gosub UNSIGNED_DOCS
Endif

Gosub OTHER_CASES       #Case  8

Gosub UPDATE_TMP_TAB

End
#################################################################################
#################################################################################
$SIGNED_DOCS

#--------------------------------------------------------------------------------
# Case 1 - Documents subject to a digital signature, originally created in X3 #
#          and
# Case 2 - Documents subject to a digital signature, originally created manually, as backup reposition or by an external software
#--------------------------------------------------------------------------------

# Issue 113779 - 2016-04-08 by RICAR : Missing control on the reports
# Issue 113779
Raz [L]V_SAFTTRNTYP
# End issue 113779

If OBJ_CTR(3) = "I"

  If !clalev([F:TSV]) : Local File TABSIVTYP [TSV] : Endif
  Call LEC_TSV_LEG("POR",[F:SIH]SIVTYP,STAT) From TRTLECLEG

  [L]VDOCTYP = [F:SIH]SIVTYP : [L]VNUM = [F:SIH]NUM : [L]VRECTYP = [F:TSV]RECTYP : [L]VORIDOC = [F:SIH]ORIDOCNUM

  # Issue 113779
  Case [F:TSV]SAFTINVTYP
    When 1 : PM07 = "Fatura"
    When 2 : PM07 = "Fatura simplificada"
    When 3 : PM07 = "Nota de Débito"
    When 4 : PM07 = "Nota de Crédito"
    When 7 : PM07 = "Fatura-Recibo"
  Endcase

  # ISSUE 84627 - 2018-04-10 by MNO : PT Certification - print report - When cancel a document myst appear "Anulado" and at same time the nature of Document
  Case [L]CANCELINVSTA
    When 2: PM07 = "Anulação de fatura"
  Endcase
  # END ISSUE 84627

  # End issue 113779

Elsif OBJ_CTR(3) = "T"
  # Issue 113779 - 2016-04-08 by RICAR : Missing control on the reports

  Case OBJ_CTR(4)
    When "TNH"
      If !clalev([F:TTN]) : Local File TABTNHTYP [TTN] : Endif
      Call LEC_TTN_LEG("POR",[F:TNH]TNHTYP,[L]STAT) From TRTLECLEG
      [L]VDOCTYP = [F:TNH]TNHTYP : [L]VNUM = [F:TNH]TNHNUM : [L]VRECTYP = [F:TTN]RECTYP : [L]VORIDOC = [F:TNH]MANDOC
      # Issue 113779
      [L]V_SAFTTRNTYP = [F:TTN]SAFTTRNTYP
      # End issue 113779
    When "PNH"
      If !clalev([F:TPN]) : Local File TABPNHTYP [TPN] : Endif
      Call LEC_TPN_LEG("POR",[F:PNH]PNHTYP,[L]STAT) From TRTLECLEG
      [L]VDOCTYP = [F:PNH]PNHTYP : [L]VNUM = [F:PNH]PNHNUM : [L]VRECTYP = [F:TPN]RECTYP : [L]VORIDOC = [F:PNH]MANDOCR
      # Issue 113779
      [L]V_SAFTTRNTYP = [F:TPN]SAFTTRNTYP
      # End issue 113779
    When "SDH"
      If !clalev([F:TSD]) : Local File TABSDHTYP [TSD] : Endif
      Call LEC_TSD_LEG("POR",[F:SDH]SDHTYP,[L]STAT) From TRTLECLEG
      [L]VDOCTYP = [F:SDH]SDHTYP : [L]VNUM = [F:SDH]SDHNUM : [L]VRECTYP = [F:TSD]RECTYP : [L]VORIDOC = [F:SDH]MANDOC
      # Issue 113779
      [L]V_SAFTTRNTYP = [F:TSD]SAFTTRNTYP
      # End issue 113779
    When "SRH"
      If !clalev([F:TRE]) : Local File TABSRHTYP [TRE] : Endif
      Call LEC_TRE_LEG("POR",[F:SRH]SRHTYP,[L]STAT) From TRTLECLEG
      [L]VDOCTYP = [F:SRH]SRHTYP : [L]VNUM = [F:SRH]SRHNUM : [L]VRECTYP = [F:TRE]RECTYP : [L]VORIDOC = [F:SRH]MANDOCR
      # Issue 113779
      [L]V_SAFTTRNTYP = [F:TRE]SAFTTRNTYP
      # End issue 113779
    When "SGH"
      If !clalev([F:TSG]) : Local File TABSGHTYP [TSG] : Endif
      Call LEC_TSG_LEG("POR",[F:SGH]SGHTYP,[L]STAT) From TRTLECLEG
      [L]VDOCTYP = [F:SGH]SGHTYP : [L]VNUM = [F:SGH]VCRNUM : [L]VRECTYP = [F:TSG]RECTYP : [L]VORIDOC = [F:SGH]MANDOC
      # Issue 113779
      [L]V_SAFTTRNTYP = [F:TSG]SAFTTRNTYP
      # End issue 113779
  Endcase

  # Issue 113779 - 2016-04-08 by RICAR : Missing control on the reports
  # Issue 113779
  Case [L]V_SAFTTRNTYP
    When 1 : PM07 = "Guia de transporte"
    When 2 : PM07 = "Guia de remessa"
    When 3 : PM07 = "Guia transporte ativos"
    When 4 : PM07 = "Guia de consignação"
    When 5 : PM07 = "Guia de devolução"
  Endcase
  # End issue 113779

Endif

Read [F:DKD]DKD0="SAFT-PT";[L]VDOCTYP;[L]VNUM
If fstat : Raz [F:DKD] : Endif
[L]WWHOLDTAX = [F:DKD]WITHOLTAX

Case [L]VRECTYP
  When 1
    If [F:DKD]PRNCHAR <> ""
      PM01 = [F:DKD]PRNCHAR + " - Processado por programa certificado n.º 213/AT"
    Else
      PM01 = "Emitido por programa certificado n.º 213/AT"
      If OBJ_CTR(3) = "I"
        #If [F:SIV]INVSTA <> 3
        If [F:SIH]STA <> 3
          PM02 = "Este documento não serve de fatura."
        Endif
      Endif
      # Issue 113779 - 2016-04-08 by RICAR : Missing control on the reports
      # Issue 113779
      #If OBJ_CTR(1) = "BIC"
      #  If [F:SIH]STA <> 3
      #    PM02 = "Este documento não serve de fatura"
      #  Endif
      #Endif
      # End issue 113779
      If OBJ_CTR(3) = "T"
        PM02 = "Não válido como documento de transporte."
      Endif
    Endif
  When 2
    PM01 = "Emitido por programa certificado n.º 213/AT"
    PM02 = "Cópia do documento original - " + [F:DKD]DOCBASTYP + "M" + " " + [L]VORIDOC
  When 3
    PM01 = "Emitido por programa certificado n.º 213/AT"
    PM02 = "Cópia do documento original - " + [F:DKD]DOCBASTYP + "D" + " " + [L]VORIDOC
  When 4
    If [F:DKD]DIGSIGN = ""
      Call ECR_TRACE   (mess(200,7711,1),1)   From GESECRAN #"External document not digitally signed cannot be printed."
      GOK = 0 : Return
    Endif
    PM01 = "Emitido por programa certificado n.º 213/AT"
    #PM02 = "Cópia do documento original - " + [F:DKD]DOCBASTYP + "I" + " " + [L]VORIDOC
    PM02 = "Cópia do documento original."
Endcase

#--------------------------------------------------------------------------------
# Case 4 - Procedure to training environment
#--------------------------------------------------------------------------------
If [F:ADS]TSTFLG=2 or nomap = "SEED"
  PM03    = "Documento emitido para fins de Formação"
  CPYN    = "SAGE PORTUGAL"
  CPYA(1) = "Edificio Olympus"
  CPYA(2) = "Av D. Afonso Henriques n° 1462"
  CPYA(3) = ""
  CPYP    = "4450-013"
  CPYS    = "MATOSINHOS"
  CPYC    = "Portugal"
Endif

ATCOD = [F:DKD]ATDTCOD

Return
#################################################################################
#################################################################################
$UNSIGNED_DOCS

#--------------------------------------------------------------------------------
# Case 3 - Documents not subject to a digital signature
#--------------------------------------------------------------------------------

PM01 = "Emitido por programa certificado n.º 213/AT"

#--------------------------------------------------------------------------------
# Case 6 - Documents that potentially can be confused with Transports or shippings
#--------------------------------------------------------------------------------

PM04 = "Não válido como documento de transporte"

#--------------------------------------------------------------------------------
# Case 99 - Proforma
#--------------------------------------------------------------------------------
If OBJ_CTR(3) = "I"
  If !clalev([F:TSV]) : Local File TABSIVTYP [TSV] : Endif
  Call LEC_TSV_LEG("POR",[F:SIH]SIVTYP,STAT) From TRTLECLEG
  If [F:TSV]SAFTINVTYP=9
    PM07 = "Fatura consignação"
  Else
    PM07 = "Fatura proforma"
  Endif
Endif


Return
#################################################################################
#################################################################################
$OTHER_CASES

#--------------------------------------------------------------------------------
# Case 5 - Documents that potentially can be confused with invoices
#--------------------------------------------------------------------------------
If OBJ_CTR(3) <> "I" | (OBJ_CTR(3) = "I" & ![L]SIGNEDDOC)
  PM05 = "Este documento não serve de fatura"
Endif

#--------------------------------------------------------------------------------
# Case 7 - Final consumer
#--------------------------------------------------------------------------------
If OBJ_CTR(1) = "SIH" & [L]SIGNEDDOC

  If [F:BPR]BPRNUM <> [F:SIH]BPR
    Read [F:BPR]BPR0 = [F:SIH]BPR
  Endif

  If [F:BPR]LEGETT = 2
    If [F:BPC]BPCTYP = 2
      If [F:SIV]BPIEECNUM = [F:BPR]EECNUM
        PM06 = "Consumidor final"
      Endif
    Endif
  Endif

Endif

#--------------------------------------------------------------------------------
# Case 8 - Invoice cancellation
#--------------------------------------------------------------------------------
If OBJ_CTR(3) = "I" & [L]CANCELINVSTA = 1
  PM05 = "Documento anulado"
Elsif OBJ_CTR(3) = "I" & [L]CANCELINVSTA = 2
  PM05 = "Documento de anulação de fatura"
Endif

Return
#################################################################################
#################################################################################
$UPDATE_TMP_TAB

Local Char TMPTABABR(GLONATB)
Case OBJ_CTR(2) #Module
  When "3" #A/P-A/R accounting
    If !clalev([F:TARPT2]) : Local File TMPARPT [TARPT2] : Endif
    TMPTABABR = "[F:TARPT2]"
    Read [F:TARPT2]TARPT0 =  [F:TARPT]NUMREQ;[F:TARPT]USR;[F:TARPT]RPTCOD;[F:TARPT]VCRNUM
    If fstat : GOK = 0 : Call ECR_TRACE(mess(182,7711,1)-"-"-mess(188,7711,1),1) From GESECRAN : Return : Endif
    Trbegin [F:TARPT2]
    Gosub ASSIGN_VAR_TO_TAB
    Rewrite [F:TARPT2]
    If fstat : Rollback : GOK = 0 : Call ECR_TRACE(mess(182,7711,1)-"-"-mess(189,7711,1),1) From GESECRAN : Return : Endif
    Commit
  When "5", "12" #Sales + Help-Desk
    If !clalev([F:TRPT2]) : Local File TMPSRPT [TRPT2] : Endif
    TMPTABABR = "[F:TRPT2]"
    Read [F:TRPT2]TSRPT0 =  [F:TRPT]NUMREQ;[F:TRPT]USR;[F:TRPT]RPTCOD;[F:TRPT]VCRNUM
    If fstat : GOK = 0 : Call ECR_TRACE(mess(182,7711,1)-"-"-mess(188,7711,1),1) From GESECRAN : Return : Endif
    Trbegin [F:TRPT2]
    Gosub ASSIGN_VAR_TO_TAB
    Rewrite [F:TRPT2]
    If fstat : Rollback : GOK = 0 : Call ECR_TRACE(mess(182,7711,1)-"-"-mess(189,7711,1),1) From GESECRAN : Return : Endif
    Commit
  When "6" #Purchasing
    If !clalev([F:TPRPT2]) : Local File TMPPRPT [TPRPT2] : Endif
    TMPTABABR = "[F:TPRPT2]"
    Read [F:TPRPT2]TPRPT0 =  [F:TPRPT]NUMREQ;[F:TPRPT]USR;[F:TPRPT]RPTCOD;[F:TPRPT]VCRNUM
    If fstat : GOK = 0 : Call ECR_TRACE(mess(182,7711,1)-"-"-mess(188,7711,1),1) From GESECRAN : Return : Endif
    Trbegin [F:TPRPT2]
    Gosub ASSIGN_VAR_TO_TAB
    Rewrite [F:TPRPT2]
    If fstat : Rollback : GOK = 0 : Call ECR_TRACE(mess(182,7711,1)-"-"-mess(189,7711,1),1) From GESECRAN : Return : Endif
    Commit
  When "7" #Stocks
    If !clalev([F:TKRPT2]) : Local File TMPKRPT [TKRPT2] : Endif
    TMPTABABR = "[F:TKRPT2]"
    Read [F:TKRPT2]TKRPT0 =  [F:TKRPT]NUMREQ;[F:TKRPT]USR;[F:TKRPT]RPTCOD;[F:TKRPT]VCRNUM
    If fstat : GOK = 0 : Call ECR_TRACE(mess(182,7711,1)-"-"-mess(188,7711,1),1) From GESECRAN : Return : Endif
    Trbegin [F:TKRPT2]
    Gosub ASSIGN_VAR_TO_TAB
    Rewrite [F:TKRPT2]
    If fstat : Rollback : GOK = 0 : Call ECR_TRACE(mess(182,7711,1)-"-"-mess(189,7711,1),1) From GESECRAN : Return : Endif
    Commit
  When "9" #Common data
    If !clalev([F:TCRPT2]) : Local File TMPCRPT [TCRPT2] : Endif
    TMPTABABR = "[F:TCRPT2]"
    Read [F:TCRPT2]TCRPT0 =  [F:TCRPT]NUMREQ;[F:TCRPT]USR;[F:TCRPT]RPTCOD;[F:TCRPT]VCRNUM
    If fstat : GOK = 0 : Call ECR_TRACE(mess(182,7711,1)-"-"-mess(188,7711,1),1) From GESECRAN : Return : Endif
    Trbegin [F:TCRPT2]
    Gosub ASSIGN_VAR_TO_TAB
    Rewrite [F:TCRPT2]
    If fstat : Rollback : GOK = 0 : Call ECR_TRACE(mess(182,7711,1)-"-"-mess(189,7711,1),1) From GESECRAN : Return : Endif
    Commit
  When Default
    GOK = 0
    Call ECR_TRACE(mess(182,7711,1)-"-"-mess(184,7711,1),1) From GESECRAN : Return
Endcase

Return
#################################################################################
#################################################################################
$ASSIGN_VAR_TO_TAB

# Issue 113779 - 2016-04-08 by RICAR : Missing control on the reports
# Issue 113779
For K = 1 To 7
# End issue 113779
  Assign TMPTABABR+"PTMENTION0"+num$(K) With evalue("PM0"+num$(K))
Next

Assign TMPTABABR+"PTCPYNAM" With CPYN
For K = 1 To 3
  Assign TMPTABABR+"PTCPYADDLIG("+num$(K-1)+")" With CPYA(K)
Next
Assign TMPTABABR+"PTCPYPOSCOD" With CPYP
Assign TMPTABABR+"PTCPYSAT"    With CPYS
Assign TMPTABABR+"PTCPYCTY"    With CPYC

If OBJ_CTR(3) = "T"
  Assign TMPTABABR+"PTATCOD"     With ATCOD
Endif

If find(TMPTABABR,"[F:TRPT2]","[F:TARPT2]")
  Assign TMPTABABR+"WITHOLTAX" With [L]WWHOLDTAX
Endif

Return
#################################################################################
#################################################################################
# End of legal mentions
#################################################################################
#################################################################################

