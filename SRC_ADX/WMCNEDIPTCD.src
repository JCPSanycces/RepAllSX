#<AdxTL>@(#)0.0.0.0 $Revision$Class Protocol detail
# Supervisor
## ACLA-CLASSE ## EDIPTCD
# 2018-11-06 07:04:59 230

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0EDIPTCD
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_PTCCOD From WMC1EDIPTCD : Gosub TESTALLSTAT
Gosub INIT_NUMLIN From WMC1EDIPTCD : Gosub TESTALLSTAT
Gosub INIT_SORT From WMC1EDIPTCD : Gosub TESTALLSTAT
Gosub INIT_PTCLINCOD From WMC1EDIPTCD : Gosub TESTALLSTAT
Gosub INIT_PTCLINDES From WMC1EDIPTCD : Gosub TESTALLSTAT
Gosub INIT_PTCLINVAL From WMC1EDIPTCD : Gosub TESTALLSTAT
Gosub INIT_PTCLINVALDIR From WMC1EDIPTCD : Gosub TESTALLSTAT
Gosub INIT_PTCLINVALTYP From WMC1EDIPTCD : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1EDIPTCD : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1EDIPTCD : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1EDIPTCD : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1EDIPTCD : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1EDIPTCD : Gosub TESTALLSTAT
Gosub AINIT From WMC0EDIPTCD : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EDIPTCD
Gosub _ALOADATTRIBUTE_PTCCOD From WMC1EDIPTCD : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_NUMLIN From WMC1EDIPTCD : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_PTCLINCOD From WMC1EDIPTCD : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EDIPTCD
Gosub LNKPRO_PTCCOD From WMC1EDIPTCD : Gosub TESTALLSTAT
Gosub LNKPRO_PTCLINVALDIR From WMC1EDIPTCD : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



