#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMAVADAT0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:43"
A_USER  = "DOC"
A_STAMP = "20181109230543"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMAVADAT0 [PAVD0]
Gosub HORODAT
Local Inpbox "PJMAVADAT0" From GFONCTION At A_STAMP With A_WINDPREV Mask [PAVD0] As [SIM_]
Grizo [PAVD0]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PAVD0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=151 : Y1(0)=1 : Y2(0)=25
X1(1)=1 : X2(1)=-2 : Y1(1)=1 : Y2(1)=0
Return

$ON_OPPNUM
Return

$ON_ZOPPNUM
Onevent BEFORE_AREA Gosub AV_ZOPPNUM From W1PJMAVADAT0
Return

$AV_ZOPPNUM
Call LECTEXTRA(zc,"PIMPL","PIMDESAXX",num$([M]OPPNUM(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_TASCOD
Return

$ON_TASSTATE
Onevent INIT_AREA Call D_TASSTATE(zc) From W1PJMAVADAT0
Return

Subprog D_TASSTATE(VALEUR)
Variable Integer VALEUR
If varinit([M]TASSTATE,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_ITMREF
Return

$ON_ZITMREF
Onevent BEFORE_AREA Gosub AV_ZITMREF From W1PJMAVADAT0
Return

$AV_ZITMREF
Call LECTEXTRA(zc,"ITMMASTER","DES1AXX",num$([M]ITMREF(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_REQDAT
Onevent BEFORE_AREA Gosub AV_REQDAT From W1PJMAVADAT0
Return

$AV_REQDAT
Chgfmt [M]REQDAT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_QTY
Onevent BEFORE_AREA Gosub AV_QTY From W1PJMAVADAT0
Return

$AV_QTY
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find([M:PAVD0]UOM,GUNITE(1..GNBUNT)),1))
Endif
Chgfmt [M]QTY(indice) With "NPz:"+GUNTFMT
Gosub _AFF
Return

$ON_UOM
Return

$ON_ZUOM
Onevent BEFORE_AREA Gosub AV_ZUOM From W1PJMAVADAT0
Return

$AV_ZUOM
Call LECTEXTRA(zc,"TABUNIT","DES",num$([M]UOM(indice)),"") From ATEXTRA
Gosub _AFF
Return

$CHG_STY
Return


