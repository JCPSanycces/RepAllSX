#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
Call EXEC(NBPAR,PARAMETRE)
End


#######################################
Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
Local Char    PARAM (50)
Local Char    VALEUR (50), CRIT1(250)
Local Date    DATEDEB, DATEFIN
Local Char    SITE (GLONFCY), MATDEB(GLONEML), MATFIN(GLONEML), ETAT(GLONARP)
Local Integer FCYEFF, CPYEFF, LIG, NUMREQ

If clalev([F:ID])=0     : Local File EMPLOID  [ID]    : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR [HRCTR] : Endif
If clalev([F:FCY])=0    : Local File FACILITY [FCY]   : Endif
If clalev([F:ARM])=0    : Local File AREPORTM [ARM]   : Endif

Call GETPARAM("fcy",NBPAR,PARAMETRE,SITE)
Call GETPARAM("datdeb",NBPAR,PARAMETRE,PARAM) : DATEDEB = PARAM
Call GETPARAM("datfin",NBPAR,PARAMETRE,PARAM) : DATEFIN = PARAM
Call GETPARAM("matdeb",NBPAR,PARAMETRE,MATDEB)
Call GETPARAM("matfin",NBPAR,PARAMETRE,MATFIN)
Call GETPARAM("X3ETA",NBPAR,PARAMETRE,[L]ETAT)
Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) : [L]NUMREQ = val(PARAM)

PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

Link [HRCTR] With [F:FCY]FCY0=[F:HRCTR]ETRFCY As [LNK]
Gosub TR1

# Affectation des effectifs
PARAM = num$(FCYEFF)
If len (PARAM)<3
 PARAM= string$(3-len(PARAM),"0")+PARAM
Endif
Call SETPARAM("FCYEFF",NBPAR,PARAMETRE,PARAM) From ETAT

PARAM = num$(CPYEFF)
If len (PARAM)<5
 PARAM= string$(5-len(PARAM),"0")+PARAM
Endif
Call SETPARAM("CPYEFF",NBPAR,PARAMETRE,PARAM) From ETAT

CRIT1 = '[F:HRCTR]ETRFCY=SITE & [F:HRCTR]CTRDAT>=DATEDEB & [F:HRCTR]CTRDAT<=DATEFIN'
If MATDEB<>""
 CRIT1 -= '& [F:HRCTR]REFNUM>="'+MATDEB+'"'
Endif
If MATFIN<>""
 CRIT1 -= '& [F:HRCTR]REFNUM<="'+MATFIN+'"'
Endif
CRIT1-= '& [F:HRCTR]FLGRET<>2'

Call DEBTRANS From GLOCK
Gosub TR2
End

#######################################
$TR1
Local Char SOCIETE (GLONCPY), OLDMAT(GLONEML)
FCYEFF=0
CPYEFF=0
Read[F:FCY]FCY0=SITE
SOCIETE=[F:FCY]LEGCPY

For [LNK]CTR0 Where [FCY]LEGCPY=SOCIETE & CTRDAT<=DATEDEB & (XITDAT=[0/0/0] | XITDAT>DATEDEB)
 If OLDMAT<>[F:HRCTR]REFNUM : # Cas du multi contrats
  If [F:FCY]FCY=SITE
   FCYEFF+=1
  Endif
  CPYEFF+=1
  OLDMAT = [F:HRCTR]REFNUM
 Endif
Next
Return

#######################################
$TR2
GOK = 1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=[L]ETAT & USR=GUSER & CREDAT<date$
 If fstat=1
  GOK = -1 : GLOCK = "AREPORTM"-GUSER : Goto ROLL_TR2
 Endif
 LIG = 0
 For [HRCTR]CTR0 Where evalue(CRIT1)
  LIG +=1
  [F:ARM]CREDAT = date$
  [F:ARM]USR    = GUSER
  [F:ARM]RPTCOD = [L]ETAT
  [F:ARM]NUMREQ = [L]NUMREQ
  [F:ARM]NUMLIG = LIG
  [F:ARM]CLEA1  = [F:HRCTR]CTRNUM
  # 6 = MEDECINE DU TRAVAIL
#MIPEA - 2016-09-28 - X3PEOP-752 - START
Local Integer ORGLINE
Local Integer COUNTER
If clalev([F:PCA])=0 : Local File CAISSE [PCA] : Endif
If !clalev([F:ADIZZ]) : Local File ATABDIV [ADIZZ]    : Endif

Filter [ADIZZ] Where [ADIZZ]NUMTAB = 10469 & [ADIZZ]LEG = GCURLEG # & [ADIZZ]CODE = [V]GINDMED

For [ADIZZ]
  [L]COUNTER+=1
    If [ADIZZ]CODE = [V]GINDMED
      [L]ORGLINE=[L]COUNTER-1 : Break
    Endif
Next
  Call ORGANISME ([F:HRCTR]REFNUM,[L]SITE,[F:HRCTR]CTRNUM,[F:ARM]CLEA2,[L]ORGLINE) From SUBORG
  #Call ORGANISME ([F:HRCTR]REFNUM,[L]SITE,[F:HRCTR]CTRNUM,[F:ARM]CLEA2,GINDMED-1) From SUBORG
#MIPEA - 2016-09-28 - X3PEOP-752 - END
  [F:ARM]CLEA3  = [F:HRCTR]REFNUM
  [F:ARM]CLED1  = [F:HRCTR]CTRDAT
  Write [F:ARM]
  If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Break : Endif
 Next
 If !GOK : Goto AB_TR2 : Endif
Commit
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

$AB_TR2
Rollback
Return

#######################################
Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End

