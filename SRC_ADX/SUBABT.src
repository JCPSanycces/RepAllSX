#<AdxTL>@(#)154.0.0.0 $Revision$
Raz GPILOBJ , GNBMASKOUV
Call OBJET("ABT",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "SETBOUT"     : Gosub SETBOUT
 When "AVANT_OUVRE" : Gosub AVANT_OUVRE
 When "LIENS"       : Gosub LIENS
Endcase
Return

#-------------------------------------------------------------------------------------------------------#
# La table ABATTAC étant de type X3 communes à plusieurs dossiers et l'intitulé
# étant du type ATX, il est nécessaire d'ouvrir la table ATEXTE dans le dossier X3
#-------------------------------------------------------------------------------------------------------#

$SETBOUT
If CLECUR=0 or REP="M" or !VERROU or nomap<>GDOSX3
 Call VIREBOUT(CHAINE,"2") From GOBJET : # Copie
Endif
Return

$AVANT_OUVRE
Local Char DOSX3(GLONADS)
If clalev([F:ADW])=0 : Local File ADOVAL [ADW] : Endif
Read [ADW]ADW0 = "";"";"SUPDOS"
DOSX3 = [F:ADW]VALEUR
If DOSX3="" : DOSX3 = "X3" : Endif
Local File =DOSX3+".ATEXTE" [ATX]
Return

$LIENS
Local Integer TYP
Local Char    FONC(GLONAFC)
TYP = [M]TYPTAC
Gosub GRITAC
FONC = [M]FONCTION
Gosub GRIFONC
Call TEXTE([M]DES,[M]ZDES) From OBJDIV
Return

#----------------------------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File ABATTAC [ABT1]
 Local File ATEXTE  [ATX1]
Elsif func DOSCONT.DOSX3([M]DOSORG)<>"" : # On a trouvé le dossier racine
 Local File =func DOSCONT.DOSX3([M]DOSORG)+".ABATTAC" [ABT1]
 Local File =func DOSCONT.DOSX3([M]DOSORG)+".ATEXTE"  [ATX1]
Else
 Call ECR_TRACE(func DOSCONT.DOSX3([M]DOSORG)-":"-mess(106,125,1),1) From GESECRAN : # Dossier inaccessible
 Return
Endif
If [M]DOSDES=nomap
 Local File ABATTAC [ABT2]
 Local File ATEXTE  [ATX2]
Elsif func DOSCONT.DOSX3([M]DOSDES)<>"" : # On a trouvé le dossier racine
 Local File =func DOSCONT.DOSX3([M]DOSDES)+".ABATTAC" [ABT2]
 Local File =func DOSCONT.DOSX3([M]DOSDES)+".ATEXTE"  [ATX2]
Else
 Call ECR_TRACE(func DOSCONT.DOSX3([M]DOSDES)-":"-mess(106,125,1),1) From GESECRAN : # Dossier inaccessible
 Return
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ABT1] , [ATX1] , [ABT2] , [ATX2]
Return

$TR_COP
GOK = 1
Trbegin [ABT2]
 Delete [ABT2] Where CODTAC=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ABATTAC" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ABT2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ABT1]CODTAC Where CODTAC=TABLE
  [F:ABT2] = [F:ABT1]
  Write [ABT2]
  If GOK<1 : Break : Endif
  Call COPTEXTE([F:ABT1]DES,[F:ABT2]DES) From OBJDIV
  If GOK<1 : Break : Endif
 Next ABT1
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#-------------------------------------------#
Subprog C_TRAIT(VALEUR)
Variable Char VALEUR
If (VALEUR="" & [M]TYPTAC=2) or (VALEUR="" & [M]FONCTION="")
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 2 : End
Endif
If [M]TYPTAC=1
 VALEUR=toupper(VALEUR)
Endif
End

Subprog C_PROGPAR(VALEUR)
Variable Char VALEUR
Local Integer OKTRT
If VALEUR <> ""
 Call EXISTE_ADX("",[M]DOSPAR,VALEUR,OKTRT) From ORDSYS
 If !OKTRT
  GMESSAGE = VALEUR-":"-mess(159,100,1) : # Programme inexistant
  mkstat = 2 : End
 Endif
Endif
End

Subprog C_PRIO(VALEUR)
If VALEUR>39
 mkstat = 1
Endif
End

Subprog C_TYPTAC(VALEUR)
Variable Integer VALEUR
Local Integer TYP
[M]TYPTAC = VALEUR
TYP = VALEUR : Gosub GRITAC
End

$GRITAC
If TYP=2
 [M]FONCTION = ""
 [M]PARAM = ""
 Grizo FONCTION, PARAM
 Actzo TRAIT
Else
 Actzo FONCTION
Endif
Local Char    FONC(GLONAFC)
FONC = [M]FONCTION
Gosub GRIFONC
Return

Subprog IB_FONCTION
End

Subprog C_FONCTION(VALEUR)
Variable Char    VALEUR()
Call LECTURE("AFC",VALEUR,"") From CONTOBJ
If [F:AFC]ACTION<>""
 Read [ACT]ACTION = [F:AFC]ACTION
 If dim([F:ACT]ABTFLG) & [F:ACT]ABTFLG<>2
  GMESSAGE = [F:AFC]ACTION-":"-mess(154,133,1) : # Action non gérée dans cette fonction
  mkstat = 2 : End
 Endif
Endif
Local Char    FONC(GLONAFC)
FONC = VALEUR
Gosub GRIFONC
End

$GRIFONC
If FONC<>""
 Call LECTURE("AFC",FONC,"") From CONTOBJ
# Est-ce une fonction web ?
 If [F:AFC]ACTION<>""
  [M]TRAIT = ""
  Grizo TRAIT
 Else
  Actzo TRAIT
  Chgfmt [M]TRAIT With "K:12u>18u"
 Endif
 K = 0
 For I=0 To [F:AFC]NBVAR-1
  If [F:AFC]VALEUR(I)="#" : K = 1 : Break : Endif
 Next I
 If K
  If [F:AFC]AIDE<>0
   Call TEXTE([F:AFC]AIDE,[M]AIDE) From OBJDIV
  Else
   [M]AIDE = ""
  Endif
  Affzo AIDE
  Actzo PARAM
 Else
  [M]PARAM = ""
  Grizo PARAM
 Endif
Else
 Actzo TRAIT
 [M]AIDE = ""
 Affzo AIDE
 If [M]TYPTAC=2
  [M]PARAM = ""
  Grizo PARAM
  Chgfmt [M]TRAIT With "K:12X>18X"
 Else
  Actzo PARAM
  Chgfmt [M]TRAIT With "K:12u>18u"
 Endif
Endif
Return

Subprog B1_FONCTION(VALEUR)
Variable Char    VALEUR()
Local Integer L_CLT
L_CLT = GCONSULT
GCONSULT = 2 # Bug 84823
Call OBJET("AFC",VALEUR,"") From GOBJET
GCONSULT = L_CLT
End


