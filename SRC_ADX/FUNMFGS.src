#<AdxTL>@(#)6.0.0.0 $Revision$
###########################################################################
# FUNMFGS  : Situation OF ou Solde/cloture OF         LLC - MAR      1999 #
#
# Version modelisée                                   MM - Septembre  2003
#
# - modèle : traitement standard (GTRAITE) avec liste de gauche
# - Ecrans : MFS0,MFS1,MFS2,MFS3,MFS4
# - Fenêtre : IMCLOSE ou IMSITU
# - Objet : MFG
# - Action TRTMCLOSE ou TRTMSITU
###########################################################################

$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "INIT"          :  Gosub INIT
 When Default
Endcase

#--- Actions liées à la fenêtre de saisie
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "FILGAUCHE"     : Gosub FILGAUCHE
 When "GAU"           : Gosub GAU
 When "SETBOUT"       : Gosub SETBOUT
 When "BOUTON"        : Gosub BOUTON
 When "FIN"           : Gosub FIN
 When "RAF"           : Gosub RAFRAICHIR
Endcase

Return

#########################################################################
# Actions du traitement standard (traitement GTRAITE)                   #
#########################################################################

$INIT
#
Global Integer GTITRE
# récupération de la valeur du code activité titre
Call LECACT("TIT",GTITRE) From TRTX3

Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Gosub CHARG_PARAM

Global   Date     GCLODAT        # FQ 67234 date de cloture à appliquer

Return

#########################################################################
# Actions de la saisie fenêtre (traitement GSAISIE)                     #
#########################################################################

$OUVRE
Local    Char       WVCR(GLONVCR) : WVCR = PARAM(1)        # numéro OF

Local Integer  L,I
Local Integer  REPONSE, WOK
Global   Date     GCLODAT        # date de cloture à appliquer

#
If clalev ([F:MFG]) <= 0 : Local File MFGHEAD    [MFG] : Endif
If clalev ([F:MFI]) <= 0 : Local File MFGITM     [MFI] : Endif
If clalev ([F:MFM]) <= 0 : Local File MFGMAT     [MFM] : Endif
If clalev ([F:MKM]) <= 0 : Local File MFGMATTRK  [MKM] : Endif     # FQ 55435
If clalev ([F:MFO]) <= 0 : Local File MFGOPE     [MFO] : Endif
If clalev ([F:MFP]) <= 0 : Local File MFGPRN     [MFP] : Endif
If clalev ([F:MTS]) <= 0 : Local File MFGTRS     [MTS] : Endif
If clalev ([F:FCY]) <= 0 : Local File FACILITY   [FCY] : Endif
If clalev ([F:ITM]) <= 0 : Local File ITMMASTER  [ITM] : Endif
If clalev ([F:ITF]) <= 0 : Local File ITMFACILIT [ITF] : Endif
If clalev ([F:ITV]) <= 0 : Local File ITMMVT     [ITV] : Endif
If clalev ([F:ITG]) <= 0 : Local File ITMCATEG   [ITG] : Endif
If clalev ([F:MWS]) <= 0 : Local File WORKSTATIO [MWS] : Endif
If clalev ([F:SCH]) <= 0 : Local File SCHEDULING [SCH] : Endif
If clalev ([F:TUN]) <= 0 : Local File TABUNIT    [TUN] : Endif
If clalev ([F:ORD]) <= 0 : Local File ORDERS     [ORD] : Endif
If clalev ([F:OPS]) <= 0 : Local File OPERATIONS [OPS] : Endif
If clalev ([F:POQ]) <= 0 : Local File PORDERQ    [POQ] : Endif
If clalev ([F:STJ]) <= 0 : Local File STOJOU     [STJ] : Endif
If clalev ([M:OPSK])<= 0 : Local Mask OPSK       [OPSK]: Endif
If clalev ([M:ORDK])<= 0 : Local Mask ORDK       [ORDK]: Endif
If clalev ([M:MTMK])<= 0 : Local Mask MTMK       [MTMK]: Endif
If clalev ([M:STW]) <= 0 : Local Mask STOWORK    [STW] : Endif
If clalev ([M:ALP]) <= 0 : Local Mask ALLPAR     [ALP]   Endif
If clalev ([M:SOW]) <= 0 : Local Mask STOSORW    [SOW]   Endif
If clalev ([F:TRU]) <= 0 : Local File TABALLRUL  [TRU] : Endif
If clalev ([F:SRU]) <= 0 : Local File TABSTORUL  [SRU] : Endif
#  11.04
If clalev ([F:MKM]) <= 0 : Local File MFGMATTRK  [MKM] : Endif
If clalev ([F:MKO]) <= 0 : Local File MFGOPETRK  [MKO] : Endif
If clalev ([F:CAL]) <= 0 : Local File CPTANALIN  [CAL] : Endif
If !clalev([M:SVW]) : Local Mask STOVALWORK [SVW] : Endif

# Pour création WIP des composants uniquement valorisés
If !clalev([F:MWH]) : Local File MFGWIP     [MWH] : Endif
If !clalev([F:MWI]) : Local File WIPCOST    [MWI] : Endif
If !clalev([F:BOH]) : Local File BOM        [BOH] : Endif
If !clalev([F:BOD]) : Local File BOMD       [BOD] : Endif
If !clalev([F:TCM]) : Local File TABCOSTMET [TCM] : Endif
If !clalev([F:ITG]) : Local File ITMCATEG   [ITG] : Endif
If !clalev([F:ITM]) : Local File ITMMASTER  [ITM] : Endif
If !clalev([F:ITF]) : Local File ITMFACILIT [ITF] : Endif
If !clalev([F:OVE]) : Local File OVERHEAD   [OVE] : Endif

If !clalev([M:STW]) : Local Mask STOWORK    [STW] : Endif
If !clalev([M:VALW]): Local Mask STOVALW   [VALW] : Endif
If GWRHACT=2
   If !clalev([F:WRH])  Local File WAREHOUSE  [WRH] : Endif
   If !clalev([F:ITW])  Local File ITMWRH     [ITW] : Endif
Endif

Gosub STK_INILOC From STKLOC

#  08.02 demande 15029
Local Mask JALK   [JALK]                                             # ecran pour jalonnement
If clalev([F:PJA])<=0 : Local File PARJAL     [PJA] : Endif          # Paramètres jalonnement

# V6 Affectations : # GH 19/05/2014 bug 100108
Gosub OPEN_MTO From MTOLINKLIB

# seulement si cloture/solde
If find(GMFGCLOSE,"3","4")
    Read [F:MTS]MTS0 = 2;GCLEMTSNUM
    If fstat : Raz [F:MTS] : [F:MTS]OPEUOMMOD = 1 : Endif
Endif

If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
Call LECTCA(8,WOK) From SUBTCA
If WOK=0
   # Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN
   Return
Endif
GOPS = [F:TCA]CODNUM(4)   # compteur encours opérations
Return

#########################################################################
$DEBUT
Raz [M:MFS0]
Raz [M:MFS1]
Raz [M:MFS2]
Raz [M:MFS3]
Raz [M:MFS4]

If WVCR <> ""
    [M:MFS0]MFGNUM = WVCR
    Gosub LOAD_SITU
Endif
Return

########################################################################
#  08.04 demande 24301
$APRES_MODIF
If find(COUZON,"MFGFCY","MFGNUM")
    Gosub FILGAUCHE
    # Issue 80297 - 2012-02-23 by CCC
    #Gosub REMPLIT_1 From WGIMSITU
    Gosub REMPLIT_1 From ="WG"+BOITE
Endif
Return

#########################################################################
$FILGAUCHE
Local Char WFCY(GLONFCY)
#  05.03 filtre sur WGGFLG
Case GMFGCLOSE
     When "3":     If dim([F:MFG]WGGFLG) > 0
                      FILGAUSUP(0)= "MFGSTA=1 & find(MFGTRKFLG,4,5) & !find([F:MFG]WGGFLG,3,4,8)"   # 71913 mm 05.11
                   Else
                      FILGAUSUP(0)="MFGSTA=1 & find(MFGTRKFLG,4,5)"
                   Endif
     When "4":     FILGAUSUP(0)="MFGSTA=4 & MFGTRKFLG < 6"
     When Default: FILGAUSUP(0)="MFGSTA=1"
Endcase

#  08.04 demande 24301
If COUZON="MFGFCY"
    If CZ<>"" FILGAUSUP(0)+='&[F:MFG]MFGFCY=CZ'        Endif
Elsif COUZON = "MFGNUM"
        If CZ <> ""
             Read [F:MFG]MFG0 = CZ
             If fstat : Raz  [F:MFG] : Endif
             WFCY = [F:MFG]MFGFCY
             FILGAUSUP(0)+='&[F:MFG]MFGFCY=WFCY'
        Endif
Else
        FILGAUSUP(0)+='&[F:MFG]MFGFCY=GFCY'
Endif
Return

#########################################################################
# GH 16/12/2013 bug 94952 réaffichage liste gauche + fiche en cours sur F5
$RAFRAICHIR
Raz IFILSUITE, FILSUITE : # GH 21/01/2014 bug 96000
Gosub LOAD_SITU : COUZON = ""
Return

#########################################################################
$GAU
[M:MFS0]MFGFCY = [F:MFG]MFGFCY

GFCY=[M:MFS0]MFGFCY
If GMODU(2)=2 : # Dossier avec module comptabilité
  Call GLOBVAR(GFCY)  From WWGLOBCPT
  #----- Chargement des globales référentiels, comptes et sections de la société -----#
  Call GETCPY(GFCY,"",0,"") From TRTX3CPT
Endif

[M:MFS0]MFGNUM = [F:MFG]MFGNUM
Gosub LOAD_SITU

Return

###########################################################################
# chargement masques
$LOAD_SITU
Raz [M:MFS1]
Raz [M:MFS2]
Raz [M:MFS3]
Raz [M:MFS4]

Local Integer I, WRET
Local Decimal WDIS
#
Read [MFG]MFG0=[M:MFS0]MFGNUM
If fstat : Return : Endif
#
If [F:MFG]MFGFCY <> [M:MFS0]MFGFCY
    [M:MFS0]MFGFCY = [F:MFG]MFGFCY
Endif
[M:MFS0]MFGSTA = [F:MFG]MFGSTA
#
If GPILNAV>1 & find(GNAVIG(GPILNAV-1),"GESMFG")             # FQ 67910 GA 10/2010 ajout  Affzo et Diszo
    Affzo [M:MFS0] : Diszo [M:MFS0]MFGFCY : Diszo [M:MFS0]MFGNUM
    Call CTL_MFGNUM([M:MFS0]MFGNUM,GMESSAGE)                # FQ 67910 GA 10/2010 attention aux contrôles prévus
    If GMESSAGE<>""
        Call ECR_TRACE(GMESSAGE,0) From GESECRAN
        GMESSAGE=""                                         # Issue 111882 - 2015-12-09 by GH : not to display message twice
        Return
    Endif
Endif
#
[M:MFS1] = [F:MFG]

[M:MFS1]OKCPLQTY = [F:MFG]CPLQTY - [F:MFG]REJCPLQTY - [F:MFG]QUACPLQTY
[M:MFS0]XMFGSTA = mess([M:MFS0]MFGSTA,317,1)
[M:MFS1]XMFGMOD = mess([M:MFS1]MFGMOD,333,1)
[M:MFS1]XSCDMOD = mess([M:MFS1]SCDMOD,334,1)
[M:MFS1]XALLSTA = mess([M:MFS1]ALLSTA,336,1)
If [F:MFG]OPTFLG <> 2
    [M:MFS1]XMFGTRKFLG = mess([M:MFS1]MFGTRKFLG,339,1)
Else
    [M:MFS1]XMFGTRKFLG = mess(2,339,1)
Endif
[M:MFS1]XSCDFLG = mess([M:MFS1]SCDFLG,335,1)
#
I = 0
For [MFI]MFI0 Where MFGNUM=[M:MFS0]MFGNUM
    # llc 02.02    12772
    nolign = I + 1
    [M:MFS2] = [F:MFI]

    [M:MFS2]BOMALT(I)     = [F:MFI]BOMALT
    [M:MFS2]BPCNUM(I)     = [F:MFI]BPCNUM
    [M:MFS2]BPCTYPDEN(I)  = [F:MFI]BPCTYPDEN
    [M:MFS2]CPLQTY(I)     = [F:MFI]CPLQTY
    [M:MFS2]EXTQTY(I)     = [F:MFI]EXTQTY
    [M:MFS2]ITMREF(I)     = [F:MFI]ITMREF
    [M:MFS2]ITMTYP(I)     = [F:MFI]ITMTYP # llc 04.00 (sous-produit)
    [M:MFS2]ITMSTA(I)     = [F:MFI]ITMSTA
    [M:MFS2]LOT(I)        = [F:MFI]LOT
    [M:MFS2]MFGDES(I)     = [F:MFI]MFGDES
    [M:MFS2]PJT(I)        = [F:MFI]PJT
    [M:MFS2]QUACPLQTY(I)  = [F:MFI]QUACPLQTY
    [M:MFS2]REJCPLQTY(I)  = [F:MFI]REJCPLQTY
    [M:MFS2]RMNEXTQTY(I)  = [F:MFI]RMNEXTQTY
    [M:MFS2]STU(I)        = [F:MFI]STU
    [M:MFS2]UOM(I)        = [F:MFI]UOM
    [M:MFS2]UOMEXTQTY(I)  = [F:MFI]UOMEXTQTY
    [M:MFS2]UOMSTUCOE(I)  = [F:MFI]UOMSTUCOE
    Read [ITM]ITM0 = [F:MFI]ITMREF
    #If !fstat : [M:MFS2]ITMDES1(I) = [F:ITM]ITMDES1 : Endif
    If !fstat
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MFS2]ITMDES1(I), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    Endif

    [M:MFS2]AFFFLG(I) = 2
    [M:MFS2]NUMLIG(I) = [M:MFS2]NBCPS+1
    [M:MFS2]NUMLIGCPS([M:MFS2]NBCPS)   = I+1
    [M:MFS2]CPSREF([M:MFS2]NBCPS)      = [F:MFI]ITMREF
    [M:MFS2]STUG([M:MFS2]NBCPS)        = [F:MFI]STU
    [M:MFS2]EXTQTYG([M:MFS2]NBCPS)     = [F:MFI]EXTQTY
    [M:MFS2]CPLQTYG([M:MFS2]NBCPS)     = [F:MFI]CPLQTY
    [M:MFS2]NBCPS +=1

    I += 1
Next
[M:MFS2]NBLIG = I

#
I=0
For [MFM]MFM0 Where MFGNUM=[M:MFS0]MFGNUM
&                 & CPNTYP<4
    # llc 02.02    12772
    nolign = I + 1
    [M:MFS3] = [F:MFM]
    [M:MFS3]XMATSTA(I) = mess([M:MFS3]MATSTA(I),363,1)
    If [M:MFS3]CPNTYP(I) = 5
       [M:MFS3]XMATSTA(I) = mess(38,198,1)
    Endif
    [M:MFS3]ALLQTY(I)     = [F:MFM]ALLQTY
    [M:MFS3]BOMOPE(I)     = [F:MFM]BOMOPE
    [M:MFS3]BOMSEQ(I)     = [F:MFM]BOMSEQ
    [M:MFS3]CUMFLG(I)     = [F:MFM]CUMFLG
    [M:MFS3]ITMREF(I)     = [F:MFM]ITMREF
    [M:MFS3]MATSTA(I)     = [F:MFM]MATSTA
    [M:MFS3]MFGLIN(I)     = [F:MFM]MFGLIN
    [M:MFS3]PICPRN(I)     = [F:MFM]PICPRN
    [M:MFS3]PLANNER(I)    = [F:MFM]PLANNER
    [M:MFS3]RETDAT(I)     = [F:MFM]RETDAT
    [M:MFS3]RETQTY(I)     = [F:MFM]RETQTY
    [M:MFS3]SCA(I)        = [F:MFM]SCA
    [M:MFS3]SCOFLG(I)     = [F:MFM]SCOFLG
    [M:MFS3]SHTQTY(I)     = [F:MFM]SHTQTY
    [M:MFS3]STU(I)        = [F:MFM]STU
    [M:MFS3]USEQTY(I)     = [F:MFM]USEQTY
    [M:MFS3]MFMITMREF(I)  = [F:MFM]ITMREF
    If [F:MFM]CPNTYP <> 5
        Read [ITM]ITM0 = [F:MFM]ITMREF
        #If !fstat : [M:MFS3]ITMDES1(I) = [F:ITM]ITMDES1 : Endif
        If !fstat
          Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MFS3]ITMDES1(I), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
        Endif

        Call LECITV2([M:MFS0]MFGFCY,[F:MFM]ITMREF,WRET) From MFGLIB
        # 81893
        Call STODISTOT("",0,0,"",WDIS) From STKLIB
        [M:MFS3]AVAQTY(I)    = WDIS + [F:MFM]ALLQTY                    # llc 09.02 15756 + 18847

        # (titres llc 130)
        If [F:ITF]STOMGTCOD <> 3
            If dim([M:MFS3]TYPQTY(I)) > 0 : [M:MFS3]TYPQTY(I) = 2 : Endif
        Else
            If dim([M:MFS3]TYPQTY(I)) > 0 : [M:MFS3]TYPQTY(I) = 1 : Endif
        Endif
    Endif

    # Graphique
    [M:MFS3]AFFFLG(I) = 2
    [M:MFS3]NUMLIG(I) = [M:MFS3]NBCPN+1
    [M:MFS3]NUMLIGCPN([M:MFS3]NBCPN)   = I+1
    [M:MFS3]MATREF([M:MFS3]NBCPN)      = [F:MFM]ITMREF
    [M:MFS3]STUG([M:MFS3]NBCPN)        = [F:MFM]STU
    [M:MFS3]RETQTYG([M:MFS3]NBCPN)     = [F:MFM]RETQTY
    [M:MFS3]USEQTYG([M:MFS3]NBCPN)     = [F:MFM]USEQTY
    [M:MFS3]NBCPN +=1

    I += 1
Next
#  11.04 visualiser les lignes ajoutées au suivi
For [F:MKM] Where MFGNUM = [F:MFG]MFGNUM & MFMITMREF = ""
    nolign = I + 1
    [M:MFS3] = [F:MKM]
    [M:MFS3]BOMOPE(I)     = [F:MKM]OPENUM
    [M:MFS3]BOMSEQ(I)     = [F:MKM]BOMSEQ
    [M:MFS3]MATSTA(I)     = 3
    Read [ITM]ITM0 = [F:MKM]ITMREF
    #If !fstat : [M:MFS3]ITMDES1(I) = [F:ITM]ITMDES1 : Endif
    If !fstat
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MFS3]ITMDES1(I), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    Endif

    Call LECITV2([M:MFS0]MFGFCY,[F:MKM]ITMREF,WRET) From MFGLIB
    Call STODISTOT("",0,0,"",WDIS) From STKLIB
    # 81893
    [M:MFS3]AVAQTY(I)    = WDIS
    If [F:ITF]STOMGTCOD <> 3
        If dim([M:MFS3]TYPQTY(I)) > 0 : [M:MFS3]TYPQTY(I) = 2 : Endif
    Else
        If dim([M:MFS3]TYPQTY(I)) > 0 : [M:MFS3]TYPQTY(I) = 1 : Endif
    Endif

    If [F:MKM]CPNTYP<4
        [M:MFS3]AFFFLG(I) = 2
        [M:MFS3]NUMLIG(I) = [M:MFS3]NBCPN+1
        [M:MFS3]NUMLIGCPN([M:MFS3]NBCPN)   = I+1
        [M:MFS3]MATREF([M:MFS3]NBCPN)      = [F:MKM]ITMREF
        [M:MFS3]STUG([M:MFS3]NBCPN)        = [F:MKM]STU
        [M:MFS3]RETQTYG([M:MFS3]NBCPN)     = 0
        [M:MFS3]USEQTYG([M:MFS3]NBCPN)     = [F:MKM]USEQTY
        [M:MFS3]NBCPN +=1
    Endif

    I += 1
Next
# fin  11.04

[M:MFS3]NBLIG = I
#
I=0
For [MFO]MFO0 Where MFGNUM=[M:MFS0]MFGNUM
    # llc 02.02    12772
    nolign = I + 1
    [M:MFS4] = [F:MFO]

    [M:MFS4]BPSNUM(I)     = [F:MFO]BPRNUM
    [M:MFS4]CPLLAB(I)     = [F:MFO]CPLLAB
    [M:MFS4]CPLOPETIM(I)  = [F:MFO]CPLOPETIM
    [M:MFS4]CPLQTY(I)     = [F:MFO]CPLQTY
    [M:MFS4]CPLSETTIM(I)  = [F:MFO]CPLSETTIM
    [M:MFS4]CPLWST(I)     = [F:MFO]CPLWST
    [M:MFS4]CPLWSTNBR(I)  = [F:MFO]CPLWSTNBR
    [M:MFS4]CPLLABNBR(I)  = [F:MFO]CPLLABNBR
    [M:MFS4]EXTLAB(I)     = [F:MFO]EXTLAB
    [M:MFS4]EXTOPETIM(I)  = [F:MFO]EXTOPETIM
    [M:MFS4]EXTQTY(I)     = [F:MFO]EXTQTY
    [M:MFS4]EXTSETTIM(I)  = [F:MFO]EXTSETTIM
    [M:MFS4]EXTWST(I)     = [F:MFO]EXTWST
    [M:MFS4]EXTWSTNBR(I)  = [F:MFO]EXTWSTNBR
    [M:MFS4]EXTLABNBR(I)  = [F:MFO]EXTLABNBR
    [M:MFS4]OPEEND(I)     = [F:MFO]OPEEND
    [M:MFS4]OPENUM(I)     = [F:MFO]OPENUM
    [M:MFS4]OPESPLNUM(I)  = [F:MFO]OPESPLNUM
    [M:MFS4]OPESTA(I)     = [F:MFO]OPESTA
    [M:MFS4]OPESTR(I)     = [F:MFO]OPESTR
    [M:MFS4]OPEUOM(I)     = [F:MFO]OPEUOM
    [M:MFS4]POHNUM(I)     = [F:MFO]POHNUM
    [M:MFS4]POPLIN(I)     = [F:MFO]POPLIN
    [M:MFS4]POPSEQ(I)     = [F:MFO]POPSEQ
    [M:MFS4]REJCPLQTY(I)  = [F:MFO]REJCPLQTY
    [M:MFS4]TIMUOMCOD(I)  = [F:MFO]TIMUOMCOD
    [M:MFS4]ROUOPENUM(I)  = [F:MFO]OPENUM
    Read [MWS]WST0=[F:MFO]EXTWST;[F:MFO]MFGFCY
    If !fstat
        [M:MFS4]WCR(I)    = [F:MWS]WCR
        [M:MFS4]WSTTYP(I) = [F:MWS]WSTTYP
    Endif
    Read [MWS]WST0=[F:MFO]EXTLAB;[F:MFO]MFGFCY
    If !fstat
        [M:MFS4]LABWCR(I) = [F:MWS]WCR
    Endif
    Read [F:SCH]SCH0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
    If fstat : Raz [F:SCH] : Endif
    [M:MFS4]DACMST(I) = [F:SCH]DACMST

    [M:MFS4]AFFFLG(I) = 2
    [M:MFS4]NUMLIG(I) = [M:MFS4]NBOPE+1
    [M:MFS4]NUMLIGOPE([M:MFS4]NBOPE)   = I+1
    [M:MFS4]OPENUMG([M:MFS4]NBOPE) = num$([F:MFO]OPENUM)+string$([F:MFO]OPESPLNUM>0," / "+num$([F:MFO]OPESPLNUM))
    [M:MFS4]STUG([M:MFS4]NBOPE) = [F:MFO]OPEUOM
    [M:MFS4]EXTQTYG([M:MFS4]NBOPE) = [F:MFO]EXTQTY
    [M:MFS4]CPLQTYG([M:MFS4]NBOPE) = [F:MFO]CPLQTY
    [M:MFS4]NBOPE += 1

    I += 1
Next
#  11.04 visualiser les lignes ajoutées au suivi
For [F:MKO] Where MFGNUM = [F:MFG]MFGNUM & ROUOPENUM = 0
    nolign = I + 1
    [M:MFS4] = [F:MKO]
    [M:MFS4]OPESTA(I)     = 5
    Read [MWS]WST0=[F:MKO]CPLWST;[F:MKO]MFGFCY
    If !fstat
        [M:MFS4]WCR(I)    = [F:MWS]WCR
        [M:MFS4]WSTTYP(I) = [F:MWS]WSTTYP
    Endif
    Read [MWS]WST0=[F:MKO]CPLLAB;[F:MKO]MFGFCY
    If !fstat
        [M:MFS4]LABWCR(I) = [F:MWS]WCR
    Endif

    [M:MFS4]AFFFLG(I) = 2
    [M:MFS4]NUMLIG(I) = [M:MFS4]NBOPE+1
    [M:MFS4]NUMLIGOPE([M:MFS4]NBOPE)   = I+1
    [M:MFS4]OPENUMG([M:MFS4]NBOPE) = num$([F:MKO]OPENUM)+string$([F:MKO]OPESPLNUM>0," / "+num$([F:MKO]OPESPLNUM))
    [M:MFS4]STUG([M:MFS4]NBOPE) = [F:MKO]OPEUOM
    [M:MFS4]EXTQTYG([M:MFS4]NBOPE) = 0
    [M:MFS4]CPLQTYG([M:MFS4]NBOPE) = [F:MKO]CPLQTY
    [M:MFS4]NBOPE += 1
    I += 1
Next
# fin  11.04
[M:MFS4]NBLIG = I
#
Read [F:MFP]MFP0 = [F:MFG]MFGNUM
If !fstat [M:MFS0]WPRN = [F:MFP]MFGFDRFLG : Endif

#  09.04 initialiser le site demande 25272
If [M:MFS0]MFGFCY = "" : [M:MFS0]MFGFCY = GFCY : Endif
# seulement si cloture/solde
If GMFGCLOSE = "3"
    # 90256 mm 04.2014 - si OF clos, ne pas réinitialiser sa date de clôture à date$
    If [M:MFS0]MFGSTA < 4  : [M:MFS1]CLODAT = date$ : Endif
    Actzo [M:MFS1]CLODAT
Else
    Grizo [M:MFS1]CLODAT
Endif
If dim(GCLODAT)<=0 Global Date GCLODAT  Endif  # FQ 67910 GA 10/2010
GCLODAT = [M:MFS1]CLODAT
Affzo [M:MFS0]
Affzo [M:MFS1]
Affzo [M:MFS2]
Affzo [M:MFS3]
Affzo [M:MFS4]

Return

########################################################################
$SETBOUT
# inactivation bouton détail suivi
If [M:MFS1]MFGTRKFLG <= 3
 Call VIREBOUT(CHMEN,"A") From GOBJET
Endif
#  08.04 demande 24301
If [M:MFS0]MFGNUM = "" : Call VIREBOUT(CHMEN,"BCD") From GOBJET : Endif

# FQ 67910 GA 10/2010 sauf si infos non chargées suite CTL_MFGNUM
If [M:MFS0]XMFGSTA = "" : Call VIREBOUT(CHMEN,"BCD") From GOBJET : Endif
Case GMFGCLOSE
        When "3":    # Issue 109749 - 2015-12-11 by BEEBE : if WO is locked by another user
                     If ([M:MFS1]MFGTRKFLG <> 4 | func MFGLIB.CHKMFGLOCK([M:MFS0]MFGNUM,0)) # inactivation bouton solde
                         Call VIREBOUT(CHMEN,"B") From GOBJET
                     Endif
                     # Issue 109749 - 2015-12-11 by BEEBE : if WO is locked by another user
                     If ([M:MFS0]MFGSTA >=4 | [M:MFS0]MFGSTA =0 | func MFGLIB.CHKMFGLOCK([M:MFS0]MFGNUM,0)) # inactivation bouton clôture
                         Call VIREBOUT(CHMEN,"C") From GOBJET
                     Endif
        When "4":    If ([M:MFS0]MFGSTA <> 4 | [M:MFS1]MFGTRKFLG = 6)  # inactivation bouton réactivation
                        Call VIREBOUT(CHMEN,"D") From GOBJET
                     Endif
Endcase

CHBOU+='=' : # GH 16/12/2013 bug 94952 réactivation de F5
Return


########################################################################
#apres éxécution des boutons, rechargement des écrans avec nouvelle situation
$BOUTON
Case BOUT
    When "B","C","D" :     Gosub LOAD_SITU
Endcase
Return

########################################################################
$CHARG_PARAM
# Issue 86120 - 2012-11-22 by CCC
Call GETCPY(GFCY,"",0,"") From TRTX3CPT

#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return


###########################################################################
# Solde OF
$SOLDE_OF
Local Integer OK,LRET,LOPE,LITM,LMAT,WPREC,WAUTO,WAUTO2
Local Integer WOPECLENBR, WITMCLENBR, WMATCLENBR
#Local Char    WNUMTEX
Local Integer WRETOUR,STAT, WFICFLG
Local Decimal WQTYCONS,WWQTYCONS,WRAPP, WWQTY, WCOEFF
Local Char     WMSG(80)
#  10.04 demande 23789
Local Integer WTRTTYP
WTRTTYP = 1
#
Raz WMSG
# 11552 11.03 MM : fonction solde OF en série, sans message d'avertissement
If dim(GSTOP)<0
    #Demande de validation du solde
    Call OUINON(mess(71,190,1),OK) From GESECRAN
    If OK <> 2 : Return : Endif
Endif

# 98877 mm 06.2014 :  fonction clôture OF en série, sans message d'avertissement
If [F:MFG]CPLQTY < [F:MFG]EXTQTY
    If dim(GQTYCTL) >0
        If GQTYCTL=2 : GWMESS2 = [F:MFG]MFGNUM - mess(74,190,1) : GSTOP=1 : Return : Endif
    Else
        Call AVERTIR(mess(74,190,1),OK) From GESECRAN
        If OK <> 2 : Return : Endif
    Endif
Endif

#Première chose, vérifier que toutes les opé pourront être soldées.
#Les opé de sous-traitance "commandée" ou ("en-cours"et ligne de cde non soldée)
#ne peuvent pas être soldées automatiquement
#De plus si il existe au moins une opé en attente ou un article lancé en attente ou
#une matière en attente alors message
Raz LRET,LOPE,LITM,LMAT
Call CTR_VALID(LRET,LOPE,LITM,LMAT)

# 08.05 31594
If LRET = 9
    If dim(GSSTCMDCTL) > 0
        GWMESS2 = [F:MFG]MFGNUM - mess(84,193,1)
        GSTOP   = 1
        Return
    Else
        Call ERREUR(mess(84,193,1)) From GESECRAN
        Return
    Endif
Endif

# 11552 11.03 MM : fonction solde OF en série, sans message d'avertissement
If LRET = 1
    If dim(GSSTCMDCTL) >0
        If GSSTCMDCTL=2 : GWMESS2 = [F:MFG]MFGNUM - mess(237,193,1) : GSTOP=1 : Return : Endif
    Else
    # Issue 84906 GA 01/2013 pas de solde possible si opé commandée
    ##    Call AVERTIR(mess(91,193,1),OK) From GESECRAN
    ##    If OK <> 2 : Return : Endif
         Call ERREUR(mess(237,193,1)) From GESECRAN
         Return
    Endif
Endif

# 11552 11.03 MM : fonction solde OF en série, sans message d'avertissement
If find(LOPE,1,4)
    If dim(GREACTL) >0
        If GREACTL=2  : GWMESS2 = [F:MFG]MFGNUM -mess(81,190,1) : GSTOP=1 : Return : Endif
    Else
        Call AVERTIR(mess(81,190,1),OK) From GESECRAN
        If OK <> 2 : Return : Endif
    Endif
Endif


# 11552 11.03 MM : fonction solde OF en série, sans message d'avertissement
If LITM = 1
    If dim(GLANCTL) >0
         If GLANCTL=2:  GWMESS2 = [F:MFG]MFGNUM - mess(82,190,1) : GSTOP=1 : Return : Endif
    Else
        Call AVERTIR(mess(82,190,1),OK) From GESECRAN
        If OK <> 2 : Return : Endif
    Endif
Endif


# 11552 11.03 MM : fonction solde OF en série, sans message d'avertissement
If LMAT = 1
    If dim(GCNSCTL) >0
        If GCNSCTL=2 :  GWMESS2 = [F:MFG]MFGNUM - mess(83,190,1) :  GSTOP=1 : Return : Endif
    Else
        Call AVERTIR(mess(83,190,1),OK) From GESECRAN
        If OK <> 2 : Return : Endif
    Endif
Endif

Raz WAUTO,LRET
Raz WAUTO2

# CCC (07/08/07) PE permettant de suivre automatiquement ou non des matières ou opé non soldées.
Raz GPE
GPOINT = "WAUTO" : Gosub ENTREE From EXEFNC

#Deuxième chose; y-a-t-il des matières à mode de déstockage automatique non soldées?
#WAUTO = 0 : On ne suit pas automatiquement les matières
#WAUTO = 1 : On suit automatiquement les matières

If mod(GPE,2)<1
    If [F:MFG]CPLQTY = 0 | [F:MTS]MATTRKFLG <> 2 : WAUTO = 0
    Else Call CTR_MAT(LRET)
        If LRET > 0
            Local Date WDATE : WDATE = date$
            Call STKCTRIPT(WDATE,[F:MFG]MFGFCY,"1") From STKLIB
            # 11552 11.03 MM
            If GMESSAGE = ""
                If  dim(GMATCTL) >0
                    If GMATCTL=2 : WAUTO = 1 : Endif
                Else
                    Raz OK
                    Call OUINON(mess(207,190,1),OK) From GESECRAN
                    If OK = 2: WAUTO = 1 : Endif
                Endif
            Endif
        Endif
    Endif
Endif

#Troisième chose : Proposition de suivi automatique des opés non soldées?
#WAUTO2 = 0 : On ne suit pas automatiquement les opés
#WAUTO2 = 1 : On suit automatiquement les opés

If mod(GPE,4)<2
    If [F:MFG]CPLQTY = 0 | [F:MTS]OPETRKFLG <> 2  : WAUTO2 = 0
    Elsif find(LOPE,1,3,4)
        # 11552 11.03 MM
        If  dim(GOPECTL) >0
            If GOPECTL=2 : WAUTO2 = 1 : Endif
        Else
            Raz OK
            Call OUINON(mess(85,190,1),OK) From GESECRAN
            If OK = 2: WAUTO2 = 1 : Endif
        Endif
    Endif
Endif


#----- Récupération compteur suivi si besoin
If WAUTO > 0 | WAUTO2 > 0
   Local Char WMTKNUM(GLONVCR)
   Local Date WDATE : WDATE = date$
   If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
   Call LECTCA(8,OK) From SUBTCA
   If OK=0
      Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN :
      GOK=0 : LRET = 1 : Return
   Endif
   Call NUMERO([F:TCA]CODNUM(2),[F:MFG]MFGFCY,WDATE,"",WMTKNUM,STAT) From SUBANM
   If STAT <> 0: Call ERREUR(mess(60,199,1)-[F:TCA]CODNUM(2)-num$([L]STAT)) From GESECRAN: GOK = 0 : LRET = 1 : Return : Endif
   GOPS = [F:TCA]CODNUM(4)   # compteur encours opérations

   Close File [F:TCA]
Endif


#----- Variables globales stock
Call GLOBVAR([F:MFG]MFGFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR([F:MFG]MFGFCY)    From WWGLOBGPA
#
If clalev ([F:MTK]) <= 0 : Local File MFGHEADTRK  [MTK] : Endif
If clalev ([F:MKM]) <= 0 : Local File MFGMATTRK   [MKM] : Endif
If clalev ([F:MKO]) <= 0 : Local File MFGOPETRK   [MKO] : Endif
If clalev ([F:SCH]) <= 0 : Local File SCHEDULING  [SCH] : Endif
If clalev ([F:MFOX])<= 0 : Local File MFGOPE      [MFOX]: Endif
If clalev ([F:MWS]) <= 0 : Local File WORKSTATIO  [MWS] : Endif
If clalev ([F:STA]) <= 0 : Local File STOALL      [STA] : Endif
If clalev ([F:STO]) <= 0 : Local File STOCK       [STO] : Endif
If clalev ([F:STL]) <= 0 : Local File STOLOT      [STL] : Endif
#

Call DEBTRANS From GLOCK
Trbegin [MFG]
#----------------------- Solde des opérations -----------------------------#
Filter [F:MFO] Where MFGNUM =[F:MFG]MFGNUM & MFOTRKFLG < 5 & OPESTA <> 6
Local Integer WOPESOL
Raz WOPESOL

For [F:MFO]
    If WPREC = 0 : WPREC = [F:MFO]OPENUM
    Elsif WPREC <> [F:MFO]OPENUM : Gosub CTR_SOLDE
                                   WPREC = [F:MFO]OPENUM
    Endif
    Read [F:MWS]WST0 = [F:MFO]EXTWST;[F:MFO]MFGFCY
    If fstat : Raz [F:MWS] : Endif
    If [F:MWS]WSTTYP = 3 & [F:MFO]OPESTA = 4
       Read [F:OPS]OPS1 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
       If fstat : Raz [F:OPS] : Endif
       Read [F:POQ]POQ0 = [F:OPS]POHNUM;[F:OPS]POPLIN;[F:OPS]POPSEQ
       If fstat : Raz [F:POQ] : Endif
    Endif
    If [F:MWS]WSTTYP<> 3 | [F:MFO]OPESTA <> 7 | ([F:MFO]OPESTA = 4 & [F:POQ]LINCLEFLG = 2)
       If [F:MWS]WSTTYP <> 3 & WAUTO2 = 1 : Gosub SOLDE_OPE
           If GOK < 1 : Break : Endif
#On se repositionne sur la bonne opé avec nouvelles valeurs
           Readlock [F:MFO]MFO0 Curr
       Endif
       [F:MFO]OPESTA = 5
       [F:MFO]MFOTRKFLG = 5
       Gosub MAJ_SUIVANTE From SUBMTKC
       If GOK < 1 : Break : Endif
        # llc 06.02
       [F:MFO]UPDDAT    = date$
       [F:MFO]UPDUSR    = GUSER
       [F:MFO]EXPNUM    = [C]EXPORT
       Rewrite [F:MFO]
       If fstat
          GOK = 0 : Call FSTA("MFO") From GLOCK : Break
       Endif
       Filter [MFI] Where MFGNUM = [F:MFO]MFGNUM
       Read [F:MFI]MFI0 First
       If !fstat
           Call UPDATE_OWX("SA",[F:MFI]PJT) From MFGLIBO
       Endif
       Filter [MFI]
       If [F:MWS]WSTTYP <> 3 : WOPECLENBR += 1 : Endif
    Endif
Next
Gosub CTR_SOLDE
If GOK = 0 : Goto TR_ROLL : Endif
Filter [F:MFO]
#----------------------- Solde des articles   -----------------------------#
Filter [F:MFI] Where MFGNUM = [F:MFG]MFGNUM & MFITRKFLG < 5 & ITMSTA <> 4
For [F:MFI]
       [F:MFI]MFITRKFLG = 5
       [F:MFI]ITMSTA = 3
       Local Integer STA : STA=0
       Call LECITV([F:MFI]MFGFCY, [F:MFI]ITMREF, "",STA) From STKLIB
       If GOK <> 1 | STA > 1 : Break : Endif
       [F:ITV]ORDSTO -= [F:MFI]RMNEXTQTY
       Rewrite [ITV] : If fstat GOK=0 : Call FSTA("ITV") From GLOCK : Break : Endif
       [F:MFI]RMNEXTQTY = 0
       [F:MFI]CLODAT = GCLODAT
       # llc 06.02
       [F:MFI]UPDDAT    = date$
       [F:MFI]UPDUSR    = GUSER
       [F:MFI]EXPNUM    = [C]EXPORT

       Rewrite [F:MFI]
       If fstat
          GOK = 0 : Call FSTA("MFI") From GLOCK : Break
       Endif

       # v6 affectations
       Gosub SUP_MTO_MFI From MFGMTOLIB

       WITMCLENBR += 1
#Maj encours
       Gosub SUP_WIP
       If GOK < 1 : Break : Endif
Next
If GOK < 1 : Goto TR_ROLL : Endif
Filter [F:MFI]
#----------------------- Solde des matières   -----------------------------#
Filter [F:MFM] Where MFGNUM = [F:MFG]MFGNUM & MFMTRKFLG < 5 & MATSTA <> 4 & CPNTYP <> 5
Local Integer WMATSOL
Raz WMATSOL
For [F:MFM]
    If [F:MFM]MFGLIN <> 0
        Read [F:MFI]MFI0 = [F:MFM]MFGNUM;[F:MFM]MFGLIN
        If fstat : GOK=0: Call RSTA("MFI",[F:MFM]MFGNUM) From GLOCK : Break : Endif    # llc 05.02 cohérence
    Else
        Filter [F:MFI] Where MFGNUM = [F:MFM]MFGNUM
        Read [F:MFI]MFI0 First
        If fstat : GOK=0: Call RSTA("MFI",[F:MFM]MFGNUM) From GLOCK : Break : Endif    # llc 05.02 cohérence
        Filter [F:MFI]
    Endif
    Gosub SOLDE_MAT

    # v6 affectations
    Gosub SUP_MTO_MFM From MFGMTOLIB

    If GOK < 1 : Break : Endif
    Call UPDATE_MFX("A", [F:MFI]PJT,[F:MFI]BOMALT, 0) From MFGLIBM
    # llc 06.02
    [F:MFM]UPDDAT    = date$
    [F:MFM]UPDUSR    = GUSER
    [F:MFM]EXPNUM    = [C]EXPORT

    #======== MAJ du champ Situation de pesée="Consommée" = DT-06/07/2010 ====#
    If [F:MFI]ITMSTA = 3
        # 67426 mm 09.10
        If dim([F:MFM]WGGSTAAVS) > 0
            [F:MFM]WGGSTAAVS= [F:MFM]WGGSTA   :# Sauvegarder la situation de pesée avant le solde d'OF
            [F:MFM]WGGSTA   = 8
        Endif
    Endif
    #=========================================================================#

    Rewrite [F:MFM]
    If fstat
       GOK = 0 : Call FSTA("MFM") From GLOCK : Break
    Endif

#------------------------------------------------------------------------------------------------------------------
# point d'entrée WIP costing 14548
    If WAUTO = 1
        If dim(WRET) < 0     : Local Integer WRET       : Endif
        If dim(GWIPCOST) < 0 : Global Char GWIPCOST(20) : Endif
        GWIPCOST = "MATTRK_NEW"
        WRET = 0
        GPOINT = "WIPCOST" : Gosub ENTREE From EXEFNC
        If WRET > 0 : GOK = 0 : Break : Endif
    Endif
#------------------------------------------------------------------------------------------------------------------

Next
If GOK < 1 : Goto TR_ROLL : Endif
#si au moins un suivi opé ou un  suivi matière création de l'entête de suivi
If WMATSOL <> 0 | WOPESOL <> 0
   Raz [F:MTK]
   [F:MTK]          = [F:MFG]
   [F:MTK]NBRMAT    = WMATSOL
   [F:MTK]MTKTEX    = [F:MFG]MFGTEX
   [F:MTK]MFGTRKNUM = WMTKNUM
   [F:MTK]CREDAT    = date$
   [F:MTK]CREUSR    = GUSER
   # Issue 78867 - 2012-02-02 by CCC
   Raz [F:MTK]UPDDAT
   Raz [F:MTK]UPDUSR
   [F:MTK]EXPNUM    = [C]EXPORT
   [F:MTK]NBROPE    = WOPESOL
   [F:MTK]ITMTRKFLG = 1
   If [F:MTK]NBRMAT > 0 : [F:MTK]MATTRKFLG = 2
   Else                 : [F:MTK]MATTRKFLG = 1
   Endif
   If [F:MTK]NBROPE > 0 : [F:MTK]OPETRKFLG = 2
   Else                 : [F:MTK]OPETRKFLG = 1
   Endif
   [F:MTK]MFGTRKDAT =  GCLODAT  # 90256 MM 04.2014 - à la place de date$

    If [F:MTK]MTKTEX <> ""
        #en auto on n'a pas pu saisir du texte, donc si texte il y a, il vient de l'OF et a comme préfixe
        #MFG,ROH ou ITM
        #on ne duplique que si ça vient de l'OF.
        If left$([F:MTK]MTKTEX,3)="MFG"
           Call DUP_CLOB("MTK",[F:MTK]MTKTEX,GOK) From TRTX3TEX
        Endif
    Endif

    Write [F:MTK]
    If fstat
       GOK = 0 : Call FSTA("MTK") From GLOCK
       Goto TR_ROLL
    Endif
    WMSG = mess(79,190,1)+WMTKNUM
Endif
Filter [F:MFM]

#----------------------- Maj  Entête OF ------------------------------------#
Readlock [F:MFG]MFG0 Curr
If fstat=1  GOK=-1 : GLOCK="$MFGHEAD"-num$([M]MFGNUM) : Goto TR_ROLL
Elsif fstat GOK=0  : Call RSTA("MFG",num$([M]MFGNUM)) From GLOCK : Goto TR_ROLL
Endif
[F:MFG]RMNEXTQTY = 0
#  06.02 demande 14860
[F:MFG]OPECLENBR += WOPECLENBR
If [F:MFG]OPECLENBR > [F:MFG]OPELINNBR : [F:MFG]OPECLENBR = [F:MFG]OPELINNBR : Endif
[F:MFG]MATCLENBR += WMATCLENBR
If [F:MFG]MATCLENBR > [F:MFG]MATLINNBR : [F:MFG]MATCLENBR = [F:MFG]MATLINNBR : Endif
[F:MFG]ITMCLENBR += WITMCLENBR
If [F:MFG]ITMCLENBR > [F:MFG]ITMLINNBR : [F:MFG]ITMCLENBR = [F:MFG]ITMLINNBR : Endif
[F:MFG]CLODAT = GCLODAT
#If [F:MFG]OPECLENBR = [F:MFG]OPELINNBR &
#&  [F:MFG]ITMCLENBR = [F:MFG]ITMLINNBR &
#&  [F:MFG]MATCLENBR = [F:MFG]MATLINNBR : [F:MFG]MFGTRKFLG = 5
#Endif
[F:MFG]MFGTRKFLG = 5

#  05.03 sortir éventuellement  l'OF du plan de pesé pour le passer à fin pesée
If dim([F:MFG]WGGFLG) > 0 & [F:MFG]WGGFLG = 3
   [F:MFG]WGGFLG = 5
   [F:MFG]WGGSTA = 8
Endif

# llc 06.02
[F:MFG]UPDDAT    = date$
[F:MFG]UPDUSR    = GUSER
[F:MFG]EXPNUM    = [C]EXPORT

# sr 01.07 demande 39107 Point d'entrée permettant de mettre à jour des zones spécifiques
# sur l'entête d'OF en solde d'OF.
GPOINT = "MFSMAJCLE" : Gosub ENTREE From EXEFNC

Rewrite [F:MFG]
If fstat
   GOK = 0 : Call FSTA("MFG") From GLOCK : Goto TR_ROLL
Else
    # Issue 96691 GA 07/2014 rejalonner si et seulement si il reste des opé non soldées
    #If WOPECLENBR <> 0 & find([F:MFG]SCDFLG,2,4)
    If WOPECLENBR <> 0 & [F:MFG]OPECLENBR < [F:MFG]OPELINNBR & find([F:MFG]SCDFLG,2,4)
        [M:JALK]CODORI = 1
        [M:JALK]CODMAJ = 0
        [M:JALK]CODTRS = 0
        [M:JALK]MFGFCY = [F:MFG]MFGFCY
        [M:JALK]MFGNUM = [F:MFG]MFGNUM
        [M:JALK]MFGSTA = [F:MFG]MFGSTA
        If [F:PJA]MFGFCY <> [M:JALK]MFGFCY
            Read [PJA]PJA0=[M:JALK]MFGFCY
            If !fstat : [M:JALK]JAVFLG = [F:PJA]AUTFRWSCD : Endif
        Endif
        Call DEJALONNE From JALLIBA
        If [M:JALK]CODRET = 0
            Call JALONNE From JALLIB
        Endif
        If GOK < 1 : Goto TR_ROLL : Endif
    Endif
    #----- MISE à jour Entête de Wipcost -----#
    If !clalev([F:MWH])  : Local File MFGWIP    [MWH]  : Endif
    Readlock [MWH]MWH0=10;[F:MFG]MFGNUM
    If fstat=1 :  GOK=-1 : GLOCK="$MFGWIP 10;"-[F:MFG]MFGNUM : Goto TR_ROLL
    Elsif fstat GOK=0  : Call RSTA("MWH",[F:MFG]MFGNUM) From GLOCK : Goto TR_ROLL
    Elsif !fstat
        [F:MWH]MFGTRKFLG = [F:MFG]MFGTRKFLG
        [F:MWH]TRKLAST   = [F:MFG]TRKLAST
        # CCC (10/01/08) DM 44021
        [F:MWH]TRKFIRST  = [F:MFG]TRKFIRST
        Rewrite [MWH]
        If fstat
        GOK = 0 : Call FSTA("MWH") From GLOCK : Goto TR_ROLL
        Endif
        Commit
        #  10.04 demande 23789 Point d'entrée permettant de lancer un traitement supplémentaire
        # comme par exemple le calcul du PRF
        GPOINT = "CUSTRTSUP" : Gosub ENTREE From EXEFNC
    Endif

    Goto FIN
Endif

$TR_ROLL
Rollback
If dim(GGIVE_UP)>0 : GGIVE_UP=1 : GSTOP=1 : Endif

$FIN
# ccc (2009-11-17) Bug 59979 : Détruire GCLODAT à la fermeture de la fenêtre
If dim(GSTOP)<0
    If dim(GCLODAT)>0       : Kill  GCLODAT     : Endif
Endif
Return

###################################
$CTR_SOLDE
Local Integer WSOLDE
If clalev ([F:MFOW]) <= 0 : Local File MFGOPE [MFOW] : Endif
Filter [F:MFOW] Where MFGNUM = [F:MFG]MFGNUM & OPENUM = WPREC
Read [F:MFOW]MFO0 First
If fstat : Filter [MFOW] : Return : Endif
Read [F:MWS]WST0 = [F:MFOW]EXTWST;[F:MFOW]MFGFCY
If fstat | [F:MWS]WSTTYP<> 3 : Filter [MFOW] : Return : Endif
For [MFOW]
    If [F:MFOW]MFOTRKFLG = 5 : WSOLDE = 1
    Else                    : WSOLDE = 0
    Endif
Next
If WSOLDE = 1 : WOPECLENBR += 1 : Endif
Filter [MFOW]
Return

###################################
$CTR_DESOLDE
Local Integer WSOLDE
If clalev ([F:MFOW]) <= 0 : Local File MFGOPE [MFOW] : Endif
Filter [F:MFOW] Where MFGNUM = [F:MFG]MFGNUM & OPENUM = WPREC
Read [F:MFOW]MFO0 First
If fstat : Filter [MFOW] : Return : Endif
Read [F:MWS]WST0 = [F:MFOW]EXTWST;[F:MFOW]MFGFCY
If fstat | [F:MWS]WSTTYP<> 3 : Filter [MFOW] : Return : Endif
For [MFOW]
    If [F:MFOW]MFOTRKFLG = 5 : WSOLDE = 1
    Else                    : WSOLDE = 0
    Endif
Next
If WSOLDE = 0 : WOPECLENBR -= 1 : Endif
Filter [MFOW]
Return

###########################################################################
# Clôture OF
$CLOTURE_OF
Local Integer OK,LRET,LOPE,LITM,LMAT,WAUTO,STAT,WAUTO2
Local Integer WOPECLENBR, WITMCLENBR, WMATCLENBR
Local Decimal WQTYCONS,WWQTYCONS,WRAPP,WWQTY, WCOEFF
#Local Char    WNUMTEX
Local Integer WRETOUR,STAT, WFICFLG
Local Char    WMSG(80)
#
#  10.04 demande 23789
Local Integer WTRTTYP
WTRTTYP = 2

Raz WMSG
# 11552 11.03 MM : fonction clôture OF en série, sans message d'avertissement
If dim(GSTOP)<0
    #Demande de validation de la clôture
    Call OUINON(mess(72,190,1),OK) From GESECRAN
    If OK <> 2 : Return : Endif
Endif

# 11552 11.03 MM : fonction clôture OF en série, sans message d'avertissement
If [F:MFG]CPLQTY < [F:MFG]EXTQTY
    If dim(GQTYCTL) >0
        If GQTYCTL=2 : GWMESS2 = [F:MFG]MFGNUM - mess(74,190,1) : GSTOP=1 : Return : Endif
    Else
        Call AVERTIR(mess(74,190,1),OK) From GESECRAN
        If OK <> 2 : Return : Endif
    Endif
Endif
#Première chose, vérifier que toutes les opé pourront être soldées.
#Les opé de sous-traitance "commandée" ou ("en-cours" et ligne de cde non soldée)
#ne peuvent pas être soldées automatiquement
#De plus message d'avertissement si une opé ou un article lancé ou une matière n'a pas été suivi
Raz LRET
Call CTR_VALID(LRET,LOPE,LITM,LMAT)

# 08.05 31594
If LRET = 9
    If dim(GSSTCMDCTL) > 0
        GWMESS2 = [F:MFG]MFGNUM - mess(84,193,1)
        GSTOP   = 1
        Return
    Else
        Call ERREUR(mess(84,193,1)) From GESECRAN
        Return
    Endif
Endif

# 11552 11.03 MM : fonction clôture OF en série, sans message d'avertissement
If LRET = 1
    If dim(GSSTCMDCTL) >0 : GWMESS2 = [F:MFG]MFGNUM - mess(93,193,1) : GSTOP=1 : Return
    Else
        Call ERREUR(mess(93,193,1)) From GESECRAN
        Return
    Endif
Endif

If find(LOPE,1,3)
    Case GCTLCLE
        When 1,2
            # 11552 11.03 MM : fonction clôture OF en série, sans message d'avertissement
            If dim(GREACTL)>0
                If GREACTL=2 : GWMESS2 = [F:MFG]MFGNUM - mess(81,190,1) : GSTOP=1 : Return : Endif
            Else
                Call AVERTIR(mess(81,190,1),OK) From GESECRAN
                If OK <> 2 : Return : Endif
            Endif
        When Default
            # 11552 11.03 MM : fonction clôture OF en série, sans message d'avertissement
            If dim(GREACTL)>0 : GWMESS2= [F:MFG]MFGNUM - mess(81,190,1) : GSTOP=1 : Return
            Else
                Call ERREUR(mess(81,190,1)) From GESECRAN
                Return
            Endif
    Endcase
Endif

# 11552 11.03 MM : fonction clôture OF en série, sans message d'avertissement
If LITM = 1
    If dim(GLANCTL) >0
        If GLANCTL =2 :  GWMESS2 = [F:MFG]MFGNUM - mess(82,190,1) : GSTOP=1 : Return : Endif
    Else
        Call AVERTIR(mess(82,190,1),OK) From GESECRAN
        If OK <> 2 : Return : Endif
    Endif
Endif

If LMAT = 1
    Case GCTLCLE
        When 1,3
            # 11552 11.03 MM : fonction clôture OF en série, sans message d'avertissement
            If dim(GCNSCTL)>0
                If GCNSCTL=2 :GWMESS2 = [F:MFG]MFGNUM - mess(83,190,1) : GSTOP=1 : Return : Endif
            Else
                Call AVERTIR(mess(83,190,1),OK) From GESECRAN
                If OK <> 2 : Return : Endif
            Endif
        When Default
            # 11552 11.03 MM : fonction clôture OF en série, sans message d'avertissement
            If dim(GCNSCTL)>0 : GWMESS2= [F:MFG]MFGNUM - mess(83,190,1) : GSTOP=1 : Return
            Else
                Call ERREUR(mess(83,190,1)) From GESECRAN
                Return
            Endif
    Endcase
Endif

# Issue 71944 - 2011-05-10 by CCC : Contrôle existence mvt en attente
Local Char LWAICTL(2)
Local Integer LOK
If !clalev([F:STJ]) : Local File STOJOU [STJ] : Endif
If dim(GWAICTL)>0
    LWAICTL=GWAICTL
Else
    # Issue 99496 - 2014-11-03 by CCC : pending transaction control
    Call PARAM([F:MFG]MFGFCY, "WOMMVTWAI", LWAICTL) From ADOVAL
Endif
If LWAICTL="2"
    If func CTRL_WAITRS_WO([F:MFG]MFGFCY,[F:MFG]MFGNUM)>0
        # 93576 mm  06.2014
        If dim(GWAICTL)>0
            GWMESS2 = [F:MFG]MFGNUM -":"- mess(289,193,1)
            GSTOP=1
            Return
        Else
            Call ERREUR(mess(289,193,1)) From GESECRAN
            Return
        Endif
    Endif
Endif

Raz WAUTO,LRET
Raz WAUTO2

# CCC (07/08/07) PE permettant de suivre automatiquement ou non des matières ou opé non soldées.
Raz GPE
GPOINT = "WAUTO" : Gosub ENTREE From EXEFNC

#Deuxième chose; y-a-t-il des matières à mode de déstockage automatique non soldées?
#WAUTO = 0 : On ne suit pas automatiquement les matières
#WAUTO = 1 : On suit automatiquement les matières
If mod(GPE,2)<1
    If [F:MFG]CPLQTY = 0 | [F:MTS]MATTRKFLG <> 2 : WAUTO = 0
    Else Call CTR_MAT(LRET)
        If LRET > 0
           Local Date WDATE : WDATE = date$
           Call STKCTRIPT(WDATE,[F:MFG]MFGFCY,"1") From STKLIB
           If GMESSAGE = ""
              # 11552 11.03 MM
              If  dim(GMATCTL) >0
                  If GMATCTL=2 : WAUTO = 1 : Endif
              Else
                  Raz OK
                  Call OUINON(mess(207,190,1),OK) From GESECRAN
                  If OK = 2 : WAUTO = 1 : Endif
              Endif
           Endif
        Endif
    Endif
Endif

#Troisième chose : Proposition de suivi automatique des opés?
#WAUTO2 = 0 : On ne suit pas automatiquement les opés
#WAUTO2 = 1 : On suit automatiquement les opés
If mod(GPE,4)<2
    If [F:MFG]CPLQTY = 0 | [F:MTS]OPETRKFLG <> 2 : WAUTO2 = 0
    Elsif find(LOPE,1,3,4)
        # 11552 11.03 MM
        If  dim(GOPECTL) >0
           If GOPECTL=2 : WAUTO2 = 1 : Endif
        Else
            Raz OK
            Call OUINON(mess(85,190,1),OK) From GESECRAN
            If OK = 2: WAUTO2 = 1 : Endif
        Endif
    Endif
Endif

#----- Récupération compteur suivi si besoin
If WAUTO > 0 | WAUTO2 > 0
   Local Char WMTKNUM(GLONVCR)
   Local Date WDATE : WDATE = date$
   If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
   Call LECTCA(8,OK) From SUBTCA
   If OK=0
      Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN
      GOK=0 : LRET = 1 : Return
   Endif
   Call NUMERO([F:TCA]CODNUM(2),[F:MFG]MFGFCY,WDATE,"",WMTKNUM,STAT) From SUBANM
   If STAT <> 0: Call ERREUR(mess(60,199,1)-[F:TCA]CODNUM(2)-num$([L]STAT)) From GESECRAN: GOK = 0 : LRET = 1 : Return : Endif
   Close File [F:TCA]
Endif

# étiquette (technique) pour faciliter l'ingénierie
$CLOTURE_SUITE
#----- Variables globales stock
Call GLOBVAR([F:MFG]MFGFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR([F:MFG]MFGFCY)    From WWGLOBGPA
#
If clalev ([F:MTK]) <= 0 : Local File MFGHEADTRK  [MTK] : Endif
If clalev ([F:MKM]) <= 0 : Local File MFGMATTRK   [MKM] : Endif
If clalev ([F:MKO]) <= 0 : Local File MFGOPETRK   [MKO] : Endif
If clalev ([F:SCH]) <= 0 : Local File SCHEDULING  [SCH] : Endif
If clalev ([F:MFOX])<= 0 : Local File MFGOPE      [MFOX]: Endif
If clalev ([F:MWS]) <= 0 : Local File WORKSTATIO  [MWS] : Endif
If clalev ([F:STA]) <= 0 : Local File STOALL      [STA] : Endif
If clalev ([F:STO]) <= 0 : Local File STOCK       [STO] : Endif
If clalev ([F:STL]) <= 0 : Local File STOLOT      [STL] : Endif
#

Call DEBTRANS From GLOCK
Trbegin [MFG]
#----------------------- Solde des opérations -----------------------------#
Filter [F:MFO] Where MFGNUM =[F:MFG]MFGNUM & OPESTA <> 6
Local Integer WOPESOL
Raz WOPESOL

For [F:MFO]
    If [F:MFO]MFOTRKFLG <> 5
        #  05.05 demande 30252
       Read [F:MWS]WST0 = [F:MFO]EXTWST;[F:MFO]MFGFCY
       If fstat : Raz [F:MWS] : Endif

       If [F:MWS]WSTTYP <> 3 & WAUTO2 = 1 : Gosub SOLDE_OPE
              If GOK < 1 : Break : Endif
              Readlock [F:MFO]MFO0 Curr : #On se repositionne sur la bonne opé
       Endif
       [F:MFO]OPESTA = 5
       [F:MFO]MFOTRKFLG = 5
# CCC (10/01/08) DM 44021
#       If [F:MFO]TRKFIRST = "00/00/00" : [F:MFO]TRKFIRST = date$ : Endif
#       [F:MFO]TRKLAST = date$

       Gosub MAJ_SUIVANTE From SUBMTKC
       If GOK < 1 : Break : Endif
       Filter [MFI] Where MFGNUM = [F:MFO]MFGNUM
       Read [F:MFI]MFI0 First
       If !fstat
           Call UPDATE_OWX("SA",[F:MFI]PJT) From MFGLIBO
       Endif
       Filter [MFI]
       WOPECLENBR += 1
    Endif

    # FQ 77745 GA 11/2011
    If [F:MFO]WIPNUM <> ""
       Call UPDATE_SCX("A", [F:MFI]PJT) From MFGLIBO
       Raz [F:MFO]WIPNUM
    Endif

    [F:MFO]MFGSTA  = 4
# CCC (10/01/08) DM 44021
#    If [F:MFO]TRKFIRST = [0/0/0] : [F:MFO]TRKFIRST = date$ : Endif
#    If [F:MFO]TRKLAST  = [0/0/0] : [F:MFO]TRKLAST  = date$ : Endif
    # llc 06.02
    [F:MFO]UPDDAT    = date$
    [F:MFO]UPDUSR    = GUSER
    [F:MFO]EXPNUM    = [C]EXPORT

    Rewrite [F:MFO]
    If fstat
    GOK = 0 : Call FSTA("MFO") From GLOCK : Break
    Endif

    #----- Mise à jour statistiques ligne opération
    Call VALSTA("MFO",1) From SUBPS2 : If GOK < 1 : Break : Endif
Next
If GOK < 1 : Goto TR_ROLLCLO : Endif

Filter [F:MFO]
#----------------------- Solde des articles   -----------------------------#
Filter [F:MFI] Where MFGNUM = [F:MFG]MFGNUM & ITMSTA <> 4
For [F:MFI]
    If [F:MFI]MFITRKFLG <> 5
       [F:MFI]MFITRKFLG = 5
       [F:MFI]ITMSTA = 3
       Local Integer STA : STA=0
       Call LECITV([F:MFI]MFGFCY, [F:MFI]ITMREF, "",STA) From STKLIB
       If GOK <> 1 | STA > 1 : Break : Endif
       [F:ITV]ORDSTO -= [F:MFI]RMNEXTQTY
       Rewrite [ITV] : If fstat GOK=0 : Call FSTA("ITV") From GLOCK : Break : Endif
       [F:MFI]RMNEXTQTY = 0

       # v6 affectations
       Gosub SUP_MTO_MFI From MFGMTOLIB

       #Maj encours
       Gosub SUP_WIP
       If GOK < 1 : Break : Endif
       WITMCLENBR += 1
    Endif
# CCC (10/01/08) DM 44021
#    If [F:MFI]TRKFIRST = [0/0/0] : [F:MFI]TRKFIRST = date$ : Endif
#    If [F:MFI]TRKLAST  = [0/0/0] : [F:MFI]TRKLAST  = date$ : Endif
    [F:MFI]MFGSTA = 4
    [F:MFI]CLODAT = GCLODAT

    # llc 06.02
    [F:MFI]UPDDAT    = date$
    [F:MFI]UPDUSR    = GUSER
    [F:MFI]EXPNUM    = [C]EXPORT

    Rewrite [F:MFI]
    If fstat
       GOK = 0 : Call FSTA("MFI") From GLOCK : Break
    Endif

    #----- Mise à jour statistiques ligne article lancé -----#
    Call VALSTA("MFI",1) From SUBPS2 : If GOK < 1 : Break : Endif
Next
If GOK < 1 : Goto TR_ROLLCLO : Endif
Filter [F:MFI]
#----------------------- Solde des matières   -----------------------------#
Filter [F:MFM] Where MFGNUM = [F:MFG]MFGNUM & MATSTA <> 4 & CPNTYP <> 5
Local Integer WMATSOL
Raz WMATSOL
For [F:MFM]
    If [F:MFM]MFGLIN <> 0
        Read [F:MFI]MFI0 = [F:MFM]MFGNUM;[F:MFM]MFGLIN
        If fstat : GOK=0: Call RSTA("MFI",[F:MFM]MFGNUM) From GLOCK : Break : Endif    # llc 05.02 cohérence
    Else
        Filter [F:MFI] Where MFGNUM = [F:MFM]MFGNUM
        Read [F:MFI]MFI0 First
        If fstat : GOK=0: Call RSTA("MFI",[F:MFM]MFGNUM) From GLOCK : Break : Endif    # llc 05.02 cohérence
        Filter [F:MFI]
    Endif
    Gosub SOLDE_MAT
    If GOK < 1 : Break : Endif

    # v6 affectations
    Gosub SUP_MTO_MFM From MFGMTOLIB

    Call UPDATE_MFX("A", [F:MFI]PJT,[F:MFI]BOMALT, 0) From MFGLIBM
    # llc 06.02
    [F:MFM]UPDDAT    = date$
    [F:MFM]UPDUSR    = GUSER
    [F:MFM]EXPNUM    = [C]EXPORT

    #======== MAJ du champ Situation de pesée="Consommée" = DT-06/07/2010 ====#
    If [F:MFI]ITMSTA = 3
        # 67426 mm 09.10
        If dim([F:MFM]WGGSTAAVS) > 0
           [F:MFM]WGGSTAAVS= [F:MFM]WGGSTA   :# Sauvegarder la situation de pesée avant le solde d'OF
           [F:MFM]WGGSTA   = 8
        Endif
    Endif
    #=========================================================================#

    Rewrite [F:MFM]
    If fstat
       GOK = 0 : Call FSTA("MFM") From GLOCK : Break
    Endif

    #----- Mise à jour statistiques ligne matières -----#
    Call VALSTA("MFM",1) From SUBPS2
Next
If GOK < 1 : Goto TR_ROLLCLO : Endif
#si au moins un suivi opé ou un suivi matière création de l'entête de suivi
If WMATSOL <> 0 | WOPESOL <> 0
Raz [F:MTK]
   [F:MTK]          = [F:MFG]
   [F:MTK]MTKTEX    = [F:MFG]MFGTEX
   [F:MTK]MFGTRKNUM = WMTKNUM
   [F:MTK]CREDAT    = date$
   [F:MTK]CREUSR    = GUSER
   [F:MTK]EXPNUM    = [C]EXPORT
   [F:MTK]ITMTRKFLG = 1
   [F:MTK]NBROPE    = WOPESOL
   [F:MTK]NBRMAT    = WMATSOL
   If [F:MTK]NBRMAT > 0 : [F:MTK]MATTRKFLG = 2
   Else                 : [F:MTK]MATTRKFLG = 1
   Endif
   If [F:MTK]NBROPE > 0 : [F:MTK]OPETRKFLG = 2
   Else                 : [F:MTK]OPETRKFLG = 1
   Endif
   [F:MTK]MFGTRKDAT = GCLODAT  # 90256 MM 04.2014 - à la place de date$

    If [F:MTK]MTKTEX <> ""
        #en auto on n'a pas pu saisir du texte, donc si texte il y a, il vient de l'OF et a comme préfixe
        #MFG,ROH ou ITM
        #on ne duplique que si ça vient de l'OF.
        If left$([F:MTK]MTKTEX,3)="MFG"
           Call DUP_CLOB("MTK",[F:MTK]MTKTEX,GOK) From TRTX3TEX
        Endif
    Endif

    Write [F:MTK]
    If fstat
       GOK = 0 : Call FSTA("MTK") From GLOCK
       Goto TR_ROLLCLO
    Endif
    WMSG = mess(79,190,1)+WMTKNUM
Endif
Filter [F:MFM]

Call CREWIPCPNVAL([F:MFG]MFGNUM)
If GOK < 1 : Goto TR_ROLLCLO : Endif

#----------------------- Maj  Entête OF ------------------------------------#
Readlock [F:MFG]MFG0 Curr
If fstat=1  GOK=-1 : GLOCK="$MFGHEAD"-num$([M]MFGNUM) : Goto TR_ROLLCLO
Elsif fstat GOK=0  : Call RSTA("MFG",num$([M]MFGNUM)) From GLOCK : Goto TR_ROLLCLO
Endif

# FQ 70633 GA 01/2011 selon 70409
#### #  06.02 demande 14860
#### [F:MFG]OPECLENBR += WOPECLENBR
#### If [F:MFG]OPECLENBR > [F:MFG]OPELINNBR : [F:MFG]OPECLENBR = [F:MFG]OPELINNBR : Endif
#### [F:MFG]MATCLENBR += WMATCLENBR
#### If [F:MFG]MATCLENBR > [F:MFG]MATLINNBR : [F:MFG]MATCLENBR = [F:MFG]MATLINNBR : Endif
#### [F:MFG]ITMCLENBR += WITMCLENBR
#### If [F:MFG]ITMCLENBR > [F:MFG]ITMLINNBR : [F:MFG]ITMCLENBR = [F:MFG]ITMLINNBR : Endif
#### #If [F:MFG]OPECLENBR = [F:MFG]OPELINNBR &
#### #&  [F:MFG]ITMCLENBR = [F:MFG]ITMLINNBR &
#### #&  [F:MFG]MATCLENBR = [F:MFG]MATLINNBR :  [F:MFG]MFGTRKFLG = 5
#### #Endif
Gosub MAJMFGHEAD From MFGLIB
#  06.02 demande 14860
[F:MFG]MFGTRKFLG = 5

#  05.03 sortir éventuellement  l'OF du plan de pesé pour le passer à fin pesée
If dim([F:MFG]WGGFLG) > 0 & [F:MFG]WGGFLG = 3
   [F:MFG]WGGFLG = 5
   [F:MFG]WGGSTA = 8
Endif

#  06.02 demande 14602 Point d'entrée permettant de mettre à jour des zones spécifiques
# sur l'entête d'OF en cloture d'OF.
GPOINT = "MFSMAJ" : Gosub ENTREE From EXEFNC

[F:MFG]MFGSTA= 4
[F:MFG]RMNEXTQTY = 0
# CCC (10/01/08) DM 44021
#If [F:MFG]TRKLAST = [0/0/0] : [F:MFG]TRKLAST = date$ : Endif

[F:MFG]CLODAT = GCLODAT
# llc 06.02
[F:MFG]UPDDAT    = date$
[F:MFG]UPDUSR    = GUSER
[F:MFG]EXPNUM    = [C]EXPORT

Rewrite [F:MFG]
If fstat
   GOK = 0 : Call FSTA("MFG") From GLOCK
Else
     #----- Mise à jour statistiques entête d'OF -----#
     Call VALSTA("MFG",1) From SUBPS2
     If GOK > 0
       #----- MISE à jour Entête de Wipcost -----#
       If !clalev([F:MWH])  : Local File MFGWIP    [MWH]  : Endif
       Readlock [MWH]MWH0=10;[F:MFG]MFGNUM
       If fstat=1  GOK=-1 : GLOCK="$MFGWIP 10;"-[F:MFG]MFGNUM : Goto TR_ROLLCLO
       Elsif !fstat
         [F:MWH]MFGTRKFLG = [F:MFG]MFGTRKFLG
         [F:MWH]TRKLAST   = [F:MFG]TRKLAST
# CCC (10/01/08) DM 44021
         [F:MWH]TRKFIRST  = [F:MFG]TRKFIRST
         Rewrite [MWH]
         If fstat
           GOK = 0 : Call FSTA("MWH") From GLOCK : Goto TR_ROLLCLO
         Endif
       Endif
       Commit
       #  10.04 demande 23789 Point d'entrée permettant de lancer un traitement supplémentaire
       # comme par exemple le calcul du PRF
       GPOINT = "CUSTRTSUP" : Gosub ENTREE From EXEFNC
       Goto FINCLO
     Endif
Endif

$TR_ROLLCLO
Rollback
If dim(GGIVE_UP)>0 : GGIVE_UP=1 : GSTOP=1 : Endif

$FINCLO
# 11552 11.03 MM : fonction solde OF en série, sans message d'avertissement
If dim(GWMESS2)>0
    If WMSG <> "" : GWMESS2 = WMSG : Return : Endif
Else
    If WMSG <> "" : Call MESSAGE(WMSG) From GESECRAN : Endif
Endif
Return

$SUP_WIP
[M:ORDK]MAJCOD     = "A"
# llc 02.03 17461
Case [F:MFI]ITMTYP
    When 1:    [M:ORDK]WIPTYP     = 5
    When 2:    [M:ORDK]WIPTYP     = 9
Endcase
[M:ORDK]WIPNUM     = [F:MFI]WIPNUM
[M:ORDK]ITMREF     = [F:MFI]ITMREF
Call WIP From TRTWIP
Return

###########################################################################
# Réactivation OF
$ACTIVE_OF
Local Integer OK
Local Integer  STA : STA=0

# demande de validation
Call OUINON(mess(92,190,1),OK) From GESECRAN
If OK <> 2 : Return : Endif

Call DEBTRANS From GLOCK
Trbegin ADOVAL
#
Gosub ACT_OF
#
Goto END_ACT

Return

#########################################################################
$ACT_OF
# lecture entête OF
Readlock [MFG]MFG0=[M:MFS0]MFGNUM
If fstat : GOK=0 : Call RSTA("MFG","MFG0") From GLOCK : Goto AB_ACT : Endif

$ACT_MAT
# mise à jour des matières
For [MFM]MFM0 Where MFGNUM = [M:MFS0]MFGNUM  & CPNTYP <> 5 With Lock
    If fstat=1 & !GSERVEUR : Goto ROLL_ACT : Endif
    If fstat : GOK=0 : Call RSTA("MFM","MFM0") From GLOCK : Goto AB_ACT : Endif

    # mise à jour statut
    [F:MFM]MFGSTA = 1
    [F:MFM]UPDDAT = date$
    [F:MFM]UPDUSR = GUSER
    [F:MFM]EXPNUM = [C]EXPORT
    Rewrite [MFM]
Next

$ACT_OPE

For [MFO]MFO0 Where MFGNUM = [M:MFS0]MFGNUM With Lock
    If fstat=1 & !GSERVEUR : Goto ROLL_ACT : Endif
    If fstat : GOK=0 : Call RSTA("MFO","MFO0") From GLOCK : Goto AB_ACT : Endif


    [F:MFO]MFGSTA = 1
    [F:MFO]UPDDAT = date$
    [F:MFO]UPDUSR = GUSER
    [F:MFO]EXPNUM = [C]EXPORT
    Rewrite [MFO]
Next

For [MFI]MFI0 Where MFGNUM=[M:MFS0]MFGNUM With Lock
    # mise à jour article lancé
    [F:MFI]MFGSTA = 1
    [F:MFI]UPDDAT = date$
    [F:MFI]UPDUSR = GUSER
    [F:MFI]EXPNUM = [C]EXPORT
    [F:MFI]CLODAT = [0/0/0]
    Rewrite [MFI]
Next

# mise à jour entête OF
[F:MFG]MFGSTA = 1
[F:MFG]CLODAT = [0/0/0]
[F:MFG]UPDDAT = date$
[F:MFG]UPDUSR = GUSER
[F:MFG]EXPNUM = [C]EXPORT
Rewrite [MFG]
#
# Issue 89939 - 2013-05-29 by CCC : supprimer les Wipcost des matières uniquement valorisées
Call DELWIPCPNVAL([F:MFG]MFGNUM)
Return

#########################################################################
$END_ACT
Commit
Return

#########################################################################
$AB_ACT
Rollback
Return

#########################################################################
$ROLL_ACT
Rollback : Call ROLL From GLOCK
If !GROLL : Goto ACT_OF : Endif
Return


######################################################
#Solde d'une opération.
$SOLDE_OPE
Local Decimal WCPLHOU
Local Decimal WREJQTY, WWREJQTY , J
Local Char    WCCE(20)
Local Decimal WUNTTIM            # llc 15971

#Récup de DACMST
Read [F:SCH]SCH0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
If fstat : Raz [F:SCH] : Endif
WDACMST = [F:SCH]DACMST
If [F:SCH]DACMST = 1  : Return : Endif
WQTYCONS = [F:MFG]CPLQTY * [F:MFO]OPESTUCOE
Call QTEARR(WQTYCONS,[F:MFO]OPEUOM) From TRTDIV
WQTYCONS -= [F:MFO]CPLQTY
If WQTYCONS < 0 : WQTYCONS = 0 : Endif
If WQTYCONS <= 0 : Return : Endif
Raz WREJQTY
WREJQTY = [F:MFG]REJCPLQTY * [F:MFO]OPESTUCOE
Call QTEARR(WREJQTY,[F:MFO]OPEUOM) From TRTDIV
WREJQTY -= [F:MFO]REJCPLQTY
If WREJQTY < 0 : WREJQTY = 0 : Endif
WWQTYCONS = WQTYCONS
WWREJQTY  = WREJQTY
#                -------------------------------------------
#Si opération borne il faut suivre les opé à suivre en même temps
If [F:SCH]DACMST = 3
   Local Shortint WOPE
   Local Integer WBREAK
#Recherche de la précédente opération à suivre (normale ou borne)
   Raz WBREAK,WOPE
   Filter [F:MFOX] Where MFGNUM = [F:MFO]MFGNUM & OPENUM < [F:MFO]OPENUM Order By Key MFO0 Desc
   For [F:MFOX]
       Read [F:SCH]SCH0 = [F:MFOX]MFGNUM;[F:MFOX]OPENUM;[F:MFOX]OPESPLNUM
       If !fstat & [F:SCH]DACMST >1 : WBREAK = 1 : Break : Endif
   Next
   If WBREAK = 1 : WOPE = [F:MFOX]OPENUM
   Else WOPE = 0
   Endif
#Traitement des opé entre les deux bornes(borne supérieure comprise)
   Filter [F:MFOX] Where MFGNUM = [F:MFO]MFGNUM & OPENUM > WOPE & OPENUM <= [F:MFO]OPENUM
Else
   Filter [F:MFOX] Where MFGNUM = [F:MFO]MFGNUM & OPENUM = [F:MFO]OPENUM &
&                            OPESPLNUM = [F:MFO]OPESPLNUM
Endif
For [F:MFOX]
#On ne prend pas les opérations exclues ou  commandées ou  sous-traitées
    If [F:MFOX]OPESTA > 5 : Goto NEXTMFOX : Endif
    Read [F:MWS]WST0 = [F:MFOX]EXTWST;[F:MFOX]MFGFCY
    If fstat | [F:MWS]WSTTYP = 3 : Goto NEXTMFOX : Endif
    $TRT_OPE
#Création enregistrement suivi opé
    Raz [F:MKO]
    [F:MKO]          = [F:MFOX]
    [F:MKO]MKOTEX    = [F:MFOX]MFOTEX
    [F:MKO]TIMTYP    = 1
#nouvelle gestion des qtés en UO ou US selon transaction
    Case [F:MTS]OPEUOMMOD
          When 1 :  [F:MKO]OPEWORCOE = 1
          When 2 :  Case [F:MTS]OPEUOMTYP
                          When 1 : [F:MKO]OPEWORCOE     = 1
                                   WWQTYCONS            = WQTYCONS
                                   WWREJQTY             = WREJQTY
                          When 2 : [F:MKO]OPEUOM        = [F:MFG]STU
                                   [F:MKO]OPEWORCOE     = [F:MFOX]OPESTUCOE
                                   If [F:MKO]OPEWORCOE = 0:[F:MKO]OPEWORCOE=1: Endif
                                   WWQTYCONS = WQTYCONS / [F:MKO]OPEWORCOE
                                   WWREJQTY  = WREJQTY  / [F:MKO]OPEWORCOE
                    Endcase
    Endcase
    Call CALCUL_QTY(WWQTYCONS,[F:MFO]OPEUOM,[F:MKO]CPLQTY,[F:MKO]OPEUOM,GBIDD1) From TRTX3
    If [F:MKO]CPLQTY > 0
       WOPESOL += 1
       Call CALCUL_QTY(WWREJQTY,[F:MFO]OPEUOM,[F:MKO]REJCPLQTY,[F:MKO]OPEUOM,GBIDD1) From TRTX3
       [F:MKO]OPETRKLIN = WOPESOL
       [F:MKO]CPLLAB    = [F:MFOX]EXTLAB
       [F:MKO]CPLWST    = [F:MFOX]EXTWST
       # llc 09.02 15971
       If [F:MFOX]EXTQTY > 0
           WUNTTIM = [F:MFOX]EXTOPETIM / [F:MFOX]EXTQTY
       Endif
       [F:MKO]CPLOPETIM = (WUNTTIM * [F:MKO]OPEWORCOE) * [F:MKO]CPLQTY            # llc 09.02 15971
       [F:MKO]CPLSETTIM = [F:MFOX]EXTSETTIM - [F:MFOX]CPLSETTIM
       If [F:MKO]CPLSETTIM < 0 : [F:MKO]CPLSETTIM = 0 : Endif
       # 11.06 demande 38402
       [F:MKO]CPLOPETIM = func TRTX3.ARRTYP("","","TIH",[F:MKO]CPLOPETIM)
       [F:MKO]CPLSETTIM = func TRTX3.ARRTYP("","","TIH",[F:MKO]CPLSETTIM)
       If [F:MFOX]OPENUM = [F:MFO]OPENUM : [F:MKO]DACMST   = WDACMST
       Else                               [F:MKO]DACMST   = 1
                                          [F:MKO]OPEBORNE = [F:MFO]OPENUM
       Endif

       # MM 03.04 demande 21666 Point d'entrée permettant de mettre à jour des zones spécifiques
       # dans le suivi d'opération en solde ou clôture d'OF
       GPOINT = "MKOTRKMAJ" : Gosub ENTREE From EXEFNC

       [F:MKO]IPTDAT    = GCLODAT   # 90256 MM 05.2014 - à la place de date$
       [F:MKO]DACDAT    = date$
       [F:MKO]DACHOU    = left$(time$,2)+mid$(time$,4,2)
       [F:MKO]CREDAT    = date$
       [F:MKO]CREUSR    = GUSER
       [F:MKO]EXPNUM    = [C]EXPORT
       Raz [F:MKO]UPDUSR
       Raz [F:MKO]UPDDAT
       If [F:MKO]MKOTEX <> ""
            #en auto on n'a pas pu saisir du texte, donc si texte il y a, il vient de l'OF et a comme préfixe
            #MFO,ROO ou ROT
            #on ne duplique que si ça vient de l'OF.
            If left$([F:MKO]MKOTEX,3)="MFO"
               Call DUP_CLOB("MKO",[F:MKO]MKOTEX,GOK) From TRTX3TEX
            Endif
       Endif

       [F:MKO]MFGTRKNUM = WMTKNUM

       Write [F:MKO]
       If fstat
          GOK = 0 : Call FSTA("MKO") From GLOCK
          LRET = 1 : Break
      Endif
      # On n'a pas [MTOK] en ligne, on appelle le trt associe au suivi de SST
       Gosub MAJMKO_CPTANALIN From MTKLIB

       #----- Mise à jour statistiques suivi opération -----#
       Call VALSTA("MKO",1) From SUBPS2 : If GOK<1 : Break : Endif


#MAJ Opération
# llc 03.01 multi-exemplaire
#       If [F:MFOX]CPLWST <> [F:MKO]CPLWST :  [F:MFOX]CPLWSTNBR += 1 : Endif
       [F:MFOX]CPLWSTNBR = [F:MFOX]EXTWSTNBR
       If [F:MFOX]CPLWST = "" : [F:MFOX]CPLWST = [F:MKO]CPLWST : Endif
       If [F:MFOX]CPLLAB = "" : [F:MFOX]CPLLAB = [F:MKO]CPLLAB : Endif
       [F:MFOX]CPLQTY    += [F:MKO]CPLQTY    * [F:MKO]OPEWORCOE
       [F:MFOX]REJCPLQTY += [F:MKO]REJCPLQTY * [F:MKO]OPEWORCOE
       [F:MFOX]CPLSETTIM += [F:MKO]CPLSETTIM
       [F:MFOX]CPLOPETIM += [F:MKO]CPLOPETIM
       # llc 09.02 15971
       If [F:MFOX]CPLUNTTIM = 0 : [F:MFOX]CPLUNTTIM = WUNTTIM
       Else [F:MFOX]CPLUNTTIM = avg(WUNTTIM,[F:MFOX]CPLUNTTIM)
       Endif
        # CCC (10/01/08) DM 44021
       #If [F:MFOX]TRKFIRST = "00/00/00" : [F:MFOX]TRKFIRST = date$ : Endif
       If [F:MFOX]TRKLAST<date$
          [F:MFOX]TRKLAST   = date$
       Endif
       If [F:MFOX]TRKLASTC<date$
          [F:MFOX]TRKLASTC  = date$
       Endif
       If [F:MFOX]TRKFIRST>date$ | [F:MFOX]TRKFIRST = "00/00/00"
           [F:MFOX]TRKFIRST = date$
       Endif
       If [F:MFOX]TRKFIRSTC>date$ | [F:MFOX]TRKFIRSTC = "00/00/00"
           [F:MFOX]TRKFIRSTC = date$
       Endif

       # llc 06.02
       [F:MFOX]UPDDAT    = date$
       [F:MFOX]UPDUSR    = GUSER
       [F:MFOX]EXPNUM    = [C]EXPORT

       Rewrite [F:MFOX]
       If fstat
          GOK = 0 : Call FSTA("MFOX") From GLOCK : Break
       Else
#Maj du fichier WORKSTATIO
          Readlock [F:MWS]WST0 = [F:MKO]CPLWST;[F:MKO]MFGFCY
          If !fstat
               WCPLHOU = [F:MKO]CPLOPETIM
               If [F:MKO]TIMUOMCOD = 2 : WCPLHOU = WCPLHOU / 60 : Endif
               [F:MWS]CPLHOUTIM += func TRTX3.ARRTYP("","","TIH",WCPLHOU)
               Rewrite [F:MWS]
               If fstat
                  GOK = 0 : Call FSTA("MWS") From GLOCK : Break
               Endif

#------------------------------------------------------------------------------------------------------------------
# point d'entrée WIP costing 14548
               If WAUTO2 = 1
                   If dim(WRET) < 0     : Local Integer WRET       : Endif
                   If dim(GWIPCOST) < 0 : Global Char GWIPCOST(20) : Endif
                   GWIPCOST = "OPETRK_NEW"
                   WRET = 0
                   GPOINT = "WIPCOST" : Gosub ENTREE From EXEFNC
                   If WRET > 0 : GOK = 0 : Break : Endif
               Endif
#------------------------------------------------------------------------------------------------------------------
             If dim(WRET) < 0     : Local Integer WRET       : Endif
             Call OPETRK_NEW(WRET) From MWIPLIB   # (TB) Intégration WIP
             If WRET > 0 : GOK = 0 : Break : Endif


          Endif
       Endif
    Endif
$NEXTMFOX
Next
#            -------------------------
Return



##############################################################
#Solde d'une matière . Traitement appelé aussi depuis SUBMFS3
$SOLDE_MAT
Local Integer WCUNFLG
Local        Integer WNO_REAJUST
Local        Decimal LQTA, LSHT, LDIS
Local        Integer LNBR, LNBJ, LRET, J, I
Local        Decimal WWALLQTY,WWSHTQTY
Local Char   WCCE(20)
Local        Char    WORI(10) : WORI = "MTMK"

Raz WNO_REAJUST

Read [F:ITM]ITM0 = [F:MFM]ITMREF
If fstat : Raz [F:ITM] : Endif
Read [F:ITF]ITF0 = [F:MFM]ITMREF;[F:MFM]MFGFCY
If fstat : Raz [F:ITF] : Endif
If [F:ITF]CUNFLG = 2
   If [F:MFM]ALLSTA > 3
      Gosub REC_LOC From SUBMTKB
   Else
      #  04.02 Problèmes Perf
      Filter [F:STO] Where STOFCY = [F:ITF]STOFCY & ITMREF = [F:ITF]ITMREF & CUNLOKFLG = 1
&                    Order By Key STO3
      Read [F:STO]STO3 First
      If fstat WCUNFLG = 2 : Endif
      Filter [F:STO]
   Endif
Endif
If [F:MFM]MFMTRKFLG <> 5
#On ne suit que les matières à code retrait post-conso
   If [F:ITF]STOCOD = 2 & WCUNFLG <> 2 & WAUTO > 0
         If [F:ITM]NEGSTO <> 2
           # Issue 95433 01/2014 cas des suivis créés avec qté nulle ou stock insuffisant
           GPE=0 : GPOINT = "CTLMFMSTO" : Gosub ENTREE From EXEFNC
           If !GPE
             # si il n'y a pas du tout de stock on ne traite pas
             Call LECSRU([F:MFM]MFGFCY,[F:ITM]TCLCOD,6,[F:MTS]TRSCODS,"",LRET) From STKLIB
             If LRET = 1 : LDIS = 0
             Else
                Call LECITV2([F:MFM]MFGFCY,[F:MFM]ITMREF,LRET) From MFGLIB
                Call STODISTOT("",0,[F:SRU]AUZSTA,"",LDIS) From STKLIB
                LDIS += [F:MFM]ALLQTY        # CCC (27/10/08) : Ajouter au disponible ce qui nous est alloué
             Endif
           Endif
         Endif
         If [F:ITM]NEGSTO = 2 | LDIS <> 0
             #Calcul de la qté à consommer
             #Si matière au forfait ou CONSMAT = 1 on sort tout ce qui reste
             If [F:MFM]LIKQTYCOD = 2 | [F:MTS]CONSMAT = 1
                   WQTYCONS = [F:MFM]RETQTY - [F:MFM]USEQTY
                   If WQTYCONS < 0 : Raz WQTYCONS : Endif
             Else
                 If [F:MFM]MFGLIN <> 0
                     Read [F:MFI]MFI0 = [F:MFM]MFGNUM;[F:MFM]MFGLIN
                     If !fstat
                         WCOEFF   = [F:MFI]CPLQTY / [F:MFI]EXTQTY
                         # CCC (09/12/08) Bug 50667 : le coef ne doit pas être arrondi sinon les qtés calculées sont fausses
                         # Ce sont les quantités qui sont arrondies
                         #WCOEFF   = arr(WCOEFF,0.00000001)
                         WQTYCONS = [F:MFM]RETQTY * WCOEFF
                         WQTYCONS = WQTYCONS - [F:MFM]USEQTY
                         If [F:MTS]CONSMAT = 2 & WQTYCONS > [F:MFM]RETQTY - [F:MFM]USEQTY
                            WQTYCONS = [F:MFM]RETQTY - [F:MFM]USEQTY
                         Endif
                         If [F:ITM]NEGSTO = 1
                            WQTYCONS = min(WQTYCONS,LDIS)
                         Endif
                         If WQTYCONS < 0 : WQTYCONS = 0 : Endif
                     Else
                         WQTYCONS = 0
                     Endif
                 Else
                     WCOEFF   = [F:MFG]CPLQTY / [F:MFG]EXTQTY
                     # CCC (09/12/08) Bug 50667 : le coef ne doit pas être arrondi sinon les qtés calculées sont fausses
                     # Ce sont les quantités qui sont arrondies
                     #WCOEFF   = arr(WCOEFF,0.00000001)
                     WQTYCONS = [F:MFM]RETQTY * WCOEFF
                     WQTYCONS = WQTYCONS - [F:MFM]USEQTY
                     If [F:MTS]CONSMAT = 2 & WQTYCONS > [F:MFM]RETQTY - [F:MFM]USEQTY
                         WQTYCONS = [F:MFM]RETQTY - [F:MFM]USEQTY
                     Endif
                     If [F:ITM]NEGSTO = 1
                        WQTYCONS = min(WQTYCONS,LDIS)
                     Endif
                     If WQTYCONS < 0 : WQTYCONS = 0 : Endif
                 Endif
             Endif
             Call QTEARR(WQTYCONS,[F:MFM]STU) From TRTDIV
             If WQTYCONS > 0

# CCC (25/02/08) Bug 46057 : Ici, on ne sait pas encore ce qui va pouvoir être consommé
#                 [F:MFM]USEQTY += WQTYCONS
#                 Call QTEARR([F:MFM]USEQTY,[F:MFM]STU) From TRTDIV
                 Raz [F:MKM]
                 [F:MKM]          = [F:MFM]
                 [F:MKM]PJT       = [F:MFI]PJT
                 [F:MKM]MKMTEX    = [F:MFM]MFMTEX
                 [F:MKM]MATTYP    = 1
                 [F:MKM]USEQTY    = WQTYCONS
                 [F:MKM]MATTRKLIN = WMATSOL+1
                 [F:MKM]MFGTRKNUM = WMTKNUM
                 [F:MKM]CUMMATSUI = 0
                 [F:MKM]MFMITMREF = [F:MKM]ITMREF
                 [F:MKM]IPTDAT    = GCLODAT  # 90256 MM 05.2014 - à la place de date$
                 [F:MKM]LOCPREF   = [F:MFM]LOC
                 [F:MKM]STAPREF   = [F:MFM]STA
                 [F:MKM]CREDAT    = date$
                 [F:MKM]CREUSR    = GUSER
                 [F:MKM]EXPNUM    = [C]EXPORT
                 [F:MKM]MFMEXTQTY = [F:MFM]RETQTY
                 Raz [F:MKM]UPDUSR
                 Raz [F:MKM]UPDDAT
                 If [F:MKM]MKMTEX <> ""
                    #en auto on n'a pas pu saisir du texte, donc si texte il y a, il vient de l'OF et a comme préfixe
                    #MFM,ou BOD
                    #on ne duplique que si ça vient de l'OF.
                    If left$([F:MKM]MKMTEX,3)="MFM"
                       Call DUP_CLOB("MKM",[F:MKM]MKMTEX,GOK) From TRTX3TEX
                    Endif
                 Endif

                 # mise à jour des stocks
                 WWQTY = [F:MKM]USEQTY
                 Gosub LOAD_MTMK       From MTKAUTLIB
                 Gosub LOAD_SOW_SORTIE From MTKAUTLIB
                 Gosub LOAD_STW        From MTKAUTLIB
                 # 12.05 demande 33517
                 Gosub LOAD_ALP        From MTKAUTLIB
                 Raz LQTA,LSHT,LNBR,LNBJ,LRET
                 If [F:MFM]ALLSTA > 1
                 Call MAJALLORI([F:MKM]MATTRKLIN,LRET) From STKALL
                 If LRET : GOK = 0 : Endif
                 WWALLQTY = [M:ALP]DESQTY
                 WWSHTQTY = [M:ALP]DESQTYSHT
                 Endif
                 Call ALISTOWORK(3,[F:MKM]MATTRKLIN,LQTA,LSHT,LNBR,LNBJ,LRET) From STKINT
                 If LRET : GOK = 0 : Endif
                 If [F:ITM]NEGSTO <> 2
                     If [F:MKM]USEQTY >  LQTA + LSHT
                        [F:MKM]USEQTY = LQTA
                     Endif
                 Endif
                If [F:MKM]USEQTY <> 0
                     # CCC (25/02/08) Bug 46057
                     [F:MFM]USEQTY += [F:MKM]USEQTY
                     Call QTEARR([F:MFM]USEQTY,[F:MFM]STU) From TRTDIV

                     # Issue 74998 - 2011-09-05 by CCC : Alim des section avant création WIPCOST
                     # chargement des sections ana de MFM dans [MTMK]
                     Read [CAL] CAL0="MFM";0;[F:MFM]MFGNUM;[F:MFM]MFGLIN;[F:MFM]BOMSEQ;[F:MFM]ITMREF;1
                     If !fstat
                            For I=1 To max(GNBDIE,GOPTCANA)
                                J=find([F:CAL]DIE(I-1),GDIE(1..GNBDIE))
                                If J
                                  Assign "[M:MTMK]CCE"+num$(J) With [F:CAL]CCE(I-1)
                                Endif
                            Next I
                     Endif
                     Write [F:MKM]
                     If fstat
                         GOK = 0 : Call FSTA("MKM") From GLOCK : Return
                     Endif
                     # On a [MTMK] en ligne, on appelle le trt associe au suivi automatique
                      Gosub MAJMKM_CPTANALIN  From MTKAUTLIB

                     Call MAJ_STOCK() From STKMAJ
                     If GOK < 1 : Return: Endif
                     #point d'entrée  pour mise à jour spécifique  05.04 demande 22362
                     GPOINT = "MKMTRKMAJ" : Gosub ENTREE From EXEFNC
                     #
                     WMATSOL += 1

                     #----- Mise à jour statistiques suivi matière -----#
                     Call VALSTA("MKM",1) From SUBPS2 : If GOK<1 : Return : Endif

                    # CCC (10/01/08) DM 44021
                    If [F:MFM]TRKLAST<date$
                       [F:MFM]TRKLAST   = date$
                    Endif
                    If [F:MFM]TRKLASTC<date$
                       [F:MFM]TRKLASTC  = date$
                    Endif
                    If [F:MFM]TRKFIRST>date$ | [F:MFG]TRKFIRST = "00/00/00"
                        [F:MFM]TRKFIRST = date$
                    Endif
                    If [F:MFM]TRKFIRSTC>date$ | [F:MFG]TRKFIRSTC = "00/00/00"
                        [F:MFM]TRKFIRSTC = date$
                    Endif

                Endif
             Endif
         Endif
   Endif
   [F:MFM]MFMTRKFLG = 5
   [F:MFM]MATSTA = 3

   If [F:MFM]ALLQTY <> 0 | [F:MFM]SHTQTY <> 0
       Local    Char    WFCY(GLONFCY) :       WFCY = [F:MFM]MFGFCY
       Local    Char    WNUM(GLONVCR) :       WNUM = [F:MFM]MFGNUM
       Local    Decimal WLIN          :       WLIN = [F:MFM]MFGLIN
       Local    Integer WTYP          :       WTYP = 10
       Local    Decimal WSEQ          :       WSEQ = [F:MFM]BOMSEQ
       Local    Char    WITM(GLONITM) :       WITM = [F:MFM]ITMREF
       Local Integer WRET
       If    ([F:MFM]ALLQTY & [F:MFM]SHTQTY) : WOPT = 0
       Elsif  [F:MFM]ALLQTY                  : WOPT = 1
       Else                                  : WOPT = 2
       Endif
       Call DELALL(WTYP, WNUM, WLIN, WSEQ, WITM, WOPT, [F:MFM]ALLQTY, [F:MFM]SHTQTY, WRET) From STKALL
       If WRET <> 0 : GOK = 0 : Return : Endif
       Raz [F:MFM]ALLQTY,[F:MFM]SHTQTY
   Endif
   WMATCLENBR += 1
Endif
# CCC (10/01/08) DM 44021
#If [F:MFM]TRKFIRST = [0/0/0] : [F:MFM]TRKFIRST = date$ : Endif
#If [F:MFM]TRKLAST  = [0/0/0] : [F:MFM]TRKLAST  = date$ : Endif

Return


######################################################
#Désolde d'une matière . Traitement appelé aussi depuis SUBMFS3
$DESOLDE_MAT
Local    Integer  WRET
Local    Decimal  WALL, WSHT, WWRK, WDIFF
Local    Integer  WALLTYP
Local    Char     WCOD(1)
#
Read [F:ITM]ITM0 = [F:MFM]ITMREF
If fstat : Raz [F:ITM] : Endif
Read [F:ITF]ITF0 = [F:MFM]ITMREF;[F:MFM]MFGFCY
If fstat : Raz [F:ITF] : Endif
If [F:MFM]USEQTY = 0
    If clalev([M:MFS0]) & [M:MFS0]WPRN = 2 : [F:MFM]MFMTRKFLG = 3
    Else                : [F:MFM]MFMTRKFLG = 1
    Endif
    [F:MFM]MATSTA = 1
Else
    [F:MFM]MFMTRKFLG = 4
    [F:MFM]MATSTA = 2
Endif

Case [F:MFM]ALLSTA
     When 2,3:      WALLTYP = 1    # allocation globale
     When 4,5:      WALLTYP = 2    # allocation détaillée
     When Default : WALLTYP = 0    # pas d'allocation
Endcase
#
If WALLTYP <> 0
    WALL = [F:MFM]RETQTY - [F:MFM]USEQTY
    WSHT = 0
    WCOD = "C"
    Call ALLOCATION(WCOD, WALLTYP, WALL, WSHT, WRET) From MFGALL
    If WRET  = 9 : Return : Endif        # llc 07.01 9308
    If WRET <> 0 : GOK = 0 : Return : Endif
    [F:MFM]ALLQTY     = WALL
    [F:MFM]SHTQTY     = WSHT
    # mise à jour statut allocation
    Case [F:MFM]ALLSTA
        When 2,4:   If [F:MFM]SHTQTY = 0  : [F:MFM]ALLSTA += 1 : Endif
        When 3,5:   If [F:MFM]SHTQTY <> 0 : [F:MFM]ALLSTA -= 1 : Endif
    Endcase
Endif
WMATCLENBR -= 1
Return

###########################################################################
Subprog CTR_VALID(LRET,LOPE,LITM,LMAT)
Variable Integer LRET,LOPE,LITM,LMAT
Local Decimal WRAPP, WQTYCONS
Local Integer WWIP : WWIP = 0                # 08.05 31594

# Issue 83444 - 2012-09-06 by CCC : LOPE mal calculé
Local Integer WSTAOPE  # 0 : aucune opé n'est à suivre
                       # 1 : il existe une opé non suivie
                       # 2 : il n'existe que des opé en cours
Local Integer WQTYOPE  # 0 : toutes les opé suivies ont réalisé une qté suffisante
                       # 2 : il existe une opé avec une qté réalisée insuffisante

Filter [F:MFO] Where MFGNUM = [F:MFG]MFGNUM
For [F:MFO]
    If [F:MFO]OPESTA = 6 : Goto N1 : Endif    # si opération exclue
#S'agit-il d'une opération de sous-traitance
    Read [F:MWS]WST0 = [F:MFO]EXTWST;[F:MFO]MFGFCY
    If !fstat
       If [F:MWS]WSTTYP=3
          If    [F:MFO]OPESTA = 7
                LRET = 1
          Elsif [F:MFO]OPESTA = 4
                Read [F:OPS]OPS1 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
                If fstat : Raz [F:OPS] : Endif
                Read [F:POQ]POQ0 = [F:OPS]POHNUM;[F:OPS]POPLIN;[F:OPS]POPSEQ
                If fstat : Raz [F:POQ] : Endif
                If [F:POQ]LINCLEFLG <> 2 : LRET = 1 : Endif
          Endif
       Endif
    Endif
    If    [F:MFO]MFOTRKFLG < 4
        #LOPE = 1
        WSTAOPE = 1
    Elsif [F:MFO]MFOTRKFLG < 5
        #If LOPE <> 3 : LOPE = 2 : Endif
        If WSTAOPE <> 1 : WSTAOPE = 2 : Endif
        WRAPP    = [F:MFO]EXTQTY / [F:MFG]EXTQTY
        WQTYCONS = [F:MFG]CPLQTY * WRAPP
        Call QTEARR(WQTYCONS,[F:MFO]OPEUOM) From TRTDIV
        If [F:MFO]CPLQTY < WQTYCONS
#            If LOPE = 1
#                LOPE = 4
#            Else
#                LOPE = 3
#            Endif
            WQTYOPE = 2
        Endif
    Endif
#    If [F:MFO]MFOTRKFLG > 4 : WWIP += 1 : Endif                              # 08.05 31594
    If [F:MFO]MFOTRKFLG > 3 : WWIP += 1 : Endif                               # 01.07 39148
$N1
Next
Filter [MFO]

LOPE = WSTAOPE + WQTYOPE

Filter [F:MFI] Where MFGNUM = [F:MFG]MFGNUM
For [F:MFI]
    If [F:MFI]MFITRKFLG < 4 : LITM = 1 : Else : WWIP += 1 : Endif            # 08.05 31594
Next
Filter [F:MFI]

Filter [F:MFM] Where MFGNUM = [F:MFG]MFGNUM & CPNTYP <> 5
For [F:MFM]
    If [F:MFM]MATSTA = 4 : Goto N2 : Endif    # si matière exclue

    # GA 05/2009 corrections FQ 53258 et FQ 53237
    #If dim([F:MFM]PKC)<=0 | !find([F:MFM]PKC,8,9) #on ne contrôle pas que pour les matières autres que rectif
    #    If [F:MFM]MFMTRKFLG < 4 : LMAT = 1 : Else : WWIP += 1 : Endif        # 08.05 31594
    #Endif
    If [F:MFM]MFMTRKFLG > 3 : WWIP += 1 : Goto N2 : Endif  # FQ 53237 contrôler tjs si suivi ok
    If dim([F:MFM]PKC)<=0 | !find([F:MFM]PKC,8,9)
      # FQ 53258 si matière non soldée, on vérifie si consommée ou non pour avertir l'utilisateur
      # seules les matières en sortie de stock post-conso pourront être sorties automatiquement (cf CTR_MAT)
        If [F:MFM]MFGLIN <> 0
           Read [F:MFI]MFI0 = [F:MFM]MFGNUM;[F:MFM]MFGLIN
           If !fstat
               WRAPP    = [F:MFM]RETQTY / [F:MFI]EXTQTY
               WQTYCONS = [F:MFI]CPLQTY * WRAPP
               Call QTEARR(WQTYCONS,[F:MFM]STU) From TRTDIV
               If [F:MFM]USEQTY < WQTYCONS
                   LMAT = 1
               Endif
           Endif
         Else
           WRAPP    = [F:MFM]RETQTY / [F:MFG]EXTQTY
           WQTYCONS = [F:MFG]CPLQTY * WRAPP
           Call QTEARR(WQTYCONS,[F:MFM]STU) From TRTDIV
           If [F:MFM]USEQTY < WQTYCONS
               LMAT = 1
           Endif
         Endif
    Endif
$N2
Next
Filter [F:MFM]

# FQ 55435 si l'OF comporte un suivi matière non prévue, on peut solder
If !WWIP  # Ctrl s'il existe un suivi matière non prévue
    If clalev ([F:MKM]) <= 0 : Local File MFGMATTRK  [MKM] : Endif     # FQ 59884 GA 11/2009
    Filter [F:MKM] Where MFGNUM = [F:MFG]MFGNUM & MFMITMREF=""
    For [F:MKM]
        WWIP += 1
    Next
    Filter [F:MKM]
Endif

# Issue 69198 - 2010-11-18 by CCC : Ctrl s'il existe un suivi d'opé non prévue
If !WWIP
    If clalev ([F:MKO]) <= 0 : Local File MFGOPETRK  [MKO] : Endif
    Filter [F:MKO] Where MFGNUM = [F:MFG]MFGNUM
    For [F:MKO]
        WWIP = 1
        Break
    Next
    Filter [F:MKO]
Endif

# FQ 55435 PE manquant par rapport à v130
# 12.06 demande 38620 : Possibilite de modifier la valeur des indicateur LOPE,LMAT,LITM
GPOINT = "CUSCTLSUP" : Gosub ENTREE From EXEFNC

# 08.05 31594
If !WWIP : LRET = 9 : Endif
End

###########################################################################
Subprog CTR_MAT(LRET)              # détermine si conso automatique ou non
Variable Integer LRET
Local Decimal WRAPP, WQTYCONS

Filter [F:MFM] Where MFGNUM = [F:MFG]MFGNUM & CPNTYP <> 5
For [F:MFM]
    If [F:MFM]MATSTA = 4 : Goto N3 : Endif    # si matière exclue
    If [F:MFM]MFMTRKFLG < 5
       Read [F:ITM]ITM0 = [F:MFM]ITMREF
       If fstat : Raz [F:ITM] : Endif
       #If [F:ITM]SERMGTCOD = 1  # FQ 53237 tjs controler si matière consommée ou non
          Read [F:ITF]ITF0 = [F:MFM]ITMREF;[F:MFM]MFGFCY
          If fstat : Raz [F:ITF] : Endif
          If [F:ITF]STOCOD = 2               # Matières gérées en retrait post-conso
               If [F:MFM]MFGLIN <> 0
                   Read [F:MFI]MFI0 = [F:MFM]MFGNUM;[F:MFM]MFGLIN
                   If !fstat
                       WRAPP    = [F:MFM]RETQTY / [F:MFI]EXTQTY
                       WQTYCONS = [F:MFI]CPLQTY * WRAPP
                       Call QTEARR(WQTYCONS,[F:MFM]STU) From TRTDIV
                       If [F:MFM]USEQTY < WQTYCONS
                           LRET = 1
                       Endif
                   Endif
                Else
                       WRAPP    = [F:MFM]RETQTY / [F:MFG]EXTQTY
                       WQTYCONS = [F:MFG]CPLQTY * WRAPP
                       Call QTEARR(WQTYCONS,[F:MFM]STU) From TRTDIV
                       If [F:MFM]USEQTY < WQTYCONS
                           LRET = 1
                       Endif
                Endif
           Endif
           If [F:ITM]SERMGTCOD = 3 & LRET = 1
              LRET = 2                            # FQ 53237 pas de conso automatique si n°serie (en entrée/sortie)
           Endif
    Endif
$N3
Next
Filter [F:MFM]
End

##########################################################################
## Etiquette ajoutée par le superviseur 08/09/2003 16:50:29 (MM)
##########################################################################
Subprog AM_MFGFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> GFCY                   # mm 12.02
    GFCY=VALEUR                     # mm 12.02
    Gosub CHARG_PARAM
Endif                               # mm 12.02

#  08.04 demande 24301
If VALEUR <> [M:MFS0]MFGFCY
    Raz [M:MFS0]
    Raz [M:MFS1]
    Raz [M:MFS2]
    Raz [M:MFS3]
    Raz [M:MFS4]
    [M:MFS0]MFGFCY = VALEUR
    Affzo [M:MFS0]
    Affzo [M:MFS1]
    Affzo [M:MFS2]
    Affzo [M:MFS3]
    Affzo [M:MFS4]
Endif
End

Subprog C_MFGNUM(VALEUR)
Variable Char    VALEUR()

Call CTL_MFGNUM(VALEUR,GMESSAGE)
If GMESSAGE<>"" : mkstat=1 : End : Endif
End

Subprog CTL_MFGNUM(LMFGNUM,LMESSAGE)
Variable Char    LMFGNUM()
Variable Char    LMESSAGE()

Read [F:MFG]MFG0 = LMFGNUM
If fstat : LMESSAGE = mess(23,100,1)
   End
Endif
If GMFGCLOSE = "1" : End : Endif
If [F:MFG]MFGTRKFLG < 4
    LMESSAGE = mess(101,193,1)
    End
Endif
# Issue X3-29487 - 2017-03-30 by ALSHE : Close WO which is in status Being optimized when POPS is activ
# If [F:MFG]OPTFLG = 2
If [F:MFG]OPTFLG = 2 & !func AFNC.ACTIV("POPS")
    LMESSAGE = mess(122,193,1)
    End
Endif
# si l'Of est dans le plan de pesée ou en cours de pesée on ne peut pas le sélectionner  05.03 + 71913 mm 05.11
If dim([F:MFG]WGGFLG ) > 0 & find([F:MFG]WGGFLG,3,4,8)
    LMESSAGE = mess(214,193,1)
    End
Endif
LMESSAGE=""
End

##########################################################################
Subprog AP_MFGNUM(VALEUR)
Variable Char    VALEUR()
Local Integer ETABOU(1..GNBBOU)

If VALEUR = [M:MFS0]MFGNUM : End : Endif


#If VALEUR<>"" : Grizo [M:MFS0]MFGFCY
#Else
#              : Actzo [M:MFS0]MFGFCY
#                Affzo [M:MFS0]MFGFCY
#                End
#Endif    # MM 09.03 Web

[M:MFS0]MFGNUM = VALEUR
Gosub LOAD_SITU
If [M:MFS1]MFGTRKFLG > 3
    ETABOU(GSPE1) = 1 : # détail suivi
Else
    ETABOU(GSPE1) = 0
Endif
Case GMFGCLOSE
    When "1":    # ben rien
    When "3":    If [M:MFS1]MFGTRKFLG = 4  # activation bouton solde
                     ETABOU(GSPE2) = 1
                 Else
                     ETABOU(GSPE2) = 0
                 Endif
                 If [M:MFS0]MFGSTA < 4     # activation bouton clôture
                     ETABOU(GSPE3) = 1
                 Else
                     ETABOU(GSPE3) = 0
                 Endif
    When "4":    If [M:MFS0]MFGSTA = 4 & [M:MFS1]MFGTRKFLG <> 6
                      ETABOU(GSPE4) = 1
                 Else
                      ETABOU(GSPE4) = 0
                 Endif
Endcase
ETABOU(GABAN) = 1 : # Fin
Call SETBOUT(ETABOU) From GESECRAN
End

##########################################################################



##################################################
Subprog TRTCLEMFG(VCRNUM)
Value    Char    VCRNUM
Read [F:MFG]MFG0 = VCRNUM
If fstat : Raz [F:MFG] : End : Endif

Gosub SOLDE_OF
End


##################################################
Subprog TRTCLOMFG(VCRNUM,CALMFC)
Value    Char    VCRNUM
Value    Integer CALMFC

Local Integer LRET
Local Char    SAV_GFONCTION(GLONAFC)

Read [F:MFG]MFG0 = VCRNUM
If fstat : Raz [F:MFG] : End : Endif
Gosub CLOTURE_OF

# Si l'OF n'a pas été clos pour une quelconque raison, on ne calcule pas son PRF
If [F:MFG]MFGSTA=4
    SAV_GFONCTION = GFONCTION
    GFONCTION="FUNWIPMFC"
    Call AUTORIS From EXEFNC
    If GNBAUZ>0
        Case CALMFC
            When 1 : # Pas de calcul de PRF
            When 2 : # Calcul du PRF
                     Call CALMFC([F:MFG]MFGFCY,10,VCRNUM) From FUNWIPMFC
            When 3 : # Demander
                     Call OUINON(mess(80,195,1),LRET) From GESECRAN
                     If LRET=2
                         Call CALMFC([F:MFG]MFGFCY,10,VCRNUM) From FUNWIPMFC
                     Endif
        Endcase
    Endif
    GFONCTION=SAV_GFONCTION
    Call AUTORIS From EXEFNC
Endif
End

##################################################
Subprog TRTREAMFG(VCRNUM)
Value    Char    VCRNUM
Read [F:MFG]MFG0 = VCRNUM
If fstat : Raz [F:MFG] : End : Endif
Gosub ACTIVE_OF
End


##################################################
# Crée les wipcost des composant uniquement valorisés
##################################################
Subprog CREWIPCPNVAL(PMFGNUM)
Value Char PMFGNUM

Local Integer LRET, ERR
Local Decimal LQTN, LQTNA, LQTB, LQTBA
Local Char    LTCM(GLONTCM)
Local Decimal LQTY, LPRI
Local Integer LPRINAT

Local Integer    LAST_SEQ, I
Local Decimal    L_CURRND
Local Integer    X_PRINAT, X_MS, X_UC, X_TXNACT
Local Char       X_MFGFCY(GLONFCY), X_ITMREF(GLONITM), X_STU(GLONUOM)
Local Decimal    X_QTY, X_QTYACT, X_AMOUNT, X_REJQTY # CCC (04/11/04) Bug 26297 Ajouts du calcul de la qté active
Local Decimal    X_INVDTA
Local Date       X_TXNDAT
Local Char       X_ECCMAJ(GLONICVVAL), X_ECCMIN(GLONICVVAL) # Issue 117125 - 2016-06-15 by CCC
Local Integer    ITM_TYP, CST_FLG
Local Decimal    LBASAMT    # Base de calcul des FG
# Issue 89923 - 2013-05-17 by CCC
Local Char       LMAJCOD(2)
Local Integer    LMATFLG

# Issue 90036 - 2013-05-29 by CCC
Local Char    LARRQTYCPN(10)
If !clalev([F:MFG]) | [F:MFG]MFGNUM<>PMFGNUM
    Local File MFGHEAD [MFG]
    Read [F:MFG]MFG0=PMFGNUM
Endif
Call PARAM([F:MFG]MFGFCY, "ARRQTYCPN", LARRQTYCPN) From ADOVAL

If !clalev([F:BOH]) : Local File BOM        [BOH] : Endif
If !clalev([F:BOD]) : Local File BOMD       [BOD] : Endif
If !clalev([F:TCM]) : Local File TABCOSTMET [TCM] : Endif
If !clalev([F:ITG]) : Local File ITMCATEG   [ITG] : Endif
If !clalev([F:ITM]) : Local File ITMMASTER  [ITM] : Endif
If !clalev([F:ITF]) : Local File ITMFACILIT [ITF] : Endif
If !clalev([F:OVE]) : Local File OVERHEAD   [OVE] : Endif
If !clalev([F:ITC]) : Local File ITMCOST    [ITC] : Endif
If !clalev([F:ICN]) : Local File ITCNAT     [ICN] : Endif
If !clalev([F:MWI]) : Local File WIPCOST    [MWI] : Endif  # FQ 62291 Pour FUNMFGS
If !clalev([F:MWH]) : Local File MFGWIP     [MWH] : Endif  # Issue 80115 - 2012-02-14 by CCC

If !clalev([M:SDP]) : Local Mask SAIDECPRI [SDP] : Endif

Raz [F:MKM]

For [MFI] Where MFGNUM=PMFGNUM
&             & CPLQTY<>0
&             & ITMTYP<>2
    Filter [BOD] Where ITMREF = [F:MFI]ITMREF
&                        & BOMALT = [F:MFI]BOMALT
&                        & BOMALTTYP = 2
&                        & BOMSTRDAT<=date$
&                        & (BOMENDDAT>=date$ | BOMENDDAT=[0/0/0])
&                        & CPNTYP=6
&                        & CSTFLG = 2   # Issue 89128 - 2013-05-16 by CCC
    For [BOD]
        Raz [F:MWI], [M:STW]
        If [F:BOH]ITMREF<>[F:BOD]ITMREF | [F:BOH]BOMALT<>[F:BOD]BOMALT | [F:BOH]BOMALTTYP<>[F:BOD]BOMALTTYP
            Read [BOH]BOH0=[F:BOD]ITMREF;[F:BOD]BOMALT;[F:BOD]BOMALTTYP
        Endif
        If [F:BOD]LIKQTY <> 0
            Call LIKQTY([F:MFI]CPLQTY,[F:MFI]STU,[F:BOH]BASQTY,[F:BOD]LIKQTYCOD,[F:BOD]LIKQTY,
&                  [F:BOD]QTYRND,[F:BOD]SCA,LQTN,LQTNA,LQTB,LQTBA) From MFGLIB
            If dim(GSCAMAJ)>0 & GSCAMAJ = 1 # Issue 88918
                If LQTNA <> 0 & LARRQTYCPN="2"  # Issue 90036 - 2013-05-29 by CCC
                    LQTY = LQTNA
                Else
                    LQTY = LQTN
                Endif
            Else
                If LQTBA <> 0 & LARRQTYCPN="2"  # Issue 90036 - 2013-05-29 by CCC
                    LQTY = LQTBA
                Else
                    LQTY = LQTB
                Endif
            Endif
        Else
            LQTY = 0
        Endif

        If LQTY<>0
            Read [F:ITM]ITM0 = [F:BOD]CPNITMREF
            [M:STW]STOFCY = [F:MFI]MFGFCY
            # Issue 99284 - 2018-07-18 by ERMIL : Use close date from the screen
            [M:STW]IPTDAT = GCLODAT
            #[M:STW]IPTDAT = date$
            [M:STW]ITMREF = [F:BOD]CPNITMREF
            [M:STW]STU    = [F:ITM]STU
            [M:STW]TRSTYP = 6    # Sortie matière
            [M:STW]VCRTYP = 12
            [M:STW]VCRNUM = ""
            [M:STW]VCRLIN = 0
            [M:STW]VCRTYPORI = 10
            [M:STW]VCRNUMORI = [F:MFI]MFGNUM
            [M:STW]VCRLINORI = [F:MFI]MFGLIN
            [M:STW]VCRSEQORI = 0
            [M:STW]NBLIG        = 1     : # 1 ligne :si création ou annulation
            [M:STW]MAJCOD(0)    = "C"
            [M:STW]QTYSTU(0)    = LQTY
            [M:STW]ECCVALMAJ(0) = [F:BOD]ECCVALMAJ
            [M:STW]ECCVALMIN(0) = [F:BOD]ECCVALMIN
            If [F:ITM]STOMGTCOD=3 & [F:ITM]DEFPOT<>0
                # Issue 83670 GA 07/2012 calcul de la qté active
                #LQTY = LQTY / [F:ITM]DEFPOT / 100
                LQTY = LQTY * [F:ITM]DEFPOT / 100
            Endif
            [M:STW]QTYSTUACT(0) = LQTY
            # Issue 82760 - 2012-06-08 by CCC
            #Call DEFPRI([M:STW]ITMREF,[M:STW]STOFCY,5,"","","",date$,LQTY,LQTY,0,LPRINAT,LPRI,LRET) From STKVAL
            Call DEFPRI([M:STW]ITMREF,[M:STW]ECCVALMAJ(0),[M:STW]ECCVALMIN(0),[M:STW]STOFCY,[M:STW]TRSTYP,"","","",date$,LQTY,LQTY,0,LPRINAT,LPRI,LRET) From STKVAL
            # Issue 80333 - 2012-02-29 by CCC
            If LRET
                Case LRET
                    When 2 : Call ECR_TRACE(mess(248,197,1)-[M:STW]ITMREF+"/"+[M:STW]STOFCY,1) From GESECRAN
                    When 3 : Call ECR_TRACE(mess(472,197,1)-[M:STW]ITMREF+"/"+[M:STW]STOFCY,1) From GESECRAN
                    When 4 : Call ECR_TRACE(mess(753,197,1)-[M:STW]ITMREF+"/"+[M:STW]STOFCY,1) From GESECRAN
                    When Default : Call ECR_TRACE("CREWIPCPNVAL -> DEFPRI err="+num$(LRET)-[M:STW]ITMREF+"/"+[M:STW]STOFCY,1) From GESECRAN
                Endcase
                GOK=0
                Break
            Endif

            [M:SVW]AMTVAL(0)    = LPRI*LQTY
            [M:SVW]PRINAT(0)    = LPRINAT       # Issue 80115 - 2012-02-14 by CCC
            [M:SVW]NBLIG = 1
            Call COPSDP2SVWVAL (0,LQTY) From STKVALECR

            Call CRE_MFGWIP([M:STW]VCRNUMORI,[M:STW]VCRTYPORI,1,[M:STW]STOFCY,[M:STW]IPTDAT,[F:MFI]ITMREF,[F:MFI]BOMALT,"",0,"",LRET) From MWIPLIB
            # erreur de création entête valorisation encours d'OF (MFGWIP)
            If LRET | GOK<1 : GMESSAGE = mess(17,2363,1) : GOK=0 : Break : Endif # FQ 69909 ctrl des sources avant End

            Read [FCY]FCY0=[M:STW]STOFCY
            Call GET_CUR_RND([F:FCY]LEGCPY, L_CURRND, LRET) From MWIPLIB
            # "erreur de lecture sur devise ; société juridique"
            If ERR = 1
              GMESSAGE = mess(10,2363,1)-[F:FCY]LEGCPY
              GOK=0 : Break # FQ 69909 ctrl des sources avant End  (sans maj GOK)
            Endif

            # Selon les cumuls X_QTY, créer un enreg 'Supp' ou un enreg 'Nouveau'
            # positionner X_TXNACT et inverser la qté et le montant si besoin
            # Traite aussi les régularisations de mvt en attente
            X_TXNDAT = [M:STW]IPTDAT
            X_MFGFCY = [M:STW]STOFCY
            X_ITMREF = [M:STW]ITMREF
            X_STU    = [M:STW]STU

            X_QTY     = [M:STW]QTYSTU(0)
            X_QTYACT  = [M:STW]QTYSTUACT(0)
            X_AMOUNT  = [M:SVW]AMTVAL(0)
            X_PRINAT  = [M:SVW]PRINAT(0)
            # Issue 117125 - 2016-06-15 by CCC : Use of X_ECCMxx in MWIPLIB
            X_ECCMAJ  = [M:STW]ECCVALMAJ(0)
            X_ECCMIN  = [M:STW]ECCVALMIN(0)

            If X_QTY <> 0
                # créer un enreg de type "Nouveau"
                Call GET_LAST_SEQ([F:MWH]VCRTYP,[F:MWH]VCRNUM,LAST_SEQ) From MWIPLIB
                X_TXNACT = 1  # on ne distinguera pas le 'modifié' du 'Nouveau' !
                Gosub MWI_MAT From MWIPLIB
                # erreur en retour "erreur à la mise à jour des encours d'OF (WIPCOST)
                If ERR
                    GMESSAGE = mess(20,2363,1)
                    GOK=0 : Break # FQ 69909 ctrl des sources avant End
                Endif
            Endif

            If LRET : GOK=0 : Break : Endif
        Endif
    Next
    Filter [BOD]
    If GOK=0 Break Endif # FQ 69909 ctrl des sources (ligne ajoutée)
Next
End

# Issue 89939 - 2013-05-29 by CCC : Annulation des wipcost sur articles uniquement valorisés lors de la réouverture OF
Subprog DELWIPCPNVAL(PMFGNUM)
Value Char PMFGNUM

If dim(GDIMCST)<=0 : Global Integer GDIMCST : Endif
GDIMCST = GACTMAT+GACTMAC+GACTLAB+2+4     # = dim mat + dim mac + dim lab + sco + invdta + fg mat + fg mac + fg lab + fg sco
Local Decimal LDELTA(1+GDIMCST*GACTDECCST)
Local Integer LAST_SEQ

If !clalev([F:BOH]) : Local File BOM        [BOH] : Endif
If !clalev([F:BOD]) : Local File BOMD       [BOD] : Endif
If !clalev([F:MWI]) : Local File WIPCOST    [MWI] : Endif
If !clalev([F:MWI1]): Local File WIPCOST    [MWI1]: Endif
If !clalev([F:MFI]) : Local File MFGITM     [MFI] : Endif

For [MFI] Where MFGNUM=PMFGNUM
&             & CPLQTY<>0
&             & ITMTYP<>2
    Filter [BOD] Where ITMREF = [F:MFI]ITMREF
&                        & BOMALT = [F:MFI]BOMALT
&                        & BOMALTTYP = 2
&                        & BOMSTRDAT<=date$
&                        & (BOMENDDAT>=date$ | BOMENDDAT=[0/0/0])
&                        & CPNTYP=6
&                        & CSTFLG = 2
    For [BOD]
        Raz [F:MWI]
        # Les enreg wipcost des articles uniquement valorisés n'ont pas de n° de suivi
        # On supprime d'abord les enreg qui n'ont pas été comptabilisés
        Delete [MWI1] Where VCRTYP=10
&                      & VCRNUM=PMFGNUM
&                      & TXNTYP=1
&                      & MFGTRKNUM=""
&                      & ITMREF = [F:BOD]CPNITMREF
&                      & GLPSTA=1
        # On annule avec un enreg d'extourne les enreg qui ont déjà été comptabilisés
        For [MWI1] Where VCRTYP=10
&                      & VCRNUM=PMFGNUM
&                      & TXNTYP=1
&                      & MFGTRKNUM=""
&                      & ITMREF = [F:BOD]CPNITMREF
            If [F:MWI]VCRNUM=""
                [F:MWI]=[F:MWI1]
                Raz [F:MWI]QTY,[F:MWI]QTYACT
                Raz [F:MWI]CSTELM, [F:MWI]AMOUNT
                Raz LDELTA
                Call LOADFIC("[F:MWI]",LDELTA, "", "CST", 0, 0)  From STKVALECR  # Alimente les zones MATCST, MACCST...
                Raz [F:MWI]MATLEV0
                [F:MWI]GLPSTA    = 1
                Raz [F:MWI]GLPDAT, [F:MWI]JOUNUM, [F:MWI]JOUTYP
            Endif
            [F:MWI]QTY -= [F:MWI1]QTY
            [F:MWI]QTYACT -= [F:MWI1]QTYACT
            Call LOADVAR(LDELTA,"[F:MWI1]", 0, "", -1, 0, 0)  From STKVALECR  # Alimente les zones MATCST, MACCST...
            Call LOADFIC("[F:MWI]",LDELTA, "", "CST", 1, 1)  From STKVALECR  # Alimente les zones MATCST, MACCST...
            For I=0 To dim([F:MWI]CSTELM)-1
                [F:MWI]CSTELM(I) -= [F:MWI1]CSTELM(I)
            Next
            [F:MWI]AMOUNT -= [F:MWI1]AMOUNT
            [F:MWI]MATLEV0 -= [F:MWI1]MATLEV0
        Next
        If [F:MWI]AMOUNT<>0 | [F:MWI]QTY<>0
            [F:MWI]TXNDAT = date$
            [F:MWI]TXNACT = 3
            Call GET_LAST_SEQ(10,PMFGNUM,LAST_SEQ) From MWIPLIB
            [F:MWI]WIPSEQ = LAST_SEQ +1
            Call ECR_MWI From MWIPLIB
        Endif
    Next
    Filter [BOD]
Next

End

# Issue 99496 - 2014-11-03 by CCC : pending transaction control
#**----------------------------------------------------------------<br/>
#* CTRL_WAITRS_WO : returns number of pending movements for an EO
#**<br/>----------------------------------------------------------------<br/>
#* @param PFCY = Site
#* @param PMFGNUM = WO number
#**<br/>----------------------------------------------------------------
#*!
Funprog CTRL_WAITRS_WO(PFCY,PMFGNUM)
Value Char PFCY
Value Char PMFGNUM

If !clalev([F:STJ]) : Local File STOJOU [STJ] : Endif

Local Integer LNB

Filter [STJ] Where STOFCY=PFCY
&                & UPDCOD=1
&                & VCRTYPORI=10
&                & VCRNUMORI=PMFGNUM
LNB = rowcount([STJ])
Filter [STJ]

End LNB

