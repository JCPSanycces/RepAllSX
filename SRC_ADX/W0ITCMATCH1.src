#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ITCMATCH1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
indice = 0
status = 1
zoncou = "NBLIG"
If varmode([M]NBLIG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG = nolign
   status = 75
   Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone INVDTA1
mkstat = 0
zoncou = "INVDTA1"
indice = 0
SAVACT = GACTION : GACTION = "PARDEV"
GACTION = SAVACT
If mkstat=1 : Raz [M]INVDTA1 : Endif

## Zone CSTTOT1
mkstat = 0
zoncou = "CSTTOT1"
indice = 0
SAVACT = GACTION : GACTION = "PARDEV"
GACTION = SAVACT
If mkstat=1 : Raz [M]CSTTOT1 : Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone INVDTA2
mkstat = 0
zoncou = "INVDTA2"
indice = 0
SAVACT = GACTION : GACTION = "PARDEV"
GACTION = SAVACT
If mkstat=1 : Raz [M]INVDTA2 : Endif

## Zone CSTTOT2
mkstat = 0
zoncou = "CSTTOT2"
indice = 0
SAVACT = GACTION : GACTION = "PARDEV"
GACTION = SAVACT
If mkstat=1 : Raz [M]CSTTOT2 : Endif

####################################
## Bloc liste 4
####################################
IMPTBL = 0

####################################
## Bloc tableau 5
####################################
IMPTBL = 1

## Zone NBLIG1
mkstat = 0
zoncou = "NBLIG1"
indice = 0
status = 1
zoncou = "NBLIG1"
If varmode([M]NBLIG1,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG1" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG1
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG1 = nolign
   status = 75
   Call SAI_NBLIG1(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

## Zone COST1
mkstat = 0
zoncou = "COST1"
SAVACT = GACTION : GACTION = "PARDEV"
GACTION = SAVACT
If mkstat=1 : Raz [M]COST1(indice) : Endif

## Zone COST2
mkstat = 0
zoncou = "COST2"
SAVACT = GACTION : GACTION = "PARDEV"
GACTION = SAVACT
If mkstat=1 : Raz [M]COST2(indice) : Endif

## Zone VARCST
mkstat = 0
zoncou = "VARCST"
SAVACT = GACTION : GACTION = "PARDEV"
GACTION = SAVACT
If mkstat=1 : Raz [M]VARCST(indice) : Endif

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

End

####################################
## Bloc tableau 5
####################################
Subprog SAI_NBLIG1(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG1
mkstat = 0
zoncou = "NBLIG1"

## Zone NBLIG1
mkstat = 0
zoncou = "NBLIG1"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "ITCMATCH1"
Return

