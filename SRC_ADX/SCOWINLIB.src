#<AdxTL>@(#)2.0.0.0 $Revision$
#######################################################################
#    TRAITEMENTS de SAISIE ou VISU en FENETRE - Achats sous-traitance #
#######################################################################
#    SCOWINLIB    selon MFGWINLIB, MFMWINLIB                          #
#######################################################################
#    SCITRKPRI: Prix d'une ligne article sous-traité                  #
#    SCITRKSTA: Situation d'une ligne article sous-traité MFITRKSTA   #
#               => remplacée par VISUETASCO Situation EO              #
#                                                                     #
#    SCSTRKPRI: Prix d'une ligne service                              #
#    SCSTRKSTA: Situation d'une ligne service             MFOTRKSTA   #
#                                                                     #
#    SCMFICH  : Détail d'une matière (selon MFMFICH / MFMWINLIB)      #
#    SCMTRKPRI: Prix d'une matière                                    #
#    SCMTRKSTA: Situation d'une ligne matière             MFMTRKSTA   #
#                                                                     #
#    SCKFICH  : Conso d'une matière non prévue en réception [93349]   #
#######################################################################
$ACTION
#--- Actions liés au type fenêtre de saisie
Case ACTION
    When "OUVRE"      : Gosub OUVRE
    When "SETBOUT"    : Gosub SETBOUT
    When "DEBUT"      : Gosub DEBUT
    When "ENR"        : Gosub ENR
    When "AVANT_OK"   : Gosub AVANT_OK
    When "OK"         : Gosub OK
    When "ABA"        : Gosub ABA
    When "END"        : Gosub ENDF
    When "APRES_MODIF": Gosub APRES_MODIF
    When "BOUTON"     : Gosub BOUTON
    When "FIN"        : Gosub FIN
    When "FINSAI"     : Gosub FINSAI
Endcase
#--- Actions liés au type traitement standard
Case ACTION
    When "INIT"       : Gosub INIT
    When "INIT_DIA"   : Gosub INIT_DIA
    When "CONTROLE"   : Gosub CONTROLE
    When "EXEC"       : Gosub EXEC
    When "TERMINE"    : Gosub TERMINE
Endcase

Return

#########################################################################
#    Actions liés au type fenêtre de saisie                             #
#########################################################################
$OUVRE
Case GACTION
    When "SCITRKPRI"    : Gosub OUV_SCITRKPRI
    When "SCITRKSTA"    : Gosub OUV_SCITRKSTA

    When "SCSTRKPRI"    : Gosub OUV_SCSTRKPRI
    When "SCSTRKSTA"    : Gosub OUV_SCSTRKSTA

    When "SCMFICH"      : Gosub OUV_SCMFICH
    When "SCMTRKPRI"    : Gosub OUV_SCMTRKPRI
    When "SCMTRKSTA"    : Gosub OUV_SCMTRKSTA

    When "SCKFICH"      : Gosub OUV_SCKFICH  # Issue 93349 GA 10/2013 Action SCKFICH for GESPTH
Endcase
Return

#-------------------------------------------------
$SETBOUT
Case GACTION
    When "SCITRKPRI"    : Gosub SETBOUT_SCITRKPRI
    When "SCITRKSTA"    : Gosub SETBOUT_SCITRKSTA

    When "SCSTRKPRI"    : Gosub SETBOUT_SCSTRKPRI
    When "SCSTRKSTA"    : Gosub SETBOUT_SCSTRKSTA

    When "SCMFICH"      : Gosub SETBOUT_SCMFICH
    When "SCMTRKPRI"    : Gosub SETBOUT_SCMTRKPRI
    When "SCMTRKSTA"    : Gosub SETBOUT_SCMTRKSTA

    When "SCKFICH"      : Gosub SETBOUT_SCKFICH  # Issue 93349 GA 10/2013 Action SCKFICH for GESPTH
Endcase
Return

#-------------------------------------------------
$DEBUT
Case GACTION
    When "SCITRKPRI"    : Gosub DEB_SCITRKPRI
    When "SCITRKSTA"    : Gosub DEB_SCITRKSTA

    When "SCSTRKPRI"    : Gosub DEB_SCSTRKPRI
    When "SCSTRKSTA"    : Gosub DEB_SCSTRKSTA

    When "SCMFICH"      : Gosub DEB_SCMFICH
    When "SCMTRKPRI"    : Gosub DEB_SCMTRKPRI
    When "SCMTRKSTA"    : Gosub DEB_SCMTRKSTA

    When "SCKFICH"      : Gosub DEB_SCKFICH  # Issue 93349 GA 10/2013 Action SCKFICH for GESPTH
Endcase
Return

#-------------------------------------------------
$ENR
Case GACTION
Endcase
Return

#-------------------------------------------------
$AVANT_OK
Case GACTION
Endcase
Return

#-------------------------------------------------
$OK
Case GACTION
    When "SCMFICH"      : Gosub OK_SCMFICH
    When "SCKFICH"      : Gosub OK_SCKFICH  # Issue 93349 GA 10/2013 Action SCKFICH for GESPTH
Endcase

Return

#-------------------------------------------------
$ABA
Case GACTION
Endcase
Return

#-------------------------------------------------
$ENDF
Case GACTION
Endcase
Return

#-------------------------------------------------
$APRES_MODIF
Case GACTION
    When "SCMFICH"    : REP = "M" : MMODIF = 1
Endcase
Return

#-------------------------------------------------
$BOUTON
Case GACTION
    When "SCMFICH"   : Gosub BOUT_SCMFICH
Endcase
Return

#-------------------------------------------------
$FIN
Case GACTION
    When "SCMFICH"   : Gosub FIN_SCMFICH
    When "SCKFICH"   : Gosub FIN_SCKFICH  # Issue 93349 GA 10/2013 Action SCKFICH for GESPTH
Endcase
Return

#-------------------------------------------------
$FINSAI
Case GACTION
Endcase
Return

#########################################################################
#    Actions liés au type traitement standard                           #
#########################################################################
$INIT
Case GACTION
Endcase
Return

#-------------------------------------------------
$INIT_DIA
Case GACTION
Endcase
Return

#-------------------------------------------------
$CONTROLE
Case GACTION
Endcase
Return

#-------------------------------------------------
$EXEC
Case GACTION
Endcase
Return

#-------------------------------------------------
$TERMINE
Case GACTION
Endcase
Return




################################################################################
# SCMFICH : Gestion en fiche d'une ligne composant Ordre sous-traitance        #
################################################################################
$OUV_SCMFICH
Local    Integer    WLIG   : WLIG = val(PARAM(1))
Local    Integer    WNEW
Local    Integer    WOK, I
Local    Integer    SLIG, J

# Issue 93349 GA 10/2013 Cohabitation avec l'action SCKFICH
# dans SUBSCM on utilise à présent les buffers [F:SCO], [F:SCI], [F:SCS] au lieu des masques écrans
Gosub OPEN_FILES_SCO From SCOLIB
[F:SCO]=[M:SCO0] :[F:SCO]=[M:SCO1]
[F:SCI]=[M:SCO0] :[F:SCI]=[M:SCO1]
[F:SCS]=[M:SCO0] :[F:SCS]=[M:SCO3]

Return

#-------------------------------------------------
$DEB_SCMFICH
MMODIF = 0
GMODMAT = 0
WNEW = 0
If [M:SCO2]CPNITMREF(WLIG) = ""                                    :  # si ajout matière non prévue
    WNEW = 1
Else
    If [M:SCO2]BOMSEQ(WLIG) = 0 : WNEW = 2 : Goto FIN_ANA : Endif  :  # si modif matière non prévue
    If [M:SCO2]MATSTA(WLIG) > 2 : WNEW = 3 : Goto FIN_ANA : Endif  :  # si matière exclue ou soldée
    If [M:SCO2]MATSTA(WLIG) = 2 : WNEW = 4 : Goto FIN_ANA : Endif  :  # si matière en cours

#GA If [M:SCO2]CUMFLG(WLIG) = 2 & [M:SCO2]MFGLIN(WLIG) = 0     :  # si matière cumulée
#GA        WNEW = 5
#GA        Goto FIN_ANA
#GA    Endif

Endif

#GA If [M:MFG1]MFGTRKFLG = 2 : WNEW = 3 : Endif

$FIN_ANA
Case WNEW
    When 0: # accès en fiche d'une matière existante
            GMODMAT     = 1
            nolign = WLIG + 1
            [M:SCM0] = [M:SCO0] : [M:SCM0] = [M:SCO2]
            [M:SCMW] = [M:SCO1] : [M:SCMW] = [M:SCO2]
            Diszo [M:SCMW]STU
            Diszo [M:SCMW]LIKQTY
            Diszo [M:SCMW]LIKQTYCOD
            Diszo [M:SCMW]QTYRND
    When 1: # ajout nouvelle matière
            GMODMAT     = 2
            Raz [M:SCM0],[M:SCMW]
            nolign = WLIG + 1
            Gosub RAZCRE From SUBSCO2
            # Issue 79808 - 2012-03-12 by CCC :
            # Remise à 0 des sections analytiques qui ont pu être initialisées.
            # Elles le seront de nouveau lors de la saisie de l'article
            For I=1 To GOPTCANA
                Assign "[M:SCO2]CCE"+num$(I)+"(nolign-1)" With ""
            Next

            [M:SCM0] = [M:SCO0] : [M:SCM0] = [M:SCO2]
            [M:SCMW] = [M:SCO1] : [M:SCMW] = [M:SCO2]
    When 2: # accès en fiche d'une matière non prévue existante
            GMODMAT     = 1
            nolign = WLIG + 1
            [M:SCM0] = [M:SCO0] : [M:SCM0] = [M:SCO2]
            [M:SCMW] = [M:SCO1] : [M:SCMW] = [M:SCO2]
            Diszo [M:SCM0]CPNITMREF
            Diszo [M:SCMW]STU
    When 3: # accès en fiche d'une matière exclue (visu uniquement)
            GMODMAT     = 1
            nolign = WLIG + 1
            [M:SCM0] = [M:SCO0] : [M:SCM0] = [M:SCO2]
            [M:SCMW] = [M:SCO1] : [M:SCMW] = [M:SCO2]
            Diszo [M:SCM0] : Diszo [M:SCMW]
    When 4: # accès en fiche d'une matière en cours
            GMODMAT  = 1
            nolign = WLIG + 1
            [M:SCM0] = [M:SCO0] : [M:SCM0] = [M:SCO2]
            [M:SCMW] = [M:SCO1] : [M:SCMW] = [M:SCO2]
            Diszo [M:SCM0] : Diszo [M:SCMW]
            Actzo [M:SCM0]CPNITMREF : # pour accèder aux boutons
            Actzo [M:SCMW]RETQTY
Endcase

If WNEW <> 1
    If dim([M:SCMW]XTYPQTY) > 0
        If [M:SCO2]TYPQTY(WLIG) <> 0
            [M:SCMW]XTYPQTY  = mess([M:SCO2]TYPQTY(WLIG), 2311, 1)
        Else
            Raz [M:SCMW]XTYPQTY
        Endif
    Endif
    If dim([M:SCMW]XTYPQTY2) > 0
        If [M:SCO2]TYPQTY2(WLIG) <> 0
            [M:SCMW]XTYPQTY2 = mess([M:SCO2]TYPQTY2(WLIG), 2311, 1)
        Else
            Raz [M:SCMW]XTYPQTY2
        Endif
    Endif
Endif
If dim([M:SCMW]RETQTY2) > 0 : Diszo [M:SCMW]RETQTY2  : Endif
If dim([M:SCMW]RETQTY2) > 0 : Diszo [M:SCMW]XTYPQTY2 : Endif

# GA 19/09/2008
Gosub PTR_SCMFICH

Affzo [SCM0] : Affzo [SCMW]
Call CHARG_SCMA_FROM_SCO2(WLIG) From SCOCPTLIB
Affzo [M:SCMA]

Return

#-------------------------------------------------
$PTR_SCMFICH   : # Paramétrage de la transaction d'EO
If clalev ([F:PTR])=0 Local File PURTRS [PTR] : Endif
If GFLAG<>"" & [F:PTR]PTRNUM<>GFLAG
   Read [PTR] PTR0=9;GFLAG : If fstat Raz [F:PTR] : Endif
Endif
If [F:PTR]STOFCYCOD>2 | [F:PTR]STOFCYSCR=3  : # STOFCY Hidden in form mode
   Grizo [M:SCM0]STOFCY
Elsif[F:PTR]STOFCYCOD=2
   Diszo [M:SCM0]STOFCY                     : # STOFCY Displayed
Else
   Actzo [M:SCM0]STOFCY                     : # STOFCY Enterable
Endif
If [F:PTR]LOCCOD>2 | [F:PTR]LOCSCR=3        : # LOC Hidden in form mode
   Grizo [M:SCMW]LOC
Elsif[F:PTR]LOCCOD=2
   Diszo [M:SCMW]LOC                        : # LOC Displayed
Else
   Actzo [M:SCMW]LOC                        : # LOT Enterable
Endif
If [F:PTR]LOTCOD>2 | [F:PTR]LOTSCR=3        : # LOT Hidden in form mode
   Grizo [M:SCMW]LOT
Elsif [F:PTR]LOTCOD=2    # Issue 107513: ERROR before [F:PTR]STOFCYCOD=2
   Diszo [M:SCMW]LOT                        : # LOT Displayed
Else
   Actzo [M:SCMW]LOT                        : # LOT Enterable
Endif
# Issue 107513/US2 GA 04/2015 : ECC for [M:SCO2] table SCOMAT
If dim([M:SCM0]ECCVALMAJ)>0
   If [F:PTR]ECCCOD>2  | [F:PTR]ECCSCR=3
      Grizo [M:SCM0]ECCVALMAJ               : # ECCVALMAJ Hidden in form mode
   Elsif [F:PTR]ECCCOD=2
      Diszo [M:SCM0]ECCVALMAJ               : # ECCVALMAJ Displayed
   Else
      Actzo [M:SCM0]ECCVALMAJ               : # ECCVALMAJ Enterable
   Endif
#
   If [F:PTR]ECCCODMIN>2  | [F:PTR]ECCSCRMIN=3
      Grizo [M:SCM0]ECCVALMIN               : # ECCVALMIN Hidden in form mode
   Elsif [F:PTR]ECCCODMIN=2
      Diszo [M:SCM0]ECCVALMIN               : # ECCVALMIN Displayed
   Else
      Actzo [M:SCM0]ECCVALMIN               : # ECCVALMIN Enterable
   Endif
Endif
# Issue 107513/US2 - end
Return
#-------------------------------------------------
$SETBOUT_SCMFICH
ETABOU(GVALI)=1
ETABOU(GPREM)=0
ETABOU(GDERN)=0
ETABOU(GSUIV)=0
ETABOU(GPREC)=0
ETABOU(GSPE1)=0

Case WNEW
    When 0,2:        If [M:SCO2]ALLSTA(WLIG) > 1
                        ETABOU(GSPE1)=0
                     Else
#GA                        If find([M:MFG1]WORTYP,2,4)
#GA                            ETABOU(GSPE1)=1
#GA                        Else
                            ETABOU(GSPE1)=0
#GA                        Endif
                     Endif
Endcase
If GCONSLCT = 1
    ETABOU(GSPE1) = 0
    Diszo [M:SCMW]
Endif
Return

#-------------------------------------------------
$BOUT_SCMFICH
Case BOUT
    When "1":    # remplacer
                 Read [ITM]ITM0=[M:SCM0]CPNITMREF
                 If !fstat
                     # récupération article remplacant par défaut
                     If [F:ITM]RPLITM <> ""
                        [M:SCM0]CPNITMREF = [F:ITM]RPLITM
                        Read [ITM]ITM0=[M:SCM0]CPNITMREF
                        If !fstat : Call AM_CPNITMREF([M:SCM0]CPNITMREF) From SUBSCM : Endif
                     Endif
                 Endif
                 GMODMAT=2
                 Actzo [M:SCM0]CPNITMREF
                 MMODIF = 1
Endcase
Return

#-------------------------------------------------
$OK_SCMFICH

Case WNEW
    When 0,2,3,4,5:  : # Maj ligne existante
                    nolign = WLIG + 1
                    If GMODMAT = 2 & [M:SCM0]CPNITMREF<>[M:SCO2]CPNITMREF(WLIG)
                       [M:SCO2]=[M:SCM0]
                    Else
                       [M:SCO2]STOFCY(nolign-1)=[M:SCM0]STOFCY
                    Endif
                    [M:SCO2]=[M:SCMW]
                    If GMODMAT = 2 : [M:SCO2]WIPNUM(WLIG) = "" : Endif
                    Boxclr [SCMW]
                    If MMODIF = 1 : mkstat = 4 : Endif : # pour passer en mode Modif
    When 1        :   : # Ajout Nouvelle ligne
                    nolign = WLIG + 1
                    [M:SCO2]=[M:SCM0]
                    [M:SCO2]=[M:SCMW]
                    [M:SCO2]MATSTA(WLIG)    = 1
                    [M:SCO2]NBLIG     += 1
                    Boxclr [SCMW]
Endcase

Call CHARG_SCO2_FROM_SCMA(WLIG) From SCOCPTLIB
Affzo [M:SCO2]
MMODIF = 1
mkstat = 4

Return

#-------------------------------------------------
$FIN_SCMFICH
# GA 26/07/2005 sinon on garde les précédentes données saisies
Raz [SCMW]
Raz [SCMA]
Raz [SCM0]
Return


################################################################################
# SCITRKSTA : Etat du suivi d'une ligne article sous-traité                    #
################################################################################
$OUV_SCITRKSTA
Local Integer WLIG     : WLIG   = val(PARAM(1))
Local Char    WABREV(GLONABR)   : WABREV = PARAM(2)
Return

#-------------------------------------------------
$DEB_SCITRKSTA
Raz [M:SCIQ]
Case WABREV :
    When "SCO1": [M:SCIQ] = [M:SCO1]
          [M:SCIQ]RMNEXTQTY = [M:SCO1]EXTQTY - [M:SCO1]CPLQTY
Endcase
Affzo [SCIQ]
Return

#-------------------------------------------------
$SETBOUT_SCITRKSTA
Return

################################################################################
# SCSTRKSTA : Etat du suivi d'une ligne service                                #
################################################################################
$OUV_SCSTRKSTA
Local Integer WLIG     : WLIG   = val(PARAM(1))
Local Char    WABREV(GLONABR)  : WABREV = PARAM(2)
Return

#-------------------------------------------------
$DEB_SCSTRKSTA
Raz [M:SCSQ]
Case WABREV   :
    When "SCO3" :
         [M:SCSQ] = [M:SCO0] : # pour SCONUM
         [M:SCSQ] = [M:SCO3]
         #[M:SCSQ]OKQTY   = [M:SCO3]CPLQTY - [M:SCO3]REJCPLQTY - [M:SCO3]QUACPLQTY
Endcase
Affzo [SCSQ]
Return

#-------------------------------------------------
$SETBOUT_SCSTRKSTA
Return

################################################################################
# SCMTRKSTA : Etat du suivi d'une ligne service                                #
################################################################################
$OUV_SCMTRKSTA
Local Integer WLIG     : WLIG   = val(PARAM(1))
Local Char    WABREV(GLONABR)   : WABREV = PARAM(2)
Return

#-------------------------------------------------
$DEB_SCMTRKSTA
nolign = WLIG + 1
Raz [M:SCMQ]
Case WABREV   :
    When "SCO2" :
        [M:SCMQ] = [M:SCO0] : # pour SCONUM
        [M:SCMQ] = [M:SCO2]
Endcase
Affzo [SCMQ]
Return

#-------------------------------------------------
$SETBOUT_SCMTRKSTA
Return



################################################################################
# SCITRKPRI : Prix d'une ligne article sous-traité                             #
################################################################################
$OUV_SCITRKPRI
Local Integer WLIG     : WLIG   = val(PARAM(1))
Local Char    WABREV(GLONABR)   : WABREV = PARAM(2)
Return

#-------------------------------------------------
$DEB_SCITRKPRI
nolign = WLIG + 1
Raz [M:SCP]
Case WABREV   :
    When "SCO1" :
        Call UPD_ITM_PRI(0) From SCOLIB
        [M:SCP] = [M:SCO0]
        [M:SCP] = [M:SCO1]
        [M:SCP]QTYPUU = [M:SCO1]EXTQTY
        [M:SCP]PUU    = [M:SCO1]PUU
        [M:SCP]OFS    = [M:SCO1]LTI
        [M:SCP]CUR = GCUR
Endcase
Affzo [M:SCP]
Return

#-------------------------------------------------
$SETBOUT_SCITRKPRI
Return


################################################################################
# SCSTRKPRI : Prix d'une ligne service de sous-traitance                       #
################################################################################
$OUV_SCSTRKPRI
Local Integer WLIG     : WLIG   = val(PARAM(1))
Local Char    WABREV(GLONABR)   : WABREV = PARAM(2)
Return

#-------------------------------------------------
$DEB_SCSTRKPRI
nolign = WLIG + 1
Raz [M:SCP]
Case WABREV   :
    When "SCO3" :
        If [M:SCO3]NETPRI=0
           Call UPD_SRV_PRI(0) From SCOLIB
        Endif
        [M:SCP] = [M:SCO3]
        [M:SCP]QTYPUU = [M:SCO3]EXTSTRQTY
        [M:SCP]PUU    = [M:SCO3]SCOPUU
        [M:SCP]OFS    = [M:SCO3]SCOLTI
        [M:SCP]CUR = GCUR
Endcase
Affzo [M:SCP]
Return

#-------------------------------------------------
$SETBOUT_SCSTRKPRI
Return


################################################################################
# SCMTRKPRI : Prix d'une ligne service de sous-traitance                       #
################################################################################
$OUV_SCMTRKPRI
Local Integer WLIG     : WLIG   = val(PARAM(1))
Local Char    WABREV(GLONABR)   : WABREV = PARAM(2)
Return

#-------------------------------------------------
$DEB_SCMTRKPRI
nolign = WLIG + 1
Raz [M:SCP]
Case WABREV   :
    When "SCO2" :
        If [M:SCO2]NETPRI(nolign-1)=0
           Call UPD_MAT_PRI(nolign-1) From SCOLIB
        Endif
        [M:SCP] = [M:SCO2]
        [M:SCP]QTYPUU = [M:SCO2]RETQTY(nolign-1)
        [M:SCP]PUU    = [M:SCO2]STU
        [M:SCP]OFS    = [M:SCO2]BOMOFS(nolign-1)
        [M:SCP]CUR = GCUR
Endcase
Affzo [M:SCP]
Return

#-------------------------------------------------
$SETBOUT_SCMTRKPRI
Return
# Issue 93349 GA 10/2013: nouvelle action SCKFICH
################################################################################
# SCKFICH : Suivi composant non prévu en rcp Ordre sous-traitance              #
################################################################################
$OUV_SCKFICH
Local    Integer    WLIG   : WLIG = val(PARAM(1))
Local    Integer    WNEW
Local    Integer    WOK, I
Local    Integer    SLIG, J
# Déclaration de GMODMAT, utilisée dans les actions d'avant saisie SUBSCM
If dim(GMODMAT)<=0 : Global Integer  GMODMAT : Endif
GMODMAT = 1
# Issue 93349 GA 10/2013 Cohabitation avec l'action SCMFICH
# dans SUBSCM on utilise à présent les buffers [F:SCO], [F:SCI], [F:SCS] au lieu des masques écrans
Gosub OPEN_FILES_SCO From SCOLIB

Return
#-------------------------------------------------
$DEB_SCKFICH
MMODIF = 0
GMODMAT = 0
WNEW = 0
If    [M:PSCM]ITMREF(WLIG) = "" : WNEW = 1   # si ajout matière non prévue
Elsif [M:PSCM]BOMSEQ(WLIG) = 0  : WNEW = 2   # si modif matière non prévue
Elsif [M:PSCM]MATSTA(WLIG) > 2  : WNEW = 3   # si matière exclue ou soldée
Elsif [M:PSCM]MATSTA(WLIG) = 2  : WNEW = 4   # si matière en cours
Endif

Case WNEW
    When 0: # accès en fiche d'une matière existante
            GMODMAT     = 1
            nolign = WLIG + 1
            [M:SCM0] = [M:PSCM]
            [M:SCMW] = [M:PSCM]
            Diszo [M:SCMW]STU
            Diszo [M:SCMW]LIKQTY
            Diszo [M:SCMW]LIKQTYCOD
            Diszo [M:SCMW]QTYRND
    When 1: # ajout nouvelle matière
            GMODMAT     = 2
            Raz [M:SCM0],[M:SCMW]
            nolign = WLIG + 1
            [M:SCM0] = [M:PSCM]
            [M:SCMW] = [M:PSCM]
            Actzo [M:SCM0]CPNITMREF : # pour accèder aux boutons
            Actzo [M:SCMW]RETQTY
            Gosub DUP_PRVLIG
    When 2: # accès en fiche d'une matière non prévue existante
            GMODMAT     = 1
            nolign = WLIG + 1
            [M:SCM0] = [M:PSCM]
            [M:SCMW] = [M:PSCM]
            Diszo [M:SCM0]CPNITMREF
            Diszo [M:SCMW]STU
    When 3: # accès en fiche d'une matière exclue (visu uniquement)
            GMODMAT     = 1
            nolign = WLIG + 1
            [M:SCM0] = [M:PSCM]
            [M:SCMW] = [M:PSCM]
            Diszo [M:SCM0] : Diszo [M:SCMW]
    When 4: # accès en fiche d'une matière en cours
            GMODMAT  = 1
            nolign = WLIG + 1
            [M:SCM0] = [M:PSCM]
            [M:SCMW] = [M:PSCM]
            Diszo [M:SCM0] : Diszo [M:SCMW]
            Actzo [M:SCM0]CPNITMREF : # pour accèder aux boutons
            Actzo [M:SCMW]RETQTY
Endcase
If [M:SCMW]RETQTY=0
  Local Decimal WQTY : WQTY = [F:SCI]EXTQTY
  Call CALCUL_QTY([F:SCI]BASQTY   , [M:SCMW]STU   , [M:SCMW]LIKQTYCOD,
&                     [M:SCMW]LIKQTY   , [M:SCMW]QTYRND, [M:SCMW]SCA,
&                     [M:SCMW]RELSCATIA, [M:SCMW]RETQTY, WQTY) From SCOLIBM
  Affzo [M:SCMW]RETQTY
Endif

Gosub PTR_SCKFICH

Affzo [SCM0] : Affzo [SCMW]
# Issue 93349 GA 10/2013 quid des CCE ?
#Call CHARG_SCKA_FROM_SCO2(WLIG) From SCOCPTLIB
Affzo [M:SCMA]

Return
#-------------------------------------------------
$DUP_PRVLIG   : # Copie infos ligne précédente
# lire SCO,SCI,...
[M:SCM0] = [F:SCO]
[M:SCM0] = [F:SCI]
[M:SCMW] = [F:SCI]

[M:SCMW]CPNTYP = 1
[M:SCMW]USEQTY = 0
[M:SCMW]BOMQTY = 1
[M:SCMW]LIKQTY = 1
[M:SCMW]LIKQTYCOD = 1

If WLIG>0
  [M:SCM0]STOFCY = [M:PSCM]STOFCY(WLIG-1)
  [M:SCMW]STOFCY = [M:PSCM]STOFCY(WLIG-1)
  [M:SCMW]DLVDAT = [M:PSCM]DLVDAT(WLIG-1)
  [M:SCMW]LOC    = [M:PSCM]LOC   (WLIG-1)
Else
  [M:SCM0]STOFCY = [F:SCI]PRHFCY
  [M:SCMW]STOFCY = [F:SCI]PRHFCY
  [M:SCMW]LOC    = [F:SCI]LOC
  [M:SCMW]DLVDAT = [F:SCO]RETDAT-[F:ITF]OFS
Endif
[M:SCMW]SCOFLG = 2 : Grizo [M:SCMW]SCOFLG
[M:SCMW]LIKQTYCOD = 2 : Grizo [M:SCMW]LIKQTYCOD
[M:SCMW]BOMOFS = [F:ITF]OFS
Diszo [M:SCM0]STOFCY
Return

#-------------------------------------------------
$PTR_SCKFICH   : # Paramétrage de la transaction d'EO
If clalev ([F:PTR])=0 Local File PURTRS [PTR] : Endif
If GFLAG<>"" & [F:PTR]PTRNUM<>GFLAG
   Read [PTR] PTR0=9;GFLAG : If fstat Raz [F:PTR] : Endif
Endif
If [F:PTR]STOFCYCOD>2 | [F:PTR]STOFCYSCR=3  : # STOFCY Hidden in form mode
   Grizo [M:SCM0]STOFCY
Elsif[F:PTR]STOFCYCOD=2
   Diszo [M:SCM0]STOFCY                     : # STOFCY Displayed
Else
   Actzo [M:SCM0]STOFCY                     : # STOFCY Enterable
Endif
If [F:PTR]LOCCOD>2 | [F:PTR]LOCSCR=3        : # LOC Hidden in form mode
   Grizo [M:SCMW]LOC
Elsif[F:PTR]LOCCOD=2
   Diszo [M:SCMW]LOC                        : # LOC Displayed
Else
   Actzo [M:SCMW]LOC                        : # LOT Enterable
Endif
If [F:PTR]LOTCOD>2 | [F:PTR]LOTSCR=3        : # LOT Hidden in form mode
   Grizo [M:SCMW]LOT
Elsif[F:PTR]STOFCYCOD=2
   Diszo [M:SCMW]LOT                        : # LOT Displayed
Else
   Actzo [M:SCMW]LOT                        : # LOT Enterable
Endif
Return

################################################################################
$SETBOUT_SCKFICH
ETABOU(GVALI)=1
ETABOU(GPREM)=0
ETABOU(GDERN)=0
ETABOU(GSUIV)=0
ETABOU(GPREC)=0
ETABOU(GSPE1)=0
Return

################################################################################
$OK_SCKFICH

Case WNEW
    When 0,2,3,4,5:  : # Maj ligne existante
                    nolign = WLIG + 1
                    [M:PSCM]STOFCY(nolign-1)=[M:SCM0]STOFCY
                    [M:PSCM]=[M:SCMW]
                    Boxclr [SCMW]
                    If MMODIF = 1 : mkstat = 4 : Endif : # pour passer en mode Modif
    When 1        :   : # Ajout Nouvelle ligne
                    nolign = WLIG + 1
                    [M:PSCM]=[M:SCM0]
                    [M:PSCM]=[M:SCMW]
                    [M:PSCM]NBMAT += 1
                    [M:PSCM]ITMREF(WLIG)  =[M:SCM0]CPNITMREF
                    [M:PSCM]SCMLIN(WLIG)  =(1000*WLIG)+999
                    [M:PSCM]BOMSEQ(WLIG)  = 0
                    [M:PSCM]MATSTA(WLIG)  = 1
                    [M:PSCM]USEQTY(WLIG)  = [M:PSCM]RETQTY(WLIG)
                    [M:PSCM]WSTODET(WLIG) = 2
                    [M:PSCM]WSTOSEQ(WLIG) = 0
                    [M:PSCM]STOFCY(WLIG)  = [M:SCM0]STOFCY
                    [M:PSCM]CREFLG(WLIG)  = 0
                    Call AM_ITMREF([M:PSCM]ITMREF(WLIG)) From TRTPSAISCM
                    Call AM_USEQTY([M:PSCM]USEQTY(WLIG)) From TRTPSAISCM
                    Boxclr [SCMW]
Endcase

# Issue 93349 GA 10/2013 quid des CCE ?
#Call CHARG_SCO2_FROM_SCMA(WLIG) From SCOCPTLIB
Affzo [M:PSCM]
MMODIF = 1
mkstat = 4

Return

################################################################################
$FIN_SCKFICH
Local    Integer    WLIG   : WLIG = val(PARAM(1))
# GA 26/07/2005 sinon on garde les précédentes données saisies
Raz [SCMW]
Raz [SCMA]
Raz [SCM0]
Return

