#<AdxTL>@(#)2.0.0.0 $Revision$

#######################################################################
# Pesée multi-article abandonnée par manque de place ds récipient ou balance
# de portée insuffisante : faire passer la valeur du flag _enPeseeMulti
# de oui à non.
#######################################################################
Subprog  MAJ_WGG()
Local Char WGGFILE (200)


Local Char     F_MFGNUM       (GLONVCR)
Local Shortint F_BOMOPE
Local Char     F_ITMREF       (GLONITM)    # mm 05.08
Local Integer  F_MFGLIN
Local Integer  F_BOMSEQ
Local Char     F_EXTSLE       (08)
Local Char     F_USESLE       (08)
Local Shortint F_CBTCOD
Local Shortint F_CONNEC
Local Char     F_EXTCTN       (08)
Local Char     F_USECTN       (08)
Local Decimal  F_CTNTAR
Local Shortint F_MLTITM
Local Char     F_TKS          (08)
Local Char     F_TGTGTS       (08)
Local Shortint F_PKC
Local Char     F_LOT          (GLONLOT)
Local Char     F_SLO          (GLONSLO)     # 98779 mm 08.2014
Local Char     F_LOC          (10)
Local Char     F_STA          (03)
Local Decimal  F_DEFPOT
Local Decimal  F_POT
Local Char     F_STU          (3)
Local Char     F_WEU          (3)
Local Decimal  F_WEIWEI
Local Decimal  F_WEI
Local Char     F_ISM
Local Shortint F_WGGOPT
Local Decimal  F_STOCOU
Local Integer  F_SEQ
Local Char     F_PROCEDURE    (8)
Local Char     F_CONTENU_ISM  (7)
Local Char     F_FORMAT_CTN   (7)
Local Char     WFIL           (06)


# transfert fichiers pesee du client vers le serveur
Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Call CSV2ILFIL(GFCY,"ilwgg","X3ScalesWgg") From OPTLIB

WGGFILE = func OPTLIB.FILNAM(GFCY,"ilwgg",0)

adxifs = ";"
adxirs = chr$(10)

# Ouverture du fichier X3ScalesWgg en lecture
Openi WGGFILE Using [WGGF]

# Lecture fichier X3ScalesWgg
Repeat

Rdseq F_MFGNUM,F_BOMOPE,F_ITMREF,F_MFGLIN,F_BOMSEQ,F_EXTSLE,F_USESLE,F_CBTCOD,F_CONNEC,
&     F_EXTCTN,F_USECTN,F_CTNTAR,F_MLTITM,F_TKS,F_TGTGTS,F_PKC,F_LOT,F_SLO,F_LOC,F_STA,
&     F_DEFPOT,F_POT,F_STU,F_WEU,F_WEIWEI,F_WEI,F_ISM,F_WGGOPT,F_STOCOU,F_SEQ,
&     F_CONTENU_ISM,F_FORMAT_CTN,F_PROCEDURE,WFIL
&     Using [WGGF]


If fstat = 1 Goto FIN_WGG2 : Endif
If fstat = 5 Goto FIN_WGG2 : Endif

Filter [WGG] Where   MFGNUM    = F_MFGNUM &
&                    BOMOPE    = F_BOMOPE &
&                    ITMREF    = F_ITMREF &
&                    MFGLIN    = F_MFGLIN &
&                    BOMSEQ    = F_BOMSEQ &
&                    CBTDAT    = date$
&              Order By Key WGG0
  Read [WGG] First
Filter [WGG]    # mm 02.2013

  # mm 10.11 - Flag Pesée multi-articles = non
  [F:WGG]MLTITMFLG = 1

Rewrite [WGG]
If fstat
       WMSGSUI = mess(157,199,1)+" : "+ "WGG"
       TRA = 1
       Call ECR_TRACE(WMSGSUI,1) From GESECRAN
       GOK = 0 : Call FSTA("WGG") From GLOCK : Gosub AB_TRT : End
Endif
#Filter [WGG]    # mm 02.2013

Until fstat <> 0

$FIN_WGG2
# fermeture de l'enregistrement
Openi

End


$AB_TRT
Rollback
End

# ############################################################################################# #
# PESEE COMPLETE ARTICLE
# Exclusivement utilisé en pesée par article                                                    #
# était-ce le dernier composant à peser de la phase ? -> FIN PHASE code 030                     #
# était-ce le dernier composant à peser de la dernière phase de l'OF ?  -> FIN OF code 031      #
# ou bien, c'est seulement la pesée complete d'un composant ?   -> FIN COMPOSANT code 029       #
# ############################################################################################# #
Subprog PESEE_COMPLETE_ART(LNUMOF, LCOMPOSANT,LBOMOPE)
Value  Char     LNUMOF
Value  Char     LCOMPOSANT
Value  Integer  LBOMOPE

Local  Char     LCODE
Local  Integer  W_WGGSTA
Local Integer   I : I=0     # 120244 mm 01.2017

# Composant soldé
LCODE = "29"
W_WGGSTA = 3

# 120244 mm 01.2017
# Several time the same componant in same phasis?
For [MFM]MFM3 Where MFGNUM = LNUMOF  &  BOMOPE = LBOMOPE & ITMREF = LCOMPOSANT
  If [F:MFM]WGGSTA  <  W_WGGSTA : I+=1 : Endif
Next

# Phase soldée ?
If I=1    # 120244 mm 01.2017
  For [MFM]MFM3 Where MFGNUM = LNUMOF  &  BOMOPE = LBOMOPE & ITMREF <> LCOMPOSANT & PKC>1
    If [F:MFM]WGGSTA <  W_WGGSTA :  W_WGGSTA = [F:MFM]WGGSTA : Break : Endif
  Next
Endif

If (I=1 & W_WGGSTA = 3)   # 120244 mm 01.2017
  LCODE = "30"
  # OF soldé ?
  For [MFM]MFM3 Where MFGNUM = LNUMOF &  BOMOPE <> LBOMOPE & PKC>1
    If [F:MFM]WGGSTA <  W_WGGSTA :   W_WGGSTA = [F:MFM]WGGSTA : Break : Endif
  Next
  If W_WGGSTA = 3 : LCODE = "31" : Endif
Endif

Call MAJ_WEIGHING_SUIVI (LCODE,2) From SCALEXCHAN

End

