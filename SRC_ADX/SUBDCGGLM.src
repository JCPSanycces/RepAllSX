#<AdxTL>@(#)0.0.0.0 $Revision$ 
#<AdxTL>@(#)0.0.0.0 $Revision$

Subprog SPLIT_THIS_DUMMY(TIMCOD)
Value Char TIMCOD
Local Integer RESULT : RESULT = 1

  Trbegin [F:DCG]

    Delete [F:DCG] Where [F:DCG]UID=99999999
    If fstat
      [V]GOK=0
      Call FSTA("DCG") From GLOCK
      Rollback
      End
    Endif
    Raz [F:DCG]
    [F:DCG]      =[M:DCG1]
    [F:DCG]UID   =99999999
    [F:DCG]TIM   =TIMCOD
    Write [F:DCG]
    If fstat
      [V]GOK=0
      Call FSTA("DCG") From GLOCK
      Rollback
      End
    Endif

    GPARENT_NOLIGN=nolign - 1
    Gosub SPLIT_THIS_TRANSACTION

    [M]UID(GPARENT_NOLIGN)=99999999
    Gosub REFRESHLVESUBNNR From SUBDCG2

    Read [F:DCG]DCG2=[M]UID(GPARENT_NOLIGN)
    If !fstat
      Delete [F:DCG]
      If fstat
        [V]GOK=0
        Call FSTA("DCG") From GLOCK
        Rollback
        End
      Endif
    Endif
    [M]UID(GPARENT_NOLIGN)=0
  Commit
End

Subprog SPLIT_THIS_TRANSACTION_PROG(VGOK,VGCURLEG,IS_SOA,V_MPYRDAT,VUIDS_TO_INCLUDE,VUIDS_COUNT)
Variable Integer VUIDS_TO_INCLUDE,VUIDS_COUNT
Value Date V_MPYRDAT
Value Char VGCURLEG
Variable Integer VGOK
Value Integer IS_SOA
  Gosub SPLIT_THIS_TRANSACTION
End

$SPLIT_THIS_TRANSACTION
  Gosub ASSIGN_SPLITFILTER_SPLIT_THIS_TRANSACTION
  If [F:DCG]UID<>99999999
    Local Char ERRMESSAGE(250)
    Call RESET_FUTURE_SPLITS_PROG(VGOK,VGCURLEG,IS_SOA,VUIDS_TO_INCLUDE,VUIDS_COUNT)
    If VGOK = 1
      [V]GOK=0
      Return
    Endif
  Endif

  If GFONCTION='GESDCG'
    THIS_REFNUM=[M:DCG1]REFNUM
  Endif
  Call SPLIT_TRANSACTIONS_PROG(VGOK,VGCURLEG,IS_SOA,THIS_REFNUM,SPLITFILTER1,SPLITFILTER2,ERRMESSAGE,V_MPYRDAT)
  If VGOK =1
    [V]GOK=0
 Endif
 If [V]GOK=0 : Return : Endif
Return

$ASSIGN_SPLITFILTER_SPLIT_THIS_TRANSACTION
  Local Char SPLITFILTER1(250)
  Local Char SPLITFILTER2(250)
  [L]SPLITFILTER1="[DCGT]UID="+num$([F:DCG]UID)
  [L]SPLITFILTER2="1=1"
Return

Subprog RESET_FUTURE_SPLITS_PROG(RF_GOK,RF_GCURLEG,RF_IS_SOA,VUIDS_TO_INCLUDE,VUIDS_COUNT)
Variable Integer VUIDS_TO_INCLUDE,VUIDS_COUNT
Value Char RF_GCURLEG
Variable Integer RF_GOK
Value Integer RF_IS_SOA
  Raz RF_GOK
  Local Integer ORGUID
  Local Integer PREV_UID
  Local Char    PREV_USR(GLONAUS)
  Local Char    PREV_UPD(GLONAUS)
  Local Date    DCG_ORGSTRDAT
  DCG_ORGSTRDAT = [F:DCG]STRDAT

  Gosub RESET_FUTURE_SPLITS
End

$RESET_FUTURE_SPLITS
  Local Integer THIS_UID
  If clalev([F:TIMT])=0 : Local File TIMCOD   [TIMT] : Endif
  If clalev([F:DCGT])=0 : Local File DEMCONGE [DCGT] : Endif

#check nature of event for enhanced flag
  If clalev([F:TIP])=0 : Local File TIMEMP [TIP] : Endif
  Read [TIMT]TIM0=RF_GCURLEG;[F:DCG]TIM
  If [TIMT]LVEENHANCE<>2 : Return : Endif

  Local Char SUBTYPESDCG(GLONHRLST)(0..,0..9)
  Local Date RESET_DCG
  Call GET_LEAVE_SUB_TYPES([F:DCG]CTRNUM, [F:DCG]STRDAT,[F:DCG]TIM, SUBTYPESDCG) From SUBHRBAL
  Call CONVERT_TO_DATE(SUBTYPESDCG(0,5), RESET_DCG) From SUBHRBAL
  If RF_IS_SOA = 5 #Only use this status to create a new record for a cancellation request
    Filter [DCGT] Where [DCGT]REFNUM=[F:DCG]REFNUM & [DCGT]CTRNUM=[F:DCG]CTRNUM
&   & [F:DCGT]TIM=[F:DCG]TIM  & [DCGT]UID>0
&   & ([DCGT]STA=1|[DCGT]STA=2|[DCGT]STA=3 |[DCGT]STA=5 |[DCGT]STA=7)
&   & [DCGT]STRDAT=[F:DCG]STRDAT
  Else
    Filter [DCGT] Where [DCGT]REFNUM=[F:DCG]REFNUM & [DCGT]CTRNUM=[F:DCG]CTRNUM
&   & [F:DCGT]TIM=[F:DCG]TIM  & [DCGT]UID>0
&   & ([DCGT]STA=1|[DCGT]STA=2|[DCGT]STA=3 |[DCGT]STA=5 |[DCGT]STA=7)
&   & [DCGT]STRDAT=[F:DCG]STRDAT
    For [DCGT]
      Local Integer CNTDEL
      For CNTDEL=0 To 14
        [F:DCGT]LVESUBTYP(CNTDEL)=''
        [F:DCGT]LVESUBBAL(CNTDEL)=0
        [F:DCGT]LVESUBRAT(CNTDEL)=0
      Next
      Rewrite [DCGT]
      Call DELETE_FROM_DEMSPLITS([F:DCGT]UID) #PEVAN - X3-111790 - 2018-10-08
    Next
    Filter [DCGT]

    If RESET_DCG<>[0/0/0]
      Filter [DCGT] Where [DCGT]REFNUM=[F:DCG]REFNUM & [DCGT]CTRNUM=[F:DCG]CTRNUM
&     & [F:DCGT]TIM=[F:DCG]TIM  & [DCGT]UID>0
&     & ([DCGT]STA=1|[DCGT]STA=2|[DCGT]STA=3 |[DCGT]STA=5 |[DCGT]STA=7)
&     & [DCGT]STRDAT>[F:DCG]STRDAT and [DCGT]ENDDAT<=RESET_DCG
    Else
      Filter [DCGT] Where [DCGT]REFNUM=[F:DCG]REFNUM & [DCGT]CTRNUM=[F:DCG]CTRNUM
&     & [F:DCGT]TIM=[F:DCG]TIM  & [DCGT]UID>0
&     & ([DCGT]STA=1|[DCGT]STA=2|[DCGT]STA=3 |[DCGT]STA=5 |[DCGT]STA=7)
&     & [DCGT]STRDAT>[F:DCG]STRDAT
    Endif
  Endif
  For [DCGT]
    Filter [F:DCG]
    Read [F:DCG]DCG2=[DCGT]UID
    If !fstat
      ORGUID = [F:DCG]UID
      THIS_UID=uniqid([TIP]) #FRLAA 2018-03-28 X3-74480
      [F:DCG]LNK=THIS_UID
      [F:DCG]WRK ="M"
      If [F:DCG]UID>0
        [F:DCG]UID*=-1 : # On va supprimer cette ligne dans TIMEMP
      Endif
      Case [F:DCG]STA
        When 2 : [F:DCG]CHRONO =num$(-adxuid(2)) : # Demande
        When 5 : [F:DCG]CHRONO2=num$(-adxuid(2)) : # Demande d'annulation
      Endcase
      Rewrite [F:DCG]
      If fstat
        RF_GOK = 1
        Return
      Endif
      [F:DCG]UPDDAT =date$
      [F:DCG]UPDUSR =[V]GUSER
      [F:DCG]UID=THIS_UID
      If [DCGT]STRDAT=DCG_ORGSTRDAT
        If RF_IS_SOA = 5 #Cancellation request not updated yet
          [F:DCG]STA = 5
          [F:DCG]WRK ="M"
        Endif
        If [DCG]STA = 2 or [DCG]STA = 5
          [F:DCG]WRK ="M"
        Else
          [F:DCG]WRK ="R"
        Endif
      Else
        [F:DCG]WRK ="R"
      Endif
      [F:DCG]LNK=THIS_UID

      [F:DCG]LVESUBTYP(0)=''
      [F:DCG]LVESUBTYP(1)=''
      [F:DCG]LVESUBTYP(2)=''
      [F:DCG]LVESUBTYP(3)=''
      [F:DCG]LVESUBTYP(4)=''
      [F:DCG]LVESUBTYP(5)=''
      [F:DCG]LVESUBTYP(6)=''
      [F:DCG]LVESUBTYP(7)=''
      [F:DCG]LVESUBTYP(8)=''
      [F:DCG]LVESUBTYP(9)=''
      [F:DCG]LVESUBTYP(10)=''
      [F:DCG]LVESUBTYP(11)=''
      [F:DCG]LVESUBTYP(12)=''
      [F:DCG]LVESUBTYP(13)=''
      [F:DCG]LVESUBTYP(14)=''

      [F:DCG]LVESUBBAL(0)=0
      [F:DCG]LVESUBBAL(1)=0
      [F:DCG]LVESUBBAL(2)=0
      [F:DCG]LVESUBBAL(3)=0
      [F:DCG]LVESUBBAL(4)=0
      [F:DCG]LVESUBBAL(5)=0
      [F:DCG]LVESUBBAL(6)=0
      [F:DCG]LVESUBBAL(7)=0
      [F:DCG]LVESUBBAL(8)=0
      [F:DCG]LVESUBBAL(9)=0
      [F:DCG]LVESUBBAL(10)=0
      [F:DCG]LVESUBBAL(11)=0
      [F:DCG]LVESUBBAL(12)=0
      [F:DCG]LVESUBBAL(13)=0
      [F:DCG]LVESUBBAL(14)=0

      [F:DCG]LVESUBRAT(0)=0
      [F:DCG]LVESUBRAT(1)=0
      [F:DCG]LVESUBRAT(2)=0
      [F:DCG]LVESUBRAT(3)=0
      [F:DCG]LVESUBRAT(4)=0
      [F:DCG]LVESUBRAT(5)=0
      [F:DCG]LVESUBRAT(6)=0
      [F:DCG]LVESUBRAT(7)=0
      [F:DCG]LVESUBRAT(8)=0
      [F:DCG]LVESUBRAT(9)=0
      [F:DCG]LVESUBRAT(10)=0
      [F:DCG]LVESUBRAT(11)=0
      [F:DCG]LVESUBRAT(12)=0
      [F:DCG]LVESUBRAT(13)=0
      [F:DCG]LVESUBRAT(14)=0

      Write [F:DCG]
      Call DELETE_FROM_DEMSPLITS([F:DCGT]UID) #PEVAN - X3-111790 - 2018-10-08
      If fstat
        RF_GOK = 1
        Return
      Else
        If func SUBDCGGLM.UPDATE_WORKFLOW_UID(ORGUID, THIS_UID)=1
          RF_GOK = 1
          Return
        Endif
      Endif
      VUIDS_TO_INCLUDE(VUIDS_COUNT)=THIS_UID
      VUIDS_COUNT+=1
    Endif
  Next

Return

Subprog RESPLIT_TRANSACTIONS_PROG(PGOK,PGCURLEG,IS_SOA,THIS_REFNUM,ERRMESSAGE,V_MPYRDAT)
Variable Integer PGOK
Variable Char ERRMESSAGE
Value Char PGCURLEG,THIS_REFNUM
Value Integer IS_SOA
Value Date V_MPYRDAT
  Gosub RESPLIT_TRANSACTIONS
End

$RESPLIT_TRANSACTIONS
  Gosub RESPLIT_TRANSACTIONS_FILTER
  Call SPLIT_TRANSACTIONS_PROG(PGOK,PGCURLEG,IS_SOA,THIS_REFNUM,SPLITFILTER1,SPLITFILTER2,ERRMESSAGE,V_MPYRDAT)
Return

$RESPLIT_TRANSACTIONS_FILTER
  Local Char SPLITFILTER1(250)
  Local Char SPLITFILTER2(250)
  [L]SPLITFILTER1="([DCGT]LVESUBTYP(0)='' & [DCGT]LVESUBTYP(1)='' & [DCGT]LVESUBTYP(2)=''"
& + " & [DCGT]LVESUBTYP(3)='' & [DCGT]LVESUBTYP(4)='' & [DCGT]LVESUBTYP(5)=''"
& + " & [DCGT]LVESUBTYP(6)='' & [DCGT]LVESUBTYP(7)='' & [DCGT]LVESUBTYP(8)='')"
  [L]SPLITFILTER2="([DCGT]LVESUBTYP(9)='' & [DCGT]LVESUBTYP(10)='' & [DCGT]LVESUBTYP(11)=''"
& + " & [DCGT]LVESUBTYP(12)='' & [DCGT]LVESUBTYP(13)='' & [DCGT]LVESUBTYP(14)='')"
Return

Subprog SPLIT_TRANSACTIONS_PROG(RF_GOK,RF_GCURLEG,RF_IS_SOA,VTHISREFNUM,V_SPLITFILTER1,V_SPLITFILTER2,V_ERRMESSAGE,P_V_MPYRDAT)
Value Date P_V_MPYRDAT
Variable Char V_ERRMESSAGE
Value Char V_SPLITFILTER1,V_SPLITFILTER2
Value Char VTHISREFNUM
Value Char RF_GCURLEG
Variable Integer RF_GOK
Value Integer RF_IS_SOA
  Gosub SPLIT_TRANSACTIONS
End

$SPLIT_TRANSACTIONS
  Local Char THISREFNUM(GLONEML),CRITHRCTR(250),CRITHRTIM(250),OVER_TAKEN_LIST(10)(0..99,0..99),VIFINALS(GLONHRLST)(0..,0..9)
  Local Date PREVCYCLE(0..99)#FRLAA 2018-03-22 X3-74480
  Local Date THISLEAVEDATE
  Local Decimal THISLEAVEDAYS, THISLEAVEHOURS,TOT_TAKN,TOTALACCRU,TOTZERO,ALLOW_AMT
  Local Integer SHOW_CREDIT_MESSAGE : SHOW_CREDIT_MESSAGE=1
  Local Integer SHOW_MAX_MESSAGE : SHOW_MAX_MESSAGE=1
  Local Integer SHOWED_A_MESSAGE: SHOWED_A_MESSAGE=0:
  Local Integer END_OFF_TRANSACTIONS: END_OFF_TRANSACTIONS=0:
  Local Integer CYCLE_RENEW,E
  Local Integer CHECK_DCG
  Local Decimal ACCRUAL_PDAY #FRLAA X3-105020 2018-09-06
  If clalev([F:TIMT])=0   : Local File TIMCOD   [TIMT]   : Endif
  If clalev([F:DCGT])=0   : Local File DEMCONGE [DCGT]   : Endif
  If clalev([F:HRCTRT])=0 : Local File EMPLOCTR [HRCTRT] : Endif
  If clalev([F:FCYT])=0   : Local File FACILITY [FCYT]   : Endif
  If clalev([F:DCG])=0    : Local File DEMCONGE [F:DCG]  : Endif

  Call GET_LEAVE_SUB_TYPES([F:DCG]CTRNUM, [F:DCG]STRDAT,[F:DCG]TIM, VIFINALS) From SUBHRBAL
  THISREFNUM=VTHISREFNUM
  Local Date GLMCYCLE
  Local Char SET_GLM(250)

  If RF_IS_SOA
    SET_GLM = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 5, RF_GCURLEG, "GLMCYCLE")
    Call CONVERT_TO_DATE(evalue(SET_GLM), GLMCYCLE) From SUBHRBAL
  Else
    GLMCYCLE = func SUBHRBAL.GET_GLM_CYCLE([F:DCG]CTRNUM,[F:DCG]CTRDAT)
  Endif
#loop all un-split transactions for employee
  Filter [HRCTRT]
  Filter [FCYT]
  Filter [TIMT]

  Link [DCGT]
& With [HRCTRT]CTR0(2)=[DCGT]REFNUM;[DCGT]CTRNUM
&      ,[FCYT]FCY0 = [HRCTRT]ETRFCY
&      ,[TIMT]TIM0 = [FCYT]LEG; [F:DCGT]TIM
& As [LNKS]
& Where [TIMT]LVEENHANCE=2 & [DCGT]UID>0
& & [HRCTRT]REFNUM=THISREFNUM
& & ([DCGT]STA=1|[DCGT]STA=2|[DCGT]STA=3 |[DCGT]STA=5 |[DCGT]STA=7)
& & evalue([L]V_SPLITFILTER1)
& & evalue([L]V_SPLITFILTER2)
& & ([F:HRCTRT]CTRDAT <= [F:DCGT]STRDAT & ([F:HRCTRT]XITDAT=[0/0/0] | [F:HRCTRT]XITDAT >= [F:DCGT]STRDAT))
& Order By Key THISSTRDAT=[DCGT]STRDAT Asc

  For [LNKS]THISSTRDAT
    Filter [F:DCG]
    Raz PREVCYCLE
    Read [F:DCG]DCG2 = [DCGT]UID

    If fstat
      V_ERRMESSAGE="Entry of absense not found"-num$([DCGT]UID)
      RF_GOK = 1
      Break
    Else
      If RF_GCURLEG<>"BRI"
        Call DELETE_FUTURE_ACCRUALS([F:DCG]CTRNUM, [F:DCG]CTRDAT, [F:DCG]STRDAT, [F:DCG]TIM,RF_IS_SOA,RF_GCURLEG) From SUBDCGGLM
      Endif

      [L]THISLEAVEDATE = [F:DCG]STRDAT
      While [L]THISLEAVEDATE<=[F:DCG]ENDDAT
        Call VALORIS_L([L]THISLEAVEDATE,[L]THISLEAVEDATE,[F:DCG]REFNUM,[F:DCG]TIM,[L]THISLEAVEDAYS,[L]THISLEAVEHOURS,[FCYT]FCY,[F:DCG]CTRNUM,RF_IS_SOA,RF_GCURLEG,P_V_MPYRDAT) From SUBACCRUAL
        If [L]THISLEAVEDAYS>0
          Gosub ALLOCATE_DAY
        Endif
        If RF_GOK <> 1
          If [L]THISLEAVEDATE=[F:DCG]ENDDAT
            END_OFF_TRANSACTIONS = 1
            If dim(LVE_REM)=0
              Local Decimal LVE_REM : LVE_REM = 1
            Endif
            Gosub CHECK_MINUS_BALANCES
            If RF_GOK =1
              Break
            Endif
          Endif
          [L]THISLEAVEDATE+=1
        Else
          Break
        Endif
      Wend

      If RF_GOK <> 1
        If RF_GCURLEG<>"BRI"
          Local Char FUTBALS(250)(0..,0..10)
          CRITHRLST="1=0 | ([F:HRCTR]CTRNUM = '"+[F:DCG]CTRNUM+"' & [F:HRCTR]CTRDAT = [" + num$([F:DCG]CTRDAT) + "])"
          Local Char CTRARRAY(GLONHRCTR)(1..)
          Local Date DTRARRAY (1..)
          Local Integer I
          If func SUBDCGGLM.CHECK_XITCTR([F:DCG]STRDAT,[F:DCG]ENDDAT,[F:DCG]REFNUM,[F:DCG]CTRNUM,CTRARRAY,DTRARRAY)>0
            For I = 1 To maxtab(CTRARRAY)
              If CTRARRAY(I)<>""
                Call LVE_ENG(CRITHRTIM,CRITHRLST,CRITHRCTR,[F:DCG]TIM,[F:DCG]CTRNUM,"",[F:DCG]STRDAT,FUTBALS,RF_IS_SOA,V_ERRMESSAGE,RF_GOK,P_V_MPYRDAT,[F:DCG]ENDDAT,1) From SUBACCRUAL
              Endif
            Next
          Else
            Call LVE_ENG(CRITHRTIM,CRITHRLST,CRITHRCTR,[F:DCG]TIM,[F:DCG]CTRNUM,"",[0/0/0],FUTBALS,RF_IS_SOA,V_ERRMESSAGE,RF_GOK,P_V_MPYRDAT,[F:DCG]ENDDAT,0) From SUBACCRUAL
          Endif
        Endif

        If func DIVPAYE.EXISTE_KXX("SUBDCGSSP") & func DIVPAYE.IS_BRI_LEG(RF_GCURLEG) & [F:DCG]SXPCAT='SSP'
        #If func SUBDCGSSP.SOA_SSPLNKPIW([F:DCG]STRDAT,[F:DCG]SXPCAT,[F:DCG]SSPPIW,[F:DCG]REFNUM,[F:DCG]SSPLNKPIW) <> 1 : Rollback : Endif
        Endif
        If func DIVPAYE.EXISTE_KXX("SUBDCGSSP") & func DIVPAYE.IS_BRI_LEG(RF_GCURLEG) & [F:DCG]SXPCAT='SSP'
          If func SUBDCGSSP.SSP_SPLIT([F:DCG]UID, "SSP_E") <> 1 : Rollback : Endif
        Endif
        If func DIVPAYE.EXISTE_KXX("SUBDCGSMP") & func DIVPAYE.IS_BRI_LEG(RF_GCURLEG) & [F:DCG]SXPCAT='SMP'
          If func SUBDCGSMP.SMP_SPLIT([F:DCG]UID, "SMP_H") <> 1 : Rollback : Endif
        Endif
        If func DIVPAYE.EXISTE_KXX("SUBDCGSMP") & func DIVPAYE.IS_BRI_LEG(RF_GCURLEG) & [F:DCG]SXPCAT='SMP'
          If func SUBDCGSMP.SMP_SPLIT([F:DCG]UID, "SMP_S") <> 1 : Rollback : Endif
        Endif
        If func DIVPAYE.EXISTE_KXX("SUBDCGSPP") & func DIVPAYE.IS_BRI_LEG(RF_GCURLEG) & [F:DCG]SXPCAT='SPP'
          If func SUBDCGSPP.SPP_SPLIT([F:DCG]UID, "SPP_E") <> 1 : Rollback : Endif
        Endif
      Else
        Break
      Endif
    Endif
  Next
Return

$ALLOCATE_DAY
  Local Date VARDAT,CYCLESTARTDATE, CYCLEENDDATE
  Local Integer LL,N,PAY,DEFPAYRATE,CC
  Local Char MIN_ALLOW_SUBTYP(GLONHRLST)
  Local Char ACCRUAL_LIST(GLONHRLST)(0..,0..9)
  Local Decimal LVE_REM
  Local Decimal BASE_AMT, SPEC_CONS_FLAG

  Local Char CTRNUMBER(GLONHRCTR) : CTRNUMBER = [F:HRCTR]CTRNUM
  Local Date CTR_DATE             : CTR_DATE = [F:HRCTR]CTRDAT

  RF_GOK = 0
  CHECK_DCG=1

  If clalev([F:TIM])=0      : Local File TIMCOD [TIM]           : Endif
  If clalev([F:HRLSTH])=0   : Local File HRLVESUBHEA [HRLSTH]   : Endif
  If clalev([F:HRACCRAL])=0 : Local File HRLVEACCRU [HRACCRAL]  : Endif

  Read [TIM]TIM0 = [FCYT]LEG; [DCGT]TIM
  If fstat
    V_ERRMESSAGE="Event does not exist"-[DCGT]TIM
    RF_GOK = 1
    Return
  Endif
  Read [HRLSTH]HRLST0 = [TIM]LEG; [TIM]LVESUBTYP(0)
  If fstat
    V_ERRMESSAGE="Sub-event does not exist"-[TIM]LVESUBTYP(0)
    RF_GOK = 1
    Return
  Endif
  If [F:HRLSTH]CYCSTRCAL=""
    V_ERRMESSAGE="Sub-event cycle start calculation not supplied"-[TIM]LVESUBTYP(0)
    RF_GOK = 1
    Return
  Else
    VARDAT = evalue([F:HRLSTH]CYCSTRCAL)
  Endif

  Gosub CYCLE_CHECK
  If RF_GOK = 1: Return : Endif

  If clalev([HRACCRA4])=0 : Local File HRLVEACCRU [HRACCRA4] : Endif

  Filter [F:HRACCRA4] Where CTR=[F:DCG]CTRNUM & CTRDAT=[L]CTR_DATE & LVEACCTIM=[F:DCG]TIM & LVEACCTYP="Accrual" & LVEACCDAT >= [L]THISLEAVEDATE

  If rowcount([F:HRACCRA4])>0
    Filter [F:HRACCRA4]
  Else
    Filter [F:HRACCRA4]
    Gosub FORECAST_ACCRUALS
    Return
  Endif

  BASE_AMT = 0
  N=0
  If [F:DCG]ENDDAY=2 & [L]THISLEAVEDATE=[F:DCG]STRDAT
    LVE_REM = 0.5
  Elsif [F:DCG]STRDAY=2 & [L]THISLEAVEDATE=[F:DCG]ENDDAT
    LVE_REM = 0.5
  Else
    LVE_REM = 1
  Endif
  Gosub PERFORM_ALL
Return

$CYCLE_CHECK
  Local Date CYCSTRDAT
  Local Integer R,J
  Local Float CYCLEN
  Local Date CYCARR(0..999,0..10)
  If clalev([F:HRPEODCC])=0  : Local File HRPEODET [HRPEODCC]     : Endif
    R=0
    If VARDAT = [0/0/0]
      VARDAT=GLMCYCLE
    Endif
    If GFONCTION="GESDCG" or GFONCTION = "SAIWRKMAN"
      Gosub CYCLE_CHECK_GFONC_GESDCG
    Endif
    If GFONCTION<>"GESDCG" and GFONCTION <> "SAIWRKMAN"
      Gosub CYCLE_CHECK_GFONC_NOTEQGESDCG
    Endif
Return

$CHECK_GCTREXTRPER
  If dim(GCTRNUMPER)<0
    Global Char GCTRNUMPER(GLONHRCTR)
    GCTRNUMPER = CTRNUMBER
    Gosub POPULATE_GCTREXTRPER
  Else
    If GCTRNUMPER <> CTRNUMBER
      Gosub POPULATE_GCTREXTRPER
      GCTRNUMPER = CTRNUMBER
    Endif
  Endif

  If dim(GCTREXTRPER)<0 or dim(GCTREXTRPERDAT)<0
    Gosub POPULATE_GCTREXTRPER
  Endif
Return

$CYCLE_CHECK_GFONC_GESDCG
  Local Integer MA
  Local Char CTRPERCOD(GLONHRPEO)
  Local Integer MA
  Gosub CHECK_GCTREXTRPER

  #Filter arrays and get PERCOD
  For MA = 1 To maxtab(GCTREXTRPER)
    If GCTREXTRPERDAT(MA,3) = [0/0/0] : Break : Endif
    If GCTREXTRPERDAT(MA,3) = CTR_DATE
      [L]CTRPERCOD = GCTREXTRPER(MA)
      Break
    Endif
  Next

  If ([TIM]COD="SSP" | [TIM]COD="SMP" | [TIM]COD="SPP")
    If CYCSTRDAT<evalue([F:HRLSTH]CYCSTRCAL)
      CYCSTRDAT=evalue([F:HRLSTH]CYCSTRCAL)
    Endif
  Endif

  If ([TIM]COD="SSP" | [TIM]COD="SMP" | [TIM]COD="SPP")
    If clalev([F:ACCRU]) = 0: Local File HRLVEACCRU [ACCRU] : Endif  #FRLAA 2018-08-14 X3-104072
    Filter [ACCRU] Where [ACCRU]LVEACCLST =[F:HRLSTH]COD and [ACCRU]CTR= CTRNUMBER Order By [ACCRU]LVEACCDAT
    Read [ACCRU] Last
    Filter [ACCRU]
    CYCSTRDAT=[ACCRU]LVEACCDAT
    If CYCSTRDAT<evalue([F:HRLSTH]CYCSTRCAL)
      CYCSTRDAT=evalue([F:HRLSTH]CYCSTRCAL)
    Endif
  Endif

  CHECKD=datesyst
  If CYCSTRDAT=[0/0/0]
    If parse(evalue([F:HRLSTH]CYCSTRCAL), 0) <> 10 & parse(evalue([F:HRLSTH]CYCSTRCAL), 0) <> 0
      CYCSTRDAT=VARDAT
    Else
      If VARDAT < evalue([F:HRLSTH]CYCSTRCAL)
        CYCSTRDAT = VARDAT
      Else
        CYCSTRDAT = evalue([F:HRLSTH]CYCSTRCAL)
      Endif
    Endif
  Endif
  CYCLEN = [F:HRLSTH]CYCLEN
  LENOPT = [F:HRLSTH]CYCLENU

#Will loop for each condition, dont want to use evalue for this prog.
  If ([TIM]COD="SSP" | [TIM]COD="SMP" | [TIM]COD="SPP")
    For MA = 1 To maxtab(GCTREXTRPERDAT)
      If GCTREXTRPERDAT(MA,1) = [0/0/0] : Break : Endif
      If GCTREXTRPERDAT(MA,2)>=CYCSTRDAT and GCTREXTRPER(MA) = [L]CTRPERCOD
        Gosub CYCLE_CHECK_GESDCG_CYCSTR
      Endif
    Next
  Elsif [F:HRLSTH]LVEACCOPT = 3 | [F:HRLSTH]LVEACCOPT = 5 | [F:HRLSTH]LVEACCOPT = 2
    For MA = 1 To maxtab(GCTREXTRPERDAT)
      If GCTREXTRPERDAT(MA,1) = [0/0/0] : Break : Endif
      If GCTREXTRPERDAT(MA,1)>=CYCSTRDAT and GCTREXTRPER(MA) = [L]CTRPERCOD
        Gosub CYCLE_CHECK_GESDCG_CYCSTR
      Endif
    Next
  Else
    If [F:HRLSTH]LVEACCOPT = 4 | [F:HRLSTH]LVEACCOPT = 6
      For MA = 1 To maxtab(GCTREXTRPERDAT)
        If GCTREXTRPERDAT(MA,1) = [0/0/0] : Break : Endif
        If GCTREXTRPERDAT(MA,2)>=CYCSTRDAT and GCTREXTRPER(MA) = [L]CTRPERCOD
          Gosub CYCLE_CHECK_GESDCG_CYCSTR
        Endif
      Next
    Endif
  Endif

  CYCLEN = [F:HRLSTH]CYCLEN
  LENOPT = [F:HRLSTH]CYCLENU
Return

$POPULATE_GCTREXTRPER
  Local Integer CTRAR
  If dim(GCTREXTRPER)<0
    Global Char GCTREXTRPER(GLONHRPEO)(1..1000)
  Else
    Raz GCTREXTRPER
  Endif

  If dim(GCTREXTRPERDAT)<0
    Global Date GCTREXTRPERDAT(1..1000,1..3)
  Else
    Raz GCTREXTRPERDAT
  Endif

#Populate the arrays
  If !clalev([F:HRCTR9]) : Local File EMPLOCTR [HRCTR9] : Endif
  If !clalev([F:HRPEOD6]) : Local File HRPEODET [HRPEOD6] : Endif
  Filter [F:HRCTR9] Where [F:HRCTR9]CTRNUM = CTRNUMBER Order By CTRDAT

  For [F:HRCTR9]
    Filter [F:HRPEOD6]
    Filter [F:HRPEOD6] Where [F:HRPEOD6]PERCOD=[F:HRCTR9]PERCOD
    For [F:HRPEOD6]
      CTRAR+=1
      GCTREXTRPER(CTRAR)      = [F:HRCTR9]PERCOD      #Period code
      GCTREXTRPERDAT(CTRAR,1) = [F:HRPEOD6]PERSTR(1)  #Period start
      GCTREXTRPERDAT(CTRAR,2) = [F:HRPEOD6]PEREND(1)  #Period end
      GCTREXTRPERDAT(CTRAR,3) = [F:HRCTR9]CTRDAT #Period end
    Next
  Next

  Filter [F:HRCTR9]
  Filter [F:HRPEOD6]
Return

$CYCLE_CHECK_GESDCG_CYCSTR
  CYCARR(R,1)=CYCSTRDAT
  If LENOPT= 1
    CYCSTRDAT=addmonth(CYCSTRDAT,CYCLEN*12)
  Else
    CYCSTRDAT=addmonth(CYCSTRDAT,CYCLEN)
  Endif
  CYCARR(R,2)=CYCSTRDAT
  R+=1
Return

$CYCLE_CHECK_GFONC_NOTEQGESDCG
  If CHECKD = [0/0/0]
    CHECKD = datesyst
  Endif

  If [HRLSTH]LVEACCOPT=22 | [HRLSTH]LVEACCOPT=7
    If CYCSTRDAT=[0/0/0] : CYCSTRDAT=ACCDAT : Endif
      If GFONCTION<>"CONSLTA" and (GCURLEG="BRI" and !([TIM]COD="SSP" | [TIM]COD="SMP" | [TIM]COD="SPP"))
        If evalue([F:HRLSTH]CYCSTRCAL)<GLMCYCLE : CYCSTRDAT=GLMCYCLE : Endif
      Endif
      CYCLEN = [F:HRLSTH]CYCLEN
      LENOPT = [F:HRLSTH]CYCLENU
      CYCARR(0,1)=CYCSTRDAT
      If LENOPT= 1
        CYCSTRDAT=addmonth(CYCSTRDAT,CYCLEN*12)
      Else
        CYCSTRDAT=addmonth(CYCSTRDAT,CYCLEN)
      Endif
      CYCARR(0,2)=CYCSTRDAT

      For I=1 To 999
        If CYCSTRDAT<=CHECKD
          CYCARR(I,1)=CYCSTRDAT
          If LENOPT= 1
            CYCSTRDAT=addmonth(CYCSTRDAT,CYCLEN*12)
          Else
            CYCSTRDAT=addmonth(CYCSTRDAT,CYCLEN)
          Endif
          CYCARR(I,2)=CYCSTRDAT
        Endif
        If CYCSTRDAT>CHECKD : Break : Endif
      Next


      If [HRLSTH]LVEACCOPT = 7
        If RCOUNTACCR=0
          DAYSTOACCRU=CHECKD-CYCARR(0,1)
          Local Date LOOPDATE(0..DAYSTOACCRU-1,0..DAYSTOACCRU-1)
          CYCSTRDAT=ACCDAT
          For Y=1 To DAYSTOACCRU
            LOOPDATE(Y-1,1)=CYCSTRDAT
            CYCSTRDAT=CYCSTRDAT+1
          Next
        Else
          DAYSTOACCRU=CHECKD-[F:HRACCR]LVEACCDAT
          Local Date LOOPDATE(0..DAYSTOACCRU-1,0..DAYSTOACCRU-1)
          CYCSTRDAT=[F:HRACCR]LVEACCDAT
          For Y=1 To DAYSTOACCRU
            LOOPDATE(Y-1,1)=CYCSTRDAT
            CYCSTRDAT=CYCSTRDAT+1
          Next
        Endif
      Endif
    Else
      If parse(evalue([F:HRLSTH]CYCSTRCAL),0)<>10 & parse(evalue([F:HRLSTH]CYCSTRCAL),0)<>0
        VARDAT = GLMCYCLE
      Else
        If evalue([F:HRLSTH]CYCSTRCAL)<GLMCYCLE and find(left$([F:HRLSTH]CYCSTRCAL,4),"func")=0 #and ([HRLSTH]LVEACCOPT <> 5 & [HRLSTH]LVEACCOPT <> 6)
          VARDAT=GLMCYCLE
        Else
          VARDAT = evalue([F:HRLSTH]CYCSTRCAL)
        Endif
      Endif
      If CYCSTRDAT=[0/0/0]
        If parse(evalue([F:HRLSTH]CYCSTRCAL), 0) <> 10 & parse(evalue([F:HRLSTH]CYCSTRCAL), 0) <> 0
          CYCSTRDAT = GLMCYCLE
        Else
          CYCSTRDAT = evalue([F:HRLSTH]CYCSTRCAL)
        Endif
      Endif
      CYCLEN = [F:HRLSTH]CYCLEN
      LENOPT = [F:HRLSTH]CYCLENU
      If GFONCTION="TRTLVEACC"
        If [F:HRLSTH]LVEACCOPT = 3 | [F:HRLSTH]LVEACCOPT = 5 | [F:HRLSTH]LVEACCOPT = 2
          Filter [F:HRPEODCC] Where PERCOD = [F:HRCTR]PERCOD and [F:HRPEODCC]PERSTR(1) >= CYCSTRDAT #and [F:HRPEODCC]PEREND(1) <= [F:VEP2]ENDDAT
        Elsif [F:HRLSTH]LVEACCOPT = 4 | [F:HRLSTH]LVEACCOPT = 6
          Filter [F:HRPEODCC] Where PERCOD = [F:HRCTR]PERCOD and [F:HRPEODCC]PEREND(1) >= CYCSTRDAT #and [F:HRPEODCC]PEREND(1) <= [F:VEP2]ENDDAT
        Endif
      Else
        If [F:HRLSTH]LVEACCOPT = 3 | [F:HRLSTH]LVEACCOPT = 5 | [F:HRLSTH]LVEACCOPT = 2
          Filter [F:HRPEODCC] Where PERCOD = [F:HRCTR]PERCOD and [F:HRPEODCC]PERSTR(1) >= CYCSTRDAT
        Elsif [F:HRLSTH]LVEACCOPT = 4 | [F:HRLSTH]LVEACCOPT = 6
          Filter [F:HRPEODCC] Where PERCOD = [F:HRCTR]PERCOD and [F:HRPEODCC]PEREND(1) >= CYCSTRDAT
        Endif
      Endif
      For [F:HRPEODCC]
        If [F:HRPEODCC]PERSTR(1)>=CYCSTRDAT & ([F:HRLSTH]CYCREC=2 | R=0) #& [F:HRPEODCC]PEREND(1)<=CYCSTRDAT
          CYCARR(R,1)=CYCSTRDAT
          If LENOPT= 1
            CYCSTRDAT=addmonth(CYCSTRDAT,CYCLEN*12)
          Else
            CYCSTRDAT=addmonth(CYCSTRDAT,CYCLEN)
          Endif
          CYCARR(R,2)=CYCSTRDAT
          R+=1
        Endif
      Next
      Filter [F:HRPEODCC]
    Endif
Return

$FORECAST_ACCRUALS
  Local Date CYCLESTARTDATE, CYCLEENDDATE,GLMCYCLE
  Local Integer N
  Local Char FUTBALS(250)(0..,0..10),GLMCYCLESTR(250)
  If RF_IS_SOA
    GLMCYCLESTR = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 5, RF_GCURLEG, "GLMCYCLE")
    Call CONVERT_TO_DATE(evalue(GLMCYCLESTR), GLMCYCLE) From SUBHRBAL
  Else
    GLMCYCLE = func SUBHRBAL.GET_GLM_CYCLE([F:DCG]CTRNUM,[F:DCG]CTRDAT)
  Endif
  SPEC_CONS_FLAG=1

  If [F:HRLSTH]CONSCALC<>""
    SPEC_CONS_FLAG=evalue([F:HRLSTH]CONSCALC)
  Endif

  If [F:DCG]TIM='SSP'
    Local Integer SSP_TRANS
    Local Char CRITHRTIM(250),CRITHRCTR(250)
    If clalev([F:DCGSSP])=0  : Local File DEMCONGE [DCGSSP]     : Endif
    If clalev([F:HRLSTHS])=0 : Local File HRLVESUBHEA [HRLSTHS] : Endif
    If clalev([F:ACCRSSP])=0 : Local File HRLVEACCRU [ACCRSSP] : Endif
    CRITHRLST="1=0 | ([F:HRCTR]CTRNUM = '"+[F:DCG]CTRNUM+"')"
    Read [HRLSTHS]HRLST0 = [TIM]LEG; "SSP_E"
    If [F:HRLSTHS]CYCSTRCAL=''
      V_ERRMESSAGE="Sub-event cycle start calculation not supplied"-"SSP_E"
      RF_GOK = 1
      Return
    Else
      If evalue([F:HRLSTHS]CYCSTRCAL)<GLMCYCLE
        VARDAT=GLMCYCLE
      Else
        VARDAT = evalue([F:HRLSTHS]CYCSTRCAL)
      Endif
    Endif
    Filter [ACCRSSP]
    Filter [ACCRSSP] Where [F:ACCRSSP]LVEACCLST="SSP_E" &[F:ACCRSSP]REFNUM=[F:DCG]REFNUM & [F:ACCRSSP]CTR=[F:DCG]CTRNUM & [F:ACCRSSP]LVEACCAMT<>"0" & [F:ACCRSSP]LVEACCDAT=VARDAT
    Filter [DCGSSP]
    Filter [DCGSSP] Where [DCGSSP]REFNUM=[F:DCG]REFNUM & [DCGSSP]CTRNUM=[F:DCG]CTRNUM
& &        [DCGSSP]TIM="SSP"
& &        ([DCGSSP]STRDAT>=VARDAT | [DCGSSP]ENDDAT >=VARDAT)& [DCGSSP]ENDDAT<=[F:DCG]ENDDAT
& &        [DCGSSP]UID>0
& &        ([DCGSSP]STA=1|[DCGSSP]STA=2|[DCGSSP]STA=3|[DCGSSP]STA=5|[DCGSSP]STA=7)
& &        ([DCGSSP]SSPSTA=2)
    If rowcount([DCGSSP])=1 & rowcount([ACCRSSP])=0 and [F:DCG]SSPSTA<>1
      Call LVE_ENG(CRITHRTIM,CRITHRLST,CRITHRCTR,[F:DCG]TIM,"","",[0/0/0],FUTBALS,RF_IS_SOA,V_ERRMESSAGE,RF_GOK,P_V_MPYRDAT,[0/0/0],0) From SUBACCRUAL
    Endif
    Filter [DCGSSP]
    Filter [ACCRSSP]
  Elsif [F:DCG]TIM='SPP'
    Local Integer SSP_TRANS
    Local Char CRITHRTIM(250),CRITHRCTR(250)
    If clalev([F:DCGSSP])=0  : Local File DEMCONGE [DCGSSP]     : Endif
    If clalev([F:HRLSTHS])=0 : Local File HRLVESUBHEA [HRLSTHS] : Endif
    If clalev([F:ACCRSSP])=0 : Local File HRLVEACCRU [ACCRSSP] : Endif

    CRITHRLST="1=0 | ([F:HRCTR]CTRNUM = '"+[F:DCG]CTRNUM+"')"
    Read [HRLSTHS]HRLST0 = [TIM]LEG; "SPP_E"
    If [F:HRLSTHS]CYCSTRCAL=''
      GMESSAGE="Sub-event cycle start calculation not supplied"-"SPP_E"
      GOK=0
      Return
    Else
      If evalue([F:HRLSTHS]CYCSTRCAL)<GLMCYCLE
        VARDAT=GLMCYCLE
      Else
        VARDAT = evalue([F:HRLSTHS]CYCSTRCAL)
      Endif
    Endif
    Filter [ACCRSSP]
    Filter [ACCRSSP] Where [F:ACCRSSP]LVEACCLST="SPP_E" &[F:ACCRSSP]REFNUM=[F:DCG]REFNUM & [F:ACCRSSP]CTR=[F:DCG]CTRNUM & [F:ACCRSSP]LVEACCAMT<>"0" & [F:ACCRSSP]LVEACCDAT=VARDAT
    Filter [DCGSSP]
    Filter [DCGSSP] Where [DCGSSP]REFNUM=[F:DCG]REFNUM & [DCGSSP]CTRNUM=[F:DCG]CTRNUM
& &        [DCGSSP]TIM="SPP"
& &        ([DCGSSP]STRDAT>=VARDAT | [DCGSSP]ENDDAT >=VARDAT)& [DCGSSP]ENDDAT<=[F:DCG]ENDDAT
& &        [DCGSSP]UID>0
& &        ([DCGSSP]STA=1|[DCGSSP]STA=2|[DCGSSP]STA=3|[DCGSSP]STA=5|[DCGSSP]STA=7)
& &        ([DCGSSP]SSPSTA=2)
    If rowcount([DCGSSP])=1 & rowcount([ACCRSSP])=0 and [F:DCG]SSPSTA<>1
      Call LVE_ENG(CRITHRTIM,CRITHRLST,CRITHRCTR,[F:DCG]TIM,"","",[0/0/0],FUTBALS,RF_IS_SOA,V_ERRMESSAGE,RF_GOK,P_V_MPYRDAT,[0/0/0],0) From SUBACCRUAL
    Endif
    Filter [DCGSSP]
    Filter [ACCRSSP]
  Elsif [F:DCG]TIM='SPP'
    Local Integer SSP_TRANS
    Local Char CRITHRTIM(250),CRITHRCTR(250)
    If clalev([F:DCGSSP])=0  : Local File DEMCONGE [DCGSSP]     : Endif
    If clalev([F:HRLSTHS])=0 : Local File HRLVESUBHEA [HRLSTHS] : Endif
    If clalev([F:ACCRSSP])=0 : Local File HRLVEACCRU [ACCRSSP] : Endif
    CRITHRLST="1=0 | ([F:HRCTR]CTRNUM = '"+[F:DCG]CTRNUM+"')"
    Read [HRLSTHS]HRLST0 = [TIM]LEG; "SPP_E"
    If [F:HRLSTHS]CYCSTRCAL=''
      GMESSAGE="Sub-event cycle start calculation not supplied"-"SPP_E"
      GOK=0
      Return
    Else
      If evalue([F:HRLSTHS]CYCSTRCAL)<GLMCYCLE
        VARDAT=GLMCYCLE
      Else
        VARDAT = evalue([F:HRLSTHS]CYCSTRCAL)
      Endif
    Endif
    Filter [ACCRSSP]
    Filter [ACCRSSP] Where [F:ACCRSSP]LVEACCLST="SPP_E" &[F:ACCRSSP]REFNUM=[F:DCG]REFNUM & [F:ACCRSSP]CTR=[F:DCG]CTRNUM & [F:ACCRSSP]LVEACCAMT<>"0" & [F:ACCRSSP]LVEACCDAT=VARDAT
    Filter [DCGSSP]
    Filter [DCGSSP] Where [DCGSSP]REFNUM=[F:DCG]REFNUM & [DCGSSP]CTRNUM=[F:DCG]CTRNUM
& &        [DCGSSP]TIM="SPP"
& &        ([DCGSSP]STRDAT>=VARDAT | [DCGSSP]ENDDAT >=VARDAT)& [DCGSSP]ENDDAT<=[F:DCG]ENDDAT
& &        [DCGSSP]UID>0
& &        ([DCGSSP]STA=1|[DCGSSP]STA=2|[DCGSSP]STA=3|[DCGSSP]STA=5|[DCGSSP]STA=7)
& &        ([DCGSSP]SSPSTA=2)
    If rowcount([DCGSSP])=1 & rowcount([ACCRSSP])=0 and [F:DCG]SSPSTA<>1
      Call LVE_ENG(CRITHRTIM,CRITHRLST,CRITHRCTR,[F:DCG]TIM,"","",[0/0/0],FUTBALS,RF_IS_SOA,V_ERRMESSAGE,RF_GOK,P_V_MPYRDAT,[0/0/0],0) From SUBACCRUAL
    Endif
    Filter [DCGSSP]
    Filter [ACCRSSP]
  Elsif [F:DCG]TIM='SMP'
    Local Integer SSP_TRANS
    Local Char CRITHRTIM(250),CRITHRCTR(250)
    If clalev([F:DCGSSP])=0  : Local File DEMCONGE [DCGSSP]     : Endif
    If clalev([F:HRLSTHS])=0 : Local File HRLVESUBHEA [HRLSTHS] : Endif
    If clalev([F:ACCRSSP])=0 : Local File HRLVEACCRU [ACCRSSP] : Endif
    CRITHRLST="1=0 | ([F:HRCTR]CTRNUM = '"+[F:DCG]CTRNUM+"')"
    Read [HRLSTHS]HRLST0 = [TIM]LEG; "SMP_H"
    If [HRLSTHS]CYCSTRCAL=''
      V_ERRMESSAGE="Sub-event cycle start calculation not supplied"-"SMP_H"
      RF_GOK = 1
      Return
    Else
      If evalue([F:HRLSTHS]CYCSTRCAL)<GLMCYCLE
        VARDAT=GLMCYCLE
      Else
        VARDAT = evalue([F:HRLSTHS]CYCSTRCAL)
      Endif
    Endif
    Filter [ACCRSSP]
    Filter [ACCRSSP] Where [F:ACCRSSP]LVEACCLST="SMP_H" &[F:ACCRSSP]REFNUM=[F:DCG]REFNUM & [F:ACCRSSP]CTR=[F:DCG]CTRNUM & [F:ACCRSSP]LVEACCAMT<>"0" & [F:ACCRSSP]LVEACCDAT=VARDAT
    Filter [DCGSSP]
    Filter [DCGSSP] Where [DCGSSP]REFNUM=[F:DCG]REFNUM & [DCGSSP]CTRNUM=[F:DCG]CTRNUM
& &        [DCGSSP]TIM="SMP"
& &        ([DCGSSP]STRDAT>=VARDAT | [DCGSSP]ENDDAT >=VARDAT)& [DCGSSP]ENDDAT<=[F:DCG]ENDDAT
& &        [DCGSSP]UID>0
& &        ([DCGSSP]STA=1|[DCGSSP]STA=2|[DCGSSP]STA=3|[DCGSSP]STA=5|[DCGSSP]STA=7)
& &        ([DCGSSP]SMPELI=2)
    Read [DCGSSP] First
    If rowcount([DCGSSP])=1 & rowcount([ACCRSSP])=0  and [F:DCG]SMPELI<>1
      Call LVE_ENG(CRITHRTIM,CRITHRLST,CRITHRCTR,[F:DCG]TIM,"","",[0/0/0],FUTBALS,RF_IS_SOA,V_ERRMESSAGE,RF_GOK,P_V_MPYRDAT,[0/0/0],0) From SUBACCRUAL
      If RF_GOK = 1
        Return
      Endif
    Endif
    Filter [DCGSSP]
    Filter [ACCRSSP]
    Read [HRLSTHS]HRLST0 = [TIM]LEG; "SMP_S"

    If [F:HRLSTHS]CYCSTRCAL=''
      V_ERRMESSAGE="Sub-event cycle start calculation not supplied"-"SMP_S"
      RF_GOK = 1
      Return
    Else
      If evalue([F:HRLSTHS]CYCSTRCAL)<GLMCYCLE
        VARDAT=GLMCYCLE
      Else
        VARDAT = evalue([F:HRLSTHS]CYCSTRCAL)
      Endif
    Endif
    Filter [ACCRSSP]
    Filter [ACCRSSP] Where [F:ACCRSSP]LVEACCLST="SMP_S" &[F:ACCRSSP]REFNUM=[F:DCG]REFNUM & [F:ACCRSSP]CTR=[F:DCG]CTRNUM & [F:ACCRSSP]LVEACCAMT<>"0" & [F:ACCRSSP]LVEACCDAT=VARDAT
    Filter [DCGSSP]
    Filter [DCGSSP] Where [DCGSSP]REFNUM=[F:DCG]REFNUM & [DCGSSP]CTRNUM=[F:DCG]CTRNUM
& &        [DCGSSP]TIM="SMP"
& &        ([DCGSSP]STRDAT>=VARDAT | [DCGSSP]ENDDAT >=VARDAT)& [DCGSSP]ENDDAT<=[F:DCG]ENDDAT
& &        [DCGSSP]UID>0
& &        ([DCGSSP]STA=1|[DCGSSP]STA=2|[DCGSSP]STA=3|[DCGSSP]STA=5|[DCGSSP]STA=7)
& &        ([DCGSSP]SMPELI=2)
    Read [DCGSSP] First
    If rowcount([DCGSSP])=1 & rowcount([ACCRSSP])=0  and [F:DCG]SMPELI<>1
      Call LVE_ENG(CRITHRTIM,CRITHRLST,CRITHRCTR,[F:DCG]TIM,"","",[0/0/0],FUTBALS,RF_IS_SOA,V_ERRMESSAGE,RF_GOK,P_V_MPYRDAT,[0/0/0],0) From SUBACCRUAL
    Endif
    Filter [DCGSSP]
    Filter [ACCRSSP]
  Else
    Local Char CRITHRLST(250)
    CRITHRLST="1=0 | ([F:HRCTR]CTRNUM = '"+[F:DCG]CTRNUM+"')"
    Call LVE_ENG("", CRITHRLST, "", [F:DCG]TIM, [F:DCG]CTRNUM, "", [L]THISLEAVEDATE, FUTBALS,RF_IS_SOA,V_ERRMESSAGE,RF_GOK,P_V_MPYRDAT,[0/0/0],0) From SUBACCRUAL
  Endif
  BASE_AMT = 0
  N=0
  If [F:DCG]ENDDAY=2 & [L]THISLEAVEDATE=[F:DCG]STRDAT
    LVE_REM = 0.5
  Elsif [F:DCG]STRDAY=2 & [L]THISLEAVEDATE=[F:DCG]ENDDAT
    LVE_REM = 0.5
  Else
    LVE_REM = 1
  Endif

  Local Char CTRNUMBER(GLONHRCTR) : CTRNUMBER = [F:DCG]CTRNUM
  Local Date CTR_DATE             : CTR_DATE = [F:DCG]CTRDAT

  Gosub PERFORM_ALL
Return

$PERFORM_ALL
  Local Char CRITHRLST(250)
  Local Char CRITHRTIM(250),CRITHRCTR(250)

  Gosub CHECK_MINUS_BALANCES_TYPE
  Gosub SET_ACCRUAL_TOTAL
  Gosub COUNT_PREVIOUS_TAKENS
  Gosub CHECK_MINUS_BALANCES

  If RF_GOK <> 1 : Gosub MAIN_PRIORITY_SPLITS : Endif
Return

$CHECK_MINUS_BALANCES_TYPE
  MIN_ALLOW_SUBTYP=''
  If clalev([F:HRACCR6])=0 : Local File HRLVEACCRU [HRACCR6] : Endif
  Local Char LVESUBTYPESARR(GLONHRLST)(1..1000)
  Local Integer MI
  Filter [F:HRACCR6] Where CTR = [L]CTRNUMBER and CTRDAT = [L]CTR_DATE and LVEACCTYP = "Linking"
  For [F:HRACCR6]ACC0
    MI+=1
    LVESUBTYPESARR(MI) = [F:HRACCR6]LVEACCLST
  Next
  Filter [F:HRACCR6]

  If clalev([F:HHRLST])=0 : Local File HRLVESUBHEA [HHRLST] : Endif
  Read [TIM]TIM0 = [FCYT]LEG; [F:DCG]TIM
  For CC=1 To dim([TIM]LVESUBTYP)
    If [TIM]LVESUBTYP(CC-1)<>""
      Read [HHRLST]HRLST0 = [TIM]LEG; [TIM]LVESUBTYP(CC-1)
      If [HHRLST]LVEFORFEIT<2
        If find([TIM]LVESUBTYP(CC-1),LVESUBTYPESARR)
          MIN_ALLOW_SUBTYP=[TIM]LVESUBTYP(CC-1)
        Endif
      Endif
    Endif
  Next
Return

$SET_ACCRUAL_TOTAL
  Local Integer ARRLOOP
  Local Decimal ALLOW_AMT,TOTALACCRU,EXT_ALLOW_AMT,TOTZERO
  Local Date CYCLESTARTDATEOC,CYCLEENDDATEOC,PREV_CYCLESTARTDATE
  Local Date LASTACCRTRNDATE

  Local Date SYSDATEARRAY(1..)
  Local Integer DA

  If clalev([F:HRACCRAT]) = 0
    Local File HRLVEACCRU [HRACCRAT]
  Endif

  Filter [F:HRACCRAT] Where [F:HRACCRAT]REFNUM=[F:DCG]REFNUM & [F:HRACCRAT]CTR=[F:DCG]CTRNUM & [F:HRACCRAT]CTRDAT = [F:DCG]CTRDAT
& &           [F:HRACCRAT]LVEACCDAT<=[L]THISLEAVEDATE

  BASE_AMT=0
  For LL=1 To dim([TIM]LVESUBTYP)
    Raz SYSDATEARRAY  #FRLAA 2018-08-16 X3-104072
    If [TIM]LVESUBTYP(LL-1) <> "" and find([TIM]LVESUBTYP(LL-1),VIFINALS(0..,1))
     If ([TIM]COD="SSP" | [TIM]COD="SMP" | [TIM]COD="SPP")
      Call GET_CYCLE_START_DATE([F:DCG]CTRNUM, [TIM]LVESUBTYP(LL-1), [L]THISLEAVEDATE, CYCLESTARTDATE, CYCLEENDDATE,RF_IS_SOA) From SUBHRBAL
    Else
      Call GET_CYCLE_START_DATE_EXTRACTION([F:DCG]CTRNUM, [TIM]LVESUBTYP(LL-1), [L]THISLEAVEDATE, CYCLESTARTDATE, CYCLEENDDATE,RF_IS_SOA,RF_GCURLEG) From SUBHRBAL
    Endif
    If PREVCYCLE(LL-1) = [0/0/0] #Value not set yet - set now
      PREVCYCLE(LL-1) = CYCLESTARTDATE
    Else #Compare values
      If PREVCYCLE(LL-1) <> CYCLESTARTDATE
        CYCLE_RENEW=1
        PREVCYCLE(LL-1) = CYCLESTARTDATE
      Endif
    Endif
    If CYCLE_RENEW=1
      Local Date CYCLESTARTDATE,CYCLEENDDATE
      Call GET_CYCLE_START_DATE_EXTRACTION([F:DCG]CTRNUM, [TIM]LVESUBTYP(LL-1), [L]THISLEAVEDATE, CYCLESTARTDATE, CYCLEENDDATE,RF_IS_SOA,RF_GCURLEG) From SUBHRBAL
    Endif
    If CYCLESTARTDATE<>[0/0/0]
      For [HRACCRAT]ACC0
#Only filter on the CYCLESTARTDATE and LVESUBTYP, original Filter ALREADY DONE IN THE START OF THE PROG
        If [F:HRACCRAT]LVEACCDAT>=CYCLESTARTDATE and [F:HRACCRAT]LVEACCLST = [TIM]LVESUBTYP(LL-1)
          If [TIM]LVESUBTYP(LL-1)=[HRACCRAT]LVEACCLST
            BASE_AMT+=val(num$([HRACCRAT]LVEACCAMT))
          Endif
        Endif
      Next
    Endif
    Raz DA
    For  [HRACCRAT]ACC0
#Only filter on the CYCLESTARTDATE and LVESUBTYP, original Filter ALREADY DONE IN THE START OF THE PROG
      If [F:HRACCRAT]LVEACCDAT>=CYCLESTARTDATE and [F:HRACCRAT]LVEACCLST = [TIM]LVESUBTYP(LL-1) and [F:HRACCRAT]LVEACCTYP<>"Linking"
#Populate the date array, Store the transaction date
        DA+=1
        [L]SYSDATEARRAY(DA) = [F:HRACCRAT]LVEACCDAT
      Endif
    Next
#Store the latest date
    [L]LASTACCRTRNDATE = max([L]SYSDATEARRAY)

    EXT_ALLOW_AMT=0
    ALLOW_AMT=[TIM]LVEMAXCRE
    If ([F:TIM]LVEMAXOPT<>2) & [F:TIM]LVEMAXCRE>0 : EXT_ALLOW_AMT=1000 : Endif

    For ARRLOOP=0 To maxtab(FUTBALS)
      If FUTBALS(ARRLOOP,2)="" : Break : Endif
      Local Date CONVERTED_DATE
      Call CONVERT_TO_DATE(FUTBALS(ARRLOOP,3), CONVERTED_DATE) From SUBHRBAL
      If FUTBALS(ARRLOOP,2)=[TIM]LVESUBTYP(LL-1) & (CONVERTED_DATE>=CYCLESTARTDATE & CONVERTED_DATE<=[L]THISLEAVEDATE) & (CONVERTED_DATE>[L]LASTACCRTRNDATE)
        BASE_AMT+=val(FUTBALS(ARRLOOP,5))
      Endif
    Next

    If [F:HRLSTH]LVEFORFEIT=2 : BASE_AMT=0 : Endif
      If [TIM]LVESUBTYP(LL-1) <> ""
        If [TIM]LVESUBTYP(LL-1)=MIN_ALLOW_SUBTYP
          ACCRUAL_LIST(N,1)=[TIM]LVESUBTYP(LL-1)
          ACCRUAL_LIST(N,2)=num$(BASE_AMT+ALLOW_AMT+EXT_ALLOW_AMT)
          TOTALACCRU+=(BASE_AMT+ALLOW_AMT+EXT_ALLOW_AMT)
          TOTZERO+=BASE_AMT
        Else
          ACCRUAL_LIST(N,1)=[TIM]LVESUBTYP(LL-1)
          ACCRUAL_LIST(N,2)=num$(BASE_AMT)
          TOTALACCRU+=(BASE_AMT)
          TOTZERO+=BASE_AMT
        Endif
        BASE_AMT=0
        N=N+1
      Endif
    Endif
  Next

  If [L]CYCLE_RENEW <> 1
    [L]ACCRUAL_PDAY = [L]TOTALACCRU
  Else
    [L]TOTALACCRU+=[L]ACCRUAL_PDAY
  Endif

  Filter [HRACCRAT]  #FRLAA 2018-08-14 X3-104072
Return

$COUNT_PREVIOUS_TAKENS
Local Char TAKEN_LIST(GLONHRLST)(0..99,0..99)
Local Char PREV_T_LST(5)
Local Decimal TAKN,TOT_TAKN
Local Integer TKKK,TKN
Local Date TEMPLEAVEDATE,CYCLESTARTDATEPREV,CYCLEENDDATEPREV
Local Integer TEMPCOUNT
Local Decimal TEMPLEAVEDAYS, TEMPLEAVEHOURS

  N=0
  TKN=0
  E=0
  If clalev([F:DCGC])=0 : Local File DEMCONGE [F:DCGC] : Endif
  If !clalev([F:DCGSP]) : Local File DEMSPLITS [DCGSP] : Endif
  Filter [F:DCGC]

  For TKKK=1 To dim([TIM]LVESUBTYP)
    If [TIM]LVESUBTYP(TKKK-1)="" : Break : Endif
    If ([TIM]COD="SSP" | [TIM]COD="SMP" | [TIM]COD="SPP")
      Call GET_CYCLE_START_DATE([F:DCG]CTRNUM, [TIM]LVESUBTYP(TKKK-1), [L]THISLEAVEDATE, CYCLESTARTDATEPREV, CYCLEENDDATEPREV,RF_IS_SOA) From SUBHRBAL
    Else
      Call GET_CYCLE_START_DATE_EXTRACTION([F:DCG]CTRNUM, [TIM]LVESUBTYP(TKKK-1), [L]THISLEAVEDATE, CYCLESTARTDATEPREV, CYCLEENDDATEPREV,RF_IS_SOA,RF_GCURLEG) From SUBHRBAL
    Endif
    If RF_GCURLEG = "BRI" and ([TIM]COD="SSP" | [TIM]COD="SMP" | [TIM]COD="SPP")
      Filter [F:DCGC]
      Filter [F:DCGC] Where [F:DCGC]REFNUM=[F:DCG]REFNUM & [F:DCGC]CTRNUM=[F:DCG]CTRNUM
& &         [F:DCGC]TIM=[TIM]COD & [F:DCGC]UID>0
& &         ([F:DCGC]STA=1|[F:DCGC]STA=2|[F:DCGC]STA=3|[F:DCGC]STA=5|[F:DCGC]STA=7)
& &         (([F:DCGC]STRDAT>=CYCLESTARTDATEPREV & [F:DCGC]STRDAT<=[L]THISLEAVEDATE))
&     Order By [F:DCGC]STRDAT
      For TKN = 1 To dim([F:DCGC]LVESUBTYP)
        For [F:DCGC]
          If [F:DCGC]LVESUBTYP(TKN-1)=[TIM]LVESUBTYP(TKKK-1)
            TAKN+=val(num$([F:DCGC]LVESUBBAL(TKN-1)))
          Endif
        Next
      Next
    Else
      Link [DCGC] With [DCGSP]DCGSP1=[DCGC]UID As [SPLITS]
&     Where [F:DCGC]CTRNUM = [F:DCG]CTRNUM and [F:DCGC]REFNUM=[F:DCG]REFNUM and [F:DCGC]TIM = [TIM]COD
&       and [F:DCGC]UID>0 and ([F:DCGC]STA=1|[F:DCGC]STA=2|[F:DCGC]STA=3|[F:DCGC]STA=5|[F:DCGC]STA=7)
&       and [F:DCGSP]LVEDAT>=[L]CYCLESTARTDATEPREV and [F:DCGSP]LVEDAT<[L]THISLEAVEDATE and [F:DCGSP]LVEDAT<=[L]CYCLEENDDATEPREV

      Columns [SPLITS] ([F:DCGSP]LVESUBTYP, [F:DCGSP]LVESUBBAL)
      For [SPLITS]
        If [DCGSP]LVESUBTYP = [TIM]LVESUBTYP(TKKK-1) and [DCGSP]LVESUBBAL > 0
          TAKN += [DCGSP]LVESUBBAL
        Endif
      Next
      Columns [SPLITS]

#      Filter [F:DCGC] Where [F:DCGC]REFNUM=[F:DCG]REFNUM & [F:DCGC]CTRNUM=[F:DCG]CTRNUM
#& &          [F:DCGC]TIM=[TIM]COD & [F:DCGC]UID>0
#& &          ([F:DCGC]STA=1|[F:DCGC]STA=2|[F:DCGC]STA=3|[F:DCGC]STA=5|[F:DCGC]STA=7)
#& &          ((([F:DCGC]STRDAT>=CYCLESTARTDATEPREV & [F:DCGC]STRDAT<[L]THISLEAVEDATE) | ([F:DCGC]ENDDAT>=CYCLESTARTDATEPREV & [F:DCGC]ENDDAT<[L]THISLEAVEDATE))
#& |          (CYCLESTARTDATEPREV>=[F:DCGC]STRDAT & CYCLESTARTDATEPREV<=[F:DCGC]ENDDAT) | (CYCLEENDDATEPREV>=[F:DCGC]STRDAT & CYCLEENDDATEPREV<=[F:DCGC]ENDDAT))
#&     Order By [F:DCGC]STRDAT
#      For TKN = 1 To dim([F:DCGC]LVESUBTYP)
#        For [F:DCGC]
#          If [F:DCGC]LVESUBTYP(TKN-1)=[TIM]LVESUBTYP(TKKK-1)
#            TAKN+=val(num$([F:DCGC]LVESUBBAL(TKN-1)))
#          Endif
#        Next
#      Next
    Endif

    TOT_TAKN+=TAKN
    TAKEN_LIST(N,1)=[TIM]LVESUBTYP(TKKK-1)
    TAKEN_LIST(N,2)=num$(TAKN)
    TAKN=0
    N=N+1

    If RF_GCURLEG <> "BRI"
      If [L]THISLEAVEDATE = CYCLESTARTDATEPREV ##Check if the current date being processed is the start of a new cycle, if that is the case, clear the taken for splits to work
        For TKN = 1 To dim(TAKEN_LIST)
          If TAKEN_LIST(TKN-1,1)=[TIM]LVESUBTYP(TKKK-1)
            TAKEN_LIST(TKN-1,2) = "0"
          Endif
        Next
        TOT_TAKN = 0
        Local Char FUTBALS(250)(0..,0..10)
        CRITHRLST="1=0 | ([F:HRCTR]CTRNUM = '"+[F:DCG]CTRNUM+"')"
      Elsif [L]THISLEAVEDATE > CYCLESTARTDATEPREV & CYCLE_RENEW=1
        For TKN = 1 To dim(OVER_TAKEN_LIST)
          If OVER_TAKEN_LIST(TKN-1,1)=[TIM]LVESUBTYP(TKKK-1)
#            TAKEN_LIST(TKN-1,2) = num$(OVER_TAKEN_LIST(TKN-1,2))#= num$(val(TAKEN_LIST(TKN-1,2)) + val(OVER_TAKEN_LIST(TKN-1,2)))
          Endif
        Next
      Endif
    Endif
  Filter [F:DCGC]
  Next
Return

$CHECK_MINUS_BALANCES
  Local Integer FRC_ERR
  Local Decimal TOTAL_REQUESTED
  Raz V_ERRMESSAGE
  Raz RF_GOK
  If dim([F:DCG]MSGAML)>0
    [F:DCG]MSGAML     = 11691
    [F:DCG]MSGAMLNUM  = 32
  Endif

  TOTAL_REQUESTED=TOT_TAKN+LVE_REM
  If TOTAL_REQUESTED>TOTZERO
    Local Char MSG(250): Local Integer MSG_POSITION: MSG = mess(27,11691,1):
    MSG_POSITION = instr(1, MSG, "{DATERANGE}") - 1
    If RF_IS_SOA
      V_ERRMESSAGE=left$(MSG, MSG_POSITION) - format$("DD2", [F:DCG]STRDAT) - " - " - format$("DD2", [F:DCG]ENDDAT) - right$(MSG, MSG_POSITION + 12)
      RF_GOK = 27
    Else
      GMESSAGE=left$(MSG, MSG_POSITION) - format$("DD2", [F:DCG]STRDAT) - " - " - format$("DD2", [F:DCG]ENDDAT) - right$(MSG, MSG_POSITION + 12)
      GERR=2
      RF_GOK = 27
    Endif
    If dim([F:DCG]MSGAML)>0
      [F:DCG]MSGAML     = 11691
      [F:DCG]MSGAMLNUM  = 27
    Endif
  Endif
  If TOTAL_REQUESTED>TOTZERO+ALLOW_AMT
    Local Char MSG(250): Local Integer MSG_POSITION: MSG = mess(29,11691,1):
    MSG_POSITION = instr(1, MSG, "{DATERANGE}") - 1
    If RF_IS_SOA
      V_ERRMESSAGE=left$(MSG, MSG_POSITION) - format$("DD2", [F:DCG]STRDAT) - " - " - format$("DD2", [F:DCG]ENDDAT) - right$(MSG, MSG_POSITION + 12)
      RF_GOK = 29
    Else
      GMESSAGE=left$(MSG, MSG_POSITION) - format$("DD2", [F:DCG]STRDAT) - " - " - format$("DD2", [F:DCG]ENDDAT) - right$(MSG, MSG_POSITION + 12)
      GERR=2
      RF_GOK = 29
    Endif
    If dim([F:DCG]MSGAML)>0
      [F:DCG]MSGAML     = 11691
      [F:DCG]MSGAMLNUM  = 29
    Endif
  Endif

  If TOTAL_REQUESTED>TOTALACCRU
    Local Char MSG(250): Local Integer MSG_POSITION: MSG = mess(26,11691,1):
    MSG_POSITION = instr(1, MSG, "{DATERANGE}") - 1
    If RF_IS_SOA
      V_ERRMESSAGE=left$(MSG, MSG_POSITION) - format$("DD2", [F:DCG]STRDAT) - " - " - format$("DD2", [F:DCG]ENDDAT) - right$(MSG, MSG_POSITION + 12)
      RF_GOK = 1
    Else
      GMESSAGE=left$(MSG, MSG_POSITION) - format$("DD2", [F:DCG]STRDAT) - " - " - format$("DD2", [F:DCG]ENDDAT) - right$(MSG, MSG_POSITION + 12)
      GOK=0
      GERR=1
      RF_GOK = 1
    Endif
  Endif
Return

$MAIN_PRIORITY_SPLITS
#check for priority and determin fractions
  For SS =1 To dim(ACCRUAL_LIST)
  If ACCRUAL_LIST(SS-1,1)="" : Break : Endif
    If LVE_REM>0 #and LVE_REM <= val(num$(Accrual_LiST(SS-1,2)))
      Gosub PRIORITY_SPLITS
    Elsif LVE_REM=0
      Gosub GET_DEF_NUM
      [F:DCG]LVESUBRAT(SS-1)=DEFPAYRATE
      [F:DCG]LVESUBTYP(SS-1)=ACCRUAL_LIST(SS-1,1)
      [F:DCG]LVESUBBAL(SS-1)+=LVE_REM
      If CYCLE_RENEW=1
        OVER_TAKEN_LIST(E,1)=ACCRUAL_LIST(SS-1,1)
        OVER_TAKEN_LIST(E,2)=num$(LVE_REM + val(OVER_TAKEN_LIST(E,2)))
        E=E+1
      Endif
    Endif
  Next

  Rewrite [F:DCG]
  If fstat
    V_ERRMESSAGE = "Error on rewrite"
    RF_GOK = 1
    Return
  Endif
Return

$PRIORITY_SPLITS
  Local Decimal SUBTYPE_BALANCE
  Local Char ZERO_TAKEN(5)
  If !clalev([F:HRLSTH2]) : Local File HRLVESUBHEA  [HRLSTH2] : Endif
  Read [HRLSTH2]HRLST1 = [TIM]LVESUBTYP(SS-1) #???

  If [F:HRLSTH2]CONSCALC=""
  Else
    CHECK_DCG=evalue([F:HRLSTH2]CONSCALC)
  Endif
  If CHECK_DCG=0 & [TIM]LVESUBTYP(SS-1) = 'PIW_N'
    ACCRUAL_LIST(0,2)="0"
    TAKEN_LIST(0,2)="0"
  Endif
    If CHECK_DCG=0 & [TIM]LVESUBTYP(SS-1) = 'SSP_N'
    ACCRUAL_LIST(3,2)="0"
    TAKEN_LIST(3,2)="0"
  Endif
  If CHECK_DCG=0 & [TIM]LVESUBTYP(SS-1) = 'SSP_W'
    ACCRUAL_LIST(1,2)="0"
    TAKEN_LIST(1,2)="0"
  Endif
  If CHECK_DCG=0 & [TIM]LVESUBTYP(SS-1) = 'SSP_E'
    ACCRUAL_LIST(2,2)="0"
    TAKEN_LIST(2,2)="0"
  Endif
  If CHECK_DCG=0 & [TIM]LVESUBTYP(SS-1) = 'SMP_H'
    ACCRUAL_LIST(0,2)="0"
    TAKEN_LIST(0,2)="0"
  Endif
  If CHECK_DCG=0 & [TIM]LVESUBTYP(SS-1) = 'SMP_S'
    ACCRUAL_LIST(1,2)="0"
    TAKEN_LIST(1,2)="0"
  Endif
  If CHECK_DCG=0 & [TIM]LVESUBTYP(SS-1) = 'SMP_N'
    ACCRUAL_LIST(2,2)="0"
    TAKEN_LIST(2,2)="0"
  Endif
  If CHECK_DCG=0 & [TIM]LVESUBTYP(SS-1) = 'SPP_E'
    ACCRUAL_LIST(0,2)="0"
    TAKEN_LIST(0,2)="0"
  Endif
  If CHECK_DCG=0 & [TIM]LVESUBTYP(SS-1) = 'SPP_N'
    ACCRUAL_LIST(1,2)="0"
    TAKEN_LIST(1,2)="0"
  Endif
  If [HRLSTH2]LVEFORFEIT=2
    ACCRUAL_LIST(SS-1,2)="0"
    TAKEN_LIST(SS-1,2)="0"
  Endif

  For SL =1 To dim(TAKEN_LIST)
    If TAKEN_LIST(SL-1,1)="" : ZERO_TAKEN=ACCRUAL_LIST(SS-1,1) : Endif
    If (TAKEN_LIST(SL-1,1)=ACCRUAL_LIST(SS-1,1) & LVE_REM<>0) | ((ZERO_TAKEN=ACCRUAL_LIST(SS-1,1)) & LVE_REM<>0)
    #check already taken vs requested
      SUBTYPE_BALANCE=val(num$(ACCRUAL_LIST(SS-1,2))) - val(num$(TAKEN_LIST(SL-1,2)))
      If TAKEN_LIST(SL-1,2)="" : SUBTYPE_BALANCE=val(num$(ACCRUAL_LIST(SS-1,2))) : Endif
        SUBTYPE_BALANCE = arr(SUBTYPE_BALANCE, 0.0001)
        If SUBTYPE_BALANCE > 0
          If LVE_REM<=SUBTYPE_BALANCE
            Gosub GET_DEF_NUM
            [F:DCG]LVESUBRAT(SS-1)=DEFPAYRATE
            [F:DCG]LVESUBTYP(SS-1)=ACCRUAL_LIST(SS-1,1)
            [F:DCG]LVESUBBAL(SS-1)+=LVE_REM
            If [L]LVE_REM > 0
              Local Decimal SPLITS_VALUE : [L]SPLITS_VALUE = [L]LVE_REM
              Gosub WRITE_TO_DEMSPLITS
            Endif
            If CYCLE_RENEW=1
              OVER_TAKEN_LIST(E,1)=ACCRUAL_LIST(SS-1,1)
              OVER_TAKEN_LIST(E,2)=num$(LVE_REM + val(OVER_TAKEN_LIST(E,2)))
              E=E+1
            Endif
            LVE_REM = 0
            SUBTYPE_BALANCE=0
#return to LST loop
            Break
          Endif
          If LVE_REM>SUBTYPE_BALANCE and LVE_REM<>0
            LVE_REM-=SUBTYPE_BALANCE
            Gosub GET_DEF_NUM
            [F:DCG]LVESUBRAT(SS-1)=DEFPAYRATE
            [F:DCG]LVESUBTYP(SS-1)=ACCRUAL_LIST(SS-1,1)
            [F:DCG]LVESUBBAL(SS-1)+=SUBTYPE_BALANCE
            If [L]SUBTYPE_BALANCE > 0
              Local Decimal SPLITS_VALUE : [L]SPLITS_VALUE = [L]SUBTYPE_BALANCE
              Gosub WRITE_TO_DEMSPLITS
            Endif
            If CYCLE_RENEW=1
              OVER_TAKEN_LIST(E,1)=ACCRUAL_LIST(SS-1,1)
              OVER_TAKEN_LIST(E,2)=num$(SUBTYPE_BALANCE + val(OVER_TAKEN_LIST(E,2)))
              E=E+1
            Endif
          Endif
#return to LST loop
          Break
        Endif
        If SUBTYPE_BALANCE=0
          Gosub GET_DEF_NUM
          [F:DCG]LVESUBRAT(SS-1)=DEFPAYRATE
          [F:DCG]LVESUBTYP(SS-1)=ACCRUAL_LIST(SS-1,1)
          [F:DCG]LVESUBBAL(SS-1)+=SUBTYPE_BALANCE
          If [L]SUBTYPE_BALANCE > 0
            Local Decimal SPLITS_VALUE : [L]SPLITS_VALUE = [L]SUBTYPE_BALANCE
            Gosub WRITE_TO_DEMSPLITS
          Endif
          #SAVAN 2017/11/30
          If CYCLE_RENEW=1
            OVER_TAKEN_LIST(E,1)=ACCRUAL_LIST(SS-1,1)
            OVER_TAKEN_LIST(E,2)=num$(SUBTYPE_BALANCE + val(OVER_TAKEN_LIST(E,2)))
            E=E+1
          Endif
        Endif
#return to LST loop
        Break
      Endif
    Next
Return

#PEVAN - X3-111790 - 2018-10-08 - START
$WRITE_TO_DEMSPLITS
  If !clalev([F:DCGSP]) : Local File DEMSPLITS [F:DCGSP] : Endif

  Raz [F:DCGSP]
  [F:DCGSP]DCGUID    = [F:DCG]UID
  [F:DCGSP]REFNUM    = [F:DCG]REFNUM
  [F:DCGSP]CTRNUM    = [F:DCG]CTRNUM
  [F:DCGSP]CTRDAT    = [F:DCG]CTRDAT
  [F:DCGSP]LVEDAT    = [L]THISLEAVEDATE
  [F:DCGSP]TIM       = [F:DCG]TIM
  [F:DCGSP]LVESUBBAL = [L]SPLITS_VALUE
  [F:DCGSP]LVESUBTYP = [F:DCG]LVESUBTYP(SS-1)
  [F:DCGSP]LVESUBRAT = [F:DCG]LVESUBRAT(SS-1)
  Write [F:DCGSP]

  Close File [F:DCGSP]
Return

Subprog UPDATE_DEMSPLITS_DCGUID(PREVIOUS_UID, NEW_UID)
Value Integer PREVIOUS_UID
Value Integer NEW_UID
  If !clalev([F:DCGSP]) : Local File DEMSPLITS [F:DCGSP] : Endif
  Update [F:DCGSP] Where [F:DCGSP]DCGUID = PREVIOUS_UID With [F:DCGSP]DCGUID = NEW_UID
  Close Local File [F:DCGSP]
End

Subprog DELETE_FROM_DEMSPLITS(DCGUID_TO_DELETE)
Value Integer DCGUID_TO_DELETE
  If !clalev([F:DCGSP]) : Local File DEMSPLITS [F:DCGSP] : Endif
  Delete [F:DCGSP] Where [F:DCGSP]DCGUID = DCGUID_TO_DELETE
  Close Local File [F:DCGSP]
End
#PEVAN - X3-111790 - 2018-10-08 - END

$GET_DEF_NUM
  DEFPAYRATE=0
  If clalev([HRLSTRAT]) = 0 : Local File HRLVESUBHEA [HRLSTRAT] : Endif

  Read [HRLSTRAT]HRLST0 = [TIM]LEG; ACCRUAL_LIST(SS-1,1)
  For PAY=1 To dim([HRLSTRAT]LVEPAYDEF)
    If [HRLSTRAT]LVEPAYDEF(PAY-1)=2
      DEFPAYRATE=PAY
    Endif
  Next
Return

Subprog DELETE_FUTURE_ACCRUALS(CTRNUMBER, CTRDATE, TRANSACTION_DATE, TIM, FA_IS_SOA,FA_GCURLEG)
Value Integer FA_IS_SOA
Value Char FA_GCURLEG
Value Char CTRNUMBER
Value Date CTRDATE
Value Date TRANSACTION_DATE
Value Char TIM
  Local Char CRITHRLST(250),GLMCYCLESTR(250)
  Local Char CRITHRTIM(250),CRITHRCTR(250)
  Local Char FUTBALS(250)(0..,0..10)
  Local Date DELETE_DATE,GLMCYCLE
  Local Integer LST
  Local Char VGCURLEG (GLONADI)
  VGCURLEG = FA_GCURLEG

  Local Date CTRXITDATE
  If clalev([F:HRCTRD]) = 0 : Local File EMPLOCTR [HRCTRD] : Endif
  Filter [HRCTRD] Where [HRCTRD]CTRNUM=CTRNUMBER and [HRCTRD]CTRDAT=CTRDATE
  Read [HRCTRD] First
  If !fstat
    CTRXITDATE = [HRCTRD]XITDAT
  Endif

  If !FA_IS_SOA
    GLMCYCLE = func SUBHRBAL.GET_GLM_CYCLE([F:HRCTRD]CTRNUM,[F:HRCTRD]CTRDAT)
  Else
    GLMCYCLESTR = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 5, VGCURLEG, "GLMCYCLE")
    Call CONVERT_TO_DATE(evalue(GLMCYCLESTR), GLMCYCLE) From SUBHRBAL
  Endif
  Local Char SUBTYPES(GLONHRLST)(0..,0..9)
  Local Date DELETE_STOP
  Call GET_LEAVE_SUB_TYPES(CTRNUMBER, TRANSACTION_DATE,TIM, SUBTYPES) From SUBHRBAL
  Call CONVERT_TO_DATE(SUBTYPES(0,5), DELETE_STOP) From SUBHRBAL
  If clalev([F:HRACCRDL])=0 : Local File HRLVEACCRU [HRACCRDL]  : Endif
  If clalev([TIMDEL]) = 0 : Local File TIMCOD [TIMDEL] : Endif
  If clalev([LSTDEL]) = 0 : Local File HRLVESUBHEA [LSTDEL] : Endif
  Filter [HRACCRDL]

  If VGCURLEG = "BRI" and ([TIM]COD="SSP" | [TIM]COD="SMP" | [TIM]COD="SPP")
    Read [TIMDEL]TIM0 = VGCURLEG;TIM
    For LST=1 To dim([TIMDEL]LVESUBTYP)
      Read [LSTDEL]HRLST0 = VGCURLEG;[TIMDEL]LVESUBTYP(LST-1)
      If [LSTDEL]LVEACCOPT=5
        If evalue([F:LSTDEL]CYCSTRCAL)<GLMCYCLE
          DELETE_DATE=GLMCYCLE
          Break
        Else
          DELETE_DATE=evalue([F:LSTDEL]CYCSTRCAL)
          Break
        Endif
      Else
        DELETE_DATE=TRANSACTION_DATE
      Endif
    Next
    Delete [F:HRACCRDL] Where [F:HRACCRDL]CTR = CTRNUMBER & [F:HRACCRDL]LVEACCTIM = TIM & [F:HRACCRDL]LVEACCDAT >= DELETE_DATE & ([L]CTRXITDATE=[0/0/0] | [F:HRACCRDL]LVEACCDAT <= [L]CTRXITDATE)
& & ([F:HRACCRDL]LVEACCTYP = "Accrual" | [F:HRACCRDL]LVEACCTYP = "Carry Over" | [F:HRACCRDL]LVEACCTYP = "Carry Over Excess")
  Else
    If DELETE_STOP<>[0/0/0]
      Delete [F:HRACCRDL] Where [F:HRACCRDL]CTR = CTRNUMBER & [F:HRACCRDL]LVEACCTIM = TIM
&       & (([F:HRACCRDL]LVEACCTYP = "Accrual" and [F:HRACCRDL]ACCPERSTR >= TRANSACTION_DATE and [F:HRACCRDL]ACCPERSTR<=DELETE_STOP)
&       | (([F:HRACCRDL]LVEACCTYP = "Carry Over" | [F:HRACCRDL]LVEACCTYP = "Carry Over Excess") and [F:HRACCRDL]LVEACCDAT >= TRANSACTION_DATE and [F:HRACCRDL]LVEACCDAT<=DELETE_STOP))
&       & ([L]CTRXITDATE=[0/0/0] | [F:HRACCRDL]ACCCYCSTR <= [L]CTRXITDATE)
    Else
      Delete [F:HRACCRDL] Where [F:HRACCRDL]CTR = CTRNUMBER & [F:HRACCRDL]LVEACCTIM = TIM
&       & (([F:HRACCRDL]LVEACCTYP = "Accrual" and [F:HRACCRDL]ACCPERSTR >= TRANSACTION_DATE)
&       | (([F:HRACCRDL]LVEACCTYP = "Carry Over" | [F:HRACCRDL]LVEACCTYP = "Carry Over Excess") and [F:HRACCRDL]LVEACCDAT >= TRANSACTION_DATE))
&       & ([L]CTRXITDATE=[0/0/0] | [F:HRACCRDL]ACCCYCSTR <= [L]CTRXITDATE) & ([F:HRACCRDL]LVEACCTYP = "Accrual" | [F:HRACCRDL]LVEACCTYP = "Carry Over" | [F:HRACCRDL]LVEACCTYP = "Carry Over Excess")
    Endif
  Endif
End


$CYCLE_CHECK_DCG
  Local Integer R,J
  Local Float CYCLEN
  Local Date CYCARR(0..999,0..10)

  If RF_IS_SOA
  Else
    If GFONCTION<>"GESDCG" and GFONCTION <> "SAIWRKMAN"
      Local Date CYCSTRDAT
    Endif
  Endif

  If clalev([F:HRPEODCC])=0 : Local File HRPEODET [HRPEODCC] : Endif
  R=0
  If VARDAT = [0/0/0]
    VARDAT=GLMCYCLE
  Endif

  If clalev([F:ACCRU]) = 0 : Local File HRLVEACCRU [ACCRU] : Endif
  If clalev([F:HRLSTHXD]) = 0 : Local File HRLVESUBHEA [HRLSTHXD] : Endif

  Read [HRLSTHXD]HRLST0 = GCURLEG; [HRLSTHBA]COD
  CHECKD=[DCG]ENDDAT

  If CYCSTRDAT=[0/0/0]
    CYCSTRDAT=VARDAT
  Endif
    CYCLEN = [F:HRLSTHXD]CYCLEN
    LENOPT = [F:HRLSTHXD]CYCLENU
  If ([TIM]COD="SSP" | [TIM]COD="SMP" | [TIM]COD="SPP")
    Filter [HRPEODCC] Where [HRPEODCC]PERCOD=[F:HRCTR]PERCOD & ([F:HRPEODCC]PEREND(1)>=CYCSTRDAT & [F:HRPEODCC]PEREND(1)<=addmonth(VARDAT,6))
  Else
    Filter [HRPEODCC] Where [HRPEODCC]PERCOD=[F:HRCTR]PERCOD & [F:HRPEODCC]PEREND(1)>=CYCSTRDAT
  Endif
  For [HRPEODCC]
    If [F:HRPEODCC]PERSTR(1)>=CYCSTRDAT #& [F:HRPEODCC]PEREND(1)>=CYCSTRDAT
      CYCARR(R,1)=CYCSTRDAT
      If LENOPT= 1
        CYCSTRDAT=addmonth(CYCSTRDAT,CYCLEN*12)
      Else
        CYCSTRDAT=addmonth(CYCSTRDAT,CYCLEN)
      Endif
      CYCARR(R,2)=CYCSTRDAT
      R+=1
    Endif
  Next
  Filter [HRPEODCC]
Return

#**
#* Function to determine if a particular start date will be consecutive with an existing absence for the employee/contract
#*  e.g. There is in existing absence of the same type that ends the day before ABSENCE_START_DATE
#* @param EMPLOYEE Employee reference to use for checking
#* @param CONTRACT Contract number to use for checking
#* @param CONTRACT_DATE Contract start date
#* @param ABSENCE_TYPE Absence type (nature of event)
#* @param ABSENCE_START_DATE Start date to check if consecutive to existing absence
#* @return If the absence start date will be consecutive then exists absence UID is returned, otherwise 0
#*!
Funprog IS_CONSECUTIVE_ABSENCE(EMPLOYEE, CONTRACT,ABSENCE_TYPE, ABSENCE_START_DATE,ABSENCE_END_DATE)
Value Char EMPLOYEE, CONTRACT, ABSENCE_TYPE
Value Date ABSENCE_START_DATE,ABSENCE_END_DATE
  Local Integer RETVAL : [L]RETVAL = 0
  If clalev([DCG_CONC]) = 0 : Local File DEMCONGE [DCG_CONC]    : Endif
  Filter [DCG_CONC] Where [DCG_CONC]REFNUM=[L]EMPLOYEE and [DCG_CONC]CTRNUM=[L]CONTRACT
&                   and [DCG_CONC]TIM=ABSENCE_TYPE and [DCG_CONC]ENDDAT = ABSENCE_START_DATE - 1 and [DCG_CONC]STA=3
  Read [F:DCG_CONC]DCG4 Last
  If !fstat
    [L]RETVAL = [DCG_CONC]UID
  Endif
  Filter [DCG_CONC]
  If [L]RETVAL=0
    Filter [DCG_CONC] Where [DCG_CONC]REFNUM=[L]EMPLOYEE and [DCG_CONC]CTRNUM=[L]CONTRACT
&                     and [DCG_CONC]TIM=ABSENCE_TYPE and [DCG_CONC]STRDAT = ABSENCE_END_DATE + 1 and [DCG_CONC]STA=3
    Read [F:DCG_CONC]DCG4 Last
    If !fstat
      [L]RETVAL = [DCG_CONC]UID
    Endif
  Endif
End [L]RETVAL

#**
#* Update the link workflow records to the new UID created
#* @param VUID Value integer, Value containing the *new* unique ID for a leave transaction
#* @param VUID_PREV Value integer, Value containing the *previous* unique ID for a leave transaction
#* @return fstat Local integer - [V]CST_AOK - 0
#*!
Funprog UPDATE_WORKFLOW_CLEARFUTURE(VUID,VUID_PREV)
Value Integer VUID,VUID_PREV
  Local Integer UPDATE_STAT
  Local File AWRKHISSUI [AWS2]

  [L]UPDATE_STAT = [V]CST_AOK
  Update [AWS2] Where VALCTX4 = num$(VUID_PREV) With VALCTX4 = num$(VUID)
End fstat

#**
#* Populate the information/message on GLM leave records
#* @param AMLNUM Value Integer, Integer containing the value of the local menu number
#* @param AMLNUMMSG Value Integer, Integer containing the value of the local menu number message
#* @param STRDAT Value Date, *Additional Parameter: Date containing the start date of the transaction
#* @param ENDDAT Value Date, *Additional Parameter: Date containing the end date of the transaction
#* @return RETMSG Local Char(250) - Return the message using the parameters passed
#*!
Funprog POP_DCGGLM_INFOMSG(AMLNUM,AMLNUMMSG,STRDAT,ENDDAT)
Value Integer AMLNUM,AMLNUMMSG
Value Date STRDAT,ENDDAT
  Local Integer MSG_POSITION
  Local Char RETMSG(250)
  Local Char MSG(250)

  If AMLNUM = 11691 #GLM messages
    Case AMLNUMMSG
      When 27 : RETMSG = func SUBDCGGLM.BUILD_DCGGLM_INFOMSG(AMLNUM,AMLNUMMSG,12,STRDAT,ENDDAT)
      When 29 : RETMSG = func SUBDCGGLM.BUILD_DCGGLM_INFOMSG(AMLNUM,AMLNUMMSG,12,STRDAT,ENDDAT)
      When Default : RETMSG = mess(AMLNUMMSG,AMLNUM,1)
    Endcase
  Else
    RETMSG = mess(AMLNUMMSG,AMLNUM,1)
  Endif

End RETMSG

#**
#* Build the information/message on GLM leave records for some 11691 message only!
#* @param AMLNUM Value Integer, Integer containing the value of the local menu number
#* @param AMLNUMMSG Value Integer, Integer containing the value of the local menu number message
#* @param BADDCHAR Value Integer, Integer containing the value of additional character read on right$ function
#* @param VSTRDAT Value Date, *Additional Parameter: Date containing the start date of the transaction
#* @param VENDDAT Value Date, *Additional Parameter: Date containing the end date of the transaction
#* @return FRETMSG Local Char(250) - Return the message using the parameters passed
#*!
Funprog BUILD_DCGGLM_INFOMSG(BAMLNUM,BAMLNUMMSG,BADDCHAR,VSTRDAT,VENDDAT)
Value Integer BAMLNUM,BAMLNUMMSG,BADDCHAR
Value Date VSTRDAT,VENDDAT
  Local Char FMSG(250)
  Local Integer FMSG_POSITION
  Local Char FRETMSG(250)

  FMSG = mess(BAMLNUMMSG,BAMLNUM,1)
  FMSG_POSITION = instr(1, FMSG, "{DATERANGE}") - 1
  FRETMSG=left$(FMSG, FMSG_POSITION) - format$("DD2", VSTRDAT) - " - " - format$("DD2", VENDDAT) - right$(FMSG, FMSG_POSITION + BADDCHAR)
End FRETMSG

Funprog CHECK_TIG(PREFNUM,PSTRDAT,PENDDAT,PCTRNUM)
Value Char PREFNUM,PCTRNUM
Value Date PSTRDAT,PENDDAT
  Local Integer RET_FUN

  If GTPS=1
    For [TIG]TIG1 Where REFNUM=PREFNUM & STRDAT<=PENDDAT & ENDDAT>=PSTRDAT
      If clalev([F:DCGCONTD])=0 : Local File DEMCONGE [DCGCONTD] : Endif
      Local Integer CONTDCHK
      CONTDCHK=0
#CHeck for the [TIG]DCGUID that exists where it is cancelled accepted and not to be included in the checks
      Filter [F:DCGCONTD] Where [F:TIG]DCGUID=[F:DCGCONTD]LNK & [F:DCGCONTD]STA=6
      Read [F:DCGCONTD] First
      If !fstat
        CONTDCHK=1
      Endif
      Filter [F:DCGCONTD]
      If find(PCTRNUM,"",[F:TIG]CTRNUM)
&     & ( [F:TIG]STRDAT<PENDDAT & CONTDCHK<>1 | ([F:TIG]STRDAT=PENDDAT & ([F:TIG]ENDDAY<2 | [L]L_I<2) & CONTDCHK<>1))
&     & ( [F:TIG]ENDDAT>PSTRDAT & CONTDCHK<>1 | ([F:TIG]ENDDAT=PSTRDAT & ([F:TIG]STRDAY<2 | [L]L_J<2) & CONTDCHK<>1))
        [V]GMESSAGE =format$([V]GFMD,[F:TIG]STRDAT)
&                   - string$([F:TIG]STRDAT<>[F:TIG]ENDDAT,"->"-format$([V]GFMD,[F:TIG]ENDDAT))
&                   - ":"-func AFNC.MES1(mess(170,10709,1),[F:TIG]TIM)
        RET_FUN = 1
        Break
      Endif
    Next
    If mkstat : End : Endif
  Endif
End RET_FUN

Funprog UPDATE_WORKFLOW_UID(LNKUID,NEWUID)
Value Integer LNKUID,NEWUID
  Local Integer RET_VAL
  Local File AWRKHISSUI [AWS3]

  Update [F:AWS3] Where VALCTX4 = num$(LNKUID) With VALCTX4 = num$(NEWUID)
  If fstat : RET_VAL = 1 : Endif
End RET_VAL

#**
#* Check if the leave date entered does not overlap over multiple contracts with the same chrono (CTRNUM)
#* @param VSTRDAT Value Date, Date containing the leave start date
#* @param VENDDAT Value Date, Date containing the leave end date
#* @param VREFNUM Value Char(GLONEML), Char containing the employee code
#* @param VCTRNUM Value Char(GLONHRCTR), Char containing the contract number used in the leave transaction
#* @return RETVAK Local Integer - Returns 1+ if multiple contracts where found, 0 if only one found or if the dates are incomplete [0/0/0]
#*!
Funprog CHECK_MULTIPLE_CTR_CHRONO(VSTRDAT,VENDDAT,VREFNUM,VCTRNUM)
Value Date VSTRDAT,VENDDAT
Value Char VREFNUM,VCTRNUM
  Local Integer RETVAL

  If VSTRDAT = [0/0/0] or VENDDAT = [0/0/0] or VREFNUM = "" or VCTRNUM = ""
    End RETVAL
  Endif

  Local File EMPLOCTR [HRCTR5]
  Filter [F:HRCTR5] Where REFNUM=VREFNUM & CTRNUM=VCTRNUM & ((CTRDAT>=VSTRDAT & CTRDAT<=VENDDAT)|(CTRDAT<=VSTRDAT & (XITDAT>=VSTRDAT|XITDAT=[0/0/0])))

  If rowcount([F:HRCTR5])>1 #Multiple records found with the same Chrono
    RETVAL = 1
  Endif
  Filter [F:HRCTR5]

End RETVAL

#**
#* Check if leave is captured for an old contract
#* @param VSTRDAT Value Date, Date containing the leave start date
#* @param VENDDAT Value Date, Date containing the leave end date
#* @param VREFNUM Value Char(GLONEML), Char containing the employee code
#* @param VCTRNUM Value Char(GLONHRCTR), Char containing the contract number used in the leave transaction
#* @param VCTROLD Value Char(GLONHRCTR)(1..), Char containing the contract number for old contracts
#* @param VDTROLD Value Date()(1..), Date containing the contract date for old contracts
#* @return RETVAK Local Integer - Returns 1+ if multiple contracts where found, 0 if only one found or if the dates are incomplete [0/0/0]
#*!
Funprog CHECK_XITCTR(VSTRDAT,VENDDAT,VREFNUM,VCTRNUM,VCTROLD,VDTROLD)
Value Date VSTRDAT,VENDDAT
Variable Char VCTROLD()(1..)
Variable Date VDTROLD(1..)
Value Char VREFNUM,VCTRNUM
  Local Integer RETVAL, I

  If VSTRDAT = [0/0/0] or VENDDAT = [0/0/0] or VREFNUM = "" or VCTRNUM = ""
    End RETVAL
  Endif

  Local File EMPLOCTR [HRCTR6]
  Filter [F:HRCTR6] Where REFNUM=VREFNUM & ((CTRDAT>=VSTRDAT & CTRDAT<=VENDDAT)|(CTRDAT<=VSTRDAT & (XITDAT>=VSTRDAT|XITDAT=[0/0/0])))

  For [F:HRCTR6]CTR0 Where XITDAT <> [0/0/0]
    I+=1
    RETVAL = 1
    VCTROLD(I) = [F:HRCTR6]CTRNUM
    VDTROLD(I) = [F:HRCTR6]CTRDAT
  Next
  Filter [F:HRCTR6]
End RETVAL

