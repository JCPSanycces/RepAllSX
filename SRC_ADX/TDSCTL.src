#<AdxTL>@(#)12.0.0.0 $Revision$
# LS Contrôle TDS Janvier 1999
# Pas de contrôle pour les anomalies référencées par TDS en gravité niveau 0

Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TDSCTL","DTDSCTL",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE 
Endcase
Return

$OUVRE
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
Return

$INIT_DIA
TMP = 1 : TRA = 1
Return

$EXEC
Call TDSCTL
Return

Subprog TDSCTL
Local Integer OK
Local Char TIT(50)
Gosub OUVRE 
TIT = mess(18,122,1) : # Contrôle TDS
GOK = 1
Call CONTLTDS
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
End

Subprog CONTLTDS
Local Integer I, POSNIC
Local Char    TIT(50), MSG(80), CRITERE(250)
Gosub OUVRE2
TIT = mess(18,122,1) : # Contrôle TDS
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif  
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(104,"-"),0) From GESECRAN 
POSNIC = 10
Gosub CTL_DRAP
If [M]ALLCPY=1
 For I=0 To [M]NBLIG-1
  Read [DCP]DCP0=[M]CPY(I)
  Gosub CTL_CPY

  # Point d'entrée FILTRE
  Raz [L]CRITERE
  GPOINT = "FILTRE" : Gosub ENTREE From EXEFNC
  If [L]CRITERE="" : [L]CRITERE="1=1" : Endif

  Filter [FCY] Where DADFLG=2 & LEGCPY=[M]CPY(I) & evalue(CRITERE)
  For [FCY]
   Read [DFC]DFC0=[F:FCY]FCY
   If !fstat : Gosub CTL_FCY
   Else 
    MSG = [F:FCY]FCY-":"-mess(50,122,1) : # Informations DAS2 non renseignées
    Gosub ERREUR
   Endif
  Next
  Filter [FCY]
  Filter [HLN] Where CPY=[M]CPY(I) & year(DAT)=[M]YEA & evalue(CRITERE)
  Gosub CTL_HLN
  Filter [HLN]
 Next I
Elsif [M]ALLCPY=2
 For [DCP]
  Gosub CTL_CPY

  # Point d'entrée FILTRE
  Raz [L]CRITERE
  GPOINT = "FILTRE" : Gosub ENTREE From EXEFNC
  If [L]CRITERE="" : [L]CRITERE="1=1" : Endif

  Filter [FCY] Where DADFLG=2 & LEGCPY=[F:DCP]CPY & evalue(CRITERE)
  For [FCY]
   Read [DFC]DFC0=[F:FCY]FCY
   If !fstat : Gosub CTL_FCY
   Else 
    MSG = [F:FCY]FCY-":"-mess(50,122,1) : # Informations DAS2 non renseignées
    Gosub ERREUR
   Endif
  Next
  Filter [FCY]
  Filter [HLN] Where CPY=[F:DCP]CPY & year(DAT)=[M]YEA & evalue(CRITERE)
  Gosub CTL_HLN
  Filter [HLN]
 Next
Endif
End

$CTL_DRAP
Read[FCY]FCY0=[M:DIA]SENFCY
If vireblc([F:FCY]CRN,2)=""
 MSG = mess(19,122,1) : # Numéro SIRET émetteur non renseigné
 Gosub ERREUR
Elsif sigma(1,len([F:FCY]CRN),pat(mid$([F:FCY]CRN,indcum,1),"#")=0)>0
 MSG = mess(20,122,1) : # Numéro SIRET émetteur non numérique
 Gosub ERREUR
Else
 Read [TCY]TCY0=[F:FCY]CRY
 If !fstat & [F:TCY]CTLPRG<>""
  Call CONTSIRET ([F:FCY]CRN,[F:FCY]CRY,"") From CONTNUM
  If mkstat = 2
   MSG = GMESSAGE
   Gosub ERREUR
  Endif
 Endif
Endif
Return

$CTL_CPY
# ENTREPRISE
If vireblc([F:DCP]DADCRN,2)=""
 MSG = [F:DCP]CPY-":"-mess(21,122,1) : # Numéro SIREN de l'entreprise non renseigné
 Gosub ERREUR
Elsif sigma(1,len([F:DCP]DADCRN),pat(mid$([F:DCP]DADCRN,indcum,1),"#")=0)>0
 MSG = [F:DCP]CPY-":"-mess(22,122,1) : # Numéro SIREN de l'entreprise non numérique
 Gosub ERREUR
Else
 Read [CPY]CPY0=[F:DCP]CPY
 Read [TCY]TCY0=[F:CPY]CRY
 If !fstat & [F:TCY]CTLPRG<>""
  Call CONTSIRET ([F:DCP]DADCRN,[F:CPY]CRY,"") From CONTNUM
  If mkstat = 2
   MSG = [F:DCP]CPY-":"-GMESSAGE
   Gosub ERREUR
  Endif
 Endif
Endif

If vireblc([F:DCP]DADCPYNAM,2)=""
 MSG = [F:DCP]CPY-":"-mess(23,122,1) : # Nom ou raison sociale de l'entreprise non renseigné
 Gosub ERREUR
Endif

# SIEGE DE L'ENTREPRISE
Read [CPY]CPY0=[F:DCP]CPY
If !fstat 
 If [F:CPY]MAIFCY=""
  # Site principal(siège) de l'entreprise inexistant
  MSG = [F:DCP]CPY-":"-mess(25,122,1)
  Gosub ERREUR
 Else
  Read[FCY]FCY0=[F:CPY]MAIFCY
  If vireblc([F:FCY]CRN,2)=""
   # Siège de l'entreprise : Numéro SIRET non renseigné
   MSG = [F:FCY]FCY-":"-mess(26,122,1) 
   Gosub ERREUR
  Elsif sigma(1,len([F:FCY]CRN),pat(mid$([F:FCY]CRN,indcum,1),"#")=0)>0
   # Siège de l'entreprise : Numéro SIRET non numérique
   MSG = [F:FCY]FCY-":"-mess(27,122,1)
   Gosub ERREUR
  Elsif mid$([F:FCY]CRN,1,9)<>mid$([F:DCP]DADCRN,1,9)
   # SIRET du siège de l'entreprise différent du SIREN de l'entreprise
   MSG = [F:FCY]FCY-":"-mess(28,122,1)
   Gosub ERREUR
  Elsif val(right$([F:FCY]CRN,POSNIC))=0
   # NIC du siège de l'entreprise non renseigné
   MSG = [F:FCY]FCY-":"-mess(29,122,1)
   Gosub ERREUR
  Else
   Read [TCY]TCY0=[F:FCY]CRY
   If !fstat & [F:TCY]CTLPRG<>""
    Call CONTSIRET ([F:FCY]CRN,[F:FCY]CRY,"") From CONTNUM
    If mkstat = 2
     MSG = [F:FCY]FCY-":"-GMESSAGE
     Gosub ERREUR
    Endif
   Endif
  Endif
 Endif
Endif

If vireblc(left$([F:DCP]DADPOSCOD,2),2)="" | vireblc(left$([F:DCP]DADPOSCOD,2),2)="0"
&                                          | vireblc(left$([F:DCP]DADPOSCOD,2),2)="00"
 # Les 2 premiers caractères du code postal sont non renseignés
 MSG = [F:DCP]CPY-":"-mess(30,122,1)
 Gosub ERREUR
Elsif sigma(1,len([F:DCP]DADPOSCOD),pat(mid$([F:DCP]DADPOSCOD,indcum,1),"#")=0)>0
 MSG = [F:DCP]CPY-":"-mess(31,122,1) : # Code postal non numérique
 Gosub ERREUR
Endif

If vireblc([F:DCP]CTYNAM+[F:DCP]POSCTY,2)=""
 MSG = [F:DCP]CPY-":"-mess(32,122,1) : # Commune et bureau distributeur non renseignés
 Gosub ERREUR
Endif

# ETABLISSEMENT DEPOSANT LES RESULTATS
If vireblc([F:DCP]DADCRN2,2)=""
 MSG = [F:DCP]CPY-":"-mess(33,122,1) : # Etab. résultat : Numéro SIRET non renseigné
 Gosub ERREUR
Elsif sigma(1,len([F:DCP]DADCRN2),pat(mid$([F:DCP]DADCRN2,indcum,1),"#")=0)>0
 MSG = [F:DCP]CPY-":"-mess(34,122,1) : # Etab. résultat : Numéro SIRET non numérique
 Gosub ERREUR
Elsif mid$([F:DCP]DADCRN2,1,9)<>mid$([F:DCP]DADCRN,1,9)
 # SIRET de l'étab résultat différent du SIREN de l'entreprise
 MSG = [F:DCP]CPY-":"-mess(35,122,1)
 Gosub ERREUR
Elsif val(right$([F:DCP]DADCRN2,POSNIC))=0
 # Etab. résultat : NIC non renseigné
 MSG = [F:DCP]CPY-":"-mess(36,122,1)
 Gosub ERREUR
Else
 Read [TCY]TCY0=[F:CPY]CRY
 If !fstat & [F:TCY]CTLPRG<>""
  Call CONTSIRET ([F:DCP]DADCRN2,[F:CPY]CRY,"") From CONTNUM
  If mkstat = 2
   MSG = [F:DCP]CPY-":"-GMESSAGE
   Gosub ERREUR
  Endif
 Endif
Endif

If vireblc(left$([F:DCP]DADPOSCOD2,2),2)="" | vireblc(left$([F:DCP]DADPOSCOD2,2),2)="0"
&                                          | vireblc(left$([F:DCP]DADPOSCOD2,2),2)="00"
 # Etab. résultat : les 2 premiers caractères du code postal sont non renseignés
 MSG = [F:DCP]CPY-":"-mess(37,122,1)
 Gosub ERREUR
Elsif sigma(1,len([F:DCP]DADPOSCOD2),pat(mid$([F:DCP]DADPOSCOD2,indcum,1),"#")=0)>0
 MSG = [F:DCP]CPY-":"-mess(38,122,1) : # Etab. résultat : Code postal non numérique
 Gosub ERREUR
Endif

If vireblc([F:DCP]CTYNAM2+[F:DCP]POSCTY2,2)=""
 # Etab. résultat : Commune et bureau distributeur non renseignés
 MSG = [F:DCP]CPY-":"-mess(39,122,1)
 Gosub ERREUR
Endif
Return

$CTL_FCY
If !find([F:DFC]NBDAS,1,2)
 # Nombre de DADS fourni par l'établissement non renseigné
 MSG = [F:DFC]FCY-":"-mess(40,122,1) 
 Gosub ERREUR
Endif
If vireblc([F:DFC]DADCRN,2)=""
 MSG = [F:DFC]FCY-":"-mess(41,122,1) : # Numéro SIRET de l'établissement non renseigné
 Gosub ERREUR
Elsif sigma(1,len([F:DFC]DADCRN),pat(mid$([F:DFC]DADCRN,indcum,1),"#")=0)>0
 MSG = [F:DFC]FCY-":"-mess(42,122,1) : # Numéro SIRET de l'établissement non numérique
 Gosub ERREUR
Elsif mid$([F:DFC]DADCRN,1,9)<>mid$([F:DCP]DADCRN,1,9)
 # SIRET de l'établissement différent du SIREN de l'entreprise
 MSG = [F:DFC]FCY-":"-mess(43,122,1)
 Gosub ERREUR
Elsif val(right$([F:DFC]DADCRN,POSNIC))=0
 MSG = [F:DFC]FCY-":"-mess(44,122,1) : # NIC de l'établissement non renseigné
 Gosub ERREUR
Elsif sigma(1,5,pat(mid$(right$([F:DFC]DADCRN,POSNIC),indcum,1),"#")=0)>0
 MSG = [F:DFC]FCY-":"-mess(45,122,1) : # NIC de l'établissement non numérique
 Gosub ERREUR
Else
 Read [FCY]FCY0=[F:DFC]FCY
 Read [TCY]TCY0=[F:FCY]CRY
 If !fstat & [F:TCY]CTLPRG<>""
  Call CONTSIRET ([F:DFC]DADCRN,[F:CPY]CRY,"") From CONTNUM
  If mkstat = 2
   MSG = [F:DFC]FCY-":"-GMESSAGE
   Gosub ERREUR
  Endif
 Endif
Endif

If vireblc([F:DFC]DADFCYNAM,2)=""
 # Nom ou raison sociale de l'établissement non renseigné
 MSG = [F:DFC]FCY-":"-mess(46,122,1)
 Gosub ERREUR
Endif

If vireblc(left$([F:DFC]DADPOSCOD,2),2)="" | vireblc(left$([F:DFC]DADPOSCOD,2),2)="0"
&                                          | vireblc(left$([F:DFC]DADPOSCOD,2),2)="00"
 # Les 2 premiers caractères du code postal de l'établissement sont non renseignés
 MSG = [F:DFC]FCY-":"-mess(47,122,1)
 Gosub ERREUR
Elsif sigma(1,len([F:DFC]DADPOSCOD),pat(mid$([F:DFC]DADPOSCOD,indcum,1),"#")=0)>0
 MSG = [F:DFC]FCY-":"-mess(48,122,1) : # Code postal de l'établissement non numérique
 Gosub ERREUR
Endif

If vireblc([F:DFC]CTYNAM+[F:DFC]POSCTY,2)=""
 # Commune et bureau distributeur de l'établissement non renseignés
 MSG = [F:DFC]FCY-":"-mess(49,122,1)
 Gosub ERREUR
Endif
Return

$CTL_HLN
For [HLN]HLN0
 Read [PRV]PRV0=[F:HLN]PRVNUM
 If fstat
  MSG = [F:HLN]PRVNUM-":"-mess(5,122,1) : # Prestataire inexistant
  Gosub ERREUR
 Elsif vireblc([F:PRV]SURNAM+[F:PRV]PRVNAM,2)="" | 
& vireblc([F:PRV]SURNAM+[F:PRV]PRVNAM,2)=string$(len([F:PRV]SURNAM+[F:PRV]PRVNAM),"X")
  MSG = [F:HLN]PRVNUM-":"-mess(51,122,1) : # Bénéficiaire non renseigné
  Gosub ERREUR
# Elsif  vireblc([F:PRV]FIRNAM,2)=""
#  MSG = [F:HLN]PRVNUM-":"-mess(52,122,1) : # Prénom du bénéficiaire non renseigné
#  Gosub ERREUR
 Elsif vireblc([F:PRV]CTYNAM+[F:PRV]POSCTY,2)=""
  MSG = [F:HLN]PRVNUM-":"-mess(53,122,1)
  # Commune et bureau distributeur non renseignés
  Gosub ERREUR
 Elsif sigma(1,len([F:PRV]POSCOD),pat(mid$([F:PRV]POSCOD,indcum,1),"#")=0)>0
  MSG = [F:HLN]PRVNUM-":"-mess(31,122,1) : # Code postal non numérique
  Gosub ERREUR
 Endif
 If find([F:HLN]HON,9,10,11)
  Call VERIF_TYPHON([F:HLN]HON,[F:HLN]TYPHON,MSG) 
 Endif
Next
Return

$ERREUR
Call ECR_TRACE(MSG,1) From GESECRAN
GOK = 0
Return

$OUVRE2
Local File TABCOUNTRY[TCY], FACILITY[FCY], DADCPY[DCP], COMPANY[CPY], DADFCY[DFC],
&          HONLIN[HLN],HONPRV[PRV]
Return

Subprog VERIF_TYPHON(NAT,TYPNAT,MSG)
Value    Integer  NAT
Value    Char     TYPNAT()
Variable Char     MSG()
Local    Integer  OK, I
Local    Char     CHAINE(5)
OK = 1
Case NAT
 When 9  : MSG = [F:HLN]PRVNUM-":"-mess(55,122,1)
           # Modalité de prise en charge : Hors plage de valeurs
           CHAINE = "FRP"
 When 10 : MSG = [F:HLN]PRVNUM-":"-mess(54,122,1)-TYPNAT
           # Nature des avantages en nature : Hors plage de valeurs
           CHAINE = "NLVA"
 When 11 : MSG = [F:HLN]PRVNUM-":"-mess(56,122,1)
           # Taux de retenue à la source : Hors plage de valeurs
           CHAINE = "RD"
Endcase
For I=1 To len(TYPNAT)
 If find(mid$(TYPNAT,I,1)," ",mid$(CHAINE,I,1))=0
  OK = 0
  Break
 Endif
Next
If !OK : Gosub ERREUR : Endif
End


