#<AdxTL>@(#)8.0.0.0 $Revision$
# Re-open a fiscal year

# CBO 2017.10.11 X3-57738 pb when no selected ledger

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTOPNFIY","FOPNFIY",4,"") From GTRAITE
End

#######################################################
## Traitement des actions
#######################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "AVANT_OK"    : Gosub AVANT_OK
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 : GOK = 0
 When "CONTROLE"    : Gosub CONTROLE
 When "SORTIE"      : Gosub SORTIE
 When "EXEC"        : Gosub EXEC
Endcase
Return

$OUVRE
Local Char    TIT(50)             : # Titre de la fonction
Local Char    SYMBOLE(80)
Gosub OUVFIC
Local Mask OPNFIY [DIA]
Raz [M:DIA]
TIT = mess(104,107,1) : # Ré-ouverture d'exercice
Local Integer OK_LEDGER_SEL # X3-57738
Return

$AVANT_OK

  OK=0
  OK_LEDGER_SEL = 0 # Issue X3-57738
  For I=0 To [M]NBLIG
    If [M]FIY(I)<>0
      OK = 1
  #  Break
    Endif
    If [M]OPNFIY(I)=2
      OK_LEDGER_SEL = 1
    Endif
  Next I
  If !OK
    GMESSAGE=mess(60,101,1) : # Il n'y a aucun exercice à ré-ouvrir
    FOK=0
    GERR=1
    GOK = 0
    Return
  Endif
  If OK_LEDGER_SEL = 0
    GMESSAGE = mess(8, 2035, 1) : # Il n'y a aucun LEDGER sélectionné
    FOK=0
    GERR=1
    GOK = 0
    OK = 0
  Endif
  # End Issue X3-57738

Return

$OUVFIC

  If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif : # Société
  If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif : # Modèle comptable
  If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif : # Exercices
  If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif : # Comptes

  If clalev([F:HAE])=0  : Local File GACCENTRY  [HAE]  : Endif : # Entete pièce
  If clalev([F:DAE])=0  : Local File GACCENTRYD [DAE]  : Endif : # Ligne pièce
  If clalev([F:DAA])=0  : Local File GACCENTRYA [DAA]  : Endif : # Ligne analytique
  If clalev([F:HAT])=0  : Local File GACCTMP    [HAT]  : Endif : # Table tempo pièce
  If clalev([F:GTE])=0  : Local File GTYPACCENT [GTE]  : Endif : # Type de pièces
  If clalev([F:GT2])=0  : Local File GTYPACCENT [GT2]  : Endif : # Type de pièces
  If clalev([F:ACV])=0  : Local File ACTIV      [ACV]  : Endif : # Codes activité

Return

$CONTROLE

  If GOK<1
    FIN = 1
    Return
  Endif

  TMP = 1
  TRA = 1

Local Integer OK

  Call LOCKCPY([M:DIA]CPY, OK) From AX3MONO
  If !OK : FIN=1 : Return : Endif
  OK=2
  #### Point d'entrée CONTROLE
  GPOINT = "CONTROLE"  :  Gosub ENTREE From EXEFNC
  If OK<>2
    FIN = 1
  Else
    TMP = 1
    TRA = 1
  Endif

Local Integer MORT
  Call PRESENCE(MORT) From CPTBATCH
  If MORT
    GMESSAGE = mess(49,134,1) : # La tâche comptable doit être démarrée
    GERR=1 : FIN=1 : Return
  Endif

Return

$SORTIE

  Call UNLOCKCPY() From AX3MONO

Return


$EXEC

  If GSERVEUR
    [M:DIA]TRACE = 2
  Endif
  If !GSERVEUR & [M:DIA]TRACE=2
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(TIT,0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Endif
  SYMBOLE = "FIYOPN"
  Lock =SYMBOLE
  If fstat
    #opération en cours sur un autre poste
    Call ECR_TRACE(mess(30,100,1),1) From GESECRAN
  Else
    Call DEBTRANS From GLOCK
    Gosub TR1

    Unlock =SYMBOLE

  Endif

  If !GSERVEUR & [M:DIA]TRACE=2
    Call FERME_TRACE From LECFIC
  Endif

Return

$TR1

# Recherche des types de pièces
Local Integer NBRANX, NBRCLO
Local Integer NBRTYP
NBRTYP= nbrecord([F:GTE])
Local Char   TTYPANX(GLONGTE)(1..NBRTYP) : # Table types pièces à prendre en cpte pour les ANX
Local Char   TTYPCLO(GLONGTE)(1..NBRTYP) : # Table types pièces à prendre en cpte pour les CLO
  GOK=1

Call LEC_CPY([M:DIA]CPY) From CPTLEC
Filter [GT2] Where LEG=[F:CPY]LEG | LEG="" Order By Key CLE=TYP Asc ; LEG Desc

  Trbegin [FIY]
  For I=0 To [M]NBLIG-1
    If [M]OPNFIY(I)=2

      Raz NBRANX, NBRCLO
      For [GT2]CLE(1)
        If [GT2]PER>1 and [F:GT2]AUZLED([M]LEDTYP(I)-1)>1
          If [F:GT2]PER=2
            NBRANX+=1
            TTYPANX(NBRANX) = [F:GT2]TYP
          Elsif [F:GT2]PER=3
            NBRCLO+=1
            TTYPCLO(NBRCLO) = [F:GT2]TYP
          Endif
        Endif
      Next

  ##############################################
  # vérification des à-nouveaux                #
  ##############################################
  #Si au moins une écriture avec l'état "Définitif" ne fait rien...
  #Mais on veut la liste de ces pièces donc une boucle "For" !!!
      For [F:HAE] Where CPY=[M:DIA]CPY & FLGREP=2 & STA=2 & FIY>[M:DIA]FIY(I) & (find(TYP,TTYPANX(1..NBRANX))<>0 or  find(TYP,TTYPCLO(1..NBRCLO))<>0)
        # : A nouveaux XXX : Ecriture définitive, annulation impossible
        Call ECR_TRACE(mess(2,621,1)-[F:HAE]NUM-":"-mess(67,119,1),1) From GESECRAN
        GOK = 0
        Break 2
      Next

  ##############################################
  # tables temporaires                         #
  ##############################################
  #Si au moins une écriture en attente dans GACCTMP ne fait rien...
  #Mais on veut la liste de ces pièces donc une boucle "For" !!!
      For [F:HAT] Where CPY=[M:DIA]CPY & FLGREP=2 & STA=2 & FIY>[M:DIA]FIY(I) & (find(TYP,TTYPANX(1..NBRANX))<>0 or  find(TYP,TTYPCLO(1..NBRCLO))<>0)
        # : XXX : Pièce en attente de validation
        Call ECR_TRACE([F:HAT]NUM-":"-mess(37,104,1),1) From GESECRAN
        GOK = 0
        Break 2
      Next

  #Transaction effectuée dans le Call DELPCE..
  ## Suppression pièce AN
      For [HAE] Where CPY=[M:DIA]CPY & FLGREP=2 & FIY=[M:DIA]FIY(I)+1 & find(TYP,TTYPANX(1..NBRANX))<>0
        Call DELPCE([F:HAE]TYP,[F:HAE]NUM) From CPTBATCH
        If GOK<1
          Break 2
        Endif
        #Suppression des à-nouveaux - No pièce : xxxxx
        Call ECR_TRACE(mess(125,116,1)-"-"-mess(11,105,1)-":"-[F:HAE]NUM,0) From GESECRAN
      Next

  ## Suppression pièce Clôture
      For [HAE] Where CPY=[M:DIA]CPY & FLGREP=2 & FIY=[M:DIA]FIY(I) & find(TYP,TTYPCLO(1..NBRCLO))<>0
        Call DELPCE([F:HAE]TYP,[F:HAE]NUM) From CPTBATCH
        If GOK<1
          Break 2
        Endif
        #Suppression des à-nouveaux - No pièce : xxxxx
        Call ECR_TRACE(mess(125,116,1)-"-"-mess(11,105,1)-":"-[F:HAE]NUM,0) From GESECRAN
      Next

      OK=0
      Call OPNFIY([M]CPY,[M]LEDTYP(I),[M]FIY(I),OK)
      If OK
        Break
      Endif

      GPE = 0
      GPOINT = "BEFWRIFIY" : Gosub ENTREE From EXEFNC
      If GPE
        OK=1
        Break
      Endif

    Endif
  Next I
  Filter [GT2]
  If GOK<1
    OK=1
  Endif

  Case OK
    When 1 : Goto AB_TR1
    When 2 : Goto ROLL_TR1
  Endcase
  Commit

  If GRAN=2
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    #Relancer la fonction :"Reconstitution des à-nouveaux"
    Call ECR_TRACE(mess(46,134,1)-tolower(mess(163,126,1))-":"-mess(104,116,1),0) From GESECRAN
  Endif
Return


Subprog OPNFIY(SOC,LEDTYP,EXERCICE,STAT)
Value Char SOC
Value Integer LEDTYP
Value Decimal EXERCICE
Variable Integer STAT

## Maj du statut de l'exercice#

Readlock [FIY]FIY0 = SOC;LEDTYP;EXERCICE
If fstat = 1
 GOK = -1 : GLOCK="$FISCALYEAR"-SOC-num$(LEDTYP)-num$(EXERCICE) : STAT=2 : End
Elsif fstat
 GOK = 0 : Call RSTA("FIY",SOC-num$(LEDTYP)-num$(EXERCICE)) From GLOCK : STAT=1 : End
Else
 [F:FIY]FIYSTA = 2          : # Ouvert
 [F:FIY]CLODAT = [0/0/0]    : # Raz de la date de clôture
 Rewrite [FIY]
 If fstat
  GOK = 0 : Call FSTA("FIY") From GLOCK : End
 Endif
 Call FIYAUT(SOC,LEDTYP,EXERCICE,GOK) From SUBFIY
 If !GOK : STAT=1 : End : Endif
 #Ré-ouverture de l'exercice jj/mm/aa - JJ/MM/AA
 Call ECR_TRACE(mess(104,107,1)-num$([F:FIY]FIYSTR)-"-"-num$([F:FIY]FIYEND),0) From GESECRAN
Endif
End

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#########################################################################
# Etiquettes du masque OPNFIY
#########################################################################

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local Integer I, NOK

If VALEUR<>""
 Call LECTURE("CPY",VALEUR,"") From CONTOBJ
 If func AFNC.PARAM("FRADGI",VALEUR)="2"
  GMESSAGE = mess(175,107,1) : # Réouverture interdite pour cette société
  mkstat = 2
  End
 Endif
 Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
 [M:DIA]NBLIG=0

 NOK=0
 For I=0 To len(mess(0,2644,1))-1
  If [F:GCM]LED(I)<>"" & [F:GCM]CFMAUT(I)<>2
   [M]LEDTYP([M:DIA]NBLIG)=I+1
   Filter [FIY] Where LEDTYP=[M]LEDTYP([M:DIA]NBLIG) & CPY=VALEUR & FIYSTA=3
   Read [FIY]FIY0 Last
   If !fstat
    [M]FIY([M:DIA]NBLIG) = [F:FIY]FIYNUM
    Call LECTURE("FIY",num$([M]LEDTYP([M:DIA]NBLIG)),VALEUR+"~"+num$([F:FIY]FIYNUM)) From CONTOBJ
    [M]DATFIYDEB([M:DIA]NBLIG) = [F:FIY]FIYSTR
    [M]DATFIYFIN([M:DIA]NBLIG) = [F:FIY]FIYEND
    Affzo DATFIYDEB([M:DIA]NBLIG), DATFIYFIN([M:DIA]NBLIG)
   Elsif fstat
    Effzo DATFIYDEB([M:DIA]NBLIG), DATFIYFIN([M:DIA]NBLIG)
    Grizo [M]OPNFIY([M:DIA]NBLIG)
    NOK+=1
   Endif
   [M:DIA]NBLIG+=1
   Filter [FIY]
  Endif
 Next I
 If NOK=[M]NBLIG
  # Il n'y a aucun exercice à ré-ouvrir
  GMESSAGE = mess(60,101,1)
  mkstat = 2 : End
 Endif
 Affzo [M:DIA]
Endif
End


$SETNOL
Local Integer NOL
NOL=nolign-1
Return

######################################################################################

