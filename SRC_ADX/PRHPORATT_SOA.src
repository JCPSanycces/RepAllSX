Subprog SETPORATT(VFNC,VABR,VID1,VBYTES,VPATH,VID2,VID3,VCNTTYPE,VSTAT)
Value Char VFNC             #Function
Value Char VABR             #Abreviation
Value Char VID1             #Identifier 1
Value Char VPATH            #Filename
Value Char VID2          #Identifier 2
Value Char VID3          #Identifier 3
Variable Blbfile  VBYTES()  #BLBFile
Value Char VCNTTYPE
Variable Integer VSTAT
#Local declaration
Local Char DOCTYP(3)
Local Char NEWVOLUME(255)
Local Char DIRVOLA(250)
Local Char NEWVPATH(100)



#Renaming the filename
NEWVPATH=VABR+"_"+VID1+"~"+VID2+"_"+VID3

#Get the type of the document based on the file extension
DOCTYP = func ESS_FUNCTIONS.MAP_CONTENTYPE_ATT(VCNTTYPE)
If DOCTYP = "PIC" or DOCTYP = "RTF"
  Call STORE_FILE_STD(VABR,VID1,VID2,NEWVPATH,VID3,NEWVOLUME,DOCTYP,VSTAT)
End
Endif

Gosub GET_VOLUME

If NEWVOLUME = "" : End : Endif #Error handling

#Actual path of the volume
DIRVOLA = func AVOLUME_CSTD._GETFULLPATH(num$(NEWVOLUME),"")

#Opening and saving actual file for BYTE
Openo DIRVOLA+NEWVPATH,0 Using [BIN1]
If fstat=0
  Putseq 1, VBYTES Using [BIN1]
  Openo Using [BIN1]
Else
  #Can handle error here
  End
Endif
#NEWVOLUME = "["+NEWVOLUME+"]\"
NEWVOLUME = "["+NEWVOLUME+"]/"


#After moving the file - the details must be stored in AOX table
Call STORE_FILE_STD(VABR,VID1,VID2,NEWVPATH,VID3,NEWVOLUME,DOCTYP,VSTAT)
#STAT Manage - Portal message?
 If VSTAT>0
  #Delete the file from NEWVOLUME
  #Leave delete option for now and return stat to rollback FRLAA 2017-09-11


   #If filinfo(NEWVOLUME+NEWVPATH,0)>=0
   If filinfo(DIRVOLA+NEWVPATH,0)>=0
    Call EFFACE(NEWVOLUME+NEWVPATH,VSTAT) From ORDSYS
     #Dont need to handle STAT - already in error handling procedure
   Endif
  #Goto AB_TR :  Return
 Endif
#Commit

End

$GET_VOLUME
If dim(NEWVOLUME)=-1 : Local Char NEWVOLUME(255) : Endif
If VFNC = "HREXS"
  Call PARAM("", "PORATTEXS", NEWVOLUME) From ADOVAL # Folder level PORATTEXS parameter
Elsif VFNC = "DCG"
  Call PARAM("", "PORATTDCG", NEWVOLUME) From ADOVAL # Folder level PORATTDCG parameter
Endif
Return

Subprog GESTPORATT(ACODE,VFNC,VREFNUM,VPATH,VDEM,VUID)
Value Char      ACODE()
Value Char      VFNC()             #Function
Value Char      VREFNUM()          #Employee
Variable Char   VPATH()            #Filename
Value Integer   VDEM          #Request
Value Integer   VUID          #UID of the line

If !([L]ACODE="READ" or [L]ACODE="DEL") End : Endif
If !clalev([F:AOX]) : Local File AOBJTXT  [AOX] : Endif
Local Integer RES
Local Char W_NAME(100)
Local Char W_LOCPATH(255)
Local Char W_DESTPATH(255)
Local Char MESSAGE(250)

Gosub REMAP_VFNC


[L]RES=func FILTER_AOX([L]VFNC,[L]VREFNUM,[L]VDEM,[L]VUID)
If RES
  [L]W_NAME=[F:AOX]NAM
  If [L]W_NAME<>""
    [L]W_NAME=ctrans([L]W_NAME,"\","/")
    [L]RES=func ASYRSTO.CTL_VOLFIL(2,[L]W_NAME,[L]W_LOCPATH,0,[L]MESSAGE)
    If !RES
      # copy to local
      # calculate destinary
      Repeat
        [L]RES=instr(0,[L]W_NAME,"/")
        [L]W_NAME=right$([L]W_NAME,[L]RES+1)
      Until RES=0
      [L]W_DESTPATH=func GETDEFDIR([L]VFNC)+[L]W_NAME
      [L]VPATH=func GET_DESTREP([L]VFNC)+[L]W_NAME
      If [L]ACODE="READ"
        Call COPIE([L]W_LOCPATH,[L]W_DESTPATH,[L]RES)From ORDSYS
      Else
         Call EFFACE([L]W_DESTPATH,[L]RES)From ORDSYS
      Endif
    Else
      Call ADDMESSERR([L]MESSAGE) From WEB
    Endif
  Endif
Endif

End

$REMAP_VFNC

If [L]VFNC="CNG" : [L]VFNC="DCG" : Endif
If [L]VFNC="NDF" : [L]VFNC="HREXS" : Endif

Return

Funprog GETDEFDIR(REP)
Value Char REP()

Local Char SEP(1) : SEP=func PRHUTIFILES.DIRSEP()
Local Char ROOT(250)
Local Char PATHREL(50)
Local Char DIRS(50)(0..)
Local Integer WI,ERR
Call STR_EXPLODE(func GET_DESTREP(REP),"/",DIRS) From PRHUTIFCTPRH
ROOT=filpath(nomap,"", "", "X3_PUB")
While(DIRS(WI)<>"")
  ROOT+=SEP+DIRS(WI)
  If filinfo(ROOT,7)<0
    Call CREREP(ROOT,ERR)From DOSAPL
  Endif
WI+=1
Wend
End ROOT+SEP

Funprog GET_DESTREP(REP)
Value Char REP
Local Char RES(250)
RES="TMP/"+REP+"/"
End RES

Subprog GETDOCTYP(VFILEXT,VDOCTYP)
Value Char VFILEXT()
Variable Char VDOCTYP()
#Add logic - have to use ADI 902!! for now DOC
#DOC,INV,PIC,RTF,TXT
VDOCTYP = func ESS_FUNCTIONS.MAP_CONTENTYPE_ATT(VFILEXT)
End

Subprog STORE_FILE_STD(PABR,PID1,PID2,VPATH,PID3,VNEWVOLUME,VTYPDOC,STAT)
Value Char PABR
Value Char PID1
Value Char PID2
Value Char VPATH
Value Char PID3
Value Char VNEWVOLUME
Value Char VTYPDOC
Variable Integer STAT : STAT = 0
Local Char FILT(250)
Local Char IDENT(250)
Local Integer ATTCAT : ATTCAT = 1  # ??Confidential??

#Opening different instance of AOX
If clalev([F:AOX2])=0 : Local File AOBJTXT [AOX2] : Endif

Gosub SET_VAR_DELETEFILE

#Trbegin [AOX2]

#Build where string
FILT="ABREV='"+PABR+"' and IDENT1='"+PID1+"' and IDENT2='"+PID2+"'" + " and IDENT3='"+PID3+"'"

#Read on filter - FILT
Filter [AOX2] Where evalue(FILT)
Read [AOX2]AOX0 First

If !fstat
   W_NAME=[F:AOX2]NAM
  [F:AOX2]NAM=VNEWVOLUME+VPATH
  [F:AOX2]TYPDOC=VTYPDOC
  [F:AOX2]IDENT3   = PID3
  Rewrite [F:AOX2]
  If W_NAME=[F:AOX2]NAM : W_NAME="" Endif
Else
 # save the name to delete after

 Raz [F:AOX2]
 [F:AOX2]ABREV    = PABR
 [F:AOX2]IDENT1   = PID1
 [F:AOX2]IDENT2   = PID2
 [F:AOX2]IDENT3   = PID3
 [F:AOX2]CAT      = ATTCAT
 [F:AOX2]NAM=VNEWVOLUME+VPATH
 [F:AOX2]TYPDOC=VTYPDOC
 Write [F:AOX2]
Endif
If fstat<>0
 STAT = 1
 W_NAME=""
 #Rollback
 End
Endif
#Commit
# replace an existing file, we delete the old file
If W_NAME<>""
  Gosub DELETE_FILE
Endif

End

Subprog STORE_FILE_SOA(VFNC,VREFNUM,VDEM,VUID,VID3,VSTAT)
Value Char VFNC
Value Char VREFNUM
Value Char VID3
Value Integer VDEM
Value Integer VUID
Variable Integer VSTAT

Gosub GET_VOLUME
If NEWVOLUME = AVOID.ACHAR
  NEWVOLUME = "ATT" : #Hardcoded to default attachments directory
Endif

Local Char VPATH(255) : VPATH=num$(VFNC)+"_"+num$(VUID)+"_"
Local Char FILT(250)
Local Char ABRV(3) : ABRV = "EML"

Local Blbfile ATTACHMENT(GLONABB)
If !clalev([F:AOX3]) : Local File AOBJTXT [AOX3] : Endif
If !clalev([F:ABB3]) : Local File ABLOB  [ABB3] : Endif


#Build where string
FILT="ABREV='"+ABRV+"' and IDENT1='"+VFNC+"~"+VREFNUM+"~"+num$(VDEM)+"' and IDENT2='"+num$(VUID)+"' and IDENT3='"+num$(VID3)+"'"
Filter [F:AOX3] Where evalue(FILT)
Read [F:AOX3] First
If !fstat : #success
  If [F:AOX3]TYPDOC = "PIC" or [F:AOX3]TYPDOC  = "RTF"
#    #File already exist in ABLOB but we need to rename to COD to EML
#    Read[F:ABB3]ABB0 = "PJ_EML";VFNC+"~"+VREFNUM+"~"+num$(VDEM);num$(VUID);num$(VID3)
#    If !fstat
#      Infbox "REWRITE"
#      # Re-write
#      [F:ABB3]CODBLB = ABRV
#      Rewrite [F:ABB3]
#      If fstat
#        VSTAT = 2
#      Else
#        VSTAT = 1
#      Endif
#    Endif
   Else
    Local Integer DASHPOS : DASHPOS = instr(1,[F:AOX3]NAM,"/")
    Local Integer EXTPOS  : EXTPOS  = instr(1,[F:AOX3]NAM,".")
    Local Char FIC_EXT(30)
    If DASHPOS
      VPATH = right$([F:AOX3]NAM,DASHPOS+1)
      If EXTPOS
        VPATH = left$(VPATH,instr(1,VPATH,".")-1)
      Endif
    Else
      VPATH = [F:AOX3]NAM
    Endif

    If EXTPOS
      FIC_EXT = right$([F:AOX3]NAM,EXTPOS+1)
    Endif

    Openi filpath(NEWVOLUME,VPATH,FIC_EXT) Using [SOA]

    Getseq GLONABB, ATTACHMENT Using [SOA]

    Openi Using [SOA]

    If ATTACHMENT <> AVOID.ABLOB
      Read[F:ABB3]ABB0 = "PJ_"+ABRV;VFNC+"~"+VREFNUM+"~"+num$(VDEM);num$(VUID);num$(VID3)
      If !fstat
        # Re-write
        [F:ABB3]BLOB    = ATTACHMENT
        [F:ABB3]CODBLB  = "PJ_"+ABRV
        Rewrite [F:ABB3]
      Else
        # Write
        [F:ABB3]CODBLB = "PJ_"+ABRV
        [F:ABB3]IDENT1 = VFNC+"~"+VREFNUM+"~"+num$(VDEM)
        [F:ABB3]IDENT2 = num$(VUID)
        [F:ABB3]IDENT3 = num$(VID3)
        [F:ABB3]BLOB   = ATTACHMENT
        [F:ABB3]CNTTYP = 'ATYPE9-1'
        [F:ABB3]TYPBLB = 3
        Write [F:ABB3]
      Endif
      If fstat
        VSTAT = 2
      Else
        VSTAT = 1
      Endif
    Endif
  Endif
Endif

LogicClose File [AOX3],[ABB3]

End

$WRITE_ATTACHMENT
Return

#################################################
Subprog REMOVE_FILE(VCODBLB,VREFNUM,VUNQ,VUID,VERR_MSG, VSTAT)
Value Char       VCODBLB
Value Char       VREFNUM
Value Integer    VUNQ
Value Integer    VUID
Variable Char    VERR_MSG
Variable Integer VSTAT

  If VUID <= 0 or VUNQ = 0
    VSTAT = [V]CST_AINFO
    VERR_MSG = "Attachment will be deleted once record is saved"
    End
  Endif

  #Initialise variables
  Local File ABLOB [BSOADEL]
  Local File AOBJTXT  [AOXDEL]
  Local Integer SOA_STAT        : SOA_STAT = 0
  Local Integer STD_STAT        : STD_STAT = 0

  Local Char DCODBLB(255), DABREV(255),DIDENT1(255),DFILT(255),DABREVSOA(10),DIDENT4(3),DFILTSOA(255)
  Local Integer DIDENT2,DIDENT3

  DCODBLB = VCODBLB
  DABREV  = 'EML'
  DIDENT1 = VREFNUM
  DIDENT2 = VUNQ
  DIDENT3 = VUID
  DABREVSOA = "PJ_EML"
  DIDENT4 = "001"
  DFILTSOA = "CODBLB='"+DABREVSOA+"' and IDENT1='"+DCODBLB+"~"+DIDENT1+"~"+num$(DIDENT2)+"' and IDENT2='"+num$(DIDENT3)+"' and IDENT3='"+num$(DIDENT4)+"'"
  DFILT   = "ABREV='"+DABREV+"' and IDENT1='"+DCODBLB+"~"+DIDENT1+"~"+num$(DIDENT2)+"' and IDENT2='"+num$(DIDENT3)+"' and IDENT3='"+num$(DIDENT4)+"'"

  Trbegin [F:BSOADEL],[F:AOXDEL]

  Gosub SOA_DLT
  If !SOA_STAT
    Gosub STD_DLT
  Endif

  If !SOA_STAT & !STD_STAT
    Commit
    VSTAT = [V]CST_AINFO
    VERR_MSG = "Attachment deleted successfully"
  Else
    Rollback
    VSTAT = [V]CST_AWARNING
    VERR_MSG = "Unable to delete attachment"
  Endif

  LogicClose File [F:BSOADEL],[F:AOXDEL]

End
#---------------------------------------------------
$SOA_DLT

  # Remove record from BBLOBSOA table which includes BLOB
  Delete [F:BSOADEL] Where evalue(DFILTSOA)
  SOA_STAT = fstat

Return
#---------------------------------------------------
$STD_DLT

  # Delete AOBJTXT pointer record as well as physical file from directory
  Filter [F:AOXDEL] Where evalue(DFILT)
  Read [F:AOXDEL] First
  If !fstat
    Local Integer DEXTPOS : DEXTPOS = instr(1,[F:AOXDEL]NAM,'.')
    Local Char    DEXT
    If DEXTPOS
      DEXT = right$([F:AOXDEL]NAM,DEXTPOS+1)
    Endif

    STD_STAT = Delfile(filpath('ATT',[F:AOXDEL]NAM,DEXT))
    If STD_STAT = -20 : # File does not exist in directory
      STD_STAT = 0
    Endif
  Endif

  If STD_STAT : Return : Endif

  Delete [F:AOXDEL]
  STD_STAT = fstat

Return
#################################################
$AB_TR
Rollback
Return
End

#################################################
# DELTYP : 0 : delete all records, 1: delete records in LUID , 2 : delete records not in LUID
#
# without transaction

Subprog DELETE_AOX_ATTACH(FNC,REFNUM,DEM,LUID,DELTYP)
Value Char FNC()
Value Char REFNUM()
Value Char DEM()
Variable Char LUID()()
Value Integer DELTYP

If clalev([F:AOX2])=0 : Local File AOBJTXT [AOX2] : Endif

Local Integer WOK,I
Gosub SET_VAR_DELETEFILE

Gosub SET_FILTER_DELETE
For [AOX2]
  Gosub CALC_VALUE_DELETE
  If WOK
    W_NAME=[F:AOX2]NAM
    Gosub DELETE_FILE
    Delete [F:AOX2] Curr
  Endif
Next

End

$SET_VAR_DELETEFILE
Local Integer STAT
Local Char FILESRV(250),MESSAGE(250),W_NAME(250)

Return

$DELETE_FILE
If W_NAME<>""
  W_NAME=ctrans(W_NAME,"\","/")
  STAT=func ASYRSTO.CTL_VOLFIL(2,W_NAME,[L]FILESRV,0,MESSAGE)
  If !STAT
    Call EFFACE([L]FILESRV,STAT)From ORDSYS
  Endif
Endif

Return

$SET_FILTER_DELETE
Local Char ABRV(10): ABRV = "EML"
Filter [AOX2] Where ABREV = ABRV and IDENT1 = FNC+"~"+REFNUM+"~"+num$(DEM)

Return

$CALC_VALUE_DELETE

If !DELTYP
    WOK=1
  Else
    I=find([F:AOX2]IDENT2,LUID)
    Case DELTYP:
      When  1 :
       WOK =(I<>0)
      When 2  :
       WOK =(I=0)
    Endcase
  Endif

Return

Funprog FILTER_AOX(FNC,REFNUM,DEM,UID,VID3)
Value Char FNC
Value Char VID3
Value Char REFNUM
Value Integer DEM
Value Integer UID
Local Integer WRET : WRET = 0
#SBA error in portal if the table doesn't open.
If !clalev([F:AOX]) : Local File AOBJTXT  [AOX] : Endif
Read [AOX]AOX0 = "EML";FNC+"~"+num$(REFNUM)+"~"+num$(DEM);num$(UID);VID3
If !fstat
  WRET = 1
Endif
End WRET

#Generic Delete function for AOBJTXT - should be called from example APRES_MOD ( No transaction mode)
Funprog ATT_AOBJTXT_MANAGE(FNC,REFNUM,DEM,LUID)
Value Char FNC
Value Char REFNUM
Value Char DEM
Value Char LUID()()

Local Integer WRET : WRET = 0
Local Char ABRV: ABRV = "EML"
Local Integer I

WRET=func ATT_AOBJTXT_MANAGETYP(FNC,REFNUM,DEM,LUID,2)
#Close files
End WRET

#################################################
# DELTYP : 0 : delete all records, 1: delete records in LUID , 2 : delete records not in LUID
Funprog ATT_AOBJTXT_MANAGETYP(FNC,REFNUM,DEM,LUID,DELTYP)
Value Char FNC
Value Char REFNUM
Value Char DEM
Value Char LUID()()
Value Integer DELTYP


Local Integer WRET : WRET = 0
Local Char ABRV: ABRV = "EML"
Local Integer I,WOK


If clalev([F:AOX2])=0 : Local File AOBJTXT [AOX2] : Endif
Trbegin AOBJTXT [AOX2]
Filter [AOX2] Where ABREV = ABRV and IDENT1 = FNC+"~"+REFNUM+"~"+num$(DEM)
For [AOX2]
  If !DELTYP
    WOK=1
  Else
    I=find([F:AOX2]IDENT2,LUID)
    Case DELTYP:
      When  1 :
       WOK =(I<>0)
      When 2  :
       WOK =(I=0)
    Endcase
  Endif
  If WOK
    Delete [F:AOX2] Curr
    If fstat=1 | fstat>5
      WRET = 1
      GOK = 0
      Break
    Endif
  Endif
Next

If GOK
 Commit
Else
 Rollback
Endif

End WRET

