#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# CLASS FACILITY
##########################################################################################################


##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When "FCY"
    Case [L]AEVENT
     When "AINSERT_AFTER"       : Gosub AINSERT_AFTER
     When "AUPDATE_AFTER"       : Gosub AUPDATE_AFTER
     When "AREAD_AFTER"         : Gosub AREAD_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "FCY.LEGCPY"              : Gosub FCY_LEGCPY
  When "FCY.FINFLG"              : Gosub FCY_FINFLG
  When "FCY.CRY"                 : Gosub FCY_CRY        :#60505
  When "FCY.ORICERFLG"           : Gosub FCY_ORICERFLG  :#60505
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return



##########################################################################################################
$AINSERT_AFTER
Gosub FINFLG_DISPLAY
Return

##########################################################################################################
$AUPDATE_AFTER
Gosub FINFLG_DISPLAY
Return

##########################################################################################################
$AREAD_AFTER
Gosub FINFLG_DISPLAY
Return


##########################################################################################################
$FCY_LEGCPY
Case [L]ARULE
  When "CONTROL"                 : Gosub LEGCPY_CONTROL
Endcase
Return

##########################################################################################################
$FCY_FINFLG
Case [L]ARULE
  When "PROPAGATE"               : Gosub FINFLG_PROPAGATE
Endcase
Return

################################################################################################
##X3-60505
$FCY_CRY
  Case [L]ARULE
    When "PROPAGATE"              : Gosub CRY_DISPLAY
  Endcase
Return

################################################################################################
#X3-60505
$FCY_ORICERFLG
  Case [L]ARULE
    When "PROPAGATE"              : Gosub ORICERFLG_DISPLAY
  Endcase
Return

##########################################################################################################
$FINFLG_PROPAGATE
Gosub FINFLG_DISPLAY
Return

###############################################################################################
$FINFLG_DISPLAY
If this.FINFLG <> [V]CST_AYES
  [L]ASTATUS = fmet this.ASETATTRIBUTE("FINRSPFCY", "$isDisabled", "false")
  If dim(this.ORICERFLG)>=0 :#X3-69093
    [L]ASTATUS = fmet this.ASETATTRIBUTE("ORICERFLG","$isDisabled","true")    :#X3-60505
    [L]ASTATUS = fmet this.ASETATTRIBUTE("REXNUM","$isDisabled","true")       :#X3-60505
  Endif
Else
  [L]ASTATUS = fmet this.ASETATTRIBUTE("FINRSPFCY", "$isDisabled", "true")
Endif
Return

###############################################################################################
$LEGCPY_CONTROL
If this.ASTALIN = [V]CST_ANEW
  [L]ASTATUS = fmet this.ASETATTRIBUTE("LEGCPY", "$isDisabled", "false")
Else
  [L]ASTATUS = fmet this.ASETATTRIBUTE("LEGCPY", "$isDisabled", "true")
Endif
Return

################################################################################################
##X3-60505
$CRY_DISPLAY
  If dim(this.ORICERFLG)>=0 & this.FINFLG = [V]CST_AYES :#X3-69093
    If (fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"EECFLG")<>[V]CST_AYES
&     & fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"GSPFLG")<>[V]CST_AYES)
      [L]ASTATUS = fmet this.ASETATTRIBUTE("ORICERFLG","$isDisabled","true")
      [L]ASTATUS = fmet this.ASETATTRIBUTE("REXNUM","$isDisabled","true")
    Else
      [L]ASTATUS = fmet this.ASETATTRIBUTE("ORICERFLG","$isDisabled","false")
    Endif
  Endif
Return

################################################################################################
##X3-60505
$ORICERFLG_DISPLAY
  If dim(this.ORICERFLG)<0 : Return : Endif :#X3-69093 it's safer.
  If this.ORICERFLG=[V]CST_AYES
    [L]ASTATUS = fmet this.ASETATTRIBUTE("REXNUM","$isDisabled","false")
  Else
    [L]ASTATUS = fmet this.ASETATTRIBUTE("REXNUM","$isDisabled","true")
  Endif
Return

