#<AdxTL>@(#)0.0.0.0 $Revision$


# Gestion du masque STOPCKSERE
##################################################################################
# Traitement TRTPCKSERE - Saisie des numéros de série globale                    #
#                         Depuis les documents correspondant au parametre LABR   #
##################################################################################
# Action SAIPCKSERE
# Paramètres - LABR Abréviation masque
#                   "PKD1" Colisage déclaratif
#                   "PKP2" Post-colisage
#            - LNOL No ligne écran (nolign-1)
#
########################################################################################
#                                                                                ACTIONS
########################################################################################
$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "AVANT_ENR"     : Gosub AVANT_ENR
 When "ENR"           : Gosub ENR
 When "ABA"           : Gosub ABA
 When "FIN"           : Gosub FIN
 When "FINSAI"        : Gosub FINSAI

 When "SEL_LISTE"     : Gosub SELLISTE
Endcase
Return

#########################################################################
$OUVRE
Global Char    PABR            : # Abréviation masque origine
Global Integer PNOL            : # No ligne courante (nolign-1) masque origine
Local Integer I, OK
# Récupération des paramètres
PABR    = PARAM(1)
PNOL    = val(PARAM(2))

If clalev([M:SPSE1])= 0 Local Mask STOPCKSERE   [SPSE1]  Endif
If clalev([F:SPD])  = 0 Local File SPACKD       [SPD]    Endif
Return

#########################################################################
$DEBUT
Local Integer WLIGNE
Raz WLIGNE
Raz I
Gosub CHARG_BC1_SPSE From TRTPCKSERE
Gosub CHARG_TAB_SPSE From TRTPCKSERE
[M:SPSE]NBLIG = I+1
Affzo [M:SPSE]
Return

#########################################################################
$SETBOUT
If !find("A",CHBOU) CHBOU+="A" Endif
If !find("E",CHBOU) CHBOU+="E" Endif
Return

#########################################################################
$AVANT_ENR
If [M:SPSE]NBLIG=0 |
& ([M:SPSE]NBLIG<>0 & sigma(I=0,[M:SPSE]NBLIG-1,[M:SPSE]QTYSTU(I))<>[M:SPSE]QTY)
   # Le nb de no série ne correspond pas à la qté à traiter
   GMESSAGE = mess(246,199,1)
   GERR=1
   FOK=0
   Return
Endif
Raz [M:SPSE1]
If [M:SPSE]NBLIG>1
   [M:SPSE1] = [M:SPSE]
   # Vérification que les plages de no série sont bien croissantes
   Sorta [M:SPSE1]NBLIG [M:SPSE1]NBLIG Order By [M:SPSE1]SERNUM([S]indice)
   For I=1 To [M:SPSE1]NBLIG-1
      If [M:SPSE1]SERNUM(I) <= [M:SPSE1]SERFIN(I-1)
         GMESSAGE = mess(464,199,1)  # Numéro de séries incorrects : des numéros sont présents plusieurs fois
         GERR=1
         FOK=0
         Break
      Endif
   Next I
Endif
Default Mask [M:SPSE]
Return

#########################################################################
$ENR
FIN = 1
Return

#########################################################################
$ABA
Gosub DEBUT
Return

#########################################################################
$FIN
Local Integer WI
WI = find(2,[M:SPSE]MODFLG(0..[M:SPSE]NBLIG-1))
If GUSER = "HCB"
  # Dbgaff
Endif
If WI > 0
   Case PABR
        When "PKD1" : Gosub CHARG_TABLEAU_SPSE  From TRTPCKSERE
                      Dela PNOL,1,[M:PKD1]NBLIG-1 [M:PKD1]NBLIG
                      [M:PKD1]NBLIG -= 1
        When "PKP2" : Gosub CHARG_TABLEAU_SPSE  From TRTPCKSERE
                      Dela PNOL,1,[M:PKP2]NBLIG-1 [M:PKP2]NBLIG
                      [M:PKP2]NBLIG -= 1
        When Default:
   Endcase
Endif
Return

#########################################################################
$FINSAI
Default Mask "["+PABR+"]"
Affzo [M]
mkstat=4
Return

########################################################################################
#                                                                        SOUS-PROGRAMMES
########################################################################################
###############################################################################
# CHARG_BC1_SPSE : chargement  masque STOPCKSERE partie bloc 1
###############################################################################
$CHARG_BC1_SPSE
Raz [M:SPSE]
Case PABR
     When "PKD1" : [M:SPSE]ITMREF       = [M:PKD1]ITMREF    (PNOL)
                   [M:SPSE]QTY          = [M:PKD1]QTY       (PNOL)
                   [M:SPSE]QTYINI       = [M:PKD1]QTYINI    (PNOL)
                   [M:SPSE]STU          = [M:PKD1]STU       (PNOL)
                   [M:SPSE]VCRLIN       = [M:PKD1]VCRLIN    (PNOL)
                   [M:SPSE]SERCOLDEB    = [M:PKD1]SERCOLDEB (PNOL)
                   [M:SPSE]SERCOLFIN    = [M:PKD1]SERCOLFIN (PNOL)
                   [M:SPSE]SERORIDEB    = [M:PKD1]SERORIDEB (PNOL)
                   [M:SPSE]SERORIFIN    = [M:PKD1]SERORIFIN (PNOL)
                   [M:SPSE]STOFCY       = [M:PKD0]STOFCY
                   [M:SPSE]VCRTYP       = [M:PKD0]VCRTYP
                   [M:SPSE]VCRNUM       = [M:PKD0]VCRNUM

     When "PKP2" : [M:SPSE]ITMREF       = [M:PKP2]ITMREF
                   [M:SPSE]QTY          = [M:PKP2]QTY       (PNOL)
                   If [M:PKP2]PACNUM    = ""
                      [M:SPSE]QTYINI    = [M:PKP2]QTYINI    (PNOL)
                   Endif
                   [M:SPSE]STU          = [M:PKP2]STU       (PNOL)
                   [M:SPSE]VCRLIN       = [M:PKP1]VCRLIN    (GLIG_PKP1)
                   [M:SPSE]SERCOLDEB    = [M:PKP2]SERCOLDEB (PNOL)
                   [M:SPSE]SERCOLFIN    = [M:PKP2]SERCOLFIN (PNOL)
                   [M:SPSE]SERORIDEB    = [M:PKP2]SERORIDEB (PNOL)
                   [M:SPSE]SERORIFIN    = [M:PKP2]SERORIFIN (PNOL)
                   [M:SPSE]STOFCY       = [M:PKP2]STOFCY
                   [M:SPSE]VCRTYP       = [M:PKP1]VCRTYP
                   [M:SPSE]VCRNUM       = [M:PKP1]VCRNUM
      When Default:
Endcase

Return

###############################################################################
# CHARG_TAB_SPSE chargement  masque STOPCKSERE partie tableau
###############################################################################
$CHARG_TAB_SPSE
Case PABR
     When "PKD1"  :[M:SPSE]QTYSTU       (I) = [M:PKD1]QTY      (PNOL)
                   [M:SPSE]SERNUM       (I) = [M:PKD1]SERNUM   (PNOL)
                   [M:SPSE]SERFIN       (I) = [M:PKD1]SERFIN   (PNOL)

     When "PKP2"  :[M:SPSE]QTYSTU       (I) = [M:PKP2]QTY      (PNOL)
                   [M:SPSE]SERNUM       (I) = [M:PKP2]SERNUM   (PNOL)
                   [M:SPSE]SERFIN       (I) = [M:PKP2]SERFIN   (PNOL)
      When Default:
Endcase
Return



##############################################################################################
# CHARG_TABLEAU_SPSE chargement du tableau de l ecran origine à l enregistrement de la fenetre
##############################################################################################
$CHARG_TABLEAU_SPSE
Raz WI
For WI=0 To [M:SPSE]NBLIG-1
    If [M:SPSE]QTYSTU (WI) <> 0
        Case PABR
            When "PKD1" : If [M:PKD1]NBLIG + 1 >  dim([M:PKD1]ITMREF)
                             Return
                          Endif
#      partie suite saisie fenetre serie à coliser
                          [M:PKD1]SERNUM           ([M:PKD1]NBLIG) = [M:SPSE]SERNUM    (WI)
                          [M:PKD1]SERFIN           ([M:PKD1]NBLIG) = [M:SPSE]SERFIN    (WI)
                          [M:PKD1]QTY              ([M:PKD1]NBLIG) = [M:SPSE]QTYSTU    (WI)
                          [M:PKD1]QTYSTU           ([M:PKD1]NBLIG) = [M:SPSE]QTYSTU    (WI)
#      partie commune à la ligne colisage origine
                          [M:PKD1]ITMREF           ([M:PKD1]NBLIG) = [M:PKD1]ITMREF    (PNOL)
                          [M:PKD1]ITMDES1          ([M:PKD1]NBLIG) = [M:PKD1]ITMDES1   (PNOL)
                          [M:PKD1]PCU              ([M:PKD1]NBLIG) = [M:PKD1]PCU       (PNOL)
                          [M:PKD1]PCUSTUCOE        ([M:PKD1]NBLIG) = [M:PKD1]PCUSTUCOE (PNOL)
                          [M:PKD1]STU              ([M:PKD1]NBLIG) = [M:PKD1]STU       (PNOL)
                          [M:PKD1]QTYPCU           ([M:PKD1]NBLIG) = [M:PKD1]QTYPCU    (PNOL)

                          If dim([M:PKD1]LOT)>0
                             [M:PKD1]LOT           ([M:PKD1]NBLIG) = [M:PKD1]LOT       (PNOL)
                          Endif
                          If dim([M:PKD1]SLO)>0
                             [M:PKD1]SLO           ([M:PKD1]NBLIG) = [M:PKD1]SLO       (PNOL)
                          Endif
                          If dim([M:PKD1]PALNUM)>0
                             [M:PKD1]PALNUM        ([M:PKD1]NBLIG) = [M:PKD1]PALNUM    (PNOL)
                          Endif
                          If dim([M:PKD1]CTRNUM)>0
                             [M:PKD1]CTRNUM        ([M:PKD1]NBLIG) = [M:PKD1]CTRNUM    (PNOL)
                          Endif
                          [M:PKD1]LIGWEU           ([M:PKD1]NBLIG) = [M:PKD1]LIGWEU    (PNOL)
                          [M:PKD1]WSTOCOU          ([M:PKD1]NBLIG) = [M:PKD1]WSTOCOU   (PNOL)
                          [M:PKD1]VCRLIN           ([M:PKD1]NBLIG) = [M:PKD1]VCRLIN    (PNOL)
                          [M:PKD1]LIGUNTWEI        ([M:PKD1]NBLIG) = [M:PKD1]LIGUNTWEI (PNOL)
                          [M:PKD1]STOMGTCOD        ([M:PKD1]NBLIG) = [M:PKD1]STOMGTCOD (PNOL)
                          [M:PKD1]PCKSTKFLG        ([M:PKD1]NBLIG) = [M:PKD1]PCKSTKFLG (PNOL)
                          [M:PKD1]PACFLG           ([M:PKD1]NBLIG) = [M:PKD1]PACFLG    (PNOL)
                          [M:PKD1]UNTWEI           ([M:PKD1]NBLIG) = [M:PKD1]UNTWEI    (PNOL)
                          [M:PKD1]SAU              ([M:PKD1]NBLIG) = [M:PKD1]SAU       (PNOL)
                          [M:PKD1]SERORIDEB        ([M:PKD1]NBLIG) = [M:PKD1]SERORIDEB (PNOL)
                          [M:PKD1]SERORIFIN        ([M:PKD1]NBLIG) = [M:PKD1]SERORIFIN (PNOL)
                          [M:PKD1]QTYINI           ([M:PKD1]NBLIG) = [M:PKD1]QTYINI    (PNOL)
                          [M:PKD1]SERCOLDEB        ([M:PKD1]NBLIG) = [M:PKD1]SERCOLDEB (PNOL)
                          [M:PKD1]SERCOLFIN        ([M:PKD1]NBLIG) = [M:PKD1]SERCOLFIN (PNOL)
                          [M:PKD1]PCKSERFLG        ([M:PKD1]NBLIG) = [M:PKD1]PCKSERFLG (PNOL)
                          [M:PKD1]SERMGTCOD        ([M:PKD1]NBLIG) = [M:PKD1]SERMGTCOD (PNOL)
#      partie calculée
                          [M:PKD1]NETWEI           ([M:PKD1]NBLIG) = [M:PKD1]QTYSTU    ([M:PKD1]NBLIG) * [M:PKD1]UNTWEI   ([M:PKD1]NBLIG)
                          Call QTEARR([M:PKD1]NETWEI([M:PKD1]NBLIG), [M:PKD1]LIGWEU([M:PKD1]NBLIG)) From TRTDIV
                          [M:PKD1]NETWEIPCK        ([M:PKD1]NBLIG) = [M:PKD1]QTYSTU    ([M:PKD1]NBLIG) * [M:PKD1]LIGUNTWEI([M:PKD1]NBLIG)
                          Call QTEARR([M:PKD1]NETWEIPCK([M:PKD1]NBLIG), [M:PKD1]LIGWEU([M:PKD1]NBLIG)) From TRTDIV
                          Actzo [M:PKD1]QTY        ([M:PKD1]NBLIG)
                          Actzo [M:PKD1]NETWEI     ([M:PKD1]NBLIG)
                          [M:PKD1]NBLIG += 1

            When "PKP2" : If [M:PKP2]NBLIG + 1 >  dim([M:PKP2]SERNUM)
                             Return
                          Endif
 #      partie suite saisie fenetre serie à coliser
                          [M:PKP2]SERNUM           ([M:PKP2]NBLIG) = [M:SPSE]SERNUM    (WI)
                          [M:PKP2]SERFIN           ([M:PKP2]NBLIG) = [M:SPSE]SERFIN    (WI)
                          [M:PKP2]QTY              ([M:PKP2]NBLIG) = [M:SPSE]QTYSTU    (WI)
                          [M:PKP2]QTYSTU           ([M:PKP2]NBLIG) = [M:SPSE]QTYSTU    (WI)
#      partie commune à la ligne colisage origine
                          [M:PKP2]PCU              ([M:PKP2]NBLIG) = [M:PKP2]PCU       (PNOL)
                          [M:PKP2]PCUSTUCOE        ([M:PKP2]NBLIG) = [M:PKP2]PCUSTUCOE (PNOL)
                          [M:PKP2]STU              ([M:PKP2]NBLIG) = [M:PKP2]STU       (PNOL)
                          [M:PKP2]QTYPCU           ([M:PKP2]NBLIG) = [M:PKP2]QTYPCU    (PNOL)

                          If dim([M:PKP2]LOT)>0
                             [M:PKP2]LOT           ([M:PKP2]NBLIG) = [M:PKP2]LOT       (PNOL)
                          Endif
                          If dim([M:PKP2]SLO)>0
                             [M:PKP2]SLO           ([M:PKP2]NBLIG) = [M:PKP2]SLO       (PNOL)
                          Endif
                          If dim([M:PKP2]PALNUM)>0
                             [M:PKP2]PALNUM        ([M:PKP2]NBLIG) = [M:PKP2]PALNUM    (PNOL)
                          Endif
                          If dim([M:PKP2]CTRNUM)>0
                             [M:PKP2]CTRNUM        ([M:PKP2]NBLIG) = [M:PKP2]CTRNUM    (PNOL)
                          Endif
                          [M:PKP2]NETWEI           ([M:PKP2]NBLIG) = [M:PKP2]NETWEI    (PNOL)
                          [M:PKP2]LIGWEU           ([M:PKP2]NBLIG) = [M:PKP2]LIGWEU    (PNOL)
                          [M:PKP2]WSTOCOU          ([M:PKP2]NBLIG) = [M:PKP2]WSTOCOU   (PNOL)
                          [M:PKP2]MODFLG           ([M:PKP2]NBLIG) = 2
                          [M:PKP2]LIGUNTWEI        ([M:PKP2]NBLIG) = [M:PKP2]LIGUNTWEI (PNOL)
                          [M:PKP2]NETWEIPCK        ([M:PKP2]NBLIG) = [M:PKP2]NETWEIPCK (PNOL)
                          [M:PKP2]PACFLG           ([M:PKP2]NBLIG) = [M:PKP2]PACFLG    (PNOL)
                          [M:PKP2]UNTWEI           ([M:PKP2]NBLIG) = [M:PKP2]UNTWEI    (PNOL)
                          [M:PKP2]SAU              ([M:PKP2]NBLIG) = [M:PKP2]SAU       (PNOL)
                          [M:PKP2]SERORIDEB        ([M:PKP2]NBLIG) = [M:PKP2]SERORIDEB (PNOL)
                          [M:PKP2]SERORIFIN        ([M:PKP2]NBLIG) = [M:PKP2]SERORIFIN (PNOL)
                          [M:PKP2]QTYINI           ([M:PKP2]NBLIG) = [M:PKP2]QTYINI    (PNOL)
                          [M:PKP2]SERCOLDEB        ([M:PKP2]NBLIG) = [M:PKP2]SERCOLDEB (PNOL)
                          [M:PKP2]SERCOLFIN        ([M:PKP2]NBLIG) = [M:PKP2]SERCOLFIN (PNOL)
#      partie calculée
                          [M:PKP2]NETWEI    ([M:PKP2]NBLIG) = [M:PKP2]QTYSTU ([M:PKP2]NBLIG) * [M:PKP2]UNTWEI   ([M:PKP2]NBLIG)
                          [M:PKP2]NETWEIPCK ([M:PKP2]NBLIG) = [M:PKP2]NETWEI ([M:PKP2]NBLIG) * [M:PKP2]LIGUNTWEI([M:PKP2]NBLIG)
                          Gosub CAL_NETWEI From TRTPKP2
                          [M:PKP2]NBLIG += 1
            When Default:
       Endcase
    Endif
Next WI

Return

######################################################################"
# SELLISTE
######################################################################"
$SELLISTE
Case LISTE
     When "STKSELPCKS"       : Gosub STKSELPCKS
Endcase
Return

#########################################################################
# STKSELPCKS                    Selection des numéros de series à coliser
#########################################################################
$STKSELPCKS
Local Char     WNUMFIN (GLONSER)
Local Integer Z
Local Integer J
Local Integer WRET
Local Integer WCOLISE
Local Char SZTIT
Z     = 0
SZTIT = ""
Raz WNUMFIN
# dans le cas d'une modification de colis la qtyini = 0  seul serorideb et serorifin sont renseignées
If [M:SPSE]QTYINI = 0
   If [M:SPSE]SERORIDEB = [M:SPSE]SERORIFIN
      [M:SPSE]QTYINI    = 1
   Endif
Endif
If [M:SPSE]QTYINI <> 0
   For J=1 To abs([M:SPSE]QTYINI)
       If J=1
          WNUMFIN  = [M:SPSE]SERORIDEB
          Gosub CTRSERPCK
          If WCOLISE = 0
             If Z >= dim(TEX) - 1
                Break
             Endif
             Z += 1
             TEX  (Z) = [M:SPSE]SERORIDEB
             TEXTE(Z) = [M:SPSE]SERORIDEB
          Endif
       Else
          If WNUMFIN = ""
             WNUMFIN=[M:SPSE]SERORIDEB
          Endif
          Call PLUS_UN(WNUMFIN,WNUMFIN,[L]WRET) From STKLIB
          If WRET = 0
             Gosub CTRSERPCK
             If WCOLISE = 0
                If Z >= dim(TEX) - 1
                   Break
                Endif
                Z += 1
                TEX  (Z) = WNUMFIN
                TEXTE(Z) = WNUMFIN
             Endif
          Else
             GMESSAGE=WNUMFIN-":"-mess(476,197,1) # erreur sur incrementation des numéros de serie
             Break
          Endif
       Endif
   Next
Else
    WNUMFIN  = [M:SPSE]SERORIDEB
    Gosub CTRSERPCK
    If WCOLISE = 0
       If Z >= dim(TEX) - 1
          Goto FINCALCUL
       Endif
       Z += 1
       TEX  (Z) = [M:SPSE]SERORIDEB
       TEXTE(Z) = [M:SPSE]SERORIDEB
    Endif
$DEBCALCUL
     Call PLUS_UN(WNUMFIN,WNUMFIN,[L]WRET) From STKLIB
     If WRET = 0
        If WNUMFIN <= [M:SPSE]SERORIFIN
           Gosub CTRSERPCK
           If WCOLISE = 0
              If Z >= dim(TEX) - 1
                 Goto FINCALCUL
              Endif
              Z += 1
              TEX  (Z) = WNUMFIN
              TEXTE(Z) = WNUMFIN
           Endif
           Goto DEBCALCUL
        Else
           Goto FINCALCUL
        Endif
     Else
         GMESSAGE=WNUMFIN-":"-mess(476,197,1) # erreur sur incrementation des numéros de serie
     Endif
$FINCALCUL
Endif
NBTEX = Z
SZTIT = mess(663,199,1) #No série(s) à coliser
TIT   = left$(SZTIT, 30)

Return

##########################################################################################
# CTRSERPCK          controle si le numero de serie n est pas déjà colisé
#        Ce composant est appelé :
#                 - en selection des numéros de séries  (GACTION = STKSELPCKS)
#                 - en saisie    des numeros de séries  (GACTION = SAIPCKSERE)
#        En sélection le controle est fait uniquement sur les colis existants
#        En saisie    le controle est fait sur les colis existants et en cours de création
##########################################################################################
$CTRSERPCK
Raz WCOLISE
# si le serie fait parti du colis origine c est ok
If [M:SPSE]SERCOLDEB <> ""
   If WNUMFIN >= [M:SPSE]SERCOLDEB &  WNUMFIN <= [M:SPSE]SERCOLFIN
      Return
   Endif
Endif
#  Controle sur colis existants
Filter [SPD] Where  VCRTYP = [M:SPSE]VCRTYP & VCRNUM = [M:SPSE]VCRNUM & VCRLIN = [M:SPSE]VCRLIN & STOFCY = [M:SPSE]STOFCY
&                          & ITMREF    = [M:SPSE]ITMREF & (WNUMFIN >= SERDEB & WNUMFIN <= SERFIN)
&       Order By Key SPD0
        For [SPD]
            WCOLISE = 1
            Break
        Next
Filter [SPD]

If GACTION = "STKSELPCKS" | WCOLISE <> 0
   Return
Endif
#  Controle sur colis en cours

Case PABR
     When "PKD1" :
           WCOLISE  = sigma(0,[M:PKD1]NBLIG-1,([M:PKD1]SERNUM(indcum)<= WNUMFIN) & ([M:PKD1]SERFIN(indcum)>= WNUMFIN) & (indcum <> PNOL))
           If WCOLISE <> 0
              WCOLISE =  2
           Endif
     When "PKP2" :
           WCOLISE  = sigma(0,[M:PKP2]NBLIG-1,([M:PKP2]SERNUM(indcum)<= WNUMFIN) & ([M:PKP2]SERFIN(indcum)>= WNUMFIN)& (indcum <> PNOL))
           If WCOLISE <> 0
              WCOLISE =  2
           Endif
     When Default:
Endcase
Return

##########################################################################################
# CTRSERPCK_ERR      erreurs suite au controle CTRSERPCK
##########################################################################################
$CTRSERPCK_ERR
Case WCOLISE
     When 1 :  GMESSAGE=WNUMFIN-":"-mess(667,199,1)-" "-mess(255,195,1)-" : "-[F:SPD]PACNUM # Ce n° de série est déjà colisé
     When 2 :  GMESSAGE=WNUMFIN-":"-mess(668,199,1)                                         # Ce n° de série est en cours de colisage
     When Default:
Endcase
Return

########################################################################################
#                                                                      ACTIONS RUBRIQUES
########################################################################################

Subprog AVANT_NBLIG
Local Integer I
I =nolign-1

If [M:SPSE]QTYSTU       (I) = 0
   [M:SPSE]QTYSTU       (I) = abs([M:SPSE]QTY) - sum([M:SPSE]QTYSTU(0..[M:SPSE]NBLIG-1))
   If [M:SPSE]QTYSTU    (I) < 0
      [M:SPSE]QTYSTU    (I) = 0
   Endif
   Affzo [M:SPSE]QTYSTU (I)
Endif
End

###########################################################################
Subprog C_QTYSTU(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL

NOL=nolign-1

# Le nb de no série ne correspond pas à la qté à traiter
If sum([M:SPSE]QTYSTU(0..[M:SPSE]NBLIG-1))-[M:SPSE]QTYSTU(NOL)+VALEUR > [M:SPSE]QTY
   GMESSAGE = mess(246,199,1)
   mkstat=2
   End
Endif

End

##########################################################################
Subprog AM_QTYSTU(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL, WRET, WNBSER
Local    Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)
Local    Integer WCOLISE
NOL                  = nolign-1
[M:SPSE]MODFLG (NOL) = 2

# Il n'y a pas encore de no série saisi
If [M:SPSE]SERNUM(NOL)=""
   End
Endif

# La quantité a diminué
If VALEUR  < [M:SPSE]QTYSTU(NOL)
   WNBSER  = VALEUR
   WNUMDEB = [M:SPSE]SERNUM(NOL)
   If WNBSER=1
      [M:SPSE]SERFIN(NOL) = WNUMDEB
   Else
      Call PLUS_NB(WNUMDEB,WNBSER,WNUMFIN,WRET) From STKLIB
      If WRET=0
         [M:SPSE]SERFIN (NOL) = WNUMFIN
      Else
         mkstat=2
         GMESSAGE=WNUMDEB-":"-mess(476,197,1) # erreur sur incrementation des numeros de series
         End
      Endif
   Endif
   Affzo [M:SPSE]SERNUM(NOL), SERFIN(NOL)
   End
Endif
# La quantité a augmentée
If VALEUR > [M:SPSE]QTYSTU(NOL)
   # Vérification que les no série existent et sont disponibles
   # pour le surplus et alimentation du no série fin
   WNBSER  = VALEUR-[M:SPSE]QTYSTU(NOL)
   WNUMDEB = [M:SPSE]SERFIN       (NOL)
   For J=1 To WNBSER
       Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
       If WRET=0
  #--- Controle no série / à la borne superieure des series à coliser
          If WNUMFIN > [M:SPSE]SERORIFIN
             GMESSAGE=WNUMFIN-":"-mess(669,199,1) # Ce n° de série n'est pas à coliser
             mkstat = 2
             Break
          Endif
          Gosub CTRSERPCK
          If WCOLISE <> 0
             Gosub CTRSERPCK_ERR
             mkstat = 2
             Break
          Endif
           WNUMDEB = WNUMFIN
       Else
          GMESSAGE=WNUMDEB-":"-mess(476,197,1) # erreur sur incrementation des numéros de serie
          mkstat=2
          Break
       Endif
   Next J
   If mkstat=2
      End
   Endif
   [M:SPSE]SERFIN      (NOL) = WNUMFIN
   Affzo [M:SPSE]SERNUM(NOL), SERFIN(NOL)
Endif

End

##########################################################################
Subprog AM_SERNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL, J, WRET, WNBSERIE
Local    Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)
Local    Integer WCOLISE
NOL     = nolign-1
WNUMDEB = VALEUR
WNUMFIN = VALEUR

# le no série doit etre compris dans la tranche des séries à coliser de la ligne du document origine
If VALEUR < [M:SPSE]SERORIDEB | VALEUR > [M:SPSE]SERORIFIN
   GMESSAGE=WNUMFIN-":"-mess(669,199,1) # Ce n° de série n'est pas à coliser
   mkstat = 2
   End
Endif


WNUMFIN = VALEUR
Gosub CTRSERPCK
If WCOLISE <> 0
   Gosub CTRSERPCK_ERR
   mkstat = 2
   End
Endif
If [M:SPSE]QTYSTU (NOL) = 1
   [M:SPSE]SERFIN (NOL) = VALEUR
   [M:SPSE]MODFLG (NOL) = 2
Else
   # Vérification  no série
   # et alimentation du no série fin
   WNBSERIE = [M:SPSE]QTYSTU (NOL)
   WNUMDEB  = VALEUR
   For J=2 To WNBSERIE
       Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
       If WRET=0
# le no série doit etre compris dans la tranche des séries à coliser de la ligne du document origine
          If WNUMFIN > [M:SPSE]SERORIFIN
             GMESSAGE=WNUMFIN-":"-mess(669,199,1) # Ce n° de série n'est pas à coliser
             mkstat = 2
             Break
          Endif
          Gosub CTRSERPCK
          If WCOLISE <> 0
             Gosub CTRSERPCK_ERR
             mkstat = 2
             Break
          Endif
          WNUMDEB = WNUMFIN
       Else
          GMESSAGE=WNUMDEB-":"-mess(476,197,1) # erreur sur incrementation des numéros de serie
          mkstat=2
          Break
       Endif
   Next J
   If mkstat=2
      End
   Endif
   [M:SPSE]SERFIN (NOL) = WNUMFIN
   [M:SPSE]MODFLG (NOL) = 2
Endif
Affzo [M:SPSE]SERFIN (NOL)

End

