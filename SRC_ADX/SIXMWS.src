#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
#  SIXMWS : pour traitements de bascule Integrale --> X3                #
#########################################################################
#                                                                       #
# Subprog SIXMWS                                                        #
#     Création des Postes de charge                                     #   
# PREREQUIS : On a un scéma hebdomadaire (créé manuellement avant)      # 
#                                                                       #
#########################################################################

Call EXEC
End

#########################################################################
Subprog EXEC

Local Integer WOUV_TRACE
If GTRACE = ""
    Call OUVRE_TRACE("SIXMWS : "+SI_MES(1)) From LECFIC
    WOUV_TRACE=1
Endif

Onerrgo TRT_ERR
#---- Création enregistrement WORKSTATIO ------#
Call ECR_TIME("SIXWORKSTATIO : "+mess(213,124,1)+" WORKSTATIO") From DOSSUB
Call SIXWORKSTATIO

$FIN_MWS
If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End



#########################################################################
# Création des postes de charge
#########################################################################
Subprog SIXWORKSTATIO

Local Integer  I, J, WOK, LERR
Local Char WX3_MWS(GLONWST), MESSAGE(250), CRITERE(250)

Gosub VAR_DECL From SIXITM
Gosub OPEN_FILES From SIXITM

Gosub OPEN_FILES

GFCY  = [F:SPX]FCY
Read [FCY]FCY0 = GFCY
If fstat
  MESSAGE= SI_MES(72)
  Call ECR_TRACE(MESSAGE,1) From GESECRAN
  End
Endif
Gosub RECUP_INT_MWS
End

$TRT_ERR
    Call ECR_TRACE( "ligne"-num$(errl)-":"-errm-errmes$(errn), 1) From GESECRAN
Resume


##########################################################
$RECUP_INT_MWS
SI_TABLE  = "XIART"
SI_SUBPRG = "SIXMWS"
Gosub SI_CRITSUP From SIXFONCTION

$LOOP_MWS

CRITERE="1=1"
CRITERE += '& left$(CODART,2) <> "$$"'
CRITERE += '& FLGREP <> 2'
CRITERE += '& ([F:XART]NATPDT = "MO" | [F:XART]NATPDT ="OP")'

LLANGUE = [F:SPX]LAN    # Pour reprise désignations articles

GOK = 1
# Traitement des articles de type "MO" et "OP"
For [XART] Where evalue(CRITERE) & evalue(SI_CRITERE) 
    Call AFFBOITE([F:XART]CODART) From SUBSIM
    Call DEBTRANS From GLOCK
    LERR=0

    Trbegin [MWS]

    Gosub CRE_MWS

    # L'opération a pu être vendue dans Intégrale => il faut créer l'article correespondant
    # Création de l'article
    Gosub CRE_ITM From SIXITM

    # Création de l'article-vente
    If LERR=0
        If [F:ITG]TCLCOD<>[F:ITM]TCLCOD
            Raz [F:ITG]
            Read [ITG]ITG0="";[F:ITM]TCLCOD
        Endif
        If [F:ITG]SALFLG=2
            Gosub CRE_ITS From SIXITM
        Endif
    Endif

    # Création de l'article-client
    If LERR=0
        Gosub CRE_ITU From SIXITM
    Endif

    If LERR=0
        Gosub CRE_ITP From SIXITM
    Endif

    If LERR | GOK<=0 | SI_SIMU=2
        Rollback
    Else
        Readlock [XART] Curr
        [F:XART]FLGREP = 2
        Rewrite [XART]
        Commit
    Endif
Next
# Dernier contrôle sur les  postes de remplacements 
# On ne peut savoir qu'à ce moment là si les postes de remplacements existent bien dans la base
# On ne peut pas le faire en simulation
If SI_SIMU = 2 : Return : Endif 
CRITERE = "1=1"
GOK = 1
# On se sert de l'ecran MWS3 pour supprimer les lignes incorrectes
For [RPW] Where evalue (CRITERE)
    Raz [M:MWS3]
    [M:MWS3]NBLIG = 0
    For I = 0 To 24
        If [F:RPW]RPLWST(I) ="" : Break : Endif
        [M:MWS3]RPLWST(I)    =[F:RPW]RPLWST(I)
        [M:MWS3]RPLWSTDES(I) =[F:RPW]RPLWSTDES(I)
        [M:MWS3]PIO(I)       =[F:RPW]PIO(I)
        [M:MWS3]RPLWCR(I)    =[F:RPW]WCR(I)
        [M:MWS3]RPLWSTTYP(I) =[F:RPW]WSTTYP(I)
    Next I
    [M:MWS3]NBLIG = I 
    If [M:MWS3]NBLIG > 0
        J = 0
        For I = [M:MWS3]NBLIG-1 To 0 Step -1
            Read [F:MWS]WST0 = [M:MWS3]RPLWST(I);[F:RPW]WCRFCY
            If fstat 
                Dela I,1 [M:MWS3]NBLIG
                [M:MWS3]NBLIG -= 1
                J += 1
            Endif
        Next I  
        #Doit-on réécrire l'enregistrement pour le corriger ?
        If J
           Call DEBTRANS From GLOCK
           Trbegin [RPW]
           GOK = 1
           Readlock [F:RPW]RPW0 Curr 
           For I=0 To 24
                If I<[M:MWS3]NBLIG 
                    [F:RPW]RPLWST(I)    = [M:MWS3]RPLWST(I)
                    [F:RPW]RPLWSTDES(I) = [M:MWS3]RPLWSTDES(I)
                    [F:RPW]PIO(I)       = [M:MWS3]PIO(I)
                    [F:RPW]WCR(I)       = [M:MWS3]RPLWCR(I)
                    [F:RPW]WSTTYP(I)    = [M:MWS3]RPLWSTTYP(I)
                Else
                    [F:RPW]RPLWST(I)    =""
                    [F:RPW]RPLWSTDES(I) =""
                    [F:RPW]PIO(I)       =0 
                    [F:RPW]WCR(I)       =""
                    [F:RPW]WSTTYP(I)    =0
                Endif
            Next I
            Rewrite [F:RPW]
            If GOK<= 0 : Break : Endif
            Commit
        Endif
    Endif
Next
If GOK<=0
     Rollback
Endif
     
Return

####################################################
# Création des enregistrements WORKSTATIO
$CRE_MWS
If SI_SIMU = 1
    #Le centre de charge a-t-il deja ete cree ?
    Read [F:TWC]TWC0 = "PROD"
    If fstat 
        Raz [F:TWC]
        [F:TWC]WCR     = "PROD"
        [F:TWC]WCRDES  = "Production"
        Call MAJTEXTRA([F:TWC]WCRDES,"TABWRKCTR","WCRDESAXX",[F:TWC]WCR,"") From ATEXTRA
        [F:TWC]DSPLEV  = 1
        [F:TWC]CREUSR  = GUSER
        [F:TWC]CREDAT  = date$
        SI_TABLE = "TABWRKCTR"
        Gosub SI_BEFWRI From SIXFONCTION
        If SI_SIMU = 1
            Write [TWC]
            If fstat 
               MESSAGE=mess(56,123,1)+" TABWRKCTR : "-func SIXFONCTION.FSTATMSG(fstat) : # Table TABWRKCTR  Erreur = x
               Call ECR_TRACE(MESSAGE,1) From GESECRAN
               GOK=0  
            Else
               MESSAGE = [F:TWC]WCR -SI_MES(23)
               Call ECR_TRACE(MESSAGE,0) From GESECRAN
            Endif
        Else
            MESSAGE = [F:TWC]WCR - SI_MES(23)
            Call ECR_TRACE(MESSAGE,0) From GESECRAN
        Endif
    Endif    
    If GOK = 0 : Return : Endif
Endif
Raz [F:MWS]
If !func SIXFONCTION.SI_CTL("WST",[F:XART]X3CLE,"XIART ("+[F:XART]CODART+")")
    GOK=0
    Return
Else
    [F:MWS]WST    = [F:XART]X3CLE
Endif
[F:MWS]WSTDES = [F:XART]DGN
Case [F:XART]NATPDT
    When "OP" : [F:MWS]WSTTYP = 1
    When "MO" : [F:MWS]WSTTYP = 2
Endcase
[F:MWS]WCR    = "PROD"
Read [F:TWD]TWD0  = [F:SPX]DEFTWD
If fstat
   Call TEXTE(1809,MESSAGE) From OBJDIV    # Schéma hebdomadaire
   MESSAGE-=mess(23,100,1)-":'"+[F:SPX]DEFTWD+"'"
   Call ECR_TRACE(MESSAGE,1) From GESECRAN
   GOK=0
   Return 
Endif

[F:MWS]RPLAUTO   = 1
[F:MWS]SBBFLG    = 1
[F:MWS]TWD       = [F:TWD]TWD
[F:MWS]EFF       = 100
[F:MWS]USE       = 100
[F:MWS]WSTNBR    = 1
[F:MWS]CLEPCTAUT = 100
[F:MWS]DSPLEV    = 1
[F:MWS]RCCP      = 1
[F:MWS]RPLAUTO   = 1
[F:MWS]SBBFLG    = 1
[F:MWS]CREDAT    = date$
[F:MWS]CREUSR    = GUSER

For [FCY] Where MFGFLG=2    # On crée le poste sur chaque site de prod
    [F:MWS]WCRFCY = [F:FCY]FCY
    Call MAJTEXTRA([F:MWS]WSTDES,"WORKSTATION","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
    Call MAJTEXTRA([F:MWS]WSTSHO,"WORKSTATION","WSTDESSHO",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA

    SI_TABLE = "WORKSTATIO"
    Gosub SI_BEFWRI From SIXFONCTION
    If SI_SIMU = 1
        Write [MWS]
        If fstat 
           MESSAGE=mess(56,123,1)+" WORKSTATIO : "-func SIXFONCTION.FSTATMSG(fstat) : # Table WORKSTATIO  Erreur = x
           Call ECR_TRACE(MESSAGE,1) From GESECRAN
           GOK=0  
        Else
           MESSAGE = [F:MWS]WST+";"+[F:MWS]WCRFCY -SI_MES(24)
           Call ECR_TRACE(MESSAGE,0) From GESECRAN
        Endif
    Else
        MESSAGE = [F:MWS]WST+";"+[F:MWS]WCRFCY - SI_MES(24)
        Call ECR_TRACE(MESSAGE,0) From GESECRAN
    Endif
Next
#Récupérer evéntuellement les articles de remplacement dans la table des postes de remplacement 
Raz [F:RPW]
Filter [F:XRPC] Where CODART= [F:XART]CODART
I   = 0
WOK = 0
For [F:XRPC]
    WOK += 1
    If I = 0
       [F:RPW]WST     = [F:MWS]WST
       [F:RPW]WCRFCY  = GFCY
    Endif
    If I = 25 : Break : Endif
    Raz WX3_MWS
    Read [F:XAR1]IND0 = [F:XRPC]ARTRPC
    If !fstat & find ([F:XAR1]NATPDT,"OP","MO")
        WX3_MWS = func SIXFONCTION.SI_COR("XIART",[F:XRPC]ARTRPC,"","") 
        If func SIXFONCTION.SI_CTL("WST",WX3_MWS,"XIART ("+[F:XAR1]CODART+")")
            [F:RPW]RPLWST(I)     = [F:XAR1]X3CLE
            [F:RPW]RPLWSTDES(I)  = [F:XAR1]DGN
            [F:RPW]WCR(I)        = "PROD"
            Case [F:XAR1]NATPDT
                When "OP" : [F:RPW]WSTTYP(I) = 1
                When "MO" : [F:RPW]WSTTYP(I) = 2
            Endcase
            [F:RPW]PIO(I) = [F:XRPC]NUMORD
            I += 1
        Endif
    Endif
Next
If WOK
    [F:RPW]CREDAT    = date$
    [F:RPW]CREUSR    = GUSER

    SI_TABLE = "RPLWST"
    Gosub SI_BEFWRI From SIXFONCTION
    If SI_SIMU = 1
        Write [RPW]
        If fstat 
           MESSAGE=mess(56,123,1)+" RPLWST : "-func SIXFONCTION.FSTATMSG(fstat) : # Table RPLWST  Erreur = x
           Call ECR_TRACE(MESSAGE,1) From GESECRAN
           GOK=0  
        Else
           MESSAGE = [F:RPW]WST - SI_MES(25)
           Call ECR_TRACE(MESSAGE,0) From GESECRAN
        Endif
    Else
       MESSAGE = [F:RPW]WST - SI_MES(25)
       Call ECR_TRACE(MESSAGE,0) From GESECRAN
    Endif
Endif
    
Return

################################################################
$OPEN_FILES
If !clalev([F:MWS])  : Local File =SI_DOSSIER+".WORKSTATIO" [MWS] : Endif
If !clalev([F:RPW])  : Local File =SI_DOSSIER+".RPLWST"     [RPW] : Endif
If !clalev([F:TWC])  : Local File =SI_DOSSIER+".TABWRKCTR"  [TWC] : Endif
If !clalev([F:TUN])  : Local File =SI_DOSSIER+".TABUNIT"    [TUN] : Endif
If !clalev([F:TWD])  : Local File =SI_DOSSIER+".TABWEEDIA"  [TWD] : Endif
If !clalev([F:FCY])  : Local File =SI_DOSSIER+".FACILITY"   [FCY] : Endif

If !clalev([F:XART]) : Local File =SI_DOSSIER+".XIART"     [XART] : Endif
If !clalev([F:XAR1]) : Local File =SI_DOSSIER+".XIART"     [XAR1] : Endif
If !clalev([F:XUNI]) : Local File =SI_DOSSIER+".XIUNIFAC"  [XUNI] : Endif
If !clalev([F:XRPC]) : Local File =SI_DOSSIER+".XIARTRPC"  [XRPC] : Endif
If !clalev([F:SPX])  : Local File =SI_DOSSIER+".SIPARX3"   [SPX] : Endif

If !clalev([M:MWS3])  : Local Mask =SI_DOSSIER+".MWS3"     [MWS3] : Endif
Return

