#################################################
## Pour la gestion des contacts
#################################################
$APRES_MODIF
  # On a modifié COUZON
  # FGR 14/08/2014 : X3SUIVI95632 : Modif contacts interdite si GESAIN en tunnel
  If find("GESAIN", GNAVIG(1..GPILNAV-1)) <> 0 Then
    mkstat = 2
    GMESSAGE = mess(1148,196,1)
    Return
  Endif
Return

#################################################
$CHARGE_RIB
  # FGR 19/06/2014 : X3SUIVI100757
  If TYP = 1 Then
    [L]DEFBID = "~"
  Elsif TYP = 3 Then
    # Dans le cas d'un site/tiers on gère les banques comme pour les tiers.
    Read [BPR]BPR2(2)=2;[F:FCY]FCY
    If fstat = 0 Then
      [L]DEFBID = "~"
    Endif
    # Issue X3-76262 - 2018-02-27 by MAE : comment
    [G:BPR]currind=1 : [G:BPR]currlen=0 : # Réinitialisation clé par défaut
  Endif

#MAPAD - X3-88967 - 2016-08-16 - START
  If (GMODU(15)=2 | GMODU(20)=2) & (GMODU(2)<>2)
    If GFONCTION='GESFCY' & func DIVPAYE.EXISTE_KXX("TRTBPAUKI") & func AFNC.ACTIV("KUK")>0 Then # Site and UK activity code
       Call UKI_FIELDS From TRTBPAUKI
    Endif
  Endif
#MAPAD - X3-88967 - 2016-08-16 - START
Return

#################################################################
## Pour la gestion des codes adresses dans les RIB des tiers
#################################################################
$CRERIB
  # Pour gérer les RIB par défaut des adresses tiers
  If [M]NUMBPA = 1 Then
    [L]DEFBID = "~"
  Elsif [M]NUMBPA = 3 Then
    # # FGR 19/06/2014 : X3SUIVI100757 : Dans le cas d'un site/tiers on gère les banques comme pour les tiers.
    Read [BPR]BPR2(2)=2;[F:FCY]FCY
    If fstat = 0 Then
      [L]DEFBID = "~"
    Endif
  Endif
Return

$C_BIDNUM
Local Integer I,J
# Si gestion des tiers
If [M]NUMBPA=1
  #Local Char    WBIDNUM(GLONBID)(30)                      # FGR 14/08/2015 : X3SUIVI110347
  #Local Integer WLIG(30)                                  # FGR 14/08/2015 : X3SUIVI110347
  Local Char    WBIDNUM(GLONBID)(dim([M]BIDBPAADD))        # FGR 14/08/2015 : X3SUIVI110347
  Local Integer WLIG(dim([M]BIDBPAADD))                    # FGR 14/08/2015 : X3SUIVI110347
  NOL=nolign-1
  # Chargement des RIB de la même adresse dans le tableau WBIDNUM
  For I=0 To [M]NBRIB-1
    If I<>nolign-1
      If [M]BIDBPAADD(I)=[M]BIDBPAADD(NOL)
        WBIDNUM(J) = [M]BIDNUM(I)
        WLIG(J)    = I+1
        J+=1
      Endif
    Endif
  Next I
  # Si tableau WBINUM non vide, test d'unicité du RIB
  If J<>0
    I = find(VALEUR,WBIDNUM(0..J-1))
    If I
      GERR=1 : GMESSAGE = mess(24,123,1)-num$(WLIG(I-1))
      mkstat=2
    Endif
  Endif
Else
#MAE, le 08/10/2010, bg66884
  #Call UNICITE(VALEUR, [M]BIDNUM) From OBJDIV
  Call UNICITE(VALEUR, [M]BIDBPAADD) From OBJDIV
Endif
If mkstat : OK = 0 : Endif
Return

$AM_BIDNUMFLG
Local Integer I,J,WNEXT

If VALEUR=2
  # Si gestion des tiers
  If [M]NUMBPA=1
    Local Integer WNEXT, J
    WNEXT=1 : J=0
    While WNEXT=1
      I = find (2,[M]BIDNUMFLG (J..[M]NBRIB-1))
      If I
        If [M]BIDBPAADD(I+J-1)=[M]BIDBPAADD(nolign-1)
          [M]BIDNUMFLG(I+J-1) = 1 : Affzo [M]BIDNUMFLG(I+J-1)
          [M]FLMOD(I+J-1)     = 1
          WNEXT=0
        Else
          J+=I
          If J>=[M]NBRIB WNEXT=0 Endif
        Endif
      Else
        WNEXT=0
      Endif
    Wend
  Else
    I = find (2,[M]BIDNUMFLG (0..[M]NBRIB -1))
    If I
      [M]BIDNUMFLG(I-1) = 1 : Affzo [M]BIDNUMFLG(I-1)
      [M]FLMOD(I-1)     = 1
    Endif
  Endif
Endif
Return

#################################################
## Société pour le bouton copie
#################################################
$GETSOC
Local Char SOCIETE(GLONCPY)
If dim([M:FCY1]LEGCPY)>0
 SOCIETE = [M:FCY1]LEGCPY
Endif
Return

#################################################
## Init contact en fonction du contexte
#################################################
$INIT_CNT
Local Char WTIERS(GLONBPR)

  # -------------------------------------
  Gosub INIT_NUMBPA  # FGR 17/12/2012 : X3SUIVI86588
  # -------------------------------------
  If    dim([M:BPR0]BPRNUM)>0
   WTIERS = [M:BPR0]BPRNUM
  Elsif dim([M:BPC0]BPCNUM)>0
   WTIERS = [M:BPC0]BPCNUM
  Elsif dim([M:BPP0]BPCNUM)>0
   WTIERS = [M:BPP0]BPCNUM
  Elsif dim([M:BPS0]BPSNUM)>0
   WTIERS = [M:BPS0]BPSNUM
  Elsif dim([M:BPT0]BPTNUM)>0
   WTIERS = [M:BPT0]BPTNUM
  Endif
  Read [CNT]CNT0=1;WTIERS;VALEUR
  If !fstat
   [M] = [F:CNT]
   [M]CNTADD(NOL) = [F:CNT]BPAADD
   [M]CNTTEL(NOL) = [F:CNT]TEL
   [M]CNTFAX(NOL) = [F:CNT]FAX
   [M]CNTWEB(NOL) = [F:CNT]WEB
   [M]CNTFLG(NOL) = 2
   [M]FLNEW(NOL)  = 1
  Endif
Return

#################################################
## Init adresse en fonction du contexte
#################################################
$INIT_BPA
  # -------------------------------------
  Gosub INIT_NUMBPA  # FGR 17/12/2012 : X3SUIVI86588
  # -------------------------------------
  # FGR 15/07/2010 : X3SUIVI66067 (début)
  If dim([M:AUS1]TELEP)>0
    #[M]TEL(NOL) = [M:AUS1]TELEP
    [M]TEL1(NOL) = [M:AUS1]TELEP
  Endif
  If dim([M:AUS1]FAX)>0
    #[M]FAX(NOL) = [M:AUS1]FAX
    [M]TEL2(NOL) = [M:AUS1]FAX
  Endif
  If dim([M:AUS1]ADDEML)>0
    #[M]WEB(NOL) = [M:AUS1]ADDEML
    [M]WEB1(NOL) = [M:AUS1]ADDEML
  Endif
  # FGR 15/07/2010 : X3SUIVI66067 (fin)

  # Initialisation de la raison sociale en fonction de l'objet
  If dim([M]NAM1)>0
   If dim([M:AUS0]NOMUSR)>0
    [M]NAM1(NOL) = [M:AUS0]NOMUSR
   Elsif dim([M:CPY0]CPYNAM)>0
    [M]NAM1(NOL) = [M:CPY0]CPYNAM
   Elsif dim([M:FCY0]FCYNAM)>0
    [M]NAM1(NOL) = [M:FCY0]FCYNAM
   Elsif dim([M:GAC0]DES)>0
    [M]NAM1(NOL) = [M:GAC0]DES
   Elsif dim([M:BUD0]DES)>0
    [M]NAM1(NOL) = [M:BUD0]DES
   Elsif dim([M:COL0]DES)>0
    [M]NAM1(NOL) = [M:COL0]DES
   Elsif dim([M:SVC0]DES)>0
    [M]NAM1(NOL) = [M:SVC0]DES
   Endif
  Endif
Return

#################################################
## Init RIB en fonction du contexte
#################################################
$INIT_BID
  # -------------------------------------
  Gosub INIT_NUMBPA  # FGR 17/12/2012 : X3SUIVI86588
  # -------------------------------------
  If dim([M]BNF)>0 & [M]BNF(nolign-1)=""
   If nolign>1
    [M]BNF(nolign-1) = [M]BNF(nolign-2)
   Else
    If dim([M:AUS0]NOMUSR)>0
     [M]BNF(nolign-1) = [M:AUS0]NOMUSR
    Elsif dim([M:CPY0]CPYNAM)>0
     [M]BNF(nolign-1) = [M:CPY0]CPYNAM
    Elsif dim([M:FCY0]FCYNAM)>0
     [M]BNF(nolign-1) = [M:FCY0]FCYNAM
    Elsif dim([M:GAC0]DES)>0
     [M]BNF(nolign-1) = [M:GAC0]DES
    Endif
   Endif
  Endif
Return

##################################################################################################
$INIT_NUMBPA
  # -------------------------------------
  # FGR 17/12/2012 : X3SUIVI86588 (début) ML943
  Case GFONCTION
    When "GESBPR", "GESBPP", "GESBPC", "GESBPS", "GESREP", "GESBPT"
      # Tiers
      [M]NUMBPA = 1
    When "GESCPY"
      # Société
      [M]NUMBPA = 2
    When "GESFCY"
      # Site
      [M]NUMBPA = 3
    When "GESAUS"
      # Utilisateur
      [M]NUMBPA = 4
    When "GESGAC"
      # Compte
      [M]NUMBPA = 5
    When "GESLDS"
      # Leads
      [M]NUMBPA = 6
  Endcase
  # FGR 17/12/2012 : X3SUIVI86588 (fin)
  # -------------------------------------
Return

##################################################################################################
$ECRIT_CNT  # FGR 02/04/2010 : X3SUIVI63506
Local Char SZCNTNUM(GLONAIN)
Local Integer IBERROR
Local Integer SVNOLIGN
Local Char SVNBPR(GLONBPR)

  #MAE, bg 77134, la lecture est faite sous une autre abréviation afin de ne pas écraser le tiers courant
  If clalev ([F:BPR1])=0 : Local File BPARTNER [BPR1] : Endif
  SVNBPR=""
  SVNOLIGN = nolign
  SZCNTNUM = [F:AIN]CNTNUM
  If LTYP = 1 Then
    # FGR 26/04/2010 : X3SUIVI64326 : Dans la suppression de tiers, la suppression des contacts n'était
    #                  pas prise en compte. Il faut le faire maintenant.
    #Local File BPARTNER [BPR]
    #Local File CONTACT [CNT]          # Issue X3-38495 - 2017-11-22 by FGR
    For [CNT]CNT0 Where BPATYP = LTYP and CCNCRM = SZCNTNUM
      Read [BPR1]BPR0=[F:CNT]BPANUM
      If fstat Then
        # Le tiers n'existe plus : on supprime (pour nettoyer) le contact
        Call ANNCNT(LTYP, [F:CNT]BPANUM) From TRTBPA
      Endif
    Next
    #Close Local File [BPR]
    #Close Local File [CNT]            # Issue X3-38495 - 2017-11-22 by FGR
  Endif
  #Local File BPARTNER [BPR]   # FGR 05/07/2011 : X3SUIVI74564
  #MAE, bg 77134
  #Sauvegarde du bpr qui est perdu dans DEFVAR from GOBJET de UPDAIN
  If clalev([F:BPR])<>0  SVNBPR = [F:BPR]BPRNUM : Endif

  Call UPDAIN("", 1, 0, SZCNTNUM, IBERROR) From SUBAINCM
  #MAE, bg 77134
  #Restitution du tiers
  If clalev([F:BPR])<>0
      If [F:BPR]BPRNUM <> SVNBPR
        Read [BPR]BPR0=SVNBPR
      Endif
  Endif

  If IBERROR Then
    nolign = SVNOLIGN
    #Close Local File [BPR]    # FGR 05/07/2011 : X3SUIVI74564  # FGR 25/04/2012 : X3SUIVI81829 pas de raison de fermer BPR
    # FGR 20/07/2010 (début)
    If dim(GAINMESSAGE) >= 0 Then
      GMESSAGE = GAINMESSAGE
      Kill GAINMESSAGE
    Endif
    # FGR 20/07/2010 (fin)
    GOK = 0
    Goto FIN_ECRIT_CNT
    #Return
  Endif
  #Close Local File [BPR]      # FGR 05/07/2011 : X3SUIVI74564
  nolign = SVNOLIGN
$FIN_ECRIT_CNT
Close Local File [BPR1]
Return

##################################################################################################
$CRECNT_BEGIN
Local Integer IBERROR

  # FGR 27/11/2013 : X3SUIVI94714
  If GMODU(13) <> 2 Then
    # S'il n'y a pas le module CRM ne rien faire
    Return
  Endif
  If GCRMSYNC <> 2 or GCRMSYNCCOR <> 2 Then
    # S'il n'y a pas la synchro Outlook ou si les contacts ne sont pas synchronisés ne rien faire
    Return
  Endif
  # ------------------------------------------------------
  Gosub COR_DEL_OPENTABLE
  # ------------------------------------------------------
  For [CNT]CNT0 Where BPATYP = LTYP and BPANUM = ENTITE
    If !find([F:CNT]CCNCRM,[M]CCNCRM(0..[M]NBCNT-1)) Then
      # Ce contact a été supprimé
      WCCNCRM =[F:CNT]CCNCRM                                    # hcb 96715
      WBPANUM =[F:CNT]BPANUM                                    # hcb 96715
      Gosub COR_DEL_MANAGEMENT
      If IBERROR Then
        GOK = -1
        Break
      Endif
    Endif
  Next
  If GOK < 1 Then
    Return
  Endif
Return

##################################################################################################
$ANNCNT_BEGIN
Local Integer IBERROR

  # FGR 27/11/2013 : X3SUIVI94714
  If GMODU(13) <> 2 Then
    # S'il n'y a pas le module CRM ne rien faire
    Return
  Endif
  If GCRMSYNC <> 2 or GCRMSYNCCOR <> 2 Then
    # S'il n'y a pas la synchro Outlook ou si les contacts ne sont pas synchronisés ne rien faire
    Return
  Endif
  # ------------------------------------------------------
  Gosub COR_DEL_OPENTABLE
  # ------------------------------------------------------
  #MAE, bg 96572
  #For [CNT]CNT0 Where BPATYP = LTYP and BPANUM = ENTITE
  For [CNT1]CNT0 Where BPATYP = LTYP and BPANUM = ENTITE
    WCCNCRM =[F:CNT1]CCNCRM                                    # hcb 96715
    WBPANUM =[F:CNT1]BPANUM                                    # hcb 96715
    Gosub COR_DEL_MANAGEMENT
    If IBERROR Then
      Break
    Endif
  Next
  If GOK < 1 Then
    Return
  Endif
Return

##################################################################################################
$COR_DEL_OPENTABLE
Local Char SZTEXTE(type(GMESSAGE)-10)

  # Issue X3-38495 - 2017-11-22 by FGR : BEGIN to not corrupt caller's context
  Local File COMPANY    [CPY]
  Local File FACILITY   [FCY]
  Local File BPARTNER   [BPR]
  Local File BPCUSTOMER [BPC]
  Local File BPSUPPLIER [BPS]
  Local File BPCARRIER  [BPT]
  Local File TABCOUNTRY [TCY]
  Local File CONTACTCRM [AIN]
  Local File CONTACT    [CNT]
  Local File CORRESPOND [COR]
  Local File BPADDRESS  [BPA]
  Local File BID        [BID]
  # Issue X3-38495 - 2017-11-22 by FGR : END
  # FGR 27/11/2013 : X3SUIVI94714
  Local File CORRESPOND [CORL]
  #MAE, bg 96572
  Local File CONTACT [CNT1]
  Local Char WCCNCRM(GLONAIN)     # hcb 96715
  Local Char WBPANUM(GLONBPN)     # hcb 96715
Return

##################################################################################################
$COR_DEL_MANAGEMENT
  # FGR 27/11/2013 : X3SUIVI94714
  For [CORL] Where [F:CORL]CNTNUM = WCCNCRM and [F:CORL]CORTYP = "AIN" and [F:CORL]BPRNUM = WBPANUM    # hcb 96715
    # On supprime le correspondant associé au contact
    Call DELCOR("TRTBPAB", 1, 0, [F:CORL]CORNUM, IBERROR) From SUBCORCA
    If IBERROR Then
      If GMESSAGE = "" Then
        Call TEXTE(15307, SZTEXTE) From OBJDIV
        GMESSAGE = mess(815,196,1) - SZTEXTE - ":" - [F:CORL]CORNUM
      Endif
      GOK = -1
      Break
    Endif
  Next
Return

