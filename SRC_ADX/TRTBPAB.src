   If func AFNC.ACTIV("KZA")>0 & func DIVPAYE.EXISTE_KXX("TRTBPAKSA") Then
     Gosub ADD_BPA From TRTBPAKSA
   Endif
   # Issue X3-112874 - 2018-10-15 by BRBAN : Must be commented until KPO developments are finish
