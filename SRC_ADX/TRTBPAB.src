 If func AFNC.ACTIV("KZA")>0 & func DIVPAYE.EXISTE_KXX("TRTBPAKSA") Then
    Call CRECNT_KSA(NUMBPA,ENTITE) From TRTBPAKSA
 Endif
Endif
