#    Gosub REMP_ADRB From TRTBPAKPO
# Endif
Endif
Return

$REMP_CNTB
If (GMODU(15)=2 | GMODU(20)=2)
  If func AFNC.ACTIV("KZA")>0 & func DIVPAYE.EXISTE_KXX("TRTBPAKSA") Then
    Gosub REMP_CNT_KSA From TRTBPAKSA
  Endif
Endif
