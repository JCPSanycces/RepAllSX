#<AdxTL>@(#)11.0.0.0 $Revision$
Local Char PARAM(30)(1..4) , VALEUR(80)
PARAM(1) = "ZBY" : PARAM(2) = "1" : PARAM(3) = "2"
VALEUR = "$ZBY.A(L1:3(5))"
VALEUR = "DB(PYR.DEB)"
VALEUR = "1..2"
#GFCYDEF="" : GDEFSOC=""
Call TRAITE_CHAR(VALEUR,PARAM,"","TXSWIZ","TXSWIZ",3,"") From GTRAITE
Infbox VALEUR
End


$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "SORTIE"      : Gosub SORTIE
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "FIN_TABLE"   : Gosub FIN_TABLE
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When Default
Endcase
Return

$INIT
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:LED])=0 : Local File GLED       [LED] : Endif
If clalev([F:GCM])=0 : Local File GACM       [GCM] : Endif
If clalev([F:GYM])=0 : Local File GACCPYM    [GYM] : Endif
If clalev([F:GRY])=0 : Local File GACCGRUPYM [GRY] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:CYM])=0 : Local File GCCEPYM    [CYM] : Endif
If clalev([F:CRY])=0 : Local File GCCEGRUPYM [CRY] : Endif
If clalev([F:CCE])=0 : Local File CACCE      [CCE] : Endif
If clalev([F:BUP])=0 : Local File BUDPAR     [BUP] : Endif
If clalev([F:BUV])=0 : Local File BUDVER     [BUV] : Endif
If clalev([F:TXS])=0 : Local File TXSA       [TXS] : Endif
If clalev([F:TXD])=0 : Local File TXSD       [TXD] : Endif
If clalev([F:TXW])=0 : Local File TXSW       [TXW] : Endif
If clalev([M:TXA2])=0: Local Mask TXSA2      [TXA2]: Endif
If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif
Return

$INIT_DIA
Local Char    CHAINE(250) , QUOTE(1)
Local Integer I , J , K
Read [FCY]FCY0 = GFCYDEF
Raz [M]
Actzo
[M]CPY    = [F:FCY]LEGCPY
If [M]CPY=""
 [M]CPY = GDEFSOC
Endif
[M]TABCUR = PARAM(1)
[M]DEFGEN = val(PARAM(2))
[M]DEFANA = val(PARAM(3))
[M]VALCUR = VALEUR
Return

$EXEC
Call CAL_FORMULE(VALEUR)
Return

$SORTIE
Read [TXS]TXS0 = [M]TABCUR
Return

Subprog CAL_FORMULE(VALEUR)
Variable Char VALEUR()
Local Char    CHAINE(250) , QUOTE(1)
Local Integer I , J , K , FLPAR
Case [M]TYPMNT
 When 1 : Gosub CPT_GEN
 When 2 : Gosub CPT_ANA
 When 3 : Gosub CPT_BUD
 When 4 : Gosub SOMME
 When 5 : If [M]EXPR<>""
           CHAINE = "R("+[M]EXPR+")"
          Else
           CHAINE = ""
          Endif
 When 6 : CHAINE = [M]VARIA
Endcase
If [M]INV=2
 CHAINE = "-"+CHAINE
Endif
VALEUR = CHAINE
End

$CPT_GEN
Call REFERENTIEL([M]REFGEN,[M]DEFGEN,CHAINE)
Case [M]CATMNT
 When 1 : CHAINE += ""
 When 2 : CHAINE += "D"
 When 3 : CHAINE += "C"
 When 4 : CHAINE += "MD"
 When 5 : CHAINE += "MC"
Endcase
Case [M]TYPBAL
 When 1 : If [M]MQ=2 : CHAINE += "Q" : Endif
 When 2 : If [M]MQ=2 : CHAINE += "QE" : Else : CHAINE += "ME" : Endif
 When 3 : If [M]MQ=2 : CHAINE += "QP" : Else : CHAINE += "MP" : Endif
Endcase
Case [M]TYPEXT
 When 1
  FLPAR = 0
  If CHAINE<>""
   CHAINE += "("
   FLPAR   = 1
  Endif
  QUOTE = ""
  If vireblc(format$("K:15#",[M]CLSDEB),2)<>[M]CLSDEB
   QUOTE = '"'
  Endif
  If [M]CLSFIN<>"" & vireblc(format$("K:15#",[M]CLSFIN),2)<>[M]CLSFIN
   QUOTE = '"'
  Endif
  CHAINE += QUOTE+[M]CLSDEB
  If [M]CLSFIN<>"" & [M]CLSFIN<>[M]CLSDEB
   CHAINE += ".."+[M]CLSFIN
  Elsif [M]CLSEXC<>""
   CHAINE += "("+right$([M]CLSEXC,len([M]CLSDEB)+1)+")"
  Endif
  CHAINE += QUOTE
  If FLPAR
   CHAINE += ")"
  Endif
 When 2
  If [M]DETAIL=2
   CHAINE += "I"
  Else
   CHAINE += "H"
  Endif
  CHAINE += "("+[M]COLL+")"
 When 3
  If [M]DETAIL=2
   CHAINE += "A"
  Else
   CHAINE += "B"
  Endif
  CHAINE += num$(NUMBIL)+"("+BILAN+")"
 When 4
  If [M]DETAIL=2
   CHAINE += "A"
  Else
   CHAINE += "B"
  Endif
  CHAINE += "("+[M]PYRAM+"."+[M]GRPCPT+")"
Endcase
Return

$CPT_ANA
Call REFERENTIEL([M]REFANA,[M]DEFANA,CHAINE)
Case [M]TYPBAL
 When  1 : CHAINE += "N"
 When  2 : CHAINE += "E"
 When  3 : CHAINE += "P"
Endcase
Case [M]MQ
 When 1 : CHAINE += "M"
 When 2 : CHAINE += "Q"
Endcase
CHAINE += "("

$NATSEC
If [M]NAT<>""
 CHAINE += [M]NAT
Elsif [M]NATPYR<>""
 CHAINE += [M]NATPYR+"."+[M]NATGRP
Else
 CHAINE += "*"
Endif
For I=0 To [M]NBLIG-1
 If [M]SEC(I)<>""
  CHAINE += ","+[M]SEC(I)
 Elsif [M]SECPYR(I)<>""
  CHAINE += ","+[M]SECPYR(I)+"."+[M]SECGRP(I)
 Else
  CHAINE += ",*"
 Endif
Next I
CHAINE += ")"
Return

$CPT_BUD
CHAINE = ""
Case [M]MQ
 When  1 : CHAINE += "GM"
 When  2 : CHAINE += "GQ"
Endcase
CHAINE += "("+[M]BUD+","+[M]VER+","
Gosub NATSEC
Return

Subprog REFERENTIEL(R1,R2,CHAINE)
Value    Integer R1
Value    Integer R2
Variable Char    CHAINE()
Local Integer I , J , N , OK
CHAINE = ""
If R1=R2 : End : Endif
CHAINE = "["+num$(R1)+"]"
End
#
# Finalement on met toujours le no (cf bug 53104)
#
N = len(mess(R1,2644,1))
For I=1 To len(mess(R1,2644,1))
 OK = 1
 For J=1 To len(mess(0,2644,1))
  If J<>R1 & left$(mess(J,2644,1),I)=left$(mess(R1,2644,1),I)
   OK = 0 : Break
  Endif
 Next J
 If OK
  N = I : Break
 Endif
Next I
CHAINE = "["+left$(mess(R1,2644,1),N)+"]"
CHAINE = ctrans(CHAINE," ","_")
End

$SOMME
CHAINE = "L"+num$([M]LIGDEB)
If [M]LIGFIN<>0 & [M]LIGFIN<>[M]LIGDEB
 CHAINE += ":"+num$([M]LIGFIN)
Endif
If [M]COLONNE<>0
 CHAINE += "("+num$([M]COLONNE)+")"
Endif
If [M]TABLO<>""
 CHAINE = "$"+[M]TABLO+"."+[M]VERSION+"("+CHAINE+")"
Elsif [M]VERSION<>""
 CHAINE = "$"+[M]VERSION+"("+CHAINE+")"
Endif
Return

######################################################################################
## Ecran TXSWIZ
######################################################################################
$SEL_TABLE
Case COUZON
 When "GRPCPT"
  OBJET = "GRY"
  CRITERE = 'PYM="'+[M]PYRAM+'"'
 When "BUD"
  OBJET = "BUP"
  If clalev([F:LED])=0 : Local File GLED [LED] : Endif
  If [F:GCM]GCM<>""
   For I=1 To dim([F:GCM]LED)
    If [F:GCM]LED(I-1)<>"" & [F:GCM]CFMAUT(I-1)<>2 & (I=1 | !find([F:GCM]LED(I-1),[F:GCM]LED(0..I-2)))
     Read [F:LED]LED0=[F:GCM]LED(I-1)
     If !fstat
      If len(CRITERE)=0
       CRITERE = 'COA="'+[F:LED]COA+'"'
      Else
       CRITERE += '| COA="'+[F:LED]COA+'"'
      Endif
     Endif
    Endif
   Next
  Endif
 When "CLSDEB","CLSFIN","CLSEXC","NAT"
  OBJET = "GAC"
  SUPP  = [M]COA
 When "PYRAM","NATPYR"
  OBJET = "GYM"
  CRITERE = 'COA="'+[M]COA+'"'
 When "NATGRP"
  OBJET = "GRY"
  CRITERE = 'PYM="'+[M]NATPYR+'"'
  Call LECTURE("BUP",[M]BUD,"") From CONTOBJ
  If [F:BUP]PYMACC<>""
   CRITERE -= '& LEV<='+num$([F:BUP]PYMACCLEV)
  Endif
 When "SEC"
  OBJET = "CCE"
  SUPP  = [M]AXE(nolign-1)
 When "SECPYR"
  OBJET = "CYM"
  CRITERE = 'DIE="'+[M]AXE(nolign-1)+'"'
 When "SECGRP"
  OBJET = "CRY"
  CRITERE = 'PYM="'+[M]SECPYR(nolign-1)+'"'
  Call LECTURE("BUP",[M]BUD,"") From CONTOBJ
  Local Integer BUDPYM
  BUDPYM = find([M]SECPYR(nolign-1),[F:BUP]PYMCCE)
  If BUDPYM & [F:BUP]PYMCCE(BUDPYM-1)<>""
   CRITERE -= '& LEV<='+num$([F:BUP]PYMCCELEV(BUDPYM-1))
  Endif
 When "TABLO"
  OBJET = "TXS"
 When "VERSION"
  OBJET = "TXW"
  CRITERE = 'TXSNAM="'+[M]TABLO+'"'
 When "VER"
  OBJET = "BUV"
  CRITERE = 'BUD="'+[M]BUD+'"'
Endcase
Return

$FIN_TABLE
Case COUZON
 When "GRPCPT","NATGRP","SECGRP"
  VALEUR = [F]GRU
 When "VERSION"
  VALEUR = [F]VERSION
Endcase
Return

######################################################################################
$SEL_LISTE
Case COUZON
 When "LIGDEB","LIGFIN" : Gosub SEL_LIGNE
 When "COLONNE"         : Gosub SEL_COLONNE
 When Default           : Gosub SEL_VARIA
Endcase
Return

$SEL_VARIA
If dim([M:TXA3]VARNAM)>0
 NBTEX = [M:TXA3]NBVAR
 For I=1 To NBTEX
  TEX(I)   = [M:TXA3]VARNAM(I-1)
  TEXTE(I) = [M:TXA3]VARNAM(I-1)-[M:TXA3]VARDES(I-1)
 Next I
Endif
Return

$SEL_COLONNE
If [M]TABLO<>""
 Read [TXS]TXS0 = [M]TABLO
 NBTEX = [F:TXS]NBRCOL
 For I=1 To NBTEX
  TEX(I)   = num$(I)
  Call LECTEXTRA(TEXTE(I),"TXSAC","NAMCOL",[M]TABLO,num$(I)) From ATEXTRA
  TEXTE(I) = num$(I)-":"-TEXTE(I)
 Next I
Else
 NBTEX = [M:TXA1]NBRCOL
 For I=1 To NBTEX
  TEX(I)   = num$(I)
  TEXTE(I) = num$(I)-":"-[M:TXA1]NAMCOL(I-1)
 Next I
Endif
Return

$SEL_LIGNE
If [M]TABLO<>""
 For [TXD] Where TXSNAM=[M]TABLO & COL=0
  NBTEX = [F:TXD]LIG
  TEX(NBTEX)   = num$([F:TXD]LIG)
  TEXTE(NBTEX) = num$([F:TXD]LIG)-":"-[F:TXD]FRM
 Next
Else
 NBTEX = [M:TXA2]NBLIG
 For I=1 To NBTEX
  TEX(I)   = num$(I)
  TEXTE(I) = num$(I)-":"-[M:TXA2]FRM0(I-1)
 Next I
Endif
Return

######################################################################################
## En-tête
######################################################################################
Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR = GDEFSOC
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Read [CPY]CPY0 = VALEUR
Read [GCM]GCM0 = [F:CPY]ACM
#Read [LED]LED0 = [F:GCM]LED([M]REFGEN-1)
#[M]COA         = [F:LED]COA
GDEFSOC = VALEUR
End

Subprog C_TYPMNT(VALEUR)
Variable Integer VALEUR
Raz [M]FLGNAT,[M]FLGSEC
Case VALEUR
 When 1
  Actzo MQ,TYPBAL
  Actzo 20-24
  If [M]MQ=0     : [M]MQ = 1     : Affzo MQ     : Endif
  If [M]TYPBAL=0 : [M]TYPBAL = 1 : Affzo TYPBAL : Endif
  If [M]TYPEXT=0 : [M]TYPEXT = 1 : Affzo TYPEXT : Endif
  If [M]CATMNT=0 : [M]CATMNT = 1 : Affzo CATMNT : Endif
  Call C_TYPEXT([M]TYPEXT)
  Effzo 25,30,35,40,50,60
  Diszo 25,30,35,40,50,60
  If [M]TYPMNT<>1 : [M]REFGEN = [M]DEFGEN : Affzo REFGEN : Endif
  [M]TIT1 = mess(221,111,1) : # Racine début
  [M]TIT2 = mess(222,111,1) : # Racine din
  [M]TIT3 = mess(223,111,1) : # Exclusion
  Affzo TIT1,TIT2,TIT3
 When 2
  Actzo MQ,TYPBAL
  Actzo 30,35
  If [M]MQ=0     : [M]MQ = 1     : Affzo MQ     : Endif
  If [M]TYPBAL=0 : [M]TYPBAL = 1 : Affzo TYPBAL : Endif
  Effzo 20-24,25,40,50,60
  Diszo 20-24,25,40,50,60
  Actzo REFANA
  If [M]TYPMNT<>2 : [M]REFANA = [M]DEFANA : Affzo REFANA : Endif
  If [M]NAT<>"" : Diszo NATPYR,NATGRP : Effzo LIBNATPYR,LIBNATGRP : Endif
  If [M]CATMNT<>0 : [M]CATMNT = 0 : Effzo CATMNT : Endif
  If [M]TYPEXT<>0 : [M]TYPEXT = 0 : Effzo TYPEXT : Endif
 When 3
  Actzo MQ
  [M]TYPBAL = 0 : Affzo TYPBAL
  Diszo TYPBAL
  Actzo 25,30,35
  Effzo 20-24,40,50,60
  Diszo 20-24,40,50,60
  Diszo REFANA
  If [M]NAT<>"" : Diszo NATPYR,NATGRP : Effzo LIBNATPYR,LIBNATGRP : Endif
  If [M]BUD<>""
   Call C_BUD([M]BUD)
   If mkstat=2 : Raz [M]BUD : mkstat=1 : Endif
  Endif
  If [M]CATMNT<>0 : [M]CATMNT = 0 : Effzo CATMNT : Endif
  If [M]TYPEXT<>0 : [M]TYPEXT = 0 : Effzo TYPEXT : Endif
 When 4
  Actzo 40
  [M]MQ     = 0 : Affzo MQ
  [M]TYPBAL = 0 : Affzo TYPBAL
  Diszo MQ,TYPBAL
  Effzo 20-24,25,30,35,50,60
  Diszo 20-24,25,30,35,50,60
  If [M]CATMNT<>0 : [M]CATMNT = 0 : Effzo CATMNT : Endif
  If [M]TYPEXT<>0 : [M]TYPEXT = 0 : Effzo TYPEXT : Endif
 When 5
  [M]MQ     = 0 : Affzo MQ
  [M]TYPBAL = 0 : Affzo TYPBAL
  Diszo MQ,TYPBAL
  Actzo 50
  Effzo 20-24,25,30,35,40,60
  Diszo 20-24,25,30,35,40,60
  If [M]CATMNT<>0 : [M]CATMNT = 0 : Effzo CATMNT : Endif
  If [M]TYPEXT<>0 : [M]TYPEXT = 0 : Effzo TYPEXT : Endif
 When 6
  [M]MQ     = 0 : Affzo MQ
  [M]TYPBAL = 0 : Affzo TYPBAL
  Diszo MQ,TYPBAL
  Actzo 60
  Effzo 20-24,25,30,35,40,50
  Diszo 20-24,25,30,35,40,50
  If [M]CATMNT<>0 : [M]CATMNT = 0 : Effzo CATMNT : Endif
  If [M]TYPEXT<>0 : [M]TYPEXT = 0 : Effzo TYPEXT : Endif
Endcase
End

Subprog C_MQ(VALEUR)
Variable Integer VALEUR
If [M]TYPMNT=1
 If VALEUR=2
  [M]CATMNT = 0
  Affzo CATMNT
  Diszo CATMNT
 Else
  Actzo CATMNT
  If [M]CATMNT=0 : [M]CATMNT = 1 : Affzo CATMNT : Endif
 Endif
Endif
End

Subprog C_TYPBAL(VALEUR)
Variable Integer VALEUR
If [M]TYPMNT=1
 If VALEUR>1 or [M]MQ=2
  [M]CATMNT = 0
  Affzo CATMNT
  Diszo CATMNT
 Else
  Actzo CATMNT
  If [M]CATMNT=0 : [M]CATMNT = 1 : Affzo CATMNT : Endif
 Endif
Endif
End

######################################################################################
## Compta géné (20-24)
######################################################################################
Subprog C_REFGEN(VALEUR)
Variable Integer VALEUR
Local Integer I
If [F:GCM]LED(VALEUR-1)=""
 # Ce référentiel n'est pas défini dans le modèle
 GMESSAGE = mess(98,104,1)
 mkstat=2 : End
Endif
Read [LED]LED0 = [F:GCM]LED(VALEUR-1)
[M]COA         = [F:LED]COA
End

Subprog C_CATMNT(VALEUR)
Variable Integer VALEUR
End

Subprog C_TYPEXT(VALEUR)
Variable Integer VALEUR
Case VALEUR
 When 1 : # Classe de compte
  Actzo CLSDEB,CLSFIN,CLSEXC
  Effzo COLL,LIBCOL,NUMBIL,BILAN,DETAIL,PYRAM,LIBPYR,GRPCPT,LIBGRP
  Diszo COLL,NUMBIL,BILAN,DETAIL,PYRAM,GRPCPT
 When 2 : # Collectif
  Actzo COLL,DETAIL
  Effzo CLSDEB,CLSFIN,CLSEXC,NUMBIL,BILAN,PYRAM,LIBPYR,GRPCPT,LIBGRP
  Diszo CLSDEB,CLSFIN,CLSEXC,NUMBIL,BILAN,PYRAM,GRPCPT
 When 3 : # Code bilan
  Actzo NUMBIL,BILAN,DETAIL
  Effzo CLSDEB,CLSFIN,CLSEXC,COLL,LIBCOL,PYRAM,LIBPYR,GRPCPT,LIBGRP
  Diszo CLSDEB,CLSFIN,CLSEXC,COLL,PYRAM,GRPCPT
 When 4 : # Pyramide
  Actzo DETAIL,PYRAM,GRPCPT
  Effzo CLSDEB,CLSFIN,CLSEXC,COLL,LIBCOL,NUMBIL,BILAN
  Diszo CLSDEB,CLSFIN,CLSEXC,COLL,NUMBIL,BILAN
Endcase
End

Subprog C_CLSFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]CLSDEB
 GMESSAGE = mess(8,133,1) : # Valeur trop petite
 mkstat = 2 : End
Endif
If VALEUR<>"" & VALEUR<>[M]CLSDEB
 Effzo CLSEXC
 Diszo CLSEXC
Else
 Actzo CLSEXC
Endif
End

Subprog C_CLSEXC(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & left$(VALEUR,len([M]CLSDEB))<>[M]CLSDEB
 VALEUR = [M]CLSDEB+VALEUR
Endif
End

Subprog C_COLL(VALEUR)
Variable Char    VALEUR()
If left$(VALEUR,2)<>"V_"
 Read [GAC]GAC1 = [M]COA;VALEUR
 If fstat
  GMESSAGE = mess(9,106,1) : # Collectif inexistant
  mkstat = 2 : End
 Else
  Local Char DESIG(GLONAX3)
  Call LECTEXTRA(DESIG,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
  [M]LIBCOL = DESIG
 Endif
Else
 Gosub CONTVAR
 [M]LIBCOL = LIBVAR
Endif
End

Subprog AS_NUMBIL(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 : VALEUR = 1 : Endif
End

Subprog C_NUMBIL(VALEUR)
Variable Decimal VALEUR
If VALEUR>dim([F:GAC]RPTCODDEB)
 GMESSAGE = mess(218,111,1)+"("+"max"-num$(dim([F:GAC]RPTCODDEB))+")" : # Valeur trop grande
 mkstat = 2 : End
Endif
End

Subprog C_BILAN(VALEUR)
Variable Char    VALEUR()
If left$(VALEUR,2)="V_"
 Gosub CONTVAR
Endif
End

Subprog C_PYRAM(VALEUR)
Variable Char    VALEUR()
Local Char DESIG(GLONAX3)
If left$(VALEUR,2)<>"V_"
 Read [GYM]GYM0 = VALEUR
 If fstat
  GMESSAGE = mess(216,111,1) : # Pyramide inexistante
  mkstat = 2 : End
 Endif
 If [F:GYM]COA<>[M]COA
  GMESSAGE = mess(217,111,1)-"("+[F:GYM]COA+"/"+[M]COA+")" : # Plan de compte incompatible avec la société
  mkstat = 2 : End
 Endif
 Call LECTEXTRA(DESIG,"GACCPYM","DESTRA",[F:GYM]PYM,"") From ATEXTRA
 [M]LIBPYR = DESIG
Else
 Gosub CONTVAR
 [M]LIBPYR = LIBVAR
Endif
End

Subprog C_GRPCPT(VALEUR)
Variable Char    VALEUR()
Local Char DESIG(GLONAX3)
If left$(VALEUR,2)<>"V_"
 Read [GRY]GRY0(2) = [M]PYRAM;VALEUR
 If fstat
  GMESSAGE = mess(31,103,1) : # Groupe de comptes inexistant
  mkstat = 2 : End
 Endif
  Call LECTEXTRA(DESIG,"GACCGRUPYM","DESTRA",[F:GRY]PYM,[F:GRY]GRU) From ATEXTRA
 [M]LIBGRP = DESIG
Else
 Gosub CONTVAR
 [M]LIBGRP = LIBVAR
Endif
End

######################################################################################
## Budgets (25)
######################################################################################
Subprog C_BUD(VALEUR)
Variable Char    VALEUR()
Local Integer I, OK
Local Char    DESIG(GLONAX3)
If left$(VALEUR,2)<>"V_"
 Read [BUP]BUP0 = VALEUR
 If fstat
  GMESSAGE = mess(21,103,1) : # Budget inexistant
  mkstat = 2 : End
 Endif

  If [F:GCM]GCM<>""
  OK = 0
  For I=1 To dim([F:GCM]LED)
   If [F:GCM]LED(I-1)<>"" & [F:GCM]CFMAUT(I-1)<>2
    Read [F:LED]LED0=[F:GCM]LED(I-1)
    If !fstat & [F:BUP]COA=[F:LED]COA
     OK = 1 : Break
    Endif
   Endif
  Next
  If OK=0
   GMESSAGE = mess(83,103,1)-[F:BUP]COA : # Budget défini sur le plan comptable
   mkstat = 2 : End
  Endif
 Endif

 Call LECTEXTRA(DESIG,"BUDPAR","DESTRA",[F:BUP]BUD,"") From ATEXTRA
 [M]LIBBUD = DESIG
 If [F:BUP]PYMACC<>""
  [M]NATPYR = [F:BUP]PYMACC
  [M]FLGNAT = 1
  Read [GYM]GYM0 = [F:BUP]PYMACC
  Call LECTEXTRA(DESIG,"GACCPYM","DESTRA",[F:GYM]PYM,"") From ATEXTRA
  [M]LIBNATPYR = DESIG
  Affzo NATPYR,LIBNATPYR
  Actzo NATPYR,NATGRP
  [M]COA = [F:GYM]COA
  Effzo NAT,LIBNAT
  Diszo NAT
 Else
  [M]COA = [F:BUP]COA
  [M]FLGNAT = 0
  Actzo NAT
 Endif
 For I=0 To [F:BUP]DIENBR-1
  If [F:BUP]PYMCCE(I)<>""
   [M]NBLIG = I+1
   [M]SECPYR(I) = [F:BUP]PYMCCE(I)
   Read [CYM]CYM0 = [F:BUP]PYMCCE(I)
   [M]AXE(I) = [F:CYM]DIE
   [M]FLGSEC(I) = 1
  Elsif [F:BUP]DIE(I)<>""
   [M]NBLIG = I+1
   [M]AXE(I) = [F:BUP]DIE(I)
   [M]FLGSEC(I) = 0
  Else
   Break
  Endif
 Next I
 If [M]VER="" or VALEUR<>[M]BUD
  Filter [BUV] Where BUD=VALEUR & DEF=2
  Read [BUV] First
  Filter [BUV]
  If fstat<=2
   [M]VER = [F:BUV]VER
  Endif
 Endif
 Affzo 35
Else
 Gosub CONTVAR
 If mkstat : End : Endif
 [M]LIBBUD = LIBVAR
Endif
End

Subprog C_VER(VALEUR)
Variable Char    VALEUR()
Call LECTURE("BUV",VALEUR,[M]BUD) From CONTOBJ
If !fstat
 Call LECTEXTRA([M]LIBVERS,"BUDVER","DESTRA",[M]BUD,VALEUR) From ATEXTRA
Else
 [M]LIBVERS = ""
Endif
End

######################################################################################
## Analytique (30)
######################################################################################
Subprog C_REFANA(VALEUR)
Variable Integer VALEUR
Local Integer I
If [F:GCM]LED(VALEUR-1)=""
 # Ce référentiel n'est pas défini dans le modèle
 GMESSAGE = mess(98,104,1)
 mkstat=2 : End
Endif
Read [LED]LED0 = [F:GCM]LED(VALEUR-1)
[M]COA         = [F:LED]COA
[M]NBLIG = [F:LED]DIENBR
For I=0 To [M]NBLIG-1
 [M]AXE(I) = [F:LED]DIE(I)
Next I
Affzo 35
End

Subprog C_NAT(VALEUR)
Variable Char    VALEUR()
Local Char DESIG(GLONAX3)
If left$(VALEUR,2)<>"V_"
 If VALEUR<>"" & !instr(1,VALEUR,"*") & !instr(1,VALEUR,"?") & !instr(1,VALEUR,"!") & !instr(1,VALEUR,"#")
&              & !instr(1,VALEUR,"..") & !instr(1,VALEUR,"(")
  Read [GAC]GAC0 = [M]COA;VALEUR
  If fstat
   GMESSAGE = mess(44,102,1) : # Compte inexistant
   mkstat = 2 : End
  Endif
  Call LECTEXTRA(DESIG,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
  [M]LIBNAT = DESIG
 Else
  [M]LIBNAT = ""
 Endif
Else
 Gosub CONTVAR
 If mkstat : End : Endif
 [M]LIBNAT = LIBVAR
Endif
If VALEUR<>""
 Effzo NATPYR,LIBNATPYR,NATGRP,LIBNATGRP
 Diszo NATPYR,NATGRP
Else
 Actzo NATPYR,NATGRP
Endif
End

Subprog AS_NATPYR(VALEUR)
Variable Char    VALEUR()
If [M]FLGNAT
 mkstat = 2 : End
Endif
End

Subprog C_NATPYR(VALEUR)
Variable Char    VALEUR()
Local Char DESIG(GLONAX3)
If VALEUR=""
 Effzo NATGRP,LIBNATGRP
 Diszo NATGRP
 End
Else
 Actzo NATGRP
Endif
If left$(VALEUR,2)<>"V_"
 Read [GYM]GYM0 = VALEUR
 If fstat
  GMESSAGE = mess(216,111,1) : # Pyramide inexistante
  mkstat = 2 : End
 Elsif [F:GYM]COA<>[M]COA
  GMESSAGE = mess(217,111,1)-"("+[F:GYM]COA+"/"+[M]COA+")" : # Plan de compte incompatible avec la société
  mkstat = 2 : End
 Endif
 Call LECTEXTRA(DESIG,"GACCPYM","DESTRA",[F:GYM]PYM,"") From ATEXTRA
 [M]LIBNATPYR = DESIG
Else
 Gosub CONTVAR
 [M]LIBNATPYR = LIBVAR
Endif
End

Subprog C_NATGRP(VALEUR)
Variable Char    VALEUR()
Local Char DESIG(GLONAX3)
If left$(VALEUR,2)<>"V_"
 Read [GRY]GRY0(2) = [M]NATPYR;VALEUR
 If fstat
  GMESSAGE = mess(31,103,1) : # Groupe de comptes inexistant
  mkstat = 2 : End
 Else
  Call LECTURE("BUP",[M]BUD,"") From CONTOBJ
  If [F:BUP]PYMACC<>"" & [F:GRY]LEV>[F:BUP]PYMACCLEV
   GMESSAGE = mess(214,111,1)-[M]BUD : # Niveau incompatible avec le budget
   mkstat = 2 : End
  Endif
 Endif
 Call LECTEXTRA(DESIG,"GACCGRUPYM","DESTRA",[F:GRY]PYM,[F:GRY]GRU) From ATEXTRA
 [M]LIBNATGRP = DESIG
Else
 Gosub CONTVAR
 [M]LIBNATGRP = LIBVAR
Endif
End

Subprog AS_SEC(VALEUR)
Variable Char    VALEUR()
If [M]FLGSEC(nolign-1)
 mkstat = 1 : End
Endif
End

Subprog C_SEC(VALEUR)
Variable Char    VALEUR()
If left$(VALEUR,2)<>"V_"
 If VALEUR<>"" & !instr(1,VALEUR,"*") & !instr(1,VALEUR,"?") & !instr(1,VALEUR,"!") & !instr(1,VALEUR,"#")
&              & !instr(1,VALEUR,"..") & !instr(1,VALEUR,"(")
  Read [CCE]CCE0 = [M]AXE(nolign-1);VALEUR
  If fstat
   GMESSAGE = mess(35,106,1) : # Section inexistante
   mkstat = 2 : End
  Endif
 Endif
Else
 Gosub CONTVAR
Endif
End

Subprog AS_SECPYR(VALEUR)
Variable Char    VALEUR()
If [M]FLGSEC(nolign-1)
 mkstat = 2 : End
Endif
If [M]SEC(nolign-1)<>""
 mkstat = 1 : End
Endif
End

Subprog C_SECPYR(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
If left$(VALEUR,2)<>"V_"
 Read [CYM]CYM0 = VALEUR
 If fstat
  GMESSAGE = mess(216,111,1) : # Pyramide inexistante
  mkstat = 2 : End
 Elsif [F:CYM]DIE<>[M]AXE(nolign-1)
  GMESSAGE = mess(40,103,1)-"("+[F:CYM]DIE+"/"+[M]AXE(nolign-1)+")" : # Axe incorrect
  mkstat = 2 : End
 Endif
Else
 Gosub CONTVAR
Endif
End

Subprog AS_SECGRP(VALEUR)
Variable Char    VALEUR()
If [M]SEC(nolign-1)<>"" or [M]SECPYR(nolign-1)=""
 mkstat = 1 : End
Endif
End

Subprog C_SECGRP(VALEUR)
Variable Char    VALEUR()
If left$(VALEUR,2)<>"V_"
 Read [CRY]CRY0(2) = [M]SECPYR(nolign-1);VALEUR
 If fstat
  GMESSAGE = mess(32,103,1) : # Groupe de sections inexistant
  mkstat = 2 : End
 Else
  Call LECTURE("BUP",[M]BUD,"") From CONTOBJ
  Local Integer BUDPYM
  BUDPYM = find([M]SECPYR(nolign-1),[F:BUP]PYMCCE)
  If BUDPYM & [F:BUP]PYMCCE(BUDPYM-1)<>"" & [F:CRY]LEV>[F:BUP]PYMCCELEV(BUDPYM-1)
   GMESSAGE = mess(214,111,1)-[M]BUD : # Niveau incompatible avec le budget
   mkstat = 2 : End
  Endif
 Endif
Else
 Gosub CONTVAR
Endif
End

$CONTVAR
LIBVAR = ""
If dim([M:TXA3]VARNAM)>0
 Local Integer V , VOK
 Local Char    LIBVAR(30)
 V = find(VALEUR,[M:TXA3]VARNAM(0..[M:TXA3]NBVAR-1))
 If !V
  VOK = 2 : Call OUINON(mess(134,111,1)+"\"+mess(142,111,1),VOK) From GESECRAN
  If VOK=2
   [M:TXA3]VARNAM([M:TXA3]NBVAR) = VALEUR
   [M:TXA3]NBVAR += 1
   Affzo [M:TXA3]
  Else
   mkstat = 2
  Endif
 Elsif [M:TXA3]VARDES(V-1)<>""
  LIBVAR = [M:TXA3]VARDES(V-1)
 Endif
Endif
If LIBVAR=""
 LIBVAR = mess(183,111,1)-VALEUR : # Variable
Endif
Return

######################################################################################
## Sommes (40)
######################################################################################
Subprog C_TABLO(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : [M]LIBTAB = mess(224,111,1) : End : Endif : # Tableau courant
If left$(VALEUR,2)<>"V_"
 Read [TXS]TXS1 = VALEUR
 If fstat
  GMESSAGE = mess(11,111,1) : # Tableau inexistant
  mkstat = 2 : End
 Endif
 Call LECTEXTRA([M]LIBTAB,"TXSA","TXSDES",VALEUR,"") From ATEXTRA
Else
 Gosub CONTVAR
 [M]LIBTAB = LIBVAR
Endif
End

Subprog C_VERSION(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]TABLO<>"" : VALEUR = "#" : Endif
If VALEUR="#" : [M]LIBVER = mess(220,111,1) : End : Endif : # Dernière version
If VALEUR=""  : [M]LIBVER = "" : End : Endif
If left$(VALEUR,2)<>"V_"
 If left$([M]TABLO,2)<>"V_"
  If [M]TABLO<>""
   Read [TXW]TXW1 = [M]TABLO;VALEUR
  Else
   Read [TXW]TXW1 = [M]TABCUR;VALEUR
  Endif
  If fstat
   GMESSAGE = mess(144,111,1) : # Version inexistante
   mkstat = 2 : End
  Endif
  [M]LIBVER = [F:TXW]VERDES
 Endif
Else
 Gosub CONTVAR
 [M]LIBVER = LIBVAR
Endif
End

Subprog C_COLONNE(VALEUR)
Variable Decimal VALEUR
Local Integer MAXCOL
If [M]TABLO=""
 Read [TXS]TXS1 = [M]TABCUR
 MAXCOL = [F:TXS]NBRCOL
Elsif left$([M]TABLO,2)<>"V_"
 Read [TXS]TXS1 = [M]TABLO
 MAXCOL = [F:TXS]NBRCOL
Else
 MAXCOL = 20
Endif
If VALEUR>MAXCOL
 GMESSAGE = mess(218,111,1)+"("+"max"-num$(MAXCOL)+")" : # Valeur trop grande
 mkstat = 2 : End
Endif
[M]LIBCOLO = func LIBCOL(VALEUR)
End

Subprog C_LIGDEB(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 2 : End
Endif
Gosub SETLIG
If VALEUR>MAXLIG
 GMESSAGE = mess(218,111,1)+"("+"max"-num$(MAXLIG)+")" : # Valeur trop grande
 mkstat = 2 : End
Endif
[M]LIBDEB = func LIBLIG(VALEUR)
End

Subprog C_LIGFIN(VALEUR)
Variable Decimal VALEUR
If VALEUR>0
 If VALEUR<LIGDEB
  GMESSAGE = mess(83,123,1) : # Valeur incorrecte
  mkstat = 2 : End
 Endif
 Gosub SETLIG
 If VALEUR>MAXLIG
  GMESSAGE = mess(218,111,1)+"("+"max"-num$(MAXLIG)+")" : # Valeur trop grande
  mkstat = 2 : End
 Endif
Else
 VALEUR = [M]LIGDEB
Endif
[M]LIBFIN = func LIBLIG(VALEUR)
End

$SETLIG
Local Integer MAXLIG
If [M]TABLO=""
 Read [TXS]TXS1 = [M]TABCUR
 MAXLIG = [F:TXS]NBLIG
Elsif left$([M]TABLO,2)<>"V_"
 Read [TXS]TXS1 = [M]TABLO
 MAXLIG = [F:TXS]NBLIG
Else
 MAXLIG = dim([M:TXA2]NBLIG)
Endif
Return

######################################################################################
## Expression (50)
######################################################################################
Subprog C_EXPR(VALEUR)
Variable Char    VALEUR()
Local Integer E
If VALEUR<>""
 E = abs(parse(VALEUR))
 If E
  GMESSAGE = mess(37,124,1)+"\"+errmes$(E) : # Expression incorrecte
  mkstat = 2 : End
 Endif
Endif
End

######################################################################################
## Variable (60)
######################################################################################
Subprog C_VARIA(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 If left$(VALEUR,2)<>"V_"
  VALEUR = "V_"+VALEUR
 Endif
 Gosub CONTVAR
 If !mkstat
  [M]LIBVAR = LIBVAR
 Endif
Else
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 2 : End
Endif
End

######################################################################################
## Formule (70)
######################################################################################
Subprog AV_FRM(VALEUR)
Variable Char    VALEUR()
Call CAL_FORMULE(VALEUR)
End

######################################################################################
## Fonctions
######################################################################################
Funprog LIBVAR(VALEUR)
Value    Char VALEUR
If dim([M:TXA3]VARNAM)>0
 Local Integer V
 V = find(VALEUR,[M:TXA3]VARNAM(0..[M:TXA3]NBVAR-1))
 If V & [M:TXA3]VARDES(V-1)<>""
  End [M:TXA3]VARDES(V-1)
 Endif
Endif
End mess(183,111,1)-VALEUR : # Variable

Funprog LIBCOL(VALEUR)
Value    Integer VALEUR
Local Char DESIG(GLONAX3)
If VALEUR=0
 End mess(188,111,1) : # Colonne courante
Else
 If [M]TABLO<>""
  If left$([M]TABLO,2)<>"V_"
   Read [TXS]TXS1 = [M]TABLO
   If !fstat
    Call LECTEXTRA(DESIG,"TXSAC","NAMCOL",[M]TABLO,num$(VALEUR)) From ATEXTRA
    End DESIG
   Endif
  Endif
 Else
  End [M:TXA1]NAMCOL(VALEUR-1)
 Endif
Endif
End ""

Funprog LIBLIG(VALEUR)
Value    Integer VALEUR
If [M]TABLO<>""
 If left$([M]TABLO,2)<>"V_"
  Read [TXD]TXD0 = [M]TABLO;VALEUR;0
  If !fstat
   End [F:TXD]FRM
  Endif
 Endif
Else
 End [M:TXA2]FRM0(VALEUR-1)
Endif
End ""

Funprog QUOTE(CHAINE)
Variable Char CHAINE
If (left$(CHAINE,1)="'" or left$(CHAINE,1)='"') & right$(CHAINE,len(CHAINE))=left$(CHAINE,1)
 End seg$(CHAINE,2,len(CHAINE)-1)
Else
 End CHAINE
Endif
End ""
######################################################################################
## Préchargement
######################################################################################
Subprog AV_DEB(VALEUR)
Variable Char    VALEUR()
Local Integer ER
If [M]VALCUR="#"
 [M]VALCUR = ""
 If [M]CPY=""
  zonsui = "CPY"
 Else
  Case [M]TYPMNT
   When 1 : zonsui = "REFGEN"
   When 2 : zonsui = "REFANA"
   When 3 : zonsui = "BUD"
   When 4 : zonsui = "TABLO"
   When 5 : zonsui = "EXPR"
   When 6 : zonsui = "VARIA"
  Endcase
 Endif
Elsif [M]VALCUR<>""
 [M]FRM = [M]VALCUR
 Gosub CHARGE
 If ER
  Call ERREUR([M]VALCUR-";"-mess(9,108,1)) From GESECRAN : # Formule incorrecte
  Effzo 20-99
  [M]VALCUR = ""
 Else
  [M]VALCUR = "#"
 Endif
Endif
End

$CHARGE
Local Char    CHAINE(250)
Local Integer I , J , K , ER , NARG , REFER
Local Char    ARG(80)(1..20)
Local Char    REF(50)
Local Char    DESIG(GLONAX3)
Read [FCY]FCY0 = GFCYDEF
Read [CPY]CPY0 = [F:FCY]LEGCPY
Read [GCM]GCM0 = [F:CPY]ACM
CHAINE = [M]VALCUR
If left$(CHAINE,1)="-"
 [M]INV = 2
 CHAINE = right$(CHAINE,2)
Else
 [M]INV = 1
Endif
REFER = 0
If left$(CHAINE,1)="["
 J = instr(1,CHAINE,"]")
 If !J : ER = 1 : Return : Endif
 REF = ctrans(toupper(seg$(CHAINE,2,J-1)),"_"," ")
 CHAINE = right$(CHAINE,J+1)
 If REF=num$(val(REF))
  REFER = val(REF)
 Else
  For I=1 To len(mess(0,2644,1))
   If left$(toupper(mess(I,2644,1)),len(REF))=REF
    REFER = I : Break
   Endif
  Next I
 Endif
Endif
[M]MQ     = 1
[M]CATMNT = 1
[M]TYPBAL = 1
If left$(CHAINE,1)="D"
 [M]CATMNT = 2
 CHAINE = right$(CHAINE,2)
Elsif left$(CHAINE,1)="C"
 [M]CATMNT = 3
 CHAINE = right$(CHAINE,2)
Elsif left$(CHAINE,2)="MD"
 [M]CATMNT = 4
 CHAINE = right$(CHAINE,3)
Elsif left$(CHAINE,2)="MC"
 [M]CATMNT = 5
 CHAINE = right$(CHAINE,3)
Elsif left$(CHAINE,2)="ME"
 [M]TYPBAL = 2
 CHAINE = right$(CHAINE,3)
Elsif left$(CHAINE,2)="MP"
 [M]TYPBAL = 3
 CHAINE = right$(CHAINE,3)
Elsif left$(CHAINE,1)="M"
 [M]TYPBAL = 1
 CHAINE = right$(CHAINE,2)
Elsif left$(CHAINE,2)="QE"
 [M]TYPBAL = 2
 [M]MQ     = 2
 CHAINE = right$(CHAINE,3)
Elsif left$(CHAINE,2)="QP"
 [M]TYPBAL = 3
 [M]MQ     = 2
 CHAINE = right$(CHAINE,3)
Elsif left$(CHAINE,1)="Q"
 [M]MQ = 2
 CHAINE = right$(CHAINE,2)
Endif
K = find(left$(CHAINE,2),"NM","NQ","EM","EQ","PM","PQ")
If K
 Gosub CHARGE_ANA
Else
 K = find(left$(CHAINE,2),"GM","GQ")
 If K
  Gosub  CHARGE_BUD
 Elsif left$(CHAINE,1)="L"
  Gosub CHARGE_SOM
 Elsif left$(CHAINE,1)="$"
  Gosub CHARGE_SOM
 Elsif left$(CHAINE,1)="R"
  Gosub CHARGE_EXP
 Elsif left$(CHAINE,2)="V_"
  Gosub CHARGE_VAR
 Else
  Gosub CHARGE_GENE
 Endif
Endif
Call C_TYPMNT([M]TYPMNT)
Call C_MQ([M]MQ)
Call C_TYPBAL([M]TYPBAL)
Return

$CHARGE_GENE
[M]TYPMNT = 1
If left$(CHAINE,1)="("
 CHAINE = seg$(CHAINE,2,len(CHAINE)-1)
Endif
[M]TYPMNT = 1
If left$(CHAINE,1)="A" or left$(CHAINE,1)="B"
 J = instr(1,CHAINE,"(")
 If !J : ER = 1 : Return : Endif
 K = val(seg$(CHAINE,2,J-1))
 If K
  [M]NUMBIL = K
  [M]BILAN  = seg$(CHAINE,J+1,len(CHAINE)-1)
  [M]BILAN  = func QUOTE([M]BILAN)
  [M]TYPEXT = 3
 Else
  REF = seg$(CHAINE,J+1,len(CHAINE)-1)
  REF = func QUOTE(REF)
  K = instr(1,REF,".")
  If !K : ER = 1 : Return : Endif
  [M]TYPEXT = 4
  [M]PYRAM  = seg$(REF,1,K-1)
  [M]GRPCPT = seg$(REF,K+1,len(CHAINE))
  If left$([M]PYRAM,2)="V_"
   [M]LIBPYR = func LIBVAR([M]PYRAM)
  Else
   Read [GYM]GYM0 = [M]PYRAM
   If !fstat
    Call LECTEXTRA(DESIG,"GACCPYM","DESTRA",[F:GYM]PYM,"") From ATEXTRA
    [M]LIBPYR = DESIG
   Endif
  Endif
  If left$([M]GRPCPT,2)="V_"
   [M]LIBGRP = func LIBVAR([M]GRPCPT)
  Else
   Read [GRY]GRY0(2) = [M]PYRAM;[M]GRPCPT
   If !fstat
    Call LECTEXTRA(DESIG,"GACCGRUPYM","DESTRA",[F:GRY]PYM,[F:GRY]GRU) From ATEXTRA
    [M]LIBGRP = DESIG
   Endif
  Endif
 Endif
 If REFER=0 : [M]REFGEN = [M]DEFGEN : Else : [M]REFGEN = REFER : Endif
 If left$(CHAINE,1)="A"
  [M]DETAIL = 2
 Else
  [M]DETAIL = 1
 Endif
Elsif left$(CHAINE,1)="H" or left$(CHAINE,1)="I"
 [M]TYPEXT = 2
 [M]COLL = seg$(CHAINE,3,len(CHAINE)-1)
 [M]COLL = func QUOTE([M]COLL)
 If REFER=0 : [M]REFGEN = [M]DEFGEN : Else : [M]REFGEN = REFER : Endif
 If left$(CHAINE,1)="I"
  [M]DETAIL = 2
 Else
  [M]DETAIL = 1
 Endif
 Call C_REFGEN([M]REFGEN)
 If left$([M]COLL,2)="V_"
  [M]LIBCOL = func LIBVAR([M]COLL)
 Else
  Read [GAC]GAC1 = [M]COA;[M]COLL
  If !fstat
   Call LECTEXTRA(DESIG,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
   [M]LIBCOL = DESIG
  Endif
 Endif
Else
 If left$(CHAINE,1)="'" or left$(CHAINE,1)='"'
  CHAINE = seg$(CHAINE,2,len(CHAINE)-1)
 Endif
 K = instr(1,CHAINE,"..")
 If K
  [M]CLSDEB = left$(CHAINE,K-1)
  [M]CLSFIN = right$(CHAINE,K+2)
 Else
  K = instr(1,CHAINE,"(")
  If K
   [M]CLSDEB = left$(CHAINE,K-1)
   [M]CLSEXC = [M]CLSDEB+seg$(CHAINE,K+1,len(CHAINE)-1)
   [M]CLSFIN = [M]CLSDEB
  Else
   [M]CLSDEB = CHAINE
   [M]CLSFIN = [M]CLSDEB
  Endif
 Endif
 [M]TYPEXT = 1
 If [M]TYPMNT=0 : [M]TYPMNT = 1 : Endif
 If REFER=0 : [M]REFGEN = [M]DEFGEN : Else : [M]REFGEN = REFER : Endif
Endif
Return

$CHARGE_ANA
[M]TYPMNT = 2
Case K
 When 1 : [M]MQ = 1 : [M]TYPBAL = 1
 When 2 : [M]MQ = 2 : [M]TYPBAL = 1
 When 3 : [M]MQ = 1 : [M]TYPBAL = 2
 When 4 : [M]MQ = 2 : [M]TYPBAL = 2
 When 5 : [M]MQ = 1 : [M]TYPBAL = 3
 When 6 : [M]MQ = 2 : [M]TYPBAL = 3
Endcase
If REFER=0 : [M]REFANA = [M]DEFANA : Else : [M]REFANA = REFER : Endif
Call C_REFANA([M]REFANA)
CHAINE = seg$(CHAINE,4,len(CHAINE)-1)
Gosub ARGUMENTS
K = instr(1,ARG(1),".")
If K & !instr(1,ARG(1),"..")
 [M]NATPYR = left$(ARG(1),K-1)
 [M]NATGRP = right$(ARG(1),K+1)
Else
 [M]NAT = ARG(1)
Endif
Gosub LIBANA
For I=2 To NARG
 K = instr(1,ARG(I),".")
 If K & !instr(1,ARG(I),"..")
  [M]SECPYR(I-2) = left$(ARG(I),K-1)
  [M]SECGRP(I-2) = right$(ARG(I),K+1)
 Else
  [M]SEC(I-2) = ARG(I)
 Endif
Next I
Return

$LIBANA
If left$([M]NAT,2)="V_"
 [M]LIBNAT = func LIBVAR([M]NAT)
Elsif [M]NAT<>""
 Read [GAC]GAC0 = [M]COA;[M]NAT
 If !fstat
  Call LECTEXTRA(DESIG,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
  [M]LIBNAT = DESIG
 Endif
Endif
If left$([M]NATPYR,2)="V_"
 [M]LIBNATPYR = func LIBVAR([M]NATPYR)
Elsif [M]NATPYR<>""
 Read [GYM]GYM0 = [M]NATPYR
 If !fstat
  Call LECTEXTRA(DESIG,"GACCPYM","DESTRA",[F:GYM]PYM,"") From ATEXTRA
  [M]LIBNATPYR = DESIG
 Endif
Endif
If left$([M]NATGRP,2)="V_"
 [M]LIBNATGRP = func LIBVAR([M]NATGRP)
Elsif [M]NATGRP<>""
 Read [GRY]GRY0 = [M]NATPYR;[M]NATGRP
 If !fstat
  Call LECTEXTRA(DESIG,"GACCGRUPYM","DESTRA",[F:GRY]PYM,[F:GRY]GRU) From ATEXTRA
  [M]LIBNATGRP = DESIG
 Endif
Endif
Return

$CHARGE_BUD
[M]TYPMNT = 3
Case K
 When 1 : [M]MQ = 1
 When 2 : [M]MQ = 2
Endcase
CHAINE = seg$(CHAINE,4,len(CHAINE)-1)
Gosub ARGUMENTS
[M]BUD = ARG(1)
[M]VER = ARG(2)
If left$([M]BUD,2)="V_"
 [M]LIBBUD = func LIBVAR([M]BUD)
Else
 Read [BUP]BUP0 = [M]BUD
 If !fstat
  [M]LIBBUD = [F:BUP]DES
 Endif
Endif
K = instr(1,ARG(3),".")
If K & !instr(1,ARG(3),"..")
 [M]NATPYR = left$(ARG(3),K-1)
 [M]NATGRP = right$(ARG(3),K+1)
Else
 [M]NAT = ARG(3)
Endif
Gosub LIBANA
For I=4 To NARG
 K = instr(1,ARG(I),".")
 If K & !instr(1,ARG(I),"..")
  [M]SECPYR(I-4) = left$(ARG(I),K-1)
  [M]SECGRP(I-4) = right$(ARG(I),K+1)
 Else
  [M]SEC(I-4) = ARG(I)
 Endif
Next I
Return

$ARGUMENTS
NARG = 0
While CHAINE<>""
 NARG += 1
 K = instr(1,CHAINE,",")
 If K
  ARG(NARG) = left$(CHAINE,K-1)
  CHAINE    = right$(CHAINE,K+1)
 Else
  ARG(NARG) = CHAINE
  CHAINE    = ""
 Endif
 ARG(NARG) = func QUOTE(ARG(NARG))
Wend
Return

$CHARGE_SOM
[M]TYPMNT = 4
If left$(CHAINE,1)="$"
 K = instr(1,CHAINE,"(")
 If !K : ER = 1 : Return : Endif
 REF = seg$(CHAINE,2,K-1)
 CHAINE = seg$(CHAINE,K+1,len(CHAINE)-1)
 REF = func QUOTE(REF)
 K = instr(1,REF,".")
 If K
  [M]TABLO   = left$(REF,K-1)
  [M]VERSION = right$(REF,K+1)
 Else
  [M]VERSION = REF
 Endif
Endif
If [M]TABLO<>""
 If left$([M]TABLO,2)="V_"
  [M]LIBTAB = func LIBVAR([M]TABLO)
 Else
  Read [TXS]TXS1 = [M]TABLO
  If !fstat
   Call LECTEXTRA([M]LIBTAB,"TXSA","TXSDES",[M]TABLO,"") From ATEXTRA
  Endif
 Endif
Else
 [M]LIBTAB = mess(224,111,1) : # Tableau courant
Endif
If [M]VERSION<>""
 If left$([M]VERSION,2)="V_"
  [M]LIBVER = func LIBVAR([M]VERSION)
 Elsif [M]VERSION="#"
  [M]LIBVER = mess(220,111,1) : # Dernière version
 Else
  If [M]TABLO=""
   Read [TXW]TXW1 = [M]TABCUR;[M]VERSION
  Else
   Read [TXW]TXW1 = [M]TABLO;[M]VERSION
  Endif
  If !fstat
   [M]LIBVER = [F:TXW]VERDES
  Endif
 Endif
Endif
K = instr(1,CHAINE,"(")
If K
 [M]COLONNE = val(right$(CHAINE,K+1))
 CHAINE = left$(CHAINE,K-1)
Endif
[M]LIGFIN = 0
K = instr(1,CHAINE,":")
If K
 [M]LIGFIN = val(right$(CHAINE,K+1))
 CHAINE = left$(CHAINE,K-1)
Endif
[M]LIGDEB = val(right$(CHAINE,2))
If [M]LIGFIN=0 : [M]LIGFIN = [M]LIGDEB : Endif
[M]LIBCOLO = func LIBCOL([M]COLONNE)
[M]LIBDEB  = func LIBLIG([M]LIGDEB)
[M]LIBFIN  = func LIBLIG([M]LIGFIN)
Return

$CHARGE_EXP
[M]TYPMNT = 5
[M]EXPR   = seg$(CHAINE,3,len(CHAINE)-1)
Return

$CHARGE_VAR
[M]TYPMNT = 6
[M]VARIA  = CHAINE
[M]LIBVAR = func LIBVAR([M]VARIA)
Return

