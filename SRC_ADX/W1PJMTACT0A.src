#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMTACT0A 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:55"
A_USER  = "DOC"
A_STAMP = "20181109230555"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMTACT0A [PJTAC0A]
Gosub HORODAT
Local Inpbox "PJMTACT0A" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJTAC0A] As [SIM_]
Grizo [PJTAC0A]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJTAC0A]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=86 : Y1(0)=1 : Y2(0)=20
Return

$ON_WCR
Return

$ON_WSTTYP
Onevent INIT_AREA Call D_WSTTYP(zc) From W1PJMTACT0A
Return

Subprog D_WSTTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]WSTTYP,indice)=0
 VALEUR = 0
Endif
Gosub _AFF
End

$ON_EXTWST
Onevent AFTER_CHANGE Gosub AMM_EXTWST From W1PJMTACT0A
Onevent BEFORE_INPUT Call AS_EXTWST(zc) From W1PJMTACT0A
Onevent CONTROL Call C_EXTWST(zc) From W1PJMTACT0A
Return

Subprog AS_EXTWST(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6076,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_EXTWST(zc) From W1PJMTACT0A
Onkey   2 Titled GBOUTS Call S_EXTWST(zc) From W1PJMTACT0A
Gosub _AFF
End

Subprog C_EXTWST(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "EXTWST" : GZNUM = 42413 : Endif
Gosub _AFF
End

$AMM_EXTWST
Call AM_EXTWST(zc)
If !mkstat & GOBJET
 zoncou = "EXTWST" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_EXTWST(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_EXTWST(VALEUR) From SUBPJTAC
If mkstat : GERR = 1 : GZONE = "EXTWST" : GZNUM = 42413 : Endif
Gosub _AFF
End

Subprog S_EXTWST(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action WORKSEL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "WORKSEL"
 PARMSK(1) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"WORKSEL","PJMSELECT","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_EXTWST(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action GOBJETC0B
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC0B"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_EXTWST" : PROGSUB = "SUBPJTAC" : PROGSPE = "SPEPJTAC" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 Local Char    OBJCLE(30)
 OBJCLE = [M:PJTAC0]TASFCY
 Call OBJET_CHAR(OBJCLE,"MWS",VALEUR) From GOBJET
 ACTION = "BB1_EXTWST" : PROGSUB = "SUBPJTAC" : PROGSPE = "SPEPJTAC" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_LABWCR
Return

$ON_LABWSTTYP
Onevent INIT_AREA Call D_LABWSTTYP(zc) From W1PJMTACT0A
Return

Subprog D_LABWSTTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]LABWSTTYP,indice)=0
 VALEUR = 0
Endif
Gosub _AFF
End

$ON_EXTLAB
Onevent AFTER_CHANGE Gosub AMM_EXTLAB From W1PJMTACT0A
Onevent BEFORE_INPUT Call AS_EXTLAB(zc) From W1PJMTACT0A
Return

Subprog AS_EXTLAB(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6076,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_EXTLAB(zc) From W1PJMTACT0A
Onkey   2 Titled GBOUTS Call S_EXTLAB(zc) From W1PJMTACT0A
Gosub _AFF
End

$AMM_EXTLAB
Call AM_EXTLAB(zc)
If !mkstat & GOBJET
 zoncou = "EXTLAB" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_EXTLAB(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_EXTLAB(VALEUR) From SUBPJTAC
If mkstat : GERR = 1 : GZONE = "EXTLAB" : GZNUM = 42414 : Endif
Gosub _AFF
End

Subprog S_EXTLAB(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action WORKSEL
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "WORKSEL"
 PARMSK(1) = "[F:MWS]WSTTYP=2"
 Call S_TAB_CHAR(VALEUR,PARMSK,"WORKSEL","PJMSELECT","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_EXTLAB(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action GOBJETC0B
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC0B"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_EXTLAB" : PROGSUB = "SUBPJTAC" : PROGSPE = "SPEPJTAC" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 Local Char    OBJCLE(30)
 OBJCLE = [M:PJTAC0]TASFCY
 Call OBJET_CHAR(OBJCLE,"MWS",VALEUR) From GOBJET
 ACTION = "BB1_EXTLAB" : PROGSUB = "SUBPJTAC" : PROGSPE = "SPEPJTAC" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$CHG_STY
Return


