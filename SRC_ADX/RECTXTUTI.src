#<AdxTL>@(#)3.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
#########################################################################
# RECTXTUTI : Recuperation des textes utilisateurs en version 140
#------------------------------------------------------------------------
# Choix de recuperation des textes .rtf ou .txt  dans masque de lancement
#------------------------------------------------------------------------
# Regles de recuperation
# - Si le fichier texte est absent --> raz du champ lien dans la table
# - Textes des fichiers de base --> ecriture TEXCLOB avec nouveau numero
#      ITMMASTER   ITMSALES    ITMBPC      ITMBPS
#      BPCUSTOMER  BPDLVCUST   BPSUPPLIER  BOM         BOMD
#      ROUTING     ROUOPE      ROUOPESTD
#     - ecriture TEXCLOB avec nouveau numero
#     - reecriture de la table avec le nouveau numero
#       LA MISE A JOUR DE CES TABLES NE DOIT ETRE EXECUTEE QU'UNE FOIS
# - Textes des autres fichiers  --> ecriture TEXCLOB avec ancien numero
#      PREQUIS     PREQUISD    PQUOTAT     PQUOTATD    PORDER
#      PORDERC     PORDERQ     PRECEIPT    PRECEIPTD   PRETURN
#      PRETURND    PINVOICEV   PINVOICED
#      SQUOTE      SQUOTED     SORDER      SORDERQ     SORDERC
#      SDELIVERY   SDELIVERYD  SRETURN     SRETURND    SINVOICE
#      SINVOICED
#      MFGHEAD     MFGMAT      MFGOPE      MFGHEADTRK  MFGMATTRK
#      MFGOPETRK   CAPVAR      HANDLINg    SCALES
#     - ecriture TEXCLOB avec ancien numero
#
# - Pas de suppression des anciens textes .rtf et .txt du repetoire TXT
#------------------------------------------------------------------------
# Controle de déroulement
# - La recuperation doit être effectuée avant reprise de l'exploitation
# - Création du parametre TEXCLOB140 a la creation du dossier
# - Si presence du paramètre a la connexion --> message avertissement
# - Suppression du paramètre en fin de recuperation
#------------------------------------------------------------------------
# Possibilite de reprise : gestion du ficher sequentiel 00_TXTV140
# - En debut recuperation creation fichier si inexistant
# - Maj table si absence abreviation (ex: ~SOH~)
# - Après maj ajout de abreviation  (ex: ~SOH~)
# - En fin : si une abreviation pour toutes les tables la recuperation
#            est complete --> suppression du paramètre TEXCLOB140
#########################################################################

Local Char PARAM(10)(1..3) , VALEUR(250)
Call TRAITE_CHAR(VALEUR,PARAM,"","RECTXTUTI","RECTXTUTI",3,"") From GTRAITE
End

#########################################################################
$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 PSUBB = (filinfo(filpath("TRT","RECTXTUTIB","adx"),0)>=0)
Endif
Case ACTION
 When "INIT"      : Gosub INIT
 When "AVANT_PAR" : Gosub AVANT_PAR
 When "CONTROLE"  : Gosub CONTROLE
 When "EXEC"      : Gosub EXEC
Endcase
If PSUBB
   Gosub ACTION From RECTXTUTIB
Endif
Return

#------------------------------------------------------------------------
$INIT
Local Mask RECTXTUTI [DIA]
Raz [M:DIA]
Return

#------------------------------------------------------------------------
$AVANT_PAR
Local Integer TEST
TEST = 1

Local Char    TABLE    (15) (0..150) : # table
Local Integer NLIEN         (0..150) : # flag :ecrire un nouveau lien (0=non/1=oui)
Local Char    ZONE1    (15) (0..150) : # champ texte 1
Local Char    ZONE2    (15) (0..150) : # champ texte 2

####
#### EN CAS DE MODIFICATION DES TABLEAUX SUIVANTS
#### --> MODIFIER LA DOC POINT D'ENTREE "RECTXTUTI / ADDTXTUTI"
####

#           --- Tronc commun ---
[L]TABLE(0) ="ITMMASTER"  : [L]NLIEN(0) =1  : [L]ZONE1(0) ="PURTEX"     : [L]ZONE2(0) ="MFGTEX"
[L]TABLE(1) =""
[L]TABLE(2) ="ITMSALES"   : [L]NLIEN(2) =1  : [L]ZONE1(2) ="ITSTEX"     : [L]ZONE2(2) ="ITPTEX"
[L]TABLE(3) =""
[L]TABLE(4) ="ITMBPC"     : [L]NLIEN(4) =1  : [L]ZONE1(4) ="ITSTEX"     : [L]ZONE2(4) ="ITPTEX"
[L]TABLE(5) =""
[L]TABLE(6) ="ITMBPS"     : [L]NLIEN(6) =1  : [L]ZONE1(6) ="TEX"        : [L]ZONE2(6) =""
[L]TABLE(7) =""

[L]TABLE(8) ="BPCUSTOMER" : [L]NLIEN(8) =1  : [L]ZONE1(8) ="INVTEX"     : [L]ZONE2(8) ="ORDTEX"
[L]TABLE(9) =""
[L]TABLE(10)="BPDLVCUST"  : [L]NLIEN(10)=1  : [L]ZONE1(10)="DLVTEX"     : [L]ZONE2(10)="PRPTEX"
[L]TABLE(11)=""
[L]TABLE(12)="BPSUPPLIER" : [L]NLIEN(12)=1  : [L]ZONE1(12)="ORDTEX"     : [L]ZONE2(12)="RTNTEX"
[L]TABLE(13)=""

[L]TABLE(14)="BOM"        : [L]NLIEN(14)=1  : [L]ZONE1(14)="HEATEX"     : [L]ZONE2(14)=""
[L]TABLE(15)=""
[L]TABLE(16)="BOMD"       : [L]NLIEN(16)=1  : [L]ZONE1(16)="BOMTEXNUM"  : [L]ZONE2(16)=""
[L]TABLE(17)=""
[L]TABLE(18)=""
[L]TABLE(19)=""

#           --- Achats ---
[L]TABLE(20)="PREQUIS"                       : [L]ZONE1(20)="TEX1"      : [L]ZONE2(20)="TEX2"
[L]TABLE(21)=""
[L]TABLE(22)="PREQUISD"                      : [L]ZONE1(22)="LINTEX"    : [L]ZONE2(22)=""
[L]TABLE(23)=""
[L]TABLE(24)="PQUOTAT"                       : [L]ZONE1(24)="TEX1"      : [L]ZONE2(24)="TEX2"
[L]TABLE(25)=""
[L]TABLE(26)="PQUOTATD"                      : [L]ZONE1(26)="LINTEX"    : [L]ZONE2(26)=""
[L]TABLE(27)=""
[L]TABLE(28)="PORDER"                        : [L]ZONE1(28)="TEX1"      : [L]ZONE2(28)="TEX2"
[L]TABLE(29)=""
[L]TABLE(30)="PORDERC"                       : [L]ZONE1(30)="TEX"       : [L]ZONE2(30)=""
[L]TABLE(31)=""
[L]TABLE(32)="PORDERQ"                       : [L]ZONE1(32)="LINTEX"    : [L]ZONE2(32)=""
[L]TABLE(33)=""
[L]TABLE(34)="PRECEIPT"                      : [L]ZONE1(34)="TEX1"      : [L]ZONE2(34)="TEX2"
[L]TABLE(35)=""
[L]TABLE(36)="PRECEIPTD"                     : [L]ZONE1(36)="LINTEX"    : [L]ZONE2(36)=""
[L]TABLE(37)=""
[L]TABLE(38)="PRETURN"                       : [L]ZONE1(38)="TEX1"      : [L]ZONE2(38)="TEX2"
[L]TABLE(39)=""
[L]TABLE(40)="PRETURND"                      : [L]ZONE1(40)="LINTEX"    : [L]ZONE2(40)=""
[L]TABLE(41)=""
[L]TABLE(42)="PINVOICEV"                     : [L]ZONE1(42)="TEX1"      : [L]ZONE2(42)="TEX2"
