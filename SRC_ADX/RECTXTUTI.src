[L]TABLE(72)=""

#           --- GP ---

[L]TABLE(73)="ROUTING"    : [L]NLIEN(73)=1   : [L]ZONE1(73)="TEXNUM"    : [L]ZONE2(73)=""
[L]TABLE(74)=""
[L]TABLE(75)="ROUOPE"     : [L]NLIEN(75)=1   : [L]ZONE1(75)="ROOTEX"    : [L]ZONE2(75)=""
[L]TABLE(76)=""
[L]TABLE(77)="ROUOPESTD"  : [L]NLIEN(77)=1   : [L]ZONE1(77)="OPETEXNUM" : [L]ZONE2(77)=""
[L]TABLE(78)=""
[L]TABLE(79)="MFGHEAD"                       : [L]ZONE1(79)="MFGTEX"    : [L]ZONE2(79)=""
[L]TABLE(80)=""
[L]TABLE(81)="MFGMAT"                        : [L]ZONE1(81)="MFMTEX"    : [L]ZONE2(81)=""
[L]TABLE(82)=""
[L]TABLE(83)="MFGOPE"                        : [L]ZONE1(83)="MFOTEX"    : [L]ZONE2(83)=""
[L]TABLE(84)=""
[L]TABLE(85)="MFGHEADTRK"                    : [L]ZONE1(85)="MTKTEX"    : [L]ZONE2(85)=""
[L]TABLE(86)=""
[L]TABLE(87)="MFGMATTRK"                     : [L]ZONE1(87)="MKMTEX"    : [L]ZONE2(87)=""
[L]TABLE(88)=""
[L]TABLE(89)="MFGOPETRK"                     : [L]ZONE1(89)="MKOTEX"    : [L]ZONE2(89)=""
[L]TABLE(90)=""
[L]TABLE(91)="CAPVAR"                        : [L]ZONE1(91)="VARTEX"    : [L]ZONE2(91)=""
[L]TABLE(92)="HANDLING"                      : [L]ZONE1(92)="TEX"       : [L]ZONE2(92)=""
[L]TABLE(93)=""
[L]TABLE(94)="SCALES"                        : [L]ZONE1(94)="TEX"       : [L]ZONE2(94)=""
[L]TABLE(95)=""
[L]TABLE(96)=""
[L]TABLE(97)=""

GPOINT="ADDTXTUTI" :  : Gosub ENTREE From EXEFNC

#-------------
# ATTENTION : Si le point d'entrée ADDTXTUTI est utilisé pour une table définie en spécifique,
#             il est impératif de faire l'ouverture des tables ATABLE, ATABIND, ATABZON, ATEXTE
#             dans le point d'entrée sous le dossier qui sera saisi dans le masque de lancement
#             La demande de conversion d'un texte d'une table spécifique est venue ultérieurement
#             et la logique du traitement n'a pas été modifiée pour ce cas exceptionnel
#-------------

If clalev([ATB])=0 : Local File =adxmother(0)+".ATABLE"  [ATB] : Endif
If clalev([ATI])=0 : Local File =adxmother(0)+".ATABIND" [ATI] : Endif
If clalev([ATZ])=0 : Local File =adxmother(0)+".ATABZON" [ATZ] : Endif
If clalev([ATX])=0 : Local File =adxmother(0)+".ATEXTE"  [ATX] : Endif

Local Integer IJ0,NOL
For IJ0=0 To dim([L]TABLE)-1
    If [L]TABLE(IJ0)="" : Goto N_IJ0 : Endif
    Read [ATB]CODFIC=[L]TABLE(IJ0)
    If fstat
       Infbox "ATABLE :"+mess(49,125,1)+" "+mess(87,116,1)+[L]TABLE(IJ0)
       Goto N_IJ0
    Endif

    Read [ATX]NUMERO=GLANGUE;[F:ATB]INTITFIC
    If fstat : Raz [F:ATX] : Endif
    [M]NBLIG  +=1 : NOL=[M]NBLIG-1
    [M]TABLE(NOL) =[L]TABLE(IJ0)
    [M]NLIEN(NOL) =[L]NLIEN(IJ0)
    [M]ABRFIC(NOL)=[F:ATB]ABRFIC

    Read [ATI]NUMLIG(2)=[L]TABLE(IJ0);1
    If !fstat : [M]DESCRIPT(NOL)=[F:ATI]DESCRIPT : Endif
    [M]TABLIB(NOL)=[F:ATX]TEXTE
    If [L]ZONE1(IJ0)<>""
       Read [ATZ]CODZONE=[L]TABLE(IJ0);[L]ZONE1(IJ0)
       If !fstat
          Read [ATX]NUMERO=GLANGUE;[F:ATZ]NOABREG
          If fstat : Raz [F:ATX] : Endif
          [M]ZONE1(NOL)=[L]ZONE1(IJ0)
          [M]ZONELIB1(NOL)=[F:ATX]TEXTE
       Else
          Infbox "ATABZON :"+mess(49,125,1)+" "+mess(87,116,1)+[L]ZONE1(IJ0)
       Endif
    Endif
    If [L]ZONE2(IJ0)<>""
       Read [ATZ]CODZONE=[L]TABLE(IJ0);[L]ZONE2(IJ0)
       If !fstat
          Read [ATX]NUMERO=GLANGUE;[F:ATZ]NOABREG
          If fstat : Raz [F:ATX] : Endif
          [M]ZONE2(NOL)=[L]ZONE2(IJ0)
          [M]ZONELIB2(NOL)=[F:ATX]TEXTE
       Else
          Infbox "ATABZON :"+mess(49,125,1)+" "+mess(87,116,1)+[L]ZONE2(IJ0)
       Endif
    Endif

$N_IJ0
Next IJ0

Return

#------------------------------------------------------------------------
$CONTROLE
OK = 1
Call OUINON(mess(171,115,1),OK) From GESECRAN : # Récupération des fichiers textes
If OK<>2 : SAI = 1 : Return : Endif
If [M]TRACE=2  TRA=1  Else  TRA=0  Endif
Return

#------------------------------------------------------------------------
$EXEC
Local Integer IJ0, IJ1, IJ2, IJ3, IJ4
Local Integer IJRW

Local Char    J_TABLE   (10)         : # nom de la table
Local Integer J_NLIEN                : # flag : creer un nouveau lien (0=non / 1=oui)
# Issue 108342  - 2015-11-06 by MAE : ABRFIC passage de 3 à 8
#Local Char    J_ABRFIC  (3)          : # abreviation table
Local Char    J_ABRFIC  (GLONABR)          : # abreviation table
Local Char    J_DESCRIPT(80)         : # description index primaire
Local Char    J_TABLIB  (25)         : # designation table

Local Integer J_NBENR                : # nombre enregistrements traites
Local Char    J_ZONE    (15) (0..25) : # nom des zones textes de la table
Local Integer J_OPT          (0..25) : # option de recuperation (2=rtf / 3=txt)
Local Integer J_NBZONTXT     (0..25) : # nombre de textes traites

Local Char    NOMFIC (GDIMFIC)       : # nom du fichier V130
Local Char    TXCNUM (GDIMFIC)       : # cle dans TEXCLOB (ancien ou nouveau numero)
Local Char    FICHIER(GDIMFIC), FICBIS(GDIMFIC)
Local Char    BID    (10)

Local Integer SAVIUM
SAVIUM = adxium
SAVIRS = adxirs
SAVIFS = adxifs
adxium = GASCII
adxifs = ""
adxirs = ""

Gosub D_TXTV140

If !GSERVEUR
 Call OUVRE_TRACE(mess(171,115,1)) From LECFIC : # Récupération des fichiers textes
Endif

Local File =[M]DOSSIER+".TEXCLOB" [TXC], =[M]DOSSIER+".TEXCLOB" [TXC2]

For IJ0=0 To dim([M]TABLE)-1             : # --- Boucle des tables a traiter ---
    Raz J_TABLE, J_NLIEN, J_ABRFIC, J_TABLIB, J_DESCRIPT, J_NBENR, J_ZONE, J_OPT, J_NBZONTXT
    If [M]TABLE(IJ0)<>"" &  filinfo(filpath("FIL",[M]TABLE(IJ0),"fde",[M]DOSSIER),0)>0
       IJ1=-1
       J_TABLE   =[M]TABLE(IJ0)    : J_ABRFIC=[M]ABRFIC(IJ0)
       J_DESCRIPT=[M]DESCRIPT(IJ0) : J_NLIEN =[M]NLIEN(IJ0)   : J_TABLIB=[M]TABLIB(IJ0)
       If [M]ZONE1(IJ0)<>""
          IJ1 +=1
          J_ZONE(IJ1)=[M]ZONE1(IJ0) : J_OPT(IJ1)=[M]OPT1(IJ0)
       Endif
       If [M]ZONE2(IJ0)<>""
          IJ1 +=1
          J_ZONE(IJ1)=[M]ZONE2(IJ0) : J_OPT(IJ1)=[M]OPT2(IJ0)
       Endif
       #     si plusieurs lignes pour la meme table (ex:SDELIVERY)
       For IJ2=IJ0+1 To dim([M]TABLE)-1
           If [M]TABLE(IJ2)=[M]TABLE(IJ0)
              If [M]ZONE1(IJ2)<>""
                 IJ1 +=1
                 J_ZONE(IJ1)=[M]ZONE1(IJ2) : J_OPT(IJ1)=[M]OPT1(IJ2)
              Endif
              If [M]ZONE2(IJ2)<>""
                 IJ1 +=1
                 J_ZONE(IJ1)=[M]ZONE2(IJ2) : J_OPT(IJ1)=[M]OPT2(IJ2)
              Endif
              [M]TABLE(IJ2)=""       : # pour ne pas reprendre la ligne
           Endif
       Next IJ2
       #    cas particulier : table CAPVAR (25 postes textes)
       If [M]TABLE(IJ0)="CAPVAR"
          Raz IJ1
          For IJ2=0 To 24
              J_ZONE(IJ2)="VARTEX("+num$(IJ2)+")" : J_OPT(IJ2)=[M]OPT1(IJ0)
          Next IJ2
       Endif

#----------
# Pour tests : maj selective des textes d'une table
#----------

#  Case J_TABLE

#       When "PREQUIS"     : #Gosub MAJ_TABLE
#       When "PREQUISD"    : Gosub MAJ_TABLE
#       When "PQUOTAT"     : Gosub MAJ_TABLE
#       When "PQUOTATD"    : Gosub MAJ_TABLE
#       When "PORDER"      : Gosub MAJ_TABLE
#       When "PORDERC"     : Gosub MAJ_TABLE
#       When "PORDERQ"     : Gosub MAJ_TABLE
#       When "PRECEIPT"    : Gosub MAJ_TABLE
#       When "PRECEIPTD"   : Gosub MAJ_TABLE
#       When "PRETURN"     : Gosub MAJ_TABLE
#       When "PRETURND"    : Gosub MAJ_TABLE
#       When "PINVOICEV"   : Gosub MAJ_TABLE
#       When "PINVOICED"   : Gosub MAJ_TABLE

#       When "SQUOTE"      : Gosub MAJ_TABLE
#       When "SQUOTED"     : Gosub MAJ_TABLE
#       When "SDELIVERY"   : Gosub MAJ_TABLE
#       When "SDELIVERYD"  : Gosub MAJ_TABLE
#       When "SRETURN"     : Gosub MAJ_TABLE
#       When "SRETURND"    : Gosub MAJ_TABLE
#       When "SINVOICEV"   : Gosub MAJ_TABLE
#       When "SINVOICED"   : Gosub MAJ_TABLE

#       When "ITMBPC"      : Gosub MAJ_TABLE
#       When "ITMBPS"      : Gosub MAJ_TABLE
#       When "BPCUSTOMER"  : Gosub MAJ_TABLE
#       When "BPDLVCUST"   : Gosub MAJ_TABLE
#       When "BPSUPPLIER"  : Gosub MAJ_TABLE

#       When "ITMMASTER"   : Gosub MAJ_TABLE
#       When "ITMBSALES"   : Gosub MAJ_TABLE
#       When "SORDER"      : Gosub MAJ_TABLE
#       When "SORDERQ"     : Gosub MAJ_TABLE
#       When "SORDERC"     : Gosub MAJ_TABLE
#  Endcase
#----------

#    Traitement de la table
        Gosub MAJ_TABLE

    Endif
Next IJ0

Call TEMPOFF From GESECRAN

adxium = SAVIUM
adxirs = SAVIRS
adxifs = SAVIFS

Gosub D_TXTV140

Return


#  traitement de tous les textes d'une table
$MAJ_TABLE
Local Char J_TXTFIND (250)         : # indicateur de présence texte
Local Char J_CLEPRIM (50)          : # valeur des champs de la cle primaire
Local Integer J_NONTROUVE

Gosub R_TXTV140
If instr(1,ENR_FLAG,"~"+J_ABRFIC+"~") : Return : Endif

Local File =[M]DOSSIER+"."+J_TABLE [AAA]
Local File =[M]DOSSIER+"."+J_TABLE [BBB]


If [M]TRACE=2
   Call ECR_TRACE(mess(56,123,1)-J_TABLE+" Index = "+J_DESCRIPT,0) From GESECRAN
Endif

Call TEMPON (mess(44,125,1)-J_TABLE) From GESECRAN

For [AAA]                                : # --- Boucle des enr. de la table ---
    Raz J_TXTFIND, IJRW
    For IJ1=0 To dim(J_ZONE)-1
        If J_ZONE(IJ1)="" : Break : Endif
        If evalue("dim([F:AAA]"+J_ZONE(IJ1)+")")>0
           J_TXTFIND +=evalue("[F:AAA]"+J_ZONE(IJ1))
        Endif
    Next IJ1

    J_TXTFIND=ctrans(J_TXTFIND,"_","")   : # pas de cle texte mais champs contient __ seuls
    If len(J_TXTFIND)>0                  : # il y a au moins une cle texte dans enr.
       Gosub CLEPRIM                     : # chargement donnees cle enr. contenant les textes
       J_NBENR +=1                       : # nb enr. ayant un ou plusieurs textes

       For IJ1=0 To dim(J_ZONE)-1        : # --- Boucle des champs texte de enr. ---

           If J_ZONE(IJ1)="" : Break : Endif
           NOMFIC=vireblc(evalue("[F:AAA]"+J_ZONE(IJ1)),2)

                                           # ne pas traiter les textes V140
           If instr(1,NOMFIC,J_ABRFIC+"~") : Break : Endif

           If NOMFIC<>""

              Raz FICHIER
              Case J_OPT(IJ1)
                   When 2 :  FICHIER = filpath("TXT",NOMFIC,"rtf",[M]DOSSIER)
                             FICBIS  = filpath("TXT",NOMFIC,"txt",[M]DOSSIER)
                   When 3 :  FICHIER = filpath("TXT",NOMFIC,"txt",[M]DOSSIER)
                             FICBIS  = filpath("TXT",NOMFIC,"rtf",[M]DOSSIER)
              Endcase
              If filinfo(FICHIER,0)>0
                 Openi FICHIER Using [FIC]
                 Rdseq [F:TXC2]TEXTE Using [FIC]

                 Case J_OPT(IJ1)
                      When 2 :             # texte rtf
                           If fstat
                              OK = -1
                           Else
                              Rdseq BID Using [FIC]
                              If fstat
                                 OK = 1 :  # On a tout lu
                              Else
                                 OK = 0
                              Endif
                           Endif
                      When 3 :             # texte txt
                           If fstat
                              OK = 1 :     # On a tout lu
                           Else
                              OK = 0
                          Endif
                 Endcase

                 Openi Using [FIC]         # fermeture du fichier texte

                 If !OK
                    Call ERREUR("|"+J_TABLE+"="+J_CLEPRIM+" : "+J_ZONE(IJ1)+" "+FICHIER-":"-mess(175,115,1),4) From DOSDIC
                 Elsif OK=1
                    Gosub ECR_TXT
                    If GOK=1
                       If !TEST            # pas de suppression des fichiers textes V130
#                         Call EFFACE(FICHIER,OK) From ORDSYS  :
                          If FICBIS<>"" & filinfo(FICBIS,0)>0
#                            Call EFFACE(FICBIS,OK) From ORDSYS
                          Endif
                       Endif
                    Endif
                 Endif
              Else
                 J_NONTROUVE +=1
                 Assign "[F:AAA]"+J_ZONE(IJ1) With ""
                 IJRW +=1
#                 Call ECR_TRACE("NON TROUVE : Clé primaire="+J_CLEPRIM+" : "+J_ZONE(IJ1)+"="+NOMFIC,0) From GESECRAN
              Endif

           Endif
       Next IJ1

       If IJRW                           : # si modif un lien --> rewrite de enregistrement
          Trbegin [AAA]
             [F:BBB]=[F:AAA]
             Readlock [AAA]Curr
             [F:AAA]=[F:BBB]
             Rewrite [AAA]
          Commit
       Endif

    Endif
Next

If [M]TRACE=2
#                 Nbre d'enregistrements traites
   GMESSAGE="   "+mess(451,197,1)-num$(J_NBENR)+"   "
#                  Texte non trouve
   GMESSAGE +="  "+mess(96,115,1)+"="+num$(J_NONTROUVE)+"   "
   If sum(J_NBZONTXT)>0
      GMESSAGE += "( "
      For IJ3=0 To dim(J_ZONE)-1
          If J_ZONE(IJ3)="" : Break : Endif
          If instr(1,J_ZONE(IJ3),"(")
             IJ4=instr(1,J_ZONE(IJ3),"(")
             GMESSAGE =GMESSAGE+left$(J_ZONE(0),IJ4-1)+"="+num$(J_NBZONTXT(0))+" "
          Else
             GMESSAGE =GMESSAGE+J_ZONE(IJ3)+"="+num$(J_NBZONTXT(IJ3))+" "
          Endif
      Next IJ3
      GMESSAGE += ")"
   Endif
   Call ECR_TRACE(GMESSAGE,0) From GESECRAN
Endif

Gosub W_TXTV140

Close Local File [AAA]
Close Local File [BBB]

Return

#-----------------------------
$ECR_TXT
GOK=1
TXCNUM=NOMFIC

Trbegin [TXC]
 If J_NLIEN                              : # si table majeure lien format V140
    Local Integer WTEXSEQ, STAT
    Call NUM_TXC(J_ABRFIC,WTEXSEQ,STAT) From TRTX3TEX
      If STAT=0
         TXCNUM=J_ABRFIC+"~"+format$("N0:8#",num$(WTEXSEQ))
         Assign "[F:AAA]"+J_ZONE(IJ1) With TXCNUM
         IJRW +=1
      Else
         Assign "[F:AAA]"+J_ZONE(IJ1) With ""
         IJRW +=1
         Goto ECR_END
      Endif
 Endif

 Delete [TXC]TXC0=TXCNUM

 Raz [F:TXC]
 [F:TXC]CODE  =TXCNUM
 [F:TXC]TEXTE =[F:TXC2]TEXTE
 [F:TXC]IDENT1= J_ABRFIC+"="+J_CLEPRIM
 [F:TXC]IDENT2=J_ZONE(IJ1)+"="+TXCNUM
 [F:TXC]IDENT3="V130="+num$(NOMFIC)
 If dim([F:TCX]CREUSR)>0 : [F:TXC]CREUSR = GUSER : Endif
 If dim([F:TXC]CREDAT)>0 : [F:TXC]CREDAT = date$ : Endif
 If dim([F:TXC]CRETIM)>0 : [F:TXC]CRETIM = time  : Endif
 Write [TXC]
 If fstat
  Call ERREUR("TEXCLOB"-J_TABLE+"="+J_CLEPRIM,1) From DOSDIC
  GOK=0 : Goto ROLL_TXT
 Endif
 If J_TABLE="CAPVAR"
    J_NBZONTXT(0) +=1                    : # nb de textes cumules
  Else
    J_NBZONTXT(IJ1) +=1                  : # nb de textes pour le champ
 Endif

$ECR_END

Commit
Return

$ROLL_TXT
Rollback
Return

#-----------------------------
$CLEPRIM
Raz J_CLEPRIM
Local Char MANIP, ZONE
MANIP=J_DESCRIPT
While MANIP<>""
      Raz ZONE
      IJ3=instr(1,MANIP,"+")
      If IJ3
         ZONE=left$(MANIP,IJ3-1) : MANIP=right$(MANIP,IJ3+1)
      Else
         ZONE=MANIP            : MANIP=""
      Endif
      If  evalue("dim([F:AAA]"+ZONE+")")>0
          J_CLEPRIM += num$(evalue("[F:AAA]"+ZONE))
          If MANIP<>"" : J_CLEPRIM +="~" : Endif
      Endif
Wend
Return


##########################################################################
## Etiquette ajoutée par le superviseur 24/12/2003 14:59:24 (JL)
##########################################################################
Subprog AS_OPT1(VALEUR)
Variable Integer VALEUR
GMENLOC(1) = 1
End

Subprog AS_OPT2(VALEUR)
Variable Integer VALEUR
GMENLOC(1) = 1
End

##########################################################################
## Etiquette ajoutée par le superviseur 30/12/2003 08:08:34 (JL)
##########################################################################
Subprog AP_DOSSIER(VALEUR)
Variable Char    VALEUR()
Local Integer I

For I=0 To dim([M]TABLE)-1
    If [M]TABLE(I)<>""
       If [M]ZONE1(I)<>""   Actzo [M]OPT1(I)   Else   Grizo [M]OPT1(I)   Endif
       If [M]ZONE2(I)<>""   Actzo [M]OPT2(I)   Else   Grizo [M]OPT2(I)   Endif

       If filinfo(filpath("FIL",[M]TABLE(I),"fde",VALEUR),0)<0
          Grizo [M]OPT1(I) : Grizo [M]OPT2(I)
      Endif

    Endif
Next I

End

##########################################################################
# Gestion du fichier 00_TXTV140 : trace de mise a jour des textes
#-------------------------------------------------------------------------
# But : Permettre la reprise de la gestion des textes
#       Effacer le paramètre de contrôle de deroulement
##########################################################################

##------------------------------------------------------------------------
## Début traitement : Si fichier absent --> creation
C_TXTV140
Local Char    SAVADXIFS, SAVADXIRS
Local Char    ENR_FLAG (250)
SAVADXIFS=adxifs : SAVADXIRS=adxirs
adxifs="" : adxirs=chr$(13)+chr$(10)
FIC_SEQ=filpath("TXT","00_TXTV140","txt",[M]DOSSIER)
If filinfo(FIC_SEQ,0) < 0
   Openo FIC_SEQ Using [FLAG]
   ENR_FLAG="~"
   Wrseq ENR_FLAG Using [FLAG]
   Openo Using [FLAG]
Endif
adxifs=SAVADXIFS : adxirs=SAVADXIRS
Return

##------------------------------------------------------------------------
## Début maj une table : Si table deja traitee --> pas maj de la table
R_TXTV140
Local Char    SAVADXIFS, SAVADXIRS
Local Char    ENR_FLAG (250)
SAVADXIFS=adxifs : SAVADXIRS=adxirs
adxifs="" : adxirs=chr$(13)+chr$(10)
FIC_SEQ=filpath("TXT","00_TXTV140","txt",[M]DOSSIER)
If filinfo(FIC_SEQ,0) >= 0
   Openi FIC_SEQ,0 Using [FLAG]
   Rdseq ENR_FLAG Using [FLAG]
   Openi Using [FLAG]
Endif
adxifs=SAVADXIFS : adxirs=SAVADXIRS
Return

##------------------------------------------------------------------------
## Fin maj une table : Ajout abreviation table --> ecriture enregistrement
W_TXTV140
Local Char    SAVADXIFS, SAVADXIRS
Local Char    ENR_FLAG (250)
SAVADXIFS=adxifs : SAVADXIRS=adxirs
adxifs="" : adxirs=chr$(13)+chr$(10)
FIC_SEQ=filpath("TXT","00_TXTV140","txt",[M]DOSSIER)
If filinfo(FIC_SEQ,0) >= 0
   Openi FIC_SEQ,0 Using [FLAG]
   Rdseq ENR_FLAG Using [FLAG]
   Openi Using [FLAG]
   ENR_FLAG = ENR_FLAG+J_ABRFIC+"~"
   Openo FIC_SEQ,0 Using [FLAG]
   Wrseq ENR_FLAG Using [FLAG]
   Openo Using [FLAG]
Endif
adxifs=SAVADXIFS : adxirs=SAVADXIRS
Return

##------------------------------------------------------------------------
## Fin traitement : Si toutes tables traitées --> suppression paramètre
D_TXTV140
Local Integer IJ0, IJSUP
IJSUP=1
Gosub R_TXTV140

For IJ0=0 To dim([M]TABLE)-1
    If !instr(1,ENR_FLAG,"~"+[M]ABRFIC(IJ0)+"~") : IJSUP=0 : Break : Endif
Next IJ0

If IJSUP
   If clalev([F:ADP])=0 : Local File ADOPAR [ADP] : Endif
   Delete [ADP] ADP0="TC";"TEXCLOB140"
Endif

Return

##########################################################################

