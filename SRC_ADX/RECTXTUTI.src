[L]TABLE(59)="SDELIVERY"                     : [L]ZONE1(59)="PRPTEX1"   : [L]ZONE2(59)="PRPTEX2"
[L]TABLE(60)=""
[L]TABLE(61)="SDELIVERYD"                    : [L]ZONE1(61)="SDDTEX"    : [L]ZONE2(61)="PRPTEX"
[L]TABLE(62)=""
