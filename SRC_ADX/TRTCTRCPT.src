#    CBO - 12.03.2012  FQ80246  GFMDAT4 au lieu de DD[/]MM[/]YYYY

#-----------------------------------------------------
# TRTCTRCPT : Gestion des infos comptables au contrat
#-----------------------------------------------------

Local Char REFNUM(30), CTRNUM(30)
Local Date CTRDAT
Local Integer ERREUR

Call DECRYPTE_IDCTR("TOTO~CONTRAT~20100731", [L]REFNUM, [L]CTRNUM, [L]CTRDAT, ERREUR)

Call MESSAGE(num$([L]ERREUR)+"\"+[L]REFNUM+"\"+[L]CTRNUM+"\"
&            +format$("D:" + GFMDAT4, [L]CTRDAT)) From GESECRAN

End

#-------------------------------------------------------------------
# GET_ID : Renvoie un identifiant pour un élément lié à un bulletin
#-------------------------------------------------------------------
Funprog GET_ID(TYP, BUL)
Value Char TYP(), BUL()

Local Char ID(250)    : # => Attention, le renvoi se fera dans CLECPT dimensionnée à 30
                        # dans CPTAUTO => voir By si possible de l'agrandir

Raz [L]ID

Case [L]TYP
    When "CPR"
        # Récupérer une chaine identifiant de manière unique
        # les infos comptables contrat pour un bulletin
        Gosub GET_IDCPR
Endcase

End [L]ID

$GET_IDCPR

Gosub OPEN_VEPW
Gosub OPEN_CPRW

Read [F:VEPW]VEP5 = [L]BUL
If fstat = 0
    Filter [F:CPRW] Where [F:CPRW]REFNUM = [F:VEPW]EMP
&                    & [F:CPRW]CTRNUM = [F:VEPW]CTRNUM
&                    & [F:CPRW]CTRDAT <= [F:VEPW]PYRDAT
    Read [F:CPRW]CPR0 Last
    If fstat <= 2

        # On normalise la fabrication d'une IDCTR des fois qu'un jour on finisse par virer la
        # date à l'intérieur, un seul endroit à corriger !

        [L]ID = func TRTCTRCPT.CRYPTE_IDCTR([F:CPRW]REFNUM, [F:CPRW]CTRNUM, [F:CPRW]CTRDAT, 1)

    Else
        Raz [L]ID
    Endif
Else
    # Pas de bulletin ... on est bien tiens !
Endif

Gosub CLOSE_VEPW
Gosub CLOSE_CPRW

Return

#--------------------------------------------------------------------
# Decryptage d'une IDCTR composée sous la forme REFNUM~CTRNUM~CTRDAT
#--------------------------------------------------------------------
Subprog DECRYPTE_IDCTR(IDCTR, REFNUM, CTRNUM, CTRDAT, ERREUR)
Value Char IDCTR()
Variable Char REFNUM(), CTRNUM()
Variable Date CTRDAT
Variable Integer ERREUR

Raz [L]ERREUR

If [L]IDCTR = "" : [L]ERREUR = 1 : End : Endif

Local Integer POS

Raz [L]REFNUM, [L]CTRNUM, [L]CTRDAT, [L]POS

[L]POS = instr(1, [L]IDCTR, "~")
If [L]POS > 0
    [L]REFNUM = mid$([L]IDCTR, 1, [L]POS-1)
    [L]IDCTR = right$([L]IDCTR, [L]POS+1)
    [L]POS = instr(1, [L]IDCTR, "~")
    If [L]POS > 0
        [L]CTRNUM = mid$([L]IDCTR, 1, [L]POS-1)
        [L]IDCTR = right$([L]IDCTR, [L]POS+1)
        [L]CTRDAT = [L]IDCTR
    Else
        [L]ERREUR = 1
    Endif
Else
    [L]ERREUR = 1
Endif
End

#JOJAC - 2017-03-27 - START
Subprog DECRYPTE_IDCOD(IDCOD, LEG, COD, ERREUR)
Value Char IDCOD()
Variable Char LEG(), COD()
Variable Integer ERREUR

Raz [L]ERREUR

If [L]IDCOD = "" : [L]ERREUR = 1 : End : Endif

Local Integer POS

Raz [L]COD, [L]LEG, [L]POS

[L]POS = instr(1, [L]IDCOD, "~")
If [L]POS > 0
    [L]LEG = mid$([L]IDCOD, 1, [L]POS-1)
    [L]IDCOD = right$([L]IDCOD, [L]POS+1)
    [L]COD = [L]IDCOD
Else
    [L]ERREUR = 1
Endif
End
#JOJAC - 2017-03-27 - END

#----------------------------------------------------------------------------
# Fabrication normalisée d'une IDCTR ou IDCPR (format identique)
# => Codée en funprog pour s'en servir directement depuis des zones évaluées
#----------------------------------------------------------------------------
Funprog CRYPTE_IDCTR(REFNUM, CTRNUM, CTRDAT, MODE)
Value Char REFNUM(), CTRNUM()
Value Date CTRDAT
Value Integer MODE

Local Char IDCTR(250)
Raz [L]IDCTR

If [L]MODE = 2
    # Schcrafougne et bidouillage sont les deux mamelles de la programmation ...
    # On va chercher le contrat dont la date est antérieure ou égale à la date passée
    # en paramètre.
    Gosub GET_CTR
Endif

If [L]CTRDAT <> [0/0/0]
    [L]IDCTR = [L]REFNUM + "~" + [L]CTRNUM + "~" + format$("D:YYYYMMDD", [L]CTRDAT)
Endif

End [L]IDCTR

$GET_CTR

Gosub OPEN_CTRW

Filter [F:CTRW] Where [F:CTRW]REFNUM = [L]REFNUM
&                    & [F:CTRW]CTRNUM = [L]CTRNUM

# Bidouille mon amie la date vide est spéciale, arbitraitement :)

If [L]CTRDAT = [0/0/0]
    # Le premier contrat
    Read [F:CTRW]CTR0 First
Else
    Read [F:CTRW]CTR0 <= [L]REFNUM ; [L]CTRNUM ; [L]CTRDAT
Endif

Raz [L]CTRDAT

If fstat <= 2
    [L]CTRDAT = [F:CTRW]CTRDAT
Endif

Filter [F:CTRW]

Gosub CLOSE_CTRW

Return

#-------------------------------------------------------------------
# Début du commencement de la fin
# Pas de ZFIC automatique mais on sauve quand même le contexte ...
#-------------------------------------------------------------------
$OPEN_CTRW
Local Integer OPEN_CTRW
If clalev([F:CTRW]) = 0
    [L]OPEN_CTRW = 2 : Local File EMPLOCTR [CTRW]
Else
    Local Char S_REFNUM_CTRW(type([F:CTRW]REFNUM)-10), S_CTRNUM_CTRW(type([F:CTRW]CTRNUM)-10)
    Local Date S_CTRDAT_CTRW
    [L]S_REFNUM_CTRW = [F:CTRW]REFNUM : [L]S_CTRNUM_CTRW = [F:CTRW]CTRNUM
    [L]S_CTRDAT_CTRW = [F:CTRW]CTRDAT
Endif
Return

$CLOSE_CTRW
If [L]OPEN_CTRW = 1
    Read [F:CTRW]CTR0 = [L]S_REFNUM_CTRW ; [L]S_CTRNUM_CTRW ; [L]S_CTRDAT_CTRW
Else
    Close Local File [CTRW]
Endif
Return

$OPEN_CPRW
Local Integer OPEN_CPRW
If clalev([F:CPRW]) = 0
    [L]OPEN_CPRW = 2 : Local File EMPLOCTRCPT [CPRW]
Else
    Local Char S_REFNUM_CPRW(type([F:CPRW]REFNUM)-10), S_CTRNUM_CPRW(type([F:CPRW]CTRNUM)-10)
    Local Date S_CTRDAT_CPRW
    [L]S_REFNUM_CPRW = [F:CPRW]REFNUM : [L]S_CTRNUM_CPRW = [F:CPRW]CTRNUM
    [L]S_CTRDAT_CPRW = [F:CPRW]CTRDAT
Endif
Return

$CLOSE_CPRW
If [L]OPEN_CPRW = 1
    Read [F:CPRW]CPR0 = [L]S_REFNUM_CPRW ; [L]S_CTRNUM_CPRW ; [L]S_CTRDAT_CPRW
Else
    Close Local File [CPRW]
Endif
Return

$OPEN_VEPW
Local Integer OPEN_VEPW
If clalev([F:VEPW]) = 0
    [L]OPEN_VEPW = 2 : Local File VALEMP [VEPW]
Else
    Local Char S_EMP_VEPW(type([F:VEPW]EMP)-10), S_BUL_VEPW(type([F:VEPW]BUL)-10)
    Local Date S_PYRDAT_VEPW
    [L]S_EMP_VEPW = [F:VEPW]EMP : [L]S_BUL_EMPW = [F:VEPW]BUL
    [L]S_PYRDAT_VEPW = [F:VEPW]PYRDAT
Endif
Return

$CLOSE_VEPW
If [L]OPEN_VEPW = 1
    Read [F:VEPW]VEP0 = [L]S_EMP_VEPW ; [L]S_PYRDAT_VEPW ; [L]S_BUL_VEPW
Else
    Close Local File [VEPW]
Endif
Return

