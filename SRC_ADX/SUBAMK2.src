#<AdxTL>@(#)3.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("AMK",GBIDC1,GBIDC2) From GOBJET
End

#---------------------------------------------------------------------#
# Avant l'action ASAIETQ :  Saisie sous-programme sur un champ
#---------------------------------------------------------------------#

$ACTION
Case ACTION
 When "AB2_NBACT"  : Gosub AB2_NBACT
 When "SEL_LISTE"  : Gosub SELLIST
 When "FIN_LISTE"  : Gosub FINLIST
Endcase
Return

$AB2_NBACT
Local Integer K, NBPAR , TYPPAR , ADRVAL
Local Char    CODPAR(10)
Local Char    ETIQUETTE(20) , PROG(GLONADC) , PFIX(10)

If (GADONIX=2 & [M]ACTION(nolign-1)="STD") | find([M]ACTION(nolign-1),"SPE","SPV")
 Case [M]TYPACT(nolign-1)
  When 1  : PFIX = "IB"
  When 2  : PFIX = "AV"
  When 3  : PFIX = "D"
  When 4  : PFIX = "AS"
  When 5  : PFIX = "C"
  When 6  : PFIX = "AP"
  When 7  : PFIX = "AM"
  When 8  : PFIX = "S"
  When 9  : PFIX = "B1"
  When 10 : PFIX = "B2"
  When 11 : PFIX = "B3"
  When 12 : PFIX = "B4"
  When 13 : PFIX = "AVANT"
  When 14 : PFIX = "APRES"
  When 15 : PFIX = "B5"
  When 16 : PFIX = "B6"
  When 17 : PFIX = "B7"
  When 18 : PFIX = "B8"
  When 19 : PFIX = "B9"
  When 20 : PFIX = "B10"
  When 21 : PFIX = "B11"
  When 22 : PFIX = "B12"
  When 23 : PFIX = "B13"
  When 24 : PFIX = "B14"
  When 25 : PFIX = "B15"
  When 26 : PFIX = "B16"
  When 27 : PFIX = "B17"
  When 28 : PFIX = "B18"
  When 29 : PFIX = "B19"
  When 30 : PFIX = "B20"
  When 31 : PFIX = "CL"
 Endcase
 ETIQUETTE = PFIX+"_"+[M]ZONCUR
 Case [M]ACTION(nolign-1)
  When "STD" : PROG = [M:AMK1]TRTSTD
  When "SPE" : PROG = [M:AMK1]TRTSPE
  When "SPV" : PROG = [M:AMK1]TRTSPV
 Endcase
 NBPAR = 0
 K = find([M]ZONCUR,[M]CODZON(0..[M]NBLIG-1))
 If find([M]ZONCUR,[M:AMK1]BASPAG(0..[M:AMK1]NBBLOC-1)) : K = 0 : Endif
 If K & [M]CODTYP(K-1)="AV" : K = 0 : Endif
 If K
  NBPAR = 1
  Call LECTURE("ATY",[M]CODTYP(K-1),"") From CONTOBJ
  Case [F:ATY]TYPTYP
   When 1  : TYPPAR = 2 : # Menu local
   When 2  : TYPPAR = 3 : # Entier court
   When 3  : TYPPAR = 3 : # Entier long
   When 4  : TYPPAR = 3 : # Float
   When 5  : TYPPAR = 3 : # Double
   When 6  : TYPPAR = 3 : # Decimal
   When 7  : TYPPAR = 1 : # Alpha
   When 8  : TYPPAR = 4 : # Date
   When 9  : NBPAR  = 0 : # Blob
   When 10 : TYPPAR = 6 : # Clob
  Endcase
  ADRVAL = 1
 Endif
 CODPAR = "VALEUR"
 GBIDC1 = CODPAR
 GBIDI1 = TYPPAR
 GBIDI2 = ADRVAL
Endif
Return

########################################
## Etiquette masque AMKFOR            ##
########################################
Subprog C_OPTFOR2(VALEUR)
Variable Char     VALEUR
If left$(VALEUR,1)='"' | left$(VALEUR,1)="'"
 mkstat = 2
Endif
End

########################################
## Etiquettes masque AMK2             ##
########################################
Subprog AS_NBLIG
Local Integer K
K = find([M]ZONCUR,[M]CODZON)
If K
 Look [AMA]TYPAFF(3)=1;[M]CODMSK;[M]ZONCUR
 If !fstat
  Chgstl [M]CODZON(K-1) With "AMKACT"
 Else
  Chgstl [M]CODZON(K-1) With ""
 Endif
Endif
Gosub SETNOL
Gosub SETZON
Effzo [AMK2]15
Call CHARGE_ACT([M]CODMSK,[M]ZONCUR) From PARMNT
Chgstl [M]CODZON(NOL) With "AMKCUR"
End

$SETZON
[M:AMK2]ZONCUR = [M:AMK2]CODZON(NOL)
Inftxt [M:AMK2]CODZON(NOL) At 2
Return

Subprog C_CODZON(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : mkstat=1 : End : Endif
If vireblc(format$("KT:30X",VALEUR),2)<>VALEUR : # mb 27.11.01 A cause bouton Codification
 mkstat = 1 : End
Endif
Call UNICITE(VALEUR,[M]CODZON(0..[M]NBLIG-1)) From OBJDIV
If mkstat : End : Endif
If VALEUR<>[M]CODZON(nolign-1)
 Call PLAGE_ZON([M]CODMSK,VALEUR) From CONTOBJ
 If mkstat : End : Endif
Endif
End

Subprog AM_CODZON(VALEUR)
Variable Char VALEUR()
Local Integer I
Gosub SETNOL
If find(VALEUR,[M:AMK1]BASPAG(0..[M:AMK1]NBBLOC-1))
 [M]CODTYP(NOL) = "ABS" : [M]SAIAFF(NOL) = 1
Else
 For I=0 To [M:AMK1]NBFIC-1
  Read [F:ATZ]CODZONE = [M:AMK1]FICREF(I) ; VALEUR
  If !fstat
   Read [F:ATB]CODFIC = [M:AMK1]FICREF(I)
   Gosub CHARGE_ZON From PARMNT
   Break
  Endif
 Next I
Endif
Call CHARGE_ACT([M]CODMSK,[M]ZONCUR) From PARMNT
End

Subprog D_NUMBLOC(NUM)
Variable Decimal NUM
Gosub SETNOL
If NUM=0
 Gosub INI_NUMBLOC From PARMNT
Endif
End

Subprog C_NUMBLOC(VALEUR)
Value Decimal VALEUR
Local Decimal NUM
Gosub SETNOL
If VALEUR<1 | VALEUR>[M:AMK1]NBBLOC : mkstat=2 : End : Endif
If [M:AMK1]TYPBLOC(VALEUR-1)=3 : # Photo
 GMESSAGE = mess(132,123,1) : # Type de bloc non géré
 mkstat = 2 : End
Endif
End

Subprog AM_NUMBLOC(VALEUR)
Value Decimal VALEUR
Gosub SETNOL
[M]NUMBLOC(NOL) = VALEUR
NUM = [M]DIME(NOL)
Gosub INI_DIME From PARMNT
[M]DIME(NOL) = NUM
Raz [M]NOZONE(NOL)
End

Subprog C_NOZONE(NUM)
Variable Decimal NUM
If NUM<1 or NUM>999
 GMESSAGE = mess(83,123,1) : # Valeur incorrecte
 mkstat = 2 : End
Endif
End

Subprog D_NOZONE(NUM)
Variable Decimal NUM
Gosub SETNOL
If NUM=0
 Gosub INI_NOZONE From PARMNT
Endif
End

Subprog B1_NOZONE(VALEUR)
Value Decimal VALEUR
Gosub SETNOL
Local Integer BLOC , NOL1 , NUMERO
[L]BLOC = [M]NUMBLOC(NOL)
[L]NUMERO = int(VALEUR)+1
For NOL1=NOL+1 To [M]NBLIG-1
 If [M]NUMBLOC(NOL1)=BLOC
  [M]NOZONE(NOL1) = [L]NUMERO
  Affzo NOZONE(NOL1)
  [L]NUMERO += 1
 Else
  Break
 Endif
Next NOL1
[M]NOZONE(NOL) = VALEUR
Affzo NOZONE(NOL)
End

Subprog B1_ZINTIT(VALEUR)
Variable Char    VALEUR()
Local Integer CAS
CAS = 1
Goto CHARGE_INTIT

Subprog B2_ZINTIT(VALEUR)
Variable Char    VALEUR()
Local Integer CAS
CAS = 2
Goto CHARGE_INTIT

Subprog B3_ZINTIT(VALEUR)
Variable Char    VALEUR()
Local Integer CAS
CAS = 3
Goto CHARGE_INTIT

$CHARGE_INTIT
Local Integer I , TX
TX = 0
For I = 0 To [M:AMK1]NBFIC-1
 Read [F:ATZ]CODZONE = [M:AMK1]FICREF(I) ; [M]CODZON(nolign-1)
 If !fstat
  Case CAS
   When 1 : TX = [F:ATZ]NOABREG
   When 2 : TX = [F:ATZ]NOCOURT
   When 3 : TX = [F:ATZ]NOLONG
  Endcase
  Read [ATX]NUMERO = GLANGUE;TX
  VALEUR = [F:ATX]TEXTE
  [M]ZINTIT(nolign-1) = VALEUR
  [M]INTIT(nolign-1) = TX
  Break
 Endif
Next I
If TX=0
 Call MESSAGE(mess(8,124,1)) From GESECRAN : # Zone inexistante
Endif
End

Subprog AP_ZINTIT(VALEUR)
Variable Char    VALEUR()
If VALEUR="$"
 [M]INTIT(nolign-1) = 0
Else
 [M]INTEVAL(nolign-1) = ""
Endif
Effzo [M:AMK2]20
End

Subprog C_ZINTIT(VALEUR)
Variable Char    VALEUR()
Call C_QUOTE(VALEUR)
End

Subprog C_QUOTE(CHAINE)
Variable Char CHAINE()
If instr(1,CHAINE,'"')
 GMESSAGE = '"'-":"-mess(94,123,1) : # Caractère interdit
 mkstat=2 : End
Endif
End

Subprog AS_PDSZON(VALEUR)
Variable Decimal VALEUR
If [M:AMK1]TYPBLOC([M]NUMBLOC(nolign-1)-1)<>2
 VALEUR = 1 : mkstat = 2
Elsif VALEUR=0 & [M]ZINTIT(nolign-1)<>""
 VALEUR = 1
Endif
End

Subprog C_PDSZON(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 & [M]ZINTIT(nolign-1)<>""
 VALEUR = 1
Endif
End

Subprog AS_CODTYP(VALEUR)
Variable Char VALEUR
Local Integer OK, NOL2
Local Char    ACT(GLONACT)
Case [M:AMK1]TYPBLOC([M]NUMBLOC(nolign-1)-1)
 When 3,4 : VALEUR = "" : mkstat = 1 : End
Endcase
If VALEUR="" : End : Endif
Raz GBOUT2, GBOUT3, OK , GBIDC3
Call LECTURE("ATY",VALEUR,"") From CONTOBJ
OK = ([F:ATY]NBTYP>0) : # Et tant pis s'il n'y a pas de paramètres
If [F:ATY]OBJLIEN<>""
 Call LECTURE("AOB",[F:ATY]OBJLIEN,"") From CONTOBJ
 If [F:AOB]LIBPAR<>0 : OK=1 : Endif
 If [F:AOB]NBOPT<>0
  GBOUT2 = mess(127,124,1) : # Options
 Endif
Endif
OK += ([F:ATY]PARTAB<>"")
If OK
 GBOUT3 = mess(174,100,1) : # Paramètres
Endif
End

Subprog C_CODTYP(VALEUR)
Variable Char VALEUR
Gosub SETNOL
Call LECTURE("ATY",VALEUR,"") From CONTOBJ
If [M]INTEVAL(NOL)<>"" & VALEUR="W"
 # Type de donnée incompatible avec un intitulé évalué
 Call ERREUR(mess(177,139,1)) From GESECRAN
 mkstat = 2 : End
Endif
If find([F:ATY]TYPTYP,11,12) : # Uuident, datetime
 # Le type interne "$1$" ne peut pas être utilisé dans un écran
 Call ERREUR(func AFNC.MES1(mess(352,139,1),mess([F:ATY]TYPTYP,30,1))) From GESECRAN
 mkstat = 2 : End
Endif
If [M]CODZON(NOL)=[M:AMK1]BASPAG([M]NUMBLOC(NOL)-1)
 If [F:ATY]TYPTYP<>9 and [M:AMK1]TYPBLOC([M]NUMBLOC(NOL)-1)=7
  # Ce champ paramètre doit être de type Blob
  Call ERREUR([M]CODZON(NOL)-":"-mess(233,123,1)) From GESECRAN
  mkstat = 2 : End
 Elsif ([F:ATY]TYPTYP<>10 and find([M:AMK1]TYPBLOC([M]NUMBLOC(NOL)-1),6,8,9))
  # Ce champ paramètre doit être de type Clob
  Call ERREUR([M]CODZON(NOL)-":"-mess(234,123,1)) From GESECRAN
  mkstat = 2 : End
 Endif
Endif
End

Subprog AP_CODTYP(VALEUR)
Variable Char     VALEUR
Local Integer NOL , K
NOL = nolign-1
Effzo 20
K = 0
Read [ATY]CODTYP=[M:AMK2]CODTYP(NOL)
If !fstat
 K = ([F:ATY]NBTYP>0) : # Et tant pis s'il n'y a pas de paramètres
 If [F:ATY]OBJLIEN<>""
  Read [AOB]ABREV=[F:ATY]OBJLIEN
  If !fstat
   If [F:AOB]LIBPAR<>0 : K = 1 : Endif
   If [F:AOB]NBOPT<>0 : K = 1 : Endif
  Endif
 Endif
 K += ([F:ATY]PARTAB<>"")
Endif
If [M:AMK2]OPTOBJ(NOL)<>""
 K += 1
Endif
If K
 Chgstl [M:AMK2]CODTYP(NOL) With "AMKACT"
Else
 Chgstl [M:AMK2]CODTYP(NOL) With ""
Endif
nolign = NOL+1
End

Subprog AM_CODTYP(VALEUR)
Variable Char VALEUR()
Local Char OTYP(GLONATY)
Local Integer OK
Gosub SETNOL
Raz GBIDC1,GBIDC2
Call LECTURE("ATY",VALEUR,"") From CONTOBJ
If [F:ATY]OBJLIEN<>""
 Call LECTURE("AOB",[F:ATY]OBJLIEN,"") From CONTOBJ
 If [F:AOB]LIBPAR<>0 : OK=1 : Endif
 If [F:AOB]NBOPT<>0
  If [M]OPTOBJ(NOL) <> "" | GBIDC3 = "OPT"
   GBIDC2="OPT"
  Endif
 Endif
Endif
OK += ([F:ATY]PARTAB<>"")
If OK
 For [AMP]CODPAR Where TYPAFF= 1 & CODAFF = [M]CODMSK & CODZON = [M]CODZON(NOL)
  GBIDC1="PAR" : Break
 Next AMP
Endif
If [M]CODTYP=VALEUR : End : Endif
## BY 8/12/99 En modif ce n'est pas très bon de réinitialiser le lien
OTYP = [M]CODTYP(NOL)
[M]CODTYP(NOL) = VALEUR
If OTYP="" : Gosub INI_CODTYP From PARMNT : Endif
If mkstat>2 : mkstat=0 : Endif
End

Subprog AS_NOLIB(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
If [M:AMK1]TYPBLOC([M]NUMBLOC(NOL)-1)=1 & find([M]CODZON(NOL),[M:AMK1]BASPAG(0..[M:AMK1]NBBLOC-1))
 mkstat=1 : End
Endif
If [M]CODTYP(NOL)="" : mkstat=1 : End : Endif
Call LECTURE("ATY",[M]CODTYP(NOL),"") From CONTOBJ
If [F:ATY]TYPTYP<>1 | [F:ATY]NOLIB<>0 : mkstat=1 : End : Endif
End

Subprog AM_NOLIB(VALEUR)
Variable Decimal VALEUR
Gosub SETNOL
If VALEUR=1
 [M]LONG(NOL) = [M:AMK1]LNGLIB([M]NUMBLOC(NOL)-1) : Affzo [M]LONG(NOL)
Else
 Read [AML]MENLOC = VALEUR
 If fstat=0 & [F:AML]LONG<>0
  [M]LONG(NOL) = [F:AML]LONG : Affzo [M]LONG(NOL)
 Endif
Endif
End

Subprog AS_LONG(VALEUR)
Variable Decimal VALEUR
Local Char LNGCOD(20)
Gosub SETNOL
If [M:AMK1]TYPBLOC([M]NUMBLOC(NOL)-1)=1 & find([M]CODZON(NOL),[M:AMK1]BASPAG(0..[M:AMK1]NBBLOC-1))
 mkstat=1 : End
Elsif [M]CODTYP(NOL)="" or [M]CODTYP(NOL)="W"
 mkstat = 1 : End
Elsif [M]CODTYP(NOL)="ADI"
 Read [AMP]CODPAR=1;[M:AMK0]CODMSK;[M]CODZON(NOL);"ADI"
 If !fstat
  LNGCOD = [F:AMP]VALPAR
  If (LNGCOD>="0" & LNGCOD<="9999") or (len(LNGCOD)>2 & find(left$(LNGCOD,1),"'",'"')) or find(left$(LNGCOD,6),"num$('",'num$("')
   mkstat = 1 : End
  Endif
 Endif
Else
 Call LECTURE("ATY",[M]CODTYP(NOL),"") From CONTOBJ
 If [F:ATY]FORTYP<>"" or [F:ATY]LNGTYP<>0 or find([F:ATY]TYPTYP,8)
  mkstat = 1 : End
 Endif
Endif
End

Subprog D_LONG(VALEUR)
Variable Decimal VALEUR
Local Char LNGCOD(20)
Gosub SETNOL
Call LECTURE("ATY",[M]CODTYP(NOL),"") From CONTOBJ
If [M]NOLIB(NOL)=1
 VALEUR = [M]LNGTYP([M]NUMBLOC(NOL)-1)
Else
 If [F:ATY]FORTYP="" & [F:ATY]LNGTYP=0 : # S'il s'agit d'un type de donnée standard
  Case [F:ATY]TYPTYP
   When 1  : VALEUR = 15  : # Libellé
   When 2  : VALEUR = 4   : # Entier Court
   When 3  : VALEUR = 8   : # Entier Long
   When 4  : VALEUR = 9.2 : # Décimal
   When 7  : VALEUR = 10  : # Alphanumérique
   When 9  : VALEUR = 1   : # Blob
   When 10 : VALEUR = 1   : # Clob
  Endcase
 Elsif [M]CODTYP(NOL)="ADI"
  Read [AMP]CODPAR=1;[M:AMK0]CODMSK;[M]CODZON(NOL);"ADI"
  If !fstat
   LNGCOD = [F:AMP]VALPAR
   If (LNGCOD>="0" & LNGCOD<="9999") or (len(LNGCOD)>2 & find(left$(LNGCOD,1),"'",'"')) or find(left$(LNGCOD,6),"num$('",'num$("')
    End
   Endif
  Endif
  VALEUR = 5 : # Table diverse avec un paramètre ADI variable ou non renseigné
 Endif
Endif
End

Subprog C_LONG(VALEUR)
Variable Decimal LONG
Local Decimal ENTIER , DECIM
If [M]CODTYP(nolign-1)="W" : End : Endif
If VALEUR=0 : mkstat=1 : End : Endif
Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
ENTIER = int(VALEUR)
DECIM  = 10*(VALEUR-ENTIER)
While DECIM<>int(DECIM)
 DECIM *= 10
Wend
Case [F:ATY]TYPTYP
 When 2  : If DECIM<>0 | ENTIER>4              : mkstat = 1 : Endif : # Entier court
 When 3  : If DECIM<>0 | ENTIER>8              : mkstat = 1 : Endif : # Entier long
 When 4  : If DECIM+ENTIER<1 | DECIM+ENTIER>32 : mkstat = 1 : Endif : # DCB
 When 7  : If DECIM<>0 | ENTIER>255            : mkstat = 1 : Endif : # Char
 When 8  : If DECIM<>0 | !find(ENTIER,4,6,8)   : mkstat = 1 : Endif : # Date
 When 9  : If DECIM<>0 | ENTIER>20             : mkstat = 1 : Endif : # Blob
 When 10 : If DECIM<>0 | ENTIER>20             : mkstat = 1 : Endif : # Clob
Endcase
If mkstat
 GMESSAGE = mess(111,123,1) : # Longueur incorrecte
Endif
End

Subprog AS_SAIAFF(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
Case [M:AMK1]TYPBLOC([M]NUMBLOC(NOL)-1)
 When 5,10   : VALEUR = 3 : mkstat = 2 : End : # Invisible
 When 3,4    : VALEUR = 0 : mkstat = 1 : End : # Photo , texte
Endcase
If [M]CODTYP(NOL)="W" : VALEUR = 2 : mkstat = 2 : End : Endif
If find([M]CODZON(NOL),[M:AMK1]BASPAG(0..[M:AMK1]NBBLOC-1))
# GMENLOC(3)=1 : # Invisible
 GMENLOC(4)=1 : # Technique
Endif
GMENLOC(4)=1 : # Technique est interdit à présent mais gardé par compatibilté
If VALEUR=4 : VALEUR=3 : Endif
End

Subprog C_SAIAFF(VALEUR)
Variable Integer VALEUR
Local Integer OK
Gosub SETNOL
If VALEUR=4 : VALEUR=3 : Endif
If VALEUR>=3
 [M]OPTSAI(NOL) = ""
 [M]OPTFOR(NOL) = ""
 [M]OPTLNG(NOL) = 0
Elsif [M]ZINTIT(NOL)<>"" & PDSZON(NOL)=0
 [M]PDSZON(NOL) = 1 : Affzo PDSZON(NOL)
Endif
If [M:AMK1]TYPBLOC([M]NUMBLOC(NOL)-1)=1
 Call LECTURE("ATY",[M]CODTYP(NOL),"") From CONTOBJ
 If find([F:ATY]TYPTYP,9,10) : # Blob, clob
  If VALEUR>=3
   # L'utilisation de ce type de champ dans un bloc tableau peut générer des anomalies de fonctionnement
   Call AVERTIR(mess([F:ATY]TYPTYP,30,1)-":"-mess(247,123,1),OK) From GESECRAN
   If OK<>2 : mkstat = 2 : End : Endif
  Else
   # Objet non géré sur ce type de bloc
   Call ERREUR(mess([F:ATY]TYPTYP,30,1)-":"-mess(134,123,1)) From GESECRAN
   mkstat = 2 : End
  Endif
 Endif
Endif
End

Subprog AS_MODE(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If [M:AMK1]TYPBLOC([M]NUMBLOC(NOL)-1)<>1 or [M]SAIAFF(NOL)>=3
& or [M]CODZON(NOL)=[M:AMK1]BASPAG([M]NUMBLOC(NOL)-1)
 mkstat = 1 : End
Endif
If [M]CODTYP(NOL)="W" : VALEUR = 1 : mkstat = 2 : End : Endif
End

Subprog AS_DIME(NUM)
Variable Decimal NUM
Gosub SETNOL
If [M]CODTYP(NOL)="" or [M]CODTYP(NOL)="W"
 NUM = 1 : mkstat=2 : End
Elsif find([M]CODZON(NOL),[M:AMK1]BASPAG(0..[M:AMK1]NBBLOC-1)) and [M:AMK1]TYPBLOC([M]NUMBLOC(NOL)-1)=1
 mkstat=1 : End
Elsif [M:AMK1]TYPBLOC([M]NUMBLOC(NOL)-1)=1
 If [M:AMK1]ACTBLOC([M]NUMBLOC(NOL)-1)<>""
  Read [ACV]CODACT = [M]CODACT(NOL)
  If !fstat & [F:ACV]DIME<>0
   mkstat=1 : End
  Endif
 Endif
 NUM = [M:AMK1]NBLIGT([M]NUMBLOC(NOL)-1) : mkstat=2 : End
Elsif [M]CODACT(NOL)<>""
 Read [ACV]CODACT = [M]CODACT(NOL)
 If !fstat & [F:ACV]DIME<>0
  mkstat=1 : End
 Endif
Endif
End

Subprog D_DIME(NUM)
Variable Decimal NUM
Gosub SETNOL
If NUM=0
 Gosub INI_DIME From PARMNT
Endif
End

Subprog AS_OBLIG(VALEUR)
Variable Integer VALEUR
If [M]SAIAFF(nolign-1)<>1 : mkstat=1 : End : Endif
If [M]CODTYP(nolign-1)="" : mkstat=1 : End : Endif
If find([M]CODZON(nolign-1),[M:AMK1]BASPAG(0..[M:AMK1]NBBLOC-1))
 mkstat = 1 : End
Endif
End

Subprog AM_TUNNEL(VALEUR)
Variable Integer VALEUR
If VALEUR =2
 Gosub SETNOL
 Call LECTURE("ATY",[M]CODTYP(NOL),"") From CONTOBJ
 If [F:ATY]OBJLIEN<>""
  Call LECTURE("AOB",[F:ATY]OBJLIEN,"") From CONTOBJ
  If [F:AOB]NOMFIC <> ""
   If find([F:AOB]NOMFIC,[M:AMK1]FICREF(0))
    GMESSAGE = func AFNC.MES1(mess(252,133,1),[F:AOB]NOMFIC)
    mkstat = 2 : End
   Endif
  Endif
 Endif
Endif
End

Subprog AS_TUNNEL(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If [M]SAIAFF(NOL)<>1 : mkstat=1 : End : Endif
If [M]CODTYP(NOL)="" : mkstat=1 : End : Endif
If find([M]CODZON(NOL),[M:AMK1]BASPAG(0..[M:AMK1]NBBLOC-1))
 mkstat=2 : End
Endif
Call LECTURE("ATY",[M]CODTYP(NOL),"") From CONTOBJ
If [F:ATY]OBJLIEN=""
 mkstat=1
 End
Else
 Call LECTURE("AOB",[F:ATY]OBJLIEN,"") From CONTOBJ
 If [F:AOB]NOMFIC <> ""
  If find([F:AOB]NOMFIC,[M:AMK1]FICREF(0))
   VALEUR = 1
   GMENLOC(2) = 1
  Endif
 Endif
Endif
End

Subprog AS_LIEN(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If [M]SAIAFF(NOL)>2  : mkstat = 1 : End : Endif
If [M]CODTYP(NOL)="" : mkstat = 1 : End : Endif
If find([M]CODZON(NOL),[M:AMK1]BASPAG(0..[M:AMK1]NBBLOC-1))
 mkstat = 2 : End
Endif
Call LECTURE("ATY",[M]CODTYP(NOL),"") From CONTOBJ
If [F:ATY]OBJLIEN="" : mkstat = 1 : End : Endif
Call LECTURE("AOB",[F:ATY]OBJLIEN,"") From CONTOBJ
If [F:AOB]NOMFIC="" : mkstat = 1 : End : Endif
Call LECTURE("ATB",[F:AOB]NOMFIC,"") From CONTOBJ
If [F:ATB]INTIT="" & [F:ATB]INTITC="" : mkstat = 1 : End : Endif
If [F:ATB]INTIT=""  : GMENLOC(2) = 1 : Endif
#If [F:ATB]INTITC="" : GMENLOC(3) = 1 : Endif
End

Subprog AS_OPTSAI(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL : Gosub SETSPE
If [M]CODTYP(NOL)="" or [M]CODTYP(NOL)="W" : mkstat=1 : End : Endif
If find([M]CODZON(NOL),[M:AMK1]BASPAG(0..[M:AMK1]NBBLOC-1))
 mkstat=1 : End
Endif
If [M]SAIAFF(NOL)>2 : mkstat = 1 : End : Endif
If [M]OPTFOR(NOL)<>""
 VALEUR = SPE
Endif
End

Subprog C_OPTSAI(VALEUR)
Variable Char VALEUR
Local Integer I , OK
Local Char    OF(1)
Local Integer TAB
Gosub SETNOL : Gosub SETSPE
If [M]OPTFOR(NOL)<>"" & VALEUR<>SPE : mkstat=2 : End
Elsif VALEUR=SPE : End
Endif
Call LECTURE("ATY",[M]CODTYP(NOL),"") From CONTOBJ
TAB = ([M]TYPBLOC([M]NUMBLOC(NOL)-1)=1)
Gosub DEF_OPTFMT From SELAMK
For I=1 To len(VALEUR)
 If !find(mid$(VALEUR,I,1),TEX(1..NBTEX))
  GMESSAGE = mid$(VALEUR,I,1)-":"-mess(99,123,1) : # Option incorrecte
  mkstat = 2 : Break
 Endif
Next I
If mkstat : End : Endif
If [M]SAIAFF(NOL)<>2 & instr(1,VALEUR,"W")
 GMESSAGE = "W :"-mess(177,133,1) : # Ce format est réservé aux champs affichés"
 mkstat = 2 : End
Endif
For OF="3","4"
 If [M]SAIAFF(NOL)<>2 & instr(1,VALEUR,OF) & [F:ATY]TYPTYP=8
  GMESSAGE = OF-":"-mess(177,133,1) : # Ce format est réservé aux champs affichés"
  mkstat = 2 : Break
 Endif
Next OF
If mkstat : End : Endif
Case [F:ATY]TYPTYP
 When 1,8,9,10
 When 7 : # Alpha
  #115175
  #If [F:ATY]FORTYP<>""
  If mid$([F:ATY]FORTYP,1,1)="="
   OK = 1
   For I=1 To len(VALEUR)
    If find(mid$(VALEUR,I,1),"A","#")
     OK = 0 : Break
    Endif
   Next I
   If !OK
    GMESSAGE = mid$(VALEUR,I,1)-":"-mess(53,139,1)-[F:ATY]FORTYP-"("+mess(21,115,1)-[F:ATY]CODTYP+")"
    # Option incompatible avec le format x (Type de donnée y)
    mkstat = 2 : End
   Endif
  Endif
 When Default
Endcase
End

Subprog AM_OPTSAI(VALEUR)
Variable Char    VALEUR()
Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
#115175
#If [F:ATY]TYPTYP=7 & [F:ATY]FORTYP<>"" & instr(1,VALEUR,"C")
If [F:ATY]TYPTYP=7 & mid$([F:ATY]FORTYP,1,1)="=" & instr(1,VALEUR,"C")
 GMESSAGE = "C :"-mess(53,139,1)-[F:ATY]FORTYP-"("+mess(21,115,1)-[F:ATY]CODTYP+")"
 # Option incompatible avec le format x (Type de donnée y)
 mkstat = 2 : End
Endif
End

$SETSPE
Local Char SPE(1)
SPE = "$"
Return

#Subprog AS_MOTCLE(VALEUR)
#Variable Char    VALEUR()
#If [M]SAIAFF(nolign-1)>2 : mkstat=1 : End : Endif
#If [M]CODTYP(nolign-1)="" or [M]CODTYP(nolign-1)="ABS" : mkstat=1 : End : Endif
#GBOUT1 = mess(103,123,1) : # Gestion aides
#End

Subprog AS_OPTLNG(VALEUR)
Variable Decimal  VALEUR
If [M]CODTYP(nolign-1)="" or instr(1,[M]OPTSAI(nolign-1),"L") : mkstat = 1 : End : Endif
Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
If [F:ATY]TYPTYP<>7 : mkstat = 1 : End : Endif : # Alpha
End

Subprog D_TYPGRAPH(VALEUR)
Variable Integer  VALEUR
If [M:AMK2]NOLIB(nolign-1)=1
 VALEUR = 2
Else
 Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
 If [F:ATY]TYPTYP=1 & [F:ATY]NOLIB=1
  VALEUR = 2
 Endif
Endif
End

Subprog AS_TYPGRAPH(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
Local Integer OK , I , TAB
If [M]CODTYP(NOL)="" or [M]CODTYP(NOL)="W" : mkstat=1 : End : Endif
If [M:AMK1]TYPBLOC([M]NUMBLOC(NOL)-1)=10 : VALEUR=1 : mkstat=2 : End : Endif  : # Bloc technique
Call LECTURE("ATY",[M]CODTYP(NOL),"") From CONTOBJ
OK  = ([F:ATY]TYPTYP=8)
If [M:AMK1]TYPBLOC([M]NUMBLOC(NOL)-1)=1
 OK +=  find([M]CODZON(NOL),[M:AMK1]BASPAG(0..[M:AMK1]NBBLOC-1))
Endif
OK +=  [M]SAIAFF(NOL)>2
If OK : VALEUR=1 : mkstat=2 : End : Endif
For I=1 To len(mess(0,43,1))
 GMENLOC(I) = 1
Next I
Case [F:ATY]TYPTYP
 When 1 : # Menu local
  GMENLOC(1)  = 0 : # Aucun
  If [M]NOLIB(NOL)=1 | [F:ATY]NOLIB=1
   GMENLOC(2)  = 0 : # Case à cocher
  Endif
  If [M:AMK1]TYPBLOC([M]NUMBLOC(NOL)-1)<>1 : # Tableau
   GMENLOC(3)  = 0 : # Boutons
   GMENLOC(4)  = 0 : # Boutons
   GMENLOC(5)  = 0 : # Boutons
   GMENLOC(6)  = 0 : # Boutons
  Endif
 When 7 : # Alpha
  GMENLOC(1)  = 0 : # Aucun
  If [M:AMK1]TYPBLOC([M]NUMBLOC(NOL)-1)=2 : # Liste
   GMENLOC(9)  = 0 : # Photo
   GMENLOC(10) = 0 : # Texte multi
   GMENLOC(11) = 0 : # rtf relatif
   GMENLOC(12) = 0 : # rtf absolu
  Endif
  GMENLOC(13) = 0 : # Icône
 When 9 : # Blob
  GMENLOC(9) = 0 : # Photo
  GMENLOC(10) = 0 : # Texte multi
 When 10 : # Clob
  GMENLOC(10) = 0 : # Texte multi
 When Default : # Numérique
  GMENLOC(1)  = 0 : # Aucun
  If [M:AMK1]TYPBLOC([M]NUMBLOC(NOL)-1)<>1 : # Tableau
#  GMENLOC(7)  = 0 : # Spin édit (non actif actuellement)
   GMENLOC(8)  = 0 : # Barre progression
  Endif
Endcase
GBOUT2 = mess(174,100,1) : # Paramètres
End

#--------------------------------#
# Type de graphique
#----------------------
# 2  Case à cocher
# 3  VC
# 4  VS
# 5  HC
# 6  HS
# 7  Spin edit
# 8  Barre progression
# 9  Photo
# 10 Texte multi
# 11 KR
# 12 KH
# 13 Icône
#--------------------------------#

Subprog C_TYPGRAPH(VALEUR)
Variable Integer VALEUR
Local Char    MESSA(250)
Local Integer K , ER
Gosub SETNOL
Call LECTURE("ATY",[M]CODTYP(NOL),"") From CONTOBJ
If !find(VALEUR,1,2,13) & [M:AMK1]TYPBLOC([M]NUMBLOC(NOL)-1)<>2 & [M:AMK1]TYPBLOC([M]NUMBLOC(NOL)-1)<6
 Call ERREUR(mess(134,123,1)) From GESECRAN : # Objet non géré sur ce type de bloc
 mkstat = 2 : End
Endif
ER = 0
If VALEUR=2 & ([F:ATY]TYPTYP<>1 | ([M]NOLIB(NOL)<>1 & [F:ATY]NOLIB<>1)) : ER = 1
Elsif find(VALEUR,1)            & find([F:ATY]TYPTYP,9,10)              : ER = 1
Elsif find(VALEUR,3,4,5,6)      & [F:ATY]TYPTYP<>1                      : ER = 1
Elsif find(VALEUR,7,8)          & !find([F:ATY]TYPTYP,2,3,4,5,6)        : ER = 1
Elsif find(VALEUR,9)            & !find([F:ATY]TYPTYP,7,9)              : ER = 1
Elsif find(VALEUR,11,12,13)     & !find([F:ATY]TYPTYP,7)                : ER = 1
Elsif find(VALEUR,10)
 If !find([F:ATY]TYPTYP,7,9,10) or ([M:AMK1]TYPBLOC([M]NUMBLOC(NOL)-1)=7 & [F:ATY]TYPTYP<>9) : ER = 1 : Endif
Endif
If ER
 Call ERREUR(mess(135,123,1)) From GESECRAN : # Objet incompatible avec le format
 mkstat = 2 : End
Endif
Case VALEUR
 When 13
  If [F:ATY]TYPTYP<>7 or ([M]LONG(NOL)<3 & [F:ATY]LNGTYP<3)
   MESSA = mess(9,139,1) : # La longueur d'un champ icône ne doit pas être inférieure à # caractères
   K = instr(1,MESSA,"#")
   If K : MESSA = left$(MESSA,K-1)+"3"+right$(MESSA,K+1) : Endif
   Call ERREUR(MESSA) From GESECRAN
   mkstat = 2 : End
  Endif
 When 1 , 2
 When Default
  If [M]DIME(NOL)>1
   GMESSAGE = mess(136,123,1) : # Répétition impossible sur ce type d'objet
   mkstat = 2 : End
  Elsif [M]CODACT(NOL)<>""
   Call LECTURE("ACV",[M]CODACT(NOL),"") From CONTOBJ
   If [F:ACV]TYP=2
    GMESSAGE = mess(136,123,1) : # Répétition impossible sur ce type d'objet
    mkstat = 2 : End
   Endif
  Endif
Endcase
End


Subprog AS_CHREPR(VALEUR)
Variable Integer VALEUR
Local Integer NBL
If [M]NUMBLOC(nolign-1)>0
 NBL = [M]NUMBLOC(nolign-1)-1
 If [M:AMK1]TYPBLOC(NBL)<>1 or [M:AMK1]BLOCTYPG(NBL)>2
&   or (left$([M:AMK2]CHPARG(nolign-1),3)<>"G01" and left$([M:AMK2]CHPARG(nolign-1),3)<>"G02")
  VALEUR=0
  mkstat = 1 : End
 Endif
Endif
End

Subprog D_CODACT(VALEUR)
Variable Char    VALEUR()
Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
VALEUR = [F:ATY]CODACT
End

Subprog AS_CODACT(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If [M]CODTYP(NOL)="" : mkstat=1 : End : Endif
End

Subprog C_CODACT(VALEUR)
Variable Char    VALEUR()
Read [ACV]CODACT = VALEUR
If !fstat
 Local Integer I
 I = [F:ACV]DIME
 Gosub LIMITE From SUBAMK1
Endif
End

Subprog C_DIME(VALEUR)
Variable Decimal VALEUR
Local Integer I
I = VALEUR
Gosub LIMITE From SUBAMK1
End


Subprog AS_VALDEF(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If [M]CODTYP(NOL)="" or [M]CODTYP(NOL)="W" : mkstat=1 : End : Endif
End

Subprog AS_CODACC(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If [M]CODTYP(NOL)="" or [M]CODTYP(NOL)="W" : mkstat=1 : End : Endif
# On ne saisit pas pour les blocs techniques
If [M:AMK1]TYPBLOC([M]NUMBLOC(NOL)-1)=10 : mkstat=1 : End : Endif
GBOUT1 = mess(25,115,1) : # Code d'accès
End

Subprog C_CODACC(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Call CONTROLE("ACS","",VALEUR,"",mkstat) From CONTOBJ
End

Subprog B1_CODACC(VALEUR)
Variable Char    VALEUR()
Call OBJET("ACS",VALEUR,"") From GOBJET
End

Subprog AS_CONSAI(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Case [M:AMK1]TYPBLOC([M]NUMBLOC(NOL)-1)
 When 3,4,5,10 : mkstat = 1 : End
Endcase
If [M]SAIAFF(NOL)>1
 mkstat = 1 : End
Endif
End

Subprog AS_CODCTL(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Case [M:AMK1]TYPBLOC([M]NUMBLOC(NOL)-1)
 When 3,4,5,10 : mkstat = 1 : End
Endcase
If [M]SAIAFF(NOL)>1
 mkstat = 1 : End
Endif
End

$SETNOL
Local Integer NOL
NOL = max(0,nolign-1)
Return

#####################################################################
## Tableau des actions
#####################################################################
Subprog AS_TYPACT(VALEUR)
Variable Integer VALEUR
Local Integer I, K
K = find([M]ZONCUR,[M]CODZON(0..[M]NBLIG-1))
If K
 If [M]TYPGRAPH(K-1)=13 : # Icône
  GMENLOC(1) = 1 : # Init-bouton
  For I=8 To 30
   GMENLOC(I) = 1 : # Tous les boutons
  Next I
 Elsif [M]CODTYP(K-1)<>"ABS"
  GMENLOC(13) = 1  : # Avant-ligne
  GMENLOC(14) = 1  : # Après-ligne
  GMENLOC(31) = 1  : # Clic
 Else
  GMENLOC(31) = 1  : # Clic
 Endif
Endif
End

Subprog C_TYPACT(VALEUR)
Variable Integer VALEUR
If GADONIX<>2
 If [M]ACTION(nolign-1)="STD" & VALEUR<>[M]TYPACT(nolign-1)
  VALEUR = [M]TYPACT(nolign-1)
  GMESSAGE = mess(9,123,1) : # Modification impossible
  mkstat = 2 : End
 Endif
Endif
Local Integer K , OK
Local Char    ACT(GLONACT) , ACTION(GLONACT)
K = find([M]ZONCUR,[M]CODZON(0..[M]NBLIG-1))
If K
 If (VALEUR>=8 & VALEUR<=12) | VALEUR>=15
  Call LECTURE("ATY",[M]CODTYP(K-1),"") From CONTOBJ
  If find(VALEUR,[F:ATY]ACTTYP(0..[F:ATY]NBTYP-1))
   OK = 2 : Call AVERTIR(mess(VALEUR,31,1)-":"-ACTION-mess(146,126,1)-[F:ATY]CODTYP,OK) From GESECRAN
#  Action utilisée par le type de données
   If OK<>2 : mkstat = 2 : End : Endif
  Endif
 Endif
Endif
End

Subprog AS_NBACT
Gosub SET_VIRELIG
End

$SET_VIRELIG
# mb 15/6/98 en duplication, le distributeur peut virer des actions standard
If [M]ACTION(nolign-1) = "STD"
 If GADONIX<>2 & GREP<>"D"
  Disable 65
 Else
  Enable 65
 Endif
# mb 2.3.6 en duplication, le client peut virer des actions vertical
Elsif [M]ACTION(nolign-1) = "SPV"
 If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
 If clalev([F:ADW])=0 : Local File ADOVAL   [ADW] : Endif
 Read [ADW]ADW0="";"";"SUPDOS"
 Read [ADS]DOSSIER=nomap
 If [F:ADS]DOSREF<>[F:ADW]VALEUR
  Disable 65
 Else
  Enable 65
 Endif
Else
 Enable 65
Endif
Return

Subprog C_NBACT
Case adxgtb
 When 0 : # On est en saisie dans le tableau
  Gosub SET_VIRELIG
 When 1,2 : # On sort du tableau
  Enable 65
Endcase
End

Subprog AP_NBACT
If find(adxgtb,1,2)
 If [M]NBACT<>0
  Call CHARGE_PARACT([M]CODMSK,[M]ZONCUR) From PARMNT
 Endif

 Call CHKACTUPD     # Issue X3-58759 - 2018-06-29 by CCC : check if actions have been modified

 Call VALID_ACT([M]CODMSK,[M]ZONCUR) From PARMNT
Endif
End

Subprog D_ACTION(VALEUR)
Variable Char     VALEUR
If GADONIX=2
 VALEUR = "STD"
Else
 VALEUR = "SPE"
Endif
End

Subprog C_ACTION(VALEUR)
Variable Char VALEUR
Gosub SETNOL
[M]COMBI(NOL) = num$([M]TYPACT(NOL))+VALEUR
Call UNICITE([M]COMBI(NOL),[M]COMBI(0..[M]NBACT-1)) From OBJDIV
If mkstat : End : Endif
If VALEUR="SPV" & [M]TRTSPV=""
 GMESSAGE=mess(123,139,1) : # Traitement vertical non renseigné
 mkstat = 2 : End
Elsif (VALEUR="SPV" or [M]ACTION(NOL)="SPV")
 If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
 If clalev([F:ADW])=0 : Local File ADOVAL   [ADW] : Endif
 Read [ADW]ADW0="";"";"SUPDOS"
 Read [ADS]DOSSIER=nomap
 If [F:ADS]DOSREF<>[F:ADW]VALEUR
  If GREP<>"D" & [M]ACTION(NOL)="SPV" & VALEUR<>"SPV"
   VALEUR = "SPV"
   GMESSAGE = mess(9,123,1) : # Modification impossible
   mkstat = 2 : End
  Elsif [M]ACTION(NOL)<>"SPV" & VALEUR="SPV"
   GMESSAGE = mess(83,123,1) : # Valeur incorrecte
   mkstat = 2 : End
  Endif
 Endif
Endif
If GADONIX<>2
 If GREP<>"D" & [M]ACTION(nolign-1)="STD" & VALEUR<>"STD"
  VALEUR = "STD"
  GMESSAGE = mess(9,123,1) : # Modification impossible
  mkstat = 2 : End
 Elsif [M]ACTION(nolign-1)<>"STD" & VALEUR="STD"
  GMESSAGE = mess(83,123,1) : # Valeur incorrecte
  mkstat = 2 : End
 Endif
Endif
End

Subprog AP_ACTION(VALEUR)
Variable Char    VALEUR()
End

Subprog AS_ZINTITACT(VALEUR)
Variable Char    VALEUR()
If !(find([M]TYPACT(nolign-1),9,10,11,12) | [M]TYPACT(nolign-1)>=15)
 Call LECTURE("ACT",[M]ACTION(nolign-1),"") From CONTOBJ
 If [F:ACT]INTITC<>0
  Call TEXTE([F:ACT]INTITC,VALEUR) From OBJDIV
 Else
  Call TEXTE([F:ACT]INTITA,VALEUR) From OBJDIV
 Endif
 mkstat = 2
Elsif VALEUR=""
 Call LECTURE("ACT",[M]ACTION(nolign-1),"") From CONTOBJ
 If [F:ACT]INTITC<>0
  Call TEXTE([F:ACT]INTITC,VALEUR) From OBJDIV
 Elsif [F:ACT]TYP<>1
  Call TEXTE([F:ACT]INTITA,VALEUR) From OBJDIV
 Endif
Endif
End

Subprog D_EXEACT(VALEUR)
Variable Integer VALEUR
If find([M]TYPACT(nolign-1),1,2,3,4,5,6,7,13,14) : # Pas des boutons
 VALEUR = 3 : # Toujours
Endif
End

Subprog AS_EXEACT(VALEUR)
Variable Integer VALEUR
If find([M]TYPACT(nolign-1),8,9,10,11,12) | [M]TYPACT(nolign-1)>=15 : # Les boutons
 GMENLOC(2) = 1 : # Import/batch
 GMENLOC(3) = 1 : # Toujours
Else
 Call LECTURE("ACT",[M]ACTION(nolign-1),"") From CONTOBJ
 If !find([F:ACT]TYP,7,8) : # Les actions qui ouvrent des fenêtres ne peuvent pas être gérées en import
  If !([F:ACT]TYP=3 & [F:ACT]PARAM2="" & [F:ACT]PARAM3=1) : # Action "Traitement standard" sans fenêtre ni saisie initiale
   GMENLOC(2) = 1 : # Import/batch
   GMENLOC(3) = 1 : # Toujours
  Endif
 Endif
Endif
End

Subprog AS_DISACT(VALEUR)
Variable Integer VALEUR
Case [M]ACTION(nolign-1)
 When "SPE" : # Spécifique
 When "SPV" : # Vertical
  GMENLOC(3) = 1 : # Verticale
  GMENLOC(4) = 1 : # Toutes
 When Default
  mkstat = 1
Endcase
End

Subprog C_DISACT(VALEUR)
Variable Integer VALEUR
If [M]ACTION(nolign-1)="SPV"
 If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
 If clalev([F:ADW])=0 : Local File ADOVAL   [ADW] : Endif
 Read [ADW]ADW0="";"";"SUPDOS"
 Read [ADS]DOSSIER=nomap
 If [F:ADS]DOSREF<>[F:ADW]VALEUR
  If [M]DISACT(nolign-1)<>VALEUR
   VALEUR = [M]DISACT(nolign-1)
   GMESSAGE = mess(9,123,1) : # Modification impossible
   mkstat = 2 : End
  Endif
 Endif
Endif
End

#####################################################################
## Tableau des paramètres
#####################################################################
Subprog AS_NBPAR
If [M]NBPAR=0 : mkstat=1 : End : Endif
End

Subprog C_NBPAR
Local Integer I
If find(adxgtb,1,2)
 For I=0 To [M]NBPAR-1
  If [M]VALPAR(I)=""
   GMESSAGE = mess(171,133,1)-[M]CODPAR(I) : # Paramètre non renseigné
   mkstat=2 : Break
  Endif
 Next I
Endif
End

Subprog AP_NBPAR
If find(adxgtb,1,2)
 Call CHKPARUPD     # Issue X3-58759 - 2018-06-29 by CCC : check if parameters have been modified
 Call VALID_ACT([M]CODMSK,[M]ZONCUR) From PARMNT
 Inftxt [M]ZONCUR At 2
Endif
End

Subprog AS_VALPAR(VALEUR)
Variable Char    VALEUR()
If dim([M]AIDE)>0
 [M]AIDE = [M]INFO(nolign-1)
 Affzo AIDE
Else
 Inftxt [M]INFO(nolign-1) At 2
Endif
End

Subprog C_INTEVAL(VALEUR)
Variable Char     VALEUR
If left$(VALEUR,1)="=" : mkstat = 2 : Endif
End

Subprog AS_TRANSM(VALEUR)
Variable Integer VALEUR
Gosub SETNOL
If [M]SAIAFF(NOL)<3 : VALEUR=0 : mkstat=1 : Endif
Case [M:AMK1]TYPBLOC([M]NUMBLOC(NOL)-1)
 When 10     : VALEUR = 2  :   [M]OPTSAI(NOL) = "*" : [M]OPTFOR(NOL) = "" : mkstat = 2
 When 5      : GMENLOC(2)=1
Endcase
End

Subprog C_TRANSM(VALEUR)
Variable Integer VALEUR
End

Subprog AV_ZINTIT(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
If find([M:AMK2]CODZON(NOL),[M:AMK1]BASPAG(0..[M:AMK1]NBBLOC-1))
  [M:AMK2]INTIT(nolign-1) = 0
  mkstat=1
Endif
End

#Subprog AS_ZINFBUL(VALEUR)
#Variable Char VALEUR
#If [M]SAIAFF(nolign-1)>2
# [M]INFBUL(nolign-1) = 0
# mkstat = 1 : End
#Endif
#End

Subprog AS_ACHPARG(VALEUR)
Variable Char    VALEUR()
Local Integer NBL :  NBL = [M]NUMBLOC(nolign-1)-1
If NBL<0 : End : Endif
#  Est-on sur un bloc tableau avec représentation graphique ?
 If [M:AMK1]TYPBLOC(NBL)<>1 or [M:AMK1]BLOCTYPT(NBL)<=1
& or find([M]CODZON(nolign-1),[M:AMK1]BASPAG(0..[M:AMK1]NBBLOC-1))
  mkstat = 1 : End
 Endif
 If [M]CODTYP(nolign-1)="AEX" : mkstat=1 : End : Endif    : # Champ d'exclusion
# On est sur un graphique
Case [M:AMK1]BLOCTYPG(NBL)
  When 1,2 : # Bloc Graphique
  When 3   : # Agenda
  When 4   : # XSL   Le code XSL est dans [M:AMK1]BLOCLIEN1(NBL)
  When 5   : # Gantt
Endcase

End


######################################################################################
$SELLIST
#   Code sélection SELPGRA

 Local Integer NBL :  NBL = [M]NUMBLOC(val(PARAM(1))-1)-1
 Local Char LCOD
# Sur quel graphique est-on
# Case [M:AMK1]BLOCTYPG(NBL)
#  When 1,2 : # Bloc Graphique
#  When 3   : # Agenda
#  When 4   : # XSL   Le code XSL est dans [M:AMK1]BLOCLIEN1(NBL)
#  When 5   : # Gantt
# Endcase
 Raz TEXTE,TEX,NBTEX
 Local File ATABDIV [A_TD]
 If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
 Read [A_TD]CODE=915;"F"+format$("N0:##",[M:AMK1]BLOCTYPG(NBL))
 If fstat<>0 : Return : Endif
 LCOD=[F:A_TD]A2
 If LCOD="XSL"
   LCOD=[M:AMK1]BLOCLIEN1(NBL)
   If clalev([F:AUR])=0 : Local File AURL [AUR] : Endif
   Read [AUR]AUR0=LCOD
   If fstat<>0 : Return : Endif
   LCOD=[F:AUR]PARXSL
 Endif

 Local Integer TYPDO,GRAP
 If [M:AMK1]BLOCTYPG(NBL)=1 or [M:AMK1]BLOCTYPG(NBL)=2
   GRAP=1
   Call LECTURE("ATY",[M]CODTYP(val(PARAM(1))-1),"") From CONTOBJ
   TYPDO=[F:ATY]TYPTYP
 Endif


 Filter [A_TD] Where NUMTAB=915 and A1=LCOD and A2<>""
 For [A_TD]
    If GRAP=1
      If [F:A_TD]CODE="G03" and TYPDO<>7 : Goto SUITSELG : Endif
      If [F:A_TD]CODE="G01" and TYPDO>4  : Goto SUITSELG : Endif
      If [F:A_TD]CODE="G02" and TYPDO>4  : Goto SUITSELG : Endif
    Endif
    NBTEX += 1
    TEXTE(NBTEX) = [F:A_TD]A2
    Read [AXX]AXX0="ATABDIV";"LNGDES";GLANGUE;"915";[F:A_TD]CODE
    If fstat=0
      TEXTE(NBTEX)+=" : "+[F:AXX]TEXTE
    Endif
    TEX(NBTEX) = [F:A_TD]CODE+":"+[F:A_TD]A2
$SUITSELG
 Next
 Filter [A_TD]
 Close Local File [A_TD]
Return

$FINLIST
#   Code sélection SELPGRA
If len(VALEUR)<3 : Return : Endif
[M:AMK2]CHPARG(val(PARAM(1))-1)=VALEUR
Read [AXX]AXX0="ATABDIV";"LNGDES";GLANGUE;"915";left$(VALEUR,3)
If fstat=0
  VALEUR=[F:AXX]TEXTE
Endif
Return

Subprog C_ACHPARG(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : [M:AMK2]CHPARG(nolign-1)="" : End : Endif
Local Integer NBL,I,TRV,TRVAP :  NBL = [M]NUMBLOC(nolign-1)-1
If NBL<0 : End : Endif

#  Est-on sur un bloc tableau avec représentation graphique ?
 If [M:AMK1]TYPBLOC(NBL)<>1 or [M:AMK1]BLOCTYPT(NBL)<=1
& or find([M]CODZON(nolign-1),[M:AMK1]BASPAG(0..[M:AMK1]NBBLOC-1))
  VALEUR="" : [M:AMK2]CHPARG(nolign-1)="" : End
 Endif
 If [M]CODTYP(nolign-1)="AEX" : VALEUR="" : [M:AMK2]CHPARG(nolign-1)="" : End : Endif  : # Champ d'exclusion

# On est sur un graphique
Case [M:AMK1]BLOCTYPG(NBL)
  When 1,2 : # Bloc Graphique
  When 3   : # Agenda
  When 4   : # XSL   Le code XSL est dans [M:AMK1]BLOCLIEN1(NBL)
  When 5   : # Gantt
Endcase

If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
Local Char LCOD
Read [ADI]CODE=915;"F"+format$("N0:##",[M:AMK1]BLOCTYPG(NBL))
If fstat<>0 : Return : Endif
LCOD=[F:ADI]A2
If LCOD="XSL"
  LCOD=[M:AMK1]BLOCLIEN1(NBL)
  If clalev([F:AUR])=0 : Local File AURL [AUR] : Endif
  Read [AUR]AUR0=LCOD
  If fstat=0 : LCOD=[F:AUR]PARXSL : Endif
Endif
Local Char TTX(20)(1..30),TTX1(50)(1..30)
Local Integer UNIC(1..30)
Local Integer NBX
Filter [ADI] Where NUMTAB=915 and A1=LCOD and A2<>""
For [ADI]
  NBX += 1
  TTX(NBX) = [F:ADI]CODE+":"+[F:ADI]A2
  UNIC(NBX)=[F:ADI]N1
  Read [AXX]AXX0="ATABDIV";"LNGDES";GLANGUE;"915";[F:ADI]CODE
  If fstat=0
    TTX1(NBX)=[F:AXX]TEXTE
  Endif
Next
Filter [ADI]

#  Contrôle que la valeur saisie appartient à la famille de paramètres
#  ou que c'est un début de valeur (complétion automatique)
If NBX=0 : VALEUR="" : [M:AMK2]CHPARG(nolign-1)="" : End : Endif

For I=1 To NBX
  If toupper(VALEUR)=toupper(TTX1(I)) : TRV=I : Break 1 : Endif
  If toupper(vireblc(VALEUR,2))=toupper(left$(TTX1(I),len(vireblc(VALEUR,2)))) and TRVAP=0 : TRVAP=I : Endif
Next I
#   Valeur incorrecte
If TRV=0 and TRVAP=0 : GMESSAGE=mess(83,123,1) : mkstat=2 : End : Endif
#   Saisie incomplète
If TRV=0 and TRVAP<>0 : TRV=TRVAP : Endif
VALEUR=TTX1(TRV)
[M:AMK2]CHPARG(nolign-1)=TTX(TRV)

#  Contrôle de l'unicité si valeur paramétrée "unique"

If UNIC(TRV)=2
     For I=0 To [M:AMK2]NBLIG-1
       If [M:AMK2]NUMBLOC(I)=NBL+1 and I<>nolign-1 and [M:AMK2]ACHPARG(I)=VALEUR
#   Code déjà attribué en ligne
         GMESSAGE=mess(149,150,1)-num$(I+1) : mkstat=2 : End
       Endif
     Next I
Endif

#  Contrôles spécifiques aux graphes :
#       - Valeur et défaut ne concernent que les colonnes numériques
#       - Libellé est une colonne de type alphanumérique
#       - Il n'y a qu'un seul défaut sur les graphes simples
Call LECTURE("ATY",[M]CODTYP(nolign-1),"") From CONTOBJ
If [M:AMK1]BLOCTYPG(NBL)=1 or [M:AMK1]BLOCTYPG(NBL)=2
 If left$(TTX(TRV),3)="G03" and [F:ATY]TYPTYP<>7
#  Le champ intitulé doit être de type alphanumérique
   GMESSAGE=mess(236,123,1) : mkstat=2 : End
 Elsif (left$(TTX(TRV),3)="G01" or left$(TTX(TRV),3)="G02") and ([F:ATY]TYPTYP<1 or [F:ATY]TYPTYP>4)
#  Les champs graphique doivent être de type numérique
   GMESSAGE=mess(237,123,1) : mkstat=2 : End
 Endif
Endif

#  Contrôles spécifiques aux radar :
#       - Les colonnes valeur sont numériques
#       - Libellé est une colonne de type alphanumérique
If [M:AMK1]BLOCTYPG(NBL)=4
 If left$(TTX(TRV),3)="R03" and [F:ATY]TYPTYP<>7
#  Le champ intitulé doit être de type alphanumérique
   GMESSAGE=mess(236,123,1) : mkstat=2 : End
 Elsif left$(TTX(TRV),3)="R02" and ([F:ATY]TYPTYP<1 or [F:ATY]TYPTYP>4)
#  Les champs graphique doivent être de type numérique
   GMESSAGE=mess(237,123,1) : mkstat=2 : End
 Endif
Endif


End

Subprog D_ACHPARG(VALEUR)
Variable Char    VALEUR()
End

Subprog AS_CHGRAPH(VALEUR)
Variable Integer VALEUR
End

#X3-91078
Subprog AS_ISMASKABLE(VALEUR)
Variable Integer VALEUR
  If [M]SAIAFF(nolign-1)>2 or
&      find([M]CODZON(nolign-1),[M:AMK1]BASPAG(0..[M:AMK1]NBBLOC-1))
   mkstat = 1
  Endif
End

# Issue X3-110075 - 2018-10-03 by ALSHE : Refuse entry if field is hidden or used as block parameter
Subprog AS_BREAKAFTER(VALEUR)
Variable Integer VALEUR
  If [M]SAIAFF(nolign-1)>2 or
&      find([M]CODZON(nolign-1),[M:AMK1]BASPAG(0..[M:AMK1]NBBLOC-1))
   mkstat = 1
  Endif
End
# End issue X3-110075


######################################################################################
#**
#* Check if an action has been modified for the current field (ZONCUR)
#* If this is the case, corresponding ACTUPDFLG is set to 2
#*!
Subprog CHKACTUPD

Local Integer LINE_FLD      # Line number of current field (ZONCUR)
Local Integer LACTUPD       # Flag to know if [M]ACTUPDFLG must be set to 2
Local Char    LFLD(GLONAVA) # Field names to compare
Local Integer I

LACTUPD = [V]CST_AFALSE

# Issue X3-58759 - 2018-06-29 by CCC : to alert if Cancel is required afterwards
If dim([M:AMK2]ACTUPDFLG)>0
    LINE_FLD = find([M]ZONCUR,[M:AMK2]CODZON)
    If LINE_FLD>0 & [M:AMK2]ACTUPDFLG(LINE_FLD-1) = 1

        # If the number of actions is different => record that actions have been modified
        Filter [AMA] Where CODAFF=[M]CODMSK
&                        & CODZON=[M]ZONCUR
&                        & TYPAFF=1
        If [M:AMK2]NBACT <> rowcount([AMA])
            LACTUPD = [V]CST_ATRUE
        Else
            # Otherwise check if each action has been modified
            For nolign=1 To [M:AMK2]NBACT
                Raz [F:AMA]
                Filter [AMA] Where CODAFF=[M]CODMSK
&                                & CODZON=[M]ZONCUR
&                                & TYPAFF=1
&                                & NOACT =[M]NOAC(nolign-1)
                Read [AMA] First
                Filter [AMA]
                # Only these fields can be modified
                For LFLD="ACTION","TYPACT","INTITACT","EXEACT","DISACT"
                    If evalue("[F:AMA]"+LFLD)<>evalue("[M:AMK2]"+LFLD)
                        LACTUPD = [V]CST_ATRUE
                        Break 2
                    Endif
                Next
            Next
        Endif
        Filter [AMA]

        If LACTUPD = [V]CST_ATRUE
            [M:AMK2]ACTUPDFLG(LINE_FLD-1) = 2
        Endif
    Endif
Endif

End


#**
#* Check if an action parameter has been modified for the current field (ZONCUR)
#* If this is the case, corresponding ACTUPDFLG is set to 2
#*!
Subprog CHKPARUPD

Local Integer LINE_FLD      # Line number of current field (ZONCUR)
Local Integer LACTUPD       # Flag to know if [M]ACTUPDFLG must be set to 2
Local Integer I

LACTUPD = [V]CST_AFALSE

# Issue X3-58759 - 2018-06-29 by CCC : to alert if Cancel is required afterwards
If dim([M:AMK2]ACTUPDFLG)>0
    LINE_FLD = find([M]ZONCUR,[M:AMK2]CODZON)
    If LINE_FLD>0 & [M:AMK2]ACTUPDFLG(LINE_FLD-1) = 1
        # Otherwise check if each action has been modified
        For I=0 To [M:AMK2]NBPAR-1
            Read [AMP]CODPAR=1;[M]CODMSK;[M]ZONCUR;[M:AMK2]CODPAR(I)
            If [M:AMK2]VALPAR(I)<>[F:AMP]VALPAR
                LACTUPD = [V]CST_ATRUE
                Break
            Endif
        Next

        If LACTUPD = [V]CST_ATRUE
            [M:AMK2]ACTUPDFLG(LINE_FLD-1) = 2
        Endif
    Endif
Endif
End


