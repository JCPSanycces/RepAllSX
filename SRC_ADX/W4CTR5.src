#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR5 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_TAXSTAAFR
Onevent BEFORE_INPUT Call AS_TAXSTAAFR(zc) From W4CTR5
Onevent AFTER_CHANGE Gosub AMM_TAXSTAAFR From W4CTR5
Onevent INIT_AREA Call D_TAXSTAAFR(zc) From W4CTR5
Onevent CONTROL Call C_TAXSTAAFR(zc) From W4CTR5
Return

Subprog D_TAXSTAAFR(VALEUR)
Variable Integer VALEUR
If varinit([M]TAXSTAAFR,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_TAXSTAAFR(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(11705) From COMBOS
## Action STD
Call AS_TAXSTAAFR(VALEUR) From SUBCTR
If mkstat=2
 [M]TAXSTAAFR(INDIC) = VALEUR
 Affzo TAXSTAAFR(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,11705,1))))
Endif
If !mkstat
 Discombo 0 From TAXSTAAFR(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From TAXSTAAFR(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_TAXSTAAFR(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

$AMM_TAXSTAAFR
Call AM_TAXSTAAFR(zc)
If !mkstat & GOBJET
 zoncou = "TAXSTAAFR" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TAXSTAAFR(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_TAXSTAAFR(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "TAXSTAAFR" : GZNUM = 56139 : Endif
Gosub _AFF
End

