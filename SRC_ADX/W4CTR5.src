$ON_VEHRAT
Onevent INIT_AREA Call D_VEHRAT(zc) From W4CTR5
Onevent CONTROL Call C_VEHRAT(zc) From W4CTR5
Onevent BEFORE_INPUT Call AS_VEHRAT(zc) From W4CTR5
Onevent AFTER_CHANGE Gosub AMM_VEHRAT From W4CTR5
Return

Subprog D_VEHRAT(VALEUR)
Variable Char    VALEUR()
If varinit([M]VEHRAT,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"11700","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_VEHRAT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"11700") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_VEHRAT(zc) From W4CTR5
Onkey   2 Titled GBOUTS Call S_VEHRAT(zc) From W4CTR5
Onkey 144 Titled GBOUTP Call P_VEHRAT(zc) From W4CTR5
Onkey 146 Titled GBOUTA Call SA_VEHRAT(zc) From W4CTR5
Gosub _AFF
End

Subprog C_VEHRAT(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"11700","") From SUBADI
If mkstat : GERR = 1 : GZONE = "VEHRAT" : GZNUM = 55179 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"11700",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "VEHRAT" : GZNUM = 55179 : Endif
Endif
Gosub _AFF
End

$AMM_VEHRAT
Call AM_VEHRAT(zc)
If !mkstat & GOBJET
 zoncou = "VEHRAT" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_VEHRAT(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZVEHRAT)")>indice
 [M]VEHRAT(indice) = VALEUR
 Affzo ZVEHRAT(indice)
Endif
Gosub _AFF
End

Subprog S_VEHRAT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "11700"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_VEHRAT(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"11700") From GOBJET
Gosub _AFF
End

Subprog SA_VEHRAT(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "11700"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_VEHRAT(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "11700"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZVEHRAT
Onevent BEFORE_AREA Gosub AV_ZVEHRAT From W4CTR5
Return

$AV_ZVEHRAT
Call LECTEXTRA(zc,"ATABDIV","LNGDES","11700",num$([M]VEHRAT(indice))) From ATEXTRA
Gosub _AFF
Return

