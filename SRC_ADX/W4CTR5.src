$ON_TAXCOD
Onevent INIT_AREA Call D_TAXCOD(zc) From W4CTR5
Onevent CONTROL Call C_TAXCOD(zc) From W4CTR5
Onevent AFTER_CHANGE Gosub AMM_TAXCOD From W4CTR5
Onevent BEFORE_INPUT Call AS_TAXCOD(zc) From W4CTR5
Return

Subprog D_TAXCOD(VALEUR)
Variable Char    VALEUR()
If varinit([M]TAXCOD,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"11800","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_TAXCOD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_TAXCOD(zc) From W4CTR5
Onkey 144 Titled GBOUTP Call P_TAXCOD(zc) From W4CTR5
Onkey 146 Titled GBOUTA Call SA_TAXCOD(zc) From W4CTR5
If VALEUR="" : Call INIADI(VALEUR,"11800") From TRTDIV : Endif
Gosub _AFF
End

Subprog C_TAXCOD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "TAXCOD" : GZNUM = 3616 : Endif
If !mkstat
 ## Action CONTADI
 Call CONTADI(VALEUR,"11800","") From SUBADI
 If mkstat : GERR = 1 : GZONE = "TAXCOD" : GZNUM = 3616 : Endif
 If !mkstat
  ## Action %CNTOBJ
  Call CONTSEL("ADI","",VALEUR,"11800",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "TAXCOD" : GZNUM = 3616 : Endif
 Endif
Endif
Gosub _AFF
End

$AMM_TAXCOD
Call AM_TAXCOD(zc)
If !mkstat & GOBJET
 zoncou = "TAXCOD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_TAXCOD(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_TAXCOD(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "TAXCOD" : GZNUM = 3616 : Endif
Gosub _AFF
End

Subprog S_TAXCOD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "11800"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_TAXCOD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "11800"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_TAXCOD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "11800"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

