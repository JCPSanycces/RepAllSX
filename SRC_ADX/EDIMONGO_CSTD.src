#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe EDIMONGO


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
    When "MET_UPDATE_MONGO"           : Gosub MET_UPDATE_MONGO
    When "OPE_UPDATE_MONGO"           : Gosub OPE_UPDATE_MONGO
  Endcase
Return


$MET_UPDATE_MONGO
Return

$OPE_UPDATE_MONGO
  #variables and log
  Gosub UPDATEMONGO_DECLARE
  Gosub UPDATEMONGO_LOG_CREATE
  Gosub UPDATEMONGO_LOG_START

  If POS = 0 #c'est toute la liste à traiter
    #treat all
    Call ADDDIAGNOSE(this.ACTX,"***"-":"-mess(70,2007,1),[V]CST_AINFO) From ASYRASYNC
    #processing objects
    #la liste ne concerne pas le XML
#    If this.APARENT.AINF.NAMCLA = "EDIMONGO_RSTD"
      Gosub UPDATEMONGO_EDI_SETUP_EDIPTC
      Gosub UPDATEMONGO_EDI_SETUP_EDIMSG
      Gosub UPDATEMONGO_EDI_SETUP_EDISEQFIL
      Gosub UPDATEMONGO_EDI_SETUP_EDIXSDUPL
      Gosub UPDATEMONGO_EDI_SETUP_EDIFLO
#    Elsif this.APARENT.AINF.NAMCLA = "EDIMONGOXML_RSTD"
#      Gosub UPDATEMONGO_EDI_SETUP_EDIXMLFIL
#    Endif
  Else
    #get OBJTYP + KEYS
    Local Integer I, J
    Local Char WMYSTRKEY(250)
    J = 1
    For I = 1 To len(KEYS)
      If mid$(KEYS,I,1) <> '-'
        WMYKEYVAL(J) = WMYKEYVAL(J) + mid$(KEYS,I,1)
        WMYSTRKEY = WMYSTRKEY + mid$(KEYS,I,1)
      Else
        J = J + 1
        WMYSTRKEY = WMYSTRKEY + "~"
      Endif
    Next I
#    Call ADDDIAGNOSE(this.ACTX,"***"-":"-"Processing record"-OBJTYP-WMYSTRKEY,[V]CST_AINFO) From ASYRASYNC

    Case OBJTYP
      When "EDIPTC"    : Gosub UPDATEMONGO_EDI_SETUP_EDIPTC
      When "EDIMSG"    : Gosub UPDATEMONGO_EDI_SETUP_EDIMSG
      When "EDISEQFIL" : Gosub UPDATEMONGO_EDI_SETUP_EDISEQFIL
      When "EDIXSDUPL" : Gosub UPDATEMONGO_EDI_SETUP_EDIXSDUPL
      When "EDIXMLFIL" : Gosub UPDATEMONGO_EDI_SETUP_EDIXMLFIL
      When "EDIFLO"    : Gosub UPDATEMONGO_EDI_SETUP_EDIFLO
    Endcase
  Endif

  #log
  Gosub UPDATEMONGO_LOG_CLOSE
  Gosub UPDATEMONGO_LOG_END
  ARET_VALUE = [V]CST_AOK
Return


#********************************************************************
# UPDATEMONGO_DECLARE
#********************************************************************
# Variables declarations
#********************************************************************
#*!
$UPDATEMONGO_DECLARE
  Local Integer WSTA
  Local Integer WOK
  Local Char WERR(250)
  Local Char WERRROOT(250)
  Local Char WTMP_ERRROOT(250)
  Local Char WCACHEUUID(36)
  Local Char WTMP_CACHEUUID(36)
  Local Char WTABLE(30)
  Local Char WABRCLA(20)
  Local Char WNEWCACHEUUID(36)
  Local Char WMYKEY(20)(1..)
  Local Char WMYKEYVAL(30)(1..)
    WMYKEYVAL(1) = ""
    WMYKEYVAL(2) = ""
    WMYKEYVAL(3) = ""
    WMYKEYVAL(4) = ""
  Local Char WMYKEYSTR(250)

  Local Integer WFLG_NEXT

  Local Integer WNBERR_TOT_FOUND   : WNBERR_TOT_FOUND = 0
  Local Integer WNBWAR_TOT_FOUND   : WNBWAR_TOT_FOUND = 0
  Local Integer WNBERR_FOUND       : WNBERR_FOUND = 0
  Local Integer WNBWAR_FOUND       : WNBWAR_FOUND = 0
  Local Integer WGET_OBJ_FLG_FOUND : WGET_OBJ_FLG_FOUND = [V]CST_ANO

  Local Integer WPHASE_STEP        : WPHASE_STEP = 0
  Local Integer WPHASE_PROGRESS    : WPHASE_PROGRESS = 0
  Local Char WPHASE_TITLE(250)
  Local Char WPHASE_DETAIL(250)
Return

#********************************************************************
# UPDATEMONGO_LOG_CREATE
#********************************************************************
# Log create
#********************************************************************
#*!
$UPDATEMONGO_LOG_CREATE
  WPHASE_STEP = WPHASE_STEP # + 1 #step 0
  WPHASE_PROGRESS = WPHASE_STEP * 10
  WPHASE_TITLE = mess(60,2007,1)-num$(WPHASE_STEP)-"-"-mess(72,2007,1)#"Lancement du traitement de mise à jour de la base MongoDB"
  WPHASE_DETAIL = mess(71,2007,1) #"Préparation du fichier trace"
  Call ASYNCTRACK(this.ACTX, WPHASE_TITLE, WPHASE_DETAIL, 10) From ASYRASYNC
  Call ADDDIAGNOSE(this.ACTX,WPHASE_TITLE-":"-WPHASE_DETAIL,[V]CST_AINFO) From ASYRASYNC

  Local Char WLOGNAME(50)      : WLOGNAME = "EDI_Update_MongoDB"
  Local Char WLOGFILENAME(100) : WLOGFILENAME = "[TRA]/"+WLOGNAME+".tra"

  Local Instance WMYLOG Using C_ALOG
  WMYLOG = NewInstance C_ALOG AllocGroup null
  WOK = fmet WMYLOG.ASETNAME(WLOGNAME)
  WOK = fmet WMYLOG.APUTLINE(string$(115,"*"),[V]CST_AINFO)
  WERR = mess(72,2007,1) #"Lancement du traitement de mise à jour de la base MongoDB"
  Local Integer WNBLEFT
  Local Integer WNBRIGHT
  WNBLEFT = abs((115-len(WERR))/2)
  WNBRIGHT = 115-len(WERR)-WNBLEFT
  WOK = fmet WMYLOG.APUTLINE(string$(WNBLEFT," ")+WERR+string$(WNBRIGHT," "),[V]CST_AINFO)
  WOK = fmet WMYLOG.APUTLINE(string$(115,"*"),[V]CST_AINFO)
  WOK = fmet WMYLOG.APUTLINE("",[V]CST_AINFO)
  WOK = fmet WMYLOG.APUTLINE("",[V]CST_AINFO)
Return

#********************************************************************
# UPDATEMONGO_LOG_START
#********************************************************************
# Log start
#********************************************************************
#*!
$UPDATEMONGO_LOG_START
  TIT = mess(25,2007,1) #"Processing"
  WOK = fmet WMYLOG.APUTLINE("*"-toupper(TIT),[V]CST_AINFO)
  WOK = fmet WMYLOG.APUTLINE(string$(115,"="),[V]CST_AINFO)
  WOK = fmet WMYLOG.APUTLINE("",[V]CST_AINFO)
Return

#********************************************************************
# UPDATEMONGO_LOG_CLOSE
#********************************************************************
# Log closure
#********************************************************************
#*!
$UPDATEMONGO_LOG_CLOSE
  WPHASE_STEP = WPHASE_STEP + 1
  WPHASE_PROGRESS = WPHASE_STEP * 10
  WPHASE_TITLE = mess(60,2007,1)-num$(WPHASE_STEP)-"-"-mess(25,2007,1)-":"-mess(82,2006,1)
  WPHASE_DETAIL = mess(73,2007,1)#"Fermeture du fichier trace"
  Call ASYNCTRACK(this.ACTX, WPHASE_TITLE, WPHASE_DETAIL, 10) From ASYRASYNC
  Call ADDDIAGNOSE(this.ACTX,WPHASE_TITLE-":"-WPHASE_DETAIL,[V]CST_AINFO) From ASYRASYNC
  WERR = "* "+toupper(mess(26,2007,1)) #End of process"
  WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
  WOK = fmet WMYLOG.APUTLINE(string$(115,"="),[V]CST_AINFO)
  WOK = fmet WMYLOG.APUTLINE("",[V]CST_AINFO)
  WERR = "["+mess(55,2007,1)+"]" #"End of log file"
  WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
  WOK = fmet WMYLOG.AENDLOG()
Return

#********************************************************************
# UPDATEMONGO_LOG_END
#********************************************************************
# Log end
#********************************************************************
#*!
$UPDATEMONGO_LOG_END
  FreeGroup WMYLOG : WMYLOG = null
  Call ADDLINKDOWNLOAD(this.ACTX,"ATYPE7",WLOGFILENAME) From ASYRASYNC
  WPHASE_STEP = WPHASE_STEP + 1
  WPHASE_PROGRESS = WPHASE_STEP * 10
  WPHASE_TITLE = mess(60,2007,1)-num$(WPHASE_STEP)-"-"-mess(27,2007,1) #Summary of global processing
  WPHASE_DETAIL = ""
  Call ASYNCTRACK(this.ACTX, WPHASE_TITLE, WPHASE_DETAIL, 10) From ASYRASYNC
  If WNBWAR_TOT_FOUND > 0
    Call ADDDIAGNOSE(this.ACTX,WPHASE_TITLE-"-"-mess(74,2007,1)-":"-num$(WNBWAR_TOT_FOUND),[V]CST_AWARNING) From ASYRASYNC
  Endif
  If WNBERR_TOT_FOUND > 0
    Call ADDDIAGNOSE(this.ACTX,WPHASE_TITLE-"-"-mess(75,2007,1)-num$(WNBERR_TOT_FOUND)+"."-mess(76,2007,1),[V]CST_AERROR) From ASYRASYNC
  Else
    Call ADDDIAGNOSE(this.ACTX,WPHASE_TITLE-"-"-mess(77,2007,1),[V]CST_ASUCCESS) From ASYRASYNC
  Endif
Return

#********************************************************************
# UPDATEMONGO_EDI_SETUP_EDIPTC
#********************************************************************
# Processing EDIPTC instances
#********************************************************************
#*!
$UPDATEMONGO_EDI_SETUP_EDIPTC
  WPHASE_TITLE  = mess(25,2007,1)-":"-mess(80,2007,1) #"Paramétrage des protocoles EDI"
  WPHASE_DETAIL = mess(25,2007,1)-":"-mess(79,2007,1) #"Enregistrements"
  WTABLE        = "EDIPTC"
  WMYKEY(1)     = "PTCCOD"
  WMYKEY(2)     = ""
  WMYKEY(3)     = ""
  WMYKEY(4)     = ""
  Gosub UPDATEMONGO_EDI_SETUP_LOG_START
  Gosub UPDATEMONGO_EDI_SETUP_CHECK_AND_DELETE_RECORDS
  Gosub UPDATEMONGO_EDI_SETUP_LOG_END
Return

