#********************************************************************
# UPDATEMONGO_EDI_SETUP_LOG_START
#********************************************************************
# Log phase
#********************************************************************
#*!
$UPDATEMONGO_EDI_SETUP_LOG_START
  WPHASE_STEP = WPHASE_STEP + 1
  WPHASE_PROGRESS = WPHASE_STEP * 10
  WPHASE_TITLE = mess(60,2007,1)-num$(WPHASE_STEP)-"-"-WPHASE_TITLE
  Call ASYNCTRACK(this.ACTX, WPHASE_TITLE, WPHASE_DETAIL, WPHASE_PROGRESS) From ASYRASYNC
  Call ADDDIAGNOSE(this.ACTX,WPHASE_TITLE,[V]CST_AINFO) From ASYRASYNC
  WOK = fmet WMYLOG.APUTLINE("", [V]CST_AINFO)
  WOK = fmet WMYLOG.APUTLINE(WPHASE_TITLE, [V]CST_AINFO)
  WOK = fmet WMYLOG.APUTLINE(string$(len(WPHASE_TITLE),"="),[V]CST_AINFO)
  WOK = fmet WMYLOG.APUTLINE("", [V]CST_AINFO)
Return

#********************************************************************
# UPDATEMONGO_EDI_SETUP_CHECK_AND_DELETE_RECORDS
#********************************************************************
# Processing
#********************************************************************
#*!
$UPDATEMONGO_EDI_SETUP_CHECK_AND_DELETE_RECORDS
  WMYKEYSTR     = ""
  Local File =WTABLE [MYTAB]
  If POS = 0
    If WTABLE = "EDIXSDUPL"
      Filter [MYTAB]
    Else
      Filter [MYTAB] Where [MYTAB]VALID = [V]CST_AYES
    Endif
  Else
    If WMYKEY(4) <> ""
      Filter [MYTAB] Where
&       evalue("[MYTAB]"+WMYKEY(1)) = WMYKEYVAL(1) and
&       evalue("[MYTAB]"+WMYKEY(2)) = WMYKEYVAL(2) and
&       evalue("[MYTAB]"+WMYKEY(3)) = WMYKEYVAL(3) and
&       evalue("[MYTAB]"+WMYKEY(4)) = WMYKEYVAL(4)
    Elsif WMYKEY(3) <> ""
      Filter [MYTAB] Where
&       evalue("[MYTAB]"+WMYKEY(1)) = WMYKEYVAL(1) and
&       evalue("[MYTAB]"+WMYKEY(2)) = WMYKEYVAL(2) and
&       evalue("[MYTAB]"+WMYKEY(3)) = WMYKEYVAL(3)
    Elsif WMYKEY(2) <> ""
      Filter [MYTAB] Where
&       evalue("[MYTAB]"+WMYKEY(1)) = WMYKEYVAL(1) and
&       evalue("[MYTAB]"+WMYKEY(2)) = WMYKEYVAL(2)
    Elsif WMYKEY(1) <> ""
      Filter [MYTAB] Where
&       evalue("[MYTAB]"+WMYKEY(1)) = WMYKEYVAL(1)
    Endif
  Endif

  For [MYTAB]
    #get object keys
    If WMYKEY(1) <> "" : WMYKEYVAL(1) = num$(evalue("[MYTAB]"+WMYKEY(1))) : WMYKEYSTR = WMYKEYVAL(1) : Endif
    If WMYKEY(2) <> "" : WMYKEYVAL(2) = num$(evalue("[MYTAB]"+WMYKEY(2))) : WMYKEYSTR = WMYKEYSTR+"~"+WMYKEYVAL(2) : Endif
    If WMYKEY(3) <> "" : WMYKEYVAL(3) = num$(evalue("[MYTAB]"+WMYKEY(3))) : WMYKEYSTR = WMYKEYSTR+"~"+WMYKEYVAL(3) : Endif
    If WMYKEY(4) <> "" : WMYKEYVAL(4) = num$(evalue("[MYTAB]"+WMYKEY(4))) : WMYKEYSTR = WMYKEYSTR+"~"+WMYKEYVAL(4) : Endif

    WGET_OBJ_FLG_FOUND = [V]CST_AYES
    If WTABLE = "EDIXSDUPL"
      WCACHEUUID = num$([MYTAB]UUIDXSD)
    Else
      WCACHEUUID = num$([MYTAB]CACHEUUID)
    Endif
    WERRROOT = mess(3,3,1)-":"- WTABLE - mess(55,123,1)-":"- WMYKEYSTR - "UUID"-":"- WCACHEUUID
    WOK = fmet WMYLOG.APUTLINE(WERRROOT, [V]CST_AINFO)
    WERRROOT = "****** "
    #On verifie l'existence d'un fichier uuid et on le supprime
    Gosub UPDATEMONGO_MONGO_CHECK_AND_DELETE_IN_MONGODB
    #on supprime l'uuid dans la table
    Gosub UPDATEMONGO_MONGO_CHECK_AND_DELETE_IN_TABLE
    #On regenere l'uuid en re-enregistrant l'instance de representation
    Gosub UPDATEMONGO_MONGO_GENERATE_NEW_UUID

##############################
#  Call ADDDIAGNOSE(this.ACTX,"Processed"-":"-"Object"-":"- WTABLE - "Key"-":"- WMYKEYSTR,[V]CST_AINFO) From ASYRASYNC
##############################
  Next
  LogicClose File [MYTAB]
Return

#********************************************************************
# UPDATEMONGO_EDI_SETUP_LOG_END
#********************************************************************
# Log end phase
#********************************************************************
#*!
$UPDATEMONGO_EDI_SETUP_LOG_END
  If WGET_OBJ_FLG_FOUND = [V]CST_AYES
    WGET_OBJ_FLG_FOUND = [V]CST_ANO
  Else
#    WNBERR_FOUND = WNBERR_FOUND + 1
    WNBWAR_FOUND = WNBWAR_FOUND + 1
    WOK = fmet WMYLOG.APUTLINE(mess(86,2007,1), [V]CST_AWARNING) #"Objet non trouvé"
    WOK = fmet WMYLOG.APUTLINE("", [V]CST_AINFO)
  Endif
  If WNBWAR_FOUND > 0
    Call ADDDIAGNOSE(this.ACTX,WPHASE_TITLE-"-"-mess(74,2007,1)-":"-num$(WNBWAR_FOUND),[V]CST_AWARNING) From ASYRASYNC
  Endif
  If WNBERR_FOUND > 0
    Call ADDDIAGNOSE(this.ACTX,WPHASE_TITLE-"-"-mess(75,2007,1)-":"-num$(WNBERR_FOUND),[V]CST_AERROR) From ASYRASYNC
  Endif
  WNBERR_TOT_FOUND = WNBERR_TOT_FOUND + WNBERR_FOUND : WNBERR_FOUND = 0
  WNBWAR_TOT_FOUND = WNBWAR_TOT_FOUND + WNBWAR_FOUND : WNBWAR_FOUND = 0
Return

#********************************************************************
# UPDATEMONGO_MONGO_CHECK_AND_DELETE_IN_MONGODB
#********************************************************************
# Check and delete a uuid record into MongoDB
#********************************************************************
#*!
$UPDATEMONGO_MONGO_CHECK_AND_DELETE_IN_MONGODB
  WERR = WERRROOT
  WSTA = func MONGODB_CHECK_RECORD(WCACHEUUID, WERR)
  If WSTA = [V]CST_AYES
    WOK = fmet WMYLOG.APUTLINE(WERR, [V]CST_AINFO)
    WERR = WERRROOT
    WSTA = func MONGODB_DELETE_RECORD(WCACHEUUID, WERR)
    If WSTA = [V]CST_AYES
      WOK = fmet WMYLOG.APUTLINE(WERR, [V]CST_AINFO)
      WSTA = [V]CST_AINFO
    Else
      WOK = fmet WMYLOG.APUTLINE(WERR, [V]CST_AWARNING)
      WSTA = [V]CST_AWARNING
    Endif
  Else
    WOK = fmet WMYLOG.APUTLINE(WERR, [V]CST_AWARNING)
    WSTA = [V]CST_AWARNING
  Endif
Return

#********************************************************************
# UPDATEMONGO_MONGO_CHECK_AND_DELETE_IN_TABLE
#********************************************************************
# erase the uuid set into the table for the current record
#********************************************************************
#*!
$UPDATEMONGO_MONGO_CHECK_AND_DELETE_IN_TABLE
  WERR = WERRROOT
  Trbegin [MYTAB]
  If WTABLE = "EDIXSDUPL"
    [MYTAB]UUIDXSD = NullUuid()
  Else
    [MYTAB]CACHEUUID = NullUuid()
  Endif
  Rewrite [MYTAB]
  If !fstat
    Commit
    #WSTA = [V]CST_AOK
    WERR = WERR-"-"-mess(87,2007,1)-":"-mess(7,2007,1) #"Suppression de l'UUID dans l'enregistrement"
    WOK = fmet WMYLOG.APUTLINE(WERR, [V]CST_AINFO)
  Else
    Rollback
    #WSTA = [V]CST_AERROR
    WERR = WERR-"-"-mess(87,2007,1)-":"-mess(9,2007,1) #"Suppression de l'UUID dans l'enregistrement"
    WOK = fmet WMYLOG.APUTLINE(WERR, [V]CST_AWARNING)
    WNBWAR_FOUND = WNBWAR_FOUND + 1
  Endif
Return

#********************************************************************
# UPDATEMONGO_MONGO_GENERATE_NEW_UUID
#********************************************************************
# generate new uuid by updating the current record
#********************************************************************
#*!
$UPDATEMONGO_MONGO_GENERATE_NEW_UUID
  WERR = WERRROOT
  WTMP_ERRROOT = WERRROOT
  Local Instance WMYREP Using ="R_"+WTABLE
  WMYREP = NewInstance With ="R_"+WTABLE
  If WMYKEY(4) <> ""
    WSTA = fmet WMYREP.AREAD(WMYKEYVAL(1),WMYKEYVAL(2),WMYKEYVAL(3),WMYKEYVAL(4))
  Elsif WMYKEY(3) <> ""
    WSTA = fmet WMYREP.AREAD(WMYKEYVAL(1),WMYKEYVAL(2),WMYKEYVAL(3))
  Elsif WMYKEY(2) <> ""
    WSTA = fmet WMYREP.AREAD(WMYKEYVAL(1),WMYKEYVAL(2))
  Elsif WMYKEY(1) <> ""
    WSTA = fmet WMYREP.AREAD(WMYKEYVAL(1))
  Endif
  If WSTA = [V]CST_AOK
    If WTABLE = "EDIXMLFIL"
      #regenerer les path, et realise l'update d'EDIXMLFIL
      WERRROOT = WERRROOT - "-" - mess(88,2007,1) #"Chemins XSD"
      WTMP_CACHEUUID = WCACHEUUID
      WCACHEUUID = num$(WMYREP.EXF.UUIDXMLTYP)
      Gosub UPDATEMONGO_MONGO_CHECK_AND_DELETE_IN_MONGODB
      WERRROOT = WTMP_ERRROOT
      WERR = WERRROOT
      WCACHEUUID = WTMP_CACHEUUID
      WTMP_CACHEUUID = num$(NullUuid())
      WMYREP.EXF.UUIDXMLTYP = NullUuid()
      WSTA = fmet WMYREP.EXF.MET_GET_PATH()
      If WSTA = [V]CST_AOK
        #ok
        WERR = WERR - "-"-mess(51,107,1)-":"-mess(7,2007,1)
        WOK = fmet WMYLOG.APUTLINE(WERR, [V]CST_AINFO)
        WFLG_NEXT = [V]CST_ATRUE
      Else
        WERR = WERR - "-"-mess(51,107,1)-":"-mess(9,2007,1)
        WOK = fmet WMYLOG.APUTLINE(WERR, [V]CST_AERROR)
        WSTA = [V]CST_AERROR
        WNBERR_FOUND = WNBERR_FOUND + 1
        WFLG_NEXT = [V]CST_AFALSE
      Endif
    Else
      WFLG_NEXT = [V]CST_ATRUE
    Endif

    WERR = WERRROOT
    If WFLG_NEXT = [V]CST_ATRUE
      WSTA = fmet WMYREP.AUPDATE()
      If WSTA <= [V]CST_AWARNING  #      If WSTA = [V]CST_AOK
        Local File ASHW [ASW]
        Read [ASW]ASW0 = WTABLE
        If !fstat
          WABRCLA = [ASW]ABRCLA
          If WTABLE = "EDIXSDUPL"
            WNEWCACHEUUID = num$(evalue("WMYREP."+WABRCLA+".UUIDXSD"))
          Else
            WNEWCACHEUUID = num$(evalue("WMYREP."+WABRCLA+".CACHEUUID"))
          Endif
          WERR = WERR - "-"-"UUID"-"/"-mess(51,107,1)-":"-mess(7,2007,1)-WNEWCACHEUUID
          WOK = fmet WMYLOG.APUTLINE(WERR, [V]CST_AINFO)
          WSTA = [V]CST_AINFO
        Else
          WERR = WERR - "-"-mess(89,2007,1) #"Classe de donnée inexistante"
          WOK = fmet WMYLOG.APUTLINE(WERR, [V]CST_AERROR)
          WSTA = [V]CST_AERROR
          WNBERR_FOUND = WNBERR_FOUND + 1
        Endif
        LogicClose File [ASW]
      Else
        WERR = WERR - "-"-"UUID"-"/"-mess(51,107,1)-":"-mess(9,2007,1)
        WOK = fmet WMYLOG.APUTLINE(WERR, [V]CST_AERROR)
        WSTA = [V]CST_AERROR
        WNBERR_FOUND = WNBERR_FOUND + 1
      Endif
    Else
      #error is already log before
    Endif
  Else
    WERR = WERR - "-"-mess(90,2007,1)-":"-mess(9,2007,1) #"Lecture de l'enregistrement"
    WOK = fmet WMYLOG.APUTLINE(WERR, [V]CST_AERROR)
    WSTA = [V]CST_AERROR
    WNBERR_FOUND = WNBERR_FOUND + 1
  Endif
  WABRCLA = ""
  WNEWCACHEUUID = ""
  FreeGroup WMYREP : WMYREP = null
  #blank line
  WOK = fmet WMYLOG.APUTLINE("", [V]CST_AINFO)
  If WSTA = [V]CST_AERROR
    Call ADDDIAGNOSE(this.ACTX,mess(25,2007,1)-":"-mess(3,3,1)-":"- WTABLE - mess(55,123,1)-":"- WMYKEYSTR,[V]CST_AERROR) From ASYRASYNC
  Else
    Call ADDDIAGNOSE(this.ACTX,mess(25,2007,1)-":"-mess(3,3,1)-":"- WTABLE - mess(55,123,1)-":"- WMYKEYSTR,[V]CST_AINFO) From ASYRASYNC
  Endif
Return

#********************************************************************
# MONGODB_CHECK_RECORD
#********************************************************************
# Check a uuid record into MongoDB
#********************************************************************
#* @param WCACHEUUID
#* @param WERR
#* @return WSTA
#*!
Funprog MONGODB_CHECK_RECORD(WCACHEUUID, WERR)
Value Char WCACHEUUID
Variable Char WERR

  Local Integer WSTA
  Local Char WMSG(250)
  Local Clbfile WCLOB(0)

  If num$(WCACHEUUID) = "00000000-0000-0000-0000-000000000000"
    #WERR = WERR-"- Check file in MongoDB (-1) failed"
    WERR = WERR-"-"-mess(91,2007,1)-":"-mess(9,2007,1) #"Vérification du fichier dans la base MongoDB"
    WSTA = [V]CST_AYES #[V]CST_ANO
  Else
    WSTA = func ASYREIP.MDB_GET_EDI_ENTITY_UUID(WCACHEUUID, WCLOB, WMSG)
    If WSTA = [V]CST_AOK
      If len(WCLOB) <> 0 # <> "" #il y a qq chose dedans
        If len(WCLOB) = 4 and left$(WCLOB, 4) = "null"
          #WERR ="fichier existant avec du contenu null" - "["+left$(WCLOB, 2)+"...]"
          #WERR = WERR-"- Check file in MongoDB (1) succeed"
          WERR = WERR-"-"-mess(91,2007,1)-":"-mess(7,2007,1) #"Vérification du fichier dans la base MongoDB"
    #on peut donc le supprimer
          WSTA = [V]CST_AYES
        Else
          #WERR ="fichier existant avec du contenu" - "["+left$(WCLOB, 10)+"...]"
          #WERR = WERR-"- Check file in MongoDB (2) succeed"
          WERR = WERR-"-"-mess(91,2007,1)-":"-mess(7,2007,1) #"Vérification du fichier dans la base MongoDB"
          #on peut donc le supprimer
          WSTA = [V]CST_AYES
        Endif
      Else
        #WERR ="fichier existant mais vide" - WMSG - left$(WCLOB, 10)
        #WERR = WERR-"- Check file in MongoDB (3) succeed"
        WERR = WERR-"-"-mess(91,2007,1)-":"-mess(7,2007,1) #"Vérification du fichier dans la base MongoDB"
        #on peut donc le supprimer
        WSTA = [V]CST_AYES
      Endif
    Else
      #rien à supprimer
      #WERR = 'fichier inexistant' - WMSG
      #WERR = WERR-"- Check file in MongoDB (0) failed"
      WERR = WERR-"-"-mess(91,2007,1)-":"-mess(9,2007,1) #"Vérification du fichier dans la base MongoDB"
      WSTA = [V]CST_AYES #[V]CST_ANO
    Endif
  Endif
End WSTA

#********************************************************************
# MONGODB_DELETE_RECORD
#********************************************************************
# Delete a uuid record into MongoDB
#********************************************************************
#* @param WCACHEUUID
#* @param WERR
#* @return WSTA
#*!
Funprog MONGODB_DELETE_RECORD(WCACHEUUID, WERR)
Value Char WCACHEUUID
Variable Char WERR

  Local Integer WSTA
  Local Char WMSG(250)

  WSTA = func ASYREIP.MDB_DELETE_EDI_ENTITY_UUID(WCACHEUUID,WMSG)
  If WSTA = [V]CST_AOK
#    WERR = WERR-"-"-"Deleting entity in cache succeed"-WCACHEUUID
    WERR = WERR-"-"-mess(58,2007,1)-":"-mess(7,2007,1)
    WSTA = [V]CST_AYES
  Else
#    WERR = WERR-"-"-"Deleting entity in cache failed"
    WERR = WERR-"-"-mess(58,2007,1)-":"-mess(9,2007,1)
    WSTA = [V]CST_ANO
  Endif
End WSTA



