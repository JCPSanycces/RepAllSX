$ON_EXRSYMPOS
Onevent BEFORE_INPUT Call AS_EXRSYMPOS(zc) From W1HREXT0
Onevent INIT_AREA Call D_EXRSYMPOS(zc) From W1HREXT0
Onevent CONTROL Call C_EXRSYMPOS(zc) From W1HREXT0
Return

Subprog D_EXRSYMPOS(VALEUR)
Variable Integer VALEUR
If varinit([M]EXRSYMPOS,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_EXRSYMPOS(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(425) From COMBOS
## Action STD
Call AS_EXRSYMPOS(VALEUR) From SUBHREXT
If mkstat=2
 [M]EXRSYMPOS(INDIC) = VALEUR
 Affzo EXRSYMPOS(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,425,1))))
Endif
If !mkstat
 Discombo 0 From EXRSYMPOS(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From EXRSYMPOS(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_EXRSYMPOS(VALEUR)
Variable Integer VALEUR
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

$CHG_STY
Return


