 Call S_AFF_CHAR(VALEUR,PARMSK,"EDITION","SUBADC","") From GACTION
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_EXRCODACC
Onevent CONTROL Call C_EXRCODACC(zc) From W1HREXT0
Onevent BEFORE_INPUT Call AS_EXRCODACC(zc) From W1HREXT0
Onevent AFTER_CHANGE Gosub AMM_EXRCODACC From W1HREXT0
Return

Subprog AS_EXRCODACC(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(189,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_EXRCODACC(zc) From W1HREXT0
Onkey   2 Titled GBOUTS Call S_EXRCODACC(zc) From W1HREXT0
Onkey 144 Titled GBOUTP Call P_EXRCODACC(zc) From W1HREXT0
Onkey 146 Titled GBOUTA Call SA_EXRCODACC(zc) From W1HREXT0
Gosub _AFF
End

Subprog C_EXRCODACC(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("ACS","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "EXRCODACC" : GZNUM = 729 : Endif
Gosub _AFF
End

$AMM_EXRCODACC
Call AM_EXRCODACC(zc)
If !mkstat & GOBJET
 zoncou = "EXRCODACC" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_EXRCODACC(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZEXRCODACC)")>indice
 [M]EXRCODACC(indice) = VALEUR
 Affzo ZEXRCODACC(indice)
Endif
Gosub _AFF
End

Subprog S_EXRCODACC(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "ACS"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

