#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HREXT0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:37"
A_USER  = "DOC"
A_STAMP = "20181109230437"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HREXT0 [HREXT0]
Gosub HORODAT
Local Inpbox "HREXT0" From GFONCTION At A_STAMP With A_WINDPREV Mask [HREXT0] As [SIM_]
Grizo [HREXT0]5
Grizo [HREXT0]10
Grizo [HREXT0]15
Grizo [HREXT0]20
Grizo [HREXT0]25
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [HREXT0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=150 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=150 : Y1(1)=3 : Y2(1)=4
X1(2)=1 : X2(2)=150 : Y1(2)=5 : Y2(2)=8
X1(3)=1 : X2(3)=150 : Y1(3)=9 : Y2(3)=10
X1(4)=1 : X2(4)=150 : Y1(4)=11 : Y2(4)=12
Return

$ON_EXRTEP
Onevent CONTROL Call C_EXRTEP(zc) From W1HREXT0
Onevent BEFORE_INPUT Call AS_EXRTEP(zc) From W1HREXT0
Return

Subprog AS_EXRTEP(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey   2 Titled GBOUTS Call S_EXRTEP(zc) From W1HREXT0
Onkey 144 Titled GBOUTP Call P_EXRTEP(zc) From W1HREXT0
Onkey 146 Titled GBOUTA Call SA_EXRTEP(zc) From W1HREXT0
Gosub _AFF
End

Subprog C_EXRTEP(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "EXRTEP" : GZNUM = 5296 : Endif
If !mkstat
 ## Action CONTOBJW
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "CONTOBJW"
 PARMSK(1) = "HREXT"
 Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJW","CONTOBJ","") From GACTION
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "EXRTEP" : GZNUM = 5296 : Endif
Endif
Gosub _AFF
End

Subprog S_EXRTEP(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELOBJW
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELOBJW"
 PARMSK(1) = "HREXT"
 PARMSK(2) = ""
 PARMSK(3) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog SA_EXRTEP(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "HREXT"
PARMSK(3) = "$"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_EXRTEP(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("HREXT",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

