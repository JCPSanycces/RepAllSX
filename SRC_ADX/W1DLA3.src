#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque DLA3 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:58"
A_USER  = "DOC"
A_STAMP = "20181109230358"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask DLA3 [DLA3]
Gosub HORODAT
Local Inpbox "DLA3" From GFONCTION At A_STAMP With A_WINDPREV Mask [DLA3] As [SIM_]
Grizo [DLA3]5
Grizo [DLA3]10
Grizo [DLA3]15
Grizo [DLA3]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [DLA3]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=77 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=77 : Y1(1)=3 : Y2(1)=5
X1(2)=1 : X2(2)=77 : Y1(2)=6 : Y2(2)=11
X1(3)=1 : X2(3)=77 : Y1(3)=12 : Y2(3)=22
Return

$ON_ACCTYP
Onevent BEFORE_INPUT Call AS_ACCTYP(zc) From W1DLA3
Onevent INIT_AREA Call D_ACCTYP(zc) From W1DLA3
Onevent CONTROL Call C_ACCTYP(zc) From W1DLA3
Return

Subprog D_ACCTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]ACCTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_ACCTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
Call INICOMBO(10389) From COMBOS
## Action STD
Call AS_ACCTYP(VALEUR) From SUBDLA
If mkstat=2
 [M]ACCTYP(INDIC) = VALEUR
 Affzo ACCTYP(INDIC) : mkstat = 2
Endif
If VALEUR<1 | GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,10389,1))))
Endif
If !mkstat
 Discombo 0 From ACCTYP(INDIC)
 If sum(GMENLOC)<>0
  Gosub COMBOS From COMBOS
  For WI=1 to WN : Discombo WCOMBO(WI) From ACCTYP(INDIC) : Next WI
 Endif
Endif
Gosub _AFF
End

Subprog C_ACCTYP(VALEUR)
Variable Integer VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "ACCTYP" : GZNUM = 52295 : Endif
If VALEUR>0 & VALEUR<dim(GMENLOC) & GMENLOC(VALEUR)<>0
 mkstat = 1 : End
Endif
Gosub _AFF
End

$ON_HOU
Onevent CONTROL Call C_HOU(zc) From W1DLA3
Onevent AFTER_AREA Call AP_HOU(zc) From W1DLA3
Return

Subprog C_HOU(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CONTHMM
 Call CONTHM(VALEUR) From TPSDIV
 If mkstat : GERR = 1 : GZONE = "HOU" : GZNUM = 47438 : Endif
Endif
Gosub _AFF
End

Subprog AP_HOU(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action INIHMM
 Call INIHM(VALEUR) From TPSDIV
 If mkstat : GERR = 1 : GZONE = "HOU" : GZNUM = 47438 : Endif
Endif
Gosub _AFF
End

