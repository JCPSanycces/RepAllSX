$ON_ACCCRN
Onevent BEFORE_AREA Gosub AV_ACCCRN From W1DLA3
Onevent CONTROL Call C_ACCCRN(zc) From W1DLA3
Return

$AV_ACCCRN
If !GWEBSERV
 ## Action FMTCRTPAY
 Call FMTCRTPAY("") From TRTDIV
Endif
If !GWEBSERV
 ## Action ASAICRT
 If [F:TCY]CRTFMTFLG<>2 : Grizo =zoncou : mkstat = 1 : Else : Actzo =zoncou : Endif
Endif
If GFMT<>""
 Chgfmt [M]ACCCRN(indice) With "K:"+GFMT
Else
 Chgfmt [M]ACCCRN(indice) With "-K:1X"
Endif
Gosub _AFF
Return

Subprog C_ACCCRN(VALEUR)
Variable Char    VALEUR()
## Action CONTSIRET
Call CONTSIRET(VALEUR,"","") From CONTNUM
If mkstat : GERR = 1 : GZONE = "ACCCRN" : GZNUM = 1424 : Endif
Gosub _AFF
End

$ON_ACCPLA
Onevent INIT_AREA Call D_ACCPLA(zc) From W1DLA3
Onevent BEFORE_INPUT Call AS_ACCPLA(zc) From W1DLA3
Return

Subprog D_ACCPLA(VALEUR)
Variable Integer VALEUR
If varinit([M]ACCPLA,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_ACCPLA(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_ACCTIM
Onevent INIT_AREA Call D_ACCTIM(zc) From W1DLA3
