#<AdxTL>@(#)6.0.0.0 $Revision$
###################################################################################################
# A UTILISER DEPUIS GESADS
#Subprog VERIF_CONNEX(ERR)                     Permet de verifier si info de connexion (console) OK
#Subprog DONNE_DROITS(DOSSCOUR,DOSSIER,TYP,ERR)Permet de faire grant
#Subprog SUPP_DROITS(DOSSCOUR,DOSSIER,TYP,ERR) Permet de faire revoke
#Subprog RETABLIR_DROITS(DOSSIER,ERR)          Permet de retablir les droits
#Subprog SET_DROITS                            Permet de raffraichir les droits pour la session courante
#Subprog CREER_ROLE_BI(SOLBI,DOSSIER,ERR)      Permet de creer les rôles nécessaires pour user BI
###################################################################################################
#Subprog CRE_PROC_PROP_GRANT(DOSSIER,ERR)      Permet de recréer la procédure stockée de propagation
#                                              des droits appelée par valfil
###################################################################################################
# INTERNES au source:
#Subprog TRT_MODIF_DROITS(DOSSCOUR,DOSSIER,TYP,GRANT,ERR) Permet de modifier les droits
#Subprog TRT_VER_CONN_SQL(ERR)                            Vérification connexion pour SqlServer
#Subprog TRT_VER_CONN_ORA(ERR)                            Vérification connexion pour Oracle
###################################################################################################
#Subprog USER_BOWORLD(SOLBI,VUSER,VPWD,ERR)               Récup des info (boworld.xml) sur user sys
###################################################################################################


####
# Lancement création procédure propagation des droits
####
Local Integer ERR
Call CRE_PROC_PROP_GRANT("",ERR)
If ERR : End : Endif
End

####
# exemples d'utilisation des sous-prog
####
Local Integer ERR
# verifier si on peut acceder à la base pour gerer les connexions
Call VERIF_CONNEX(ERR)
Infbox num$(ERR)
If ERR : End : Endif
End
###################################################################################################
###################################################################################################
Subprog DONNE_DROITS(DOSSCOUR,DOSSIER,TYP,ERR)
Value Char DOSSCOUR()
Value Char DOSSIER() : # DOSSIER auquel on donne autorisation sur DOSSCOUR
Value Char TYP : # "L" pour lecture, "T" pour tout
Variable Integer ERR

Call TRT_MODIF_DROITS(DOSSCOUR,DOSSIER,TYP,1,ERR)

End

###################################################################################################
###################################################################################################
Subprog SUPP_DROITS(DOSSCOUR,DOSSIER,TYP,ERR)
Value Char DOSSCOUR()
Value Char DOSSIER() : # DOSSIER auquel on supprime autorisation sur DOSSCOUR
Value Char TYP : # "L" pour lecture, "T" pour tout
Variable Integer ERR

Call TRT_MODIF_DROITS(DOSSCOUR,DOSSIER,TYP,0,ERR)

End

###################################################################################################
###################################################################################################
Subprog VERIF_CONNEX(ERR)
Variable Integer ERR
If GTYPDBA=1 : # oracle
   Call TRT_VER_CONN_ORA(ERR)
Elsif GTYPDBA=2 : # sqlserver
   Call TRT_VER_CONN_SQL(ERR)
Endif
End

###################################################################################################
###################################################################################################
Subprog TRT_VER_CONN_SQL(ERR)
Variable Integer ERR
#############################################################
## Pour SQL-server
#############################################################
Local Char    BASE(30), USER(30), PASSE(30)
Local Char    SAVIFS(5) , SAVIRS(5) , XBASE(20)
Local Integer SAVIUM,I
Local Char    TBDAT(30) , TBIDX(30)
Local Char    CMDFIC(GDIMFIC), FICCMD(GDIMFIC)
Local Char    FICTRA(GDIMFIC), FICSQL(GDIMFIC)
Local Char    SQLFIC(GDIMFIC), TRAFIC(GDIMFIC)
Local Char    APPLI(50) , IRS(2)
Local Char    MACHINE(GDIMFIC), NOMDOS(GDIMFIC),MACBID(GDIMFIC)
Local Char    PROPERTY(100),AUTHEN_PWD(200),AUTHEN_LOGIN(200)
Local Char    XINSTANCE(200),SQLDBA(50)
Local Char    XHOSTNAME(200) : # Hostname (, port) where the SQL Server is running. Could be "." for local host
Local Char    TEXT(250)(3)

APPLI=nomap
Call MACHINE(APPLI,MACHINE,NOMDOS) From ORDSYS
IRS = chr$(13)+chr$(10)
SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
adxifs = "" : adxirs = chr$(10) : adxium = GASCII
Call PASSE(APPLI,XBASE,USER,PASSE,BASE,TBIDX) From ORAPASSE
If BASE<>""
   # jira X3-86047 86048 86049
   PROPERTY="database.software.sqlinternalpwd"
   # Récupération du passwd authenfication login
   Call PASSWD(PROPERTY,AUTHEN_PWD,ERR) From DOSBASE
   If ERR <> 0
       Goto FIN_VERIF_SQL
   Endif
   # recuperation du compte sa....AUTHEN_LOGIN
   # si on trouve rien sa par défaut.....
   Call PASSWD("database.software.sqlinternallogin",AUTHEN_LOGIN,ERR) From DOSBASE
   If ERR <> 0
       Goto FIN_VERIF_SQL
   Endif

   If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
        SQLDBA = "sqlcmd"
        # instance ?
        Call RECH_PROPERTY("database.adonix.sqlinstance",XINSTANCE,ERR) From DOSBASE
        If ERR <> 0
           Goto FIN_VERIF_SQL
        Endif
        # Get the SQL Server hostname from CONNECTSTR. Remove # and \ right part if exist
        XHOSTNAME = getenv$("CONNECTSTR")
        If (instr(0,XHOSTNAME,"\") > 0)
             XHOSTNAME = left$(XHOSTNAME,instr(0,XHOSTNAME,"\")-1)
        Endif
        If (instr(0,XHOSTNAME,"#") > 0)
              XHOSTNAME = left$(XHOSTNAME,instr(0,XHOSTNAME,"#")-1)
        Endif
        #XINSTANCE = ".\"+XINSTANCE
        XINSTANCE = XHOSTNAME+'\'+XINSTANCE
   Else
        SQLDBA = "osql"
   Endif


 FICCMD = filpath("tmp","sqltrt"+num$(adxuid(2)),"BAT",APPLI)
 Call MACHINE(FICCMD ,MACBID,CMDFIC) From ORDSYS
 FICSQL = filpath("tmp","sqltrt"+num$(adxuid(2)),"sql",APPLI)
 Call MACHINE(FICSQL,MACBID,SQLFIC) From ORDSYS
 FICTRA = filpath("tmp","sqltrt"+num$(adxuid(2)),"log",APPLI)
 Call MACHINE(FICTRA,MACBID,TRAFIC) From ORDSYS
 System COMMANDE = MACHINE+'@ae_rm'-'"'+CMDFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 adxifs = "" : adxirs = IRS : adxium = GASCII
 ##
 Openo FICSQL , 0
 Wrseq "select 'OK'"
 Wrseq "GO"
 Wrseq "EXIT"
 Openo
 CTRL=2
 Gosub EXEC_FIC_SQL
 System COMMANDE = MACHINE+'@ae_rm'-'"'+CMDFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 If ERR<>0
    Call ECR_TRACE(mess(227,100,1),1) From GESECRAN
    Goto FIN_VERIF_SQL
 Endif

Endif
$FIN_VERIF_SQL
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
End

###################################################################################################
###################################################################################################
Subprog TRT_VER_CONN_ORA(ERR)
Variable Integer ERR

#############################################################
## Pour Oracle
#############################################################
Local Char    BASE(30), USER(30), PASSE(30)
Local Char    SAVIFS(5) , SAVIRS(5) , XBASE(20)
Local Integer SAVIUM
Local Char    TBDAT(30) , TBIDX(30)
Local Char    FICTRA(GDIMFIC), FICSQL(GDIMFIC)
Local Char    SQLFIC(GDIMFIC), TRAFIC(GDIMFIC)
Local Char    APPLI(50), IRS(2), OS(10)
Local Char    MACHINE(GDIMFIC), NOMDOS(GDIMFIC),MACBID(GDIMFIC)
Local Char    PROPERTY(100),AUTHEN_PWD(200), AUTHEN_LOGIN(200)
Local Char    WVERSORA(30)
Local Char    TEXT(250)(3)


APPLI=nomap
Call MACHINE(APPLI,MACHINE,NOMDOS) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
If toupper(OS)="UNIX"
   IRS = chr$(10)
Else
   IRS = chr$(13)+chr$(10)
Endif

SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
adxifs = "" : adxirs = IRS : adxium = GASCII
Call PASSE(APPLI,BASE,USER,PASSE,TBDAT,TBIDX) From ORAPASSE
If BASE<>""

  PROPERTY="database.software.sqlsystempwd"
  # Récupération du passwd system
  Call PASSWD(PROPERTY,AUTHEN_PWD,ERR) From DOSBASE
  If ERR <> 0
      ERR=1
      Goto FIN_VERIF_ORA
  Endif
  # recuperation du compte sa....AUTHEN_LOGIN
  # si on trouve rien system par défaut.....
  Call PASSWD("database.software.sqlsystemlogin",AUTHEN_LOGIN,ERR) From DOSBASE
  If ERR <> 0
      ERR=1
      Goto FIN_VERIF_ORA
  Endif
  #

  Call VERS_ORA(WVERSORA,ERR) From ORATRA
  If ERR <> 0
      Goto FIN_VERIF_ORA
  Endif

 FICSQL = filpath("tmp","oratrt"+num$(adxuid(2)),"sql",APPLI)
 Call MACHINE(FICSQL,MACBID,SQLFIC) From ORDSYS
 FICTRA = filpath("tmp","oratrt"+num$(adxuid(2)),"log",APPLI)
 Call MACHINE(FICTRA,MACBID,TRAFIC) From ORDSYS
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 adxifs = "" : adxirs = IRS : adxium = GASCII

 Openo FICSQL , 0
 Wrseq "set termout off"
 Wrseq "set echo    off"
 Wrseq "spool"-TRAFIC
 #Wrseq "connect SYSTEM/"+AUTHEN_PWD
 Wrseq "connect "+AUTHEN_LOGIN+"/"+AUTHEN_PWD
 Wrseq "select 'OK' from DUAL;"
 Wrseq "exit"
 Openo
 CTRL=2
 Gosub EXEC_FIC_ORA
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 If ERR<>0
    Call ECR_TRACE(mess(227,100,1),1) From GESECRAN
    Goto FIN_VERIF_ORA
 Endif

Endif
$FIN_VERIF_ORA
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
End


###################################################################################################
###################################################################################################
Subprog TRT_MODIF_DROITS(DOSSCOUR,DOSSIER,TYP,GRANT,ERR)
Value Char DOSSCOUR()
Value Char DOSSIER() : # DOSSIER pour lequel on va modifier les autorisations sur DOSSCOUR
Value Char TYP : # "L" pour lecture, "T" pour tout
Value Integer GRANT : # 1 pour GRANT, 0 pour REVOKE
Variable Integer ERR

If GRANT <>0 and GRANT <>1
   Goto ERREUR
Endif
If TYP<>"L" and TYP<>"T"
   Goto ERREUR
Endif
If DOSSCOUR="" or DOSSIER=""
   Goto ERREUR
Endif
If DOSSCOUR=DOSSIER
   Goto ERREUR
Endif
If GTYPDBA=1 : # oracle
   Gosub MOD_DROITS_ORA
Elsif GTYPDBA=2 : # sqlserver
   Gosub MOD_DROITS_SQL
Endif
#si on a donné des droits au dossier courant, il faut mettre à jour la session courante
If !ERR & DOSSIER=nomap
    Call SET_DROITS
Endif
End

$MOD_DROITS_SQL
#############################################################
## Pour SQL-server
#############################################################
Local Char    BASE(30), USER(30), PASSE(30)
Local Char    SAVIFS(5) , SAVIRS(5) , XBASE(20)
Local Integer SAVIUM,I
Local Char    TBDAT(30) , TBIDX(30)
Local Char    CMDFIC(GDIMFIC), FICCMD(GDIMFIC)
Local Char    FICTRA(GDIMFIC), FICSQL(GDIMFIC)
Local Char    SQLFIC(GDIMFIC), TRAFIC(GDIMFIC)
Local Char    APPLI(50) , IRS(2)
Local Char    MACHINE(GDIMFIC), NOMDOS(GDIMFIC),MACBID(GDIMFIC)
Local Char    PROPERTY(100),AUTHEN_PWD(200),AUTHEN_LOGIN(200),XINSTANCE(200),SQLDBA(50)
Local Char    XHOSTNAME(200) : # Hostname (, port) where the SQL Server is running. Could be "." for local host
Local Char    TEXT(250)(3)
Local Integer TROUVE : TROUVE=0

SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
Onerrgo ERREUR

#VPO 08/09/08 49050 pb validation datawarehouse et roles 140
##VPO 18/09/08 49228 pb test des droits sql server
##For (Char VBDDROL(200)) From '5' Sql
##&  "select name from dbo.sysusers where name='"+DOSSCOUR+"_ADX' AND hasdbaccess=0 AND islogin=0 AND issqluser=0"
##&        As [BDD]
## TROUVE=1
## Break
##Next
##If TROUVE

For (Char VBDDROL(200)) From '5' Sql
&  "select name from dbo.sysusers where name='USER_ADONIX' AND hasdbaccess=0 AND islogin=0 AND issqluser=0"
&        As [BDD]
 TROUVE=1
 Break
Next
If TROUVE=0

APPLI=nomap
Call MACHINE(APPLI,MACHINE,NOMDOS) From ORDSYS
IRS = chr$(13)+chr$(10)
adxifs = "" : adxirs = chr$(10) : adxium = GASCII
Call PASSE(APPLI,XBASE,USER,PASSE,BASE,TBIDX) From ORAPASSE
If BASE<>""

   PROPERTY="database.software.sqlinternalpwd"
   # Récupération du passwd authenfication login
   Call PASSWD(PROPERTY,AUTHEN_PWD,ERR) From DOSBASE
   If ERR <> 0
       Goto FIN_DROITS_SQL
   Endif
   # recuperation du compte sa....AUTHEN_LOGIN
   # si on trouve rien sa par défaut.....
   Call PASSWD("database.software.sqlinternallogin",AUTHEN_LOGIN,ERR) From DOSBASE
   If ERR <> 0
       Goto FIN_DROITS_SQL
   Endif
   #
   If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
        SQLDBA = "sqlcmd"
        # instance ?
        Call RECH_PROPERTY("database.adonix.sqlinstance",XINSTANCE,ERR) From DOSBASE
        If ERR<>0
           Goto FIN_DROITS_SQL
        Endif
        # Get the SQL Server hostname from CONNECTSTR. Remove # and \ right part if exist
        XHOSTNAME = getenv$("CONNECTSTR")
        If (instr(0,XHOSTNAME,"\") > 0)
             XHOSTNAME = left$(XHOSTNAME,instr(0,XHOSTNAME,"\")-1)
        Endif
        If (instr(0,XHOSTNAME,"#") > 0)
            XHOSTNAME = left$(XHOSTNAME,instr(0,XHOSTNAME,"#")-1)
        Endif
        #XINSTANCE = ".\"+XINSTANCE
        XINSTANCE = XHOSTNAME+'\'+XINSTANCE
   Else
        SQLDBA = "osql"
   Endif


 FICCMD = filpath("tmp","sqltrt"+num$(adxuid(2)),"BAT",APPLI)
 Call MACHINE(FICCMD ,MACBID,CMDFIC) From ORDSYS
 FICSQL = filpath("tmp","sqltrt"+num$(adxuid(2)),"sql",APPLI)
 Call MACHINE(FICSQL,MACBID,SQLFIC) From ORDSYS
 FICTRA = filpath("tmp","sqltrt"+num$(adxuid(2)),"log",APPLI)
 Call MACHINE(FICTRA,MACBID,TRAFIC) From ORDSYS
 System COMMANDE = MACHINE+'@ae_rm'-'"'+CMDFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 adxifs = "" : adxirs = IRS : adxium = GASCII
 ##
 Openo FICSQL , 0
 Wrseq "use"-XBASE
 Wrseq "GO"
 If GRANT = 1
     If TYP="T"
        Wrseq "exec sp_addrolemember '"+DOSSCOUR+"_ADX','"+DOSSIER+"'"
     Else : # "L"
        Wrseq "exec sp_addrolemember '"+DOSSCOUR+"_ADX_R','"+DOSSIER+"'"
     Endif
 Else
     If TYP="T"
        Wrseq "exec sp_droprolemember '"+DOSSCOUR+"_ADX','"+DOSSIER+"'"
     Else : # "L"
        Wrseq "exec sp_droprolemember '"+DOSSCOUR+"_ADX_R','"+DOSSIER+"'"
     Endif
 Endif
 Wrseq "GO"
 Wrseq "EXIT"
 Openo
 If GRANT = 1
     CTRL=2
 Else
     CTRL=1
 Endif
 Gosub EXEC_FIC_SQL
 System COMMANDE = MACHINE+'@ae_rm'-'"'+CMDFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 If ERR<>0
    Goto FIN_DROITS_SQL
 Endif

Endif
Endif : #VPO 08/09/08 49050 pb validation datawarehouse et roles 140

$FIN_DROITS_SQL
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
Return

$MOD_DROITS_ORA
#############################################################
## Pour Oracle
#############################################################
Local Char    BASE(30), USER(30), PASSE(30)
Local Char    SAVIFS(5) , SAVIRS(5) , XBASE(20)
Local Integer SAVIUM
Local Char    TBDAT(30) , TBIDX(30)
Local Char    FICTRA(GDIMFIC), FICSQL(GDIMFIC)
Local Char    SQLFIC(GDIMFIC), TRAFIC(GDIMFIC)
Local Char    APPLI(50), IRS(2), OS(10)
Local Char    MACHINE(GDIMFIC), NOMDOS(GDIMFIC),MACBID(GDIMFIC)
Local Char PROPERTY(100),AUTHEN_PWD(200),AUTHEN_LOGIN(200)
Local Char WVERSORA(30)
Local Char TEXT(250)(3)
Local Integer TROUVE : TROUVE=0

SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
Onerrgo ERREUR

#VPO 08/09/08 49050 pb validation datawarehouse et roles 140
For (Char VBDDROL(200)) From '3' Sql
&        "select granted_role from dba_role_privs where granted_role='"+DOSSCOUR+"_ADX' "
&        As [BDD]
 TROUVE=1
 Break
Next

If TROUVE

APPLI=nomap
Call MACHINE(APPLI,MACHINE,NOMDOS) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
If toupper(OS)="UNIX"
   IRS = chr$(10)
Else
   IRS = chr$(13)+chr$(10)
Endif

adxifs = "" : adxirs = IRS : adxium = GASCII
Call PASSE(APPLI,BASE,USER,PASSE,TBDAT,TBIDX) From ORAPASSE
If BASE<>""
    PROPERTY="database.software.sqlsystempwd"
    # Récupération du passwd system
    Call PASSWD(PROPERTY,AUTHEN_PWD,ERR) From DOSBASE
    If ERR <> 0
        ERR=1
        Goto FIN_DROITS_ORA
    Endif
    # recuperation du compte sa....AUTHEN_LOGIN
    # si on trouve rien system par défaut.....
    Call PASSWD("database.software.sqlsystemlogin",AUTHEN_LOGIN,ERR) From DOSBASE
    If ERR <> 0
        ERR=1
        Goto FIN_DROITS_ORA
    Endif
    #
    Call VERS_ORA(WVERSORA,ERR) From ORATRA
    If ERR <> 0
        Goto FIN_DROITS_ORA
    Endif

 FICSQL = filpath("tmp","oratrt"+num$(adxuid(2)),"sql",APPLI)
 Call MACHINE(FICSQL,MACBID,SQLFIC) From ORDSYS
 FICTRA = filpath("tmp","oratrt"+num$(adxuid(2)),"log",APPLI)
 Call MACHINE(FICTRA,MACBID,TRAFIC) From ORDSYS
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 adxifs = "" : adxirs = IRS : adxium = GASCII

 Openo FICSQL , 0
 Wrseq "set termout off"
 Wrseq "set echo    off"
 Wrseq "spool"-TRAFIC
 #Wrseq "connect SYSTEM/"+AUTHEN_PWD
 Wrseq "connect "+AUTHEN_LOGIN+"/"+AUTHEN_PWD
 If GRANT = 1
     If TYP="T"
        Wrseq "grant"-DOSSCOUR+"_ADX to"-DOSSIER+";"
     Else : # "L"
        Wrseq "grant"-DOSSCOUR+"_ADX_R to"-DOSSIER+";"
     Endif
 Else
     If TYP="T"
        Wrseq "revoke"-DOSSCOUR+"_ADX from"-DOSSIER+";"
     Else : # "L"
        Wrseq "revoke"-DOSSCOUR+"_ADX_R from"-DOSSIER+";"
     Endif
 Endif
 Wrseq "exit"
 Openo
 If GRANT = 1
     CTRL=2
 Else
     CTRL=1
 Endif
 Gosub EXEC_FIC_ORA
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 If ERR<>0
    Goto FIN_DROITS_ORA
 Endif

Endif
Endif : #VPO 08/09/08 49050 pb validation datawarehouse et roles 140

$FIN_DROITS_ORA
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
Return

###################################################################################################
###################################################################################################
$ERREUR
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ERREUR(GMESSAGE) From GESECRAN
ERR=1
End



###################################################################################################
###################################################################################################
Subprog RETABLIR_DROITS(DOSSIER,ERR)
Value Char DOSSIER()
Variable Integer ERR

If GTYPDBA<>1 : # ne faire que si Oracle
    End
Endif
#############################################################
## Pour Oracle
#############################################################
Local Char    BASE(30), USER(30), PASSE(30)
Local Char    SAVIFS(5) , SAVIRS(5) , XBASE(20)
Local Integer SAVIUM
Local Char    TBDAT(30) , TBIDX(30)
Local Char    FICTRA(GDIMFIC), FICSQL(GDIMFIC)
Local Char    SQLFIC(GDIMFIC), TRAFIC(GDIMFIC)
Local Char    APPLI(50), IRS(2), OS(10)
Local Char    MACHINE(GDIMFIC), NOMDOS(GDIMFIC),MACBID(GDIMFIC)
Local Char PROPERTY(100),AUTHEN_PWD(200),AUTHEN_LOGIN(200)
Local Char WVERSORA(30)
Local Char TEXT(250)(3)


APPLI=nomap
Call MACHINE(APPLI,MACHINE,NOMDOS) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
If toupper(OS)="UNIX"
   IRS = chr$(10)
Else
   IRS = chr$(13)+chr$(10)
Endif

SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
adxifs = "" : adxirs = IRS : adxium = GASCII
Call PASSE(APPLI,BASE,USER,PASSE,TBDAT,TBIDX) From ORAPASSE
If BASE<>""

  PROPERTY="database.software.sqlsystempwd"
  # Récupération du passwd system
  Call PASSWD(PROPERTY,AUTHEN_PWD,ERR) From DOSBASE
  If ERR <> 0
      ERR=1
      Goto FIN_RET_ORA
  Endif
  # recuperation du compte sa....AUTHEN_LOGIN
  # si on trouve rien system par défaut.....
  Call PASSWD("database.software.sqlsystemlogin",AUTHEN_LOGIN,ERR) From DOSBASE
  If ERR <> 0
      ERR=1
      Goto FIN_RET_ORA
  Endif

  #
  Call VERS_ORA(WVERSORA,ERR) From ORATRA
  If ERR <> 0
      Goto FIN_RET_ORA
  Endif

 FICSQL = filpath("tmp","oratrt"+num$(adxuid(2)),"sql",APPLI)
 Call MACHINE(FICSQL,MACBID,SQLFIC) From ORDSYS
 FICTRA = filpath("tmp","oratrt"+num$(adxuid(2)),"log",APPLI)
 Call MACHINE(FICTRA,MACBID,TRAFIC) From ORDSYS
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 adxifs = "" : adxirs = IRS : adxium = GASCII

 Openo FICSQL , 0
 Wrseq "set termout off"
 Wrseq "set echo    off"
 Wrseq "spool"-TRAFIC
 #Wrseq "connect SYSTEM/"+AUTHEN_PWD
 Wrseq "connect "+AUTHEN_LOGIN+"/"+AUTHEN_PWD

 Gosub WRITE_CTRL_PROC
 Wrseq "exit"
 Openo
 CTRL=2
 Gosub EXEC_FIC_ORA
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 If ERR<>0
    Goto FIN_RET_ORA
 Endif

 Openo FICSQL , 0
 Wrseq "set termout off"
 Wrseq "set echo    off"
 Wrseq "spool"-TRAFIC
 #Wrseq "connect SYSTEM/"+AUTHEN_PWD
 Wrseq "connect "+AUTHEN_LOGIN+"/"+AUTHEN_PWD

 Gosub WRITE_EXE_PROC
 Wrseq "exit"
 Openo
 CTRL=2
 Gosub EXEC_FIC_ORA
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 If ERR<>0
    Goto FIN_RET_ORA
 Endif

Endif
$FIN_RET_ORA
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
End

###################################################################################################
###################################################################################################
$EXEC_FIC_SQL
Local Char WORDRE(250)
Local Char    LIGNE(250)
 ##
 ## On ecrit le fichier de commande pour le déclenchement
 ## car bug sur probleme de PATH
 ##WORDRE = SQLDBA-"-D"-BASE-"-U sa -P"-VPWD-"-i"-SQLFIC-"-o"-TRAFIC-"-h-1 -n -w250"

 Openo FICCMD , 0
 Wrseq "@ECHO OFF"
 Wrseq "BREAK OFF"
 # jira X3-86047 86048 86049 replace osql by sqlcmd
 If func ASYRSYS.VERSRUN(GACTX,"")>= "R091"
       Wrseq "SET SQLCMD_EXE="+SQLDBA
       WORDRE = 'IF EXIST "%SQLS7_SQLCMD%\BINN\'+SQLDBA+'.EXE" SET SQLCMD_EXE="%SQLS7_SQLCMD%\BINN\'+SQLDBA+'.EXE"'
       Wrseq WORDRE
       WORDRE = '%SQLCMD_EXE%'-'-S'-XINSTANCE-'-d'-XBASE-'-U'-AUTHEN_LOGIN-'-P'-AUTHEN_PWD-'-i'-'"'+SQLFIC+'"'-'-o'-'"'+TRAFIC+'"'-'-h-1 -w500'
       Wrseq WORDRE
 Else
       Wrseq "SET OSQL_EXE="+SQLDBA
       WORDRE = 'IF EXIST "%SQLS7_OSQL%\BINN\'+SQLDBA+'.EXE" SET OSQL_EXE="%SQLS7_OSQL%\BINN\'+SQLDBA+'.EXE"'
       Wrseq WORDRE
       WORDRE = '%OSQL_EXE%'-'-D'-BASE-'-U sa -P'-AUTHEN_PWD-'-i'-'"'+SQLFIC+'"'-'-o'-'"'+TRAFIC+'"'-'-h-1 -n -w500'
       Wrseq WORDRE
 Endif
 Wrseq "BREAK ON"
 Openo
 System COMMANDE = MACHINE+'@'+CMDFIC
 adxifs = "" : adxirs = IRS : adxium = GASCII
 If filinfo(FICTRA,0)>0 and CTRL=2
  Openi FICTRA
  Rdseq LIGNE
  While fstat=0
   LIGNE=vireblc(LIGNE,2)
   If ERR=1
        TEXT(1)=LIGNE
        Call ECR_TRACE(TEXT(0..1),1) From GESECRAN
      Break
   Elsif toupper(left$(LIGNE,3))="MSG"
      TEXT(0)=LIGNE
      ERR=1
   Endif
   Rdseq LIGNE
  Wend
  Openi
 Elsif CTRL=2
      Call ECR_TRACE("|"+mess(12,100,1)-FICTRA,1) From GESECRAN
      ERR=1
 Endif
Return
###################################################################################################
###################################################################################################
$EXEC_FIC_ORA
Local Char WORDRE(250)
Local Char    LIGNE(250)

 SQLDBA = "sqlplus" : # Ca existe dans les 2 versions
 WORDRE = SQLDBA-'/NOLOG @'+SQLFIC
 Call SYSTEME(MACHINE,WORDRE,"",ERR) From ORDSYS
 adxifs = "" : adxirs = IRS : adxium = GASCII
 If filinfo(FICTRA,0)>0 and CTRL=2
  Openi FICTRA
  Rdseq LIGNE
  While fstat=0
   LIGNE=vireblc(LIGNE,2)
   If left$(LIGNE,4) = "ORA-"
      Call ECR_TRACE("|"+LIGNE,1) From GESECRAN
      ERR=1
      Break
   Elsif left$(LIGNE,4) = "SP2-"
      Call ECR_TRACE("|"+LIGNE,1) From GESECRAN
      ERR=1
      Break
   Elsif left$(LIGNE,4) = "PLS-"
      Call ECR_TRACE("|"+LIGNE,1) From GESECRAN
      ERR=1
      Break
   Endif
   Rdseq LIGNE
  Wend
  Openi
 Elsif CTRL=2
      Call ECR_TRACE("|"+mess(12,100,1)-FICTRA,1) From GESECRAN
      ERR=1
 Endif
Return

###################################################################################################
###################################################################################################
$WRITE_CTRL_PROC
   Wrseq ""
   Wrseq "CREATE OR REPLACE PROCEDURE SPX3_"+DOSSIER+"_CTRL_GRANT (i_usr IN VARCHAR2) IS"
   Wrseq ""
   Wrseq "wUSR dba_role_privs.GRANTEE%TYPE;"
   Wrseq ""
   Wrseq "CURSOR crech_supp IS"
   Wrseq "select OWNER,TABLE_NAME,PRIVILEGE"
   Wrseq "from dba_tab_privs TU"
   Wrseq "where TU.GRANTEE=wUSR"
   Wrseq "and exists (select 'x' from  dba_tab_privs TR ,dba_roles R "
   Wrseq "            where (R.role like '%ADX%' OR R.role like '%ADONIX%') and R.role=TR.GRANTEE"
   Wrseq "            and TR.OWNER=TU.OWNER and TR.TABLE_NAME=TU.TABLE_NAME and TR.PRIVILEGE = TU.PRIVILEGE)"
   Wrseq "and not exists(select 'x' from dba_tab_privs TR,dba_role_privs RP "
   Wrseq "               where RP.GRANTEE=wUSR and RP.GRANTED_ROLE=TR.GRANTEE"
   Wrseq "               and TR.OWNER=TU.OWNER and TR.TABLE_NAME=TU.TABLE_NAME "
   Wrseq "               and TR.PRIVILEGE = TU.PRIVILEGE )"
   Wrseq "UNION"
   Wrseq "select OWNER,TABLE_NAME,PRIVILEGE"
   Wrseq "from dba_tab_privs TU"
   Wrseq "where TU.GRANTEE=wUSR"
   Wrseq "and PRIVILEGE<>'SELECT'"
   Wrseq "and exists (select 'x' from  dba_tab_privs TR ,dba_roles R "
   Wrseq "            where (R.role like '%ADX%' OR R.role like '%ADONIX%') and R.role=TR.GRANTEE"
   Wrseq "            and TR.OWNER=TU.OWNER and TR.TABLE_NAME=TU.TABLE_NAME and TR.PRIVILEGE = TU.PRIVILEGE)"
   Wrseq "order by 1,2,3;"
   Wrseq "wrech_supp crech_supp%ROWTYPE;"
   Wrseq ""
   Wrseq "CURSOR crech_new IS"
   Wrseq "select distinct TR.OWNER,TR.TABLE_NAME"
   Wrseq "from dba_tab_privs TR,dba_role_privs RP ,dba_objects OB"
   Wrseq "where RP.GRANTEE=wUSR and RP.GRANTED_ROLE=TR.GRANTEE"
   Wrseq "and (RP.GRANTED_ROLE like '%ADX%' OR RP.GRANTED_ROLE like '%ADONIX%')"
   Wrseq "and TR.OWNER<>wUSR"
   Wrseq "and TR.PRIVILEGE='SELECT'"
   Wrseq "and OB.OWNER=TR.OWNER AND OB.OBJECT_NAME=TR.TABLE_NAME AND OB.OBJECT_TYPE IN ('TABLE','VIEW')"
   Wrseq "and not exists(select 'x' from dba_tab_privs TU"
   Wrseq "               where TU.GRANTEE=wUSR"
   Wrseq "               and TR.OWNER=TU.OWNER and TR.TABLE_NAME=TU.TABLE_NAME "
   Wrseq "               and TR.PRIVILEGE = TU.PRIVILEGE "
   Wrseq "               AND TU.GRANTABLE=DECODE(TR.OWNER,'SYS',TU.GRANTABLE,'SYSTEM',TU.GRANTABLE,'YES')  )"
   Wrseq "order by 1,2;"
   Wrseq "wrech_new crech_new%ROWTYPE;"
   Wrseq ""
   Wrseq "l_sql varchar2(500);"
   Wrseq "BEGIN"
   Wrseq "  wUSR:=NULL;"
   Wrseq "  IF i_usr IS NOT NULL THEN"
   Wrseq "      wUSR := i_usr;"
   Wrseq "  END IF;"
   Wrseq "  ------------------------------------"
   Wrseq "  -- Recherche des droits à supprimer"
   Wrseq "  ------------------------------------"
   Wrseq "  OPEN crech_supp;"
   Wrseq "  FETCH crech_supp INTO wrech_supp;"
   Wrseq "  WHILE crech_supp%FOUND"
   Wrseq "  LOOP"
   Wrseq "  -- on a un utilisateur beneficiaire du droit"
   Wrseq "    l_sql:= 'revoke '||wrech_supp.PRIVILEGE||' on '||"
   Wrseq "               wrech_supp.OWNER||'.'||wrech_supp.TABLE_NAME||' from '||wUSR;"
#   Wrseq "    dbms_output.put_line('SPX3_"+DOSSIER+"_CTRL_GRANT: SUPP ('||wUSR||') '||wrech_supp.OWNER||'.'||wrech_supp.TABLE_NAME||'('||wrech_supp.PRIVILEGE||')');"
   Wrseq "    execute immediate l_sql;"
   Wrseq "    FETCH crech_supp INTO wrech_supp;"
   Wrseq "  END LOOP;"
   Wrseq "  CLOSE crech_supp;"
   Wrseq ""
   Wrseq ""
   Wrseq "  ------------------------------------"
   Wrseq "  -- Recherche des droits à ajouter"
   Wrseq "  ------------------------------------"
   Wrseq "  OPEN crech_new;"
   Wrseq "  FETCH crech_new INTO wrech_new;"
   Wrseq "  WHILE crech_new%FOUND"
   Wrseq "  LOOP"
   Wrseq "    -- on a un utilisateur qui doit beneficier du droit"
   Wrseq "    IF wrech_new.OWNER='SYS' or wrech_new.OWNER='SYSTEM' THEN"
   Wrseq "    l_sql:= 'grant SELECT on '||"
   Wrseq "               wrech_new.OWNER||'.'||wrech_new.TABLE_NAME||' to '||wUSR;"
   Wrseq "    ELSE"
   Wrseq "    l_sql:= 'grant SELECT on '||"
   Wrseq "               wrech_new.OWNER||'.'||wrech_new.TABLE_NAME||' to '||wUSR||' with grant option';"
   Wrseq "    END IF;"
#   Wrseq "    dbms_output.put_line('SPX3_"+DOSSIER+"_CTRL_GRANT: NEW ('||wUSR||') '||wrech_new.OWNER||'.'||wrech_new.TABLE_NAME||'(SELECT)');"
   Wrseq "    execute immediate l_sql;"
   Wrseq "    FETCH crech_new INTO wrech_new;"
   Wrseq "  END LOOP;"
   Wrseq "  CLOSE crech_new;"
   Wrseq ""
   Wrseq "EXCEPTION WHEN OTHERS THEN RAISE;"
   Wrseq "END;"
   Wrseq "/"
   Wrseq ""
   Wrseq "show errors"
   Wrseq ""
Return


###################################################################################################
###################################################################################################
$WRITE_EXE_PROC
   Wrseq ""
#   Wrseq "SET SERVEROUTPUT ON"
   Wrseq "BEGIN"
#   Wrseq "DBMS_OUTPUT.ENABLE(1000000);"
   Wrseq "SPX3_"+DOSSIER+"_CTRL_GRANT('"+DOSSIER+"');"
   Wrseq "END;"
   Wrseq "/"
   Wrseq ""
   Wrseq "DROP PROCEDURE SPX3_"+DOSSIER+"_CTRL_GRANT ;"
   Wrseq ""
Return




###################################################################################################
###################################################################################################
Subprog CRE_PROC_PROP_GRANT(DOSSIER,ERR)
Value Char DOSSIER()
Variable Integer ERR

If GTYPDBA<>1 : # ne faire que si Oracle
    End
Endif
#############################################################
## Pour Oracle
#############################################################
Local Char    BASE(30), USER(30), PASSE(30)
Local Char    SAVIFS(5) , SAVIRS(5) , XBASE(20)
Local Integer SAVIUM
Local Char    TBDAT(30) , TBIDX(30)
Local Char    FICTRA(GDIMFIC), FICSQL(GDIMFIC)
Local Char    SQLFIC(GDIMFIC), TRAFIC(GDIMFIC)
Local Char    APPLI(50), IRS(2), OS(10)
Local Char    MACHINE(GDIMFIC), NOMDOS(GDIMFIC),MACBID(GDIMFIC)
Local Char    WVERSORA(30)

APPLI=nomap
Call MACHINE(APPLI,MACHINE,NOMDOS) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
If toupper(OS)="UNIX"
   IRS = chr$(10)
Else
   IRS = chr$(13)+chr$(10)
Endif

SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
adxifs = "" : adxirs = IRS : adxium = GASCII
If DOSSIER="" : DOSSIER=NOMDOS : Endif
Call PASSE(DOSSIER,BASE,USER,PASSE,TBDAT,TBIDX) From ORAPASSE
If BASE<>""

 Call VERS_ORA(WVERSORA,ERR) From ORATRA
 If ERR <> 0
    Goto FIN_CRE_ORA
 Endif

 FICSQL = filpath("tmp","oratrt"+num$(adxuid(2)),"sql",APPLI)
 Call MACHINE(FICSQL,MACBID,SQLFIC) From ORDSYS
 FICTRA = filpath("tmp","oratrt"+num$(adxuid(2)),"log",APPLI)
 Call MACHINE(FICTRA,MACBID,TRAFIC) From ORDSYS
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 adxifs = "" : adxirs = IRS : adxium = GASCII

 Openo FICSQL , 0
 Wrseq "set termout off"
 Wrseq "set echo    off"
 Wrseq "spool"-TRAFIC
 Wrseq "connect"-USER+"/"+PASSE
 Gosub WRITE_PROP_PROC
 Wrseq "exit"
 Openo
 CTRL=2
 Gosub EXEC_FIC_ORA
 System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
 System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
 If ERR<>0
    Goto FIN_CRE_ORA
 Endif

Endif
$FIN_CRE_ORA
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
End


###################################################################################################
###################################################################################################
$WRITE_PROP_PROC
   Wrseq ""
   Wrseq "CREATE OR REPLACE PROCEDURE "+DOSSIER+".SPX3_"+DOSSIER+"_PROP_GRANT (i_owner IN VARCHAR2, "
   Wrseq "                                                   i_obj IN VARCHAR2 := NULL) IS"
   Wrseq ""
   Wrseq "wROLE dba_tab_privs.GRANTEE%TYPE;"
   Wrseq "wOBJ dba_tab_privs.TABLE_NAME%TYPE := NULL;"
   Wrseq "-- GRANTEE,OWNER,TABLE_NAME,GRANTOR,PRIVILEGE,GRANTABLE,HIERARCHY"
   Wrseq ""
   Wrseq "CURSOR crech_role IS"
   Wrseq "select TR.GRANTEE,TR.OWNER,TR.TABLE_NAME,TR.PRIVILEGE "
   Wrseq "from dba_tab_privs TR,dba_objects OB"
   Wrseq "where TR.OWNER=i_owner "
   Wrseq "and TR.PRIVILEGE='SELECT'"
   Wrseq "and (TR.TABLE_NAME =wOBJ or wOBJ IS NULL)"
   Wrseq "and exists(select 'x' from DBA_ROLES R where R.role=TR.GRANTEE)"
   Wrseq "and OB.STATUS='VALID' and OB.TEMPORARY='N'"
   Wrseq "and OB.OWNER=TR.OWNER AND OB.OBJECT_NAME=TR.TABLE_NAME AND OB.OBJECT_TYPE IN ('TABLE','VIEW')"
   Wrseq "order by 2,3,1,4;"
   Wrseq "wrech_role crech_role%ROWTYPE;"
   Wrseq ""
   Wrseq "-- GRANTEE,GRANTED_ROLE,ADMIN_OPTION,DEFAULT_ROLE"
   Wrseq ""
   Wrseq "CURSOR crech_user IS"
   Wrseq "select RP.GRANTEE"
   Wrseq "from dba_role_privs RP"
   Wrseq "where RP.GRANTED_ROLE=wROLE"
   Wrseq "and RP.GRANTEE not in ('SYSTEM','SYS',i_owner)"
   Wrseq "and not exists(select 'x' from dba_tab_privs TU"
   Wrseq "               where TU.GRANTEE=RP.GRANTEE"
   Wrseq "               and TU.OWNER=wrech_role.OWNER and TU.TABLE_NAME=wrech_role.TABLE_NAME"
   Wrseq "               and TU.PRIVILEGE=wrech_role.PRIVILEGE"
   Wrseq "               AND TU.GRANTABLE=DECODE(wrech_role.OWNER,'SYS',TU.GRANTABLE,'SYSTEM',TU.GRANTABLE,'YES')  )"
   Wrseq "order by 1;"
   Wrseq "wrech_user crech_user%ROWTYPE;"
   Wrseq "l_sql varchar2(500);"
   Wrseq "BEGIN"
   Wrseq "  wOBJ:=NULL;"
   Wrseq "  IF i_obj IS NOT NULL THEN"
   Wrseq "      wOBJ := i_obj;"
   Wrseq "  END IF;"
   Wrseq "  wROLE:=NULL;"
   Wrseq "  OPEN crech_role;"
   Wrseq "  FETCH crech_role INTO wrech_role;"
   Wrseq "  WHILE crech_role%FOUND"
   Wrseq "  LOOP"
   Wrseq "  -- on a un role et un privilege"
   Wrseq "     wROLE := wrech_role.GRANTEE;"
#   Wrseq "     dbms_output.put_line('SPX3_"+DOSSIER+"_PROP_GRANT: ('||wROLE||') '||wrech_role.OWNER||'.'||wrech_role.TABLE_NAME||' ('||wrech_role.PRIVILEGE||')');"
   Wrseq "     OPEN crech_user;"
   Wrseq "     FETCH crech_user INTO wrech_user;"
   Wrseq "     WHILE crech_user%FOUND"
   Wrseq "     LOOP"
   Wrseq "     -- on a un utilisateur beneficiaire du role"
   Wrseq "       IF wrech_role.OWNER='SYS' OR wrech_role.OWNER='SYSTEM' THEN"
   Wrseq "       l_sql:= 'grant '||wrech_role.PRIVILEGE||' on '||"
   Wrseq "                  wrech_role.OWNER||'.'||wrech_role.TABLE_NAME||' to '||wrech_user.GRANTEE;"
   Wrseq "       ELSE"
   Wrseq "       l_sql:= 'grant '||wrech_role.PRIVILEGE||' on '||"
   Wrseq "                  wrech_role.OWNER||'.'||wrech_role.TABLE_NAME||' to '||wrech_user.GRANTEE||' with grant option';"
   Wrseq "       END IF;"
#   Wrseq "       dbms_output.put_line('--> ('||wROLE||') '||l_sql);"
   Wrseq "       execute immediate l_sql;"
   Wrseq "       FETCH crech_user INTO wrech_user;"
   Wrseq "     END LOOP;"
   Wrseq "     CLOSE crech_user;"
   Wrseq "     FETCH crech_role INTO wrech_role;"
   Wrseq "  END LOOP;"
   Wrseq "  CLOSE crech_role;"
   Wrseq ""
   Wrseq "EXCEPTION WHEN OTHERS THEN RAISE;"
   Wrseq "END;"
   Wrseq "/"
   Wrseq ""
   Wrseq "show errors"
   Wrseq ""
Return


###################################################################################################
###Permet de raffraichir les droits pour la session courante
###################################################################################################
Subprog SET_DROITS
If GTYPDBA=1
    Execsql From '3' Sql "SET ROLE ALL"
Endif
End


###################################################################################################
###Fonction permettant de creer le rôle necessaire pour la BI
###################################################################################################

#-----------------------------------------#
# Structure du fichier BOWORLD
#-----------------------------------------#
#<SOLUTION ID='' HOST='' PATH=''>
#    <PROXYPASS></PROXYPASS>
#    <SOLUTIONBIS>
#        <SOLUTIONBI ID='' >
#            <HOST></HOST>
#            <PATH></PATH>
#            <DATABASE ID='' SUPERUSER='' SUPERPWD='' >
#                <NAME></NAME>
#                <TYPE></TYPE>
#                <HOST></HOST>
#                <PORT></PORT>
#                <OS></OS>
#                <ADMINUSER></ADMINUSER>
#                <ADMINPWD></ADMINPWD>
#                <DBLINK></DBLINK>
#            </DATABASE>
#            <RUNTIME ID='' >
#                <HOST></HOST>
#                <PORT></PORT>
#                <PATH></PATH>
#                <OS></OS>
#            </RUNTIME>
#        </SOLUTIONBI>
#    </SOLUTIONBIS>
#</SOLUTION>

#-----------------------------------------------------------------------------------------------------#
# Recherche user et pwd (parcours du noeud de la solution BI dans le fichier boworld)
#-----------------------------------------------------------------------------------------------------#

Subprog USER_BOWORLD(SOLBI,VUSER,VPWD,ERR)
Value Char SOLBI     : # Nom de la solution BI (facultatif)
Variable Char VUSER  : # Nom de l'utilisateur
Variable Char VPWD   : # Mot de passe de l'utilisateur
Variable Integer ERR : # <>0 -> erreur

Local Char    NOMFIC(GDIMFIC) , LIGNE(250) , WPWD(200)
Local Integer I , J , OKSOL , OKBI , OKDAT

Call BOWORLD(NOMFIC) From ABICREBAS
If NOMFIC="" : ERR = 1 : End : Endif

# Contenu du fichier boworld
ERR = 1
OK=0
Openi NOMFIC,0 Using [BOS_]
Iomode adxifs ""  Using [BOS_]
Iomode adxirs chr$(10)  Using [BOS_]
Iomode adxium GUTF8  Using [BOS_]
Raz OKSOL , OKBI , OKDAT
Rdseq LIGNE Using [BOS_]
While !fstat
 If instr(1,toupper(LIGNE),"<SOLUTION ")
  OKSOL = instr(1,toupper(LIGNE),toupper("ID='"+GINSTID+"'"))
  OKSOL += instr(1,toupper(LIGNE),toupper('ID="'+GINSTID+'"'))
 Elsif OKSOL & instr(1,toupper(LIGNE),toupper("</SOLUTION>"))
  OKSOL = 0
 Endif
 If OKSOL : # On est dans le noeud de la bonne solution x3
  If SOLBI=""
   OKBI = 1
  Elsif instr(1,toupper(LIGNE),toupper("<SOLUTIONBI "))
   OKBI = instr(1,toupper(LIGNE),toupper("ID='"+SOLBI+"'"))
   OKBI += instr(1,toupper(LIGNE),toupper('ID="'+SOLBI+'"'))
  Elsif OKBI & instr(1,toupper(LIGNE),toupper("</SOLUTIONBI>"))
   OKBI = 0
  Endif
  If OKBI : # On est dans le noeud de la bonne solution BI
   If instr(1,toupper(LIGNE),toupper("<DATABASE ID"))
    OKDAT = 1
   Elsif OKDAT & instr(1,toupper(LIGNE),toupper("</"+DATA))
    OKDAT = 0
   Endif
   If OKDAT : # On est dans le bon noeud
        # on est même sur la bonne ligne
    PROPERTY="SUPERUSER="
    I = instr(1,toupper(LIGNE),toupper(PROPERTY))
    If I
     #VPO 22/05/07 BUG41412 : on cherche le caractère suivant
     CARSUIV=mid$(LIGNE,I+len(PROPERTY),1)
     J = instr(I+len(PROPERTY)+1,toupper(LIGNE),CARSUIV)
     If J : # Pour traiter les propriétés sous forme superuser='xx' ou superuser=""xx""
      VUSER = mid$(LIGNE,I+len(PROPERTY)+1,J-(I+len(PROPERTY)+1))
      OK += 1
     Endif
    Endif
    I=0
    J=0
    PROPERTY="SUPERPWD="
    I = instr(1,toupper(LIGNE),toupper(PROPERTY))
    If I
     #VPO 22/05/07 BUG41412 : on cherche le caractère suivant
     CARSUIV=mid$(LIGNE,I+len(PROPERTY),1)
     J = instr(I+len(PROPERTY)+1,toupper(LIGNE),CARSUIV)
     If J : # Pour traiter les propriétés sous forme superuser='xx' ou superuser=""xx""
      WPWD= mid$(LIGNE,I+len(PROPERTY)+1,J-(I+len(PROPERTY)+1))
      OK += 1
     Endif
    Endif
    If OK=2 : ERR=0 : Endif
    Break
   Endif
  Endif
 Endif
 Rdseq LIGNE Using [BOS_]
Wend
Openi Using [BOS_]
If !ERR & OK=2 & WPWD<>""
 Call DECRYPTO(WPWD,LIGNE) From GESUSER
 VPWD= LIGNE
Endif
End


###################################################################################################
###################################################################################################
Subprog CREER_ROLE_BI(SOLBI,DOSSIER,ERR)
Value Char SOLBI() : # Nom de la solution BI
Value Char DOSSIER() : # nom du datawarehouse
Variable Integer ERR

# Issue 58608 - 2013-01-21 by VPO : vérifier droit de connection DBA à la base de données
Call VCREER_ROLE_BI(SOLBI,DOSSIER,ERR) From TRTGRANT
If ERR : End : Endif

Local Char    TYPBAS(20) , TYPOS(20)
Local Char    MACHINE(GDIMFIC),MACBID(GDIMFIC)
Local Char    FICTRA(GDIMFIC), FICSQL(GDIMFIC)
Local Char    SQLFIC(GDIMFIC), TRAFIC(GDIMFIC)
Local Char    LIGNE(250)
Local Char    APPLI(50) ,SQLDBA(50) , IRS(2)
Local Char WVERSORA(30)
Local Char VUSER(50),VPWD(50)


Call MACHINE_BO(SOLBI,MACHINE) From ABICREBAS
APPLI = DOSSIER

Call VAR_BOWORLD("type",SOLBI,"database",TYPBAS,ERR) From ABICREBAS
If ERR : End : Endif
##rien a faire dans ce cas
If TYPBAS="SQLSERVER" : End :  Endif
If TYPBAS<>"ORACLE" : End :  Endif
Call VAR_BOWORLD("os",SOLBI,"database",TYPOS,ERR) From ABICREBAS
If ERR : End : Endif

If toupper(TYPOS)="UNIX"
   IRS = chr$(10)
Else
   IRS = chr$(13)+chr$(10)
Endif

SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
adxifs = "" : adxirs = IRS : adxium = GASCII

Call USER_BOWORLD(SOLBI,VUSER,VPWD,ERR) From TRTGRANT
If ERR: Goto FIN_CREER_ROLE_BI : Endif

FICSQL = filpath("!tmp","sqlrole"+num$(adxuid(2)),"sql","","",MACHINE)
Call MACHINE(FICSQL,MACBID,SQLFIC) From ORDSYS
FICTRA = filpath("!tmp","sqlrole"+num$(adxuid(2)),"log","","",MACHINE)
Call MACHINE(FICTRA,MACBID,TRAFIC) From ORDSYS
System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'


Call VERS_ORA(WVERSORA,ERR) From ORATRA
If ERR : Goto FIN_CREER_ROLE_BI : Endif

Openo FICSQL , 0
Wrseq "set termout off"
Wrseq "set echo    off"
Wrseq "spool"-TRAFIC
If left$(WVERSORA,1)="8"
    Wrseq "connect"-VUSER+"/"+VPWD
Else
    Wrseq "connect"-VUSER+"/"+VPWD-"as SYSDBA"
Endif
Wrseq ""
Wrseq "CREATE ROLE "+APPLI+"_ADX_SYS;"
Wrseq ""
Wrseq "grant"
Wrseq "        create session,"
Wrseq "        create table,"
Wrseq "        create view,"
Wrseq "        create trigger,"
Wrseq "        create sequence,"
Wrseq "        create procedure,"
Wrseq "        alter session"
Wrseq "        to "+APPLI+"_ADX_SYS ;"
Wrseq ""
Wrseq "grant select on sys.obj$ to "+APPLI+"_ADX_SYS ;"
Wrseq "grant select on sys.ind$ to "+APPLI+"_ADX_SYS ;"
Wrseq "grant select on sys.col$ to "+APPLI+"_ADX_SYS ;"
Wrseq "grant select on sys.icol$ to "+APPLI+"_ADX_SYS ;"
Wrseq "grant select on sys.user$ to "+APPLI+"_ADX_SYS ;"
Wrseq ""
Wrseq "grant select on v_$session to "+APPLI+"_ADX_SYS ;"
Wrseq "grant select on v_$process to "+APPLI+"_ADX_SYS ;"
Wrseq "grant select on v_$parameter to "+APPLI+"_ADX_SYS ;"
Wrseq ""
Wrseq "REM Nouveaux droits pour 150"
Wrseq "REM --------------------------"
Wrseq "REM "
Wrseq ""
Wrseq "grant select on v_$database to "+APPLI+"_ADX_SYS;"
Wrseq "grant select on v_$instance to "+APPLI+"_ADX_SYS;"
Wrseq ""
Wrseq "REM uniquement ssi base 10g;"
Wrseq "grant select on v_$sgainfo to "+APPLI+"_ADX_SYS;"
Wrseq ""
Wrseq "grant select on v_$pgastat to "+APPLI+"_ADX_SYS;"
Wrseq "grant select on v_$sgastat to "+APPLI+"_ADX_SYS;"
Wrseq "grant select on v_$statname to "+APPLI+"_ADX_SYS ;"
Wrseq "grant select on v_$sesstat  to "+APPLI+"_ADX_SYS ;"
Wrseq "grant select on v_$sqltext_with_newlines  to "+APPLI+"_ADX_SYS ;"
Wrseq "grant select on v_$LOCK   to "+APPLI+"_ADX_SYS ;"
Wrseq ""
Wrseq "REM Nouveaux droits pour 150"
Wrseq "REM --------------------------"
Wrseq "REM ces droits devront être aussi sur utilisateurs"
Wrseq ""
Wrseq "grant select on DBA_OBJECTS  to "+APPLI+"_ADX_SYS ;"
Wrseq "grant select on dba_tab_privs to "+APPLI+"_ADX_SYS;"
Wrseq "grant select on dba_role_privs to "+APPLI+"_ADX_SYS;"
Wrseq "grant select on dba_roles to "+APPLI+"_ADX_SYS;"
Wrseq ""
Wrseq "REM ------------------------------------------;"
Wrseq "REM GRANT POUR SYSTEM"
Wrseq "REM ------------------------------------------;"
Wrseq ""
Wrseq "grant select on DBA_OBJECTS  to SYSTEM with grant option ;"
Wrseq "grant select on dba_tab_privs to SYSTEM with grant option;"
Wrseq "grant select on dba_role_privs to SYSTEM with grant option;"
Wrseq "grant select on dba_roles to SYSTEM with grant option;"
Wrseq ""
Wrseq "exit"
Openo
# on ne fait pas de contrôle
CTRL=0
Gosub EXEC_FIC_ORA
System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
#System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'

$FIN_CREER_ROLE_BI
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
End
###################################################################################################
###################################################################################################


###################################################################################################
###################################################################################################
Subprog VCREER_ROLE_BI(SOLBI,DOSSIER,ERR)
Value Char SOLBI() : # Nom de la solution BI
Value Char DOSSIER() : # nom du datawarehouse
Variable Integer ERR

Local Char    TYPBAS(20) , TYPOS(20)
Local Char    MACHINE(GDIMFIC),MACBID(GDIMFIC)
Local Char    FICTRA(GDIMFIC), FICSQL(GDIMFIC)
Local Char    SQLFIC(GDIMFIC), TRAFIC(GDIMFIC)
Local Char    LIGNE(250)
Local Char    APPLI(50) ,SQLDBA(50) , IRS(2)
Local Char WVERSORA(30)
Local Char VUSER(50),VPWD(50)


Call MACHINE_BO(SOLBI,MACHINE) From ABICREBAS
APPLI = DOSSIER

Call VAR_BOWORLD("type",SOLBI,"database",TYPBAS,ERR) From ABICREBAS
If ERR : End : Endif
##rien a faire dans ce cas
If TYPBAS="SQLSERVER" : End :  Endif
If TYPBAS<>"ORACLE" : End :  Endif
Call VAR_BOWORLD("os",SOLBI,"database",TYPOS,ERR) From ABICREBAS
If ERR : End : Endif

If toupper(TYPOS)="UNIX"
   IRS = chr$(10)
Else
   IRS = chr$(13)+chr$(10)
Endif

SAVIFS = adxifs : SAVIRS = adxirs : SAVIUM = adxium
adxifs = "" : adxirs = IRS : adxium = GASCII

Call USER_BOWORLD(SOLBI,VUSER,VPWD,ERR) From TRTGRANT
If ERR: Goto FIN_VCREER_ROLE_BI : Endif

FICSQL = filpath("!tmp","sqlvrole"+num$(adxuid(2)),"sql","","",MACHINE)
Call MACHINE(FICSQL,MACBID,SQLFIC) From ORDSYS
FICTRA = filpath("!tmp","sqlvrole"+num$(adxuid(2)),"log","","",MACHINE)
Call MACHINE(FICTRA,MACBID,TRAFIC) From ORDSYS
System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'


Call VERS_ORA(WVERSORA,ERR) From ORATRA
If ERR : Goto FIN_VCREER_ROLE_BI : Endif

Openo FICSQL , 0
Wrseq "set termout off"
Wrseq "set echo    off"
Wrseq "spool"-TRAFIC
If left$(WVERSORA,1)="8"
    Wrseq "connect"-VUSER+"/"+VPWD
Else
    Wrseq "connect"-VUSER+"/"+VPWD-"as SYSDBA"
Endif
Wrseq ""
Wrseq "select 'OK' from DUAL;"
Wrseq ""
Wrseq "exit"
Openo
# on fait le contrôle
CTRL=2
Gosub EXEC_FIC_ORA
System COMMANDE = MACHINE+'@ae_rm'-'"'+SQLFIC+'"'
System COMMANDE = MACHINE+'@ae_rm'-'"'+TRAFIC+'"'
If ERR<>0
    #Droits insuffisants pour accéder à la base du datawarehouse en tant que DBA
    Call ECR_TRACE(mess(236,100,1),1) From GESECRAN
    Goto FIN_VCREER_ROLE_BI
Endif

$FIN_VCREER_ROLE_BI
adxifs = SAVIFS : adxirs = SAVIRS : adxium = SAVIUM
End
###################################################################################################
###################################################################################################


###################################################################################################
###################################################################################################
Subprog CHECK_ROLE_TRIGGER(DOSSIER,ERR)
Value Char DOSSIER()
Variable Integer ERR

If GTYPDBA<>1 : # ne faire que si Oracle
    End
Endif
Local Char SCRIPT(100)
Local Integer TROUVE
TROUVE=0
Onerrgo ERREUR
For (Char VBDDROL(200)) From '3' Sql
&        "select granted_role from dba_role_privs where granted_role='"+GDOSX3+"_ADX_SYS' and grantee='"+DOSSIER+"'"
&        As [BDD]
 TROUVE=1
 Break
Next
Onerrgo

If ERR or TROUVE=0
 Call ECR_TRACE(mess(237,124,1),1) From GESECRAN
 Call ECR_TRACE(func AFNC.MES1(mess(238,124,1),GDOSX3+"_ADX_SYS"-'/'-DOSSIER),1) From GESECRAN
 ERR=1
 End
Endif

TROUVE=0
Onerrgo ERREUR
For (Char VBDDROL(200)) From '3' Sql
&        "select role from role_sys_privs where role='"+GDOSX3+"_ADX_SYS' and privilege='DROP ANY TRIGGER'"
&        As [BDD]
 TROUVE=1
 Break
Next
Onerrgo

If ERR
 Call ECR_TRACE(mess(237,124,1),1) From GESECRAN
 Call ECR_TRACE(func AFNC.MES1(mess(238,124,1),GDOSX3+"_ADX_SYS"-'/'-DOSSIER),1) From GESECRAN
 ERR=1
 End
Elsif TROUVE=0
 Call ECR_TRACE(mess(237,124,1),1) From GESECRAN
 Call ECR_TRACE(func AFNC.MES1(mess(238,124,1),GDOSX3+"_ADX_SYS"-'/'-DOSSIER),1) From GESECRAN
 Local Char    APPLI(50), OS(10)
 Local Char    MACHINE(GDIMFIC), NOMDOS(GDIMFIC)
 APPLI=nomap
 Call MACHINE(APPLI,MACHINE,NOMDOS) From ORDSYS
 Call GET_OS(MACHINE,OS) From ORDSYS
 If toupper(OS)="UNIX"
   SCRIPT="$ADXDIR/ebin/update_SYS_role_17R301.sql"
 Else
   SCRIPT="$ADXDIR/ebin/update_SYS_role_17R3xx.sql"
 Endif
 Call ECR_TRACE(func AFNC.MES1(mess(239,124,1),SCRIPT),1) From GESECRAN
 ERR=1
 End
Endif

End

