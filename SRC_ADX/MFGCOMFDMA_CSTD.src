#<AdxTL>@(#)0.0.0.0 $Revision$
# Class MFGCOMFDMA


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
    When "INITIALIZE" : Gosub INITIALIZE
    When "SET_FDMA" : Gosub SET_FDMA
    When "GET_COMPONENT_LTI" : Gosub GET_COMPONENT_LTI
Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

#**----------------------------------------------------------------<br/>
#* INITIALIZE : Initialize properties of the instance
#**<br/>----------------------------------------------------------------<br/>
#* @param ITMREF = Component code
#* @param BOMSEQ = Component BOM sequence number
#* @param OPENUM = Operation number component is linked
#* @param REQQTY = Required quantity of this component
#* @param REMQTY = Remaining quantity to be allocated/assigned/ordered
#**<br/>----------------------------------------------------------------
#*!
$INITIALIZE
    this.ITMREF = [L]ITMREF
    this.BOMSEQ = [L]BOMSEQ
    this.OPENUM = [L]OPENUM
    this.REQQTY = [L]REQQTY
    If [L]REMQTY <= 0
        this.REMQTY = 0
        this.FDMA = date$
        this.LTDAT = date$
    Else
        this.REMQTY = [L]REMQTY
        Gosub SET_FDMA
    Endif
Return

#**----------------------------------------------------------------<br/>
#* SET_FDMA : Determine the First date of material availability
#**<br/>----------------------------------------------------------------<br/>
$SET_FDMA
    Local File ITMMASTER [ITM]
    Local File ITMFACILIT [ITF]
    Local File TABREOPOL [TRP]
    Local File PARMRP [PCB]
    Local File ITMBPS [ITP]

    Local Integer TYP # Work order type for assignments
    Local Integer LTI # Lead time for component
    Local Decimal LQTA # Quantity available at FDMA

    TYP = 10

    # Get FDMA from stock
    Call CAL_FDMA(this.APARENT.MFGFCY, this.ITMREF, [L]TYP, this.APARENT.MFGNUM, this.APARENT.MFGLIN, this.BOMSEQ, 2, this.REMQTY, [L]LQTA, this.FDMA) From STKLIB

    # If we have a date from the stock function but we haven't satisfied the quantity set the FDMA based on assigned date.
    If this.REMQTY > [L]LQTA
        # Work out date for today + lead time
        Gosub GET_COMPONENT_LTI
        this.LTDAT = date$ + LTI

        #this.FDMA = max (this.LTDAT, this.FDMA)
        # this.FDMA may have a spurious date if [L]LQTA = 0
        # Issue X3-58250 - 2017-10-02 by ALSHE : LQTA must be checked <= 0
        If [L]LQTA <= 0 | this.FDMA = [0/0/0]
            this.FDMA = this.LTDAT
        Else
            this.FDMA = max (this.LTDAT, this.FDMA)
        Endif
    Endif

    # Use calculated lead time if FMDA is blank
    #If this.FDMA = [0/0/0]
    #    this.FDMA = this.LTDAT
    #Endif
Return

#**----------------------------------------------------------------<br/>
#* GET_COMPONENT_LTI : Get the re-order lead time for a component
#**<br/>----------------------------------------------------------------<br/>
#* Lead time is taken from stock records based on Suggestion type and lead time values.
#* @param LTI = Lead time in calendars as an integer
#**<br/>----------------------------------------------------------------
#*!
$GET_COMPONENT_LTI
    Local Char BPRNUM(GLONBPR)
    Local Char SRVITMREF(GLONITM)

    Local Integer I
    Local Integer WRKDAYS
    Local Integer CALDAYS
    Local Integer INTMULTI

    Local Decimal SCOLTI
    Local Decimal MULTIREQQTY
    Local Decimal MULTI
    Local Decimal DSTDEL

    Local Date STARTDAY
    Local Date ENDDAY

    LTI = 0
    [L]CALDAYS = 0

    If [F:ITF]ITMREF <> this.ITMREF | [F:ITF]STOFCY <> this.APARENT.MFGFCY
        Read [ITF]ITF0 = this.ITMREF;this.APARENT.MFGFCY
        If fstat <> [V]CST_AOK
            ARET_VALUE = 1
            Return
        Endif
    Endif

    If [F:PCB]STOFCY <> this.APARENT.MFGFCY
        Read [PCB]PCB0 = this.APARENT.MFGFCY
        If fstat <> [V]CST_AOK
            ARET_VALUE = 1
            Return
        Endif
    Endif

    # Issue X3-64161 - 2017-11-16 by ALSHE : read ITM record to determine product reorder leadtime
    If [F:ITM]ITMREF <> this.ITMREF
        Read [ITM]ITM0 = this.ITMREF
        If fstat <> [V]CST_AOK
            ARET_VALUE = 1
            Return
        Endif
    Endif

    # Set quality lead time
    [L]WRKDAYS = [F:ITF]QUALTI

    # Manufacturing lead time type
    If [F:ITF]REOCOD=3
        # Call the generic function to determine lead time for multiple work orders
        Call CALCUL_DELAI([F:ITF]MFGLTI, this.REMQTY, [L]DSTDEL) From MFGLIB_SYRA
        [L]WRKDAYS = [L]DSTDEL

    # Sub-contract lead time type
    Elsif [F:ITF]REOCOD=5
        If [F:ITM]SCPFLG=2
            #Issue X3-114520 by GEBIL 25/10/2018 : PS breack due to global variable
            If dim(GITMBPSFCY)<0
              Global Integer GITMBPSFCY
              Local Char WPARAM(1)
              Call PARAM(this.APARENT.MFGFCY,'ITMBPSFCY',WPARAM) From ADOVAL
              GITMBPSFCY = val(WPARAM)
            Endif
            Call FIND_BPRNUM (this.ITMREF,[F:PCB]MRPBOMALT,"",this.APARENT.MFGFCY,[L]BPRNUM) From SCOLIB
            Call FIND_SCI_LTI(this.ITMREF,[L]BPRNUM,this.APARENT.MFGFCY,[F:PCB]MRPBOMALT,[L]SRVITMREF,[L]SCOLTI) From SCOLIB_SYRA

            [L]CALDAYS = [L]SCOLTI
        Else
            [L]CALDAYS = [F:ITF]OFS
        Endif

    # Purchasing lead time type
    # Issue X3-64161 - 2017-11-16 by ALSHE : If LT on product site = 0, use LT from product
		Elsif [F:ITF]OFS = 0
        [L]CALDAYS = [F:ITM]OFS
    Else
        [L]CALDAYS = [F:ITF]OFS
    Endif

    # Convert any working days to calendar days
    [L]STARTDAY = date$ + [L]CALDAYS
    # Call the generic function to calculate calendar days lead time from working days
    Call CALCUL_DATE_PLN([L]STARTDAY, [L]WRKDAYS, this.APARENT.MFGFCY, 0, this.APARENT.TWD, [L]ENDDAY) From MFGLIB_SYRA
    LTI = [L]ENDDAY - date$
Return

