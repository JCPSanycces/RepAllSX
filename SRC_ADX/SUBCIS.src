    [M:CG2]FLD1    =  ""
    [M:CG2]OPE1    = 1 
    [M:CG2]VAL1    = ""
    [M:CG2]VALI1   = ""
    Affzo [M:CG2]  
  Endif

  GCVAL1      = [M:CG2]VAL1 
  WIANDORSUIV  = [M:CG2]ANDOR2
