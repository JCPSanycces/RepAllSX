Variable Char VALEUR()
Local Integer WITYP
Local Integer I
I = 1
#If VALEUR = "" 
#   WCREQUETE = ""
#   [M:CG2]REQUETE = WCREQUETE
#   Affzo [CG2]
#   [M]VAL1 = ""
#   Affzo [M]VAL1
#   End 
