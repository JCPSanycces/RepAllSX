I = 5
Goto C_FLD
##########################################################################
## $C_ZFLD : Fonction de Controle sur la saisie des rubriques            ##
##########################################################################
$C_ZFLD

Local Integer K , DIME , DIMMAX
Local Char    ZONE(20)

VALEUR = toupper(VALEUR)
ZONE = VALEUR

##---- Lecture afin de voir si la rubrique existe dans la table ---------  ##
Read [ATZ]CODZONE = evalue("[M]TBL"+num$(I));ZONE
If fstat
   GMESSAGE = mess(9,124,1) : # Champ inexistant
   mkstat = 2 : End
Endif

If [F:ATZ]CODTYP="AXX"
   GMESSAGE = [F:ATZ]CODTYP-":"-mess(14,133,1) : # Type de donnée incorrect
   mkstat = 2 : End
Endif

Read [ATY]CODTYP = [F:ATZ]CODTYP
If !fstat 
   If  [F:ATY]TYPTYP>8
       GMESSAGE = mess([F:ATY]TYPTYP,30,1)-":"-mess(14,133,1) : # Type de donnée incorrect
       mkstat = 2 : End
   Else 
       WITYP = [F:ATY]TYPTYP
   Endif 
Endif

VALEUR = ZONE

Return
##########################################################################
$C_FLD

If VALEUR=""
 If [M]NBTBL<>0
  Case I
   When 1 : [M]TBL1 = "" : Affzo TBL1
   When 2 : [M]TBL2 = "" : Affzo TBL2
   When 3 : [M]TBL3 = "" : Affzo TBL3
   When 4 : [M]TBL4 = "" : Affzo TBL4
   When 5 : [M]TBL5 = "" : Affzo TBL5
  Endcase
 Endif
 End
Endif
VALEUR = toupper(VALEUR)
Local Integer K , DIME , DIMMAX
Local Char    ZONE(20)
K = instr(1,VALEUR,"(")
If K
 DIME = val(right$(VALEUR,K+1))
 ZONE = left$(VALEUR,K-1)
Else
 DIME = 0
 ZONE = VALEUR
Endif

Read [ATZ]CODZONE = evalue("[M]TBL"+num$(I));ZONE
If fstat
 GMESSAGE = mess(9,124,1) : # Champ inexistant
 mkstat = 2 : End
Endif
If [F:ATZ]CODTYP="AXX"
 GMESSAGE = [F:ATZ]CODTYP-":"-mess(14,133,1) : # Type de donnée incorrect
 mkstat = 2 : End
Endif
Read [ATY]CODTYP = [F:ATZ]CODTYP
If !fstat & [F:ATY]TYPTYP>8
 GMESSAGE = mess([F:ATY]TYPTYP,30,1)-":"-mess(14,133,1) : # Type de donnée incorrect
 mkstat = 2 : End
Endif
If [F:ATZ]CODACT<>""
 Read [ACV]CODACT = [F:ATZ]CODACT
 If !fstat & ([F:ACV]DIMFIL<>0 or [F:ACV]DIME<>0)
  DIMMAX = max([F:ACV]DIMFIL,[F:ACV]DIME)
 Endif
Else
 DIMMAX = [F:ATZ]DIME
Endif
If (DIME<>0 | DIMMAX<>0) & DIME>DIMMAX-1
 GMESSAGE = mess(46,105,1) : # Indice incorrect
 mkstat = 2 : End
Endif
VALEUR = ZONE
If DIME>0
 VALEUR += "("+num$(DIME)+")"
Endif

End

