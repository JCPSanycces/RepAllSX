#<AdxTL>@(#)4.0.0.0 $Revision$
####################################################################################################
##         Source : SUBCIS                                                                        ##                       
##         Auteur : JDE                                                                           ##                       
##         Date création : 17/02/2005                                                             ##                         
##         Sélection des biens pour la Cession intra-groupe                                       ##                     
####################################################################################################
##  Modifications :                                                                               ## 
##  GLE - 25/03/2011 FQ72442 : manque le return de l'étiquette $FILTRE                            ##
##  MDJ - 13/03/2009         : recopie de V5 vers BERYL  car traitement jamais migré à ce jour    ##
####################################################################################################
##------------------------------------------------------------------------------------------------##
##  La fonction GESCIS permet d'inserer l'action GOBJET avec le parametre CIS dans le menu               
##  L'action GOBJET appelle : 
##       - La fenètre OCIS qui appelle les écrans CIS0 
##       - Le traitement SUBCIS 
##------------------------------------------------------------------------------------------------##
## PRINCIPALES ETIQUETTES UTILISEES                                                               ## 
##------------------------------------------------------------------------------------------------##

## Gestion du masque CIS
#
Raz GPILOBJ

Call OBJET("CIS",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
# Infbox 'SUBCIS action=' + ACTION 

Case ACTION
    When "AVANT_OUVRE"  : Gosub AVANT_OUVRE
    When "OUVRE"        : Gosub OUVRE
    When "DEBUT"        : Gosub DEBUT     
    When "AFFMASK"      : Gosub AFFMASK
    When "FILTRE"       : Gosub FILTRE
    When "SETBOUT"      : Gosub SETBOUT
    When "RAZCRE"       : Gosub RAZCRE      
    When "RAZDUP"       : Gosub RAZDUP      
    When "VERIF_CRE"    : Gosub VERIF_CRE   
    When "VERIF_MOD"    : Gosub VERIF_MOD   
    When "LIENS"        : Gosub LIENS
    When "SEL_TABLE"    : Gosub SEL_TABLE
    When "SEL_LISTE"    : Gosub SEL_LISTE
    When "FIN"          : Gosub FIN
    When "FERME"        : Gosub FERME
When Default
Endcase
Return

####################################################################################################
## $AVANT_OUVRE: avant ouverture de l'écran                                                       ##   
####################################################################################################
$AVANT_OUVRE

Global Integer GIANDOR2 
Global Integer GIANDOR3 
Global Integer GIANDOR4 
Global Integer GIANDOR5 
Global Char    GCRUB1 
Global Char    GCRUB2
Global Char    GCRUB3
Global Char    GCRUB4
Global Char    GCRUB5 
Global Integer GIOPE1 
Global Integer GIOPE2 
Global Integer GIOPE3 
Global Integer GIOPE4 
Global Integer GIOPE5 
Global Char    GCVAL1 
Global Char    GCVAL2 
Global Char    GCVAL3 
Global Char    GCVAL4 
Global Char    GCVAL5 
Global Char    GSELCIG 


Global Integer GIREQVALIDE

GIREQVALIDE = G_OUI 


Return 
##########################################################################
## $OUVRE  :                                                            ##
##########################################################################
$OUVRE 

#Local Char   WREFSEL
Local Char   WSOCSRC 

# Sauvegarde du contexte - variables globales
If TUNNEL : Gosub SAUVE_GLOBAL_SV From GLOBIMM : Endif


If clalev([F:ATZ])  =0 : Local File ATABZON   [ATZ]           : Endif : # Dictionnaire des champs   
If clalev([F:ATY])  =0 : Local File ATYPE     [ATY]           : Endif : # Type de données    

# Entrée par tunnel
If TUNNEL & ( CLE2 <> "") 
  WSOCSRC = CLE2
  GSELCIG = CLE1
  [M:CG2]CPYSRC = WSOCSRC
Endif

CLE2 = ""


Return 
###############################
$DEBUT

If [M]NBTBL=0
 [M]TBL1 = [M]ATB
 [M]TBL2 = [M]ATB
 [M]TBL3 = [M]ATB
 [M]TBL4 = [M]ATB
 [M]TBL5 = [M]ATB
 Affzo TBL1, TBL2, TBL3, TBL4, TBL5
 Grizo TBL1, TBL2, TBL3, TBL4, TBL5
Endif

Return

#********************************************************************
$AFFMASK

If GSELCIG = ""
  Raz [M:CG2]
  [M:CG2]REFSELCIG = "" :          Affzo [M:CG2]REFSELCIG
 # [M:CG2]CPYSRC    = WSOCSRC :   Affzo [M:CG2]CPYSRC  : Diszo [M:CG2]CPYSRC 
  If dim(GCSOCSRC)>0
    If GCSOCSRC <> "" 
      [M:CG2]CPYSRC    = GCSOCSRC :   Affzo [M:CG2]CPYSRC  : Diszo [M:CG2]CPYSRC 
    Endif
  Endif
Endif

Affzo [M:CG2]

Return
#********************************************************************
$FILTRE


#If GSELCIG = ""
  If dim(GCSOCSRC)>0
   FILTSUP += "CPYSRC=GCSOCSRC"
  Endif
#Endif
Return : # FQ72442

####################################################################################################
## $RAZCRE : Réinit pour création                                                                 ##
####################################################################################################
$RAZCRE


If  (clalev([M:CG2])) 
  If dim(GCSOCSRC)>0
    If GCSOCSRC <> "" 
      [M:CG2]CPYSRC    = GCSOCSRC :   Affzo [M:CG2]CPYSRC  : Diszo [M:CG2]CPYSRC 
    Endif
  Endif
Endif

Gosub VAL_DEF

Return

####################################################################################################
## $RAZDUP : Réinit pour duplication                                                              ##
####################################################################################################
$RAZDUP
    Gosub VAL_DEF
Return

####################################################################################################
## $LIENS: après ouverture de l'écran                                                             ##   
####################################################################################################
$LIENS
Affzo [M:CG2] 

GIANDOR2 = [M:CG2]ANDOR2
GIANDOR3 = [M:CG2]ANDOR3
GIANDOR4 = [M:CG2]ANDOR4
GIANDOR5 = [M:CG2]ANDOR5
 
GCRUB1   = [M:CG2]FLD1
GCRUB2   = [M:CG2]FLD2
GCRUB3   = [M:CG2]FLD3
GCRUB4   = [M:CG2]FLD4
GCRUB5   = [M:CG2]FLD5

GIOPE1   = [M:CG2]OPE1
GIOPE2   = [M:CG2]OPE2
GIOPE3   = [M:CG2]OPE3
GIOPE4   = [M:CG2]OPE4
GIOPE5   = [M:CG2]OPE5

GCVAL1   = [M:CG2]VAL1
GCVAL2   = [M:CG2]VAL2
GCVAL3   = [M:CG2]VAL3
GCVAL4   = [M:CG2]VAL4
GCVAL5   = [M:CG2]VAL5


  WSOCSRC = [M:CG2]CPYSRC
  GSELCIG = [M:CG2]REFSELCIG
  
Return 
########################################
$SEL_LISTE
Case LISTE
 When "ASELTBL"
  Local Char XTAB(GLONATB) , XTEXTE(30)
  NBTEX = 0
  XTAB = [M]ATB : Gosub SELTAB
  For I=1 To [M]NBTBL
   XTAB = [M]TBTBL(I)
   Gosub SELTAB
  Next I
Endcase
Return

$SELTAB
NBTEX += 1
Read [ATB]CODFIC = XTAB
TEX(NBTEX) = XTAB
Call TEXTE([F:ATB]INTITFIC,XTEXTE) From OBJDIV
TEXTE(NBTEX) = XTAB-"["+[F:ATB]ABRFIC+"]"-XTEXTE
Return

########################################
$SEL_TABLE
Case TABLE
 When "ASELFLD"
  If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
  If clalev([F:ATX])=0 : Local File ATEXTE  [ATX] : Endif
  If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif
  If clalev([F:ACV])=0 : Local File ACTIV   [ACV] : Endif
  TIT = mess(109,124,1)-PARAM(1) : # Choix d'un champ TABLE
  START = "[F:ATZ]CODZONE"
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "[F:ATZ]CODZONE" : TIT(NBCOL) = mess(36,124,1)
  NBCOL += 1 : COL(NBCOL) = "[F:ATX]TEXTE"   : TIT(NBCOL) = mess(82,123,1)
  Link [ATZ]
& With [ATX]NUMERO=GLANGUE;[F:ATZ]NOCOURT
&    , [ATY]CODTYP=[F:ATZ]CODTYP 
&    , [ACV]CODACT=[F:ATZ]CODACT
& As [LNK]
& Where [F:ATZ]CODFIC=PARAM(1) & [F:ATZ]CODTYP<>"AXX" & [F:ATY]TYPTYP<9
&     & ([F:ATZ]CODACT="" | [F:ACV]FLACT=2)
  Default File [LNK]
Endcase
Return


####################################################################################################
## $CONTROLE_REQUETE: Requete                                                                     ##   
####################################################################################################
$CONTROLE_REQUETE
 

GIREQVALIDE = G_OUI 

# GIANDOR = 1: Et GIANDOR = 2: Ou 
# GCRUB1
# GIOPE1  
# GCVAL1
##------------------------------------------------------------------------------------------------##
## Controle de la 2ème ligne                                                                      ## 
##------------------------------------------------------------------------------------------------##
# 78 : La rubrique courante doit être identique à la rubrique précédente si les 2 rubriques sont liées par un 'Ou' 
If GIANDOR2  = 2 and  GCRUB2 <> "" and GCRUB2 <> GCRUB1
    GMESSAGE = mess(78,409,1)  : GERR=1  : mkstat=2
    GIREQVALIDE = G_NON 
    Return 
Endif 


# 79 : La rubrique courante doit être différente de la rubrique précédente si les 2 rubriques sont liées par un 'Et'  
If GIANDOR2 = 1 and  GCRUB2 <> "" and GCRUB2 = GCRUB1 and   (GIOPE1    = 2 or GIOPE2    = 2 )
    GMESSAGE = mess(79,409,1) - mess(88,409,1)  : GERR=1 : mkstat=2
    GIREQVALIDE = G_NON 
    Return 
Endif 


##------------------------------------------------------------------------------------------------##
## Controle de la 3ème ligne                                                                      ## 
##------------------------------------------------------------------------------------------------##
If GIANDOR3  = 2 and  GCRUB3 <> "" and GCRUB3 <> GCRUB2
    GMESSAGE = mess(78,409,1)  : GERR=1  : mkstat=2
    GIREQVALIDE = G_NON 
    Return 
Endif 

If GIANDOR3 = 1 and  GCRUB3 <> "" and GCRUB3 = GCRUB2 and   (GIOPE2    = 2 or GIOPE3    = 2 )
    GMESSAGE = mess(79,409,1)  : GERR=1 : mkstat=2
    GIREQVALIDE = G_NON  
    Return 
Endif 

##------------------------------------------------------------------------------------------------##
## Controle de la 4ème ligne                                                                      ## 
##------------------------------------------------------------------------------------------------##
If GIANDOR4  = 2 and  GCRUB4 <> "" and GCRUB4 <> GCRUB3
    GMESSAGE = mess(78,409,1)  : GERR=1  : mkstat=2
    GIREQVALIDE = G_NON 
    Return 
Endif 

If GIANDOR4 = 1 and  GCRUB4 <> "" and GCRUB4 = GCRUB3 and   (GIOPE3    = 2 or GIOPE4    = 2 ) 
    GMESSAGE = mess(79,409,1)  : GERR=1: mkstat=2
    GIREQVALIDE = G_NON 
    Return   
Endif 

##------------------------------------------------------------------------------------------------##
## Controle de la 5ème ligne                                                                      ## 
##------------------------------------------------------------------------------------------------##
If GIANDOR5  = 2 and  GCRUB5 <> "" and GCRUB5 <> GCRUB4
    GMESSAGE = mess(78,409,1)  : GERR=1 : mkstat=2
    GIREQVALIDE = G_NON 
    Return 
Endif 
If GIANDOR5 = 1 and  GCRUB5 <> "" and GCRUB5 = GCRUB4 and   (GIOPE4    = 2 or GIOPE5    = 2 )
    GMESSAGE = mess(79,409,1)  : GERR=1 : mkstat=2
    GIREQVALIDE = G_NON 
    Return 
Endif 


Return 
##########################################################################
## $CRE_REQUETE : Création de la requete                                ##
##########################################################################
$CRE_REQUETE

Local Char WCREQUETE (255)
Local Char WCOBJET 

Local Integer WIANDORPREC 
Local Integer WIANDORSUIV 
Local Integer WIANDOR 
Local Integer WIOPE 
Local Integer WIPAR 

Local Char WCOBJETLG   
Local Char WCRUB 
Local Char WCVAL 
Local Char WCVALI
Local Char WCANDOR 
Local Char WCOPE 
Local Char WCPAR1 
Local Char WCPAR2 

#WCREQUETE   = ""
WCPAR1      = ""
WCPAR2      = ""
WIANDORPREC = 0
WIANDORSUIV = 0
WIPAR       = G_NON
WCOBJETLG   = ""


WCOBJET  = ' [F:FAS]'


#---------- Transformation des opérateurs  --------------------------*  
#---------- Transformation des and-or      --------------------------*  
#---------- Alimentation requete           --------------------------*  

WCOBJETLG    = [M:CG2]TBL1
WIOPE        = [M:CG2]OPE1  
WIANDOR      = 0
WCRUB         = [M:CG2]FLD1

If  [M:CG2]VALI1  <> ""
  WCVAL        = [M:CG2]VALI1   
Else 
  WCVAL        = [M:CG2]VAL1
Endif

WIANDORSUIV  = [M:CG2]ANDOR2
Gosub RECH_OPE
Gosub RECH_ANDOR 
Gosub ALIM_REQUETE

WCOBJETLG   = [M:CG2]TBL2
WIOPE       = [M:CG2]OPE2  
WIANDOR     = [M:CG2]ANDOR2
WCRUB       = [M:CG2]FLD2 

If  [M:CG2]VALI2  <> ""
  WCVAL        = [M:CG2]VALI2 
Else 
  WCVAL        = [M:CG2]VAL2
Endif

WIANDORSUIV = [M:CG2]ANDOR3
Gosub RECH_OPE
Gosub RECH_ANDOR 
Gosub ALIM_REQUETE

WCOBJETLG   = [M:CG2]TBL3
WIOPE       = [M:CG2]OPE3  
WIANDOR     = [M:CG2]ANDOR3
WCRUB       = [M:CG2]FLD3 

If  [M:CG2]VALI3  <> ""
  WCVAL        = [M:CG2]VALI3 
Else 
  WCVAL        = [M:CG2]VAL3
Endif


WIANDORSUIV = [M:CG2]ANDOR4

Gosub RECH_OPE
Gosub RECH_ANDOR 
Gosub ALIM_REQUETE

WCOBJETLG   = [M:CG2]TBL4
WIOPE       = [M:CG2]OPE4  
WIANDOR     = [M:CG2]ANDOR4
WCRUB       = [M:CG2]FLD4 

If  [M:CG2]VALI4 <> ""
  WCVAL        = [M:CG2]VALI4 
Else 
  WCVAL        = [M:CG2]VAL4
Endif

WIANDORSUIV = [M:CG2]ANDOR5
Gosub RECH_OPE
Gosub RECH_ANDOR 
Gosub ALIM_REQUETE


WCOBJETLG   = [M:CG2]TBL5
WIOPE       = [M:CG2]OPE5  
WIANDOR     = [M:CG2]ANDOR5
WCRUB       = [M:CG2]FLD5 
If  [M:CG2]VALI5  <> ""
  WCVAL        = [M:CG2]VALI5
Else 
  WCVAL        = [M:CG2]VAL5
Endif

WIANDORSUIV = 3

Gosub RECH_OPE
Gosub RECH_ANDOR 
Gosub ALIM_REQUETE


[M:CG2]REQUETE = WCREQUETE
Affzo [CG2]REQUETE 

Return 

#---------- Recherche AND/OR  --------------------------*  
$RECH_ANDOR

WCANDOR = ""


#-- Parentheses ( si on traite un 'et' qui sera suivi d'un 'ou' --------------------------* 
If (WIANDORSUIV = 2  and WIANDORSUIV <> WIANDOR ) and [M:CG2]FLD2 < > ""
   WCPAR1    = '('
   WIPAR       = G_OUI
Else 
   WCPAR1    = ''
Endif 


#-- Parentheses ( si on traite un 'et' qui a été précédé d'un 'ou' -----------------------*  
If WIANDORSUIV = 1  and WIPAR       = G_OUI
   WCPAR2    = ')'
   WIPAR       = G_NON
Else 
   WCPAR2    = ''
Endif 

If WIANDOR = 1 
  WCANDOR = " and "
Elsif WIANDOR = 2 
  WCANDOR = " or "
Endif

WIANDORPREC = WIANDOR 

#*-- Parentheses fermante s'il y a eu une ) et qu'on est en fin de requête  -----------------------*  
If WIANDORSUIV = 3  and WIPAR       = G_OUI
   WCPAR2    = ')'
Endif 

Return 
#---------- Recherche opérateur  --------------------------*  
$RECH_OPE

WCOPE = ""

If WIOPE = 2 
  WCOPE = "="
Elsif WIOPE = 3 
  WCOPE = "<>"
Elsif WIOPE = 4 
  WCOPE = ">"
Elsif WIOPE = 5 
  WCOPE = ">="
Elsif WIOPE = 6 
  WCOPE = "<"
Elsif WIOPE = 7 
  WCOPE = "<= "
Endif

Return 
#---------- Alimentation de la requete   --------------------------*  
#-- TYPTYP=7 -> alpha, TYPTYP=8 -> date, TYPTYP=autre -> Num ------*  
$ALIM_REQUETE
Local Char WCQUOTE 
Local Char EXPR 
WCQUOTE = "'"

If WCRUB <> "" 
  Read [ATZ]CODZONE = WCOBJETLG ; WCRUB 
  # il faut aussi traiter les champs à plusieurs dimensions comme les sections ana CCE(n)
    Read [ATY]CODTYP = [F:ATZ]CODTYP
    If !fstat 
      If  [F:ATY]TYPTYP = 7 
        WCQUOTE = "'"
        WCREQUETE = WCREQUETE  + WCANDOR + WCPAR1  + WCOBJET  + WCRUB - WCOPE - WCQUOTE  + WCVAL + WCQUOTE  + WCPAR2  
      Elsif   [F:ATY]TYPTYP = 8 
        EXPR += '['+format$(GFMD,gdat$(WCVAL))+']'
        WCREQUETE = WCREQUETE  + WCANDOR + WCPAR1  + WCOBJET  + WCRUB - WCOPE - EXPR  -  WCPAR2  
      Else 
        WCQUOTE = ""
        WCREQUETE = WCREQUETE  + WCANDOR + WCPAR1  + WCOBJET  + WCRUB - WCOPE - WCQUOTE  + WCVAL + WCQUOTE  + WCPAR2  
      Endif 
    Endif 
  #Endif 
Endif 


#*-- Parentheses fermante s'il y a eu une ) et qu'on est en fin de requête  -----------------------*  
#-- Parentheses ( si on traite un 'et' qui a été précédé d'un 'ou' -----------------------*  
If WIANDORSUIV = 3  and WIPAR       = G_OUI
  WCREQUETE = WCREQUETE  +  WCPAR2
Endif    

Return 
####################################################################################################
## $KILL_GLOBAL : KIll de toutes les globales                                                     ##                   
####################################################################################################
KILL_GLOBAL

If dim(GIANDOR2)         >0      : Kill GIANDOR2 : Endif     
If dim(GIANDOR3)         >0      : Kill GIANDOR3 : Endif     
If dim(GIANDOR4)         >0      : Kill GIANDOR4 : Endif     
If dim(GIANDOR5)         >0      : Kill GIANDOR5 : Endif     

If dim(GCRUB1)           >0      : Kill GCRUB1: Endif     
If dim(GCRUB2)           >0      : Kill GCRUB2: Endif     
If dim(GCRUB3)           >0      : Kill GCRUB3: Endif     
If dim(GCRUB4)           >0      : Kill GCRUB4: Endif     
If dim(GCRUB5)           >0      : Kill GCRUB5: Endif     

If dim(GIOPE1)           >0      : Kill GIOPE1: Endif     
If dim(GIOPE2)           >0      : Kill GIOPE2: Endif     
If dim(GIOPE3)           >0      : Kill GIOPE3: Endif     
If dim(GIOPE4)           >0      : Kill GIOPE4: Endif     
If dim(GIOPE5)           >0      : Kill GIOPE5: Endif     

If dim(GCVAL1)           >0      : Kill GCVAL1: Endif     
If dim(GCVAL2)           >0      : Kill GCVAL2: Endif     
If dim(GCVAL3)           >0      : Kill GCVAL3: Endif     
If dim(GCVAL4)           >0      : Kill GCVAL4: Endif     
If dim(GCVAL5)           >0      : Kill GCVAL5: Endif     


  
Return 

####################################################################################################
## $FIN :                                                                                         ##
####################################################################################################
$FIN

Gosub KILL_GLOBAL

FIN = 1 : GOK = 0

Return
####################################################################################################
## $FERME:                                                                                         ##
####################################################################################################
$FERME

  #----------------------------------------------------------------------# 
  # Si on est venu par tunnel il faut restaurer les variables globales   # 
  #----------------------------------------------------------------------# 
  If TUNNEL 
    Gosub RESTAURE_GLOBAL_SV From GLOBIMM 
  Endif

Return
####################################################################################################
## $VAL_DEF : Maj de valeur par défaut                                                            ## 
####################################################################################################

$VAL_DEF


If (clalev([M:CG2])) 
  [M:CG2]TBL1="FXDASSETS"
  [M:CG2]TBL2="FXDASSETS"
  [M:CG2]TBL3="FXDASSETS"
  [M:CG2]TBL4="FXDASSETS"
  [M:CG2]TBL5="FXDASSETS"


  [M:CG2]ANDOR2  = 1 
  [M:CG2]ANDOR3  = 1 
  [M:CG2]ANDOR4  = 1 
  [M:CG2]ANDOR5  = 1 

  [M:CG2]OPE1    = 2 
  [M:CG2]OPE2    = 2 
  [M:CG2]OPE3    = 2 
  [M:CG2]OPE4    = 2 
  [M:CG2]OPE5    = 2 

  Affzo [M:CG2] 

Endif
                                 
Return

####################################################################################################
## $VERIF_CRE :                                                                                   ## 
####################################################################################################

$VERIF_CRE

Gosub VERIF 

Return 

####################################################################################################
## $VERIF_MOD :                                                                                   ## 
####################################################################################################

$VERIF_MOD

Gosub VERIF 

Return 
   
####################################################################################################
## $VERIF     :                                                                                   ## 
####################################################################################################

$VERIF
Local Integer LOK 
 


If [M:CG2]REFSELCIG = ""   
  GMESSAGE = mess(154,410,1) : GERR=1 
  mkstat=2
  OK = 0 
  FIN = 1
  GOK = 0
  Return 
Endif 

If [M:CG2]SELCIGDES = ""   
  GMESSAGE = mess(156,410,1) : GERR=1 
  mkstat=2
  OK = 0 
  FIN = 1
  GOK = 0
  Return 
Endif 

If [M:CG2]CPYSRC = ""   
  GMESSAGE = mess(155,410,1) : GERR=1 
  mkstat=2
  OK = 0 
  FIN = 1
  GOK = 0
  Return 
Endif 


If [M:CG2]FLD1 = ""   
  Call OUINON(mess(157,410,1) -  [M:CG2]CPYSRC + mess(158,410,1) , LOK) From GESECRAN
  If ( LOK <> G_OUI) 
    mkstat=2
    OK = 0 
    FIN = 1
    GOK = 0
    Return 
  Endif 
Endif 

GSELCIG = [M:CG2]REFSELCIG 

Gosub CONTROLE_REQUETE

If GIREQVALIDE = G_NON 
  GMESSAGE = mess(89,409,1) : GERR=1 
  mkstat=2
  OK = 0 
  FIN = 1
  GOK = 0
  Return 
Endif


Return 

##########################################################################
## $SETBOUT   :                                                         ##
##########################################################################
$SETBOUT 



  [M:CG2]TBL1    = "FXDASSETS"
  [M:CG2]TBL2    = "FXDASSETS"
  [M:CG2]TBL3    = "FXDASSETS"
  [M:CG2]TBL4    = "FXDASSETS"
  [M:CG2]TBL5    = "FXDASSETS"

Affzo [M:CG2]


Return 
##########################################################################
##########################################################################
## Gestion de la sélection étendue 
##########################################################################
##########################################################################
########################################
Subprog AS_TBL1(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 1
Goto AS_TBL
##-----------------------##
Subprog AS_TBL2(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 2
Goto AS_TBL
##-----------------------##
Subprog AS_TBL3(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 3
Goto AS_TBL
##-----------------------##
Subprog AS_TBL4(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 4
Goto AS_TBL
##-----------------------##
Subprog AS_TBL5(VALEUR)
Variable Char    VALEUR()
Local Integer I
I = 5
Goto AS_TBL
##-----------------------##
$AS_TBL
If I>1 & (evalue("[M]TBL"+num$(I-1))="" or evalue("[M]FLD"+num$(I-1))="")
 mkstat = 1 : End
Endif
If [M]NBTBL=0
 VALEUR = [M]ATB
 mkstat = 2  : End
Elsif VALEUR = ""
 VALEUR = [M]ATB
Endif
End

##########################################################################
## Gestion des bouton ANDOR : et/ou                                     ##
##########################################################################

##----------------------------------------------------------------------##
##---- AS_XXX : Avant saisie  ------------------------------------------##
##----------------------------------------------------------------------##
Subprog AS_ANDOR2(VALEUR)
Variable Integer VALEUR
If [M]FLD1="" : mkstat = 1 : End : Endif
GIANDOR2 = VALEUR 
End
##-----------------------##
Subprog AS_ANDOR3(VALEUR)
Variable Integer VALEUR
If [M]FLD2="" :  mkstat = 1 : End : Endif
GIANDOR3 = VALEUR
End
##-----------------------##
Subprog AS_ANDOR4(VALEUR)
Variable Integer VALEUR
If [M]FLD3="" : :mkstat = 1 : End : Endif
GIANDOR4 = VALEUR
End
##-----------------------##
Subprog AS_ANDOR5(VALEUR)
Variable Integer VALEUR
If [M]FLD4="" : mkstat = 1 :  End : Endif
GIANDOR5 = VALEUR
End

