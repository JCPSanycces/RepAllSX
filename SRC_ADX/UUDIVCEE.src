#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################################
## Mise à jour de la tables diverse n°15 et de la table ITMCUSNOM
## - Enlèvement de la dépendance de la table diverse n°15 (Régimes CEE) vers la 909
## - Màj des intitulés traduisibles de la table des Nomenclatures CEE 
##############################################################################

Call PATCH(nomap)

End

Subprog PATCH(DOSSIER)
Value Char DOSSIER

Call ECR_TRACE("UUDIVCEE - Mise à jour Tables ADI 15 et ITMCUSNOM",0) From GESECRAN
Call EXE_UUDIVCEE(DOSSIER)

End

Subprog EXE_UUDIVCEE(DOSSIER)
Value Char DOSSIER
Local Char WKLIBELLE(250)
#--- Pour la lecture de la langue du dossier
#FQ 52172
#Local File =DOSSIER+".ADOSSIER" [WADS]
#Read [F:WADS]DOSSIER=[L]DOSSIER
#If fstat : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS]DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

#---- Enlèvement de la dépendance de la table diverse n°15 (Régimes CEE) vers la 909 
Local File =DOSSIER+".ATABTAB"    [ADV]
Call ECR_TRACE("Mise à jour dépendance Table diverse n°15 : Début",0) From GESECRAN
Trbegin  [ADV]

Update [ADV] Where NUMTAB=15 With DEPNUM=0
If !fstat
 Commit
Else
 Call ECR_TRACE("Mise à jour dépendance Table diverse n°15 : Erreur",1) From GESECRAN
 Rollback
Endif

Close Local File [ADV]
Call ECR_TRACE("Mise à jour dépendance Table diverse n°15 : Fin",0) From GESECRAN
#---- fin MAJ Table diverse n°15

#---- Màj des intitulés traduisibles de la table des Nomenclatures CEE
If filinfo(filpath("FIL","ATEXTRA","fde",DOSSIER),0)>0

  Local File =DOSSIER+".ATEXTRA"   [AXX]    
  
  If filinfo(filpath("FIL","ITMCUSNOM","fde",DOSSIER),0)>0
  
    Local File =DOSSIER+".ITMCUSNOM"   [INO] 
    Call ECR_TRACE("Mise à jour ATEXTRA pour la Nomenclature CEE : Début",0) From GESECRAN
    #--- Sauvegarde puis récupération de la langue du dossier à migrer -----#
    Local Char SAV_GLANGUE(GLONLAN)
    SAV_GLANGUE=GLANGUE
    GLANGUE=[F:ADS]LANDEF         

    For [INO]
      Raz WKLIBELLE
      Call LECTEXTRA(WKLIBELLE,"ITMCUSNOM","DESAXX",[F:INO]ITMNOM,"") From ATEXTRA
      If WKLIBELLE=""
        #---La transaction est gérée dans le ATEXTRA
        Call MAJTEXTRA([F:INO]ITMCUSDES,"ITMCUSNOM","DESAXX",[F:INO]ITMNOM,"") From ATEXTRA
        If GOK<1
          Call ECR_TRACE("File ATEXTRA"-"ITMCUSNOM DESAXX"-[F:INO]ITMNOM+
&                    ",Error ="-num$(fstat),1) From GESECRAN
          GOK=1 : Break
        Endif
      Endif
    Next
    #--- Restitution du code langue de connexion -----#
    GLANGUE=SAV_GLANGUE 
       
    Close Local File [INO]
    Call ECR_TRACE("Mise à jour ATEXTRA pour la Nomenclature CEE : Fin",0) From GESECRAN
  Endif
  
  Close Local File [AXX]
Endif
#---- fin MAJ Table ITMCUSNOM

End
