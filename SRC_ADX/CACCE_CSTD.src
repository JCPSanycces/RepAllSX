#<AdxTL>@(#)5.0.0.0 $Revision$
# Classe CACCE
##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "ADELETE_AFTER"           : Gosub ADELETE_AFTER # Issue X3-3500 - 2018-07-18 by FGR
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

##########################################################################################################
$ADELETE_AFTER
  # Issue X3-3500 - 2018-07-18 by FGR
  Local File GCCEPYM    [CYM]
  Local File GCCEGRUPYM [CRY]
  Local File GCCEPYMPRT [CYP]
  Local File GCCEPYMLIK [CYK]
  # -------------------------
  Delete [CYP] Where [F:CYP]DIE = this.DIE and [F:CYP]CCE = this.CCE
  If fstat <> [V]CST_AOK Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("", func AFNC.MES2(mess(1204,196,1), this.DIE, this.CCE), [V]CST_AERROR))
  Endif
  For [CYM]CYM1 Where DIE = this.DIE
    Delete [CYK] Where [F:CYK]PYM = [F:CYM]PYM and [F:CYK]CCE = this.CCE
    If fstat <> [V]CST_AOK Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("", func AFNC.MES2(mess(1204,196,1), this.DIE, this.CCE), [V]CST_AERROR))
    Endif
    Delete [CRY] Where [F:CRY]PYM = [F:CYM]PYM and [F:CRY]CCE = this.CCE
    If fstat <> [V]CST_AOK Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.ASETERROR("", func AFNC.MES2(mess(1204,196,1), this.DIE, this.CCE), [V]CST_AERROR))
    Endif
  Next
Return

