#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMGANTT0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone EVRLEV
mkstat = 0
zoncou = "EVRLEV"
indice = 0
IMPENT = [M]EVRLEV
If varinit([M]EVRLEV,indice)=0
 IMPENT = 1
Endif
If varmode([M]EVRLEV,indice)=0
 [M]EVRLEV(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "EVRLEV" : Gosub ACTION From =IMPTRT
  IMPENT = [M]EVRLEV(indice)
 Endif
Endif
[M]EVRLEV = IMPENT

## Zone MULPRJ
mkstat = 0
zoncou = "MULPRJ"
indice = 0
IMPENT = [M]MULPRJ
If varinit([M]MULPRJ,indice)=0
 IMPENT = 1
Endif
If varmode([M]MULPRJ,indice)=0
 [M]MULPRJ(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "MULPRJ" : Gosub ACTION From =IMPTRT
  IMPENT = [M]MULPRJ(indice)
 Endif
Endif
[M]MULPRJ = IMPENT

## Zone DSYITMRET
mkstat = 0
zoncou = "DSYITMRET"
indice = 0
IMPENT = [M]DSYITMRET
If varinit([M]DSYITMRET,indice)=0
 IMPENT = 1
Endif
If varmode([M]DSYITMRET,indice)=0
 [M]DSYITMRET(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DSYITMRET" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DSYITMRET(indice)
 Endif
Endif
[M]DSYITMRET = IMPENT

## Zone DSYOPE
mkstat = 0
zoncou = "DSYOPE"
indice = 0
IMPENT = [M]DSYOPE
If varinit([M]DSYOPE,indice)=0
 IMPENT = 1
Endif
If varmode([M]DSYOPE,indice)=0
 [M]DSYOPE(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DSYOPE" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DSYOPE(indice)
 Endif
Endif
[M]DSYOPE = IMPENT

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMGANTT0"
Return

