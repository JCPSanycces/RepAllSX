#<AdxTL>@(#)9.0.0.0 $Revision$
End

#**
#* Funprog HANDLER_POST()
#* Create a working copy
#*!
Funprog HANDLER_POST(ACTX,ASWK,ARCV,PSYR,ASND,JSON)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Variable Instance JSON Using C_ASYRJSO

Local Integer ASTATUS : ASTATUS=[V]CST_AOK
Local Integer COUNT

ASTATUS = func ASYRDELSYS.CREATE_WORKING_COPY(ACTX,ASWK,ARCV,PSYR.WRKUID,COUNT,PSYR.CODREP,PSYR.SELREP,"CREATE")
If ASTATUS = [V]CST_AOK
 ASTATUS = func PROGRAM_CREATE(ACTX,ASWK(COUNT),PSYR,ARCV,JSON,ASND)
Endif
End ASTATUS

#**
#* Funprog HANDLER_GET()
#* Create an empty entity
#*!
Funprog HANDLER_GET(ACTX,ASWK,ARCV,PSYR,ASND)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND

Local Integer ASTATUS : ASTATUS=[V]CST_AOK
Local Integer COUNT

Local  Instance JSON Using C_ASYRJSO

PSYR.WRKUID = NullUuid

ASTATUS = func ASYRDELSYS.CREATE_WORKING_COPY(ACTX,ASWK,ARCV,PSYR.WRKUID,COUNT,PSYR.CODREP,PSYR.SELREP,"CREATE")
If ASTATUS = [V]CST_AOK
 ASTATUS = func PROGRAM_CREATE(ACTX,ASWK(COUNT),PSYR,ARCV,JSON,ASND)
 If ASTATUS = [V]CST_AOK
  ASTATUS = func ASYRDELSYS.DELETE_WORKING_COPY(ACTX,ASWK,PSYR.WRKUID)
 Endif
Endif
End ASTATUS

#------------------------------------------------------------#
# Request create management (POST)
#------------------------------------------------------------#

Funprog PROGRAM_CREATE(ACTX,ASWK,PSYR,ARCV,NODE,ASND)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK Using C_ASYRWRK
Variable Instance PSYR Using C_ASYR
Variable Instance ARCV Using C_ASYRRCV
Variable Instance NODE Using C_ASYRJSO
Variable Instance ASND Using C_ASYRSND

Local Integer I , J , K , NUMLIN , ASTATUS , WITHDATA , SUBCLA ,ASTAERR , ASTACRUD
Local Uuident UIDINS , UID
Local Char    INSFAT(250)
Local Char    REPNAM(20) , GRPINS(20)
Local Char    PRGREP(30) , PRGEXE(30)
Local Char    WPRO(250) , WVAL(255)

Raz ASND.DATA

FreeInstance [ULN]

Local Instance REP      Using C_AREPENT
Local Instance WREP     Using ="R_"+ASWK.REPRES
Local Instance UPD(1..) Using C_ADELTA    : # Delta values of properties initialized
Local Instance BUT(1..) Using C_ADELTABUT : # Delta button
Local Instance ULN(1..) Using C_ADELTALIN : # Uncommitted lines of collection by the serveur

#--------------------------------------------------#
# Load json presentation (metadata & data)
#--------------------------------------------------#

PRGREP = func SUBASW.PREFIX_TRT+ASWK.REPRES : # WMREP

REPNAM = ASWK.REPNAM

Call DESCRIPTION_REPRESENTATION(REP,REPNAM) From =PRGREP

ASWK.METCLA = REP

# Create instance representation

WREP = evalue ("Newinstance ["+REPNAM+"] , R_"+REP.REP+'(ACTX,UIDINS,NUMLIN,null,"")')
ASWK.DATCLA = WREP

ASTATUS = fmet WREP.AGETWRIGHTC
ASTAERR = fmet WREP._AERROR(ACTX,2)
If ASTATUS>=[V]CST_AERROR :  End ASTATUS : Endif

# uuid instance

CHAINE = "WREP."+REP.ICL+".AUUID"
If evalue("dim("+CHAINE+")")>0
 UID = evalue(CHAINE)
Else
 UID = NullUuid
Endif

# Load representation's parameters

Call SET_REP_PARAMETERS(WREP,ARCV) From ASYRMAIN

# Deltas returned by Syracuse (in the case of a broken working copy)

If NODE<>null
 ASTATUS = func ASYRDEL.PARSEDELTA(ACTX,NODE,UPD)
 If maxtab(UPD)>0
  Gosub SEARCH_UUID_MASTER
  If ASTAERR=[V]CST_AERROR
   End [V]CST_AERROR
  Elsif UID=NullUuid
   UID = getUuid
   Gosub SET_UUID
  Else
   Assign "WREP."+REP.ICL+".AUUID" With UID
  Endif
  WITHDATA = 1
  WREP.setAccessorEnabled = 1
  Call SET_SYSSNAPSHOT(WREP,1) From ASYRDELSYS
  Call SET_REPRESENTATION(REP,WREP,UPD,ULN) From ASYRDELCLI
  FreeInstance [UPD]
  Local Instance  UPD(1..) Using C_ADELTA
  Call LOAD_DELTA(WREP,REP,UPD,ULN) From ASYRDELSRV
  ASTAERR = fmet WREP._AERROR(ACTX,2)
  Call SET_SYSSNAPSHOT(WREP,0) From ASYRDELSYS
  WREP.setAccessorEnabled = 0
 Endif
Endif

If !WITHDATA

 # Enable snapshots before init

 Call SET_SYSSNAPSHOT(WREP,1) From ASYRDELSYS

 # Init
 ASTACRUD = fmet WREP.AINIT
 ASTAERR = fmet WREP._AERROR(ACTX,2)

 # Set value parameters entry

 For I=1 To maxtab(WREP._APARAMURL)
  If WREP._APARAMURL(I)<>null & WREP._APARAMURL(I).PAR<>"" & WREP._APARAMURL(I).VPR<>"{"+WREP._APARAMURL(I).PAR+"}"
   K = find(WREP._APARAMURL(I).PAR,REP.PRO(1..maxtab(REP.PRO)).PRO)
   If dim(REP.PRO(K).ENT)>0 & REP.PRO(K).ENT=2
    WPRO = "WREP."+REP.PRO(K).PTH
    WVAL = WREP._APARAMURL(I).VPR
    If evalue("dim("+WPRO+")")>0
     If GTRASYR : Call TRACE("Parameter cod="+WREP._APARAMURL(I).PAR-"value="+WREP._APARAMURL(I).VPR) From ASYRCOM : Endif
     Case REP.PRO(K).TYP
      When 1     : Assign WPRO With func ASYRSUB.BOOLEAN_TO_ADX(WVAL)
      When 2,3,4 : Assign WPRO With val(WVAL)
      When 5     : Assign WPRO With func ASYRSUB.DATE_TO_ADX(WVAL)
      When 6     : Assign WPRO With func ASYRSUB.TIME_TO_ADX(WVAL)
      When 7     : Assign WPRO With WVAL
      When 8,9   : # Clob , blob
      When 10    : Assign WPRO With val(WVAL)
      When 11    : Assign WPRO With func ASYRSUB.DATETIME_TO_ADX(WVAL)
      When 25    : # Atexte
      When 26    : # Atextra
     Endcase
    Endif
   Endif
  Endif
 Next I

 # Load delta classe with sysnapshot init

 Call LOAD_DELTA(WREP,REP,UPD,ULN) From ASYRDELSRV

Endif

#------------------------------#
# Load buttons from prototype
#------------------------------#

Call LOAD_BUTTON(UPD,REP) From ASYRDELSYS

#--------------------------------------------#
# Enable buttons & choices of buttons
#--------------------------------------------#

# Where is the link ?
#--------------------------
# 1 Property
# 2 Line de collection
# 3 Collection
# 4 Page
# 5 Fiche/Enregistrement

# Links Type
#----------------------------#
# 0 Standard (save, abort)
# 1 Link
# 2 Method
# 3 Operation
# 4 Link X3

For I=1 To maxtab(REP.LNK)
 # Method or $links with action=save,abort
 If REP.LNK(I)<>null & find(REP.LNK(I).AFF,4,5) & REP.LNK(I).EDT=2
& & (REP.LNK(I).TYP=2 or (REP.LNK(I).TYP=1 & find(REP.LNK(I).CMP,17,18) & ASTACRUD<[V]CST_AERROR))
& or(find(REP.LNK(I).CMP,18)>0 & ASTACRUD>=[V]CST_AERROR)
  CHAINE = ""
  # isHidden/false
  Call MAJ_ATTRIBUT(UPD,3,0,NullUuid,UID,0,CHAINE,REP.LNK(I).COD,func ASYRSUB.CODATT("H"),func ASYRSUB.BOOLEAN_TO_SYR(1))
& From ASYRDELSYS
  # isDisable/false
  Call MAJ_ATTRIBUT(UPD,3,0,NullUuid,UID,0,CHAINE,REP.LNK(I).COD,func ASYRSUB.CODATT("G"),func ASYRSUB.BOOLEAN_TO_SYR(1))
& From ASYRDELSYS
  For J=1 To maxtab(REP.LNK(I).LNK)
   If REP.LNK(I).LNK(J)<>null
    # isHidden/false
    Call MAJ_ATTRIBUTLNK(UPD,3,0,NullUuid,UID,0,"",REP.LNK(I).COD,REP.LNK(I).LNK(J).COD,func ASYRSUB.CODATT("H")
&   ,func ASYRSUB.BOOLEAN_TO_SYR(1)) From ASYRDELSYS
   Endif
  Next J
 Endif
Next I

#--------------------------------------#
# Disable snapshots
#--------------------------------------#

Call SET_SYSSNAPSHOT(WREP,0) From ASYRDELSYS

#------------------------------------------#
# JSON generation
#------------------------------------------#

ASWK.NUMWRK += 1
Call DETAIL_JSON(REP,WREP,ASWK,PSYR,UPD,ASND.DATA) From ASYRDATDEL

#----------------------------------------------------------#
# Send delta init properties of representation
#----------------------------------------------------------#

ASND.URL      = PSYR.PREFIX+'/'+PSYR.URLUPD+"('"+num$(ASWK.TRCKID)+"')"+PSYR.URLREP+ASWK.REPRES+".$edit"
ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+"."+ASWK.REPRES+".$edit"

End fmet ACTX.AGETMAXERROR("")

#--------------------------------------------------------------------------#
# Miscellaneous programs
#--------------------------------------------------------------------------#

$SET_UUID
Assign "WREP."+REP.ICL+".AUUID" With UID
Call MAJ_FIELD(UPD,0,0,NullUuid,UID,-1,"","",0,CLOB) From  ASYRDELSYS
For I=1 To maxtab(UPD)
 If UPD(I)<>null & UPD(I).UID=NullUuid
  UPD(I).UID = UID
 Endif
Next I
Return

#------------------------------#
$SEARCH_UUID_MASTER
Raz ASTAERR
UID = NullUuid
For I=1 To maxtab(UPD)
 If UPD(I)<>null & UPD(I).UIDPAR=NullUuid & UPD(I).UID<>NullUuid & (len(UPD(I).COL) =0)
  UID = UPD(I).UID
  Break
 Endif
Next I
If maxtab(UPD)=0
 ASTAERR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_NOT_FOUND,mess(20,149,1)) :# "Data JSON empty"
Elsif UID=NullUuid
 SUBCLA = 0
 For I=1 To maxtab(REP.COL)
  If REP.COL(I)<>null & instr(1,REP.COL(I).GRI,".")
   SUBCLA = 1 : Break
  Endif
 Next I
 If SUBCLA
  ASTAERR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_NOT_FOUND,mess(20,149,1)) :# "Data JSON empty"
 Endif
Endif
Return
