#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe PJMTSKOPE
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"                       : Gosub AREAD_AFTER                     From PJMTSKOPE_CSTD_EVENTS
        When "ACONTROL"                          : Gosub ACONTROL                        From PJMTSKOPE_CSTD_EVENTS
        When "AINSERT_CONTROL_BEFORE"            : Gosub AINSERT_CONTROL_BEFORE          From PJMTSKOPE_CSTD_EVENTS
        When "AUPDATE_CONTROL_BEFORE"            : Gosub AUPDATE_CONTROL_BEFORE          From PJMTSKOPE_CSTD_EVENTS
        When "AUPDATE_CONTROL_AFTER"             : Gosub AUPDATE_CONTROL_AFTER           From PJMTSKOPE_CSTD_EVENTS
        When "ADELETE_CONTROL_BEFORE"            : Gosub ADELETE_CONTROL_BEFORE          From PJMTSKOPE_CSTD_EVENTS
      Endcase
    When "RAFFT"
      Case [L]AEVENT
        When "ACONTROL"                          : Gosub RAFFT_ACONTROL                  From PJMTSKOPE_CSTD_EVENTS
        When "ADDLINE_BEFORE"                    : Gosub RAFFT_ADDLINE_BEFORE            From PJMTSKOPE_CSTD_EVENTS
        When "ADELLINE_BEFORE"                   : Gosub RAFFT_ADELLINE_BEFORE           From PJMTSKOPE_CSTD_EVENTS
        When "ADDLINE_AFTER"                     : Gosub RAFFT_ADDLINE_AFTER             From PJMTSKOPE_CSTD_EVENTS
        When "AINSERT_CONTROL_BEFORE"            : Gosub RAFFT_AINSERT_CONTROL_BEFORE    From PJMTSKOPE_CSTD_EVENTS
        When "AUPDATE_CONTROL_BEFORE"            : Gosub RAFFT_AUPDATE_CONTROL_BEFORE    From PJMTSKOPE_CSTD_EVENTS
     Endcase
   When "OPLNK"
      Case [L]AEVENT
        When "ACONTROL"                          : Gosub OPLNK_ACONTROL                  From PJMTSKOPE_CSTD_EVENTS
        When "AUPDATE_CONTROL_BEFORE"            : Gosub OPLNK_AUPDATE_CONTROL_BEFORE    From PJMTSKOPE_CSTD_EVENTS
        When "ADDLINE_BEFORE"                    : Gosub OPLNK_ADDLINE_BEFORE            From PJMTSKOPE_CSTD_EVENTS
        When "ADELLINE_BEFORE"                   : Gosub OPLNK_ADELLINE_BEFORE           From PJMTSKOPE_CSTD_EVENTS
      Endcase
    When Default
  Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "SETERROR"                              : Gosub SETERROR                        From PJMTSKOPE_CSTD_METHODS
    When "GET_SUMMED_RATE"                       : Gosub GET_SUMMED_RATE                 From PJMTSKOPE_CSTD_METHODS
    When "GET_RESOURCE_RATE"                     : Gosub GET_RESOURCE_RATE               From PJMTSKOPE_CSTD_METHODS
    When "GET_RES_RATE_DIM"                      : Gosub GET_RES_RATE_DIM                From PJMTSKOPE_CSTD_METHODS
    When "GET_RES_RATE_CSTYP"                    : Gosub GET_RES_RATE_CSTYP              From PJMTSKOPE_CSTD_METHODS
    When "GET_OPEUOM"                            : Gosub GET_OPEUOM                      From PJMTSKOPE_CSTD_METHODS
    When "GET_OPEUOM_RES1"                       : Gosub GET_OPEUOM_RES1                 From PJMTSKOPE_CSTD_METHODS
    When "GET_OPEUOM_TASK"                       : Gosub GET_OPEUOM_TASK                 From PJMTSKOPE_CSTD_METHODS
    When "GET_OPEUOM_DEFAULT"                    : Gosub GET_OPEUOM_DEFAULT              From PJMTSKOPE_CSTD_METHODS
    When "GET_STDOPENUM_DES"                     : Gosub GET_STDOPENUM_DES               From PJMTSKOPE_CSTD_METHODS
    When "COPY"                                  : Gosub COPY                            From PJMTSKOPE_CSTD_METHODS
    When "COPY_LOAD_PROPERTIES"                  : Gosub COPY_LOAD_PROPERTIES            From PJMTSKOPE_CSTD_METHODS
    When "PROGRESS"                              : Gosub PROGRESS                        From PJMTSKOPE_CSTD_METHODS
    When "COMPUTE_OPECST_OPECTS2"                : Gosub COMPUTE_OPECST_OPECTS2          From PJMTSKOPE_CSTD_METHODS
    When "COMPUTE_EXTAMT"                        : Gosub COMPUTE_EXTAMT                  From PJMTSKOPE_CSTD_METHODS
    #
    When "RAFFT_INIT_TECH_PROP"                  : Gosub RAFFT_INIT_TECH_PROP            From PJMTSKOPE_CSTD_METHODS
    When "RAFFT_COUNT"                           : Gosub RAFFT_COUNT                     From PJMTSKOPE_CSTD_METHODS
    When "RAFFT_GET_INDEX"                       : Gosub RAFFT_GET_INDEX                 From PJMTSKOPE_CSTD_METHODS
    When "RAFFT_SUM_POASTDQTY"                   : Gosub RAFFT_SUM_POASTDQTY             From PJMTSKOPE_CSTD_METHODS
    When "RAFFT_SUM_POACSMQTY"                   : Gosub RAFFT_SUM_POACSMQTY             From PJMTSKOPE_CSTD_METHODS
    When "RAFFT_SUM_POARMNQTY"                   : Gosub RAFFT_SUM_POARMNQTY             From PJMTSKOPE_CSTD_METHODS
    When "RAFFT_REPEAT_OPESTR"                   : Gosub RAFFT_REPEAT_OPESTR             From PJMTSKOPE_CSTD_METHODS
    When "RAFFT_REPEAT_OPEEND"                   : Gosub RAFFT_REPEAT_OPEEND             From PJMTSKOPE_CSTD_METHODS
    #
    When "OPLNK_COUNT"                           : Gosub OPLNK_COUNT                     From PJMTSKOPE_CSTD_METHODS
    When "OPLNK_USED"                            : Gosub OPLNK_USED                      From PJMTSKOPE_CSTD_METHODS
  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
  Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "KEYCONCAT"                   : Gosub KEYCONCAT                       From PJMTSKOPE_CSTD_PROPERTIES
    When "OPEUOM"                      : Gosub OPEUOM                          From PJMTSKOPE_CSTD_PROPERTIES
    When "OPEUOM2"                     : Gosub OPEUOM2                         From PJMTSKOPE_CSTD_PROPERTIES
    When "EXTWST"                      : Gosub EXTWST                          From PJMTSKOPE_CSTD_PROPERTIES
    When "EXTWSTNBR"                   : Gosub EXTWSTNBR                       From PJMTSKOPE_CSTD_PROPERTIES
    When "EXTQTY"                      : Gosub EXTQTY                          From PJMTSKOPE_CSTD_PROPERTIES
    When "RMNQTY"                      : Gosub RMNQTY                          From PJMTSKOPE_CSTD_PROPERTIES
    When "OPESTA"                      : Gosub OPESTA                          From PJMTSKOPE_CSTD_PROPERTIES
    When "OPEDATS"                     : Gosub OPEDATS                         From PJMTSKOPE_CSTD_PROPERTIES
    When "OPEDATH"                     : Gosub OPEDATH                         From PJMTSKOPE_CSTD_PROPERTIES
    When "STDOPENUM"                   : Gosub STDOPENUM                       From PJMTSKOPE_CSTD_PROPERTIES
    When "OPESPLNUM"                   : Gosub OPESPLNUM                       From PJMTSKOPE_CSTD_PROPERTIES
    When "EXTLAB"                      : Gosub EXTLAB                          From PJMTSKOPE_CSTD_PROPERTIES
    When "EXTLABNBR"                   : Gosub EXTLABNBR                       From PJMTSKOPE_CSTD_PROPERTIES
    When "OPECST"                      : Gosub OPECST                          From PJMTSKOPE_CSTD_PROPERTIES
    When "OPECST2"                     : Gosub OPECST2                         From PJMTSKOPE_CSTD_PROPERTIES
    When "OPESTARTDT"                  : Gosub OPESTARTDT                      From PJMTSKOPE_CSTD_PROPERTIES
    When "OPEENDDT"                    : Gosub OPEENDDT                        From PJMTSKOPE_CSTD_PROPERTIES
    When "CSMQTY"                      : Gosub CSMQTY                          From PJMTSKOPE_CSTD_PROPERTIES
    #
    When "TCHOPEUOM2AN"                : Gosub TCHOPEUOM2AN                    From PJMTSKOPE_CSTD_PROPERTIES
    When "TCHOPESTRAN"                 : Gosub TCHOPESTRAN                     From PJMTSKOPE_CSTD_PROPERTIES
    When "TCHOPEENDAN"                 : Gosub TCHOPEENDAN                     From PJMTSKOPE_CSTD_PROPERTIES
    #
    When "RAFFT.POACLB"                : Gosub RAFFT_POACLB                    From PJMTSKOPE_CSTD_PROPERTIES
  Endcase
Return

