#<AdxTL>@(#)4.0.0.0 $Revision$
$ACTION
Case ACTION
 When "IMPORT"     : Gosub IMPORT
Endcase
Return

$IMPORT
If [F:ACO]ABB="" : Return : Endif
I = find([F:ACO]ABB,[M:ACO1]ABB(0..[M:ACO1]BASTAB-1))
If I
 nolign = I
 NBCRE += 1
Else
 [M:ACO1]BASTAB += 1
 nolign = [M:ACO1]BASTAB
 NBMOD += 1
Endif
[M:ACO1] = [F:ACO]

Return
