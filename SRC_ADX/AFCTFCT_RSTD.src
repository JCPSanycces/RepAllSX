#<AdxTL>@(#)0.0.0.0 $Revision$
# Représentation AFCTFCT

$ACTION
Case CURPRO
 When ""      : Gosub METHODS
 When Default : Gosub PROPERTIES
Endcase
Return

$PROPERTIES
Return

$METHODS
Case [L]CURPTH
 When ""
  Case ACTION
   When "AREAD_BEFORE" : Gosub AREAD_BEFORE
   When "AREAD_AFTER" : Gosub AREAD_AFTER
  Endcase
 When "AFT"
  Case ACTION
   When "AREAD_AFTER" : Gosub TEST
  Endcase
Endcase
Return

$AREAD_BEFORE
Return


$AREAD_AFTER
Return

$TEST
Return
