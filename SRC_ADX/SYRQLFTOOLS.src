#**
#* Declare public variable.
#* Must be call at the start of the main script
#*
#* @param PDESC Brief description of this script. Will be appear on mail subject
#*!
Subprog QLF_START(PDESC)
Value Char PDESC()

  Local Integer RET

  [L]RET = func SYRQLFTOOLS.QLF_END()

  # Declare public variables
  Global Char GSOBJECT(250)                 # Mail subject
  Global Char GSLOGS(type(GTRACE)-10)(1..)  # Logs array
  Global Integer GCASE_FAILURE              # Number of case failure
  Global Clbfile GBODY(0)                   # Mail body

  GSOBJECT = PDESC
  If (GSERVEUR) Then
    GSOBJECT -= "(Batch)"
  Endif

End

#**
#* Execute the function through the given QLF and store the log to send
#*
#* @param PSCRIPT Script to run
#* @param PSUBPROG Subprog to execute
#* @param PNFORCE_LOG Set to CST_AYES to alway add the given log file, even when no error is detected
#*!
#**
Subprog QLF_RUN(PSCRIPT, PSUBPROG, PNFORCE_LOG)
Value Char PSCRIPT()
Value Char PSUBPROG()
Value Integer PNFORCE_LOG

  # Execute given QLF
  Local Clbfile RESULT(2)
  RESULT = func =PSCRIPT+"."+PSUBPROG With ()

  # Store the number of failure in the QLF
  GCASE_FAILURE += GXUNIT_CASE_FAILURE

  # Store the QLF name in body paragraph
  GBODY += chr$(10)
  If (GXUNIT_CASE_FAILURE > 0) Then
    GBODY += "-> "
  Endif
  GBODY += PSCRIPT - "-"
  GBODY -= num$(GXUNIT_CASE_SUCCESS) - "Case succeed"
  If (GXUNIT_CASE_FAILURE > 0) Then
    GBODY -= "," - num$(GXUNIT_CASE_FAILURE) - "Case failed"
    GBODY -= "(View log attachment)"
  Endif

  # Add log to send if error appea
  Call _QLF_ADD_LOG(PSCRIPT+"_"+GUSER, GSLOGS, GXUNIT_CASE_FAILURE, PNFORCE_LOG) From SYRQLFTOOLS

End

#**
#* Send QLF logs to receivers of given area
#*
#* @param PAREA Area code
#* @return CST_ATRUE
#*!
Funprog QLF_SEND_LOGS(PAREA)
Value Char PAREA()

  Local Char SMAILS(GLONMAI)(1..)

  If (func _QLF_SET_EMAILS_AREA(PAREA, SMAILS) = [V]CST_ATRUE) Then
    Call _QLF_SEND_MAIL(GSLOGS, SMAILS) From SYRQLFTOOLS
  Endif

End [V]CST_ATRUE

#**
#* End fonction to reset declaration.
#* This function must be call mandatory and at the end of main script.
#* @return CST_ATRUE
#*!
Funprog QLF_END()

  If dim(GSOBJECT) >= 0 Then
    Kill GSOBJECT
  Endif
  If dim(GSLOGS) >= 0 Then
    Kill GSLOGS
  Endif
  If (dim(GCASE_FAILURE) >= 0) Then
    Kill GCASE_FAILURE
  Endif
  If (dim(GBODY) >= 0) Then
    Kill GBODY
  Endif

End [V]CST_ATRUE

#**
#* Add the the given log file to the sended log array
#* @private
#*
#* @param PSLOG       Log file to add
#* @param RSLOGS      Log file array
#* @param RNQLF_CHAIN Number of failure in the last QLF
#* @param PNFORCE_LOG Set to CST_AYES to alway add the given log file, even when no error is detected
#*!
Subprog _QLF_ADD_LOG(PSLOG, RSLOGS, RNQLF_CHAIN, PNFORCE_LOG)
Value Char PSLOG
Variable Char RSLOGS()(1..)
Value Integer RNQLF_CHAIN
Value Integer PNFORCE_LOG

  If RNQLF_CHAIN > 0 or PNFORCE_LOG = [V]CST_AYES Then
    RSLOGS(maxtab(RSLOGS)+1) = PSLOG
  Endif

End

#**
#* Send log files to the given receivers
#*
#* @param PSLOGS Log file array
#* @param PSMAILS Mail adress array
#*!
Subprog _QLF_SEND_MAIL(PSLOGS, PSMAILS)
Value Char PSLOGS()(1..)
Value Char PSMAILS()(1..)

Local Integer ASTATUS
Local Char SA_FROM(250)
Local Char SA_USER(250)(1..)
Local Char SCC_USER(250)(1..)
Local Char SZEMAILSUBJECT(250)
Local Clbfile BODY(4)
Local Char S_ATTACHMENTS(250)(1..)
Local Integer NI
Local Integer NE

  SA_FROM = "noreply@sage.com"

  Raz SA_USER
  NE = 0
  For NI = 1 To maxtab(PSMAILS)
    If PSMAILS(NI) <> "" Then
      NE += 1
      SA_USER(NE) = PSMAILS(NI)
    Endif
  Next NI
  If NE = 0 Then
    End
  Endif

  Raz SCC_USER

  Raz S_ATTACHMENTS
  NE = 0
  For NI = 1 To maxtab(PSLOGS)
    If PSLOGS(NI) <> "" Then
      NE += 1
      S_ATTACHMENTS(NE) = filpath("TRA", PSLOGS(NI), "tra", nomap)
    Endif
  Next NI

  If dim(GSOBJECT) < 0 Then
    SZEMAILSUBJECT = "QLF execution"
  Else
    SZEMAILSUBJECT = GSOBJECT
  Endif
  BODY = "Result of the QLFs execution (" + nomap + ")"
  If NE = 0 Then
    SZEMAILSUBJECT += " : no error detected on" - nomap
    BODY += " : no error detected"
  Else
    SZEMAILSUBJECT += " with error detected on" - nomap
    If (dim(GCASE_FAILURE) >= 0) Then
      BODY += " : " + num$(GCASE_FAILURE) + " error(s) detected"
    Endif
  Endif
  # Add list of QLF executed
  If (dim(GBODY) >= 0) Then
    BODY += chr$(10) + GBODY
  Endif

  ASTATUS = func ASYRMAIL.ASEND_MAIL(GACTX, SA_FROM, SA_USER, SCC_USER, SZEMAILSUBJECT, BODY, S_ATTACHMENTS, [V]CST_ANO)

End

###################################################################################################
#**
#* Variable declaration for QLF chain execution
#* @variable XUNIT_SUITE_RESULT : return value of the .testsuite() subroutine
#* @variable STRACE             : Log file name for one QLF
#* @variable STBTRACES          : Log file name list to send
#* @variable STBMAILS           : Emails adresses lists to send the result mail
#* @variable NFORCE_LOG         : By default set to [V]CST_ANO. If set to [V]CST_AYES, logs files will
#*                                always be send, even if there is no error detected.
#* @deprecated
#*!
$QLF_CHAIN_INIT
Local Clbfile XUNIT_SUITE_RESULT(2)
Local Char STRACE(type(GTRACE)-10)
Local Char STBTRACES(type(GTRACE)-10)(1..)
Local Char STBMAILS(GLONMAI)(1..)
Local Integer NFORCE_LOG

  NFORCE_LOG = [V]CST_ANO
  If dim(GQLF_CHAIN) < 0 Then
    Global Integer GQLF_CHAIN
  Endif
  GQLF_CHAIN = 0

Return

#**
#* Detect if at least an error has been detected in the QLF subroutine.
#* To call at the end of each QLF subroutine.
#* @deprecated
#*!
Subprog QLF_CHAIN_EXECUTE
  If dim(GQLF_CHAIN) >= 0 Then
    If GQLF_CHAIN = 0 Then
      GQLF_CHAIN = GXUNIT_FAILURE
    Endif
  Endif

End

#**
#* Clear the environment created by QLF_CHAIN_INIT
#* @deprecated
#*!
$QLF_CHAIN_KILL
  If dim(GQLF_CHAIN) >= 0 Then
    Kill GQLF_CHAIN
  Endif

Return

