#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ITF10 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBITF
mkstat = 0
zoncou = "NBITF"
indice = 0
status = 1
zoncou = "NBITF"
If varmode([M]NBITF,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NBITF From SUBITF
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NBITF : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBITF" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBITF
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBITF = nolign
   status = 75
   Call SAI_NBITF(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_NBITF From SUBITF
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NBITF" : GZNUM = 0 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

####################################
## Bloc liste 3
####################################
IMPTBL = 0

####################################
## Bloc liste 4
####################################
IMPTBL = 0

####################################
## Bloc liste 5
####################################
IMPTBL = 0

## Zone XDOUFLG
mkstat = 0
zoncou = "XDOUFLG"
indice = 0
IMPENT = [M]XDOUFLG
WNUM = IMPENT
If varinit([M]XDOUFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]XDOUFLG,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_XDOUFLG(IMPENT) From SUBITF
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]XDOUFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "XDOUFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]XDOUFLG(indice)
 Endif
 If !mkstat
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_XDOUFLG(IMPENT) From SUBITF
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "XDOUFLG" : GZNUM = 3935 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]XDOUFLG = IMPENT

## Zone XPIO
mkstat = 0
zoncou = "XPIO"
indice = 0
WNUM = [M]XPIO
If varmode([M]XPIO,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "XPIO" : Gosub ACTION From =IMPTRT
 Endif
 If WNUM<>[M]XPIO or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_XPIO([M]XPIO) From SUBITF
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "XPIO" : GZNUM = 1164 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone XCTMBPSFLG
mkstat = 0
zoncou = "XCTMBPSFLG"
indice = 0
IMPENT = [M]XCTMBPSFLG
WNUM = IMPENT
If varinit([M]XCTMBPSFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]XCTMBPSFLG,indice)=0
 [M]XCTMBPSFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "XCTMBPSFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]XCTMBPSFLG(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_XCTMBPSFLG(IMPENT) From SUBITF
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "XCTMBPSFLG" : GZNUM = 2173 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]XCTMBPSFLG = IMPENT

####################################
## Bloc liste 6
####################################
IMPTBL = 0

####################################
## Bloc liste 7
####################################
IMPTBL = 0

## Zone XCPRCOE
mkstat = 0
zoncou = "XCPRCOE"
indice = 0
WNUM = [M]XCPRCOE
If varinit([M]XCPRCOE,indice)=0
 [M]XCPRCOE = 1
Endif
If varmode([M]XCPRCOE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "XCPRCOE" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTCPR"
 Call CONTCPR([M]XCPRCOE) From TRTX3
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "XCPRCOE" : GZNUM = 3950 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>[M]XCPRCOE or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_XCPRCOE([M]XCPRCOE) From SUBITF
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "XCPRCOE" : GZNUM = 3950 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone XCPRAMT
mkstat = 0
zoncou = "XCPRAMT"
indice = 0
WNUM = [M]XCPRAMT
SAVACT = GACTION : GACTION = "PARDEV"
GACTION = SAVACT
If mkstat=1 : Raz [M]XCPRAMT : Endif
If !mkstat
 If varmode([M]XCPRAMT,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "XCPRAMT" : Gosub ACTION From =IMPTRT
  Endif
  If [M]XCPRAMT<0
   mkstat = 1 : GMESSAGE = mess(180,141,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "XCPRAMT" : GZNUM = 48557 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WNUM<>[M]XCPRAMT or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_XCPRAMT([M]XCPRAMT) From SUBITF
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "XCPRAMT" : GZNUM = 48557 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone XSTCNUM
mkstat = 0
zoncou = "XSTCNUM"
indice = 0
WCHAR = [M]XSTCNUM
If varmode([M]XSTCNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "XSTCNUM" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_XSTCNUM([M]XSTCNUM) From SUBITF
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "XSTCNUM" : GZNUM = 49730 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]XSTCNUM or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_XSTCNUM([M]XSTCNUM) From SUBITF
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "XSTCNUM" : GZNUM = 49730 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBITF(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBITF
mkstat = 0
zoncou = "NBITF"
If !mkstat
 SAVACT = GACTION : GACTION = "STD"
 Call C_NBITF From SUBITF
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "NBITF" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone BPSNUM
mkstat = 0
zoncou = "BPSNUM"
WCHAR = [M]BPSNUM(indice)
If varmode([M]BPSNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BPSNUM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]BPSNUM(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "BPSNUM" : GZNUM = 3680 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("BPS","",[M]BPSNUM(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "BPSNUM" : GZNUM = 3680 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_BPSNUM([M]BPSNUM(indice)) From SUBITF
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "BPSNUM" : GZNUM = 3680 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]BPSNUM(indice) or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_BPSNUM([M]BPSNUM(indice)) From SUBITF
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "BPSNUM" : GZNUM = 3680 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone DOUFLG
mkstat = 0
zoncou = "DOUFLG"
IMPENT = [M]DOUFLG(indice)
If varinit([M]DOUFLG,indice)=0
 IMPENT = 1
Endif
[M]DOUFLG(indice) = IMPENT

## Zone CTMBPSFLG
mkstat = 0
zoncou = "CTMBPSFLG"
IMPENT = [M]CTMBPSFLG(indice)
If varinit([M]CTMBPSFLG,indice)=0
 IMPENT = 1
Endif
[M]CTMBPSFLG(indice) = IMPENT

## Zone DEFBPSFLG
mkstat = 0
zoncou = "DEFBPSFLG"
IMPENT = [M]DEFBPSFLG(indice)
If varinit([M]DEFBPSFLG,indice)=0
 IMPENT = 1
Endif
[M]DEFBPSFLG(indice) = IMPENT

## Zone DEFCTMBPSFLG
mkstat = 0
zoncou = "DEFCTMBPSFLG"
IMPENT = [M]DEFCTMBPSFLG(indice)
If varinit([M]DEFCTMBPSFLG,indice)=0
 IMPENT = 1
Endif
[M]DEFCTMBPSFLG(indice) = IMPENT

## Zone CPRAMT
mkstat = 0
zoncou = "CPRAMT"
SAVACT = GACTION : GACTION = "PARDEV"
GACTION = SAVACT
If mkstat=1 : Raz [M]CPRAMT(indice) : Endif

## Zone NBITF
mkstat = 0
zoncou = "NBITF"
status = 71
SAVACT = GACTION : GACTION = "STD"
Call APRES_NBITF From SUBITF
GACTION = SAVACT

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "ITF10"
Return

