#<AdxTL>@(#)0.0.0.0 $Revision$Class Lot
# Supervisor
## ACLA-CLASSE ## PRJLOT
# 2018-11-06 07:13:52 940

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0PRJLOT
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_PRJ From WMC1PRJLOT : Gosub TESTALLSTAT
Gosub INIT_LOT From WMC1PRJLOT : Gosub TESTALLSTAT
Gosub INIT_DESLOT From WMC1PRJLOT : Gosub TESTALLSTAT
Gosub INIT_ACTDAT From WMC1PRJLOT : Gosub TESTALLSTAT
Gosub INIT_AMTLOT From WMC1PRJLOT : Gosub TESTALLSTAT
Gosub INIT_CURLOT From WMC1PRJLOT : Gosub TESTALLSTAT
Gosub INIT_FINMOD From WMC1PRJLOT : Gosub TESTALLSTAT
Gosub INIT_FCY From WMC1PRJLOT : Gosub TESTALLSTAT
Gosub INIT_FASGRP From WMC1PRJLOT : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1PRJLOT : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1PRJLOT : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1PRJLOT : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1PRJLOT : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1PRJLOT : Gosub TESTALLSTAT
Gosub AINIT From WMC0PRJLOT : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0PRJLOT
Gosub _ALOADATTRIBUTE_PRJ From WMC1PRJLOT : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_LOT From WMC1PRJLOT : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0PRJLOT
Gosub LNKPRO_AMTLOT From WMC1PRJLOT : Gosub TESTALLSTAT
Gosub LNKPRO_CURLOT From WMC1PRJLOT : Gosub TESTALLSTAT
Gosub LNKPRO_FINMOD From WMC1PRJLOT : Gosub TESTALLSTAT
Gosub LNKPRO_FCY From WMC1PRJLOT : Gosub TESTALLSTAT
Gosub LNKPRO_CREUSR From WMC1PRJLOT : Gosub TESTALLSTAT
Gosub LNKPRO_UPDUSR From WMC1PRJLOT : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



