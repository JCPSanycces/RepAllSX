#<AdxTL>@(#)165.0.0.0 $Revision$
###############################################################
## Gestion des objets de type tableau                        ##
###############################################################
$CHARGE
Assign "[G:"+ABFIC+"]currind" With 1
Assign "[G:"+ABFIC+"]currlen" With 0
Gosub DEFAUT From =PROGOBJ
Gosub CRITTAB
Raz [M]
If PPAG : Call TEMPON("L") From GESECRAN : Endif
MA = 1
IMA = 1
ACTION = "LIENS0" : Gosub ACTION From GOBJSUB
nolign = 0
For [F]
 If nolign>=MAXLIG
  Call ERREUR(mess(26,100,1)) From GESECRAN : # Tableau plein
  Break
 Endif
 nolign += 1
 Gosub CHARGEMSK From =WINPROG
 ACTION = "LIENS" : Gosub ACTION From GOBJSUB
Next
Assign "[M]"+BASPAG With nolign
ACTION = "LIENS2" : Gosub ACTION From GOBJSUB
Filter [F]
If PPAG : Call TEMPOFF From GESECRAN : Endif
Return

$CRITTAB
CRITTAB = ""
If CLESEC<>"" & evalue("dim([M]"+CLESEC+")")=1 
&  & (dim([L]CLEVALEUR)<0 | !find(CLESEC,CLEFCY,CLEDEP))
 CLECUR2 = num$(evalue("[M]"+CLESEC))
 If TPCLE2=1
  CRITTAB = CLESEC+"='"+CLECUR2+"'"
 Elsif TPCLE2=3
  If CLECUR2=""
   CRITTAB += CLESEC+"=[0/0/0]"
  Elsif instr(1,CLECUR2,"/")
   CRITTAB += CLESEC+"=["+CLECUR2+"]"
  Elsif len(CLECUR2)=8 
   CRITTAB += CLESEC+"='"+CLECUR2+"'"
  Endif
 Else
  CRITTAB = CLESEC+"="+CLECUR2
 Endif
Endif
Gosub CRITERE From GOBJSUB
If CRITTAB<>""
 If CRITERE<>""
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",CRITTAB,"&") From GOBJSUB
 Else
  CRITERE = CRITTAB
 Endif
Endif
Gosub FIL_FILTRE From GOBJSUB
Return

########################################################
$MODIF
If GADONIX=2 
 Call VERIF_GRP(ABREV,CLECUR1,CLECUR2,OK) From GOBJET
 If !OK : GOK = 0 : Return : Endif
Endif
OK = 1
ACTION = "VERIF_MOD" : Gosub ACTION From GOBJSUB
If ! OK : GOK = 0 : Return : Endif
If PPAG : Call TEMPON("E") From GESECRAN : Endif
Call DEBTRANS From GLOCK
Gosub TR3
If PPAG : Call TEMPOFF From GESECRAN : Endif
If GOK>=1
 ACTION = "APRES_MOD" : Gosub ACTION From GOBJSUB
 If NUMESPION<0
  Call ESPION(NOMFIC,2,IDENT,"") From ESPION
  NUMESPION=1
 Endif
 If GADONIX=2 : Call TRACE_COR(ABREV,CLECUR1,CLECUR2,"M") From GOBJET : Endif
 If GRPDEB<>"" : Call ENVOI_GROUPE(GRPDEB) From AWRK : Endif
Elsif GRPDEB<>""
 Call VIRE_GROUPE(GRPDEB) From AWRK
 GOK = 0
Endif
Return

$TR3
GOK = 1
GRPDEB = ""
Trbegin ADOVAL
 Gosub DEFAUT From =PROGOBJ
 # mb 21.11.03 Vaut mieux essayer de locker car le delete ne rend pas la main sur un enreg locké
 If dim([L]CLEVALEUR)<0 : ## GEODE, sauf si gestion par env site/dep
  Lock [F]
  If fstat
   GOK=-1 : GLOCK="$"+NOMFIC : Goto ROLL_TR3
  Endif
 Endif
 Gosub CRITTAB
 If dim(ANOWRITE)<=0 or !ANOWRITE
  Delete [F] Where evalue(CRITERE)
  If fstat=1 | fstat>5
   GOK=0 : Call RSTA(ABFIC,"*") From GLOCK : Goto AB_TR3
  Endif
  Filter [F]
  If dim([M]CREUSR)=MAXLIG & dim([M]UPDUSR)=MAXLIG
   NUMESPION=1
  Else
   NUMESPION=-1
  Endif 
  For nolign=1 To evalue("[M]"+BASPAG)
   Raz [F]
   [F] = [M]
   Gosub INICRE
   ACTION = "INICRE" : Gosub ACTION From GOBJSUB
   Write
   If fstat
    GOK=0 : Call FSTA(ABFIC) From GLOCK : Break
   Endif
   ACTION = "CREATION" : Gosub ACTION From GOBJSUB
   If GOK<1 : Break : Endif
   If NUMESPION>0
    Gosub SET_CLE2 From GOBJSUB 
    Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT
    Call ESPION(NOMFIC,NUMESPION,IDENT,"") From ESPION
   Endif
  Next nolign
 Endif
 If    GOK<0 : Goto ROLL_TR3
 Elsif GOK=0 : Goto AB_TR3
 Endif

 ACTION = "MODIF" : Gosub ACTION From GOBJSUB
 If GOK<0   : Goto ROLL_TR3
 Elsif !GOK : Goto AB_TR3
 Endif

 IDENT=""
 ## GEODE
 If dim([L]CLEDEP)>0 & [L]CLEDEP<>""    : IDENT=GDEP+"~"+GFCY
 Elsif dim([L]CLEFCY)>0 & [L]CLEFCY<>"" : IDENT=GFCY
 Endif
 ##
 
 Call WRKGLOB(171,[L]IDENT,[L]NOMFIC,[L]NOMINT) From GOBJACT
 Call WORKPLUS(2,ABREV,"C",IDENT,"",0,1,0,GRPDEB) From AWRK
 If GOK<0   : Goto ROLL_TR3
 Elsif !GOK : Goto AB_TR3
 Endif

Commit
Return

$ROLL_TR3
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR3 : Endif

$AB_TR3
Rollback
Return

$INICRE
If NUMESPION>=0
 If evalue("dim([F:"+ABFIC+"]CREUSR)>0 & [F:"+ABFIC+"]CREUSR=''") 
  NUMESPION=1 : # ligne nouvelle créée
 Elsif evalue("dim([F:"+ABFIC+"]UPDUSR)>0 & [F:"+ABFIC+"]UPDUSR='!'")
  NUMESPION=2 : # ligne modifiée
 Else
  NUMESPION=0 : # ligne inchangée
 Endif
Endif
If NUMESPION=2 | NUMESPION<0
 Gosub INIMOD From GOBJSUB
Endif
If evalue("dim([F:"+ABFIC+"]CREUSR)>0 & [F:"+ABFIC+"]CREUSR=''")
 If dim(GUSRSD)>0 & GUSRSD<>""
  Assign "[F:"+ABFIC+"]CREUSR" With GUSRSD
 Else
  Assign "[F:"+ABFIC+"]CREUSR" With GUSER
 Endif
Endif
If evalue("dim([F:"+ABFIC+"]CREDAT)>0 & [F:"+ABFIC+"]CREDAT=[0/0/0]")
 Assign "[F:"+ABFIC+"]CREDAT" With date$
Endif
If evalue("dim([F:"+ABFIC+"]CRETIM)>0 & [F:"+ABFIC+"]CRETIM=0")
 Assign "[F:"+ABFIC+"]CRETIM" With time
Endif
If evalue("dim([F:"+ABFIC+"]EXPNUM)>0 & [F:"+ABFIC+"]EXPNUM=0")
 Assign "[F:"+ABFIC+"]EXPNUM" With [C]EXPORT
Endif
If evalue("dim([F:"+ABFIC+"]UPDUSR)>0 & [F:"+ABFIC+"]UPDUSR='!'")
 Assign "[F:"+ABFIC+"]UPDUSR" With ""
Endif
Return

#################
Subprog UPDLIGTAB
#################
# liée à l'action UPDLIGTAB
If nolign>0 & dim([M]UPDUSR(nolign-1))>0 
 [M]UPDUSR(nolign-1)="!"
Endif
End

############################
Subprog CODTAB(VALEUR,ABREV)
############################
# liée à l'action CODTAB
Value Char VALEUR(), ABREV()
If VALEUR<>""
 Call LECTURE(ABREV,VALEUR,"") From CONTOBJ
 If fstat=0 : mkstat=2 : Endif
Endif
End

