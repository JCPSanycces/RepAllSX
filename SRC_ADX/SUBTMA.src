#<AdxTL>@(#)5.0.0.0 $Revision$
$ACTION
Case ACTION
 When "LIENS"  : Gosub LIENS
 When "INICRE" : Gosub INICRE
Endcase
Return


## GH 20/03/2014 bug 97919 pour conserver le CREDATTIM des lignes existantes
##                                     et le UPDDATTIM des lignes existantes non modifiées

$LIENS
If dim([M]CREDATTIM2)>0
   [M]CREDATTIM2(nolign-1) = num$([F:TMA]CREDATTIM)
Endif
If dim([M]UPDDATTIM2)>0
   [M]UPDDATTIM2(nolign-1) = num$([F:TMA]UPDDATTIM)
Endif
Return

$INICRE
If dim([M]CREDATTIM2)>0 & NUMESPION<>1 : # pas nouvelle ligne
   [F]CREDATTIM = gdatetime$([M]CREDATTIM2(nolign-1))
Endif
If dim([M]UPDDATTIM2)>0
   Case NUMESPION
     When 0  : # Ligne inchangée (ni nouvelle, ni modifiée)
       [F]UPDDATTIM = gdatetime$([M]UPDDATTIM2(nolign-1))
     When 2  : # Ligne modifiée
       [F]UPDDATTIM = gdatetime$("")
   Endcase
Endif
Return

##

########################################
Subprog AS_EMPNUM(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0 : mkstat = 2 : Endif
End

########################################
Subprog C_EMPNUM(VALEUR)
Variable Decimal VALEUR
Call UNICITE(VALEUR, [M:TMA1]EMPNUM(0..NBMAT-1)) From OBJDIV
End

########################################
Subprog C_USR(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" : End : Endif  
##Read [F:AUS]CODUSR = VALEUR
##If fstat : GMESSAGE = mess(23,100,1) : mkstat = 1 : End : Endif
Call UNICITE(VALEUR, [M:TMA1]USR(0..NBMAT-1)) From OBJDIV
End

