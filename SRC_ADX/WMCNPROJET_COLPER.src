# Supervisor
## ACLA-CLASSE ## PROJET_COLPER
# 2018-11-06 07:13:49 984

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0PROJET_COLPER
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_PERSTR From WMC1PROJET_COLPER : Gosub TESTALLSTAT
Gosub INIT_PEREND From WMC1PROJET_COLPER : Gosub TESTALLSTAT
Gosub INIT_AMTPRV From WMC1PROJET_COLPER : Gosub TESTALLSTAT
Gosub INIT_CURPRV From WMC1PROJET_COLPER : Gosub TESTALLSTAT
Gosub AINIT From WMC0PROJET_COLPER : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0PROJET_COLPER
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0PROJET_COLPER
Gosub LNKPRO_CURPRV From WMC1PROJET_COLPER : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



