#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTITC37   Table TABCOSTMVT                                   Module TC #
#           Initialiser la zone NUM à 1                                  #
##########################################################################
# Issue 78775 - 2011-12-21 by CCC
##########################################################################

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Call OUVRE_TRACE("Init de [F:TCM]NUM si nécessaire") From LECFIC

For [ADS]
  Call TEMPON("O") From GESECRAN
  Call MAJ_UTITC37([F:ADS]DOSSIER) 
  Call TEMPOFF     From GESECRAN
Next

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

End

Subprog MAJ_UTITC37(PDOSSIER)
Value Char PDOSSIER

Local Integer COMPTEUR

If filinfo(filpath("FIL","TABCOSTMVT","fde",PDOSSIER),0) <=0   End   Endif
If clalev([F:TVM])=0 : Local File =PDOSSIER+".TABCOSTMVT"    [TVM] : Endif
If clalev([F:TVM0])=0 : Local File =PDOSSIER+".TABCOSTMVT"   [TVM0]: Endif

Call ECR_TIME("DOSMAJ30 Init [F:TVM]NUM") From DOSSUB

Trbegin [TVM]
For [TVM] Where NUM=0
    Look [TVM0]TVM1=[F:TVM]VLTCOD;1;[F:TVM]MVTTYP;[F:TVM]TRSCOD
    If fstat
        [F:TVM]NUM=1
        Rewrite [TVM]
        COMPTEUR += 1
    Endif
Next
Commit

Close Local File [TVM]

Call ECR_TRACE("UTITC37: "+num$(COMPTEUR)+" records processed",0) From GESECRAN
Call ECR_TRACE("",0) From GESECRAN

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If filinfo(filpath("FIL","TABCOSTMVT","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= code table  
Call MAJ_UTITC37(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If filinfo(filpath("FIL","TABCOSTMVT","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= code table  
Call MAJ_UTITC37(APPLI)        
End

