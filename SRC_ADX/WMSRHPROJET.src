#<AdxTL>@(#)0.0.0.0 $Revision$Class ## ?IDENTQRY? SEARCH ##
# Supervisor
#WMSRHPROJET PROJET
# 2018-11-06 07:13:51 359

Funprog IS_IMPLEMENTED()
End 1
#---------------------------------------------------------------------------------------------------#
# List of tables to open
#---------------------------------------------------------------------------------------------------#
$ASEARCH_OPEN
If filinfo(filpath("FIL","PROJET","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File PROJET [PRJ]
If filinfo(filpath("FIL","PRJLOT","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File PRJLOT [PJL]
If filinfo(filpath("FIL","PRJFAS","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File PRJFAS [PJF]
Local File PROJET [PRJ_]
Local File ATEXTRA [AXX_1]
Local File ATEXTRA [AXX_2]
Local Char KEY_PRJ(120)(1..3)
Local Char KEY_PJL(120)(1..3)
Local Char KEY_PJF(120)(1..3)
#Empty keys :
KEY_PRJ(3) = ""
KEY_PJL(3) = "+"
KEY_PJF(3) = "+0"
ACTION = "ASEARCH_OPEN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to close
#---------------------------------------------------------------------------------------------------#
$ASEARCH_CLOSE
LogicClose File [PRJ]
LogicClose File [PJL]
LogicClose File [PJF]
LogicClose File [PRJ_]
LogicClose File [AXX_1]
LogicClose File [AXX_2]
ACTION = "ASEARCH_CLOSE_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to join
#---------------------------------------------------------------------------------------------------#
$ASEARCH_JOIN
Link [PRJ] With
& [PJL]PJL0=[F:PRJ]PRJ,
& [PJF]PJF0=[F:PRJ]PRJ,
& [F:AXX_1]AXX0 = "PROJET";"DESTRA";GACTX.LAN;[F:PRJ]PRJ;"",
& [F:AXX_2]AXX0 = "PROJET";"SHOTRA";GACTX.LAN;[F:PRJ]PRJ;""
& As [LNK_]
& Where (1=1
& )
ACTION = "ASEARCH_JOIN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to join
#---------------------------------------------------------------------------------------------------#
$ASEARCH_JOIN_INC
Link [PRJ] With
& [PJL]PJL0=[F:PRJ]PRJ,
& [PJF]PJF0=[F:PRJ]PRJ,
& [F:AXX_1]AXX0 = "PROJET";"DESTRA";GACTX.LAN;[F:PRJ]PRJ;"",
& [F:AXX_2]AXX0 = "PROJET";"SHOTRA";GACTX.LAN;[F:PRJ]PRJ;""
& As [LNK_]
& Where (UPDDATTIM > gdatetime$(QUPDDATTIM)
& )
ACTION = "ASEARCH_JOIN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# Create an instance of
#---------------------------------------------------------------------------------------------------#
$ASEARCH_CREATEINSTANCE
Local Integer ASTATUS
Local Integer FINS
Local Integer CI1
Local Integer CJ1
Local Char    SEPINS1(2) : SEPINS1=""
Local Char IS1(1)

Return

#---------------------------------------------------------------------------------------------------#
# Set an instance
#---------------------------------------------------------------------------------------------------#
$ASEARCH_SETINSTANCE
KEY_PRJ(2) = [F:PRJ]PRJ
KEY_PJL(2) = [F:PJL]PRJ+"+"+[F:PJL]LOT
KEY_PJF(2) = [F:PJF]PRJ+"+"+num$([F:PJF]LIG)

If (KEY_PRJ(2) <> KEY_PRJ(3)) & (KEY_PRJ(1) <> KEY_PRJ(2))
 If INS <> null
  [L]ASTATUS = fmet INS.ACTION("ASEARCH_TRANS_AFTER")
  #serialize INS
  Gosub ASEARCH_TO_JSON
 Endif
#Create a new instance
INS = NewInstance C_PROJET(GACTX,UIDINS,NUMLIN,null,"") AllocGroup null
INS.setaccessorEnabled = 0
SetInstance INS With [F:PRJ]
FINS = 1
Call ASETTEXTRA(INS.AXX,INS.ALLOCGRP(),"DESTRA",[F:AXX_1]TEXTE,GACTX.LAN) From ASYRSUB
Call ASETTEXTRA(INS.AXX,INS.ALLOCGRP(),"SHOTRA",[F:AXX_2]TEXTE,GACTX.LAN) From ASYRSUB
Local Integer COLBPRFIN_MAXI:COLBPRFIN_MAXI= 0
Local Integer COLBPRFIN_MAXI:COLBPRFIN_MAXI= 0
Local Integer COLBPRFIN_MAX:COLBPRFIN_MAX=0
If dim([F:PRJ]BPRFIN)>0
    If COLBPRFIN_MAXI = 0
        COLBPRFIN_MAXI = dim([F:PRJ]BPRFIN)
    Else
        COLBPRFIN_MAXI = min(COLBPRFIN_MAXI,dim([F:PRJ]BPRFIN))
    Endif
Endif
If dim([F:PRJ]BPRFIN)>0
    If COLBPRFIN_MAXI = 0
        COLBPRFIN_MAXI = dim([F:PRJ]BPRFIN)
    Else
        COLBPRFIN_MAXI = min(COLBPRFIN_MAXI,dim([F:PRJ]BPRFIN))
    Endif
Endif
CJ1=1
For CI1 = 0 To COLBPRFIN_MAXI-1
 Break ([F:PRJ]BPRFIN(CI1)="")
 COLBPRFIN_MAX+=1
 #Create a new instance
 INS.COLBPRFIN(CJ1) = NewInstance C_PROJET_COLBPRFIN(GACTX,UIDINS,NUMLIN,INS,"") AllocGroup INS
 INS.COLBPRFIN(CJ1).setaccessorEnabled = 0
 INS.COLBPRFIN(CJ1).BPRFIN=[F:PRJ]BPRFIN(CI1)
 CJ1+=1
Next CI1
 KEY_PRJ(1) = KEY_PRJ(2)
Endif : # KEY_PRJ(1) <> KEY_PRJ(2)

Return

#---------------------------------------------------------------------------------------------------#
# Serialize the entity in a JSON format
#---------------------------------------------------------------------------------------------------#
$ASEARCH_TO_JSON
If FINS=0 : Return : Endif
QCOUNT += 1
Onerrgo ERROR_VALUE
Append ASND.DATA ,SEPINS1
SEPINS1 = ','+chr$(10)
Append ASND.DATA ,'{'
Append ASND.DATA ,'"PRJ":'             +'"'+escJson(INS.PRJ)+'"'
Append ASND.DATA ,',"DESTRA":'         
Append ASND.DATA ,'"'
Append ASND.DATA ,escJson(func ASYRSUB.AGETTEXTRA(INS.AXX,"DESTRA",GACTX.LAN))
Append ASND.DATA ,'"'
Append ASND.DATA ,',"SHOTRA":'         
Append ASND.DATA ,'"'
Append ASND.DATA ,escJson(func ASYRSUB.AGETTEXTRA(INS.AXX,"SHOTRA",GACTX.LAN))
Append ASND.DATA ,'"'
Append ASND.DATA ,',"GCF":'            +'"'+escJson(INS.GCF)+'"'
Append ASND.DATA ,',"INVTYP":'         +'"'+escJson(INS.INVTYP)+'"'
Append ASND.DATA ,',"AIM":'            +'"'+escJson(INS.AIM)+'"'
Append ASND.DATA ,',"USR":'            +'"'+escJson(INS.USR)+'"'
Append ASND.DATA ,',"CUR":'            +'"'+escJson(INS.CUR)+'"'
Append ASND.DATA ,',"$access":'        +'"'+escJson(INS.ACS)+'"'
Append ASND.DATA ,',"CREUSR":'         +'"'+escJson(INS.CREUSR)+'"'
Append ASND.DATA ,',"UPDUSR":'         +'"'+escJson(INS.UPDUSR)+'"'
IS1=""
CJ1=1
Append ASND.DATA ,',"COLBPRFIN":['
For CI1=1 To COLBPRFIN_MAX
 Append ASND.DATA ,IS1+'{'
 Append ASND.DATA ,'"BPRFIN":'          +'"'+escJson(INS.COLBPRFIN(CJ1).BPRFIN)+'"'
 Append ASND.DATA ,'}'
 IS1=","
 CJ1+=1
Next CI1
Append ASND.DATA , "]"
Append ASND.DATA ,'}'
Onerrgo
Freegroup INS
INS = null
Raz KEY_PRJ(1),KEY_PJL(1),KEY_PJF(1)
FINS = 0
Return

#---------------------------------------------------------------------------------------------------#
# Errors
#---------------------------------------------------------------------------------------------------#
$ERROR_VALUE
SVALUE ='"<error'-errmes$(errn)+'>"'
Resume
#---------------------------------------------------------------------------------------------------#
# Link standard key
#---------------------------------------------------------------------------------------------------#
$AQUERY_PRIMARYKEYS
Local Char ASTDKEY(250)
ASTDKEY = ""
ASTDKEY += "[F:PRJ]PRJ"
ACTION = "ASEARCH_PRIMARYKEYS_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# Actions
#---------------------------------------------------------------------------------------------------#
$ASEARCH_ACTION
Local Char CURPRO(250),CURPTH(250),AMETHOD(50),AEVENT(50)
[L]AEVENT = [L]ACTION
 Gosub METHODS From PROJET_CSTD
Gosub METHODS From PROJET_CSTD
Return

#---------------------------------------------------------------------------------------------------#
# APPEND_PROTOTYPE
#---------------------------------------------------------------------------------------------------#
Funprog APPEND_PROTOTYPE(ACTX,WCLOB,PSYR)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Clbfile   WCLOB
Variable Instance  PSYR     Using C_ASYR
Local Integer ERROR : ERROR = 0
Local Integer IND   : IND = 0
Local Char TRTNAME(80)
Local Char REPRESENTATION(80)
Local File ASHW    [ASW]
Filter [ASW] Where CODCLA="PROJET" & DEFREP=2
Read [ASW]ASW0 First
If !fstat
 If  [ASW]ENAFAC(0) = 2
  REPRESENTATION = [ASW]CODREP
 Else
  WCLOB ="{}"
  End ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(62,149,1),"PROJET")) 
 Endif
Endif
Close Local File [ASW]
If len(REPRESENTATION)=0
 WCLOB ="{}"
 End ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(62,149,1),"PROJET")) 
Endif
Append WCLOB,'{'
Append WCLOB,'"$baseUrl":"'+PSYR.PREFIX+'"'
Append WCLOB,',"$baseType":"'+PSYR.CNTPRE+"."+nomap+'"'
Append WCLOB,',"$classTitle":"'+func GET_RES_STRING(ACTX.LAN,33574)+'"'
Append WCLOB,',"$url":"{$baseUrl}/PROJET'+PSYR.URLREP+''+REPRESENTATION+'.$search"'
Append WCLOB,',"$prototype":"{$baseUrl}/$prototypes('+"'"+'{$representation}.$thumb'+"'"+')"'
Append WCLOB,',"$type":"{$baseType}.'+REPRESENTATION+'.$search"'
Append WCLOB,',"$properties":{'
Append WCLOB,'"$resources":{'
Append WCLOB,'"$type":"application/x-array"'
Append WCLOB,',"$item":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,33574)+' {$key}"'
Append WCLOB,',"$key":"{PRJ}"'
Append WCLOB,',"$url":"{$baseUrl}/PROJET('+"'"+'{$key}'+"'"+')'+PSYR.URLREP+'PROJET.searchItem"'
Append WCLOB,',"$properties":{'
Append WCLOB,'"PRJ":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,33574)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":15'
Append WCLOB,"}"
Append WCLOB,',"DESTRA":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,8)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":30'
Append WCLOB,"}"
Append WCLOB,',"SHOTRA":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,4010)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":12'
Append WCLOB,"}"
Append WCLOB,',"GCF":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,616)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,"}"
Append WCLOB,',"INVTYP":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,33579)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":20'
Append WCLOB,"}"
Append WCLOB,',"AIM":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,14435)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":20'
Append WCLOB,"}"
Append WCLOB,',"USR":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,1462)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":5'
Append WCLOB,"}"
Append WCLOB,',"CUR":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,323)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":3'
Append WCLOB,"}"
Append WCLOB,',"$access":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,71)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":10'
Append WCLOB,"}"
Append WCLOB,',"CREUSR":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,4049)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,"}"
Append WCLOB,',"UPDUSR":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,4051)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,"}"
Append WCLOB,',"COLBPRFIN":{'
Append WCLOB,'"$type":"application/x-array"'
Append WCLOB,',"$minItems":0'
Append WCLOB,',"$maxItems":10'
Append WCLOB,',"$item":{'
Append WCLOB,'"$type":"application/json"'
Append WCLOB,',"$properties":{'
Append WCLOB,'"BPRFIN":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,19569)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":15'
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,',"$links":{'
Append WCLOB,'"$search$details":{'
Append WCLOB,'"$title":"Detail"'
Append WCLOB,',"$default":true'
Append WCLOB,',"$url":"{$baseUrl}/PROJET('+"'"+'{$key}'+"'"+')?representation=PROJET.$details"'
Append WCLOB,',"$devices":"desktop"'
Append WCLOB,"}"
Append WCLOB,"}"
Append WCLOB,"}"
End ERROR
