#<AdxTL>@(#)0.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Bug 81482
# Update the field OPT in table AFCTPRF with the following logic:
# If the table related to the function does not have a field ENAFLG
# then the option N should be removed if exists
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("Update field OPT in table AFCTPRF ") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJTAB
End

#----------------------------------------------------------------------------------------#

$MAJTAB

If DOSSIER=nomap
 Local File AFCTPRF [AFP]
Else
 Local File =DOSSIER+".AFCTPRF" [AFP]
Endif

If dim([F:AFP]OPT)<0
 Return
Endif

Trbegin [AFP]
 For [AFP]
  If instr(1,[F:AFP]OPT, "N")
   If !func SUBAFP.OPT([F:AFP]FNC)
    Call ECR_TRACE([F:AFP]PRFCOD-[F:AFP]FNC-[F:AFP]FCYGRU,0) From GESECRAN
    # remove "N"
    [F:AFP]OPT = ctrans([F:AFP]OPT,"N","") 
    Rewrite [AFP]
    If fstat
     Call ERREUR("AFCTPRF"-[F:AFP]PRFCOD-[F:AFP]FNC-[F:AFP]FCYGRU,3) From DOSDIC
    Endif
   Endif 
  Endif
 Next AFP
Commit

Close Local File [AFP]

Return
