#<AdxTL>@(#)6.0.0.0 $Revision$
#---------------------------------------------------------------------------#
# Actions liées aux allocations OF                                          #
# - SAIMFGALL    Gestion allocation OF                                      #
#---------------------------------------------------------------------------#
$ACTION
Case ACTION
    When "OUVRE":         Case GACTION
                              When "SAIMFGALL" : Gosub OUVRE_MFGALL
                          Endcase
    When "DEBUT":         Case GACTION
                              When "SAIMFGALL" : Gosub DEBUT_MFGALL
                          Endcase
    When "SETBOUT":       Case GACTION
                              When "SAIMFGALL" : Gosub SETBOUT_MFGALL
                          Endcase
    When "BOUTON":        Case GACTION
                              When "SAIMFGALL" : Gosub BOUTON_MFGALL
                          Endcase
    When "FIN":           Case GACTION
                              When "SAIMFGALL":  Gosub FIN_MFGALL
                          Endcase
    When Default
Endcase
Return

#---------------------------------------------------------------------------#
# Action SAIMFGALL                                                          #
#---------------------------------------------------------------------------#
###########################################################################
# ouverture
$OUVRE_MFGALL
Local    Char    WMFGNUM(GLONVCR) : WMFGNUM = PARAM(1)
Local    Char    WFCY(GLONFCY)
Local    Integer WTRKFLG
Local    Integer WRET
Local    Integer WLK  : WLK = 0       # 37403 mm 09.06
Local    Integer WDLK : WDLK = 0      # FQ 63906 GA 05/2010 pour ajout du Unlock

If clalev ([F:MFG]) <= 0 : Local File MFGHEAD    [MFG] : Endif

If dim(GALL) < 0 : Global Integer GALL : Endif
GALL = 0
Return

###########################################################################
# ouverture
$DEBUT_MFGALL

# lock OF - 37403 mm 09.06
WLK = 0
#Lock = "MFG"+WMFGNUM With lockwait = 0
#If fstat
#    WLK = 1
#Endif
# FQ 63906 GA 05/2010
If WDLK<>1 # FQ 63906 GA 05/2010 sauf si on l'a déjà locké ici
   WLK =  func TRTX3FNC.CHECK_LOCK("MFG",WMFGNUM,1,WDLK)
Endif

# lecture entête OF
If [F:MFG]MFGNUM <> WMFGNUM
    Read [MFG]MFG0=WMFGNUM
    If fstat : PARAM(2) = num$(1) : FIN = 1 : Return : Endif
Endif

WFCY     = [F:MFG]MFGFCY
WTRKFLG  = [F:MFG]MFGTRKFLG
[M:MFA1] = [F:MFG]
If [M:MFA1]MATLINNBR = 0 : PARAM(2) = num$(2) : FIN = 1 : Return : Endif
Case [M:MFA1]ALLSTA
    When 1,2,4 :  [M:MFA1]TALL = 1
    When 3,5   :  If [M:MFA1]OVRALLNBR <> 0
                      [M:MFA1]TALL = 1
                  Else
                      [M:MFA1]TALL = 2
                  Endif
Endcase
[M:MFA1]TDESALL = 1
# Point d'entrée choix allocation - 36160 mm 05.06
GPOINT = "ALLCHO" : Gosub ENTREE From EXEFNC
#
Affzo  [MFA1]
Return

###########################################################################
# ouverture
$SETBOUT_MFGALL
Case [M:MFA1]ALLSTA
    When 1 :     ETABOU(GSPE1) = 1                           # allocation
                 ETABOU(GSPE2) = 0                           # désallocation
                 ETABOU(GSPE3) = 0                           # visu allocation
    When 2,4:    ETABOU(GSPE1) = 1
                 ETABOU(GSPE2) = 1
                 ETABOU(GSPE3) = 1
    When 3,5:    If [M:MFA1]DETALLNBR = [M:MFA1]MATLINNBR
                     If [M:MFA1]SHTMATNBR = 0
                         ETABOU(GSPE1) = 0
                     Else
                         ETABOU(GSPE1) = 1
                     Endif
                 Else
                         ETABOU(GSPE1) = 1
                 Endif
                 ETABOU(GSPE2) = 1
                 ETABOU(GSPE3) = 1
Endcase
If GCONSULT = 1
    ETABOU(GSPE1) = 0
    ETABOU(GSPE2) = 0
Endif
If [F:MFG]MATCLENBR = [F:MFG]MATLINNBR
    ETABOU(GSPE1) = 0
    ETABOU(GSPE2) = 0
Endif

# 37403 mm 09.06
If WLK
    ETABOU(GSPE1) = 0
    ETABOU(GSPE2) = 0
    Diszo [M:MFA1]
Endif

Return

###########################################################################
# ouverture
$BOUTON_MFGALL
Case BOUT
    When "1"       :     # allouer
                         Call ALLOC_OF2("C", 1, WMFGNUM, [M:MFA1]TALL, [M:MFA1]TDESALL, "R", WRET)
                         If WRET = 0 : GALL = 1 : Endif
                         # relecture entête OF
                         Read [MFG]MFG0=WMFGNUM
                         If fstat : PARAM(2) = num$(1) : FIN = 1 : Return : Endif
                         Gosub DEBUT_MFGALL
    When "2"       :     # désallouer
                         Call ALLOC_OF2("A", 1, WMFGNUM, [M:MFA1]TALL, [M:MFA1]TDESALL, "R", WRET)
                         If WRET = 0 : GALL = 1 : Endif
                         # relecture entête OF
                         Read [MFG]MFG0=WMFGNUM
                         If fstat : PARAM(2) = num$(1) : FIN = 1 : Return : Endif
                         Gosub DEBUT_MFGALL
Endcase
FIN=0

Return

###########################################################################
# ouverture
$OK_MFGALL
Return

###########################################################################
# ouverture
$FIN_MFGALL
If WDLK=1 # FQ 63906 GA 05/2010 pour dé-locker l'OF si et seulement si on l'a locké ici
   Unlock = "MFG"+WMFGNUM
Endif
If GALL = 1
    Case GFONCTION
        When "FUNGBENCH" : If clalev ([M:MGD])=0
                               [M:MGB]REACT = 2
                               GLRET = 2
                               Gosub FABRICATION From FUNGBENCH
                           Else
                               [M:MGD]REACT = 2
                               GDLRET = 2
                               Gosub FABRICATION From FUNDBENCH
                           Endif
        When "FUNDBENCH" : If clalev ([M:MGB])=0
                               [M:MGD]REACT = 2
                               GDLRET = 2
                               Gosub FABRICATION From FUNDBENCH
                           Else
                               [M:MGB]REACT = 2
                               GLRET = 2
                               Gosub FABRICATION From FUNGBENCH
                           Endif
        When "FUNBENPLT" : If dim([M:MBP]REACT)
                               [M:MBP]REACT = 2
                               Gosub PILOTAGE From FUNBENPLT
                               GLRET = 2
                           Endif
     Endcase
Endif
Return

###########################################################################
#                                                                         #
#    TRAITEMENTS LIES aux ALLOCATIONS dans la GPAO                        #
#                                                                         #
###########################################################################
#-------------------------------------------------------------------------#
# ALLOC_OF  : Sous-programme d'allocation d'un OF                         #
#             Génération des allocations dans le fichier STOALL           #
#                        par appel des composants d'allocations de STKALL #
#-------------------------------------------------------------------------#
# Prérequis : L'écran paramêtre ALLPAR doit être ouvert                   #
#-------------------------------------------------------------------------#
# Entrée  LTRT       : Type de traitement                                 #
#                            "C" : Création d'une allocation              #
#                            "M" : Modification                           #
#                            "A" : Annulation                             #
#                            "E" : Passage global/détail                  #
#         LTRS       : Mode transaction (LTRS=1 pour transaction)         #
#         LMFGNUM    : Numéro OF                                          #
#         LALLTYP    : Type alloc (1 = global, 2  = détail)               #
#         LDESALL    : Type désallocation (1 = complète, 2 = par type)    #
#         LRET       : Code retour                                        #
#                             0 : OK                                      #
#                             1 : Erreur                                  #
#-------------------------------------------------------------------------#
Subprog ALLOC_OF(LTRT, LTRS, LMFGNUM, LALLTYP, LDESALL, LRET)
Value     Char     LTRT
Value     Integer  LTRS
Value     Char     LMFGNUM
Value     Integer  LALLTYP
Value     Integer  LDESALL
Variable  Integer  LRET

Call ALLOC_OF2(LTRT, LTRS, LMFGNUM, LALLTYP, LDESALL, "", LRET)
End

Subprog ALLOC_OF2(LTRT, LTRS, LMFGNUM, LALLTYP, LDESALL, LSUP, LRET)
Value     Char     LTRT
Value     Integer  LTRS
Value     Char     LMFGNUM
Value     Integer  LALLTYP
Value     Integer  LDESALL
Value     Char     LSUP
Variable  Integer  LRET

Local     Integer  WALLTYP
Local     Integer  WRET
Local     Decimal  WCPLQTY
Local     Decimal  WALL, WSHT
Local     Integer  MEMSTA
Local     Char     WCLE(50)
Local     Integer  WLIN
Local     Integer  WSEQ
Local     Char     WITM(GLONITM)
Local     Integer  WALLTYP
Local     Char     WTRT(1)
Local     Char     WPARAM(10)
Local     Char     WSUP(1)

# ouverture tables
If clalev([F:MFM]) = 0 : Local File MFGMAT    [MFM] : Endif
If clalev([F:ORD]) = 0 : Local File ORDERS    [ORD] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER [ITM] : Endif

# ouverture écrans
If clalev([M:ORDK])= 0 : Local Mask ORDK   [ORDK] : Endif
If clalev([M:ALP]) = 0 : Local Mask ALLPAR [ALP]  : Endif

# début de la transaction d'allocation
GOK  = 1
LRET = 0
WTRT = LTRT
If LTRS = 1 : Call DEBTRANS From GLOCK : Endif
$TR_ALLOC
If LTRS = 1 : Trbegin ADOVAL           : Endif

# lecture entête OF
Readlock [MFG]MFG0=LMFGNUM
If    fstat = 1  : GOK = -1 : LRET = 1 : GLOCK="$MFGHEAD"-LMFGNUM             : Goto ROLL_ALLOC
Elsif fstat      : GOK =  0 : LRET = 1 : Call RSTA("MFG", LMFGNUM) From GLOCK : Goto AB_ALLOC    : Endif

# on connait le site, récupération du paramètre stock : MARGE alerte péremption jours
#Call PARAM([F:MFG]MFGFCY,"MARPER",WPARAM) From ADOVAL                                  # hcb v6per
#GSMARPER = val(WPARAM)                                                                 #hcb v6per

# parcours des composants de l'OF
# Issue 80560 - 2012-03-09 by CCC : Ne pas modifier le statut d'alloc sur les matières déjà consommées
#For [MFM]MFM0 Where MFGNUM=LMFGNUM
# Issue 88151 - 2013-03-07 by CCC
#For [MFM]MFM0 Where MFGNUM=LMFGNUM & RETQTY>USEQTY
For [MFM]MFM0 Where MFGNUM=LMFGNUM & (RETQTY>USEQTY |RETQTY=0)

    # point d'entrée choix allocation matière - 42359 mm 07.07
    GPE = 0
    GPOINT = "ALLCHOMAT" : Gosub ENTREE From EXEFNC
    If GPE   : Goto SUIV : Endif

    # si matière soldée/exclue pas de traitement
    If LTRT <> "A" & [F:MFM]MATSTA > 2 : Goto SUIV : Endif
    If [F:MFM]CPNTYP = 5 : Goto SUIV : Endif      # Issue 94453 GA 11/2013

    LTRT = WTRT
    WLIN = [F:MFM]MFGLIN
    WSEQ = [F:MFM]BOMSEQ
    WITM = [F:MFM]ITMREF
    # mémo statut
    MEMSTA = [F:MFM]ALLSTA

    # si désallocation et matière non allouée, pas de traitement
    If LTRT = "A" & [F:MFM]ALLSTA = 1    : Goto SUIV : Endif

    # si désallocation des globales uniquement et allocation détail, pas de traitement
    If LTRT = "A" & LDESALL = 2 & LALLTYP = 1 & !find([F:MFM]ALLSTA,2,3) : Goto SUIV : Endif

    # si désallocation des détails uniquement et allocation globale, pas de traitement
    If LTRT = "A" & LDESALL = 2 & LALLTYP = 2 & !find([F:MFM]ALLSTA,4,5) : Goto SUIV : Endif

    # 44409 mm 06.08 -  Si la matière a le statut en cours de pesée, pas de désallocation
    # 85521 mm 11.12 - WGGBOX géré pour la pesée par OF :
    # c'est lui qui porte l'info "matière en cours de pesée box" à la place de WGGSTA
    If dim([F:MFM]WGGBOX)>0
        If LTRT = "A" & ( LDESALL = 1 | LDESALL = 2 & LALLTYP = 2 )
            If [F:MFM]ALLSTA >= 4  & [F:MFM]WGGBOX=2  : Goto SUIV : Endif
        Endif
    Endif

    # si demande allocation globale et matière allouée détail, pas de traitement
    If LTRT = "C" & LALLTYP = 1 & [F:MFM]ALLSTA > 3 : Goto SUIV : Endif

    # si passage de global vers détail, mode "E"
    If (LTRT = "C" & LALLTYP = 2 & [F:MFM]ALLSTA > 1 & [F:MFM]ALLSTA < 4) : LTRT = "E" : Endif

    Case LTRT
        When "C","M": If [F:MFM]ALLQTY = 0 & [F:MFM]SHTQTY = 0
                          TRTLIG = "C"
                      Else
                          TRTLIG="M"
                      Endif
                      WALL    = [F:MFM]RETQTY - [F:MFM]ALLQTY - [F:MFM]SHTQTY - [F:MFM]USEQTY
                      WSHT    = [F:MFM]SHTQTY
                      WALLTYP = LALLTYP
                      # Issue 88151 - 2013-03-07 by CCC
                      #If WALL <= 0 & WSHT <= 0 : Goto SUIV : Endif
                      If [F:MFM]RETQTY<>0 & WALL <= 0 & WSHT <= 0 : Goto SUIV : Endif
        When "A":     TRTLIG  = "A"
                      WALL    = [F:MFM]ALLQTY
                      WSHT    = [F:MFM]SHTQTY
                      If LDESALL = 1
                          Case [F:MFM]ALLSTA
                               When 2,3: WALLTYP = 1
                               When 4,5: WALLTYP = 2
                          Endcase
                      Else
                          WALLTYP = LALLTYP
                      Endif
        When "E":     TRTLIG  = "E"
                      WALL    = [F:MFM]ALLQTY
                      WSHT    = [F:MFM]SHTQTY
                      WALLTYP = LALLTYP
                      # Issue 88151 - 2013-03-07 by CCC
                      #If WALL <= 0 & WSHT <= 0 : Goto SUIV : Endif
                      If [F:MFM]RETQTY<>0 & WALL <= 0 & WSHT <= 0 : Goto SUIV : Endif
    Endcase

    Readlock [MFM]MFM0=LMFGNUM;WLIN;WSEQ;WITM
    WCLE = LMFGNUM-num$([F:MFM]MFGLIN)-num$([F:MFM]BOMSEQ)-[F:MFM]ITMREF
    If fstat=1
           GOK = -1 : LRET = 1 : GLOCK="$MFGMAT"-WCLE              : Goto ROLL_ALLOC
        Elsif fstat
           GOK =  0 : LRET = 1 : Call RSTA("MFM", WCLE) From GLOCK : Goto AB_ALLOC
        Endif

        # appel à la routine de gestion des allocations
        If instr(1,LSUP,"R")
            WSUP="R"
        Endif
        Call ALLOCATION2(TRTLIG, WALLTYP, WSUP, WALL, WSHT, WRET)
        If WRET  = 9             # llc 07.01 9308
            Rewrite [MFM]
            WRET = 0
            Goto SUIV
        Endif
        If WRET <> 0 : LRET = 1 : Goto AB_ALLOC : Endif

        # mise à jour matière
        Case LTRT
            When "C","M": [F:MFM]ALLQTY    += WALL
                          [F:MFM]SHTQTY     = WSHT
                          Case LALLTYP
                            When 1: [F:MFM]ALLSTA = 3
                            When 2: [F:MFM]ALLSTA = 5
                          Endcase
            When "A":     [F:MFM]ALLQTY     = 0
# Issue 84767 - 2012-11-13 by CCC
#                          [F:MFM]SHTQTY     = 0
                          [F:MFM]SHTQTY     -= WSHT
                          If [F:MFM]SHTQTY=0
                            [F:MFM]ALLSTA     = 1
                          Else
                            [F:MFM]ALLSTA += 1
                          Endif
            When "E":     [F:MFM]ALLQTY     = WALL
                          [F:MFM]SHTQTY     = WSHT
                          [F:MFM]ALLSTA     = 5
        Endcase
        # si rupture, maj statut allocation
        If [F:MFM]SHTQTY <> 0 : [F:MFM]ALLSTA -= 1 : Endif
        # point d'entrée pour modifier spécifiquement les données d'allocation - 09.07 mm 42605
        GPOINT = "MFMMAJ" : Gosub ENTREE From EXEFNC
        # mise à jour matière
        Rewrite [MFM]
        If fstat : GOK=0 : LRET = 1 : Call FSTA("MFM") From GLOCK : Goto AB_ALLOC : Endif
        # lecture encours pour récupérer le n° affaire
        Read [ORD]ORD0=6;[F:MFM]WIPNUM;[F:MFM]ITMREF
        # mise à jour de l'encours
        Call UPDATE_MFX("M", [F:ORD]PJT, [F:ORD]BOMALT, 0) From MFGLIBM

        # FQ 70409 GA 01/2011
        #Gosub MAJMFG

        # v6 affectations
        Gosub MAJ_MTO_MFM From MFGMTOLIB
$SUIV
    Next

  # FQ 70409 GA 01/2011 maj de l'entete d'OF
    Gosub MAJMFGHEAD From MFGLIB

    # 82781
    [F:MFG]UPDDAT = date$
    [F:MFG]UPDUSR = GUSER
    [F:MFG]EXPNUM = [C]EXPORT

    Rewrite [MFG]
    If fstat=1  GOK=-1: LRET = 1 : GLOCK="$MFGHEAD"-LMFGNUM             : Goto ROLL_ALLOC
    Elsif fstat GOK=0 : LRET = 1 : Call RSTA("MFG", LMFGNUM) From GLOCK : Goto AB_ALLOC : Endif
#
$TR_FIN
If LTRS = 1
    Commit
Endif
End

$ROLL_ALLOC
If LTRS = 1
    Rollback  : Call ROLL From GLOCK
    If !GROLL : LRET = 0 : Goto TR_ALLOC : Endif
Endif
End

$AB_ALLOC
If LTRS = 1
    Rollback
Endif
End

###########################################################################
#-------------------------------------------------------------------------#
# ALLOCATION: sous-programme d'allocation                                 #
#-------------------------------------------------------------------------#
# Entrée                                                                  #
#         LTRTLIG    : Type de traitement                                 #
#                            "C" : Création d'une allocation              #
#                            "M" : Modification                           #
#                            "D" : Diminution                             #
#                            "A" : Annulation                             #
#                            "E" : Evolution (global vers détail)         #
#         LALLTYP    : Type allocation                                    #
#         LALL       : Quantité à allouer                                 #
# Sortie  LALL       : Quantité réellement allouée                        #
#         LSHT       : Quantité rejettée                                  #
#         LRET       : Code retour                                        #
#-------------------------------------------------------------------------#
Subprog ALLOCATION(LTRTLIG, LALLTYP, LALL, LSHT, LRET)
Value    Char    LTRTLIG
Value    Integer LALLTYP
Variable Decimal LALL
Variable Decimal LSHT
Variable Integer LRET

Call ALLOCATION2(LTRTLIG, LALLTYP, "", LALL, LSHT, LRET)

End

Subprog ALLOCATION2(LTRTLIG, LALLTYP, LSUP, LALL, LSHT, LRET)
Value    Char    LTRTLIG
Value    Integer LALLTYP
Value    Char    LSUP
Variable Decimal LALL
Variable Decimal LSHT
Variable Integer LRET
#
Local    Char    WFCY(GLONFCY)    :       WFCY = [F:MFM]MFGFCY
Local    Char    WITM(GLONITM)    :       WITM = [F:MFM]ITMREF            # 09.05 31984
Local    Char    WNUM(GLONVCR)    :       WNUM = [F:MFM]MFGNUM
Local    Decimal WLIN             :       WLIN = [F:MFM]MFGLIN
Local    Integer WTYP             :       WTYP = 10
Local    Decimal WSEQ             :       WSEQ = [F:MFM]BOMSEQ
Local    Integer L                :       L    = nolign-1
Local    Decimal WALLSTU, WSHTSTU, WALLQTY, WSHTQTY, WSHTQTYSUP, WQTY
Local    Integer WOPT
Local    Integer WRUP             :       WRUP      = 1                    # on génère toujours les ruptures
Local    Integer WALLPAR          :       WALLPAR   = 0                    # allocations partielles toujours autorisées pour
                                                                           # avoir des ruptures (vu avec TS 05.05)
Local    Char    WMAJ(1)          :       WMAJ      = "C"
Local    Integer WRET
Local    Integer WRGT             :       If instr(1,LSUP,"R") : WRGT=10 Else WRGT=0 : Endif
Local    Integer I                :       I = 0       # 96067 mm 04.2014
Local    Integer WFIND            :       WFIND = 0   # 96067 mm 04.2014

If GFONCTION = "FUNSCA"
Local    Char    DEPOT(GLONWRH)   : DEPOT      = ""    # Cdp mm 03.11
Local    Char    LOC(GLONEMP)     : LOC        = ""    # emplacement - Cdp mm 01.11
Endif

# paramètres allocation (il est préférable de l'ouvrir en amont)
If clalev([M:ALP]) = 0 : Local Mask ALLPAR [ALP]  : Endif

LRET = 0

# lecture ITM si nécessaire
If [F:ITM]ITMREF <> [F:MFM]ITMREF
    Read [ITM]ITM0=[F:MFM]ITMREF
    If fstat : Raz [F:ITM] : Endif
Endif
# lecture ITF si nécessaire
If [F:ITF]ITMREF <> [F:MFM]ITMREF | [F:ITF]STOFCY <> [F:MFM]MFGFCY
    Read [ITF]ITF0=[F:MFM]ITMREF;[F:MFM]MFGFCY
    If fstat : Raz [F:ITF] : Endif
Endif

# point d'entrée filtre allocation
GPOINT = "MFMALL" : Gosub ENTREE From EXEFNC
If WRET <> 0 : LRET = WRET : Goto FIN_ALLOCATION : Endif

# Alimentation de la classe ecran ALLPAR
Raz [M:ALP]
[M:ALP]TRSTYP    = 0
[M:ALP]VCRTYP    = WTYP
[M:ALP]VCRNUM    = WNUM
[M:ALP]VCRLIN    = WLIN
[M:ALP]VCRSEQ    = WSEQ
[M:ALP]STOFCY    = [F:MFM]MFGFCY
[M:ALP]ITMREF    = [F:MFM]ITMREF
[M:ALP]PCU       = [F:MFM]STU
[M:ALP]PCUSTUCOE = 1
[M:ALP]TYPQTY    = 2
If GFONCTION = "FUNSCA"   # 41612 mm 06.07
    [M:ALP]BESDAT    = date$
    [M:ALP]DLVDAT    = [0/0/0]
Else
    [M:ALP]BESDAT    = [F:MFM]RETDAT
    [M:ALP]DLVDAT    = [F:MFM]RETDAT
Endif
[M:ALP]PECRER    = 1
[M:ALP]PECINTLOC = 2
[M:ALP]PECPLFLOC = 2                                                               # Prise en cpte empl quai : Oui ?
[M:ALP]PECCUNLOK = 2                                                               # Prise en cpte stock en cours inventaire : Oui ?
If [F:MFM]SCOFLG = 2                                                               # Prise en compte emplacements sous-traitants
    [M:ALP]PECSCOLOC = 2
    # on renseigne le tiers et l'adresse, on prend le premier tiers trouvé (approximation en cas de splittage)
    If [F:MFM]BOMOPE <> 0
        If clalev([F:MFO])  = 0 : Local File MFGOPE [MFO] : Endif
        Filter [MFO] Where MFGNUM=[F:MFM]MFGNUM & OPENUM=[F:MFM]BOMOPE
&                    Order By Key MFO0
        For [MFO]
             WFIND = 1
            [M:ALP]BPRNUM = [F:MFO]BPRNUM
            [M:ALP]BPAADD = [F:MFO]BPAADD
            If [M:ALP]BPRNUM <> "" : Break : Endif
        Next
        Filter [MFO]
        # 96067 mm 04.2014 : enregistrement pas encore créé dans [MFO]
        If !WFIND & clalev([M:MFG3]) : # If !WFIND : # GH 23/05/2016 bug 107273 - in some contexts [M:MFG3] seems to be absent
          For I=0 To [M:MFG3]NBLIG-1
             If [F:MFM]BOMOPE = [M:MFG3]OPENUM(I)
                Read [MWS]WST0= [M:MFG3]EXTWST(I);[M:MFG0]MFGFCY
                If !fstat
                   [M:ALP]BPRNUM = [M:MFG3]BPRNUM(I)
                   [M:ALP]BPAADD = [M:MFG3]BPAADD(I)
                   If [M:ALP]BPRNUM <> "" : Break : Endif
                Endif
             Endif
          Next I
        Endif
    Endif
Else
    [M:ALP]PECSCOLOC = 1
Endif
[M:ALP]LOT       = [F:MFM]LOT
[M:ALP]STOLOC    = [F:MFM]LOC
[M:ALP]STA       = [F:MFM]STA
[M:ALP]PECQLYCTL = 2
WSHTQTY     = LSHT
WALLQTY     = LALL
Raz [M:ALP]WRH
# Issue 107513 - 2015-04-29 by JUSYN : ECC for table MFGMAT
If dim([M:ALP]ECCVALMAJ)>0 & [F:ITM]ECCSTO>1
   [M:ALP]ECCVALMAJ=[F:MFM]ECCVALMAJ
Endif
If dim([M:ALP]ECCVALMIN)>0 & [F:ITM]ECCSTO>2
   [M:ALP]ECCVALMIN=[F:MFM]ECCVALMIN
Endif
# mm 03.11
If GFONCTION = "FUNSCA"
  Call LEC_WRH(DEPOT,LOC) From SCALEXCHAN
  [M:ALP]WRH = DEPOT
  # Issue 83364 - 2012-07-06 by SR
  [M:ALP]STOLOC = LOC
Endif

Case LTRTLIG
     When "C" : # ------ Création     -----------
        [M:ALP]QTY = WALLQTY
        Call GENSTOALL(WMAJ, LALLTYP, WRUP, WALLPAR, LRET) From STKALL
        If LRET <> 0  : End : Endif
#       Quantité qui a été allouée
        WALLSTU = [M:ALP]ALLQTY
#       Quantité rupture
        WSHTSTU = [M:ALP]ALLQTYSHT
     When "M" : # ------ Modification -----------
        # point d'entrée pour respecter la contrainte mono-lot en cas d'augmentation de la quantité lancée - 63248 mm 03.10
        GPE = 0 : GPOINT = "MODALLMAT" : Gosub ENTREE From EXEFNC
        If !GPE
# ----- Suppression de l'allocation existante sur les manquants
          If  WSHTQTY <> 0
              # Issue 84767 - 2012-11-13 by CCC : +10 pour ne pas supprimer les listes à ranger
              WOPT = 2 + WRGT    : # suppression manquants seuls
              WQTY = 0 : WSHTQTYSUP = 0
              Call DELALL(WTYP, WNUM, WLIN, WSEQ, WITM, WOPT, WQTY, WSHTQTYSUP, LRET) From STKALL
              If LRET <> 0  : End : Endif
  #           On enlève de la quantité rupture les manquants reellement supprimés
              WSHTQTY -= WSHTQTYSUP
          Endif
# ----- Allocation de la nouvelle qté + les manquants supprimés
          WALLQTY = WALLQTY + WSHTQTYSUP
          [M:ALP]QTY = WALLQTY
          If WALLQTY<>0
              Call GENSTOALL(WMAJ, LALLTYP, WRUP, WALLPAR, LRET) From STKALL
              If LRET <> 0  : End : Endif
          Endif
  #       Quantité qui a été allouée
          WALLSTU = [M:ALP]ALLQTY
  #       On ajoute à la quantité déjà en rupture la nouvelle quantité rupture générée
          WSHTQTY += [M:ALP]ALLQTYSHT
          WSHTSTU = WSHTQTY
        Endif
     When "A" : # ------ Annulation   -----------
        # Issue 84767 - 2012-11-13 by CCC : +10 pour ne pas supprimer les listes à ranger
        WOPT = 0 + WRGT    :     # suppression allocations + manquants
        WALLQTY = 0 : WSHTQTYSUP = 0
        Call DELALL(WTYP, WNUM, WLIN, WSEQ, WITM, WOPT, WALLQTY, WSHTQTYSUP, LRET) From STKALL
        If LRET <> 0  : End : Endif
#       Quantité allouée qui a été supprimée
        WALLSTU=WALLQTY
        WSHTSTU=WSHTQTYSUP
     When "D" : # ------ Diminution -----------
        WQTY = WALLQTY + WSHTQTY
        If WQTY <> 0
            WOPT=0                              : # 0 : diminution manquant puis allocation
            If WALLQTY <> 0
                If WSHTQTY = 0 WOPT=1 Endif     : # 1 : diminution allocations seules
            Elsif WSHTQTY <> 0
                WOPT = 2                        : # 2 : diminution manquant seuls
            Endif
            WOPT += WRGT
            Call DIMALL(WTYP, WNUM, WLIN, WSEQ, WITM, WOPT, WQTY, WALLQTY, WSHTQTY, LRET) From STKALL
            If LRET <> 0  : End : Endif
#           Quantité allouée qui a été diminuée
            WALLSTU = WALLQTY
            WSHTSTU = WSHTQTY
        Endif
     When "E" : # ------ Passage de global à détail -----------
# ----- suppression allocations + manquants
        WOPT = 0 + WRGT   :
        WALLQTY = 0 : WSHTQTYSUP = 0
        Call DELALL(WTYP, WNUM, WLIN, WSEQ, WITM, WOPT, WALLQTY, WSHTQTYSUP, LRET) From STKALL
        If LRET <> 0  : End : Endif

# ----- créatoin nouvelles allocations
        [M:ALP]QTY = LALL + LSHT
        Call GENSTOALL(WMAJ, LALLTYP, WRUP, WALLPAR, LRET) From STKALL
        If LRET <> 0  : End : Endif
#       Quantité qui a été allouée
        WALLSTU = [M:ALP]ALLQTY
#       Quantité rupture
        WSHTSTU = [M:ALP]ALLQTYSHT
     When Default :
        End
Endcase
LALL = WALLSTU
LSHT = WSHTSTU
$FIN_ALLOCATION
# Issue 93646 GA 01/2014
# point d'entrée pour traitement particulier en cas de rupture
If LSHT>0
   GPOINT = "CTLSHTMAT" : Gosub ENTREE From EXEFNC
Endif
If LRET <> 0  : LALL =0   : Endif
End

#########################################################################
# Allocation d une matière d un of                                      #
#########################################################################
Subprog ALLOC_MAT(LTRT, LTRS, LMFGNUM, LALLTYP, LDESALL, LRET, LITM, LLIN, LSEQ, QTYBESOIN)
Value     Char     LTRT
Value     Integer  LTRS
Value     Char     LMFGNUM
Value     Integer  LALLTYP
Value     Integer  LDESALL
Variable  Integer  LRET
Value     Char     LITM
Value     Integer  LLIN
Value     Integer  LSEQ
Value     Decimal  QTYBESOIN

Local     Integer  WALLTYP
Local     Integer  WRET
Local     Decimal  WCPLQTY
Local     Decimal  WALL, WSHT, WECART
Local     Integer  MEMSTA
Local     Char     WCLE(50)
Local     Integer  WALLTYP
Local     Char     WTRT(1)

If clalev([F:MFG]) = 0 : Local File MFGHEAD [MFG] : Endif
If clalev([F:MFM]) = 0 : Local File MFGMAT  [MFM] : Endif
If clalev([F:ORD]) = 0 : Local File ORDERS  [ORD] : Endif

If clalev([M:ORDK])= 0 : Local Mask ORDK    [ORDK] : Endif

# début de la transaction d'allocation
GOK=1
LRET=0
WTRT = LTRT
If LTRS = 1
    Call DEBTRANS From GLOCK
Endif
$TR_ALLOCMAT
If LTRS = 1
    Trbegin ADOVAL
Endif

    Readlock [MFG]MFG0=LMFGNUM
    If fstat=1  : GOK=-1: LRET = 1 : GLOCK="$MFGHEAD"-LMFGNUM             : Goto ROLL_ALLOCMAT
    Elsif fstat : GOK=0 : LRET = 1 : Call RSTA("MFG", LMFGNUM) From GLOCK : Goto AB_ALLOCMAT: Endif
#
    Readlock [MFM]MFM0=LMFGNUM;LLIN;LSEQ;LITM
        WCLE = LMFGNUM-num$([F:MFM]MFGLIN)-num$([F:MFM]BOMSEQ)-[F:MFM]ITMREF
        If fstat=1
           GOK=-1: LRET = 1 : GLOCK="$MFGMAT"-WCLE              : Goto ROLL_ALLOCMAT
        Elsif fstat
           GOK=0 : LRET = 1 : Call RSTA("MFM", WCLE) From GLOCK : Goto AB_ALLOCMAT
        Endif

        If LTRT <> "A" & [F:MFM]MATSTA > 2  : Goto SUIVMAT : Endif
        If [F:MFM]CPNTYP = 5 : Goto SUIVMAT : Endif      # Issue 94453 GA 11/2013

        LTRT = WTRT
        # mémo statut
        MEMSTA = [F:MFM]ALLSTA
        # si désallocation et matière non allouée, pas de traitement
        If LTRT = "A" & [F:MFM]ALLSTA = 1    : Goto SUIVMAT : Endif
        # si désallocation des globales uniquement et allocation détail, pas de traitement
        If LTRT = "A" & LDESALL = 2 & LALLTYP = 1 & !find([F:MFM]ALLSTA,2,3) : Goto SUIVMAT : Endif
        # si désallocation des détails uniquement et allocation globale, pas de traitement
        If LTRT = "A" & LDESALL = 2 & LALLTYP = 2 & !find([F:MFM]ALLSTA,4,5) : Goto SUIVMAT : Endif
        # si demande allocation globale et matière allouée détail, pas de traitement
        If LTRT = "C" & LALLTYP = 1 & [F:MFM]ALLSTA > 3 : Goto SUIVMAT : Endif
        # si passage de global vers détail, mode "E"
        If ( LTRT = "C" & LALLTYP=2 & [F:MFM]ALLSTA > 1 & [F:MFM]ALLSTA < 4)
           LTRT = "E"
        Endif

        # si désallocation et matière non allouée, pas de traitement
        If LTRT = "R" & [F:MFM]ALLSTA = 1    : Goto SUIVMAT : Endif
        # si désallocation des globales uniquement et allocation détail, pas de traitement
        If LTRT = "R" & LDESALL = 2 & LALLTYP = 1 & !find([F:MFM]ALLSTA,2,3) : Goto SUIVMAT : Endif
        # si désallocation des détails uniquement et allocation globale, pas de traitement
        If LTRT = "R" & LDESALL = 2 & LALLTYP = 2 & !find([F:MFM]ALLSTA,4,5) : Goto SUIVMAT : Endif

        Case LTRT
            When "C","M":
                          If [F:MFM]ALLQTY = 0 & [F:MFM]SHTQTY = 0
                              TRTLIG = "C"
                          Else
                              TRTLIG="M"
                          Endif
                          WALL    = [F:MFM]RETQTY - [F:MFM]ALLQTY - [F:MFM]SHTQTY - [F:MFM]USEQTY
                          WSHT    = [F:MFM]SHTQTY
                          WALLTYP = LALLTYP
                          # 87563 mm 02.2013 : cas particulier des excipients dans la cdp
                          If (dim([F:MFM]PKC)>0 & (find([F:MFM]PKC,4,5,6,7,10)))
                            If [F:MFM]ALLQTY >= QTYBESOIN : Goto SUIVMAT : Endif
                            # mm 05.2013 - suite APCPRD-2876
                            # Si on a généré de la rupture, c'est qu'on a dû désallouer
                            # des alloc. de l'OF non conformes au box de pesée
                            If GPRIALL = 2
                              If [F:MFM]SHTQTY : Raz  QTYBESOIN : Endif
                            Endif
                          Endif
                          If QTYBESOIN <> 0
                              WALL = QTYBESOIN
                          Endif
                          # Issue 88151 - 2013-03-07 by CCC
                          #If WALL <= 0 & WSHT <= 0 : Goto SUIVMAT : Endif
                          If [F:MFM]RETQTY<>0 & WALL <= 0 & WSHT <= 0 : Goto SUIVMAT : Endif
            When "A":     TRTLIG  = "A"
                          WALL    = [F:MFM]ALLQTY
                          WSHT    = [F:MFM]SHTQTY
                          If LDESALL = 1
                              Case [F:MFM]ALLSTA
                                   When 2,3: WALLTYP = 1
                                   When 4,5: WALLTYP = 2
                              Endcase
                          Else
                              WALLTYP = LALLTYP
                          Endif
            When "R":     TRTLIG  = "A"
                          WALL    = [F:MFM]RETQTY - [F:MFM]ALLQTY - [F:MFM]SHTQTY - [F:MFM]USEQTY
                          WSHT    = [F:MFM]SHTQTY
                          If LDESALL = 1
                              Case [F:MFM]ALLSTA
                                   When 2,3: WALLTYP = 1
                                   When 4,5: WALLTYP = 2
                              Endcase
                          Else
                              WALLTYP = LALLTYP
                          Endif
                          If WALL <= 0 & WSHT <= 0 : Goto SUIVMAT : Endif
            When "E":     TRTLIG  = "E"
                          WALL    = [F:MFM]ALLQTY
                          WSHT    = [F:MFM]SHTQTY
                          WALLTYP = LALLTYP
                          # Issue 88151 - 2013-03-07 by CCC
                          #If WALL <= 0 & WSHT <= 0 : Goto SUIVMAT : Endif
                          If [F:MFM]RETQTY<>0 & WALL <= 0 & WSHT <= 0 : Goto SUIVMAT : Endif
        Endcase


        # appel à la routine de gestion des allocations
        Call ALLOCATION(TRTLIG, WALLTYP, WALL, WSHT, WRET)
        If WRET  = 9
            Rewrite [MFM]
            WRET = 0
            Goto SUIVMAT
        Endif
        If WRET <> 0 : LRET = 1 : Goto AB_ALLOCMAT : Endif

        # mise à jour matière
        Case LTRT
            When "C","M": [F:MFM]ALLQTY    += WALL
                          [F:MFM]SHTQTY     = WSHT
                          Case LALLTYP
                            When 1: [F:MFM]ALLSTA = 3
                            When 2: [F:MFM]ALLSTA = 5
                          Endcase
            When "A","R": [F:MFM]ALLQTY     = 0
                          [F:MFM]SHTQTY     = 0
                          [F:MFM]ALLSTA     = 1
            When "E":     [F:MFM]ALLQTY     = WALL
                          [F:MFM]SHTQTY     = WSHT
                          [F:MFM]ALLSTA     = 5
        Endcase
        # si rupture, maj statut allocation
        If [F:MFM]SHTQTY <> 0 : [F:MFM]ALLSTA -= 1 : Endif
        # point d'entrée pour modifier spécifiquement les données d'allocation - 09.07 mm 42605
        GPOINT = "MFMMAJ" : Gosub ENTREE From EXEFNC
        # mise à jour matière
        Rewrite [MFM]
        If fstat : GOK=0 : LRET = 1 : Call FSTA("MFM") From GLOCK : Goto AB_ALLOCMAT : Endif
        # lecture encours pour récupérer le n° affaire
        Read [ORD]ORD0=6;[F:MFM]WIPNUM;[F:MFM]ITMREF
        # mise à jour de l'encours
        Call UPDATE_MFX("M", [F:ORD]PJT, [F:ORD]BOMALT, 0) From MFGLIBM

        # FQ 70409 GA 01/2011 Maj déplacée + tard pour performances
        # mise à jour entête
        ##### Gosub MAJMFG
        # v6 affectations
        Gosub MAJ_MTO_MFM From MFGMTOLIB
$SUIVMAT

  # FQ 70409 GA 01/2011 maj de l'entete d'OF
   Gosub MAJMFGHEAD From MFGLIB

   # 82781
   [F:MFG]UPDDAT = date$
   [F:MFG]UPDUSR = GUSER
   [F:MFG]EXPNUM = [C]EXPORT
   Rewrite [MFG]
   If fstat=1  GOK=-1: LRET = 1 : GLOCK="$MFGHEAD"-LMFGNUM             : Goto ROLL_ALLOC
   Elsif fstat GOK=0 : LRET = 1 : Call RSTA("MFG", LMFGNUM) From GLOCK : Goto AB_ALLOC : Endif
#
$TR_FINMAT
If LTRS = 1
    Commit
Endif
End

$ROLL_ALLOCMAT
If LTRS = 1
    Rollback  : Call ROLL From GLOCK
    If !GROLL : LRET = 0 : Goto TR_ALLOCMAT : Endif
Endif
End

$AB_ALLOCMAT
If LTRS = 1
    Rollback
Endif


End

#########################################################################
# Purge des ruptures sur un emplacement approvisionné                   #
# llc 02.02
#########################################################################
Subprog ALLOC_APPROMAT(LTRS, LFCY, LITM, LLOC, LRET)
Value     Integer  LTRS
Value     Char     LFCY
Value     Char     LITM
Value     Char     LLOC
Variable  Integer  LRET

Local     Char     WMESS(85)
Local     Char     WMESS1(85)
Local     Char     WMESS2(85)
Local     Integer  WRET

If clalev([F:MFM]) = 0 : Local File MFGMAT  [MFM] : Endif
If clalev([F:STA]) = 0 : Local File STOALL  [STA]  : Endif

Filter [MFM] Where MFGFCY = LFCY &
&                  ITMREF = LITM &
&                  LOC    = LLOC
For [MFM]MFM1                                    # llc 05.02 14394 Performances
    Filter [STA] Where STOFCY = [F:MFM]MFGFCY &
&                      ITMREF = [F:MFM]ITMREF &
&                      VCRTYP = 10            &
&                      VCRNUM = [F:MFM]MFGNUM &
&                      VCRLIN = [F:MFM]MFGLIN &
&                      VCRSEQ = [F:MFM]BOMSEQ &
&                      ALLTYP = 4
    For [STA]
        If fstat : Break : Endif
        Call ALLOC_MAT("C", LTRS, [F:MFM]MFGNUM, 2, 0, WRET, [F:MFM]ITMREF, [F:MFM]MFGLIN, [F:MFM]BOMSEQ, 0) From MFGALL
        If WRET = 1
            LRET = 1
            # FQ 69909 Ctrl des sources avant 2 x Filter + End
        Endif
        Break
    Next
    Filter [STA]
    If LRET=1 Break Endif # FQ 69909 Ctrl des sources ligne ajoutée suite au remplacement du End
Next
Filter [MFM]

End

#########################################################################
# Mise à jour matière après allocation manuelle                         #
#########################################################################
Subprog MAJALLMAT(LNUM, LLIN, LSEQ, LITM, LQTY, LSHT, LMOD, LRET)
Value     Char     LNUM
Value     Integer  LLIN
Value     Integer  LSEQ
Value     Char     LITM
Value     Decimal  LQTY
Value     Decimal  LSHT
Value     Integer  LMOD
Variable  Integer  LRET

# FQ 70409 GA 01/2011 nouvelle fonction simplifiée pour les performances
Call MAJALLMAT2(LNUM, LLIN, LSEQ, LITM, LQTY, LSHT, LMOD, LRET)

# Maj de l'entete d'OF
Call MAJALLMFG (LNUM, LLIN, LSEQ, LITM, LRET)

End

#########################################################################
# Mise à jour matière après allocation                                  #
#########################################################################
Subprog MAJALLMAT2(LNUM, LLIN, LSEQ, LITM, LQTY, LSHT, LMOD, LRET)
Value     Char     LNUM
Value     Integer  LLIN
Value     Integer  LSEQ
Value     Char     LITM
Value     Decimal  LQTY
Value     Decimal  LSHT
Value     Integer  LMOD
Variable  Integer  LRET

Local     Integer  MEMSTA

If clalev([F:MFM]) = 0 : Local File MFGMAT  [MFM] : Endif
If clalev([F:MFG]) = 0 : Local File MFGHEAD [MFG] : Endif
If clalev([F:ORD]) = 0 : Local File ORDERS  [ORD] : Endif

If clalev([M:ORDK])= 0 : Local Mask ORDK    [ORDK] : Endif

# FQ 63624 GA 03/2010 voir aussi SCOALL
# lecture matière
Read [MFM]MFM0=LNUM;LLIN;LSEQ;LITM
If fstat : WRET=1 : End : Endif
If [F:MFM]MATSTA > 2 : End : Endif      # FQ 63624 GA 03/2010 sortir sans locker la matière
If [F:MFM]CPNTYP = 5 : End : Endif      # Issue 94453 GA 11/2013

# lecture matière
#Readlock [MFM]MFM0=LNUM;LLIN;LSEQ;LITM
Readlock [MFM] Curr
If fstat : WRET=1 : Call RSTA("MFM", LNUM-num$(LLIN)-num$(LSEQ)-LITM) From GLOCK : End : Endif

# mémo statut
MEMSTA = [F:MFM]ALLSTA

# FQ 63624 GA 03/2010 sortie en erreur "Return non correspondant à Gosub" si pas de transaction démarrée
# si matière soldée ou exclue
#If [F:MFM]MATSTA > 2 : Rewrite [MFM] : Commit : End : Endif       # llc 11.01 11616

[F:MFM]ALLQTY    = LQTY
[F:MFM]SHTQTY    = LSHT

Case LMOD
    When 1:     If [F:MFM]ALLQTY = 0 & [F:MFM]SHTQTY = 0
                    [F:MFM]ALLSTA = 1
                Else
                    [F:MFM]ALLSTA    = 3
                    # si rupture, maj statut allocation
                    If [F:MFM]SHTQTY <> 0 : [F:MFM]ALLSTA -= 1 : Endif
                Endif
    When 2:     If [F:MFM]ALLQTY = 0 & [F:MFM]SHTQTY = 0
                    [F:MFM]ALLSTA = 1
                Else
                    [F:MFM]ALLSTA    = 5
                    # si rupture, maj statut allocation
                    If [F:MFM]SHTQTY <> 0 : [F:MFM]ALLSTA -= 1 : Endif
                Endif
Endcase

# point d'entrée pour mettre à jour des zones spécifiques de MFGMAT - 105569 mm 02.2015
GPOINT = "ALLMATMAJ": Gosub ENTREE From EXEFNC

# mise à jour matière
Rewrite [MFM]
If fstat WRET=1 : Call FSTA("MFM") From GLOCK : Endif

# lecture encours pour récupérer le n° affaire
Read [ORD]ORD0=6;[F:MFM]WIPNUM;[F:MFM]ITMREF

# mise à jour de l'encours
Call UPDATE_MFX("M", [F:ORD]PJT, [F:ORD]BOMALT, 0) From MFGLIBM

# FQ 70409 GA 01/2011 Maj déplacée + tard pour performances
# mise à jour entête
##### Gosub MAJMFG

# v6 affectations
Gosub MAJ_MTO_MFM From MFGMTOLIB
End

# FQ 70409 GA 01/2011 Maj déplacée + tard pour performances
#####-----------------------------------------------------------------------#
##### Mise à jour de l'entete OF                                            #
#####-----------------------------------------------------------------------#
