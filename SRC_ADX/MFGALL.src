#-----------------------------------------------------------------------#
# Mise à jour de l'entete OF                      # FQ 70409 GA 01/2011 #
#-----------------------------------------------------------------------#
Subprog MAJALLMFG(LNUM, LLIN, LSEQ, LITM, LRET)
Value     Char     LNUM
Value     Integer  LLIN
Value     Integer  LSEQ
Value     Char     LITM
Variable  Integer  LRET
Local Integer XTOT
Local Integer I
#
  If LNUM="" End Endif
  LRET=0

  If clalev([F:MFG]) = 0 : Local File MFGHEAD [MFG] : Endif

  Readlock [MFG]MFG0=LNUM
  If fstat = 1
     GOK = -1 : GLOCK = "$MFGHEAD"+[F:MFG]MFGNUM
     LRET=1 : End
  Elsif fstat
     GOK = 0  : Call RSTA("MFG",   [F:MFG]MFGNUM) From GLOCK
     LRET=2 : End
  Endif
#
  Gosub MAJMFGHEAD From MFGLIB
#
  # 82781
  [F:MFG]UPDDAT = date$
  [F:MFG]UPDUSR = GUSER
  [F:MFG]EXPNUM = [C]EXPORT
  Rewrite [MFG]
  If fstat
     GOK = 0 : Call FSTA("MFG") From GLOCK
     LRET=2 : End
  Endif
#
End

