#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMAUS 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone PAUSROL
mkstat = 0
zoncou = "PAUSROL"
indice = 0
If varinit([M]PAUSROL,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]PAUSROL,"639","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]PAUSROL,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "PAUSROL" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]PAUSROL,"639","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PAUSROL" : GZNUM = 10073 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]PAUSROL,"639",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "PAUSROL" : GZNUM = 10073 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone ENAFLGPJM
mkstat = 0
zoncou = "ENAFLGPJM"
indice = 0
IMPENT = [M]ENAFLGPJM
If varinit([M]ENAFLGPJM,indice)=0
 IMPENT = [V]CST_ANO
Endif
If varmode([M]ENAFLGPJM,indice)=0
 [M]ENAFLGPJM(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENAFLGPJM" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ENAFLGPJM(indice)
 Endif
Endif
[M]ENAFLGPJM = IMPENT

## Zone PAUSCST
mkstat = 0
zoncou = "PAUSCST"
indice = 0
SAVACT = GACTION : GACTION = "FMTFM2DEV"
Call FMTFM2DEV(PAUSCUR) From TRTDIV
GACTION = SAVACT
If mkstat=1 : Raz [M]PAUSCST : Endif
If !mkstat
 If varmode([M]PAUSCST,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "PAUSCST" : Gosub ACTION From =IMPTRT
  Endif
 Endif
Endif

## Zone PAUSCUR
mkstat = 0
zoncou = "PAUSCUR"
indice = 0
If varmode([M]PAUSCUR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PAUSCUR" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("TCU","!",[M]PAUSCUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "PAUSCUR" : GZNUM = 323 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PCCCOD
mkstat = 0
zoncou = "PCCCOD"
indice = 0
If varmode([M]PCCCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PCCCOD" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("PJCC","!",[M]PCCCOD,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "PCCCOD" : GZNUM = 43998 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PAUSTT
mkstat = 0
zoncou = "PAUSTT"
indice = 0
IMPENT = [M]PAUSTT
If varinit([M]PAUSTT,indice)=0
 IMPENT = [V]CST_ANO
Endif
If varmode([M]PAUSTT,indice)=0
 [M]PAUSTT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PAUSTT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PAUSTT(indice)
 Endif
Endif
[M]PAUSTT = IMPENT

## Zone PAUSPA
mkstat = 0
zoncou = "PAUSPA"
indice = 0
IMPENT = [M]PAUSPA
WNUM = IMPENT
If varinit([M]PAUSPA,indice)=0
 IMPENT = [V]CST_ANO
Endif
If varmode([M]PAUSPA,indice)=0
 [M]PAUSPA(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PAUSPA" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PAUSPA(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_PAUSPA(IMPENT) From SUBPAUS
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PAUSPA" : GZNUM = 54587 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]PAUSPA = IMPENT

## Zone TWD
mkstat = 0
zoncou = "TWD"
indice = 0
If varmode([M]TWD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TWD" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("TWD","!",[M]TWD,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "TWD" : GZNUM = 1809 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
indice = 0
status = 1
zoncou = "NBLIG"
If varmode([M]NBLIG,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NBLIG From SUBPAUS
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NBLIG : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG = nolign
   status = 75
   Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

## Zone STRDAT
mkstat = 0
zoncou = "STRDAT"
If varmode([M]STRDAT,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_STRDAT([M]STRDAT(indice)) From SUBPAUS
 GACTION = SAVACT
 If mkstat=1 : Raz [M]STRDAT(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "STRDAT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If [M]STRDAT(indice)=[0/0/0]
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "STRDAT" : GZNUM = 1805 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_STRDAT([M]STRDAT(indice)) From SUBPAUS
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "STRDAT" : GZNUM = 1805 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone ENDDAT
mkstat = 0
zoncou = "ENDDAT"
If varmode([M]ENDDAT,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_ENDDAT([M]ENDDAT(indice)) From SUBPAUS
 GACTION = SAVACT
 If mkstat=1 : Raz [M]ENDDAT(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "ENDDAT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If [M]ENDDAT(indice)=[0/0/0]
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "ENDDAT" : GZNUM = 1806 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_ENDDAT([M]ENDDAT(indice)) From SUBPAUS
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "ENDDAT" : GZNUM = 1806 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone CODVAR
mkstat = 0
zoncou = "CODVAR"
If varinit([M]CODVAR,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]CODVAR(indice),"641","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]CODVAR,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "CODVAR" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]CODVAR(indice),2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "CODVAR" : GZNUM = 2675 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]CODVAR(indice),"641","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CODVAR" : GZNUM = 2675 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]CODVAR(indice),"641",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "CODVAR" : GZNUM = 2675 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone VARTWD
mkstat = 0
zoncou = "VARTWD"
If varmode([M]VARTWD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "VARTWD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]VARTWD(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "VARTWD" : GZNUM = 1809 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("TWD","",[M]VARTWD(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "VARTWD" : GZNUM = 1809 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
status = 71
SAVACT = GACTION : GACTION = "STD"
Call APRES_NBLIG From SUBPAUS
GACTION = SAVACT

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMAUS"
Return

