#<AdxTL>@(#)2.0.0.0 $Revision$
########################################################################################
# UUMGTRTSAL04   Order historic migration script                          Sales module #
########################################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTSAL04") From LECFIC
  Endif

  #Call RAZ_UUMGTRTSAL04(DOSSIER)
  Call MAJ_UUMGTRTSAL04(DOSSIER)
  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

##############################################################################################
# UUMGTRTSAL04 Moulinette de Migration des historiques commandes normales
Subprog MAJ_UUMGTRTSAL04(DOSSIER)
Value Char DOSSIER

# Issue 106947 - 20150811 by LD : Migration of historic folder
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1
# Issue 106947 - 20150811 by LD

Local Integer ERR
##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : : # N = no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL04",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

#----- Récupération du n° de version
Local Char    CVERSION(3)
Local Integer VERSION
Call MIGGETVERSION (DOSSIER,CVERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL04",7,ERR) From TRTMIG : #7=Erreur
  End
Else
 VERSION=val(CVERSION)
Endif


Local Char WNAMVOHM,WNAMVOPM,WNAMVOQM
Call MIGTABNAME (DOSSIER,"VSORDER", WNAMVOHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"VSORDERP",WNAMVOPM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"VSORDERQ",WNAMVOQM,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL04",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMVOHM,"fde",DOSSIER),0)<0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL04",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMVOPM,"fde",DOSSIER),0)<0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL04",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMVOQM,"fde",DOSSIER),0)<0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL04",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL04",2,ERR) From TRTMIG : #2=En cours
Gosub MIG_OUVRE From TRTMIG #Gbn-108768

###################

Local Char WTAB_VOH (30) (adxwrb)
Local Char WTAB_VOP (90) (adxwrb)
Local Char WTAB_VOQ (90) (adxwrb)
Local Char WTAB_CAL (120) (adxwrb)
Local Shortint WCPT_VOH,WCPT_VOP,WCPT_VOQ,WCPT_CAL

Call ECR_TIME("UUMGTRTSAL04 Sales Order Process : Update VSORDER-Q-P") From DOSSUB
Call ECR_TRACE("UUMGTRTSAL04 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Call MIGTABINIT (DOSSIER,"VSORDER",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"VSORDERP",ERR) From TRTMIG
Call MIGTABINIT (DOSSIER,"VSORDERQ",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:VOH])  = 0 : Local File =DOSSIER+".VSORDER"      [VOH]  : Endif   # Fichier X3 "Vide"
If clalev([F:VOP])  = 0 : Local File =DOSSIER+".VSORDERP"     [VOP]  : Endif   # Fichier X3 "Vide"
If clalev([F:VOQ])  = 0 : Local File =DOSSIER+".VSORDERQ"     [VOQ]  : Endif   # Fichier X3 "Vide"

If clalev([F:VOHM]) = 0 : Local File =DOSSIER+"."+WNAMVOHM    [VOHM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:VOPM]) = 0 : Local File =DOSSIER+"."+WNAMVOPM    [VOPM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:VOQM]) = 0 : Local File =DOSSIER+"."+WNAMVOQM    [VOQM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBLUS, NBCOMMIT
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=5
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

#101380 SST Line Level Override .sn
Local Char WPARAM(GLONADP)
#101380 SST Line Level Override .en

# Déclaration des variables communes de travail
Local Integer I, J

#déclaration des variables locales de travail
Local Char     WSITE : Raz WSITE

Gosub OUVRE_SAL From UUMGTRTSAL00
If GOK<>1
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL04",7,ERR) From TRTMIG : #7=Erreur
  Goto FIN
Endif

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTSAL04",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(5))

#-----  Lien des tables entête & lignes -----#
#----- on ne met pas le numero de ligne dans le tri
#Link [VOPM] With [VOHM]VOH0~=[F:VOPM]SOHNUM;[F:VOPM]LINREVNUM , [VOQM]VOQ0~=[F:VOPM]SOHNUM;[F:VOPM]LINREVNUM;[F:VOPM]SOPLIN;[F:VOPM]SOPSEQ
#&    As [LNK] Where [F:VOPM]SOHCAT<>4
#&    Order By Key CLE = [F:VOHM]SALFCY;[F:VOHM]SOHNUM;[F:VOHM]REVNUM

Link [VOHM] With [BPC]BPC0=[F:VOHM]BPCORD
&    As [LNK] Where [F:VOHM]SOHCAT<4
&    Order By Key CLE = [F:VOHM]SOHCAT;[F:VOHM]SALFCY;[F:VOHM]SOHNUM;[F:VOHM]REVNUM

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTSAL04" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

# Boucle de traitement des commandes normales, prêts, à facturation directe
$LOOP_SAL01
Raz NB
If STOP=1
 STOP = 2
 CRITERE = "[F:VOHM]SOHCAT=val(TABMIGKEY(1)) & [F:VOHM]SALFCY=TABMIGKEY(2) & [F:VOHM]SOHNUM=TABMIGKEY(3) & [F:VOHM]REVNUM>val(TABMIGKEY(4))"
Elsif STOP=2
 STOP = 3
 CRITERE = "[F:VOHM]SOHCAT=val(TABMIGKEY(1)) & [F:VOHM]SALFCY=TABMIGKEY(2) & [F:VOHM]SOHNUM>TABMIGKEY(3)"
Elsif STOP=3
 STOP = 4
 CRITERE = "[F:VOHM]SOHCAT=val(TABMIGKEY(1)) & [F:VOHM]SALFCY>TABMIGKEY(2)"
Elsif STOP=4
 STOP = 0
 CRITERE = "[F:VOHM]SOHCAT>val(TABMIGKEY(1))"
Else
 CRITERE = "1=1"
Endif

Trbegin [VOH],[VOP],[VOQ]
GOK = 1

For [LNK]CLE(4)  Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  #rupture par site,commande
  NBLUS+=1

  # PE pour exclure ligne
  If FILTRELIN
    FLUX="UUMGTRTSAL04" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
    If ISVALID=0 : Goto SUITE_LOOP_SAL01 : Endif
  Endif

  #Raz [F:VOH]
  Gosub RAZ_VOH
  [F:VOH] = [F:VOHM]

  If WSITE<>[F:VOPM]SALFCY
      Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,[F:VOPM]SALFCY) From TRTX3CPT
      Call GLOBVAR([F:VOPM]SALFCY) From WWGLOBVEN
      WSITE=[F:VOPM]SALFCY

      #108649.so
      #If GACTKUS
      #    Call PARAM([F:VOPM]SALFCY,"USATAX",WPARAM) From ADOVAL
      #    GLOCUSATAX=val(WPARAM)
      #    If GLOCUSATAX>0  GLOCUSATAX-=1 : Endif
      #Else
      #    Raz GLOCUSATAX
      #Endif
      #108649.eo
  Endif

  If dim([F:VOH]DIE)>0 & [F:VOH]DIE(0)=""
      For I=1 To max(GNBDIE,GOPTCANA)
          [F:VOH]DIE(I-1)=GDIE(I)
      Next I
  Endif

  # Source folder version before V6.0
  If VERSION<GMIGX3VER60
    Gosub MAJ60_VOH
    If GOK<1 : Break : Endif
  Endif

  # Source folder version before V6.1
  If VERSION<GMIGX3VER61
    Gosub MAJ61_VOH
    If GOK<1 : Break : Endif
  Endif

  #101380 SST Line Level Override .sn
  # Source folder version before V8 [AKIRA]
  If VERSION>=GMIGX3VER70 & VERSION<GMIGX3VER80
    Gosub MAJ80_VOH
    If GOK<1 : Break : Endif
  Endif
  #101380 SST Line Level Override .en

  ############################
  #-- Boucle sur les lignes
  ############################
  For [VOPM] VOP0 Where SOHNUM=[F:VOH]SOHNUM & LINREVNUM=[F:VOH]REVNUM

    #rupture par ligne de facture

    #Raz [F:VOP]
    Gosub RAZ_VOP
    [F:VOP] = [F:VOPM]
    [F:VOP]CPY=[F:VOH]CPY

    # Source folder version before V6.0
    If VERSION<GMIGX3VER60
      Gosub AMAJ60_VOP
      If GOK<1 : Break : Endif
    Endif

    #101380 SST Line Level Override .sn
    # Source folder version before V8 [AKIRA]
    If VERSION>=GMIGX3VER70 & VERSION<GMIGX3VER80
      Gosub MAJ80_VOPVOH
      If GOK<1 : Break : Endif
    Endif
    #101380 SST Line Level Override .en


    # Issue 106947 - 20150811 by LD : Migration of historic folder
#    If NEWMOTEUR
#        Gosub VOP_STK : # pour stocker ref
#        WriteB [VOP]
#    Else
#        Write [VOP]
#    Endif
#    If fstat
#        If NEWMOTEUR & adxwrb>1
#          Call ECR_TRACE("File VSORDERP, Error ="-num$(fstat),1) From GESECRAN
#          Gosub VOP_ERRTRA : # pour afficher les ref
#        Else
#          Call ECR_TRACE("File VSORDERP(SOHNUM/SOPLIN/SOPSEQ)"-[F:VOP]SOHNUM-num$([F:VOP]SOPLIN)-num$([F:VOP]SOPSEQ)+", ERROR ="-num$(fstat),1) From GESECRAN
#        Endif
#        GOK=0 : Break
#    Endif
    Gosub VOP_STK : # pour stocker ref
    WriteB [VOP]
    If fstat
        Call ECR_TRACE("File VSORDERP, Error ="-num$(fstat),1) From GESECRAN
        Gosub VOP_ERRTRA : # pour afficher les ref
        GOK=0 : Break
    Endif
    # Issue 106947 - 20150811 by LD
  Next
  If GOK<1 : Break : Endif


  For [VOQM] VOQ0 Where SOHNUM=[F:VOH]SOHNUM & LINREVNUM=[F:VOH]REVNUM

    #rupture par ligne de facture

    #Raz [F:VOQ]
    Gosub RAZ_VOQ
    [F:VOQ] = [F:VOQM]

    # Source folder version before V6.0
    If VERSION<GMIGX3VER60
      Gosub MAJ60_VOHVOPVOQ
      If GOK<1 : Break : Endif
    Endif

    # 71065 : PJT
    # Source folder version before V11 (before CHALLENGER)
    If VERSION<GMIGX3VER110
      Gosub MAJ110_VOQVOH
      If GOK<1 : Break : Endif
    Endif
    # 71065 : PJT

    # Issue 106947 - 20150811 by LD : Migration of historic folder
#    If NEWMOTEUR
#        Gosub VOQ_STK : # pour stocker ref
#        WriteB [VOQ]
#    Else
#        Write [VOQ]
#    Endif
#    If fstat
#        If NEWMOTEUR & adxwrb>1
#          Call ECR_TRACE("File VSORDERQ, Error ="-num$(fstat),1) From GESECRAN
#          Gosub VOQ_ERRTRA : # pour afficher les ref
#        Else
#          Call ECR_TRACE("File VSORDERQ(SOHNUM/SOPLIN/SOQSEQ)"-[F:VOQ]SOHNUM-num$([F:VOQ]SOPLIN)-num$([F:VOQ]SOQSEQ)+", Error ="-num$(fstat),1) From GESECRAN
#        Endif
#        GOK=0 : Break
#    Endif
    Gosub VOQ_STK : # pour stocker ref
    WriteB [VOQ]
    If fstat
        Call ECR_TRACE("File VSORDERQ, Error ="-num$(fstat),1) From GESECRAN
        Gosub VOQ_ERRTRA : # pour afficher les ref
        GOK=0 : Break
    Endif
    # Issue 106947 - 20150811 by LD

  Next
  If GOK<1 : Break : Endif

  # Source folder version before V6.0
  If VERSION<GMIGX3VER60
    Gosub SUITE_MAJ60_VOH
    If GOK<1 : Break : Endif
  Endif

   # --- alimentation des champs et écriture enreg
  # Issue 106947 - 20150811 by LD : Migration of historic folder
#  If NEWMOTEUR
#      Gosub VOH_STK : # pour stocker ref
#      WriteB [F:VOH]
#  Else
#      Write [F:VOH]
#  Endif
#  If fstat
#    If NEWMOTEUR & adxwrb>1
#      Call ECR_TRACE("File VSORDER, Error ="-num$(fstat),1) From GESECRAN
#      Gosub VOH_ERRTRA : # pour afficher les ref
#    Else
#      Call ECR_TRACE("File VSORDER(SOHNUM)"-[F:VOH]SOHNUM+", Error ="-num$(fstat),1) From GESECRAN
#    Endif
#    GOK=0 : Break
#  Endif
  Gosub VOH_STK : # pour stocker ref
  WriteB [F:VOH]
  If fstat
    Call ECR_TRACE("File VSORDER, Error ="-num$(fstat),1) From GESECRAN
    Gosub VOH_ERRTRA : # pour afficher les ref
    GOK=0 : Break
  Endif
  # Issue 106947 - 20150811 by LD
  NB+=1
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = num$([F:VOHM]SOHCAT)
    TABMIGKEY(2) = [F:VOHM]SALFCY
    TABMIGKEY(3) = [F:VOHM]SOHNUM
    TABMIGKEY(4) = num$([F:VOHM]REVNUM)
    STOP=1
    Break
  Endif
$SUITE_LOOP_SAL01
Next

$FIN_LOOP_SAL01
If GOK<1
  Rollback
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL04",7,ERR) From TRTMIG : #7=Erreur
Else
  #If NEWMOTEUR & adxwrb>1   :   # Issue 106947 - 20150811 by LD : Migration of historic folder
    Flush [F:VOH]
    If fstat
        Call ECR_TRACE("File VSORDER, Error ="-num$(fstat),1) From GESECRAN
        Gosub VOH_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_LOOP_SAL01 : #on part sur rollback
    Endif
    Flush [F:VOP]
    If fstat
        Call ECR_TRACE("File VSORDERP, Error ="-num$(fstat),1) From GESECRAN
        Gosub VOP_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_LOOP_SAL01 : #on part sur rollback
    Endif
    Flush [F:VOQ]
    If fstat
        Call ECR_TRACE("File VSORDERQ, Error ="-num$(fstat),1) From GESECRAN
        Gosub VOQ_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_LOOP_SAL01 : #on part sur rollback
    Endif
    Flush [F:CAL]
    If fstat
        Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
        Gosub CAL_ERRTRA : # pour afficher les ref
        GOK=0 : Goto FIN_LOOP_SAL01 : #on part sur rollback
    Endif
  #Endif                     :   # Issue 106947 - 20150811 by LD : Migration of historic folder
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
  If STOP
      TABMIGKEY(5)=num$(STOP)
  Else
      Raz TABMIGKEY
  Endif
  Call MIGSTKKEY (DOSSIER,"UUMGTRTSAL04",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto FIN_LOOP_SAL01
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTSAL04",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_SAL01
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

$FIN
Close Local File [VOP], [VOH], [VOQ]
Close Local File [VOPM], [VOHM], [VOQM]

#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (DOSSIER,"VSORDER" ,ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"VSORDERP",ERR) From TRTMIG
Call MIGTABEND (DOSSIER,"VSORDERQ",ERR) From TRTMIG

Call MIGTRTEND (DOSSIER,"UUMGTRTSAL04") From TRTMIG
Call ECR_TIME("UUMGTRTSAL04 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End


##############################################################################################
Subprog RAZ_UUMGTRTSAL04(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : # N= no module
  End
Endif

#Gbn-101380
##1.1 - Récupération du n° de version
#####################################
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL04",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

Local Char WNAMVOHM,WNAMVOPM,WNAMVOQM
Call MIGTABNAME (DOSSIER,"VSORDER", WNAMVOHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"VSORDERP",WNAMVOPM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"VSORDERQ",WNAMVOQM,ERR) From TRTMIG
If ERR : End : Endif

If filinfo(filpath("FIL",WNAMVOHM,"fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table
If filinfo(filpath("FIL",WNAMVOPM,"fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table
If filinfo(filpath("FIL",WNAMVOQM,"fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table

##2 - On vide les fichiers selon le cas
#######################################
Local Char REQTSQL (250) (2)
#Local File =DOSSIER+".VSORDER"     [VOH]
#Local File =DOSSIER+".VSORDERP"    [VOP]
#Local File =DOSSIER+".VSORDERQ"    [VOQ]
Local File =DOSSIER+".CPTANALIN"   [CAL]

# Issue 81811 - 2012-04-24 by VPO : vider les tables
Call MIGTABRAZ (DOSSIER,"VSORDER",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"VSORDERP",ERR) From TRTMIG
Call MIGTABRAZ (DOSSIER,"VSORDERQ",ERR) From TRTMIG
#Onerrgo ERR_SQL
#Trbegin [VOH]
#REQTSQL(0)="DELETE FROM "-DOSSIER+".VSORDER WHERE SOHCAT_0<4 "
#Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
#Onerrgo
#Commit
#
#Onerrgo ERR_SQL
#Trbegin [VOP]
#REQTSQL(0)="DELETE FROM "-DOSSIER+".VSORDERP WHERE SOHCAT_0<4 "
#Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
#Onerrgo
#Commit
#
#Onerrgo ERR_SQL
#Trbegin [VOQ]
#REQTSQL(0)="DELETE FROM "-DOSSIER+".VSORDERQ WHERE SOHCAT_0<4 "
#Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
#Onerrgo
#Commit

#Gbn-101380
If val(VERSION)<GMIGX3VER60
  Onerrgo ERR_SQL
  Trbegin [CAL]
  REQTSQL(0)="DELETE FROM "-DOSSIER+".CPTANALIN WHERE ABRFIC_0='VOP' AND "
  REQTSQL(1)="NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".VSORDER WHERE CPTANALIN.VCRNUM_0=VSORDER.SOHNUM_0) "
  Execsql From num$(GTYPDBA*2+1) Sql REQTSQL
  Onerrgo
  Commit
Endif

##3 - On vide AMIGKEY pour le flux
####################
Call MIGRAZKEY (DOSSIER,"UUMGTRTSAL04",ERR) From TRTMIG

End
###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Call ECR_TRACE(REQTSQL,1) From GESECRAN
ERR=1
Resume
##############################################################################################
$VOH_STK
Call STK (WTAB_VOH,WCPT_VOH,[F:VOH]SOHNUM) From TRTMIG
Return
$VOP_STK
Call STK (WTAB_VOP,WCPT_VOP,[F:VOP]SOHNUM-'/'-num$([F:VOP]SOPLIN)-'/'-num$([F:VOP]SOPSEQ)) From TRTMIG
Return
$VOQ_STK
Call STK (WTAB_VOQ,WCPT_VOQ,[F:VOQ]SOHNUM-'/'-num$([F:VOQ]SOPLIN)-'/'-num$([F:VOQ]SOQSEQ)) From TRTMIG
Return
$CAL_STK
Call STK (WTAB_CAL,WCPT_CAL,[F:CAL]ABRFIC-'/'-num$([F:CAL]VCRTYP)-'/'-[F:CAL]VCRNUM-'/'-num$([F:CAL]VCRLIN)-'/'-num$([F:CAL]VCRSEQ)-'/'-[F:CAL]CPLCLE-'/'-num$([F:CAL]ANALIG)) From TRTMIG
Return
##############################################################################################
#################################################
$VOH_ERRTRA
Call ERRTRA (WTAB_VOH,WCPT_VOH,"File VSORDER(SOHNUM)=") From TRTMIG
Return
$VOP_ERRTRA
Call ERRTRA (WTAB_VOP,WCPT_VOP,"File VSORDERP(SOHNUM/SOPLIN/SOPSEQ)=") From TRTMIG
Return
$VOQ_ERRTRA
Call ERRTRA (WTAB_VOQ,WCPT_VOQ,"File VSORDERQ(SOHNUM/SOPLIN/SOQSEQ)=") From TRTMIG
Return
$CAL_ERRTRA
Call ERRTRA (WTAB_CAL,WCPT_CAL,"File CPTANALIN(ABRFIC/VCRTYP/VCRNUM/VCRLIN/VCRSEQ/CPLCLE/ANALIG)=") From TRTMIG
Return

########################################################################
$RAZ_VOH

Raz [F:VOH]APPFLG
Raz [F:VOH]BPAORD      : Raz [F:VOH]BPAINV
#Raz [F:VOH]BPAPYR
If dim([F:VOH]DIE)>0 Raz [F:VOH]DIE : Endif
Raz [F:VOH]CPY
Raz [F:VOH]DSPTOTQTY   : Raz [F:VOH]DSPTOTVOL   : Raz [F:VOH]DSPTOTWEI
Raz [F:VOH]DSPVOU      : Raz [F:VOH]DSPWEU
Raz [F:VOH]EECICT
If GACTDEB=2 Raz [F:VOH]EECLOC Endif
Raz [F:VOH]FFWADD      : Raz [F:VOH]FFWNUM      : Raz [F:VOH]ICTCTY
If dim([F:VOH]INVDTADSP)>0 :  Raz [F:VOH]INVDTADSP : Raz [F:VOH]INVDTATYP : Raz [F:VOH]SFISSTCOD : Endif #gbn-101380
Raz [F:VOH]PLISTC
Raz [F:VOH]ORDNOTL     : Raz [F:VOH]ORDATIL
Raz [F:VOH]ORDINVNOTL  : Raz [F:VOH]ORDINVATIL

Return
########################################################################
$RAZ_VOP

Raz [F:VOP]CPY

Return
########################################################################
$RAZ_VOQ

Raz [F:VOQ]CPY
If dim([F:VOQ]DDTANOT)>0 Raz [F:VOQ]DDTANOT : Raz [F:VOQ]DDTANUM  Endif
Raz [F:VOQ]DSPLINFLG
Raz [F:VOQ]DSPLINVOL : Raz [F:VOQ]DSPLINWEI
Raz [F:VOQ]DSPVOU    : Raz [F:VOQ]DSPWEU
Raz [F:VOQ]LPRQTY    : Raz [F:VOQ]LPRQTYSTU  : Raz [F:VOQ]OPRQTY  : Raz [F:VOQ]OPRQTYSTU
Raz [F:VOQ]PRECOD    : Raz [F:VOQ]PREQTY     : Raz [F:VOQ]PREQTYSTU

Return

########################################################################
# Initialization of the new fields for V6.0
########################################################################
$MAJ60_VOH

     [F:VOH]CPY=GSOCIETE
     If [F:VOH]SOHCAT<>4
        # Si ce n'est pas une cde ouverte, alimentation incoterm et lieu de transport CEE
        # Si c'est une cde ouverte, l'alimentation se fera dans VSORDERC
        Gosub RECUP_BPD_VOH
     Endif
     # Initialisation ds le tableau des éléments de facturation
     # INVDTATYP : Type de valeur : Si élément taux INVDTATYP=3 (%) Sinon INVDTATYP=1 (HT)
     For WI=0 To dim([F:VOH]INVDTA)-1
         If [F:VOH]INVDTA(WI)<>0
             [F:VOH]INVDTATYP(WI)=1
             WJ=find([F:VOH]INVDTA(WI),WSFINUM(0..WNBSFI-1))
             If WJ>0 & WSFIAMTCOD(WJ-1)=1 [F:VOH]INVDTATYP(WI)=3 Endif
         Endif
     Next
     # Renseignement des unités de répartition
     [F:VOH]DSPWEU=GSALDSPWEU
     [F:VOH]DSPVOU=GSALDSPVOU
     Raz [F:VOH]DSPTOTQTY, [F:VOH]DSPTOTWEI, [F:VOH]DSPTOTVOL

Return

########################################################################
$RECUP_BPD_VOH

     If ([F:VOH]EECICT="" | (GACTDEB=2 & [F:VOH]EECLOC=0))
         # Si ce n'est pas une cde ouverte, alimentation incoterm et lieu de transport CEE
         # Si c'est une cde ouverte, l'alimentation se fera dans VSORDERC
         If [F:BPD]BPCNUM<>[F:VOH]BPCORD | [F:BPD]BPAADD<>[F:VOH]BPAADD
             Read [F:BPD]BPD0 = [F:VOH]BPCORD;[F:VOH]BPAADD : If fstat Raz [BPD] Endif
         Endif
         If [F:VOH]EECICT="" [F:VOH]EECICT=[F:BPD]EECICT Endif
         If GACTDEB=2 & [F:VOH]EECLOC=0 [F:VOH]EECLOC=[F:BPD]EECLOC Endif
     Endif

Return

########################################################################
# Initialization of the new fields (Orders lines) for V6.0
########################################################################
$MAJ60_VOHVOPVOQ
              [F:VOP]CPY=[F:VOH]CPY
              [F:VOQ]CPY=[F:VOH]CPY
              [F:VOQ]DSPLINFLG= 2
              [F:VOQ]DSPWEU=[F:VOH]DSPWEU
              [F:VOQ]DSPVOU=[F:VOH]DSPVOU
Return

########################################################################
$SUITE_MAJ60_VOH

      # Alimentation des montants en devise VOCiété

      If [F:VOH]CUR <> "" and GLOCALDEV <> "" Then
        # FGR 12/01/2010 : X3SUIVI61184
        If [F:VOH]ORDNOT<>0
            Call COURMNT([F:VOH]CUR,GLOCALDEV,GLOCALDEV,[F:VOH]CHGTYP,[F:VOH]ORDDAT,1,
&                        [F:VOH]ORDNOT,[F:VOH]ORDNOTL,[F:VOH]CHGRAT,WRET) From TRTDEV
        Endif
        If [F:VOH]ORDATI<>0
            Call COURMNT([F:VOH]CUR,GLOCALDEV,GLOCALDEV,[F:VOH]CHGTYP,[F:VOH]ORDDAT,1,
&                        [F:VOH]ORDATI,[F:VOH]ORDATIL,[F:VOH]CHGRAT,WRET) From TRTDEV
        Endif
      Endif

      Gosub RECUP_BPR

Return

########################################################################
# Initialization of the new fields for V6.1
########################################################################
$MAJ61_VOH

      If dim([F:VOH]APPFLG)>0 & [F:VOH]APPFLG=0 [F:VOH]APPFLG=4 Endif : # Init du flag signée à 4 : Pas de signature

Return

########################################################################
# Initialization of the new fields for V8 [AKIRA]
########################################################################
$MAJ80_VOH
  #SST Line Level Override
  #If GACTLTA & GLOCUSATAX #108649.o
  If GSSTTAX(find([F:VOH]CPY,GSOC)) #108649.n
      For I=0 To dim([F:VOH]INVDTA)-1
          If [F:VOH]INVDTA(I)<>0
              Local Integer WJ
              WJ=find([F:VOH]INVDTA(I),WSFINUM(0..WNBSFI))
              If WJ>0 : [F:VOH]SFISSTCOD(I)=WSFISSTCOD(WJ-1) : Endif
          Endif
      Next
  Endif
Return

########################################################################
# Initialization of the new fields for V8 (Quotes lines) [AKIRA]
########################################################################
$MAJ80_VOPVOH
   #SST Line Level Override
   #If GACTLTA & GLOCUSATAX #108649.o
   If GSSTTAX(find([F:VOH]CPY,GSOC)) #108649.n
       If [F:VOP]ITMREF<>""
           Read [F:ITM]ITM0 = [F:VOP]ITMREF
           If !fstat #Record exists
              If [F:ITM]SSTCOD<>""
                  [F:VOP]SSTCOD = [F:ITM]SSTCOD
              Endif
          Endif
       Endif
   Endif
Return

# 71065 : PJT
########################################################################
# Initialization of the new fields for U11 (Order lines) [CHALLENGER]
########################################################################
$MAJ110_VOQVOH

[F:VOQ]PJT = [F:VOH]PJT

# 107890 : Scheduled invoices : (LD:25/03/16)
# Source folder version before V10 [AVENGER-U10]
If [F:VOQ]DLVFLG=0 [F:VOQ]DLVFLG = 2 Endif : # Type of flow deliverable
# 107890 : Scheduled invoices : (LD:25/03/16)

Return
# 71065 : PJT

########################################################################
$RECUP_BPR

    If [F:VOH]BPAORD="" | [F:VOH]BPAINV=""
      If [F:BPC]BPCNUM<>[F:VOH]BPCORD
        Read [BPC]BPC0=[F:VOH]BPCORD
        If fstat Raz [F:BPC] Endif
      Endif
    Endif

    If [F:VOH]BPAORD=""
      [F:VOH]BPAORD=[F:BPC]BPAADD
    Endif

    If [F: VOH]BPAINV=""
#     [F:VOH]BPAINV=[F:BPC]BPAINV
      If [F:VOH]BPCINV=[F:BPC]BPCINV
          [F:VOH]BPAINV=[F:BPC]BPAINV
      Else
          If [F:BPR]BPRNUM<>[F:VOH]BPCINV
              Read [BPR]BPR0=[F:VOH]BPCINV
              If fstat Raz [F:BPR] Endif
          Endif
          [F:VOH]BPAINV=[F:BPR]BPAADD
      Endif
    Endif

Return

########################################################################
$AMAJ60_VOP
    Gosub UPD_CAL_VOP
Return

# -------------------------------------------------- #
# Création des enregistrements de la table CPTANALIN #
# -------------------------------------------------- #
$UPD_CAL_VOP

#Look [CAL] CAL0="VOP";0;[F:VOP]SOHNUM;[F:VOP]SOPLIN;[F:VOP]SOPSEQ;"";1
#If fstat
    Raz [F:CAL]
    [F:CAL]ABRFIC="VOP"
    [F:CAL]VCRNUM=[F:VOP]SOHNUM
    [F:CAL]VCRLIN=[F:VOP]SOPLIN
    [F:CAL]VCRSEQ=[F:VOP]SOPSEQ
    [F:CAL]CPLCLE=num$([F:VOP]LINREVNUM)
    [F:CAL]ANALIG=1
    For J=1 To max(GNBCOA,2)
        [F:CAL]LED(J-1)=GLEDSOC(J)
        [F:CAL]COA(J-1)=GCOA(J)
    Next J
    Gosub EVAL_CAL

    # Issue 106947 - 20150811 by LD : Migration of historic folder
#    If NEWMOTEUR
#        Gosub CAL_STK : # pour stocker ref
#        WriteB [F:CAL]
#    Else
#        Write [F:CAL]
#    Endif
#    If fstat
#      If NEWMOTEUR & adxwrb>1
#        Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
#        Gosub CAL_ERRTRA : # pour afficher les ref
#      Else
#        Call ECR_TRACE("File CPTANALIN VOP 0"-[F:VOP]SOHNUM-num$([F:VOP]SOPLIN)-num$([F:VOP]SOPSEQ)-num$([F:VOP]LINREVNUM)-
#&                                +", Error ="-num$(fstat),1) From GESECRAN
#      Endif
#      GOK=0 : Return
#    Endif
    Gosub CAL_STK : # pour stocker ref
    WriteB [F:CAL]
    If fstat
        Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
        Gosub CAL_ERRTRA : # pour afficher les ref
        GOK=0 : Return
    Endif
    # Issue 106947 - 20150811 by LD
#Endif

Return


$EVAL_CAL
  For J=1 To max(GNBDIE,GOPTCANA)
      [F:CAL]DIE(J-1)=GDIE(J)
      Case J
          When 1 : [F:CAL]CCE(J-1)=[F:VOPM]CCE1
          When 2 : [F:CAL]CCE(J-1)=[F:VOPM]CCE2
          When 3 : [F:CAL]CCE(J-1)=[F:VOPM]CCE3
          When 4 : [F:CAL]CCE(J-1)=[F:VOPM]CCE4
          When 5 : [F:CAL]CCE(J-1)=[F:VOPM]CCE5
          When 6 : [F:CAL]CCE(J-1)=[F:VOPM]CCE6
          When 7 : [F:CAL]CCE(J-1)=[F:VOPM]CCE7
          When 8 : [F:CAL]CCE(J-1)=[F:VOPM]CCE8
          When 9 : [F:CAL]CCE(J-1)=[F:VOPM]CCE9
          When Default
      Endcase

#       If evalue("dim([F:VOPM]CCE"+num$(J)+")")>0
#           [F:CAL]CCE(J-1)=evalue("[F:VOPM]CCE"+num$(J))
#       Endif

  Next J
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 106947 - 20150811 by LD : Migration of historic folder
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
# Issue 106947 - 20150811 by LD
Call MAJ_UUMGTRTSAL04(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTSAL04(APPLI)
End

