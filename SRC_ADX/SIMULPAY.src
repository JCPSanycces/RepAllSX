#<AdxTL>@(#)7.0.0.0 $Revision$
#Gosub TEST : End

##########################################################################################
## Simulation de paye
##########################################################################################
GACTION = "SIMULPAY"
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"SIMULPAY","SIMULPAY","") From GSAISIE
End

$ACTION
Case ACTION
 When "BOUTON" : Gosub BOUTON
 When "DEBUT"  : Gosub DEBUT
 When "FIN"    : Gosub FIN
Endcase
Return

$DEBUT
Local Char VRUBDES(30)
Gosub OUVRE
Raz [M:SIM]
Read [RUB]RUB0 = GCURLEG;ENV_OBJRUB
[M:SIM]RUBOBJ = [F:RUB]COD
Call LECTEXTRA(VRUBDES,"RUBRIQUE","DES",GCURLEG,[F:RUB]COD) From ATEXTRA
Chgtzn [M:SIM]OBJ With VRUBDES
Chgtzn [M:SIM]C1 With LIBCUM(1)
Chgtzn [M:SIM]C2 With LIBCUM(2)
Chgtzn [M:SIM]C3 With LIBCUM(3)
Chgtzn [M:SIM]C4 With LIBCUM(4)
Chgtzn [M:SIM]C5 With LIBCUM(5)
Chgtzn [M:SIM]C6 With LIBCUM(6)
#LS
Chgtzn [M:SIM]C1A With LIBCUM(1)
Chgtzn [M:SIM]C2A With LIBCUM(2)
Chgtzn [M:SIM]C3A With LIBCUM(3)
Chgtzn [M:SIM]C4A With LIBCUM(4)
Chgtzn [M:SIM]C5A With LIBCUM(5)
#
[M:SIM]PYRDAT = gdat$(ENV_DATPAY)
If ENV_VARSAL<>""
 [M:SIM]NBVAR     = 1
 [M:SIM]VARIA(0)  = ENV_VARSAL
 #[M:SIM]VALEUR(0) = 1500
Endif
Affzo [SIM]
Return

$OUVRE
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG : Endif

Local Char    ENV_OBJRUB(GLONRUB) , ENV_OBJVAR(GLONVRA) , ENV_INCVAR(GLONVRA)
Local Char    SAV_OBJRUB(GLONRUB) , SAV_OBJVAR(GLONVRA) , SAV_INCVAR(GLONVRA)
Local Char    ENV_VARSAL(GLONVRA) , ENV_DATPAY(10)

Local Integer SAV_TWDPAY
Local Integer I , J , K
Gosub OUVPAY From SUBVEPX
Read [ADW]ADW0 = "";"";"PAERUB"
ENV_OBJRUB = [F:ADW]VALEUR
Read [ADW]ADW0 = "";"";"PAEVAR"
ENV_INCVAR = [F:ADW]VALEUR
Read [ADW]ADW0 = "";"";"PAEVAL"
ENV_OBJVAR = [F:ADW]VALEUR
Read [ADW]ADW0 = "";"";"VARSAL"
ENV_VARSAL = [F:ADW]VALEUR
#64942
#Read [ADW]ADW0 = "";"";"DATPAY"
#ENV_DATPAY = [F:ADW]VALEUR
ENV_DATPAY = gdat$(func DIVPAYE.INIPARUSR("DATPAY","",""))

If clalev([F:RUB])=0    : Local File RUBRIQUE   [RUB]   : Endif
If clalev([F:VRA])=0    : Local File VARIA      [VRA]   : Endif
If clalev([F:VEP])=0    : Local File VALEMP     [VEP]   : Endif
If clalev([F:VLA])=0    : Local File VALEUR     [VLA]   : Endif
If clalev([F:ID])=0     : Local File EMPLOID    [ID]    : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR   [HRCTR] : Endif
If GINTMT=1
 If clalev([F:PSN])=0   : Local File PRESTATION [PSN]   : Endif
Endif
If clalev([F:FCY])=0    : Local File FACILITY   [FCY]   : Endif
If clalev([F:CPY])=0  : Local File COMPANY       [CPY]  : Endif
If clalev([F:ADW])=0    : Local File ADOVAL     [ADW]   : Endif
Return

#JOJAC - 2016-08-04 - X3PEOP-958 - START
#84795
$AVANT_BOUTON
  If [M:SIM]REFNUM=""
    GERR=1 : GMESSAGE=mess(10,123,1) : GZONE="REFNUM" : GZNUM=1598
    zonsui="REFNUM"
  Endif
Return
#end 84795
#JOJAC - 2016-08-04 - X3PEOP-958 - END

$BOUTON
Case BOUT
 When "1" : Gosub CALCUL
Endcase
Return

$CALCUL
Local Integer I , J
Local Integer PASAPAS
Default Mask [SIM]
PASAPAS = -3
Effzo [SIM]25-40
GOK = 1
If [M:SIM]ENVERS=2
 Gosub SET_PAE
Endif
# LS: Lancement d'1 simulation sur une session.Fin. Lancement de la même simulation sur une autre session.
# La simulation de la 2ème session ne renvoie rien car les instructions Readlock de PLAN renvoient fstat à 1.
# L'enregistrement est verrouillé par la 1ère session => Mettre une transaction pour déverrouiller les tables
Call DEBTRANS From GLOCK
Trbegin [HRCTR]
 Call PLAN("",PASAPAS,0) From GPLAN
 #82486 : Amélio des perfs
 If dim(GNBRCRB)>=0 : Call KILL_PROFIL(0) From GPLAN : Endif
Commit
If [M:SIM]ENVERS=2
 Gosub RESET_PAE
 Affzo [SIM]20
Endif
Chgstl [M]NBLIG With ""
Affzo [SIM]25-40
If [M:SIM]ENVERS=2
 K = find(ENV_OBJRUB,[M:SIM]RUB(0..[M:SIM]NBLIG-1))
 If K
  Chgstl [M:SIM]RUB(K-1) With "RELIEF"
  Chgstl [M:SIM]LIB(K-1) With "RELIEF"
  Chgstl [M:SIM]BAS(K-1) With "RELIEF"
  Chgstl [M:SIM]TX1(K-1) With "RELIEF"
  Chgstl [M:SIM]MT1(K-1) With "RELIEF"
  Chgstl [M:SIM]TX2(K-1) With "RELIEF"
  Chgstl [M:SIM]MT2(K-1) With "RELIEF"
  zonsui = "NBLIG("+num$(K-1)+")"
 Endif
Else
 zonsui = "NBLIG(0)"
Endif
Return

$SET_PAE
Call DEBTRANS From GLOCK
Gosub TR1
Return

$TR1
GOK = 1
Trbegin [HRCTR]
 Filter [HRCTR] Where REFNUM=[M:SIM]REFNUM & CTRNUM=[M:SIM]CTRNUM & [F:HRCTR]CTRDAT<=[M:SIM]PYRDAT
 Readlock [HRCTR]CTR0 Last
 Filter [HRCTR]
 If fstat
  GOK = 0 : Call RSTA("HRCTR",[M:SIM]REFNUM-[M:SIM]CTRNUM) From GLOCK : Goto AB_TR1
 Endif
 SAV_TWDPAY = [F:HRCTR]TWDPAY
 SAV_OBJRUB = [F:HRCTR]OBJRUB
 SAV_OBJVAR = [F:HRCTR]OBJVAR
 SAV_INCVAR = [F:HRCTR]INCVAR
 [F:HRCTR]OBJRUB = ENV_OBJRUB
 [F:HRCTR]OBJVAR = ENV_OBJVAR
 [F:HRCTR]INCVAR = ENV_INCVAR
 [F:HRCTR]TWDPAY = 2
 Rewrite [HRCTR]
 If fstat
  GOK = 0 : Call FSTA("HRCTR") From GLOCK : Goto AB_TR1
 Endif
Commit
K = find(ENV_OBJVAR,[M:SIM]VARIA(0..[M:SIM]NBVAR-1))-1
If K<0
 K = [M:SIM]NBVAR
 [M:SIM]NBVAR += 1
 [M:SIM]VARIA(K) = ENV_OBJVAR
Endif
[M:SIM]VALEUR(K) = [M:SIM]OBJ
Return

#JOJAC - 2016-08-04 - X3PEOP-958 - START
#84820
K = find(ENV_INCVAR,[M:SIM]VARIA(0..[M:SIM]NBVAR-1))-1
If K>=0
 Raz [M:SIM]VALEUR(K)
Endif
#end 84820
#JOJAC - 2016-08-04 - X3PEOP-958 - END

$RESET_PAE
Call DEBTRANS From GLOCK
Gosub TR2
Return

$TR2
GOK = 1
Trbegin [HRCTR]
 Filter [HRCTR] Where REFNUM=[M:SIM]REFNUM & CTRNUM=[M:SIM]CTRNUM & [F:HRCTR]CTRDAT<=[M:SIM]PYRDAT
 Readlock [HRCTR]CTR0 Last
 Filter [HRCTR]
 If fstat
  GOK = 0 : Call RSTA("HRCTR",[M:SIM]CTRNUM) From GLOCK : Goto AB_TR2
 Endif
 [F:HRCTR]OBJRUB = SAV_OBJRUB
 [F:HRCTR]OBJVAR = SAV_OBJVAR
 [F:HRCTR]INCVAR = SAV_INCVAR
 [F:HRCTR]TWDPAY = SAV_TWDPAY
 Rewrite [HRCTR]
 If fstat
  GOK = 0 : Call FSTA("HRCTR") From GLOCK : Goto AB_TR2
 Endif
Commit
Return

$AB_TR1
$AB_TR2
Rollback
Return

######################################################################################
## Ecran SIMULPAY
######################################################################################

## Intermittent
Subprog AM_MOIS(VALEUR)
Variable Date    VALEUR
If GINTMT<>1 : End : Endif
Raz [M]DATDEB,DATFIN
For [PSN]PSN0 Where CTRNUM=[M]CTRNUM & BUL="" & month([F:PSN]PSNENDDAT)=month(VALEUR)
 If [M]DATDEB=[0/0/0] | [F:PSN]PSNSTRDAT<[M]DATDEB
  [M]DATDEB = [F:PSN]PSNSTRDAT
 Endif
 If [F:PSN]PSNENDDAT>[M]DATFIN
  [M]DATFIN = [F:PSN]PSNENDDAT
 Endif
Next
If [M]DATDEB=[0/0/0] | [M]DATFIN=[0/0/0]
 GMESSAGE = mess(53,10701,1) : # Le contrat n'a pas de prestation en cours sur ce mois
 mkstat = 2 : End
Endif
[M]PYRDAT = [M]DATFIN
Affzo [M]PYRDAT
End

Subprog B2_REFNUM(VALEUR)
Variable Char    VALEUR()
Gosub SEL_CONTRAT
If mkstat=2 : End : Endif
End


$SEL_CONTRAT
Local Integer NBCTR , NUMCTR, TBNUM(1..100)
Local Char    TBCTR(GLONVCR)(0..100) , LIBCTR(80)(0..100), CRITERE(100), LEGS(GLONADI)(0..100)
Local Date    TBDEB(0..100) , TBFIN(0..100)
Call LECTURE("EML",VALEUR,"") From CONTOBJ
NBCTR = 0
Raz TBDEB, TBFIN, TBCTR, LIBCTR, LEGS
#93779
Local Integer MYOK
CRITERE = 'REFNUM="'+VALEUR+'" & CTRDAT<=['+format$(GFMD,[M]PYRDAT)+']'
For [HRCTR]CTR0 Where evalue(CRITERE)
 Gosub SEL_CONTRAT2
Next
#If [F:ID]FLGINT<>2
# CRITERE = 'REFNUM="'+VALEUR+'" & CTRDAT<=['+format$(GFMD,[M]PYRDAT)+']'
# If [F:ID]FLGMULCTR=2
#  For [HRCTR]CTR0 Where evalue(CRITERE)
#   Gosub SEL_CONTRAT2
#  Next
# Else
#  Filter [HRCTR] Where evalue(CRITERE)
#  Read [HRCTR]CTR0 Last
#  Filter [HRCTR]
#  Gosub SEL_CONTRAT2
# Endif
#Else
# CRITERE = 'REFNUM="'+VALEUR+'"'
# For [HRCTR] Where evalue(CRITERE)
#  Gosub SEL_CONTRAT2
# Next
#Endif
#end 93779

If NBCTR=0
 GMESSAGE = mess(150,10702,1) : # Pas de contrat de travail pour ce salarié
 mkstat = 2 : Return
Elsif NBCTR=1
 NUMCTR = 1
Else
 Call SAITEX(NBCTR,LIBCTR,NUMCTR,mess(151,10702,1)) From GESECRAN : # Choix du contrat
 If NUMCTR=0 : mkstat = 2 : Return : Endif
Endif

[M]LIBREF = [F:ID]NAM-[F:ID]SRN
[M]CTRNUM = TBCTR(NUMCTR)
[M]DATDEB = TBDEB(NUMCTR)
[M]DATFIN = TBFIN(NUMCTR)
GCURLEG = LEGS(NUMCTR)

If dim([M]PSNNUM)>0
 If [F:ID]FLGINT<>2 : # Pas Intermittent
  Grizo PSNNUM,MOIS
 Else
  [M]PSNNUM = TBNUM(NUMCTR)
  If [M]PSNNUM=0 : # Paye par contrat
   Actzo MOIS
   #[M]MOIS = gdat$(01,month(TBDEB(NUMCTR)),year(TBDEB(NUMCTR)))
   [M]MOIS = gdat$(01,month(TBFIN(NUMCTR)),year(TBFIN(NUMCTR)))
  Else
   Raz [M]MOIS
   Diszo MOIS
  Endif
  [M]PYRDAT = [M]DATFIN
  Affzo MOIS, PSNNUM, PYRDAT
 Endif
Endif
Affzo LIBREF,CTRNUM, DATDEB, DATFIN :#93779
Return


$SEL_CONTRAT2
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
#93779
MYOK=0
Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
If val(func AFNC.PARAM('DMA',[F:HRCTR]ETRFCY))=12 & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=gdat$(01,month([M]PYRDAT),year([M]PYRDAT)))
 MYOK=1
Endif
If val(func AFNC.PARAM('DMA',[F:HRCTR]ETRFCY))<>12 & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>eomonth(addmonth([M]PYRDAT,-2)))
 MYOK=1
Endif
If MYOK
#end93779
Case [F:HRCTR]CALPAY
  When 1 : # Paye par contrat
    If dim([M]PSNNUM)>0 & [F:ID]FLGINT=2 : #Intermittent
     #JOJAC - 2016-08-04 - X3PEOP-958 - START
     #For [PSN]PSN0 Where CTRNUM=[F:HRCTR]CTRNUM & BUL=""
     ##**92316 US2225 : Add filter on CTRDAT
     For [PSN]PSN0 Where CTRNUM=[F:CTR]CTRNUM & BUL="" & CTRDAT=[F:CTR]CTRDAT
     #JOJAC - 2016-08-04 - X3PEOP-958 - END
     # If TBDEB(NBCTR+1)=[0/0/0] | TBDEB(NBCTR+1)>[F:PSN]PSNSTRDAT
     #  TBDEB(NBCTR+1) = [F:PSN]PSNSTRDAT
     # Endif
     # If TBFIN(NBCTR+1)<[F:PSN]PSNENDDAT & month([F:PSN]PSNENDDAT)=month(TBDEB(NBCTR+1))
     #  TBFIN(NBCTR+1) = [F:PSN]PSNENDDAT
     # Endif
      If TBFIN(NBCTR+1)>[F:PSN]PSNENDDAT | TBFIN(NBCTR+1)=[0/0/0]
       TBFIN(NBCTR+1) = [F:PSN]PSNENDDAT
       If TBDEB(NBCTR+1)>[F:PSN]PSNSTRDAT | TBDEB(NBCTR+1)=[0/0/0]
        TBDEB(NBCTR+1) = [F:PSN]PSNSTRDAT
       Endif
      Elsif month(TBFIN(NBCTR+1))=month([F:PSN]PSNENDDAT) & TBDEB(NBCTR+1)>[F:PSN]PSNSTRDAT
       TBDEB(NBCTR+1) = [F:PSN]PSNSTRDAT
      Endif
     Next
     If TBDEB(NBCTR+1)<>[0/0/0]
      NBCTR += 1
      TBCTR(NBCTR)  = [F:HRCTR]CTRNUM
      LEGS(NBCTR) = [F:CPY]LEG
      TBNUM(NBCTR)  = 0
      LIBCTR(NBCTR) = [F:HRCTR]CTRNUM-":"-format$(GFMD,[F:HRCTR]CTRDAT)-format$(GFMD,[F:HRCTR]XITDAT)
&                    -[F:FCY]FCY-[F:FCY]FCYNAM
     Endif
    Else
     NBCTR += 1
     TBCTR(NBCTR)  = [F:HRCTR]CTRNUM
     LEGS(NBCTR) = [F:CPY]LEG
     TBNUM(NBCTR)  = 0
     LIBCTR(NBCTR) = [F:HRCTR]CTRNUM-":"-format$(GFMD,[F:HRCTR]CTRDAT)-format$(GFMD,[F:HRCTR]XITDAT)
&                   -[F:FCY]FCY-[F:FCY]FCYNAM
     TBDEB(NBCTR) = [F:HRCTR]CTRDAT
     TBFIN(NBCTR) = [F:HRCTR]XITDAT
    Endif
  When 2,3 : # Paye par prestation ou par jour
    If GINTMT=1
     #JOJAC - 2016-08-04 - X3PEOP-958 - START
     #For [PSN]PSN0 Where CTRNUM=[F:HRCTR]CTRNUM & BUL=""
     ##**92316 US2225 : Add filter on CTRDAT
     For [PSN]PSN0 Where CTRNUM=[F:CTR]CTRNUM & BUL="" & CTRDAT=[F:CTR]CTRDAT
     #JOJAC - 2016-08-04 - X3PEOP-958 - END
      NBCTR += 1
      TBCTR(NBCTR)  = [F:HRCTR]CTRNUM
      LEGS(NBCTR) = [F:CPY]LEG
      TBNUM(NBCTR)  = [F:PSN]PSNNUM
      LIBCTR(NBCTR) = [F:HRCTR]CTRNUM-"("+num$([F:PSN]PSNNUM)+")"-":"-format$(GFMD,[F:PSN]PSNSTRDAT)-format$(GFMD,[F:PSN]PSNENDDAT)
&                   -[F:FCY]FCY-[F:FCY]FCYNAM
      TBDEB(NBCTR)  = [F:PSN]PSNSTRDAT
      TBFIN(NBCTR)  = [F:PSN]PSNENDDAT
     Next
    Endif
Endcase
Endif
Return


Subprog AM_REFNUM(VALEUR)
#JOJAC - 2016-08-04 - X3PEOP-958 - START
#Variable Char REFNUM()
Variable Char VALEUR()
#JOJAC - 2016-08-04 - X3PEOP-958 - END
Local Integer I
If clalev([F:VRA])=0 : Local File VARIA [VRA] : Endif

Gosub SEL_CONTRAT
If mkstat=2 : End : Endif

Filter [VEP] Where EMP=VALEUR & CTRNUM=[M]CTRNUM & PYRDAT<=[M]PYRDAT
Read [VEP]VEP0 Last
Filter [VEP]
If fstat<=2
 Effzo 20
 [M]NBVAR = 0
 For [VLA] Where TYP=4 & CPY="" & FCY="" & EMP=VALEUR & DAT=[F:VEP]PYRDAT & BUL=[F:VEP]BUL & VARVAL<>0
  # Ls : On affiche que les variables de type conservation
  Read [F:VRA]VRA0=GCURLEG;[F:VLA]VARCOD
  If !fstat & [F:VRA]TYPINI=1 : # Conservation
   [M]VARIA([M]NBVAR)  = [F:VLA]VARCOD
   [M]VALEUR([M]NBVAR) = [F:VLA]VARVAL
   [M]NBVAR += 1
  Endif
 Next
 Affzo 20
Endif
Effzo 25-40
End

Subprog C_ENVERS(VALEUR)
Variable Integer VALEUR
Local Integer K
If VALEUR=1
 Grizo OBJ
Else
 Actzo OBJ
 If [M]OBJ=0
  K = find([M]RUBOBJ,[M]RUB(0..[M]NBLIG-1))
  If K
   [M]OBJ = [M]MT1(K-1)+[M]MT2(K-1)
  Endif
 Endif
Endif
End

Subprog C_NBLIG
If status=75
 mkstat = 2
Endif
End

############################################################################################################
# Sous-pro "silencieux" (=> web-service)
############################################################################################################
## Subprog SIMULPAY(EMPLO,CONTRAT,DAT,NBVAR,TBVAR,TBVAL,ENVERS,OBJECTIF,NBRUB,TBRUB,BASE,TX1,MT1,TX2,MT2,STAT,MESSA)
############################################################################################################
$TEST
Local Integer NBVAR
Local Char    TBVAR(GLONVRA)(1..100)
Local Decimal TBVAL(1..100)
Local Integer NBRUB
Local Char    TBRUB(GLONRUB)(1..100)
Local Char    TBLIB(GLONDES)(1..100)
Local Decimal BASE(1..100) , TX1(1..100) , TX2(1..100) , MT1(1..100) , MT2(1..100)
Local Decimal TBROW(1..100)
Local Integer STAT
# LS
Local Decimal CUM1MOI, CUM1AN, CUM2MOI, CUM2AN, CUM3MOI, CUM3AN, CUM4MOI, CUM4AN, CUM5MOI, CUM5AN, CUM6MOI
Local Char    CUM1LIB, CUM2LIB, CUM3LIB, CUM4LIB, CUM5LIB, CUM6LIB
#
NBVAR    = 1
TBVAR(1) = "SALAIRE"
TBVAL(1) = 2000
# LS
#NBRUB    = 1
#TBRUB(1) = "NET_PAYER"
#Call SIMULPAY("ASN200200000014","ASN00000041",0,[01/01/2024],[01/01/2024],NBVAR,TBVAR,TBVAL
#& ,1,2000.06,NBRUB,TBRUB,TBROW,BASE,TX1,MT1,TX2,MT2,STAT,GMESSAGE) From SIMULPAY
#
Call SIMULPAY("ASN200200000020","ASN00000049",0,[01/12/2007],[01/12/2007],NBVAR,TBVAR,TBVAL,1,0,NBRUB,TBRUB,TBROW,TBLIB,
&  BASE,TX1,MT1,TX2,MT2,CUM1LIB,CUM1MOI,CUM1AN,CUM2LIB,CUM2MOI,CUM2AN,CUM3LIB,CUM3MOI,CUM3AN,CUM4LIB,
&  CUM4MOI,CUM4AN,CUM5LIB,CUM5MOI,CUM5AN,CUM6LIB,CUM6MOI,STAT,GMESSAGE) From SIMULPAY


If STAT
 Call ERREUR(GMESSAGE) From GESECRAN
Else
 For I=1 To NBRUB
  Infbox TBRUB(I)-num$(MT1(I))
 Next I
Endif
Return

############################################################################################################

Subprog SIMULPAY(EMPLO,CONTRAT,PSNNUM,DATDEB,DATFIN,NBVAR,TBVAR,TBVAL,ENVERS,OBJECTIF,NBRUB,TBRUB,TBROW,TBLIB,BASE,TX1,MT1,
&  TX2,MT2,CUM1LIB,CUM1MOI,CUM1AN,CUM2LIB,CUM2MOI,CUM2AN,CUM3LIB,CUM3MOI,CUM3AN,CUM4LIB,CUM4MOI,CUM4AN,
&  CUM5LIB,CUM5MOI,CUM5AN,CUM6LIB,CUM6MOI,STAT,MESSA)
Value    Char    EMPLO
Value    Char    CONTRAT
Value    Date    DATDEB, DATFIN
Value    Integer NBVAR, PSNNUM
Value    Char    TBVAR()(1..)
Value    Decimal TBVAL(1..)
Value    Integer ENVERS
Value    Decimal OBJECTIF
Variable Integer NBRUB
Variable Char    TBRUB()(1..), TBLIB()(1..)
Variable Decimal BASE(1..)
Variable Decimal TX1(1..)
Variable Decimal TX2(1..)
Variable Decimal MT1(1..)
Variable Decimal MT2(1..)
Variable Integer STAT
Variable Char    MESSA()
# Ls
Variable Decimal TBROW(1..)
Variable Decimal CUM1MOI, CUM1AN, CUM2MOI, CUM2AN, CUM3MOI, CUM3AN, CUM4MOI, CUM4AN
Variable Decimal CUM5MOI, CUM5AN, CUM6MOI
Variable Char    CUM1LIB, CUM2LIB, CUM3LIB, CUM4LIB, CUM5LIB, CUM6LIB
#
Gosub OUVRE

Local Integer PASAPAS
Local Char    LIGNE(250)
Local Mask SIMULPAY [SIM]
Raz [M:SIM]
#Raz BASE , TX1 , MT1 , TX2 , MT2
STAT  = 0
MESSA = ""

Read [ID]ID0 = EMPLO
If fstat
 STAT = 1 : MESSA = EMPLO-":"-mess(83,10702,1) : End : # Matricule inexistant
Endif
Filter [HRCTR] Where REFNUM=EMPLO & CTRNUM=CONTRAT & CTRDAT<=DATFIN
Read [HRCTR]CTR0 Last
Filter [HRCTR]
If fstat
 STAT = 1 : MESSA = CONTRAT-":"-mess(26,10701,1) : End : # Contrat inexistant
Endif
[M:SIM]REFNUM = EMPLO
[M:SIM]PYRDAT = DATFIN
[M:SIM]CTRNUM = CONTRAT
[M:SIM]PSNNUM = PSNNUM
[M:SIM]DATDEB = DATDEB
[M:SIM]DATFIN = DATFIN

##########################################################
# Là, il faudra initialiser avec les valeurs du contrat
##########################################################
For I=1 To NBVAR
 [M:SIM]VARIA(I-1)  = TBVAR(I)
 [M:SIM]VALEUR(I-1) = TBVAL(I)
Next I
[M:SIM]NBVAR = NBVAR
##########################################################

PASAPAS = -3
GOK = 1
Call OUVRE_TRACE("") From LECFIC
If ENVERS
 [M:SIM]OBJ = OBJECTIF
 K = find([F:HRCTR]OBJVAR,[M:SIM]VARIA(0..[M:SIM]NBVAR-1))-1
 If K<0
  K = [M:SIM]NBVAR
  [M:SIM]NBVAR += 1
  [M:SIM]VARIA(K) = [F:HRCTR]OBJVAR
 Endif
 [M:SIM]VALEUR(K) = [M:SIM]OBJ
 # Gosub SET_PAE : LS
Endif
# LS: Lancement d'1 simulation sur une session.Fin. Lancement de la même simulation sur une autre session.
# La simulation de la 2ème session ne renvoie rien car les instructions Readlock de PLAN renvoient fstat à 1.
# L'enregistrement est verrouillé par la 1ère session => Mettre une transaction pour déverrouiller les tables
Call DEBTRANS From GLOCK
Trbegin [HRCTR]
 Call PLAN("",PASAPAS,0) From GPLAN
 #82486 : Amélio des perfs
 If dim(GNBRCRB)>=0 : Call KILL_PROFIL(0) From GPLAN : Endif
Commit
#LS
#If ENVERS
# Gosub RESET_PAE
#Endif
#
Call FERME_TRACE From LECFIC
If GOK<1
 STAT = 1 : MESSA = GMESSAGE : End
Endif
If GERRTRACE
 Openi filpath("TRA",GTRACE,"tra")
 Rdseq LIGNE
 Rdseq LIGNE
 MESSA = ""
 While !fstat
  If left$(LIGNE,5)="<0001"
   MESSA -= "\"+vireblc(right$(LIGNE,6),2)
  Endif
  Rdseq LIGNE
 Wend
 Openi
 STAT = 1 : End
Endif

If NBRUB=0
 For I=0 To [M:SIM]NBLIG-1
  NBRUB += 1
  TBRUB(NBRUB) = [M:SIM]RUB(I)
  TBROW(NBRUB) = [M:SIM]ROW(I) : # LS
  TBLIB(NBRUB) = [M:SIM]LIB(I) : # LS
  BASE(NBRUB)  = [M:SIM]BAS(I)
  TX1(NBRUB)   = [M:SIM]TX1(I)
  TX2(NBRUB)   = [M:SIM]TX2(I)
  MT1(NBRUB)   = [M:SIM]MT1(I)
  MT2(NBRUB)   = [M:SIM]MT2(I)
 Next I
 #LS
 CUM1MOI = [M:SIM]C1 : CUM2MOI = [M:SIM]C2
 CUM3MOI = [M:SIM]C3 : CUM4MOI = [M:SIM]C4
 CUM5MOI = [M:SIM]C5 : CUM6MOI = [M:SIM]C6
 For [ADW]ADW1 Where PARAM>="BULCUM1" & PARAM<="BULCUM6"
  Read [CUM]CUM0 = GCURLEG;[F:ADW]VALEUR
  If !fstat
   Case [F:ADW]PARAM
    When "BULCUM1" : CUM1LIB = [F:CUM]CUMPRN
    When "BULCUM2" : CUM2LIB = [F:CUM]CUMPRN
    When "BULCUM3" : CUM3LIB = [F:CUM]CUMPRN
    When "BULCUM4" : CUM4LIB = [F:CUM]CUMPRN
    When "BULCUM5" : CUM5LIB = [F:CUM]CUMPRN
    When "BULCUM6" : CUM6LIB = [F:CUM]CUMPRN
   Endcase
  Endif
 Next
 #
Else
 For I=1 To NBRUB
  K = find(TBRUB(I),[M:SIM]RUB(0..[M:SIM]NBLIG-1))
  If K
   BASE(I) = [M:SIM]BAS(K-1)
   TX1(I)  = [M:SIM]TX1(K-1)
   MT1(I)  = [M:SIM]MT1(K-1)
   TX2(I)  = [M:SIM]TX2(K-1)
   MT2(I)  = [M:SIM]MT2(K-1)
  Endif
 Next I
Endif
End

######################################################################################
# Sous-pro appelés depuis GPLAN
######################################################################################
######################################################################################
# Pour remplir un "valemp" bidon
######################################################################################
$INIVEP
Raz [F:VEP]
Case GACTION
 When Default
  Filter [HRCTR] Where REFNUM= [M:SIM]REFNUM & CTRNUM=[M:SIM]CTRNUM & CTRDAT<[M:SIM]PYRDAT
  Read [HRCTR]CTR0 Last
  Filter [HRCTR]
  [F:VEP]EMP    = [F:HRCTR]REFNUM
  [F:VEP]PYRDAT = [M:SIM]PYRDAT
  [F:VEP]CTRNUM = [M:SIM]CTRNUM
  [F:VEP]FCY    = [F:HRCTR]ETRFCY
  [F:VEP]SRV    = [F:HRCTR]ETRSRV
  [F:VEP]PRF    = [F:HRCTR]PROPRF
  [F:VEP]CTRDAT = [F:HRCTR]CTRDAT
  [F:VEP]PYRMON = gdat$(01,month([M:SIM]PYRDAT),year([M:SIM]PYRDAT))
  [F:VEP]PAYDAT = [M:SIM]PYRDAT
  If dim([M:SIM]PSNNUM)>0 & [F:ID]FLGINT=2 : #Intermittent
   [F:VEP]STRDAT = [M:SIM]DATDEB
   [F:VEP]ENDDAT = [M:SIM]DATFIN
  Else
   [F:VEP]STRDAT = max([F:HRCTR]CTRDAT, gdat$(01,month([M:SIM]PYRDAT),year([M:SIM]PYRDAT)))
   If [F:HRCTR]XITDAT<>[0/0/0]
    [F:VEP]ENDDAT = min([F:HRCTR]XITDAT,[M:SIM]PYRDAT)
   Else
    [F:VEP]ENDDAT = [M:SIM]PYRDAT
   Endif
  Endif
Endcase
Return

######################################################################################
# Pour initialiser les variables
######################################################################################
$INIVAR
Case GACTION
 When Default
 For I=0 To [M:SIM]NBVAR-1
  Assign "V_"+[M:SIM]VARIA(I) With [M:SIM]VALEUR(I)
 Next I
Endcase
Return

######################################################################################
# Pour stocker les rubriques
######################################################################################
$RUBRIQUE
Case GACTION
 When Default
  If MEM & (BASE<>0 | TAUX<>0 | MONT<>0) & !ENVERS
   Read [RUB]RUB1 = GCURLEG;RANG
   If [F:RUB]AMTPRN>1
    If [M:SIM]NBLIG>0 & RANG=[M:SIM]ROW([M:SIM]NBLIG-1) & [L]TYP=2
     Case [F:RUB]AMTPRN
      When 1,2,4
       [M:SIM]TX2([M:SIM]NBLIG-1) = TAUX
       [M:SIM]MT2([M:SIM]NBLIG-1) = MONT
      When 3,5
       [M:SIM]TX2([M:SIM]NBLIG-1) = -TAUX
       [M:SIM]MT2([M:SIM]NBLIG-1) = -MONT
     Endcase
    Else
     [M:SIM]ROW([M:SIM]NBLIG) = RANG
     [M:SIM]RUB([M:SIM]NBLIG) = RUB
     If LIBRUB=""
      Call LECTEXTRA(LIBRUB,"RUBRIQUE","DES",[F:RUB]LEG,[F:RUB]COD) From ATEXTRA
     Endif
     [M:SIM]LIB([M:SIM]NBLIG) = LIBRUB
     If [F:RUB]AMTPRN=1 or [F:RUB]AMTPRN>=4
      [M:SIM]BAS([M:SIM]NBLIG) = BASE
     Endif
     Case TYP
      When 2,8
       Case [F:RUB]AMTPRN
        When 1,2,4
         [M:SIM]TX2([M:SIM]NBLIG) = TAUX
         [M:SIM]MT2([M:SIM]NBLIG) = MONT
        When 3,5
         [M:SIM]TX2([M:SIM]NBLIG) = -TAUX
         [M:SIM]MT2([M:SIM]NBLIG) =- MONT
       Endcase
      When Default
       Case [F:RUB]AMTPRN
        When 1,2,4
         [M:SIM]TX1([M:SIM]NBLIG) = TAUX
         [M:SIM]MT1([M:SIM]NBLIG) = MONT
        When 3,5
         [M:SIM]TX1([M:SIM]NBLIG) = -TAUX
         [M:SIM]MT1([M:SIM]NBLIG) = -MONT
       Endcase
     Endcase
     [M:SIM]NBLIG += 1
    Endif
    #Raz MEM, BASE, TAUX, MONT, [L]TYP
    #Raz TEXOS, PEXOS, TEXOP, PEXOP
   Endif
  Endif
  Raz MEM, BASE, TAUX, MONT, [L]TYP
  Raz TEXOS, PEXOS, TEXOP, PEXOP
Endcase
Return

######################################################################################
# Pour stocker les cumuls
######################################################################################
$CUMULS

Case GACTION
 When Default
  Gosub OUVPAY From SUBVEPX
#LS
#  [M:SIM]C1 = evalue("C_"+BULCUM(1))
#  [M:SIM]C2 = evalue("C_"+BULCUM(2))
#  [M:SIM]C3 = evalue("C_"+BULCUM(3))
#  [M:SIM]C4 = evalue("C_"+BULCUM(4))
#  [M:SIM]C5 = evalue("C_"+BULCUM(5))
#  [M:SIM]C6 = evalue("C_"+BULCUM(6))

#MIPEA - 2016-08-08 - X3PEOP-785 - START
Chgtzn [M:SIM]OBJ With VRUBDES
Chgtzn [M:SIM]C1 With LIBCUM(1)
Chgtzn [M:SIM]C2 With LIBCUM(2)
Chgtzn [M:SIM]C3 With LIBCUM(3)
Chgtzn [M:SIM]C4 With LIBCUM(4)
Chgtzn [M:SIM]C5 With LIBCUM(5)
Chgtzn [M:SIM]C6 With LIBCUM(6)
#LS
Chgtzn [M:SIM]C1A With LIBCUM(1)
Chgtzn [M:SIM]C2A With LIBCUM(2)
Chgtzn [M:SIM]C3A With LIBCUM(3)
Chgtzn [M:SIM]C4A With LIBCUM(4)
Chgtzn [M:SIM]C5A With LIBCUM(5)
#MIPEA - 2016-08-08 - X3PEOP-785 - START

  [M:SIM]C1A = evalue("C_"+BULCUM(1))
  [M:SIM]C2A = evalue("C_"+BULCUM(2))
  [M:SIM]C3A = evalue("C_"+BULCUM(3))
  [M:SIM]C4A = evalue("C_"+BULCUM(4))
  [M:SIM]C5A = evalue("C_"+BULCUM(5))
  [M:SIM]C1 = [M:SIM]C1A-evalue("C_"+BULCUM(1)+"(2)")
  [M:SIM]C2 = [M:SIM]C2A-evalue("C_"+BULCUM(2)+"(2)")
  [M:SIM]C3 = [M:SIM]C3A-evalue("C_"+BULCUM(3)+"(2)")
  [M:SIM]C4 = [M:SIM]C4A-evalue("C_"+BULCUM(4)+"(2)")
  [M:SIM]C5 = [M:SIM]C5A-evalue("C_"+BULCUM(5)+"(2)")
  [M:SIM]C6 = evalue("C_"+BULCUM(6))-evalue("C_"+BULCUM(6)+"(2)")
Endcase
If [M:SIM]ENVERS=2
 Local Integer WK
 WK = find([F:HRCTR]INCVAR,[M:SIM]VARIA(0..[M:SIM]NBVAR-1))
 If WK
  [M:SIM]VALEUR(WK-1) = evalue("V_"+[F:HRCTR]INCVAR)
 Endif
Endif
Return

$FIN
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return
######################################################################################
## Etiquette ajoutée par le superviseur (écran SIMULPAY) 09/01/2014 12:51:05 (LANEG)
######################################################################################
#93779
Subprog AM_PYRDAT(VALEUR)
Variable Date    VALEUR
Local Integer OK
OK=1
If [M]REFNUM<>""
 If clalev([F:HRCTR2])=0 : Local File EMPLOCTR   [HRCTR2] : Endif
 If VALEUR<[M]DATDEB
  Filter [HRCTR2] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & CTRDAT<=VALEUR
  Read [HRCTR2]CTR0 Last
  Filter [HRCTR2]
  If !fstat
   [M]DATDEB=[F:HRCTR2]CTRDAT
   [M]DATFIN=[F:HRCTR2]XITDAT
   End
  Else
   Filter [HRCTR2] Where REFNUM=[M]REFNUM & CTRDAT<=VALEUR
   Read [HRCTR2]CTR0 Last
   Filter [HRCTR2]
   If !fstat
    [M]DATDEB=[F:HRCTR2]CTRDAT
    [M]DATFIN=[F:HRCTR2]XITDAT
    [M]CTRNUM=[F:HRCTR2]CTRNUM
    Affzo DATDEB, DATFIN, CTRNUM
    End
   Else
    OK=0
   Endif
  Endif
 Endif
 If ([M]DATFIN>[0/0/0] & VALEUR>[M]DATFIN) | !OK
  #Ne pas bloquer pour cas du décalage de paie ou PYRDAT> XITDAT
  OK = 2
  Call AVERTIR(mess(158,10702,1),OK) From GESECRAN :# Pas de contrat valide sur la période
  If OK=1 : mkstat = 2 : End : Endif
 Endif
Endif
End


