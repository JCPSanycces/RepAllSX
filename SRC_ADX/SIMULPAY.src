######################################################################################
Subprog AS_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Char SAV_GCURLEG(3)

If GCURLEG <> "" : SAV_GCURLEG = GCURLEG : Endif
GCURLEG=""
End


