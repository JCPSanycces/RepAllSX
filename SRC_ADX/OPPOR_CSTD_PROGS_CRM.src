#######################################################################################
# Classe OPPOR
#######################################################################################
# CRM SUBROUTINES                                                                     #
#######################################################################################
#######################################################################################
Subprog CRM_MANAGE_STEPB(SCONTEXT)
Value Char SCONTEXT

Local Integer DIMPJT

  If find(SCONTEXT,"SOH","SQH") = 0 Then
    # Cas de bug en développement
    GMESSAGE = mess(624,1771) - ":" - SCONTEXT
    GERR = 1
    GOK = 0
    End
  Endif
  If SCONTEXT = "SOH" and dim([M:SOH4]DPJT) >= 0 Then
    DIMPJT = dim([M:SOH4]DPJT) + 1

    Local Char SVCRNUM(type([M:SOH0]SOHNUM)-10)
  Elsif SCONTEXT = "SQH" and  dim([M:SQH2]DPJT) >= 0 Then
    DIMPJT = dim([M:SQH2]DPJT) + 1

    Local Char SVCRNUM(type([M:SQH0]SQHNUM)-10)
  Else
    End  # S'il n'y a pas de champ PJT, ça va planter alors on part
  Endif

Local Integer NI
Local Integer IRET
Local Integer NBPJT
Local Integer NBPREPJT
Local Char SPJT(GLONPJT)(1..DIMPJT)
Local Char SPREPJT(GLONPJT)(1..DIMPJT)
Local Instance GZINSOPP Using C_OPPOR

  # ------------------------------
  GZINSOPP = NewInstance C_OPPOR AllocGroup null
  # ------------------------------
  If SCONTEXT = "SOH" Then
    SVCRNUM = [M:SOH0]SOHNUM
  Elsif SCONTEXT = "SQH" Then
    SVCRNUM = [M:SQH0]SQHNUM
  Endif
  # ------------------------------
  # 1°) On recherche toutes les première utilisation d'une même affaire
  Call GET_LIST_SPJT(SCONTEXT, NBPJT, SPJT)
  # 2°) on recherche toutes les affaires qui ont été modifiées, et qui ne sont pas dans la première liste : Il faudra faire une suppression sur les affaires
  Call GET_LIST_SPREPJT(SCONTEXT, NBPJT, SPJT, NBPREPJT, SPREPJT)
  # ------------------------------
  # 3°) On met à jour les compteurs pour les affaires dont la référence a été utilisée
  For NI = 1 To NBPJT
    IRET = fmet GZINSOPP.CRM_ADD_STEPB(SPJT(NI), SCONTEXT, SVCRNUM, AVOID.ACHAR)
    If IRET <> [V]CST_AOK Then
      GMESSAGE = SPJT(NI) - ":" - func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSOPP)
      GERR = 1
      GOK = 0
      Break
    Endif
  Next NI
  If GERR = 1 Then
    Goto END_CRM_MANAGE_STEPB
  Endif
  # ------------------------------
  # 4°) On met à jour les affaires qui étaient utilisées et ne le sont plus
  For NI = 1 To NBPREPJT
    IRET = fmet GZINSOPP.CRM_DEL_STEPB(SPREPJT(NI), SCONTEXT, SVCRNUM)
    If IRET <> [V]CST_AOK Then
      Call RECOVERS_ERROR_IN_CLASSIC(GZINSOPP) From SUBOPPA
      GMESSAGE = SPREPJT(NI) - ":" - GMESSAGE
      GERR = 1
      GOK = 0
      Break
    Endif
  Next NI
  If GERR = 1 Then
    Goto END_CRM_MANAGE_STEPB
  Endif
  # ------------------------------
$END_CRM_MANAGE_STEPB
  If GZINSOPP <> null Then
    FreeGroup GZINSOPP
  Endif
End

#######################################################################################
Subprog CRM_DEL_STEPB(SCONTEXT)
Value Char SCONTEXT

Local Integer DIMPJT

  If find(SCONTEXT,"SOH","SQH") = 0 Then
    # Cas de bug en développement
    GMESSAGE = mess(624,1771) - ":" - SCONTEXT
    GERR = 1
    GOK = 0
    End
  Endif
  If SCONTEXT = "SOH" and dim([M:SOH4]DPJT) >= 0 Then
    DIMPJT = dim([M:SOH4]DPJT) + 1

    Local Char SVCRNUM(type([M:SOH0]SOHNUM)-10)
  Elsif SCONTEXT = "SQH" and  dim([M:SQH2]DPJT) >= 0 Then
    DIMPJT = dim([M:SQH2]DPJT) + 1

    Local Char SVCRNUM(type([M:SQH0]SQHNUM)-10)
  Else
    End  # S'il n'y a pas de champ PJT, ça va planter alors on part
  Endif

Local Integer NI
Local Integer IRET
Local Integer NBPJT
Local Char SPJT(GLONPJT)(1..DIMPJT)
Local Instance GZINSOPP Using C_OPPOR

  # ------------------------------
  GZINSOPP = NewInstance With C_OPPOR #AllocGroup null
  # ------------------------------
  If SCONTEXT = "SOH" Then
    SVCRNUM = [M:SOH0]SOHNUM
  Elsif SCONTEXT = "SQH" Then
    SVCRNUM = [M:SQH0]SQHNUM
  Endif
  # ------------------------------
  # 1°) On recherche toutes les première utilisation d'une même affaire
  Call GET_LIST_SPJT(SCONTEXT, NBPJT, SPJT)
  # 2°) On met à jour les compteurs pour les affaires dont la référence a été utilisée
  For NI = 1 To NBPJT
    IRET = fmet GZINSOPP.CRM_DEL_STEPB(SPJT(NI), SCONTEXT, SVCRNUM)
    If IRET <> [V]CST_AOK Then
      GMESSAGE = SPJT(NI) - ":" - func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSOPP)
      GERR = 1
      GOK = 0
      Break
    Endif
  Next NI
  If GERR = 1 Then
    Goto END_CRM_DEL_STEPB
  Endif
  # ------------------------------
$END_CRM_DEL_STEPB
  If GZINSOPP <> null Then
    FreeGroup GZINSOPP
  Endif
End

#######################################################################################
Subprog GET_LIST_SPJT(SCONTEXT, NBPJT, SPJT)
Value Char SCONTEXT
Variable Integer NBPJT
Variable Char SPJT()(1..)

Local Integer NI
Local Integer NE

  Raz SPJT
  NBPJT = 0
  If SCONTEXT = "SOH" Then
    # 1°) On recherche toutes les première utilisation d'une même affaire
    For NI = 0 To [M:SOH4]NBLIG-1
      If [M:SOH4]DPJT(NI) <> "" Then
        If NBPJT < 1 Then
          NBPJT += 1
          SPJT(NBPJT) = [M:SOH4]DPJT(NI)
          NE = 0
        Else
          NE = find([M:SOH4]DPJT(NI), SPJT(1..NBPJT))
          If NE < 1 Then
            NBPJT += 1
            SPJT(NBPJT) = [M:SOH4]DPJT(NI)
          Endif
        Endif
      Endif
    Next NI
  Elsif SCONTEXT = "SQH" Then
    For NI = 0 To [M:SQH2]NBLIG-1
      If [M:SQH2]DPJT(NI) <> "" Then
        If NBPJT < 1 Then
          NBPJT += 1
          SPJT(NBPJT) = [M:SQH2]DPJT(NI)
          NE = 0
        Else
          NE = find([M:SQH2]DPJT(NI), SPJT(1..NBPJT))
          If NE < 1 Then
            NBPJT += 1
            SPJT(NBPJT) = [M:SQH2]DPJT(NI)
          Endif
        Endif
      Endif
    Next NI
  Endif
End

#######################################################################################
Subprog GET_LIST_SPREPJT(SCONTEXT, NBPJT, SPJT, NBPREPJT, SPREPJT)
Value Char SCONTEXT
Value Integer NBPJT
Value Char SPJT()(1..)
Variable Integer NBPREPJT
Variable Char SPREPJT()(1..)

Local Integer NI
Local Integer NE

  Raz SPREPJT
  NBPREPJT = 0
  If SCONTEXT = "SOH" Then
    For NI = 0 To [M:SOH4]NBLIG-1
      If [M:SOH4]DPREOPP(NI) <> "" and find([M:SOH4]DPREOPP(NI), SPJT(1..NBPJT)) = 0 Then
        If NBPREPJT < 1 Then
          NBPREPJT += 1
          SPREPJT(NBPREPJT) = [M:SOH4]DPREOPP(NI)
        Else
          NE = find([M:SOH4]DPREOPP(NI), SPREPJT(1..NBPREPJT))
          If NE < 1 Then
            NBPREPJT += 1
            SPREPJT(NBPREPJT) = [M:SOH4]DPJT(NI)
          Endif
        Endif
      Endif
    Next NI
  Elsif SCONTEXT = "SQH" Then
    For NI = 0 To [M:SQH2]NBLIG-1
      If [M:SQH2]DPREOPP(NI) <> "" and find([M:SQH2]DPREOPP(NI), SPJT(1..NBPJT)) = 0 Then
        If NBPREPJT < 1 Then
          NBPREPJT += 1
          SPREPJT(NBPREPJT) = [M:SQH2]DPREOPP(NI)
        Else
          NE = find([M:SQH2]DPREOPP(NI), SPREPJT(1..NBPREPJT))
          If NE < 1 Then
            NBPREPJT += 1
            SPREPJT(NBPREPJT) = [M:SQH2]DPJT(NI)
          Endif
        Endif
      Endif
    Next NI
  Endif
End

