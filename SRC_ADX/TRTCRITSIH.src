#<AdxTL>@(#)9.0.0.0 $Revision$
################################################################################################
#                                                                                              #
# Traitement standard de saisie des critères de picking en gestion des factures de ventes V140 #
#                                                                                              #
# Traitement TRTCRITSIH / Action TRTCRITSIH                                                    #
#                                                                                              #
################################################################################################
# Appelée en gestion des factures et des avoirs depuis le menu option                          #
################################################################################################
$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "INIT"        : Gosub INIT
 When Default
Endcase
#--- Actions liées à la fenêtre de saisie ICRITSIH
Case ACTION
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : REP="M"
 When "OK"          : Gosub OK
 When "ABA"         : Gosub ABA
Endcase
Case ACTION
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "FIN_TABLE"   : Gosub FIN_TABLE
Endcase
Return

#---------------------#
# Sélection sur champ #
#---------------------#
$SEL_TABLE
Local Integer SAVGFACTYP : SAVGFACTYP=GFACTYP
Case COUZON
  When "CRISIHNUM"
    OBJET="SIH"
    # Critères factures  :
    # Les factures doivent être validées
    CRITERE='INVTYP=1 & INVSTA=3 & SALFCY="'+[M:SIH0]SALFCY+'" & BPCINV="'+[M:SIH0]BPCINV+'"'
    # V6.2 : Certification
    # Si ctrl date documents : La facture doit avoir une date <= à la date de l'avoir
    If GCTLDATORI=2 CRITERE+='& INVDAT<=[M:SIH0]INVDAT' Endif
    # Utilisé dans l'action FILTRE de SUBSIHA Pour pouvoir sélectionner une facture en création d'avoir
    GFACTYP=1
  When "CRISRHNUM"
    OBJET="SRH"
    # Critères retours   :
    # Les retours ne doivent pas être des retours de prêts
    CRITERE='LNDRTN=1 & (SALFCY="" | SALFCY="'+[M:SIH0]SALFCY+'") & (BPCINV="" | BPCINV="'+[M:SIH0]BPCINV+'")'
    # V6.2 : Certification
    # Si ctrl date documents : Le retour doit avoir une date <= à la date de la facture
    If GCTLDATORI=2 CRITERE+='& RTNDAT<=[M:SIH0]INVDAT' Endif
  When "CRISRENUM"
    OBJET="SRE"
    # Critères demandes de services :
    # Les demandes doivent être cloturée, facturable
    CRITERE ='SREASS=5 & SREINVFLG=2'
    CRITERE+='& SALFCY="'+[M:SIH0]SALFCY+'" & SREBPCINV=[M:SIH0]BPCINV'
    # V6.2 : Certification
    # Si ctrl date documents : La commande doit avoir une date <= à la date de la facture
    If GCTLDATORI=2 CRITERE+='& SREDATASS<=[M:SIH0]INVDAT' Endif
  When "CRICONNUM"
    OBJET="CON"
    # Critères contrats de service :
    # Les contrats doivent avoir date prochain envoi fac.<= date facture, date prochaine fac. renseignée
    # Les contrats ne doivent pas être résiliés, archivés, ne doivent pas être des contrats de garantie
    CRITERE ='NEXSHIINV<=[M:SIH0]INVDAT & NEXINVDAT<>[00/00/00] & RSIFLG<>2 & FDDFLG<>2 & CONCAT<>1'
    CRITERE+='& CONAMT>0 & ITMREF<>"" & SALFCY="'+[M:SIH0]SALFCY+'" '
    # V6.2 : Certification
    # Si ctrl date documents : Le contrat doit avoir une date <= à la date de la facture
    If GCTLDATORI=2 CRITERE+='& CONSTRDAT<=[M:SIH0]INVDAT' Endif
  When "CRISOHNUM"
    OBJET="SOH"
    # Critères commandes :
    # Les commandes doivent à facturation directes, non facturées

    # X3-29085  this selection must also proposes normal sales orders not totally invoiced.
    # When the sales invoices has got already one order picked, the selection criteria must
    # proposed only the category already picked (normal sales order or direct invoice sales order)
    Case [M:SIH1]SIHORI
      When 2
          CRITERE ='SOHCAT=3 & INVSTA<>3 & SALFCY="'+[M:SIH0]SALFCY+'" & BPCINV="'+[M:SIH0]BPCINV+'"'
      When 10
           CRITERE ='SOHCAT=1 & INVSTA<>3 & SALFCY="'+[M:SIH0]SALFCY+'" & BPCINV="'+[M:SIH0]BPCINV+'"'
      When Default
           CRITERE ='(SOHCAT=1 or SOHCAT=3) & INVSTA<>3 & SALFCY="'+[M:SIH0]SALFCY+'" & BPCINV="'+[M:SIH0]BPCINV+'"'
    Endcase

    ## Fin X3-29085
    # V6.2 : Certification
    # Si ctrl date documents : La commande doit avoir une date <= à la date de la facture
    If GCTLDATORI=2 CRITERE+='& ORDDAT<=[M:SIH0]INVDAT' Endif
  When "CRISDHNUM"
    OBJET="SDH"
    # Critères livraisons :
    # Les livraisons doivent être validées, non facturées, ni prêts, ni sous-traitance,
    #     ni inter-sites intra-société
    CRITERE ='CFMFLG=2 & INVFLG=1 & LND<>2 & SCO<>2 & (BETFCY=1 | (BETFCY=2 & BETCPY=2))'
    CRITERE+='& SALFCY="'+[M:SIH0]SALFCY+'" & BPCINV="'+[M:SIH0]BPCINV+'"'
    # V6.2 : Certification
    # Si ctrl date documents : La livraison doit avoir une date <= à la date de la facture
    #If GCTLDATORI=2 CRITERE+='& DLVDAT<=[M:SIH0]INVDAT' Endif : # Dde 73382
    If GCTLDATORI=2 CRITERE+='& SHIDAT<=[M:SIH0]INVDAT' Endif  : # Dde 73382
  When "CRIUMRNUM"
    #--CPO 87923 Gestion des prélèvements SDD
    OBJET="MDT"
    # Critères factures  :
    # Mandats de la société du document et lié au tiers payeur
    CRITERE='CPY="'+GSOCIETE+'" & BPCNUM="'+[M:SIH1]BPRPAY+'"'
    #--/
Endcase
Return

$FIN_TABLE
GFACTYP=SAVGFACTYP
Return

#---------------------------------------------------------#
# Détermination de la fenêtre à ouvrir                    #
#---------------------------------------------------------#
$INIT
If [M:SIH0]INVTYP = 1
    BOITE = "ICRITINV"
Else
    BOITE = "ICRITCNO"
Endif
Return

#---------------------------------------------------------#
# Chargement du masque critères de picking                #
#---------------------------------------------------------#
$DEBUT

Case [M:SIH0]INVTYP
  When 1 : [M:SCRI]=[M:SIH0]
           If [M:SCRI]CRIITMREF="" Raz [M:SCRI]CRIITMDES Endif
           Case [M:SIH1]SIHORI
               When 2 : Actzo [M:SCRI]CRISOHNUM : Gosub DEACTIV_SOH
               When 3 : Actzo [M:SCRI]CRISDHNUM : Gosub DEACTIV_SDH
               When 7 : Actzo [M:SCRI]CRICONNUM : Gosub DEACTIV_CON
               When 8 : Actzo [M:SCRI]CRISRENUM : Gosub DEACTIV_SRE
                # 107888 : Scheduled invoices : (LD:11/05/16)
                # For the moment, we manage only scheduled invoices from order
                # This will have to be changed when we'll manage other scheduled invoices
               When 10 : Actzo [M:SCRI]CRISOHNUM : Gosub DEACTIV_SOH
                # 107888 : Scheduled invoices : (LD:11/05/16)
               When Default :
                    If [M:SCRI]CRISOHNUM <> "" Actzo [M:SCRI]CRISOHNUM : Gosub DEACTIV_SOH Endif
                    If [M:SCRI]CRISDHNUM <> "" Actzo [M:SCRI]CRISDHNUM : Gosub DEACTIV_SDH Endif
                    If [M:SCRI]CRICONNUM <> "" Actzo [M:SCRI]CRICONNUM : Gosub DEACTIV_CON Endif
                    If [M:SCRI]CRISRENUM <> "" Actzo [M:SCRI]CRISRENUM : Gosub DEACTIV_SRE Endif
           Endcase
           Affzo [M:SCRI]1-99
  When 2 : [M:SCRC]=[M:SIH0]
           If [M:SCRC]CRIITMREF="" Raz [M:SCRC]CRIITMDES Endif
           #--CPO 87923 Gestion des prélèvements SDD
           If dim([M:SCRC]CRIUMRNUM)>0
             If find([M:SIH1]SIHORI,1,4)>0 and dim([M:SIH2]UMRNUM)>0 and [M:SCRC]CRIUMRNUM="" and [M:SIH2]UMRNUM<>""
               [M:SCRC]CRIUMRNUM=[M:SIH2]UMRNUM
             Endif
           Endif
           Case [M:SIH1]SIHORI
               When 4       : Actzo [M:SCRC]CRISIHNUM : Grizo [M:SCRC]CRISRHNUM
                              #--CPO 87923 Gestion des prélèvements SDD
                              If dim([M:SCRC]CRIUMRNUM)>0
                                If dim([M:SIH2]SDDFLG)>0
                                  If [M:SIH2]SDDFLG=2
                                    Actzo [M:SCRC]CRIUMRNUM
                                  Else
                                    Grizo [M:SCRC]CRIUMRNUM
                                  Endif
                                Else
                                  Grizo [M:SCRC]CRIUMRNUM
                                Endif
                              Endif
                              #--/
               When 6       : Actzo [M:SCRC]CRISRHNUM : Grizo [M:SCRC]CRISIHNUM
                              If dim([M:SCRC]CRIUMRNUM)>0 : Grizo [M:SCRC]CRIUMRNUM : Endif :#--CPO 87923 Gestion des prélèvements SDD
               When Default :
                    If [M:SCRC]CRISIHNUM <> "" Grizo [M:SCRC]CRISRHNUM Endif
                    If [M:SCRC]CRISRHNUM <> ""
                      Grizo [M:SCRC]CRISIHNUM
                      If dim([M:SCRC]CRIUMRNUM)>0 : Grizo [M:SCRC]CRIUMRNUM : Endif :#--CPO 87923 Gestion des prélèvements SDD
                    Endif
                    #--CPO 87923 Gestion des prélèvements SDD
                    If dim([M:SIH2]SDDFLG)>0
                      If [M:SIH2]SDDFLG=2 and [M:SCRC]CRISRHNUM = ""
                        Actzo [M:SCRC]CRIUMRNUM
                      Else
                        Grizo [M:SCRC]CRIUMRNUM
                      Endif
                    # FGR 13/12/2013 : X3SUIVI95093
                    #Else
                    #  Grizo [M:SCRC]CRIUMRNUM
                    Endif
                    #--/
           Endcase
           Affzo [M:SCRC]1-99
Endcase
Return

$DEACTIV_SOH
Grizo [M:SCRI]CRISRENUM, CRICONNUM, CRISDHNUM
Return
$ACTIV_SOH
Actzo [M:SCRI]CRISRENUM, CRICONNUM, CRISDHNUM
Return
$DEACTIV_SDH
Grizo [M:SCRI]CRISRENUM, CRICONNUM, CRISOHNUM, CRIITMREF
Return
$ACTIV_SDH
Actzo [M:SCRI]CRISRENUM, CRICONNUM, CRISOHNUM, CRIITMREF
Return
$DEACTIV_CON
Grizo [M:SCRI]CRISRENUM, CRISOHNUM, CRISDHNUM
Return
$ACTIV_CON
Actzo [M:SCRI]CRISRENUM, CRISOHNUM, CRISDHNUM
Return
$DEACTIV_SRE
Grizo [M:SCRI]CRICONNUM, CRISOHNUM, CRISDHNUM, CRIITMREF
Return
$ACTIV_SRE
Actzo [M:SCRI]CRICONNUM, CRISOHNUM, CRISDHNUM, CRIITMREF
Return
#---------------------------------------------------------#
# Sauvegarde des critères de picking saisis               #
#---------------------------------------------------------#
$OK
Case [M:SIH0]INVTYP
  When 1 : [M:SIH0]=[M:SCRI]
  When 2 : [M:SIH0]=[M:SCRC]
           #--CPO 87923 Gestion des prélèvements SDD
           #--Il faut pouvoir gérer le vide dans le FILGAUCHE5...
           If dim([M:SIH2]UMRNUM)>0 and dim([M:SCRC]CRIUMRNUM)>0
             If [M:SIH2]UMRNUM<>"" and [M:SCRC]CRIUMRNUM=""
               #--On est venus avec un n° de mandat et on sort sans..
               #--Il me faut une valeur bidon afin de la tester dans FILGAUCHE5
               [M:SIH0]CRIUMRNUM="~~~~"
             Endif
           Endif
Endcase

#mkstat = 4 : # ??????
FIN = 1
Return


#---------------------------------------------------------#
# Réalimentation des valeurs initiales                    #
#---------------------------------------------------------#
$ABA

Raz REP
Gosub DEBUT
REP = ""
Affzo [M]1-99

Return
#######################################################################
#                     ACTIONS CHAMPS ECRAN SCRITCNO                   #
#######################################################################
Subprog C_CRISIHNUM(VALEUR)
Variable Char    VALEUR()
Local    Char    WFCY (GLONFCY)

If VALEUR="" End : Endif
# --- La facture doit appartenir à la même société juridique
If clalev([F:FCY])=0 Local File FACILITY [FCY] : Endif
Read [SIV] SIV0=VALEUR : If fstat Raz [F:SIV] : GMESSAGE=VALEUR-":"-mess(23,100,1) : mkstat=2 : End : Endif
WFCY=[F:SIV]SALFCY : Gosub CTLLEGCPY : If mkstat=2 End Endif
# V6.2 : Certification
# Si ctrl date documents : La facture doit avoir une date <= à la date de la facture
If GCTLDATORI=2 & [F:SIV]INVDAT>[M:SIH0]INVDAT
  GMESSAGE=mess(4,413,1)-VALEUR-format$(GFMDAT,[F:SIV]INVDAT)-":\"-mess(348,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
  mkstat=1 : End
Endif
End
#####################################
Subprog AM_CRISIHNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
    Grizo [M]CRISRHNUM : # N°facture renseigné : On grize le n°retour
Elsif [M:SIH4]NBLIG=0 | [M:SIH1]SIHORI=1
    Actzo [M]CRISRHNUM : # N°facture non renseigné et aucune ligne ou avoir direct : On réactive le n°facture
Endif
End
######################################################################################
Subprog C_CRISRHNUM(VALEUR)
Variable Char    VALEUR()
Local    Char    WFCY (GLONFCY)

If VALEUR="" End : Endif
# --- Le retour doit appartenir à la même société juridique
If clalev([F:FCY])=0 Local File FACILITY [FCY] : Endif
Read [SRH] SRH0=VALEUR : If fstat Raz [F:SRH]  : End : Endif
WFCY=[F:SRH]STOFCY : Gosub CTLLEGCPY : If mkstat=2 End Endif
# V6.2 : Certification
# Si ctrl date documents : Le retour doit avoir une date <= à la date de la facture
If GCTLDATORI=2 & [F:SRH]RTNDAT>[M:SIH0]INVDAT
  GMESSAGE=mess(6,413,1)-VALEUR-format$(GFMDAT,[F:SRH]RTNDAT)-":\"-mess(348,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
  mkstat=1 : End
Endif
End
#####################################
Subprog AM_CRISRHNUM(VALEUR)
Variable Char    VALEUR()

If VALEUR<>""
    Grizo [M]CRISIHNUM : # N°retour renseigné : On grize le n°facture
    If dim([M]CRIUMRNUM)>0 : Grizo [M]CRIUMRNUM : Endif :#--CPO 87923 Gestion des prélèvements SDD
Elsif [M:SIH4]NBLIG=0 | [M:SIH1]SIHORI=1
    Actzo [M]CRISIHNUM : # N°retour non renseigné et aucune ligne ou avoir direct : On réactive le n°facture
Endif

If VALEUR = ""
    If dim([M]CRIUMRNUM)>0 : Actzo [M]CRIUMRNUM : Endif :#--CPO 87923 Gestion des prélèvements SDD
Endif

End
#--CPO 87923 Gestion des prélèvements SDD
######################################################################################
## Etiquette ajoutée par le superviseur (écran SCRITCNO) 25/07/2013 16:59:55 (CPO)
######################################################################################
Subprog C_CRIUMRNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR="" End : Endif

End

Subprog AM_CRIUMRNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
    Grizo [M]CRISRHNUM : # N° de mandat renseigné : On grize le n° de retour
Else
    Actzo [M]CRISRHNUM
Endif
End
#--/

#######################################################################
#                     ACTIONS CHAMPS ECRAN SCRITINV                   #
#######################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran SCRITINV) 26/11/2004 14:13:26 (LD)
######################################################################################
Subprog C_CRISRENUM(VALEUR)
Variable Char    VALEUR()
Local    Char    WFCY (GLONFCY)

If VALEUR="" End : Endif
# --- La demande de service doit appartenir à la même société juridique
If clalev([F:FCY])=0 Local File FACILITY [FCY] : Endif
Read [SRE] SRE0=VALEUR : If fstat Raz [F:SRE] : GMESSAGE=VALEUR-":"-mess(23,100,1) : mkstat=2 : End : Endif
WFCY=[F:SRE]SALFCY : Gosub CTLLEGCPY : If mkstat=2 End Endif
# V6.2 : Certification
# Si ctrl date documents : La commande doit avoir une date <= à la date de la facture
If GCTLDATORI=2 & [F:SRE]SREDATASS>[M:SIH0]INVDAT
  GMESSAGE=mess(8,413,1)-VALEUR-format$(GFMDAT,[F:SRE]SREDATASS)-":\"-mess(347,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
  mkstat=1 : End
Endif
End
#####################################
Subprog AM_CRISRENUM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
    Gosub DEACTIV_SRE : # N°dde renseigné : On grize les autres n°
Elsif [M:SIH4]NBLIG=0 | [M:SIH1]SIHORI=1
    Gosub ACTIV_SRE   : # N°dde non renseigné et aucune ligne ou fact. directe : On réactive les autres n°
Endif
End
######################################################################################
Subprog C_CRICONNUM(VALEUR)
Variable Char    VALEUR()
Local    Char    WFCY (GLONFCY)

If VALEUR="" End : Endif
# --- La demande de service doit appartenir à la même société juridique
If clalev([F:FCY])=0 Local File FACILITY [FCY] : Endif
Read [CON] CON0=VALEUR : If fstat Raz [F:CON] : GMESSAGE=VALEUR-":"-mess(23,100,1) : mkstat=2 : End : Endif
WFCY=[F:CON]SALFCY : Gosub CTLLEGCPY : If mkstat=2 End Endif
# V6.2 : Certification
# Si ctrl date documents : Le contrat doit avoir une date <= à la date de la facture
If GCTLDATORI=2 & [F:CON]CONSTRDAT>[M:SIH0]INVDAT
  GMESSAGE=mess(7,413,1)-VALEUR-format$(GFMDAT,[F:CON]CONSTRDAT)-":\"-mess(347,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
  mkstat=1 : End
Endif
End
#####################################
Subprog AM_CRICONNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
    Gosub DEACTIV_CON : # N°contrat renseigné : On grize les autres n°
Elsif [M:SIH4]NBLIG=0 | [M:SIH1]SIHORI=1
    Gosub ACTIV_CON   : # N°contrat non renseigné et aucune ligne ou fact. directe : On réactive les autres n°
Endif
End
######################################################################################
Subprog C_CRISOHNUM(VALEUR)
Variable Char    VALEUR()
Local    Char    WFCY (GLONFCY)

If VALEUR="" End : Endif
# --- La commande doit appartenir à la même société juridique
If clalev([F:FCY])=0 Local File FACILITY [FCY] : Endif
Read [SOH] SOH0=VALEUR : If fstat Raz [F:SOH] : GMESSAGE=VALEUR-":"-mess(23,100,1) : mkstat=2 : End : Endif
WFCY=[F:SOH]SALFCY : Gosub CTLLEGCPY : If mkstat=2 End Endif
# V6.2 : Certification
# Si ctrl date documents : La commande doit avoir une date <= à la date de la facture
If GCTLDATORI=2 & [F:SOH]ORDDAT>[M:SIH0]INVDAT
  GMESSAGE=mess(2,413,1)-VALEUR-format$(GFMDAT,[F:SOH]ORDDAT)-":\"-mess(347,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
  mkstat=1 : End
Endif
End
#####################################
Subprog AM_CRISOHNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
    Gosub DEACTIV_SOH : # N°commande renseigné : On grize les autres n°
Elsif [M:SIH4]NBLIG=0 | [M:SIH1]SIHORI=1
    Gosub ACTIV_SOH   : # N°commande non renseigné et aucune ligne : On réactive les autres n°
Endif
End
######################################################################################
Subprog C_CRISDHNUM(VALEUR)
Variable Char    VALEUR()
Local    Char    WFCY (GLONFCY)

If VALEUR="" End : Endif
# --- La commande doit appartenir à la même société juridique
If clalev([F:FCY])=0 Local File FACILITY [FCY] : Endif
Read [SDH] SDH0=VALEUR : If fstat Raz [F:SDH] : GMESSAGE=VALEUR-":"-mess(23,100,1) : mkstat=2 : End : Endif
WFCY=[F:SDH]SALFCY : Gosub CTLLEGCPY : If mkstat=2 End Endif
# V6.2 : Certification
# Si ctrl date documents : La livraison doit avoir une date <= à la date de la facture
#If GCTLDATORI=2 & [F:SDH]DLVDAT>[M:SIH0]INVDAT : # Dde 73382
If GCTLDATORI=2 & [F:SDH]SHIDAT>[M:SIH0]INVDAT  : # Dde 73382
  #GMESSAGE=mess(3,413,1)-VALEUR-format$(GFMD,[F:SDH]DLVDAT)-":\"-mess(347,192,1) : # Dde 73382
  GMESSAGE=mess(3,413,1)-VALEUR-format$(GFMDAT,[F:SDH]SHIDAT)-":\"-mess(347,192,1) : # Dde 73382 :#--CPO 83985 GFMDAT au lieu de GFMD
  mkstat=1 : End
Endif
End
#####################################
Subprog AM_CRISDHNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
    Gosub DEACTIV_SDH : # N°livraison renseigné : On grize les autres n°
Elsif [M:SIH4]NBLIG=0 | [M:SIH1]SIHORI=1
    Gosub ACTIV_SDH   : # N°livraison non renseigné et aucune ligne : On réactive les autres n°
Endif
End
######################################################################################
#######################################################################
#                     ACTIONS CHAMPS COMMUNES                         #
#######################################################################
######################################################################################
Subprog AM_CRIITMREF(VALEUR)
Variable Char    VALEUR()

Raz [M]CRIITMDES
#If VALEUR<>"" [M]CRIITMDES=[F:ITS]ITMDES1 : Endif
If VALEUR<>""
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITS]ITMREF,[M]CRIITMDES, "[F:ITS]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56270
Endif
Affzo [M]CRIITMDES
End
######################################################################################

# -------------------------------------------------------------------- #
# Contrôle d'appartenance à la même société juridique                  #
# -------------------------------------------------------------------- #
$CTLLEGCPY

Read [FCY] FCY0=WFCY : If fstat Raz [F:FCY] : Endif
If [F:FCY]LEGCPY<>GSOCIETE GMESSAGE=mess(2,194,1) : mkstat=2 : Return : Endif

Return
######################################################################################

