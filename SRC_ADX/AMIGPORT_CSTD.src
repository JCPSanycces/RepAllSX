#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe AMIGPORT

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AREAD"             : Gosub AREAD
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
   When "AIMPORT"           : this.TYP=TYP : this.CLE=CLE : # temporary ?
                                  Gosub AREAD : Gosub AMIGPORT From AMIGSYRPORT
Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return








###############################################
$AREAD
Local Integer SIERR
Local Char QUERY_TYP(20)
Local Char QUERY_CLE(40)

  QUERY_TYP=this.TYP
  QUERY_CLE=this.CLE
  Gosub CHARGE_DET From AMIGPORT_CSTD

Return

###############################################
$CHARGE_DET
  Case QUERY_TYP
    When mess(2,63,1)
             Local File AUTILIS
             Read [AUS]CODUSR=QUERY_CLE
             If fstat
               SIERR=fmet this.ASETERROR("CODE",mess(141,100,1),[V]CST_AERROR) : # User code doesn't exist
             Endif
             this.AUSER=[AUS]USR
    When mess(1,63,1)
             Local File AMETUTI
             Read [AME]AME0=QUERY_CLE
             If fstat
               SIERR=fmet this.ASETERROR("CODE",mess(84,141,1),[V]CST_AERROR) : # Code doesn't exist
             Endif
             this.ATRADE=[AME]CODMET
    When Default
             SIERR=fmet this.ASETERROR("",mess(84,141,1),[V]CST_AERROR) : # Code doesn't exist
  Endcase
 Return

$CHARGE_QUERY
Local Integer NBLIG, MAXLIG : NBLIG=0

Local File AUTILIS
Local File AMETUTI
Local File ATEXTRA

  Filter [AUS] Where ENAFLG=2 and USRCONNECT=2
  MAXLIG=rowcount([AUS])
  MAXLIG=min(MAXLIG+nbrecord([AME]),10000)
  Filter [AUS]

Local Char    TYP_TBL   (20) (1..MAXLIG)
Local Char    CLE_TBL   (40) (1..MAXLIG)
Local Char    INTIT_TBL (100) (1..MAXLIG)


  For [AME]
    Break (NBLIG=dim(TYP_TBL))
    NBLIG+=1 : TYP_TBL(NBLIG)=mess(1,63,1) : CLE_TBL(NBLIG)=[AME]CODMET
    Read [AXX]AXX0="AMETUTI";"INTMET";GACTX.LAN;[AME]CODMET;""
    If fstat
      Read [AXX]AXX0="AMETUTI";"INTMET";"ENG";[AME]CODMET;""
      If fstat
        INTIT_TBL(NBLIG)=""
      Else
        INTIT_TBL(NBLIG)=[AXX]TEXTE
      Endif
    Else
      INTIT_TBL(NBLIG)=[AXX]TEXTE
    Endif
  Next

  For [AUS] Where ENAFLG=2 and USRCONNECT=2
    Break (NBLIG=dim(TYP_TBL))
    NBLIG+=1 : TYP_TBL(NBLIG)=mess(2,63,1) : CLE_TBL(NBLIG)=[AUS]USR
    INTIT_TBL(NBLIG)=[AUS]NOMUSR
  Next

Return

