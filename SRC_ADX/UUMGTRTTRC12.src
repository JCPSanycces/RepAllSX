#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################
# UUMGTRTTRC12          Moulinette de Migration              Module TRC  #
#                                                                        #
#          Update of new field BOMALTTYP                                 #
#                                                                        #
##########################################################################
# From TRCMAJ30  : UPDCBH   : Update of CBNHEA    new field BOMALTTYP    #
#                              +  new flags instead of old CLSTYP        #
##########################################################################
# Issues 80101 & 80102 & get VERSION number - GA 02/2012
##########################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
If !GSERVEUR
  Call SAIDOS(WDOSSIER,"") From SAIDOS
Endif
If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 107271 - 2015-08-05 by CCC
  #Read [ADS]DOSSIER=[L]WDOSSIER : If fstat Raz [F:ADS] : Endif
  If !func DOSSUB.FILL_ADS(WDOSSIER): End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTTRC12") From LECFIC
  Endif

  #Call RAZ_UUMGTRTTRC12(WDOSSIER)
  Call MAJ_UUMGTRTTRC12(WDOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
  If APPLI=GDOSX3 : End : Endif
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 107271 - 2015-08-05 by CCC
  #Read [ADS]DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If !func DOSSUB.FILL_ADS(APPLI): End : Endif
  Call MAJ_UUMGTRTTRC12(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTTRC12(APPLI)
End

##########################################################################
Subprog MAJ_UUMGTRTTRC12(WDOSSIER)
Value Char WDOSSIER

adxftl=10
adxwrb=10
NEWMOTEUR=1

If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 107271 - 2015-08-05 by CCC
#Read [ADS]DOSSIER=WDOSSIER : If fstat Raz [F:ADS] : Endif
If !func DOSSUB.FILL_ADS(WDOSSIER): End : Endif

GOK=1
Gosub LOA_BOM From UUMGTRTTRC00

Gosub UPDCBH
If GOK<=0
    Call ECR_TRACE("UUMGTRTTRC12 table CBNHEA Incorrectly Processed : Update CBH"-WDOSSIER,1) From GESECRAN
Endif
End
##########################################################################
Subprog RAZ_UUMGTRTTRC12(WDOSSIER)
Value Char WDOSSIER

Local Integer ERR

GOK=1

##1 - verifications
####################

If [F:ADS]MODULE(8)<>2 | [F:ADS]MODULE(6)<>2 : End : Endif          : # N= no module

Local Char WNAMFICM
Call MIGTABNAME (WDOSSIER,"CBNHEA",WNAMFICM,ERR) From TRTMIG
If ERR : End : Endif

##2 - On vide les fichiers selon le cas
#######################################

If  filinfo(filpath("FIL","CBNHEA","fde",WDOSSIER),0)>0
& & filinfo(filpath("FIL",WNAMFICM,"fde",WDOSSIER),0)>0
  #Call ECR_TRACE("RAZ_ Raz table CBNHEA"-WDOSSIER,0) From GESECRAN
  Call MIGTABRAZ (WDOSSIER,"CBNHEA",ERR) From TRTMIG
  Call MIGRAZKEY (WDOSSIER,"UUMGTRTTRC12",ERR) From TRTMIG
Endif

End


###############################################################################
# UPDCBH : - INIT du type d'alternative BOMALTTYP
###############################################################################
# Paramètres E : WDOSSIER   = Dossier
###############################################################################
$UPDCBH
Local Integer ERR

GOK=1

##1 - verifications
####################

If [F:ADS]MODULE(8)<>2 | [F:ADS]MODULE(6)<>2 : # Module 9=Tronc commun et 7=Stock
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC12",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

#----- Is new file ok ? ...  -----#
If filinfo(filpath("FIL","CBNHEA","fde",WDOSSIER),0) <=0
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC12",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

Local Char WNAMCBHM
Call MIGTABNAME (WDOSSIER,"CBNHEA",WNAMCBHM,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC12",7,ERR) From TRTMIG : #7=Erreur
  Return
Endif

#----- Is old renamed file ok ?...  -----#
If filinfo(filpath("FIL",WNAMCBHM,"fde",WDOSSIER),0) < 0
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC12",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif


##2 - Traitements en cours
####################

Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC12",2,ERR) From TRTMIG : #2=En cours

#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (WDOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC12",7,ERR) From TRTMIG : #7=Erreur
  Return : # End # 2015-11-09 by GH
Endif

###################

Call ECR_TIME("UUMGTRTTRC12 tables CBH Process : Update CBH") From DOSSUB
Call ECR_TRACE("UUMGTRTTRC12:Process Start on : "+WDOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (WDOSSIER,"CBNHEA",ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:CBH])  = 0 : Local File =WDOSSIER+".CBNHEA"      [CBH]  : Endif   # Fichier X3 "Vide"
If clalev([F:CBHM]) = 0 : Local File =WDOSSIER+"."+WNAMCBHM   [CBHM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:ITM])  = 0 : Local File =WDOSSIER+".ITMMASTER"   [ITM]  : Endif   # Articles migrés pour recup des *FLG

#-----  Déclaration des variables -----#
Local Char WTAB_CBH (100) (adxwrb) : # Issue 112303 - 2015-11-09 by GH - not to do before MIG_OUVRE
Local Shortint WCPT_CBH

# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, ISVALID, NBCOMMIT, NBLUS
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30) # Issue 80101 ajout HINTSPE
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE

# Déclaration des variables communes de travail
Local Integer I, J

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (WDOSSIER,"UUMGTRTTRC12",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

#-----  Lien des tables entête & lignes -----#
Link [CBHM] With [ITM]ITM0~=[F:CBHM]ITMREF
&    As [LNK]
&    Order By Key CLE = [F:CBHM]STOFCY;[F:CBHM]ITMREF

# PE pour ajout clause where
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTTRC12" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_CBH00
Raz NB
# Issue 80145 Key=STOFCY+ITMREF instead of ITMREF+STOFCY
If STOP=1
 STOP = 2
 CRITERE = "[F:CBHM]STOFCY=TABMIGKEY(1) & [F:CBHM]ITMREF>TABMIGKEY(2)"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:CBHM]STOFCY>TABMIGKEY(1) "
Else
 CRITERE = "1=1"
Endif

Trbegin [CBH]
GOK = 1

For [LNK]CLE Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS += 1

  # PE pour exclure ligne
  If FILTRELIN
      ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto NEXT_CBH : Endif
  Endif

  #Raz [F:CBH]
  # version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_CBH
  Endif
  [F:CBH] = [F:CBHM]

  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_CBH
    If GOK<1 : Break : Endif
  Endif

  # --- alimentation des champs et écriture enreg
  If NEWMOTEUR
      Gosub CBH_STK : # pour stocker ref
      WriteB [F:CBH]
  Else
      Write [F:CBH]
  Endif
  If fstat
    If NEWMOTEUR & adxwrb>1
      Call ECR_TRACE("File CBNHEA, Error ="-num$(fstat),1) From GESECRAN
      Gosub CBH_ERRTRA : # pour afficher les ref
    Else
      Call ECR_TRACE("File CBNHEA(STOFCY/ITMREF)"-[F:CBH]STOFCY-"/"-[F:CBH]ITMREF+", ERROR ="-num$(fstat),1) From GESECRAN
    Endif
    GOK=0 : Break
  Endif

  NB+=1
  If NB>GMAXUPDTRS
   # Issue 80145 Key=STOFCY+ITMREF au lieu de ITMREF+STOFCY
    TABMIGKEY(1) = [F:CBHM]STOFCY
    TABMIGKEY(2) = [F:CBHM]ITMREF
    STOP=1
    Break
  Endif
$NEXT_CBH
Next

$END_CBH
If GOK<1
  Rollback
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTTRC12",7,ERR) From TRTMIG : #7=Erreur
Else
  If NEWMOTEUR & adxwrb>1
    Flush [F:CBH]
    If fstat
        Call ECR_TRACE("File CBNHEA, Error ="-num$(fstat),1) From GESECRAN
        Gosub CBH_ERRTRA : # pour afficher les ref
        GOK=0 : Goto END_CBH : #on part sur rollback
    Endif
  Endif
  If STOP
    TABMIGKEY(NBMIGKEY)=num$(STOP)
  Else
    Raz TABMIGKEY
  Endif
  # Stocker les valeurs de ACLE1/ACLE2/ACLE3/ACLE4/STOP dans la table AMIGKEY.
  Call MIGSTKKEY (WDOSSIER,FLUX,NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
  If ERR
   GOK=-1 : Goto END_CBH
  Endif
  Commit
  NBCOMMIT+=NB
  Call MIGSTKPROGRESS (WDOSSIER,"UUMGTRTTRC12",STOP,ERR) From TRTMIG
  If STOP
    Goto LOOP_CBH00
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [CBH]
Close Local File [CBHM]
Close Local File [ITM]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (WDOSSIER,"CBNHEA",ERR) From TRTMIG
Call MIGTRTEND (WDOSSIER,"UUMGTRTTRC12") From TRTMIG
Call ECR_TIME("UUMGTRTTRC12:"+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
Return

#######################################################################
$CBH_STK
Call STK (WTAB_CBH,WCPT_CBH,[F:CBH]STOFCY-"/"-[F:CBH]ITMREF) From TRTMIG
Return

#######################################################################
$CBH_ERRTRA
Call ERRTRA (WTAB_CBH,WCPT_CBH,"File CBNHEA(STOFCY/ITMREF)=") From TRTMIG
Return

##########################################################################
$RAZV6_CBH
Raz [F:CBH]BOMALTTYP
Return

#######################################################################
# Code extrait de TRCMAJ30 - table CBNHEA
########################################################################
$MAJV6_CBH
[F:CBH]MFGFLG = [F:ITM]MFGFLG
[F:CBH]SCPFLG = [F:ITM]SCPFLG
[F:CBH]SCSFLG = [F:ITM]SCSFLG
[F:CBH]PHAFLG = [F:ITM]PHAFLG
[F:CBH]GENFLG = [F:ITM]GENFLG
[F:CBH]TOOFLG = [F:ITM]TOOFLG
[F:CBH]DLVFLG = [F:ITM]DLVFLG
[F:CBH]PURFLG = [F:ITM]PURFLG
[F:CBH]SALFLG = [F:ITM]SALFLG
[F:CBH]INTFLG = [F:ITM]INTFLG
If [F:CBH]BOMALT > 0 & [F:CBH]BOMALTTYP=0
   [F:CBH]BOMALTTYP=WBOMALTTYP([F:CBH]BOMALT)
Endif
#[F:CBH]UPDUSR=GUSER
#[F:CBH]UPDDAT=date$
Return

