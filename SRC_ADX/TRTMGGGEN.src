#<AdxTL>@(#)8.0.0.0 $Revision$
#########################################################################
# Pour exécution hors intégration de patch
#########################################################################

Local Char DOSSIER(30)
Local Integer IERRTRT

  DOSSIER = nomap
  Call SAIDOS(DOSSIER,"") From SAIDOS
  If DOSSIER<>""
    Call TEMPON("O") From GESECRAN
    # FGR 09/04/2008 : X3SUIVI46633
    #Call OUVRE_TRACE("Query support regeneration") From LECFIC
    Call OUVRE_TRACE(mess(475,183,1)) From LECFIC
    #
    Call GENSUPPORT(DOSSIER, IERRTRT)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif
End
#########################################################################
#####################################################################################################################
#                                                                                                                   #
# Régénération des supports de sélection                                              Module CRM   19 juillet 2002  #
#                                                                                                                   #
#####################################################################################################################
#####################################################################################################################
Subprog PATCH(APPLI)
Value Char APPLI

Local Integer IERR2

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
    End
  Endif
  #Si Module Support client non actif. On ne fait rien.
  If [F:ADS]MODULE(11) <> 2 Then
    End
  Endif
  #Si Module Action Co non actif. On ne fait rien.
  If [F:ADS]MODULE(12) <> 2 Then
    End
  Endif
  Call GENSUPPORT(APPLI, IERR2)
End

#######################################################################
Subprog GENSUPPORT(SZAPPLI, IPBL)
Value Char SZAPPLI
Variable Integer IPBL

Local Integer ITERATOR

  # FGR 10/07/2009 : X3SUIVI56465 (début)
  If !clalev([F:TLA]) : Local File =SZAPPLI+".TABLAN" [TLA] : Endif
  Call COMPTE_LANGUE
  # FGR 10/07/2009 : X3SUIVI56465 (fin)

Local Char SZLNKBPR(30)(50)
Local Char SZLNKIDXBPR(30)(50)
Local Char SZLNKEXPBPR(80)(50)
Local Char SZLNKCCN(30)(50)
Local Char SZLNKIDXCCN(30)(50)
Local Char SZLNKEXPCCN(80)(50)
Local Char SZLNKMAC(30)(50)
Local Char SZLNKIDXMAC(30)(50)
Local Char SZLNKEXPMAC(80)(50)
Local Char SZLNKSOL(30)(50)
Local Char SZLNKIDXSOL(30)(50)
Local Char SZLNKEXPSOL(80)(50)
Local Char SZLNKSRE(30)(50)
Local Char SZLNKIDXSRE(30)(50)
Local Char SZLNKEXPSRE(80)(50)
Local Char SZMACTXT
Local Char SZTEXTCIBLE(GLONDCO)(GNBLANGUE,2)  # FGR 10/07/2009 : X3SUIVI56465
Local Char SZTEXTFID(GLONDCO)(GNBLANGUE,2)    # FGR 10/07/2009 : X3SUIVI56465

  IPBL = 0
  Raz SZLNKBPR
  Raz SZLNKIDXBPR
  Raz SZLNKEXPBPR
  Raz SZLNKCCN
  Raz SZLNKIDXCCN
  Raz SZLNKEXPCCN
  Raz SZLNKMAC
  Raz SZLNKIDXMAC
  Raz SZLNKEXPMAC
  Raz SZLNKSOL
  Raz SZLNKIDXSOL
  Raz SZLNKEXPSOL
  Raz SZLNKSRE
  Raz SZLNKIDXSRE
  Raz SZLNKEXPSRE
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  # FGR 09/04/2008 : X3SUIVI46633
  #Call ECR_TIME("Start query support regeneration") From DOSSUB
  Call ECR_TIME(mess(476,183,1)) From DOSSUB
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  ##################################################################################
  # Ouverture des tables utiles.
  ##################################################################################
  If !clalev([F:DVA]) : Local File =SZAPPLI+".DEFVAL" [DVA] : Endif
  If !clalev([F:TGL]) : Local File =SZAPPLI+".TGRLIS" [TGL] : Endif
  If !clalev([F:TLL]) : Local File =SZAPPLI+".TGRLISLNK" [TLL] : Endif
  If !clalev([F:TLF]) : Local File =SZAPPLI+".TGRLISFIE" [TLF] : Endif
  If !clalev([F:TGP]) : Local File =SZAPPLI+".TGRSSP" [TGP] : Endif
  If !clalev([F:SSP]) : Local File =SZAPPLI+".SELSSP" [SSP] : Endif
  If !clalev([F:SSC]) : Local File =SZAPPLI+".SELSSPCPN" [SSC] : Endif
  If !clalev([F:FID]) : Local File =SZAPPLI+".FIEDIC" [FID] : Endif
  If !clalev([F:FDF]) : Local File =SZAPPLI+".FIEDICFIE" [FDF] : Endif
  If !clalev([F:ATZ]) : Local File =SZAPPLI+".ATABZON" [ATZ] : Endif
  If !clalev([F:AXX]) : Local File =SZAPPLI+".ATEXTRA" [AXX] : Endif
  If !clalev([F:ATX]) : Local File =SZAPPLI+".ATEXTE" [ATX] : Endif    # FGR 10/07/2009 : X3SUIVI56465
  If !clalev([F:AST]) : Local File =SZAPPLI+".APLSTD" [AST] : Endif    # FGR 10/07/2009 : X3SUIVI56465
  ##################################################################################
  # Etape 1 : Répertoire des champs de sélection
  ##################################################################################
  # Contenu du répertoire : 
  # OPPOR|OPPSRENUM       = SERREQUEST
  # SCRIPT|CREUSR         = AUTILIS
  # SCPASW|SCP            = SCRIPT
  # SCPQST|SCPNUM         = SCRIPT
  # MACHINES|BPCNUM       = BPARTNER
  # MACHINES|CCNNUM       = CONTACTCRM
  # SERREQUEST|CREUSR     = AUTILIS
  # SERREQUEST|SOLNUM     = SOLUTION
  # ITMMASTER|ITMREF      = ITMMASTER
  # MARASSDEF|MARSCTNUM   = MARSCT
  # TABLINCFG|CFGLIN      = TABLINCFG
  ##################################################################################
  Call ECR_TIME(mess(493,183,1)) From DOSSUB
  #On nettoie le répertoire des champs de sélection
  Trbegin [DVA]
  Delete [DVA] Where [F:DVA]OBC = "MGV"
  If fstat Then
    Rollback
    IPBL = 1
    Call ECR_TRACE(mess(477,183,1),1) From GESECRAN
    Call ECR_TIME(mess(478,183,1)) From DOSSUB
    End
  Else
    Commit
  Endif
  #####################################
  #On génère 
  Trbegin [DVA]
  Call WRITE_DVA ("MGV", "OPPOR|OPPSRENUM", "SERREQUEST", IPBL)
  Call WRITE_DVA ("MGV", "SCRIPT|CREUSR", "AUTILIS", IPBL)
  Call WRITE_DVA ("MGV", "SCPASW|SCP", "SCRIPT", IPBL)
  Call WRITE_DVA ("MGV", "SCPQST|SCPNUM", "SCRIPT", IPBL)
  Call WRITE_DVA ("MGV", "MACHINES|BPCNUM", "BPARTNER", IPBL)
  Call WRITE_DVA ("MGV", "MACHINES|CCNNUM", "CONTACTCRM", IPBL)
  Call WRITE_DVA ("MGV", "SERREQUEST|CREUSR", "AUTILIS", IPBL)
  Call WRITE_DVA ("MGV", "SERREQUEST|SOLNUM", "SOLUTION", IPBL)
  Call WRITE_DVA ("MGV", "ITMMASTER|ITMREF", "ITMMASTER", IPBL)
  Call WRITE_DVA ("MGV", "MARASSDEF|MARSCTNUM", "MARSCT", IPBL)
  Call WRITE_DVA ("MGV", "TABLINCFG|CFGLIN", "TABLINCFG", IPBL)
  If IPBL Then
    Rollback
    End
  Endif
  Commit
  Call ECR_TIME(mess(480,183,1)) From DOSSUB
  #################################################################################
  # Etape 2 : Définition des cibles standards
  #################################################################################
  Call ECR_TIME(mess(481,183,1)) From DOSSUB
  #On charge les tableaux tampon
  #BPARTNER
  ITERATOR = 0
  Filter [TLL] Where [F:TLL]TGRTAB = "BPARTNER"
  For [TLL]
    If [F:TLL]TGRLNK <> "BPADDRESS" Then
      If [F:TLL]TGRLNK <> "BPCUSTOMER" Then
        SZLNKBPR(ITERATOR) = [F:TLL]TGRLNK
        SZLNKIDXBPR(ITERATOR) = [F:TLL]TGRLNKIDX
        SZLNKEXPBPR(ITERATOR) = [F:TLL]TGREXPLNK
        ITERATOR += 1
      Endif
    Endif
  Next
  Filter [TLL]
  #CONTACTCRM
  ITERATOR = 0
  Filter [TLL] Where [F:TLL]TGRTAB = "CONTACTCRM"
  For [TLL]
    If [F:TLL]TGRLNK <> "CONTACT" Then
      SZLNKCCN(ITERATOR) = [F:TLL]TGRLNK
      SZLNKIDXCCN(ITERATOR) = [F:TLL]TGRLNKIDX
      SZLNKEXPCCN(ITERATOR) = [F:TLL]TGREXPLNK
      ITERATOR += 1
    Endif
  Next
  Filter [TLL]
  #MACHINES
  ITERATOR = 0
  Filter [TLL] Where [F:TLL]TGRTAB = "MACHINES"
  For [TLL]
    SZLNKMAC(ITERATOR) = [F:TLL]TGRLNK
    SZLNKIDXMAC(ITERATOR) = [F:TLL]TGRLNKIDX
    SZLNKEXPMAC(ITERATOR) = [F:TLL]TGREXPLNK
    ITERATOR += 1
  Next
  Filter [TLL]
  #SOLUTION
  ITERATOR = 0
  Filter [TLL] Where [F:TLL]TGRTAB = "SOLUTION"
  For [TLL]
    If [F:TLL]TGRLNK <> "SERREQUEST" Then
      SZLNKSOL(ITERATOR) = [F:TLL]TGRLNK
      SZLNKIDXSOL(ITERATOR) = [F:TLL]TGRLNKIDX
      SZLNKEXPSOL(ITERATOR) = [F:TLL]TGREXPLNK
      ITERATOR += 1
    Endif
  Next
  Filter [TLL]
  #SERREQUEST
  ITERATOR = 0
  Filter [TLL] Where [F:TLL]TGRTAB = "SERREQUEST"
  For [TLL]
    If [F:TLL]TGRLNK <> "SOLUTION" Then
      SZLNKSOL(ITERATOR) = [F:TLL]TGRLNK
      SZLNKIDXSOL(ITERATOR) = [F:TLL]TGRLNKIDX
      SZLNKEXPSOL(ITERATOR) = [F:TLL]TGREXPLNK
      ITERATOR += 1
    Endif
  Next
  Filter [TLL]
  #######################################
  #On nettoie le répertoire des cibles
  Trbegin [TGL], [TLL]
  Delete [TGL] Where [F:TGL]TGRLISSTD = 1
  If fstat Then
    Rollback
    IPBL = 1
    Call ECR_TRACE(mess(482,183,1),1) From GESECRAN
    Call ECR_TIME(mess(483,183,1)) From DOSSUB
    End
  Endif
  #On nettoie le répertoire des tables liées aux cibles
  Delete [TLL] Where [F:TLL]TGRLNKSTD = 1
  If fstat Then
    Rollback
    IPBL = 1
    Call ECR_TRACE(mess(482,183,1),1) From GESECRAN
    Call ECR_TIME(mess(483,183,1)) From DOSSUB
    End
  Endif
  Commit
  #On nettoie le répertoire des cibles
  Call DELETE_TGL_TLL ("BPARTNER", IPBL)
  Call DELETE_TGL_TLL ("CONTACTCRM", IPBL)
  Call DELETE_TGL_TLL ("MACHINES", IPBL)
  Call DELETE_TGL_TLL ("SOLUTION", IPBL)
  Call DELETE_TGL_TLL ("SERREQUEST", IPBL)
  If IPBL Then
    End
  Endif
  #####################################
  #On génère 
  Trbegin [TGL], [TLL]
  #Tiers
  #Call TEXTE(1500, SZTEXTCIBLE) From OBJDIV   #Tiers
  Call TEXTELAN(2, 1500, -1, SZTEXTCIBLE)      #Tiers # FGR 10/07/2009 : X3SUIVI56465
  Call WRITE_TGL ("BPARTNER", SZTEXTCIBLE, mess(1,183,1), "DEFBPARTNER", "BPRNUM", "BPR", IPBL)
  Call WRITE_TLL ([F:TGL]TGRTAB, "BPCUSTOMER", "BPC0", "[F:BPR]BPRNUM", 1, IPBL)
  Call WRITE_TLL ([F:TGL]TGRTAB, "BPADDRESS", "BPA0", "1;[F:BPR]BPRNUM;[F:BPR]BPAADD", 1, IPBL)
  #On rajoute les tables liées par l'utilisateur
  For ITERATOR = 0 To dim(SZLNKBPR)-1
    If SZLNKBPR(ITERATOR) = ""  Then
      Break
    Else
      Call WRITE_TLL ([F:TGL]TGRTAB, SZLNKBPR(ITERATOR), SZLNKIDXBPR(ITERATOR), SZLNKEXPBPR(ITERATOR), 0, IPBL)
    Endif
  Next
  #Interlocuteurs
  #Call TEXTE(14398, SZTEXTCIBLE) From OBJDIV   #Interlocuteurs
  Call TEXTELAN(2, 14398, -1, SZTEXTCIBLE)      #Interlocuteurs # FGR 10/07/2009 : X3SUIVI56465
  Call WRITE_TGL ("CONTACTCRM", SZTEXTCIBLE, mess(2,183,1), "DEFCONTACTCRM", "CNTNUM", "AIN", IPBL)
  Call WRITE_TLL ([F:TGL]TGRTAB, "CONTACT", "CNT2", "[F:AIN]CNTNUM", 1, IPBL)
  #On rajoute les tables liées par l'utilisateur
  For ITERATOR = 0 To dim(SZLNKCCN)-1
    If SZLNKCCN(ITERATOR) = "" Then
      Break
    Else
      Call WRITE_TLL ([F:TGL]TGRTAB, SZLNKCCN(ITERATOR), SZLNKIDXCCN(ITERATOR), SZLNKEXPCCN(ITERATOR), 0, IPBL)
    Endif
  Next
  #Parc client
  #Call TEXTE(14542, SZTEXTCIBLE) From OBJDIV   #Parc client
  Call TEXTELAN(2, 14542, -1, SZTEXTCIBLE)      #Parc client # FGR 10/07/2009 : X3SUIVI56465
  Call TEXTE(14542, [F:TGL]TGRDES) From OBJDIV  #Parc client
  Call WRITE_TGL ("MACHINES", SZTEXTCIBLE, [F:TGL]TGRDES, "DEFMACHINES", "MACNUM", "MAC", IPBL)
  #On rajoute les tables liées par l'utilisateur
  For ITERATOR = 0 To dim(SZLNKMAC)-1
    If SZLNKMAC(ITERATOR) = "" Then
      Break
    Else
      Call WRITE_TLL ([F:TGL]TGRTAB, SZLNKMAC(ITERATOR), SZLNKIDXMAC(ITERATOR), SZLNKEXPMAC(ITERATOR), 0, IPBL)
    Endif
  Next
  #Solutions
  #Call TEXTE(14576, SZTEXTCIBLE) From OBJDIV   #Solutions
  Call TEXTELAN(2, 14576, -1, SZTEXTCIBLE)      #Solutions # FGR 10/07/2009 : X3SUIVI56465
  Call TEXTE(14576, [F:TGL]TGRDES) From OBJDIV  #Solutions
  Call WRITE_TGL ("SOLUTION", SZTEXTCIBLE, [F:TGL]TGRDES, "DEFSOLUTION", "NUM", "SOL", IPBL)
  Call WRITE_TLL ([F:TGL]TGRTAB, "SERREQUEST", "SRE6", "[F:SOL]NUM", 1, IPBL)
  #On rajoute les tables liées par l'utilisateur
  For ITERATOR = 0 To dim(SZLNKSOL)-1
    If SZLNKSOL(ITERATOR) = "" Then
      Break
    Else
      Call WRITE_TLL ([F:TGL]TGRTAB, SZLNKSOL(ITERATOR), SZLNKIDXSOL(ITERATOR), SZLNKEXPSOL(ITERATOR), 0, IPBL)
    Endif
  Next
  #Demandes de service
  #Call TEXTE(14508, SZTEXTCIBLE) From OBJDIV   #Demandes de service
  Call TEXTELAN(2, 14508, -1, SZTEXTCIBLE)      #Demandes de service # FGR 10/07/2009 : X3SUIVI56465
  Call TEXTE(14508, [F:TGL]TGRDES) From OBJDIV  #Demandes de service
  Call WRITE_TGL ("SERREQUEST", SZTEXTCIBLE, [F:TGL]TGRDES, "DEFSERREQUEST", "SRENUM", "SRE", IPBL)
  Call WRITE_TLL ([F:TGL]TGRTAB, "SOLUTION", "SOL1", "[F:SRE]SOLNUM", 1, IPBL)
  #On rajoute les tables liées par l'utilisateur
  For ITERATOR = 0 To dim(SZLNKSOL)-1
    If SZLNKSOL(ITERATOR) = "" Then
      Break
    Else
      Call WRITE_TLL ([F:TGL]TGRTAB, SZLNKSRE(ITERATOR), SZLNKIDXSRE(ITERATOR), SZLNKEXPSRE(ITERATOR), 0, IPBL)
    Endif
  Next
  If IPBL Then
    Rollback
    End
  Endif
  Commit
  Call ECR_TIME(mess(494,183,1)) From DOSSUB
  ################################################################################
  # Etape 3 : Définition des supports de sélection standards
  ################################################################################
  Gosub GENSSPSTD From TRTMGGSSP
  If IPBL Then
    Call ECR_TIME(mess(489,183,1)) From DOSSUB
    End
  Endif
  ################################################################################
  # Etape 4 : Définition des supports de présentation standards
  ################################################################################
  Call ECR_TIME(mess(495,183,1)) From DOSSUB
  Call TEXTE(14542, SZMACTXT) From OBJDIV   #Parc client
  #On nettoie le répertoire des supports de présentation
  Trbegin [TGP], [TLF]
  Delete [TGP] Where [F:TGP]SPTSTD = 1
  If fstat Then
    Rollback
    IPBL = 1
    Call ECR_TRACE(mess(486,183,1),1) From GESECRAN
    Call ECR_TIME(mess(490,183,1)) From DOSSUB
    End
  Endif
  #On nettoie le répertoire des supports de présentation
  Delete [TLF] Where [F:TLF]TGRFIESTD = 1
  If fstat Then
    Rollback
    IPBL = 1
    Call ECR_TRACE(mess(486,183,1),1) From GESECRAN
    Call ECR_TIME(mess(490,183,1)) From DOSSUB
    End
  Endif
  Commit
  #####################################
  #On génère 
  Trbegin [TGP], [TLF]
  #Tiers
  Call WRITE_TGP ("DEFBPARTNER", "BPARTNER", "POSCOD", "BPADDRESS", 1, IPBL)
  #Champs à afficher
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "BPARTNER", "BPRNUM", 1, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "BPARTNER", "BPRNAM", 2, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "BPADDRESS", "POSCOD", 3, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "BPADDRESS", "CTY", 4, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "BPADDRESS", "SAT", 5, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "BPADDRESS", "CRYNAM", 6, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "BPADDRESS", "FAX", 7, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "BPADDRESS", "WEB", 8, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "BPARTNER", "NAF", 9, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "BPARTNER", "BPCFLG", 10, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "BPARTNER", "PPTFLG", 11, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "BPARTNER", "BPSFLG", 12, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "BPARTNER", "BPTFLG", 13, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "BPARTNER", "REPFLG", 14, 1, IPBL)
  #Interlocuteurs
  Call WRITE_TGP ("DEFCONTACTCRM", "CONTACTCRM", "CNTLNA", "CONTACTCRM", 1, IPBL)
  #Champs à afficher
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "CONTACTCRM", "CNTTTL", 1, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "CONTACTCRM", "CNTFNA", 2, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "CONTACTCRM", "CNTLNA", 3, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "CONTACTCRM", "ZIP", 4, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "CONTACTCRM", "CTY", 5, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "CONTACTCRM", "SAT", 6, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "CONTACTCRM", "CRY", 7, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "CONTACTCRM", "CNTETS", 8, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "CONTACTCRM", "CNTFAX", 9, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "CONTACTCRM", "CNTEMA", 10, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "CONTACTCRM", "CNTCSP", 11, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "CONTACTCRM", "CNTNUM", 12, 1, IPBL)
  #Parc client
  Call WRITE_TGP ("DEFMACHINES", "MACHINES", "MACNUM", "MACHINES", 1, IPBL)
  #Champs à afficher
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "MACHINES", "MACNUM", 1, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "MACHINES", "MACPDTCOD", 2, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "MACHINES", "MACDES", 3, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "MACHINES", "MACQTY", 4, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "MACHINES", "MACSERNUM", 5, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "MACHINES", "MACBRACLA", 6, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "MACHINES", "MACITNTYP", 7, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "MACHINES", "MACCUTBPC", 8, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "MACHINES", "MACBPCDAT", 9, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "MACHINES", "MACBPCPRI", 10, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "MACHINES", "MACBPCCUR", 11, 1, IPBL)
  #Solutions
  Call WRITE_TGP ("DEFSOLUTION", "SOLUTION", "NUM", "SOLUTION", 1, IPBL)
  #Champs à afficher
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "SOLUTION", "TTR", 1, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "SOLUTION", "CAT", 2, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "SOLUTION", "CREUSR", 3, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "SOLUTION", "CREDAT", 4, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "SOLUTION", "CREHOU", 5, 1, IPBL)
  Call WRITE_TLF ([F:TGP]TGR, [F:TGP]TGRSSPNUM, "SOLUTION", "NUM", 6, 1, IPBL)
  #Demandes de service
