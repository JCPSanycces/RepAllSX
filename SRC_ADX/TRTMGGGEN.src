#######################################################################
Subprog COMPTE_LANGUE

  # FGR 10/07/2009 : X3SUIVI56465
  # Les table TABLAN[TLA] doit être ouvertes avant sur le bon dossier
  If dim(GNBLANGUE) < 0 Then
    Global Integer GNBLANGUE

    GNBLANGUE = rowcount([TLA])
  Endif
End

######################################################################
Subprog TEXTELAN(PCAS, PNUM, PCHAP, RTEXTE)
Value Integer PCAS
Value Integer PNUM
Value Integer PCHAP
Variable Char RTEXTE()(,)

Local Integer NI
Local Integer NOUVERT

  # FGR 10/07/2009 : X3SUIVI56465
  # Les table APLSTD[AST] et ATEXTE[ATX] doivent être ouvertes avant sur le bon dossier
  # FGR 07/10/2009 : Si la table n'est pas ouverte, je l'ouvre sur le dossier courant et la referme
  NI = 0
  NOUVERT = 0
  Raz RTEXTE
  If PCAS = 1 Then
    # mess(x,x,x) dans toutes les langues : table APLSTD
    If clalev([F:AST]) = 0 : Local File APLSTD [AST] : NOUVERT = 1 : Endif
    Filter [AST] Where LANCHP = PCHAP and LANNUM = PNUM
    For [AST]
      RTEXTE(NI,0) = [F:AST]LAN
      RTEXTE(NI,1) = [F:AST]LANMES
      NI += 1
    Next
    Filter [AST]
    If NOUVERT = 1 Then
      Close File [AST]
    Endif
  Elsif PCAS = 2 Then
    # Call TEXTE(xx,xx) From OBJDIV dans toutes les langues : table ATEXTE
    If clalev([F:ATX]) = 0 : Local File ATEXTE [ATX] : NOUVERT = 1 : Endif
    Filter [ATX] Where NUMERO = PNUM
    For [ATX]
      RTEXTE(NI,0) = [F:ATX]LAN
      RTEXTE(NI,1) = [F:ATX]TEXTE
      NI += 1
    Next
    Filter [ATX]
    If NOUVERT = 1 Then
      Close File [ATX]
    Endif
  Else
    # On fait rien, ça RAZ juste RTEXTE
  Endif
End

######################################################################
Subprog MAJTEXTRALAN(SZTEXTE, TABLE, CHAMP, CLE1, CLE2)
Value Char SZTEXTE()(,)
Value Char TABLE
Value Char CHAMP
Value Char CLE1
Value Char CLE2

Local Char ZSVLANGUE(GLONLAN)
Local Integer NI

  # FGR 10/07/2009 : X3SUIVI56465
  NI = 0
  ZSVLANGUE = GLANGUE
  While SZTEXTE(NI,0) <> "" and NI < dim(SZTEXTE)
    GLANGUE = SZTEXTE(NI,0)
    Call MAJTEXTRA(SZTEXTE(NI,1), TABLE, CHAMP, CLE1, CLE2) From ATEXTRA
    NI += 1
  Wend
  GLANGUE = ZSVLANGUE
End
