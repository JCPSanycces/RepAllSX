  #Trbegin [FID]
  Trbegin [FID], [AXX]
  For [FID] Where [F:FID]CAT = ""
    Call SUPTEXTRA("FIEDIC", "CRITABAXX", [F:FID]CRITAB, [F:FID]CAT) From ATEXTRA
  Next
  # FGR 23/12/2009 : X3SUIVI61144 (fin)
  Delete [FID] Where [F:FID]CAT = ""
  If fstat Then
    Rollback
    IPBL = 1
    Call ECR_TRACE(mess(488,183,1),1) From GESECRAN
    Call ECR_TIME(mess(491,183,1)) From DOSSUB
    End
  Else
