  Trbegin [FID], [FDF]
  Call TEXTELAN(1, 410, 183, SZTEXTFID)     #Consommations après-vente # FGR 10/07/2009 : X3SUIVI56465
  Call WRITE_FID ("HDKTASK", SZTEXTFID, "", IPBL)
  If IPBL Then
    Rollback
    End
  Endif
  Gosub COSMETIC4 From TRTMGGG8
  If IPBL Then
    Rollback
    Call ECR_TIME(mess(491,183,1)) From DOSSUB
    End
  Endif
  Commit
  ###########
  #ESCSRE
  Trbegin [FID], [FDF]
  Call TEXTELAN(1, 14, 972, SZTEXTFID)     #Escalades # FGR 10/07/2009 : X3SUIVI56465
  Call WRITE_FID ("ESCSRE", SZTEXTFID, "", IPBL)
  If IPBL Then
    Rollback
    End
  Endif
  Gosub COSMETIC5 From TRTMGGG8
  If IPBL Then
    Rollback
    Call ECR_TIME(mess(491,183,1)) From DOSSUB
    End
  Endif
  Commit
  Call ECR_TIME(mess(498,183,1)) From DOSSUB
  ################################################################################
  # Etape 6 : Création des formules de dimensionnement des tables relatives au ciblage marketing
  ################################################################################
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME(mess(492,183,1)) From DOSSUB
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  #
  If dim(GNBLANGUE) > 0 Then
    # FGR 10/07/2009 : X3SUIVI56465
    Kill GNBLANGUE
  Endif
End

###################################################################
# Définition des formules de dimensionnement des tables relatives au ciblage
###################################################################
$CREFORDIMTAB
  Call CRE_AFO ("FIEDIC", "200")
  Call CRE_AFO ("FIEDICFIE", "4000")
  Call CRE_AFO ("TGRLIS", "200")
  Call CRE_AFO ("TGRLISFIE", "3000")
  Call CRE_AFO ("TGRLISLNK", "1500")
  Call CRE_AFO ("TGRSSP", "1000")
  Call CRE_AFO ("SELSSP", "250")
  Call CRE_AFO ("SELSSPCPN", "3000")
  Call CRE_AFO ("MKGQUR", "2000")
  Call CRE_AFO ("MKGQURPPL", "5000")
  Call CRE_AFO ("MKGOPG", "1000")
  Call CRE_AFO ("QURCRI", "8000")
  Call CRE_AFO ("QURCRIVAL", "10000")
  Call CRE_AFO ("QUREXTRACT", "10000")
  Call CRE_AFO ("QURTMP", "100000")
Return

###################################################################
Subprog CRE_AFO (SZCODFIC, SZFORDIM)
Value Char SZCODFIC
Value Char SZFORDIM

  Read [AFO]AFO0=SZCODFIC
  If fstat Then
    Trbegin [AFO]
    [F:AFO]CODFIC = SZCODFIC
    [F:AFO]FORDIM = SZFORDIM
    [F:AFO]UPDDAT = [00/00/00]
    [F:AFO]UPDUSR = ""
    [F:AFO]CREDAT = date$
    [F:AFO]CREUSR = GUSER
    [F:AFO]CRETIM = 53374
    [F:AFO]UPDTIM = 53374
    Write [AFO]
    If fstat Then
      Rollback
    Else
      Commit
    Endif
  Endif
End

###################################################################
Subprog UPDATE_FDF (SZCRITAB, SZSELCRIFIE, PCAS, PNUM, PCHAP, SZSELCRIAXX, ISELCRIFLG, ISELCRISRT, IPBL)
Value Char SZCRITAB
Value Char SZSELCRIFIE
Value Integer PCAS          # FGR 10/07/2009 : X3SUIVI56465
Value Integer PNUM          # FGR 10/07/2009 : X3SUIVI56465
Value Integer PCHAP         # FGR 10/07/2009 : X3SUIVI56465
Value Char SZSELCRIAXX
Value Integer ISELCRIFLG
Value Integer ISELCRISRT
Variable Integer IPBL

Local Char SZTEXTE(GLONDCO)(GNBLANGUE,2) # FGR 10/07/2009 : X3SUIVI56465
Local Integer NI                         # FGR 10/07/2009 : X3SUIVI56465

  # FGR 10/07/2009 : X3SUIVI56465
  If IPBL = 0 Then
    Read [FDF]FDF0=SZCRITAB;SZSELCRIFIE
    If !fstat Then
      [F:FDF]SELCRIFLG = ISELCRIFLG
      [F:FDF]SELCRISRT = ISELCRISRT
      Rewrite [FDF]
      If fstat Then
        Call ECR_TRACE(mess(504,183,1) - SZCRITAB + "." + SZSELCRIFIE,1) From GESECRAN
        IPBL = 1
        End
      Endif
      If PCAS <> -1 Then
        Call TEXTELAN(PCAS, PNUM, PCHAP, SZTEXTE) # FGR 10/07/2009 : X3SUIVI56465
        If SZSELCRIAXX <> "" Then
          While SZTEXTE(NI,0) <> "" and NI < dim(SZTEXTE)
            SZTEXTE(NI,1) = SZTEXTE(NI,1) - ":" - SZSELCRIAXX
            NI += 1
          Wend
        Endif
        #If SZSELCRIAXX <> "" Then
        #  Call MAJTEXTRA(SZSELCRIAXX, "FIEDICFIE", "SELCRIAXX", [F:FDF]CRITAB, [F:FDF]SELCRIFIE + "~" + [F:FDF]CAT) From ATEXTRA
        #Endif
        Call MAJTEXTRALAN(SZTEXTE, "FIEDICFIE", "SELCRIAXX", [F:FDF]CRITAB, [F:FDF]SELCRIFIE + "~" + [F:FDF]CAT) # FGR 10/07/2009 : X3SUIVI56465
      Endif
    Endif
  Endif
End

###################################################################
Subprog WRITE_DVA (SZOBC, SZPARAM, SZALHX0, IPBL)
Value Char SZOBC
Value Char SZPARAM
Value Char SZALHX0
Variable Integer IPBL

  If IPBL = 0 Then
    [F:DVA]OBC = SZOBC
    [F:DVA]PARAM = SZPARAM
    [F:DVA]ALHX(0) = SZALHX0
    Write [DVA]
    If fstat Then
      IPBL = 1
      Call ECR_TRACE(mess(479,183,1) - SZOBC - '.' - SZPARAM - '.' - SZALHX0,1) From GESECRAN
      Call ECR_TIME(mess(478,183,1)) From DOSSUB
      End
    Endif
  Endif
End

###################################################################
Subprog DELETE_TGL_TLL (SZTGRTAB, IPBL)
Value Char SZTGRTAB
Variable Integer IPBL

  If IPBL = 0 Then
    Trbegin [TGL], [TLL]
    Delete [TGL] Where [F:TGL]TGRTAB = SZTGRTAB
    If fstat Then
      Rollback
      IPBL = 1
      Call ECR_TRACE(mess(482,183,1) - "[TGL]" + SZTGRTAB,1) From GESECRAN
      Call ECR_TIME(mess(483,183,1)) From DOSSUB
      End
    Endif
    #On nettoie le répertoire des tables liées aux cibles
    Delete [TLL] Where [F:TLL]TGRTAB = SZTGRTAB
    If fstat Then
      Rollback
      IPBL = 1
      Call ECR_TRACE(mess(482,183,1) - "[TLL]" + SZTGRTAB,1) From GESECRAN
      Call ECR_TIME(mess(483,183,1)) From DOSSUB
      End
    Endif
    Commit
  Endif
End

###################################################################
Subprog WRITE_TLF (SZTGRTAB, SZTGRSSPNUM, SZTGRTABLNK, SZTGRFIE, ITGRFIEORD, ITGRFIESTD, IPBL)
Value Char SZTGRTAB
Value Char SZTGRSSPNUM
Value Char SZTGRTABLNK
Value Char SZTGRFIE
Value Integer ITGRFIEORD
Value Integer ITGRFIESTD
Variable Integer IPBL

  If IPBL = 0 Then
    #Champs à afficher
    [F:TLF]TGRTAB = SZTGRTAB
    [F:TLF]TGRSSPNUM = SZTGRSSPNUM
    [F:TLF]TGRTABLNK = SZTGRTABLNK
    [F:TLF]TGRFIE = SZTGRFIE
    [F:TLF]TGRFIEORD = ITGRFIEORD
    [F:TLF]TGRFIESTD = ITGRFIESTD
    Write [TLF]
    If fstat Then
      IPBL = 1
      Call ECR_TRACE(mess(487,183,1) - SZTGRTAB - '.' - SZTGRSSPNUM - '.' - SZTGRTABLNK - '.' - SZTGRFIE,1) From GESECRAN
      Call ECR_TIME(mess(490,183,1)) From DOSSUB
      End
    Endif
  Endif
End

###################################################################
Subprog WRITE_TGP (SZTGRSSPNUM, SZTGR, SZFIESRT, SZTABSRT, IFIESRTTYP, IPBL)
Value Char SZTGRSSPNUM
Value Char SZTGR
Value Char SZFIESRT
Value Char SZTABSRT
Value Integer IFIESRTTYP
Variable Integer IPBL

Local Char SZTEXTE(GLONDCO)(GNBLANGUE,2)    # FGR 10/07/2009 : X3SUIVI56465
Local Integer NI                            # FGR 10/07/2009 : X3SUIVI56465

  Call DELETE_TGP_TLF (SZTGRSSPNUM, IPBL)
  If IPBL = 0 Then
    [F:TGP]TGRSSPNUM = SZTGRSSPNUM
    [F:TGP]TGR = SZTGR
    [F:TGP]FIESRT = SZFIESRT
    [F:TGP]TABSRT = SZTABSRT
    [F:TGP]FIESRTTYP = IFIESRTTYP
    [F:TGP]SPTSTD = 1
    [F:TGP]SPTDEF = 1
    [F:TGP]CREUSR = GUSER
    [F:TGP]CREDAT = date$
    Write [TGP]
    If fstat Then
      IPBL = 1
      Call ECR_TRACE(mess(487,183,1),1) From GESECRAN
      Call ECR_TIME(mess(490,183,1)) From DOSSUB
      End
    Else
      Call TEXTELAN(1, 31, 183, SZTEXTE)      #Présentation par défaut de la cible # FGR 10/07/2009 : X3SUIVI56465
      NI = 0
      While SZTEXTE(NI,0) <> "" and NI < dim(SZTEXTE)
        SZTEXTE(NI,1) = SZTEXTE(NI,1) - ":" - [F:TGP]TGR
        NI += 1
      Wend
      #Call MAJTEXTRA(mess(31,183,1) - ":" - [F:TGP]TGR, "TGRSSP", "TGRAXX", [F:TGP]TGRSSPNUM, "") From ATEXTRA
      Call MAJTEXTRALAN(SZTEXTE, "TGRSSP", "TGRAXX", [F:TGP]TGRSSPNUM, "") # FGR 10/07/2009 : X3SUIVI56465
      If GOK <= 0 Then
        IPBL = 1
        Call ECR_TRACE(mess(487,183,1),1) From GESECRAN
        Call ECR_TIME(mess(490,183,1)) From DOSSUB
        End
      Endif
    Endif
  Endif
End

###################################################################
Subprog DELETE_TGP_TLF (SZTGRSSPNUM, IPBL)
Value Char SZTGRSSPNUM
Variable Integer IPBL

  If IPBL = 0 Then
    Delete [TGP] Where [F:TGP]TGRSSPNUM = SZTGRSSPNUM
    If fstat Then
      IPBL = 1
      Call ECR_TRACE(mess(486,183,1) - "[TGP]" - SZTGRSSPNUM,1) From GESECRAN
      Call ECR_TIME(mess(490,183,1)) From DOSSUB
      End
    Endif
    #On nettoie le répertoire des supports de présentation
    Delete [TLF] Where [F:TLF]TGRSSPNUM = SZTGRSSPNUM
    If fstat Then
      IPBL = 1
      Call ECR_TRACE(mess(486,183,1) - "[TLF]" - SZTGRSSPNUM,1) From GESECRAN
      Call ECR_TIME(mess(490,183,1)) From DOSSUB
      End
    Endif
  Endif
End

###################################################################
Subprog WRITE_FID (SZTABCODE, SZCRITABNAM, SZCAT, IPBL)
Value Char SZTABCODE
Value Char SZCRITABNAM()(,) # FGR 10/07/2009 : X3SUIVI56465
Value Char SZCAT
Variable Integer IPBL

  If IPBL = 0 Then
    Call DELETE_FID_FDF (SZTABCODE, SZCAT, IPBL)
    If IPBL = 0 Then
      [F:FID]CRITAB = SZTABCODE
      [F:FID]STD = 1
      [F:FID]CAT = SZCAT
      Write [FID]
      If fstat Then
        IPBL = 1
        Call ECR_TRACE(mess(488,183,1) - SZTABCODE - '.' - SZCRITABNAM,1) From GESECRAN
        Call ECR_TIME(mess(491,183,1)) From DOSSUB
        End
      Endif
      #Call MAJTEXTRA(SZCRITABNAM, "FIEDIC", "CRITABAXX", [F:FID]CRITAB, [F:FID]CAT) From ATEXTRA
      Call MAJTEXTRALAN(SZCRITABNAM, "FIEDIC", "CRITABAXX", [F:FID]CRITAB, [F:FID]CAT) # FGR 10/07/2009 : X3SUIVI56465
      Call WRITE_FDF (SZTABCODE, SZCAT, IPBL)
    Else
      Call ECR_TIME(mess(491,183,1)) From DOSSUB
      End
    Endif
  Endif
End

###################################################################
# Suppression des critères de ciblages standard recréés automatiquement
###################################################################
Subprog DELETE_FID_FDF (SZTABCODE, SZCAT, IPBL)
Value Char SZTABCODE
Value Char SZCAT
Variable Integer IPBL

  If IPBL = 0 Then
    #On nettoie le répertoire des critères de ciblage
    Delete [FID] Where [F:FID]CRITAB = SZTABCODE and [F:FID]CAT = SZCAT
    If fstat Then
      IPBL = 1
      Call ECR_TRACE(mess(488,183,1) - "[FID]" - SZTABCODE - "." - SZCAT,1) From GESECRAN
      End
    Endif
    #On nettoie le répertoire des critères de ciblage
    Delete [FDF] Where [F:FDF]CRITAB = SZTABCODE and [F:FDF]CAT = SZCAT
    If fstat Then
      IPBL = 1
      Call ECR_TRACE(mess(488,183,1) - "[FDF]" - SZTABCODE - "." - SZCAT,1) From GESECRAN
      End
    Endif
  Endif
End

######################################################################
# Génère une proposition par défaut de critère de ciblage pour une table donnée
######################################################################
Subprog WRITE_FDF (SZTABCODE, SZCAT, IPBL)
Value Char SZTABCODE
Value Char SZCAT
Variable Integer IPBL

Local Integer ITERATOR
Local Char SZTEXTE(GLONDCO)(GNBLANGUE,2)    # FGR 10/07/2009 : X3SUIVI56465

  If IPBL = 0 Then
    ITERATOR = 1000
    Filter [ATZ] Where [F:ATZ]CODFIC = SZTABCODE
    For [ATZ]CODZONE
      [F:FDF]CRITAB = [F:ATZ]CODFIC
      [F:FDF]SELCRIFIE = [F:ATZ]CODZONE
      [F:FDF]SELCRIFLG = 2
      [F:FDF]SELCRISRT = ITERATOR
      [F:FDF]STD = 1
      [F:FDF]CAT = SZCAT
      Write [FDF]
      If fstat Then
        IPBL = 1
        Call ECR_TRACE(mess(499,183,1) - SZTABCODE - "-" - [F:ATZ]CODZONE,1) From GESECRAN
        Break
      Endif
      #Call TEXTE([F:ATZ]NOLONG, SZTEXTE) From OBJDIV
      Call TEXTELAN(2, [F:ATZ]NOLONG, -1, SZTEXTE)      # FGR 10/07/2009 : X3SUIVI56465
      #Call MAJTEXTRA(SZTEXTE, "FIEDICFIE", "SELCRIAXX", [F:FDF]CRITAB, [F:FDF]SELCRIFIE + "~" + [F:FDF]CAT) From ATEXTRA
      Call MAJTEXTRALAN(SZTEXTE, "FIEDICFIE", "SELCRIAXX", [F:FDF]CRITAB, [F:FDF]SELCRIFIE + "~" + [F:FDF]CAT) # FGR 10/07/2009 : X3SUIVI56465
      ITERATOR += 1
    Next
    Filter [ATZ]
  Endif
End

