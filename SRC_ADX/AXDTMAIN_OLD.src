#**
#* Lock a file (old method - 02/03/2009)
#* 
#* @param APPL
#* @param DIR
#* @param NAME
#*!
Funprog LOCKFILE(APPL, DIR, NAME)
Value Char APPL()
Value Char DIR()
Value Char NAME()

Local Clbfile VERROU(1)
Local Char    FICLCK(GDIMFIC)

FICLCK = filpath(DIR, NAME, "LCKsrc", APPL)
If filinfo(FICLCK,0)>0
 VERROU = func GETMESSLOCK(FICLCK)
Else
 Openo FICLCK Using [LOK]
 Iomode adxifs ""       Using [LOK]
 Iomode adxirs chr$(10) Using [LOK]
 Iomode adxium GASCII   Using [LOK]
 Wrseq adxmac(-2) Using [LOK]
 Wrseq adxusr Using [LOK]
 Wrseq format$(GFMD,date$)-"-"-time$ Using [LOK]
 Openo Using [LOK]
 VERROU = "1"
Endif
End VERROU

#**
#* Lock a file (new method - 02/03/2009)
#* 
#* @param APPL
#* @param DIR
#* @param NAME
#* 
#* @since 02/03/2009
#*!
Funprog LOCK_FILE(APPL, DIR, NAME)
Value Char APPL()
Value Char DIR()
Value Char NAME()

Local Char NEWLINE_SEPARATOR(4) : NEWLINE_SEPARATOR = "#NL#"
Local Char VALUE_SEPARATOR(4)   : VALUE_SEPARATOR   = "#SP#"

Local Clbfile VERROU(1)
Local Char    FICLCK(GDIMFIC)
Local Char    LOCKDATE
Local Char    LOCKRESULT

FICLCK = filpath(DIR, NAME, "LCKsrc", APPL)
If filinfo(FICLCK,0)>0
 LOCKRESULT = "0"
 LOCKDATE = func GETLOCKDATETIME(FICLCK)
Else
 LOCKDATE = format$(GFMD,date$)-"-"-time$
 Openo FICLCK Using [LOK]
 Iomode adxifs ""       Using [LOK]
 Iomode adxirs chr$(10) Using [LOK]
 Iomode adxium GASCII   Using [LOK]
 Wrseq adxmac(-2) Using [LOK]
 Wrseq adxusr Using [LOK]
 Wrseq LOCKDATE Using [LOK]
 Openo Using [LOK]
 LOCKRESULT = "1"
Endif
VERROU = LOCKRESULT + NEWLINE_SEPARATOR + NAME + VALUE_SEPARATOR + adxmac(-2) + VALUE_SEPARATOR + adxusr + VALUE_SEPARATOR + LOCKDATE 
# VERROU = LOCKRESULT + VALUE_SEPARATOR + NAME + VALUE_SEPARATOR + adxmac(-2) + VALUE_SEPARATOR + adxusr + VALUE_SEPARATOR + LOCKDATE 
If LOCKRESULT <> "1"
 VERROU += NEWLINE_SEPARATOR + func GETMESSLOCK(FICLCK)
Endif
End VERROU



#**
#* Unlock a file
#* 
#* @param APPL
#* @param DIR
#* @param NAME
#*!
Subprog UNLOCKFILE(APPL, DIR, NAME)
Value Char APPL()
Value Char DIR()
Value Char NAME()

Local Char    FICLCK(GDIMFIC)
Local Integer STAT

FICLCK = filpath(DIR, NAME, "LCKsrc", APPL)

If FICLCK<>"" & filinfo(FICLCK, 0)>0
 Call EFFACE(FICLCK, STAT) From ORDSYS
Endif
End

#**
#* Gets lock message
#* 
#* @param LOCKEDFILE
#*!
Funprog GETMESSLOCK(LOCKEDFILE)
Value Char    LOCKEDFILE()

Local Char LCKERR(250)(1..3)
Local Clbfile MESSLOCK(1)

Openi LOCKEDFILE Using [LOK]

Iomode adxifs ""       Using [LOK]
Iomode adxirs chr$(10) Using [LOK]
Iomode adxium GASCII   Using [LOK]

Rdseq LCKERR(1) Using [LOK]
Rdseq LCKERR(2) Using [LOK]
Rdseq LCKERR(3) Using [LOK]
Openi Using [LOK]
#Call ERREUR(mess(200,124,1)+"\|"+LCKERR(1)+"|\|"+LCKERR(2)+"|\|"+LCKERR(3)) From GESECRAN
MESSLOCK = mess(200,124,1)+" "+LCKERR(1)+" ("+LCKERR(2)+") - "+LCKERR(3)
End MESSLOCK

#**
#* Gets lock date time
#* @param LOCKEDFILE
#*!
Funprog GETLOCKDATETIME(LOCKEDFILE)
Value Char    LOCKEDFILE()

Local Char LCKERR(250)(1..3)
Local Clbfile MESSLOCK(1)

Openi LOCKEDFILE Using [LOK]

Iomode adxifs ""       Using [LOK]
Iomode adxirs chr$(10) Using [LOK]
Iomode adxium GASCII   Using [LOK]

Rdseq LCKERR(1) Using [LOK]
Rdseq LCKERR(2) Using [LOK]
Rdseq LCKERR(3) Using [LOK]
Openi Using [LOK]
MESSLOCK = LCKERR(3)
End MESSLOCK


#**
#* Compiles a file
#* 
#* @param PROG
#* @param DOSSIER
#*!
Funprog COMPILTRT(PROG, DOSSIER)
Value    Char    PROG()
Value    Char    DOSSIER()

Local Integer STAT , SAVSEEK
Local Char    FICTRA(GDIMFIC)
Local Char    ORDSYS(250)(1..2)
Local Char    MESSAGE(80)(1..5) , MESSA(80)
Local Char    SAVIFS(20), SAVIRS(20)
Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC)

Local Clbfile MESSCOMPILE(1)

Local Char VALUE_SEPARATOR(4)   : VALUE_SEPARATOR   = "#SP#"

Call MACHINE(DOSSIER, MACHINE, APPLI) From ORDSYS

SAVIFS = adxifs
SAVIRS = adxirs
ORDSYS(1) = "valtrt"-APPLI-PROG
MESSA = mess(20,123,1) : # Erreur en validation du traitement

FICTRA = filpath("tmp", PROG, "tra", APPLI, "", MACHINE)
Openo FICTRA, 0
Openo

ORDSYS(2)  = FICTRA
Call SYSTEME(MACHINE, ORDSYS, "", STAT) From ORDSYS
#If STAT
# Call ECR_TRACE(mess(6,123,1)-NUM$(STAT)-"SYSTEME"+"\|"+ORDSYS(1),1) From GESECRAN : # Erreur
#Endif

adxifs = ""
adxirs = chr$(10)
Openi FICTRA
Raz MESSAGE
Rdseq MESSAGE(1)
Rdseq MESSAGE(2)
Rdseq MESSAGE(3)
Rdseq MESSAGE(4)
Rdseq MESSAGE(5)
Openi

If MESSAGE(1)<>""
# Call ECR_TRACE(MESSA-PROG+"\|"+MESSAGE(1)+"|\|"+MESSAGE(2)+"|\|"+MESSAGE(3)+"|\|"+MESSAGE(4),1)
#& From GESECRAN
 MESSCOMPILE = MESSA-PROG+VALUE_SEPARATOR+MESSAGE(1)+VALUE_SEPARATOR+MESSAGE(2)+VALUE_SEPARATOR+MESSAGE(3)+VALUE_SEPARATOR+MESSAGE(4)
Else
 MESSCOMPILE = "1"
 Call EFFACE(FICTRA, STAT) From ORDSYS
# If STAT
#  Call ECR_TRACE(mess(6,123,1)-NUM$(STAT)-"EFFACE"+"\|"+FICTRA,1) From GESECRAN : # Erreur
# Endif
Endif

adxifs = SAVIFS
adxirs = SAVIRS

End MESSCOMPILE


#**
#* Get local menu label
#* 
#* @param CHAPTER
#* @param NUMBER
#* @param FILENUMBER
#*!
Funprog GETLOCALMENU(CHAPTER, NUMBER, FILENUMBER)
Value    Char    CHAPTER()
Value    Char    NUMBER()
Value    Char    FILENUMBER()

Local Integer NCHAPTER
Local Integer NNUMBER
Local Integer NFILENUMBER

NCHAPTER = val(CHAPTER)
NNUMBER = val(NUMBER)
NFILENUMBER = val(FILENUMBER)

Local Char    MESSAGE(250)
MESSAGE = mess(NNUMBER, NCHAPTER, NFILENUMBER)
End MESSAGE


#**
#* Format source header 
#*!
Funprog GETFILEHEADER()
Local Char FILEHEADER(80)
FILEHEADER = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
End FILEHEADER


#**
#* Gets source from server (as a clob)
#*  
#* @param X3FOLDER
#* @param SRCCODE
#*!
Funprog GETFILE(X3FOLDER, SRCCODE)
Value Char    X3FOLDER()
Value Char    SRCCODE()

Local Char    FILEHEADER(80)
FILEHEADER = func GETFILEHEADER()

Local Char SRCNAME(GDIMFIC)
SRCNAME = filpath("TRT", SRCCODE, "src", X3FOLDER)

Local Clbfile FILECONTENT(10)
Raz FILECONTENT

Local Integer DIME, I, J, K, NB, R
If filinfo(SRCNAME, 0)<0 : End FILECONTENT : Endif

Local Char    CHAINE(250)
DIME = 10000
Local Char    LINE(255)(1..DIME)

Openi SRCNAME Using [TRT]
Iomode adxifs "" Using [TRT]
Iomode adxirs chr$(10) Using [TRT]
Iomode adxium GUTF8 Using [TRT]
# Iomode adxium GASCII Using [TRT]
Raz LINE, NB
Rdseq CHAINE Using [TRT]
If !fstat & left$(CHAINE,5)<>left$(FILEHEADER,5)
 NB += 1
 LINE(NB) = CHAINE
Endif
Iomode adxirs "" Using [TRT]
Rdseq CHAINE Using [TRT]
While CHAINE<>""
 While CHAINE<>""
  If NB>=DIME
#   Call ERREUR("|"+SRCNAME-"|\"-mess(175,115,1)) From GESECRAN : # Taille du fichier trop grande
   Break 2
  Else
   K = instr(1,CHAINE,chr$(10))
   If K
    NB += 1
    LINE(NB) = left$(CHAINE,K)
    CHAINE = right$(CHAINE,K+1)
   Else
    NB += 1
    LINE(NB) = CHAINE
    CHAINE = ""
   Endif
  Endif
 Wend
 Rdseq CHAINE Using [TRT]
Wend
Openi Using [TRT]
fstat=0
# Le fichier .src contient des LF en fin de ligne
# La saisie du clob par le client x3 rajoute des CR+LF en fin de ligne
# A la lecture du .src , on rajoute des CR+LF en bout de ligne pour éviter une après_modif inutile
R = 1
For I=1 To NB
 K = len(LINE(I))
 If right$(LINE(I),K)=chr$(10)
#  If R
#   LINE(I) = format$("KTv1:"+num$(type(LINE))+"X",left$(LINE(I),K-1))+chr$(13)+chr$(10)
#  Else
   LINE(I) = left$(LINE(I),K-1)+chr$(13)+chr$(10)
#  Endif
  R = 1
 Else
  R = 0
 Endif
Next I
Setlob FILECONTENT With LINE

End FILECONTENT

#**
#* Puts source to server (receive as a clob)
#*  
#* @param X3FOLDER
#* @param SRCCODE
#* @param FILECONTENT
#*!
Funprog PUTFILE(X3FOLDER, SRCCODE, FILECONTENT)
Value Char    X3FOLDER()
Value Char    SRCCODE()
Value Clbfile FILECONTENT()

Local Char OK
Local Integer DIME , I , K , NB
DIME = 10000
Local Char    LIGNE(255)(1..DIME)

Local Char    FILEHEADER(80)
FILEHEADER = func GETFILEHEADER()

Local Char SRCNAME(GDIMFIC)
SRCNAME = filpath("TRT", SRCCODE, "src", X3FOLDER)

Raz LIGNE
Setlob LIGNE With FILECONTENT
If LIGNE=""
 # Delete empty file
 Call DELETEFILE(SRCCODE, X3FOLDER, "1", "")
 OK = "0"
 End
Endif

OK = "1"
NB = DIME
While NB & LIGNE(NB)=""
 NB -= 1
Wend
# Deletion of CR from clob before writing file
For I=1 To NB
 LIGNE(I) = ctrans(LIGNE(I),chr$(13),"")
Next I
Openo SRCNAME, 0 Using [TRT]
Iomode adxifs ""       Using [TRT]
Iomode adxirs chr$(10) Using [TRT]
Iomode adxium GUTF8 Using [TRT]
# Iomode adxium GASCII Using [TRT]
#Wrseq FILEHEADER-[M]DES Using [TRT]
Wrseq FILEHEADER       Using [TRT]
Iomode adxirs ""       Using [TRT]
For I=1 To NB
 Wrseq LIGNE(I) Using [TRT]
Next I
Openo Using [TRT]

End OK

#**
#* Delete a file from server
#* 
#* @param SRCCODE trt code (eg SUBITM)
#* @param X3FOLDER folder (eg SUPERV)
#* @param DELETEADX "1" for ADX deletion 
#* @param CONDITION deletion condition (eg GADONIX<>2)
#*!
Subprog DELETEFILE(SRCCODE, X3FOLDER, DELETEADX, CONDITION)
  Value Char    SRCCODE()
  Value Char    X3FOLDER()
  Value Char    DELETEADX()
  Value Char    CONDITION()
 
  Local Integer STAT
  Local Char NOMSRC(GDIMFIC)
  Local Integer NEED_TO_DELETE

  If CONDITION = ""
    NEED_TO_DELETE = 1
  Else
    NEED_TO_DELETE = evalue(CONDITION)
  Endif
 
  If NEED_TO_DELETE = 1
    NOMSRC = filpath("TRT", SRCCODE, "src", X3FOLDER)
    Call EFFACE(NOMSRC, STAT) From ORDSYS
    If DELETEADX = "1"
      Call EFFACE_ADX("", X3FOLDER, SRCCODE, STAT) From ORDSYS
    Endif
  Endif
End

#**
#* Gets the list of programs on server (in a folder)
#* Exclude W* programs (generated programs)
#*  
#* @param DOSSIER
#* @param START
#* @param NBMAX
#*!
Funprog GETFILESLIST(DOSSIER, START, NBMAX)

Value Char    DOSSIER()
Value Char    START()
Value Char    NBMAX()

Local Char    FILTRE(250)
Local Clbfile FILES(10)

FILTRE = 'left$(TRT,1)<>"W"'
FILES = func GETFILTEREDFILESLIST(DOSSIER, START, FILTRE, NBMAX)

End FILES


#**
#* Gets the filtered list of programs on server (in a folder) 
#* @param DOSSIER
#* @param START
#* @param FILTERS
#* @param NBMAX
#*!
Funprog GETFILTEREDFILESLIST(DOSSIER, START, FILTERS, NBMAX)
Value Char    DOSSIER()
Value Char    START()
Value Char    FILTERS()
Value Char    NBMAX()

Local Char    FILTRE(250), REPERT(GDIMFIC), FILRAP(250)
Local Char    MACHINE(250), APPLI(GLONADS), ORDSYS(250)
Local Char    CODTRT(GLONADC), DESIG(GLONDES), CODUSR(GLONDES), TIMMOD(10)
# Local Char    WTRT(30)(1..GNBSEL), WDES(GLONDES)(1..GNBSEL)
# Local Char    WUSR(GLONDES)(1..GNBSEL), WTIM(10)(1..GNBSEL)
# Local Libelle WMDL(1..GNBSEL)
# Local Date    WDAT(1..GNBSEL)
Local Char    TYP(3)
Local Integer NB_TRT, K
Local Char    REVERSE(10)
Local Date    DATMOD
Local Libelle MODULE
Local Integer NB_MAX

Local Clbfile FILES(10)

Local Char VALUE_SEPARATOR(4)   : VALUE_SEPARATOR   = "#SP#"

TYP    = "src"
If NBMAX = "-1" : NB_MAX = GNBSEL : Else : NB_MAX = val(NBMAX) : Endif

If DOSSIER="" : DOSSIER = nomap : Endif
Call MACHINE(DOSSIER, MACHINE, APPLI) From ORDSYS
REPERT = filpath("TRT", "", "", APPLI, "", MACHINE)
FILTRE = 'TRT>="'+START+'"'
If DOSSIER=nomap
 Local File ADICTRT [ADC]
Else
 Local File =DOSSIER+".ADICTRT" [ADC]
Endif
FILRAP = '1=1'

# Chargement
If FILTRE<>"" : FILTRE += "&" : Endif
FILTRE += 'TRT<>""'

# Apply filter
If FILTERS<>"" 
  If FILTRE<>"" : FILTRE += "&" : Endif
  FILTRE += FILTERS
Endif

If clalev([F:TRT_])>0 : Close Local File [TRT_] : Endif
Case TYP
 When "src"
  ORDSYS = MACHINE+"@"+'lsadx -a'-toupper(APPLI)-REVERSE-REPERT
  FILTRE += '& pat(TRT,"*.src")'
 When Default
  ORDSYS = MACHINE+"@"+'archive -d '+DOSSIER-REVERSE-' -t "adx" -l "*" -v'
Endcase
Local File (TRT(30)) From System ORDSYS As [TRT_]

NB_TRT =0
For [TRT_] Where evalue(FILTRE)
 NB_TRT += 1
 K = instr(1,[F:TRT_]TRT,".src")
 If K
  CODTRT = left$([F:TRT_]TRT,K-1)
 Else
  CODTRT = [F:TRT_]TRT
 Endif
# Call INFOADX(CODTRT,APPLI,MACHINE,CODUSR,GBIDC1,GBIDD1,DATMOD,TIMMOD,K) From EDITRTWEB
# Read [ADC]ADC0 = CODTRT
# If !fstat
#  DESIG = [F:ADC]DES
#  MODULE = [F:ADC]MODULE
# Else
#  Case TYP
#   When "src"
#    ER = 0
#    Onerrgo KEEP_ERROR
#    DESIG = filcom("TRT",CODTRT,"src",APPLI)
#    Onerrgo
#    If ER : DESIG = "" : Endif
#   When "adx"
#    Call INFO_ADX("","",CODTRT,20,DESIG) From ORDSYS
#  Endcase
#  MODULE = 99
# Endif
 If NB_TRT>NB_MAX
   Break
 Endif
#  WTRT(NB_TRT) = CODTRT
#  WDES(NB_TRT) = DESIG
#  WUSR(NB_TRT) = CODUSR
#  WDAT(NB_TRT) = DATMOD
#  WTIM(NB_TRT) = TIMMOD
#  WMDL(NB_TRT) = MODULE
 FILES+=CODTRT+VALUE_SEPARATOR
Next TRT_
# If FILRAP <> "1=1"
# Call FERME_BOITE From GESECRAN
# Endif
# For J=+1 To GNBSEL
#  WTRT(J) = chr$(255)
# Next J
# adxmxl = NB_TRT
End FILES


$KEEP_ERROR
ER = errn
Resume

#**
#* Get locked files list
#*!
Funprog GET_LOCKED_FILES
Local Char    SAVIFS(5) , SAVIRS(5)
Local Integer SAVIUM
Local Char    APPLI(GLONADS) , EXT(10)
Local Char    FICHIER(250)
Local Integer NBTRT , I
Local Char    TBTRT(GLONADC+2)(1..300)
Local Char    STR(250)(3)

Local Char NEWLINE_SEPARATOR(4) : NEWLINE_SEPARATOR = "#NL#"
Local Char VALUE_SEPARATOR(4)   : VALUE_SEPARATOR   = "#SP#"
Local Clbfile FILES(10)

APPLI = nomap
EXT   = "LCKsrc"

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxifs = ""
adxirs = chr$(10)
adxium = GASCII

# Infbox(adxtct-adxmac(-1)-" | "-adxmac(-2))
Call SYSTEME2(adxmac(0), "lsadx -a"-APPLI-"TRT"-EXT, "", NBTRT, TBTRT) From ORDSYS
For I=1 To min(NBTRT, dim(TBTRT))
 FICHIER = filpath("TRT", TBTRT(I), EXT, APPLI)
 If filinfo(FICHIER, 0)>=0
  Openi FICHIER
  Rdseq STR(0)
  Rdseq STR(1)
  Rdseq STR(2)
  Openi
  # Program / Machine / User / DateTime
  FILES += TBTRT(I) + VALUE_SEPARATOR + STR(0)+ VALUE_SEPARATOR + STR(1) + VALUE_SEPARATOR + STR(2) + NEWLINE_SEPARATOR
 Endif
Next I

adxirs = SAVIRS
adxifs = SAVIFS
adxium = SAVIUM
End FILES

#**
#* Get default help location
#*!
Funprog GET_HELP_PATH()
Local Char RETOUR(200)
Local Integer OK
Call RECHPROP("doc.files.clientwebaccessurl", RETOUR, OK) From INTRUTILA
End RETOUR

#**
#* Get Solution name
#*!
Funprog GET_SOLUTION_NAME()
Local Char SOLUTION(200)
Local Char NOMFIC(200), VALL1(200)

Call NAMEFIC(nomap,"SOL","","",NOMFIC) From INTRUTILA
If filinfo(NOMFIC,7)<0 : Goto ERRLEC : Endif
fstat=0
Openi NOMFIC,0 Using [CST_]
If fstat<>0 : Goto ERRLEC : Endif
Iomode adxifs ""  Using [CST_]
Iomode adxirs chr$(10)  Using [CST_]
Iomode adxium GUTF8  Using [CST_]
fstat=0
While fstat=0
  Rdseq VALL1 Using [CST_]
  If instr(1,VALL1,"<solution")<>0
    I1=instr(1,VALL1,"name")
    I2=instr(I1+6,VALL1,'"')
    If I2-I1-6>0
      SOLUTION=vireblc(mid$(VALL1,I1+6,I2-I1-6),2)
    Endif
  Endif
Wend
End SOLUTION

$ERRLEC:
End ""

#**
#* Launch a program in Eclipse IDE (via http server)
#* 
#* @param NOMFIC
#*!
Funprog LAUNCH_TRT_OLD(NOMFIC)
Value Char NOMFIC()

Local Char RETOUR(250)
Local Char COMMAND(255)

Local Char SERVER(250)
Local Char PORT(250)
Local Char APPFOLDER(250)
Local Char HTTPPORT(250)
Local Char ECLIPSEPATH(250)

SERVER = tolower(GMACADO)
PORT = num$(adxtcp)
APPFOLDER = nomap
HTTPPORT = num$(8086)
ECLIPSEPATH = GAXDTFLD



# Get X3 client local data dir
Local Char X3USERDIR(255)
Getui RETOUR = "" With "X3UserDir"
K = instr(1, RETOUR, "=")
Local Char X3USERDIR(255)
X3USERDIR = right$(RETOUR, K+2)
# Infbox("X3UserDir= " + X3USERDIR)




# Check if X3 http server jar exists on client side

# If not, transfert X3 http server jar on client side


# Launch url (to open program in Eclipse IDE)
COMMAND = "java -jar x3client.jar " + SERVER + ";" + PORT + ";" + APPFOLDER + ";" + HTTPPORT + ";" + NOMFIC + ";" + ECLIPSEPATH
Call EXECLI(COMMAND, RETOUR) From ORDSYS
  
End RETOUR



#**
#* Launch a program in Eclipse IDE (via http server)
#* 
#* @param NOMFIC the source file name (eg : GTRAITE.src)
#* @param READONLY 1 for open readonly, 0 for open read/write
#*!
Subprog LAUNCH_TRT(NOMFIC, READONLY)
Value Char NOMFIC()
Value Integer READONLY
  
Local Integer NB_PARAM
Local Integer I
NB_PARAM=11
I=1
Local Char JAR_NAME(250)    
Local Char JAR_FULLNAME(250)    
Local Char JAR_EXT(10)    
Local Char PARAM_NAME(250)(1..NB_PARAM)
Local Char PARAM_VALUE(250)(1..NB_PARAM)
Local Char RESULT(250)

Onerrgo ERR_LAUNCH

JAR_NAME="ideclient"
JAR_EXT="jar"
JAR_FULLNAME=JAR_NAME + "." + JAR_EXT

# set parameters
PARAM_NAME(I)="folder"
PARAM_VALUE(I)=nomap

I+=1
PARAM_NAME(I)="server"
PARAM_VALUE(I)=tolower(GMACADO)

I+=1
PARAM_NAME(I)="port"
PARAM_VALUE(I)=num$(adxtcp)

I+=1
PARAM_NAME(I)="src"
PARAM_VALUE(I)=NOMFIC

I+=1
PARAM_NAME(I)="readonly"
If READONLY = 1
    PARAM_VALUE(I)="true"
Else
    PARAM_VALUE(I)="false"
Endif

I+=1
PARAM_NAME(I)="trace"
PARAM_VALUE(I)="false"

I+=1
PARAM_NAME(I)="x.lang"
PARAM_VALUE(I)=GLANGUE

I+=1
PARAM_NAME(I)="x.user"
PARAM_VALUE(I)=GUSER

Local Char PWD(50)
If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
Read [AUS]CODUSR = GUSER
If fstat=0
  PWD=[F:AUS]NEWPAS
Else
  PWD="error"
Endif

I+=1
PARAM_NAME(I)="x.pwd"
PARAM_VALUE(I)=PWD

I+=1
PARAM_NAME(I)="x.osuser"
PARAM_VALUE(I)=adxcus

I+=1
PARAM_NAME(I)="x.ospwd"
PARAM_VALUE(I)=adxcpw

# check if jar file is available
Local Char INFOFILE(GDIMFIC)(3)
Local Integer INFORET
INFORET = func GET_X3CLI_FILE_INFO(JAR_NAME, JAR_EXT, INFOFILE)
If (INFORET <> 0)
  # Exécution impossible - Fichier inexistant : ...
  Errbox mess(160,115,1) + " - " + mess(101,100,1) + " :" + chr$(13) 
&   + "'" + INFOFILE(0) + "'" + chr$(13)
  End
Endif

#CALLIU "XDT_ECLI:openSRC" With JAR_NAME, PARAM_NAME, PARAM_VALUE
RESULT = Funciu "XDT_ECLI:openSRC" With (JAR_FULLNAME, PARAM_NAME, PARAM_VALUE)

Onerrgo

End

$ERR_LAUNCH
  # Exécution impossible - Vérifier votre installation :
  # 'SAFE X3 Studio for Eclipse'
  # Cette application n'est pas configurée sur votre poste. Veuillez contacter l'administrateur du système.
Errbox mess(160,115,1) + " - " + mess(2,9119,1) + " :" + chr$(13)
& + "'SAFE X3 Studio for Eclipse'" + chr$(13)
& + mess(22, 9137,1) 
Resume

#**
#* Get file properties (infos displayed in ADICTRT)
#* 
#* @param NOMFIC
#*!
Funprog GET_FILE_PROPERTIES(NOMFIC)
Value Char NOMFIC()

Local Clbfile RETOUR(6)

Local Char WSRC(250)
Local Char WSRCINT(250)
Local Char WINFO(250)(0..6)
Local Char WSEPARATOR(5) : WSEPARATOR = "|"

Local Char NEWLINE_SEPARATOR(4) : NEWLINE_SEPARATOR = "#NL#"
Local Char VALUE_SEPARATOR(4)   : VALUE_SEPARATOR   = "#SP#"

If clalev([F:ADC])=0 : Local File ADICTRT [ADC] : Endif

NAME = ""

Read [F:ADC]ADC0=NOMFIC
If !fstat
#    Call TEXTE([F:ADC]INTITFIC, NAME) From OBJDIV

    If [F:ADC]SRC <> 2
        WSRC = "false"
    Else
        WSRC = "true"
    Endif

    If [F:ADC]SRCINT <> 2
        WSRCINT = "false"
    Else
        WSRCINT = "true"
    Endif

    Call INFOS(NOMFIC, WINFO)

    RETOUR += [F:ADC]CODTRT + VALUE_SEPARATOR 
&    + [F:ADC]DES + VALUE_SEPARATOR
&    + num$([F:ADC]MODULE) + VALUE_SEPARATOR
&    + mess([F:ADC]MODULE, 14, 1) + VALUE_SEPARATOR
&    + [F:ADC]CODACT + VALUE_SEPARATOR
&    + WSRC + VALUE_SEPARATOR
&    + WSRCINT + VALUE_SEPARATOR
&    + [F:ADC]TEXTE + VALUE_SEPARATOR
&    + WINFO(0) + WSEPARATOR + WINFO(1) + WSEPARATOR + WINFO(2) + WSEPARATOR
&    + WINFO(3) + WSEPARATOR + WINFO(4) + WSEPARATOR + WINFO(5) + WSEPARATOR
&    + WINFO(6) + NEWLINE_SEPARATOR

Endif

Close Local File [F:ADC]

End RETOUR

#**
#* 
#* @param FICHIER
#* @param INFOS
#*!
Subprog INFOS(FICHIER, INFOS)
Value Char    FICHIER()
Variable Char INFOS()(0..6)
Raz INFOS
Local Integer L

Local Decimal PROPRIO
Local Decimal TAILLE
Local Date    DATMOD
Local Char    HREMOD
Local Integer OK

Gosub CHARGE_USR From SUBADC

L = 0
Call INFOFIC("TRT", FICHIER, "src", PROPRIO, TAILLE, DATMOD, HREMOD, OK) From SUBADC
If OK<0
 INFOS(L) = mess(55,100,1)-"src"-mess(87,100,1) : # Fichier...inexistant
Else
 INFOS(L) = mess(55,100,1)-"src"-mess(172,126,1)-nomap(OK) : # Fichier...présent dans le dossier
 L += 1
 INFOS(L) = num$(TAILLE)-mess(133,133,1) : # octets
 If NBUSER
  Gosub USER From SUBADC
  INFOS(L) += ","-mess(134,133,1)-IDUSR : # Propriétaire
 Endif
 INFOS(L) += ","-mess(162,124,1)-format$("D:"+GFMDAT4,DATMOD)-HREMOD-"GMT" : # Modifié le
Endif
L += 2
Call INFOADX(FICHIER,PROPRIO,TAILLE,DATMOD,HREMOD,OK) From SUBADC
If OK<0
 INFOS(L) = mess(158,139,1) : # Traitement inexistant dans l'archive
Else
 INFOS(L) = mess(159,139,1)-nomap(OK) : # Traitement existant dans l'archive du dossier
Endif
If TAILLE>=0
 L += 1
 INFOS(L) = num$(TAILLE)-mess(133,133,1) : # octets
 If NBUSER
  Gosub USER From SUBADC
  INFOS(L) += ","-mess(134,133,1)-IDUSR : # Propriétaire
 Endif
 INFOS(L) += ","-mess(162,124,1)-format$("D:"+GFMDAT4,DATMOD)-HREMOD-"GMT" : # Modifié le
Endif
L += 2
Call VERSACH(nomap,INFOS(L)) From SUBADC
INFOS(L) = mess(199,115,1)-"->"-INFOS(L)
End

#**
#* Gets modules 
#*!
Funprog GETMODULES()

Local Clbfile MODULES(9)

Local Char    LABEL(255)
Local Integer INDEX
Local Integer NB
Local Integer CHAPTER : CHAPTER = 14

Local Char NEWLINE_SEPARATOR(4) : NEWLINE_SEPARATOR = "#NL#"
Local Char VALUE_SEPARATOR(4)   : VALUE_SEPARATOR   = "#SP#"

MODULES = ""

 NB = len(mess(0, CHAPTER, 1))
For INDEX=1 To NB
    LABEL = func GETLOCALMENU(num$(CHAPTER), num$(INDEX), "1")
    MODULES += num$(INDEX) + VALUE_SEPARATOR + LABEL + NEWLINE_SEPARATOR
Next INDEX

End MODULES

#**
#* Sets file properties
#* 
#* @deprecated use now SET_FILE_PROPERTIES_V2
#* @param NOMFIC
#* @param RECORD
#*!
Funprog SET_FILE_PROPERTIES(NOMFIC, RECORD)
Value Char NOMFIC()
Value Char RECORD()

Local Char RETOUR(250)
RETOUR = func SET_FILE_PROPERTIES_V2(NOMFIC, RECORD, "")
End RETOUR

#**
#* Set file properties (with additional TEXT parameter) in ADICTRT
#* 
#* @param NOMFIC
#* @param RECORD
#* @param TEXT 
#*!
Funprog SET_FILE_PROPERTIES_V2(NOMFIC, RECORD, TEXT)
Value Char NOMFIC()
Value Char RECORD()
Value Clbfile TEXT()

Local Char RETOUR(250)

Local Char WDES(250)
Local Integer WMODULE
Local Char WCODACT(250)
Local Integer WSRC
Local Integer WSRCINT

Local Integer NBMOT
Local Integer NBMOTMAX : NBMOTMAX = 30
Local Char    TABSPLIT(255)(NBMOTMAX+1) : 

Local Char SYMBOLE

Local Char NEWLINE_SEPARATOR(4) : NEWLINE_SEPARATOR = "#NL#"
Local Char VALUE_SEPARATOR(4)   : VALUE_SEPARATOR   = "#SP#"

If clalev([F:ADC])=0 : Local File ADICTRT [ADC] : Endif

SYMBOLE="ADC"+NOMFIC    
Lock =SYMBOLE With lockwait=0
If [S]fstat = 1     # locked record
    RETOUR = "0" + NEWLINE_SEPARATOR + NOMFIC + " : " + mess(60,100,1)
Else
  Trbegin [ADC]
  Readlock [F:ADC]ADC0 = NOMFIC
  If [S]fstat <> 1 
    
    NBMOT = func SPLIT(RECORD, VALUE_SEPARATOR, TABSPLIT)
    
    WDES = TABSPLIT(0)
    WMODULE = val(TABSPLIT(1))
    WCODACT = TABSPLIT(2)
    WSRC = val(TABSPLIT(3))
    WSRCINT = val(TABSPLIT(4))
    If TEXT = ""
      Setlob TEXT With TABSPLIT(5)
    Endif
    
    [F:ADC]DES = WDES
    [F:ADC]MODULE = WMODULE
    [F:ADC]CODACT = WCODACT
    [F:ADC]SRC = WSRC
    [F:ADC]SRCINT = WSRCINT
    [F:ADC]TEXTE = TEXT
    
    If [S]fstat=0
      Rewrite [F:ADC]
    Else
      [F:ADC]CODTRT = NOMFIC
      Write [F:ADC]
    Endif
    Call SETTEXT("TRT", NOMFIC, TEXT, WDES)
    
    Commit
    Unlock =SYMBOLE
    RETOUR = "1"
  Else      # locked record
    Rollback
    RETOUR = "0" + NEWLINE_SEPARATOR + NOMFIC + " : " + mess(60,100,1)
  Endif
Endif  

Close Local File [F:ADC]

End RETOUR


#fonction déjà présente dans ARECHMEN (voir pour la centraliser quelque-part)
#**
#* Splits a string with a given separator
#* 
#* @param CHAINE
#* @param SEPARATEUR
#* @param RETOUR
#*!
Funprog SPLIT(CHAINE,SEPARATEUR,RETOUR)
Value Char CHAINE()
Value Char SEPARATEUR()
Variable Char RETOUR()()

Local Clbfile CHAINE_LOB(1)
CHAINE_LOB = CHAINE

Local Integer NBMOT
NBMOT = func SPLIT_LOB(CHAINE_LOB, SEPARATEUR, RETOUR)
End NBMOT

#**
#* Splits a clbfile with a given separator
#* 
#* @param CHAINE
#* @param SEPARATEUR
#* @param RETOUR
#*!
Funprog SPLIT_LOB(CHAINE,SEPARATEUR,RETOUR)
Value Clbfile CHAINE()
Value Char SEPARATEUR()
Variable Char RETOUR()() #tableau de chaines de caractères où sont renvoyées les chaines découpées

Local Integer DEBUT , FIN , FINBOUCLE , NBMOT

DEBUT=1 #debut du mot
FIN=1 #fin du mot
FINBOUCLE=0 #sortie de boucle
NBMOT=0 #nombre de mot

#parcourt de la chaine
Repeat
 #recherche d'un mot
 FIN=instr(DEBUT,CHAINE,SEPARATEUR)
 If FIN=0
  FINBOUCLE=1
  FIN=len(CHAINE)+1
 Endif
 RETOUR(NBMOT)=seg$(CHAINE,DEBUT,FIN-1) #ajout du mot au retour
 DEBUT=FIN+len(SEPARATEUR)
 NBMOT+=1  
Until FINBOUCLE | NBMOT=dim(RETOUR)
End NBMOT

#**
#* Return label corresponding to an object code 
#* @param OBJECTCODE
#* @param KEYCODE
#*!
Funprog GET_OBJECT_LABEL(OBJECTCODE, KEYCODE)
Value Char    OBJECTCODE()
Value Char    KEYCODE()

Local Char    LABEL(255)
LABEL = func AFNC.INTCLE(OBJECTCODE, KEYCODE)

End LABEL

#**
#* Evaluates an expression
#* @param EXPR the expression to evaluate
#* @return RETOUR error code (0=OK) + separator + evaluated result
#*!
Funprog EVALUE_EXPR(EXPR)
Value Char EXPR()

Local Char NEWLINE_SEPARATOR(4) : NEWLINE_SEPARATOR = "#NL#"

Local Integer ERRCODE
Local Char    EVAL(255)
Local Char    RETOUR(255)

ERRCODE = parse(EXPR)

Onerrgo EVALUE_EXPR_ERROR

Local Integer OK
Call FLUSHADX(OK) From AFLUSHADX

EVAL = ""
RETOUR = "0"
If ERRCODE = 0
    EVAL = evalue(EXPR)
    If ERRCODE <> 0
        ERRCODE = 0
        EVAL = num$(evalue(EXPR))
    Endif

    If ERRCODE = 0
        RETOUR = "1" + NEWLINE_SEPARATOR + EVAL
    Endif
Endif

End RETOUR


 $EVALUE_EXPR_ERROR
    ERRCODE = errn
 Resume

#**
#* Return <code>0</code> if file exists in the X3CLI directory and 
#* <code>1</code> if it not exists 
#* @param FILE_NAME
#* @param FILE_EXT
#*!
Funprog GET_X3CLI_FILE_INFO(FILE_NAME, FILE_EXT, INFO)
Value Char FILE_NAME
Value Char FILE_EXT
Variable Char INFO()()

Local Char REP(GDIMFIC)
Local Char NAMEREP(GDIMFIC)
Local Integer RETVAL

REP = "X3_ROOT/X3CLI"
# == get filename ==
NAMEREP = filpath(REP, FILE_NAME, FILE_EXT, "X3_PUB", "", adxmac(-1))
INFO(0) = NAMEREP   
# == get size ==
INFO(1) = num$(filinfo(NAMEREP,7))
#Infbox "ret=" + num$(FILE_ERR)
If val(INFO(1)) > 0 
#  Infbox mess(101,100,1) + " : " + NAMEREP
  # == get modification date ==
  INFO(2) = num$(filinfo(NAMEREP,9))
  RETVAL = 0 : #OK
Else
  RETVAL = 1 : #KO
Endif

End RETVAL

#**
#* Return method (Funprog or Subprog) info from ASUBPROG table 
#* @param PROGRAM
#* @param SUBPRO
#*!
Funprog GETMETHODINFO(PROGRAM, SUBPRO)
Value Char    PROGRAM()
Value Char    SUBPRO()

Local Char    NAME(255)
Local Clbfile TEXT(4)
Local Clbfile FIELDS(4)
Local Char SUBPRO_TYPE(255)
Local Integer OK
Local Integer MAXPARAMIDX

Local Char NEWLINE_SEPARATOR(4) : NEWLINE_SEPARATOR = "#NL#"
Local Char VALUE_SEPARATOR(4)   : VALUE_SEPARATOR   = "#SP#"

If clalev([F:ASU])=0 : Local File ASUBPROG  [ASU] : Endif
If clalev([F:ASP])=0 : Local File ASUBPROGD [ASP] : Endif


# Initializations
NAME = ""
FIELDS = ""
TEXT = ""

Read [F:ASU]ASU0=PROGRAM;SUBPRO
If fstat=0
    Call TEXTE([F:ASU]INTIT, NAME) From OBJDIV
    If ([F:ASU]FONCTION = 1)
      SUBPRO_TYPE = "Subprog"
    Else
      SUBPRO_TYPE = "Funprog"
    Endif
    
    # Read text
    TEXT = func GETMETHODINFOTEXT(PROGRAM, SUBPRO)
        
    # Concat method informations
    FIELDS = PROGRAM + "." + SUBPRO + VALUE_SEPARATOR
&          + NAME + VALUE_SEPARATOR
&          + SUBPRO_TYPE + VALUE_SEPARATOR
&          + num$([F:ASU]TYPFCT) + VALUE_SEPARATOR
&          + mess([F:ASU]TYPFCT, 33, 1) + VALUE_SEPARATOR
&          + [F:ASU]CODACT + VALUE_SEPARATOR
&          + num$([F:ASU]MODULE) + VALUE_SEPARATOR
&          + mess([F:ASU]MODULE, 14, 1) + VALUE_SEPARATOR
&          + num$([F:ASU]TYPASU) + VALUE_SEPARATOR
&          + mess([F:ASU]TYPASU, 7849, 1) + VALUE_SEPARATOR
&          + TEXT + VALUE_SEPARATOR

    FIELDS += "" + VALUE_SEPARATOR # deprecated
    FIELDS += "" + VALUE_SEPARATOR # see
    FIELDS += "" + VALUE_SEPARATOR # since
    FIELDS += "" + VALUE_SEPARATOR # return

    # Concat method parameters informations
    MAXPARAMIDX = [F:ASU]NBRPAR - 1
    For [ASP]ASP0 Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
      Call TEXTE([F:ASP]INTITPAR, NAME) From OBJDIV
      FIELDS += [F:ASP]PARAM + VALUE_SEPARATOR
&            + NAME + VALUE_SEPARATOR
&            + num$([F:ASP]TYPPAR) + VALUE_SEPARATOR
&            + mess([F:ASP]TYPPAR, 33, 1) + VALUE_SEPARATOR
&            + num$([F:ASP]DIME) + VALUE_SEPARATOR
&            + num$([F:ASP]ADRVAL) + VALUE_SEPARATOR
&            + mess([F:ASP]ADRVAL, 34, 1) + VALUE_SEPARATOR
    Next ASP

    FIELDS += NEWLINE_SEPARATOR

Endif
Close Local File [F:ASU],[F:ASP]
End FIELDS

#**
#* Return text documentation displayed for subprog (ASUBPROG)
#* @param PROGRAM
#* @param SUBPRO
#*!
Funprog GETMETHODINFOTEXT(PROGRAM, SUBPRO)
Value Char    PROGRAM()
Value Char    SUBPRO()

If clalev([F:ADO])=0 : Local File ADOCUMENT  [ADO] : Endif
If clalev([F:ADH])=0 : Local File ADOCCLB    [ADH] : Endif

Local Integer OK
Local Clbfile TEXT(4) : TEXT = ""
Call LECTURE_DOC("ASU", PROGRAM + "_" + SUBPRO, TEXT, OK) From SUBADO

#Close Local File [F:ADO]
#Close Local File [F:ADH]
        
End TEXT

#**
#* Set text documentation (ASUBPROG)
#* @param PROGRAM
#* @param SUBPRO
#* @param TEXT
#*!
Subprog SETMETHODINFOTEXT(PROGRAM, SUBPRO, TEXT)
Value Char    PROGRAM()
Value Char    SUBPRO()
Value Clbfile TEXT()

Local Char TIT
Call SETTEXT("ASU", PROGRAM + "_" + SUBPRO, TEXT, TIT)
End


#**
#* Set method info (ASUBPROG)
#* @param PROGRAM
#* @param SUBPRO
#* @param RECORD infos (concateneted with separator)
#* @param TEXT explaination
#*!
Funprog SET_METHOD_INFO(PROGRAM, SUBPRO, RECORD, TEXT)
Value Char  PROGRAM()
Value Char  SUBPRO()
Value Clbfile RECORD()
Value Clbfile TEXT()

Local Char RETOUR(250)

Local Integer INTIT_NUMBER
Local Integer I
Local Integer PARAM_IDX, PARAM_NBR
Local Integer NBSPLIT
Local Integer MAXPARAMIDX
Local Integer NBSPLITMAX : NBSPLITMAX = 265
Local Integer WFSTAT
Local Char    TABSPLIT(255)(NBSPLITMAX+1)

Local Char SYMBOLE

Local Char NEWLINE_SEPARATOR(4) : NEWLINE_SEPARATOR = "#NL#"
Local Char VALUE_SEPARATOR(4)   : VALUE_SEPARATOR   = "#SP#"

If clalev([F:ASU])=0 : Local File ASUBPROG  [ASU] : Endif
If clalev([F:ASP])=0 : Local File ASUBPROGD [ASP] : Endif


SYMBOLE="ASU"+SUBPRO+"\"+PROGRAM
Lock =SYMBOLE With lockwait=0
If [S]fstat = 1     # locked record
    RETOUR = "0" + NEWLINE_SEPARATOR + PROGRAM + "." + SUBPRO + " : " + mess(60,100,1)
Else
  Trbegin [ASU]
  Readlock [F:ASU]ASU0 = PROGRAM;SUBPRO
  WFSTAT = [S]fstat
  If WFSTAT <> 1 
    
    Call SETMETHODINFOTEXT(PROGRAM, SUBPRO, TEXT)
        
    NBSPLIT = func SPLIT_LOB(RECORD, VALUE_SEPARATOR, TABSPLIT)
    Call NUMERO(TABSPLIT(0), INTIT_NUMBER) From OBJDIV
    [F:ASU]INTIT = INTIT_NUMBER
    [F:ASU]CODACT = TABSPLIT(1)
    [F:ASU]MODULE = val(TABSPLIT(2))
    [F:ASU]TYPASU = val(TABSPLIT(3))
    [F:ASU]FONCTION = val(TABSPLIT(4))
    [F:ASU]TYPFCT = val(TABSPLIT(5))
        
    # Parameters informations
    PARAM_IDX = 6 # number of occurences
    PARAM_NBR = 5 # number of elements by occurence
    MAXPARAMIDX = ( NBSPLIT - PARAM_IDX ) / PARAM_NBR

    Delete [ASP] Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
    If fstat
     Rollback : RETOUR = "0" + NEWLINE_SEPARATOR + "" + PROGRAM + "." + SUBPRO
     Close Local File [F:ASU],[F:ASP]
     End RETOUR    
    Endif

    [F:ASU]NBRPAR = MAXPARAMIDX
    For I = 0 To MAXPARAMIDX - 1 Step 1 
      [F:ASP]PRG = [F:ASU]PRG 
      [F:ASP]SUBPRG = [F:ASU]SUBPRG
      [F:ASP]PARAM = TABSPLIT(I * PARAM_NBR + PARAM_IDX + 0)
      Call NUMERO(TABSPLIT(I * PARAM_NBR + PARAM_IDX + 1), INTIT_NUMBER) From OBJDIV
      [F:ASP]INTITPAR = INTIT_NUMBER
      [F:ASP]TYPPAR = val(TABSPLIT(I * PARAM_NBR + PARAM_IDX + 2)) 
      [F:ASP]DIME = val(TABSPLIT(I * PARAM_NBR + PARAM_IDX + 3))
      [F:ASP]ADRVAL = val(TABSPLIT(I * PARAM_NBR + PARAM_IDX + 4))
    Next I

    If WFSTAT <> 0
      [F:ASU]PRG = PROGRAM
      [F:ASU]SUBPRG = SUBPRO
      Write [F:ASU]
    Else
      Rewrite [F:ASU]
    Endif
    Commit
    Unlock =SYMBOLE
    RETOUR = "1"
  Else      # locked record
    Rollback
    RETOUR = "0" + NEWLINE_SEPARATOR + "" + PROGRAM + "." + SUBPRO + " : " + mess(60,100,1)
  Endif
Endif  

Close Local File [F:ASU],[F:ASP]

End RETOUR

Subprog SETTEXT(TYP,COD,TEX,TIT)
Value Char TYP , COD
Value Clbfile TEX
Value Char TIT

If clalev([F:ADO])=0 : Local File ADOCUMENT  [ADO] : Endif
If clalev([F:ADH])=0 : Local File ADOCCLB    [ADH] : Endif

Call ECRIRE_DOC(TYP,COD,TEX,TIT) From SUBADO

#Close Local File [F:ADO]
#Close Local File [F:ADH]
        
End

