#**
#* Return table info (code + name)
#* @param CODE the code of the table
#*!
Funprog GETTABLEINFO(CODE)
Value Char    CODE()

Local Char    NAME(255)
Local Char    TABLECODE(255)
Local Clbfile FIELDS(1)

Local Char NEWLINE_SEPARATOR(4) : NEWLINE_SEPARATOR = "#NL#"
Local Char VALUE_SEPARATOR(4)   : VALUE_SEPARATOR   = "#SP#"

If clalev([F:ATB])=0 : Local File ATABLE [ATB] : Endif

NAME = ""
FIELDS = ""
TABLECODE = func GETTABLECODE(CODE)
Read [F:ATB]CODFIC=TABLECODE
If fstat=0
    Call TEXTE([F:ATB]INTITFIC, NAME) From OBJDIV
    FIELDS += TABLECODE + VALUE_SEPARATOR + NAME + NEWLINE_SEPARATOR 
Endif
Close Local File [F:ATB]
End FIELDS

#**
#* Return mask info (code + name) 
#* @param CODE the code fo the mask
#*!
Funprog GETMASKINFO(CODE)
Value Char    CODE()

Local Char    NAME(255)
Local Char    MASKCODE(255)
Local Clbfile FIELDS(1)

Local Char NEWLINE_SEPARATOR(4) : NEWLINE_SEPARATOR = "#NL#"
Local Char VALUE_SEPARATOR(4)   : VALUE_SEPARATOR   = "#SP#"

If clalev([F:MSK])=0 : Local File AMSK [MSK] : Endif

NAME = ""
FIELDS = ""
MASKCODE = func GETMASKCODE(CODE)
Read [F:MSK]CODMSK=MASKCODE
If fstat=0
    Call TEXTE([F:MSK]INTMSK, NAME) From OBJDIV
    FIELDS += MASKCODE + VALUE_SEPARATOR + NAME + NEWLINE_SEPARATOR 
Endif
Close Local File [F:MSK]
End FIELDS

#**
#* Return field table name 
#* @param TABLECODE the table code
#* @param FIELDCODE the field code
#*!
Funprog GETFIELDNAME(TABLECODE, FIELDCODE)
Value Char    TABLECODE()
Value Char    FIELDCODE()
#Value Char    LAN()
Local Char    NAME(255)
Local Integer LGNFIELDS(5)

If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif

NAME = ""

Read [ATZ]CODZONE=TABLECODE;FIELDCODE
If fstat=0
    #Call TEXTELAN([F:ATZ]NOLONG, NAME, LAN) From OBJDIV
    Call TEXTE([F:ATZ]NOLONG, NAME) From OBJDIV
Endif

Close Local File [ATZ]

End NAME

#**
#* Return table code (search if table code is an abbreviation code)
#* 
#* @param TABLECODE the table or abbreviation code
#*!=================================================================
Funprog GETTABLECODE(TABLECODE)
Value Char    TABLECODE()
Local Char    REALTABLECODE(255)

REALTABLECODE = ""
If clalev([F:ATB])=0 : Local File ATABLE [ATB] : Endif
# Take first TABLECODE as a table code...
Read [F:ATB]CODFIC=TABLECODE
If fstat = 0
  REALTABLECODE = TABLECODE
Else
  # ...if not found, take it as a table abbreviation
  Read [F:ATB]ABRFIC=TABLECODE
  If fstat = 0
    REALTABLECODE = [F:ATB]CODFIC
  Endif
Endif
Close Local File [ATB]
End REALTABLECODE

#Funprog GETTABLEFIELDS(TABLECODE, LAN)
#**
#* Return table fields
#* @param TABLECODE the table code
#*!=================================================================
Funprog GETTABLEFIELDS(TABLECODE)
Value Char    TABLECODE()
#Value Char    LAN()
Local Clbfile FIELDS(6)
Local Char    LIBFIELDS(255)
Local Char    LIBTYPE(255)
Local Char    LIBACTIVITE(255)
Local Integer LGNFIELD(5)

Local Char    TYPTYP(255)
Local Char    FORTYP(255)
Local Char    OPTION(255)

Local Char NEWLINE_SEPARATOR(4) : NEWLINE_SEPARATOR = "#NL#"
Local Char VALUE_SEPARATOR(4)   : VALUE_SEPARATOR   = "#SP#"

If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif

FIELDS = ""
NAME = ""

TABLECODE = func GETTABLECODE(TABLECODE)

Filter [F:ATZ] Where [F:ATZ]CODFIC = TABLECODE Order By [F:ATZ]CODZONE Asc
For [F:ATZ]
    Call TEXTE([F:ATZ]NOLONG, LIBFIELDS) From OBJDIV
    LGNFIELD = [F:ATZ]LONG

    # Lecture du Libelle Type
    Call GETLIBELTYPE([F:ATZ]CODTYP, LIBTYPE, LGNFIELD, TYPTYP, FORTYP, OPTION)

    # Lecture du Libelle activite
    LIBACTIVITE = func GETLIBACTIVITE([F:ATZ]CODACT)
    FIELDS += [F:ATZ]CODZONE + VALUE_SEPARATOR + LIBFIELDS + VALUE_SEPARATOR 
    FIELDS += [F:ATZ]CODTYP + VALUE_SEPARATOR + LIBTYPE + VALUE_SEPARATOR 
    FIELDS += num$(LGNFIELD) + VALUE_SEPARATOR + [F:ATZ]CODACT + VALUE_SEPARATOR
    FIELDS += LIBACTIVITE + VALUE_SEPARATOR + num$([F:ATZ]NOLIB) + VALUE_SEPARATOR
    FIELDS += num$([F:ATZ]DIME) + VALUE_SEPARATOR + TYPTYP + VALUE_SEPARATOR
    FIELDS += FORTYP + VALUE_SEPARATOR + OPTION + NEWLINE_SEPARATOR
Next
Filter [F:ATZ]
Close Local File [ATZ]

End FIELDS

#**
#* Return table index 
#* @param TABLECODE the table code
#*!=================================================================
Funprog GETTABLEINDEX(TABLECODE)
Value Char    TABLECODE()
Local Clbfile FIELDS(6)
Local Char    NAME(255)

Local Char NEWLINE_SEPARATOR(4) : NEWLINE_SEPARATOR = "#NL#"
Local Char VALUE_SEPARATOR(4)   : VALUE_SEPARATOR   = "#SP#"

TABLECODE = func GETTABLECODE(TABLECODE)

If clalev([F:AIX])=0 : Local File ATABIND [AIX] : Endif

INDEX = ""
NAME = ""

Filter [F:AIX] Where [F:AIX]CODFIC = TABLECODE Order By [F:AIX]CODIND Asc
For [F:AIX]
    INDEX += [F:AIX]CODIND + VALUE_SEPARATOR + [F:AIX]DESCRIPT + NEWLINE_SEPARATOR
Next
Filter [F:AIX]
Close Local File [AIX]

End INDEX

#**
#* Return mask code (search if mask code is an abbreviation code)
#* 
#* @since 05/01/2010 
#* @param MASKCODE searched code
#*!=================================================================
Funprog GETMASKCODE(MASKCODE)
Value Char    MASKCODE()
Local Char    REALMASKCODE(255)

REALMASKCODE= ""
If clalev([F:MSK])=0 : Local File AMSK [MSK] : Endif
# Take first MASKCODE as a mask code...
Read [F:MSK]CODMSK=MASKCODE
If fstat = 0
  REALMASKCODE= MASKCODE
Else
  # ...if not found, take it as a mask abbreviation (the first one)
  Filter [F:MSK] Where [F:MSK]ABRMSK = MASKCODE Order By [F:MSK]CODMSK Asc
  Read [F:MSK] First
  If fstat = 0
    REALMASKCODE= [F:MSK]CODMSK
  Endif
  Filter [F:MSK]
Endif
Close Local File [MSK]
End REALMASKCODE

#**
#* Return mask fields 
#* @param MASKCODE the mask code
#*!
Funprog GETMASKFIELDS(MASKCODE)
Value Char    MASKCODE()

Local Clbfile FIELDS(6)
Local Char    LIBFIELDS(255)
Local Char    LIBTYPE(255)
Local Char    LIBACTIVITE(255)
Local Integer LGNFIELD(5)

Local Char    TYPTYP(255)
Local Char    FORTYP(255)
Local Char    OPTION(255)

Local Char NEWLINE_SEPARATOR(4) : NEWLINE_SEPARATOR = "#NL#"
Local Char VALUE_SEPARATOR(4)   : VALUE_SEPARATOR   = "#SP#"

If clalev([F:AMK])=0 : Local File AMSKZON [AMK] : Endif

FIELDS = ""
LIBFIELDS = ""

MASKCODE = func GETMASKCODE(MASKCODE)

Filter [F:AMK] Where [F:AMK]CODMSK = MASKCODE Order By [F:AMK]CODZON Asc
For [F:AMK]

    If [F:AMK]INTIT = 0
      If [F:AMK]INTEVAL <> ""
        LIBFIELDS = "$" - " (" + [F:AMK]INTEVAL + ")"
      Endif
    Else
      Call TEXTE([F:AMK]INTIT, LIBFIELDS) From OBJDIV
    Endif

    LGNFIELD = [F:AMK]LONG

    # Lecture du Libelle Type
    Call GETLIBELTYPE([F:AMK]CODTYP, LIBTYPE, LGNFIELD, TYPTYP, FORTYP, OPTION)

    # Lecture du Libelle activite
    LIBACTIVITE = func  GETLIBACTIVITE([F:AMK]CODACT)

    FIELDS += [F:AMK]CODZON + VALUE_SEPARATOR + LIBFIELDS + VALUE_SEPARATOR 
    FIELDS += [F:AMK]CODTYP + VALUE_SEPARATOR + LIBTYPE + VALUE_SEPARATOR 
    FIELDS += num$(LGNFIELD) + VALUE_SEPARATOR + [F:AMK]CODACT + VALUE_SEPARATOR 
    FIELDS += LIBACTIVITE + VALUE_SEPARATOR + num$([F:AMK]NOLIB) + VALUE_SEPARATOR 
    FIELDS += num$([F:AMK]DIME) + VALUE_SEPARATOR + TYPTYP + VALUE_SEPARATOR 
    FIELDS += FORTYP + VALUE_SEPARATOR + OPTION + NEWLINE_SEPARATOR 
Next
Filter [F:AMK]
Close Local File [AMK]

End FIELDS

#**
#* Return global vars 
#*!
Funprog GETGLOBALVARS()
#Value Char    LAN()

Local Clbfile VARS(9)

Local Char    LIBFIELDS(255)
Local Char    LIBTYPE(255)
Local Char    LIBACTIVITE(255)
Local Integer LGNFIELD(5)

Local Char    TYPTYP(255)
Local Char    FORTYP(255)
Local Char    OPTION(255)

Local Char NEWLINE_SEPARATOR(4) : NEWLINE_SEPARATOR = "#NL#"
Local Char VALUE_SEPARATOR(4)   : VALUE_SEPARATOR   = "#SP#"


If clalev([F:AGB])=0 : Local File AGLOBVAR [AGB] : Endif

VARS = ""
LIBFIELDS = ""

For [F:AGB]AGB0
    Call TEXTE([F:AGB]INTIT, LIBFIELDS ) From OBJDIV

    LGNFIELD = 0
    If len([F:AGB]LNGTYP) > 0
        LGNFIELD = val([F:AGB]LNGTYP)
    Endif

    # Lecture du Libelle Type
    Call GETLIBELTYPE([F:AGB]CODTYP, LIBTYPE, LGNFIELD, TYPTYP, FORTYP, OPTION)


    # Lecture du Libelle activite
    LIBACTIVITE = func GETLIBACTIVITE([F:AGB]CODACT)

    VARS += [F:AGB]CODVAR + VALUE_SEPARATOR + LIBFIELDS + VALUE_SEPARATOR 
    VARS += [F:AGB]CODTYP + VALUE_SEPARATOR + LIBTYPE + VALUE_SEPARATOR 
    VARS += num$(LGNFIELD) + VALUE_SEPARATOR + [F:AGB]CODACT + VALUE_SEPARATOR 
    VARS += LIBACTIVITE + VALUE_SEPARATOR + TYPTYP + VALUE_SEPARATOR 
    VARS += FORTYP + VALUE_SEPARATOR + OPTION + NEWLINE_SEPARATOR
Next

Close Local File [AGB]

End VARS

#**
#* Return global vars list (only codes)
#* 
#* @since 1.0.1 - 22/01/2010
#* 
#*!
Funprog GETGLOBALVARSLIST()
  Local Clbfile VARS(9)
  Local Char NEWLINE_SEPARATOR(4) : NEWLINE_SEPARATOR = "#NL#"
  Local Char VALUE_SEPARATOR(4)   : VALUE_SEPARATOR   = "#SP#"
  If clalev([F:AGB])=0 : Local File AGLOBVAR [AGB] : Endif
  VARS = ""
  For [F:AGB]AGB0
      VARS += [F:AGB]CODVAR + NEWLINE_SEPARATOR
  Next
  Close Local File [AGB]
End VARS

#**
#* Return global var info of a global var
#* 
#* @param CODE the global var code
#* 
#* @since 1.0.1 - 22/01/2010
#*!
Funprog GETGLOBALVARINFO(CODE)
Value Char CODE()

Local Clbfile VARS(9)

Local Char    LIBFIELDS(255)
Local Char    LIBTYPE(255)
Local Char    LIBACTIVITE(255)
Local Integer LGNFIELD(5)

Local Char    TYPTYP(255)
Local Char    FORTYP(255)
Local Char    OPTION(255)

Local Char NEWLINE_SEPARATOR(4) : NEWLINE_SEPARATOR = "#NL#"
Local Char VALUE_SEPARATOR(4)   : VALUE_SEPARATOR   = "#SP#"

If clalev([F:FIC])=0 : Local File AGLOBVAR [FIC] : Endif

VARS = ""
LIBFIELDS = ""

Read [F:FIC]AGB0=CODE
If fstat = 0
    Call TEXTE([F:FIC]INTIT, LIBFIELDS ) From OBJDIV

    LGNFIELD = 0
    If len([F:FIC]LNGTYP) > 0
        LGNFIELD = val([F:FIC]LNGTYP)
    Endif

    # Lecture du Libelle Type
    Call GETLIBELTYPE([F:FIC]CODTYP, LIBTYPE, LGNFIELD, TYPTYP, FORTYP, OPTION)

    # Lecture du Libelle activite
    LIBACTIVITE = func GETLIBACTIVITE([F:FIC]CODACT)

    VARS += [F:FIC]CODVAR + VALUE_SEPARATOR + LIBFIELDS + VALUE_SEPARATOR 
    VARS += [F:FIC]CODTYP + VALUE_SEPARATOR + LIBTYPE + VALUE_SEPARATOR 
    VARS += num$(LGNFIELD) + VALUE_SEPARATOR + [F:FIC]CODACT + VALUE_SEPARATOR 
    VARS += LIBACTIVITE + VALUE_SEPARATOR + TYPTYP + VALUE_SEPARATOR 
    VARS += FORTYP + VALUE_SEPARATOR + OPTION + NEWLINE_SEPARATOR
Endif

Close Local File [FIC]

End VARS

#**
#* Return counters 
#*!
Funprog GETCOUNTERS()

Local Clbfile VARS(9)

Local Char    LIBCOUNTER(255)
Local Char    CODCOUNTER(255)
Local Char    RAZ_LEVEL(255)
Local Char    DEF_LEVEL(255)
Local Char    COUNTER_TYPE(255)


Local Char NEWLINE_SEPARATOR(4) : NEWLINE_SEPARATOR = "#NL#"
Local Char VALUE_SEPARATOR(4)   : VALUE_SEPARATOR   = "#SP#"

#If clalev([F:FIC])=0 : Local File ACODNUM [FIC] : Endif
If clalev([F:FIC])=0 : Local File APLCOM [FIC] : Endif

VARS = ""

For [F:FIC]

    RAZ_LEVEL = num$([F:FIC]COMIND)
    DEF_LEVEL = num$([F:FIC]COMFLD)
    COUNTER_TYPE = mess(func GETCOUNTERSTYPE([F:FIC]COMTYP), 30, 1)

     #LIBCOUNTER = [F:FIC]COMNOM - "(" + num$([F:FIC]COMIND) + ")"
     LIBCOUNTER = ""
     CODCOUNTER = [F:FIC]COMNOM
     
     If [F:FIC]COMIND > 0
        CODCOUNTER += "(" + num$([F:FIC]COMIND) + ")"
     Endif

    VARS += CODCOUNTER 
&    + VALUE_SEPARATOR + LIBCOUNTER
&    + VALUE_SEPARATOR + COUNTER_TYPE 
&    + VALUE_SEPARATOR + num$([F:FIC]COMLEN) 
&    + VALUE_SEPARATOR + RAZ_LEVEL 
&    + VALUE_SEPARATOR + DEF_LEVEL 
&    + NEWLINE_SEPARATOR

Next

Close Local File [FIC]

End VARS

#**
# Return the real counter type, the one to use with mess(x,30,1)
# @param COUNTERTYPE counter type number stored in table 
#*!
Funprog GETCOUNTERSTYPE(COUNTERTYPE)
Value Integer COUNTERTYPE
Local Integer MESSCOUNTERTYPE
MESSCOUNTERTYPE = COUNTERTYPE - 299
End MESSCOUNTERTYPE

#**
#* Return type label
#* 
#* @param CODE
#* @param NAME
#* @param LGN
#* @param TYPTYP
#* @param FORTYP
#* @param OPTION
#*!
Subprog GETLIBELTYPE(CODE,  NAME , LGN, TYPTYP, FORTYP, OPTION)
Value Char CODE()
Variable Char NAME()
Variable Integer LGN()
Variable Char TYPTYP()
Variable Char FORTYP()
Variable Char OPTION()

Local Char    NAME(255)

NAME = ""
TYPTYP = ""
FORTYP = ""
OPTION = ""

If clalev([F:ATY])=0 : Local File ATYPE [ATY] : Endif

Read [ATY]CODTYP=CODE
If fstat=0 
    Call TEXTE([F:ATY]INTITTYP, NAME) From OBJDIV

    If LGN  = 0
        LGN =[F:ATY]LNGTYP
    Endif
    
    If [F:ATY]TYPTYP >= 0
        TYPTYP = func GETLOCALMENU( "30", num$([F:ATY]TYPTYP), "1")
    Endif
    FORTYP = [F:ATY]FORTYP 
    OPTION = [F:ATY]OPTION

Endif
Close Local File [ATY]

End


#**
#* Return activity label
#* 
#* @param CODE the activity code
#*!
Funprog GETLIBACTIVITE(CODE)
Value Char CODE()

Local Char NAME(255)

NAME = ""

If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif

Read [ACV]CODACT=CODE
If fstat=0
    Call TEXTE([F:ACV]LIBACT, NAME ) From OBJDIV
Endif
Close Local File [ACV]

End NAME

