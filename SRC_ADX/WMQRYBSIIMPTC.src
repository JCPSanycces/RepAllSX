#<AdxTL>@(#)0.0.0.0 $Revision$Class Bank import type codes
# Supervisor
## WMREP REPRESENTATION ## BSIIMPTC
# 2018-08-16 22:22:47 461

#-------------------------------------------------------------------#
# Tables list to open
#-------------------------------------------------------------------#
$AQUERY_OPEN
If clalev([F:BSITC])=0 : Local File BSIIMPTC [BSITC] : Endif
If clalev([F:WAXX1])=0 : Local File ATEXTRA [WAXX1] : Endif
ACTION = "AQUERY_OPEN_AFTER" : Gosub AQUERY_ACTION
Return
 
#-------------------------------------------------------------------#
# Tables list to close
#-------------------------------------------------------------------#
$AQUERY_CLOSE
LogicClose File [BSITC]
LogicClose File [WAXX1]
ACTION = "AQUERY_CLOSE_AFTER" : Gosub AQUERY_ACTION
Return
 
#-------------------------------------------------------------------#
# Link for the query
#-------------------------------------------------------------------#
$AQUERY_JOIN
Link [BSITC] With
& [F:WAXX1]AXX0 = "BSIIMPTC";"DESAXX";GACTX.LAN;[F:BSITC]BSICODTC;""
& As [LNK_]
& Where ( (1=1)
&  )
ACTION = "AQUERY_JOIN_AFTER" : Gosub AQUERY_ACTION
Return
 
#-------------------------------------------------------------------#
# Link for the lookup
#-------------------------------------------------------------------#
$AQUERY_JOIN_LOOKUP
Link [BSITC] With
& [F:WAXX1]AXX0 = "BSIIMPTC";"DESAXX";GACTX.LAN;[F:BSITC]BSICODTC;""
& As [LNK_]
& Where ( (1=1)
&  )
Return
 
#-------------------------------------------------------------------#
# Default filter for the query
#-------------------------------------------------------------------#
$AQUERY_FILTER_DEF
Return
 
#-------------------------------------------------------------------#
# Transclass of fields of query
#-------------------------------------------------------------------#
$AQUERY_TRANS
# BSITC --- BSIIMPTC(BSITC)
QRY(NBREP) = NewInstance R_BSIIMPTC AllocGroup PQRY
QRY(NBREP).setAccessorEnabled = 0
If dim([F:BSITC]AUUID)>0 & [F:BSITC]AUUID=NullUuid
 [F:BSITC]AUUID = getUuid
Endif
SetInstance QRY(NBREP).BSITC With [F:BSITC]
[L]ASTATUS = fmet QRY(NBREP).ACTION("AQUERY_TRANS_AFTER")
Call ASETTEXTRA(QRY(NBREP).BSITC.AXX,"QRY","DESAXX",[F:WAXX1]TEXTE,[F:WAXX1]LANGUE) From ASYRSUB
 
QRY(NBREP).setAccessorEnabled = 1
Gosub AQUERY_LNKPRO
Return

#-------------------------------------------------------------------#
# Create instance
#-------------------------------------------------------------------#
$AQUERY_CREATEINSTANCE
# BSITC --- BSIIMPTC(BSITC)
QRY = NewInstance R_BSIIMPTC AllocGroup PQRY
QRY.BSITC.AXX(1) = NewInstance C_ATXTTRA AllocGroup QRY
QRY.setAccessorEnabled = 0
Return

#-------------------------------------------------------------------#
# Create instance
#-------------------------------------------------------------------#
$AQUERY_SETINSTANCE
If dim([F:BSITC]AUUID)>0 & [F:BSITC]AUUID=NullUuid
 [F:BSITC]AUUID = getUuid
Endif
SetInstance QRY.BSITC With [F:BSITC]
QRY.BSITC.AXX(1).PRO = "DESAXX"
QRY.BSITC.AXX(1).LAN = [F:WAXX1]LANGUE
QRY.BSITC.AXX(1).TEX = [F:WAXX1]TEXTE
QRY.BSITC.AXX(1).FLG = 1
[L]ASTATUS = fmet QRY.ACTION("AQUERY_TRANS_AFTER")
Return

#-------------------------------------------------------------------#
# Additionnal criteria of query
#-------------------------------------------------------------------#
$AQUERY_CRITERIA
Gosub DECLARE_VAR From WMC0BSIIMPTC
CURQRY = "R_BSIIMPTC"
ACTION = "AQUERY_CRITERIA_AFTER" : Gosub AQUERY_ACTION
Return

#-------------------------------------------------------------------#
# LNKPRO of query 
#-------------------------------------------------------------------#
$AQUERY_LNKPRO
Callmet QRY(NBREP).BSITC.BAN.LNKPRO
Return

#-------------------------------------------------------------------#
# LNKPRO of query INSTANCE
#-------------------------------------------------------------------#
$AQUERY_LNKPRO_INSTANCE
Callmet QRY.BSITC.BAN.LNKPRO
Return

#-------------------------------------------------------------------#
# LOAD_PROPERTIES of query
#-------------------------------------------------------------------#
$AQUERY_DECODE_CRITERIA
NBPRO = 0
NBPRO += 1 : TBPRO(NBPRO) = "BSICODTC" : TBFIL(NBPRO) = "[F:BSITC]BSICODTC"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "BSITC.BSICODTC"
NBPRO += 1 : TBPRO(NBPRO) = "BAN" : TBFIL(NBPRO) = "[F:BSITC]BAN"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "BSITC.BAN"
NBPRO += 1 : TBPRO(NBPRO) = "DESAXX" : TBFIL(NBPRO) = "[F:WAXX1]TEXTE"
           : TBTYP(NBPRO) = 26 : TBPTH(NBPRO) = "BSITC.DESAXX"
NBPRO += 1 : TBPRO(NBPRO) = "SHO" : TBFIL(NBPRO) = "[F:BSITC]SHO"
           : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "BSITC.SHO"
ACTION = "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_ACTION
Return

#-------------------------------------------------------------------#
# Standard key of query
#-------------------------------------------------------------------#
$AQUERY_PRIMARYKEYS
Local Char ASTDKEY(250)
ASTDKEY = ""
ASTDKEY += "[F:BSITC]BSICODTC"
ASTDKEY += ";"+"[F:BSITC]BAN"
ACTION = "AQUERY_PRIMARYKEYS_AFTER" : Gosub AQUERY_ACTION
Return

#-------------------------------------------------------------------#
# ACTIONS
#-------------------------------------------------------------------#
$AQUERY_ACTION
Local Char CURPRO(250),CURPTH(250),AMETHOD(50),AEVENT(50)
[L]AEVENT = [L]ACTION
Gosub METHODS From BSIIMPTC_RSTD
Gosub EVENTS From BSIIMPTC_RSTD
Return
 


