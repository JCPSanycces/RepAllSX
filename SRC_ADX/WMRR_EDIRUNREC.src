#<AdxTL>@(#)0.0.0.0 $Revision$Class EDI inbound msg. generation
# Supervisor
## CRUD-CLASSE ## EDIRUNREC
# 2018-10-17 07:54:26 852


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File EDIRUN [EDR_]

If !SILENCE : Call TRACE("2 --> Local Instance R_EDIRUNREC") From ASYRCOM : Endif
Local Instance EDIRUNREC Using R_EDIRUNREC

If !SILENCE : Call TRACE("3 --> New Instance R_EDIRUNREC") From ASYRCOM : Endif
EDIRUNREC = NewInstance R_EDIRUNREC AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [EDR_]EDR0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of EDIRUN") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.AREAD([EDR_]NUM))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("EDIRUNREC.EDR.NUM ="-num$(EDIRUNREC.EDR.NUM)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(EDIRUNREC.EDR.AKEYS)
  Call TRACE("-"-num$(I)-":"-EDIRUNREC.EDR.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [EDR_]
FreeGroup EDIRUNREC
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(EDIRUNREC,ACLE,ASTATUS,_ETAG)
Variable Instance EDIRUNREC Using R_EDIRUNREC
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Shortint _NUM
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_NUM = val([L]CLE(1)) : Endif
Raz [L]_ETAG
Local File EDIRUN [EDR]
Default File [F:EDR]
Read [F:EDR]EDR0 = [L]_NUM
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:EDR]UPDTICK)>0
 [L]_ETAG = num$([F:EDR]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(EDIRUNREC,ACLE,ASTATUS)
Variable Instance EDIRUNREC Using R_EDIRUNREC
Value Char ACLE
Variable Integer ASTATUS
Local Shortint _NUM
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_NUM = val([L]CLE(1)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.AREAD([L]_NUM))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(EDIRUNREC,_NUM,ASTATUS)
Variable Instance EDIRUNREC Using R_EDIRUNREC
Value Shortint _NUM
Variable Integer ASTATUS

If EDIRUNREC = null : End : Endif

Gosub AVARIABLES From WMR00EDIRUNREC
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If EDIRUNREC.APARENT=null
 [L]A_I = EDIRUNREC.freeSnapshot
 EDIRUNREC.snapshotEnabled = 0
 EDIRUNREC.setAccessorEnabled = 0
Endif

If fmet EDIRUNREC.ACTX.AGETAFCRIGHT(EDIRUNREC,"EDIRUNREC",[V]CST_ATRUE)>=[V]CST_AERROR : [L]ASTATUS=[V]CST_AERROR : Goto AREAD_END : Endif
Default File [F:EDR]
Read [F:EDR]EDR0 = [L]_NUM
If fstat
[L]A_ERROR = num$([L]_NUM)
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(EDIRUNREC,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If fmet EDIRUNREC.ACTX.AGETAFCRIGHTR(EDIRUNREC,"EDIRUNREC",[L]A_STRSITE,[V]CST_ATRUE)>=[V]CST_AERROR
 [L]ASTATUS=[V]CST_AERROR : Goto AREAD_END
Endif

[L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.ACTION("AREAD_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

EDIRUNREC.EDR.setAccessorEnabled = 0
[L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.EDR.AREAD([L]_NUM))
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & EDIRUNREC.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If EDIRUNREC.APARENT=null
 EDIRUNREC.snapshotEnabled = 1
 EDIRUNREC.setAccessorEnabled = 1
Endif
LogicClose File [EDR] ,[EDRD]
End



