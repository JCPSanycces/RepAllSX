#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT4 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBRHAB
mkstat = 0
zoncou = "NBRHAB"
indice = 0
status = 1
zoncou = "NBRHAB"
If varmode([M]NBRHAB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRHAB" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRHAB
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRHAB = nolign
   status = 75
   Call SAI_NBRHAB(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  SAVACT = GACTION : GACTION = "STD"
  Call C_NBRHAB From SUBEML2
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "NBRHAB" : GZNUM = 0 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBRHAB(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRHAB
mkstat = 0
zoncou = "NBRHAB"
If !mkstat
 SAVACT = GACTION : GACTION = "STD"
 Call C_NBRHAB From SUBEML2
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "NBRHAB" : GZNUM = 0 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone PJ
mkstat = 0
zoncou = "PJ"
If varmode([M]PJ,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_PJ([M]PJ(indice)) From SUBEML2
 GACTION = SAVACT
 If mkstat=1 : Raz [M]PJ(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "PJ" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone CAT
mkstat = 0
zoncou = "CAT"
IMPENT = [M]CAT(indice)
WNUM = IMPENT
If varinit([M]CAT,indice)=0
 IMPENT = 1
Endif
If varmode([M]CAT,indice)=0
 [M]CAT(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CAT" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CAT(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_CAT(IMPENT) From SUBEML2
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CAT" : GZNUM = 707 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]CAT(indice) = IMPENT

## Zone HAB
mkstat = 0
zoncou = "HAB"
If varmode([M]HAB,indice)=0
 SAVACT = GACTION : GACTION = "DEFHRLIC"
 Call DEFHRLIC([M]HAB(indice),[V]GCURLEG,"") From SUBHRLIC
 GACTION = SAVACT
 If mkstat=1 : Raz [M]HAB(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "HAB" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]HAB(indice),2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "HAB" : GZNUM = 46765 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTHRLIC"
   Call CONTHRLIC([M]HAB(indice),[V]GCURLEG,"") From SUBHRLIC
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "HAB" : GZNUM = 46765 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "CONTOBJN"
    Local Char    VALEUR(250)
    VALEUR = [M]HAB(indice)
    Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
    [M]HAB(indice) = VALEUR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "HAB" : GZNUM = 46765 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone PMTTYP
mkstat = 0
zoncou = "PMTTYP"
IMPENT = [M]PMTTYP(indice)
If varinit([M]PMTTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]PMTTYP,indice)=0
 [M]PMTTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "PMTTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]PMTTYP(indice)
 Endif
Endif
[M]PMTTYP(indice) = IMPENT

## Zone PMTNUM
mkstat = 0
zoncou = "PMTNUM"
If varmode([M]PMTNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PMTNUM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone HABSTR
mkstat = 0
zoncou = "HABSTR"
If varmode([M]HABSTR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "HABSTR" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone HABPLC
mkstat = 0
zoncou = "HABPLC"
If varmode([M]HABPLC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "HABPLC" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone HABEND
mkstat = 0
zoncou = "HABEND"
If varmode([M]HABEND,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_HABEND([M]HABEND(indice)) From SUBEML2
 GACTION = SAVACT
 If mkstat=1 : Raz [M]HABEND(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "HABEND" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "DATDEBFIN"
  Call DATDEBFIN([M]HABEND(indice),[M]HABSTR(nolign-1)) From EXEFNC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "HABEND" : GZNUM = 5463 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone HABFLG
mkstat = 0
zoncou = "HABFLG"
IMPENT = [M]HABFLG(indice)
If varinit([M]HABFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]HABFLG,indice)=0
 [M]HABFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "HABFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]HABFLG(indice)
 Endif
Endif
[M]HABFLG(indice) = IMPENT

## Zone HABCMT
mkstat = 0
zoncou = "HABCMT"
If varmode([M]HABCMT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "HABCMT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ETRPITTYP
mkstat = 0
zoncou = "ETRPITTYP"
If varmode([M]ETRPITTYP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ETRPITTYP" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ETRPITDAT
mkstat = 0
zoncou = "ETRPITDAT"
If varmode([M]ETRPITDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ETRPITDAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ETRPITEXPDAT
mkstat = 0
zoncou = "ETRPITEXPDAT"
If varmode([M]ETRPITEXPDAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "ETRPITEXPDAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone RFGNBR
mkstat = 0
zoncou = "RFGNBR"
If varmode([M]RFGNBR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "RFGNBR" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_RFGNBR([M]RFGNBR(indice)) From SUBEML2
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "RFGNBR" : GZNUM = 1120 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone NBRHAB
mkstat = 0
zoncou = "NBRHAB"
status = 71
SAVACT = GACTION : GACTION = "STD"
Call APRES_NBRHAB From SUBEML2
GACTION = SAVACT

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "HRMAT4"
Return

