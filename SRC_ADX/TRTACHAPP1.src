#<AdxTL>@(#)81.0.0.0 $Revision$
########################################################################
# TRTACHAPP1          Traitements des signatures          Module ACHAT #
# -------------------------------------------------------------------- #
# Sous-programmes :                                                    #
#   - PAMAPPFLG : Test modif rubr. majeure pour raz signatures         #
########################################################################



########################################################################
# PAMAPPFLG : S/P de test modification rubrique majeure   MBT 08/01/98 #
#             pour reprise du cycle de signature                       #
#----------------------------------------------------------------------#
# Subprog PAMAPPFLG (WABMSK,NOLIG,NOMZON)                              #
#   WABMSK  : Abréviation du masque écran contenant les lignes         #
#            si "" --> Mise à jour de l'indicateur GAPPFLG             #
#   NOLIG   : Indice de la ligne active (nolign-1)                     #
#   NOMZON  : Nom du champ courant (remplace le zoncou MBT 30/11/00)   #
#                                                                      #
# Attention : Ce S/P est appelé par une action "Après_Modif"           #
########################################################################
Subprog PAMAPPFLG (WABMSK,NOLIG,NOMZON)
Value  Char     WABMSK
Value  Integer  NOLIG
Value  Char     NOMZON
Local  Shortint FLAG : FLAG=1
# Issue 88103 - 2013-02-25 by SR : Ajout de zone pour exploitation du P.E en D.A
If NOMZON = "CUR"        |
&  NOMZON = "CHGCOE"     |
&  NOMZON = "UOM"        |
&  NOMZON = "QTYUOM"     |
&  NOMZON = "UOMPUUCOE"  |
&  NOMZON = "PUU"        |
&  NOMZON = "QTYPUU"     |
&  NOMZON = "QTYSTU"     |
&  NOMZON = "GROPRI"     |
&  NOMZON = "DISCRGVAL1" |
&  NOMZON = "DISCRGVAL2" |
&  NOMZON = "DISCRGVAL3" |
&  NOMZON = "DISCRGVAL4" |
&  NOMZON = "DISCRGVAL5" |
&  NOMZON = "DISCRGVAL6" |
&  NOMZON = "DISCRGVAL7" |
&  NOMZON = "DISCRGVAL8" |
&  NOMZON = "DISCRGVAL9" |
&  NOMZON = "INVDTAAMT"  |
&  NOMZON = "BPSNUM"     |
&  NOMZON = "NETPRI"     |
&  NOMZON = "PRHFCY"     |
&  NOMZON = "EXTRCPDAT"  |
&  NOMZON = "EXTORDDAT"  : FLAG=2 : Endif

#######################################################
# Appel du point d'entrée PAMAPPFLG :                 #
# --------------------------------------------------- #
# FLAG  Indicateur rubrique majeure                   #
#       pour reprise du cycle de signature            #
#      1 = Rubrique non majeure                       #
#      2 = Rubrique majeure                           #
#######################################################
#VPO 25/02/11 71885 ajout PE
GPOINT="PAMAPPFLG" : Gosub ENTREE From EXEFNC
# Issue 88103 - 2013-02-25 by SR : exploitation du P.E en D.A
If WABMSK = "PSH1"
   Assign "[M:"+WABMSK+"]WAPPFLG(NOLIG)"  With FLAG
   End
Endif   
If FLAG=2
  If WABMSK=""
    GAPPFLG=2
  Else
    Assign "[M:"+WABMSK+"]WAPPFLG(NOLIG)"  With 2
  Endif
Endif
End
