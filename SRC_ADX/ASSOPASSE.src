#<AdxTL>@(#)8.0.0.0 $Revision$
Raz GNBMASKOUV
Local Char PARAM(50)(1..2) , VALEUR(50) , PROGSPE(GLONADC)
Call TRTSPE(nomap,"ASSOPASSE",PROGSPE) From SUBACT
Call SAISIE_CHAR(VALEUR,PARAM,"ASSOPASSE","ASSOPASSE",PROGSPE) From GSAISIE
Infbox PARAM(1)
End

#------------------------------------------------------------------------------------#
$ACTION
Case ACTION
 When "DEBUT" : Gosub DEBUT
 When "OK"    : Gosub OK
Endcase
Return

#--------------------------------------------------------------#
$DEBUT
Raz [M]
Return

#--------------------------------------------------------------#
$OK
Local Char OLDPASSE(50)
OLDPASSE = PARAM(1)
If OLDPASSE<>"" & OLDPASSE<>XCRYPT([M]PAS1)
 GMESSAGE = mess(80,100,1)  : # Ancien mot de passe incorrect
 GERR = 1 : OK = 0 : Return
Endif 
If [M]PAS2<>[M]PAS3
 GMESSAGE = mess(81,100,1)  : # Les 2 mots de passe ne sont pas identiques
 GERR = 1 : OK = 0 : Return
Endif
PARAM(1) = XCRYPT([M]PAS2)
mkstat = 4
Return

