#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################################################
#     ENSEMBLE de sous-programmes utilitaires créés pour le CRM
#
#  GET_TRAD      : Programme de renvoi d'un texte traduisible.
#  GET_TRADAUT   : Programme automatique de renvoi d'un texte traduisible.
#  GET_TRADWVAL  : Programme automatique de renvoi d'un texte traduisible sans valeur clé.
#  GET_LIB       : Renvoi un libellé de table diverse à partir d'un code.
#  GET_LIBSHO    : Renvoi un libellé court de table diverse à partir d'un code.
#  GET_LIBF      : Renvoi le premier libellé de la table diverse indiquée.
#  GET_LIBFC     : Renvoi le premier code de la table diverse indiquée.
#  GET_LIBM      : Renvoi d'un libellé de menu local à partir d'un code.
#  CHECKREP      : Test la correspondance entre un code représentant et l'utilisateur courant
#  GETDEVCPY     : Renvoi la devise de la société.
#  CHECKPRC      : Test si la valeur donnée correspond à un pourcentage.
#  GETDEVCLA     : Retourne le nom complet du devise à partir de son code.
#  SETCUR        : Retourne la devise par défaut à affecter à un enregistrement.
#  GETDUR        : Retourne la durée de travail (en heures) écoulée entre deux dates.
#  GETNEWHOUR    : Retourne une heure augmentée du nombre de minutes indiquées
#  GETBPRTYP     : Retourne la nature du tiers en clair en fonction d'une priorité arbitraire
#  GETCLOSTAT    : Retourne le statut de clôture d'une étape avant-vente d'affaire
#  GETWORKDAY    : Retourne le nombre de jours et d'heures travaillées par un collaborateur entre deux dates
#  GETNEXTWDAY   : Retourne le prochain jour travaillé d'un collaborateur à partir de la date indiquée
#  CHECKNOTWKD   : Vérifie si un répresentant travaille à une date donnée
#  CHKTUVNOTWKD  : Vérifie les périodes d'indisponibilité
#  GETNBCLLDAY   : Retourne le nombre d'appels programmés pour un représentant pour une date précise.
#  REMTPLEXT     : Retire l'extension d'un nom de fichier.
#  ADDTPLEXT     : Ajoute l'extension .rpt à un nom de fichier.
#  ADDTPLEXT2    : Ajoute une extension à un nom de fichier.
#  ISCRMSET      : Informe si le module Action commerciale a été installé pour le dossier en cours.
#  ISHDKSET      : Informe si le module Support client a été installé pour le dossier en cours.
#  SETSITECRM    : Défini le site par défaut pour un objet des modules Action commerciale et Support client.

#  LSE V5
#  SITECRMDEF    : Défini le site par défaut pour un objet des modules Action commerciale et Support client.
#  SITECRMREP    : Défini le site par rapport à celui du représentant
#  SITECRMINTREP : Défini le site par rapport de l'interlocuteur
#
###########################################################################################################

##########################################################################################################
#Programme de renvoi d'un texte traduisible.                                 #
##############################################################################
Subprog GET_TRAD(SZTABLE, SZFIELD, SZCLE1, SZCLE2, LIB)
Value Char SZTABLE
Value Char SZFIELD
Value Char SZCLE1
Value Char SZCLE2
Variable Char LIB

  LIB = ""
  Call LECTEXTRA(LIB, SZTABLE, SZFIELD, SZCLE1, SZCLE2) From ATEXTRA
End

##########################################################################################################
#Programme automatique de renvoi d'un texte traduisible.                     #
##############################################################################
Subprog GET_TRADAUT(SZTABLE, SZFIELD, SZVALUE, LIB)
Value Char SZTABLE
Value Char SZFIELD
Value Char SZVALUE
Variable Char LIB

  LIB = ""
  If SZTABLE = "" Then
    End
  Endif
  If SZFIELD = "" Then
    End
  Endif
  If SZVALUE = "" Then
    End
  Endif
  Local File ATABIND [ATI]

Local Char SZVALUE2(250)
Local Integer ISTRINDSEA

  SZVALUE2 = ""
  ISTRINDSEA = 0
  Filter [ATI] Where [F:ATI]CODFIC = SZTABLE and [F:ATI]HOMONYM <> 2 Order By [F:ATI]NUMLIG Asc
  For [ATI] Hint Key CODIND
    If [F:ATI]DESCRIPT <> "" Then
      ISTRINDSEA = 0
      ISTRINDSEA = instr(1, [F:ATI]DESCRIPT, '+')
      If ISTRINDSEA = 0 Then
        Call LECTEXTRA(LIB, SZTABLE, SZFIELD, SZVALUE, SZVALUE2) From ATEXTRA
      Endif
    Endif
    Break
  Next
  Filter [ATI]
End

##########################################################################################################
#Programme automatique de renvoi d'un texte traduisible sans valeur clé.     #
##############################################################################
Subprog GET_TRADWVAL(SZTABLE, SZABRTABLE, SZFIELD, LIB)
Value Char SZTABLE
Value Char SZABRTABLE
Value Char SZFIELD
Variable Char LIB

  LIB = ""
  If SZTABLE = "" Then
    End
  Endif
  If SZABRTABLE = "" Then
    End
  Endif
  If SZFIELD = "" Then
    End
  Endif
  Local File ATABIND [ATI]

Local Char SZBUFFFLOAT(250)
Local Char SZBUFFFDAT(250)
Local Char SZVALUE(250)
Local Char SZVALUE2(250)
Local Char SZKEYFIELD(250)
Local Integer ISTRINDSEA

  SZVALUE = ""
  SZVALUE2 = ""
  ISTRINDSEA = 0
  SZKEYFIELD = ""
  Filter [ATI] Where [F:ATI]CODFIC = SZTABLE and [F:ATI]HOMONYM <> 2 Order By [F:ATI]NUMLIG Asc
  For [ATI] Hint Key CODIND
    If [F:ATI]DESCRIPT <> "" Then
      ISTRINDSEA = 0
      ISTRINDSEA = instr(1, [F:ATI]DESCRIPT, '+')
      If ISTRINDSEA = 0 Then
        SZKEYFIELD = [F:ATI]DESCRIPT
        Assign ("SZVALUE") With evalue("[F:" + SZABRTABLE + "]" + SZKEYFIELD)
        If SZVALUE <> "" Then
          Call LECTEXTRA(LIB, SZTABLE, SZFIELD, SZVALUE, SZVALUE2) From ATEXTRA
        Endif
      Endif
    Endif
    Break
  Next
  Filter [ATI]
End

##########################################################################################################
#Programme de renvoi d'un libellé de table diverse à partir d'un code.       #
##############################################################################
Subprog GET_LIB(CODETAB, CODELIB, LIB)
Value Integer CODETAB
Value Char CODELIB()
Variable Char LIB()

  Call LECTEXTRA(LIB, "ATABDIV", "LNGDES", num$(CODETAB), CODELIB) From ATEXTRA
End

##########################################################################################################
#Programme de renvoi d'un libellé de table diverse à partir d'un code.       #
##############################################################################
Subprog GET_LIBSHO(CODETAB, CODELIB, LIB)
Value Integer CODETAB
Value Char CODELIB()
Variable Char LIB()

  Call LECTEXTRA(LIB, "ATABDIV", "SHODES", num$(CODETAB), CODELIB) From ATEXTRA
End

##########################################################################################################
#Programme de renvoi d'un libellé court de table diverse à partir d'un code. #
##############################################################################
Funprog FGET_LIB(CODETAB, CODELIB, CHAMP)
Value Integer CODETAB
Value Char CODELIB()
Value Char CHAMP   # soit "SHODES", soit "LNGDES"

  If CHAMP = "SHODES" Then
    Local Char LIB(GLONAX1)

    Call GET_LIBSHO(CODETAB, CODELIB, LIB)
  Elsif CHAMP = "LNGDES" Then
    Local Char LIB(GLONAX3)

    Call GET_LIB(CODETAB, CODELIB, LIB)
  Else
    Local Char LIB(GLONAX3)

    LIB = mess(11,133,1)  # Si on vient là c'est quand même un bug !
  Endif
End LIB

##########################################################################################################
#Programme de renvoi du premier libellé de la table diverse indiquée.        #
##############################################################################
Subprog GET_LIBF(CODETAB, CODELIB, LIB)
Value Integer CODETAB
Variable Char CODELIB()
Variable Char LIB()

  Local File ATABDIV [ADI]
  Filter [ADI] Where [F:ADI]NUMTAB = CODETAB Order By [F:ADI]CODE Asc
  For [ADI]
    CODELIB = [F:ADI]CODE
    Call LECTEXTRA(LIB, "ATABDIV", "LNGDES", num$(CODETAB), CODELIB) From ATEXTRA
    Break
  Next
  Filter [ADI]
End

##########################################################################################################
#Programme de renvoi du premier code de la table diverse indiquée.           #
##############################################################################
Subprog GET_LIBFC(CODETAB, CODELIB)
Value Integer CODETAB
Variable Char CODELIB()

  Local File ATABDIV [ADI]
  Filter [ADI] Where [F:ADI]NUMTAB = CODETAB Order By [F:ADI]CODE Asc
  For [ADI]
    CODELIB = [F:ADI]CODE
    Break
  Next
  Filter [ADI]
End

##########################################################################################################
#Programme de renvoi d'un libellé de menu local à partir d'un code.          #
##############################################################################
Subprog GET_LIBM(CODECHA, CODENUM, CODELAN, LIB)
Value Integer CODECHA
Value Integer CODENUM
Variable Char CODELAN()
Variable Char LIB()

  Local File APLSTD [MTD]
  Read [MTD]CLE=CODECHA;CODENUM;CODELAN
  LIB = [F:MTD]LANMES
End

##########################################################################################################
#Programme de test de correspondance entre un code représentant et l'utilisateur courant #
#                                                                                        #
# Si REP = GUSER alors RESULT = 0 sinon RESULT = 2                                       #
##########################################################################################
Subprog CHECKREP(CODEREP, RESULT)
Value Char CODEREP
Variable Integer RESULT

  Local File SALESREP [REP]
  Read [REP]REP0=CODEREP
  If !fstat Then
    If [F:REP]AUSNUM = GUSER Then
      RESULT = 0
    Else
      RESULT = 2
    Endif
  Endif
End

##########################################################################################################
#Programme de renvoi de la devise de la société indiqué #
#########################################################
Subprog GETDEVCPY(CODECPY, CODEFCY, CODECUR, IT_IS_OK)
Value Char CODECPY
Value Char CODEFCY
Variable Char CODECUR
Variable Integer IT_IS_OK

  If CODECPY = "" Then
    #Recherche du code société à partir du code site
    Local File FACILITY[FCY]
    Read [FCY] FCY0 = CODEFCY
    If fstat Then
      IT_IS_OK = 0
      End
    Endif
    CODECPY = [F:FCY]LEGCPY
  Endif
  #Recherche de la devise à partir du code société
  Local File COMPANY [CPY]
  Read [CPY]CPY0=CODECPY
  If fstat Then
   IT_IS_OK = 0
   End
  Endif
  CODECUR = [F:CPY]ACCCUR
  IT_IS_OK = 1
End

##########################################################################################################
#Programme de test d'une valeur de pourcentage     #
#                                                  #
# Renvoi 1 si la valeur est un pourcentage         #
# Renvoi 0 si la valeur n'est pas un pourcentage   #
#                                                  #
####################################################
Subprog CHECKPRC(IPRCVALUE, ISPERCENT)
Value Integer IPRCVALUE
Variable Integer ISPERCENT

  ISPERCENT = 0
  If IPRCVALUE <= 100 and IPRCVALUE >= 0 Then
    ISPERCENT = 1
  Endif
End

##########################################################################################################
#Retourne le nom complet d'une devise à partir de son code #
############################################################
Subprog GETDEVCLA(CODEDEV, DEVLIB)
Value Char CODEDEV
Variable Char DEVLIB

  Local File TABCUR[TCU]
  Read [TCU]TCU0=CODEDEV
  DEVLIB = [F:TCU]CURDES
End

##########################################################################################################
#Retourne la devise par défaut à affecter à un enregistrement #
###############################################################
Subprog SETCUR(CODECLI, CODEREP, SZRESULT)
Value Char CODECLI
Value Char CODEREP
Variable Char SZRESULT

  # FGR 23/06/2014 : X3SUIVI100941 : prendre la devise dans BPC et REP, plus dans BPR.
  # Attention : S/P qui suppose que le tiers est un client. Ne fonctionne donc que dans le support/client
  #             ou les affaires.
  If SZRESULT <> "" Then
    End
  Endif
  #If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  #Affecte les valeurs souhaitées
  If CODECLI <> "" Then
    #Read [BPR]BPR0=CODECLI
    Read [BPC]BPC0=CODECLI
    If !fstat Then
      #SZRESULT = [F:BPR]CUR
      SZRESULT = [F:BPC]CUR
    Endif
  Endif
  If SZRESULT = "" Then
    If CODEREP <> "" Then
      If !clalev([F:REP]) : Local File SALESREP [REP] : Endif
      #Read [BPR]BPR0=CODEREP
      Read [REP]REP0=CODEREP
      If !fstat Then
        #SZRESULT = [F:BPR]CUR
        SZRESULT = [F:REP]CUR
      Endif
    Endif
  Endif
End

################################################################################################
# Retourne la durée de travail (format HHMM) écoulée entre deux dates avec heure debut et fin. #
################################################################################################
Subprog GET_DUREE_DT_HO(ITYPE, SZAUSCOD, SZFCY, SZTPSMAX, IDATDEB, IZHOUDEB, IDATFIN, IZHOUFIN, SZDUR)
Value Integer ITYPE
Value Char SZAUSCOD
Value Char SZFCY
Value Char SZTPSMAX  # Format éventuellement imposé par la taille du champs (ex. : "9900" HHMM)
Value Date IDATDEB
Value Char IZHOUDEB
Value Date IDATFIN
Value Char IZHOUFIN
Variable Char SZDUR

  #--------------------------------------------
  # Signification de SZAUSCOD selon ITYPE
  # ITYPE = 0 : Pas de schéma on prend tj LMMJV : 08:00-12:00 14:00-18:00
  #         1 : Utilisateur
  #         2 : Schéma hebdomadaire directement
  #         3 : On pourrait imaginer les tiers (fournisseurs, prestataires). Mais ils n'ont pas de schéma hebdomadaire.
  #--------------------------------------------
Local Char SZDIAHOU(100)
Local Integer ISCHOUROK

Local Date DATCAL

Local Integer IWKDFLG
Local Integer IMAXFORDIH
Local Integer VALDATCAL
Local Integer NI
Local Integer INBHOU
Local Integer INBMIN

Local Char    SZHOUDEB(GLONHM)    # Heure debut en chaîne
Local Char    SZHOUFIN(GLONHM)    # Heure fin en chaîne
Local Decimal DECCUMTPS           # Cumul temps : Heure,minutes en centième
Local Char    SZCUPTPS(10)        # Cumul temps converti en heure minutes

Local Integer IHOUDB              # heure début retenue                         09 Heure
Local Integer IMINDB              # minutes début retenue                       30 minutes
Local Decimal DECHOCTDB           # heure,minutes début retenue en centième      9.50 (en centième)
Local Integer IHOUFN              # heure fin retenue
Local Integer IMINFN              # minutes fin retenue
Local Decimal DECHOCTFN           # heure,minutes fin retenue en centième

  # FGR 04/09/2008 : X3SUIVI33081 : en tenant compte du schéma horaire de l'intervenant
  Local File AUTILIS [AUS]
  Local File DIAHOU [DIH]
  Local File TABWEEDIA [TWD]
  Local File FACILITY [FCY]
  #
  Raz [DIH]
  Raz [TWD]
  Raz SZDUR
  #----------------------------------------------------------------
  If ITYPE = 1 Then
    # Utilisateur
    Read [AUS]CODUSR=SZAUSCOD
    If fstat Then
      End
    Endif
    # Récupération du schéma horaire
    Call PARAMUTIL("AUSCRMH", SZDIAHOU, SZAUSCOD, "") From SUBAUS
  Elsif ITYPE = 2 Then
    # Schéma hebdomadaire
    SZDIAHOU = SZAUSCOD
  Else
    SZDIAHOU = ""
  Endif
  #----------------------------------------------------------------
  If SZDIAHOU <> "" Then
    Read [TWD]TWD0=SZDIAHOU
    If fstat Then
      ISCHOUROK = 0
    Else
      ISCHOUROK = 1
    Endif
  Else
    ISCHOUROK = 0
  Endif
  #----------------------------------------------------------------
  If ISCHOUROK = 0 Then
    # S'il n'y a pas de schéma horaire, on en crée "un faux" qui ne sera pas enregistré, et alimenté ainsi :
    #   - Journées de travail : en fonction des jours ouvrés indiqués au niveau du site.
    #                           S'il n'y a pas de site : lundi, mardi, mercredi, jeudi, vendredi
    #   - Schéma horaire unique : 8h00-12h00 14h00-18h00 (8 heures)
    # Ca permet d'utiliser le même programme pour calculer le temps
    # Je charge les classes [F:xxx] mais je ne les enregistre pas
    # On initialise les durée quotidienne en fonction des jours ouvrés indiqués sur le site
    Raz [F:DIH]               # FGR 27/01/2011 : X3SUIVI70826
    [F:DIH]NUM = "XXX"        # Ca permet de ne pas declencher le Read [DIH]... ci-dessous
    [F:DIH]STRHOU(0) = "0800"
    [F:DIH]ENDHOU(0) = "1200"
    [F:DIH]STRHOU(1) = "1400"
    [F:DIH]ENDHOU(1) = "1800"
    #
    If SZFCY <> "" and ITYPE <> 0 Then
      Read [FCY]FCY0=SZFCY
    Endif
    If fstat or SZFCY = "" or ITYPE = 0 Then
      Raz [F:TWD]             # FGR 27/01/2011 : X3SUIVI70826
      #For NI = 0 To 5        # FGR 27/01/2011 : X3SUIVI70826
      For NI = 0 To 4         # FGR 27/01/2011 : X3SUIVI70826
        [F:TWD]DIAHOU(NI) = [F:DIH]NUM
      Next NI
    Else
      For NI = 0 To dim([F:FCY]UVYDAY)-1
        If [F:FCY]UVYDAY(NI) = 2 Then
          [F:TWD]DIAHOU(NI) = [F:DIH]NUM
        Else
          [F:TWD]DIAHOU(NI) = ""
        Endif
      Next NI
    Endif
  Endif
  #----------------------------------------------------------------
  DECCUMTPS = 0
  DATCAL = IDATDEB
  While DATCAL <= IDATFIN
    # On regarde s'il travaille à cette date (s'il faut le faire c'est là qu'on le mettra)
    If 1=1 Then
      # Oui : on compte les heures
      VALDATCAL = dayn(DATCAL)-1   # Indice de [F:TWD]DIAHOU
      If [F:TWD]DIAHOU(VALDATCAL) <> "" Then
        #############################################################################################
        # Il y a un schéma horaire indiqué
        If [F:TWD]DIAHOU(VALDATCAL) <> [F:DIH]NUM Then
          # On ne lit DIH que s'il est différent de celui actuel
          Read [DIH]DIH0=[F:TWD]DIAHOU(VALDATCAL)
        Endif
        IMAXFORDIH = dim([F:DIH]ENDHOU)-1
        #############################################################################################
        # La on cherche les heures début et fin de la journée DATCAL par rapport à IDATDEB et IDATFIN
        If DATCAL = IDATDEB Then
          # C'est le premier jour : on prend l'heure début passée
          SZHOUDEB = IZHOUDEB
        Else
          # Les jours suivants on prend le début de la journée du schéma horaire
          SZHOUDEB = [F:DIH]STRHOU(0)
        Endif
        #
        If DATCAL = IDATFIN Then
          # C'est le dernier jour : on prend l'heure de fin passée
          SZHOUFIN = IZHOUFIN
        Else
          # Sinon on prend l'heure de fin de la journée du schéma horaire
          For NI = 0 To IMAXFORDIH
            If [F:DIH]ENDHOU(NI) = "" Then
              Break
            Else
              SZHOUFIN = [F:DIH]ENDHOU(NI)
            Endif
          Next NI
        Endif
        #############################################################################################
        # Là on calcul le temps travaillé pour la journée DATCAL et on le cumul
        For NI = 0 To IMAXFORDIH
          If [F:DIH]ENDHOU(NI) = "" Then
            Break
          Else
            # FGR 23/03/2011 X3SUIVI72593 (début)
            If SZHOUDEB >= [F:DIH]ENDHOU(NI) and SZHOUFIN <= [F:DIH]STRHOU(NI+1) Then
              # si l'heure de début est >= à l'heure de fin de la tranche et que l'heure de fin est <= à l'heure
              # de début de la tranche suivante, c'est que l'intervention à lieu dans une période non travaillée.
              # => on ne calcul donc rien le temps est à zéro.
              Break
            Endif
            # FGR 23/03/2011 X3SUIVI72593 (fin)
            If SZHOUDEB > [F:DIH]ENDHOU(NI) Then  # FGR 27/01/2011 : X3SUIVI70826
              # Si l'heure de début n'est pas dans la tranche traitée, on ne fait rien
            Else
              If [F:DIH]STRHOU(NI) > SZHOUDEB Then
                # Si l'heure de debut de la tranche horaire NI est supérieure à l'heure de début de travail de la journée
                # le calcul du temps commence à partir du debut de la tranche ([F:DIH]STRHOU(NI))
                IHOUDB = val(left$([F:DIH]STRHOU(NI),2))
                IMINDB = val(mid$([F:DIH]STRHOU(NI),3,2))
              Else
                # Sinon, le calcul du temps commence à partir du début de travail de la journée (SZHOUDEB)
                IHOUDB = val(left$(SZHOUDEB,2))
                IMINDB = val(mid$(SZHOUDEB,3,2))
              Endif
              DECHOCTDB = IHOUDB + (IMINDB / 60)
              #
              If [F:DIH]ENDHOU(NI) < SZHOUFIN Then
                # Si l'heure de debut de la tranche horaire NI est inférieure à l'heure de fin de travail de la journée
                # le calcul du temps fini à la fin de la tranche ([F:DIH]ENDHOU(NI))
                IHOUFN = val(left$([F:DIH]ENDHOU(NI),2))
                IMINFN = val(mid$([F:DIH]ENDHOU(NI),3,2))
              Else
                # Sinon, le calcul du temps fini à la fin du travail de la journée (SZHOUDEB)
                IHOUFN = val(left$(SZHOUFIN,2))
                IMINFN = val(mid$(SZHOUFIN,3,2))
              Endif
              DECHOCTFN = IHOUFN + (IMINFN / 60)
              #----------------------------------------------
              DECCUMTPS = DECCUMTPS + (DECHOCTFN - DECHOCTDB)
              #----------------------------------------------
              If [F:DIH]ENDHOU(NI) >= SZHOUFIN Then
                # Si l'heure de fin de la tranche du schéma horaire est supérieure ou égale à l'heure de fin de travail
                # de la journée travaillée, on arrête. Pas la peine de regarder les autres tranches horaires
                Break
              Endif
              # FGR 23/03/2011 : X3SUIVI72593 (début)
              If NI < IMAXFORDIH Then
                If [F:DIH]STRHOU(NI+1) >= SZHOUFIN Then
                  # Si l'heure de début de la trahcne suivante est supérieure à l'heure de fin de l'intervention
                  # on s'arrête là.
                  Break
                Endif
              Endif
              # FGR 23/03/2011 : X3SUIVI72593 (fin)
            Endif
          Endif
        Next NI
        #############################################################################################
      Else
        # S'il n'y en n'a pas c'est qu'il ne travaille pas. On ne fait rien
      Endif
    Else
      # S'il ne travaille pas on ne fait rien
    Endif
    # Suite de la boucle
    DATCAL += 1
  Wend
  ######################################################################
  INBHOU = fix(DECCUMTPS)
  If DECCUMTPS = INBHOU Then
    INBMIN = 0
  Else
    #INBMIN = fix((DECCUMTPS - INBHOU) * 60)      # FGR 27/01/2011 : X3SUIVI70826
    INBMIN = arr((DECCUMTPS - INBHOU) * 60, 1)    # FGR 27/01/2011 : X3SUIVI70826
  Endif
  SZCUPTPS = ""
  If len(SZTPSMAX) = 5 Then
    # FGR 23/07/2014 : X3SUIVI101618
    If INBHOU < 100 and INBHOU > 10 Then
      SZCUPTPS = "0" + num$(INBHOU)
    Elsif INBHOU < 10 Then
      SZCUPTPS = "00" + num$(INBHOU)
    Else
      SZCUPTPS = num$(INBHOU)
    Endif
  Else
    If INBHOU < 10 Then
      SZCUPTPS = "0" + num$(INBHOU)
    Else
      SZCUPTPS = num$(INBHOU)
    Endif
  Endif
  If INBMIN < 10 Then
    SZCUPTPS = SZCUPTPS + "0" + num$(INBMIN)
  Else
    SZCUPTPS = SZCUPTPS + num$(INBMIN)
  Endif
  ######################################################################
  If SZTPSMAX = "" Then
    SZDUR = SZCUPTPS
  Elsif val(SZTPSMAX) >= val(SZCUPTPS) Then  # FGR 16/07/2014 : X3SUIVI101501 Elsif SZTPSMAX >= SZCUPTPS Then
    SZDUR = SZCUPTPS
  Else
    SZDUR = SZTPSMAX
  Endif
End

######################################################################
Subprog GETDUR(IDATDEB, SZHOUDEB, IDATFIN, SZHOUFIN, SZDUR)
Value Integer IDATDEB
Value Char SZHOUDEB
Value Integer IDATFIN
Value Char SZHOUFIN
Variable Char SZDUR

Local Integer I
Local Integer IDUR
Local Integer ISTART
Local Integer ISTOP
Local Integer INBHOU
Local Integer INBMIN
Local Char SZNBHOU(10)
Local Char SZNBMIN(10)

  # ----------------------------------------------
  # FGR 16/03/2012 : X3SUIVI80819 (début)
  # -----------------------
  If IDATFIN = IDATDEB and SZHOUFIN < SZHOUDEB Then
    SZDUR = ""
    End
  Endif
  # -----------------------
  If IDATDEB <> IDATFIN Then    # FGR 04/04/2013 : X3SUIVI88542
    If SZHOUDEB < "0900" Then
      SZHOUDEB = "0900"         # De toute façon la journée commence à 9h00
    Elsif SZHOUDEB > "1800" Then
      SZHOUDEB = "0900"         # On passe au début du jour suivant
      IDATDEB += 1
    Endif
    # -----------------------
    If SZHOUFIN > "1800" Then
      SZHOUFIN = "1800"         # De toute façon la journée termine à 18h00
    Elsif SZHOUFIN < "0900" Then
      SZHOUFIN = "1800"         # On passe à la fin du jour précédent
      IDATFIN -= 1
    Endif
  Endif
  # -----------------------
  If IDATFIN < IDATDEB Then
    SZDUR = "0000"
    End
  Endif
  # FGR 16/03/2012 : X3SUIVI80819 (fin)
  # ----------------------------------------------
  ISTART = IDATDEB + 1
  ISTOP = IDATFIN - 1
  I = ISTART
  INBHOU = 0
  INBMIN = 0
  IDUR = 0
  SZNBHOU = ""
  SZNBMIN = ""
  SZDUR = ""
  # -----------------------
  If IDATDEB = IDATFIN Then
    #If dayn(nday$(IDATDEB)) < 6 Then   # FGR 04/04/2013 : X3SUIVI88542              # FGR 16/03/2012 : X3SUIVI80819
      # Pas les samedis et dimanches
      If val(mid$(SZHOUDEB,3,2)) > val(mid$(SZHOUFIN,3,2)) Then
        # Minutes heure début supérieure à minute heure de fin
        INBHOU = val(left$(SZHOUFIN,2)) - val(left$(SZHOUDEB,2))
        INBHOU -= 1
        INBMIN = 60 - abs((val(mid$(SZHOUDEB,3,2)) - val(mid$(SZHOUFIN,3,2))))
      Elsif val(mid$(SZHOUDEB,3,2)) < val(mid$(SZHOUFIN,3,2)) Then
        # Minutes heure début inférieure à minute heure de fin
        INBHOU = val(left$(SZHOUFIN,2)) - val(left$(SZHOUDEB,2))
        INBMIN = abs(val(mid$(SZHOUFIN,3,2)) - val(mid$(SZHOUDEB,3,2)))
      Elsif val(mid$(SZHOUDEB,3,2)) = val(mid$(SZHOUFIN,3,2)) Then
        # Minutes heure début égale à minute heure de fin
        INBHOU = val(left$(SZHOUFIN,2)) - val(left$(SZHOUDEB,2))
        INBMIN = 0
      Endif
    #Endif
    If INBHOU < 10 Then
      SZNBHOU = "0" + num$(INBHOU)
    Else
      SZNBHOU = num$(INBHOU)
    Endif
    If INBMIN < 10 Then
      SZNBMIN = "0" + num$(INBMIN)
    Else
      SZNBMIN = num$(INBMIN)
    Endif
    SZDUR = SZNBHOU + SZNBMIN
  Else
    #Traitement des heures des jours compris entre les deux dates.
    For I = ISTART To ISTOP
      If dayn(nday$(I)) < 6 Then
        IDUR += 9
      Endif
    Next
    SZDUR = num$(IDUR)
    # -----------------------------------------
    # Traitement des heures de la date de début
    INBHOU = 0                                    # FGR 16/03/2012 : X3SUIVI80819
    INBMIN = 0                                    # FGR 16/03/2012 : X3SUIVI80819
    If dayn(nday$(IDATDEB)) < 6 Then
      # On ignore les samedis et dimanche
      INBHOU = 18 - val(left$(SZHOUDEB,2))
      If val(mid$(SZHOUDEB,3,2)) > 0 Then
        INBHOU -= 1
        INBMIN = 60 - val(mid$(SZHOUDEB,3,2))
      Else
        INBMIN = 0
      Endif
    Endif
    IDUR += INBHOU
    If IDUR < 10 Then
      SZNBHOU = "0" + num$(IDUR)
    Else
      SZNBHOU = num$(IDUR)
    Endif
    If INBMIN < 10 Then
      SZNBMIN = "0" + num$(INBMIN)
    Else
      SZNBMIN = num$(INBMIN)
    Endif
    SZDUR = SZNBHOU + SZNBMIN
    # -----------------------------------------
    #Traitement des heures de la date de fin
    INBHOU = 0                                    # FGR 16/03/2012 : X3SUIVI80819
    If dayn(nday$(IDATFIN)) < 6 Then
      # On ignore les samedis et dimanche
      If val(left$(SZHOUFIN,2)) >= 9 Then         # FGR 16/03/2012 : X3SUIVI80819
        INBHOU = val(left$(SZHOUFIN,2)) - 9
        INBMIN += val(mid$(SZHOUFIN,3,2))
        If INBMIN > 59 Then
          INBHOU += 1
          INBMIN = INBMIN - 60
        Endif
      Endif
      IDUR += INBHOU
      If IDUR < 10 Then
        SZNBHOU = "0" + num$(IDUR)
      Else
        SZNBHOU = num$(IDUR)
      Endif
      If INBMIN < 10 Then
        SZNBMIN = "0" + num$(INBMIN)
      Else
        SZNBMIN = num$(INBMIN)
      Endif
      SZDUR = SZNBHOU + SZNBMIN
    Endif
  Endif
  If val(SZNBHOU) > 99 Then
    SZDUR = "9900"
  Endif
End

##########################################################################################################
# Retourne une heure augmentée du nombre de minutes indiquées #
###############################################################
Subprog GETNEWHOUR(SZHOU, INBMIN, SZNEWHOU)
Value Char SZHOU
Value Integer INBMIN
Variable Char SZNEWHOU
Local Integer INBHOU
Local Integer IREMMIN
Local Integer IHOUPART
Local Integer IMINPART
Local Char SZHOUPART(50)
Local Char SZMINPART(50)

  INBHOU = 0
  IREMMIN = 0
  IHOUPART = 0
  IMINPART = 0
  SZHOUPART = ""
  SZMINPART = ""
  If INBMIN < 60 Then
    If (INBMIN + val(mid$(SZHOU, 3, 2))) < 60 Then
      IHOUPART = val(left$(SZHOU, 2))
      IMINPART = INBMIN + val(mid$(SZHOU, 3, 2))
    Else
      IHOUPART = val(left$(SZHOU, 2)) + 1
      IMINPART = (INBMIN + val(mid$(SZHOU, 3, 2))) - 60
    Endif
  Else
    INBHOU = INBMIN / 60
    IREMMIN = INBMIN - (60 * INBHOU)
    If (IREMMIN + val(mid$(SZHOU, 3, 2))) < 60 Then
      IHOUPART = val(left$(SZHOU, 2)) + INBHOU
      IMINPART = IREMMIN + val(mid$(SZHOU, 3, 2))
    Else
      IHOUPART = val(left$(SZHOU, 2)) + INBHOU + 1
      IMINPART = (IREMMIN + val(mid$(SZHOU, 3, 2))) - 60
    Endif
  Endif
  If IHOUPART < 10 Then
    SZHOUPART = "0" + num$(IHOUPART)
    If IHOUPART = 0 Then
      SZHOUPART = "00"
    Endif
  Else
    SZHOUPART = num$(IHOUPART)
  Endif
  If IMINPART < 10 Then
    SZMINPART = "0" + num$(IMINPART)
    If IMINPART = 0 Then
      SZMINPART = "00"
    Endif
  Else
    SZMINPART = num$(IMINPART)
  Endif
  SZNEWHOU = SZHOUPART + SZMINPART
End

##########################################################################################################
# Retourne la nature du tiers en clair en fonction d'une priorité arbitraire #
##############################################################################
Subprog GETBPRTYP(SZBPRNUM, SZBPRTYP, SZBPXAOB)
Value Char SZBPRNUM
Variable Char SZBPRTYP
Variable Char SZBPXAOB    # FGR 05/04/2011 : X3SUIVI72615

  #Priorité rétenue :
  #Tiers divers
  #Transporteur
  #Représentant
  #Prestataire
  #Fournisseur
  #Donneur d'ordre
  #Prospect/Client
  SZBPXAOB = "BPR"
  If SZBPRNUM = "" Then
    SZBPRTYP = mess(142,121,1)
    End
  Endif
  Local File BPARTNER [BPR]
  Read [BPR]BPR0=SZBPRNUM
  If fstat Then
    SZBPRTYP = mess(142,121,1)
    End
  Endif
  If [F:BPR]BPRACC = 2 : SZBPRTYP = mess(6,277,1)   :                    Endif   #Tiers divers
  If [F:BPR]BPTFLG = 2 : SZBPRTYP = mess(3,277,1)   : SZBPXAOB = "BPT" : Endif   #Transporteur
  If [F:BPR]REPFLG = 2 : SZBPRTYP = mess(5,277,1)   : SZBPXAOB = "REP" : Endif   #Représentant
  If [F:BPR]PRVFLG = 2 : SZBPRTYP = mess(238,196,1) :                    Endif   #Prestataire
  If [F:BPR]BPSFLG = 2 : SZBPRTYP = mess(2,277,1)   : SZBPXAOB = "BPS" : Endif   #Fournisseur
  If [F:BPR]DOOFLG = 2 : SZBPRTYP = mess(239,196,1) :                    Endif   #Donneur d'ordre
  If [F:BPR]PPTFLG = 2 : SZBPRTYP = mess(240,196,1) : SZBPXAOB = "BPP" : Endif   #Prospect
  If [F:BPR]BPCFLG = 2 : SZBPRTYP = mess(1,277,1)   : SZBPXAOB = "BPC" : Endif   #Client
  If SZBPRTYP = "" Then
    SZBPRTYP = mess(142,121,1)
  Endif
  Close Local File [BPR]
End

##########################################################################################################
#Programme de renvoi du statut de clôture d'une étape avant-vente d'affaire  #
##############################################################################
Subprog GETCLOSTAT(CODELIB, LIB)
Value Char CODELIB
Variable Integer LIB

  LIB = 0
  Local File ATABDIV [ADI]
  Read [ADI]CODE=400;CODELIB
  If !fstat Then
    If [F:ADI]N1 = 2 Then
      LIB = 1
    Endif
  Endif
End

##########################################################################################################
# Retourne le nombre de jours et d'heures travaillées par un collaborateur entre deux dates #
#############################################################################################
Subprog GETWORKDAY(SZREPCOD, SZAUSCOD, DDEBDAT, DENDDAT, INBWDAY, INBWHOU, IOK)
Value Char SZREPCOD
Value Char SZAUSCOD
Value Date DDEBDAT
Value Date DENDDAT
Variable Integer INBWDAY
Variable Integer INBWHOU
Variable Integer IOK

Local Char SZFULTIM(50)
Local Integer IFULTIM
Local Char SZDIAHOU(50)
Local Integer IWKDFLG
Local Integer IOPGSTR
Local Integer IOPGEND
Local Integer ID
Local Integer IK
Local Integer IDAYWEE
Local Date DCURDAT

  IOK = 1
  Local File AUTILIS [AUS]
  Local File DIAHOU [DIH]
  Local File TABWEEDIA [TWD]
  #
  IOPGSTR = nday(DDEBDAT)
  IOPGEND = nday(DENDDAT)
  ID = 0
  IK = 0
  DCURDAT = DDEBDAT
  IDAYWEE = 0
  IWKDFLG = 0
  #
  Read [AUS]CODUSR=SZAUSCOD
  If fstat Then
    IOK = 0
    End
  Endif
  Call PARAMUTIL("AUSCRMG", SZFULTIM, SZAUSCOD, "") From SUBAUS
  If SZFULTIM = "" Then
    IFULTIM = 1
  Else
    IFULTIM = val(SZFULTIM)
  Endif
  Call PARAMUTIL("AUSCRMH", SZDIAHOU, SZAUSCOD, "") From SUBAUS
  INBWDAY = 0
  INBWHOU = 0
  #Calcul du nombre de jours travaillés pendant l'opération.
  If IFULTIM = 2 Then
    For ID = IOPGSTR To IOPGEND
      IDAYWEE = dayn(DCURDAT)
      If IDAYWEE < 6 Then
        IWKDFLG = 1
        Call CHECKNOTWKD(SZREPCOD, DCURDAT, IWKDFLG, IOK)
        If IWKDFLG Then
          INBWDAY += 1
          INBWHOU += 9
        Endif
      Endif
      DCURDAT = DCURDAT + 1
    Next
  Else
    If SZDIAHOU = "" Then
      For ID = IOPGSTR To IOPGEND
        IDAYWEE = dayn(DCURDAT)
        If IDAYWEE < 6 Then
          IWKDFLG = 1
          Call CHECKNOTWKD(SZREPCOD, DCURDAT, IWKDFLG, IOK)
          If IWKDFLG Then
            INBWDAY += 1
            INBWHOU += 8
          Endif
        Endif
        DCURDAT = DCURDAT + 1
      Next
    Else
      Read [TWD]TWD0=SZDIAHOU
      If fstat Then
        For ID = IOPGSTR To IOPGEND
          IDAYWEE = dayn(DCURDAT)
          If IDAYWEE < 6 Then
            IWKDFLG = 1
            Call CHECKNOTWKD(SZREPCOD, DCURDAT, IWKDFLG, IOK)
            If IWKDFLG Then
              INBWDAY += 1
              INBWHOU += 9
            Endif
          Endif
          DCURDAT = DCURDAT + 1
        Next
      Else
        For ID = IOPGSTR To IOPGEND
          IDAYWEE = dayn(DCURDAT)
          If [F:TWD]DAYCAP(IDAYWEE - 1) > 0 Then
            IWKDFLG = 1
            Call CHECKNOTWKD(SZREPCOD, DCURDAT, IWKDFLG, IOK)
            If IWKDFLG Then
              INBWHOU += [F:TWD]DAYCAP(IDAYWEE - 1)
              INBWDAY += 1
            Endif
          Endif
          DCURDAT = DCURDAT + 1
        Next
      Endif
    Endif
  Endif
End

##########################################################################################################
# Vérifie si un répresentant travaille à une date donnée #
##########################################################
Subprog CHECKNOTWKD(SZREP, DDATE, IWORKED, IERRINF)
Value Char SZREP
Value Date DDATE
Variable Integer IWORKED
Variable Integer IERRINF

  IWORKED = 1
  If SZREP = "" Then
    End
  Endif
  If DDATE = [00/00/00] Then
    End
  Endif

Local Integer ITER
Local Char SZFCY(GLONFCY)

  Local File AFCTFCT [AFT]
  Local File AUTILIS [AUS]
  Local File TABUNAVAIL [TUV]
  Local File FACILITY [FCY]
  Local File SALESREP [REP]
  Local File BAPPOINT [BAP]
  Local File ATABDIV [ADI]
  #
  SZFCY = ""
  #On vérifie les indisponibilité liées au site
  Read [REP]REP0=SZREP
  If !fstat Then
    If [F:REP]FCY = "" Then
      If [F:REP]AUSNUM <> "" Then
        Read [AUS]CODUSR=[F:REP]AUSNUM
        If !fstat Then
          If [F:AUS]PRFFCT <> "" Then
            Read [AFT]AFT0=[F:AUS]PRFFCT
            If !fstat Then
              SZFCY = [F:AFT]FCYDEF(4)
            Endif
          Endif
        Endif
      Endif
    Else
      SZFCY = [F:REP]FCY
    Endif
  Endif
  If SZFCY <> "" Then
    Read [FCY]FCY0=SZFCY
    If !fstat Then
      If [F:FCY]UVYCOD <> "" Then
        Read [TUV]UVY0=[F:FCY]UVYCOD
        If !fstat Then
          For ITER = 0 To dim([F:TUV]UVYSTRDAT)-1
            If [F:TUV]UVYSTRDAT(ITER) <> [00/00/00] Then
              If [F:TUV]UVYSTRDAT(ITER) <= DDATE Then
                If [F:TUV]UVYENDDAT(ITER) >= DDATE Then
                  IWORKED = 0
                Endif
              Endif
            Endif
            If IWORKED = 0 Then
              Break
            Endif
          Next
        Endif
      Endif
    Endif
  Endif
  If IWORKED = 0 Then
    End
  Endif
  #On vérifie ses absences déclarées via rendez-vous.
  #RDV en date fixe
  Filter [BAP] Where [F:BAP]APTDAT <= DDATE and [F:BAP]APTDATEND >= DDATE and [F:BAP]APTDAT <> [00/00/00]
  For [BAP] Hint Key APP2
    For ITER = 0 To dim([F:BAP]APTREPNUM)-1
      If [F:BAP]APTREPNUM(ITER) <> "" Then
        If [F:BAP]APTREPNUM(ITER) = SZREP Then
          If [F:BAP]APTTYP <> "" Then
            Read [ADI]CODE=433;[F:BAP]APTTYP
            If !fstat Then
              If [F:ADI]N1 = 2 Then
                IWORKED = 0
              Endif
            Endif
          Endif
          Break
        Endif
      Endif
    Next
    If IWORKED = 0 Then
      Break
    Endif
  Next
  Filter [BAP]
End

##########################################################################################################
# Vérifie les périodes d'indisponibilité #
##########################################
Subprog CHKTUVNOTWKD(SZREP, DDATE, IWORKED, SZUVYNAM, SZUVYCOD, IERRINF)
Value Char SZREP
Value Date DDATE
Variable Integer IWORKED
Variable Char SZUVYNAM
Variable Char SZUVYCOD
Variable Integer IERRINF

  IWORKED = 1
  SZUVYNAM = ""
  If SZREP = "" Then
    End
  Endif
  If DDATE = [00/00/00] Then
    End
  Endif

Local Integer ITER
Local Char SZFCY(GLONFCY)

  Local File AFCTFCT [AFT]
  Local File AUTILIS [AUS]
  Local File TABUNAVAIL [TUV]
  Local File FACILITY [FCY]
  Local File SALESREP [REP]
  #
  SZFCY = ""
  #On vérifie les indisponibilité liées au site
  Read [REP]REP0=SZREP
  If !fstat Then
    If [F:REP]FCY = "" Then
      If [F:REP]AUSNUM <> "" Then
        Read [AUS]CODUSR=[F:REP]AUSNUM
        If !fstat Then
          If [F:AUS]PRFFCT <> "" Then
            Read [AFT]AFT0=[F:AUS]PRFFCT
            If !fstat Then
              SZFCY = [F:AFT]FCYDEF(4)
            Endif
          Endif
        Endif
      Endif
    Else
      SZFCY = [F:REP]FCY
    Endif
  Endif
  If SZFCY <> "" Then
    Read [FCY]FCY0=SZFCY
    If !fstat Then
      If [F:FCY]UVYCOD <> "" Then
        Read [TUV]UVY0=[F:FCY]UVYCOD
        If !fstat Then
          For ITER = 0 To dim([F:TUV]UVYSTRDAT)-1
            If [F:TUV]UVYSTRDAT(ITER) <> [00/00/00] Then
              If [F:TUV]UVYSTRDAT(ITER) <= DDATE Then
                If [F:TUV]UVYENDDAT(ITER) >= DDATE Then
                  SZUVYCOD = [F:TUV]UVYCOD
                  SZUVYNAM = [F:TUV]UVYNAM(ITER)
                  IWORKED = 0
                Endif
              Endif
            Endif
            If IWORKED = 0 Then
              Break
            Endif
          Next
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
# Retourne le prochain jour travaillé d'un collaborateur à partir de la date indiquée #
#######################################################################################
Subprog GETNEXTWDAY(SZREPCOD, SZAUSCOD, DDAY, DNEXDAY, IOK)
Value Char SZREPCOD
Value Char SZAUSCOD
Value Date DDAY
Variable Date DNEXDAY
Variable Integer IOK

Local Char SZFULTIM(50)
Local Integer IFULTIM
Local Char SZDIAHOU(50)
Local Integer INUMDAY
Local Integer IWKDDAY(7)
Local Integer ITOTWDAY
Local Integer I
Local Integer DNEXFDAY
Local Integer IWKDFLG
Local Date DWDATE
Local Integer ILOOPSECURE

  IOK = 1
  ILOOPSECURE = 0
  IWKDFLG = 0
  DWDATE = DDAY + 1
  INUMDAY = 0
  DNEXFDAY = 0
  ITOTWDAY = 0
  Raz IWKDDAY

  Local File AUTILIS [AUS]
  Local File DIAHOU [DIH]
  Local File TABWEEDIA [TWD]
  Read [AUS]CODUSR=SZAUSCOD
  If fstat Then
    IOK = 0
    End
  Endif
  Call PARAMUTIL("AUSCRMG", SZFULTIM, SZAUSCOD, "") From SUBAUS
  If SZFULTIM = "" Then
    IFULTIM = 1
  Else
    IFULTIM = val(SZFULTIM)
  Endif
  Call PARAMUTIL("AUSCRMH", SZDIAHOU, SZAUSCOD, "") From SUBAUS
  #Obtient le jour de la semaine passé en paramètre
  INUMDAY = dayn(DDAY)
  #Obtient la liste des jours travaillés pour le collaborateur
  If IFULTIM = 2 Then
    IWKDDAY(0) = 1
    IWKDDAY(1) = 1
    IWKDDAY(2) = 1
    IWKDDAY(3) = 1
    IWKDDAY(4) = 1
    IWKDDAY(5) = 0
    IWKDDAY(6) = 0
  Else
    If SZDIAHOU = "" Then
      IWKDDAY(0) = 1
      IWKDDAY(1) = 1
      IWKDDAY(2) = 1
      IWKDDAY(3) = 1
      IWKDDAY(4) = 1
      IWKDDAY(5) = 0
      IWKDDAY(6) = 0
    Else
      Read [TWD]TWD0=SZDIAHOU
      If fstat Then
        IWKDDAY(0) = 1
        IWKDDAY(1) = 1
        IWKDDAY(2) = 1
        IWKDDAY(3) = 1
        IWKDDAY(4) = 1
        IWKDDAY(5) = 0
        IWKDDAY(6) = 0
      Else
        For I = 0 To dim(IWKDDAY)-1
          If [F:TWD]DAYCAP(I) > 0 Then
            IWKDDAY(I) = 1
          Endif
        Next
      Endif
   Endif
  Endif
  #Vérifie s'il y a un moins un jour travaillé
  For I = 0 To dim(IWKDDAY)-1
    If IWKDDAY(I) <> 0 Then
      ITOTWDAY += 1
    Endif
  Next
  If ITOTWDAY = 0 Then
    IOK = 0
    End
  Endif
  While !IWKDFLG
    #Vérifie si DWDATE est un jours travaillé dans le schéma hebdomadaire
    If IWKDDAY(dayn(DWDATE)-1) > 0 Then
      Call CHECKNOTWKD(SZREPCOD, DWDATE, IWKDFLG, IOK)
      If IWKDFLG Then
        DNEXDAY = DWDATE
      Endif
    Endif
    DWDATE = DWDATE + 1
    If ILOOPSECURE >= 50000 Then
      Gosub OUTLOOP
      Break
    Endif
    ILOOPSECURE += 1
  Wend
End

##########################################################################################################
$OUTLOOP
  #Obtient le prochain jour travaillé sans tenir compte des absences et jours fériés
  I = INUMDAY
  If I >= 6 Then
    I = 0
  Endif
  While IWKDDAY(I) = 0
    I += 1
    If I = 6 Then
      I = 0
    Endif
  Wend
  DNEXFDAY = I + 1
  #Il n'y a qu'un jour travaillé dans la semaine.
  If DNEXFDAY = INUMDAY Then
    DNEXDAY = DDAY + 7
    Return
  Endif
  If DNEXFDAY > INUMDAY Then
    DNEXDAY = DDAY + (DNEXFDAY - INUMDAY)
    Return
  Endif
  If DNEXFDAY < INUMDAY Then
    DNEXDAY = DDAY + (7 - INUMDAY) + DNEXFDAY
    Return
  Endif
Return

##########################################################################################################
# Retourne le nombre d'appels programmés pour un représentant pour une date précise. #
######################################################################################
Subprog GETNBCLLDAY(SZREPCOD, DDAY, INBCLL)
Value Char SZREPCOD
Value Date DDAY
Variable Integer INBCLL

  Local File PHONECALL [CLL]
  INBCLL = 0
  Filter [CLL] Where [F:CLL]CLLDATX = DDAY and [F:CLL]CLLREP = SZREPCOD and [F:CLL]CLLTYP = 2 and [F:CLL]CLLDON <> 2
  For [CLL]
    INBCLL += 1
  Next
  Filter [CLL]
End

##########################################################################################################
# Retire l'extension d'un nom de fichier. #
###########################################
Subprog REMTPLEXT(SZTPLNAM, SZNEWNAM)
Value Char SZTPLNAM
Variable Char SZNEWNAM

  # FGR 23/12/2013 : X3SUIVI92373
  Raz SZNEWNAM
  If SZTPLNAM <> "" Then
    SZNEWNAM = left$(SZTPLNAM, instr(0, SZTPLNAM, ".")-1)
  Endif
End

##########################################################################################################
# Ajoute l'extension .rpt à un nom de fichier. #
################################################
Subprog ADDTPLEXT(SZTPLNAM, SZNEWNAM)
Value Char SZTPLNAM
Variable Char SZNEWNAM

Local Char UPTPLNAM(type(SZTPLNAM)-10)

  UPTPLNAM = toupper(SZTPLNAM)
  SZNEWNAM = UPTPLNAM + ".rpt"
End

##########################################################################################################
# Ajoute une extension à un nom de fichier. #
#############################################
Subprog ADDTPLEXT2(SZFILEEXT, SZTPLNAM, SZNEWNAM)
Value Char SZFILEEXT
Value Char SZTPLNAM
Variable Char SZNEWNAM

Local Char UPTPLNAM(type(SZTPLNAM)-10)

  UPTPLNAM = toupper(SZTPLNAM)
  SZNEWNAM = UPTPLNAM + SZFILEEXT
End

##########################################################################################################
# Informe si le module Action commerciale a été installé pour le dossier en cours. #
####################################################################################
Subprog ISCRMSET(IREP)
Variable Integer IREP

  IREP = 0
  Local File ADOSSIER [ADS]
  Read [ADS]DOSSIER=nomap
  If fstat Then
    IREP = 0
    End
  Endif
  If [F:ADS]MODULE(12) <> 2 Then
    IREP = 0
  Else
    IREP = 1
  Endif
End

##########################################################################################################
# Informe si le module Support client a été installé pour le dossier en cours. #
################################################################################
Subprog ISHDKSET(IREP)
Variable Integer IREP

  IREP = 0
  Local File ADOSSIER [ADS]
  Read [ADS]DOSSIER=nomap
  If fstat Then
    IREP = 0
    End
  Endif
  If [F:ADS]MODULE(11) <> 2 Then
    IREP = 0
 Else
    IREP = 1
  Endif
End


##########################################################################################################
# Défini le site par défaut pour un objet des modules Action commerciale et Support client. #
#############################################################################################
Subprog SETSITECRM(SZMODULE, SZBPC, SZREP, SZSITE)
Value Char SZMODULE   #ACT ou HDK
Value Char SZBPC
Value Char SZREP
Variable Char SZSITE

  #Si un site a déjà été renseigné. On le conserve.
  If SZSITE <> "" Then
    End
  Endif
  #Etape 1 : Le site utilisateur prime sur le reste
  If SZMODULE = "ACT" Then
    If GFCYDEF(13) <> "" Then
      SZSITE = GFCYDEF(13)
    Else
      If GFCYDEF(5) <> "" Then
        SZSITE = GFCYDEF(5)
      Endif
    Endif
  Endif
  If SZMODULE = "HDK" Then
    If GFCYDEF(12) <> "" Then
      SZSITE = GFCYDEF(12)
    Else
      If GFCYDEF(5) <> "" Then
        SZSITE = GFCYDEF(5)
      Endif
    Endif
  Endif
  If SZMODULE = "" Then
    If GFCYDEF(5) <> "" Then
      SZSITE = GFCYDEF(5)
    Endif
  Endif
  If SZSITE <> "" Then
    End
  Endif
  #Etape 2 :Si aucun site utilisateur n'est trouvé, on travaille  avec le représentant
  Local File SALESREP [REP]
  If SZREP <> "" Then
    Read [REP]REP0=SZREP
    If fstat = 0 Then
      SZSITE = [F:REP]FCY
    Endif
  Endif
End

##########################################################################################################
# Défini le site par défaut pour un objet des modules Action commerciale et Support client. #
#############################################################################################
Subprog SITECRMDEF (SZMODULE, SZSITE)
Value Char SZMODULE   #ACT ou HDK
Variable Char SZSITE

  #Si un site a déjà été renseigné. On le conserve.
  If SZSITE <> "" Then
    End
  Endif
  #on affecte le site par défaut de l'utilisateur
  If SZMODULE = "ACT" Then
    If GFCYDEF(13) <> "" Then
      SZSITE = GFCYDEF(13)
    Endif
  Endif
  If SZMODULE = "HDK" Then
    If GFCYDEF(12) <> "" Then
      SZSITE = GFCYDEF(12)
    Endif
  Endif
End

##########################################################################################################
# Défini le site par rapport à celui du représentant suivant le     #
# paramètre CRMREPSIT pour un objet des modules Action commerciale  #
# et Support client.                                                #
#####################################################################
Subprog SITECRMREP (SZMODULE, SZREP, SZSITE)
Value Char SZMODULE   #ACT ou HDK
Value Char SZREP
Variable Char SZSITE

Local Char SZNEWSITE(GLONFCY)
Local Char SZMESS(250)
Local Integer IASK

  SZNEWSITE = ""
  IASK = 0
  SZMESS = ""
  If GCRMREPSIT = 1 Then
    If SZSITE <> "" Then
      End
    Endif
  Endif
  If GCRMREPSIT = 2 or GCRMREPSIT = 3 Then
    If SZREP <> "" Then
      Local File SALESREP [REP]
      Read [REP]REP0=SZREP
      If !fstat Then
        SZNEWSITE = [F:REP]FCY
      Endif
    Endif
  Endif
  If SZNEWSITE = "" Then
    End
  Endif
  If SZSITE = "" Then
    SZSITE = SZNEWSITE
    End
  Endif
  #Affecte les valeurs souhaitées
  Case GCRMREPSIT
    When 2
      If SZNEWSITE <> SZSITE Then
        #On demande si on veut remplacer
        #Voulez-vous remplacer le site par celui du représentant?
        SZMESS = mess(205,177,1)
        Call OUINON(SZMESS, IASK) From GESECRAN
        If IASK = 2 Then
          SZSITE = SZNEWSITE
        Endif
      Endif
    When 3
      If SZNEWSITE <> SZSITE Then
        SZSITE = SZNEWSITE
      Endif
    When Default
      #On ne fait rien
  Endcase
End

##########################################################################################################
# Défini le site par rapport à celui de l'interlocuteur, si il est  #
# associé à un représentant, on prent celui du représentant         #
# sinon site par défaut du module. On gere le paramètre             #
# CRMREPSIT pour un objet des modules Action commerciale            #
# et Support client.                                                #
#####################################################################
Subprog SITECRMINTREP(SZMODULE, SZINTER, SZSITE)
Value Char SZMODULE   #ACT ou HDK
Value Char SZINTER
Variable Char SZSITE

Local Char SZNEWSITE(GLONFCY)
Local Char SZREP(GLONREP)
Local Char SZCHAPITRE(250)
Local Char SZPROFIL(250)
Local Char SZMESS(250)
Local Integer IASK
Local Integer OK

  SZREP = ""
  SZNEWSITE = ""
  SZCHAPITRE = ""
  SZPROFIL = ""
  IASK = 0
  SZMESS = ""
  OK = 0
  If GCRMREPSIT = 1 Then
    If SZSITE <> "" Then
      End
    Endif
  Endif
  Local File AFCTFCT [AFT]
  If GCRMREPSIT = 2 or GCRMREPSIT = 3 Then
    #Recherche du représentant
    Call PARAMUTIL("AUSCRMF",SZREP,SZINTER,SZNEWSITE) From SUBAUS
    If SZREP <> "" Then
      # Il y a un représentant associé, on cherche site def
      If SZREP <> "" Then
        Local File SALESREP [REP]
        Read [REP]REP0=SZREP
        If !fstat Then
          SZNEWSITE = [F:REP]FCY
        Endif
      Endif
    Endif
    If SZNEWSITE = "" Then
      If SZINTER <> "" Then
        Local File AUTILIS [AUS]
        Read [AUS]CODUSR=SZINTER
        If !fstat Then
          SZPROFIL = [F:AUS]PRFFCT
        Endif
        Local File AFCTFCT [AFT]
        If SZMODULE = "ACT" Then
          SZCHAPITRE = "CRM"
        Else
          SZCHAPITRE = SZMODULE
        Endif
        Read [AFT]AFT0=SZPROFIL
        If !fstat Then
          Call DFLCHAP(SZCHAPITRE,SZNEWSITE,OK) From SUBAUS
        Endif
      Endif
    Endif
  Endif
  If SZNEWSITE = "" Then
    End
  Endif
  If SZSITE = "" Then
    SZSITE = SZNEWSITE
    End
  Endif
  #Affecte les valeurs souhaitées
  Case GCRMREPSIT
    When 2
      If SZNEWSITE <> SZSITE Then
        #On demande si on veut remplacer
        #Voulez-vous remplacer le site par celui du représentant?
        SZMESS = mess(205,177,1)
        Call OUINON(SZMESS, IASK) From GESECRAN
        If IASK = 2 Then
          SZSITE = SZNEWSITE
        Endif
      Endif
    When 3
      If SZNEWSITE <> SZSITE Then
        SZSITE = SZNEWSITE
      Endif
    When Default
      #On ne fait rien
  Endcase
End

##########################################################################################################
Funprog GET_SITE_DEFAUT (SZMODULE, SZSITE)
Value Char SZMODULE   #ACT ou HDK
Value Char SZSITE

  # FGR 10/12/2008 : Recupération du site pas défaut selon le module
Local Char ARENDRE(GLONFCY)
Local Integer I
Local Char STBSITE(GLONFCY)(4)
Local Integer NBSITE

  If SZMODULE = "ACT" Then
    # Action commerciale
    STBSITE(0) = GFCYDEF(13)
    STBSITE(1) = GFCYDEF(12)
    STBSITE(2) = GFCYDEF(5)
    NBSITE = 2
  Elsif SZMODULE = "HDK" Then
    # Support client
    STBSITE(0) = GFCYDEF(12)
    STBSITE(1) = GFCYDEF(13)
    STBSITE(2) = GFCYDEF(5)
    NBSITE = 2
  Endif
  If SZSITE = "" Then
    For I = 0 To NBSITE
      If STBSITE(I) <> "" Then
        ARENDRE = STBSITE(I)
        Break
      Endif
    Next
    If ARENDRE = "" Then
      # FGR 16/12/2009 : X3SUIVI60647 : trouver un site de vente
      Call GETFCYDEF(ARENDRE, "[F:FCY]SALFLG=2") From TRTX3
    Endif
  Else
    ARENDRE = SZSITE
  Endif
End ARENDRE

##########################################################################################################
Funprog GET_NUMERO_CHRONO (SZMODULE, SZSITE, SZCODCPT, DDATE, SZCOMP, SZNUM, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZMODULE   #ACT ou HDK
Value Char SZSITE
Value Char SZCODCPT
Value Date DDATE
Value Char SZCOMP
Variable Char SZNUM
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

  # FGR 10/12/2008 : Recupération du chrono centralisée
Local Integer ARENDRE
Local Integer STAT
Local Char SNUMLOCAL(GLONVCR)
Local Char SEXCEPTION(10)

  SEXCEPTION = ""
  If len(SZMODULE) > 3 Then
    # Si SEXCEPTION = "1" : Force l'entrée dans le calcul de NUMERO.
    #SEXCEPTION = right$(SZMODULE, 1+len(SZMODULE)-3)      # Issue X3-52139 - 2017-08-25 by FGR
    SEXCEPTION = right$(SZMODULE, len(SZMODULE))           # Issue X3-52139 - 2017-08-25 by FGR
    SZMODULE = left$(SZMODULE, 3)
  Endif
  #
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  #
  If GMANCOU <> 2 or (GMANCOU = 2 and vireblc(SZNUM, 2) = "") or SEXCEPTION = "1" Then
    ARENDRE = 1
    SZSITE = func GET_SITE_DEFAUT (SZMODULE, SZSITE)
    If DDATE = [0/0/0] Then
      DDATE = date$
    Endif
    #
    Call NUMERO(SZCODCPT, SZSITE, DDATE, SZCOMP, SNUMLOCAL, STAT) From SUBANM
    If STAT = 0 Then
      SZNUM = SNUMLOCAL
    Else
      # problème lors de la récupération du compteur
      IERRINF = 60
      ICHAPTER = 199
      IBRETOUR = 0
    Endif
  Else
    ARENDRE = 0
  Endif
End ARENDRE

##########################################################################################################
Subprog READ_COUNTER(SVALEUR, IMODULE, IND, SCPY, SLEG, SCODE, IMANUAL)
Value Char SVALEUR
Value Integer IMODULE
Value Integer IND
Value Char SCPY
Value Char SLEG
Variable Char SCODE
Variable Integer IMANUAL

Local Integer IOK

  # FGR 20/12/2012 : X3SUIVI71937
  Raz SCODE
  Raz IMANUAL
  If SVALEUR <> "" and SVALEUR <> GFCY Then
    GFCY = SVALEUR
    Call GETSOC(GFCY) From DEVSUB
    Raz SCPY
    Raz SLEG
  Endif
  # ----------------------------------------------------
  Local File TABCOUAFF [TCA]
  # ----------------------------------------------------
  If SCPY <> "" Then
    GSOCIETE = SCPY
  Endif
  If SLEG <> "" Then
    GCURLEG = SLEG
  Endif
  # ----------------------------------------------------
  Call LECTCA(IMODULE, IOK) From SUBTCA
  If fstat or !IOK Then
    GERR = 1
    GMESSAGE = mess(58,105,1) - mess(IMODULE,14,1) -  ":" - mess(250,199,1)
    mkstat = 1
    End
  Endif
  # ----------------------------------------------------
  IMANUAL = [F:TCA]MANCOU(IND)
  SCODE = [F:TCA]CODNUM(IND)
  # ----------------------------------------------------
End

