Gosub DECLARE_VAR From WMC0ACODNUM
[L]CURPRO = "SEQ"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.SEQ=0 and fmet this.AGETATTRIBUTE("SEQ","$isMandatory")="true"
 this.SEQ = 1
Endif
Return
 
$CONTROL_SEQ
Gosub DECLARE_VAR From WMC0ACODNUM
[L]CURPRO = "SEQ"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_SEQ                   : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_SEQ                   : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_SEQ
[L]CURPRO = "SEQ"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.SEQ=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_SEQ
[L]CURPRO = "SEQ"
If this.SEQ<0 or this.SEQ>len(mess(0,932,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"932 ->"-num$(this.SEQ)-mess(99,123,1)):  Return : # Local menu "932 -> Invalid option
Endif
Return

$_AOTHERS_SEQ
[L]CURPRO = "SEQ"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_SEQ
[L]CURPRO = "SEQ"
Return

