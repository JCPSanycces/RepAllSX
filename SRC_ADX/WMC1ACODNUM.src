#<AdxTL>@(#)0.0.0.0 $Revision$Class Doc sequence numbers
# Supervisor
## ACLA-CLASSE ## ACODNUM
# 2018-11-06 07:00:51 541


####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 1 : CODNUM Sequence number ( Field ANM 5)
####################################################################

$SET_CODNUM
If [L]_AOLDVAL<>this.CODNUM
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_CODNUM
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.CODNUM
 Gosub PROPAGATE_CODNUM
Endif
Return

$INIT_CODNUM
Gosub DECLARE_VAR From WMC0ACODNUM
[L]CURPRO = "CODNUM"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_CODNUM
Gosub DECLARE_VAR From WMC0ACODNUM
[L]CURPRO = "CODNUM"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_CODNUM                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_CODNUM                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_CODNUM
[L]CURPRO = "CODNUM"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.CODNUM,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_CODNUM
[L]CURPRO = "CODNUM"
If vireblc(this.CODNUM,2)<>vireblc(format$("K:5B",this.CODNUM),2)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(149,100,1)) :  Return : # Incorrect Format
Endif
Return

$_AOTHERS_CODNUM
[L]CURPRO = "CODNUM"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_CODNUM
[L]CURPRO = "CODNUM"
Return

$PROPAGATE_CODNUM
this.isReadonly = 0
[L]CURPRO = "CODNUM"
Gosub _LNKPRO_CODNUM
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_CODNUM
Gosub DECLARE_VAR From WMC0ACODNUM
[L]CURPRO = "CODNUM"
$_LNKPRO_CODNUM
If vireblc(this.CODNUM,2)<>""
 # Link ACODNUM
 Local File ACODNUM [WANM]
 Read [F:WANM]ANM0 = this.CODNUM
 If !fstat
  Local File ATEXTRA [WAXX]
  Local Char ILAN(GLONLAN)
  For ILAN=this.ACTX.LAN, this.ACTX.AFOLD.ALANGDEF
   For [F:WAXX] Where CODFIC="ACODNUM" & ZONE="DES" & IDENT1=[F:WANM]CODNUM & IDENT2="" & LANGUE = ILAN
    [L]ASTATUS = fmet this.ASETATTRIBUTE("CODNUM","$description",[WAXX]TEXTE)
    Break 2
   Next WAXX
  Next ILAN
  LogicClose File [WAXX]
 Endif
 LogicClose File [WANM]
Endif
Return

$_ALOADATTRIBUTE_CODNUM
[L]ASTATUS = fmet this.ASETATTRIBUTE("CODNUM","$isMandatory","true")
Return


####################################################################
# 2 : DES Description ( Field AX3)
####################################################################

$GET_DES
Gosub DECLARE_VAR From WMC0ACODNUM
[L]CURPRO = "DES"
this.DES = fmet this.AGETTEXTRA(CURPRO)
[L]ARULE = "GET" : [L]ACTION = "GET" : Gosub ACTION From ASYRSUB
Return

$SET_DES
If [L]_AOLDVAL<>this.DES
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_DES
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.DES
 Gosub PROPAGATE_DES
Endif
Return

