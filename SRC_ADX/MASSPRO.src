  #Endif
  #If [M:CTR1]SUICAR = 2 & GREP <> "A"
  #  Raz [F:EPO]
  #  [F:EPO] = [M:CTR1]
  #  [F:EPO] = [M:CTR0]
  #  [F:EPO]DATPOT  = [M:CTR0]CTRDAT
  #  [F:EPO]ORIGINE = 1 : # ML 399 Automatique
  #  Write [EPO]
  #  If fstat
  #   GOK = 0 : Call FSTA("EPO") From GLOCK : Return
  #  Endif
  #Endif
Return

$MAJ_TRAINER
  #If [M:CTR0]FLGVAR=2 : Return : Endif
  If func AFNC.ACTIV("FRT")>0 Then
    Local Integer LFLG_CONTRAT_ENCOURS : LFLG_CONTRAT_ENCOURS = 1

    Filter [F:HRCTR3] Where REFNUM=[M:CTR0]REFNUM and CTRDAT<=date$
&                     and (XITDAT = [0/0/0] or XITDAT >= date$)
&                Order By CTRDAT Asc
    If rowcount([F:HRCTR3]) > 0 Then
      LFLG_CONTRAT_ENCOURS = 2
    Endif
    Filter [F:HRCTR3]
    If LFLG_CONTRAT_ENCOURS = 1 Then
      Filter [F:TRN] Where REFNUM=[M:CTR0]REFNUM and ENAFLG=2
      For [TRN]TRN1
        [F:TRN]ENAFLG=1
        Rewrite [TRN] Curr
        If fstat
          GOK = 0 : Call FSTA("TRN") From GLOCK : Break
        Endif
      Next
      Filter [TRN]
    Endif
  Endif

Return

$MAJ_ESB
Local  Integer L_K

  If !clalev([F:SRV]) : Local File SERVICE [SRV] : Endif
  If !clalev([F:SIT]) : Local File SITEPAYE [SIT] : Endif
  If !clalev([F:WAD]) : Local File EMPLOAD [WAD] : Endif
  If clalev([F:ESB])=0  : Local File EMPSBD [ESB]  : Endif

  Filter [ESB] Where [F:ESB]REFNUM = [M:MPS]REFNUM(L_IJ)
&                & [F:ESB]CTRNUM = [M:MPS]CTRNUM(L_IJ)
&                & [F:ESB]CTRDAT = [M:MPS]CTRDAT(L_IJ)

  #Read [F:ESB]EPO0=[M:MPS]REFNUM(L_IJ);[M:MPS]CTRNUM(L_IJ);1;[M:MPS]CTRDAT(L_IJ)
  [ESB]REFNUM=[HRCTR1]REFNUM
  [ESB]CTRNUM=[HRCTR1]CTRNUM
  [ESB]CTRDAT=[M:MPS]CTRDAT2(L_IJ)

  Write [ESB]
  If fstat <> 0
    [V]GOK = 0
    Call FSTA("CPR") From GLOCK
    Return
  Endif

#If ACTION="ANNULE"
