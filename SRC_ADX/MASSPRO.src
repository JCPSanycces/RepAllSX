######################################################################################
Subprog AM_FLGVAR(VALEUR)
Variable Integer VALEUR
If VALEUR=2 Then
  Actzo [M:MPS]AVTCTRDAT(nolign-1)
  Actzo [M:MPS]AVTCTRGRD(nolign-1)
  Actzo [M:MPS]AVTXITDAT(nolign-1)
  Actzo [M:MPS]AVTXITGRD(nolign-1)
Else
  Grizo [M:MPS]AVTCTRDAT(nolign-1)
  Grizo [M:MPS]AVTCTRGRD(nolign-1)
  Grizo [M:MPS]AVTXITDAT(nolign-1)
  Grizo [M:MPS]AVTXITGRD(nolign-1)
Endif
  Affzo [M:MPS]AVTCTRDAT(nolign-1)
  Affzo [M:MPS]AVTCTRGRD(nolign-1)
  Affzo [M:MPS]AVTXITDAT(nolign-1)
  Affzo [M:MPS]AVTXITGRD(nolign-1)

End

