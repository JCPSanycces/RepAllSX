#    Call AM_XITDAT(VALEUR) From SUBCTRKSA
#  Endif
#Endif
#FRLAA - 2015-05-21 - REQUIREMENT 108198 US 3582 - END
#109374 - Painfullness
#If dim([M:CTRB]FLGEXCPEN) > 0 & [M:CTRB]FLGEXCPEN<>2
# If [M:CTR1]POT<>""
#  [M:CTR8]XITDAT=VALEUR
#  Gosub CHARGE_CPN From SUBCTRKFR
# Endif
#Endif

#MAPAD 2016-08-05 start
#If func ISKMIEA()
#  If func AFNC.ACTIV("KJO") Then
#    Call AS_TAXENDDATMID() From SUBCTRMID
