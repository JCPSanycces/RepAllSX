Subprog AS_AVTXITDAT(VALEUR)
Variable Date   VALEUR

#JASMI - 2017-10-09 - X3-58791 - START
#  If [M:GENMPS]PROSEL = 1  or  func AFNC.ACTIV("KGH") Then
  If [M:GENMPS]PROSEL = 1  or  func DIVPAYE.IS_KGH_LEG(GCURLEG) Then
#JASMI - 2017-10-09 - X3-58791 - END
   If dim([M:MPS]AVTXITDAT) > 0  : Chgfmt [M:MPS]AVTXITDAT   With  "-DZ:"+GFMDAT    :Endif
  Endif

If [L]VALEUR = [0/0/0] : [L]VALEUR = ([M:MPS]AVTCTRDAT(nolign-1)) : Endif

End

Subprog FIND_VAR (PVALEUR,PNUMTAB, PNUMTDS)
Variable Char PVALEUR()
Value Integer PNUMTAB
Value Char PNUMTDS ()

If !clalev([F:ADI])   : Local File ATABDIV    [ADI]  : Endif

  Filter [F:ADI] Where NUMTAB=PNUMTAB & A1=PNUMTDS
  Read[F:ADI]CODE Last
  Filter [F:ADI]
  If !fstat
   PVALEUR=[F:ADI]CODE
  Else
   PVALEUR="VAR" #: au cas où...
  Endif
End

Subprog AS_AVTXITGRD(VALEUR)
Variable Char    VALEUR()
  Call FIND_VAR(VALEUR,359,"096")
End
