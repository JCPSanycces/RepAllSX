######################################################################################
## Section automatically added (screen GENMPS) 09/14/2016 10:18:14 (MAPAD)
######################################################################################
Subprog AM_PROSEL(VALEUR)
Variable Integer VALEUR
  If VALEUR = 1 Then
       If dim([M:GENMPS]SELVAR)>0  : Chgfmt [M:GENMPS]SELVAR   With  "-LA:1"   :  Endif
       If dim([M:GENMPS]DATDEB)>0  : [M:GENMPS]DATDEB=eomonth(GMOIPAY)         : Actzo [M:GENMPS]DATDEB  : Affzo [M:GENMPS]DATDEB: Endif
  Else
       If dim([M:GENMPS]SELVAR)>0  : Chgfmt [M:GENMPS]SELVAR   With  "LA:1"   :  Endif
       If dim([M:GENMPS]DATDEB)>0 and [M:GENMPS]SELVAR=2 Then
         [M:GENMPS]DATDEB=GMOIPAY
         Grizo [M:GENMPS]DATDEB
         Affzo [M:GENMPS]DATDEB
       Endif
  Endif

Affzo [M:GENMPS]SELVAR
End

Subprog AM_SELVAR(VALEUR)
Variable Integer VALEUR
  If [M:GENMPS]PROSEL = 1 Then
       If dim([M:GENMPS]DATDEB)>0  : Actzo [M:GENMPS]DATDEB  : Affzo [M:GENMPS]DATDEB: Endif
  Else
       If VALEUR=2 Then
         [M:GENMPS]DATDEB=GMOIPAY
         Grizo [M:GENMPS]DATDEB
         Affzo [M:GENMPS]DATDEB
         [M:GENMPS]DATFIN =eomonth(GMOIPAY)
         Affzo [M:GENMPS]DATFIN
       Else
#         [M:GENMPS]DATDEB=eomonth(GMOIPAY)
         Actzo [M:GENMPS]DATDEB
         Affzo [M:GENMPS]DATDEB
       Endif
  Endif

End

