######################################################################################

######################################################################################
## Section automatically added (screen MASSPRO) 09/23/2016 10:39:34 (MAPAD)
######################################################################################
Subprog AM_XITDAT(VALEUR)
Variable Date    VALEUR
If [M:MPS]AVTCTRDAT(nolign-1) <> [00/00/00] Then
   If VALEUR > [M:MPS]AVTCTRDAT(nolign-1) Then
      [M:MPS]FLGVAR(nolign-1)=2
      [M:MPS]AVTCTRDAT(nolign-1) = [00/00/00]
      Actzo [M:MPS]AVTCTRDAT(nolign-1),AVTCTRGRD(nolign-1),AVTXITDAT(nolign-1),AVTXITGRD(nolign-1)
      Affzo [M:MPS]FLGVAR(nolign-1),AVTCTRDAT(nolign-1),AVTCTRGRD(nolign-1),AVTXITDAT(nolign-1),AVTXITGRD(nolign-1)
   Endif
Endif
End

