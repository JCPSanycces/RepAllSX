######################################################################################
Subprog AS_XITDAT(VALEUR)
Variable Date    VALEUR
  If [M:GENMPS]PROSEL = 1 Then
   If dim([M:MPS]XITDAT) > 0  : Chgfmt [M:MPS]XITDAT   With  "-DZ:"+GFMDAT    :Endif
  Endif
End

######################################################################################

######################################################################################
## Section automatically added (screen MASSPRO) 09/19/2016 14:39:19 (MAPAD)
######################################################################################
$CONTROLE_TIP2
If clalev([F:TIP])=0  : Local File TIMEMP     [TIP] : Endif
Local Integer W_OK
CRITCTRL="REFNUM='"+[M]REFNUM(nolign-1)+"' & CTRNUM='"+[M]CTRNUM(nolign-1)+"'"
If [M]CTRDAT(nolign-1)<>[0/0/0]
 CRITCTRL-="& (CTRDAT=[0/0/0] | CTRDAT=["+num$([M]CTRDAT(nolign-1))+"])"
# CRITCTRL-="& DATPYR>=["+num$([M]CTRDAT)+"]"
 # BUG90196
 CRITCTRL-="& (DATPYR>=["+num$([M]CTRDAT(nolign-1))+"])"
Endif
If WXITDAT<>[0/0/0]
 CRITCTRL-="& ENDDAT > ["+num$(WXITDAT)+"]"
Endif
Filter [TIP] Where evalue(CRITCTRL)
Read [TIP]TIP2 First
Filter [TIP]
If !fstat
  # Modification : Temps saisi au-delà de la période
  W_OK = 2
  Call AVERTIR (mess(60,123,1)-":"-mess(143,10701,1),W_OK) From GESECRAN
  If W_OK=1 : mkstat = 2 : Return : Endif
Endif
Return

$CONTROLE_PRVPAIE
Local Integer L_OK
If clalev([F:VPR])=0  : Local File VALPRV           [VPR] : Endif
Filter [F:VPR] Where EMP=[M]REFNUM(nolign-1) & CTRNUM=[M]CTRNUM(nolign-1) & CTRDAT=[M]CTRDAT(nolign-1) & DAT>[M]XITDAT(nolign-1) & VARVAL<>0
Read [F:VPR]VPR0 First
Filter [F:VPR]
If !fstat
  L_OK = 2
  #Valeur(s) prévisionnelle(s) existante(s), postérieure(s) au
  Call AVERTIR(mess(153,10701,1)-num$(WXITDAT),L_OK) From GESECRAN
  If L_OK<>2 : mkstat=2 : Return : Endif
Endif

If clalev([F:PPD])=0  : Local File PPREQUESTD       [PPD] : Endif
Filter [F:PPD] Where REFNUM=[M]REFNUM(nolign-1) & CTRNUM=[M]CTRNUM(nolign-1) & CTRDAT=[M]CTRDAT(nolign-1) & APLSTR>WXITDAT  & (DEMAMT<>0 | ACPAMT<>0)
Read [F:PPD]PPD0 First
Filter [F:PPD]
If !fstat
  L_OK = 2
  #Bordereau de prépa-paie existant, postérieur au
  Call AVERTIR(mess(154,10701,1)-num$(WXITDAT),L_OK) From GESECRAN
  If L_OK<>2 : mkstat=2 : Return : Endif
Endif
Return

Subprog AP_XITDAT(VALEUR)
Variable Date    VALEUR

If VALEUR<>[0/0/0] & ([M]XITDAT =[0/0/0] | VALEUR < [M]XITDAT(nolign-1) )
 WXITDAT=VALEUR
 Gosub CONTROLE_TIP2
 If mkstat : End : Endif
 If GPAYE
  Gosub CONTROLE_PRVPAIE
  If mkstat : End : Endif
 Endif
Endif
GRETTIP=1
#If VALEUR=[0/0/0] & [M]XITFNL<>1
