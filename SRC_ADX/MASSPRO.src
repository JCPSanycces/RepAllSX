######################################################################################
Subprog AM_ETRFCY(VALEUR)
Variable Char    VALEUR()

Local Char    CRITCTRL (250), SOC(GLONCPY), VOIDCHAR(250),TEMP(250)
Local Integer OK

  GRETTIP=1

  If clalev([F:ID])=0 : Local File EMPLOID    [F:ID] : Endif
  Filter [F:ID] Where [F:ID]REFNUM = [M:MPS]REFNUM(nolign-1)
  Read [F:ID]ID0 Last

 #ADNGO - 2017-09-08 - START
 #If clalev([F:CTR])=0 : Local File EMPLOCTR[CTR] : Endif
 #Filter [F:CTR] Where REFNUM=[M:MPS]REFNUM(nolign-1) & CTRNUM=[M:MPS]CTRNUM(nolign-1)
  If clalev([F:HRCTR])=0 : Local File EMPLOCTR[HRCTR] : Endif
  Filter [F:HRCTR] Where REFNUM=[M:MPS]REFNUM(nolign-1) & CTRNUM=[M:MPS]CTRNUM(nolign-1)
 #ADNGO - 2017-09-08 - END

  Call LECTURE("FCY",[M:MPS]ETRFCY2(nolign-1),"") From CONTOBJ
  SOC = [F:FCY]LEGCPY

  Call LECTURE("FCY",VALEUR,"") From CONTOBJ

#JASMI - 2017-10-11 - X3-59273 - START
  If [F:FCY]LEG<>GCURLEG
    GMESSAGE = mess(00074,00127,1)
    mkstat = 2 : End
  Endif
#JASMI - 2017-10-11 - X3-59273 - END

  If [F:FCY]LEGCPY<>SOC
    pcolor=GCOUL(1)
#JASMI - 2017-10-11 - X3-59313 - START
#    Affzo [M]ETRFCY(nolign-1)
#JASMI - 2017-10-11 - X3-59313 - END
    Affzo [M]POT(nolign-1)
    Affzo [M]JOBPOT(nolign-1)
    Affzo [M]PROPRF(nolign-1)
    Affzo [M]ETRSRV(nolign-1)
    Affzo [M]CTRGRD(nolign-1)
    Affzo [M]NATCON(nolign-1)
    Affzo [M]CTRDAT2(nolign-1)
    Affzo [M]XITGRD(nolign-1)
  Endif

#  If GREP<>"C" & GREP<>"D" & [F:ID]FLGINT<>2
  #Gosub CONTROLE
#   If mkstat : End : Endif
#     Gosub CONTROLE_TIP
#   If mkstat : End : Endif
#  Endif

  #If func ISKSA()
 #   Call DIFFCPY(VALEUR,OK) # need to clarify if msg up front
  #  If OK = 1 : mkstat = 2 : End : Endif
 # Endif

  GSOCIETE=[F:FCY]LEGCPY :
  [M:MPS]CPY(nolign-1)=[F:FCY]LEGCPY :
  Affzo [M:MPS]CPY(nolign-1)

  #get legislation
  [M:MPS]LEG(nolign-1)=[F:FCY]LEG
  Affzo [M:MPS]LEG(nolign-1)

End

$CONTROLE

Return

$CONTROLE_TIP
  CRITCTRL="REFNUM='"+[M:MPS]REFNUM(nolign-1)+"' & CTRNUM='"+[M:MPS]CTRNUM(nolign-1)+"'"
  If [M:MPS]CTRDAT(nolign-1)<>[0/0/0]
    CRITCTRL-="& (CTRDAT=[0/0/0] | CTRDAT=["+num$([M:MPS]CTRDAT(nolign-1))+"])"
   # BUG90196
   # CRITCTRL-="& DATPYR>=["+num$([M]CTRDAT)+"]"
   #ADNGO - 2017-09-11 - START
   #CRITCTRL-="& ([F:CTR]FLGRET=2 & DATPYR>=["+num$([F:CTR]RETDATEFF)+"] | DATPYR>=["+num$([M:MPS]CTRDAT(nolign-1))+"])"
    CRITCTRL-="& ([F:HRCTR]FLGRET=2 & DATPYR>=["+num$([F:HRCTR]RETDATEFF)+"] | DATPYR>=["+num$([M:MPS]CTRDAT(nolign-1))+"])"
   #ADNGO - 2017-09-11 - END
  Endif
  #ADNGO - 2017-09-11 - START
  #If [F:CTR]XITDAT<>[0/0/0]
  If [F:HRCTR]XITDAT<>[0/0/0]
  #ADNGO - 2017-09-11 - END
   #ADNGO - 2017-09-11 - START
   #CRITCTRL-="& ENDDAT<=["+num$([F:CTR]XITDAT)+"]"
    CRITCTRL-="& ENDDAT<=["+num$([F:HRCTR]XITDAT)+"]"
   #ADNGO - 2017-09-11 - END
  Endif

  If clalev([F:TIP])=0  : Local File TIMEMP     [TIP] : Endif
  Filter [TIP] Where evalue(CRITCTRL)
  Read [TIP]TIP2 First
  Filter [TIP]
  If !fstat
   # Modification impossible : Temps saisis sur la période
   #ADNGO - 2017-09-11 - START
   #GMESSAGE = mess(13,701,1)
    GMESSAGE = mess(13,10701,1)
   #ADNGO - 2017-09-11 - END
    mkstat = 2 : Return
  Endif

Return

$RET_EXTOURNE
  If dim([M:CTRA]FLGRET) > 0 & [M:CTRA]FLGRET = 2 & [M:CTRA]RETTYP = 1
    Local Integer OK_MODIF
    #Avenant au contrat avec retroactivité, le type de retroactivité 'Extourne' est plus approprié à cette modification.
    #Confirmez-vous la modification ?
    Call AVERTIR(mess(97,10701,1)+"\"+mess(180,133,1)-"?", [L]OK_MODIF) From GESECRAN
    If [L]OK_MODIF = 1 : mkstat = 2 : Return : Endif
  Endif

Return

$REFRESH_BULDEM

Return

$REFRESH_CPR
  Gosub REFRESH_CPR From SUBCTR2

Return

Subprog CONTROLE_PAYE(MATRI, CRITERE,COUNTROWS)
Variable Char MATRI ()
Variable Char CRITERE
Variable Integer COUNTROWS

  Raz mkstat
  If GPAYE<>1 : End : Endif
  If clalev([F:VEP])=0  : Local File VALEMP   [VEP]  : Endif
  Filter [F:VEP] Where EMP=MATRI & evalue (CRITERE)
  Read [F:VEP]VEP0 First
  Filter [F:VEP]
  If !fstat : COUNTROWS=1 : Endif
End

Funprog ISKSA()
