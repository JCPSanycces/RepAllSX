Subprog AS_AVTCTRDAT(VALEUR)
Variable Date    VALEUR
#JASMI - 2017-10-09 - X3-58791 - START
#  If [M:GENMPS]PROSEL = 1 or func AFNC.ACTIV("KGH") Then
  If [M:GENMPS]PROSEL = 1 or func DIVPAYE.IS_KGH_LEG(GCURLEG) Then
#JASMI - 2017-10-09 - X3-58791 - END
   If dim([M:MPS]AVTCTRDAT) > 0  : Chgfmt [M:MPS]AVTCTRDAT   With  "-DZ:"+GFMDAT    :Endif
  Endif

If [L]VALEUR = [0/0/0] : [L]VALEUR = ([M:MPS]XITDAT(nolign-1) + 1) : Endif
End
#
#
Subprog C_AVTCTRDAT(VALEUR)
Variable Date  VALEUR
If VALEUR<>[0/0/0] & VALEUR<[M:MPS]XITDAT(nolign-1)
 #La date du nouveau contrat ne peut pas être antérieure à la date de sortie du contrat d'origine
 GMESSAGE=mess(114,10701,1)
 mkstat=2 : End
Endif
End
