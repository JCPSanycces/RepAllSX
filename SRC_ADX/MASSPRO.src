   GOK = 0 : Call FSTA("ESB") From GLOCK : Return
  Endif

Return

######################################################################################
## Section automatically added (screen MASSPRO) 08/25/2016 09:39:02 (MAPAD)
######################################################################################
Subprog B1_ETRFCY(VALEUR)
Variable Char    VALEUR()

Local Integer L_IJ

For L_IJ=nolign-1 To [M]NBLIG-1
 If [M]UPD(L_IJ) = 2
  [M]ETRFCY(L_IJ) = VALEUR
  Actzo [M]ETRFCY(L_IJ)
 Endif
Next L_IJ
Affzo [M]5

End

