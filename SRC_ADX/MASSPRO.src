Subprog B1_CTRDAT2(VALEUR)
Variable Date    VALEUR

Local Integer L_IJ

For L_IJ=nolign-1 To [M]NBLIG-1
 If [M]UPD(L_IJ) = 2
  [M]CTRDAT2(L_IJ) = VALEUR
  Affzo [M]CTRDAT2(L_IJ)
 Endif
Next L_IJ

End

