#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char     PARAM(10)(1..3) , VALEUR(10)

  PARAM(1) = ""
  Call TRAITE_CHAR(VALEUR,PARAM,"MASSPRO","MASSPRO","GENMPS",4,"") From GTRAITE

End

$ACTION
  Case ACTION
    When "INIT"        : Gosub INIT

    When "OUVRE_BOITE" : Gosub OUVRE_BOITE
    When "TITRE"       :
    When "DEBUT"       :
                         If BOITE="MASSPRO"
                          Gosub CHARGE_CRIT
                          Gosub CHARGE_MSK
                         Else
                          Affzo [GENMPS]: Setmok [GENMPS] With 0
                         Endif
                         Gosub DEBUT
    When "OK"          : If BOITE="GENMPS"
                           BOX = 0 : # To keep [M:GENMPS] open
                         Elsif BOITE="MASSPRO"
                           Gosub EXEC
                         Endif
    When "END"         : Raz [M:GENMPS]
                             #Raz [M:MPS]#FIN = 1
    When "CONTROLE"    : Gosub CONTROLE
                         If GSTATUT<>GSTAOK
                         # To exit If End button is activated on criteria window
                          FIN = 1
                         Endif
    When "EXEC"        : Gosub EXECFIN # SEGAY 19/02/14 US 940 81085
  Endcase

Return

######################################################
$INIT
Local Mask   GENMPS [GENMPS]

Local Char      CRITERE_DAT(GDIMFIC)
Local Char      CRITERE_CPY(GDIMFIC), CRITERE_FCY(GDIMFIC), CRITERE_SRV(GDIMFIC), CRITERE_PRF(GDIMFIC)
Local Char      CRITERE_DEB(GDIMFIC), CRITERE_FIN(GDIMFIC), CRITERE_LIBRE(GDIMFIC), CRITERE_POP(GDIMFIC)
Local Char      CRITERE_POT(GDIMFIC), CRITERE_JOBPOT(GDIMFIC),CRITERE_ACTIVE(100)
Local Integer   CRITERE_VAR
Local Char      CRITERE_DATDEB(GDIMFIC)
Local Char      CRITERE_DATFIN(GDIMFIC)

Local Char SYMBOLE (80)
Local Date IRP5DATE

  Gosub OUVFIC

  Raz [M:GENMPS]
  Call LECMEMO("STD","[M:GENMPS]","emp") From GMEMO

Return

$OUVRE_BOITE

Return

######################################################
## Ouverture des tables
######################################################
$OUVFIC
  If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
  If clalev([F:ACV])=0 : Local File ACTIV      [ACV] : Endif
  If clalev([F:ACC])=0 : Local File ACCES      [ACC] : Endif
  If clalev([F:ADW])=0 : Local File ADOVAL     [ADW] : Endif
  If clalev([F:ATB])=0 : Local File ATABLE     [ATB] : Endif
  If clalev([F:ATZ])=0 : Local File ATABZON    [ATZ] : Endif
  If clalev([F:ATI])=0 : Local File ATABIND    [ATI] : Endif
  If clalev([F:ATX])=0 : Local File ATEXTE     [ATX] : Endif
  If clalev([F:ATY])=0 : Local File ATYPE      [ATY] : Endif
  If clalev([F:DIC])=0 : Local File DICOEMP    [DIC] : Endif
  If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif
  If clalev([F:POA])=0 : Local File POPULA     [POA] : Endif
  If clalev([F:SMH])=0 : Local File SCREMPH    [SMH] : Endif
  If clalev([F:SMD])=0 : Local File SCREMPD    [SMD] : Endif
  If clalev([F:ECT])=0 : Local File EMPCTR     [ECT] : Endif
  If clalev([F:JOD])=0 : Local File JOBTYPDEF  [JOD] : Endif
  If clalev([F:POD])=0 : Local File POSTEDEF   [POD] : Endif
  If clalev([F:PFD])=0 : Local File PROFILDEF  [PFD] : Endif
  If clalev([F:AGC])=0  : Local File AGRPCPY   [AGC]  : Endif
  If clalev([F:FGR])=0  : Local File FACGROUP  [FGR]  : Endif
  If clalev([F:POT])=0 : Local File POSTE   [POT]     : Endif
  #ADNGO - 2017-09-08 - START
  #If clalev([F:CTR])=0 : Local File EMPLOCTR   [CTR] : Endif
  If clalev([F:HRCTR])=0 : Local File EMPLOCTR   [HRCTR] : Endif
  #ADNGO - 2017-09-08 - END
  If clalev([F:HRCTR1])=0 : Local File EMPLOCTR   [HRCTR1] : Endif

  #ADNGO - 2017-09-08 - START
  Gosub OUVRE From WPDEFTABLE
  #Gosub OUVRE From DEFTABLE
  #ADNGO - 2017-09-08 - END

Return

########################################################
$CHARGE_CRIT
Local Char      CRITERE_DATDEB(GDIMFIC)
Local Char      CRITERE_DATFIN(GDIMFIC)

  If [M:GENMPS]DATDEB <> [00/00/0000] Then
    #ADNGO - 2017-09-08 - START
    #CRITERE_DATDEB = '([F:CTR]CTRDAT>=['+format$(GFMD,[M:GENMPS]DATDEB)+'])'
    CRITERE_DATDEB = '([F:HRCTR]CTRDAT>=['+format$(GFMD,[M:GENMPS]DATDEB)+'])'
    #ADNGO - 2017-09-08 - END
  Endif

  If [M:GENMPS]DATFIN <> [00/00/0000] Then
    #ADNGO - 2017-09-08 - START
    #CRITERE_DATFIN = '([F:CTR]CTRDAT<=['+format$(GFMD,[M:GENMPS]DATFIN)+'])'
    CRITERE_DATFIN = '([F:HRCTR]CTRDAT<=['+format$(GFMD,[M:GENMPS]DATFIN)+'])'
    #ADNGO - 2017-09-08 - END
  Endif

  If [M:GENMPS]PROSEL = 1 Then
    #ADNGO - 2017-09-08 - START
    #CRITERE_DAT  = '([F:CTR]XITDAT=[0/0/0]'
    CRITERE_DAT  = '([F:HRCTR]XITDAT=[0/0/0]'
    #ADNGO - 2017-09-08 - END

    If CRITERE_DATDEB <> "" Then
       CRITERE_DAT += '|' + CRITERE_DATDEB + ')'
    Else
      CRITERE_DAT += ')'
    Endif

    If CRITERE_DATFIN <> "" Then
     CRITERE_DAT += '&' + CRITERE_DATFIN
    Endif

  Else
    If [M:GENMPS]SELVAR = 1 Then
      #ADNGO - 2017-09-08 - START
      #CRITERE_DAT  = '[F:CTR]XITDAT=[0/0/0]&[F:CTR]FLGVAR=1'
      CRITERE_DAT  = '[F:HRCTR]XITDAT=[0/0/0]&[F:HRCTR]FLGVAR=1'
      #ADNGO - 2017-09-08 - END

      If CRITERE_DATDEB <> "" Then
        CRITERE_DAT += '&' + CRITERE_DATDEB
      Endif

      If CRITERE_DATFIN <> "" Then
        CRITERE_DAT += '&' + CRITERE_DATFIN
      Endif

    Else
      #ADNGO - 2017-09-08 - START
      #CRITERE_DAT  = '[F:CTR]XITDAT<>[0/0/0]&[F:CTR]XITFNL=2'
      CRITERE_DAT  = '[F:HRCTR]XITDAT<>[0/0/0]&[F:HRCTR]XITFNL=2'
      #ADNGO - 2017-09-08 - END
      #ADNGO - 2017-09-08 - START
      #CRITERE_DATFIN = '([F:CTR]XITDAT<=['+format$(GFMD,[M:GENMPS]DATFIN)+'])'
      #CRITERE_DATDEB = '([F:CTR]XITDAT>=['+format$(GFMD,[M:GENMPS]DATDEB)+'])'
      CRITERE_DATFIN = '([F:HRCTR]XITDAT<=['+format$(GFMD,[M:GENMPS]DATFIN)+'])'
      CRITERE_DATDEB = '([F:HRCTR]XITDAT>=['+format$(GFMD,[M:GENMPS]DATDEB)+'])'
      #ADNGO - 2017-09-08 - END
      If CRITERE_DATDEB <> "" Then
        CRITERE_DAT += '&' + CRITERE_DATDEB
      Endif

      If CRITERE_DATFIN <> "" Then
        CRITERE_DAT += '&' + CRITERE_DATFIN
      Endif
    Endif
  Endif

  If [M:GENMPS]CPY<>""
    CRITERE_CPY = "[F:FCY]LEGCPY='"+[M:GENMPS]CPY+"'"
  Else
    CRITERE_CPY = "1=1"
  Endif

  If [M:GENMPS]FCY<>""
    #ADNGO - 2017-09-08 - START
    #CRITERE_FCY = "[F:CTR]ETRFCY='"+[M:GENMPS]FCY+"'"
    CRITERE_FCY = "[F:HRCTR]ETRFCY='"+[M:GENMPS]FCY+"'"
    #ADNGO - 2017-09-08 - END
  Else
    CRITERE_FCY = "1=1"
  Endif

  If [M:GENMPS]SRV<>""
    #ADNGO - 2017-09-08 - START
    #CRITERE_SRV = "[F:CTR]ETRSRV='"+[M:GENMPS]SRV+"'"
    CRITERE_SRV = "[F:HRCTR]ETRSRV='"+[M:GENMPS]SRV+"'"
    #ADNGO - 2017-09-08 - END
  Else
    CRITERE_SRV = "1=1"
  Endif

  If [M:GENMPS]PRF<>""
    #ADNGO - 2017-09-08 - START
    #CRITERE_PRF = "[F:CTR]PROPRF='"+[M:GENMPS]PRF+"'"
    CRITERE_PRF = "[F:HRCTR]PROPRF='"+[M:GENMPS]PRF+"'"
    #ADNGO - 2017-09-08 - END
  Else
    CRITERE_PRF = "1=1"
  Endif

  If [M:GENMPS]MATDEB<>""
    #ADNGO - 2017-09-08 - START
    #CRITERE_DEB = '[F:CTR]REFNUM>="'+[M:GENMPS]MATDEB+'"'
    CRITERE_DEB = '[F:HRCTR]REFNUM>="'+[M:GENMPS]MATDEB+'"'
    #ADNGO - 2017-09-08 - END
  Else
    CRITERE_DEB = "1=1"
  Endif

  If [M:GENMPS]MATFIN<>""
    #ADNGO - 2017-09-08 - START
    #CRITERE_FIN = '[F:CTR]REFNUM<="'+[M:GENMPS]MATFIN+'"'
    CRITERE_FIN = '[F:HRCTR]REFNUM<="'+[M:GENMPS]MATFIN+'"'
    #ADNGO - 2017-09-08 - END
  Else
    CRITERE_FIN = "1=1"
  Endif

  If [M:GENMPS]CRITERE<>""
    CRITERE_LIBRE = [M:GENMPS]CRITERE
  Else
    CRITERE_LIBRE = "1=1"
  Endif

  If [M:GENMPS]POT<>""
    #ADNGO - 2017-09-08 - START
    #CRITERE_POT = "[F:CTR]POT='"+[M:GENMPS]POT+"'"
    CRITERE_POT = "[F:HRCTR]POT='"+[M:GENMPS]POT+"'"
    #ADNGO - 2017-09-08 - END
  Else
    CRITERE_POT = "1=1"
  Endif

  If [M:GENMPS]JOBPOT<>""
    #ADNGO - 2017-09-08 - START
    #CRITERE_JOBPOT = "[F:CTR]JOBPOT='"+[M:GENMPS]JOBPOT+"'"
    CRITERE_JOBPOT = "[F:HRCTR]JOBPOT='"+[M:GENMPS]JOBPOT+"'"
    #ADNGO - 2017-09-08 - END
  Else
    CRITERE_JOBPOT = "1=1"
  Endif

  If [M:GENMPS]POP<>""
    CRITERE_POP = "[F:POA]REFNUM<>''"
  Else
    CRITERE_POP = "1=1"
  Endif
  #ADNGO - 2017-09-08 - START
  #CRITERE_ACTIVE = '[F:CTR]XITDAT<['+format$(GFMD,date$)+']'
  CRITERE_ACTIVE = '[F:HRCTR]XITDAT<['+format$(GFMD,date$)+']'
  #ADNGO - 2017-09-08 - END

Return

###################################################

$DEBUT
Local Integer PROCESS(2)

  PROCESS = [M:GENMPS]PROSEL
  Call FUNCTIONDISPLAY(PROCESS)

  If dim([M:GENMPS]PROSEL) > 0 Then
    If [M:GENMPS]PROSEL = 1 Then
         If dim([M:GENMPS]SELVAR)>0  : Chgfmt [M:GENMPS]SELVAR   With  "-LA:1"   : Affzo [M:GENMPS]SELVAR: Endif
         If dim([M:GENMPS]DATDEB)>0  : Actzo [M:GENMPS]DATDEB  : Affzo [M:GENMPS]DATDEB: Endif

    Else
         If dim([M:GENMPS]SELVAR)>0  : Chgfmt [M:GENMPS]SELVAR   With  "LA:1"  :  Affzo [M:GENMPS]SELVAR: Endif
         If dim([M:GENMPS]DATDEB)>0 and [M:GENMPS]SELVAR=2  : [M:GENMPS]DATDEB=GMOIPAY      : Grizo [M:GENMPS]DATDEB  : Affzo [M:GENMPS]DATDEB: Endif
         If dim([M:GENMPS]DATFIN)>0 and [M:GENMPS]SELVAR=2  : [M:GENMPS]DATFIN=eomonth(GMOIPAY)      : Grizo [M:GENMPS]DATFIN  : Affzo [M:GENMPS]DATFIN: Endif
    Endif
  Endif

Return

$CHARGE_MSK
Local Integer   L_OK, L_IJ, L_DEBSAL
Local Char      L_TEMPO(GDIMFIC), L_TEMPO2(GDIMFIC)
Local Char      L_POPUL(GLONPOP)(0..)
Local Integer   L_NB_POPUL
Local Char      L_CRITERE(GDIMFIC)

Local Integer   NBGRP
Local Char      LIS_CPY_GRP(GLONCPY)(0..100)

#ADNGO - 2017-09-08 - START
#Link [CTR] With [ID]ID0   = [F:CTR]REFNUM
#&             , [FCY]FCY0 = [F:CTR]ETRFCY
#&          As [LCTR]
#JASMI - 2017-11-20 - X3-64932 - START
#Link [HRCTR] With [ID]ID0   = [F:HRCTR]REFNUM
#&             , [FCY]FCY0 = [F:HRCTR]ETRFCY
#&          As [LCTR]
If [M:GENMPS]POP<>""
  Link [HRCTR]
& With [ID]ID0   = [F:HRCTR]REFNUM
&    , [FCY]FCY0 = [F:HRCTR]ETRFCY
&    , [POA]POA0 = [M:GENMPS]POP;[F:HRCTR]REFNUM
&   As [LCTR]
Else
  Link [HRCTR]
& With [ID]ID0   = [F:HRCTR]REFNUM
&    , [FCY]FCY0 = [F:HRCTR]ETRFCY
&   As [LCTR]
Endif
#JASMI - 2017-11-20 - X3-64932 - END
#ADNGO - 2017-09-08 - END

GERR   = 0
nolign = 0

For [LCTR]CTR0(2) Where evalue(CRITERE_DAT)
&                     & evalue(CRITERE_CPY) & evalue(CRITERE_FCY)
&                     & evalue(CRITERE_SRV) & evalue(CRITERE_PRF)
&                     & evalue(CRITERE_DEB) & evalue(CRITERE_FIN)
&                     & evalue(CRITERE_POP)
&                     & evalue(CRITERE_POT) & evalue(CRITERE_JOBPOT)
&                     & [F:ID]ENAFLG=2
#&                     & evalue(CRITERE_ACTIVE)
  L_OK = 1
  #ADNGO - 2017-09-08 - START
  #Call CONTROLE([F:ID]REFNUM,[F:CTR]CTRDAT,[F:CTR]CTRNUM,CRITERE_LIBRE,L_OK,1) From DIVPAYE
  Call CONTROLE([F:ID]REFNUM,[F:HRCTR]CTRDAT,[F:HRCTR]CTRNUM,CRITERE_LIBRE,L_OK,1) From DIVPAYE
  #ADNGO - 2017-09-08 - END

  If L_OK
    If [M:GENMPS]PROSEL = 1
      #ADNGO - 2017-09-08 - START
      #[M:MPS]REFNUM(nolign)=[F:CTR]REFNUM
      [M:MPS]REFNUM(nolign)=[F:HRCTR]REFNUM
      #ADNGO - 2017-09-08 - END
      [M:MPS]CPY(nolign)=[F:ID]CPY
      [M:MPS]NAM(nolign)=[F:ID]NAM
      [M:MPS]SRN(nolign)=[F:ID]SRN
      #ADNGO - 2017-09-08 - START
      #[M:MPS]CTRNUM(nolign)=[F:CTR]CTRNUM
      #[M:MPS]CTRDAT(nolign)=[F:CTR]CTRDAT
      #[M:MPS]ETRFCY(nolign)=[F:CTR]ETRFCY
      [M:MPS]CTRNUM(nolign)=[F:HRCTR]CTRNUM
      [M:MPS]CTRDAT(nolign)=[F:HRCTR]CTRDAT
      [M:MPS]ETRFCY(nolign)=[F:HRCTR]ETRFCY
      #ADNGO - 2017-09-08 - END
       Call LECTURE("FCY",[M:MPS]ETRFCY(nolign),"") From CONTOBJ
       [M:MPS]LEG(nolign)=[F:FCY]LEG

      #ADNGO - 2017-09-08 - START
      #[M:MPS]POT(nolign)=[F:CTR]POT
      #[M:MPS]JOBPOT(nolign)=[F:CTR]JOBPOT
      #[M:MPS]PROPRF(nolign)=[F:CTR]PROPRF
      #[M:MPS]ETRSRV(nolign)=[F:CTR]ETRSRV

      [M:MPS]POT(nolign)=[F:HRCTR]POT
      [M:MPS]JOBPOT(nolign)=[F:HRCTR]JOBPOT
      [M:MPS]PROPRF(nolign)=[F:HRCTR]PROPRF
      [M:MPS]ETRSRV(nolign)=[F:HRCTR]ETRSRV
      #ADNGO - 2017-09-08 - END

      #ADNGO - 2017-09-08 - START
      #[M:MPS]CTRGRD(nolign)=[F:CTR]CTRGRD
      #[M:MPS]NATCON(nolign)=[F:CTR]NATCON
      #[M:MPS]CTRDAT2(nolign)=[F:CTR]CTRDAT
      #[M:MPS]XITGRD(nolign)=[F:CTR]XITGRD

      [M:MPS]CTRGRD(nolign)=[F:HRCTR]CTRGRD
      [M:MPS]NATCON(nolign)=[F:HRCTR]NATCON
      [M:MPS]CTRDAT2(nolign)=[F:HRCTR]CTRDAT
      [M:MPS]XITGRD(nolign)=[F:HRCTR]XITGRD
      #ADNGO - 2017-09-08 - END

      #ADNGO - 2017-09-08 - START
      #[M:MPS]ETRFCY2(nolign)=[F:CTR]ETRFCY
      #[M:MPS]POT2(nolign)=[F:CTR]POT
      #[M:MPS]JOBPOT2(nolign)=[F:CTR]JOBPOT
      #[M:MPS]PROPRF2(nolign)=[F:CTR]PROPRF
      #[M:MPS]ETRSRV2(nolign)=[F:CTR]ETRSRV

      [M:MPS]ETRFCY2(nolign)=[F:HRCTR]ETRFCY
      [M:MPS]POT2(nolign)=[F:HRCTR]POT
      [M:MPS]JOBPOT2(nolign)=[F:HRCTR]JOBPOT
      [M:MPS]PROPRF2(nolign)=[F:HRCTR]PROPRF
      [M:MPS]ETRSRV2(nolign)=[F:HRCTR]ETRSRV
      #ADNGO - 2017-09-08 - END

      pcolor=GCOUL(0)
      Grizo [M:MPS]ETRFCY
      Grizo [M:MPS]POT
      Grizo [M:MPS]JOBPOT
      Grizo [M:MPS]PROPRF
      Grizo [M:MPS]ETRSRV

      Grizo [M:MPS]CTRGRD
      Grizo [M:MPS]NATCON
      Grizo [M:MPS]CTRDAT2
      Grizo [M:MPS]XITGRD

    Else
      #ADNGO - 2017-09-08 - START
      #[M:MPS]REFNUM(nolign)=[F:CTR]REFNUM
      #[M:MPS]CPY(nolign)=[F:ID]CPY
      #[M:MPS]NAM(nolign)=[F:ID]NAM
      #[M:MPS]SRN(nolign)=[F:ID]SRN
      #[M:MPS]CTRNUM(nolign)=[F:CTR]CTRNUM
      #[M:MPS]ETRFCY(nolign)=[F:CTR]ETRFCY

      [M:MPS]REFNUM(nolign)=[F:HRCTR]REFNUM
      [M:MPS]CPY(nolign)=[F:ID]CPY
      [M:MPS]NAM(nolign)=[F:ID]NAM
      [M:MPS]SRN(nolign)=[F:ID]SRN
      [M:MPS]CTRNUM(nolign)=[F:HRCTR]CTRNUM
      [M:MPS]ETRFCY(nolign)=[F:HRCTR]ETRFCY
      #ADNGO - 2017-09-08 - END

       Call LECTURE("FCY",[M:MPS]ETRFCY(nolign),"") From CONTOBJ
       [M:MPS]LEG(nolign)=[F:FCY]LEG

      #ADNGO - 2017-09-08 - START
      #[M:MPS]FLGVAR(nolign)=[F:CTR]FLGVAR
      [M:MPS]FLGVAR(nolign)=[F:HRCTR]FLGVAR
      #ADNGO - 2017-09-08 - END



      #ADNGO - 2017-09-08 - START
      #[M:MPS]CTRDAT(nolign)=[F:CTR]CTRDAT
      #[M:MPS]XITDAT(nolign)=[F:CTR]XITDAT
      #[M:MPS]XITGRD(nolign)=[F:CTR]XITGRD

      [M:MPS]CTRDAT(nolign)=[F:HRCTR]CTRDAT
      [M:MPS]XITDAT(nolign)=[F:HRCTR]XITDAT
      [M:MPS]XITGRD(nolign)=[F:HRCTR]XITGRD
      #ADNGO - 2017-09-08 - END

      #ADNGO - 2017-09-08 - START
      #[M:MPS]XITDAT2(nolign)=[F:CTR]XITDAT
      #[M:MPS]XITGRD2(nolign)=[F:CTR]XITGRD
      [M:MPS]XITDAT2(nolign)=[F:HRCTR]XITDAT
      [M:MPS]XITGRD2(nolign)=[F:HRCTR]XITGRD
      #ADNGO - 2017-09-08 - END

      If !clalev([F:HRCTR4]) : Local File EMPLOCTR    [HRCTR4]  : Endif
      #ADNGO - 2017-09-08 - START
      #Filter [CTR4] Where REFNUM=[F:CTR]REFNUM and ETRFCY = [F:CTR]ETRFCY and FLGVAR=2
      Filter [HRCTR4] Where REFNUM=[F:HRCTR]REFNUM and ETRFCY = [F:HRCTR]ETRFCY and FLGVAR=2
      #ADNGO - 2017-09-08 - END
      Read [HRCTR4]CTR0 Last

      If (!fstat)
        [M:MPS]AVTCTRDAT(nolign)=[HRCTR4]CTRDAT
        [M:MPS]AVTCTRGRD(nolign)=[HRCTR4]CTRGRD
        [M:MPS]AVTXITDAT(nolign)=[HRCTR4]XITDAT
        [M:MPS]AVTXITGRD(nolign)=[HRCTR4]XITGRD

        [M:MPS]AVTCTRDAT2(nolign)=[HRCTR4]CTRDAT
        [M:MPS]AVTCTRGRD2(nolign)=[HRCTR4]CTRGRD
        [M:MPS]AVTXITDAT2(nolign)=[HRCTR4]XITDAT
        [M:MPS]AVTXITGRD2(nolign)=[HRCTR4]XITGRD
        [M:MPS]CRTNUMFLGVAR(nolign)=[HRCTR4]CTRNUM
      Endif

      pcolor=GCOUL(0)

      Grizo [M:MPS]ETRFCY
      Grizo [M:MPS]XITDAT
      Grizo [M:MPS]XITGRD
      Grizo [M:MPS]FLGVAR

      Grizo [M:MPS]AVTCTRDAT
      Grizo [M:MPS]AVTCTRGRD
      Grizo [M:MPS]AVTXITDAT
      Grizo [M:MPS]AVTXITGRD

      Endif

    nolign += 1

  Endif : # If L_OK
Next : # [LCTR]CTR0(2)

Local Integer COUNT

  If GERR : Return : Endif
  Onerrgo
  [M:MPS]NBLIG = nolign

  [M:MPS]RED = mess(00027,10715,1) + "," - mess(00028,10715,1)  #"RED – This type of transfer will result in a new contract number, please note no employee totals will be transferred to new contract."
  [M:MPS]BLUE = mess(00029,10715,1) #"BLUE – This type of transfer will result in a new contract with the same contract number."

  Affzo [MPS]

Return

Subprog FUNCTIONDISPLAY(PROCESS)
Value Integer PROCESS

  Case PROCESS #LM 11722 #CREATE SEPRATE SUBS LATER
    When 1#Bulk transfers
      If dim([M:MPS]FLGVAR) > 0 : Chgfmt [M:MPS]FLGVAR      With "-LA:1"          : Endif
      If dim([M:MPS]XITDAT) > 0  : Chgfmt [M:MPS]XITDAT    With "-DZ:"+GFMDAT   : Endif

      #VAR INPUTS
      If dim([M:MPS]AVTCTRDAT ) > 0    : Chgfmt [M:MPS]AVTCTRDAT        With  "-DZ:"+GFMDAT4    : Endif
      If dim([M:MPS]AVTCTRGRD) > 0     : Chgfmt [M:MPS]AVTCTRGRD        With "-K:20X"             : Endif
      If dim([M:MPS]AVTXITDAT) > 0     : Chgfmt [M:MPS]AVTXITDAT        With "-DZ:"+GFMDAT         : Endif
      If dim([M:MPS]AVTXITGRD) > 0     : Chgfmt [M:MPS]AVTXITGRD        With "-K:20X"             : Endif

    When 2#Bulk terminations
      If dim([M:MPS]CTRDAT2) > 0  : Chgfmt [M:MPS]CTRDAT2        With "-DcZ:"+GFMDAT   : Endif

      If dim([M:MPS]POT) > 0     : Chgfmt [M:MPS]POT             With "-K:10X"             : Endif
      If dim([M:MPS]JOBPOT) > 0  : Chgfmt [M:MPS]JOBPOT          With "-K:10X"             : Endif
      If dim([M:MPS]PROPRF) > 0  : Chgfmt [M:MPS]PROPRF          With "-K:3X"              : Endif
      If dim([M:MPS]ETRSRV) > 0  : Chgfmt [M:MPS]ETRSRV          With "-K:5X"              : Endif
      If dim([M:MPS]CTRDAT2) > 0  : Chgfmt [M:MPS]CTRDAT2        With "-DcZ:"+GFMDAT       : Endif
      If dim([M:MPS]CTRGRD) > 0  : Chgfmt [M:MPS]CTRGRD          With "-K:20X"             : Endif
      If dim([M:MPS]NATCON) > 0  : Chgfmt [M:MPS]NATCON          With "-K:20X"             : Endif

      If dim([M:MPS]RED) > 0   : Chgfmt [M:MPS]RED          With "-K:100X"             : Endif
      If dim([M:MPS]BLUE) > 0  : Chgfmt [M:MPS]BLUE          With "-K:100X"             : Endif

         #VAR INPUTS

#JASMI - 2017-10-09 - X3-58791 - START
#      If func AFNC.ACTIV("KGH")
      If func DIVPAYE.IS_KGH_LEG(GCURLEG)
#JASMI - 2017-10-09 - X3-58791 - END
        If dim([M:MPS]FLGVAR) > 0 : Chgfmt [M:MPS]FLGVAR      With "-LA:1"          : Endif
       # If dim([M:MPS]XITDAT) > 0  : Chgfmt [M:MPS]XITDAT    With "-DZ:"+GFMDAT   : Endif
        If dim([M:MPS]AVTCTRDAT) > 0    : Chgfmt [M:MPS]AVTCTRDAT        With  "-DZ:"+GFMDAT4    : Endif
        If dim([M:MPS]AVTCTRGRD) > 0     : Chgfmt [M:MPS]AVTCTRGRD        With "-K:20X"             : Endif
        If dim([M:MPS]AVTXITDAT) > 0     : Chgfmt [M:MPS]AVTXITDAT        With "-DZ:"+GFMDAT         : Endif
        If dim([M:MPS]AVTXITGRD) > 0     : Chgfmt [M:MPS]AVTXITGRD        With "-K:20X"             : Endif
      Endif

  Endcase
End
######################################################

Subprog FIELDSDISPLAY(PROCESS, VALEUR)
Value Integer PROCESS
Value Integer VALEUR

  Case PROCESS #LM 11722 #CREATE SEPRATE SUBS LATER
    When 1#Bulk transfers
      If VALEUR=2 Then
        Actzo [M:MPS]ETRFCY(nolign-1)
        Actzo [M:MPS]POT(nolign-1)
        Actzo [M:MPS]JOBPOT(nolign-1)
        Actzo [M:MPS]PROPRF(nolign-1)
        Actzo [M:MPS]ETRSRV(nolign-1)
        Actzo [M]ETRFCY(nolign-1)
        Actzo [M]POT(nolign-1)
        Actzo [M]JOBPOT(nolign-1)
        Actzo [M]PROPRF(nolign-1)
        Actzo [M]ETRSRV(nolign-1)
        Actzo [M]CTRGRD(nolign-1)
        Actzo [M]NATCON(nolign-1)
        Actzo [M]CTRDAT2(nolign-1)
        Actzo [M]XITGRD(nolign-1)
        pcolor=GCOUL(3)

      Else
        Grizo [M:MPS]ETRFCY(nolign-1)
        Grizo [M:MPS]ETRFCY(nolign-1)
        Grizo [M:MPS]POT(nolign-1)
        Grizo [M:MPS]JOBPOT(nolign-1)
        Grizo [M:MPS]PROPRF(nolign-1)
        Grizo [M:MPS]ETRSRV(nolign-1)
        Grizo [M]ETRFCY(nolign-1)
        Grizo [M]POT(nolign-1)
        Grizo [M]JOBPOT(nolign-1)
        Grizo [M]PROPRF(nolign-1)
        Grizo [M]ETRSRV(nolign-1)
        Grizo [M]CTRGRD(nolign-1)
        Grizo [M]NATCON(nolign-1)
        Grizo [M]CTRDAT2(nolign-1)
        Grizo [M]XITGRD(nolign-1)
        pcolor=GCOUL(0)
      Endif

      Affzo [M:MPS]ETRFCY(nolign-1)
      Affzo [M:MPS]POT(nolign-1)
      Affzo [M:MPS]JOBPOT(nolign-1)
      Affzo [M:MPS]PROPRF(nolign-1)
      Affzo [M:MPS]ETRSRV(nolign-1)
      Affzo [M]ETRFCY(nolign-1)
      Affzo [M]POT(nolign-1)
      Affzo [M]JOBPOT(nolign-1)
      Affzo [M]PROPRF(nolign-1)
      Affzo [M]ETRSRV(nolign-1)
      Affzo [M]CTRGRD(nolign-1)
      Affzo [M]NATCON(nolign-1)
      Affzo [M]CTRDAT2(nolign-1)
      Affzo [M]XITGRD(nolign-1)

    When 2#Bulk terminations

    If [M:GENMPS]SELVAR=2 Then
      If VALEUR=2 Then
        If [M:MPS]FLGVAR(nolign-1)=2 Then
          Actzo [M:MPS]AVTCTRDAT(nolign-1)
          Actzo [M:MPS]AVTCTRGRD(nolign-1)
          Actzo [M:MPS]AVTXITDAT(nolign-1)
          Actzo [M:MPS]AVTXITGRD(nolign-1)
          pcolor=GCOUL(0)

          Affzo [M:MPS]AVTCTRDAT(nolign-1)
          Affzo [M:MPS]AVTCTRGRD(nolign-1)
          Affzo [M:MPS]AVTXITDAT(nolign-1)
          Affzo [M:MPS]AVTXITGRD(nolign-1)
        Else
          Actzo [M:MPS]FLGVAR(nolign-1)
          Actzo [M:MPS]XITDAT(nolign-1)
          Actzo [M:MPS]XITGRD(nolign-1)


          Affzo [M:MPS]FLGVAR(nolign-1)
          Affzo [M:MPS]XITDAT(nolign-1)
          Affzo [M:MPS]XITGRD(nolign-1)
        Endif
      Else
        Grizo [M:MPS]AVTCTRDAT(nolign-1)
        Grizo [M:MPS]AVTCTRGRD(nolign-1)
        Grizo [M:MPS]AVTXITDAT(nolign-1)
        Grizo [M:MPS]AVTXITGRD(nolign-1)
        Grizo [M:MPS]FLGVAR(nolign-1)
        Grizo [M:MPS]XITDAT(nolign-1)
        Grizo [M:MPS]XITGRD(nolign-1)

        Affzo [M:MPS]AVTCTRDAT(nolign-1)
        Affzo [M:MPS]AVTCTRGRD(nolign-1)
        Affzo [M:MPS]AVTXITDAT(nolign-1)
        Affzo [M:MPS]AVTXITGRD(nolign-1)
        Affzo [M:MPS]FLGVAR(nolign-1)
        Affzo [M:MPS]XITDAT(nolign-1)
        Affzo [M:MPS]XITGRD(nolign-1)
      Endif

    Else
      If VALEUR=2 Then
        Actzo [M:MPS]XITDAT(nolign-1)
        Actzo [M:MPS]XITGRD(nolign-1)
        Actzo [M:MPS]FLGVAR(nolign-1)
      Else
        Grizo [M:MPS]XITDAT(nolign-1)
        Grizo [M:MPS]XITGRD(nolign-1)
        Grizo [M:MPS]FLGVAR(nolign-1)
      Endif

      Affzo [M:MPS]XITDAT(nolign-1)
      Affzo [M:MPS]XITGRD(nolign-1)
      Affzo [M:MPS]FLGVAR(nolign-1)

    Endif
  Endcase

End

Subprog FIELDSDISPLAYALL(PROCESS, LINE)
Value Integer PROCESS
Value Integer LINE

  Case PROCESS #LM 11722 #CREATE SEPRATE SUBS LATER
    When 1#Bulk transfers
      Actzo [M:MPS]ETRFCY(LINE)
      Actzo [M:MPS]POT(LINE)
      Actzo [M:MPS]JOBPOT(LINE)
      Actzo [M:MPS]PROPRF(LINE)
      Actzo [M:MPS]ETRSRV(LINE)
      Actzo [M]ETRFCY(LINE)
      Actzo [M]POT(LINE)
      Actzo [M]JOBPOT(LINE)
      Actzo [M]PROPRF(LINE)
      Actzo [M]ETRSRV(LINE)
      Actzo [M]CTRGRD(LINE)
      Actzo [M]NATCON(LINE)
      Actzo [M]CTRDAT2(LINE)
      Actzo [M]XITGRD(LINE)

    When 2#Bulk terminations
  Endcase

End

$ERREUR

Resume

$EXECFIN
  If BOITE="MASSPRO"
     SAI=1
  Endif

Return

######################################################
$EXEC
Local  Integer NBENREG_CTR
Local  Char    L_MESSAGE(250)
Local  Char    L_CONTRAT(250)
Local  Char    L_SAV_CONTRAT(250)
Local Integer WARNING,YESNO
Raz L_MESSAGE,L_CONTRAT,L_SAV_CONTRAT
Local Integer COUNTDIFFCPY,COUNTSAMECPY,TERMEMP,COUNTRECALPAY
Local Integer COUNTROWS

  COUNTROWS=0
  WARNING=0
  [L]COUNTDIFFCPY = 0
  [L]COUNTSAMECPY = 0
  COUNTRECALPAY=0

  TERMEMP =0

  SYMBOLE = "MASSPRO"
  Lock =SYMBOLE
  If fstat
    GMESSAGE = mess(30,100,1)
    Unlock =SYMBOLE
    GERR = 1 : SAI = 1 : Return
  Endif

#START HERE
  If [M:GENMPS]PROSEL=1 Then
    If dim([M:MPS]NBLIG) > 0
      For L_IJ=0 To [M:MPS]NBLIG-1
        If [M:MPS]UPD(L_IJ)=2
          If [M:MPS]CTRDAT2(L_IJ) = [00/00/00] or [M:MPS]CTRDAT2(L_IJ) <= [M]CTRDAT(L_IJ) Then
            If [M:MPS]CTRDAT2(L_IJ) = [00/00/00] Then
              GMESSAGE = mess(00010,00123,1) -" : "- mess(00006,10506,1) - mess(00003,00011,1)
              GERR  = 2
              FIN = 0
              Return
            Else
              GMESSAGE = "New contract start date cannot be less than or equal to your current contract"#mess(00024,10715,1)
              GERR  = 2
              FIN = 0
              Return
            Endif
          Endif

          If [M:MPS]CTRGRD(L_IJ) = "" Then
            GMESSAGE = mess(00010,00123,1) -" : "- mess(00027,00114,1) - mess(00389,00197,1)
            GERR  = 2
            FIN = 0
            Return
          Endif

          If [M:MPS]NATCON(L_IJ) = "" Then
            GMESSAGE = mess(00010,00123,1) -" : "- mess(00018,00103,1)  - mess(00006,10506,1)
            GERR  = 2
            FIN = 0
            Return
          Endif

          If [M:MPS]XITGRD(L_IJ) = "" Then
            GMESSAGE = mess(00010,00123,1) -" : End reason"
            GERR  = 2
            FIN = 0
            Return
          Endif

          If [M:MPS]POT(L_IJ) = "" Then
            GMESSAGE = mess(00010,00123,1) -" : "- mess(00007,10489,1)
            GERR  = 2
            FIN = 0
            Return
          Endif

          If [M:MPS]JOBPOT(L_IJ) = "" Then
            GMESSAGE = mess(00010,00123,1) -" : "- mess(00005,10937,1)
            GERR  = 2
            FIN = 0
            Return
          Endif

          If [M:MPS]PROPRF(L_IJ) = "" Then
            GMESSAGE = mess(00010,00123,1) -" : "- mess(00042,00151,1)
            GERR  = 2
            FIN = 0
            Return
          Endif

          If [M:MPS]ETRSRV(L_IJ) = "" Then
            GMESSAGE = mess(00010,00123,1) -" : "- mess(00003,10491,1)
            GERR  = 2
            FIN = 0
            Return
          Endif
        Endif

        Read [HRCTR1]CTR0=[M:MPS]REFNUM(L_IJ);[M:MPS]CTRNUM(L_IJ);[M:MPS]CTRDAT(L_IJ)
        Call LECTURE("FCY",[F:HRCTR1]ETRFCY,"") From CONTOBJ
        SOC = [F:FCY]LEGCPY
        TEMP = [F:HRCTR1]ETRFCY
        Call LECTURE("FCY",[M]ETRFCY(L_IJ),"") From CONTOBJ
        If [F:FCY]LEGCPY<>SOC
          [L]COUNTDIFFCPY =+ 1
        Else
          [L]COUNTSAMECPY =+ 1
        Endif
      Next L_IJ
    Endif
    Call OUINON((func AFNC.MES1(mess(00025,10715,1),num$([L]COUNTDIFFCPY))
&        + "\" + func AFNC.MES1(mess(00026,10715,1),num$([L]COUNTSAMECPY))
&        + "\" + mess(00205,00100,1)), YESNO) From GESECRAN
    If YESNO<>2
      OK=0
      Return
    Endif
  #JASMI - 2017-10-11 - X3-59300 - START
    Infbox mess(00049,11662,1)
  #JASMI - 2017-10-11 - X3-59300 - END
  Else
  #BULK TERMINATIONS - BACK END VALIDATIONS
    If dim([M:MPS]NBLIG) > 0
      For L_IJ=0 To [M:MPS]NBLIG-1
        If [M:MPS]UPD(L_IJ)=2
          If !clalev([F:HRCTR3]) : Local File EMPLOCTR     [HRCTR3]  : Endif
          Filter [HRCTR3] Where REFNUM=[M:MPS]REFNUM(L_IJ) and CTRNUM=[M:MPS]CTRNUM(L_IJ) and CTRDAT=[M:MPS]CTRDAT(L_IJ)
          Read [HRCTR3]CTR0 = [M:MPS]REFNUM(L_IJ);[M:MPS]CTRNUM(L_IJ);[M:MPS]CTRDAT(L_IJ)
          Filter [HRCTR3]

          If [HRCTR3]FLGVAR = 1 Then
            If [M:MPS]XITDAT(L_IJ) = [0/0/0] Then
              GMESSAGE = mess(00010,00123,1) -" : "- mess(00003,00138,1)
              GERR  = 2
              FIN = 0
              Return
            Endif
            If [M:MPS]XITGRD(L_IJ) = "" Then
              GMESSAGE = mess(00010,00123,1) -" : End reason"
              GERR  = 2
              FIN = 0
              Return
            Endif
          Endif
          If [M:MPS]FLGVAR(L_IJ) = 2
            If [M:MPS]AVTCTRDAT(L_IJ) = [0/0/0] Then # & VALEUR<[M:MPS]XITDAT(nolign-1)
              GMESSAGE = mess(00010,00123,1) -" : "- mess(00003,00646,1)- mess(00006,10506,1) - mess(00003,00011,1)
              GERR  = 2
              FIN = 0
              Return
            Endif

            If [M:MPS]AVTCTRGRD(L_IJ) = "" Then
              GMESSAGE = mess(00010,00123,1) -" : "- mess(00003,10646,1)- mess(00027,00114,1) - mess(00389,00197,1)
              GERR  = 2
              FIN = 0
              Return
            Endif

            If [M:MPS]AVTXITDAT(L_IJ) = [0/0/0] Then
              GMESSAGE = mess(00010,00123,1) -" : "- mess(00003,10646,1)- mess(00003,00138,1)
              GERR  = 2
              FIN = 0
              Return
            Endif

            If [M:MPS]AVTXITGRD(L_IJ) = "" Then
              GMESSAGE = mess(00010,00123,1) -" : "- mess(00003,10646,1)- "End reason"
              GERR  = 2
              FIN = 0
              Return
            Endif
          Endif

          If [M:MPS]XITDAT(L_IJ)<> [0/0/0]
            If [M:MPS]XITDAT(L_IJ) < [M:MPS]CTRDAT(L_IJ)
              GMESSAGE = mess(6,10702,1): #La date de sortie ne peut pas être inférieure à la date d'entrée
              mkstat = 1 : End
            Endif

            If [M:MPS]XITDAT(L_IJ)<> [M:MPS]XITDAT2(L_IJ)
              COUNTRECALPAY +=1
            Endif
          Endif
        Endif
      Next
      If COUNTRECALPAY > 0 Then
        OK = 2
        Call AVERTIR(mess(00029,10715,1),OK) From GESECRAN
        #Call AVERTIR("Changes were made to terminated employees, please recalculate payslips.",OK) From GESECRAN
        If OK=1 : mkstat = 1 : End : Endif
      Endif
    Endif
  Endif
#End here

  TIT = mess(116,10701,1) :

  Call OUVRE_TRACE(TIT) From LECFIC
  Call ECR_TRACE(TIT,0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

  For L_IJ=0 To [M:MPS]NBLIG-1
   If [M:MPS]UPD(L_IJ)=2
   If [M:GENMPS]PROSEL=1 Then
     Gosub TR1 #Transaction for bulk transfer
   Else
     Gosub TR2 #Transaction for bulk termination
   Endif
    If GOK<1 : Break : Endif
   Endif
  Next L_IJ

  Unlock =SYMBOLE

  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  If NBENREG_CTR>0  Then
    Call ECR_TRACE(mess(117,10701,1)-":"-num$(NBENREG_CTR),0) From GESECRAN : #
  Else
    Call ECR_TRACE(mess(118,10701,1),0) From GESECRAN :
  Endif
  Call FERME_TRACE From LECFIC

  Call LEC_TRACE From LECFIC
  GMESSAGE=""

  Raz [M:GENMPS]
  Raz [M:MPS]

Return

##############
$TR1
  GOK = 1
  Call DEBTRANS From GLOCK

  Trbegin [F:HRCTR1]
  GCLE = [M:MPS]REFNUM(L_IJ)+"|"+[M:MPS]CTRNUM(L_IJ)+"|"+[M:MPS]CTRDAT(L_IJ)
  Read [HRCTR1]CTR0=[M:MPS]REFNUM(L_IJ);[M:MPS]CTRNUM(L_IJ);[M:MPS]CTRDAT(L_IJ)

  If fstat=1
    GOK = -1 : GLOCK = "$EMPLOCTR"-GCLE : Goto ROLL_TR1
  Elsif fstat
    #ADNGO - 2017-09-08 - START
    #GOK = 0 : Call RSTA("CTR",GCLE) From GLOCK : Goto AB_TR1
    GOK = 0 : Call RSTA("HRCTR",GCLE) From GLOCK : Goto AB_TR1
    #ADNGO - 2017-09-08 - END
  Endif
  SOC =""
  TEMP=""

  If clalev([F:HRCTR1])=0 : Local File EMPLOCTR[HRCTR1] : Endif
  Filter [HRCTR1] Where REFNUM=[M]REFNUM(L_IJ) & CTRNUM=[M]CTRNUM(L_IJ) & CTRDAT=[M]CTRDAT(L_IJ)

  Read [HRCTR1]CTR1 Last
  Filter [HRCTR1]

  If !fstat
    Call LECTURE("FCY",[F:HRCTR1]ETRFCY,"") From CONTOBJ
    SOC = [F:FCY]LEGCPY
    TEMP = [F:HRCTR1]ETRFCY
    Call LECTURE("FCY",[M]ETRFCY(L_IJ),"") From CONTOBJ
    If [F:FCY]LEGCPY<>SOC
      Gosub DIFFCPY
    Else
      Gosub SAMECPY
    Endif
  Endif






  If fstat
    #ADNGO - 2017-09-08 - START
    #GOK = 0 : Call FSTA("CTR") From GLOCK
    GOK = 0 : Call FSTA("HRCTR") From GLOCK
    #ADNGO - 2017-09-08 - END
  Endif
  If GOK=-1 : Goto ROLL_TR1
  Elsif GOK<1 : Goto AB_TR1
  Endif

  L_MESSAGE =""
  L_CONTRAT = [M:MPS]REFNUM(L_IJ)+[M:MPS]CTRNUM(L_IJ)+format$("D:"+GFMDAT,[M:MPS]CTRDAT(L_IJ))


  If L_CONTRAT <> L_SAV_CONTRAT
    L_SAV_CONTRAT = L_CONTRAT
    NBENREG_CTR+=1
    L_MESSAGE = space$(3)+mess(00001,10319,1)-[M:MPS]REFNUM(L_IJ)-"/"-mess(72,10720,1)-[M:MPS]CTRNUM(L_IJ)-":"+chr$(13)+chr$(10)
    L_MESSAGE+= space$(4)+mess(274,142,1)-chr$(13)+chr$(10)
  Else
    L_MESSAGE = space$(4)+mess(274,142,1)-chr$(13)+chr$(10)
  Endif

  If [M:MPS]ETRFCY(L_IJ) <> [M:MPS]ETRFCY2(L_IJ)
    L_MESSAGE+= space$(5)+mess(00003,00045,1)-mess(205,197,1)-" : "-mess(130,6000,1)-TEMP+chr$(13)+chr$(10)
    L_MESSAGE+= space$(5)+mess(00003,00045,1)-mess(206,197,1)-" : "-mess(130,6000,1)-[M:MPS]ETRFCY(L_IJ)+chr$(13)+chr$(10)
  Endif

  If [M:MPS]POT(L_IJ) <> [M:MPS]POT2(L_IJ)
    L_MESSAGE+= space$(5)+mess(00007,10489,1)-mess(205,197,1)-" : "-mess(130,6000,1)-[M:MPS]POT2(L_IJ)+chr$(13)+chr$(10)
    L_MESSAGE+= space$(5)+mess(00007,10489,1)-mess(206,197,1)-" : "-mess(130,6000,1)-[M:MPS]POT(L_IJ)+chr$(13)+chr$(10)
  Endif

  If [M:MPS]JOBPOT(L_IJ) <> [M:MPS]JOBPOT2(L_IJ)
    L_MESSAGE+= space$(5)+mess(00005,10937,1)-mess(205,197,1)-" : "-mess(130,6000,1)-[M:MPS]JOBPOT2(L_IJ)+chr$(13)+chr$(10)
    L_MESSAGE+= space$(5)+mess(00005,10937,1)-mess(206,197,1)-" : "-mess(130,6000,1)-[M:MPS]JOBPOT(L_IJ)+chr$(13)+chr$(10)
  Endif

  If [M:MPS]PROPRF(L_IJ) <> [M:MPS]PROPRF(L_IJ)
    L_MESSAGE+= space$(5)+mess(00042,00151,1)-mess(205,197,1)-" : "-mess(130,6000,1)-[M:MPS]PROPRF2(L_IJ)+chr$(13)+chr$(10)
    L_MESSAGE+= space$(5)+mess(00042,00151,1)-mess(206,197,1)-" : "-mess(130,6000,1)-[M:MPS]PROPRF(L_IJ)+chr$(13)+chr$(10)
  Endif

  If [M:MPS]ETRSRV(L_IJ) <> [M:MPS]ETRSRV(L_IJ)
    L_MESSAGE+= space$(5)+mess(00004,10489,1) -mess(205,197,1)-" : "-mess(130,6000,1)-[M:MPS]ETRSRV2(L_IJ)+chr$(13)+chr$(10)
    L_MESSAGE+= space$(5)+mess(00004,10489,1) -mess(206,197,1)-" : "-mess(130,6000,1)-[M:MPS]ETRSRV(L_IJ)+chr$(13)+chr$(10)
  Endif

  Call ECR_TRACE(L_MESSAGE,0) From GESECRAN : # Matricule / Contrat : Champ ... avant ... aprés

  Commit

Return

$AB_TR1
  Rollback

Return

$ROLL_TR1
  Rollback
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto TR1 : Endif

Return

$TR2
  GOK = 1
  Call DEBTRANS From GLOCK
  Local Integer INDENDDATE
  INDENDDATE=0

  Trbegin [F:HRCTR1]
  If  [M]CTRDAT(L_IJ) = [0/0/0] Then
    GCLE = [M:MPS]REFNUM(L_IJ)+"|"+[M:MPS]CTRNUM(L_IJ)+"|"+[M:MPS]AVTCTRDAT2(L_IJ)
    Read [HRCTR1]CTR0=[M:MPS]REFNUM(L_IJ);[M:MPS]CTRNUM(L_IJ);[M:MPS]AVTCTRDAT2(L_IJ)
  Else
    GCLE = [M:MPS]REFNUM(L_IJ)+"|"+[M:MPS]CTRNUM(L_IJ)+"|"+[M:MPS]CTRDAT(L_IJ)
    Read [HRCTR1]CTR0=[M:MPS]REFNUM(L_IJ);[M:MPS]CTRNUM(L_IJ);[M:MPS]CTRDAT(L_IJ)
  Endif


  If fstat=1
    GOK = -1 : GLOCK = "$EMPLOCTR"-GCLE : Goto ROLL_TR2
  Elsif fstat
    #ADNGO - 2017-09-08 - START
    #GOK = 0 : Call RSTA("CTR",GCLE) From GLOCK : Goto AB_TR2
    GOK = 0 : Call RSTA("HRCTR",GCLE) From GLOCK : Goto AB_TR2
    #ADNGO - 2017-09-08 - END
  Endif
  SOC =""
  TEMP=""

  If clalev([F:HRCTR1])=0 : Local File EMPLOCTR[HRCTR1] : Endif
  If  [M]CTRDAT(L_IJ) = [0/0/0] Then
    Filter [HRCTR1] Where REFNUM=[M]REFNUM(L_IJ) & CTRNUM=[M]CTRNUM(L_IJ) & CTRDAT=[M]AVTCTRDAT2(L_IJ)
  Else
    Filter [HRCTR1] Where REFNUM=[M]REFNUM(L_IJ) & CTRNUM=[M]CTRNUM(L_IJ) & CTRDAT=[M]CTRDAT(L_IJ)
  Endif

  Read [HRCTR1]CTR1 Last
  Filter [HRCTR1]

  If !fstat
    #Perform update of End date, end reason and exit date
    If [M]XITDAT(L_IJ)<>[M]XITDAT2(L_IJ) or [M]XITGRD(L_IJ)<>[M]XITGRD2(L_IJ) #Changed end date of contract, update and count
      [HRCTR1]XITDAT = [M]XITDAT(L_IJ)
      [HRCTR1]XITGRD = [M]XITGRD(L_IJ)
      [HRCTR1]LSTDAY = [M]XITDAT(L_IJ)
      [HRCTR1]XITFNL =2

      Rewrite [HRCTR1]

      If [M]LEG(L_IJ)="ZAF" Then
        If clalev([F:CTRSA])=0 : Local File EMPLOCTRSA[CTRSA] : Endif
        Filter [CTRSA] Where REFNUM=[M]REFNUM(L_IJ) & CTRNUM=[M]CTRNUM(L_IJ) & CTRDAT=[M]CTRDAT(L_IJ)
        Read [CTRSA]CTRSA0 Last
        IRP5DATE=[CTRSA]IRPENDDAT
        [CTRSA]IRPENDDAT = [M]XITDAT(L_IJ)
        Rewrite [CTRSA]
      Endif
    Endif

    If [M:MPS]FLGVAR(L_IJ) = 2 # check if already a VAR, if so update, if not create
      If !clalev([F:HRCTR4]) : Local File EMPLOCTR    [HRCTR4]  : Endif
      Filter [HRCTR4] Where REFNUM=[M:MPS]REFNUM(L_IJ) and CTRNUM = [M:MPS]CRTNUMFLGVAR(L_IJ) and CTRDAT=[M:MPS]AVTCTRDAT2(L_IJ)and FLGVAR=2
      Read [HRCTR4]CTR0 Last

      If (!fstat) Then
      #UPDATE VRA
        [HRCTR4]CTRDAT = [M]AVTCTRDAT(L_IJ)
        [HRCTR4]CTRGRD = [M]AVTCTRGRD(L_IJ)
        [HRCTR4]XITDAT = [M]AVTXITDAT(L_IJ)
        [HRCTR4]XITGRD = [M]AVTXITGRD(L_IJ)
        [HRCTR4]XITFNL =2
        [HRCTR4]LSTDAY = [M]AVTCTRDAT(L_IJ)
        Rewrite [HRCTR4]
      Else
        Gosub CREATEVAR
      Endif
    Endif
  Endif

  If fstat
    #ADNGO - 2017-09-08 - START
    #GOK = 0 : Call FSTA("CTR") From GLOCK
    GOK = 0 : Call FSTA("HRCTR") From GLOCK
    #ADNGO - 2017-09-08 - END
  Endif
  If GOK=-1 : Goto ROLL_TR2
  Elsif GOK<1 : Goto AB_TR2
  Endif

  L_MESSAGE =""
  L_CONTRAT = [M:MPS]REFNUM(L_IJ)+[M:MPS]CTRNUM(L_IJ)+format$("D:"+GFMDAT,[M:MPS]CTRDAT(L_IJ))

  If L_CONTRAT <> L_SAV_CONTRAT
    L_SAV_CONTRAT = L_CONTRAT
    NBENREG_CTR+=1
    L_MESSAGE = space$(3)+mess(00001,10319,1)-[M:MPS]REFNUM(L_IJ)-"/"-mess(72,10720,1)-[M:MPS]CTRNUM(L_IJ)-":"+chr$(13)+chr$(10)
    L_MESSAGE+= space$(4)+mess(274,142,1)-chr$(13)+chr$(10)
  Else
    L_MESSAGE = space$(4)+mess(274,142,1)-chr$(13)+chr$(10)
  Endif

  If [M:MPS]XITDAT(L_IJ) <> [M:MPS]XITDAT2(L_IJ) Then
    L_MESSAGE+= space$(5)+mess(00003,00138,1)-mess(205,197,1)-" : "-mess(130,6000,1)-[M:MPS]XITDAT2(L_IJ)+chr$(13)+chr$(10)
    L_MESSAGE+= space$(5)+mess(00003,00138,1)-mess(206,197,1)-" : "-mess(130,6000,1)-[M:MPS]XITDAT(L_IJ)+chr$(13)+chr$(10)
  Endif

  If [M:MPS]XITGRD(L_IJ) <> [M:MPS]XITGRD2(L_IJ) Then
    L_MESSAGE+= space$(5)+"End reason"-mess(205,197,1)-" : "-mess(130,6000,1)-[M:MPS]XITGRD2(L_IJ)+chr$(13)+chr$(10)
    L_MESSAGE+= space$(5)+"End reason"-mess(206,197,1)-" : "-mess(130,6000,1)-[M:MPS]XITGRD(L_IJ)+chr$(13)+chr$(10)
  Endif

  If [M:MPS]FLGVAR(L_IJ) = 2
    If [M:MPS]AVTCTRDAT(L_IJ) <> [M:MPS]AVTCTRDAT2(L_IJ) Then
      L_MESSAGE+= space$(5)+"VAR CTR date"-mess(205,197,1)-" : "-mess(130,6000,1)-[M:MPS]AVTCTRDAT2(L_IJ)+chr$(13)+chr$(10)
      L_MESSAGE+= space$(5)+"VAR CTR date"-mess(206,197,1)-" : "-mess(130,6000,1)-[M:MPS]AVTCTRDAT(L_IJ)+chr$(13)+chr$(10)
    Endif

    If [M:MPS]AVTCTRGRD(L_IJ) <> [M:MPS]AVTCTRGRD2(L_IJ) Then
      L_MESSAGE+= space$(5)+"VAR Start reason"-mess(205,197,1)-" : "-mess(130,6000,1)-[M:MPS]AVTCTRGRD2(L_IJ)+chr$(13)+chr$(10)
      L_MESSAGE+= space$(5)+"VAR Start reason"-mess(206,197,1)-" : "-mess(130,6000,1)-[M:MPS]AVTCTRGRD(L_IJ)+chr$(13)+chr$(10)
    Endif

    If [M:MPS]AVTXITDAT(L_IJ) <> [M:MPS]AVTXITDAT2(L_IJ) Then
      L_MESSAGE+= space$(5)+"VAR End date"-mess(205,197,1)-" : "-mess(130,6000,1)-[M:MPS]AVTXITDAT2(L_IJ)+chr$(13)+chr$(10)
      L_MESSAGE+= space$(5)+"VAR End date"-mess(206,197,1)-" : "-mess(130,6000,1)-[M:MPS]AVTXITDAT(L_IJ)+chr$(13)+chr$(10)
    Endif

    If [M:MPS]AVTXITGRD(L_IJ) <> [M:MPS]AVTXITGRD2(L_IJ) Then
      L_MESSAGE+= space$(5)+"VAR End reason"-mess(205,197,1)-" : "-mess(130,6000,1)-[M:MPS]AVTXITGRD2(L_IJ)+chr$(13)+chr$(10)
      L_MESSAGE+= space$(5)+"VAR End reason"-mess(206,197,1)-" : "-mess(130,6000,1)-[M:MPS]AVTXITGRD(L_IJ)+chr$(13)+chr$(10)
    Endif
  Endif

  Call ECR_TRACE(L_MESSAGE,0) From GESECRAN : # Matricule / Contrat : Champ ... avant ... aprés
  Commit

Return

$CREATEVAR
Local Char COMPTEUR(100)
Local Integer I, STAT, VOK
Local Char CHRONO(30)

  If clalev([F:TCA])=0 : Local File TABCOUAFF[TCA] : Endif
  Read [TCA]TCA0 = 9
#JASMI - 2017-10-09 - X3-58791 - START
  #COMPTEUR = [F:TCA]CODNUM(2)
  COMPTEUR = [F:TCA]CODNUM(4)
#JASMI - 2017-10-09 - X3-58791 - END
  If COMPTEUR=""
    #ADNGO - 2017-09-08 - START
    #GMESSAGE = mess(39,701,1) : # Compteur contrat non défini
    GMESSAGE = mess(39,10701,1) : # Compteur contrat non défini
    #ADNGO - 2017-09-08 - END
    GOK = 0 : Return
  Endif

# Call NUMERO(COMPTEUR,[M]ETRFCY(L_IJ),date$,[CTR1]NATCON,CHRONO,STAT) From SUBANM
  If !clalev([F:HRCTR2]) : Local File EMPLOCTR     [HRCTR2]  : Endif
# If [L]CHRONO<>""
  [F:HRCTR2]=[F:HRCTR1]
  #[F:CTR2]CTRNUM = CHRONO
  [F:HRCTR2]CTRDAT = [M:MPS]AVTCTRDAT(L_IJ)
  [F:HRCTR2]CTRGRD = [M:MPS]AVTCTRGRD(L_IJ)
  [F:HRCTR2]XITDAT = [M:MPS]AVTXITDAT(L_IJ)
  [F:HRCTR2]XITGRD = [M:MPS]AVTXITGRD(L_IJ)
  [F:HRCTR2]LSTDAY = [M:MPS]AVTCTRDAT(L_IJ)
  [F:HRCTR2]FLGVAR = 2
  [F:HRCTR2]XITFNL = 1
  If GPAYE : [F:HRCTR2]RAZCUM = 1 : Endif
  [F:HRCTR2]CLEEVETIM = 1
  [F:HRCTR2]SUICAR = 1
  [F:HRCTR2]FLGRET=1
  [F:HRCTR2]RETTYP=1
  [F:HRCTR2]RETSTATUT =1
  Raz [F:HRCTR2]RETDATEFF,[F:HRCTR2]RETCTRNUMORI,[F:HRCTR2]RETCTRDATORI,[F:HRCTR2]RETGRD

  If GPAYE & dim([F:HRCTR2]FLGCREBUL)>=0 : [F:HRCTR2]FLGCREBUL=2 : Endif

  Write [F:HRCTR2]
  If fstat
    #ADNGO - 2017-09-08 - START
    #GOK = 0 : Call FSTA("CTR") From GLOCK
    GOK = 0 : Call FSTA("HRCTR") From GLOCK
    #ADNGO - 2017-09-08 - END
  Endif

  If [M:MPS]LEG(L_IJ)="ZAF"
    Call SET_EMPCTRSA([M:MPS]REFNUM(L_IJ),[M:MPS]CTRNUM(L_IJ),[M:MPS]CTRDAT(L_IJ),[M:MPS]AVTCTRDAT(L_IJ)) From SUBCTRKSA
  Endif

  If !clalev([F:CPR])  : Local File EMPLOCTRCPT  [CPR]   : Endif :#108400
  If !clalev([F:CPR2]) : Local File EMPLOCTRCPT  [CPR2]  : Endif :#108400

  Read [F:CPR]=[F:HRCTR1]REFNUM;[F:HRCTR1]CTRNUM;[F:HRCTR1]CTRDAT
  If !fstat
    Raz [F:CPR2]
    [F:CPR2]=[F:CPR]
    [F:CPR2]CTRNUM = [M:MPS]CTRNUM(L_IJ)
    [F:CPR2]CTRDAT = [M:MPS]AVTCTRDAT(L_IJ)
    Write [F:CPR2]
    If fstat
      GOK = 0 : Call FSTA("CPR") From GLOCK
    Endif
  Endif

  If !GOK : Return : Endif

  Readlock[F:ID]ID0=[M:MPS]REFNUM(L_IJ)
  If !fstat
    [F:ID]FLGMULCTR=2
    [F:ID]UPDDAT = date$
    [F:ID]UPDUSR = GUSER
    [F:ID]UPDTIM = time
    Rewrite [F:ID]
    If fstat
      GOK = 0 : Call FSTA("ID") From GLOCK : Return
    Endif
  Endif
  If !GOK : Return : Endif

  If clalev([F:TIP])=0  : Local File TIMEMP     [TIP] : Endif
  Call SET_EMPCTR([F:HRCTR2]REFNUM, [F:HRCTR2]CTRNUM, 1) From TRTRETAVT    : # Recalcul EMPCTR
  If GOK<1 : Return : Endif

Return

$AB_TR2
  Rollback

Return

$ROLL_TR2
  Rollback
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto TR2 : Endif

Return

