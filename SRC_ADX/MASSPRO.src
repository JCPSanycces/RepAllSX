#RES=func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
RES=func AFNC.ACTIV("KGZA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
#ADNGO - 2017-09-11 - END
End RES

Subprog DIFFCPYTEST(VALEUR,ISOK)
Variable Char VALEUR
Variable Integer ISOK : ISOK = 2

  SOC =""
  If clalev([F:HRCTR1])=0 : Local File EMPLOCTR[HRCTR1] : Endif
  Filter [HRCTR1] Where REFNUM=[M]REFNUM(nolign-1) & CTRNUM=[M]CTRNUM(nolign-1) & CTRDAT=[M]CTRDAT(nolign-1)
  Read [HRCTR1]CTR1 Last
  Filter [HRCTR1]
  If !fstat
    Call LECTURE("FCY",[F:HRCTR1]ETRFCY,"") From CONTOBJ
    SOC = [F:FCY]LEGCPY
    Call LECTURE("FCY",VALEUR,"") From CONTOBJ
    If [F:FCY]LEGCPY<>SOC
    #  GMESSAGE = mess(40,11662,1)
     # ISOK=1
     # End
    Else
    #  Infbox("ALL OK SIMPLE UPDATE")
    Endif
 Endif

End

$DIFFCPY
#ADD ALL CALLS TO CREATE A NEW CONTRACT

#THRAM 2016-08-23 - US X3PEOP-512 - START
#Gosub CREATION_DAT From SUBCTR2
#Gosub FNLXITDAT From SUBCTR2
#THRAM 2016-08-23 - US X3PEOP-512 - END
#If GINTMT=1
# Raz [F:PSN]
# [F:PSN]CREDAT = date$
# [F:PSN]CREUSR = GUSER
# [F:PSN]CRETIM = time
# Gosub CRE_PSN
# If [V]GOK<1 : Return : Endif
#Endif

  Gosub INICRE
  If [V]GOK<1 : Return : Endif

  Gosub MAJ_EMPLOID
  If [V]GOK<1 : Return : Endif

#Gosub MAJ_EMPLOELC
#If [V]GOK<1 : Return : Endif
  Gosub MAJ_EMPLOCTRCPT
  If [V]GOK<1 : Return : Endif

  Gosub MAJ_EMPLOPOT
  If [V]GOK<1 : Return : Endif
#Gosub MAJ_TRAINER
#If [V]GOK<1 : Return : Endif

  Gosub MAJ_ESB
  If [V]GOK<0 : Return : Endif

  If [M:MPS]LEG(L_IJ)="ZAF"
    #KSA FOR NOW
    Gosub MAJ_KSA
  Endif
  If [V]GOK<1 : Return : Endif

  Gosub APRES

Return

$MAJ_KSA
  Filter [F:CTRSA] Where [F:CTRSA]REFNUM = [M:MPS]REFNUM(L_IJ)
&                & [F:CTRSA]CTRNUM = [M:MPS]CTRNUM(L_IJ)
&                & [F:CTRSA]CTRDAT = [M:MPS]CTRDAT(L_IJ)

  Read [F:CTRSA]CTRSA0=[M:MPS]REFNUM(L_IJ);[M:MPS]CTRNUM(L_IJ);[M:MPS]CTRDAT(L_IJ)

  [F:CTRSA]REFNUM=[HRCTR1]REFNUM
  [F:CTRSA]CTRNUM=[HRCTR1]CTRNUM
  [F:CTRSA]CTRDAT=[M:MPS]CTRDAT2(L_IJ)

  If [M:MPS]CTRNUM(L_IJ) <> [HRCTR1]CTRNUM
    [F:CTRSA]IRPSTRDAT = [M]CTRDAT2(L_IJ)
    [F:CTRSA]IRPENDDAT=IRP5DATE
  Endif

  Write [F:CTRSA]
  If fstat <> 0
    [V]GOK = 0
    Call FSTA("CPR") From GLOCK
    Return
  Endif

Return

$SAMESIT
#Create new contract with same chrono
  [HRCTR1]CTRDAT = ([M]CTRDAT2(L_IJ))
  [HRCTR1]CTRGRD = [M]CTRGRD(L_IJ)
  [HRCTR1]NATCON  = [M]NATCON(L_IJ)

  If [M]POT(L_IJ) <> [M]POT2(L_IJ)
    [HRCTR1]POT=[M]POT(L_IJ)
  Endif
  If [M]JOBPOT(L_IJ) <> [M]JOBPOT2(L_IJ)
    [HRCTR1]JOBPOT=[M]JOBPOT(L_IJ)
  Endif
  If [M]PROPRF(L_IJ) <> [M]PROPRF2(L_IJ)
    [HRCTR1]PROPRF=[M]PROPRF(L_IJ)
  Endif
  If [M]ETRSRV(L_IJ) <> [M]ETRSRV2(L_IJ)
    [HRCTR1]ETRSRV=[M]ETRSRV(L_IJ)
  Endif

  Rewrite [HRCTR1]

Return

$SAMECPY
 [HRCTR1]ETRFCY = [M]ETRFCY(L_IJ)
 [HRCTR1]CTRDAT = ([M]CTRDAT2(L_IJ))
 [HRCTR1]CTRGRD = [M]CTRGRD(L_IJ)
 [HRCTR1]NATCON  = [M]NATCON(L_IJ)

  If [M]POT(L_IJ) <> [M]POT2(L_IJ)
    [HRCTR1]POT=[M]POT(L_IJ)
  Endif

  If [M]JOBPOT(L_IJ) <> [M]JOBPOT2(L_IJ)
    [HRCTR1]JOBPOT=[M]JOBPOT(L_IJ)
  Endif

  If [M]PROPRF(L_IJ) <> [M]PROPRF2(L_IJ)
    [HRCTR1]PROPRF=[M]PROPRF(L_IJ)
  Endif

  If [M]ETRSRV(L_IJ) <> [M]ETRSRV2(L_IJ)
    [HRCTR1]ETRSRV=[M]ETRSRV(L_IJ)
  Endif

  Write [HRCTR1]

  Gosub MAJ_EMPLOID
  If [V]GOK<1 : Return : Endif

  Gosub MAJ_EMPLOCTRCPT
  If [V]GOK<1 : Return : Endif

  Gosub MAJ_EMPLOPOT
  If [V]GOK<1 : Return : Endif
  #Gosub MAJ_TRAINER
  #If [V]GOK<1 : Return : Endif

  Gosub MAJ_ESB
  If [V]GOK<0 : Return : Endif

  If [M]LEG(L_IJ) = "ZAF"
    #KSA FOR NOW
    Gosub MAJ_KSA
  Endif

  If [V]GOK<1 : Return : Endif

#UPDATE contract with end dates
  Filter [HRCTR1] Where REFNUM=[M]REFNUM(L_IJ) & CTRNUM=[M]CTRNUM(L_IJ) & CTRDAT=[M]CTRDAT(L_IJ)

  Read [HRCTR1]CTR1 Last
  Filter [HRCTR1]

  [HRCTR1]XITDAT = [M]CTRDAT2(L_IJ)-1
  [HRCTR1]XITGRD = [M]XITGRD(L_IJ)
  [HRCTR1]XITFNL = 1

#  CRITCTRL="CTRNUM='"+[M:MPS]CTRNUM(nolign-1)+"'"
#  CRITCTRL-="& CTRDAT=["+num$([M:MPS]CTRDAT(nolign-1))+"]"
#  Call CONTROLE_PAYE([M:MPS]REFNUM(nolign-1), CRITCTRL)
#  If mkstat
#   [CTR1]XITFNL =2
#  Endif

  Rewrite [HRCTR1]

  Gosub APRES

Return

$INICRE
Local Integer I, STAT, VOK
Local Char CHRONO(30)

  [HRCTR1]XITDAT = [M]CTRDAT2(L_IJ)-1
  [HRCTR1]XITGRD = [M]XITGRD(L_IJ)
  [HRCTR1]XITFNL =2

  Rewrite [HRCTR1]

  If [M]LEG(L_IJ) = "ZAF"
    If clalev([F:CTRSA])=0 : Local File EMPLOCTRSA[CTRSA] : Endif
    Filter [CTRSA] Where REFNUM=[M]REFNUM(L_IJ) & CTRNUM=[M]CTRNUM(L_IJ) & CTRDAT=[M]CTRDAT(L_IJ)
    Read [CTRSA]CTRSA0 Last
    IRP5DATE=[CTRSA]IRPENDDAT
    [CTRSA]IRPENDDAT = [M]CTRDAT2(L_IJ)-1
    Rewrite [CTRSA]

  Endif
  #Elsif func AFNC.ACTIV("KAQ") Then
  #
  #  If clalev([F:CTRAFR])=0 : Local File EMPLOCTRAFR[CTRAFR] : Endif
  #  Filter [CTRAFR] Where REFNUM=[M]REFNUM(L_IJ) & CTRNUM=[M]CTRNUM(L_IJ) & CTRDAT=[M]CTRDAT(L_IJ)
  #  Read [CTRAFR]CTRAFR0 Last
  #  [CTRAFR]TAXENDDAT = [M]CTRDAT2(L_IJ)-1
  #  Rewrite [CTRAFR]
  #Endif

  If clalev([F:TCA])=0 : Local File TABCOUAFF[TCA] : Endif

  Read [TCA]TCA0 = 9
#JASMI - 2017-10-09 - X3-58791 - START
  #COMPTEUR = [F:TCA]CODNUM(2)
  COMPTEUR = [F:TCA]CODNUM(4)
#JASMI - 2017-10-09 - X3-58791 - END
  If COMPTEUR=""
    #ADNGO - 2017-09-11 - START
    #GMESSAGE = mess(39,701,1) : # Compteur contrat non défini
    GMESSAGE = mess(39,10701,1) : # Compteur contrat non défini
    #ADNGO - 2017-09-11 - END
    GOK = 0 : Return
  Endif

  Call NUMERO(COMPTEUR,[M]ETRFCY(L_IJ),date$,[HRCTR1]NATCON,CHRONO,STAT) From SUBANM

  If STAT
    #ADNGO - 2017-09-11 - START
    #GMESSAGE = mess(4,702,1)-COMPTEUR : # "Erreur sur compteur"
    GMESSAGE = mess(4,10702,1)-COMPTEUR : # "Erreur sur compteur"
    #ADNGO - 2017-09-11 - END
    GOK = 0 : Return
  Endif

#First update current contract - end date and IRP5 dates
#Then create new contract with correct IRP5 dates
  Raz [HRCTR1]XITDAT,[HRCTR1]XITGRD,[HRCTR1]XITFNL
  [HRCTR1]CTRNUM = CHRONO
  [HRCTR1]CTRDAT = [M]CTRDAT2(L_IJ)
  [HRCTR1]ETRFCY = [M]ETRFCY(L_IJ)
  [HRCTR1]CTRGRD = [M]CTRGRD(L_IJ)
  [HRCTR1]NATCON = [M]NATCON(L_IJ)

  If [M]POT(L_IJ) <> [M]POT2(L_IJ)
    [HRCTR1]POT=[M]POT(L_IJ)
  Endif

  If [M]JOBPOT(L_IJ) <> [M]JOBPOT2(L_IJ)
    [HRCTR1]JOBPOT=[M]JOBPOT(L_IJ)
  Endif

  If [M]PROPRF(L_IJ) <> [M]PROPRF2(L_IJ)
    [HRCTR1]PROPRF=[M]PROPRF(L_IJ)
  Endif

  If [M]ETRSRV(L_IJ) <> [M]ETRSRV2(L_IJ)
    [HRCTR1]ETRSRV=[M]ETRSRV(L_IJ)
  Endif

  Write [HRCTR1]

  If func AFNC.ACTIV("KSA") Then
  #  If clalev([F:CTRSA])=0 : Local File EMPLOCTRSA[CTRSA] : Endif
  #  Filter [CTRSA] Where REFNUM=[M]REFNUM(L_IJ) & CTRNUM=[M]CTRNUM(L_IJ) & CTRDAT=[M]CTRDAT(L_IJ)
  #  Read [CTRSA]CTRSA0 Last
  #  [CTRSA]IRPSTRDAT = [M]CTRDAT2(L_IJ)
  #  Rewrite [CTRSA]
  Elsif func AFNC.ACTIV("KAQ") Then
  #  If clalev([F:CTRAFR])=0 : Local File EMPLOCTRAFR[CTRAFR] : Endif
  #  Filter [CTRAFR] Where REFNUM=[M]REFNUM(L_IJ) & CTRNUM=[M]CTRNUM(L_IJ) & CTRDAT=[M]CTRDAT(L_IJ)
  #  Read [CTRAFR]CTRAFR0 Last
  #  [CTRAFR]TAXSTRDAT = [M]CTRDAT2(L_IJ)
  #  Rewrite [CTRAFR]
  Endif

#If [M]REFNUM<>[F:ID]REFNUM
# Read [ID]ID0=[M]REFNUM
# If fstat : Return : Endif
#Endif
#If [F:ID]FLGINT<>2
# [F:CTR]CALPAY = 1                   : # Par contrat
# [F:CTR]STACTR = 2                   : # Validé
#Elsif [F:ID]FLGINT=2 & GINTMT=1 & [M:CTR3]STACTR=2
# [F:CTR]XITDAT = max([M:CTR3]PSNENDDAT)
# [F:CTR]XITGRD = "FDC"
# #96623
# [M:CTR0]XITDAT=[F:CTR]XITDAT : Affzo [M:CTR0]XITDAT
# [M:CTR8]XITDAT=[F:CTR]XITDAT : [M:CTR8]XITGRD=[F:CTR]XITGRD : Affzo [M:CTR8]5
# #end 96623
#Endif
#If [F:CTR]FLGVAR=0 : [F:CTR]FLGVAR=1 : Endif
#Gosub SAUVE_EVT

# V01X08 - Délégation maladie disparaît (public seulement), on force la valeur trois si vide
#          pour éviter un effet de bord malencontreux.
#If dim([M]DEGMAL) > 0 & [M]DEGMAL = 0
# [M]DEGMAL = 3
#Endif

#If GPAYE
# Gosub SAVE_RETROCTR From SUBCTRRET
# #If the field doesn't exist in screens or if it's null (security)
# #-----> We have to assign it in the file
# Local Char ZONE(10) : ZONE = "FLGCREBUL"
# Gosub SET_ZONE
# If !MA  or [M]FLGCREBUL=0
#   Local Integer TEMPO
#   #Manage the box 'Break payslip' (2 = Assign only)
#   [L]TEMPO=[F:CTR]FLGCREBUL
#   Call UPD_FLGCREBUL(TEMPO, 2) From SUBCTR2
#   [F:CTR]FLGCREBUL=[L]TEMPO
# Endif
#Endif
Return

$CREATION_DAT
#[CTR1]DATCRE = eomonth(GMOIPAY) #NEED TO VERIFY

Return

$FNLXITDAT
#[CTR1]DATXITFNL = eomonth(GMOIPAY)#NEED TO VERIFY

Return

$CRE_PSN
  [F:PSN]CTRNUM    = [HRCTR1]CTRNUM
  [F:PSN]REFNUM    = [HRCTR1]REFNUM
  [F:PSN]CTRDAT    = [HRCTR1]CTRDAT
  For nolign=1 To [CTR]NBRPSN
    [F:PSN]       = [M:CTR3]
    [F:PSN]PSNNUM = nolign
    Write [PSN]
    If fstat
      GOK=0 : Call FSTA("PSN") From GLOCK : Break
    Endif
  Next
  If GOK=0 : Return : Endif

Return

$MAJ_EMPLOID
  Filter  [F:ID]
  If [HRCTR1]FLGVAR=2 : Return : Endif

  If clalev([F:ID])=0 : Local File EMPLOID[ID] : Endif
  Filter [ID] Where REFNUM=[M]REFNUM(L_IJ)
  Read [ID]ID0 Last

  If fstat=1
   GOK=-1 : GLOCK="$EMPLOID"-[M]REFNUM(L_IJ)
   Return
  Elsif fstat
   GOK=0 : Call FSTA("ID") From GLOCK
   Return
  Endif

  Filter  [F:ID]

  #BRBAN - 96348 - Source Retention
  #If func DIVPAYE.EXISTE_KXX("SUBCTRKPO") Then
  #  Gosub MAJ_EMPLOID From SUBCTRKPO
  #Endif

  [F:ID]FCY      = [HRCTR1]ETRFCY
  [F:ID]FCYORI   = [HRCTR1]ETRFCY
  [F:ID]SRV      = [HRCTR1]ETRSRV
  [F:ID]PRF      = [HRCTR1]PROPRF
  Read [FCY]FCY0=[HRCTR1]ETRFCY
  [F:ID]CPY      = [F:FCY]LEGCPY
  Rewrite [F:ID]

  If fstat
   GOK=0 : Call FSTA("ID") From GLOCK : Return
  Endif

Return

$MAJ_EMPLOELC
  #If [M]MAIFCY<2 : Return : Endif

  #If [M:CTR0]FLGVAR=2 : Return : Endif
  #ADNGO -2017-09-11 - START
  #Look [ELC]ELC0=[F:CTR]REFNUM;[F:CTR]ETRFCY
  Look [ELC]ELC0=[F:HRCTR]REFNUM;[F:HRCTR]ETRFCY
  #ADNGO -2017-09-11 - END
  If !fstat : Return : Endif

  Link [ELC] With [FCY]FCY0=RPEFCY
&            As [LNK]
&         Where REFNUM=[F:HRCTR]REFNUM & [FCY]LEGCPY=func DIVPAYE.GETSOC([F:HRCTR]ETRFCY)
  Read [LNK] First
  If !fstat
    Readlock [ELC] Curr
    If fstat
      [V]GOK  =-1
      [V]GLOCK="$EMPLOELC"-[F:ELC]REFNUM-[F:ELC]RPEFCY
      Return
    Endif

    [F:ELC]RPEFCY=[F:HRCTR]ETRFCY
    [F:ELC]UPDUSR=[V]GUSER
    [F:ELC]UPDDAT=date$
    [F:ELC]UPDTIM=time

    Rewrite [ELC] Curr
    If fstat
      [V]GOK=0
      Call FSTA("ELC") From GLOCK
      Return
    Endif
  Else
    Raz [F:ELC]
    [F:ELC]REFNUM=[F:HRCTR]REFNUM
    [F:ELC]RPEFCY=[F:HRCTR]ETRFCY
    [F:ELC]CREUSR=[V]GUSER
    [F:ELC]CREDAT=date$
    [F:ELC]CRETIM=time

    Write [ELC]
    If fstat
      [V]GOK=0
      Call FSTA("ELC") From GLOCK
      Return
    Endif
  Endif

Return

$MAJ_EMPLOCTRCPT
  Filter [F:CPR] Where [F:CPR]REFNUM = [M:MPS]REFNUM(L_IJ)
&                & [F:CPR]CTRNUM = [M:MPS]CTRNUM(L_IJ)
&                & [F:CPR]CTRDAT = [M:MPS]CTRDAT(L_IJ)

  Read [F:CPR]CPR0=[M:MPS]REFNUM(L_IJ);[M:MPS]CTRNUM(L_IJ);[M:MPS]CTRDAT(L_IJ)

  [F:CPR]REFNUM=[HRCTR1]REFNUM
  [F:CPR]CTRNUM=[HRCTR1]CTRNUM
  [F:CPR]CTRDAT=[M:MPS]CTRDAT2(L_IJ)

  Write [F:CPR]
  If fstat <> 0
    [V]GOK = 0
    Call FSTA("CPR") From GLOCK
    Return
  Endif

Return

$MAJ_EMPLOPOT
  #If [M:CTR0]FLGVAR=2 : Return : Endif
  Filter [EPO] Where [F:EPO]REFNUM = [M:MPS]REFNUM(L_IJ)
&                & [F:EPO]CTRNUM = [M:MPS]CTRNUM(L_IJ)
&                & [F:EPO]DATPOT = [M:MPS]CTRDAT(L_IJ)
&                & [F:EPO]ORIGINE=1

  Read [F:EPO]EPO0=[M:MPS]REFNUM(L_IJ);[M:MPS]CTRNUM(L_IJ);1;[M:MPS]CTRDAT(L_IJ)

  [F:EPO]REFNUM=[HRCTR1]REFNUM
  [F:EPO]CTRNUM=[HRCTR1]CTRNUM
  [F:EPO]DATPOT=[M:MPS]CTRDAT2(L_IJ)
  [F:EPO]POT=[M:MPS]POT(L_IJ)
  [F:EPO]JOBPOT=[M:MPS]JOBPOT(L_IJ)

  Write [F:EPO]
  If fstat <> 0
    [V]GOK = 0
    Call FSTA("CPR") From GLOCK
    Return
  Endif

  #Delete [EPO] Where [F:EPO]REFNUM=[M:CTR0]REFNUM
  #&                & [F:EPO]CTRNUM=[M:CTR0]CTRNUM
  #&                & [F:EPO]DATPOT=[M:CTR0]CTRDAT
