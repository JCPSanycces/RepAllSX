Subprog B3_NBLIG
Local Integer L_IJ
Local Integer PROCESS(2)

  PROCESS = [M:GENMPS]PROSEL

  For L_IJ=nolign-1 To [M]NBLIG-1
    [M]UPD(L_IJ) = 2
    Call FIELDSDISPLAYALL(PROCESS,L_IJ)
  Next L_IJ
  Affzo [M]5

End

Subprog B4_NBLIG
# Décocher
Local Integer L_IJ

  For L_IJ=nolign-1 To [M]NBLIG-1
    [M]UPD(L_IJ) = 1

    Grizo [M]ETRFCY(L_IJ)
    Grizo [M]POT(L_IJ)
    Grizo [M]JOBPOT(L_IJ)
    Grizo [M]PROPRF(L_IJ)
    Grizo [M]ETRSRV(L_IJ)

    Grizo [M]CTRGRD(L_IJ)
    Grizo [M]NATCON(L_IJ)
    Grizo [M]CTRDAT2(L_IJ)
    Grizo [M]XITGRD(L_IJ)
  Next L_IJ
  Affzo [M]5

End

$CRIT_CPY
#MABOS-28/02/13-88305
  [L]NBGRP=0
  Call GRP_WITH_CPY_IN([F:FCY]LEGCPY,[F:FCY]FCY,[L]LIS_CPY_GRP,[L]NBGRP ) From SUBCTR
  L_CRITERE = " find([F]CPY, [L]LIS_CPY_GRP(0..[L]NBGRP)) "

Return

