#     GOK = -1 : GLOCK = "$EMPSBD"-[M:CTR0]REFNUM-[M:CTR0]CTRNUM-[M:CTR0]CTRDAT-num$([F:ESB]NIVEAU)-num$([F:ESB]RANG)
#     Return
#   Endif
#   Read [F:WAD] AD0=[M:CTR0]REFNUM
#   If !fstat
#    For L_K=0 To len(mess(0,50,1))
#      If [F:WAD]CHEF(L_K)<> ""
#         Raz [F:ESB]
#         [F:ESB]CHEF=[F:WAD]CHEF(L_K)
#         [F:ESB]NIVEAU=2
#         [F:ESB]RANG=L_K+1
