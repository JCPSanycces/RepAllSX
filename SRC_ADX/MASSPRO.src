######################################################################################

$APRES

GOK = 1

Filter [HRCTR1]  Where REFNUM=[M:MPS]REFNUM(L_IJ) & CTRNUM=[HRCTR1]CTRNUM
Read [HRCTR1]CTR0 Last

If fstat
 Raz [F:HRCTR1]
Endif

Read [ECT]ECT0=[M:MPS]REFNUM(L_IJ);[HRCTR1]CTRNUM

If fstat=1
 GOK=-1 : GLOCK="$EMPCTR"-[M:MPS]REFNUM-[HRCTR1]CTRNUM
Elsif fstat

   [F:ECT]REFNUM = [M:MPS]REFNUM(L_IJ)
   [F:ECT]CTRNUM = [HRCTR1]CTRNUM
   [F:ECT]NBRCTR = rowcount([HRCTR1])
   [F:ECT]FCY    = [M:MPS]ETRFCY(L_IJ)
   [F:ECT]SRV    = [M:MPS]ETRSRV(L_IJ)
   [F:ECT]PRF    = [M:MPS]PROPRF(L_IJ)
   [F:ECT]CREUSR = [V]GUSER
   [F:ECT]CREDAT = date$
   [F:ECT]CRETIM = time
   Write [ECT]
   If fstat
    GOK=0 : Call FSTA("ECT") From GLOCK
   Endif
Else

 [F:ECT]NBRCTR = rowcount([HRCTR1])
 If [F:HRCTR1]FLGVAR<>2
  [F:ECT]FCY    = [M:MPS]ETRFCY(L_IJ)
  [F:ECT]SRV    = [M:MPS]ETRSRV(L_IJ)
  [F:ECT]PRF    = [M:MPS]PROPRF(L_IJ)
 Endif

 [F:ECT]UPDUSR = [V]GUSER
 [F:ECT]UPDDAT = date$
 [F:ECT]UPDTIM = time
 If [F:ECT]NBRCTR>0
  Rewrite [ECT]
  If fstat
   GOK=0 : Call FSTA("ECT") From GLOCK
  Endif
 Else
  Delete [ECT]ECT0=[M:MPS]REFNUM(L_IJ);[HRCTR1]CTRNUM(HRCTR1)
  If fstat=1 | fstat>5
   GOK=0 : Call RSTA("ECT",[M:MPS]REFNUM-[HRCTR1]CTRNUM) From GLOCK
  Endif
 Endif
Endif
If GOK=1
 I = 0
# For [CTR1]CTR0
#  I +=1
#  [F:CTR1]NUMLIG = I
#  #First contract = Check the box 'Break payslip' is mandatory except for casual workers
##  If I=1 & GPAYE
##   If GINTMT & [F:ID]FLGINT=2
##    [F:CTR1]FLGCREBUL=1
##   Else
##    [F:CTR1]FLGCREBUL=2
##   Endif
##  Endif
#  Rewrite [CTR1]Curr
#  If fstat
#   GOK=0 : Call FSTA("CTR") From GLOCK : Break
#  Endif
# Next
Endif
Filter [HRCTR1]
If GOK<0   : Goto ROLL_APRES
Elsif !GOK : Goto AB_APRES
Endif
# Si MAJ_EMPLOID fait dans ANNULE, l'enreg n'est pas encore annulé et rowid renvoie 1
#If ACTION="AP_ANNULE"
# Gosub MAJ_EMPLOID
# If GOK<0   : Goto ROLL_APRES
# Elsif !GOK : Goto AB_APRES
# Endif
#Endif
#If GPAYE & ACTION<>"APRES_MOD"
# # MAJ du CTRDAT de la saisie des valeurs prev non encore passées en paie
# # En effet si déjà passée en paie cela signifie qu'il existe des payes donc on aura planté avant.
# Gosub MAJ_VALPREV
# If GOK<0   : Goto ROLL_APRES
# Elsif !GOK : Goto AB_APRES
# Endif
#Endif

#If GRETTIP
#   Local Char W_TIP_REFNUM(GLONMAT)
#   Local Char W_TIP_CTRNUM(GLONCTR)
#   Local Char WACTION
#   Local Date W_TIP_CTRDAT
#   Local Date W_TIP_XITDAT
#   Local Char W_TIP_ETRFCY(GLONFCY)
#   Local Char W_TIP_ETRSRV(GLONSRV)
#
#
#   W_TIP_REFNUM=[M]REFNUM
#   W_TIP_CTRNUM=[M]CTRNUM
#   W_TIP_CTRDAT=[M]CTRDAT
#   W_TIP_XITDAT=[M]XITDAT
#   W_TIP_ETRFCY=[M]ETRFCY
#   W_TIP_ETRSRV=[M:CTR1]ETRSRV
#
#
#   WACTION=ACTION
#   If [M:CTR0]FLGVAR<>2 & GTPS
#     Gosub MAJ_TIMEMP2
#     GRETTIP=0
#     If GOK<0   : Goto ROLL_APRES
#     Elsif !GOK : Goto AB_APRES
#     Endif
#   Endif
#   GRETTIP=0
#Endif
#Commit
Return

########################################################
$ROLL_APRES
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto APRES : Endif

########################################################
$AB_APRES
Rollback
Return

