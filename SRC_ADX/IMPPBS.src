#<AdxTL>@(#)3.0.0.0 $Revision$

$ACTION
 Case ACTION
  When "IMP_OUVRE"     : Gosub IMP_OUVRE
  When "IMP_VERIF_CRE" : Gosub IMP_VERIF_CRE
  When "IMP_VERIF_MOD" : Gosub IMP_VERIF_MOD
 Endcase
Return


$IMP_OUVRE
If clalev([COA]) = 0 : Local File GCOA     [COA] : Endif
Return



$IMP_VERIF_CRE
$IMP_VERIF_MOD

OK=1
Gosub CONTROLE
Return


$CONTROLE
#--------- Le champs COA est obligatoire et existant
If [F:PBS]COA=""
 GMESSAGE ="COA"-mess(10,123,1) # Zone obligatoire
 OK=0 : Return
Else
 Read [COA]COA0=[F:PBS]COA
 If fstat
  GMESSAGE = "COA"-mess(83,123,1)-[F:PBS]COA  # Valeur incorrecte
  OK=0 : Return
 Endif
Endif

#--------- Le champs NUMCOD est obligatoire
If [F:PBS]NUMCOD<1 or [F:PBS]NUMCOD>10
 GMESSAGE = "NUMCOD"-mess(83,123,1)-num$([F:PBS]NUMCOD)  # Valeur incorrecte
 OK=0 : Return
Endif

#--------- Le champs ACCSTR est obligatoire
If [F:PBS]ACCSTR=""
 GMESSAGE = "ACCSTR"-mess(10,123,1) # Zone obligatoire
 OK=0 : Return
Else
 If [F:COA]FXDLEN=2 & [F:PBS]ACCSTR<>"*"
  If vireblc([F:PBS]ACCSTR,2)<>vireblc(format$([F:COA]ACCFMT,[F:PBS]ACCSTR),2)
   # Format incorrect
   GMESSAGE = [F:PBS]ACCSTR-mess(149,100,1)
   OK=0 : Return
  Endif
 Endif
Endif 

#--------- Le champs CODCDT est obligatoire
If [F:PBS]CODCDT=""
 GMESSAGE = "CODCDT"-mess(10,123,1) # Zone obligatoire
 OK=0 : Return
Endif

#--------- Le champs CODDEB est obligatoire
If [F:PBS]CODDEB=""
 GMESSAGE = "CODDEB"-mess(10,123,1) # Zone obligatoire
 OK=0 : Return
Endif
Return

