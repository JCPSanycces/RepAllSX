#<AdxTL>@(#)12.0.0.0 $Revision$
#########################################################################
#    GESTION DU COLISAGE                                                #
#-----------------------------------------------------------------------#
#  - Traitement        : FUNPACK                                        #
#  - Action e_commerce : TRTPACK    (Trt standard)                      #
#                        SAIPACK    (Saisie fenêtre)                    #
#                        TRICOL     (Trt divers)      Bouton bas écran  #
#                        TRIEMB     (Trt divers)      Bouton bas écran  #
#                        DIVCOLOR   (Trt divers)      Avant zone        #
#                        SAIPACKMAN (Saisie fenêtre)  B1 ligne colis    #
#                        SAIPACKAUT (Saisie fenêtre)  B2 ligne colis    #
#                        DIVANUPACK (Trt divers)      B3 ligne colis    #
#                                                                       #
#########################################################################

#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
#CHECK UNUSED_BEGIN
#--- Actions liées au traitement standard
Case ACTION
 When "INIT"        : Case GACTION
                       When "TRTPACK" : Gosub INIT_TRTPACK
                      Endcase
 When "INIT_DIA"    : Case GACTION
                       When "TRTPACK" : Gosub INIT_DIA_TRTPACK
                      Endcase
 When "TERMINE"     : Case GACTION
                       When "TRTPACK" : Gosub TERMINE_TRTPACK
                      Endcase
 When Default
Endcase
#CHECK UNUSED_END

#--- Actions liées à la fenêtre de saisie
Case ACTION
 When "OUVRE"       : Case GACTION
                       When "TRTPACK", "SAIPACK" : Gosub OUVRE_TRTPACK
                      Endcase
 When "SETBOUT"     : Case GACTION
                       When "TRTPACK", "SAIPACK" : Gosub SETBOUT_TRTPACK
                      Endcase
 When "DEBUT"       : Case GACTION
                       When "TRTPACK", "SAIPACK" : Gosub DEBUT_TRTPACK
                       When "SAIPACKMAN"         : Gosub DEBUT_SAIPACKMAN
                       When "SAIPACKAUT"         : Gosub DEBUT_SAIPACKAUT
                      Endcase
 When "AP_CHOIX"    : Case GACTION
                       When "TRTPACK", "SAIPACK" : Gosub AP_CHOIX_TRTPACK
                      Endcase
 When "AVANT_ENR"   : Case GACTION
                       When "TRTPACK", "SAIPACK" : Gosub AVANT_ENR_TRTPACK
                      Endcase
 When "ENR"         : Case GACTION
                       When "TRTPACK", "SAIPACK" : Gosub ENR_TRTPACK
                      Endcase
 When "SUP"         : Case GACTION
                       When "TRTPACK", "SAIPACK" : Gosub SUP_TRTPACK
                      Endcase
 When "AVANT_SUI"   : Case GACTION
                       When "TRTPACK", "SAIPACK" : Gosub AVANT_SUI_TRTPACK
                      Endcase
 When "SUI"         : Case GACTION
                       When "TRTPACK", "SAIPACK" : Gosub SUI_TRTPACK
                      Endcase
 When "OK"          : Case GACTION
                       When "SAIPACKMAN"         : Gosub OK_SAIPACKMAN
                       When "SAIPACKAUT"         : Gosub OK_SAIPACKAUT
                      Endcase
 When "FIN"         : Case GACTION
                       When "TRTPACK", "SAIPACK" : Gosub FIN_TRTPACK
                      Endcase
 When "FINSAI"      : Case GACTION
                       When "SAIPACKMAN"         : Gosub FINSAI_SAIPACKMAN
                       When "SAIPACKAUT"         : Gosub FINSAI_SAIPACKAUT
                      Endcase
Endcase

#--- Actions liées au traitement divers
Case ACTION
 When "TRT_DIV"     : Case TRAIT
                       When "TRICOL"     : Gosub TRICOL
                       When "TRIEMB"     : Gosub TRIEMB
                       When "DIVCOLOR"   : Gosub DIVCOLOR
                       When "DIVANUPACK" : Gosub DIVANUPACK
                      Endcase
 When Default
Endcase

Return

#########################################################################
# Détail des actions liées au traitement standard                       #
#########################################################################

#########################################################################
#CHECK UNUSED_BEGIN
$INIT_TRTPACK
TIT = mess(320,198,1)

# C'est une fonction vente qui travaille sur un site d'expédition
# On surcharge donc le site par défaut du module avec celui d'expédition
# pour que les contrôles d'autorisation des sites soient corrects.
GFCYDEF(0) = GFCYDEF(7)

If clalev([F:SDH]) = 0 Local File SDELIVERY  [SDH] Endif
If clalev([F:SDD]) = 0 Local File SDELIVERYD [SDD] Endif

Call GETDEV(GFCYDEF(5))  From DEVSUB
Call GLOBVAR(GFCYDEF(5),"VEN") From TRTX3

Return

#########################################################################
$INIT_DIA_TRTPACK
Raz [M:DIA]
[M:DIA]SSTOFCY=GFCYDEF(7)
[M:DIA]SSHIDAT=date$
[M:DIA]SVCRTYP=4
[M:DIA]SCOL=1
[M:DIA]SNONVAL=2
[M:DIA]SVAL=1
[M:DIA]SINV=1
Diszo [M:DIA]SINV
Return

#########################################################################
$TERMINE_TRTPACK

Return
#CHECK UNUSED_END
#########################################################################
# Détail des actions liées à la saisie fenêtre                          #
#########################################################################
#########################################################################
$OUVRE_TRTPACK

Global Integer  GPACSEQ : Raz GPACSEQ
Local  Integer  FINCOL, NBLIV, VOK : VOK = 1

#Local  Integer  ETABOU(1..GNBBOU), SAVOBJET
#Local  Char     SAVPROG(10), WCLECUR

Local  Char     WCLECUR
Local  Char     SYMBOLE

#---------------------------------------------------------------------#
# Variables utilisables par le point d'entrée                         #
#                                                                     #
# WCODTRT     : Traitement effectué "C" (Création), "A" (Annulation)  #
#---------------------------------------------------------------------#
Local Char WPOINT_CODTRT
Local  Char  CRIT(250)
TIT = mess(156,195,1)

If clalev([F:SPH]) = 0 Local File SPACK      [SPH] Endif
If clalev([F:SPD]) = 0 Local File SPACKD     [SPD] Endif
If clalev([F:TPA]) = 0 Local File TABPACKAGE [TPA] Endif
If clalev([F:BPD]) = 0 Local File BPDLVCUST  [BPD] Endif

# Issue X3-69499 - 2018-06-12 by TS
If clalev([F:ACV]) = 0 Local File ACTIV      [ACV] Endif
Global Integer GVALIDLIN  : # Niveau de validation de la livraison
                            #   1 = Ligne de livraison
                            #   0 = Livraison complète
GVALIDLIN=0
# Complète Delivery Validation "CDV"
Read [ACV] CODACT = "CDV"
If !fstat & [F:ACV]FLACT<>2
  GVALIDLIN=1
Endif
# End issue X3-69499

# Définition des critères de sélection des livraisons
#--- depuis le menu colisage
#CHECK UNUSED_BEGIN
If GACTION = "TRTPACK"
#  CRIT = "INVFLG<>2"
   CRIT= "1=1"
   If [M:DIA]SNUMDEB<>""      : CRIT -= '& SDHNUM>="'+[M:DIA]SNUMDEB+'"' : Endif
   If [M:DIA]SNUMFIN<>""      : CRIT -= '& SDHNUM<="'+[M:DIA]SNUMFIN+'"' : Endif
   If [M:DIA]SSTOFCY<>""      : CRIT -= '& STOFCY="'+[M:DIA]SSTOFCY+'"'  : Endif
   If [M:DIA]SSHIDAT<>[0/0/0] : CRIT -= "& SHIDAT<=["+format$(GFMD,[M:DIA]SSHIDAT)+"]" : Endif
   If [M:DIA]SBPCORDDEB<>""   : CRIT -= '& BPCORD>="'+[M:DIA]SBPCORDDEB+'"' : Endif
   If [M:DIA]SBPCORDFIN<>""   : CRIT -= '& BPCORD<="'+[M:DIA]SBPCORDFIN+'"' : Endif
   If [M:DIA]SBPAADDDEB<>""   : CRIT -= '& BPAADD>="'+[M:DIA]SBPAADDDEB+'"' : Endif
   If [M:DIA]SBPAADDFIN<>""   : CRIT -= '& BPAADD<="'+[M:DIA]SBPAADDFIN+'"' : Endif
   If [M:DIA]SCOL<>2          : CRIT -= "& PACFLG<>2" : Endif
   If [M:DIA]SNONVAL<>2       : CRIT -= "& CFMFLG=2"  : Endif
   If [M:DIA]SVAL<>2          : CRIT -= "& CFMFLG<>2" : Endif
   If [M:DIA]SINV<>2          : CRIT -= "& INVFLG<>2" : Endif
Endif
#CHECK UNUSED_END

#--- depuis la gestion des livraisons
If GACTION = "SAIPACK"
   CRIT = "SDHNUM=[M:SDH0]SDHNUM"
Endif

Return

#########################################################################
$SETBOUT_TRTPACK
If [M:SPK2]INVFLG=2
#    Raz ETABOU(GENRE)
#    Raz ETABOU(SUPP)
#    Raz ETABOU(GSPE1)
#    Raz ETABOU(GSPE2)
    Call VIREBOUT(CHBOU, "ES") From GOBJET
    Call VIREBOUT(CHMEN, "12") From GOBJET

    Return
Endif

#ETABOU(GENRE)=1
#ETABOU(GSUPP)=1
#If sum([M:SPK2]PACSEQ)=0 Raz ETABOU(GENRE) Endif
#If WLIGCOL=0             Raz ETABOU(GSUPP) Endif
If !instr(1,CHBOU,"E") CHBOU+= "E" Endif
If !instr(1,CHBOU,"S") CHBOU+= "S" Endif
If sum([M:SPK2]PACSEQ)=0 Call VIREBOUT(CHBOU, "E") From GOBJET : Endif
If WLIGCOL=0             Call VIREBOUT(CHBOU, "S") From GOBJET : Endif

Return

#########################################################################
$DEBUT_TRTPACK

Raz NBLIV
# Filtre sur les livraisons à traiter
Filter [SDH] Where evalue (CRIT)
Read [SDH]SDH0 First
If !fstat
    # Issue X3-69499 - 2018-06-12 by TS
    If GVALIDLIN=1 & [F:SDH]CFMFLG<>2
      Filter [SDD] Where SDHNUM=[F:SDH]SDHNUM & LINCFMFLG=2
      If rowcount([SDD])>0
        Filter [SDD]
        Goto NEXT_SDH
      Endif
      Filter [SDD]
   Endif
   # End issue X3-69499
   NBLIV += 1
   VOK = 2
   WCLECUR = [F:SDH]SDHNUM
   Gosub VERROU
   If VOK=1
      Goto NEXT_SDH
   Elsif VOK=0
      FIN=1 : Return
   Endif
Else
   FIN=1 : Return
Endif
Goto SUITE_SDH

$NEXT_SDH
Read [SDH]SDH0 Next
If !fstat
    # Issue X3-69499 - 2018-06-12 by TS
    If GVALIDLIN=1 & [F:SDH]CFMFLG<>2
      Filter [SDD] Where SDHNUM=[F:SDH]SDHNUM & LINCFMFLG=2
      If rowcount([SDD])>0
        Filter [SDD]
        Goto NEXT_SDH
      Endif
      Filter [SDD]
   Endif
   # End issue X3-69499
   NBLIV += 1
   VOK = 2
   WCLECUR = [F:SDH]SDHNUM
   Gosub VERROU
   If VOK=1
      Goto NEXT_SDH
   Elsif VOK=0
      FIN=1 : Return
   Endif
Else
   FIN=1 : Return
Endif

$SUITE_SDH
Gosub CHARGE_COLIS

If [M:SPK2]INVFLG=2
    Diszo [M:SPK2]1-99
Else
    Actzo [M:SPK2]1-99
    If GFRENUM=0 Grizo [M:SPK2]CARPLIFLG Endif
Endif

# Il n'y a rien à traiter
If [M:SPK2]NBLIG = 0
   Gosub DEVERROU
   Goto NEXT_SDH
Endif

Return

#####################################################
# Chargement de l'écran de colisage de la livraison #
#####################################################
$CHARGE_COLIS

Local Integer I, J, OK, REPONSE, WNBCOL, WPACSEQ
Local Integer WLIGCOL       : # Nb lignes écrans déjà colisées
Local Decimal WQTECOL       : # Qté déjà colisée sur une ligne de liv
Local Decimal WQTACOL       : # Qté à coliser en automatique sur une ligne de liv
Local Integer WDACDLV       : # No élément facturation dans livraison pour colisage
Local Char    RACINE

Call GETDEV([F:SDH]SALFCY)  From DEVSUB
Call GLOBVAR([F:SDH]SALFCY,"VEN") From TRTX3

# Récupération de l'élément de facturation à alimenter avec le montant des colis
#Raz WDACDLV
#If GPCKNUM <> 0
#   Read [SFI]SFI0=GPCKNUM
#   If !fstat
#      WDACDLV = [F:SFI]DACDLV
#   Endif
#Endif

Raz [M:SPK2]
nolign = 0

[M:SPK2]       = [F:SDH]
[M:SPK2]VCRTYP = 4
[M:SPK2]VCRNUM = [F:SDH]SDHNUM

If [F:SDH]BPDNAM(0) <> ""
    [M:SPK2]BPDNAM = [F:SDH]BPDNAM(0)
Else
    If clalev([F:BPD])=0 Local File BPDLVCUST [BPD] Endif
    If [F:BPD]BPCNUM <> [F:SDH]BPCORD | [F:BPD]BPAADD <> [F:SDH]BPAADD
       Read [BPD]BPD0 = [F:SDH]BPCORD;[F:SDH]BPAADD
       If fstat : Raz [F:BPD]: Endif
    Endif
    [M:SPK2]BPDNAM = [F:BPD]BPDNAM
Endif

# Alimentation de l'écran des détails colis
RACINE=""
# A partir des détails colis déjà existant
For [SPD]SPD0 Where VCRTYP=4 & VCRNUM=[F:SDH]SDHNUM
    nolign += 1
    [M:SPK2] = [F:SPD]

    If nolign = 1 & len([F:SPD]PACNUM) > 4
       If mid$([F:SPD]PACNUM,len([F:SPD]PACNUM)-4,1)="-"
          RACINE = left$([F:SPD]PACNUM,len([F:SPD]PACNUM)-5)
       Else
          RACINE=""
       Endif
    Elsif RACINE <> ""
       If len([F:SPD]PACNUM) > 4
          If RACINE <> left$([F:SPD]PACNUM,len([F:SPD]PACNUM)-5)
             RACINE = ""
          Endif
       Else
          RACINE = ""
       Endif
    Endif

Next

[M:SPK2]PACRAC = RACINE

WLIGCOL = nolign
# Sauvegarde du dernier no ordre
If WLIGCOL <> 0
   WPACSEQ = [M:SPK2]PACSEQ(nolign-1)
Endif
# A partir des détails livraison restant à coliser
If WLIGCOL = 0
   # Rien n'était colisé
   For [SDD]SDD0 Where SDHNUM=[F:SDH]SDHNUM
      nolign  += 1
      [M:SPK2] = [F:SDD]
      [M:SPK2]VCRLIN(nolign-1) = [F:SDD]SDDLIN
      [M:SPK2]VCRSEQ(nolign-1) = 0
      # Colisage automatique si emballage et capacité sont renseignés
      If [M:SPK2]PCK(nolign-1) <> "" & [M:SPK2]PCKCAP(nolign-1) <> 0
         Gosub COLIS_AUTO
      Endif
   Next
Else
   # Il y avait déjà du colisage
   For [SDD]SDD0 Where SDHNUM=[F:SDH]SDHNUM
      Raz WQTECOL
      For I = 0 To WLIGCOL-1
         If [M:SPK2]VCRLIN(I) = [F:SDD]SDDLIN
            WQTECOL += [M:SPK2]QTY(I)
         Endif
      Next I
      If WQTECOL < [F:SDD]QTY
         nolign += 1
         [M:SPK2] = [F:SDD]
         [M:SPK2]VCRLIN(nolign-1) = [F:SDD]SDDLIN
         [M:SPK2]VCRSEQ(nolign-1) = 0
         [M:SPK2]QTY(nolign-1) = [F:SDD]QTY - WQTECOL
         # Colisage automatique si emballage et capacité sont renseignés
         If [M:SPK2]PCK(nolign-1) <> "" & [M:SPK2]PCKCAP(nolign-1) <> 0
            Gosub COLIS_AUTO
         Endif
      Endif
   Next
Endif
[M:SPK2]NBLIG = nolign
# Il n'y a rien à traiter
If [M:SPK2]NBLIG = 0 Return Endif

# Alimentation du nombre de colis
[M:SPK2]PACNBR = max([M:SPK2]PACSEQ(0..[M:SPK2]NBLIG-1))

Affzo [M:SPK2]1-99
Grizo VCRTYP

Return

#------------------------------------------------#
# Colisage automatique d'une ligne de livraison  #
#------------------------------------------------#
$COLIS_AUTO

WNBCOL = int([M:SPK2]QTY(nolign-1)/[M:SPK2]PCKCAP(nolign-1))
If mod([M:SPK2]QTY(nolign-1),[M:SPK2]PCKCAP(nolign-1)) <> 0
   WNBCOL += 1
Endif

If WNBCOL <> 0
   WQTACOL = [M:SPK2]QTY(nolign-1)
   If WQTACOL > [M:SPK2]PCKCAP(nolign-1)
      [M:SPK2]QTY(nolign-1)    = [M:SPK2]PCKCAP(nolign-1)
      WQTACOL -= [M:SPK2]QTY(nolign-1)
      Gosub ALIM_PAC
      For J = 2 To WNBCOL
         nolign += 1
         [M:SPK2] = [F:SDD]
         [M:SPK2]VCRLIN(nolign-1) = [F:SDD]SDDLIN
         [M:SPK2]VCRSEQ(nolign-1) = 0
         If WQTACOL > [M:SPK2]QTY(nolign-2)
            [M:SPK2]QTY(nolign-1) = [M:SPK2]QTY(nolign-2)
         Else
            [M:SPK2]QTY(nolign-1) = WQTACOL
         Endif
         WQTACOL -= [M:SPK2]QTY(nolign-1)
         Gosub ALIM_PAC
      Next J
   Else
      Gosub ALIM_PAC
   Endif
Endif

Return

# Alimentation no séquence et colis
$ALIM_PAC
WPACSEQ += 1
[M:SPK2]PACSEQ(nolign-1) = WPACSEQ
If [M:SPK2]PACRAC <> ""
   [M:SPK2]PACNUM(nolign-1) = [M:SPK2]PACRAC+"-"+format$("N0:4",WPACSEQ)
Endif

Return

# Verrouillage de la livraison
$VERROU
SYMBOLE = "SDH"+[F:SDH]SDHNUM
Lock = SYMBOLE With lockwait = 0
If fstat = 1
   Call ECR_TRACE([F:SDH]SDHNUM-mess(10,100,1),1) From GESECRAN
   VOK = 1
Elsif fstat
   Call ECR_TRACE(mess(150,199,1)-"$SDELIVERY",1) From GESECRAN
   VOK = 0
Endif
Return

# Déverrouillage de la livraison
$DEVERROU
Unlock = SYMBOLE
Return

#########################################################################
$AP_CHOIX_TRTPACK

Raz FINCOL

Return

#########################################################################
$AVANT_ENR_TRTPACK

Global Libelle GPACLBE
GPACLBE = [M]PACLBE

# La livraison n'est pas entièrement colisée
If find(0,[M:SPK2]PACSEQ(0..[M:SPK2]NBLIG-1))
#--- à changer si le gosub EXEACT s'éxécute après ACTION = ACT (dans GSAISIE) ---
#   GERR=2
   GERR=3
#--- fin du changement ----------------------------------------------------------
   GMESSAGE=mess(57,191,1)

#--- à changer si le gosub EXEACT s'éxécute après ACTION = ACT (dans GSAISIE) ---
   Local Integer WOK : WOK=2
   Call AVERTIR(GMESSAGE, WOK) From GESECRAN
   Raz GMESSAGE : If WOK=1 Return Endif
#--- fin du changement ----------------------------------------------------------
Endif

#--- à changer si le gosub EXEACT s'éxécute après ACTION = ACT (dans GSAISIE) ---
#    EXEACT execute l'action SAIPACKLBE branchée sur le bouton enregistrer de la fenetre FPACK
#    SAIPACKLBE est l'action d'impression des étiquettes, EXEACT est executé avant ACTION=ACT
#    il faut donc que le colisage ait déjà été enregsitré
Gosub ENR_COLISAGE
Gosub DEVERROU
#--- fin du changement ----------------------------------------------------------

Return

#########################################################################
$ENR_TRTPACK

#--- à changer si le gosub EXEACT s'éxécute après ACTION = ACT (dans GSAISIE) ---
#    EXEACT execute l'action SAIPACKLBE branchée sur le bouton enregistrer de la fenetre FPACK
#    SAIPACKLBE est l'action d'impression des étiquettes, EXEACT est executé avant ACTION=ACT
#    c'est trop tard pour enregistrer le colisage (fait en AVANT_ENR)
#Gosub ENR_COLISAGE
#Gosub DEVERROU
#--- fin du changement ----------------------------------------------------------
If GACTION="TRTPACK"
   Gosub NEXT_SDH
Else
   FIN=1
Endif
Return

#####################################################
# Enregistrement du colisage                        #
#####################################################
$ENR_COLISAGE
Local Integer NOL, WPACSEQ, WONE, WNBCOL, WSTAT
Local Decimal WPCKWEI      : # Tare du colis
Local Decimal WUNTWEI      : # Poids unitaire de l'article
Local Decimal WNETWEI      : # Poids net du colis
Local Decimal WSDHNETWEI   : # Poids net de la livraison
Local Decimal WSDHGROWEI   : # Poids brut de le livraison
Local Decimal WVOL         : # Volume du colis
Local Decimal WSDHVOL      : # Volume de la livraison
Local Char    WVOU(3)      : # Unité volume

WONE = 2

Sorta [M:SPK2]NBLIG [M:SPK2]NBLIG Order By [M:SPK2]PACSEQ(indice),
&                   [M:SPK2]VCRLIN(indice),[M:SPK2]VCRSEQ(indice)

Call DEBTRANS From GLOCK
GOK = 1
Trbegin [SPH]
#-----------------------#
# Suppression des colis #
#-----------------------#
Delete [SPH] Where VCRTYP=4 & VCRNUM=[F:SDH]SDHNUM
Delete [SPD] Where VCRTYP=4 & VCRNUM=[F:SDH]SDHNUM

#   ---------------------------------------------------------------------#
#   Point d'entree à la mise à jour d'un détail colis                    #
#   ---------------------------------------------------------------------#
WPOINT_CODTRT="A"
GPOINT="PACKDETMAJ" : Gosub ENTREE From EXEFNC
If GOK < 1 Goto ABORT : Endif

#-----------------------#
# Création des colis    #
#-----------------------#
For nolign=1 To [M:SPK2]NBLIG
   # La ligne n'est pas colisée
   If [M:SPK2]PACSEQ(nolign-1) = 0 Goto NEXT_NOLIGN Endif

   # Ecriture du colis (après traitement de ses détails)
   If [M:SPK2]PACSEQ(nolign-1) <> WPACSEQ
      If WPACSEQ <> 0
         Gosub MAJ_SPH
         If GOK = 0 Break Endif
      Endif
      WPACSEQ = [M:SPK2]PACSEQ(nolign-1)
      WITMREF = [M:SPK2]ITMREF(nolign-1)
   Endif

   # Ecriture du détail colis
   [F:SPD] = [M:SPK2]

   If dim([F:SPD]CPY)>0 : [F:SPD]CPY=GSOCIETE : Endif

   [F:SPD]CREDAT = date$
   [F:SPD]CREUSR = GUSER
   [F:SPD]EXPNUM = [C]EXPORT

#   ---------------------------------------------------------------------#
#   Point d'entree à la mise à jour d'un détail colis                    #
#   ---------------------------------------------------------------------#
    WPOINT_CODTRT="C"
    GPOINT="PACKDETMAJ" : Gosub ENTREE From EXEFNC
    If GOK < 1 Break : Endif

   Write [SPD]
   If fstat Call FSTA("SPD") From GLOCK : GOK=0 : Break Endif

   # Lecture table emballage et détail livraison
   If [F:TPA]PCK <> [F:SPD]PCK
      Read [TPA]TPA0=[F:SPD]PCK
      If fstat GOK = 0 : Call RSTA("TPA",[F:SPD]PCK) From GLOCK : Break Endif
   Endif
   If [F:SDD]SDHNUM <> [F:SPD]VCRNUM | [F:SDD]SDDLIN <> [F:SPD]VCRLIN
      Read [SDD]SDD0=[F:SPD]VCRNUM;[F:SPD]VCRLIN
      If fstat GOK = 0
         Call RSTA("SDD",[F:SPD]VCRNUM-num$([F:SPD]VCRLIN)) From GLOCK
         Break
      Endif
   Endif

   # Calcul poids net et unicité article pour maj colis
   If [F:TPA]WEU="" [F:TPA]WEU=[F:SDH]WEU Endif

   If [F:SDD]WEU <> "" & [F:TPA]WEU <> ""
      WUNTWEI = [F:SDD]UNTWEI
      If [F:SDD]WEU = [F:TPA]WEU
         WNETWEI += [F:SPD]QTY * WUNTWEI
      Else
         # Conversion poids unitaire de unité poids liv en unité poids colis
         Call SCONV_TCO([F:SDD]WEU,[F:TPA]WEU,WUNTWEI) From TRTVENQTE
         WNETWEI += [F:SPD]QTY * WUNTWEI
      Endif
   Endif
   If [F:SPD]ITMREF <> WITMREF
      WONE = 1
   Endif

$NEXT_NOLIGN
Next nolign

If GOK = 0 Goto ABORT Endif

If WPACSEQ=0 Commit : Return Endif

# Ecriture du dernier colis (après traitement de ses détails)
Gosub MAJ_SPH
If GOK = 0 Goto ABORT Endif

WVOU = [F:SDH]VOU
# Réécriture de la livraison
Readlock [SDH]SDH0=WCLECUR
If fstat
   GOK = 0 : Call RSTA("SDH",WCLECUR) From GLOCK : Goto ABORT
Endif

Local Integer IJL
IJL=sum(([F:SDH]GROWEI<>WSDHGROWEI),
&       ([F:SDH]VOL<>WSDHVOL),([F:SDH]VOU<>WVOU),
&       ([F:SDH]BPTNUM<>[M:SPK2]BPTNUM))

[F:SDH]PACFLG = 2
[F:SDH]PACNBR = WNBCOL
[F:SDH]NETWEI = WSDHNETWEI
[F:SDH]GROWEI = WSDHGROWEI
[F:SDH]VOL    = WSDHVOL
[F:SDH]VOU    = WVOU
[F:SDH]BPTNUM = [M:SPK2]BPTNUM

If [M:SPK2]CARPLIFLG=2 & IJL
   Gosub RECH_TARIF_TRSP From TRTVENLIV
Endif

Rewrite [SDH]

Commit

Return

#-----------------------------------------------------#
# Ecriture du colis (après traitement de ses détails) #
# et calcul cumuls pour maj entête livraison          #
#-----------------------------------------------------#
$MAJ_SPH

[F:SPH]       = [F:TPA]
If [F:SPH]VOU = ""
   Raz WVOL
Else
   WVOL = [F:TPA]VOL
Endif
# Conversion prix emballage
If [F:SDH]CUR <> GSYSCUR
   Call CONVERT(GSYSCUR,[F:SDH]CUR,GSYSCUR,[F:SDH]CHGTYP,date$,
&               [F:TPA]PCKPRI,[F:SPH]PCKPRI,WSTAT) From TRTDEV
Endif
[F:SPH]CUR    = [F:SDH]CUR
[F:SPH]CHGTYP = [F:SDH]CHGTYP

[F:SPH]       = [F:SPD]

If dim([F:SPH]CPY)>0 : [F:SPH]CPY=GSOCIETE : Endif

[F:SPH]NETWEI    = WNETWEI
[F:SPH]ONEITMFLG = WONE

Write [SPH]
If fstat
   GOK = 0 : Call FSTA("SPH") From GLOCK : Return
Endif

# Incrémentation nombre de colis de la livraison
WNBCOL += 1
# Incrémentation poids net et brut de la livraison
If [F:SPH]WEU <> "" & [F:SDH]WEU <> ""
   If [F:SPH]WEU = [F:SDH]WEU
      WSDHNETWEI += WNETWEI
      WSDHGROWEI += WNETWEI + [F:SPH]PCKWEI
   Else
      # Conversion poids unitaire de unité poids colis en unité poids entête liv
      Call SCONV_TCO([F:SPH]WEU,[F:SDH]WEU,WNETWEI) From TRTVENQTE
      WSDHNETWEI += WNETWEI
      WPCKWEI     = [F:SPH]PCKWEI
      Call SCONV_TCO([F:SPH]WEU,[F:SDH]WEU,WPCKWEI) From TRTVENQTE
      WSDHGROWEI += WNETWEI + WPCKWEI
   Endif
Endif
# Incrémentation volume de la livraison
If [F:SPH]VOU <> ""
   If [F:SDH]VOU="" [F:SDH]VOU=[F:SPH]VOU Endif
   If [F:SPH]VOU = [F:SDH]VOU
      WSDHVOL += WVOL
   Else
      # Conversion volume colis en unité volume entête liv
      Call SCONV_TCO([F:SPH]VOU,[F:SDH]VOU,WVOL) From TRTVENQTE
      WSDHVOL += WVOL
   Endif
Endif

# Raz poids net, volume et unicité article du colis
Raz WNETWEI, WVOL
WONE = 2

Return

# Rollback suite à erreur
$ABORT
Rollback

Return

#########################################################################
$SUP_TRTPACK

Gosub ANU_COLISAGE
Gosub DEVERROU
Gosub NEXT_SDH

Return

#####################################################
# Annulation du colisage                            #
#####################################################
$ANU_COLISAGE

Call DEBTRANS From GLOCK
GOK = 1
Trbegin [SPH]

# Suppression des colis
Delete [SPH] Where VCRTYP=4 & VCRNUM=[F:SDH]SDHNUM
Delete [SPD] Where VCRTYP=4 & VCRNUM=[F:SDH]SDHNUM

#   ---------------------------------------------------------------------#
#   Point d'entree à la mise à jour d'un détail colis                    #
#   ---------------------------------------------------------------------#
WPOINT_CODTRT="A"
GPOINT="PACKDETMAJ" : Gosub ENTREE From EXEFNC
If GOK < 1 Goto ABORT : Endif


# Réécriture de la livraison
Readlock [SDH]SDH0=WCLECUR
If fstat
   GOK = 0 : Call RSTA("SDH",WCLECUR) From GLOCK : Goto ABORT
Endif
[F:SDH]PACFLG = 1
Raz [F:SDH]VOL
Raz [F:SDH]PACNBR
[F:SDH]GROWEI=[F:SDH]NETWEI
Rewrite [SDH]

Commit

Return

#########################################################################
$AVANT_SUI_TRTPACK

If ETABOU(GENRE) = 1
   GERR=3
   GMESSAGE=mess(60,191,1)
Endif

Return

#########################################################################
$SUI_TRTPACK

Gosub DEVERROU
Gosub NEXT_SDH

Return

#########################################################################
$FIN_TRTPACK

Gosub DEVERROU
Filter [SDH]

Return

#########################################################################
# Fenêtre colisage manuel
#########################################################################
$DEBUT_SAIPACKMAN
Local Integer I, J, NOL, OK
Local Decimal WQTYCOL

NOL = nolign-1
If nolign > [M:SPK2]NBLIG : FIN=1 : Return : Endif

Raz [M:SPK3]
[M:SPK3]XITMREF  = [M:SPK2]ITMREF(NOL)
[M:SPK3]XITMDES1 = [M:SPK2]ITMDES1(NOL)
[M:SPK3]XQTACOL  = [M:SPK2]QTY(NOL)
[M:SPK3]XSAU     = [M:SPK2]SAU(NOL)

# Pas de saisie du no colis s'il y a une racine
If [M:SPK2]PACRAC <> "" Diszo [M:SPK3]XPACNUM Endif

Affzo [M:SPK3]1-99

Return

#########################################################################
$OK_SAIPACKMAN

If [M:SPK3]XNBLIG=0 : FIN=1 : Return : Endif

nolign = NOL+1
# Contrôle que l'on peut insérer les lignes dans le tableau
If [M:SPK2]NBLIG + [M:SPK3]XNBLIG > dim([M:SPK2]NUMLIG)-1
   GERR=1 : GMESSAGE=mess(122,199,1) : Return
   End
Endif
# Insertion des lignes
Insa nolign,[M:SPK3]XNBLIG,[M:SPK2]NBLIG+[M:SPK3]XNBLIG-1 [M:SPK2]NBLIG
[M:SPK2]NBLIG += [M:SPK3]XNBLIG
nolign = NOL+2
#status = 0

# Alimentation des nouvelles lignes
Raz J
For I = NOL+1 To NOL+[M:SPK3]XNBLIG
   [M:SPK2]ITMREF(I)  = [M:SPK2]ITMREF(NOL)
   [M:SPK2]ITMDES1(I) = [M:SPK2]ITMDES1(NOL)
   [M:SPK2]PCK(I)     = [M:SPK3]XPCK(J)
   [M:SPK2]QTY(I)     = [M:SPK3]XQTY(J)
   [M:SPK2]SAU(I)     = [M:SPK2]SAU(NOL)
   [M:SPK2]PACSEQ(I)  = [M:SPK3]XPACSEQ(J)
   [M:SPK2]PACNUM(I)  = [M:SPK3]XPACNUM(J)
   [M:SPK2]VCRLIN(I)  = [M:SPK2]VCRLIN(NOL)
   [M:SPK2]VCRSEQ(I)  = [M:SPK2]VCRSEQ(NOL)
   [M:SPK2]PCKCAP(I)  = [M:SPK2]PCKCAP(NOL)
   WQTYCOL += [M:SPK3]XQTY(J)
   J += 1
Next I

# Suppression ou maj de la ligne initiale
If WQTYCOL = [M:SPK2]QTY(NOL)
   Dela NOL,1 [M:SPK2]NBLIG
   [M:SPK2]NBLIG  -= 1
Else
   [M:SPK2]QTY(NOL) -= WQTYCOL
Endif

# Alimentation du nombre de colis
[M:SPK2]PACNBR = max([M:SPK2]PACSEQ(0..[M:SPK2]NBLIG-1))

FIN=1

Return

#########################################################################
$FINSAI_SAIPACKMAN

If [M:SPK2]PACSEQ(NOL) = 0
   Raz GBOUT3                     : # Annulation colisage
Else
   Raz GBOUT1                     : # Colisage manuel
   Raz GBOUT2                     : # Colisage automatique
Endif

#Affzo [M:SPK2]10,20

# Agrégation des lignes
Gosub AGREG_LIG
#Affzo [M:SPK2]10
Affzo [M:SPK2]10,20

mkstat=4

Return

#########################################################################
# Fenêtre colisage automatique
#########################################################################
$DEBUT_SAIPACKAUT
Local Integer I, J, NOL, OK

NOL = nolign-1
If nolign > [M:SPK2]NBLIG : FIN=1 : Return : Endif

Raz [M:SPK4]
[M:SPK4]YITMREF  = [M:SPK2]ITMREF(NOL)
[M:SPK4]YITMDES1 = [M:SPK2]ITMDES1(NOL)
[M:SPK4]YQTACOL  = [M:SPK2]QTY(NOL)
[M:SPK4]YSAU     = [M:SPK2]SAU(NOL)
[M:SPK4]YPCK     = [M:SPK2]PCK(NOL)

Affzo [M:SPK4]1-99

Return

#########################################################################
$OK_SAIPACKAUT

If [M:SPK4]YNBCOL=0 : FIN=1 : Return : Endif

nolign = NOL+1
# Contrôle que l'on peut insérer les lignes dans le tableau
If [M:SPK2]NBLIG + [M:SPK4]YNBCOL > dim([M:SPK2]NUMLIG)-1
   GERR=1 : GMESSAGE=mess(122,199,1) : Return
Endif
# Insertion des lignes
Insa nolign,[M:SPK4]YNBCOL,[M:SPK2]NBLIG+[M:SPK4]YNBCOL-1 [M:SPK2]NBLIG
[M:SPK2]NBLIG += [M:SPK4]YNBCOL
nolign = NOL+2
#status = 0
# Alimentation des nouvelles lignes
Raz J
For I = NOL+1 To NOL+[M:SPK4]YNBCOL
   [M:SPK2]ITMREF(I)  = [M:SPK2]ITMREF(NOL)
   [M:SPK2]ITMDES1(I) = [M:SPK2]ITMDES1(NOL)
   [M:SPK2]PCK(I)     = [M:SPK4]YPCK
   [M:SPK2]QTY(I)     = [M:SPK4]YQTPCOL
   [M:SPK2]SAU(I)     = [M:SPK2]SAU(NOL)
   [M:SPK2]PACSEQ(I)  = [M:SPK4]YPACSEQ1 + J
   If [M:SPK2]PACRAC <> ""
      [M:SPK2]PACNUM(I) = [M:SPK2]PACRAC+"-"+format$("N0:4",[M:SPK4]YPACSEQ1+J)
#   Else
#      [M:SPK2]PACNUM(I) = format$("N0:4",[M:SPK4]YPACSEQ1+J)
   Endif
   [M:SPK2]VCRLIN(I)  = [M:SPK2]VCRLIN(NOL)
   [M:SPK2]VCRSEQ(I)  = [M:SPK2]VCRSEQ(NOL)
   [M:SPK2]PCKCAP(I)  = [M:SPK2]PCKCAP(NOL)
   J += 1
   # Quantité du dernier colis
   If J = [M:SPK4]YNBCOL
      [M:SPK2]QTY(I) = [M:SPK2]QTY(NOL) - [M:SPK4]YQTPCOL*([M:SPK4]YNBCOL-1)
   Endif
Next I

# Suppression de la ligne initiale
Dela NOL,1 [M:SPK2]NBLIG
[M:SPK2]NBLIG  -= 1
# Alimentation du nombre de colis
[M:SPK2]PACNBR = max([M:SPK2]PACSEQ(0..[M:SPK2]NBLIG-1))

FIN=1

Return

#########################################################################
$FINSAI_SAIPACKAUT

If [M:SPK2]PACSEQ(NOL) = 0
   Raz GBOUT3                     : # Annulation colisage
Else
   Raz GBOUT1                     : # Colisage manuel
   Raz GBOUT2                     : # Colisage automatique
Endif

#Affzo [M:SPK2]10,20

# Agrégation des lignes
Gosub AGREG_LIG
#Affzo [M:SPK2]10
Affzo [M:SPK2]10,20

mkstat=4

Return

#########################################################################
# Détail des actions liées aux traitements divers                       #
#########################################################################
#----------------------------------
# Bouton bas écran : Tri par colis
#----------------------------------
$TRICOL
Sorta [M:SPK2]NBLIG [M:SPK2]NBLIG Order By [M:SPK2]PACNUM(indice),
&                   [M:SPK2]ITMREF(indice),[M:SPK2]VCRLIN(indice)
Affzo 10
Return

#--------------------------------------
# Bouton bas écran : Tri par emballage
#--------------------------------------
$TRIEMB
Sorta [M:SPK2]NBLIG [M:SPK2]NBLIG Order By [M:SPK2]PCK(indice),
&                   [M:SPK2]ITMREF(indice),[M:SPK2]PACNUM(indice)
Affzo 10
Return

#---------------------------------------------------
# Avant zone : Colorisation des lignes non colisées
#---------------------------------------------------
$DIVCOLOR

pcolor = GCOUL(0)
If [M:SPK2]PACSEQ(nolign-1) = 0 pcolor = GCOUL(1) Endif
Return

#----------------------------------
# Bouton3 : Annulation du colisage
#----------------------------------
$DIVANUPACK
Local Integer I, J, NOL, OK
Local Integer WNBCOL
Local Decimal WQTYCOL

NOL = nolign-1
I = find([M:SPK2]VCRLIN(NOL),[M:SPK2]VCRLIN(0..NOL-1),
&                            [M:SPK2]VCRLIN(NOL+1..[M:SPK2]NBLIG-1))
# C'était la seule ligne de colis pour cette ligne de livraison
If I = 0
   # Retassement des no séquence
   Gosub RETASSE_SEQ
   Raz [M:SPK2]PCK(NOL)
   Raz [M:SPK2]PACSEQ(NOL)
   Raz [M:SPK2]PACNUM(NOL)
   Raz [M:SPK2]PCKCAP(NOL)
# Il y a d'autres lignes de colis pour cette ligne de livraison
Else
   OK = 0
   For J = 0 To [M:SPK2]NBLIG-1
      # C'est la partie de ligne de livraison qui n'est pas colisée
      If [M:SPK2]VCRLIN(J) = [M:SPK2]VCRLIN(NOL) & [M:SPK2]PACSEQ(J) = 0
         # Incrémentation de la quantité
         [M:SPK2]QTY(J) += [M:SPK2]QTY(NOL)
         # Retassement des no séquence
         Gosub RETASSE_SEQ
         # Suppression de la ligne de colisage
         Dela NOL,1 [M:SPK2]NBLIG
         [M:SPK2]NBLIG -= 1
         OK = 1
         Break
      Endif
   Next J
   # Toute la ligne de livraison était colisée, raz de la ligne de colisage
   If OK = 0
      # Retassement des no séquence
      Gosub RETASSE_SEQ
      Raz [M:SPK2]PCK(NOL)
      Raz [M:SPK2]PACSEQ(NOL)
      Raz [M:SPK2]PACNUM(NOL)
      Raz [M:SPK2]PCKCAP(NOL)
   Endif
Endif

# Alimentation du nombre de colis
[M:SPK2]PACNBR = max([M:SPK2]PACSEQ(0..[M:SPK2]NBLIG-1))

If [M:SPK2]PACSEQ(NOL) = 0
   Raz GBOUT3                     : # Annulation colisage
Else
   Raz GBOUT1                     : # Colisage manuel
   Raz GBOUT2                     : # Colisage automatique
Endif

Affzo [M:SPK2]10,20
mkstat=4
Return

#------------------------------
# Retassement des no séquence
#------------------------------
$RETASSE_SEQ

J = find([M:SPK2]PACSEQ(NOL),[M:SPK2]PACSEQ(0..NOL-1),
&                            [M:SPK2]PACSEQ(NOL+1..[M:SPK2]NBLIG-1))
# Retassement des no séquence s'il était unique
If J = 0
   For J = 0 To [M:SPK2]NBLIG-1
      If [M:SPK2]PACSEQ(J) > [M:SPK2]PACSEQ(NOL)
         [M:SPK2]PACSEQ(J) -= 1
#         val(mid$([M:SPK2]PACNUM(J),len([M:SPK2]PACNUM(J)-3),4)) -= 1
         If [M:SPK2]PACRAC <> ""
            [M:SPK2]PACNUM(J) = [M:SPK2]PACRAC+"-"+format$("N0:4",[M:SPK2]PACSEQ(J))
#         Else
#            [M:SPK2]PACNUM(J) = format$("N0:4",[M:SPK2]PACSEQ(J))
         Endif
      Endif
  Next J
Endif
Return

#--------------------------------------------------------------
# Agrégation des lignes de colis (caractéristiques identiques)
#--------------------------------------------------------------
$AGREG_LIG
Local Integer I,J
I = 1
$AGREG_DEB
If I > [M:SPK2]NBLIG-1 Return Endif
For J = I To [M:SPK2]NBLIG-1
   If [M:SPK2]VCRLIN(J)=[M:SPK2]VCRLIN(I-1) & [M:SPK2]PACSEQ(J)=[M:SPK2]PACSEQ(I-1)
      [M:SPK2]QTY(I-1) += [M:SPK2]QTY(J)
      Dela J,1 [M:SPK2]NBLIG
      [M:SPK2]NBLIG -= 1
      I -= 1
      Break
   Endif
Next J
I += 1
Goto AGREG_DEB

Return

#-------------------------------------------------#
# Actions sur les champs de l'écran SPACK1        #
#-------------------------------------------------#
#CHECK UNUSED_BEGIN
######################################## Obligatoire
Subprog AP_SSTOFCY(VALEUR)
Variable Char    VALEUR()
Diszo [M:DIA]SVCRTYP
If [M]SVAL=2
    Actzo [M]SINV
Else
    Diszo [M]SINV
Endif
End
#CHECK UNUSED_END

######################################## Obligatoire
Subprog AM_SNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]SNUMFIN = VALEUR : Affzo [M]SNUMFIN : Endif
End

######################################## Obligatoire
Subprog AM_SBPCORDDEB(VALEUR)
Variable Char    VALEUR()
#GBPCNUM = VALEUR
If VALEUR <> ""
   [M]SBPCORDFIN = VALEUR : Affzo [M]SBPCORDFIN : Actzo [M]SBPAADDDEB
Else
   Diszo [M]SBPAADDDEB
Endif
End

######################################## Obligatoire
Subprog AM_SBPAADDDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]SBPAADDFIN = VALEUR : Affzo [M]SBPAADDFIN Endif
End

######################################## Obligatoire
Subprog AP_SBPCORDFIN(VALEUR)
Variable Char    VALEUR()
#GBPCNUM = VALEUR
If VALEUR <> ""
   Actzo [M]SBPAADDFIN
Else
   Raz [M]SBPAADDFIN : Diszo [M]SBPAADDFIN
Endif
End

######################################## Obligatoire
Subprog C_SBPAADDFIN(VALEUR)
Variable Char    VALEUR()
If [M]SBPCORDDEB = [M]SBPCORDFIN
   If VALEUR  < [M]SBPAADDDEB
      GMESSAGE = mess(44,199,1) : mkstat = 2
   Endif
Endif
End

######################################## Obligatoire
Subprog AM_SNONVAL(VALEUR)
Variable Integer VALEUR
If VALEUR = 1 & [M]SVAL = 1
   [M]SVAL = 2
   Affzo [M]SVAL
   Actzo [M]SINV
Endif
End

######################################## Obligatoire
Subprog AM_SVAL(VALEUR)
Variable Integer VALEUR
If VALEUR = 1 & [M]SNONVAL = 1
   [M]SNONVAL = 2
   Affzo [M]SNONVAL
Endif
If VALEUR=2
    Actzo [M]SINV
Else
    Diszo [M]SINV
Endif
End

#-------------------------------------------------#
# Actions sur les champs de l'écran SPACK2        #
#-------------------------------------------------#

######################################## Obligatoire
Subprog AM_PACRAC(VALEUR)
Variable Char    VALEUR()
Local    Integer I

For I = 0 To [M:SPK2]NBLIG-1
   If [M:SPK2]PACSEQ(I) <> 0
      If VALEUR <> ""
         [M:SPK2]PACNUM(I) = VALEUR+"-"+format$("N0:4",[M:SPK2]PACSEQ(I))
      Else
#         [M:SPK2]PACNUM(I) = format$("N0:4",[M:SPK2]PACSEQ(I))
         [M:SPK2]PACNUM(I) = ""
      Endif
   Endif
Next I
Affzo 10

End

######################################## Obligatoire
Subprog IB_NBLIG
Local Integer NOL

NOL = nolign-1

If [M:SPK2]INVFLG=2 Raz GBOUT1, GBOUT2, GBOUT3 : End: Endif
If [M:SPK2]PACSEQ(NOL) = 0
   Raz GBOUT3                     : # Annulation colisage
Else
   Raz GBOUT1                     : # Colisage manuel
   Raz GBOUT2                     : # Colisage automatique
Endif

End
########################################
Subprog C_NBLIG

# Pour réajuster NBLIG
# --> Le dela effectué en APRES_NBLIG pose pb sur la dernière ligne du tableau
#     NBLIG n'est pas décrémenté
If [M:SPK2]NBLIG > 0
    If [M:SPK2]ITMREF([M]NBLIG-1)= "" [M:SPK2]NBLIG-=1 : Affzo [M:SPK2]10 Endif
#    Affzo [M:SPK2]10
Endif
#
End
######################################## Obligatoire
Subprog APRES_NBLIG
Local    Integer NOL, OK, I, J
NOL = nolign-1
Raz OK

# Le numéro de séquence a été modifié
If GPACSEQ=1
   Raz GPACSEQ
   If [M:SPK2]PACSEQ(NOL) <> 0
      I = find([M:SPK2]VCRLIN(NOL),[M:SPK2]VCRLIN(0..NOL-1),
&                                  [M:SPK2]VCRLIN(NOL+1..[M:SPK2]NBLIG-1))
      If I <> 0
         For J = 0 To [M:SPK2]NBLIG-1
            If J<>NOL
               # C'est la partie de ligne de livraison qui n'est pas colisée
               If [M:SPK2]VCRLIN(J) = [M:SPK2]VCRLIN(NOL) & [M:SPK2]PACSEQ(J) = [M:SPK2]PACSEQ(NOL)
                  # Incrémentation de la quantité
                  #[M:SPK2]QTY(J) += [M:SPK2]QTY(NOL)
                  [M:SPK2]QTY(NOL)   += [M:SPK2]QTY(J)
                  [M:SPK2]PACSEQ(NOL) = [M:SPK2]PACSEQ(J)
                  [M:SPK2]PACNUM(NOL) = [M:SPK2]PACNUM(J)
                  # Suppression de la ligne de colisage
                  #Dela NOL,1 [M:SPK2]NBLIG
                  Dela J,1 [M:SPK2]NBLIG
                  [M:SPK2]NBLIG -= 1
                  OK = 1
                  Break
               Endif
            Endif
         Next J
#        Affzo 10
      Endif
     Affzo 10
   Endif
Endif

If [M:SPK2]PCK(nolign-1)="" | [M:SPK2]PACSEQ(nolign-1)=0
   Raz [M:SPK2]PCK(nolign-1)
   Raz [M:SPK2]PACSEQ(nolign-1)
   Raz [M:SPK2]PACNUM(nolign-1)
#  La ligne n'est pas colisée : Il faut réafficher la ligne en rouge
   Affzo [M:SPK2]ITMREF(nolign-1), ITMDES1(nolign-1), QTY(nolign-1), SAU(nolign-1)
   Affzo [M:SPK2]PCK(nolign-1), PACSEQ(nolign-1), PACNUM(nolign-1)
Endif

[M:SPK2]PACNBR = max([M:SPK2]PACSEQ(0..[M:SPK2]NBLIG-1))
Affzo 20

#Affzo 10,20
End

######################################## Obligatoire
Subprog AS_PCK(VALEUR)
Variable Char    VALEUR()

If VALEUR <> "" & [M:SPK2]PACSEQ(nolign-1) <> 0
   mkstat = 2
Endif
End

######################################## Obligatoire
Subprog C_PCK(VALEUR)
Variable Char    VALEUR()
Local    Integer I

# Si le no séquence n'a pas été saisi, pas de contrôle
If [M:SPK2]PACSEQ(nolign-1) = 0 End Endif
# Si ce no séquence existe déjà, vérification de la cohérence des codes emballage
If nolign <> 1
   I = find([M:SPK2]PACSEQ(nolign-1),[M:SPK2]PACSEQ(0..nolign-2))
Endif
If I <> 0
   If VALEUR <> [M:SPK2]PCK(I-1)
      GMESSAGE=mess(135,192,1) : mkstat = 2 : End
   Endif
Else
   If nolign <> [M:SPK2]NBLIG
      I = find([M:SPK2]PACSEQ(nolign-1),[M:SPK2]PACSEQ(nolign..[M:SPK2]NBLIG-1))
   Endif
   If I <> 0
      I += nolign
      If VALEUR <> [M:SPK2]PCK(I-1)
         GMESSAGE=mess(135,192,1) : mkstat = 2 : End
      Endif
   Endif
Endif
End

######################################## Obligatoire
Subprog AS_PACSEQ(VALEUR)
Variable Decimal VALEUR

If [M:SPK2]PCK(nolign-1) <> "" & VALEUR <> 0
   mkstat = 2
   End
Endif
If VALEUR = 0
   VALEUR = max([M:SPK2]PACSEQ(0..[M:SPK2]NBLIG-1)) + 1
Endif
End

######################################## Obligatoire
Subprog C_PACSEQ(VALEUR)
Variable Decimal VALEUR
Local    Integer I, NOL

# Traitement particulier s'il ni a qu'une ligne
If [M:SPK2]NBLIG = 1
   If VALEUR = 1
      End
   Else
      GMESSAGE=mess(136,192,1)
      mkstat = 2
      End
   Endif
Endif

# Passage en négatif du no séquence de la ligne traitée
[M:SPK2]PACSEQ(nolign-1) *= -1

# Si l'on est sur la dernière ligne, le no séquence doit être consécutif
# sinon il y a problème sur le dela de la dernière ligne (mauvais NBLIG)
#If nolign=[M:SPK2]NBLIG & VALEUR <= max([M:SPK2]PACSEQ(0..[M:SPK2]NBLIG-1))
#   GMESSAGE=mess(181,192,1) : mkstat = 2
#   [M:SPK2]PACSEQ(nolign-1) *= -1 : End
#Endif

# Le no séquence doit exister ou être consécutif
If VALEUR > max([M:SPK2]PACSEQ(0..[M:SPK2]NBLIG-1)) + 1
   GMESSAGE=mess(136,192,1) : mkstat = 2
   [M:SPK2]PACSEQ(nolign-1) *= -1 : End
Endif
# Si le code emballage n'a pas été saisi, pas de contrôle
If [M:SPK2]PCK(nolign-1) = ""
   [M:SPK2]PACSEQ(nolign-1) *= -1 : End
Endif

# Si ce no séquence existe déjà, vérification de la cohérence des codes emballage
I = find(VALEUR,[M:SPK2]PACSEQ(0..[M:SPK2]NBLIG-1))
If I <> 0
   If [M:SPK2]PCK(nolign-1) <> [M:SPK2]PCK(I-1)
      GMESSAGE=mess(135,192,1) : mkstat = 2
      [M:SPK2]PACSEQ(nolign-1) *= -1 : End
   Endif
Endif

# Restitution du no séquence de la ligne traitée
[M:SPK2]PACSEQ(nolign-1) *= -1

End

######################################## Obligatoire
Subprog AP_PACSEQ(VALEUR)
Variable Decimal VALEUR

Local Integer NOL  : NOL = nolign-1

If VALEUR <> 0
   If [M:SPK2]PACRAC <> ""
      [M:SPK2]PACNUM(NOL) = [M:SPK2]PACRAC+"-"+format$("N0:4",VALEUR)
#   Else
#      [M:SPK2]PACNUM(NOL) = format$("N0:4",VALEUR)
   Endif
Else
   Raz [M:SPK2]PACNUM(NOL)
Endif
Affzo [M:SPK2]PACNUM(NOL)

End

######################################## Obligatoire
Subprog AM_PACSEQ(VALEUR)
Variable Decimal VALEUR

GPACSEQ=1

End

######################################## Obligatoire
Subprog AS_PACNUM(VALEUR)
Variable Char    VALEUR()
# Pas de saisie du no colis s'il y a une racine
If [M:SPK2]PACRAC <> "" mkstat=2 Endif
End

#-------------------------------------------------#
# Actions sur les champs de l'écran SPACK3        #
#-------------------------------------------------#

######################################## Obligatoire
Subprog C_XNBLIG
Local Integer I, NOL

NOL = nolign-1
If find(status,73,82) & [M:SPK3]XNBLIG >= dim([M:SPK3]XNUMLIG)-1
   GMESSAGE=mess(122,199,1) : mkstat=2 : End
Endif
# Si suppression d'une ligne
If status = 65
   I = find([M:SPK3]XPACSEQ(NOL),[M:SPK3]XPACSEQ(0..NOL-1),[M:SPK3]XPACSEQ(NOL+1..[M:SPK3]XNBLIG-1))
   # Retassement des no séquence s'il était unique
   If I = 0
      For I=0 To [M:SPK3]XNBLIG-1
         If [M:SPK3]XPACSEQ(I) > [M:SPK3]XPACSEQ(nolign-1)
            [M:SPK3]XPACSEQ(I) -= 1
#            val(mid$([M:SPK3]XPACNUM(I),len([M:SPK3]XPACNUM(I)-3),4)) -= 1
            If [M:SPK2]PACRAC <> ""
               [M:SPK3]XPACNUM(I) = [M:SPK2]PACRAC+"-"+format$("N0:4",[M:SPK3]XPACSEQ(I))
#            Else
#               [M:SPK3]XPACNUM(I) = format$("N0:4",[M:SPK3]XPACSEQ(I))
            Endif
         Endif
      Next I
   Endif
   Affzo [M:SPK3]10
Endif
End

######################################## Obligatoire
Subprog AVANT_XNBLIG

[M:SPK3]XQTYCOL -= [M:SPK3]XQTY(nolign-1)
End

######################################## Obligatoire
Subprog APRES_XNBLIG

[M:SPK3]XQTYCOL += [M:SPK3]XQTY(nolign-1)
Affzo [M:SPK3]5
End

######################################## Obligatoire
Subprog C_XPCK(VALEUR)
Variable Char    VALEUR()
Local    Integer I

# Si le no séquence n'a pas été saisi, pas de contrôle
If [M:SPK3]XPACSEQ(nolign-1) = 0 End Endif
# Si ce no séquence existe déjà, vérification de la cohérence des codes emballage
If nolign <> 1
   I = find([M:SPK3]XPACSEQ(nolign-1),[M:SPK3]XPACSEQ(0..nolign-2))
Endif
# Contrôle cohérence dans écran colisage SPK3
If I <> 0
   If VALEUR <> [M:SPK3]XPCK(I-1)
      GMESSAGE=mess(135,192,1) : mkstat = 2 : End
   Endif
Else
   If nolign <> [M:SPK3]XNBLIG
      I = find([M:SPK3]XPACSEQ(nolign-1),[M:SPK3]XPACSEQ(nolign..[M:SPK3]XNBLIG))
   Endif
   If I <> 0
      I += nolign
      If VALEUR <> [M:SPK3]XPCK(I-1)
         GMESSAGE=mess(135,192,1) : mkstat = 2 : End
      Endif
   Else
      # Contrôle cohérence no séquence dans écran colisage SPK2
      I = find([M:SPK3]XPACSEQ(nolign-1),[M:SPK2]PACSEQ(0..[M:SPK2]NBLIG-1))
      If I <> 0
         If VALEUR <> [M:SPK2]PCK(I-1)
            GMESSAGE=mess(135,192,1) : mkstat = 2 : End
         Endif
      Endif
   Endif
Endif
End

######################################## Facultatif
Subprog AS_XQTY(VALEUR)
Variable Decimal VALEUR

If VALEUR = 0
   VALEUR = [M:SPK3]XQTACOL - [M:SPK3]XQTYCOL
Endif
End

######################################## Obligatoire
Subprog C_XQTY(VALEUR)
Variable Decimal VALEUR

If [M:SPK3]XQTYCOL + VALEUR > [M:SPK3]XQTACOL
   GMESSAGE = mess(69,192,1) : mkstat = 2
Endif
End

######################################## Facultatif
Subprog AS_XPACSEQ(VALEUR)
Variable Decimal VALEUR

If VALEUR = 0
   VALEUR = max(max([M:SPK3]XPACSEQ(0..[M:SPK3]XNBLIG))+1,max([M:SPK2]PACSEQ(0..[M:SPK2]NBLIG-1))+1)
Endif
End

######################################## Obligatoire
Subprog C_XPACSEQ(VALEUR)
Variable Decimal VALEUR
Local    Integer I

# Passage en négatif du no séquence de la ligne traitée
[M:SPK3]XPACSEQ(nolign-1) *= -1

# Le no séquence doit exister ou être consécutif
If VALEUR > max([M:SPK2]PACSEQ(0..[M:SPK2]NBLIG-1)) + 1 &
&  VALEUR > max([M:SPK3]XPACSEQ(0..[M:SPK3]XNBLIG)) + 1
   GMESSAGE=mess(136,192,1) : mkstat = 2
   [M:SPK3]XPACSEQ(nolign-1) *= -1 : End
Endif
# Si le code emballage n'a pas été saisi, pas de contrôle
If [M:SPK3]XPCK(nolign-1) = ""
   [M:SPK3]XPACSEQ(nolign-1) *= -1 : End
Endif

# Si ce no séquence existe déjà, vérification de la cohérence des codes emballage
I = find(VALEUR,[M:SPK3]XPACSEQ(0..[M:SPK3]XNBLIG))
If I <> 0
   If [M:SPK3]XPCK(nolign-1) <> [M:SPK3]XPCK(I-1)
      GMESSAGE=mess(135,192,1) : mkstat = 2
      [M:SPK3]XPACSEQ(nolign-1) *= -1 : End
   Endif
Else
   # Contrôle cohérence no séquence dans écran colisage SPK2
   I = find(VALEUR,[M:SPK2]PACSEQ(0..[M:SPK2]NBLIG-1))
   If I <> 0
      If [M:SPK3]XPCK(nolign-1) <> [M:SPK2]PCK(I-1)
         GMESSAGE=mess(135,192,1) : mkstat = 2
         [M:SPK3]XPACSEQ(nolign-1) *= -1 : End
      Endif
   Endif
Endif

# Restitution du no séquence de la ligne traitée
[M:SPK3]XPACSEQ(nolign-1) *= -1
End

######################################## Obligatoire
Subprog AP_XPACSEQ(VALEUR)
Variable Decimal VALEUR

Local    Integer NOL
NOL = nolign-1

If VALEUR <> 0
   If [M:SPK2]PACRAC <> ""
      [M:SPK3]XPACNUM(NOL) = [M:SPK2]PACRAC+"-"+format$("N0:4",VALEUR)
#   Else
#      [M:SPK3]XPACNUM(NOL) = format$("N0:4",VALEUR)
   Endif
Else
   Raz [M:SPK3]XPACNUM(NOL)
Endif
Affzo [M:SPK3]XPACNUM(NOL)
End

#-------------------------------------------------#
# Actions sur les champs de l'écran SPACK4        #
#-------------------------------------------------#

######################################## Obligatoire
Subprog C_YQTPCOL(VALEUR)
Variable Decimal VALEUR

If VALEUR > [M:SPK4]YQTACOL : mkstat = 2 : Endif
End

######################################## Obligatoire
Subprog AM_YQTPCOL(VALEUR)
Variable Decimal VALEUR

[M:SPK4]YNBCOL = int([M:SPK4]YQTACOL/VALEUR)
If mod([M:SPK4]YQTACOL,VALEUR) <> 0
   [M:SPK4]YNBCOL += 1
Endif
[M:SPK4]YPACSEQ1 = max([M:SPK2]PACSEQ(0..[M:SPK2]NBLIG-1)) + 1
[M:SPK4]YPACSEQ2 = [M:SPK4]YPACSEQ1 + [M:SPK4]YNBCOL - 1
Affzo [M:SPK4]15
End

