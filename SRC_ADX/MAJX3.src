#<AdxTL>@(#)0.0.0.0 $Revision$
Call MAJ
End

###################################################################
Subprog MAJ
Local Char    FICHIER(20) , ORDSYS(250) , PARAM(250)
Local Char    FICOLD(GLONATB) , FICNEW(GLONATB) , FICCOP(GLONATB+1)
Local Char    SRFORG(250) , SRFDES(250) , SRFSAV(250) , SRFCOP(250) , FICX3(250)
Local Char    LIGNE(250) , LIGSAV(250)(1..4) , CHAINE(250)
Local Integer I , J , K , STAT , NBLAN
Local Char    LANGUE(GLONLAN)(1..300)

Lock X3MAJ
If fstat=1 : # Y'a quelqu'un d'autre dans cette galère
 GOK = 0 : End
Endif

Local File ATABIND [ATI_]

Call TEMPON(mess(79,125,1)) From GESECRAN : # MAJ Superviseur

## Intégration/fusion des tables "W"

ORDSYS = adxmac(0)+'@lsadx -a '+nomap-' FIL fde'
Local File (FICHIER(GLONATB)) From System ORDSYS As [FIL_]

For [FIL_]
 If left$([FIL_]FICHIER,1)="W"
  FICNEW = [FIL_]FICHIER
  FICOLD = "A"+right$(FICNEW,2)
  FICCOP = "WW"+right$(FICNEW,2)
  Gosub FUSFIC
 Endif
Next FIL_

# Recherche des langues

Local File ATEXTE [ATX]
NBLAN = 0
For [ATX]NUMERO(1)
 NBLAN += 1
 LANGUE(NBLAN) = [F:ATX]LAN
Next
Close Local File [ATX]

## Transfert du menu X3

For I=1 To NBLAN
 If filinfo(filpath("M"+LANGUE(I),"X3","mnu",0),0)>=0
  Call COPIE(filpath("M"+LANGUE(I),"X3","mnu",0),filpath("M"+LANGUE(I),"ADMIN","mnu",0),STAT) From ORDSYS
  Call COPIEMEN(nomap,LANGUE(I),"X3","ADMIN") From VALCSTWEB
  Call EFFACE(filpath("M"+LANGUE(I),"X3","mnu",0),STAT) From ORDSYS
 Endif
Next I

## Mise à jour version des tables dossiers et batchs

Gosub RECADS
Gosub RECRQT
Gosub RECABT

#109897
If dim(GDOSX3)<0
 Global Char    GDOSX3(GLONADS)
Endif
Call PARAM("","SUPDOS",GDOSX3) From ADOVAL
If nomap=GDOSX3
 Call PATCH(nomap) From UTIMAJREPSRV
Endif

## Mise à jour fichier ADOSSIER

Local File ADOSSIER [ADS]
Trbegin [ADS]
 Update [ADS] Where TSTFLG=0 With TSTFLG=1
Commit
Close Local File [ADS]

## Effacement du fichier magique

FICX3 = filpath("","X3","new",0)
Call EFFACE(FICX3,STAT) From ORDSYS

Unlock X3MAJ
GOK = 1
Call TEMPOFF From GESECRAN
End

###################################################################
$ECHEC
Unlock X3MAJ
GOK = 0
Call TEMPOFF From GESECRAN
End

###################################################################
$FUSFIC
# Est-ce que les fichiers existent

If filinfo(filpath("FIL",FICOLD,"fde",0),0)<0 : Return : Endif
If filinfo(filpath("FIL",FICNEW,"fde",0),0)<0 : Return : Endif

# Copie des tables dont on gère le changement de version

If find(FICOLD,"ADOSSIER","ABATRQT","ABATABTD")
 Gosub COPIE
Endif

# Changement de structure

SRFORG = filpath("FIL",FICNEW,"srf",0) : # W
SRFDES = filpath("FIL",FICOLD,"srf",0)
If filinfo(SRFDES,0)>=0
 SRFSAV = filpath("FIL",FICOLD,"old",0)
 Call MOVE(SRFDES,SRFSAV,STAT) From ORDSYS
 adxifs = ""
 adxirs = chr$(10)
 Openi SRFSAV
 Rdseq LIGSAV(1) : # Titre
 Rdseq LIGSAV(2) : # Abrev
 Rdseq LIGSAV(3) : # Localisation
 Rdseq LIGSAV(4) : # Base + taille
 Openi
 EXISTE = 1
Else
 EXISTE = 0
Endif
Openi SRFORG
Openo SRFDES , 0
If EXISTE
 Rdseq LIGNE : Wrseq LIGSAV(1)
 Rdseq LIGNE : Wrseq LIGSAV(2)
 Rdseq LIGNE : Wrseq LIGSAV(3)
 Rdseq LIGNE : Wrseq LIGSAV(4)
Else
 Rdseq LIGNE : Wrseq LIGNE
 Rdseq LIGNE : Wrseq LIGNE
 Rdseq LIGNE : Wrseq LIGNE
 Rdseq LIGNE : Wrseq LIGNE
Endif
fstat = 0
Rdseq LIGNE
While fstat=0
 Wrseq LIGNE
 Rdseq LIGNE
Wend
Openi
Openo
ORDSYS = "valfil"-nomap-FICOLD
Call SYSTEME("",ORDSYS,"",STAT) From ORDSYS

# Fusion de données

Read [ATI_]NUMLIG(2) = FICOLD;1
CHAINE = [F:ATI_]DESCRIPT
J = instr(1,CHAINE,"+")
K = instr(1,CHAINE,"-")
If    J &  K : K = min(J,K)
Elsif J & !K : K = J
Endif
If K : CHAINE = left$(CHAINE,K-1) : Endif
Local File =FICNEW [F1] , =FICOLD [F2]
[G:F2]currind = 1
[G:F2]currlen = 0

# Fusion

Default File [F2]
Call DEBTRANS From GLOCK
Gosub TR1
Close Local File [F1] , [F2]
If EXISTE
 Call EFFACE(SRFSAV,STAT) From ORDSYS
Endif

# Effacement de la table "W"

If GOK=1
 ORDSYS = "valfil -d"-nomap-FICNEW
 Call SYSTEME("",ORDSYS,"",STAT) From ORDSYS
Endif

Return

###################################################################
$TR1
GOK = 1
Trbegin [F2]
# On est obligé de faire un cas particulier pour les fichiers des dossiers
 If !find(FICOLD,"ADOSSIER","ADOSACT","ADOSDIM","ADOSSOL")
  Delete [F2] Where num$(evalue(CHAINE))<"X"
  If fstat=1
   GOK = -1 : GLOCK = "$"+FICOLD : Goto ROLL_TR1
  Endif
 Endif
 For [F1]
  [F:F2] = [F:F1]
  Read [F2] =
  If fstat
   [F:F2] = [F:F1]
   Write [F2]
  Else
   [F:F2] = [F:F1]
   Rewrite [F2]
  Endif
  If fstat
   GOK = 0 : Call FSTA("F2") From GLOCK : Break
  Endif
 Next F1
 If GOK<>1 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

###################################################################
$RECADS
FICCOP = "WWDOSSIER"
If filinfo(filpath("FIL",FICCOP,"fde",0),0)<0 : Return : Endif
Local File =FICCOP [F1] , ADOSSIER [F2] , ADOSSOL [F3]
If dim([F:F1]LNBLIEN)>0 or dim([F:F1]CREWIN)<=0 or dim([F:F1]DOSLEG)<=0
 Gosub TR2
Endif
Close Local File [F1] , [F2] , [F3]
ORDSYS = "valfil -d"-nomap-FICCOP
Call SYSTEME("",ORDSYS,"",STAT) From ORDSYS
Return

$TR2
Trbegin [F2]
 For [F1]
  Read [F2]DOSSIER=[F:F1]DOSSIER
  If fstat=1
   GOK = -1 : GLOCK = "$ADOSSIER" : Break
  Elsif !fstat
   If dim([F:F1]CREWIN)<=0 & GADONIX<>2
    [F:F2]CREWIN = 2
    [F:F2]CRECNS = 2
   Endif
   If dim([F:F1]DOSLEG)<=0 & [F:F2]NBLEG<=0
    If dim(TBCRY)<0
     Gosub SETLEG From SUPMAJ30
    Endif
    K = find([F:F2]CRYDEF,TBCRY(1..NBLEG))
    If K
     [F:F2]DOSLEG(0) = TBLEG(K)
     [F:F2]NBLEG = 1
    Endif
   Endif
   Rewrite [F2]
   If fstat
    GOK = 0 : Call FSTA("F2") From GLOCK : Break
   Endif
   If dim([F:F1]LNBLIEN)>0
    Read [F3]ADD0(1)=[F:F1]DOSSIER
    If fstat
     For I=1 To [F:F1]LNBLIEN
      [F:F3]LTYPLIEN = [F:F1]LTYPLIEN(I-1)
      [F:F3]LDOSTARG = [F:F1]LDOSTARG(I-1)
      [F:F3]LLIENACT = 1 : # Liens non actif
      [F:F3]LMAC     = [F:F1]LMAC(I-1)
      [F:F3]LSERV    = [F:F1]LSERV(I-1)
      [F:F3]LTYPOS   = [F:F1]LTYPOS(I-1)
      [F:F3]LTYPDBA  = [F:F1]LTYPDBA(I-1)
      [F:F3]LSOL     = [F:F1]LSOL(I-1)
      [F:F3]LREP     = [F:F1]LREP(I-1)
      [F:F3]LSRC     = [F:F1]LSRC(I-1)
      [F:F3]LDBA     = [F:F1]LDBA(I-1)
      [F:F3]LUSR     = [F:F1]LUSR(I-1)
      [F:F3]LPWD     = [F:F1]LPWD(I-1)
      [F:F3]NUMLIG   = I
      [F:F3]DOSSIER  = [F:F1]DOSSIER
      Write [F3]
      If fstat
       GOK = 0 : Call FSTA("F3") From GLOCK : Break 2
      Endif
     Next I
    Endif
   Endif
  Endif
 Next F1
 If GOK=0 : Goto AB_TR2
 Elsif GOK=-1 : Goto ROLL_TR2
 Endif
Commit
Return

$AB_TR2
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

###################################################################
$RECRQT
FICCOP = "WWBATRQT"
If filinfo(filpath("FIL",FICCOP,"fde",0),0)<0 : Return : Endif
Local File =FICCOP [F1] , ABATRQTL [F2] , ABATRQT [F3]
If dim([F:F2]PARAM)>0 & dim([F:F1]DEB)>0
 Gosub TR3
Endif
Close Local File [F1] , [F2] , [F3]
ORDSYS = "valfil -d"-nomap-FICCOP
Call SYSTEME("",ORDSYS,"",STAT) From ORDSYS
Return

$TR3
GOK = 1
Trbegin [F2] , [F3]
 K = 0
 Read [F1]NUMREQ First
 While !fstat
  If K= 0
   K = [F:F1]NUMREQ
   J = 0
  Endif
  [F:F2]NUMREQ = K
  For I=0 To dim([F:F1]DEB)-1
   If [F:F1]DEB(I) = "&" : Break : Endif
   If [F:F1]DEB(I) <> ""
    J += 1
    [F:F2]PARAM   = [F:F1]DEB(I)
    [F:F2]VALEUR  = [F:F1]FIN(I)
    [F:F2]NUM     = J
    Write [F2]
    If fstat
     GOK = 0 : Call FSTA("F2") From GLOCK : Break 2
    Endif
   Endif
  Next I
  If [F:F1]DEB(dim([F:F1]DEB)-1) <> "&"
   K = 0
  Endif
  Read [F1]NUMREQ Next
 Wend
 If GOK<>1 : Goto AB_TR3 : Endif
 For [F3]
  Look [F2]NUMREQ(1)=[F:F3]NUMREQ
  If fstat
   Delete [F3] Curr
   If fstat
    GOK = 0 : Call FSTA("F3") From GLOCK : Goto AB_TR3
   Endif
  Endif
 Next
Commit
Return

$AB_TR3
Rollback
Return

###################################################################
$RECABT
FICCOP = "WWBATABTD"
If filinfo(filpath("FIL",FICCOP,"fde",0),0)<0 : Return : Endif
Local File =FICCOP [F1] , ABATABTD [F2]
If dim([F:F2]PARAM)>0 & dim([F:F1]DEB)>0
 Gosub TR4
Endif
Close Local File [F1] , [F2]
ORDSYS = "valfil -d"-nomap-FICCOP
Call SYSTEME("",ORDSYS,"",STAT) From ORDSYS
Return

$TR4
GOK = 1
Trbegin [F2]
 For [F1]
  Delete [F2] Where [F2]CODABT=[F1]CODABT & [F2]CODTAC=[F1]CODTAC
  If fstat=1
   GOK = -1 : GLOCK = "$ABATABTD" : Break
  Endif
 Next F1
 If GOK=-1 : Goto ROLL_TR4 : Endif
 K = 0
 Read [F1]ABD0 First
 While !fstat
  If K=0
   If dim([F:F1]LIG)>0
    K = [F:F1]LIG
   Else
    K = 1
   Endif
   J = 0
  Endif
  [F:F2] = [F:F1]
  [F:F2]LIG = K
  If [F:F1]DEB(0)<>""
   For I=0 To dim([F:F1]DEB)-1
    If [F:F1]DEB(I) = "&" : Break : Endif
    If [F:F1]DEB(I) <> ""
     J += 1
     [F:F2]PARAM   = [F:F1]DEB(I)
     [F:F2]VALEUR  = [F:F1]FIN(I)
     [F:F2]NUM     = J
     Write [F2]
     If fstat
      GOK = 0 : Call FSTA("F2") From GLOCK : Break 2
     Endif
    Endif
   Next I
  Endif
  If [F:F1]DEB(dim([F:F1]DEB)-1) <> "&"
   K = 0
  Endif
  Read [F1]ABD0 Next
 Wend
 If GOK=0 : Goto AB_TR4 : Endif
Commit
Return

$AB_TR4
Rollback
Return

$ROLL_TR4
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR4 : Endif

###################################################################
$COPIE
SRFDES = filpath("FIL",FICOLD,"srf",0)
SRFCOP = filpath("FIL",FICCOP,"srf",0)
If filinfo(SRFDES,0)>0
 Call COPIE(SRFDES,SRFCOP,STAT) From ORDSYS
 ORDSYS = "valfil"-nomap-FICCOP
 Call SYSTEME("",ORDSYS,"",STAT) From ORDSYS
 Local File =FICOLD [F1] , =FICCOP [F2]
 Gosub TR5
 Close Local File [F1] , [F2]
Endif
Return

$TR5
GOK = 1
Trbegin [F2]
 For [F1]
  [F:F2] = [F:F1]
  Write [F2]
  If fstat
   GOK = 0 : Call FSTA("F2") From GLOCK : Break
  Endif
 Next F1
 If GOK<1 : Goto AB_TR5 : Endif
Commit
Return

$AB_TR5
Rollback
Return

