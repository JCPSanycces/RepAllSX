#<AdxTL>@(#)7.0.0.0 $Revision$
$CREEBDO
Local Integer NOPER, FLGWR
Local Integer VOK
Local Decimal OLDMTT, OLDQTY
Gosub OUVFIC From SUBBDO
## Si on le fait dans INITODS, risque de le faire N fois dans BUDNATSEC
Call LECTURE("BUP",[F:BUD]BUD,"") From CONTOBJ
Gosub TR1
Return

$CPT
Call COMPTEUR (NUMCPT, VOK) From SUBBDO
Return

$INITODS
Local Char  LBUDDIE(GLONDIE)(9), LBUDCCE(GLONCCE)(9) : # To relate dimension of the budget to dimension of the ledger
Local Integer KK
Raz LBUDDIE, LBUDCCE
For KK=0 To [F:BUP]DIENBR-1
 If [F:BUP]DIE(KK)=[F:BUD]DIE1    : LBUDCCE(KK) = [F:BUD]CCE1 : LBUDDIE(KK) = [F:BUD]DIE1
 Elsif [F:BUP]DIE(KK)=[F:BUD]DIE2 : LBUDCCE(KK) = [F:BUD]CCE2 : LBUDDIE(KK) = [F:BUD]DIE2
 Elsif [F:BUP]DIE(KK)=[F:BUD]DIE3 : LBUDCCE(KK) = [F:BUD]CCE3 : LBUDDIE(KK) = [F:BUD]DIE3
 Elsif [F:BUP]DIE(KK)=[F:BUD]DIE4 : LBUDCCE(KK) = [F:BUD]CCE4 : LBUDDIE(KK) = [F:BUD]DIE4
 Elsif [F:BUP]DIE(KK)=[F:BUD]DIE5 : LBUDCCE(KK) = [F:BUD]CCE5 : LBUDDIE(KK) = [F:BUD]DIE5
 Elsif [F:BUP]DIE(KK)=[F:BUD]DIE6 : LBUDCCE(KK) = [F:BUD]CCE6 : LBUDDIE(KK) = [F:BUD]DIE6
 Elsif [F:BUP]DIE(KK)=[F:BUD]DIE7 : LBUDCCE(KK) = [F:BUD]CCE7 : LBUDDIE(KK) = [F:BUD]DIE7
 Elsif [F:BUP]DIE(KK)=[F:BUD]DIE8 : LBUDCCE(KK) = [F:BUD]CCE8 : LBUDDIE(KK) = [F:BUD]DIE8
 Elsif [F:BUP]DIE(KK)=[F:BUD]DIE9 : LBUDCCE(KK) = [F:BUD]CCE9 : LBUDDIE(KK) = [F:BUD]DIE9
 Endif
Next

Raz [F:BDO]
[F:BDO]=[F:BUD]
Raz [F:BDO]AMT
Raz [F:BDO]QTY
[F:BDO]CCE1 = LBUDCCE(0) : [F:BDO]DIE1 = LBUDDIE(0)
[F:BDO]CCE2 = LBUDCCE(1) : [F:BDO]DIE2 = LBUDDIE(1)
[F:BDO]CCE3 = LBUDCCE(2) : [F:BDO]DIE3 = LBUDDIE(2)
[F:BDO]CCE4 = LBUDCCE(3) : [F:BDO]DIE4 = LBUDDIE(3)
[F:BDO]CCE5 = LBUDCCE(4) : [F:BDO]DIE5 = LBUDDIE(4)
[F:BDO]CCE6 = LBUDCCE(5) : [F:BDO]DIE6 = LBUDDIE(5)
[F:BDO]CCE7 = LBUDCCE(6) : [F:BDO]DIE7 = LBUDDIE(6)
[F:BDO]CCE8 = LBUDCCE(7) : [F:BDO]DIE8 = LBUDDIE(7)
[F:BDO]CCE9 = LBUDCCE(8) : [F:BDO]DIE9 = LBUDDIE(8)
[F:BDO]CUR=[F:BUP]CUR
If [F:BUP]PYMACC=""
 Call LECTURE("GAC",[F:BUD]ACC,[F:BUD]COA) From CONTOBJ
 If [F:GAC]UOM<>"" & [F:BUP]QTY=2
  [F:BDO]UOM = [F:GAC]UOM
 Endif
Else
 Call LECTURE("GRY",[F:BUD]ACC,[F:BUP]PYMACC) From CONTOBJ
 If [F:GRY]UOMDAC=2 & [F:BUP]QTY=2
  [F:BDO]UOM = [F:GRY]UOM
 Endif
Endif
Return


$TR1
If clalev([M:BCR])>0 : # Maj OD budgétaires via la saisie des budgets
 Case [M:BCR]BUDCAT
  When 1   : Gosub BUDPER
  When 2,3 : Gosub BUDCCEACC
 Endcase
 # MAJ OD budgétaires via une autre fonction que la saisie des budgets et le calcul budgétaire
 # Le calcul budgétaire génère son OD
Else
 Gosub BUDGET
Endif
If GOK<>0 & NBRLIG>0
 Read[F:BDE]BDE0=NUMCPT
 If fstat >2
  Raz [F:BDE]
  [F:BDE]NUM=NUMCPT
  [F:BDE]BUD=[F:BUD]BUD
  [F:BDE]DES=mess(59,108,1)-GUSER-num$(date$)  :#OD Budget + USER + Date
  If clalev([M:BCR])>0
   [F:BDE]VER    = [F:BUD]VER
   [F:BDE]BUDTYP = [M:BCR]BUDTYP                  :#Code transaction d'origine
  Elsif GFONCTION<>"GESBUC"
   [F:BDE]VER    = [F:BUD]VER
   [F:BDE]BUDTYP = ""
  Else
   [F:BDE]VER    = [F:BUD2]VER
   [F:BDE]BUDTYP = ""
  Endif
  [F:BDE]CREUSR=GUSER
  [F:BDE]CREDAT=date$
  GPOINT = "BEFWRIBDE" : Gosub ENTREE From EXEFNC
  Write [BDE]
  If fstat
   GOK=0 : Call FSTA("BDE") From GLOCK
  Endif
 Endif
Endif
Return

$BUDPER
Gosub INITODS
For [PER]PER0 Where CPY=[M:BCR]CPY & LEDTYP=[M:BCR]LEDTYP & PERSTR>=[M:BCR]DATD & PEREND<=[M:BCR]DATF & FIYNUM=J
 NOPER=[F:PER]PERNUM-1
 If [BUP]QTY=2
  [F:BDO]QTY=[F:BUD]QTY(NOPER)-[F:BUD9]QTY(NOPER)
 Endif
 [F:BDO]AMT=[F:BUD]AMT(NOPER)-[F:BUD9]AMT(NOPER)
 If (abs([F:BDO]QTY)+ abs([F:BDO]AMT))=0 : FLGWR=0 : Else : FLGWR=1 : Endif
 If FLGWR=1
  If NUMCPT=""
   Gosub CPT
   If VOK : GOK=0: Break : Endif
  Endif
  [F:BDO]NUM=NUMCPT
  [F:BDO]LIN=NBRLIG+1
  [F:BDO]STRDAT=[F:PER]PERSTR
  [F:BDO]ENDDAT=[F:PER]PEREND
  NBRLIG+=1
  Write [BDO]
  If fstat
   GOK=0 : Call FSTA("BDO") From GLOCK : Break
  Endif
 Endif
 NOPER+=1
Next
If GOK<0 : Return : Endif
Return

$BUDCCEACC
If J=[M:BCR]FIYSTR(I)
 Gosub INITODS
Endif
For [PER]PER0 Where CPY=[M:BCR]CPY & LEDTYP=[M:BCR]LEDTYP & PERSTR>=[M:BCR]DATDEB(I) & PEREND<=[M:BCR]DATFIN(I) & FIYNUM=J
 NOPER=[F:PER]PERNUM-1
 If [BUP]QTY=2
  [F:BDO]QTY+=[F:BUD]QTY(NOPER)-[F:BUD9]QTY(NOPER)
 Endif
 [F:BDO]AMT+=[F:BUD]AMT(NOPER)-[F:BUD9]AMT(NOPER)
 NOPER+=1
Next
If (abs([F:BDO]QTY)+ abs([F:BDO]AMT))=0 : FLGWR=0 : Else : FLGWR=1 : Endif
If FLGWR=1 & J=[M:BCR]FIYEND(I)
 If NUMCPT=""
  Gosub CPT
  If VOK : GOK=0: Return : Endif
 Endif
 [F:BDO]NUM=NUMCPT
 [F:BDO]LIN=NBRLIG+1
 [F:BDO]STRDAT=[M:BCR]DATDEB(I)    :#Date debut
 [F:BDO]ENDDAT=[M:BCR]DATFIN(I)    :#Date fin
  NBRLIG+=1
 Write [BDO]
 If fstat
  GOK=0 : Call FSTA("BDO") From GLOCK
 Endif
Endif
If GOK<0 : Return : Endif
Return


$BUDGET
Gosub INITODS
Local Char SOCIETE(GLONCPY)
Local Integer NBRLIG : NBRLIG = 0
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif
SOCIETE = [F:BUD]CPY
For [PER]PER0 Where CPY=[L]SOCIETE & LEDTYP=[F:BUD]LEDTYP & FIYNUM=[F:BUD]FIY
 If GFONCTION = "BUDCOP" : # Cas de la copie du budget : c'est forcément une création du budget...
  NOPER=[F:PER]PERNUM-1
  If [BUP]QTY=2
   [F:BDO]QTY=[F:BUD]QTY(NOPER)
  Endif
  [F:BDO]AMT=[F:BUD]AMT(NOPER)
 Elsif dim([L]XAMTBUD)>0 & dim([L]XQTYBUD)>0 # Cas de l'import ou du calcul de budget : ce peut être une création ou un MAJ de budget...
  NOPER=[F:PER]PERNUM-1
  If [BUP]QTY=2
   [F:BDO]QTY=[F:BUD]QTY(NOPER)-[L]XQTYBUD(NOPER)
  Endif
  [F:BDO]AMT=[F:BUD]AMT(NOPER)-[L]XAMTBUD(NOPER)
 Endif
 If (abs([F:BDO]QTY)+ abs([F:BDO]AMT))=0 : FLGWR=0 : Else : FLGWR=1 : Endif
 If FLGWR=1
  If NUMCPT=""
   Gosub CPT
   If VOK : GOK=0: Break : Endif
  Endif
  [F:BDO]NUM=NUMCPT
  [F:BDO]LIN=NBRLIG+1
  [F:BDO]STRDAT=[F:PER]PERSTR
  [F:BDO]ENDDAT=[F:PER]PEREND
  NBRLIG+=1
  Write [BDO]
  If fstat
   GOK=0 : Call FSTA("BDO") From GLOCK : Break
  Endif
 Endif
 NOPER+=1
Next
If GOK<0 : Return : Endif
Return

