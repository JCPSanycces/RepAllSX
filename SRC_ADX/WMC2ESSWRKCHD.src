#<AdxTL>@(#)0.0.0.0 $Revision$Class Children
# Supervisor
## ACLA-CLASSE ## ESSWRKCHD
# 2018-10-23 06:53:15 230

####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 31 : CHDCKK Child ( Field Local menu number 1)
####################################################################

$SET_CHDCKK
If [L]_AOLDVAL<>this.CHDCKK
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_CHDCKK
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.CHDCKK
 Gosub PROPAGATE_CHDCKK
Endif
Return

$INIT_CHDCKK
Gosub DECLARE_VAR From WMC0ESSWRKCHD
[L]CURPRO = "CHDCKK"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.CHDCKK=0 and fmet this.AGETATTRIBUTE("CHDCKK","$isMandatory")="true"
 this.CHDCKK = 1
Endif
Return
 
$CONTROL_CHDCKK
Gosub DECLARE_VAR From WMC0ESSWRKCHD
[L]CURPRO = "CHDCKK"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_CHDCKK                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_CHDCKK                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_CHDCKK
[L]CURPRO = "CHDCKK"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.CHDCKK=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_CHDCKK
[L]CURPRO = "CHDCKK"
If this.CHDCKK<0 or this.CHDCKK>len(mess(0,1,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"1 ->"-num$(this.CHDCKK)-mess(99,123,1)):  Return : # Local menu "1 -> Invalid option
Endif
Return

$_AOTHERS_CHDCKK
[L]CURPRO = "CHDCKK"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_CHDCKK
[L]CURPRO = "CHDCKK"
Return

$PROPAGATE_CHDCKK
this.isReadonly = 0
[L]CURPRO = "CHDCKK"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_CHDCKK
Gosub DECLARE_VAR From WMC0ESSWRKCHD
[L]CURPRO = "CHDCKK"
$_LNKPRO_CHDCKK
Return




