# Classe PXXSIGHIS_RSTD

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
     Case [L]AEVENT
       When "AQUERY_CRITERIA_AFTER" : Gosub AQUERY_CRITERIA_AFTER
       When "AQUERY_JOIN_AFTER"     : Gosub AQUERY_JOIN_AFTER
     Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "RCHRONO"
      Case [L]ARULE
        When "GET" : Gosub RCHRONO_GET
      Endcase
    When "TYPVCR"
      Case [L]ARULE
        When "GET" : Gosub TYPVCR_GET
      Endcase
    When "RCLEDEC"
      Case [L]ARULE
        When "GET" : Gosub RCLEDEC_GET
      Endcase
    When Default
      Case this.TYPVCR
        When 8
          Gosub PROPERTIES_POHTYP
        When 31
          Gosub PROPERTIES_PSHTYP
        When 7
          Gosub PROPERTIES_POCTYP
      Endcase
  Endcase
Return

$PROPERTIES_POHTYP
  Case [L]CURPRO
    When "DEVTTC"
      Case [L]ARULE
        When "GET" : Gosub POHTYP_DEVTTC_GET
      Endcase
    When "RVALCTXDAT"
      Case [L]ARULE
        When "GET" : Gosub POHTYP_RVALCTXDAT_GET
      Endcase
    When "RVALCTXBPS"
      Case [L]ARULE
        When "GET" : Gosub POHTYP_RVALCTXBPS_GET
      Endcase
    When "RVALCTXCPY"
      Case [L]ARULE
        When "GET" : Gosub POHTYP_RVALCTXCPY_GET
      Endcase
    When "RVALCTXAUS"
      Case [L]ARULE
        When "GET" : Gosub POHTYP_RVALCTXAUS_GET
      Endcase
    When "RVALCTXNOT"
      Case [L]ARULE
        When "GET" : Gosub POHTYP_RVALCTXNOT_GET
      Endcase
    When "RVALCTXCUR"
      Case [L]ARULE
        When "GET" : Gosub POHTYP_RVALCTXCUR_GET
      Endcase
    When "RVALCTXATI"
      Case [L]ARULE
        When "GET" : Gosub POHTYP_RVALCTXATI_GET
      Endcase
  Endcase
Return

$PROPERTIES_PSHTYP
  Case [L]CURPRO
    When "RVALCTXDAT"
      Case ACTION
        When "GET" : Gosub PSHTYP_RVALCTXDAT_GET
      Endcase
    When "RVALCTXBPS"
      Case ACTION
        When "GET" : Gosub PSHTYP_RVALCTXBPS_GET
      Endcase
    When "RVALCTXCPY"
      Case ACTION
        When "GET" : Gosub PSHTYP_RVALCTXCPY_GET
      Endcase
    When "RVALCTXAUS"
      Case ACTION
        When "GET" : Gosub PSHTYP_RVALCTXAUS_GET
      Endcase
    When "RVALCTXITM"
      Case ACTION
        When "GET" : Gosub PSHTYP_RVALCTXITM_GET
      Endcase
    When "RVALCTXITMNA"
      Case ACTION
        When "GET" : Gosub PSHTYP_RVALCTXITMNA_GET
      Endcase
    When "RVALCTXNOT"
      Case ACTION
        When "GET" : Gosub PSHTYP_RVALCTXNOT_GET
      Endcase
    When "RVALCTXCUR"
      Case ACTION
        When "GET" : Gosub PSHTYP_RVALCTXCUR_GET
      Endcase
    When "RVALCTXQTY"
      Case ACTION
        When "GET" : Gosub PSHTYP_RVALCTXQTY_GET
      Endcase
    When "RVALCTXUOM"
      Case ACTION
        When "GET" : Gosub PSHTYP_RVALCTXUOM_GET
      Endcase
  Endcase
Return

$PROPERTIES_POCTYP
  Case [L]CURPRO
    When "RVALCTXDAT"
      Case [L]ARULE
        When "GET" : Gosub POCTYP_RVALCTXDAT_GET
      Endcase
    When "RVALCTXBPS"
      Case [L]ARULE
        When "GET" : Gosub POCTYP_RVALCTXBPS_GET
      Endcase
    When "RVALCTXCPY"
      Case [L]ARULE
        When "GET" : Gosub POCTYP_RVALCTXCPY_GET
      Endcase
    When "RVALCTXAUS"
      Case [L]ARULE
        When "GET" : Gosub POCTYP_RVALCTXAUS_GET
      Endcase
    When "RVALCTXNOT"
      Case [L]ARULE
        When "GET" : Gosub POCTYP_RVALCTXNOT_GET
      Endcase
    When "RVALCTXCUR"
      Case [L]ARULE
        When "GET" : Gosub POCTYP_RVALCTXCUR_GET
      Endcase
  Endcase
Return


#######################################################################################
## Methods
#######################################################################################

#######################################################################################
$AQUERY_CRITERIA_AFTER
  If PQRY.QWHERE <> "" Then
    PQRY.QWHERE="("+PQRY.QWHERE+") and (FLGSIG eq 1 or FLGSIG eq 5) and DEST eq GACTX.USER"
  Else
    PQRY.QWHERE="(FLGSIG eq 1 or FLGSIG eq 5) and DEST eq GACTX.USER"
  Endif
Return

#######################################################################################
$AQUERY_JOIN_AFTER
  Local Char VARS(20)(1..3), COLS(20)(1..3)

  VARS(1)="FLGSIG"
  COLS(1)="[F:AWS]FLGSIG"
  VARS(2)="DEST"
  COLS(2)="[F:AWS]DEST"
  Link [AWS] With [A_]AWS2=[AWS]DEST;[AWS]CHRONO
&  As [LNK_]
&  Where evalueSData(PQRY.QWHERE,VARS,COLS)
&  and (((CODEVT='PSHSIG'|CODEVT='PSDSIG'|CODWRK='PSHSIG'|CODWRK='PSDSIG')&(CODWRK<>'PSHSIGNCR'|CODWRK<>'PSDSIGNCR'))|((CODEVT='POHSIG'|CODWRK='POHSIG')&(CODWRK<>'POHSIGNCR'))|
&      ((CODEVT='POCSIG'|CODWRK='POCSIG')&(CODWRK<>'POCSIGNCR')))
Return




#######################################################################################
## Common properties PSH/POH/POC
#######################################################################################

#######################################################################################
$RCHRONO_GET
  this.RCHRONO = this.AWS.CHRONO
Return

#######################################################################################
$TYPVCR_GET
  Case this.AWS.ABROBJ
    When "PSH", "PSD"
      this.TYPVCR = 31 # Demande d'achat ML477
    When "POH"
      this.TYPVCR = 8  # Commande ML477         - on est dans la achats donc pas besoin de prendre ML29
    When Default
      this.TYPVCR = 7  # Commande ouverte ML477 - on est dans la achats donc pas besoin de prendre ML28
  Endcase
Return

#######################################################################################
$RCLEDEC_GET
  this.RCLEDEC = this.AWS.CLEDEC
Return




#######################################################################################
## Properties for POH
#######################################################################################

#######################################################################################
$POHTYP_DEVTTC_GET
  this.DEVTTC = this.AWS.VALCTX6
Return

#######################################################################################
$POHTYP_RVALCTXDAT_GET
  Local Integer IDAY
  Local Integer IMONTH
  Local Integer IYEAR

  IDAY = val(left$(this.AWS.VALCTX7,2))
  IMONTH = val(mid$(this.AWS.VALCTX7,4,2))
  IYEAR = val(mid$(this.AWS.VALCTX7,7,4))
  this.RVALCTXDAT = gdat$(IDAY, IMONTH, IYEAR)
Return

#######################################################################################
$POHTYP_RVALCTXBPS_GET
  this.RVALCTXBPS = this.AWS.VALCTX2
Return

#######################################################################################
$POHTYP_RVALCTXCPY_GET
  this.RVALCTXCPY = this.AWS.VALCTX3
Return

#######################################################################################
$POHTYP_RVALCTXAUS_GET
  this.RVALCTXAUS = this.AWS.VALCTX1
Return

#######################################################################################
$POHTYP_RVALCTXNOT_GET
  this.RVALCTXNOT = val(this.AWS.VALCTX4)
Return

#######################################################################################
$POHTYP_RVALCTXCUR_GET
  this.RVALCTXCUR = this.AWS.VALCTX6
Return

#######################################################################################
$POHTYP_RVALCTXATI_GET
  this.RVALCTXATI = val(this.AWS.VALCTX5)
Return





