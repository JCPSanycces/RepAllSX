#<AdxTL>@(#)0.0.0.0 $Revision$Classe Initiateurs clients
# Superviseur
## CRUD-CLASSE ## CCMCRORIGC
# 2018-10-19 07:50:18 238


############################################################################################
### Subprog _AUPDATE
############################################################################################
Subprog _AUPDATE(CCMCRORIGC,ASTATUS)
Variable Instance CCMCRORIGC Using C_CCMCRORIGC
Variable Integer ASTATUS

If CCMCRORIGC = null : End : Endif

Gosub _AVARIABLES From WMC00CCMCRORIGC

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AUPDATE_CCMCRORIGC

End

#-----------------------------------------------------#

############################################################################################
### Subprog AUPDATE
############################################################################################
Subprog AUPDATE(CCMCRORIGC,ASTATUS)
Variable Instance CCMCRORIGC Using C_CCMCRORIGC
Variable Integer ASTATUS

If CCMCRORIGC = null : End : Endif

Gosub AVARIABLES From WMC00CCMCRORIGC
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
CCMCRORIGC.ASTALIN = [V]CST_AUPD
Gosub AUPDATE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

If !adxlog
 Gosub AUPDATE_TR_CCMCRORIGC
Else
 Gosub AUPDATE_CCMCRORIGC
Endif
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

Gosub _AUPDATE_AFTER
[L]A_I = CCMCRORIGC.freeSnapshot
CCMCRORIGC.snapshotEnabled = 1
$AUPDATE_END
End


$AUPDATE_CONTROL
Gosub _AUPDATE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet CCMCRORIGC._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet CCMCRORIGC._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet CCMCRORIGC._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AUPDATE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_BEFORE
If CCMCRORIGC.ASTALIN = [V]CST_ANEWDEL : Return : Endif
CCMCRORIGC.ASTALIN = [V]CST_AUPD
If [V]CST_ASTALIN(CCMCRORIGC.ASTALIN)<>""
 [L]A_ASTALIN = CCMCRORIGC.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGC.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif

Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_AFTER

If [V]CST_ASTALIN(CCMCRORIGC.ASTALIN)<>""
 [L]A_ASTALIN = CCMCRORIGC.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGC.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
Return

#-----------------------------------------------------#
$AUPDATE_TR_CCMCRORIGC
Trbegin [F:CCMCROC]
 Gosub AUPDATE_CCMCRORIGC
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AUPDATE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AUPDATE_CCMCRORIGC
[L]A_ASTALIN = CCMCRORIGC.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGC.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00CCMCRORIGC._MAJSQL_CCMCRORIGC(CCMCRORIGC))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


[L]A_ASTALIN = CCMCRORIGC.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet CCMCRORIGC.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AUPDATE_ABORT
Rollback
$_AUPDATE_ABORT
If CCMCRORIGC.snapshotEnabled=1
 [L]A_RETIK = CCMCRORIGC.revertUpdTick
Endif

[L]ASTATUS = max(fmet CCMCRORIGC.ACTION("AUPDATE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AUPDATE_AFTER
If find(CCMCRORIGC.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 CCMCRORIGC.ASTALIN = [V]CST_ALL
Endif
Return



