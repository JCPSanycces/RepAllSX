#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################################
# UTITC74                                                                              #
#                                                                                      #
# Common Data module - PT consignment invoices                                         #
#                                                                                      #
#                                                                                      #
########################################################################################
Call MAJ_UTITC74
End

#-------------------------------------------------------------------------------#
Subprog MAJ_UTITC74
Local Char DOSSIER(30)
  DOSSIER=nomap
  Call SAIDOS(DOSSIER,"UTITC74 - PT consignment invoices.") From SAIDOS
  If DOSSIER <> "" Then
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTITC74 - Starting PT consignment invoices.") From LECFIC
    Call EXE_UTITC74(DOSSIER)
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

#-------------------------------------------------------------------------------#
Subprog EXE_UTITC74(DOSSIER)
Value Char    DOSSIER
  If (func DOSSUB.ISHISTFOLD(DOSSIER))
    Call ECR_TRACE("UTITC74 : Not to perform on archive folder : "+DOSSIER,0) From GESECRAN
    End
  Endif
  Call ECR_TIME("UTITC74 : Starting PT consignment invoices :"-DOSSIER) From DOSSUB
  Gosub TRT_SAFTTYP
  Call ECR_TRACE(string$(65,"-"),0) From GESECRAN
  Call ECR_TIME("UTITC74 : End folder's process"-DOSSIER) From DOSSUB
End

#-------------------------------------------------------------------------------#
# Change SAFTINVTYP field from TABSIVTYP table : 1(invoice)-->9(proforma)       #
# Change SAFTINVTYP field from TABPIVTYP table : 1(invoice)-->9(proforma)       #
#-------------------------------------------------------------------------------#
$TRT_SAFTTYP

If GTRACE=""
 Call OUVRE_TRACE("UTITC74 - Starting PT consignment invoices.") From LECFIC
 Local Integer LTRACE
Endif

If filinfo(filpath("FIL","TABSIVTYP","fde",DOSSIER),0) <= 0 Then
  Return
Endif

If filinfo(filpath("FIL","TABPIVTYP","fde",DOSSIER),0) <= 0 Then
  Return
Endif

If func AFNC.ACTIV("KPO")
  Local File = DOSSIER+".TABSIVTYP"  [F:TSV]
  Local File = DOSSIER+".TABPIVTYP"  [F:TPV]

  Trbegin [TSV]

  Filter [F:TSV] Where [F:TSV]INVTYP=5 & [F:TSV]SAFTINVTYP<8 & ([F:TSV]LEG="" | [F:TSV]LEG="POR")
  For [F:TSV]
    [F:TSV]SAFTINVTYP=8 : Rewrite [F:TSV]
  Next
  Filter [F:TSV]

  If GOK<1
    Rollback
  Else
    Commit
  Endif

  Trbegin [TPV]

  Filter [F:TPV] Where [F:TPV]INVTYP=5 & [F:TPV]SAFTINVTYP<8 & ([F:TPV]LEG="" | [F:TPV]LEG="POR")
  For [F:TPV]
    [F:TPV]SAFTINVTYP=8 : Rewrite [F:TPV]
  Next
  Filter [F:TPV]

  If GOK<1
    Rollback
  Else
    Commit
  Endif
Endif

If dim(LTRACE)>0
  Call LEC_TRACE From LECFIC
Endif

Return

#-------------------------------------------------------------------------------#
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 End Endif
  If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
  Read [ADS]DOSSIER=APPLI
  If func DOSSUB.FILL_ADS(APPLI)=0    : End : Endif

  If filinfo(filpath("FIL","TABSIVTYP","fde",APPLI),0)<=0  : End : Endif
  If filinfo(filpath("FIL","TABPIVTYP","fde",APPLI),0)<=0  : End : Endif

  Call EXE_UTITC74(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif

  If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
  Read [ADS]DOSSIER=APPLI
  If filinfo(filpath("FIL","TABSIVTYP","fde",APPLI),0)<=0  : End : Endif
  If filinfo(filpath("FIL","TABPIVTYP","fde",APPLI),0)<=0  : End : Endif

  Call EXE_UTITC74(APPLI)
End

