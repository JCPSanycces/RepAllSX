#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
#  SIXMFG : pour traitements de bascule Integrale --> X3                #
#########################################################################
#                                                                       #
# Subprog SIXMFG                                                        #
#     Prérequis :                                                       #  
#                 Les données de base (ART,NOM,etc ...)existent         #
#                 Les données techniques (GAMME,POSTES,etc...) existent #
#                 Le paramètre général GMFGMTSNUM est renseigné         #
#                 La nomenclature de l'article produit existe           #
#     On crée   :                                                       #
#                 Les ordres de fabrication fermes, en attente          #
#                 On ne "récupère" pas les OF Intégrale, on créé des    #
#                 OF X3 par reprise des données entête d'OF Intégrale   #
#                 on s'appuie sur les traitements de génération         #
#                 automatique d'OF.                                     #
#                 On assume que pour chaque article produit, on va      #
#                 trouver la nomenclature Intégrale qui nous permettra  #
#                 trouver la nomenclature X3 !!! Ce qui veut dire       #    
#                 qu'on ne sait pas récupérer les Of pour lesquels      #
#                 la nomenclature n'est pas l'article produit           #
#                 (cas possible dans l'Intégrale)                       #  
#                 En 140/V5 on ne récupère pas les lignes de type texte #
#                                                                       #
#########################################################################

Call EXEC
End

#########################################################################
Subprog EXEC
Local Integer WOUV_TRACE, WOK


If GTRACE = ""
    Call OUVRE_TRACE("SIXMFG : Process translation file from INTEGRALE to X3") From LECFIC
    WOUV_TRACE=1
Endif

Onerrgo TRT_ERR
#---- Création des OF's ------#
Call ECR_TIME("SIXMFG : Create MFG") From DOSSUB

Call SIXX3_MFG

$FIN_MFG
Onerrgo

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End



#########################################################################
# Création des OF's
#########################################################################
Subprog SIXX3_MFG
Local Integer  WOUV_TRACE, WOK
Local Char     WX3_ITM(GLONITM), WX3_ROUNUM(GLONITM), MESSAGE(250)
Local Decimal  WX3_QTY
Local Shortint WX3_BOMALT(2),WX3_ROUALT(2)
Local Integer  WRET
Local Integer  I
Local Integer STOP, NB, I, J
Local Char    CRITERE(250)
# 05.08
Local Integer SINUMORD, SIREL, SIWIP

Gosub OPEN_FILES

#------------------------------------------------------------------------------
# On devrait procéder à ce chargement dans la boucle de lecture des OF car ces
# infos sont propres au site de production ...
# Pour des raisons de performances, on considère que les paramètres généraux
# sont compatibles
GFCY  = [F:SPX]FCY
Read [FCY]FCY0= GFCY
If fstat
  MESSAGE= SI_MES(72)
  Call ECR_TRACE(MESSAGE,1) From GESECRAN
  End
Endif
Gosub CHARG_PARAM
# Vérification que la transaction d'OF automatique est paramétrée
If GMFGMTSNUM = ""  
    Call ECR_TRACE( "Transaction d'OF non paramétrée", 1) From GESECRAN
    WOK = 0 : End
Else
    Read [F:MTS]MTS0 = 1;GMFGMTSNUM
    If fstat : Raz [F:MTS]
        Call ECR_TRACE( "Transaction d'OF non paramétrée", 1) From GESECRAN
        WOK = 0 : End
    Endif
Endif

# On doit pouvoir tout créer: on force les valeurs
[F:MTS]MFGMODC = 2  
[F:MTS]MFGMODM = 2  
[F:MTS]MFGMODO = 2  
[F:MTS]TYPMODM = 2  
[F:MTS]TYPMODO = 2  
#-----------------------------------------------------------------------------

Gosub RECUP_INT_MFG
End

$TRT_ERR
    Call ECR_TRACE( "line"-num$(errl)-":"-errm-errmes$(errn), 1) From GESECRAN
Resume


##########################################################################
$RECUP_INT_MFG
Raz WRET
Raz I

SI_TABLE   = "XIETTOF"
SI_SUBPROG = "SI_MFG"
Gosub SI_CRITSUP From SIXFONCTION

# 05.08 (on prend les PP lancés sans BA)
SINUMORD = 0
CRITERE = 'FLGMAJ = "C" & LETRLQ = "P" & DATPIE >= [F:SPX]STRPER & FLGREP <> 2'  
Filter [F:XOF] Where evalue(CRITERE) & evalue(SI_CRITERE)
For [F:XOF]
    Call AFFBOITE(num$([F:XOF]NUMORD)) From SUBSIM

    SINUMORD = [F:XOF]NUMORD
    SIREL = 0
    SIWIP = 0
    # boucle d'analyse, le PP est-il lancé ? le PP est-il en cours ?
    For [F:XOF1] Where NUMORDPP = SINUMORD
        SIREL = 1
        If [F:XOF1]DRNNUMBA <> 0 : SIWIP = 1 : Break :  Endif       
    Next

    # on ne garde que les PP lancé et non en cours
    If !SIREL : Goto NEXTOF : Endif
    If SIWIP  : Goto NEXTOF : Endif

    For [XLIG] Where (NUMORD = SINUMORD & TYPENR = "L" & LBR1CODSPF = "")
        Read [XOF1]IND0=[F:XLIG]NUMORDOFGEN;""
        If fstat 
            MESSAGE = num$([F:XOF]NUMORD) - SI_MES(257) : Gosub ENHANCE_TRACE
            Call ECR_TRACE(MESSAGE,-2) From GESECRAN
            Goto NEXTLIG
        Endif

        Raz WRET
        Gosub HEAD_CTL
        If !WRET
              GOK=1
              Trbegin [MFG]
              Gosub CRE_WOF 
              If SI_SIMU = 1
                 If GOK < 1
                      Rollback
                      MESSAGE= num$([F:XOF]NUMORD) - SI_MES(26) : Gosub ENHANCE_TRACE
                      Call ECR_TRACE(MESSAGE,1) From GESECRAN
                 Else
                      Readlock [F:XOF] Curr  
                      [F:XOF]FLGREP = 2
                      Rewrite [F:XOF]
                      Commit
                      MESSAGE = [F:MFG]MFGNUM - SI_MES(27) : Gosub ENHANCE_TRACE
                      Call ECR_TRACE(MESSAGE,0) From GESECRAN
                 Endif
              Else
                 If GOK < 1
                      MESSAGE= num$([F:XOF]NUMORD) - SI_MES(26) : Gosub ENHANCE_TRACE 
                      Call ECR_TRACE(MESSAGE,1) From GESECRAN
                 Else
                      MESSAGE = [F:MFG]MFGNUM - SI_MES(27) : Gosub ENHANCE_TRACE 
                      Call ECR_TRACE(MESSAGE,0) From GESECRAN
                 Endif
                 # En simulation, on Rollback toujours   
                 Rollback
              Endif
        Endif
$NEXTLIG 
    Next
$NEXTOF
Next
Filter [XOF]

# Si pas simulation, Lancer le recalcul de la charge ???

Return

##########################################################################
$HEAD_CTL
# Recherche nomenclature Intégrale
# On recherche une nomenclature sur l'article lancé
Filter [F:XNMC] Where CODARTCSE = [F:XLIG]CODART & NUMNMC = [F:XOF1]CODNUMNMC &
&                     ZONSPF = [F:XOF]CODNMCSPF & NUMCST = 0 &  FLGREP = 2
Read [F:XNMC]IND0 First
If fstat
    Filter [F:XNMC] Where CODARTCSE = [F:XLIG]CODART &
&                         ZONSPF = [F:XOF]CODNMCSPF & NUMCST = 0 &  FLGREP = 2
     Read [F:XNMC]IND0 First
     If fstat
         MESSAGE = num$([F:XOF]NUMORD) - SI_MES(29) : Gosub ENHANCE_TRACE
         Call ECR_TRACE(MESSAGE,-2) From GESECRAN
         WRET = 1
         Return
     Endif
Endif
Filter [F:XNMC]
# Lecture article Integrale 
Read [F:XART]IND0 = [F:XNMC]CODARTCSE
If fstat 
     MESSAGE = [F:XNMC]CODARTCSE - SI_MES(9) : Gosub ENHANCE_TRACE
     Call ECR_TRACE(MESSAGE,-2) From GESECRAN
     WRET = 1
     Return
Endif
WX3_ITM = func SIXFONCTION.SI_COR("XIART",[F:XNMC]CODARTCSE,"","") 
# Lecture article X3
Read [F:ITM]ITM0 = WX3_ITM
If fstat
     MESSAGE = mess (134,100,1) - WX3_ITM : Gosub ENHANCE_TRACE
     Call ECR_TRACE(MESSAGE,-2) From GESECRAN
     WRET = 1
     Return
Endif

#-----------------------------------------------------------------
# recherche et bascule sur le site de fabrication préférentiel de 
# l'article lancé
GFCY = func SIXITM.GETMFGFCY
#-----------------------------------------------------------------

Read [ITF]ITF0=[F:ITM]ITMREF;GFCY  
If fstat   
   MESSAGE = mess(45,193,1) - WX3_ITM : Gosub ENHANCE_TRACE
   Call ECR_TRACE(MESSAGE,-2) From GESECRAN
   WRET = 1
   Return 
Endif
#
Call CONTMFGITM(GFCY)
If GMESSAGE <> ""
     MESSAGE = num$([F:XOF]NUMORD) + "/" + [F:ITM]ITMREF - GMESSAGE : Gosub ENHANCE_TRACE
     Call ECR_TRACE(MESSAGE,-2) From GESECRAN
     WRET = 1
     Raz GMESSAGE   
     Return
Endif
WX3_BOMALT = val(func SIXFONCTION.SI_COR4("XINMC",[F:XNMC]ZONSPF,[F:XNMC]CODARTCSE,num$([F:XNMC]NUMNMC),num$([F:XNMC]NUMCST),"",""))
Read [F:BOH]BOH0 = WX3_ITM;WX3_BOMALT;2         # 56567
If fstat | [F:BOH]USESTA <> 2
     MESSAGE = num$([F:XOF]NUMORD) -SI_MES(30) : Gosub ENHANCE_TRACE
     Call ECR_TRACE(MESSAGE,-2) From GESECRAN
     WRET = 1
     Return
Endif

# formatter la quantité selon unité X3
WX3_QTY = [F:XLIG]QTEBES
Call QTEARR(WX3_QTY,[F:ITM]STU) From TRTDIV 
# Trouver éventuellement une gamme qui va bien, sinon OF matières seules
[F:MTS]MFGMODC = 2  
[F:MTS]MFGMODO = 2  

Gosub RECH_GAMME

# Message d'information mais on passe quand même
If   WRET
     [F:MTS]MFGMODC = 1 
     [F:MTS]MFGMODO = 1  
     WRET = 0
     If GMESSAGE <> ""
         MESSAGE = GMESSAGE : Gosub ENHANCE_TRACE
         Call ECR_TRACE(MESSAGE,0) From GESECRAN
         Raz GMESSAGE
     Endif
     Return
Endif

Return



#############################################################
Subprog CONTMFGITM(LFCY) 
Value Char     LFCY 
Local    Integer  VS 
# 
Case [F:ITM]ITMSTA  
    When 1,2,3  :  #   Article actif  ou non disponible( non bloquant) = ok  
    When Default:  #   Article non disponible (bloquant) 
                   GMESSAGE = (mess(3,196,1)+" ("+mess([F:ITM]ITMSTA,246,1)+")") 
                   End   
Endcase   
#    Article non fabriqué  
If [F:ITM]MFGFLG <> 2  
    GMESSAGE = mess(44,193,1)   
    End  
Endif  

#    Article non géré en stock   
If !find([F:ITM]STOMGTCOD,2,3,4)   
  GMESSAGE = mess(147,199,1) 
  End   
Endif   
End  

#########################################################################   
$RECH_GAMME   
Local Integer I
Local Integer  TABTBO(3)

# Il y a une gamme dans l'OF Intégrale
If [F:XOF]CODGAM <> ""
    Read [F:XNMC]IND0 =[F:XOF]CODNMCSPF;[F:XOF]CODGAM;[F:XOF]CODNUMNMC;0
    If !fstat & FLGREP = 2
        # Lecture article Integrale
        Read [F:XART]IND0 = [F:XOF]CODGAM
        If fstat 
             MESSAGE = [F:XOF]CODGAM - SI_MES(9) : Gosub ENHANCE_TRACE
             Call ECR_TRACE(MESSAGE,-2) From GESECRAN
             WRET = 1
             Return
        Endif
        # code article = article + site
        WX3_ROUNUM = func SIXFONCTION.SI_COR("XIART",[F:XART]CODART,"","") + GFCY 
        # Lecture article X3
        Read [F:ITM]ITM0 = WX3_ROUNUM
        If fstat
             MESSAGE = mess (134,100,1) - WX3_ROUNUM : Gosub ENHANCE_TRACE
             Call ECR_TRACE(MESSAGE,-2) From GESECRAN
             WRET = 1
             Return
        Endif
        Read [ITF]ITF0=[F:ITM]ITMREF;GFCY  
        If fstat   
           MESSAGE = mess(45,193,1)  - WX3_ROUNUM : Gosub ENHANCE_TRACE
           Call ECR_TRACE(MESSAGE,-2) From GESECRAN 
           WRET = 1
           Return 
        Endif
        # Si il y a une gamme dans l'OF , la nomenclature Intégrale récupérée est en fait une gamme
        # Dans X3CLE on va trouver l'alternative de gamme X3
        WX3_ROUALT = val(func SIXFONCTION.SI_COR4("XINMC",[F:XNMC]ZONSPF,[F:XNMC]CODARTCSE,num$([F:XNMC]NUMNMC),num$([F:XNMC]NUMCST),"",""))
        Read [F:ROH]ROH0 = WX3_ROUNUM;WX3_ROUALT;GFCY       # 56567
        If !fstat & [F:ROH]USESTA = 2 & [F:ROH]CFMFLG = 2
            Read [F:TRO]TRO0 = [F:ITF]MFGROUALT
            If fstat | ([F:TRO]FCY<> "" & [F:TRO]FCY=GFCY)|[F:TRO]MFGUSE<>2  : WRET = 1: Return : Endif
            Raz TABTBO,I
            # Contrôle de cohérence de l'alternative de nomenclature
            TABTBO(0)=[F:TRO]BOMALT1  
            TABTBO(1)=[F:TRO]BOMALT2  
            TABTBO(2)=[F:TRO]BOMALT3  
            If !find(WX3_BOMALT, TABTBO) :  WX3_ROUALT = 0 : WRET = 1 : Return : Endif
            WRET = 0
            Return
        Endif
    Endif
Endif
#On va essayer de trouver une gamme qui va bien
If [F:ITF]STOFCY <> GFCY | [F:ITF]ITMREF <> WX3_ITM
    Read [F:ITF]ITF0 = WX3_ITM;GFCY
    If fstat : Raz [F:ITF] : Endif
Endif
WRET = 1
#    Lecture ROUTING  
If [F:ITF]MFGROU <> "" : WX3_ROUNUM = [F:ITF]MFGROU : Else : WX3_ROUNUM = WX3_ITM : Endif
If [F:ITF]MFGROUALT <> 0
    Read [F:ROH]ROH0 = [F:ITF]MFGROU;[F:ITF]MFGROUALT;GFCY    # 56567
    If !fstat & [F:ROH]USESTA = 2 & [F:ROH]CFMFLG = 2
        Read [F:TRO]TRO0 = [F:ITF]MFGROUALT
        If fstat | ([F:TRO]FCY<> "" & [F:TRO]FCY=GFCY)|[F:TRO]MFGUSE<>2  : WRET = 1: Return : Endif
        Raz TABTBO,I
        # Contrôle de cohérence de l'alternative de nomenclature
        TABTBO(0)=[F:TRO]BOMALT1  
        TABTBO(1)=[F:TRO]BOMALT2  
        TABTBO(2)=[F:TRO]BOMALT3  
        If !find(WX3_BOMALT, TABTBO) : WRET = 1 : Return : Endif
        WRET = 0
        Return
    Endif
Endif
#
For [ROH] Where ITMREF=WX3_ROUNUM & FCY=GFCY    # 56567
    If !fstat & [F:ROH]USESTA = 2 & [F:ROH]CFMFLG = 2
        Read [TRO]TRO0=[F:ROH]ROUALT  
        If fstat | ([F:TRO]FCY<>"" & [F:TRO]FCY<>GFCY)|[F:TRO]MFGUSE<>2 : Goto NXT_ROH : Endif
        Raz TABTBO,I
        # Contrôle de cohérence de l'alternative de nomenclature
        TABTBO(0)=[F:TRO]BOMALT1  
        TABTBO(1)=[F:TRO]BOMALT2  
        TABTBO(2)=[F:TRO]BOMALT3  
        If !find(WX3_BOMALT, TABTBO) : Goto NXT_ROH : Endif
        WRET = 0
        Break
    Endif
$NXT_ROH
Next  
Return    


##########################################################################
$CRE_WOF


Raz [M:MFGK]

[M:MFGK]CODMAJ    = "C" 
[M:MFGK]AUTOTRT   = 2
[M:MFGK]CODTRS    = 0
[M:MFGK]MFGNUM    = ""
[M:MFGK]MFGLIN    = 0
[M:MFGK]MFGFCY    = GFCY
[M:MFGK]MFGSTA    = 1
[M:MFGK]ITMREF    = WX3_ITM
[M:MFGK]PRVQTY    = 0
[M:MFGK]EXTQTY    = WX3_QTY
[M:MFGK]STRDAT    = [F:XOF] DATDEBTRX
[M:MFGK]ENDDAT    = [F:XOF] DATFINPRV
[M:MFGK]BOMALT    = WX3_BOMALT
If [F:MTS]MFGMODO = 2  
    [M:MFGK]ROUNUM    = [F:ROH]ITMREF
    [M:MFGK]ROUALT    = [F:ROH]ROUALT
Endif
[M:MFGK]FMI       = 1
[M:MFGK]BPRNUM    = ""
[M:MFGK]PJT       = [F:XOF]CODAFR
[M:MFGK]PIO       = 1
[M:MFGK]VCRTYPORI = 0
[M:MFGK]VCRNUMORI = ""
[M:MFGK]VCRLINORI = 0
[M:MFGK]VCRSEQORI = 0
[M:MFGK]WIPTYP    = 0
[M:MFGK]WIPNUM    = ""  
Case [F:MTS]SCDMODSAI
    When 1:    [M:MFGK]SCDMOD = 1
    When 2:    [M:MFGK]SCDMOD = 2
    When Default: [M:MFGK]SCDMOD = 1
Endcase
Call MAJ_OF From MFGAUTLIB
If GOK > 0 & [M:MFGK]CODRET=0
    Readlock [F:MFG]MFG0 = [M:MFGK]MFGNUM
    [F:MFG]SINUM = func GETSISTRINGDB([F:XOF]NUMSER,[F:XOF]NUMPIE,[F:XLIG]NUMLIG)
    #Récupération du texte Intégrale  
    Call RECUP_TEXTE([F:MFG]MFGTEX)  
    Rewrite [F:MFG]
Endif
Return

##########################################################################
Subprog RECUP_TEXTE(LNUMTEX)
Variable Char LNUMTEX
Local    Integer I,WTEX
Raz SI_CLOB, WTEX
# On récupère le texte du bloc note si il est présent, sinon le texte des commentaires
Filter [F:XBLN] Where PRF = "ZP" & NUMORDPIE = [F:XOF]NUMORD
Read [F:XBLN]IND0 First
If fstat = 0
    For I = 1 To 19
        If I < 10
            SI_CLOB(I-1) =  evalue("[F:XBLN]LIG0" + num$(I))
        Else
            SI_CLOB(I-1) =  evalue("[F:XBLN]LIG" + num$(I))
        Endif
    Next
Elsif [F:XOF]CMT1 <> ""
    For I = 1 To 5
        SI_CLOB(I-1) =  evalue("[F:XOF]CMT" + num$(I))
    Next
Endif
LNUMTEX = func SIXFONCTION.SI_CLOB("MFG") 
Filter [F:XBLN]
End

##########################################################################
$OPEN_FILES
If clalev ([F:ORD1])<= 0 : Local File=SI_DOSSIER+".ORDERS"     [ORD1]: Endif 
If clalev ([F:ITM]) <= 0 : Local File=SI_DOSSIER+".ITMMASTER"  [ITM] : Endif
If clalev ([F:ITF]) <= 0 : Local File=SI_DOSSIER+".ITMFACILIT" [ITF] : Endif
If clalev ([F:MFG]) <= 0 : Local File=SI_DOSSIER+".MFGHEAD"    [MFG] : Endif
If clalev ([F:MFI]) <= 0 : Local File=SI_DOSSIER+".MFGITM"     [MFI] : Endif
If clalev ([F:SCH]) <= 0 : Local File=SI_DOSSIER+".SCHEDULING" [SCH] : Endif
If clalev ([F:FCY]) <= 0 : Local File=SI_DOSSIER+".FACILITY"   [FCY] : Endif
#If clalev ([F:TUV]) <= 0 : Local File=SI_DOSSIER+".TABUNAVAIL" [TUV] : Endif
If clalev ([F:TBO]) <= 0 : Local File=SI_DOSSIER+".TABBOMALT"  [TBO] : Endif
If clalev ([F:TRO]) <= 0 : Local File=SI_DOSSIER+".TABROUALT"  [TRO] : Endif
If clalev ([F:BOH]) <= 0 : Local File=SI_DOSSIER+".BOM"        [BOH] : Endif
If clalev ([F:ROH]) <= 0 : Local File=SI_DOSSIER+".ROUTING"    [ROH] : Endif
If clalev ([F:MTS]) <= 0 : Local File=SI_DOSSIER+".MFGTRS"     [MTS] : Endif
If clalev ([F:SPX]) <= 0 : Local File=SI_DOSSIER+".SIPARX3"    [SPX] : Endif
If clalev ([M:MFGK])<= 0 : Local Mask=SI_DOSSIER+".MFGK"      [MFGK] : Endif

#
If !clalev([F:XART]): Local File =SI_DOSSIER+".XIART"      [XART] : Endif
If !clalev([F:XOF]) : Local File =SI_DOSSIER+".XIETTOF"    [XOF]  : Endif
If !clalev([F:XLIG]): Local File =SI_DOSSIER+".XILIGOF"    [XLIG] : Endif
If !clalev([F:XUNI]): Local File =SI_DOSSIER+".XIUNIFAC"   [XUNI] : Endif
If !clalev([F:XBLN]): Local File =SI_DOSSIER+".XIBLNETPIE" [XBLN] : Endif
If !clalev([F:XNMC]): Local File =SI_DOSSIER+".XINMC"      [XNMC] : Endif
# 05.08 (instance supplémentaire de [XOF] pour la double boucle de recherche
If !clalev([F:XOF1]): Local File =SI_DOSSIER+".XIETTOF"    [XOF1] : Endif
Return

######################################################################## 
$CHARG_PARAM
#----- Variables globales stock 
Call GETDEV(GFCY)     From DEVSUB :#Pour récupérer GSOCIETE
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
#----- Temporaire pour régler pb GSEQAUTO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return

######################################################################## 
$ENHANCE_TRACE
MESSAGE -= "("+func GETSISTRINGLOG([F:XOF]NUMSER,[F:XOF]NUMPIE,[F:XOF]NUMORD,[F:XOF]LETRLQ,[F:XLIG]NUMLIG)+
&          "-"+[F:XLIG]CODART+"-"+num$([F:XOF1]CODNUMNMC)+")"
Return

########################################################################
Funprog GETSISTRINGLOG( LNUMSER, LNUMPIE, LNUMORD, LLETRLQ, LNUMLIG)
Value    Char     LNUMSER
Value    Char     LNUMPIE
Value    Integer  LNUMORD
Value    Char     LLETRLQ
Value    Integer  LNUMLIG

Local Char LSTRING

LSTRING = "PP"+LNUMSER+LNUMPIE+"-"+num$(LNUMORD)+LLETRLQ+"-"+num$(LNUMLIG)

End LSTRING

########################################################################
Funprog GETSISTRINGDB( LNUMSER, LNUMPIE, LNUMLIG)
Value    Char     LNUMSER
Value    Char     LNUMPIE
Value    Integer  LNUMLIG

Local Char LSTRING

LSTRING = "PP"+LNUMSER+LNUMPIE+"-"+num$(LNUMLIG)

End LSTRING

