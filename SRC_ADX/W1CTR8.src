$ON_XITGRD
Onevent BEFORE_INPUT Call AS_XITGRD(zc) From W1CTR8
Onevent CONTROL Call C_XITGRD(zc) From W1CTR8
Onevent AFTER_CHANGE Gosub AMM_XITGRD From W1CTR8
Return

Subprog AS_XITGRD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(37037,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
## Action DEFHRXGD
Call DEFHRXGD(VALEUR,GCURLEG,GSOCIETE) From SUBHRXGD
If mkstat=2
 [M]XITGRD(INDIC) = VALEUR
 Affzo XITGRD(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_XITGRD(zc) From W1CTR8
Onkey   2 Titled GBOUTS Call S_XITGRD(zc) From W1CTR8
Onkey 144 Titled GBOUTP Call P_XITGRD(zc) From W1CTR8
Onkey 146 Titled GBOUTA Call SA_XITGRD(zc) From W1CTR8
Gosub _AFF
End

Subprog C_XITGRD(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "XITGRD" : GZNUM = 47332 : Endif
If !mkstat
 ## Action CONTHRXGD
 Call CONTHRXGD(VALEUR,GCURLEG,GSOCIETE) From SUBHRXGD
 If mkstat : GERR = 1 : GZONE = "XITGRD" : GZNUM = 47332 : Endif
 If !mkstat
  ## Action CONTOBJN
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "CONTOBJN"
  Call S_AFF_CHAR(VALEUR,PARMSK,"CONTOBJN","CONTOBJ","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "XITGRD" : GZNUM = 47332 : Endif
  If !mkstat
   ## Action STD
   Call C_XITGRD(VALEUR) From SUBCTR
   If mkstat : GERR = 1 : GZONE = "XITGRD" : GZNUM = 47332 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_XITGRD
Call AM_XITGRD(zc)
If !mkstat & GOBJET
 zoncou = "XITGRD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_XITGRD(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_XITGRD(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "XITGRD" : GZNUM = 47332 : Endif
If !mkstat & evalue("dim("+clanam([M])+"ZXITGRD)")>indice
 [M]XITGRD(indice) = VALEUR
 Affzo ZXITGRD(indice)
Endif
Gosub _AFF
End

Subprog S_XITGRD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELHRXGD
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELHRXGD"
 PARMSK(1) = GCURLEG
 PARMSK(2) = GSOCIETE
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELHRXGD","SUBHRXGD","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_XITGRD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNHRXGD
 Call TUNHRXGD(VALEUR,GCURLEG,GSOCIETE) From SUBHRXGD
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

Subprog SA_XITGRD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "HRXGD"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_XITGRD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("HRXGD",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

