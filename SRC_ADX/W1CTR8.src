$AV_DATLIC
Chgfmt [M]DATLIC(indice) With "DzZ:"+GFMDAT4
Gosub _AFF
Return

Subprog AS_DATLIC(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_DATLIC(VALEUR) From SUBCTR
If mkstat=2
 [M]DATLIC(INDIC) = VALEUR
 Affzo DATLIC(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

