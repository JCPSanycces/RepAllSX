$ON_XITLEA
Onevent INIT_AREA Call D_XITLEA(zc) From W1CTR8
Onevent CONTROL Call C_XITLEA(zc) From W1CTR8
Onevent BEFORE_INPUT Call AS_XITLEA(zc) From W1CTR8
Onevent AFTER_CHANGE Gosub AMM_XITLEA From W1CTR8
Return

Subprog D_XITLEA(VALEUR)
Variable Char    VALEUR()
If varinit([M]XITLEA,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"10379","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_XITLEA(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"10379") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_XITLEA(zc) From W1CTR8
Onkey   2 Titled GBOUTS Call S_XITLEA(zc) From W1CTR8
Onkey 144 Titled GBOUTP Call P_XITLEA(zc) From W1CTR8
Onkey 146 Titled GBOUTA Call SA_XITLEA(zc) From W1CTR8
Gosub _AFF
End

Subprog C_XITLEA(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"10379","") From SUBADI
If mkstat : GERR = 1 : GZONE = "XITLEA" : GZNUM = 46633 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"10379",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "XITLEA" : GZNUM = 46633 : Endif
Endif
Gosub _AFF
End

$AMM_XITLEA
Call AM_XITLEA(zc)
If !mkstat & GOBJET
 zoncou = "XITLEA" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_XITLEA(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZXITLEA)")>indice
 [M]XITLEA(indice) = VALEUR
 Affzo ZXITLEA(indice)
Endif
Gosub _AFF
End

Subprog S_XITLEA(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADILEG
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADILEG"
 PARMSK(1) = "10379"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADILEG","SELTABCPT","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_XITLEA(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"10379") From GOBJET
Gosub _AFF
End

Subprog SA_XITLEA(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "10379"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_XITLEA(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "10379"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

