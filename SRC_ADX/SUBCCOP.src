############################################################
$COP_TRT
WCPT = 0
Local Char    WTRT(10)(27)
Local Integer STAT
Local Char    DOSORG(20)  , DOSDES(20)
Local Char    MACORG(40)  , MACDES(40)
Local Char    FICORG(250) , FICDES(250)
Local Char    EXT(5)
Local Integer I
#
WTRT(00) = "CFGLIB"
WTRT(01) = "CFGLIBA"
WTRT(02) = "CFGLIBB"
WTRT(03) = "CFGLIBC"
WTRT(04) = "CFGLIBD"
WTRT(05) = "XXCFG"
WTRT(06) = "XXACT"
WTRT(07) = "VISUMFG"
WTRT(08) = "LLCLIB"
WTRT(09) = "SUBTCT"
WTRT(10) = "SUBCAB"
WTRT(11) = "SUBCCOP"
WTRT(12) = "SUBCFG"
WTRT(13) = "SUBCFGF"
WTRT(14) = "SUBCFGH"
WTRT(15) = "SUBCFGI"
WTRT(16) = "SUBCSEL"
WTRT(17) = "SUBCWIN"
WTRT(18) = "SUBCFH"
WTRT(19) = "SUBCFM"
WTRT(20) = "SUBCQU"
WTRT(21) = "SUBCSE"
WTRT(22) = "SUBCSH"
WTRT(23) = "SUBTLP"
WTRT(24) = "SUBCFA"
WTRT(25) = "SUBCPU"
WTRT(26) = "SUBCFGU"
#
For I = 0 To dim(WTRT)-1
  Call TEMPON(WTRT(I)) From GESECRAN
  Call MACHINE([M]DOSORG,MACORG,DOSORG) From ORDSYS
  Call MACHINE([M]DOSDES,MACDES,DOSDES) From ORDSYS
  For EXT = "adx","src"
    Call PATHFIL(FICORG,"TRT",WTRT(I),EXT,DOSORG,"",MACORG) From DOSCONT
    If filinfo(FICORG,0)>=0
      Call PATHFIL(FICDES,"TRT",WTRT(I),EXT,DOSDES,"",MACDES) From DOSCONT
      Call COPIE(FICORG,FICDES,STAT) From ORDSYS
      If EXT = "adx"
        WCPT += 1
        Call ECR_TRACE(format$("N0:2#",WCPT)-mess(44,115,1)-WTRT(I),0) From GESECRAN
      Else
        Call ECR_TRACE("  "-mess(43,115,1)-WTRT(I),0) From GESECRAN
      Endif
    Endif
  Next EXT
  Call TEMPOFF From GESECRAN
Next I
Return
############################################################
$COP_MEN
WCPT = 0
Local Integer I
Local Integer WMEN(20)
WMEN(00) = 188
WMEN(01) = 752
If [M:DIA]UPDFLG = 2
  WMEN(02) = 0
Else
  WMEN(02) = 760
Endif
WMEN(03) = 761
WMEN(04) = 762
WMEN(05) = 763
WMEN(06) = 764
WMEN(07) = 765
WMEN(08) = 766
WMEN(09) = 767
WMEN(10) = 768
WMEN(11) = 769
WMEN(12) = 770
WMEN(13) = 771
WMEN(14) = 772
WMEN(15) = 773
WMEN(16) = 774
WMEN(17) = 775
WMEN(18) = 776
WMEN(19) = 213
For I = 0 To dim(WMEN)-1
  If WMEN(I) <> 0
    Call COPIE(WMEN(I)) From APLSTD
    Call ECR_TRACE(mess(1,30,1)-format$("N0:3#",WMEN(I)),0) From GESECRAN
  Endif
Next I
Return
############################################################
$BAC_MEN
Local File APLSTD    [MENE]
Local File CFGMENLOC [MENO]
WMSG = "Backup"
Gosub TRT_SVG
Close Local File [MENE]
Close Local File [MENO]
Return
############################################################
$RES_MEN
Local File CFGMENLOC [MENE]
Local File APLSTD    [MENO]
WMSG = "Restore"
Gosub TRT_SVG
Close Local File [MENE]
Close Local File [MENO]
Return
############################################################
$TRT_SVG
Local Integer WMEN(20)
WMEN(00) = 188
WMEN(01) = 752
WMEN(02) = 760
WMEN(03) = 761
WMEN(04) = 762
WMEN(05) = 763
WMEN(06) = 764
WMEN(07) = 765
WMEN(08) = 766
WMEN(09) = 767
WMEN(10) = 768
WMEN(11) = 769
WMEN(12) = 770
WMEN(13) = 771
WMEN(14) = 772
WMEN(15) = 773
WMEN(16) = 774
WMEN(17) = 775
WMEN(18) = 776
WMEN(19) = 213
For I = 0 To dim(WMEN)-1
  Trbegin [MENO]
  GOK = 1
  Delete [MENO] Where LANCHP = WMEN(I)
  fstat = 0
  Filter [MENE] Where LANCHP = WMEN(I)
  For [MENE]
    [F:MENO] = [F:MENE]
    Write [MENO]
    If fstat
      GOK = 0
      Call FSTA("MENO") From GLOCK
      Break
    Endif
  Next
  Filter [MENE]
  If GOK = 1
    Commit
    Call ECR_TRACE(WMSG-format$("N0:3#",WMEN(I)),0) From GESECRAN
  Else
    Rollback
  Endif
Next I
Return
############################################################
$TRT_SPE
# Mise en compatibilé selon version configurateur
If clalev([F:CSL]) = 0 : Local File CFGSCELIN [CSL] : Endif
If clalev([F:CFM]) = 0 : Local File CFGMAC    [CFM] : Endif
Trbegin [CSL]
GOK = 1
Filter [CSL]
For [CSL]
  Case [F:CSL]SYMDIS
    When 2       : [F:CSL]SYMDIS = 1
    When Default : [F:CSL]SYMDIS = 2
  Endcase
  Rewrite [CSL]
  If fstat
    GOK = 0
    Call FSTA("CSL") From GLOCK
    Break
  Endif
Next
Filter [CSL]
If GOK = 1
  Commit
Else
  Rollback
  Return
Endif
#
Trbegin [CFM]
GOK = 1
Filter [CFM]
For [CFM]
  Case [F:CFM]SYMDIS
    When 2       : [F:CFM]SYMDIS = 1
    When Default : [F:CFM]SYMDIS = 2
  Endcase
  Rewrite [CFM]
  If fstat
    GOK = 0
    Call FSTA("CFM") From GLOCK
    Break
  Endif
Next
#
Filter [CFM]
If GOK = 1
  Commit
Else
  Rollback
Endif
Return
############################################################
Subprog D_DOSORG(VALEUR)
Variable Char    VALEUR()
VALEUR = nomap
End
############################################################
Subprog AS_DOSORG(VALEUR)
Variable Char    VALEUR()
mkstat = 2
End
############################################################
Subprog AS_DOSDES(VALEUR)
Variable Char    VALEUR()
If [M]BACMEN = 2 | [M]RESMEN = 2 | [M]TRTSPE = 2
  mkstat = 2
  End
Endif
Call C_DOSSIER(GBIDC3) From DOSCONT
If mkstat
 mkstat = 0
Else
 VALEUR = GBIDC3
Endif
End
############################################################
Subprog C_DOSDES(VALEUR)
Variable Char    VALEUR()
If VALEUR=[M]DOSORG
  mkstat = 1
  End
Endif
GBIDC3 = VALEUR
End
############################################################
Subprog AS_BACMEN(VALEUR)
Variable Integer VALEUR
If [M]CFGFLG = 2 |
&  [M]TYPFLG = 2 |
&  [M]TABFLG = 2 |
&  [M]MSKFLG = 2 |
&  [M]WINFLG = 2 |
&  [M]ACTFLG = 2 |
&  [M]FONFLG = 2 |
&  [M]OBJFLG = 2 |
&  [M]TRTFLG = 2 |
&  [M]MENFLG = 2 |
&  [M]RESMEN = 2 |
&  [M]TRTSPE = 2
  VALEUR = 1
  mkstat = 2
Endif
End
############################################################
Subprog AS_RESMEN(VALEUR)
Variable Integer VALEUR
If [M]CFGFLG = 2 |
&  [M]TYPFLG = 2 |
&  [M]TABFLG = 2 |
&  [M]MSKFLG = 2 |
&  [M]WINFLG = 2 |
&  [M]ACTFLG = 2 |
&  [M]FONFLG = 2 |
&  [M]OBJFLG = 2 |
&  [M]TRTFLG = 2 |
&  [M]MENFLG = 2 |
&  [M]BACMEN = 2 |
&  [M]TRTSPE = 2
  VALEUR = 1
  mkstat = 2
Endif
End
############################################################
Subprog C_TRTSPE(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
  [M]UPDFLG = 1
  [M]CFGFLG = 1
  [M]TYPFLG = 1
  [M]TABFLG = 1
  [M]MSKFLG = 1
  [M]WINFLG = 1
  [M]ACTFLG = 1
  [M]FONFLG = 1
  [M]OBJFLG = 1
  [M]TRTFLG = 1
  [M]MENFLG = 1
  [M]BACMEN = 1
  [M]RESMEN = 1
  Affzo [M]UPDFLG
  Affzo [M]10-20
  Grizo [M]UPDFLG
  Grizo [M]10-15
Endif
End

