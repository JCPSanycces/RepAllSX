#<AdxTL>@(#)3.0.0.0 $Revision$ Gestion du masque CFGCOP
#CHECK UNUSED_SOURCE
Local Char PARAM(30)(1..1) , VALEUR(10)
PARAM(1) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBCCOP","CFGCOP",3) From GTRAITE
End

$ACTION
Case BCRIT
  When "CFGCOP"
    Case ACTION
      When "INIT_DIA"
      When "CONTROLE"
        TMP = 1
      When "EXEC"
        Gosub TRT_COP
  Endcase
Endcase
Return
############################################################
$TRT_COP
Local Char    WMSG(20)
Local Char    WACT(3) : WACT = "XCF"
Local Integer WCPT
Local Mask ACOPIE [DIA2]
Raz[M:DIA2]:Transmask [M:DIA] To [M:DIA2]# Issue 25606[M:DIA2] = [M:DIA]
#
Call OUVRE_TRACE("Copy configurator") From LECFIC
#
If [M:DIA]CFGFLG = 2 : Gosub COP_CFG : Endif
If [M:DIA]TYPFLG = 2 : Gosub COP_TYP : Endif
If [M:DIA]TABFLG = 2 : Gosub COP_TAB : Gosub MAJ_TAB : Endif
If [M:DIA]MSKFLG = 2 : Gosub COP_MSK : Gosub MAJ_MSK : Endif
If [M:DIA]WINFLG = 2 : Gosub COP_WIN : Endif
If [M:DIA]ACTFLG = 2 : Gosub COP_ACT : Endif
If [M:DIA]FONFLG = 2 : Gosub COP_FON : Endif
If [M:DIA]OBJFLG = 2 : Gosub COP_OBJ : Endif
If [M:DIA]TRTFLG = 2 : Gosub COP_TRT : Endif
If [M:DIA]MENFLG = 2 : Gosub COP_MEN : Endif
If [M:DIA]BACMEN = 2 : Gosub BAC_MEN : Endif
If [M:DIA]RESMEN = 2 : Gosub RES_MEN : Endif
If [M:DIA]TRTSPE = 2 : Gosub TRT_SPE : Endif
#
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
Return
############################################################
$COP_CFG
Local File ACTIV [ACV0]
Filter [ACV0] Where CODACT = WACT
For [ACV0]
  Call COPIE([F:ACV0]CODACT) From SUBACV
  Call ECR_TRACE("  "-mess(14,115,1)-[F:ACV0]CODACT,0) From GESECRAN
Next
Filter [ACV0]
Close Local File [ACV0]
Return
############################################################
$COP_TYP
WCPT = 0
Local File ATYPE [ATY0]
Filter [ATY0] Where CODACT = WACT
For [ATY0]
  Call COPIE([F:ATY0]CODTYP) From SUBATY
  WCPT += 1
  Call ECR_TRACE(format$("N0:2#",WCPT)-mess(5,42,1)-[F:ATY0]CODTYP,0) From GESECRAN
Next
Filter [ATY0]
Close Local File [ATY0]
Return
############################################################
$COP_TAB
WCPT = 0
#
Local File ATABLE [ATB0]
Filter [ATB0] Where CODACT = WACT
For [ATB0]
  Call COPIE([F:ATB0]CODFIC) From SUBATB
  WCPT += 1
  Call ECR_TRACE(format$("N0:2#",WCPT)-mess(56,123,1)-[F:ATB0]CODFIC,0) From GESECRAN
Next
Filter [ATB0]
Close Local File [ATB0]
Return
############################################################
$MAJ_TAB
Local Integer I
Local Char    WTAB(10)(06)
#
WTAB(00) = "BOM"
WTAB(01) = "ITMFACILIT"
WTAB(02) = "ITMMASTER"
WTAB(03) = "ITMMVT"
WTAB(04) = "ITMSALES"
WTAB(05) = "ROUTING"
# Mise à jour tables existantes
Local File ATABLE  [ATBL]
Local File ATABZON [ATZL]
Local File ATABIND [ATIL]
#
Local File =[M]DOSDES+".ATABLE"  [ATBE]
Local File =[M]DOSDES+".ATABZON" [ATZE]
Local File =[M]DOSDES+".ATABIND" [ATIE]
#
For I = 0 To dim(WTAB)-1
  Gosub MAJ_TABLE
Next I
#
Close Local File [ATBL]
Close Local File [ATZL]
Close Local File [ATIL]
Close Local File [ATBE]
Close Local File [ATZE]
Close Local File [ATIE]
Return
############################################################
$MAJ_TABLE
Trbegin [ATBE], [ATZE], [ATIE]
GOK = 1
Read [ATBL]CODFIC=WTAB(I)
If fstat
  Return
Endif
Read [ATBE]CODFIC=WTAB(I)
If fstat
  Return
Endif
Filter [ATZL] Where CODFIC = WTAB(I) & CODACT = WACT
For [ATZL]
  [F:ATZE] = [F:ATZL]
  Write [ATZE]
  If !find(fstat,0,3)
    GOK = 0
    Break
  Endif
  Call ECR_TRACE(mess(5,42,1)-[F:ATZL]CODFIC-[F:ATZL]CODZONE,0) From GESECRAN
Next
Filter [ATZL]
If GOK = 1
  Filter [ATIL] Where CODFIC = WTAB(I) & CODACT = WACT
  For [ATIL]
    [F:ATIE] = [F:ATIL]
    Write [ATIE]
    If !find(fstat,0,3)
      GOK = 0
      Break
    Endif
    Call ECR_TRACE(mess(5,42,1)-[F:ATIL]CODFIC-[F:ATIL]CODIND,0) From GESECRAN
  Next
  Filter [ATIL]
Endif
#
If GOK = 1
  Commit
Else
  Rollback
Endif
Return
############################################################
$COP_MSK
WCPT = 0
Local File AMSK [AMK0]
Filter [AMK0] Where CODACT = WACT  & left$(CODMSK,1) <> "W"
For [AMK0]
  Call COPIE([F:AMK0]CODMSK) From SUBAMK
  WCPT += 1
  Call ECR_TRACE(format$("N0:2#",WCPT)-mess(2,42,1)-[F:AMK0]CODMSK,0) From GESECRAN
Next
Filter [AMK0]
Close Local File [AMK0]
Return
############################################################
$MAJ_MSK
# Mise à jour masque ITM1
Local File AMSK    [AMKL]
Local File AMSKZON [AMZL]
Local File AMSKACT [AMAL]
Local File AMSKPAR [AMPL]
#
Local File =[M]DOSDES+".AMSK"    [AMKE]
Local File =[M]DOSDES+".AMSKZON" [AMZE]
Local File =[M]DOSDES+".AMSKACT" [AMAE]
Local File =[M]DOSDES+".AMSKPAR" [AMPE]
#
Trbegin [AMKE], [AMZE], [AMAE], [AMPE]
GOK = 1
#
Read [AMKL]CODMSK = "ITM1"
If fstat = 0
  Read [AMKE]CODMSK="ITM1"
  If fstat = 0
    If [F:AMKE]RANG(5) = 0
      [F:AMKE]RANG(5)    = [F:AMKL]RANG(5)
      [F:AMKE]TYPBLOC(5) = 5
      If [F:AMKE]NBBLOC = 5
        [F:AMKE]NBBLOC = 6
      Endif
      Rewrite [AMKE]
      If fstat
        GOK = 0
        Return
      Endif
    Endif
    Filter [AMZL] Where CODMSK = "ITM1" & CODACT = WACT
    For [AMZL]
      fstat = 0
      [F:AMZE] = [F:AMZL]
      Write [AMZE]
      If fstat = 0
        Call ECR_TRACE(mess(2,42,1)-[F:AMZL]CODMSK-[F:AMZL]CODZON,0) From GESECRAN
        Filter [AMAL] Where CODAFF = [F:AMZL]CODMSK  & CODZON = [F:AMZL]CODZON
        For [AMAL]
          [F:AMAE] = [F:AMAL]
          Write [AMAE]
          If fstat
            GOK = 0
            Break 2
          Endif
        Next
        Filter [AMAL]
        Filter [AMPL] Where CODAFF = [F:AMZL]CODMSK  & CODZON = [F:AMZL]CODZON
        For [AMPL]
          [F:AMPE] = [F:AMPL]
          Write [AMPE]
          If fstat
            GOK = 0
            Break 2
          Endif
        Next
        Filter [AMPL]
      Endif
    Next
    Filter [AMZL]
  Endif
Endif
#
If GOK = 1
  Commit
Else
  Rollback
Endif
Close Local File [AMKL]
Close Local File [AMZL]
Close Local File [AMAL]
Close Local File [AMPL]
Close Local File [AMKE]
Close Local File [AMZE]
Close Local File [AMAE]
Close Local File [AMPE]
Return
############################################################
$COP_WIN
