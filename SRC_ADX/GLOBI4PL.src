#########################################################
Subprog  KPL_DUR_DET ( E04DTDB1, E04DTFN1, E04DTDB2, E04DTFN2, E04DTDB3, E04DTFN3,
&                      E04DTFN4, E04DTFN5, E04TYPPRODAT, E04PSEPLN, E04SESFLG, S04DURDET)
#
# - Objet  : Calcule la durée de détention dans l'intervalle (exercice ou période) qui correspond
#            à un nombre de jours, de semaines de mois ou d'année selon le type prorata
#
# - Rem.   : Date de début 1 et Date de fin 1 doivent être obligatoirement renseignées
#            Si l'une ou l'autre est nulle alors la durée de détention sera nulle
#
#
# - Entrée :
#            Date de début de l'intervalle (période ou exercice ) (obligatoire)
#            Date de fin de l'intervalle (période ou exercice)    (obligatoire)
#            Date de début divers
#            Date de fin divers
#            Date de début d'amortissement
#            Date de fin d'amortissement
#            Date de sortie
#            Date de classement du bien comme détenu pour la vente
#            Plan de saisonnalité
#
# - Sortie : Durée de détention
#
#   Boite noire gcfcd3
#
Value Date         E04DTDB1, E04DTDB2, E04DTDB3, E04DTFN1, E04DTFN2, E04DTFN3, E04DTFN4, E04DTFN5
Value Char         E04TYPPRODAT, E04PSEPLN
Value Integer      E04SESFLG
Variable Decimal   S04DURDET : S04DURDET = 0


#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
Local Shortint CALL_E04
Goto $DEB_KPL_DUR_DET
$GSB_KPL_DUR_DET
  # Déclaration des paramètres en entrée
  Local Date      E04DTDB1        : E04DTDB1     = [M:DIV]PD(0)
  Local Date      E04DTFN1        : E04DTFN1     = [M:DIV]PD(1)
  Local Date      E04DTDB2        : E04DTDB2     = [M:DIV]PD(2)
  Local Date      E04DTFN2        : E04DTFN2     = [M:DIV]PD(3)
  Local Date      E04DTDB3        : E04DTDB3     = [M:DIV]PD(4)
  Local Date      E04DTFN3        : E04DTFN3     = [M:DIV]PD(5)
  Local Date      E04DTFN4        : E04DTFN4     = [M:DIV]PD(6)
  Local Date      E04DTFN5        : E04DTFN5     = [M:DIV]PD(7)
  Local Char      E04TYPPRODAT    : E04TYPPRODAT = [M:DIV]PC(0)
  Local Char      E04PSEPLN       : E04PSEPLN    = [M:DIV]PC(1)
  Local Integer   E04SESFLG       : E04SESFLG    = [M:DIV]PE(0)
  Local Decimal   S04DURDET

$DEB_KPL_DUR_DET
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

Local Date    L04DTDBDET , L04DTFNDET


  # Date de début & fin dans l'intervalle (exercice ou période)
  #Call CAL_DAT_BORNES
  #&    ( E04DTDB1, E04DTFN1, E04DTDB2, E04DTFN2, E04DTDB3, E04DTFN3, E04DTFN4,
  #&      E04DTFN5, L04DTDBDET, L04DTFNDET) From =G_GLOB9
  [M:DIV]PD(0)= E04DTDB1 : [M:DIV]PD(1)= E04DTFN1 : [M:DIV]PD(2)= E04DTDB2 : [M:DIV]PD(3)= E04DTFN2
  [M:DIV]PD(4)= E04DTDB3 : [M:DIV]PD(5)= E04DTFN3 : [M:DIV]PD(6)= E04DTFN4 : [M:DIV]PD(7)= E04DTFN5
  Gosub GSB_CAL_DAT_BORNES From =G_GLOB9
  L04DTDBDET = [M:DIV]RD(1)
  L04DTFNDET = [M:DIV]RD(2)
  If ([M:DIV]ERROR) Then :  If (dim(CALL_E04)<0) Then : Return : Else : End : Endif :   Endif

  # -1 --------------------------
  # Contrôle des dates obtenues
  If ( L04DTDBDET > L04DTFNDET ) Then
    S04DURDET = 0
  # -1 --------------------------
  Else
    If ( E04PSEPLN <> "" and E04SESFLG = G_OUI ) Then
      Local Integer IM
      S04DURDET = sigma( IM= month(L04DTDBDET), month(L04DTFNDET), [F:PSE]ACTFLG(IM-1) =G_OUI)
    Else
      # Durée de détention selon type de prorata
      #Call CAL_DAT_DIFF( L04DTDBDET, L04DTFNDET, PTYPPRODAT, S04DURDET ) From =G_GLOB9
      [M:DIV]PD(0)= L04DTDBDET : [M:DIV]PD(1)= L04DTFNDET : [M:DIV]PC(0)= E04TYPPRODAT
      Gosub GSB_CAL_DAT_DIFF From =G_GLOB9 : S04DURDET = [M:DIV]RV(0)
    Endif
  Endif
  # -1 --------------------------

  If ( S04DURDET < 0 ) Then : S04DURDET = 0 : Endif
  Call ECR_FICH("FS1", 9, "KPL_DUR_DET - Durée de détention              = " + num$(S04DURDET)  ) From =G_GLOB0



#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
If (dim(CALL_E04)<0) Then
 # Récupération des paramètres en sortie
 [M:DIV]RV(1) = S04DURDET
 Return
Endif
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

End

#

#
#########################################################
Subprog  KPL_DUR_REST_AMT (PVLNREF, PDOTREF, PDOTPERMIN, PSESFLG, PSESTYP, PPSEOPN, RDOTM, RNBM_REST_AMT)
#
# - Objet  : Calcule le mombre de mois "actif" restant à amortir
#
# - Entrée :
#
# - Sortie :
#            Nombre de mois actif restant à amortir
#            Dotation mensuelle de référence
#
Value    Decimal   PVLNREF
Value    Decimal   PDOTREF
Value    Decimal   PDOTPERMIN
Value    Integer   PSESFLG
Value    Integer   PSESTYP
Value    Integer   PPSEOPN
Variable Decimal   RDOTM
Variable Integer   RNBM_REST_AMT : RNBM_REST_AMT = 0

  # Dotation mensuelle
  RDOTM = PDOTREF /12
  If (PSESFLG = G_OUI and PSESTYP = GVML_STINCR) Then
    # Increasing
    RDOTM = PDOTREF /PPSEOPN
  Endif
  #Call CAL_ARRONDI_MNT (RDOTM, [M:DIV]CUR, RDOTM) From =G_GLOB8
  [M:DIV]PV(0)= RDOTM : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : RDOTM = [M:DIV]RV(1)

  Local Decimal L_NBM
  L_NBM = PVLNREF / RDOTM

  # Nombre de mois "actif" restant à amortir
  Local    Decimal   L_DECI   : L_DECI = L_NBM - fix(L_NBM)
  Local    Decimal   L_ENT    : L_ENT  = L_NBM - L_DECI
  If ( L_DECI <> 0 ) Then
    Local Decimal  WLSTDOTPER
    WLSTDOTPER = PVLNREF - (RDOTM * L_ENT)
    If ( WLSTDOTPER < PDOTPERMIN ) Then
      RNBM_REST_AMT = L_ENT
    Else
      RNBM_REST_AMT = L_ENT + 1
    Endif
  Else
    RNBM_REST_AMT = L_ENT
  Endif

  Call ECR_FICH("FS1", 9, "KPL_NBM_REST_AMT - Nbre de mois actif restant      = " + num$(RNBM_REST_AMT)  ) From =G_GLOB0

End


#
#########################################################
Subprog CAL_DATE_FIN_AMORT_MODE_ML ( PDTDBREF, PNBMACT, PPSEPLN, PSESFLG, RDTFNAMT )
#
# - Objet  : Renvoie la date de fin d'amortissement lorsque le mode ML
#            en fonction du type de prorata, de la date de début d'amortissement et d'une durée
#
#
# - Entrée :
#            Date de début
#            Vaaleur nette
#            Type de saisonnalité
#            Dotation exercice
# - Sortie :
#            Date de fin d'amortissement

#   Boite noire
#
Value    Date      PDTDBREF
Value    Integer   PNBMACT
Value    Char      PPSEPLN
Value    Integer   PSESFLG
Variable Date      RDTFNAMT

 #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif


  # Evaluation du nombre de mois d'amortissement (en tenant compte de la saisonnalité)
  Local Integer IMREG
  Local Integer IMMAX
  Local Integer IM
  IMMAX = (PNBMACT+1)*12
  IMCUR = month(PDTDBREF)
  IM = 0
  For IMREG = 1 To IMMAX
    If ( PPSEPLN <> "" and PSESFLG = G_OUI ) Then
      If ( [F:PSE]ACTFLG(IMCUR-1) = G_OUI ) Then
        IM = IM+1
        If (IM = PNBMACT) Then : Break : Endif
      Endif
      IMCUR = IMCUR +1
      If (IMCUR = 13) Then : IMCUR = 1 : Endif
    Else
      IMREG = PNBMACT : Break
    Endif
  Next IMREG

  # Détermination de la date de fin d'amortissement
  RDTFNAMT = PDTDBREF - 1
  RDTFNAMT = addmonth(RDTFNAMT, IMREG)
  RDTFNAMT = eomonth(RDTFNAMT)

End


#########################################################
Subprog  CAL_DOT_EXE_ML
#
# - Objet  : Calcule la dotation de l'exercice selon le mode ML
#            Linéaire polonais FQ67577
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#

Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir

  #If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #If ( [M:DIV]BDEBUG and [F:DEPC]DPRPLN = 2) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  [M:DIV]AMTEXC  = 0.
  [M:DIV]DOTEXE  = 0.
  If ( [F:DEPC]ACLCOE = 0. ) Then : [F:DEPC]ACLCOE = 1. : Endif

  # Valeur amortissable
  [M:DIV]VALAMT =  [M:DIV]BASAMT-[F:DEPC]RSDVAL
  # FQ112798
  Local Integer IM
  If([M:DIV]BMDR and [M:DIV2]LSTMDRDAT <> [0/0/0])
    IM = find([M:DIV2]LSTMDRDAT, [M:DEP]PERSTRDAT)
    Case [M:DIV]TYPCAL
      When "R","T"
        [M:DIV]VALAMT = [M:DEP]DPRBAS(IM-1)-[F:DEPC]RSDVAL
      When "I"
        [M:DIV]VALAMT = [M:DEP]BSEVAL(IM-1)-[F:DEPC]RSDVAL
    Endcase
  Endif

  # En cas de modernisation dans l'exercice,  la dotation exercice
  # est majorée des amortissements déjà constatés sur les périodes closes avant modernisation
  # La valeur nette début de période de modernisation doit être prise en compte
  # pour la détermination de la date de fin d'amortissement
  Local Date     L_DTDBPER
  Local Decimal  L_VLNAMT
  If ([M:DIV]DTDBPER > [M:DIV]DTDBAMTREG) Then
    L_DTDBPER   = [M:DIV]DTDBPER
  Else
    L_DTDBPER   = [M:DIV]DTDBAMTREG
  Endif

  # FQ112798
  # L_KMDRDAT est affectée avec la date de modernisation que le calcul doit interpréter
  # Soit c'est la date de modernisation de la période si elle est applicable (<= à la période)
  # soit c'est la date de dernière modernisation "effective" dans le cas d'une nième modernisation.
  Local Date L_KMDRDAT
  L_KMDRDAT = [0/0/0]
  If ( [F:DEPC]KMDRDAT <> [0/0/0]) Then
    If ( [F:DEPC]KMDRDAT <= [F:DEPC]PERSTRDAT ) Then
      L_DTDBPER   = [F:DEPC]KMDRDAT
      L_KMDRDAT   = [F:DEPC]KMDRDAT
    Else
      If ([M:DIV2]LSTMDRDAT <> [0/0/0])
        L_DTDBPER   = [M:DIV2]LSTMDRDAT
        L_KMDRDAT   = [M:DIV2]LSTMDRDAT
      Else
        L_DTDBPER   = [F:DEPC]KMDRDAT
        L_KMDRDAT   = [F:DEPC]KMDRDAT
      Endif
    Endif
  Endif

  L_VLNAMT         = [M:DIV]VLNAMT
  [M:DIV]MDRCUMP_1 = 0
  # Indice période de modernisation
  IM = find(L_DTDBPER, [M:DEP]PERSTRDAT)
  # Sauvegarde DEPC dans WDEP
  [F:WDEP]= [F:DEPC]
  # Positionnement DEPC sur période de modernisation
  nolign = IM
  [F:DEPC] = [M:DEP]
  [F:DEPC]BSEVAL = [M:DIV]VALAMT
  [F:DEPC]DPRBAS = [M:DIV]VALAMT
  Case [M:DIV]TYPCAL
    When "R"
      [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - RDP" : Gosub CAL_ADDLVL  From =G_GLOB0
      #Call CAL_VALEUR_NETTE ( "RDP", [F:DEPC]DPRBAS, 0, [M:DIV]BMDR, [F:DEPC]NBV  ) From =G_GLOB4
      [M:DIV]PC(0)= "RDP" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 0 : [M:DIV]PE(1)= [M:DIV]BMDR
      Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
      L_VLNAMT = [M:DIV]RV(1)
      # En cas de modernisation
      # FQ112798
      If ([M:DIV]BMDR and [F:WDEP]KMDRDAT <> [0/0/0] and [F:WDEP]PERSTRDAT >= L_KMDRDAT) Then
        [M:DIV]MDRCUMP_1 = [F:DEPC]PERCLOCUM
      Endif
    When "T"
      [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - TDP" : Gosub CAL_ADDLVL  From =G_GLOB0
      #Call CAL_VALEUR_NETTE ( "TDP", [F:DEPC]DPRBAS, 0, [M:DIV]BMDR, [F:DEPC]NBVT ) From =G_GLOB4
      [M:DIV]PC(0)= "TDP" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PE(0)= 0 : [M:DIV]PE(1)= [M:DIV]BMDR
      Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
      L_VLNAMT = [M:DIV]RV(1)
      # En cas de modernisation
      # FQ112798
      If ([M:DIV]BMDR and [F:WDEP]KMDRDAT <> [0/0/0] and [F:WDEP]PERSTRDAT >= L_KMDRDAT) Then
        [M:DIV]MDRCUMP_1 = [F:DEPC]PERCLOCUMT
      Endif
    When "I"
      [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - IDP" : Gosub CAL_ADDLVL  From =G_GLOB0
      #Call CAL_VALEUR_NETTE ( "IDP", [F:DEPC]BSEVAL, 0, [M:DIV]BMDR, [F:DEPC]NBVI ) From =G_GLOB4
      [M:DIV]PC(0)= "IDP" : [M:DIV]PV(0)= [F:DEPC]BSEVAL : [M:DIV]PE(0)= 0 : [M:DIV]PE(1)= [M:DIV]BMDR
      Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
      L_VLNAMT= [M:DIV]RV(1)
      # En cas de modernisation
      # FQ112798
      If ([M:DIV]BMDR and [F:WDEP]KMDRDAT <> [0/0/0] and [F:WDEP]PERSTRDAT >= L_KMDRDAT) Then
        [M:DIV]MDRCUMP_1 = [F:DEPC]PERCLOCUMI
      Endif
  Endcase

  # Restoration WDEP dans DEPC
  [F:DEPC] = [F:WDEP]

  # Déduction de l'ecart de modernisation si elle ne s'applique qu'après clôture de la période suivante
  # Ainsi la valeur amortissable est considéré hors modernisation
  If ( not([M:DIV]BMDR) and [F:DEPC]KMDRDEV <> 0) Then
    [M:DIV]VALAMT = [M:DIV]VALAMT-[F:DEPC]KMDRDEV
  Endif

  # La saisonnalité est-elle à appliquer pour le plan
  [M:DIV]SESFLG = val(mid$([F:WFAS]KSESFLG, [F:DEPC]DPRPLN, 1))

  # Valeur amortissable
  Local Decimal L_VALAMT
  L_VALAMT      = [M:DIV]VALAMT
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_ML - Valeur amortissable           =" + num$(L_VALAMT)   ) From =G_GLOB0

  # Valeur nette nulle
  If ( [M:DIV]VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_ML - Valeur nette amortissable déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH
&   ("FS1", 7, "CAL_DOT_EXE_ML - Dotation exercice   ="+ format$([M:DIV]CURFMT,[M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_ML - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_ML - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_ML - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_ML - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_ML - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_ML - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_ML - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_ML - Valeur amortissable   =" + num$([M:DIV]VALAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_ML - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_ML - Valnet amort déb exe  =" + num$([M:DIV]VLNAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_ML - Coef. d'accélèration  =" + num$([F:DEPC]ACLCOE) ) From =G_GLOB0
  Endif

  #=================
  # Taux / Duree
  #=================
  #-------------------------------
  If ( [F:DEPC]DPRRATFLG = G_OUI ) Then
    # Calcul de la durée à partir du taux forcé
    [M:DIV]TXAMT = [F:DEPC]DPRRAT
    # La durée d'amortissement est un nombre d'années devant correspondre à un nombre entier de mois
    # FQ76310
    #Call CAL_RETRAITE_DUREE_EN_MOIS ( (1/[M:DIV]TXAMT), [F:DEPC]DPRDUR )  From =G_GLOB9
    Call CAL_RETRAITE_DUREE_EN_MOIS ( (1/[M:DIV]TXAMT), [M:DIV]DURAMTREG )  From =G_GLOB9
    [F:DEPC]DPRDUR  = [M:DIV]DURAMTREG
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_ML - Taux forcé ........."       ) From =G_GLOB0
  #-------------------------------
  Else
    # Calcul du taux à partir de la durée
    # La durée d'amortissement est un nombre d'années devant correspondre à un nombre entier de mois
    Call CAL_RETRAITE_DUREE_EN_MOIS ( [F:DEPC]DPRDUR, [M:DIV]DURAMTREG )  From =G_GLOB9
    [F:DEPC]DPRDUR  = [M:DIV]DURAMTREG
    # Calcul du taux à partir de la durée ( pour stockage & affichage )
    [F:DEPC]DPRRAT = arr( (1/[F:DEPC]DPRDUR), 0.000001)
    # Calcul du taux à partir de la durée ( non arrondi pour calcul)
    [M:DIV]TXAMT = (1/[F:DEPC]DPRDUR)
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_ML - Taux  = (1/ Durée d'amort (année) ) * Coef.accél."       ) From =G_GLOB0
  Endif
  #-------------------------------
  # Nombre de mois d'amortissement
  Local Integer DUREM
  Call CAL_DUREE_OU_NBMOIS ("D", [M:DIV]DURAMTREG, DUREM, [F:DEPC]DPRDUR, DUREM ) From =G_GLOB9
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_ML - Taux                  =" + num$([M:DIV]TXAMT)   ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_ML - Durée d'amort (année) =" + num$([F:DEPC]DPRDUR) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_ML - Durée d'amort (mois)  =" + num$(DUREM)          ) From =G_GLOB0

  #=================
  # Date Fin Amort.
  #=================
  # Dotation exercice de référence  (linéaire de référence)
  Local Decimal L_DOTEXEREF
  L_DOTEXEREF = [M:DIV]VALAMT * [M:DIV]TXAMT * [F:DEPC]ACLCOE
  #Call CAL_ARRONDI_MNT (L_DOTEXEREF, [M:DIV]CUR, L_DOTEXEREF) From =G_GLOB8
  [M:DIV]PV(0)= L_DOTEXEREF : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : L_DOTEXEREF = [M:DIV]RV(1)
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_ML - Dot. Exe. référence   =" + num$(L_DOTEXEREF)) From =G_GLOB0
  Case [M:DIV]TYPCAL
      When "R" : [M:DIV]DOTEXEREF  = L_DOTEXEREF
      When "T" : [M:DIV]DOTEXEREFT = L_DOTEXEREF
      When "I" : [M:DIV]DOTEXEREFI = L_DOTEXEREF
  Endcase

  Local Decimal L_DOTPERREF
  Local Integer L_NBM_AMT
  Call KPL_DUR_REST_AMT
&      (L_VLNAMT, L_DOTEXEREF, [M:DIV]DOTPERMIN, [M:DIV]SESFLG , [M:DIV]SESTYP, [M:DIV]PSEMOPN,
&       L_DOTPERREF, L_NBM_AMT) From =G_GLOB4PL

  # FQ79813
  [M:DIV]PD(0) = L_DTDBPER
  [M:DIV]PE(0) = L_NBM_AMT
  Gosub CAL_DATE_FIN_AMORT_ML From =G_GLOB8
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_ML - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)   ) From =G_GLOB0

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_ML - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_ML - Val. amortissable     =" + num$(L_VALAMT)       ) From =G_GLOB0

  # Si la modernisation n'est pas à prendre en compte,
  # elle n'entre pas dans la détermination de la durée de détention.
  Local Date L_MDRDAT
  # FQ112798
  If ([M:DIV]BMDR) Then
    If ([M:DIV2]LSTMDRDAT <> [0/0/0]) Then
      L_MDRDAT = [M:DIV2]LSTMDRDAT
    Else
      L_MDRDAT = [F:DEPC]KMDRDAT
    Endif
  Else
    L_MDRDAT = [0/0/0]
  Endif
  # Durée de détention dans l'exercice
# Call  KPL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, L_MDRDAT, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&      [M:DIV]DATNUL, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, [M:DIV]PSEPLN, [M:DIV]SESFLG, WDURDET) From =G_GLOB4PL
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= L_MDRDAT
  [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DATNUL
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT  : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  [M:DIV]PC(1)= [M:DIV]PSEPLN    : [M:DIV]PE(0)= [M:DIV]SESFLG
  Gosub GSB_KPL_DUR_DET From =G_GLOB4PL
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_ML - Dot. Exe. référence         =" + num$(L_DOTEXEREF)) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_ML - Durée Détention Exe.        =" + num$(WDURDET) ) From =G_GLOB0

  # Durée de l'exercice de reférence
  Local Integer WDUREXE
  WDUREXE = 12
  If ([M:DIV]SESFLG = G_OUI and [M:DIV]SESTYP = GVML_STINCR ) Then : WDUREXE = [M:DIV]PSEMOPN : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_ML - Durée référence Exe.        =" + num$(WDUREXE) ) From =G_GLOB0

  #---------------------------------------------
  # Calcul Dotation exercice
  #---------------------------------------------
  If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I")  ) Then
    # La date de fin d'amortissement appartient à l'exercice
    # La valeur nette est soldée
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_ML - Fin amort <= Fin Exe. => Solde" ) From =G_GLOB0
    # calcul de la dotation exercice
    Call ECR_FICH("FS1",7, "Dotation exercice = Valnet amort déb exe  " ) From =G_GLOB0
    [M:DIV]DOTEXE = [M:DIV]VLNAMT
  Else
    Call ECR_FICH("FS1",7,
&     "Dotation exercice = Linéaire de référence * Durée détention / Durée exercice  " ) From =G_GLOB0
    [M:DIV]DOTEXE = L_DOTEXEREF * ( WDURDET / WDUREXE)
  Endif
  # En cas de modernisation, ajout des amortissements déjà constatés avant modernisation
  [M:DIV]DOTEXE = [M:DIV]DOTEXE + [M:DIV]MDRCUMP_1

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT ([M:DIV]DOTEXE, [M:DIV]CUR, [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= [M:DIV]DOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)
  #If ( [M:DIV]BDEBUG and [F:DEPC]DPRPLN = G301FIS) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif


  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_ML - Dotation exe.            =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End


#########################################################
Subprog  CAL_DOT_EXE_MD
#
# - Objet  : Calcule la dotation de l'exercice selon le mode MD
#            Degressif polonais FQ72372
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#

Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir

  #If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #If ( [M:DIV]BDEBUG and [F:DEPC]DPRPLN = 2) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #If ( [M:DIV]BDEBUG and ![M:DIV]BCUME_1 ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  [M:DIV]AMTEXC  = 0.
  [M:DIV]DOTEXE  = 0.
  If ( [F:DEPC]ACLCOE = 0. ) Then : [F:DEPC]ACLCOE = 1. : Endif

  # Valeur amortissable
  # FQ112798
  [M:DIV]VALAMT =  [M:DIV]BASAMT-[F:DEPC]RSDVAL
  If([M:DIV]BMDR and [M:DIV2]LSTMDRDAT <> [0/0/0])
    Local Integer IM
    IM = find([M:DIV2]LSTMDRDAT, [M:DEP]PERSTRDAT)
    Case [M:DIV]TYPCAL
      When "R","T"
        [M:DIV]VALAMT = [M:DEP]DPRBAS(IM-1)-[F:DEPC]RSDVAL
      When "I"
        [M:DIV]VALAMT = [M:DEP]BSEVAL(IM-1)-[F:DEPC]RSDVAL
    Endcase
  Endif

  # En cas de modernisation dans l'exercice,  la dotation exercice
  # est majorée des amortissements déjà constatés sur les périodes closes avant modernisation
  # La valeur nette début de période de modernisation doit être prise en compte
  # pour la détermination de la date de fin d'amortissement
  Local Date     L_DTDBPER
  Local Decimal  L_VLNAMT
  If ([M:DIV]DTDBPER > [M:DIV]DTDBAMTREG) Then
    L_DTDBPER = [M:DIV]DTDBPER
  Else
    L_DTDBPER = [M:DIV]DTDBAMTREG
  Endif

  # FQ112798
  # L_KMDRDAT est affectée avec la date de modernisation que le calcul doit interpréter
  # Soit c'est la date de modernisation de la période si elle est applicable (<= à la période)
  # soit c'est la date de dernière modernisation "effective" dans le cas d'une nième modernisation.
  Local Date L_KMDRDAT
  L_KMDRDAT = [0/0/0]
  If ( [F:DEPC]KMDRDAT <> [0/0/0]) Then
    If ( [F:DEPC]PERSTRDAT >= [F:DEPC]KMDRDAT ) Then
      L_DTDBPER   = [F:DEPC]KMDRDAT
      L_KMDRDAT   = [F:DEPC]KMDRDAT
    Else
      If ([M:DIV2]LSTMDRDAT <> [0/0/0])
        L_DTDBPER   = [M:DIV2]LSTMDRDAT
        L_KMDRDAT   = [M:DIV2]LSTMDRDAT
      Else
        L_DTDBPER   = [F:DEPC]KMDRDAT
        L_KMDRDAT   = [F:DEPC]KMDRDAT
      Endif
    Endif
  Endif

  [M:DIV]MDRCUMP_1 = 0
  # Sauvegarde DEPC dans WDEP
  [F:WDEP]= [F:DEPC]

  # Si la période n'est pas la période courante ( modernisation rétroactive)
  If ( L_DTDBPER <> [F:DEPC]PERSTRDAT ) Then
    # Indice période
    Local Integer IM
    IM = find(L_DTDBPER, [M:DEP]PERSTRDAT)
    # Positionnement DEPC sur période
    nolign = IM : [F:DEPC] = [M:DEP]
  Endif

  [F:DEPC]BSEVAL = [M:DIV]VALAMT
  [F:DEPC]DPRBAS = [M:DIV]VALAMT
  Case [M:DIV]TYPCAL
    When "R"
      [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - RDE" : Gosub CAL_ADDLVL  From =G_GLOB0
      #Call CAL_VALEUR_NETTE ( "RDE", [F:DEPC]DPRBAS, [M:DIV]SUB, 0, [M:DIV]BMDR, [F:DEPC]NBV  ) From =G_GLOB4
      [M:DIV]PC(0)= "RDE" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PV(1)= [M:DIV]SUB : [M:DIV]PE(0)= 0 : [M:DIV]PE(1)= [M:DIV]BMDR
      Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
      L_VLNAMT = [M:DIV]RV(1)
      # En cas de modernisation
      # FQ112798
      If ([M:DIV]BMDR and [F:WDEP]KMDRDAT <> [0/0/0] and [F:WDEP]PERSTRDAT >= L_KMDRDAT) Then
        [M:DIV]MDRCUMP_1 = [F:DEPC]PERCLOCUM
      Endif
    When "T"
      [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - TDE" : Gosub CAL_ADDLVL  From =G_GLOB0
      #Call CAL_VALEUR_NETTE ( "TDP", [F:DEPC]DPRBAS, [M:DIV]SUB, 0, [M:DIV]BMDR, [F:DEPC]NBVT ) From =G_GLOB4
      [M:DIV]PC(0)= "TDE" : [M:DIV]PV(0)= [F:DEPC]DPRBAS : [M:DIV]PV(1)= [M:DIV]SUB : [M:DIV]PE(0)= 0 : [M:DIV]PE(1)= [M:DIV]BMDR
      Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
      L_VLNAMT = [M:DIV]RV(1)
      # En cas de modernisation
      # FQ112798
      If ([M:DIV]BMDR and [F:WDEP]KMDRDAT <> [0/0/0] and [F:WDEP]PERSTRDAT >= L_KMDRDAT) Then
        [M:DIV]MDRCUMP_1 = [F:DEPC]PERCLOCUMT
      Endif
    When "I"
      [M:DIV]LVLLIB = "4.CAL_VALEUR_NETTE - IDE" : Gosub CAL_ADDLVL  From =G_GLOB0
      #Call CAL_VALEUR_NETTE ( "IDP", [F:DEPC]BSEVAL, [M:DIV]SUB, 0, [M:DIV]BMDR, [F:DEPC]NBVI ) From =G_GLOB4
      [M:DIV]PC(0)= "IDE" : [M:DIV]PV(0)= [F:DEPC]BSEVAL : [M:DIV]PV(1)= [M:DIV]SUB : [M:DIV]PE(0)= 0 : [M:DIV]PE(1)= [M:DIV]BMDR
      Gosub GSB_CAL_VALEUR_NETTE From =G_GLOB4
      L_VLNAMT= [M:DIV]RV(1)
      # En cas de modernisation
      # FQ112798
      If ([M:DIV]BMDR and [F:WDEP]KMDRDAT <> [0/0/0] and [F:WDEP]PERSTRDAT >= L_KMDRDAT) Then
        [M:DIV]MDRCUMP_1 = [F:DEPC]PERCLOCUMI
      Endif
  Endcase

  # Restoration WDEP dans DEPC
  [F:DEPC] = [F:WDEP]

  # Déduction de l'ecart de modernisation si elle ne s'applique qu'après clôture de la période suivante
  # Ainsi la valeur amortissable est considéré hors modernisation
  If ( not([M:DIV]BMDR) and [F:DEPC]KMDRDEV <> 0) Then
    [M:DIV]VALAMT = [M:DIV]VALAMT-[F:DEPC]KMDRDEV
  Endif

  # La saisonnalité est-elle à appliquer pour le plan
  [M:DIV]SESFLG = val(mid$([F:WFAS]KSESFLG, [F:DEPC]DPRPLN, 1))

  # Valeur nette nulle
  If ( [M:DIV]VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_MD - Valeur nette amortissable déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_MD - Dotation exercice   ="+ format$([M:DIV]CURFMT,[M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MD - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MD - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MD - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MD - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MD - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MD - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MD - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MD - Valeur amortissable   =" + num$([M:DIV]VALAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MD - Cumul  E-1            =" + num$([F:DEPC]DPRCUM) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MD - Valnet amort déb exe  =" + num$(L_VLNAMT)       ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_MD - Coef. d'accélèration  =" + num$([F:DEPC]ACLCOE) ) From =G_GLOB0
  Endif

  #=================
  # Taux / Duree
  #=================
  #-------------------------------
  If ( [F:DEPC]DPRRATFLG = G_OUI ) Then
    # Calcul de la durée à partir du taux forcé
    [M:DIV]TXAMT = [F:DEPC]DPRRAT
    # La durée d'amortissement est un nombre d'années devant correspondre à un nombre entier de mois
    Call CAL_RETRAITE_DUREE_EN_MOIS ( (1/[M:DIV]TXAMT), [F:DEPC]DPRDUR )  From =G_GLOB9
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_MD - Taux forcé ........." ) From =G_GLOB0
  #-------------------------------
  Else
    # Calcul du taux à partir de la durée
    # La durée d'amortissement est un nombre d'années devant correspondre à un nombre entier de mois
    Call CAL_RETRAITE_DUREE_EN_MOIS ( [F:DEPC]DPRDUR, [M:DIV]DURAMTREG )  From =G_GLOB9
    [F:DEPC]DPRDUR  = [M:DIV]DURAMTREG
    # Calcul du taux à partir de la durée ( non arrondi pour calcul)
    [M:DIV]TXAMT = (1/[F:DEPC]DPRDUR)
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_MD - Taux  = (1/ Durée d'amort (année) ) * Coef.accél." ) From =G_GLOB0
  Endif
  #-------------------------------
  # Nombre de mois d'amortissement
  Local Integer DUREM
  Call CAL_DUREE_OU_NBMOIS ("D", [M:DIV]DURAMTREG, DUREM, [F:DEPC]DPRDUR, DUREM ) From =G_GLOB9
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_MD - Taux                  =" + num$([M:DIV]TXAMT) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_MD - Durée d'amort (année) =" + num$([F:DEPC]DPRDUR) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_MD - Durée d'amort (mois)  =" + num$(DUREM) ) From =G_GLOB0

  #=================
  # Linéaire de référence
  #=================
   # Dotation exercice de référence  (linéaire de référence)
  Local Decimal L_LINEXEREF
  L_LINEXEREF = [M:DIV]VALAMT * [M:DIV]TXAMT
  #Call CAL_ARRONDI_MNT (L_LINEXEREF, [M:DIV]CUR, L_LINEXEREF) From =G_GLOB8
  [M:DIV]PV(0)= L_LINEXEREF : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : L_LINEXEREF = [M:DIV]RV(1)
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_MD - Linéaire de référence =" + num$(L_LINEXEREF) ) From =G_GLOB0
  Case [M:DIV]TYPCAL
      When "R" : [M:DIV]DOTEXEREF  = L_LINEXEREF
      When "T" : [M:DIV]DOTEXEREFT = L_LINEXEREF
      When "I" : [M:DIV]DOTEXEREFI = L_LINEXEREF
  Endcase
  #=================
  # Date Fin Amort.
  #=================
  [M:DIV]DTFNAMT = [0/0/0]
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_MD - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT) ) From =G_GLOB0


  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_MD - Pas d'amortissement Bien détenu pour la vente" ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  # Si la modernisation n'est pas à prendre en compte,
  # elle n'entre pas dans la détermination de la durée de détention.
  Local Date L_MDRDAT
  # FQ112798
  If ([M:DIV]BMDR) Then
    If ([M:DIV2]LSTMDRDAT <> [0/0/0]) Then
      L_MDRDAT = [M:DIV2]LSTMDRDAT
    Else
      L_MDRDAT = [F:DEPC]KMDRDAT
    Endif
  Else
    L_MDRDAT = [0/0/0]
  Endif

  # Durée de détention dans l'exercice
# Call  KPL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, L_MDRDAT, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&      [M:DIV]DATNUL, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, [M:DIV]PSEPLN, [M:DIV]SESFLG, WDURDET) From =G_GLOB4PL
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE    : [M:DIV]PD(2)= L_MDRDAT
  [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DATNUL
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT  : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  [M:DIV]PC(1)= [M:DIV]PSEPLN    : [M:DIV]PE(0)= [M:DIV]SESFLG
  Gosub GSB_KPL_DUR_DET From =G_GLOB4PL
  If ([M:DIV]ERROR) Then : End : Endif
  WDURDET = [M:DIV]RV(1)

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_MD - Valnet amort déb exe        =" + num$(L_VLNAMT) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_MD - Durée Détention Exe.        =" + num$(WDURDET) ) From =G_GLOB0

  # Durée de l'exercice de reférence
  Local Integer WDUREXE
  WDUREXE = 12
  If ([M:DIV]SESFLG = G_OUI and [M:DIV]SESTYP = GVML_STINCR ) Then : WDUREXE = [M:DIV]PSEMOPN : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_MD - Durée référence Exe.        =" + num$(WDUREXE) ) From =G_GLOB0

  #---------------------------------------------
  # Calcul Dotation exercice
  #---------------------------------------------
  # Dotation dégressive
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_MD - Dégressif = Val.net.déb Exe * Taux * accel * (Dur.dét./Dur.exe.)" ) From =G_GLOB0
  [M:DIV]DOTEXE = L_VLNAMT * [M:DIV]TXAMT * [F:DEPC]ACLCOE * ( WDURDET / WDUREXE)
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_MD - Dégressif =" + num$(arr([M:DIV]DOTEXE,0.01)) ) From =G_GLOB0    # Dotation linéaire
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_MD - Linéaire  = Linéaire de référence * Durée détention / Durée exercice" ) From =G_GLOB0
  Local Decimal L_DOTLIN
  L_DOTLIN = L_LINEXEREF * ( WDURDET / WDUREXE)
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_MD - Linéaire  =" + num$(arr(L_DOTLIN,0.01)) ) From =G_GLOB0


  # Bascule en linéaire
  If ( [M:DIV]DOTEXE < L_DOTLIN ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_MD - Bascule en linéaire"  ) From =G_GLOB0
    [M:DIV]DOTEXE      = L_DOTLIN
    [M:DIV]LINFLG      = G_OUI
  Else
    [M:DIV]LINFLG     = G_NON
  Endif

  # En cas de modernisation, ajout des amortissements déjà constatés avant modernisation
  [M:DIV]DOTEXE = [M:DIV]DOTEXE + [M:DIV]MDRCUMP_1

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT ([M:DIV]DOTEXE, [M:DIV]CUR, [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= [M:DIV]DOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)
  #If ( [M:DIV]BDEBUG and [F:DEPC]DPRPLN = G301FIS) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif


  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4


  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_MD - Dotation exe.            =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End

#***********************************************************
#
#         D O T A T I O N   -   E X E R C I C E
#
#   M o d e   a m o r t i s s e m e n t   R O U M A I N S
#
#***********************************************************
#
# Modèle
#If ( GUSER = "MWA" and [M:DIV]BDEBUG and [F:DEPC]AASREF = [F:DEPC]AASREF and [F:DEPC]DPRPLN = [F:DEPC]DPRPLN ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif



#########################################################
Subprog  KRO_DUR_DET ( E04DTDB1, E04DTFN1, E04DTDB2, E04DTFN2, E04DTDB3, E04DTFN3,
&                      E04DTFN4, E04DTFN5, E04TYPPRODAT, S04DURDET)
#
# - Objet  : Calcule la durée de détention dans l'intervalle (exercice ou période) qui correspond
#            à un nombre de jours, de semaines de mois ou d'année selon le type prorata
#
# - Rem.   : Date de début 1 et Date de fin 1 doivent être obligatoirement renseignées
#            Si l'une ou l'autre est nulle alors la durée de détention sera nulle
#
#
# - Entrée :
#            Date de début de l'intervalle (période ou exercice ) (obligatoire)
#            Date de fin de l'intervalle (période ou exercice)    (obligatoire)
#            Date de début divers
#            Date de fin divers
#            Date de début d'amortissement
#            Date de fin d'amortissement
#            Date de sortie
#            Date de classement du bien comme détenu pour la vente
#
# - Sortie : Durée de détention
#
#   Boite noire gcfcd3
#
Value Date         E04DTDB1, E04DTDB2, E04DTDB3, E04DTFN1, E04DTFN2, E04DTFN3, E04DTFN4, E04DTFN5
Value Char         E04TYPPRODAT
Variable Decimal   S04DURDET : S04DURDET = 0


#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
Local Shortint CALL_E04
Goto $DEB_KRO_DUR_DET
$GSB_KRO_DUR_DET
  # Déclaration des paramètres en entrée
  Local Date      E04DTDB1        : E04DTDB1     = [M:DIV]PD(0)
  Local Date      E04DTFN1        : E04DTFN1     = [M:DIV]PD(1)
  Local Date      E04DTDB2        : E04DTDB2     = [M:DIV]PD(2)
  Local Date      E04DTFN2        : E04DTFN2     = [M:DIV]PD(3)
  Local Date      E04DTDB3        : E04DTDB3     = [M:DIV]PD(4)
  Local Date      E04DTFN3        : E04DTFN3     = [M:DIV]PD(5)
  Local Date      E04DTFN4        : E04DTFN4     = [M:DIV]PD(6)
  Local Date      E04DTFN5        : E04DTFN5     = [M:DIV]PD(7)
  Local Char      E04TYPPRODAT    : E04TYPPRODAT = [M:DIV]PC(0)
  Local Decimal   S04DURDET

$DEB_KRO_DUR_DET
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

Local Date    L04DTDBDET , L04DTFNDET


  # Date de début & fin dans l'intervalle (exercice ou période)
  #Call CAL_DAT_BORNES
  #&    ( E04DTDB1, E04DTFN1, E04DTDB2, E04DTFN2, E04DTDB3, E04DTFN3, E04DTFN4,
  #&      E04DTFN5, L04DTDBDET, L04DTFNDET) From =G_GLOB9
  [M:DIV]PD(0)= E04DTDB1 : [M:DIV]PD(1)= E04DTFN1 : [M:DIV]PD(2)= E04DTDB2 : [M:DIV]PD(3)= E04DTFN2
  [M:DIV]PD(4)= E04DTDB3 : [M:DIV]PD(5)= E04DTFN3 : [M:DIV]PD(6)= E04DTFN4 : [M:DIV]PD(7)= E04DTFN5
  Gosub GSB_CAL_DAT_BORNES From =G_GLOB9
  L04DTDBDET = [M:DIV]RD(1)
  L04DTFNDET = [M:DIV]RD(2)
  If ([M:DIV]ERROR) Then :  If (dim(CALL_E04)<0) Then : Return : Else : End : Endif :   Endif

  # -1 --------------------------
  # Contrôle des dates obtenues
  If ( L04DTDBDET > L04DTFNDET ) Then
    S04DURDET = 0
  # -1 --------------------------
  Else
    # Durée de détention selon type de prorata
    #Call CAL_DAT_DIFF( L04DTDBDET, L04DTFNDET, PTYPPRODAT, S04DURDET ) From =G_GLOB9
    [M:DIV]PD(0)= L04DTDBDET : [M:DIV]PD(1)= L04DTFNDET : [M:DIV]PC(0)= E04TYPPRODAT
    Gosub GSB_CAL_DAT_DIFF From =G_GLOB9 : S04DURDET = [M:DIV]RV(0)
  Endif
  # -1 --------------------------

  # Déduction de la durée de détention du nonbre de mois d'arret dans la période P1 à Pc de l'exercice
  Call ECR_FICH("FS1", 9, "KRO_DUR_DET - Durée de détention              = " + num$(S04DURDET)  ) From =G_GLOB0
  S04DURDET = S04DURDET - [F:DEPC]KFIYNBMSTP
  If ( S04DURDET < 0 ) Then : S04DURDET = 0 : Endif
  Call ECR_FICH("FS1", 9, "KRO_DUR_DET - Nombre de mois d'arrêt          = " + num$([F:DEPC]KFIYNBMSTP) ) From =G_GLOB0
  Call ECR_FICH("FS1", 9, "KRO_DUR_DET - Durée de détention retraitée    = " + num$(S04DURDET)  ) From =G_GLOB0


#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
If (dim(CALL_E04)<0) Then
 # Récupération des paramètres en sortie
 [M:DIV]RV(1) = S04DURDET
 Return
Endif
#%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

End

#
#########################################################
Subprog  KRO_DUR_REST_AMT (PDTDBAMT, PDTDB, PDTFNAMT, RDUR_REST_AMT)
#
# - Objet  : Calcule la durée restant à amortir qui correspond à un nombre de mois
#            restant à courir jusqu'à la fin de l'amortissement
#
# - Entrée :
#
# - Sortie : Durée restant à amortir
#   Boite noire calc_dur_rest_amt (gcfc10)
#

Value     Date     PDTDBAMT, PDTDB, PDTFNAMT
Variable  Decimal  RDUR_REST_AMT : RDUR_REST_AMT = 0

Local     Date     LDAT

  LDAT = max(PDTDBAMT, PDTDB)
  # Si date de début > fin d'amortissement
  # la durée restant à amortir est nulle
  # ---------------------------
  If ( LDAT <= PDTFNAMT ) Then
    # Durée restant à amortir selon type de prorata
    #Call CAL_DAT_DIFF(LDAT, PDTFNAMT, "M", RDUR_REST_AMT ) From =G_GLOB9
    [M:DIV]PD(0)= LDAT: [M:DIV]PD(1)= PDTFNAMT : [M:DIV]PC(0)= "M"
    Gosub GSB_CAL_DAT_DIFF From =G_GLOB9 : RDUR_REST_AMT = [M:DIV]RV(0)
  Endif
  # ---------------------------

  # Déduction de la durée de détention du nonbre de mois d'arret dans la période P1 à Pc de l'exercice
  Call ECR_FICH("FS1", 9, "KRU_DUR_REST_AMT - Durée de détention              = " + num$(RDUR_REST_AMT)  ) From =G_GLOB0
  RDUR_REST_AMT = RDUR_REST_AMT - [F:DEPC]KFIYNBMSTP
  If ( RDUR_REST_AMT < 0 ) Then : RDUR_REST_AMT = 0 : Endif
  Call ECR_FICH("FS1", 9, "KRU_DUR_REST_AMT - Nombre de mois d'arrêt          = " + num$([F:DEPC]KFIYNBMSTP)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 9, "KRU_DUR_REST_AMT - Durée de détention retraitée    = " + num$(RDUR_REST_AMT)  ) From =G_GLOB0

End

#########################################################
Subprog  CAL_DOT_EXE_RL
#
# - Objet  : Calcule la dotation de l'exercice selon le mode RL
#            Linéaire roumains FQ77877
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#

Local Decimal WDURDET    : WDURDET     = 0.   : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.   : # Durée restant à amortir
Local Decimal WDOTEXE    : WDOTEXE     = 0.   : # Dotation exercice

  #If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #If ( [M:DIV]BDEBUG and [F:DEPC]DPRPLN = 2) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  [M:DIV]AMTEXC  = 0.
  [M:DIV]DOTEXE  = 0.

  # Valeur amortissable
  [M:DIV]VALAMT =  [M:DIV]BASAMT-[F:DEPC]RSDVAL

  # Valeur nette nulle
  If ( [M:DIV]VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RL - Valeur nette amortissable déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH
&   ("FS1", 7, "CAL_DOT_EXE_RL - Dotation exercice   ="+ format$([M:DIV]CURFMT,[M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RL - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RL - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RL - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RL - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RL - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RL - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RL - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RL - Valeur amortissable   =" + num$([M:DIV]VALAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RL - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RL - Valnet amort déb exe  =" + num$([M:DIV]VLNAMT)     ) From =G_GLOB0
  Endif

  #=================
  # Taux / Duree
  #=================
  #-------------------------------
  If ( [F:DEPC]DPRRATFLG = G_OUI ) Then
    # Calcul de la durée à partir du taux forcé
    [M:DIV]TXAMT = [F:DEPC]DPRRAT
    # La durée d'amortissement est un nombre d'années devant correspondre à un nombre entier de mois
    Call CAL_RETRAITE_DUREE_EN_MOIS ( (1/[M:DIV]TXAMT), [M:DIV]DURAMTREG )  From =G_GLOB9
    [F:DEPC]DPRDUR  = [M:DIV]DURAMTREG
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RL - Taux forcé ........."       ) From =G_GLOB0
  #-------------------------------
  Else
    # Calcul du taux à partir de la durée
    # La durée d'amortissement est un nombre d'années devant correspondre à un nombre entier de mois
    Call CAL_RETRAITE_DUREE_EN_MOIS ( [F:DEPC]DPRDUR, [M:DIV]DURAMTREG )  From =G_GLOB9
    [F:DEPC]DPRDUR  = [M:DIV]DURAMTREG
    # Calcul du taux à partir de la durée ( pour stockage & affichage )
    [F:DEPC]DPRRAT = arr( (1/[F:DEPC]DPRDUR), 0.000001)
    # Calcul du taux à partir de la durée ( non arrondi pour calcul)
    [M:DIV]TXAMT = (1/[F:DEPC]DPRDUR)
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RL - Taux  = (1/ Durée d'amort (année) )"       ) From =G_GLOB0
  Endif

  #=================
  # Date Fin Amort.
  #=================

  Gosub CAL_DATE_FIN_AMORT_RL From =G_GLOB8
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RL - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)   ) From =G_GLOB0
  If (find([F:DEPC]KSTPDEPSTA, GVML_SSNSTPP, GVML_SSTSTPP) <> 0 ) Then
    # Si Amorti prolongation ou suspendre prolongation alors ajout du nombre de mois d'arrêt
    [M:DIV]DTFNAMT = func GLOBB9.CAL_DAT_PLUS( [M:DIV]DTFNAMT, [F:DEPC]KNBMSTPDEP, "M" )
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RL - Fin d'amort retraitéé =" + num$([M:DIV]DTFNAMT)) From =G_GLOB0
  Endif

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RL - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  # Stop dépréciation - Si l'amortissement du bien est suspendu - FQ80825
  If ( find([F:DEPC]KSTPDEPSTA, GVML_SSSTOPD, GVML_SSRSTDI, GVML_SSRSTPR) <> 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RL - Amortissement suspendu"  ) From =G_GLOB0
    [M:DIV]AMTEXC = [F:DEPC]PERCLOEXC
    [M:DIV]DOTEXE = [F:DEPC]PERCLOCUM
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  #---------------------------------------------
  # Calcul Dotation exercice
  #---------------------------------------------
  #- 1 -----------------------------------------------------------
  If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I")  ) Then
#    # La date de fin d'amortissement appartient à l'exercice
#    # La valeur nette est soldée
#    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RL - Fin amort <= Fin Exe. => Solde" ) From =G_GLOB0
#    # calcul de la dotation exercice
#    Call ECR_FICH("FS1",7, "Dotation exercice = Valnet amort déb exe  " ) From =G_GLOB0
#    [M:DIV]DOTEXE = [M:DIV]VLNAMT

  # Durée de détention dans l'exercice
# Call  KRO_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&       [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT,  WDURDET) From =G_GLOB4PL
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_KRO_DUR_DET From =G_GLOB4PL
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RL - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0

    # La valeur nette est soldée au prorata de la détention par rapport au reste à amortir
    # pour tenir compte de l'éventualité d'une sortie avant la fin d'amortissement.
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RL - Fin amort <= Fin Exe. => Solde" ) From =G_GLOB0
    # Calcul de la durée restant à amortir
    Call  KRO_DUR_REST_AMT ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, WDURRES) From =G_GLOB4PL
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RL - Durée residuelle      =" + num$(WDURRES) ) From =G_GLOB0

    # calcul de la dotation exercice
    If ( WDURRES <> 0 ) Then
      Call ECR_FICH("FS1", 7,
&     "Dotation exercice = Valnet amort déb exe * ( Durée Détention Exe. / Durée résiduelle )") From =G_GLOB0
      WDOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
    Else
      WDOTEXE = 0
    Endif

  #- 1 -----------------------------------------------------------
  Else
    #- 2 -----------------------------------------------------------
    If ( ([F:DEPC]KNBMSTPDEP = 0  and [F:DEPC]KSTPDEPSTA = GVML_SSNOSTP)          or
&        ([F:DEPC]KNBMSTPDEP <> 0 and find ([F:DEPC]KSTPDEPSTA, GVML_SSNSTPP, GVML_SSRSTPR) <> 0)  ) Then
      # Linéaire standard ou prolongé
      #----------------
      # Durée de détention dans l'exercice
    # Call  KRO_DUR_DET
    #&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
    #&       [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT,  WDURDET) From =G_GLOB4PL
      [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
      [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
      [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      Gosub GSB_KRO_DUR_DET From =G_GLOB4PL
      WDURDET = [M:DIV]RV(1)
      If ([M:DIV]ERROR) Then : End : Endif
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RL - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0

      # Durée de l'exercice de reférence
      Local Integer WDUREXE
      WDUREXE = 12
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RL - Durée référence Exe.        =" + num$(WDUREXE) ) From =G_GLOB0

      # Linéaire si "Pas en arrêt" et jamais arrété ou déjà arrêté mais prolongé
      Call ECR_FICH("FS1",7, "Dotation exercice = Val. amort. * Taux lin. * (Durée dét. / Durée exe.)  " ) From =G_GLOB0
    WDOTEXE = ( [M:DIV]VALAMT * [M:DIV]TXAMT ) * ( WDURDET / WDUREXE)
    #- 2 -----------------------------------------------------------
    Else
      # Résiduel
      #----------------
      Local Decimal WCUMP_1    : WCUMP_1    = 0.   : # Cumul P-1
      Case [M:DIV]TYPCAL
        When "R"
          WCUMP_1 = [F:DEPC]PERCLOCUM
        When "T"
          WCUMP_1 = [F:DEPC]PERCLOCUMT
        When "I"
          WCUMP_1 = [F:DEPC]PERCLOCUMI
      Endcase
      # Durée de détention dans l'exercice
    # Call  CAL_DUR_DET
    #&      ([M:DIV]DTDBPER, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
    #&       [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT,  WDURDET) From =G_GLOB8
      [M:DIV]PD(0)= [M:DIV]DTDBPER : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
      [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
      [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      Gosub GSB_CAL_DUR_DET From =G_GLOB8
      WDURDET = [M:DIV]RV(1)
      If ([M:DIV]ERROR) Then : End : Endif
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RL - Durée Dét. Rési Exe.  =" + num$(WDURDET) ) From =G_GLOB0

      # Calcul de la durée restant à amortir
      Call CAL_DUR_REST_AMT ([M:DIV]DTDBAMTREG, [M:DIV]DTDBPER, [M:DIV]DTFNAMT, "M", WDURRES) From =G_GLOB8
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RL - Durée residuelle      =" + num$(WDURRES) ) From =G_GLOB0
      # calcul de la dotation exercice
      If ( WDURRES <> 0 ) Then
        Call ECR_FICH("FS1", 7,
&       "Dotation exercice = Valnet amort déb exe * ( Durée Détention Exe. / Durée résiduelle )") From =G_GLOB0
        WDOTEXE = ( ([M:DIV]VLNAMT-WCUMP_1) * ( WDURDET / WDURRES)) + WCUMP_1
      Else
        WDOTEXE = 0
  Endif
    Endif
    #- 2 -----------------------------------------------------------
  Endif
  #- 1 -----------------------------------------------------------


  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT ([M:DIV]DOTEXE, [M:DIV]CUR, [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RL - Dotation exe.            =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End

#########################################################
Subprog  CAL_DOT_EXE_RX
#
# - Objet  : Calcule la dotation de l'exercice selon le mode RX
#            Accéléré roumain FQ77877
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
# Gestion des erreurs

Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir
Local Decimal WDURD50    : WDURD50     = 0.     : # Durée restant à amortir à 50%

  #If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #If ( [M:DIV]BDEBUG and [F:DEPC]DPRPLN = 11) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #If ( [M:DIV]BDEBUG and [F:DEPC]FIYSTRDAT = [01/01/2015]) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  [M:DIV]AMTEXC  = 0.
  [M:DIV]DOTEXE  = 0.


  # Valeur amortissable
  [M:DIV]VALAMT =  [M:DIV]BASAMT-[F:DEPC]RSDVAL

  # Valeur nette nulle
  If ( [M:DIV]VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RX - Valeur nette amortissable déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH
&   ("FS1", 7, "CAL_DOT_EXE_RX - Dotation exercice   ="+ format$([M:DIV]CURFMT,[M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RX - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RX - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RX - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RX - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RX - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RX - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RX - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RX - Valeur amortissable   =" + num$([M:DIV]VALAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RX - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RX - Valnet amort déb exe  =" + num$([M:DIV]VLNAMT)     ) From =G_GLOB0
  Endif

  #=================
  # Taux / Duree
  #=================

  # Calcul du taux à partir de la durée
  # La durée d'amortissement est un nombre d'années devant correspondre à un nombre entier de mois
  Call CAL_RETRAITE_DUREE_EN_MOIS ( [F:DEPC]DPRDUR, [M:DIV]DURAMTREG )  From =G_GLOB9
  [F:DEPC]DPRDUR  = [M:DIV]DURAMTREG
  # Calcul du taux à partir de la durée ( pour stockage & affichage )
  [F:DEPC]DPRRAT = arr( (1/([F:DEPC]DPRDUR-1)), 0.000001)
  # Calcul du taux à partir de la durée ( non arrondi pour calcul)
  [M:DIV]TXAMT = (1/([F:DEPC]DPRDUR-1))
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RX - Taux  = (1/ Durée d'amort (année) )"       ) From =G_GLOB0


  #=================
  # Date Fin Amort.
  #=================

  Gosub CAL_DATE_FIN_AMORT_RX From =G_GLOB8
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RX - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)   ) From =G_GLOB0
  If (find([F:DEPC]KSTPDEPSTA, GVML_SSNSTPP, GVML_SSTSTPP) <> 0 ) Then
    # Si Amorti prolongation ou suspendre prolongation alors ajout du nombre de mois d'arrêt
    [M:DIV]DTFNAMT = func GLOBB9.CAL_DAT_PLUS( [M:DIV]DTFNAMT, [F:DEPC]KNBMSTPDEP, "M" )
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RX - Fin d'amort retraitée =" + num$([M:DIV]DTFNAMT)) From =G_GLOB0
  Endif

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RX - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  # Stop dépréciation - Si l'amortissement du bien est suspendu - FQ80825
  If ( find([F:DEPC]KSTPDEPSTA, GVML_SSSTOPD, GVML_SSRSTDI, GVML_SSRSTPR) <> 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RX - Amortissement suspendu"  ) From =G_GLOB0
    [M:DIV]AMTEXC = [F:DEPC]PERCLOEXC
    [M:DIV]DOTEXE = [F:DEPC]PERCLOCUM
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  # Durée de l'exercice de reférence
  Local Integer WDUREXE
  WDUREXE = 12
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RX - Durée référence Exe.        =" + num$(WDUREXE) ) From =G_GLOB0

  # Fin du 12ème mois à 50%
  Local Date WDTFN50
  WDTFN50 = func GLOBI9.CAL_DAT_PLUS( [M:DIV]DTDBAMTREG-1, 12+[F:DEPC]KNBMSTPDEP, [M:DIV]TYPPRODAT )
  # Ajustement à la fin du mois
  WDTFN50 = func GLOBB9.CAL_DAT_DERN( WDTFN50 , "M")
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RX - 12 mois à 50% soit jusqu'au  " + num$(WDTFN50) ) From =G_GLOB0


  # 50% de la valeur amortissable arrondie dans la devise du contexte
  Local Decimal WVALA50
  #Call CAL_ARRONDI_MNT ([M:DIV]VALAMT * 0.5, [M:DIV]CUR, [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= [M:DIV]VALAMT * 0.5 : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WVALA50 = [M:DIV]RV(1)

  #---------------------------------------------
  # Calcul Dotation exercice
  #---------------------------------------------
  #- 1 ----------
  If ( WDTFN50 >= [M:DIV]DTFNEXE) Then
    # 50% selon détention
    #--
    # Durée de détention dans l'exercice
#   Call  KRO_DUR_DET
#&        ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&         [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT,  WDURDET) From =G_GLOB4PL
    [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
    [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
    [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
    Gosub GSB_KRO_DUR_DET From =G_GLOB4PL
    WDURDET = [M:DIV]RV(1)
    If ([M:DIV]ERROR) Then : End : Endif
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RX - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0

    Call ECR_FICH("FS1",7,
&     "Dotation exercice = 50% Val. amort. * (Durée dét. / Durée exe.)  " ) From =G_GLOB0
    [M:DIV]DOTEXE = WVALA50 * ( WDURDET / WDUREXE)

  #- 1 ----------
  Elsif( func GLOBB9.CAL_DAT_INSIDE(WDTFN50, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
    # Panaché 50% et linéaire roumain
    #--
    # Durée de détention à 50%
#   Call  KRO_DUR_DET
#&        ([M:DIV]EXEDATREF, WDTFN50,        [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&         [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT,  WDURDET) From =G_GLOB4PL
    [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= WDTFN50 : [M:DIV]PD(2)= [M:DIV]DATNUL
    [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
    [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
    Gosub GSB_KRO_DUR_DET From =G_GLOB4PL
    WDURD50 = [M:DIV]RV(1)
    If ([M:DIV]ERROR) Then : End : Endif
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RX - Durée Détention à 50% =" + num$(WDURDET) ) From =G_GLOB0
    # Durée de détention dans l'exercice
#   Call  KRO_DUR_DET
#&        ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&         [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT,  WDURDET) From =G_GLOB4PL
    [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
    [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
    [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
    Gosub GSB_KRO_DUR_DET From =G_GLOB4PL
    WDURDET = [M:DIV]RV(1)
    If ([M:DIV]ERROR) Then : End : Endif
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RX - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0
    # Durée de détention dans l'exercice
    WDURDET = WDURDET - WDURD50
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RX - Durée Dét. en linéaire=" + num$(WDURDET) ) From =G_GLOB0

    If (WDURDET <> 0) Then
      Call ECR_FICH("FS1",7, "Dotation à 50%    = Valnet amort déb exe  " ) From =G_GLOB0
      [M:DIV]DOTEXE = WVALA50 - [F:DEPC]DPRCUM
    Endif

    # Linéaire roumain
    If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I")  ) Then
      # La valeur nette est soldée au prorata de la détention par rapport au reste à amortir
      # pour tenir compte de l'éventualité d'une sortie avant la fin d'amortissement.
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RX - Fin amort <= Fin Exe. => Solde" ) From =G_GLOB0
      # Calcul de la durée restant à amortir
      Call  KRO_DUR_REST_AMT([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, WDURRES) From =G_GLOB4PL
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RX - Durée residuelle      =" + num$(WDURRES) ) From =G_GLOB0

      # calcul de la dotation exercice
      If ( WDURRES <> 0 ) Then
        Call ECR_FICH("FS1", 7,
&       "Dotation exercice = Valnet amort déb exe * ( Durée Détention Exe. / Durée résiduelle )") From =G_GLOB0
        [M:DIV]DOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
      Else
        [M:DIV]DOTEXE = 0
      Endif
    Else
      If ( [F:DEPC]KNBMSTPDEP <> 0 ) Then
        # Si il y a au moins un arrêt on passe en résiduel
        # Calcul de la durée restant à amortir
        Call  KRO_DUR_REST_AMT(WDTFN50+1, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, WDURRES) From =G_GLOB4PL
        Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RX - Durée residuelle      =" + num$(WDURRES) ) From =G_GLOB0

        # calcul de la dotation exercice
        If ( WDURRES <> 0 ) Then
          Call ECR_FICH("FS1", 7,
&         "Dotation exercice = Valnet amort déb exe * ( Durée Détention Exe. / Durée résiduelle )") From =G_GLOB0
          [M:DIV]DOTEXE += ([M:DIV]VALAMT - WVALA50) * ( WDURDET / WDURRES)
        Endif
      Else
      Call ECR_FICH("FS1",7,
&     "Dotation exercice = ( 50% Val. amort. * Taux lin. * (Durée dét. / Durée exe.)  " ) From =G_GLOB0
      [M:DIV]DOTEXE += ( ([M:DIV]VALAMT - WVALA50) * [M:DIV]TXAMT ) * ( WDURDET / WDUREXE)
    Endif
    Endif
  #- 1 ----------
  Else

    # Durée de détention dans l'exercice
#     Call  KRO_DUR_DET
#&          ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&           [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT,  WDURDET) From =G_GLOB4PL
    [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
    [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
    [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
    Gosub GSB_KRO_DUR_DET From =G_GLOB4PL
    WDURDET = [M:DIV]RV(1)
    If ([M:DIV]ERROR) Then : End : Endif
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RX - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0

    # Linéaire roumain
    #- 2 ----------
    If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I")  ) Then
      # La valeur nette est soldée au prorata de la détention par rapport au reste à amortir
      # pour tenir compte de l'éventualité d'une sortie avant la fin d'amortissement.
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RX - Fin amort <= Fin Exe. => Solde" ) From =G_GLOB0
      # Calcul de la durée restant à amortir
      Call  KRO_DUR_REST_AMT([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, WDURRES) From =G_GLOB4PL
      Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RX - Durée residuelle      =" + num$(WDURRES) ) From =G_GLOB0

      # calcul de la dotation exercice
      If ( WDURRES <> 0 ) Then
        Call ECR_FICH("FS1", 7,
&       "Dotation exercice = Valnet amort déb exe * ( Durée Détention Exe. / Durée résiduelle )") From =G_GLOB0
        [M:DIV]DOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
      Else
        [M:DIV]DOTEXE = 0
      Endif
    #- 2 ----------
    Else
      #- 3 ----------
      If ( [F:DEPC]KNBMSTPDEP = 0 ) Then
        #--- Accéléré - classique
      Call ECR_FICH("FS1",7,
&     "Dotation exercice = ( 50% Val. amort. * Taux lin. * (Durée dét. / Durée exe.)  " ) From =G_GLOB0
      [M:DIV]DOTEXE = ( ([M:DIV]VALAMT - WVALA50) * [M:DIV]TXAMT ) * ( WDURDET / WDUREXE)
      #- 3 ----------
      Else
        #--- Résiduel
        # Si il y a au moins un arrêt on passe en résiduel
        Local Decimal WCUMP_1    : WCUMP_1    = 0.   : # Cumul P-1
        Case [M:DIV]TYPCAL
          When "R"
            WCUMP_1 = [F:DEPC]PERCLOCUM
          When "T"
            WCUMP_1 = [F:DEPC]PERCLOCUMT
          When "I"
            WCUMP_1 = [F:DEPC]PERCLOCUMI
        Endcase
        # Durée de détention résiduel dans l'exercice
      # Call  CAL_DUR_DET
      #&      ([F:DEPC]PERSTRDAT, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
      #&       [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT,  WDURDET) From =G_GLOB8
        [M:DIV]PD(0)= [F:DEPC]PERSTRDAT : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
        [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
        [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
        Gosub GSB_CAL_DUR_DET From =G_GLOB8
        WDURDET = [M:DIV]RV(1)
        If ([M:DIV]ERROR) Then : End : Endif
        Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RX - Durée Dét. Rési Exe.  =" + num$(WDURDET) ) From =G_GLOB0

        # Calcul de la durée restant à amortir
        Call  CAL_DUR_REST_AMT([M:DIV]DTDBAMTREG, [M:DIV]DTDBPER, [M:DIV]DTFNAMT, "M", WDURRES) From =G_GLOB8
        Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RX - Durée residuelle      =" + num$(WDURRES) ) From =G_GLOB0
        # calcul de la dotation exercice
        If ( WDURRES <> 0 ) Then
          Call ECR_FICH("FS1", 7,
&         "Dotation exercice = Valnet amort déb exe * ( Durée Détention Exe. / Durée résiduelle )") From =G_GLOB0
          [M:DIV]DOTEXE = ( ([M:DIV]VLNAMT-WCUMP_1) * ( WDURDET / WDURRES)) + WCUMP_1
        Else
          [M:DIV]DOTEXE = 0
        Endif
    Endif
      #- 3 ----------
  Endif
    #- 2 ----------
  Endif
  #- 1 ----------


  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT ([M:DIV]DOTEXE, [M:DIV]CUR, [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= [M:DIV]DOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RX - Dotation exe.            =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End


#########################################################
Subprog  CAL_DOT_EXE_RD
#
# - Objet  : Calcule la dotation de l'exercice selon le mode RD
#            Dégressif roumain FQ77877
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement

Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir
Local Integer BP_1       : BP_1        = 0      : # Reconstution P-1 et intègration dans période courante

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG and [F:DEPC]PERSTRDAT = [01/03/2013]) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #If ( [M:DIV]BDEBUG and [F:DEPC]DPRPLN = 2) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  [M:DIV]AMTEXC  = 0.
  [M:DIV]DOTEXE  = 0.

  # Valeur nette nulle
  If ( [M:DIV]VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RD - Valeur nette amortissable déb. exe. nulle") From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RD - Dotation exercice   ="+ format$([M:DIV]CURFMT,[M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RD - Déb. Exercice         =" + num$([M:DIV]DTDBEXE) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RD - Fin  Exercice         =" + num$([M:DIV]DTFNEXE) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RD - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RD - Date de sortie        =" + num$([M:DIV]DATSORREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RD - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RD - Base                  =" + num$([M:DIV]BASAMT) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RD - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RD - Cumul  E-1            =" + num$([F:DEPC]DPRCUM) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RD - Valnet amort déb exe  =" + num$([M:DIV]VLNAMT) ) From =G_GLOB0
  Endif

  #=================
  # Taux / Duree
  #=================

  # Calcul du taux à partir de la durée
  # La durée d'amortissement est un nombre d'années devant correspondre à un nombre entier de mois
  Call CAL_RETRAITE_DUREE_EN_MOIS ( [F:DEPC]DPRDUR, [M:DIV]DURAMTREG )  From =G_GLOB9
  [F:DEPC]DPRDUR  = [M:DIV]DURAMTREG
  # Calcul du taux à partir de la durée
  Call CAL_TAUX_MODE_RD([F:DEPC]DPRDUR, [M:DIV]TXAMT, [F:DEPC]DPRRAT) From =G_GLOB8
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RD - Durée d'amortissement =" + num$([M:DIV]DURAMTREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RD - Taux  d'amortissement =" + num$([M:DIV]TXAMT)      ) From =G_GLOB0


  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RD - Pas d'amortissement Bien détenu pour la vente" ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  #=================
  # Date Fin Amort.
  #=================

  Gosub CAL_DATE_FIN_AMORT_RD From =G_GLOB8
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RD - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT) ) From =G_GLOB0
  If (find([F:DEPC]KSTPDEPSTA, GVML_SSNSTPP, GVML_SSTSTPP) <> 0 ) Then
    # Si Amorti prolongation ou suspendre prolongation alors ajout du nombre de mois d'arrêt
    [M:DIV]DTFNAMT = func GLOBB9.CAL_DAT_PLUS( [M:DIV]DTFNAMT, [F:DEPC]KNBMSTPDEP, "M" )
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RD - Fin d'amort retraitéé =" + num$([M:DIV]DTFNAMT)) From =G_GLOB0
  Endif


  # Si état redemarré sans prolongation - redétermination du taux et de la durée d'amortissement
  If ([F:DEPC]KNBMSTPDEP <> 0 and [F:DEPC]KSTPDEPSTA = GVML_SSNOSTP ) Then
    Local Integer SDPRDUR : SDPRDUR = [F:DEPC]DPRDUR
    # Calcul de la durée restant à amortir
    Call  CAL_DUR_REST_AMT([M:DIV]DTDBAMTREG, [F:DEPC]KBIRDAT, [M:DIV]DTFNAMT, "M", WDURRES) From =G_GLOB8
    [F:DEPC]DPRDUR = WDURRES /12
    Call CAL_RETRAITE_DUREE_EN_MOIS ( [F:DEPC]DPRDUR, [M:DIV]DURAMTREG )  From =G_GLOB9
    # Calcul du taux à partir de la durée
    Call CAL_TAUX_MODE_RD([M:DIV]DURAMTREG, [M:DIV]TXAMT, [F:DEPC]DPRRAT) From =G_GLOB8
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RD - Durée après redémar.  =" + num$([M:DIV]DURAMTREG)  ) From =G_GLOB0
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RD - Taux  après redémar.  =" + num$([M:DIV]TXAMT)      ) From =G_GLOB0
  Endif

  # Durée de l'exercice de reférence
  Local Integer WDUREXE
  WDUREXE = 12
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RD - Durée référence Exe.        =" + num$(WDUREXE)  ) From =G_GLOB0

  # Initialisation du tableau des périodes de la structure CALDIV (Dotation exercice = somme des dotations période
  #    ***************
  Call CAL_INI_PER_EXE ( [F:DEPC]FIYSTRDAT, [F:DEPC]FIYENDDAT ) From =G_GLOB7


  If ( [M:DIV]VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RD - Val. nette déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RD - Dotation exercice   ="+ format$([M:DIV]CURFMT,[M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  # Intialisation
  #==

  # Si 1er DEPREC et Début amortissement antérieur à période courante
  If ( [F:DEPC]LSTCLODAT = [0/0/0] and
&   func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTDBAMTREG, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") and
&   [M:DIV]DTDBAMTREG < [F:DEPC]PERSTRDAT ) Then : BP_1 = 1 : Endif

  # Valeurs nettes
  Local Decimal R_VLNANI : R_VLNANI = 0
  Local Decimal L_VLNANI
  Local Decimal L_VALNET
  L_VALNET = [M:DIV]VLNAMT
  Case [M:DIV]TYPCAL
    When "R"
      L_VLNANI = [F:DEPC]KBIRNBV  - [F:DEPC]RSDVAL
    When "T"
      L_VLNANI = [F:DEPC]KBIRNBVT - [F:DEPC]RSDVAL
    When "I"
      L_VLNANI = [F:DEPC]KBIRNBVI - [F:DEPC]RSDVAL
  Endcase

  # Date anniversaire
  Local Date L_DATANI
  If ([F:DEPC]KBIRDAT = [0/0/0] or [F:DEPC]PERENDDAT <= [M:DIV]DTDBAMTREG or BP_1 ) Then
    L_DATANI = [M:DIV]DTDBAMTREG
    [F:DEPC]KBIRDAT = L_DATANI
  Else
    L_DATANI = [F:DEPC]KBIRDAT
  Endif

  # Prise en compte des amortissements déjà constatés sur les périodes closes
  Local Decimal L_DOTPER(1..24)
  Local Decimal L_DOT1AP(1..24)
  Local Decimal L_EXCPER(1..24)
  Local Decimal L_EXC1AP(1..24)
  Local Decimal L_BIRNBV(1..24)
  Local Date    L_BIRDAT(1..24)
  I_P = find([F:DEPC]PERSTRDAT-1, [M:DIV2]PERENDDAT)
  #-1 ----------
  If (I_P <> 0) Then
    Case [M:DIV]TYPCAL
      When "R"
        L_DOTPER(I_P) = [F:DEPC]PERCLOCUM
        L_DOT1AP(I_P) = [F:DEPC]PERCLOCUM
        L_EXCPER(I_P) = [F:DEPC]PERCLOEXC
        L_EXC1AP(I_P) = [F:DEPC]PERCLOEXC
        [M:DIV]DOTEXE = [F:DEPC]PERCLOCUM + [F:DEPC]PERCLOEXC
        L_VALNET   = L_VALNET - [F:DEPC]PERCLOCUM - [F:DEPC]PERCLOEXC
      When "T"
        L_DOTPER(I_P) = [F:DEPC]PERCLOCUMT
        L_DOT1AP(I_P) = [F:DEPC]PERCLOCUMT
        L_EXCPER(I_P) = [F:DEPC]PERCLOEXCT
        L_EXC1AP(I_P) = [F:DEPC]PERCLOEXCT
        [M:DIV]DOTEXE = [F:DEPC]PERCLOCUMT + [F:DEPC]PERCLOEXCT
        L_VALNET   = L_VALNET - [F:DEPC]PERCLOCUMT - [F:DEPC]PERCLOEXCT
      When "I"
        L_DOTPER(I_P) = [F:DEPC]PERCLOCUMI
        L_DOT1AP(I_P) = [F:DEPC]PERCLOCUMI
        L_EXCPER(I_P) = [F:DEPC]PERCLOEXCI
        L_EXC1AP(I_P) = [F:DEPC]PERCLOEXCI
        [M:DIV]DOTEXE = [F:DEPC]PERCLOCUMI + [F:DEPC]PERCLOEXCI
        L_VALNET   = L_VALNET - [F:DEPC]PERCLOCUMI - [F:DEPC]PERCLOEXCI
    Endcase
  Endif
  #-1 ----------

  #>1 >>>>>>>>>>>>>>>>
  For I_P = 1 To [M:DIV2]NB_PER
    If ( [M:DIV]DTDBAMTREG < [M:DIV2]PERENDDAT(I_P-1) and ([M:DIV2]PERSTRDAT(I_P-1) >= [F:DEPC]PERSTRDAT or BP_1) ) Then
      Case [M:DIV]TYPCAL
        When "R"
          L_BIRNBV((I_P)) = [F:DEPC]KBIRNBV  - [F:DEPC]RSDVAL
        When "T"
          L_BIRNBV((I_P)) = [F:DEPC]KBIRNBVT - [F:DEPC]RSDVAL
        When "I"
          L_BIRNBV((I_P)) = [F:DEPC]KBIRNBVI - [F:DEPC]RSDVAL
      Endcase
   Endif
  Next I_P
  #>1 >>>>>>>>>>>>>>>>


  # CALCUL DES PERIODES RESTANT A CLORE
  #>1 >>>>>>>>>>>>>>>>
  For I_P = 1 To [M:DIV2]NB_PER
    #- 2 -------------------------
    If ( [M:DIV]DTDBAMTREG < [M:DIV2]PERENDDAT(I_P-1) and ([M:DIV2]PERSTRDAT(I_P-1) >= [F:DEPC]PERSTRDAT or BP_1) ) Then
      #- 3 -------------------------
      If ( [M:DIV]DATSORREG = [0/0/0] or [M:DIV]DATSORREG >= [M:DIV2]PERENDDAT(I_P-1)  ) Then
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RD - Déb. Période  *****   =" + num$([M:DIV2]PERSTRDAT(I_P-1)) ) From =G_GLOB0
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RD - Fin. Période  *****   =" + num$([M:DIV2]PERENDDAT(I_P-1)) ) From =G_GLOB0
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RD - Valeur nette          =" + num$(L_VALNET)           ) From =G_GLOB0
        # Entretien valeur nette anniversaire et date anniversaire
        # Si Etat - Redemarré sans prolongation
        If ([F:DEPC]KNBMSTPDEP <> 0 and [F:DEPC]KSTPDEPSTA = GVML_SSNOSTP ) Then
          #Call CAL_DAT_DIFF( [F:DEPC]KBIRDAT, [M:DIV2]PERENDDAT(I_P-1), "M" , WNBM ) From =G_GLOB9
          [M:DIV]PD(0)= [F:DEPC]KBIRDAT : [M:DIV]PD(1)= [M:DIV2]PERENDDAT(I_P-1) : [M:DIV]PC(0)= "M"
          Gosub GSB_CAL_DAT_DIFF From =G_GLOB9 : WNBM = [M:DIV]RV(0)
        Else
        #Call CAL_DAT_DIFF( [M:DIV]DTDBAMTREG, [M:DIV2]PERENDDAT(I_P-1), "M" , WNBM ) From =G_GLOB9
        [M:DIV]PD(0)= [M:DIV]DTDBAMTREG : [M:DIV]PD(1)= [M:DIV2]PERENDDAT(I_P-1) : [M:DIV]PC(0)= "M"
        Gosub GSB_CAL_DAT_DIFF From =G_GLOB9 : WNBM = [M:DIV]RV(0)
          WNBM = WNBM - [F:DEPC]KNBMSTPDEP
        Endif

        If ( mod(WNBM, 12) = 1 ) Then
          L_VLNANI = L_VALNET
          L_DATANI = [M:DIV2]PERSTRDAT((I_P-1))
        Endif

        # Date anniversaire
        # Si Etat - Redemarré sans prolongation
        If ([F:DEPC]KNBMSTPDEP <> 0 and [F:DEPC]KSTPDEPSTA = GVML_SSNOSTP ) Then
          L_BIRDAT(I_P) =  [F:DEPC]KBIRDAT
        Else
        L_BIRDAT(I_P) =  L_DATANI
        Endif
        # Valeur nette anniversaire
        L_BIRNBV(I_P) =  L_VLNANI

        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RD - Valeur nette anniv.   =" + num$(L_VLNANI)           ) From =G_GLOB0
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RD - Date anniversaire     =" + num$(L_DATANI)           ) From =G_GLOB0
        #==  REFERENCE DEGRESSIF ET LINEAIRE RESIDUEL
        #- 4----------
        If (L_VLNANI <> R_VLNANI) Then
          #==
          # Rupture valeur nette anniversaire
          #==
          R_VLNANI = L_VLNANI

          # Dégressif
          #==
          Local Decimal R_DOTDEG : R_DOTDEG = 0
          R_DOTDEG = R_VLNANI * [M:DIV]TXAMT
          # Arrondi dans la devise du contexte
          #Call CAL_ARRONDI_MNT (R_DOTDEG, [M:DIV]CUR, R_DOTDEG) From =G_GLOB8
          [M:DIV]PV(0)= R_DOTDEG : [M:DIV]PC(0)= [M:DIV]CUR
          Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : R_DOTDEG = [M:DIV]RV(1)
          Call ECR_FICH("FS1", 9, "CAL_DOT_EXE_RD - Référence dégressive  =" + num$(R_DOTDEG)  ) From =G_GLOB0

          # Linéaire résiduelle
          #==
          Local Decimal R_DOTLIN : R_DOTLIN = 0
          Local Date    L_CURANI
          If ([F:DEPC]KNBMSTPDEP <> 0 and [F:DEPC]KSTPDEPSTA = GVML_SSNOSTP ) Then
            # Si Etat - Redemarré sans prolongation
            If (month(L_DATANI) = 1 ) Then
              L_CURANI = gdat$(01,01, year([M:DIV2]PERSTRDAT(0)))
            Elsif (month(L_DATANI) = month([M:DIV2]PERSTRDAT(I_P-1))) Then
              L_CURANI = [M:DIV2]PERSTRDAT(I_P-1)
            Else
              L_CURANI = gdat$(01,month(L_DATANI), year([M:DIV2]PERSTRDAT(0))-1)
            Endif
          Else
            # Dans les autres cas
            L_CURANI = L_DATANI
          Endif
          # Durée de détention residuelle à date anniversaire
#           Call  CAL_DUR_DET
#        &        (L_CURANI,    [M:DIV]DTFNAMT,   [M:DIV]DATNUL,    [M:DIV]DATNUL, [M:DIV]DATNUL,
#        &         [M:DIV]DATNUL,  [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT,  WDURRES) From =G_GLOB8
          [M:DIV]PD(0)= L_CURANI   : [M:DIV]PD(1)= [M:DIV]DTFNAMT : [M:DIV]PD(2)= [M:DIV]DATNUL
          [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DATNUL  : [M:DIV]PD(5)= [M:DIV]DATNUL
          [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
          Gosub GSB_CAL_DUR_DET From =G_GLOB8
          WDURRES = [M:DIV]RV(1)
          If ([M:DIV]ERROR) Then : End : Endif
          If (WDURRES <> 0 ) Then
            R_DOTLIN = (R_VLNANI / WDURRES )  * 12
          Endif
          # Arrondi dans la devise du contexte
          #Call CAL_ARRONDI_MNT (R_DOTLIN, [M:DIV]CUR, R_DOTLIN) From =G_GLOB8
          [M:DIV]PV(0)= R_DOTLIN : [M:DIV]PC(0)= [M:DIV]CUR
          Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : R_DOTLIN = [M:DIV]RV(1)
          Call ECR_FICH("FS1", 9, "CAL_DOT_EXE_RD - Durée Résiduelle      =" + num$(WDURRES)  ) From =G_GLOB0
          Call ECR_FICH("FS1", 9, "CAL_DOT_EXE_RD - Référence linéaire    =" + num$(R_DOTLIN)  ) From =G_GLOB0
        Endif
        #-4 ----------

        #==  DOTATION PERIODE

        # Dotation période
        If ( find([F:DEPC]KSTPDEPSTA, GVML_SSSTOPD, GVML_SSRSTDI, GVML_SSRSTPR) <> 0 ) Then
          # Amortissement suspendu
          L_DOTPER(I_P) =  0.
        Else
          If (R_DOTDEG > R_DOTLIN) Then
            # Degressif
            L_DOTPER(I_P) =  L_VLNANI * [M:DIV]TXAMT / 12
          Else
            # Linéaire résiduel
            # Durée de détention residuelle à période courante
#             Call  CAL_DUR_DET
#          &        ([M:DIV2]PERSTRDAT(I_P-1), [M:DIV]DTFNAMT, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DATNUL,
#          &         [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT,  WDURDET) From =G_GLOB4PL
            [M:DIV]PD(0)= [M:DIV2]PERSTRDAT(I_P-1) : [M:DIV]PD(1)= [M:DIV]DTFNAMT   : [M:DIV]PD(2)= [M:DIV]DATNUL
            [M:DIV]PD(3)= [M:DIV]DATNUL            : [M:DIV]PD(4)= [M:DIV]DATNUL    : [M:DIV]PD(5)= [M:DIV]DATNUL
            [M:DIV]PD(6)= [M:DIV]DATSOREXE         : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
            Gosub GSB_CAL_DUR_DET From =G_GLOB8
            WDURRES = [M:DIV]RV(1)
            If ( WDURRES <> 0 ) Then
            L_DOTPER(I_P) = L_VALNET /WDURRES
            Endif
          Endif
          # Arrondi dans la devise du contexte
          #Call CAL_ARRONDI_MNT (L_DOTPER(I_P), [M:DIV]CUR, L_DOTPER(I_P)) From =G_GLOB8
          [M:DIV]PV(0)= L_DOTPER(I_P) : [M:DIV]PC(0)= [M:DIV]CUR
          Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : L_DOTPER(I_P) = [M:DIV]RV(1)
        Endif


        # Solde de la valeur nette
        If ( abs(L_DOTPER(I_P)) > abs(L_VALNET) ) Then
          L_DOTPER(I_P) = L_VALNET
        Endif
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RD - Dotation période      =" + num$(L_DOTPER(I_P)) ) From =G_GLOB0
        # La dotation exercice est le total des dotations des périodes
        [M:DIV]DOTEXE          += L_DOTPER(I_P)
        # La valeur nette est diminuée de la dotation de la période
        L_VALNET               -= L_DOTPER(I_P)
        # Entretien Cumul 1 à Pc
        If (I_P > 1 ) Then :  L_DOT1AP(I_P) = L_DOT1AP(I_P-1) : Endif
        L_DOT1AP(I_P) += L_DOTPER(I_P)
        Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_RD - Cumul 1 à P           =" + num$(L_DOT1AP(I_P)) ) From =G_GLOB0

      Endif
      #- 3 -------------------------
    Endif
    #- 2 -------------------------
  Next I_P
  #>1 >>>>>>>>>>>>>>>>

  #>>>>>>>>>>>>>>>>>
  For I_P = 1 To [M:DIV2]NB_PER
    [M:DIV2]BIRDAT(I_P-1) = L_BIRDAT(I_P)
    Case [M:DIV]TYPCAL
      When "R"
        [M:DIV2]DOTPER (I_P-1) = L_DOTPER(I_P)
        [M:DIV2]DOT1AP (I_P-1) = L_DOT1AP(I_P)
        [M:DIV2]EXCPER (I_P-1) = L_EXCPER(I_P)
        [M:DIV2]EXC1AP (I_P-1) = L_EXC1AP(I_P)
        [M:DIV2]BIRNBV (I_P-1) = L_BIRNBV(I_P)
      When "T"
        [M:DIV2]DOTPERT(I_P-1) = L_DOTPER(I_P)
        [M:DIV2]DOT1APT(I_P-1) = L_DOT1AP(I_P)
        [M:DIV2]EXCPERT(I_P-1) = L_EXCPER(I_P)
        [M:DIV2]EXC1APT(I_P-1) = L_EXC1AP(I_P)
        [M:DIV2]BIRNBVT(I_P-1) = L_BIRNBV(I_P)
      When "I"
        [M:DIV2]DOTPERI(I_P-1) = L_DOTPER(I_P)
        [M:DIV2]DOT1API(I_P-1) = L_DOT1AP(I_P)
        [M:DIV2]EXCPERI(I_P-1) = L_EXCPER(I_P)
        [M:DIV2]EXC1API(I_P-1) = L_EXC1AP(I_P)
        [M:DIV2]BIRNBVI(I_P-1) = L_BIRNBV(I_P)
    Endcase
  Next I_P
  #>>>>>>>>>>>>>>>>>

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT ([M:DIV]DOTEXE, [M:DIV]CUR, [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= [M:DIV]DOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)


  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_RD - Dotation exe.            =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Si Etat - Redemarré sans prolongation
  If ([F:DEPC]KNBMSTPDEP <> 0 and [F:DEPC]KSTPDEPSTA = GVML_SSNOSTP ) Then
   [F:DEPC]DPRDUR   = SDPRDUR
   [M:DIV]DURAMTREG = SDPRDUR
  Endif

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End

#*******************************************************************
#
#         D O T A T I O N   -   E X E R C I C E
#
#   M o d e   a m o r t i s s e m e n t    A U S T R A L I E N S
#
#*******************************************************************


#########################################################
Subprog  CAL_DOT_EXE_AL
#
# - Objet  : Calcule la dotation de l'exercice selon le mode AL (Prime cost)
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#   FQ84283
#

Local Decimal WDURDET  : WDURDET  = 0.  : # Durée de détention dans l'exercice
Local Decimal WDURRES  : WDURRES  = 0.  : # Durée restant à amortir
Local Decimal WDOTEXE  : WDOTEXE  = 0.  : # Dotation exercice

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG and [F:DEPC]DPRPLN = 1) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  #=================
  # Taux / Duree
  #=================

  [M:DIV]TXAMT     = 1 / [F:DEPC]DPRDUR
  [M:DIV]DURAMTREG = [F:DEPC]DPRDUR


  If ([M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_AL - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_AL - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_AL - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_AL - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_AL - Date de sortie Exe.   =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_AL - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_AL - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_AL - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_AL - Val. nette déb. exe.  =" + num$([M:DIV]VLNAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_AL - Durée                 =" + num$([M:DIV]DURAMTREG ) ) From =G_GLOB0
  Endif
  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  Gosub CAL_DATE_FIN_AMORT_AL From =G_GLOB8

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_AL - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    # Arrondi du taux à 6 décimales pour stockage.
    [M:DIV]TXAMT = arr( [M:DIV]TXAMT, 0.000001)
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  #---------------------
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_AL - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_AL - Val. amortissable     =" + num$([M:DIV]VALAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_AL - Taux  Linéaire        =" + num$([M:DIV]TXAMT )     ) From =G_GLOB0

  # Durée de détention dans l'exercice
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&       [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT,  WDURDET) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_AL - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0


  #-1 --------------------
  If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
  # La date de fin d'amortissement n'appartient pas à l'exercice

    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_AL - Durée Exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0

    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
    # calcul de la dotation exercice
    If ( [M:DIV]DUREXE <> 0 ) Then
      # Valeur amortissable * taux * prorata de détention dans l'exercice
      # sur la base de 365 jours y compris si l'année est bissextile
      Call ECR_FICH("FS1", 7,
&     "Dotation exercice = Val. amortissable. * Taux  Linéaire * ( Durée Détention Exe. / Durée Exercice (toujours 365j) )") From =G_GLOB0
      WDOTEXE = [M:DIV]VALAMT * [M:DIV]TXAMT * ( WDURDET / 365 )
    Else
      WDOTEXE = 0
    Endif
    #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , WDOTEXE) From =G_GLOB8
    [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXE = [M:DIV]RV(1)
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_AL - Dotation exe.         =" + num$(WDOTEXE) ) From =G_GLOB0
    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

  #-1 --------------------
  Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
  # La date de fin d'amortissement appartient à l'exercice

    # La valeur nette est soldée au prorata de la détention par rapport au reste à amortir
    # pour tenir compte de l'éventualité d'une sortie avant la fin d'amortissement.

    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_AL - Fin amort <= Fin Exe. => Solde" ) From =G_GLOB0
    # Calcul de la durée restant à amortir
    Call  CAL_DUR_REST_AMT
&         ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&   From =G_GLOB8
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_AL - Durée residuelle      =" + num$(WDURRES) ) From =G_GLOB0

    # calcul de la dotation exercice
    If ( WDURRES <> 0 ) Then
      Call ECR_FICH("FS1", 7,
&     "Dotation exercice = Valnet amort déb exe * ( Durée Détention Exe. / Durée résiduelle )") From =G_GLOB0
      WDOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
    Else
      WDOTEXE = 0
    Endif

  Endif
  #-1 --------------------

  # Bien que le taux ne soit pas arrondi pour le calcul de la dotation exercice, il est arrondi à 6 décimales pour stockage.
  [M:DIV]TXAMT = arr( [M:DIV]TXAMT, 0.000001)


  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # La fin d'amortissement est antérieure à l'exercice courant
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, si la dotation est > à la valeur nette, la dotation ne peut être égale qu'à la valeur nette
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_AL - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End

#########################################################
Subprog  CAL_DOT_EXE_AD
#
# - Objet  : Calcule la dotation de l'exercice selon le mode AD
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#   FQ84283
#
#

Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  If ([M:DIV]NIVDET > 7) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_AD - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_AD - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_AD - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_AD - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_AD - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_AD - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_AD - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_AD - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_AD - Valnet amort déb exe  =" + num$([M:DIV]VLNAMT)     ) From =G_GLOB0
  Endif
  #=================
  # Taux
  #=================
  # Taux dégressif
  Local Decimal WACLCOE
  If ( [F:WFAS]PURDAT >= [10/05/2006] ) Then
    WACLCOE = 2.
  Else
    WACLCOE = 1.5
  Endif
  [M:DIV]TXAMT     = (1 / [F:DEPC]DPRDUR)  * WACLCOE
  If ([M:DIV]TXAMT > 1.) Then : [M:DIV]TXAMT = 1. : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_AD - Acceleration          =" + num$(WACLCOE)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_AD - Taux  d'amortissement =" + num$([M:DIV]TXAMT)) From =G_GLOB0

  #=================
  # Date Fin Amort.
  #=================
  Gosub CAL_DATE_FIN_AMORT_AD From =G_GLOB8
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_AD - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0

  If ( [M:DIV]VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_AD - Val. nette déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_AD - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_AD - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  # Durée de détention dans l'exercice
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&      [M:DIV]DATNUL, [M:DIV]DATSOREXE,  [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DATNUL
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_AD - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_AD - Durée exercice        =" + num$(365) ) From =G_GLOB0

  # Cas standard

  #---------------------------------------------
  # Calcul Dotation exercice dégressive
  #---------------------------------------------
  Call ECR_FICH("FS1", 7,
& "Dotation dégressive = Val. nette déb. exe. * * Taux  d'amortissement * (Durée Détention Exe. / Durée Exercice)") From =G_GLOB0
  [M:DIV]DOTEXE = [M:DIV]VLNAMT * ( [M:DIV]TXAMT ) * ( WDURDET / 365 )

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT ([M:DIV]DOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= [M:DIV]DOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_AD - Dotation dégressive ................... ="-num$([M:DIV]DOTEXE) ) From =G_GLOB0

  Local Decimal WDOTEXEMIN : WDOTEXEMIN = [M:DIV]DOTEXEMIN
  If (WDOTEXEMIN = 0.) Then : WDOTEXEMIN = 1. : Endif
  If (  abs([M:DIV]DOTEXE) <= WDOTEXEMIN ) Then
    [M:DIV]DOTEXE = [M:DIV]VLNAMT
  Endif

  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  # Bien que le taux ne soit pas arrondi pour le calcul de la dotation exercice, il est arrondi à 6 décimales pour stockage.
  [M:DIV]TXAMT = arr( [M:DIV]TXAMT, 0.000001)

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_AD - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End

#*******************************************************************
#
#         D O T A T I O N   -   E X E R C I C E
#
#   M o d e   a m o r t i s s e m e n t    S U I S S E
#
#*******************************************************************


#########################################################
Subprog  CAL_DOT_EXE_HL
#
# - Objet  : Calcule la dotation de l'exercice selon le mode HL (Linéaire suisse)
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#   FQ84281
#

Local Decimal WDURDET  : WDURDET  = 0.  : # Durée de détention dans l'exercice
Local Decimal WDURRES  : WDURRES  = 0.  : # Durée restant à amortir
Local Decimal WDOTEXE  : WDOTEXE  = 0.  : # Dotation exercice

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG and [F:DEPC]DPRPLN = 1) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  #=================
  # Taux / Duree
  #=================

  [M:DIV]TXAMT     = 1 / [F:DEPC]DPRDUR
  [M:DIV]DURAMTREG = [F:DEPC]DPRDUR


  If ([M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_HL - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_HL - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_HL - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_HL - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_HL - Date de sortie Exe.   =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_HL - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_HL - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_HL - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_HL - Val. nette déb. exe.  =" + num$([M:DIV]VLNAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_HL - Durée                 =" + num$([M:DIV]DURAMTREG ) ) From =G_GLOB0
  Endif
  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  Gosub CAL_DATE_FIN_AMORT_HL From =G_GLOB8

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_HL - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    # Arrondi du taux à 6 décimales pour stockage.
    [M:DIV]TXAMT = arr( [M:DIV]TXAMT, 0.000001)
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  #---------------------
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_HL - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_HL - Val. amortissable     =" + num$([M:DIV]VALAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_HL - Taux  Linéaire        =" + num$([M:DIV]TXAMT )     ) From =G_GLOB0

  # Durée de détention dans l'exercice
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&       [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT,  WDURDET) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_HL - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0


  #-1 --------------------
  If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
  # La date de fin d'amortissement n'appartient pas à l'exercice

    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_HL - Durée Exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0

    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
    # calcul de la dotation exercice
    If ( [M:DIV]DUREXE <> 0 ) Then
      # Valeur amortissable * taux * prorata de détention dans l'exercice
      Call ECR_FICH("FS1", 7,
&     "Dotation exercice = Val. amortissable. * Taux  Linéaire * ( Durée Détention Exe. / Durée Exercice (toujours 365j) )") From =G_GLOB0
      WDOTEXE = [M:DIV]VALAMT * [M:DIV]TXAMT * ( WDURDET / [M:DIV]DUREXE )
    Else
      WDOTEXE = 0
    Endif
    #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , WDOTEXE) From =G_GLOB8
    [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXE = [M:DIV]RV(1)
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_HL - Dotation exe.         =" + num$(WDOTEXE) ) From =G_GLOB0
    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

  #-1 --------------------
  Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
  # La date de fin d'amortissement appartient à l'exercice

    # La valeur nette est soldée au prorata de la détention par rapport au reste à amortir
    # pour tenir compte de l'éventualité d'une sortie avant la fin d'amortissement.

    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_HL - Fin amort <= Fin Exe. => Solde" ) From =G_GLOB0
    # Calcul de la durée restant à amortir
    Call  CAL_DUR_REST_AMT
&         ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&   From =G_GLOB8
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_HL - Durée residuelle      =" + num$(WDURRES) ) From =G_GLOB0

    # calcul de la dotation exercice
    If ( WDURRES <> 0 ) Then
      Call ECR_FICH("FS1", 7,
&     "Dotation exercice = Valnet amort déb exe * ( Durée Détention Exe. / Durée résiduelle )") From =G_GLOB0
      WDOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
    Else
      WDOTEXE = 0
    Endif

  Endif
  #-1 --------------------

  # Bien que le taux ne soit pas arrondi pour le calcul de la dotation exercice, il est arrondi à 6 décimales pour stockage.
  [M:DIV]TXAMT = arr( [M:DIV]TXAMT, 0.000001)


  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # La fin d'amortissement est antérieure à l'exercice courant
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, si la dotation est > à la valeur nette, la dotation ne peut être égale qu'à la valeur nette
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_HL - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End

#########################################################
Subprog  CAL_DOT_EXE_HD
#
# - Objet  : Calcule la dotation de l'exercice selon le mode HD ( Dégressif suisse )
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#   FQ84281
#
#

Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  If ([M:DIV]NIVDET > 7) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_HD - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_HD - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_HD - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_HD - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_HD - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_HD - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_HD - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_HD - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_HD - Valnet amort déb exe  =" + num$([M:DIV]VLNAMT)     ) From =G_GLOB0
  Endif
  #=================
  # Taux
  #=================
  # Taux dégressif
  If ( [F:DEPC]DPRRATFLG = G_OUI ) Then
    [M:DIV]TXAMT = [F:DEPC]DPRRAT
  Else
    [M:DIV]TXAMT = (1 / [F:DEPC]DPRDUR)
  Endif
  If ([M:DIV]TXAMT > 1.) Then : [M:DIV]TXAMT = 1. : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_HD - Taux  d'amortissement =" + num$([M:DIV]TXAMT)) From =G_GLOB0

  #=================
  # Date Fin Amort.
  #=================
  Gosub CAL_DATE_FIN_AMORT_HD From =G_GLOB8
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_HD - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0

  If ( [M:DIV]VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_HD - Val. nette déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_HD - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_HD - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  # Durée de détention dans l'exercice
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&      [M:DIV]DATNUL, [M:DIV]DATSOREXE,  [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DATNUL
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_HD - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_HD - Durée exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0

  # Cas standard

  #---------------------------------------------
  # Calcul Dotation exercice dégressive
  #---------------------------------------------
  Call ECR_FICH("FS1", 7,
& "Dotation dégressive = Val. nette déb. exe. * * Taux  d'amortissement * (Durée Détention Exe. / Durée Exercice)") From =G_GLOB0
  [M:DIV]DOTEXE = [M:DIV]VLNAMT * ( [M:DIV]TXAMT ) * ( WDURDET / [M:DIV]DUREXE )

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT ([M:DIV]DOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= [M:DIV]DOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_HD - Dotation dégressive ................... ="-num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Valeur nette soldée si elle est inférieure à la valeur nette minimum NETVALWRO
  Local Decimal WNETVALWRO : WNETVALWRO = [M:DIV]ENDNVLWRO
  If (WNETVALWRO = 0.) Then : WNETVALWRO = 1. : Endif
  If (  abs([M:DIV]VLNAMT) <= WNETVALWRO ) Then
    [M:DIV]DOTEXE = [M:DIV]VLNAMT
  Endif

  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  # Bien que le taux ne soit pas arrondi pour le calcul de la dotation exercice, il est arrondi à 6 décimales pour stockage.
  If ([F:DEPC]DPRRATFLG <> G_OUI ) Then :  [M:DIV]TXAMT = arr( [M:DIV]TXAMT, 0.000001) : Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_HD - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End


#########################################################
Subprog  CAL_DOT_EXE_TL
#
# - Objet  : Calcule la dotation de l'exercice selon le mode TL
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#
#   FQ105809
#

Local Decimal WDURDET  : WDURDET  = 0.  : # Durée de détention dans l'exercice
Local Decimal WDURRES  : WDURRES  = 0.  : # Durée restant à amortir
Local Decimal WDOTEXE  : WDOTEXE  = 0.  : # Dotation exercice

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG and [F:DEPC]DPRPLN = 1) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.


  #=================
  # Taux / Duree
  #=================
  #---------------------
  If ( [F:DEPC]DPRRATFLG = G_OUI ) Then
    [M:DIV]TXAMT = [F:DEPC]DPRRAT
    # Calcul de la durée à partir du taux forcé
    Call  CAL_DUREE_SELON_TAUX_LINEAIRE ([M:DIV]TXAMT, [M:DIV]DURAMTREG) From =G_GLOB8
  Else
    # Durée en année et centième d'année
    [M:DIV]DURAMTREG = arr( [F:DEPC]DPRDUR, 0.01)
    # Calcul du taux linéaire à partir de la durée
    Call CAL_TAUX_LINEAIRE ([M:DIV]FLGRNDCHG, [M:DIV]DURAMTREG, [M:DIV]TXAMT) From =G_GLOB8
  Endif
  #---------------------

  If ([M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_TL - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_TL - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_TL - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_TL - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_TL - Date de sortie Exe.   =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_TL - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_TL - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_TL - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_TL - Val. nette déb. exe.  =" + num$([M:DIV]VLNAMT) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_TL - Durée                 =" + num$([M:DIV]DURAMTREG ) ) From =G_GLOB0
  Endif
  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  Gosub CAL_DATE_FIN_AMORT_TL From =G_GLOB8

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_TL - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    # Bien que le taux ne soit pas arrondi pour le calcul de la dotation exercice, il est arrondi à 6 décimales pour stockage.
    If( [M:DIV]FLGRNDCHG = G_OUI ) Then : [M:DIV]TXAMT = arr( [M:DIV]TXAMT, 0.000001) : Endif
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  #---------------------
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_TL - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_TL - Val. amortissable     =" + num$([M:DIV]VALAMT) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_TL - Taux  Linéaire        =" + num$([M:DIV]TXAMT ) ) From =G_GLOB0

  # Gestion de la priorité (Taux/Fin) d'amortissement
  Local Integer B_TXPRI : B_TXPRI = 0
  If ( [M:DIV]FLGTXPRI = G_OUI and [M:DIV]VLNAMT <> 0 and [F:DEPC]DPRRATFLG = G_OUI  and
&      ( [M:DIV]DTFNAMT < [M:DIV]DTDBEXE or func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT,[M:DIV]DTDBEXE,[M:DIV]DTFNEXE,"I") ) ) Then
    B_TXPRI = 1
    # Si le taux d'amortissement est prioritaire et que la valeur nette n'est pas nulle
    # Fin d'amortissement repoussée au delà de la fin d'exercice
    [M:DIV]DTFNAMT = func GLOBB9.CAL_DAT_PLUS( [M:DIV]DTFNEXE, 1, "D" )
    Local Date WDTFNEXE, WDTDBEXE
    Local Integer WINDEXE
    # Début/Fin exercice
    #Call CAL_EXERCICE_SELON_DATE  ( [M:DIV]DTFNAMT , GVML_TPJOUR, WDTDBEXE, WDTFNEXE, WINDEXE ) From =G_GLOB8
    [M:DIV]PD(0)= [M:DIV]DTFNAMT : [M:DIV]PV(0)= GVML_TPJOUR
    Gosub GSB_CAL_EXERCICE_SELON_DATE From =G_GLOB8
    WDTDBEXE = [M:DIV]RD(1) : WDTFNEXE = [M:DIV]RD(2) : WINDEXE  = [M:DIV]RE(0)
    If ([M:DIV]ERROR) Then : End : Endif
    [M:DIV]DTFNAMT = WDTFNEXE
  Endif

  # Durée de détention dans l'exercice
# Call  CAL_DUR_DET
#&      ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&       [M:DIV]DTFNAMT, [M:DIV]DATSOREXE, [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT,  WDURDET) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_TL - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0


  #-1 --------------------
  If ( [M:DIV]DTFNAMT > [M:DIV]DTFNEXE ) Then
  # La date de fin d'amortissement n'appartient pas à l'exercice

    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_TL - Durée Exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0

    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
    # calcul de la dotation exercice
    If ( [M:DIV]DUREXE <> 0 ) Then
      # Valeur amortissable * taux * prorata de détention dans l'exercice
      Call ECR_FICH("FS1", 7,
&     "Dotation exercice = Val. amort. * Taux  Lin. * ( Durée Dét. Exe. / Durée Exe. )") From =G_GLOB0
      WDOTEXE = [M:DIV]VALAMT * [M:DIV]TXAMT * ( WDURDET / [M:DIV]DUREXE )
    Else
      WDOTEXE = 0
    Endif
    #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , WDOTEXE) From =G_GLOB8
    [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXE = [M:DIV]RV(1)
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_TL - Dotation exe.         =" + num$(WDOTEXE) ) From =G_GLOB0
    #!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

  #-1 --------------------
  Elsif ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
  # La date de fin d'amortissement appartient à l'exercice

    # La valeur nette est soldée au prorata de la détention par rapport au reste à amortir
    # pour tenir compte de l'éventualité d'une sortie avant la fin d'amortissement.

    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_TL - Fin amort <= Fin Exe. => Solde" ) From =G_GLOB0
    # Calcul de la durée restant à amortir
    Call  CAL_DUR_REST_AMT
&         ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&   From =G_GLOB8
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_TL - Durée residuelle      =" + num$(WDURRES) ) From =G_GLOB0

    # calcul de la dotation exercice
    If ( WDURRES <> 0 ) Then
      Call ECR_FICH("FS1", 7,
&     "Dotation exercice = Valnet amort déb exe * ( Durée Dét. Exe. / Durée résid. )") From =G_GLOB0
      WDOTEXE = [M:DIV]VLNAMT * ( WDURDET / WDURRES)
    Else
      WDOTEXE = 0
    Endif

  Endif
  #-1 --------------------

  # Bien que le taux ne soit pas arrondi pour le calcul de la dotation exercice, il est arrondi à 6 décimales pour stockage.
  If( [M:DIV]FLGRNDCHG = G_OUI ) Then : [M:DIV]TXAMT = arr( [M:DIV]TXAMT, 0.000001) : Endif

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXE, [M:DIV]CUR , [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= WDOTEXE : [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # La fin d'amortissement est antérieure à l'exercice courant
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, si la dotation est > à la valeur nette, la dotation ne peut être égale qu'à la valeur nette
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_TL - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Taux prioritaire
  If ( B_TXPRI ) Then
    If ( [M:DIV]DOTEXE = 0 ) Then
      [M:DIV]DTFNAMT = [F:DEPC]ENDDPRDAT
    Else
      WDURRES  = ([M:DIV]VLNAMT / [M:DIV]DOTEXE ) * 365.25
      [M:DIV]DTFNAMT = (func GLOBB9.CAL_DAT_PLUS( max([M:DIV]DTDBAMTREG, [M:DIV]DTDBEXE), WDURRES, "D" )) - 1
    Endif
  Endif

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End


#########################################################
Subprog  CAL_DOT_EXE_TD
#
# - Objet  : Calcule la dotation de l'exercice selon le mode TD
#            Degressif turque
#
#   Rem. 1°) Lorsque le porata temporis est "1/2 année"
#            Le début d'amt pour la dotation exercice est le milieu du semestre du début d'amt
#            Le début d'amt pour la dotation période  est le début de mois du début d'amt (prorata mois)
#        2°) Lorsque le prorara temporis est "1/2 année" ou "1/2 mois"
#            Calcul de la dotation exercice sans tenir compte de la date de sortie
#            Puis la dotation exercice est proratée par rapport à la date de sortie
#
#
# - Entrée :
#
# - Sortie : Dotation de l'exercice
#
#   [M:DIV]DOTEXE   Dotation de l'exercice
#   [M:DIV]TXAMT    Taux d'amortissement
#
#   FQ105809
#

Local Decimal WTXAMT     : WTXAMT      = 0.     : # Taux d'amortissement
Local Decimal WDURDET    : WDURDET     = 0.     : # Durée de détention dans l'exercice
Local Decimal WDURRES    : WDURRES     = 0.     : # Durée restant à amortir
Local Decimal WDOTEXEDEG : WDOTEXEDEG  = 0.     : # Dotation exercice en dégressif
Local Decimal WDOTEXELIN : WDOTEXELIN  = 0.     : # Dotation exercice en linéaire sur valeur résiduelle
Local Date    WDTDBAMT   :                      : # Date de début d'amort régularisé pour dotation exercice


  #If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  [M:DIV]AMTEXC = 0.
  [M:DIV]DOTEXE = 0.

  If ( [M:DIV]VLNAMT = 0 ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_TD - Val. nette déb. exe. nulle" ) From =G_GLOB0
    [M:DIV]DOTEXE = 0.
    Call ECR_FICH
&   ("FS1", 7, "CAL_DOT_EXE_TD - Dotation exercice   ="+ format$([M:DIV]CURFMT,[M:DIV]DOTEXE) ) From =G_GLOB0
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif

  If ( [M:DIV]NIVDET > 7 ) Then
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_TD - Déb. Exercice         =" + num$([M:DIV]DTDBEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_TD - Fin  Exercice         =" + num$([M:DIV]DTFNEXE)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_TD - Début d'amort.        =" + num$([M:DIV]DTDBAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_TD - Date de sortie        =" + num$([M:DIV]DATSORREG)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_TD - Date de sortie Exe    =" + num$([M:DIV]DATSOREXE)  ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_TD - Base                  =" + num$([M:DIV]BASAMT)     ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_TD - Valeur résiduelle     =" + num$([F:DEPC]RSDVAL)    ) From =G_GLOB0
  Call ECR_FICH("FS1", 8, "CAL_DOT_EXE_TD - Cumul  E-1            =" + num$([F:DEPC]DPRCUM)    ) From =G_GLOB0
  Endif

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_TD - Valnet amort déb exe  =" + num$([M:DIV]VLNAMT) ) From =G_GLOB0


  #=================
  # Taux / Duree
  #=================
  #---------------------
  # Durée en année et centième d'année
  [M:DIV]DURAMTREG = arr( [F:DEPC]DPRDUR, 0.01)
  # Taux d'amortissement - Utilisation d'une variable locale car pas d'arrondi
  WTXAMT = ( 1 / [M:DIV]DURAMTREG ) * [F:DEPC]ACLCOE
  # Pas de taux d'amortissement en table
  [M:DIV]TXAMT   = 0.00
  #---------------------
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_TD - Durée d'amortissement =" + num$([M:DIV]DURAMTREG) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_TD - Coef. d'accélèration  =" + num$([F:DEPC]ACLCOE) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_TD - Taux  d'amortissement =" + num$(WTXAMT)             ) From =G_GLOB0

  #=================
  # Date Fin Amort.
  #=================
  #---------------------
  # Selon type de prorata saisi avec Date de début d'amortissement (fichier)
  Gosub CAL_DATE_FIN_AMORT_TD From =G_GLOB8
  #---------------------
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_TD - Fin   d'amort.        =" + num$([M:DIV]DTFNAMT)    ) From =G_GLOB0

  # Aucun amortissement si le bien a été classé comme détenu pour la vente avant le début d'exercice
  If ( [M:DIV]DETVTEDAT <> [0/0/0] and [M:DIV]DETVTEDAT < [F:DEPC]FIYSTRDAT ) Then
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_TD - Pas d'amortissement Bien détenu pour la vente"  ) From =G_GLOB0
    [M:DIV]AMTEXC = 0.
    [M:DIV]DOTEXE = 0.
    Gosub CAL_RMVLVL From =G_GLOB0
    End
  # ***
  Endif


  # Durée de détention dans l'exercice
#   Call  CAL_DUR_DET
#&        ([M:DIV]EXEDATREF, [M:DIV]DTFNEXE, [M:DIV]DATNUL, [M:DIV]DATNUL, [M:DIV]DTDBAMTREG,
#&        [M:DIV]DTFNAMT, [M:DIV]DATSOREXE,  [M:DIV]DETVTEDAT, [M:DIV]TYPPRODAT, WDURDET) From =G_GLOB8
  [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
  [M:DIV]PD(3)= [M:DIV]DATNUL    : [M:DIV]PD(4)= [M:DIV]DTDBAMTREG : [M:DIV]PD(5)= [M:DIV]DTFNAMT
  [M:DIV]PD(6)= [M:DIV]DATSOREXE : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
  Gosub GSB_CAL_DUR_DET From =G_GLOB8
  WDURDET = [M:DIV]RV(1)
  If ([M:DIV]ERROR) Then : End : Endif
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_TD - Durée Détention Exe.  =" + num$(WDURDET) ) From =G_GLOB0
  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_TD - Durée Exercice        =" + num$([M:DIV]DUREXE) ) From =G_GLOB0

  #---------------------------------------------
  # Calcul Dotation exercice dégressive
  #---------------------------------------------
  Call ECR_FICH("FS1",7,
&   "Dotation dégressif = Valnet amort déb exe * Taux  d'amortissement * ( Durée Détention Exe. / Durée Exercice)  " ) From =G_GLOB0
  WDOTEXEDEG = [M:DIV]VLNAMT * ( WTXAMT ) * ( WDURDET / [M:DIV]DUREXE )

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXEDEG, [M:DIV]CUR , WDOTEXEDEG) From =G_GLOB8
    [M:DIV]PV(0)= WDOTEXEDEG : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXEDEG = [M:DIV]RV(1)
    Call ECR_FICH
&   ("FS1", 7, "CAL_DOT_EXE_TD - Dotation dégressive ................... ="-num$(WDOTEXEDEG) ) From =G_GLOB0

  # Calcul de la durée restant à amortir
    Call  CAL_DUR_REST_AMT
&         ([M:DIV]DTDBAMTREG, [M:DIV]EXEDATREF, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES)
&   From =G_GLOB8
    Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_TD - Linéaire Durée Résid. à amort.  =" + num$(WDURRES)) From =G_GLOB0

  #---------------------------------------------
  # Calcul Dotation exercice linéaire sur valeur et durée résiduelles
  #---------------------------------------------
  # Cas standard
  If ( WDURRES = 0 ) Then
    WDOTEXELIN = 0
  Else
    Call ECR_FICH("FS1",7,
&     "Dotation linéaire = Valnet amort déb exe *  ( Durée Détention Exe. / Durée résiduelle)  " ) From =G_GLOB0
    WDOTEXELIN = [M:DIV]VLNAMT * ( WDURDET / WDURRES )
  Endif

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT (WDOTEXELIN, [M:DIV]CUR, WDOTEXELIN) From =G_GLOB8
    [M:DIV]PV(0)= WDOTEXELIN : [M:DIV]PC(0)= [M:DIV]CUR
    Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : WDOTEXELIN = [M:DIV]RV(1)
    Call ECR_FICH
&        ("FS1", 7, "CAL_DOT_EXE_TD - Linéaire val.rés./dur rés.............. ="-num$(WDOTEXELIN)) From =G_GLOB0

  # Détermination de la dotation exercice
  If ( abs(WDOTEXEDEG) > abs(WDOTEXELIN) ) Then
    [M:DIV]DOTEXE = WDOTEXEDEG
  Else
    [M:DIV]DOTEXE = WDOTEXELIN
  Endif

  # Arrondi dans la devise du contexte
  #Call CAL_ARRONDI_MNT ([M:DIV]DOTEXE, [M:DIV]CUR, [M:DIV]DOTEXE) From =G_GLOB8
  [M:DIV]PV(0)= [M:DIV]DOTEXE: [M:DIV]PC(0)= [M:DIV]CUR
  Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:DIV]DOTEXE = [M:DIV]RV(1)

  # Si la fin d'amortissement est antérieure à l'exercice courant
  # et que la valeur nette est non nulle elle doit être soldée sur la dotation de l'exercice courant
  # Elle doit l'être aussi soldée dans la période courante
  Gosub EVALUE_FLGSLDPER From =G_GLOB4

  # Sécurité, la dotation ne peut pas être > à la valeur nette - ajustement éventuel
  Gosub PLAFONNEMENT_A_VLNAMT From =G_GLOB4

  Call ECR_FICH("FS1", 7, "CAL_DOT_EXE_TD - Dotation exe.         =" + num$([M:DIV]DOTEXE) ) From =G_GLOB0

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End

