#**  Endif
#** Next AXE
#**Endif
#*!
#MIPEA - 2017-01-25- X3-12033- END
Return
#MIPEA - 2017-01-27- X3-12033- START
Subprog INISEC_DSP_EMPTY(ABREV)
Value Char    ABREV
Local Char    NAT(GLONNAT), CCE(GLONCCE), CPY_TIP(GLONCPY)
Local Integer JS
Local Char    WSAVGSOC(GLONCPY)

  CPY_TIP= func DIVPAYE.GETSOC(evalue("[F:"+ABREV+"]FCY"))
  Gosub LISTDIE
  JS=0
  NAT=evalue("[F:"+ABREV+"]NATCOD")
  Call LECT_NATCOD (NAT) From TPSDIV
  If [F:TIM]CCEINI<>""
    WSAVGSOC=GSOCIETE
    GSOCIETE=CPY_TIP
    For AXE=1 To GOPTCANA
      If find([F:TIM]DIE(AXE-1),WLSTDIE(1..WNBRDIE)) Then
        Call INISEC(CCE,[F:TIM]CCEINI,[F:TIM]DIE(AXE-1)) From SUBCDE
        Assign "[F:"+ABREV+"]CCE("+num$(JS)+")" With CCE
        Assign "[F:"+ABREV+"]DIE("+num$(JS)+")" With [F:TIM]DIE(AXE-1)
        JS+=1
      Endif
    Next AXE
    GSOCIETE=WSAVGSOC
  Endif
  JS=0
  For AXE=1 To GOPTCANA
    If find([F:TIM]DIE(AXE-1),WLSTDIE(1..WNBRDIE)) Then
      If evalue("[F:"+ABREV+"]CCE("+num$(JS)+")")=""
        Assign "[F:"+ABREV+"]CCE("+num$(JS)+")" With [F:TIM]CCE(AXE-1)
        Assign "[F:"+ABREV+"]DIE("+num$(JS)+")" With [F:TIM]DIE(AXE-1)
        JS+=1
      Endif
    Endif
  Next AXE
End
#MIPEA - 2017-01-27- X3-12033- END

