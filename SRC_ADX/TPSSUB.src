#<AdxTL>@(#)0.0.0.0 $Revision$
#** V7 : Waiting Time Mangement **#
#*********************************#

$ACTION
Case ACTION
 When "SEL_LISTE"    : Gosub SEL_LISTE
 When "VERF_LISTE"   : Gosub VERF_LISTE
Endcase
Return

$SEL_LISTE
Case LISTE
 When "SELSEM"    : Gosub SELSEM
 When "SELNUMWEK" : Gosub SELNUMWEK
 When "SELPYRDAT" : Gosub SELPYRDAT
Endcase
Return

$VERF_LISTE
Case LISTE
 When "SELSEM"    : Gosub VERFSEM
 When "SELNUMWEK" : Gosub VERFNUMWEK
Endcase
Return

################################################################################
## Recadrage d'une date sur une date de paye
################################################################################
Subprog CADRE_PYRDAT(VALEUR,CTRPERCOD)
Variable Date VALEUR
#MIPEA - 2016-12-13 - X3-12089- START
Value    Char CTRPERCOD
#Value    Char SITE

If clalev([F:HRPEOD])=0 : Local File HRPEODET [HRPEOD] : Endif

Local Integer OK
OK = 0
#JOJAC - 2017-03-10 - START
Filter [F:HRPEOD] Where PERCOD=CTRPERCOD & PYRDAT = VALEUR
Read [F:HRPEOD] First
Filter [HRPEOD]
If fstat
#JOJAC - 2017-03-10 - END
  Filter [HRPEOD] Where PERCOD=CTRPERCOD & PERSTR(0)<=VALEUR & PEREND(0)>=VALEUR
  Read [HRPEOD]HRPEOD0 First
  Filter [HRPEOD]
  If fstat>2
    Filter [HRPEOD] Where PERCOD=CTRPERCOD & PYRDAT>VALEUR
    Read [HRPEOD]HRPEOD0 First
    Filter [HRPEOD]
    If fstat>2
      GMESSAGE = mess(12,10709,1) : # Pas de paye définie à cette date
      mkstat = 2 : End
    Endif
  Endif
  VALEUR = [F:HRPEOD]PYRDAT
#JOJAC - 2017-03-10 - START
Endif
#JOJAC - 2017-03-10 - END
#MIPEA - 2016-12-13 - X3-12089- END
#** V7 : Waiting Time Mangement **#
#**If clalev([F:HRPEO])=0 : Local File HRPERIOD [HRPEO] : Endif
#**Local Char    SITPEO(GLONFCY)
#**Local Integer OK
#**OK = 0
#**Filter [HRPEO] Where YEA=year(VALEUR) & FCY=SITE
#**Read [HRPEO]PEO0 First
#**Filter [HRPEO]
#**If fstat<=2
#** SITPEO = SITE
#**Else
#** SITPEO = ""
#**Endif
#**Read [HRPEO]PEO0 = SITPEO;VALEUR
#**If fstat
#** Filter [HRPEO] Where FCY=SITPEO & PERSTR(0)<=VALEUR & PEREND(0)>=VALEUR
#** Read [HRPEO]PEO0 First
#** Filter [HRPEO]
#** If fstat>2
#**  Filter [HRPEO] Where FCY=SITPEO & PYRDAT>VALEUR
#**  Read [HRPEO]PEO0 First
#**  Filter [HRPEO]
#**  If fstat>2
#**   GMESSAGE = mess(12,10709,1) : # Pas de paye définie à cette date
#**   mkstat = 2 : End
#**  Endif
#** Endif
#**Endif
#**VALEUR = [F:HRPEO]PYRDAT
#**
#*!
End

#
# Recadrage d'une date sur une date de paye pour évènement calendaire
# SEGAY bug 67983
# @param  VALEUR  : date
# @param  SITE    : site
# @param  MONDAC    : type evenement calendaire ML 409 (2=mois calendaire)
# @since 08/10/10
#
Subprog CADRE_PYRDAT_MD(VALEUR,CTRPERCOD,MONDAC)
Variable Date VALEUR
Value    Char CTRPERCOD
#Value    Char SITE
Value Integer MONDAC
#LIPET - X3-11621 - 28-02-2017 - START
#** V7 : Waiting Time Mangement **#
#**If clalev([F:HRPEO])=0 : Local File HRPERIOD [HRPEO] : Endif
#**Local Char    SITPEO(GLONFCY)
#**Local Integer OK
#**OK = 0
#**Filter [HRPEO] Where YEA=year(VALEUR) & FCY=SITE
#**Read [HRPEO]PEO0 First
#**Filter [HRPEO]
#**If fstat<=2
#** SITPEO = SITE
#**Else
#** SITPEO = ""
#**Endif
#**Read [HRPEO]PEO0 = SITPEO;VALEUR
#**# SEGAY bug 73488
#**# En paramètre VALEUR = [F:TIP]STRDAT donc on teste qu'il soit compris dans la période
#**If fstat
#**& or (MONDAC = 2 & ([F:HRPEO]PERSTR(0)>VALEUR or [F:HRPEO]PEREND(1)<VALEUR)) or (MONDAC <> 2 & ([F:HRPEO]PERSTR(0)>VALEUR or [F:HRPEO]PEREND(0)<VALEUR))
#** If MONDAC = 2
#**  Filter [HRPEO] Where FCY=SITPEO & PERSTR(0)<=VALEUR & PEREND(1)>=VALEUR
#** Else
#**  Filter [HRPEO] Where FCY=SITPEO & PERSTR(0)<=VALEUR & PEREND(0)>=VALEUR
#** Endif
#** Read [HRPEO]PEO0 First
#** Filter [HRPEO]
#** If fstat>2
#**  Filter [HRPEO] Where FCY=SITPEO & PYRDAT>VALEUR
#**  Read [HRPEO]PEO0 First
#**  Filter [HRPEO]
#**  If fstat>2
#**   GMESSAGE = mess(12,10709,1) : # Pas de paye définie à cette date
#**   mkstat = 2 : End
#**  Endif
#** Endif
#**Endif
#**VALEUR = [F:HRPEO]PYRDAT
#*!

If clalev([F:HRPEOD])=0 : Local File HRPERIODET [HRPEOD] : Endif

Local Integer OK
OK = 0

Filter [HRPEOD] Where PERCOD=CTRPERCOD & PERSTR(0)<=VALEUR & PEREND(0)>=VALEUR
Read [HRPEOD]HRPEOD0 First
Filter [HRPEOD]
# SEGAY bug 73488
# En paramètre VALEUR = [F:TIP]STRDAT donc on teste qu'il soit compris dans la période
If fstat
& or (MONDAC = 2 & ([F:HRPEOD]PERSTR(0)>VALEUR or [F:HRPEOD]PEREND(1)<VALEUR)) or (MONDAC <> 2 & ([F:HRPEOD]PERSTR(0)>VALEUR or [F:HRPEOD]PEREND(0)<VALEUR))
 If MONDAC = 2
  Filter [HRPEOD] Where PERCOD=CTRPERCOD & PERSTR(0)<=VALEUR & PEREND(1)>=VALEUR
 Else
  Filter [HRPEOD] Where PERCOD=CTRPERCOD & PERSTR(0)<=VALEUR & PEREND(0)>=VALEUR
 Endif
 Read [HRPEOD]HRPEOD0 First
 Filter [HRPEOD]
Endif
If fstat>2
  Filter [HRPEOD] Where PERCOD=CTRPERCOD & PYRDAT>VALEUR
  Read [HRPEOD]HRPEOD0 First
  Filter [HRPEOD]
  If fstat>2
    GMESSAGE = mess(12,10709,1) : # Pas de paye définie à cette date
    mkstat = 2 : End
  Endif
Endif
VALEUR = [F:HRPEOD]PYRDAT
#LIPET - X3-11621 - 28-02-2017 - END
End


################################################################################
## Sélection date de paye
################################################################################
$SELPYRDAT
#JASMI - START
#** V7 : Waiting Time Mangement **#
#**Local Integer SITVID, AN
#**TIT = mess(8,31,1) : # Sélection
#**Filter [HRPEO] Where FCY="" or FCY=PARAM(1) Order By PYRDAT Desc; FCY Desc
#**For [HRPEO]
#** If AN<>[F:HRPEO]YEA
#**  AN = [F:HRPEO]YEA
#**  If [F:HRPEO]FCY=""
#**   SITVID = 1
#**  Else
#**   SITVID = 0
#**  Endif
#** Endif
#** If [F:HRPEO]FCY=PARAM(1) | SITVID=1
#**  NBTEX += 1
#**  TEX(NBTEX) = [F:HRPEO]PYRDAT
#**  If [F:HRPEO]FCY=""
#**   TEXTE(NBTEX) = format$("D:"+GFMDAT,[F:HRPEO]PYRDAT)+space$(5)+space$(7)+space$(5)+
#**&                 format$("D:"+GFMDAT,[F:HRPEO]PERSTR)-"=>"-format$("D:"+GFMDAT,[F:HRPEO]PEREND)
#**  Else
#**TEXTE(NBTEX) = format$("D:"+GFMDAT,[F:HRPEO]PYRDAT)+space$(5)+[F:HRPEO]FCY+space$(5)+
#**&                 format$("D:"+GFMDAT,[F:HRPEO]PERSTR)-"=>"-format$("D:"+GFMDAT,[F:HRPEO]PEREND)
#**  Endif
#** Endif
#**Next
#**Filter [HRPEO]
#**
Local Integer AN
Local Date STR2
Local Date END2
#LIPET - 2017-05-16 - X3-36890 - START
Local Char TEX(255)(0..)
Local Char TEXTE(255)(0..)
#LIPET - 2017-05-16 - X3-36890 - END
If clalev([F:HRPEOD])=0 : Local File HRPEODET [HRPEOD] : Endif

[L]STR2 = gdat$(func DIVPAYE.INIPARUSR("DEBPAY","",""))
[L]END2 = gdat$(func DIVPAYE.INIPARUSR("FINPAY","",""))

TIT = mess(8,31,1) : # Sélection
#ADNGO - 2017-01-09 - X3-11347 - START
#Filter [HRPEOD] Where PERCOD=PARAM(1) Order By PYRDAT Desc; FCY Desc
#JOJAC - 2017-01-23 - START
#MIPEA - 2017-02-27- X3-11361- START
If dim([M]PERCOD)>0
  Filter [HRPEOD] Where PERCOD=[M]PERCOD Order By PYRDAT Desc
Else
  Filter [HRPEOD] Where PERCOD=PARAM(1) Order By PYRDAT Desc
Endif
#Filter [HRPEOD] Where PERCOD=PARAM(1) Order By PYRDAT Desc
#MIPEA - 2017-02-27- X3-11361- END
#Filter [HRPEOD] Where PERCOD=PARAM(1) & (PYRDAT >=[L]STR2 & PYRDAT <=[L]END2) Order By PYRDAT Desc
#JOJAC - 2017-01-23 - END
#ADNGO - 2017-01-09 - X3-11347 - END

#JOJAC - 2017-01-23 - START
For [HRPEOD]
 If AN<>[F:HRPEOD]PERYEA
  AN = [F:HRPEOD]PERYEA
#  If [F:HRPEO]FCY=""
#   SITVID = 1
#  Else
#   SITVID = 0
#  Endif
 Endif
# If [F:HRPEO]FCY=PARAM(1) | SITVID=1
  NBTEX += 1
  TEX(NBTEX) = [F:HRPEOD]PYRDAT
#  If [F:HRPEO]FCY=""
#   TEXTE(NBTEX) = format$("D:"+GFMDAT,[F:HRPEO]PYRDAT)+space$(5)+space$(7)+space$(5)+
#&                 format$("D:"+GFMDAT,[F:HRPEO]PERSTR)-"=>"-format$("D:"+GFMDAT,[F:HRPEO]PEREND)
#  Else
TEXTE(NBTEX) = format$("D:"+GFMDAT,[F:HRPEOD]PYRDAT)+space$(5)+[F:HRPEOD]PERCOD+space$(5)+num$([F:HRPEOD]PERYEA)+space$(5)+
&                 format$("D:"+GFMDAT,[F:HRPEOD]PERSTR)-"->"-format$("D:"+GFMDAT,[F:HRPEOD]PEREND)
#  Endif
# Endif
Next
Filter [HRPEOD]
#JASMI - END
#JOJAC - 2017-01-23 - END
Return

###########################
$FILTRE
Local Char CRITSAL(250)
CRITSAL = "[F:ID]ENAFLG=2 & [F:ID]FLGTPS=2"
If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
 CRITSAL -= "& find([F:ECT]FCY,GUSRFCY(1..GNBAUZ))"
Endif
If GUSRACS<>2
 CRITSAL -= "& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))"
Endif

Link [ECT] With
&   [ID]ID0=[F:ECT]REFNUM
& , [ACC]CODACC=GUSER;[F:ID]CODACS
& As [LID]
& Where evalue(CRITSAL) & [F:ACC]EXEC=2
Return

################################################################################
## Sélection d'une semaine
################################################################################
$SELSEM
DAT1 = gdat$(PARAM(2))
DAT2 = gdat$(PARAM(3))
Repeat
 NBTEX += 1
 TEX(NBTEX) = num$(week(DAT1))
 TEXTE(NBTEX) = TEX(NBTEX)-":"-format$("D:"+GFMDAT4,DAT1)-format$("D:"+GFMDAT4,DAT1+6)
 DAT1 += 7
Until DAT1>DAT2
Return

$VERFSEM
VALEUR   = gdat$(PARAM(2))+7*(CHOIX-1)
PARAM(1) = VALEUR+6
Return

################################################################################
## Sélection d'un numéro de semaine
################################################################################
$SELNUMWEK
#LIPET - X3-11322 - 18-01-2017 - START
#** V7 : Waiting Time Mangement **#
#**Local Date DAT
#**Local Date DAT1(0..200)
#**Local Integer SITVID, AN, I
#**
#**TIT = mess(149,10709,1) : # Sélection d'une semaine
#**Filter [HRPEO] Where find(val(PARAM(2)),YEAWEK)<>0 & (FCY="" | FCY=PARAM(1)) Order By PYRDAT Desc; FCY Desc
#**For [HRPEO]
#** If AN<>[F:HRPEO]YEA
#**  AN = [F:HRPEO]YEA
#**  If [F:HRPEO]FCY=""
#**   SITVID = 1
#**  Else
#**   SITVID = 0
#**  Endif
#** Endif
#** If [F:HRPEO]FCY=PARAM(1) | SITVID=1
#**  For I= dim([F:HRPEO]NUMWEK)-1 To 0 Step -1
#**   If [F:HRPEO]NUMWEK(I)<>0 & [F:HRPEO]YEAWEK(I)=val(PARAM(2))
#**    DAT = [F:HRPEO]PERSTR(0)+7*I : # Jour du début de la semaine
#**    NBTEX +=1
#**    DAT1(NBTEX)  = [F:HRPEO]PYRDAT
#**    TEX(NBTEX)   = num$([F:HRPEO]NUMWEK(I))
#**    TEXTE(NBTEX) = mess(57,10709,1)+space$(1)+format$("K:4X",TEX(NBTEX))+" : "+mess(94,100,1)+space$(1)+
#**&                 format$("D:"+GFMDAT4,DAT)+space$(1)+mess(95,100,1)+space$(1)+format$("D:"+GFMDAT4,DAT+6)
#**&                 +space$(4)+[F:HRPEO]FCY
#**   Endif
#**  Next
#** Endif
#**Next
#**FILTER [HRPEO]
#**
#*!
Local Date DAT
Local Date DAT1(0..200)
Local Integer SITVID, AN, I

TIT = mess(149,10709,1) : # Sélection d'une semaine

Filter [HRPEOD] Where find(val(PARAM(2)),YEAWEK)<>0 & (PERCOD=PARAM(1)) Order By PYRDAT Desc
For [HRPEOD]
 If AN<>[F:HRPEOD]PERYEA
  AN = [F:HRPEOD]PERYEA
 Endif
# If [F:HRPEO]FCY=PARAM(1) | SITVID=1
  For I= dim([F:HRPEOD]NUMWEK)-1 To 0 Step -1
   If [F:HRPEOD]NUMWEK(I)<>0 & [F:HRPEOD]YEAWEK(I)=val(PARAM(2))
    DAT = [F:HRPEOD]PERSTR(0)+7*I : # Jour du début de la semaine
    NBTEX +=1
    DAT1(NBTEX)  = [F:HRPEOD]PYRDAT
    TEX(NBTEX)   = num$([F:HRPEOD]NUMWEK(I))
    TEXTE(NBTEX) = mess(57,10709,1)+space$(1)+format$("K:4X",TEX(NBTEX))+" : "+mess(94,100,1)+space$(1)+
&                 format$("D:"+GFMDAT4,DAT)+space$(1)+mess(95,100,1)+space$(1)+format$("D:"+GFMDAT4,DAT+6)
&                 +space$(4)+[F:HRPEOD]PERCOD
   Endif
  Next
Next
Filter [HRPEOD]
#LIPET - X3-11322 - 18-01-2017 - END
Return

$VERFNUMWEK
PARAM(3) = DAT1(CHOIX)
mkstat = 4 : # Si dans la liste on a 2 semaines 52 (une sur le 31/01/06 et une sur le 31/12/06)
Return

################################################################################
## Remplissage analytique
################################################################################
#ADNGO - 2017-01-19 - X3-11992 - START
$LISTDIE
Local Char    WSAVGSOC(GLONCPY)
Local Char    WACM(GLONGCM)
Local Char    WLSTDIE(GLONDIE)(1..[V]GOPTCANA)
Local Integer WNBRDIE
Local Integer WNBPLAN
Local Char    WTPLAN(GLONCOA)(1..len(mess(0,2644,1)))
Local Integer WTREFTYP(1..2)
Local Integer WTOBLIG(1..[V]GOPTCANA)

  WSAVGSOC=GSOCIETE
  GSOCIETE=CPY_TIP
  Call SETGCM(CPY_TIP,WACM) From CPTDIV : # code du modèle de la société
  # Liste des axes de tous les référentiels du modèle (nb référentiels limités à len de
  Call SETPLAN2(WACM,WNBPLAN,WTPLAN,WTREFTYP,WNBRDIE,WLSTDIE,WTOBLIG) From CPTDIV
  GSOCIETE=WSAVGSOC
Return
#ADNGO - 2017-01-19 - X3-11992 - END
$INISEC
#MIPEA - 2017-01-25- X3-12033- START

Local Integer AXE
Read [F:CPT]CPT0 = [L]MATRI
If !fstat
 [F:TIP]DSP = [F:CPT]DSP
Endif
# On suppose le bon contrat sous les pieds : cette étiquette est appelée par TRTFOR / TRTGEN / TRTREM
#                                            la lecture est faite au préalable
Read [F:CPR]CPR0 = [L]MATRI ; [L]CTR ; [F:HRCTR]CTRDAT
If !fstat
 [F:TIP]DSP = [F:CPR]DSP
Endif
If [F:TIP]DSP = ""
 If [F:TIM]CCEINI<>""
  If    [F:TIP]NATCOD=""          : Raz [F:NAT]
  Elsif [F:NAT]COD<>[F:TIP]NATCOD : Read [NAT]NAT0=GCURLEG;[F:TIP]NATCOD
  Endif
  For AXE=1 To GOPTCANA
   Call INISEC([F:TIP]CCE(AXE-1),[F:TIM]CCEINI,num$(AXE)) From SUBCDE
  Next AXE
 Endif
 For AXE=1 To GOPTCANA
  If [F:TIP]CCE(AXE-1)=""
   [F:TIP]CCE(AXE-1) = [F:TIM]CCE(AXE-1)
  Endif
 Next AXE
Endif

#** V7 : Waiting Time Mangement **#
#**
#**Local Integer AXE
#**Read [F:CPT]CPT0 = [L]MATRI
#**If !fstat
#** [F:TIP]DSP = [F:CPT]DSP
#**Endif
#**# On suppose le bon contrat sous les pieds : cette étiquette est appelée par TRTFOR / TRTGEN / TRTREM
#**#                                            la lecture est faite au préalable
#**Read [F:CPR]CPR0 = [L]MATRI ; [L]CTR ; [F:HRCTR]CTRDAT
