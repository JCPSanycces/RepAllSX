######################################################################################
## Conversion d'un montant unique
## Subprog CONVERT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
##
## Conversion avec toute la précision
## Subprog CONVERT2(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
##
## Conversion avec un arrondi donné (en nombre de décimales)
## Subprog CONVERT3(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,ARODEC,MTORG,MTDES,STAT)
##
## Conversion d'un tableau à somme constante
## Subprog CONVERT_TAB(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
##
## Conversion d'un tableau avec un arrondi forcé
## Subprog CONVERT3_TAB(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,ARODEC,MTORG,MTDES,STAT)
##
## Récupération du cours entre une devise origine et la devise société
## Subprog COURSITE(DEVORG,SITE,TYPCOURS,DATCOURS,COURS,STAT)
##
## Conversion avec un arrondi donné (en nombre de décimales) et cours éventuellement fourni
## Subprog COURMNT(DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,ARODEC,MTORG,MTDES,COURS,STAT)
######################################################################################
########################################################################################
# Test suite Process TRTDEV_SYRA : QLFSA_TRTDEV_SYRA
# CPO 02/01/2014
# launch with : func qlfsa_trtdev_syra.testsuite in the Eclipse console
########################################################################################
Subprog CONVERT(CTX,DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
Value 	 Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Char    DEVORG           : # Devise d'origine
Value    Char    DEVDES           : # Devise destination
Value    Char    DEVSOC           : # Devise de la société
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Decimal MTORG            : # Montant origine
Variable Decimal MTDES            : # Montant destination
Variable Integer STAT             : # Status de retour (0 = OK)
Local Integer NBMONT : NBMONT = 0
Local Integer ARROND : ARROND = 1 : # Arrondi
Goto CONVERSION

Subprog CONVERT2(CTX,DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
Value 	 Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Char    DEVORG           : # Devise d'origine
Value    Char    DEVDES           : # Devise destination
Value    Char    DEVSOC           : # Devise de la société
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Decimal MTORG            : # Montant origine
Variable Decimal MTDES            : # Montant destination
Variable Integer STAT             : # Status de retour (0 = OK)
Local Integer NBMONT : NBMONT = 0
Local Integer ARROND : ARROND = 0 : # Pas d'arrondi
Goto CONVERSION

Subprog CONVERT3(CTX,DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,ARODEC,MTORG,MTDES,STAT)
Value 	 Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Char    DEVORG           : # Devise d'origine
Value    Char    DEVDES           : # Devise destination
Value    Char    DEVSOC           : # Devise de la société
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Integer ARODEC           : # Arrondi
Value    Decimal MTORG            : # Montant origine
Variable Decimal MTDES            : # Montant destination
Variable Integer STAT             : # Status de retour (0 = OK)
Local Integer NBMONT : NBMONT = 0
Local Integer ARROND : ARROND = 2 : # Arrondi forcé à ARODES
Local Decimal ADODES
If int(ARODEC)>0 : ARODES = 10^(-ARODEC) : Else : ARROND = 1 : Endif
Goto CONVERSION

Subprog CONVERT_TAB(CTX,DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
Value 	 Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Char    DEVORG           : # Devise d'origine
Value    Char    DEVDES           : # Devise destination
Value    Char    DEVSOC           : # Devise de la société
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Decimal MTORG(0..)       : # Montant origine
Variable Decimal MTDES(0..)       : # Montant destination
Variable Integer STAT             : # Status de retour (0 = OK)
Local Integer NBMONT : NBMONT = dim(MTORG)-1
Local Integer ARROND : ARROND = 1
Goto CONVERSION

Subprog CONVERT2_TAB(CTX,DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,MTORG,MTDES,STAT)
Value 	 Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Char    DEVORG           : # Devise d'origine
Value    Char    DEVDES           : # Devise destination
Value    Char    DEVSOC           : # Devise de la société
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Decimal MTORG(0..)       : # Montant origine
Variable Decimal MTDES(0..)       : # Montant destination
Variable Integer STAT             : # Status de retour (0 = OK)
Local Integer NBMONT : NBMONT = dim(MTORG)-1
Local Integer ARROND : ARROND = 0
Goto CONVERSION

Subprog CONVERT3_TAB(CTX,DEVORG,DEVDES,DEVSOC,TYPCOURS,DATCOURS,ARODEC,MTORG,MTDES,STAT)
Value 	 Instance CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Char    DEVORG           : # Devise d'origine
Value    Char    DEVDES           : # Devise destination
Value    Char    DEVSOC           : # Devise de la société
Value    Integer TYPCOURS         : # Type de cours
Value    Date    DATCOURS         : # Date du cours
Value    Integer ARODEC           : # Arrondi
Value    Decimal MTORG(0..)       : # Montant origine
Variable Decimal MTDES(0..)       : # Montant destination
Variable Integer STAT             : # Status de retour (0 = OK)
Local Integer NBMONT : NBMONT = dim(MTORG)-1
Local Integer ARROND : ARROND = 2 : # Arrondi forcé à ARODES
Local Decimal ADODES
If int(ARODEC)>0 : ARODES = 10^(-ARODEC) : Else : ARROND = 1 : Endif
Goto CONVERSION
#######################################################################################
Subprog COURSITE(CTX,DEVORG,SITE,TYPCOURS,DATCOURS,COURS,STAT)
Value    Instance CTX Using C_WMACONTEXT
Value    Char    DEVORG        : # Devise origine
Value    Char    SITE          : # Site
Value    Libelle TYPCOURS      : # Type de cours
Value    Date    DATCOURS      : # Date du cours
Variable Decimal COURS         : # Cours
Variable Integer STAT          : # Status de retour (OK=0)

Local Char    DEVDES(GLONCUR), DEV1(GLONCUR), DEV2(GLONCUR), DEVCUR(GLONCUR)
Local Decimal COURDIV , COURMUL
Local Decimal EURT1, EURT2, COURS1
Local Integer EUR1, EUR2, FLEURO

#--Variables locales chargées à partir du contexte (remplacement des globales)
Local Char    CTX_EURO(GLONCUR)
#Local Decimal CTX_EURODEV
#Local Decimal CTX_AROEURO
#Local Decimal CTX_DECRCU
Local Date    CTX_HIDATE

#--Init des variables liées au contexte
CTX_EURO    = fmet CTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,CTX.AFOLDER,"EURO")
CTX_HIDATE  = gdat$(31,12,adxdcs+99)
#CTX_EURODEV = fmet CTX.APARAM.AGETVALNUM ([V]CST_ALEVFOLD,CTX.AFOLDER,"EURODEV")
#CTX_DECRCU  = fmet CTX.APARAM.AGETVALNUM ([V]CST_ALEV


Local File FACILITY [FCY]
Local File COMPANY  [CPY]

COURS=1
# If SITE="" : SITE=GFCYDEF : Endif
# If SITE="" : SITE = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.CRY,"FCY")

If [F:FCY]FCY<>SITE
 Read [FCY]FCY0=SITE
 If fstat : STAT=1 : End Endif
Endif
If [F:CPY]CPY<>[F:FCY]LEGCPY
 Read [CPY]CPY0=[F:FCY]LEGCPY
 If fstat : STAT=1 : End Endif
Endif

Local Instance ACPY Using C_ACPY
# Call SETCUR(1,[F:CPY]CPY,DEVDES) From CPTDIV_SYRA
DEVDES = [CPY]RGCCUR

FLEURO=1
STAT=0
If DATCOURS=[0/0/0] : DATCOURS=CTX_HIDATE : Endif
If TYPCOURS=0 : TYPCOURS=1 : Endif

If DEVORG=DEVDES
 COURS=1 : End
Endif

Local File TABCUR    [TCU]
Local File TABCHANGE [TCH]

#If DEVORG=GEURO
If DEVORG=CTX_EURO
 If [F:TCU]CUR<>DEVDES
     Read [TCU]TCU0=DEVDES
     If fstat STAT=3 : End Endif
 Endif
 If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
  # Euro vers devise "in"
  If [F:TCU]EURRAT=0
   COURS=1 : STAT=1
  Else
   COURS=[F:TCU]EURRAT
  Endif
 Else
  # Euro vers devise "out"
  DEV1=DEVDES : DEV2=CTX_EURO : Gosub COURS
 Endif
Elsif DEVDES=CTX_EURO  #GEURO
 If [F:TCU]CUR<>DEVORG
     Read [TCU]TCU0=DEVORG
     If fstat STAT=2 : End Endif
 Endif
 If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
  # Devise "in" vers Euro
  If [F:TCU]EURRAT=0
   COURS=1 : STAT=1
  Else
   COURS=1/[F:TCU]EURRAT
  Endif
 Else
  # Devise "out" vers Euro
  DEV1=CTX_EURO : DEV2=DEVORG : Gosub COURS
 Endif
Else
 If [F:TCU]CUR<>DEVORG
     Read [TCU]TCU0=DEVORG
     If fstat STAT=2 : End Endif
 Endif
 If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
  EUR1=[F:TCU]EURFLG
 Else
  EUR1=1
 Endif
 EURT1=[F:TCU]EURRAT
 If [F:TCU]CUR<>DEVDES
     Read [TCU]TCU0=DEVDES
     If fstat STAT=3 : End Endif
 Endif
 If [F:TCU]EURFLG=2 & ([F:TCU]EURDAT=[0/0/0] | [F:TCU]EURDAT<=DATCOURS)
  EUR2=[F:TCU]EURFLG
 Else
  EUR2=1
 Endif
 EURT2=[F:TCU]EURRAT
 If EUR1=2 & EUR2=2
  # Devise "in" vers devise "in"
  If EURT1=0 | EURT2=0
   COURS=1 : STAT=1
  Else
   COURS=EURT2/EURT1
  Endif
 Elsif EUR1=2
  # Devise "in" vers devise "out"
  DEV1=DEVDES : DEV2=CTX_EURO : Gosub COURS
  If EURT1=0
   COURS=1 : STAT=1
  Else
   COURS=COURS/EURT1
  Endif
 Elsif EUR2=2
  # Devise "out" vers devise "in"
  DEV1=CTX_EURO : DEV2=DEVORG : Gosub COURS
  If EURT2=0
   COURS=1 : STAT=1
  Else
   COURS=COURS*EURT2
  Endif
 Else
  # Devise "out" vers devise "out"
  DEV1=DEVDES : DEV2=DEVORG : Gosub COURS
  If STAT<>0
   # Y'a pas de cours direct, on passe l'euro pour l'europe
   STAT=0
   If FLEURO
    DEV1=CTX_EURO : DEV2=DEVORG : Gosub COURS
    If STAT=0
     COURS1=COURS
     DEV1=DEVDES : DEV2=CTX_EURO : Gosub COURS
     If STAT=0
      COURS=COURS1*COURS
     Endif
    Endif
   Endif
  Endif
 Endif
Endif
End

################################################################################################
# Issue X3-70668 - 2018-01-30 by FGR : BEGIN : Working with cache classes
$CONVERSION
Local Decimal COURS , COURDIV , COURMUL , COURDIV1 , COURMUL1 , ARD
Local Char    DEV1(GLONCUR) , DEV2(GLONCUR) , DEVCUR(GLONCUR)
Local Decimal MTEURO , AROEURO , EURT1 , EURT2 , SOMME
Local Integer EUR1 , EUR2 , I , FLEURO

Local Decimal NTCUCURRND
Local Date DTCUEURDAT
Local Decimal NTCUEURRAT

#--Variables locales chargées à partir du contexte (remplacement des globales)
Local Char    CTX_EURO(GLONCUR)
Local Decimal CTX_EURODEV
Local Decimal CTX_AROEURO
Local Decimal CTX_DECRCU
Local Date    CTX_HIDATE

  #--------------------------
  #--Init des variables liées au contexte
  CTX_EURO    = fmet CTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,CTX.AFOLDER,"EURO")
  CTX_EURODEV = fmet CTX.ACACHE.ACUR.AGETVALDEC(CTX_EURO, "CURRND")
  CTX_DECRCU  = fmet CTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD,CTX.AFOLDER,"DECRCU")
  CTX_HIDATE  = gdat$(31,12,adxdcs+99)
  CTX_AROEURO = fmet CTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD,CTX.AFOLDER,"AROEURO")
  #If fmet CTX.APARAM.AGETVALERR = 0 Then        # Issue X3-81514 - 2018-03-06 by FGR
  If CTX_AROEURO > 0 Then                        # Issue X3-81514 - 2018-03-06 by FGR
    AROEURO = 10^(-CTX_AROEURO)   # Arrondi pour les calculs en euro
  Else
    AROEURO = 0.001               # Valeur par défaut minimale
  Endif
  #--------------------------
  FLEURO  = 1                    # Passage par l'euro ou non
  STAT = 0
  If DATCOURS = [0/0/0] Then
    DATCOURS = CTX_HIDATE
  Endif
  If TYPCOURS = 0 Then
    TYPCOURS = 1
  Endif
  #--------------------------
  # Cas trivial
  If DEVORG = DEVDES Then
    NTCUCURRND = fmet CTX.ACACHE.ACUR.AGETVALDEC(DEVDES, "CURRND")
    For I = 0 To NBMONT
      MTDES(I) = MTORG(I)
      Case ARROND
        When 1
          MTDES(I) = arr(MTDES(I), NTCUCURRND)
        When 2
          MTDES(I) = arr(MTDES(I), ARODES)
      Endcase
    Next I
    Goto FIN
  Endif
  #--------------------------
  Local File TABCHANGE [TCH]
  If DEVORG = CTX_EURO Then
    DTCUEURDAT = fmet CTX.ACACHE.ACUR.AGETVALDAT(DEVDES, "EURDAT")
    NTCUEURRAT = fmet CTX.ACACHE.ACUR.AGETVALDEC(DEVDES, "EURRAT")
    If fmet CTX.ACACHE.ACUR.AGETVALNUM(DEVDES, "EURFLG") = [V]CST_AYES and (DTCUEURDAT = [0/0/0] or DTCUEURDAT <= DATCOURS) Then
      # Euro vers devise "in"
      SOMME = 0
      Case ARROND
        When 1
          ARD = fmet CTX.ACACHE.ACUR.AGETVALDEC(DEVDES, "CURRND")
        When 2
          ARD = ARODES
        When Default
          ARD = 0
      Endcase
      For I = 0 To NBMONT
        MTDES(I) = arr((MTORG(I) + SOMME) * NTCUEURRAT, ARD) - arr(SOMME * NTCUEURRAT, ARD)
        SOMME += MTORG(I)
      Next I
    Else
      # Euro vers devise "out"
      DEV1 = CTX_EURO
      DEV2 = DEVDES
      Gosub COURS
      If STAT = 0 Then
        SOMME = 0
        Case ARROND
          When 1
            ARD = fmet CTX.ACACHE.ACUR.AGETVALDEC(DEVDES, "CURRND")
          When 2
            ARD = ARODES
          When Default
            ARD = 0
        Endcase
        For I = 0 To NBMONT
          MTDES(I) = arr((MTORG(I) + SOMME) * arr(COURMUL / COURDIV, 10^-CTX_DECRCU),ARD) - arr(SOMME * arr(COURMUL / COURDIV, 10^-CTX_DECRCU), ARD)
          SOMME += MTORG(I)
        Next I
      Endif
    Endif
  Elsif DEVDES = CTX_EURO Then
    DTCUEURDAT = fmet CTX.ACACHE.ACUR.AGETVALDAT(DEVORG, "EURDAT")
    NTCUEURRAT = fmet CTX.ACACHE.ACUR.AGETVALDEC(DEVORG, "EURRAT")
    If fmet CTX.ACACHE.ACUR.AGETVALNUM(DEVORG, "EURFLG") = [V]CST_AYES and (DTCUEURDAT = [0/0/0] or DTCUEURDAT <= DATCOURS) Then
      # Devise "in" vers Euro
      SOMME = 0
      Case ARROND
        When 1
          ARD = CTX_EURODEV
        When 2
          ARD = ARODES
        When Default
          ARD = 0
      Endcase
      For I = 0 To NBMONT
        MTDES(I) = arr((MTORG(I) + SOMME) / NTCUEURRAT, ARD) - arr(SOMME / NTCUEURRAT, ARD)
        SOMME += MTORG(I)
      Next I
    Else
      # Devise "out" vers Euro
      DEV1 = CTX_EURO
      DEV2 = DEVORG
      Gosub COURS
      If STAT = 0 Then
        SOMME = 0
        Case ARROND
          When 1
            ARD = CTX_EURODEV
          When 2
            ARD = ARODES
          When Default
            ARD = 0
        Endcase
        For I=0 To NBMONT
          MTDES(I) = arr((MTORG(I) + SOMME) * arr(COURDIV / COURMUL, 10^-CTX_DECRCU), ARD) - arr(SOMME * arr(COURDIV / COURMUL, 10^-CTX_DECRCU), ARD)
          SOMME += MTORG(I)
        Next I
      Endif
    Endif
  Else
    DTCUEURDAT = fmet CTX.ACACHE.ACUR.AGETVALDAT(DEVORG, "EURDAT")
    NTCUEURRAT = fmet CTX.ACACHE.ACUR.AGETVALDEC(DEVORG, "EURRAT")
    If fmet CTX.ACACHE.ACUR.AGETVALNUM(DEVORG, "EURFLG") = [V]CST_AYES and (DTCUEURDAT = [0/0/0] or DTCUEURDAT <= DATCOURS) Then
      EUR1 = fmet CTX.ACACHE.ACUR.AGETVALNUM(DEVORG, "EURFLG")
    Else
      EUR1 = [V]CST_ANO
    Endif
    EURT1 = NTCUEURRAT
    #
    DTCUEURDAT = fmet CTX.ACACHE.ACUR.AGETVALDAT(DEVDES, "EURDAT")
    NTCUEURRAT = fmet CTX.ACACHE.ACUR.AGETVALDEC(DEVDES, "EURRAT")
    If fmet CTX.ACACHE.ACUR.AGETVALNUM(DEVDES, "EURFLG") = [V]CST_AYES and (DTCUEURDAT = [0/0/0] or DTCUEURDAT <= DATCOURS) Then
      EUR2 = fmet CTX.ACACHE.ACUR.AGETVALNUM(DEVDES, "EURFLG")
    Else
      EUR2 = [V]CST_ANO
    Endif
    EURT2 = NTCUEURRAT
    If EUR1 = [V]CST_AYES and EUR2 = [V]CST_AYES Then
      # Devise "in" vers devise "in"
      SOMME = 0
      For I = 0 To NBMONT
        Case ARROND
          When 1
            ARD = AROEURO
          When 2
            ARD = ARODES
          When Default
            ARD = 0
        Endcase
        MTEURO = arr((MTORG(I) + SOMME) / EURT1, ARD)
        MTSOMM = arr(SOMME / EURT1, ARD)
        Case ARROND
          When 1
            ARD = fmet CTX.ACACHE.ACUR.AGETVALDEC(DEVDES, "CURRND")
          When 2
            ARD = ARODES
          When Default
            ARD = 0
        Endcase
        MTDES(I) = arr(MTEURO * EURT2, ARD) - arr(MTSOMM * EURT2, ARD)
        SOMME += MTORG(I)
      Next I
    Elsif EUR1 = [V]CST_AYES Then
      # Devise "in" vers devise "out"
      DEV1 = CTX_EURO
      DEV2 = DEVDES
      Gosub COURS
      If STAT = 0 Then
        SOMME = 0
        For I = 0 To NBMONT
          Case ARROND
            When 1
              ARD = AROEURO
            When 2
              ARD = ARODES
            When Default
              ARD = 0
          Endcase
          MTEURO = arr((MTORG(I) + SOMME) / EURT1, ARD)
          MTSOMM = arr(SOMME / EURT1, ARD)
          Case ARROND
            When 1
              ARD = fmet CTX.ACACHE.ACUR.AGETVALDEC(DEVDES, "CURRND")
            When 2
              ARD = ARODES
            When Default
              ARD = 0
          Endcase
          MTDES(I) = arr(MTEURO * arr(COURMUL / COURDIV, 10^-CTX_DECRCU), ARD) - arr(MTSOMM * arr(COURMUL / COURDIV, 10^-CTX_DECRCU), ARD)
          SOMME += MTORG(I)
        Next I
      Endif
    Elsif EUR2 = [V]CST_AYES Then
      # Devise "out" vers devise "in"
      DEV1 = CTX_EURO
      DEV2 = DEVORG
      Gosub COURS
      If STAT = 0 Then
        SOMME = 0
        For I = 0 To NBMONT
          Case ARROND
            When 1
              ARD = AROEURO
            When 2
              ARD = ARODES
            When Default
              ARD = 0
          Endcase
          MTEURO = arr((MTORG(I) + SOMME) * arr(COURDIV / COURMUL, 10^-CTX_DECRCU), ARD)
          MTSOMM = arr(SOMME * arr(COURDIV / COURMUL, 10^-CTX_DECRCU), ARD)
          Case ARROND
            When 1
              ARD = fmet CTX.ACACHE.ACUR.AGETVALDEC(DEVDES, "CURRND")
            When 2
              ARD = ARODES
            When Default
              ARD = 0
          Endcase
          MTDES(I) = arr(MTEURO * EURT2, ARD) - arr(MTSOMM * EURT2, ARD)
          SOMME += MTORG(I)
        Next I
      Endif
    Else
      # Devise "out" vers devise "out"
      DEV1 = DEVDES
      DEV2 = DEVORG
      Gosub COURS
      If STAT = 0 Then
        #  Y'a un cours direct
        SOMME = 0
        For I = 0 To NBMONT
          Case ARROND
            When 1
              ARD = fmet CTX.ACACHE.ACUR.AGETVALDEC(DEVDES, "CURRND")
            When 2
              ARD = ARODES
            When Default
              ARD = 0
          Endcase
          MTDES(I) = arr((MTORG(I) + SOMME) * arr(COURDIV / COURMUL, 10^-CTX_DECRCU), ARD) - arr(SOMME * arr(COURDIV / COURMUL, 10^-CTX_DECRCU), ARD)
          SOMME += MTORG(I)
        Next I
      Else
        #  Sinon, on passe par le cours "société" (pour l'étranger)
        #  ou par l'euro pour l'europe
        STAT = 0
        If FLEURO Then
          DEV1 = CTX_EURO
          DEV2 = DEVORG
          Gosub COURS
          If STAT=0
            COURMUL1 = COURMUL
            COURDIV1 = COURDIV
            DEV1 = CTX_EURO
            DEV2 = DEVDES
            Gosub COURS
            If STAT = 0 Then
              SOMME = 0
              For I = 0 To NBMONT
                Case ARROND
                  When 1
                    ARD = AROEURO
                  When 2
                    ARD = ARODES
                  When Default
                    ARD = 0
                Endcase
                MTEURO = arr((MTORG(I)+SOMME)*arr(COURDIV1/COURMUL1,10^-CTX_DECRCU),ARD)
                MTSOMM = arr(SOMME*arr(COURDIV1/COURMUL1,10^-CTX_DECRCU),ARD)
                Case ARROND
                  When 1
                    ARD = fmet CTX.ACACHE.ACUR.AGETVALDEC(DEVDES, "CURRND")
                  When 2
                    ARD = ARODES
                  When Default
                    ARD = 0
                Endcase
                MTDES(I) = arr(MTEURO * arr(COURMUL / COURDIV, 10^-CTX_DECRCU), ARD) - arr(MTSOMM * arr(COURMUL / COURDIV, 10^-CTX_DECRCU), ARD)
                SOMME += MTORG(I)
              Next I
            Endif
          Endif
        Else
          DEV1 = DEVSOC
          DEV2 = DEVORG
          Gosub COURS
          If STAT = 0 Then
            COURMUL1 = COURMUL
            COURDIV1 = COURDIV
            DEV1 = DEVSOC
            DEV2 = DEVDES
            Gosub COURS
            If STAT = 0 Then
              SOMME = 0
              For I = 0 To NBMONT
                Case ARROND
                  When 1
                    ARD = AROEURO
                  When 2
                    ARD = ARODES
                  When Default
                    ARD = 0
                Endcase
                MTEURO = arr((MTORG(I) + SOMME) * arr(COURDIV1 / COURMUL1, 10^-CTX_DECRCU), ARD)
                MTSOMM = arr(SOMME * arr(COURDIV1 / COURMUL1, 10^-CTX_DECRCU), ARD)
                Case ARROND
                  When 1
                    ARD = fmet CTX.ACACHE.ACUR.AGETVALDEC(DEVDES, "CURRND")
                  When 2
                    ARD = ARODES
                  When Default
                    ARD = 0
                Endcase
                MTDES(I) = arr(MTEURO * arr(COURMUL / COURDIV, 10^-CTX_DECRCU), ARD) - arr(MTSOMM * arr(COURMUL / COURDIV, 10^-CTX_DECRCU), ARD)
                SOMME += MTORG(I)
              Next I
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
$FIN
End

$COURS
  Filter [TCH] Where CHGTYP = TYPCOURS and CURDEN = DEV1 and CUR = DEV2 and CHGSTRDAT <= DATCOURS
  Read [TCH]TCH0 Last
  If fstat <= 2 Then
    # Version 150, il y a 2 cours...
    COURMUL = [F:TCH]REVCOURS
    COURDIV = [F:TCH]CHGDIV
    If COURMUL = 0 Then
      COURMUL = 1
    Endif
    If COURDIV = 0 Then
      COURDIV = 1
    Endif
    COURS = arr(COURDIV / COURMUL, 10^-fmet CTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, CTX.AFOLDER, "DECRCU"))
    STAT = 0
  Else
    STAT = 1
  Endif
  #GPOINT = "RECHTCH" : Gosub ENTREE From EXEFNC
Return

