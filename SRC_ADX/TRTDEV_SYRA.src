##############################################################################
##  Check the currency capture with the euro and the validity date          ##
##############################################################################
Subprog CONT_CURR(DEVISE,DAT,MESSAGE,OK)
Value Char       DEVISE
Value Date       DAT
Variable Char    MESSAGE
Variable Integer OK

Local Char    EURO(GLONCUR)
Local Integer EURDAC
Local Date    EURDAT

Local File TABCUR  [TCU]
Local File AUTILIS [AUS]

OK = 1

Read [TCU]TCU0=DEVISE
If fstat<>[V]CST_AOK
 MESSAGE = DEVISE-":"-mess(151,105,1) # Devise inexistante
 OK=0 : End
Endif

Look [AUS]CODUSR=GACTX.USER
If fstat<>[V]CST_AOK
 MESSAGE = GACTX.USER-":"-mess(1,948,1) # Utilisateur incorrect
 OK=0 : End
Endif

# Date de validité
If [F:TCU]CURENDDAT<>[0/0/0] & DAT>=[F:TCU]CURENDDAT
 # Devise non valide à partir du
 MESSAGE = DEVISE-":"-mess(96,107,1)-num$([F:TCU]CURENDDAT) : # format$ avec GFMDAT4 non disponible
 OK = 0 : End
Endif

# Contrôle utilisateur
EURO = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,"","EURO")
If DEVISE = EURO : End : Endif
EURDAT = fmet GACTX.APARAM.AGETUSERVALDATE("DATDEBCTR")
EURDAC = fmet GACTX.APARAM.AGETUSERVALNUM("SAIDEVISE")


If EURDAT<>[0/0/0] & datesyst>EURDAT
 If [F:TCU]EURFLG=2 & DEVISE<>EURO
  If EURDAC<>2
   OK = 0   : # An error
  Else
  # A warning is displayed in some functions GESGAS GESGAF GESBIC GESBIS GESPAY GESCMM GESLOT GESPIH GESFAS
  # GESBUP GESFRM GESPAB GESSQH GESSOH GESSOR GESSDH GESSIH GESPPD GESPSH GESPOI GESPOH GESPOC SUBHLN* BUDDET*
  # BUDNAT* BUDSEC* PAYPRO*
   OK = 2
  Endif
  MESSAGE = mess(94,107,1) : # Saisie en devise in interdite
  End
 Endif
Endif

End

