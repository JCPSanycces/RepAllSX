#<AdxTL>@(#)9.0.0.0 $Revision$
#############################################################################################
#   Programmes utilitaires pour la définition d'un ciblage marketing
#
#   SETPPLGRU  : Renseigne la définition des groupes de populations
#   CTLPPLGRU  : Contrôle le contenu du champs GRUDEF avant création ou modification
#   GESNBCRI   : Contrôle la saisie du tableau des critères et valeurs de critères.
#   SETCRIGRU  : Renseigne la définition des groupes de critère
#   SETCRIGRU2 : Renseigne la définition des groupes de critère lors d'un nombre de ligne érroné.
#
#############################################################################################
#####################################################################
#  Renseigne la définition des groupes de populations
#####################################################################
Subprog SETPPLGRU
Local Integer IQ
Local Integer ILINNUM
Local Integer ILIGNE

  IQ = 0
  ILINNUM = 0
  ILIGNE = 0
  #Test si l'on est en insertion.
  If nolign > 1 Then
    If nolign > [M:MGG1]NBPPL Then
      IINSERT = 0
    Else
      IINSERT = 1
    Endif
  Else
    If [M:MGG1]NBPPL = nolign-1 Then
      IINSERT = 0
    Else
      IINSERT = 1
    Endif
  Endif
  If IINSERT Then
    ILIGNE = [M:MGG1]NBPPL-1
  Else
    ILIGNE = [M:MGG1]NBPPL
  Endif
  If [M:MGG1]NBPPL < 1 Then
    [M:MGG1]PPLGRUDIO = "(1)"
    End
  Endif
  [M:MGG1]PPLGRUDIO = "("
  For IQ = 0 To ILIGNE
    ILINNUM = IQ + 1
    If ILINNUM > 1 Then
      Case [M:MGG1]PPLOPD(IQ)
        When 1
          [M:MGG1]PPLGRUDIO = [M:MGG1]PPLGRUDIO - mess(2,2959,1) - num$(ILINNUM)
        When 2
          [M:MGG1]PPLGRUDIO = [M:MGG1]PPLGRUDIO - mess([M:MGG1]PPLOPD(IQ),2959,1) - num$(ILINNUM)
        When 3
          [M:MGG1]PPLGRUDIO = [M:MGG1]PPLGRUDIO + ")" - mess([M:MGG1]PPLOPD(IQ),2959,1) - "(" + num$(ILINNUM)
        When 4
          [M:MGG1]PPLGRUDIO = [M:MGG1]PPLGRUDIO - mess([M:MGG1]PPLOPD(IQ),2959,1) - num$(ILINNUM)
        When 5
          [M:MGG1]PPLGRUDIO = [M:MGG1]PPLGRUDIO + ")" - mess([M:MGG1]PPLOPD(IQ),2959,1) - "(" + num$(ILINNUM)
        When Default
      Endcase
    Else
      [M:MGG1]PPLGRUDIO = [M:MGG1]PPLGRUDIO + num$(ILINNUM)
    Endif
  Next
  [M:MGG1]PPLGRUDIO = [M:MGG1]PPLGRUDIO + ")"
End

####################################################################
# Contrôle le contenu du champs GRUDEF avant création ou modification
####################################################################
Subprog CTLPPLGRU(INBLINTAB, SZCRIPPLFLG, SZGRUDIO, ICANCREMOD)
Value Integer INBLINTAB
Value Char SZCRIPPLFLG 
Variable Char SZGRUDIO
Variable Integer ICANCREMOD

Local Integer INBOUVRE
Local Integer INBFERME
Local Integer ISTART
Local Integer ITER
Local Integer ITER2
Local Integer IPRECRI
Local Integer INEWCRI
Local Integer IPOS1
Local Integer IPOS2
Local Integer ICRICOUNT
Local Char SZVALEUR

  INBOUVRE = 0
  INBFERME = 0
  ISTART = 1
  ITER = 1
  ITER2 = 0
  IPRECRI = 0
  INEWCRI = 0
  IPOS1 = 0
  IPOS2 = 0
  ICRICOUNT = 0
  SZVALEUR = vireblc(SZGRUDIO, 4)
  #S'il n'y a pas de critères et que le champs est vide. Ca va bien
  If INBLINTAB < 1 Then
    If SZGRUDIO = "" Then
      ICANCREMOD = 1
      End
    Endif
  Endif
  #Vérifie la réciprocité des parenthèse
  While 1
    ISTART = instr(ISTART, SZGRUDIO, '(')
    If ISTART Then
      ISTART += 1
      INBOUVRE += 1
    Else
      Break
    Endif
  Wend
  ISTART = 1
  While 1
    ISTART = instr(ISTART, SZGRUDIO, ')')
    If ISTART Then
      ISTART += 1
      INBFERME += 1
    Else
      Break
    Endif
  Wend
  If INBOUVRE > INBFERME Then
    GMESSAGE = mess(513,196,1)   #Il manque une ou plusieurs parenthèses fermante.
    GERR = 1
    ICANCREMOD = 0
    End
  Endif
  If INBFERME > INBOUVRE Then
    GMESSAGE = mess(512,196,1)   #Il manque une ou plusieurs parenthèses ouvrante.
    GERR = 1
    ICANCREMOD = 0
    End
  Endif
  #Vérifie l'absence de groupes de parenthèses vides
  If instr(1, SZGRUDIO, '()') Then
    GMESSAGE = mess(514,196,1)   #Un des groupes de parenthèses est vide.
    GERR = 1
    ICANCREMOD = 0
    End
  Endif
  #Vérifie que la zone commence et fini avec une parenthèse
  If left$(SZGRUDIO, 1) <> '(' Then
    GMESSAGE = mess(519,196,1)   #La définition doit commencer avec une parenthèse.
    GERR = 1
    ICANCREMOD = 0
    End
  Endif
  If mid$(SZGRUDIO, len(SZGRUDIO), 1) <> ')' Then
    GMESSAGE = mess(520,196,1)   #La définition doit se terminer avec une parenthèse.
    GERR = 1
    ICANCREMOD = 0
    End
  Endif
  #Vérifie que tous les numéros de critères sont mentionnés dans le regroupement
  For ITER = 1 To INBLINTAB
    If !instr(1, SZGRUDIO, num$(ITER)) Then
      If SZCRIPPLFLG = "CRI" Then
        GMESSAGE = mess(516,196,1)   #Il manque un ou plusieurs numéro de critères.
      Elsif SZCRIPPLFLG = "PPL" Then
        GMESSAGE = mess(808,196,1)   #Il manque un ou plusieurs numéro de populations.
      Endif
      GERR = 1
      ICANCREMOD = 0
      Break
    Endif
  Next
  If ICANCREMOD = 0 Then
    End
  Endif
  #Vérifie qu'il n'y a pas de critères hors plage autorisée
  ITER = 1
  ITER2 = 0
  While ITER < len(SZGRUDIO)
    If instr(1, "0123456789", mid$(SZGRUDIO, ITER, 1)) Then
      SZCRIL = mid$(SZGRUDIO, ITER, 1)
      ITER2 = ITER + 1
      While instr(1, "0123456789", mid$(SZGRUDIO, ITER2, 1))
        SZCRIL = SZCRIL + mid$(SZGRUDIO, ITER2, 1)
        ITER2 += 1
      Wend
      If val(SZCRIL) < 1 Then
        If SZCRIPPLFLG = "CRI" Then
          #Certains numéros ne correspondent pas à des critères.
          GMESSAGE = mess(518,196,1)    
        Elsif SZCRIPPLFLG = "PPL" Then
          #Certains numéros ne correspondent pas à des populations.
          GMESSAGE = mess(809,196,1)    
        Endif
        GERR = 1
        ICANCREMOD = 0
        Break
      Endif
      If val(SZCRIL) > INBLINTAB Then
        If SZCRIPPLFLG = "CRI" Then
          #Certains numéros ne correspondent pas à des critères.
          GMESSAGE = mess(518,196,1)    
        Elsif SZCRIPPLFLG = "PPL" Then
          #Certains numéros ne correspondent pas à des populations.
          GMESSAGE = mess(809,196,1)    
        Endif
        GERR = 1
        ICANCREMOD = 0
        Break
      Endif
      ITER = ITER + len(SZCRIL) - 1
    Endif
    ITER += 1
  Wend
  If ICANCREMOD = 0 Then
    End
  Endif
  #Vérifie qu'un même code n'a pas été saisi plusieurs fois
  ITER = 1
  ITER2 = 0
  IPRECRI = 0
  INEWCRI = 0
  IPOS1 = 0
  IPOS2 = 0
  ICRICOUNT = 0
  While ITER < len(SZGRUDIO)
    IPOS1 = instr(1, "0123456789", mid$(SZGRUDIO, ITER, 1))
    If IPOS1 Then
      SZCRIL = mid$(SZGRUDIO, ITER, 1)
      ITER2 = ITER + 1
      While instr(1, "0123456789", mid$(SZGRUDIO, ITER2, 1))
        SZCRIL = SZCRIL + mid$(SZGRUDIO, ITER2, 1)
        ITER2 += 1
      Wend
      IPOS2 = 1
      ICRICOUNT = 0
      While 1
        IPOS2 = instr(IPOS2, SZGRUDIO, SZCRIL)
        If IPOS2 Then
          ICRICOUNT += 1
          IPOS2 += 1
          If ICRICOUNT > 1 Then
            If SZCRIPPLFLG = "CRI" Then
              #Un même numéro de critère a été saisi plusieurs fois.
              GMESSAGE = mess(517,196,1)    
            Elsif SZCRIPPLFLG = "PPL" Then
              #Un même numéro de population a été saisi plusieurs fois.
              GMESSAGE = mess(810,196,1)    
            Endif
            GERR = 1
            ICANCREMOD = 0
            Break 2
          Endif
        Else
          Break
        Endif
      Wend
      ITER = ITER + len(SZCRIL) - 1
    Endif
    ITER += 1
  Wend
  If ICANCREMOD = 0 Then
    End
  Endif
  #Vérifie que tous les numéros sont saisis par ordre croissant uniquement.
  ITER = 1
  ITER2 = 0
  IPRECRI = 0
  INEWCRI = 0
  While ITER < len(SZGRUDIO)
    If instr(1, "0123456789", mid$(SZGRUDIO, ITER, 1)) Then
      SZCRIL = mid$(SZGRUDIO, ITER, 1)
      ITER2 = ITER + 1
      While instr(1, "0123456789", mid$(SZGRUDIO, ITER2, 1))
        SZCRIL = SZCRIL + mid$(SZGRUDIO, ITER2, 1)
        ITER2 += 1
      Wend
      INEWCRI = val(SZCRIL)
      If INEWCRI < IPRECRI Then
        If SZCRIPPLFLG = "CRI" Then
          #Les codes critères doivent être saisis uniquement dans un ordre croissant.
          GMESSAGE = mess(515,196,1)    
        Elsif SZCRIPPLFLG = "PPL" Then
          #Les codes populations doivent être saisis uniquement dans un ordre croissant.
          GMESSAGE = mess(811,196,1)    
        Endif
        GERR = 1
        ICANCREMOD = 0
        Break
      Endif
      If INEWCRI = IPRECRI Then
        If SZCRIPPLFLG = "CRI" Then
          #Un même numéro de critère a été saisi plusieurs fois.
          GMESSAGE = mess(517,196,1)    
        Elsif SZCRIPPLFLG = "PPL" Then
          #Un même numéro de population a été saisi plusieurs fois.
          GMESSAGE = mess(810,196,1)    
        Endif
        GERR = 1
        ICANCREMOD = 0
        Break
      Endif
      IPRECRI = INEWCRI
      ITER = ITER + len(SZCRIL) - 1
    Endif
    ITER += 1
  Wend
  If ICANCREMOD = 0 Then
    End
  Endif
  #Vérifie qu'un opérateur existe entre chaque numéro de critère
  ITER = 1
  ITER2 = 0
  IPRECRI = 0
  INEWCRI = 0
  ICRICOUNT = 0
  IPOS1 = 0
  IPOS2 = 0
  While ITER < len(SZVALEUR)
    If !IPOS2 Then
      If !instr(1, "()0123456789", mid$(SZVALEUR, ITER, 1)) Then
        #Certains opérateurs sont placés de manière incorrecte.
        GMESSAGE = mess(522,196,1)    
        GERR = 1
        ICANCREMOD = 0
        Break
      Endif
    Endif
    If instr(1, "0123456789", mid$(SZVALEUR, ITER, 1)) Then
      IPOS2 = 1
      SZCRIL = mid$(SZVALEUR, ITER, 1)
      ITER2 = ITER + 1
      While instr(1, "0123456789", mid$(SZVALEUR, ITER2, 1))
        SZCRIL = SZCRIL + mid$(SZVALEUR, ITER2, 1)
        ITER2 += 1
      Wend
      #Il peut y avoir une mauvaise constitution d'un numéro de critère.
      #Il faut donc vérifier qu 'il correspond à une ligne existante
      If val(SZCRIL) < 1 Then
        #Certains opérateurs sont placés de manière incorrecte.
        GMESSAGE = mess(522,196,1)    
        GERR = 1
        ICANCREMOD = 0
        Break
      Endif
      If val(SZCRIL) > INBLINTAB Then
        #Certains opérateurs sont placés de manière incorrecte.
        GMESSAGE = mess(522,196,1)    
        GERR = 1
        ICANCREMOD = 0
        Break
      Endif
      ITER2 = ITER + len(SZCRIL)
      ICRICOUNT = 0
      While 1
        If ITER2 > len(SZVALEUR) Then
          If ICRICOUNT Then
            #Certains opérateurs sont placés de manière incorrecte.
            GMESSAGE = mess(522,196,1)    
            GERR = 1
            ICANCREMOD = 0
            Break 2
          Else
            ICRICOUNT = 1
          Endif
          Break
        Endif
        If instr(1, "0123456789", mid$(SZVALEUR, ITER2, 1)) Then
          Break
        Endif
        If !instr(1, "()0123456789", mid$(SZVALEUR, ITER2, 1)) Then
          ICRICOUNT += 1
        Endif
        ITER2 += 1
      Wend
      If !ICRICOUNT Then
        #Il manque un ou plusieurs opérateurs.
        GMESSAGE = mess(521,196,1)    
        GERR = 1
        ICANCREMOD = 0
        Break
      Endif
      ITER = ITER2 - 1
    Endif
    ITER += 1
  Wend
  If ICANCREMOD = 0 Then
    End
  Endif
  #Vérifie qu'un opérateur n'est pas placé entre un numéro de critère et une parenthèse
  ITER = 1
  ITER2 = 0
  #Contrôle d'un opérateur entre une parenthèse et un numéro
  While ITER < len(SZVALEUR)
    If instr(1, "((((", mid$(SZVALEUR, ITER, 1)) Then
      ITER2 = ITER + 1
      If !instr(1, "(0123456789", mid$(SZVALEUR, ITER2, 1)) Then
        #Certains opérateurs sont placés de manière incorrecte.
        GMESSAGE = mess(522,196,1)    
        GERR = 1
        ICANCREMOD = 0
        Break
      Endif
    Endif
    ITER += 1
  Wend
  If ICANCREMOD = 0 Then
    End
  Endif
  ITER = 1
  ITER2 = 0
  #Contrôle d'un opérateur entre un numéro et une parenthèse
  While ITER < len(SZVALEUR)
    If instr(1, "))))", mid$(SZVALEUR, ITER, 1)) Then
      ITER2 = ITER - 1
      If !instr(1, ")0123456789", mid$(SZVALEUR, ITER2, 1)) Then
        #Certains opérateurs sont placés de manière incorrecte.
        GMESSAGE = mess(522,196,1)    
        GERR = 1
        ICANCREMOD = 0
        Break
      Endif
    Endif
    ITER += 1
  Wend
End

#####################################################################################
# Contrôle la saisie du tableau des critères et valeurs de critères.
#####################################################################################
Subprog GESNBCRI(INOL)
Value Integer INOL

  If GCRIDIRTY Then
    Call SAVECRIVAL([M:MGG0]QURNUM, [M:MGG2]PPLORDX, [M:MGG2]CRINUM(GPRECRINOL)) From TRTMGG
  Endif
  If INOL > dim([M:MGG2]CRINUM)-1 Then
    End
  Endif
  If [M:MGG2]CRINUM(INOL) > 0 Then
    Call LOADCRIVAL([M:MGG0]QURNUM, [M:MGG2]PPLORDX, [M:MGG2]CRINUM(INOL)) From TRTMGG
  Else
    Raz [M:MGG2]NBOCC
    Raz [M:MGG2]CRIVAL
    Raz [M:MGG2]CRIVALNUM
    Raz [M:MGG2]CRIVALDAT
  Endif
  Affzo [M:MGG2]15
End

#####################################################################################
# Contrôle la saisie du tableau des critères et valeurs de critères.
#####################################################################################
Subprog GESNBPPL(INOL)
Value Integer INOL

  If GPPLDIRTY Then
    Call SAVECRI([M:MGG0]QURNUM, [M:MGG1]PPLORD(GPREMGG1NOL)) From TRTMGG
  Endif
  If INOL > dim([M:MGG1]PPLSELSPT)-1 Then
    End
  Endif
  If [M:MGG1]PPLORD(INOL) > 0 Then
    Call LOADCRI([M:MGG0]QURNUM, [M:MGG1]PPLORD(INOL)) From TRTMGG
  Else
    Raz [M:MGG2]NBCRI
    Raz [M:MGG2]NBCRISEL
    Raz [M:MGG2]CRIOPD
    Raz [M:MGG2]CRITAB
    Raz [M:MGG2]CRIFIE
    Raz [M:MGG2]CRICND
    Raz [M:MGG2]CRINUM
    Raz [M:MGG2]CRIFIETYP
    Raz [M:MGG2]NBOCC
    Raz [M:MGG2]CRIVAL
    Raz [M:MGG2]CRIVALNUM
    Raz [M:MGG2]CRIVALDAT
  Endif
  Affzo [M:MGG2]10
  Affzo [M:MGG2]15
End

#####################################################################
#  Renseigne la définition des groupes de critère
#####################################################################
Subprog SETCRIGRU
Local Integer IQ
Local Integer ILINNUM
Local Integer ILIGNE

  IQ = 0
  ILINNUM = 0
  ILIGNE = 0
  #Test si l'on est en insertion.
  If nolign > 1 Then
    If nolign > [M:MGG2]NBCRI Then
      IINSERT = 0
    Else
      IINSERT = 1
    Endif
  Else
    If [M:MGG2]NBCRI = nolign-1 Then
      IINSERT = 0
    Else
      IINSERT = 1
    Endif
  Endif
  If IINSERT Then
    ILIGNE = [M:MGG2]NBCRI-1
  Else
    ILIGNE = [M:MGG2]NBCRI
  Endif
  If [M:MGG2]NBCRI < 1 Then
    [M:MGG2]CRIGRUDIO = "(1)"
    End
  Endif
  [M:MGG2]CRIGRUDIO = "("
  For IQ = 0 To ILIGNE
    ILINNUM = IQ + 1
    If ILINNUM > 1 Then
      Case [M:MGG2]CRIOPD(IQ)
        When 1
          [M:MGG2]CRIGRUDIO = [M:MGG2]CRIGRUDIO - mess(2,2959,1) - num$(ILINNUM)
        When 2
          [M:MGG2]CRIGRUDIO = [M:MGG2]CRIGRUDIO - mess([M:MGG2]CRIOPD(IQ),2959,1) - num$(ILINNUM)
        When 3
          [M:MGG2]CRIGRUDIO = [M:MGG2]CRIGRUDIO + ")" - mess([M:MGG2]CRIOPD(IQ),2959,1) - "(" + num$(ILINNUM)
        When 4
          [M:MGG2]CRIGRUDIO = [M:MGG2]CRIGRUDIO - mess([M:MGG2]CRIOPD(IQ),2959,1) - num$(ILINNUM)
        When 5
          [M:MGG2]CRIGRUDIO = [M:MGG2]CRIGRUDIO + ")" - mess([M:MGG2]CRIOPD(IQ),2959,1) - "(" + num$(ILINNUM)
        When Default
      Endcase
    Else
      [M:MGG2]CRIGRUDIO = [M:MGG2]CRIGRUDIO + num$(ILINNUM)
    Endif
  Next
  [M:MGG2]CRIGRUDIO = [M:MGG2]CRIGRUDIO + ")"
End

#####################################################################
#  Renseigne la définition des groupes de critère lors d'un nombre de ligne érroné.
#####################################################################
Subprog SETCRIGRU2(INBLIGNE)
Value Integer INBLIGNE

Local Integer IQ
Local Integer ILINNUM

  IQ = 0
  ILINNUM = 0
  If INBLIGNE < 1 Then
    [M:MGG2]CRIGRUDIO = ""
    End
  Endif
  [M:MGG2]CRIGRUDIO = "("
  For IQ = 0 To INBLIGNE-1
    ILINNUM = IQ + 1
    If ILINNUM > 1 Then
      Case [M:MGG2]CRIOPD(IQ)
        When 1
          [M:MGG2]CRIGRUDIO = [M:MGG2]CRIGRUDIO - mess(2,2959,1) - num$(ILINNUM)
        When 2
          [M:MGG2]CRIGRUDIO = [M:MGG2]CRIGRUDIO - mess([M:MGG2]CRIOPD(IQ),2959,1) - num$(ILINNUM)
        When 3
          [M:MGG2]CRIGRUDIO = [M:MGG2]CRIGRUDIO + ")" - mess([M:MGG2]CRIOPD(IQ),2959,1) - "(" + num$(ILINNUM)
        When 4
          [M:MGG2]CRIGRUDIO = [M:MGG2]CRIGRUDIO - mess([M:MGG2]CRIOPD(IQ),2959,1) - num$(ILINNUM)
        When 5
          [M:MGG2]CRIGRUDIO = [M:MGG2]CRIGRUDIO + ")" - mess([M:MGG2]CRIOPD(IQ),2959,1) - "(" + num$(ILINNUM)
        When Default
      Endcase
    Else
      [M:MGG2]CRIGRUDIO = [M:MGG2]CRIGRUDIO + num$(ILINNUM)
    Endif
  Next
  [M:MGG2]CRIGRUDIO = [M:MGG2]CRIGRUDIO + ")"
End

############################################################################################
#Contrôle de la présence de condition Compris entre avec une seule valeur de critère
############################################################################################
Subprog CTLCND10(SZQURNUM, ICANSV)
Value Char SZQURNUM
Variable Integer ICANSV

Local Integer INBCRIVAL

  INBCRIVAL = 0
  Filter [QCR] Where [F:QCR]QURNUM = SZQURNUM and [F:QCR]CRICND = 10
  For [QCR]QCR2
    INBCRIVAL = 0
    Filter [QCV] Where [F:QCV]QURNUM = [F:QCR]QURNUM and [F:QCV]PPLORD = [F:QCR]PPLORD and [F:QCV]CRINUM = [F:QCR]CRINUM
    For [QCV] QCV1
      INBCRIVAL += 1
    Next
    Filter [QCV]
    If INBCRIVAL = 1 Then
      ICANSV = 0
      Break
    Endif
  Next
  Filter [QCR]
End
