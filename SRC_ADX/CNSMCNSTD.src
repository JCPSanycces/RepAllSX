#<AdxTL>@(#)5.0.0.0 $Revision$
#############################################################################################################
# Consultation du parc client.                                          Module CRM          17 novembre 2000.
#############################################################################################################
#############################################################################################################
$ACTION
  Case ACTION
    When "AUTORIS"    : Gosub AUTORIS
    When "FERME"      : Gosub FERME
    When "OUVRE"      : Gosub OUVRE
    When "LECTURE"    : Gosub LECTURE
    When "AV_MAGNETO" : Gosub AV_MAGNETO
    When "SET_DERLU"  : Gosub SET_DERLU
    When "SETBOUT"    : Gosub SETBOUT
    When "DEB_CRIT"   : Gosub DEB_CRIT
    When "FIN_CRIT"   : Gosub FIN_CRIT
    When default
  Endcase
Return

#############################################################################################################
$AUTORIS
Return

#############################################################################################################
$OUVRE
Global Char GSZMCNBRACLA
Local Char SZTXTNUM

  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
  If !clalev([F:COT]) : Local File CONTTEMPL [COT] : Endif
  [M:MCN1]CCNNUM = PARAM(1)
  [M:MCN1]BPCNUM = ""
  GSZMCNBRACLA = ""
  #Obtention du libellé du champ Marque
  Call PARAM("", "MACBRAUSE", SZTXTNUM) From ADOVAL
  Call TEXTE(val(SZTXTNUM), GSZMCNBRACLA) From OBJDIV
  If GSZMCNBRACLA = "" Then
    Call TEXTE(14543, GSZMCNBRACLA) From OBJDIV
  Endif
  NAVIG = "CONSMCN"
Return

#############################################################################################################
$FERME
  Kill GSZMCNBRACLA
Return

#############################################################################################################
$LECTURE
Local Integer IADINUM

  IADINUM = 19 + GFAMCIA
  #-- Changement d'écran paramétrable
  Gosub CHANGE_MSK From GCONSULT 
  #Affiche le nom de l'interlocuteur en en-tête.
  Read [AIN]AIN0=[M:MCN1]CCNNUM
  If fstat Then
    [M:MCN1]CCNCLA = [M:MCN1]CCNNUM
  Else
    Call BUILDFULNAM("AIN", [M:MCN1]CCNCLA) From CRMUTIL140
  Endif
  Raz [M:MCN2]
  [M:MCN2]NBLIG  = 0
  Filter [MAC] Where [F:MAC]MACITNTYP=1 and [F:MAC]CCNNUM=[M:MCN1]CCNNUM Order By [F:MAC]MACNUM Desc
  nolign = 0
  For [MAC]
    If [M:MCN2]NBLIG >= dim([M:MCN2]MACQTY)-1 Then
      #L'ensemble du parc n'a pas pu être totalement affiché dans la consultation.
      GMESSAGE = mess(39,177,1)
      GERR = 2
      Break
    Endif
    nolign += 1
    [M:MCN2] = [F:MAC]
    #Gestion des compléments au transclass
    Gosub ADDCPLTOTC
    [M:MCN2]NBLIG += 1
  Next
  Filter [MAC]
Return

#############################################################################################################
$AV_MAGNETO
Return

#############################################################################################################
$SET_DERLU
Return

#############################################################################################################
$SETBOUT
Return

#############################################################################################################
$DEB_CRIT
Return

#############################################################################################################
$FIN_CRIT
Return

#############################################################
# Complément au transclass sans agrégation
#############################################################
#############################################################################################################
$ADDCPLTOTC
  #Affiche la famille commerciale et la garantie applicable
  If [F:MAC]MACPDTCOD = "" Then
    [M:MCN2]MACFAMCIA(nolign-1) = ""
    [M:MCN2]MACWARTYP(nolign-1) = ""
    [M:MCN2]MACFAMCIAC(nolign-1) = ""
    [M:MCN2]MACWARTYPC(nolign-1) = ""
  Else
    Read [ITM]ITM0=[F:MAC]MACPDTCOD
    If fstat Then
      [M:MCN2]MACFAMCIA(nolign-1) = ""
      [M:MCN2]MACWARTYP(nolign-1) = ""
      [M:MCN2]MACFAMCIAC(nolign-1) = ""
      [M:MCN2]MACWARTYPC(nolign-1) = ""
    Else
      [M:MCN2]MACFAMCIAC(nolign-1) = [F:ITM]TSICOD(GFAMCIA-1)
      Call GET_LIB(IADINUM, [F:ITM]TSICOD(GFAMCIA-1), [M:MCN2]MACFAMCIA(nolign-1)) From CRM_UTIL
      If [F:MAC]MACITNLND = 2 Then
        #Parc en prêt
        If [F:ITM]TPLCONLND = "" Then
          [M:MCN2]MACWARTYP(nolign-1) = ""
          [M:MCN2]MACWARTYPC(nolign-1) = ""
        Else
          Read [COT]COT0=[F:ITM]TPLCONLND
          If fstat Then
            [M:MCN2]MACWARTYPC(nolign-1) = ""
            [M:MCN2]MACWARTYP(nolign-1) = ""
          Else
            [M:MCN2]MACWARTYP(nolign-1) = [F:COT]TPLNAM
            [M:MCN2]MACWARTYPC(nolign-1) = [F:COT]CONNUM
          Endif
        Endif
      Else
        #Parc acheté
        If [F:ITM]TPLCONGUA = "" Then
          [M:MCN2]MACWARTYP(nolign-1) = ""
          [M:MCN2]MACWARTYPC(nolign-1) = ""
        Else
          Read [COT]COT0=[F:ITM]TPLCONGUA
          If fstat Then
            [M:MCN2]MACWARTYP(nolign-1) = ""
            [M:MCN2]MACWARTYPC(nolign-1) = ""
          Else
            [M:MCN2]MACWARTYP(nolign-1) = [F:COT]TPLNAM
            [M:MCN2]MACWARTYPC(nolign-1) = [F:COT]CONNUM
          Endif
        Endif
      Endif
    Endif
  Endif
  #Marque en clair
  Call GET_LIB(408, [F:MAC]MACBRA, [M:MCN2]MACBRACLA(nolign-1)) From CRM_UTIL
  #Utilisateur final en clair
  [M:MCN2]CUTBPCCLA(nolign-1) = ""
  If [F:MAC]CCNNUM <> "" Then
    Read [AIN]AIN0=[F:MAC]CCNNUM
    If !fstat Then
      Call BUILDFULNAM("AIN", [M:MCN2]CUTBPCCLA(nolign-1)) From CRMUTIL140
    Endif
  Endif
Return

# FQ 57754 Module Support client GA 10/2009
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(12)<>2 End Endif

Call VALGTC(APPLI,"MCN") From SUBGTC

End
