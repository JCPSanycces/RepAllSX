#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTITRC04   Suppression du browser MDT            Module Tronc commun   #
#            dans la fenêtre OMDT                                        #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Deletion of the hierarchical list in the mandates function") From LECFIC

  Call MAJ_UTITRC04(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTITRC04(DOSSIER)
Value Char DOSSIER
Local Integer I, OK
Call ECR_TRACE("UTITRC04 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:AWB])  =0  Local File =DOSSIER+".AWINBRO"   [AWB] : Endif
If clalev([F:ACV])  =0  Local File =DOSSIER+".ACTIV"     [ACV] : Endif

Read [ACV]CODACT="SDD"
If fstat | [F:ACV]FLACT<>2
 Call ECR_TRACE("UTITRC04 : SDD disable Process End on : "+DOSSIER,0) From GESECRAN
 Close Local File [AWB],[ACV]
 End
Endif

Call DEBTRANS From GLOCK
OK = 0

Trbegin [AWB]
 Readlock [AWB]="OMDT"
 If fstat
  Call ECR_TRACE(mess(58,134,1)-"AWINBRO"+DOSSIER,1) From GESECRAN
 Else
  For I=0 To [F:AWB]NBLIS-1
   If OBJLIS(I)="MDT"
    Raz [F:AWB]OBJLIS(I), [F:AWB]INTLIS(I), [F:AWB]CLELIS(I), [F:AWB]ORDLIS(I), [F:AWB]TRELIS(I), [F:AWB]BROLIS(I)
    Raz [F:AWB]CHGLIS(I), [F:AWB]ABRLIS(I), [F:AWB]FLELIS(I), [F:AWB]ACTLIS(I), [F:AWB]EXPLIS(I), [F:AWB]ROWLIS(I)
    OK = 1
   Elsif OK
    [F:AWB]OBJLIS(I-1) = [F:AWB]OBJLIS(I)
    [F:AWB]INTLIS(I-1) = [F:AWB]INTLIS(I)
    [F:AWB]CLELIS(I-1) = [F:AWB]CLELIS(I)
    [F:AWB]ORDLIS(I-1) = [F:AWB]ORDLIS(I)
    [F:AWB]TRELIS(I-1) = [F:AWB]TRELIS(I)
    [F:AWB]BROLIS(I-1) = [F:AWB]BROLIS(I)
    [F:AWB]CHGLIS(I-1) = [F:AWB]CHGLIS(I)
    [F:AWB]ABRLIS(I-1) = [F:AWB]ABRLIS(I)
    [F:AWB]FLELIS(I-1) = [F:AWB]FLELIS(I)
    [F:AWB]ACTLIS(I-1) = [F:AWB]ACTLIS(I)
    [F:AWB]EXPLIS(I-1) = [F:AWB]EXPLIS(I)
    [F:AWB]ROWLIS(I-1) = [F:AWB]ROWLIS(I)
    Raz [F:AWB]OBJLIS(I), [F:AWB]INTLIS(I), [F:AWB]CLELIS(I), [F:AWB]ORDLIS(I), [F:AWB]TRELIS(I), [F:AWB]BROLIS(I)
    Raz [F:AWB]CHGLIS(I), [F:AWB]ABRLIS(I), [F:AWB]FLELIS(I), [F:AWB]ACTLIS(I), [F:AWB]EXPLIS(I), [F:AWB]ROWLIS(I)
   Endif
  Next
  If OK
   [F:AWB]NBLIS -=1
   Rewrite [AWB]
   If !fstat
    Call ECR_TRACE("MDT browser deleted in the AWINBRO table "+DOSSIER,0) From GESECRAN
   Endif
  Endif
 Endif
Commit

Close Local File [AWB], [ACV]
If OK=1
 Call VALID("OMDT",DOSSIER,1,OK) From VALWIN
Else
 Call ECR_TRACE("No browser deleted "+DOSSIER,0) From GESECRAN
Endif
Call ECR_TRACE("UTITRC04 : Process End on : "+DOSSIER,0) From GESECRAN

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(8)<>2 : End : Endif
If filinfo(filpath("FIL","AWINBRO","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTITRC04(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If [F:ADS]MODULE(8)<>2 : End : Endif
If filinfo(filpath("FIL","AWINBRO","fde",APPLI),0)<=0 : End : Endif
Call MAJ_UTITRC04(APPLI)
End
