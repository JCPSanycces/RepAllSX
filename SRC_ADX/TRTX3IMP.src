#<AdxTL>@(#)6.0.0.0 $Revision$
###########################################################################
#                    TRAITEMENTS COMMUN IMPORT X3               V140      #
# IMP_DECLARE                                                             #
#     Déclaration des variables                                           #
# RECHERCHE_LIGNE                                                         #
#     Reconnaissance d'une ligne importée dans le tableau des lignes      #
# ECR_TEXTE                                                               #
#     Import un texte stocké en format txt (8 lignes maxi)                #
# EXP_TEXTE                                                               #
#     Export un texte stocké en format txt (8 lignes maxi)                #
# IMP_CORRESP                                                             #
#     Table de correspondance de noms entre table et ecran                #
#     (uniquement pour masques à double stockage)                         #
# IMP_CPL                                                                 #
#     Complement d'import (pour garnir champs non saisissables en [M]     #
#     Generation traitements CPL_FICMSK et CPL_MSKFIC dans WWIxxxxxx      #
#       qui garni la classe [M:JJJx] à partir de la classe [F] puis       #
#       restitue [M:JJJx] dans [F]                                        #
#       Dans IMP_TRTSUP faire  Gosub IMP_CPL From TRTX3IMP                #
#    et Dans IMP_FERME faire  Gosub IMP_FIN_CPL From TRTX3IMP             #
#     Appel de CPL_FICMSK dans IMP_ZONE et/ou IMP_TAB sur le dernier      #
#       champ saisissable                                                 #
#       IMPFICCPL="xxx" : Gosub CPL_FICMSK From G_NOMTRT                  #
#       Chargement dans [M:JJJ]des champs IMPFICCPL (exemple: "SOH")      #
#       (Chaque masque de l'objet est ouvert sous JJJx)                   #
#     Appel de CPL_MSKFIC                                                 #
#       transfert de [M:JJJx] dans [F] et dans [M] de l'objet             #
#       dans action standard IMP_INICRE ou IMP_INIMOD pour entête         #
#       dans action INICRE_LIG ou INIMOD_LIG depuis le SUBxxx             #
# IMP_ZON_BPA                                                             #
#       Action IMP_ZON pour la gestion des adresses                       #
#               commun à IMPBPR IMPBPC IMPBPS IMPREP IMPBPP               #
# IMP_ZON_CNT                                                             #
#       Action IMP_ZON pour la gestion des contacts                       #
#               commun à IMPBPR IMPBPC IMPBPS IMPBPP                      #
# IMP_ZON_RIB                                                             #
#       Action IMP_ZON pour la gestion des ribs                           #
#               commun à IMPBPR IMPBPC IMPBPS                             #
# SETMODE_ON                                                              #
#   Positionne un contexte d'import pour les instructions d'affichage     #
#       Permet la prise en compte des instructions diszo,actzo            #
#       Inhibe les instructions d'affichage                               #
# SETMODE_OFF                                                             #
#   Dépositionne un contexte d'import pour les instructions d'affichage   #
#       Permet les instructions d'affichage  (ex infbox)                  #
#                                                                         #
###########################################################################
# Issue X3-68810 - 20180111 by LD : Wrong lines updated in order modification by import.

###########################################################################

# -------------------------------------------------------------- #
# Déclaration des variables                                      #
# -------------------------------------------------------------- #
$IMP_DECLARE
Local Char    ICLEPRIM(30)(0..8) : # Liste clés primaires     (nom ds fichier)
Local Char    ICLESEC (30)(0..8) : # Liste clés secondaires 1 (nom ds fichier)
Local Char    ICLESEC2(30)(0..8) : # Liste clés secondaires 2 (nom ds fichier)
Local Integer ICLEBRK     (0..8) : # Indicateur arrêt recherche
                                   # (arrêt si =1 et cle paramétrée)
Local Char    TPRIM   (30)(0..8) : # Liste clés primaires     (nom ds tableau)
Local Char    TSEC    (30)(0..8) : # Liste clés secondaires 1 (nom ds tableau)
Local Char    TSEC2   (30)(0..8) : # Liste clés secondaires 2 (nom ds tableau)
Local Char    NBASTAB (30)       : # Nom de la variable de bas de tableau
Return

# -------------------------------------------------------------- #
# Reconnaissance d'une ligne importée dans le tableau des lignes #
# -------------------------------------------------------------- #
# ATTENTION : Penser à reporter les modifications dans IMPETATS  #
# -------------------------------------------------------------- #
$RECHERCHE_LIGNE
Local Char    NCLEPRIM(30), NCLESEC(30), NCLESEC2(30)
Local Char    TABCHPP (30), TABCHPS(30), TABCHPS2(30), NCLEFIC(3),   NCLEZONFIC(30)
Local Integer ICLE, K, I, TYP
Local Char    ACTLIG(30) : ACTLIG = ""                                                             # FGR 28/04/2015 : X3SUIVI107901 pas rien
Local Integer NIVREC : # Niveau de recherche : (0,1,2,3)
Local Integer BASTAB : # Nbre de lignes ds le tableau
For ICLE = 0 To dim(ICLEPRIM)-1
# #-------------------------------#
# # Traitement de la clé primaire #
# #-------------------------------#
  If ICLEPRIM(ICLE) <> ""
# Possibility to have more than 3 char in the abreviation (CCC modification done for 115658)
#    If left$(ICLEPRIM(ICLE), 1) = "["
##     #--- On donne l'abréviation du fichier ---#
#      NCLEFIC    = mid$(ICLEPRIM(ICLE), 4,3)
#      NCLEZONFIC = mid$(ICLEPRIM(ICLE), 8,23)
#      K = find(NCLEFIC-NCLEZONFIC,[M:AOE2]ZONE(0..[M:AOE2]NBRLIG-1))
#    Else
##     #--- On ne donne pas l'abréviation du fichier ---#
#      K = find (ICLEPRIM(ICLE), [M:AOE2]FLD(0..[M:AOE2]NBRLIG-1))
#    Endif
#    If K <> 0
##     #--- La clé est paramétrée : Recherche du nom de la clé ---#
#      #NCLEPRIM = "[F:"+left$([M:AOE2]ZONE(K-1), 3)+"]"+[M:AOE2]FLD(K-1)
#      I = instr(1,[M:AOE2]ZONE(K-1)," ")-1
#      NCLEPRIM = "[F:"+left$([M:AOE2]ZONE(K-1), I)+"]"+[M:AOE2]FLD(K-1)
    NCLEPRIM = func GETFLD(ICLEPRIM(ICLE))
    If NCLEPRIM<>""
      TYP=evalue ("type("+NCLEPRIM+")")
      If (TYP>10 & evalue(NCLEPRIM)<>"") or (TYP=3 & evalue(NCLEPRIM)<>[0/0/0])
&     or (TYP<11 & TYP<>3 & evalue(NCLEPRIM)<>0)
#       #--- Recherche nom du champs dans le tableau : nom différent ---#
        If TPRIM(ICLE) <> ""
          TABCHPP = TPRIM(ICLE)
#       #--- Recherche nom du champs dans le tableau : même nom que la clé ---#
        Else
          TABCHPP = ICLEPRIM(ICLE)
        Endif
#       #--- Positionnement du niveau de recherche ---#
        NIVREC=1
#       #--------------------------------------#
#       # Traitement de la 1ère clé secondaire #
#       #--------------------------------------#
        If ICLESEC(ICLE) <> ""
# Possibility to have more than 3 char in the abreviation
#         #--- Il y a une clé secondaire 1 à vérifier ---#
#          If left$(ICLEPRIM(ICLE), 1) = "["
##           #--- On donne l'abréviation du fichier ---#
#            NCLEFIC    = mid$(ICLESEC(ICLE), 4,3)
#            NCLEZONFIC = mid$(ICLESEC(ICLE), 8,23)
#            K = find(NCLEFIC-NCLEZONFIC,[M:AOE2]ZONE(0..[M:AOE2]NBRLIG-1))
#          Else
##           #--- On ne donne pas l'abréviation du fichier ---#
#            K = find (ICLESEC(ICLE), [M:AOE2]FLD(0..[M:AOE2]NBRLIG-1))
#          Endif
#          If K <> 0
##           #--- Recherche du nom de la clé ---#
#            NCLESEC = "[F:"+left$([M:AOE2]ZONE(K-1), 3)+"]"+[M:AOE2]FLD(K-1)
          NCLESEC = func GETFLD(ICLESEC(ICLE))
          If NCLESEC<>""
            TYP=evalue ("type("+NCLESEC+")")
            If (TYP>10 & evalue(NCLESEC)<>"") or (TYP=3 & evalue(NCLESEC)<>[0/0/0])
&           or (TYP<11 & TYP<>3 & evalue(NCLESEC)<>0)
#             #--- Recherche nom du champs dans le tableau : nom différent ---#
              If TSEC(ICLE) <> ""
                TABCHPS = TSEC(ICLE)
#             #--- Recherche nom du champs dans le tableau : même nom que la clé ---#
              Else
                TABCHPS = ICLESEC(ICLE)
              Endif
#             #--- Positionnement du niveau de recherche ---#
              NIVREC = 2
#             #--------------------------------------#
#             # Traitement de la 2ème clé secondaire #
#             #--------------------------------------#
              If ICLESEC2(ICLE) <> ""
# Possibility to have more than 3 char in the abreviation
#             #--- Il y a une clé secondaire 2 à vérifier ---#
#                If left$(ICLEPRIM(ICLE), 1) = "["
##                 #--- On donne l'abréviation du fichier ---#
#                  NCLEFIC    = mid$(ICLESEC2(ICLE), 4,3)
#                  NCLEZONFIC = mid$(ICLESEC2(ICLE), 8,23)
#                  K = find(NCLEFIC-NCLEZONFIC,[M:AOE2]ZONE(0..[M:AOE2]NBRLIG-1))
#                Else
##                 #--- On ne donne pas l'abréviation du fichier ---#
#                  K = find (ICLESEC2(ICLE), [M:AOE2]FLD(0..[M:AOE2]NBRLIG-1))
#                Endif
#                If K <> 0
##                 #--- Recherche du nom de la clé ---#
#                  NCLESEC2 = "[F:"+left$([M:AOE2]ZONE(K-1), 3)+"]"+[M:AOE2]FLD(K-1)
                NCLESEC2 = func GETFLD(ICLESEC2(ICLE))
                If NCLESEC2<>""
                  TYP=evalue ("type("+NCLESEC2+")")
                  If (TYP>10 & evalue(NCLESEC2)<>"") or (TYP=3 & evalue(NCLESEC2)<>[0/0/0])
&                 or (TYP<11 & TYP<>3 & evalue(NCLESEC2)<>0)
#                   #--- Recherche nom du champs dans le tableau : nom différent ---#
                    If TSEC2(ICLE) <> ""
                      TABCHPS2 = TSEC2(ICLE)
#                   #--- Recherche nom du champs dans le tableau : même nom que la clé ---#
                    Else
                      TABCHPS2 = ICLESEC2(ICLE)
                    Endif
#                   #--- Positionnement du niveau de recherche ---#
                    NIVREC = 3
#                 #-- La clé secondaire 2 n'est pas renseignée : On stoppe la recherche --#
                  Else
                    NIVREC = 0
                  Endif
                Endif
              Endif
#           #--- La clé secondaire 1 n'est pas renseignée : On stoppe la recherche ---#
            Else
              NIVREC = 0
            Endif
          Endif
        Endif
        If NIVREC <> 0
          BASTAB = evalue ("[M]"+NBASTAB)
          For I=0 To BASTAB - 1
#           #--- Recherche dans le tableau ---#
            If evalue (NCLEPRIM) = evalue ("[M]"+TABCHPP+"(I)")
#             #--- On a trouve la ligne avec la cle primaire ---#
              If NIVREC > 1
                If evalue(NCLESEC) = evalue ("[M]"+TABCHPS+"(I)")
#                 #--- On a trouvé la ligne avec la cle secondaire 1 ---#
                  If NIVREC = 3
                    If evalue(NCLESEC2) = evalue ("[M]"+TABCHPS2+"(I)")
#                     #--- On a trouvé la ligne avec la cle secondaire 2 ---#
                      ACTLIG = "M" : nolign = I+1
                    Endif
                  Else
                    ACTLIG = "M" : nolign = I+1
                  Endif
                Endif
              Else
                ACTLIG = "M" : nolign = I+1
              Endif
            Endif
            If ACTLIG = "M" Break 2 : Endif
          Next
          If ICLE=0 | ICLEBRK(ICLE)=1 : Break : Endif
        Endif
      Endif
    Endif
  Endif
Next
Return

#**----------------------------------------------------------------<br/>
#* GETFLD : Check if a field is in the import template and then return the name of the field like with file abreviation ([F:XXX]FFFFFF)
#**<br/>----------------------------------------------------------------<br/>
#* @param FLD = Fields to find (can be "FFFFFF" or [XXX]FFFFFF or [F:XXXX]FFFFFF
#* @return [F:XXXX]FFFFFF if the field FFFFFF is in the template ([M:AOE2] has to be filled before to call this function)
#**<br/>----------------------------------------------------------------
#*!
Funprog GETFLD(FLD)
Value Char FLD

Local Integer I,K

    If left$(FLD, 1) = "["
#     #--- On donne l'abréviation du fichier ---#
      I = instr(1,FLD,"]")
      If left$(FLD,3)="[F:"
          NCLEFIC    = mid$(FLD,4,I-4)
      Else
          NCLEFIC    = mid$(FLD,2,I-2)
      Endif

      NCLEZONFIC = right$(FLD, I+1)
      K = find(NCLEFIC-NCLEZONFIC,[M:AOE2]ZONE(0..[M:AOE2]NBRLIG-1))
    Else
#     #--- On ne donne pas l'abréviation du fichier ---#
      K = find (FLD, [M:AOE2]FLD(0..[M:AOE2]NBRLIG-1))
    Endif
    If K <> 0
#     #--- La clé est paramétrée : Recherche du nom de la clé ---#
      I = instr(1,[M:AOE2]ZONE(K-1)," ")-1
      End "[F:"+left$([M:AOE2]ZONE(K-1), I)+"]"+[M:AOE2]FLD(K-1)
    Endif
End ""

#######################################################################
# Import une ligne en creation modif suppression                      #
#######################################################################
Subprog TRT_LIGNE (TRT,LIGNE,NBLIG,TSTFULL)
Value    Char    TRT        : # (C)reate / (U)pdate / (D)elete
Variable Integer LIGNE      : # no de ligne (nolign)
Variable Char    NBLIG      : # variable Bas Tableau
Value    Char    TSTFULL    : # Nom champ pour test tableau plein

If TRT="C" & NBLIG>= evalue ("dim([M]"+TSTFULL+")")
   If GTRACE<>""
      Call ECR_TRACE(mess(26,100,1)-num$(NBLIG),1) From GESECRAN
   Endif
Endif
If TRT="C" & LIGNE=0
   NBLIG +=1 : LIGNE=NBLIG : status=73
Elsif TRT="U"
   status=75
Endif
If TRT="D"
#
Endif

End


#######################################################################
#
#     Import / Export  des Textes Clob ( TXT ou RTF )
#
#######################################################################

# ---------------------------------------------------------------------
# Declaration des variables pour Import Export des textes
# devant etre renseignées dans IMPxxx avant appel OUVRE_TEXTE
# (les variables utilisees dans SAIMSK doivent etre en Global)
# ---------------------------------------------------------------------
$DECLARE_TEXTE

Global Integer G_IMPORT, G_EXPORT
Local  Char    TSTCHAMP (30) (0..180) : # test presence dans paramétrage (ex: SOH*71)              # FGR 28/04/2015 : X3SUIVI107901 pas (10)
Return

# ---------------------------------------------------------------------
# Ouverture Import Export de texte
# (les variables utilisees dans SAIMSK doivent etre en Global)
# ---------------------------------------------------------------------

$OUVRE_TEXTE

Global Integer G_ENT, G_PIE, G_DET
Global Integer G_TX11, G_TX12, G_TX13, G_TX21, G_TX22, G_TX23, G_TX31, G_TX32, G_TX33
Global Integer G_TX41, G_TX42, G_TX43, G_TX51, G_TX52, G_TX53
Global Integer G_NLDET                : # texte autorise uniquement en creation mais
                                        # permis en ajout une nouvelle ligne detail
Global Char    T_TXT     (5)

Global Char    G_NUM_CLOB (50)        : # nom complet du champ lien contenant la clé
Global Char    G_CLE_CLOB (GLONTXC)   : # no du texte clob
Global Char    G_ZON_CLOB (50)        : # nom du champ contenant le texte
Global Char    G_ID_RTF(30)           : # identifiant texte rtf                                    # FGR 28/04/2015 : X3SUIVI107901 pas rien
G_ID_RTF  ="{\urtf"

Local Integer IT1, IT2, IT3, IT4, IATB
Local Char    TSTFIC  (5)
Local Char    TSTGIMP (5)
Local Integer OKCHAMP
Local Char FILORI (250)

# --- pour les 3 textes possibles (entete, pied, detail)
Raz IT3
For IT1=0 To dim(TSTCHAMP)-1
  IT2=instr (1,TSTCHAMP(IT1),"*")
  If IT2
    TSTFIC =left$(TSTCHAMP(IT1),IT2-1)
    TSTGIMP=right$(TSTCHAMP(IT1),IT2)
    If TSTFIC<>""
      Call TST_CHAMP(TSTFIC,TSTGIMP,OKCHAMP) From SUBIMPOBJ
      If OKCHAMP

        Case IT1
          When   1,   2,   3,   4,   5,   6,   7,   8  : IT3=1 : G_ENT +=1
          When  11,  12,  13,  14,  15,  16,  17,  18  : IT3=1 : G_PIE +=1
          When  21,  22,  23,  24,  25,  26,  27,  28  : IT3=1 : G_DET +=1

          When  31,  32,  33,  34,  35,  36,  37,  38  : IT3=1 : G_TX11 +=1
          When  41,  42,  43,  44,  45,  46,  47,  48  : IT3=1 : G_TX12 +=1
          When  51,  52,  53,  54,  55,  56,  57,  58  : IT3=1 : G_TX13 +=1

          When  61,  62,  63,  64,  65,  66,  67,  68  : IT3=1 : G_TX21 +=1
          When  71,  72,  73,  74,  75,  76,  77,  78  : IT3=1 : G_TX22 +=1
          When  81,  82,  83,  84,  85,  86,  87,  88  : IT3=1 : G_TX23 +=1

          When  91,  92,  93,  94,  95,  96,  97,  98  : IT3=1 : G_TX31 +=1
          When 101, 102, 103, 104, 105, 106, 107, 108  : IT3=1 : G_TX32 +=1
          When 111, 112, 113, 114, 115, 116, 117, 118  : IT3=1 : G_TX33 +=1

          When 121, 122, 123, 124, 125, 126, 127, 128  : IT3=1 : G_TX41 +=1
          When 131, 132, 133, 134, 135, 136, 137, 138  : IT3=1 : G_TX42 +=1
          When 141, 142, 143, 144, 145, 146, 147, 148  : IT3=1 : G_TX43 +=1

          When 151, 152, 153, 154, 155, 156, 157, 158  : IT3=1 : G_TX51 +=1
          When 161, 162, 163, 164, 165, 166, 167, 168  : IT3=1 : G_TX52 +=1
          When 171, 172, 173, 174, 175, 176, 177, 178  : IT3=1 : G_TX53 +=1

        Endcase
      Endif
    Endif
  Endif
Next IT1

# --- si présent dans paramétrage d'import de texte
If IT3
#     ouverture table compteurs no de texte clob (si import)
  If G_IMPORT
    If !clalev([F:TCC]) : Local File TEXCPT [TCC] : Endif
  Endif
#     ouverture de ecran gestion des textes
  If !clalev([M:ITC]) : Local Mask IMPTXTCLOB [ITC] : Endif
Endif

Return

# ---------------------------------------------------------------------
# Import d'un texte
# ---------------------------------------------------------------------
# Prérequis
# ---------------------------------------------------------------------
# Import :
# - Texte dans classe [F] de la table
#   - G_ZON_CLOB="[M:XXX]YYYYY" (nom complet de la variable de type ACB)
#                               (en retour : ce champ contient le texte)
#                               (le chemin complet : nolign si necessaire)
#   - G_CLE_CLOB ne sera pas modifié
# - Classe [F] est un lien qui contient cle table TEXCLOB
#   - G_ZON_CLOB=""
#   - G_CLE_CLOB=""             (retour: Clé enregistrement TEXCLOB créé)
# ---------------------------------------------------------------------

$ECR_TEXTE

Local Integer IJ0
Local Integer J_CAR    : # indicateur fichier vide (0=vide)
Local Integer J_END    : # no derniere ligne a ecrire

#     variables pour recherche du numéro de texte
Local Integer WTEXSEQ
Local Integer WRETOUR
Local Char    WNUMTEX(30)                                                                          # FGR 28/04/2015 : X3SUIVI107901 pas rien

Raz G_CLE_CLOB

#   suppression des blancs en fin de ligne + recherche derniere ligne
#   (recherche de la derniere ligne en partant de la fin)
Raz J_CAR, J_END
For IJ0=dim([M:ITC]LIGGIMP)-1 To 0 Step -1
    [M:ITC]LIGGIMP(IJ0)=vireblc([M:ITC]LIGGIMP(IJ0),1)
    If [M:ITC]LIGGIMP(IJ0)<>"" : J_CAR=1 : Endif
    If !J_CAR : J_END=IJ0 : Endif
Next IJ0

If !J_CAR : Goto ET1 : Endif       : # pas de texte

#   ajout du crlf (0D0A) à chaque ligne sauf la derniere
For IJ0=0 To J_END-1
    If len([M:ITC]LIGGIMP(IJ0))<>99      : # Textes découpés pour des raisons techniques
       [M:ITC]LIGGIMP(IJ0) += chr$(13)
       [M:ITC]LIGGIMP(IJ0) += chr$(10)
    Endif
Next IJ0

Raz [M:ITC]TEXTE
Setlob [M:ITC]TEXTE With [M:ITC]LIGGIMP

If G_ZON_CLOB=""                   : # ecrire le texte dans TEXCLOB
   Call NUM_TXC(IMPFIC,WTEXSEQ,WRETOUR) From TRTX3TEX
   G_CLE_CLOB=IMPFIC+"~"+format$("N0:8#",num$(WTEXSEQ))
   If !clalev([F:TXC]) : Local File TEXCLOB [TXC] : Endif

   WADXLOG=adxlog
   If !WADXLOG : Trbegin [TXC] : Endif
   Raz [F:TXC]
   [F:TXC]CODE  =G_CLE_CLOB
   [F:TXC]TEXTE =[M:ITC]TEXTE
   [F:TXC]CREUSR=GUSER
   [F:TXC]CREDAT=date$
   [F:TXC]CRETIM=time
   Write [TXC]
   If !WADXLOG : Commit        : Endif

Else                               : # ecrire le texte dans le champ

   If evalue("dim("+G_ZON_CLOB+")")>0
      Assign G_ZON_CLOB With [M:ITC]TEXTE
   Endif

Endif

# ----------
$ET1
Raz [M:ITC]LIGGIMP

Return

# ---------- Chargement [M:ITC]LIGGIMP avec GIMP(71 à 78)
$IMP_T1
Raz [M:ITC]LIGGIMP
  [M:ITC]LIGGIMP(0)=GIMP(71) : [M:ITC]LIGGIMP(1)=GIMP(72) : [M:ITC]LIGGIMP(2)=GIMP(73)
  [M:ITC]LIGGIMP(3)=GIMP(74) : [M:ITC]LIGGIMP(4)=GIMP(75) : [M:ITC]LIGGIMP(5)=GIMP(76)
  [M:ITC]LIGGIMP(6)=GIMP(77) : [M:ITC]LIGGIMP(7)=GIMP(78)
  [M:ITC]NBGIMP=8
  Raz GIMP(71), GIMP(72), GIMP(73), GIMP(74), GIMP(75), GIMP(76), GIMP(77), GIMP(78)
Return

# ---------- Chargement [M:ITC]LIGGIMP avec GIMP(81 à 88)
$IMP_T2
Raz [M:ITC]LIGGIMP
  [M:ITC]LIGGIMP(0)=GIMP(81) : [M:ITC]LIGGIMP(1)=GIMP(82) : [M:ITC]LIGGIMP(2)=GIMP(83)
  [M:ITC]LIGGIMP(3)=GIMP(84) : [M:ITC]LIGGIMP(4)=GIMP(85) : [M:ITC]LIGGIMP(5)=GIMP(86)
  [M:ITC]LIGGIMP(6)=GIMP(87) : [M:ITC]LIGGIMP(7)=GIMP(88)
  [M:ITC]NBGIMP=8
  Raz GIMP(81), GIMP(82), GIMP(83), GIMP(84), GIMP(85), GIMP(86), GIMP(87), GIMP(88)
Return

# ---------- Chargement [M:ITC]LIGGIMP avec GIMP(91 à 98)
$IMP_T3
Raz [M:ITC]LIGGIMP
  [M:ITC]LIGGIMP(0)=GIMP(91) : [M:ITC]LIGGIMP(1)=GIMP(92) : [M:ITC]LIGGIMP(2)=GIMP(93)
  [M:ITC]LIGGIMP(3)=GIMP(94) : [M:ITC]LIGGIMP(4)=GIMP(95) : [M:ITC]LIGGIMP(5)=GIMP(96)
  [M:ITC]LIGGIMP(6)=GIMP(97) : [M:ITC]LIGGIMP(7)=GIMP(98)
  [M:ITC]NBGIMP=8
  Raz GIMP(91), GIMP(92), GIMP(93), GIMP(94), GIMP(95), GIMP(96), GIMP(97), GIMP(98)
Return


# ---------------------------------------------------------------------
# Export d'un texte
# ---------------------------------------------------------------------
# Prérequis
# ---------------------------------------------------------------------
# Export
# - Texte dans classe [F] de la table
#   - G_ZON_CLOB = "[F:XXX]YYYYY"   (nom complet de la variable)
#   - G_CLE_CLOB = ""
# - Classe [F] est un lien qui contient cle table TEXCLOB
#   - G_ZON_CLOB = ""
#   - G_CLE_CLOB = Clé de la table TEXCLOB
# - Z
# ---------------------------------------------------------------------

$EXP_TEXTE

Local Integer J_GIMP_LG   : # longueur du champ GIMP de import/export
Local Integer J_LF        : # si =1 --> LF (ligne suivante)
Local Integer J_COUPE     : #
Local Integer IJ0,IJ1,IJ2

If dim(GIMP)>0 : J_GIMP_LG=type(GIMP)-10 : Else : J_GIMP_LG=99 : Endif

If G_CLE_CLOB<>""
   If !clalev([F:TXC]) : Local File TEXCLOB [TXC] : Endif
   Read [TXC]TXC0=G_CLE_CLOB
   If fstat : Return : Endif
   G_ZON_CLOB="[F:TXC]TEXTE"
Endif

If !clalev ([M:ITC]) : Local Mask IMPTXTCLOB [ITC] : Endif
Raz [M:ITC]NBSLB, LIGSETLOB, NBGIMP, LIGGIMP, LIGWRK_O, LIGWRK_W, LIGWRK_D

[M:ITC]TEXTE=evalue(G_ZON_CLOB)                  : # chargement du clob dans masque
Setlob [M:ITC]LIGSETLOB  With [M:ITC]TEXTE       : # chargement du clob dans tableau
                                                 : # recherche si, texte en rtf
If instr(1,[M:ITC]LIGSETLOB(0),G_ID_RTF) : Raz [M:ITC]LIGSETLOB : Endif

[M:ITC]NBSLB=dim([M:ITC]LIGSETLOB)
For IJ0=dim([M:ITC]LIGSETLOB)-1 To 0 Step -1     : # nb de lignes occupées dans tableau
    If len([M:ITC]LIGSETLOB(IJ0))>0 : Break : Endif
    [M:ITC]NBSLB -=1                             : # depuis la fin pour gerer interlignes
Next IJ0
For IJ0=0 To [M:ITC]NBSLB-1                      : # suppression de CR (0D)
    [M:ITC]LIGSETLOB(IJ0)=ctrans([M:ITC]LIGSETLOB(IJ0),chr$(13),"")
Next IJ0

For IJ0=0 To [M:ITC]NBSLB-1                      : # traitement des lignes du tableau
    [M:ITC]LIGWRK_O=[M:ITC]LIGSETLOB(IJ0)
    While [M:ITC]LIGWRK_O<>""
          IJ1=instr(1,[M:ITC]LIGWRK_O,chr$(10))  : # recherche ligne suivante (LF)
          Raz J_LF
          If IJ1
             [M:ITC]LIGWRK_W=left$([M:ITC]LIGWRK_O,IJ1-1)
             J_LF=1
             [M:ITC]LIGWRK_O=right$([M:ITC]LIGWRK_O,IJ1+1)
          Else
             [M:ITC]LIGWRK_W=[M:ITC]LIGWRK_O
             [M:ITC]LIGWRK_O=""
          Endif

$PLUS_DE_99
          If LIGWRK_W<>"" | (LIGWRK_W="" & J_LF)
             Raz J_COUPE

             If len([M:ITC]LIGWRK_D)+len([M:ITC]LIGWRK_W)>=J_GIMP_LG
                If [M:ITC]NBGIMP<dim([M:ITC]LIGGIMP)
                   [M:ITC]NBGIMP +=1
                   nolign=[M:ITC]NBGIMP
                   J_COUPE=J_GIMP_LG-len([M:ITC]LIGWRK_D)
                   [M:ITC]LIGGIMP(nolign-1)  =[M:ITC]LIGWRK_D
                   [M:ITC]LIGGIMP(nolign-1) +=left$([M:ITC]LIGWRK_W,J_COUPE)
#                  [M:ITC]LIGWRK_D=right$([M:ITC]LIGWRK_W,J_COUPE+1)      # bug 35515
                   Raz [M:ITC]LIGWRK_D                                    # bug 35515
                   [M:ITC]LIGWRK_W=right$([M:ITC]LIGWRK_W,J_COUPE+1)      # bug 35515
                   Goto PLUS_DE_99                                        # bug 35515
                Endif
             Else
                [M:ITC]LIGWRK_D +=[M:ITC]LIGWRK_W
             Endif

             If J_LF
                If [M:ITC]NBGIMP<dim([M:ITC]LIGGIMP)
                   [M:ITC]NBGIMP +=1
                   nolign=[M:ITC]NBGIMP
                   [M:ITC]LIGGIMP(nolign-1)  =[M:ITC]LIGWRK_D
                Endif
                Raz [M:ITC]LIGWRK_D : Raz J_LF
             Endif

          Endif
    Wend
Next IJ0

If LIGWRK_D<>""
   If [M:ITC]NBGIMP<dim([M:ITC]LIGGIMP)
      [M:ITC]NBGIMP +=1
      nolign=[M:ITC]NBGIMP
      [M:ITC]LIGGIMP(nolign-1)  =[M:ITC]LIGWRK_D
   Endif
   Raz [M:ITC]LIGWRK_D : Raz J_LF
Endif

Return

# ----------
$EXP_RAZ_T1
Raz GIMP(71),GIMP(72),GIMP(73),GIMP(74),GIMP(75),GIMP(76),GIMP(77),GIMP(78)
Return
# ----------
$EXP_RAZ_T2
Raz GIMP(81),GIMP(82),GIMP(83),GIMP(84),GIMP(85),GIMP(86),GIMP(87),GIMP(88)
Return
# ----------
$EXP_RAZ_T3
Raz GIMP(91),GIMP(92),GIMP(93),GIMP(94),GIMP(95),GIMP(96),GIMP(97),GIMP(98)
Return

# ---------- Chargement GIMP(71 a 78) avec [M:ITC]LIGGIMP
$EXP_T1
GIMP(71)=[M:ITC]LIGGIMP(0) : GIMP(72)=[M:ITC]LIGGIMP(1) : GIMP(73)=[M:ITC]LIGGIMP(2)
GIMP(74)=[M:ITC]LIGGIMP(3) : GIMP(75)=[M:ITC]LIGGIMP(4) : GIMP(76)=[M:ITC]LIGGIMP(5)
GIMP(77)=[M:ITC]LIGGIMP(6) : GIMP(78)=[M:ITC]LIGGIMP(7)
Return

# ---------- Chargement GIMP(81 a 88) avec [M:ITC]LIGGIMP
$EXP_T2
GIMP(81)=[M:ITC]LIGGIMP(0) : GIMP(82)=[M:ITC]LIGGIMP(1) : GIMP(83)=[M:ITC]LIGGIMP(2)
GIMP(84)=[M:ITC]LIGGIMP(3) : GIMP(85)=[M:ITC]LIGGIMP(4) : GIMP(86)=[M:ITC]LIGGIMP(5)
GIMP(87)=[M:ITC]LIGGIMP(6) : GIMP(88)=[M:ITC]LIGGIMP(7)
Return
# ---------- Chargement GIMP(91 a 98) avec [M:ITC]LIGGIMP
$EXP_T3
GIMP(91)=[M:ITC]LIGGIMP(0) : GIMP(92)=[M:ITC]LIGGIMP(1) : GIMP(93)=[M:ITC]LIGGIMP(2)
GIMP(94)=[M:ITC]LIGGIMP(3) : GIMP(95)=[M:ITC]LIGGIMP(4) : GIMP(96)=[M:ITC]LIGGIMP(5)
GIMP(97)=[M:ITC]LIGGIMP(6) : GIMP(98)=[M:ITC]LIGGIMP(7)
Return


###################################################################
# -------------------------------------------------------------- #
# Création table correspondance des noms entre table et ecran    #
# uniquement dans le cas de masques à double stockage            #
# ( Articles-clients, Articles-Fournisseurs, etc....)            #
# enregistré dans une colonne [M:AOE2] sous la forme             #
# XXX YYYYYYYY (XXX=classe [M], YYYY..=champ du masque)          #
#----------------------------------------------------------------#
#                     Table              Masque                  #
# Articles-Clients    ITMBPC    [ITU] ! ITU    [ITU]             #
# Articles-Fourn.     ITMBPS    [ITP] ! ITP    [ITP]             #
# Adresses Clients    BPADDRESS [BPA] ! BPABPC [BPAC]            #
# CLIENTS livrés      BPDLVCUST [BPD] ! BPC4   [BPC4]            #
# Contacts clients    CONTACT   [CNT] ! CNTBPC [CNTC]            #
# Adresses Tiers      BPADDRESS [BPA] ! BPABPR [BPAB]            #
# Contacts Tiers      CONTACT   [CNT] ! CNTBPR [CNTB]            #
# Adresses Prospects  BPADDRESS [BPA] ! BPABPP [BPAP] pas d'IMP  #
# Contacts Prospects  CONTACT   [CNT] ! CNTBPP [CNTP] pas d'IMP  #
# Adresses Fourn.     BPADDRESS [BPA] ! BPABPS [BPAS]            #
# Contacts Fourn.     CONTACT   [CNT] ! CNTBPS [CNTS]            #
# Adresses Représent. BPADDRESS [BPA] ! BPAREP [BPAR]            #
# Adresses Transport. BPADDRESS [BPA] ! BPABPT [BPAT] pas d'IMP  #
# Contacts Transport. CONTACT   [CNT] ! CNTBPT [CNTT] pas d'IMP  #
# Tarifs Transport.   CARPRICE  [CAP] ! BPT3   [BPT3] pas d'IMP  #
# -------------------------------------------------------------- #
$IMP_CORRESP
Local Integer IJ0, IOAMZ
Local Char    JABFIC (GLONABR), JCODMSK (GLONAMK)                                                  # FGR 28/04/2015 : X3SUIVI107901 pas (5) et (10)
If clalev([F:AMZ])<=0 : Local File AMSKZON [AMZ] : IOAMZ=1 : Endif

Case [M:AOE1]OBJ
    When "LDS"
#        --- import leads
         If CORFIC="BPADDRESS" : JABFIC="BPA" : JCODMSK="BPALDS" : Gosub CORR_X : Endif
    When "BPC"
#        --- import clients
         If CORFIC="BPADDRESS" : JABFIC="BPA" : JCODMSK="BPABPC" : Gosub CORR_X : Endif
         If CORFIC="BPDLVCUST" : JABFIC="BPD" : JCODMSK="BPC4" :   Gosub CORR_X : Endif
         If CORFIC="CONTACT"   : JABFIC="CNT" : JCODMSK="CNTBPC" : Gosub CORR_K : Endif
    When "BPP"
#        --- import prospects
         If CORFIC="BPADDRESS" : JABFIC="BPA" : JCODMSK="BPABPP" : Gosub CORR_X : Endif
         If CORFIC="CONTACT"   : JABFIC="CNT" : JCODMSK="CNTBPP" : Gosub CORR_K : Endif
    When "BPR"
#        --- import tiers
         If CORFIC="BPADDRESS" : JABFIC="BPA" : JCODMSK="BPABPR" : Gosub CORR_X : Endif
         If CORFIC="CONTACT"   : JABFIC="CNT" : JCODMSK="CNTBPR" : Gosub CORR_K : Endif
    When "BPS"
#        --- import fournisseurs
         If CORFIC="BPADDRESS" : JABFIC="BPA" : JCODMSK="BPABPS" : Gosub CORR_X : Endif
         If CORFIC="CONTACT"   : JABFIC="CNT" : JCODMSK="CNTBPS" : Gosub CORR_K : Endif

    When "BPT"
#        --- import transporteurs (en prévision : import non développé)
         If CORFIC="BPADDRESS" : JABFIC="BPA" : JCODMSK="BPABPT" : Gosub CORR_X : Endif
         If CORFIC="CONTACT"   : JABFIC="CNT" : JCODMSK="CNTBPT" : Gosub CORR_K : Endif

    When "ITM"
#        --- import articles
         If CORFIC="ITMBPC" : JABFIC="ITU" : JCODMSK="ITU" : Gosub CORR_X : Endif
         If CORFIC="ITMBPS" : JABFIC="ITP" : JCODMSK="ITP" : Gosub CORR_X : Endif

    When "REP"
#        --- import représentants
         If CORFIC="BPADDRESS" : JABFIC="BPA" : JCODMSK="BPAREP" : Gosub CORR_X : Endif

    When "SOH"
#        --- import commandes

    When "SQH"
#        --- import devis

    When Default

Endcase

#--- import articles
#If CORFIC="ITMBPC"    & [M:AOE1]OBJ="ITM" : JABFIC="ITU" : JCODMSK="ITU" : Gosub CORR_X : Endif
#If CORFIC="ITMBPS"    & [M:AOE1]OBJ="ITM" : JABFIC="ITP" : JCODMSK="ITP" : Gosub CORR_X : Endif
#--- import clients
#If CORFIC="BPADDRESS" & [M:AOE1]OBJ="BPC" : JABFIC="BPA" : JCODMSK="BPABPC" : Gosub CORR_X : Endif
#If CORFIC="BPDLVCUST" & [M:AOE1]OBJ="BPC" : JABFIC="BPD" : JCODMSK="BPC4" :   Gosub CORR_X : Endif
#If CORFIC="CONTACT"   & [M:AOE1]OBJ="BPC" : JABFIC="CNT" : JCODMSK="CNTBPC" : Gosub CORR_X : Endif
#--- import tiers
#If CORFIC="BPADDRESS" & [M:AOE1]OBJ="BPR" : JABFIC="BPA" : JCODMSK="BPABPR" : Gosub CORR_X : Endif
#If CORFIC="CONTACT"   & [M:AOE1]OBJ="BPR" : JABFIC="CNT" : JCODMSK="CNTBPR" : Gosub CORR_X : Endif
#--- import fournisseurs
#If CORFIC="BPADDRESS" & [M:AOE1]OBJ="BPS" : JABFIC="BPA" : JCODMSK="BPABPS" : Gosub CORR_X : Endif
#If CORFIC="CONTACT"   & [M:AOE1]OBJ="BPS" : JABFIC="CNT" : JCODMSK="CNTBPS" : Gosub CORR_X : Endif
#--- import représentants
#If CORFIC="BPADDRESS" & [M:AOE1]OBJ="REP" : JABFIC="BPA" : JCODMSK="BPAREP" : Gosub CORR_X : Endif
#--- import transporteurs (en prévision : import non développé)
#If CORFIC="BPADDRESS" & [M:AOE1]OBJ="BPT" : JABFIC="BPA" : JCODMSK="BPABPT" : Gosub CORR_X : Endif
#If CORFIC="CONTACT"   & [M:AOE1]OBJ="BPT" : JABFIC="CNT" : JCODMSK="CNTBPT" : Gosub CORR_X : Endif

If IOAMZ : Close Local File [AMZ] : Endif
Return

#----------------------------------------------------------------------
$CORR_X
For IJ0=0 To dim([M:AOE2]ZONMSK)-1
  If [M:AOE2]FIL(IJ0)=CORFIC
    Read [AMZ] CODE=JCODMSK;"X"+[M:AOE2]FLD(IJ0)
    If !fstat : [M:AOE2]ZONMSK(IJ0)=JABFIC+" "+"X"+[M:AOE2]FLD(IJ0) : Endif
  Endif
Next IJ0
Return
#----------------------------------------------------------------------

$CORR_K
For IJ0=0 To dim([M:AOE2]ZONMSK)-1
  If [M:AOE2]FIL(IJ0)=CORFIC
     Read [AMZ] CODE=JCODMSK;"K"+[M:AOE2]FLD(IJ0)
    If !fstat : [M:AOE2]ZONMSK(IJ0)=JABFIC+" "+"K"+[M:AOE2]FLD(IJ0) : Endif
  Endif
Next IJ0
Return

$CORR_M
For IJ0=0 To dim([M:AOE2]ZONMSK)-1
  If [M:AOE2]FIL(IJ0)=CORFIC
    Read [AMZ] CODE=JCODMSK;"X"+[M:AOE2]FLD(IJ0)
    If !fstat : [M:AOE2]ZONMSK(IJ0)=JABFIC+" "+"X"+[M:AOE2]FLD(IJ0) : Endif
  Endif
Next IJ0

Return

# -------------------------------------------------------------- #
# Création table correspondance des noms entre table et ecran    #
# -------------------------------------------------------------- #
$IMP_FIN_CPL
#VPO 28/05/09 51611 il faut supprimer les variables
If dim(G_NOMTRT)>0     : Kill G_NOMTRT     : Endif
If dim(G_TRTIMPORT)>0  : Kill G_TRTIMPORT  : Endif
Return

$IMP_CPL
Local Integer IJ0, IJ1, IJ2, IJ3, IJ4, IJ5, IOAOB, IOATB, IOAMK, IOAMZ

#   le nom du traitement d'import genere doit etre mis dans une globale
Global Char G_NOMTRT (GLONADC)    : G_NOMTRT=NOMTRT                                                # FGR 28/04/2015 : X3SUIVI107901 pas (15)
Global Char G_TRTIMPORT (GLONADC) : G_TRTIMPORT=[M:AOE1]TRTIMP                                     # FGR 28/04/2015 : X3SUIVI107901 pas (15)

#   recherche de l'objet qui gère l'import
If [M:AOE1]OBJ="" : Goto RETURN0 : Endif
If clalev([F:AOB])<=0 : Local File AOBJET  [AOB] : IOAOB=1 : Endif
If clalev([F:ATB])<=0 : Local File ATABLE  [ATB] : IOATB=1 : Endif
If clalev([F:AMK])<=0 : Local File AMSK    [AMK] : IOAMK=1 : Endif
If clalev([F:AMZ])<=0 : Local File AMSKZON [AMZ] : IOAMZ=1 : Endif

# --- Utilisation du dictionnaire des objets ( onglet divers : bloc import )
#       pour la creation d'un tableau de travail table-masque
Read [AOB]ABREV=[M:AOE1]OBJ
If fstat : Goto RETURN0 : Endif

Local Char J_FIC    (GLONATB) (0..dim([F:AOB]IMPTBL)-1) : # nom de la table                        # FGR 28/04/2015 : X3SUIVI107901 pas (15)
Local Char J_ABRFIC  (GLONABR) (0..dim([F:AOB]IMPTBL)-1) : # abreviation de la table               # FGR 28/04/2015 : X3SUIVI107901 pas (5)
Local Char J_MSK    (GLONAMK) (0..dim([F:AOB]IMPTBL)-1) : # nom du masque                          # FGR 28/04/2015 : X3SUIVI107901 pas (15)
Local Char J_ABRMSK  (GLONABR) (0..dim([F:AOB]IMPTBL)-1) : # abreviation du masque                 # FGR 28/04/2015 : X3SUIVI107901 pas (5)
Local Char J_INDLIG (GLONAVA) (0..dim([F:AOB]IMPTBL)-1) : # nom de la variable bas tableau         # FGR 28/04/2015 : X3SUIVI107901 pas (15)
Local Char J_ABRMSKZ (GLONABR) (0..dim([F:AOB]IMPTBL)-1) : # abreviation du masque de sauvegarde   # FGR 28/04/2015 : X3SUIVI107901 pas (5)


Local Char J_FICCPL (GLONATB) (0..dim([F:AOB]IMPTBL)-1) : # nom de la table pour generation        # FGR 28/04/2015 : X3SUIVI107901 pas (15)
Local Char J_ABRCPL (GLONABR) (0..dim([F:AOB]IMPTBL)-1) : # abreviation de la table pour generation# FGR 28/04/2015 : X3SUIVI107901 pas (5)

Local Char TABFLD_NOM (25)
Local Char TABFLD_IND (25)
Local Char MSKZON_OBJ (50)                         : # champ du masque objet
Local Char MSKABR_OBJ (10)                         : # abreviation masque objet

Raz IJ2
For IJ1=0 To dim([F:AOB]IMPTBL)-1
   If [F:AOB]IMPTBL(IJ1)="" : Break : Endif
   J_FIC (IJ1)=[F:AOB]IMPTBL(IJ1)                  : # chgt nom de la table
   Read [F:ATB]CODFIC=[F:AOB]IMPTBL(IJ1)           : # lecture dictionnaire des tables
   If !fstat : J_ABRFIC(IJ1)=[F:ATB]ABRFIC : Endif : #   chgt abreviation de la table
   J_MSK(IJ1)=[F:AOB]IMPMSK(IJ1)                   : # chgt nom du masque
   Read [F:AMK]CODMSK=[F:AOB]IMPMSK(IJ1)           : # lecture dictionnaire des masques
   If !fstat
      IJ3 = find([F:AMK]ABRMSK,J_ABRMSK)           : #   chgt abr. masque de travail
      If IJ3                                       : #     "JJJ"+ 0 a 9
         J_ABRMSKZ(IJ1)=J_ABRMSKZ(IJ3-1)
      Else
         J_ABRMSKZ(IJ1)="JJJ"+num$(IJ2)
         IJ2 +=1
      Endif
      J_ABRMSK(IJ1)=[F:AMK]ABRMSK                  : #   chgt abreviation du masque
   Endif
   J_INDLIG(IJ1)=[F:AOB]IMPTAB(IJ1)                : # chgt nom variable bas tableau
Next IJ1

#--- Ouverture des masques de travail
For IJ0=0 To dim(J_FIC)-1
    If J_FIC(IJ0)="" : Break : Endif
    Case J_ABRMSKZ(IJ0)
         When "JJJ0"  If clalev([M:JJJ0])=0 : Local Mask =J_MSK(IJ0) [JJJ0] : Endif
         When "JJJ1"  If clalev([M:JJJ1])=0 : Local Mask =J_MSK(IJ0) [JJJ1] : Endif
         When "JJJ2"  If clalev([M:JJJ2])=0 : Local Mask =J_MSK(IJ0) [JJJ2] : Endif
         When "JJJ3"  If clalev([M:JJJ3])=0 : Local Mask =J_MSK(IJ0) [JJJ3] : Endif
         When "JJJ4"  If clalev([M:JJJ4])=0 : Local Mask =J_MSK(IJ0) [JJJ4] : Endif
         When "JJJ5"  If clalev([M:JJJ5])=0 : Local Mask =J_MSK(IJ0) [JJJ5] : Endif
         When "JJJ6"  If clalev([M:JJJ6])=0 : Local Mask =J_MSK(IJ0) [JJJ6] : Endif
         When "JJJ7"  If clalev([M:JJJ7])=0 : Local Mask =J_MSK(IJ0) [JJJ7] : Endif
         When "JJJ8"  If clalev([M:JJJ8])=0 : Local Mask =J_MSK(IJ0) [JJJ8] : Endif
         When "JJJ9"  If clalev([M:JJJ9])=0 : Local Mask =J_MSK(IJ0) [JJJ9] : Endif
         When Default
    Endcase
Next IJ0

#--- Boucle sur les lignes du modele d'import

For IJ0=0 To dim([M:AOE2]ZONMSK)-1

#      Extraire l'indice du nom de champ table
    Raz TABFLD_NOM, TABFLD_IND
    IJ3= instr(1,[M:AOE2]FLD(IJ0),"(")
    If IJ3
       TABFLD_NOM=left$([M:AOE2]FLD(IJ0),IJ3-1)
       TABFLD_IND=right$([M:AOE2]FLD(IJ0),IJ3)
    Else
       TABFLD_NOM=[M:AOE2]FLD(IJ0)
    Endif

#      Recherche dans le tableau table-masque
    For IJ1=0 To dim(J_FIC)-1
        If J_FIC(IJ1)="" : Break : Endif
        If [M:AOE2]FIL(IJ0)=J_FIC(IJ1)
           Read [AMZ]CODE=J_MSK(IJ1);TABFLD_NOM
           If !fstat
              Gosub IOB_MAJ
           Else
              If J_INDLIG(IJ1)<>""                 : # si table des lignes recherche avec "D"+nom champ
                 Read [AMZ]CODE=J_MSK(IJ1);"D"+TABFLD_NOM
                 If !fstat
                    TABFLD_NOM="D"+TABFLD_NOM
                    Gosub IOB_MAJ
                 Else
                    Read [AMZ]CODE=J_MSK(IJ1);"DET"+TABFLD_NOM
                    If !fstat
                       TABFLD_NOM="DET"+TABFLD_NOM
                       Gosub IOB_MAJ
                    Endif
                 Endif
              Endif
           Endif
        Endif
    Next IJ1
Next IJ0

#--- Generation dans le programme impxxxxxx

Raz IJ0, IJ1
#      Creer une table des abreviation des table (un seul poste par table)
For IJ0=0 To dim(J_FIC)-1
    If J_FIC(IJ0)="" : Break : Endif
    If !find(J_ABRFIC(IJ0),J_ABRCPL)
       J_FICCPL(IJ1)=J_FIC(IJ0) : J_ABRCPL(IJ1)=J_ABRFIC(IJ0)
       IJ1 +=1
    Endif
Next IJ0

#---
Wrseq "$CPL_FICMSK"
Wrseq "Case IMPFICCPL"
For IJ0=0 To dim(J_ABRCPL)-1
    If J_ABRCPL(IJ0)="" : Break : Endif
    Raz IJ2

    # Issue X3-68810
#   S'il y a au moins un champ affiché ou invisible, on va utiliser les masques [M:JJJ]
#   Il faut les razer. On fait le raz uniquement sur le fichier d'entête
#   There is at least one displayed/invisible field, we are going to use [M:JJJ] masks
#   We need to raz them. It is done only when the header file is proceed
    If (find (2, [M:AOE2]ZONMSKSTA(0 .. dim([M:AOE2]ZONMSKSTA)-1))  |
&       find (3, [M:AOE2]ZONMSKSTA(0 .. dim([M:AOE2]ZONMSKSTA)-1))) &
&       J_FICCPL(IJ0)=[M:AOE1]FLGFIL(0)
#       On a trouvé un champ affiché ou invisible, on est sur le ficher entête
#       There is one displayed/invisible field, the header file is proceed
        Wrseq "     When '"+vireblc(J_ABRCPL(IJ0),2)+"'"
#       Faire le raz des masques de travail si enregistrement entête
#       Do the raz for [M:JJJ] masks if header record
        For IJ3=0 To 9
            If evalue("clalev([M:JJJ"+num$(IJ3)+"])")>0
                If !IJ3
                    Wrseq "          Raz [M:JJJ"+num$(IJ3)+"]",
                Else
                    Wrseq " , [M:JJJ"+num$(IJ3)+"]",
                Endif
            Endif
        Next IJ3
        Wrseq
        IJ2=1
    Endif
    # End issue X3-68810

    For IJ1=0 To dim([M:AOE2]FIL)-1
#       Uniquement pour les champs affiches et invisibles et autorises en import
#                  et autorises en import (voir table FICZON_INT dans IMPXXX)
        If [M:AOE2]FIL(IJ1)=J_FICCPL(IJ0) & find ([M:AOE2]ZONMSKSTA(IJ1),2,3)
&          & !find(J_ABRCPL(IJ0)+"/"+vireblc([M:AOE2]FLD(IJ1),2),FICZON_INT)

#          Extraire le champ masque et indice
           Raz TABFLD_NOM, TABFLD_IND
           IJ3=instr(1,[M:AOE2]ZONMSK1(IJ1),"(")
           If IJ3
              TABFLD_NOM=vireblc(left$([M:AOE2]ZONMSK1(IJ1),IJ3-1),2)
              TABFLD_IND=vireblc(right$([M:AOE2]ZONMSK1(IJ1),IJ3+1),2)
              IJ3=instr(1,TABFLD_IND,")")
              If IJ3
                 TABFLD_IND=vireblc(left$(TABFLD_IND,IJ3-1),2)
              Endif
           Else
              TABFLD_NOM=vireblc([M:AOE2]ZONMSK1(IJ1),2)
           Endif
           If TABFLD_IND="" : TABFLD_IND="0" : Endif

#          Generer le when xxx une seule fois
           If !IJ2
              Wrseq "     When '"+vireblc(J_ABRCPL(IJ0),2)+"'"
#             Faire le raz des masques de travail si enregistrement entête
              If J_FICCPL(IJ0)=[M:AOE1]FLGFIL(0)
                 For IJ3=0 To 9
                     If evalue("clalev([M:JJJ"+num$(IJ3)+"])")>0
                        If !IJ3
                           Wrseq "          Raz [M:JJJ"+num$(IJ3)+"]",
                        Else
                           Wrseq " , [M:JJJ"+num$(IJ3)+"]",
                        Endif
                     Endif
                 Next IJ3
                 Wrseq
              Endif
              IJ2=1
           Endif

           If TABFLD_IND="nolign-1"
              Wrseq "          If nolign>0 & nolign<=dim("+TABFLD_NOM+")"
           Else
              Wrseq "          If dim("+TABFLD_NOM+")>"+TABFLD_IND
           Endif
           Wrseq "             "+[M:AOE2]ZONMSK1(IJ1)+"=[F:"+vireblc(J_ABRCPL(IJ0),2)+"]"+[M:AOE2]FLD(IJ1)
           Wrseq "          Endif"

        Endif
    Next IJ1

Next IJ0
Wrseq "     When Default"
Wrseq "Endcase"
Wrseq "Return"

#---
Wrseq "$CPL_MSKFIC"
Wrseq "Case IMPFICCPL"
For IJ0=0 To dim(J_ABRCPL)-1
    If J_ABRCPL(IJ0)="" : Break : Endif
    Raz IJ2
    For IJ1=0 To dim([M:AOE2]FIL)-1
#       Uniquement pour les champs affiches et invisibles
#                  et autorises en import (voir table FICZON_INT dans IMPXXX)
        If [M:AOE2]FIL(IJ1)=J_FICCPL(IJ0) & find ([M:AOE2]ZONMSKSTA(IJ1),2,3)
&          & !find(J_ABRCPL(IJ0)+"/"+vireblc([M:AOE2]FLD(IJ1),2),FICZON_INT)

#          Extraire le champ masque et indice
           Raz TABFLD_NOM, TABFLD_IND
           IJ3=instr(1,[M:AOE2]ZONMSK1(IJ1),"(")
           If IJ3
              TABFLD_NOM=vireblc(left$([M:AOE2]ZONMSK1(IJ1),IJ3-1),2)
              TABFLD_IND=vireblc(right$([M:AOE2]ZONMSK1(IJ1),IJ3+1),2)
              IJ3=instr(1,TABFLD_IND,")")
              If IJ3
                 TABFLD_IND=vireblc(left$(TABFLD_IND,IJ3-1),2)
              Endif
           Else
              TABFLD_NOM=vireblc([M:AOE2]ZONMSK1(IJ1),2)
           Endif
           If TABFLD_IND="" : TABFLD_IND="0" : Endif

#          Constitution du champ masque objet (pour transfert du masque JJJx dans [F] et [M] objet)
           MSKZON_OBJ=[M:AOE2]ZONMSK1(IJ1)
           IJ4=instr(1,MSKZON_OBJ,":")
           If IJ4 : MSKABR_OBJ=right$(MSKZON_OBJ,IJ4+1) : Endif
           IJ4= instr(1,MSKABR_OBJ,"]")
           If IJ4 : MSKABR_OBJ=left$(MSKABR_OBJ,IJ4-1) : Endif
           IJ4= instr(1,MSKZON_OBJ,"]")
           If IJ4 : MSKZON_OBJ=right$(MSKZON_OBJ,IJ4+1) : Endif
           IJ5=find(MSKABR_OBJ,J_ABRMSKZ)
           If IJ5
              MSKZON_OBJ="[M:"+J_ABRMSK(IJ5-1)+"]"+MSKZON_OBJ
           Else
              MSKZON_OBJ=[M:AOE2]ZONMSK1(IJ1)
           Endif

#          Generer le when xxx une seule fois
           If !IJ2
              Wrseq "     When '"+vireblc(J_ABRCPL(IJ0),2)+"'"
              IJ2=1
           Endif

           If TABFLD_IND="nolign-1"
              Wrseq "          If nolign>0 & nolign<=dim("+TABFLD_NOM+")"
           Else
              Wrseq "          If dim("+TABFLD_NOM+")>"+TABFLD_IND
           Endif
           Wrseq "             [F:"+vireblc(J_ABRCPL(IJ0),2)+"]"+[M:AOE2]FLD(IJ1)+"="+[M:AOE2]ZONMSK1(IJ1)
           Wrseq "             "+MSKZON_OBJ+"="+[M:AOE2]ZONMSK1(IJ1)
           Wrseq "          Endif"

        Endif
    Next IJ1

Next IJ0
Wrseq "     When Default"
Wrseq "Endcase"
Wrseq "Return"

$RETURN0
If IOAOB : Close Local File [AOB] : Endif
If IOATB : Close Local File [ATB] : Endif
If IOAMK : Close Local File [AMK] : Endif
If IOAMZ : Close Local File [AMZ] : Endif

Return

#--- mise a jour dans le tableau (masque AOE2)
$IOB_MAJ
Case [M:AOE2]ZONMSKSTA(IJ0)
     When 0 : If find([F:AMZ]SAIAFF,1,2,3) : Gosub IOB_0 : Endif
     When 1
     When 2 : If find([F:AMZ]SAIAFF,1,3)   : Gosub IOB_0 : Endif
     When 3 : If find([F:AMZ]SAIAFF,1,2)   : Gosub IOB_0 : Endif
Endcase
Return
$IOB_0
[M:AOE2]ZONMSK1(IJ0)="[M:"+vireblc(J_ABRMSKZ(IJ1),2)+"]"+TABFLD_NOM+TABFLD_IND
If J_INDLIG(IJ1)<>"" : [M:AOE2]ZONMSK1(IJ0) +="(nolign-1)" : Endif
[M:AOE2]ZONMSKSTA(IJ0)=[F:AMZ]SAIAFF
Return


# -------------------------------------------------------------- #
# Champs du modele (identifiant du champ paramétré)              #
#   - appelé notamment dans des imports spécifiques ($OUVRE)     #
#   - utilisation de la colonne ZONMSK1 du masque AOE2           #
#   - constitué de l'abréviation table et du champ               #
#     exemple [F:SDH]STOFCY(0) champ table (indice obligatoire)  #
#             SDH-*1           autre champ (pas d'indice)        #
# -------------------------------------------------------------- #
$FLD_MODELE
Local Integer IJ0, IJ1, IJ2
Local Integer IATB
Local Char    IJ_CODFIC (GLONATB) (0..20)                                                          # FGR 28/04/2015 : X3SUIVI107901 pas (15)
Local Char    IJ_ABRFIC (GLONABR)  (0..20)                                                         # FGR 28/04/2015 : X3SUIVI107901 pas (5)
Local Char    L_ABRFIC  (GLONABR)                                                                  # FGR 28/04/2015 : X3SUIVI107901 pas (5)
If clalev([ATAB])=0 : Local File ATABLE [ATB] : IATB=1 : Endif
Raz [M:AOE2]ZONMSK1
For IJ0=0 To dim([M:AOE2]FLD)-1
    Raz L_ABRFIC
    IJ1=find ([M:AOE2]FIL(IJ0),IJ_CODFIC)
    If IJ1
       L_ABRFIC=IJ_ABRFIC(IJ1-1)
     Else
       Read [ATB]CODFIC=[M:AOE2]FIL(IJ0)
       If fstat
          Raz [F:ATB]
        Else
          IJ2=find("",IJ_CODFIC )
          If IJ2 : IJ_CODFIC(IJ2-1)=[M:AOE2]FIL(IJ0) : IJ_ABRFIC(IJ2-1)=[F:ATB]ABRFIC : Endif
       Endif
       L_ABRFIC=[F:ATB]ABRFIC
    Endif

   If    instr (1,[M:AOE2]FLD(IJ0),"/")                           : # ligne séparateur
         [M:AOE2]ZONMSK1(IJ0)=L_ABRFIC+"-"+[M:AOE2]FLD(IJ0)
   Elsif instr (1,[M:AOE2]FLD(IJ0),"*")                           : # variable GIMP
         [M:AOE2]ZONMSK1(IJ0)=L_ABRFIC+"-"+[M:AOE2]FLD(IJ0)
   Elsif instr (1,[M:AOE2]FLD(IJ0),"(")                           : # champ table avec indice
         [M:AOE2]ZONMSK1(IJ0)="[F:"+L_ABRFIC+"]"+[M:AOE2]FLD(IJ0)
   Else                                                           : # champ table sans indice
         [M:AOE2]ZONMSK1(IJ0)="[F:"+L_ABRFIC+"]"+[M:AOE2]FLD(IJ0)+"(0)"
   Endif
Next IJ0
If IATB : Close Local File [ATB] : Endif
Return

# -------------------------------------------------------------- #
# IMP_ZON_BPA                                                    #
#       Action IMP_ZON pour la gestion des adresses              #
#               commun à IMPBPR IMPBPC IMPBPS IMPREP IMPBPP      #
# -------------------------------------------------------------- #
$IMP_ZON_BPA
# ---------------------------------------------------#
#     Adresse                                        #
# ---------------------------------------------------#
        Case IMPZON
            When "NBADR" :
#                Traitement particulier sur la 1ère zone de l'écran
#                --> Recharger nolign et indice pour se positionner sur la bonne ligne
                indice = [M]XNUMLIG
                nolign = indice + 1
            When "CODADR" :
#                Traitement particulier sur la 1ère zone de l'écran
#                --> Recharger nolign et indice pour se positionner sur la bonne ligne
                indice = [M]XNUMLIG
                nolign = indice + 1

                IMPZONFIC= "BPAADD"
                IMPZONMSK= "[M]"+IMPZON+"("+num$(nolign-1)+")"
            When "XADDLIG1","XADDLIG2","XADDLIG3" :
#                Nom de zone fichier-ecran different et zones indicées
                indice=val(mid$(IMPZON,8,1))-1
                IMPZONFIC= "BPAADDLIG("+num$(indice)+")"
                IMPZONMSK=IMPZON
            # FGR 08/10/2010 : X3SUIVI66788 (début)
            When "XTEL1","XTEL2","XTEL3","XTEL4","XTEL5"
              # Nom de zone fichier-ecran different et zones indicées
              indice = val(mid$(IMPZON,len(IMPZON),1))-1
              IMPZONFIC = "TEL("+num$(indice)+")"
              IMPZONMSK = IMPZON
            When "XWEB1","XWEB2","XWEB3","XWEB4","XWEB5"
              # Nom de zone fichier-ecran different et zones indicées
              indice = val(mid$(IMPZON,len(IMPZON),1))-1
              IMPZONFIC = "WEB("+num$(indice)+")"
              IMPZONMSK = IMPZON
            # FGR 08/10/2010 : X3SUIVI66788 (fin)
            When "XBPACRY" :
#                Nom de zone fichier-ecran different
                IMPZONFIC= "CRY"
                IMPZONMSK= IMPZON
            When Default
                IXZ = find(IMPFIC-IMPZON,[M:AOE2]ZONMSK)
                If IXZ
                  IMPZONFIC=[M:AOE2]FLD(IXZ-1)
                  IMPZONMSK=IMPZON
                Endif

        Endcase
Return


# -------------------------------------------------------------- #
# IMP_ZON_CNT                                                    #
#       Action IMP_ZON pour la gestion des contacts              #
#               commun à IMPBPR IMPBPC IMPBPS IMPREP IMPBPP      #
# -------------------------------------------------------------- #
$IMP_ZON_CNT
# ---------------------------------------------------#
#     Contact                                        #
# ---------------------------------------------------#
        # Dans l'objet BPR, le masque [CNTBPR] est lié au fichier CONTACT
        # Mais certains champs st ds le fichier CONTACTCRM                 ==> il faut changer IMPFIC
        #When "KCNTTTL", "KCNTLNA", "KCNTFNA", "KCNTMOB", "KCNTBIR","KCNTCSP" #MAE, bg 90444
        Case IMPZON
            When "KCNTTTL", "KCNTLNA", "KCNTFNA", "KCNTBIR","KCNTCSP","KCNTLAN"  #MAE,bg 94516,ajout de KCNTLAN
                IMPFIC="AIN" : # champs stockés ds le fichier CONTACTCRM
            When Default
                IMPFIC="CNT"
        Endcase
        Case IMPZON
            When "NBCNT" :
#                Traitement particulier sur la 1ère zone de l'écran
#                --> Recharger nolign et indice pour se positionner sur la bonne ligne
                indice = [M]KNOLIG
                nolign = indice + 1
            When "CCNCRM" :
#                Traitement particulier sur la 1ère zone de l'écran
#                --> Recharger nolign et indice pour se positionner sur la bonne ligne
                indice = [M]KNOLIG
                nolign = indice + 1

                IMPZONFIC= IMPZON
                IMPZONMSK= "[M]"+IMPZON+"("+num$(nolign-1)+")"
            When "KCNTTTL","KCNTLNA","KCNTFNA","KCNTFNC","KCNTSRV","KCNTMSS","KCNTBIR",
&                "KCNTFLG","KCNTCSP","KCNTLAN"  #MAE,bg 94516,ajout de KCNTLAN
#&                "KCNTMOB","KCNTFLG","KCNTCSP"     #MAE, bg 90444
#                Nom de zone fichier-ecran different
                IMPZONFIC = right$(IMPZON,2)
                IMPZONMSK=IMPZON
            When "KCNTADD":
#                Nom de zone fichier-ecran different
                IMPZONFIC = "BPAADD"
                IMPZONMSK=IMPZON
            When "KCNTTEL":
#                Nom de zone fichier-ecran different
                IMPZONFIC = "TEL"
                IMPZONMSK=IMPZON
            When "KCNTFAX":
#                Nom de zone fichier-ecran different
                IMPZONFIC = "FAX"
                IMPZONMSK=IMPZON
            When "KCNTWEB":
#                Nom de zone fichier-ecran different
                IMPZONFIC = "WEB"
                IMPZONMSK=IMPZON
            #MAE, bg 100117
            When "KCNTMOB":
#                Nom de zone fichier-ecran different
                IMPZONFIC = "MOB"
                IMPZONMSK=IMPZON
            When Default
                IXZ = find(IMPFIC-IMPZON,[M:AOE2]ZONMSK)
                If IXZ
                  IMPZONFIC=[M:AOE2]FLD(IXZ-1)
                  IMPZONMSK=IMPZON
                Endif
        Endcase
Return


# -------------------------------------------------------------- #
# IMP_ZON_BID                                                    #
#       Action IMP_ZON pour la gestion des ribs                  #
#               commun à IMPBPR IMPBPC IMPBPS                    #
# -------------------------------------------------------------- #
$IMP_ZON_BID
# ---------------------------------------------------#
#     Rib                                            #
# ---------------------------------------------------#
        Case IMPZON
            When "BIDBPAADD", "BIDCRY", "BIDCUR" :
                IMPZONFIC = mid$(IMPZON,4,19)
                IMPZONMSK= "[M]"+IMPZON+"("+num$(nolign-1)+")"
            When "BIDNUMFLG" :
                IMPZONFIC=""
                If [M]BIDNUM(nolign-1) = [F:BPR]BIDNUM
                   [M]BIDNUMFLG(nolign-1)=2
                   IMPMOD=1
                Endif
        Endcase
Return

#######################################################################
# Utilisation de l'instruction setmode --> suppression affichage
# avant le call SAIMSK et SAI_NBLIG
# pour afficher des infbox dans IMP_ZONE et IMP_TAB
# utiliser Setmode_off Setmode_on
# ( pour afficher : Gosub SETMODE_OFF en debut de IMP_ZONE ou IMP_TAB )
#######################################################################
#   Positionne un contexte d'import pour les instructions d'affichage
#       Permet la prise en compte des instructions diszo,actzo
#       Inhibe les instructions d'affichage
#######################################################################
$SETMODE_ON
Setmode GNBAFF, GAFFCOD, GAFFMASK, GAFFCHP, GAFFIND, GAFFTXT, GAFFRANG, GAFFOPT1, GAFFOPT2
Return
#######################################################################
#   Dépositionne un contexte d'import pour les instructions d'affichage
#       Permet les instructions d'affichage (infbox par exemple)
#######################################################################
$SETMODE_OFF
Setmode
Return

#######################################################################
# Appel du point d'entrée IMPZONINV
# - pour chargement de zones invisibles ou affichées dans les imports
#######################################################################
$PE_IMPZONINV
GPOINT="IMPZONINV" : Gosub ENTREE From EXEFNC
Return
#######################################################################

