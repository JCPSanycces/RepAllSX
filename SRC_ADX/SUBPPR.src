#<AdxTL>@(#)113.0.0.0 $Revision$
########################################################################
# SUBPPR : Gestion des motifs de prix ACHATS      Créé    JLS et SR    #
#                                                 Modifié MBT 23/07/98 #
#----------------------------------------------------------------------#
# Table mise à jour  : [F:PPR]PPREASON                                 #
########################################################################
 
Call OBJET ("PPR",GBIDC1,GBIDC2) From GOBJET
End 

#########################################################################
$ACTION
Case ACTION
 When "SETBOUT"    : Gosub SETBOUT   : # Activation/désactivation boutons
 When "FILTRE"     : Gosub FILTRE    : # Ecriture du tableau
 When "LIENS"      : Gosub LIENS     : # Après chargement de chaque ligne
 When "INICRE"     : Gosub INICRE    : # Chargement de la clé
 When "VERIF_MOD"  : Gosub VERIF_MOD : # Vérification avant d'enregistrer
 When "VERF_ANU"   : Gosub VERF_ANU  : # Contrôle de suppression
 When "AVANT_ACT"  : Gosub AVANT_ACT : # Avant exécution d'une action bouton
 When "FERME"      : Gosub FERME     : # Pour test valeur des globales
 When "MODIF"      : Gosub MODIF
 When "ANNULE"     : Gosub ANNULE
 When "CHANGE"       : Call CHANGE_AXX ("PPREASON", [L]OCODE, "", [L]NCODE, "") From TRTX3TEX
 When Default
Endcase 
Return  

#########################################################################

$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET : # Désactivation changement de clé
Return

$FILTRE
FILTSUP=""
Return

$LIENS
If [M:PPR1]DACMAN(nolign-1)=0  [M:PPR1]DACMAN(nolign-1)=1 : Endif
If [M:PPR1]UPDPRI(nolign-1)=0  [M:PPR1]UPDPRI(nolign-1)=1 : Endif
Return

#------------------------------------------------------------------------
$INICRE
[F:PPR]PRIREN=nolign
[M:PPR1]PRIREN(nolign-1)=nolign
[F:PPR]PRIRENCAR=num$([F:PPR]PRIREN)
[F:PPR]DES=[M:PPR1]DESAXX(nolign-1)
[F:PPR]LANDESSHO=GLANGUE+"~"+[F:PPR]DES
Return

#------------------------------------------------------#
# avant exécution d'une action bouton (ex Suppression) #
#------------------------------------------------------#
$AVANT_ACT
If BOUT<>"S" Return : Endif
If [M:PPR1]NBREN<>nolign
   GERR = 1 : GMESSAGE=mess(186,199,1) : OK=0 
Endif  
Return

#------------------------------------------------------------------------
# Contrôle si présence des motifs par défaut
#   - GDACMANPUR : Motif par défaut en saisie manuelle
#   - GUPDPRIPUR : Motif par défaut pour le prix
#------------------------------------------------------------------------
$VERIF_MOD
If GDACMANPUR<>0
  If [M:PPR1]NBREN<GDACMANPUR
    GMESSAGE=mess(29,194,1)+num$(GDACMANPUR) : GERR=1 : OK=0 : Return
  Elsif [M:PPR1]DACMAN(GDACMANPUR-1)<>2 | [M:PPR1]UPDPRI(GDACMANPUR-1)<>2
    GMESSAGE=mess(58,194,1)+num$(GDACMANPUR) : GERR=1 : OK=0 : Return
  Endif
Endif
If GUPDPRIPUR<>0
  If [M:PPR1]NBREN<GUPDPRIPUR
    GMESSAGE=mess(30,194,1)+num$(GUPDPRIPUR) : GERR=1 : OK=0 : Return
  Endif
Endif
Return

#------------------------------------------------------------------------ 
# Seule la dernière ligne est supprimable à cause de la numérotation 
#------------------------------------------------------------------------  
$VERF_ANU
If [M:PPR1]NBREN<>val(CODE) 
   GERR = 1 : GMESSAGE=mess(186,199,1) : OK=0 
Endif  
Return 
 
#------------------------------------------------------------------------
# Contrôle si présence des motifs par défaut
#   - GDACMANPUR : Motif par défaut en saisie manuelle
#   - GUPDPRIPUR : Motif par défaut pour le prix
#------------------------------------------------------------------------
$FERME
If GDACMANPUR<>0
 Read [PPR] PPR0=GDACMANPUR
 If fstat
  GERR = 2
  GMESSAGE =mess(29,194,1)+num$(GDACMANPUR)
 Else
  If [F:PPR]DACMAN<>2 | [F:PPR]UPDPRI<>2
   GERR = 2
   GMESSAGE=mess(58,194,1)+num$(GDACMANPUR)
  Endif
 Endif
Endif
If GUPDPRIPUR<>0
 Read [PPR] PPR0=GUPDPRIPUR
 If fstat
  GERR = 2
  GMESSAGE =mess(30,194,1)+num$(GUPDPRIPUR)
 Endif
Endif
Return

#------------------------------------------------------------------------
$MODIF
Delete [AXX] Where CODFIC="PPREASON" & LANGUE=GLANGUE
If fstat=1 | fstat>5
   GOK=0 : Call RSTA("AXX",GLANGUE) From GLOCK : Return
Endif
For nolign=1 To [M]NBREN
    Call MAJTEXTRA([M]DESAXX(nolign-1),"PPREASON","DESAXX",num$([M]PRIREN(nolign-1)),"") From ATEXTRA
    If GOK<1 : Break : Endif
Next nolign
Return

#------------------------------------------------------------------------
$ANNULE
Delete [AXX] Where CODFIC="PPREASON" & IDENT1=[L]CODE
If fstat=1 | fstat>5
   GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

#########################################################################

Subprog C_NBREN
# interdit sup ligne sauf si dernière
If find(status,68,83) | (status=65 & NBREN<>nolign)
   GMESSAGE=mess(186,199,1) : mkstat=2
Endif
End
