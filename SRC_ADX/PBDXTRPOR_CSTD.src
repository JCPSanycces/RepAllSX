########################################################################################################################
# Module        : Finance
# Description   : Payment balance declaration extraction Portugal (Class PBDXTRPOR)
########################################################################################################################
# Updates :
# Date       | Author     | Version | Description
# 2015-08-31 | DNE        |         | SAM #110662
# 2015-12-21 | ANGRE      | U10     | SAM #111399  changed ACTION to AMETHOD in $METHODS
# 2016-10-21 | RMA        | U12     | SAM #119282 GRUGPY no longer linked with an activity code
# 2017-10-17 | DNE        | U12     | Jira X3-60032: Now PBDGEND.COUPARCRY is filled with business partner's country
# 2018-05-03 | DNE        | VNEXT   | Jira X3-87157: FreeGroup in wrong place.
# 2018-07-24 | DNE        | VNEXT   | Jira X3-101699: Payment export rejects records with no X3 payment connected.
# 2018-08-03 | DNE        | VNEXT   | Jira X3-102078: Fallback for payment journals without payemtns in PAYMENTH.
########################################################################################################################


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return



########################################################################################################################
# Properties ###########################################################################################################

$PROPERTIES
  Case [L]CURPRO
  Endcase
Return

########################################################################################################################
# Methods ##############################################################################################################
# SAM # 111399 changed ACTION to AMETHOD
$METHODS
  Case [L]CURPTH
    When ""
      Case [L]AMETHOD
        When "COLLECT"     : Gosub COLLECT_DATA
        When "POST_BEFORE" : Gosub POST_BEFORE
        When "EXPORT"      : Gosub EXPORT_FILE
      Endcase
  Endcase
Return

########################################################################################################################
# Private ##############################################################################################################

####
#
#
# Parameter (as variables in the calling context):
#
# ...
#
####

$COLLECT_DATA
    ARET_VALUE = [V]CST_AOK
    If PARAM_PBDGEN = null Then
        ASTATUS = fmet this.ASETERROR( "", mess(6,112,1), [V]CST_AERROR ) #  'Nonexistent instance'
        ARET_VALUE = [V]CST_AERROR
        Return
    Endif

    Local Instance PBDCONFIG Using C_PBDCONFIG
    PBDCONFIG = NewInstance C_PBDCONFIG
    ASTATUS = fmet PBDCONFIG.AREAD( PARAM_PBDGEN.PBDCCODE, PARAM_PBDGEN.LEG )

    # Initialize tables, variables etc.
    Gosub INIT

    # Run data extraction.
    PARAM_CPY    = PARAM_PBDGEN.GRPORCPY
    PARAM_LEDIDX = PARAM_PBDGEN.LEDTYP
    PARAM_PERSTR = PARAM_PBDGEN.DATEFROM
    PARAM_PEREND = PARAM_PBDGEN.DATETO
    Gosub EXEC

    # Free memory
    FreeGroup PBDCONFIG
Return


####
#
#
# Parameter (as variables in the calling context):
#
# ...
#
####

$INIT
    If !clalev( [F:CPY] )    : Local File COMPANY      [CPY]    : Endif
    If !clalev( [F:CPY2] )   : Local File COMPANY      [CPY2]   : Endif # 2018-08-03 DNE X3-102078
    If !clalev( [F:AGC] )    : Local File AGRPCPY      [AGC]    : Endif
    If !clalev( [F:AGC2] )   : Local File AGRPCPY      [AGC2]   : Endif
    If !clalev( [F:TCY] )    : Local File TABCOUNTRY   [TCY]    : Endif
    If !clalev( [F:LED] )    : Local File GLED         [LED]    : Endif
    If !clalev( [F:GCM] )    : Local File GACM         [GCM]    : Endif
    If !clalev( [F:PER] )    : Local File PERIOD       [PER]    : Endif
    If !clalev( [F:JOU] )    : Local File GJOURNAL     [JOU]    : Endif
    If !clalev( [F:HAE] )    : Local File GACCENTRY    [HAE]    : Endif
    If !clalev( [F:HAE2] )   : Local File GACCENTRY    [HAE2]   : Endif
    If !clalev( [F:DAE] )    : Local File GACCENTRYD   [DAE]    : Endif
    If !clalev( [F:DAE1] )   : Local File GACCENTRYD   [DAE1]   : Endif
    If !clalev( [F:DAE2] )   : Local File GACCENTRYD   [DAE2]   : Endif
    If !clalev( [F:DAE3] )   : Local File GACCENTRYD   [DAE3]   : Endif
    If !clalev( [F:BPR] )    : Local File BPARTNER     [BPR]    : Endif
    If !clalev( [F:BPR2] )   : Local File BPARTNER     [BPR2]   : Endif
    If !clalev( [F:BPC] )    : Local File BPCUSTOMER   [BPC]    : Endif
    If !clalev( [F:PAN] )    : Local File PAYACCNUM    [PAN]    : Endif
    If !clalev( [F:PMD] )    : Local File PAYACCNUMD   [PMD]    : Endif
    If !clalev( [F:PYH] )    : Local File PAYMENTH     [PYH]    : Endif
    If !clalev( [F:BAN] )    : Local File BANK         [BAN]    : Endif
    If !clalev( [F:ABN] )    : Local File ABANK        [ABN]    : Endif
    If !clalev( [F:BAL] )    : Local File BALANCE      [BAL]    : Endif
    If !clalev( [F:DUD] )    : Local File GACCDUDATE   [DUD]    : Endif
    If !clalev( [F:HDU] )    : Local File HISTODUD     [HDU]    : Endif
    If !clalev([F:PBDBPD])   : Local File PBDBPGRPD    [PBDBPD] : Endif

    # Parameters
    Local Char      PARAM_CPY(GLONCPY)
    Local Char      PARAM_NPC(255)
    Local Char      PARAM_LED(GLONLED)
    Local Integer   PARAM_LEDIDX
    Local Date      PARAM_PERSTR
    Local Date      PARAM_PEREND

    # Local variables
    Local Char      CRITERIA(255)
    Local Integer   LINE_INDEX
    Local Instance  PBDCONFIGLINE Using C_PBDCONFIGD
    Local Instance  PBDGEND Using C_PBDGEND
    Local Char      CPYCRYCOD(GLONCPY)
    Local Char      ECOCOD(255)
    Local Integer   LINE
    Local Integer   ERRIND, ISTATUS
    Local Integer   LENGTH, I
Return



####
#
#
# Parameter (as variables in the calling context):
#
# PARAM_CPY   Local Char PARAM_CPY(GLONCPY)   Company or goup of companies to process
#
####

$EXEC
    Filter [F:AGC] Where GRP = PARAM_CPY
    For [F:AGC]AGC0

        Read [F:CPY]CPY0 = [F:AGC]CPY
        If fstat
            Raz [F:CPY]
        Else
            CPYCRYCOD = [F:CPY]CRY
        Endif

        Read [F:GCM]GCM0 = [F:CPY]ACM
        If fstat
            Raz [F:GCM]#
        Else
            PARAM_LED = [F:GCM]LED( PARAM_LEDIDX - 1 )
        Endif

        If len([F:CPY]EECNUM) > 9
            PARAM_NPC = right$( [F:CPY]EECNUM, len( [F:CPY]EECNUM ) - 8 )
        Else
            PARAM_NPC = [F:CPY]EECNUM
        Endif

        Read [F:LED]LED0 = PARAM_LED
        If fstat : Raz [F:LED] : Endif

      # Payments (if configured)
      If ( PBDCONFIG.PROCESSTYPE = 1 ) or  ( PBDCONFIG.PROCESSTYPE = 3 )
          Gosub PBD_CALC_PAYMENTS
      Endif

      # Open items (if configured)
      If ( PBDCONFIG.PROCESSTYPE = 2 ) or  ( PBDCONFIG.PROCESSTYPE = 3 )
          Gosub PBD_CALC_OPENITEMS
      Endif
    Next
    Filter [F:AGC]
Return



$PBD_CALC_PAYMENTS
    [L]LINE = 1

    # Entry point for additional selection criteria
    Raz CRITERIA
    GPOINT="PBDPORCRITPAY" : Gosub ENTREE From EXEFNC
    If CRITERIA = "" : CRITERIA = "1=1" : Endif

    # Create query.
    Link [F:HAE] With
&       [F:DAE1]DAE0(2) ~= [F:HAE]TYP; [F:HAE]NUM,
&       [F:DAE2]DAE0(2) ~= [F:DAE1]TYP; [F:DAE1]NUM,
&       [F:BPR]BPR0 = [F:DAE2]BPR
&   As [LNK]
&   Where [F:DAE2]LEDTYP = [F:DAE1]LEDTYP
&     and [F:HAE]CPY = PARAM_CPY
&     and [F:HAE]ACCDAT >= PARAM_PERSTR and [F:HAE]ACCDAT <= PARAM_PEREND
&     and [F:HAE]LED( PARAM_LEDIDX - 1 ) = PARAM_LED
&     and [F:DAE1]LEDTYP = PARAM_LEDIDX
&     and evalue( func PBDXTRLIB.TRIGGERING_ACCOUNTS( "[F:DAE1]ACC", PBDCONFIG.ROOTACC ) )
&     and evalue( func PBDXTRLIB.DATA_TO_INCLUDE( PBDCONFIG, "[F:DAE2]ACC", "[F:DAE2]BPR", "[F:DAE1]TYP", "[F:DAE1]SNS" ) )
&     and evalue( func PBDXTRLIB.DATA_TO_EXCLUDE( PBDCONFIG, "[F:DAE2]ACC", "[F:DAE2]BPR", "[F:DAE1]TYP" ) )
&     and evalue( CRITERIA )
&   Order By Key CLE = [F:DAE1]TYP; [F:DAE1]NUM; [F:DAE1]LEDTYP; [F:DAE1]LIN; [F:DAE2]TYP; [F:DAE2]NUM; [F:DAE2]LEDTYP; [F:DAE2]LIN

    [L]PBDGEND = NewInstance C_PBDGEND AllocGroup null

    # Loop on query data.
    For [LNK]CLE(3)
        For [F:DAE]DAE0
&           Where TYP = [F:DAE1]TYP
&             and NUM = [F:DAE1]NUM
&             and LEDTYP = [F:DAE1]LEDTYP
&             and not evalue( func PBDXTRLIB.TRIGGERING_ACCOUNTS( "ACC", PBDCONFIG.ROOTACC ) )

            # ... get the index of the matching data to include line in the configuration (or -1 otherwise).
            Raz ECOCOD
            LINE_INDEX = func PBDXTRLIB.MATCH_DATA_TO_INCLUDE_LINE( PBDCONFIG, [F:DAE]ACC, [F:DAE]BPR, [F:DAE1]TYP, [F:DAE1]SNS, ECOCOD )
            If LINE_INDEX >= 0
                PBDCONFIGLINE = PBDCONFIG.LINESINCL( LINE_INDEX )
                If ECOCOD = ""
                    Filter [F:HAE2]
&                     Where not ( TYP = [F:HAE]TYP and  NUM = [F:HAE]NUM )
&                       and BPRVCR = [F:HAE]BPRVCR

                    For [F:HAE2]HAE0
                        Filter [F:DAE3]
&                       Where TYP = [F:HAE2]TYP
&                         and NUM = [F:HAE2]NUM
&                         and BPR <> ""

                        Read [F:DAE3]DAE0 First
                        If !fstat
                            LINE_INDEX = func PBDXTRLIB.MATCH_DATA_TO_INCLUDE_LINE( PBDCONFIG, [F:DAE3]ACC, [F:DAE3]BPR, [F:DAE1]TYP, [F:DAE1]SNS, ECOCOD )
                            If LINE_INDEX >= 0
                                PBDCONFIGLINE = PBDCONFIG.LINESINCL( LINE_INDEX )
                                Break
                            Endif
                        Endif
                        Filter [F:DAE3]
                    Next
                    Filter [F:HAE2]
                Endif
            Endif
#2015-07-10 DNE MODIF BEGIN
#    If ( LINE_INDEX >= 0 ) and ( PBDGEND.BPRCRY = [F:CPY]CRY ) #and  PBDGEND.ACCCRY <> [F:CPY]CRY
#        LENGTH = len( PBDGEND.BPR )
#        For I = LENGTH To 1 Step -1
#          Read [F:PBDBPD]PBDBPD0 = PBDCONFIGLINE.BPGROUP; PARAM_PBDGEN.LEG; left$( left$( PBDGEND.BPR, I ) + "*", LENGTH )
#          If !fstat
#              If [F:PBDBPD]FLGBPNINC = 2
#                  ASTATUS = fmet [L]PBDGEND.AINSERT()
#              Endif
#              Break
#          Endif
#        Next
#    Else
#        ASTATUS = fmet [L]PBDGEND.AINSERT()
#    Endif
#2015-07-10 DNE MODIF ORIG
            Gosub ADD_DATA_LINE_PAY
#2015-07-10 DNE MODIF END
            If ASTATUS <> [V]CST_AOK
              Gosub PBDGEND_LINES_ERRORPRT
              ASTATUS = fmet this.ASETERROR( "", mess(380,107,1), [V]CST_AERROR ) #  'Inserting into database failed'
              ARET_VALUE = [V]CST_AERROR
              Break
            Endif
            [L]LINE += 1
        Next
    Next
    FreeGroup [L]PBDGEND
Return



$PBD_CALC_OPENITEMS
    [L]LINE = 1

    # Get possible (distinct) BPs
    For [F:BPR] Where [F:BPR]CRY <> "" and [F:BPR]CRY <> [F:CPY]CRY
        Filter [F:BAL] Where CPY = [F:CPY]CPY and BPR = [F:BPR]BPRNUM
        Read [F:BAL] First
        If !fstat
            # Entry point for additional selection criteria
            Raz CRITERIA
            GPOINT="PBDPORCRITOI" : Gosub ENTREE From EXEFNC
            If CRITERIA = "" : CRITERIA = "1=1" : Endif

            # Create main query for each BP.
            Link [F:HDU] With
&                [F:HAE]HAE0 ~= [F:HDU]TYP; [F:HDU]NUM,
&                [F:DAE]DAE2 ~= [F:HDU]ACCNUM,
&                [F:DUD]DUD1 ~= [F:HDU]ACCNUM; [F:HDU]DUDLIG
&           As [LNK]
&           Where [F:HDU]CPY = PARAM_CPY
&           and [F:HAE]FLGREP <> 2
&           and find( [F:HAE]CAT, 1, 4 ) <> 0
&           and [F:HDU]DATEVT <= PARAM_PEREND
&           and ( [F:HDU]BPR = [F:BPR]BPRNUM or [F:HDU]BPRPAY = [F:BPR]BPRNUM )
&           and [F:HAE]LED( PARAM_LEDIDX - 1 ) = PARAM_LED
&           and [F:DAE]LEDTYP = PARAM_LEDIDX
&           and evalue( func PBDXTRLIB.DATA_TO_INCLUDE( PBDCONFIG, "[F:DAE]ACC", "[F:HDU]BPR", "[F:DAE]TYP", "[F:DAE]SNS" ) )
&           and evalue( func PBDXTRLIB.DATA_TO_EXCLUDE( PBDCONFIG, "[F:DAE]ACC", "[F:HDU]BPR", "[F:DAE]TYP" ) )
&           and evalue( CRITERIA )
&           Order By Key CLE = [F:DUD]TYP; [F:DUD]NUM; [F:DUD]LIG; [F:DUD]DUDLIG; [F:HDU]NUMHDU Desc

           [L]PBDGEND = NewInstance C_PBDGEND AllocGroup null

            # Loop on query data.
            For [LNK]CLE(4)
                If [F:HDU]DUDSTA = 2 and [F:HDU]FLGCLE <> 2

                    # ...
                    Raz ECOCOD
                    LINE_INDEX = func PBDXTRLIB.MATCH_DATA_TO_INCLUDE_LINE( PBDCONFIG, [F:DAE]ACC, [F:HDU]BPR, [F:DAE]TYP, [F:DAE]SNS, ECOCOD )

                    # ...
                    If LINE_INDEX >= 0
                        PBDCONFIGLINE = PBDCONFIG.LINESINCL( LINE_INDEX )

                        # Get economic reason code by "Related company"
                        #
                        # Note: These "N..." and "M..." economic reason codes must exist!
                        #       So please update the reference folder.
                        If pat( [F:DAE]ACC, "219*") | pat( [F:DAE]ACC, "229*")
                            ECOCOD = "M1101"
                        Else
                            Raz ECOCOD
                            ECOCOD = "N"
                            If [F:DAE]SNS < 0
                                ECOCOD += "2"
                            Else
                                ECOCOD += "1"
                            Endif
                            ECOCOD += "0"
                            If [F:BPR]CPYREL > 0
                                ECOCOD += num$([F:BPR]CPYREL)
                            Else
                                # Fallback for uninitialized BPs ([F:BPR]CPYREL = 0).
                                ECOCOD += "1"
                            Endif
                            ECOCOD += "1"
                        Endif

                        # Add a line to open items list.
                        Gosub ADD_DATA_LINE_OI
                        If ASTATUS <> [V]CST_AOK
                            Gosub PBDGEND_LINES_ERRORPRT
                            ASTATUS = fmet this.ASETERROR( "",  mess(380,107,1), [V]CST_AERROR ) # 'Inserting into database failed'
                            ARET_VALUE = [V]CST_AERROR
                            Break
                        Endif
                        [L]LINE += 1
                    Endif
                Endif
            Next
# 2018-05-03 DNE INSERT BEGIN (X3-87157)
            FreeGroup [L]PBDGEND
# 2018-05-03 DNE INSERT END
        Endif
        Filter [F:BAL]
    Next
# 2018-05-03 DNE DEL BEGIN (X3-87157)
#    FreeGroup [L]PBDGEND
# 2018-05-03 DNE DEL END
Return


$PBDGEND_LINES_ERRORPRT
    For ERRIND = 1 To maxtab( PBDGEND.AERROR )
        ISTATUS = fmet this.ASETERROR( PBDGEND.AERROR(ERRIND).PRO, [L]PBDGEND.AERROR(ERRIND).MES, [L]PBDGEND.AERROR(ERRIND).STA)
    Next
Return


$ADD_DATA_LINE_OI
    Gosub ADD_DATA_LINE_COMMON

    PBDGEND.ISOITEM        = [V]CST_AYES
    PBDGEND.BPR            = [F:DAE]BPR
    PBDGEND.COUPAR         = [F:DAE]OFFACC
    PBDGEND.DUEDAT         = PARAM_PEREND
    PBDGEND.ACCTYP         = 5

    Case PBDCONFIG.AMOUNT
        When 2                                                                # AML 3643: 'Ledger currency'
            PBDGEND.CUR    = [F:HDU]CURLED
            PBDGEND.AMOUNT = [F:HDU]AMTLED * [F:HDU]SNS
        When Default                                                          # AML 3643: 'Original transaction currency'
            PBDGEND.CUR    = [F:HDU]CUR
            PBDGEND.AMOUNT = [F:HDU]AMTCUR * [F:HDU]SNS
    Endcase

    ISTATUS = 1
    If ISTATUS and ( PBDGEND.BPRCRY = [F:CPY]CRY )
        Gosub ADD_DATA_LINE_COMMON_ALWAYS_INCLUDE_BP
    Endif
    If ISTATUS
        ASTATUS = fmet [L]PBDGEND.AINSERT()
    Endif
Return


$ADD_DATA_LINE_PAY
    Gosub ADD_DATA_LINE_COMMON

    PBDGEND.ISOITEM        = [V]CST_ANO
    If ECOCOD = 'M1101' and ( ( PARAM_PEREND - [F:HAE]ACCDAT ) > 365 )
        PBDGEND.ECOCOD     = 'M1201'
    Endif
    PBDGEND.BPR            = [F:DAE]BPR
    PBDGEND.COUPAR         = [F:DAE]ACC

    Case PBDCONFIG.AMOUNT
        When 2                                                                # AML 3643: 'Ledger currency'
            PBDGEND.CUR    = [F:DAE]CURLED
            PBDGEND.AMOUNT = [F:DAE]AMTLED * [F:DAE]SNS * (-1)
        When Default                                                          # AML 3643: 'Original transaction currency'
            PBDGEND.CUR    = [F:DAE]CUR
            PBDGEND.AMOUNT = [F:DAE]AMTCUR * [F:DAE]SNS * (-1)
    Endcase

    # 2018-07-24 DNE X3-101699
    ISTATUS = 0  # Not yet identified as foreign payment. Set to 1 if to be added to the output list.
    Read [F:PYH]PYH0 = [F:HAE]BPRVCR
    If !fstat # Payment found: Use payment to detect a foreign payment
        PBDGEND.ACCDAT     = [F:PYH]ACCDAT
        PBDGEND.BPR        = [F:PYH]BPR

        Read [F:BPR2]BPR0  = [F:PYH]BPR
        If !fstat
            PBDGEND.BPRCRY = [F:BPR2]CRY
        Endif

        Read [F:BAN]BAN0 = [F:PYH]BAN
        If !fstat
            #
            # Note: The test on existence of PORBANCOD field in table ABANK is necessary for
            #       at the point in time when the push to X3DEV will happen the ABANK table
            #       will not be updated.
            #
            Raz PBDGEND.BIDNUM
            If dim( [F:ABN]PORBANCOD ) > 0
                Read [F:ABN]ABN0 = [F:BAN]CRY; left$( [F:BAN]BIDNUM, 4 )
                If !fstat
                    PBDGEND.BIDNUM = [F:ABN]PORBANCOD
                Endif
            Endif
            If PBDGEND.BIDNUM = ""
                # Fallback
                PBDGEND.BIDNUM = left$( [F:BAN]BIDNUM, 4 )
            Endif
            PBDGEND.ACCCRY = [F:BAN]CRY
            PBDGEND.ACCTYP = 0
            If dim( [F:BPR2]GRUGPY ) and ( [F:BPR2]GRUGPY <> "" )
                Read [F:AGC2]AGC0 = [F:BPR2]GRUGPY; [F:CPY]CPY
                If !fstat
                    PBDGEND.ACCTYP = 4
                Endif
            Endif
            If PBDGEND.ACCTYP > 0
            Elsif [F:BAN]BANCSH = 1
                If [F:BAN]CRY = [F:CPY]CRY  # 2015-08-31 DNE SAM #110662
                    PBDGEND.ACCTYP = 1
                Else
                    PBDGEND.ACCTYP = 2
                Endif
            Else
                PBDGEND.ACCTYP = 5
            Endif
        Endif
        ISTATUS = 1
    Else  # Payment not found: Use journal to detect a foreign payment (2018-08-03 DNE X3-102078)
# TODO (DNE): Was that all?
        # 1/ Check if (at least one) bank account corresponding to the triggering account
        #    ([F:DAE1]ACC together with [F:LED]COA) belongs to a foreign bank.
        #
        #    Note: Foreign and domestic banks should not be mixed on an account number.
        #
        Link [F:BAN] With [F:CPY2]CPY0 ~= [F:BAN]CPY
&       As [BANCPY]
&       Where [F:BAN]CRY    <> [F:CPY2]CRY
&         and [F:BAN]COA    = [F:LED]COA
&         and [F:BAN]BANACC = [F:DAE1]ACC
&       Order By Key CLE = [F:BAN]BAN

        For [BANCPY]CLE
            PBDGEND.ACCCRY = [F:BAN]CRY
            PBDGEND.ACCTYP = 2              # "External bank account"
            ISTATUS = 1
            Break
        Next

        # 2/ Else (all domestic bank accounts) check if a BP is a foreigner.
        If !ISTATUS
            PBDGEND.ACCCRY = [F:CPY]CRY     # Bank country is domestic, so the same as the company's.
            PBDGEND.ACCTYP = 1              # "Internal bank account"
            Read [F:BPR2]BPR0 = PBDGEND.BPR
            If !fstat
                 PBDGEND.BPRCRY    = [F:BPR2]CRY
                 PBDGEND.COUPARCRY = [F:BPR2]CRY
                 ISTATUS = 1
            Endif
        Endif
    Endif

    If ISTATUS and ( PBDGEND.BPRCRY = [F:CPY]CRY ) and ( PBDGEND.ACCCRY = [F:CPY]CRY )
        Gosub ADD_DATA_LINE_COMMON_ALWAYS_INCLUDE_BP
    Endif
    If ISTATUS
        ASTATUS = fmet [L]PBDGEND.AINSERT()
    Endif
Return


$ADD_DATA_LINE_COMMON_ALWAYS_INCLUDE_BP
    ISTATUS = 0
    If LINE_INDEX >= 0
        LENGTH = len( PBDGEND.BPR )
        For I = LENGTH To 1 Step -1
          Read [F:PBDBPD]PBDBPD0 = PBDCONFIGLINE.BPGROUP; PARAM_PBDGEN.LEG; left$( left$( PBDGEND.BPR, I ) + "*", LENGTH )
          If !fstat
              If [F:PBDBPD]FLGBPNINC = 2
                  ISTATUS = 1
              Endif
              Break
          Endif
        Next
    Endif
Return


$ADD_DATA_LINE_COMMON
    PBDGEND.CODE           = PARAM_PBDGEN.CODE
    PBDGEND.LEG            = PARAM_PBDGEN.LEG
    PBDGEND.ISDETAIL       = [V]CST_AYES
    PBDGEND.LINE           = [L]LINE
    PBDGEND.ECOTYP         = 1                                             # AML 3641: 'Not used'
    PBDGEND.BPRCRY         = [F:BPR]CRY
    PBDGEND.FLG            = 1                                             # AML 3649: 'Creation'
    PBDGEND.NPC            = PARAM_NPC
    PBDGEND.ACCNUM         = [F:DAE]ACCNUM
    PBDGEND.DOCTYP         = [F:DAE]TYP
    PBDGEND.DOCNUM         = [F:DAE]NUM
    PBDGEND.ACCDAT         = [F:DAE]ACCDAT
    PBDGEND.ACTCRY         = CPYCRYCOD
# 2017-10-17 DNE MODIF BEGIN (X3-60032)
    PBDGEND.COUPARCRY      = [F:BPR]CRY
# 2017-10-17 DNE MODIF ORIG
#    PBDGEND.COUPARCRY      = CPYCRYCOD
# 2017-10-17 DNE MODIF END

    PBDGEND.ECOCOD         = ECOCOD
    If LINE_INDEX >= 0
      PBDGEND.ORIENT         = PBDCONFIGLINE.ORIENT
      PBDGEND.ORIENTCFG      = PBDCONFIGLINE.ORIENT
      PBDGEND.NOTES          = PBDCONFIGLINE.NOTES
    Else
      PBDGEND.ORIENT         = 0
      PBDGEND.ORIENTCFG      = 0
      PBDGEND.NOTES          = ""
    Endif
Return


$EXPORT_FILE
    ARET_VALUE = [V]CST_AOK
    If PARAM_PBDGEN = null Then
        Call ADDDIAGNOSE( this.ACTX, mess(6,112,1), CST_AERROR ) From ASYRASYNC # 'Nonexistent instance'
        ARET_VALUE = [V]CST_AERROR
        Return
    Endif

    Local Instance PBDCONFIG Using C_PBDCONFIG

    PBDCONFIG = NewInstance C_PBDCONFIG
    ASTATUS = fmet PBDCONFIG.AREAD( PARAM_PBDGEN.PBDCCODE, PARAM_PBDGEN.LEG )
    If ASTATUS <> [V]CST_AOK
        Call ADDDIAGNOSE( PARAM_PBDGEN.ACTX, mess(6,112,1), CST_AERROR ) From ASYRASYNC # 'Nonexistent instance'
        ARET_VALUE = [V]CST_AERROR
        Return
    Endif

    Local File PBDGEND [PBDGEND]
    Local File PBDGEND [PBDGEND2]
    Local Char FLGTXT(1), NPC(50), EXPNAME(255)
    Local Integer COUNT : Raz COUNT

    Filter [F:PBDGEND2]
&   Where [F:PBDGEND2]CODE     = PARAM_PBDGEN.CODE
&     and [F:PBDGEND2]LEG      = PARAM_PBDGEN.LEG
&     and [F:PBDGEND2]ISDETAIL = [V]CST_ANO
&     and abs( [F:PBDGEND2]AMOUNT ) > 0
&     and abs( [F:PBDGEND2]AMOUNT ) >= abs( PBDCONFIG.AMTLIMIT )
&   Order By Key CLE = NPC

    Raz NPC

    For [F:PBDGEND2]CLE
        If NPC <> [F:PBDGEND2]NPC
            NPC = [F:PBDGEND2]NPC
            Gosub XML_INIT From CNSRSGSTDLIB
            EXPNAME = "BOP_COPE." + NPC + "." + format$( "D:YYYYMM", PARAM_PBDGEN.DATETO) + "." + format$( "D:YYYYMMDDhhmmss", date$ ) + ".xml"
            XMLFILENAME = func ASYRSTO.GETFULLPATH( "TMP", EXPNAME )
            Gosub XML_OPEN From CNSRSGSTDLIB

            If XMLFILEERR
                Call ADDDIAGNOSE( PARAM_PBDGEN.ACTX, mess(262,107,1), CST_AERROR ) From ASYRASYNC
                ARET_VALUE = CST_AERROR
                Return
            Endif

            # Open an asynchronous popup window ans show some information
            Call ASYNCTRACK( PARAM_PBDGEN.ACTX, NPC, EXPNAME, 0) From ASYRASYNC

            # Write XML data.
            XMLTAG = "BOP_CO" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB                                    # <BOP_CO>
                XMLTAG = "controlo" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB                              #     <controlo>
                    XMLTAG = "reportante" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB                        #         <reportante>
                        XMLTAG = "npc" : XMLCONTENT = NPC : Gosub XML_CREATE_TAG From CNSRSGSTDLIB      #             <npc>5999999993</npc>
                    Gosub XML_POP_TAG From CNSRSGSTDLIB                                                 #         </reportante>
                    XMLTAG = "periodorep" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB                        #         <periodorep>
                        XMLTAG = "ano" : XMLCONTENT = format$( "N0:4", year( PARAM_PBDGEN.DATETO ) )
                        Gosub XML_CREATE_TAG From CNSRSGSTDLIB                                          #             <ano>2015</ano>
                        XMLTAG = "mes" : XMLCONTENT = format$( "N0:2", month( PARAM_PBDGEN.DATETO ) )
                        Gosub XML_CREATE_TAG From CNSRSGSTDLIB                                          #             <mes>01</mes>
                    Gosub XML_POP_TAG From CNSRSGSTDLIB                                                 #         </periodorep>
                Gosub XML_POP_TAG From CNSRSGSTDLIB                                                     #     </controlo>

                XMLTAG = "reporte" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB                               #     <reporte>

                    # Write records.
                    Filter [F:PBDGEND]
&                   Where [F:PBDGEND]CODE     = PARAM_PBDGEN.CODE
&                     and [F:PBDGEND]LEG      = PARAM_PBDGEN.LEG
&                     and [F:PBDGEND]ISDETAIL = [V]CST_ANO
&                     and [F:PBDGEND]NPC      = NPC
&                     and abs( [F:PBDGEND]AMOUNT ) > 0
&                     and abs( [F:PBDGEND]AMOUNT ) >= abs( PBDCONFIG.AMTLIMIT )

                    For [F:PBDGEND]PBDGEND0
                        COUNT += 1

                        Case [F:PBDGEND]FLG
                            When 1 : FLGTXT = "C"
                            When 2 : FLGTXT = "M"
                            When 3 : FLGTXT = "A"
                        Endcase

                        XMLTAG = "registo" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB                       #         <registo>
                            XMLTAG = "id_reg" : XMLCONTENT = format$( "D:YYYYMM", PARAM_PBDGEN.DATETO) + "-" + format$( "N0:13", COUNT )
                            Gosub XML_CREATE_TAG From CNSRSGSTDLIB                                      #             <id_reg>000...-0...1</id_reg>
                            XMLTAG = "data_ref" : XMLCONTENT = format$( "D:YYYYMMDD", PARAM_PBDGEN.DATETO )
                            Gosub XML_CREATE_TAG From CNSRSGSTDLIB                                      #             <data_ref>20150131</data_ref>
                            XMLTAG = "reg" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB                       #             <reg>
                                XMLTAG = "cope" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB                  #                 <cope>
                                    XMLTAG = "natureza_registo" : XMLCONTENT = FLGTXT
                                    Gosub XML_CREATE_TAG From CNSRSGSTDLIB                              #                     <natureza_registo>C</natureza_registo>
                                    If [F:PBDGEND]NPC2 <> ""
                                        XMLTAG = "npc2" : XMLCONTENT = [F:PBDGEND]NPC2
                                        Gosub XML_CREATE_TAG From CNSRSGSTDLIB                          #                     <npc2>xxx</npc2>
                                    Endif
                                    XMLTAG = "montante" : XMLCONTENT = num$( ar2( abs( [F:PBDGEND]AMOUNT ) ) )
                                    Gosub XML_CREATE_TAG From CNSRSGSTDLIB                              #                     <montante>xxx</montante>
                                    XMLTAG = "divisa" : XMLCONTENT = [F:PBDGEND]CUR
                                    Gosub XML_CREATE_TAG From CNSRSGSTDLIB                              #                     <divisa>xxx</divisa>
                                    XMLTAG = "cod_estat" : XMLCONTENT = [F:PBDGEND]ECOCOD
                                    Gosub XML_CREATE_TAG From CNSRSGSTDLIB                              #                     <cod_estat>A1010</cod_estat>
                                    XMLTAG = "tipo_valor"
                                    If [F:PBDGEND]ISOITEM = 2
                                        XMLCONTENT = "P"
                                    Else
                                        If [F:PBDGEND]AMOUNT < 0
                                            XMLCONTENT = "S"
                                        Else
                                            XMLCONTENT = "E"
                                        Endif
                                    Endif
                                    Gosub XML_CREATE_TAG From CNSRSGSTDLIB                              #                     <tipo_valor>xxx</tipo_valor>
                                    XMLTAG = "tipo_conta"
                                    Case [F:PBDGEND]ACCTYP
                                        When 1       : XMLCONTENT = "I"
                                        When 2       : XMLCONTENT = "E"
                                        When 3       : XMLCONTENT = "O"
                                        When 4       : XMLCONTENT = "C"
                                        When Default : XMLCONTENT = "X"
                                    Endcase
                                    Gosub XML_CREATE_TAG From CNSRSGSTDLIB                              #                     <tipo_conta>xxx</tipo_conta>
                                    If [F:PBDGEND]BIDNUM <> ""
                                        XMLTAG = "id_banco" : XMLCONTENT = [F:PBDGEND]BIDNUM
                                        Gosub XML_CREATE_TAG From CNSRSGSTDLIB                          #                     <id_banco>xxx</id_banco>
                                    Endif
                                    If [F:PBDGEND]ACCCRY <> ""
                                        XMLTAG = "pais_conta" : XMLCONTENT = func PBDXTRLIB.GET_ISO3166_1_ALPHA3( [F:PBDGEND]ACCCRY )
                                        Gosub XML_CREATE_TAG From CNSRSGSTDLIB                          #                     <pais_conta>xxx</pais_conta>
                                    Endif
                                    If [F:PBDGEND]COUPARCRY <> ""
                                        XMLTAG = "pais_contraparte" : XMLCONTENT = func PBDXTRLIB.GET_ISO3166_1_ALPHA3( [F:PBDGEND]COUPARCRY )
                                        Gosub XML_CREATE_TAG From CNSRSGSTDLIB                          #                     <pais_contraparte>xxx</pais_contraparte>
                                    Endif
                                    If [F:PBDGEND]ACTCRY <> ""
                                        XMLTAG = "pais_activo" : XMLCONTENT = func PBDXTRLIB.GET_ISO3166_1_ALPHA3( [F:PBDGEND]ACTCRY )
                                        Gosub XML_CREATE_TAG From CNSRSGSTDLIB                          #                     <pais_activo>xxx</pais_activo>
                                    Endif
                                    If [F:PBDGEND]DUEDAT <> [0/0/0]
                                        XMLTAG = "data_vencimento" : XMLCONTENT = format$( "D:YYYYMMDD", [F:PBDGEND]DUEDAT )
                                        Gosub XML_CREATE_TAG From CNSRSGSTDLIB                          #                     <data_vencimento>xxx</data_vencimento>
                                    Endif
                                    If [F:PBDGEND]COUPAR <> ""
                                        XMLTAG = "contraparte" : XMLCONTENT = "xxx"
                                        Gosub XML_CREATE_TAG From CNSRSGSTDLIB                          #                     <contraparte>xxx</contraparte>
                                    Endif
                                    If [F:PBDGEND]NOTES <> ""
                                        XMLTAG = "observacoes" : XMLCONTENT = [F:PBDGEND]NOTES
                                        Gosub XML_CREATE_TAG From CNSRSGSTDLIB                          #                     <observacoes>xxx</observacoes>
                                    Endif
                                Gosub XML_POP_TAG From CNSRSGSTDLIB                                     #                 </cope>
                            Gosub XML_POP_TAG From CNSRSGSTDLIB                                         #             </reg>
                        Gosub XML_POP_TAG From CNSRSGSTDLIB                                             #         </registo>

                        # Check for a user abort and abort.
                        If func ASYRASYNC.ABORTREQUESTED( PARAM_PBDGEN.ACTX )
                            ARET_VALUE = [V]CST_AERROR
                            Filter [F:PBDGEND]
                            Goto ABORTEXPORT
                        Endif
                    Next
                    Filter [F:PBDGEND]

                Gosub XML_POP_TAG From CNSRSGSTDLIB                                                     #     </reporte>
            Gosub XML_POP_TAG From CNSRSGSTDLIB                                                         # </BOP_CO>
            Gosub XML_CLOSE From CNSRSGSTDLIB
        Endif

        # Create a download link to the file.
        Call ADDLINKDOWNLOAD( PARAM_PBDGEN.ACTX, "ATYPE10-1", "[TMP]/" + EXPNAME ) From ASYRASYNC
    Next
$ABORTEXPORT
    Filter [F:PBDGEND2]
    FreeGroup PBDCONFIG
Return


$POST_BEFORE
    ARET_VALUE = [V]CST_AOK

    If PARAM_PBDGEN = null Then
        ASTATUS = fmet this.ASETERROR( "", mess(6,112,1), [V]CST_AERROR ) #  'Nonexistent instance'
        ARET_VALUE = [V]CST_AERROR
        Return
    Endif

    Local Instance PBDCONFIG Using C_PBDCONFIG

    PBDCONFIG = NewInstance C_PBDCONFIG
    ASTATUS = fmet PBDCONFIG.AREAD( PARAM_PBDGEN.PBDCCODE, PARAM_PBDGEN.LEG )
    If ASTATUS <> [V]CST_AOK
        ASTATUS = fmet PARAM_PBDGEN.ASETERROR( "", mess(6,112,1), [V]CST_AERROR ) #  'Nonexistent instance'
        ARET_VALUE = [V]CST_AERROR
        Return
    Endif

    Local Char FIELDNAME(255)
    Local File PBDGEND [PBDGEND]

    Trbegin [PBDGEND]
    Filter [F:PBDGEND]
&   Where [F:PBDGEND]CODE     = PARAM_PBDGEN.CODE
&     and [F:PBDGEND]LEG      = PARAM_PBDGEN.LEG
&     and [F:PBDGEND]ISDETAIL = [V]CST_ANO
&     and abs( [F:PBDGEND]AMOUNT ) >= abs( PBDCONFIG.AMTLIMIT )
&     and abs( [F:PBDGEND]AMOUNT ) > 0

    For [F:PBDGEND]PBDGEND0
        FIELDNAME = "NPC"    : Gosub POST_BEFORE_MANDATORY_STR
        FIELDNAME = "AMOUNT" : Gosub POST_BEFORE_MANDATORY_NUM
        FIELDNAME = "FLG"    : Gosub POST_BEFORE_MANDATORY_NUM
        FIELDNAME = "CUR"    : Gosub POST_BEFORE_MANDATORY_STR
        FIELDNAME = "ECOCOD" : Gosub POST_BEFORE_MANDATORY_STR
        # 2015-08-31 DNE (SAM #110662)
        # E-mail from FMA from 2015-08-31: "ACCCRY (bank account origin) is mandatory only if ACCTYP= “E” or “O”."
        If [F:PBDGEND]ISOITEM <> 2 and ( [F:PBDGEND]ACCTYP = 2 or [F:PBDGEND]ACCTYP = 3 )
            FIELDNAME = "ACCCRY" : Gosub POST_BEFORE_MANDATORY_STR
        Endif
        FIELDNAME = "ACCTYP" : Gosub POST_BEFORE_MANDATORY_NUM
        FIELDNAME = "BPRCRY" : Gosub POST_BEFORE_MANDATORY_STR

        # Update TYPAMT as some kind of "sign".
        #
        # Note: We do this here for otherwise amounts wouldn't be balanced.
        #
        If [F:PBDGEND]ISOITEM = 2
            [F:PBDGEND]TYPAMT = "P"
        Else
            If [F:PBDGEND]AMOUNT < 0
#                [F:PBDGEND]AMOUNT = -[F:PBDGEND]AMOUNT
                [F:PBDGEND]TYPAMT = "S"
            Else
                [F:PBDGEND]TYPAMT = "E"
            Endif
        Endif
        Rewrite [F:PBDGEND]
    Next
    Commit
    LogicClose File [PBDGEND]
Return

$POST_BEFORE_MANDATORY_STR
    If evalue( "[F:PBDGEND]" + FIELDNAME ) = ""
        ASTATUS = fmet PARAM_PBDGEN.ASETERROR( "",
&                 func AFNC.MES4( mess(392,107,1), mess([F:PBDGEND]ISOITEM, 3644,1), FIELDNAME, num$( [F:PBDGEND]LINE ), mess(1,79,1) ),
&                 [V]CST_AERROR ) #  ''Section '$1$' / field '$2$' / line $3$: $4$' / 'Mandatory values''
        ARET_VALUE = [V]CST_AERROR
    Endif
Return

$POST_BEFORE_MANDATORY_NUM
    If evalue( "[F:PBDGEND]" + FIELDNAME ) = 0
        ASTATUS = fmet PARAM_PBDGEN.ASETERROR( "",
&                 func AFNC.MES4( mess(392,107,1), mess([F:PBDGEND]ISOITEM, 3644,1), FIELDNAME, num$( [F:PBDGEND]LINE ), mess(1,79,1) ),
&                 [V]CST_AERROR ) #  ''Section '$1$' / field '$2$' / line $3$: $4$' / 'Mandatory values''
        ARET_VALUE = [V]CST_AERROR
    Endif
Return

