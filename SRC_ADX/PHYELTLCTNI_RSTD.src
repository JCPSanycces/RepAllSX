#<AdxTL>@(#)0.0.0.0 $Revision$
# Issue 112576
# Physical elements non inventoried (from a location)

$EVENTS

  Case [L]CURPTH
  When ""
    Case [L]AEVENT
    When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
#    When "AQUERY_CRITERIA_AFTER"        : Gosub AQUERY_CRITERIA_AFTER # Issue 112576
    Endcase
  Endcase

Return

$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

$PROPERTIES

Return

$AQUERY_TRANS_AFTER

  # this physical element has never been inventoried : must be seen
  If this.PHY.IVYDAT = AVOID.ADATE
    Return
  Endif

  # A physical element is inventoried if the inventory date is greater or equal
  # than the current date minus the gap given by INVVALPER parameter : mustn't be seen
  If this.PHY.IVYDAT >= date$ - fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY, this.PHY.CPY, "INVVALPER")
    [L]ASTATUS = [V]CST_AERROR
  Endif

Return

# Issue 112576 : It's may be better to use AQUERY_CRITERIA_AFTER.
# but there's a technical pb : so we use AQUERY_TRANS_AFTER
$AQUERY_CRITERIA_AFTER

# Get the company
#Local File PHYLCT [LCT]
#Read [LCT]LCT0 = LCTCOD
#Local Date WIVYDAT
#
#  WIVYDAT = date$ - fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY, [F:LCT]CPY, "INVVALPER")
#
#  If (PQRY.QWHERE <> "")
#    PQRY.QWHERE = "(" + PQRY.QWHERE +") and"
#  Endif
#  PQRY.QWHERE -= "(IVYDAT eq AVOID.ADATE or IVYDAT le WIVYDAT)"

Return

