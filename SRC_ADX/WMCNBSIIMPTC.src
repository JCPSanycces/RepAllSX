#<AdxTL>@(#)0.0.0.0 $Revision$Class Bank import type codes
# Supervisor
## ACLA-CLASSE ## BSIIMPTC
# 2018-08-16 22:22:46 169

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0BSIIMPTC
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_BSICODTC From WMC1BSIIMPTC : Gosub TESTALLSTAT
Gosub INIT_DESAXX From WMC1BSIIMPTC : Gosub TESTALLSTAT
Gosub INIT_SHO From WMC1BSIIMPTC : Gosub TESTALLSTAT
Gosub INIT_CREDATTIM From WMC1BSIIMPTC : Gosub TESTALLSTAT
Gosub INIT_UPDDATTIM From WMC1BSIIMPTC : Gosub TESTALLSTAT
Gosub INIT_AUUID From WMC1BSIIMPTC : Gosub TESTALLSTAT
Gosub INIT_CREUSR From WMC1BSIIMPTC : Gosub TESTALLSTAT
Gosub INIT_UPDUSR From WMC1BSIIMPTC : Gosub TESTALLSTAT
Gosub INIT_BAN From WMC1BSIIMPTC : Gosub TESTALLSTAT
Gosub AINIT From WMC0BSIIMPTC : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0BSIIMPTC
Gosub _ALOADATTRIBUTE_BSICODTC From WMC1BSIIMPTC : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_DESAXX From WMC1BSIIMPTC : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_SHO From WMC1BSIIMPTC : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0BSIIMPTC
For AINDCLA=1 To maxtab(this.LINES)
 If this.LINES(AINDCLA)<>null& find(this.LINES(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.LINES(AINDCLA)._ALNKPRO : Gosub TESTALLSTAT
 Endif
Next AINDCLA
Gosub LNKPRO_CREUSR From WMC1BSIIMPTC : Gosub TESTALLSTAT
Gosub LNKPRO_UPDUSR From WMC1BSIIMPTC : Gosub TESTALLSTAT
Gosub LNKPRO_BAN From WMC1BSIIMPTC : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



