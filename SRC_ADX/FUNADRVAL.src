#<AdxTL>@(#)1.0.0.0 $Revision$
####################################################################################
# Program Name: FUNADRVAL    (from FRNADR(NA version); from FUNPIH)
# Description : Sage Sales Tax (SST) Address Validation Utility
#             : Based on user parameters sends 4 types of BPADDRESS records for validation
#               to an external process, which will update the records as
#               'valid' addresses.
#               Runs for all companies, since most BP types dont have a company
#               associated in v7.
# Author      : Ruedi Schmid
# Date        : Feb 20, 2012
# Type        : Runs when SST enabled for an install : LTA activity code
#               Table LTAPAR has SST parameters.
# Menu        : Commondata > BPs > Utilities> Address Validation
#
#FUNCTION    : FUNADRVRF
#ACTION      : TRTADRVAL
#WINDOW      : DADRVAL
#SCREEN      : SADRVAL1
#TRT         : FUNADRVAL
####################################################################################

$ACTION
#----------------------------------------------------------#
# Actions sur le traitement standard (GTRAITE)             #
# TRTFUNPIH  : Fonction de validation des factures/avoirs  #
#----------------------------------------------------------#
#Infbox ACTION

Case ACTION
 When "OUVRE_BATCH" : Gosub OUVRE
 When "INIT"        : Gosub INIT
 When "DEBUT"       : Gosub DEBUT
 When "OK"          : GOK=1
 When "END"         : GOK=0
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
Endcase

Return


$INIT
###########################################################
# INIT: Initalize,  Declarations, Set UI defaults
############################

If GSERVEUR #if we get an error while running in batch, just log
  Onerrgo ERRBATCH : # En batch, il vaut mieux mettre onerrgo
Endif

# Open files and local variables
Gosub OUVRE
Local Mask SADRVAL1 [DIA]
Raz [M:DIA]

# Set Defaults - (In DEBUT set field enable/disable to take effect)
[M:DIA]ALLFCY = 2  #Yes - All Sites
[M:DIA]ALLBPC = 2  #Yes - All Customers
[M:DIA]ALLBPP = 2  #Yes - All Prospects
[M:DIA]ALLLDS = 2  #Yes - All Leads
[M:DIA]VALFLG = 2  #Yes - Unvalidated addresses only (more performant)

[M:DIA]TRACE   = 2  #Yes - trace

#Trace title - mess(00006,09704,1) : Validation
TIT = mess(00006,09704,1)

Return

$OUVRE
###########################################################
# OUVRE: Open files and local variables
############################
#----- Variables locales -----#
Local Char WCRITFCY(250), WCRITBPC(250), WCRITLDS(250), WCRITBPP(250), WCRITVAL(250)
Local Integer   ERR_COUNTER,   VALID_COUNTER #Records Processed
Local Char    TIT(50)

#----- Open files -----#
If clalev([F:BPA]) =0  Local File BPADDRESS   [BPA] : Endif
#----- Used depending on User Selections -----
If clalev([F:FCY]) =0  Local File FACILITY    [FCY] : Endif
If clalev([F:BPC]) =0  Local File BPCUSTOMER  [BPC] : Endif
If clalev([F:BPR]) =0  Local File BPARTNER    [BPR] : Endif

If GMODU(13)=2   #58592 - JOBRO - check to make sure CRM is active
If clalev([F:LDS]) =0  Local File LEAD        [LDS] : Endif
Endif            #58592
#----- Used for validation against SST Parameters for this folder -----
If !clalev([F:LTP]) :  Local File LTAPAR [LTP] : Endif
Read [F:LTP]LTP0=nomap
#if fstat - we have bigger problems so dont worry bout message.

ERR_COUNTER = 0
VALID_COUNTER = 0

Return

$DEBUT
###########################################################
# DEBUT: Set screen field enable/disable based on INIT defaults set.
############################

#Since default settings take effect here, not in INIT
#(disable To/From fields)
Call AM_ALLFCY([M:DIA]ALLFCY )  #No - All Sites
Call AM_ALLBPC([M:DIA]ALLBPC )  #Yes - All Customers
Call AM_ALLBPP([M:DIA]ALLBPP )  #Yes - All Prospects
If GMODU(13)=2   #58592 - JOBRO - check to make sure CRM is active
Call AM_ALLLDS([M:DIA]ALLLDS )  #Yes - All Leads
Else             #58592.sn
    Chgfmt [M]ALLLDS  With "-K:10X"
    Chgfmt [M]FRLDS   With "-K:10X"
    Chgfmt [M]TOLDS   With "-K:10X"
Endif            #58592.en
#Need to redisplay "Set Defaults from OUVRE" and  AM_ALLBPC GRIZOS
Affzo [DIA]
Return


$CONTROLE
#####################################################
# Fires after OK and End buttons
# On OK before EXEC is called - standard
##########################################

If GOK<1  FIN=1 : Endif
Return


$EXEC
####################################################
# Exécution du traitement #
###########################
Local Integer ERR

If !GSERVEUR
  If [M:DIA]TRACE=2
    # Open the trace log (Batch handles automatically)
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(TIT,0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
  Endif
Endif


#NOTES on Data to be used:

#[BPC]BPCTYP values local menu 401:
#   1 N NORMAL
#   2 D MISCELLANEOUS
#   3 I INTRA-COMPANY
#   4 P PROSPECT

#[BPA]BPATYP values  local menu 943:
#     6 LEADS    Table LEADS [LDS]
#     5 C ACCOUNTS
#     4 S USER
#     3 F SITE  BP
#     2 C COMPANY
#     1 B BUSINESS PARTNER

#[LDS]PSTTYP Contact Type- menu 7811:
# 1   STANDARD
# 2   LEAD

#[LDS]PSTSTA Lead Status- menu 3040:
# 1   DISQUALIFIED
# 2   ON HOLD
# 3   QUALIFIED
# 4   CONTACTED

#NOTE : Differentiate BPA records we will use the following criteria
# Site - [BPA]BPATYP = 3
# Customer - Table: BPCUSTOMER [BPC] + [BPA]BPATYP = 1
# Prospect - Table: BPCUSTOMER [BPC] + [BPC]BPCTYP = 4  (Obj: BPP)
# Lead -  Table: LEAD [LDS] + [BPA]BPATYP = 6  (Obj: LDS)


#Build the filters based on user seleced criteria.
#Sites
If [M:DIA]ALLFCY<>2 & [M:DIA]FRFCY<>""# Not all sites
  WCRITFCY -='(BPANUM>= "'+[M:DIA]FRFCY+'" & BPANUM<= "'+[M:DIA]TOFCY+'" & [BPA]BPATYP=3)'
Elsif [M:DIA]ALLFCY=2 # All sites
  WCRITFCY -='(BPATYP=3)'
Endif

#Customers
If [M:DIA]ALLBPC<>2 & [M:DIA]FRBPC<>"" # Not all customers
  WCRITBPC -='(BPANUM>= "'+[M:DIA]FRBPC+'" & BPANUM<= "'+[M:DIA]TOBPC+'" & [BPA]BPATYP=1)'
Elsif [M:DIA]ALLBPC=2 # All customers
  WCRITBPC -='(BPATYP=1)'
Endif

#Prospects
If [M:DIA]ALLBPP<>2 & [M:DIA]FRBPP<>"" # Not all Prospects
  WCRITBPP -='(BPANUM>= "'+[M:DIA]FRBPP+'" & BPANUM<= "'+[M:DIA]TOBPP+'" & [BPA]BPATYP=1 & [BPC]BPCTYP = 4)'
Elsif [M:DIA]ALLBPP=2 # All customers
  WCRITBPP -='([BPA]BPATYP=1 & [BPC]BPCTYP = 4)'
Endif

If GMODU(13)=2  #58592 - JOBRO - check to make sure CRM is active
#Leads
If [M:DIA]ALLLDS<>2 & [M:DIA]FRLDS <>"" # Not all leads
  WCRITLDS -='(BPANUM>= "'+[M:DIA]FRLDS+'" & BPANUM<= "'+[M:DIA]TOLDS+'" & [BPA]BPATYP=6 & [LDS]PSTTYP=2 & [LDS]PSTSTA<>1)' #Lead contact type and not Disqualified'
Elsif [M:DIA]ALLLDS=2 # All leads
  WCRITLDS -='([BPA]BPATYP=6 & [LDS]PSTTYP=2 & [LDS]PSTSTA<>1)' #Lead contact type and not Disqualified'
Endif
Endif           #58592

#Unvalidated option
If [M:DIA]VALFLG=2  # Unvalidated addresses only
  WCRITVAL ='& (ADRVAL<>2)'
Else
  WCRITVAL = '' #Initialize to '' to avoid fail upon concat.
Endif

Call CHECK_FILTER(WCRITFCY,WCRITVAL)
Call CHECK_FILTER(WCRITBPC,WCRITVAL)
Call CHECK_FILTER(WCRITBPP,WCRITVAL)
If GMODU(13)=2   #58592 - JOBRO - check to make sure CRM is active
Call CHECK_FILTER(WCRITLDS,WCRITVAL)
Endif            #58592

#Get Errors to be used by $CHECKANDSEND outside the loop
#mess(00001,00716,1) : No validation
#mess(00164,00100,1) : Country Mandatory
#mess(00004,00899,1) : Validation error
#mess(00041,00151,1) : Folder parameters
# mess(00129,00100,1) : Non-existent Country Code
MESSAGE_NOCRY =  mess(00001,00716,1) + " - " + mess(00164,00100,1)
MESSAGE_FAIL  =  mess(00001,00716,1) + " - " + mess(00004,00899,1)
MESSAGE_CRY   =  mess(00001,00716,1) + " - " + mess(00041,00151,1) + " " + mess(00129,00100,1)

#*-----                       -------------  #
#*-----  Address record loops -------------  #
#*-----                       -------------  #

# NOTE: This is how to tell the type of BPADDRESS record
# Site      - BPATYP = 3
# Customer  - Table: BPCUSTOMER [BPC]  BPATYP = 1
# Prospect  - Table: BPCUSTOMER [BPC] Obj: BPP   [BPC]BPCTYP = 4
# Lead      - Obj: LDS Table: LEAD [LDS] BPATYP = 6  & [LDS]PSTTYP=2 & [LDS]PSTSTA<>1

ERR=0

#Site -----------------------------------  #
If WCRITFCY  <>""
  #User message if log is on: Processing Sites
  If [M:DIA]TRACE=2
    Call ECR_TRACE(mess(00001,00020,1) +" "+  mess(00154,00198,1)+"...",0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
  Endif

  Trbegin [BPA]
  Filter [BPA] Where evalue(WCRITFCY + WCRITVAL)
  For [F:BPA]
    Gosub $CHECKANDSEND
    If  ERR=1 : Break : Endif #Severe error
  Next    # BPA
  Filter [BPA]
  If ERR =1
    Rollback
  Else
    Commit
  Endif
Endif

#Customer -----------------------------------  # InnerJoin - ~=
If WCRITBPC <>""
  #User message if log is on: Processing Customers
  If [M:DIA]TRACE=2
    Call ECR_TRACE(mess(00001,00020,1)+" "+  mess(00037,00183,1)+"...",0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
  Endif

  Trbegin [BPA]
  Link [BPA] With [BPC]BPC0~=[F:BPA]BPANUM
& As [LBPC]
&   Where (evalue(WCRITBPC + WCRITVAL))
  For [F:LBPC]
    Gosub $CHECKANDSEND
    If  ERR=1 : Break : Endif #Severe error
  Next
  Filter [BPA]
  If ERR =1
    Rollback
  Else
    Commit
  Endif
Endif

#Prospect -----------------------------------  # InnerJoin - ~=
If WCRITBPP  <>""
  #User message if log is on: Processing Prospects
  If [M:DIA]TRACE=2
    Call ECR_TRACE(mess(00001,00020,1)+" "+  mess(00036,00183,1)+"...",0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
  Endif

  Trbegin [BPA]
  Link [BPA] With [BPC]BPC0~=[F:BPA]BPANUM
&   As [LBPP]
&   Where (evalue(WCRITBPP + WCRITVAL))
For [F:LBPP]
    Gosub CHECKANDSEND
    If  ERR=1 : Break : Endif #Severe error
  Next
  Filter [BPA]
  If ERR =1
    Rollback
  Else
    Commit
  Endif
Endif

#Lead -----------------------------------  # InnerJoin- ~=
#If WCRITLDS <>""  #58592.o
If WCRITLDS <>"" and GMODU(13)=2 #58592.n - JOBRO - check to make sure CRM is active
  #User message if log is on: Processing Leads
  If [M:DIA]TRACE=2
    Call ECR_TRACE(mess(00001,00020,1)+" "+  mess(00006,00943,1)+"...",0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
  Endif

  Trbegin [BPA]
  Link [BPA] With [LDS]LDS0~=[F:BPA]BPANUM
&   As [LLDS]
&   Where (evalue(WCRITLDS + WCRITVAL))
  For [F:LLDS]
    Gosub CHECKANDSEND
    If  ERR=1 : Break : Endif #Severe error
  Next
  If ERR =1
    Rollback
  Else
    Commit
  Endif
Endif

#rs Call TEMPON("V") From GESECRAN - dispaly
Call TEMPOFF From GESECRAN  #rs? what is this - long process for display

Return

Subprog CHECK_FILTER(MAIN_ENTITY_CRITERIA, REVALIDATE_CRITERIA)
########################################################################
#Check Filter is syntactically reliable before applying
# but we Dont know what parse exactly does - moved into a routine
############################
Value Char MAIN_ENTITY_CRITERIA()
Value Char REVALIDATE_CRITERIA()

If MAIN_ENTITY_CRITERIA <>""
  #If we dont get 0 back its an  error and need to show/log it.
  If parse(MAIN_ENTITY_CRITERIA + REVALIDATE_CRITERIA )
    Call ECR_TRACE("Filter error: "+ MAIN_ENTITY_CRITERIA + REVALIDATE_CRITERIA,1) From GESECRAN
  Endif
Endif

End

$CHECKANDSEND
###########################################################
#CheckAndSend: Call Addr Verif library if BPA addr has a Country
#               populate Address then call the Address verification library
#               Retrieve SST address and update [BPA] with validated address or with an unvalidated flag.
#              Log errors for display.
############################

Local Integer OERR
Local Char ICPY(GLONCPY)

#Skip record w/o validation if country is blank, give warning if logging on .
If [F:BPA]CRY = ''
   ERR_COUNTER+=1
   If [M:DIA]TRACE=2
      # Call ECR_TRACE([BPA]BPADES + space$(25- len([BPA]BPADES)) + " / " + [BPA]BPANUM + " / " + [BPA]BPAADD + " : " + MESSAGE_NOCRY,1) From GESECRAN   # 108139.o
      Call ECR_TRACE([BPA]BPADES + space$(30- len([BPA]BPADES)) + " / " + [BPA]BPANUM + " / " + [BPA]BPAADD + " : " + MESSAGE_NOCRY,1) From GESECRAN   # 108139.n
   Endif
   Return
Else
    #Skip record w/o validation if country is not on SST Parmeters,
    # Verify we support this country (ignore Company)
    If !find([F:BPA]CRY,[F:LTP]CRY)
      #Just skip, dont warn or count as error.
      Return
    Endif # !find
Endif # [F:BPA]CRY = ''

#Set address/BP values to send into SST for validation
IBPTYP = 0              # not used [F:BPA]BPATYP
IBPNUM  = [F:BPA]BPANUM
ICODADR =[F:BPA]BPAADD
If [F:BPA]BPATYP=3
  #Site
  ICPY= [F:FCY]LEGCPY
  INAM  = [F:FCY]FCYNAM
Elsif  [F:BPA]BPATYP=6
  #Lead
  ICPY = '' # [F:LDS] file has no company (Feb/2012 Currently, if blank it will be replaced with first x3company on Paramters)
  If GMODU(13)=2   #58592 - JOBRO - check to make sure CRM is active
    INAM  =[F:LDS]CPYNAM
  Else             #58592.sn
    INAM=""
  Endif            #58592.en
Else
  #Customer or Prospect are [BPC]
  If dim([F:BPC]CPY)>0
    ICPY = [F:BPC]CPY # [BPC] company not enterable on propect/cust UI (Feb/2012 Currently, if blank it will be replaced with first x3company on Paramters)
  Endif
  INAM  = [F:BPC]BPCNAM
Endif

#Initialize
IDISPLAY = 0   #0 for  mass update, $CHECKANDSEND logs errors itself since check for company too.

# Actual Address that will be evaluated and possibly normalized by SST(Avalera)
IOLINE1  = [F:BPA]BPAADDLIG(0)
IOLINE2  = [F:BPA]BPAADDLIG(1)
IOLINE3  = [F:BPA]BPAADDLIG(2)
IOCTY    = [F:BPA]CTY
IOREGION = [F:BPA]SAT
IOPOSCOD = [F:BPA]POSCOD
IOCRY    = [F:BPA]CRY

#Passed back
OADDRTYPE = "" #POBOX passback # OTYPE > POFLG  > POBOX > [F:BPA]POSCOD
OERR = 0       #errors comming back
OERRMSG = ""   #ignore in mass validation

# ADR_VALID(ICPY, IBPTYP,IBPNUM,ICODADR,INAM,IOLINE1,IOLINE2,IOLINE3,IOCTY,IOREGION,IOPOSCOD,IOCRY,OTYPE,IDISPLAY,OERR,OERRMSG)
Call ADR_VALID(ICPY, IBPTYP,IBPNUM,ICODADR,INAM,IOLINE1,IOLINE2,IOLINE3,IOCTY,IOREGION,IOPOSCOD,IOCRY,OADDRTYPE,IDISPLAY,OERR,OERRMSG) From TRTADRLIB

# Evaluate if address was Validated or it errored.
# Then update Address file with Validated address or log error.
If OERR
  ERR_COUNTER+=1
  # Dont display OERRMSG incorrect single internal mess, or empty so just use BPA fields + MESSAGE_FAIL
  # Call ECR_TRACE([BPA]BPADES + space$(25- len([BPA]BPADES)) + " / " + [BPA]BPANUM + " / " + [BPA]BPAADD + " : " + MESSAGE_FAIL  ,1) From GESECRAN   # 108139.o
  Call ECR_TRACE([BPA]BPADES + space$(30- len([BPA]BPADES)) + " / " + [BPA]BPANUM + " / " + [BPA]BPAADD + " : " + MESSAGE_FAIL  ,1) From GESECRAN   # 108139.n
  # Set address to Unvalidated(ADRVAL=1) and write below
  [F:BPA]ADRVAL = 1
Else
  VALID_COUNTER+=1
  # About to update using Validated(possibly modified to standard address format) address fields from SST
  #
  # Update table only if the information changed AND [F:BPA]ADRVAL was 1 (if it was 2(validated) and no change occured dont update w same info)
  If [F:BPA]ADRVAL = 2 and vireblc([F:BPA]BPAADDLIG(0),2) = vireblc(IOLINE1,2)
&   and vireblc([F:BPA]BPAADDLIG(1), 2) = vireblc(IOLINE2, 2) and vireblc([F:BPA]BPAADDLIG(2), 2)= vireblc(IOLINE3, 2)
&   and vireblc([F:BPA]CTY, 2) = vireblc(IOCTY, 2) and vireblc([F:BPA]SAT, 2) = vireblc(IOREGION, 2)
&   and vireblc([F:BPA]POSCOD, 2) = vireblc(IOPOSCOD, 2) and vireblc([F:BPA]CRY, 2) = vireblc(IOCRY, 2)
    # Skip for performance - Address was previously validated and return values were same
    # Dont Rewrite [BPA]
    Return
  Else
    #Address changed, or was not validated previously
    [F:BPA]ADRVAL = 2
    [F:BPA]BPAADDLIG(0) = IOLINE1
    [F:BPA]BPAADDLIG(1) = IOLINE2
    [F:BPA]BPAADDLIG(2)= IOLINE3
    [F:BPA]CTY = IOCTY
    [F:BPA]SAT = IOREGION
    [F:BPA]POSCOD = IOPOSCOD
    [F:BPA]CRY = IOCRY
  Endif #compare [F:BPA]values
Endif #OERR

 #Write both on OERR true or false
 Rewrite [BPA]
 If fstat
    If !GSERVEUR:  Call ERREUR("Could not write BPA record") From GESECRAN
    ERR=1 : Return : Endif #exit on hard error, rdddss
 Endif

Return


$TERMINE
##########################################################################
# After EXEC show number of validated records if any  #
#####################################
If !GSERVEUR
  If [M:DIA]TRACE=2
    If ERR_COUNTER + VALID_COUNTER = 0 : # Aucune pièce à traiter/No document to process
      Call ECR_TRACE(mess(8,107,1),0) From GESECRAN
    Else
      If ERR_COUNTER   : Call ECR_TRACE(mess(00002,02950,1) + " : "+ num$(ERR_COUNTER),0)    From GESECRAN : Endif #mess(00002,02950,1) : Not validated
      If VALID_COUNTER : Call ECR_TRACE(mess(00003,00429,1) + " : "+ num$(VALID_COUNTER),0)  From GESECRAN : Endif #mess(00003,00429,1) : Validated
    Endif

    Call FERME_TRACE From LECFIC
    TRA=1 #rs - checkout standard one to s ee if should be initaialized
  Endif
Endif

Return


########### ZONE ACTIONS ##########################################################################

########## AM_ CHECKBOX #####################################################################
Subprog AM_ALLFCY(VALEUR)
###########################################################
#After_Change: Based on value enable/disable related FROM and TO field
############################
Variable Integer VALEUR

 Call ENABLEDISABLE_FROMTO (VALEUR, "FCY")

End
Subprog AM_ALLBPC(VALEUR)
###########################################################
#After_Change: Based on value enable/disable related FROM and TO field
############################
Variable Integer VALEUR

 Call ENABLEDISABLE_FROMTO (VALEUR, "BPC")
End
Subprog AM_ALLBPP(VALEUR)
###########################################################
#After_Change: Based on value enable/disable related FROM and TO field
############################
Variable Integer VALEUR

 Call ENABLEDISABLE_FROMTO (VALEUR, "BPP")
End

Subprog AM_ALLLDS(VALEUR)
###########################################################
#After_Change: Based on value enable/disable related FROM and TO field
############################
Variable Integer VALEUR
 Call ENABLEDISABLE_FROMTO (VALEUR, "LDS")
End

########## AM_ FROM #####################################################################
Subprog AM_FRFCY(VALEUR)
###########################################################
#After_Change: Default entered FROM value into the TO field
############################
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]TOFCY = VALEUR : Affzo [M:DIA]TOFCY :  Endif
End

Subprog AM_FRBPC(VALEUR)
###########################################################
#After_Change: Default entered FROM value into the TO field
############################
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]TOBPC = VALEUR : Affzo [M:DIA]TOBPC :  Endif

End
Subprog AM_FRBPP(VALEUR)
###########################################################
#After_Change: Default entered FROM value into the TO field
############################
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]TOBPP = VALEUR : Affzo [M:DIA]TOBPP :  Endif
End

Subprog AM_FRLDS(VALEUR)
###########################################################
#After_Change: Default entered FROM value into the TO field
############################
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]TOLDS = VALEUR : Affzo [M:DIA]TOLDS :  Endif
End

########## Special Control Code #####################################################################
Subprog C_FRBPP(VALEUR)
###########################################################
#Control: Data Type only filters to Customer;  so control here - only allow Prospects are Type 4 BPC's
############################
Variable Char    VALEUR()

If VALEUR <> "" : Gosub CHECK_PROSPECT  : Endif

End

Subprog C_TOBPP(VALEUR)
###########################################################
#Control: Data Type only filters to Customer;  so control here - only allow Prospects are Type 4 BPC's
############################
Variable Char    VALEUR()

If VALEUR <> "" : Gosub CHECK_PROSPECT  : Endif

End

###########################################################
$CHECK_PROSPECT
Filter [F:BPC] Where BPCNUM=VALEUR and BPCTYP=4
Read [F:BPC] First
If fstat
   GMESSAGE = mess(1128,196,1) # "Invalid BP" - not a prospect
   mkstat = 2
Endif
Filter [F:BPC]
Return
###########################################################

Subprog ENABLEDISABLE_FROMTO (CHECKED, CONTROLPREFIX)
###########################################################
#Description:
#         Called from "All" checkbox fields
#         Enable related controls if checkbox is not checked, Disable(clear) if checked.
#Parameters:
#           CHECKED - checkbox VALUE
#           CONTROLPREFIX - prefix of the checkbox matches the related FROM TO range fields
############################
Value Integer CHECKED
Value Char CONTROLPREFIX()
Local Char ZONE_FROM(30) , ZONE_TO(30)

#Set retlated controls based on prefix
ZONE_FROM = "[M:DIA]FR"+CONTROLPREFIX
ZONE_TO   = "[M:DIA]TO"+CONTROLPREFIX

If CHECKED = 1
   #No - Display
   Actzo =ZONE_FROM
   Actzo =ZONE_TO
Else
   #Yes - Clear and disable
   Effzo =ZONE_FROM
   Effzo =ZONE_TO
   Grizo =ZONE_FROM
   Grizo =ZONE_TO
Endif

Affzo =ZONE_FROM
Affzo =ZONE_TO

End

$ERRBATCH
###################
# Si erreur Batch #
###################
  Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End  #Hard end

##########################################################
# 58592 - JOBRO - can no longer use the LDS data type since
#                 CRM could be inactive
###########################################################
Subprog C_FRLDS(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : Gosub CHECK_LEAD  : Endif
End

###########################################################
Subprog C_TOLDS(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : Gosub CHECK_LEAD  : Endif
End
###########################################################
$CHECK_LEAD

Read [F:LDS]LDS0=VALEUR
If fstat
   GMESSAGE = mess(83,123,1) #Invalid value
   mkstat = 2
Endif
End
#58592

