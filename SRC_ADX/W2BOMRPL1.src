#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque BOMRPL1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_ITMTOLNEG
Onevent BEFORE_INPUT Call AS_ITMTOLNEG(zc) From W2BOMRPL1
Return

Subprog AS_ITMTOLNEG(VALEUR)
Variable Decimal VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action PASECCUSE2
Call PASECCUSE2 From ECCLIB
If mkstat=2
 [M]ITMTOLNEG(INDIC) = VALEUR
 Affzo ITMTOLNEG(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

$CHG_STY
Return


