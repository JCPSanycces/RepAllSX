#<AdxTL>@(#)0.0.0.0 $Revision$ Initialize field BREAKAFTER
#----------------------------------------------------------------------------------------#
# X3-110077
# Initialize BREAKAFTER field in table AMSKZON and ASHWEXPPRO
#----------------------------------------------------------------------------------------#

Call MAJ_UTIINIBREAKAFTER
End

#-------------------------------------------------------------------------------#
Subprog MAJ_UTIINIBREAKAFTER
Local Char DOSSIER(30)
Local Integer LRET
Local Integer LFORCE
Local Integer LDELAXX

DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIINIBREAKAFTER - Init BREAKAFTER field from AMSKZON & ASHWEXPPRO") From SAIDOS
If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
        Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UTIINIBREAKAFTER - Init BREAKAFTER field from AMSKZON & ASHWEXPPRO") From LECFIC
    Call INI_BREAKAFTER(DOSSIER)

    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
Endif
End


Subprog INI_BREAKAFTER(DOSSIER)
Value Char DOSSIER

  If [L]DOSSIER <>""
    If [L]DOSSIER=nomap
      Local File AMSKZON    [AMZ2]
      Local File ASHWEXPPRO [ASWR2]
    Else
      Local File =[L]DOSSIER+".AMSKZON"    [AMZ2]
      Local File =[L]DOSSIER+".ASHWEXPPRO" [ASWR2]
    Endif
  Else
    End
  Endif

  If dim([AMZ2]BREAKAFTER)>0
    Trbegin [AMZ2]
    Update [AMZ2] Where BREAKAFTER<1 With BREAKAFTER=1
    If !fstat
      Commit
      Call ECR_TIME ("Initialization of BREAKAFTER in AMSKZON done") From DOSSUB
    Else
      Rollback
      Call ECR_TIME ("Error during initialization of BREAKAFTER in AMSKZON") From DOSSUB
    Endif

    If dim([ASWR2]BREAKAFTER)>0
      Trbegin [ASWR2]
      Update [ASWR2] Where BREAKAFTER<1 With BREAKAFTER=1
      If !fstat
        Commit
        Call ECR_TIME ("Initialization of BREAKAFTER in ASHWEXPPRO done") From DOSSUB
      Else
        Rollback
        Call ECR_TIME ("Error during initialization of BREAKAFTER in ASHWEXPPRO") From DOSSUB
      Endif
    Endif
  Endif

  LogicClose File [AMZ2]
  LogicClose File [ASWR2]
End

########################################################################
# Automatic executed by patch
########################################################################
Subprog PATCH(DOSSIER)
Value Char DOSSIER
  Call INI_BREAKAFTER(DOSSIER)
End

#######################################################################
# Executed by dosmaj (folder validation)
########################################################################
Subprog UTI_MOUL (DOSSIER)
Value Char DOSSIER
  Call INI_BREAKAFTER(DOSSIER)
End

