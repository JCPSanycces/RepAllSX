#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# EMHRMAJ90_LMMSC UTI process                                   PAY Module
#                 Migration To U12 - Vnext version
#
# ==>  Update LOCAL MENUS to miscellaneous table records
#
##########################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  # Check Payroll Module
  If [F:ADS]MODULE(14)<>2 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Update LOCAL MENUS to miscellaneous table records") From LECFIC

  Call MAJ_EMHRMAJ90_LMMSC(WDOSSIER)

  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

Subprog MAJ_EMHRMAJ90_LMMSC(LDOSSIER)
Value Char LDOSSIER

  Onerrgo CYCLECHECKERROR
  Local Char      DOSLEGMIG(5)                                #for folder name return by get leg function
  Local Char      MENUNAME(GLONATB)(1..)                      #array for local menu table name, datatype ATB(Tables)
  Local Char      MISCTAB(GLONATB)(1..)                       #array for miscellaneous table name
  Local Integer   STAT :STAT = 1                              #for writing to the log file in subprog MIGRATE_TABLE
  Local Integer   NRBREC, I, NBRTAB                           #number of records, index for array management, number of tables
  Local Char      MSG(200)                                    #not seeing where this getting used
  Local Char      THISPROC(20) : THISPROC = 'EMHRMAJ90_LMMSC'     #for passing duing subprogram calls

  #check if folder table file is not open, then open
  If clalev([F:ADS]) = 0  :Local File ADOSSIER [ADS] :Endif
  #Read the folder table where folder = current folder (nomap)
  Read [ADS] DOSSIER=[L]LDOSSIER
  #if the read successful, reset the table class for use
  If fstat :Raz [F:ADS] :Endif

  Call TEMPON("O") From GESECRAN
  Call ECR_TRACE("EMHRMAJ90_LMMSC: Update LOCAL MENUS to miscellaneous table records",0) From GESECRAN
  Call ECR_TRACE("EMHRMAJ90_LMMSC: Start of process on : "+LDOSSIER,0) From GESECRAN

  #gets the folder legislation
  DOSLEGMIG = func EMHRMAJ90_LEG.GET_LEG(LDOSSIER)

  #Adding the local menus to an array for migration
  Gosub ADD_TABLE_ARRAY_LEG

  #Loop through the local menus and calls the migration sub program
  Gosub LOOP_TABLE_ARRAY_LEG

  #closes the "Operation in progress" popup again
  Call TEMPOFF From GESECRAN
  #close the migration log file
  Call ECR_TRACE(THISPROC +": Completed Local Menu migration to Misc Table process",0) From GESECRAN
  Call FERME_TRACE From LECFIC
  #display the migration log file
  Call LEC_TRACE From LECFIC

End #end migration process ###########################################################################################

$CYCLECHECKERROR
  Call ECR_TRACE("Error in EMHRMAJ90_LMMSC: " + num$(errn)-errmes$(errn)-errm, -1) From GESECRAN
Resume

#Add the local menu 'tables' to stage for migration to Misc Tables
$ADD_TABLE_ARRAY_LEG

  #initialise array index, and start at 1 for loading local menu 'tables'
  I  = 0
  I += 1 : MENUNAME(I) = "329" : MISCTAB(I) = "10469" #Contribution fund
  #I += 1 : MENUNAME(I) = "391 " : MISCTAB(I) = " "
  #add the rest here as the above line with local menu name

  #store the number of local menus to loop through for migrating
  [L]NBRTAB = I

Return ##############################################################################################################

#loop through the table array and migrate the message data for each local menu
$LOOP_TABLE_ARRAY_LEG

  #open the local menu header table for reading
  If clalev([F:AML]) = 0 : Local File = LDOSSIER+"."+"AMENLOC"   [AML]  :Endif
  #open the local menu's messages table for reading
  If clalev([F:AST]) = 0 : Local File = LDOSSIER+"."+"APLSTD"    [AST]  :Endif
  #open the miscellaneous table header setup (header) table for writing
  If clalev([F:ADV]) = 0 : Local File = LDOSSIER+"."+"ATABTAB"   [ADV]  : Endif
  #open the miscellaneous table records for writing
  If clalev([F:ADI]) = 0 : Local File = LDOSSIER+"."+"ATABDIV"   [ADI]  : Endif

  #Loop through the list of local menus to migrate
  For I = 1 To [L]NBRTAB
    #Infbox"iteration of local menu array, I = " - num$(I) - " of total loops [L]NBRTAB = " - num$([L]NBRTAB)
    Call ECR_TRACE(THISPROC +": Local Menu migration " + MENUNAME(I) + " to Misc Table: " + MISCTAB(I) + " - Starting on folder: "+LDOSSIER,0)
&   From GESECRAN
    #write the local menu columns to the log file to reference
    Call ECR_TRACE("Miscellaneous table data - " + " Code:"+" Description:"+" Short Desc:"+ " Type:"+ " Leg:"+ " Title"+ " Active",0)
&   From GESECRAN

#    Call TRACE(1, "UTIMIG_LMMT", THISPROC +": Local Menu migration " + MENUNAME(I) + " to Misc Table: " + MISCTAB(I) + " - Starting on folder: "+LDOSSIER) From EXTTRACELOG
    #call the subprog to migrate the local menu data
    Call MIGRATE_TABLE(THISPROC, DOSLEGMIG, STAT, LDOSSIER, MENUNAME(I), MISCTAB(I))
  Next

  #Close the local menu header and messages table used for reading and writing
  LogicClose File [F:AML] #local menu header
  LogicClose File [F:AST] #local menu messages
  LogicClose File [F:ADV] #miscellaneous table setup (header)
  LogicClose File [F:ADI] #miscellaneous table records

  #Resets global variables
  Call DEBTRANS From GLOCK

Return ##############################################################################################################

#This is called while looping through the local menu table array
Subprog MIGRATE_TABLE(THISPROC, DOSLEGMIG, STAT, LDOSSIER, MENUNAME, MISCTAB)

  #declare subprog parameters
  Value   Char      LDOSSIER, THISPROC, DOSLEGMIG, MENUNAME, MISCTAB
  Value   Integer   STAT                    #for writing to the log file in subprog MIGRATE_TABLE
                    STAT = 1                #initialize
  Local   Char      MSG(200)                #not seeing where this is getting used
  Local   Integer   COMPTEUR                #number of records processed by the last update instruction
  Local   Integer   UPD_OK                  #for insert/update transaction control, 1 = No and 2 = Yes
                    UPD_OK = 2              #initialize
  Local   Integer   MODULE_OK               #to check if the module from 100 range and 10000 range matches, 1 = 'no' and 2 = 'yes'
                    MODULE_OK = 2           #initialize
  Local   Char      LNGDES(GLONAX3)         #misc table long description for atextra
  Local   Char      SHODES(GLONAX1)         #misc table short description for atextra
  Local   Integer   MSGBREAK                #remove this after debugging
  Local   Char      TARGET_CODE(5)          #to check the matching and order of the misc tab
                    TARGET_CODE = "None"    #initialize
  Local   Char      TARGET_LNGDES(GLONAX3)  #to check the matching and order of the misc tab
                    TARGET_LNGDES = "None"  #initialize

  #Infbox'Source local Menu =' - MENUNAME #checked: array passed in

  #reset the local menu messages dataset for writing
  Raz [F:AML]  #local menu header

  Raz [F:AST]  #local menu messages for read
  Raz [F:ADV]  #local miscellaneous table message for write
  Raz [F:ADI]  #miscellaneous table records
  UPD_OK = 2

  #get the local menu messages to be writen
  Filter [F:AST] Where [F:AST]LANCHP = val(MENUNAME)
&                and [F:AST]LANNUM > 0
&                and [F:AST]LAN = "ENG" #only get default language, because the insert generate for other languages.
  #Infbox'Number of local menu source messages: [F:AST] = ' - num$(rowcount([F:AST]))

  #do any validation here, setting UPD_OK = 1, on failures

  #Write local menu messages to the miscellaneous table
  If UPD_OK = 2 #check if any validation rules failed
    #MSGBREAK = 2 #remove this after debugging
    #loop through the all the local menu messages to write
    For [F:AST]
      #do transaction control on the write to miscellaneous table for locking or rollbacks
      Trbegin [F:ADI] #target menu messages

        UPD_OK = 2 #re-initialize for loop transaction control exception handling
        Raz [L]TARGET_CODE
        Raz [L]TARGET_LNGDES

        #trap all on error exception handler
        Onerrgo ERRHANDLE

        #Read the target menu messages to check for existing messages and order matching
        Read [F:ADI]CODE = val(MISCTAB); num$([F:AST]LANNUM)
        Filter [F:ADI] Where [F:ADI]NUMTAB = val(MISCTAB) and [F:ADI]CODE = num$([F:AST]LANNUM)
        #Infbox'Check it target already exist count [F:ADI] = ' - num$(rowcount([F:ADI]))
        If fstat
          [L]TARGET_CODE = 'None'
          [L]TARGET_LNGDES = 'None'
        Else
          #store the message order to to see if its the same message on the target menu before writing
          [L]TARGET_CODE = num$([F:ADI]CODE)
          #read the atextra translation for the long description on miscellaneous table
          Call LECTEXTRA([L]TARGET_LNGDES, "ATABDIV", "LNGDES", MISCTAB, [F:ADI]CODE) From ATEXTRA
          #Infbox"read atextra long desc: [L]TARGET_LNGDES = " - [L]TARGET_LNGDES
        Endif

        If UPD_OK = 2 #Passed write miscellaneous table validation
          #load the miscellaneous table from the local menu, defaulting columns not matching
          [F:ADI] = [F:AST]                                                     #class transfer for the common fields
          If dim([F:ADI]NUMTAB) > 0 : [F:ADI]NUMTAB = val(MISCTAB)        Endif #table number - setup index key to be updated
          If dim([F:ADI]CODE)   > 0 : [F:ADI]CODE   = num$([F:AST]LANNUM) Endif #code - part of index
          If dim([F:ADI]LNGDES) > 0
            #write the atextra translation for the long description to misc tab
            Call MAJTEXTRA([F:AST]LANMES, "ATABDIV", "LNGDES", MISCTAB, [F:ADI]CODE) From ATEXTRA #translate long description                                   #load long description
          Endif
          If dim([F:ADI]SHODES) > 0
            #write the atextra translation for the short description to misc tab
            Call MAJTEXTRA([F:AST]LANMES, "ATABDIV", "SHODES", MISCTAB, [F:ADI]CODE) From ATEXTRA #short description - default long description
          Endif
          If dim([F:ADI]DEFVAL) > 0 : [F:ADI]DEFVAL = 1             Endif       #default value - defaulting "local Menu" data type
          If dim([F:ADI]DEPCOD) > 0 : [F:ADI]DEPCOD = ""            Endif       #dependency - defaulting null alphnumeric "Miscellaneous table set-up" data type
          If dim([F:ADI]SOC)    > 0 : [F:ADI]SOC    = ""            Endif       #group of company - defaulting null alphanumeric "Company Grouping" data type
          If dim([F:ADI]LEG)    > 0 : [F:ADI]LEG    = DOSLEGMIG     Endif       #legislation - migration folder legislation
          If dim([F:ADI]ENAFLG) > 0 : [F:ADI]ENAFLG = 2             Endif       #active flag - defaulting 2 = "Yes"
        Endif

        #If MSGBREAK = 2 #remove this after debugging
          #Call LECTEXTRA([L]LNGDES, "ATABDIV", "LNGDES", MISCTAB, [F:ADI]CODE) From ATEXTRA
          #Infbox"look in variable from misc tab [L]LNGDES = "-num$([L]LNGDES)
          #Call LECTEXTRA([L]SHODES, "ATABDIV", "SHODES", MISCTAB, [F:ADI]CODE) From ATEXTRA
          #Infbox"look in variable from misc tab [L]SHODES = "-num$([L]SHODES)
          #Infbox"look in target Misc tab [F:ADI]NUMTAB  = "-num$([F:ADI]NUMTAB)
          #Infbox"look in target Misc tab [F:ADI]CODE    = "-num$([F:ADI]CODE)
          #Infbox"look in target Misc tab [F:ADI]LEG     = "-num$([F:ADI]LEG)
          #MSGBREAK = 1
        #Endif

        #build the message for the record written to the log file
        MSG = (" - " + num$([F:ADI]CODE)
&                    + " : " + num$([F:AST]LANMES)
&                    + " : " + num$([F:AST]LANMES)
&                    + " : " + num$([F:ADI]DEFVAL)
&                    + " : " + num$([F:ADI]LEG)
&                    + " : " + num$([F:ADI]SOC)
&                    + " : " + num$([F:ADI]ENAFLG)
&             )

        #check if the target misc table message already exist in the same order
        If num$([F:AST]LANNUM) = [L]TARGET_CODE
&       and num$([F:AST]LANMES) = [L]TARGET_LNGDES
          UPD_OK = 1
          #Call ECR_TRACE("Already Exist: " + MSG,0) From GESECRAN
          MSG = (" Already Exist: " + MSG)
        Else
          #write the 10000 range local menu record
          Write [F:ADI]
          If fstat
            If fstat = 3 #record already exists
              #Call ECR_TRACE("Already Exists: " + MSG,0) From GESECRAN
              MSG = (" Already Exist: "  + MSG)
              #Do we overwite the message with an update?
              #Rewrite
              If fstat
                UPD_OK = 1
                #Call ECR_TRACE("Error Updating: " + MSG,0) From GESECRAN
                MSG = ("Error Updating: " + MSG)
              Endif
            Else
              #Catch all for anything other than duplicate record exist as above
              UPD_OK = 1
              #Call ECR_TRACE("Error Inserting: " + MSG,0) From GESECRAN
              MSG = ("Error Inserting: " + MSG)
            Endif
          Endif
        Endif

        #remove this after debugging
        #If MSGBREAK = 2
        #  Infbox"Write fstat =" - num$(fstat)
        #Endif
        #MSGBREAK = 1

        #Transaction control commit changes or rollback
        If UPD_OK = 2
          #Commit
          Rollback #remove this
          #write sucessful record to the log file
          Call ECR_TRACE("Successful: " + MSG,0) From GESECRAN
        Else
          Rollback
          #write sucessful record to the log file
#          Call TRACE(2, "UTIMIG_LMMT", "Failed: " + MSG) From EXTTRACELOG
          Call ECR_TRACE("Failed: " + MSG,-1) From GESECRAN
        Endif

      #End: Trbegin [F:ADV]

    Next #get next record in local menu message filter

  Endif

End #end subprog MIGRATE_TABLE ###########################################################################

$ERRHANDLE
  Call ECR_TRACE("Error: " + num$(errn)-errmes$(errn)-errm, 1) From GESECRAN
  UPD_OK = 2
Resume #to return to instruction after onerrgo exception was encountered


End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT90 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif
If [F:ADS]MODULE(14)<>2 : End : Endif
Call MAJ_EMHRMAJ90_LMMSC(APPLI)
End

#######################################################################
# To execute during DOSMAJ90 process (validation of folder)
# call by DOSMAJ90
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(14)<>2 : End : Endif
Call MAJ_EMHRMAJ90_LMMSC(APPLI)
End

