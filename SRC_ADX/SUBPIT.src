#<AdxTL>@(#)10.0.0.0 $Revision$
######################################################################################
$ACTION
#Infbox "ACTION="+ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "RAZCRE"    : Gosub RAZCRE
 When "RAZDUP"    : Gosub RAZCRE
 When "VERIF_MOD" : Gosub VERIF
 When "VERIF_CRE" : Gosub VERIF
 When "CREATION"  : Gosub TR_CRE
 When "MODIF"     : Gosub TR_MOD
 When "LIENS"     : Gosub LIENS
 When "SETBOUT"   : Gosub SETBOUT
 ###autres actions : SELPIT
 When "SEL_TABLE"    : Gosub SEL_TABLE
 When "FILTRE"       : Gosub FILTRE
 When Default
Endcase
Return



######################################################################################
Subprog AP_TYP(VALEUR)
Variable Integer VALEUR
    Raz [M:PIT1]ABRFIL , [M:PIT1]TABFIL , [M:PIT1]NB
    Case VALEUR
        When 1 : #PLM Articles
                [M:PIT1]EXPORT=1 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "ITMMASTER" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "ITMBPS" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "ITMFACILIT" : [M:PIT1]NB+=1
        When 2 : #PLM Nomenclatures
                [M:PIT1]EXPORT=1 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "BOM" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "BOMD" : [M:PIT1]NB+=1
        When 3 : #Ordonnancement OF
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "OPERATIONS" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "MFGHEAD" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "MFGITM" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "ORDERS" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "SCHEDULING" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "ITMMASTER" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "ITMFACILIT" : [M:PIT1]NB+=1
        When 4 : #Ordonnancement Opérations
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "OPERATIONS" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "MFGOPE" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "MFGHEAD" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "MFGITM" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "ORDERS" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "SCHEDULING" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "ITMMASTER" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "ITMFACILIT" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "WORKSTATIO" : [M:PIT1]NB+=1
        When 5 : #Ordonnancement Successions
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "OPERATIONS" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "MFGHEAD" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "MFGOPE" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "SCHEDULING" : [M:PIT1]NB+=1
        When 6 : #Ordonnancement Articles
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "MFGITM" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "ITMMASTER" : [M:PIT1]NB+=1
        When 7 : #Ordonnancement Centres de charge
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "TABWRKCTR" : [M:PIT1]NB+=1
        When 8 : #Ordonnancement Postes de charge
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "WORKSTATIO" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "TABWRKCTR" : [M:PIT1]NB+=1
        When 9 : #Ordonnancement Postes par Centre de charge
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "WORKSTATIO" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "TABWRKCTR" : [M:PIT1]NB+=1
        When 10 : #Ordonnancement Ressources secondaires
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "WORKSTATIO" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "ITMMASTER" : [M:PIT1]NB+=1
        When 11 : #Ordonnancement Postes de charges de remplacement
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "RPLWST" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "WORKSTATIO" : [M:PIT1]NB+=1
        When 12 : #Ordonnancement Variations de capacité par poste
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "CAPVAR" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "WORKSTATIO" : [M:PIT1]NB+=1
        When 13 : #Ordonnancement Clients
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPCUSTOMER" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPADDRESS" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "CONTACT" : [M:PIT1]NB+=1
        When 14 : #Ordonnancement Affaires
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "OPPOR" : [M:PIT1]NB+=1
        When 15 : #Ordonnancement Commandes
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "SORDER" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "MFGITM" : [M:PIT1]NB+=1
        When 16 : #Ordonnancement Nomenclatures
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "ORDERS" : [M:PIT1]NB+=1
        When 17 : #Ordonnancement Achats
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "ORDERS" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "MFGMAT" : [M:PIT1]NB+=1
        When 18 : #Ordonnancement Stocks
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "ITMMVT" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "MFGMAT" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "ITMFACILIT" : [M:PIT1]NB+=1
        When 19 : #MMS Articles / Pièces détachées
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "ITMMASTER" : [M:PIT1]NB+=1
        When 20 : #MMS Centres de coût / Sections analytiques
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "CACCE" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "FACILITY" : [M:PIT1]NB+=1
        When 21 : #MMS Sites de stockage
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "FACILITY" : [M:PIT1]NB+=1
        When 22 : #MMS Stock article/site
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "ITMMVT" : [M:PIT1]NB+=1
        When 23 : #MMS Journal des stocks
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "STOJOU" : [M:PIT1]NB+=1
        When 24 : #MMS Mouvements
                [M:PIT1]EXPORT=1 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "SMVTH" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "SMVTD" : [M:PIT1]NB+=1
        When 25 : #MMS Fournisseurs
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPSUPPLIER" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPARTNER" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPADDRESS" : [M:PIT1]NB+=1
        When 26 : #MMS Contacts fournisseurs
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "CONTACT" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "CONTACTCRM" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPSUPPLIER" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPARTNER" : [M:PIT1]NB+=1
        When 27 : #MMS Classifications fournisseurs
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPSUPPLIER" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPARTNER" : [M:PIT1]NB+=1
        When 28 : #MMS Articles fournisseurs
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "ITMBPS" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "PPRICLIST" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "ITMMASTER" : [M:PIT1]NB+=1
        When 29 : #MMS Demandes d’achats
                [M:PIT1]EXPORT=1 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "PREQUIS" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "PREQUISD" : [M:PIT1]NB+=1
        When 30 : #MMS Avancement demandes d’achats
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "PREQUIS" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "PREQUISD" : [M:PIT1]NB+=1
        When 31 : #MMS Affaires
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "OPPOR" : [M:PIT1]NB+=1
        When 32 : #MMS Unités
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "TABUNIT" : [M:PIT1]NB+=1
        When 33 : #MMS Utilisateurs
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "AUTILIS" : [M:PIT1]NB+=1
        When 34 : #MMS Conversions d'unités
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "TABCOEFF" : [M:PIT1]NB+=1
        When 35 : #SCM Articles/Produits
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "ITMMASTER" : [M:PIT1]NB+=1
        When 36 : #SCM Articles/Conversions
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "ITMMASTER" : [M:PIT1]NB+=1
        When 37 : #SCM Articles/Critères
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "ITMMASTER" : [M:PIT1]NB+=1
        When 38 : #SCM Clients
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPCUSTOMER" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPARTNER" : [M:PIT1]NB+=1
        When 39 : #SCM Sites
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "FACILITY" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPCUSTOMER" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPARTNER" : [M:PIT1]NB+=1
        When 40 : #SCM Sites/Critères
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "FACILITY" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPCUSTOMER" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPARTNER" : [M:PIT1]NB+=1
        When 41 : #SCM Historique de ventes
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "SORDERQ" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "ITMMASTER" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPCUSTOMER" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPARTNER" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "SORDER" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "SORDERP" : [M:PIT1]NB+=1
        When 42 : #SCM En-cours commandes
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "SORDERQ" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "ITMMASTER" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPCUSTOMER" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPARTNER" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "SORDER" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "SORDERP" : [M:PIT1]NB+=1
        When 43 : #SCM Prévisions de ventes
                [M:PIT1]EXPORT=1 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "ORDERS" : [M:PIT1]NB+=1
        When 44 : #SCM Articles/Sites
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "ITMFACILIT" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "ITMMASTER" : [M:PIT1]NB+=1
        When 45 : #REACH Articles
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "ITMMASTER" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "ITMBPS" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPSUPPLIER" : [M:PIT1]NB+=1
        When 46 : #REACH Fournisseurs
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPSUPPLIER" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPARTNER" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPADDRESS" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "CONTACT" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "CONTACTCRM" : [M:PIT1]NB+=1

#        # Issue 73734 - 2012-02-22 by RBA - Schémas
#        When 47 : #Ordonnancement Schéma hebdomadaire
#                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
#                [M:PIT1]TABFIL([M:PIT1]NB) = "TABWEEDIA" : [M:PIT1]NB+=1
#        When 48 : #Ordonnancement Schéma horaires
#                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
#                [M:PIT1]TABFIL([M:PIT1]NB) = "DIAHOU" : [M:PIT1]NB+=1

        When 47 : #ENERGY Ecritures
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPARTNER"   : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "COMPANY"    : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "FACILITY"   : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "GACCENTRY"  : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "GACCENTRYD" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "GACCENTRYA" : [M:PIT1]NB+=1
        When 48 : # Fichier des écritures comptables
                [M:PIT1]EXPORT=2 : Affzo [M:PIT1]EXPORT
                [M:PIT1]TABFIL([M:PIT1]NB) = "BPARTNER"   : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "GACCENTRY"  : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "GACCENTRYD" : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "GACCOUNT"   : [M:PIT1]NB+=1
                [M:PIT1]TABFIL([M:PIT1]NB) = "GJOURNAL"   : [M:PIT1]NB+=1
    Endcase
    For  nolign = 1 To [M:PIT1]NB
        Read [ATB]CODFIC=[M:PIT1]TABFIL(nolign-1)
        If !fstat
           [M:PIT1]ABRFIL(nolign-1) = [F:ATB]ABRFIC
        Endif
    Next
End



######################################################################################
$OUVRE
If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
Return

$RAZCRE
[M:PIT1]STDFLG=1
Affzo [M:PIT1]STDFLG
Gosub GERESTD
Call AP_EXPORT([M:PIT1]EXPORT)
Call AP_NORECFLG([M:PIT1]NORECFLG)
###
Call AP_HEATYP([M:PIT1]HEATYP)
# Affichage pour que les grizo soient effectifs
Gosub AFFZONE From GOBJSUB
For I=0 To [M]NBPIZ-1
    If [M:PIT1]HEATYP<>4
        Grizo [M:PIT1]DES(I)
    Else
        Actzo [M:PIT1]DES(I)
    Endif
Next I
Return

$SETBOUT
If varmode([M:PIT1]LNG)<>3  : #zone visible
   Chgfmt [M:PIT1]LNG With "-NP+zF:5"
Endif
If !GSOPHIA
    If [M:PIT1]STDFLG=2
        Call VIREBOUT(CHAINE,"A") From GOBJET
    Endif
Endif
Return

$GERESTD
If !GSOPHIA
    If [M:PIT1]STDFLG=2
        Grizo [M:PIT1]INTIT
        Grizo [M:PIT1]10
        Grizo [M:PIT1]15
        Grizo [M:PIT1]20
    Else
        Actzo [M:PIT1]INTIT
        Actzo [M:PIT1]10
        Actzo [M:PIT1]15
        Actzo [M:PIT1]20
    Endif
    Grizo [M:PIT1]STDFLG
Endif
Return
######################################################################################
$LIENS
Call AP_TYP([M:PIT1]TYP)
Gosub GERESTD
Call AP_EXPORT([M:PIT1]EXPORT)
Call AP_NORECFLG([M:PIT1]NORECFLG)
Call AP_HEATYP([M:PIT1]HEATYP)
# Chargement ecran PIVZON [PIZ] (tableau)
If dim([M:PIT1]NBPIZ) > 0
  Raz [M:PIT1]CODFIC,[M:PIT1]CODZONE,[M:PIT1]DES,[M:PIT1]WRKZON,[M:PIT1]FRM,[M:PIT1]NBPIZ,[M:PIT1]LNG
  nolign = 0
  For [PIZ]PIZ0 Where ID=[M:PIT1]ID
     nolign += 1
     [M:PIT1]=[F:PIZ]
     Call AP_CODZONE([M:PIT1]CODZONE(nolign-1))
  Next
  [M:PIT1]NBPIZ = nolign
    # Affichage pour que les grizo soient effectifs
    Gosub AFFZONE From GOBJSUB
    For I=0 To [M]NBPIZ-1
        If [M:PIT1]HEATYP<>4
            Grizo [M:PIT1]DES(I)
        Else
            Actzo [M:PIT1]DES(I)
        Endif
    Next I
Endif
Gosub GERESTD
Return

######################################################################################
$VERIF
If [M:PIT1]NBPIZ<1
   GERR=1 : GMESSAGE=mess(38,7710,1) : OK=0 : Return
Endif
Call AP_TYP([M:PIT1]TYP)
For  nolign = 1 To [M:PIT1]NBPIZ
    Call C_CODFIC([M:PIT1]CODFIC(nolign-1))
    If mkstat: GMESSAGE=[M:PIT1]CODFIC(nolign-1)-":"-GMESSAGE : OK=0 : Return : Endif
    Call C_CODZONE([M:PIT1]CODZONE(nolign-1))
    If mkstat: GMESSAGE=[M:PIT1]CODZONE(nolign-1)-":"-GMESSAGE : OK=0 : Return : Endif
    If [M:PIT1]EXPORT<>2 & [M:PIT1]FRM(nolign-1)<>""
        GERR=1 : GMESSAGE=mess(37,7710,1) : OK=0 : Return
    Endif
    If [M:PIT1]WRKZON(nolign-1)=2 & (nolign=1 | nolign=[M:PIT1]NBPIZ)
        GERR=1 : GMESSAGE=mess(41,7710,1) : OK=0 : Return
    Endif
    Read [ATZ]CODZONE=[M:PIT1]CODFIC(nolign-1);[M:PIT1]CODZONE(nolign-1)
    If fstat & [M:PIT1]EXPORT=2 & [M:PIT1]FRM(nolign-1)=""
        ##Une formule est obligatoire sur une zone à évaluer
         GMESSAGE=mess(42,7710,1)
         GMESSAGE=[M:PIT1]CODZONE(nolign-1)-":"-GMESSAGE : OK=0 : Return
    Elsif fstat & [M:PIT1]EXPORT<>2 & [M:PIT1]WRKZON(nolign-1)<>2
        ##En import, une zone qui n'est pas une zone de table est obligatoirement une zone de travail
         GMESSAGE=mess(65,7710,1)
         GMESSAGE=[M:PIT1]CODZONE(nolign-1)-":"-GMESSAGE : OK=0 : Return
    Endif
Next
Return

######################################################################################
$TR_CRE
Goto SUBCREMOD

$TR_MOD
# Mise à jour table PLMDEFVAL
If dim([M:PIT1]NBPIZ) > 0
     For [PIZ]PIZ0 Where ID = [M:PIT1]ID
       Delete [PIZ]
    #  Vérifier si un enregistrement est locké : si oui : Fin
       If fstat = 1
          GOK = -1
          Call RSTA("PIZ",[M:PIT1]ID) From GLOCK : Break
       Endif
     Next
Endif
If GOK < 0 Goto FINCREMOD Endif

$SUBCREMOD
 For  nolign = 1 To [M:PIT1]NBPIZ
   Raz [F:PIZ]
   [F:PIZ] = [M:PIT1]
   If [M:PIT1]HEATYP<>4
        Raz [F:PIZ]DES
   Endif
   [F:PIZ]ID    = [M:PIT1]ID
   [F:PIZ]LIN   = nolign
   If [F:PIZ]CREUSR  = ""
      [F:PIZ]CREUSR    = GUSER
      [F:PIZ]CREDAT    = date$
      Raz [F:PIZ]UPDUSR
      Raz [F:PIZ]UPDDAT
   Endif
   Write [PIZ]
   If fstat
    GOK = 0 : Call FSTA("PIZ") From GLOCK : Break
   Endif

 Next nolign

$FINCREMOD
# Retour de la CREATION et de la MODIF
Return


######################################################################################
Subprog AVANT_NBPIZ
    Call AP_TYP([M:PIT1]TYP)
End

######################################################################################
Subprog C_CODFIC(VALEUR)
Variable Char    VALEUR()
If find(VALEUR,[M:PIT1]TABFIL)=0
    GMESSAGE = mess(83,123,1)
    mkstat = 2
    End
Endif
End

######################################################################################
Subprog C_CODZONE(VALEUR)
Variable Char    VALEUR()
If [M:PIT1]CODFIC(nolign-1)<>"" & VALEUR=""
    GMESSAGE = mess(10,123,1)
    mkstat = 2
    End
Endif
##Read [ATZ]CODZONE=[M:PIT1]CODFIC(nolign-1);VALEUR
##If fstat & [M:PIT1]EXPORT<>2
##    GMESSAGE = mess(23,100,1)
##    mkstat = 2
##    End
##Endif
For I=0 To NBPIZ
    If [M:PIT1]CODFIC(nolign-1)+"/"+VALEUR=[M:PIT1]CODFIC(I)+"/"+[M:PIT1]CODZONE(I) & I<>nolign-1
        GMESSAGE = mess(29,100,1)-num$(I+1)
        mkstat = 2
        End
    Endif
Next I
If [M:PIT1]HEATYP<>4
    Grizo [M:PIT1]DES(nolign-1)
Else
    Actzo [M:PIT1]DES(nolign-1)
Endif
End

######################################################################################
Subprog AP_CODZONE(VALEUR)
Variable Char    VALEUR()
 Read [ATZ]CODZONE=[M:PIT1]CODFIC(nolign-1);VALEUR
 If fstat=0
    #il s'agit d'une zone de table
    If [M:PIT1]DES(nolign-1)="" | [M:PIT1]HEATYP<>4 | [M:PIT1]CODZONE(nolign-1)<>VALEUR
        Call TEXTE([F:ATZ]NOCOURT,[M:PIT1]DES(nolign-1)) From OBJDIV
    Endif
    Raz [ATY]
    Read [ATY]CODTYP=[F:ATZ]CODTYP
    If fstat | [F:ATY]LNGTYP=0
        [M:PIT1]LNG(nolign-1)=[F:ATZ]LONG
    Else
        [M:PIT1]LNG(nolign-1)=[F:ATY]LNGTYP
    Endif
 Else
    #il s'agit d'une formule
    If [M:PIT1]HEATYP<>4
        Raz [M:PIT1]DES(nolign-1) : Affzo [M:PIT1]DES(nolign-1)
    Endif
    ##en import, on est forcement sur une zone non gérée
    If [M:PIT1]EXPORT<>2
       [M:PIT1]WRKZON(nolign-1)=2 : Affzo [M:PIT1]WRKZON(nolign-1)
    Endif
 Endif
If [M:PIT1]HEATYP<>4
    Grizo [M:PIT1]DES(nolign-1)
Else
    Actzo [M:PIT1]DES(nolign-1)
Endif
End

######################################################################################
Subprog AS_FRM(VALEUR)
Variable Char    VALEUR()
If [M:PIT1]EXPORT<>2
    [S]mkstat=1
Endif
End


######################################################################################
Subprog AM_TYP(VALEUR)
Variable Integer VALEUR
Call AP_TYP(VALEUR)
End
######################################################################################
Subprog AM_WRKZON(VALEUR)
Variable Integer VALEUR
If nolign=1 & VALEUR=2
    GMESSAGE=mess(41,7710,1)
    GERR=1
    [S]mkstat=2
Endif
End

######################################################################################
Subprog AS_HEAMES(VALEUR)
Variable Char    VALEUR()
If [M]HEATYP<>3
    [S]mkstat=1
Endif
End

Subprog AS_NORECMES(VALEUR)
Variable Char    VALEUR()
If [M]NORECFLG<>2
    [S]mkstat=1
Endif
End

######################################################################################
Subprog AP_NORECFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
    If !GSOPHIA
        If [M:PIT1]STDFLG=2
            Grizo [M:PIT1]NORECMES
        Else
            Actzo [M:PIT1]NORECMES
        Endif
    Else
        Actzo [M:PIT1]NORECMES
    Endif
Else
    Raz [M:PIT1]NORECMES
    Grizo [M:PIT1]NORECMES
Endif
End

######################################################################################
Subprog AP_EXPORT(VALEUR)
Variable Integer VALEUR
If VALEUR=2
    If !GSOPHIA
        If [M:PIT1]STDFLG=2
            Grizo [M:PIT1]NORECFLG
        Else
            Actzo [M:PIT1]NORECFLG
        Endif
    Else
        Actzo [M:PIT1]NORECFLG
    Endif
Else
    [M:PIT1]NORECFLG=1
    Grizo [M:PIT1]NORECFLG
    ##VPO 07/10/10 bug68041 [M:PIT1]HEATYP=1
    Grizo [M:PIT1]HEAMES
Endif
End

######################################################################################
Subprog AP_HEATYP(VALEUR)
Variable Integer VALEUR
If VALEUR=0 : VALEUR=1 : Endif
##VPO 07/10/10 bug68041
If VALEUR > 2 & [M]EXPORT=1 : VALEUR=2 : Endif
If VALEUR=3
    If !GSOPHIA
        If [M:PIT1]STDFLG=2
            Grizo [M:PIT1]HEAMES
        Else
            Actzo [M:PIT1]HEAMES
        Endif
    Else
        Actzo [M:PIT1]HEAMES
    Endif
Elsif VALEUR=4
    If !GSOPHIA
        If [M:PIT1]STDFLG=2
            Grizo [M:PIT1]DES
        Else
            Actzo [M:PIT1]DES
        Endif
    Else
        Actzo [M:PIT1]DES
    Endif
Else
    Raz [M:PIT1]HEAMES
    Grizo [M:PIT1]HEAMES
Endif
End


######################################################################################
########################################
# Action Seltable SELPIT
########################################
$SEL_TABLE
Local Char ABR(15)
Local Char FILTPIT(15)
ABR = VALEUR
OBJET = "PIT"
[L]FILTPIT= "TYP="+PARAM(1) : # type de pivots
Return

$FILTRE
If dim([L]FILTPIT)>0 & [L]FILTPIT<>""
 FILTSUP = [L]FILTPIT
Endif
Return

##################################################
Subprog CONTPIT(AZC,OBJTYP)
Variable Char    AZC()
Value    Integer OBJTYP
If OBJTYP=0 : End : Endif
If clalev([F:PIT])=0 : Local File PIVOTS [PIT] : Endif
Read [PIT]PIT0 = AZC
If fstat : End : Endif
If [F:PIT]TYP<>OBJTYP
  GMESSAGE = mess(52,7710,1)-':'-mess(OBJTYP,2240,1) : # Le pivot n'EST PAS DU type VOULU
  mkstat = 2 : End
Endif
End


######################################################################################


######################################################################################
########################################
# Bouton COPIE
########################################
#-------------------------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File PIVOTS [PIT1]
 Local File PIVZON [PIZ1]
Else
 Local File =[M]DOSORG+".PIVOTS" [PIT1]
 Local File =[M]DOSORG+".PIVZON" [PIZ1]
Endif
If [M]DOSDES=nomap
 Local File PIVOTS [PIT2]
 Local File PIVZON [PIZ2]                # FQ 64773 GA 05/2010 avant [PIV2]
Else
 Local File =[M]DOSDES+".PIVOTS" [PIT2]
 Local File =[M]DOSDES+".PIVZON" [PIZ2]
Endif
OK = 1
If GTRACE=""
 Read [PIT2]PIT0=TABLE
 If !fstat
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [PIT1], [PIZ1]
&              , [PIT2], [PIZ2]
Return

$TR_COP
GOK = 1
Trbegin [PIT2] , [PIZ2]
 Read [PIT2]PIT0=TABLE
 Delete [PIT2] Where ID=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".PIVOTS" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("PIT2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [PIZ2] Where ID=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".PIVZON" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("PIZ2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [PIT1]PIT0 Where ID=TABLE
  [F:PIT2] = [F:PIT1]
  If dim([F:PIT2]UPDUSR)>0 : [F:PIT2]UPDUSR= GUSER : Endif
  If dim([F:PIT2]UPDDAT)>0 : [F:PIT2]UPDDAT= date$ : Endif
  If dim([F:PIT2]UPDTIM)>0 : [F:PIT2]UPDTIM= time  : Endif
  Write [PIT2]
  If fstat
   GOK=0 : Call FSTA("PIT2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [PIZ1]PIZ0 Where ID=TABLE
  [F:PIZ2] = [F:PIZ1]
  Write [PIZ2]
  If fstat
   GOK=0 : Call FSTA("PIZ2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 If GOK<1 : Goto AB_TR_COP : Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

######################################################################################
######################################################################################
Subprog IB_NBPIZ
If GSOPHIA
    If varmode([M:PIT1]LNG)=3 : #zone invisible
        [V]GBOUT1="LNG"-mess(2,35,1)
    Else
        [V]GBOUT1="LNG"-mess(3,35,1)
    Endif
Else
    Raz [V]GBOUT1
Endif
End

Subprog B1_NBPIZ
If GSOPHIA
    If varmode([M:PIT1]LNG)=3  : #zone invisible
       Chgfmt [M:PIT1]LNG With "NP+zF:5"
       Affzo [M:PIT1]20
    Else
       Chgfmt [M:PIT1]LNG With "-NP+zF:5"
    Endif
Endif
End


