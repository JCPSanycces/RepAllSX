#<AdxTL>@(#)9.0.0.0 $Revision$ Param鴲age des consultations
Raz GBIDC1 , GPILOBJ
Call OBJET("ACN",GBIDC1,"") From GOBJET
End

$ACTION
Case ACTION
 When "LIENS"   : Gosub LIENS
 When "INICRE"  : Gosub INICRE
 When "SETBOUT" : Gosub SETBOUT
 When "EXEBOUT" : Gosub EXEBOUT
 When default
Endcase
Return

$LIENS
Call TEXTE([M]LIBEL,[M]DES) From OBJDIV
Raz [M]SCRNAM1, [M]SCRNAM2, [M]SCRABB1, [M]SCRABB2, [M]SCRNAM0, [M]SCRABB0
If !clalev([F:AWI]) : Local File AWINDOW [AWI] : Endif
If !clalev([F:AMK]) : Local File AMSK    [AMK] : Endif
Read [AWI]AWI0 = [M]WND1
If !fstat
 [M]SCRNAM1 = [F:AWI]MSKENT
 [M]SCRNAM2 = [F:AWI]NOMMSK(0)
 If [M]SCRNAM1<>""
  Read [AMK]CODMSK = [M]SCRNAM1
  If !fstat : [M]SCRABB1 = [F:AMK]ABRMSK : Endif
 Endif
 If [M]SCRNAM2<>""
  Read [AMK]CODMSK = [M]SCRNAM2
  If !fstat : [M]SCRABB2 = [F:AMK]ABRMSK : Endif
 Endif
Endif
Read [AWI]AWI0 = [M]WND0
If !fstat
 [M]SCRNAM0 = [F:AWI]NOMMSK(0)
 If [M]SCRNAM0<>""
  Read [AMK]CODMSK = [M]SCRNAM0
  If !fstat : [M]SCRABB0 = [F:AMK]ABRMSK : Endif
 Endif
Endif
Call GRISE_SCR([M]WND0)
Call GRISE_FIL([M]OBJET)
Call GRISE_ABR([M]FILNAM)
Return

Subprog GRISE_SCR(FENETRE)
Value Char FENETRE
If clalev([F:AMZ])=0 : Local File AMSKZON [AMZ] : Endif
Local Integer OK
OK = 0
If FENETRE<>""
 Call LECTURE("AWI",FENETRE,"") From CONTOBJ
 If !fstat & [F:AWI]NOMMSK(0)<>""
  For [AMZ]CODE Where CODMSK=[F:AWI]NOMMSK(0)
   If [F:AMZ]CODTYP="GTC"
    OK = 1 : Break
   Endif
  Next AMZ
 Endif
Endif
If OK
 Actzo [ACN1]SCRCOD
Else
 Effzo [ACN1]SCRCOD
 Grizo [ACN1]SCRCOD
Endif
End

Subprog GRISE_FIL(OBJET)
Value Char OBJET
Local Integer OK
OK = 1
If OBJET<>""
 If clalev([F:AOB])=0 : Local File AOBJET [AOB] : Endif
 Read [AOB]ABREV = OBJET
 If !fstat
  OK = 0
 Endif
Endif
If !OK
 Diszo [ACN3]FILNAM
Else
 Actzo [ACN3]FILNAM
Endif
End

Subprog GRISE_ABR(NOMFIC)
Value Char NOMFIC
If NOMFIC<>""
 Actzo [ACN3]FILABB , FILKEY , ZSITE , ZACC , FILCND , MAGNETO
Else
 Effzo [ACN3]FILABB , FILKEY , ZSITE , ZACC , FILCND , MAGNETO
 Grizo [ACN3]FILABB , FILKEY , ZSITE , ZACC , FILCND , MAGNETO
Endif
End

$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET
If !CLECUR or REP<>"" or !VERROU
 Call VIREBOUT(CHAINE,"V234") From GOBJET : # Validation, Copie, Visu , Visu web
Endif
If filinfo(filpath("TRT","WWCNS"+CLECUR1,"src",0),0)<0
 Call VIREBOUT(CHAINE,"34") From GOBJET
Endif
If GBROWS
 Call VIREBOUT(CHAINE,"3") From GOBJET : # Visu
Endif
If GVIRTDIR=""
 Call VIREBOUT(CHAINE,"4") From GOBJET : # Visu Web
Endif
Return

$EXEBOUT
Case REP
 When "V" : Call GENERE(CLECUR1)
 When "3" : Call VISUM(CLECUR1) 
 When "4" : Call VISUWEB(CLECUR1) 
Endcase
Return 

$INICRE
# mb 24.8.1 bug 10169 Mise à jour du code consultation sur les windows associées
Local Char WWIN(GLONFEN), WSYMBOLE(30)
For WWIN=[M:ACN1]WND0,[M:ACN1]WND1
 If WWIN<>""
  Read [AWI]AWI0 = WWIN
  If !fstat & [F:AWI]CNS=""
   WSYMBOLE = "AWI"+WWIN
   Lock =WSYMBOLE With lockwait=0
   If fstat
    GMESSAGE = mess(14,126,1)-WWIN+"\"+mess(60,100,1) : # fenêtre ... enregistrement verrouillé
    GOK = 0 : Break
   Else
    Readlock [AWI]AWI0 = WWIN
    If fstat=1
     GOK = -1 : GLOCK = "$AWINDOW"-WWIN : Break
    Elsif fstat
     GOK = 0 : Call RSTA("AWI",WWIN) From GLOCK : Break
    Else
     [F:AWI]CNS = [M:ACN0]COD
     Rewrite [AWI]
     If fstat
      GOK=0 : Call FSTA("AWI") From GLOCK : Break
     Endif
    Endif
   Endif
  Endif
 Endif
Next WWIN
Return

########################################################################
Subprog GENERE(CNSCOD)
Value Char CNSCOD()
Local Integer OK
# Validation consultation
OK=2 : Call OUINON(mess(23,126,1)-CNSCOD,OK) From GESECRAN
If OK=2
 # Traitements WWCNSxxx, CNSxxxSTD
 Call GENTRT(nomap,CNSCOD) From ACNTRT
 # Fonction et action CONSxxx
 Call GENACT(nomap,CNSCOD)
Endif
End

Subprog GENDOS(APPLI)
Value Char APPLI
Local File =APPLI+".ACONSULT" [ACN]
Local File =APPLI+".ACONSULT" [ACN2]
Local File =APPLI+".AMSK"     [AMK]
Local File =APPLI+".ATABLE"   [ATB]
Local File =APPLI+".AWINDOW"  [AWI]
For [ACN2]ACN0
 Call ECR_TRACE([F:ACN2]COD,0) From GESECRAN
 Call GENTRTSIL(APPLI,[F:ACN2]COD) From ACNTRT
Next
End

Subprog GENACT(APPLI,COD)
Value Char APPLI
Value Char COD
If clalev([F:ACT])=0 : Local File =APPLI+".ACTION"    [ACT] : Endif
If clalev([F:AFC])=0 : Local File =APPLI+".AFONCTION" [AFC] : Endif
If clalev([F:ACN])=0 : Local File =APPLI+".ACONSULT"  [ACN] : Endif
Local Char    ACTION(GLONACT) , FENETRE(GLONFEN)
Local Integer FNCNUM
ACTION = "CONS"+COD
Read [ACN]ACN0 = COD
Read [ACT]ACTION = [L]ACTION
If fstat
 GOK = 1
 Trbegin [ACT]
  Raz [F:ACT]
  [F:ACT] = [F:ACN]
  [F:ACT]ACTION = [L]ACTION
  [F:ACT]INTITA = [F:ACN]LIBEL
  [F:ACT]TYPACT = max(1,[F:ACT]TYPACT)
  [F:ACT]MODULE = max(1,[F:ACT]MODULE)
  [F:ACT]PARAM3 = max(1,[F:ACT]PARAM3)
  [F:ACT]PARAM6 = max(1,[F:ACT]PARAM6)
  [F:ACT]AMSFLG = max(1,[F:ACT]AMSFLG)
  [F:ACT]ABTFLG = max(1,[F:ACT]ABTFLG)
  [F:ACT]PUBFLG = max(1,[F:ACT]PUBFLG)
  [F:ACT]TYP    = 2
  [F:ACT]TYPACT = 1
  [F:ACT]PARAM1 = COD
  [F:ACT]CREDAT = date$
  [F:ACT]CREUSR = GUSER
  If dim([F:ACT]CRETIM)>0 : [F:ACT]CRETIM = time : Endif
  Write [ACT]
  If fstat
   GOK = 0 : Call FSTA("ACT") From GLOCK
  Endif
 Commit
Endif
Read [AFC]CODINT = ACTION
If fstat
 Read [AFC]NUMFNC Last
 If fstat>2 : FNCNUM = 1 : Else : FNCNUM = [F:AFC]NUMFNC+1 : Endif
 If FNCNUM>=9001 & FNCNUM<=9999
  FNCNUM = 10000
 Endif
 If GADONIX<>2
  FNCNUM = max(FNCNUM,5001)
 Endif
 GOK = 1
 Trbegin [AFC]
  Raz [F:AFC]
  [F:AFC] = [F:ACN]
  [F:AFC]CODINT    = [L]ACTION
  [F:AFC]CODEXT    = [L]ACTION
  [F:AFC]NUMFNC    = FNCNUM
  [F:AFC]NOM       = [F:ACN]LIBEL
  [F:AFC]LIBMENU   = [F:ACN]LIBEL
  [F:AFC]TYPTRAIT  = 1
  [F:AFC]FCYAUZ    = 1
  [F:AFC]CREDAT    = date$
  [F:AFC]CREUSR    = GUSER
  [F:AFC]TYP       = 1
  [F:AFC]ACTION    = [L]ACTION
  If dim([F:AFC]CRETIM)>0 : [F:AFC]CRETIM = time : Endif
  Write [AFC]
  If fstat
   GOK = 0 : Call FSTA("AFC") From GLOCK
  Endif
 Commit
Endif
End

#############################################################################
$TRTCOP
If [M]DOSORG=nomap 
 Local File ACONSULT  [ACN1] 
 Local File ATEXTE    [ATX1] 
Else 
 Local File =[M]DOSORG+".ACONSULT"  [ACN1]
 Local File =[M]DOSORG+".ATEXTE"    [ATX1] 
Endif 
If [M]DOSDES=nomap 
 Local File ACONSULT  [ACN2] 
 Local File ATEXTE    [ATX2] 
Else 
 Local File =[M]DOSDES+".ACONSULT"  [ACN2]
 Local File =[M]DOSDES+".ATEXTE"    [ATX2]
Endif 
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ACN1], [ATX1], [ACN2], [ATX2]
Return

$TR_COP
GOK = 1
Trbegin [ACN2] , [ATX2]
 Delete [ACN2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ACONSULT" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ACN2","") From GLOCK : Goto AB_TR_COP
 Endif
 Read [ACN1]ACN0 = TABLE
 If !fstat
  [F:ACN2] = [F:ACN1]
  Call COPTEXTE([F:ACN1]LIBEL,[F:ACN2]LIBEL) From OBJDIV
  If dim([F:ACN2]UPDUSR)>0 : [F:ACN2]UPDUSR = GUSER : Endif
  If dim([F:ACN2]UPDDAT)>0 : [F:ACN2]UPDDAT = date$ : Endif
  If dim([F:ACN2]UPDTIM)>0 : [F:ACN2]UPDTIM = time : Endif
  If GOK>0
   Write [ACN2]
   If fstat
    GOK=0 : Call FSTA("ACN2") From GLOCK
   Endif
  Endif
  If GOK<0    : Goto ROLL_TR_COP
  Elsif GOK=0 : Goto AB_TR_COP 
  Endif
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif


#######################################################################
Subprog VISUWEB(CNSCOD)
Value Char    CNSCOD
If GBROWS<>0
 Call VISUM(CNSCOD)
Else
 Local Char    URL(200) , RETOUR(200) , AASEP(1) , PROGCNS(GLONADC)
 PROGCNS = "WWCNS"+CNSCOD
 Gosub NOMFIC From =PROGCNS
 AASEP = "/"
 If instr(1,GVIRTDIR,"\") : AASEP = "\" : Endif
 URL =  GVIRTDIR+AASEP+nomap+AASEP+"GEN"+AASEP+GLANGUE
 URL += AASEP+"FENW"+AASEP+BOITE+".xml"
 Callui RETOUR="" With     "UIAction="+chr$(1)+"OpenFile",
&                          "UILocalDir="+ chr$(1) +"HTTP",
&                          "UILocalFile="+ chr$(1) +URL
Endif
End

#######################################################################
Subprog VISUM(CNSCOD)
Value Char CNSCOD()

Local Integer MA , OK , REPONSE , ETABOU(1..GNBBOU)
Local Char    PROGCNS(GLONADC) , WINPROG(GLONADC) , WINPROG2(GLONADC) , MESSAGE(80)

PROGCNS = "WWCNS"+CNSCOD
Gosub NOMFIC From =PROGCNS
Call NOMTRTWIN(BOITE,WINPROG) From MSKDIV
Call NOMTRTWIN(CBOITE,WINPROG2) From MSKDIV

Onerrgo ERREUR From CONTROLE
Local File TABCUR [TCU] , TABCOUNTRY [TCY]
Call LECTURE("ACN",CNSCOD,"") From CONTOBJ
Call LECTURE("TCU",GSYSCUR,"") From CONTOBJ
Call LECTURE("TCY",GPAYS,"") From CONTOBJ
For MA=0 To 2
 If MA=2 & CODMSKDEF<>"" & evalue("dim([M:"+ABMSK(0)+"]ECRAN)>0")
  Call VERFGTC(CNSCOD,CODMSKDEF,CODMSKDEF,MESSAGE,OK) From GCONSULT
  If OK : NOMMSK(2) = "WM"+CNSCOD+CODMSKDEF : Endif
 Endif
 Gosub OUVRE_MSK From =PROGCNS
Next MA
Onerrgo
If GERREUR : GERREUR=0 : End : Endif

Gosub OUVRE_BOITE From =WINPROG
For MA=0 To 2
 Gosub GRISE_MSK From =PROGCNS
Next MA 
Call SAVBOUT From GESECRAN
ETABOU(GBFIN) = 1 
ETABOU(GVALI) = 1 
If NOMMSK(0)<>"" : ETABOU(GSPE1) = 1 : Endif
Call SETBOUT(ETABOU) From GESECRAN

$VISUM_SAI
Onerrgo CHUT
Gosub SAISIE_BOITE From =WINPROG
Onerrgo
Case REPONSE
 When GSTABOU2+100+2 : Gosub VISUM_CRIT : Goto VISUM_SAI
Endcase
Gosub FERME_BOITE From =WINPROG
Call RESTBOUT From GESECRAN
End

$VISUM_CRIT
Call SAVBOUT From GESECRAN
Raz ETABOU
ETABOU(GBFIN) = 1 
ETABOU(GVALI) = 1 
Call SETBOUT(ETABOU) From GESECRAN
MA = -1 : Gosub OUVRE_MSK From =PROGCNS
Gosub OUVRE_BOITE From =WINPROG2
MA = -1 : Gosub GRISE_MSK From =PROGCNS
Onerrgo CHUT
Gosub SAISIE_BOITE From =WINPROG2
Onerrgo
Gosub FERME_BOITE From =WINPROG2
Call RESTBOUT From GESECRAN
Return

$CHUT
Resume

##############################################
##    Etiquettes ecran ACN1
##############################################

Subprog C_WND1(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If VALEUR=""
 Effzo [M]SCRNAM1, SCRNAM2, SCRABB1, SCRABB2
 End
Endif
If !clalev([F:AWI]) : Local File AWINDOW [AWI] : Endif
If !clalev([F:AMK]) : Local File AMSK    [AMK] : Endif
Read [AWI]AWI0 = VALEUR
If fstat
 # Fenêtre inexistante
 GMESSAGE=VALEUR-mess(6,126,1) : mkstat=2 : End
Endif
[M]SCRNAM1 = [F:AWI]MSKENT
[M]SCRNAM2 = [F:AWI]NOMMSK(0)
If [M]SCRNAM1<>""
 Read [AMK]CODMSK = [M]SCRNAM1
 If !fstat
  [M]SCRABB1 = [F:AMK]ABRMSK
 Endif
Endif
If [M]SCRNAM2<>""
 Read [AMK]CODMSK = [M]SCRNAM2
 If !fstat
  [M]SCRABB2 = [F:AMK]ABRMSK
 Endif
Endif

If [M]SCRNAM1=""
 # Fenêtre sans écran d'entête
 GMESSAGE = VALEUR-":"-mess(17,126,1) : mkstat=2 : End
Elsif [M]SCRABB1=""
 # Ecran inexistant
 GMESSAGE = [M]SCRNAM1-mess(1,105,1) : mkstat=2 : End
Elsif [M]SCRNAM2=""
 # Fenêtre sans onglet
 GMESSAGE = VALEUR-":"-mess(19,126,1) : mkstat=2 : End
Elsif [M]SCRABB2=""
 # Ecran inexistant
 GMESSAGE = [M]SCRNAM2-mess(1,105,1) : mkstat=2 : End
Elsif [M]SCRABB1=[M]SCRABB2
 # Ecrans de même abréviation
 GMESSAGE = [M]SCRNAM1-[M]SCRNAM2-":"-mess(21,126,1) : mkstat=2 : End
Elsif !find("NBLIG",[F:AMK]BASPAG(0..[F:AMK]NBBLOC-1))
 # Ecran sans tableau de bas de page NBLIG
 GMESSAGE = [M]SCRNAM2-":"-mess(22,126,1)-"NBLIG" : mkstat=2 : End
Endif

Affzo SCRNAM1, SCRNAM2, SCRABB1,SCRABB2
End

Subprog C_WND0(VALEUR)
Variable Char    VALEUR()
Local Integer OK : OK=1
If VALEUR=""
 Effzo [M]SCRNAM0, SCRABB0
 Call GRISE_SCR(VALEUR)
 End
Endif
If !clalev([F:AWI]) : Local File AWINDOW [AWI] : Endif
If !clalev([F:AMK]) : Local File AMSK    [AMK] : Endif
Read [AWI]AWI0 = VALEUR
If fstat
 # Fenêtre inexistante
 GMESSAGE=VALEUR-mess(6,126,1) : mkstat=2 : End
Endif
[M]SCRNAM0 = [F:AWI]NOMMSK(0)
If [M]SCRNAM0<>""
 Read [AMK]CODMSK = [M]SCRNAM0
 If !fstat
  [M]SCRABB0 = [F:AMK]ABRMSK
 Endif
Endif

If [M]SCRNAM0=""
 # Fenêtre sans onglet
 GMESSAGE = VALEUR-":"-mess(19,126,1) : mkstat=2 : End
Elsif [M]SCRABB0=""
 # Ecran inexistant
 GMESSAGE = [M]SCRNAM0-mess(1,105,1) : mkstat=2 : End
Elsif [F:AWI]NBMSK>1
 # Fenêtre avec plusieurs onglets
 GMESSAGE = VALEUR-":"-mess(20,126,1) : mkstat=2 : End
Elsif [F:AWI]MSKENT<>""
 # Fenêtre avec écran d'entête
 GMESSAGE = VALEUR-":"-mess(18,126,1) : mkstat=2 : End
Elsif [M]SCRABB0=[M]SCRABB1
 # Ecrans de même abréviation
 GMESSAGE = [M]SCRNAM0-[M]SCRNAM1-":"-mess(21,126,1) : mkstat=2 : End
Elsif [M]SCRABB0=[M]SCRABB2
 # Ecrans de même abréviation
 GMESSAGE = [M]SCRNAM0-[M]SCRNAM2-":"-mess(21,126,1) : mkstat=2 : End
Endif

Affzo SCRNAM0, SCRABB0 
Call GRISE_SCR(VALEUR)
End

Subprog C_FLD1(VALEUR)
Variable Char    VALEUR()
If VALEUR="" 
 If [M]WND0="" : GMESSAGE=mess(10,123,1) : mkstat=2 : Endif : # Zone obligatoire
 End
Endif
If !clalev([F:AMZ]) : Local File AMSKZON [AMZ] : Endif
Read [AMZ]CODE = [M]SCRNAM1;VALEUR
If fstat
 GMESSAGE=mess(41,100,1) : mkstat=2 : # Champ inexistant
Endif
End

Subprog AS_FLD0(VALEUR)
Variable Char    VALEUR()
If [M]WND0="" : mkstat=1 : End : Endif
End

Subprog C_FLD0(VALEUR)
Variable Char    VALEUR()
Local Integer TYP0, TYP1, NOL
NOL = nolign-1
If VALEUR=""
 If [M]FLD1(NOL)="" : GMESSAGE=mess(10,123,1) : mkstat=2 : Endif : # Zone obligatoire
 End
Endif
If !clalev([F:AMZ]) : Local File AMSKZON [AMZ] : Endif
If !clalev([F:ATY]) : Local File ATYPE   [ATY] : Endif
Read [AMZ]CODE = [M]SCRNAM0;VALEUR
If fstat
 GMESSAGE=mess(41,100,1) : mkstat=2 : End : # Champ inexistant
Endif
If [M]FLD1(NOL)<>""
 Read [ATY]CODTYP = [F:AMZ]CODTYP 
 If !fstat : TYP0=[F:ATY]TYPTYP : Endif
 Read [AMZ]CODE = [M]SCRNAM1;[M]FLD1(NOL)
 If !fstat
  Read [ATY]CODTYP = [F:AMZ]CODTYP 
  If !fstat : TYP1=[F:ATY]TYPTYP : Endif
 Endif
 If TYP1<>TYP0
  GMESSAGE = mess(47,139,1)-mess(TYP1,30,1) : mkstat=2 : # Ce champ doit être de type
 Endif 
Endif
End

Subprog AS_DSYCRI(VALEUR)
Variable Integer VALEUR
If [M]FLD0(indice)="" or [M]FLD1(indice)="" : VALEUR=2 : mkstat=2 : Endif
End

##############################################
##    Etiquettes ecran ACN3
##############################################

Subprog AM_OBJET(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 If clalev([F:AOB])=0 : Local File AOBJET [AOB] : Endif
 Read [AOB]ABREV = VALEUR
 If !fstat & [M]FILNAM<>[F:AOB]NOMFIC
  [M]FILNAM = [F:AOB]NOMFIC
  Raz [M]FILABB : Call AV_FILABB([M]FILABB) : Affzo FILABB
  Raz [M]FILKEY : Call AV_FILKEY([M]FILKEY) : Affzo FILKEY
 Endif
Endif 
End

Subprog C_OBJET(VALEUR)
Variable Char    VALEUR()
Call GRISE_FIL(VALEUR)
End

Subprog AM_FILNAM(VALEUR)
Variable Char    VALEUR()
Raz [M]FILABB
End

Subprog C_FILNAM(VALEUR)
Variable Char    VALEUR()
Call GRISE_ABR(VALEUR)
End

Subprog AV_FILABB(VALEUR)
Variable Char    VALEUR()
If [M]FILNAM<>"" & VALEUR="" 
 If !clalev([F:ATB]) : Local File ATABLE [ATB] : Endif
 Read [ATB]CODFIC = [M]FILNAM
 If !fstat : VALEUR=[F:ATB]ABRFIC : Endif
Endif
End

Subprog AV_FILKEY(VALEUR)
Variable Char    VALEUR()
If [M]FILNAM<>"" & VALEUR="" 
 If !clalev([F:ATI]) : Local File ATABIND [ATI] : Endif
 Read [ATI]NUMLIG(2) = [M]FILNAM;1
 If !fstat : VALEUR=[F:ATI]CODIND : Endif
Endif
End

Subprog C_FILKEY(VALEUR)
Variable Char    VALEUR()
If !clalev([F:ATI]) : Local File ATABIND [ATI] : Endif
Read [ATI]CODIND = [M]FILNAM;VALEUR
If fstat : # Clé inexistante
 GMESSAGE = mess(6,114,1) : mkstat=2 
Endif
End

Subprog C_ZSITE(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Read [ATZ]CODZONE = [M]FILNAM;VALEUR
If fstat
 GMESSAGE = mess(22,124,1) : # Zone inexistante
 mkstat = 2 : End
Endif
End

Subprog C_ZACC(VALEUR)
Variable Char    VALEUR()
Call C_ZSITE(VALEUR)
End

Subprog AS_FILCND(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
NOL = indice
If [M]FILNAM="" or (NOL>0 & [M]FILCND(NOL-1)="") : mkstat=1 : Endif
End

Subprog AS_NBRCPNKEY
If [M]FILNAM=""
 Effzo 20 
Elsif adxgtb=1
 Gosub SETKEY
Endif
End

$SETKEY
If !clalev([F:ATI]) : Local File ATABIND [ATI] : Endif
Local Char EXPCLE(250)
Local Integer I, J, NBCMP
Read [ATI]CODIND = [M]FILNAM;[M]FILKEY
If fstat=0
 NBCMP = 0
 EXPCLE = [F:ATI]DESCRIPT
 While EXPCLE<>""
  I = instr(1,EXPCLE,"+") 
  J = instr(1,EXPCLE,"-")
  If    I & J  : I = min(I,J)
  Elsif J & !I : I = J
  Endif
  If !I : I=len(EXPCLE)+1 : Endif
  If I : [M]CPNKEY(NBCMP)=left$(EXPCLE,I-1) : EXPCLE = right$(EXPCLE,I+1)
  Else : EXPCLE = ""
  Endif
  NBCMP+=1
 Wend
 [M]NBRCPNKEY=NBCMP
 Affzo 20
Else
 Effzo 20 
Endif
Return

Subprog AS_CPNSCR(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
NOL=nolign-1
If NOL>0 & [M]CPNSCR(NOL-1)="" : mkstat=1 : End : Endif
GBOUT1 = mess(17,124,1) : # Dictionnaire écrans
End

Subprog C_CPNSCR(VALEUR)
Variable Char    VALEUR()
Local Integer NOL
NOL=nolign-1
If VALEUR=""
 If NOL=0
  # Zone obligatoire
  GMESSAGE = mess(10,123,1) : mkstat=2
 Endif
 End
Endif
If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
If !clalev([F:AMZ]) : Local File AMSKZON [AMZ] : Endif
If !clalev([F:ATY]) : Local File ATYPE   [ATY] : Endif
Local Integer TYP1, TYP2
Read [AMZ]CODE = [M]SCRNAM1;VALEUR
If fstat
 GMESSAGE=mess(41,100,1) : mkstat=2 : End : # Champ inexistant
Endif
Read [ATY]CODTYP = [F:AMZ]CODTYP 
If !fstat : TYP1=[F:ATY]TYPTYP : Endif
Read [ATZ]CODZONE = [M]FILNAM;[M]CPNKEY(NOL)
If !fstat
 Read [ATY]CODTYP = [F:ATZ]CODTYP 
 If !fstat : TYP2=[F:ATY]TYPTYP : Endif
Endif
If TYP1<>TYP2
 GMESSAGE = mess(47,139,1)-mess(TYP2,30,1) : mkstat=2 : # Ce champ doit être de type
Endif 
End

