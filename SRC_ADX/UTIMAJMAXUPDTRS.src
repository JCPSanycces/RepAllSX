#<AdxTL>@(#)4.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Update MAXUPDTRS parameter to 50000 at least
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update MAXUPDTRS parameter") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If !mkstat
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub UPD
End

#-------------------#
$UPD
Local Integer VALMAX
If DOSSIER=nomap
 Local File ADOVAL [ADW]
Else
 Local File =DOSSIER+".ADOVAL" [ADW]
Endif
Trbegin [ADW]
 Read [ADW]ADW0="";"";"MAXUPDTRS"
 If !fstat
  VALMAX=val([F:ADW]VALEUR)
  If VALMAX<50000
   Call ECR_TRACE("Folder"-[L]DOSSIER-": MAXUPDTRS"-num$(VALMAX)-"->"-num$(50000),0) From GESECRAN
   [F:ADW]VALEUR="50000"
   Rewrite [F:ADW]
   If fstat
    Call ERREUR("ADOVAL MAXUPDTRS folder="+DOSSIER,2) From DOSDIC
   Endif
  Else
   Call ECR_TRACE("Folder"-[L]DOSSIER-": MAXUPDTRS current value"-num$(VALMAX),0) From GESECRAN
  Endif
 Endif
Commit


Close Local File [ADW]

Return

