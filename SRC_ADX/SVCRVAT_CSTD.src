#######################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
     When ""
        Case [L]AEVENT
          When "AREAD_AFTER"     : Gosub AREAD_AFTER      :#--CPO 14.08.2013 Revue code
        Endcase
  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES

#Case CURPRO
#  When Default
#Endcase

Return
# Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class - removed all _LEG properties related calls and also all AREAD_AFTER_xxx badly called from other scripts
#######################################################################################
$AREAD_AFTER
  #--Ici on fait des choses qui n'ont rien à voir avec une classe parent...
  #--Si des propriétés dépendent de la classe parent, elles sont initialisées dans le script de cette dernière
  #--en tenant compte du CURPTH

  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class - added LEG propert to SINVOICEV class
  If this.LEG = AVOID.ACHAR
    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this, this.CPY, AVOID.ACHAR, this.LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_VAT_LEG(this, this.VAT, this.CPY, AVOID.ACHAR, this.LEG, this.VAT_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  #--

  If this.VATTYP=1                    : # colonne TTC uniquement si taxe principale
      this.VATATI = this.VATGRO+this.VATAMT+this.VATSUPAMT
  Endif

  If this.VATTYP>3                   : # colonne TTC car les taxes annexes (globales facture)
      this.VATATI = this.VATAMT : # ne sont pas répercutées sur les lignes taxes principales
  Endif                               : # liées aux produits

Return

