#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion paramètres
Local Char PARAM(30)(1..2) , VALEUR(20)
Raz GNBMASKOUV
#PARAM(1) = "SUP_*DAT*"
#PARAM(1) = "*DAT*"
Call SAISIE_CHAR(VALEUR,PARAM,"ADOVAL","ADOVAL","XWADOVAL") From GSAISIE
End

#--------------------------------------------------------#
# Le paramètre de la fonction ADPVAL peut contenir
# - Chapitre_Modèle de paramètre
# - ou Chapitre seul
# - ou Modèle de paramètre seul (avec !#?*)
#--------------------------------------------------------#

#--------------------------------------------------------#
$ACTION
If dim([L]PSUBAD)<=0
 Local Integer PSUBAD
 Call EXISTE_ADX("","","ADOVALB",PSUBAD) From ORDSYS
Endif
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "AP_CHOIX"    : Gosub AP_CHOIX
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "ENR"         : Gosub ENREGISTRE
 When "ABA"         : Gosub ABANDON
 When "END"         : Gosub FIN
 When "SUI"         : Gosub SUIVANT
 When "PRE"         : Gosub PRECEDENT
 When "FIR"         : Gosub PREMIER
 When "LAS"         : Gosub DERNIER
 When "FIN"         : Gosub TERMINE
 When "HLP"         : Gosub AIDE
 When "TIR"         : Gosub TIR
 When "GAU"         : Gosub GAU
 When "RAF"         : Gosub RAF
 When "SUP"         : Gosub SUP
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "VERF_TABLE"  : Gosub VERF_TABLE
Endcase
If PSUBAD
 Gosub ACTION From ADOVALB
Endif
Return

#--------------------------------------------------------#
$OUVRE
Local Integer  I , J , K , TABNUM
Local Char     CHPCUR(GLONADI) , SOCCUR(GLONCPY) , SITCUR(GLONFCY)
Local Char     LEGCUR(GLONADI) , LEGDEF(GLONADI)
Local Integer  DEL , CRE , CLECUR
Local Char     SITDEF(GLONFCY) , SOCDEF(GLONCPY) , SOCSIT(GLONFCY) , LEGSIT(GLONADI)
Local Char     CHAINE(80)
Local Integer  FLBATCH
Local Char     CHAP(GLONADI), CHPDEB(GLONADI)
Local Char     MODELE(20)
Local Shortint NBPAR , NBVAL
Local Integer  UPDDOSTAG

If clalev([F:ADW])=0  : Local File ADOVAL    [ADW]  : Endif
If clalev([F:ADP])=0  : Local File ADOPAR    [ADP]  : Endif
If clalev([F:ADP2])=0 : Local File ADOPAR    [ADP2] : Endif
If clalev([F:ADV])=0  : Local File ATABTAB   [ADV]  : Endif
If clalev([F:ADI])=0  : Local File ATABDIV   [ADI]  : Endif
If clalev([F:ADG])=0  : Local File ADOVALGRP [ADG]  : Endif
If clalev([F:AGB])=0  : Local File AGLOBVAR  [AGB]  : Endif
If clalev([F:AXX])=0  : Local File ATEXTRA   [AXX]  : Endif
If clalev([F:ATY])=0  : Local File ATYPE     [ATY]  : Endif
If clalev([F:FCY])=0  : Local File FACILITY  [FCY]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY   [CPY]  : Endif
If clalev([F:FGR])=0  : Local File FACGROUP  [FGR]  : Endif
If clalev([F:ATZ])=0  : Local File ATABZON   [ATZ]  : Endif
If clalev([F:AOB])=0  : Local File AOBJET    [AOB]  : Endif
If clalev([F:ACC])=0  : Local File ACCES     [ACC]  : Endif

NBPAR = nbrecord([F:ADP])

Link [ADW] With [ADP]ADP1=[F:ADW]PARAM As [BADW] Order By Key CLE=[F:ADP]CHAPITRE;CMP;FCY;PARAM

NBVAL = 0
For [BADW]CLE(3)
 NBVAL += 1
Next BADW

Local Char    WCHP(GLONADI)(1..NBVAL) , WCOD(max(GLONCPY,GLONFCY,GLONADI))(1..NBVAL)
Local Char    WDESCHP(GLONDES)(1..NBVAL) , WDESCOD(GLONDES)(1..NBVAL)
Local Char    WDESTYP(20)(1..NBVAL)
Local Integer WTYP(1..NBVAL)
Local File   (Char CHP(GLONADI) , Integer TYP , Char COD(max(GLONCPY,GLONFCY,GLONADI))
&           , Char DESCHP(GLONDES) , Char DESCOD(GLONDES) , Char DESTYP(20))
&             From Variable WCHP , WTYP , WCOD , WDESCHP , WDESCOD , WDESTYP As [AADW]
&             Order By CHP ; TYP ; COD

Local Char    WGRP(GLONADI)(1..NBPAR) , WPAR(GLONADP)(1..NBPAR) , WDESGRP(GLONDES)(1..NBPAR)
&           , WDESPAR(80)(1..NBPAR)
Local File   (Char GRP(GLONADI) , Char PAR(GLONADP) , Char DESGRP(GLONDES) , Char DESPAR(80))
&             From Variable WGRP , WPAR , WDESGRP , WDESPAR As [AADP]
&             Order By GRP ; PAR

Local Mask ADOVAL

Raz [M]
TABNUM  = 901
REPORT2 = "ADOVAL"
Gosub DECODE_PARAM
Return

#--------------------------------------------------------#
$DEBUT
Global Char BOXVAL(10) , BOXGEN(10)
BOXVAL = "GAU_CHE"+num$(find("AD5",OBJLIS(1..dim(OBJLIS)-1)))
BOXGEN = "GAU_CHE"+num$(find("AD6",OBJLIS(1..dim(OBJLIS)-1)))
If [L]CHPDEB<>""
 Filter [ADI] Where NUMTAB=TABNUM & CODE=[L]CHPDEB
 CHPCUR = [L]CHPDEB
 Gosub LECTURE
 Affzo
Else
 Filter [ADI] Where NUMTAB=TABNUM
Endif
REP = ""
Gosub DEGRISE
Gosub REMPLIT
Return

#--------------------------------------------------------#
$FIN
If dim(BOXGEN)>0
 Kill BOXGEN , BOXVAL
Endif
Gosub DEVERROU
Return

#--------------------------------------------------------#
$TIR
If currbox<>BOXCURR
 Gosub REMPLIT
Endif
Return

#--------------------------------------------------------#
$RAF
Gosub REMPLIT
Gosub LECTURE
Affzo
FOK = 0
Return

#----------------------------#
$REMPLIT
Case currbox
 When BOXVAL
  I = 0
  For [BADW]CLE(3) Where [F:ADP]MODIF=2 & ([L]MODELE = "" or pat([F:ADP]PARAM,[L]MODELE)=1)
   If I<dim(WCHP)
    I += 1
    WCHP(I) = [F:ADP]CHAPITRE
    Call LECTEXTRA(WDESCHP(I),"ATABDIV","LNGDES","901",WCHP(I)) From ATEXTRA
    If [F:ADW]CMP="" & [F:ADW]FCY=""
     WTYP(I)    = 1
     WCOD(I)    = ""
     WDESCOD(I) = nomap
     WDESTYP(I) = mess(1,987,1) : # Dossier
    Elsif [F:ADW]CMP="*"
     WTYP(I)    = 2
     WCOD(I)    = [F:ADW]FCY
     WDESCOD(I) = ""
     WDESTYP(I) = mess(5,987,1) : # Législation
    Elsif [F:ADW]CMP<>""
     WTYP(I)    = 3
     WCOD(I)    = [F:ADW]CMP
     WDESCOD(I) = ""
     WDESTYP(I) = mess(2,987,1) : # Société
    Elsif [F:ADW]FCY<>""
     WTYP(I)    = 4
     WCOD(I)    = [F:ADW]FCY
     WDESCOD(I) = ""
     WDESTYP(I) = mess(3,987,1) : # Site
    Endif
   Endif
  Next BADW
  For J=I+1 To dim(WCHP)
   WCHP(J) = chr$(255)
  Next J
  adxmxl = I
  Filter [AADW] Order By CHP ; TYP ; COD
  Case currbox
   When "GAU_CHE1" : Fillbox [ADW1] GAU_CHE1
   When "GAU_CHE2" : Fillbox [ADW1] GAU_CHE2
   When "GAU_CHE3" : Fillbox [ADW1] GAU_CHE3
   When "GAU_CHE4" : Fillbox [ADW1] GAU_CHE4
  Endcase
  Filter [AADW]
 When BOXGEN
  I = 0
  For [ADP]ADP5 Where CHAPITRE=[M]CHAPITRE & MODIF=2
   K = find([F:ADP]PARAM,[M:ADW1]PARAM)
   If K & I<dim(WGRP)
    I += 1
    WGRP(I) = [F:ADP]GRPPAR
    WPAR(I) = [F:ADP]PARAM
    Call LECTEXTRA(WDESGRP(I),"ATABDIV","LNGDES","903",WGRP(I)) From ATEXTRA
    Call TEXTE([F:ADP]NAM,WDESPAR(I)) From OBJDIV
    If [M:ADW1]VALEUR(K-1)<>""
     If find([F:ADP]TYPVAL,1,4)
      If len([M:ADW1]VALEUR(K-1))>30
       WDESPAR(I) = [F:ADP]PARAM+'="'+left$([M:ADW1]VALEUR(K-1),30)+'..."'-"("+WDESPAR(I)+")"
      Else
       WDESPAR(I) = [F:ADP]PARAM+'="'+[M:ADW1]VALEUR(K-1)+'"'-"("+WDESPAR(I)+")"
      Endif
     Else
      WDESPAR(I) = [F:ADP]PARAM+'='+[M:ADW1]VALEUR(K-1)-"("+WDESPAR(I)+")"
     Endif
    Else
     WDESPAR(I) = [F:ADP]PARAM+'=""'-"("+WDESPAR(I)+")"
    Endif
   Endif
  Next ADP
  For J=I+1 To dim(WGRP)
   WGRP(J) = chr$(255)
  Next J
  adxmxl = I
  Filter [AADP] Order By GRP ; PAR
  Case currbox
   When "GAU_CHE1" : Fillbox [ADW1] GAU_CHE1
   When "GAU_CHE2" : Fillbox [ADW1] GAU_CHE2
   When "GAU_CHE3" : Fillbox [ADW1] GAU_CHE3
   When "GAU_CHE4" : Fillbox [ADW1] GAU_CHE4
  Endcase
  Filter [AADP]
Endcase
Return

#--------------------------------------------------------#
$GAU
Case currbox
 When BOXVAL
  REP = ""
  Gosub DEVERROU
  [M]CHAPITRE = [F:AADW]CHP
  Case [F:AADW]TYP
   When 1 : # Dossier
    [M]CMP = ""
    [M]FCY = ""
    If dim([M]LEG)>0 : [M]LEG = "" : Endif
   When 2 : # Législation
    [M]CMP = ""
    [M]FCY = ""
    If dim([M]LEG)>0 : [M]LEG = [F:AADW]COD : Endif
   When 3 : # Société
    [M]CMP = [F:AADW]COD
    [M]FCY = ""
    If dim([M]LEG)>0 : [M]LEG = "" : Endif
   When 4 : # Site
    [M]CMP = ""
    [M]FCY = [F:AADW]COD
    If dim([M]LEG)>0 : [M]LEG = "" : Endif
  Endcase
  CHPCUR = [M]CHAPITRE
  If dim([M]LEG)>0 : LEGCUR = [M]LEG : Else : LEGCUR = "" : Endif
  SOCCUR = [M]CMP
  SITCUR = [M]FCY
  Gosub LECTURE
  Affzo
Endcase
Return

#---------------------------#
$SETBOX
Case currbox
 When BOXVAL
  [F:AADW]CHP = [M:ADW1]CHAPITRE
  If dim([M:ADW1]LEG)>0 & [M:ADW1]LEG<>""
   [F:AADW]TYP = 2
   [F:AADW]COD = [M:ADW1]LEG
  Elsif [M:ADW1]CMP<>""
   [F:AADW]TYP = 3
   [F:AADW]COD = [M:ADW1]CMP
  Elsif [M:ADW1]FCY<>""
   [F:AADW]TYP = 4
   [F:AADW]COD = [M:ADW1]FCY
  Else
   [F:AADW]TYP = 1
   [F:AADW]COD = ""
  Endif
  Read [AADW] =
  Case currbox
   When "GAU_CHE1" : Setlbox [ADW1] GAU_CHE1
   When "GAU_CHE2" : Setlbox [ADW1] GAU_CHE2
   When "GAU_CHE3" : Setlbox [ADW1] GAU_CHE3
   When "GAU_CHE4" : Setlbox [ADW1] GAU_CHE4
  Endcase
 When BOXGEN
  Local Integer K
  K = 0
  For [ADP]ADP5 Where CHAPITRE=[M:ADW1]CHAPITRE & GRPPAR=[M:ADW1]GRPCOD(nolign-1) & MODIF=2
   K = find([F:ADP]PARAM,[M:ADW1]PARAM)
   If K : Break : Endif
  Next ADP
  If K
   Filter [AADP] Order By GRP ; PAR
   [F:AADP]GRP = [F:ADP]GRPPAR
   [F:AADP]PAR = [F:ADP]PARAM
   Read [AADP] =
   Case currbox
    When "GAU_CHE1" : Setlbox [ADW1] GAU_CHE1
    When "GAU_CHE2" : Setlbox [ADW1] GAU_CHE2
    When "GAU_CHE3" : Setlbox [ADW1] GAU_CHE3
    When "GAU_CHE4" : Setlbox [ADW1] GAU_CHE4
   Endcase
   Filter [AADP]
  Endif
Endcase
Return

#--------------------------------------------------------#
$ENREGISTRE
Gosub MODIF
Gosub DEGRISE
REP = ""

# clean cache after modif
If dim(GACTX)>=0
  Local Integer WIND_RESULT
  WIND_RESULT= fmet GACTX.APARAM._ACLEAN()
Endif


Return

#--------------------------------------------------------#
$ABANDON
Gosub DEGRISE
Gosub LECTURE
REP = ""
Affzo
Return

#--------------------------------------------------------#
$SUP
Call DEBTRANS From GLOCK
Gosub TR_SUP
Return

$TR_SUP
Trbegin [ADW]
 If [M]CMP<>""
  For [ADP] Where CHAPITRE=[M]CHAPITRE & ([L]MODELE = "" or pat([F:ADP]PARAM,[L]MODELE)=1)
   Delete [ADW] Where CMP=[M]CMP & PARAM=[F:ADP]PARAM
   If fstat=1
    GOK=-1 : Call FSTA("ADW") From GLOCK : Break
   Endif
  Next ADP
 Elsif [M]FCY<>""
  For [ADP] Where CHAPITRE=[M]CHAPITRE & ([L]MODELE = "" or pat([F:ADP]PARAM,[L]MODELE)=1)
   Delete [ADW] Where FCY=[M]FCY & PARAM=[F:ADP]PARAM
   If fstat=1
    GOK=-1 : Call FSTA("ADW") From GLOCK : Break
   Endif
  Next ADP
 Elsif dim([M]LEG)>0 & [M]LEG<>""
  For [ADP] Where CHAPITRE=[M]CHAPITRE & ([L]MODELE = "" or pat([F:ADP]PARAM,[L]MODELE)=1)
   Delete [ADW] Where CMP="*" & FCY=[M]LEG & PARAM=[F:ADP]PARAM
   If fstat=1
    GOK=-1 : Call FSTA("ADW") From GLOCK : Break
   Endif
  Next ADP
 Endif
 If GOK<1 : Goto ROLL_SUP : Endif
Commit
Return

$ROLL_SUP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_SUP : Endif

#--------------------------------------------------------#
$AIDE
CHAINE = "ADP_"+[M]CHAPITRE+"_"+[M]PARAM(nolign-1)
Hlpbox CHAINE
Return

#--------------------------------------------------------#
$AP_CHOIX
Case REPONSE
 When GSTACLK+3
  Gosub VERROU
  If VERROU
   REPONSE = 0
   Gosub LECTURE
   Affzo
  Endif
 When GSTALFT,GSTALF2,GSTALF3,GSTALF4
  If currbox=BOXGEN
   Local Char    PARMSK(250)(1..20) , VALMSK(30)
   PARMSK(1) = [F:AADP]GRP
   PARMSK(2) = [F:AADP]PAR
   Call SAISIE_CHAR(VALMSK,PARMSK,"ADWP","ASAIPARVAL","") From GSAISIE
   If mkstat=4 & REP="" : REP = "M" : Endif
   nolign = 0
   For I=1 To [M:ADW1]NBGRP
    If [F:AADP]GRP=[M:ADW1]GRPCOD(I-1)
     nolign = I : Break
    Endif
   Next I
   If nolign>0
    zonsui = "[M:ADW1]NBGRP("+num$(nolign-1)+")"
   Endif
   REPONSE = 0
  Endif
Endcase
Return

#--------------------------------------------------------#
$SETBOUT
If [M]CHAPITRE=""
 Call VIREBOUT(CHBOU,"<>") From GOBJET
Endif
If [M]CHAPITRE="" or ([M]CMP="" & [M]FCY="" & (dim([M]LEG)<=0 or [M]LEG=""))
 Call VIREBOUT(CHBOU,"S") From GOBJET
Endif
If instr(1,CHBOU,"L")=0
 CHBOU += "L"
Endif
If instr(1,CHBOU,"=")=0
 CHBOU += "="
Endif
If !VERROU & CLECUR
 IMGFLG(3) = 1 : # Icône Cadenas
Else
 IMGFLG(3) = 0
Endif
If CLECUR & GCONSULT
 Call VIREBOUT(CHBOU,"MS") From GOBJET
 IMGFLG(5) = 1 : # Croix blanche
Else
 IMGFLG(5) = 0
Endif
Return

#--------------------------------------------------------#
$TERMINE
Gosub DEVERROU
Return

#--------------------------------------------------------#
$APRES_MODIF
Case COUZON
 When "CHAPITRE","CMP","FCY","LEG"
  Gosub DEVERROU
  Assign "[M]"+COUZON With CZ
  If CZ<>""
   Case COUZON
    When "LEG" : [M]CMP = "" : [M]FCY = ""
    When "CMP" : [M]FCY = "" : If dim([M]LEG)>0 : [M]LEG = "" : Endif
    When "FCY" : [M]CMP = "" : If dim([M]LEG)>0 : [M]LEG = "" : Endif
   Endcase
  Endif
  CHPCUR = [M]CHAPITRE
  If dim([M]LEG)>0 : LEGCUR = [M]LEG : Else : LEGCUR = "" : Endif
  SOCCUR = [M]CMP
  SITCUR = [M]FCY
  Gosub LECTURE
  Affzo
 When Default
  #F_add_admca_managment
  #  If [M]CHAPITRE="SUP" & GADONIX<>2 & GPROFIL<>GSUPER                      # 108633-13.o
  If [M]CHAPITRE="SUP" & GADONIX<>2 & GPROFIL<>GSUPER & GPROFIL<>"ADMCA"    # 108633-13.n
   GERR=1 : GMESSAGE = mess(9,123,1) : mkstat = 1 : Return
  Endif
  If !VERROU
   GERR = 1 : GMESSAGE = mess(10,100,1) : # Modification en cours sur un autre poste
   mkstat = 1 : Return
  Endif
  REP = "M"
  Gosub GRISE
  Case COUZON
   When "NBGRP"
    Case status
     When 129 , 130 : # Boutons "Détail" et "Recherche"
      Gosub CHARGE_GRP
      Affzo [ADW1]20
      Gosub REMPLIT
      Gosub SETBOX
    Endcase
   When "JEUCOD"
    Gosub REMPLIT
    Gosub SETBOX
  Endcase
Endcase
Return

#---------------------------#
$DEGRISE
Actzo CHAPITRE, CMP, FCY
If dim([M]LEG)>0
 If func AFNC.ACTIV("LEG")
  Actzo LEG
 Else
  Grizo LEG
 Endif
Endif
If [L]CHAP<>"" : Grizo CHAPITRE : Endif
Return

#---------------------------#
$GRISE
Grizo CHAPITRE, CMP, FCY
If dim([M]LEG)>0
 Grizo LEG
Endif
Return

#---------------------------#
$VERROU
SYMBOLE = "ADW"-CHPCUR-SOCCUR-SITCUR-LEGCUR
Lock =SYMBOLE With lockwait=0
If !fstat
 VERROU = 1
Else
 VERROU = 0
Endif
ACTION = "VERROU" : Gosub ACTION
Return

#---------------------------#
$DEVERROU
If VERROU
 Unlock =SYMBOLE : VERROU = 0
Endif
ACTION = "DEVERROU" : Gosub ACTION
Return

#---------------------------#
$LECTURE
Raz [M]
Gosub VERROU

# Chargement du tableau détail

nolign = 0
Raz SOCSIT , LEGSIT
If SITCUR<>""
 Call LECTURE("FCY",SITCUR,"") From CONTOBJ
 SOCSIT = [F:FCY]LEGCPY
 Call LECTURE("CPY",SOCSIT,"") From CONTOBJ
 If dim([F:CPY]LEG)>0
  LEGSIT = [F:CPY]LEG
 Endif
Endif
If SOCCUR<>""
 Call LECTURE("CPY",SOCCUR,"") From CONTOBJ
 If dim([F:CPY]LEG)>0
  LEGSIT = [F:CPY]LEG
 Endif
Endif
For [ADP]ADP5 Where CHAPITRE=CHPCUR & MODIF=2 & ([L]MODELE = "" or pat([F:ADP]PARAM,[L]MODELE)=1)
 OK = 0
 Case [F:ADP]NIVDEF
  When 1 : If SOCCUR="" & SITCUR="" & LEGCUR="" : OK = 1 : Endif
  When 2 : If SITCUR=""                         : OK = 1 : Endif
  When 3 :                                      : OK = 1
  When 4 : If [F:ADP]VALDEF=2                   : OK = 1 : Endif
  When 5 : If SOCCUR="" & SITCUR=""             : OK = 1 : Endif
 Endcase
 If [F:ADP]ACS<>"" & GUSRACS<>2
  Read [ACC]CODACC = GUSER;[F:ADP]ACS
  If fstat or [F:ACC]MODIF<>2 : OK = 0 : Endif
 Endif
 If OK
  nolign += 1
  [M] = [F:ADP]
  If dim([M]AUTMOD)>0
   [M]AUTMOD(nolign-1) = func AUTMOD([L]SITCUR,[L]SOCCUR,[L]LEGCUR,"")
  Endif
  Call TEXTE([F:ADP]NAM,[M]NAME(nolign-1)) From OBJDIV
  Case [F:ADP]TYPVAL
   When 1 : [M]FMT(nolign-1) = "Kf:"+num$(GLONADW)+"X"
   When 2 : [M]FMT(nolign-1) = "Nf:10F"
   When 3 : [M]FMT(nolign-1) = "Df:"+GFMDAT4
   When 4 : [M]FMT(nolign-1) = "Nf:2#"
  Endcase
  Case [F:ADP]TYPVAL
   When 1 : [M]TYP(nolign-1) = "A"   : [M]LONG(nolign-1)  = GLONADW
   When 2 : [M]TYP(nolign-1) = "DCB" : [M]LONG(nolign-1)  = 15
   When 3 : [M]TYP(nolign-1) = "D"   : [M]LONG(nolign-1)  = 0
   When 4 : [M]TYP(nolign-1) = "M"   : [M]NOLIB(nolign-1) = [F:ADP]NOLIB
  Endcase
  If [F:ADP]OBJET<>""
   Filter [ATY] Where OBJLIEN=[F:ADP]OBJET
   K = 0
   For [ATY]
    K += 1 : If K>1 : Break : Endif
   Next
   Filter [ATY]
   If K=1 & left$([F:ATY]FORTYP,1)<>"="
    [M]TYP(nolign-1) = [F:ATY]CODTYP
   Else
    Call EXISTE_ADX("","","WO"+[F:ADP]OBJET,K) From ORDSYS
    If K
     Gosub SETCLE From ="WO"+[F:ADP]OBJET
     Read [AOB]ABREV = [F:ADP]OBJET
     Read [ATZ]CODZONE = [F:AOB]NOMFIC;CLEPRIM
     Read [ATY]CODTYP = [F:ATZ]CODTYP
     [M]TYP(nolign-1) = [F:ATY]CODTYP
    Endif
   Endif
  Endif
  SOCDEF = SOCCUR
  SITDEF = SITCUR
  LEGDEF = LEGCUR
  OK = 0
  While !OK
   If LEGDEF<>""
    Read [ADW]ADW0 = "*";LEGDEF;[F:ADP]PARAM
   Else
    Read [ADW]ADW0 = SOCDEF;SITDEF;[F:ADP]PARAM
   Endif
   If !fstat
    [M]VALEUR(nolign-1) = [F:ADW]VALEUR
    [M]GRPDEF(nolign-1) = [F:ADW]JEU
    Call CHARGE([M]VALEUR(nolign-1),[M]TYP(nolign-1),[M]NOLIB(nolign-1),[M]LONG(nolign-1),[M]VALINT(nolign-1)) From FMTVAR
    OK = 1
   Elsif [F:ADP]NIVDEF=5
    If LEGDEF<>"" : LEGDEF = ""
    Else          : OK = 1
    Endif
   Elsif [F:ADP]NIVDEF>=3
    If    SITDEF<>"" : SITDEF = "" : SOCDEF = SOCSIT
    Elsif SOCDEF<>"" : SOCDEF = "" : LEGDEF = LEGSIT
    Elsif LEGDEF<>"" : LEGDEF = ""
    Else             : OK = 1
    Endif
   Elsif [F:ADP]NIVDEF=2
    If    SOCDEF<>"" : SOCDEF = "" : LEGDEF = LEGSIT
    Elsif LEGDEF<>"" : LEGDEF = ""
    Else             : OK = 1
    Endif
   Else
    OK = 1
   Endif
  Wend
  If    LEGDEF<>"" : [M]NIVEAU(nolign-1) = 5
  Elsif SITDEF<>"" : [M]NIVEAU(nolign-1) = 3
  Elsif SOCDEF<>"" : [M]NIVEAU(nolign-1) = 2
  Else             : [M]NIVEAU(nolign-1) = 1
  Endif
 Endif
Next ADP
[M]NBVAR = nolign
[M]CHAPITRE = CHPCUR
[M]CMP = SOCCUR
[M]FCY = SITCUR
If dim([M]LEG)>0 : [M]LEG = LEGCUR : Endif

# Chargement du tableau valeurs groupées
Gosub CHARGE_GRP

# Listes de gauche
Case currbox
 When BOXVAL : Gosub SETBOX
 When BOXGEN : Gosub REMPLIT
Endcase

CLECUR = 1
SAVACT = ACTION
ACTION = "LECTURE" : Gosub ACTION
ACTION = SAVACT
Return

#--------------------------------------#
Funprog AUTMOD(FCY,CPY,TCY,USR)
Value Char FCY , CPY , TCY , USR
Local Integer OK , ER , I
Local Char    PARAM(GLONADP) , SIT(GLONFCY) , SOC(GLONCPY) , LEG(GLONADI)
OK = 1
If dim([F:ADP]CNDMOD)>0 & [F:ADP]CNDMOD<>""
 [L]PARAM = [F:ADP]PARAM
 Local File ADOPAR [ADP_],ADOPAR [ADP]
 Read [ADP_]ADP1 = [L]PARAM
 [F:ADP] = [F:ADP_]
 Gosub INIVARCND
 Onerrgo ER
 OK = evalue([F:ADP_]CNDMOD)
 Onerrgo
 If ER : OK = 1 : Endif
 Close Local File [ADP],[ADP_]
Endif
End OK

$ER
ER = errn
Resume

#-------------#
$INIVARCND
Raz SIT , SOC , LEG
If USR<>"" & FCY="" & [F:ADP]VALDEF=2
 Call DFLCHAP([F:ADP]CHAPITRE,FCY,OK) From SUBAUS
Endif
If FCY<>""
 SIT = FCY
 I = find(FCY,GSITE(1..GNBSITE))
 If I
  SOC = GSOCSITE(I)
  LEG = GLEGSOC(find(SOC,GSOC(1..GNBSOC)))
 Endif
Elsif CPY<>""
 SOC = CPY
 I = find(CPY,GSOC(1..GNBSOC))
 If I
  LEG = GLEGSOC(I)
 Endif
Elsif TCY<>""
 LEG = TCY
Endif
If GNBLEG=1 & LEG=""
 LEG = GDOSLEG
Endif
Return

#-----------------------------------------------------#
$CHARGE_GRP
Local Char    CODGRP(GLONADI) , CODJEU(GLONADI) , CODCHA(GLONADI)
Local Integer CODLIG , JEUOK , CODNIV

# Affectation jeux valeurs par défaut

If [M:ADW1]NBVAR<=0 : Return : Endif

Raz CODGRP , CODLIG
I = 0
While I<[M:ADW1]NBVAR
 I += 1
 If CODGRP=""
  CODGRP = [M:ADW1]GRPPAR(I-1)
  CODLIG = I
  CODNIV = 0
 Elsif CODGRP<>[M:ADW1]GRPPAR(I-1)
  Gosub SET_JEUDEF
  CODGRP = [M:ADW1]GRPPAR(I-1)
  CODLIG = I
  CODNIV = 0
 Endif
 If CODNIV=0
  CODNIV = [M:ADW1]NIVEAU(I-1)
 Elsif CODNIV<>[M:ADW1]NIVEAU(I-1)
  CODNIV = -1
 Endif
Wend
I += 1
Gosub SET_JEUDEF

# Chargement écran paramètres groupés

Sorta [M:ADW1]NBVAR [M:ADW1]NBVAR Order By [M:ADW1]GRPPAR(indice)

Effzo [M:ADW1]20
Raz [M:ADW1]NBGRP
CODGRP = ""
I = 0
While I<[M:ADW1]NBVAR
 I += 1
 If CODGRP=""
  CODGRP = [M:ADW1]GRPPAR(I-1)
  CODNIV = [M:ADW1]NIVEAU(I-1)
  CODJEU = [M:ADW1]GRPDEF(I-1)
 Elsif CODGRP<>[M:ADW1]GRPPAR(I-1)
  Gosub ALIM_GRP
  CODGRP = [M:ADW1]GRPPAR(I-1)
  CODNIV = [M:ADW1]NIVEAU(I-1)
  CODJEU = [M:ADW1]GRPDEF(I-1)
 Else
  If CODNIV=5
   If [M:ADW1]NIVEAU(I-1)>=2
    CODNIV = [M:ADW1]NIVEAU(I-1)
   Endif
  Elsif [M:ADW1]NIVEAU(I-1)=5
   If CODNIV=1 : CODNIV = 5 : Endif
  Elsif CODNIV<[M:ADW1]NIVEAU(I-1)
   CODNIV = [M:ADW1]NIVEAU(I-1)
  Endif
 Endif
Wend
If [M:ADW1]NBGRP=0 | (CODGRP<>[M:ADW1]GRPCOD([M:ADW1]NBGRP-1))
 Gosub ALIM_GRP
Endif
Affzo 20
For I=1 To [M:ADW1]NBGRP
 K = 1
 For [ADP2]ADP5 Where CHAPITRE=[M:ADW1]CHAPITRE & GRPPAR=[M:ADW1]GRPCOD(I-1)
  J = find([F:ADP2]PARAM,[M:ADW1]PARAM)
  If J & dim([M:ADW1]AUTMOD)>0 & [M:ADW1]AUTMOD(J-1)=0
   K = 0 : Break
  Endif
 Next ADP2
 If !K
  Grizo [ADW1]JEUCOD(I-1)
 Else
  Actzo [ADW1]JEUCOD(I-1)
 Endif
Next I
Return

#-----------------------------#
$ALIM_GRP
[M:ADW1]NBGRP += 1
[M:ADW1]GRPCOD([M:ADW1]NBGRP-1)   = CODGRP
[M:ADW1]NIVGRP([M:ADW1]NBGRP-1)   = CODNIV
[M:ADW1]JEUCOD([M:ADW1]NBGRP-1)   = CODJEU
Return

#-----------------------------#
$SET_JEUDEF
If CODNIV<0
 For K=CODLIG To I-1
  [M:ADW1]GRPDEF(K-1) = "" : # Personnalisé
 Next K
Elsif CODNIV
 Raz CODJEU , JEUOK
 For K=CODLIG To I-1
  If CODJEU=""
   CODJEU = [M:ADW1]GRPDEF(K-1)
   JEUOK = 1
  Elsif CODJEU<>[M:ADW1]GRPDEF(K-1)
   JEUOK = 0 : Break
  Endif
 Next K
 If !JEUOK
  CODJEU = ""
 Endif
 For K=CODLIG To I-1
  [M:ADW1]GRPDEF(K-1) = CODJEU
 Next K
Endif
Return

#--------------------------------------------------------------#
$MODIF
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=1
 Gosub GLOBVAR
Endif
Return

#---------------------------#
$GLOBVAR
For I=0 To [M]NBVAR-1
 For [AGB]AGB2 Where PARAM=[M]PARAM(I)
  If evalue("dim("+[F:AGB]CODVAR+")>0")
   Read [ADP]ADP1 = [F:AGB]PARAM
   If !fstat
    Read [ATY]CODTYP = [F:AGB]CODTYP
    If !fstat
     Case [F:ADP]NIVDEF
      When 1,2,3,5
       Call PARAM("",[F:AGB]PARAM,GBIDC3) From ADOVAL
       Case [F:ATY]TYPTYP
        When 7 : Assign [F:AGB]CODVAR With GBIDC3
        When 4 : Assign [F:AGB]CODVAR With val(GBIDC3)
        When 8 : Assign [F:AGB]CODVAR With func INIDAT([F:AGB]CODVAR,GBIDC3)
        When 1 : Assign [F:AGB]CODVAR With val(GBIDC3)
       Endcase
      When 4
       Call PARAMUTIL([F:AGB]PARAM,GBIDC3,"","") From SUBAUS
       Case [F:ATY]TYPTYP
        When 7 : Assign [F:AGB]CODVAR With GBIDC3
        When 4 : Assign [F:AGB]CODVAR With val(GBIDC3)
        When 8 : Assign [F:AGB]CODVAR With func INIDAT([F:AGB]CODVAR,GBIDC3)
        When 1 : Assign [F:AGB]CODVAR With val(GBIDC3)
       Endcase
     Endcase
    Endif
   Endif
  Endif
 Next AGB
Next I
Return

#----------------------------#
Funprog INIDAT(NAMGLO,VALEUR)
Value Char NAMGLO , VALEUR
Local Date DAT
If find(VALEUR,"","000000","00000000") or !find(len(VALEUR),6,8)
 Case NAMGLO
  When "GDATDEB" : [L]DAT = [01/01/1970]
  When "GDATFIN" : [L]DAT = GHIDATE
  When Default   : [L]DAT = [0/0/0]
 Endcase
Else
 [L]DAT = gdat$(VALEUR)
Endif
End [L]DAT

#---------------------------#
$TR1
GOK=1
FLBATCH = 0
If dim(UPDDOSTAG)>0 : Raz UPDDOSTAG : Endif
Trbegin [ADW]
 For I=0 To [M]NBVAR-1
  CRE = 0 : DEL = 0
  If SITCUR<>""
   If [M]NIVEAU(I)<>3
    Read [ADW]ADW0 = "";SITCUR;[M]PARAM(I)
    If !fstat
     DEL = 1
    Endif
   Else
    CRE = 1
   Endif
  Elsif SOCCUR<>""
   If [M]NIVEAU(I)<>2
    Read [ADW]ADW0 = SOCCUR;"";[M]PARAM(I)
    If !fstat
     DEL = 1
    Endif
   Else
    CRE = 1
   Endif
  Elsif LEGCUR<>""
   If [M]NIVEAU(I)<>5
    Read [ADW]ADW0 = "*";LEGCUR;[M]PARAM(I)
    If !fstat
     DEL = 1
    Endif
   Else
    CRE = 1
   Endif
  Else
   CRE = 1
  Endif
  If LEGCUR<>""
   Readlock [ADW]ADW0 = "*";LEGCUR;[M]PARAM(I)
   If fstat=1
    GOK=-1 : GLOCK = "$ADOVAL"-"*"-LEGCUR-[M]PARAM(I) : Break
   Endif
  Else
   Readlock [ADW]ADW0 = SOCCUR;SITCUR;[M]PARAM(I)
   If fstat=1
    GOK=-1 : GLOCK = "$ADOVAL"-SOCCUR-SITCUR-[M]PARAM(I) : Break
   Endif
  Endif
  If fstat
   If CRE
    Gosub TST_BATCH
    Raz [F:ADW]
    If LEGCUR<>""
     [F:ADW]CMP = "*"
     [F:ADW]FCY = LEGCUR
    Else
     [F:ADW]CMP = SOCCUR
     [F:ADW]FCY = SITCUR
    Endif
    [F:ADW]PARAM  = [M]PARAM(I)
    [F:ADW]VALEUR = [M]VALINT(I)
    [F:ADW]JEU    = [M]GRPDEF(I)
    Gosub INICRE
    Write [ADW]
    If fstat
     GOK=0 : Call FSTA("ADW") From GLOCK : Break
    Endif
    If [M]NIVEAU(I)=1 and dim(UPDDOSTAG)>0 : UPDDOSTAG = 1 : Endif
   Endif
  Else
   If DEL
    Gosub TST_BATCH
    Delete [ADW]
   Else
    If [F:ADW]VALEUR<>[M]VALINT(I) | [F:ADW]JEU<>[M]GRPDEF(I)
     Gosub TST_BATCH
     Gosub INIMOD
     [F:ADW]VALEUR = [M]VALINT(I)
     [F:ADW]JEU    = [M]GRPDEF(I)
     Rewrite [ADW]
     If fstat
      GOK=0 : Call FSTA("ADW") From GLOCK : Break
     Endif
     If [M]NIVEAU(I)=1 and dim(UPDDOSTAG)>0 : UPDDOSTAG = 1 : Endif
    Endif
   Endif
  Endif
 Next I
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 If dim(UPDDOSTAG)>0 and UPDDOSTAG>0 : Call UPDATE_FOLDERETAG(nomap) From ASYRFNC : Endif
Commit
# X3-59028 - 2018-02-22 JPGA - Accounting_Task has been removed and managed like other Batch task
# X3-59028 - Code removed
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$TST_BATCH
## Paramètres qui influent sur la validation de pièce
If find([M]PARAM(I),"BALANARPT","BALGACRPT","CPTRES","FRWGAC","FRWANA","FRWAXI1","FRWAXI2"
&      ,"FRWAXI3","FRWAXI4","FRWAXI5","FRWAXI6","FRWAXI7","FRWAXI8","FRWAXI9")
    FLBATCH = 1
Endif
Return

#---------------------------------------------------------#
$INICRE
If dim([F:ADW]CREDAT)>0 : [F:ADW]CREDAT = date$ : Endif
If dim([F:ADW]CREUSR)>0 : [F:ADW]CREUSR = GUSER : Endif
If dim([F:ADW]CRETIM)>0 : [F:ADW]CRETIM = time  : Endif
Return

#---------------------------------------------------------#
$INIMOD
If dim([F:ADW]UPDDAT)>0 : [F:ADW]UPDDAT = date$ : Endif
If dim([F:ADW]UPDUSR)>0 : [F:ADW]UPDUSR = GUSER : Endif
If dim([F:ADW]UPDTIM)>0 : [F:ADW]UPDTIM = time  : Endif
Return

#---------------------------------------------------------#
$PREMIER
Gosub DEVERROU
Filter [ADI] Where NUMTAB = TABNUM
Read [ADI]CODE First
Repeat
 Gosub OKCHAP
 If !OKCHAP
  Read [ADI]CODE Next
 Endif
Until OKCHAP or fstat>2
Goto SUIVPREC

#---------------------------------------------------------#
$DERNIER
Gosub DEVERROU
Filter [ADI] Where NUMTAB = TABNUM
Read [ADI]CODE Last
Repeat
 Gosub OKCHAP
 If !OKCHAP
  Read [ADI]CODE Prev
 Endif
Until OKCHAP or fstat>2
Goto SUIVPREC

#---------------------------------------------------------#
$SUIVANT
Gosub DEVERROU
Filter [ADI] Where NUMTAB = TABNUM
Read [ADI]CODE > TABNUM;CHPCUR
Repeat
 Gosub OKCHAP
 If !OKCHAP
  Read [ADI]CODE Next
 Endif
Until OKCHAP or fstat>2
Goto SUIVPREC

#---------------------------------------------------------#
$PRECEDENT
Gosub DEVERROU
Filter [ADI] Where NUMTAB = TABNUM
Read [ADI]CODE < TABNUM;CHPCUR
Repeat
 Gosub OKCHAP
 If !OKCHAP
  Read [ADI]CODE Prev
 Endif
Until OKCHAP or fstat>2
Goto SUIVPREC

#---------------------------#
$SUIVPREC
Filter [ADI]
If fstat>2
 Call ERREUR(mess(11,100,1)) From GESECRAN
 Read [ADI]CODE = TABNUM;CHPCUR
 Gosub LECTURE
 While [M]NBVAR=0
  Case ACT
   When "SUI", "LAS" : Gosub LEC_PRE
   When "PRE", "FIR" : Gosub LEC_SUI
  Endcase
 Wend
Else
 Gosub DEVERROU
 CHPCUR = [F:ADI]CODE
 Gosub LECTURE
 While [M]NBVAR=0
  Case ACT
   When "SUI", "FIR" : Goto SUIVANT
   When "PRE", "LAS" : Goto PRECEDENT
  Endcase
 Wend
Endif
Affzo
Return

#---------------------------#
$OKCHAP
Local Integer OKCHAP
OKCHAP = 1
Case GPRODUIT
 When 0
  Case [F:ADI]CODE
   When "IMM"
    If GMODU(4)<>2 : OKCHAP = 0 : Endif
   When "ACH","VEN","GPA","STO"
    If GMODU(7)<>2 : OKCHAP = 0 : Endif
  Endcase
Endcase
Return

#---------------------------#
$LEC_SUI
Gosub DEVERROU
Filter [ADI] Where NUMTAB = TABNUM
Read [ADI]CODE > TABNUM;CHPCUR
CHPCUR = [F:ADI]CODE
Gosub LECTURE
Filter [ADI]
Return

#---------------------------#
$LEC_PRE
Gosub DEVERROU
Filter [ADI] Where NUMTAB = TABNUM
Read [ADI]CODE < TABNUM;CHPCUR
CHPCUR = [F:ADI]CODE
Gosub LECTURE
Filter [ADI]
Return

#---------------------------#
$DECODE_PARAM
Raz [L]CHAP, [L]MODELE, [L]CHPDEB
If PARAM(1)<>""
 GFLAG = PARAM(1)
Endif
If GFLAG=""
 GFLAG = VALEUR
Endif
If GFLAG<>""
 K = instr(1,GFLAG,"_")
 If K
  [L]CHAP   = left$(GFLAG,K-1)
  [L]CHPDEB = left$(GFLAG,K-1)
  [L]MODELE = right$(GFLAG,K+1)
  Filter [ADP] Where CHAPITRE=[L]CHAP
  Read [ADP] First
  Filter [ADP]
  If fstat
   FIN = 1
  Else
   Filter [ADP] Where CHAPITRE=[L]CHAP & pat([F]PARAM,[L]MODELE)=1
   Read [ADP] First
   Filter [ADP]
   If fstat
    FIN = 1
   Endif
  Endif
 Else
  Filter [ADP] Where CHAPITRE=GFLAG
  Read [ADP] First
  Filter [ADP]
  If !fstat
   [L]CHPDEB = GFLAG
   [L]CHAP   = GFLAG
  Else
   Filter [ADP] Where pat([F]PARAM,GFLAG)=1
   Read [ADP] First
   Filter [ADP]
   If !fstat
    [L]CHPDEB = [F:ADP]CHAPITRE
    [L]MODELE = GFLAG
   Else
    FIN = 1
   Endif
  Endif
 Endif
Endif
Return

#------------------------------------------------------------#
Subprog INIVAR(PARAM)
Value Char PARAM
If clalev([F:AGB])=0 : Local File AGLOBVAR [AGB] : Endif
If clalev([F:ADP])=0 : Local File ADOPAR   [ADP] : Endif
If clalev([F:ATY])=0 : Local File ATYPE    [ATY] : Endif
Read [AGB]AGB2 = [L]PARAM
If !fstat & evalue("dim("+[F:AGB]CODVAR+")>0")
 Read [ADP]ADP1 = [F:AGB]PARAM
 If !fstat
  Read [ATY]CODTYP = [F:AGB]CODTYP
  If !fstat
   Case [F:ADP]NIVDEF
    When 1,2,3,5
     Call PARAM("",[F:AGB]PARAM,GBIDC3) From ADOVAL
     Case [F:ATY]TYPTYP
      When 7 : Assign [F:AGB]CODVAR With GBIDC3
      When 4 : Assign [F:AGB]CODVAR With val(GBIDC3)
      When 8 : If len(GBIDC3)=0 : GBIDC3="00000000" : Endif : Assign [F:AGB]CODVAR With gdat$(GBIDC3)
      When 1 : Assign [F:AGB]CODVAR With val(GBIDC3)
     Endcase
    When 4
     Call PARAMUTIL([F:AGB]PARAM,GBIDC3,"","") From SUBAUS
     Case [F:ATY]TYPTYP
      When 7 : Assign [F:AGB]CODVAR With GBIDC3
      When 4 : Assign [F:AGB]CODVAR With val(GBIDC3)
      When 8 : If len(GBIDC3)=0 : GBIDC3="00000000" : Endif : Assign [F:AGB]CODVAR With gdat$(GBIDC3)
      When 1 : Assign [F:AGB]CODVAR With val(GBIDC3)
     Endcase
   Endcase
  Endif
 Endif
Endif
End

#------------------------------------------------------------#
Subprog CLEAR_PARAM
If dim(GSIPARAM)>0
 Raz [V]GNUPARAM,[V]GSIPARAM,[V]GVAPARAM
Endif
End

#------------------------------------------------------------#
Subprog PARAML(SITE,PARAM,VALEUR)
Value Char    SITE
Value Char    PARAM
Variable Char VALEUR()
Gosub PARAM_
###
End

#------------------------------------------------------------#
Subprog PARAM(SITE,PARAM,VALEUR)
Value Char    SITE
Value Char    PARAM
Variable Char VALEUR()
Gosub PARAM_
End


$PARAM_
#X3-69874
#X3-81818 X3-81554 wrong format date due to jira 69874 replace GFMD by "D:YYYYMMDD"

If dim(GACTX)>=0
  Local Integer PARAMTYPE, PARAMDEFLEV

  [L]PARAMTYPE = fmet GACTX.APARAM._AGETADPTYP([L]PARAM)
  [L]PARAMDEFLEV = fmet GACTX.APARAM._AGETADPLEV([L]PARAM)

  #PARAMTYPE : 1=Alphanumeric, 2=Numeric, 3=Date, 4=ML
  If [L]PARAMDEFLEV=4
    Case [L]PARAMTYPE
      When 1 : [L]VALEUR = fmet GACTX.APARAM.AGETUSERVALCHAR([L]PARAM)
      When 2, 4 : [L]VALEUR = num$(fmet GACTX.APARAM.AGETUSERVALNUM([L]PARAM))
      When 3 : [L]VALEUR = format$("D:YYYYMMDD",fmet GACTX.APARAM.AGETUSERVALDATE([L]PARAM))
      When Default : Raz [L]VALEUR
    Endcase
  Else
    Case [L]PARAMTYPE
      When 1 : [L]VALEUR = fmet GACTX.APARAM.AGETVALCHAR([L]PARAMDEFLEV,[L]SITE,[L]PARAM)
      When 2, 4 : [L]VALEUR = num$(fmet GACTX.APARAM.AGETVALNUM([L]PARAMDEFLEV,[L]SITE,[L]PARAM))
      When 3 : [L]VALEUR = format$("D:YYYYMMDD",fmet GACTX.APARAM.AGETVALDATE([L]PARAMDEFLEV,[L]SITE,[L]PARAM))
      When Default : Raz [L]VALEUR
    Endcase
  Endif
Else
    # read in database directly
    # jira 85115 simplified the code
    Local Integer RES_FOUND
    Local Char PARAMVAL(255)
    Local Char WAPPLI(80)
    WAPPLI = nomap
    Call _READ_DATA_ADOVAL(WAPPLI, SITE, PARAM, RES_FOUND, PARAMVAL) From ADP_TOOL
    VALEUR = PARAMVAL
Endif
Return


#------------------#
$SETLEG
Local Char LEG(GLONADI)
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
Gosub SETSOC
If SOCIETE<>""
 Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
 If !fstat
  LEG = [F:CPY]LEG
 Elsif find(SOCIETE,GDOSLEG(1..GNBLEG))
  LEG = SOCIETE
 Else
  LEG = ""
 Endif
Endif
Return

#-----------------#
$SETSOC
Local Char    SOCIETE(GLONCPY)
Local Integer ISITE
If SITE<>""
 ISITE = find(SITE,GSITE(1..GNBSITE))
 If ISITE
  SOCIETE = GSOCSITE(ISITE)
 Else
  SOCIETE = SITE
 Endif
Endif
Return

#------------------------------------------------------------#
$SEL_TABLE
Case TABLE
 When "ADOVALSEL"
  Read [ADP]ADP1 = [M]PARAM(nolign-1)
  If [F:ADP]OBJET<>""
   OBJET   = [F:ADP]OBJET
   OPTIONS = [F:ADP]SELOPT
   If instr(1,[F:ADP]VALUES(0),"~")
    I=0 : CHAINE = [F:ADP]VALUES(0)
    While instr(1,CHAINE,"~")>0
     SUPP(I)  = left$(CHAINE,instr(1,CHAINE,"~")-1)
     CHAINE   = right$(CHAINE,instr(1,CHAINE,"~")+1)
     I+=1
    Wend
    SUPP(I) = CHAINE
   Else
    If left$([F:ADP]VALUES(0),1)="="
     Onerrgo RIEN
     SUPP = evalue(right$([F:ADP]VALUES(0),2))
     Onerrgo
    Else
     SUPP = [F:ADP]VALUES(0)
    Endif
   Endif
  Else
   OK = 0
  Endif
 When "SELPARVAL"
  OBJET   = "ADP"
  ORDRE   = "PARAM"
  CRITERE = "MODIF=2"
  If dim([M]LEG)>0 & [M]LEG<>""
   CRITERE += " & (find(NIVDEF,2,3,5)<>0 | (NIVDEF=4 & VALDEF=2))"
  Elsif [M]CMP<>""
   CRITERE += " & (find(NIVDEF,2,3)<>0 | (NIVDEF=4 & VALDEF=2))"
  Elsif [M]FCY<>""
   CRITERE += " & (NIVDEF=3 | (NIVDEF=4 & VALDEF=2))"
  Else
   CRITERE += " & (NIVDEF<>4 | VALDEF=2)"
  Endif
Endcase
Return

$RIEN
Resume

#----------------------------------------------------------#
$VERF_TABLE
Case TABLE
 When "SELPARVAL"
  If [F:ADP]GRPPAR<>""
   If [F:ADP]CHAPITRE<>[M]CHAPITRE
    # Paramètre\appartient au chapitre
    Call MESSAGE(mess(143,105,1)-[F:ADP]PARAM+"\"+mess(92,142,1)-[F:ADP]CHAPITRE) From GESECRAN
   Else
    nolign = find([F:ADP]GRPPAR,[M:ADW1]GRPCOD)
    If nolign
     Local Char    PARPAR(250)(1..2)
     PARPAR(1) = [M:ADW1]GRPCOD(nolign-1)
     Call SAISIE_NUM(GBIDD1,PARPAR,"ADWP","ASAIPARVAL","") From GSAISIE
    Endif
   Endif
  Endif
Endcase
Return

#------------------------------------------------------------#
$SEL_LISTE
Case LISTE
 When "SELADV"
  NBTEX = 0
  For [ADI]CODE Where NUMTAB=901
   Gosub OKCHAP
   If OKCHAP
    NBTEX += 1
    TEX(NBTEX) = [F:ADI]CODE
    Read [AXX]AXX0 = "ATABDIV";"LNGDES";GLANGUE;"901";[F:ADI]CODE
    TEXTE(NBTEX) = [F:AXX]TEXTE
    If !fstat
     TEXTE(NBTEX) = TEX(NBTEX)-TEXTE(NBTEX)
    Endif
   Endif
  Next
 When "ADOVALLST"
  Read [ADP]ADP1 = [M]PARAM(nolign-1)
  If [F:ADP]NBVAL<>0
&  & [F:ADP]OBJET=""    # Issue X3-44568 - 2017-06-12 by CCC : NBVAL=1 if parameter of object
   Local Date    DAT
   For I=1 To [F:ADP]NBVAL
    Case [F:ADP]TYPVAL
     When 4       : TEX(I) = mess(val([F:ADP]VALUES(I-1)),[F:ADP]NOLIB,1)
     When 3       : DAT = [F:ADP]VALUES(I-1) : TEX(I) = format$("D:"+GFMDAT4,DAT)
     When 2       : TEX(I) = format$("N:15F",val([F:ADP]VALUES(I-1)))
     When Default : TEX(I) = [F:ADP]VALUES(I-1)
    Endcase
   Next I
   NBTEX = [F:ADP]NBVAL
  Else
   OK = 0
  Endif
Endcase
Return

#------------------------------------------------------------#
Subprog AS_NBGRP
Gosub SETBOX
End

Subprog C_NBGRP
If adxgtb=2 & find(status,129,130)
 mkstat = 2
Endif
End

Subprog AS_JEUCOD(VALEUR)
Variable Char VALEUR()
If dim([M]LEG)>0 & [M]LEG<>""
 GMODIF = 5
Elsif [M]CMP<>""
 GMODIF = 2
Elsif [M]FCY<>""
 GMODIF = 3
Else
 GMODIF = 1
Endif
End

Subprog AM_JEUCOD(VALEUR)
Variable Char VALEUR
For I=1 To [M]NBVAR
 If [M]GRPPAR(I-1)=GRPCOD(nolign-1)
  [M]GRPDEF(I-1) = VALEUR
  Read [ADG]ADG1 = VALEUR;[M]CHAPITRE;[M]GRPPAR(I-1);[M]PARAM(I-1)
  If !fstat
   [M]VALINT(I-1) = [F:ADG]VALEUR
   [M]VALEUR(I-1) = [F:ADG]VALEUR
   Call CHARGE([M]VALEUR(I-1),[M]TYP(I-1),[M]NOLIB(I-1),[M]LONG(I-1),[M]VALINT(I-1)) From FMTVAR
   Case GMODIF
    When 5 : [M]NIVEAU(I-1) = 5
    When 2 : [M]NIVEAU(I-1) = 2
    When 3 : [M]NIVEAU(I-1) = 3
    When 1 : [M]NIVEAU(I-1) = 1
   Endcase
  Endif
 Endif
Next I
Case GMODIF
 When 5 : [M]NIVGRP(nolign-1) = 5
 When 2 : [M]NIVGRP(nolign-1) = 2
 When 3 : [M]NIVGRP(nolign-1) = 3
 When 1 : [M]NIVGRP(nolign-1) = 1
Endcase
End

Subprog C_JEUCOD(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Gosub SETNOL
Read [ADG]ADG0(3)=[M]CHAPITRE;[M]GRPCOD(NOL);VALEUR
If fstat
 GMESSAGE = mess(23,100,1) : # Fiche inexistante
 mkstat = 1 : End
Endif
End

Subprog IB_JEUCOD
Local Char    CLE1(20) , CLE2(20)
Call TITOBJ("ADG","",GBOUT1) From CONTOBJ
Raz GBOUT3, GBOUT4 , GBOUT5
If [M]FCY<>""
 Call LECTURE("FCY",[M]FCY,"") From CONTOBJ
 CLE1 = [F:FCY]LEGCPY
 CLE2 = ""
 Gosub SET_JEU
 If CODJEU<>""
  GBOUT5 = mess(85,123,1)-"("+CODJEU+")" : # Valeur société
 Endif
Endif
If dim([M]LEG)>0 & ([M]FCY<>"" | [M]CMP<>"")
 If [M]CMP<>""
  Call LECTURE("CPY",[M]CMP,"") From CONTOBJ
 Elsif [M]FCY<>""
  Call LECTURE("FCY",[M]FCY,"") From CONTOBJ
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
 Endif
 CLE1 = "*"
 CLE2 = [F:CPY]LEG
 Gosub SET_JEU
 If CODJEU<>""
  GBOUT4 = mess(217,123,1)-"("+CODJEU+")" : # Valeur législation
 Endif
Endif
If [M]FCY<>"" | [M]CMP<>"" | (dim([M]LEG)>0 & [M]LEG<>"")
 CLE1 = ""
 CLE2 = ""
 Gosub SET_JEU
 If CODJEU<>""
  GBOUT3 = mess(84,123,1)-"("+CODJEU+")"  : # Valeur dossier
 Endif
Endif
End

$SET_JEU
Local Char    CODJEU(GLONADI)
Local Integer K
Filter [ADG] Where CHAPITRE=[M]CHAPITRE & GRPPAR=[M]GRPCOD(nolign-1)
Raz CODJEU
For [ADG]ADG1(1)
 CODJEU = [F:ADG]GRPDEF
 For [ADG]ADG1
  K = find([F:ADG]PARAM,[M]PARAM)
  If K
   Read [ADW]ADW0 = CLE1;CLE2;[F:ADG]PARAM
   If fstat | [F:ADW]VALEUR<>[F:ADG]VALEUR
    CODJEU = ""
    Break
   Endif
  Endif
 Next ADG
 If CODJEU<>""
  Break
 Endif
Next ADG_1
Filter [ADG]
Return

Subprog B1_JEUCOD(VALEUR)
Variable Char    VALEUR()
Local Char CHP(GLONADI) , JEU(GLONADP)
Local Integer I
Gosub SETNOL
CHP = [M]CHAPITRE
JEU = VALEUR
If JEU=""
 Filter [ADG] Where CHAPITRE=[M]CHAPITRE & GRPPAR=[M]GRPCOD(NOL)
 Read [ADG] First
 If !fstat
  JEU = [F:ADG]GRPDEF
 Endif
 Filter [ADG]
Endif
Call OBJET_CHAR([M]GRPCOD(NOL),"ADG",CHP+"~"+JEU) From GOBJET
mkstat = 4
End

Subprog B2_JEUCOD(VALEUR)
Variable Char    VALEUR()
Local Char    PARMSK(250)(1..20)
Gosub SETNOL
PARMSK(1) = [M]GRPCOD(NOL)
Call SAISIE_CHAR(VALEUR,PARMSK,"ADWP","ASAIPARVAL","") From GSAISIE
For I=1 To [M]NBVAR
 If [M]GRPCOD(NOL)=[M]GRPPAR(I-1)
  VALEUR = [M]GRPDEF(I-1)
  [M]JEUCOD(NOL) = [M]GRPDEF(I-1)
  Break
 Endif
Next I
mkstat = 4
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

Subprog B3_JEUCOD(VALEUR)
Variable Char    VALEUR()
Local Char    CLE1(20) , CLE2(20)
CLE1 = ""
CLE2 = ""
Gosub SET_JEU
If CODJEU<>""
 VALEUR = CODJEU
 GMODIF = 1
 mkstat = 4
Endif
End

Subprog B4_JEUCOD(VALEUR)
Variable Char    VALEUR()
Local Char    CLE1(20) , CLE2(20)
If [M]CMP<>""
 Call LECTURE("CPY",[M]CMP,"") From CONTOBJ
Elsif [M]FCY<>""
 Call LECTURE("FCY",[M]FCY,"") From CONTOBJ
 Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
Endif
CLE1 = "*"
CLE2 = [F:CPY]LEG
Gosub SET_JEU
If CODJEU<>""
 VALEUR = CODJEU
 mkstat = 4
 GMODIF = 5
Else
 CLE1 = ""
 CLE2 = ""
 Gosub SET_JEU
 If CODJEU<>""
  VALEUR = CODJEU
  mkstat = 4
  GMODIF = 1
 Endif
Endif
End

Subprog B5_JEUCOD(VALEUR)
Variable Char    VALEUR()
Local Char    CLE1(max(GLONCPY,GLONFCY,GLONADI)) , CLE2(max(GLONCPY,GLONFCY,GLONADI))
Local Integer OK
OK = 0
Call LECTURE("FCY",[M]FCY,"") From CONTOBJ
CLE1 = [F:FCY]LEGCPY
CLE2 = ""
Gosub SET_JEU
If CODJEU<>""
 VALEUR = CODJEU
 mkstat = 4
 GMODIF = 2
 OK = 1
Endif
If !OK & dim([M]LEG)>0
 Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
 CLE1 = "*"
 CLE2 = [F:CPY]LEG
 Gosub SET_JEU
 If CODJEU<>""
  VALEUR = CODJEU
  mkstat = 4
  GMODIF = 5
  OK = 1
 Endif
Endif
If !OK
 CLE1 = ""
 CLE2 = ""
 Gosub SET_JEU
 If CODJEU<>""
  VALEUR = CODJEU
  mkstat = 4
  GMODIF = 1
 Endif
Endif
End

