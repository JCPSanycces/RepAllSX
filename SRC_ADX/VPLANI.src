Subprog C_ANNEE(VALEUR)
Variable Decimal VALEUR
#ADNGO - 2017-02-15 - X3-11509 - START
If VALEUR<1900
 GMESSAGE = mess(106,10709,1) : # Annﾃｩe incorrecte
 mkstat = 2 : End
Endif
#ADNGO - 2017-02-15 - X3-11509 - END
End


