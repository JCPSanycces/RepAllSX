#<AdxTL>@(#)0.0.0.0 $Revision$
# Modifications :
#    FQ81491 - 15/11/13 - prise en compte date d'effet + fiches de rﾃｩtroactivitﾃｩ
#    FQ92896 US2872 - 09/17/14 - passage nouveau composant pour le client fusion #SBA

GUSRAUZ(1) = "1"
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"VPLANI","VPLANI","") From GSAISIE
End

$ACTION
Case ACTION
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "SUI"         : Gosub SUIVPREC
 When "PRE"         : Gosub SUIVPREC
 When "FIR"         : Gosub SUIVPREC
 When "LAS"         : Gosub SUIVPREC
 When "ABA"         : Gosub ABANDON
 When "ENR"         : Gosub ENREGISTRER
 When "SETBOUT"     : Gosub SETBOUT
 When Default
Endcase
Return

$DEBUT
Local Char    CRITERE(250)
Local Integer I , J , K , NOL, PSPE
Local Integer TYPJOU , TOUS
If clalev([F:ID])=0  : Local File EMPLOID  [ID]  : Endif
If clalev([F:PLE])=0 : Local File PLANEMP  [PLE] : Endif
If clalev([F:BBB])=0 : Local File BBLOB    [BBB] : Endif
If clalev([F:HLY])=0 : Local File HLYDAY   [HLY] : Endif
#ADNGO - 2017-01-23 - X3-11509 - START
#If clalev([F:CTR])=0 : Local File EMPLOCTR [CTR] : Endif
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
#ADNGO - 2017-01-23 - X3-11509 - END
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:PLN])=0 : Local File PLANTYP  [PLN] : Endif
If clalev([F:WTY])=0 : Local File TYPWEEK  [WTY] : Endif
If clalev([F:NAT])=0 : Local File NATACTIV [NAT] : Endif
If instr(1,GUSRAUZ(1),"1") : # Tous utilisateurs
 TOUS = 1
Else
 TOUS = 0
Endif
Call EXISTE_ADX("","","SPEVPLAN",PSPE) From ORDSYS
Gosub INIT_ACTIV
Gosub ACTZONE
[M:VPL0]REFNUM = GREFNUM
##71976 : GMOIPAY is now in 'Common module'
#65879
##If GPAYE
 [M:VPL0]ANNEE  = year(GMOIPAY)
##Else
## [M:VPL0]ANNEE  = year(datesyst)
##Endif

If [M:VPL0]REFNUM<>""
 Call C_REFNUM([M:VPL0]REFNUM)
 Call AM_REFNUM([M:VPL0]REFNUM)
 If [M:VPL0]REFNUM<>"" & [M:VPL0]CTRNUM<>""
  Gosub REMPLIT
 Endif
#41674
Else
 Effzo [M:VPL0]
 ##71976 : GMOIPAY is now in 'Common module'
 #65879
 ##If GPAYE
  [M:VPL0]ANNEE  = year(GMOIPAY)
 ##Else
 ## [M:VPL0]ANNEE  = year(datesyst)
 ##Endif
Endif
Affzo [M:VPL0]
Return

$ACTZONE
Actzo [VPL0]ANNEE
If TOUS
 Actzo [VPL0]REFNUM
Else
 Grizo [VPL0]REFNUM
Endif
Return

$GRIZONE
Grizo [VPL0]ANNEE,REFNUM
Return

$SETBOUT
CHBOU = ""
#SBA : sup ref [M:VPL2]
#If find(1,[M:VPL1]FLMOD(0..[M:VPL1]NBDAY)) | find(1,[M:VPL2]FLMOD(0..[M:VPL2]NBDAY))
If find(1,[M:VPL1]FLMOD(0..[M:VPL1]NBDAY))
 CHBOU += "EA"
Elsif TOUS
 CHBOU += "09<>"
Endif
Return

$APRES_MODIF
If find(COUZON,"REFNUM","ANNEE","CTRNUM")
 Assign "[M:VPL0]"+COUZON With zc
 Gosub REMPLIT
Endif
Return

$SUIVPREC
Filter [ID] Where ENAFLG=2 & FLGTPS=2
Case ACTION
 When "FIR" : Read [ID]ID0 First : ACTION = "SUI"
 When "LAS" : Read [ID]ID0 Last  : ACTION = "PRE"
 When "SUI" : Read [ID]ID0 > [M:VPL0]REFNUM
 When "PRE" : Read [ID]ID0 < [M:VPL0]REFNUM
Endcase
If fstat<=2
 mkstat = 0
 Call DROIT([F:ID]REFNUM) From DIVPAYE
 If mkstat
  Goto SUIVPREC
 Else
  Effzo [VPL0]CTRNUM,CPY,ZCPY,FCY,ZFCY,SRV,ZSRV,JOB
  [M:VPL0]REFNUM = [F:ID]REFNUM
  Call C_REFNUM([M:VPL0]REFNUM)
  Call AM_REFNUM([M:VPL0]REFNUM)
  Gosub REMPLIT
  #61235
  Affzo [M:VPL0]
 Endif
Endif
Filter [ID]
Return

$REMPLIT
Effzo [VPL1]20
# SBA
#Effzo [VPL2]20
If [M:VPL0]REFNUM="" : Return : Endif
Gosub INIT_H
#ADNGO - 2017-02-01 - X3-11509 - START
#Read [HLY]HLY0 = [M:VPL0]ANNEE;[M:VPL0]FCY
Read [HLY]HLY0 = [M:VPL0]ANNEE;[M:VPL0]FCY;GCURLEG
#ADNGO - 2017-02-01 - X3-11509 - END
If fstat
#ADNGO - 2017-02-01 - X3-11509 - START
 #Read [HLY]HLY0 = [M:VPL0]ANNEE;""
 Read [HLY]HLY0 = [M:VPL0]ANNEE;"";GCURLEG
#ADNGO - 2017-02-01 - X3-11509 - END
 If fstat
  Raz [F:HLY]
 Endif
Endif
Raz CRITERE
CRITERE  = 'REFNUM="'+[M:VPL0]REFNUM+'"'
CRITERE -= '& CTRNUM="'+[M:VPL0]CTRNUM+'"'
CRITERE -= '& YEA='+num$([M:VPL0]ANNEE)
[M:VPL1]NBDAY = gdat$(31,12,[M:VPL0]ANNEE)-gdat$(1,1,[M:VPL0]ANNEE)+1
# SBA
#[M:VPL2]NBDAY = gdat$(31,12,[M:VPL0]ANNEE)-gdat$(1,1,[M:VPL0]ANNEE)+1
#TYPJOU = TYPDEF : # Non dﾃｩfini
# SBA
#Default Mask [VPL2]
#Gosub REMP_TAB
#Affzo [VPL2]
TYPJOU = TYPDEF : # Non dﾃｩfini
Default Mask [VPL1]
Gosub REMP_TAB
Affzo [VPL1]
SUIZON = "NBDAY"
Return

$REMP_TAB
For NOL=0 To [M]NBDAY-1
 [M]DAT(NOL) = gdat$(1,1,[M:VPL0]ANNEE)+NOL
 Call TRSFDATP([M]DAT(NOL),[M]DATI(NOL)) From INTRUTILA
 If find([M]DAT(NOL),[F:HLY]HLYDAY(0..[F:HLY]NBRDAY-1))
  [M]TYPDAY(NOL) = 2 : # Chﾃｴmﾃｩ
 Else
  If NOL<LG
   Case mid$(LISJOU1,NOL+1,1)
    When "1"     : [M]TYPDAY(NOL) = 3 : # Ouvrable
    When "2"     : [M]TYPDAY(NOL) = 1 : # Ouvrﾃｩ
    When Default : [M]TYPDAY(NOL) = 2 : # Chﾃｴmﾃｩ
   Endcase
   For I=1 To NPLAG
    Assign "[M]PLAG"+num$(I)+"("+num$(NOL)+")" With evalue("NATPLAG1"+num$(I)+"(NOL)")
   Next I
  Else
   Case mid$(LISJOU2,NOL-LG+1,1)
    When "1"     : [M]TYPDAY(NOL) = 3 : # Ouvrable
    When "2"     : [M]TYPDAY(NOL) = 1 : # Ouvrﾃｩ
    When Default : [M]TYPDAY(NOL) = 2 : # Chﾃｴmﾃｩ
   Endcase
   For I=1 To NPLAG
    Assign "[M]PLAG"+num$(I)+"("+num$(NOL)+")" With evalue("NATPLAG2"+num$(I)+"(NOL-LG)")
   Next I
  Endif
 Endif
Next

For [PLE] Where evalue(CRITERE)
 NOL = [F:PLE]DAT-gdat$(1,1,[M]ANNEE)
 If NOL>=0 & NOL<=[M]NBDAY
  For I=1 To NPLAG
   If [F:PLE]TYPDAY=3 | [F:PLE]STRTIM(I-1)="" : # Jour chﾃｴmﾃｩ
    TYPJOU = TYPCNG
   Elsif [F:PLE]NATCOD(I-1)=""
    TYPJOU = TYPAUT
   Else
    For J=1 To NBACTIV
     Raz TYPJOU
     If find([F:PLE]NATCOD(I-1),TBACTIV(J,1..MAXACT))<>0
      TYPJOU = J : Break
     Endif
    Next
    If TYPJOU=0 : TYPJOU = TYPAUT : Endif
   Endif
   Assign "[M]PLAG"+num$(I)+"("+num$(NOL)+")" With TYPJOU
  Next I
 Endif
Next
Return

$ENREGISTRER
Call DEBTRANS From GLOCK
# SBA
#Default Mask [VPL2]
#Gosub TR1
Default Mask [VPL1]
Gosub TR1
Raz [M:VPL1]FLMOD
# SBA
#Raz [M:VPL2]FLMOD
Gosub ACTZONE
Gosub REMPLIT
Return

$TR1
GOK = 1
Trbegin [PLE]
 For I=0 To [M]NBDAY-1
  If [M]FLMOD(I)=1
   Readlock [PLE]PLE0 = [M:VPL0]REFNUM;[M]DAT(I);[M:VPL0]CTRNUM
   If fstat=1
    GOK = -1 : GLOCK = "PLANEMP"-[M:VPL0]REFNUM : Break
   Elsif fstat
    Raz [F:PLE]
    [F:PLE]REFNUM = [M:VPL0]REFNUM
    [F:PLE]CTRNUM = [M:VPL0]CTRNUM
    [F:PLE]YEA    = [M:VPL0]ANNEE
    [F:PLE]DAT    = [M]DAT(I)
    Gosub SET_ACTIV
    If FLDEF
     Write [PLE]
    Endif
   Else
    Gosub SET_ACTIV
    If FLDEF
     Rewrite [PLE]
    Else
     Delete [PLE]
    Endif
   Endif
   If fstat
    GOK = 0 : Call FSTA("PLE") From GLOCK : Break
   Endif
  Endif
 Next I
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$SET_ACTIV
FLDEF = 0
[F:PLE]NBRHOU = 0
For J=1 To NPLAG
 TYPJOU = evalue("[M]PLAG"+num$(J)+"("+num$(I)+")")
 If TYPJOU<>TYPDEF : FLDEF = 1 : Endif
 [F:PLE]NATCOD(J-1) = ACTIVDEF(TYPJOU)
 If [F:PLE]NATCOD(J-1)<>""
  If I<LG
   [F:PLE]STRTIM(J-1) = evalue("DEBPLAG1"+num$(J)+"(I)")
   [F:PLE]ENDTIM(J-1) = evalue("FINPLAG1"+num$(J)+"(I)")
   [F:PLE]BRKTIM(J-1) = evalue("DURPLAG1"+num$(J)+"(I)")
   [F:PLE]NBRHOU      = HEURES1(I)
  Else
   [F:PLE]STRTIM(J-1) = evalue("DEBPLAG2"+num$(J)+"(I-LG)")
   [F:PLE]ENDTIM(J-1) = evalue("FINPLAG2"+num$(J)+"(I-LG)")
   [F:PLE]BRKTIM(J-1) = evalue("DURPLAG2"+num$(J)+"(I-LG)")
   [F:PLE]NBRHOU      = HEURES2(I-LG)
  Endif
 Endif
Next J
If sum([F:PLE]NATCOD)=""
 [F:PLE]TYPDAY = 3
 [F:PLE]NBRDAY = 0
 Raz [F:PLE]NBRHOU,STRTIM,ENDTIM,BRKTIM,CCE1,CCE2,CCE3,CCE4,CCE5,CCE6,CCE7,CCE8,CCE9
Else
 [F:PLE]TYPDAY = 2
 If I<LG
  [F:PLE]NBRDAY = ar2([F:PLE]NBRHOU/HEURES1(I))
 Else
  [F:PLE]NBRDAY = ar2([F:PLE]NBRHOU/HEURES2(I-LG))
 Endif
Endif
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$ABANDON
Gosub REMPLIT
Gosub ACTZONE
Return

Subprog C_REFNUM(VALEUR)
Variable Char    VALEUR()
Effzo [VPL0] NOM,PHOTO
Read [ID]ID0 = VALEUR
If !fstat
 [M:VPL0]NOM = [F:ID]NAM-[F:ID]SRN : Affzo [VPL0] NOM
 Read [BBB]BBB0 = "EMPPIC";VALEUR;"";"";""
 If !fstat
  [M:VPL0]PHOTO = [F:BBB]BLOB : Affzo [VPL0]PHOTO
 Endif
Endif
End

Subprog AM_REFNUM(VALEUR)
Variable Char     VALEUR
#62139
Raz [M]CTRNUM
If [F:ID]FLGMULCTR<>2
 Call CHERCHE_CTR(VALEUR,date$,[M:VPL0]CTRNUM) From DIVPAYE
 Affzo [M:VPL0]CTRNUM
 Call MAJ_ZONE(VALEUR,[M:VPL0]CTRNUM)
Endif
Call GRISE_CTRNUM([F:ID]FLGMULCTR)
#ADNGO - 2017-03-01 - X3-11509 - START
If !clalev([F:HRCTR2]) : Local File EMPLOCTR [HRCTR2] : Endif
  If !clalev([F:FCY2]) : Local File FACILITY [FCY2]  : Endif
    Filter  [HRCTR2] Where CTRNUM=[M:VPL0]CTRNUM
    Read [HRCTR2] First
    Filter [HRCTR2]
    Read [FCY2]FCY0 = [F:HRCTR2]ETRFCY
    If !fstat
    GCURLEG = [F:FCY2]LEG
    [M:VPL0]LEG = GCURLEG
    Affzo [M:VPL0]LEG
    Endif
#ADNGO - 2017-03-01 - X3-11509 - END
End

Subprog AS_CTRNUM(VALEUR)
Variable Char     VALEUR
If [M:VPL0]CTRNUM=""
 Call SELCTR([M:VPL0]REFNUM,date$,date$,VALEUR) From DIVPAYE
Endif
End

Subprog AM_CTRNUM(VALEUR)
Variable Char     VALEUR
Call MAJ_ZONE([M:VPL0]REFNUM,VALEUR)
End

Subprog MAJ_ZONE(MATRI,CTR)
Value Char MATRI,CTR
If clalev([F:ECT])=0 : Local File EMPCTR   [ECT] : Endif
#ADNGO - 2017-01-23 - X3-11509 - START
#If clalev([F:CTR])=0 : Local File EMPLOCTR [CTR] : Endif
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
#ADNGO - 2017-01-23 - X3-11509 - END
Read [ECT]ECT0=MATRI;CTR
If !fstat
 [M:VPL0]FCY = [F:ECT]FCY
 [M:VPL0]SRV = [F:ECT]SRV
 Affzo [VPL0]FCY, ZFCY, SRV, ZSRV
 Read [FCY]FCY0=[F:ECT]FCY
 [M:VPL0]CPY = [F:FCY]LEGCPY
 Affzo [VPL0]CPY,ZCPY
 #ADNGO - 2017-01-23 - X3-11509 - START
 #Read [CTR]CTR2 = MATRI;CTR;[F:ECT]NBRCTR
 Read [HRCTR]CTR2 = MATRI;CTR;[F:ECT]NBRCTR
 #ADNGO - 2017-01-23 - X3-11509 - END
 If !fstat
  #ADNGO - 2017-01-23 - X3-11509 - START
  #[M:VPL0]JOB = [F:CTR]JOB
  [M:VPL0]JOB = [F:HRCTR]JOB
  #ADNGO - 2017-01-23 - X3-11509 - END
  Affzo [VPL0]JOB
 Endif
Endif
End

Subprog GRISE_CTRNUM(VALEUR)
Value Integer VALEUR
If VALEUR=2
 Actzo [M:VPL0]CTRNUM
Else
 Diszo [M:VPL0]CTRNUM
Endif
Affzo [M:VPL0]CTRNUM
End

Subprog B1_NBDAY
#57659
#Local Char PARAM(30)(1..2) , VALEUR(30)
Local Char PARAM(30)(1..3) , VALEUR(30)
PARAM(1) = [M:VPL0]REFNUM
PARAM(2) = [M]DAT(nolign-1)
#57659
PARAM(3) = [M:VPL0]CTRNUM
Call SAISIE_CHAR(VALEUR,PARAM,"WFPLE","PLNEMP","XWPLNEMP") From GSAISIE
End

######################################################################################
## Interactivitﾃｩ
######################################################################################
Subprog MAJPLAN(LDEB,PLAGED,LFIN,PLAGEF,ETAT,MESSAGE,CODRET)
Value Integer LDEB
Value Integer PLAGED
Value Integer LFIN
Value Integer PLAGEF
Value Integer ETAT
Variable Char MESSAGE()
Variable Integer CODRET
Local Integer NOL , PLAGE, PSPE

Call EXISTE_ADX("","","SPEVPLAN",PSPE) From ORDSYS
Gosub INIT_ACTIV
Gosub INIT_H
NOL = LDEB-1
If LDEB<>LFIN
 For PLAGE=PLAGED To NPLAG
  Gosub MAJP
 Next PLAGE
 For NOL=LDEB To LFIN-2
  For PLAGE=1 To NPLAG
   Gosub MAJP
  Next
 Next NOL
 NOL = LFIN-1
 For PLAGE=1 To PLAGEF
  Gosub MAJP
 Next PLAGE
Else
 For PLAGE=PLAGED To PLAGEF
  Gosub MAJP
 Next PLAGE
Endif
CODRET = 1
mkstat = 4
Gosub GRIZONE
End

$MAJP
If [M]TYPDAY(NOL)=1
 Case PLAGE
  When 1 : [M]PLAG1(NOL) = ETAT : Affzo PLAG1(NOL)
  When 2 : [M]PLAG2(NOL) = ETAT : Affzo PLAG2(NOL)
  When 3 : [M]PLAG3(NOL) = ETAT : Affzo PLAG3(NOL)
  When 4 : [M]PLAG4(NOL) = ETAT : Affzo PLAG4(NOL)
 Endcase
 [M]FLMOD(NOL) = 1
Endif
Return

######################################################################################
## Initialisation
######################################################################################
$INIT_ACTIV
Local Integer NPLAG , NBACTIV, MAXACT, JR
#ADNGO - 2017-01-23 - X3-11509 - START
#NBACTIV = len(mess(0,417,1))
NBACTIV = len(mess(0,10417,1))
#ADNGO - 2017-01-23 - X3-11509 - END
MAXACT  = 50
Local Integer TYPCNG , TYPDEF, TYPAUT
# 8 options max dans le menu 417=>6 groupes max. Les 2 derniﾃｨres options sont "Chﾃｴmﾃｩ" et "Non dﾃｩfini"
# Chﾃｴmﾃｩ
# Non dﾃｩfini (le planning n'est pas saisi)
Local Char    TBACTIV(GLONNAT)(1..NBACTIV,1..MAXACT) :# Natures d'activitﾃｩ associﾃｩes ﾃ chaque groupe
Local Char    ACTIVDEF(GLONNAT)(1..NBACTIV)          :# Natures d'activitﾃｩ par dﾃｩfaut pour chaque groupe
Local Char    DEBPLAG11(4)(200), DEBPLAG21(4)(200), DEBPLAG12(4)(200), DEBPLAG22(4)(200)
Local Char    DEBPLAG13(4)(200), DEBPLAG23(4)(200), DEBPLAG14(4)(200), DEBPLAG24(4)(200)
Local Char    FINPLAG11(4)(200), FINPLAG21(4)(200), FINPLAG12(4)(200), FINPLAG22(4)(200)
Local Char    FINPLAG13(4)(200), FINPLAG23(4)(200), FINPLAG14(4)(200), FINPLAG24(4)(200)
Local Integer NATPLAG11(200), NATPLAG21(200), NATPLAG12(200), NATPLAG22(200)
Local Integer NATPLAG13(200), NATPLAG23(200), NATPLAG14(200), NATPLAG24(200)
Local Decimal DURPLAG11(200), DURPLAG21(200), DURPLAG12(200), DURPLAG22(200)
Local Decimal DURPLAG13(200), DURPLAG23(200), DURPLAG13(200), DURPLAG23(200)
Local Decimal HEURES1(200), HEURES2(200)
Local Char    LISJOU1(200), LISJOU2(200)
Local Date    DATDEB, DATFIN
Local Integer DECALJOU
Local Integer LG
LG=dim(HEURES1)

For [NAT]NAT0
 I = find("",TBACTIV([F:NAT]PLNEMP,1..MAXACT))
 If I<>0
  TBACTIV([F:NAT]PLNEMP,I) = [F:NAT]COD
 Endif
 If I=1
  ACTIVDEF([F:NAT]PLNEMP) = [F:NAT]COD
 Endif
 If [F:NAT]FLGDEF=2
  ACTIVDEF([F:NAT]PLNEMP) = [F:NAT]COD
 Endif
Next

TYPCNG = NBACTIV-1   : # Jour chﾃｴmﾃｩ
TYPDEF = NBACTIV     : # Non dﾃｩfini (planning inexistant)
TYPAUT = NBACTIV-2   : # Planning existant mais nature vide
If dim([M:VPL1]PLAG1)>0 : NPLAG = 1 : Endif
If dim([M:VPL1]PLAG2)>0 : NPLAG = 2 : Endif
If dim([M:VPL1]PLAG3)>0 : NPLAG = 3 : Endif
ACT = "DEBUT" : Gosub ACT
Return

$INIT_H
# FQ81491 - 15/11/13 - Prise en compte date d'effet, d'oﾃｹ l'ajout de FLGRET et RETDATEFF
#ADNGO - 2017-01-23 - X3-11509 - START
#Filter [CTR] Where REFNUM=[M:VPL0]REFNUM & CTRNUM=[M:VPL0]CTRNUM & ((FLGRET<>2 & CTRDAT<=gdat$(31,12,[M:VPL0]ANNEE)) | (FLGRET=2 & RETDATEFF<=gdat$(31,12,[M:VPL0]ANNEE)))
#Read [CTR]CTR1 Last
#Filter [CTR]
#If !fstat & [F:CTR]PLNTYP<>""
# Read [PLN]PLN0=[M:VPL0]ANNEE;[F:CTR]PLNTYP
Filter [HRCTR] Where REFNUM=[M:VPL0]REFNUM & CTRNUM=[M:VPL0]CTRNUM & ((FLGRET<>2 & CTRDAT<=gdat$(31,12,[M:VPL0]ANNEE)) | (FLGRET=2 & RETDATEFF<=gdat$(31,12,[M:VPL0]ANNEE)))
Read [HRCTR]CTR1 Last
Filter [HRCTR]
#MIPEA - 2017-11-27- US X3-63170- START
Call SET_GFIRDAY([F:HRCTR]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-27- US X3-63170- END
If !fstat & [F:HRCTR]PLNTYP<>""
 Read [PLN]PLN0=[M:VPL0]ANNEE;[F:HRCTR]PLNTYP;GCURLEG
#ADNGO - 2017-01-23 - X3-11509 - END
 If fstat
 #ADNGO - 2017-01-23 - X3-11509 - START
  #Read [PLN]PLN0=[M:VPL0]ANNEE;GPLANNING
  Read [PLN]PLN0=[M:VPL0]ANNEE;GPLANNING;GCURLEG
 #ADNGO - 2017-01-23 - X3-11509 - END
 Endif
Else
#ADNGO - 2017-01-23 - X3-11509 - START
 #Read [PLN]PLN0=[M:VPL0]ANNEE;GPLANNING
 Read [PLN]PLN0=[M:VPL0]ANNEE;GPLANNING;GCURLEG
#ADNGO - 2017-01-23 - X3-11509 - END
Endif
If !fstat
 Raz LISJOU1, LISJOU2, JR
 # Le 1er jour de l'annﾃｩe ne commence pas forcﾃｩment un lundi et dans la semaine type on peut ﾃｪtre ﾃ cheval sur 2 annﾃｩes.
 # Dans LISJOU on ne doit avoir que les jours de l'annﾃｩe => DECALJOU.
 Call SEMAINE([M:VPL0]ANNEE,1,DATDEB,DATFIN) From SUBPLN
 DECALJOU = gdat$(01,01,[M:VPL0]ANNEE)-DATDEB
 #61588
 If DECALJOU<0 : DECALJOU=7+DECALJOU : Endif
 #
 For K=0 To dim([F:PLN]WEKTYP)-1
  #ADNGO - 2017-01-23 - X3-11509 - START
  #Read [WTY]WTY0=[F:PLN]WEKTYP(K)
  Read [WTY]WTY0=GCURLEG;[F:PLN]WEKTYP(K)
  #ADNGO - 2017-01-23 - X3-11509 - END
  If !fstat
   For J=0+DECALJOU To dim([F:WTY]TYPDAY)-1
    If len(LISJOU1)<LG
     LISJOU1 +=num$([F:WTY]TYPDAY(J))
    Else
     LISJOU2 +=num$([F:WTY]TYPDAY(J))
    Endif
    If [F:WTY]TYPDAY(J)=2
     If JR<LG
      HEURES1(JR) = [F:WTY]NBRHRS1(J)
      For I=1 To NPLAG
       Assign "DEBPLAG1"+num$(I)+"(JR)" With evalue("[F:WTY]STRTIM"+num$(I-1)+"("+num$(J)+")")
       Assign "FINPLAG1"+num$(I)+"(JR)" With evalue("[F:WTY]ENDTIM"+num$(I-1)+"("+num$(J)+")")
       Assign "DURPLAG1"+num$(I)+"(JR)" With evalue("[F:WTY]BRKTIM"+num$(I-1)+"("+num$(J)+")")
       If evalue("[F:WTY]NATCOD"+num$(I-1)+"("+num$(J)+")")<>""
       #ADNGO - 2017-01-23 - X3-11509 - START
        #Read [NAT]NAT0=evalue("[F:WTY]NATCOD"+num$(I-1)+"("+num$(J)+")")
        Read [NAT]NAT0=GCURLEG;evalue("[F:WTY]NATCOD"+num$(I-1)+"("+num$(J)+")")
       #ADNGO - 2017-01-23 - X3-11509 - END
        Assign "NATPLAG1"+num$(I)+"(JR)" With [F:NAT]PLNEMP
       Elsif evalue("[F:WTY]ENDTIM"+num$(I-1)+"("+num$(J)+")")<>""
        Assign "NATPLAG1"+num$(I)+"(JR)" With TYPDEF
       Else
        Assign "NATPLAG1"+num$(I)+"(JR)" With TYPCNG
       Endif
      Next
     Else
      HEURES2(JR-LG) = [F:WTY]NBRHRS1(J)
      For I=1 To NPLAG
       Assign "DEBPLAG2"+num$(I)+"(JR-LG)" With evalue("[F:WTY]STRTIM"+num$(I-1)+"("+num$(J)+")")
       Assign "FINPLAG2"+num$(I)+"(JR-LG)" With evalue("[F:WTY]ENDTIM"+num$(I-1)+"("+num$(J)+")")
       Assign "DURPLAG2"+num$(I)+"(JR-LG)" With evalue("[F:WTY]BRKTIM"+num$(I-1)+"("+num$(J)+")")
       If evalue("[F:WTY]NATCOD"+num$(I-1)+"("+num$(J)+")")<>""
       #ADNGO - 2017-01-23 - X3-11509 - START
        #Read [NAT]NAT0=evalue("[F:WTY]NATCOD"+num$(I-1)+"("+num$(J)+")")
        Read [NAT]NAT0=GCURLEG;evalue("[F:WTY]NATCOD"+num$(I-1)+"("+num$(J)+")")
       #ADNGO - 2017-01-23 - X3-11509 - END
        Assign "NATPLAG2"+num$(I)+"(JR-LG)" With [F:NAT]PLNEMP
       Elsif evalue("[F:WTY]ENDTIM"+num$(I-1)+"("+num$(J)+")")<>""
        Assign "NATPLAG2"+num$(I)+"(JR-LG)" With TYPDEF
       Else
        Assign "NATPLAG2"+num$(I)+"(JR-LG)" With TYPCNG
       Endif
      Next
     Endif
    Endif
    JR +=1
   Next
  Endif
  DECALJOU=0
 Next
Endif
ACT = "MODIF" : Gosub ACT
Return

$ACT
If PSPE : Gosub ACTION From SPEVPLAN : Endif
Return

