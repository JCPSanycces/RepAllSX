# GLE - 10.12.2009 - FQ60756 - Présenter les champs "affichés" dans la sélection lien dépense-biens
################################################################################
# Mon petit bazar jusqu'à ce que je le connaisse par coeur
#     Infbox "nolign="-num$(nolign)
################################################################################
Call OBJET("LDA",GBIDC1,GBIDC2) From GOBJET
End

################################################################################
$ACTION
  Case ACTION
    When "SEL_TABLE"      : Gosub SEL_TABLE
    When "SEL_LISTE"      : Gosub SEL_LISTE
    When Default
  Endcase
Return

#-------------------------------------------------------------------------------
$SEL_TABLE
  Case TABLE
    When "SELBIPLIK1"    : Gosub SET_TAMZLIK1
  Endcase
Return

#-------------------------------------------------------------------------------
$SEL_LISTE
  Case LISTE
    When "SELBIPLIK"   : Gosub SET_LAWILIK
    When "SELAWILIK1"  : Gosub SET_LAWIZLIK1
    When "SELAWILIK2"  : Gosub SET_LAWIZLIK2
    When "SELAWILIKI"  : Gosub SET_LAWIZLIKI
  Endcase
Return

#-------------------------------------------------------------------------------
$SET_LAWILIK
# Liste liste : sur les écrans d'une fenêtre passée
#
Local Char LWIN, CHAINE
Local Integer N_I

  If clalev([F:AWIB])=0 : Local File AWINDOW [AWIB] : Endif
  If clalev([F:ATXB])=0 : Local File ATEXTE  [ATXB] : Endif

  LWIN   = PARAM(1)
  NBTEX = 0
  Filter [AWIB] Where WIN=LWIN
  Read [AWIB]AWI0 First
  Filter [AWIB]

  #NBTEX += 1
  #TEX(NBTEX)   = [F:AWIB]MSKENT
  #TEXTE(NBTEX) = [F:AWIB]MSKENT-mess(24,7770,1)
  For N_I = 0 To [F:AWIB]NBMSK-1
    #------------------------------
    NBTEX += 1
    Call DECODE_TEXTE ([F:AWIB]INTMSK(N_I), CHAINE) From GLOBIENS
    TEX(NBTEX)   = [F:AWIB]NOMMSK(N_I)
    TEXTE(NBTEX) = [F:AWIB]NOMMSK(N_I)-CHAINE
    #------------------------------
    # Suite de la boucle
  Next N_I
Return

#-------------------------------------------------------------------------------
$SET_LAWIZLIK1
# Liste liste : sur les champs d'une fenêtre passée avec les libellés
#
Local Char    LWIN, CHAINE(250)(1..2)
Local Char    LCODMSK(GLONAMK)(12)
Local Integer N_I

  If clalev([F:AWIB])=0 : Local File AWINDOW [AWIB] : Endif : # Dictionnaire des fenêtres
  If clalev([F:AMZB])=0 : Local File AMSKZON [AMZB] : Endif : # Dictionnaire des champs écran
  If clalev([F:ATYB])=0 : Local File ATYPE   [ATYB] : Endif : # Types de données

  Link [AMZB] With [F:ATYB]CODTYP=[F:AMZB]CODTYP As [LAMZ]
  Default File [LAMZ]

  LWIN   = PARAM(1)
  Filter [AWIB] Where WIN=LWIN
  Read [AWIB]AWI0 First
  Filter [AWIB]
  CHAINE(1) = ""
  CHAINE(2) = ""
  If [AWIB]MSKENT <> "" Then
    CHAINE(1) += "[F:AMZB]CODMSK='"+[AWIB]MSKENT+"'"
  Endif
  For N_I = 0 To [AWIB]NBMSK-1
    If CHAINE(1) <> "" Then
      CHAINE(1) += "|"
    Endif
    CHAINE(1) += "[F:AMZB]CODMSK='"+[F:AWIB]NOMMSK(N_I)+"'"
    #------------------------------
    # Suite de la boucle
  Next N_I
  If CHAINE(1) <> "" Then
    CHAINE(1)  = "("+CHAINE+")"
  Else
    CHAINE(1)  = "(1=1)"
  Endif
  #CHAINE(2)   += "&[F:AMZB]SAIAFF<>3 &[F:AMZB]SAIAFF<>2"        : # Ni affiché, ni invisible
  CHAINE(2)   += "&[F:AMZB]SAIAFF<>3"                           : # Pas invisible FQ60756
  CHAINE(2)   += "&[F:AMZB]CODTYP<>'W' &[F:AMZB]CODTYP<>'ABS'"  : # Pas les types W et ABS
  CHAINE(2)   += "&[F:AMZB]CODTYP<>'IAA'"                       : # Pas les types IAA
  If PARAM(4) = "PARTRZL1" Then
    CHAINE(2) += "&([F:ATYB]TYPTYP<>7|[F:AMZB]CODTYP='ADI')"    : # Pas alpha ou alpha mais ADI
    CHAINE(2) += "&[F:AMZB]CODZON<>'AASREF'"                    : # Pas la référence du bien
  Endif

  For [LAMZ]DICO Where evalue(CHAINE)
    #------------------------------
    If [F:AMZB]CODTYP='CCE' or [F:AMZB]CODTYP='BCC' Then
      For N_I=1 To GOPTCANA
        NBTEX       += 1
        TEX(NBTEX)   = [F:AMZB]CODZON+"("+num$(N_I-1)+")"
        TEXTE(NBTEX) = func GLOBIENS.GET_LIBELLE_CHAMP (PARAM(3), [F:AMZB]CODMSK, TEX(NBTEX), val(PARAM(2)))
        #------------------------------
        # Suite de la boucle
      Next N_I
    Else
      NBTEX       += 1
      TEX(NBTEX)   = [F:AMZB]CODZON
      TEXTE(NBTEX) = func GLOBIENS.GET_LIBELLE_CHAMP (PARAM(3), [F:AMZB]CODMSK, [F:AMZB]CODZON, val(PARAM(2)))
    Endif
    #------------------------------
    # Suite de la boucle
  Next
Return

#-------------------------------------------------------------------------------
$SET_LAWIZLIK2
# Liste liste : sur les champs d'une fenêtre, avec contrôles du types de donnée
# du type physique et éventuellement d'un préfixe de nom de colonne
##############################################################################
# ATTENTION cette liste est appelée dans liste suivante SET_LAWIZLIKI
##############################################################################
#

  Local Char CODFIC    : CODFIC = "AMSKZON"
  Local Char LWIN, LPRE, LTPD
  Local Integer LTP
  Local Char LCODMSK(GLONAMK)(12)
  Local Integer N_I, LG

  If dim(CHAINE) <= 0 Then : # sinon la chaine est gérée ailleurs
    Local Char CHAINE(250)(1..2)
    Raz CHAINE
  Endif

  If clalev([F:AWIB])=0 : Local File AWINDOW [AWIB] : Endif
  If clalev([F:AMZB])=0 : Local File AMSKZON [AMZB] : Endif
  If clalev([F:ATYB])=0 : Local File ATYPE   [ATYB] : Endif : # Types de données

  Link [AMZB] With [F:ATYB]CODTYP=[F:AMZB]CODTYP As [LAMZ]
  Default File [LAMZ]

  LWIN     = PARAM(1)
  LPRE     = PARAM(2) : LG = len(LPRE)
  LTPD     = PARAM(3)
  LTPP     = val(PARAM(4))

  Filter [AWIB] Where WIN=LWIN
  Read [AWIB]AWI0 First
  Filter [AWIB]
  If [AWIB]MSKENT <> "" Then
    CHAINE(1) += "[F:AMZB]CODMSK='"+[AWIB]MSKENT+"'"
  Endif
  For N_I = 0 To [AWIB]NBMSK-1
    If CHAINE(1) <> "" Then
      CHAINE(1) += "|"
    Endif
    CHAINE(1) += "[F:AMZB]CODMSK='"+[F:AWIB]NOMMSK(N_I)+"'"
    #------------------------------
    # Suite de la boucle
  Next N_I
  If CHAINE(1) <> "" Then
    CHAINE(1) = "("+CHAINE(1)+")"
  Else
    CHAINE(1) = "(1=1)"
  Endif

  CHAINE(2) += "&[F:AMZB]SAIAFF<>3 &[F:AMZB]SAIAFF<>2"        : # Ni affiché, ni invisible
  CHAINE(2) += "&[F:AMZB]CODTYP<>'W' &[F:AMZB]CODTYP<>'ABS'"  : # Pas les types W et ABS

  If LPRE <> "" Then
    CHAINE(2) += "&left$([F:AMZB]CODZON,LG)=LPRE"            : # préfixe de nom de colonne
  Endif
  If LTPD <> "" Then
    CHAINE(2) += "&[F:AMZB]CODTYP=LTPD"                      : # Que le même type de données
  Endif
  If LTPP <> 0 Then
    CHAINE(2) += "&[F:ATYB]TYPTYP=LTPP"                      : # Que le même type physique
  Endif

  For [LAMZ] Where evalue(CHAINE)
    #------------------------------
    If [F:AMZB]CODTYP='CCE' or [F:AMZB]CODTYP='BCC' Then
      For N_I=1 To GOPTCANA
        NBTEX       += 1
        TEX(NBTEX)   = [F:AMZB]CODZON+"("+num$(N_I-1)+")"
        TEXTE(NBTEX) = func GLOBIENS.GET_LIBELLE_CHAMP (PARAM(5), [F:AMZB]CODMSK, TEX(NBTEX), val(PARAM(6)))
        #------------------------------
        # Suite de la boucle
      Next N_I
    Else
      NBTEX       += 1
      TEX(NBTEX)   = [F:AMZB]CODZON
      TEXTE(NBTEX) = func GLOBIENS.GET_LIBELLE_CHAMP (PARAM(5), [F:AMZB]CODMSK, [F:AMZB]CODZON, val(PARAM(6)))
    Endif
    #------------------------------
    # Suite de la boucle
  Next
Return

#-------------------------------------------------------------------------------
$SET_LAWIZLIKI
# Liste liste : sur les champs d'une fenêtre, avec contrôles du types de donnée
# du type physique et éventuellement d'un préfixe de nom de colonne
# Ajout clause de restictions inventaire si PARAM(7) donne une table diverse
##
  Local Integer NBTEX_NEW, TOSORT
  Local Char LWIN, LOBJ
  Local Char CHAINE(250)(1..2)

  Raz CHAINE

  LWIN = PARAM(1)
  LOBJ = PARAM(6)
  TOSORT=G_NON
  If LWIN="FINVRAPM" and LOBJ="2" : #liste utilisée pour tri sur fenetre de rapprochement manuel
        TOSORT=G_OUI
        PARAM(1)="OFAS"
        LWIN = PARAM(1)
  Endif
  # le param7 contient le nom de la table diverse pour ctrl
  LADI     = PARAM(7)
  # on appelle liste particularisée
  Gosub SET_LAWIZLIK2

  If TOSORT=G_OUI : #liste utilisée pour tri sur fenetre de rapprochement manuel
        PARAM(1)="FINVRAPM"
        LWIN = PARAM(1)
  Endif
  If LADI <> ""
      If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif : # Tables diverses
  Endif
  ###
  # on va ajouter les rub de la table qui ne sont pas dans la liste
  ###
  If clalev([F:ATZB])=0 : Local File ATABZON [ATZB] : Endif
  If clalev([F:ATYB])=0 : Local File ATYPE   [ATYB] : Endif : # Types de données

  # filtre sur type physique
  If PARAM(4)<>""
      Link [ATZB] With [F:ATYB]CODTYP=[F:ATZB]CODTYP As [LATZ] Where [F:ATYB]TYPTYP=LTPP 
  Else
      Link [ATZB] With [F:ATYB]CODTYP=[F:ATZB]CODTYP As [LATZ] 
  Endif
  Default File [LATZ]
  For [LATZ] Where [F:ATZB]CODFIC='FXDASSETS' and [F:ATZB]DIME=1 and [F:ATZB]CODTYP<>'CCE' and [F:ATZB]CODTYP<>'BCC'
    If find([F:ATZB]CODZONE,TEX(0..NBTEX))=0
          NBTEX += 1
          TEX(NBTEX)   = [F:ATZB]CODZONE
          Call DECODE_TEXTE ([F:ATZB]NOCOURT, TEXTE(NBTEX)) From GLOBIENS
    Endif
  Next

  ###
  # On retraite les enreg pour voir ceux qu'il faut enlever et présenter la liste avec les codes !!!
  ###
  NBTEX_NEW = 0
  For I=1 To NBTEX
      RUB=G_OUI      
      If LADI=num$(GTD_INVPRB)
        # lecture des enreg de la table diverse donnée
        Filter [ADI] Where NUMTAB=val(LADI) and A1=TEX(I) and N1=G_NON
        Read [ADI]CODE First
        Filter [ADI]
        If fstat=0
            # la rub n'est pas alimentable, on ne la prend pas
            RUB=G_NON
        Endif
      Elsif TOSORT=G_OUI
        # il ne faut que les rub du mask de FAS qui sont dans INVRAPM1
        Read [AMZB]CODE="INVRAPM1";TEX(I)
        If fstat<>0 Then
            # la rub non trouvée, on ne la prend pas
            RUB=G_NON
        Endif
      Endif
      If RUB=G_OUI
          NBTEX_NEW += 1
          TEX(NBTEX_NEW)   = TEX(I)
          # libellé seul
          #TEXTE(NBTEX_NEW) = TEXTE(I)
          # code + libellé
          #TEXTE(NBTEX_NEW) = TEX(I)+space$(20-len(TEX(I)))+TEXTE(I)
          # libellé+code
          TEXTE(NBTEX_NEW) = left$(TEXTE(I),40)+space$(50-len(left$(TEXTE(I),40)))+TEX(I)
      Endif
    #------------------------------
    # Suite de la boucle
  Next I
  NBTEX=NBTEX_NEW
Return


#-------------------------------------------------------------------------------
$SET_TAMZLIK1
# Liste table : sur les champs d'un écran passé
#
  Local Char CODFIC    : CODFIC = "AMSKZON"
  Local Char LCODMSK

  If clalev([F:AMZB])=0 : Local File AMSKZON [AMZB] : Endif
  If clalev([F:ATXB])=0 : Local File ATEXTE  [ATXB] : Endif

  Link [AMZB] With [ATXB]NUMERO = GLANGUE;[F:AMZB]INTIT As [LAMZ]
  Default File [LAMZ]

  LCODMSK   = PARAM(1)
  CRITERE   = "[F:AMZB]CODMSK=LCODMSK and [F:AMZB]SAIAFF<> 3"
  CRITERE  += " and [F:AMZB]CODTYP<>'W'"
  ORDRE     = "CODZON"
  START     = "CODZON"

  TIT(0)    = mess(30,7770,1)
  NBCOL     = 0
  NBCOL    += 1 : COL(NBCOL) = "CODZON"    : Gosub TEXTE From GLOBIENS : COL(NBCOL) = "[F:AMZB]CODZON"
  NBCOL    += 1 : COL(NBCOL) = "INTIT"     : Gosub TEXTE From GLOBIENS : COL(NBCOL) = "[F:ATXB]TEXTE"
Return

