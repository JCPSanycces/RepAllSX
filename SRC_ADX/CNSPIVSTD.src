$FIN_CRIT
  [M:PIV1]FLG = 0
  [M:PIV1] = [M:CSTK]
Return

############################################################
$AV_MAGNETO
  NBCMP = 1
  FILTRE = ""
  # --------------------
  Case [M:PIV1]VCRTYPSEL
    When NUM_SQH
      Default File [SQH]
      CLE       = "SQH0"
      CLECMP(0) = "SQHNUM"
      ABFIC     = "SQH"
      Filter [F:SQH]
    When NUM_SDH
      Default File [SDH]
      CLE       = "SDH0"
      CLECMP(0) = "SDHNUM"
      ABFIC     = "SDH"
      Filter [F:SDH]
    When NUM_SRH
      Default File [SRH]
      CLE       = "SRH0"
      CLECMP(0) = "SRHNUM"
      ABFIC     = "SRH"
      Filter [F:SRH]
    When NUM_SIH
      Default File [SIH]
      CLE       = "SIH0"
      CLECMP(0) = "NUM"
      ABFIC     = "SIH"
      FILTRE    = "[F:SIH]INVTYP=1 OR [F:SIH]INVTYP=5"
      Filter [F:SIH]
    When NUM_SIV
      Default File [SIV]
      CLE       = "SIV0"
      CLECMP(0) = "NUM"
      ABFIC     = "SIV"
      FILTRE    = "[F:SIV]INVTYP=2"
      Filter [F:SIH]
    When NUM_SOH
      Default File [SOH]
      CLE       = "SOH0"
      CLECMP(0) = "SOHNUM"
      ABFIC     = "SOH"
      Filter [F:SOH]
      FILTRE    = "SOHCAT<>4"
    When NUM_SOC
      Default File [SOC]
      CLE       = "SOC0"
      CLECMP(0) = "SOHNUM"
      ABFIC     = "SOC"
      Filter [F:SOC]
    When NUM_PRH
      Default File [PRH]
      CLE       = "PRH0"
      CLECMP(0) = "PRHNUM"
      ABFIC     = "PRH"
      Filter [F:PRH]
    When NUM_PRL
      Default File [PRL]
      CLE       = "PRL0"
      CLECMP(0) = "PRLNUM"
      ABFIC     = "PRL"
      FILTRE    = "[F:PRL]ORITYP<>3 AND [F:PRL]ORITYP<>4"
      Filter [F:PRL]
    When NUM_DUD, NUM_DUDA
      # FGR 13/01/2012 : X3SUIVI71278
      Default File [DUD]
      CLE       = "DUD8"
      CLECMP(0) = "NUMDUD"
      ABFIC     = "DUD"
      Filter [F:DUD]
    When NUM_PYH
      # FGR 13/01/2012 : X3SUIVI71278
      Default File [PYH]
      CLE       = "PYH0"
      CLECMP(0) = "NUM"
      ABFIC     = "PYH"
      Filter [F:PYH]
    When NUM_REL
      # FGR 13/01/2012 : X3SUIVI71278
      Default File [SOI]
      CLE       = "SOI0"
      CLECMP(0) = "SOINUM"
      ABFIC     = "SOI"
      Filter [F:SOI]
    When NUM_TSK
      # FGR 13/01/2012 : X3SUIVI71278
      Default File [TSK]
      CLE       = "TSK0"
      CLECMP(0) = "TSKNUM"
      ABFIC     = "TSK"
      Filter [F:TSK]
    When NUM_CLL
      # FGR 13/01/2012 : X3SUIVI71278
      Default File [CLL]
      CLE       = "CLL0"
      CLECMP(0) = "CLLNUM"
      ABFIC     = "CLL"
      Filter [F:CLL]
    When NUM_BAP
      # FGR 13/01/2012 : X3SUIVI71278
      Default File [BAP]
      CLE       = "APP0"
      CLECMP(0) = "APTNUM"
      ABFIC     = "BAP"
      Filter [F:BAP]
    When NUM_CON
      # FGR 13/01/2012 : X3SUIVI71278
      Default File [CON]
      CLE       = "CON0"
      CLECMP(0) = "CONNUM"
      ABFIC     = "CON"
      Filter [F:CON]
    When NUM_MAC
      # FGR 13/01/2012 : X3SUIVI71278
      Default File [MAC]
      CLE       = "MAC0"
      CLECMP(0) = "MACNUM"
      ABFIC     = "MAC"
      Filter [F:MAC]
    When NUM_SRE
      # FGR 13/01/2012 : X3SUIVI71278
      Default File [SRE]
      CLE       = "SRE0"
      CLECMP(0) = "SRENUM"
      ABFIC     = "SRE"
      Filter [F:SRE]
    When NUM_ITN
      # FGR 13/01/2012 : X3SUIVI71278
      Default File [ITN]
      CLE       = "ITN0"
      CLECMP(0) = "NUM"
      ABFIC     = "ITN"
      Filter [F:ITN]
    When NUM_SOL
      # FGR 13/01/2012 : X3SUIVI71278
      Default File [SOL]
      CLE       = "SOL0"
      CLECMP(0) = "NUM"
      ABFIC     = "SOL"
      Filter [F:SOL]
    #---------------------------------
    # FGR 08/02/2012 : X3SUIVI71269
    When NUM_PIH, NUM_PIHC
      Default File [PIH]
      CLE       = "PIH0"
      CLECMP(0) = "NUM"
      ABFIC     = "PIH"
      FILTRE    = "([F:PIH]INVTYP=1 OR [F:PIH]INVTYP=5) AND [F:PIH]ORIMOD=6"
      Filter [F:PIH]
    When NUM_PIV
      Default File [PIH]
      CLE       = "PIH0"
      CLECMP(0) = "NUM"
      ABFIC     = "PIH"
      FILTRE    = "[F:PIH]INVTYP=2"
      Filter [F:PIH]
    When NUM_PNH
      Default File [PNH]
      CLE       = "PNH0"
      CLECMP(0) = "PNHNUM"
      ABFIC     = "PNH"
      Filter [F:PNH]
    When NUM_PTH
      Default File [PTH]
      CLE       = "PTH0"
      CLECMP(0) = "PTHNUM"
      ABFIC     = "PTH"
      Filter [F:PTH]
    When NUM_POC
      Default File [POC]
      CLE       = "POC0"
      CLECMP(0) = "POHNUM"
      ABFIC     = "POC"
      Filter [F:POC]
    When NUM_POH
      Default File [POH]
      CLE       = "POH0"
      CLECMP(0) = "POHNUM"
      ABFIC     = "POH"
      Filter [F:POH]
      FILTRE = "SOHCAT<>4 & POHTYP<>2"
    When NUM_PSH
      Default File [PSH]
      CLE       = "PSH0"
      CLECMP(0) = "PSHNUM"
      ABFIC     = "PSH"
      Filter [F:PSH]
    When NUM_PQH
      Default File [PQH]
      CLE       = "PQH0"
      CLECMP(0) = "PQHNUM"
      ABFIC     = "PQH"
      Filter [F:PQH]
    When NUM_SCO
      Default File [SCO]
      CLE       = "SCO0"
      CLECMP(0) = "SCONUM"
      ABFIC     = "SCO"
      Filter [F:SCO]
    When NUM_LOF
      # FGR 10/10/2012 : X3SUIVI81498
      Default File [LOF]
      CLE       = "LOF0"
      CLECMP(0) = "CODLOF"  # ATTENTION ICI : clé composée
      CLECMP(1) = "LINLOF"  # ATTENTION ICI : clé composée
      ABFIC     = "LOF"
      Filter [F:LOF]
    When NUM_FAS
      # FGR 10/10/2012 : X3SUIVI81498
      Default File [FAS]
      CLE       = "FAS0"
      CLECMP(0) = "AASREF"
      ABFIC     = "FAS"
      Filter [F:FAS]
    When NUM_BIS
      # FGR 24/10/2012 : X3SUIVI81498
      Default File [PIH]
      CLE       = "PIH0"
      CLECMP(0) = "NUM"
      ABFIC     = "PIH"
      FILTRE    = "[F:PIH]ORIMOD=3"
    When NUM_CTRH
      # FGR 29/05/2015 : X3SUIVI104697
      Default File [CTRH]
      CLE       = "CTRH0"
      CLECMP(0) = "CTRNUM"
      ABFIC     = "CTRH"
      Filter [F:CTRH]
    When NUM_SHH
      # FGR 29/05/2015 : X3SUIVI104697
      Default File [SHH]
      CLE       = "SHH0"
      CLECMP(0) = "SHIPNUM"
      ABFIC     = "SHH"
      Filter [F:SHH]
    When NUM_TRNP
      # FGR 29/05/2015 : X3SUIVI104697
      Default File [TRNP]
      CLE       = "TRNP0"
      CLECMP(0) = "TRNNUM"
      ABFIC     = "TRNP"
      Filter [F:TRNP]
    When Default
  Endcase
  [M:PIV1]VCRLINSEL = 0
  Affzo [M:PIV1]VCRLINSEL
Return

############################################################
$AP_MAGNETO
  [M:PIV1]FLG = 0
  [M:PIV1]VCRCTL = 1
  If fstat < 4 and [M:PIV1]VCRNUMSEL <> "" Then
    Gosub AFFICHER_SEL
    APMAGNETO = G_OUI
  Endif
Return

############################################################
$CLECUR
  If [M:PIV1]VCRNUMSEL <> "" Then
    CLECUR = 1
  Endif
Return

############################################################
$SETBOUT

  If [M:PIV1]FLG = 0 Then
    If !GINTRA Then
      Call VIREBOUT(CHAINE, "R") From GOBJET
    Endif
  Endif
  If [M:PIV1]VCRCTL = 0 Then
    Call VIREBOUT(CHAINE, "B") From GOBJET
  Endif

Return
###########################################################
$SEL_TABLE

  Case TABLE
    When "SELPIV"  : Gosub S_SELPIV
  Endcase

Return
### Issue X3-86804 #################################################################################################
$FIN_TABLE

  Case TABLE
    When "SELPIV"
      # Only if document type = Expense
      If [M:PIV1]VCRTYPSEL = NUM_LOF
        VALEUR= [F:LOF]CODLOF
        [M:PIV1]VCRNUMSEL= VALEUR
        [M:PIV1]VCRLINSEL= [F:LOF]LINLOF
        Affzo [M:PIV1]VCRNUMSEL
        Affzo [M:PIV1]VCRLINSEL
      Endif
  Endcase

Return
###########################################################
$SEL_LISTE
  Case LISTE
    When "SELLINV" : Gosub S_SELLINV
  Endcase
Return

############################################################
Subprog LOAD_SCREEN(PARAM)
Value Char PARAM()(1..)

Local Integer WI

  For WI = 1 To dim(PARAM)
    Case WI
      When 1
        If PARAM(WI) <> "" Then
          Case PARAM(WI)
            When "SQH" : [M:PIV1]VCRTYPSEL = NUM_SQH
            When "SDH" : [M:PIV1]VCRTYPSEL = NUM_SDH
            When "SRH" : [M:PIV1]VCRTYPSEL = NUM_SRH
            When "SIH" : [M:PIV1]VCRTYPSEL = NUM_SIH
            When "SIV" : [M:PIV1]VCRTYPSEL = NUM_SIV
            When "SOH" : [M:PIV1]VCRTYPSEL = NUM_SOH
            When "SOC" : [M:PIV1]VCRTYPSEL = NUM_SOC
            When "PRH" : [M:PIV1]VCRTYPSEL = NUM_PRH
            When "PRL" : [M:PIV1]VCRTYPSEL = NUM_PRL
            # --------------------------------------
            When "HAE" : [M:PIV1]VCRTYPSEL = NUM_HAE
            # --------------------------------------
            When "DUD" : [M:PIV1]VCRTYPSEL = NUM_DUD        # FGR 13/01/2012 : X3SUIVI71278
            When "PAY" : [M:PIV1]VCRTYPSEL = NUM_PYH        # FGR 13/01/2012 : X3SUIVI71278
            When "REL" : [M:PIV1]VCRTYPSEL = NUM_REL        # FGR 13/01/2012 : X3SUIVI71278
            When "BIS" : [M:PIV1]VCRTYPSEL = NUM_BIS        # FGR 24/10/2012 : X3SUIVI81498
            # --------------------------------------
            When "TSK" : [M:PIV1]VCRTYPSEL = NUM_TSK        # FGR 13/01/2012 : X3SUIVI71278
            When "CLL" : [M:PIV1]VCRTYPSEL = NUM_CLL        # FGR 13/01/2012 : X3SUIVI71278
            When "BAP" : [M:PIV1]VCRTYPSEL = NUM_BAP        # FGR 13/01/2012 : X3SUIVI71278
            When "PJT" : [M:PIV1]VCRTYPSEL = NUM_PJT
            # --------------------------------------
            When "CON" : [M:PIV1]VCRTYPSEL = NUM_CON        # FGR 13/01/2012 : X3SUIVI71278
            When "MAC" : [M:PIV1]VCRTYPSEL = NUM_MAC        # FGR 13/01/2012 : X3SUIVI71278
            When "SRE" : [M:PIV1]VCRTYPSEL = NUM_SRE        # FGR 13/01/2012 : X3SUIVI71278
            When "ITN" : [M:PIV1]VCRTYPSEL = NUM_ITN        # FGR 13/01/2012 : X3SUIVI71278
            When "SOL" : [M:PIV1]VCRTYPSEL = NUM_SOL        # FGR 13/01/2012 : X3SUIVI71278
            # --------------------------------------
            When "PIH" : [M:PIV1]VCRTYPSEL = NUM_PIH        # FGR 08/02/2012 : X3SUIVI71269
            When "PIV" : [M:PIV1]VCRTYPSEL = NUM_PIV        # FGR 08/02/2012 : X3SUIVI71269
            When "PNH" : [M:PIV1]VCRTYPSEL = NUM_PNH        # FGR 08/02/2012 : X3SUIVI71269
            When "PTH" : [M:PIV1]VCRTYPSEL = NUM_PTH        # FGR 08/02/2012 : X3SUIVI71269
            When "POC" : [M:PIV1]VCRTYPSEL = NUM_POC        # FGR 08/02/2012 : X3SUIVI71269
            When "POH" : [M:PIV1]VCRTYPSEL = NUM_POH        # FGR 08/02/2012 : X3SUIVI71269
            When "PSH" : [M:PIV1]VCRTYPSEL = NUM_PSH        # FGR 08/02/2012 : X3SUIVI71269
            When "PQH" : [M:PIV1]VCRTYPSEL = NUM_PQH        # FGR 08/02/2012 : X3SUIVI71269
            When "SCO" : [M:PIV1]VCRTYPSEL = NUM_SCO        # FGR 08/02/2012 : X3SUIVI71269
            # --------------------------------------
            When "LOF" : [M:PIV1]VCRTYPSEL = NUM_LOF        # FGR 10/10/2012 : X3SUIVI81498
            When "FAS" : [M:PIV1]VCRTYPSEL = NUM_FAS        # FGR 10/10/2012 : X3SUIVI81498
            # --------------------------------------
            When "CTRH" : [M:PIV1]VCRTYPSEL = NUM_CTRH      # FGR 29/05/2015 : X3SUIVI104697
            When "SHIP" : [M:PIV1]VCRTYPSEL = NUM_SHH       # FGR 29/05/2015 : X3SUIVI104697
            When "TRNP" : [M:PIV1]VCRTYPSEL = NUM_TRNP      # FGR 29/05/2015 : X3SUIVI104697
          Endcase
        Else
          # Permet d'initialiser avec la première valeur disponible dans le menu
          Raz GMENLOC
          Call AS_VCRTYPSEL([M:PIV1]VCRTYPSEL)
        Endif
      When 2
        If PARAM(WI) <> "" Then
          [M:PIV1]VCRNUMSEL = PARAM(WI)
        Endif
      When 3
        If PARAM(WI) <> "" Then
          [M:PIV1]VCRLINSEL = val(PARAM(WI))
        Endif
    Endcase
  Next WI
  If clalev([M:CSTK]) <> 0 and [M:CSTK]MEMO = "STD" Then
    [M:PIV1] = [M:CSTK]
  Else
    [M:PIV1]LEVMAX = 15
  Endif
End

############################################################
# Etiquette appelée dans GCONSULT
$LECTURE
Local Char VCRN(GLONVCR)
Local Integer VCRL       # FGR 25/10/2012 : X3SUIVI81498
Local Integer VCRT
Local Integer LEVMAX

  Call AFFICHE_STA([M:PIV1]VCRTYPSEL)
  # On ne fait pas la lecture si on vient de cliquer sur suivant/précédent,
  # car la lecture a déjà été faite via l'appel de AP_MAGNETO dans GCONSULT
  If APMAGNETO = G_OUI Then
    APMAGNETO = G_NON
    Return
  Endif
  # -----------
  WFILSPE = "1=1"
  If dim(PROGSPE) >= 0 and PROGSPE <> "" Then
    GPROGSPEPIV = PROGSPE
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif
  # -----------
  If [M:PIV1]FLG <> 0 Then
    # Purge des lignes non sélectionnées
    If WREAD = 0 or CHGPAG = 1 Then
      If GACTION <> "VISUPIV" Then
        VCRN = [M:PIV1]VCRNUMSEL
        VCRT = [M:PIV1]VCRTYPSEL
        VCRL = [M:PIV1]VCRLINSEL   # FGR 25/10/2012 : X3SUIVI81498
        #
        Gosub PUR_SELECTIONS From CONSPITOOLS
        WTIMD = time
        # Création des enregistrements dans la table de travail PIWRK
        LEVMAX = [M:PIV1]LEVMAX
        Case [M:PIV1]TRKSEL
          When 1
            Gosub TRT_NIVEAUX_AMONT From CONSPITOOLS
          When 2
            Gosub TRT_NIVEAUX_AVAL From CONSPITOOLS
        Endcase
        If VS = 1 Then
          Gosub DEL_WRK From CONSPITOOLS
        Endif
      Endif
    Endif
    Filter [PKW]
    If GCNSPIXUUID <> "" Then
      Filter [PKW] Where PRONUM = GCNSPIXUUID Order By Key SKW0
    Endif
    # Renseignement des lignes du tableau, par les enregistrements de la table de travail PIWRK
    Gosub CHARGE_PAG From CONSPITOOLS
    # Vérification des redondances dans l'arborescence
    Call VERIF_PAG(NOL)
    #
    Call DISPLAY_TIERS("PIV1", PROGSTD) From CONSPITOOLS
  Endif
Return

############################################################
Subprog VERIF_PAG(NOL)
Variable Integer NOL

Local Integer I
Local Integer J
Local Integer K
Local Integer L
Local Char VCRNUM(GLONVCR)

If dim([M:PIV3]LEVC) >= 0 Then
  Local Char LEV(type([M:PIV3]LEVC)-10)
Else
  Local Char LEV(type([M:PIV2]LEV)-10)
Endif
Local Integer VCRTYP

  If clalev([M:PIV3]) and GACTION = "VISUPIV" Then
    I = 2
    While I <= [M:PIV3]NBLIG
      VCRNUM = [M:PIV3]VCRNUM(I-1)
      VCRTYP = [M:PIV3]VCRTYP(I-1)
      LEV    = [M:PIV3]LEVC(I-1)
      For J = 2 To I-1
        # Cas des avoir sous les factures et les retours : doit être uniquement sous le retour
        If [M:PIV3]VCRNUM(J-1) = VCRNUM and [M:PIV3]VCRTYP(J-1) = VCRTYP and VCRTYP = NUM_SIV
&          and [M:PIV3]LEV(J-1) = LEV and left$([M:PIV3]PARKEY(J-1),2) = num$(NUM_SIH)+"-"
&       Then
          L = 0
          While [M:PIV3]LEV(J+L) > [M:PIV3]LEV(J-1)
            L += 1
          Wend
          For K = J To [M:PIV3]NBLIG-1
            Call REMONTER_LIGNE(K-1, K+L) From CONSPITOOLS
          Next
        Else
          If [M:PIV3]VCRNUM(J-1) = VCRNUM and [M:PIV3]VCRTYP(J-1) = VCRTYP
&            and ([M:PIV3]LEVC(J-1) > LEV or [M:PIV3]PARKEY(J-1) = [M:PIV3]PARKEY(I-1))
&         Then
            If I < [M:PIV3]NBLIG Then
              For K = I To [M:PIV3]NBLIG-1
                Call REMONTER_LIGNE(K-1, K) From CONSPITOOLS
              Next
            Endif
            Call VIDER_LIGNE([M:PIV3]NBLIG-1) From CONSPITOOLS
            [M:PIV3]NBLIG = [M:PIV3]NBLIG-1
            I -= 1
            Break 1
          Endif
        Endif
      Next
      I += 1
    Wend
    Affzo [M:PIV3]
  Else
    I = 2
    While I <= [M:PIV2]NBLIG
      VCRNUM = [M:PIV2]VCRNUM(I-1)
      VCRTYP = [M:PIV2]VCRTYP(I-1)
      LEV    = [M:PIV2]LEV(I-1)
      For J = 2 To I-1
        # Cas des avoir sous les factures et les retours : doit être uniquement sous le retour
        If [M:PIV2]VCRNUM(J-1) = VCRNUM and [M:PIV2]VCRTYP(J-1) = VCRTYP and VCRTYP = NUM_SIV
&          and [M:PIV2]LEV(J-1) = LEV and left$([M:PIV2]PARKEY(J-1),2) = num$(NUM_SIH)+"-"
&       Then
          L = 0
          While [M:PIV2]LEV(J+L)>[M:PIV2]LEV(J-1)
            L += 1
          Wend
           Dela J-1,1 [M:PIV2]LEV, [M:PIV2]VCRTYP, [M:PIV2]VCRNUM, [M:PIV2]IPTDAT,
&                     [M:PIV2]SALFCY, [M:PIV2]BPRNUM, [M:PIV2]BPRNAM, [M:PIV2]JOU, [M:PIV2]PARKEY,
&                     [M:PIV2]KEYC, [M:PIV2]LIB, [M:PIV2]LIBSH, [M:PIV2]LIGNE, [M:PIV2]PARLIN,
&                     [M:PIV2]VCRSTAT1, [M:PIV2]VCRSTAT2, [M:PIV2]VCRSTAT3, [M:PIV2]VCRSTAT4

          [M:PIV2]NBLIG = [M:PIV2]NBLIG - 1
          I -= 1
          Break 1
        Elsif [M:PIV2]VCRNUM(J-1) = VCRNUM and [M:PIV2]VCRTYP(J-1) = VCRTYP and VCRTYP = NUM_TRNP
&            and ([M:PIV2]LEV(J-1) > LEV or [M:PIV2]PARKEY(J-1) = [M:PIV2]PARKEY(I-1))
            # FGR 01/06/2015 : X3SUIVI104697 : Les transports plusieurs parents. On ne les supprime pas.
        Else
          If [M:PIV2]VCRNUM(J-1) = VCRNUM and [M:PIV2]VCRTYP(J-1) = VCRTYP
&            and ([M:PIV2]LEV(J-1) > LEV or [M:PIV2]PARKEY(J-1) = [M:PIV2]PARKEY(I-1))
&         Then
            Dela I-1,1 [M:PIV2]LEV, [M:PIV2]VCRTYP, [M:PIV2]VCRNUM, [M:PIV2]IPTDAT,
&                      [M:PIV2]SALFCY, [M:PIV2]BPRNUM, [M:PIV2]BPRNAM, [M:PIV2]JOU, [M:PIV2]PARKEY,
&                      [M:PIV2]KEYC, [M:PIV2]LIB, [M:PIV2]LIBSH, [M:PIV2]LIGNE, [M:PIV2]PARLIN,
&                      [M:PIV2]VCRSTAT1, [M:PIV2]VCRSTAT2, [M:PIV2]VCRSTAT3, [M:PIV2]VCRSTAT4

            [M:PIV2]NBLIG = [M:PIV2]NBLIG-1
            I -= 1
            Break 1
          Endif
        Endif
      Next
      I += 1
    Wend
    NOL = [M:PIV2]NBLIG-1
  Endif
End

############################################################
$AFFICHER_SEL
Local Integer NOL

  NOL = -1
  If dim(PROGSTD) < 0 Then
    Local Char PROGSTD(GLONADC)
  Endif
  PROGSTD = "CNSPIVSTD"
  If dim(AMONT_AVAL) < 0 Then
    Global Integer AMONT_AVAL
  Endif
  AMONT_AVAL = G_OUI
  #
  Gosub OUVRE
  WFILS = "1=1"
  Gosub OUVRE_SEL
  Gosub LECTURE
  #
  Affzo [M:PIV1]
  Affzo [M:PIV2]
  AMONT_AVAL = G_NON
Return

############################################################
$OUVRE_SEL
  MAXLIG = dim([M:PIV2]LEV)
  # ----------
  Filter [DUD]      # FGR 13/01/2012 : X3SUIVI71278
  If GMODU(3) = 2 Then
    # Module "Tiers"
    Filter [PYH]    # FGR 13/01/2012 : X3SUIVI71278
    Filter [SOI]    # FGR 13/01/2012 : X3SUIVI71278
    Filter [PIH]    # FGR 24/10/2012 : X3SUIVI81498
  Endif
  # -----------------------------
  If GMODU(5) = 2 Then
    # Module "Vente"
    Filter [SOH]
    Filter [SDH]
    Filter [SIH]
    Filter [SRH]
    Filter [SIV]
  Endif
  # -----------------------------
  If GMODU(6) = 2 Then
    # Module "Achats"
    Filter [PIH]    # FGR 08/02/2012 : X3SUIVI71269
    Filter [PIV]    # FGR 08/02/2012 : X3SUIVI71269
    Filter [PNH]    # FGR 08/02/2012 : X3SUIVI71269
    Filter [PTH]    # FGR 08/02/2012 : X3SUIVI71269
    Filter [POC]    # FGR 08/02/2012 : X3SUIVI71269
    Filter [POH]    # FGR 08/02/2012 : X3SUIVI71269
    Filter [PSH]    # FGR 08/02/2012 : X3SUIVI71269
    Filter [PQH]    # FGR 08/02/2012 : X3SUIVI71269
    Filter [SCO]    # FGR 08/02/2012 : X3SUIVI71269
    Filter [CTRH]   # FGR 29/05/2015 : X3SUIVI104697
    Filter [SHH]    # FGR 29/05/2015 : X3SUIVI104697
    Filter [TRNP]   # FGR 29/05/2015 : X3SUIVI104697
  Endif
  # -----------------------------
  If GMODU(12) = 2 Then
    # Module "Support client"
    Filter [CON]    # FGR 13/01/2012 : X3SUIVI71278
    Filter [MAC]    # FGR 13/01/2012 : X3SUIVI71278
    Filter [SRE]    # FGR 13/01/2012 : X3SUIVI71278
    Filter [ITN]    # FGR 13/01/2012 : X3SUIVI71278
    Filter [SOL]    # FGR 13/01/2012 : X3SUIVI71278
  Endif
  # -----------------------------
  If GMODU(13) = 2 Then
    # Module "Action commerciale"
    Filter [TSK]    # FGR 13/01/2012 : X3SUIVI71278
    Filter [CLL]    # FGR 13/01/2012 : X3SUIVI71278
    Filter [BAP]    # FGR 13/01/2012 : X3SUIVI71278
  Endif
  # -----------------------------
  # FGR 10/10/2012 : X3SUIVI81498
  If GMODU(14) = 2 Then
    # Module "Immobilisation"
    Filter [LOF]
    Filter [FAS]
  Endif
  # -----------------------------
  Filter [PKW]
  # -----------------------------
  If [M:PIV1]FLG = 0 Then
    WFILSPE = "1=1"
    If GPROGSPEPIV <> "" Then
      ACTION = "FILTRE" : Gosub ACTION From =GPROGSPEPIV
    Endif
    #
    [M:PIV1]FLG = 1
    If clalev([M:PIV2]) and GACTION <> "VISUPIV" Then
      Effzo [M:PIV2]
    Endif
    If clalev([M:PIV3]) or GACTION = "VISUPIV" Then
      Effzo [M:PIV3]
    Endif
    #
    Call TEMPON(mess(58,187,1) - "1") From GESECRAN
    GSTOPRT += 1
    GCNSPIXUUID = uuid$
    Gosub LOAD_FILTER
    #
    WNIV    = 1
    TLEV(1) = 1
    #
    GOK = 1
    GPOINT = "OUVRE_SEL_V" : Gosub ENTREE From EXEFNC
    If GOK < 1 Then
      Return
    Endif
    # -----------------------------
    Trbegin [PKW]
    # -----------------------------
    # Création du 1er enregistrement dans la table de travail PIWRK. Cet enregistrement représente le 1er niveau dans l'arborescence
    Case [M:PIV1]VCRTYPSEL
      When NUM_SQH
        Filter [SQH] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key SQH0
        For [SQH]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [SQH]
      When NUM_SDH
        Filter [SDH] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key SDH0
        For [SDH]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [SDH]
      When NUM_SRH
        Filter [SRH] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key SRH0
        For [SRH]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [SRH]
      When NUM_SIH
        Filter [SIH] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key SIH0
        For [SIH]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [SIH]
      When NUM_SIV
        Filter [SIH] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key SIH0
        For [SIH]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [SIH]
      When NUM_SOH
        Filter [SOH] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key SOH0
        For [SOH]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [SOH]
      When NUM_SOC
        Filter [SOC] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key SOC0
        Read [F:SOC]First
        Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
        Filter [SOC]
      When NUM_PRH
        Filter [PRH] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key PRH0
        For [PRH]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [PRH]
      When NUM_PRL
        Filter [PRL] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key PRL0
        Read [F:PRL]First
        Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
        Filter [PRL]
      When NUM_DUD, NUM_DUDA
        # FGR 13/01/2012 : X3SUIVI71278
        Filter [DUD] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key DUD8
        For [DUD]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [DUD]
      When NUM_PYH
        # FGR 13/01/2012 : X3SUIVI71278
        Link [F:PYH] With [F:PYD]PYD0=[F:PYH]NUM As [PY_] Order By Key PY_0=[F:PYD]NUM;[F:PYD]LIN
        Filter [PY_] Where evalue(WFIL1) & evalue(WFILSPE)
        For [PY_]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [PY_]
      When NUM_REL
        # FGR 13/01/2012 : X3SUIVI71278
        Filter [SOI] Where evalue(WFIL1) & evalue(WFILSPE)
        For [SOI]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [SOI]
      When NUM_TSK
        # FGR 13/01/2012 : X3SUIVI71278
        Filter [TSK] Where evalue(WFIL1) & evalue(WFILSPE)
        For [TSK]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [TSK]
      When NUM_CLL
        # FGR 13/01/2012 : X3SUIVI71278
        Filter [CLL] Where evalue(WFIL1) & evalue(WFILSPE)
        For [CLL]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [CLL]
      When NUM_BAP
        # FGR 13/01/2012 : X3SUIVI71278
        Filter [BAP] Where evalue(WFIL1) & evalue(WFILSPE)
        For [BAP]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [BAP]
      When NUM_CON
        # FGR 13/01/2012 : X3SUIVI71278
        Filter [CON] Where evalue(WFIL1) & evalue(WFILSPE)
        For [CON]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [CON]
      When NUM_MAC
        # FGR 13/01/2012 : X3SUIVI71278
        Filter [MAC] Where evalue(WFIL1) & evalue(WFILSPE)
        For [MAC]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [MAC]
      When NUM_SRE
        # FGR 13/01/2012 : X3SUIVI71278
        Filter [SRE] Where evalue(WFIL1) & evalue(WFILSPE)
        For [SRE]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [SRE]
      When NUM_ITN
        # FGR 13/01/2012 : X3SUIVI71278
        Filter [ITN] Where evalue(WFIL1) & evalue(WFILSPE)
        For [ITN]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [ITN]
      When NUM_SOL
        # FGR 13/01/2012 : X3SUIVI71278
        Filter [SOL] Where evalue(WFIL1) & evalue(WFILSPE)
        For [SOL]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [SOL]
      # ---------------------------------------------------
      # FGR 08/02/2012 : X3SUIVI71269
      When NUM_PIH, NUM_PIHC
        Filter [PIH] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key PIH0
        For [PIH]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [PIH]
      When NUM_PIV
        Filter [PIH] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key PIH0
        For [PIH]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [PIH]
      When NUM_PNH
        Filter [PNH] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key PNH0
        For [PNH]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [PNH]
      When NUM_PTH
        Filter [PTH] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key PTH0
        For [PTH]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [PTH]
      When NUM_POC
        Filter [POC] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key POC0
        Read [POC] First
        Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
        Filter [POC]
      When NUM_POH
        Filter [POH] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key POH0
        For [POH]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [POH]
      When NUM_PSH
        Filter [PSH] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key PSH0
        For [PSH]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [PSH]
      When NUM_PQH
        Filter [PQH] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key PQH0
        For [PQH]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [PQH]
      When NUM_SCO
        Filter [SCO] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key SCO0
        For [SCO]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [SCO]
      When NUM_LOF
        # FGR 10/10/2012 : X3SUIVI81498
        Filter [LOF] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key LOF0
        For [LOF]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [LOF]
      When NUM_FAS
        # FGR 10/10/2012 : X3SUIVI81498
        Filter [FAS] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key FAS0
        For [FAS]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [FAS]
      When NUM_BIS
        # FGR 24/10/2012 : X3SUIVI81498
        Filter [PIH] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key PIH0
        For [PIH]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [PIH]
      When NUM_CTRH
        # FGR 29/05/2015 : X3SUIVI104697
        Filter [CTRH] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key CTRH0
        For [CTRH]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [CTRH]
      When NUM_SHH
        # FGR 29/05/2015 : X3SUIVI104697
        Filter [SHH] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key SHH0
        For [SHH]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [SHH]
      When NUM_TRNP
        # FGR 29/05/2015 : X3SUIVI104697
        Filter [TRNP] Where evalue(WFIL1) & evalue(WFILSPE) Order By Key TRNP0
        For [TRNP]
          Call ECR_NIV1([M:PIV1]TRKSEL, [M:PIV1]VCRTYPSEL, [M:PIV1]VCRLINSEL)
          If fstat Then
            Break
          Endif
        Next
        Filter [TRNP]
      # ---------------------------------------------------
      When Default
    Endcase
    # -----------------------------
    If fstat Then
      Rollback
    Else
      Commit
    Endif
    # -----------------------------
    Call TEMPOFF From GESECRAN
  Endif
Return

############################################################
# Ecriture de l'enregistrement de PIWRK qui représentera le 1er niveau de l'arborescence
Subprog ECR_NIV1(ITRKSEL, IVCRTYPSEL, IVCRLINSEL)
Value Integer ITRKSEL
Value Integer IVCRTYPSEL
Value Integer IVCRLINSEL

Local Char ENRLOC(GLONID)
Local Integer WI

  Raz [F:PKW]
  Case IVCRTYPSEL
    When NUM_SQH
      ENRLOC = "SQH" + [F:SQH]SQHNUM
      [F:PKW] = [F:SQH]
      Gosub FILL_SQH From CNSPIV1STD
    When NUM_SDH
      ENRLOC = "SDH" + [F:SDH]SDHNUM
      [F:PKW] = [F:SDH]
      Gosub FILL_SDH From CNSPIV1STD
    When NUM_SRH
      ENRLOC = "SRH" + [F:SRH]SRHNUM
      [F:PKW] = [F:SRH]
      Gosub FILL_SRH From CNSPIV1STD
    When NUM_SIH
      ENRLOC = "SIH" + [F:SIH]NUM
      [F:PKW] = [F:SIH]
      Gosub FILL_SIH From CNSPIV1STD
    When NUM_SIV
      ENRLOC = "SIA" + [F:SIH]NUM
      [F:PKW] = [F:SIH]
      Gosub FILL_SIV From CNSPIV1STD
    When NUM_SOH
      ENRLOC = "SOH" + [F:SOH]SOHNUM
      [F:PKW] = [F:SOH]
      Gosub FILL_SOH From CNSPIV1STD
    When NUM_SOC
      ENRLOC = "SOC" + [F:SOH]SOHNUM
      [F:PKW] = [F:SOC]
      Gosub FILL_SOC From CNSPIV1STD
    When NUM_PRH
      ENRLOC = "PRH" + [F:PRH]PRHNUM
      [F:PKW] = [F:PRH]
      Gosub FILL_PRH From CNSPIV1STD
    When NUM_PRL
      ENRLOC = "PRL" + [F:PRL]PRLNUM
      [F:PKW] = [F:PRL]
      Gosub FILL_PRL From CNSPIV1STD
      # La table des listes de préparation contient un n° de ligne, donc des
      # noms de client différents ==> on l'enlève sur la 1ère ligne.
      BPRNUM_T = ""
    When NUM_DUD, NUM_DUDA
      # FGR 13/01/2012 : X3SUIVI71278
      [F:PKW] = [F:DUD]
      Gosub FILL_DUD From CNSPIV1STD
    When NUM_PYH
      # FGR 13/01/2012 : X3SUIVI71278
      ENRLOC = "PYH" + [F:PYH]NUM
      [F:PKW] = [F:PYH]
      Gosub FILL_PYH From CNSPIV1STD
    When NUM_REL
      # FGR 13/01/2012 : X3SUIVI71278
      ENRLOC = "SOI" + [F:SOI]SOINUM
      [F:PKW] = [F:SOI]
      Gosub FILL_REL From CNSPIV1STD
    When NUM_TSK
      # FGR 13/01/2012 : X3SUIVI71278
      ENRLOC = "TSK" + [F:TSK]TSKNUM
      [F:PKW] = [F:TSK]
      Gosub FILL_TSK From CNSPIV1STD
    When NUM_CLL
      # FGR 13/01/2012 : X3SUIVI71278
      ENRLOC = "CLL" + [F:CLL]CLLNUM
      [F:PKW] = [F:CLL]
      Gosub FILL_CLL From CNSPIV1STD
    When NUM_BAP
      # FGR 13/01/2012 : X3SUIVI71278
      ENRLOC = "BAP" + [F:BAP]APTNUM
      [F:PKW] = [F:BAP]
      Gosub FILL_BAP From CNSPIV1STD
    When NUM_CON
      # FGR 13/01/2012 : X3SUIVI71278
      ENRLOC = "CON" + [F:CON]CONNUM
      [F:PKW] = [F:CON]
      Gosub FILL_CON From CNSPIV1STD
    When NUM_MAC
      # FGR 13/01/2012 : X3SUIVI71278
      ENRLOC = "MAC" + [F:MAC]MACNUM
      [F:PKW] = [F:MAC]
      Gosub FILL_MAC From CNSPIV1STD
    When NUM_SRE
      # FGR 13/01/2012 : X3SUIVI71278
      ENRLOC = "SRE" + [F:SRE]SRENUM
      [F:PKW] = [F:SRE]
      Gosub FILL_SRE From CNSPIV1STD
    When NUM_ITN
      # FGR 13/01/2012 : X3SUIVI71278
      ENRLOC = "ITN" + [F:ITN]NUM
      [F:PKW] = [F:ITN]
      Gosub FILL_ITN From CNSPIV1STD
    When NUM_SOL
      # FGR 13/01/2012 : X3SUIVI71278
      ENRLOC = "SOL" + [F:SOL]NUM
      [F:PKW] = [F:SOL]
      Gosub FILL_SOL From CNSPIV1STD
    # ---------------------------------------------------
    # FGR 08/02/2012 : X3SUIVI71269
    When NUM_PIH, NUM_PIHC
      ENRLOC = "PIH" + [F:PIH]NUM
      [F:PKW] = [F:PIH]
      Gosub FILL_PIH From CNSPIA1STD
    When NUM_PIV
      ENRLOC = "PIA" + [F:PIH]NUM
      [F:PKW] = [F:PIH]
      Gosub FILL_PIV From CNSPIA1STD
    When NUM_PNH
      ENRLOC = "PNH" + [F:PNH]PNHNUM
     [F:PKW] = [F:PNH]
      Gosub FILL_PNH From CNSPIA1STD
    When NUM_PTH
      ENRLOC = "PTH" + [F:PTH]PTHNUM
      [F:PKW] = [F:PTH]
      Gosub FILL_PTH From CNSPIA1STD
    When NUM_POC
      ENRLOC = "POC" + [F:POC]POHNUM
      [F:PKW] = [F:POC]
      Gosub FILL_POC From CNSPIA1STD
    When NUM_POH
      ENRLOC = "POH" + [F:POH]POHNUM
      [F:PKW] = [F:POH]
      Gosub FILL_POH From CNSPIA1STD
    When NUM_PSH
      ENRLOC = "PSH" + [F:PSH]PSHNUM
      [F:PKW] = [F:PSH]
      Gosub FILL_PSH From CNSPIA1STD
    When NUM_PQH
      ENRLOC = "PQH" + [F:PQH]PQHNUM
      [F:PKW] = [F:PQH]
      Gosub FILL_PQH From CNSPIA1STD
    When NUM_SCO
      ENRLOC = "SCO" + [F:SCO]SCONUM
      [F:PKW] = [F:SCO]
      Gosub FILL_SCO From CNSPIA1STD
    # ---------------------------------------------------
    When NUM_LOF
      # FGR 10/10/2012 : X3SUIVI81498
      ENRLOC = "LOF" + [F:LOF]CODLOF + "/" + num$([F:LOF]LINLOF)   # ATTENTION ICI : clé composée
      [F:PKW] = [F:LOF]
      Gosub FILL_LOF From CNSPIF1STD
    When NUM_FAS
      # FGR 10/10/2012 : X3SUIVI81498
      ENRLOC = "FAS" + [F:FAS]AASREF
      [F:PKW] = [F:FAS]
      Gosub FILL_FAS From CNSPIF1STD
    When NUM_BIS
      # FGR 24/10/2012 : X3SUIVI81498
      ENRLOC = "PIH" + [F:PIH]NUM
      [F:PKW] = [F:PIH]
      Gosub FILL_PIH From CNSPIA1STD
    When NUM_CTRH
      # FGR 29/05/2015 : X3SUIVI104697
      ENRLOC = "CTRH" + [F:CTRH]CTRNUM
      [F:PKW] = [F:CTRH]
      Gosub FILL_CTRH From CNSPIA1STD
    When NUM_SHH
      # FGR 29/05/2015 : X3SUIVI104697
      ENRLOC = "SHH" + [F:SHH]SHIPNUM
      [F:PKW] = [F:SHH]
      Gosub FILL_SHH From CNSPIA1STD
    When NUM_TRNP
      # FGR 29/05/2015 : X3SUIVI104697
      ENRLOC = "TRNP" + [F:TRNP]TRNNUM
      [F:PKW] = [F:TRNP]
      Gosub FILL_TRNP From CNSPIA1STD
    When Default
  Endcase
  # -----------------------------
  If IVCRLINSEL > 0 Then
    VCRLIN_T = IVCRLINSEL
  Endif
  # -----------------------------
  Gosub WRITE_PKW From CONSPITOOLS
  # -----------------------------
End

############################################################
$DECLARE_VAR
  Gosub DECLARE_VAR From CONSPITOOLS
  Case GACTION
    When "CONSPIV", "CONSPIC", "CONSPIH"          # FGR 15/12/2014 : X3SUIVI104792
      SCONTEXTE = "PIV"
    When "CONSPIA"
      SCONTEXTE = "PIA"
    When "CONSPIT"
      SCONTEXTE = "PIT"
    When "CONSPIF"                                # FGR 10/10/2012 : X3SUIVI81498
      SCONTEXTE = "PIF"                           # FGR 10/10/2012 : X3SUIVI81498
  Endcase
Return

############################################################
$LOAD_FILTER
  Raz GBIDI1
  Raz WFIL
  Raz WFIL1
  Case [M:PIV1]VCRTYPSEL
    When NUM_SQH
      Gosub FILTER_SQH From CNSPIV1STD
    When NUM_SDH
      Gosub FILTER_SDH From CNSPIV1STD
    When NUM_SRH
      Gosub FILTER_SRH From CNSPIV1STD
    When NUM_SIH
      Gosub FILTER_SIH From CNSPIV1STD
    When NUM_SIV
      Gosub FILTER_SIV From CNSPIV1STD
    When NUM_SOH
      Gosub FILTER_SOH From CNSPIV1STD
    When NUM_SOC
      Gosub FILTER_SOC From CNSPIV1STD
    When NUM_PRH
      Gosub FILTER_PRH From CNSPIV1STD
    When NUM_PRL
      Gosub FILTER_PRL From CNSPIV1STD
    When NUM_DUD, NUM_DUDA
      Gosub FILTER_DUD From CNSPIV1STD            # FGR 13/01/2012 : X3SUIVI71278
    When NUM_PYH
      Gosub FILTER_PYH From CNSPIV1STD            # FGR 13/01/2012 : X3SUIVI71278
    When NUM_REL
      Gosub FILTER_REL From CNSPIV1STD            # FGR 13/01/2012 : X3SUIVI71278
    When NUM_TSK
      Gosub FILTER_TSK From CNSPIV1STD            # FGR 13/01/2012 : X3SUIVI71278
    When NUM_CLL
      Gosub FILTER_CLL From CNSPIV1STD            # FGR 13/01/2012 : X3SUIVI71278
    When NUM_BAP
      Gosub FILTER_BAP From CNSPIV1STD            # FGR 13/01/2012 : X3SUIVI71278
    When NUM_CON
      Gosub FILTER_CON From CNSPIV1STD            # FGR 13/01/2012 : X3SUIVI71278
    When NUM_MAC
      Gosub FILTER_MAC From CNSPIV1STD            # FGR 13/01/2012 : X3SUIVI71278
    When NUM_SRE
      Gosub FILTER_SRE From CNSPIV1STD            # FGR 13/01/2012 : X3SUIVI71278
    When NUM_ITN
      Gosub FILTER_ITN From CNSPIV1STD            # FGR 13/01/2012 : X3SUIVI71278
    When NUM_SOL
      Gosub FILTER_SOL From CNSPIV1STD            # FGR 13/01/2012 : X3SUIVI71278
    # ---------------------------------------------------
    # FGR 08/02/2012 : X3SUIVI71269
    When NUM_PIH, NUM_PIHC
      Gosub FILTER_PIH From CNSPIA1STD
    When NUM_PIV
      Gosub FILTER_PIV From CNSPIA1STD
    When NUM_PNH
      Gosub FILTER_PNH From CNSPIA1STD
    When NUM_PTH
      Gosub FILTER_PTH From CNSPIA1STD
    When NUM_POC
      Gosub FILTER_POC From CNSPIA1STD
    When NUM_POH
      Gosub FILTER_POH From CNSPIA1STD
    When NUM_PSH
      Gosub FILTER_PSH From CNSPIA1STD
    When NUM_PQH
      Gosub FILTER_PQH From CNSPIA1STD
    When NUM_SCO
      Gosub FILTER_SCO From CNSPIA1STD
    # ---------------------------------------------------
    # FGR 10/10/2012 : X3SUIVI81498
    When NUM_LOF
      Gosub FILTER_LOF From CNSPIF1STD
    When NUM_FAS
      Gosub FILTER_FAS From CNSPIF1STD
    # ---------------------------------------------------
    When NUM_BIS
      # FGR 24/10/2012 : X3SUIVI81498
      Gosub FILTER_BIS From CNSPIV1STD
    When NUM_CTRH
      # FGR 29/05/2015 : X3SUIVI104697
      Gosub FILTER_CTRH From CNSPIA1STD
    When NUM_SHH
      # FGR 29/05/2015 : X3SUIVI104697
      Gosub FILTER_SHH From CNSPIA1STD
    When NUM_TRNP
      # FGR 29/05/2015 : X3SUIVI104697
      Gosub FILTER_TRNP From CNSPIA1STD
  Endcase
Return

############################################################
# TRAITEMENTS POUR GESTION AMONT
############################################################
$ENTREE_OF_AMONT
Local Integer GCOMMIT

  GOK = 1
  GPOINT = "FIND_AMONT_V" : Gosub ENTREE From EXEFNC
  If GOK < 1 Then
    Return
  Endif
  # ------------
  GCOMMIT = G_OUI
  Trbegin [PKW1]
  # ------------
  Case [F:PKW]VCRTYP
    When NUM_SQH
      Call FIND_TREE_AMONT_SQH(INIV, WLEV, GCOMMIT) From CNSPIV2STD
    When NUM_SDH
      Call FIND_TREE_AMONT_SDH(INIV, WLEV, GCOMMIT) From CNSPIV2STD
    When NUM_SRH
      Call FIND_TREE_AMONT_SRH(INIV, WLEV, GCOMMIT) From CNSPIV2STD
    When NUM_SIH
      Call FIND_TREE_AMONT_SIH(INIV, WLEV, GCOMMIT) From CNSPIV2STD
    When NUM_SIV
      Call FIND_TREE_AMONT_SIV(INIV, WLEV, GCOMMIT) From CNSPIV2STD
    When NUM_SOH
      Call FIND_TREE_AMONT_SOH(INIV, WLEV, GCOMMIT) From CNSPIV2STD
    When NUM_SOC
      Call FIND_TREE_AMONT_SOC(INIV, WLEV, GCOMMIT) From CNSPIV2STD
    When NUM_PRH
      Call FIND_TREE_AMONT_PRH(INIV, WLEV, GCOMMIT) From CNSPIV2STD
    When NUM_PRL
      Call FIND_TREE_AMONT_PRL(INIV, WLEV, GCOMMIT) From CNSPIV2STD
    When NUM_DUD, NUM_DUDA
