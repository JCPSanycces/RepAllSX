    When NUM_PQH
      Call FIND_TREE_AMONT_PQH(INIV, WLEV, GCOMMIT) From CNSPIA2STD
    When NUM_SCO
      Call FIND_TREE_AMONT_SCO(INIV, WLEV, GCOMMIT) From CNSPIA2STD
    # ---------------------------------------------------
    # FGR 10/10/2012 : X3SUIVI81498
    When NUM_LOF
      Call FIND_TREE_AMONT_LOF(INIV, WLEV, GCOMMIT) From CNSPIF2STD
    When NUM_FAS
      Call FIND_TREE_AMONT_FAS(INIV, WLEV, GCOMMIT) From CNSPIF2STD
