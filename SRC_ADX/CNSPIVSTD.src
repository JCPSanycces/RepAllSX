  NUM_TRNP= 39                                              # FGR 29/05/2015 : X3SUIVI104697
  # -----------------------------
  [M:PIV1]VCRCTL = 0
  # -----------------------------
  # FGR 25/01/2012 : X3SUIVI71278
  Call GETDEV(GFCY)  From DEVSUB
  [M:PIV1]CURSOC = GLOCALDEV
  [M:PIV1]CURFOL = GSYSCUR
  # -----------------------------
  If [M:PIV1]VCRTYPSEL = 0 Then
    Call LOAD_SCREEN(PARAM)
  Endif
  # -----------------------------
  # Si Param(2) est renseigné, c'est que la traçabilité est appelée depuis un autre menu :
  # on affiche donc directement le résultat, sauf si on a cliqué sur le bouton Détails
  If dim(PARAM) >= 0 and PARAM(2) <> "" Then
    [M:PIV1]TRKSEL = 2
    NOL = -1
    Gosub OUVRE_SEL
  Endif
  # -----------------------------
  NAVIG = GACTION
  # -----------------------------
  SUITE  = 1
  RETOUR = 1
Return

