    When NUM_TRNP
      # FGR 29/05/2015 : X3SUIVI104697
      Call FIND_TREE_AMONT_TRNP(INIV, WLEV, GCOMMIT) From CNSPIA2STD
    When NUM_CTRH
      # FGR 29/05/2015 : X3SUIVI104697
      Call FIND_TREE_AMONT_CTRH(INIV, WLEV, GCOMMIT) From CNSPIA2STD
    # ---------------------------------------------
  Endcase
  If GCOMMIT = G_NON Then
    Rollback
  Else
    Commit
  Endif
Return

