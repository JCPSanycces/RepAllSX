######################################################################################
Subprog AP_VCRNUMSEL(VALEUR)
Variable Char    VALEUR()

  If [M:PIV1]FLG = 0 Then
    [M:PIV1]VCRNUMSEL = VALEUR
    Gosub AFFICHER_SEL
  Endif
End

############################################################
Subprog AM_VCRNUMSEL(VALEUR)
Variable Char    VALEUR()

Local Integer NOL

  NOL = -1
  [M:PIV1]FLG = 0
  [M:PIV1]VCRLINSEL = 0
  Affzo [M:PIV1]VCRLINSEL
  If [M:PIV1]VCRNUMSEL <> VALEUR Then
    [M:PIV1]VCRNUMSEL = VALEUR
    Gosub AFFICHER_SEL
  Endif
End

############################################################
Subprog AM_LEVMAX(VALEUR)
Variable Decimal VALEUR

  [M:PIV1]FLG = 0
End

############################################################
Subprog C_LEVMAX(VALEUR)
Variable Decimal VALEUR

  If VALEUR < 2 or VALEUR > 15 Then
    mkstat = 2
  Endif
End

############################################################
Subprog AM_REGFLG(VALEUR)
Variable Integer VALEUR

  [M:PIV1]FLG = 0
End

############################################################
Subprog AM_ZERFLG(VALEUR)
Variable Integer VALEUR

  [M:PIV1]FLG = 0
End

############################################################
Subprog AV_LEV(VALEUR)
Variable Char    VALEUR()

  If nolign > 0 Then
    If [M]QTYSTU(nolign-1) < 0 Then
      pcolor = GCOUL(1)
    Else
      pcolor = GCOUL(0)
    Endif
  Endif
End

############################################################
Subprog IB_NBLIG
Local Char PROJECT(GLONOPP)  # Issue X3-70238 - 2018-03-28 by FGR
Local Char BUDGET(GLONVCR)   # Issue X3-70238 - 2018-03-28 by FGR
Local Char TASK(GLONVCR)     # Issue X3-70238 - 2018-03-28 by FGR
Local Integer IRET           # Issue X3-70238 - 2018-03-28 by FGR
Local Integer IPIMTYP        # Issue X3-70238 - 2018-03-28 by FGR
Local Char SMESS(250)        # Issue X3-70238 - 2018-03-28 by FGR

  Raz GBOUT6                 # Issue X3-70238 - 2018-03-28 by FGR
  If [M:PIV2]VCRTYP(nolign-1) > 0 Then
    # Issue X3-70238 - 2018-03-28 by FGR : BEGIN
    If [M:PIV2]VCRTYP(nolign-1) <> NUM_PJT Then
      GBOUT2 = mess([M:PIV2]VCRTYP(nolign-1),477,1)
      Raz GBOUT3
    Else
      IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, [M:PIV2]VCRNUM(nolign-1), PROJECT, BUDGET, TASK)
      IPIMTYP = func PIMPL_CSTD_PROGS.GET_PIMTYP_VALUE(GACTX, PROJECT, AVOID.ACHAR, AVOID.ACHAR, SMESS)
      If IPIMTYP = 1 or IPIMTYP = 3 Then
        GBOUT2 = mess([M:PIV2]VCRTYP(nolign-1),477,1)
      Else
        Raz GBOUT2
      Endif
      If IPIMTYP = 2 or IPIMTYP = 3 Then
        GBOUT3 = mess(40,477,1)
      Else
        Raz GBOUT3
      Endif
      IPIMTYP = func PIMPL_CSTD_PROGS.GET_PIMTYP_VALUE(GACTX, PROJECT, BUDGET, TASK, SMESS)
      If TASK <> AVOID.ACHAR Then
        GBOUT6 = mess(IPIMTYP,2254,1)
      Elsif BUDGET <> AVOID.ACHAR Then
        GBOUT6 = mess(IPIMTYP,2254,1)
      Endif
    Endif
    # Issue X3-70238 - 2018-03-28 by FGR : END
  Endif
  # ---------------------------------------------------
  # FGR 23/01/2012 :X3SUIVI71278 (début) et FGR 08/02/2012 : X3SUIVI71269 (début)
  If [M:PIV2]VCRTYP(nolign-1) = NUM_DUD Then
    Read [DUD]DUD8=[M:PIV2]VCRNUM(nolign-1)
    Case [F:DUD]BPRTYP
      When 1
        GBOUT2 = mess(NUM_SIH,477,1)
      When 2
        GBOUT2 = mess(NUM_PIH,477,1)
    Endcase
  Elsif [M:PIV2]VCRTYP(nolign-1) = NUM_DUDA Then
    Read [DUD]DUD8=[M:PIV2]VCRNUM(nolign-1)
    Case [F:DUD]BPRTYP
      When 1
        GBOUT2 = mess(NUM_SOH,477,1)
      When 2
        GBOUT2 = mess(NUM_POH,477,1)
    Endcase
  Endif
  # FGR 23/01/2012 :X3SUIVI71278 (fin) et FGR 08/02/2012 : X3SUIVI71269 (fin)
  # ---------------------------------------------------
  If GPILNAV > 1 Then
    # Si on vient de la gestion des objets, on empêche la consultation de la pièce
    Case [M:PIV2]VCRTYP(nolign-1)
      When NUM_SQH
        If find("GESSQH", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_SDH
        If find("GESSDH", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_SRH
          Read [F:SRH]SRH0=[M:PIV2]VCRNUM(nolign-1)
          If !fstat Then
            If [F:SRH]LNDRTN = G_OUI and find("GESSRL", GNAVIG(1..GPILNAV)) Then
              GBOUT2 = ""
            Elsif [F:SRH]SCORTN = G_OUI and find("GESSRS", GNAVIG(1..GPILNAV)) Then
              GBOUT2 = ""
            Elsif find("GESSRH", GNAVIG(1..GPILNAV)) Then
              GBOUT2 = ""
            Endif
          Endif
          If find("GESSRH", GNAVIG(1..GPILNAV)) Then
            GBOUT2 = ""
          Endif
      When NUM_SIH, NUM_DUD
        If find("GESSIH", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_SIV
        If find("GESSIH", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_SOH, NUM_DUDA
        If find("GESSOH", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_SOC
        If [M:PIV1]VCRLINSEL > 0 Then
          If find("GESSOQ", GNAVIG(1..GPILNAV)) Then
            GBOUT2 = ""
          Endif
        Else
          If find("GESSOR", GNAVIG(1..GPILNAV)) Then
            GBOUT2 = ""
          Endif
        Endif
      When NUM_HAE
        If find("GESGAS", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_PRH
        If find("GESPRH", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_PRL
        If find("GESPRL", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_PJT
        If find("GESOPP",GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_PYH
        # FGR 13/01/2012 : X3SUIVI71278
        If find("GESPAY", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_REL
        # FGR 13/01/2012 : X3SUIVI71278
        If find("GESREL", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_TSK
        # FGR 13/01/2012 : X3SUIVI71278
        If find("GESTSK", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_CLL
        # FGR 13/01/2012 : X3SUIVI71278
        If find("GESCLL", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_BAP
        # FGR 13/01/2012 : X3SUIVI71278
        If find("GESBAP", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_CON
        # FGR 13/01/2012 : X3SUIVI71278
        If find("GESCON", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_MAC
        # FGR 13/01/2012 : X3SUIVI71278
        If find("GESMAC", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_SRE
        # FGR 13/01/2012 : X3SUIVI71278
        If find("GESSRE", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_ITN
        # FGR 13/01/2012 : X3SUIVI71278
        If find("GESITN", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_SOL
        # FGR 13/01/2012 : X3SUIVI71278
        If find("GESSOL", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      # ------------------------------------------
      # FGR 08/02/2012 : X3SUIVI71269
      When NUM_PIH, NUM_PIHC, NUM_DUD
        If find("GESPIH", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_PIV
        If find("GESPIH", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_PNH
        If find("GESPNH", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_PTH
        If find("GESPTH", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_POC
        If [M:PIV1]VCRLINSEL>0 Then
          If find("GESPOD", GNAVIG(1..GPILNAV)) Then
            GBOUT2 = ""
          Endif
        Else
          If find("GESPOC", GNAVIG(1..GPILNAV)) Then
            GBOUT2 = ""
          Endif
        Endif
      When NUM_POH, NUM_DUDA
        If find("GESPOH", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_PSH
        If find("GESPSH", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_PQH
        If find("GESPQH", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_SCO
        If find("GESSCO",GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      # ------------------------------------------
      # FGR 10/10/2012 : X3SUIVI81498
      When NUM_LOF
        If find("GESLOF",GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_FAS
        If find("GESFAS",GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      # ------------------------------------------
      When NUM_BIS
        # FGR 24/10/2012 : X3SUIVI81498
        If find("GESBIS", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_CTRH
        # FGR 29/05/2015 : X3SUIVI104697
        If find("GESCTRH", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_SHH
        # FGR 29/05/2015 : X3SUIVI104697
        If find("GESSHIP", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When NUM_TRNP
        # FGR 29/05/2015 : X3SUIVI104697
        If find("GESTRNP", GNAVIG(1..GPILNAV)) Then
          GBOUT2 = ""
        Endif
      When Default
    Endcase
  Endif
  # ---------------------------------------------------
  If nolign = 1 Then
    If [M:PIV1]TRKSEL = 1 Then
      GBOUT4 = ""
    Endif
    If [M:PIV1]TRKSEL = 2 Then
      GBOUT5 = ""
    Endif
  Endif
  # ---------------------------------------------------
  If [M:PIV2]VCRTYP(nolign-1) = NUM_PRL Then
    # FGR 13/01/2012 : X3SUIVI71278 : Pas de tunnel, il n'y a pas d'objet
    GBOUT2 = ""
  Endif
  # ---------------------------------------------------
  If find([M:PIV2]VCRTYP(nolign-1), NUM_HAE, NUM_PJT) Then
    GBOUT4 = ""
    GBOUT5 = ""
  Endif
  # -----------------------------------------
  If [M:PIV2]VCRTYP(nolign-1) = NUM_PYH Then
    GBOUT5 = ""
  Endif
End

######################################################################################
Subprog B2_NBLIG
Local Char SAV_VCRNUM(GLONVCR)
Local Char SOPLIN(GLONVCR)
Local Char NOM_OBJET(GLONAOB)
Local Char NOM_TYP(GLONDES)
Local Char DEB_TYP(GLONVCR)
Local Integer NOL
Local Integer I
Local Char VALBOUT(250), PARBOUT(250)(1..20)
Local Char SVCR(GLONVCR)

  NOL = nolign-1
  NOM_TYP = num$([M:PIV2]VCRTYP(NOL))
  # On sauvegarde et on kille le GCNSPIXUUID, car dans certains traitements objets,
  # il est re-déclaré d'une façon différente, donc plantage
  # -----------------------------------------
  Case [M:PIV2]VCRTYP(NOL)
    When NUM_SIH              # facture vente
      NOM_OBJET = "SIH"
      Filter [F:SIV]
    When NUM_SIV              # avoir vente
      NOM_OBJET = "SIH"
      Filter [F:SIV]
    When NUM_SRH              # retour client
      NOM_OBJET = "SRH"
      Read [F:SRH]SRH0=[M:PIV2]VCRNUM(NOL)
      If !fstat Then
        If [F:SRH]LNDRTN = G_OUI Then
          NOM_OBJET = "SRL"
        Elsif [F:SRH]SCORTN = G_OUI Then
          NOM_OBJET = "SRS"
        Endif
      Endif
      Filter [F:SRH]
    When NUM_SDH              # livraison
      NOM_OBJET = "SDH"
      Filter [F:SDH]
    When NUM_PRH              # preparation
      NOM_OBJET = "PRH"
      Filter [F:PRH]
    When NUM_PRL              # liste préparation
      NOM_OBJET = "PRL"
      Filter [F:PRL]
    When NUM_SOC              # demande livraison
      If [M:PIV1]VCRLINSEL > 0 Then
        NOM_OBJET = "SOQ"
      Else
        NOM_OBJET = "SOR"
      Endif
    When NUM_SOH              # commande vente
      NOM_OBJET = "SOH"
      Read [F:SOH]SOH0=[M:PIV2]VCRNUM(NOL)
      If !fstat Then
        If [F:SOH]SOHCAT = 4 Then
          NOM_OBJET = "SOR"
        Endif
      Endif
      Filter [F:SOH]
    When NUM_SQH              # devis
      NOM_OBJET = "SQH"
      Filter [F:SQH]
    When NUM_HAE              # pièce
      NOM_OBJET = "GAS"
      If NOL > 0 Then
        # FQ55783 - MABON 17/07/09 - Recherche du type de la pièce
        I = 1
        While val([M:PIV2]LEV(NOL-I)) <> val([M:PIV2]LEV(NOL))-1
          I += 1
        Wend
        Local File GACCENTRY [HAEM]
        # -----------------------------------------
        Local File SINVOICE [SIH]
        Local File PINVOICE [PIH]
        Case [M:PIV2]VCRTYP(NOL-I)
          When NUM_SIH, NUM_SIV
            Read [SIH]SIH0=[M:PIV2]VCRNUM(NOL)
            If fstat Then
              Raz [F:SIH]
            Endif
            DEB_TYP = [F:SIH]GTE
          When NUM_PIH, NUM_PIV
            Read [PIH]PIH0=[M:PIV2]VCRNUM(NOL)
            If fstat Then
              Raz [F:PIH]
            Endif
            DEB_TYP = [F:PIH]GTE
        Endcase
        Filter [F:HAEM] Where NUM=[M:PIV2]VCRNUM(NOL) and TYP=DEB_TYP
        # -----------------------------------------
        Read [F:HAEM]First
        NOM_TYP = [F:HAEM]TYP
        Close Local File [HAEM]
      Endif
      Filter [F:HAE]
    When NUM_PJT              # affaire
      NOM_OBJET = "OPP"
      Filter [F:OPP]
    When NUM_DUDA             # Acompte => On part sur commande
      # FGR 13/01/2012 : X3SUIVI71278
      Filter [F:DUD]
      Read [DUD]DUD8=[M:PIV2]VCRNUM(nolign-1)
      Case [F:DUD]BPRTYP
        When 1
          NOM_OBJET = "SOH"
        When 2
          NOM_OBJET = "POH"
      Endcase
    When NUM_DUD              # Echéance => On part sur facture
      # FGR 13/01/2012 : X3SUIVI71278
      Filter [F:DUD]
      Read [DUD]DUD8=[M:PIV2]VCRNUM(nolign-1)
      Case [F:DUD]BPRTYP
        When 1
          NOM_OBJET = "SIH"
        When 2
          NOM_OBJET = "PIH"
      Endcase
    When NUM_PYH              # Règlements
      # FGR 13/01/2012 : X3SUIVI71278
      NOM_OBJET = "PAY"
      Filter [F:PYH]
    When NUM_REL              # Relevés
      # FGR 13/01/2012 : X3SUIVI71278
      NOM_OBJET = "REL"
      Filter [F:SOI]
    When NUM_TSK              # Tâches
      # FGR 13/01/2012 : X3SUIVI71278
      NOM_OBJET = "TSK"
      Filter [F:TSK]
    When NUM_CLL              # Appels
      # FGR 13/01/2012 : X3SUIVI71278
      NOM_OBJET = "CLL"
      Filter [F:CLL]
    When NUM_BAP              # Rendez-vous
      # FGR 13/01/2012 : X3SUIVI71278
      NOM_OBJET = "BAP"
      Filter [F:BAP]
    When NUM_CON              # Contrat de service
      # FGR 13/01/2012 : X3SUIVI71278
      NOM_OBJET = "CON"
      Filter [F:CON]
    When NUM_MAC              # Parc client
      # FGR 13/01/2012 : X3SUIVI71278
      NOM_OBJET = "MAC"
      Filter [F:MAC]
    When NUM_SRE              # Demande de service
      # FGR 13/01/2012 : X3SUIVI71278
      NOM_OBJET = "SRE"
      Filter [F:SRE]
    When NUM_ITN              # Intervention
      # FGR 13/01/2012 : X3SUIVI71278
      NOM_OBJET = "ITN"
      Filter [F:ITN]
    When NUM_SOL              # Solution
      # FGR 13/01/2012 : X3SUIVI71278
      NOM_OBJET = "SOL"
      Filter [F:SOL]
    # ------------------------------------------
    # FGR 08/02/2012 : X3SUIVI71269
    When NUM_PIH, NUM_PIHC    # facture achat
      NOM_OBJET = "PIH"
    When NUM_PIV              # avoir achat
      NOM_OBJET = "PIH"
    When NUM_PNH              # retour
      NOM_OBJET = "PNH"
    When NUM_PTH              # réception
      NOM_OBJET = "PTH"
    When NUM_POC              # demande livraison
      If [M:PIV1]VCRLINSEL > 0 Then
        NOM_OBJET = "POD"
      Else
        NOM_OBJET = "POC"
      Endif
    When NUM_POH              # commande achat
      NOM_OBJET = "POH"
    When NUM_PSH              # demande achat
      NOM_OBJET = "PSH"
    When NUM_PQH              # devis
      NOM_OBJET = "PQH"
    When NUM_SCO              # ordre sous-traitance
      NOM_OBJET = "SCO"
    # ------------------------------------------
    # FGR 10/10/2012 : X3SUIVI81498
    When NUM_LOF              # Dépense
      NOM_OBJET = "LOF"
    When NUM_FAS              # Bien comptable
      NOM_OBJET = "FAS"
    # ------------------------------------------
    # FGR 24/10/2012 : X3SUIVI81498
    When NUM_BIS              # facture tiers fournisseur
      NOM_OBJET = "BIS"
    When NUM_CTRH             # Conteneur
      # FGR 29/05/2015 : X3SUIVI104697
      NOM_OBJET = "CTRH"
    When NUM_SHH              # Expédition
      # FGR 29/05/2015 : X3SUIVI104697
      NOM_OBJET = "SHIP"
    When NUM_TRNP             # Transport
      # FGR 29/05/2015 : X3SUIVI104697
      NOM_OBJET = "TRNP"
    When Default
  Endcase
  # ----------------------------------
  GCONSULT = 2
  If NOM_OBJET <> "" Then
    # FGR 13/01/2012 : X3SUIVI71278 : NOM_OBJET peut être vide. Le tester avant un tunnel
    # On sauvegarde le VCRNUM, car si la pièce n'existe pas, ou ne peut être affichée
    # car filtre dans la gestion d'objet, la clé va être modifiée, et donc le VCRNUM aussi
    SAV_VCRNUM = [M:PIV2]VCRNUM(NOL)
    If NOM_OBJET = "SOQ" Then
      # Dans ce cas, la clé est composée (SOHNUM+SOPLIN); il faut donc inverser
      # les clés envoyées à GOBJET (puisque CLEPRIM=SOPLIN et CLESEC=SOHNUM)
      Local Char SOPLIN(GLONDES)       # FGR 26/05/2016 : X3SUIVI116775
      # Issue 118239 - 2016-12-09 by SR :Utiliser le numéro de ligne de la ligne
#      SOPLIN = num$([M:PIV1]VCRLINSEL)
      SOPLIN = num$([M:PIV1]VCRLIN(NOL))
      Call OBJET(NOM_OBJET, SOPLIN, [M:PIV2]VCRNUM(NOL)) From GOBJET
    Elsif NOM_OBJET = "POD" Then
      # FGR 08/02/2012 : X3SUIVI71269
      # Dans ce cas, la clé est composée (POHNUM+POPLIN); il faut donc inverser
      # les clés envoyées à GOBJET (puisque CLEPRIM=SOPLIN et CLESEC=SOHNUM)
      Local Char POPLIN(GLONDES)       # FGR 26/05/2016 : X3SUIVI116775
     # Issue 118239 - 2016-12-09 by SR : utiliser le numéro de ligne de la ligne
 #     POPLIN = num$([M:PIV1]VCRLINSEL)
      POPLIN = num$([M:PIV2]VCRLIN(NOL))
      Call OBJET(NOM_OBJET,POPLIN,[M:PIV2]VCRNUM(NOL)) From GOBJET
    Elsif NOM_OBJET = "LOF" Then
      # FGR 17/10/2012 : X3SUIVI81498 (début)
      Local Char LFGRFGR(GLONVCR)
      Local Char SVCRNUMLOF(type([M:PIV2]VCRNUM(NOL))-10)
      Local Integer NI

      Raz SVCRNUMLOF
      If instr(1,[M:PIV2]VCRNUM(NOL),"/") Then
        For NI = 1 To len([M:PIV2]VCRNUM(NOL))
          If mid$([M:PIV2]VCRNUM(NOL),NI,1) = "/" Then
            SVCRNUMLOF += "@"
          Else
            SVCRNUMLOF += mid$([M:PIV2]VCRNUM(NOL),NI,1)
          Endif
        Next NI
      Else
        SVCRNUMLOF = [M:PIV2]VCRNUM(NOL)
      Endif
      Call OBJET_CHAR(LFGRFGR, "LOF", SVCRNUMLOF) From GOBJET
      # FGR 17/10/2012 : X3SUIVI81498 (fin)
    Else
      If [M:PIV2]VCRTYP(NOL) <> NUM_DUD and [M:PIV2]VCRTYP(NOL) <> NUM_DUDA Then
        Call OBJET(NOM_OBJET,[M:PIV2]VCRNUM(NOL),NOM_TYP) From GOBJET
      Else
        SVCR = VCRNUMCALC(NOL)
        Call OBJET(NOM_OBJET,SVCR,NOM_TYP) From GOBJET
      Endif
    Endif
    [M:PIV2]VCRNUM(NOL) = SAV_VCRNUM
  Endif
  # ----------------------------------
  GCONSULT = 0
End

######################################################################################
Subprog B3_NBLIG
Local Char SAV_VCRNUM(GLONVCR)
Local Char NOM_OBJET(GLONAOB)
Local Char NOM_TYP(GLONDES)
Local Integer NOL

  # Issue X3-70238 - 2018-03-28 by FGR : BEGIN
  If [M:PIV2]VCRTYP(nolign-1) = NUM_PJT Then
    NOM_OBJET = "PJM"
    Filter [F:OPP]
  Endif
  # -----------------------------------------
  If NOM_OBJET <> "" Then
    NOL = nolign-1
    NOM_TYP = num$([M:PIV2]VCRTYP(NOL))
    GCONSULT = 2
    SAV_VCRNUM = [M:PIV2]VCRNUM(NOL)
    Call OBJET(NOM_OBJET,[M:PIV2]VCRNUM(NOL),NOM_TYP) From GOBJET
    [M:PIV2]VCRNUM(NOL) = SAV_VCRNUM
    GCONSULT = 0
  Endif
  # ----------------------------------
End

######################################################################################
Subprog B6_NBLIG

Local Integer NOL
Local Char PROJECT(GLONOPP)
Local Char BUDGET(GLONVCR)
Local Char TASK(GLONVCR)
Local Integer IRET
Local Integer IPIMTYP
Local Char SMESS(250)

  # Issue X3-70238 - 2018-03-28 by FGR
  NOL = nolign-1
  If [M:PIV2]VCRTYP(NOL) = NUM_PJT Then
    IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, [M:PIV2]VCRNUM(NOL), PROJECT, BUDGET, TASK)
    IPIMTYP = func PIMPL_CSTD_PROGS.GET_PIMTYP_VALUE(GACTX, PROJECT, BUDGET, TASK, SMESS)
    If IPIMTYP = 4 Then
      Call TUNPJMBUD(BUDGET, PROJECT) From PJMSELECT
    Else
      Call TUNPJMTSK(TASK, PROJECT) From PJMSELECT
    Endif
  Endif
End

######################################################################################
# Bouton Détails
$OUVRE_VISU
Local Integer MAXLIG
Local Integer NOL
Local Char PRONUM_S(len(uuid$))

  If dim(PROGSTD) < 0 Then
    Local Char PROGSTD(GLONADC)
  Endif
  PROGSTD = "CNSPIVSTD"
  [M:PIV1]FLG = 1
  Gosub OUVRE
  # ----------------------------------
  MAXLIG = dim([M:PIV3]LEV)
  # FGR 25/01/2012 : X3SUIVI71278
  [M:PIV3]BPRNUM1 = [M:PIV1]BPRNUM
  [M:PIV3]CURSOC = GLOCALDEV
  [M:PIV3]CURFOL = GSYSCUR
  # ----------------------------------
  Gosub LECTURE
Return

######################################################################################
$TRAC_CLIC_DROIT
Local Integer NOL

  NOL = -1
  If dim(PROGSTD) < 0 Then
    Local Char PROGSTD(GLONADC)
  Endif
  PROGSTD = "CNSPIVSTD"
  If dim(AMONT_AVAL) < 0 Then
    Global Integer AMONT_AVAL
  Endif
  AMONT_AVAL = G_OUI
  [M:PIV1]TRKSEL = SENS
  [M:PIV1]FLG = 0
  [M:PIV1]VCRNUMSEL = [M:PIV2]VCRNUM(nolign-1)
  [M:PIV1]VCRTYPSEL = [M:PIV2]VCRTYP(nolign-1)
  [M:PIV1]VCRLINSEL = 0
  # ----------------------------------
  Gosub OUVRE
  WFILS = "1=1"
  Gosub OUVRE_SEL
  Gosub LECTURE
  # ----------------------------------
  Affzo [M:PIV1]
  Affzo [M:PIV2]
  AMONT_AVAL = G_NON
  # ----------------------------------
  zonsui = "[M:PIV1]VCRNUMSEL"
  mkstat = 99
Return

######################################################################################
# Traçabilité amont affichée par clic droit
Subprog B4_NBLIG
Local Integer SENS

  SENS = 1
  If [M:PIV1]VCRLINSEL > 0 and [M:PIV1]VCRTYPSEL <> [M:PIV2]VCRTYP(nolign-1) Then
    [M:PIV1]VCRLINSEL = 0
  Endif
  Gosub TRAC_CLIC_DROIT
End

######################################################################################
# Traçabilité aval affichée par clic droit
Subprog B5_NBLIG
Local Integer SENS

  SENS = 2
  If [M:PIV1]VCRLINSEL > 0 and [M:PIV1]VCRTYPSEL <> [M:PIV2]VCRTYP(nolign-1) Then
    [M:PIV1]VCRLINSEL = 0
  Endif
  Gosub TRAC_CLIC_DROIT
End

######################################################################################
Subprog AS_VCRLINSEL(VALEUR)
Variable Decimal VALEUR

  If [M:PIV1]VCRTYPSEL = NUM_PRL Then
    mkstat = 2
  Endif
End

######################################################################################
Subprog AM_VCRLINSEL(VALEUR)
Variable Decimal VALEUR

  [M:PIV1]VCRCTL = 1
  If [M:PIV1]VCRLINSEL <> VALEUR Then
    [M:PIV1]FLG = 0
  Endif
  If [M:PIV1]VCRNUMSEL <> "" and [M:PIV1]FLG = 0 Then
    [M:PIV1]VCRLINSEL = VALEUR
    Gosub AFFICHER_SEL
  Endif
End

######################################################################################
Subprog C_VCRLINSEL(VALEUR)
Variable Decimal VALEUR

  [M:PIV1]VCRCTL = 1
  If [M:PIV1]VCRNUMSEL <> "" and VALEUR > 0 Then
    Case [M:PIV1]VCRTYPSEL
      When NUM_SQH
        If !clalev([F:SQD]) Then Local File SQUOTED   [SQD] : Endif
        Filter [F:SQD] Where SQHNUM=[M:PIV1]VCRNUMSEL and SQDLIN=VALEUR
        If rowcount([F:SQD]) = 0 Then
          mkstat = 2
          [M:PIV1]VCRCTL = 0
        Endif
        Filter [F:SQD]
      When NUM_SDH
        If !clalev([F:SDD]) Then Local File SDELIVERYD [SDD] : Endif
        Filter [F:SDD] Where SDHNUM=[M:PIV1]VCRNUMSEL and SDDLIN=VALEUR
        If rowcount([F:SDD]) = 0 Then
          mkstat = 2
          [M:PIV1]VCRCTL = 0
        Endif
        Filter [F:SDD]
      When NUM_SRH
        If !clalev([F:SRD]) Then Local File SRETURND [SRD] : Endif
        Filter [F:SRD] Where SRHNUM=[M:PIV1]VCRNUMSEL and SRDLIN=VALEUR
        If rowcount([F:SRD]) = 0 Then
          mkstat = 2
          [M:PIV1]VCRCTL = 0
        Endif
        Filter [F:SRD]
      When NUM_SIH
        If !clalev([F:SID]) Then Local File SINVOICED [SID] : Endif
        Filter [F:SID] Where NUM=[M:PIV1]VCRNUMSEL and SIDLIN=VALEUR
        If rowcount([F:SID]) = 0 Then
          mkstat = 2
          [M:PIV1]VCRCTL = 0
        Endif
        Filter [F:SID]
      When NUM_SIV
        If !clalev([F:SID]) Then Local File SINVOICED [SID] : Endif
        Filter [F:SID] Where NUM=[M:PIV1]VCRNUMSEL and SIDLIN=VALEUR
        If rowcount([F:SID]) = 0 Then
          mkstat = 2
          [M:PIV1]VCRCTL = 0
        Endif
        Filter [F:SID]
      When NUM_SOH
        If !clalev([F:SOQ]) Then Local File SORDERQ [SOQ] : Endif
        Filter [F:SOQ] Where SOHNUM=[M:PIV1]VCRNUMSEL and SOPLIN=VALEUR
        If rowcount([F:SOQ]) = 0 Then
          mkstat = 2
          [M:PIV1]VCRCTL = 0
        Endif
        Filter [F:SOQ]
      When NUM_PRH
        If !clalev([F:PRE]) Then Local File STOPRED   [PRE] : Endif
        Filter [F:PRE] Where PRHNUM=[M:PIV1]VCRNUMSEL and PRELIN=VALEUR
        If rowcount([F:PRE]) = 0 Then
          mkstat = 2
          [M:PIV1]VCRCTL = 0
        Endif
        Filter [F:PRE]
      When NUM_DUD, NUM_DUDA
        # FGR 13/01/2012 : X3SUIVI71278
        If !clalev([F:DUD]) Then Local File GACCDUDATE [DUD] : Endif
        Filter [F:DUD] Where NUMDUD=[M:PIV1]VCRNUMSEL and DUDLIG=VALEUR
        If rowcount([F:DUD]) = 0 Then
          mkstat = 2
          [M:PIV1]VCRCTL = 0
        Endif
        Filter [F:DUD]
      When NUM_PYH
        # FGR 13/01/2012 : X3SUIVI71278
        If !clalev([F:PYD]) Then Local File PAYMENTD [PYD] : Endif
        Filter [F:PYD] Where NUM=[M:PIV1]VCRNUMSEL and LIN=VALEUR
        If rowcount([F:PYD]) = 0 Then
          mkstat = 2
          [M:PIV1]VCRCTL = 0
        Endif
        Filter [F:PYD]
      When NUM_PYH
        # FGR 13/01/2012 : X3SUIVI71278
        If !clalev([F:DUD]) Then Local File GACCDUDATE [DUD] : Endif
        Filter [F:DUD] Where SOI=G_OUI and SOINUM=[M:PIV1]VCRNUMSEL and DUDLIG=VALEUR
        If rowcount([F:DUD]) = 0 Then
          mkstat = 2
          [M:PIV1]VCRCTL = 0
        Endif
        Filter [F:DUD]
      When NUM_TSK
        # FGR 13/01/2012 : X3SUIVI71278 : Rien à faire dans ce cas, pas de ligne sur les tâches
      When NUM_CLL
        # FGR 13/01/2012 : X3SUIVI71278 : Rien à faire dans ce cas, pas de ligne sur les appels
      When NUM_BAP
        # FGR 13/01/2012 : X3SUIVI71278 : Rien à faire dans ce cas, pas de ligne sur les rendez-vous
      When NUM_CON
        # FGR 13/01/2012 : X3SUIVI71278 : Rien à faire dans ce cas, pas de ligne sur les contrats de service
      When NUM_MAC
        # FGR 13/01/2012 : X3SUIVI71278 : Rien à faire dans ce cas, pas de ligne sur les parcs client
      When NUM_SRE
        # FGR 13/01/2012 : X3SUIVI71278 : Rien à faire dans ce cas, pas de ligne sur les demandes de service
      When NUM_ITN
        # FGR 13/01/2012 : X3SUIVI71278 : Rien à faire dans ce cas, pas de ligne sur les interventions
      When NUM_SOL
        # FGR 13/01/2012 : X3SUIVI71278 : Rien à faire dans ce cas, pas de ligne sur les solutions
      # ---------------------------------------
      # FGR 08/02/2012 : X3SUIVI71269
      When NUM_PIH, NUM_PIHC
        If !clalev([F:PID]) Then Local File PINVOICED  [PID] : Endif
        Filter [F:PID] Where NUM=[M:PIV1]VCRNUMSEL and (INVTYP=1 or INVTYP=5) and PIDLIN=VALEUR
        If rowcount([F:PID]) = 0 Then
          mkstat = 2
          [M:PIV1]VCRCTL = 0
        Endif
        Filter [F:PID]
      When NUM_PIV
        If !clalev([F:PID]) Then Local File PINVOICED  [PID] : Endif
        Filter [F:PID] Where NUM=[M:PIV1]VCRNUMSEL and INVTYP=2 and PIDLIN=VALEUR
        If rowcount([F:PID]) = 0 Then
          mkstat = 2
          [M:PIV1]VCRCTL = 0
        Endif
        Filter [F:PID]
      When NUM_PNH
        If !clalev([F:PND]) Then Local File PRETURND  [PND] : Endif
        Filter [F:PND] Where PNHNUM=[M:PIV1]VCRNUMSEL and PNDLIN=VALEUR
        If rowcount([F:PND]) = 0 Then
          mkstat = 2
          [M:PIV1]VCRCTL = 0
        Endif
        Filter [F:PND]
      When NUM_PTH
        If !clalev([F:PTD]) Then Local File PRECEIPTD  [PTD] : Endif
        Filter [F:PTD] Where PTHNUM=[M:PIV1]VCRNUMSEL and PTDLIN=VALEUR
        If rowcount([F:PTD]) = 0 Then
          mkstat = 2
          [M:PIV1]VCRCTL = 0
        Endif
        Filter [F:PTD]
      When NUM_POC
        # FGR 09/02/2012 : X3SUIVI71269 : Rien à faire dans ce cas
      When NUM_POH
        If !clalev([F:POQ]) Then Local File PORDERQ    [POQ] : Endif
        Filter [F:POQ] Where POHNUM=[M:PIV1]VCRNUMSEL and POPLIN=VALEUR
        If rowcount([F:POQ]) = 0 Then
          mkstat = 2
          [M:PIV1]VCRCTL = 0
        Endif
        Filter [F:POQ]
      When NUM_PSH
        If !clalev([F:PSD]) Then Local File PREQUISD   [PSD] : Endif
        Filter [F:PSD] Where PSHNUM=[M:PIV1]VCRNUMSEL and PSDLIN=VALEUR
        If rowcount([F:PSD]) = 0 Then
          mkstat = 2
          [M:PIV1]VCRCTL = 0
        Endif
        Filter [F:PSD]
      When NUM_PQH
        If !clalev([F:PQD]) Then Local File PQUOTATD   [PQD] : Endif
        Filter [F:PQD] Where PQHNUM=[M:PIV1]VCRNUMSEL and PQDLIN=VALEUR
        If rowcount([F:PQD]) = 0 Then
          mkstat = 2
          [M:PIV1]VCRCTL = 0
        Endif
        Filter [F:PQH]
      When NUM_SCO
        If !clalev([F:SCI]) Then Local File SCOITM     [SCI] : Endif
        Filter [F:SCI] Where SCONUM=[M:PIV1]VCRNUMSEL and SCILIN=VALEUR
        If rowcount([F:SCI]) = 0 Then
          mkstat = 2
          [M:PIV1]VCRCTL = 0
        Endif
        Filter [F:SCI]
      # ---------------------------------------
      # FGR 10/10/2012 : X3SUIVI81498
      When NUM_LOF
        If !clalev([F:LOF]) Then Local File LAYOUTFAS  [LOF] : Endif
        Filter [F:LOF] Where CODLOF=[M:PIV1]VCRNUMSEL and LINLOF=VALEUR
        If rowcount([F:LOF]) = 0 Then
          mkstat = 2
          [M:PIV1]VCRCTL = 0
        Endif
        Filter [F:LOF]

      When NUM_FAS
        # Rien à faire dans ce cas, pas de ligne sur les biens comptables
      # ---------------------------------------
      # FGR 24/10/2012 : X3SUIVI81498
      When NUM_BIS
        If !clalev([F:PID]) Then Local File PINVOICED  [PID] : Endif
        Filter [F:PID] Where NUM=[M:PIV1]VCRNUMSEL and PIDLIN=VALEUR
        If rowcount([F:PID]) = 0 Then
          mkstat = 2
          [M:PIV1]VCRCTL = 0
        Endif
        Filter [F:PID]
      When NUM_CTRH
        # FGR 29/05/2015 : X3SUIVI104697 : Rien à faire dans ce cas, pas de ligne sur les conteneurs
      When NUM_SHH
        # FGR 29/05/2015 : X3SUIVI104697 : Rien à faire dans ce cas, pas de ligne sur les expéditions
      When NUM_TRNP
        # FGR 29/05/2015 : X3SUIVI104697 : Rien à faire dans ce cas, pas de ligne sur les transports
      When Default
    Endcase
  Endif
  If [M:PIV1]VCRCTL = 0 Then
    GMESSAGE = mess(139,105,1) : # Ligne inexistante
  Endif
End

############################################################
# ACTION COMMERCIALE
############################################################
Subprog FIND_TSK_AVAL_FROM(SORIADI, SORIVCR, IORIVCRL, INIV, WLEV, GCOMMIT)
Value Char SORIADI
Value Char SORIVCR
Value Integer IORIVCRL
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char TSKNUM_F(GLONVCR)

  If GMODU(13) = G_NON Then
    # Module "Action commerciale"
    End
  Endif
  If !clalev([F:TSK]) Then Local File TASK [TSK] : Endif
  # ---------------------
  Filter [TSK] Where [F:TSK]TSKORIADI = SORIADI and [F:TSK]TSKORIVCR = SORIVCR
  If rowcount([F:TSK]) > 0 Then
    For [F:TSK]
      TSKNUM_F = [F:TSK]TSKNUM
      Gosub WRITE_PKW1_TSK From CNSPIV2STD
      WK = 1
    Next
  Endif
  Filter [TSK]
  # ---------------------
End

############################################################
Funprog GET_TYP(ITYPE)
Value Integer ITYPE

Local Char SARENDRE(GLONAOB)

  SARENDRE = string$(ITYPE=1,"SIH") + string$(ITYPE=2,"SIV")
End SARENDRE

