    # Module "Action commerciale"
    If !clalev([F:TSK]) Then Local File TASK       [TSK]  : Endif : # Tâches                 # FGR 13/01/2012 : X3SUIVI71278
    If !clalev([F:CLL]) Then Local File PHONECALL  [CLL]  : Endif : # Appels                 # FGR 13/01/2012 : X3SUIVI71278
    If !clalev([F:BAP]) Then Local File BAPPOINT   [BAP]  : Endif : # Rendez-vous            # FGR 13/01/2012 : X3SUIVI71278
  Endif
