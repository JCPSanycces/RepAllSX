# SUPPORT CLIENT
############################################################
Subprog FIND_CON_AVAL_FROM(SORIML, SORIVCR, IORIVCRL, INIV, WLEV, GCOMMIT)
Value Integer SORIML
Value Char SORIVCR
Value Integer IORIVCRL
