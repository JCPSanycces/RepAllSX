############################################################
$LOA_PAGE_FIN
  If clalev([M:PIV3]) and GACTION = "VISUPIV"  Then
    [M:PIV3]NBLIG = NOL
    Affzo [M:PIV3]
  Endif
  # On incrémente le NOL pour afficher directement lorsqu'on clique droit sur Amont/Aval
  # Lorsqu'on affiche normalement, le NBLIG sera recalculé dans GCONSULT
  NOL += 1
  # Issue 84171 - 2012-09-07 by MUARN : erreur tracabilité pièces ajout contrôle GACTION
  If GACTION <> "VISUPIV"
    If clalev([M:PIV2]) and NOL >= 0 Then
      [M:PIV2]NBLIG = NOL
    Endif
  Endif
Return

############################################################
$LOA_LIGNE
Local Char SBPRNAM(GLONNAM)
Local Integer I
Local Integer NB_
Local Char LEVALP(GLONDES)

  If [F:PKW]BPRNUM <> "" Then
    If !clalev([F:BPR]) Then Local File BPARTNER [BPR] : Endif
    Read [BPR]BPR0=[F:PKW]BPRNUM
    If fstat = 0 Then
      SBPRNAM = [F:BPR]BPRNAM(0)
    Endif
  Endif
  #----------------------------------------------
  If clalev([M:PIV3]) or GACTION = "VISUPIV" Then
    [M:PIV3] = [F:PKW]
    If NOL = -1 Then
      [M:PIV3]PARKEY(0) = ""
      # FGR 10/12/2012 : X3SUIVI86461
      #[M:PIV3]KEYC(0) = [F:PKW]VCRNUM
      [M:PIV3]KEYC(0) = num$([F:PKW]VCRTYP) + "-" + [F:PKW]VCRNUM
    Endif
    If left$([F:PKW]LEVALP,1) = "_" Then
      NB_ = 0
      LEVALP = [F:PKW]LEVALP
      For I = 1 To len([F:PKW]LEVALP)
        If left$(LEVALP,1) = "_" Then
          LEVALP = mid$(LEVALP, 2, len(LEVALP)-1)
          NB_ += 1
        Else
          Break
        Endif
      Next I
      [M:PIV3]LEVC(nolign-1) = LEVALP
      I = 1
      While [M:PIV3]LEVC(nolign-1-I) <> num$(NB_)
        I += 1
      Wend
      If NOL > -1 Then
        [M:PIV3]PARKEY(nolign-1) = [M:PIV3]KEYC(nolign-1-I)
      Endif
    Else
      [M:PIV3]LEVC(nolign-1) = [F:PKW]LEVALP
      If NOL > -1 Then
        [M:PIV3]PARKEY(nolign-1) = [M:PIV3]KEYC(0)
      Endif
    Endif
    If NOL > -1 Then
      # FGR 10/12/2012 : X3SUIVI86461
      #[M:PIV3]KEYC(nolign-1) = num$([F:PKW]VCRTYP) + "-" + [F:PKW]VCRNUM
      [M:PIV3]KEYC(nolign-1) = num$([F:PKW]VCRTYP) + "-" + [F:PKW]VCRNUM + "-" + [F:PKW]VCRNUMORI + "-" + num$([F:PKW]VCRLINORI)
    Endif
    [M:PIV3]BPRNAM(nolign-1) = SBPRNAM
    [M:PIV3]LEV(nolign-1) = [F:PKW]LEVALP
  Endif
  #----------------------------------------------
  If clalev([M:PIV2]) and GACTION <> "VISUPIV" Then
    [M:PIV2] = [F:PKW]
    If NOL = -1 Then
      [M:PIV2]PARKEY(0) = ""
      # FGR 10/12/2012 : X3SUIVI86461
      #[M:PIV2]KEYC(0) = [F:PKW]VCRNUM
      [M:PIV2]KEYC(0) = num$([F:PKW]VCRTYP) + "-" + [F:PKW]VCRNUM
    Endif
    [M:PIV2]BPRNAM(nolign-1) = SBPRNAM
    If left$([F:PKW]LEVALP,1) = "_" Then
      NB_ = 0
      LEVALP = [F:PKW]LEVALP
      For I = 1 To len([F:PKW]LEVALP)
        If left$(LEVALP,1) = "_" Then
          LEVALP = mid$(LEVALP, 2, len(LEVALP)-1)
          NB_ += 1
        Else
          Break
        Endif
      Next I
      [M:PIV2]LEV(nolign-1) = LEVALP
      I = 1
      While [M:PIV2]LEV(nolign-1-I) <> num$(NB_)
        I += 1
      Wend
      If NOL > -1 Then
        [M:PIV2]PARKEY(nolign-1) = [M:PIV2]KEYC(nolign-1-I)
      Endif
    Else
      [M:PIV2]LEV(nolign-1) = [F:PKW]LEVALP
      If NOL>-1 Then
        [M:PIV2]PARKEY(nolign-1) = [M:PIV2]KEYC(0)
      Endif
    Endif
    If NOL > -1 Then
      # FGR 10/12/2012 : X3SUIVI86461
      #[M:PIV2]KEYC(nolign-1) = num$([F:PKW]VCRTYP) + "-" + [F:PKW]VCRNUM
      [M:PIV2]KEYC(nolign-1) = num$([F:PKW]VCRTYP) + "-" + [F:PKW]VCRNUM + "-" + [F:PKW]VCRNUMORI + "-" + num$([F:PKW]VCRLINORI)
    Endif
    [M:PIV2]LIB(nolign-1) = [F:PKW]VCRNUM
  Endif
Return

############################################################
# Fenetre de sélection des pièces
$S_SELPIV
Local Char WNUM(GLONVCR)

  WNUM = VALEUR
  # ----------------------
  TIT(0)  = mess(18,100,1)
  CRITERE = "1=1"
  Case [M:PIV1]VCRTYPSEL
    When NUM_SQH
      If !clalev([F:SQH]) Then Local File SQUOTE    [SQH] : Endif
      Default File [SQH]
      OBJET = "SQH"
    When NUM_SDH
      If !clalev([F:SDH]) Then Local File SDELIVERY [SDH] : Endif
      Default File [SDH]
      OBJET = "SDH"
    When NUM_SRH
      If !clalev([F:SRH]) Then Local File SRETURN   [SRH] : Endif
      Default File [SRH]
      OBJET = "SRH"
    When NUM_SIH
      If !clalev([F:SIH]) Then Local File SINVOICE  [SIH] : Endif
      Default File [SIH]
      GSELFAC = 1
      OBJET   = "SIH"
      Filter [F:SIV]
      CRITERE = "INVTYP=1 or INVTYP=5"
    When NUM_SIV
      If !clalev([F:SIH]) Then Local File SINVOICE  [SIH] : Endif
      Default File [SIH]
      GSELFAC = 1
      OBJET   = "SIH"
      Filter [F:SIV]
      CRITERE = "INVTYP=2"
    When NUM_SOH
      If !clalev([F:SOH]) Then Local File SORDER    [SOH] : Endif
      Default File [SOH]
      OBJET = "SOH"
      CRITERE = "SOHCAT<>4"
    When NUM_SOC
      If !clalev([F:SOC]) Then Local File SORDERC   [SOC] : Endif
      Default File [SOC]
      OBJET = "SOM"
      START = "SOHNUM"
    When NUM_PRH
      If !clalev([F:PRH]) : Local File STOPREH   [PRH] : Endif
      Default File [PRH]
      OBJET = "PRH"
    When NUM_PRL
      If !clalev([F:PRL]) Then Local File STOPRELIS [PRL] : Endif
      Default File [PRL]
      OBJET   = "PRL"
      CRITERE = "ORITYP=1 or ORITYP=2"
      OPTIONS = "|"
    When NUM_DUD, NUM_DUDA
      # FGR 13/01/2012 : X3SUIVI71278
      If !clalev([F:DUD]) Then Local File GACCDUDATE [DUD] : Endif
      Default File [DUD]
      OBJET = ""
    When NUM_PYH
      # FGR 13/01/2012 : X3SUIVI71278
      If !clalev([F:PYH]) Then Local File PAYMENTH [PYH] : Endif
      Default File [PYH]
      OBJET = "PAY"
      Global Char GFLAGLEG(GLONADI)
    When NUM_REL
      # FGR 13/01/2012 : X3SUIVI71278
      If !clalev([F:SOI]) Then Local File SOI [SOI] : Endif
      Default File [SOI]
      OBJET = "REL"
    When NUM_TSK
      # FGR 13/01/2012 : X3SUIVI71278
      If !clalev([F:TSK]) Then Local File TASK [TSK] : Endif
      Default File [TSK]
      OBJET = "TSK"
    When NUM_CLL
      # FGR 13/01/2012 : X3SUIVI71278
      If !clalev([F:CLL]) Then Local File PHONECALL [CLL] : Endif
      Default File [CLL]
      OBJET = "CLL"
    When NUM_BAP
      # FGR 13/01/2012 : X3SUIVI71278
      If !clalev([F:BAP]) Then Local File BAPPOINT [BAP] : Endif
      Default File [BAP]
      OBJET = "BAP"
    When NUM_CON
      # FGR 13/01/2012 : X3SUIVI71278
      If !clalev([F:CON]) Then Local File CONTSERV [CON] : Endif
      Default File [CON]
      OBJET = "CON"
    When NUM_MAC
      # FGR 13/01/2012 : X3SUIVI71278
      If !clalev([F:MAC]) Then Local File MACHINES [MAC] : Endif
      Default File [MAC]
      OBJET = "MAC"
    When NUM_SRE
      # FGR 13/01/2012 : X3SUIVI71278
      If !clalev([F:SRE]) Then Local File SERREQUEST [SRE] : Endif
      Default File [SRE]
      OBJET = "SRE"
    When NUM_ITN
      # FGR 13/01/2012 : X3SUIVI71278
      If !clalev([F:ITN]) Then Local File INTERVEN [ITN] : Endif
      Default File [ITN]
      OBJET = "ITN"
    When NUM_SOL
      # FGR 13/01/2012 : X3SUIVI71278
      If !clalev([F:SOL]) Then Local File SOLUTION [SOL] : Endif
      Default File [SOL]
      OBJET = "SOL"
    # --------------------------------------------
    # FGR 08/02/2012 : X3SUIVI71269
    When NUM_PIH, NUM_PIHC
      If !clalev([F:PIH]) Then Local File PINVOICE  [PIH] : Endif
      Default File [PIH]
      GSELFAC = 1
      OBJET   = "PIH"
      Filter [F:PIH]
      CRITERE = "(INVTYP=1 or INVTYP=5) and ORIMOD=6"
    When NUM_PIV
      If !clalev([F:PIH]) Then Local File PINVOICE  [PIH] : Endif
      Default File [PIH]
      GSELFAC = 1
      OBJET   = "PIH"
      Filter [F:PIH]
      CRITERE = "INVTYP=2"
    When NUM_PNH
      If !clalev([F:PNH]) Then Local File PRETURN   [PNH] : Endif
      Default File [PNH]
      OBJET = "PNH"
    When NUM_PTH
      If !clalev([F:PTH]) Then Local File PRECEIPT  [PTH] : Endif
      Default File [PTH]
      OBJET = "PTH"
    When NUM_POC
      If !clalev([F:POC]) Then Local File PORDERC   [POC] : Endif
      Default File [POC]
      OBJET = "POD"
      START = "POHNUM"
    When NUM_POH
      If !clalev([F:POH]) Then Local File PORDER    [POH] : Endif
      Default File [POH]
      OBJET = "POH"
      CRITERE = "SOHCAT<>4 & POHTYP<>2"
    When NUM_PSH
      If !clalev([F:PSH]) Then Local File PREQUIS   [PSH] : Endif
      Default File [PSH]
      OBJET = "PSH"
    When NUM_PQH
      If !clalev([F:PQH]) Then Local File PQUOTAT   [PQH] : Endif
      Default File [PQH]
      OBJET = "PQH"
    When NUM_SCO
      If !clalev([F:SCO]) Then Local File SCOHEAD   [SCO] : Endif
      Default File [SCO]
      OBJET = "SCO"
    # --------------------------------------------
    # FGR 10/10/2012 : X3SUIVI81498
    When NUM_LOF
      If !clalev([F:LOF]) Then Local File LAYOUTFAS [LOF] : Endif
      Default File [LOF]
      OBJET = "LOF"
      WNUM=""     # Issue X3-86804
    When NUM_FAS
      If !clalev([F:FAS]) Then Local File FXDASSETS [FAS] : Endif
      Default File [FAS]
      OBJET = "FAS"
    # --------------------------------------------
    # FGR 24/10/2012 : X3SUIVI81498
    When NUM_BIS
      If !clalev([F:PIH]) Then Local File PINVOICE  [PIH] : Endif
      Default File [PIH]
      GSELFAC = 1
      OBJET   = "PIH"
      Filter [F:PIH]
      CRITERE = "ORIMOD=3"
    When NUM_CTRH
      # FGR 29/05/2015 : X3SUIVI104697
      If !clalev([F:CTRH]) Then Local File CONTAINER [CTRH] : Endif
      Default File [CTRH]
      OBJET   = "CTRH"
    When NUM_SHH
      # FGR 29/05/2015 : X3SUIVI104697
      If !clalev([F:SHH]) Then Local File SHIPMENT   [SHH] : Endif
      Default File [SHH]
      OBJET   = "SHIP"
    When NUM_TRNP
      # FGR 29/05/2015 : X3SUIVI104697
      If !clalev([F:TRNP]) Then Local File TRANSPORT   [TRNP] : Endif
      Default File [TRNP]
      OBJET   = "TRNP"
    When Default
  Endcase
  SENS = 1
  VALEUR = WNUM
  DEFPAG = 1
Return

############################################################
# Fenêtre de sélection des lignes de pièces
$S_SELLINV
Local Integer  I
Local Char TEXTE(80)(1..200,1..2)

  I = 0
  TIT(1) = mess(3,176,1) # N° ligne
  TIT(2) = mess(18,7,1)  # Article
  CRITERE = "1=1"
  If [M:PIV1]VCRNUMSEL <> "" Then
    Case [M:PIV1]VCRTYPSEL
      When NUM_SQH
        If !clalev([F:SQD]) Then Local File SQUOTED   [SQD] : Endif
        Filter [F:SQD] Where SQHNUM=[M:PIV1]VCRNUMSEL
        #Lignes Devis No <n° devis>
        TIT = mess(7,105,1) - mess(5,413,1) - mess(3,132,1) - [M:PIV1]VCRNUMSEL
        For [F:SQD]
          I += 1
          TEX(I) = num$([F:SQD]SQDLIN)
          TEXTE(I,1) = num$([F:SQD]SQDLIN)
          TEXTE(I,2) = [F:SQD]ITMREF
        Next
        Filter [F:SQD]
      When NUM_SDH
        If !clalev([F:SDD]) Then Local File SDELIVERYD [SDD] : Endif
        Filter [F:SDD] Where SDHNUM=[M:PIV1]VCRNUMSEL
        #Lignes Livraison No <n° livraison>
        TIT = mess(7,105,1) - mess(129,197,1) - mess(3,132,1) - [M:PIV1]VCRNUMSEL
        For [F:SDD]
          I += 1
          TEX(I) = num$([F:SDD]SDDLIN)
          TEXTE(I,1) = num$([F:SDD]SDDLIN)
          TEXTE(I,2) = [F:SDD]ITMREF
        Next
        Filter [F:SDD]
      When NUM_SRH
        If !clalev([F:SRD]) Then Local File SRETURND [SRD] : Endif
        Filter [F:SRD] Where SRHNUM=[M:PIV1]VCRNUMSEL
        #Lignes Retour No <n° retour>
        TIT = mess(7,105,1) - mess(144,124,1) - mess(3,132,1) - [M:PIV1]VCRNUMSEL
        For [F:SRD]
          I += 1
          TEX(I) = num$([F:SRD]SRDLIN)
          TEXTE(I,1) = num$([F:SRD]SRDLIN)
          TEXTE(I,2) = [F:SRD]ITMREF
        Next
        Filter [F:SRD]
      When NUM_SIH
        If !clalev([F:SID]) Then Local File SINVOICED [SID] : Endif
        Filter [F:SID] Where NUM=[M:PIV1]VCRNUMSEL
        #Lignes Facture No <n° facture>
        TIT = mess(7,105,1) - mess(55,198,1) - mess(3,132,1) - [M:PIV1]VCRNUMSEL
        For [F:SID]
          I += 1
          TEX(I) = num$([F:SID]SIDLIN)
          TEXTE(I,1) = num$([F:SID]SIDLIN)
          TEXTE(I,2) = [F:SID]ITMREF
        Next
        Filter [F:SID]
      When NUM_SIV
        If !clalev([F:SID]) Then Local File SINVOICED [SID] : Endif
        Filter [F:SID] Where NUM=[M:PIV1]VCRNUMSEL
        #Lignes Avoir No <n° avoir>
        TIT = mess(7,105,1) - mess(2,267,1) - mess(3,132,1) - [M:PIV1]VCRNUMSEL
        For [F:SID]
          I += 1
          TEX(I) = num$([F:SID]SIDLIN)
          TEXTE(I,1) = num$([F:SID]SIDLIN)
          TEXTE(I,2) = [F:SID]ITMREF
        Next
        Filter [F:SID]
      When NUM_SOC
        If !clalev([F:SOC]) Then Local File SORDERC [SOC] : Endif
        Filter [F:SOC] Where SOHNUM=[M:PIV1]VCRNUMSEL
        #Lignes Commande No <n° commande>
        TIT = mess(7,105,1) - mess(10,159,1) - mess(3,132,1) - [M:PIV1]VCRNUMSEL
        For [F:SOC]
          I += 1
          TEX(I) = num$([F:SOC]SOPLIN)
          TEXTE(I,1) = num$([F:SOC]SOPLIN)
          TEXTE(I,2) = [F:SOC]ITMREF
        Next
        Filter [F:SOC]
      When NUM_SOH
        If !clalev([F:SOQ]) Then Local File SORDERQ [SOQ] : Endif
        Filter [F:SOQ] Where SOHNUM=[M:PIV1]VCRNUMSEL
        #Lignes Commande No <n° commande>
        TIT = mess(7,105,1) - mess(10,159,1) - mess(3,132,1) - [M:PIV1]VCRNUMSEL
        Local Char SOQ_F(GLONSOH+GLONITM+1)(1..rowcount([F:SOQ]))
        For [F:SOQ]
          If [F:SOQ]SOPLIN > 0 and !find(num$([F:SOQ]SOPLIN) + "~" + [F:SOQ]ITMREF, SOQ_F) Then
            I += 1
            SOQ_F(I) = num$([F:SOQ]SOPLIN) + "~" + [F:SOQ]ITMREF
            TEX(I) = num$([F:SOQ]SOPLIN)
            TEXTE(I,1) = num$([F:SOQ]SOPLIN)
            TEXTE(I,2) = [F:SOQ]ITMREF
          Endif
        Next
        Filter [F:SOQ]
      When NUM_PRH
        If !clalev([F:PRE]) Then Local File STOPRED   [PRE] : Endif
        Filter [F:PRE] Where PRHNUM=[M:PIV1]VCRNUMSEL
        #Lignes Bon prépa No <n° bon>
        TIT = mess(7,105,1) - mess(5,477,1) - mess(3,132,1) - [M:PIV1]VCRNUMSEL
        For [F:PRE]
          I += 1
          TEX(I) = num$([F:PRE]PRELIN)
          TEXTE(I,1) = num$([F:PRE]PRELIN)
          TEXTE(I,2) = [F:PRE]ITMREF
        Next
        Filter [F:PRE]
      When NUM_DUD, NUM_DUDA
        # FGR 13/01/2012 : X3SUIVI71278
        If !clalev([F:DUD]) Then Local File GACCDUDATE [DUD] : Endif
        Filter [F:DUD] Where NUMDUD=[M:PIV1]VCRNUMSEL
        #Lignes Bon prépa No <n° bon>
        TIT = mess(7,105,1) - mess(12,477,1) - mess(3,132,1) - [M:PIV1]VCRNUMSEL
        For [F:DUD]
          I += 1
          TEX(I) = num$([F:DUD]LIG)
          TEXTE(I,1) = num$([F:DUD]LIG)
          TEXTE(I,2) = [F:DUD]NUM
        Next
        Filter [F:DUD]
      When NUM_PYH
        # FGR 13/01/2012 : X3SUIVI71278
        If !clalev([F:PYD]) Then Local File PAYMENTD [PYD] : Endif
        Filter [F:PYD] Where NUM=[M:PIV1]VCRNUMSEL
        #Lignes Bon prépa No <n° bon>
        TIT = mess(7,105,1) - mess(13,477,1) - mess(3,132,1) - [M:PIV1]VCRNUMSEL
        For [F:PYD]
          I += 1
          TEX(I) = num$([F:PYD]LIN)     # Issue X3-55167 - 2017-09-14 by FHA : Bug Fixed
          TEXTE(I,1) = num$([F:PYD]LIN) # Issue X3-55167 - 2017-09-14 by FHA : Bug Fixed
          TEXTE(I,2) = [F:PYD]NUM
        Next
        Filter [F:PYD]
      When NUM_REL
        # FGR 13/01/2012 : X3SUIVI71278
        If !clalev([F:PYD]) Then Local File PAYMENTD  [PYD] : Endif
        Filter [F:PYD] Where NUM=[M:PIV1]VCRNUMSEL
        #Lignes Bon prépa No <n° bon>
        TIT = mess(7,105,1) - mess(13,477,1) - mess(3,132,1) - [M:PIV1]VCRNUMSEL
        For [F:PYD]
          I += 1
          TEX(I) = num$([F:PYD]LIN)     # Issue X3-55167 - 2017-09-14 by FHA : Bug Fixed
          TEXTE(I,1) = num$([F:PYD]LIN) # Issue X3-55167 - 2017-09-14 by FHA : Bug Fixed
          TEXTE(I,2) = [F:PYD]NUM
        Next
        Filter [F:PYD]
      When NUM_TSK
        # FGR 13/01/2012 : X3SUIVI71278 : Il n'y a rien ici pour les tâches
      When NUM_CLL
        # FGR 13/01/2012 : X3SUIVI71278 : Il n'y a rien ici pour les appels
      When NUM_BAP
        # FGR 13/01/2012 : X3SUIVI71278 : Il n'y a rien ici pour les rendez-vous
      When NUM_CON
        # FGR 13/01/2012 : X3SUIVI71278 : Il n'y a rien ici pour les contrats de service
      When NUM_MAC
        # FGR 13/01/2012 : X3SUIVI71278 : Il n'y a rien ici pour les parcs client
      When NUM_SRE
        # FGR 13/01/2012 : X3SUIVI71278 : Il n'y a rien ici pour les demandes de service
      When NUM_ITN
        # FGR 13/01/2012 : X3SUIVI71278 : Il n'y a rien ici pour les interventions
      When NUM_SOL
        # FGR 13/01/2012 : X3SUIVI71278 : Il n'y a rien ici pour les solutions
      # --------------------------------------------
      # FGR 08/02/2012 : X3SUIVI71269
      When NUM_PIH, NUM_PIHC
        If !clalev([F:PID]) Then Local File PINVOICED  [PID] : Endif
        Filter [F:PID] Where NUM=[M:PIV1]VCRNUMSEL and (INVTYP=1 or INVTYP=5)
        #Lignes Facture No <n° facture>
        TIT = mess(7,105,1) - mess(55,198,1) - mess(3,132,1) - [M:PIV1]VCRNUMSEL
        For [F:PID]
          I += 1
          TEX(I) = num$([F:PID]PIDLIN)
          TEXTE(I,1) = num$([F:PID]PIDLIN)
          TEXTE(I,2) = [F:PID]ITMREF
        Next
        Filter [F:PID]
      When NUM_PIV
        If !clalev([F:PID]) Then Local File PINVOICED  [PID] : Endif
        Filter [F:PID] Where NUM=[M:PIV1]VCRNUMSEL and INVTYP=2
        #Lignes Avoir No <n° avoir>
        TIT = mess(7,105,1) - mess(2,267,1) - mess(3,132,1) - [M:PIV1]VCRNUMSEL
        For [F:PID]
          I += 1
          TEX(I) = num$([F:PID]PIDLIN)
          TEXTE(I,1) = num$([F:PID]PIDLIN)
          TEXTE(I,2) = [F:PID]ITMREF
        Next
        Filter [F:PID]
      When NUM_PNH
        If !clalev([F:PND]) Then Local File PRETURND  [PND] : Endif
        Filter [F:PND] Where PNHNUM=[M:PIV1]VCRNUMSEL
        #Lignes Retour No <n° retour>
        TIT = mess(7,105,1) - mess(144,124,1) - mess(3,132,1) - [M:PIV1]VCRNUMSEL
        For [F:PND]
          I += 1
          TEX(I) = num$([F:PND]PNDLIN)
          TEXTE(I,1) = num$([F:PND]PNDLIN)
          TEXTE(I,2) = [F:PND]ITMREF
        Next
        Filter [F:PND]
      When NUM_PTH
        If !clalev([F:PTD]) Then Local File PRECEIPTD  [PTD] : Endif
        Filter [F:PTD] Where PTHNUM=[M:PIV1]VCRNUMSEL
        #Lignes Réception No <n° réception>
        TIT = mess(7,105,1) - mess(34,172,1) - [M:PIV1]VCRNUMSEL
        For [F:PTD]
          I += 1
          TEX(I) = num$([F:PTD]PTDLIN)
          TEXTE(I,1) = num$([F:PTD]PTDLIN)
          TEXTE(I,2) = [F:PTD]ITMREF
        Next
        Filter [F:PTD]
      When NUM_POC
        If !clalev([F:POC]) Then Local File PORDERC [POC] : Endif
        Filter [F:POC] Where POHNUM=[M:PIV1]VCRNUMSEL
        #Lignes Commande No <n° commande>
        TIT = mess(7,105,1) - mess(10,159,1) - mess(3,132,1) - [M:PIV1]VCRNUMSEL
        For [F:POC]
          I += 1
          TEX(I) = num$([F:POC]POPLIN)
          TEXTE(I,1) = num$([F:POC]POPLIN)
          TEXTE(I,2) = [F:POC]ITMREF
        Next
        Filter [F:POC]
      When NUM_POH
        If !clalev([F:POQ]) Then Local File PORDERQ    [POQ] : Endif
        Filter [F:POQ] Where POHNUM=[M:PIV1]VCRNUMSEL
        #Lignes Commande No <n° commande>
        TIT = mess(7,105,1) - mess(10,159,1) - mess(3,132,1) - [M:PIV1]VCRNUMSEL
        For [F:POQ]
          I += 1
          TEX(I) = num$([F:POQ]POPLIN)
          TEXTE(I,1) = num$([F:POQ]POPLIN)
          TEXTE(I,2) = [F:POQ]ITMREF
        Next
        Filter [F:POQ]
      When NUM_PSH
        If !clalev([F:PSD]) Then Local File PREQUISD   [PSD] : Endif
        Filter [F:PSD] Where PSHNUM=[M:PIV1]VCRNUMSEL
        #Lignes Demande No <n° demande>
        TIT = mess(7,105,1) - mess(153,154,1) - [M:PIV1]VCRNUMSEL
        For [F:PSD]
          I += 1
          TEX(I) = num$([F:PSD]PSDLIN)
          TEXTE(I,1) = num$([F:PSD]PSDLIN)
          TEXTE(I,2) = [F:PSD]ITMREF
        Next
        Filter [F:PSD]
      When NUM_PQH
        If !clalev([F:PQD]) Then Local File PQUOTATD   [PQD] : Endif
        Filter [F:PQD] Where PQHNUM=[M:PIV1]VCRNUMSEL
        #Lignes Appel d'offre No <n° appel>
        TIT = mess(7,105,1) - mess(1,535,1) - mess(3,132,1) - [M:PIV1]VCRNUMSEL
        For [F:PQD]
          I += 1
          TEX(I) = num$([F:PQD]PQDLIN)
          TEXTE(I,1) = num$([F:PQD]PQDLIN)
          TEXTE(I,2) = [F:PQD]ITMREF
        Next
        Filter [F:PQD]
      When NUM_SCO
        If !clalev([F:SCI]) Then Local File SCOITM  [SCI] : Endif
        Filter [F:SCI] Where SCONUM=[M:PIV1]VCRNUMSEL
        #Lignes Ordre sous-traitance No <n° ordre>
        TIT = mess(7,105,1) - mess(13,306,1) - [M:PIV1]VCRNUMSEL
        For [F:SCI]
          I += 1
          TEX(I) = num$([F:SCI]SCILIN)
          TEXTE(I,1) = num$([F:SCI]SCILIN)
          TEXTE(I,2) = [F:SCI]ITMREF
        Next
        Filter [F:SCI]
      # --------------------------------------------
      # FGR 10/10/2012 : X3SUIVI81498
      When NUM_LOF
        # Il n'y a rien ici pour les Dépenses
      When NUM_FAS
        # Il n'y a rien ici pour les Biens comptables
      # --------------------------------------------
      # FGR 24/10/2012 : X3SUIVI81498
      When NUM_BIS
        # Il n'y a rien ici pour les factures tiers fournisseur
      When NUM_CTRH
        # FGR 29/05/2015 : X3SUIVI104697 Il n'y a rien ici pour les containers
      When NUM_SHH
        # FGR 29/05/2015 : X3SUIVI104697 Il n'y a rien ici pour les expéditions
      When NUM_TRNP
        # FGR 29/05/2015 : X3SUIVI104697 Il n'y a rien ici pour les Transports
      When Default
    Endcase
    NBTEX = I
  Else
    FIN = 1
  Endif
Return

############################################################
Subprog AM_TRKSEL(VALEUR)
Variable Integer VALEUR

  [M:PIV1]FLG = 0
End

######################################################################################
Subprog D_TRKSEL(VALEUR)
Variable Integer VALEUR

  Chgtzn [M:PIV1]VCRSTA_L With ""
  Chgtzn [M:PIV1]VCRSTA_C With ""
  Chgtzn [M:PIV1]VCRSTA_S With ""
  Chgfmt [M:PIV1]VCRSTA_L With "-K:123X"
  Chgfmt [M:PIV1]VCRSTA_C With "-K:123X"
  Chgfmt [M:PIV1]VCRSTA_S With "-K:123X"
End

############################################################
Subprog GET_TXT_STA_FROM_NUM(INUM, STBTXT)
Value Integer INUM
Variable Char STBTXT()(0..)

  # FGR 13/01/2012 : X3SUIVI71278
  Raz STBTXT
  STBTXT(0) = " : "
  #STBTXT(0) = "/"
  Case INUM
    When NUM_SQH
      STBTXT(1) = mess(22,104,1) - mess(121,198,1)             # Etat devis
      STBTXT(2) = mess(71,75,1)                                # Signature
    When NUM_SDH
      STBTXT(1) = mess(251,200,1)                              # Etat retour
      STBTXT(2) = mess(218,200,1)                              # Etat facture
    When NUM_SIH
      STBTXT(1) = mess(218,200,1)                              # Etat facture
      STBTXT(2) = mess(655,197,1)                              # Catégorie     # FGR 31/08/2015 : X3SUIVI110665 (facture ou proforma)
    When NUM_SIV
      STBTXT(1) = mess(22,104,1) - mess(2,267,1)               # Etat avoir
    When NUM_SOH
      STBTXT(1) = mess(215,200,1)                              # Etat commande
      STBTXT(2) = mess(217,200,1)                              # Etat livraison
      STBTXT(3) = mess(218,200,1)                              # Etat facture
      STBTXT(4) = mess(71,75,1)                                # Signature
    When NUM_SOC
      STBTXT(1) = mess(391,194,1)                              # Date limite dépassée
      STBTXT(2) = mess(71,75,1)                                # Signature
    When NUM_PRH
      STBTXT(1) = mess(22,104,1) - mess(24,721,1)              # Etat bon préparation
    When NUM_SRH, NUM_HAE, NUM_PRL
      STBTXT(1) = ""
    When NUM_PJT
      STBTXT(1) = mess(1066,196,1)                             # Type
      STBTXT(2) = mess(1065,196,1)                             # Actif
    When NUM_DUD, NUM_DUDA
      STBTXT(1) = mess(56,105,1)                               # Relance
      STBTXT(2) = mess(57,105,1)                               # Bon à payer
    When NUM_PYH
      STBTXT(1) = mess(81,142,1)                               # Etat
    When NUM_REL
      STBTXT(1) = mess(11,107,1)                               # Pièce validée
    When NUM_TSK
      STBTXT(1) = mess(1061,196,1)                             # Effectué
    When NUM_CLL
      STBTXT(1) = mess(1061,196,1)                             # Action effectué
      STBTXT(2) = mess(1051,196,1)                             # Type d'appel
    When NUM_BAP
      STBTXT(1) = mess(1061,196,1)                             # Effectué
      STBTXT(2) = mess(81,183,1)                               # Lieu du rendez-vous
    When NUM_CON
      STBTXT(1) = mess(655,197,1)                              # Catégorie
      STBTXT(2) = mess(1052,196,1)                             # Toutes compétences
      STBTXT(3) = mess(1053,196,1)                             # Tout le parc
      STBTXT(4) = mess(1054,196,1)                             # Priorité au parc
    When NUM_MAC
      STBTXT(1) = mess(1056,196,1)                             # Type d'implantation
      STBTXT(2) = mess(1057,196,1)                             # Installé en prêt
      STBTXT(3) = mess(1058,196,1)                             # Numéro de série
    When NUM_SRE
      STBTXT(1) = mess(650,197,1)                              # Affectation
      STBTXT(2) = mess(117,196,1)                              # Couverture
      STBTXT(3) = mess(1059,196,1)                             # Gravité
    When NUM_ITN
      STBTXT(1) = mess(1061,196,1)                             # Effectué
      STBTXT(2) = mess(10,423,1)                               # Sous-traité
      STBTXT(3) = mess(655,197,1)                              # Catégorie
    When NUM_SOL
      STBTXT(1) = mess(655,197,1)                              # Catégorie
      STBTXT(2) = mess(1060,196,1)                             # Famille compétence
    # --------------------------------------------
    # FGR 08/02/2012 : X3SUIVI71269
    When NUM_PIH, NUM_PIHC
      STBTXT(1) = mess(218,200,1)                              # Etat facture
    When NUM_PIV
      STBTXT(1) = mess(22,104,1) - mess(2,267,1)               # Etat avoir
    When NUM_POH
      STBTXT(1) = mess(3,418,1)                                # Facturée
      STBTXT(2) = mess(71,075,1)                               # Signature
      STBTXT(3) = mess(3,363,1)                                # Soldée
      STBTXT(4) = mess(117,198,1)                              # Réception
    When NUM_POC
      STBTXT(1) = mess(3,418,1)                                # Facturée
      STBTXT(2) = mess(71,075,1)                               # Signature
      STBTXT(3) = mess(391,194,1)                              # Date limite dépassée
    When NUM_PSH
      STBTXT(1) = mess(3,363,1)                                # Soldée
      STBTXT(2) = mess(62,191,1)                               # Commandée
      STBTXT(3) = mess(71,075,1)                               # Signature
    When NUM_PQH
      STBTXT(1) = mess(391,194,1)                              # Date limite dépassée
    When NUM_PTH
      STBTXT(1) = mess(3,418,1)                                # Facturée
      STBTXT(2) = mess(191,107,1)                              # Comptabilisée
      # Issue 84972 - 2012-10-08 by SR
      STBTXT(3) = mess(3,363,1)                                # Soldée
    When NUM_PNH
      STBTXT(1) = mess(3,418,1)                                # Facturée
    When NUM_SCO
      STBTXT(1) = mess(18,173,1) - mess(69,151,1)              # Statut ordre
      STBTXT(2) = mess(348,194,1)                              # Situation article lancé
      STBTXT(3) = mess(18,173,1) - mess(56,198,1)              # Statut Allocation
    # --------------------------------------------
    # FGR 10/10/2012 : X3SUIVI81498
    When NUM_LOF
      STBTXT(1) = mess(67,200,1)                               # Type de facture
      STBTXT(2) = mess(1120,196,1)                             # Immobilisée
    When NUM_FAS
      STBTXT(1) = mess(17,2287,1)                              # Nature PCG
      STBTXT(2) = mess(358,7773,1)                             # Date de sortie
      STBTXT(3) = mess(1121,196,1)                             # Immobilisée
    # --------------------------------------------
    # FGR 24/10/2012 : X3SUIVI81498
    When NUM_BIS
      STBTXT(1) = mess(218,200,1)                              # Etat facture
    When NUM_CTRH
      # FGR 29/05/2015 : X3SUIVI104697
      STBTXT(1) = mess(517,194,1)                              # Plein
      STBTXT(2) = mess(514,194,1)                              # Numéro de plomb 1
    When NUM_SHH
      # FGR 29/05/2015 : X3SUIVI104697
      STBTXT(1) = mess(190,75,1)                               # Statut
      STBTXT(2) = mess(518,194,1)                              # Pays d'origine
      STBTXT(3) = mess(519,194,1)                              # Pays de destination
    When NUM_TRNP
      # FGR 29/05/2015 : X3SUIVI104697
      STBTXT(1) = mess(520,194,1)                              # Mode transport
      STBTXT(2) = mess(190,75,1)                               # Statut
      STBTXT(3) = mess(521,194,1)                              # Date départ
      STBTXT(4) = mess(522,194,1)                              # Date arrivée prévue
    When Default
  Endcase
End

############################################################
Subprog AFFICHE_STA(VALEUR)
Variable Integer VALEUR

Local Char STBVCRSTAT(GLONDCO)(0..4)          # FGR 20/01/2012 : X3SUIVI71278

  Call GET_TXT_STA_FROM_NUM(VALEUR, STBVCRSTAT)
  # -------------------------------------------
  Chgfmt [M:PIV1]VCRSTA   With "KP:123X"
  Chgtzn [M:PIV1]VCRSTA_L With ""
  Chgfmt [M:PIV1]VCRSTA_L With "-K:123X"
  Chgtzn [M:PIV1]VCRSTA_C With ""
  Chgfmt [M:PIV1]VCRSTA_C With "-K:123X"
  Chgtzn [M:PIV1]VCRSTA_S With ""
  Chgfmt [M:PIV1]VCRSTA_S With "-K:123X"
  # -------------------------------------------
  Case VALEUR
    When NUM_SQH
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
      Chgtzn [M:PIV1]VCRSTA_S With STBVCRSTAT(2)
      Chgfmt [M:PIV1]VCRSTA_S With "KP:123X"
    When NUM_SDH
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
      Chgtzn [M:PIV1]VCRSTA_L With STBVCRSTAT(2)
      Chgfmt [M:PIV1]VCRSTA_L With "KP:123X"
    When NUM_SIH
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
      Chgtzn [M:PIV1]VCRSTA_L With STBVCRSTAT(2)           # FGR 31/08/2015 : X3SUIVI110665
      Chgfmt [M:PIV1]VCRSTA_L With "KP:123X"               # FGR 31/08/2015 : X3SUIVI110665
    When NUM_SIV
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
    When NUM_SOH
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
      Chgtzn [M:PIV1]VCRSTA_L With STBVCRSTAT(2)
      Chgfmt [M:PIV1]VCRSTA_L With "KP:123X"
      Chgtzn [M:PIV1]VCRSTA_C With STBVCRSTAT(3)
      Chgfmt [M:PIV1]VCRSTA_C With "KP:123X"
      Chgtzn [M:PIV1]VCRSTA_S With STBVCRSTAT(4)
      Chgfmt [M:PIV1]VCRSTA_S With "KP:123X"
    When NUM_SOC
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
      Chgtzn [M:PIV1]VCRSTA_S With STBVCRSTAT(2)
      Chgfmt [M:PIV1]VCRSTA_S With "KP:123X"
    When NUM_PRH
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
    When NUM_SRH, NUM_HAE, NUM_PRL, NUM_PJT
      Chgtzn [M:PIV1]VCRSTA With STBVCRSTAT(1)
      Chgfmt [M:PIV1]VCRSTA With "-K:123X"
    When NUM_DUD, NUM_DUDA
      # FGR 13/01/2012 : X3SUIVI71278
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
      Chgtzn [M:PIV1]VCRSTA_S With STBVCRSTAT(2)
      Chgfmt [M:PIV1]VCRSTA_S With "KP:123X"
    When NUM_PYH
      # FGR 13/01/2012 : X3SUIVI71278
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
    When NUM_REL
      # FGR 13/01/2012 : X3SUIVI71278
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
    When NUM_TSK
      # FGR 13/01/2012 : X3SUIVI71278
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
    When NUM_CLL
      # FGR 13/01/2012 ! X3SUIVI71278
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
      Chgtzn [M:PIV1]VCRSTA_S With STBVCRSTAT(2)
      Chgfmt [M:PIV1]VCRSTA_S With "KP:123X"
    When NUM_BAP
      # FGR 13/01/2012 : X3SUIVI71278
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
      Chgtzn [M:PIV1]VCRSTA_S With STBVCRSTAT(2)
      Chgfmt [M:PIV1]VCRSTA_S With "KP:123X"
    When NUM_CON
      # FGR 13/01/2012 : X3SUIVI71278
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
      Chgtzn [M:PIV1]VCRSTA_S With STBVCRSTAT(2)
      Chgfmt [M:PIV1]VCRSTA_S With "KP:123X"
      Chgtzn [M:PIV1]VCRSTA_C With STBVCRSTAT(3)
      Chgfmt [M:PIV1]VCRSTA_C With "KP:123X"
      Chgtzn [M:PIV1]VCRSTA_L With STBVCRSTAT(4)
      Chgfmt [M:PIV1]VCRSTA_L With "KP:123X"
    When NUM_MAC
      # FGR 13/01/2012 : X3SUIVI71278
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
      Chgtzn [M:PIV1]VCRSTA_S With STBVCRSTAT(2)
      Chgfmt [M:PIV1]VCRSTA_S With "KP:123X"
      Chgtzn [M:PIV1]VCRSTA_C With STBVCRSTAT(3)
      Chgfmt [M:PIV1]VCRSTA_C With "KP:123X"
    When NUM_SRE
      # FGR 13/01/2012 : X3SUIVI71278
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
      Chgtzn [M:PIV1]VCRSTA_S With STBVCRSTAT(2)
      Chgfmt [M:PIV1]VCRSTA_S With "KP:123X"
      Chgtzn [M:PIV1]VCRSTA_C With STBVCRSTAT(3)
      Chgfmt [M:PIV1]VCRSTA_C With "KP:123X"
    When NUM_ITN
      # FGR 13/01/2012 : X3SUIVI71278
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
      Chgtzn [M:PIV1]VCRSTA_S With STBVCRSTAT(2)
      Chgfmt [M:PIV1]VCRSTA_S With "KP:123X"
      Chgtzn [M:PIV1]VCRSTA_C With STBVCRSTAT(3)
      Chgfmt [M:PIV1]VCRSTA_C With "KP:123X"
    When NUM_SOL
      # FGR 13/01/2012 : X3SUIVI71278
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
      Chgtzn [M:PIV1]VCRSTA_S With STBVCRSTAT(2)
      Chgfmt [M:PIV1]VCRSTA_S With "KP:123X"
    # --------------------------------------------
    # FGR 08/02/2012 : X3SUIVI71269
    When NUM_PIH, NUM_PIHC
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
    When NUM_PIV
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
    When NUM_POH
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
      Chgtzn [M:PIV1]VCRSTA_D With STBVCRSTAT(2)
      Chgfmt [M:PIV1]VCRSTA_D With "KP:123X"
      Chgtzn [M:PIV1]VCRSTA_S With STBVCRSTAT(3)
      Chgfmt [M:PIV1]VCRSTA_S With "KP:123X"
      Chgtzn [M:PIV1]VCRSTA_R With STBVCRSTAT(4)
      Chgfmt [M:PIV1]VCRSTA_R With "KP:123X"
    When NUM_POC
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
      Chgtzn [M:PIV1]VCRSTA_D With STBVCRSTAT(2)
      Chgfmt [M:PIV1]VCRSTA_D With "KP:123X"
      Chgtzn [M:PIV1]VCRSTA_S With STBVCRSTAT(3)
      Chgfmt [M:PIV1]VCRSTA_S With "KP:123X"
    When NUM_PSH
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
      Chgtzn [M:PIV1]VCRSTA_D With STBVCRSTAT(2)
      Chgfmt [M:PIV1]VCRSTA_D With "KP:123X"
      Chgtzn [M:PIV1]VCRSTA_S With STBVCRSTAT(3)
      Chgfmt [M:PIV1]VCRSTA_S With "KP:123X"
    When NUM_PQH
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
    When NUM_PTH
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
      Chgtzn [M:PIV1]VCRSTA_D With STBVCRSTAT(2)
      Chgfmt [M:PIV1]VCRSTA_D With "KP:123X"
      # Issue 84972 - 2012-10-08 by SR
      Chgtzn [M:PIV1]VCRSTA_S With STBVCRSTAT(3)
      Chgfmt [M:PIV1]VCRSTA_S With "KP:123X"
    When NUM_PNH
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
    When NUM_SCO
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
      Chgtzn [M:PIV1]VCRSTA_D With STBVCRSTAT(2)
      Chgfmt [M:PIV1]VCRSTA_D With "KP:123X"
      Chgtzn [M:PIV1]VCRSTA_S With STBVCRSTAT(1)
      Chgfmt [M:PIV1]VCRSTA_S With "KP:123X"
    # --------------------------------------------
    # FGR 10/10/2012 : X3SUIVI81498
    When NUM_LOF
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
      Chgtzn [M:PIV1]VCRSTA_S With STBVCRSTAT(2)
      Chgfmt [M:PIV1]VCRSTA_S With "KP:123X"
    When NUM_FAS
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
      Chgtzn [M:PIV1]VCRSTA_L With STBVCRSTAT(2)
      Chgfmt [M:PIV1]VCRSTA_L With "KP:123X"
      Chgtzn [M:PIV1]VCRSTA_C With STBVCRSTAT(3)
      Chgfmt [M:PIV1]VCRSTA_C With "KP:123X"
    # FGR 24/10/2012 : X3SUIVI81498
    When NUM_BIS
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
    When NUM_CTRH
      # FGR 29/05/2015 : X3SUIVI104697
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
      Chgtzn [M:PIV1]VCRSTA_S With STBVCRSTAT(2)
      Chgfmt [M:PIV1]VCRSTA_S With "KP:123X"
      Chgtzn [M:PIV1]VCRSTA_C With STBVCRSTAT(3)
      Chgfmt [M:PIV1]VCRSTA_C With "KP:123X"
      Chgtzn [M:PIV1]VCRSTA_L With STBVCRSTAT(4)
      Chgfmt [M:PIV1]VCRSTA_L With "KP:123X"
    When NUM_SHH
      # FGR 29/05/2015 : X3SUIVI104697
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
      Chgtzn [M:PIV1]VCRSTA_S With STBVCRSTAT(2)
      Chgfmt [M:PIV1]VCRSTA_S With "KP:123X"
      Chgtzn [M:PIV1]VCRSTA_C With STBVCRSTAT(3)
      Chgfmt [M:PIV1]VCRSTA_C With "KP:123X"
      Chgtzn [M:PIV1]VCRSTA_L With STBVCRSTAT(4)
      Chgfmt [M:PIV1]VCRSTA_L With "KP:123X"
    When NUM_TRNP
      # FGR 29/05/2015 : X3SUIVI104697
      Chgtzn [M:PIV1]VCRSTA   With STBVCRSTAT(1)
      Chgtzn [M:PIV1]VCRSTA_S With STBVCRSTAT(2)
      Chgfmt [M:PIV1]VCRSTA_S With "KP:123X"
      Chgtzn [M:PIV1]VCRSTA_C With STBVCRSTAT(3)
      Chgfmt [M:PIV1]VCRSTA_C With "KP:123X"
      Chgtzn [M:PIV1]VCRSTA_L With STBVCRSTAT(4)
      Chgfmt [M:PIV1]VCRSTA_L With "KP:123X"
    When Default
  Endcase
  Affzo [M:PIV1]
End

######################################################################################
Subprog AS_VCRTYPSEL(VALEUR)
Variable Integer VALEUR

Local Integer NI

  # Jamais de tunnel
  GMENLOC(NUM_HAE) = 1
  GMENLOC(NUM_PJT) = 1
  GMENLOC(NUM_DUD) = 1        # FGR 13/01/2012 : X3SUIVI71278
  GMENLOC(NUM_DUDA) = 1       # FGR 13/01/2012 : X3SUIVI71278
  # FGR 08/02/2012 : X3SUIVI71269
  Case GACTION
    When "CONSPIV"
      # Module "Achats"
      GMENLOC(NUM_PIH) = 1
      GMENLOC(NUM_PIV) = 1
      GMENLOC(NUM_PNH) = 1
      GMENLOC(NUM_PTH) = 1
      GMENLOC(NUM_POC) = 1
      GMENLOC(NUM_POH) = 1
      GMENLOC(NUM_PSH) = 1
      GMENLOC(NUM_PQH) = 1
      GMENLOC(NUM_SCO) = 1
      GMENLOC(NUM_PIHC)= 1
      GMENLOC(NUM_CTRH)= 1             # FGR 29/05/2015 : X3SUIVI104697
      GMENLOC(NUM_SHH) = 1             # FGR 29/05/2015 : X3SUIVI104697
      GMENLOC(NUM_TRNP)= 1             # FGR 29/05/2015 : X3SUIVI104697
      # Module "Support client"
      GMENLOC(NUM_CON) = 1
      GMENLOC(NUM_MAC) = 1
      GMENLOC(NUM_SRE) = 1
      GMENLOC(NUM_ITN) = 1
      GMENLOC(NUM_SOL) = 1
      # Module "Action commerciale"
      GMENLOC(NUM_CLL) = 1
      GMENLOC(NUM_BAP) = 1
      GMENLOC(NUM_TSK) = 1
      # Module "Immobilisations"
      GMENLOC(NUM_LOF) = 1             # FGR 10/10/2012 : X3SUIVI81498
      GMENLOC(NUM_FAS) = 1             # FGR 10/10/2012 : X3SUIVI81498
    When "CONSPIA"
      # Module "Vente"
      GMENLOC(NUM_SIH) = 1
      GMENLOC(NUM_SIV) = 1
      GMENLOC(NUM_SRH) = 1
      GMENLOC(NUM_SDH) = 1
      GMENLOC(NUM_PRH) = 1
      GMENLOC(NUM_PRL) = 1
      GMENLOC(NUM_SOC) = 1
      GMENLOC(NUM_SOH) = 1
      GMENLOC(NUM_SQH) = 1
      # Module "Tiers"
      GMENLOC(NUM_REL) = 1
      # Module "Support client"
      GMENLOC(NUM_CON) = 1
      GMENLOC(NUM_MAC) = 1
      GMENLOC(NUM_SRE) = 1
      GMENLOC(NUM_ITN) = 1
      GMENLOC(NUM_SOL) = 1
      # Module "Action commerciale"
      GMENLOC(NUM_CLL) = 1
      GMENLOC(NUM_BAP) = 1
      GMENLOC(NUM_TSK) = 1
      # Module "Immobilisations"
      GMENLOC(NUM_LOF) = 1             # FGR 10/10/2012 : X3SUIVI81498
      GMENLOC(NUM_FAS) = 1             # FGR 10/10/2012 : X3SUIVI81498
    When "CONSPIC"
      If GMODU(12) <> G_OUI Then
        # Module "Support client"
        GMENLOC(NUM_CON) = 1
        GMENLOC(NUM_MAC) = 1
        GMENLOC(NUM_SRE) = 1
        GMENLOC(NUM_ITN) = 1
        GMENLOC(NUM_SOL) = 1
      Endif
      # Module "Achats"
      GMENLOC(NUM_PIH) = 1
      GMENLOC(NUM_PIV) = 1
      GMENLOC(NUM_PNH) = 1
      GMENLOC(NUM_PTH) = 1
      GMENLOC(NUM_POC) = 1
      GMENLOC(NUM_POH) = 1
      GMENLOC(NUM_PSH) = 1
      GMENLOC(NUM_PQH) = 1
      GMENLOC(NUM_SCO) = 1
      GMENLOC(NUM_PIHC)= 1
      GMENLOC(NUM_CTRH)= 1             # FGR 29/05/2015 : X3SUIVI104697
      GMENLOC(NUM_SHH) = 1             # FGR 29/05/2015 : X3SUIVI104697
      GMENLOC(NUM_TRNP)= 1             # FGR 29/05/2015 : X3SUIVI104697
      # Module "Vente"
      GMENLOC(NUM_SIH) = 1
      GMENLOC(NUM_SIV) = 1
      GMENLOC(NUM_SRH) = 1
      GMENLOC(NUM_SDH) = 1
      GMENLOC(NUM_PRH) = 1
      GMENLOC(NUM_PRL) = 1
      GMENLOC(NUM_SOC) = 1
      GMENLOC(NUM_SOH) = 1
      GMENLOC(NUM_SQH) = 1
      # Module "Tiers"
      GMENLOC(NUM_PYH) = 1
      GMENLOC(NUM_REL) = 1
      GMENLOC(NUM_BIS) = 1             # FGR 24/10/2012 : X3SUIVI81498
      # Module "Immobilisations"
      GMENLOC(NUM_LOF) = 1             # FGR 10/10/2012 : X3SUIVI81498
      GMENLOC(NUM_FAS) = 1             # FGR 10/10/2012 : X3SUIVI81498
    When "CONSPIH"                     # FGR 15/12/2014 : X3SUIVI104792
      If GMODU(13) <> G_OUI Then
        # Module "Action commerciale"
        GMENLOC(NUM_CLL) = 1
        GMENLOC(NUM_BAP) = 1
        GMENLOC(NUM_TSK) = 1
      Endif
      # Module "Achats"
      GMENLOC(NUM_PIH) = 1
      GMENLOC(NUM_PIV) = 1
      GMENLOC(NUM_PNH) = 1
      GMENLOC(NUM_PTH) = 1
      GMENLOC(NUM_POC) = 1
      GMENLOC(NUM_POH) = 1
      GMENLOC(NUM_PSH) = 1
      GMENLOC(NUM_PQH) = 1
      GMENLOC(NUM_SCO) = 1
      GMENLOC(NUM_PIHC)= 1
      GMENLOC(NUM_CTRH)= 1             # FGR 29/05/2015 : X3SUIVI104697
      GMENLOC(NUM_SHH) = 1             # FGR 29/05/2015 : X3SUIVI104697
      GMENLOC(NUM_TRNP)= 1             # FGR 29/05/2015 : X3SUIVI104697
      # Module "Vente"
      GMENLOC(NUM_SIH) = 1
      GMENLOC(NUM_SIV) = 1
      GMENLOC(NUM_SRH) = 1
      GMENLOC(NUM_SDH) = 1
      GMENLOC(NUM_PRH) = 1
      GMENLOC(NUM_PRL) = 1
      GMENLOC(NUM_SOC) = 1
      GMENLOC(NUM_SOH) = 1
      GMENLOC(NUM_SQH) = 1
      # Module "Tiers"
      GMENLOC(NUM_PYH) = 1
      GMENLOC(NUM_REL) = 1
      GMENLOC(NUM_BIS) = 1
      # Module "Immobilisations"
      GMENLOC(NUM_LOF) = 1
      GMENLOC(NUM_FAS) = 1
    When "CONSPIT"
      # Module "Support client"
      GMENLOC(NUM_CON) = 1
      GMENLOC(NUM_MAC) = 1
      GMENLOC(NUM_SRE) = 1
      GMENLOC(NUM_ITN) = 1
      GMENLOC(NUM_SOL) = 1
      # Module "Action commerciale"
      GMENLOC(NUM_CLL) = 1
      GMENLOC(NUM_BAP) = 1
      GMENLOC(NUM_TSK) = 1
      # Module "Vente"
      GMENLOC(NUM_SIH) = 1
      GMENLOC(NUM_SIV) = 1
      GMENLOC(NUM_SRH) = 1
      GMENLOC(NUM_SDH) = 1
      GMENLOC(NUM_PRH) = 1
      GMENLOC(NUM_PRL) = 1
      GMENLOC(NUM_SOC) = 1
      GMENLOC(NUM_SOH) = 1
      GMENLOC(NUM_SQH) = 1
      # Module "Achats"
      GMENLOC(NUM_PIH) = 1
      GMENLOC(NUM_PIV) = 1
      GMENLOC(NUM_PNH) = 1
      GMENLOC(NUM_PTH) = 1
      GMENLOC(NUM_POC) = 1
      GMENLOC(NUM_POH) = 1
      GMENLOC(NUM_PSH) = 1
      GMENLOC(NUM_PQH) = 1
      GMENLOC(NUM_SCO) = 1
      GMENLOC(NUM_PIHC)= 1
      GMENLOC(NUM_CTRH)= 1             # FGR 29/05/2015 : X3SUIVI104697
      GMENLOC(NUM_SHH) = 1             # FGR 29/05/2015 : X3SUIVI104697
      GMENLOC(NUM_TRNP)= 1             # FGR 29/05/2015 : X3SUIVI104697
      # Module "Immobilisations"
      GMENLOC(NUM_LOF) = 1             # FGR 10/10/2012 : X3SUIVI81498
      GMENLOC(NUM_FAS) = 1             # FGR 10/10/2012 : X3SUIVI81498
    When "CONSPIF"
      # FGR 10/10/2012 : X3SUIVI81498
      # Module "Vente"
      GMENLOC(NUM_SIH) = 1
      GMENLOC(NUM_SIV) = 1
      GMENLOC(NUM_SRH) = 1
      GMENLOC(NUM_SDH) = 1
      GMENLOC(NUM_PRH) = 1
      GMENLOC(NUM_PRL) = 1
      GMENLOC(NUM_SOC) = 1
      GMENLOC(NUM_SOH) = 1
      GMENLOC(NUM_SQH) = 1
      # Module "Tiers"
      GMENLOC(NUM_PYH) = 1
      GMENLOC(NUM_REL) = 1
      GMENLOC(NUM_BIS) = 1             # FGR 24/10/2012 : X3SUIVI81498
      # Module "Support client"
      GMENLOC(NUM_CON) = 1
      GMENLOC(NUM_MAC) = 1
      GMENLOC(NUM_SRE) = 1
      GMENLOC(NUM_ITN) = 1
      GMENLOC(NUM_SOL) = 1
      # Module "Action commerciale"
      GMENLOC(NUM_CLL) = 1
      GMENLOC(NUM_BAP) = 1
      GMENLOC(NUM_TSK) = 1
      # Module "Achats"
      GMENLOC(NUM_PIH) = 1
      GMENLOC(NUM_PIV) = 1
      GMENLOC(NUM_PNH) = 1
      GMENLOC(NUM_PTH) = 1
      GMENLOC(NUM_POC) = 1
      GMENLOC(NUM_POH) = 1
      GMENLOC(NUM_PSH) = 1
      GMENLOC(NUM_PQH) = 1
      GMENLOC(NUM_SCO) = 1
      GMENLOC(NUM_PIHC)= 1
      GMENLOC(NUM_CTRH)= 1             # FGR 29/05/2015 : X3SUIVI104697
      GMENLOC(NUM_SHH) = 1             # FGR 29/05/2015 : X3SUIVI104697
      GMENLOC(NUM_TRNP)= 1             # FGR 29/05/2015 : X3SUIVI104697
    When Default
  Endcase
  If GMODU(13) <> G_OUI Then
    # Module "Action commerciale"
    GMENLOC(NUM_CLL) = 1
    GMENLOC(NUM_BAP) = 1
    GMENLOC(NUM_TSK) = 1
  Endif
  If GMODU(3) <> G_OUI Then
    # Module "Tiers"
    GMENLOC(NUM_PYH) = 1
    GMENLOC(NUM_REL) = 1
    GMENLOC(NUM_BIS) = 1             # FGR 24/10/2012 : X3SUIVI81498
  Endif
  # ---- Pour positionner sur la première valeur disponible
  If VALEUR = 0 Then
    Case GACTION
      When "CONSPIH"
        VALEUR = NUM_CON                 # FGR 22/12/2014 : X3SUIVI104792 : cas particulier parce que s'il y a TSK c'est lui qui vient en premier
      When Default
        For NI = 1 To len(mess(0,477,1))
          If GMENLOC(NI) <> 1 Then
            VALEUR = NI
            Break
          Endif
        Next NI
    Endcase
  Endif
End

############################################################
Subprog AM_VCRTYPSEL(VALEUR)
Variable Integer VALEUR

  # FGR 20/01/2012 : X3SUIVI71278 (début)
  #NUM_DUD, NUM_PYH, NUM_REL, NUM_DUDA, NUM_TSK, NUM_CLL, NUM_BAP, NUM_CON, NUM_MAC, NUM_SRE, NUM_ITN, NUM_SOL, NUM_FAS, NUM_BIS # FGR 10/10/2012 : X3SUIVI81498 ajout NUM_FAS
  Case VALEUR
    When NUM_DUD, NUM_PYH, NUM_REL, NUM_DUDA, NUM_TSK, NUM_CLL, NUM_BAP, NUM_CON, NUM_MAC, NUM_SRE, NUM_ITN, NUM_SOL, NUM_FAS, NUM_BIS, NUM_CTRH, NUM_SHH, NUM_TRNP # FGR 29/05/2015 : X3SUIVI104697
      Chgfmt [M:PIV1]VCRLINSEL With "-Nz:8#"
    When Default
      Chgfmt [M:PIV1]VCRLINSEL With "Nz:8#"
  Endcase
  # FGR 20/01/2012 : X3SUIVI71278 (fin)
  [M:PIV1]FLG = 0
  [M:PIV1]VCRNUMSEL = ""
  [M:PIV1]VCRLINSEL = 0
  [M:PIV1]VCRCTL    = 0
  # FQ55971 - MABON 29/06/09 - Faire apparaître le statut de la pièce
  [M:PIV1]VCRSTA    = ""
  [M:PIV1]VCRSTA_L  = ""
  [M:PIV1]VCRSTA_C  = ""
  [M:PIV1]VCRSTA_S  = ""
  Call AFFICHE_STA(VALEUR)
End

############################################################
Subprog C_VCRNUMSEL(VALEUR)
Variable Char    VALEUR()

  [M:PIV1]VCRCTL = 1
  VALEUR = toupper(VALEUR)
  Case [M:PIV1]VCRTYPSEL
    When NUM_SQH
      If !clalev([F:SQH]) Then Local File SQUOTE    [SQH] : Endif
      Read [F:SQH]SQH0=VALEUR
      If fstat Then
        mkstat = 2
        [M:PIV1]VCRCTL = 0
        GMESSAGE = mess(261,197,1)  # Pièce inexistante
      Else
        # FGR 26/01/2012 : X3SUIVI71278
        GFCY = [F:SQH]SALFCY
      Endif
    When NUM_SDH
      If !clalev([F:SDH]) Then Local File SDELIVERY [SDH] : Endif
      Read [F:SDH]SDH0=VALEUR
      If fstat Then
        mkstat = 2
        [M:PIV1]VCRCTL = 0
        GMESSAGE = mess(261,197,1)  # Pièce inexistante
      Else
        # FGR 26/01/2012 : X3SUIVI71278
        GFCY = [F:SDH]SALFCY
      Endif
    When NUM_SRH
