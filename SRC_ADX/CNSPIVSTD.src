############################################################
Subprog FIND_TREE_AMONT_CRM(SORIADI, SORIVCR, SORIVCRL, INIV, WLEV, GCOMMIT)
Value Char SORIADI
Value Char SORIVCR
Value Integer SORIVCRL
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char CLLNUM_F(GLONVCR)
Local Char BAPNUM_F(GLONVCR)
Local Char TSKNUM_F(GLONVCR)
Local Char SQH_F(GLONSQH)
Local Char SOH_F(GLONSOH)
Local Char SDH_F(GLONSDH)
Local Char SIH_F(GLONSIH)
Local Char SIV_F(GLONSIH)
Local Char SRH_F(GLONSRH)
Local Char MAC_F(GLONVCR)
Local Char PIH_F(GLONVCR)
Local Char PIV_F(GLONVCR)
Local Char PNH_F(GLONVCR)
Local Char POC_F(GLONVCR)
Local Char POH_F(GLONVCR)
Local Char PQH_F(GLONVCR)
Local Char SCO_F(GLONVCR)

  Case SORIADI
    When "CRM1"
      # Appels
      Read [CLL]CLL0=SORIVCR
      CLLNUM_F = [F:CLL]CLLNUM
      Gosub WRITE_PKW1_CLL From CNSPIV2STD
    When "CRM2"
      # Rendez-vous
      Read [BAP]APP0=SORIVCR
      BAPNUM_F = [F:BAP]APTNUM
      Gosub WRITE_PKW1_BAP From CNSPIV2STD
    When "CRM3"
      # Tâches
      Read [TSK]TSK0=SORIVCR
      TSKNUM_F = [F:TSK]TSKNUM
      Gosub WRITE_PKW1_TSK From CNSPIV2STD
    When "SAL1"
      # Devis
      Read [SQH]SQH0=SORIVCR
      SQH_F = [F:SQH]SQHNUM
      Gosub WRITE_PKW1_SQH From CNSPIV2STD
    When "SAL2"
      # Commande
      Read [SOH]SOH0=SORIVCR
      SOH_F = [F:SOH]SOHNUM
      Gosub WRITE_PKW1_SOH From CNSPIV2STD
    When "SAL3"
      # Livraison
      Read [SDH]SDH0=SORIVCR
      SDH_F = [F:SDH]SDHNUM
      Gosub WRITE_PKW1_SDH From CNSPIV2STD
    When "SAL4"
      # Facture/avoir
      Read [SIH]SIH0=SORIVCR
      If [F:SIH]INVTYP = 1 or [F:SIH]INVTYP = 5 Then
        # Facture
        SIH_F = [F:SIH]NUM
        Gosub WRITE_PKW1_SIH From CNSPIV2STD
      Elsif [F:SIV]INVTYP = 2 Then
        # Avoir
        SIV_F = [F:SIH]NUM
        Gosub WRITE_PKW1_SIV From CNSPIV2STD
      Endif
    When "SAL5"
      # Commande ouverte
      Read [SOC]SOC0=SORIVCR
      SOH_F = [F:SOC]SOHNUM
      Gosub WRITE_PKW1_SOC From CNSPIV2STD
    When "SAL7"
      # Retour livraison
      Read [SRH]SRH0=SORIVCR
      SRH_F = [F:SRH]SRHNUM
      Gosub WRITE_PKW1_SRH From CNSPIV2STD
    # --------------------------------------------
    When "HDK3"
      # Contrat de service
      Read [CON]CON0=SORIVCR
      SRH_F = [F:CON]CONNUM
      Gosub WRITE_PKW1_CON From CNSPIV2STD
    When "HDK4"
      # Parc client
      Read [MAC]MAC0=SORIVCR
      MAC_F = [F:MAC]MACNUM
      Gosub WRITE_PKW1_MAC From CNSPIV2STD
    When "HDK1"
      # Demande de service
      Read [SRE]SRE0=SORIVCR
      MAC_F = [F:SRE]SRENUM
      Gosub WRITE_PKW1_SRE From CNSPIV2STD
    When "HDK2"
      # Demande de service
      Read [ITN]ITN0=SORIVCR
      MAC_F = [F:ITN]NUM
      Gosub WRITE_PKW1_ITN From CNSPIV2STD
    # --------------------------------------------
    When "PUR3"
      # Facture/Facture complémentaire/Avoir
      Read [PIH]PIH0=SORIVCR
      If [F:PIH]PIHTYP = 1 Then
        # Facture
        SIH_F = [F:PIH]NUM
        Gosub WRITE_PKW1_PIH From CNSPIA2STD
      Elsif [F:PIH]PIHTYP = 2 Then
        # Facture
        # FLORENT ICI quand j'aurais les factures complémentaires
        PIH_F = [F:PIH]NUM
        Gosub WRITE_PKW1_PIH From CNSPIA2STD
      Else
        # Avoir
        PIV_F = [F:PIH]NUM
        Gosub WRITE_PKW1_PIV From CNSPIA2STD
      Endif
    When "PUR2"
      # Retour fournisseur
      Read [PNH]PNH0=SORIVCR
      PNH_F = [F:PNH]PNHNUM
      Gosub WRITE_PKW1_PNH From CNSPIA2STD
    When "PUR5"
      # Commande ouverte
      Read [POC]POC0=SORIVCR
      POC_F = [F:POC]POHNUM
      Gosub WRITE_PKW1_POC From CNSPIA2STD
    When "PUR1"
      # Commande
      Read [POH]POH0=SORIVCR
      POH_F = [F:POH]POHNUM
      Gosub WRITE_PKW1_POH From CNSPIA2STD
    When "PUR4"
      # Appel d'offre
      Read [PQH]PQH0=SORIVCR
      PQH_F = [F:PQH]PQHNUM
      Gosub WRITE_PKW1_PQH From CNSPIA2STD
    When "PUR7"
      # Sous-traitance
      Read [SCO]SOC0=SORIVCR
      SCO_F = [F:SCO]SCONUM
      Gosub WRITE_PKW1_SCO From CNSPIA2STD
    When Default
  Endcase
  WK = 1
End

