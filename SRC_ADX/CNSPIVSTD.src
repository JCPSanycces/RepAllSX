#<AdxTL>@(#)4.0.0.0 $Revision$
############################################################
# Issue X3-86804 - 2018-10-10 by MDJ : Expenses - Error message in the "Journal traceability" CONSPIF
#
$ACTION
  Case GACTION
    When "CONSPIV", "CONSPIC", "CONSPIH", "CONSPIT", "CONSPIA", "CONSPIF"        # FGR 15/12/2014 : X3SUIVI104792
      Case ACTION
        When "AUTORIS"    : Gosub AUTORIS From CONSPITOOLS
        When "FERME"      : Gosub FERME   From CONSPITOOLS
        When "OUVRE"      : Gosub OUVRE
        When "LECTURE"    : Gosub LECTURE
        When "SETBOUT"    : Gosub SETBOUT
        When "EXEBOUT"    : Gosub EXEBOUT From CONSPITOOLS
        When "DEB_CRIT"   : [M:CSTK] = [M:PIV1]
        When "FIN_CRIT"   : Gosub FIN_CRIT
        When "AV_MAGNETO" : Gosub AV_MAGNETO
        When "AP_MAGNETO" : Gosub AP_MAGNETO
        When "CLECUR"     : Gosub CLECUR
        When Default
      Endcase
    # -------------
    When "SELPIV"
      Case ACTION
        When "SEL_TABLE"  : Gosub SEL_TABLE
        When "FIN_TABLE"  : Gosub FIN_TABLE   # Issue X3-86804
      Endcase
    # -------------
    When "SELLINV"
      Case ACTION
        When "SEL_LISTE"  : Gosub SEL_LISTE
      Endcase
    # -------------
    When "VISUPIV"
      Case ACTION
        When "DEBUT"      : Gosub OUVRE_VISU
      Endcase
  Endcase
Return
############################################################
