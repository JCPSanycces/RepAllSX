Local Char CONNUM_F(GLONVCR)

  If GMODU(12) = G_NON Then
    # Module "Support client"
    End
  Endif
  If !clalev([F:CON]) Then Local File CONTSERV [CON] : Endif
  # ---------------------
  Filter [CON] Where [F:CON]CONORI = SORIML and [F:CON]CONORIVCR = SORIVCR
  If rowcount([F:CON]) > 0 Then
    For [F:CON]
      CONNUM_F = [F:CON]CONNUM
      Gosub WRITE_PKW1_CON From CNSPIV2STD
      WK = 1
    Next
  Endif
  Filter [CON]
  # ---------------------
End

############################################################
Subprog FIND_MAC_AVAL_FROM(SORIML, SORIVCR, IORIVCRL, INIV, WLEV, GCOMMIT)
Value Integer SORIML
Value Char SORIVCR
Value Integer IORIVCRL
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char MACNUM_F(GLONVCR)

  If GMODU(12) = G_NON Then
    # Module "Support client"
    End
  Endif
  If !clalev([F:MAC]) Then Local File MACHINES [MAC] : Endif
  # ---------------------
  # FGR 10/12/2012 : X3SUIVI86461 : tester IORIVCRL
  If IORIVCRL = 0 Then
    Filter [MAC] Where [F:MAC]MACORI = SORIML and [F:MAC]MACORIVCR = SORIVCR
  Else
    Filter [MAC] Where [F:MAC]MACORI = SORIML and [F:MAC]MACORIVCR = SORIVCR and [F:MAC]MACORIVCRL = IORIVCRL
  Endif
  If rowcount([F:MAC]) > 0 Then
    For [F:MAC]
      MACNUM_F = [F:MAC]MACNUM
      Gosub WRITE_PKW1_MAC From CNSPIV2STD
      WK = 1
    Next
  Endif
  Filter [MAC]
  # ---------------------
End

############################################################
Subprog FIND_TREE_AMONT_HDK(SORIML, SORIVCR, SORIVCRL, INIV, WLEV, GCOMMIT)
Value Integer SORIML
Value Char SORIVCR
Value Integer SORIVCRL
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char SOH_F(GLONSOH)
Local Char SDH_F(GLONSDH)
Local Char SIH_F(GLONSIH)
Local Char SIV_F(GLONSIH)

  If GMODU(12) = G_NON Then
    # Module "Support client"
    End
  Endif
  Case SORIML
    When 2
      # Commande
      Read [SOH]SOH0=SORIVCR
      SOH_F = [F:SOH]SOHNUM
      Gosub WRITE_PKW1_SOH From CNSPIV2STD
    When 3
      # Livraison
      Read [SDH]SDH0=SORIVCR
      SDH_F = [F:SDH]SDHNUM
      Gosub WRITE_PKW1_SDH From CNSPIV2STD
    When 4
      # Facture/avoir (avoir improbable)
      Read [SIH]SIH0=SORIVCR
      If [F:SIH]INVTYP = 1 or [F:SIH]INVTYP = 5 Then
        # Facture
        SIH_F = [F:SIH]NUM
        Gosub WRITE_PKW1_SIH From CNSPIV2STD
      Elsif [F:SIV]INVTYP = 2 Then
        # Avoir
        SIV_F = [F:SIH]NUM
        Gosub WRITE_PKW1_SIV From CNSPIV2STD
      Endif
    When Default
  Endcase
  WK = 1
End

#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI="X3" End Endif
  If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
  Read [ADS]DOSSIER=APPLI
  If !fstat & [F:ADS]MODULE(4)<>2 End Endif
  Call VALGTC(APPLI,"PIV") From SUBGTC
End

