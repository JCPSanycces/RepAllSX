#<AdxTL>@(#)0.0.0.0 $Revision$ 
#Contains all functions for ESS ( HRM - Employee self servicce
#**
#* Pass the ABLOB Content type and convert to AOBJTXT type
#* @param ATTCOD Value Char, Char array containing fields in the key of the main table
#* @return MAPPEDCOD Local Char - Default "PTL"
#*!

Funprog MAP_CONTENTYPE_ATT(ATTCOD)
Value Char ATTCOD
Local Char MAPPEDCOD(GLONADI)

#Do the mapping first and then use result to query misc table 902

Case ATTCOD
  When "AQCWORD"        : MAPPEDCOD = "DOC"
  When "ATYPE0"         : MAPPEDCOD = "PTL"
  When "ATYPE1"         : MAPPEDCOD = "PTL"
  When "ATYPE10"        : MAPPEDCOD = "TXT"
  When "ATYPE10-1"      : MAPPEDCOD = "TXT"
  When "ATYPE10-2"      : MAPPEDCOD = "TXT"
  When "ATYPE10-3"      : MAPPEDCOD = "RTF"
  When "ATYPE11"        : MAPPEDCOD = "PTL"
  When "ATYPE12"        : MAPPEDCOD = "PTL"
  When "ATYPE2"         : MAPPEDCOD = "PTL"
  When "ATYPE3"         : MAPPEDCOD = "PTL"
  When "ATYPE4"         : MAPPEDCOD = "PTL"
  When "ATYPE5"         : MAPPEDCOD = "PTL"
  When "ATYPE6"         : MAPPEDCOD = "PTL"
  When "ATYPE7"         : MAPPEDCOD = "PTL"
  When "ATYPE7-2"       : MAPPEDCOD = "PTL"
  When "ATYPE8"         : MAPPEDCOD = "PTL"
  When "ATYPE9"         : MAPPEDCOD = "DOC"
  When "ATYPE9-1"       : MAPPEDCOD = "PIC"
  When "CGM"            : MAPPEDCOD = "PIC"
  When "DOC"            : MAPPEDCOD = "DOC"
  When "OFFICEDOC"      : MAPPEDCOD = "DOC"
  When "OFFICEXLS"      : MAPPEDCOD = "DOC"
  When "PDF"            : MAPPEDCOD = "PDF"
  When "PPT"            : MAPPEDCOD = "PTL"
  When "XLS"            : MAPPEDCOD = "DOC"
  When Default          : MAPPEDCOD = "PTL"
Endcase

End MAPPEDCOD

$SOA_ATTACHMENTS_DCG
#Always save files from V6 - Even if HRESS not active
Local Integer NN, ATT_STAT, WRITE_STAT
If !clalev([AOX7])    : Local File AOBJTXT  [AOX7] : Endif
If !clalev([DCG6])    : Local File DEMCONGE [DCG6] : Endif
Filter [F:AOX7]

Trbegin [DCG6]

For NN = 0 To [M:DCG1]NBLIG-1
  #There can be multiple attachments per line
  Filter [F:AOX7] Where ABREV = "EML" and IDENT1 = "DCG"+"~"+num$([M:DCG1]REFNUM)+"~"+num$([M:DCG1]DEM(NN)) and IDENT2 = num$([M:DCG1]UID(NN))and IDENT3 = "001"
  For [AOX7]
    #Get the TYPDOC - Images and RTF text already managed
    #Store the file
    Call STORE_FILE_SOA("DCG",[M:DCG1]REFNUM,[M:DCG1]DEM(NN),[M:DCG1]UID(NN),[F:AOX7]IDENT3,WRITE_STAT) From PRHPORATT_SOA
    If WRITE_STAT = 2 : Break 2 : Endif
    #Store DEMCONGE ID Fields
    Read[F:DCG6]DCG3 = [M:DCG1]REFNUM;[M:DCG1]UID(NN)
    If !fstat
      # Re-write
      [F:DCG6]IDENT1 = [F:AOX7]IDENT1
      [F:DCG6]IDENT2 = [F:AOX7]IDENT2
      [F:DCG6]IDENT3 = [F:AOX7]IDENT3
      Rewrite [F:DCG6]
      If fstat
        WRITE_STAT = 2
      Else
        WRITE_STAT = 1
        #Check if file was deleted
#        ATT_STAT = func PRHPORATT_SOA.FILTER_AOX("DCG",[M:DCG1]REFNUM,[M:DCG1]DEM(NN),[M:DCG1]UID(NN),"001")
#        If ATT_STAT = 0
#          If !clalev([ABB8]) : Local File ABLOB [ABB8] : Endif
#          Read [F:ABB8]ABB0 = "EML";[F:AOX7]IDENT1;[F:AOX7]IDENT2;[F:AOX7]IDENT3
#          If !fstat
#            Delete [F:ABB8]
#            If fstat
#              WRITE_STAT = 2
#            Endif
#          Endif
#        Endif
      Endif
    Endif
    If WRITE_STAT = 2 : Break 2 : Endif
  Next
Next

If WRITE_STAT = 1
  Commit
Else
  Rollback
Endif
Return

$MOVE_ATTACHMENTS_DCG

If !clalev([AOX4])    : Local File AOBJTXT  [AOX4]   : Endif
If !clalev([AOX5])    : Local File AOBJTXT  [AOX5]   : Endif
If !clalev([ABB8])    : Local File ABLOB    [ABB8]  : Endif
If !clalev([ABB9])    : Local File ABLOB    [ABB9] : Endif

Local Integer PRV_UID   : PRV_UID = [F:DCG]UID
Local Char IDEN_1(255) : IDEN_1 = "DCG~"+num$([M:DCG1]REFNUM)+"~"+num$([M:DCG1]DEM(nolign-1))
Local Char IDEN_2(255) : IDEN_2 = num$(PRV_UID) : #PRV_UID - old records UID
Local Char IDEN_3(255) : IDEN_3 = "001"
Local Integer UPD_OK   : UPD_OK = 2

Read [AOX4]AOX0 = "EML";IDEN_1;IDEN_2;IDEN_3
If !fstat : #else - assumed no attachments
  [F:AOX5]       = [F:AOX4]
  [F:AOX5]IDENT2 = num$([F:DCG]UID)
  Write [F:AOX5]
  If fstat
    UPD_OK = 1
  Endif

  If UPD_OK = 2
    Read [ABB8]ABB0 = "PJ_EML";IDEN_1;IDEN_2;IDEN_3
    If !fstat
      Raz [F:ABB9]
      [F:ABB9]       = [F:ABB8]
      [F:ABB9]IDENT2 = num$([F:DCG]UID)

      If UPD_OK = 2
        Write [F:ABB9]
        If fstat
          UPD_OK = 1
        Endif
      Endif

      If UPD_OK = 2
        Delete [F:ABB8]
        If fstat
          UPD_OK = 1
        Endif
      Endif
    Endif

    If UPD_OK = 2
      Delete [F:AOX4]
      If fstat
        UPD_OK = 1
      Endif
    Endif
  Endif
Endif

If UPD_OK = 1
  [V]GOK=0
Endif

If clalev([AOX4])   : Close File [AOX4]   : Endif
If clalev([AOX5])   : Close File [AOX5]   : Endif
If clalev([ABB8])   : Close File [ABB8]   : Endif
If clalev([ABB9])   : Close File [ABB9]   : Endif

Return



#**
#* Get the description of a property code
#* @param PROPCODE Value Char, Class property code
#* @param CLSCODE Value Char, Class Code
#* @param VLEG Value Char, Legislation
#* @return FIELDDESC Local Char - Property description
#*!
Funprog GET_CLASS_PROP_DESC(PROPCODE,TABLECODE,VLEG)
Value Char PROPCODE,TABLECODE,VLEG
Local Char FIELDDESC(GLONATX)

Call LECTEXTRA(FIELDDESC,"ATABZON","NOCOURT","EMPLOID","REFNUM") From ATEXTRA
End FIELDDESC

$UPDATE_HRESSATT
Local Integer WRITESTAT, READSTAT, COLIND, I
Local Char CNTTYP(GLONATYP)

#Set default values for variables
WRITESTAT = [V]CST_AOK
READSTAT  = [V]CST_AOK




#Loop through ESSATT collection
#Check for existing record
For COLIND = 1 To  maxtab(this.ESSATT)
  If find(this.ESSATT(COLIND).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
    #Instantiate the class
    Local Instance I_HRESSATT Using C_HRESSATT
    If (I_HRESSATT <> null) : FreeGroup I_HRESSATT : Endif
    I_HRESSATT = NewInstance C_HRESSATT AllocGroup null

    READSTAT = I_HRESSATT.AREAD(this.ESSATT(COLIND).ABREV,this.ESSATT(COLIND).IDENT1,this.ESSATT(COLIND).IDENT2,this.ESSATT(COLIND).IDENT3)
    #Load values = READSTAT will only be used to determine the method to invoke    If READSTAT = [V]CST_AOK
    #Load the fields and save the class/record
    I_HRESSATT.ABREV      = ""#this.ESSATT(COLIND).XXXX
    I_HRESSATT.IDENT1     = ""
    I_HRESSATT.IDENT2     = ""
    I_HRESSATT.IDENT3     = ""
    I_HRESSATT.TCH_ATT    = ""

    If READSTAT = [V]CST_AOK
      #Existing record
      #Invoke the update method
      WRITESTAT = I_HRESSATT.AUPDATE
    Else
      #Invoke the insert method
      WRITESTAT = I_HRESSATT.AINSERT
    Endif

  Endif
  FreeGroup I_HRESSATT
  #Call code to get CNTTYP
  Gosub GET_CNTTYP
Next I

Return


$GET_CNTTYP

  #Success - Get the content type
  Local File ABLOB [ABB1]
  Read [ABB1]ABB0 = I_HRESSATT.ABREV;I_HRESSATT.IDENT1;I_HRESSATT.IDENT2;I_HRESSATT.IDENT3
  If fstat = [V]CST_AOK
    CNTTYP = [F:ABB1]CNTTYP
  Endif

Return

Funprog DEL_ESS_PAYSLIP(VABREV,VEMP,VCTRNUM,VBUL,VEXT)
Value Char VEMP,VCTRNUM,VBUL,VEXT,VABREV
Local Char FILT(250)
If !clalev([F:ESBL3]) : Local File ESSEMLBLB  [ESBL3] : Endif

#Build where string
#MIPEA - 2018-05-08 -X3-90512- START
FILT="CODBLB='"+VABREV+"' and IDENT1='"+VBUL+"."+VEXT+"'"
#FILT="CODBLB='"+VABREV+"' and IDENT1='"+VEMP+"~"+VCTRNUM+"~"+VBUL+"."+VEXT+"'"
#MIPEA - 2018-05-08 -X3-90512- END
Delete [F:ESBL3] Where evalue(FILT)

End fstat

Funprog DETESSEMP(ESWDUID)
Value Integer  ESWDUID
Local Char     LTEXT(250)(1..)
Local Char     SEP(10) : SEP=""
Local Char     W_TEMP(150),LIBCOD(30),TITEXS(80),SNSCOD(1)
Local Integer  IT

If clalev([F:ESWD1])=0 : Local File ESSWRKFLWDET  [ESWD1] : Endif

Filter [F:ESWD1] Where UID=[L]ESWDUID and MAIREC <> 2 # Only want detail and not combined main

Raz LTEXT : IT=1
For [F:ESWD1]
  LIBCOD="" : SNSCOD=""

  W_TEMP="-"-"Request"-num$([F:ESWD1]UID)-";"-mess(3,11,1)-format$(GFMD,[F:ESWD1]CREDATTIM)-";"-"Employee"-num$([F:ESWD1]REFNUM)-";"-"Field"-num$([F:ESWD1]FLDNAM)-";"-"Old value"-num$([F:ESWD1]OLDVAL)
& -";"-"New value"-num$([F:ESWD1]NEWVAL)
  If len(LTEXT(IT))+len(W_TEMP)>250 and IT<10 Then
    IT+=1
  Endif
  LTEXT(IT) += SEP+W_TEMP
  SEP=chr$(10)+chr$(13)
Next
Filter [F:ESWD1]

End LTEXT(1)-LTEXT(2)-LTEXT(3)-LTEXT(4)-LTEXT(5)-LTEXT(6)-LTEXT(7)-LTEXT(8)-LTEXT(9)-LTEXT(10)

Funprog DETESSEMPHEA(ESWDUID)
Value Integer  ESWDUID
Local Char     LTEXT(250)(1..)
Local Char     SEP(10) : SEP=""
Local Char     W_TEMP(150),LIBCOD(30),TITEXS(80),SNSCOD(1)
Local Integer  IT

If clalev([F:ESWD1])=0 : Local File ESSWRKFLWDET  [ESWD1] : Endif

Filter [F:ESWD1] Where UID=[L]ESWDUID and MAIREC = 2 # Only want detail and not combined main

Raz LTEXT : IT=1
For [F:ESWD1]
  LIBCOD="" : SNSCOD=""

  W_TEMP="-"-"Request"-num$([F:ESWD1]UID)-";"-mess(3,11,1)-format$(GFMD,[F:ESWD1]CREDATTIM)

  If len(LTEXT(IT))+len(W_TEMP)>250 and IT<10 Then
    IT+=1
  Endif
  LTEXT(IT) += SEP+W_TEMP
  SEP=chr$(10)+chr$(13)
Next
Filter [F:ESWD1]

End LTEXT(1)-LTEXT(2)-LTEXT(3)-LTEXT(4)-LTEXT(5)-LTEXT(6)-LTEXT(7)-LTEXT(8)-LTEXT(9)-LTEXT(10)

Funprog RECORD_STATUS(VFLDNAM)
Value Char VFLDNAM

Case VFLDNAM
  When "MAIN" : End mess(318,10726,1)   #Updated
  When "NEW"  : End mess(00416,00197,1)  #Created
  When "DEL"  : End mess(00175,197,1) #Deleted
Endcase
End

Funprog ESSGROUP(VTABLE)
Value Char VTABLE
Local Char GROUPING(30)
Case VTABLE
  When "EMPLOID"          : GROUPING = mess(0004,10727,1)
  When "EMPLOIDSA"        : GROUPING = mess(0005,10727,1)
  When "EMPLOCHD"         : GROUPING = mess(0006,10727,1)
  When "EMPLOIDRT"        : GROUPING = mess(0008,10727,1)
  When "EMPLOIDSART"      : GROUPING = mess(0005,10727,1)
  When "EMPLOIDSPAS"      : GROUPING = mess(0007,10727,1)
  When "EMPLOIDPAS"       : GROUPING = mess(0007,10727,1)
  When Default            : GROUPING = mess(0004,10727,1)
Endcase
  GROUPING = GROUPING-mess(0003,10727,1)
End GROUPING

Funprog GET_FLDDESC(VCODFIC,VCODZONE,VLAN)
Value Char VCODFIC,VCODZONE,VLAN
Local Char TEXTDESC(250)
Local File AREFTXT [ART1]
Local File ATEXTRA [AXX2]
Local File ATABZON [ATZ3]
Local File ATEXTE  [ATX2]

Filter [F:ATZ3] Where CODFIC = VCODFIC and CODZONE = VCODZONE
Read [F:ATZ3] First
If !fstat
  Filter [F:ART1] Where CLES = [F:ATZ3]CODFIC+"~"+num$([F:ATZ3]NUMLIG)+"~"+[F:ATZ3]CODZONE+"~"
  Read [F:ART1] First
  If !fstat
    Read [F:ATX2]NUMERO = VLAN;[F:ART1]TXTNUM
    If !fstat
      TEXTDESC = [F:ATX2]TEXTE
    Endif
  Endif
Endif

End TEXTDESC

#**
#* Get the icon code from the status value
#* @param CSTA Value integer, Values in LM 10743
#* @return ICONVAL Local Char - Icon dictionary value
#*!
Funprog SET_ICON(VSTA)
Value Integer VSTA
Local Char ICONVAL(3)

Case VSTA
When 1          : ICONVAL = "250"
When 2          : ICONVAL = "250"
When 3          : ICONVAL = "246"
When 4          : ICONVAL = "248"
When 5          : ICONVAL = "249"
When 6          : ICONVAL = "245"
When 7          : ICONVAL = "247"
When Default    : ICONVAL = "250"
Endcase

End ICONVAL

Funprog UPDATE_ESSURSTRK(VUSER,VABREV,VIDENT1,VIDENT2,VIDENT3,VFNC,VATTFLG,VREFNUM,VUID,VCTRNUM)
Value Char VUSER, VABREV,VIDENT1,VIDENT2,VIDENT3,VFNC,VREFNUM,VCTRNUM
Value Integer VATTFLG,VUID

#Local variables
Local Integer TRAN_PEND
Local Integer UPDATE_STAT

Local File ESSUSRTRK [ESUT]
[L]TRAN_PEND = adxlog


If ![L]TRAN_PEND
  Trbegin [F:ESUT]
Endif

Read [F:ESUT]ESUT0 = VUSER
If !fstat
  #re-write
  Gosub SET_ESSURSTRK_FIELDS
  Rewrite [F:ESUT]
  If fstat : [L]UPDATE_STAT = 1 : Endif
Else
  #write
  Raz [F:ESUT]
  [F:ESUT]USR = VUSER
  Gosub SET_ESSURSTRK_FIELDS
  Write [F:ESUT]
  If fstat : [L]UPDATE_STAT = 1 : Endif
Endif

If ![L]TRAN_PEND
  If ![L]UPDATE_STAT
    Commit
  Else
    Rollback
  Endif
Endif
End [L]UPDATE_STAT


$SET_ESSURSTRK_FIELDS

[F:ESUT]ABREV       = VABREV
[F:ESUT]IDENT1      = VIDENT1
[F:ESUT]IDENT2      = VIDENT2
[F:ESUT]IDENT3      = VIDENT3
[F:ESUT]FNC         = VFNC
[F:ESUT]ATTFLG      = VATTFLG
[F:ESUT]REFNUM      = VREFNUM
[F:ESUT]UID         = VUID
[F:ESUT]CTRNUM      = VCTRNUM



Return

Funprog DETDCGLIB(STA,NUM1,NUM2,DEM,VREFNUM)
Value Integer STA,NUM1,NUM2,DEM
Value Char    VREFNUM()
Local Char    LRET(250)
Local Char VNAM(40), VSRN(40)

Local File EMPLOID [ID2]

Read [F:ID2]ID0 = VREFNUM
If !fstat
  [L]VNAM = [F:ID2]NAM
  [L]VSRN = [F:ID2]SRN
Endif

  LRET=func AFNC.MES1(string$([L]STA<5,mess(NUM1,10726,1))+string$([L]STA>=5,mess(NUM2,10726,1)),num$([L]DEM))-[L]VREFNUM-[L]VNAM-[L]VSRN
End LRET

Funprog SETPORATT(VFNC,VABR,VID1,VBYTES,VPATH,VID2,VID3,VCNTTYPE)

Value Char VFNC             #Function
Value Char VABR             #Abreviation
Value Char VID1             #Identifier 1
Value Char VPATH            #Filename
Value Char VID2          #Identifier 2
Value Char VID3          #Identifier 3
Variable Blbfile  VBYTES()  #BLBFile
Value Char VCNTTYPE
Local Integer VSTAT
#Local declaration
Local Char DOCTYP(3)
Local Char NEWVOLUME(255)
Local Char DIRVOLA(250)
Local Char NEWVPATH(100)

VSTAT = [V]CST_AYES

Call PARAM("", "PORATTDCG", NEWVOLUME) From ADOVAL

#Renaming the filename
NEWVPATH=VABR+"_"+VID1+"_"+VID2+"_"+VID3

#Get the type of the document based on the file extension
DOCTYP = func ESS_FUNCTIONS.MAP_CONTENTYPE_ATT(VCNTTYPE)
If DOCTYP = "PIC" or DOCTYP = "RTF"
  Call STORE_FILE_STD(VABR,VID1,VID2,NEWVPATH,VID3,NEWVOLUME,DOCTYP,VSTAT)
End
Endif


If NEWVOLUME = "" : End [V]CST_ANO : Endif #Error handling

#Actual path of the volume
DIRVOLA = func AVOLUME_CSTD._GETFULLPATH(num$(NEWVOLUME),"")

#Opening and saving actual file for BYTE
Openo DIRVOLA+NEWVPATH+".pdf",0 Using [BIN1]
If fstat=0
  Putseq 1, VBYTES Using [BIN1]
  Openo Using [BIN1]
Else
  #Can handle error here
  End
Endif

#NEWVOLUME = "["+NEWVOLUME+"]\"
NEWVOLUME = "["+NEWVOLUME+"]/"


#After moving the file - the details must be stored in AOX table
Call STORE_FILE_STD(VABR,VID1,VID2,NEWVPATH,VID3,NEWVOLUME,DOCTYP,VSTAT)
#STAT Manage - Portal message?
 If VSTAT>0
  #Delete the file from NEWVOLUME
  #Leave delete option for now and return stat to rollback FRLAA 2017-09-11


   #If filinfo(NEWVOLUME+NEWVPATH,0)>=0
   If filinfo(DIRVOLA+NEWVPATH,0)>=0
    Call EFFACE(NEWVOLUME+NEWVPATH,VSTAT) From ORDSYS
     #Dont need to handle STAT - already in error handling procedure
   Endif
  #Goto AB_TR :  Return
 Endif
#Commit

End VSTAT


Subprog STORE_FILE_STD(PABR,PID1,PID2,VPATH,PID3,VNEWVOLUME,VTYPDOC,STAT)
Value Char PABR
Value Char PID1
Value Char PID2
Value Char VPATH
Value Char PID3
Value Char VNEWVOLUME
Value Char VTYPDOC
Variable Integer STAT : STAT = 0
Local Char FILT(250)
Local Char IDENT(250)
Local Integer ATTCAT : ATTCAT = 1  # ??Confidential??

#Opening different instance of AOX
If clalev([F:AOX2])=0 : Local File AOBJTXT [AOX2] : Endif

Gosub SET_VAR_DELETEFILE

#Trbegin [AOX2]

#Build where string
FILT="ABREV='"+PABR+"' and IDENT1='"+PID1+"' and IDENT2='"+PID2+"'" + " and IDENT3='"+PID3+"'"

#Read on filter - FILT
Filter [AOX2] Where evalue(FILT)
Read [AOX2]AOX0 First

If !fstat
   W_NAME=[F:AOX2]NAM
  [F:AOX2]NAM=VNEWVOLUME+VPATH
  [F:AOX2]TYPDOC=VTYPDOC
  [F:AOX2]IDENT3   = PID3
  Rewrite [F:AOX2]
  If W_NAME=[F:AOX2]NAM : W_NAME="" Endif
Else
 # save the name to delete after

 Raz [F:AOX2]
 [F:AOX2]ABREV    = PABR
 [F:AOX2]IDENT1   = PID1
 [F:AOX2]IDENT2   = PID2
 [F:AOX2]IDENT3   = PID3
 [F:AOX2]CAT      = ATTCAT
 [F:AOX2]NAM=VNEWVOLUME+VPATH
 [F:AOX2]TYPDOC=VTYPDOC
 Write [F:AOX2]
Endif
If fstat<>0
 STAT = 1
 W_NAME=""
 #Rollback
 End
Endif
#Commit
# replace an existing file, we delete the old file
If W_NAME<>""
  Gosub DELETE_FILE
Endif

End

$SET_VAR_DELETEFILE
Local Integer STAT
Local Char FILESRV(250),MESSAGE(250),W_NAME(250)

Return

$DELETE_FILE
If W_NAME<>""
  W_NAME=ctrans(W_NAME,"\","/")
  STAT=func ASYRSTO.CTL_VOLFIL(2,W_NAME,[L]FILESRV,0,MESSAGE)
  If !STAT
    Call EFFACE([L]FILESRV,STAT)From ORDSYS
  Endif
Endif

Return

Funprog WORKFLOWSTAT(VWRK)
Value Char VWRK
Local Integer WRKSTAT

Case VWRK
  When "C"  : WRKSTAT = 1
  When "M"  : WRKSTAT = 2
  When "D"  : WRKSTAT = 3

Endcase

End WRKSTAT

$DECLARE_EMPSTYLE
Local Integer STYLESTAT
Local Char WFILENAME(250)
Local Char WFIELDNAME(250)
Local Char WSTYLECODE(GLONASY)

Return

$CREATE_STYLE_SCRIPT_EMPDETAIL
Local Char RET_ACTCODE(GLONACV)(1..)
Local Char SEND_ACTCODE(GLONACV)(1..)
Local Char COMBINED_ACTCODE(GLONACV)(1..)
Local Integer ISFOUND()
Local Char MISCACT(5)
Local Char MISCLEG(GLONADI)
Local Char W_TIMESTAMP(20)



#get filename

  SCRISRC = filpath("TRT",WFILENAME,"src",nomap)

#open source file
  Openo SCRISRC,0
  adxifs = ""
  adxirs = chr$(10)

 Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
  Wrseq '# User :'-GUSER
  Wrseq '# timestamp :'-W_TIMESTAMP
  Wrseq ''
  Wrseq "Subprog STYLE_FIELDS"
  Wrseq ''
Return

$CREATE_STYLE_SCRIPT_EMPDETAIL_DETAIL

Wrseq "If dim("+WFIELDNAME+")>0 : Chgstl "+WFIELDNAME+ " With '"+WSTYLECODE+"' :  Endif"
Return

$CLOSE_SCRIPT_EMPDETAIL
#close file
Openo
If GOK<>0
  If dim(OK)<0 : Local Integer OK : Endif

  Call VALID("TRT",WFILENAME,nomap,OK) From VALMSKSUB
  If OK=0
  Else
    Call STYLE_FIELDS() From =WFILENAME
  Endif
Endif

Return

Funprog CODEVTDESC(VCODEVT)
Value Char VCODEVT
Local Char CODDESC

Case VCODEVT
  When "DCGMOD"     : CODDESC = mess(00003,10412,1)#Leave
  When "DCG"        : CODDESC = mess(00003,10412,1)#Leave
  When "HREXS"      : CODDESC = mess(00005,10853,1) #Expense note
  When "EXSMOD"     : CODDESC = mess(00005,10853,1) #Expense note
  When "ESWD"       : CODDESC = mess(00004,10727,1) #Personal
  When "ESWDOD"     : CODDESC = mess(00004,10727,1) #Personal
  When Default      : CODDESC = mess(00004,10727,1) #Personal
Endcase

End CODDESC

