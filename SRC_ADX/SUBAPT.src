#<AdxTL>@(#)5.0.0.0 $Revision$ Gestion du fichier APATCH
Call OBJET("APT",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "SETBOUT"  : Gosub SETBOUT
 When "LIENS"    : Gosub LIENS
Endcase

Return

###################################################################
############ actions standards ####################################
###################################################################
$OUVRE
Local Char WDOSX3(20)
Local File ADOVAL [ADW]
Read [ADW]ADW0 = "";"";"SUPDOS"
WDOSX3 = [F:ADW]VALEUR
If WDOSX3="" : WDOSX3 = "X3" : Endif
Return

$SETBOUT
If GADONIX<>2
 Call VIREBOUT(CHAINE,"CDMAH") From GOBJET
Endif
Return

#--------------------------------------------#
#--------------------------------------------#

$LIENS
#-------------------------------------------------------------------#
# on affiche le fichier contenant la description de la maintenance  #
# ce fichier doit etre dans le repertoire PATCH  du dossier de X3   #
#-------------------------------------------------------------------#

If [F]NUMP = 0 : Return : Endif
Local Char    WOS_ORD(GDIMFIC)(1..3)
Local Char    WMACHINE (GDIMFIC)
Local Char    WFICHIER (GDIMFIC)

Call MACHINE (filpath("","",""),WMACHINE,WFICHIER) From ORDSYS
Call GET_OS (WMACHINE,WOS_ORD) From ORDSYS

If WOS_ORD (1) = "unix" 
    #-- erreur sur le filinfo avec adxmac (-1) 
    #-- donc on prend toujours adxmac (0) 
    #-- ce n'est pas le cas pour NT 
    WMACHINE = adxmac (0)
Elsif adxmac(0)= ""
    WMACHINE  = adxmac(-1)
Else
    WMACHINE  = adxmac(0)
Endif

If dim([M]TEXRTF) >= 0
    If GLANGUE = "FRA" : WFICHIER="FRA"
    Else               : WFICHIER="ENG"
    Endif
    Case GPRODUIT
     When 1       : WFICHIER+="_XPG" : # GEODE GX
     When 2       : WFICHIER+="_XPP" : # Sage ADONIX RH
     When 3       : WFICHIER+="_XPA" : # ABELX3
     When Default : WFICHIER+="_XMT" : # X3, biens, loan ...
    Endcase
    WFICHIER += "_"+num$([F]NUMP)+"_140"
    If filinfo (filpath("PATCH",WFICHIER,"rtf",WDOSX3,"",WMACHINE),0) >= 0
     [M]TEXRTF =  filpath("PATCH",WFICHIER,"rtf",WDOSX3,"",WMACHINE) 
    Endif
Endif

Return

