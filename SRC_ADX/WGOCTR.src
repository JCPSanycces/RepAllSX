#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion de la fenêtre OCTR

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(14)
Local Integer A_RESULT
A_DATE  = [09/11/2018]
A_HEURE = "23:13:24"
A_USER  = "DOC"
Call ISWINVALID(nomap,GLANGUE,"OCTR",0,A_STAMP,A_RESULT,1) From INTRUTILB
Return

$NAVIGMSK
Local Char NAVMSK(200)
NAVMSK="CTR0;CTR1;CTR8;CTR2;CTR4;CTR7;CTR3;CTR5;CTR6;CTRPEN;CTR9;CTRA;CTRB;CTR12;"
Return

$OUVRE_BOITE
Gosub INIT_BOITE
Gosub DEF_BOITE
Gosub AFF_BOITE
Return

$INIT_BOITE
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(50)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 0
AFOLDEF = 1
ABRENA = ""
BOX1 = "GAU_CHE"
OBJLIS(0) = "CTR"
CHGLIS(0) = 2
BROLIS(0) = 2
TRELIS(0) = 1
DESLIS(0) = "REFNUM+CTRNUM+CTRDAT"
OBJLIS(1) = "CT0"
CHGLIS(1) = 2
BROLIS(1) = 2
TRELIS(1) = 2
DESLIS(1) = "REFNUM+CTRNUM+CTRDAT"
If clalev([M:CTR0])=0 : Local Mask CTR0 [CTR0] : Endif
If clalev([M:CTR1])=0 : Local Mask CTR1 [CTR1] : Endif
If clalev([M:CTR8])=0 : Local Mask CTR8 [CTR8] : Endif
If clalev([M:CTR2])=0 : Local Mask CTR2 [CTR2] : Endif
If clalev([M:CTR4])=0 : Local Mask CTR4 [CTR4] : Endif
If clalev([M:CTR7])=0 : Local Mask CTR7 [CTR7] : Endif
If clalev([M:CTR3])=0 : Local Mask CTR3 [CTR3] : Endif
If clalev([M:CTR5])=0 : Local Mask CTR5 [CTR5] : Endif
If clalev([M:CTR6])=0 : Local Mask CTR6 [CTR6] : Endif
If clalev([M:CTRPEN])=0 : Local Mask CTRPEN [CTRPEN] : Endif
If clalev([M:CTR9])=0 : Local Mask CTR9 [CTR9] : Endif
If clalev([M:CTRA])=0 : Local Mask CTR10 [CTRA] : Endif
If clalev([M:CTRB])=0 : Local Mask CTR11 [CTRB] : Endif
If clalev([M:CTR12])=0 : Local Mask CTR12 [CTR12] : Endif
Gosub TIT
nolign = 1
If clalev([F:AFF])=0 : Local File AFCTFCY  [AFF] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
If clalev([F:ID])=0 : Local file EMPLOID [ID] : Endif
If clalev([F:FCY])=0 : Local file FACILITY [FCY] : Endif
If clalev([F:CPY])=0 : Local file COMPANY [CPY] : Endif
If clalev([F:JOT])=0 : Local file JOBTYP [JOT] : Endif
If clalev([F:POT])=0 : Local file POSTE [POT] : Endif
If clalev([F:ACC])=0 : Local file ACCES [ACC] : Endif
If clalev([F:SRV])=0 : Local file SERVICE [SRV] : Endif
Link [HRCTR] With
& [AFF]AFF0~=[F:HRCTR]ETRFCY;GPROFIL;GUSRFCT,
& [FGR]FGR0=GGRPFCY;[F:HRCTR]ETRFCY,
& [ID]ID0=[F:HRCTR]REFNUM,
& [FCY]FCY0=[F:HRCTR]ETRFCY,
& [CPY]CPY0=[F:FCY]LEGCPY,
& [JOT]JOT0=[F:HRCTR]JOBPOT,
& [POT]POT0=[F:HRCTR]POT,
& [ACC]CODACC=GUSER;[F:ID]CODACS,
& [SRV]SRV0=[F:HRCTR]ETRSRV
& As [HRCTR_]
If clalev([F:HRCTR])=0 : Local file EMPLOCTR [HRCTR] : Endif
If clalev([F:ID])=0 : Local file EMPLOID [ID] : Endif
If clalev([F:ACC])=0 : Local file ACCES [ACC] : Endif
If clalev([F:FCY])=0 : Local file FACILITY [FCY] : Endif
Link [HRCTR] With
& [ID]ID0=[F:HRCTR]REFNUM,
& [ACC]CODACC=GUSER;[F:ID]CODACS,
& [FCY]FCY0=[F:HRCTR]ETRFCY
& As [CT1]
& Order By Key CTR0
Return

$DEF_BOITE
Gosub HORODAT From WGOCTR
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OCTR" From GFONCTION At A_STAMP With A_WINDPREV Mask [CTR0]
&   Folder Mask [CTR1]
& , Folder Mask [CTR8]
& , Folder Mask [CTR2]
& , Folder Mask [CTR4]
& , Folder Mask [CTR7]
& , Folder Mask [CTR3]
& , Folder Mask [CTR5]
& , Folder Mask [CTR6]
& , Folder Mask [CTRPEN]
& , Folder Mask [CTR9]
& , Folder Mask [CTRA]
& , Folder Mask [CTRB]
& , Folder Mask [CTR12]
&  Listbox [HRCTR_] GAU_CHE
&   [L]SAIRAP(1) = [F:HRCTR]REFNUM Using "K:15c" Titled TITSEL(1) ,
&   [L]SAIRAP(2) = [F:ID]NAM Using "K:40X" Titled TITSEL(2) ,
&   [L]SAIRAP(3) = [F:ID]SRN Using "K:40X" Titled TITSEL(3) ,
&   [L]SAIRAP(4) = [F:HRCTR]CTRNUM Using "K:20X" Titled TITSEL(4) ,
&   [L]SAIRAP(5) = [F:HRCTR]CTRDAT Using "DZz:"+GFMDAT4 Titled TITSEL(5) ,
&   [L]SAIRAP(6) = [F:HRCTR]XITDAT Using "DZz:"+GFMDAT Titled TITSEL(6) ,
&   [L]SAIRAP(7) = [F:FCY]LEGCPY Using "K:5c" Titled TITSEL(7) ,
&   [L]SAIRAP(8) = [F:HRCTR]ETRFCY Using "K:5c" Titled TITSEL(8) ,
&   [L]SAIRAP(9) = string$([F:CPY]LEG<>'',[F:CPY]LEG)+string$([F:CPY]LEG='',mess(91,187,1)) Using "K:10X" Titled TITSEL(9) ,
&   [L]SAIRAP(10) = [F:HRCTR]ETRSRV Using "K:5X" Titled TITSEL(10) ,
&   [L]SAIRAP(11) = [F:HRCTR]PROPRF Using "K:3X" Titled TITSEL(11) ,
&   [L]SAIRAP(12) = mess([F:HRCTR]XITFNL(0),1,1) Using "" Titled TITSEL(12) ,
&   [L]SAIRAP(13) = mess([F:HRCTR]FLGRET(0),1,1) Using "" Titled TITSEL(13) ,
&   [L]SAIRAP(14) = mess([F:HRCTR]FLGCREBUL(0),1,1) Using "" Titled TITSEL(14)
&  Treebox [CT1] GAU_CHE1
&   [F:HRCTR]REFNUM-[F:ID]NAM-[F:ID]SRN Using "" Titled TITSEL1(1) ,
&   [F:HRCTR]CTRNUM Using "K:20X" Titled TITSEL1(2) ,
&   format$("D:MM[/]DD[/]YYYY",CTRDAT)
&   Titled ""
& As [CTR1]
Titled [CTR1] TIT
Return

$VISU_BOITE
Gosub INIT_BOITE
Gosub HORODAT From WGOCTR
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OCTR" From GFONCTION At A_STAMP With A_WINDPREV Mask [CTR0]
&   Folder Mask [CTR1]
& , Folder Mask [CTR8]
& , Folder Mask [CTR2]
& , Folder Mask [CTR4]
& , Folder Mask [CTR7]
& , Folder Mask [CTR3]
& , Folder Mask [CTR5]
& , Folder Mask [CTR6]
& , Folder Mask [CTRPEN]
& , Folder Mask [CTR9]
& , Folder Mask [CTRA]
& , Folder Mask [CTRB]
& , Folder Mask [CTR12]
& As [CTR1]
Titled [CTR1] TIT
Gosub AFF_BOITE
Return

$AFF_BOITE
Boxact [CTR1] Folder AFOLDEF
Return

$SAISIE_BOITE
Boxinp [CTR1] Using REPONSE
Return

$FERME_BOITE
Onerrgo RIEN
Close Local Inpbox [CTR1]
Onerrgo
Return

$RIEN
Resume

$TIT
Local Char TITLIS(30)
Call TEXTE(5481,TITLIS) From OBJDIV
Local Char TITLIS1(30)
Call TEXTE(47955,TITLIS1) From OBJDIV
Local Char TITSEL(30)(1..14)
Call TEXTE(10793,TITSEL(1)) From OBJDIV
Call TEXTE(55,TITSEL(2)) From OBJDIV
Call TEXTE(1825,TITSEL(3)) From OBJDIV
Call TEXTE(5481,TITSEL(4)) From OBJDIV
Call TEXTE(212,TITSEL(5)) From OBJDIV
Call TEXTE(7830,TITSEL(6)) From OBJDIV
Call TEXTE(1343,TITSEL(7)) From OBJDIV
Call TEXTE(1344,TITSEL(8)) From OBJDIV
Call TEXTE(26213,TITSEL(9)) From OBJDIV
Call TEXTE(18735,TITSEL(10)) From OBJDIV
Call TEXTE(8750,TITSEL(11)) From OBJDIV
Call TEXTE(46631,TITSEL(12)) From OBJDIV
Call TEXTE(46403,TITSEL(13)) From OBJDIV
Call TEXTE(46778,TITSEL(14)) From OBJDIV
Local Char TITSEL1(30)(1..3)
Call TEXTE(10793,TITSEL1(1)) From OBJDIV
Call TEXTE(5481,TITSEL1(2)) From OBJDIV
Call TEXTE(212,TITSEL1(3)) From OBJDIV
Local Char TIT(60) , TITTRN(60)
Call TEXTE(45483,TIT) From OBJDIV
If GPROGRAMME<>""
 If dim([L]ACTION)<0 : Local Char ACTION(20) : Endif
 [L]ACTION = "TITRE" : Gosub ACTION From =GPROGRAMME
Endif
Return

$REMPLIT_
Gosub SETCLE_
If dim(FILTREG)<=0 or FILTREG
 If CRITERE=""  : CRITERE  = "1=1" : Endif
 If FILTSUP=""  : FILTSUP  = "1=1" : Endif
 If FILROLE=""  : FILROLE  = "1=1" : Endif
 If FILSUITE="" : FILSUITE = "1=1" : Endif
 Filter [HRCTR_] Where evalue(CRITERE) & evalue(FILTSUP) & evalue(FILROLE) & evalue(FILSUITE)
&       Order With CLELISTE
Endif
GPOINT = "AV_FILLBOX" : Gosub ENTREE From EXEFNC
ACTION = "HINT" : Gosub ACTION From =GPROGRAMME
If HINTLIS(0)<>'' or NOHLIS(0)<>0
 Fillbox [CTR1] GAU_CHE Hint Key =HINTLIS(0)
Else
 Gosub CALNOHOBJ From GOBJET
 If A_NOH
  Fillbox [CTR1] GAU_CHE
 Else
  Fillbox [CTR1] GAU_CHE Hint Key =""
 Endif
Endif
GPOINT = "AP_FILLBOX" : Gosub ENTREE From EXEFNC
Filter [HRCTR_]
Return

$REMPLIT_1
If dim(FILTREG)<=0 or FILTREG
 If CRITERE=""   : CRITERE   = "1=1" : Endif
 If FILGAUSUP="" : FILGAUSUP = "1=1" : Endif
 If FILSUITE=""  : FILSUITE  = "1=1" : Endif
 Filter [CT1] Where evalue(CRITERE) & evalue(FILGAUSUP) & evalue(FILSUITE)
&       Order By Key CTR0
Endif
GPOINT = "AV_FILLBOX" : Gosub ENTREE From EXEFNC
ACTION = "HINT" : Gosub ACTION From =GPROGRAMME
If HINTLIS(1)<>'' or NOHLIS(1)<>0
 Fillbox [CTR1] GAU_CHE1 Hint Key =HINTLIS(1)
Else
 Gosub CALNOH From GOBJET
 If A_NOH
  Fillbox [CTR1] GAU_CHE1
 Else
  Fillbox [CTR1] GAU_CHE1 Hint Key =""
 Endif
Endif
GPOINT = "AP_FILLBOX" : Gosub ENTREE From EXEFNC
Filter [CT1]
Return

$SETCLE_
Local Char    CLELISTE(250)
Local Integer INDLIS , SNSLIS , LENLIS, GAUTRELIS
INDLIS = 1
SNSLIS = 1
LENLIS = 3
GAUTRELIS = 1
CLELISTE = "REFNUM;CTRNUM;CTRDAT"
ACTION = "CLE_GAUCHE" : Gosub ACTION From =GPROGRAMME
Return

$SETCLE_1
Local Char    CLELISTE(250)
Local Integer INDLIS , SNSLIS , LENLIS, GAUTRELIS
INDLIS = 1
SNSLIS = 1
LENLIS = 3
GAUTRELIS = 2
CLELISTE = "REFNUM;CTRNUM;CTRDAT"
ACTION = "CLE_GAUCHE" : Gosub ACTION From =GPROGRAMME
Return

$DEFAUT_BRO
Case ILIS
 When 0 : Default file [HRCTR_]
 When 1 : Default file [CT1]
Endcase
Return

$SETBOX
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [HRCTR_] Order With CLELISTE
  Setlbox [CTR1] GAU_CHE
  Filter [HRCTR_]
 When "GAU_CHE1"
  Setlbox [CTR1] GAU_CHE1
Endcase
Return

$SETORDER
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [HRCTR_] Order With CLELISTE
Endcase
Return

$ENDORDER
Case currbox
 When "GAU_CHE"
  Gosub SETCLE_
  Filter [HRCTR_]
Endcase
Return

$PICKING
Return

$DEPICK
Return

$REPICK
Return

$SETCUR
Return

$DEFVAR
Local Char    ABMSK(GLONABR)(0..15) , NOMMSK(GLONAMK)(0..15)
Local Integer NBMASK , AMA(0..15) , NBMSKCMP
NOMMSK(0) = "CTR0"         : ABMSK(0)  = "CTR0"     : AMA(0) = 1
NOMMSK(1) = "CTR1"         : ABMSK(1)  = "CTR1"     : AMA(1) = 1
NOMMSK(2) = "CTR8"         : ABMSK(2)  = "CTR8"     : AMA(2) = 1
NOMMSK(3) = "CTR2"         : ABMSK(3)  = "CTR2"     : AMA(3) = 1
NOMMSK(4) = "CTR4"         : ABMSK(4)  = "CTR4"     : AMA(4) = 1
NOMMSK(5) = "CTR7"         : ABMSK(5)  = "CTR7"     : AMA(5) = 1
NOMMSK(6) = "CTR3"         : ABMSK(6)  = "CTR3"     : AMA(6) = 1
NOMMSK(7) = "CTR5"         : ABMSK(7)  = "CTR5"     : AMA(7) = 1
NOMMSK(8) = "CTR6"         : ABMSK(8)  = "CTR6"     : AMA(8) = 1
NOMMSK(9) = "CTRPEN"       : ABMSK(9)  = "CTRPEN"   : AMA(9) = 1
NOMMSK(10) = "CTR9"         : ABMSK(10)  = "CTR9"     : AMA(10) = 1
NOMMSK(11) = "CTR10"        : ABMSK(11)  = "CTRA"     : AMA(11) = 1
NOMMSK(12) = "CTR11"        : ABMSK(12)  = "CTRB"     : AMA(12) = 1
NOMMSK(13) = "CTR12"        : ABMSK(13)  = "CTR12"    : AMA(13) = 1
NBMASK = 13
NBMSKCMP = 0
Return

$SETMASK
Case MA
 When 0 : If clalev([M:CTR0])>0 : Default Mask [CTR0] : Endif
 When 1 : If clalev([M:CTR1])>0 : Default Mask [CTR1] : Endif
 When 2 : If clalev([M:CTR8])>0 : Default Mask [CTR8] : Endif
 When 3 : If clalev([M:CTR2])>0 : Default Mask [CTR2] : Endif
 When 4 : If clalev([M:CTR4])>0 : Default Mask [CTR4] : Endif
 When 5 : If clalev([M:CTR7])>0 : Default Mask [CTR7] : Endif
 When 6 : If clalev([M:CTR3])>0 : Default Mask [CTR3] : Endif
 When 7 : If clalev([M:CTR5])>0 : Default Mask [CTR5] : Endif
 When 8 : If clalev([M:CTR6])>0 : Default Mask [CTR6] : Endif
 When 9 : If clalev([M:CTRPEN])>0 : Default Mask [CTRPEN] : Endif
 When 10 : If clalev([M:CTR9])>0 : Default Mask [CTR9] : Endif
 When 11 : If clalev([M:CTRA])>0 : Default Mask [CTRA] : Endif
 When 12 : If clalev([M:CTRB])>0 : Default Mask [CTRB] : Endif
 When 13 : If clalev([M:CTR12])>0 : Default Mask [CTR12] : Endif
Endcase
Return

$TITMASK
Case MA
 When 0 : If clalev([M:CTR0])>0 : Gosub TITRES From W1CTR0 : Endif
 When 1 : If clalev([M:CTR1])>0 : Gosub TITRES From W1CTR1 : Endif
 When 2 : If clalev([M:CTR8])>0 : Gosub TITRES From W1CTR8 : Endif
 When 3 : If clalev([M:CTR2])>0 : Gosub TITRES From W1CTR2 : Endif
 When 4 : If clalev([M:CTR4])>0 : Gosub TITRES From W1CTR4 : Endif
 When 5 : If clalev([M:CTR7])>0 : Gosub TITRES From W1CTR7 : Endif
 When 6 : If clalev([M:CTR3])>0 : Gosub TITRES From W1CTR3 : Endif
 When 7 : If clalev([M:CTR5])>0 : Gosub TITRES From W1CTR5 : Endif
 When 8 : If clalev([M:CTR6])>0 : Gosub TITRES From W1CTR6 : Endif
 When 9 : If clalev([M:CTRPEN])>0 : Gosub TITRES From W1CTRPEN : Endif
 When 10 : If clalev([M:CTR9])>0 : Gosub TITRES From W1CTR9 : Endif
 When 11 : If clalev([M:CTRA])>0 : Gosub TITRES From W1CTR10 : Endif
 When 12 : If clalev([M:CTRB])>0 : Gosub TITRES From W1CTR11 : Endif
 When 13 : If clalev([M:CTR12])>0 : Gosub TITRES From W1CTR12 : Endif
Endcase
Return

$FERME_MASK
If clalev([M:CTR0])>0 : Close Local Mask [CTR0] : Endif
If clalev([M:CTR1])>0 : Close Local Mask [CTR1] : Endif
If clalev([M:CTR8])>0 : Close Local Mask [CTR8] : Endif
If clalev([M:CTR2])>0 : Close Local Mask [CTR2] : Endif
If clalev([M:CTR4])>0 : Close Local Mask [CTR4] : Endif
If clalev([M:CTR7])>0 : Close Local Mask [CTR7] : Endif
If clalev([M:CTR3])>0 : Close Local Mask [CTR3] : Endif
If clalev([M:CTR5])>0 : Close Local Mask [CTR5] : Endif
If clalev([M:CTR6])>0 : Close Local Mask [CTR6] : Endif
If clalev([M:CTRPEN])>0 : Close Local Mask [CTRPEN] : Endif
If clalev([M:CTR9])>0 : Close Local Mask [CTR9] : Endif
If clalev([M:CTRA])>0 : Close Local Mask [CTRA] : Endif
If clalev([M:CTRB])>0 : Close Local Mask [CTRB] : Endif
If clalev([M:CTR12])>0 : Close Local Mask [CTR12] : Endif
Return

$RAZMASK
Case MA
 When 0 : If clalev([M:CTR0])>0 : Raz [M:CTR0] : Endif
 When 1 : If clalev([M:CTR1])>0 : Raz [M:CTR1] : Endif
 When 2 : If clalev([M:CTR8])>0 : Raz [M:CTR8] : Endif
 When 3 : If clalev([M:CTR2])>0 : Raz [M:CTR2] : Endif
