$CHARGEMSK
Case IMA
 When 0 : If clalev([M:CTR0])>0 : [M:CTR0] = [F:HRCTR] : Endif
 When 1 : If clalev([M:CTR1])>0 : [M:CTR1] = [F:HRCTR] : Endif
 When 2 : If clalev([M:CTR8])>0 : [M:CTR8] = [F:HRCTR] : Endif
 When 3 : If clalev([M:CTR2])>0 : [M:CTR2] = [F:HRCTR] : Endif
 When 4 : If clalev([M:CTR4])>0 : [M:CTR4] = [F:HRCTR] : Endif
 When 5 : If clalev([M:CTR7])>0 : [M:CTR7] = [F:HRCTR] : Endif
 When 6 : If clalev([M:CTR3])>0 : [M:CTR3] = [F:HRCTR] : Endif
 When 7 : If clalev([M:CTR5])>0 : [M:CTR5] = [F:HRCTR] : Endif
 When 8 : If clalev([M:CTR6])>0 : [M:CTR6] = [F:HRCTR] : Endif
 When 9 : If clalev([M:CTRPEN])>0 : [M:CTRPEN] = [F:HRCTR] : Endif
 When 10 : If clalev([M:CTR9])>0 : [M:CTR9] = [F:HRCTR] : Endif
 When 11 : If clalev([M:CTRA])>0 : [M:CTRA] = [F:HRCTR] : Endif
 When 12 : If clalev([M:CTRB])>0 : [M:CTRB] = [F:HRCTR] : Endif
 When 13 : If clalev([M:CTR12])>0 : [M:CTR12] = [F:HRCTR] : Endif
Endcase
Return

$GRISE_CLE
If AMA(0)
 Grizo [CTR0]CTRNUM,REFNUM,CTRDAT
Else
 Grizo [CTR1]CTRNUM,REFNUM,CTRDAT
Endif
Return

$DEGRISE_CLE
If AMA(0)
 Actzo [CTR0]CTRNUM,REFNUM,CTRDAT
Else
 Actzo [CTR1]CTRNUM,REFNUM,CTRDAT
Endif
Return

$BOUTON
STDBOUT = "ECSAN09<>RILJMP"
NBTEX  = 0
NBTEX += 1
CBOUT(NBTEX) = "4" : LBOUT(NBTEX) = 1101 : Call TEXTE(37399,TEXTE(NBTEX)) From OBJDIV
NBTEX += 1
CBOUT(NBTEX) = "7" : LBOUT(NBTEX) = 1102 : Call TEXTE(47298,TEXTE(NBTEX)) From OBJDIV
Raz NBMEN, CMEN, TMEN, NMEN, LMEN
NBMEN += 1
NMEN(NBMEN) = 10 : Call TEXTE(1043,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 10 : CMEN(NBMEN) = "1" : LMEN(NBMEN) = 2001 : Call TEXTE(45056,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 10 : CMEN(NBMEN) = "2" : LMEN(NBMEN) = 2002 : Call TEXTE(45611,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 10 : CMEN(NBMEN) = "3" : LMEN(NBMEN) = 2003 : Call TEXTE(14284,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 10 : CMEN(NBMEN) = "5" : LMEN(NBMEN) = 2004 : Call TEXTE(45077,TMEN(NBMEN)) From OBJDIV
NBMEN += 1
NMEN(NBMEN) = 10 : CMEN(NBMEN) = "6" : LMEN(NBMEN) = 2005 : Call TEXTE(47293,TMEN(NBMEN)) From OBJDIV
Return

$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
 When "4"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M:CTR0]REFNUM
  PARBOUT(2) = [M:CTR0]CTRNUM
  PARBOUT(3) = num$("6")
  FLGEXE = 1
  GACTION = "MATPCA"
  Call TRAITE_CHAR(VALBOUT,PARBOUT,"","MATPCA","MATPCA",4,"XYMATPCA") From GTRAITE
 When "7"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M]REFNUM
  PARBOUT(2) = [M]CTRNUM
  PARBOUT(3) = [M]CTRDAT
  PARBOUT(4) = [M]LEG
  PARBOUT(5) = num$([M:CTR1]FLGCRE1)
  PARBOUT(6) = num$([M:CTR1]FLGCRE1)
  FLGEXE = 1
  GACTION = "CTRDOC"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"CTRDOC","CTRDOC","SPECTRDOC") From GSAISIE
  [M:CTR1]FLGCRE1 = val(PARBOUT(5))
  [M:CTR1]FLGCRE1 = val(PARBOUT(6))
 When "1"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M]REFNUM
  PARBOUT(2) = [M]CTRDAT
  PARBOUT(3) = [M]CTRNUM
  FLGEXE = 1
  GACTION = "TRTGENCTR"
  Call TRAITE_CHAR(VALBOUT,PARBOUT,"","TRTGENCTR","TRTGENCTR",4,"XYTRTGENCTR") From GTRAITE
 When "2"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = "VEP"
  PARBOUT(2) = [M:CTR0]REFNUM
  FLGEXE = 1
  GACTION = "GOBJET"
  Call OBJET_CHAR(VALBOUT,PARBOUT(1),PARBOUT(2)) From GOBJET
 When "3"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  FLGEXE = 1
  GACTION = "CHGCTRDAT"
  Call TRAITE_CHAR(VALBOUT,PARBOUT,"","CHGCTRDAT","CHGCTRDAT",3,"") From GTRAITE
 When "5"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = "OCTR"
  PARBOUT(2) = [M:CTR0]REFNUM
  PARBOUT(3) = [M:CTR0]CTRNUM
  PARBOUT(4) = [M:CTR0]CTRDAT
  PARBOUT(5) = [V]GBIDC1
  PARBOUT(6) = [V]GBIDC2
  FLGEXE = 1
  GACTION = "TRTRETAVT"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"TRTRETAVT","TRTRETAVT","XYTRTRETAVT") From GSAISIE
  [V]GBIDC1 = PARBOUT(5)
  [V]GBIDC2 = PARBOUT(6)
 When "6"
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  PARBOUT(1) = [M:CTR0]REFNUM
  PARBOUT(2) = [M:CTR0]CTRNUM
  PARBOUT(3) = [M:CTR0]CTRDAT
  PARBOUT(4) = [M:CTR0]XITDAT
  PARBOUT(5) = [V]GBIDC1
  PARBOUT(6) = [V]GBIDC2
  FLGEXE = 1
  GACTION = "TRTVARAVT"
  Call SAISIE_CHAR(VALBOUT,PARBOUT,"TRTVARAVT","TRTVARAVT","XYTRTVARAVT") From GSAISIE
  [V]GBIDC1 = PARBOUT(5)
  [V]GBIDC2 = PARBOUT(6)
Endcase
GACTION = SAVACT
Return

$EXEACT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return


