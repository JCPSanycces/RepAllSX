 When 7 : If clalev([M:CTR5])>0 : [F:HRCTR] = [M:CTR5] : Endif
 When 8 : If clalev([M:CTR6])>0 : [F:HRCTR] = [M:CTR6] : Endif
 When 9 : If clalev([M:CTRPEN])>0 : [F:HRCTR] = [M:CTRPEN] : Endif
