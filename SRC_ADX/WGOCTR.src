$AFF_ENAFLG
Return

$CHARGEFIC
Case IMA
 When 0 : If clalev([M:CTR0])>0 : [F:HRCTR] = [M:CTR0] : Endif
 When 1 : If clalev([M:CTR1])>0 : [F:HRCTR] = [M:CTR1] : Endif
 When 2 : If clalev([M:CTR8])>0 : [F:HRCTR] = [M:CTR8] : Endif
