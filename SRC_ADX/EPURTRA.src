#<AdxTL>@(#)10.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AHISTO","AHISTO",3,"") From GTRAITE
End

#----------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE"   : Gosub OUVRE : # Nouveau par AHISTO
 When "FILTRE"  : Gosub FILTRE
 When "FERME"   : Gosub FERME
Endcase
Return


#----------------------------------------------#
# GTRAITE
#----------------------------------------------#

$EPURE_TRA
# Epuration des traces
REFDAT = date$-TEMPS
REP = "TRA"
EXT = "tra"
ORDSYS = 'lsadx -a "'+nomap+'" -t '+REP+' '+EXT
Call SYSTEME2("",ORDSYS,"",NBFIC,LISTEFIC) From ORDSYS
For I=1 To min(abs(NBFIC),dim(LISTEFIC))
 FICTRA = filpath(REP,"","")+"/"+LISTEFIC(I)+"."+EXT
 SECONDES  = filinfo(FICTRA,9)
 DATFIC = [01/01/1970]+int(SECONDES/(24*3600))
 TAILLE = filinfo(FICTRA,7)
 If TAILLE=0 | DATFIC<=REFDAT
  If TRACEDET & !instr(1,LISTEFIC(I),".")
   Call ECR_TRACE(LISTEFIC(I)+"."+EXT-":"-filcom(REP,LISTEFIC(I),EXT),0) From GESECRAN
  Endif
  NBEPU += 1
  If !SIMUL
   Call EFFACE(FICTRA,STAT) From ORDSYS
  Endif
 Endif
Next I
Return

#----------------------------------------------#
# AHISTO
#----------------------------------------------#

$OUVRE
Local Integer OK , I , NBFIC , STAT , SECONDES , NBEPU , TAILLE
Local Char    REP(10) , EXT(10) , CRI(250)
Local Date    DATFIC , REFDAT
Local Char    ORDSYS(250) , FICTRA(GDIMFIC)
Local Char    LISTEFIC(60)(1..30000)
Return

$FERME
Gosub EPURE_TRA
NRDEL = NBEPU
NBRES = NBFIC
Return

$FILTRE
FILTSUP = '1=0' : # La table ATMPTRA est épurée par le code histo ATMP
Return

#----------------------------------------------#
Subprog AS_DATEPU(VALEUR)
Variable Date     VALEUR
If [M]NBMOIS<>0
 mkstat = 1
Else
 VALEUR = date$-1
Endif
End

