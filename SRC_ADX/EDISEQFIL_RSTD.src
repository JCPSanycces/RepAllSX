#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"     : Gosub AREAD_AFTER
        When Default
      Endcase
    When "ESF"
      Case [L]AEVENT
         When "AREAD_AFTER"    : Gosub ESF_AREAD_AFTER
      Endcase
    When "ESF.ESFF"
      Case [L]AEVENT
         When "AREAD_AFTER"    : Gosub ESF_ESFF_AREAD_AFTER
         When "ADDLINE_AFTER"  : Gosub ESF_ESFF_ADDLINE_AFTER
      Endcase
    When "ESF.ESFN"
      Case [L]AEVENT
         When "AREAD_AFTER"    : Gosub ESF_ESFN_AREAD_AFTER
      Endcase
    When "ESF.ESFD"
      Case [L]AEVENT
         When "AREAD_AFTER"    : Gosub ESF_ESFD_AREAD_AFTER
         When "ADDLINE_AFTER"  : Gosub ESF_ESFD_ADDLINE_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "ESF.OPTDAT" :
      Case [L]ARULE
        When 'PROPAGATE'  : Gosub ESF_OPTDAT_PROPAGATE
      Endcase
    When "ESF.OPTMNL" :
      Case [L]ARULE
        When 'PROPAGATE'  : Gosub ESF_OPTMNL_PROPAGATE
      Endcase
    When "ESF.MSGDIR" :
      Case [L]ARULE
        When "PROPAGATE": Gosub ESF_MSGDIR_PROPAGATE
      Endcase
    When "ESF.TYPFIL" :
      Case [L]ARULE
        When "PROPAGATE": Gosub ESF_TYPFIL_PROPAGATE
      Endcase
    When "ESF.ESFF.FILCOD" :
      Case [L]ARULE
        When 'PROPAGATE'  : Gosub ESF_ESFF_FILCOD_PROPAGATE
      Endcase
    When "ESF.ESFN.COMTYP" :
      Case [L]ARULE
        When "PROPAGATE": Gosub ESF_ESFN_COMTYP_PROPAGATE
      Endcase
  Endcase
Return


#####################################################################
$ESF_OPTDAT_PROPAGATE
  this.APARENT.LIBDAT = func SET_LIBDAT(this.OPTDAT)
Return

####################################################################
$ESF_OPTMNL_PROPAGATE
  this.APARENT.LIBMNL = func SET_LIBMNL(this.OPTMNL)
Return

####################################################################
$ESF_MSGDIR_PROPAGATE
  Call ESF_DISPLAY(this)
Return

####################################################################
$ESF_TYPFIL_PROPAGATE
  Call ESF_DISPLAY(this)

  Local Integer I
  For I = 1 To maxtab(this.ESFD)
    Call ESF_ESFD_DISPLAY(this.ESFD(I))
  Next I
Return

####################################################################
$ESF_ESFF_FILCOD_PROPAGATE
  Local Integer I
  For I = 1 To maxtab(this.APARENT.ESFF)
    Call ESF_ESFF_DISPLAY(this.APARENT.ESFF(I))
  Next I
Return

####################################################################
$ESF_ESFN_COMTYP_PROPAGATE
  Call ESF_ESFN_DISPLAY(this)
Return

#********************************************************************
# Method AREAD_AFTER
#********************************************************************
#* Switch the display
#*!
$AREAD_AFTER
  Local Integer WPOS : WPOS = 0
  Local Integer WNB  : WNB = 0
  #display EDI flows using the current Sequential File structure
  Local File EDIFLO [EFL]
  Local File EDIFLOD [EFLD]
  Link [EFLD] With [EFL]EFL0 = [EFLD]FLOCOD;[EFLD]FLOREL As [LIEN] Where [EFLD]MSGTYP = 1
&      and [EFLD]MSGCOD = this.ESF.MSGCOD and [EFLD]MSGREL = this.ESF.MSGREL and [EFLD]MSGFILNOR = this.ESF.MSGFILNOR
  For [LIEN]
    WNB = WNB + 1
    If WNB < func AFNC.ACTIV("EDINB") #100 #limit of collection
      WPOS = fmet this.ADDLINE('FLO', [V]CST_ALASTPOS)
      this.FLO(WPOS).FLOFLOCOD = [EFLD]FLOCOD
      this.FLO(WPOS).FLOFLOREL = [EFLD]FLOREL
      this.FLO(WPOS).FLOFLODES = [EFL]FLODES
      this.FLO(WPOS).FLOVALID = [EFL]VALID
      this.FLO(WPOS).FLOFLGACT = [EFL]FLGACT
    Endif
  Next
  LogicClose File [EFLD]
  LogicClose File [EFL]
Return


#********************************************************************
# Method ESF_AREAD_AFTER
#********************************************************************
#* Switch the display
#*!
$ESF_AREAD_AFTER
  Call ESF_DISPLAY(this)
  this.APARENT.LIBMNL = func SET_LIBMNL(this.OPTMNL)
  this.APARENT.LIBDAT = func SET_LIBDAT(this.OPTDAT)
Return

#********************************************************************
# Method ESF_ESFF_AREAD_AFTER
#********************************************************************
#*
#*!
$ESF_ESFF_AREAD_AFTER
  Call ESF_ESFF_DISPLAY(this)
Return

#********************************************************************
# Method ESF_ESFF_ADDLINE_AFTER
#********************************************************************
#*
#*!
$ESF_ESFF_ADDLINE_AFTER
  Call ESF_ESFF_DISPLAY(this)
Return

#********************************************************************
# Method ESF_ESFN_AREAD_AFTER
#********************************************************************
#*
#*!
$ESF_ESFN_AREAD_AFTER
  Call ESF_ESFN_DISPLAY(this)
  this.FORMAT = func SET_FORMAT(this.COMTYP, this.COMVAL)
Return

#********************************************************************
# Method ESF_ESFD_AREAD_AFTER
#********************************************************************
#*
#*!
$ESF_ESFD_AREAD_AFTER
  Call ESF_ESFD_DISPLAY(this)
Return

#********************************************************************
# Method ESF_ESFD_ADDLINE_AFTER
#********************************************************************
#*
#*!
$ESF_ESFD_ADDLINE_AFTER
  Call ESF_ESFD_DISPLAY(this)
Return

#********************************************************************
# Subprog ESF_DISPLAY
#********************************************************************
#
#* Switch the display
#* @param WOBJECT --> OBJECT
#*!
Subprog ESF_DISPLAY(WOBJECT)
Variable Instance WOBJECT Using OBJECT
  Local Integer WOK, I, WNB
  Local Char WPROP(20)

  WPROP = "$isHidden"
  If WOBJECT.MSGDIR = 2 # Receipt
    WOK = fmet WOBJECT.ASETATTRIBUTE('KEYALIAS',     WPROP, 'false')
    WOK = fmet WOBJECT.ASETATTRIBUTE('KEYDES',       WPROP, 'false')
    WOK = fmet WOBJECT.ASETATTRIBUTE('KEYPROPERTY',  WPROP, 'false')
#    WOK = fmet WOBJECT.ASETATTRIBUTE('KEYPROTOPATH', WPROP, 'false') # 114721
  Else
    WOK = fmet WOBJECT.ASETATTRIBUTE('KEYALIAS',     WPROP, 'true')
    WOK = fmet WOBJECT.ASETATTRIBUTE('KEYDES',       WPROP, 'true')
    WOK = fmet WOBJECT.ASETATTRIBUTE('KEYPROPERTY',  WPROP, 'true')
#    WOK = fmet WOBJECT.ASETATTRIBUTE('KEYPROTOPATH', WPROP, 'true') # 114721
  Endif

  WPROP = "$isDisabled"
  Case WOBJECT.TYPFIL
    When 1 :
      WOK = fmet WOBJECT.ASETATTRIBUTE('SEPREC', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('SEPFLD', WPROP, 'false')
      WOK = fmet WOBJECT.ASETATTRIBUTE('SEPDEC', WPROP, 'false')
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLDLIM', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('CODDBA', WPROP, 'false')

    When 2 :
      WOK = fmet WOBJECT.ASETATTRIBUTE('SEPREC', WPROP, 'false')
      WOK = fmet WOBJECT.ASETATTRIBUTE('SEPFLD', WPROP, 'false')
      WOK = fmet WOBJECT.ASETATTRIBUTE('SEPDEC', WPROP, 'false')
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLDLIM', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('CODDBA', WPROP, 'false')

    When 3 :
      WOK = fmet WOBJECT.ASETATTRIBUTE('SEPREC', WPROP, 'false')
      WOK = fmet WOBJECT.ASETATTRIBUTE('SEPFLD', WPROP, 'false')
      WOK = fmet WOBJECT.ASETATTRIBUTE('SEPDEC', WPROP, 'false')
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLDLIM', WPROP, 'false')
      WOK = fmet WOBJECT.ASETATTRIBUTE('CODDBA', WPROP, 'false')

    When 4 :
      WOK = fmet WOBJECT.ASETATTRIBUTE('SEPREC', WPROP, 'false')
      WOK = fmet WOBJECT.ASETATTRIBUTE('SEPFLD', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('SEPDEC', WPROP, 'false')
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLDLIM', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('CODDBA', WPROP, 'true')

    When 5, 6, 7 :
      WOK = fmet WOBJECT.ASETATTRIBUTE('SEPREC', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('SEPFLD', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('SEPDEC', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLDLIM', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('CODDBA', WPROP, 'true')
  Endcase

End

#********************************************************************
# Subprog ESF_ESFD_DISPLAY
#********************************************************************
#
#* Switch the display
#* @param WOBJECT --> OBJECT
#*!
Subprog ESF_ESFD_DISPLAY(WOBJECT)
Variable Instance WOBJECT Using OBJECT

  Local Integer WOK, I
  Local Char WPROP(20)
  WPROP = "$isDisabled"

  Case WOBJECT.APARENT.TYPFIL
    When 4 :
        WOK = fmet WOBJECT.ASETATTRIBUTE("LOC", WPROP, "false")
        WOK = fmet WOBJECT.ASETATTRIBUTE("LNG", WPROP, "false")
    When Default:
        WOK = fmet WOBJECT.ASETATTRIBUTE("LOC", WPROP, "true")
        WOK = fmet WOBJECT.ASETATTRIBUTE("LNG", WPROP, "true")
   Endcase
   WOK = fmet WOBJECT.ASETATTRIBUTE("DESCRIPTION", WPROP, "true")

   If WOBJECT.APARENT.MSGDIR=1
     WOK = fmet WOBJECT.ASETATTRIBUTE("FLGREC", WPROP, "true")
   Else
     WOK = fmet WOBJECT.ASETATTRIBUTE("FLGREC", WPROP, "false")
   Endif
End


#********************************************************************
# Subprog ESF_ESFF_DISPLAY
#********************************************************************
#
#* Switch the display
#* @param WOBJECT --> OBJECT
#*!
Subprog ESF_ESFF_DISPLAY(WOBJECT)
Variable Instance WOBJECT Using OBJECT
  Local Integer WOK, I
  Local Char WPROP1(20), WPROP2(20)
  WPROP1 = "$isMandatory"
  WPROP2 = "$isDisabled"

  Case WOBJECT.APARENT.MSGDIR
    When 1 :
      WOK = fmet WOBJECT.ASETATTRIBUTE("FILNAM"   , WPROP1,"true")
      WOK = fmet WOBJECT.ASETATTRIBUTE("MAINFIELD", WPROP1,"false")
      WOK = fmet WOBJECT.ASETATTRIBUTE("MAINFIELD", WPROP2, "true")
      WOK = fmet WOBJECT.ASETATTRIBUTE("LINKFIELD", WPROP2, "true")
      WOK = fmet WOBJECT.ASETATTRIBUTE("PARFILE"  , WPROP2, "true")
    When 2 :
      WOK = fmet WOBJECT.ASETATTRIBUTE("FILNAM"   , WPROP1, "true")
      WOK = fmet WOBJECT.ASETATTRIBUTE("MAINFIELD", WPROP1, "true")
      WOK = fmet WOBJECT.ASETATTRIBUTE("MAINFIELD", WPROP2,  "false")
      WOK = fmet WOBJECT.ASETATTRIBUTE("LINKFIELD", WPROP2 , "false")
      WOK = fmet WOBJECT.ASETATTRIBUTE("PARFILE"  , WPROP2 , "false")
  Endcase
End

#********************************************************************
# Subprog ESF_ESFN_DISPLAY
#********************************************************************
#
#* Switch the display
#* @param WOBJECT --> OBJECT
#*!
Subprog ESF_ESFN_DISPLAY(WOBJECT)
Variable Instance WOBJECT Using OBJECT
  Local Integer WOK, I
  Local Char WPROP1(20), WPROP2(20)
  WPROP1 = "$isMandatory"
  WPROP2 = "$isDisabled"

  If WOBJECT.APARENT.MSGDIR = 1 # Issue
    Case WOBJECT.COMTYP
      When 1,2,7:
        WOK = fmet WOBJECT.ASETATTRIBUTE("COMVAL", WPROP1, "false")
        WOK = fmet WOBJECT.ASETATTRIBUTE("COMVAL", WPROP2, "true")
      When Default:
        WOK = fmet WOBJECT.ASETATTRIBUTE("COMVAL", WPROP1, "true")
        WOK = fmet WOBJECT.ASETATTRIBUTE("COMVAL", WPROP2, "false")
    Endcase
  Else
    WOK = fmet WOBJECT.ASETATTRIBUTE("COMVAL", WPROP1, "false")
    WOK = fmet WOBJECT.ASETATTRIBUTE("COMVAL", WPROP2, "true")
  Endif
End

#********************************************************************
# Funprog SET_LIBDAT
#********************************************************************
#
#* @param WOPTDAT --> Date type
#* @return WLIBDAT
#* #*!
Funprog SET_LIBDAT(WOPTDAT)
Value Integer WOPTDAT
  Local Char WLIBDAT(10)
  Case WOPTDAT
    When 1 : WLIBDAT = right$(mess(15,141,1),5)  : # 1 : DDMMYY
    When 2 : WLIBDAT = right$(mess(16,141,1),5)  : # 2 : DDMMYYYY
    When 3 : WLIBDAT = right$(mess(17,141,1),5)  : # 3 : YYMMAA
    When 4 : WLIBDAT = right$(mess(18,141,1),5)  : # 4 : YYYYMMDD
    When 5 : WLIBDAT = right$(mess(175,141,1),5) : # 5 : YYYY-MM-DD
  Endcase
End WLIBDAT

#********************************************************************
# Funprog SET_LIBMNL
#********************************************************************
#
#* @param WOPTMNL
#* @return WLIBDAT
#* #*!
Funprog SET_LIBMNL(WOPTMNL)
Value Integer WOPTMNL
  Local Char WLIBMNL(10)
  Case WOPTMNL
    When 0       : WLIBMNL = right$(mess(22,141,1),4) : # 0 : Valeur
    When 1       : WLIBMNL = right$(mess(23,141,1),4) : # 1 : Code
    When Default : WLIBMNL = right$(mess(24,141,1),4) : # n : premiers carac
  Endcase
End WLIBMNL

#********************************************************************
# Funprog SET_FORMAT
#********************************************************************
#
#* @param WCOMTYP
#* @param WCOMVAL
#* @return WFORMAT
#* #*!
Funprog SET_FORMAT(WCOMTYP, WCOMVAL)
Value Integer WCOMTYP
Value Char WCOMVAL
  Local Char WFORMAT(10) : WFORMAT = ""
  If WCOMVAL <> ""
    Case WCOMTYP
      When 4       : WFORMAT = mess(val(WCOMVAL),2015,1) #date
      When 5       : WFORMAT = mess(val(WCOMVAL),2016,1) #times
      When Default : WFORMAT = ""
    Endcase
  Endif
End WFORMAT

