#FRLAA  - 2015/05/13 - REQUIREMENT 105483 - US 3571 - START
# Mask Management CPYLEGMID

$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEBUT"        : Gosub DEBUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE #FRLAA 2015-06-04 - Requirement 105483 US 3675
    When "OK"           : Gosub OK
  Endcase
Return

$OUVRE
  If clalev([F:CPYMID])=0 : Local File HRCOMPANYMID [CPYMID]  : Endif
  Call MANAGE_LOCALISATION("CPYLEGMID") From DIVPAYE #FRLAA - 2016-06-24 - REQUIREMENT 114309 US 271
Return

#FRLAA 2015-06-04 - Requirement 105483 US 3675 - START
$OUVRE_BOITE
#If !func AFNC.ACTIV("KFR")  & !func AFNC.ACTIV("KPO") Then    :#Necessary for PAIEV6 folder where all activity codes are activated !
#  If dim([M:CLMID]TRDLICNUM)>0  :   Chgfmt [M:CLMID]TRDLICNUM        With "-K:15X"         : Raz [M:CLMID]TRDLICNUM   :   Endif
#  If dim([M:CLMID]TRDLICDAT)>0  :   Chgfmt [M:CLMID]TRDLICDAT        With "-D:"+GFMDAT4                               :   Endif
#  If dim([M:CLMID]INDLICNUM)>0  :   Chgfmt [M:CLMID]INDLICNUM        With "-K:15X"         : Raz [M:CLMID]INDLICNUM   :   Endif
#  If dim([M:CLMID]INDLICDAT)>0  :   Chgfmt [M:CLMID]INDLICDAT        With "-D:"+GFMDAT4                               :   Endif
#  If dim([M:CLMID]CMLLICNUM)>0  :   Chgfmt [M:CLMID]CMLLICNUM        With "-K:15X"         : Raz [M:CLMID]CMLLICNUM   :   Endif
#  If dim([M:CLMID]CMLLICDAT)>0  :   Chgfmt [M:CLMID]CMLLICDAT        With "-D:"+GFMDAT4                               :   Endif
#Endif
Return
 #FRLAA 2015-06-04 - Requirement 105483 US 3675 - END

$DEBUT
  Raz [M:CLMID]
  [M]CPY = [M:CPY0]CPY
  Read [F:CPYMID]CPYMID0 = [M:CPY0]CPY
  If !fstat
    [M:CLMID] = [F:CPYMID]
  Else
    Affzo [M:CLMID]
    Call HIDE_RENAME_FIELDS
#JASMI - 2018-01-12 - X3-70809 - START
    Call AM_CPYRGTTYP([M:CLMID]CPYRGTTYP)
#JASMI - 2018-01-12 - X3-70809 - END
    Return
  Endif

  If [F:CPYMID]SPOTYP <> 1
    Raz [M]SPOTIT
    Diszo [M]SPOTIT
  Else
    Actzo [M]SPOTIT
  Endif

  Call HIDE_RENAME_FIELDS
  #DEHEN - 2014-05-20 - Requirement 116102  - US 3 - START
  #ADNGO - 2017-11-29 - X3-60298 - START
  #If func AFNC.ACTIV("KQA") Then
  If func DIVPAYE.IS_KQA_LEG(GCURLEG) Then
  #ADNGO - 2017-11-29 - X3-60298 - END
    Call SETACTVIS()
    Call CALCTOT()
  Endif
  #Assign "[M:CLMID]PERNUM" With [F:CPYMID]PERNUM
  #DEHEN - 2014-05-20 - Requirement 116102  - US 3 - END
  Affzo [M:CLMID]
Return

$OK
#At least one permit must exist
If PMTLIGNUM < 1
  GERR  = 2
  GMESSAGE = mess(00002,11738,1)
  FIN = 0 # Instruct the supervisor to keep the window open
  Return
Endif

Trbegin [F:CPYMID]
Read [F:CPYMID]CPYMID0 = [M:CPY0]CPY
If fstat
  [F:CPYMID]    = [M:CLMID]
  [F:CPYMID]CPY = [M:CPY0]CPY
  Write [F:CPYMID]
  Commit
Else
  [F:CPYMID] = [M:CLMID]
  Rewrite [F:CPYMID]
  Commit
Endif
If fstat
  GOK=0 : Call FSTA("CPYMID ") From GLOCK
Endif

If !GOK : Goto AB_TR1 : Return : Endif
Return

$AB_TR1
Rollback
Call ERREUR(mess (17,107,1)) From GESECRAN :#Rollback suite à une erreur dans la transaction
Return

