#FRLAA  - 2015-06-17 - REQUIREMENT 105483 - US 3675 - START
Subprog C_BOXNUM(VALEUR)
Variable Char    VALEUR()
For [CPYMID]CPYMID1
  If [F:CPYMID]BOXNUM = VALEUR
    If [M]CPY <> [F:CPYMID]CPY
      GERR = 2  : GMESSAGE = (mess(00018,11738,1) + [F:CPYMID]CPY)
      mkstat = 2
    Endif
  Endif
Next
End
#FRLAA  - 2015-07-09 - REQUIREMENT 105483 - US 3675 - END

#FRLAA  - 2015-06-17 - REQUIREMENT 109427 - US 3712 - START
Subprog C_PMTCAT(VALEUR)
Variable Integer VALEUR
Local Integer DUPNUM : DUPNUM = 0
Local Integer CURRLNE : CURRLNE = nolign

For nolign = 1 To dim([M:CLMID]PMTCAT)
  If [M:CLMID]PMTNUM(nolign-1)<>""
    If [M:CLMID]PMTCAT(nolign-1) = VALEUR : DUPNUM=+1 : Endif
    If DUPNUM > 0 : GERR2 : GMESSAGE = mess(00006,07971,1) : mkstat = 2 : Break : Endif
  Endif
 Next nolign
End
#FRLAA  - 2015-07-09 - REQUIREMENT 109427 - US 3712 - END

