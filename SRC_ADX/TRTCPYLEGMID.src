#DEHEN - 2014-05-20 - Requirement 116102  - US 3 - START
Subprog CALCTOT()
  #ADNGO - 2017-11-29 - X3-60298 - START
  #If func AFNC.ACTIV("KQA") Then
  If func DIVPAYE.IS_KQA_LEG(GCURLEG) Then
  #ADNGO - 2017-11-29 - X3-60298 - END
  Local Integer I, NBRTOT, NBRACTTOT
    nolign = 0
    For I=1 To [F:CPYMID]PERNUM
      nolign += 1
      NBRTOT+=[M:CLMID]PERNBR(nolign-1)
      NBRACTTOT+=[M:CLMID]PERNBRACT(nolign-1) #DEHEN - 2014-06-23 - Requirement 116975  - US 3
    Next
    [M:CLMID]NUMPRMVIS = NBRTOT
    [M:CLMID]NUMACTPRMVIS = NBRACTTOT #DEHEN - 2014-06-23 - Requirement 116975  - US 3
    #Grizo [M:CLMID]NUMPRMVIS
  Endif
End

#DEHEN - 2014-06-23 - Requirement 116975  - US 3 - START
Subprog SETACTVIS()
  Local Integer I, EMPCOUNT
  #Open Tables
  If clalev([F:ID])  = 0  : Local File EMPLOID  [ID]  : Endif
  If clalev([F:HRCTR]) = 0  : Local File EMPLOCTR [HRCTR] : Endif
  #Build Links
  Link  [ID]
&  With  [HRCTR]CTR0 = [ID]REFNUM
&  As    [LNK]
&  Where [HRCTR]XITDAT = [00/00/00] & [ID]NBRCTR <> 0
    nolign = 0
    For I=1 To [F:CPYMID]PERNUM
      nolign += 1
      For [LNK]
        If [F:CPYMID]PERNTT(nolign-1) = [F:ID]NTT
          EMPCOUNT += 1
        Endif
      Next
      [M:CLMID]PERNBRACT(nolign-1) = EMPCOUNT
      EMPCOUNT = 0
    Next
End
#DEHEN - 2014-06-23 - Requirement 116975  - US 3 - END


Subprog C_CPYRGTDAT(VALEUR)
Variable Date    VALEUR
 If VALEUR > date$
  GERR = 2  : GMESSAGE = mess(181,10717,1)
  mkstat = 2
 Endif
End

Subprog C_CPYPRC(VALEUR)
Variable Decimal VALEUR
If (VALEUR+[M]SPOOWN) > 100
  GERR = 2  : GMESSAGE = mess(00001,11738,1)
  mkstat = 2
Endif
End

Subprog AM_SPOTYP(VALEUR)
Variable Integer VALEUR
If VALEUR <> 1
  Raz [M]SPOTIT
  Diszo [M]SPOTIT
Else
  Actzo [M]SPOTIT
Endif
Affzo [M]SPOTIT
End

Subprog C_SPOOWN(VALEUR)
Variable Decimal VALEUR
If (VALEUR+[M]CPYPRC) > 100
  GERR = 2  : GMESSAGE = mess(00001,11738,1)
  mkstat = 2
Endif
End

Subprog C_PMTDAT(VALEUR)
Variable Date    VALEUR
If VALEUR <> [00/00/00] Then
  If VALEUR < date$
    GERR = 2  : GMESSAGE = mess(00072,00199,1)
    mkstat = 2
  Endif
Endif
End


Subprog AM_CPYRGTTYP(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
  [M]CPYPRC = 49
  [M]SPOOWN = 51
Else
  [M]CPYPRC = 100
  [M]SPOOWN = 0
Endif
Affzo [M]CPYPRC
Affzo [M]SPOOWN
End


Subprog AS_NUMPRMVIS(VALEUR)
Variable Decimal VALEUR
Read [F:CPYMID]CPYMID0 = [M:CPY0]CPY
If fstat
#  If VALEUR = 0 Then
#    VALEUR = 1
#  Endif
Endif
End



