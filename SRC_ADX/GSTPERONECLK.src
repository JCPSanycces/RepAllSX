#<AdxTL>@(#)0.0.0.0 $Revision$ 
######################################################################################################
# Project       : Australian GST report
# File          : GSTPERONECLK
# Version       : 1.0
# Authors       : Daniel Nell (DNE)
# Creation Date : 2018-02-21
######################################################################################################
# Module        : Finance
# Description   : Create new periods for all active GST groups.
######################################################################################################
# Updates       :
# Date          | Author | Version | Description
# 2018-03-09    | Bader  | 2018.R3 | CODGSTPER now numerical
######################################################################################################

$ACTION
    Case ACTION
        When "INIT"        : Gosub INIT
        When "INIT_DIA"    : Gosub INIT_DIA
        When "EXEC"        : Gosub EXEC
    Endcase
Return

$INIT
    If !clalev( [F:GSTGH] ) : Local File GSTGRP  [GSTGH] : Endif                  # GST group header

    Local Integer I, QSTATUS                                                      # Loop counter, Syracuse status
Return

$INIT_DIA
    Filter [F:GSTGH] Where ENAFLG = 2                                             # Only active GST groups
    Raz [M]NBLIG                                                                  # Reset row counter.
    For [F:GSTGH]GSTGH0
        [M]CODGSTGRP( [M]NBLIG ) = [F:GSTGH]CODGSTGRP                             # GST group
        [M]GSTPER(    [M]NBLIG ) = [F:GSTGH]GSTPER                                # Monthly/Quarterly?

        # Calculate  period start and end dates based on GST group setting.
        Call INIT_DATES( [F:GSTGH]CODGSTGRP, [M]DATSTR( [M]NBLIG ), [M]DATEND( [M]NBLIG ) ) From SUBGSTPER

        # "Validate" row if end date not in the future.
        If [M]DATEND( [M]NBLIG ) <= date$
            [M]NBLIG += 1 # Increase row counter
        Endif
    Next
    Filter [F:GSTGH]
Return

$EXEC
    Local Instance GSTPER Using C_GSTPER                                          # Class instance

    # Open a new trace file.
# TODO (DNE): Proper message.
    Call OUVRE_TRACE( TITCRIT ) From LECFIC

    For I = 0 To [M]NBLIG - 1
        If [M]FLGCRE( I ) = 2
            # Create new empty instanace.
            [L]GSTPER = NewInstance C_GSTPER AllocGroup null
            [L]QSTATUS = fmet [L]GSTPER.AINIT()

            # Fill instance.
            [L]GSTPER.CODGSTGRP = [M]CODGSTGRP( I )                               # GST group
            [L]GSTPER.DATSTR    = [M]DATSTR( I )                                  # Period start date
            [L]GSTPER.DATEND    = [M]DATEND( I )                                  # Period end date

            # Try to write instance to database.
            [L]QSTATUS = fmet [L]GSTPER.AINSERT()

            # Error/Message handling.
            If QSTATUS = [V]CST_AOK                                               # Success
                Call ECR_TRACE( mess(42,187,1) - ":" - num$([L]GSTPER.CODGSTPER) - "-" - [M]CODGSTGRP( I ) - "-" - [M]DATSTR( I ) - "-" - [M]DATEND( I ), 0 )  From GESECRAN # 'Record Created'
            Else                                                                  # Error
                Call ECR_TRACE( func AFNC.MES1( mess(54,149,1), num$([L]GSTPER.CODGSTPER) +"~" + [M]CODGSTGRP( I ) + "~" + [M]DATSTR( I ) + "~" + [M]DATEND( I ) ), 1 )  From GESECRAN
            Endif

            # Free memory of class instance.
            FreeGroup [L]GSTPER
       Endif
    Next

    # Trace file handling.
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
Return

