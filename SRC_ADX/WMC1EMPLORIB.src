[L]CURPRO = "BIDCRY"
If vireblc(this.BIDCRY,2)<>""
 If fmet this.AGETATTRIBUTE([L]CURPRO,"$namProParent")=""
  [L]ASTATUS =  func WMTYPCRY.ACTRLREF(this,"BIDCRY",this.BIDCRY,this.BIDCRY,"")
