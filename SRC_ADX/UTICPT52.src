#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# UTICPT52    Module CPT    1099/DAS processing                            #
#             Initialize the new parameter DCLFEES                         #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Initialize the new parameter DCLFEES") From LECFIC

  Call MAJ_UTICPT52(DOSSIER) 

  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTICPT52(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

Call ECR_TRACE("UTICPT52 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Open Tables -----#
If clalev([F:ACV])  =0  Local File =DOSSIER+".ACTIV"   [ACV]  : Endif
If clalev([F:ACV2]) =0  Local File =DOSSIER+".ACTIV"   [ACV2] : Endif
If clalev([F:ADW])  =0  Local File =DOSSIER+".ADOVAL"  [ADW]  : Endif    # Parameter Values

Raz COMPTEUR
Call DEBTRANS From GLOCK

Trbegin [ACV2]

 Readlock [ACV2]CODACT="FEE"    
 If !fstat
  
  # Update the new parameter DCLFEES to DAS (2) if activity code DAS is active.
  If func AFNC.ACTIV("DAS")    
      Readlock [ADW]ADW1="DCLFEES";"";""
      If fstat>1
       Raz [F:ADW]
       [F:ADW]PARAM  = "DCLFEES"
       [F:ADW]VALEUR = "2"     #DAS
       [F:ADW]CREDAT = date$
       [F:ADW]CREUSR = GUSER
       [F:ADW]CRETIM = time
       Write [ADW]
       If !fstat : COMPTEUR +=1 : Endif
      Elsif !fstat
       [F:ADW]VALEUR = "2"     #DAS
       [F:ADW]UPDDAT = date$
       [F:ADW]UPDUSR = GUSER
       [F:ADW]UPDTIM = time
       Rewrite [ADW]
       If !fstat : COMPTEUR +=1 : Endif
      Endif
  Endif

 Endif

Commit

Close Local File [ACV], [ACV2], [ADW]

Call ECR_TRACE("UTICPT52 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN

End

########################################################################
# Executed Automatically during patch integration                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI="X3" : End : Endif

If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI
If fstat : Raz [F:ADS] : Endif

If [F:ADS]MODULE(1)<>2 : End : Endif    # Module CPT active

If filinfo(filpath("FIL","ACTIV","fde",APPLI),0)<=0 : End : Endif  
If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)<=0 : End : Endif  

Call MAJ_UTICPT52(APPLI)  
      
End

#######################################################################
# Executed during Folder validation
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If APPLI="X3" End : Endif

If [F:ADS]MODULE(1)<>2 : End : Endif        # Module CPT active

If filinfo(filpath("FIL","ACTIV","fde",APPLI),0)<=0 : End : Endif  
If filinfo(filpath("FIL","ADOVAL","fde",APPLI),0)<=0 : End : Endif  

Call MAJ_UTICPT52(APPLI)

End
