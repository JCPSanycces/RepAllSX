#<AdxTL>@(#)0.0.0.0 $Revision$Class Protocol
# Supervisor
## CRUD-CLASSE ## EDIPTC
# 2018-11-06 07:04:56 652


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File EDIPTC [EPT_]

If !SILENCE : Call TRACE("2 --> Local Instance C_EDIPTC") From ASYRCOM : Endif
Local Instance EDIPTC Using C_EDIPTC

If !SILENCE : Call TRACE("3 --> New Instance C_EDIPTC") From ASYRCOM : Endif
EDIPTC = NewInstance C_EDIPTC AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [EPT_]EPT0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of EDIPTC") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.AREAD([EPT_]PTCCOD))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("EDIPTC.PTCCOD ="-num$(EDIPTC.PTCCOD)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(EDIPTC.AKEYS)
  Call TRACE("-"-num$(I)-":"-EDIPTC.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [EPT_]
FreeGroup EDIPTC
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(EDIPTC,ACLE,ASTATUS,_ETAG)
Variable Instance EDIPTC Using C_EDIPTC
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Char _PTCCOD(20)
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_PTCCOD = num$([L]CLE(1)) : Endif
Raz [L]_ETAG
Local File EDIPTC [EPT]
Default File [F:EPT]
Read [F:EPT]EPT0 = [L]_PTCCOD
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:EPT]UPDTICK)>0
 [L]_ETAG = num$([F:EPT]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(EDIPTC,ACLE,ASTATUS)
Variable Instance EDIPTC Using C_EDIPTC
Value Char ACLE
Variable Integer ASTATUS
Local Char _PTCCOD(20)
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_PTCCOD = num$([L]CLE(1)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.AREAD([L]_PTCCOD))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(EDIPTC,_PTCCOD,ASTATUS)
Variable Instance EDIPTC Using C_EDIPTC
Value Char _PTCCOD
Variable Integer ASTATUS

If EDIPTC = null : End : Endif

Gosub AVARIABLES From WMC00EDIPTC
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If EDIPTC.APARENT=null
 [L]A_I = EDIPTC.freeSnapshot
 EDIPTC.snapshotEnabled = 0
 EDIPTC.setAccessorEnabled = 0
Endif

Gosub ATRT_AREAD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & EDIPTC.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If EDIPTC.APARENT=null
 EDIPTC.snapshotEnabled = 1
 EDIPTC.setAccessorEnabled = 1
Endif
LogicClose File [EPT] ,[EPTD] ,[EPTM]
End

#-----------------------------------------------------#
$ATRT_AREAD
[L]ASTATUS = max([L]ASTATUS,fmet EDIPTC._ACTION_PARAM("AREAD_BEFORE",[L]_PTCCOD))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Default File [F:EPT]
Read [F:EPT]EPT0 = [L]_PTCCOD
If fstat
[L]A_ERROR = [L]_PTCCOD
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(EDIPTC,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If dim([F:EPT]AUUID)>0 & [F:EPT]AUUID=NullUuid
 [F:EPT]AUUID = getUuid
Endif
SetInstance EDIPTC With [F:EPT]
EDIPTC.ASTALIN = [V]CST_ALL

#-----------------------------------------------------#
If [L]A_LEVEL>=2
 Default File [F:EPTD]
 [L]A_N2=0
 For [F:EPTD]EPTD1 Where PTCCOD=[F:EPT]PTCCOD
  [L]A_N2 +=1
  EDIPTC.EPTD(A_N2) = NewInstance  C_EDIPTCD(EDIPTC.ACTX,NullUuid,[L]A_N2,EDIPTC,"EPTD") AllocGroup EDIPTC
  [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTD(A_N2).ADDINSTANCE_BOUND)
  If dim([F:EPTD]AUUID)>0 & [F:EPTD]AUUID=NullUuid
   [F:EPTD]AUUID = getUuid
  Endif
  SetInstance EDIPTC.EPTD(A_N2) With [F:EPTD]
  [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTD(A_N2).ACTION("AREAD_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  EDIPTC.EPTD(A_N2).ASTALIN = [V]CST_ALL
  [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTD(A_N2).ASETATTRIBUTE("PTCCOD","$namProParent","PTCCOD"))
 Next EPTD
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
If [L]A_LEVEL>=2
 Default File [F:EPTM]
 [L]A_N2=0
 For [F:EPTM]EPTM0 Where PTCCOD=[F:EPT]PTCCOD
  [L]A_N2 +=1
  EDIPTC.EPTM(A_N2) = NewInstance  C_EDIPTCM(EDIPTC.ACTX,NullUuid,[L]A_N2,EDIPTC,"EPTM") AllocGroup EDIPTC
  [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTM(A_N2).ADDINSTANCE_BOUND)
  If dim([F:EPTM]AUUID)>0 & [F:EPTM]AUUID=NullUuid
   [F:EPTM]AUUID = getUuid
  Endif
  SetInstance EDIPTC.EPTM(A_N2) With [F:EPTM]
  [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTM(A_N2).ACTION("AREAD_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  EDIPTC.EPTM(A_N2).ASTALIN = [V]CST_ALL
  [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTM(A_N2).ASETATTRIBUTE("PTCCOD","$namProParent","PTCCOD"))
 Next EPTM
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
#-----------------------------------------------------#

[L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


Return



