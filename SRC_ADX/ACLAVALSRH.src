#<AdxTL>@(#)0.0.0.0 $Revision$
Gosub TEST From ACLAVAL

#Call TEST From ZTEST_ACLAVALSRH
End

$_GENERATE_SRC
MAGIC      = mess(77,133,1) : # Superviseur Adonix
IDENTTRT   = "#"+NOMTRTSRH
IDENTSRH   = "##"-"?IDENTQRY?"-"SEARCH ##"
TITETA     = "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
Call STC_DEB([L]APPLI,[L]MACHINE,[L]NOMTRTSRH,[L]IDENTTRT,[L]CODCLA,IDENTSRH,[L]MAGIC,[L]TITETA,"TRT") From ACLASUB
Call TRT_FIN([L]CLOB,[L]NOMTRTSRH,0,[L]DOSSIER,"TRT",OK,AERR) From ACLASUB
Return

#**
#* VALTRT_SRH : Write and validate a WMSRH treatment
#*!
Subprog VALTRT_SRH(TEST,DOSSIER,CODCLA,ACLA,AERR)
Value Integer TEST
Value Char    DOSSIER
Value Char    CODCLA
Variable     Instance  ACLA  Using C_ACLA
Variable     Instance  AERR(1..) Using C_AERROR

Local Integer I,J
Local Integer OK
Local Char    MACHINE(GDIMFIC) , APPLI(GLONADS)
Local Schar   IDENTTRT(30),IDENTSRH(30)
Local Schar   TITETA(80)
Local Char    MAGIC(80)
Local Clbfile CLOB
Local Integer REPTYPE
Local Integer JNBPRO(0..),JLEVEL
Local Char    ABR(8)
Local Integer BDYNALLOC : BDYNALLOC=0
Local Integer BALLOC
Local Integer LEVEL : LEVEL=1
Local Char    INSCLA(10): INSCLA="INS"
Local Char    SEP1(10),SEP2(10),SEP3(10),SEP4(10),SEP5(5)
Local Char    TYPLNK(2)
Local Char    ST_RAZ_KEYS(250):ST_RAZ_KEYS='Raz '
Local Clbfile ST_KEYS,ST_KEYS2
Local Integer NBRAXX,NBRATX
Local Integer RESCOUNT,RESTBL(1..)
Local Integer MESCOUNT,MESCHPTBL(1..),MESNUMTBL(1..)
Local Integer ISCOLLECTION: ISCOLLECTION=1

Local Char    TAB_ROLFLD(GLONAVB)(1..)
Local Integer NB_ROLFLD

Local File =[L]DOSSIER+".ATABZON"        [ATZ_]
Local File =[L]DOSSIER+".AFONCTION"     [AFC]
Local File =[L]DOSSIER+".AROLE"            [ARL]
Local File =[L]DOSSIER+".AOBJET"           [AOB]
Local File =[L]DOSSIER+".ASHW"            [ASW]

JNBPRO(JLEVEL)=0

If ACLA.TYPCLA=2 :#persistant classe !
 Gosub DEF_VAR_BLOCS
 Gosub DEF_VAR_JSON

 Gosub LOAD_ROLFLD

 Gosub LOAD_BLOCS


 Append BLOCS(BJOIN1), "Link ["+ACLA.ACLAK(1).ABRLNK+"] With"
 Append BLOCS(BJINC1), "Link ["+ACLA.ACLAK(1).ABRLNK+"] With"

 #TABLES
 SEP1=""
 For I=1 To maxtab(ACLA.ACLAK)
  ABR = ACLA.ACLAK(I).ABRLNK
  #Error if the table cannot be opened :
  #SAM 122063 => filinfo
  Append BLOCS(BOPEN1), 'If filinfo(filpath("FIL","'+ACLA.ACLAK(I).TABLNK+'","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif '+chr$(10)
  Call ST_OPEN_TABLE(BLOCS(BOPEN1)  ,ABR ,ACLA.ACLAK(I).TABLNK)
  Call ST_CLOSE_TABLE(BLOCS(BCLOSE1),ACLA.ACLAK(I).ABRLNK)
  If I = 1
   ABR += "_"
   Call ST_OPEN_TABLE(BLOCS(BOPEN2)  ,ABR ,ACLA.ACLAK(I).TABLNK)
   Call ST_CLOSE_TABLE(BLOCS(BCLOSE2),ABR)
  Endif

  Append BLOCS(BOPEN3),"Local Char KEY_"+ACLA.ACLAK(I).ABRLNK+"(120)(1..3)"+chr$(10)
  If I>1 : ST_RAZ_KEYS += ',' : Endif
  ST_RAZ_KEYS+='KEY_'+ACLA.ACLAK(I).ABRLNK+'(1)'


  If I>1
   Append ST_KEYS,chr$(10)
   Append ST_KEYS2,chr$(10)
  Endif

  Append ST_KEYS , "KEY_"+ACLA.ACLAK(I).ABRLNK+"(2) = "
  Append ST_KEYS2, "KEY_"+ACLA.ACLAK(I).ABRLNK+'(3) = "'
  SEP2=""
  SEP5=""
  For J=1 To ACLA.ACLAK(I).NBRIND
   Raz SEP3,SEP4
   Append ST_KEYS2,SEP5
   If ACLA.ACLAK(I).TYPIND(J) <> [V]CST_ATYPCHAR
    SEP3 = "num$("
    SEP4 = ")"
    Append ST_KEYS2,'0'
   Endif
   Append ST_KEYS,SEP2+SEP3+"[F:"+ACLA.ACLAK(I).ABRLNK+"]"+ACLA.ACLAK(I).INDEX(J)+SEP4
   SEP2 = '+"+"+'
   SEP5 = '+'
  Next J
  Append ST_KEYS2,'"'

  If I = 1
   #Create an auto join
   Append BLOCS(BJOIN2), chr$(10)+"& ["+ACLA.ACLAK(I).ABRLNK+"_]"+ACLA.ACLAK(I).CLELNK+"="
   SEP1=","
   SEP2=""
   For J=1 To ACLA.ACLAK(I).NBRIND
    Append BLOCS(BJOIN2), SEP2+"["+ACLA.ACLAK(I).ABRLNK+"]"+ACLA.ACLAK(I).INDEX(J)
    Append BLOCS(BPRIM) , 'ASTDKEY += "'+SEP2+'[F:'+ ACLA.ACLAK(I).ABRLNK+']'+ ACLA.ACLAK(I).INDEX(J)+'"'+chr$(10)
    SEP2 = ";"
   Next J
   Append BLOCS(BJOIN2),","
  Else
   If I = 2
    #Delete the 'auto join'
    Raz BLOCS(BJOIN2),SEP1
   Endif
   Case ACLA.ACLAK(I).TYPLNK
    When 1,2 : #0,1 or 0,n
     TYPLNK="="
    When 3,4 : : #1,1 or 1,n
    TYPLNK="~="
     If instr(1,BLOCS(BJOIN2),TYPLNK)
      # Oracle accepts one and only one outer join
      TYPLNK="="
     Endif
    Endcase

   Append BLOCS(BJOIN2), chr$(10)+"& ["+ACLA.ACLAK(I).ABRLNK+"]"+ACLA.ACLAK(I).CLELNK+TYPLNK+ACLA.ACLAK(I).EXPLNK+","
   SEP1=","
  Endif


  If !find(ACLA.ACLAK(I).TYPLNK,0,3) #3 = 1,1
   BDYNALLOC = 1
  Endif
 Next I


 If BDYNALLOC = 1
  BALLOC = BINS
  Append BLOCS(BINS),ST_KEYS
  Append BLOCS(BINS),chr$(10)
  Append BLOCS(BOPEN3),"#Empty keys :"+chr$(10)
  Append BLOCS(BOPEN3),ST_KEYS2+chr$(10)
 Else
  BALLOC = BCREATE
 Endif
 #Blank line
 Append BLOCS(BINS),chr$(10)

 Call APPEND_CLASSE(TEST,DOSSIER,CODCLA,"null","INS",ACLA,ACLA,ACLA.ACLAK(1).TABLNK,ACLA.ACLAK(1).ABRLNK,AERR,BLOCS,JNBPRO,JLEVEL,BDYNALLOC,1,LEVEL,"KEY_"+ACLA.ACLAK(1).ABRLNK,NBRAXX,NBRATX,RESCOUNT,
& RESTBL,MESCOUNT,MESCHPTBL,MESNUMTBL,ISCOLLECTION,TAB_ROLFLD,NB_ROLFLD)
 Gosub CLOSE_BLOCS

 If maxtab(AERR)>0 : End : Endif

 NOMTRTSRH  = func APREFIXTRT.GET_PREFIX_SEARCH + CODCLA
 Append BLOCS(BRESH), "Gosub  _GET_RES_STRING From "+NOMTRTSRH+'B' +chr$(10)
 Append BLOCS(BRESH), "End RES" +chr$(10)
 Append BLOCS(BMENUH), "Gosub  _GET_RES_MENU From "+NOMTRTSRH+'B' +chr$(10)
 Append BLOCS(BMENUH), "End RES" +chr$(10)

 For I=1 To BMENUH
  Append CLOB,BLOCS(I)
 Next I
 Gosub  _GENERATE_SRC

 Raz CLOB
 For I=BRES To BMENU
  Append CLOB,BLOCS(I)
 Next I

 NOMTRTSRH += 'B'
 Gosub  _GENERATE_SRC

 Close Local File [ATZ_]
Else
 Append CLOB, "Funprog IS_IMPLEMENTED()"+chr$(10)
 Append CLOB, "End 0"+chr$(10)

 Append CLOB, "Funprog APPEND_PROTOTYPE(ACTX,WCLOB,PSYR)" +chr$(10)
 Append CLOB, "Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT" +chr$(10)
 Append CLOB, "Variable Clbfile   WCLOB" +chr$(10)
 Append CLOB, "Variable Instance  PSYR     Using C_ASYR" +chr$(10)
 Append CLOB, "Local Integer ERROR : ERROR = 0" +chr$(10)
 Append CLOB, "Append WCLOB, '{}' " +chr$(10)
 Append CLOB, "End ERROR" +chr$(10)
 NOMTRTSRH  = func APREFIXTRT.GET_PREFIX_SEARCH + CODCLA
 Gosub  _GENERATE_SRC

Endif
End

#**
#* APPEND_CLASSE
#*!
Subprog APPEND_CLASSE(TEST,DOSSIER,CODCLA,INSCLAPAR,INSCLA,ACLAPAR,ACLA,TABLNK,ABRLNK,AERR,BLOCS,JNBPRO,JLEVEL,BDYNALLOC,CRECLA,LEVEL,KEYLNK,NBRAXX,NBRATX,RESCOUNT,RESTBL,MESCOUNT,MESCHPTBL,MESNUMTBL,
& ISCOLLECTION,TAB_ROLFLD,NB_ROLFLD)
Value Integer TEST
Value Char    DOSSIER
Value Char    CODCLA
Value Char    INSCLAPAR
Value Char    INSCLA
Variable   Instance  ACLAPAR  Using C_ACLA
Variable   Instance  ACLA  Using C_ACLA
Variable   Char      TABLNK
Variable   Char      ABRLNK
Variable   Instance  AERR(1..) Using C_AERROR
Variable   Clbfile BLOCS()(1..)
Variable   Integer JNBPRO(0..)
Variable   Integer JLEVEL
Variable   Integer BDYNALLOC
Value      Integer CRECLA
Value      Integer LEVEL
Value      Char    KEYLNK
Variable   Integer NBRAXX
Variable   Integer NBRATX
Variable Integer RESCOUNT
Variable Integer RESTBL(1..)
Variable Integer MESCOUNT
Variable Integer MESCHPTBL(1..)
Variable Integer MESNUMTBL(1..)
Value Integer ISCOLLECTION
Variable Char TAB_ROLFLD()(1..)
Variable Integer NB_ROLFLD

Local Integer G,I,J,F
Local Char    INSCLACOL(50)

Local Char    SEP(1),SEP2(1)
Local Char    FLDCLA(20),FLDPRO(30),FLDTBL(30)
Local Char    SVALUE(250)
Local Char    ATBKEY(250)(1..5)

Local Char    CODGRP(20)(1..)
Local Char    CONDGRP(80)(1..)
Local Char    LNKGRP(60)(1..)
Local Char    ABRGRP(20)(1..)
Local Integer IDXGRP(1..)
Local Integer CRECLAGRP(1..)
Local Integer TYPGRP(1..)
Local Integer NBRGRP

Local Char    ST_ASNDDATA(40),CST_ASNDDATA(40) : CST_ASNDDATA="Append ASND.DATA ,"
Local Char    CST_CI(4) : CST_CI="CI"
Local Char    CST_CJ(4) : CST_CJ="CJ"
Local Char    CST_IS(4) : CST_IS="IS"
Local Char    ST_CI(4) : ST_CI=CST_CI
Local Char    ST_CI2(4) : ST_CI2=CST_CI
Local Char    ST_CJ(4) : ST_CJ=CST_CJ
Local Char    ST_IS(4) : ST_IS=CST_IS
Local Char    ST_IS2(4) :ST_IS2=CST_IS
Local Char    ST_SEPINS(10) : ST_SEPINS="SEPINS"
Local Char    STATEMENT(160)(1..)
Local Char    ST_KEY(160)
Local Char    ST_CJ_MIN(20)
Local Char    ST_FOR_CI(250)
Local Char    ST_BREAK(250)
Local Char    COLMAX(250)
Local Char    LINE(250)
Local Integer BALLOC,INDALLOC
Local Integer MINGRP
Local Integer FLAG
Local Char    CLAIND(GLONAVL)(1..)
Local Char    LKEYLNK(50)
Local Instance  ACLACHILD  Using C_ACLA
Local Instance  ACLACOL    Using C_ACLA
Local Char INSGROUP(10)

Gosub DEF_VAR_BLOCS
Gosub DEF_VAR_JSON

ST_ASNDDATA = CST_ASNDDATA
ST_CI      += num$(LEVEL)
ST_CI2     += num$(LEVEL-1)
ST_CJ      += num$(LEVEL)
ST_SEPINS  += num$(LEVEL)
ST_IS      += num$(LEVEL)
ST_IS2     += num$(LEVEL-1)


If LEVEL = 1
 # Properties belonging to the classe's key are necessarily "searchable"
 For I=1 To maxtab(ACLA.ACLAI)
  Break (ACLA.ACLAI(I) = null)
  CLAIND(I) = ACLA.ACLAI(I).CLEREF
 Next I
Endif


If BDYNALLOC = 1
 BALLOC   = BINS
 INDALLOC = LEVEL
 If len(KEYLNK)
  Call APPEND_LINE(1, BLOCS(BINS), "If ("+KEYLNK+"(2) <> "+KEYLNK+"(3)) & ("+KEYLNK+"(1) <> "+KEYLNK+"(2))")
 Endif
 If LEVEL = 1
  Call APPEND_LINE(1, BLOCS(BINS), ' If INS <> null')
  Call APPEND_LINE(1, BLOCS(BINS), '  [L]ASTATUS = fmet INS.ACTION("ASEARCH_TRANS_AFTER")')
  Call APPEND_LINE(1, BLOCS(BINS), '  #serialize INS')
  Call APPEND_LINE(1, BLOCS(BINS), '  Gosub ASEARCH_TO_JSON')
  Call APPEND_LINE(1, BLOCS(BINS), ' Endif')
 Endif

 If len(KEYLNK) > 0
  ST_KEY  = " "+KEYLNK+"(1) = "+KEYLNK+"(2)"+chr$(10)
  ST_KEY += "Endif : # "+KEYLNK+"(1) <> "+KEYLNK+"(2)"+chr$(10)
 Endif
Else
 BALLOC   = BCREATE
 INDALLOC = 1
Endif

Call APPEND_LINE(INDALLOC, BLOCS(BALLOC), '#Create a new instance')
If instr(1,INSCLA,'.')
 INSGROUP = "INS"
Else
 INSGROUP = "null"
Endif
Call APPEND_LINE(INDALLOC, BLOCS(BALLOC), INSCLA+" = NewInstance C_"+CODCLA+'(GACTX,UIDINS,NUMLIN,'+INSCLAPAR+',"") AllocGroup '+INSGROUP)
Call APPEND_LINE(INDALLOC, BLOCS(BALLOC), INSCLA+".setaccessorEnabled = 0")
If CRECLA=1
 Call APPEND_LINE(INDALLOC, BLOCS(BINS), "SetInstance "+INSCLA+" With [F:"+ABRLNK+"]")
Endif
If LEVEL =1
 Call APPEND_LINE(INDALLOC, BLOCS(BINS), "FINS = 1")
Endif

#List of "searchable" collections :
For G=1 To ACLA.NBRGRP
 For I=1 To maxtab(ACLA.ACLAF)
  If ACLA.CODGRP(G) = ACLA.ACLAF(I).FLDGRP & (ACLA.ACLAF(I).FLDSEARCH=2 or find(ACLA.ACLAF(I).FLDCLA,TAB_ROLFLD)>0)
   #One more searchable group
   NBRGRP +=1
   IDXGRP(NBRGRP)      = G
   CODGRP(NBRGRP)      = ACLA.CODGRP(G)
   CRECLAGRP(NBRGRP)   = ACLA.CRECLAGRP(G)

   If len(ACLA.PROGRP(G)) > 0
    # trick : >= instead of = in order to be able tu cumulate logical statements
    CONDGRP(NBRGRP) =  ST_CI+ ' > [F:' + ABRLNK+']'+ACLA.PROGRP(G) :
   Endif

   If ACLA.CRECLAGRP(G) = 2
    #collection of nested classes
    TYPGRP(NBRGRP) = NBRGRP
   Else
    #collection of instances
    TYPGRP(NBRGRP) = ACLA.NBRGRP + NBRGRP
    LNKGRP(NBRGRP) = ACLA.ACLAF(I).LNKCLA
    For J=1 To maxtab(ACLAPAR.ACLAK)
     If ACLAPAR.ACLAK(J).CLALNK =ACLA.ACLAF(I).LNKCLA
      ABRGRP(NBRGRP) = ACLAPAR.ACLAK(J).ABRLNK
      Break
     Endif
    Next J
   Endif
   #Next group !
   Break
  Endif
 Next I
Next G

Sorta NBRGRP TYPGRP, CODGRP, CONDGRP, LNKGRP, ABRGRP, IDXGRP,CRECLAGRP Order By TYPGRP(indice+1)


If LEVEL = 1
 Call APPEND_LINE(LEVEL, BLOCS(BJSON2), "Append ASND.DATA ,SEPINS1")
 Call APPEND_LINE(LEVEL, BLOCS(BJSON2), "SEPINS1 = ','+chr$(10)")
 Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ST_ASNDDATA + "'{'" )
Elsif ISCOLLECTION
 Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ST_ASNDDATA + ST_IS2+"+'{'" )
Endif

#First loop on classe's properties :
SEP = ""
For I=1 To maxtab(ACLA.ACLAF)
 If len(ACLA.ACLAF(I).FLDGRP) = 0
& & (ACLA.ACLAF(I).FLDSEARCH=2 or find(ACLA.ACLAF(I).FLDCLA , CLAIND) or find(ACLA.ACLAF(I).FLDCLA,TAB_ROLFLD)>0) or (ACLA.ACLAF(I).FLDCLA = ACLA.ACCSTR)

  #Prototype of the field :
  Gosub PRO_FLDCLA

  FLDTBL = '[F:' + ABRLNK+']'+ACLA.ACLAF(I).FLDCLA
  If ACLA.ACLAF(I).FLDCLA = ACLA.ACCSTR
   FLDCLA = left$(SEP+'"'+"$access"+'":'+"'"+string$(20,' '),20)
  Else
   FLDCLA = left$(SEP+'"'+ACLA.ACLAF(I).FLDCLA+'":'+"'"+string$(20,' '),20)
  Endif
  SVALUE = INSCLA +'.'+ACLA.ACLAF(I).FLDCLA

  Case ACLA.ACLAF(I).ATY.CODTYP
  When "AXX","AX1","AX2","AX3"
   #TODO If LEVEL = 1
    Gosub DEL_SELF_JOIN
    NBRAXX +=1
    #Call APPEND_LINE(1, BLOCS(BOPEN2) , "If clalev([F:AXX_"+num$(NBRAXX)+"])=0 : Local File ATEXTRA [AXX_"+num$(NBRAXX)+"] : Endif")
    Call APPEND_LINE(1, BLOCS(BOPEN2) , "Local File ATEXTRA [AXX_"+num$(NBRAXX)+"]")
    Call APPEND_LINE(1, BLOCS(BCLOSE2), "LogicClose File [AXX_"+num$(NBRAXX)+"]")

    Raz ATBKEY
    For J=1 To maxtab(ACLA.ACLAF(I).ATBKEY)
     Case ACLA.ACLAF(I).ATBKEY(J).CODPAR
      When "CODFIC"  : ATBKEY(1) = ACLA.ACLAF(I).ATBKEY(J).VALEUR
      When "ZONE"    : ATBKEY(2) = ACLA.ACLAF(I).ATBKEY(J).VALEUR
      When "LANGUE"  : ATBKEY(3) = ACLA.ACLAF(I).ATBKEY(J).VALEUR
       If left$(ATBKEY(3),4)="ACTX" : ATBKEY(3)="G"+ATBKEY(3) : Endif
      When "IDENT1"  : ATBKEY(4) = func COMPUTE_ATBKEY(TABLNK,ABRLNK, ACLA.ACLAF(I).ATBKEY(J))
      When "IDENT2"  :
       If CRECLA=2
        ATBKEY(5) = "num$("+ST_CI2+")"
       Else
        ATBKEY(5) = func COMPUTE_ATBKEY(TABLNK,ABRLNK, ACLA.ACLAF(I).ATBKEY(J))
       Endif
     Endcase
    Next J

    If CRECLA=2
     LINE = 'Read [F:AXX_'+num$(NBRAXX)+']AXX0 = '
     SEP2=""
     For J=1 To 5
      LINE += SEP2+ATBKEY(J)
      SEP2 = ";"
     Next J
     Call APPEND_LINE(LEVEL, BLOCS(BINS) ,LINE)
     Call APPEND_LINE(LEVEL, BLOCS(BINS) ,"If !fstat")
    Endif
    LINE  = 'Call ASETTEXTRA('+INSCLA+'.AXX,'
    LINE +=  INSCLA+'.ALLOCGRP(),'
    LINE +=  '"'+ACLA.ACLAF(I).FLDCLA+'",'
    LINE +=  '[F:AXX_'+num$(NBRAXX)+ ']TEXTE,'
    LINE +=  'GACTX.LAN) From ASYRSUB' :#SAM 98298


    If CRECLA=2
     Call APPEND_LINE(LEVEL+1, BLOCS(BINS),LINE)
     Call APPEND_LINE(LEVEL, BLOCS(BINS) ,"Endif")
    Else
     Call APPEND_LINE(INDALLOC, BLOCS(BINS),LINE)

     Raz LINE
     LINE += chr$(10) + '& [F:AXX_'+num$(NBRAXX)+']AXX0 = '
     SEP2=""
     For J=1 To 5
      LINE += SEP2+ATBKEY(J)
      SEP2 = ";"
     Next J
     LINE += ","
     Call APPEND_STATEMENT(LEVEL, BLOCS(BJOIN2) ,LINE)
    Endif
    #TODO Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ST_ASNDDATA+"'"+FLDCLA+ " : SVALUE = "+SVALUE+" : Gosub APPEND_JSTRING From ASYRSRH")
    Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ST_ASNDDATA+"'"+FLDCLA)
    Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ST_ASNDDATA+"'"+'"'+"'")
    Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ST_ASNDDATA+'escJson(func ASYRSUB.AGETTEXTRA('+INSCLA+'.AXX,"'+ACLA.ACLAF(I).FLDCLA+'",GACTX.LAN))')
    Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ST_ASNDDATA+"'"+'"'+"'")
    SVALUE
   #TODO Endif
  When "ATX"
   #TODO If LEVEL = 1
    Gosub DEL_SELF_JOIN
    NBRATX +=1
#    Call APPEND_LINE(1, BLOCS(BOPEN2) , "If clalev([F:ATX_"+num$(NBRATX)+"])=0 : Local File ATEXTE [ATX_"+num$(NBRATX)+"] : Endif")
#    Call APPEND_LINE(1, BLOCS(BCLOSE2), "Close Local File [ATX_"+num$(NBRATX)+"]")
    Call APPEND_LINE(1, BLOCS(BOPEN2) , "Local File ATEXTE [ATX_"+num$(NBRATX)+"]")
    Call APPEND_LINE(1, BLOCS(BCLOSE2), "LogicClose File [ATX_"+num$(NBRATX)+"]")

    LINE  = 'Call ASETTEXT('+INSCLA+'.ATX,'
    LINE +=  INSCLA+'.ALLOCGRP(),'
    LINE +=  '"'+ACLA.ACLAF(I).FLDCLA+'",'
    LINE +=  '[F:ATX_'+num$(NBRATX)+ ']TEXTE,'
    LINE +=  '[F:ATX_'+num$(NBRATX)+ ']LAN,'
    LINE +=  '[F:ATX_'+num$(NBRATX)+ ']NUMERO) From ASYRSUB'

    If CRECLA=2
     LINE = 'Read [F:ATX_'+num$(NBRATX)+']NUMERO = GACTX.LAN;[F:'+ABRLNK+']'+ ACLA.ACLAF(I).FLDCLA + ","
     Call APPEND_STATEMENT(LEVEL, BLOCS(BINS) ,LINE)

     Call APPEND_LINE(LEVEL  , "If fstat!")
     Call APPEND_LINE(LEVEL+1, BLOCS(BINS),LINE)
     Call APPEND_LINE(LEVEL  , "Endif")
    Else
     Call APPEND_LINE(INDALLOC, BLOCS(BINS),LINE)
     LINE = chr$(10) + '& [F:ATX_'+num$(NBRATX)+']NUMERO = GACTX.LAN;[F:'+ABRLNK+']'+ ACLA.ACLAF(I).FLDCLA + ","
     Call APPEND_STATEMENT(LEVEL, BLOCS(BJOIN2) ,LINE)
    Endif
    #TODO remove Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ST_ASNDDATA+"'"+FLDCLA+ ' : SVALUE = func ASYRSUB.AGETTEXT('+INSCLA+'.ATX,"'+ACLA.ACLAF(I).FLDCLA+'",GACTX.LAN) : Gosub APPEND_JSTRING From
# ASYRSRH')
    Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ST_ASNDDATA+"'"+FLDCLA)
    Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ST_ASNDDATA+"'"+'"'+"'")
    Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ST_ASNDDATA+'escJson(func ASYRSUB.AGETTEXT('+INSCLA+'.ATX,"'+ACLA.ACLAF(I).FLDCLA+'",GACTX.LAN))')
    Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ST_ASNDDATA+"'"+'"'+"'")
#TODO Endif
  When Default
    If CRECLA=2
     Call APPEND_LINE(LEVEL, BLOCS(BINS), SVALUE +'=' + FLDTBL + '('+ST_CI2+')')
    Endif

   Case ACLA.ACLAF(I).ATY.TYPTYP
    When 1
     If find(ACLA.ACLAF(I).FLDCLA , CLAIND)=0 : # 118725
      Call APPEND_LINE(LEVEL, BLOCS(BJSON2), '')
      Call APPEND_LINE(LEVEL, BLOCS(BJSON2), "if("+SVALUE+") = 2")
      Call APPEND_LINE(LEVEL, BLOCS(BJSON2), " " + ST_ASNDDATA +" '"+FLDCLA+'+"true"')
      Call APPEND_LINE(LEVEL, BLOCS(BJSON2), "else")
      Call APPEND_LINE(LEVEL, BLOCS(BJSON2), " " + ST_ASNDDATA +" '"+FLDCLA+'+"false"')
      Call APPEND_LINE(LEVEL, BLOCS(BJSON2), "endif")
     Else
      Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ST_ASNDDATA+"'"+FLDCLA+" + num$("+SVALUE+")")
     Endif
    When 2,3,4,10
     Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ST_ASNDDATA+"'"+FLDCLA+" + num$("+SVALUE+")")
    When 7
    Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ST_ASNDDATA+"'"+FLDCLA+'+'+"'"+'"'+"'"+'+'+"escJson("+SVALUE+")"+'+'+"'"+'"'+"'")
    When 5,8
     Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ST_ASNDDATA+"'"+FLDCLA+" + func ASYRSRH.DATE_TO_SYR("+SVALUE+")")
    When 6
     Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ST_ASNDDATA+"'"+FLDCLA+" + '" + '"' + "' + func ASYRSUB.TIME_TO_SYR("+SVALUE+") + '"+'"'+"'")
    When 11
     Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ST_ASNDDATA+"'"+FLDCLA+" + '" + '"' + "' + num$("+SVALUE+") + '"+'"'+"'")
   Endcase
  Endcase
  SEP = ","
 Endif
Next I

#Loop on collections :
FLAG=1
For G=1 To NBRGRP
 If FLAG
  Call APPEND_LINE(1, BLOCS(BCREATE), "Local Integer "+ST_CI)
  Call APPEND_LINE(1, BLOCS(BCREATE), "Local Integer "+ST_CJ)
  Call APPEND_LINE(1, BLOCS(BCREATE), 'Local Char    '+ST_SEPINS+'(2) : '+ST_SEPINS+'=""')
  Call APPEND_LINE(1, BLOCS(BCREATE), 'Local Char '+ST_IS+'(1)'+chr$(10))

  FLAG=0
 Endif

 Local Integer CHILD_ISCOLLECTION : CHILD_ISCOLLECTION=0
 If !(ACLA.MINGRP(IDXGRP(G)) = 2 & ACLA.MAXGRP(IDXGRP(G)) = 1)
  CHILD_ISCOLLECTION = 1
  #It isn't a 1x1 collection = OBJECT!
  #Prototype :
  JPRONAM = CODGRP(G) : Gosub PRO_START_OBJECT
  JPRONAM = '$type'   : JPROVAL = func ASYRJSO.TYP('array') : Gosub PRO_APPEND_PROPERTY_TEXT

  ST_CJ_MIN = ST_CJ+"=0"
  MINGRP = -1
  If ACLA.MINGRP(IDXGRP(G)) > 0
   Case ACLA.MINGRP(IDXGRP(G))
    When 1 : MINGRP = 0 :#0
    When 2 : MINGRP = 1 :#1
    When 3 : MINGRP = ACLA.MAXGRP(IDXGRP(G)):#Maxium
   Endcase

   JPRONAM = '$minItems'  : JPROVAL =  num$(MINGRP) : Gosub PRO_APPEND_PROPERTY_NUM
   ST_CJ_MIN = ST_CJ+"="+ num$(1)
  Endif

  #Create :
  If ACLA.MAXGRP(IDXGRP(G)) > 0
   JPRONAM = '$maxItems'  :JPROVAL =  num$(ACLA.MAXGRP(IDXGRP(G))) : Gosub PRO_APPEND_PROPERTY_NUM
  Endif

  #Create :
  JPRONAM = '$item'       : Gosub PRO_START_OBJECT
  JPRONAM = '$type'       : JPROVAL = 'application/json' : Gosub PRO_APPEND_PROPERTY_TEXT
  JPRONAM = '$properties' : Gosub PRO_START_OBJECT
 Else
   #CHILD_ISCOLLECTION = 0
   Call APPEND_LINE(1, BLOCS(BALLOC), ST_CJ+"=1")
   ST_CJ_MIN = ST_CJ+"=1"
 Endif
 ##TODO REMOVE JPRONAM = '$properties' : Gosub PRO_START_OBJECT

 ACLACHILD = null
 If CRECLAGRP(G) = 2
  #It's a nested collection
  LKEYLNK=""
  For J=1 To maxtab(ACLA.ACLACOL)
   If ACLA.ACLACOL(J) <> null & ACLA.ACLACOL(J).CODCLA = CODCLA + '_' + CODGRP(G)
    ACLACHILD = ACLA.ACLACOL(J)
    Break
   Endif
  Next J
  If ACLACHILD = null
   #The classe wasn't found in the collection
   J = maxtab(ACLA.ACLACOL)+1
   ACLA.ACLACOL(J)  = NewInstance C_ACLA AllocGroup ACLA
   Call LOAD_CLASSE(TEST,DOSSIER,CODCLA+"_"+CODGRP(G),2,CODGRP(G),ACLA.ACLACOL(J),AERR) From ACLAVALLEC
   ACLACHILD = ACLA.ACLACOL(J)
  Endif

  If ACLACHILD <> null
    # Issue X3-47119 - 2018-10-08 by CCC
    # collection_name_MAXI = maximum number of elements in the collection based on dimension of the smallest searchable field
    # collection_name_MAX  = actual number of elements added in the collection
    #COLMAX = ACLACHILD.ACLAF(1).FLDCLA+"_MAX"
    #Call APPEND_LINE(LEVEL, BLOCS(BINS),"Local Integer "+COLMAX+":"+COLMAX+"0")    :#Breaking condition
    COLMAXI = CODGRP(G)+"_MAXI"
    Call APPEND_LINE(LEVEL, BLOCS(BALLOC),"Local Integer "+COLMAXI+":"+COLMAXI+"= 0")
    Call APPEND_LINE(LEVEL, BLOCS(BINS),"Local Integer "+COLMAXI+":"+COLMAXI+"= 0")
    COLMAX = CODGRP(G)+"_MAX"
    Call APPEND_LINE(LEVEL, BLOCS(BINS),"Local Integer "+COLMAX+":"+COLMAX+"=0")    :#Breaking condition
    For F=1 To maxtab(ACLACHILD.ACLAF)
        If ACLACHILD.ACLAF(F).FLDSEARCH=2
            # Calculation for "$ASEARCH_CREATEINSTANCE"
            Call APPEND_LINE(LEVEL, BLOCS(BALLOC),'If dim([F:'+ABRLNK+"]"+ACLACHILD.ACLAF(F).FLDCLA+")>0")
            Call APPEND_LINE(LEVEL, BLOCS(BALLOC),'    If '+CODGRP(G)+'_MAXI = 0')
            Call APPEND_LINE(LEVEL, BLOCS(BALLOC),'        '+CODGRP(G)+'_MAXI = dim([F:'+ABRLNK+"]"+ACLACHILD.ACLAF(F).FLDCLA+")")
            Call APPEND_LINE(LEVEL, BLOCS(BALLOC),'    Else')
            Call APPEND_LINE(LEVEL, BLOCS(BALLOC),'        '+CODGRP(G)+'_MAXI = min('+CODGRP(G)+'_MAXI,dim([F:'+ABRLNK+"]"+ACLACHILD.ACLAF(F).FLDCLA+"))")
            Call APPEND_LINE(LEVEL, BLOCS(BALLOC),'    Endif')
            Call APPEND_LINE(LEVEL, BLOCS(BALLOC),'Endif')

            # Calculation for "$ASEARCH_SETINSTANCE"
            Call APPEND_LINE(LEVEL, BLOCS(BINS),'If dim([F:'+ABRLNK+"]"+ACLACHILD.ACLAF(F).FLDCLA+")>0")
            Call APPEND_LINE(LEVEL, BLOCS(BINS),'    If '+CODGRP(G)+'_MAXI = 0')
            Call APPEND_LINE(LEVEL, BLOCS(BINS),'        '+CODGRP(G)+'_MAXI = dim([F:'+ABRLNK+"]"+ACLACHILD.ACLAF(F).FLDCLA+")")
            Call APPEND_LINE(LEVEL, BLOCS(BINS),'    Else')
            Call APPEND_LINE(LEVEL, BLOCS(BINS),'        '+CODGRP(G)+'_MAXI = min('+CODGRP(G)+'_MAXI,dim([F:'+ABRLNK+"]"+ACLACHILD.ACLAF(F).FLDCLA+"))")
            Call APPEND_LINE(LEVEL, BLOCS(BINS),'    Endif')
            Call APPEND_LINE(LEVEL, BLOCS(BINS),'Endif')
        Endif
    Next

    #ST_FOR_CI = 'For '+ST_CI+' = 0 To dim([F:'+ABRLNK+"]"+ACLACHILD.ACLAF(1).FLDCLA+")-1"
    ST_FOR_CI = 'For '+ST_CI+' = 0 To '+COLMAXI+"-1"

   ST_BREAK = " Break ("
   If len(CONDGRP(G)) > 0
    ST_BREAK  += '('+CONDGRP(G) + ')'
    If MINGRP >= 0
     ST_BREAK += ' & ('+ ST_CJ +' >= '+num$(MINGRP)+')'
    Endif
   Else
    OP =""
    For F=1 To maxtab(ACLACHILD.ACLAF)
     If ACLACHILD.ACLAF(F).FLDSEARCH=2
      ST_BREAK+= OP + '[F:' + ABRLNK+']'+ACLACHILD.ACLAF(F).FLDCLA + '('+ST_CI+')='
      If find(ACLACHILD.ACLAF(F).ATY.TYPTYP,1,2,3,4,10)
       ST_BREAK+=  '0'
      Else
       ST_BREAK+= '""'
      Endif
      OP= " & "
     Endif
    Next F
   Endif
   ST_BREAK += ')'
  Endif
 Else
  #It's a collection of instances :
  If len(ST_KEY) > 0
   #IF KEY_1 <> KEY_2
   Call APPEND_LINE(1, BLOCS(BINS), ST_KEY)
   Raz ST_KEY
  Endif

  For J=1 To maxtab(ACLA.ACLAK)
   If ACLA.ACLAK(J).CLALNK=LNKGRP(G)
    ACLACHILD = ACLA.ACLAK(J).ACLALNK
    ABRLNK    = ACLA.ACLAK(J).ABRLNK
    TABLNK    = ACLA.ACLAK(J).TABLNK
    LKEYLNK   = "KEY_"+ABRLNK
    Break
   Endif
  Next J
 Endif

 If ACLACHILD <> null
  #CJ1=1
  #For CI1 = 0 To dim([F:ACD]RAN)-1
  If BDYNALLOC=0  &  (CRECLAGRP(G) = 2)
   Call APPEND_LINE(LEVEL, BLOCS(BALLOC) ,ST_CJ_MIN) #set class data
   Call APPEND_LINE(LEVEL, BLOCS(BALLOC), ST_FOR_CI) :#For CIn = 0 To dim(FIELD)-1
  Endif

  If CRECLAGRP(G) = 2
   #it's a nested collection
   Call APPEND_LINE(LEVEL, BLOCS(BINS),ST_CJ_MIN) #set class data
   Call APPEND_LINE(LEVEL, BLOCS(BINS),ST_FOR_CI)
   Call APPEND_LINE(LEVEL, BLOCS(BINS),ST_BREAK)    :#Breaking condition
   Call APPEND_LINE(LEVEL, BLOCS(BINS)," "+COLMAX+"+=1")    :#Breaking condition

  Else
   If CHILD_ISCOLLECTION
    Call APPEND_LINE(LEVEL, BLOCS(BINS) ,ST_CJ+"=maxtab("+INSCLA + "." + CODGRP(G)+")+1") #set class data
   Else
    Call APPEND_LINE(LEVEL, BLOCS(BINS) ,ST_CJ+"=1") #set class data
   Endif
  Endif

  Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ST_IS+'=""')
  Call APPEND_LINE(LEVEL, BLOCS(BJSON2) ,ST_CJ_MIN)
  If CHILD_ISCOLLECTION
   Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ST_ASNDDATA+"'"+SEP+'"'+CODGRP(G)+ '"'+ ":['")
  Else
   Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ST_ASNDDATA+"'"+SEP+"'")
  Endif
  If len(COLMAX)
   Call APPEND_LINE(LEVEL, BLOCS(BJSON2), "For "+ST_CI+"=1 To "+COLMAX)
   Raz COLMAX
  Else
   Call APPEND_LINE(LEVEL, BLOCS(BJSON2), "For "+ST_CI+"=1 To maxtab("+INSCLA +'.' + CODGRP(G)+")")
  Endif

  INSCLACOL = INSCLA + "." + CODGRP(G) + "(" + ST_CJ + ")"

  Raz TAB_ROLFLD,NB_ROLFLD
  Call APPEND_CLASSE(TEST,DOSSIER,ACLACHILD.CODCLA,INSCLA,INSCLACOL,ACLA,ACLACHILD,TABLNK,ABRLNK,AERR,BLOCS,JNBPRO,JLEVEL,BDYNALLOC,CRECLAGRP(G),LEVEL+1,LKEYLNK,NBRAXX,NBRATX,RESCOUNT,RESTBL,MESCOUNT
& ,MESCHPTBL,MESNUMTBL,CHILD_ISCOLLECTION,TAB_ROLFLD,NB_ROLFLD)


  Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ' '+ST_IS+'=","')
  Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ' '+ST_CJ+'+=1')
  Call APPEND_LINE(LEVEL, BLOCS(BJSON2), "Next "+ST_CI)
  ST_ASNDDATA = CST_ASNDDATA
  If CHILD_ISCOLLECTION
   Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ST_ASNDDATA+' "]"')
  Endif
  #CJ1+=1
  #Next CI1
  If BDYNALLOC=0 &  (CRECLAGRP(G) = 2)
   Call APPEND_LINE(LEVEL, BLOCS(BALLOC), ' '+ST_CJ+'+=1')
   Call APPEND_LINE(LEVEL, BLOCS(BALLOC), "Next "+ST_CI)
  Endif

  If CRECLAGRP(G) = 2
   #it's a nested collection
   Call APPEND_LINE(LEVEL, BLOCS(BINS), ' '+ST_CJ+'+=1')
   Call APPEND_LINE(LEVEL, BLOCS(BINS), "Next "+ST_CI)
  Endif
 Endif :#ACLACHILD <> null
 If CHILD_ISCOLLECTION
  Gosub PRO_END_OBJECT : #$properties
  Gosub PRO_END_OBJECT : #$type
  Gosub PRO_END_OBJECT : #$item
 Endif
Next G :#For G=1 To NBRGRP

If ISCOLLECTION
 Call APPEND_LINE(LEVEL, BLOCS(BJSON2), ST_ASNDDATA+"'}'")
Endif

If len(ST_KEY) > 0
 #IF KEY_1 <> KEY_2
 Call APPEND_LINE(1, BLOCS(BINS), ST_KEY)
Endif

# TREATMENTS
For I=1 To ACLA.NBRTRT
 If ACLA.ACLATRT(I).CODTRT<>""
  Call APPEND_LINE(LEVEL, BLOCS(BACTION),"Gosub METHODS From " + ACLA.ACLATRT(I).CODTRT)
 Endif
Next
End

#**
#* APPEND_LINE
#*
#* @param INDENT
#* @param BLOC
#* @param LINE
#*!
Subprog APPEND_LINE(INDENT,BLOC,LINE)
Value Integer    INDENT
Variable Clbfile BLOC
Value    Char    LINE
LINE += chr$(10)
Goto _APPEND_STATEMENT

Subprog APPEND_STATEMENT(INDENT,BLOC,LINE)
Value Integer    INDENT
Variable Clbfile BLOC
Value    Char    LINE

$_APPEND_STATEMENT
Append BLOC,string$(INDENT-1," ")+LINE
End

$DEF_VAR_BLOCS
Local Integer NBLOCS : NBLOCS=0
Local Integer BOPEN1,BOPEN2,BOPEN3
Local Integer BCLOSE1,BCLOSE2,BCLOSE3
Local Integer BJOIN1,BJOIN2,BJOIN3
Local Integer BJINC1,BJINC2,BJINC3
Local Integer BCREATE
Local Integer BINS
Local Integer BJSON1,BJSON2
Local Integer BPRIM
Local Integer BACTION
Local Integer BERROR
Local Integer BRESH,BRES
Local Integer BMENUH,BMENU
Local Integer BPROTO
NBLOCS +=1 : BOPEN1  = NBLOCS
NBLOCS +=1 : BOPEN2  = NBLOCS
NBLOCS +=1 : BOPEN3  = NBLOCS
NBLOCS +=1 : BCLOSE1 = NBLOCS
NBLOCS +=1 : BCLOSE2 = NBLOCS
NBLOCS +=1 : BCLOSE3 = NBLOCS
NBLOCS +=1 : BJOIN1  = NBLOCS
NBLOCS +=1 : BJOIN2  = NBLOCS
NBLOCS +=1 : BJOIN3  = NBLOCS
NBLOCS +=1 : BJINC1  = NBLOCS
NBLOCS +=1 : BJINC2  = NBLOCS
NBLOCS +=1 : BJINC3  = NBLOCS
NBLOCS +=1 : BCREATE = NBLOCS
NBLOCS +=1 : BINS  = NBLOCS
NBLOCS +=1 : BJSON1  = NBLOCS
NBLOCS +=1 : BJSON2  = NBLOCS
NBLOCS +=1 : BERROR  = NBLOCS
NBLOCS +=1 : BPRIM   = NBLOCS
NBLOCS +=1 : BACTION = NBLOCS
NBLOCS +=1 : BPROTO  = NBLOCS
NBLOCS +=1 : BRESH  = NBLOCS
NBLOCS +=1 : BMENUH  = NBLOCS
NBLOCS +=1 : BRES  = NBLOCS
NBLOCS +=1 : BMENU = NBLOCS
Return
#**
#* LOAD_BLOCS
#*!
$LOAD_BLOCS

Local Clbfile BLOCS(2)(1..NBLOCS)
Local Char CLASSTITLE(250)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ASYRSYS

Append BLOCS(BOPEN1), "Funprog IS_IMPLEMENTED()"+chr$(10)
Append BLOCS(BOPEN1), "End 1"+chr$(10)

Call ST_TAG(BLOCS(BOPEN1)  ,"ASEARCH_OPEN" ,"List of tables to open")
Call ST_TAG(BLOCS(BCLOSE1) ,"ASEARCH_CLOSE","List of tables to close")
Call ST_TAG(BLOCS(BJOIN1) ,"ASEARCH_JOIN" ,"List of tables to join")
Call ST_TAG(BLOCS(BJINC1) ,"ASEARCH_JOIN_INC" ,"List of tables to join")
Call ST_TAG(BLOCS(BCREATE),"ASEARCH_CREATEINSTANCE" ,"Create an instance of")
Append BLOCS(BCREATE), "Local Integer ASTATUS"+chr$(10)
Append BLOCS(BCREATE), "Local Integer FINS"+chr$(10)

Call ST_TAG(BLOCS(BINS)  ,"ASEARCH_SETINSTANCE" ,"Set an instance")
Call ST_TAG(BLOCS(BJSON1)  ,"ASEARCH_TO_JSON" ,"Serialize the entity in a JSON format")
Append BLOCS(BJSON1), "If FINS=0 : Return : Endif"+chr$(10)
Append BLOCS(BJSON1), "QCOUNT += 1"+chr$(10)
Append BLOCS(BJSON1), 'Onerrgo ERROR_VALUE'+chr$(10)

Call ST_TAG(BLOCS(BPRIM)  ,"AQUERY_PRIMARYKEYS" ,"Link standard key")
Append BLOCS(BPRIM), "Local Char ASTDKEY(250)" +chr$(10)
Append BLOCS(BPRIM), 'ASTDKEY = ""'+chr$(10)

Call ST_TAG(BLOCS(BACTION),"ASEARCH_ACTION" ,"Actions")
Append BLOCS(BACTION),"Local Char CURPRO(250),CURPTH(250),AMETHOD(50),AEVENT(50)"+chr$(10)
Append BLOCS(BACTION),"[L]AEVENT = [L]ACTION"+chr$(10)
Call ST_TAG(BLOCS(BERROR),"ERROR_VALUE" ,"Errors")
Append BLOCS(BERROR), "SVALUE =" + "'"+ '"<error' + "'" + "-errmes$(errn)+" + "'"+  '>"'+ "'" +chr$(10)

Append BLOCS(BRESH), "#---------------------------------------------------------------------------------------------------#" +chr$(10)
Append BLOCS(BRESH), "# GET_RES_STRING" +chr$(10)
Append BLOCS(BRESH), "#---------------------------------------------------------------------------------------------------#" +chr$(10)
Append BLOCS(BRESH), "Funprog GET_RES_STRING(_LAN,_ID)" +chr$(10)
Append BLOCS(BRESH), "Value Char _LAN" +chr$(10)
Append BLOCS(BRESH), "Value Integer _ID" +chr$(10)

Append BLOCS(BRES), "#---------------------------------------------------------------------------------------------------#" +chr$(10)
Append BLOCS(BRES), "$_GET_RES_STRING" +chr$(10)
Append BLOCS(BRES), "Local Char RES(250)" +chr$(10)

Append BLOCS(BMENUH), chr$(10)
Append BLOCS(BMENUH), "#---------------------------------------------------------------------------------------------------#" +chr$(10)
Append BLOCS(BMENUH), "# GET_RES_MENU" +chr$(10)
Append BLOCS(BMENUH), "#---------------------------------------------------------------------------------------------------#" +chr$(10)
Append BLOCS(BMENUH), "Funprog GET_RES_MENU(_LAN,_ID)" +chr$(10)
Append BLOCS(BMENUH), "Value Char _LAN" +chr$(10)
Append BLOCS(BMENUH), "Value Char _ID" +chr$(10)

Append BLOCS(BMENU), "#---------------------------------------------------------------------------------------------------#" +chr$(10)
Append BLOCS(BMENU), "$_GET_RES_MENU" +chr$(10)
Append BLOCS(BMENU), "Local Char RES(250)" +chr$(10)


Append BLOCS(BPROTO), "#---------------------------------------------------------------------------------------------------#" +chr$(10)
Append BLOCS(BPROTO), "# APPEND_PROTOTYPE" +chr$(10)
Append BLOCS(BPROTO), "#---------------------------------------------------------------------------------------------------#" +chr$(10)

Append BLOCS(BPROTO), "Funprog APPEND_PROTOTYPE(ACTX,WCLOB,PSYR)" +chr$(10)
Append BLOCS(BPROTO), "Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT" +chr$(10)
Append BLOCS(BPROTO), "Variable Clbfile   WCLOB" +chr$(10)
Append BLOCS(BPROTO), "Variable Instance  PSYR     Using C_ASYR" +chr$(10)
Append BLOCS(BPROTO), "Local Integer ERROR : ERROR = 0" +chr$(10)
Append BLOCS(BPROTO), "Local Integer IND   : IND = 0" +chr$(10)
Append BLOCS(BPROTO), "Local Char TRTNAME(80)" +chr$(10)
Append BLOCS(BPROTO), "Local Char REPRESENTATION(80)" +chr$(10)
#TODO D=Desktop
Append BLOCS(BPROTO), 'Local File ASHW    [ASW]'+chr$(10)
Append BLOCS(BPROTO), 'Filter [ASW] Where CODCLA="'+CODCLA+'" & DEFREP=2'+chr$(10)
Append BLOCS(BPROTO), 'Read [ASW]ASW0 First'+chr$(10)
Append BLOCS(BPROTO), 'If !fstat'+chr$(10)
Append BLOCS(BPROTO), ' If  [ASW]ENAFAC(0) = 2'+chr$(10)
Append BLOCS(BPROTO), '  REPRESENTATION = [ASW]CODREP'+chr$(10)
Append BLOCS(BPROTO), ' Else'+chr$(10)
Append BLOCS(BPROTO), '  WCLOB ="{}"'+chr$(10)
Append BLOCS(BPROTO), '  End ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(62,149,1),"'+CODCLA+'")) '+chr$(10)
Append BLOCS(BPROTO), ' Endif'+chr$(10)
Append BLOCS(BPROTO), 'Endif'+chr$(10)
Append BLOCS(BPROTO), 'Close Local File [ASW]'+chr$(10)
Append BLOCS(BPROTO), 'If len(REPRESENTATION)=0'+chr$(10)
Append BLOCS(BPROTO), ' WCLOB ="{}"'+chr$(10)
Append BLOCS(BPROTO), ' End ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(62,149,1),"'+CODCLA+'")) '+chr$(10)
Append BLOCS(BPROTO), 'Endif'+chr$(10)

JPRONAM = ''            : Gosub PRO_START_OBJECT
JPRONAM = '$baseUrl'    : JPROVAL = func JSOVAR('PSYR.PREFIX') : Gosub PRO_APPEND_PROPERTY_TEXT
JPRONAM = '$baseType'   : JPROVAL = func JSOVAR('PSYR.CNTPRE+"."+nomap') : Gosub PRO_APPEND_PROPERTY_TEXT
JPRONAM = '$classTitle' : JPROVAL = num$(ACLA.INTCLA)  : Gosub PRO_APPEND_RES_STRING
CLASSTITLE = JPROVAL
JPRONAM = '$url'        : JPROVAL = '{$baseUrl}/'+CODCLA+func JSOVAR('PSYR.URLREP')+func JSOVAR('REPRESENTATION')+'.$search' : Gosub PRO_APPEND_PROPERTY_TEXT
JPRONAM = '$prototype'  : JPROVAL = '{$baseUrl}/$prototypes('+JSQUOTE+'{$representation}.$thumb'+JSQUOTE+')' : Gosub PRO_APPEND_PROPERTY_TEXT
JPRONAM = '$type'       : JPROVAL = '{$baseType}.'+func JSOVAR('REPRESENTATION')+'.$search' : Gosub PRO_APPEND_PROPERTY_TEXT
If ACLA.FCYSTR<>""
 JPRONAM = '$facility'       : JPROVAL = '{' + ACLA.FCYSTR + '}' : Gosub PRO_APPEND_PROPERTY_TEXT
Endif
JPRONAM = '$properties' : Gosub PRO_START_OBJECT
JPRONAM = '$resources'  : Gosub PRO_START_OBJECT
JPRONAM = '$type'       : JPROVAL = func ASYRJSO.TYP('array') : Gosub PRO_APPEND_PROPERTY_TEXT
JPRONAM = '$item'       : Gosub PRO_START_OBJECT
JPRONAM = '$title' : JPROVAL = CLASSTITLE-"{$key}"  : Gosub PRO_APPEND_PROPERTY_TEXT :#PRO_APPEND_RES_STRING
JPRONAM = '$key'          :
 # INDEX and KEY

Local Integer I
JPROVAL = '{'+ACLA.KEYINT+'}'
 I = 1
 While I>0
   I = instr(I,JPROVAL,'+')
   If I
    JPROVAL = left$(JPROVAL,I-1) + '}~{'+right$(JPROVAL,I+1)
   Endif
 Wend
JPRONAM = '$key'  : Gosub PRO_APPEND_PROPERTY_TEXT
JPRONAM = '$url'         : JPROVAL = '{$baseUrl}/'+CODCLA+'('+JSQUOTE+"{$key}"+JSQUOTE+')'+func JSOVAR('PSYR.URLREP')+CODCLA+'.searchItem' : Gosub PRO_APPEND_PROPERTY_TEXT
JPRONAM = '$properties' : Gosub PRO_START_OBJECT
Return

#**
#* LOAD_ROLFLD
#*!
$LOAD_ROLFLD
Raz NB_ROLFLD,TAB_ROLFLD
For [ASW]ASW0 Where CODCLA=ACLA.CODCLA & AFCRIGHT<>""
 Read [AFC]CODINT=[F:ASW]AFCRIGHT
 If !fstat &  [AFC]ACTION="GOBJET"
  Read [AOB]ABREV = vireblc(ctrans([AFC]VALPAR(0),'"'+"'","  "),3)
  If !fstat
   For [ARL]ARL0 Where OBJ = [F:AOB]ABREV
    NB_ROLFLD += 1
    TAB_ROLFLD(NB_ROLFLD) = [F:ARL]FLD
   Next
  Endif
 Endif
Next
Return

#**
#* DEF_VAR_JSON
#*!
$DEF_VAR_JSON
Local Char    JPRONAM(250),JPROVAL(250),JCRLF(10)
Local Integer JN : JN = 0
Local Char    JOC(2)(1..5) , JNC(2)(1..5)
Local Char    JSQUOTE(10)
Local Char    JNODETYPE(1)

JSQUOTE="'+"+'"'+"'"+'"'+"+'"

#JN += 1 : JOC(JN) = "\\" : JNC(JN) = "\"
#JN += 1 : JOC(JN) = '\"' : JNC(JN) = '"'
#JN += 1 : JOC(JN) = "\n" : JNC(JN) = chr$(10)
#JN += 1 : JOC(JN) = "\r" : JNC(JN) = chr$(13)
#JN += 1 : JOC(JN) = "\t" : JNC(JN) = chr$(9)
Return


#**
#* PRO_APPEND_PROPERTY
#*!
$PRO_APPEND_PROPERTY
Append BLOCS(BPROTO), "Append WCLOB,'"
If JNBPRO(JLEVEL) > 0
 Append BLOCS(BPROTO), ","
Endif
JNBPRO(JLEVEL) += 1
Return

#**
#* PRO_APPEND_PROPERTY_TEXT
#*!
$PRO_APPEND_PROPERTY_TEXT
Gosub PRO_APPEND_PROPERTY
Append BLOCS(BPROTO), '"'+JPRONAM + '":"'
Append BLOCS(BPROTO),JPROVAL
Append BLOCS(BPROTO), '"'+"'"+chr$(10)
Return

#**
#* PRO_APPEND_PROPERTY_NUM
#*!
$PRO_APPEND_PROPERTY_NUM
Gosub PRO_APPEND_PROPERTY
Append BLOCS(BPROTO), '"'+JPRONAM + '":'+JPROVAL+"'"+chr$(10)
Return

#**
#* PRO_APPEND_PROPERTY_MAXLENGTH
#*!
$PRO_APPEND_PROPERTY_MAXLENGTH
If ACLA.ACLAF(I).ATY.LNGTYP > 0
 JPRONAM = '$maxLength' : JPROVAL = num$(ACLA.ACLAF(I).ATY.LNGTYP)       : Gosub PRO_APPEND_PROPERTY_NUM
Endif
Return

#**
#* PRO_START_OBJECT
#*!
$PRO_START_OBJECT
JNODETYPE = '{'
Gosub PRO_START_NODE
Return

#**
#* PRO_START_ARRAY
#*!
$PRO_START_ARRAY
JNODETYPE = '['
Gosub PRO_START_NODE
Return

#**
#* PRO_START_NODE
#*!
$PRO_START_NODE
Append BLOCS(BPROTO), 'Append WCLOB,'
Append BLOCS(BPROTO), "'"
If JNBPRO(JLEVEL) > 0
 Append BLOCS(BPROTO), ','
Endif
If len(JPRONAM) > 0
 Append BLOCS(BPROTO), '"'+JPRONAM + '":'+JNODETYPE+"'"
Else
 Append BLOCS(BPROTO), JNODETYPE+"'"
Endif
Append BLOCS(BPROTO), chr$(10)

JNBPRO(JLEVEL) += 1
JLEVEL += 1
JNBPRO(JLEVEL)=0
Return

#**
#* PRO_END_OBJECT
#*!
$PRO_END_OBJECT
JNODETYPE = '}'
Gosub PRO_END_NODE
Return

#**
#* PRO_END_ARRAY
#*!
$PRO_END_ARRAY
JNODETYPE = ']'
Gosub PRO_END_NODE
Return
#**
#* PRO_END_NODE
#*!
$PRO_END_NODE
Append BLOCS(BPROTO), 'Append WCLOB,'
Append BLOCS(BPROTO), '"'+JNODETYPE+'"'
Append BLOCS(BPROTO), chr$(10)
JNBPRO(JLEVEL)=0
JLEVEL -= 1
Return

#**
#* JSOVAR
#*
#* @param V
#*!
Funprog JSOVAR(V)
Value Char V
End "'+"+V+"+'"


#**
#* PRO_APPEND_RES_STRING
#*!
$PRO_APPEND_RES_STRING
RESCOUNT+=1 : RESTBL(RESCOUNT) = val(JPROVAL)
JPROVAL   = func JSOVAR('func GET_RES_STRING(ACTX.LAN,'+JPROVAL+')')
Gosub PRO_APPEND_PROPERTY_TEXT
Return


#**
#*
#*!
$PRO_FLDCLA
FLDPRO  = ACLA.ACLAF(I).FLDCLA

If ACLA.ACLAF(I).FLDCLA = ACLA.ACCSTR
 JPRONAM = "$access"
Else
 JPRONAM = FLDPRO
Endif
Gosub PRO_START_OBJECT

JPRONAM = '$title'
JPROVAL = num$(ACLA.ACLAF(I).INTFLD)
Gosub PRO_APPEND_RES_STRING

If !find(ACLA.ACLAF(I).ATY.TYPTYP,8,9)
 JPRONAM = "$capabilities" : JPROVAL  = 'sort,filter' :Gosub PRO_APPEND_PROPERTY_TEXT
Endif

If len(ACLA.ACLAF(I).ACS)
 JPRONAM = "$access" : JPROVAL  = ACLA.ACLAF(I).ACS :Gosub PRO_APPEND_PROPERTY_TEXT
Endif

If len(ACLA.ACLAF(I).CATSEARCH)
 JPRONAM = "$searchFacets" : JPROVAL  = ACLA.ACLAF(I).CATSEARCH :Gosub PRO_APPEND_PROPERTY_TEXT
Endif

Case ACLA.ACLAF(I).ATY.TYPTYP
 When 1 : # Menu
  If ACLA.ACLAF(I).MENU = 1
  JPRONAM = '$type'      : JPROVAL = func ASYRJSO.TYP('boolean') : Gosub PRO_APPEND_PROPERTY_TEXT
  Else
   JPRONAM = '$type'      : JPROVAL = func ASYRJSO.TYP('choice') : Gosub PRO_APPEND_PROPERTY_TEXT
   JPRONAM = '$value'     : Gosub PRO_START_OBJECT
   JPRONAM = '$type'      : JPROVAL = func ASYRJSO.TYP('integer') : Gosub PRO_APPEND_PROPERTY_TEXT
   JPRONAM = '$enum'     : Gosub PRO_START_ARRAY
   Local Integer M
   For M=1 To len(mess(0,ACLA.ACLAF(I).MENU,1))
    JPRONAM = ''     : Gosub PRO_START_OBJECT
    JPRONAM = '$value'      : JPROVAL = num$(M) : Gosub PRO_APPEND_PROPERTY_NUM
    MESCOUNT+=1 :
    MESCHPTBL(MESCOUNT) =  M
    MESNUMTBL(MESCOUNT) = ACLA.ACLAF(I).MENU
    JPRONAM = '$title'
    JPROVAL   = func JSOVAR('func GET_RES_MENU(ACTX.LAN,"'+num$(ACLA.ACLAF(I).MENU)+'.'+num$(M)+'")')
    Gosub PRO_APPEND_PROPERTY_TEXT
    Gosub PRO_END_OBJECT
   Next M

   Gosub PRO_END_ARRAY
   Gosub PRO_END_OBJECT
  Endif
 When 2 : # Short integer
  JPRONAM = '$type'      : JPROVAL = func ASYRJSO.TYP('integer') : Gosub PRO_APPEND_PROPERTY_TEXT
  Gosub PRO_APPEND_PROPERTY_MAXLENGTH
 When 3 : # Long integer
  JPRONAM = '$type'      : JPROVAL = func ASYRJSO.TYP('integer') : Gosub PRO_APPEND_PROPERTY_TEXT
  Gosub PRO_APPEND_PROPERTY_MAXLENGTH
 When 4 : # Decimal
  JPRONAM = '$type'      : JPROVAL = func ASYRJSO.TYP('decimal') : Gosub PRO_APPEND_PROPERTY_TEXT
  Gosub PRO_APPEND_PROPERTY_MAXLENGTH
 When 5 : # Float
  JPRONAM = '$type'      : JPROVAL = func ASYRJSO.TYP('real') : Gosub PRO_APPEND_PROPERTY_TEXT
  Gosub PRO_APPEND_PROPERTY_MAXLENGTH
 When 6 : # Double
  JPRONAM = '$type'      : JPROVAL = func ASYRJSO.TYP('decimal') : Gosub PRO_APPEND_PROPERTY_TEXT
  Gosub PRO_APPEND_PROPERTY_MAXLENGTH
 When 7 : # String
  JPRONAM = '$type'      : JPROVAL = func ASYRJSO.TYP('string') : Gosub PRO_APPEND_PROPERTY_TEXT
  Gosub PRO_APPEND_PROPERTY_MAXLENGTH
 When 8 : # Date
  JPRONAM = '$type'      : JPROVAL = func ASYRJSO.TYP('date') : Gosub PRO_APPEND_PROPERTY_TEXT
 When 9 : # BLOB
  JPRONAM = '$type'      : JPROVAL = func ASYRJSO.TYP('binary') : Gosub PRO_APPEND_PROPERTY_TEXT
 When 10 : # CLOB
  JPRONAM = '$type'      : JPROVAL = func ASYRJSO.TYP('binary') : Gosub PRO_APPEND_PROPERTY_TEXT
 When 11 : # UUID
  JPRONAM = '$type'      : JPROVAL = func ASYRJSO.TYP('string') : Gosub PRO_APPEND_PROPERTY_TEXT
 When 11 : # datetime
  JPRONAM = '$type'      : JPROVAL = func ASYRJSO.TYP("datetime") : Gosub PRO_APPEND_PROPERTY_TEXT
 When 25 : # String for ATEXTE
  JPRONAM = '$type'      : JPROVAL = func ASYRJSO.TYP('string') : Gosub PRO_APPEND_PROPERTY_TEXT
  Gosub PRO_APPEND_PROPERTY_MAXLENGTH
 When 26 : # String for ATEXTRA
  JPRONAM = '$type'      : JPROVAL = func ASYRJSO.TYP('string') : Gosub PRO_APPEND_PROPERTY_TEXT
  Gosub PRO_APPEND_PROPERTY_MAXLENGTH
Endcase

Gosub PRO_END_OBJECT
Return

#**
#* CLOSE_BLOCS
#*!
$CLOSE_BLOCS
Gosub PRO_END_OBJECT : #$properties

Call ST_RETURN(BLOCS(BACTION))

Append BLOCS(BERROR), "Resume"+chr$(10)

Call ST_ACTION(BLOCS(BOPEN3),"OPEN")
Call ST_RETURN(BLOCS(BOPEN3))

Call ST_ACTION(BLOCS(BCLOSE3),"CLOSE")
Call ST_RETURN(BLOCS(BCLOSE3))

#remove the last comma:
BLOCS(BJOIN2) = left$(BLOCS(BJOIN2),len(BLOCS(BJOIN2))-1)
BLOCS(BJINC2) = BLOCS(BJOIN2)

Call APPEND_LINE(1,BLOCS(BJOIN2),chr$(10)+"& As [LNK_]"+chr$(10)+"& Where (1=1"+chr$(10)+"& )")
Call ST_ACTION(BLOCS(BJOIN3),"JOIN")
Call ST_RETURN(BLOCS(BJOIN3))

Call APPEND_LINE(1,BLOCS(BJINC2),chr$(10)+"& As [LNK_]"+chr$(10)+"& Where (UPDDATTIM > gdatetime$(QUPDDATTIM)"+chr$(10)+"& )")
Call ST_ACTION(BLOCS(BJINC2),"JOIN")
Call ST_RETURN(BLOCS(BJINC2))

Call ST_RETURN(BLOCS(BCREATE))

If BDYNALLOC=0
 Call APPEND_LINE(1, BLOCS(BINS), '[L]ASTATUS = fmet INS.ACTION("ASEARCH_TRANS_AFTER")')
 Call APPEND_LINE(1, BLOCS(BINS), 'Gosub ASEARCH_TO_JSON')
Endif
Call ST_RETURN(BLOCS(BINS))

Append BLOCS(BJSON2),"Onerrgo"+chr$(10)
If BDYNALLOC
 Append BLOCS(BJSON2), 'Freegroup '+INSCLA+chr$(10)
 Append BLOCS(BJSON2), 'INS = null'+chr$(10)
 Append BLOCS(BJSON2), ST_RAZ_KEYS+chr$(10)
Endif
Append BLOCS(BJSON2), 'FINS = 0'+chr$(10)
Call ST_RETURN(BLOCS(BJSON2))

Call ST_ACTION(BLOCS(BPRIM),"PRIMARYKEYS")
Call ST_RETURN(BLOCS(BPRIM))

Gosub PRO_END_OBJECT : #$item
Gosub PRO_END_OBJECT : #$resources
Gosub PRO_END_OBJECT : #$properties

# LiNKS :
JPRONAM = '$links' : Gosub PRO_START_OBJECT
#Local File ASHW    [ASW]
Local Integer AREP
Local Char DEVICES(10)(1..3)
DEVICES(1)="desktop"
DEVICES(2)="mobile"
DEVICES(3)="tablet"

Filter [ASW] Where CODCLA=[L]CODCLA & DEFREP=2
For [ASW]
 JPRONAM = '$search'
 If AREP
 JPRONAM += '_' + num$(AREP)
 Endif
 JPRONAM += '$details'
 Gosub PRO_START_OBJECT
 AREP += 1
 JPRONAM = "$title" : JPROVAL  = 'Detail' :Gosub PRO_APPEND_PROPERTY_TEXT
 If [ASW]DEFREP
 JPRONAM = "$default" : JPROVAL  = 'true' :Gosub PRO_APPEND_PROPERTY_NUM
 Endif
 JPRONAM = '$url'    : JPROVAL = '{$baseUrl}/'+CODCLA+'('+JSQUOTE+"{$key}"+JSQUOTE+')?representation='+[ASW]CODREP+'.$details' : Gosub PRO_APPEND_PROPERTY_TEXT
 JPRONAM = "$devices" : JPROVAL  = DEVICES([ASW]TYPMSKREP) : Gosub PRO_APPEND_PROPERTY_TEXT
 Gosub PRO_END_OBJECT : #$search
Next ASW
Close Local File [ASW]
Gosub PRO_END_OBJECT : #$links

Gosub PRO_END_OBJECT : #
Append BLOCS(BPROTO), "End ERROR" +chr$(10)

Local File ADOSSIER [ADS]
# 118229
Local File =[L]DOSSIER+".APLSTD" [AST]
Local File =[L]DOSSIER+".ATEXTE"   [ATX]

Local Integer AL,AR,STAT
Local Char RESSTR(250)
#107271 Read [ADS]DOSSIER=nomap
#STAT=func DOSSUB.FILL_ADS(nomap)
#119343
STAT=func DOSSUB.FILL_ADS([L]DOSSIER)

Append BLOCS(BRES), "Case _LAN" +chr$(10)
For AL=1 To [F:ADS]NBRLAN
 Append BLOCS(BRES), ' When "'+[F:ADS]LAN(AL-1)+'":'+chr$(10)
 Append BLOCS(BRES), '  Case _ID'+chr$(10)
  For AR=1 To RESCOUNT
   Read [ATX]NUMERO = [F:ADS]LAN(AL-1);RESTBL(AR)
    If !fstat
     RESSTR = [F:ATX]TEXTE
    Else
     #Get the text in the default language if it wasn't translated:
     Read [ATX]NUMERO = [F:ADS]LANDEF;RESTBL(AR)
     If !fstat
      RESSTR = [F:ATX]TEXTE
     Endif
    Endif
   Append BLOCS(BRES), '   When '+num$(RESTBL(AR)) + ': RES=' + "'" + func ASHWJSO.ESCQUOTE(RESSTR) +"'"+chr$(10)
  Next AR
 Append BLOCS(BRES), '  Endcase'+chr$(10)
Next AL
Append BLOCS(BRES), "Endcase" +chr$(10)
Append BLOCS(BRES), "Return" +chr$(10)

RESSTR =''
Append BLOCS(BMENU), "Case _LAN" +chr$(10)
For AL=1 To [F:ADS]NBRLAN
 Append BLOCS(BMENU), ' When "'+[F:ADS]LAN(AL-1)+'":'+chr$(10)
 Append BLOCS(BMENU), '  Case _ID'+chr$(10)
 For AR=1 To MESCOUNT
  Read [AST]CLE = MESNUMTBL(AR);MESCHPTBL(AR);[F:ADS]LAN(AL-1)
  Append BLOCS(BMENU), '   When "' + num$(MESNUMTBL(AR))+'.'+num$(MESCHPTBL(AR))+ '": RES=' + "'" + func ASHWJSO.ESCQUOTE(func ASHWJSO.APPEND_JSON_STRING([F:AST]LANMES)) +"'"+chr$(10)
 Next AR
 Append BLOCS(BMENU), '  Endcase'+chr$(10)
Next AL
Append BLOCS(BMENU), "Endcase" +chr$(10)
Append BLOCS(BMENU), "Return" +chr$(10)

Close Local File [ADS]
Close Local File [ATX]
Close Local File [AST]

Return

#**
#* DEL_SELF_JOIN
#*!
$DEL_SELF_JOIN
If (NBRAXX+NBRATX)=0 & (instr(1,BLOCS(BJOIN2),',') = 0)
 Raz BLOCS(BOPEN2),BLOCS(BCLOSE2),BLOCS(BJOIN2)
Endif
Return

#**
#* COMPUTE_ATBKEY
#*!
Funprog COMPUTE_ATBKEY(TABLNK,ABRLNK,ATBKEY)
Variable Char     TABLNK
Variable Char     ABRLNK
Variable Instance ATBKEY Using C_ACLAPARFLD

Local Char CODZONE(250) : CODZONE=ATBKEY.VALEUR
Local Char TKEY(250) : TKEY='""'

If left$(CODZONE,6)="=num$("
  CODZONE = mid$(CODZONE,7,len(CODZONE)-7)
Elsif left$(CODZONE,5)="=val("
  CODZONE= mid$(CODZONE,6,len(CODZONE)-6)
Endif

Read [ATZ_]CODZONE = TABLNK;CODZONE
If !fstat
 TKEY = "[F:"+ABRLNK+"]"+CODZONE
Endif
End TKEY

#**
#* ST_TAG
#*
#* @param BLOC
#* @param TAG
#* @param COM
#*!
Subprog ST_TAG(BLOC,TAG,COM)
Variable Clbfile BLOC
Value Char COM
Value Char TAG

Append BLOC,  "#---------------------------------------------------------------------------------------------------#"+chr$(10)
Append BLOC,  "# "+COM+chr$(10)
Append BLOC,  "#---------------------------------------------------------------------------------------------------#"+chr$(10)
Append BLOC,  "$" + TAG +chr$(10)
End

#**
#* ST_OPEN_TABLE
#*
#* @param BLOC
#* @param TABLE
#* @param ABREV
#*!
Subprog ST_OPEN_TABLE(BLOC,ABREV,TABLE)
Variable Clbfile BLOC
Variable Char ABREV
Value Char TABLE
Append BLOC, "Local File "+TABLE+" ["+ABREV+"]"+chr$(10)
End

#**
#* ST_CLOSE_TABLE
#*
#* @param BLOC
#* @param ABREV
#*!
Subprog ST_CLOSE_TABLE(BLOC,ABREV)
Variable Clbfile BLOC
Variable Char ABREV
#Append BLOC, "Close Local File ["+ABREV+"]"+chr$(10)
Append BLOC, "LogicClose File ["+ABREV+"]"+chr$(10)
End
#**
#* ST_ACTION
#*
#* @param BLOC
#* @param ACTION
#*!
Subprog ST_ACTION(BLOC,ACTION)
Variable Clbfile BLOC
Value    Char ACTION

Append BLOC, 'ACTION = "ASEARCH_'+ACTION+'_AFTER" : Gosub ASEARCH_ACTION'+chr$(10)
End

#**
#* ST_RETURN
#*
#* @param BLOC
#*!
Subprog ST_RETURN(BLOC)
Variable Clbfile BLOC
Append BLOC, "Return"+chr$(10)+chr$(10)
End

