#<AdxTL>@(#)3.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# PRE-Mise à jour ATYPE, alimentation ATYPERUL
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update fields on ATYPERUL table") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER

If DOSSIER=nomap
 Local File ATYPE [ATY]
Else
 Local File =DOSSIER+".ATYPE"  [ATY]
Endif
Filter [ATY]

If DOSSIER=nomap
 Local File ATYPERUL [ATYR]
Else
 Local File =DOSSIER+".ATYPERUL"  [ATYR]
Endif

#If dim([F:ATY]TRTRUL)>0
#Gosub ATY_ATYR
#Endif

#If DOSSIER=nomap
# Local File ASHW [ASW]
#Else
# Local File =DOSSIER+".ASHW"  [ASW]
#Endif
#
#If dim([F:ATY]DEFREPDES)>0 & dim([F:ASW]DEFREP)>0
#Gosub ATY_UPD_DEFREP
#Endif

#Local Integer ERR : ERR=0
#Onerrgo ERRFILE
#If DOSSIER=nomap
# Local File ATYPERPAR [ATYRP]
# Local File APARTYP [APAR]
#Else
# Local File =DOSSIER+".ATYPERPAR"  [ATYRP]
# Local File =DOSSIER+".APARTYP"  [APAR]
#Endif
#Onerrgo
#
#If ERR : End : Endif
#Gosub ATY_UPD2

Close Local File
End

#----------------------------------------------------------------------------------------#
$ERRFILE
ERR=1
Resume


#-------------------#
$ATY_ATYR
Local Integer I
# Mise à jour de la table ATYPERUL
Call ECR_TRACE(mess(81,125,1)-DOSSIER+".ATYPERUL:"-time$,0) From GESECRAN

Trbegin [ATYR]
For [ATY]

  For I=1 To 20
   If [F:ATY]TRTRUL(I-1)<>""
    Read [ATYR]ATYR0=[F:ATY]CODTYP;[F:ATY]TYPRUL(I-1);[F:ATY]TRTRUL(I-1);[F:ATY]PRGRUL(I-1)
    If fstat
      Raz [F:ATYR]
      [F:ATYR]=[F:ATY]

      [F:ATYR]TYPRUL=[F:ATY]TYPRUL(I-1)
      [F:ATYR]TRTRUL=[F:ATY]TRTRUL(I-1)
      [F:ATYR]PRGRUL=[F:ATY]PRGRUL(I-1)
      [F:ATYR]ORDRUL=[F:ATY]ORDRUL(I-1)
      [F:ATYR]ACTRUL=[F:ATY]ACTRUL(I-1)

      Write [ATYR]
      If fstat
       Call ERREUR("ATYPERUL"-[F:ATY]CODTYP,1) From DOSDIC
      Endif
    Endif
   Endif
  Next I
Next ATY
Commit
Return


#-------------------#
$ATY_UPD_DEFREP

# Mise à jour de la table ATYPE
Call ECR_TRACE("ATY_UPD_DEFREP"-mess(81,125,1)-DOSSIER+".ATYPE:"-time$,0) From GESECRAN

Trbegin [ATY]
For [ATY]

  If [F:ATY]CODCLA<>"" & [F:ATY]DEFREPDES=""
     Filter [ASW] Where CODCLA = [F:ATY]CODCLA & TYPMSKREP=1 & DEFREP = 2
     Read [ASW] First
     If !fstat
      [F:ATY]DEFREPDES = [F:ASW]CODREP
     Endif
     Filter [ASW]
  Endif

  If [F:ATY]CODCLA<>"" & [F:ATY]DEFREPMOB=""
     Filter [ASW] Where CODCLA = [F:ATY]CODCLA & TYPMSKREP=2 & DEFREP = 2
     Read [ASW] First
     If !fstat
      [F:ATY]DEFREPMOB = [F:ASW]CODREP
     Endif
     Filter [ASW]
  Endif

  If [F:ATY]CODCLA<>"" & [F:ATY]DEFREPTAB=""
     Filter [ASW] Where CODCLA = [F:ATY]CODCLA & TYPMSKREP=3 & DEFREP = 2
     Read [ASW] First
     If !fstat
      [F:ATY]DEFREPTAB = [F:ASW]CODREP
     Endif
     Filter [ASW]
  Endif

  Rewrite [ATY]
  If fstat
   Call ERREUR("ATYPE"-[F:ATY]CODTYP,2) From DOSDIC
  Endif
Next ATY
Commit
Return

#-------------------#
$ATY_UPD2

# Mise à jour de la table ATYPERPAR
Call ECR_TRACE("ATY_UPD2"-mess(81,125,1)-DOSSIER+".ATYPERPAR:"-time$,0) From GESECRAN

Trbegin [APAR],[ATYRP]
For [APAR]
  Read [ATYRP]ATYRP0=[F:APAR]CODTYP;[F:APAR]TYPRUL;[F:APAR]TRTRUL;[F:APAR]PRGRUL;[F:APAR]PARCOD
  If fstat
#   Read [ATYRP]ATYRP1=[F:APAR]CODTYP;[F:APAR]TYPRUL;[F:APAR]TRTRUL;[F:APAR]PRGRUL;[F:APAR]PARORD
#   If fstat
    Raz [F:ATYRP]
    [F:ATYRP]=[F:APAR]
    Write [ATYRP]
    If fstat
     Call ERREUR("ATYPERPAR"-[F:ATYRP]CODTYP-num$([F:APAR]TYPRUL)-[F:APAR]TRTRUL-[F:APAR]PRGRUL-[F:APAR]PARCOD,1) From DOSDIC
    Endif
#   Endif
  Endif
Next APAR
Commit
Return
