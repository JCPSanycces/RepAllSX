#<AdxTL>@(#)4.0.0.0 $Revision$
#########################################################################
# Traitement standard de proposition d'allocation                  V140 #
#    Action TRTALLPRO                                                   #
#########################################################################
# Appelé depuis la saisie d'allocation manuelle                         #
# Traitement TRTSTOALL / Action SAISTOALL                               #
#########################################################################

#########################################################################
$ACTION
#--- Actions liées au traitement standard TRTALLPRO
Case ACTION
 When "INIT"       : Gosub INIT
 When "CONTROLE"   : Gosub CONTROLE
 When "EXEC"       : Gosub EXEC
 When "TERMINE"    : Gosub TERMINE
 When Default
Endcase

#--- Actions liés à la fenêtre de saisie IALLFIL
Case ACTION
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "ENR"         : Gosub ENR
 When "ABA"         : Gosub ABA
 When "END"         : Gosub ACTEND
 When "FINSAI"      : Gosub FINSAI
Endcase
Return

#########################################################################
$INIT

If clalev([F:ITM])=0  Local File ITMMASTER  [ITM]  Endif
If clalev([F:ITG])=0  Local File ITMCATEG   [ITG]  Endif
If clalev([F:ITF])=0  Local File ITMFACILIT [ITF]  Endif
If clalev([F:ITV])=0  Local File ITMMVT     [ITV]  Endif
If clalev([F:TRU])=0  Local File TABALLRUL  [TRU]  Endif
If clalev([F:SRU])=0  Local File TABSTORUL  [SRU]  Endif
If clalev([F:STL])=0  Local File STOLOT     [STL]  Endif

Global Shortint GLFIN   : GLFIN=0

Return

#########################################################################
$OUVRE_BOITE
Local  Integer WA,WQ,WR,LRET
Global Integer GFILTREAQR
Global Char    GTRUCOD(6)
Global Integer GLRET : Raz GLRET

#Case [M:ALL]VCRTYP
# When 2       : GBIDC1  = mess(2,701,1)
#                GLOCSEL = "[F:STC]LOCCAT<>3&[F:STC]LOCCAT<>4"
# When 10      : GBIDC1  = mess(10,701,1)
#                GLOCSEL = "[F:STC]LOCCAT<>3"
# When Default : GBIDC1  = mess(2,701,1)
#                GLOCSEL = "[F:STC]LOCCAT<>3&[F:STC]LOCCAT<>4"
#Endcase

GBIDC1 = mess([M:ALL]VCRTYP,701,1)

# Lecture des tables article
Call LECITM([M:ALL]STOFCY,[M:ALL]ITMREF,"",0,"",LRET) From STKLIB
If LRET<>0
   FIN=1 : GLRET=1 : Return
Endif

# Récupération de la règle d'allocation
#--- Issue X3-4501 : ajout VCRTYP=40
Case [M:ALL]VCRTYP
 When 2, 40          : # Commande, tache affaire
                       GTRUCOD = [F:ITG]ALLRULORD
 When 10             : # OF (opération de sous-traitance)
                       If [M:ALL]PECSCOLOC=2
                          GTRUCOD = [F:ITG]ALLRULSCC
                       # OF (interne)
                       Else
                          GTRUCOD = [F:ITG]ALLRULMAT
                       Endif
 When 36             : # Ordre sous-traitance
                       GTRUCOD = [F:ITG]ALLRULSCC
 When Default
Endcase

Raz [F:TRU]
If GTRUCOD<>""
   # Lecture règle d'allocation
   Read [TRU]TRU0=GTRUCOD
   If fstat Raz GTRUCOD Endif
Endif

If GTRUCOD<>""
   # Statuts autorisés par les règles d'allocation
   For I=0 To dim([F:TRU]STAFLT)-1
      If [F:TRU]STAFLT(I)<>0
         If find([F:TRU]STAFLT(I),1,3,5,7) WA=1  Endif
         If find([F:TRU]STAFLT(I),2,3,6,7) WQ=1  Endif
         If find([F:TRU]STAFLT(I),4,5,6,7) WR=1  Endif
      Endif
   Next I
Else
   WA=1
Endif
GFILTREAQR = WA+2*WQ+4*WR

Gosub FORMAT_INV From STKLIB

Return

#########################################################################
$DEBUT

Raz [M:ALF]

[M:ALF]STOFCY = [M:ALL]STOFCY
[M:ALF]ITMREF = [M:ALL]ITMREF
[M:ALF]VCRNUM = [M:ALL]VCRNUM
[M:ALF]VCRTYP = [M:ALL]VCRTYP

If dim([M:ALF]LOT)>0    [M:ALF]LOT   =[M:ALL]XLOT    Endif
If dim([M:ALF]LOC)>0    [M:ALF]LOC   =[M:ALL]XLOC    Endif
If dim([M:ALF]LOCTYP)>0 [M:ALF]LOCTYP=[M:ALL]XLOCTYP Endif
[M:ALF]STA = [M:ALL]XSTA

Affzo [M:ALF]

Return

#########################################################################
$SETBOUT

ETABOU(GENRE)=1
ETABOU(GABAN)=1

Return

#########################################################################
$ENR

If dim([M:ALF]LOT)>0    [M:ALL]XLOT   =[M:ALF]LOT    Endif
If dim([M:ALF]LOC)>0    [M:ALL]XLOC   =[M:ALF]LOC    Endif
If dim([M:ALF]LOCTYP)>0 [M:ALL]XLOCTYP=[M:ALF]LOCTYP Endif
[M:ALL]XSTA = [M:ALF]STA

GOK = 1
FIN = 1

Return

#########################################################################
$ABA

# Réalimentation avec les valeurs initiales
Gosub DEBUT

Return

#########################################################################
$ACTEND

GLFIN=1

Return

#########################################################################
$FINSAI

If GOK=1 mkstat=4 Endif

Return

#########################################################################
$CONTROLE

If GLFIN=1 FIN=1 Endif

Return

#########################################################################
$EXEC
Local Integer LRUP, LRET, LFULLTAB
Local Char    WTRUCOD
Local Integer WSTA, WA, WQ, WR, WLOC
Local Integer I, J, K, L
Local Decimal SVGQTY, WSTUACTDIS

# Si problème dans le GSAISIE
If GLRET=1
   FIN=1 : Return
Endif

# Effacement des saisies ou propositions précédentes
Raz [M:ALL]PECQTY
Effzo [M:ALL]15

# Rechargement des allocations déjà existantes
Gosub ALI_MSK_ALL From TRTSTOALL

# Chargement des paramètres pour l'algorithme d'allocation
Raz [M:ALP]
[M:ALP] = [M:ALL]
Raz [M:ALP]TRSTYP
Raz [M:ALP]TRSCOD
[M:ALP]TYPQTY     = 2
# Si existence allocation globale
If [M:ALL]ALLTYP = 1
   [M:ALP]QTY = [M:ALL]QTYTOALL
Else
   [M:ALP]QTY = [M:ALL]QTYTOALL - [M:ALL]OLDALLQTY
Endif

[M:ALP]ALLQTY = [M:ALL]GLOALLQTY

# Pas de quantité à traiter
If [M:ALP]QTY<=0
   Goto EXEC_SUITE
Endif

[M:ALP]BESDAT     = [M:ALL]RETDAT
[M:ALP]ALLDAT     = [31/12/2999]
[M:ALP]PECRER     = 1

# Si OF
If [M:ALL]VCRTYP = 10
   [M:ALP]PECSCOLOC = [M:ALL]PECSCOLOC
# Sinon si EO
Elsif [M:ALL]VCRTYP = 36
   [M:ALP]PECSCOLOC = 2
Else
   [M:ALP]PECSCOLOC = 1
Endif
# Prise en compte du stock en cours d'inventaire
[M:ALP]PECCUNLOK  = 2
# Prise en compte du stock avec demande d'analyse
[M:ALP]PECQLYCTL  = 2
[M:ALP]FILSTO     = ""
[M:ALP]LOT        = [M:ALL]XLOT
[M:ALP]LOC        = [M:ALL]XLOC
[M:ALP]STA        = [M:ALL]XSTA
[M:ALP]LOCTYP     = [M:ALL]XLOCTYP

# Récupération règle d'allocation et statuts autorisés
WTRUCOD = GTRUCOD
WSTA    = GFILTREAQR

Raz WLOC
# Prise en compte emplacement quai (en attente de rangement)
If [M:ALP]PECPLFLOC=2 WLOC+=1  Endif
# Prise en compte emplacement sous-traitant
If [M:ALP]PECSCOLOC=2 WLOC+=4  Endif
# Si pas d'emplacements internes
If [M:ALP]PECINTLOC=1 WLOC=WLOC*(-1) Endif
# Calcul stock disponible
Call STODISTOT("",WLOC,WSTA,[M:ALP]PECOWNER,WSTUACTDIS) From STKLIB

# On rajoute l'allouée global (limité à la qté à traiter)
WSTUACTDIS += min([M:ALP]QTY,[M:ALP]ALLQTY)

#--- Bug 73461
# Si on doit consommer les réservations client, on les rajoutent,
# en les limitant à la quantité pas déjà allouée
If [M:ALL]VCRTYP=2 & [M:ALL]BPCORD<>"" & dim(GRERBPC)>0 & GRERBPC<>1
   Local Decimal LQTA
   Local Char    LNUM
   LNUM=format$("K:"+num$(GLONBPC)+"X",[M:ALL]BPCORD)+format$("K:"+num$(GLONBPD)+"X",[M:ALL]BPAADD)
   LNUM= vireblc(LNUM, 1)
   Call CAL_RERQTY(1,[M:ALL]ITMREF,[M:ALL]STOFCY,LNUM,[M:ALL]RETDAT,LQTA) From STKALL
   If LQTA<>0
      WSTUACTDIS += min(LQTA,[M:ALP]QTY-[M:ALP]ALLQTY)
   Endif
Endif
#---

SVGQTY = [M:ALP]QTY
# Si pas de stock disponible, pas de proposition
If WSTUACTDIS <=0 Goto EXEC_SUITE Endif
# Si quantité disponible < quantité à allouer, on appelle l'algo avec
# comme quantité à allouer, la quantité disponible
If WSTUACTDIS<[M:ALP]QTY [M:ALP]QTY=WSTUACTDIS Endif

LRUP=1
# Appel à l'algorithme d'allocation
Call STOCKALG(LRUP,WTRUCOD,LFULLTAB,LRET) From STKALL
If LRET<>0 & GMESSAGE<>""
   Call MESSAGE(GMESSAGE) From GESECRAN
   Goto EXEC_SUITE
Endif

K = [M:ALL]NBLIG
For I=0 To [M:ALP]NBLIG-1
   J=[M:ALP]NLIG(I)
   Break ([M:ALP]WFLG(J)=0)
   If [M:ALP]WQTYSTUACT(J)<>0
      Read [STO]STO0=[M:ALP]STOFCY;[M:ALP]WSTOCOU(J)
      If !fstat
         # Recherche si la ligne proposée est déjà dans le tableau
         L=find([M:ALP]WSTOCOU(J),[M:ALL]STOCOU(0..[M:ALL]NBLIG-1))
         # Elle est déjà dans le tableau --> on cumule dessus
         If L>0
            L-=1
            [M:ALL]ALLQTY(L)    += [M:ALP]WQTYSTUACT(J)
            If [M:ALL]XPCUSTUCOE(L)=0 [M:ALL]XPCUSTUCOE(L)=1 Endif
            [M:ALL]ALLQTYPCU(L)  = [M:ALL]ALLQTY(L)/[M:ALL]XPCUSTUCOE(L)

            [M:ALL]PECQTY       += [M:ALP]WQTYSTUACT(J)
         # C'est une nouvelle ligne
         Else
            If dim([M:ALL]LOT)>0
               [M:ALL]LOT(K) = [F:STO]LOT
               If dim([M:ALL]SLO)>0 [M:ALL]SLO(K)=[F:STO]SLO Endif
               If dim([M:ALL]POT)>0
                  Read [STL]STL0=[M:ALL]ITMREF;[F:STO]LOT;[F:STO]SLO
                  If !fstat
                     If [M:ALL]STOMGTCOD=3
                        [M:ALL]POT(K) = [F:STL]POT
                     Elsif [M:ALL]STOMGTCOD=4
                        [M:ALL]POT(K) = [F:STL]ACT
                     Endif
                  Endif
               Endif
            Endif
            [M:ALL]TOTQTY(K)      = [F:STO]QTYSTUACT
            [M:ALL]STA(K)         = [M:ALP]WSTA(J)
            If dim([M:ALL]LOC)>0    [M:ALL]LOC(K)    = [M:ALP]WLOC(J)    Endif
            If dim([M:ALL]SERNUM)>0 [M:ALL]SERNUM(K) = [M:ALP]WSERNUM(J) Endif
            If dim([M:ALL]SHLDAT)>0 [M:ALL]SHLDAT(K) = [M:ALP]WSHLDAT(J) Endif
            #--- Issue X3-53322
            If dim([M:ALL]LPNNUM)>0 [M:ALL]LPNNUM(K) = [M:ALP]WLPNNUM(J) Endif
            [M:ALL]XPCU(K)        = [M:ALP]WPCU(J)
            [M:ALL]XPCUSTUCOE(K)  = [M:ALP]WPCUSTUCOE(J)
            [M:ALL]AVAQTY(K)      = [M:ALP]WQTYACTAVA(J)
            [M:ALL]ALLQTY(K)      = [M:ALP]WQTYSTUACT(J)
            If [M:ALL]XPCUSTUCOE(K)=0 [M:ALL]XPCUSTUCOE(K)=1 Endif
            [M:ALL]ALLQTYPCU(K)   = [M:ALL]ALLQTY(K)/[M:ALL]XPCUSTUCOE(K)
            [M:ALL]STOCOU(K)      = [M:ALP]WSTOCOU(J)

            [M:ALL]PECQTY += [M:ALL]ALLQTY(K)
            K += 1
         Endif
      Endif
   Endif
Next I

[M:ALL]NBLIG = K

$EXEC_SUITE
[M:ALP]QTY = SVGQTY

# Affichage de la proposition
Affzo [M:ALL]1-99

Return

#########################################################################
$TERMINE

Return

