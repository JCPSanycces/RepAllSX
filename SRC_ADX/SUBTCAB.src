Call OBJET("TCA",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "CHARGE_DOC" : Gosub CHARGE_DOC
 When "VERIF_CRE"  : Gosub VERIF_CRE
 When "VERIF_MOD"  : Gosub VERIF_MOD
 When "INICRE"     : Gosub INICREMOD
 When "INIMOD"     : Gosub INICREMOD
 When "APRES_CRE"  : Gosub MAJFIN
 When "APRES_MOD"  : Gosub MAJFIN
 When "CHARGE_DOC" : Gosub CHARGE_DOC
 When "AS_MODULE"  : Gosub AS_MODULE
 When "C_MODULE"   : Gosub C_MODULE
 When "AM_MODULE"  : Gosub AM_MODULE
 When "C_NBDOC"    : Gosub C_NBDOC
 When "C_CODNUM"   : Gosub C_CODNUM
 When "AS_MANCOU"  : Gosub AS_MANCOU
Endcase
Return

