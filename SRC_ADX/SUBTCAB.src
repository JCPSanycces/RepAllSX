Return

$VERIF_CTEUR
#MIPEA - 23/09/2016 - Req 114309 - X3 People integration - START
If [M]MODULE=15 | [M]MODULE=20 #Check X3 People modules 15 and 20
  Gosub INIT_LNG
Endif
#MIPEA - 23/09/2016 - Req 114309 - X3 People integration - END
If [M]MODULE=3 | [M]MODULE=2
 Local Integer LNGTYP
 If !clalev([F:ATZ]) Local File ATABZON [ATZ] Endif
 For nolign=1 To [M]NBDOC
  If [F:ANM]CODNUM<>[M]CODNUM(nolign-1)
    Read [ANM]ANM0=[M]CODNUM(nolign-1) : If fstat : Raz [F:ANM] : Endif
  Endif

  # cas particulier : compteurs pour Projet, Approbation et Révision
  If [M]MODULE=2
   If func AFNC.ACTIV("GDD")
    Case nolign
     When 9
      LNGTYP = GLONPRJ
     When 10
      Read [ATZ]NUMLIG="BUDAPP";1;"NUM"
      If !fstat
       LNGTYP = [F:ATZ]LONG
      Endif
     When 11
      Read [ATZ]NUMLIG="BUDREV";1;"NUM"
      If !fstat
       LNGTYP = [F:ATZ]LONG
      Endif
     When Default LNGTYP = GLONVCR
    Endcase
   Else
    LNGTYP=GLONVCR
   Endif
  Elsif [M]MODULE=3
   Case nolign
    When 12      If func AFNC.ACTIV("FUP") : LNGTYP = GLONFUP : Else : LNGTYP=GLONVCR : Endif
    When 14      If func AFNC.ACTIV("SDD") : LNGTYP = GLONMDT : Else : LNGTYP=GLONVCR : Endif
    When Default LNGTYP = GLONVCR
   Endcase
  Endif

  If sum([F:ANM]POSLNG(0..dim([F:ANM]POSLNG)-1)) > LNGTYP
   GMESSAGE=[M]CODNUM(nolign-1)-mess(223,199,1)-"("+num$(LNGTYP)+")" : OK=0 : Break
  Endif

 Next nolign

 If OK=0 : Call ERREUR(GMESSAGE) From GESECRAN : Raz GMESSAGE : Return : Endif
Endif

#-----------------------------------------------------------------------#
# Pas de contrôle pour les modules différents de Achats, Vtes, STO et GP#
#-----------------------------------------------------------------------#
If [M]MODULE<5 | [M]MODULE>8  Return : Endif

#----- Vérification que tous les compteurs soient affectés -----#
Local Integer LNGTYP
For nolign=1 To [M]NBDOC
  If CODNUM(nolign-1)="" : OK=0 : Break : Endif
Next nolign
If OK=0 : Call ERREUR(mess(62,199,1)) From GESECRAN : Return : Endif
#----- Vérification que la longueur des compteurs n'excède pas la longueur
#----- du type de donnée concerné (personnalisable en v 140)        -----#
For nolign=1 To [M]NBDOC
  If [F:ANM]CODNUM<>[M]CODNUM(nolign-1)
    Read [ANM]ANM0=[M]CODNUM(nolign-1) : If fstat : Raz [F:ANM] : Endif
  Endif

  # cas particulier : compteurs pour PAL,CTR,Lot et Série (TB  30/06/03) v 140
  # cas particulier : chronos stock et fifo
  If [M]MODULE = 7
   Case nolign
    When 1       If !clalev([F:STO]) Local File STOCK [STO] Endif
                 LNGTYP = GLONVCR
                 If type([F:STO]STOCOU)>=4 & type([F:STO]STOCOU)<=9
                    If [F:ANM]NBPOS<>1 | [F:ANM]TYP<>2 | [F:ANM]NIVDEF<>1
                       GMESSAGE = mess(87,199,1) : OK=0 : Break
                    Endif
                 Endif
    When 3       If !clalev([F:STJ]) Local File STOJOU [STJ] Endif
                 LNGTYP = GLONVCR
                 If type([F:STJ]CSTCOU)>=4 & type([F:STJ]CSTCOU)<=9
                    If [F:ANM]NBPOS<>1 | [F:ANM]TYP<>2 | [F:ANM]NIVDEF<>1
                       GMESSAGE = mess(111,199,1) : OK=0 : Break
                    Endif
                 Endif
    When 4       LNGTYP = GLONPAL
    When 5       LNGTYP = GLONCTR
    When 8       LNGTYP = GLONLOT
    When 13      LNGTYP = GLONSER
    When Default LNGTYP = GLONVCR
   Endcase
  Else
    LNGTYP = GLONVCR
  Endif

  If sum([F:ANM]POSLNG(0..dim([F:ANM]POSLNG)-1)) > LNGTYP
    GMESSAGE=[M]CODNUM(nolign-1)-mess(223,199,1) : OK=0 : Break
  Endif

Next nolign

If OK=0 : Call ERREUR(GMESSAGE) From GESECRAN : Raz GMESSAGE : Return : Endif
Return

