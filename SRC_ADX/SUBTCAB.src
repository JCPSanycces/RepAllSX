$C_NBDOC
#-------------------------------------------------------------------------#
# Contrôle NBDOC : Tous les compteurs (sauf Stocks) doivent être affectés #
#-------------------------------------------------------------------------#
If !find(status,1,4,5,20,21,26,92,93) End : Endif
# If [M]MODULE<>7
