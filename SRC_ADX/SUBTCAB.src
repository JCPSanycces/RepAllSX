$C_CODNUM
#------------------------------------------------------------#
# Contrôle pour les modules Achats, Ventes et GPAO :         #
# Le code compteur doit être renseigné et la longueur        #
# du compteur ne doit pas excéder 15 caractères              #
#------------------------------------------------------------#
# Le compteur des OD budgétaire doit obligatoirement être    #
# défini au niveau dossier.                                  #
#------------------------------------------------------------#
Local Integer LNGTYP, CHK

If [M]MODULE=2
 If nolign=7
  Read [ANM]ANM0=VALEUR
  If !fstat & [ANM]NIVDEF<>1
   #Le compteur doit être défini au niveau dossier
   GMESSAGE=mess(405,199,1) : mkstat=1 : Return
  Endif
 Endif
 #---------------------------------------------------------
 # Cas budgets opérationnels
 # Test des compteurs Projet, Approbation & Révision
 If [F:ANM]CODNUM<>VALEUR
   Read [ANM]ANM0=VALEUR  : If fstat : Raz [F:ANM]  : Endif
 Endif
 #
 If !clalev([F:ATZ]) Local File ATABZON [ATZ] Endif
 # cas particulier : compteurs pour Projet, Approbation et Révision
 If func AFNC.ACTIV("GDD")
  Case nolign
   When 9
    LNGTYP = GLONPRJ
   When 10
    Read [ATZ]NUMLIG="BUDAPP";1;"NUM"
    If !fstat
     LNGTYP = [F:ATZ]LONG
    Endif
   When 11
    Read [ATZ]NUMLIG="BUDREV";1;"NUM"
    If !fstat
     LNGTYP = [F:ATZ]LONG
    Endif
   When Default LNGTYP = GLONVCR
  Endcase
 Else
  LNGTYP = GLONVCR
 Endif

 If sum([F:ANM]POSLNG(0..dim([F:ANM]POSLNG)-1)) > LNGTYP
  GMESSAGE = mess(223,199,1)-"("+num$(LNGTYP)+")" : mkstat=1 : Return
 Endif

 #---------------------------------------------------------
Endif

#If [M]MODULE<5 | [M]MODULE>8 Return : Endif
If [M]MODULE>8 Return : Endif

#Issue X3-85504 - 2018-04-12 by VAVIL : Sequence number control
If VALEUR<>''
  If func AFNC.ACTIV("KPO")>0 & find([M:TCA1]LEG,"POR","")
    If [M]MODULE=5 & nolign=6
    Local Char WMESS(100) : WMESS = ""
    Call CTL_CODNUM_FINAL(VALEUR,[M:TCA1]LEG,"","TCA",WMESS) From PORLEGLIB
    If WMESS <> "" : GMESSAGE = WMESS : mkstat = 2 : Endif
    Endif
  Endif
Endif
# Issue End

# The sequence counter isn't mandatory if the activity code isn't active
CHK = 1
If [M]MODULE=2 & nolign=8 & !func AFNC.ACTIV("TDB")                : CHK=0 : Endif
If [M]MODULE=2 & (find(nolign,9,10,11) & !func AFNC.ACTIV("GDD"))  : CHK=0 : Endif
If [M]MODULE=3 & (nolign=10 | nolign=11) & !func AFNC.ACTIV("KAG") : CHK=0 : Endif
If [M]MODULE=3 & nolign=12 & !func AFNC.ACTIV("FUP")               : CHK=0 : Endif
If [M]MODULE=3 & nolign=14 & !func AFNC.ACTIV("SDD")               : CHK=0 : Endif
If [M]MODULE=2 & nolign=17 & !func AFNC.ACTIV("KBE")               : CHK=0 : Endif
If [M]MODULE=2 & nolign=18 & !func AFNC.ACTIV("KBE")               : CHK=0 : Endif

If VALEUR="" & CHK=1
 GMESSAGE=mess(62,199,1)
 mkstat=1 : Return
Endif

If [F:ANM]CODNUM<>VALEUR
   Read [ANM]ANM0=VALEUR  : If fstat : Raz [F:ANM]  : Endif
Endif
# cas particulier : compteurs pour PAL,CTR,Lot et Série (TB  30/06/03) v 140
If [M]MODULE = 7
 Case nolign
  When 1       If !clalev([F:STO]) Local File STOCK [STO] Endif
               LNGTYP = GLONVCR
               If type([F:STO]STOCOU)>=4 & type([F:STO]STOCOU)<=9
                  If [F:ANM]NBPOS<>1 | [F:ANM]TYP<>2 | [F:ANM]NIVDEF<>1
                     GMESSAGE = mess(87,199,1) : mkstat=1
                  Endif
               Endif
  When 3       If !clalev([F:STJ]) Local File STOJOU [STJ] Endif
               LNGTYP = GLONVCR
               If type([F:STJ]CSTCOU)>=4 & type([F:STJ]CSTCOU)<=9
                  If [F:ANM]NBPOS<>1 | [F:ANM]TYP<>2 | [F:ANM]NIVDEF<>1
                     GMESSAGE = mess(111,199,1) : mkstat=1
                  Endif
               Endif
  When 4       LNGTYP = GLONPAL
  When 5       LNGTYP = GLONCTR
  When 8       LNGTYP = GLONLOT
  When 13      LNGTYP = GLONSER
  When Default LNGTYP = GLONVCR
 Endcase
Elsif [M]MODULE = 3
 Case nolign
  When 12      If func AFNC.ACTIV("FUP") : LNGTYP = GLONFUP : Else : LNGTYP = GLONVCR : Endif
  When 14      If func AFNC.ACTIV("SDD") : LNGTYP = GLONMDT : Else : LNGTYP = GLONVCR : Endif
  When Default LNGTYP = GLONVCR
 Endcase
Else
 LNGTYP = GLONVCR
Endif
#MIPEA - 23/09/2016 - Req 114309 - X3 People integration - START
If [M]MODULE=15 | [M]MODULE=20 #Check X3 People modules 15 and 20
  Gosub INIT_LNG
Endif
#MIPEA - 23/09/2016 - Req 114309 - X3 People integration - END
If sum([F:ANM]POSLNG(0..dim([F:ANM]POSLNG)-1)) > LNGTYP
 GMESSAGE = mess(223,199,1)-"("+num$(LNGTYP)+")" : mkstat=1 : Return
Endif

If [M]MODULE=2
 If nolign=16
  If [F:ANM]CODNUM<>VALEUR
   Read [ANM]ANM0=VALEUR  : If fstat : Raz [F:ANM]  : Endif
  Endif
  CHK=1
  For I=0 To [F:ANM]NBPOS-1
   If [F:ANM]POSTYP(I)=9 : CHK=0 : Break : Endif
  Next
  If CHK
   GMESSAGE=mess(629,199,1) : mkstat=1 : Return
  Endif
  If [F:ANM]NIVRAZ<>4
   GMESSAGE=mess(630,199,1) : mkstat=1 : Return
  Endif
 Endif
Endif

Return

$AS_MANCOU
# sr 08.01 demande 10246
#-------------------------------------------------------------#
# Si module  GPAO pas de saisie manuelle de compteur #
#-------------------------------------------------------------#
If ([M]MODULE = 8 and nolign <> 1)
   VALEUR=1 : mkstat=2
Endif

#-------------------------------------------------------------#
# Si module  STOCK pas de saisie manuelle selon le compteur #
# demande 24926 #
#-------------------------------------------------------------#

If ([M]MODULE=7 and (nolign<>10 & nolign<>11 & nolign<>15 & nolign<>16 & nolign<>17 & nolign<>18 & nolign<>19))
   VALEUR=1 : mkstat=2
Endif

#-----------------------------------------------------#
# Si Compta Tiers pas de saisie manuelle de compteur  #
#-----------------------------------------------------#

If ([M]MODULE=2 and nolign<>8) or ([M]MODULE=3 & !find(nolign,8,14)) #<YYFIN_71258_US250>
   VALEUR=1 : mkstat=2
Endif

#-----------------------------------------------------------------------------------#
# Si module Support client contrôle des compteurs autorisés en saisie manuelle      #
#-----------------------------------------------------------------------------------#
If [M]MODULE=12
    #LSE 16/12/2005 FQ17522 FQ33857
    #If nolign < 5
    #    VALEUR=1
    #    mkstat=2
    #Endif
    #If nolign > 6
    If nolign > 8
        VALEUR=1
        mkstat=2
    Endif
Endif

#-----------------------------------------------------------------------------------#
# Si module  Action commerciale contrôle des compteurs autorisés en saisie manuelle #
#-----------------------------------------------------------------------------------#
#LSE 16/12/2005 FQ33857
#If [M]MODULE=13
#    If nolign < 6
#        VALEUR=1
#        mkstat=2
#    Endif
#    If nolign > 7
#        VALEUR=1
#        mkstat=2
#    Endif
#Endif
#LSE 06/04/2006
If [M]MODULE=13
    If (nolign = 9) or (nolign = 10) or (nolign = 11)
        VALEUR=1
        mkstat=2
    Endif
Endif

#-----------------------------------------------------#
# Si module Comptabilité, pour budget opérationnels , #
# pas de saisie manuelle de compteur Projet           #
#-----------------------------------------------------#
If [M]MODULE=2
 If nolign=9 | nolign=10 | nolign=11 : VALEUR=1 : mkstat=2 : Endif
Endif

#MIPEA - 23/09/2016 - Req 114309 - X3 People integration - START
If find([M]MODULE,15,20)>0 Then #Check X3 People modules 15 and 20
  VALEUR=1 : mkstat=2
Endif
#MIPEA - 23/09/2016 - Req 114309 - X3 People integration - END

Return

