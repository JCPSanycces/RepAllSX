#MIPEA - 23/09/2016 - Req 114309 - X3 People integration - START
$INIT_LNG
Local Integer LNGCPT
Case [M:TCA1]MODULE
 When 15
  Case nolign
   When 1 : LNGCPT=GLONFRM
   When 10 : LNGCPT=GLONMHR
   When 11 : LNGCPT=GLONMHV
   When 12 : LNGCPT=GLONMHP
   When 13 : LNGCPT=GLONMHE
   When 14 : LNGCPT=GLONMHS
   When 15 : LNGCPT=GLONMHC
   When 16 : LNGCPT=GLONMHT
   When Default : LNGCPT=GLONVCR
  Endcase
 When 20 :
  Case nolign
   When 1 : LNGCPT=GLONDEM
   When 2 : LNGCPT=GLONHRSES
   When 4 : LNGCPT=GLONCEV
   When Default : LNGCPT=GLONVCR
  Endcase
 When 9
  Case nolign
   When 2 : LNGCPT=GLONEML
   When 3 : LNGCPT=GLONHRENT
   When 4 : LNGCPT=GLONHRCTR
   When Default : LNGCPT=GLONVCR
  Endcase
 When Default
  LNGCPT=GLONVCR
Endcase
Return
#MIPEA - 23/09/2016 - Req 114309 - X3 People integration - END

#-----------------------------------------#
# Mise à jour variables globales si stock #
#-----------------------------------------#
$MAJFIN
If [M]MODULE = 7
  GCHR  = [F:TCA]CODNUM(0)
  GQUA  = [F:TCA]CODNUM(1)
  GFIFO = [F:TCA]CODNUM(2)
  GPAL  = [F:TCA]CODNUM(3)
  GCTR  = [F:TCA]CODNUM(4)
  GTRF  = [F:TCA]CODNUM(5)
  GINV  = [F:TCA]CODNUM(6)
  GLOT  = [F:TCA]CODNUM(7)
  GWIP  = [F:TCA]CODNUM(8)
  GMIS  = [F:TCA]CODNUM(9)
  GMII  = [F:TCA]CODNUM(10)
  GCFG  = [F:TCA]CODNUM(11)

  # v 140 rajouter les globales pour Série, Inventaire, Chgt stock
  GSER  = [F:TCA]CODNUM(12)
  GSSS  = [F:TCA]CODNUM(13)
  GCHG  = [F:TCA]CODNUM(14)

## ou utiliser la boucle avec les nouvelles variables ??????????????????????????
  # En 140, seule cette boucle est utile, car les variables globales précédentes ne doivent plus être utilisée.
  Raz GSTKCPT
  Raz GSTKCPTMAN
  For I=0 To dim([F:TCA]CODNUM)-1
      GSTKCPT(I)    = [F:TCA]CODNUM(I)
      GSTKCPTMAN(I) = [F:TCA]MANCOU(I)
  Next I

Endif
Return

$AS_MODULE
#------------------------#
# Avant saisie du module #
#------------------------#
#MIPEA - 23/09/2016 - Req 114309 - X3 People integration - START
#For I=1 To len(mess(0,14,1))
# If !find(I,1,2,3,5,6,7,8,9,12,13,14)
#  GMENLOC(I) = 1
# Endif
#Next I
If [V]GMODU(15) | [V]GMODU(20) #Check X3 People modules 15 and 20
  For I=1 To len(mess(0,14,1))
   If !find(I,1,2,3,5,6,7,8,9,12,13,14,15,20) : #Added 15 and 20 for X3 People
    GMENLOC(I) = 1
   Endif
  Next I
Else
  For I=1 To len(mess(0,14,1))
   If !find(I,1,2,3,5,6,7,8,9,12,13,14)
    GMENLOC(I) = 1
   Endif
  Next I
Endif
#MIPEA - 23/09/2016 - Req 114309 - X3 People integration - END
If VALEUR=0 or GMENLOC(VALEUR)=1
 VALEUR = find(0,GMENLOC(1..len(mess(0,14,1))))
Endif
Return

$C_MODULE
#---------------------------------#
#       Contrôle sur MODULE       #
# ------------------------------- #
# Pour l'instant seul les modules #
# achats ventes stocks GP permis  #
# BY 19/11/99 ajout Tiers         #
# GA 08/09/2008 ajout TC          #
#---------------------------------#
#If (VALEUR=2  | VALEUR=3 | VALEUR = 5 | VALEUR = 6 | VALEUR = 7 | VALEUR = 8 | VALEUR = 12 | VALEUR = 13) & GMODU(VALEUR)=2
 #MIPEA - 23/09/2016 - Req 114309 - X3 People integration - START
#If find(VALEUR,1,2,3,5,6,7,8,9,12,13,14) & GMODU(VALEUR)=2
#  mkstat = 0
#Else
#  GMESSAGE = mess(63,199,1)
#  mkstat = 1
#Endif
If [V]GMODU(15) | [V]GMODU(20) #Check X3 People modules 15 and 20
  If find(VALEUR,1,2,3,5,6,7,8,9,12,13,14,15,20) & GMODU(VALEUR)=2 : #Added 15 and 20 for X3 People
    mkstat = 0
  Else
    GMESSAGE = mess(63,199,1)
    mkstat = 1
  Endif
Else
  If find(VALEUR,1,2,3,5,6,7,8,9,12,13,14) & GMODU(VALEUR)=2
    mkstat = 0
  Else
    GMESSAGE = mess(63,199,1)
    mkstat = 1
  Endif
Endif
#MIPEA - 23/09/2016 - Req 114309 - X3 People integration - END
Affzo 10
Return
#MIPEA - 23/09/2016 - Req 114309 - X3 People integration - START
$AM_MODULE
#----------------------------------------------#
# Après modif module : Chargement MANCOU à NON #
#----------------------------------------------#
[M:TCA1]MODULE=VALEUR
Gosub CHARGE_DOC
For nolign=1 To [M]NBDOC
   MANCOU(nolign-1)=1
Next nolign
Affzo 10
Return
