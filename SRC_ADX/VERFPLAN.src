#<AdxTL>@(#)3.0.0.0 $Revision$
#** V7 : Waiting Time Mangement **#
#*********************************#

Local Char PARAM(10)(1..2) , VALEUR(10)
GACTION = "VERFPLAN"
Call TRAITE_CHAR(VALEUR,PARAM,"","VERFPLAN","GENPLAN",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT_DIA": Gosub INIT_DIA
 When "TIT_DIA" : TITCRIT = mess(54,10703,1) : GCURLEG = GLEGFIL
 When "EXEC"    :
 If dim([M:DIA]ALLLEG)>0 & [M:DIA]ALLLEG=2
 Local Integer I
  For I=1 To GNBLEG
   Call EXEC(GDOSLEG(I))
  Next
 Else
  If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
  Call EXEC(GCURLEG)
 Endif
 When "SORTIE"  : Gosub SORTIE
Endcase
Return

$INIT_DIA
Raz [M:DIA]
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

Subprog EXEC(LEGPLAN)
Value Char LEGPLAN
TRA = 1
Local Char APPLI(10)
APPLI = nomap
Local Char    FORMULE(250)
Local Integer I , J , T , OK , VRF , TYP , E , IX , ANOM
#47239
Local Integer LNGFOR
Local Char    OP2(2) , OP3(3) , OP(3) , CODE(80) , TEXTE(80) , ABR(5)

If clalev([F:RUB])=0  : Local File =APPLI+".RUBRIQUE" [RUB]  : Endif
If clalev([F:RUB2])=0 : Local File =APPLI+".RUBRIQUE" [RUB2] : Endif
If clalev([F:CUM])=0  : Local File =APPLI+".CUMUL"    [CUM]  : Endif
If clalev([F:CUM2])=0 : Local File =APPLI+".CUMUL"    [CUM2] : Endif
If clalev([F:VRA])=0  : Local File =APPLI+".VARIA"    [VRA]  : Endif
If clalev([F:VRA2])=0 : Local File =APPLI+".VARIA"    [VRA2] : Endif
If clalev([F:ATB])=0  : Local File =APPLI+".ATABLE"   [ATB]  : Endif
If clalev([F:ATZ])=0  : Local File =APPLI+".ATABZON"  [ATZ]  : Endif
#LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#**If clalev([F:TIM])=0  : Local File =APPLI+".TIMCOD" [TIM]  : Endif
#*!
If clalev([F:TIM])=0  : Local File =APPLI+".TIMCOD" [TIM]  : Endif
#LIPET - 2017-05-20 - END
If !GSERVEUR
 Call OUVRE_TRACE(mess(54,10703,1)-[L]LEGPLAN) From LECFIC : # Vérification plan de paye
Endif

Call ECR_TRACE(mess(55,10703,1),0) From GESECRAN : # Vérification des rubriques
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

VRF  = 1
ANOM = 0

For [RUB2]RUB0 Where LEG=LEGPLAN
 E = 0
 TYP = 1 : FORMULE = [F:RUB2]CNDCAL    : Gosub CONTFRM
 TYP = 2 : FORMULE = [F:RUB2]BAS       : Gosub CONTFRM
 TYP = 3 : FORMULE = [F:RUB2]RAT1      : Gosub CONTFRM
 TYP = 4 : FORMULE = [F:RUB2]RAT2      : Gosub CONTFRM
 TYP = 5 : FORMULE = [F:RUB2]TBLFRM(0) : Gosub CONTFRM
 TYP = 5 : FORMULE = [F:RUB2]TBLFRM(1) : Gosub CONTFRM
 TYP = 5 : FORMULE = [F:RUB2]TBLFRM(2) : Gosub CONTFRM
 For IX=0 To [F:RUB]ITVNBR-1
  TYP = 6 : FORMULE = [F:RUB2]ITVAMT(IX) : Gosub CONTFRM
 Next IX
 TYP = 7 : FORMULE = [F:RUB2]AMTMAX(0) : Gosub CONTFRM
 TYP = 7 : FORMULE = [F:RUB2]AMTMAX(1) : Gosub CONTFRM
 TYP = 7 : FORMULE = [F:RUB2]AMTMAX(2) : Gosub CONTFRM
Next
If !ANOM
 Call ECR_TRACE(mess(57,10703,1),0) From GESECRAN : # Aucune anomalie
Endif

Call ECR_TRACE("",0) From GESECRAN

Call ECR_TRACE(mess(56,10703,1),0) From GESECRAN : # Vérification des cumuls
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

VRF  = 2
ANOM = 0
For [CUM2]CUM0 Where LEG=LEGPLAN
 E = 0
 TYP = 11 : FORMULE = [F:CUM2]CUMINI : Gosub CONTFRM
 TYP = 12 : FORMULE = [F:CUM2]CUMREP : Gosub CONTFRM
Next
If !ANOM
 Call ECR_TRACE(mess(57,10703,1),0) From GESECRAN : # Aucune anomalie
Endif

Call ECR_TRACE("",0) From GESECRAN
Call ECR_TRACE(mess(57,123,1)-mess(40,124,1),0) From GESECRAN : # Vérification variables
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
VRF  = 3
ANOM = 0
TYP=13

#LIPET - 2017-05-20 - START
#** V7 : Waiting Time Mangement **#
#**For [VRA2]VRA0 Where TIMCOD<>""
#** E=0
#** CODE=[F:VRA2]TIMCOD
#** Read[TIM]TIM0=[F:VRA2]TIMCOD
#** If fstat
#**  GERR = 1 : GMESSAGE = mess(160,123,1) : Gosub ERREUR : # Evenement  inexistant
#** Endif
#**Next
#**
#*!
For [VRA2]VRA0 Where TIMCOD<>""
 E=0
 CODE=[F:VRA2]TIMCOD
 Read[TIM]TIM0=GCURLEG;[F:VRA2]TIMCOD
 If fstat
  GERR = 1 : GMESSAGE = mess(160,123,1) : Gosub ERREUR : # Evenement  inexistant
 Endif
Next
#LIPET - 2017-05-20 - END
If !ANOM
 Call ECR_TRACE(mess(57,10703,1),0) From GESECRAN : # Aucune anomalie
Endif

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
#47239 : On affichait la dernière erreur dans une boite + on rebouclait sur Verification plan de paie
Raz GERR : FIN = 1
End

#tax band
$CONTFRM
FORMULE = vireblc(format$("KT:250X",FORMULE),2)
I = 0
GERR = 0
# 47239
LNGFOR = len(FORMULE)

While I<=len(FORMULE)-1
 OP2 = mid$(FORMULE,I,2)
 OP3 = mid$(FORMULE,I,3)
 T = 0
 #65041
 If find(OP2,"R_","V_","C_","B_")
  T = 1 : J = I+2 : I += 2 : OP = OP2
 Endif
 If find(OP3,"TA_","TB_","TC_","EA_","EB_","EC_","[F]","[F:","TD_","TE_","TF_","TG_","TH_","TI_","ED_","EE_","EF_","EG_","EH_","EI_")
  T = 1 : J = I+3 : I += 3 : OP = OP3
 Endif
 If T
  While I<len(FORMULE) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(FORMULE,I+1,1))
   I += 1
  Wend
  CODE = seg$(FORMULE,J,I)
  Case OP
   When "R_","TA_","TB_","TC_","EA_","EB_","EC_","B_","TD_","TE_","TF_","TG_","TH_","TI_","ED_","EE_","EF_","EG_","EH_","EI_": #65041
    Read [RUB]RUB0 = LEGPLAN;CODE
    If fstat
     GERR = 1 : GMESSAGE = mess(11,10702,1) : Gosub ERREUR :  # Rubrique inexistante
    #65041
    Elsif OP<>"R_" & OP<>"B_"
     If [F:RUB]TYPRUB<>5
      GERR = 1 : GMESSAGE = mess(12,10702,1) : Gosub ERREUR : # La rubrique n'est pas de type assiette
     Endif
    Endif
   When "V_"
    Read [VRA]VRA0 = LEGPLAN;CODE
    If fstat
     GERR = 1 : GMESSAGE = mess(13,10702,1) : Gosub ERREUR : # Variable inexistante
    #Elsif [F:VRA]FLGEXS<>2 :#DBA le 01/03/06 : ????
     Elsif [F:VRA]FLGEXS=2
     GERR=1 : GMESSAGE=mess(183,10703,1) : Gosub ERREUR : # Variable de note de frais
    Endif
   When "C_"
    Read [CUM]CUM0 = LEGPLAN;CODE
    If fstat
     GERR = 1 : GMESSAGE = mess(14,10702,1) : Gosub ERREUR : # Cumul inexistant
    Endif
   When "[F]"
    #LIPET - 2017-05-20 - START
    #** V7 : Waiting Time Mangement **#
    #**OK = 0
    #**For [ATZ]DICO Where CODZONE=CODE
    #** If find([F:ATZ]CODFIC,GEMPTAB(1..GNBEMPTAB),"TIMEMPDAT","TIMRECAP")
    #**  OK = 1 : Break
    #** Endif
    #**Next
    #**If !OK
    #** GERR = 1 : GMESSAGE = mess(15,10702,1) : Gosub ERREUR : # Champ inexistant dans la base
    #**Endif
  #*!
    OK = 0
    For [ATZ]DICO Where CODZONE=CODE
     If find([F:ATZ]CODFIC,GEMPTAB(1..GNBEMPTAB),"TIMEMPDAT","TIMRECAP")
      OK = 1 : Break
     Endif
    Next
    If !OK
     GERR = 1 : GMESSAGE = mess(15,10702,1) : Gosub ERREUR : # Champ inexistant dans la base
    Endif
  #LIPET - 2017-05-20 - END
   When "[F:"
    I = instr(J,FORMULE,"]")
    ABR = seg$(FORMULE,J,I-1)
    J = I+1
    While I<len(FORMULE) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(FORMULE,I+1,1))
     I += 1
    Wend
    CODE = seg$(FORMULE,J,I)
    Read [ATB]ABRFIC = ABR
    If !fstat
     Read [ATZ]CODZONE = [F:ATB]CODFIC;CODE
    Endif
    If fstat
     CODE = "[F:"+ABR+"]"+CODE
     GERR = 1 : GMESSAGE = mess(15,10702,1) : Gosub ERREUR : # Champ inexistant dans la base
    Endif
  Endcase
  #47239
  #65041
  If find(OP,"R_","C_","B_") & mid$(FORMULE,I+1,1)<>"("
   LNGFOR +=3
  Endif
  # fin 47239
 Else
  I += 1
 Endif
Wend
#47239
If LNGFOR>250
 # Expression trop longue
 # Les codes rubriques et cumuls seront complétés par "(1)" à la génération du plan de paie
 GERR = 1 : GMESSAGE = mess(62,123,1)+"\"+mess(206,10703,1)
 Gosub ERREUR
Endif
# fin 47239
Return

$ERREUR
If E=0
 Case VRF
  When 1 : TEXTE = mess(55,10702,1)-":"-[F:RUB2]COD-"("+num$([F:RUB2]ROW)+")" : # Rubrique
  When 2 : TEXTE = mess(82,10702,1)-":"-[F:CUM2]CUMCOD                        : # Cumul
  When 3 : TEXTE = mess(33,147,1)-":"-[F:VRA2]COD                             : #Variable
 Endcase
 Call ECR_TRACE(TEXTE,1) From GESECRAN
 E = 1
Endif
Case TYP
 When  1 : TEXTE = mess(58,10703,1) : # Condition de calcul
 When  2 : TEXTE = mess(59,10703,1) : # Base
 When  3 : TEXTE = mess(60,10703,1) : # Taux 1
 When  4 : TEXTE = mess(61,10703,1) : # Taux 2
 When  5 : TEXTE = mess(62,10703,1) : # Formule grille
 When  6 : TEXTE = mess(63,10703,1) : # Montant par intervalle
 When  7 : TEXTE = mess(64,10703,1) : # Plafond
 When 11 : TEXTE = mess(65,10703,1) : # Formule d'initialisation
 When 12 : TEXTE = mess(66,10703,1) : # Formule de reprise
 When 13 : TEXTE = mess(160,123,1)  : # Evenement inexistant
Endcase
Call ECR_TRACE(TEXTE-":"-CODE-":"-GMESSAGE,0) From GESECRAN
ANOM += 1
Return

