Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()

#RMA * 85785
If func AFNC.ACTIV("KPO") > 0
  Call SHOW_HIDE_TPN(VALEUR) From PORLEGLIB
Endif

End
