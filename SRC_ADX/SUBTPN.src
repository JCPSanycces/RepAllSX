#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
#    PURCHASE RETURN TYPES                                                           #
######################################################################################
$ACTION
Case ACTION
  When "OUVRE"         : Gosub OUVRE
  When "AFFMASK"       : Gosub AFFMASK
  When "RAZCRE"        : Gosub RAZCRE
  When "RAZDUP"        : Gosub RAZDUP
  When "INICRE"        : Gosub INICRE
  When "INIMOD"        : Gosub INIMOD
  When "ANNULE"        : Gosub ANNULE
  When "LIENS"         : Gosub LIENS
  When "FERME"         : Gosub FERME
  When "SEL_TABLE"
    Case TABLE
      When "SELTPN"    : Gosub SELTPN
    Endcase
  When "VERIF_CRE"     : Gosub VERIF_CRE
  When "VERIF_MOD"     : Gosub VERIF_MOD
Endcase

Return
######################################################################################
######################################################################################
$OUVRE

#-----------------------------------#
# Save global variables             #
#-----------------------------------#
Gosub SAUV_GLOB From TRTX3GLOB
Raz GGRPFCY
Raz GSOCIETE

If !clalev([F:TPN3]) : Local File TABPNHTYP [TPN3] : Endif
If !clalev([F:ANM])  : Local File ACODNUM   [ANM]  : Endif

Return
######################################################################################
######################################################################################
$VERIF_CRE

Gosub VERIF

Return
######################################################################################
######################################################################################
$VERIF_MOD

Gosub VERIF

Return
######################################################################################
######################################################################################
$VERIF

Case [M:TPN1]LEG
  When ""
    Read [F:TPN3]TPN0=[M:TPN1]PNHTYP;"POR"
    If !fstat
      If [M:TPN1]RECTYP <> [F:TPN3]RECTYP
        Call ECR_TRACE(func AFNC.MES2(mess(136,7711,1),[F:TPN3]PNHTYP,[F:TPN3]LEG),2) From GESECRAN
        OK = 0 : Return
      Endif
      If [M:TPN1]SAFTTRNTYP <> [F:TPN3]SAFTTRNTYP
        Call ECR_TRACE(func AFNC.MES2(mess(137,7711,1),[F:TPN3]PNHTYP,[F:TPN3]LEG),2) From GESECRAN
        OK = 0 : Return
      Endif
    Endif
  When "POR"
    Read [F:TPN3]TPN0=[M:TPN1]PNHTYP;""
    If !fstat
      If [M:TPN1]RECTYP <> [F:TPN3]RECTYP
        Call ECR_TRACE(func AFNC.MES2(mess(136,7711,1),[F:TPN3]PNHTYP,mess(59,151,1)),2) From GESECRAN
        OK = 0 : Return
      Endif
      If [M:TPN1]SAFTTRNTYP <> [F:TPN3]SAFTTRNTYP
        Call ECR_TRACE(func AFNC.MES2(mess(137,7711,1),[F:TPN3]PNHTYP,mess(59,151,1)),2) From GESECRAN
        OK = 0 : Return
      Endif
    Endif
Endcase

Return
######################################################################################
######################################################################################
$INICRE

Gosub MAJ_ATEXTRA

Return
######################################################################################
######################################################################################
$INIMOD

Gosub MAJ_ATEXTRA

Return
######################################################################################
######################################################################################
$MAJ_ATEXTRA

If GREP="D"
 Call DUPTEXTRA("TABPNHTYP","DESAXX",CLECUR1,"","TABPNHTYP","DESAXX",[F:TPN]PNHTYP,[F:TPN]LEG)  From ATEXTRA
 Call DUPTEXTRA("TABPNHTYP","SHOAXX",CLECUR1,"","TABPNHTYP","SHOAXX",[F:TPN]PNHTYP,[F:TPN]LEG)  From ATEXTRA
Endif

#--- Creation / Modif de ATEXTRA
Call MAJTEXTRA ([M:TPN1]DESAXX,"TABPNHTYP","DESAXX",[M:TPN1]PNHTYP,[M:TPN1]LEG) From ATEXTRA
Call MAJTEXTRA ([M:TPN1]SHOAXX,"TABPNHTYP","SHOAXX",[M:TPN1]PNHTYP,[M:TPN1]LEG) From ATEXTRA

Return
######################################################################################
######################################################################################
$AFFMASK

Call FMTLEG From TRTX3 : # Pour rendre invisible si nécessaire le champ "Législation"
Gosub GRILEG

Return
######################################################################################
######################################################################################
$RAZCRE

Gosub GRILEG

#RMA * 85785
If func AFNC.ACTIV("KPO") > 0
  Call SHOW_HIDE_TPN([M:TPN1]LEG) From PORLEGLIB
Endif

Return
######################################################################################
######################################################################################
$RAZDUP

#RMA * 85785
If func AFNC.ACTIV("KPO") > 0
  Call SHOW_HIDE_TPN([M:TPN1]LEG) From PORLEGLIB
Endif

Return
######################################################################################
######################################################################################
$LIENS

GCURLEG = [F:TPN]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
GGRPFCY = [F:TPN]GFY

#RMA * 85785
If func AFNC.ACTIV("KPO") > 0
  Call SHOW_HIDE_TPN([M:TPN1]LEG) From PORLEGLIB
Endif

# Issue X3-143 - 2016-10-03 by RICAR : 107966 - Change the field actions on RECTYP, SAFTTRNTYP and COMAT
# Issue X3-143
If func AFNC.ACTIV("KPO") > 0
  Gosub DISABLE_TPN_FIELDS From PORLEGLIB
Endif
# End issue X3-143

Return
######################################################################################
######################################################################################
$GRILEG

If func AFNC.ACTIV("LEG")=0 : # Mono-legislation folder
  Diszo [M:TPN1]LEG
  [M:TPN1]LEG=GDOSLEG(1)
  Affzo [M:TPN1]LEG : If dim([M:TPN1]ZLEG)>0  Affzo [TPN1]ZLEG : Endif
Endif

Return
######################################################################################
######################################################################################
$ANNULE

Delete [AXX]Where CODFIC="TABPNHTYP" & IDENT1=[F:TPN]PNHTYP & IDENT2=[F:TPN]LEG

Return
######################################################################################
######################################################################################
$FERME
#------------------------------------#
# Restore global variables           #
#------------------------------------#
Gosub REST_GLOB From TRTX3GLOB

# To manage the button Tunnel
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONTPN) : Endif

VCOD = CLE2

Return
######################################################################################
######################################################################################
$SELTPN

If clalev([F:TPN])=0  : Local File TABPNHTYP  [TPN] : Endif

If clalev([F:FCY])=0  : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY] : Endif
If clalev([F:FGR])=0  : Local File FACGROUP   [FGR] : Endif
If clalev([F:AXX])=0  : Local File ATEXTRA    [AXX] : Endif
If clalev([F:AMZZ])=0 : Local File AMSKZON   [AMZZ] : Endif :#--CPO 71937 Pour déterminer les options de sélection
If clalev([F:AGF])=0  : Local File AGRPFCY    [AGF] : Endif :#--CPO 71937

Local Char    FCY(GLONFCY)
Local Char    CPY(GLONCPY)
Local Char    LEG(GLONADI)
Local Char    GRP(GLONAGF)
Local Integer WNOL
Local Integer ERR
Local Char    SZVIEW(GLONAVW)

#--Selection options
If dim(OPTIONS)<0 : Local Char OPTIONS(30) Endif
Local Char CODMSK   (GLONAMK)
Local Char CHAMPCOD (GLONAVA)
CODMSK  =PARAM(6)
CHAMPCOD=PARAM(7)

OPTIONS=""
If CODMSK<>"" & CHAMPCOD<>""
  Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
  If fstat=0 : OPTIONS =[F:AMZZ]OPTOBJ : Endif
Endif

If GFONCTION = "GESTPN" Then
  OBJET = "TPN"
  Return
Endif

#--------------------------------------------------------------------------------------------------
# Identifying the parameters
#--------------------------------------------------------------------------------------------------
LEG    = PARAM(1)
FCY    = PARAM(2)
GRP    = PARAM(3)
CPY    = PARAM(4)

#--Init. of legislation
If func AFNC.ACTIV("LEG")=0
 [L]LEG = GDOSLEG
Endif

If [L]LEG=""
 If [L]FCY<>""
  Call LEC_FCY([L]FCY) From CPTLEC
  Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
  [L]LEG = [F:CPY]LEG
 Elsif [L]CPY<>""
  Call LEC_CPY([L]CPY) From CPTLEC
  [L]LEG = [F:CPY]LEG
 Endif
Endif

If [L]LEG=""
 [L]LEG = GCURLEG
Endif

START   = "[F:TPN]PNHTYP"
ORDRE   = "[F:TPN]PNHTYP;[F:TPN]LEG"
OBJET   = "TPN"
OPTIONS = "|"

#--------------------------------------------------------------------------------------------------
## Standard selection criteria
#--------------------------------------------------------------------------------------------------

CRITERE(1) = '1=1'
#--Groupe de soc/sites
If [L]FCY="" & [L]CPY="" & [L]GRP<>""
  #--If group it's a company
  Read [F:AGF]AGF0=[L]GRP
  If !fstat
    If [F:AGF]FLGLEG=2 : [L]CPY=[L]GRP : Endif
  Endif
  #--Le filtrage sur les groupes sites/sociétés sont fait dans le link directement
Endif
#--Facility
If    [L]FCY<>""
  CRITERE(1) -= '& ([F:TPN]GFY="" | ([F:TPN]GFY<>"" & [F:FGR]FCY="'+[L]FCY+'"))'
#--Company
#Elsif [L]CPY<>""
#  CRITERE(1) -= '& ([F:TPN]GFY="" | ([F:TPN]GFY<>"" & [F:TREC]LEGCPY="'+[L]CPY+'"))'
Endif
#--Legislation
If [L]LEG<>""
  CRITERE(2) -= '& ([F:TPN]LEG="'+[L]LEG+'" | [F:TPN]LEG="")'
Endif
#--First selection character
If dim(SELCAR)>0 & SELCAR<>0
  CRITERE(2) -= '& left$([F:TPN]PNHTYP,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
Endif

ICRITERE = 3

#MGG X3-38593 Row level permission
#Call FILROLE(OBJET,FILROLE) From SUBARL
Call FILROLE("TPN",FILROLE) From SUBARL
#END MGG X3-38593 Row level permission

If FILROLE<>"" & FILROLE<>"1=1"
 For I=0 To dim(FILROLE)-1
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILROLE(I),"&") From GOBJSUB
 Next I
Endif

# Options de sélection
If OPTIONS<>""
  Gosub OPTIONS From WOTPN
  ICRITERE=2
  For I=1 To NBCOND
   If instr(1,OPTIONS,OPT(I))
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","("+CONDIT(I)+")","&") From GOBJSUB
   Endif
  Next I
Endif

DEFPAG = 1

Return
###########################################################################
# $TRTCOP
###########################################################################
$TRTCOP

#-----------------------------------------------------------#
# Label called by ACOPIE Supervisor script                  #
# --------------------------------------------------------- #
# Copy of a purchase return                                 #
#-----------------------------------------------------------#
If [M]DOSORG=nomap
   Local File TABPNHTYP [TPN1]
   Local File ATEXTRA   [AXX1]

Else
   Local File =[M]DOSORG+".TABPNHTYP" [TPN1]
   Local File =[M]DOSORG+".ATEXTRA"   [AXX1]
Endif
If [M]DOSDES=nomap
   Local File TABPNHTYP [TPN2]
   Local File ATEXTRA   [AXX2]
   Local File ACTIV     [ACV2]
Else
   Local File =[M]DOSDES+".TABPNHTYP" [TPN2]
   Local File =[M]DOSDES+".ATEXTRA"   [AXX2]
   Local File =[M]DOSDES+".ATABDIV"   [ADI2]
   Local File =[M]DOSDES+".ACTIV"     [ACV2]
   Local File =func DOSCONT.DOSX3([M]DOSDES)+".ADOSSIER"  [ADS2]
Endif
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TRT_COPY

Close Local File [TPN1], [TPN2]
Close Local File [AXX1], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
If clalev([F:ADI2])>0 : Close Local File [ADI2] : Endif
If clalev([F:ACV2])>0 : Close Local File [ACV2] : Endif

Return

######################################################################################
######################################################################################
$TRT_COPY
#--------------------------------------------------#
# Copy transaction of a purchase return            #
#--------------------------------------------------#
Local Char    LEGDES(GLONADI)
Local Integer WMONOLEGDES
# By default : Destination Leg = Leg of the record being copied
LEGDES=TABLE2
GOK=1

If [M]DOSDES<>nomap
    # Le dossier destination est-il mono-leg ?
    If [F:ACV2]CODACT<>"LEG"
     Read [ACV2]CODACT = "LEG"
     If fstat Raz [F:ACV2] : Endif
    Endif
    If [F:ACV2]FLACT<>2
     WMONOLEGDES=0
    Else
     WMONOLEGDES=1
    Endif

    If WMONOLEGDES =0
        # Dossier destination mono-leg
        LG = instr(1, [M]DOSDES, "@")
        If LG = 0 Then
          SZDOSSIER = [M]DOSDES
        Else
          SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
        Endif
        Read [ADS2]DOSSIER=SZDOSSIER
        If fstat
            # Problem reading the folder
            Call MESSAGE(SZDOSSIER-":"-mess(78,133,1) ) From GESECRAN  #-- Folder does not exist --#
            Return
        Endif
        If [F:ADS2]DOSLEG(0)=""
            # Legislation not available on the folder
            Call MESSAGE(SZDOSSIER-":"-mess(241,133,1) ) From GESECRAN  #-- At least one legislation is mandatory  --#
            Return
        Endif
        If TABLE2<>[F:ADS2]DOSLEG(0) & TABLE2<>''
            # La leg de l'enreg. à copier n'est pas tte leg et elle est <> Leg dossier mono-leg
            # Pas de copie
            Call MESSAGE(mess(617,199,1)-"("-[F:ADS2]DOSLEG(0)-") :"-mess(618,199,1)) From GESECRAN
            Return
        Elsif TABLE2=''
            # La leg de l'enreg. à copier est toute leg
            # On peut copier l'enreg : Leg destination=leg du dossier mono-leg
            LEGDES=[F:ADS2]DOSLEG(0)
        Endif
    Else
        # Dossier destination multi-leg
        If TABLE2<>''
          # Enregistrement à copier avec leg<>""
          Local Char SZDOSSIER(GLONADS)
          Local Integer LG
          Read [ADI2]CODE=909; TABLE2
          If fstat
           Call MESSAGE (TABLE2 - ':'- mess(173,187,1)  ) From GESECRAN : #-- Législation inexistante sur ce dossier --#
           Return
          Endif

          LG = instr(1, [M]DOSDES, "@")
          If LG = 0 Then
            SZDOSSIER = [M]DOSDES
          Else
            SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
          Endif
          Read [ADS2]DOSSIER=SZDOSSIER
          If !fstat Then
              If !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
                Call MESSAGE(TABLE2 - ':' - mess(249,133,1) ) From GESECRAN  #-- Législation non gérée par ce dossier --#
                Return
              Endif
          Endif
        Endif
    Endif
Endif

Read [TPN2]TPN0=TABLE ;LEGDES
If !fstat
    Local Integer WOK : WOK=1
    Call AVERTIR (mess(197,133,1), WOK) From GESECRAN : #-- enregistrement existe déjà --#
    If WOK=1 Return : Endif
Endif

Trbegin [TPN2]
  Delete [TPN2] Where PNHTYP=TABLE & LEG = LEGDES
  If fstat=1 GOK=-1 : GLOCK="$"+[M]DOSDES+".TABPNHTYP"-TABLE : Goto ROLL_COPIE
  Elsif fstat GOK=0 : Call RSTA("TPN2",TABLE) From GLOCK    : Goto AB_COPIE
  Endif
  If !fstat
         #--- copie des données
         For [TPN1]Where PNHTYP=TABLE & LEG = TABLE2
             [F:TPN2]=[F:TPN1]
             [F:TPN2]LEG = LEGDES
             If TABLE2=LEGDES
                 Call COPTEXTRA("TABPNHTYP","DESAXX",TABLE,TABLE2) From ATEXTRA
                 Call COPTEXTRA("TABPNHTYP","SHOAXX",TABLE,TABLE2) From ATEXTRA
             Else
                 Call COPTEXTRA1("TABPNHTYP","DESAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
                 Call COPTEXTRA1("TABPNHTYP","SHOAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
             Endif
             If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
             If dim([F:TPN2]UPDUSR)>0 : [F:TPN2]UPDUSR = GUSER : Endif
             If dim([F:TPN2]UPDDAT)>0 : [F:TPN2]UPDDAT = date$ : Endif
             Write [TPN2]
             If fstat
                GOK = 0 : Call FSTA("TPN2") From GLOCK : Break
             Endif
         Next
      Endif
      If   GOK<0    : Goto ROLL_COPIE
         Elsif !GOK : Goto AB_COPIE
      Endif
Commit

Return
######################################################################################
######################################################################################
#----------- Abandon copy ----------#
$AB_COPIE
Rollback
Return
######################################################################################
######################################################################################
#----- Try again if necessary  -----#
$ROLL_COPIE
Rollback : Call ROLL From GLOCK : If !GROLL Goto TRT_COPY : Endif
Return
######################################################################################
######################################################################################
Subprog CONTTPN(COD,LEG,CODMSK,CHAMPCOD,FCY,GROUPE,CPY)
Variable Char    COD()
Value    Char    LEG()
Value    Char    CODMSK()
Value    Char    CHAMPCOD()
Value    Char    FCY
Value    Char    GROUPE
Value    Char    CPY


Local    Integer CAS
Local    Char    OPTIONS(30)

If GFONCTION = "GESTPN" | COD="" : End : Endif

If clalev([F:TPN]) =0 : Local File TABPNHTYP [TPN]  : Endif
If clalev([F:AMZZ])=0 : Local File AMSKZON   [AMZZ] : Endif :#--for the selection options of the object

If func AFNC.ACTIV("LEG")=0
  LEG = GDOSLEG
Endif

CAS = 1 : #--Legislation is empty

# No GCURLEG but we have CPY or FCY on-line
If clalev([F:CPY])=0  : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY] : Endif
If [L]LEG="" and ([L]CPY<>"" | [L]FCY<>"")
  If [L]FCY<>""
    If [F:FCY]FCY<>[L]FCY
      Read [F:FCY]FCY0=[L]FCY
      If fstat : Raz [F:FCY] Endif
    Endif
    If [L]CPY="" : [L]CPY=[F:FCY]LEGCPY : Endif
  Endif
  If [L]CPY<>""
    If [F:CPY]CPY<>[L]CPY
      Read [F:CPY]CPY0=[L]CPY
      If fstat : Raz [F:CPY] Endif
    Endif
    [L]LEG=[F:CPY]LEG
  Endif
Endif

If LEG<>""
  Read [TPN]TPN0=COD;LEG
  If fstat
    Read [TPN]TPN0=COD;""
  Else
    CAS = 2 : #--Legislation isn't empty
  Endif
Else
  Read [TPN]TPN0(1)=COD
  If !fstat
    LEG = [F:TPN]LEG
    CAS = 2
  Endif
Endif

If fstat
  Filter [TPN] Where PNHTYP=[L]COD
  Look [TPN]TPN0 First
  If !fstat
    # "No existing record for the curent legislation"
    GMESSAGE = [L]COD-":"-mess(232,107,1)-"["+[L]LEG+"]"
  Else
    # "Record does not exist"
    GMESSAGE = [L]COD-":"-mess(23,100,1)
  Endif
  Filter [TPN]
  mkstat = 2 : End
Endif

#--Filter by company group
If [L]CPY<>"" and [L]FCY=""
  If [F:TPN]GFY<>""
    If clalev([F:AGF])=0 : Local File AGRPFCY    [AGF]  : Endif
    Read [AGF]AGF0=[F:TPN]GFY
    If !fstat
      If [F:AGF]FLGLEG=2
        #--Company
        If [F:TPN]GFY<>[L]CPY
          GMESSAGE += COD+"\"+mess(63,127,1)-":"-[F:TPN]GFY :
          mkstat = 2 : End
        Endif
      Elsif [F:AGF]FLGCPY=2
        If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
        Look [AGC]AGC0 = [F:TPN]GFY;[L]CPY
        If fstat
          GMESSAGE += COD+"\"+mess(63,127,1)-":"-[F:TPN]GFY :
          mkstat = 2 : End
        Endif
      Endif
    Endif
  Endif
Endif
#--

#--Coeherence control between tax group and legislation
If [F:TPN]GFY<>"" and LEG<>""
  Call CTLGFYLEG([F:TPN]GFY,LEG,"","") From TRTVENCTL
  If mkstat : End : Endif
Endif
#--Coeherence control between between group and return legislation
If GROUPE<>"" and [F:TPN]LEG<>""
  Call CTLGFYLEG(GROUPE,[F:TPN]LEG,"","") From TRTVENCTL
  If mkstat : End : Endif
Endif

#--Findig Object options defined on the data type of the field in the screen
OPTIONS=""
If CODMSK<>"" & CHAMPCOD<>""
  Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
  If fstat=0 : OPTIONS=[F:AMZZ]OPTOBJ : Endif
Endif

If CAS=2
 Call CONTROLE("TPN",OPTIONS,LEG,COD,mkstat) From CONTOBJ
Else
 Call CONTROLE("TPN",OPTIONS,"",COD,mkstat) From CONTOBJ
Endif

End
######################################################################################
######################################################################################
Subprog TUNTPN(COD,LEG)
Variable Char    COD()
Value    Char    LEG()
Local Integer TOKILL

TOKILL = 0
If dim(VCOD)<1
  Global Char VCOD(GLONTPN)
  TOKILL = 1
Endif

# To update the TPN code after the tunnel order
VCOD = COD
If clalev([F:TPN])=0 : Local File TABPNHTYP [TPN] : Endif
If GNBLEG=1
  LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>""
  LEG = GCURLEG
#--If LEG="" then firstly we search a TPN record with LEG="" secondly a TPN record with TPN<>""
Elsif LEG=""
  Read [TPN]TPN0 = VCOD;[L]LEG
  If fstat
    Read [TPN]TPN0(1)=VCOD
    If !fstat
      LEG = [F:TPN]LEG
    Endif
  Endif
Endif

Read [TPN]TPN0 = [L]COD;[L]LEG
If fstat : LEG = "" : Endif

Call OBJET("TPN",[L]LEG,VCOD) From GOBJET

COD = VCOD
If TOKILL : Kill VCOD : Endif

End
######################################################################################
## Section automatically added (screen TPN1) 10/21/2014 17:53:47 (RMA)
######################################################################################
Subprog C_LEG(VALEUR)
Variable Char    VALEUR()

GCURLEG = VALEUR

#Issue X3-82950 - 2018-03-20 by VAVIL : 122007 - Sequence number control
If func AFNC.ACTIV("KPO")>0 & find(VALEUR,"POR","")
  Local Char WMESS(100) : WMESS = ""
  Call CTL_CODNUM_LEG(VALEUR,[M:TPN1]PNHTYP,"TPN",WMESS)    From PORLEGLIB
  If WMESS <> "" : GMESSAGE = WMESS : mkstat = 2 : Endif
Endif
# Issue End

End
######################################################################################
Subprog C_GFY(VALEUR)
Variable Char    VALEUR()

GGRPFCY = VALEUR

End
######################################################################################
Subprog AM_GFY(VALEUR)
Variable Char    VALEUR()

GGRPFCY = VALEUR

End
######################################################################################
Subprog C_CODNUM(VALEUR)
Variable Char    VALEUR()
#Issue X3-82950 - 2018-03-20 by VAVIL : 122007 - Sequence number control
If VALEUR<>''
  If func AFNC.ACTIV("KPO")>0 & find([M:TPN1]LEG,"POR","")
    Local Char WMESS(100) : WMESS = ""
    If find(VALEUR,[M:TPN1]CODNUMEND,[M:TPN1]CODNUMFCYD,[M:TPN1]CODNUMCPYD) : GMESSAGE = mess(142,7711,1) : mkstat = 2 : End : Endif
    Call CTL_CODNUM_NORMAL(VALEUR,[M:TPN1]LEG,[M:TPN1]PNHTYP,"TPN",WMESS) From PORLEGLIB
    If WMESS <> "" : GMESSAGE = WMESS : mkstat = 2 : Endif
  Endif
Endif
# Issue End

Gosub CTL_CODNUM

End
