# Classe EDISDNO


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AREAD_AFTER"           : Gosub AREAD_AFTER
    Endcase
Endcase
Return
#$EVENTS
##Case [L]CURPTH
##   When ""
##    Case [L]AEVENT
##    Endcase
##Endcase
#Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_AFTER_LOAD_REPRESENTATION" : Gosub MET_AFTER_LOAD_REPRESENTATION
  Endcase
Return


####################################################################
$AREAD_AFTER
  Gosub GETVALPARAMURL From TRTFUNEDI
Return


#********************************************************************
# Method MET_AFTER_LOAD_REPRESENTATION
#********************************************************************
#
#*
#* @param WCATACT
#* @param WCATCOD
#* @param WPARCOD
#* @param WDUPLICATE
#* @param WTEST
#* @param WSEPDEC #114721
#* @param WERR
#* @return [V]CST_AOK/[V]CST_AERROR
#*!
$MET_AFTER_LOAD_REPRESENTATION
  Local Integer WSTATUS    : WSTATUS = [V]CST_AOK
  Local Integer WCATOPE    : WCATOPE = func EDILIBB.GET_CATOPE(WCATCOD, WERR)
  Case WCATACT
    When 1 :
      Case WPARCOD
        When "EDICOM" : Gosub EDICOM_ISSUE
        When Default  : WSTATUS = [V]CST_AERROR : WERR = ""
      Endcase
    When 2 :
      Case WPARCOD
        When "EDICOM" : Gosub EDICOM_RECEIPT
        When Default  : WSTATUS = [V]CST_AERROR : WERR = ""
      Endcase
  Endcase

  ARET_VALUE = WSTATUS
Return

$EDICOM_ISSUE
  #not implemented
  WSTATUS = [V]CST_AERROR
Return

$EDICOM_RECEIPT
  WSTATUS = [V]CST_AOK

  #test EDIDOCFUN
  WSTATUS = func TEST_FUNCOD(WCATOPE, this.EDIDOCFUN, WERR)
  If WSTATUS = [V]CST_AOK
    Case WCATOPE #func EDILIBB.GET_CATOPE(WCATCOD, WERR)
      When 0 :
        WSTATUS = [V]CST_AERROR
      When 1 : # Read -> error
        Gosub EDICOM_RECEIPT_OPE_READ
      When 2 : # Create -> is by default
        Gosub EDICOM_RECEIPT_OPE_CREATE
      When 3 : # Delete
        Gosub EDICOM_RECEIPT_OPE_DELETE
      When 4 : # Update -> not implemented
        Gosub EDICOM_RECEIPT_OPE_UPDATE
    Endcase
  Endif
Return



$EDICOM_RECEIPT_OPE_READ
  WSTATUS = [V]CST_AERROR
Return

$EDICOM_RECEIPT_OPE_CREATE
  Gosub EDICOM_RECEIPT_GET_X3_KEYS



  #1-traitement de l'en-tête

  #dates conversion
  this.SDN.RCPDAT = format$("D:YYYYMMDD",left$(this.EDIRCPDAT, 8))
  this.SDN.NOTDAT = format$("D:YYYYMMDD",left$(this.EDINOTDAT, 8))

  #2-traitement des lignes
  Local Integer I
  For I = 1 To maxtab (this.SDN.SDND)
    #dates conversion
    this.SDN.SDND(I).RCPDAT = this.SDN.RCPDAT
    this.SDN.SDND(I).SDDLIN = this.SDN.SDND(I).EDISDDLIN #voir si conversion ou pas

    #Searching ITMREF code from EAN EDIITMREF
    If WSTATUS = [V]CST_AOK
      Local File ITMMASTER [ITM]
      Filter [ITM] Where EANCOD = this.SDN.SDND(I).EDIITMREF
      Read First
      If fstat = [V]CST_AOK
        this.SDN.SDND(I).ITMREF = [F:ITM]ITMREF
      Else
        WSTATUS = [V]CST_AERROR
        WERR = mess(196,2006,1) #Cannot find the item code
        Break
      Endif
      LogicClose File [ITM]
    Endif

    #transcoding the SAU unit from table 228
    If WSTATUS = [V]CST_AOK
      Local Char WSAU(3)
      WSAU = func TRTFUNEDI.TRANSCODE(this.SDN.SDND(I).EDIRCPSAU, 228, WCATACT)
      If WSAU = ""
        WSTATUS = [V]CST_AERROR
        WERR = mess(197,2006,1) #Cannot find the unit
        Break
      Else
        this.SDN.SDND(I).RCPSAU = WSAU
      Endif
    Endif

  Next I

Return

$EDICOM_RECEIPT_OPE_DELETE # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
  Gosub EDICOM_RECEIPT_GET_X3_KEYS

  #Searching X3 reference to delete
  Local Integer WFOUND : WFOUND = [V]CST_AFALSE
  Local Char WSDNNUM(255)
  Local File SDELIVERYNO [SDN]
  Filter [SDN] Where [SDN]SDNNUMREF = this.SDN.SDNNUMREF
&       and [SDN]BPCORD = this.SDN.BPCORD
&       and [SDN]BPAADD = this.SDN.BPAADD
&       and [SDN]FCY    = this.SDN.FCY
  For [SDN]
    WFOUND = [V]CST_ATRUE
    WSDNNUM = [SDN]SDNNUM
    Break
  Next
  If WFOUND <> [V]CST_ATRUE
    WSTATUS = [V]CST_AERROR
    WERR = "Cannot find the key value" #mess(127,2006,1) #Cannot find the BP or ADDRESS code RBA DELETE
  Else
    WOK = fmet this.AREAD(WSDNNUM)
    WSTATUS = WOK
  Endif
Return

$EDICOM_RECEIPT_OPE_UPDATE
  WSTATUS = [V]CST_AERROR
Return


$EDICOM_RECEIPT_GET_X3_KEYS
  #1-Searching customer´s EDI code
  Local File EDIBPRPAR [EBP]
  Local Integer WFND
  If WSTATUS = [V]CST_AOK
    WFND=0
    Filter [EBP] Where PARCOD = WPARCOD and EDIORDCOD = this.IDBUYER
    Read [EBP]First
    If fstat <> [V]CST_AOK
      Filter [EBP] Where PARCOD = WPARCOD and EXCEDICOD = this.IDBUYER
      Read [EBP] First
      If fstat = [V]CST_AOK: WFND=1: Endif
    Else : WFND=1
    Endif
    If WFND=1
      this.SDN.BPCORD = [F:EBP]BPANUM
#      this.SDN.BPAORD = [F:EBP]BPAADD
      this.SDN.BPAADD = [F:EBP]BPAADD
    Else
      WSTATUS = [V]CST_AERROR
      WERR = mess(127,2006,1) #Cannot find the BP or ADDRESS code
    Endif
  Endif

  Filter [EBP]

  If WSTATUS = [V]CST_AOK
    WFND=0
    Filter [EBP] Where PARCOD = WPARCOD and EDISDHCOD = this.EDISDHCOD
    Read [EBP]First
    If fstat <> [V]CST_AOK
      Filter [EBP] Where PARCOD = WPARCOD and EXCEDICOD= this.EDISDHCOD
      Read [EBP] First
      If fstat = [V]CST_AOK: WFND=1: Endif
    Else : WFND=1
    Endif

    If WFND=1
      this.SDN.BPAADD = [F:EBP]BPAADD
    Else
      WSTATUS = [V]CST_AERROR
      WERR = mess(127,2006,1) #Cannot find the BP or ADDRESS code
    Endif
  Endif
  LogicClose File [EBP]


  #2- Filling Company and site
  If WSTATUS = [V]CST_AOK
    this.SDN.FCY = func TRTFUNEDI.ORD_EDICODE_SE(this.EDICPYCOD,WPARCOD,this.SDN.BPCORD,1)
    this.SDN.CPY = func TRTFUNEDI.ORD_EDICODE_SE(this.EDICPYCOD,WPARCOD,this.SDN.BPCORD,2)

    Local File FACILITY [FCY]
    Read [FCY]FCY0=this.SDN.FCY
    If fstat=[V]CST_AOK
      If [F:FCY]LEGCPY<> this.SDN.CPY
         WERR=mess(125,2006,1)   #Site does not belong to the company
         WSTATUS = [V]CST_AERROR
       Endif
    Endif
    LogicClose File [FCY]
  Endif

  If WSTATUS = [V]CST_AOK
    If this.SDN.CPY=""
      WSTATUS = [V]CST_AERROR
      WERR = mess(126,2006,1) #Cannot find the site code
    Endif
  Endif


#  #1- Searching site form EDICOM code (EXCEDICOD)
#  If WSTATUS = [V]CST_AOK
#    Local File EDIFCYPAR [EFP]
#    Filter [EFP] Where PARCOD = WPARCOD and EXCEDICOD = this.IDSELLER
#    Read First
#    If fstat=[V]CST_AOK
#      this.SDN.FCY = [F:EFP]FCY
#    Else
#      WSTATUS = [V]CST_AERROR
#      WERR = mess(126,2006,1)   #Cannot find the site code
#    Endif
#    LogicClose File [EFP]
#  Endif

#  #2- Searching customer´s EDI code
#  If WSTATUS = [V]CST_AOK
#    Local File EDIBPRPAR [EBP]
#    Filter [EBP] Where PARCOD = WPARCOD and EXCEDICOD = this.IDBUYER
#    Read First
#    If fstat = [V]CST_AOK
#      this.SDN.BPCORD = [F:EBP]BPANUM
#      this.SDN.BPAADD = [F:EBP]BPAADD
#    Else
#      WSTATUS = [V]CST_AERROR
#      WERR = mess(127,2006,1) #Cannot find the BP or ADDRESS code
#    Endif
#    LogicClose File [EBP]
#  Endif
Return


Funprog TEST_FUNCOD(WCATOPE, WEDIDOCFUN, WERR)
Value Integer WCATOPE
Value Integer WEDIDOCFUN
Variable Char WERR

  Local Integer WFUNSTA : WFUNSTA = [V]CST_AERROR
  Local Integer WFUNCOD : WFUNCOD = WEDIDOCFUN #val(WEDIDOCFUN)

  Case WCATOPE
    When 1 : # Read -> error
      WFUNSTA = [V]CST_AERROR
    When 2 : # Create -> is by default
      Case WFUNCOD
        When 3  :      WFUNSTA = [V]CST_AERROR #3  = CANCELACION
        When 5  :      WFUNSTA = [V]CST_AERROR #5  = REEMPLAZAR
        When 6  :      WFUNSTA = [V]CST_AERROR #6  = CONFIRMACIÓN
        When 7  :      WFUNSTA = [V]CST_AERROR #7  = DUPLICADO
        When 9  :      WFUNSTA = [V]CST_AOK    #9  = ORIGINAL (POR DEFECTO)
        When 31 :      WFUNSTA = [V]CST_AERROR #31 = COPIA
        When 16 :      WFUNSTA = [V]CST_AERROR #16 = PROPUESTA (CRP). SE UTILIZA CONJUNTAMENTE CON NODO=22E
        When 46 :      WFUNSTA = [V]CST_AERROR #46 = PROVISIONAL
        When Default : WFUNSTA = [V]CST_AERROR
      Endcase
    When 3 : # Delete
      Case WFUNCOD
        When 3  :      WFUNSTA = [V]CST_AOK    #3  = CANCELACION
        When 5  :      WFUNSTA = [V]CST_AERROR #5  = REEMPLAZAR
        When 6  :      WFUNSTA = [V]CST_AERROR #6  = CONFIRMACIÓN
        When 7  :      WFUNSTA = [V]CST_AERROR #7  = DUPLICADO
        When 9  :      WFUNSTA = [V]CST_AERROR #9  = ORIGINAL (POR DEFECTO)
        When 31 :      WFUNSTA = [V]CST_AERROR #31 = COPIA
        When 16 :      WFUNSTA = [V]CST_AERROR #16 = PROPUESTA (CRP). SE UTILIZA CONJUNTAMENTE CON NODO=22E
        When 46 :      WFUNSTA = [V]CST_AERROR #46 = PROVISIONAL
        When Default : WFUNSTA = [V]CST_AERROR
      Endcase
    When 4 : # Update -> not implemented
      WFUNSTA    = [V]CST_AERROR
    When Default
      WFUNSTA = [V]CST_AERROR
  Endcase

#WEDIDOCFUN
#3  = CANCELACION
#5  = REEMPLAZAR
#6  = CONFIRMACIÓN
#7  = DUPLICADO
#9  = ORIGINAL (POR DEFECTO)
#31 = COPIA
#16 = PROPUESTA (CRP). SE UTILIZA CONJUNTAMENTE CON NODO=22E
#46 = PROVISIONAL

  If WFUNSTA = [V]CST_AERROR
    WERR = mess(206,2006,1) #"Code fonction incompatible"
  Else
    WERR = ""
  Endif
End WFUNSTA

