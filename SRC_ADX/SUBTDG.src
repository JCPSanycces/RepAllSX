#<AdxTL>@(#)8.0.0.0 $Revision$
Subprog AS_ALLCPY(VALEUR)
Variable Integer VALEUR
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
    mkstat = 1 : End
Endif
End

Subprog AS_CPY(VALEUR)
Variable Char VALEUR
Call AS_CPY(VALEUR) From CPTTRT
End

########################################
Subprog AS_NBLIG
If [M]ALLCPY = 2
 Effzo CPY,ZCPY
 [M]NBLIG=0
 mkstat = 1
 End
Endif
End

########################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]CPY(0..[M]NBLIG-1)) From OBJDIV
If mkstat : End : Endif
If clalev([F:DCP])=0 : Local File DADCPY [DCP] : Endif
Read[DCP]DCP0=VALEUR
If fstat
 GMESSAGE = mess(24,122,1) : # Société non répertoriée DAS2
 mkstat = 2
Endif
End

########################################
Subprog C_SENFCY(VALEUR)
Variable Char    VALEUR()
Read[FCY]FCY0=VALEUR
If !find([F:FCY]LEGCPY,[M]CPY(0..[M]NBLIG-1)) & [M]ALLCPY<>2
 GMESSAGE = mess(30,106,1)-[F:FCY]LEGCPY : # Ce site est dans la société
 mkstat = 2
Endif
End

########################################
Subprog D_YEA(VALEUR)
Variable Decimal VALEUR
VALEUR = year(date$)-1
End

Subprog AM_TDSFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Actzo [M]13
Else
 Grizo [M]13
Endif
End

Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat = 2 : End
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
Local Char NOMIMP(GDIMFIC)
If VALEUR=1
 Raz [M:DIA]VOLFIL
 Grizo [M:DIA]VOLFIL
Else
 [M]VOLFIL = "[TMP]"
 Actzo [M:DIA]VOLFIL
Endif
Affzo [M:DIA]VOLFIL
End

######################################################################################

Subprog D_INI(VALEUR)
Variable Decimal VALEUR
If [M]VOLFIL=""
 Call PARAM("", "DASDIR", [M]VOLFIL) From ADOVAL
 If left$([M]VOLFIL,1)="["
  [M]TYPEXP=2
 Elsif [M]VOLFIL<>""
  [M]TYPEXP=1
  Raz [M]VOLFIL
  Grizo [M]VOLFIL
 Else
  [M]TYPEXP=2
  [M]VOLFIL="[TMP]"
  Actzo [M]VOLFIL
 Endif
Endif
End

Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]FICHIER,E_TYPE_FOLDER,GMESSAGE)
End

Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM()
Value Char VALEUR()
Variable Integer OK
Local Char TMP(250)
Gosub ENUM_VOLFIL_TYPE From ASYRSTO
If func ASYRSTO.CTL_VOLFIL(2,VALEUR,TMP,E_TYPE_FOLDER,GMESSAGE)<>0
 OK = 0 : End
Endif
End
