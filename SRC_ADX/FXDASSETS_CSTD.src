# Classe FXDASSETS

$EVENTS
  Case CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_BEFORE" : Gosub AREAD_BEFORE_FAS
        When "AREAD_AFTER"  : Gosub AREAD_AFTER_FAS
      Endcase
  Endcase
Return

$METHODS
  Case CURPTH
    When ""
      Case [L]AMETHOD
        When Default  : Gosub METHODS From FXDASSETS_C_MPR
      Endcase
  Endcase
Return

$OPERATIONS
  Case CURPTH
    When ""
      Case [L]AOPERATION
        When Default  : Gosub OPERATIONS From FXDASSETS_C_MPR
      Endcase
  Endcase
Return

$AREAD_BEFORE_FAS
  # filter to load only DEPREC from current fiscal year
  Local File CONTEXT  [RCNX]
  Local File FISCYEAR [RFIS]

  this.DEP_FILTER = ""

#  Read [F:FAS]FAS0 = this.AKEYS(1)
#
#  For [RCNX] Where CPY=[F:FAS]CPY
#    Read [RFIS]FIY1=[F:RCNX]CPY;[F:RCNX]CNX;2
#    PERSTRDAT([F:RCNX]CNX) = [F:RFIS]DATSTRPER([F:RFIS]INDCURPER-1)
#
#    If this.DEFILTER <> ""
#      this.DEP_FILTER+="or"
#    Endif
#    this.DEP_FILTER += "(CNX="+num$([F:RCNX]CNX)-" and PERSTDRAT>="-[F:RFIS]DATSTRPER([F:RFIS]INDCURPER-1)-")"
#  Next

  If this.DEP_FILTER = ""
    this.DEP_FILTER = "1=1"
  Endif

  Close File [RCNX]
  Close File [RFIS]
Return

$AREAD_AFTER_FAS
  Local Integer N_I : N_I = 1
  Local Integer LNB : # Line number

  Local Date    FIYSTRDAT(11) : # date de début exercice courant
  Local Date    FIYENDDAT(11) : # date de fin exercice courant
  Local Date    PERSTRDAT(11) : # date de début période courante
  Local Date    PERENDDAT(11) : # date de fin période courante

  Local File CONTEXT  [RCNX]
  Local File FISCYEAR [RFIS]
  Local File DEPREC   [RDEP]

  # Recherche des périodes courantes pour les contextes
  For [RCNX] Where CPY=this.CPY
    Read [RFIS]FIY1=[F:RCNX]CPY;[F:RCNX]CNX;2
    FIYSTRDAT([F:RCNX]CNX) = [F:RFIS]DATSTRFIY
    FIYENDDAT([F:RCNX]CNX) = [F:RFIS]DATENDFIY
    PERSTRDAT([F:RCNX]CNX) = [F:RFIS]DATSTRPER([F:RFIS]INDCURPER-1)
    PERENDDAT([F:RCNX]CNX) = [F:RFIS]DATENDPER([F:RFIS]INDCURPER-1)
  Next

  # Plus ou moins values : initialisation du nom du plan et chargement de la valeur nette au jour de sortie
  If this.ISSDAT <> [0/0/0]
    LNB = 1
    For [RCNX] Where CPY=this.CPY
      For N_I = 0 To [F:RCNX]NBPLC-1
        this.CGAL(LNB) = NewInstance  =this.AllocGrp, C_FXDASSETS_CGAL(this.ACTX,NullUuid,[L]LNB,this,"CGAL")
        this.CGAL(LNB).GALDPRPLN = [F:RCNX]PLNCAA(N_I)
        Gosub LOAD_GAL
        LNB += 1
      Next
    Next
  Endif
####################################################################
#Goto APRES_CBO
#  If this.ISSDAT = [0/0/0]
#    LNB = 0
#  Else
#    LNB = 1
#  Endif
#  # Recherche des périodes courantes pour les contextes
#  For [RCNX] Where CPY=this.CPY
#    Read [RFIS]FIY1=[F:RCNX]CPY;[F:RCNX]CNX;2
#    FIYSTRDAT([F:RCNX]CNX) = [F:RFIS]DATSTRFIY
#    FIYENDDAT([F:RCNX]CNX) = [F:RFIS]DATENDFIY
#    PERSTRDAT([F:RCNX]CNX) = [F:RFIS]DATSTRPER([F:RFIS]INDCURPER-1)
#    PERENDDAT([F:RCNX]CNX) = [F:RFIS]DATENDPER([F:RFIS]INDCURPER-1)
#    If this.ISSDAT <> [0/0/0]
#      For N_I = 0 To [F:RCNX]NBPLC-1
#        this.CGAL(LNB) = NewInstance  =this.AllocGrp, C_FXDASSETS_CGAL(this.ACTX,NullUuid,[L]LNB,this,"CGAL")
#        this.CGAL(LNB).GALDPRPLN = [F:RCNX]PLNCAA(N_I)
#        Gosub LOAD_GAL
