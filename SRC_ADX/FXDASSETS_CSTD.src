#      Next
#    Endif
#  Next
#
#$APRES_CBO
####################################################################
  Close File [RCNX]
  Close File [RFIS]
  Close File [RDEP]
Return

$LOAD_GAL
  Local Decimal L_NBV
  Local Integer L_CNX : L_CNX = [F:RCNX]CNX
  Local Char L_REQUETE(250)
  Local Date DD1, DD2
  L_NBV    = 0.

  If (this.ISSDAT < PERSTRDAT(L_CNX)) Then
    # Sortie antérieure à la période courante
    If ( this.ISSDAT >= FIYSTRDAT(L_CNX) ) Then
      # Dans l'exercice courant, on lit le DEPREC courant
      DD1 = FIYSTRDAT(L_CNX)
      DD2 = PERSTRDAT(L_CNX)
      L_REQUETE  = "CPY=this.CPY and AASREF=this.AASREF and DPRPLN=this.CGAL(LNB).GALDPRPLN and "
      L_REQUETE += "FIYENDDAT=DD1 and PERENDDAT=DD2"
      Filter [F:RDEP] Where evalue(L_REQUETE)
      Read [F:RDEP] Last
      If (!fstat) Then :  L_NBV    = [F:RDEP]NBV  :  Endif
    Endif
    If ( this.ISSDAT < FIYSTRDAT(L_CNX) ) Then
      # Dans un exercice antérieur, on lit le dernier DEPREC de l'exercice de sortie
      L_REQUETE  = "CPY=this.CPY and AASREF=this.AASREF and DPRPLN=this.CGAL(LNB).GALDPRPLN and "
      L_REQUETE += "FIYSTRDAT<=this.ISSDAT and FIYENDDAT>=this.ISSDAT"
      Filter [F:RDEP] Where evalue(L_REQUETE)
      Read [F:RDEP] Last
      If (!fstat) Then :  L_NBV    = [F:RDEP]NBV  :  Endif
    Endif
  #-2 --------------
  Elsif (this.ISSDAT >= PERSTRDAT(L_CNX) and this.ISSDAT <= PERENDDAT(L_CNX)) Then
    # Sortie dans la pér. courante, on prend le DEPREC courant
    DD1 = FIYENDDAT(L_CNX)
    DD2 = PERENDDAT(L_CNX)
    L_REQUETE  = "CPY=this.CPY and AASREF=this.AASREF and DPRPLN=this.CGAL(LNB).GALDPRPLN and "
    L_REQUETE += "FIYENDDAT=DD1 and PERENDDAT=DD2"

    Filter [F:RDEP] Where evalue(L_REQUETE)
    Read [F:RDEP] Last
    If (!fstat) Then   :    L_NBV   = [F:RDEP]NBV  :  Endif
  #-2 --------------
  Elsif (this.ISSDAT >= PERENDDAT(L_CNX)) Then
    # Sortie dans une pér. postérieure à la pér. courante, on lit le DEPREC contenant la date de sortie.
    L_REQUETE  = "CPY=this.CPY and AASREF=this.AASREF and DPRPLN=this.CGAL(LNB).GALDPRPLN and "
    L_REQUETE += "((PERSTRDAT=[0/0/0] and FIYSTRDAT<=this.ISSDAT and FIYENDDAT>=this.ISSDAT) or "
    L_REQUETE += " (PERSTRDAT<>[0/0/0] and PERSTRDAT<=this.ISSDAT and PERENDDAT>=this.ISSDAT))"
    Filter [F:RDEP] Where evalue(L_REQUETE)
    Read [F:RDEP] Last
    If (!fstat) Then   :    L_NBV   = [F:RDEP]NBV  :  Endif
  Endif

  this.CGAL(LNB).NBV = L_NBV
Return

#############
# PROPERTIES
#############
$PROPERTIES
  Case CURPRO
    When "CPY"    : Gosub CPY
  Endcase
Return

$CPY
  Case ACTION
    When "SET"    : Gosub CPY_SET
  Endcase
Return

$CPY_SET
  this.DEP_FILTER = "1=1"
Return

