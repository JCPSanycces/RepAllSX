  Local Integer I
  Local Integer WPOS
  Local Integer WOK

  Call DELETELINES(this, "EXFD") From EDILIBA
  For I = 1 To maxtab(WTAB_ALIAS)
    WPOS = fmet this.ADDLINE('EXFD', [V]CST_ALASTPOS)
    this.EXFD(WPOS).ALIAS        = WTAB_ALIAS(I)
    this.EXFD(WPOS).PATHID       = val(WTAB_PATHID(I))
    this.EXFD(WPOS).CONDITIONSTR = WTAB_CONDITIONSTR(I)
  Next I
  WOK = fmet this.AUPDATE()
  If WOK = [V]CST_AOK
    ASTATUS = fmet this.ASETERROR("",mess(102,130,1) ,[V]CST_AOK)   # Update performed ## 112148
  Else
    ASTATUS = fmet this.ASETERROR("",mess(50,176,1),[V]CST_AERROR)  # Error during update ## 112148
  Endif

  ARET_VALUE = [V]CST_AOK
Return

