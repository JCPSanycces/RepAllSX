#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Data Class EDIXMLFIL                                                        #
# Manages main class EDIXMLFIL (this)                                         #
# Author : RBA                                                                #
###############################################################################

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case CURPTH
    When ""
      Case [L]AEVENT
        When "AINSERT_CONTROL_AFTER"  : Gosub AINSERT_CONTROL_AFTER
        When "AUPDATE_CONTROL_AFTER"  : Gosub AUPDATE_CONTROL_AFTER
        When "ADELETE_CONTROL_AFTER"  : Gosub ADELETE_CONTROL_AFTER
      Endcase
    When "EXFF"
      Case [L]AEVENT
        When "ADELLINE_BEFORE"        : Gosub EXFF_ADELLINE_BEFORE
        When "ADELLINE_AFTER"         : Gosub EXFF_ADELLINE_AFTER
        When "ADDLINE_BEFORE"         : Gosub EXFF_ADDLINE_BEFORE
        When "ADDLINE_AFTER"          : Gosub EXFF_ADDLINE_AFTER
      Endcase
    When "EXFN"
      Case [L]AEVENT
        When "ADDLINE_BEFORE"         : Gosub EXFN_ADDLINE_BEFORE
      Endcase
    When "EXFD"
      Case [L]AEVENT
        When "AREAD_AFTER"            : Gosub EXFD_AREAD_AFTER
        When "ADELLINE_AFTER"         : Gosub EXFD_ADELLINE_AFTER
        When "ADDLINE_BEFORE"         : Gosub EXFD_ADDLINE_BEFORE
        When "ADDLINE_AFTER"          : Gosub EXFD_ADDLINE_AFTER
      Endcase
    When "EXSD"
      Case [L]AEVENT
        When "AREAD_AFTER"            : Gosub EXSD_AREAD_AFTER
        When "ADELLINE_AFTER"         : Gosub EXSD_ADELLINE_AFTER
        When "ADDLINE_BEFORE"         : Gosub EXSD_ADDLINE_BEFORE
        When "ADDLINE_AFTER"          : Gosub EXSD_ADDLINE_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_POST_JSON"           : Gosub MET_POST_JSON
    When "MET_PUT_JSON"            : Gosub MET_PUT_JSON
    When "MET_DEL_JSON"            : Gosub MET_DEL_JSON
    When "MET_DEL_JSON_TYP"        : Gosub MET_DEL_JSON_TYP  #X3-67156 - Delete EDI XMLfile and XSD
    When "MET_DEL_JSON_FILE"       : Gosub MET_DEL_JSON_FILE #X3-67156 - Delete EDI XMLfile and XSD
    When "MET_VALIDATE"            : Gosub MET_VALIDATE
    When "MET_PARSE_XSD"           : Gosub MET_PARSE_XSD
    When "MET_LOAD_PATH_XML"       : Gosub MET_LOAD_PATH_XML
    When "MET_GET_PATH"            : Gosub MET_GET_PATH #generate method
    When "MET_VALIDATE_MAPPING_XML": Gosub MET_VALIDATE_MAPPING_XML
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
##    When "xxx"           : Gosub xxx
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "MSGCOD" :
      Case [L]ARULE
        When "CONTROL"     : Gosub MSGCOD_CONTROL
        When "PROPAGATE"   : Gosub MSGCOD_PROPAGATE
      Endcase
    When "MSGREL" :
      Case [L]ARULE
        When "CONTROL"     : Gosub MSGREL_CONTROL
        When "PROPAGATE"   : Gosub MSGREL_PROPAGATE
      Endcase
    When "MSGFILNOR" :
      Case [L]ARULE
        When "PROPAGATE"   : Gosub MSGFILNOR_PROPAGATE
      Endcase
    When "MSGFOR" :
      Case [L]ARULE
        When 'INIT'        : Gosub MSGFOR_INIT
        When 'CONTROL'     : Gosub MSGFOR_CONTROL
        When 'PROPAGATE'   : Gosub MSGFOR_PROPAGATE
      Endcase
    When "TYPFIL" :        ## INI 112148
      Case [L]ARULE
        When 'INIT'        : Gosub TYPFIL_INIT
        When 'CONTROL'     : Gosub TYPFIL_CONTROL
      Endcase              ## END 112148
    When "CACHEUUID" :
      Case [L]ARULE
        When "INIT"        : Gosub CACHEUUID_INIT
      Endcase
    When "FLGMUX" :
      Case [L]ARULE
        When "INIT"        : Gosub FLGMUX_INIT
      Endcase
    When "REPCOD" :
      Case [L]ARULE
        When "PROPAGATE"   : Gosub REPCOD_PROPAGATE
      Endcase
    When "KEYALIAS" :
      Case [L]ARULE
        When "CONTROL"     : Gosub KEYALIAS_CONTROL              ## INI 112148     Not used in XML files
        When "PROPAGATE"   : Gosub KEYALIAS_PROPAGATE            ## INI 112148     Not used in XML files
      Endcase
    When "KEYPROPERTY" :
      Case [L]ARULE
        When "CONTROL"     : Gosub KEYPROPERTY_CONTROL           ## INI 112148     Not used in XML files
        When "PROPAGATE"   : Gosub KEYPROPERTY_PROPAGATE         ## INI 112148     Not used in XML files
      Endcase
    When "EXFF.MANDATORY" :
      Case [L]ARULE
        When "INIT"      : Gosub EXFF_MANDATORY_INIT
        When "CONTROL"   : Gosub EXFF_MANDATORY_CONTROL
      Endcase
    When "EXFF.FILNAM"  :
      Case [L]ARULE
        When "CONTROL"   : Gosub EXFF_FILNAM_CONTROL
      Endcase
    When "EXFN.COMTYP" :
      Case [L]ARULE
        When "CONTROL"   : Gosub EXFN_COMTYP_CONTROL
        When "PROPAGATE" : Gosub EXFN_COMTYP_PROPAGATE
      Endcase
    When "EXFN.COMVAL" :
      Case [L]ARULE
        When "CONTROL"     : Gosub EXFN_COMVAL_CONTROL
        When "PROPAGATE"   : Gosub EXFN_COMVAL_PROPAGATE
      Endcase
    When "EXFD.ALIAS" :
      Case [L]ARULE
         When "CONTROL"    : Gosub EXFD_ALIAS_CONTROL
         When "PROPAGATE"  : Gosub EXFD_ALIAS_PROPAGATE
      Endcase
    When "EXFD.EXPRESSION" :
      Case [L]ARULE
        When "CONTROL"     : Gosub EXFD_EXPRESSION_CONTROL
        When "PROPAGATE"   : Gosub EXFD_EXPRESSION_PROPAGATE
      Endcase
    When "EXFD.CONDITIONSTR" :
      Case [L]ARULE
        When "CONTROL"     : Gosub EXFD_CONDITIONSTR_CONTROL
        When "PROPAGATE"   : Gosub EXFD_CONDITIONSTR_PROPAGATE
      Endcase
    When "EXFD.PATHID" :
      Case [L]ARULE
         When "PROPAGATE"  : Gosub EXFD_PATHID_PROPAGATE
      Endcase
    When "EXSD.CODE" :
      Case [L]ARULE
        When "CONTROL"     : Gosub EXSD_CODE_CONTROL
        When "PROPAGATE"   : Gosub EXSD_CODE_PROPAGATE
      Endcase
  Endcase
Return


####################################################################

$MSGCOD_CONTROL
  If this.MSGCOD <> ""
    this.MSGCOD = func EDILIBA.FORMATVAL("MSGCOD", this.MSGCOD)
  Endif
Return

####################################################################

$MSGCOD_PROPAGATE
  Local Integer WOK, I
  Local Char WERR(250)
  WERR = ""

  this.MSGFILNOR = ""
  this.MSGREL = ""

  If this.MSGCOD = ""
    Call DELETELINES(this, "EXFD") From EDILIBA
  Else
    #rechercher le sens dans la table
    Local File EDIMSG [EMS]
    Filter [EMS] Where MSGCOD = this.MSGCOD Order By Key EMS0 Asc #attention la clé est en caractere et non en chiffre donc le tri n'est pas correct
    Read [EMS]EMS0 First
    If fstat = [V]CST_AOK
      this.MSGREL = [F:EMS]MSGREL
      this.MSGDIR = [F:EMS]MSGDIR
      this.FILDES = [F:EMS]MSGDES
      this.REPCOD = [F:EMS]REPCOD
      this.ABRCLA = [F:EMS]ABRCLA
    Else
      this.MSGREL = ""
      this.MSGDIR = 1
      this.FILDES = ""
      this.REPCOD = ""
      this.ABRCLA = ""
      WERR = mess(126,143,1)
      ASTATUS = fmet this.ASETERROR("MSGCOD",WERR,[V]CST_AERROR)
    Endif
    LogicClose File [EMS]
  Endif

  this.VALID = [V]CST_ANO
Return

####################################################################

$MSGREL_CONTROL
  If this.MSGREL <> ""
    this.MSGREL = func EDILIBA.FORMATVAL("MSGREL", this.MSGREL)
  Endif
Return

####################################################################

$MSGREL_PROPAGATE
  Local Integer WOK
  Local Char WERR(250) : WERR = ""

  this.MSGFILNOR = ""

  If this.MSGREL = ""
    Call DELETELINES(this, "EXFD") From EDILIBA
  Else
    If this.MSGCOD <> "" and this.MSGREL <> ""
      Local File EDIMSG [EMS]
      Read [EMS]EMS0 = this.MSGCOD;this.MSGREL
      If !fstat
        this.MSGDIR = [EMS]MSGDIR
        this.FILDES = [EMS]MSGDES
        this.REPCOD = [EMS]REPCOD
      Else
        this.REPCOD = ""
        WERR = mess(126,143,1)
        ASTATUS = fmet this.ASETERROR("MSGREL",WERR,[V]CST_AERROR)
      Endif
      LogicClose File [EMS]

    Endif
  Endif
  this.VALID = [V]CST_ANO
Return

####################################################################

$MSGFILNOR_PROPAGATE
  If this.MSGREL = ""
    Call DELETELINES(this, "EXFD") From EDILIBA
  Else
    If this.MSGCOD <> "" and this.MSGREL <> "" and this.MSGFILNOR <> ""
      Local File EDIXMLFIL [EXF]
      Read [EXF]EXF0 = this.MSGCOD; this.MSGREL; this.MSGFILNOR
      If !fstat
        ASTATUS = fmet this.ASETERROR("MSGREL",mess(45,7779,1)-":"-this.MSGCOD+"~"+this.MSGREL,[V]CST_AERROR)
      Else
        #
      Endif
      LogicClose File [EXF]
    Endif
  Endif
  this.VALID = [V]CST_ANO
Return

####################################################################

$MSGFOR_INIT
  this.MSGFOR = 2
Return

####################################################################

$MSGFOR_CONTROL
  If this.MSGFOR <> 2
    this.MSGFOR = 2
  Endif
Return

####################################################################

#112148
$TYPFIL_INIT
  this.TYPFIL = 5
Return

####################################################################

#112148
$TYPFIL_CONTROL
  If this.TYPFIL <> 5
    this.TYPFIL = 5
  Endif
Return

####################################################################

$MSGFOR_PROPAGATE
  this.VALID = [V]CST_ANO
Return

####################################################################

$CACHEUUID_INIT
  this.CACHEUUID = NullUuid()
Return

####################################################################

$FLGMUX_INIT
  this.FLGMUX = [V]CST_AYES
Return

####################################################################

$REPCOD_PROPAGATE
Return

####################################################################

$KEYALIAS_CONTROL
  this.KEYALIAS=toupper(this.KEYALIAS)
  If this.MSGDIR = 2 #receipt
    #verifier que l'alias est présent dans le detail EXFD
    Local Integer I
    Local Integer WOK : WOK = [V]CST_AFALSE
    If this.KEYALIAS <> ""
      For I = 1 To maxtab(this.EXFD)
        If this.EXFD(I) <> null and this.EXFD(I).ASTALIN <> [V]CST_ADEL and this.EXFD(I).ASTALIN <> [V]CST_ANEWDEL
          If this.EXFD(I).ALIAS = this.KEYALIAS
            WOK = [V]CST_ATRUE
            Break
          Endif
        Endif
      Next
      If WOK = [V]CST_AFALSE
        ASTATUS = fmet this.ASETERROR("KEYALIAS",mess(00126,00143,1),[V]CST_AERROR)
      Endif
    Else
      ASTATUS = fmet this.ASETERROR("KEYALIAS",mess(00532,00177,1),[V]CST_AWARNING)
    Endif
  Else
    this.KEYALIAS = ""
  Endif
Return

####################################################################

$KEYALIAS_PROPAGATE
  Local Char WTXT(120)
  Local Char WLAN(3)

  If this.KEYALIAS <> ""
    If this.REPCOD <> ""
      Local File ASHWEXPPRO [ASWR]
      Read [ASWR]ASWR0 = this.REPCOD;this.KEYALIAS
      If !fstat
        this.KEYPROPERTY = [ASWR]CODPRO
        WLAN = this.ACTX.LAN
#        WLAN="ENG"
        ##Always propose the english text
        Call TEXTELAN([ASWR]INTPRO,WTXT,WLAN) From OBJDIV
        this.KEYDES = WTXT
        this.KEYPROTOPATH = func EDILIBC.GET_PROTOPATH(this.KEYALIAS, this.KEYPROPERTY, this.REPCOD)
      Else
        this.KEYPROPERTY = ""
        this.KEYDES = ""
        this.KEYPROTOPATH = ""
        ASTATUS = fmet this.ASETERROR("KEYALIAS",mess(00126,00143,1) ,[V]CST_AERROR)
      Endif
      LogicClose File [ASWR]
    Else
      this.KEYPROPERTY = ""
      this.KEYDES = ""
      this.KEYPROTOPATH = ""
    Endif
  Else
    this.KEYPROPERTY = ""
    this.KEYDES = ""
    this.KEYPROTOPATH = ""
  Endif

  this.VALID = [V]CST_ANO
Return

####################################################################

$KEYPROPERTY_CONTROL
  Local Integer WOK
  Local Char WERR(250)
  Local File ASHWEXPPRO
  this.KEYPROPERTY=toupper(this.KEYPROPERTY)
  If this.KEYPROPERTY<>""
    Read [ASWR]ASWR3=this.REPCOD;this.KEYPROPERTY
    If fstat<>[V]CST_AOK
      WERR = mess(00126,00143,1) # invalid value
      ASTATUS = fmet this.ASETERROR("KEYPROPERTY",WERR,[V]CST_AERROR)
    Endif
  Endif
Return

####################################################################

$KEYPROPERTY_PROPAGATE
  this.VALID = [V]CST_ANO
Return

####################################################################

$EXFF_MANDATORY_INIT
  If this.AORDER = 1 #1ST LINE
    this.MANDATORY = [V]CST_AYES
  Endif
Return

####################################################################

$EXFF_MANDATORY_CONTROL
  Local Char WERR(100)
  If this.APARENT.MSGDIR=2
    If this.MANDATORY = [V]CST_ANO and this.AORDER = 1 #1ST LINE
      WERR=mess(53,2006,1) # First line mandatory
      ASTATUS = fmet this.ASETERROR("MANDATORY",WERR,[V]CST_AERROR)
    Endif
  Endif
Return

####################################################################

$EXFF_FILNAM_CONTROL
  Local Char WERR(100)
  Local Integer I
  Local Char WCHAR(1)(1..13)
  WCHAR(1) ="/"  :  WCHAR(2) ="\"  : WCHAR(3) ="*"
  WCHAR(4) =":"  :  WCHAR(5) ="?"  : WCHAR(6) ="¿"
  WCHAR(7) ="<"  :  WCHAR(8) =">"  : WCHAR(9) ='"'
  WCHAR(10)="|"  :  WCHAR(11)=" "  : WCHAR(12)="¡"
  WCHAR(13)="!"
  Local Shortint I
  For I = 1 To maxtab(WCHAR())
    If instr(1,this.FILNAM,WCHAR(I)) <> 0
      WERR = func AFNC.MES1(mess(14,2006,1), WCHAR(I))
      ASTATUS = fmet this.ASETERROR("FILNAM",WERR,[V]CST_AERROR)
      Break
    Endif
  Next

  If WERR = ""
    For I  =1 To maxtab(this.APARENT.EXFF)
      If this.APARENT.EXFF(I) <> null
&     and this.APARENT.EXFF(I).ASTALIN <> [V]CST_ADEL
&     and this.APARENT.EXFF(I).ASTALIN <> [V]CST_ANEWDEL
&     and this.APARENT.EXFF(I).AORDER <> this.AORDER
&     and this.APARENT.EXFF(I).FILNAM = this.FILNAM
        WERR=mess(00033,00137,1)  # Code already exists
        ASTATUS = fmet this.ASETERROR("FILNAM",WERR,[V]CST_AERROR)
        Break
      Endif
    Next
  Endif
Return

####################################################################

$EXFN_COMTYP_CONTROL
  Local Shortint I, J
  Local Char WERR(100) : WERR = ""

  #test 1
  If this.APARENT.MSGDIR=1 #issue
    If this.COMTYP <> 6 #constant
      For I=1 To maxtab(this.APARENT.EXFN)
        If this.APARENT.EXFN(I)<>null
&       and !find(this.APARENT.EXFN(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)
&       and this.APARENT.EXFN(I).COMTYP = this.COMTYP
&       and this.APARENT.EXFN(I).AORDER <> this.AORDER
          #err
          WERR = mess(91,2006,1) #"This component can only be assigned once"
          Break
        Endif
      Next
    Endif
  Endif

#  #test 2
  If this.APARENT.MSGDIR=1 #issue
    If this.COMTYP = 2 or this.COMTYP = 3 #main key or merge key
      For I=1 To maxtab(this.APARENT.EXFN)
        If this.APARENT.EXFN(I)<>null and !find(this.APARENT.EXFN(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)
          If this.COMTYP = 2 and this.APARENT.EXFN(I).COMTYP = 3 and this.AORDER <> this.APARENT.EXFN(I).AORDER
            WERR = mess(52,2006,1) #"Main key and merge key cannot be associated both"
            #err
            Break
          Elsif this.COMTYP = 3 and this.APARENT.EXFN(I).COMTYP = 2 and this.AORDER <> this.APARENT.EXFN(I).AORDER
            WERR = mess(52,2006,1) #"Main key and merge key cannot be associated both"
            #err
            Break
          Endif
        Endif
      Next
    Endif
  Endif

  If WERR <> ""
    ASTATUS = fmet this.ASETERROR("COMTYP",WERR,[V]CST_AERROR)
  Endif
Return

####################################################################

$EXFN_COMTYP_PROPAGATE
  Case this.COMTYP
    When 4       : this.COMVAL="1": this.FORMAT=mess(1,2015,1)
    When 5       : this.COMVAL="1": this.FORMAT=mess(1,2016,1)
    When Default : this.COMVAL="" : this.FORMAT=""
  Endcase
  this.APARENT.VALID = [V]CST_ANO
Return

####################################################################

$EXFN_COMVAL_CONTROL
  If this.COMVAL <> ""
    Local Char WERR(250) : WERR = ""

    Case this.COMTYP
      When 1, 2:
            WERR = mess(126,143,1) #WERR = "Value cannot be set"
      When 3:
            Local File ASHWEXPPRO [ASWR]
            Read [ASWR]ASWR0 = this.APARENT.REPCOD;this.COMVAL
            If fstat <> [V]CST_AOK
              WERR = mess(126,143,1)- mess(61,2006,1) # invalid value. Must be a property presents in the representation.
            Endif
            LogicClose File [ASWR]
      When 4:
            this.COMVAL=toupper(this.COMVAL)
            If func EDILIBA.STR_ISNUM(this.COMVAL) = [V]CST_ATRUE
              If val(this.COMVAL) > 12 or val(this.COMVAL)<1
                WERR = mess(35,2006,1) #WERR = "Invalid format"
              Endif
            Else
              WERR = mess(35,2006,1) #WERR = "Invalid format"  #only numbers are allowed
            Endif
      When 5:
            this.COMVAL=tolower(this.COMVAL)
            If func EDILIBA.STR_ISNUM(this.COMVAL) = [V]CST_ATRUE
              If val(this.COMVAL) > 4 or val(this.COMVAL)<1
                WERR = mess(35,2006,1) #WERR = "Invalid format"
              Endif
            Else
              WERR = mess(35,2006,1) #WERR = "Invalid format"  #only numbers are allowed
            Endif
      When 6, 8:
            Local Char WCHAR(1)(1..13)
            WCHAR(1) ="/"  :  WCHAR(2) ="\"  : WCHAR(3) ="*"
            WCHAR(4) =":"  :  WCHAR(5) ="?"  : WCHAR(6) ="¿"
            WCHAR(7) ="<"  :  WCHAR(8) =">"  : WCHAR(9) ='"'
            WCHAR(10)="|"  :  WCHAR(11)=" "  : WCHAR(12)="¡"
            WCHAR(13)="!"
            Local Shortint I
            For I = 1 To maxtab(WCHAR())
              If instr(1,this.COMVAL,WCHAR(I)) <> 0
                WERR = func AFNC.MES1(mess(14,2006,1), WCHAR(I))
                Break
              Endif
            Next
    Endcase

    If WERR <> ""
      ASTATUS = fmet this.ASETERROR("COMVAL",WERR,[V]CST_AERROR)
    Endif
  Endif
Return

####################################################################

$EXFN_COMVAL_PROPAGATE
  If this.COMVAL <> ""
    Case this.COMTYP
      When 3       : Local File ASHWEXPPRO [ASWR]
                     Read [ASWR]ASWR0 = this.APARENT.REPCOD;this.COMVAL
                     If !fstat
                       this.FORMAT = [ASWR]CODPRO
                     Else
                       this.FORMAT = ""
                     Endif
                     LogicClose File [ASWR]
      When 4       : this.FORMAT = mess(val(this.COMVAL),2015,1) #date
      When 5       : this.FORMAT = mess(val(this.COMVAL),2016,1) #time
      When Default : this.FORMAT = ""
    Endcase
  Endif
  this.APARENT.VALID = [V]CST_ANO
Return

####################################################################

$EXFD_ALIAS_CONTROL
  this.ALIAS=toupper(this.ALIAS)
Return

####################################################################

$EXFD_ALIAS_PROPAGATE
  this.REPCOD = this.APARENT.REPCOD

  Local Integer WOK
  WOK = func PROPAGATE_EXFD_ALIAS(this)
  this.APARENT.VALID = [V]CST_ANO
Return

####################################################################

$EXFD_EXPRESSION_CONTROL
  Local Integer WOK
  Local Char WERR(250)
  Local File ASHWEXPPRO
  this.EXPRESSION=toupper(this.EXPRESSION)
  If this.EXPRESSION <> ""
    Read [ASWR]ASWR3 = this.APARENT.REPCOD;this.EXPRESSION
    If fstat
      WERR = mess(00126,00143,1) # invalid value
      ASTATUS = fmet this.ASETERROR("EXPRESSION",WERR,[V]CST_AERROR)
    Endif
  Endif
Return

####################################################################

$EXFD_EXPRESSION_PROPAGATE
  this.APARENT.VALID = [V]CST_ANO
Return

####################################################################

$EXFD_CONDITIONSTR_CONTROL

Return

####################################################################

$EXFD_CONDITIONSTR_PROPAGATE
  Local Integer WOK
  WOK = func PROPAGATE_EXFD_CONDITIONSTR(this)
Return

####################################################################

$EXFD_PATHID_PROPAGATE
  ASTATUS = fmet this.ADELETEERROR("PATHID")
  If this.PATHID <> 0
    Local File EDIXMLFILP [EXFP]
    Read [EXFP]EXFP0 = this.MSGCOD;this.MSGREL;this.MSGFILNOR;this.PATHID
    If !fstat
      this.PATHSTR  = [EXFP]PATHSTR
      this.PATHTYPE = [EXFP]PATHTYPE
      this.PATHREST = [EXFP]PATHREST
    Else
      ASTATUS = fmet this.ASETERROR("PATHID","Error",[V]CST_AERROR)
      this.PATHSTR  = ""
      this.PATHTYPE = ""
      this.PATHREST = ""
    Endif
    LogicClose File [EXFP]
  Else
    this.PATHSTR  = ""
    this.PATHTYPE = ""
    this.PATHREST = ""
  Endif

  this.APARENT.VALID = [V]CST_ANO
Return

####################################################################

$EXSD_CODE_CONTROL
  If this.CODE <> ""
    this.CODE = func EDILIBA.FORMATVAL("CODE", this.CODE)
  Endif
Return

####################################################################

$EXSD_CODE_PROPAGATE
  If this.CODE <> ""
    Local File EDIXSDUPL [EXU]
    Read [EXU]EXU0 = this.CODE
    If !fstat
      this.NAM     = [EXU]NAM
      this.FILNAM  = [EXU]FILNAM
      this.FILDES  = [EXU]FILDES
      this.UUIDXSD = [EXU]UUIDXSD
    Else
      this.NAM     = ""
      this.FILNAM  = ""
      this.FILDES  = ""
      this.UUIDXSD = NullUuid()
    Endif
    LogicClose File [EXU]
  Endif
Return

####################################################################

#********************************************************************
# Method AINSERT_CONTROL_AFTER
#********************************************************************
#
#********************************************************************
$AINSERT_CONTROL_AFTER
  Local Integer WOK
  Local Char WERR(250)

  WOK = fmet this.MET_POST_JSON(WERR)
  If WOK <> [V]CST_AINFO
    ASTATUS = fmet this.ASETERROR("CACHEUUID",WERR, WOK)
  Endif

  WOK = fmet this.MET_VALIDATE()
  If WOK <> [V]CST_ATRUE
    WERR = mess(160,2006,1) #Invalid XML file setup
    ASTATUS = fmet this.ASETERROR("VALID", WERR, [V]CST_AWARNING)
  Endif

Return


#********************************************************************
# Method AUPDATE_CONTROL_AFTER
#********************************************************************
#
#********************************************************************
$AUPDATE_CONTROL_AFTER
  Local Integer WOK
  Local Char WERR(250)

  WOK = fmet this.MET_PUT_JSON(WERR)
  If WOK <> [V]CST_AINFO
    ASTATUS = fmet this.ASETERROR("CACHEUUID",WERR, WOK)
  Endif

  WOK = fmet this.MET_VALIDATE()
  If WOK <> [V]CST_ATRUE
    WERR = mess(160,2006,1) #Invalid XML file setup
    ASTATUS = fmet this.ASETERROR("VALID", WERR, [V]CST_AWARNING)
  Endif
Return

#********************************************************************
# Method ADELETE_CONTROL_AFTER
#********************************************************************
#*
#*!
$ADELETE_CONTROL_AFTER
  Local Integer WOK, WFOUND_FLG : WFOUND_FLG = [V]CST_AFALSE
  Local Char WERR(250)

  Local File EDIFLOD [EFLD]
#  Filter [EFLD] Where [EFLD]MSGCOD = this.MSGCOD and [EFLD]MSGREL = this.MSGREL and [EFLD]MSGFILNOR = this.MSGFILNOR and [EFLD]MSGTYP = this.MSGFILNOR
  Filter [EFLD] Where [EFLD]MSGTYP = 1 and [EFLD]MSGFOR  = 2 and [EFLD]MSGCOD = this.MSGCOD and [EFLD]MSGREL = this.MSGREL and [EFLD]MSGFILNOR = this.MSGFILNOR
  For [EFLD]
    WFOUND_FLG = [V]CST_ATRUE
#    WERR = mess(1,115,1)+"."-mess(147,2006,1)+".("+[EFLD]FLOCOD+"/"+[EFLD]FLOREL+")"
#    WERR = mess(1,115,1)+"."+"Le fichier XML est déjà utilisé"+".("+[EFLD]FLOCOD+"/"+[EFLD]FLOREL+")"
    WERR = mess(1,115,1)+"."-mess(180,2006,1)+".("+[EFLD]FLOCOD+"/"+[EFLD]FLOREL+")"    ## 112148
    ASTATUS = fmet this.ASETERROR("", WERR, [V]CST_AERROR)
    Break
  Next
  LogicClose File [EFLD]

  #X3-67156 - Delete EDI XMLfile and XSD
  If WFOUND_FLG = [V]CST_AFALSE
    WOK = fmet this.MET_DEL_JSON(WERR)
#    ASTATUS = fmet this.ASETERROR("CACHEUUID",WERR, WOK)
    ASTATUS = fmet this.ASETERROR("",WERR, WOK)
    WERR = ""

    WOK = fmet this.MET_DEL_JSON_FILE(WERR)
    ASTATUS = fmet this.ASETERROR("",WERR, WOK)
    WERR = ""

    WOK = fmet this.MET_DEL_JSON_TYP(WERR)
#    ASTATUS = fmet this.ASETERROR("UUIDXMLTYP",WERR, WOK)
    ASTATUS = fmet this.ASETERROR("",WERR, WOK)
    WERR = ""
#  If WFOUND_FLG = [V]CST_AFALSE
#    WOK = fmet this.MET_DEL_JSON(WERR)
#    If WOK <> [V]CST_AOK
#      ASTATUS = fmet this.ASETERROR("CACHEUUID",WERR, WOK)
#    Endif
##    #supprimer FILEUUID
##    WOK = fmet this.MET_FILE_REMOVE()
  #/X3-67156 - Delete EDI XMLfile and XSD
  Endif
Return


#********************************************************************
# Method EXFF_ADELLINE_BEFORE
#********************************************************************
#*
#*!
$EXFF_ADELLINE_BEFORE
  this.VALID = [V]CST_ANO
Return


#********************************************************************
# Method EXFF_ADELLINE_AFTER
#********************************************************************
#*
#*!
$EXFF_ADELLINE_AFTER
  this.APARENT.VALID = [V]CST_ANO
Return


#********************************************************************
# Method EXFF_ADDLINE_BEFORE
#********************************************************************
#*
#*!
$EXFF_ADDLINE_BEFORE
  Local Integer I
  Local Integer WNBLINE : WNBLINE = 0
  For I = 1 To maxtab(this.EXFF)
    If this.EXFF(I)<>null and this.EXFF(I).ASTALIN <> [V]CST_ANEWDEL and this.EXFF(I).ASTALIN <> [V]CST_ADEL
      WNBLINE = WNBLINE + 1
    Endif
  Next
  If WNBLINE >= 1
    #Only one line can be defined
    ASTATUS = fmet this.ASETERROR("",mess(71,2006,1),[V]CST_AERROR)
    Return
  Endif

  Local Char WERR(100)
  If this.MSGCOD = "" or this.MSGREL = "" or this.MSGFILNOR = ""
    WERR = mess(120,2006,1) #Keys must be set
    ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
  Endif

  this.VALID = [V]CST_ANO

Return


#********************************************************************
# Method EXFF_ADDLINE_AFTER
#********************************************************************
#*
#*!
$EXFF_ADDLINE_AFTER
  this.NUMLIN    = 1 + max(this.APARENT.EXFF(1..maxtab(this.APARENT.EXFF)).NUMLIN)

  #search previous and next lines
  Local Integer I, BEF_LINE, AFT_LINE
  BEF_LINE = 0
  AFT_LINE = 0
  For I = 1 To maxtab(this.APARENT.EXFF)
    If this.APARENT.EXFF(I) <> null
      If this.APARENT.EXFF(I).AORDER = this.AORDER - 1
        BEF_LINE=I
      Elsif this.APARENT.EXFF(I).AORDER = this.AORDER + 1
        AFT_LINE=I
      Endif
    Endif
  Next I

  Local Integer BEF_LINE_SORT, AFT_LINE_SORT
  Local Integer MY_STEP : #Step in the sort order between two records
  MY_STEP = 100
  #insert a line in the array in a position <> first line
  If AFT_LINE <> 0
    #Assign the SORT property
    AFT_LINE_SORT = this.APARENT.EXFF(AFT_LINE).SORT
    #check if a next line exist
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EXFF(BEF_LINE).SORT : Else : BEF_LINE_SORT = 0 : Endif
    #if no more place to insert -> insert by dichotomy
    If BEF_LINE_SORT <= AFT_LINE_SORT - 2
      #Assign the SORT property
      this.SORT = int((BEF_LINE_SORT + AFT_LINE_SORT)/2)
    Else
      #if not enough place, we re-assign the SORT property of all the lines after the inserted line
      For I=1 To maxtab(this.APARENT.EXFF)
        If this.APARENT.EXFF(I) <> null
          If this.APARENT.EXFF(I).AORDER >= this.AORDER
            #Assign the SORT property of each line from the current line
            this.APARENT.EXFF(I).SORT = this.APARENT.EXFF(I).AORDER * MY_STEP
          Endif
        Endif
      Next I
    Endif
  #if the line is inserted at the 1st position of the array
  Else #If AFT_LINE = 0
    AFT_LINE_SORT = 0
    #we check if there is a next line
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EXFF(BEF_LINE).SORT : Endif
    #Assign the SORT property
    this.SORT = BEF_LINE_SORT + MY_STEP
  Endif

  this.APARENT.VALID = [V]CST_ANO
Return


#********************************************************************
# Method EXFN_ADDLINE_BEFORE
#********************************************************************
#*
#*!
$EXFN_ADDLINE_BEFORE
  #In receipt, this block is not allowed
  Local Char WERR(100) : WERR = ""
  Local Integer WFOUND_FLG : WFOUND_FLG = [V]CST_AFALSE
  Local Integer I

  If this.MSGDIR = 2
    WERR = mess(70,2006,1)      #Insertion impossible. This block is not allowed in receipt sense
    ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
  Else
    #if there is nothing into EXFF impossible to add any line here
    For I = 1 To maxtab(this.EXFF)
      If this.EXFF(I) <> null and this.EXFF(I).ASTALIN <> [V]CST_ADEL and this.EXFF(I).ASTALIN <> [V]CST_ANEWDEL
        WFOUND_FLG = [V]CST_ATRUE
        Break
      Endif
    Next

    If WFOUND_FLG = [V]CST_AFALSE
      WERR = mess(63,2006,1)      # Insertion impossible, no file code created
      ASTATUS = fmet this.ASETERROR("",WERR,[V]CST_AERROR)
    Endif
  Endif
  this.VALID = [V]CST_ANO
Return

#********************************************************************
# Method EXFD_AREAD_AFTER
#********************************************************************
#*
#*!
$EXFD_AREAD_AFTER
  Local Char WTXT(120)
  Local Char WLAN(3)

  this.REPCOD = this.APARENT.REPCOD

  If this.ALIAS <> "" and this.REPCOD <> ""
    Local File ASHWEXPPRO [ASWR]
    Read [ASWR]ASWR0 = this.REPCOD;this.ALIAS
    If !fstat
      this.EXPRESSION = [ASWR]CODPRO
      WLAN = this.ACTX.LAN
      Call TEXTELAN([ASWR]INTPRO,WTXT,WLAN) From OBJDIV
      this.DESCRIPTION = WTXT
    Else
      this.EXPRESSION = ""
    Endif
    LogicClose File [ASWR]
  Else
    this.EXPRESSION = ""
  Endif

  this.NUMORDER = this.AORDER

Return


#********************************************************************
# Method EXFD_ADDLINE_AFTER
#********************************************************************
#*
#*!
$EXFD_ADELLINE_AFTER
  this.APARENT.VALID = [V]CST_ANO

  Local Integer WNB_NUMORI(1..), WNB_NUMI(1..), WNB_AST(1..), W_NUMORI(1..), W_NUMI(1..)
  Local Integer I, K, R, D, WDEL , WNDEL, WNB_END, WNB_REC, WND, WREC

  For I = 1 To maxtab(this.APARENT.EXFD)
    WNB_REC=this.APARENT.EXFD(I).AORDER
    If  find(WNB_REC,WNB_NUMI(1..WREC))<>0 and find(WNB_AST(WNB_REC),2,4)<>0 : Goto NOWRITE: Endif
      WNB_NUMORI(WNB_REC)=WNB_REC
      WNB_NUMI(WNB_REC)=I
      WNB_AST (WNB_REC)=this.APARENT.EXFD(I).ASTALIN
      If WNB_REC>WREC: WREC=WNB_REC: Endif
    $NOWRITE
  Next

  For I = 1 To WREC
    If find(WNB_AST(I),[V]CST_ADEL,[V]CST_ANEWDEL)=0
      WND+=1
      W_NUMORI(WND)=WND
      W_NUMI(WND)=WNB_NUMI(I)
    Endif
  Next

  D=WND
  For I = 1 To maxtab(this.APARENT.EXFD)
    R=find(I,W_NUMI(1..WND))
    If R<>0
      this.APARENT.EXFD(I).NUMORDER=W_NUMORI(R)
    Else
      D+=1
      this.APARENT.EXFD(I).NUMORDER=D
    Endif
  Next I

Return


#********************************************************************
# Method EXFD_ADDLINE_BEFORE
#********************************************************************
#*
#*!
$EXFD_ADDLINE_BEFORE
#Pour ajouter un ligne il faut que :
#-il existe des lignes dans EXFP
#-que ca soit enregistré

  Local Integer WFLG_ADD_LINE : WFLG_ADD_LINE = [V]CST_AFALSE
  Local File EDIXMLFILP [EXFP]
  Filter [EXFP] Where [EXFP]MSGCOD = this.MSGCOD and [EXFP]MSGREL = this.MSGREL and [EXFP]MSGFILNOR = this.MSGFILNOR
  For [EXFP]
    WFLG_ADD_LINE = [V]CST_ATRUE
    Break
  Next
  If WFLG_ADD_LINE = [V]CST_AFALSE
    ASTATUS = fmet this.ASETERROR("",mess(183,2006,1), [V]CST_AERROR) #Impossible to insert a line : XML Paths are not propagated  ## 112148
  Endif
  LogicClose File [EXFP]
Return


#********************************************************************
# Method EXFD_ADDLINE_AFTER
#********************************************************************
#*
#*!
$EXFD_ADDLINE_AFTER
  #on ajoute une ligne
  this.NUMLIN    = 1 + max(this.APARENT.EXFD(1..maxtab(this.APARENT.EXFD)).NUMLIN)

  #Manage the SORT property
  Local Integer I, BEF_LINE, AFT_LINE #positions in collection (they have a 0 value here)
  #Where are the previous and next lines ?
  For I = 1 To maxtab(this.APARENT.EXFD)
    If this.APARENT.EXFD(I) <> null
      If this.APARENT.EXFD(I).AORDER = this.AORDER - 1
        BEF_LINE=I
      Elsif this.APARENT.EXFD(I).AORDER = this.AORDER + 1
        AFT_LINE=I
      Endif
    Endif
  Next I

  Local Integer BEF_LINE_SORT, AFT_LINE_SORT, OFFSET_LINE #positions in the sort order
  Local Integer MY_STEP #Step in the sort order between two records
  MY_STEP = 100
  #If the new line is inserted in the middle of the array, not in 1st position
  If AFT_LINE <> 0
    #Assign the SORT property
    AFT_LINE_SORT = this.APARENT.EXFD(AFT_LINE).SORT
    #Test if a next line exists
#    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EXFD(BEF_LINE).SORT : Else : BEF_LINE_SORT = 0 : Endif
    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EXFD(BEF_LINE).SORT : Endif
    #If there is enough space then we insert using a dichotomy method
    If BEF_LINE_SORT <= AFT_LINE_SORT - 2
      #Assign the SORT property
      this.SORT = int((BEF_LINE_SORT + AFT_LINE_SORT)/2)
    Else
      #if there is not enough space, we reassign the SORT property of all lines from the new inserted line
      For I=1 To maxtab(this.APARENT.EXFD)
        If this.APARENT.EXFD(I) <> null
          OFFSET_LINE = this.APARENT.EXFD(I).AORDER - this.AORDER
#          If this.APARENT.EXFD(I).AORDER >= this.AORDER
          If OFFSET_LINE>=0
            #Assign the SORT property
            this.APARENT.EXFD(I).SORT = BEF_LINE_SORT + MY_STEP + (OFFSET_LINE * MY_STEP)
          Endif
        Endif
      Next I
    Endif
  #If the new inserted line is at the 1st position in the array
  Else #If AFT_LINE = 0
    AFT_LINE_SORT = 0
    #Test if a next line exists
#    If BEF_LINE <> 0 : BEF_LINE_SORT = this.APARENT.EXFD(BEF_LINE).SORT : Else : BEF_LINE_SORT = 0 : Endif
    If BEF_LINE <> 0
      BEF_LINE_SORT = this.APARENT.EXFD(BEF_LINE).SORT
    Endif
    #Assign the SORT property
    this.SORT = BEF_LINE_SORT + MY_STEP
  Endif

  Local Integer I
  For I = 1 To maxtab(this.APARENT.EXFD)
    If this.APARENT.EXFD(I)<>null and find(this.APARENT.EXFD(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      this.APARENT.EXFD(I).NUMORDER = this.APARENT.EXFD(I).AORDER
    Endif
  Next I

  this.APARENT.VALID = [V]CST_ANO
Return

#********************************************************************
# Method EXSD_AREAD_AFTER
#********************************************************************
#*
#*!
$EXSD_AREAD_AFTER
  If this.CODE <> ""
    Local File EDIXSDUPL [EXU]
    Read [EXU]EXU0 = this.CODE
    If !fstat
      this.NAM     = [EXU]NAM
      this.FILNAM  = [EXU]FILNAM
      this.FILDES  = [EXU]FILDES
      this.UUIDXSD = [EXU]UUIDXSD
    Else
      this.NAM     = ""
      this.FILNAM  = ""
      this.FILDES  = ""
      this.UUIDXSD = NullUuid()
    Endif
    LogicClose File [EXU]
  Else
    this.NAM     = ""
    this.FILNAM  = ""
    this.FILDES  = ""
    this.UUIDXSD = NullUuid()
  Endif
Return


