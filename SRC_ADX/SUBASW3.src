Subprog APRES_NBCLELNK
#----- Si touche "Echap" ou autre statut "Abandon" -----#
If status=6 | status=7 | status=27 | status=28 | status=1792
  End
#----- Si suppression ligne -----#
Elsif status=65 | status=68 | status=83
  End
Endif
 Local Integer I
 I=find(func SUBASW_TOOL.BUILD_ASW5_IDENT2(3,[M:ASW7]AFFLNKCUR,2,[M:ASW7]CODLNKCUR,[M:ASW7]ANCLNKCUR,[M:ASW7]CODCLELNK(nolign-1)),[M:ASW5]IDENT2)
 If I>0
   [M:ASW5]ADRVAL(I-1) = [M:ASW7]MODCLELNK(nolign-1) : Affzo [M:ASW5]ADRVAL(I-1)
   [M:ASW5]VALEUR(I-1) = [M:ASW7]VALCLELNK(nolign-1) : Affzo [M:ASW5]VALEUR(I-1)
 Endif
End

#----------------- key mod ------------------#
Subprog AS_MODCLELNK(VALEUR)
Variable Integer VALEUR
Local Integer I
I=find(func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW7]AFFLNKCUR,[M:ASW7]ANCLNKCUR,[M:ASW7]CODLNKCUR),[M:ASW6]IDENT2)
If I>0
  If [M:ASW6]CMPLNK(I-1)=19
    mkstat=2
    End
  Endif
Endif
End

Subprog AM_MODCLELNK(VALEUR)
Variable Integer VALEUR
Gosub AM_ASWP_INVLNK From SUBASW_TOOL
End

#----------------- key value ------------------#
Subprog AS_VALCLELNK(VALEUR)
Variable Char    VALEUR()
Local Integer I
I=find(func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW7]AFFLNKCUR,[M:ASW7]ANCLNKCUR,[M:ASW7]CODLNKCUR),[M:ASW6]IDENT2)
If I>0
  If [M:ASW6]CMPLNK(I-1)=19
    mkstat=2
    End
  Endif
Endif
End

Subprog C_VALCLELNK(VALEUR)
Variable Char    VALEUR()
 Local Char L_ERR_MSG(250),L_PARCOL(GLONAVC)
 Case [M:ASW7]AFFLNKCUR
   When 1: #property
    L_PARCOL = func SUBASW_TOOL.GET_COL_FROM_PRO_PATH_SCREEN([M:ASW7]ANCLNKCUR,1)
   When 2: #collection line
    L_PARCOL = [M:ASW7]ANCLNKCUR
 Endcase

 Local Integer I,J
 Local Char PARACT(GLONACV)
 I=find(func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW7]AFFLNKCUR,[M:ASW7]ANCLNKCUR,[M:ASW7]CODLNKCUR),[M:ASW6]IDENT2)
 If [M:ASW7]AFFLNKCUR=1
  For J=0 To [M:ASW4]NBRPRO-1
   If [M:ASW4]CODPRO(J)=[M:ASW7]ANCLNKCUR
    If func AFNC.ACTIV([M:ASW6]ACVLNK(I-1))
     PARACT=[M:ASW4]ACTPRO(J)
    Else
     PARACT=[M:ASW6]ACVLNK(I-1)
    Endif
    If !func SUBASW_TOOL.L_CHECK_PARAMETER([M:ASW6]ANCLNK(I-1),"",[M:ASW7]CODCLELNK(nolign-1),PARACT,VALEUR, [M:ASW7]TYPCLELNK(nolign-1), [M:ASW7]MODCLELNK(nolign-1), L_PARCOL,
&      [M:ASW0]CODREP, 1, 1, [M:ASW6]CMPLNK(I-1),
&      [M:ASW6]DETLNK(I-1),[M:ASW6]QRYLNK(I-1),[M:ASW6]EDILNK(I-1),[M:ASW6]LOKLNK(I-1),[M:ASW6]SUMLNK(I-1),
&      0, L_ERR_MSG)
     GMESSAGE = L_ERR_MSG
     mkstat = 2
    Endif
   Endif
  Next
 Else
  If !func SUBASW_TOOL.L_CHECK_PARAMETER([M:ASW6]ANCLNK(I-1),"",[M:ASW7]CODCLELNK(nolign-1),[M:ASW6]ACVLNK(I-1),VALEUR, [M:ASW7]TYPCLELNK(nolign-1), [M:ASW7]MODCLELNK(nolign-1), L_PARCOL,
&    [M:ASW0]CODREP, 1, 1, [M:ASW6]CMPLNK(I-1),
&    [M:ASW6]DETLNK(I-1),[M:ASW6]QRYLNK(I-1),[M:ASW6]EDILNK(I-1),[M:ASW6]LOKLNK(I-1),[M:ASW6]SUMLNK(I-1),
&    0, L_ERR_MSG)
   GMESSAGE = L_ERR_MSG
   mkstat = 2
  Endif
 Endif
End

