Variable Char    VALEUR()
 Call SEL_EXPRO_ASW4(VALEUR,0) From SUBASW_TOOL
End

Subprog AM_VALCLELNK(VALEUR)
Variable Char    VALEUR()
Gosub AM_ASWP_INVLNK From SUBASW_TOOL
End


######################################################################################
#--------------------------- block "Links" (displayed) ------------------------------#
######################################################################################

Subprog B2_WNBLNK
If [M:ASW7]WINVLNK(nolign-1)=2
 [M:ASW7]WINVLNK(nolign-1)=1
 Affzo [M:ASW7]WINVLNK(nolign-1)
 mkstat=4
Endif
End


Subprog IB_WNBLNK
If [M:ASW7]WINVLNK(nolign-1)<>2
 Raz GBOUT2
Endif
End

Subprog AS_WNBLNK
Local Integer NOL : NOL=nolign-1
 Chgstl [M:ASW7]WNBLNK With ""
 Chgstl [M:ASW7]WNBLNK(NOL) With "AMKCUR"
 Call ACTZO_ASW7(NOL) From SUBASW_TOOL
 Effzo  [M:ASW7]10
 Effzo  [M:ASW7]15
 If [M:ASW7]WCODLNK(NOL)=""
  Raz [M:ASW7]ANCLNKCUR
  Raz [M:ASW7]AFFLNKCUR
  Raz [M:ASW7]CODLNKCUR
  Raz [M:ASW7]TYPLNKCUR
  End
 Endif
 [M:ASW7]ANCLNKCUR = [M:ASW7]WANCLNK(NOL)
 [M:ASW7]AFFLNKCUR = [M:ASW7]WAFFLNK(NOL)
 [M:ASW7]CODLNKCUR = [M:ASW7]WCODLNK(NOL)
 [M:ASW7]TYPLNKCUR = func L_BUILD_TYPLNKCUR([M:ASW7]WCODLNK(NOL),[M:ASW7]WTYPLNK(NOL),[M:ASW7]WREPLNK(NOL),[M:ASW7]WCMPLNK(NOL),[M:ASW7]WCLAPTRLNK(NOL),[M:ASW7]WCLALNK(NOL),[M:ASW7]WMETLNK(NOL),[M:
& ASW7]WCODFNCLNK(NOL),[M:ASW7]WRPTCOD(NOL))
 Call DISPLAY_PARLNK_ASW7([M:ASW7]AFFLNKCUR,[M:ASW7]ANCLNKCUR,[M:ASW7]CODLNKCUR) From SUBASW_TOOL
End

Subprog C_WNBLNK
 Local Integer I, NOL
 NOL=nolign-1
 Case status
  When 65 # remove a line
   #Controls
   #If [M:ASW7]WFLGSTDLNK(NOL)=2
   # GMESSAGE=mess(196,143,1) : mkstat=2 : End
   #Endif
   For I=0 To [M:ASW6]NBRLNK-1
    If [M:ASW7]WAFFLNK(NOL)=[M:ASW6]AFFLNK(I) & [M:ASW7]WANCLNK(NOL)=[M:ASW6]ANCLNK(I)
&    & [M:ASW7]WCODLNK(NOL)=[M:ASW6]REMSTDLNK(I)
      GMESSAGE=mess(197,143,1) : mkstat=2 : Break
    Endif
   Next I
   If mkstat : End : Endif
   # remove link from table [M:ASW6]
   I=find(func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW7]WAFFLNK(NOL),[M:ASW7]WANCLNK(NOL),[M:ASW7]WCODLNK(NOL)),[M:ASW6]IDENT2)
   If I>0
    Dela I-1,1 [M:ASW6]NBRLNK
    [M:ASW6]NBRLNK -=1
   Endif
   # remove the parameters/keys
   Call REMOVE_PARAM_ASW5([M:ASW7]WAFFLNK(NOL),[M:ASW7]WANCLNK(NOL),[M:ASW7]WCODLNK(NOL),3) From SUBASW_TOOL
   Raz   [M:ASW7]ANCLNKCUR,[M:ASW7]AFFLNKCUR,[M:ASW7]CODLNKCUR, [M:ASW7]TYPLNKCUR
   Effzo [M:ASW7]10
   Effzo [M:ASW7]15
   Gosub AFFZO_ASW5 From SUBASW
   Gosub AFFZO_ASW6 From SUBASW

  When 73, 82 # insert/create a new line
   If [M:ASW6]NBRLNK = dim([M:ASW6]CODLNK)
    GMESSAGE = mess(187,143,1) # Le nombre maximum de liens est atteint
    mkstat=2 : End
   Endif
   Raz   [M:ASW7]ANCLNKCUR,[M:ASW7]AFFLNKCUR,[M:ASW7]CODLNKCUR, [M:ASW7]TYPLNKCUR
   Effzo [M:ASW7]10
   Effzo [M:ASW7]15
 Endcase
End

Subprog APRES_WNBLNK
#----- Si touche "Echap" ou autre statut "Abandon" -----#
If status=6 | status=7 | status=27 | status=28 | status=1792
  End
#----- Si suppression ligne -----#
Elsif status=65 | status=68 | status=83
  End
Endif
Local Integer I
Local Char NEW_TYPLNKCUR(250)
Local Integer NOL : NOL=nolign-1
If [M:ASW7]WCODLNK(NOL)<>""
 If [M:ASW7]CODLNKCUR<> ""
  # remove old link from table [M:ASW6]
   I=find(func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW7]AFFLNKCUR,[M:ASW7]ANCLNKCUR,[M:ASW7]CODLNKCUR),[M:ASW6]IDENT2)
   If I>0
    Dela I-1,1 [M:ASW6]NBRLNK
    [M:ASW6]NBRLNK -=1
   Endif
 Endif

 # add current link into table [M:ASW6]
 I=[M:ASW6]NBRLNK
 [M:ASW6]CODLNK(I) = [M:ASW7]WCODLNK(NOL)
 [M:ASW6]INTITLNK(I) = [M:ASW7]WINTITLNK(NOL)
 [M:ASW6]INTLNK(I) = [M:ASW7]WINTLNK(NOL)
 [M:ASW6]TYPLNK(I) = [M:ASW7]WTYPLNK(NOL)
 [M:ASW6]REPLNK(I) = [M:ASW7]WREPLNK(NOL)
 [M:ASW6]CMPLNK(I) = [M:ASW7]WCMPLNK(NOL)
 [M:ASW6]TARLNK(I) = [M:ASW7]WTARLNK(NOL)
 [M:ASW6]CLAPTRLNK(I) = [M:ASW7]WCLAPTRLNK(NOL)
 [M:ASW6]CLALNK(I) = [M:ASW7]WCLALNK(NOL)
 [M:ASW6]METLNK(I) = [M:ASW7]WMETLNK(NOL)
 [M:ASW6]FLGASYLNK(I) = [M:ASW7]WFLGASYLNK(NOL)
 [M:ASW6]CODFNCLNK(I) = [M:ASW7]WCODFNCLNK(NOL)
 [M:ASW6]FREELNK(I) = [M:ASW7]WFREELNK(NOL)
 [M:ASW6]RPTCOD(I) = [M:ASW7]WRPTCOD(NOL) :#104754/3
 [M:ASW6]MENLNK(I) = [M:ASW7]WMENLNK(NOL)
 [M:ASW6]ORDLNK(I) = [M:ASW7]WORDLNK(NOL)
 [M:ASW6]AFFLNK(I) = [M:ASW7]WAFFLNK(NOL)
 [M:ASW6]ANCLNK(I) = [M:ASW7]WANCLNK(NOL)
 [M:ASW6]ATTLNK(I) = [M:ASW7]WATTLNK(NOL)
 [M:ASW6]FLGSTDLNK(I) = [M:ASW7]WFLGSTDLNK(NOL)
 [M:ASW6]REMSTDLNK(I) = [M:ASW7]WREMSTDLNK(NOL)
 [M:ASW6]ACVLNK(I) = [M:ASW7]WACVLNK(NOL)
 [M:ASW6]DETLNK(I) = [M:ASW7]WDETLNK(NOL)
 [M:ASW6]QRYLNK(I) = [M:ASW7]WQRYLNK(NOL)
 [M:ASW6]EDILNK(I) = [M:ASW7]WEDILNK(NOL)
 [M:ASW6]LOKLNK(I) = [M:ASW7]WLOKLNK(NOL)
 [M:ASW6]SUMLNK(I) = [M:ASW7]WSUMLNK(NOL)
 [M:ASW6]ENALNK(I) = [M:ASW7]WENALNK(NOL)
 [M:ASW6]INVLNK(I) = [M:ASW7]WINVLNK(NOL)
 [M:ASW6]STDNEW(I) = 1
 [M:ASW6]IDENT2(I) = func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW7]WAFFLNK(NOL),[M:ASW7]WANCLNK(NOL),[M:ASW7]WCODLNK(NOL))
 [M:ASW6]NBRLNK += 1
 Gosub AFFZO_ASW6 From SUBASW

 [L]NEW_TYPLNKCUR = func L_BUILD_TYPLNKCUR([M:ASW7]WCODLNK(NOL),[M:ASW7]WTYPLNK(NOL),[M:ASW7]WREPLNK(NOL),[M:ASW7]WCMPLNK(NOL),[M:ASW7]WCLAPTRLNK(NOL),[M:ASW7]WCLALNK(NOL),[M:ASW7]WMETLNK(NOL),[M:ASW7
& ]WCODFNCLNK(NOL),[M:ASW7]WRPTCOD(NOL))
 If [L]NEW_TYPLNKCUR<>[M:ASW7]TYPLNKCUR | [M:ASW7]ANCLNKCUR <> [M:ASW7]WANCLNK(NOL)
  If [M:ASW7]CODLNKCUR<> ""
   # remove old parameters/keys from table [M:ASW5]
   Call REMOVE_PARAM_ASW5([M:ASW7]AFFLNKCUR,[M:ASW7]ANCLNKCUR,[M:ASW7]CODLNKCUR,3) From SUBASW_TOOL
  Endif
  Effzo [M:ASW7]10
  Effzo [M:ASW7]15
  # set new CODLNKCUR, TYPLNKCUR
  [M:ASW7]ANCLNKCUR = [M:ASW7]WANCLNK(NOL)
  [M:ASW7]AFFLNKCUR = [M:ASW7]WAFFLNK(NOL)
  [M:ASW7]CODLNKCUR = [M:ASW7]WCODLNK(NOL)
  [M:ASW7]TYPLNKCUR = [L]NEW_TYPLNKCUR

  # add new parameters/keys into table [M:ASW5]
  Call LOAD_PARLNK_ASW5(0,nomap,[M:ASW0]CODREP,[M:ASW1]CODCLA,
&     [M:ASW7]WCMPLNK(NOL),[M:ASW7]AFFLNKCUR,[M:ASW7]ANCLNKCUR,[M:ASW7]CODLNKCUR,[M:ASW7]WTYPLNK(NOL),
&     [M:ASW7]WCLALNK(NOL),[M:ASW7]WREPLNK(NOL),[M:ASW7]WCLAPTRLNK(NOL),[M:ASW7]WMETLNK(NOL)+[M:ASW7]WRPTCOD(NOL),
&     [M:ASW7]WCODFNCLNK(NOL)) From SUBASW_TOOL

  # display the new parameters/keys
  Call DISPLAY_PARLNK_ASW7([M:ASW7]AFFLNKCUR,[M:ASW7]ANCLNKCUR,[M:ASW7]CODLNKCUR) From SUBASW_TOOL
 Endif
Endif
End


#--------------- Anchor ---------------#
Subprog AS_WANCLNK(VALEUR)
Variable Char    VALEUR()
 If [M:ASW7]WAFFLNK(nolign-1)=0 : #création de lien
   [M:ASW7]WAFFLNK(nolign-1) = [M:ASW7]TYPANCLNK
   [M:ASW7]WENALNK(nolign-1) = 2
   [M:ASW7]WINVLNK(nolign-1) = 1
 Endif
 If [M:ASW7]CODANCLNK<>""
  If VALEUR = "" : VALEUR = [M:ASW7]CODANCLNK : Endif
  mkstat = 2 : End
 Elsif [M:ASW7]WFLGSTDLNK(nolign-1)=2 : mkstat=2 : End
 Elsif find([M:ASW7]WAFFLNK(nolign-1),4,5)
  mkstat=1 : End
 Endif
End

Subprog C_WANCLNK(VALEUR)
Variable Char    VALEUR()
Local Integer NOL : NOL=nolign-1
VALEUR=toupper(VALEUR)
 Case [M:ASW7]WAFFLNK(nolign-1)
  When 1:
   If !find(VALEUR, [M:ASW4]CODPRO)
    GMESSAGE = mess(170,143,1) # Veillez mettre une propriété exposée
    mkstat = 2 : End
   Endif
  When 2,3:
   If !find(VALEUR, [M:ASW1]CODCOL)
    GMESSAGE = VALEUR-":"-mess(144,143,1) : # Collection inexistante.
    mkstat = 2 : End
   Endif
 Endcase
 # ATTENTION : le ctrl d'unicité doit se faire sur le tableau invisible
 If [M:ASW7]WANCLNK(NOL)<>VALEUR
   If [M:ASW7]CODLNKCUR<>[M:ASW7]WCODLNK(NOL) | [M:ASW7]ANCLNKCUR<>VALEUR | [M:ASW7]AFFLNKCUR<>[M:ASW7]WAFFLNK(NOL)
     Call UNICITE_CODLNK([M:ASW7]WCODLNK(NOL),[M:ASW7]WAFFLNK(NOL),VALEUR)
     If mkstat : End : Endif
   Endif
 Endif
End

Subprog S_WANCLNK(VALEUR)
Variable Char    VALEUR()
 If [M:ASW7]CODANCLNK=""
  Case [M:ASW7]WAFFLNK(nolign-1)
   When 1: Call SEL_EXPRO_ASW4(VALEUR,0) From SUBASW_TOOL
   When 2: Call SEL_COL_ASW1(VALEUR, 2) From SUBASW_TOOL
   When 3: Call SEL_COL_ASW1(VALEUR, 3) From SUBASW_TOOL
  Endcase
 Endif
End

#----------------------------------------
Subprog UNICITE_CODLNK(CODLNK,AFFLNK,ANCLNK)
Value Char CODLNK
Value Integer AFFLNK
Value Char ANCLNK
Local Integer I

I=find(func SUBASW_TOOL.BUILD_ASW6_IDENT2([L]AFFLNK,[L]ANCLNK,[L]CODLNK),[M:ASW6]IDENT2)
If I>0
 # Code déjà existant
 GMESSAGE = mess(33,137,1)-[L]CODLNK+"\"+
&     func AMK_TOOL.GET_FIELD_LABEL("ASHW7", "TYPANCLNK")+"="+mess([M:ASW6]AFFLNK(I-1),7965,1)-
&     func AMK_TOOL.GET_FIELD_LABEL("ASHW7", "CODANCLNK")+"="+[M:ASW6]ANCLNK(I-1)
 mkstat=2 : End
Endif
End

#-------------Link code -------------#
Subprog AS_WCODLNK(VALEUR)
Variable Char    VALEUR()
If [M:ASW7]WFLGSTDLNK(nolign-1)=2 : mkstat=2 : End : Endif
End

Subprog C_WCODLNK(VALEUR)
Variable Char    VALEUR()
Local Integer NOL : NOL=nolign-1
VALEUR=toupper(VALEUR)
Gosub LNK_RESERVED From SUBASW
If find(VALEUR,CODLNK_RESERVED)
  Call ERREUR(VALEUR-":"-mess(205,133,1)) From GESECRAN : # Code réservé
  mkstat = 1 : End
Endif
If VALEUR <>[M:ASW7]WCODLNK(nolign-1)
  # name covention
  Call PLAGE(VALEUR,1) From CONTOBJ
  If mkstat : End : Endif

  # unique check
  If find([M:ASW7]TYPANCLNK,4,5)<>0 | [M:ASW7]CODANCLNK<>""
    Call UNICITE(VALEUR,[M:ASW7]WCODLNK(0..[M:ASW7]WNBLNK-1)) From OBJDIV
    If mkstat : End : Endif
  Endif
  # ATTENTION : le ctrl d'unicité doit se faire sur le tableau invisible
  If [M:ASW7]WAFFLNK(NOL)=0 & [M:ASW7]TYPANCLNK<>0
    [M:ASW7]WAFFLNK(NOL) = [M:ASW7]TYPANCLNK
  Endif
  If [M:ASW7]WANCLNK(NOL)="" & [M:ASW7]CODANCLNK<>""
    [M:ASW7]WANCLNK(NOL)=[M:ASW7]CODANCLNK
  Endif
  If [M:ASW7]CODLNKCUR<>VALEUR | [M:ASW7]ANCLNKCUR<>[M:ASW7]WANCLNK(NOL) | [M:ASW7]AFFLNKCUR<>[M:ASW7]WAFFLNK(NOL)
    Call UNICITE_CODLNK(VALEUR,[M:ASW7]WAFFLNK(NOL),[M:ASW7]WANCLNK(NOL))
    If mkstat : End : Endif
  Endif
  If find(VALEUR,[M:ASW8]CODMENU)
    GMESSAGE=mess(229,143,1)
    mkstat=2
    End
  Endif
Endif
End

#------------------------------#
Subprog AS_WINTITLNK(VALEUR)
Variable Char    VALEUR()
If [M:ASW7]WFLGSTDLNK(nolign-1)=2 : mkstat=2 : End : Endif
End

#--------------- Actif ---------------#
Subprog AS_WENALNK(VALEUR)
Variable Integer VALEUR
#If [M:ASW7]WTYPLNK(nolign-1)=3
#  GMENLOC(2)=1 : #Opération non autorisée
#Endif
End

Subprog AM_WENALNK(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Effzo [M:ASW7]WINVLNK(nolign-1)
Endif
End

#--------------- Type ---------------#
Subprog AS_WTYPLNK(VALEUR)
Variable Integer VALEUR
#GMENLOC(5)=1 : #Libre
If [M:ASW7]WFLGSTDLNK(nolign-1)=2 : mkstat=2 : End : Endif
If [M:ASW1]TYPMSKREP<>1
 GMENLOC(4)=1 : #X3 Convergence
 GMENLOC(6)=1 : #Etat Crystal  #104754/3
Endif
#101877/99183
If [M:ASW7]WAFFLNK(nolign-1)=1
 GMENLOC(2)=1 : #Method on property not allowed
Endif
#104754/3
If find([M:ASW7]WAFFLNK(nolign-1),4,5)=0
 GMENLOC(6)=1 : #Etat Crystal  #104754/3
Endif
End

Subprog AM_WTYPLNK(VALEUR)
Variable Integer VALEUR
 If VALEUR<>1
  Effzo [M:ASW7]WCMPLNK(nolign-1)
  Effzo [M:ASW7]WREPLNK(nolign-1)
 Endif
 If !find(VALEUR, 2,3)
  Effzo [M:ASW7]WCLAPTRLNK(nolign-1)
  Effzo [M:ASW7]WMETLNK(nolign-1)
 Endif
 If !find(VALEUR, 1,2,3,6)  #104754/3
  Effzo [M:ASW7]WCLALNK(nolign-1)
 Endif
 If VALEUR<>3
  Effzo [M:ASW7]WFLGASYLNK(nolign-1)
 Endif
 If VALEUR<>4
  Effzo [M:ASW7]WCODFNCLNK(nolign-1)
 Endif
 If VALEUR<>5
  Effzo [M:ASW7]WFREELNK(nolign-1)
 Endif
 If VALEUR<>6 :#104754/3
  Effzo [M:ASW7]WRPTCOD(nolign-1)
 Else
  [M:ASW7]WREPLNK(nolign-1)=[M:ASW0]CODREP
  [M:ASW7]WCLALNK(nolign-1)=[M:ASW1]CODCLA
 Endif
End


#------------ Crystal report -------------#
Subprog AS_WRPTCOD(VALEUR)
Variable Char    VALEUR()
If [M:ASW7]WTYPLNK(nolign-1)<>6 : mkstat=1 : End : Endif

End

#------------ Representation -------------#
Subprog AS_WREPLNK(VALEUR)
Variable Char    VALEUR()
If [M:ASW7]WFLGSTDLNK(nolign-1)=2 : mkstat=2 : End : Endif
If [M:ASW7]WTYPLNK(nolign-1)=6 : mkstat=2 : End : Endif   #104754/3
If [M:ASW7]WTYPLNK(nolign-1)<>1 : mkstat=1 : End : Endif
End

Subprog C_WREPLNK(VALEUR)
Variable Char    VALEUR()
 Read [ASW2]ASW0 = VALEUR
 If !fstat
  If [M:ASW1]TYPMSKREP<>[F:ASW2]TYPMSKREP
   GMESSAGE=func AFNC.MES1(mess(252,143,1), mess([M:ASW1]TYPMSKREP,7963,1))-":"-func AFNC.MES1(mess(255,143,1), mess([F:ASW2]TYPMSKREP,7963,1))
   GERR=1
   mkstat = 2 : End
  Endif
 Endif
End

Subprog AM_WREPLNK(VALEUR)
Variable Char    VALEUR()
 Read [ASW2]ASW0 = VALEUR
 If !fstat
  [M:ASW7]WCLALNK(nolign-1) = [F:ASW2]CODCLA
  Affzo [M:ASW7]WCLALNK(nolign-1)
 Endif
End


#--------------- Behavior ---------------#
Subprog AS_WCMPLNK(VALEUR)
Variable Integer VALEUR
#On ne gère pas le Imprimer pour le moment
#If nomap<>"SUPERV"
  GMENLOC(11)=1 : # Afficher en PDF
  GMENLOC(12)=1 : # Lister en PDF
#Endif
If [M:ASW7]WFLGSTDLNK(nolign-1)<>2
  GMENLOC(17)=1 : #Enregistrer
  GMENLOC(18)=1 : #Abandon
  GMENLOC(19)=1 : #Gestion LOB
  GMENLOC(22)=1 : #115007/1 Aide
Endif
GMENLOC(6)=1 : # Dupliquer fiche
#104754/3
If [M:ASW7]WTYPLNK(nolign-1)=6
  GMENLOC(1)=1
  GMENLOC(2)=1
  GMENLOC(3)=1
  GMENLOC(4)=1
  GMENLOC(5)=1
  GMENLOC(6)=1
  GMENLOC(7)=1
  GMENLOC(8)=1
  GMENLOC(9)=1
  GMENLOC(10)=1
  GMENLOC(11)=1
  GMENLOC(12)=1
  GMENLOC(13)=1
  GMENLOC(14)=1
  GMENLOC(15)=1
  GMENLOC(16)=1
  GMENLOC(17)=1
  GMENLOC(18)=1
  GMENLOC(19)=1
  GMENLOC(22)=1 :#115007/1 Aide
Else
  GMENLOC(20)=1
  GMENLOC(21)=1
Endif
If [M:ASW7]WFLGSTDLNK(nolign-1)=2 : mkstat=2 : End : Endif
If find([M:ASW7]WTYPLNK(nolign-1),1,6)=0 : mkstat=1 : End : Endif   #104754/3
End

#--------------- Target ---------------#
Subprog AS_WTARLNK(VALEUR)
Variable Integer VALEUR
Local Integer OK_TARGET
If [M:ASW7]WFLGSTDLNK(nolign-1)=2 : mkstat=2 : End : Endif
#104754/3
If [M:ASW7]WTYPLNK(nolign-1)=6 : mkstat=2 : End : Endif
# to be able to set the target on a page link (a free link or a representation link on query, details, or summary facet).
OK_TARGET=0
If [M:ASW7]WAFFLNK(nolign-1)=4 & [M:ASW7]WTYPLNK(nolign-1)=5 : OK_TARGET=1 : Endif
If [M:ASW7]WAFFLNK(nolign-1)=4 & [M:ASW7]WTYPLNK(nolign-1)=1 & find([M:ASW7]WCMPLNK(nolign-1),2,5,10)>0 : OK_TARGET=1 : Endif
If !OK_TARGET : mkstat=1 : End : Endif
End


#--------------- Instance path ---------------#
Subprog AS_WCLAPTRLNK(VALEUR)
Variable Char    VALEUR()
If [M:ASW7]WFLGSTDLNK(nolign-1)=2 : mkstat=2 : End : Endif
If !find([M:ASW7]WTYPLNK(nolign-1),2,3) : mkstat=1 : End : Endif
#101876
If VALEUR="" & find([M:ASW7]WAFFLNK(nolign-1),2,3) & [M:ASW7]WTYPLNK(nolign-1)=2
 VALEUR=[M:ASW7]WANCLNK(nolign-1)
Endif
End

Subprog C_WCLAPTRLNK(VALEUR)
Variable Char    VALEUR()
 Local Char TAB_COD(250)(1..100)
 Local Char TAB_CLA(GLONACLA)(1..100)
 Local Integer TAB_NB, I, FLG_MET_EXIST

 VALEUR = toupper(VALEUR)

#101876
 If [M:ASW7]WTYPLNK(nolign-1)=2
  If find([M:ASW7]WAFFLNK(nolign-1),2,3) & VALEUR<>[M:ASW7]WANCLNK(nolign-1)
   GMESSAGE = mess(57,140,1) : mkstat = 2 : End : # Chemin de la classe incorrect
  Elsif find([M:ASW7]WAFFLNK(nolign-1),4,5) & (VALEUR<>"" & VALEUR<>[M:ASW1]ABRCLA)
   GMESSAGE = mess(57,140,1) : mkstat = 2 : End : # Chemin de la classe incorrect
  Elsif [M:ASW7]WAFFLNK(nolign-1)=1
   If pat([M:ASW7]WANCLNK(nolign-1),VALEUR+".*")=0
    GMESSAGE = mess(57,140,1) : mkstat = 2 : End : # Chemin de la classe incorrect
   Elsif instr(0,right$([M:ASW7]WANCLNK(nolign-1),len(VALEUR)+2),".")>0
    GMESSAGE = mess(57,140,1) : mkstat = 2 : End : # Chemin de la classe incorrect
   Endif
  Endif
 Endif

If VALEUR = ""
  If [M:ASW7]WTYPLNK(nolign-1)=3
   #88438
#   GMESSAGE = mess(10,123,1) : #"Zone obligatoire"
#   mkstat = 2 : End
  Else
   Effzo [M:ASW7]WCLALNK(nolign-1)
   Affzo [M:ASW7]WCLALNK(nolign-1)
  Endif
 Else
  Call LOAD_CHILD_CLASSES([M:ASW1]CODCLA,[M:ASW1]ABRCLA,TAB_COD,TAB_CLA,TAB_NB) From SUBASW_TOOL
  I = find(VALEUR, TAB_COD)
  If I>0
   [M:ASW7]WCLALNK(nolign-1) = TAB_CLA(I)
   Affzo [M:ASW7]WCLALNK(nolign-1)
   If [M:ASW7]WTYPLNK(nolign-1)=2
    FLG_MET_EXIST = func SUBASW_TOOL.CHECK_METHODS_EXIST([M:ASW7]WCLALNK(nolign-1), 0)
    If !FLG_MET_EXIST
     GMESSAGE = mess(41,140,1) :# "Aucune methodes de definis sur cette classe"
     mkstat=2 : End
    Endif
   Elsif [M:ASW7]WTYPLNK(nolign-1)=3
    FLG_MET_EXIST = func SUBASW_TOOL.CHECK_METHODS_EXIST([M:ASW7]WCLALNK(nolign-1), 1)
    If !FLG_MET_EXIST
     GMESSAGE = mess(42,140,1) : # "Aucune opérations de definies sur cette classe"
     mkstat=2 : End
    Endif
   Endif
  Else
   GMESSAGE = VALEUR-":"-mess(57,140,1) : mkstat = 2 : End : # Chemin de la classe incorrect
  Endif
 Endif
End

Subprog S_WCLAPTRLNK(VALEUR)
Variable Char    VALEUR()
 Local Integer NBTEX, CHOI,I
 Local Char    TEX(GLONDES)(1..500,1..2) , TIT(GLONDES)(0..2) , CRITERE(250)

 Local Char TAB_COD(250)(1..100)
 Local Char TAB_CLA(GLONACLA)(1..100)
 Local Integer TAB_NB

 Call LOAD_CHILD_CLASSES([M:ASW1]CODCLA,[M:ASW1]ABRCLA,TAB_COD,TAB_CLA,TAB_NB) From SUBASW_TOOL

 For I=1 To TAB_NB
  If [M:ASW7]WTYPLNK(nolign-1)=2
   If find([M:ASW7]WAFFLNK(nolign-1),2,3) & TAB_COD(I)=[M:ASW7]WANCLNK(nolign-1)
    NBTEX+= 1
    TEX(NBTEX,1)  = TAB_COD(I)
    TEX(NBTEX,2)  = TAB_CLA(I)
   Elsif find([M:ASW7]WAFFLNK(nolign-1),4,5) & TAB_COD(I)=[M:ASW1]ABRCLA
    NBTEX+= 1
    TEX(NBTEX,1)  = TAB_COD(I)
    TEX(NBTEX,2)  = TAB_CLA(I)
   Elsif [M:ASW7]WAFFLNK(nolign-1)=1 & pat([M:ASW7]WANCLNK(nolign-1),TAB_COD(I)+".*")>0
    If instr(0,right$([M:ASW7]WANCLNK(nolign-1),len(TAB_COD(I))+2),".")=0
      NBTEX+= 1
      TEX(NBTEX,1)  = TAB_COD(I)
      TEX(NBTEX,2)  = TAB_CLA(I)
    Endif
   Endif
  Else
   NBTEX+= 1
   TEX(NBTEX,1)  = TAB_COD(I)
   TEX(NBTEX,2)  = TAB_CLA(I)
  Endif
 Next

 CHOI = 0
 TIT(0) = mess(22,123,1) # Selection
 TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("ASHW7", "CLAPTRLNK") # Chemin de l'instance
 TIT(2) = func AMK_TOOL.GET_FIELD_LABEL("ASHW1", "CODCLA") # Code classe

 If NBTEX=1
  VALEUR = TEX(1,1)
 Elsif NBTEX>0
  Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
  If status<>7 & CHOI<>0
   VALEUR = TEX(CHOI,1)
  Endif
 Endif

End

#--------------- Class ---------------#
Subprog AS_WCLALNK(VALEUR)
Variable Char    VALEUR()
If [M:ASW7]WFLGSTDLNK(nolign-1)=2 : mkstat=2 : End : Endif
If [M:ASW7]WTYPLNK(nolign-1)<>3 | [M:ASW7]WCLAPTRLNK(nolign-1)<>"" : mkstat=2 : End : Endif
End

#--------------- Method ---------------#
Subprog AS_WMETLNK(VALEUR)
Variable Char    VALEUR()
If [M:ASW7]WFLGSTDLNK(nolign-1)=2 : mkstat=2 : End : Endif
If !find([M:ASW7]WTYPLNK(nolign-1),2,3) : mkstat=1 : End : Endif
End

Subprog C_WMETLNK(VALEUR)
Variable Char    VALEUR()
 If [M:ASW7]WCLALNK(nolign-1)<>""
  Read [ACLAM]ACLAM0 = [M:ASW7]WCLALNK(nolign-1);VALEUR
  If !fstat
   If [M:ASW7]WTYPLNK(nolign-1) = 2 & [F:ACLAM]FLGOPE = 2
    GMESSAGE = VALEUR+":"-mess(173,143,1)  # Cette méthode est une opération
    mkstat=2 : End
   Elsif [M:ASW7]WTYPLNK(nolign-1) = 3 & [F:ACLAM]FLGOPE <> 2
    GMESSAGE = VALEUR+":"-mess(174,143,1)  # Cette méthode n'est pas une opération
    mkstat=2 : End
   Endif
    Local Char CLA_COD(GLONACLA)
    Local Integer SEL_MOD
    CLA_COD=[M:ASW7]WCLALNK(nolign-1)
    SEL_MOD=[M:ASW7]WTYPLNK(nolign-1)
    Gosub DEFLIST_METH From SUBACLA_TOOL
    Gosub LIST_METH From SUBACLA_TOOL
    If !find(VALEUR, TEX(1..NBTEX,1))
      #La méthode $1$ ne peut pas être utilisée dans un lien
      GMESSAGE=func AFNC.MES1(mess(214,143,1),VALEUR)
      mkstat=2 : End
    Endif
  Else
   GMESSAGE = VALEUR+":"-mess(172,143,1)  # Méthode inexistante
   mkstat=2 : End
  Endif
 Else
  If !find(VALEUR, [M:ASW3]CODMET)
   GMESSAGE = VALEUR+":"-mess(172,143,1)  # Méthode inexistante
   mkstat=2 : End
  Endif
  Local Char REP_COD(GLONASW)
  REP_COD=[M:ASW0]CODREP
  Gosub DEFLIST_METH From SUBASW_TOOL
  Gosub LIST_METH From SUBASW_TOOL
  If !find(VALEUR, TEX(1..NBTEX,1))
    #La méthode $1$ ne peut pas être utilisée dans un lien
    GMESSAGE=func AFNC.MES1(mess(214,143,1),VALEUR)
    mkstat=2 : End
  Endif
 Endif
End

Subprog S_WMETLNK(VALEUR)
Variable Char    VALEUR()
 If [M:ASW7]WCLALNK(nolign-1)<>""
  Case [M:ASW7]WTYPLNK(nolign-1)
   When 2:
    Call SEL_METHOD([M:ASW7]WCLALNK(nolign-1), 2, VALEUR) From SUBACLA_TOOL
   When 3:
    Call SEL_METHOD([M:ASW7]WCLALNK(nolign-1), 3, VALEUR) From SUBACLA_TOOL
  Endcase
 Else
  Call SEL_METHOD([M:ASW0]CODREP, VALEUR) From SUBASW_TOOL
 Endif
End

#--------------- asynchronous operation ---------------#
Subprog AS_WFLGASYLNK(VALEUR)
Variable Integer VALEUR
If [M:ASW7]WTYPLNK(nolign-1)<>3 or [M:ASW7]WMETLNK(nolign-1)=""
 mkstat=1
 End
Endif
End

#--------------- Function ---------------#
Subprog AS_WCODFNCLNK(VALEUR)
Variable Char    VALEUR()
If [M:ASW7]WFLGSTDLNK(nolign-1)=2 : mkstat=2 : End : Endif
If [M:ASW7]WTYPLNK(nolign-1)<>4 : mkstat=1 : End : Endif
End

#--------------- URL ---------------#
Subprog AS_WFREELNK(VALEUR)
Variable Char    VALEUR()
If [M:ASW7]WFLGSTDLNK(nolign-1)=2 : mkstat=2 : End : Endif
If [M:ASW7]WTYPLNK(nolign-1)<>5 : mkstat=1 : End : Endif
End


#--------------- Menu ---------------#
Subprog AS_WMENLNK(VALEUR)
Variable Char    VALEUR()
If !find([M:ASW7]WAFFLNK(nolign-1),4,5) : mkstat=1 : End : Endif
If [M:ASW7]WTARLNK(nolign-1)=3 : mkstat=1 : End : Endif
End

Subprog C_WMENLNK(VALEUR)
Variable Char VALEUR
 If VALEUR <> "" & !find(VALEUR,[M:ASW8]CODMENU)
  GMESSAGE = mess(84,141,1) # Code inexistant
  mkstat = 2 : End
 Endif
End


Subprog S_WMENLNK(VALEUR)
Variable Char    VALEUR()
 Local Integer NBTEX, CHOI,I
 Local Char    TEX(GLONDES)(1..500,1..5) , TIT(GLONDES)(0..5)

 For I=0 To [M:ASW8]NBMENU-1
  NBTEX+= 1
  TEX(NBTEX,1)  = [M:ASW8]CODMENU(I)
  TEX(NBTEX,2)  = [M:ASW8]ZLIBMENU(I)
  TEX(NBTEX,3)  = [M:ASW8]PARMENU(I)
  TEX(NBTEX,4)  = num$([M:ASW8]ORDMENU(I))
  TEX(NBTEX,5)  = [M:ASW8]ACTMENU(I)
 Next

 CHOI = 0
 TIT(0) = mess(22,123,1)-":"-func AMK_TOOL.GET_FIELD_LABEL("ASHW7", "WMENLNK")# Selection : Menu
 TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("ASHW8", "CODMENU")  # Code
 TIT(2) = func AMK_TOOL.GET_FIELD_LABEL("ASHW8", "ZLIBMENU") # Libellé
 TIT(3) = func AMK_TOOL.GET_FIELD_LABEL("ASHW8", "PARMENU")  # Parent
 TIT(4) = func AMK_TOOL.GET_FIELD_LABEL("ASHW8", "ORDMENU")  # Ordre
 TIT(5) = func AMK_TOOL.GET_FIELD_LABEL("ASHW8", "ACTMENU")  # Code activité

 If NBTEX=1
  VALEUR = TEX(1,1)
 Elsif NBTEX>0
  Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
  If status<>7 & CHOI<>0
   VALEUR = TEX(CHOI,1)
  Endif
 Endif
End

Subprog AS_WORDLNK(VALEUR)
Variable Decimal VALEUR
#If !find([M:ASW7]WAFFLNK(nolign-1),4,5) : mkstat=1 : End : Endif
#If [M:ASW7]WMENLNK(nolign-1)="" : mkstat=1 : End : Endif
End

Subprog C_WORDLNK(VALEUR)
Variable Decimal VALEUR
End

#--------------- Attribut ---------------#
Subprog AS_WATTLNK(VALEUR)
Variable Integer    VALEUR()
If [M:ASW7]WFLGSTDLNK(nolign-1)=2 : mkstat=2 : End : Endif
If [M:ASW7]WAFFLNK(nolign-1)<>1 : mkstat=2 : End : Endif
If [M:ASW7]WCMPLNK(nolign-1)<>2 : #Detail
  GMENLOC(2)=1
Endif
If [M:ASW7]WCMPLNK(nolign-1)<>9 : #lookup
  GMENLOC(3)=1
Endif
If [M:ASW7]WCMPLNK(nolign-1)<>10 : #summary
  GMENLOC(4)=1
Endif
End

Subprog C_WATTLNK(VALEUR)
Variable Integer    VALEUR()
 If VALEUR > 1 & VALEUR<>[M:ASW7]WATTLNK(nolign-1)
    Call UNICITE_ATTLNK(nolign-1,VALEUR)
    If mkstat : End : Endif
 Endif
 If VALEUR=2 & [M:ASW7]WCMPLNK(nolign-1)<>2 : #Detail
  mkstat=2
 Elsif VALEUR=3 & [M:ASW7]WCMPLNK(nolign-1)<>9 : #lookup
  mkstat=2
 Elsif VALEUR=4 & [M:ASW7]WCMPLNK(nolign-1)<>10 : #summary
  mkstat=2
 Endif
 If mkstat
  GMESSAGE=func AFNC.MES2(mess(194,143,1), mess([M:ASW7]WCMPLNK(nolign-1),7971,1), mess(VALEUR,7973,1))
  End
 Endif
End

#----------------------------------------
Subprog UNICITE_ATTLNK(NOL,ATTLNK)
Value Integer NOL
Value Integer ATTLNK
Local Integer I

#on ne s'occupe pas des attributs des liens standards
For I=0 To [M:ASW6]NBRLNK-1
  If [M:ASW6]AFFLNK(I)=[M:ASW7]WAFFLNK(NOL) & [M:ASW6]ANCLNK(I)=[M:ASW7]WANCLNK(NOL)
&    & [M:ASW6]ATTLNK(I)=[L]ATTLNK & [M:ASW6]FLGSTDLNK(I)<>2
&    & [M:ASW6]CODLNK(I)<>[M:ASW7]WCODLNK(NOL)
     # L'attribut $1$ est déja indiqué pour le lien "$2$" sur $3$
     GMESSAGE = func AFNC.MES3( mess(190,143,1),mess([L]ATTLNK,7973,1),[M:ASW6]CODLNK(I),mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))
     mkstat=2 : Break
  Endif
Next I
End

#--------------- Replacement ---------------#
Subprog AS_WREMSTDLNK(VALEUR)
Variable Char    VALEUR()
 If [M:ASW7]WFLGSTDLNK(nolign-1)<>2 : mkstat=1 : End : Endif
 If find([M:ASW7]WCMPLNK(nolign-1),17,18,19,20,21,22) : mkstat=1 : End : Endif
 If [M:ASW7]WTARLNK(nolign-1)>1 : mkstat=1 : End : Endif
End

Subprog C_WREMSTDLNK(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif

Local Integer NOL : NOL=nolign-1
Local Integer I
I=find(func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW7]WAFFLNK(NOL),[M:ASW7]WANCLNK(NOL),VALEUR),[M:ASW6]IDENT2)
If I=0
  GMESSAGE = mess(84,141,1) : # Code inexistant
  mkstat=2 : End
Elsif [M:ASW6]FLGSTDLNK(I-1)=2
  # Le lien de remplacement $1$ doit être non standard
  GMESSAGE = func AFNC.MES1(mess(204,143,1),VALEUR)
  mkstat=2 : End
Elsif !(([M:ASW6]TYPLNK(I-1)=[M:ASW7]WTYPLNK(NOL) & [M:ASW6]CMPLNK(I-1)=[M:ASW7]WCMPLNK(NOL))
&      |([M:ASW7]WTYPLNK(NOL)=1 & [M:ASW6]TYPLNK(I-1)=4)
&      |([M:ASW7]WTYPLNK(NOL)=4 & [M:ASW6]TYPLNK(I-1)=1))
  #Le lien de remplacement $1$ doit correspondre aux type et action du lien $2$
  GMESSAGE = func AFNC.MES2(mess(203,143,1),VALEUR,[M:ASW7]WCODLNK(NOL))
  mkstat=2 : End
Elsif [M:ASW6]TARLNK(I-1)=3
  #Le lien $1$ avec une cible $2$ ne peut pas être utilisé comme lien de remplacement
  GMESSAGE = func AFNC.MES2(mess(283,143,1),VALEUR,mess([M:ASW6]TARLNK(I-1),7975,1))
  mkstat=2 : End
Elsif [M:ASW7]WENALNK(NOL)=2 & [M:ASW6]ENALNK(I-1)<>2
  # Le lien de remplacement $1$ doit être actif
  GMESSAGE = func AFNC.MES1(mess(195,143,1),VALEUR)
  mkstat=2 : End
Endif
End

Subprog S_WREMSTDLNK(VALEUR)
Variable Char    VALEUR()
Call SEL_REMSTDLNK_ASW6(VALEUR, nolign-1) From SUBASW_TOOL
End

#--------------- faccettes ---------------#
Subprog AS_WDETLNK(VALEUR)
Variable Integer VALEUR
If [M:ASW7]WFLGSTDLNK(nolign-1)=2 : mkstat=2 : End : Endif
# facette not eligible for method link
If [M:ASW7]WTYPLNK(nolign-1)=2 : mkstat=1: End : Endif
End

Subprog AS_WQRYLNK(VALEUR)
Variable Integer VALEUR
If [M:ASW7]WFLGSTDLNK(nolign-1)=2 : mkstat=2 : End : Endif
# facette not eligible for method link
If [M:ASW7]WTYPLNK(nolign-1)=2 : mkstat=1: End : Endif
#104754/3
If [M:ASW7]WTYPLNK(nolign-1)=6 & [M:ASW7]WAFFLNK(nolign-1)=4 : mkstat=1: End : Endif
End

Subprog AS_WEDILNK(VALEUR)
Variable Integer VALEUR
If [M:ASW7]WFLGSTDLNK(nolign-1)=2 : mkstat=2 : End : Endif
#104754/3
If [M:ASW7]WTYPLNK(nolign-1)=6 : mkstat=1: End : Endif
#Sur Edit, uniquement Rep(1)/9-10 ou methode(2) ou libre(5)
If [M:ASW7]WTYPLNK(nolign-1)=1
  If !find([M:ASW7]WCMPLNK(nolign-1),9,10) | [M:ASW7]WTARLNK(nolign-1)>1
    mkstat=1: End
  Endif
  If [M:ASW7]WCMPLNK(nolign-1)=9
    #si prop clé de la classe principale, pas de lookup
    If func SUBASW_TOOL.IS_CLA_KEY([M:ASW7]WANCLNK(nolign-1),func SUBASW_TOOL.GET_TYP_FROM_PRO_PATH_SCREEN([M:ASW7]WANCLNK(nolign-1)),[M:ASW1]CODCLA,[M:ASW1]ABRCLA)
      mkstat=1: End
    Endif
  Endif
Elsif !find([M:ASW7]WTYPLNK(nolign-1),2,5) | [M:ASW7]WTARLNK(nolign-1)>1
  # facette not eligible for operation,convergence link
  mkstat=1: End
Endif
End

Subprog AS_WLOKLNK(VALEUR)
Variable Integer VALEUR
If [M:ASW7]WFLGSTDLNK(nolign-1)=2 : mkstat=2 : End : Endif
#104754/3
If [M:ASW7]WTYPLNK(nolign-1)=6 : mkstat=1: End : Endif
# facette not eligible for method link
If [M:ASW7]WTYPLNK(nolign-1)=2 : mkstat=1: End : Endif
# facette not eligible for Convergence X3
If [M:ASW7]WTYPLNK(nolign-1)=4 : mkstat=1: End : Endif
# facette not eligible for having a target
If [M:ASW7]WTARLNK(nolign-1)>1 : mkstat=1: End : Endif
End

Subprog AS_WSUMLNK(VALEUR)
Variable Integer VALEUR
If [M:ASW7]WFLGSTDLNK(nolign-1)=2 : mkstat=2 : End : Endif
#104754/3
If [M:ASW7]WTYPLNK(nolign-1)=6 : mkstat=1: End : Endif
# facette not eligible for method link
If [M:ASW7]WTYPLNK(nolign-1)=2 : mkstat=1: End : Endif
# facette not eligible for Convergence X3
If [M:ASW7]WTYPLNK(nolign-1)=4 : mkstat=1: End : Endif
End


###################################################################
#--------------------------- Tab "Menu"  -------------------------#
###################################################################


#--------------- Menu code ---------------#
Subprog C_CODMENU(VALEUR)
Variable Char    VALEUR()
 # unique check
 Call UNICITE(VALEUR,[M:ASW8]CODMENU(0..[M:ASW8]NBMENU-1)) From OBJDIV
 If find(VALEUR,[M:ASW6]CODLNK)
    GMESSAGE=mess(228,143,1)
    mkstat=2
    End
 Endif
End


#--------------- Parent menu ---------------#
Subprog C_PARMENU(VALEUR)
Variable Char    VALEUR()
Local Char WPARENT(GLONAVA),WMENU(GLONAVA)
Local Integer I
 WPARENT=VALEUR
 WMENU=[M:ASW8]CODMENU(nolign-1)
 While WPARENT<>""
  If WPARENT=WMENU
    #Code parent "$1$" non autorisé pour le menu "$2$"
    GMESSAGE=func AFNC.MES2(mess(226,143,1), WPARENT, WMENU)
    mkstat=2
    End
  Endif
  I=find(WPARENT,[M:ASW8]CODMENU)
  If I=0
   GMESSAGE=func AFNC.MES2(mess(226,143,1), WPARENT, WMENU)
   mkstat=2
   Break
  Elsif [M:ASW8]PARMENU(I-1)=[M:ASW8]CODMENU(nolign-1)
   GMESSAGE=func AFNC.MES2(mess(226,143,1), VALEUR, [M:ASW8]CODMENU(nolign-1))
   mkstat=2
   Break
  Endif
  WPARENT=[M:ASW8]PARMENU(I-1)
  WMENU=[M:ASW8]CODMENU(I-1)
 Wend
End

Subprog S_PARMENU(VALEUR)
Variable Char    VALEUR()
 Local Integer NBTEX, CHOI,I
 Local Char    TEX(GLONAVA)(1..500,1..1) , TIT(GLONDES)(0..1) , CRITERE(250)

 For I=0 To [M:ASW8]NBMENU-1
  If I<>nolign-1
   NBTEX+= 1
   TEX(NBTEX,1)  = [M:ASW8]CODMENU(I)
  Endif
 Next

 CHOI = 0
 TIT(0) = mess(22,123,1) # Selection
 TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("ASHW7", "WMENLNK") # Menu

 If NBTEX=1
  VALEUR = TEX(1,1)
 Elsif NBTEX>0
  Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
  If status<>7 & CHOI<>0
   VALEUR = TEX(CHOI,1)
  Endif
 Endif
End


#------------ default Menu/link code for facette -------------#
Subprog AS_LNKMENFAC(VALEUR)
Variable Char    VALEUR()
If [M:ASW8]DEFLNKFAC(nolign-1)=2
  If VALEUR<>""
  Effzo [M:ASW8]ACTLNKFAC(nolign-1)
  Effzo [M:ASW8]LIBLNKMEN(nolign-1)
  [M:ASW8]AFFLNKFAC(nolign-1)=0
  Effzo [M:ASW8]LIBAFFLNK(nolign-1)
  mkstat=1
  Else
  mkstat=2
  Endif
Endif
End

Subprog S_LNKMENFAC(VALEUR)
Variable Char    VALEUR()
 Local Integer NBTEX, CHOI,I,OK_LNK
 Local Char    TEX(GLONAVB)(1..500,1..5) , TIT(GLONDES)(0..5) , CRITERE(250)

 For I=0 To [M:ASW6]NBRLNK-1
  # verif lien OK
  OK_LNK=func IS_LNKMENFAC_OK(nolign,I)

  If OK_LNK
   NBTEX+= 1
   TEX(NBTEX,1)  = mess(186,100,1) # Lien
   TEX(NBTEX,2)  = [M:ASW6]CODLNK(I)
   TEX(NBTEX,3)  = [M:ASW6]INTITLNK(I)
   TEX(NBTEX,4)  = mess([M:ASW6]AFFLNK(I),7965,1)
   TEX(NBTEX,5)  = num$([M:ASW6]AFFLNK(I))
  Endif
 Next I

 For I=0 To [M:ASW8]NBMENU-1
  If [M:ASW8]PARMENU(I)=""
   NBTEX+= 1
   TEX(NBTEX,1)  = func AMK_TOOL.GET_FIELD_LABEL("ASHW7", "WMENLNK") # Menu
   TEX(NBTEX,2)  = [M:ASW8]CODMENU(I)
   TEX(NBTEX,3)  = [M:ASW8]ZLIBMENU(I)
   TEX(NBTEX,4)  = [M:ASW8]PARMENU(I)
   TEX(NBTEX,5)  = ""
  Endif
 Next

 CHOI = 0
 TIT(0) = mess(22,123,1) # Sélection
 TIT(1) = mess(186,100,1)+"/"+func AMK_TOOL.GET_FIELD_LABEL("ASHW8", "LNKMENFAC") # Lien/Menu
 TIT(2) = func AMK_TOOL.GET_FIELD_LABEL("ASHW8", "CODMENU")  # Code
 TIT(3) = func AMK_TOOL.GET_FIELD_LABEL("ASHW8", "ZLIBMENU") # Libellé
 TIT(4) = ""
 TIT(5) = ""

 Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
 If status<>7 & CHOI<>0
  VALEUR = TEX(CHOI,2)
  [M:ASW8]AFFLNKFAC(nolign-1)=val(TEX(CHOI,5))
  If [M:ASW8]AFFLNKFAC(nolign-1)=0
   Effzo [M:ASW8]LIBAFFLNK(nolign-1)
  Else
   [M:ASW8]LIBAFFLNK(nolign-1)=mess([M:ASW8]AFFLNKFAC(nolign-1),7965,1)
   Affzo [M:ASW8]LIBAFFLNK(nolign-1)
  Endif
 Endif
End

Funprog IS_LNKMENFAC_OK(NOFAC,NOLASW6)
Value Integer NOFAC,NOLASW6
Local Integer OK_LNK,J
  OK_LNK=0
  # verif facette du lien OK
  If NOFAC=1 & [M:ASW6]DETLNK(NOLASW6)=2 : OK_LNK=1 : Endif
  If NOFAC=2 & [M:ASW6]EDILNK(NOLASW6)=2 : OK_LNK=1 : Endif
  If NOFAC=3 & [M:ASW6]QRYLNK(NOLASW6)=2 : OK_LNK=1 : Endif
  If NOFAC=4 & [M:ASW6]LOKLNK(NOLASW6)=2 : OK_LNK=1 : Endif
  If NOFAC=5 & [M:ASW6]SUMLNK(NOLASW6)=2 : OK_LNK=1 : Endif

  If OK_LNK
   If [M:ASW6]ENALNK(NOLASW6)<>2 : OK_LNK=0
   # Page ou Fiche/Enregistrement sur Detail/Edit/Summary
   Elsif !([M:ASW6]AFFLNK(NOLASW6)=4 |([M:ASW6]AFFLNK(NOLASW6) = 5 & find(NOFAC,1,2,5))) : OK_LNK=0
   # sans menu
   Elsif [M:ASW6]MENLNK(NOLASW6)<>"" : OK_LNK=0
   Elsif [M:ASW6]TARLNK(NOLASW6)=3 : OK_LNK=0
   Elsif [M:ASW6]FLGSTDLNK(NOLASW6)<>2
    #pas lien de remplacement
    For J=0 To [M:ASW6]NBRLNK-1
     If [M:ASW6]AFFLNK(NOLASW6)=[M:ASW6]AFFLNK(J) & [M:ASW6]REMSTDLNK(J)=[M:ASW6]CODLNK(NOLASW6)
      OK_LNK=0
      Break
     Endif
    Next J
   Endif
  Endif
End OK_LNK


Subprog C_LNKMENFAC(VALEUR)
Variable Char    VALEUR()
Local Integer RES_OK, I,J,OK_LNK
If VALEUR <> ""
  # Check if it's a Menu
  I = find(VALEUR, [M:ASW8]CODMENU)
  If I>0 & [M:ASW8]PARMENU(I-1)=""
   RES_OK = 1
   [M:ASW8]LIBLNKMEN(nolign-1) = [M:ASW8]ZLIBMENU(I-1)
   [M:ASW8]AFFLNKFAC(nolign-1)=0
   Effzo [M:ASW8]LIBAFFLNK(nolign-1)
   End
  Endif
  If !RES_OK & I=0
   # Check if it's a Page link
   If [M:ASW8]AFFLNKFAC(nolign-1)<>0
     J = find(func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW8]AFFLNKFAC(nolign-1),"",VALEUR),[M:ASW6]IDENT2)
     If J>0
      OK_LNK=func IS_LNKMENFAC_OK(nolign,J-1)
      If OK_LNK
       I=J
      Endif
     Endif
   Endif
   If I=0
    For J=0 To [M:ASW6]NBRLNK-1
     If [M:ASW6]CODLNK(J)=VALEUR
      # verif lien OK
      OK_LNK=func IS_LNKMENFAC_OK(nolign,J)
      If OK_LNK
       I=J+1
       Break
      Endif
     Endif
    Next J
   Endif
   If OK_LNK & I>0
     RES_OK = 1
     [M:ASW8]LIBLNKMEN(nolign-1)=[M:ASW6]INTITLNK(I-1)
     [M:ASW8]AFFLNKFAC(nolign-1)=[M:ASW6]AFFLNK(I-1)
     [M:ASW8]LIBAFFLNK(nolign-1)=mess([M:ASW8]AFFLNKFAC(nolign-1),7965,1)
   Endif
  Endif

  If !RES_OK
   GMESSAGE = mess(227,143,1) :# Il faut indiquer un code lien valide pour la facette ou un code menu
   mkstat = 2 : End
  Endif
Else
  Effzo [M:ASW8]ACTLNKFAC(nolign-1)
  Effzo [M:ASW8]LIBLNKMEN(nolign-1)
  [M:ASW8]AFFLNKFAC(nolign-1)=0
  Effzo [M:ASW8]LIBAFFLNK(nolign-1)
Endif
End


#--------------- Facette ---------------#
Subprog C_FACCETTE(VALEUR)
Variable Integer VALEUR
# # unique check
# Call UNICITE(VALEUR,[M:ASW8]FACCETTE(0..[M:ASW8]NBCONFIG-1)) From OBJDIV
End

Subprog AS_ACTLNKFAC(VALEUR)
Variable Char    VALEUR()
If [M:ASW8]LNKMENFAC(nolign-1)=""
 If VALEUR=""
   mkstat=2
 Else
   mkstat=1
 Endif
Endif
End

###################################################################
#-------------------- other subprog/funprog  ---------------------#
###################################################################

# build the field TYPLNKCUR
Funprog L_BUILD_TYPLNKCUR(CODLNK,TYPLNK,REPLNK,CMPLNK,CLAPTRLNK,CLALNK,METLNK,FNCLNK,RPTCOD)
Value Char CODLNK
Value Integer TYPLNK
Value Char REPLNK
Value Integer CMPLNK
Value Char CLAPTRLNK,CLALNK,METLNK,FNCLNK
 Local Char RES_TYPLNKCUR(250)
 RES_TYPLNKCUR = CODLNK+"~"+num$(TYPLNK)+"~"+REPLNK+"~"+num$(CMPLNK)+"~"+CLAPTRLNK+"~"+CLALNK+"~"+METLNK+"~"+FNCLNK+"~"+RPTCOD
End RES_TYPLNKCUR




