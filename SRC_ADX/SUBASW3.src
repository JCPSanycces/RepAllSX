#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Gestion du masque ASHW7
######################################################################################
## ASW7 : Liens
######################################################################################
$ASW7
Return



###################################################################
#------------------------- block "Selection" ---------------------#
###################################################################

######################################################################################
Subprog AS_TYPANCLNK(VALEUR)
Variable Integer VALEUR
GMENLOC(3)=1 : #Type ancre=Collection
End


#--------- Anchor type ---------#
Subprog AM_TYPANCLNK(VALEUR)
Variable Integer VALEUR
 Effzo [M:ASW7]CODANCLNK
 If !find(VALEUR,1,2,3)
  Diszo [M:ASW7]CODANCLNK
 Else
  Actzo [M:ASW7]CODANCLNK
 Endif
 # display link table
 Call DISPLAY_LNK_ASW7(1,VALEUR, [M:ASW7]CODANCLNK,[M:ASW7]OPTSTDLNK,[M:ASW7]OPTINVLNK) From SUBASW_TOOL
End


#--------- Anchor code ---------#
Subprog C_CODANCLNK(VALEUR)
Variable Char    VALEUR()
VALEUR=toupper(VALEUR)
 Case [M:ASW7]TYPANCLNK
  When 1:
   If !find(VALEUR, [M:ASW4]CODPRO)
    GMESSAGE = mess(170,143,1) : # Veuillez indiquer une propriété exposée
    mkstat = 2 : End
   Endif
  When 2,3:
   If !find(VALEUR, [M:ASW1]CODCOL)
    GMESSAGE = mess(144,143,1) : #  Collection inexistante
    mkstat = 2 : End
   Endif
 Endcase
End

Subprog AM_CODANCLNK(VALEUR)
Variable Char    VALEUR()
 # display link table
 Call DISPLAY_LNK_ASW7(1,[M:ASW7]TYPANCLNK, VALEUR,[M:ASW7]OPTSTDLNK,[M:ASW7]OPTINVLNK) From SUBASW_TOOL
End

Subprog S_CODANCLNK(VALEUR)
Variable Char    VALEUR()
 Case [M:ASW7]TYPANCLNK
  When 1: Call SEL_EXPRO_ASW4(VALEUR,0) From SUBASW_TOOL
  When 2: Call SEL_COL_ASW1(VALEUR, 2) From SUBASW_TOOL
  When 3: Call SEL_COL_ASW1(VALEUR, 3) From SUBASW_TOOL
 Endcase
End


#--------- Option "Display the std links" ---------#
Subprog AM_OPTSTDLNK(VALEUR)
Variable Integer VALEUR
 # display link table
 Call DISPLAY_LNK_ASW7(1,[M:ASW7]TYPANCLNK, [M:ASW7]CODANCLNK,VALEUR,[M:ASW7]OPTINVLNK) From SUBASW_TOOL
End

Subprog AM_OPTINVLNK(VALEUR)
Variable Integer VALEUR
# display link table
Call DISPLAY_LNK_ASW7(1,[M:ASW7]TYPANCLNK, [M:ASW7]CODANCLNK,[M:ASW7]OPTSTDLNK,VALEUR) From SUBASW_TOOL
End


###################################################################
#---------------------- block "Parameters" -----------------------#
###################################################################

Subprog APRES_NBRPARLNK
#----- Si touche "Echap" ou autre statut "Abandon" -----#
If status=6 | status=7 | status=27 | status=28 | status=1792
  End
#----- Si suppression ligne -----#
Elsif status=65 | status=68 | status=83
  End
Endif
 Local Integer I,J
 I=find(func SUBASW_TOOL.BUILD_ASW5_IDENT2(3,[M:ASW7]AFFLNKCUR,1,[M:ASW7]CODLNKCUR,[M:ASW7]ANCLNKCUR,[M:ASW7]CODPARLNK(nolign-1)),[M:ASW5]IDENT2)
 If I>0
   [M:ASW5]VALEUR(I-1) = [M:ASW7]VALPARLNK(nolign-1) : Affzo [M:ASW5]VALEUR(I-1)
   [M:ASW5]NOLIB(I-1) = [M:ASW7]MNLPARLNK(nolign-1) : Affzo [M:ASW5]NOLIB(I-1)
   [M:ASW5]LNG(I-1) = [M:ASW7]LNGPARLNK(nolign-1) : Affzo [M:ASW5]LNG(I-1)
   [M:ASW5]TYPAFF(I-1) = [M:ASW7]AFFPARLNK(nolign-1) : Affzo [M:ASW5]TYPAFF(I-1)
   #104754/3
   J=find(func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW7]AFFLNKCUR,[M:ASW7]ANCLNKCUR,[M:ASW7]CODLNKCUR),[M:ASW6]IDENT2)
   If J>0
    If [M:ASW6]TYPLNK(J-1)=6
      [M:ASW5]VALEUR(I-1) = [M:ASW7]VALPARDEBLNK(nolign-1) : Affzo [M:ASW5]VALEUR(I-1)
      I=find(func SUBASW_TOOL.BUILD_ASW5_IDENT2(3,[M:ASW7]AFFLNKCUR,3,[M:ASW7]CODLNKCUR,[M:ASW7]ANCLNKCUR,[M:ASW7]CODPARLNK(nolign-1)),[M:ASW5]IDENT2)
      If I>0
       [M:ASW5]VALEUR(I-1) = [M:ASW7]VALPARFINLNK(nolign-1) : Affzo [M:ASW5]VALEUR(I-1)
       [M:ASW5]NOLIB(I-1) = [M:ASW7]MNLPARLNK(nolign-1) : Affzo [M:ASW5]NOLIB(I-1)
       [M:ASW5]LNG(I-1) = [M:ASW7]LNGPARLNK(nolign-1) : Affzo [M:ASW5]LNG(I-1)
       [M:ASW5]TYPAFF(I-1) = [M:ASW7]AFFPARLNK(nolign-1) : Affzo [M:ASW5]TYPAFF(I-1)
      Endif
    Endif
   Endif
 Endif
End


#----------------- input ------------------#
Subprog AS_AFFPARLNK(VALEUR)
Variable Integer VALEUR
Local Integer I
I=find(func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW7]AFFLNKCUR,[M:ASW7]ANCLNKCUR,[M:ASW7]CODLNKCUR),[M:ASW6]IDENT2)
If I>0
  If [M:ASW6]TYPLNK(I-1)=4 | [M:ASW6]TYPLNK(I-1)=3 | [M:ASW6]CMPLNK(I-1)=19
    mkstat=2
    End
  Endif
Endif
If [M:ASW7]PARFILLNK(nolign-1)=2 | [M:ASW7]PARENTLNK(nolign-1)=2
  mkstat=2
  End
Endif
End

Subprog C_AFFPARLNK(VALEUR)
Variable Integer VALEUR
End

Subprog AM_AFFPARLNK(VALEUR)
Variable Integer VALEUR
Gosub AM_ASWP_INVLNK From SUBASW_TOOL
End

#----------------- paremeter local menu number ------------------#
Subprog AS_MNLPARLNK(VALEUR)
Variable Decimal VALEUR
If [M]TYPPARLNK(nolign-1)<> 1  or [M]AFFPARLNK(nolign-1)<>2: mkstat=1 : End : Endif
Local Integer I
I=find(func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW7]AFFLNKCUR,[M:ASW7]ANCLNKCUR,[M:ASW7]CODLNKCUR),[M:ASW6]IDENT2)
If I>0
  If [M:ASW6]TYPLNK(I-1)=4 | [M:ASW6]TYPLNK(I-1)=3
    mkstat=1
    End
  Elsif [M:ASW6]CMPLNK(I-1)=19
    mkstat=2
    End
  Endif
Endif
End

Subprog C_MNLPARLNK(VALEUR)
Variable Decimal VALEUR
End

Subprog AM_MNLPARLNK(VALEUR)
Variable Decimal VALEUR
Gosub AM_ASWP_INVLNK From SUBASW_TOOL
End


#----------------- paremeter lenth ------------------#
Subprog AS_LNGPARLNK(VALEUR)
Variable Decimal VALEUR
If !find([M:ASW7]TYPPARLNK(nolign-1),1,2,3,4,5,6) or [M]AFFPARLNK(nolign-1)<>2: mkstat=1 : End : Endif
Local Integer I
I=find(func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW7]AFFLNKCUR,[M:ASW7]ANCLNKCUR,[M:ASW7]CODLNKCUR),[M:ASW6]IDENT2)
If I>0
  If [M:ASW6]TYPLNK(I-1)=4 | [M:ASW6]TYPLNK(I-1)=3
    mkstat=1
    End
  Elsif [M:ASW6]CMPLNK(I-1)=19
    mkstat=2
    End
  Endif
Endif
End

Subprog C_LNGPARLNK(VALEUR)
Variable Decimal VALEUR
End

Subprog AM_LNGPARLNK(VALEUR)
Variable Decimal VALEUR
Gosub AM_ASWP_INVLNK From SUBASW_TOOL
End


#----------------- paremeter value ------------------#
Subprog AS_VALPARLNK(VALEUR)
Variable Char    VALEUR()
Local Integer I
I=find(func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW7]AFFLNKCUR,[M:ASW7]ANCLNKCUR,[M:ASW7]CODLNKCUR),[M:ASW6]IDENT2)
If I>0
  #104754/3
  If find([M:ASW6]CMPLNK(I-1),19,20,21)>0
    mkstat=2
    End
  Endif
Endif
End

Subprog C_VALPARLNK(VALEUR)
Variable Char    VALEUR()
 Local Char L_ERR_MSG(250),L_PARCOL(GLONAVC)
 Case [M:ASW7]AFFLNKCUR
   When 1: #property
    L_PARCOL = func SUBASW_TOOL.GET_COL_FROM_PRO_PATH_SCREEN([M:ASW7]ANCLNKCUR,1)
   When 2: #collection line
    L_PARCOL = [M:ASW7]ANCLNKCUR
 Endcase

 Local Integer I,J
 Local Char PARACT(GLONACV)
 I=find(func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW7]AFFLNKCUR,[M:ASW7]ANCLNKCUR,[M:ASW7]CODLNKCUR),[M:ASW6]IDENT2)

 If [M:ASW7]AFFLNKCUR=1
  For J=0 To [M:ASW4]NBRPRO-1
   If [M:ASW4]CODPRO(J)=[M:ASW7]ANCLNKCUR
    If func AFNC.ACTIV([M:ASW6]ACVLNK(I-1))
     PARACT=[M:ASW4]ACTPRO(J)
    Else
     PARACT=[M:ASW6]ACVLNK(I-1)
    Endif
    If !func SUBASW_TOOL.L_CHECK_PARAMETER([M:ASW6]ANCLNK(I-1),"",[M:ASW7]CODPARLNK(nolign-1),PARACT,[L]VALEUR, [M:ASW7]TYPPARLNK(nolign-1), [M:ASW7]MODPARLNK(nolign-1), L_PARCOL,
&      [M:ASW0]CODREP, 1, 1, [M:ASW6]CMPLNK(I-1),
&      [M:ASW6]DETLNK(I-1),[M:ASW6]QRYLNK(I-1),[M:ASW6]EDILNK(I-1),[M:ASW6]LOKLNK(I-1),[M:ASW6]SUMLNK(I-1),
&      max([M:ASW7]AFFPARLNK(nolign-1),[M:ASW7]PARFILLNK(nolign-1),[M:ASW7]PARENTLNK(nolign-1)), L_ERR_MSG)
     GMESSAGE = L_ERR_MSG
     mkstat = 2
    Endif
   Endif
  Next
 Else
  If !func SUBASW_TOOL.L_CHECK_PARAMETER([M:ASW6]ANCLNK(I-1),"",[M:ASW7]CODPARLNK(nolign-1),[M:ASW6]ACVLNK(I-1),[L]VALEUR, [M:ASW7]TYPPARLNK(nolign-1), [M:ASW7]MODPARLNK(nolign-1), L_PARCOL,
&    [M:ASW0]CODREP, 1, 1, [M:ASW6]CMPLNK(I-1),
&    [M:ASW6]DETLNK(I-1),[M:ASW6]QRYLNK(I-1),[M:ASW6]EDILNK(I-1),[M:ASW6]LOKLNK(I-1),[M:ASW6]SUMLNK(I-1),
&    max([M:ASW7]AFFPARLNK(nolign-1),[M:ASW7]PARFILLNK(nolign-1),[M:ASW7]PARENTLNK(nolign-1)), L_ERR_MSG)
   GMESSAGE = L_ERR_MSG
   mkstat = 2
  Endif
 Endif
End

Subprog S_VALPARLNK(VALEUR)
Variable Char    VALEUR()
 Call SEL_EXPRO_ASW4(VALEUR,0) From SUBASW_TOOL
End


Subprog AM_VALPARLNK(VALEUR)
Variable Char    VALEUR()
Gosub AM_ASWP_INVLNK From SUBASW_TOOL
End

