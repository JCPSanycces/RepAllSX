#<AdxTL>@(#)12.0.0.0 $Revision$
###########################################################
## Programme de gestion des postes de charge             ##
###########################################################
## écrit en juillet 1998 par LLC                         ##
###########################################################
$ACTION

Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "FERME"        : Gosub FERME
 When "STATUT"       : Gosub STATUT
 When "SETBOUT"      : Gosub SETBOUT
 When "AVANTBOUT"    : Gosub AVANTBOUT
 When "EXEBOUT"      : Gosub EXEBOUT
 When "RAZDUP"       : Gosub RAZDUP
 When "RAZCRE"       : Gosub RAZCRE
 When "LIENS"        : Gosub LIENS
                       Gosub LIENS        From SUBMWS2
                       Gosub LIENS        From SUBMWS3
 When "CREATION"     : Gosub CREATION
                       Gosub CREATION     From SUBMWS2
                       Gosub CREATION     From SUBMWS3
 When "MODIF"        : Gosub MODIF
                       Gosub MODIF        From SUBMWS2
                       Gosub MODIF        From SUBMWS3
 When "ANNULE"       : Gosub ANNULE
                       Gosub ANNULE       From SUBMWS2
                       Gosub ANNULE       From SUBMWS3
 When "VERIF_MOD"    : Gosub VERIF_MOD
                       Gosub VERIF_MOD    From SUBMWS2
                       Gosub VERIF_MOD    From SUBMWS3
 When "ABANDON"      : Gosub ABANDON      From SUBMWS2

 When Default
Endcase
Return

###########################################################
$OUVRE
# llc 12.01 10124
Local Char     WFCY(GLONFCY)
Local Date     CUTSTRDAT
Local Integer  HORIZ, WOK, WJAL                # llc 11.02 16478
#Local Char     WWSTD, WWSTF  Plus utilisé

# classes ouvertes pour postes remplacement (TB - Sept 99)
# 08.07 42165 Ajout des clalev sur MWS2,TWC2,AMZ
If clalev([F:MWS2])=0 : Local File WORKSTATIO [MWS2] : Endif
If clalev([F:TWC2])=0 : Local File TABWRKCTR  [TWC2] : Endif
If clalev([F:AMZ])=0  : Local File AMSKZON    [AMZ]  : Endif

# 15158 08.02 MM
If clalev([F:OPS])=0 : Local File OPERATIONS [OPS] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:ROT])=0 : Local File ROUOPESTD  [ROT] : Endif               # llc 02.03 17367
If clalev([F:WKL])=0 : Local File WORKLOAD   [WKL] : Endif               # graphe en flash

#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
Return

###########################################################
$FERME
#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
#-----
Return

###########################################################
$RAZCRE
Call RAZ_CLOB From ACLOB
Return

###########################################################
$RAZDUP
Local Integer I, WRET
Call RAZ_CLOB From ACLOB

For I=0 To [M:MWS2]NBLIG-1
    Call DUP_CLOB("CPV",[M:MWS2]VARTEX(I),WRET) From TRTX3TEX
    If WRET<1 Raz [M:MWS2]VARTEX(I) : Endif
Next


# remise à zéro des cumuls  (04/02/00)  TB
If !GIMPORT
  Effzo [M:MWS1]EXTHOUTIM
  Effzo [M:MWS1]CPLHOUTIM
Endif
Effzo [M:MWS3]
[M:MWS3]NBLIG = 0
Affzo [M:MWS3]
Return


###########################################################################
## Modification des lignes llc 02.03 17367
#########################################################################
$MODIF
# première boucle sur poste principal
For [ROT]ROT0 Where [F:ROT]FCY = [M:MWS0]WCRFCY & [F:ROT]WST = [M:MWS0]WST
    Readlock [ROT] Curr
    If !fstat
        [F:ROT]WCR = [M:MWS0]WCR
        Rewrite [ROT]
    Endif
Next

# première boucle sur poste principal
For [ROT]ROT0 Where [F:ROT]FCY = [M:MWS0]WCRFCY & [F:ROT]LABWST = [M:MWS0]WST
    Readlock [ROT] Curr
    If !fstat
        [F:ROT]LABWCR = [M:MWS0]WCR
        Rewrite [ROT]
    Endif
Next

# dernière boucle sur poste STR
For [ROT]ROT0 Where [F:ROT]FCY = [M:MWS0]WCRFCY & [F:ROT]SCOWST = [M:MWS0]WST
    Readlock [ROT] Curr
    If !fstat
        [F:ROT]SCOWCR = [M:MWS0]WCR
        Rewrite [ROT]
    Endif
Next
#---CPO gestion des libéllés traduisibles
Call MAJTEXTRA([M:MWS0]WSTDESAXX,"WORKSTATIO","WSTDESAXX",[M:MWS0]WST,[M:MWS0]WCRFCY) From ATEXTRA
Call MAJTEXTRA([M:MWS0]WSTSHOAXX,"WORKSTATIO","WSTSHOAXX",[M:MWS0]WST,[M:MWS0]WCRFCY) From ATEXTRA

Return

###########################################################
$LIENS
Read [F:TWC]TWC0 = [M:MWS0]WCR
#---CPO Cause libéllé traduisible : Géré par le type de données (Lien long)
#If !fstat : [M:MWS0]WCRDES = [F:TWC]WCRDES : Endif
If fstat : Raz [F:TWC] : Endif

# llc 07.01  9728 (sous-traitance)
Case [M:MWS0]WSTTYP
    When 1
      [M:MWS1]LOCCAT = 1
      Actzo [M:MWS1]RUNBRKFLG #114791.n
    When 2
      [M:MWS1]LOCCAT = 1
      Grizo [M:MWS1]RUNBRKFLG #114791.n
    When 3
      [M:MWS1]LOCCAT = 4
      Grizo [M:MWS1]RUNBRKFLG #114791.n
Endcase

# MM 08.02
# Issue X3-22755 - 2017-02-20 by ALSHE : Hide iLog fields
If dim([M:MWS1]GRPHOR)>0 & dim([M:MWS1]GRPFLG)>0 & dim([M:MWS1]JOURS1)>0
    [M:MWS1]JOURS1 = mess(1,635,1)
    If [M:MWS1]GRPFLG =1 : [M:MWS1]GRPHOR=0 : Grizo [M:MWS1]GRPHOR
    Else Actzo [M:MWS1]GRPHOR
    Endif
		If !find([M:MWS1]GRPFLG,1,2)     : [M:MWS1]GRPFLG     = 1 : Endif    # llc 02.03 regroupement
Endif
If !find([M:MWS1]CONSTRAINT,1,2) : [M:MWS1]CONSTRAINT = 1 : Endif    # llc 02.03 regroupement

# 10.05 charge en flash
Local Integer I : I = 0

Filter [WKL] Where MFGFCY=[M:MWS0]WCRFCY & WST=[M:MWS0]WST
&            Order By Key WKL0

[M:MWS4]NBLIGC = 0
For [WKL]
    If I >= 100 : Break : Endif
    [M:MWS4]PERSTR(I) = [F:WKL]PERSTR
    [M:MWS4]PEREND(I) = [F:WKL]PEREND
    [M:MWS4]PERAVA(I) = [F:WKL]PERAVA
    [M:MWS4]OWFLOD(I) = [F:WKL]OWFLOD
    [M:MWS4]OWPLOD(I) = [F:WKL]OWPLOD
    [M:MWS4]OWSLOD(I) = [F:WKL]OWSLOD
    [M:MWS4]ORSLOD(I) = [F:WKL]ORSLOD
    [M:MWS4]PERTXT(I) = format$("D:"+GFMDAT4,[F:WKL]PEREND)

    I += 1
Next
[M:MWS4]NBLIGC = I
Filter [WKL]

Return

$CHARG_LIB
Read [AMZ] CODE="MWS1";GBIDC3 : If fstat Raz [F:AMZ] : Endif
Call TEXTE([F:AMZ]INTIT,GBIDC3) From OBJDIV
Return


###########################################################
$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET

If !CLECUR | GREP <> ""
    Call VIREBOUT(CHAINE,"1") From GOBJET
Endif
#consultation de l'Encours charge tjs active
# modification capacité tjs active
CHMEN += "EV"

#Recalcul de la charge actif que si clé courante et pas en modif
If CLECUR & GREP = ""
   CHMEN += "R"
Endif
Return


###########################################################################################
#    Avant l'execution des boutons et des menus                                           #
###########################################################################################
$AVANTBOUT

Local Char     WFONC1(30)
Local Char     WTYP(4), WTEX(12), WANCTEX(12), SYMBOLE2(20)
Local Integer  WCOD
Local Integer  WMODULE    :    WMODULE = 8

GERR=0
# Pour etre sur qu'il soit bien chargé
GFCY=[M]WCRFCY
Case BOUT
    When "1" :      OK=1
                    If !GIMPORT
                        Call OUINON(mess(134,190,1),OK) From GESECRAN
                    Endif
                    If OK=1: OK = 0 : GERR = 1 : GMESSAGE= "" : Return : Endif
                    Call TEMPON(mess(134,195,1)) From GESECRAN
                    Call OUVRE_TRACE(mess(134,195,1)) From LECFIC
                    Call ECR_TRACE(" ",0) From GESECRAN
                    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
                    Call PRTSCR("MWS0","MWS0","",0,1) From ATRTX3
                    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
                    Call ECR_TRACE(" ",0) From GESECRAN
    When "E" :
    When "V" :
    When "R" :      OK=1
                    If !GIMPORT
                         Call OUINON(mess(160,190,1),OK) From GESECRAN
                    Endif
                    If OK=1 : OK = 0 : GERR = 1 : GMESSAGE= "" : Return : Endif
                    Call TEMPON(mess(134,195,1)) From GESECRAN
                    Call OUVRE_TRACE(mess(134,195,1)) From LECFIC
                    Call ECR_TRACE(" ",0) From GESECRAN
                    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
                    Call PRTSCR("MWS0","MWS0","",0,1) From ATRTX3
                    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
                    Call ECR_TRACE(" ",0) From GESECRAN

Endcase
Return


###########################################################################################
$STATUT
#---------------------------------#
# Après choix dans menus spéciaux #
#---------------------------------#
Case BOUT
    When "R" :          Call FERME_TRACE From LECFIC
                        Call TEMPOFF From GESECRAN
                        Call LEC_TRACE   From LECFIC
    When Default  :
Endcase
Return


###########################################################
# après éxécution du bouton
$EXEBOUT
Case BOUT
        When "1" : # Rejalonner
                   Gosub RELIT From GOBJSUB         # FQ 53566 GA 11/2009
                   Call FERME_TRACE From LECFIC
                   Call TEMPOFF From GESECRAN
                   Call LEC_TRACE   From LECFIC
Endcase
Return

########################################################################
# llc 11.03 19248
$VERIF_MOD
Local Integer I
Local Integer WMODCAP : WMODCAP = 0
# si les données impactant la capacité ont changé, message
If ([F:MWS]WST <> [M:MWS0]WST) | ([F:MWS]WCRFCY <> [M:MWS0]WCRFCY)
    Read [MWS]WST0=[M:MWS0]WST;[M:MWS0]WCRFCY
    If fstat : Return : Endif
Endif
If [F:MWS]TWD <> [M:MWS1]TWD         : WMODCAP = 1 : Goto FIN_VMOD : Endif
If [F:MWS]WSTNBR <> [M:MWS1]WSTNBR   : WMODCAP = 1 : Goto FIN_VMOD : Endif
If ([F:CPV]WST <> [M:MWS0]WST) | ([F:CPV]WCRFCY <> [M:MWS0]WCRFCY)
    Read [CPV]CPV0=[M:MWS0]WST;[M:MWS0]WCRFCY
    If fstat : Return : Endif
Endif
For I = 0 To 24
    If [F:CPV]STRDAT(I) <> [0/0/0] & I >= [M:MWS2]NBLIG : WMODCAP  = 1 : Break : Endif
    If [F:CPV]STRDAT(I) <> [M:MWS2]STRDAT(I)            : WMODCAP  = 1 : Break : Endif
    If [F:CPV]ENDDAT(I) <> [M:MWS2]ENDDAT(I)            : WMODCAP  = 1 : Break : Endif
    If [F:CPV]TWD(I)    <> [M:MWS2]VARTWD(I)            : WMODCAP  = 1 : Break : Endif
    If [F:CPV]WSTNBR(I) <> [M:MWS2]VARWSTNBR(I)         : WMODCAP  = 1 : Break : Endif
Next I
$FIN_VMOD
If WMODCAP : GMESSAGE = mess(199,190,1) : Call MESSAGE(GMESSAGE) From GESECRAN : Raz GMESSAGE : Endif
Return
#############################################################
$ANNULE
Delete [AXX] Where CODFIC="WORKSTATIO" & IDENT1=[L]SUPP(0) & IDENT2=[L]CODE
If fstat=1 | fstat>5
 # FGR 12/01/2010 : X3SUIVI60986
 #GOK=0 : Call RSTA([AXX],[L]SUPP(0)-[L]CODE) From GLOCK : Return
 GOK=0 : Call RSTA("AXX",[L]SUPP(0)-[L]CODE) From GLOCK : Return
Endif
Return
#############################################################
$CREATION
Call MAJTEXTRA([M:MWS0]WSTDESAXX,"WORKSTATIO","WSTDESAXX",[M:MWS0]WST,[M:MWS0]WCRFCY) From ATEXTRA
Call MAJTEXTRA([M:MWS0]WSTSHOAXX,"WORKSTATIO","WSTSHOAXX",[M:MWS0]WST,[M:MWS0]WCRFCY) From ATEXTRA

Return

########################################################################
$CHARG_PARAM
#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return

#########################################
# étiquettes des écrans
#########################################

#################################
Subprog C_WCR(VALEUR)
Variable Char     VALEUR
Read [F:TWC]TWC0 = VALEUR
If fstat GMESSAGE = mess(23,100,1)
   mkstat = 1
   End
Endif
#---CPO Cause libéllé traduisible : Géré par le type de données (Lien long)
#[M:MWS0]WCRDES = [F:TWC]WCRDES
# avertissement en cas de modif du centre               (03/02/00    TB)
If !find(GREP,"C","D") & VALEUR <> [F:MWS]WCR
# "Cette modification peut avoir des conséquences ! Vérifier les cas d'emploi"
   Call MESSAGE(mess(128,193,1)) From GESECRAN
Endif
End

#################################
Subprog C_WSTTYP(VALEUR)
Variable Integer VALEUR
# avertissement en cas de modif du type               (03/02/00    TB)
If !find(GREP,"C","D") & VALEUR <> [F:MWS]WSTTYP
# "Cette modification peut avoir des conséquences ! Vérifier les cas d'emploi"
   Call MESSAGE(mess(128,193,1)) From GESECRAN
Endif
# llc 07.01 9728 (sous-traitance)
Case VALEUR
    When 1,2:    [M:MWS1]LOCCAT = 1
    When 3:      [M:MWS1]LOCCAT = 4
Endcase
End

#114791.sn
#################################
Subprog AM_WSTTYP(VALEUR)
Variable Integer VALEUR
  Case VALEUR
    When 1 #Machine
      Actzo [M:MWS1]RUNBRKFLG
    When Default
      Grizo [M:MWS1]RUNBRKFLG
      Effzo [M:MWS1]RUNBRKFLG
  Endcase
End
#114791.en

#################################
Subprog C_VLTCCE(VALEUR)
Variable Char     VALEUR
If VALEUR <> ""
   Read [MWC]WCT0=VALEUR;[M:MWS0]WCRFCY
   If  fstat : GMESSAGE=mess(137,193,1)
      mkstat=2
   Endif
Endif
End

#################################
Subprog AS_STOLOC(VALEUR)
Variable Char     VALEUR
GBOUT1=mess(9,198,1)
End

###########################################################
Subprog C_STOLOC(VALEUR)
Variable Char     VALEUR
VALEUR=toupper(VALEUR)
If clalev([F:STC])=0 : Local File STOLOC [STC] : Endif
If VALEUR <> ""
    Read [STC]STC0=[M:MWS0]WCRFCY;VALEUR
    Case fstat
        When 1,4,5 :
            If [M:MWS0]WSTTYP = 3 |
&           (!instr(1,VALEUR,"*") & !instr(1,VALEUR,"?") & !instr(1,VALEUR,"#") & !instr(1,VALEUR,"!"))
                GMESSAGE = mess(23,100,1)
                mkstat = 2
                End
            Endif
        When Default :
            # llc 07.01 9728 (sous-traitance)
            If (find([M:MWS0]WSTTYP,1,2) & [F:STC]LOCCAT <> 1) | ([M:MWS0]WSTTYP = 3 & !find([F:STC]LOCCAT,1,4))
                GMESSAGE=mess(16,196,1)
                mkstat=2
            Endif
    Endcase
Endif
End

########################################
Subprog AM_STOLOC(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
End

########################################
Subprog C_EFF(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 : mkstat = 2 : Endif
End

########################################
Subprog AS_VLTCCE(VALEUR)
Variable Char    VALEUR()
Raz GBOUT1
GBOUT1 = mess(410,198,1)
End

########################################
Subprog B1_VLTCCE(VALEUR)
Variable Char    VALEUR()
Local    Char    WFCY(GLONFCY)
WFCY = [M:MWS0]WCRFCY
Call OBJET("MWC",WFCY,VALEUR) From GOBJET
If [F:MWC]VLTCCE <> "" & [F:MWC]VLTFCY = [M:MWS0]WCRFCY
    VALEUR = [F:MWC]VLTCCE
Endif
End

########################################
Subprog AM_WCR(VALEUR)
Variable Char    VALEUR()
# Issue X3-22755 - 2017-02-20 by ALSHE : Hide iLog fields
If dim([M:MWS1]DSPLEV)>0
    [M:MWS1]DSPLEV = [F:TWC]DSPLEV
    If !GIMPORT : Affzo [M:MWS1]DSPLEV : Endif
Endif
End

########################################
Subprog C_SHR(VALEUR)
Variable Decimal VALEUR
If VALEUR < -99 : mkstat = 2 : Endif
End

########################################
Subprog C_WSTNBR(VALEUR)
Variable Decimal VALEUR

If VALEUR <> [F:MWS]WSTNBR & !find(GREP,"C","D")
    Call MESSAGE(mess(128,193,1)) From GESECRAN
Endif
End

########################################
Subprog C_GRPFLG(VALEUR)            # MM 08.02
Variable Integer VALEUR
Local Integer I
# la valeur oui est réservée aux postes machine
If ([M:MWS0]WSTTYP<>1 & VALEUR<>1)
    VALEUR =1
    [M:MWS1]GRPFLG= VALEUR
    GERR=1 : GMESSAGE = mess(203,193,1) : End
Endif

# la valeur oui est interdite si le poste est multi-exemplaire
If ([M:MWS1]WSTNBR >1  & VALEUR<>1)
    VALEUR =1
    [M:MWS1]GRPFLG= VALEUR
    GERR=1 : GMESSAGE =mess(204,193,1) : End
Endif

# pour le cas où on ait modifié le nombre d'exemplaire de poste dans l'onglet "variation de capacité"
For I=0 To [M:MWS2]NBLIG-1
    If ([M:MWS2]VARWSTNBR(I)>1 & VALEUR <>1)
        VALEUR =1 : [M:MWS1]GRPFLG=VALEUR
        GERR=1 : GMESSAGE =(mess(204,193,1)-mess(172,190,1)) : End
    Endif
Next I

End

########################################
Subprog AM_GRPFLG(VALEUR)     # MM 08.02
Variable Integer VALEUR

Case VALEUR
    When 1 : [M:MWS1]GRPHOR =0 : Grizo [M:MWS1]GRPHOR
    When 2 : Actzo [M:MWS1]GRPHOR
Endcase
End

########################################
Subprog C_GRPHOR(VALEUR)    # MM 08.02
Variable Decimal VALEUR

If [M:MWS1]GRPFLG=1 : VALEUR =0 : [M:MWS1]GRPHOR = VALEUR :  Grizo [M:MWS1]GRPHOR : Endif
End

#114791.sn
########################################
Subprog C_RUNBRKFLG(VALEUR)
Variable Integer VALEUR

  Local Integer OK

  #Check if there is change in value
  If !find(GREP,"C","D") & [M:MWS1]RUNBRKFLG<>VALEUR
    If func SFTLIB.WST_IN_TXN([M:MWS0]WST,[M:MWS0]WCRFCY)=[V]CST_AYES
      Call AVERTIR(mess(109,2422,1),OK) From GESECRAN
      If OK = [V]CST_ANO
        mkstat = 2
      Endif
    Endif
  Endif
End
#114791.en

##########################################################################
## Etiquette ajoutée par le superviseur 15/04/2003 10:36:00 (SR)
##########################################################################
Subprog S_WST(VALEUR)
Variable Char    VALEUR()
If [F:MWS]WST = "" : End : Endif
Read [F:MWS]WST0 Curr
If !fstat & [F:MWS]WST = VALEUR
    [M:MWS0]WCRFCY = [F:MWS]WCRFCY
    [M:MWS0]WSTTYP = [F:MWS]WSTTYP
    [M:MWS0]WCR    = [F:MWS]WCR
Endif
If !GIMPORT
   Affzo [M:MWS0]WCRFCY, WSTTYP, WCR
Endif
End



######################################################################################
## Etiquette ajoutée par le superviseur (écran MWS4) 02/02/2007 08:30:22 (SR)
######################################################################################
Subprog IB_NBLIGC
End


######################################################################################


######################################################################################
## Etiquette ajoutée par le superviseur (écran MWS0) 20/04/2011 16:06:36 (LLC)
######################################################################################
Subprog C_WCRFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> GFCY
    GFCY=VALEUR
    Gosub CHARG_PARAM
Endif
End


######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran MWS1) 05/01/2012 15:32:51 (LTR)
######################################################################################
Subprog AM_PCCCOD(VALEUR)
Variable Char    VALEUR()
#----------------------------------------------------------------------------------------------
#----- 01/2012 Ltr: pour la nature de dépense, on contrôle le site
#----- de la nature de dépense (select) et celui du poste de charge(WCRFCY), ecran MWS0
#----- Si le site de la nature de dépsense(PCCFCY) est null : ok
#----- Sinon, les deux sites doivent être identiques, sinon erreur message.
#----- Aspect fonctionnel: la liste des Natures proposée sont Actif et provision=1 (Non,No)
#----------------------------------------------------------------------------------------------
Local Integer WRET
#---- WRET=0 okay, sinon code erreur dans le menu-message 2260  -------------------------------
WRET=func TRTBOPCC.CONTROL_FCY(VALEUR,[M:MWS0]WCRFCY)
If WRET > 0
  #---- WRET=112 : code erreur
  GERR=1
  GMESSAGE=func AFNC.MES2(mess(WRET,2260,1),VALEUR,[M:MWS0]WCRFCY)
  [M:MWS1]PCCCOD="" : VALEUR=""
Endif
End
######################################################################################

