#<AdxTL>@(#)12.0.0.0 $Revision$
##########################################################################################################
#   Composants technique de gestion des rendez-vous       Module CRM      5 mai 2006
#
# DELTSK    : Sous-programme d'annulation d'un rendez-vous.
#
##########################################################################################################
Subprog TEST
Local Char SZAPTNUM
Local Integer LERRCOD

  GSYNCOUTLOOK = 1
  SZAPTNUM = "000000000076481"
  Call DELBAP("SUBBAPCA", 2, 2, SZAPTNUM, LERRCOD) 
  GSYNCOUTLOOK =0
End

##########################################################################################################
Subprog DELBAP(SZDELBAPTRT, ITRACE, ILEC_TRACE, SZAPTNUM, LERRCOD) 
Value Char SZDELBAPTRT
Value Integer ITRACE
Value Integer ILEC_TRACE
Value Char SZAPTNUM
Variable Integer LERRCOD

Global Char GSZDELBAPTRT
Global Integer GIDELBAPTRACE

Local Integer IBOPENTRACE
Local Integer IBDEBTRANSFLG
Local Integer NI  # FGR 14/04/2011 : X3SUIVI73241

  IBOPENTRACE = 0
  GSZDELBAPTRT = SZDELBAPTRT
  GIDELBAPTRACE = ITRACE
  If GSZDELBAPTRT = "" Then
    GSZDELBAPTRT = "SUBBAPCA"
  Endif
  Raz LERRCOD, GMESSAGE
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If ITRACE Then
    If GTRACE = "" Then
      #Suppression de rendez-vous démarrée à partir du contexte :  GSZDELBAPTRT
      Call OUVRE_TRACE (mess(328,177,1) - GSZDELBAPTRT) From LECFIC
      IBOPENTRACE = 1
    Endif
  Endif
#--- variables
Local  Integer OK, SAVGIMPORT 
Local  Char    ACTION(20), ABREV(5) 
Local Char SAVGABREV

  #--- declaration et chargement des variables objet 
  ABREV = "BAP"
  SAVGABREV = GABREV
  GABREV = "BAP"
  Gosub DEFVAR From GOBJET    # FGR 07/06/2010 : X3SUIVI64666 A faire juste après GABREV
  #
  SAVFONC = GFONCTION         # FGR 16/09/2009 : X3SUIVI57846
  GFONCTION = "GES"+ABREV     # FGR 16/09/2009 : X3SUIVI57846
  #Gosub DEFVAR From GOBJET   # FGR 07/06/2010 : X3SUIVI64666 là on perd SAVFONC !
  SAVGIMPORT = GIMPORT
  GIMPORT = 1
  #Gestion des autorisations
  Call AUTORIS From EXEFNC
  GOK=1
  OK=1
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=AVANT_OUVRE",0) From GESECRAN
  Endif
  ACTION="AVANT_OUVRE" : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("    ERROR AVANT_OUVRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  #--- ouverture de la fenêtre contrat
  If clalev([M:BAP0])=0 : Local Mask BAP0 [BAP0] : Endif
  If clalev([M:BAP1])=0 : Local Mask BAP1 [BAP1] : Endif
  If clalev([M:BAP2])=0 : Local Mask BAP2 [BAP2] : Endif
  If clalev([M:BAP3])=0 : Local Mask BAP3 [BAP3] : Endif
  If clalev([M:BAP4])=0 : Local Mask BAP4 [BAP4] : Endif
  If clalev([M:BAP5])=0 : Local Mask BAP5 [BAP5] : Endif
  Raz [M:BAP0], [M:BAP1], [M:BAP2], [M:BAP3], [M:BAP4], [M:BAP5]
  #--- ouverture des tables necessaires
  If clalev([F:BAP])=0 : Local File BAPPOINT [BAP] : Endif
  Gosub OUVRE From WOBAP 
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=OUVRE",0) From GESECRAN
  Endif
  ACTION = "OUVRE" : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("    ERROR OUVRE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  WINPROG = "WGOBAP"
  GREP = "A"
  Read [BAP]APP0=SZAPTNUM
  If fstat Then
    LERRCOD = 4
    #Erreur lors de la lecture du rendez-vous + " : " +SZAPTNUM
    Call ECR_TRACE(mess(292,177,1)+" : "+SZAPTNUM,1) From GESECRAN
    Gosub ONERROR
    End
  Endif
  [M:BAP0] = [F:BAP]
  [M:BAP1] = [F:BAP]
  [M:BAP2] = [F:BAP]
  [M:BAP3] = [F:BAP]
  [M:BAP4] = [F:BAP]
  [M:BAP5] = [F:BAP]
  Default Mask [BAP0]
  Default Mask [BAP1]
  Default Mask [BAP2]
  Default Mask [BAP3]
  Default Mask [BAP4]
  Default Mask [BAP5]

  # FGR 14/04/2011 : X3SUIVI73241 (début)
  For NI = 0 To dim([M:BAP2]APTREPNUM)-1
    Call ECR_TRACE("0- NI=" - num$(NI) - "[M:BAP2]APTREPNUM(NI)=[" + [M:BAP2]APTREPNUM(NI) + "]", 0) From GESECRAN  # FLORENT ICI
    If [M:BAP2]APTREPNUM(NI) <> "" Then
      [M:BAP2]NBLIGREP = NI + 1
    Endif
  Next NI
  # FGR 14/04/2011 : X3SUIVI73241 (fin)
  #------------------------------------------------------------------------  
  #--- chargement des masques de objet
  # FGR 14/04/2011 : X3SUIVI73241 (début) ne sert à rien en suppression
  #If ITRACE > 1 Then
  #  Call ECR_TRACE("MASK",0) From GESECRAN
  #Endif
  ## chargement masques enregistrement entête rendez-vous
  #Default Mask [BAP0]
  #Call SAIMSK("BAP","IMP_ZONE","SUBBAPCA") From W0BAP0
  #If mkstat Then
  #  If ITRACE > 1 Then
  #    Call ECR_TRACE("  ERROR  MARSK BAP0 mkstat="+num$(mkstat),1) From GESECRAN
  #  Endif
  #  LERRCOD = 2
  #  Gosub ONERROR
  #  End
  #Endif
  #Default Mask [BAP1]
  #Call SAIMSK("BAP","IMP_ZONE","SUBBAPCA") From W0BAP1
  #If mkstat Then
  #  If ITRACE > 1 Then
  #    Call ECR_TRACE("  ERROR  MARSK BAP1(IMP_ZONE) mkstat="+num$(mkstat),1) From GESECRAN
  #  Endif
  #  LERRCOD = 2
  #  Gosub ONERROR
  #  End
  #Endif
  #Default Mask [BAP1]
  #Call SAIMSK("BAP","IMP_TAB","SUBBAPCA") From W0BAP1
  #If mkstat Then
  #  If ITRACE > 1 Then
  #    Call ECR_TRACE("  ERROR  MARSK BAP1(IMP_TAB) mkstat="+num$(mkstat),1) From GESECRAN
  #  Endif
  #  LERRCOD = 2
  #  Gosub ONERROR
  #  End
  #Endif
  #Default Mask [BAP2]
  #Call SAIMSK("BAP","IMP_ZONE","SUBBAPCA") From W0BAP2
  #If mkstat Then
  #  If ITRACE > 1 Then
  #    Call ECR_TRACE("  ERROR  MARSK BAP2(IMP_ZONE) mkstat="+num$(mkstat),1) From GESECRAN
  #  Endif
  #  LERRCOD = 2
  #  Gosub ONERROR
  #  End
  #Endif
  #Default Mask [BAP2]
  #Call SAIMSK("BAP","IMP_TAB","SUBBAPCA") From W0BAP2
  #If mkstat Then
  #  If ITRACE > 1 Then
  #    Call ECR_TRACE("  ERROR  MARSK BAP2(IMP_TAB) mkstat="+num$(mkstat),1) From GESECRAN
  #  Endif
  #  LERRCOD = 2
  #  Gosub ONERROR
  #  End
  #Endif
  #Default Mask [BAP3]
  #Call SAIMSK("BAP","IMP_ZONE","SUBBAPCA") From W0BAP3
  #If mkstat Then
  #  If ITRACE > 1 Then
  #    Call ECR_TRACE("  ERROR  MARSK BAP3 mkstat="+num$(mkstat),1) From GESECRAN
  #  Endif
  #  LERRCOD = 2
  #  Gosub ONERROR
  #  End
  #Endif
  #Default Mask [BAP4]
  #Call SAIMSK("BAP","IMP_ZONE","SUBBAPCA") From W0BAP4
  #If mkstat Then
  #  If ITRACE > 1 Then
  #    Call ECR_TRACE("  ERROR  MARSK BAP4 mkstat="+num$(mkstat),1) From GESECRAN
  #  Endif
  #  LERRCOD = 2
  #  Gosub ONERROR
  #  End
  #Endif
  #Default Mask [BAP5]
  #Call SAIMSK("BAP","IMP_ZONE","SUBBAPCA") From W0BAP5
  #If mkstat Then
  #  If ITRACE > 1 Then
  #    Call ECR_TRACE("  ERROR  MARSK BAP5 mkstat="+num$(mkstat),1) From GESECRAN
  #  Endif
  #  LERRCOD = 2
  #  Gosub ONERROR
  #  End
  #Endif
  # FGR 14/04/2011 : X3SUIVI73241 (fin) ne sert à rien en suppression
  GPOINT = "MSKDELBAP" : Gosub ENTREE From EXEFNC  #CHECK IGNORE_LINE
  If mkstat Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR  GPOINT=MSKDELBAP mkstat="+num$(mkstat),1) From GESECRAN
    Endif
    LERRCOD = 8
    Gosub ONERROR
    End
  Endif
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=VERF_ANU",0) From GESECRAN
  Endif
  ACTION = "VERF_ANU"   : Gosub ACTION From GOBJSUB
  If !OK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR VERF_ANU",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  Read [BAP]APP0=SZAPTNUM
  If fstat Then
    LERRCOD = 4
    #Erreur lors de la lecture du rendez-vous + " : " +SZAPTNUM
    Call ECR_TRACE(mess(292,177,1)+" : "+SZAPTNUM,1) From GESECRAN
    Gosub ONERROR
    End
  Endif
  Readlock [BAP]Curr
  If fstat <> 0 Then
    #Impossible de locker le rendez-vous+" : "+SZAPTNUM
    Call ECR_TRACE(mess(325,177,1)+" : "+SZAPTNUM,1) From GESECRAN
    Gosub ONERROR
    End
  Endif
  Raz [F:BAP]
  Default File [F:BAP]
  [F:BAP] = [M:BAP0]
  [F:BAP] = [M:BAP1]
  [F:BAP] = [M:BAP2]
  [F:BAP] = [M:BAP3]
  [F:BAP] = [M:BAP4]
  [F:BAP] = [M:BAP5]
  [F:BAP]UPDUSR = GUSER
  [F:BAP]UPDDAT = date$
  If ITRACE > 1 Then
    #Suppression [F:BAP]  -  APTNUM= +[F:BAP]APTNUM
    Call ECR_TRACE(mess(329,177,1)+[F:BAP]APTNUM,0) From GESECRAN
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [BAP]
  Endif
  Delete [F:BAP] Where [F:BAP]APTNUM = SZAPTNUM
  If fstat Then
    LERRCOD = 9
    GOK = 0
    Call FSTA("BAP") From GLOCK
    #Erreur lors de la suppression du rendez-vous + " : " +SZAPTNUM
    Call ECR_TRACE(mess(297,177,1)+" : "+SZAPTNUM,1) From GESECRAN
    Gosub ONERROR
    End
  Endif
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=ANNULE",0) From GESECRAN
  Endif
  ACTION = "ANNULE" : Gosub ACTION From GOBJSUB
  If !GOK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR ANNULE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  If IBDEBTRANSFLG = 0
    Commit
  Endif
  If ITRACE Then
    #"[F:BAP] - APTNUM="+[F:BAP]APTNUM+"  " supprimé
    Call ECR_TRACE("[F:BAP] - APTNUM="+[F:BAP]APTNUM+"  "+mess(377,177,1),0) From GESECRAN
  Endif
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=AP_ANNULE",0) From GESECRAN
  Endif
  ACTION = "AP_ANNULE"   : Gosub ACTION From GOBJSUB
  If !GOK Then
    If ITRACE > 1 Then
      Call ECR_TRACE("  ERROR AP_ANNULE",1) From GESECRAN
    Endif
    LERRCOD = 1
    Gosub ONERROR
    End
  Endif
  If ITRACE > 1 Then
    Call ECR_TRACE("ACTION=FERME",0) From GESECRAN
  Endif
  ACTION = "FERME" : Gosub ACTION From GOBJSUB
  If IBOPENTRACE = 1 Then
    Call FERME_TRACE From LECFIC
  Endif
  GIMPORT = SAVGIMPORT
  GABREV = SAVGABREV
  GFONCTION = SAVFONC         # FGR 16/09/2009 : X3SUIVI57846
  Kill GSZDELBAPTRT 
  Kill GIDELBAPTRACE
  If IBOPENTRACE = 1 Then
    If ILEC_TRACE Then
      Call LEC_TRACE From LECFIC  
    Endif
  Endif
End

##########################################################################################################
$ACTION
Local Char SZVALBEFORE
Local Char SZVALAFTER
Local Integer IBTESTOK

  IBTESTOK = 0
  Raz SZVALBEFORE
  Raz SZVALAFTER
  If evalue ("type([M]"+IMPZON+")") < 300 Then
    IBTESTOK = 1
  Endif
  If IBTESTOK = 1
    SZVALBEFORE = num$(evalue("[M]"+IMPZON))
  Endif
  If GIDELBAPTRACE Then
    Call ECR_TRACE("ACTION = "+ACTION-"IMPZON="+IMPZON-"XOK="+num$(XOK),0) From GESECRAN
    If IBTESTOK = 1 Then
      #"    "+Valeur avant = +" : " +SZVALBEFORE 
      Call ECR_TRACE("    "+  mess(369,177,1)+" : "+ SZVALBEFORE ,0) From GESECRAN 
    Endif
  Endif
  Case ACTION 
     When "IMP_ZONE"
       Gosub BAP_SET_HEA_INFO From =GSZDELBAPTRT
     When "IMP_TAB"
       Gosub BAP_SET_DET_INFO From =GSZDELBAPTRT
  Endcase
  If IBTESTOK = 1 Then
    SZVALAFTER = num$(evalue("[M]"+IMPZON))
    If SZVALAFTER <> SZVALBEFORE Then
      IMPMOD = 1
    Endif
  Else
    IMPMOD = 1
  Endif
  If GIDELBAPTRACE Then
    If IBTESTOK = 1 Then
      #"    "+Valeur après = +" : " +SZVALAFTER
      Call ECR_TRACE("    "+mess(370,177,1)+" : "+ SZVALAFTER,0) From GESECRAN 
    Endif
  Endif
Return

##########################################################################################################
$ONERROR
  If IBDEBTRANSFLG = 0 Then
    If adxlog Then
      Rollback
    Endif
  Endif
  If IBOPENTRACE = 1 Then
    Call FERME_TRACE From LECFIC
  Endif
  GOK = 0
  GIMPORT = SAVGIMPORT
  GABREV = SAVGABREV
  GFONCTION = SAVFONC         # FGR 16/09/2009 : X3SUIVI57846
  Kill GSZDELBAPTRT 
  Kill GIDELBAPTRACE
  If IBOPENTRACE = 1 Then
    If ILEC_TRACE Then
      Call LEC_TRACE From LECFIC  
    Endif
  Endif
Return

##########################################################################################################
# Affectation des valeurs pour la création d'une tache. (exemple)
#############################################################################
$SET_HEA_INFO_EXEMPLE
  Case IMPZON
    When "APTNUM" 
      #Numéro de rendez-vous        
      [M:BAP0]APTNUM= ""
    When "NBLIGCCN"
      #Nombre de Correspondant/Personne à visiter
      [M:BAP1]NBLIGCCN=0
    When "ATPREPMNA"
      #Organisateur
      [M:BAP2]ATPREPMNA= ""      
    When "NBLIGREP"
      #Nombre de représentant 
      [M:BAP2]NBLIGREP(indice)= 0
    When "ATPADDCMT"
      #Description adresse
      [M:BAP3]ATPADDCMT=""
    When "FULDAY"
      #Journée entière
      [M:BAP1]FULDAY= 1     
    When "APTDUR"
      #Durée rendez-vous
      [M:BAP1]APTDUR= ""
    When "APTDAT"
      #Date rendez-vous
      [M:BAP1]APTDAT= ""      
    When "APTHOU"
      #Heure rendez-vous
      [M:BAP1]APTHOU= ""      
    When "APTDATEND"
      #Fin rendez-vous
      [M:BAP1]APTDATEND= ""      
    When "APTHOUEND"
      #Heure fin
      [M:BAP1]APTHOUEND= ""      
    When "FULOBJ"
      #sujet/Objectif
      #[M:BAP1]FULOBJ= 
    When "FULRPO"
      #Compte rendu
      #[M:BAP4]FULRPO= ""
  Endcase
Return

#############################################################################
#DETAIL
$SET_DET_INFO_EXEMPLE
  Case IMPZON
    When "APTCCNNUM"
      #Personne
      Case indice
        When 0
          IMPMOD = 1 
          [M:BAP2]APTCCNNUM(indice)= ""      
        When 1
          IMPMOD=1 
          [M:BAP2]APTCCNNUM(indice)= ""      
      Endcase
    When "APTCOR"
      #Correspondant    Personne à visiter
      Case indice
        When 0
          IMPMOD=1 
          [M:BAP1]APTCOR(indice)=""
        When 1
          IMPMOD=1 
          [M:BAP1]APTCOR(indice)=""
      Endcase
    When "APTREPNUM"
      #Représentant
      Case indice
        When 0
          IMPMOD=1 
          [M:BAP2]APTREPNUM(indice)= ""      
        When 1
          IMPMOD=1 
          [M:BAP2]APTREPNUM(indice)= ""      
      Endcase
  Endcase
Return

##########################################################################################################
# Affectation des valeurs pour la création d'une tache. (exemple)
#############################################################################
$SET_HEA_INFO
  Case IMPZON
    When "APTNUM" 
      #Numéro de rendez-vous        
      # [M:BAP0]APTNUM= ""
    When "NBLIGCCN"
      #Nombre de Correspondant/Personne à visiter
      [M:BAP1]NBLIGCCN=2
    When "ATPREPMNA"
      #Organisateur
      [M:BAP2]ATPREPMNA= "LSE12"      
    When "NBLIGREP"
      #Nombre de représentant 
      [M:BAP2]NBLIGREP(indice)= 2
    When "ATPADDCMT"
      #Description adresse
      [M:BAP3]ATPADDCMT="Mon lieu de rendez vous"
    When "FULDAY"
      #Journée entière
      [M:BAP1]FULDAY= 1     
    When "APTDUR"
      #Durée rendez-vous
      [M:BAP1]APTDUR= "25"
    When "APTDAT"
      #Date rendez-vous
      [M:BAP1]APTDAT= "20060525"      
    When "APTHOU"
      #Heure rendez-vous
      [M:BAP1]APTHOU= "1010"      
    When "APTDATEND"
      #Fin rendez-vous
      [M:BAP1]APTDATEND= "20060525"      
    When "APTHOUEND"
      #Heure fin
      [M:BAP1]APTHOUEND= "1111"      
    When "FULOBJ"
      #sujet/Objectif
      #[M:BAP1]FULOBJ= 
    When "FULRPO"
      #Compte rendu
      #[M:BAP4]FULRPO= ""
  Endcase
Return

#############################################################################
#DETAIL
$SET_DET_INFO
  Case IMPZON
    When "APTCOR"
      #Correspondant    Personne à visiter
      Case indice
        When 0
          IMPMOD=1 
          [M:BAP1]APTCOR(0)="000000000000031"
        When 1
          IMPMOD=1 
          [M:BAP1]APTCOR(1)="000000000000030"
      Endcase
    When "APTREPNUM"
      #Représentant
      Case indice
        When 0
          IMPMOD=1 
          [M:BAP2]APTREPNUM(0)= "LSE12"    
        When 1
          IMPMOD=1 
          [M:BAP2]APTREPNUM(1)= "JPJ"      
      Endcase
  Endcase
Return
