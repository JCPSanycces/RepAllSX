#<AdxTL>@(#)8.0.0.0 $Revision$
######################################################################
# sous-pro et fonctions propres à la gestion d'un pivot de connecteur
######################################################################
$INIT_FILE
WADXIUM= adxium
WADXIRS= adxirs
WADXIFS= adxifs
GPOINT = "PIVOTSFILE" : Gosub ENTREE From EXEFNC
WADXIUM_NEW= adxium
WADXIRS_NEW= adxirs
WADXIFS_NEW= adxifs
adxifs = '' : # on ne doit pas positionner le adxifs
Return

$OUVREPIVOT
If clalev ([F:PIT]) = 0 : Local File PIVOTS [PIT] : Endif
If clalev ([F:PIZ]) = 0 : Local File PIVZON [PIZ] : Endif
If clalev ([F:ATB]) = 0 : Local File ATABLE [ATB] : Endif
Return

######################
$INITPIVOT
Gosub OUVREPIVOT

Local Integer NBPIVZON : Raz NBPIVZON
Local Char WPIVNORECMES (50): Raz WPIVNORECMES
Local Integer WPIVHEATYP : Raz WPIVHEATYP
Local Char WPIVHEADMES (250): Raz WPIVHEADMES
Call READPIT(CONPIT,NBPIVZON,WPIVNORECMES,WPIVHEATYP,WPIVHEADMES)

Local Char WPIVTABZON(GLONATB+GLONAVA+2)(1..NBPIVZON) : Raz WPIVTABZON
Local Char WPIVTABABR(GLONABR)(1..NBPIVZON) : Raz WPIVTABABR
Local Char WPIVZON(GLONAVA)(1..NBPIVZON) : Raz WPIVTABZON
Local Char WPIVFRM(150)(1..NBPIVZON) : Raz WPIVFRM
Local Integer WPIVWRK(1..NBPIVZON) : Raz WPIVWRK
#
Local Char WPIVVAL(255)(1..NBPIVZON) : Raz WPIVVAL
Local Char WPIVVALFIC(GLONAVA)(1..NBPIVZON) : Raz WPIVVALFIC
#
Call LOADPIVZON(CONPIT,NBPIVZON,WPIVTABZON,WPIVTABABR,WPIVZON,WPIVFRM,WPIVWRK)
Return

############################################
Subprog READPIT (CONPIT,NBPIVZON,WPIVNORECMES,WPIVHEATYP,WPIVHEADMES)
Value Char CONPIT()
Variable Integer NBPIVZON
Variable Char WPIVNORECMES ()
Variable Integer WPIVHEATYP
Variable Char WPIVHEADMES ()


Raz NBPIVZON
Raz WPIVNORECMES
Raz WPIVHEATYP
Raz WPIVHEADMES

Read [PIT]PIT0=CONPIT
If fstat
    Call ERREUR(mess(13,7710,1)-":"-CONPIT) From GESECRAN
    End
Endif

If [F:PIT]NORECFLG=0 : [F:PIT]NORECFLG=1 : Endif
If [F:PIT]NORECFLG=2
    WPIVNORECMES = [F:PIT]NORECMES
Endif

If [F:PIT]HEATYP=0 : [F:PIT]HEATYP=1 : Endif
WPIVHEATYP=[F:PIT]HEATYP
If [F:PIT]HEATYP=3
    WPIVHEADMES= [F:PIT]HEAMES
Endif

# Issue 91400 - 2013-11-14 by RBA : gestion des champs dimensionnés uniquement pour PLM
#different du PLM
If clalev([M:DIA])=0 or clalev([M:DIA]) and masknam([DIA])<>'PLMINT'

  Filter [PIZ]  Where ID=CONPIT
  NBPIVZON=rowcount([PIZ])
  Filter [PIZ]

#  If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
#  For [PIZ]PIZ0 Where ID=CONPIT
#    Read [ATZ]CODZONE=[F:PIZ]CODFIC;[F:PIZ]CODZONE
#    If !fstat
#        NBPIVZON = NBPIVZON + [ATZ]DIME
#    Else
#      NBPIVZON = NBPIVZON + 1
#    Endif
#  Next
#  Close File [ATZ]
Else #le PLM peut gérér les champs dimensionnés
  If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
  # Issue 85433(2) - 2012-10-24 by RBA : gestion des champs dimensionnés
  If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
  #/ Issue 85433(2) - 2012-10-24 by RBA : gestion des champs dimensionnés
  For [PIZ]PIZ0 Where ID=CONPIT
    Read [ATZ]CODZONE=[F:PIZ]CODFIC;[F:PIZ]CODZONE
    If !fstat
      # Issue 85433(2) - 2012-10-24 by RBA : gestion des champs dimensionnés
      If [ATZ]DIME = 0 and [ATZ]CODACT <> ""
        Read [ACV]CODACT=[ATZ]CODACT
        NBPIVZON = NBPIVZON + [ACV]DIME
      Else
      #/ Issue 85433(2) - 2012-10-24 by RBA : gestion des champs dimensionnés
        NBPIVZON = NBPIVZON + [ATZ]DIME
      # Issue 85433(2) - 2012-10-24 by RBA : gestion des champs dimensionnés
      Endif
      #/ Issue 85433(2) - 2012-10-24 by RBA : gestion des champs dimensionnés
    Else
      NBPIVZON = NBPIVZON + 1
    Endif
  Next
  # Issue 85433(2) - 2012-10-24 by RBA : gestion des champs dimensionnés
  Close File [ACV]
  #/ Issue 85433(2) - 2012-10-24 by RBA : gestion des champs dimensionnés
  Close File [ATZ]
Endif
#/Issue 85433
#/Issue 91400

If NBPIVZON=0 : NBPIVZON=1 : Endif
End

#################################################################################
Subprog LOADPIVZON(CONPIT,NBPIVZON,WPIVTABZON,WPIVTABABR,WPIVZON,WPIVFRM,WPIVWRK)
Value Char CONPIT()
Value Integer NBPIVZON
Variable Char WPIVTABZON()(1..NBPIVZON)
Variable Char WPIVTABABR()(1..NBPIVZON)
Variable Char WPIVZON()(1..NBPIVZON)
Variable Char WPIVFRM()(1..NBPIVZON)
Variable Integer WPIVWRK(1..NBPIVZON)

# Issue 91400 - 2013-11-14 by RBA : gestion des champs dimensionnés uniquement pour PLM
If clalev([M:DIA])=0 or clalev([M:DIA]) and masknam([DIA])<>'PLMINT'
  If CONPIT<>""
    For [PIZ]PIZ0 Where ID=CONPIT
      WPIVTABZON([F:PIZ]LIN)=[F:PIZ]CODFIC+"/"+[F:PIZ]CODZONE
      WPIVZON([F:PIZ]LIN)=[F:PIZ]CODZONE
      WPIVFRM([F:PIZ]LIN)=[F:PIZ]FRM
      Read [ATB]CODFIC=[F:PIZ]CODFIC
      If !fstat
          WPIVTABABR([F:PIZ]LIN)=[F:ATB]ABRFIC
      Endif
      If [F:PIZ]WRKZON=0 : [F:PIZ]WRKZON=1 : Endif
      WPIVWRK([F:PIZ]LIN)=[F:PIZ]WRKZON
    Next
  Endif
Else
  Local Integer WDIM, WILIN, WLIN
  WDIM = 0
  WLIN = 0
  WILIN = 0

  If CONPIT<>""
    If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
    #RBA
    If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
    #/RBA
    For [PIZ]PIZ0 Where ID=CONPIT
      Read [ATZ]CODZONE=[F:PIZ]CODFIC;[F:PIZ]CODZONE

      If !fstat
        # Issue 85433(2) - 2012-10-24 by RBA : gestion des champs dimensionnés
        #WDIM = [ATZ]DIME
        If [ATZ]DIME = 0 and [ATZ]CODACT <> ""
          Read [ACV]CODACT=[ATZ]CODACT
          WDIM = [ACV]DIME
        Else
          WDIM = [ATZ]DIME
        Endif
        #/ Issue 85433(2) - 2012-10-24 by RBA : gestion des champs dimensionnés
        If WDIM > 1
          For WILIN = 0 To WDIM - 1
            WLIN = WLIN + 1
            WPIVTABZON(WLIN)=[F:PIZ]CODFIC+"/"+[F:PIZ]CODZONE+"("+num$(WILIN)+")"
            WPIVZON(WLIN)=[F:PIZ]CODZONE+"("+num$(WILIN)+")"
            WPIVFRM(WLIN)=[F:PIZ]FRM
            Read [ATB]CODFIC=[F:PIZ]CODFIC
            If !fstat
                WPIVTABABR(WLIN)=[F:ATB]ABRFIC
            Endif
            If [F:PIZ]WRKZON=0 : [F:PIZ]WRKZON=1 : Endif
            WPIVWRK(WLIN)=[F:PIZ]WRKZON
          Next
        Else
          WLIN = WLIN + 1
          WPIVTABZON(WLIN)=[F:PIZ]CODFIC+"/"+[F:PIZ]CODZONE
          WPIVZON(WLIN)=[F:PIZ]CODZONE
          WPIVFRM(WLIN)=[F:PIZ]FRM
          Read [ATB]CODFIC=[F:PIZ]CODFIC
          If !fstat
              WPIVTABABR(WLIN)=[F:ATB]ABRFIC
          Endif
          If [F:PIZ]WRKZON=0 : [F:PIZ]WRKZON=1 : Endif
          WPIVWRK(WLIN)=[F:PIZ]WRKZON
        Endif
      Else
        WLIN = WLIN + 1
        WPIVTABZON(WLIN)=[F:PIZ]CODFIC+"/"+[F:PIZ]CODZONE
        WPIVZON(WLIN)=[F:PIZ]CODZONE
        WPIVFRM(WLIN)=[F:PIZ]FRM
        Read [ATB]CODFIC=[F:PIZ]CODFIC
        If !fstat
            WPIVTABABR(WLIN)=[F:ATB]ABRFIC
        Endif
        If [F:PIZ]WRKZON=0 : [F:PIZ]WRKZON=1 : Endif
        WPIVWRK(WLIN)=[F:PIZ]WRKZON
      Endif

    Next
    # Issue 85433(2) - 2012-10-24 by RBA : gestion des champs dimensionnés
    Close File [ACV]
    #/ Issue 85433(2) - 2012-10-24 by RBA : gestion des champs dimensionnés
    Close File [ATZ]

  Endif
#/Issue 85433
Endif
#/Issue 91400
End

######################################################################
Subprog RAZVALPIVOT(CONPIT,NBPIVZON,WPIVVAL,WPIVVALFIC)
Value Char CONPIT()
Value Integer NBPIVZON
Variable Char WPIVVAL()(1..NBPIVZON)
Variable Char WPIVVALFIC()(1..NBPIVZON)

If CONPIT<>""
Raz WPIVVAL
Raz WPIVVALFIC
Endif
End

######################################################################
Subprog EVALPIVOT(CONPIT,NBPIVZON,WPIVTABZON,WPIVTABABR,WPIVZON,WPIVFRM,WPIVWRK,WPIVVAL,WPIVVALFIC)
Value Char CONPIT()
Value Integer NBPIVZON
Variable Char WPIVTABZON()(1..NBPIVZON)
Variable Char WPIVTABABR()(1..NBPIVZON)
Variable Char WPIVZON()(1..NBPIVZON)
Variable Char WPIVFRM()(1..NBPIVZON)
Variable Integer WPIVWRK(1..NBPIVZON)
Variable Char WPIVVAL()(1..NBPIVZON)
Variable Char WPIVVALFIC()(1..NBPIVZON)

Local Integer PIVTYP

If CONPIT<>""
    Onerrgo ON_ERR_EVAL
    For NOPIV=1 To NBPIVZON
        PIVTYP=evalue("type([F:"+WPIVTABABR(NOPIV)+"]"+WPIVZON(NOPIV)+")")
        If WPIVFRM(NOPIV)<>""
               Case PIVTYP
                When 1, 2, 4, 5, 6, 7, 9
                    WPIVVAL(NOPIV) = num$(evalue(WPIVFRM(NOPIV)))
                When 3
                    WPIVVAL(NOPIV) = vireblc(format$("D:YYYYMMDD",evalue(WPIVFRM(NOPIV))),1)
                When Default
                    WPIVVAL(NOPIV) = evalue(WPIVFRM(NOPIV))
              Endcase
       Else
            If PIVTYP>0 : # sinon il s'agit d'une erreur et on ne peut pas trouver la valeur
               Case PIVTYP
                When 1, 2, 4, 5, 6, 7, 9
                    WPIVVAL(NOPIV) = num$(evalue("[F:"+WPIVTABABR(NOPIV)+"]"+WPIVZON(NOPIV)))
                When 3
                    WPIVVAL(NOPIV) = vireblc(format$("D:YYYYMMDD",evalue("[F:"+WPIVTABABR(NOPIV)+"]"+WPIVZON(NOPIV))),1)
                When Default
                    WPIVVAL(NOPIV) = evalue("[F:"+WPIVTABABR(NOPIV)+"]"+WPIVZON(NOPIV))
              Endcase
            Endif
        Endif
    Next
    Onerrgo
Endif
End
$ON_ERR_EVAL
Onerrgo
If WPIVFRM(NOPIV)<>""
Call ECR_TRACE(mess(43,7710,1)-CONPIT+"/"+WPIVTABZON(NOPIV)-"("+WPIVFRM(NOPIV)+")",1) From GESECRAN : # erreur
Else
Call ECR_TRACE(mess(43,7710,1)-CONPIT+"/"+WPIVTABZON(NOPIV),1) From GESECRAN : # erreur
Endif
Resume

######################################################################
Subprog WRPIVOT_HEAD(CONPIT,NBPIVZON,WPIVTABZON,WPIVTABABR,WPIVZON,WPIVWRK,WPIVHEATYP,WPIVHEADMES,WPREM,WFILE)
Value Char CONPIT()
Value Integer NBPIVZON
Variable Char WPIVTABZON()(1..NBPIVZON)
Variable Char WPIVTABABR()(1..NBPIVZON)
Variable Char WPIVZON()(1..NBPIVZON)
Variable Integer WPIVWRK(1..NBPIVZON)
Variable Integer WPIVHEATYP
Variable Char WPIVHEADMES ()
Variable Integer WPREM
Variable Char WFILE()

Local Char    WCHAIN(255), WSPECHAR, WSEPCHR
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs
If WADXIFS_NEW=""
WSEPCHR=";"
Else
WSEPCHR=WADXIFS_NEW
Endif
If CONPIT<>""
    ###VPO 28/01/10 If WPREM= 0 & (WPIVHEATYP=2 | WPIVHEATYP=3)
    If WPREM= 0
        Openo WFILE,0 Using [FPIV]
        #on ecrit l'entête
        If WPIVHEATYP=3
            WPREM= 1
            Wrseq WPIVHEADMES Using [FPIV]
        Elsif WPIVHEATYP=2 | WPIVHEATYP=4
            WPREM= 1
            For NOPIV=1 To NBPIVZON
                If WPIVWRK(NOPIV)<>2
                    If WPIVHEATYP=2
                        WCHAIN = WPIVZON(NOPIV)
                    Else
                        Read [F:PIZ]PIZ0=CONPIT;NOPIV
                        WCHAIN = [F:PIZ]DES
                    Endif
                    WSPECHAR   = ","
                    Gosub REMOVE_CHAR
                    WSPECHAR   = WSEPCHR
                    Gosub REMOVE_CHAR
                    If NOPIV=1
                        Wrseq WCHAIN; Using [FPIV]
                        ###If NBPIVZON=1 : # VPO 22/10/09 correct si une seule colonne
                        ###    Wrseq "" Using [FPIV]
                        ###Endif
                    #VPO 29/01/10Elsif NOPIV=NBPIVZON
                    #    Wrseq WSEPCHR+WCHAIN Using [FPIV]
                    Else
                        Wrseq WSEPCHR+WCHAIN; Using [FPIV]
                    Endif
                Endif
            Next
            #VPO 29/01/10
            Wrseq "" Using [FPIV]
        Endif
        #on ferme
        Openo Using [FPIV]
    Endif
Endif
End
######################################################################
Subprog WRPIVOT_END(CONPIT,NBENREG,WPIVNORECMES,WPREM,WFILE)
Value Char CONPIT()
Value Integer NBENREG
Value Char WPIVNORECMES ()
Variable Integer WPREM
Variable Char WFILE()

If CONPIT<>""
  If NBENREG=0 & WPIVNORECMES<>""
    If WPREM = 0
        Openo WFILE,0 Using [FPIV]
        WPREM= 1
    Else
        Openo WFILE Using [FPIV]
    Endif
    Wrseq WPIVNORECMES Using [FPIV]
    #on ferme
    Openo Using [FPIV]
  Endif
Endif
End
######################################################################
Subprog WRPIVOT(NBPIVZON,WPIVTABZON,WPIVTABABR,WPIVZON,WPIVFRM,WPIVWRK,WPIVVAL,WPIVVALFIC)
Value Integer NBPIVZON
Variable Char WPIVTABZON()(1..NBPIVZON)
Variable Char WPIVTABABR()(1..NBPIVZON)
Variable Char WPIVZON()(1..NBPIVZON)
Variable Char WPIVFRM()(1..NBPIVZON)
Variable Integer WPIVWRK(1..NBPIVZON)
Variable Char WPIVVAL()(1..NBPIVZON)
Variable Char WPIVVALFIC()(1..NBPIVZON)

Local Char    WCHAIN(255), WSPECHAR, WSEPCHR
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs
If WADXIFS_NEW=""
WSEPCHR=";"
Else
WSEPCHR=WADXIFS_NEW
Endif
For NOPIV=1 To NBPIVZON
  If WPIVWRK(NOPIV)<>2
    WCHAIN     = WPIVVAL(NOPIV)
    # SAM 94218 - code non exécuté pour le connecteur ACCENTFIL
    If clalev([M:DIA])=0 or clalev([M:DIA]) and masknam([DIA])<>'FAEINT'
      WSPECHAR   = ","
      Gosub REMOVE_CHAR
    Endif
    WSPECHAR   = WSEPCHR
    Gosub REMOVE_CHAR
    If NOPIV=1
        Wrseq WCHAIN; Using [FPIV]
        ###If NBPIVZON=1 : # VPO 22/10/09 correct si une seule colonne
        ###    Wrseq "" Using [FPIV]
        ###Endif
    #VPO 29/01/10Elsif NOPIV=NBPIVZON
    #VPO 29/01/10    Wrseq WSEPCHR+WCHAIN Using [FPIV]
    Else
        Wrseq WSEPCHR+WCHAIN; Using [FPIV]
    Endif
  Endif
Next
#VPO 29/01/10
Wrseq "" Using [FPIV]
End

#########################################################################
# Enlève un caractère d'une chaine
# alimenter la variable WCHAIN et le caractère WSPECHAR
$REMOVE_CHAR
Local Integer I

I = instr(0,WCHAIN, WSPECHAR)
While (I > 0)
    WCHAIN = left$(WCHAIN,I-1)+right$(WCHAIN,I+1)
    I = instr(0, WCHAIN, WSPECHAR)
Wend

Return

######################################################################
$CHARGEPIVOT
Local Char MYVAL (255)
Local Clbfile MYCLOB(10)
Local Integer MYNB : Raz MYNB

Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs
If WADXIFS_NEW=""
WSEPCHR=";"
Else
WSEPCHR=WADXIFS_NEW
Endif

MYCLOB=LIGCLOB
Raz WPIVVAL
Raz WPIVVALFIC
For NOPIV=1 To NBPIVZON
    POS=instr(1,MYCLOB,WSEPCHR)
    If POS>0
        MYVAL=left$(MYCLOB,POS-1)
        MYCLOB=right$(MYCLOB,POS+1)
        MYNB+=1
    Else
        POS=instr(1,MYCLOB,chr$(13)+chr$(10))
        If POS>0
            MYVAL=left$(MYCLOB,POS-1)
            MYCLOB=MYVAL
        Endif
        POS=instr(1,MYCLOB,chr$(10))
        If POS>0
            MYVAL=left$(MYCLOB,POS-1)
            MYCLOB=MYVAL
        Endif
        POS=instr(1,MYCLOB,chr$(13))
        If POS>0
            MYVAL=left$(MYCLOB,POS-1)
            MYCLOB=MYVAL
        Endif
        MYVAL=MYCLOB
    Endif
    If find(WPIVZON(NOPIV),"PLMATTURL","PLMHISURL","MMSURL")<>0 & MYVAL<>""
        J=instr(1,toupper(MYVAL),"HTTP://")
        If J
            MYVAL=right$(MYVAL,J+7)
        Endif
    Endif
    ##VPO 03/12/09
    ##If WPIVWRK(NOPIV)<>2
        MYVAL=vireblc(MYVAL,1)
        If MYVAL<>"" & WPIVWRK(NOPIV)<>2
           WPIVVALFIC(NOPIV)=WPIVZON(NOPIV)
        Endif
        WPIVVAL(NOPIV)=MYVAL
    ##Endif
Next
If MYNB<NBPIVZON-1
    If dim(NOLIG)>0
    Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG),1) From GESECRAN : # erreur
    Endif
    Call ECR_TRACE(mess(40,7710,1),1) From GESECRAN : # erreur
    Call ECR_TRACE(string$(20,"*"),0) From GESECRAN
    OK=0
    ERR=1
Endif
Return

#####################################################

Funprog GETVAL (CODFIC,CODZON,NBPIVZON,WPIVTABZON,WPIVVAL)
Value Char CODFIC()
Value Char CODZON()
Value Integer NBPIVZON
Value Char WPIVTABZON()(1..NBPIVZON)
Value Char WPIVVAL()(1..NBPIVZON)
I=find(CODFIC+"/"+CODZON,WPIVTABZON(1..NBPIVZON))
If I
    End WPIVVAL(I)
Endif
End ""
#####################################################

Funprog GETVALZON (CODZON,NBPIVZON,WPIVZON,WPIVVAL)
Value Char CODZON()
Value Integer NBPIVZON
Value Char WPIVZON()(1..NBPIVZON)
Value Char WPIVVAL()(1..NBPIVZON)
I=find(CODZON,WPIVZON(1..NBPIVZON))
If I
    End WPIVVAL(I)
Endif
End ""

#####################################################
Subprog SETVAL (CODFIC,CODZON,NBPIVZON,WPIVTABZON,WPIVVAL,WPIVVALFIC,VALCHAR)
Value Char CODFIC()
Value Char CODZON()
Value Integer NBPIVZON
Value Char WPIVTABZON()(1..NBPIVZON)
Variable Char WPIVVAL()(1..NBPIVZON)
Variable Char WPIVVALFIC()(1..NBPIVZON)
Value Char VALCHAR()
I=find(CODFIC+"/"+CODZON,WPIVTABZON(1..NBPIVZON))
If I
    WPIVVAL(I)=VALCHAR
    If VALCHAR<>""
       WPIVVALFIC(I)=CODZON
    Endif
Endif
End

#####################################################
Subprog ASSIGNVAL (CONPIT,TABZON,MSKZON,VALCHAR,OK)
Value Char CONPIT()
Value Char TABZON()
Value Char MSKZON()
Value Char VALCHAR()
Variable Integer OK
Onerrgo ERRASSIGN
    TYP = evalue("type("+MSKZON+")")
    Case TYP
    When 1, 2, 4, 5, 6, 7, 9
       Assign MSKZON With val(VALCHAR)
    When 3
        If vireblc(VALCHAR,1)=""
        Assign MSKZON With [0/0/0]
        Else
        Assign MSKZON With VALCHAR
        Endif
    When Default
       Assign MSKZON With VALCHAR
    Endcase
End
#####################################################
$ERRASSIGN
Onerrgo
If dim(NOLIG)>0
Call ECR_TRACE(mess(10,7710,1)-num$(NOLIG),1) From GESECRAN : # erreur
Endif
Call ECR_TRACE(mess(39,7710,1)-CONPIT+"/"+TABZON-"("+VALCHAR+")",1) From GESECRAN : # erreur
Call ECR_TRACE(string$(20,"*"),0) From GESECRAN
OK=0
Resume
#####################################################
#####################################################

Funprog BOOLEAN (VALMEN1)
Value Integer VALMEN1
If VALMEN1=2
    End 1
Else
    End 0
Endif
End 0
#####################################################
#####################################################
Funprog VALCOL(TYPCOD,VALCOD,LIBCOD)
Value Integer TYPCOD : # menu local 2248
Value Char VALCOD()
Value Char LIBCOD()
If TYPCOD=2 : #Libellé seul
    End LIBCOD
Elsif TYPCOD=3 : #Code et libellé
    End vireblc(VALCOD-LIBCOD,1)
Else : # TYPCOD=1 : #Code seul
    End VALCOD
Endif
End ""

#####################################################
#####################################################
# FQ 65094 GA 06/2010
Subprog FILE_UTF8_BOM (FIRST_LINE)
Variable Clbfile FIRST_LINE

If adxium<>GUTF8 End Endif

Local Clbfile WTEXT(10) : WTEXT=FIRST_LINE

# Le codage UTF8 peut prendre 1,2 ou 3 caractères
# Code ASCII du caractère UTF8 "ï»¿" = 65279
If ascii(mid$(WTEXT,1,1))= 65279
   FIRST_LINE = mid$(WTEXT,2,len(WTEXT)-1)
   Call ECR_TRACE(mess(80,7710,1),-1) From GESECRAN
Endif
End
