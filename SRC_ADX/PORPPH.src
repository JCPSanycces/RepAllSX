THEEND_DEMPPH

End

#69043
#
# Liste des bordereaux de prépa-paie
# pour STATUTS mettre les STA séparés par des virgules : ex : "2,4,6"
#
Subprog GETBDXPPH (MGR, STATUTS, DATDEB, DATFIN, REQNUM, DES, DEMDAT, APLDAT, REQSTA, PVHCOD, PVHDES)
Value Char MGR(), STATUTS()
Value Date DATDEB, DATFIN
Variable Char REQNUM()(0..), DES()(0..), PVHCOD()(0..), PVHDES()(0..)
Variable Date DEMDAT(0..), APLDAT(0..)
Variable Integer REQSTA(0..)
Local Char CRITPPH(250), MANAGER(GLONEML), USER(250), SAVUSR(250)
Local Integer N
Local Char OLDPVHCOD(GLONPVH), OLDPVHDES(30)

If !clalev([F:HRPPH]) : Local File PPREQUESTH [HRPPH] : Endif
If !clalev([F:PVH])   : Local File PPVRALISH [PVH]    : Endif

[L]MANAGER=[L]MGR
If [L]MANAGER <> ""
 [L]USER = func PORPPH.WHOIS(1, [L]MANAGER)
Else
 [L]USER = [V]GUSER
 [L]MANAGER = func PORPPH.WHOIS(2, [L]USER)
Endif

[L]SAVUSR = [V]GUSER
[V]GUSER = [L]USER
Gosub AUTORIS
[V]GUSER = [L]SAVUSR
If [V]GERR : End : Endif

Raz N

[L]CRITPPH="MGR='"+[L]MANAGER+"'"
If [L]STATUTS<>""    : [L]CRITPPH-="& find(REQSTA,"+[L]STATUTS+")<>0" : Endif
If [L]DATDEB>[0/0/0] : [L]CRITPPH-="& DEMDAT>=["+format$(GFMD,[L]DATDEB)+"]" : Endif
If [L]DATFIN>[0/0/0] : [L]CRITPPH-="& DEMDAT<=["+format$(GFMD,[L]DATFIN)+"]" : Endif

For [HRPPH]PPH0 Where evalue([L]CRITPPH)
  If N>=dim([L]REQNUM)
    GERR=1
    Break 2
  Endif
  [L]REQNUM(N) = [HRPPH]REQNUM
  [L]DES(N)    = [HRPPH]DES
  [L]DEMDAT(N) = [HRPPH]DEMDAT
  [L]APLDAT(N) = [HRPPH]APLDAT
  [L]REQSTA(N) = [HRPPH]REQSTA
  [L]PVHCOD(N) = [HRPPH]PVHCOD

  If ([HRPPH]PVHCOD <> [L]OLDPVHCOD)
    Raz [L]OLDPVHDES
    [L]OLDPVHCOD = [HRPPH]PVHCOD
    Read [PVH]PVH0 = GCURLEG;[L]OLDPVHCOD
    If !fstat
      [L]OLDPVHDES = [PVH]PVHDES
    Endif
  Endif
  [L]PVHDES(N) = [L]OLDPVHDES

  N+=1
Next
If [V]GERR
  [V]GMESSAGE="GETBDXPPH :"-func AFNC.MES1(mess(80,10701,1),num$(N))
  #           Dimension des variables inférieure à $1$
Endif
End


#
# Liste des variables des demandes de prépa-paie
# pour STATUTS mettre les STA séparés par des virgules : ex : "2,4,6"
#
Subprog GETVARPPH(NUMDEM, MANAGER, PVHCOD, DATDEB, DATFIN, STATUTS, REQNUM, DES, MGR, LIBSTABDX, DEMDAT, APLDAT, VRACOD, VRADES, STA, LIBSTA)
Value Char NUMDEM(), MANAGER(), PVHCOD()
Value Date DATDEB, DATFIN
Value Char STATUTS()
Variable Char REQNUM()(0..), DES()(0..), MGR()(0..)
Variable Char VRACOD()(0..), VRADES()(0..)
Variable Integer STA(0..)
Variable Char LIBSTABDX()(0..), LIBSTA()(0..)
Variable Date DEMDAT(0..), APLDAT(0..)
Local Char CRITPPH(250), CRITPPD(250)
Local Char LMGR(GLONEML), USER(250), SAVUSR(250)
Local Integer N, I, J
Local Char VRACODSTA(20)(0..999), LVRACOD(GLONVRA)(0..999)
Local Integer LSTA(0..999)

If !clalev([F:HRPPH]) : Local File PPREQUESTH [HRPPH] : Endif
If !clalev([F:HRPPD])   : Local File PPREQUESTD [HRPPD]   : Endif
If !clalev([F:VRA])   : Local File VARIA [VRA]        : Endif

[L]LMGR=[L]MANAGER
If [L]LMGR <> ""
 [L]USER = func PORPPH.WHOIS(1, [L]LMGR)
Else
 [L]USER = [V]GUSER
 [L]LMGR = func PORPPH.WHOIS(2, [L]USER)
Endif

[L]SAVUSR = [V]GUSER
[V]GUSER = [L]USER
Gosub AUTORIS
[V]GUSER = [L]SAVUSR
If [V]GERR : End : Endif

Raz N

If [L]NUMDEM<>""
  [L]CRITPPH="REQNUM='"+[L]NUMDEM+"'"
Else
  [L]CRITPPH="MGR='"+[L]LMGR+"'"
  If [L]PVHCOD<>""     : [L]CRITPPH-="& PVHCOD='"+[L]PVHCOD+"'" : Endif
  If [L]DATDEB>[0/0/0] : [L]CRITPPH-="& DEMDAT>=["+format$(GFMD,[L]DATDEB)+"]" : Endif
  If [L]DATFIN>[0/0/0] : [L]CRITPPH-="& DEMDAT<=["+format$(GFMD,[L]DATFIN)+"]" : Endif
Endif

[L]CRITPPD="1=1"
If [L]STATUTS<>"" : [L]CRITPPD="find(STA,"+[L]STATUTS+")<>0" : Endif

Local Integer CREAGLOB
Gosub INIT_CHECK_SUBORD From DIVPAYE
For [HRPPH]PPH0 Where evalue([L]CRITPPH)
  Raz [L]J, [L]VRACODSTA
  Filter [F:HRPPD] Where [F:HRPPD]REQNUM=[F:HRPPH]REQNUM & evalue([L]CRITPPD)
&   Order By [F:HRPPD]VRACOD;[F:HRPPD]STA
  For [F:HRPPD]
    If [L]J >= dim([L]VRACODSTA)
      Break
    Endif
    Call CHECK_SUBORD([F:HRPPD]REFNUM,"",[V]GFLXPORCCG,[31/12/9999])From DIVPAYE
    If !mkstat & [HRPPD]STA<>2
      If !find([HRPPD]VRACOD+"|"+num$([HRPPD]STA), [L]VRACODSTA)
        [L]VRACODSTA([L]J) = [HRPPD]VRACOD+"|"+num$([HRPPD]STA)
        [L]LVRACOD([L]J) = [HRPPD]VRACOD
        [L]LSTA([L]J) = [HRPPD]STA
        [L]J+=1
      Endif
    Endif
  Next
  Filter [F:HRPPD]
  J-=1
  For [L]I=0 To J
    If [L]N >= dim([L]REQNUM)
      GERR = 1
      Break 2
    Endif
    [L]REQNUM([L]N)   = [HRPPH]REQNUM
    [L]DES([L]N)      = [HRPPH]DES
    [L]MGR([L]N)      = [HRPPH]MGR
    [L]LIBSTABDX([L]N)= mess([HRPPH]REQSTA,10641,1)
    [L]DEMDAT([L]N)   = [HRPPH]DEMDAT
    [L]APLDAT([L]N)   = [HRPPH]APLDAT
    [L]VRACOD([L]N)   = [L]LVRACOD([L]I)
    [L]STA([L]N)      = [L]LSTA([L]I)
    [L]LIBSTA([L]N)   = mess([L]STA([L]N),10640,1)

    #Read[F:VRA]VRA0 = [L]VRACOD([L]N)
    #If !fstat
     #[L]VRADES([L]N) = [F:VRA]DES
    #Endif
    Call LECTEXTRA([L]VRADES([L]N),"VARIA","DES",GCURLEG,[L]VRACOD([L]N)) From ATEXTRA
    N+=1
  Next
Next
Filter [F:HRPPH]
If CREAGLOB :  Kill GDONOTCLOSE , GSVFLUX , GTTYPMGR : Endif

If [V]GERR
  [V]GMESSAGE="GETVARPPH :"-func AFNC.MES1(mess(80,10701,1),num$(N))
  #           Dimension des variables inférieure à $1$
Endif
End

#
# Synthèse des bordereaux de prépa paie.
#
Subprog GETSYNPPH(REQNUM, VRACOD, VRADES, DEMAMT, NBVRA, NBBRO, NBINA
&                 , NBDEM, NBREF, NBACP, NBPEC)
Value Char REQNUM()
Variable Char VRACOD()(0..), VRADES()(0..)
Variable Decimal DEMAMT(0..)
Variable Integer NBVRA(0..), NBBRO(0..), NBINA(0..), NBDEM(0..)
Variable Integer NBREF(0..), NBACP(0..), NBPEC(0..)
Local Char LVRACOD(GLONVRA)(1..999)
Local Decimal LVRAMT(1..999)
Local Integer LVRANB(1..999,7)
Local Integer N, J

Gosub AUTORIS
If GERR : End : Endif

If [L]REQNUM = ""
  [V]GMESSAGE="GETSYNPPH :"-mess(148,10717,1)
  [V]GERR=1 : End
Endif

If !clalev([F:HRPPD]) : Local File PPREQUESTD [HRPPD] : Endif
If !clalev([F:VRA]) : Local File VARIA [VRA] : Endif

Raz [L]N
[L]J=1
Gosub GET_PPDSTA From TRTPREPAY

Filter [F:HRPPD] Where REQNUM=[L]REQNUM
For [HRPPD]PPD0
  If [L]J-1 >= dim([L]VRACOD)
    GERR=1
    Break
  Endif
  [L]N = find([HRPPD]VRACOD, [L]LVRACOD)
  If [L]N=0
    [L]LVRACOD([L]J)=[HRPPD]VRACOD
    [L]N=[L]J
    [L]J+=1
  Endif
  [L]LVRAMT([L]N)+= [HRPPD]DEMAMT

  If [HRPPD]DEMAMT <> 0
    LVRANB([L]N,0) += 1
  Endif

  Case [HRPPD]STA
    When [L]PPDSTA_BROUILLON
        If [HRPPD]DEMAMT <> 0 : [L]LVRANB([L]N,1) += 1 : Endif
    When [L]PPDSTA_INACTIF
        [L]LVRANB([L]N,2) += 1
    When [L]PPDSTA_DEMANDE
        [L]LVRANB([L]N,3) += 1
    When [L]PPDSTA_REFUSE
        [L]LVRANB([L]N,4) += 1
    When [L]PPDSTA_ACCEPTE
        [L]LVRANB([L]N,5) += 1
    When [L]PPDSTA_PRISENCOMPTE
        [L]LVRANB([L]N,6) += 1
  Endcase
Next
Filter [F:HRPPD]

Raz [L]N
[L]J-=1

If [L]J < dim([L]VRACOD)
  While [L]N < [L]J
    [L]VRACOD([L]N) = [L]LVRACOD([L]N+1)
    [L]DEMAMT([L]N) = [L]LVRAMT([L]N+1)
    [L]NBVRA([L]N)  = [L]LVRANB([L]N+1,0)
    [L]NBBRO([L]N)  = [L]LVRANB([L]N+1,1)
    [L]NBINA([L]N)  = [L]LVRANB([L]N+1,2)
    [L]NBDEM([L]N)  = [L]LVRANB([L]N+1,3)
    [L]NBREF([L]N)  = [L]LVRANB([L]N+1,4)
    [L]NBACP([L]N)  = [L]LVRANB([L]N+1,5)
    [L]NBPEC([L]N)  = [L]LVRANB([L]N+1,6)
    #Read [VRA]VRA0 = [L]LVRACOD([L]N+1)
    #If !fstat
    #  [L]VRADES([L]N) = [VRA]DES
    #Endif
    Call LECTEXTRA([L]VRADES([L]N),"VARIA","DES",GCURLEG,[L]LVRACOD([L]N+1)) From ATEXTRA
    N+=1
  Wend
Endif

If [V]GERR
  [V]GMESSAGE="GETSYNPPH :"-func AFNC.MES1(mess(80,10701,1),num$(N))
  #           Dimension des variables inférieure à $1$
Endif

End
#end 69043
