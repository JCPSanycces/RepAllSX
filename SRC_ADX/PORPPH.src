#<AdxTL>@(#)5.0.0.0 $Revision$
#---------------------------------------------------
# PORPPH : Interfaces portail pour préparation paye
#---------------------------------------------------

Local Char REFNUM(50)
Local Char TPVHCOD(15)(10), TPVHDESC(30)(10)
Local Char TCRICPY(5)(10), TCRIFCY(5)(10), TCRISRV(5)(10), TCRIPRF(5)(10), TCRIPOP(15)(10)
Local Integer I

[L]REFNUM = "FRED"

Call OUVRE_TRACE("Test GETLSTPVH") From LECFIC

Call GETLSTPVH (REFNUM, TPVHCOD, TPVHDESC, TCRICPY, TCRIFCY, TCRISRV, TCRIPRF, TCRIPOP)

For [L]I = 0 To dim([L]TPVHCOD) - 1
    If [L]TPVHCOD([L]I) = "" : Break : Endif
    Call ECR_TRACE([L]TPVHCOD([L]I)-[L]TPVHDESC([L]I), 0) From GESECRAN
Next
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

End

# ------------------------------------------------------------------ #
#         Check of the rigths       USER / FUNCTION                  #
#                                   USER / PERSONNEL ID              #
#                                                                    #
#         Vérification des droits   USER / FONCTION                  #
#                                   USER / MATRICULE                 #
# ------------------------------------------------------------------ #
$AUTORIS

If !clalev([F:ID])  : Local File EMPLOID [ID]  : Endif
If !clalev([F:ACC]) : Local File ACCES   [ACC] : Endif

If [V]GFONCTION<>"PRHPPH"
 [V]GFONCTION="PRHPPH"
 Call AUTORIS From EXEFNC
Endif

If GNBAUZ = 0
 GMESSAGE = mess(74,100,1)-"("+GFONCTION+")" : # Fonction non autorisée
 GERR = 1
Endif

If dim(GUSR_SRVAUT) < 1
 Global Char    GUSR_SRVAUT(GLONAUS)
Endif
If GUSR_SRVAUT <> GUSER
 GUSR_SRVAUT = GUSER
 Call AUTSRV From GLOBPAY
Endif

If dim([L]MATRICULE)>0 & [L]MATRICULE<>[V]GREFNUM & !GERR
 Call DROIT(MATRICULE,"","","") From DIVPAYE
 If GMESSAGE <> ""
  GMESSAGE -= "("-MATRICULE-")"
 Endif
Endif

Return

# ------------------------------------------------------------------ #
#         List of the lists of variables                             #
#         Liste des Listes de variables                              #
# ------------------------------------------------------------------ #
Subprog GETLSTPVH (REFNUM, TPVHCOD, TPVHDESC, TCRICPY, TCRIFCY, TCRISRV, TCRIPRF, TCRIPOP)
Value Char REFNUM()
Variable Char TPVHCOD()(), TPVHDESC()()
Variable Char TCRICPY()(), TCRIFCY()(), TCRISRV()(), TCRIPRF()(), TCRIPOP()()

Gosub AUTORIS
If GERR : End : Endif

If !clalev([F:PVH])  : Local File PPVRALISH [PVH]  : Endif
If !clalev([F:WACC]) : Local File ACCES     [WACC] : Endif
If !clalev([F:WAUS]) : Local File AUTILIS   [WAUS] : Endif

Local Integer NBPPH, OK
Local Char USER(250)

# Récupérer le "GUSER" correspondant au REFNUM afin de pouvoir filtrer sur le code d'accès présent sur PVH

If [L]REFNUM <> ""
 [L]USER = func PORPPH.WHOIS(1, [L]REFNUM)
Else
 [L]USER = GUSER
Endif

Read [F:WAUS]CODUSR = [L]USER
If fstat = 0
    Raz [L]NBPPH

    For [F:PVH]PVH0 Where [F:PVH]ENAFLG = 2 and [F:PVH]LEG = GCURLEG
        [L]OK = 1
        If [F:PVH]CODACS <> ""
            If [F:WAUS]ALLACS = 2
                [L]OK = 2
            Else
                Read [F:WACC]CODACC = [L]USER ; [F:PVH]CODACS
                If fstat = 0 & find(2, [F:WACC]CONSUL, [F:WACC]MODIF, [F:WACC]EXEC)
                    [L]OK = 2
                Endif
            Endif
        Else
            [L]OK = 2
        Endif
        If [L]OK = 2
            [L]TPVHCOD([L]NBPPH) = [F:PVH]PVHCOD
            [L]TPVHDESC([L]NBPPH) = [F:PVH]PVHDES
            [L]TCRICPY([L]NBPPH) = [F:PVH]CRICPY
            [L]TCRIFCY([L]NBPPH) = [F:PVH]CRIFCY
            [L]TCRISRV([L]NBPPH) = [F:PVH]CRISRV
            [L]TCRIPRF([L]NBPPH) = [F:PVH]CRIPRF
            [L]TCRIPOP([L]NBPPH) = [F:PVH]CRIPOP
            [L]NBPPH += 1
        Endif
    Next
Endif

End

Funprog WHOIS(MODE, ID)
Value Integer MODE
Value Char ID()

Local File ADOVALAUS [WADU]

Local Char WHOIS(250)
Raz [L]WHOIS

Case [L]MODE
    When 1
        # On a un matricule, on veut le user
        Filter [F:WADU] Where [F:WADU]PARAM = "REFNUM"
&                        & [F:WADU]VALEUR = [L]ID
        Read [F:WADU]ADU0 First
        If fstat = 0
            [L]WHOIS = [F:WADU]CODUSR
        Endif
    When 2
        # On a un user, on veut le matricule
        Filter [F:WADU] Where [F:WADU]PARAM = "REFNUM"
&                        & [F:WADU]CODUSR = [L]ID
        Read [F:WADU]ADU0 First
        If fstat = 0
            [L]WHOIS = [F:WADU]VALEUR
        Endif
Endcase

Filter [WADU]

End [L]WHOIS

# ------------------------------------------------------------------ #
#         Read of a list of variables                                #
#         Lecture d'une Liste de variables                           #
# ------------------------------------------------------------------ #
Subprog GETPVH (PVHCOD,VRADES,VRACOD)
Value    Char PVHCOD()
Variable Char VRADES()(0..)
Variable Char VRACOD()(0..)

Gosub AUTORIS
If GERR : End : Endif

If !clalev([F:PVH]) : Local File PPVRALISH [PVH] : Endif
If !clalev([F:HRPVD]) : Local File PPVRALISD [HRPVD] : Endif
If !clalev([F:ACC]) : Local File ACCES     [ACC] : Endif

Local Integer N

Read [PVH]PVH0 = GCURLEG;[L]PVHCOD
If fstat>1
 GMESSAGE = [L]PVHCOD-":"-mess(23,100,1) : # Fiche inexistante
 GERR     = 1
 End
Endif

Link   [F:HRPVD] With  [F:PVH]PVH0   = [F:HRPVD]LEG;[F:HRPVD]PVHCOD
&                   ,[F:ACC]CODACC = GUSER;[F:PVH]CODACS
&              As    [LNK]

Filter [F:LNK] Where [F:PVH]PVHCOD = [L]PVHCOD
&                 &  [F:PVH]ENAFLG = 2
&                 & ([F:PVH]CODACT = "" | func AFNC.ACTIV([F:PVH]CODACT))
&                 & ([F:PVH]CODACS = "" | GUSRACS=2
&                                       | [F:ACC]CONSUL=2 | [F:ACC]MODIF=2 | [F:ACC]EXEC=2)

Raz N

For  [LNK]
 If N >= dim([L]VRACOD)
  GERR = 1
  Break
 Endif

 [L]VRACOD(N) = [F:HRPVD]VRACOD
 [L]VRADES(N) = [F:HRPVD]CROINPDES

 N += 1
Next

Filter [HRPVD]

If GERR
 GMESSAGE = "GETPVH :"-func AFNC.MES1(mess(80,10701,1),num$(N))
 #           Dimension des variables inférieure à $1$
Endif

End

# ------------------------------------------------------------------ #
#         Mise à jour de bordereau de préparation de paie            #
#            n lignes , même action pour les n lignes                #
# ------------------------------------------------------------------ #

Subprog SEMDEMPPH2( ACTION,MGR,REQNUM,REQSTA,PVHCOD,DEMDAT,APLDAT,DES,PYRDAT
&                  , CRICPY,CRIFCY,CRISRV,CRIPRF,CRIPOP,CMT
&                  , REFN,CTRN,MSGERR,MSGWARN
&                  , NUMLIG,IDPPD,REFNUM,CTRNUM,NAM
&                  , VRACOD,VRADES,DEMAMT,ACPAMT,VRACMT
&                  , STA,BUL
&                 )

Value    Char    ACTION(), MGR(),PVHCOD(),DES(),CMT()
Value    Char    CRICPY(),CRIFCY(),CRISRV(),CRIPRF(),CRIPOP()
Variable Date    DEMDAT, APLDAT,PYRDAT
Variable Integer REQNUM, REQSTA
Variable Char    REFN()(0..),CTRN()(0..),MSGERR()(0..),MSGWARN()(0..)
Variable Integer NUMLIG(0..),IDPPD(0..),STA(0..)
Variable Char    REFNUM()(0..),CTRNUM()(0..),NAM()(0..),BUL()(0..)
Variable Char    VRACOD()(0..),VRADES()(0..),VRACMT()(0..)
Variable Decimal DEMAMT(0..),ACPAMT(0..)

Local Shortint   I, J, E, D
Local Integer    SAV_GWSTAT

If !clalev([F:HRPPH]) : Local File PPREQUESTH   [HRPPH] : Endif
If !clalev([F:HRPPD]) : Local File PPREQUESTD   [HRPPD] : Endif

D-=1
Raz GERR


Trbegin [HRPPD]
 While I<D

   SV_GWSTAT = GW_STAT

#   Call SETDEMPPD( ACTION,MGR,REQNUM,REQSTA,PVHCOD,DEMDAT,APLDAT,DES,PYRDAT
#&                  , CRICPY,CRIFCY,CRISRV,CRIPRF,CRIPOP,CMT
#&                  , REFN(I..D),CTRN(I..D)
#&                  , NUMLIG(I..D),IDPPD(I..D),REFNUM(I..D),CTRNUM(I..D),NAM(I..D)
#&                  , VRACOD(I..D),VRADES(I..D),DEMAMT(I..D),ACPAMT(I..D),VRACMT(I..D)
#&                  , STA(I..D),BUL(I..D)
#&                 )

   If [V]GERR
    E           +=1
    If GMESSAGE = "" & GW_STAT <> SV_GWSTAT : # Si AFF From GSAISIE a effacé GMESSAGE on peut le retrouver dans GW_MESS(70120)
     GMESSAGE = GW_MESS(GW_STAT)
     Raz GW_MESS(GW_STAT)  : # Si on ne fait pas ça les messages sont affichés 2 fois
    Endif
    [L]MSGERR(I) =[V]GMESSAGE
    Raz [V]GMESSAGE, [V]GERR
    Break #75663 Useless to show several times the same message
   Endif
   # 1 ligne en entrée peut donner n lignes en sortie
   Repeat : I+=1 : Until I=D | [L]REFNUM(I)=""
   If I=D
    E           +=1
    [L]MSGERR(I) ="SETDEMPPH2 :"-func AFNC.MES1(mess(80,10701,1),num$(D+1))
    #             Dimension des variables inférieure à $1$
    Break
   Endif


 Wend
 If E
  Rollback
  GMESSAGE=mess(99,116,1)-num$(E) : # Nombre d'erreurs
  GERR    =1
 Else
  Commit
 Endif

End

# ------------------------------------------------------------------ #
#         Update of a slip draft                                     #
#                                                                    #
# Actions : CREATE , MODIFY                                          #
#         + VERIFY : test of the validity of the employees list      #
#                               -----                                #
#         Mise à jour de bordereau de préparation de paie            #
# !!!! revu !!!! On reçoit une ligne pour                                           #
# !!!! revu !!!!    - un manager, un matricule, une liste de variable                #
# !!!! revu !!!!  On en renvoie n                                                    #
# !!!! revu !!!!   - une par variable                                               #
#                                                                    #
# Actions : CREATE , MODIFY                                          #
#         + VERIFY : test de validité de la liste de salarié         #
# ------------------------------------------------------------------ #
Subprog SETDEMPPH ( ACTION,MGR,REQNUM,REQSTA,PVHCOD,DEMDAT,APLDAT,DES,PYRDAT
&                  , CRICPY,CRIFCY,CRISRV,CRIPRF,CRIPOP,CMT
&                  , REFN,CTRN
&                  , NUMLIG,IDPPD,REFNUM,CTRNUM,NAM
&                  , VRACOD,VRADES,DEMAMT,ACPAMT,VRACMT
&                  , STA,BUL
&                 )
Value    Char    ACTION(), MGR(),PVHCOD(),DES(),CMT()
Value    Char    CRICPY(),CRIFCY(),CRISRV(),CRIPRF(),CRIPOP()
Variable Date    DEMDAT, APLDAT,PYRDAT
Variable Integer REQNUM, REQSTA
Variable Char    REFN()(0..),CTRN()(0..)
Variable Integer NUMLIG(0..),IDPPD(0..),STA(0..)
Variable Char    REFNUM()(0..),CTRNUM()(0..),NAM()(0..),BUL()(0..)
Variable Char    VRACOD()(0..),VRADES()(0..),VRACMT()(0..)
Variable Decimal DEMAMT(0..),ACPAMT(0..)

Local    Char    MATRICULE([V]GLONEML)

Gosub OUVRE From WOPPH
If !clalev([F:ID])   : Local File EMPLOID  [ID]   : Endif
If !clalev([F:ACC])  : Local File ACCES    [ACC]  : Endif
If !clalev([F:CTRW]) : Local File EMPLOCTR [CTRW] : Endif

Gosub INIT_CHECK_SUBORD From DIVPAYE

GMOIPAY=gdat$(func DIVPAYE.INIPARUSR("MOIPAY","",""))
If GMOIPAY=[0/0/0] : GMOIPAY=gdat$(01,month(date$),year(date$)) : Endif

If [L]MGR = ""
 [L]MGR = GREFNUM
Endif

[L]MATRICULE = [L]MGR

Read [ID]ID0 = [L]MATRICULE
If !fstat & [F:ID]ENAFLG<2
 GMESSAGE = mess(100,10717,1)-"("-MATRICULE-")" : # Ce salarié est inactif
 GERR     = 1
 Goto THEEND_DEMPPH
Endif

Gosub AUTORIS
If [V]GERR : Goto THEEND_DEMPPH : Endif
# There's no site authorization to be check
Case [L]ACTION
  When "CREATE"                     : If !instr(1,GUSRAUZ,"C") : GERR=1 : Endif
  When "MODIFY" , "VERIFY" , "SEND" : If !instr(1,GUSRAUZ,"M") : GERR=1 : Endif
Endcase
If GERR
 GMESSAGE=mess(99,9009,1) : # Action non autorisée
 Goto THEEND_DEMPPH
Endif

If [L]ACTION <> "CREATE"
 Filter [HRPPH] Where REQNUM=[L]REQNUM
 Read [HRPPH] First
 Filter [HRPPH]
 If fstat
  [V]GMESSAGE=mess(23,100,1) : # Fiche inexistante
  [V]GERR    =1
  End
 Elsif ([F:EXS]EXSSTA>1 | [F:EXS]STA=2) & [L]ACTION<>"READ"
  [V]GMESSAGE=mess(26,10718,1) : # La note de frais n'est plus en statut brouillon
  [V]GERR    =1
  End
 Endif

 [L]CLECUR2(1)=[L]REFNUM
 [L]CLECUR2(2)=[L]CTRNUM
 [L]CLECUR2(3)="1"
Endif

If !find([L]ACTION,"CREATE","READ")
 [L]SYMBOLE="EXS"+num$([L]EXSNUM)+"\"+[L]REFNUM+"\"+[L]CTRNUM
 Lock =[L]SYMBOLE
 If fstat
  [V]GMESSAGE=mess(98,126,1) : # La fiche est utilisée par un autre utilisateur
  [V]GERR    =1
  End
 Endif
Endif

