#<AdxTL>@(#)6.0.0.0 $Revision$
####################################################################
# IMPSOL : traitement correspondant au modèle d'import / export SOL
#          (solutions du support client)
# - 25/09/2008 : SYMEU
####################################################################

$ACTION
Case ACTION
  When "IMP_OUVRE"     : Gosub IMP_OUVRE
  When "IMPORT"        : Gosub IMPORT
Endcase
Return

####################################################################
# Au début de l'import
####################################################################
$IMP_OUVRE

Local Integer NBOCC
Return

####################################################################
# A chaque chargement de la classe F à partir du fichier d'import
####################################################################
$IMPORT

Case IMPFIC
    When "SOL"
        # Alimentation du tableau des mots-clés
        [M:SOL3]NBWRD=0
        For NBOCC=1 To dim([F:SOL]KEYWRD)
          If evalue("[F:SOL]KEYWRD("+num$(NBOCC-1)+ ")") <>"" Then
            [M:SOL3]KEYWRD(NBOCC-1)=evalue("[F:SOL]KEYWRD("+num$(NBOCC-1)+ ")")
            [M:SOL3]NBWRD+=1
          Else
            Break        
          Endif
        Next
  
        # Alimentation du tableau des solutions
        [M:SOL4]NBLIG=0
        For NBOCC=1 To dim([F:SOL]CODSOL)
          If evalue("[F:SOL]CODSOL("+num$(NBOCC-1)+ ")") <>"" Then
            [M:SOL4]CODSOL(NBOCC-1)=evalue("[F:SOL]CODSOL("+num$(NBOCC-1)+ ")")
            [M:SOL4]NBLIG+=1
          Else
            Break        
          Endif
        Next

        # Renseignement de nolign avec la plus petite des 2 variables de bas de tableau. 
        # Cela peut paraître bizarre, mais si on prend la plus grande valeur, il y a une
        # erreur à l'import (zone indicée obligatoire).
        # De toute façon, comment faire avec un seul nolign pour 2 tableaux ?
        nolign=min([M:SOL3]NBWRD,[M:SOL4]NBLIG)

    When "HD3"
        # Affectation du clob de la description de la solution
        [M:SOL2]SOLFULDES=[F:HD3]CLOB
Endcase
Return
