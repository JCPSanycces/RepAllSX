#<AdxTL>@(#)0.0.0.0 $Revision$Class Function code
# Supervisor
## ATY-ATYPE ## EFN
# 2018-11-09 07:14:10 193

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,CODINT,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char CODINT
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File AFONCTION [AFC]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".AFONCTION" [AFC]
Endif

Default File [F:AFC]
Read [F:AFC]CODINT = [L]CODINT
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]CODINT)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]CODINT)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


