#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
 Case ACTION
    When 'BOUTON' : Gosub BOUTON
    When 'FIN'  : Gosub FIN
    When 'OUVRE'  : Gosub OUVRE
    When 'OK' : Gosub OK
  Endcase
Return


#-----------------------------------------------------------------------------#
$FIN

Return

#-----------------------------------------------------------------------------#
$OUVRE

Return
#-----------------------------------------------------------------------------#
$OK


Return
#-----------------------------------------------------------------------------#

$BOUTON
  Case BOUT
    When 'R' : Gosub GENREPORT
    When 'S' : Gosub SEARCH
  Endcase
Return

#-----------------------------------------------------------------------------#
$SEARCH

If clalev([F:WHR]) = 0 Local File WHTHDR[WHR] : Endif

Local Char FSTRING(255)

#clear grid
Raz [M:WHTA]NBLIG
Affzo [M:WHTA]

FSTRING = 'RPTTYP = 1 '

#if company is selected
If [M:WHTA]CPY <> ''
  FSTRING += ' and (CPY >= [M:WHTA]SCPY)'
Endif

#if site is selected
If [M:WHTA]FCY <> ''
  FSTRING += ' and (FCY >= [M:WHTA]SFCY)'
Endif

#if report number is selected
If [M:WHTA]SRPTNUM <> ''
  FSTRING += ' and (RPTNUM = [M:WHTA]RPTNUM)'
Endif

#if date is selected
If num$([M:WHTA]DAT) <> '00/00/0000'
  FSTRING += ' and (RUNDAT = [M:WHTA]DAT)'
Endif

  Filter[F:WHR] Where evalue(FSTRING)

nolign = 0
For [F:WHR]
  nolign +=1
  [M:WHTA] = [F:WHR]
Next

[M:WHTA]NBLIG = nolign

Affzo [M:WHTA]

Return


#-----------------------------------------------------------------------------#

$GENREPORT

Local Integer RPT
Local Integer NBPAR_MAX : NBPAR_MAX=10
Local Char XTBPAR(20)(1..NBPAR_MAX)
Local Char XTBVAL(250)(1..NBPAR_MAX)
Local Char XREPNUM : XREPNUM = 'AUSWHT'
Local Char XDESTINATION : XDESTINATION = 'PREVIEW' #3 PREVISU / MESSPDF
#find the selected report.
RPT = find(2,[M:WHTA]SELECT)

If RPT > 0
  XTBPAR(1)="RPTNUM" : XTBVAL(1) = [M:WHTA]RPTNUM(RPT-1)
  Call ETAT(XREPNUM,"",XTBPAR,XTBVAL) From ETAT
 #Call ETAT(XREPNUM, XDESTINATION,"",0,"",XTBPAR,XTBVAL) From AIMP3

Endif

Return
######################################################################################
## Section automatically added (screen WHTA0) 08/23/2016 14:51:55 (JAMUL)
######################################################################################
Subprog AM_SELECT(VALEUR)
Variable Integer VALEUR

Local Integer RPT
If VALEUR = 2
  RPT = find(2,[M:WHTA]SELECT) - 1
    If RPT > 0
     GMESSAGE  = mess(13,7704,1)
     GERR = 1
     VALEUR = 1
   Endif
Endif

End


######################################################################################




