#<AdxTL>@(#)8.0.0.0 $Revision$
Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AINITEXTRA","AINITEXTRA",3,"") From GTRAITE
End

#----------------------------------------------------#
$ACTION
Case ACTION
 When "EXEC"        : Gosub EXEC
 When "AVANT_PAR"   : Gosub AVANT_PAR
 When Default
Endcase
Return

$AVANT_PAR
TIT = mess(77,127,1) : #  Initialisation des textes traduisibles
TMP = 1
TRA = 1
Return

Subprog C_LANDES(VALEUR)
Variable Char    VALEUR()
If [M:DIA]LANORI = VALEUR
 GMESSAGE = mess(63,176,1) : # La langue de référence et la langue de traduction doivent être différentes.
 mkstat = 2 :  End
Endif
End


$EXEC
Local File =[M:DIA]DOSSIER+".ATEXTRA" [AXX_] 
Local File =[M:DIA]DOSSIER+".ATEXTRA" [AXX2]
Local Integer I
If !GSERVEUR
 Call OUVRE_TRACE([L]TIT) From LECFIC
Endif
Call ECR_TRACE(mess(77,127,1)-":",0) From GESECRAN
Call DEBTRANS From GLOCK
Gosub TR_INI
Close Local File [AXX_], [AXX2]
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

$TR_INI
GOK = 1
Trbegin [AXX_]
For [F:AXX2]AXX0(1) Where LANGUE=[M:DIA]LANORI
 I=0
 For [F:AXX2]AXX0
  Read [AXX_]AXX0 = [F:AXX2]CODFIC;[F:AXX2]ZONE;[M:DIA]LANDES;[F:AXX2]IDENT1;[F:AXX2]IDENT2
  If fstat
   I += 1
   [F:AXX_] = [F:AXX2]
   [F:AXX_]LANGUE = [M:DIA]LANDES
   Write [F:AXX_]
   If fstat
    GOK = 0 : Call FSTA("AXX_") From GLOCK : Break 2
   Endif
  Endif
 Next AXX2
 If I
  Call ECR_TRACE(space$(10)-mess(56,123,1)-[F:AXX2]CODFIC-":"-num$(I)-mess(103,141,1),0) From GESECRAN
 Endif
Next AXX2
If   GOK<0 : Goto ROLL_TR_INI
Elsif !GOK : Goto AB_TR_INI
Endif
Commit
Return

$AB_TR_INI
Rollback
Return

$ROLL_TR_INI
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_INI : Endif
######################################################################################

