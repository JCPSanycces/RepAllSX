#<AdxTL>@(#)4.0.0.0 $Revision$
####################################################################################
# Program Name: SUBPAYS
# Description : Payment Proposal Control Currency Summary
# Author      : GRNA
####################################################################################


####################################################################################
$ACTION

Case ACTION
  When "DEBUT"      : Gosub DEBUT
  When Default
Endcase

Return


####################################################################################
$DEBUT

Raz [M:PCS]

[M:PCS]TOTAMTCPY = [M:PCL]TOTAMTCPY
[M:PCS]CURCPY    = [M:PCL]CURCPY

For NOL=0 To [M:PCL]NBLIG-1
  If [M:PCL]TYPLIN(NOL)=1  
    CURLIN = find([M:PCL]CUR(NOL),[M:PCS]CUR(0..[M:PCS]NBCUR-1))
    If CURLIN
      [M:PCS]AMTCUR(CURLIN-1) += [M:PCL]AMTCUR(NOL)
      If [M:PCL]AMTCUR(NOL)<>0                  # GRNA 18.08.11
        [M:PCS]NBRPAY(CURLIN-1) += 1  
      Endif                                     # GRNA 18.08.11
    Else
      [M:PCS]CUR([M:PCS]NBCUR)    = [M:PCL]CUR(NOL)
      [M:PCS]NBRPAY([M:PCS]NBCUR) = 1
      [M:PCS]AMTCUR([M:PCS]NBCUR) = [M:PCL]AMTCUR(NOL)
      If [M:PCL]AMTCUR(NOL)<>0                  # GRNA 18.08.11
        [M:PCS]NBCUR += 1 
      Endif                                     # GRNA 18.08.11
    Endif
  Endif
Next

Affzo [M:PCS]

Return


# Called from SUBPAYC, PAYPROPAL
######################################################################################
$PAY_SORT

# Set sort order
Case [M:DIA]ORDRE
 When 1 : Filter [TP2] Order By Key CLE=BPR;AMTLOC     # Business Partner
 When 2 : Filter [TP2] Order By Key CLE=toupper(BPRNAM);AMTLOC  # Trade Name  # 93332.n toupper
 When 3 : Filter [TP2] Order By Key CLE=PAYTYP;AMTLOC  # Transaction
 When 4 : Filter [TP2] Order By Key CLE=DUDDAT;AMTLOC  # Open Item
Endcase

Return


# Called from SUBPAYC
####################################################################################
$PAYC_AMTLOC

If [M:PCL]CUR(nolign-1)=[L]DEVLED : [M:PCL]AMTLOC(nolign-1) = [M:PCL]AMTCUR(nolign-1) 
Else 
 Call CONVERT([M:PCL]CUR(nolign-1),DEVLED,DEVLED,[F:TPY]RATTYP,[M:DIA]ACCDAT,
&             [M:PCL]AMTCUR(nolign-1),[M:PCL]AMTLOC(nolign-1),[L]STAT) From TRTDEV
 If [L]STAT
  # Pas de cours de devise [M:PCL]CUR(nolign-1) -> DEVLED
  Call ECR_TRACE(mess(16,114,1)-[M:PCL]CUR(nolign-1)-"->"-DEVLED-"("+format$("D:"+GFMDAT,[M:DIA]ACCDAT)-")",1) From GESECRAN
  GOK=0 : Break 2
 Endif
Endif

Return


