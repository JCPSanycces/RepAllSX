#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################################################
# Handling of DETFUP mask : details of open items to be reminded for a specific BP
##########################################################################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
GERR = 0
GPROG    = "TRTCFUP"
GTYPPROG = 4
GWINDOW  = "DFUP"
GWINCRIT = "CRITFUP"
Call TRAITE_CHAR(VALEUR,PARAM,GWINDOW,GPROG,GWINCRIT,GTYPPROG,"") From GTRAITE
End

##########################################################################################################

$ACTION
# when returning from actions SEL, DESEL or INVSEL, $SETBOUT MUST be called
If (ACTION="BB3_NBLIG" or ACTION="BB4_NBLIG" or ACTION="BB5_NBLIG") and find(2,[M]UPD)<>0
 mkstat = 4
 Return
Endif

Case GACTION
 When "FUPDESEL"
  Case ACTION
   When "EXEC" : SELMOD=0 : Gosub SEL
  Endcase
 When "FUPSEL"
  Case ACTION
   When "EXEC" : SELMOD=1 : Gosub SEL
  Endcase
 When "FUPINVSEL"
  Case ACTION
   When "EXEC" : SELMOD=2 : Gosub SEL
  Endcase
 When "DETFUP"
  Case ACTION
   When "INIT"        : Gosub INIT
   When "APRES_MODIF" : Gosub APRES_MODIF
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
   When "SETBOUT"     : Gosub SETBOUT
   When "FIR"         : Gosub PREMIER
   When "LAS"         : Gosub DERNIER
   When "SUI"         : Gosub SUIVANT
   When "PRE"         : Gosub PRECEDENT
   When "ENR"         : Gosub ENR # clic sur Enregistrer
   When "ABA"         : Gosub ABA # clic sur Abandon
   When "BOUTON"      : Gosub BOUTON
   When "FIN"         : Gosub FIN
   When "SORTIE"      : Gosub SORTIE
  Endcase
When "GSELLIS"   :
 Case COUZON
  When "ADD" : Gosub S_ADD
 Endcase
Endcase

Enable GSTAEDI
Return

##########################################################################################################

$INIT
# name of the window to be used
If dim([M:CFP0]ECRAN)>0 and [M:CFP0]ECRAN<>""
 BOITE = "WDFUP"+[M:CFP0]ECRAN
Else
 BOITE = "DFUP"
Endif
Return

##########################################################################################################
$SEL
Case SELMOD
When 0 : # Deselect all
 For N=0 To [M:DFUP]NBLIG-1
  If [M:DFUP]SEL(N)<>1
   [M:DFUP]SEL(N)=1
   [M:DFUP]UPD(N)=2
  Endif
 Next
 [M:DFUP]NBSEL=0
When 1 : # Select all
 For N=0 To [M:DFUP]NBLIG-1
  If [M:DFUP]SEL(N)<>2
   [M:DFUP]SEL(N)=2
   [M:DFUP]UPD(N)=2
  Endif
 Next
 [M:DFUP]NBSEL=[M]NBLIG
When 2 : # Invert selection
 For N=0 To [M:DFUP]NBLIG-1
  [M:DFUP]SEL(N)=3-[M:DFUP]SEL(N)
  [M:DFUP]UPD(N)=2
 Next
 [M:DFUP]NBSEL = [M]NBLIG-[M:DFUP]NBSEL
Endcase
Affzo [M:DFUP]
Return

##########################################################################################################

$BOUTON
Case BOUT
 When "R" : # Return
  Gosub MAJ_NBM_NBL From TRTFUP
  FIN=1
 When Default:
Endcase
Return

##########################################################################################################


$APRES_MODIF
If GCONSULT
 Call ERREUR(mess(9,123,1)) From GESECRAN : # Modification not possible
 mkstat = 2 : Return
Elsif !VERROU
 Call ERREUR(mess(10,100,1)) From GESECRAN : # Change in progress on another workstation
 mkstat = 2 : Return
Endif
[M:DFUP]UPD(nolign-1)=2
Return

##########################################################################################################

$FIN
Filter [TFP2]
Gosub MAJ_NBM_NBL From TRTFUP
Return

##########################################################################################################
# save updatable values
# on ne met à jour que si la ligne a été modifiée
##########################################################################################################
$ROLL_TR1
Rollback
Call TEMPOFF From GESECRAN
Call ROLL From GLOCK
If GROLL : Return : Else : Goto ENR : Endif

# update tables TMPFUP0, TMPFUP1 and TMPFUP2 with the contents of the masks
$ENR
Local Decimal DEPRAT
Local Integer UPD
# Save
Call TEMPON(mess(87,116,1)) From GESECRAN

Read [TFP0]TFP0=[M:CFP0]QURNUM

Filter [TFP1]
Trbegin [TFP1]
 For N=0 To [M:DFUP]NBLIG-1
  If [M:DFUP]UPD(N)=2 # Selected
   # update the current campaign
   Update [TFP2] Where NUMREQ=[M:CFP0]QURNUM and [F:TFP2]NUMDUD=[M:DFUP]NUMDUD(N) With SEL=[M:DFUP]SEL(N), FUPMOD=[M:DFUP]FUPMOD(N)
   If fstat=1
    GOK = -1 : GLOCK = "$TMPFUP2"-[M:CFP0]QURNUM-[M:DFUP]NUMDUD(N) : Break
   Elsif fstat
    ABR = "TFP2" : GOK = 0 : Break
   Endif

   Call LITTABDEP([M:DFUP]DEP(N), nday([M:CFP1]REFDAT)-nday([M:DFUP]DUDDAT(N)), [L]DEPRAT) From TRTDIV

   # update LEVFUP, ADD, DEP, DEPRAT et AMTDEP in ALL campaigns to avoid inconsistency
   Update [TFP2] Where [F:TFP2]NUMDUD=[M:DFUP]NUMDUD(N) With LEVFUP=[M:DFUP]LEVFUP(N), ADD=[M:DFUP]ADD(N), DEP=[M:DFUP]DEP(N),
&                                                            DEPRAT=[L]DEPRAT, AMTDEP=[M:DFUP]AGIOS(N)
   If fstat
    GOK = -1 : GLOCK = "$TMPFUP2"-[M:DFUP]NUMDUD(N) : Break
   Elsif fstat
    ABR = "TFP2" : GOK = 0 : Break
   Endif

   # update the "due date" in the main table
   If [M:DFUP]DUDDAT(N)<>[M:DFUP]ODUDDAT(N)
    Readlock [F:DUD]DUD8=[M:DFUP]NUMDUD(N)
    [F:DUD]DUDDAT=[M:DFUP]DUDDAT(N)
    Local Decimal EXERCICE, PERIODE
    Local Integer TYPLED
    Call LECLEDMAIN(1,[F:DUD]CPY,TYPLED) From CPTDIV
    Call GETPERSOC([F:DUD]CPY,TYPLED,[F:DUD]DUDDAT,EXERCICE,PERIODE) From CPTSUB
    [F:DUD]FIY = EXERCICE
    [F:DUD]PER = PERIODE
    Rewrite [F:DUD]
    If fstat=1
     GOK = -1 : GLOCK = "$GACCDUDATE"-[F:DUD]TYP-[F:DUD]NUM-num$([F:DUD]LIG)-num$([F:DUD]DUDLIG) : Break
    Elsif fstat
     ABR = "DUD" : GOK = 0 : Break
    Endif

    If [M:DFUP]DUDDAT(N)>[F:TFP0]REFDAT
     # the open item is no longer part of this campaign, it must be deleted
     Delete [TFP2] Where NUMREQ=[M:CFP0]QURNUM and NUMDUD=[M:DFUP]NUMDUD(N)
     If fstat
      GOK = -1 : GLOCK = "$TMPFUP2"-[M:CFP0]QURNUM-[M:DFUP]NUMDUD(N) : Break
     Elsif fstat
      ABR = "TFP2" : GOK = 0 : Break
     Endif
     # delete the line in DETFUP mask
     Dela N, 1 [M]NBLIG
     # Dela doesn't automatically update NBLIG
     [M]NBLIG -= 1
    Endif
    [M:DFUP]ODUDDAT(N) = [M:DFUP]DUDDAT(N)
   Endif

   # same thing for Dispute code
   If [M:DFUP]DPTCOD(N)<>[M:DFUP]ODPTCOD(N)
    # update Dispute code in main table
    Update [DUD] Where NUMDUD=[M:DFUP]NUMDUD(N) With DPTCOD=[M:DFUP]DPTCOD(N)
    If fstat
     GOK = -1 : GLOCK = "$GACCDUDATE"-[M:DFUP]NUMDUD(N) : Break
    Elsif fstat
     ABR = "DUD" : GOK = 0 : Break
    Endif
    [M:DFUP]ODPTCOD(N) = [M:DFUP]DPTCOD(N)
   Endif

   If func AFNC.ACTIV("HDU")
    Read [F:DAE]DAE2=[F:DUD]ACCNUM
    # 1 = creation or update
    Call HISTOECH("DUD",1,[F:DAE]ACCDAT) From MODECHE
    If !GOK : Break : Endif
   Endif

   # the update of FUP mask is done later by calling LECTURE From TRTFUP
   T = 0
   Repeat
    T += find([M:DFUP]FCY(0), [M:FUP]FCY(T..[M:FUP]NBLIG-1))
   Until [M:FUP]BPC(T-1)=[M:DFUP]TIERS
   T = T-1

   Local Integer SEL
   If [M:DFUP]NBSEL=0
    [L]SEL = 1 # no open item selected
   Elsif [M:DFUP]NBSEL=[M:DFUP]NBLIG
    [L]SEL = 3 # all open items selected
   Else
    [L]SEL = 2 # some open items selected
   Endif
   Update [TFP1] Where [F:TFP1]NUMREQ=[M:CFP0]QURNUM and BPC=[M:DFUP]TIERS and FCY=[M:DFUP]FCY(0) With SEL=[L]SEL, UPDUSR=GUSER, UPDDAT=date$
   If fstat
    GOK = -1 : GLOCK = "$TMPFUP1"-[M:DFUP]NUMDUD(N)-[M:DFUP]TIERS-[M:DFUP]CPY(0)-[M:DFUP]FCY(0) : Break
   Elsif fstat
    ABR = "TFP1" : GOK = 0 : Break
   Endif
   If UPD=0 and adxuprec<>0 : UPD=1 : Endif
  Endif
  [M:DFUP]UPD(N)=1
 Next # N

 If GOK=-1
  Goto ROLL_TR1
 Elsif GOK=0
  Call FSTA(ABR) From GLOCK : Rollback
 Else
  Gosub UPD_FUPTOTAMT From TRTFUP
  If UPD
   Update [TFP0] Where QURNUM=[M:CFP0]QURNUM With UPDUSR=GUSER, UPDDAT=date$
   If fstat
    GOK = -1 : GLOCK = "$TMPFUP0"-[M:CFP0]QURNUM : Goto ROLL_TR1
   Elsif fstat
    ABR = "TFP0" : GOK = 0
    Call FSTA(ABR) From GLOCK : Rollback
   Else
    Commit
   Endif
  Endif
 Endif

Affzo [M:FUP]

##### Mettre à jour la valeur de [M:FUP]TOTFUPLIG sur la ligne de total #####
# Recherche de la ligne de total
Local Integer T2
Local Decimal SOMME
SOMME = 0
If [M:FUP]SUPTOT = [V]CST_ATRUE Then
    # mise à jour de [M:FUP]ECH2 et [M:FUP]TOTFUP2
    For T2=0 To [M:FUP]NBLIG-1
        SOMME += [M:FUP]TOTFUPLIG(T2)
    Next
Else
    T2 = T
    Repeat
        SOMME += [M:FUP]TOTFUPLIG(T2)
     T2 = T2+1
    Until [M:FUP]TOT(T2)=2
    [M:FUP]TOTFUPLIG(T2) = SOMME
    Affzo [M:FUP]TOTFUPLIG(T2)

    # mise à jour de [M:FUP]ECH2 et [M:FUP]TOTFUP2
    SOMME = 0
    For T2=0 To [M:FUP]NBLIG-1
        If [M:FUP]TOT(T2)=2 : SOMME += [M:FUP]TOTFUPLIG(T2) : Endif
    Next
Endif
[M:FUP]ECH2 = SOMME
Affzo [M:FUP]ECH2
#Call CALC_TOTFUP2 From TRTFUP

Local Decimal SOLRELT, SOLNONRELT, AGIOS, TOTFUPT
Local Integer MAXBPC
MAXBPC=dim([M:FUP]BPC)
Gosub LECTURE From TRTFUP

If [M:CFP2]AGIO=2
 [M:FUP]AGIOS(T) = [M:DFUP]TOTAGIOS
 Affzo [M:FUP]AGIOS(T)
 Call CALC_TOTAGIOS From TRTFUP
Endif

Call TEMPOFF From GESECRAN
Return

##########################################################################################################

$ABA
# réinitialisation du masque avec le contenu des tables TMPFUP0, TMPFUP1 et TMPFUP2
# Cancel
Call TEMPON(mess(5,123,1)) From GESECRAN
Gosub LECTURE
Call TEMPOFF From GESECRAN
Return

##########################################################################################################

$OUVRE
Local Char BPC(GLONBPC), VALPAR(200), TIERS(GLONBPC), CPY(GLONCPY), FCY(GLONFCY)
Local Integer MAXFUP, STAT, FUPFCY, TYPCOURS, SEL, N, T
Local Decimal AMTDEP, MTDES
Local Char DEVORG(GLONCUR), DEVDES(GLONCUR), DEVSOC(GLONCUR)
Local Char ICONE1(GLONICO), ICONE2(GLONICO), ICONE3(GLONICO)
Global Integer CMTLEN2
Local Char ABR(4) # Used for FSTA() calls

If clalev([F:TFP1])=0 : Local File TMPFUP1    [TFP1] : Endif
If clalev([F:TFP2])=0 : Local File TMPFUP2    [TFP2] : Endif
If clalev([F:TCF])=0  : Local File TMPFUPCMT  [TCF]  : Endif
If clalev([F:DUD])=0  : Local File GACCDUDATE [DUD]  : Endif
If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif
If clalev([F:BPA])=0  : Local File BPADDRESS  [BPA]  : Endif
If clalev([F:SIH])=0  : Local File SINVOICE   [SIH]  : Endif
If clalev([F:PIH])=0  : Local File PINVOICE   [PIH]  : Endif
If clalev([F:SIV])=0  : Local File SINVOICEV  [SIV]  : Endif
If clalev([F:TCY])=0  : Local File TABCOUNTRY [TCY]  : Endif
If clalev([F:TSV])=0  : Local File TABSIVTYP  [TSV]  : Endif
If clalev([F:BPC])=0  : Local File BPCUSTOMER [BPC]  : Endif
If clalev([F:BPR])=0  : Local File BPARTNER   [BPR]  : Endif
If clalev([F:AMZ])=0  : Local File AMSKZON    [AMZ]  : Endif
If clalev([F:CNT])=0  : Local File CONTACT    [CNT]  : Endif
If clalev([F:DAE])=0 :  Local File GACCENTRYD [DAE]  : Endif

If PARAM(1)="" or PARAM(2)="" or PARAM(3)=""
 End
Else
 BPC = PARAM(1)
 CPY = PARAM(2)
 FCY = PARAM(3)
Endif

Read [AMZ]CODE="DETFUP";"CMT"
CMTLEN2=[AMZ]LONG

For N=0 To dim([M:DFUP]UPD)-1
 [M:DFUP]UPD(N)=1
Next

ICONE1= ""    # no open item selected
ICONE2= "251" # some open items selected
ICONE3= "252" # all open items selected

# Rate type
Call PARAM("","CHGTYP",VALPAR) From ADOVAL
TYPCOURS = val(VALPAR)

# 66194 - relance par site
If [F:FGP]GRP<>[F:BPC]GRP : Read [FGP]FGP0=[F:BPC]GRP : Endif
FUPFCY = [F:FGP]FUPFCY

# The "Filter" must be placed AFTER the "Link" to avoid a crash
# DFUP mask : right-clicking "Open items" displays open items associated with BP and company and site of the line clicked
#
# Filter [TFP2] Where NUMREQ=[M:CFP0]QURNUM and BPC=[L]BPC and CPY=[L]CPY and FCY=[L]FCY Order By NUMDUD Asc

If FUPFCY=2
 Link [TFP2] With [DUD]DUD8=[TFP2]NUMDUD, [TCF]TCF0=[TFP2]NUMDUD As [LNKD]
& Where [TFP2]NUMREQ=[M:CFP0]QURNUM and [TFP2]BPC=[L]BPC and [TFP2]CPY=[L]CPY and [TFP2]FCY=[L]FCY
& and [DUD]CPY=[L]CPY and [DUD]FCY=[L]FCY
& Order By [DUD]FCY Asc;[DUD]DUDDAT Asc;[DUD]AMTLOC Desc;[DUD]NUMDUD Asc
Else
 Link [TFP2] With [DUD]DUD8=[TFP2]NUMDUD, [TCF]TCF0=[TFP2]NUMDUD As [LNKD]
& Where [TFP2]NUMREQ=[M:CFP0]QURNUM and [TFP2]BPC=[L]BPC and [TFP2]CPY=[L]CPY
& and [DUD]CPY=[L]CPY
& Order By [DUD]DUDDAT Asc;[DUD]AMTCUR Desc;[DUD]NUMDUD Asc
Endif

# 64954 and 64277 : Filter statement moved here to avoid a crash
# Ecran DFUP : le clic-droit "Echéances" affiche les échéances correspondant au tiers ET à la société ET au site de la ligne cliquée
Filter [TFP2] Order By NUMDUD Asc

# retrieve the country of the BP
Read [BPA]BPA0=1;[L]BPC
Return

##########################################################################################################

$DEBUT
 MAXFUP=dim([M:DFUP]BPC)
 Raz [M:DFUP]
 [M:DFUP]TIERS=BPC
 Gosub LECTURE
Return

##########################################################################################################

$VERROU
SYMBOLE = "FUP"+[M:CFP0]QURNUM
Lock =SYMBOLE With lockwait=0
If fstat
 VERROU = 0
Else
 VERROU = 1
Endif
Return

$LECTURE
Gosub VERROU
N=0 : nolign=0

# save the current BP
[L]TIERS=[M:DFUP]TIERS

# save the current DUDDEB
Local Char DUDDEB(15)
[L]DUDDEB = [M:DFUP]DUDDEB

Raz [M:DFUP]
Read [BPC]BPC0=[L]TIERS
If fstat=0 : [M:DFUP]FUPMINAMT = [BPC]FUPMINAMT : Endif

# re-set the current BP and DUDDEB
[M:DFUP]TIERS = [L]TIERS
[M:DFUP]DUDDEB = [L]DUDDEB

If dim([M:DFUP]BPCSHO)>0
 [M:DFUP]BPCSHO=[F:BPC]BPCSHO
Endif

If [M:DFUP]DUDDEB=""
 Read [TFP2] First
 [M:DFUP]DUDDEB=[TFP2]NUMDUD
Endif
[M:DFUP]NBSEL=0

# comparaison des codes devise de toutes les échéances à afficher
# on affiche chaque ligne dans sa devise, mais les totaux (bloc du bas) sont affichés dans la devise DEVDES
DEVDES=""
For [LNKD] Where [TFP2]NUMDUD>=[M:DFUP]DUDDEB
 Read [CPY]CPY0=[DUD]CPY
 If DEVDES=""
  DEVDES = [F:CPY]ACCCUR
 Elsif DEVDES<>[F:CPY]ACCCUR
# les codes devise ne sont pas tous identiques --> utilisation devise reporting
  DEVDES=GSYSCUR
  Break
 Endif
Next

Read [F:CNT]CNT0=1;[M:DFUP]TIERS;[F:BPC]CNTNAM
[M:DFUP]CNT = [F:CNT]CCNCRM
If [F:CNT]CNTFNC=0
 [M:DFUP]FNCCNT = ""
Else
 [M:DFUP]FNCCNT = mess([F:CNT]CNTFNC,233,1)
Endif
[M:DFUP]WEB = [F:CNT]WEB
[M:DFUP]TEL = [F:CNT]TEL

For [LNKD] Where [TFP2]NUMDUD>=[M:DFUP]DUDDEB
 [M:DFUP]CPY(N)    = [F:DUD]CPY
 [M:DFUP]FCY(N)    = [F:DUD]FCY
 [M:DFUP]TYP(N)    = [F:DUD]TYP
 [M:DFUP]DPTCOD(N) = [F:DUD]DPTCOD
 [M:DFUP]ODPTCOD(N)= [M:DFUP]DPTCOD(N)

 [M:DFUP]NUM(N)    = [F:DUD]NUM
 [M:DFUP]BPC(N)    = [F:DUD]BPR
 [M:DFUP]BPRPAY(N) = [F:DUD]BPRPAY

 [M:DFUP]CUR2(N)   = [F:DUD]CUR

 [M:DFUP]DUDDAT(N) = [F:DUD]DUDDAT
 [M:DFUP]ODUDDAT(N)= [M:DFUP]DUDDAT(N)
 [M:DFUP]AMTCUR(N) = [F:DUD]AMTCUR*[F:DUD]SNS
 [M:DFUP]CLECUR(N) = ([F:DUD]AMTCUR-[F:DUD]PAYCUR-[F:DUD]TMPCUR)*[F:DUD]SNS

 # on affiche le niveau de relance enregistré dans TMPFUP2
 [M:DFUP]LEVFUP(N) = [F:TFP2]LEVFUP
 [M:DFUP]SEL(N)    = [F:TFP2]SEL
 [M:DFUP]FUPMOD(N) = [F:TFP2]FUPMOD
 [M:DFUP]OSTCTL(N) = [F:BPC]OSTCTL
 If [F:TFP2]SEL=2
  [M:DFUP]NBSEL+=1
 Endif

 If len([F:TCF]CMT)>CMTLEN2
  [M:DFUP]CMT(N)   = left$([F:TCF]CMT,CMTLEN2-3)+"..."
 Else
  [M:DFUP]CMT(N)   = [F:TCF]CMT
 Endif

 Read [BPR]BPR0=[F:DUD]BPRPAY
 [M:DFUP]LAN(N) = [F:BPR]LAN

 [M:DFUP]DEP(N)    = [F:TFP2]DEP

 If [M:CFP2]AGIO=2
  [M:DFUP]AGIOS(N) = [F:TFP2]AMTDEP
 Endif

 [M:DFUP]DEL(N)    = nday([M:CFP1]REFDAT)-nday([F:DUD]DUDDAT)
 [M:DFUP]NUMDUD(N) = [F:DUD]NUMDUD
 [M:DFUP]ACCNUM(N) = [F:DUD]ACCNUM
 [M:DFUP]NUMINV(N) = [F:DUD]NUM # pour tunnel vers factures

 [M:DFUP]CLELOC(N) = ([F:DUD]AMTLOC-[F:DUD]PAYLOC-[F:DUD]TMPLOC)*[F:DUD]SNS

 # convertir le bloc des totaux en devise DEVDES (champs TOTCLELOC, TOTAGIOS, TOTCLE)
 DEVORG = [F:DUD]CUR
 Read [CPY]CPY0=[F:DUD]CPY
 DEVSOC = [F:CPY]ACCCUR
 MTORG = [M:DFUP]CLELOC(N)
 DATCOURS = datesyst

 MTDES = MTORG

 If [M:DFUP]SEL(N)=2
  [M:DFUP]TOTCLELOC += MTDES
 Endif

 AMT=MTDES

 [M:DFUP]TOTCLELIG(N) = [M:DFUP]CLELOC(N)+[M:DFUP]AGIOS(N)
 If [M:DFUP]SEL(N)=2
  [M:DFUP]TOTAGIOS  += [M:DFUP]AGIOS(N)
 Endif
 [M:DFUP]ADD(N)   = [F:TFP2]ADD

 If dim([M:DFUP]EMAIL)>0
  Read [BPA]BPA0=1;[M:DFUP]BPRPAY(N);[M:DFUP]ADD(N)
  [M:DFUP]EMAIL(N) = [F:BPA]WEB
 Endif

 nolign+=1
 N+=1
 If N>=MAXFUP
  # Tableau plein
  Call ERREUR(mess(26,100,1)) From GESECRAN
  Break
 Endif
 GPOINT = "LOADDATA" : Gosub ENTREE From EXEFNC
Next
[M:DFUP]TOTCLE = [M:DFUP]TOTCLELOC+[M:DFUP]TOTAGIOS
[M:DFUP]CUR = [M:FUP]CUR
[M:DFUP]NBLIG=N
Affzo
Return

##########################################################################################################
Subprog CALC_TOTCLE
# update mask DETFUP
Raz [M:DFUP]TOTCLE, [M:DFUP]TOTCLELOC, [M:DFUP]TOTAGIOS
For N=0 To [M:DFUP]NBLIG-1
 If [M:DFUP]SEL(N)=2
  [M:DFUP]TOTCLE += [M:DFUP]TOTCLELIG(N)
  [M:DFUP]TOTCLELOC += [M:DFUP]TOTCLELIG(N)
  [M:DFUP]TOTAGIOS += [M:DFUP]AGIOS(N)
 Endif
Next
Affzo [M:DFUP]TOTCLE, TOTCLELOC, TOTAGIOS
End

##########################################################################################################

$SETBOUT
If find(2,[M]UPD)=0 # no need to save
 REP=""
 # activation des boutons Enregistrer et Annuler, désactivation du bouton Retour
 Call VIREBOUT(CHBOU,"EA") From GOBJET
 If instr(1,CHMEN,"R")=0 : CHMEN+="R" : Endif
Else # enregistrement autorisé et nécessaire
 REP="M"
 # désactivation des boutons Enregistrer et Annuler, activation du bouton Retour
 If instr(1,CHBOU,"E")=0 : CHBOU+="E" : Endif
 If instr(1,CHBOU,"A")=0 : CHBOU+="A" : Endif
 Call VIREBOUT(CHMEN,"R") From GOBJET
Endif

# Si la campagne a déjà été validée, on grise le bouton "Enregistrer" et le bloc tableau
Read [TFP0]TFP0=[M:CFP0]QURNUM
If [TFP0]VALIDE=2
 Call VIREBOUT(CHBOU,"EA") From GOBJET
 If instr(1,CHMEN,"R")=0 : CHMEN+="R" : Endif
# on grise tous les champs du bloc tableau sauf NBLIG pour que les menus en clic droit restent accessibles
 For [AMZ]CODE Where CODMSK="DETFUP" and NUMBLOC=2 and CODZON<>"NBLIG"
  Diszo = "[M:DFUP]"+[F:AMZ]CODZON
 Next
Endif

If !VERROU
 IMGFLG(3) = 1 : # Cadenas
Else
 IMGFLG(3) = 0
Endif
Return

##########################################################################################################

$PREMIER
Read [LNKD] First
If [M:DFUP]DUDDEB=[TFP2]NUMDUD
 # Début/Fin de fichier
 Call ERREUR(mess(11,100,1)) From GESECRAN
Else
 [M:DFUP]DUDDEB=[TFP2]NUMDUD
 Gosub LECTURE
Endif
Return

##########################################################################################################

$PRECEDENT
Read [LNKD]<[M:DFUP]NUMDUD(0)
N=1
If fstat>2
 # Début/Fin de fichier
 Call ERREUR(mess(11,100,1)) From GESECRAN
Else
 While N<MAXFUP and fstat<=2
  Read [LNKD] Prev
  N+=1
 Wend
 [M:DFUP]DUDDEB=[TFP2]NUMDUD
 Gosub LECTURE
Endif
Return

##########################################################################################################

$SUIVANT
If [M:DFUP]NBLIG<1
 Return
Endif
Read [LNKD]>[M:DFUP]NUMDUD([M:DFUP]NBLIG-1)
If fstat>2
 # Début/Fin de fichier
 Call ERREUR(mess(11,100,1)) From GESECRAN
Else
 [M:DFUP]DUDDEB=[TFP2]NUMDUD
 Gosub LECTURE
Endif
Return

##########################################################################################################

$DERNIER
N=0
Read [LNKD] Last
Repeat
 Read [LNKD] Prev
 N+=1
Until N>=MAXFUP-1 or fstat>2
If [M:DFUP]DUDDEB=[TFP2]NUMDUD
 # Début/Fin de fichier
 Call ERREUR(mess(11,100,1)) From GESECRAN
Else
 [M:DFUP]DUDDEB=[TFP2]NUMDUD
 Gosub LECTURE
Endif
Return

##########################################################################################################

$SORTIE
nolign = [M:FUP]NOLIG
Call AS_NBLIG From TRTFUP

# 70784
If dim(GBIDI1)<0 : Global Integer GBIDI1 : Endif
GBIDI1 = 1
Return

##########################################################################################################

Subprog AM_DEP(VALEUR)
Variable Char    VALEUR()
Local Decimal AMTDEP, AMT
# recalculer le montant escompte/agio en utilisant le nouveau code escompte/agio
# Les escomptes ne doivent pas avoir de signes
# les agios malgré leur signe négatif doivent incrémenter le montant à relancer.
# 71932
If [M:CFP2]AGIO=2
 Read [DUD]DUD8=[M:DFUP]NUMDUD(nolign-1)
 AMT=[M:DFUP]AMTCUR(nolign-1)-[F:DUD]PAYCUR-[F:DUD]TMPCUR
 Call ESC_AGIO(VALEUR,date$,[M:DFUP]DUDDAT(nolign-1),[M:DFUP]DEL(nolign-1),AMT,[M:DFUP]CUR2(nolign-1),AMTDEP,[F:DUD]ACCNUM,[F:DUD]DUDLIG) From MODECHE
 [M:DFUP]AGIOS(nolign-1) = -AMTDEP
 # mettre à jour le total
 [M:DFUP]TOTCLELIG(nolign-1) = [M:DFUP]CLECUR(nolign-1)+[M:DFUP]AGIOS(nolign-1)
 Gosub  CALC_TOTAGIOS
 For N=0 To [M:FUP]NBLIG-1
  [M:FUP]TOTFUPLIG(N) = [M:FUP]SOLREL(N)+[M:FUP]SOLNONREL(N)+[M:FUP]AGIOS(N)
 Next
 Affzo [M:FUP]TOTFUPLIG
 [M:DFUP]TOTCLE = [M:DFUP]TOTCLELOC+[M:DFUP]TOTAGIOS
 [M:DFUP]UPD(nolign-1)=2
 Affzo [M:DFUP]TOTCLE
Endif
End

$CALC_TOTAGIOS
# mise à jour écran DETFUP
Raz [M:DFUP]TOTAGIOS
For N=0 To [M:DFUP]NBLIG-1
 [M:DFUP]TOTAGIOS += [M:DFUP]AGIOS(N)
Next
Affzo [M:DFUP]TOTAGIOS
Return

##########################################################################################################

$S_ADD
Local Char TEXTE(30)(1..200,1..2) , TIT(30)(0..2)
Local Char TIERS(GLONBPC)
# Sélection code adresse
TIT(0) = mess(44,133,1)
NBTEX = 0

If [M:CFP1]BPRFUP=1
 # tiers relancé = tiers payeur
 TIERS = [M:DFUP]BPRPAY(nolign-1)
Else
 # tiers relancé = tiers facturé
 TIERS = [M:DFUP]BPC(nolign-1)
Endif

# bug 58506
For [BPA] Where BPATYP=1 & BPANUM=TIERS
 NBTEX += 1
 TEX(NBTEX) = [F:BPA]BPAADD
 TEXTE(NBTEX, 1) = TEX(NBTEX)
 TEXTE(NBTEX, 2) = [F:BPA]BPADES
Next
Return

##########################################################################################################

Subprog C_ADD(VALEUR)
Variable Char VALEUR()
Local Char TIERS(GLONBPC)

If [M:CFP1]BPRFUP=1
 # tiers relancé = tiers payeur
 TIERS = [M:DFUP]BPRPAY(nolign-1)
Else
 # tiers relancé = tiers facturé
 TIERS = [M:DFUP]BPC(nolign-1)
Endif

# bug 58506
Look [F:BPA]BPA0=1;TIERS;VALEUR # BPATYP=1 -> tiers
If fstat
 # Adresse inexistante
 GMESSAGE = mess(10,119,1)
 mkstat=2
 End
Endif
End

##########################################################################################################

# bug 58506
Subprog AM_ADD(VALEUR)
Variable Char VALEUR()
Local Char TIERS(GLONBPC)

If [M:CFP1]BPRFUP=1
 # tiers relancé = tiers payeur
 TIERS = [M:DFUP]BPRPAY(nolign-1)
Else
 # tiers relancé = tiers facturé
 TIERS = [M:DFUP]BPC(nolign-1)
Endif

Read [F:BPA]BPA0=1;TIERS;VALEUR # BPATYP=1 -> tiers
[M:DFUP]EMAIL(nolign-1) = [F:BPA]WEB
Affzo [M:DFUP]EMAIL(nolign-1)
End

##########################################################################################################

Subprog IB_NBLIG
Raz [M:DFUP]MONTANT
For [DUD] Where [DUD]ACCNUM=[M:DFUP]ACCNUM(nolign-1)
 [M:DFUP]MONTANT+=[F:DUD]AMTCUR
Next

# Bouton 1 : Zoom sur la facture
GBOUT1=""
Read [F:SIH]SIH2 = [M:DFUP]TYP(nolign-1);[M:DFUP]NUM(nolign-1)
If !fstat
 Case [F:SIH]ORIMOD
  When 3 : GBOUT1 = mess(43,109,1) : # Facture tiers client
  When 5 : GBOUT1 = mess(45,109,1) : # Facture vente
 Endcase
Elsif fstat=5
 Read [F:PIH]PIH2 = [M:DFUP]TYP(nolign-1);[M:DFUP]NUM(nolign-1)
 If !fstat
  Case [F:PIH]ORIMOD
   When 3 : GBOUT1 = mess(44,109,1) : # Facture tiers fournisseur
   When 6 : GBOUT1 = mess(46,109,1) : # Facture achat
  Endcase
 Endif
Endif

# si la campagne est déjà validée, on supprime les menus contextuels : "Gestion des échéances", "Sélectionner tout", "Désélectionner tout"
# "Inverser sélection" et "MAJ taux escompte/agio"
Read [TFP0]TFP0=[M:CFP0]QURNUM
If [TFP0]VALIDE=2
 Raz GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6
Endif
End

##########################################################################################################

Subprog B1_NBLIG
Local Char OBJETC(3)

Read [F:SIH]SIH2 = [M:DFUP]TYP(nolign-1);[M:DFUP]NUM(nolign-1)
If !fstat
 Case [F:SIH]ORIMOD
  When 3 : # Facture tiers client
   Call LECTURE("BIC",[M:DFUP]NUM(nolign-1),"") From CONTOBJ
   GCONSULT=2 # pour être en lecture seule dans la fonction de facture tiers client
   If !fstat : OBJETC = "BIC" :  Endif
  When 5 : # Facture vente
   Call LECTURE("SIH",[M:DFUP]NUM(nolign-1),"") From CONTOBJ
   If !fstat : OBJETC = "SIH" : Endif
 Endcase
Elsif fstat=5
 Read [F:PIH]PIH2 = [M:DFUP]TYP(nolign-1);[M:DFUP]NUM(nolign-1)
 If !fstat
  Case [F:PIH]ORIMOD
   When 3 : # Facture tiers fournisseur
    Call LECTURE("BIS",[M:DFUP]NUM(nolign-1),"") From CONTOBJ
    If !fstat : OBJETC = "BIS" : Endif
   When 6 : # Facture achat
    Call LECTURE("PIH",[M:DFUP]NUM(nolign-1),"") From CONTOBJ
    If !fstat : OBJETC = "PIH" : Endif
  Endcase
 Endif
Endif

If OBJETC<>""
 Call OBJET(OBJETC,[M:DFUP]NUMINV(nolign-1),"") From GOBJET
Endif
End

##########################################################################################################
Subprog AM_SEL(VALEUR)
Variable Integer VALEUR
Local Integer N

N=nolign-1
If VALEUR=1
 [M:DFUP]NBSEL-=1
 Raz [M:DFUP]TOTCLELIG(N)
Elsif VALEUR=2
 [M:DFUP]NBSEL+=1
 [M:DFUP]TOTCLELIG(N)=[M:DFUP]CLELOC(N)+[M:DFUP]AGIOS(N)
Endif
Affzo [M:DFUP]TOTCLELIG(N)
[M:DFUP]SEL(N)=VALEUR # affectation explicite nécessaire pour fonctionnement correct de CALC_TOTCLE
Call CALC_TOTCLE

# bug 58466
Affzo [M:FUP]
End

##########################################################################################################

Subprog AS_NBLIG
Read [DUD]DUD8=[M:DFUP]NUMDUD(nolign-1)

# Mise à jour de la valeur du champ [M:DFUP]CMT2 avec le commentaire associé à l'échéance de la ligne courante
Read [TCF]TCF0=[M:DFUP]NUMDUD(nolign-1)
If fstat=0
 If [M:DFUP]CMT2<>[F:TCF]CMT
  [M:DFUP]CMT2=[F:TCF]CMT
  Affzo [M:DFUP]CMT2
 Endif
Else
 Raz [M:DFUP]CMT2
 # bug 59090
 Affzo [M:DFUP]CMT2
Endif

[M:DFUP]CNT = [F:BPC]CNTNAM

[M:DFUP]NOLIG=nolign

# Will be re-enabled later
#Chgstl [M:DFUP]NBLIG With "" # suppression des styles
# style à stocker dans un paramètre ?
#Chgstl [M:DFUP]NBLIG(nolign-1) With "AWARN" # ajout style sur la ligne courante
# No Affzo here, or else sorting a column will no longer work
Envzo
End

##########################################################################################################

Subprog AM_CMT2(VALEUR)
Variable Clbfile VALEUR
# Attention : il faut utiliser Rewrite pour mettre à jour un champ Clob (plantage avec Update)
# voir le bug 30087 pour plus d'infos
# mais ça fonctionne en V6 apparemment ??
Trbegin [TFP2]
Look [F:TCF]TCF0=[M:DFUP]NUMDUD([M:DFUP]NOLIG-1)
[F:TCF]CMT=zc
[F:TCF]TYPBLB = 2
If fstat
 [F:TCF]NUMDUD=[M:DFUP]NUMDUD([M:DFUP]NOLIG-1)
 Write [F:TCF]
Else
 Rewrite [F:TCF]
Endif

If fstat
 Call FSTA('TCF') From GLOCK
 Rollback
 zoncou = "CMT2"
Else
 Commit
 If len(zc)>CMTLEN2
  [M:DFUP]CMT([M:DFUP]NOLIG-1) = left$(zc,CMTLEN2-3)+"..."
 Else
  [M:DFUP]CMT([M:DFUP]NOLIG-1) = zc
 Endif
 Affzo [M:DFUP]CMT([M:DFUP]NOLIG-1)
Endif
End

##########################################################################################################
# recopie du code escompte/agio de la ligne courante sur toutes les lignes situées en dessous
Subprog B6_NBLIG
Local Integer IND, I
IND = nolign-1
For I=IND+1 To [M:DFUP]NBLIG-1
 [M:DFUP]DEP(I) = [M:DFUP]DEP(I-1)
 nolign = I+1
 Call AM_DEP([M:DFUP]DEP(I))
 [M:DFUP]UPD(I)=2
Next
nolign = IND+1
Affzo
# on force l'appel à $SETBOUT
mkstat=4
End

######################################################################################

Subprog C_LEVFUP(VALEUR)
Variable Decimal VALEUR
If VALEUR>5
 # Le niveau de relance doit être inférieur ou égal à 5
 GMESSAGE = mess(257,117,1)
 mkstat=2
Endif
If mkstat : End : Endif
End

######################################################################################

Subprog AM_LEVFUP(VALEUR)
Variable Decimal VALEUR
Gosub MAJ_NBM_NBL From TRTFUP
End

######################################################################################
Subprog AM_DUDDAT(VALEUR)
Variable Date VALEUR
Local Decimal AMTDEP, AMT

# mettre à jour [M]DEL
[M:DFUP]DEL(nolign-1) = nday([M:CFP1]REFDAT)-nday(VALEUR)
Affzo [M:DFUP]DEL(nolign-1)

# recalculer le montant escompte/agio en utilisant la nouvelle date d'échéance
# Les escomptes ne doivent pas avoir de signe
# les agios malgré leur signe négatif doivent incrémenter le montant à relancer.
If [M:CFP2]AGIO=2
 Read [DUD]DUD8=[M:DFUP]NUMDUD(nolign-1)
 AMT=[M:DFUP]AMTCUR(nolign-1)-[F:DUD]PAYCUR-[F:DUD]TMPCUR
 Call ESC_AGIO([M:DFUP]DEP(nolign-1),date$,VALEUR,[M:DFUP]DEL(nolign-1),AMT,[M:DFUP]CUR2(nolign-1),AMTDEP,[F:DUD]ACCNUM,[F:DUD]DUDLIG) From MODECHE
 [M:DFUP]AGIOS(nolign-1) = -AMTDEP
 # mettre à jour le total
 [M:DFUP]TOTCLELIG(nolign-1) = [M:DFUP]CLECUR(nolign-1)+[M:DFUP]AGIOS(nolign-1)
 Gosub  CALC_TOTAGIOS
 For N=0 To [M:FUP]NBLIG-1
  [M:FUP]TOTFUPLIG(N) = [M:FUP]SOLREL(N)+[M:FUP]SOLNONREL(N)+[M:FUP]AGIOS(N)
 Next
 Affzo [M:FUP]TOTFUPLIG
 [M:DFUP]TOTCLE = [M:DFUP]TOTCLELOC+[M:DFUP]TOTAGIOS
 [M:DFUP]UPD(nolign-1)=2
 Affzo [M:DFUP]TOTCLE
Endif
End

