#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque AJS2 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone RESNAM
mkstat = 0
zoncou = "RESNAM"
indice = 0
WCHAR = [M]RESNAM
If varmode([M]RESNAM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "RESNAM" : Gosub ACTION From =IMPTRT
 Endif
 If WCHAR<>[M]RESNAM or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_RESNAM([M]RESNAM) From AJSSYNC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "RESNAM" : GZNUM = 42354 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

indice = 0
status = 1
zoncou = "NBLIG"
If !mkstat
 NBLIG = [M]NBLIG
 For nolign=1 To NBLIG
  indice = nolign-1
  [M]NBLIG = nolign
  status = 75
  Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
  If mkstat : Break : Endif
 Next nolign
 If mkstat : End : Endif
 indice = 0
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

## Zone RESCLE
mkstat = 0
zoncou = "RESCLE"
indice = 0
WCHAR = [M]RESCLE
If varmode([M]RESCLE,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "RESCLE" : Gosub ACTION From =IMPTRT
 Endif
 If WCHAR<>[M]RESCLE or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_RESCLE([M]RESCLE) From AJSSYNC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "RESCLE" : GZNUM = 2943 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone RESUUID
mkstat = 0
zoncou = "RESUUID"
indice = 0
WCHAR = [M]RESUUID
If varmode([M]RESUUID,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "RESUUID" : Gosub ACTION From =IMPTRT
 Endif
 If WCHAR<>[M]RESUUID or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_RESUUID([M]RESUUID) From AJSSYNC
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "RESUUID" : GZNUM = 42348 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1



End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "AJS2"
Return

