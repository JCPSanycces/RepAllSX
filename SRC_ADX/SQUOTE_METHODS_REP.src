#<AdxTL>@(#)0.0.0.0 $Revision$
End
#######################################################################################
# METHODS                                                                             #
#######################################################################################
#######################################################################################
$AREAD_AFTER
  Gosub AREAD_AFTER_C_CPY
  Gosub AREAD_AFTER_C_FCY
  Gosub AREAD_AFTER_C_SREP
  # ------------------------
  Local File CONTACTCRM [AIN]
  If this.SQH.BPCADD.CNTNAM <> "" Then
    Read [AIN]AIN0=this.SQH.BPCADD.CNTNAM
    If !fstat Then
      this.ORDCNTTTL = [F:AIN]CNTTTL
      this.ORDCNTLNA = [F:AIN]CNTLNA
      this.ORDCNTFNA = [F:AIN]CNTFNA
    Endif
  Endif
  If this.SQH.BPDADD.CNTNAM <> "" Then
    Read [AIN]AIN0=this.SQH.BPDADD.CNTNAM
    If !fstat Then
      this.DLVCNTTTL = [F:AIN]CNTTTL
      this.DLVCNTLNA = [F:AIN]CNTLNA
      this.DLVCNTFNA = [F:AIN]CNTFNA
    Endif
  Endif
Return

#######################################################################################
$AREAD_AFTER_C_CPY
Local Integer ILINEBPR

  If this.SQH.C_CPY(1) = null Then
    ILINEBPR = fmet this.SQH.C_CPY.ADDLINE("C_CPY", [V]CST_ALASTPOS)
  Else
    ILINEBPR = 1
  Endif
  Callmet this.SQH.C_CPY(ILINEBPR).AREAD(this.SQH.CPY)
Return

#######################################################################################
$AREAD_AFTER_C_FCY
Local Integer ILINEBPR

  If this.SQH.C_FCY(1) = null Then
    ILINEBPR = fmet this.SQH.C_FCY.ADDLINE("C_FCY", [V]CST_ALASTPOS)
  Else
    ILINEBPR = 1
  Endif
  Callmet this.SQH.C_FCY(1).AREAD(this.SQH.SALFCY)
Return

#######################################################################################
$AREAD_AFTER_C_SREP
Local Integer NI
Local Integer ILINE
Local Integer ILINEBPR

  For NI = 1 To maxtab(this.SQH.C_REP)
    If this.SQH.C_REP(NI).REP <> "" Then
      If this.SQH.C_SREP(1) = null Then
        ILINE = fmet this.SQH.ADDLINE("C_SREP", [V]CST_ALASTPOS)
        If this.SQH.C_SREP.BPR(1) = null Then
          # FGR 26/06/2013 : solution de contournement. le ADDLINE n'instancie pas BPR en dessous lorsqu'il est (1,1)
          ILINEBPR = fmet this.SQH.C_SREP.ADDLINE("BPR", [V]CST_ALASTPOS)
        Endif
      Endif
      Callmet this.SQH.C_SREP(1).AREAD(this.SQH.C_REP(NI).REP)
    Endif
    Break                # Je ne prends que le premier représentant
  Next NI
Return
