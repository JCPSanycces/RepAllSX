#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIGPA37: Verifie que les zones MATCST, MACCST, LABCST... de WIPCOST   #
#           sont alimentées, sinon, les alimente                         #
##########################################################################
# CCC 06/11/11                                           Bug 84658       #
##########################################################################

Call MAJ_UTIGPA37
End

##################################
Subprog MAJ_UTIGPA37
Local Char DOSSIER(30) : DOSSIER=nomap
Local Integer LRET
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER="" : End : Endif
Call OUVRE_TRACE("UTIGPA37: [MWI]xxxCST correction") From LECFIC
LRET=2
Call OUINON(mess(27,107,1)-"?",LRET) From GESECRAN
Call EXE_UTIGPA37(DOSSIER, LRET=2)
Call FERME_TRACE From LECFIC
Call TEMPOFF     From GESECRAN
Call LEC_TRACE From LECFIC
End

##################################
Subprog EXE_UTIGPA37(DOSSIER,PSIM)
Value Char DOSSIER
Value Integer PSIM

Call ECR_TRACE("UTIGPA37 : Process Start on : "+DOSSIER,0) From GESECRAN

If filinfo(filpath("FIL","MFGHEAD","fde",DOSSIER),0) <= 0  : End : Endif
If filinfo(filpath("FIL","WIPCOST","fde",DOSSIER),0)  <= 0  : End : Endif

Local File =[L]DOSSIER+".MFGHEAD"   [MFG]
Local File =[L]DOSSIER+".WIPCOST"   [MWI]
Local File =[L]DOSSIER+".MFGCOST"   [MFC]
Local File =[L]DOSSIER+".ITMMASTER" [ITM]

Local Char LMFGNUM(GLONVCR)
Local Char LCRIT(250), LFIL(250)
Local Decimal LVALMFC(max(1,GACTMAT,GACTLAB,GACTMAC))
Local Integer LSIM : LSIM=0
Local Integer STOP : STOP=0
Local Integer MAJ


#CHECK IGNORE_BEGIN
# Ex : LFIL="[MWI]CREDAT<GDATDECCST & [MFG]MFGTRKFLG<6"
LFIL="1=1"
GPOINT="UITGPA37"
Gosub ENTREE From EXEFNC
#CHECK IGNORE_END

LSIM=PSIM
#LFIL="[MFG]MFGNUM='CCP1203000666' & [MWI]WIPSEQ=99"

If LSIM
    Call ECR_TRACE("Simulation", -1) From GESECRAN
Endif

Link [MWI] With [MFG]MFG0~=[F:MWI]VCRNUM As [MFX]
&          Where [F:MWI]VCRTYP=10
&              & find([MWI]TXNTYP,1,14)>0
&              & evalue(LFIL)
&          Order By Key KMWI=[MWI]VCRNUM;[MWI]TXNTYP;[MWI]WIPSEQ

$LOOP_MWI

GOK=1
Trbegin [MWI]

If STOP=1
    CRIT="[MWI]VCRNUM>LMFGNUM"
    STOP=0
Else
    CRIT="1=1"
Endif
For [MFX]KMWI(1) Where evalue(CRIT)
    For [MFX]KMWI
        GMESSAGE = mess(699,197,1)-[F:MWI]VCRNUM-num$([F:MWI]TXNTYP)-num$([F:MWI]WIPSEQ)
        If [F:MWI]AMOUNT<>0
&        & sum([F:MWI]MATCST)=0
&        & sum([F:MWI]MACCST)=0
&        & sum([F:MWI]LABCST)=0
&        & [F:MWI]SCOCST    = 0
&        & [F:MWI]INVDTACST = 0
&        & [F:MWI]OVEMATCST = 0
&        & [F:MWI]OVEMACCST = 0
&        & [F:MWI]OVELABCST = 0

            Read [MWI]MWI0=
            If fstat
                GOK=0
                # Table ... Erreur de lecture
                Call ECR_TRACE(GMESSAGE-mess(56,123,1)-"WIPCOST"-":"-mess(49,125,1)-"(fstat="+num$(fstat)+")",1) From GESECRAN
                Break
            Else
                Read [ITM]ITM0=[F:MWI]ITMREF
                If find([F:MWI]TXNTYP,1,14)
                    Gosub ALIM_MWICST
                    Rewrite [MWI]
                Endif
                If fstat
                    GOK=0
                    # Table ... Erreur de réécriture
                    Call ECR_TRACE(GMESSAGE-mess(56,123,1)-"WIPCOST"-":"-mess(27,125,1)-"(fstat="+num$(fstat)+")",1) From GESECRAN
                    Break
                Endif
                If LSIM
                    Call ECR_TRACE(GMESSAGE,0) From GESECRAN
                    For I=8 To 15
                        Call ECR_TRACE("  [F:MWI]CSTELM("+num$(I)+")"+num$([F:MWI]CSTELM(I)),0) From GESECRAN
                    Next
                    For I=0 To GACTMAT-1
                        Call ECR_TRACE("    [F:MWI]MATCST("+num$(I)+")"+num$([F:MWI]MATCST(I)),0) From GESECRAN
                    Next
                    For I=0 To GACTLAB-1
                        Call ECR_TRACE("    [F:MWI]LABCST("+num$(I)+")"+num$([F:MWI]LABCST(I)),0) From GESECRAN
                    Next
                    For I=0 To GACTMAC-1
                        Call ECR_TRACE("    [F:MWI]MACCST("+num$(I)+")"+num$([F:MWI]MACCST(I)),0) From GESECRAN
                    Next
                    Call ECR_TRACE("    [F:MWI]SCOCST"+num$([F:MWI]SCOCST),0) From GESECRAN
                    Call ECR_TRACE("    [F:MWI]OVEMATCST"+num$([F:MWI]OVEMATCST),0) From GESECRAN
                    Call ECR_TRACE("    [F:MWI]OVELABCST"+num$([F:MWI]OVELABCST),0) From GESECRAN
                    Call ECR_TRACE("    [F:MWI]OVEMACCST"+num$([F:MWI]OVEMACCST),0) From GESECRAN
                    Call ECR_TRACE("    [F:MWI]OVESCOCST"+num$([F:MWI]OVESCOCST),0) From GESECRAN
                Endif
            Endif
            MAJ+=1
        Endif
    Next
    LMFGNUM = [F:MWI]VCRNUM
    STOP=1
    Break
Next

If GOK<1 | LSIM
    Rollback
Else
    Commit
Endif
If STOP
    Goto LOOP_MWI
Endif

GMESSAGE=""
If MAJ>0
   GMESSAGE=":"-num$(MAJ)-"Records updated"
Endif
Call ECR_TRACE("UTIGPA37 : Process End on : "+DOSSIER-GMESSAGE,0) From GESECRAN
GMESSAGE=""
End

########################################################################
# Utilisé aussi dans UUMGTRTGPA01
########################################################################
$ALIM_MWICST
        If [F:MWI]AMOUNT<>0
&        & sum([F:MWI]MATCST)=0
&        & sum([F:MWI]MACCST)=0
&        & sum([F:MWI]LABCST)=0
&        & [F:MWI]SCOCST    = 0
&        & [F:MWI]INVDTACST = 0
&        & [F:MWI]OVEMATCST = 0
&        & [F:MWI]OVEMACCST = 0
&        & [F:MWI]OVELABCST = 0
                Case [F:MWI]TXNTYP
                    When 1  :
                        If [F:MWI]AMOUNT<>0
&                        & sum([F:MWI]CSTELM(0..7))=0
&                        & sum([F:MWI]CSTELM(8..15))=0  # Conséquences du bug 48459
                            [F:MWI]CSTELM(0) = [F:MWI]AMOUNT
                            [F:MWI]CSTELM(8) = [F:MWI]AMOUNT
                            [F:MWI]MATCST(max(1,[F:MWI]MATGRP-1)) = [F:MWI]CSTELM(8)
                        Else
                            [F:MWI]MATCST(max(1,[F:MWI]MATGRP-1)) = [F:MWI]CSTELM(8)
                            [F:MWI]LABCST(0) = [F:MWI]CSTELM(9)
                            [F:MWI]MACCST(0) = [F:MWI]CSTELM(10)
                            [F:MWI]SCOCST = [F:MWI]CSTELM(11)
                            [F:MWI]OVEMATCST = [F:MWI]CSTELM(12)
                            [F:MWI]OVELABCST = [F:MWI]CSTELM(13)
                            [F:MWI]OVEMACCST = [F:MWI]CSTELM(14)
                            [F:MWI]OVESCOCST = [F:MWI]CSTELM(15)
                        Endif
                    When 14 :
                        [F:MWI]MATCST(max(1,[F:MWI]MATGRP-1)) = [F:MWI]CSTELM(8)
                        [F:MWI]LABCST(0) = [F:MWI]CSTELM(9)
                        [F:MWI]MACCST(0) = [F:MWI]CSTELM(10)
                        [F:MWI]SCOCST = [F:MWI]CSTELM(11)
                        [F:MWI]OVEMATCST = [F:MWI]CSTELM(12)
                        [F:MWI]OVELABCST = [F:MWI]CSTELM(13)
                        [F:MWI]OVEMACCST = [F:MWI]CSTELM(14)
                        [F:MWI]OVESCOCST = [F:MWI]CSTELM(15)
                        If [F:MWI]ITMTYP<>2 & clalev([F:MFC])<>0
                            # On tente de récupérer la décomposition dans le prévisionnel
                            If dim([F:MFC]VCRNUM)>0
                                Filter [MFC] Where VCRTYP=[F:MWI]VCRTYP
&                                                & VCRNUM=[F:MWI]VCRNUM
&                                                & VCRLIN=[F:MWI]VCRLIN
&                                                & STOFCY=[F:MWI]MFGFCY
&                                                & ITMREF=[F:MWI]ITMREF
&                                                & UID=0
&                                                & MFCTYP=2
                            Else
                                Filter [MFC] Where MFGNUM=[F:MWI]VCRNUM
&                                                & MFGLIN=[F:MWI]VCRLIN
&                                                & STOFCY=[F:MWI]MFGFCY
&                                                & ITMREF=[F:MWI]ITMREF
&                                                & MFCTYP=2
                            Endif
                            Read [MFC] First
                            If fstat
                                If dim([F:MFC]VCRNUM)>0
                                    Filter [MFC] Where VCRTYP=[F:MWI]VCRTYP
&                                                    & VCRNUM=[F:MWI]VCRNUM
&                                                    & VCRLIN=[F:MWI]VCRLIN
&                                                    & STOFCY=[F:MWI]MFGFCY
&                                                    & ITMREF=[F:MWI]ITMREF
&                                                    & UID=0
&                                                    & MFCTYP=1
                                Else
                                    Filter [MFC] Where MFGNUM=[F:MWI]VCRNUM
&                                                    & MFGLIN=[F:MWI]VCRLIN
&                                                    & STOFCY=[F:MWI]MFGFCY
&                                                    & ITMREF=[F:MWI]ITMREF
&                                                    & MFCTYP=1
                                Endif
                                Read [MFC] First
                            Endif
                            Filter [MFC]
                            If !fstat
                                Raz LVALMFC
                                For I=0 To GACTMAT-1
                                    LVALMFC(I) = [F:MFC]MATCPNCST(I)
                                Next
                                Call REPVAL([F:MWI]CSTELM(8),LVALMFC,0,LVALMFC)
                                For I=0 To GACTMAT-1
                                    [F:MWI]MATCST(I) = LVALMFC(I)
                                Next

                                Raz LVALMFC
                                For I=0 To GACTLAB-1
                                    LVALMFC(I) = [F:MFC]LABCPNCST(I) + [F:MFC]LABCST(I)
                                Next
                                Call REPVAL([F:MWI]CSTELM(9),LVALMFC,0,LVALMFC)
                                For I=0 To GACTLAB-1
                                    [F:MWI]LABCST(I) = LVALMFC(I)
                                Next

                                Raz LVALMFC
                                For I=0 To GACTMAC-1
                                    LVALMFC(I) = [F:MFC]MACCPNCST(I) + [F:MFC]MACCST(I)
                                Next
                                Call REPVAL([F:MWI]CSTELM(10),LVALMFC,0,LVALMFC)
                                For I=0 To GACTMAC-1
                                    [F:MWI]MACCST(I) = LVALMFC(I)
                                Next
                            Endif
                        Endif
                Endcase
        Endif
Return

##############################################################
# Répartition d'une valeur (PVAL) dans le vecteur PVALREP
# au prorata de PCLEREP, en arrondissant selon PRND
##############################################################
Subprog REPVAL(PVAL, PCLEREP, PRND, PVALREP)
Value Decimal PVAL
Value Decimal PCLEREP()
Value Decimal PRND
Variable Decimal PVALREP()

Local Integer I
Local Decimal LTOT, LCUMCLE, LCUMREP

Raz PVALREP

LTOT = sum(PCLEREP)
If LTOT=0 | PVAL=0
    End
Endif

Raz LCUMREP, LCUMCLE
For I=0 To dim(PCLEREP)-1
    LCUMCLE += PCLEREP(I)
    PVALREP(I) = PVAL*LCUMCLE/LTOT-LCUMREP
    If PRND<>0
        PVALREP(I) = arr(PVALREP(I),PRND)
    Endif
    LCUMREP+=PVALREP(I)
Next

End
########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat : Raz [F:ADS] : Endif
Call EXE_UTIGPA37(APPLI,0)
End

#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
Call EXE_UTIGPA37(APPLI,0)
End
