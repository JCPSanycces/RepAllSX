#<AdxTL>@(#)5.0.0.0 $Revision$
$ACTION
Case ACTION
 When "IMP_TAB"      : Gosub IMP_TAB
Endcase
Return


$IMP_TAB
If left$(IMPZON,3) = "CCE"
 I = val(right$(IMPZON,4))
 Assign "[M]CCE"+num$(I)+"("+num$(indice)+")" With evalue("[F:EXS]CCE("+num$(I-1)+")")
Elsif IMPZON="CUR" 
 Call INI_COURS("EXS0",[M:EXS0]CPY(indice),[M:EXS0]CUR(indice),[M:EXS0]RATDAT(indice),1,indice+1) From SUBEXS
Endif

Return

