#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
Endcase

Return

$OUVRE
If clalev([F:AWS])    = 0 : Local File AWRKHISSUI       [AWS]     : Endif
If clalev([F:ID])     = 0 : Local File EMPLOID          [ID]      : Endif
If clalev([F:HREXS])  = 0 : Local File HREXPENSES       [HREXS]   : Endif
If clalev([F:EXSH1])  = 0 : Local File EXPENSESHEA      [EXSH1]   : Endif
Return

$DEBUT
#Update header icon
#[M]WSTA2 = func ESS_FUNCTIONS.SET_ICON(2)
#[M]WSTADES2 = 2

Local Decimal TOTPAY
nolign =0

Filter [F:AWS] Where DEST = GUSER and FLGSIG =3 and (CODEVT="HREXS" | CODEVT = "EXSMOD" )
For [F:AWS]AWS0
  Raz TOTPAY
  nolign +=1
  If nolign > dim([M:ESWXS]REFNUM) : Break : Endif
  [M:ESWXS] = [F:AWS]
  For [F:HREXS] Where REFNUM = [F:AWS]VALCTX1 and EXSNUM = val([F:AWS]VALCTX2)
    TOTPAY+=[F:HREXS]PAYSHR
  Next
  [M:ESWXS]TOTPAY(nolign-1) = TOTPAY
  Filter [F:EXSH1] Where REFNUM = [F:AWS]VALCTX1 and EXSNUM = val([F:AWS]VALCTX2)
  Read [F:EXSH1] First
  Filter [F:EXSH1]
  If !fstat
    [M:ESWXS] = [F:EXSH1]
    #Update icon
    #[M:ESWXS]WSTA(nolign-1) = func ESS_FUNCTIONS.SET_ICON([F:EXSH1]EXSSTA)
  Endif

  Read [F:ID]ID0 = [F:AWS]VALCTX1
  If !fstat
    [M:ESWXS]NAM(nolign-1) = [F:ID]NAM
    [M:ESWXS]SRN(nolign-1) = [F:ID]SRN
  Endif
  [M:ESWXS]NBRLIN = nolign
Next
Filter [F:AWS]
Affzo [M:ESWXS]1-99
Return

$REFRESH_ESSWRKEXS
Local Integer TOTLINE, I
##This routine is used to refresh the screen after an approval has been made to remove the record(s) from the screen

[L]TOTLINE = [M:ESWXS]NBRLIN
[L]I = [L]TOTLINE
For nolign = 1 To TOTLINE
  If [M:ESWXS]WWRK(nolign-1) = "S" #signed
    Dela nolign-1 [M:ESWXS]NBRLIN
    [L]I-=1
  Endif
Next
[M:ESWXS]NBRLIN = [L]I
Affzo [M:ESWXS]1-99
Return

