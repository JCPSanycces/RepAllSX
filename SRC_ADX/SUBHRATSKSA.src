#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "LIENS"        : Gosub LIENS
  When "STYLE"        : Gosub STYLE
  When "INIMOD"       : Gosub INIMOD
Endcase
Return

#JASMI - 2015-08-12 - Req. 108579 - US 3890 - START
$OUVRE
If clalev([F:HRATSSA])=0 : Local File HRTASSEDICSA [HRATSSA] : Endif

Return

$LIENS
nolign=0
For [F:HRATSSA]ATS0 Where REFNUM=[F:HRATS]REFNUM & CTRNUM=[F:HRATS]CTRNUM & XITDAT=[F:HRATS]XITDAT
  [M:HRASS3]=[F:HRATSSA]
  [M:HRASS4]=[F:HRATSSA]

  For I=2 To 18
    If [F:HRATS]AMTALC(I)<>0
      nolign+=1
      [M:HRASS6]AMTALCCOD(nolign-1)=[F:HRATSSA]AMTALCCOD(I)
      [M:HRASS6]AMTALC(nolign-1)=[F:HRATS]AMTALC(I)
    Endif
  Next
Next
[M:HRASS6]NBRALC=nolign

Return

$STYLE
#JASMI - 2015-07-20 - Requirement 108579 - US 3790 - START
#Renaming and hiding fields
#MIPEA - 2016-08-11 - X3PEOP-975 - START
  If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
  #If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
#MIPEA - 2016-08-11 - X3PEOP-975 - END
  #JASMI - 2015-10-20 - Requirement 108579 - US 3990 - START
  #changes to header
  #hide fields
    If dim([M:HRASS0]NUMORD)>0 : Chgfmt [M:HRASS0]NUMORD  With "-N:8" : Raz [M:HRASS0]NUMORD : Endif
  #JASMI - 2015-10-20 - Requirement 108579 - US 3990 - END

  #changes to employee tab
  #raname field
    If dim([M:HRASS1]OLDNAM)>0 : Chgtzn [M:HRASS1]OLDNAM     With mess(22,11662,1) : Endif

  #raname block
    Chgtbk [M:HRASS1]10         With mess(36,11662,1)

  #hide block and contents
  #MIPEA - 2016-08-11 - X3PEOP-975 - START
    If func DIVPAYE.IS_KZA(GCURLEG)
    #If func AFNC.ACTIV("KZA")>0
  #MIPEA - 2016-08-11 - X3PEOP-975 - END
      If dim([M:HRASS1]NUMSSC)>0 : Chgfmt [M:HRASS1]NUMSSC  With "-K:30X" : Endif
    Endif
    Chgtbk [M:HRASS1]20         With ""
    If dim([M:HRASS1]FLGLIKFAM)>0 : Chgfmt [M:HRASS1]FLGLIKFAM  With "-LA:1"    : Raz [M:HRASS1]FLGLIKFAM : Endif
    If dim([M:HRASS1]TYPLNK)>0    : Chgfmt [M:HRASS1]TYPLNK     With "-LA:2524" : Raz [M:HRASS1]TYPLNK : Endif
    If dim([M:HRASS1]CATQLF)>0    : Chgfmt [M:HRASS1]CATQLF     With "-K:20X"   : Raz [M:HRASS1]CATQLF : Endif
    If dim([M:HRASS1]STA)>0       : Chgfmt [M:HRASS1]STA        With "-K:20X"   : Raz [M:HRASS1]STA : Endif
    If dim([M:HRASS1]TEL)>0       : Chgfmt [M:HRASS1]TEL        With "-K:20X"   : Raz [M:HRASS1]TEL : Endif
    If dim([M:HRASS1]EML)>0       : Chgfmt [M:HRASS1]EML        With "-K:50X"   : Raz [M:HRASS1]EML : Endif
    If dim([M:HRASS1]TYPSCH)>0    : Chgfmt [M:HRASS1]TYPSCH     With "-K:50X"   : Raz [M:HRASS1]TYPSCH : Endif
    If dim([M:HRASS1]SCH)>0       : Chgfmt [M:HRASS1]SCH        With "-K:50X"   : Raz [M:HRASS1]SCH : Endif

  #hide block and contents
    Chgtbk [M:HRASS1]25         With ""
    If dim([M:HRASS1]JOBPUB)>0 : Chgfmt [M:HRASS1]JOBPUB     With "-LA:364"  : Raz [M:HRASS1]JOBPUB : Endif

  #hide block and contents
    Chgtbk [M:HRASS1]30         With ""
    If dim([M:HRASS1]CAIARC)>0    : Chgfmt [M:HRASS1]CAIARC     With "-K:200X"  : Raz [M:HRASS1]CAIARC : Endif
    If dim([M:HRASS1]CAIAGI)>0    : Chgfmt [M:HRASS1]CAIAGI     With "-K:200X"  : Raz [M:HRASS1]CAIAGI : Endif
    If dim([M:HRASS1]CAIRETSPE)>0 : Chgfmt [M:HRASS1]CAIRETSPE  With "-K:200X"  : Raz [M:HRASS1]CAIRETSPE : Endif

  #changes to employer tab
  #hide field
    If dim([M:HRASS2]FCYSTALEG)>0 : Chgfmt [M:HRASS2]FCYSTALEG  With "-K:30X" : Raz [M:HRASS2]FCYSTALEG : Endif

  #hide block and contents
    Chgtbk [M:HRASS2]10         With ""
    If dim([M:HRASS2]ORGASS)>0    : Chgfmt [M:HRASS2]ORGASS     With "-LA:325"  : Raz [M:HRASS2]ORGASS : Endif
    If dim([M:HRASS2]ORGASSSPE)>0 : Chgfmt [M:HRASS2]ORGASSSPE  With "-K:15X"   : Raz [M:HRASS2]ORGASSSPE : Endif
    If dim([M:HRASS2]NUMORGASS)>0 : Chgfmt [M:HRASS2]NUMORGASS  With "-K:15X"   : Raz [M:HRASS2]NUMORGASS : Endif

  #hide block and contents
    Chgtbk [M:HRASS2]15         With ""
    If dim([M:HRASS2]FLGNSS)>0    : Chgfmt [M:HRASS2]FLGNSS     With "-LA:1"    : Raz [M:HRASS2]FLGNSS : Endif
    If dim([M:HRASS2]FLGVACSPE)>0 : Chgfmt [M:HRASS2]FLGVACSPE  With "-LA:1"    : Raz [M:HRASS2]FLGVACSPE : Endif
    If dim([M:HRASS2]FLGAFR)>0    : Chgfmt [M:HRASS2]FLGAFR     With "-LA:1"    : Raz [M:HRASS2]FLGAFR : Endif
    If dim([M:HRASS2]FLGCVT)>0    : Chgfmt [M:HRASS2]FLGCVT     With "-LA:1"    : Raz [M:HRASS2]FLGCVT : Endif
    If dim([M:HRASS2]NUMCVT)>0    : Chgfmt [M:HRASS2]NUMCVT     With "-K:6X"    : Raz [M:HRASS2]NUMCVT : Endif
    If dim([M:HRASS2]CODANA)>0    : Chgfmt [M:HRASS2]CODANA     With "-K:4X"    : Raz [M:HRASS2]CODANA : Endif
    If dim([M:HRASS2]FLGRVC)>0    : Chgfmt [M:HRASS2]FLGRVC     With "-LA:1"    : Raz [M:HRASS2]FLGRVC : Endif
    If dim([M:HRASS2]DATADH)>0    : Chgfmt [M:HRASS2]DATADH     With "-D:"+GFMDAT4 : Raz [M:HRASS2]DATADH : Endif
    If dim([M:HRASS2]FCYNBRSAL)>0 : Chgfmt [M:HRASS2]FCYNBRSAL  With "-N:6"     : Raz [M:HRASS2]FCYNBRSAL : Endif
    If dim([M:HRASS2]FCYCRN)>0    : Chgfmt [M:HRASS2]FCYCRN     With "-K:20X"   : Raz [M:HRASS2]FCYCRN : Endif
    If dim([M:HRASS2]FCYNAF)>0    : Chgfmt [M:HRASS2]FCYNAF     With "-K:10X"   : Raz [M:HRASS2]FCYNAF : Endif

  #changes to job tab
  #hide block and contents
    Chgtbk [M:HRASS3]15         With ""
    If dim([M:HRASS3]DEPLSTPLC)>0 : Chgfmt [M:HRASS3]DEPLSTPLC  With "-K:2X"    : Raz [M:HRASS3]DEPLSTPLC : Endif
    If dim([M:HRASS3]EMPSYSSSC)>0 : Chgfmt [M:HRASS3]EMPSYSSSC  With "-K:20X"   : Raz [M:HRASS3]EMPSYSSSC : Endif
    If dim([M:HRASS3]NAMSYSSSC)>0 : Chgfmt [M:HRASS3]NAMSYSSSC  With "-K:30X"   : Raz [M:HRASS3]NAMSYSSSC : Endif
    If dim([M:HRASS3]NUMSYSSSC)>0 : Chgfmt [M:HRASS3]NUMSYSSSC  With "-K:15X"   : Raz [M:HRASS3]NUMSYSSSC : Endif

  #JASMI - 2015-11-02 - Req. 105483 - START
  #MIPEA - 2016-08-11 - X3PEOP-975 - START
    If func DIVPAYE.IS_MIDDLEEAST_LEG(GCURLEG)
    #If func AFNC.ACTIV("KMIEA")>0
  #MIPEA - 2016-08-11 - X3PEOP-975 - START
      If dim([M:HRASS3]FLGPRV)>0     : Chgfmt [M:HRASS3]FLGPRV     With "-LA:1"       : Raz [M:HRASS3]FLGPRV : Endif
      If dim([M:HRASS3]FLGPRVOFF)>0  : Chgfmt [M:HRASS3]FLGPRVOFF  With "-LA:1"       : Raz [M:HRASS3]FLGPRVOFF : Endif
      If dim([M:HRASS3]STRDATPRV1)>0 : Chgfmt [M:HRASS3]STRDATPRV1 With "-D:"+GFMDAT4 : Raz [M:HRASS3]STRDATPRV1 : Endif
      If dim([M:HRASS3]STRDATPRV2)>0 : Chgfmt [M:HRASS3]STRDATPRV2 With "-D:"+GFMDAT4 : Raz [M:HRASS3]STRDATPRV2 : Endif
      If dim([M:HRASS3]STRDATPRV3)>0 : Chgfmt [M:HRASS3]STRDATPRV3 With "-D:"+GFMDAT4 : Raz [M:HRASS3]STRDATPRV3 : Endif
      If dim([M:HRASS3]STRDATPRV4)>0 : Chgfmt [M:HRASS3]STRDATPRV4 With "-D:"+GFMDAT4 : Raz [M:HRASS3]STRDATPRV4 : Endif
      If dim([M:HRASS3]ENDDATPRV1)>0 : Chgfmt [M:HRASS3]ENDDATPRV1 With "-D:"+GFMDAT4 : Raz [M:HRASS3]ENDDATPRV1 : Endif
      If dim([M:HRASS3]ENDDATPRV2)>0 : Chgfmt [M:HRASS3]ENDDATPRV2 With "-D:"+GFMDAT4 : Raz [M:HRASS3]ENDDATPRV2 : Endif
      If dim([M:HRASS3]ENDDATPRV3)>0 : Chgfmt [M:HRASS3]ENDDATPRV3 With "-D:"+GFMDAT4 : Raz [M:HRASS3]ENDDATPRV3 : Endif
      If dim([M:HRASS3]ENDDATPRV4)>0 : Chgfmt [M:HRASS3]ENDDATPRV4 With "-D:"+GFMDAT4 : Raz [M:HRASS3]ENDDATPRV4 : Endif
      If dim([M:HRASS3]GRDPRV)>0     : Chgfmt [M:HRASS3]GRDPRV     With "-K:30X"      : Raz [M:HRASS3]GRDPRV : Endif
    Endif
  #JASMI - 2015-11-02 - Req. 105483 - END

  #changes to termination tab
  #hide fields
    If dim([M:HRASS4]GRDHRSWEK)>0 : Chgfmt [M:HRASS4]GRDHRSWEK  With "-LA:366"  : Raz [M:HRASS4]GRDHRSWEK : Endif
    If dim([M:HRASS4]GRDHRSSPE)>0 : Chgfmt [M:HRASS4]GRDHRSSPE  With "-K:20X"   : Raz [M:HRASS4]GRDHRSSPE : Endif

  #JASMI - 2015-10-19 - Requirement 108579 - US 3990 - START
    Chgtbk [M:HRASS4]20 With ""
    If dim([M:HRASS4]PLNSOC)>0    : Chgfmt [M:HRASS4]PLNSOC     With "-LA:1"        : Raz [M:HRASS4]PLNSOC : Endif
    If dim([M:HRASS4]DATPLNSOC)>0 : Chgfmt [M:HRASS4]DATPLNSOC  With "-D:"+GFMDAT4  : Raz [M:HRASS4]DATPLNSOC : Endif
    If dim([M:HRASS4]FLGCNG)>0    : Chgfmt [M:HRASS4]FLGCNG     With "-LA:1"        : Raz [M:HRASS4]FLGCNG : Endif
  #JASMI - 2015-10-19 - Requirement 108579 - US 3990 - END

  #hide block and contents
    Chgtbk [M:HRASS4]25         With ""
    If dim([M:HRASS4]REJCVTFNE)>0 : Chgfmt [M:HRASS4]REJCVTFNE  With "-LA:1"    : Raz [M:HRASS4]REJCVTFNE : Endif

  #hide block and contents
    Chgtbk [M:HRASS4]30         With ""
    If dim([M:HRASS4]FLGFNG1)>0   : Chgfmt [M:HRASS4]FLGFNG1    With "-LA:1"    : Raz [M:HRASS4]FLGFNG1 : Endif
    If dim([M:HRASS4]FLGFNG2)>0   : Chgfmt [M:HRASS4]FLGFNG2    With "-LA:1"    : Raz [M:HRASS4]FLGFNG2 : Endif
    If dim([M:HRASS4]CLM1)>0      : Chgfmt [M:HRASS4]CLM1       With "-K:30X"   : Raz [M:HRASS4]CLM1 : Endif
    If dim([M:HRASS4]CLM2)>0      : Chgfmt [M:HRASS4]CLM2       With "-K:30X"   : Raz [M:HRASS4]CLM2 : Endif
    If dim([M:HRASS4]GRD1)>0      : Chgfmt [M:HRASS4]GRD1       With "-K:30X"   : Raz [M:HRASS4]GRD1 : Endif
    If dim([M:HRASS4]GRD2)>0      : Chgfmt [M:HRASS4]GRD2       With "-K:30X"   : Raz [M:HRASS4]GRD2 : Endif
    If dim([M:HRASS4]GRDXITSPE)>0 : Chgfmt [M:HRASS4]GRDXITSPE  With "-K:30X"   : Raz [M:HRASS4]GRDXITSPE : Endif

  #JASMI - 2015-10-19 - Requirement 108579 - US 3990 - START
  #changes to salaries and bonuses tab
    If dim([M:HRASS5]NBRDAY)>0    : Chgfmt [M:HRASS5]NBRDAY     With "-Nz:6.2"  : Raz [M:HRASS5]NBRDAY : Endif
  #JASMI - 2015-10-19 - Requirement 108579 - US 3990 - END

  #changes to full settlement tab
  #rename block
    Chgtbk [M:HRASS6]15         With mess(41,11662,1)

  #raname field
    If dim([M:HRASS6]ALCLEA)>0 : Chgtzn [M:HRASS6]ALCLEA With mess(37,11662,1) : Endif

  #hide fields
    If dim([M:HRASS6]CAIPRO)>0    : Chgfmt [M:HRASS6]CAIPRO    With "-K:30X"   : Raz [M:HRASS6]CAIPRO    : Endif
    If dim([M:HRASS6]NBRDAYLEA)>0 : Chgfmt [M:HRASS6]NBRDAYLEA With "-Nz:3.0"  : Raz [M:HRASS6]NBRDAYLEA : Endif
    If dim([M:HRASS6]AMTALC1)>0   : Chgfmt [M:HRASS6]AMTALC1   With "-Nz:9.2"  : Raz [M:HRASS6]AMTALC1   : Endif
    If dim([M:HRASS6]AMTALC2)>0   : Chgfmt [M:HRASS6]AMTALC2   With "-Nz:9.2"  : Raz [M:HRASS6]AMTALC2   : Endif
    If dim([M:HRASS6]AMTALC3)>0   : Chgfmt [M:HRASS6]AMTALC3   With "-Nz:9.2"  : Raz [M:HRASS6]AMTALC3   : Endif
    If dim([M:HRASS6]AMTALC4)>0   : Chgfmt [M:HRASS6]AMTALC4   With "-Nz:9.2"  : Raz [M:HRASS6]AMTALC4   : Endif
    If dim([M:HRASS6]AMTALC5)>0   : Chgfmt [M:HRASS6]AMTALC5   With "-Nz:9.2"  : Raz [M:HRASS6]AMTALC5   : Endif
    If dim([M:HRASS6]AMTALC6)>0   : Chgfmt [M:HRASS6]AMTALC6   With "-Nz:9.2"  : Raz [M:HRASS6]AMTALC6   : Endif
    If dim([M:HRASS6]AMTALC7)>0   : Chgfmt [M:HRASS6]AMTALC7   With "-Nz:9.2"  : Raz [M:HRASS6]AMTALC7   : Endif
    If dim([M:HRASS6]AMTALC8)>0   : Chgfmt [M:HRASS6]AMTALC8   With "-Nz:9.2"  : Raz [M:HRASS6]AMTALC8   : Endif
    If dim([M:HRASS6]AMTALC9)>0   : Chgfmt [M:HRASS6]AMTALC9   With "-Nz:9.2"  : Raz [M:HRASS6]AMTALC9   : Endif
    If dim([M:HRASS6]AMTALC10)>0  : Chgfmt [M:HRASS6]AMTALC10  With "-Nz:9.2"  : Raz [M:HRASS6]AMTALC10  : Endif
    If dim([M:HRASS6]AMTALC11)>0  : Chgfmt [M:HRASS6]AMTALC11  With "-Nz:9.2"  : Raz [M:HRASS6]AMTALC11  : Endif
    If dim([M:HRASS6]AMTALC12)>0  : Chgfmt [M:HRASS6]AMTALC12  With "-Nz:9.2"  : Raz [M:HRASS6]AMTALC12  : Endif
    If dim([M:HRASS6]AMTALC13)>0  : Chgfmt [M:HRASS6]AMTALC13  With "-Nz:9.2"  : Raz [M:HRASS6]AMTALC13  : Endif
    If dim([M:HRASS6]AMTALC14)>0  : Chgfmt [M:HRASS6]AMTALC14  With "-Nz:9.2"  : Raz [M:HRASS6]AMTALC14  : Endif
    If dim([M:HRASS6]AMTALC15)>0  : Chgfmt [M:HRASS6]AMTALC15  With "-Nz:9.2"  : Raz [M:HRASS6]AMTALC15  : Endif
    If dim([M:HRASS6]AMTALC16)>0  : Chgfmt [M:HRASS6]AMTALC16  With "-Nz:9.2"  : Raz [M:HRASS6]AMTALC16  : Endif
    If dim([M:HRASS6]AMTALC17)>0  : Chgfmt [M:HRASS6]AMTALC17  With "-Nz:9.2"  : Raz [M:HRASS6]AMTALC17  : Endif
    If dim([M:HRASS6]AMTALC18)>0  : Chgfmt [M:HRASS6]AMTALC18  With "-Nz:9.2"  : Raz [M:HRASS6]AMTALC18  : Endif
    If dim([M:HRASS6]AMTALC19)>0  : Chgfmt [M:HRASS6]AMTALC19  With "-Nz:9.2"  : Raz [M:HRASS6]AMTALC19  : Endif
    If dim([M:HRASS6]FLGALC14)>0  : Chgfmt [M:HRASS6]FLGALC14  With "-LA:1"    : Raz [M:HRASS6]FLGALC14  : Endif

  #hide fields
    If dim([M:HRASS7]NBRDIF)>0    : Chgfmt [M:HRASS7]NBRDIF    With "-Nz:9.2" : Raz [M:HRASS7]NBRDIF    : Endif
    If dim([M:HRASS7]AMTDIF)>0    : Chgfmt [M:HRASS7]AMTDIF    With "-Nz:9.2" : Raz [M:HRASS7]AMTDIF    : Endif
    If dim([M:HRASS7]ORGDIF1)>0   : Chgfmt [M:HRASS7]ORGDIF1   With "-K:10X"  : Raz [M:HRASS7]ORGDIF1   : Endif
    If dim([M:HRASS7]ORGDIF2)>0   : Chgfmt [M:HRASS7]ORGDIF2   With "-K:10X"  : Raz [M:HRASS7]ORGDIF2   : Endif
    If dim([M:HRASS7]FLGPORMUT)>0 : Chgfmt [M:HRASS7]FLGPORMUT With "-LA:1"   : Raz [M:HRASS7]FLGPORMUT : Endif
    If dim([M:HRASS7]FLGPORPRV)>0 : Chgfmt [M:HRASS7]FLGPORPRV With "-LA:1"   : Raz [M:HRASS7]FLGPORPRV : Endif
    If dim([M:HRASS7]NBRMON)>0    : Chgfmt [M:HRASS7]NBRMON    With "-Nz:9.2" : Raz [M:HRASS7]NBRMON    : Endif
    If dim([M:HRASS7]NBRWEE)>0    : Chgfmt [M:HRASS7]NBRWEE    With "-Nz:9.2" : Raz [M:HRASS7]NBRWEE    : Endif

  Endif
#JASMI - 2015-07-20 - Requirement 108579 - US 3790 - END

Return

$INIMOD
Delete [F:HRATSSA] Where REFNUM=[F:HRATS]REFNUM & XITDAT=[F:HRATS]XITDAT & CTRNUM=[F:HRATS]CTRNUM
If fstat=1
 GOK =-1 : GLOCK = "$HRTASSEDICSA" : Return
Endif
Raz [F:HRATSSA]
[F:HRATSSA]REFNUM=[F:HRATS]REFNUM
[F:HRATSSA]XITDAT=[F:HRATS]XITDAT
[F:HRATSSA]CTRNUM=[F:HRATS]CTRNUM
[F:HRATSSA]DATANC=[M:HRASS3]DATANC
If [F:HRATS]XITDAT=[0/0/0] or [F:HRATSSA]DATANC=[0/0/0]
  [F:HRATSSA]ANCPERSRV=0
Else
  [F:HRATSSA]ANCPERSRV=(year([F:HRATS]XITDAT)-year([F:HRATSSA]DATANC))*12
#JASMI - 2016-01-08 - Requirement 113175 - START
#  [F:HRATSSA]ANCPERSRV+=(month([F:HRATS]XITDAT)-month([F:HRATSSA]DATANC))
  [F:HRATSSA]ANCPERSRV+=(month([F:HRATS]XITDAT)-month([F:HRATSSA]DATANC))+1
#JASMI - 2016-01-08 - Requirement 113175 - END
Endif
[F:HRATSSA]DATCPY=[M:HRASS3]DATCPY
If [F:HRATS]XITDAT=[0/0/0] or [F:HRATSSA]DATCPY=[0/0/0]
  [F:HRATSSA]CPYPERSRV=0
Else
  [F:HRATSSA]CPYPERSRV=(year([F:HRATS]XITDAT)-year([F:HRATSSA]DATCPY))*12
#JASMI - 2016-01-08 - Requirement 113175 - START
#  [F:HRATSSA]CPYPERSRV+=(month([F:HRATS]XITDAT)-month([F:HRATSSA]DATCPY))
  [F:HRATSSA]CPYPERSRV+=(month([F:HRATS]XITDAT)-month([F:HRATSSA]DATCPY))+1
#JASMI - 2016-01-08 - Requirement 113175 - END
Endif
[F:HRATSSA]DATFCY=[M:HRASS3]DATFCY
If [F:HRATS]XITDAT=[0/0/0] or [F:HRATSSA]DATFCY=[0/0/0]
  [F:HRATSSA]FCYPERSRV=0
Else
  [F:HRATSSA]FCYPERSRV=(year([F:HRATS]XITDAT)-year([F:HRATSSA]DATFCY))*12
#JASMI - 2016-01-08 - Requirement 113175 - START
#  [F:HRATSSA]FCYPERSRV+=(month([F:HRATS]XITDAT)-month([F:HRATSSA]DATFCY))
  [F:HRATSSA]FCYPERSRV+=(month([F:HRATS]XITDAT)-month([F:HRATSSA]DATFCY))+1
#JASMI - 2016-01-08 - Requirement 113175 - END
Endif
#MIPEA - 2016-08-11 - X3PEOP-975 - START
If func DIVPAYE.IS_KZA(GCURLEG)
#If func AFNC.ACTIV("KZA")>0
#MIPEA - 2016-08-11 - X3PEOP-975 - START
  [F:HRATSSA]UEMCLMSUB=[M:HRASS4]UEMCLMSUB
  [F:HRATSSA]TOTMONREM=[M:HRASS4]TOTMONREM
  [F:HRATSSA]NONCTBRSN=[M:HRASS4]NONCTBRSN
  [F:HRATSSA]TERRSN=[M:HRASS4]TERRSN
Endif
#JASMI - 2015-08-19 - Requirement 108579 - US 3790 - START
[F:HRATSSA]ALWREE=[M:HRASS3]ALWREE
[F:HRATSSA]REERSN=[M:HRASS3]REERSN
#JASMI - 2015-08-19 - Requirement 108579 - US 3790 - END

#JASMI - 2015-10-27 - Req. 108579 - US 3890 - START
[F:HRATSSA]EXOCOD=[M:HRASS4]EXOCOD
#JASMI - 2015-10-27 - Req. 108579 - US 3890 - END

#JASMI - 2015-11-02 - Req. 105483 - START
#MIPEA - 2016-08-11 - X3PEOP-975 - START
If func DIVPAYE.IS_MIDDLEEAST_LEG(GCURLEG)
#If func AFNC.ACTIV("KMIEA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0)
#MIPEA - 2016-08-11 - X3PEOP-975 - START
  [F:HRATSSA]NTCPAY=[M:HRASS3]NTCPAY
  [F:HRATSSA]DNARUPCON=[M:HRASS3]DNARUPCON
Endif
#JASMI - 2015-11-02 - Req. 105483 - END

#redundancy
For I=2 To 18
  [F:HRATSSA]AMTALCCOD(I)=""
  [F:HRATS]AMTALC(I)=0
Next

For nolign=1 To [M:HRASS6]NBRALC
  [F:HRATSSA]AMTALCCOD(nolign-1+2)=[M:HRASS6]AMTALCCOD(nolign-1)
  [F:HRATS]AMTALC(nolign-1+2)=[M:HRASS6]AMTALC(nolign-1)
Next

Write [F:HRATSSA]
If fstat<>0
  GOK = 0 : Call FSTA("HRATSSA") From GLOCK : Return
Endif

Return
#JASMI - 2015-08-12 - Req. 108579 - US 3890 - END

