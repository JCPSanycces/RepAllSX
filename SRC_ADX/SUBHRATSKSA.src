#MIPEA - 2016-10-11 - X3PEOP-751 - START
Subprog AM_TERRSN(VALEUR)
Variable Char VALEUR
#Motif obligatoire en cas de :
  #"Autre motif autre que le licenciement"
  #"Licenciement pour autre motif"
  #"Démission"
  #59208 : "Licenciement"
If VALEUR="AUT" or VALEUR="ALI" or VALEUR="DEM" or VALEUR="LIC"
 Actzo[M:HRASS4]TERRSN
Else
 Effzo[M:HRASS4]TERRSN
 Grizo[M:HRASS4]TERRSN
Endif
End
#MIPEA - 2016-10-11 - X3PEOP-751 - END

