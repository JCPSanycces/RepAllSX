#<AdxTL>@(#)1.0.0.0 $Revision$
#######################################################
# Tâche batch de suivi des sessions
#######################################################

$ACTION

  Case ACTION
    When "INIT"         : Gosub INIT
    When "EXEC"         : Gosub EXEC
    When "TERMINE"      : Gosub TERMINE
    When "OUVRE_BATCH"  : Gosub OUVRE
    When Default
  Endcase
Return

#######################################################
$INIT

  Gosub OUVRE
Return

#######################################################
$OUVRE

  If clalev([F:HRSES])=0 : Local File SESSIONS [HRSES] : Endif
  If clalev([F:INS])=0 : Local File INSCRIPT [INS] : Endif
  If clalev([F:TSE])=0 : Local File TMPSES   [TSE] : Endif
Return

#######################################################
$EXEC
Local Char TIT(50)

  TIT=mess(172,10717,1) : # Suivi des sessions
  If !GSERVEUR
    Call OUVRE_TRACE(TIT) From LECFIC
  Endif
  
  Call SUIVI_SESSIONS
  
  If !GSERVEUR
    Call FERME_TRACE From LECFIC
  Endif
Return

###############################################################
$TERMINE

  If !GSERVEUR
    TRA = 1
  Else
    TRA = 0
  Endif
Return

# Pour les sessions à venir, on regarde si le nombre d'inscrits est inférieur au nombre minimum de la session
Subprog SUIVI_SESSIONS
Local Char MESSAGE(250)

  Gosub CHARGE_TSE From SUBHRSES
#  For [F:HRSES] Where STRDAT>=[01/08/2010]
  For [F:HRSES] Where STRDAT>=date$
    Read [F:TSE]TSE0=[F:HRSES]COD
    If !fstat Then
      If [F:TSE]NBRINS<[F:HRSES]NBRPRTMIN Then
        MESSAGE=mess(34,10717,1)-[F:HRSES]COD-mess(173,10717,1)-num$([F:HRSES]NBRPRTMIN-[F:TSE]NBRINS)-mess(174,10717,1) : # Session incomplète : il manque x participants
        Call ECR_TRACE(MESSAGE, 0) From GESECRAN
      Endif
    Endif
  Next
End
