#<AdxTL>@(#)11.0.0.0 $Revision$
#########################################################################
# Fonction Réactivation OF à l'étude      GPAO                          #
# annulation du blocage logique (par OPTFLG) des OF                     # 
# en cours d'optimisation                                               #
#                                                                       #
# ACTION  :                                                             #
#    SAIOPTFREE : action de saisie fenêtre                              #
#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################

$ACTION
#---Actions liées à la saisie fenêtre
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "DEBUT"      : Gosub DEBUT
  When "OK"         : Gosub OK
  When Default
Endcase

Return
####################################################################### 
$OUVRE
Call FIND_GFCYDEF(8) From TRTX3       # FQ 54218
Gosub CHARG_PARAM                 # mm 12.02

Return

####################################################################### 
$DEBUT
Raz [M:MOPF]
Call FIND_GFCYDEF(8) From TRTX3       # FQ 54218
[M:MOPF]MFGFCY = GFCY       
[M:MOPF]USR    = GUSER
Affzo [M:MOPF]          
Return

####################################################################### 
$OK
Call FREEMFG([M:MOPF]MFGFCY, [M:MOPF]USR,1) From OPTLIBA 
Return

########################################################################
# Chargement variables globales
$CHARG_PARAM

Call GLOBVAR(GFCY)    From WWGLOBSTO

# Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA

Return 
##########################################################################
## Etiquette ajoutée par le superviseur 21/10/2003 13:45:46 (MM)
##########################################################################
Subprog AM_MFGFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> GFCY                   # mm 12.02
    GFCY=VALEUR                     # mm 12.02
    Gosub CHARG_PARAM
Endif                               # mm 12.02

End


##########################################################################

