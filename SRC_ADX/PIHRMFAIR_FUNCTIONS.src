Funprog TOKEN_REQUEST(I_PCLASS,V_TOKENVAL)
Variable Instance I_PCLASS Using C_PIHRMFAIR
Variable Char V_TOKENVAL
Local Integer RETVAL : RETVAL = [V]CST_AOK
Gosub DECLARE_TOKENVAL

Gosub DECLARE_CLASSES_WSERV

#1.Get the token from Fairsail (Salesforce)
HTTP_STATUS = func GET_TOKEN(RESBODY_FUNC,RESHEAD_FUNC)

#Test the HTTP status returned from the function
If (int(HTTP_STATUS/100)<>2)
  End [V]CST_AERROR
Endif

#Parse the response body (Json file)
RETVAL = func PARSE_JSON_TOKEN(I_PCLASS,RESBODY_FUNC,TOKENVAL)

#Set return token value
V_TOKENVAL = TOKENVAL

End RETVAL




#**
#* Label for parsing the json (response body) and getting the token needed
#* @param I_PCLASS Instance , the current class instance (this)
#* @param JSONDBODY Clbfile, response body that will be parsed
#* @param TOKENVAL Char(255), token value from parsed json file "access_token"
#* @return RETVAL Integer - CST_AERROR or CST_AOK
#*!
Funprog PARSE_JSON_TOKEN(I_PCLASS,JSONDBODY,TOKENVAL)
Value Clbfile JSONDBODY
Variable Char TOKENVAL
Variable Instance I_PCLASS Using C_PIHRMFAIR
Local Integer RETVAL : RETVAL = [V]CST_AERROR

#Local variables
Local Integer   I_NODE

#Declare NODES
Gosub INIT_NODE

#Insert the Json file into the ASYRJSO (Supervisor) class
If func ASYRJSONPARSE.PARSEJSON(I_PCLASS.ACTX,JSONDBODY,NODES,NODE) = [V]CST_AOK
  RETVAL = [V]CST_AOK
  For [L]I_NODE = 1 To maxtab(NODES)
    If (NODES([L]I_NODE) <> null)
      #Check for "access_token"
      If NODES([L]I_NODE).PRO = "access_token"
        #Set the token value to variable char TOKENVAL
        TOKENVAL = mid$(NODES([L]I_NODE).CLB.CLB,NODES([L]I_NODE).START+1,NODES([L]I_NODE).LENGTH-2)
      Endif
    Endif
  Next
Endif
End RETVAL


Funprog INT_DEFAULT(VPROPERTY,VVALUE)
Value Char VVALUE,VPROPERTY
Local Char RETVALUE(250)
Local Integer I

#EMPLOID.SEX - can not have 0 value
If VPROPERTY = "SEX"
  If parse(VVALUE+"1")=0
    For I = 1 To len(mess(0,10314,1)) #BRI Legislation
      If val(VVALUE) = I
        RETVALUE = num$(I)
        Break
      Endif
    Next
    If RETVALUE = AVOID.ACHAR : RETVALUE = "1" : Endif
  Else
    RETVALUE = "1"
  Endif
Else
  RETVALUE = VVALUE
Endif

#EMPLOID.ENAFLG - Set to active if blank
If VPROPERTY = "ENAFLG"
  If parse(VVALUE+"1")=0
    For I = 1 To len(mess(0,00001,1)) #BRI Legislation
      If val(VVALUE) = I
        RETVALUE = num$(I)
        Break
      Endif
    Next
    If RETVALUE = AVOID.ACHAR : RETVALUE = "2" : Endif
  Else
    RETVALUE = "2"
  Endif
Else
  RETVALUE = VVALUE
Endif



End RETVALUE

Funprog ENCODE_URL(_URL)
Variable Char _URL
Local Char CHR(1)
Local Char URL(250)

For I=1 To len(_URL)
  CHR = mid$(_URL,I,1)
  If find(CHR,",","/","?",":","@","&","=","+","#"," ",'"',"'","%")
    URL += "%40"
  Else
    URL+= CHR
  Endif
Next
End URL

#**
#* Label for getting the mapped table name
#* @param MAPPEDCODE Char(10), Code mapped to the table
#* @return Local char MTABLE (GLONATB)- Table name mapped to code
#*!
Funprog GET_MAPPED_TABLE(MAPPEDCODE)
Value Char MAPPEDCODE
Local Char MTABLE (GLONATB)
#TODO: Might add as setup?

Case MAPPEDCODE
  When "1001"   : MTABLE = "EMPLOIDSTG"
  When "1002"   : MTABLE = "EMPUKISTG"
  When "1003"   : MTABLE = "EMPLOCTRSTG"
  When "1004"   : MTABLE = "EMPCTRUKISTG"
  When "1005"   : MTABLE = "EMPLORIBSTG"
Endcase

End MTABLE
#**
#* Label for getting the mapped table code
#* @param MAPPEDTABLE Char(GLONATB), Code mapped to the table
#* @return Local char MAPPEDCODE (5)- Table name mapped to code
#*!
Funprog GET_MAPPED_CODE(MAPPEDTABLE)
Value Char MAPPEDTABLE
Local Char MAPPEDCODE(5)

Case MAPPEDTABLE
  When "EMPLOIDSTG"     : MAPPEDCODE = "1001"
  When "EMPUKISTG"      : MAPPEDCODE = "1002"
  When "EMPLOCTRSTG"    : MAPPEDCODE = "1003"
  When "EMPCTRUKISTG"   : MAPPEDCODE = "1004"
  When "EMPLORIBSTG"    : MAPPEDCODE = "1005"
Endcase


End MAPPEDCODE

$PROPVALUE
Local Integer PROTYPE, IS_OK, IS_NUM
Local Char CONVERTED_PVALUE(250), PARSEVALUE(250)
#PERROR_MSG - Variable parameter from method
Local Integer ERROR_FLAG
[L]ARET_VALUE = [V]CST_AOK

#Implementing the error handling as we do not know what will be sent on Json
Onerrgo ERR_HANDLE
#First, we need to get the property type
PROTYPE = func PIHRMJSONFUNC.GETTYP(this, PPROPERTY)
#Add the value to the property

#Check specific fields for default values
CONVERTED_PVALUE = func PIHRMFAIR_FUNCTIONS.INT_DEFAULT(PPROPERTY, PVALUE)

#Loop through the class to get the matching property for the assignment
K=this.ObjectNbs
For J=1 To K
  #No need to check the type here as it will be mapped to properties and not classes
  If this.ObjectVar(J) = PPROPERTY
    [L]ARET_VALUE = [V]CST_AOK
    Gosub CONVERT_PROPVAL From PIHRMJSONFUNC
    Assign "this."+PPROPERTY With PROPVALCON
  Endif
Next J

If ERROR_FLAG
  [L]ARET_VALUE = [V]CST_AWARNING
Endif

Return

$ERR_HANDLE
  ERROR_FLAG=errn
  PERROR_MSG=errmes$(errn)
Resume

Subprog GET_ERRORS(WCONTAINER,VERRMSG)
Variable Char VERRMSG
Variable Instance WCONTAINER Using C_EMPLOCTRUKI

Local Integer I
Local Char WTEXTE(50)

VERRMSG = func LCCLIB.MAXMSG(WCONTAINER)
End

