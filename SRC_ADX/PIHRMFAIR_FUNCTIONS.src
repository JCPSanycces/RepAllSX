Local Integer LIN : LIN = 1

#Add line in PIHRMFAIRERR
Gosub ADD_ERRLINE
[L]ENDRESULT = [L]WRITESTATUS
End [L]ENDRESULT



$ADD_ERRLINE
Gosub INIT_PIHRMFAIRERR
I_PIHRMFAIRERR.INTUID    = PUNIQID
I_PIHRMFAIRERR.LVL       = ERRLVL
I_PIHRMFAIRERR.TYP       = ERRTYP
I_PIHRMFAIRERR.NAM       = ELEMENTNAME
I_PIHRMFAIRERR.IND       = ARRINDEX
I_PIHRMFAIRERR.FLDNAM    = VFLDNAM
I_PIHRMFAIRERR.ID        = EMPID
I_PIHRMFAIRERR.MSG       = VMSG
I_PIHRMFAIRERR.LEG       = PLEG
I_PIHRMFAIRERR.REFNUM    = VREFNUM
I_PIHRMFAIRERR.SRVTYP    = PPROCESSID
I_PIHRMFAIRERR.LIGNUM    = [L]LIN
I_PIHRMFAIRERR.CLA       = VACTIVE_CLASS
[L]WRITESTATUS           = fmet I_PIHRMFAIRERR.AINSERT()
Gosub FREE_PIHRMFAIRERR
Return



