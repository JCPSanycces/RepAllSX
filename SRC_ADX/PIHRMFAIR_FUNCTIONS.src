$DECLARE_CLASSES_WSERV
Local Clbfile DATA(0), DATA_SENT(0)
Local Char PCOD(100)(1..10),PVAL(200)(1..10),HCOD(100)(1..10),HVAL(200)(1..10)
Local Clbfile RESHEAD_FUNC(0),RESBODY_FUNC(0)
Local Integer I, FUTURE
Local Integer MAXTEXT, MAXCOUNTER
MAXTEXT = 250
Local Char MSG_RETS(MAXTEXT)
Local Integer HTTP_STATUS
Local Char MAINKEYFIELD(GLONAVA)
Local Char WEBSERNAME (50)
Local Char HTTPMETHOD (10)
Local Char SUBURL(250), AUTHOR(20)
Return


$DECLARE_INSTANCE_VARIABLES
Local Integer HTTP_FUNC, FUNCRETVAL
Local Integer INT_PAGECOUNT, I
Local Integer MAXTEXT,MAXEMP
MAXTEXT = 250
Local Char PAGECOUNT(10)
Local Char W_MESS(MAXTEXT)
Local Char W_MESS_FUNC(MAXTEXT)
Local Char MEMBERLISTARR(250)(0..)
Local Char MEMBERIDLISTARR(250)(0..)
Local Char RMESSAGE(250)
Local Char PAYROLLBATCHID(250)
Local Clbfile PAYBATCH_RESHEAD(0),PAYBATCH_RESBODY(0)
Local Clbfile EMPLOYEE_RESHEAD(0),EMPLOYEE_RESBODY(0)
Local Clbfile RETBODY_UNESCJSON_MEMBER(0)
Return


$DECLARE_TOKENVAL
Local Char TOKENVAL(255)
Return


Funprog PAYROLL_BATCH_REQUEST(I_PCLASS,TOKENVAL_RET,HTTP_RET,MSG_RET_FUNC,RETBODY_RET,RETHEAD_RET,PROCESS_INT,V_BID_DATA,V_BID_SERV)
Variable Instance I_PCLASS Using C_PIHRMFAIR
Variable Char MSG_RET_FUNC
Variable Clbfile RETBODY_RET, RETHEAD_RET
Variable Integer HTTP_RET
Value Char TOKENVAL_RET
Value Char V_BID_DATA,V_BID_SERV
Value Integer PROCESS_INT
Local Integer RETVAL
RETVAL = [V]CST_AOK

#Declare function variables
Gosub DECLARE_CLASSES_WSERV

#Request batch
Gosub REQUEST_BATCHLIST_FUNC

#Test the HTTP Status
If (int(HTTP_RET/100)<>2)
  #Populate return variables to handle in main sub
  #We know this is an error so we can set RETVAL to the function
  #Set the return message and RETVAL
  RETVAL = func PIHRMFAIR_FUNCTIONS.HANDLE_HTTP_ERROR(RESHEAD_FUNC,RESBODY_FUNC,MSG_RET_FUNC,HTTP_RET)
Endif

#Set return values- to used if successful
Gosub SET_RETURN_VALUE
End RETVAL

$REQUEST_BATCHLIST_FUNC
  HTTP_RET = func PIHRMFAIR_FUNCTIONS.GET_BATCHLIST(TOKENVAL_RET,RESBODY_FUNC,RESHEAD_FUNC,PROCESS_INT,V_BID_DATA,V_BID_SERV)
Return

#**
#* Evaluate a property in a class - used to compare values for any class
#* @param SYPROP Char array, array to be populated with system properties
#* @return RETVAL Local Integer
#*!
Funprog SET_SYPROP(VSYSPROP)
Variable Char VSYSPROP
Local Integer RETVAL
RETVAL = [V]CST_AOK

VSYSPROP(1)="AATTRIBUTES"
VSYSPROP(2)="ACTX"
VSYSPROP(3)="AERROR"
VSYSPROP(4)="AINF"
VSYSPROP(5)="AKEYS"
VSYSPROP(6)="AORDER"
VSYSPROP(7)="APARENT"
VSYSPROP(8)="ASTALIN"
VSYSPROP(9)="AUUID"
VSYSPROP(10)="CREDATTIM"
VSYSPROP(11)="UPDDATTIM"
VSYSPROP(12)="CREUSR"
VSYSPROP(13)="UPDUSR"
VSYSPROP(14)="CRETIM"
VSYSPROP(15)="CREDATTIM"
VSYSPROP(16)="CREDAT"
VSYSPROP(17)="UPDDAT"
VSYSPROP(18)="UPDDATTIM"
VSYSPROP(19)="UPDTIM"

End RETVAL




#**
#* Label for getting the token needed to call Fairsail(Salesforce) to obtain new URL
#* @param TOKENVAL Char(255), token value from parsed json file "access_token"
#* @param RETBODY_RET Local Clbfile, response body that will be populated by the web service call and can be used by the program calling the function
#* @param RETHEAD_RET Local Clbfile, response header that will be populated by the web service call and can be used by the program calling the function
#* @param INT_PROCESS Local Integer, integer value containing the integration process (1.Employee etc)
#* @return HTTP_STATUS Local Integer - see https://en.wikipedia.org/wiki/List_of_HTTP_status_codes for possible return codes
#*!
Funprog GET_BATCHLIST(TOKENVAL,RETBODY_RET,RETHEAD_RET,INT_PROCESS,V_BID_DATA,V_BID_SERV)
Value Integer INT_PROCESS
Value Char TOKENVAL,V_BID_DATA,V_BID_SERV
Variable Clbfile RETBODY_RET, RETHEAD_RET

#Declare variables to use in wserv call
Gosub DECLARE_CLASSES_WSERV

#TODO: Create local menu and build call to sub through evalue
Case INT_PROCESS
  When 1 : Gosub SET_GET_BATCHLIST From EMPLOIDSTG_CSTD_MPU
Endcase

HTTP_STATUS=func ASYRRESTCLI.EXEC_REST_WS(WEBSERNAME, HTTPMETHOD, SUBURL, PCOD,PVAL,HCOD,HVAL, DATA_SENT, FUTURE, "", RESHEAD_FUNC, RESBODY_FUNC)

Gosub SET_RETURN_VALUE
End HTTP_STATUS


Funprog PARSE_JSON_BATCHLIST(I_PCLASS,JSONDBODY,V_PAYROLLBATCHID,V_PAGECOUNT)
Value Clbfile JSONDBODY
Variable Char V_PAYROLLBATCHID
Variable Char V_PAGECOUNT
Variable Instance I_PCLASS Using C_PIHRMFAIR

#Local variables
Local Integer   I_NODE,RETVAL
Local Integer MEMBERARR,MEMBERIDARR
Local Clbfile RETBODY_UNESCJSON(0)

RETVAL = [V]CST_AERROR
RETBODY_UNESCJSON=unescJson(JSONDBODY)

#Declare NODES
Gosub INIT_NODE

#Insert the Json file into the ASYRJSO (Supervisor) class
If func ASYRJSONPARSE.PARSEJSON(I_PCLASS.ACTX,RETBODY_UNESCJSON,NODES,NODE) = [V]CST_AOK
  RETVAL = [V]CST_AOK
  For [L]I_NODE = 1 To maxtab(NODES)
    If (NODES([L]I_NODE) <> null)
      #Check for "teamMemberURI"
      If NODES([L]I_NODE).PRO = "payrollBatchURI"
        #Set payoll ID
        V_PAYROLLBATCHID = mid$(NODES([L]I_NODE).CLB.CLB,NODES([L]I_NODE).START+1,NODES([L]I_NODE).LENGTH-2)
      Endif
      If NODES([L]I_NODE).PRO = "pageCount"
        #Set the page count
        V_PAGECOUNT = mid$(NODES([L]I_NODE).CLB.CLB,NODES([L]I_NODE).START,NODES([L]I_NODE).LENGTH-1)
      Endif
    Endif
  Next
Endif


Gosub FREE_NODE
End RETVAL

Funprog GET_EMPLOYEE_LIST(VTIMER,HTTP_RET,TOKENVAL,RETBODY_RET,RETHEAD_RET,V_PAYROLLBATCHID,INT_PROCESS,VPAGECOUNT,MSG_RET)
Value Char TOKENVAL,V_PAYROLLBATCHID,MSG_RET
Value Integer VPAGECOUNT,VTIMER
Value Integer INT_PROCESS
Variable Integer  HTTP_RET
Variable Clbfile RETBODY_RET,RETHEAD_RET
#Local variables
Local Integer   WRITESTATUS,MY_STATUS,I_NODE,RETVAL
Local Integer FIRSTREC, ERRHANDLE
RETVAL = [V]CST_AOK

#Declare variables to use in wserv call
Gosub DECLARE_CLASSES_WSERV

#TODO: Create local menu and build call to sub through evalue
Case INT_PROCESS
  When 1 : Gosub SET_EMPLOYEE_REQUEST From EMPLOIDSTG_CSTD_MPU
Endcase

#Execute request
Gosub EXECUTE_EMPLOYEELIST
If (int(HTTP_RET/100)<>2)
  #Execute request
  Gosub EXECUTE_EMPLOYEELIST #Retry
Endif


If (int(HTTP_RET/100)<>2)
  #Populate return variables to handle in main sub
  #We know this is an error so we can set RETVAL to the function
  #Set the return message and RETVAL
  RETVAL = func PIHRMFAIR_FUNCTIONS.HANDLE_HTTP_ERROR(RESHEAD_FUNC,RESBODY_FUNC,MSG_RET,HTTP_RET)
Else
  Gosub SET_RETURN_VALUE
Endif

End RETVAL

$EXECUTE_EMPLOYEELIST
#Getting the timer details
Gosub GET_REQUEST_TIMER

While TIMEDIFF < SETTIMVAL
HTTP_STATUS=func ASYRRESTCLI.EXEC_REST_WS(WEBSERNAME, HTTPMETHOD, SUBURL, PCOD,PVAL,HCOD,HVAL, DATA_SENT, FUTURE, "", RESHEAD_FUNC, RESBODY_FUNC)
HTTP_RET = HTTP_STATUS
If (int(HTTP_RET/100)=2) : Break : Endif
ELAPSETIME = time
TIMEDIFF = ELAPSETIME-ORIGINTIME
Wend
Return

Funprog SEND_ERRORLIST(HTTP_RET,TOKENVAL,V_PAYROLLBATCHID,INT_PROCESS,MSG_RET,VLEG,VPROCESSID,VINTUID)
Value Char TOKENVAL,V_PAYROLLBATCHID,VLEG
Variable Char MSG_RET
Value Integer INT_PROCESS,VPROCESSID,VINTUID
Variable Integer  HTTP_RET

#Local variables
Local Char CURID(100),PREVID(100)
Local Char V_TEAMMEMBERID(100)
Local Integer RETVAL,FUNCRETVAL
RETVAL = [V]CST_AOK

#Loop through error table
#Combine each call with all errors for each member
Local File PIHRMFAIRERR [PHFE1]

Filter [F:PHFE1] Where INTUID = VINTUID and LEG = VLEG and SRVTYP = VPROCESSID Order By Key PHFE2 = ID Asc
If rowcount([PHFE1]) > 0 : RETVAL = [V]CST_AWARNING : Endif
For [PHFE1]PHFE2
  CURID = [F:PHFE1]ID
  If CURID <> PREVID
    V_TEAMMEMBERID = CURID
    #Send message
    FUNCRETVAL =  func SEND_MEMBER_GRP_ERR(HTTP_RET,TOKENVAL,V_PAYROLLBATCHID,INT_PROCESS,MSG_RET,V_TEAMMEMBERID,VLEG,VPROCESSID,VINTUID)
    If FUNCRETVAL = [V]CST_AERROR : Break : Endif
  Endif
  PREVID = [F:PHFE1]ID
Next
#We need to set the RETVAl to warning to indicate that there were errors found
#Manual assignment needed not to affect the normal behaviour of functions
If FUNCRETVAL = [V]CST_AERROR : RETVAL = [V]CST_AERROR : Endif
Filter [F:PHFE1]
End RETVAL

Funprog SEND_MEMBER_GRP_ERR(HTTP_RET,TOKENVAL,V_PAYROLLBATCHID,INT_PROCESS,MSG_RET,V_TEAMMEMBERID,PLEG,PPROCESSID,PINTUID)
Value Char TOKENVAL,V_PAYROLLBATCHID,V_TEAMMEMBERID,PLEG
Variable Char MSG_RET
Value Integer INT_PROCESS,PPROCESSID,PINTUID
Variable Integer  HTTP_RET

Local Integer   WRITESTATUS,MY_STATUS,I_NODE,RETVAL
Local Integer FIRSTREC, ERRHANDLE
Local Clbfile JSON_DATA
Local Integer TABLEROWCOUNT, I, FUNCRET
Local Char JSONDATE(10)
FUNCRET = [V]CST_AOK
JSONDATE = num$(year(date$))+"-"+num$(month(date$))+"-"+num$(day(date$))

Local File PIHRMFAIRERR [PHFE2]
Gosub DECLARE_CLASSES_WSERV

Filter [F:PHFE2] Where INTUID = PINTUID and ID = V_TEAMMEMBERID and LEG = PLEG and SRVTYP = PPROCESSID
If rowcount([PHFE2])>0
  #Start building the Json string
  Gosub START_JSON
  TABLEROWCOUNT = rowcount([PHFE2])
Else
  Filter [F:PHFE2]
  End
Endif

For [PHFE2]PHFE0
  I+=1
  #Build the Json string
  Gosub BUILD_JSON_DETAIL
  If TABLEROWCOUNT=I
    #Close JSON file and send
    Gosub CLOSE_SEND_JSON
    If FUNCRET = [V]CST_AERROR : Break : Endif
  Endif
Next

Filter [F:PHFE2]
End FUNCRET

$START_JSON

Append JSON_DATA, '{'
Append JSON_DATA, ' "errors": {'
Append JSON_DATA, '   "validationDate": "'+JSONDATE+'",'
Append JSON_DATA, '     "validationErrors": ['

Return

$BUILD_JSON_DETAIL
Append JSON_DATA, '    {'
Append JSON_DATA, '        "severityLevel": "'+[F:PHFE2]LVL+'",'
Append JSON_DATA, '           "errorType": "'+[F:PHFE2]TYP+'",'
Append JSON_DATA, '             "elementName": "'+[F:PHFE2]NAM+'",'
Append JSON_DATA, '               "arrayIndex":'+num$([F:PHFE2]IND)+','
Append JSON_DATA, '                 "fieldName": "'+func GET_MAPPED_CODE([F:PHFE2]CLA)+"_"+[F:PHFE2]FLDNAM+'",'
Append JSON_DATA, '                   "Id": "'+[F:PHFE2]ID+'",'
Append JSON_DATA, '                     "errorMessage": "'+[F:PHFE2]MSG+'"'

If TABLEROWCOUNT=I
  Append JSON_DATA, '    }'
Else
  Append JSON_DATA, '    },'
Endif
Return

$CLOSE_SEND_JSON
  Append JSON_DATA, '    ]'
  Append JSON_DATA, '  }'
  Append JSON_DATA, '}'

#TODO: Create local menu and build call to sub through evalue
#The error table is generic for now so all should be processed here
Case INT_PROCESS
  When 1 : Gosub SET_EMPLOYEE_ERROR From EMPLOIDSTG_CSTD_MPU
Endcase

#JSON_DATA = escJson(JSON_DATA)

HTTP_STATUS=func ASYRRESTCLI.EXEC_REST_WS(WEBSERNAME, HTTPMETHOD, SUBURL, PCOD,PVAL,HCOD,HVAL, JSON_DATA, FUTURE, "", RESHEAD_FUNC, RESBODY_FUNC)

#Assigning HTTP_STATUS to HTTP_RET to keep all return variables the same
HTTP_RET = HTTP_STATUS

If (int(HTTP_RET/100)<>2)
  #We know this is an error so we can set RETVAL to the function
  #Set the return message and RETVAL
  FUNCRET = func PIHRMFAIR_FUNCTIONS.HANDLE_HTTP_ERROR(RESHEAD_FUNC,RESBODY_FUNC,MSG_RET,HTTP_RET)
Endif

Return


$GET_REQUEST_TIMER
Local Integer SECDIFF
Local Integer ORIGINTIME, ELAPSETIME, TIMEDIFF, SETTIMVAL
SETTIMVAL = VTIMER
ORIGINTIME = time
ELAPSETIME = time
TIMEDIFF = ELAPSETIME-ORIGINTIME
Return





Funprog HANDLE_HTTP_ERROR(VRESHEAD_FUNC,VRESBODY_FUNC,W_MESS,V_HTTP_FUNC)
Value Clbfile VRESHEAD_FUNC,VRESBODY_FUNC
Variable Char W_MESS
Value Integer V_HTTP_FUNC
Local Integer MAXTEXT : MAXTEXT = 250
Local Integer RETVAL : RETVAL = [V]CST_AERROR

#Test the HTTP Status
If (V_HTTP_FUNC = 0)
  # Error from Syracuse server
  W_MESS = mid$(VRESHEAD_FUNC,1,MAXTEXT)
Elsif (int(V_HTTP_FUNC/100)=2)
  #Success
  RETVAL = [V]CST_AOK
Else
  # Error from outgoing server
  W_MESS = mid$(VRESBODY_FUNC,1,MAXTEXT)
Endif
End RETVAL

$INIT_NODE
Local Integer NODEINIT
Local Instance  NODES(1..)    Using C_ASYRJSO
Local Instance  NODE          Using C_ASYRJSO

#NODES(1..) = NewInstance C_ASYRJSO AllocGroup null
#NODEINIT    = fmet NODES(1..).AINIT()
Return

$FREE_NODE
#FreeGroup NODES(1..)
Return

Funprog HANDLE_EMPLOYEE_ERRORS_CLASS(I_MAINCLASS,ELEMENTNAME,ARRINDEX,ERRTYP,ERRLVL,PUNIQID,PLEG,PPROCESSID,EMPID,VREFNUM,VACTIVE_CLASS)
#Variable Instance I_MAINCLASS Using C_EMPLOIDSTG
Value Char ELEMENTNAME, ERRTYP,ERRLVL,PLEG,EMPID,VREFNUM,VACTIVE_CLASS
Value Integer ARRINDEX, PUNIQID,PPROCESSID
Local Char VFLDNAM(50), VMSG(250)

Local Char RMESSAGE (250)
Local Integer ENDRESULT : ENDRESULT = [V]CST_AOK
Local Integer INDEX,WRITESTATUS,LIN



For [L]LIN = 1 To maxtab(I_MAINCLASS.AERROR)
  If (I_MAINCLASS.AERROR([L]LIN) <> null and I_MAINCLASS.AERROR([L]LIN).DEL <> [V]CST_AYES) Then
    If (I_MAINCLASS.AERROR([L]LIN).STA >= [V]CST_AWARNING) Then
      RMESSAGE  = I_MAINCLASS.AERROR([L]LIN).MES
      VMSG      = I_MAINCLASS.AERROR([L]LIN).MES
      VFLDNAM   = I_MAINCLASS.AERROR([L]LIN).PRO
      If (I_MAINCLASS.AERROR([L]LIN).PRO = AVOID.ACHAR) : VFLDNAM = "CRUD" : Endif
        Gosub ADD_ERRLINE
      #Endif
    Endif
  Endif
Next
End ENDRESULT


Funprog HANDLE_EMPLOYEE_ERRORS_CLASS_TEST(I_MAINCLASS,ELEMENTNAME,ARRINDEX,ERRTYP,ERRLVL,PUNIQID,PLEG,PPROCESSID,EMPID)
#Variable Instance I_MAINCLASS Using C_EMPLOIDSTG
Value Char ELEMENTNAME, ERRTYP,ERRLVL,PLEG,EMPID
Value Integer ARRINDEX, PUNIQID,PPROCESSID
Local Char VFLDNAM(50), VMSG(250)

Local Char RMESSAGE (250)
Local Integer ENDRESULT : ENDRESULT = [V]CST_AOK
Local Integer INDEX,WRITESTATUS,LIN

For [L]LIN = 1 To maxtab(I_MAINCLASS.AERROR)
  If (I_MAINCLASS.AERROR([L]LIN) <> null and I_MAINCLASS.AERROR([L]LIN).DEL <> [V]CST_AYES) Then
    If (I_MAINCLASS.AERROR([L]LIN).STA > [V]CST_AWARNING) Then
      RMESSAGE  = I_MAINCLASS.AERROR([L]LIN).MES
      VMSG      = I_MAINCLASS.AERROR([L]LIN).MES
      VFLDNAM   = I_MAINCLASS.AERROR([L]LIN).PRO

      If (I_MAINCLASS.AERROR([L]LIN).PRO = AVOID.ACHAR) : I_MAINCLASS.AERROR([L]LIN).PRO = "CRUD" : Endif
        Gosub ADD_ERRLINE
      #Endif
    Endif
  Endif
Next
End ENDRESULT

Funprog HANDLE_PROPERTY_ERROR(VFLDNAM,VMSG,ELEMENTNAME,ARRINDEX,ERRTYP,ERRLVL,PUNIQID,PLEG,PPROCESSID,EMPID,VREFNUM,VACTIVE_CLASS)
Value Char ELEMENTNAME, ERRTYP,ERRLVL,PLEG,EMPID,VREFNUM,VACTIVE_CLASS
Value Integer ARRINDEX, PUNIQID,PPROCESSID
Value Char VFLDNAM, VMSG
