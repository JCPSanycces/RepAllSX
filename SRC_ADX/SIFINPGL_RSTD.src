# Class SIFINPGL
##########################################################
$METHODS
Case [L]CURPTH
   When ""
      Case [L]ACTION
        When "AQUERY_TRANS_AFTER" : Gosub AQUERY_TRANS_AFTER
      Endcase
Endcase
Return
##########################################################
$PROPERTIES
Case [L]CURPRO
Endcase
Return
##########################################################
$AQUERY_TRANS_AFTER

  # Convert the Budget tracking type
  If [F:CRY]BUDTRK= 2
    this.CRY.BTR = "Yes"
  Else
    this.CRY.BTR = "No"
  Endif

Return
