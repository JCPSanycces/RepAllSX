#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################################################################
#
# GESTION DES BIENS - SUPPRESSION : EXECUTION DU TRAITEMENT
# =========================================================
#
# @ver        1.0.0
# @date       xx/xx/xxxx
# @user       GBO
# @modif      xx/xx/xxxx
#
# Liste des sous-programmes :
# -------------------------
#
#
#
# Liste des fonctions :
# -------------------
#
#
# Liste des routines :
# ------------------
#
# $ACTION
#
########################################################################################################################
# Modifications :
# -------------
#
# - USR - xx.xx.xxxx - Fq yyyyy - Commentaire
# - MWA   20.02.2013 -  67615_8 - Ventilation analytiques biens POOL & LVA
# - GBO - 07.10.2010 - Fq 65071 - Génération d'un événement d'annulation même s'il n'y pas de dotation +
#                                 Alimentation des nouveaux champs TYPANN et ACCCODORI
# - MDJ - 09.08.2010 - Fq 64312 - Détachement du contrat de location lors de la suppression du bien
# - GBO - 23.06.2010 - Fq 65376 - Erreur en suppression de bien avec écart entre plans
# - GBO - 07.05.2010 - Fq 64544 - Gestion des écarts entre plans d'amortissement
# - GBO - 04.03.2010 - Fq 63049 - Gestion des dépenses en suppression de bien
#
########################################################################################################################
 If !clalev([F:FAS])  : Local File FXDASSETS [FAS]  : Endif
 If !clalev([M:FAS0]) : Local Mask FAS0      [FAS0] : Endif

 Local Char PARAM(30)(1..2)
 Local Char VALEUR
 PARAM(1)="142001393"
 PARAM(2)="142"
 Read [F:FAS]FAS0=PARAM(1)
 [M:FAS0]=[F:FAS]
 Trbegin [F:FAS]
 Gosub AP_VERF_ANU_FASCNL
 Gosub AV_ANNULE_FASCNL
 Gosub AP_ANNULE_FASCNL
 Rollback

 End


#---------------------------------------
# Appel de la fenêtre de gestion
# comptable de la suppression d'un
# bien comptable
#---------------------------------------
$OUVRE_TABLES
  If !clalev([M:FC0])  : Local Mask FASCNL0 [M:FC0] : Endif
  If !clalev([M:FC1])  : Local Mask FASCNL1 [M:FC1] : Endif
  If G_ACTCCN=G_OUI
   If !clalev([M:FC2])  : Local Mask FASCNL2 [M:FC2] : Endif
  Endif
  If !clalev([M:FC3])  : Local Mask FASCNL3 [M:FC3] : Endif #Fq63049-GBO
  If G_ACTLNK=G_OUI
   If !clalev([M:FC4])  : Local Mask FASCNL4 [M:FC4] : Endif #Fq64544-GBO
  Endif
Return

#---------------------------------------
# Appel de la fenêtre de gestion
# comptable de la suppression d'un
# bien comptable
#---------------------------------------
$AP_VERF_ANU_FASCNL
  #> Ouverture de la fenêtre de gestion de la suppression de bien
  Local Char LIGNE(115)
  Local Char PARAM(30)(1..2)
  Local Char VALEUR

  If !clalev([M:FC0])  : Local Mask FASCNL0 [M:FC0] : Endif
  If !clalev([M:FC1])  : Local Mask FASCNL1 [M:FC1] : Endif
  If G_ACTCCN=G_OUI
   If !clalev([M:FC2]) : Local Mask FASCNL2 [M:FC2] : Endif
  Endif
  If !clalev([M:FC3])  : Local Mask FASCNL3 [M:FC3] : Endif
  #@fq64544
  If G_ACTLNK=G_OUI
   If !clalev([M:FC4]) : Local Mask FASCNL4 [M:FC4] : Endif
  Endif

  PARAM(1)=[M:FAS0]AASREF
  PARAM(2)=[M:FAS0]CPY
  Call TRAITE_CHAR(VALEUR,PARAM,"","TRTFASCNL","FASCNL",4,"") From GTRAITE

Return

#---------------------------------------
# Exploitation de la fenêtre de gestion
# comptable de la suppression d'un
# bien comptable :
#   - Génération des événements FASCNL
#   - Génération des événements FASLNKCNL
#   - Génération des événements FASRPRCNL
#   - Suppression / Extourne des autres
#     événements générés pour le bien
#---------------------------------------
$AV_ANNULE_FASCNL

  If GOK=0 : Return : Endif
  If [M:FC0]FLGTRC=G_OUI & GTRACE=""
   Call OUVRE_TRACE(mess(699,GML_MSGFAS,1)-[M:FC0]AASREF) From LECFIC # "Suppression du bien comptable"
   Global Integer LTRCCNL
  Endif

  If [M:FC0]FLGTRC=G_OUI : Gosub TRACE_CNL_ET From SUBFASCNLTRA : Endif

  #> Exploitation de la fenêtre de gestion de la suppression de bien

  If !clalev([F:SFAS])  : Local File FXDASSETS [SFAS] : Endif

  Global Integer GCPTEXEANT
  Global Shortint GTYPANN     #fq65071
  Global Char     GACCCODORI  #fq65071

  Local  Integer I_EVT, I_AXE
  Local  Char    CHAMP
  Local  Char    EVTINT
  Local  Date    DATE_EFFET
  Local  Date    DATE_COMPTA
  Local  Integer CODERR
  Local  Integer SPLAN, SFIY

  [F:SFAS]=[F:FAS]

  #> Création des événements d'annulation de dotation
  If !clalev([F:DEPE])  : Local File DEPREC    [DEPE] : Endif
  If  clalev([F:EVT0])  : Close Local File     [EVT0] : Endif
  Local File EFASCNL [EVT0]
  Gosub CRE_EVT_FASCNL

  #@fq64544
  #> Création des événements d'annulation d'écarts entre plans (code activité LNK à oui seulement)
  If G_ACTLNK=G_OUI
   If !clalev([F:DEPE]) : Local File DEPREC    [DEPE]  : Endif
   If  clalev([F:EVT0]) : Close Local File     [EVT0]  : Endif
   Local File EFASLNKCNL [EVT0]
   Gosub CRE_EVT_FASLNKCNL
   If [M:FC0]FLGTRC=G_OUI
    LIGNE = string$(100,"-") : Call ECR_TRACE(LIGNE,0) From GESECRAN
   Endif
  Endif

  #> Création des événements d'annulation de provisions pour renouvellement (code activité CCN à oui seulement)
  If G_ACTCCN=G_OUI
   If !clalev([F:RPRE]) : Local File CCNRPR    [RPRE]  : Endif
   If  clalev([F:EVT0]) : Close Local File     [EVT0]  : Endif
   Local File EFASCCNCNL [EVT0]
   Gosub CRE_EVT_FASRPRCNL
   If [M:FC0]FLGTRC=G_OUI
    LIGNE = string$(100,"-") : Call ECR_TRACE(LIGNE,0) From GESECRAN
   Endif
  Endif

  #> Bien renouvelant : annulation du renouvellement sur les biens pères (code activité CCN à oui seulement)
  Gosub CAN_RNW

  #> Dépenses liées : traitements des dépenses
  Gosub TRT_LOF


  #> CONTRAT DE LOCATION-FINANCEMENT LIÉ : TRAITEMENTS DU CONTRAT
  #- FQ-64312  --------------------------
  If ( G_ACTLEA = G_OUI )
    If [M:FC0]LEAREF <> "" : Gosub TRT_LEA : Endif
  Endif

  [F:FAS]=[F:SFAS]
  Kill GCPTEXEANT
  Kill GTYPANN    #fq65071
  Kill GACCCODORI #fq65071

  If CODERR
   #Call LEC_TRACE From LECFIC
   GOK=0
  Endif

  #> Ajout de la comptabilisation immédiate #RAF


Return

#---------------------------------------
# Affichage du compte-rendu de
# suppression du bien et
# suppression des variables globales
#---------------------------------------
$AP_ANNULE_FASCNL
  If dim(FASCNLEND)>0
   Kill FASCNLEND
   Return
  Endif
  If dim(LTRCCNL)>0
   Kill LTRCCNL
   Call LEC_TRACE From LECFIC
  Endif
Return

#---------------------------------------
# Création des événements d'annulation
# comptable FASCNL
#---------------------------------------
$CRE_EVT_FASCNL
  If ![M:FC1]NBEVTI : Return : Endif
  Gosub TRACE_CNL_ET_DOT From SUBFASCNLTRA
  For I_EVT=1 To [M:FC1]NBEVTI
   If [M:FC0]FLGTRC=G_OUI : Gosub TRACE_CNL_PLN From SUBFASCNLTRA : Endif
   #> Préparation des infos nécessaires à la génération de l'événement
   EVTINT             = "FASCNL"+num$([M:FC1]IDPRPLN(I_EVT-1))
   DATE_EFFET         = [M:FC1]IEVTDAT(I_EVT-1)
   DATE_COMPTA        = [M:FC1]ICPTDATINT(I_EVT-1)
   [F:FAS]DSP         = [M:FC1]IDSP(I_EVT-1)
   For I_AXE = 1 To 9
    CHAMP = "[F:FAS]DIE("+num$(I_AXE-1)+")"
    Assign CHAMP With evalue("[M:FC1]IDIE"+num$(I_AXE)+"(I_EVT-1)")
    CHAMP = "[F:FAS]CCE("+num$(I_AXE-1)+")"
    Assign CHAMP With evalue("[M:FC1]ICCE"+num$(I_AXE)+"(I_EVT-1)")
   Next I_AXE
   If [M:FC1]IFIYSTA(I_EVT-1)=GVML_TECOURA & dim(FIRSTEVT)<0
    GCPTEXEANT         = [M:FC1]FLGEXTANT
    Local Integer FIRSTEVT
   Endif
   Raz [F:DEPE]
   If GCPTEXEANT=G_OUI
    [F:DEPE]DPRCUM    = [M:FC1]IDPRCUM(I_EVT-1)
    [F:DEPE]EXCCUM    = [M:FC1]IEXCCUM(I_EVT-1)
    [F:DEPE]LEGCUM    = [M:FC1]ILEGCUM(I_EVT-1)
    [F:DEPE]LEGRVECUM = [M:FC1]ILEGRVECUM(I_EVT-1)
    [F:DEPE]EXEIMLCUM = [M:FC1]IEXEIMLCUM(I_EVT-1)
    [F:DEPE]EXERVECUM = [M:FC1]IEXERVECUM(I_EVT-1)
    [F:DEPE]EXETRFCUM = [M:FC1]IEXETRFCUM(I_EVT-1)
   Endif
   [F:DEPE]PSTDPE     = [M:FC1]IPSTDPE(I_EVT-1)
   [F:DEPE]PSTEXC     = [M:FC1]IPSTEXC(I_EVT-1)
   [F:DEPE]PSTDER     = [M:FC1]IPSTDER(I_EVT-1)
   [F:DEPE]PSTDERRVE  = [M:FC1]IPSTDERRVE(I_EVT-1)
   [F:DEPE]PSTRVETRF  = [M:FC1]IPSTRVETRF(I_EVT-1)
   If G_ACTCCN=G_OUI
    [F:DEPE]PSTCADCRB = [M:FC1]IPSTCADCRB(I_EVT-1)
   Endif
   [F:DEPE]DPRBAS     = [M:FC1]IDPRBAS(I_EVT-1)
   GTYPANN    = [M:FC1]TYPANNI([M:FC1]IDPRPLN(I_EVT-1)-1) #fq65071
   GACCCODORI = [M:FC1]ACCCODORI                          #fq65071
   # Alimentation de champs SPE dans l'événement d'annulation
   GPOINT = "FASCNLEVTFLD" : Gosub ENTREE From EXEFNC     #CHECK IGNORE_LINE
   Call GENER_EVE(GVML_OMBIEN,[F:FAS]CPY,[F:FAS]FCY,[F:FAS]AASREF,0,EVTINT,DATE_EFFET,DATE_COMPTA,CODERR) From GENEVE
   If [M:FC0]FLGTRC=G_OUI : Gosub TRACE_CNL_DOT_EVT From SUBFASCNLTRA : Endif
  Next I_EVT
  If [M:FC0]FLGTRC=G_OUI
   If![M:FC1]NBEVTI
    Gosub TRACE_CNL_ET_EVT From SUBFASCNLTRA : Gosub TRACE_CNL_NO_EVT From SUBFASCNLTRA
   Endif
  Endif
Return

#---------------------------------------
# Création des événements d'annulation
# comptable des Ecarts entre plans
#---------------------------------------
#@fq54644
$CRE_EVT_FASLNKCNL
If 1=1
  If ![M:FC4]NBLNKEVTI : Return : Endif
  Gosub TRACE_LNK_ET_DOT From SUBFASCNLTRA
  For I_EVT=1 To [M:FC4]NBLNKEVTI
   If [M:FC0]FLGTRC=G_OUI : Gosub TRACE_LNK_PLN From SUBFASCNLTRA : Endif
   #> Préparation des infos nécessaires à la génération de l'événement
   EVTINT             = "LNKCNL"+num$([M:FC4]IDPRPLN(I_EVT-1)) #fq65376
   DATE_EFFET         = [M:FC4]IEVTDAT(I_EVT-1)
   DATE_COMPTA        = [M:FC4]ICPTDATINT(I_EVT-1)
   [F:FAS]DSP         = [M:FC4]IDSP(I_EVT-1)
   For I_AXE = 1 To 9
    CHAMP = "[F:FAS]DIE("+num$(I_AXE-1)+")"
    Assign CHAMP With evalue("[M:FC4]IDIE"+num$(I_AXE)+"(I_EVT-1)")
    CHAMP = "[F:FAS]CCE("+num$(I_AXE-1)+")"
    Assign CHAMP With evalue("[M:FC4]ICCE"+num$(I_AXE)+"(I_EVT-1)")
   Next I_AXE
   If [M:FC4]IFIYSTA(I_EVT-1)=GVML_TECOURA & dim(FIRSTEVT)<0
    GCPTEXEANT         = [M:FC4]FLGEXTANT
    Local Integer FIRSTEVT
   Endif
   Raz [F:DEPE]
   If GCPTEXEANT=G_OUI
    [F:DEPE]LNKCUM    = [M:FC4]ILNKCUM(I_EVT-1) #fq65376
   Endif
   [F:DEPE]PSTLNK     = [M:FC4]IPSTLNK(I_EVT-1) #fq65376
   Call GENER_EVE(GVML_OMBIEN,[F:FAS]CPY,[F:FAS]FCY,[F:FAS]AASREF,0,EVTINT,DATE_EFFET,DATE_COMPTA,CODERR) From GENEVE
   If [M:FC0]FLGTRC=G_OUI : Gosub TRACE_CNL_LNK_EVT From SUBFASCNLTRA : Endif
  Next I_EVT
  If [M:FC0]FLGTRC=G_OUI
   If![M:FC4]NBLNKEVTI
    Gosub TRACE_CNL_ET_EVT From SUBFASCNLTRA : Gosub TRACE_CNL_NO_EVT From SUBFASCNLTRA
   Endif
  Endif

Endif
Return

#---------------------------------------
# Création des événements d'annulation
# comptable des provisions pour
# renouvellement FASRPRCNL
#---------------------------------------
$CRE_EVT_FASRPRCNL
 If G_ACTCCN<>G_OUI : Return : Endif
 If G_CCNRPR<>G_OUI : Return : Endif
 If ![M:FC2]NBEVR : Return : Endif
 Gosub TRACE_CNL_ET_RPR From SUBFASCNLTRA
 For I_EVT=1 To [M:FC2]NBEVR
  #> Préparation des infos nécessaires à la génération de l'événement
  EVTINT             = "FASCCNCNL"
  DATE_EFFET         = [M:FC2]EVTDAT(I_EVT-1)
  DATE_COMPTA        = [M:FC2]CPTDATINT(I_EVT-1)
  [F:FAS]DSP         = [M:FC2]EDSP(I_EVT-1)
  For I_AXE = 1 To 9
   CHAMP = "[F:FAS]DIE("+num$(I_AXE-1)+")"
   Assign CHAMP With evalue("[M:FC2]EDIE"+num$(I_AXE)+"(I_EVT-1)")
   CHAMP = "[F:FAS]CCE("+num$(I_AXE-1)+")"
   Assign CHAMP With evalue("[M:FC2]ECCE"+num$(I_AXE)+"(I_EVT-1)")
  Next I_AXE
  If [M:FC2]EFIYSTA(I_EVT-1)=GVML_TECOURA & dim(FIRSTEVT)<0
   GCPTEXEANT         = [M:FC2]FLGEXTANTR
   Local Integer FIRSTEVT
  Endif
  Raz [F:RPRE]
  If GCPTEXEANT=G_OUI
   [F:RPRE]E_1ACGRPR  = [M:FC2]EE_1ACGRPR(I_EVT-1)
   [F:RPRE]E_1FISRPR  = [M:FC2]EE_1FISRPR(I_EVT-1)
   [F:RPRE]E_1RVERPR  = [M:FC2]EE_1RVERPR(I_EVT-1)
   [F:RPRE]E_1SUPCAD  = [M:FC2]EE_1SUPCAD(I_EVT-1)
  Endif
  [F:RPRE]PSTACGRPR  = [M:FC2]EPSTACGRPR(I_EVT-1)
  [F:RPRE]PSTFISRPR  = [M:FC2]EPSTFISRPR(I_EVT-1)
  Call GENER_EVE(GVML_OMBIEN,[F:FAS]CPY,[F:FAS]FCY,[F:FAS]AASREF,0,EVTINT,DATE_EFFET,DATE_COMPTA,CODERR) From GENEVE
  If [M:FC0]FLGTRC=G_OUI : Gosub TRACE_CNL_RPR_EVT From SUBFASCNLTRA : Endif
 Next I_EVT
 If [M:FC0]FLGTRC=G_OUI & ![M:FC2]NBEVR : Gosub TRACE_CNL_NO_EVT From SUBFASCNLTRA : Endif
Return

#---------------------------------------
# Si le bien est un bien en concession
# dont le flag RNWDONFLG est à oui
# on recherche les biens père pour
# annuler la sortie. Permet de les
# libérer pour un nouveau renouvellement
#---------------------------------------
$CAN_RNW
 If G_ACTCCN<>G_OUI          : Return : Endif    # Gestion des concessions inactives
 If G_CCNRPR<>G_OUI          : Return : Endif    # Gestion des concession non gérées par renouvellement
 If [M:FC2]RNWCANFLG<>G_OUI  : Return : Endif    # Pas d'annulation de renouvellement.

 If [F:FAS]OWNTYP=GVML_TDCONCE & [F:FAS]CCNETRNAT=GVML_NECONCS & [F:FAS]CCNETRTYP=GVML_NARENEW & [F:FAS]RNWDONFLG=G_OUI & [M:FC2]RNWCANFLG=G_OUI

  Gosub TRACE_CNL_ET_RNWCAN From SUBFASCNLTRA

  #> Annulation du renouvellement pour les biens pères
  #  -------------------------------------------------

  If !clalev([F:FASF]) : Local File FXDASSETS [FASF] : Endif
  LREQ='RNWAASREF="'+[F:FAS]AASREF+'"&CCNREF="'+[F:FAS]CCNREF+'"'
  Filter [F:FASF] Where evalue(LREQ)
  Local Char LMESSERR(255)
  If rowcount([F:FASF])>0

   Gosub TRACE_CNL_ET_ISSCAN From SUBFASCNLTRA

   #> Lock des biens pères

   For [FASF]
    If  ( func GLOBIENS.LOCK_SYMBOLE ("FAS", [F:FASF]CPY, [F:FASF]AASREF, 0) = 0 ) Then
     RERR = 1 : GOK=0
     LMESSERR="[F:FAS]"-[F:FASF]AASREF-mess(226,GML_MSGFAS,1)
     GOK=0
     Call ECR_TRACE(LMESSERR,1) From GESECRAN
     Break
    Endif
   Next

   #> Annulation de la sortie pour renouvellement des biens père

   If GOK
    Local Integer RETOUR
    GTRANS = 1 : # Pour signaler que c'est ce traitement qui gère le commitment et non pas la transaction objet métier
    GOK    = 1
    Call LAUNCH_SILTRT("FASISS","SUBFASCNL",RETOUR) From TRCPROCOM
    If (RETOUR) Then
      NB_ERR +=1
      GOK=0
      LMESSERR="SUBFASCNL/$CAN_RNW-s/p[LAUNCH_SILTRT] RETOUR"-num$(RETOUR)
      Call ECR_TRACE(LMESSERR,1) From GESECRAN
    Endif
   Endif

   #> Raz des infos relatives au biens fils sur les biens pères (voir si ce n'est pas déjà fait par la sortie)

  If GOK
   Update [F:FASF] Where evalue(LREQ) With RNWAASREF=""
   If fstat
    LMESSERR="SUBFASCNL/$CAN_RNW-Update [F:FASF] fstat="-num$(fstat) #@err
    Call ECR_TRACE(LMESSERR,1) From GESECRAN
    GOK=0
   Endif
  Endif

   #> Emission de la liste des biens renouvelés dans la trace si pas d'erreur

   If GOK
    Local Integer I_MOTH
    For I_MOTH=1 To [M:FC2]NBMOTH
     Gosub TRACE_CNL_ISSCAN From SUBFASCNLTRA
    Next
  Endif

  Gosub TRACE_CNL_PIED_ISSCAN From SUBFASCNLTRA

  Endif
  Filter [F:FASF]

  #> Génération de l'événement d'annulation de renouvellement pour le bien fils
  #  --------------------------------------------------------------------------
  If GOK
   If !clalev([F:E31]) : Local File EFASRNW    [E31] : Endif
   If !clalev([F:EVT]) : Local File EFASRNWCNL [EVT] : Endif
   Local Integer CODERR
   Read [F:E31]EVE0=[M:FC2]EVTREF;[M:FC2]EVTTIMSTP
   If !fstat
    [F:EVT]=[F:E31]
    [F:EVT]EVTINT="FASRNWCNL"
    [F:EVT]CREUSR=GUSER
    [F:EVT]CREDAT=date$
    [F:EVT]CRETIM=time
    [F:EVT]CPTFLG=G_NON
    [F:EVT]TIMSTP=func GENEVE.BUILD_TIMSTP(date$, time)
    Write [F:EVT]
    Gosub TRACE_CNL_ET_EVT From SUBFASCNLTRA
    CODERR=fstat
   If fstat
     LMESSERR="SUBFASCNL/$CAN_RNW-Write [F:EVT] fstat="-num$(fstat) #@err
    Call ECR_TRACE(LMESSERR,1) From GESECRAN
    GOK=0
   Endif
    Gosub TRACE_CNL_RNW_EVT From SUBFASCNLTRA
  Endif

  Endif

  #> Suppression de l'opération de renouvellement validée
  #  ----------------------------------------------------

  If GOK
   If !clalev([F:RWP]) : Local File RNWPREP [RWP] : Endif
   Delete [F:RWP] Where RNWAASREF=[F:FAS]AASREF
   If fstat
    LMESSERR="SUBFASCNL/$CAN_RNW-Delete [F:RWP] fstat="-num$(fstat) #@err
    Call ECR_TRACE(LMESSERR,1) From GESECRAN
    GOK=0
   Endif
  Endif

 Endif

Return

#======================================================
# ANNULATION DE RENOUVELLEMENT
#======================================================
$ALIM_MASK
  # Flag de simulation
  FLGSIM          =  G_NON
  [M:MHC]FLGSIM   =  G_NON
  # Alimentation de l'en-tête
  [M:MHC]FLGCPY(find([F:FAS]CPY,[M:MHC]CPY)-1)  = G_OUI
  [M:MHC]FLGFCY(find([F:FAS]FCY,[M:MHC]FCY)-1)  = G_OUI
  # Alimentation des paramètres de l'action étendue
  Effzo [M:ASL]
  Effzo [M:FASS]
  [M:ASL]EXP1          = '[F:MAS1]RNWAASREF="'+[F:FAS]AASREF+'"& [F:MAS1]CCNREF="'+[F:FAS]CCNREF+'"'
  # Alimentation des paramètres de la sortie
  [M:FASS]CCLISSFLG    = G_OUI
  [M:FASS]EXTISSFLG    = G_NON
Return
#======================================================
# GESTION DES DEPENSES LIEES
#======================================================
$TRT_LOF
 If dim([M:FC3]NBDEST)<0 : Return : Endif
 If [M:FC3]NBDEST=0      : Return : Endif

 Gosub TRACE_CNL_ET_LOF From SUBFASCNLTRA

 Local Integer I_LOF
 Local Char    L_ACTION
 Local Char    LCODLOF
 Local Integer LLINLOF

 For I_LOF=1 To [M:FC3]NBDEST
  LCODLOF=[M:FC3]CODLOF(I_LOF-1)
  LLINLOF=[M:FC3]LINLOF(I_LOF-1)
  If [M:FC3]FLGDEL(I_LOF-1)=G_OUI : Gosub DEL_LOF    : Endif
  If [M:FC3]FLGULI(I_LOF-1)=G_OUI : Gosub UNLINK_LOF : Endif
 Next I_LOF

 Gosub TRACE_CNL_PIED_LOF From SUBFASCNLTRA

Return

#======================================================
# GESTION DES DEPENSES LIEES
#======================================================
$DEL_LOF
 If !clalev([F:LOF]) : Local File LAYOUTFAS [LOF] : Endif
 Delete [LOF] Where CPY=[M:FAS0]CPY and CODLOF=LCODLOF and LINLOF=LLINLOF
 If fstat
  GOK=0
  LMESSERR="SUBFASCNL/$DEL_LOF-Delete [F:LOF] fstat="-num$(fstat)-LCODLOF-num$(LLINLOF) #@err
  Call ECR_TRACE(LMESSERR,1) From GESECRAN
 Else
  Gosub TRACE_LOF_DELETE From SUBFASCNLTRA
 Endif

Return

#======================================================
# GESTION DES DEPENSES LIEES
#======================================================
$UNLINK_LOF
 [F:FAS]DSP = [F:SFAS]DSP  : # 67615_8
 Local Integer LSUPBCO : Gosub DDAB_LOF From TRTFASDDE
 Gosub TRACE_LOF_UNLINK From SUBFASCNLTRA
Return
#======================================================
#  #*Fq-64312 DETACHEMENT DU CONTRAT LIE
#======================================================
$TRT_LEA
 Gosub TRACE_CNL_ET_LEA From SUBFASCNLTRA

 Local Integer I_LEA
 Local Char    L_ACTION
 Local Char    LLEAREF

    #- FQ-64312  --------------------------
  If ( G_ACTLEA = G_OUI )
        Update [LEA]
&       Where LEAREF= [M:FC0]LEAREF
&       With  CUMIASBSE -= [M:FAS1]IASETRNOT
        If ( fstat ) Then
          GOK = 0
          Call FSTA("LEA") From GLOCK
        Endif
      Gosub TRACE_LEA_DETA From SUBFASCNLTRA
      Gosub TRACE_CNL_PIED_LEA From SUBFASCNLTRA
   Endif

Return
