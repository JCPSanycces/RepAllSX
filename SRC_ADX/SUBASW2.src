  [M:ASW4]DETPRO(I)=2 :  Affzo [M:ASW4]DETPRO(I)
 Endif
Next I
VALEUR=[M:ASW4]DETPRO(nolign-1)
[M:ASW4]STALIN(nolign-1)=1
If find(2,[M:ASW4]DETPRO)=0 : # detail
 [M:ASW1]ENAFAC(0)=1 : Affzo [M:ASW1]ENAFAC(0)
Else
 [M:ASW1]ENAFAC(0)=2 : Affzo [M:ASW1]ENAFAC(0)
Endif
End

