Subprog B2_LOKPRO(VALEUR)
Variable Integer VALEUR
Local Integer OK
Local Char L_ERR_MSG(250)
Local Integer I
For I=nolign-1 To [M:ASW4]NBRPRO-1
 If [M:ASW4]LOKPRO(I)<>2
  If [M:ASW4]FLDGRPPRO(I)<>""
   Call CONTROLE_LOKPRO([M:ASW0]CODREP,[M:ASW4]ALIAS(I),[M:ASW4]CODPRO(I),[M:ASW4]FLDGRPPRO(I),[M:ASW1]CODCLA,[M:ASW1]ABRCLA,OK,L_ERR_MSG)
   If OK
    [M:ASW4]LOKPRO(I)=2 :  Affzo [M:ASW4]LOKPRO(I)
   Endif
  Else
   [M:ASW4]LOKPRO(I)=2 :  Affzo [M:ASW4]LOKPRO(I)
  Endif
 Endif
Next I
VALEUR=[M:ASW4]LOKPRO(nolign-1)
[M:ASW4]STALIN(nolign-1)=1
If find(2,[M:ASW4]LOKPRO)=0 : # lookup
 [M:ASW1]ENAFAC(3)=1 : Affzo [M:ASW1]ENAFAC(3)
Else
 [M:ASW1]ENAFAC(3)=2 : Affzo [M:ASW1]ENAFAC(3)
Endif
End

