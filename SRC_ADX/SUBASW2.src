#<AdxTL>@(#)3.0.0.0 $Revision$
Raz GPILCOD ,GNBMASKOUV
GBIDC1 ="ZZVPOATABLE3"
Call OBJET("ASW",GBIDC1,GBIDC2) From GOBJET
End

Gosub ASW1 : # ASW1 : General
Gosub ASW9 : # ASW9 EXTENSION PROPRIETE
Gosub ASW3 : # ASW3 méthodes
Gosub ASW2 : # ASW2 ORGANISATION
Gosub ASW4 : # ASW4 PROPRIETE EXPOSÉ
Gosub ASW7 From SUBASW3 : # ASW7 liens

######################################################################################
######################################################################################
# Controle ecrans ASW 0-->9
######################################################################################

######################################################################################
## ASW1 : General
######################################################################################
$ASW1
Return

Subprog C_CODCLA(VALEUR)
Variable Char    VALEUR()
Read [ACLA]ACLA0 = VALEUR
If !fstat & [F:ACLA]FLGBUFFER=2
 GMESSAGE = VALEUR-":"-mess(274,143,1) : #Classe tampon interdite
 mkstat = 2 : End
Endif
Read [F:ACLAT]ACLAT0=VALEUR;"R"
If fstat or (!fstat and [F:ACLAT]ENAMETSTD<>2)
 GMESSAGE = func AFNC.MES1(mess(92,140,1),VALEUR) : # Méthode "READ" obligatoire
 mkstat = 2 : End
Endif


End

Subprog AM_CODCLA(VALEUR)
Variable Char    VALEUR()
Gosub OUVRE_ATAB From SUBACLA
Read [F:ACLA1]ACLA0 = VALEUR
If !fstat
 [M:ASW1]MODULE = [F:ACLA1]MODULE
 [M:ASW1]CODACT = [F:ACLA1]CODACT
 If [F:ACLA1]TYPCLA=2
  Read [ATB]CODFIC = [F:ACLA1]TABREF
  If !fstat
   Call REPLACE_ABRCLA([F:ATB]ABRFIC)
   [M:ASW1]ABRCLA = [F:ATB]ABRFIC
   If [F:ATB]ISTABLE=2
    [M:ASW1]ISTABLE = 2
   Else
    [M:ASW1]ISTABLE = 1
   Endif
   Affzo [M:ASW1]ABRCLA
   Affzo [M:ASW1]ISTABLE
   Actzo [M:ASW2]CODIND
  Endif
 Else
   [M:ASW1]ISTABLE = 3
  Grizo [M:ASW2]CODIND
 Endif
 Affzo [M:ASW1]MODULE
 Affzo [M:ASW1]CODACT
 Gosub CHARGE_TABREF From SUBASW
Endif
If VALEUR<>[M:ASW1]CODCLA
  #il faut mettre a jour les liens
  [M:ASW1]CODCLA=VALEUR
  Gosub MAJ_STDLNK_FCT_2 From SUBASW
Endif
End


Subprog C_ABRCLA(VALEUR)
Variable Char    VALEUR()
Gosub ABR_RESERVED From SUBASW
If find(VALEUR,ABR_RESERVED)
 GMESSAGE = VALEUR-":"-mess(129,133,1) : # Code réservé
 mkstat = 2 : End
Endif
If find(VALEUR,[M:ASW1]CODCOL)
 GMESSAGE = VALEUR-":"-mess(83,123,1)-":"-mess(54,140,1) : # Valeur incorrecte
 mkstat = 2 : End
Endif
End

Subprog AM_ABRCLA(VALEUR)
Variable Char    VALEUR()
Local Integer I
If VALEUR<>[M:ASW1]ABRCLA
 #il faut modifier propriétés,collections
 Call REPLACE_ABRCLA(VALEUR)
 #il faut mettre a jour les liens
 [M:ASW1]ABRCLA=VALEUR
 Gosub MAJ_STDLNK_FCT_2 From SUBASW
Endif
End

Subprog REPLACE_ABRCLA(VALEUR)
Variable Char    VALEUR()

 For I=0 To [M:ASW1]NBRCOL-1
  If [M:ASW1]CODCOL(I)<>""
   If left$([M:ASW1]CODCOL(I),len([M:ASW1]ABRCLA+"."))=[M:ASW1]ABRCLA+"."
    [M:ASW1]CODCOLOLD(I)=[M:ASW1]CODCOL(I)
    [M:ASW1]CODCOL(I) = VALEUR+right$([M:ASW1]CODCOL(I),len([M:ASW1]ABRCLA+"."))
   Endif
  Endif
 Next
 Affzo  [M:ASW1]25
 Call REPLACE_CODCOL([M:ASW1]ABRCLA,VALEUR)
End

