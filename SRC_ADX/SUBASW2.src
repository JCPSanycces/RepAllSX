#&             mess(6,7961,1)-mess(7,7961,1)-mess(8,7961,1)-mess(9,7961,1),
#&             mess(3,7881,1))
#      GERR=1 : mkstat=2 : Break
#    Endif
#   Next J
#   If mkstat : End : Endif
 Endif
End

