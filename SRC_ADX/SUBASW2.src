Subprog AS_NBRTRT
#If func SUBACLA2.TRT_ISRESERVED([M:ASW1]MODULE,[M:ASW1]TYPTRT(nolign-1),[M:ASW1]CODTRT(nolign-1),[M:ASW1]ACTTRT(nolign-1))
#  mkstat = 2 : End
#Endif
End

Subprog C_NBRTRT
Case status
 When 65,83  : # suppressions
  If func SUBACLA2.TRT_ISRESERVED([M:ASW1]MODULE,[M:ASW1]TYPTRT(nolign-1),[M:ASW1]CODTRT(nolign-1),[M:ASW1]ACTTRT(nolign-1))
    GMESSAGE=mess(244,143,1)
    mkstat = 2 : End
  Endif
Endcase
End

Subprog IB_NBRTRT
If [M:ASW1]CODTRT(nolign-1)=""
Raz GBOUT1
Endif
End

Subprog B1_NBRTRT
If [M:ASW1]CODTRT(nolign-1)<>""
 ## Action TRTADC
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "TRTADC"
 PARMSK(1) = ""
 Call S_AFF_CHAR([M:ASW1]CODTRT(nolign-1),PARMSK,"EDITION","SUBADC","") From GACTION
 GACTION = SAVACT
Endif
End

Subprog AS_CODTRT(VALEUR)
Variable Char    VALEUR()
If func SUBACLA2.TRT_ISRESERVED([M:ASW1]MODULE,[M:ASW1]TYPTRT(nolign-1),[M:ASW1]CODTRT(nolign-1),[M:ASW1]ACTTRT(nolign-1))
  mkstat = 2 : End
Endif
If VALEUR=""
 VALEUR = [M:ASW0]CODREP+string$([M:ASW1]NBRTRT>0,num$([M:ASW1]NBRTRT))
 Case [M:ASW1]TYPTRT(nolign-1)
  When 1  : VALEUR += "_RSTD"
  When 2  : VALEUR += "_RVER"
  When 3  : VALEUR += "_RSPE"
 Endcase
Endif
End

Subprog C_CODTRT(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:ASW1]CODTRT(0..[M:ASW1]NBRTRT-1)) From OBJDIV
If mkstat : End : Endif
End

Subprog AM_CODTRT(VALEUR)
Variable Char    VALEUR()
If [M:ASW1]CODTRT(nolign-1)<>VALEUR & left$(VALEUR,1)="A" & GPRODUIT<>-1
 GMESSAGE = mess(129,133,1) : # Code réservé
 mkstat = 2 : End
Endif
Local Integer OK
Call EXISTE_ADX("","",VALEUR,OK) From ORDSYS
If OK>0
 OK=2
 Call AVERTIR(mess(143,123,1),OK) From GESECRAN : # Traitement déjà existant
 If OK<>2 : mkstat=2 : Endif
Endif
End

Subprog AS_TYPTRT(VALEUR)
Variable Integer VALEUR
If func SUBACLA2.TRT_ISRESERVED([M:ASW1]MODULE,[M:ASW1]TYPTRT(nolign-1),[M:ASW1]CODTRT(nolign-1),[M:ASW1]ACTTRT(nolign-1))
  mkstat = 2 : End
Endif
If GADONIX<>2 : GMENLOC(1) = 1 : Endif
End

Subprog C_TYPTRT(VALEUR)
Variable Integer VALEUR
If [M:ASW1]RANTRT(nolign-1)=1000 & VALEUR<>1
 GMESSAGE=func AFNC.MES1(mess(256,143,1),mess(1,7844,1))
 GERR=1
 mkstat=2
 End
Endif
End

Subprog AS_RANTRT(VALEUR)
Variable Decimal VALEUR
If func SUBACLA2.TRT_ISRESERVED([M:ASW1]MODULE,[M:ASW1]TYPTRT(nolign-1),[M:ASW1]CODTRT(nolign-1),[M:ASW1]ACTTRT(nolign-1))
  mkstat = 2 : End
Endif
If VALEUR<>0 : End : Endif
If nolign=1
 If GADONIX=2 & [M:ASW1]TYPTRT(nolign-1)=1 : VALEUR = 1000 : Else : VALEUR = 1100 : Endif
Elsif nolign>=2
 VALEUR = [M:ASW1]RANTRT(nolign-2)+100
 If VALEUR=1000 & [M:ASW1]TYPTRT(nolign-1)<>1 : VALEUR = 1100 : Endif
Endif
End

Subprog C_RANTRT(VALEUR)
Variable Decimal VALEUR
Call UNICITE(VALEUR,[M:ASW1]RANTRT(0..[M:ASW1]NBRTRT-1)) From OBJDIV
If mkstat : End : Endif
If VALEUR=1000 & [M:ASW1]TYPTRT(nolign-1)<>1
 GMESSAGE=func AFNC.MES1(mess(256,143,1),mess(1,7844,1))
 GERR=1
 mkstat=2
 End
Endif
End

Subprog AS_ACTTRT(VALEUR)
Variable Char    VALEUR()
If func SUBACLA2.TRT_ISRESERVED([M:ASW1]MODULE,[M:ASW1]TYPTRT(nolign-1),[M:ASW1]CODTRT(nolign-1),[M:ASW1]ACTTRT(nolign-1))
  mkstat = 2 : End
Endif
End

