######################################################################################
######################################################################################
# Les selections  : a regrouper des qu'on aura le temps
######################################################################################
######################################################################################
$DEFSEL2
Local Integer NBTEX, CHOI,I
Local Char    TEX(GLONDES)(1..500,1..2) , TIT(GLONDES)(0..2) , CRITERE(250)
Return

$DEFSEL3
Local Integer NBTEX, CHOI,I
Local Char    TEX(GLONDES)(1..500,1..3) , TIT(GLONDES)(0..3) , CRITERE(250)
Return

$DEFSEL4
Local Integer NBTEX, CHOI,I
Local Char    TEX(GLONDES)(1..500,1..4) , TIT(GLONDES)(0..4) , CRITERE(250)
NBTEX=0
Raz TEX
Raz TIT
Raz CRITERE
Return
######################################################################################
# selection of group
######################################################################################
Subprog SEL_GRP(VALEUR)
Variable Char VALEUR

Gosub DEFSEL4
Local Char    WABR(80)

For I=0 To [M:ASW1]NBRCOL-1
 If instr(1,[M:ASW1]CODCOL(I),".")<=0
  NBTEX+= 1
  TEX(NBTEX,1) = [M:ASW1]CODCOL(I)
  TEX(NBTEX,2) = num$([M:ASW1]MINCOL(I))
  TEX(NBTEX,3) = num$([M:ASW1]MINCOL(I))
  TEX(NBTEX,4) = [M:ASW1]ALIASCOL(I)
 Endif
Next

CHOI = 0
TIT(0) = mess(22,123,1) # Sélection
TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("ASHW9", "FLDGRP") # Collection
TIT(2) = func AMK_TOOL.GET_FIELD_LABEL("ASHW1", "MINCOL") # Nb mini
TIT(3) = func AMK_TOOL.GET_FIELD_LABEL("ASHW1", "MAXCOL") # Nb max
TIT(4) = func AMK_TOOL.GET_FIELD_LABEL("ASHW1", "ALIASCOL") # Alias

#If NBTEX=1
# VALEUR = TEX(1,1)
#ELS
If NBTEX>0
 Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
 If status<>7 & CHOI<>0
  VALEUR = TEX(CHOI,1)
 Endif
Endif
End


$DEFGRP
Local Integer ITEX
Local Char    TEX(GLONDES)(1..500,1..4)
Return

$CHARGE_GRP
#Gosub DEFSEL4
Gosub DEFGRP

For I=0 To [M:ASW1]NBRCOL-1
  ITEX+= 1
  TEX(ITEX,1) = [M:ASW1]CODCOL(I)
  TEX(ITEX,2) = num$([M:ASW1]MINCOL(I))
  TEX(ITEX,3) = num$([M:ASW1]MINCOL(I))
  TEX(ITEX,4) = ""
Next
Goto SUITE_CHARGE_GRP

$CHARGE_GRP2
#Gosub DEFSEL4
Gosub DEFGRP

$SUITE_CHARGE_GRP
Local Char TAB_COD(250)(1..100)
Local Char TAB_MIN(80)(1..100)
Local Char TAB_MAX(80)(1..100)
Local Char TAB_CLA(GLONACLA)(1..100)
Local Integer TAB_NB

Local Char    WABR(80)
If dim([M:ASW1]ABRCLA)>0
 WABR = [M:ASW1]ABRCLA
Else
 WABR = [F:ASW]ABRCLA
Endif

 Call LOAD_FLDGRP([M:ASW1]CODCLA,WABR,TAB_COD,TAB_MIN,TAB_MAX,TAB_CLA,TAB_NB) From SUBASW_TOOL

 For I=1 To TAB_NB
  ITEX+= 1
  TEX(ITEX,1)  = TAB_COD(I)
  TEX(ITEX,2)  = TAB_MIN(I)
  TEX(ITEX,3)  = TAB_MAX(I)
  TEX(ITEX,4)  = TAB_CLA(I)
 Next

Return




######################################################################################
# selection section in agroup
######################################################################################
Subprog S_SECBLC(VALEUR)
Variable Char    VALEUR()
Gosub DEFSEL3

For I=0 To [M:ASW2]NBRSEC-1
 NBTEX+= 1
 TEX(NBTEX,1) = [M:ASW2]CODSEC(I)
 TEX(NBTEX,2) = num$([M:ASW2]NIVSEC(I))
 TEX(NBTEX,3) = [M:ASW2]AZINTSEC(I)
Next
CHOI = 0
TIT(0) = mess(22,123,1) # Sélection
TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("ASHW2", "CODSEC") : # "Section"
TIT(2) = func AMK_TOOL.GET_FIELD_LABEL("ASHW2", "NIVSEC") : #"Ordre"
TIT(3) = mess(30,109,1) : # INTITULé
If NBTEX=1
 VALEUR = TEX(1,1)
Elsif NBTEX>0
 Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
 If status<>7 & CHOI<>0
  VALEUR = TEX(CHOI,1)
 Endif
Endif
End


######################################################################################
# selection propertie
######################################################################################
Subprog SEL_PRO(VALEUR,WCODPRO,WINT,WINTIT)
Variable Char    VALEUR()
Variable Char    WCODPRO
Variable Integer WINT
Variable Char    WINTIT
Local Integer NBFLD, CHOI,I
Local Char    TEX(GLONDES)(1..500,1..5) , TIT(GLONDES)(0..5) ,CRITERE(250),WFLD(GLONACLA)
Local Integer INTIT(1..500)
Gosub RECH_PRO

If VALEUR = "" or !instr(1,VALEUR,".")
 For I=0 To [M:ASW9]NBRFLD-1
  NBFLD+= 1
  TEX(NBFLD,1) = [M:ASW9]CODFLD(I)
  TEX(NBFLD,2) = [M:ASW9]AZINTFLD(I)
  TEX(NBFLD,3) = [M:ASW0]CODREP
  TEX(NBFLD,4) = ""
  TEX(NBFLD,5) = ""
  INTIT(NBFLD) = [M:ASW9]INTFLD(I)
 Next
 For [F:ACLAF]ACLAF1 Where CODCLA=[M:ASW1]CODCLA
  NBFLD+= 1
  TEX(NBFLD,1) = [F:ACLAF]FLDCLA
  Call TEXTE([F:ACLAF]INTFLD,TEX(NBFLD,2)) From OBJDIV
  TEX(NBFLD,3) = ""
  TEX(NBFLD,4) = [M:ASW1]CODCLA
  TEX(NBFLD,5) = [F:ACLAF]LNKCLA
  INTIT(NBFLD) = [F:ACLAF]INTFLD
 Next
Else
 If NBCLA=0 or NBCLA=1
  CRITERE = "CODCLA=[M:ASW1]CODCLA"
 Elsif NBCLA>1
  WCLA = [M:ASW1]CODCLA
  For I=2 To NBCLA
   Read [ACLAF]ACLAF0=WCLA;TABCLA(I)
   If !fstat
    WCLA = [ACLAF]LNKCLA
   Else
    Dela I,1 TABCLA
    NBCLA -= 1
   Endif
  Next
  CRITERE = "CODCLA='"+WCLA+"'"
 Endif
 For [F:ACLAF]ACLAF1 Where evalue(CRITERE)
  NBFLD+= 1
  TEX(NBFLD,1) = [F:ACLAF]FLDCLA
  Call TEXTE([F:ACLAF]INTFLD,TEX(NBFLD,2)) From OBJDIV
  TEX(NBFLD,3) = ""
  TEX(NBFLD,4) = [F:ACLAF]CODCLA
  TEX(NBFLD,5) = [F:ACLAF]LNKCLA
  INTIT(NBFLD) = [F:ACLAF]INTFLD
 Next
Endif

CHOI = 0
TIT(0) = mess(22,123,1) # Sélection
TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("ASHW9", "CODFLD") : # "Propriété"
TIT(2) = mess(30,109,1) : # INTITULé
TIT(3) = func AMK_TOOL.GET_FIELD_LABEL("ASHW0", "CODREP") : # "Représentation"
TIT(4) = func AMK_TOOL.GET_FIELD_LABEL("ASHW1", "CODCLA") : # "Classe"
TIT(5) = mess(58,140,1) # Pointeur vers
If NBFLD=1
 If TEX(1,4)<>""
  VALEUR = [M:ASW1]ABRCLA
  For I=2 To NBCLA
   VALEUR += "."+TABCLA(I)
  Next
  VALEUR += "."+TEX(1,1)
 Else
  VALEUR = TEX(1,1)
 Endif
Elsif NBFLD>1
 Call SAITEX_COL_MAX(NBFLD,TEX,CHOI,TIT,240,60) From GESECRAN
 If status<>7 & CHOI<>0
  If TEX(CHOI,4)<>""
   Read [ACLAF]ACLAF0 =TEX(CHOI,4);TEX(CHOI,1)
   If !fstat & [ACLAF]CODTYP="" & [ACLAF]LNKCLA<>""
    GBIDC1 = [ACLAF]LNKCLA
    Filter [ACLAF] Where CODCLA=GBIDC1
    Read [ACLAF]ACLAF1 First
    Filter [ACLAF]
    If !fstat
     VALEUR = [M:ASW1]ABRCLA
     If NBCLA=0
      VALEUR += "."+TEX(CHOI,1)+"."+[ACLAF]FLDCLA
     Elsif NBCLA>0
      For I=2 To NBCLA
       VALEUR += "."+TABCLA(I)
      Next
      VALEUR += "."+TEX(CHOI,1)+"."+[ACLAF]FLDCLA
     Endif
     Call SEL_PRO(VALEUR,WCODPRO,WINT,WINTIT)
    Endif
    Filter [ACLAF]
   Else
    WCODPRO = [M:ASW1]ABRCLA
    If NBCLA=0
     Read [ACLAF]ACLAF0 = TEX(NBFLD,4);TEX(CHOI,1)
     If !fstat & [ACLAF]FLDGRP<>""
      WCODPRO += "."+[ACLAF]FLDGRP
     Endif
     WCODPRO += "."+TEX(CHOI,1)
    Else
     For I=2 To NBCLA
      WCODPRO +="."+TABCLA(I)
     Next
     Read [ACLAF]ACLAF0 = TEX(NBFLD,4);TEX(CHOI,1)
     If !fstat & [ACLAF]FLDGRP<>""
      WCODPRO += "."+[ACLAF]FLDGRP
     Endif
     WCODPRO += "."+TEX(CHOI,1)
    Endif
    VALEUR = TEX(CHOI,1)
    WINT   = INTIT(CHOI)
    WINTIT = TEX(CHOI,2)
   Endif
  Else
   I = find(TEX(CHOI,1),[M:ASW9]CODFLD(0..[M:ASW9]NBRFLD-1))
   If I>0 & [M:ASW9]FLDGRP(I-1)<>""
    WCODPRO = [M:ASW9]FLDGRP(I-1)+"."+TEX(CHOI,1)
   Else
    WCODPRO = TEX(CHOI,1)
   Endif
   VALEUR  = TEX(CHOI,1)
   WINT    = INTIT(CHOI)
   WINTIT  = TEX(CHOI,2)
  Endif
 Endif
Endif
End

$RECH_PRO
Local Char TABCLA(GLONACLA)(1..50),WFLD(GLONAVB),CHAINE(250)
Local Integer NBCLA
CHAINE = [L]VALEUR
I=instr(1,CHAINE,".")
While I>0
 NBCLA += 1
 TABCLA(NBCLA) = left$(CHAINE,I-1)
 CHAINE = right$(CHAINE,I+1)
 I=instr(1,CHAINE,".")
Wend
WFLD = CHAINE
Return


######################################################################################
# selection of group in a ALIAS
######################################################################################
Subprog S_BLCPRO(VALEUR)
Variable Char    VALEUR()
Gosub DEFSEL4
For I=0 To [M:ASW2]NBRBLC-1
 NBTEX+= 1
 TEX(NBTEX,1) = [M:ASW2]CODBLC(I)
 TEX(NBTEX,2) = [M:ASW2]SECBLC(I)
 TEX(NBTEX,3) = num$([M:ASW2]NIVBLC(I))
 TEX(NBTEX,4) = [M:ASW2]AZINTBLC(I)
Next
CHOI = 0
TIT(0) = mess(22,123,1) # Sélection
TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("ASHW2", "CODBLC") : #"Bloc"
TIT(2) = func AMK_TOOL.GET_FIELD_LABEL("ASHW2", "CODSEC") : #"Section"
TIT(3) = func AMK_TOOL.GET_FIELD_LABEL("ASHW2", "NIVBLC") : # "Ordre"
TIT(4) = mess(30,109,1) : # INTITULé
If NBTEX=1
 VALEUR = TEX(1,1)
Elsif NBTEX>0
 Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
 If status<>7 & CHOI<>0
  VALEUR = TEX(CHOI,1)
 Endif
Endif
End

######################################################################################
# Selection of alias
######################################################################################
Subprog SEL_ALIAS(VALEUR)
Variable Char    VALEUR()
Gosub DEFSEL3
For I=0 To [M:ASW4]NBRPRO-1
 NBTEX+= 1
 TEX(NBTEX,1) = [M:ASW4]ALIAS(I)
 TEX(NBTEX,2) = [M:ASW4]AZINTPRO(I)
 TEX(NBTEX,3) = [M:ASW4]CODPRO(I)
Next
CHOI = 0
TIT(0) = mess(22,123,1) # Sélection
TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("ASHW4", "ALIAS") : # "Alias"
TIT(2) = mess(30,109,1) : # INTITULé
TIT(3) = func AMK_TOOL.GET_FIELD_LABEL("ASHW4", "CODPRO") : # "Propriété"
If NBTEX=1
 VALEUR = TEX(1,1)
Elsif NBTEX>0
 Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
 If status<>7 & CHOI<>0
  VALEUR = TEX(CHOI,1)
 Endif
Endif
End

######################################################################################
# Selection of propertie
######################################################################################
Subprog SEL_CODPRO(VALEUR)
Variable Char    VALEUR()
Gosub DEFSEL3
For I=0 To [M:ASW4]NBRPRO-1
 NBTEX+= 1
 TEX(NBTEX,1) = [M:ASW4]ALIAS(I)
 TEX(NBTEX,2) = [M:ASW4]AZINTPRO(I)
 TEX(NBTEX,3) = [M:ASW4]CODPRO(I)
Next
CHOI = 0
TIT(0) = mess(22,123,1) # Sélection
TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("ASHW4", "ALIAS") : # "Alias"
TIT(2) = mess(30,109,1) : # INTITULé
TIT(3) = func AMK_TOOL.GET_FIELD_LABEL("ASHW4", "CODPRO") : # "Propriété"
If NBTEX=1
 VALEUR = TEX(1,3)
Elsif NBTEX>0
 Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
 If status<>7 & CHOI<>0
  VALEUR = TEX(CHOI,3)
 Endif
Endif
End

######################################################################################
# Selection of propertie for a group
######################################################################################
Subprog S_PROCOL(VALEUR)
Variable Char    VALEUR()

Gosub DEFSEL3

For I = 0 To [M:ASW9]NBRFLD-1
 NBTEX+= 1
 TEX(NBTEX,1) = [M:ASW9]CODFLD(I)
 TEX(NBTEX,2) = [M:ASW9]AZINTFLD(I)
 TEX(NBTEX,3) = [M:ASW9]CODTYP(I)
Next

CHOI = 0
TIT(0)=mess(8,31,1) # Sélection
TIT(1)=func AMK_TOOL.GET_FIELD_LABEL("ASHW9", "CODFLD") # Champ
TIT(2)=func AMK_TOOL.GET_FIELD_LABEL("ASHW9", "AZINTFLD") # Libellé
TIT(3)=func AMK_TOOL.GET_FIELD_LABEL("ASHW9", "CODTYP") # Type

Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
If status<>7 & CHOI<>0
 VALEUR = TEX(CHOI,1)
Endif
End


