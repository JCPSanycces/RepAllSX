Subprog B2_TYPAFFPRO(VALEUR)
Variable Integer VALEUR
Local Integer I
For I=nolign-1 To [M:ASW4]NBRPRO-1
 If [M:ASW4]TYPAFFPRO(I)<>2
  If [M:ASW4]STAEDIPRO(I)=1 & [M:ASW4]EDIPRO(I)=2
   If [M:ASW4]CODPROATY(I)<>""
    Read [ATY]CODTYP=[M:ASW4]CODPROATY(I)
    If !(!fstat & [F:ATY]FMTPROSYR=6)
     [M:ASW4]TYPAFFPRO(I)=2 :  Affzo [M:ASW4]TYPAFFPRO(I)
    Endif
   Else
    [M:ASW4]TYPAFFPRO(I)=2 :  Affzo [M:ASW4]TYPAFFPRO(I)
   Endif
  Endif
 Endif
Next I
VALEUR=[M:ASW4]TYPAFFPRO(nolign-1)
#[M:ASW4]STALIN(nolign-1)=1
End

