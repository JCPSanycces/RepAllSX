Subprog AVANT_NBRCOL
[M:ASW1]CODCOLOLD(nolign-1)=[M:ASW1]CODCOL(nolign-1)
End

Subprog APRES_NBRCOL
#----- Si touche "Echap" ou autre statut "Abandon" -----#
If status=6 | status=7 | status=27 | status=28 | status=1792
  End
#----- Si suppression ligne -----#
Elsif status=65 | status=68 | status=83
  End
Endif
If [M:ASW1]CODCOL(nolign-1)<>"" & [M:ASW1]CODCOLOLD(nolign-1)<>""
&   & [M:ASW1]CODCOL(nolign-1)<>[M:ASW1]CODCOLOLD(nolign-1)
&   & instr(1,[M:ASW1]CODCOLOLD(nolign-1),".")<=0 : #on ne remplace pas sur les collections de classe
 Call REPLACE_CODCOL([M:ASW1]CODCOLOLD(nolign-1),[M:ASW1]CODCOL(nolign-1))
Endif
End

#-----------------------------------------
Funprog RECH_CODCOL(CHAINE,LCODOLD)
Value Char CHAINE,LCODOLD
If left$(CHAINE,len([L]LCODOLD+"."))=[L]LCODOLD+"."
 End 1
Elsif left$(CHAINE,len("=num$("+[L]LCODOLD+"."))="=num$("+[L]LCODOLD+"."
   End 7
Elsif left$(CHAINE,len("=val("+[L]LCODOLD+"."))="=val("+[L]LCODOLD+"."
   End 6
Endif
End 0

#-----------------------------------------
Subprog REPLACE_CODCOL(LCODOLD,LCOD)
Value Char LCODOLD,LCOD

Local Integer II,JJ,KK

  # on remplace dans les propriétés
  For II=0 To [M:ASW9]NBRFLD-1
   KK=func RECH_CODCOL([M:ASW9]FLDGRP(II),[L]LCODOLD)
   If KK<>0
    JJ=KK+len([L]LCODOLD)
    [M:ASW9]FLDGRP(II) = left$([M:ASW9]FLDGRP(II),KK-1)+[L]LCOD+right$([M:ASW9]FLDGRP(II),JJ)
    Affzo [M:ASW9]FLDGRP(II)
   Endif
   If [M:ASW9]FLDGRP(II)=[L]LCODOLD
    [M:ASW9]FLDGRP(II) = [L]LCOD
    Affzo [M:ASW9]FLDGRP(II)
   Endif
  Next
  # on remplace dans les clés des propriétés
  For II=0 To [M:ASW9]NBCLE-1
   KK=func RECH_CODCOL([M:ASW9]VALCLE(II),[L]LCODOLD)
   If KK<>0
    JJ=KK+len([L]LCODOLD)
    [M:ASW9]VALCLE(II) = left$([M:ASW9]VALCLE(II),KK-1)+[L]LCOD+right$([M:ASW9]VALCLE(II),JJ)
    Affzo [M:ASW9]VALCLE(II)
   Endif
  Next
  # on remplace dans les paramètres des propriétés
  For II=0 To [M:ASW9]NBRPAR-1
   KK=func RECH_CODCOL([M:ASW9]VALEUR(II),[L]LCODOLD)
   If KK<>0
    JJ=KK+len([L]LCODOLD)
    [M:ASW9]VALEUR(II) = left$([M:ASW9]VALEUR(II),KK-1)+[L]LCOD+right$([M:ASW9]VALEUR(II),JJ)
    Affzo [M:ASW9]VALEUR(II)
   Endif
  Next
  # on remplace dans les propriétés exposées
  For II=0 To [M:ASW4]NBRPRO-1
   KK=func RECH_CODCOL([M:ASW4]CODPRO(II),[L]LCODOLD)
   If KK<>0
    JJ=KK+len([L]LCODOLD)
    [M:ASW4]CODPRO(II) = left$([M:ASW4]CODPRO(II),KK-1)+[L]LCOD+right$([M:ASW4]CODPRO(II),JJ)
    Affzo [M:ASW4]CODPRO(II)
   Endif
   KK=func RECH_CODCOL([M:ASW4]FLDGRPPRO(II),[L]LCODOLD)
   If KK<>0
    JJ=KK+len([L]LCODOLD)
    [M:ASW4]FLDGRPPRO(II) = left$([M:ASW4]FLDGRPPRO(II),KK-1)+[L]LCOD+right$([M:ASW4]FLDGRPPRO(II),JJ)
    Affzo [M:ASW4]FLDGRPPRO(II)
   Endif
   If [M:ASW4]FLDGRPPRO(II)=[L]LCODOLD
    [M:ASW4]FLDGRPPRO(II) = [L]LCOD
    Affzo [M:ASW4]FLDGRPPRO(II)
   Endif
  Next

  # on remplace dans filtre des liens
  If find([M:ASW7]TYPANCLNK,1,2,3) : #propriété/collection/ligne de collection
     KK=func RECH_CODCOL([M:ASW7]CODANCLNK,[L]LCODOLD)
     If KK<>0
      JJ=KK+len([L]LCODOLD)
      [M:ASW7]CODANCLNK = left$([M:ASW7]CODANCLNK,KK-1)+[L]LCOD+right$([M:ASW7]CODANCLNK,JJ)
      Affzo [M:ASW7]CODANCLNK
     Endif
     If [M:ASW7]CODANCLNK=[L]LCODOLD
      [M:ASW7]CODANCLNK = [L]LCOD
      Affzo [M:ASW7]CODANCLNK
     Endif
  Endif
  # on remplace dans les liens
  For II=0 To [M:ASW7]WNBLNK-1
   If find([M:ASW7]WAFFLNK(II),1,2,3) : #propriété/collection/ligne de collection
     KK=func RECH_CODCOL([M:ASW7]WANCLNK(II),[L]LCODOLD)
     If KK<>0
      JJ=KK+len([L]LCODOLD)
      [M:ASW7]WANCLNK(II) = left$([M:ASW7]WANCLNK(II),KK-1)+[L]LCOD+right$([M:ASW7]WANCLNK(II),JJ)
      Affzo [M:ASW7]WANCLNK(II)
     Endif
     If [M:ASW7]WANCLNK(II)=[L]LCODOLD
      [M:ASW7]WANCLNK(II) = [L]LCOD
      Affzo [M:ASW7]WANCLNK(II)
     Endif
   Endif
   KK=func RECH_CODCOL([M:ASW7]WCLAPTRLNK(II),[L]LCODOLD)
   If KK<>0
    JJ=KK+len([L]LCODOLD)
    [M:ASW7]WCLAPTRLNK(II) = left$([M:ASW7]WCLAPTRLNK(II),KK-1)+[L]LCOD+right$([M:ASW7]WCLAPTRLNK(II),JJ)
    Affzo [M:ASW7]WCLAPTRLNK(II)
   Endif
   If [M:ASW7]WCLAPTRLNK(II)=[L]LCODOLD
    [M:ASW7]WCLAPTRLNK(II) = [L]LCOD
    Affzo [M:ASW7]WCLAPTRLNK(II)
   Endif
  Next
  # on remplace dans les clés des liens
  For II=0 To [M:ASW7]NBCLELNK-1
   KK=func RECH_CODCOL([M:ASW7]VALCLELNK(II),[L]LCODOLD)
   If KK<>0
    JJ=KK+len([L]LCODOLD)
    [M:ASW7]VALCLELNK(II) = left$([M:ASW7]VALCLELNK(II),KK-1)+[L]LCOD+right$([M:ASW7]VALCLELNK(II),JJ)
    Affzo [M:ASW7]VALCLELNK(II)
   Endif
  Next
  # on remplace dans les paramètres des liens
  For II=0 To [M:ASW7]NBRPARLNK-1
   KK=func RECH_CODCOL([M:ASW7]VALPARLNK(II),[L]LCODOLD)
   If KK<>0
    JJ=KK+len([L]LCODOLD)
    [M:ASW7]VALPARLNK(II) = left$([M:ASW7]VALPARLNK(II),KK-1)+[L]LCOD+right$([M:ASW7]VALPARLNK(II),JJ)
    Affzo [M:ASW7]VALPARLNK(II)
   Endif
  Next

  # on remplace dans les liens (tableau invisible)
  For II=0 To [M:ASW6]NBRLNK-1
   If find([M:ASW6]AFFLNK(II),1,2,3) : #propriété/collection/ligne de collection
     KK=func RECH_CODCOL([M:ASW6]ANCLNK(II),[L]LCODOLD)
     If KK<>0
      JJ=KK+len([L]LCODOLD)
      [M:ASW6]ANCLNK(II) = left$([M:ASW6]ANCLNK(II),KK-1)+[L]LCOD+right$([M:ASW6]ANCLNK(II),JJ)
      Affzo [M:ASW6]ANCLNK(II)
      [M:ASW6]IDENT2(II)=func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW6]AFFLNK(II),[M:ASW6]ANCLNK(II),[M:ASW6]CODLNK(II))
      Affzo [M:ASW6]IDENT2(II)
     Endif
     If [M:ASW6]ANCLNK(II)=[L]LCODOLD
      [M:ASW6]ANCLNK(II) = [L]LCOD
      Affzo [M:ASW6]ANCLNK(II)
      [M:ASW6]IDENT2(II)=func SUBASW_TOOL.BUILD_ASW6_IDENT2([M:ASW6]AFFLNK(II),[M:ASW6]ANCLNK(II),[M:ASW6]CODLNK(II))
      Affzo [M:ASW6]IDENT2(II)
     Endif
   Endif
   KK=func RECH_CODCOL([M:ASW6]CLAPTRLNK(II),[L]LCODOLD)
   If KK<>0
    JJ=KK+len([L]LCODOLD)
    [M:ASW6]CLAPTRLNK(II) = left$([M:ASW6]CLAPTRLNK(II),KK-1)+[L]LCOD+right$([M:ASW6]CLAPTRLNK(II),JJ)
    Affzo [M:ASW6]CLAPTRLNK(II)
   Endif
   If [M:ASW6]CLAPTRLNK(II)=[L]LCODOLD
    [M:ASW6]CLAPTRLNK(II) = [L]LCOD
    Affzo [M:ASW6]CLAPTRLNK(II)
   Endif
  Next
  # on remplace dans les paramètres (tableau invisible)
  For II=0 To [M:ASW5]NBRPAR-1
   KK=func RECH_CODCOL([M:ASW5]INTVAL(II),[L]LCODOLD)
   If KK<>0
    JJ=KK+len([L]LCODOLD)
    [M:ASW5]INTVAL(II) = left$([M:ASW5]INTVAL(II),KK-1)+[L]LCOD+right$([M:ASW5]INTVAL(II),JJ)
    Affzo [M:ASW5]INTVAL(II)
   Endif
   KK=func RECH_CODCOL([M:ASW5]VALEUR(II),[L]LCODOLD)
   If KK<>0
    JJ=KK+len([L]LCODOLD)
    [M:ASW5]VALEUR(II) = left$([M:ASW5]VALEUR(II),KK-1)+[L]LCOD+right$([M:ASW5]VALEUR(II),JJ)
    Affzo [M:ASW5]VALEUR(II)
   Endif
   #si param de lien, on doit remplacer dans ancre
   If [M:ASW5]TYPPAR(II)=3
     KK=func RECH_CODCOL([M:ASW5]CODFLD(II),[L]LCODOLD)
     If KK<>0
      JJ=KK+len([L]LCODOLD)
      [M:ASW5]CODFLD(II) = left$([M:ASW5]CODFLD(II),KK-1)+[L]LCOD+right$([M:ASW5]CODFLD(II),JJ)
      Affzo [M:ASW5]CODFLD(II)
      [M:ASW5]IDENT2(II)=func SUBASW_TOOL.BUILD_ASW5_IDENT2([M:ASW5]TYPPAR(II),[M:ASW5]AFFLNK(II),[M:ASW5]TYPKEY(II),[M:ASW5]CODLNK(II),[M:ASW5]CODFLD(II),[M:ASW5]CODPAR(II))
      Affzo [M:ASW5]IDENT2(II)
     Endif
     If [M:ASW5]CODFLD(II)=[L]LCODOLD
      [M:ASW5]CODFLD(II) = [L]LCOD
      Affzo [M:ASW5]CODFLD(II)
      [M:ASW5]IDENT2(II)=func SUBASW_TOOL.BUILD_ASW5_IDENT2([M:ASW5]TYPPAR(II),[M:ASW5]AFFLNK(II),[M:ASW5]TYPKEY(II),[M:ASW5]CODLNK(II),[M:ASW5]CODFLD(II),[M:ASW5]CODPAR(II))
      Affzo [M:ASW5]IDENT2(II)
     Endif
   Endif
  Next
End

Subprog C_NBRCOL
Case status
 When 65  : # suppression lien dans tableaux
  # verif si collection utilisée dans les extensions de propriété
  I=find([M:ASW1]CODCOL(nolign-1),[M:ASW9]FLDGRP)
  If I>0
    GMESSAGE = func AFNC.MES2(mess(89,140,1),num$(I),[M:ASW9]CODFLD(I-1))
    mkstat = 2 : End
  Endif

  #Controls lienbs

  Local Integer MES_OK
  Local Integer I,J
  If [M:ASW1]CODCOL(nolign-1)<>""
    I=0 : J=0
    For I=0 To [M:ASW6]NBRLNK-1
      If find([M:ASW6]AFFLNK(I),2,3) & [M:ASW6]FLGSTDLNK(I)<>2 & [M:ASW6]ANCLNK(I)=[M:ASW1]CODCOL(nolign-1)
       MES_OK=1
       Call AVERTIR(mess(200,143,1)+"\\"+mess(205,100,1),MES_OK) From GESECRAN
       If MES_OK<>2
         mkstat=2
       Endif
       Break
      Endif
    Next I
    If mkstat : End : Endif
    For I=0 To [M:ASW6]NBRLNK-1
      If find([M:ASW6]AFFLNK(I),2,3) & [M:ASW6]ANCLNK(I)=[M:ASW1]CODCOL(nolign-1)
        # remove the parameters/keys
        Call REMOVE_PARAM_ASW5([M:ASW6]AFFLNK(I),[M:ASW6]ANCLNK(I),[M:ASW6]CODLNK(I),3) From SUBASW_TOOL
        Dela I,1 [M:ASW6]NBRLNK
        [M:ASW6]NBRLNK -=1
        I-=1
      Endif
    Next I
    Effzo [M:ASW7]10
    Effzo [M:ASW7]15
    Gosub AFFZO_ASW5 From SUBASW
    Call DISPLAY_LNK_ASW7(1,[M:ASW7]TYPANCLNK, [M:ASW7]CODANCLNK, [M:ASW7]OPTSTDLNK,[M:ASW7]OPTINVLNK) From SUBASW_TOOL
  Endif
Endcase
End



Subprog C_CODCOL(VALEUR)
Variable Char    VALEUR()
If toupper(VALEUR)<>[M:ASW1]CODCOL(nolign-1)
  # name covention
  Call PLAGE(VALEUR,1) From CONTOBJ
  If mkstat : End : Endif
Endif

Call UNICITE(toupper(VALEUR),[M:ASW1]CODCOL(0..[M:ASW1]NBRCOL-1)) From OBJDIV
If mkstat : End : Endif

If find(toupper(VALEUR),[M:ASW9]CODFLD)
 GMESSAGE = mess(146,143,1) # Code déjà utilisé pour une propriété ou une collection.
 mkstat = 2 : End
Endif

If instr(1,VALEUR,".")<=0
 If find(toupper(VALEUR),[M:ASW1]ABRCLA)
  GMESSAGE = VALEUR-":"-mess(83,123,1)-":"-mess(55,140,1)  : # Valeur incorrecte : instane DÉJÀ EXISTANTE
  mkstat = 2 : End
 Endif

 If len(VALEUR)>GLONAVA
  VALEUR = left$(VALEUR,GLONAVA)
 Endif
Else
 #Call C_FLDGRP(VALEUR)
 VALEUR = toupper(VALEUR)
 Gosub CHARGE_GRP2
 If !find(VALEUR,TEX)
  GMESSAGE = VALEUR-":"-mess(144,143,1) : # Collection inexistante.
  mkstat = 2 : End
 Endif
Endif
End

Subprog AM_CODCOL(VALEUR)
Variable Char    VALEUR()
 VALEUR = toupper(VALEUR)

 If instr(1,VALEUR,".")<=0
  [M:ASW1]ALIASCOL(nolign-1) = VALEUR
  Affzo [M:ASW1]ALIASCOL(nolign-1)
 Else
  # in case it's a collection coming from the class, need to prefill the collection information
  Local Integer I
  Local Char    WABR(80)
  Local Char TAB_COD(250)(1..100)
  Local Char TAB_LIB(80)(1..100)
  Local Integer TAB_MIN(1..100)
  Local Char TAB_ACT(80)(1..100)
  Local Integer TAB_MAX(1..100)
  Local Char TAB_COM(80)(1..100)
  Local Integer TAB_INS(1..100)
  Local Integer TAB_SUP(1..100)
  Local Integer TAB_TRI(1..100)
  Local Integer TAB_APD(1..100)
  Local Char TAB_CLA(GLONACLA)(1..100)
  Local Integer TAB_NB
  WABR = [M:ASW1]ABRCLA
  Call LOAD_FLDGRP_COMPLETE([M:ASW1]CODCLA,WABR,TAB_COD,TAB_LIB,TAB_MIN,TAB_ACT,TAB_MAX,TAB_COM,TAB_INS,TAB_SUP,TAB_TRI,TAB_APD,TAB_CLA,TAB_NB) From SUBASW_TOOL
  I = find(VALEUR, TAB_COD)
  If I>0
   [M:ASW1]INTITCOL(nolign-1)  = TAB_LIB(I)
   [M:ASW1]MINCOL(nolign-1)    = TAB_MIN(I)
   [M:ASW1]ACTCOL(nolign-1)    = TAB_ACT(I)
   [M:ASW1]MAXCOL(nolign-1)    = TAB_MAX(I)
   [M:ASW1]PROCOL(nolign-1)    = TAB_COM(I)
   [M:ASW1]FLGINSCOLCLA(nolign-1) = TAB_INS(I)
   [M:ASW1]FLGSUPCOLCLA(nolign-1) = TAB_SUP(I)
   [M:ASW1]FLGTRICOLCLA(nolign-1) = TAB_TRI(I)
   [M:ASW1]FLGAPDCOLCLA(nolign-1) = TAB_APD(I)
   [M:ASW1]FLGINSCOL(nolign-1) = TAB_INS(I)
   [M:ASW1]FLGSUPCOL(nolign-1) = TAB_SUP(I)
   [M:ASW1]FLGTRICOL(nolign-1) = TAB_TRI(I)
   [M:ASW1]FLGAPDCOL(nolign-1) = TAB_APD(I)
   Affzo [M:ASW1]INTITCOL(nolign-1)
   Affzo [M:ASW1]MINCOL(nolign-1)
   Affzo [M:ASW1]ACTCOL(nolign-1)
   Affzo [M:ASW1]MAXCOL(nolign-1)
   Affzo [M:ASW1]PROCOL(nolign-1)
   Affzo [M:ASW1]FLGINSCOL(nolign-1)
   Affzo [M:ASW1]FLGSUPCOL(nolign-1)
   Affzo [M:ASW1]FLGTRICOL(nolign-1)
   Affzo [M:ASW1]FLGAPDCOL(nolign-1)
  Endif
 Endif
End


Subprog S_CODCOL(VALEUR)
Variable Char    VALEUR()

Gosub DEFSEL4
Local Char    WABR(80)

Local Char TAB_COD(250)(1..100)
Local Char TAB_MIN(80)(1..100)
Local Char TAB_MAX(80)(1..100)
Local Char TAB_CLA(GLONACLA)(1..100)
Local Integer TAB_NB

 WABR = [M:ASW1]ABRCLA
 Call LOAD_FLDGRP([M:ASW1]CODCLA,WABR,TAB_COD,TAB_MIN,TAB_MAX,TAB_CLA,TAB_NB) From SUBASW_TOOL

 For I=1 To TAB_NB
  NBTEX+= 1
  TEX(NBTEX,1)  = TAB_COD(I)
  TEX(NBTEX,2)  = TAB_MIN(I)
  TEX(NBTEX,3)  = TAB_MAX(I)
  TEX(NBTEX,4)  = TAB_CLA(I)
 Next

CHOI = 0
TIT(0) = mess(22,123,1) # Selection
TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("ASHW9", "FLDGRP") # Collection
TIT(2) = func AMK_TOOL.GET_FIELD_LABEL("ASHW1", "MINCOL") # Nb mini
TIT(3) = func AMK_TOOL.GET_FIELD_LABEL("ASHW1", "MAXCOL") # Nb max
TIT(4) = func AMK_TOOL.GET_FIELD_LABEL("ASHW1", "CODCLA") # Code classe

If NBTEX=1
 VALEUR = TEX(1,1)
Elsif NBTEX>0
 Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
 If status<>7 & CHOI<>0
  VALEUR = TEX(CHOI,1)
 Endif
Endif
End






Subprog AS_ALIASCOL(VALEUR)
Variable Char    VALEUR()
 If VALEUR = "" and instr(1,[M:ASW1]CODCOL(nolign-1),".")<=0
  VALEUR = [M:ASW1]CODCOL(nolign-1)
 Endif
 If instr(1,[M:ASW1]CODCOL(nolign-1),".")<=0
  mkstat = 2 : End
 Endif
End


Subprog C_ALIASCOL(VALEUR)
Variable Char    VALEUR()
 Call UNICITE(VALEUR,[M:ASW1]ALIASCOL(0..[M:ASW1]NBRCOL-1)) From OBJDIV
 If mkstat : End : Endif
End


Subprog AS_FLGINSCOL(VALEUR)
Variable Integer VALEUR
 If instr(1,[M:ASW1]CODCOL(nolign-1),".")>0 and [M:ASW1]FLGINSCOLCLA(nolign-1)<>2
  mkstat = 1 : End
 Endif
End

Subprog AS_FLGSUPCOL(VALEUR)
Variable Integer VALEUR
 If instr(1,[M:ASW1]CODCOL(nolign-1),".")>0 and [M:ASW1]FLGSUPCOLCLA(nolign-1)<>2
  mkstat = 1 : End
 Endif
End

Subprog AS_FLGTRICOL(VALEUR)
Variable Integer VALEUR
 If instr(1,[M:ASW1]CODCOL(nolign-1),".")>0 and [M:ASW1]FLGTRICOLCLA(nolign-1)<>2
  mkstat = 1 : End
 Endif
End

Subprog AS_FLGAPDCOL(VALEUR)
Variable Integer VALEUR
 If instr(1,[M:ASW1]CODCOL(nolign-1),".")>0 and [M:ASW1]FLGAPDCOLCLA(nolign-1)<>2
  mkstat = 1 : End
 Endif
End

Subprog AS_MINCOL(VALEUR)
Variable Integer VALEUR
 If instr(1,[M:ASW1]CODCOL(nolign-1),".")>0
  mkstat = 2 : End
 Endif
End

Subprog AS_ACTCOL(VALEUR)
Variable Char    VALEUR()
 If instr(1,[M:ASW1]CODCOL(nolign-1),".")>0
  mkstat = 2 : End
 Endif
End

Subprog C_ACTCOL(VALEUR)
Variable Char    VALEUR()
 Local Integer I
 If VALEUR <> "" and [M:ASW1]CODCOL(nolign-1)<>""
  Read [ACV]CODACT = VALEUR
  If fstat
   # Code activité inexistant
   GMESSAGE = VALEUR+": "+mess(22,150,1)
   mkstat =2 : End
  Endif
  If [ACV]DIME <= 0
   GMESSAGE = mess(105,143,1) : # Valeur 0 impossible pour les classes représentations.
   mkstat =2 : End
  Endif
 Endif
End


Subprog AS_MAXCOL(VALEUR)
Variable Decimal VALEUR
 If [M:ASW1]ACTCOL(nolign-1)<>""
  mkstat = 1 : End
 Endif
 If instr(1,[M:ASW1]CODCOL(nolign-1),".")>0
  mkstat = 2 : End
 Endif
End

Subprog C_MAXCOL(VALEUR)
Variable Decimal VALEUR
If instr(1,[M:ASW1]CODCOL(nolign-1),".")=0
 If VALEUR <=0
  If VALEUR = 0
   GMESSAGE = mess(105,143,1) : # Valeur 0 impossible pour les classes représentations.
  Else
   GMESSAGE = mess(83,123,1) : # Valeur incorrecte
  Endif
  mkstat = 2 : End
 Endif
Endif
End

Subprog AS_PROCOL(VALEUR)
Variable Char    VALEUR()
 If instr(1,[M:ASW1]CODCOL(nolign-1),".")>0
  mkstat = 2 : End
 Endif
End

Subprog C_PROCOL(VALEUR)
Variable Char    VALEUR()
Local Integer K
If VALEUR="" : End : Endif
K= find(VALEUR, [M:ASW9]CODFLD(0..[M:ASW9]NBRFLD-1))
If K=0
 GMESSAGE = mess(22,124,1) : # Zone inexistante
 mkstat = 2 : End
Endif
Read [ATY]CODTYP = [M:ASW9]CODTYP(K-1)
If [ATY]TYPTYP<>2 and [ATY]TYPTYP <> 3
 GMESSAGE = mess(113,127,1) : # Type de donnée incompatible
 mkstat = 2 : End
Endif
End


######################################################################################
## ASW3 : Méthodes
######################################################################################
$ASW3
Return

Subprog AS_NBRMET
Chgstl [M:ASW3]NBRMET With ""
Chgstl [M:ASW3]NBRMET(nolign-1) With "AMKCUR"
Effzo  [M:ASW3]10
If [M:ASW0]CODREP="" | [M:ASW3]CODMET(nolign-1)=""
 Raz [M:ASW3]METCUR
 End
Endif
Local Integer I,J
[M:ASW3]METCUR= [M:ASW3]CODMET(nolign-1)

I=0
For J=0 To [M:ASW3]WNBRPARMET-1
 If [M:ASW3]WCODMET(J) = [M:ASW3]CODMET(nolign-1)& I<dim([M:ASW3]CODPARMET)
  [M:ASW3]CODPARMET(I) = [M:ASW3]WCODPARMET(J)
  [M:ASW3]TYPPARMET(I) = [M:ASW3]WTYPPARMET(J)
  [M:ASW3]MODPARMET(I) = [M:ASW3]WMODPARMET(J)
  [M:ASW3]INTPARMET(I) = [M:ASW3]WINTPARMET(J)
  [M:ASW3]CLAPARMET(I) = [M:ASW3]WCLAPARMET(J)
  [M:ASW3]DIMPARMET(I) = [M:ASW3]WDIMPARMET(J)
  Call TEXTE([M:ASW3]WINTPARMET(J),[M:ASW3]INTITPARMET(I)) From OBJDIV
  I += 1
 Endif
Next
[M:ASW3]NBRPARMET = I
Affzo [M:ASW3]10
End

Subprog C_NBRMET
Case status
 When 65  : # suppression param dans tableau
  Local Integer I
  #Controls
  If [M:ASW3]METCUR<>""
    For I=0 To [M:ASW6]NBRLNK-1
      If [M:ASW6]TYPLNK(I)=2 & [M:ASW6]CLALNK(I)="" & [M:ASW6]METLNK(I)=[M:ASW3]METCUR
        GMESSAGE=func AFNC.MES2( mess(198,143,1),[M:ASW6]CODLNK(I), mess([M:ASW6]AFFLNK(I),7965,1)-[M:ASW6]ANCLNK(I))
        mkstat=2 : Break
      Endif
     Next I
    If mkstat : End : Endif
  Endif
  #
  I= find([M:ASW3]METCUR,[M:ASW3]WCODMET(0..[M:ASW3]WNBRPARMET-1))
  While I>0
   Dela I-1,1 [M:ASW3]WNBRPARMET
   [M:ASW3]WNBRPARMET -= 1
   I= find([M:ASW3]METCUR,[M:ASW3]WCODMET(0..[M:ASW3]WNBRPARMET-1))
  Wend
  Raz [M:ASW3]METCUR
  Effzo  [M:ASW3]10
  Gosub SORTA_ASW3 From SUBASW
  Affzo [M:ASW3]15

 When 73
  Raz [M:ASW3]METCUR
  Effzo  [M:ASW3]10
  Gosub SORTA_ASW3 From SUBASW
  Affzo [M:ASW3]15
Endcase
End

Subprog C_CODMET(VALEUR)
Variable Char    VALEUR()
Gosub MET_RESERVE From SUBACLA
If find(VALEUR,TBMET)
 GMESSAGE = VALEUR-":"-mess(129,133,1) : # Code réservé
 mkstat = 2 : End
Endif
If VALEUR<>[M:ASW3]CODMET(nolign-1)
  # name covention
  Call PLAGE(VALEUR,1) From CONTOBJ
  If mkstat : End : Endif
Endif
Call UNICITE(VALEUR,[M:ASW3]CODMET(0..[M:ASW3]NBRMET-1)) From OBJDIV
If mkstat : End : Endif
End

Subprog AM_CODMET(VALEUR)
Variable Char    VALEUR()
For I=0 To [M:ASW3]WNBRPARMET
 If [M:ASW3]WCODMET(I)=[M:ASW3]METCUR
  [M:ASW3]WCODMET(I)=VALEUR
 Endif
Next
Affzo [M:ASW3]15
End

Subprog C_NBRPARMET
Local Integer I,J,K,NOL
NOL = nolign-1
Case status
 When 71
  If GFLAG ="1"
   For I=0 To WNBRPARMET-1
    If [M:ASW3]WCODMET(I)=[M:ASW3]METCUR & [M:ASW3]WNOPARMET(I)>=NOL+1
     [M:ASW3]WNOPARMET(I) -=1
    Endif
   Next
   GFLAG = ""
   Gosub SORTA_ASW3 From SUBASW
   Affzo [M:ASW3]15
  Endif
 When 73
  For I=0 To WNBRPARMET-1
   If [M:ASW3]WCODMET(I)=[M:ASW3]METCUR & [M:ASW3]WNOPARMET(I)>=NOL+1
    [M:ASW3]WNOPARMET(I) +=1
   Endif
  Next
  GFLAG ="1"
  Gosub SORTA_ASW3 From SUBASW
  Affzo [M:ASW3]15
 When 65  : # suppression param dans tableau
  For I=0 To WNBRPARMET-1
   If [M:ASW3]WCODMET(I)=[M:ASW3]METCUR & [M:ASW3]WCODPARMET(I) = [M:ASW3]CODPARMET(NOL)
    Dela I,1 [M:ASW3]WNBRPARMET
    [M:ASW3]WNBRPARMET -= 1
    Break
   Endif
  Next
  For I=0 To WNBRPARMET-1
   If [M:ASW3]WCODMET(I)=[M:ASW3]METCUR & [M:ASW3]WNOPARMET(I)>NOL+1
   [M:ASW3]WNOPARMET(I) -=1
   Endif
  Next
  Gosub SORTA_ASW3 From SUBASW
  Affzo [M:ASW3]15
Endcase
End

Subprog APRES_NBRPARMET
#----- Si touche "Echap" ou autre statut "Abandon" -----#
If status=6 | status=7 | status=27 | status=28 | status=1792
  End
#----- Si suppression ligne -----#
Elsif status=65 | status=68 | status=83
  End
Endif
If [M:ASW3]METCUR="" | [M:ASW3]CODPARMET(nolign-1)="" :  End : Endif
Local Integer I,J,K,NOL
NOL = nolign-1
For I=0 To WNBRPARMET-1
 If [M:ASW3]WCODMET(I)=[M:ASW3]METCUR & [M:ASW3]WNOPARMET(I) = NOL+1
  J=1
  Break
 Endif
Next
If J=0
 I=[M:ASW3]WNBRPARMET
 [M:ASW3]WNBRPARMET += 1
Endif
[M:ASW3]WCODMET(I)    = [M:ASW3]METCUR
[M:ASW3]WCODPARMET(I) = [M:ASW3]CODPARMET(NOL)
[M:ASW3]WTYPPARMET(I) = [M:ASW3]TYPPARMET(NOL)
[M:ASW3]WMODPARMET(I) = [M:ASW3]MODPARMET(NOL)
[M:ASW3]WINTPARMET(I) = [M:ASW3]INTPARMET(NOL)
[M:ASW3]WCLAPARMET(I) = [M:ASW3]CLAPARMET(NOL)
[M:ASW3]WDIMPARMET(I) = [M:ASW3]DIMPARMET(NOL)
[M:ASW3]WNOPARMET(I)  = NOL+1
Gosub SORTA_ASW3 From SUBASW
Affzo [M:ASW3]15
GFLAG = ""
End

Subprog AS_CODPARMET(VALEUR)
Variable Char    VALEUR()
If [M:ASW3]METCUR="" : GMESSAGE=mess(172,143,1): GERR=1 : mkstat=2 : Endif
End

Subprog C_CODPARMET(VALEUR)
Variable Char    VALEUR()
If [M:ASW3]METCUR="" : GMESSAGE=mess(172,143,1): GERR=1 : mkstat=2 : Endif
Call UNICITE(VALEUR,[M:ASW3]CODPARMET(0..[M:ASW3]NBRPARMET-1)) From OBJDIV
If mkstat : End : Endif
End


Subprog AS_DIMPARMET(VALEUR)
Variable Integer VALEUR
If [M:ASW3]TYPPARMET(nolign-1) = 13 : GMENLOC(3) = 1 : Endif
End

######################################################################################
## ASW9 extension propriete
######################################################################################
$ASW9
Return

Subprog AS_NBRFLD
 Local Integer I,J
 Chgstl [M:ASW9]CODFLD With ""
 Chgstl [M:ASW9]CODFLD(nolign-1) With "AMKCUR"
 Effzo  [M:ASW9]10
 Effzo  [M:ASW9]15
 If [M:ASW0]CODREP="" | [M:ASW9]CODFLD(nolign-1)=""
  Raz [M:ASW9]FLDCUR : End
 Endif

 [M:ASW9]STALIN(nolign-1)=0

 # initialise FLDCUR, CODTYPCUR
 [M:ASW9]FLDCUR= [M:ASW9]CODFLD(nolign-1)
 If [M:ASW9]LOBTAB(nolign-1)=""
  [M:ASW9]CODTYPCUR = [M:ASW9]CODTYP(nolign-1)
 Else
  [M:ASW9]CODTYPCUR  = [M:ASW9]CODTYP(nolign-1) + "." + [M:ASW9]LOBTAB(nolign-1)+ "." + [M:ASW9]LOBFLD(nolign-1)
 Endif

 # refresh [ASW9]10, [ASW9]15
 Gosub DISPLAY_PARAM_CODFLD
 If L_HAS_PARAM
  Chgstl [M:ASW9]CODTYP(nolign-1) With "AMKACT"
  If [M:ASW9]LOBTAB(nolign-1)<>""
   Chgstl [M:ASW9]LOBTAB(nolign-1) With "AMKACT"
   Chgstl [M:ASW9]LOBFLD(nolign-1) With "AMKACT"
   Chgstl [M:ASW9]LOBCNT(nolign-1) With "AMKACT"
  Endif
 Else
  Chgstl [M:ASW9]CODTYP(nolign-1) With ""
  Chgstl [M:ASW9]LOBTAB(nolign-1) With ""
  Chgstl [M:ASW9]LOBFLD(nolign-1) With ""
  Chgstl [M:ASW9]LOBCNT(nolign-1) With ""
 Endif
End

Subprog C_NBRFLD
Local Char WCODPRO(GLONAVC)
Local Integer I
Case status
 When 65  : # suppression prop dans tableau
  If [M:ASW9]FLDGRP(nolign-1)<>""
    WCODPRO=[M:ASW9]FLDGRP(nolign-1)+"."+[M:ASW9]CODFLD(nolign-1)
  Else
    WCODPRO=[M:ASW9]CODFLD(nolign-1)
  Endif
  I=find(WCODPRO,[M:ASW4]CODPRO)
  If I>0
    GMESSAGE=func AFNC.MES2( mess(213,143,1),[M:ASW9]CODFLD(nolign-1),[M:ASW4]ALIAS(I-1))
    mkstat=2 : End
  Endif
  [M:ASW9]FLDCUR= [M:ASW9]CODFLD(nolign-1)
  Call REMOVE_PARAM_ASW5(1,[M:ASW9]FLDCUR,"",1) From SUBASW_TOOL
  Gosub AFFZO_ASW5 From SUBASW
  Raz   [M:ASW9]FLDCUR
  Effzo [M:ASW9]10
  Effzo [M:ASW9]15

# When 83
#  For NOL=nolign-1 To nolign1
#  [M:ASW9]FLDCUR= [M:ASW9]CODFLD(NOL)
#  Gosub DEL_PARAM_CODFLD
#  Next

 When 73 : # Insertion, param dans tableau
  Raz [M:ASW9]FLDCUR
  Effzo  [M:ASW9]10
  Effzo  [M:ASW9]15

Endcase
End

Subprog AVANT_NBRFLD
Case status
 When 67 # Paste
  [M:ASW9]CODFLD(nolign-1)= "PROPERTYCOPY"
  Affzo [M:ASW9]CODFLD(nolign-1)
  If [M:ASW9]LOBTAB(nolign-1) <> ""
   Call L_AM_LOBTAB([M:ASW9]LOBTAB(nolign-1),[M:ASW9]LOBFLD(nolign-1), [M:ASW9]CODFLD(nolign-1))
  Else
   Call L_AM_CODTYP([M:ASW9]CODTYP(nolign-1), [M:ASW9]CODFLD(nolign-1))
  Endif
Endcase
End

Subprog APRES_NBRFLD
#----- Si touche "Echap" ou autre statut "Abandon" -----#
If status=6 | status=7 | status=27 | status=28 | status=1792
  End
#----- Si suppression ligne -----#
Elsif status=65 | status=68 | status=83
  End
Endif
 Local Char L_CODTYP(GLONATY)
 # calculate CODTYP used in [M:ASW1]CODTYP
 L_CODTYP = [M:ASW9]CODTYP(nolign-1)
 If [M:ASW9]LOBTAB(nolign-1) <> ""
  L_CODTYP = L_CODTYP+"."+[M:ASW9]LOBTAB(nolign-1)+"."+[M:ASW9]LOBFLD(nolign-1)
 Endif
 Local Integer I
 # remove the no longer used parameters/keys from [M:ASW5]
 For I = 0 To [M:ASW5]NBRPAR-1
  If [M:ASW5]TYPPAR(I) = 1
   If !find([M:ASW5]CODFLD(I),[M:ASW9]CODFLD)
    Dela I,1 [M:ASW5]NBRPAR
    [M:ASW5]NBRPAR-= 1
    I-=1
   Elsif [M:ASW5]CODFLD(I) = [M:ASW9]FLDCUR and [M:ASW5]CODTYP(I)<>L_CODTYP
    Dela I,1 [M:ASW5]NBRPAR
    [M:ASW5]NBRPAR-= 1
    I-=1
   Endif
  Endif
 Next

#MaJ des liens
Case status
  When 73, 82 # insert/create a new line
    #nothing
  When Default
    If [M:ASW9]STALIN(nolign-1)<>0
      Gosub MAJ_STDLNK_FCT_2 From SUBASW
    Endif
Endcase
End


Subprog AS_AZINTSHTFLD(VALEUR)
Variable Char    VALEUR()
If [M]AZINTSHTFLD(nolign-1) = ""
 If len([M]AZINTFLD(nolign-1))<20
  VALEUR = [M]AZINTFLD(nolign-1)
  [M:ASW9]INTSHTFLD(nolign-1) = [M]INTFLD(nolign-1)
 Endif
Endif
End


$DISPLAY_PARAM_CODFLD
 Local Integer J, L_HAS_PARAM

 L_HAS_PARAM = 0
 [M:ASW9]NBRPAR = 0
 [M:ASW9]NBCLE = 0

 Gosub SORTA_ASW5 From SUBASW
 Gosub AFFZO_ASW5 From SUBASW

 For J=0 To [M:ASW5]NBRPAR-1
  If [M:ASW5]TYPPAR(J)=1 & [M:ASW5]CODFLD(J) = [M:ASW9]FLDCUR & [M:ASW5]ISKEY(J)<>2
   If [M:ASW5]CODTYP(J)=""
    [M:ASW5]CODTYP(J) = [M:ASW9]CODTYPCUR
   Endif
   # Only the parameter/key related the current data type will be displayed
   If [M:ASW5]CODTYP(J) = [M:ASW9]CODTYPCUR
    L_HAS_PARAM = 1
   # Keys
   If [M:ASW5]TYPKEY(J)=2
    [M:ASW9]CODCLE([M:ASW9]NBCLE) = [M:ASW5]CODPAR(J)
    [M:ASW9]INTCLE([M:ASW9]NBCLE) = [M:ASW5]INTITPAR(J)
    [M:ASW9]TYPCLE([M:ASW9]NBCLE) = [M:ASW5]TYPINTPAR(J)
    [M:ASW9]VALCLE([M:ASW9]NBCLE) = [M:ASW5]VALEUR(J)
    [M:ASW9]NBCLE += 1
   # Parameters
   Else
    [M:ASW9]CODPAR([M:ASW9]NBRPAR)      = [M:ASW5]CODPAR(J)
    [M:ASW9]INTITPAR([M:ASW9]NBRPAR)    = [M:ASW5]INTITPAR(J)
    [M:ASW9]TYPINTPAR([M:ASW9]NBRPAR)   = [M:ASW5]TYPINTPAR(J)
    [M:ASW9]CODCLAPAR([M:ASW9]NBRPAR)   = [M:ASW5]CODCLAPAR(J)
    [M:ASW9]ADRVAL([M:ASW9]NBRPAR)      = [M:ASW5]ADRVAL(J)
    [M:ASW9]VALEUR([M:ASW9]NBRPAR)      = [M:ASW5]VALEUR(J)
    [M:ASW9]NBRPAR += 1
   Endif
   Endif
  Endif
 Next
 Affzo [M:ASW9]10
 Affzo [M:ASW9]15
Return

Subprog C_VALEUR(VALEUR)
Variable Char    VALEUR()
Local Char L_ERR_MSG(250), L_PARCOL(GLONAVC)
Local Integer I

If [L]VALEUR="" & [M:ASW9]CODPAR(nolign-1)<>"AFILTER"
 GMESSAGE = mess(10,123,1) : #ZONE OBLIGATOIRE
 mkstat= 2 : End
Elsif  [L]VALEUR="" & [M:ASW9]CODPAR(nolign-1)="AFILTER"
 End
Elsif  [M:ASW9]CODPAR(nolign-1)="AENABLE" & find([L]VALEUR,"1","2")=0
 GMESSAGE = mess(126,143,1) # Valeur invalide.
 mkstat= 2 : End
Endif

I = find([M:ASW9]FLDCUR, [M:ASW9]CODFLD)
If I>0
 L_PARCOL = [M:ASW9]FLDGRP(I-1)
 If !func SUBASW_TOOL.L_CHECK_PARAMETER([M:ASW9]CODFLD(I-1),[M:ASW9]CODTYP(I-1),[M:ASW9]CODPAR(nolign-1),[M:ASW9]ACTFLD(I-1),VALEUR, [M:ASW9]TYPINTPAR(nolign-1), [M:ASW9]ADRVAL(nolign-1), L_PARCOL,
&              [M:ASW0]CODREP, 1, 0, 0, 0,0,0,0,0, 0, L_ERR_MSG)
  GMESSAGE = L_ERR_MSG
  mkstat = 2
 Endif
Endif
End

Subprog AM_VALEUR(VALEUR)
Variable Char    VALEUR()
Call AFTERMODIF([M:ASW9]FLDCUR,[M:ASW9]CODPAR(nolign-1),1,1,"VALEUR",VALEUR)
End

Subprog AFTERMODIF(CODECUR,CODEPAR,CODETYPKEY,CODETYPPAR,CHAMP,VALEUR)
Value Char CODECUR
Value Char CODEPAR
Value Integer CODETYPKEY
Value Integer CODETYPPAR
Value Char CHAMP
Value Char VALEUR
Local Integer I,J,ILOB
J=find(CODECUR,[M:ASW9]CODFLD)
If J
 Read [ATY]CODTYP=[M:ASW9]CODTYP(J-1)
 If !fstat
  If find([F:ATY]TYPTYP,9,10)<>0
   ILOB=1
  Endif
 Endif
Endif
I=find(func SUBASW_TOOL.BUILD_ASW5_IDENT2(CODETYPPAR,1,CODETYPKEY,"",CODECUR,CODEPAR),[M:ASW5]IDENT2)
If I>0
  Case CHAMP
   When "VALEUR" : If [M:ASW5]VALEUR(I-1) = [L]VALEUR : ILOB=0 : Endif
                   [M:ASW5]VALEUR(I-1) = [L]VALEUR
                   Affzo [M:ASW5]VALEUR(I-1)
   When "NOLIB"  : If [M:ASW5]NOLIB(I-1) = val([L]VALEUR) : ILOB=0 : Endif
                   [M:ASW5]NOLIB(I-1)  = val([L]VALEUR)
                   Affzo [M:ASW5]NOLIB(I-1)
   When "TYPAFF" : If [M:ASW5]TYPAFF(I-1) = val([L]VALEUR) : ILOB=0 : Endif
                   [M:ASW5]TYPAFF(I-1) = val([L]VALEUR)
                   Affzo [M:ASW5]TYPAFF(I-1)
   When "LNG"    : If [M:ASW5]LNG(I-1) = val([L]VALEUR) : ILOB=0 : Endif
                   [M:ASW5]LNG(I-1)    = val([L]VALEUR)
                   Affzo [M:ASW5]LNG(I-1)
  Endcase
Endif
If ILOB
Gosub MAJ_STDLNK_FCT_2 From SUBASW
Endif
End

Subprog C_VALCLE(VALEUR)
Variable Char    VALEUR()
Local Char L_ERR_MSG(250), L_PARCOL(GLONAVC)
Local Integer I
I = find([M:ASW9]FLDCUR, [M:ASW9]CODFLD)
If I>0
 L_PARCOL = [M:ASW9]FLDGRP(I-1)
 If !func SUBASW_TOOL.L_CHECK_PARAMETER([M:ASW9]CODFLD(I-1),[M:ASW9]CODTYP(I-1),[M:ASW9]CODCLE(nolign-1),[M:ASW9]ACTFLD(I-1),VALEUR, [M:ASW9]TYPCLE(nolign-1), 2, L_PARCOL,
&              [M:ASW0]CODREP, 1, 0, 0, 0,0,0,0,0, 0,L_ERR_MSG)
  GMESSAGE = L_ERR_MSG
  mkstat = 2
 Endif
Endif
End


Subprog AM_VALCLE(VALEUR)
Variable Char    VALEUR()
Call AFTERMODIF([M:ASW9]FLDCUR,[M:ASW9]CODCLE(nolign-1),2,1,"VALEUR",VALEUR)
End

$SEL_OPTION
Gosub DEFSEL3 From SUBASW2
I = find([M:ASW9]FLDCUR, [M:ASW9]CODFLD)
If I>0
 Read [ATY]CODTYP = [M]CODTYP(I-1)
 If !fstat
  For [ACLAO] Where CODCLA=[ATY]CODCLA
    NBTEX+= 1
    TEX(NBTEX,1) = [F:ACLAO]OPTCOD
    TEX(NBTEX,2) = func AFNC.TEXTE([F:ACLAO]OPTLIB)
    TEX(NBTEX,3) = [F:ACLAO]OPTACT
  Next
  CHOI = 0
  TIT(0) = mess(22,123,1) # Sélection
  TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("ASHW2", "OPTCOD")
  TIT(2) = mess(30,109,1) : # INTITULé
  TIT(3) = func AMK_TOOL.GET_FIELD_LABEL("ASHW2", "OPTACT")
  Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
  If status<>7 & CHOI<>0
   VALEUR = '"'+TEX(CHOI,1)+'"'
  Endif
 Endif
Endif
Return

Subprog S_VALEUR(VALEUR)
Variable Char    VALEUR()
If zoncou="VALEUR"
 If [M:ASW9]CODPAR(nolign-1) ="AFILTER"
  Gosub SEL_OPTION
  End
 Endif
 If [M:ASW9]CODPAR(nolign-1) ="AENABLE"
  Gosub SEL_AENABLE From SUBACLA2
  End
 Endif
Endif
Local Integer NBCHOI, CHOI
Local Char    TEX(GLONDES)(1..[M:ASW9]NBRFLD,1..4) , TIT(GLONDES)(0..4)
For  I=0 To [M:ASW9]NBRFLD-1
 If [M:ASW9]CODTYP(I)<>"ARF"
  NBCHOI += 1
  TEX(NBCHOI,1) = [M:ASW9]CODFLD(I)
  TEX(NBCHOI,2) = [M:ASW9]CODTYP(I)
  TEX(NBCHOI,3) = [M:ASW9]AZINTFLD(I)
  TEX(NBCHOI,4) = [M:ASW9]FLDGRP(I)
 Endif
Next
CHOI = 0
TIT(0) = mess(8,31,1) : #SÉLECTION
TIT(1) = mess(199,123,1) : #PROPRIÉTÉS
TIT(2) = mess(5,42,1) : # type DE DONNÉES
TIT(3) = func AMK_TOOL.GET_FIELD_LABEL("ACLA6", "ZINTFLD") # Libellé
TIT(4) = ""
Call SAITEX_COL_MAX(NBCHOI,TEX,CHOI,TIT,240,60) From GESECRAN
If status<>7 & CHOI<>0
 VALEUR = ""
 If TEX(CHOI,4)<>""
  VALEUR = TEX(CHOI,4)+"."
 Endif
 VALEUR += TEX(CHOI,1)
Endif
End

Subprog S_VALCLE(VALEUR)
Variable Char    VALEUR()
Call S_VALEUR(VALEUR)
End


#######

Subprog C_CODFLD(VALEUR)
Variable Char    VALEUR()
If [M:ASW1]ABRCLA=VALEUR
 GMESSAGE = VALEUR-mess(83,123,1) : # VALEUR INCORRECTE
 mkstat = 2 : End
Endif
Call UNICITE(VALEUR,[M:ASW9]CODFLD(0..[M:ASW9]NBRFLD-1)) From OBJDIV
If mkstat : End : Endif
If find(VALEUR,[M:ASW1]CODCOL)
 GMESSAGE = mess(146,143,1) # Code déjà utilisé pour une propriété ou une collection.
 mkstat = 2 : End
Endif
End

Subprog AM_CODFLD(VALEUR)
Variable Char    VALEUR()
 [M:ASW9]FLDCUR = VALEUR
 If [M:ASW9]LOBTAB(nolign-1) <> ""
  Call L_AM_LOBTAB([M:ASW9]LOBTAB(nolign-1), [M:ASW9]LOBFLD(nolign-1),VALEUR)
 Else
  Call L_AM_CODTYP([M:ASW9]CODTYP(nolign-1), VALEUR)
 Endif
 [M:ASW9]STALIN(nolign-1)=1
End

Subprog AS_NUMFLD(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
 If nolign=1
  VALEUR = 10
 Else
  VALEUR = [M:ASW9]NUMFLD(nolign-2)+10
 Endif
Endif
End

Subprog IB_CODTYP
Local Integer OKLIS : [L]OKLIS=0
 Read [ATY]CODTYP=[M:ASW9]CODTYP(nolign-1)
 If !fstat & [F:ATY]TYPPROSYR<>""
  Read [ATYP]ATYP0=[F:ATY]TYPPROSYR
  If !fstat & [F:ATYP]LISFLG=2
   [L]OKLIS=1
  Endif
 Endif
 If [L]OKLIS<>1
  Raz GBOUT2
 Endif
End

