Variable Decimal VALEUR
 Read [AML]MENLOC = VALEUR
 If fstat=0 & [F:AML]LONG<>0
  [M]LONG(nolign-1) = [F:AML]LONG : Affzo [M]LONG(nolign-1)
 Endif
End

