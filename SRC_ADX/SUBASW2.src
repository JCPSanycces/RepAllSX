Subprog B2_QRYPRO(VALEUR)
Variable Integer VALEUR
Local Integer OK
Local Char L_ERR_MSG(250)
Local Integer I
For I=nolign-1 To [M:ASW4]NBRPRO-1
 If [M:ASW4]QRYPRO(I)<>2
  If [M:ASW4]FLDGRPPRO(I)<>""
   Call CONTROLE_QRYPRO([M:ASW0]CODREP,[M:ASW4]ALIAS(I),[M:ASW4]CODPRO(I),[M:ASW4]FLDGRPPRO(I),[M:ASW1]CODCLA,[M:ASW1]ABRCLA,OK,L_ERR_MSG)
   If OK
    [M:ASW4]QRYPRO(I)=2 :  Affzo [M:ASW4]QRYPRO(I)
   Endif
  Else
   [M:ASW4]QRYPRO(I)=2 :  Affzo [M:ASW4]QRYPRO(I)
  Endif
 Endif
Next I
VALEUR=[M:ASW4]QRYPRO(nolign-1)
[M:ASW4]STALIN(nolign-1)=1
If find(2,[M:ASW4]QRYPRO)=0 :# Query
 [M:ASW1]ENAFAC(2)=1 : Affzo [M:ASW1]ENAFAC(2)
Else
 [M:ASW1]ENAFAC(2)=2 : Affzo [M:ASW1]ENAFAC(2)
Endif
End

Subprog B3_QRYPRO(VALEUR)
