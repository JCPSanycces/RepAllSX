Subprog AS_QRYPRO(VALEUR)
Variable Integer VALEUR
Local Integer OK
Local Integer NOL : NOL=nolign-1
Local Char L_ERR_MSG(250)
If [M:ASW4]FLDGRPPRO(NOL)<>""
  Call CONTROLE_QRYPRO([M:ASW0]CODREP,[M:ASW4]ALIAS(NOL),[M:ASW4]CODPRO(NOL),[M:ASW4]FLDGRPPRO(NOL),[M:ASW1]CODCLA,[M:ASW1]ABRCLA,OK,L_ERR_MSG)
  If !OK
    mkstat=1 : #collection de dimension : pas dans query
    VALEUR=1
    [M:ASW4]QRYPRO(NOL)=1
#    [M:ASW4]STAQRYPRO(NOL)=2
#    Affzo [M:ASW4]STAQRYPRO(NOL)
    If [M:ASW1]ENAFAC(2)<>1:# Query
      If find(2,[M:ASW4]QRYPRO)=0
        [M:ASW1]ENAFAC(2)=1 : Affzo [M:ASW1]ENAFAC(2)
        [M:ASW4]STALIN(NOL)=1
      Endif
    Endif
  Endif
Endif
End

Subprog CONTROLE_QRYPRO(LCODREP,LALIAS,LCODPRO,LFLDGRPPRO,LCODCLA,LABRCLA,OK,L_ERR_MSG)
Value Char LCODREP,LALIAS,LCODPRO,LFLDGRPPRO,LCODCLA,LABRCLA
Variable Integer OK
Variable Char L_ERR_MSG

Local Char TABCLA(80)(1..50)
Local Char TABPTR(80)(1..50),GRP(50)
Local Integer NBCLA,ISACTX

OK=1
If instr(1,LFLDGRPPRO,".")=0
  #Collection de dimensionnement non autorisée en query
  L_ERR_MSG=mess(189,143,1)
  OK=0
Else
  Call DECODE_PRO(LFLDGRPPRO,0,"GRP","",LCODREP,LABRCLA,LCODCLA,TABPTR,TABCLA,GRP,ISACTX,NBCLA) From SUBASW
  If (NBCLA>1 & TABCLA(NBCLA)="") or NBCLA=0
    #collection non trouvée
    #Collection de dimensionnement non autorisée en query
    L_ERR_MSG=mess(189,143,1)
    OK=0
  Elsif NBCLA>0
    Filter [ACLAF] Where FLDGRP=[L]GRP & CODCLA=TABCLA(NBCLA) & LNKCLA=""
    Read [ACLAF]ACLAF0 First
    If !fstat & [F:ACLAF]LNKCLA=""
      #Collection de dimensionnement non autorisée en query
      L_ERR_MSG=mess(189,143,1)
      OK=0
    Endif
    Filter [ACLAF]
    If OK
     Filter [ACLAK] Where CODCLA=LCODCLA & REFLNK=[L]GRP
     Read [ACLAK]ACLAK0 First
     If fstat
       #Seules les propriétés de la classe principale et des classes liées 0,1 ou 1,1 peuvent être exposées en query
       L_ERR_MSG=mess(222,143,1)
       OK=0
     Elsif find([F:ACLAK]TYPLNK,1,3)=0
       #Seules les propriétés de la classe principale et des classes liées 0,1 ou 1,1 peuvent être exposées en query
       L_ERR_MSG=mess(222,143,1)
       OK=0
     Endif
     Filter [ACLAK]
    Endif
  Endif
Endif
End

Subprog AS_LOKPRO(VALEUR)
Variable Integer VALEUR
Local Integer OK
Local Integer NOL : NOL=nolign-1
Local Char L_ERR_MSG(250)
If [M:ASW4]FLDGRPPRO(NOL)<>""
  Call CONTROLE_LOKPRO([M:ASW0]CODREP,[M:ASW4]ALIAS(NOL),[M:ASW4]CODPRO(NOL),[M:ASW4]FLDGRPPRO(NOL),[M:ASW1]CODCLA,[M:ASW1]ABRCLA,OK,L_ERR_MSG)
  If !OK
    mkstat=1 : #collection de dimension : pas dans lookup
    VALEUR=1
    [M:ASW4]LOKPRO(NOL)=1
#    [M:ASW4]STALOKPRO(NOL)=2
#    Affzo [M:ASW4]STALOKPRO(NOL)
    If [M:ASW1]ENAFAC(3)<>1:# lookup
      If find(2,[M:ASW4]LOKPRO)=0
        [M:ASW1]ENAFAC(3)=1 : Affzo [M:ASW1]ENAFAC(3)
        [M:ASW4]STALIN(NOL)=1
      Endif
    Endif
  Endif
Endif
End

Subprog CONTROLE_LOKPRO(LCODREP,LALIAS,LCODPRO,LFLDGRPPRO,LCODCLA,LABRCLA,OK,L_ERR_MSG)
Value Char LCODREP,LALIAS,LCODPRO,LFLDGRPPRO,LCODCLA,LABRCLA
Variable Integer OK
Variable Char L_ERR_MSG

Local Char TABCLA(80)(1..50)
Local Char TABPTR(80)(1..50),GRP(50)
Local Integer NBCLA,ISACTX

OK=1
If instr(1,LFLDGRPPRO,".")=0
  #Collection de dimensionnement non autorisée en lookup
  L_ERR_MSG=mess(233,143,1)
  OK=0
Else
  Call DECODE_PRO(LFLDGRPPRO,0,"GRP","",LCODREP,LABRCLA,LCODCLA,TABPTR,TABCLA,GRP,ISACTX,NBCLA) From SUBASW
  If (NBCLA>1 & TABCLA(NBCLA)="") or NBCLA=0
    #collection non trouvée
    #Collection de dimensionnement non autorisée en lookup
    L_ERR_MSG=mess(233,143,1)
    OK=0
  Elsif NBCLA>0
    Filter [ACLAF] Where FLDGRP=[L]GRP & CODCLA=TABCLA(NBCLA) & LNKCLA=""
    Read [ACLAF]ACLAF0 First
    If !fstat & [F:ACLAF]LNKCLA=""
      #Collection de dimensionnement non autorisée en lookup
      L_ERR_MSG=mess(233,143,1)
      OK=0
    Endif
    Filter [ACLAF]
    If OK
     Filter [ACLAK] Where CODCLA=LCODCLA & REFLNK=[L]GRP
     Read [ACLAK]ACLAK0 First
     If fstat
       #Seules les propriétés de la classe principale et des classes liées 0,1 ou 1,1 peuvent être exposées en lookup
       L_ERR_MSG=mess(234,143,1)
       OK=0
     Elsif find([F:ACLAK]TYPLNK,1,3)=0
       #Seules les propriétés de la classe principale et des classes liées 0,1 ou 1,1 peuvent être exposées en lookup
       L_ERR_MSG=mess(234,143,1)
       OK=0
     Endif
     Filter [ACLAK]
    Endif
  Endif
Endif
End

Subprog AM_QRYPRO(VALEUR)
Variable Integer VALEUR
[M:ASW4]STALIN(nolign-1)=1
[M:ASW4]QRYPRO(nolign-1)=VALEUR
If VALEUR=2
  [M:ASW1]ENAFAC(2)=2 : Affzo [M:ASW1]ENAFAC(2)
Elsif VALEUR<>2
#  [M:ASW4]STAQRYPRO(nolign-1)=2
#  Affzo [M:ASW4]STAQRYPRO(nolign-1)
  If find(2,[M:ASW4]QRYPRO)=0 & [M:ASW1]ENAFAC(2)<>1:# Query
    [M:ASW1]ENAFAC(2)=1 : Affzo [M:ASW1]ENAFAC(2)
  Endif
Endif
End

