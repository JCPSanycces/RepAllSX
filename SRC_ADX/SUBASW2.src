## Subprog - internal use only
######################################################################################

# ------------- AM_CODFLD, AM_CODTYP, AVANT_NBRFLD internal use only -------------- #
Subprog L_AM_CODTYP(VALEUR, FLDCUR)
Variable Char    VALEUR()
Value    Char    FLDCUR()
 Local Integer L_EXIST
 Local Integer I,J,K

 Effzo [M:ASW9]10
 Effzo [M:ASW9]15

 # clean LOBTAB if necessary
 Read [ATY]CODTYP=[L]VALEUR
 If [F:ATY]TYPSELSYR<>3 : #Rich media
  Effzo [M:ASW9]LOBTAB(nolign-1)
  Chgstl [M:ASW9]LOBTAB(nolign-1) With ""
  Effzo [M:ASW9]LOBFLD(nolign-1)
  Chgstl [M:ASW9]LOBFLD(nolign-1) With ""
  Effzo [M:ASW9]LOBCNT(nolign-1)
  Chgstl [M:ASW9]LOBCNT(nolign-1) With ""
 Endif

 # initialise FLDCUR , CODTYPCUR
 [M:ASW9]FLDCUR = [L]FLDCUR
 If [M:ASW9]LOBTAB(nolign-1)=""
  [M:ASW9]CODTYPCUR = [L]VALEUR
 Else
  [M:ASW9]CODTYPCUR  = [L]VALEUR + "." + [M:ASW9]LOBTAB(nolign-1)+ "." + [M:ASW9]LOBFLD(nolign-1)
 Endif

 # Check if parameters/keys already loaded for this data type
 For I = 0 To [M:ASW5]NBRPAR-1
  If [M:ASW5]TYPPAR(I)=1 & [M:ASW5]CODFLD(I)=[M:ASW9]FLDCUR & [M:ASW5]CODTYP(I)=[M:ASW9]CODTYPCUR
   L_EXIST = 1 : Break
  Endif
 Next

 If !L_EXIST
  Read [ATY]CODTYP = [L]VALEUR
  If !fstat
   # load parameters related to the data type
   Call L_LOAD_PARAM_ATY(nomap, [M:ASW0]CODREP, [F:ATY]CODTYP, [ASW9]FLDCUR, 1, 1)
   If [ATY]CODCLA<>""
    # load keys related to the data type
    Gosub L_LOAD_KEY
   Endif
   #97530
   J=0
   For I=0 To [M:ASW5]NBRPAR-1
    If [M:ASW5]CODFLD(I)=[M:ASW9]FLDCUR & [M:ASW5]TYPKEY(I)=2 & [M:ASW5]CODTYP(I)=[M:ASW9]CODTYPCUR
     J+=1
     K=I
    Endif
   Next
   If J=1 & [M:ASW5]VALEUR(K)=""
    [M:ASW5]VALEUR(K) = [M:ASW9]FLDGRP(nolign-1)+string$([M:ASW9]FLDGRP(nolign-1)<>"",".")+[M:ASW9]FLDCUR
#    [M:ASW9]VALCLE(0) = [M:ASW5]VALEUR(K)
#    Affzo [M:ASW9]VALCLE(0)
   Endif
   #
  Endif
 Endif
 # refresh [M:ASW9]10 and [M:ASW9]15
 Gosub DISPLAY_PARAM_CODFLD
 If L_HAS_PARAM
  Chgstl [ASW9]CODTYP(nolign-1) With "AMKACT"
 Else
  Chgstl [ASW9]CODTYP(nolign-1) With ""
  Chgstl [ASW9]LOBTAB(nolign-1) With ""
  Chgstl [ASW9]LOBFLD(nolign-1) With ""
  Chgstl [ASW9]LOBCNT(nolign-1) With ""
 Endif
End


# ------------- AM_CODFLD, AM_lobtab, AVANT_NBRFLD internal use only -------------- #
Subprog L_AM_LOBTAB(VALTAB,VALFLD,FLDCUR)
Value    Char    VALTAB()
Value    Char    VALFLD()
Value    Char    FLDCUR()

 Local Integer L_EXIST

 Effzo [M:ASW9]10
 Effzo [M:ASW9]15

 # initialise FLDCUR, CODTYPCUR
 [M:ASW9]FLDCUR = FLDCUR
 If VALTAB=""
  [M:ASW9]CODTYPCUR = [M:ASW9]CODTYP(nolign-1)
 Else
  [M:ASW9]CODTYPCUR  = [M:ASW9]CODTYP(nolign-1) + "." + VALTAB +"." + VALFLD
 Endif

 # Check if parameters/keys already loaded for this data type
 For I = 0 To [M:ASW5]NBRPAR-1
  If [M:ASW5]TYPPAR(I) = 1 and [M:ASW5]CODFLD(I) = [M:ASW9]FLDCUR and [M:ASW5]CODTYP(I)=[M:ASW9]CODTYPCUR
   L_EXIST = 1 : Break
  Endif
 Next

 If !L_EXIST
  Read [ATY]CODTYP = [M:ASW9]CODTYP(nolign-1)
  If !fstat
   # load parameters related to the data type
   Call L_LOAD_PARAM_ATY(nomap, [M:ASW0]CODREP, [F:ATY]CODTYP, [ASW9]FLDCUR, 1, 1)
   If [ATY]CODCLA<>""
    # load keys related to the data type
    Gosub L_LOAD_KEY
   Endif
  Endif
  If [F:ATY]TYPSELSYR=3 & [F:ATY]SUPFLG=2
   Gosub L_LOAD_MEDIA
  Endif
 Endif

 # refresh [M:ASW9]10, [ASW9]15
 Gosub DISPLAY_PARAM_CODFLD
 If L_HAS_PARAM
  Chgstl [ASW9]LOBTAB(nolign-1) With "AMKACT"
  Chgstl [ASW9]LOBFLD(nolign-1) With "AMKACT"
  Chgstl [ASW9]LOBCNT(nolign-1) With "AMKACT"
 Else
  Chgstl [ASW9]CODTYP(nolign-1) With ""
  Chgstl [ASW9]LOBTAB(nolign-1) With ""
  Chgstl [ASW9]LOBCNT(nolign-1) With ""
 Endif
End



######################################################################################
## Etiquette - internal use only
######################################################################################

$L_LOAD_MEDIA
Gosub DEF_TAB_PARLNK From SUBASW_TOOL
If [M:ASW9]LOBTAB(nolign-1)<>""
 Read [ATI]NUMLIG = [M:ASW9]LOBTAB(nolign-1);1
 If !fstat
  Call CHARGE_CLE([F:ATI]CODFIC,[F:ATI]DESCRIPT,nomap,[F:ATY]CODCLA,[M:ASW9]FLDCUR,1,WWCODPAR,WWCODCUR,WWTYPPAR,
& WWFLDCLE,WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,
& WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,WWNBRPARALL) From
& SUBACLA
 Endif
Endif
Call FILL_PARAM_ASW5(1,nomap,[M:ASW0]CODREP,1,[M:ASW9]FLDCUR,"",1,[M:ASW9]CODTYPCUR,WWCODPAR,
& WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,WWISKEY,
& WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,WWPARFIL,WWPARENT,WWVALPAR,WWNBRPARALL
& ) From SUBASW_TOOL
Gosub AFFZO_ASW5 From SUBASW
Return

# -----------   AM_CODTYP/SUBASW.$LIENS internal use only ------------ #
Subprog L_LOAD_PARAM_ATY(DOSSIER, CODREP, CODTYP, FLDCUR, TYPPAR, TYPKEY)
Value Char DOSSIER, CODREP, CODTYP, FLDCUR
Value Integer TYPPAR, TYPKEY

Gosub DEF_TAB_PARLNK From SUBASW_TOOL

# load parameters from ATY

For [ATYR]ATYR0 Where CODTYP=[L]CODTYP & ENARUL=2
 If func AFNC.ACTIV([ATYR]ACTRUL)>0
  For [ATYRP]ATYRP1 Where CODTYP=[ATYR]CODTYP &  TYPRUL=[ATYR]TYPRUL & TRTRUL=[ATYR]TRTRUL  & PRGRUL=[ATYR]PRGRUL
   If !find([ATYRP]PARCOD,"AINSTANCE","APRONAME","AVALUE","AVALCNT","AEXIST","AFORMAT") & !find([ATYRP]PARCOD,[L]WWCODPAR) : # & [ATYRP]PARCLE<>2
    [L]WWCODPAR([L]WWNBRPARALL)     = [ATYRP]PARCOD
    [L]WWNUMPAR([L]WWNBRPARALL)     = [L]WWNBRPARALL+1
    [L]WWTYPKEY([L]WWNBRPARALL)     = [L]TYPKEY
    [L]WWINTITPAR([L]WWNBRPARALL)   = func ASYRFNC.TEXTE([ATYRP]PARTIT)
    [L]WWTYPINTPAR([L]WWNBRPARALL)  = [ATYRP]PARTYP
    [L]WWADRVAL([L]WWNBRPARALL)     = [ATYRP]PARMOD
    [L]WWCODCLAPAR([L]WWNBRPARALL)  = [ATYRP]PARCLA
    [L]WWISKEY([L]WWNBRPARALL)      = [ATYRP]PARCLE
    [L]WWNBRPARALL+=1
   Endif
  Next
 Endif
Next

Call FILL_PARAM_ASW5(1,nomap,[M:ASW0]CODREP,1,[L]FLDCUR,"",[L]TYPPAR,[M:ASW9]CODTYPCUR,WWCODPAR,
& WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,WWISKEY,
& WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,WWPARFIL,WWPARENT,WWVALPAR,WWNBRPARALL) From SUBASW_TOOL
Gosub AFFZO_ASW5 From SUBASW
End

# -----------   L_AM_CODTYP/SUBASW.$LIENS internal use only ------------ #
$L_LOAD_KEY
Gosub DEF_TAB_PARLNK From SUBASW_TOOL
Call CHARGE_CLA_ATI_CLE(nomap,[F:ATY]CODCLA,[M:ASW9]FLDCUR,1,WWCODPAR,WWCODCUR,WWTYPPAR,WWFLDCLE,WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,WWNBRPARALL) From
& SUBACLA
Call FILL_PARAM_ASW5(1,nomap,[M:ASW0]CODREP,1,[M:ASW9]FLDCUR,"",1,[M:ASW9]CODTYPCUR,WWCODPAR,
& WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,WWISKEY,
& WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,WWPARFIL,WWPARENT,WWVALPAR,WWNBRPARALL) From SUBASW_TOOL
Gosub AFFZO_ASW5 From SUBASW
Return
