Subprog AS_LOBTAB(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Read [ATY]CODTYP=[M:ASW9]CODTYP(NOL)
If [F:ATY]TYPSELSYR<>3 : mkstat=1 : End : Endif
If [F:ATY]SUPFLG<>2 : mkstat=1 : End : Endif
End

Subprog AS_LOBFLD(VALEUR)
Variable Char    VALEUR()
If [M:ASW9]LOBTAB(nolign-1)="" : mkstat=1 : End : Endif
End

Subprog C_LOBFLD(VALEUR)
Variable Char    VALEUR()
Local Integer WTYPINT
Gosub SETNOL
Read [ATZ]CODZONE=[M:ASW9]LOBTAB(NOL);VALEUR
If fstat
    GMESSAGE = mess(23,100,1) : # Fiche inexistante
    GERR=1
    mkstat=2
    End
Endif
Read [ATY]CODTYP=[F:ATZ]CODTYP
WTYPINT=[F:ATY]TYPTYP
Read [ATY]CODTYP=[M:ASW9]CODTYP(NOL)
If WTYPINT<>[F:ATY]TYPTYP
    # Le type interne du champ lob choisi n'est pas cohérent avec le type de la propriété
    GMESSAGE = mess(168,143,1)
    GERR=1
    mkstat=2
    End
Endif
End

Subprog AM_LOBFLD(VALEUR)
Variable Char    VALEUR()
Call L_AM_LOBTAB([M:ASW9]LOBTAB(nolign-1),VALEUR,[M:ASW9]CODFLD(nolign-1) )
End


Subprog AS_LOBCNT(VALEUR)
Variable Char    VALEUR()
If [M:ASW9]LOBTAB(nolign-1)="" : mkstat=1 : End : Endif
Gosub SETNOL
Read [ATY]CODTYP=[M:ASW9]CODTYP(NOL)
If [F:ATY]TYPSELSYR<>3 : mkstat=1 : End : Endif
If [F:ATY]SUPFLG<>2 : mkstat=1 : End : Endif
Read [ATYP]ATYP0=[F:ATY]TYPPROSYR
If fstat : mkstat=1 : End : Endif
If [F:ATYP]PREFLG<>2 : mkstat=1 : End : Endif
End

Subprog C_LOBCNT(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Gosub SETNOL
Read [ATZ]CODZONE=[M:ASW9]LOBTAB(NOL);VALEUR
If fstat
    GMESSAGE = mess(23,100,1) : # Fiche inexistante
    GERR=1
    mkstat=2
    End
Endif
If [F:ATZ]CODTYP<>"ATYP"
    # Le "Content type" doit être de type "ATYP"
    GMESSAGE = mess(238,143,1)
    GERR=1
    mkstat=2
    End
Endif
End

Subprog S_LOBCNT(VALEUR)
Variable Char    VALEUR()
 ## Action SELFLDTAB3
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELFLDTAB3"
 PARMSK(1) = [M:ASW9]LOBTAB(nolign-1)
 If filinfo(filpath("FIL","AVIEWFLD","fde",nomap),0)<0
  Local File ATABZON [ATZ]
 Else
  Local File AVIEWFLD [ATZ]
 Endif
 Filter [ATZ] Where CODTYP="ATYP"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELFLDTAB3","LNKSUB","") From GACTION
 Filter [ATZ]
 GACTION = SAVACT
End

$SETNOL
Local Integer NOL
NOL=nolign-1
Return

Subprog AS_NOLIB(VALEUR)
Variable Decimal VALEUR
Read [ATY]CODTYP=[M:ASW9]CODTYP(nolign-1)
If [F:ATY]TYPTYP<>1 or [F:ATY]NOLIB<>0 : mkstat=1 : End : Endif
End

Subprog AS_LONG(VALEUR)
Variable Decimal VALEUR
Read [ATY]CODTYP=[M:ASW9]CODTYP(nolign-1)
If [F:ATY]FORTYP<>"" or [F:ATY]LNGTYP<>0 or find([F:ATY]TYPTYP,8,11,12)
 mkstat=1 : End
Elsif find([F:ATY]TYPTYP,9,10)
 VALEUR=1
 mkstat=2 : End
Endif
End

Subprog C_LONG(VALEUR)
Variable Decimal VALEUR
Local Decimal ENTIER , DECIM
If [M:ASW9]CODTYP(nolign-1)="W" : End : Endif
If VALEUR=0 : mkstat=1 : End : Endif
Read [ATY]CODTYP=[M:ASW9]CODTYP(nolign-1)
ENTIER = int(VALEUR)
DECIM  = 10*(VALEUR-ENTIER)
While DECIM<>int(DECIM)
 DECIM *= 10
Wend
Case [F:ATY]TYPTYP
 When 1  : If DECIM<>0 | ENTIER>50             : mkstat = 1 : Endif : # Libellé
 When 2  : If DECIM<>0 | ENTIER>4              : mkstat = 1 : Endif : # Entier court
 When 3  : If DECIM<>0 | ENTIER>8              : mkstat = 1 : Endif : # Entier long
 When 4  : If DECIM+ENTIER<1 | DECIM+ENTIER>32 : mkstat = 1 : Endif : # DCB
 When 7  : If DECIM<>0 | ENTIER>250            : mkstat = 1 : Endif : # Char
# When 8  : If DECIM<>0 | !find(ENTIER,4,6,8)   : mkstat = 1 : Endif : # Date
# When 9  : If DECIM<>0 | ENTIER>20             : mkstat = 1 : Endif : # Blob
# When 10 : If DECIM<>0 | ENTIER>20             : mkstat = 1 : Endif : # Clob
Endcase
If mkstat
 GMESSAGE = mess(111,123,1) : # Longueur incorrecte
Endif
End

Subprog C_FLDGRP(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
Gosub CHARGE_GRP
If !find(VALEUR,TEX)
 GMESSAGE = VALEUR-":"-mess(144,143,1) : # Collection inexistante.
 mkstat = 2 : End
Elsif instr(1,VALEUR,".")
 #La définition de propriété de représentation sur la collection $1$ n'est pas autorisée
 GMESSAGE = func AFNC.MES1(mess(223,143,1), VALEUR)
 mkstat = 2 : End
Endif
End

Subprog AM_FLDGRP(VALEUR)
Variable Char    VALEUR()
 [M:ASW9]STALIN(nolign-1)=1
End


Subprog S_FLDGRP(VALEUR)
Variable Char    VALEUR()
Call SEL_GRP(VALEUR)
End

Subprog AS_TABCONT(VALEUR)
Variable Char    VALEUR()
Read [ACL_]ACL0 = [M:ASW9]CODCTL(nolign-1)
If fstat or ([F:ACL_]DEPCTL="" & [F:ACL_]DEPCTL2="" & [F:ACL_]DEPCTL3="")
 mkstat = 1 : End
Endif
End


######################################################################################
## ASW2 Oaganisation
######################################################################################
$ASW2
Return

Subprog AVANT_NBRSEC
[M:ASW2]CODSECOLD(nolign-1)=[M:ASW2]CODSEC(nolign-1)
End

Subprog APRES_NBRSEC
#----- Si touche "Echap" ou autre statut "Abandon" -----#
If status=6 | status=7 | status=27 | status=28 | status=1792
  End
#----- Si suppression ligne -----#
Elsif status=65 | status=68 | status=83
  End
Endif
Local Integer I
If [M:ASW2]CODSEC(nolign-1)<>"" & [M:ASW2]CODSECOLD(nolign-1)<>"" & [M:ASW2]CODSEC(nolign-1)<>[M:ASW2]CODSECOLD(nolign-1)
  For I=0 To [M:ASW2]NBRBLC-1
   If [M:ASW2]SECBLC(I)=[M:ASW2]CODSECOLD(nolign-1)
    [M:ASW2]SECBLC(I) = [M:ASW2]CODSEC(nolign-1)
    Affzo [M:ASW2]SECBLC(I)
  Endif
  Next
Endif
End


Subprog C_NBRSEC
Local Integer I
Case status
 When 65  : # suppression param dans tableau
  I=find([M:ASW2]CODSEC(nolign-1),[M:ASW2]SECBLC)
  If I>0
    GMESSAGE = mess(81,143,1)-num$(I)
    mkstat = 2
  Endif
Endcase
End


Subprog C_CODSEC(VALEUR)
Variable Char    VALEUR()
If VALEUR<>[M:ASW2]CODSEC(nolign-1)
  # name covention
  Call PLAGE(VALEUR,1) From CONTOBJ
  If mkstat : End : Endif
Endif
Call UNICITE(VALEUR,[M:ASW2]CODSEC(0..[M:ASW2]NBRSEC-1)) From OBJDIV
If mkstat : End : Endif
End

Subprog C_NIVSEC(VALEUR)
Variable Decimal VALEUR
Call UNICITE(VALEUR,[M:ASW2]NIVSEC(0..[M:ASW2]NBRSEC-1)) From OBJDIV
If mkstat : End : Endif
End


Subprog AS_NIVSEC(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
 If nolign=1
  VALEUR = 10
 Else
  VALEUR = [M]NIVSEC(nolign-2)+10
 Endif
Endif
End

Subprog AS_NIVBLC(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
 If nolign=1
  VALEUR = 10
 Else
  VALEUR = [M]NIVBLC(nolign-2)+10
 Endif
Endif
End


Subprog AVANT_NBRBLC
[M:ASW2]CODBLCOLD(nolign-1)=[M:ASW2]CODBLC(nolign-1)
End

Subprog APRES_NBRBLC
#----- Si touche "Echap" ou autre statut "Abandon" -----#
If status=6 | status=7 | status=27 | status=28 | status=1792
  End
#----- Si suppression ligne -----#
Elsif status=65 | status=68 | status=83
  End
Endif
Local Integer I
If [M:ASW2]CODBLC(nolign-1)<>"" & [M:ASW2]CODBLCOLD(nolign-1)<>"" & [M:ASW2]CODBLC(nolign-1)<>[M:ASW2]CODBLCOLD(nolign-1)
  For I=0 To [M:ASW4]NBRPRO-1
   If [M:ASW4]BLCPRO(I)=[M:ASW2]CODBLCOLD(nolign-1)
    [M:ASW4]BLCPRO(I) = [M:ASW2]CODBLC(nolign-1)
    Affzo [M:ASW4]BLCPRO(I)
   Endif
  Next
Endif
End

Subprog C_NBRBLC
Local Integer I
Case status
 When 65  : # suppression param dans tableau
  I=find([M:ASW2]CODBLC(nolign-1),[M:ASW4]BLCPRO)
  If I>0
    GMESSAGE = mess(86,143,1)-num$(I)
    mkstat = 2
  Endif
Endcase
End

Subprog C_CODBLC(VALEUR)
Variable Char    VALEUR()
If VALEUR<>[M:ASW2]CODBLC(nolign-1)
  # name covention
  Call PLAGE(VALEUR,1) From CONTOBJ
  If mkstat : End : Endif
Endif
Call UNICITE(VALEUR,[M:ASW2]CODBLC(0..[M:ASW2]NBRBLC-1)) From OBJDIV
If mkstat : End : Endif
End


Subprog C_SECBLC(VALEUR)
Variable Char    VALEUR()
If !find(VALEUR,[M:ASW2]CODSEC(0..[M:ASW2]NBRSEC-1))
 GMESSAGE = VALEUR-":"-mess(25,126,1) : # CODE INCORRECT
 mkstat = 2 : End
Endif
End

Subprog AM_SECBLC(VALEUR)
Variable Char    VALEUR()
[M:ASW2]ANIVSEC(nolign-1) = [M:ASW2]NIVSEC(find(VALEUR,[M:ASW2]CODSEC(0..[M:ASW2]NBRSEC-1))-1)
End

Subprog C_NIVBLC(VALEUR)
Variable Decimal VALEUR
For I=0 To [M:ASW2]NBRBLC-1
 If num$(VALEUR)+num$([M:ASW2]ANIVSEC(nolign-1))=num$([M:ASW2]NIVBLC(I))+num$([M:ASW2]ANIVSEC(I)) & I<>nolign-1
  GMESSAGE = mess(24,123,1)-num$(I) : # : CODE DÉJÀ EXISTANT EN LIGNE
  mkstat = 2 : End
 Endif
Next
End

Subprog AS_NBROPT
If [M:ASW2]OPTFLGCLA(nolign-1)=2
  Grizo [M:ASW2]AZOPTLIB(nolign-1)
  Grizo [M:ASW2]OPTACT(nolign-1)
  Grizo [M:ASW2]OPTCND(nolign-1)
  Grizo [M:ASW2]AZOPTERR(nolign-1)
Else
  Actzo [M:ASW2]AZOPTLIB(nolign-1)
  Actzo [M:ASW2]OPTACT(nolign-1)
  Actzo [M:ASW2]OPTCND(nolign-1)
  Actzo [M:ASW2]AZOPTERR(nolign-1)
Endif
End


######################################################################################
# Selection option fo class :
######################################################################################
Subprog S_OPTCOD(VALEUR)
Variable Char    VALEUR()
Gosub DEFSEL3

For [ACLAO] Where CODCLA=[M:ASW1]CODCLA
  NBTEX+= 1
  TEX(NBTEX,1) = [F:ACLAO]OPTCOD
  TEX(NBTEX,2) = func AFNC.TEXTE([F:ACLAO]OPTLIB)
  TEX(NBTEX,3) = [F:ACLAO]OPTACT
Next
 CHOI = 0
 TIT(0) = mess(22,123,1) # Sélection
 TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("ASHW2", "OPTCOD")
 TIT(2) = mess(30,109,1) : # INTITULé
 TIT(3) = func AMK_TOOL.GET_FIELD_LABEL("ASHW2", "OPTACT")
# If NBTEX=1
#  VALEUR = TEX(1,1)
# Elsif NBTEX>0
  Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,60) From GESECRAN
  If status<>7 & CHOI<>0
   VALEUR = TEX(CHOI,1)
   [M:ASW2]OPTFLGCLA(nolign-1)=2
   Affzo [M:ASW2]OPTFLGCLA(nolign-1)
  Endif
# Endif
End

Subprog C_OPTCOD(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If [M:ASW2]OPTFLGCLA(nolign-1)=2
  Read [ACLAO]ACLAO0 = [M:ASW1]CODCLA;VALEUR
  If fstat
   GMESSAGE = func AFNC.MES2(mess(147,143,1), VALEUR, [M:ASW1]CODCLA )
   mkstat = 2 : End
  Endif
Endif
Call UNICITE(VALEUR,[M:ASW2]OPTCOD(0..[M:ASW2]NBROPT-1)) From OBJDIV
If mkstat : End : Endif
End

Subprog AM_OPTCOD(VALEUR)
Variable Char    VALEUR()
If [M:ASW2]OPTFLGCLA(nolign-1)=2
  Read [ACLAO]ACLAO0 = [M:ASW1]CODCLA;VALEUR
  If !fstat
     [M:ASW2]=[F:ACLAO]
     [M:ASW2]AZOPTLIB(nolign-1) = func AFNC.TEXTE([F:ACLAO]OPTLIB)
     [M:ASW2]AZOPTERR(nolign-1) = func AFNC.TEXTE([F:ACLAO]OPTERR)
      Affzo [M:ASW2]AZOPTLIB(nolign-1)
      Affzo [M:ASW2]OPTACT(nolign-1)
      Affzo [M:ASW2]OPTCND(nolign-1)
      Affzo [M:ASW2]AZOPTERR(nolign-1)
      #
      Grizo [M:ASW2]AZOPTLIB(nolign-1)
      Grizo [M:ASW2]OPTACT(nolign-1)
      Grizo [M:ASW2]OPTCND(nolign-1)
      Grizo [M:ASW2]AZOPTERR(nolign-1)
  Endif
Else
  Actzo [M:ASW2]AZOPTLIB(nolign-1)
  Actzo [M:ASW2]OPTACT(nolign-1)
  Actzo [M:ASW2]OPTCND(nolign-1)
  Actzo [M:ASW2]AZOPTERR(nolign-1)
Endif
End

Subprog C_OPTOBY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Call UNICITE(VALEUR,[M:ASW2]OPTOBY(0..[M:ASW2]NBROPT-1)) From OBJDIV
  If mkstat : End : Endif
  If [M:ASW2]OPTDEF(nolign-1)=2
     #Un filtre obligatoire ne doit pas être aussi par défaut
     GMESSAGE = mess(205,143,1)
     mkstat = 2 : End
  Endif
Endif
End

Subprog C_OPTDEF(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Call UNICITE(VALEUR,[M:ASW2]OPTDEF(0..[M:ASW2]NBROPT-1)) From OBJDIV
  If mkstat : End : Endif
  If [M:ASW2]OPTOBY(nolign-1)=2
     #Un filtre obligatoire ne doit pas être aussi par défaut
     GMESSAGE = mess(205,143,1)
     mkstat = 2 : End
  Endif
Endif
End

Subprog C_OPTCND(VALEUR)
Variable Char    VALEUR()
If func CONTROL_SDATA(VALEUR,GMESSAGE)=0
 mkstat = 2 : End
Endif
End

Subprog C_AZOPTERR(VALEUR)
Variable Char    VALEUR()
End

Funprog CONTROL_SDATA(VALEUR,MESSAGE)
Value Char VALEUR
Variable Char MESSAGE
Local Char TAB(20)(1..)
Local Char CHP(20)(1..)
Local Clbfile WVALEUR
Local Integer OK : OK=1

If VALEUR ="" : End OK : Endif

Onerrgo ERRSDATA
WVALEUR = toSData(TAB,CHP,VALEUR)
#If OK & len(WVALEUR)>250
# MESSAGE = mess(37,124,1)+"\"+mess(62,123,1)
# MESSAGE += "\"+VALEUR
# OK=0
#Endif
Onerrgo
End OK

$ERRSDATA
If errn
 If errm<>""
  MESSAGE = mess(37,124,1)+"\"+errm-errmes$(errn)
 Else
  MESSAGE = mess(37,124,1)+"\"+errmes$(errn)
 Endif
Else
 MESSAGE = mess(37,124,1)
Endif
MESSAGE += "\"+VALEUR
WVALEUR=""
OK=0
Resume


######################################################################################
## ASW4 Propriete exposé
######################################################################################
$ASW4
Return

Subprog AS_NBRPRO
#109787
#Chgstl [M:ASW4]ALIAS With ""
#Chgstl [M:ASW4]ALIAS (nolign-1) With "AMKCUR"
Chgstl [M:ASW4]NBRPRO With ""
Chgstl [M:ASW4]NBRPRO(nolign-1) With "AMKCUR"
[M:ASW4]STALIN(nolign-1)=0
End

Subprog C_NBRPRO
Case status
 When 65  : # suppression lien dans tableaux
  #Controls
  If [M:ASW4]CODPRO(nolign-1)<>""
    Gosub SUPP_LNK_CODPRO
    If mkstat : End : Endif
  Endif
Endcase
End

$SUPP_LNK_CODPRO
Local Integer MES_OK
Local Integer I,J
  I=0 : J=0
  If nolign>1
    I=find([M:ASW4]CODPRO(nolign-1),[M:ASW4]CODPRO(0..nolign-2))
  Endif
  If nolign<[M:ASW4]NBRPRO
    J=find([M:ASW4]CODPRO(nolign-1),[M:ASW4]CODPRO(nolign..[M:ASW4]NBRPRO-1))
  Endif
  If I+J=0
    For I=0 To [M:ASW6]NBRLNK-1
      If [M:ASW6]AFFLNK(I)=1 & [M:ASW6]FLGSTDLNK(I)<>2 & [M:ASW6]ANCLNK(I)=[M:ASW4]CODPRO(nolign-1)
       MES_OK=1
       Call AVERTIR(mess(199,143,1)+"\\"+[M:ASW4]CODPRO(nolign-1)+"\\"+mess(205,100,1),MES_OK) From GESECRAN
       If MES_OK<>2
         mkstat=2
       Endif
       Break
      Endif
    Next I
    If mkstat : Return : Endif
    For I=0 To [M:ASW6]NBRLNK-1
      If [M:ASW6]AFFLNK(I)=1 & [M:ASW6]ANCLNK(I)=[M:ASW4]CODPRO(nolign-1)
        # remove the parameters/keys
        Call REMOVE_PARAM_ASW5([M:ASW6]AFFLNK(I),[M:ASW6]ANCLNK(I),[M:ASW6]CODLNK(I),3) From SUBASW_TOOL
        Dela I,1 [M:ASW6]NBRLNK
        [M:ASW6]NBRLNK -=1
        I-=1
      Endif
    Next I
    Effzo [M:ASW7]10
    Effzo [M:ASW7]15
    Gosub AFFZO_ASW5 From SUBASW
    Call DISPLAY_LNK_ASW7(1,[M:ASW7]TYPANCLNK, [M:ASW7]CODANCLNK, [M:ASW7]OPTSTDLNK,[M:ASW7]OPTINVLNK) From SUBASW_TOOL
  Endif
Return

Subprog APRES_NBRPRO
#----- Si touche "Echap" ou autre statut "Abandon" -----#
If status=6 | status=7 | status=27 | status=28 | status=1792
  End
#----- Si suppression ligne -----#
Elsif status=65 | status=68 | status=83
  End
Endif
Case status
  When 73, 82 # insert/create a new line
    Gosub MAJ_STDLNK_FCT_2 From SUBASW
    [M]BLCPRO(nolign-1) =[M]BLCPRO(nolign-1)
  When Default
    If [M:ASW4]STALIN(nolign-1)<>0
      Gosub MAJ_STDLNK_FCT_2 From SUBASW
    Endif
Endcase
End

Subprog D_BLCPRO(VALEUR)
Variable Char    VALEUR()
If nolign-1=0
 VALEUR = [M]CODBLC(0)
Else
VALEUR = [M]BLCPRO(nolign-2)
Endif
End

Subprog C_ALIAS(VALEUR)
Variable Char    VALEUR()
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1) : End
Endif
Call UNICITE(VALEUR,[M:ASW4]ALIAS(0..[M:ASW4]NBRPRO-1)) From OBJDIV
If mkstat : End : Endif
End

Subprog S_ALIAS(VALEUR)
Variable Char    VALEUR()
#If [M:ASW4]CODPRO(nolign-1)<>""
# VALEUR = toupper([M:ASW4]CODPRO(nolign-1))
#Endif
Local Integer WINT
Call SEL_PRO(VALEUR,[M:ASW4]CODPRO(nolign-1),WINT,[M:ASW4]AZINTPRO(nolign-1))
[M:ASW4]INTPRO(nolign-1) = WINT
Affzo [M:ASW4]INTPRO(nolign-1)
Affzo [M:ASW4]CODPRO(nolign-1)
Affzo [M:ASW4]AZINTPRO(nolign-1)
#
Call CONTROLE_CODPRO(1,[M:ASW4]CODPRO(nolign-1),nolign-1,0,0,GMESSAGE ) From SUBASW2
[M:ASW4]STALIN(nolign-1)=1
# refresh "Collection"
[M:ASW4]FLDGRPPRO(nolign-1) =  func SUBASW_TOOL.GET_COL_FROM_PRO_PATH_SCREEN([M:ASW4]CODPRO(nolign-1),1)
Affzo [M:ASW4]FLDGRPPRO(nolign-1)
#94200
[M:ASW4]ACTPRO(nolign-1) =  func SUBASW_TOOL.GET_ACV_FROM_PRO_PATH_SCREEN([M:ASW4]CODPRO(nolign-1))
Affzo [M:ASW4]ACTPRO(nolign-1)
End

Subprog C_CODPRO(VALEUR)
Variable Char    VALEUR()
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1) : End
Endif
VALEUR = toupper(VALEUR)

#90233
Call UNICITE(VALEUR,[M:ASW4]CODPRO(0..[M:ASW4]NBRPRO-1)) From OBJDIV
If mkstat : End : Endif

Call CONTROLE_CODPRO(1,VALEUR,nolign-1,0,0,GMESSAGE )
If GMESSAGE<>"" : GERR=1 : mkstat =2 : End : Endif
End

Subprog CONTROLE_CODPRO(C_CODPRO,LCODPRO,LNOL,BINTPRO,BINTSHTPRO,LMESSERR )
Value Integer C_CODPRO
Value Char LCODPRO
Value Integer LNOL
Value Integer BINTPRO
Value Integer BINTSHTPRO
Variable Char LMESSERR

Local Integer J
###
If C_CODPRO
  Local Char    TABCLA(GLONACLA)(1..50),TABPTR(GLONAVB)(1..50),OBJ(50)
  Local Integer NBCLA,ISACTX
  Call DECODE_PRO(LCODPRO,2,"PRO",nomap,[M:ASW0]CODREP,[M:ASW1]ABRCLA,[M:ASW1]CODCLA,TABPTR,TABCLA,OBJ,ISACTX,NBCLA) From SUBASW
  [M:ASW4]CODPROISACTX(LNOL)=ISACTX
  [M:ASW4]CODPROOBJ(LNOL)=OBJ
  [M:ASW4]CODPRONBCLA(LNOL)=NBCLA
  If NBCLA>0
    [M:ASW4]CODPROCLA(LNOL)=TABCLA(NBCLA)
  Else
    [M:ASW4]CODPROCLA(LNOL)=""
  Endif
Endif
If [M:ASW4]CODPRONBCLA(LNOL)>0
 If [M:ASW4]CODPROCLA(LNOL)=""
  If ![M:ASW4]CODPROISACTX(LNOL)
   J=find([M:ASW4]CODPROOBJ(LNOL),[M:ASW9]CODFLD)
   If J>0
    [M:ASW4]CODPROATY(LNOL) = [M:ASW9]CODTYP(J-1)
    [M:ASW4]CODPROTYP(LNOL) = func ATY_TOOL.GET_INTERNAL_TYP_LM30([M:ASW9]CODTYP(J-1))
    If BINTPRO
     [M:ASW4]INTPRO(LNOL)   = [M:ASW9]INTFLD(J-1)
     [M:ASW4]AZINTPRO(LNOL) = [M:ASW9]AZINTFLD(J-1)
     Affzo [M:ASW4]AZINTPRO(LNOL)
    Endif
    If BINTSHTPRO
     [M:ASW4]INTSHTPRO(LNOL)   = [M:ASW9]INTSHTFLD(J-1)
     [M:ASW4]AZINTSHTPRO(LNOL) = [M:ASW9]AZINTSHTFLD(J-1)
     Affzo [M:ASW4]AZINTSHTPRO(LNOL)
    Endif
   Elsif fstat
    LMESSERR = LCODPRO-":"-mess(36,140,1)  : End : #"Propriété non définie dans la représentation courante"
   Endif
  Else
   Read [F:ACTX]ACTX0 = [M:ASW4]CODPROOBJ(LNOL)
   If !fstat
    [M:ASW4]CODPROATY(LNOL) = [ACTX]CODTYP
    [M:ASW4]CODPROTYP(LNOL) = func ATY_TOOL.GET_INTERNAL_TYP_LM30([ACTX]CODTYP)
    If BINTPRO
      [M:ASW4]INTPRO(LNOL)   = [ACTX]INTIT
      Call TEXTE([ACTX]INTIT,[M:ASW4]AZINTPRO(LNOL)) From OBJDIV
      Affzo [M:ASW4]AZINTPRO(LNOL)
    Endif
   Elsif fstat
    LMESSERR = mess(289,139,1)  : End # Code contexte inexistant
   Endif
  Endif
 Else
  Read [ACLAF]ACLAF0 = [M:ASW4]CODPROCLA(LNOL);[M:ASW4]CODPROOBJ(LNOL)
  If !fstat
   If [F:ACLAF]CODTYP=""
     LMESSERR = mess(35,140,1)-LCODPRO-":"-mess(56,140,1)  : End : # propriété ou collection inexistante
   Endif
   [M:ASW4]CODPROATY(LNOL) = [F:ACLAF]CODTYP
   [M:ASW4]CODPROTYP(LNOL) = func ATY_TOOL.GET_INTERNAL_TYP_LM30([F:ACLAF]CODTYP)
   If BINTPRO
    [M:ASW4]INTPRO(LNOL)   = [F:ACLAF]INTFLD
    Call TEXTE([F:ACLAF]INTFLD,[M:ASW4]AZINTPRO(LNOL)) From OBJDIV
    Affzo [M:ASW4]AZINTPRO(LNOL)
   Endif
   If BINTSHTPRO
    [M:ASW4]INTSHTPRO(LNOL)   = [F:ACLAF]INTSHTFLD
    Call TEXTE([F:ACLAF]INTSHTFLD,[M:ASW4]AZINTSHTPRO(LNOL)) From OBJDIV
    Affzo [M:ASW4]AZINTSHTPRO(LNOL)
   Endif
  Endif
 Endif
Else
 LMESSERR = mess(35,140,1)-LCODPRO-":"-mess(56,140,1)  : End : # propriété ou collection inexistante
Endif
End

Subprog AM_CODPRO(VALEUR)
Variable Char    VALEUR()
 Call CONTROLE_CODPRO(0,VALEUR,nolign-1,1,1,GMESSAGE )
 If GMESSAGE<>"" : GERR=1 : mkstat =2 : End : Endif
 Gosub SUPP_LNK_CODPRO
 If mkstat : End : Endif
 [M:ASW4]STALIN(nolign-1)=1
 # refresh "Collection"
 [M:ASW4]FLDGRPPRO(nolign-1) =  func SUBASW_TOOL.GET_COL_FROM_PRO_PATH_SCREEN(VALEUR,1)
 Affzo [M:ASW4]FLDGRPPRO(nolign-1)
End

Subprog S_CODPRO(VALEUR)
Variable Char    VALEUR()
Local Integer WINT
Local Char WVAL(250),WVAL2(250),WVAL3(250)
WVAL2 = VALEUR
Call SEL_PRO(WVAL,WVAL2,WINT,WVAL3)
[M:ASW4]INTPRO(nolign-1) = WINT
VALEUR = WVAL2
End

Subprog AS_AZINTPRO(VALEUR)
Variable Char    VALEUR()
Local Char MESSERR(250)
If VALEUR=""
  Call CONTROLE_CODPRO(0,[M:ASW4]CODPRO(nolign-1),nolign-1,1,0,MESSERR )
  VALEUR=[M:ASW4]AZINTPRO(nolign-1)
  [M:ASW4]STALIN(nolign-1)=1
Endif
End

Subprog AM_AZINTPRO(VALEUR)
Variable Char    VALEUR()
  [M:ASW4]STALIN(nolign-1)=1
End

Subprog AS_AZINTSHTPRO(VALEUR)
Variable Char    VALEUR()
Local Char MESSERR(250)
If VALEUR=""
  Call CONTROLE_CODPRO(0,[M:ASW4]CODPRO(nolign-1),nolign-1,0,1,MESSERR )
  VALEUR=[M:ASW4]AZINTSHTPRO(nolign-1)
Endif
End

Subprog AS_UOMPRO(VALEUR)
Variable Char    VALEUR()
If find([M:ASW4]CODPROTYP(nolign-1),2,3,4,5,6)=0
 mkstat=1 : End
Endif
End

Subprog C_UOMPRO(VALEUR)
Variable Char    VALEUR()
Local Integer I
If VALEUR<>""
 VALEUR=toupper(VALEUR)
 I=find(VALEUR,[M:ASW4]CODPRO)
 If I>0
  If func SUBASW.IS_ATY_UNIT([M:ASW4]CODPROATY(I-1))=0
   #La propriété "$1$" ne correspond pas à une unité
   GMESSAGE=func AFNC.MES1(mess(241,143,1), VALEUR)
  Elsif ([M:ASW4]QRYPRO(nolign-1)=2 & [M:ASW4]QRYPRO(I-1)<>2)
&     | ([M:ASW4]DETPRO(nolign-1)=2 & [M:ASW4]DETPRO(I-1)<>2)
&     | ([M:ASW4]EDIPRO(nolign-1)=2 & [M:ASW4]EDIPRO(I-1)<>2)
&     | ([M:ASW4]LOKPRO(nolign-1)=2 & [M:ASW4]LOKPRO(I-1)<>2)
&     | ([M:ASW4]SUMPRO(nolign-1)=2 & [M:ASW4]SUMPRO(I-1)<>2)
   #La propriété unité doit être présente sur les mêmes facettes
   GMESSAGE=mess(243,143,1)
  Endif
 Else
  #Veuillez indiquer une propriété exposée
  GMESSAGE=VALEUR-":"-mess(170,143,1)
 Endif
 If GMESSAGE<>"" : GERR=1 : mkstat =2 : End : Endif
Endif
End

Subprog S_UOMPRO(VALEUR)
Variable Char    VALEUR()
 Call SEL_EXPRO_ASW4(VALEUR,1) From SUBASW_TOOL
End

Subprog AS_ORDPRO(VALEUR)
Variable Decimal VALEUR
If VALEUR<>0 : End : Endif
If nolign=1
  VALEUR = 10
Elsif nolign>=2
 VALEUR = [M:ASW4]ORDPRO(nolign-2)+10
Endif
End

