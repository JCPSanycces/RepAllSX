If fstat or (!fstat and [F:ACLA]TYPCLA<>2)
 mkstat = 1 : End
Endif
End

Subprog C_CODIND(VALEUR)
Variable Char    VALEUR()
End

Subprog AM_CODIND(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read [ATI]CODIND=[M]TABREF;VALEUR
 If !fstat
  [M:ASW2]ADESIND=[ATI]DESCRIPT
  Affzo [M:ASW2]ADESIND
  Grizo [M]DESCRIPT
 Endif
Else
 Raz  [M]DESCRIPT,[M]ADESIND
 Actzo [M]DESCRIPT
Endif
End

Subprog AS_DESCRIPT(VALEUR)
Variable Char    VALEUR()
Read [F:ACLA]ACLA0 = [M:ASW1]CODCLA
If fstat or (!fstat and [F:ACLA]TYPCLA<>2)
 mkstat = 1 : End
Endif
If [M]CODIND<>"" :  mkstat=1  : Endif
End

Subprog C_DESCRIPT(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 VALEUR=toupper(VALEUR)
 Local Integer ASTATUS
 Local Char MESSA(250)
 [L]ASTATUS = func CONTROL_INDEX(VALEUR,[M]TABREF,nomap,MESSA)
 If [L]ASTATUS>= [V]CST_AERROR
  GMESSAGE = MESSA
  mkstat=1 : End
 Endif
Endif
End

Subprog AM_DESCRIPT(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Grizo [M]CODIND,ADESIND
Else
 Actzo [M]CODIND,ADESIND
Endif
End


Funprog CONTROL_INDEX(INDEX,TABREF,AFOLDER,MESSA)
Variable Char    INDEX()
Value    Char    TABREF,AFOLDER
Variable Char    MESSA

Local Integer I , J , K , NB , ERR
Local Char    DESCRIPTEUR(120), ZINDEX(120), ZCLE(GLONAVA+5)(1..16) , ERRIND(250) , ZONE(GLONAVA)
Local Decimal LNGZON , LNGCLE , DIME , DIMAX

If filinfo(filpath("FIL","AVIEWTAB","fde",AFOLDER),0)<0
& or filinfo(filpath("FIL","AVIEWFLD","fde",AFOLDER),0)<0
& or filinfo(filpath("FIL","AVIEWIND","fde",AFOLDER),0)<0
 Local File =AFOLDER+".ATABLE" [ATB]
 Local File  =AFOLDER+".ATABZON" [ATZ]
 Local File  =AFOLDER+".ATABIND" [ATI]
Else
 Local File  =AFOLDER+".AVIEWTAB" [ATB]
 Local File  =AFOLDER+".AVIEWFLD" [ATZ]
 Local File  =AFOLDER+".AVIEWIND" [ATI]
Endif

Local File =AFOLDER+".ATYPE" [ATY]

ERR = [V]CST_AOK

Raz ERR, NB

If left$(INDEX,1)="+" or left$(INDEX,1)="-" : # to autoise + or - in first position
 DESCRIPTEUR = right$(INDEX,2)
Else
 DESCRIPTEUR = INDEX
Endif

LNGCLE = 1
While DESCRIPTEUR<>""
 ERR = 0
 NB += 1
 If NB>dim(ZCLE) : Break : Endif
 I = instr(1,DESCRIPTEUR,"+")
 J = instr(1,DESCRIPTEUR,"-")
 If I & J
  I = min(I,J)
 Elsif J & !I
  I = J
 Endif
 If I
  ZINDEX = left$(DESCRIPTEUR,I-1)
  # CC    14/02/2013   ----   Pour autoriser des index avec - sur la première colonne
  If J=1 and ZINDEX=""
    I = instr(2,DESCRIPTEUR,"+")
    J = instr(2,DESCRIPTEUR,"-")
    If I<>0 or J<>0
      ZINDEX=mid$(DESCRIPTEUR,2,max(I,J)-1)
    Else
      ZINDEX=right$(DESCRIPTEUR,2)
      DESCRIPTEUR=""
    Endif
    I=J
  Endif
  DESCRIPTEUR = right$(DESCRIPTEUR,I+1)
 Else
  ZINDEX = DESCRIPTEUR
  DESCRIPTEUR = ""
 Endif
 If ZINDEX<>""
  I = instr(1,ZINDEX,"(")
  If I
   ZONE = left$(ZINDEX,I-1)
   DIME = val(right$(ZINDEX,I+1))+1
  Else
   ZONE = ZINDEX
   DIME = 1
  Endif
 Endif
 ZCLE(NB) = ZONE
 If TABREF<>""
  Read [F:ATZ]CODZONE=TABREF;ZONE
  If fstat
   MESSA = mess(10,176,1)-INDEX+"\"+ZONE-mess(11,176,1)
   # Index/Zone inexistante
   ERR = [V]CST_AERROR : Break
  Elsif find([F:ATZ]CODTYP,"AXX","AX1","AX2","AX3","AUUID")
   MESSA = mess(10,176,1)-INDEX+"\"+ZINDEX-mess(277,123,1)
   # Index/Ce type de champ est interdit dans les index
   ERR = [V]CST_AERROR : Break
  Else
   DIMAX = [F:ATZ]DIME
   If [F:ATZ]CODACT<>""
    Read [ACV]CODACT = [F:ATZ]CODACT
    If fstat or [F:ACV]FLACT<>2
     ERRIND -= ZINDEX
     ERR =  [V]CST_AWARNING
    Else
     If [F:ACV]DIME<>0
      #DIMAX = [F:ACV]DIME
     Endif
    Endif
   Endif
   If DIMAX>1 or DIME>1
    # Index/Zone dimensionnée
    MESSA = mess(10,176,1)-INDEX+"\"+ZINDEX-":"-mess(105,123,1)
    ERR =  [V]CST_AERROR : Break
   Endif
   If !ERR
    LNGCLE += 2
    Read [ATY]CODTYP=[F:ATZ]CODTYP
    Case [F:ATY]TYPTYP
     When 9,10
      MESSA = mess(10,176,1)-INDEX+"\"+ZINDEX-mess(277,123,1)
      # Index/Ce type de champ est interdit dans les index
      ERR =  [V]CST_AERROR : Break
    Endcase
   Endif
  Endif
 Endif
Wend

If ERR =  [V]CST_AERROR : End ERR : Endif

If  NB>dim(ZCLE)
 MESSA = INDEX-":"-mess(29,176,1) : # Trop de composantes de clé (maximum #)
 K = instr(1,MESSA,"#")
 If K : MESSA = left$(MESSA,K-1)+num$(dim(ZCLE))+right$(MESSA,K+1) : Endif
 ERR =  [V]CST_AERROR
Elsif NB=0
 MESSA = INDEX-":"-mess(158,133,1) : # Aucune zones actives sur cet index
 ERR =  [V]CST_AERROR
Elsif ERRIND<>""
 # Index...Zone avec un code activité inactif
 MESSA = mess(10,176,1)-INDEX+"\"+ERRIND-mess(22,176,1)
 ERR =  [V]CST_AWARNING
Endif
End ERR


