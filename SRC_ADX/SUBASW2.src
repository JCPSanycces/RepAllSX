Local Integer I
For I=nolign-1 To [M:ASW4]NBRPRO-1
 If [M:ASW4]QRYPRO(I)<>1
  [M:ASW4]QRYPRO(I)=1 :  Affzo [M:ASW4]QRYPRO(I)
 Endif
Next I
VALEUR=[M:ASW4]QRYPRO(nolign-1)
[M:ASW4]STALIN(nolign-1)=1
If find(2,[M:ASW4]QRYPRO)=0 :# Query
 [M:ASW1]ENAFAC(2)=1 : Affzo [M:ASW1]ENAFAC(2)
Else
 [M:ASW1]ENAFAC(2)=2 : Affzo [M:ASW1]ENAFAC(2)
Endif
End

