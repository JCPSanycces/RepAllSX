#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################
# Sous-pro pour pivot de type : conversion d'unites
#                             cf AML 2240 : 34
###################################################
# FQ 64773 GA 05/2010 préfixe des noms de variables TCOWPIV devient WK
######################################################################
$OUVTAB_TCO
If !clalev([F:AXX]) Local File ATEXTRA [AXX] Endif
If !clalev([F:TUN]) Local File TABUNIT [TUN] Endif
If !clalev([F:TCO]) Local File TABCOEFF [TCO] Endif
Return

######################################################################
Subprog TRT_TCO(ID,CLETRT,PITTCO,P_CRITERE,OK)
Value Char ID()
Value Char CLETRT () 
Value Char PITTCO () 
Value Char P_CRITERE() 
Variable Integer OK

If PITTCO ="" : Return : Endif

Local Integer SAVADXIUM : SAVADXIUM=adxium
Local Char    SAVADXIFS : SAVADXIFS=adxifs
Local Char    SAVADXIRS : SAVADXIRS=adxirs
adxium = GUTF8
adxifs = ''
adxirs = chr$(13)+chr$(10)
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs

Gosub OUVTAB_TCO
Gosub OUVREPIVOT From CONNECTFCT


Local Integer WPRETCO : Raz WPRETCO
Local Integer WNBTCO : Raz WNBTCO 
Local Char    OPTTCO(GDIMFIC)
OPTTCO = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pittco")
Local Integer WKNBZON        : Raz WKNBZON
Local Char    WKNORECMES (50): Raz WKNORECMES 
Local Integer WKHEATYP       : Raz WKHEATYP 
Local Char    WKHEADMES (250): Raz WKHEADMES 

Call READPIT(PITTCO,WKNBZON,WKNORECMES,WKHEATYP ,WKHEADMES ) From CONNECTFCT
Local Char    WKTABZON(GLONATB+GLONAVA+2)(1..WKNBZON) : Raz WKTABZON
Local Char    WKTABABR(GLONABR)(1..WKNBZON) : Raz WKTABABR
Local Char    WKZON(GLONAVA)(1..WKNBZON) : Raz WKTABZON
Local Char    WKFRM(150)(1..WKNBZON) : Raz WKFRM
Local Integer WKWRK(1..WKNBZON) : Raz WKWRK
Local Char    WKVAL(255)(1..WKNBZON) : Raz WKVAL
Local Char    WKVALFIC(GLONAVA)(1..WKNBZON) : Raz WKVALFIC
Call LOADPIVZON(PITTCO,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK) From CONNECTFCT
Call WRPIVOT_HEAD(PITTCO,WKNBZON,WKTABZON,WKTABABR,WKZON,WKWRK,WKHEATYP,WKHEADMES,WPRETCO,OPTTCO) From CONNECTFCT

#######
For [TCO] Where evalue(P_CRITERE)
    Gosub WR_TCO
Next
#######

Call WRPIVOT_END(PITTCO ,WNBTCO ,WKNORECMES ,WPRETCO ,OPTTCO) From CONNECTFCT
adxium = SAVADXIUM
adxifs = SAVADXIFS
adxirs = SAVADXIRS
End

######################################################################
$WR_TCO
    ################################
    # fichiers TCO
    ################################
    #     Ouverture du fichier OPTTCO en écriture
    If WPRETCO = 0
      Openo OPTTCO,0 Using [FPIV]
      WPRETCO = 1
    Else
      Openo OPTTCO Using [FPIV]
    Endif
    
    WNBTCO += 1
    Call RAZVALPIVOT(PITTCO,WKNBZON,WKVAL,WKVALFIC) From CONNECTFCT
    Call EVALPIVOT(PITTCO,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    Call WRPIVOT(WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    #     fermeture du fichier
    Openo Using [FPIV]
Return

######################################################################
