#<AdxTL>@(#)0.0.0.0 $Revision$
## Called from the Action: CCMIMPBAT (Create Impact Analysis via Batch Server process) ...

$ACTION

  Case ACTION
    When "EXEC"        : Gosub EXEC_CREATE_IMPACT_ANALYSIS
    When Default
  Endcase

Return

$EXEC_CREATE_IMPACT_ANALYSIS

  Local Char CHANGE_REQUEST_ID(20)
  Local Integer TRANSACTION
  Local Integer LOCAL_STATUS

  CHANGE_REQUEST_ID = [M:CCMB]CRID
  TRANSACTION = [M:CCMB]TRANSACTION

  Case TRANSACTION
    When 0 :
      Local Instance CHGREQ Using C_CCMCHGREQ
      CHGREQ = NewInstance C_CCMCHGREQ AllocGroup null
      LOCAL_STATUS = fmet CHGREQ.AREAD(CHANGE_REQUEST_ID)
      LOCAL_STATUS = fmet CHGREQ.CREATE_IMPACT_ANALYSIS()
      FreeGroup CHGREQ

    When 3 :
      Local Instance IMPBOH Using C_CCMIMPBOH
      IMPBOH = NewInstance C_CCMIMPBOH AllocGroup null
      LOCAL_STATUS = fmet IMPBOH.CREATE_IMPACT_BOMS(CHANGE_REQUEST_ID)
      FreeGroup IMPBOH

    When 5 :
      Local Instance IMPFOH Using C_CCMIMPFOH
      IMPFOH = NewInstance C_CCMIMPFOH AllocGroup null
      LOCAL_STATUS = fmet IMPFOH.CREATE_IMPACT_FORECAST(CHANGE_REQUEST_ID)
      FreeGroup IMPFOH

    When 6 :
      Local Instance IMPPRH Using C_CCMIMPPRH
      IMPPRH = NewInstance C_CCMIMPPRH AllocGroup null
      LOCAL_STATUS = fmet IMPPRH.CREATE_PURCHASE_REQUEST(CHANGE_REQUEST_ID)
      FreeGroup IMPPRH

    When 7 :
      Local Instance IMPPOH Using C_CCMIMPPOH
      IMPPOH = NewInstance C_CCMIMPPOH AllocGroup null
      LOCAL_STATUS = fmet IMPPOH.CREATE_PURCHASE_ORDERS(CHANGE_REQUEST_ID)
      FreeGroup IMPPOH

    When 8 :
      Local Instance IMPSQH Using C_CCMIMPSQH
      IMPSQH = NewInstance C_CCMIMPSQH AllocGroup null
      LOCAL_STATUS = fmet IMPSQH.CREATE_SALES_QUOTES(CHANGE_REQUEST_ID)
      FreeGroup IMPSQH

    When 9 :
      Local Instance IMPROH Using C_CCMIMPROH
      IMPROH = NewInstance C_CCMIMPROH AllocGroup null
      LOCAL_STATUS = fmet IMPROH.CREATE_ROUTING(CHANGE_REQUEST_ID)
      FreeGroup IMPROH

    When 10 :
      Local Instance IMPSOH Using C_CCMIMPSOH
      IMPSOH = NewInstance C_CCMIMPSOH AllocGroup null
      LOCAL_STATUS = fmet IMPSOH.CREATE_SALES_ORDERS(CHANGE_REQUEST_ID)
      FreeGroup IMPSOH

    When 11 :
      Local Instance IMPITM Using C_CCMIMPITM
      IMPITM = NewInstance C_CCMIMPITM AllocGroup null
      LOCAL_STATUS = fmet IMPITM.CREATE_IMPACT_STOCK(CHANGE_REQUEST_ID)
      FreeGroup IMPITM

    When 12 :
      Local Instance IMPSCH Using C_CCMIMPSCH
      IMPSCH = NewInstance C_CCMIMPSCH AllocGroup null
      LOCAL_STATUS = fmet IMPSCH.CREATE_SUB_CONTRACT_ORDERS(CHANGE_REQUEST_ID)
      FreeGroup IMPSCH

    When 14 :
      Local Instance IMPMFGH Using C_CCMIMPMFGH
      IMPMFGH = NewInstance C_CCMIMPMFGH AllocGroup null
      LOCAL_STATUS = fmet IMPMFGH.CREATE_WORK_ORDERS(CHANGE_REQUEST_ID)
      FreeGroup IMPMFGH

    When Default
  Endcase

  # Begin a Database Transaction ...
  Local Integer TRANSACTION_PENDING
  Local File CCMCHGREQ [REQ]
  TRANSACTION_PENDING = adxlog
  If (adxlog = 0)
    Trbegin [REQ]
  Endif

  # Impact Analysis 'Created' flag = "Yes" ...
  Update [REQ] Where CRID = CHANGE_REQUEST_ID With
&   IMPACTANAL = 2

  # Commit or Rollback the Database Transaction ...
  If (TRANSACTION_PENDING = 0)
    Commit
  Endif

Return

