#<AdxTL>@(#)8.0.0.0 $Revision$
#---------------------------------------------------------------------------#
#      PURMTOLIB mise à jour des affectations liées aux commandes Achats    #
#---------------------------------------------------------------------------#
# $AVANT_MODFIC_POH    Action  AVANT_MODFIC             de SUBPOHA
# $AVANT_MODFIC_POD    Action  AVANT_MODFIC             de SUBPODA
# $MAJ_MTO_AP_ALL_POH  Actions APRES_CRE, APRES_MOD     de SUBPOHA
# $MAJ_MTO_AP_ALL_POD  Actions APRES_MOD                de SUBPODA
# $SUP_MTO_AV_ALL      Action  AV_ANNULE                de SUBPOHA
# $VERF_ANU            Action  VERF_ANU                 de SUBPOHA
# $MAJ_MTO_POQ         Appel de CREATION_LIGNE_POQ      de TRTACHPOD1
# $SUP_MTO_POQ         Appel de SUPP/SOLDE_LIGNE_POQ    de TRTACHPOD1
# Subprog MAJ_MTO      Mise à jour affectations suite à réception
# $CRE_MTO_SO_PO       Création contremarque
#---------------------------------------------------------------------------#
# FQ 73203 GA 04/2011 Problème suite FQ 71360 remplacer [ORD1] par [ORDB]
#############################################################################
$AVANT_MODFIC_POH
Local Integer I

Gosub CHECK_MTO From MTOLINKLIB

# V6 Affectations
# ici il faut supprimer les affectations des:
#     - articles présents dans la commande avant modification et absents du tableau
#     - articles soldés
# car la suppression des affectations s'appuie sur les encours

# les articles commandés supprimés
For [POQ]POQ0 Where POHNUM = [M:POH0]POHNUM
    If !find([F:POQ]POPLIN,[M:POH2]POPLIN(0..[M:POH2]NBLIG - 1)) : Gosub SUP_MTO_AV_POQ : Endif
Next

# les articles commandés soldés
For I = 0 To [M:POH2]NBLIG - 1
    If [M:POH2]LINCLEFLG(I) = 2
        Gosub SUP_MTO_AV_POH2
    Endif
Next I
Return

########################################################################
$AVANT_MODFIC_POD
Local Integer I

Gosub CHECK_MTO From MTOLINKLIB

# V6 Affectations
# ici il faut supprimer les affectations des:
#     - articles présents dans la commande avant modification et absents du tableau
#     - articles soldés
# car la suppression des affectations s'appuie sur les encours

# les articles commandés supprimés
For [POQ]POQ0 Where POHNUM = [M:POD1]POHNUM & POPLIN = [M:POD1]POPLIN
    If !find([F:POQ]POQSEQ,[M:POD1]POQSEQ(0..[M:POD1]NBLIG - 1)) : Gosub SUP_MTO_AV_POQ : Endif
Next

# les articles commandés soldés ou planifiés
For I = 0 To [M:POD1]NBLIG - 1
    If [M:POD1]LINSTA(I) = 3 | [M:POD1]WIPSTA(I)<>1 : # GH 03/07/2012 # If  [M:POD1]LINSTA(I) = 3
        Gosub SUP_MTO_AV_POD1
    Endif
Next I
Return

#########################################################################
$SUP_MTO_AV_POD1
# V6 Règle d'affectation
Local Char    WPTOCOD(GLONPTO)

Gosub CHECK_MTO From MTOLINKLIB

# GH 18/06/12
# raz des affectations
#Raz [M:MLIK]
#If func MTOLINKLIB.IS_DIRECT_ORDER([M:POD1]PRHFCY, 14, [M:POD1]POHNUM, [M:POD1]POPLIN, [M:POD1]POQSEQ(I))
#      [M:MLIK]FMIFLG = 9  # pour forcer la suppression
#Else
#    [M:MLIK]FMIFLG = 1
#Endif
[M:MLIK]MAJCOD    = "Z"
#[M:MLIK]STOFCY    = [M:POD1]PRHFCY : # GH 02/07/2012
[M:MLIK]STOFCY    = [M:POD1]XPRHFCY(I)
[M:MLIK]ITMREF    = [M:POD1]ITMREF
[M:MLIK]RESSTYP   = 14
[M:MLIK]RESSNUM   = [M:POD1]POHNUM
[M:MLIK]RESSLIN   = [M:POD1]POPLIN
[M:MLIK]RESSSEQ   = [M:POD1]POQSEQ(I)
[M:MLIK]FRCPRO    = 2                # pour supprimer les affectations forcées
[M:MLIK]FMIFLG    = 9                # pour supprimer les affectations de contremarque  # GH 18/06/12
[M:MLIK]FEEDBACK  = 1
Call UPDMTOLINK From MTOLINKLIB
If !GOK : GOK = 1 : Endif
Return

#########################################################################
$SUP_MTO_AV_POH2
Gosub CHECK_MTO From MTOLINKLIB

# raz des affectations
Raz [M:MLIK]
# GH 18/06/12
#If func MTOLINKLIB.IS_DIRECT_ORDER([M:POH2]PRHFCY(I), 14, [M:POH0]POHNUM, [M:POH2]POPLIN(I), 1)
#      [M:MLIK]FMIFLG = 9  # pour forcer la suppression
#Else
#    [M:MLIK]FMIFLG = 1
#Endif
[M:MLIK]MAJCOD    = "Z"
[M:MLIK]STOFCY    = [M:POH2]PRHFCY(I)
[M:MLIK]ITMREF    = [M:POH2]ITMREF(I)
[M:MLIK]RESSTYP   = 14
[M:MLIK]RESSNUM   = [M:POH0]POHNUM
[M:MLIK]RESSLIN   = [M:POH2]POPLIN(I)
[M:MLIK]RESSSEQ   = 1
[M:MLIK]FRCPRO    = 2                     # pour supprimer les affectations forcées
[M:MLIK]FMIFLG    = 9                     # pour supprimer les affectations de contremarque  # GH 18/06/12
[M:MLIK]FEEDBACK  = 1

GOK=1
Call UPDMTOLINK From MTOLINKLIB
GOK=1
Return

