#########################################################################
$SUP_MTO_AV_ALL
Local Integer I

Gosub CHECK_MTO From MTOLINKLIB

# boucle sur les articles commandés
For I = 0 To [M:POH2]NBLIG - 1

    # raz des affectations
    Raz [M:MLIK]
    ## GH 18/06/12
    #If func MTOLINKLIB.IS_DIRECT_ORDER([M:POH2]PRHFCY(I), 14, [M:POH0]POHNUM, [M:POH2]POPLIN(I), 1)
    #    [M:MLIK]FMIFLG = 9  # pour forcer la suppression
    #Else
    #    [M:MLIK]FMIFLG = 1
    #Endif
    [M:MLIK]MAJCOD    = "Z"
    [M:MLIK]STOFCY    = [M:POH2]PRHFCY(I)
    [M:MLIK]ITMREF    = [M:POH2]ITMREF(I)
    [M:MLIK]RESSTYP   = 14
    [M:MLIK]RESSNUM   = [M:POH0]POHNUM
    [M:MLIK]RESSLIN   = [M:POH2]POPLIN(I)
    [M:MLIK]RESSSEQ   = 1
    [M:MLIK]FRCPRO    = 2                # pour supprimer les affectations forcées
    [M:MLIK]FMIFLG    = 9                # pour supprimer les affectations de contremarque  # GH 18/06/12
    [M:MLIK]FEEDBACK  = 1

    GOK = 1
    Call UPDMTOLINK From MTOLINKLIB
    GOK = 1
Next I
Return

#########################################################################
$VERF_ANU
Local Integer I, WRET

Gosub CHECK_MTO From MTOLINKLIB

For I = 0 To [M:POH2]NBLIG - 1
    WRET = 0
    Call CHECK_FRCQTY([M:POH2]PRHFCY(I), [M:POH2]ITMREF(I), 14, [M:POH0]POHNUM, [M:POH2]POPLIN(I), 1, 2, WRET) From MTOLINKLIB
    If WRET
        # lecture règle si nécessaire
        If [F:PTO]PTOCOD <> [M:POH2]PTOCOD(I)
            Read [PTO]PTO0=[M:POH2]PTOCOD(I)
            If fstat : Raz [F:PTO] : Endif
        Endif
        If [F:PTO]FRCPRO <> 2
            OK = 1
            # Les affectations forcées pour cet ordre de fabrication vont être supprimées. \Souhaitez vous continuer ?
            Call OUINON(mess(228,190,1),OK) From GESECRAN
            If OK = 1 : OK = 0 : Break : Endif
        Endif
    Endif
Next I
Return

#########################################################################
$MAJ_MTO_AP_ALL_POH
Local Integer I, K, N
Local Libelle WMTOMAJ
Local Decimal WDEMQTY, WFRCQTY

# Issue 78764 - 2011-12-19 by VPO : creation de cde depuis les retours , on est déjà dans une transaction
Local  Libelle  WADXLOG
If !adxlog : WADXLOG=0 : Else  WADXLOG=1 : Endif

I = [M:POH2]NBLIG
If I>0
 Local Char    TITM(GLONITM) (I)
 Local Char    TFCY(GLONFCY) (I)
 Local Char    TELT(1+GLONITM+GLONFCY) (I)
 Local Libelle TFRC(I)
Endif

Gosub CHECK_MTO From MTOLINKLIB

# boucle sur les articles
For I = 0 To [M:POH2]NBLIG - 1

    # GH 29/02/2012 bug 79880
    If ACTION="APRES_CRE" & func MTOLINKLIB.LINK_EXISTS([M:POH2]PRHFCY(I), 14, [M:POH0]POHNUM, [M:POH2]POPLIN(I), 1 ,2)
       Goto NXT_MAJ_MTOI
    Endif

    # si contremarque, on modifie la qté de l'affectation
    If func MTOLINKLIB.IS_DIRECT_ORDER([M:POH2]PRHFCY(I), 14, [M:POH0]POHNUM, [M:POH2]POPLIN(I), 1)
        GOK=0
        If !clalev([F:ORDB]) :  Local File ORDERS   [ORDB] : Endif
        Filter [ORDB] Where ITMREF=[M:POH2]ITMREF(I)
        Read [ORDB]ORD3 = [M:POH2]PRHFCY(I);2;[M:POH2]SOHNUM(I);[M:POH2]SOPLIN(I);[M:POH2]SOQSEQ(I)
        If !fstat
            WDEMQTY = [F:ORDB]RMNEXTQTY - [F:ORDB]ALLQTY
            Read [ORDB]ORD3 = [M:POH2]PRHFCY(I);14;[M:POH0]POHNUM;[M:POH2]POPLIN(I);1
            If !fstat
               WDEMQTY = min([F:ORDB]RMNEXTQTY,WDEMQTY)               # 05.2011
               GOK=1
            Endif
        Endif
        Filter [ORDB]
        If !GOK : GOK=1 : Goto NXT_MAJ_MTOI : Endif

        # Issue 78764 - 2011-12-19 by VPO : creation de cde depuis les retours , on est déjà dans une transaction
        If WADXLOG=0
           Trbegin [MLK]
        Endif
            Raz [M:MLIK]
            [M:MLIK]MAJCOD  = "M"
            [M:MLIK]ITMREF  = [M:POH2]ITMREF(I)
            [M:MLIK]STOFCY  = [M:POH2]PRHFCY(I)
            # la demande
            [M:MLIK]DEMTYP  = 2
            [M:MLIK]DEMNUM  = [M:POH2]SOHNUM(I)
            [M:MLIK]DEMLIN  = [M:POH2]SOPLIN(I)
            [M:MLIK]DEMSEQ  = [M:POH2]SOQSEQ(I)
            [M:MLIK]DWIPTYP = 1
            # la ressource
            [M:MLIK]RESSTYP = 14
            [M:MLIK]RESSNUM = [M:POH0]POHNUM
            [M:MLIK]RESSLIN = [M:POH2]POPLIN(I)
            [M:MLIK]RESSSEQ = 1
            # la quantité
            [M:MLIK]LIKQTY  = WDEMQTY
            [M:MLIK]FRCFLG  = 2
            [M:MLIK]FMIFLG  = 2
            Call UPDMTOLINK             From MTOLINKLIB
            If GOK>0 & ![M:MLIK]RET : # GH 13/10/2015 bug 111344 [M:MLIK]RET<>0 indicates something is wrong
                Call UPDORDERS_FROM_MLIK    From MTOLINKLIB
            Endif

        # Issue 78764 - 2011-12-19 by VPO : creation de cde depuis les retours , on est déjà dans une transaction
        If WADXLOG=0
          If GOK>0 : Commit : Else Rollback : Endif
        Endif

        Goto NXT_MAJ_MTOI
    Endif

    # lecture règle si nécessaire
    If [F:PTO]PTOCOD <> [M:POH2]PTOCOD(I)
        Read [PTO]PTO0=[M:POH2]PTOCOD(I)
        If fstat : Raz [F:PTO] : Endif
    Endif

    WMTOMAJ = ([F:PTO]PTOREAL=2 & [F:PTO]REAL4RESS=2)

    If WMTOMAJ
        K=find([M:POH2]ITMREF(I)-[M:POH2]PRHFCY(I),TELT(0..N-1))-1
        If K<0
           TELT(N)=[M:POH2]ITMREF(I)-[M:POH2]PRHFCY(I)
           TITM(N)=[M:POH2]ITMREF(I)
           TFCY(N)=[M:POH2]PRHFCY(I)
           TFRC(N)=1+([F:PTO]FRCPRO=2)
           K=N : N+=1
        Endif
    Endif

    If !WMTOMAJ | TFRC(K) <> 2
       If !clalev([F:ORDB]) :  Local File ORDERS   [ORDB] : Endif
       Filter [ORDB] Where ITMREF=[M:POH2]ITMREF(I)
       Read [ORDB]ORD3 = [M:POH2]PRHFCY(I);14;[M:POH0]POHNUM;[M:POH2]POPLIN(I);1
       Filter [ORDB]
       If !fstat
         If !WMTOMAJ
            Call GET_FRCQTY([M:POH2]PRHFCY(I), [M:POH2]ITMREF(I), -14, [M:POH0]POHNUM, [M:POH2]POPLIN(I), 1, 2, WDEMQTY) From MTOLINKLIB
         Endif
         Call GET_FRCQTY([M:POH2]PRHFCY(I), [M:POH2]ITMREF(I), 14, [M:POH0]POHNUM, [M:POH2]POPLIN(I), 1, 2, WFRCQTY) From MTOLINKLIB
         If WFRCQTY > [F:ORDB]RMNEXTQTY | (!WMTOMAJ & WDEMQTY > [F:ORDB]RMNEXTQTY) : # ressource sur-affectée
            If WADXLOG=0
                GOK=1
                Trbegin [MLK]
            Endif
                Raz [M:MLIK]
                If !WMTOMAJ
                    [M:MLIK]MAJCOD    = "R"
                    [M:MLIK]PRPTYP    = 1                # annule & remplace
                    [M:MLIK]PRPMOD    = 1                # mode mise à jour
                Else
                    [M:MLIK]MAJCOD    = "Z"
                Endif
                [M:MLIK]STOFCY    = [M:POH2]PRHFCY(I)
                [M:MLIK]ITMREF    = [M:POH2]ITMREF(I)
                [M:MLIK]RESSTYP   = 14
                [M:MLIK]RESSNUM   = [M:POH0]POHNUM
                [M:MLIK]RESSLIN   = [M:POH2]POPLIN(I)
                [M:MLIK]RESSSEQ   = 1
                [M:MLIK]FRCPRO    = 1 + (WMTOMAJ | WFRCQTY > [F:ORDB]RMNEXTQTY)
                [M:MLIK]FEEDBACK  = 1
                Call UPDMTOLINK From MTOLINKLIB
            If WADXLOG=0
                If GOK>0 : Commit : Else Rollback : Endif
            Endif
         Endif
       Endif
    Endif

$NXT_MAJ_MTOI
Next I

For I = 0 To N - 1
    # recalcul complet des affectations de l'article suivant la règle
    If WADXLOG=0
       GOK=1
       Trbegin [MLK]
    Endif
        Raz [M:MLIK]
        [M:MLIK]MAJCOD    = "P"
        [M:MLIK]PRPTYP    = 1                    # annule & remplace
        [M:MLIK]PRPMOD    = 1                    # mode mise à jour
        [M:MLIK]STOFCY    = TFCY(I)
        [M:MLIK]ITMREF    = TITM(I)
        [M:MLIK]FEEDBACK  = 1
        [M:MLIK]FRCPRO    = TFRC(I)
        Call UPDMTOLINK From MTOLINKLIB
    If WADXLOG=0
       If GOK>0 : Commit : Else Rollback : Endif
    Endif
Next I
Return

#########################################################################
$MAJ_MTO_AP_ALL_POD
Local Integer I, K, N
Local Libelle WMTOMAJ
Local Char    WPTOCOD(GLONPTO)

I = [M:POD1]NBLIG
If I>0
 Local Char    TFCY(GLONFCY) (I)
 Local Libelle TFRC(I)
Endif

Gosub CHECK_MTO From MTOLINKLIB

# pas de contremarque
# GH 18/06/12 Une demande de livraison achat/vente ne peut être impliquée que dans des affectations non forcées

# boucle sur les lignes
For I = 0 To [M:POD1]NBLIG - 1

   WPTOCOD = func ITMLIB.GET_PTOCOD([M:POD1]ITMREF,[M:POD1]XPRHFCY(I))
   # lecture règle si nécessaire
   If [F:PTO]PTOCOD <> WPTOCOD
      Read [PTO]PTO0=WPTOCOD
      If fstat : Raz [F:PTO] : Endif
   Endif

   WMTOMAJ = ([F:PTO]PTOREAL=2 & [F:PTO]REAL4RESS=2)

   If WMTOMAJ
       K=find([M:POD1]XPRHFCY(I),TFCY(0..N-1))-1
       If K<0
           TFCY(N)=[M:POD1]XPRHFCY(I)
           TFRC(N)=1+([F:PTO]FRCPRO=2)
           K=N : N+=1
       Endif
   Endif
Next

# recalcul complet des affectations de l'article suivant la règle
For I = 0 To N - 1
  GOK=1
  Trbegin [MLK]
    Raz [M:MLIK]
    [M:MLIK]MAJCOD    = "P"
    [M:MLIK]PRPTYP    = 1                    # annule & remplace
    [M:MLIK]PRPMOD    = 1                    # mode mise à jour
    [M:MLIK]STOFCY    = TFCY(I)
    [M:MLIK]ITMREF    = [M:POD1]ITMREF
    [M:MLIK]FRCPRO    = TFRC(I)
    [M:MLIK]FEEDBACK  = 1
    Call UPDMTOLINK From MTOLINKLIB
  If GOK>0 : Commit : Else Rollback : Endif
Next
Return

#########################################################################
$MAJ_MTO_POQ
Local Decimal WFRCQTY, WDEMQTY
Local Libelle WMTOMAJ
Local Char    WPTOCOD(GLONPTO) : # V6 Règle d'affectation

Gosub CHECK_MTO From MTOLINKLIB

# si contremarque, on modifie la qté de l'affectation
If func MTOLINKLIB.IS_DIRECT_ORDER([F:POQ]PRHFCY, 14, [F:POQ]POHNUM, [F:POQ]POPLIN, [F:POQ]POQSEQ)
    GOK=0
    If !clalev([F:ORDB]) :  Local File ORDERS   [ORDB] : Endif
    Filter [ORDB] Where ITMREF=[F:POQ]ITMREF
    Read [ORDB]ORD3 = [F:POQ]PRHFCY;2;[F:POQ]SOHNUM;[F:POQ]SOPLIN;[F:POQ]SOQSEQ
    If !fstat
        WDEMQTY = [F:ORDB]RMNEXTQTY - [F:ORDB]ALLQTY
        Read [ORDB]ORD3 = [F:POQ]PRHFCY;14;[F:POQ]POHNUM;[F:POQ]POPLIN;[F:POQ]POQSEQ
        If !fstat
           WDEMQTY = min([F:ORDB]RMNEXTQTY,WDEMQTY)               # 05.2011
           GOK=1
        Endif
    Endif
    Filter [ORDB]
    If !GOK : GOK=1 : Return : Endif

    Raz [M:MLIK]
    [M:MLIK]MAJCOD  = "M"
    [M:MLIK]ITMREF  = [F:POQ]ITMREF
    [M:MLIK]STOFCY  = [F:POQ]PRHFCY
    # la demande
    [M:MLIK]DEMTYP  = 2
    [M:MLIK]DEMNUM  = [F:POQ]SOHNUM
    [M:MLIK]DEMLIN  = [F:POQ]SOPLIN
    [M:MLIK]DEMSEQ  = [F:POQ]SOQSEQ
    [M:MLIK]DWIPTYP = 1
    # la ressource
    [M:MLIK]RESSTYP = 14
    [M:MLIK]RESSNUM = [F:POQ]POHNUM
    [M:MLIK]RESSLIN = [F:POQ]POPLIN
    [M:MLIK]RESSSEQ = [F:POQ]POQSEQ
    # la quantité
    [M:MLIK]LIKQTY  = WDEMQTY
    [M:MLIK]FRCFLG  = 2
    [M:MLIK]FMIFLG  = 2

    Call UPDMTOLINK             From MTOLINKLIB
    If GOK>0 & ![M:MLIK]RET : # GH 13/10/2015 bug 111344 [M:MLIK]RET<>0 indicates something is wrong
       Call UPDORDERS_FROM_MLIK    From MTOLINKLIB
    Endif

    Return
Endif

WPTOCOD = func ITMLIB.GET_PTOCOD([F:POQ]ITMREF,[F:POQ]PRHFCY)
# lecture règle si nécessaire
If [F:PTO]PTOCOD <> WPTOCOD
   Read [PTO]PTO0=WPTOCOD
   If fstat : Raz [F:PTO] : Endif
Endif

WMTOMAJ = ([F:PTO]PTOREAL=2 & [F:PTO]REAL4RESS=2)

If !WMTOMAJ | [F:PTO]FRCPRO <> 2
   If !clalev([F:ORDB]) :  Local File ORDERS   [ORDB] : Endif
   Filter [ORDB] Where ITMREF=[F:POQ]ITMREF
   Read [ORDB]ORD3 = [F:POQ]PRHFCY;14;[F:POQ]POHNUM;[F:POQ]POPLIN;[F:POQ]POQSEQ
   Filter [ORDB]
   If !fstat
     If !WMTOMAJ
        Call GET_FRCQTY([F:POQ]PRHFCY, [F:POQ]ITMREF, -14, [F:POQ]POHNUM, [F:POQ]POPLIN, [F:POQ]POQSEQ, 2, WDEMQTY) From MTOLINKLIB
     Endif
     Call GET_FRCQTY([F:POQ]PRHFCY, [F:POQ]ITMREF, 14, [F:POQ]POHNUM, [F:POQ]POPLIN, [F:POQ]POQSEQ, 2, WFRCQTY) From MTOLINKLIB
     If WFRCQTY > [F:ORDB]RMNEXTQTY | (!WMTOMAJ & WDEMQTY > [F:ORDB]RMNEXTQTY) : # ressource sur-affectée
        Raz [M:MLIK]
        If !WMTOMAJ
            [M:MLIK]MAJCOD    = "R"
            [M:MLIK]PRPTYP    = 1                # annule & remplace
            [M:MLIK]PRPMOD    = 1                # mode mise à jour
        Else
            [M:MLIK]MAJCOD    = "Z"
        Endif
        [M:MLIK]STOFCY    = [F:POQ]PRHFCY
        [M:MLIK]ITMREF    = [F:POQ]ITMREF
        [M:MLIK]RESSTYP   = 14
        [M:MLIK]RESSNUM   = [F:POQ]POHNUM
        [M:MLIK]RESSLIN   = [F:POQ]POPLIN
        [M:MLIK]RESSSEQ   = [F:POQ]POQSEQ
        [M:MLIK]FRCPRO    = 1 + (WMTOMAJ | WFRCQTY > [F:ORDB]RMNEXTQTY)
        [M:MLIK]FEEDBACK  = 1
        GOK=1
        Call UPDMTOLINK From MTOLINKLIB
     Endif
   Endif
Endif

If WMTOMAJ
    # recalcul complet des affectations de l'article suivant la règle
    Raz [M:MLIK]
    [M:MLIK]MAJCOD    = "P"
    [M:MLIK]PRPTYP    = 1                    #annule & remplace
    [M:MLIK]PRPMOD    = 1                    # mode mise à jour
    [M:MLIK]STOFCY    = [F:POQ]PRHFCY
    [M:MLIK]ITMREF    = [F:POQ]ITMREF
    [M:MLIK]FRCPRO    = [F:PTO]FRCPRO
    [M:MLIK]FEEDBACK  = 1
    GOK=1
    Call UPDMTOLINK From MTOLINKLIB
Endif
Return

#########################################################################
# création affectation entre SO et PO (PEC ou contremarque)
# 10.09
$CRE_MTO_SO_PO
# GH 25/04/2014 bug 84573 affectation générée ssi cde vente sans ctm ou avec ctm=achat
If !find([F:SOQ]FMI,1,3) : Return : Endif

Gosub CHECK_MTO From MTOLINKLIB

If [F:SOQ]FMI <> 3
  Local Char WPTOCOD(GLONPTO)
  WPTOCOD = func ITMLIB.GET_PTOCOD([F:SOQ]ITMREF,[F:SOQ]STOFCY)
  # lecture règle si nécessaire
  If [F:PTO]PTOCOD <> WPTOCOD
     Read [PTO]PTO0=WPTOCOD
     If fstat : Raz [F:PTO] : Endif
  Endif

  # si affectation temps réel non active et pas une contremarque -> pas d'affectation
  If [F:PTO]PTOREAL < 2 : Return : Endif : # GH 27/04/2012 bug 79880
Endif

GOK=0
Local Decimal WDEMQTY
If !clalev([F:ORDB]) :  Local File ORDERS   [ORDB] : Endif
Filter [ORDB] Where ITMREF=[F:SOQ]ITMREF
Read [ORDB]ORD3 = [F:SOQ]STOFCY;2;[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ
If !fstat
 If ([F:SOQ]FMI<>3 & [F:PTO]PTODIR<>2) | [F:ORDB]MTOQTY=0            # GH 25/04/2014 bug 84573
   WDEMQTY = [F:ORDB]RMNEXTQTY - [F:ORDB]ALLQTY - [F:ORDB]MTOQTY     # GH 11/10/2012 bug 84918 # [F:ORDB]EXTQTY - [F:ORDB]ALLQTY
   Read [ORDB]ORD3 = [F:SOQ]STOFCY;14;[F:POQ]POHNUM;[F:POQ]POPLIN;[F:POQ]POQSEQ
   If !fstat
    If ([F:SOQ]FMI<>3 & [F:PTO]PTODIR<>2) | [F:ORDB]MTOQTY=0         # GH 25/04/2014 bug 84573
      WDEMQTY = min([F:ORDB]RMNEXTQTY-[F:ORDB]MTOQTY,WDEMQTY)        # GH 11/10/2012 bug 84918 # min([F:ORDB]RMNEXTQTY-[F:ORDB]MTOQTY,WDEMQTY)
      If find(GFONCTION,"FUNMPICK","FUNMPICKA") & dim([L]WLIKMAX)=1  # GH 15/05/2014 bug 99197
         WDEMQTY = min(WDEMQTY,WLIKMAX)
      Endif
      If WDEMQTY>0 : GOK=1 : Endif
    Endif
   Endif
 Endif
Endif
Filter [ORDB]
If !GOK : GOK=1 : Return : Endif

Raz [M:MLIK]
[M:MLIK]MAJCOD  = "C"
[M:MLIK]STOFCY  = [F:SOQ]STOFCY
[M:MLIK]ITMREF  = [F:SOQ]ITMREF
# la demande
[M:MLIK]DEMTYP  = 2
[M:MLIK]DEMNUM  = [F:SOQ]SOHNUM
[M:MLIK]DEMLIN  = [F:SOQ]SOPLIN
[M:MLIK]DEMSEQ  = [F:SOQ]SOQSEQ
[M:MLIK]DWIPTYP = 1
# la ressource
[M:MLIK]RESSTYP = 14
[M:MLIK]RESSNUM = [F:POQ]POHNUM
[M:MLIK]RESSLIN = [F:POQ]POPLIN
[M:MLIK]RESSSEQ = [F:POQ]POQSEQ
# la quantité
[M:MLIK]LIKQTY = WDEMQTY
[M:MLIK]FRCFLG  = 2
# [M:MLIK]FMIFLG  = 2 : # GH 29/02/2012 bug 79880
If [F:SOQ]FMI  = 3 : [M:MLIK]FMIFLG  = 2 : Else [M:MLIK]FMIFLG  = 1 : Endif

Call UPDMTOLINK             From MTOLINKLIB
If GOK>0 & ![M:MLIK]RET : # GH 13/10/2015 bug 111344 [M:MLIK]RET<>0 indicates something is wrong
 Call UPDORDERS_FROM_MLIK    From MTOLINKLIB
Endif
Return

###########################################
# Mise à jour des affectations et allocation
# du stock réceptionné à la demande
Subprog MAJ_MTO (TRTLIG,LQTY)
Value Char    TRTLIG
Value Decimal LQTY

If GMODU(5) = 2
    If clalev ([F:SOQ]) = 0  : Local File SORDERQ [SOQ]  : Endif
    If clalev ([F:SOP]) = 0  : Local File SORDERP [SOP]  : Endif
    If clalev ([F:SOH]) = 0  : Local File SORDER  [SOH]  : Endif
Endif
If GMODU(6) = 2
    If clalev ([F:SCO]) <= 0 : Local File SCOHEAD    [SCO] : Endif
    If clalev ([F:SCI]) <= 0 : Local File SCOITM     [SCI] : Endif
    If clalev ([F:SCM]) <= 0 : Local File SCOMAT     [SCM] : Endif
    If clalev ([F:SCS]) <= 0 : Local File SCOSRV     [SCS] : Endif
Endif
If GMODU(8) = 2
    Gosub OPEN_FILES_MFG From MFGLIB
Endif

If clalev ([F:STA]) = 0  : Local File STOALL  [STA]  : Endif
If clalev ([F:STJ]) = 0  : Local File STOJOU  [STJ]  : Endif

Gosub OPEN_MTO From MTOLINKLIB

Case TRTLIG
    When "C":   # allocation aux demandes affectées
                If func MTOLINKLIB.LINK_EXISTS([F:POQ]PRHFCY, 14, [F:POQ]POHNUM, [F:POQ]POPLIN, [F:POQ]POQSEQ, 2)
                    Raz [M:MLIK]
                    [M:MLIK]MAJCOD  = "E"
                    [M:MLIK]STOFCY  = [F:POQ]PRHFCY
                    [M:MLIK]RESSTYP = 14
                    [M:MLIK]RESSNUM = [F:POQ]POHNUM
                    [M:MLIK]RESSLIN = [F:POQ]POPLIN
                    [M:MLIK]RESSSEQ = [F:POQ]POQSEQ
                    [M:MLIK]ITMREF  = [F:POQ]ITMREF
                    [M:MLIK]LIKQTY  = LQTY
                    [M:MLIK]TRTNAM  = "PURMTOLIB"
                    Call UPDMTOLINK From MTOLINKLIB
                Endif

    When "A":   # suppression allocations si contremarque
                # GH !!
                # cette partie ne se lance pas car [POQ]VCR[TYP/NUM/SEQ]ORI ne sont pas renseignés (idem en V5)
                # et tant bien même ça le serait, les [STJ]REGFLG de la réception annulée sont à déjà 2, donc ça ne changerait rien
                If [F:POQ]ORI = 3 & [F:POQ]VCRTYPORI = 2
                    Raz [M:MLIK]
                    [M:MLIK]MAJCOD  = "S"
                    [M:MLIK]DEMNUM  = [F:POQ]VCRNUMORI
                    [M:MLIK]DEMLIN  = [F:POQ]VCRLINORI
                    [M:MLIK]DEMSEQ  = [F:POQ]VCRSEQORI
                    [M:MLIK]DWIPTYP = 1                   # 68911
                    [M:MLIK]ITMREF  = [F:POQ]ITMREF
                    Gosub MAJ_MTO_ALLOCATION
                Endif

                # mise à jour affectations
                Gosub MAJ_MTO_POQ             # 05.2011
Endcase
End

###########################################
# Allocation basée sur affectation
$MAJ_MTO_ALLOCATION
Local Decimal WQTY, WQTY1, WQTY2, WSHTQTY
Local Decimal WQTYACT, WALLQTY
Local Integer WRETOUR, WRET
Local Decimal SAV_WALLQTY, WQTE, WQTE1, WQTE2, WQTERES, WSTOCOU
Local Char    WDEFLOC(GLONLOC), WDEFLOCTYP(GLONTLO)
Local Char    WDEFLOC2(GLONLOC), WDEFLOCTYP2(GLONTLO)
Local Char    SYMBOLE(250)
Local Decimal WSTJQTY, WENTCUMALLQTY   # 76887

WRETOUR = 0

# suivant le type de demande, on sépare les traitements pour plus de lisibilité
Case [M:MLIK]DWIPTYP
    When 1, 8 : Gosub MAJ_SOF                    # commande client ou demande inter-site
  # GH 14/06/12 bug 77574
  # When 1    : Gosub MAJ_SOF                    # commande client
    When 3    : Gosub MAJ_MSF                    # matière à envoyer a un sous-traitant
    When 6    : Gosub MAJ_MWF                    # matière pour production interne

    When 14   : Gosub MAJ_PJM                    # Process PJM demands (X3-70716)

Endcase

Return

###################################################
# Allocation a une matière pour production interne
$MAJ_MWF
Local Integer MEMSTA

Read [MFM]MFM0 = [M:MLIK]DEMNUM ;[M:MLIK]DEMLIN;[M:MLIK]DEMSEQ;[M:MLIK]ITMREF
If fstat : Return : Endif

# si la matière est soldée/exclue
If [F:MFM]MATSTA > 2 : Return : Endif

Read [MFG]MFG0 = [F:MFM]MFGNUM
If fstat : Raz [F:MFG] : Return : Endif

If [M:MLIK]MAJCOD = "S"
   GPE = 0
   GPOINT = "CUSTRTALL" : Gosub ENTREE From EXEFNC
   If GOK < 1 : Return : Endif
   If !GPE

     If clalev([F:STO1]) = 0  : Local File STOCK  [STO1] : Endif

     # suppression des allocations
     For [STJ]STJ1   Where STOFCY = [F:PTD]PRHFCY
&                        & VCRTYP = 6
&                        & VCRNUM = [F:PTD]PTHNUM
&                        & VCRLIN = [F:PTD]PTDLIN
&                        & ITMREF = [F:PTD]ITMREF
&                        & REGFLG <> 2
&                        & TRSTYP <> 29           : #--- Issues 115206 & 120309
          Raz WSTOCOU
          #--- Issue X3-53322 : ajout LPN
          Call CLESTO([F:STJ]STOFCY,[F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,[F:STJ]BPSLOT,
&                     [F:STJ]PALNUM,[F:STJ]CTRNUM,[F:STJ]STA,[F:STJ]LOC,[F:STJ]PCU,
&                     [F:STJ]PCUSTUCOE,[F:STJ]SERNUM,[F:STJ]QLYCTLDEM,[F:STJ]OWNER,
&                     [F:STJ]STOFLD1,[F:STJ]STOFLD2,[F:STJ]LPNNUM,[L]WSTOCOU) From STKLIB
          For [STA]STA1 Where STOFCY = [F:STJ]STOFCY &
&                               VCRTYP = 10 & STOCOU = WSTOCOU &
&                               VCRNUM = [F:MFM]MFGNUM & VCRLIN = [F:MFM]MFGLIN &
&                               VCRSEQ = [F:MFM]BOMSEQ
               Call SUPALL([F:STA]STOFCY,[F:STA]ITMREF,[F:STA]STOCOU,[F:STA]SEQ,WRETOUR) From STKALL
               If WRETOUR <> 0 : GOK = 0 : Break : Endif
               WQTE2-= [F:STA]QTYSTU
               SAV_WALLQTY-= [F:STA]QTYSTU
          Next
          If GOK < 1 : Break : Endif
      Next
      If GOK < 1 : Return : Endif
   Endif
Else
     # GH 23/07/2013 bug 87805 remplacé par le DIMALL dans la boucle
     # si manquants, suppression allocation sur les manquants
     #If [F:MFM]SHTQTY > 0
     #   WQTY1 = 0 : WQTY2 = 0
     #   Call DELALL(10, [F:MFM]MFGNUM, [F:MFM]MFGLIN, [F:MFM]BOMSEQ, [F:MFM]ITMREF, 2, WQTY1, WQTY2, WRET) From STKALL
     #   If WRET <> 0 : Return : Endif
     #   [F:MFM]SHTQTY = 0
     #Endif

     # qté restant a allouer :
     WALLQTY = [F:MFM]RETQTY - [F:MFM]ALLQTY - [F:MFM]USEQTY
     If WALLQTY <= 0  : Return : Endif

     # point d'entrée permettant de modifier la quantité à allouer
     # il suffit de mettre WALLQTY = [M:MLIK]LIKQTY
     # derrière, on enlève la quantité déclarée en "R"
     GPOINT = "CALWALLQTY"
     Gosub  ENTREE From EXEFNC

     If WALLQTY > [M:MLIK]LIKQTY : WALLQTY = [M:MLIK]LIKQTY : Endif
     If WALLQTY <= 0             : Return                   : Endif
     # SAV_WALLQTY = WALLQTY      # GH 23/07/2013 bug 87805

     # ---------------------------------------------
     GPE = 0
     GPOINT = "CUSTRTALL" : Gosub ENTREE From EXEFNC
     If GOK < 1 : Return : Endif
     If !GPE
         # Recherche de l'emp (type) de consommation si exclusif
         Raz WDEFLOC, WDEFLOCTYP
         Call RECH_PICLOC(10,[F:MFM]MFGFCY,[F:MFM]ITMREF,[F:MFM]LOC,"",1,1,"O",WDEFLOC,WDEFLOCTYP) From STKALL

         ## Issue 118801 GH 02/12/16 - search location (type) for allocation if there is one exclusive
         Raz WDEFLOC2, WDEFLOCTYP2
         Call RECH_PICLOC(-10,[F:MFM]MFGFCY,[F:MFM]ITMREF,[F:MFM]LOC,"",1,1,"O",WDEFLOC2,WDEFLOCTYP2) From STKALL

         # GH 15/01/15 Bug 104861 : Changement du type d'allocation globale en détaillée ?
         # 0=Non 1=Allocation globale à supprimer 2=Affectation allouée en détail => ancien (Allocation + Manquant) global à recréer en détaillé
         Local Integer WCHGALL
         WCHGALL = (find([F:MFM]ALLSTA,2,3)<>0)
         If WCHGALL & [F:MFM]ALLQTY=0 : WCHGALL=2 : Endif

         WENTCUMALLQTY = ENT_CUMALLQTY  # 76887
         # boucle du fichier STOJOU
         For [STJ]STJ1 Where STOFCY = [F:PTD]PRHFCY
&                        & VCRTYP = 6
&                        & VCRNUM = [F:PTD]PTHNUM
&                        & VCRLIN = [F:PTD]PTDLIN
&                        & ITMREF = [F:PTD]ITMREF
&                        & REGFLG <> 2
&                        & TRSTYP <> 29           : #--- Issues 115206 & 120309

             If WALLQTY <= 0 : Break : Endif

             ## Issue 118801 GH 02/12/16 - compatibility with resource stock location depends on the (exclusive) allocation location
             ##                            instead of the (exclusive) material consumption
             ## GH 23/07/2013 bug 87805 test de WDEFLOC
             #If !find([L]WDEFLOC,"",[F:STJ]LOC) : Goto NXT_STJ_MWF : Endif
             ## GH 23/07/2013 bug 91012 test de WDEFLOCTYP
             #If !find([L]WDEFLOCTYP,"","*")
             #   If !clalev([F:STC]) : Local File STOLOC [STC] : Endif
             #   Read [STC]STC0 = [F:STJ]STOFCY;[F:STJ]LOC
             #   If fstat | pat([F:STC]LOCTYP,[L]WDEFLOCTYP)=0  : Goto NXT_STJ_MWF : Endif
             #Endif
             If !find([L]WDEFLOC2,"",[F:STJ]LOC) : Goto NXT_STJ_MWF : Endif
             If !find([L]WDEFLOCTYP2,"","*")
                If !clalev([F:STC]) : Local File STOLOC [STC] : Endif
                Read [STC]STC0 = [F:STJ]STOFCY;[F:STJ]LOC
                If fstat | pat([F:STC]LOCTYP,[L]WDEFLOCTYP2)=0 : Goto NXT_STJ_MWF : Endif
             Endif
             [L]WSTOCOU=0
             #--- Issue X3-53322 : ajout LPN
             Call CLESTO([F:STJ]STOFCY,[F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,[F:STJ]BPSLOT,
&                        [F:STJ]PALNUM,[F:STJ]CTRNUM,[F:STJ]STA,[F:STJ]LOC,[F:STJ]PCU,
&                        [F:STJ]PCUSTUCOE,[F:STJ]SERNUM,[F:STJ]QLYCTLDEM,[F:STJ]OWNER,
&                        [F:STJ]STOFLD1,[F:STJ]STOFLD2,[F:STJ]LPNNUM,[L]WSTOCOU) From STKLIB
             If [L]WSTOCOU=0 : Goto NXT_STJ_MWF : Endif

             # 76887
             If [F:STJ]QTYSTU <= WENTCUMALLQTY
                WSTJQTY = 0
                WENTCUMALLQTY-= [F:STJ]QTYSTU
             Else
                WSTJQTY = [F:STJ]QTYSTU - WENTCUMALLQTY
                WENTCUMALLQTY = 0
             Endif
             If WSTJQTY<=0 : Goto NXT_STJ_MWF : Endif

             # GH 15/01/15 Bug 104861 : # suppression de l'allocation globale
             If WCHGALL=1
                WQTY    = [F:MFM]ALLQTY
                WQTY1 = 0 : WQTY2 = 0
                Call DIMALL(10, [F:MFM]MFGNUM, [F:MFM]MFGLIN, [F:MFM]BOMSEQ, [F:MFM]ITMREF, 1 , WQTY, WQTY1, WQTY2, WRET) From STKALL
                If WRET <> 0 : GOK=0 : Break : Endif

                WCHGALL = 2
                WQTE2-= WQTY1
             Endif

             # GH 27/06/2017 Issue 38509 - consider WSTJQTY and not anymore [F:STJ]QTYSTU
#            WALLQTY-= [F:STJ]QTYSTU
#            If WALLQTY >= 0
#               WQTY = [F:STJ]QTYSTU
#            Else
#               WQTY = WALLQTY + [F:STJ]QTYSTU
#            Endif
             WQTY = min(WALLQTY,WSTJQTY)
             WALLQTY-= WQTY

             If [F:STJ]POT <> 0
                 WQTYACT = WQTY * ([F:STJ]POT/100)
             Else
                 WQTYACT = WQTY
             Endif

             WQTE = [F:MFM]ALLQTY  # quantité déjà allouée
             # calcul de la quantité allouée en unité active
             If [F:STJ]POT <> 0
                   GBIDD2 = WQTE * ([F:STJ]POT/100)
             Else
                   GBIDD2 = WQTE
             Endif
             Raz GBIDC1

             #--- TS 106217 ajout paramètre LECC (avant dernier)
             Call CREALL(2,[F:STJ]STOFCY,[F:STJ]ITMREF,WSTOCOU,[F:PTD]RCPDAT,WQTY,
&                        WQTYACT,10,[F:MFM]MFGNUM,[F:MFM]MFGLIN,[F:MFM]BOMSEQ,GBIDC1,[F:MFM]RETDAT,
&                        "","","","","","",WQTE,GBIDD2,WDEFLOC,WDEFLOCTYP,"","",1,"",WRETOUR) From STKALL
             If WRETOUR <> 0 : GOK = 0 : Break : Endif
             WQTE2+= WQTY
             SAV_WALLQTY+= WQTY       # GH 23/07/2013 bug 87805

$NXT_STJ_MWF
         Next
         If GOK < 1 : Return : Endif

         # GH 23/07/2013 bug 87805
         If SAV_WALLQTY <> 0 : # WCHGALL=2
            If WCHGALL : WQTY = [F:MFM]SHTQTY : # suppression du manquant global  # GH 31/07/13 Bug 90797
            Else       : WQTY = SAV_WALLQTY   : # diminution du manquant détail
            Endif
            If WQTY<>0
               WQTY1 = 0 : WQTY2 = 0
               Call DIMALL(10, [F:MFM]MFGNUM, [F:MFM]MFGLIN, [F:MFM]BOMSEQ, [F:MFM]ITMREF, 2, WQTY, WQTY1, WQTY2, WRET) From STKALL
               If WRET <> 0 : Return : Endif
            Endif

            If WCHGALL
              # GH 15/01/15 Bug 104861 : # allocation en détaillé

              WSHTQTY = max(0,[F:MFM]SHTQTY-SAV_WALLQTY)
              [F:MFM]ALLSTA = 3-(WSHTQTY>0)
              If WSHTQTY<>0 : # GH 23/06/14 Bug 100441
                 # Création du manquant détail
                 #--- TS 106217 ajout paramètre LECC (avant dernier)
                 Call CREALL(4,[F:MFM]MFGFCY,[F:MFM]ITMREF,0,[31/12/2999],0,
&                            WSHTQTY,10,[F:MFM]MFGNUM,[F:MFM]MFGLIN,[F:MFM]BOMSEQ,"",max(date$,[F:MFM]RETDAT),
&                            [F:MFM]LOT,"",[F:MFM]STA,WDEFLOC2,"","",0,0,"","","","",1,[F:MFM]ECCVALMAJ,WRET) From STKALL
                 If WRET <> 0 : Return : Endif
              Endif

              If [F:MFM]ALLQTY<>0
                 WQTY = [F:MFM]ALLQTY : WQTY2 = 0
                 Call ALLOCATION("C", 2, WQTY, WQTY2, WRET) From MFGALL
                 If WRET <> 0 : Return : Endif
                 WQTE2+= WQTY
              Endif

              # WCHGALL = 3
            Endif
         Endif

     Endif
Endif
If WRETOUR <> 0     : Return : Endif
If SAV_WALLQTY = 0  : Return : Endif

SYMBOLE = "MFG"+[F:MFG]MFGNUM
Lock =SYMBOLE With lockwait=0
If fstat
   # Ordre de fabrication ... Modification en cours sur un autre poste
   GMESSAGE=mess(5,306,1)-[F:MFG]MFGNUM+"\"+mess(10,100,1) : GERR=1
   GOK=0 : Return
Endif

# mise à jour detail matière
Readlock [MFG]MFG0 = [F:MFM]MFGNUM
If fstat= 1
    GOK = -1 : GLOCK = "$MFGHEAD"-[F:MFM]MFGNUM : Goto MAJ_FIN
Elsif fstat
    GOK = 0  : Call RSTA("MFG",[F:MFM]MFGNUM) From GLOCK : Goto MAJ_FIN
Endif

Readlock [MFM]MFM0=[M:MLIK]DEMNUM;[M:MLIK]DEMLIN;[M:MLIK]DEMSEQ;[M:MLIK]ITMREF
If fstat = 1
    GOK = -1 : GLOCK = "$MFGMAT"-[M:MLIK]DEMNUM-num$([M:MLIK]DEMLIN)-num$([M:MLIK]DEMSEQ)-[M:MLIK]ITMREF : Goto MAJ_FIN
Elsif fstat
    GOK = 0  : Call RSTA("MFM",[M:MLIK]DEMNUM-num$([M:MLIK]DEMLIN)-num$([M:MLIK]DEMSEQ)-[M:MLIK]ITMREF) From GLOCK : Goto MAJ_FIN
Endif

MEMSTA = [F:MFM]ALLSTA

#-- WQTE2 contient la quantité allouée ou désallouée réellement
[F:MFM]ALLQTY+= WQTE2
If [F:MFM]ALLQTY < 0 : [F:MFM]ALLQTY = 0 : Endif

# statut alloc détaillé et complet ou rupture
[F:MFM]ALLSTA = 5
WSHTQTY = 0
If [F:MFM]ALLQTY < ([F:MFM]RETQTY - [F:MFM]USEQTY)
    [F:MFM]ALLSTA-= 1
    WSHTQTY = [F:MFM]RETQTY - [F:MFM]USEQTY - [F:MFM]ALLQTY
Endif

If [M:MLIK]MAJCOD="S"
    If WSHTQTY>0
      #--- TS 106217 ajout paramètre LECC (avant dernier)
      Call CREALL(4,[F:MFM]MFGFCY,[F:MFM]ITMREF,0,[F:PTD]RCPDAT,0,
&                 WSHTQTY,10,[F:MFM]MFGNUM, [F:MFM]MFGLIN,[F:MFM]BOMSEQ,"",[F:MFM]RETDAT,
&                 [F:MFM]LOT,"",[F:MFM]STA,[F:MFM]LOC,"","",0,0,"","","","",1,[F:MFM]ECCVALMAJ,WRET) From STKALL
    Endif
    [F:MFM]SHTQTY = WSHTQTY
Else
    [F:MFM]SHTQTY-= SAV_WALLQTY
Endif
If [F:MFM]SHTQTY<0 : [F:MFM]SHTQTY=0 : Endif : # GH 09/12/2014 bug 103464

# mise à jour matière
Rewrite [MFM]
If fstat
    GOK = 0 : Call FSTA ("MFG") From GLOCK : Goto MAJ_FIN
Endif

# lecture encours pour récupérer le n° affaire
Read [ORD]ORD0=6;[F:MFM]WIPNUM;[F:MFM]ITMREF

# mise à jour de l'encours
Call UPDATE_MFX("M", [F:ORD]PJT, [F:ORD]BOMALT, 0) From MFGLIBM

# FQ 70409 GA 01/2011
# mise à jour entête
# Gosub MAJMFG From MFGALL
Gosub MAJMFGHEAD From MFGLIB

Rewrite [MFG]
If fstat
    GOK = 0 : Call FSTA ("MFG") From GLOCK : Goto MAJ_FIN
Endif

# 76887 sauvegarde du cumul alloué
If [M:MLIK]MAJCOD = "E" : ENT_CUMALLQTY+= SAV_WALLQTY : Endif

Goto MAJ_FIN

###################################################
# Allocation a une matière mise à dispo du sous-traitant
$MAJ_MSF
Local Integer MEMSTA

Read [SCM]SCM0 = [M:MLIK]DEMNUM ;[M:MLIK]DEMLIN;[M:MLIK]DEMSEQ
If fstat : Return : Endif

# si la matière est soldée/exclue
If [F:SCM]MATSTA > 2 : Return : Endif

Read [SCO]SCO0 = [F:SCM]SCONUM
If fstat : Raz [F:SCO] : Return : Endif

If [M:MLIK]MAJCOD = "S"
   GPE = 0
   GPOINT = "CUSTRTALL" : Gosub ENTREE From EXEFNC
   If GOK < 1 : Return : Endif
   If !GPE

     If clalev([F:STO1]) = 0  : Local File STOCK  [STO1] : Endif

     # suppression des allocations
     For [STJ]STJ1   Where STOFCY = [F:PTD]PRHFCY
&                        & VCRTYP = 6
&                        & VCRNUM = [F:PTD]PTHNUM
&                        & VCRLIN = [F:PTD]PTDLIN
&                        & ITMREF = [F:PTD]ITMREF
&                        & REGFLG <> 2
&                        & TRSTYP <> 29           : #--- Issues 115206 & 120309
          Raz WSTOCOU
          #--- Issue X3-53322 : ajout LPN
          Call CLESTO([F:STJ]STOFCY,[F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,[F:STJ]BPSLOT,
&                     [F:STJ]PALNUM,[F:STJ]CTRNUM,[F:STJ]STA,[F:STJ]LOC,[F:STJ]PCU,
&                     [F:STJ]PCUSTUCOE,[F:STJ]SERNUM,[F:STJ]QLYCTLDEM,[F:STJ]OWNER,
&                     [F:STJ]STOFLD1,[F:STJ]STOFLD2,[F:STJ]LPNNUM,[L]WSTOCOU) From STKLIB
          For [STA]STA1 Where STOFCY = [F:STJ]STOFCY &
&                             VCRTYP = 36 & STOCOU = WSTOCOU &
&                             VCRNUM = [F:SCM]SCONUM & VCRLIN = [F:SCM]SCILIN &
&                             VCRSEQ = [F:SCM]SCMLIN
               Call SUPALL([F:STA]STOFCY,[F:STA]ITMREF,[F:STA]STOCOU,[F:STA]SEQ,WRETOUR) From STKALL
               If WRETOUR <> 0 : GOK = 0 : Break : Endif
               WQTE2-= [F:STA]QTYSTU
               SAV_WALLQTY-= [F:STA]QTYSTU
          Next
          If GOK < 1 : Break : Endif
      Next
      If GOK < 1 : Return : Endif
   Endif
Else
     # GH 07/02/2013 bug 87805 remplacé par le DIMALL dans la boucle
     # si manquants, suppression allocation sur les manquants
     #If [F:SCM]SHTQTY > 0
     #   WQTY1 = 0 : WQTY2 = 0
     #   Call DELALL(36, [F:SCM]SCONUM, [F:SCM]SCILIN, [F:SCM]SCMLIN, [F:SCM]CPNITMREF, 2, WQTY1, WQTY2, WRET) From STKALL
     #   If WRET <> 0 : Return : Endif
     #   [F:SCM]SHTQTY = 0
     #Endif

     # qté restant a allouer :
     WALLQTY = [F:SCM]RETQTY - [F:SCM]ALLQTY - [F:SCM]USEQTY
     If WALLQTY <= 0  : Return : Endif

     # point d'entrée permettant de modifier la quantité à allouer
     # il suffit de mettre WALLQTY = [M:MLIK]LIKQTY
     # derrière, on enlève la quantité déclarée en "R"
     GPOINT = "CALWALLQTY"
     Gosub  ENTREE From EXEFNC

     If WALLQTY > [M:MLIK]LIKQTY : WALLQTY = [M:MLIK]LIKQTY : Endif
     If WALLQTY <= 0             : Return                   : Endif
     # SAV_WALLQTY = WALLQTY      # GH 07/02/2013 bug 87805

     # ---------------------------------------------
     GPE = 0
     GPOINT = "CUSTRTALL" : Gosub ENTREE From EXEFNC
     If GOK < 1 : Return : Endif
     If !GPE
         # Recherche de l'emp (type) de consommation si exclusif
         Raz WDEFLOC, WDEFLOCTYP
         Call RECH_PICLOC(36,[F:SCM]STOFCY,[F:SCM]CPNITMREF,[F:SCM]LOC,"",1,1,"O",WDEFLOC,WDEFLOCTYP) From STKALL

         # GH 15/01/15 Bug 104861 : Changement du type d'allocation globale en détaillée ?
         # 0=Non 1=Allocation globale à supprimer 2=Affectation allouée en détail => ancien (Allocation + Manquant) global à recréer en détaillé
         Local Integer WCHGALL
         WCHGALL = (find([F:SCM]ALLSTA,2,3)<>0)
         If WCHGALL & [F:SCM]ALLQTY=0 : WCHGALL=2 : Endif

         WENTCUMALLQTY = ENT_CUMALLQTY  # 76887
         # boucle du fichier STOJOU
         For [STJ]STJ1 Where STOFCY = [F:PTD]PRHFCY
&                        & VCRTYP = 6
&                        & VCRNUM = [F:PTD]PTHNUM
&                        & VCRLIN = [F:PTD]PTDLIN
&                        & ITMREF = [F:PTD]ITMREF
&                        & REGFLG <> 2
&                        & TRSTYP <> 29           : #--- Issues 115206 & 120309
             If WALLQTY <= 0 : Break : Endif

             # GH 07/02/2013 bug 87805 test de WDEFLOC
             If !find([L]WDEFLOC,"",[F:STJ]LOC) : Goto NXT_STJ_MSF : Endif
             # GH 23/07/2013 bug 91012 test de WDEFLOCTYP
             If !find([L]WDEFLOCTYP,"","*")
                If !clalev([F:STC]) : Local File STOLOC [STC] : Endif
                Read [STC]STC0 = [F:STJ]STOFCY;[F:STJ]LOC
                If fstat | pat([F:STC]LOCTYP,[L]WDEFLOCTYP)=0  : Goto NXT_STJ_MSF : Endif
             Endif
             [L]WSTOCOU=0
             #--- Issue X3-53322 : ajout LPN
             Call CLESTO([F:STJ]STOFCY,[F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,[F:STJ]BPSLOT,
&                        [F:STJ]PALNUM,[F:STJ]CTRNUM,[F:STJ]STA,[F:STJ]LOC,[F:STJ]PCU,
&                        [F:STJ]PCUSTUCOE,[F:STJ]SERNUM,[F:STJ]QLYCTLDEM,[F:STJ]OWNER,
&                        [F:STJ]STOFLD1,[F:STJ]STOFLD2,[F:STJ]LPNNUM,[L]WSTOCOU) From STKLIB
             If [L]WSTOCOU=0 : Goto NXT_STJ_MSF : Endif

             # 76887
             If [F:STJ]QTYSTU <= WENTCUMALLQTY
                WSTJQTY = 0
                WENTCUMALLQTY-= [F:STJ]QTYSTU
             Else
                WSTJQTY = [F:STJ]QTYSTU - WENTCUMALLQTY
                WENTCUMALLQTY = 0
             Endif
             If WSTJQTY<=0 : Goto NXT_STJ_MSF : Endif

             # GH 15/01/15 Bug 104861 : # suppression de l'allocation globale
             If WCHGALL=1
                WQTY    = [F:SCM]ALLQTY
                WQTY1 = 0 : WQTY2 = 0
                Call DIMALL(36, [F:SCM]SCONUM, [F:SCM]SCILIN, [F:SCM]SCMLIN, [F:SCM]CPNITMREF, 1, WQTY, WQTY1, WQTY2, WRET) From STKALL
                If WRET <> 0 : GOK=0 : Break : Endif

                WCHGALL = 2
                WQTE2-= WQTY1
             Endif

             # GH 27/06/2017 Issue 38509 - consider WSTJQTY and not anymore [F:STJ]QTYSTU
#            WALLQTY-= [F:STJ]QTYSTU
#            If WALLQTY >= 0
#               WQTY = [F:STJ]QTYSTU
#            Else
#               WQTY = WALLQTY + [F:STJ]QTYSTU
#            Endif
             WQTY = min(WALLQTY,WSTJQTY)
             WALLQTY-= WQTY

             If [F:STJ]POT <> 0
                 WQTYACT = WQTY * ([F:STJ]POT/100)
             Else
                 WQTYACT = WQTY
             Endif

             WQTE = [F:SCM]ALLQTY  # quantité déjà allouée
             # calcul de la quantité allouée en unité active
             If [F:STJ]POT <> 0
                   GBIDD2 = WQTE * ([F:STJ]POT/100)
             Else
                   GBIDD2 = WQTE
             Endif
             Raz GBIDC1

             #--- TS 106217 ajout paramètre LECC (avant dernier)
             Call CREALL(2,[F:STJ]STOFCY,[F:STJ]ITMREF,WSTOCOU,[F:PTD]RCPDAT,WQTY,
&                        WQTYACT,36,[F:SCM]SCONUM,[F:SCM]SCILIN,[F:SCM]SCMLIN,GBIDC1,[F:SCM]DLVDAT,
&                        "","","","","","",WQTE,GBIDD2,WDEFLOC,WDEFLOCTYP,"","",1,"",WRETOUR) From STKALL
             If WRETOUR <> 0 : GOK = 0 : Break : Endif
             WQTE2+= WQTY
             SAV_WALLQTY+= WQTY       # GH 07/02/2013 bug 87805

$NXT_STJ_MSF
         Next
         If GOK < 1 : Return : Endif

         # GH 07/02/2013 bug 87805
         If SAV_WALLQTY <> 0 : # WCHGALL=2
            If WCHGALL : WQTY = [F:SCM]SHTQTY : # suppression du manquant global  # GH 31/07/13 Bug 90797
            Else       : WQTY = SAV_WALLQTY   : # diminution du manquant détail
            Endif
            If WQTY<>0
               WQTY1 = 0 : WQTY2 = 0
               Call DIMALL(36, [F:SCM]SCONUM, [F:SCM]SCILIN, [F:SCM]SCMLIN, [F:SCM]CPNITMREF, 2, WQTY, WQTY1, WQTY2, WRET) From STKALL
               If WRET <> 0 : Return : Endif
            Endif

            If WCHGALL
              # GH 15/01/15 Bug 104861 : # allocation en détaillé

              WSHTQTY = max(0,[F:SCM]SHTQTY-SAV_WALLQTY)
              [F:SCM]ALLSTA = 3-(WSHTQTY>0)
              If WSHTQTY<>0 : # GH 23/06/14 Bug 100441
                 # Création du manquant détail
                 #--- TS 106217 ajout paramètre LECC (avant dernier)
                 Call CREALL(4,[F:SCM]STOFCY,[F:SCM]CPNITMREF,0,[31/12/2999],0,
&                            WSHTQTY,36,[F:SCM]SCONUM,[F:SCM]SCILIN,[F:SCM]SCMLIN,"",max(date$,[F:SCM]DLVDAT),
&                            [F:SCM]LOT,"",[F:SCM]STA,WDEFLOC,"","",0,0,"","","","",1,[F:SCM]ECCVALMAJ,WRET) From STKALL
                 If WRET <> 0 : Return : Endif
              Endif

              If [F:SCM]ALLQTY<>0
                  WQTY = [F:SCM]ALLQTY : WQTY2 = 0
                  Call ALLOCATION("C", 2, WQTY, WQTY2, WRET) From SCOALL
                  If WRET <> 0 : Return : Endif
                  WQTE2+= WQTY
              Endif

              # WCHGALL = 3
            Endif
         Endif

     Endif
Endif
If WRETOUR <> 0     : Return : Endif
If SAV_WALLQTY = 0  : Return : Endif

SYMBOLE = "SCO"+[F:SCO]SCONUM
Lock =SYMBOLE With lockwait=0
If fstat
   # Ordre de sous-traitance ... Modification en cours sur un autre poste
   GMESSAGE=mess(13,306,1)-[F:SCO]SCONUM+"\"+mess(10,100,1) : GERR=1
   GOK=0 : Return
Endif

# mise à jour detail matière
Readlock [SCO]SCO0 = [F:SCM]SCONUM
If fstat= 1
    GOK = -1 : GLOCK = "$SCOHEAD"-[F:SCM]SCONUM : Goto MAJ_FIN
Elsif fstat
    GOK = 0  : Call RSTA("SCO",[F:SCM]SCONUM) From GLOCK : Goto MAJ_FIN
Endif

Readlock [SCM]SCM0=[M:MLIK]DEMNUM;[M:MLIK]DEMLIN;[M:MLIK]DEMSEQ
If fstat = 1
    GOK = -1 : GLOCK = "$SCOMAT"-[M:MLIK]DEMNUM-num$([M:MLIK]DEMLIN)-num$([M:MLIK]DEMSEQ) : Goto MAJ_FIN
Elsif fstat
    GOK = 0  : Call RSTA("SCM",[M:MLIK]DEMNUM-num$([M:MLIK]DEMLIN)-num$([M:MLIK]DEMSEQ)) From GLOCK : Goto MAJ_FIN
Endif

MEMSTA = [F:SCM]ALLSTA

#-- WQTE2 contient la quantité allouée ou désallouée réellement
[F:SCM]ALLQTY+= WQTE2
If [F:SCM]ALLQTY < 0 : [F:SCM]ALLQTY = 0 : Endif

# statut alloc détaillé et complet ou rupture
[F:SCM]ALLSTA = 5
WSHTQTY = 0
If [F:SCM]ALLQTY < ([F:SCM]RETQTY - [F:SCM]USEQTY)
    [F:SCM]ALLSTA-= 1
    WSHTQTY = [F:SCM]RETQTY - [F:SCM]USEQTY - [F:SCM]ALLQTY
Endif

If [M:MLIK]MAJCOD="S"
    If WSHTQTY>0
      #--- TS 106217 ajout paramètre LECC (avant dernier)
      Call CREALL(4,[F:SCM]STOFCY,[F:SCM]CPNITMREF,0,[F:SCM]DLVDAT,0,
&                 WSHTQTY,36,[F:SCM]SCONUM,[F:SCM]SCILIN,[F:SCM]SCMLIN,"",[F:SCM]DLVDAT,
&                 [F:SCM]LOT,"",[F:SCM]STA,[F:SCM]LOC,"","",0,0,"","","","",1,[F:SCM]ECCVALMAJ,WRET) From STKALL
    Endif
    [F:SCM]SHTQTY = WSHTQTY
Else
    [F:SCM]SHTQTY-= SAV_WALLQTY
Endif
If [F:SCM]SHTQTY<0 : [F:SCM]SHTQTY=0 : Endif : # GH 09/12/2014 bug 103464

# mise à jour matière
Rewrite [SCM]
If fstat
    GOK = 0 : Call FSTA ("SCM") From GLOCK : Goto MAJ_FIN
Endif

# lecture encours pour récupérer le n° affaire
Read [ORD]ORD0=3;[F:SCM]WIPNUM;[F:SCM]CPNITMREF

# mise à jour de l'encours
Call UPDATE_MSX("M", 0) From SCOLIB

Gosub MAJSCOHEAD From SCOLIB

Rewrite [SCO]
If fstat
    GOK = 0 : Call FSTA ("SCO") From GLOCK : Goto MAJ_FIN
Endif

# 76887 sauvegarde du cumul alloué
If [M:MLIK]MAJCOD = "E" : ENT_CUMALLQTY+= SAV_WALLQTY : Endif

Goto MAJ_FIN

###################################################
# Allocation a une commande de vente
$MAJ_SOF
Local Decimal WALL, WSHT
Local Char    ABR(7) : ABR="[F:SOQ]"

#----- lecture détail cde vente pour récupérer la qté restante à allouer -----#
Read [SOH]SOH0=[M:MLIK]DEMNUM
If fstat : Raz [F:SOH] : Return : Endif

Read [SOP]SOP0=[M:MLIK]DEMNUM;[M:MLIK]DEMLIN;[M:MLIK]DEMSEQ
If fstat : Raz [F:SOP] : Endif

Read [SOQ]SOQ0=[M:MLIK]DEMNUM;[M:MLIK]DEMLIN;[M:MLIK]DEMSEQ
If fstat : Raz [F:SOQ] : Endif

#----- si la ligne de commande a été soldée, il ne faut plus la toucher -----#
If [F:SOQ]SOQSTA = 3 : Return : Endif

#----- Si l'article nest pas géré en stock, pas de traitement -----#
If [F:SOQ]STOMGTCOD < 2 : Return : Endif

#----- Vérification si le site de réception et site d'expédition sont différents -----#
If [F:SOQ]STOFCY <> [F:PTD]PRHFCY
    Call ECR_TRACE(mess(339,194,1),0) From GESECRAN : GPURTRACE=2 : Return
Endif

#--------------------------------------------#
# WQTERES : quantité restant à allouée       #
# WQTE1   : quantité à allouée ou désallouée #
# WQTE2   : quantité allouée réellement      #
#--------------------------------------------#

If [M:MLIK]MAJCOD = "S"

    WQTERES = [F:PTD]QTYSTU
    If WQTERES > [F:SOQ]ALLQTYSTU : WQTERES = [F:SOQ]ALLQTYSTU : Endif

    #--- Suppression des allocations pour chacun des mouvements
    For [STJ] STJ1 Where STOFCY=[F:PTD]PRHFCY
&                      & VCRTYP=6
&                      & VCRNUM=[F:PTD]PTHNUM
&                      & VCRLIN=[F:PTD]PTDLIN
&                      & REGFLG<>2
&                      & TRSTYP<>29           : #--- Issues 115206 & 120309
        If WQTERES <= 0 : Break : Endif

        If (WQTERES - [F:STJ]QTYSTU) > 0
            WQTE1 = [F:STJ]QTYSTU
        Else
            WQTE1 = WQTERES
            Raz WQTERES
        Endif
        WQTERES-= WQTE1

        Raz WSTOCOU
        #--- Issue X3-53322 : ajout LPN
        Call CLESTO([F:STJ]STOFCY,[F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,[F:STJ]BPSLOT,
&                   [F:STJ]PALNUM,[F:STJ]CTRNUM,[F:STJ]STA,[F:STJ]LOC,[F:STJ]PCU,
&                   [F:STJ]PCUSTUCOE,[F:STJ]SERNUM,[F:STJ]QLYCTLDEM,[F:STJ]OWNER,
&                   [F:STJ]STOFLD1,[F:STJ]STOFLD2,[F:STJ]LPNNUM,[L]WSTOCOU) From STKLIB

        For [STA]STA1 Where VCRTYP=2 & VCRNUM=[F:SOQ]SOHNUM & VCRLIN=[F:SOQ]SOPLIN &
&                           VCRSEQ=[F:SOQ]SOQSEQ & STOCOU=WSTOCOU
            # Suppression de l'allocation correspondante de la pièce d'origine
            Call SUPALL([F:STA]STOFCY,[F:STA]ITMREF,[F:STA]STOCOU,[F:STA]SEQ,WRETOUR) From STKALL
            If WRETOUR <> 0 : GOK=0 : Break : Endif
            WQTE2-= [F:STA]QTYSTU
            SAV_WALLQTY-= [F:STA]QTYSTU
        Next

        If GOK < 1 : Break : Endif
    Next
    If GOK < 1 : Return : Endif
Else

    # GH 23/07/2013 bug 87805 remplacé par le DIMALL dans la boucle
    # si manquants, diminution/suppression allocation sur les manquants
    #If [F:SOQ]SHTQTYSTU <> 0
    #   WQTY = [M:MLIK]LIKQTY
    #   WQTY1 = 0 : WQTY2 = 0
    #   Call DIMALL(2, [F:SOQ]SOHNUM, [F:SOQ]SOPLIN, [F:SOQ]SOQSEQ, [F:SOQ]ITMREF, 2, WQTY, WQTY1, WQTY2,WRET) From STKALL
    #   If WRET <> 0 : Return : Endif
    #   WSHTQTY = [F:SOQ]SHTQTYSTU - WQTY2
    #Endif

    WSHTQTY = [F:SOQ]SHTQTYSTU

    # Recherche de l'emp (type) de livraison si exclusif
    Raz WDEFLOC, WDEFLOCTYP
    Call RECH_PICLOC(2,[F:SOQ]STOFCY,[F:SOQ]ITMREF,"","",1,1,"O",WDEFLOC,WDEFLOCTYP) From STKALL

    ## Issue 118801 GH 02/12/16 - search location (type) for allocation if there is one exclusive
    Raz WDEFLOC2, WDEFLOCTYP2
    Call RECH_PICLOC(-2,[F:SOQ]STOFCY,[F:SOQ]ITMREF,"","",1,1,"O",WDEFLOC2,WDEFLOCTYP2) From STKALL

    If [F:SOH]SOHCAT = 3
       WQTERES = [F:SOQ]QTYSTU-[F:SOQ]ALLQTYSTU-[F:SOQ]INVQTYSTU
     Else
       WQTERES = [F:SOQ]QTYSTU-[F:SOQ]ALLQTYSTU-[F:SOQ]DLVQTYSTU-[F:SOQ]ODLQTYSTU
    Endif

    If WQTERES > [M:MLIK]LIKQTY : WQTERES = [M:MLIK]LIKQTY : Endif
    If WQTERES <= 0             : Return                   : Endif
    If WQTERES >= [F:PTD]QTYSTU : WQTERES=[F:PTD]QTYSTU : Endif

    #---------------------------------------------------------#
    # Point d'entrée CHGALLQTY pour modifier la qté à allouer #
    # ------------------------------------------------------- #
    # Variable utilisable par le point d'entrée               #
    #                                                         #
    # WQTERES : Quantité à allouer en US                      #
    #---------------------------------------------------------#
    Gosub POINT_CHGALLQTY From SUBPTHA : # Pour rendre pérenne le point d'entrée en v6
    If WQTERES > [F:PTD]QTYSTU : WQTERES = [F:PTD]QTYSTU : Endif

    #--- Issue 122340
    Local Decimal WQTYSTU, WQTYARR
    #---------------------------------------------
    # TS : réajustement qté en unité vente entière
    #---------------------------------------------
    WQTYSTU = WQTERES
    If [F:SOP]SAU<>[F:SOP]STU
      Call CTRQTYPCU([F:SOP]SAU,[F:SOP]SAUSTUCOE,WQTYSTU,WQTYARR) From STKLIB
      If WQTYARR<>WQTYSTU
        Call QTEARR(WQTYARR,[F:SOP]STU) From TRTDIV
        WQTYSTU = WQTYARR
        WQTY    = WQTYSTU/[F:SOP]SAUSTUCOE
        Call QTEARR(WQTY,[F:SOP]SAU) From TRTDIV
      Endif
    Endif
    WQTERES = WQTYSTU
    If WQTERES<=0  Return Endif
    #--- End 122340

    # SAV_WALLQTY = WQTERES    # GH 23/07/2013 bug 87805

    # GH 31/07/13 Bug 90797 : Changement du type d'allocation globale en détaillée ?
    # 0=Non 1=Allocation globale à supprimer 2=Affectation allouée en détail => ancien (Allocation + Manquant) global à recréer en détaillé
    Local Integer WCHGALL
    WCHGALL = ([F:SOQ]ALLTYP=1)
    If WCHGALL & [F:SOQ]ALLQTYSTU=0 : WCHGALL=2 : Endif

    #-----
    WENTCUMALLQTY = ENT_CUMALLQTY  # 76887
    For [STJ] STJ1 Where STOFCY=[F:PTD]PRHFCY
&                      & VCRTYP=6
&                      & VCRNUM=[F:PTD]PTHNUM
&                      & VCRLIN=[F:PTD]PTDLIN
&                      & REGFLG<>2
&                      & TRSTYP<>29           : #--- Issues 115206 & 120309
        If WQTERES <= 0 : Break : Endif

        ## Issue 118801 GH 02/12/16 - compatibility with resource stock location depends on the (exclusive) allocation location
        ##                            instead of the (exclusive) delivery location
        # GH 23/07/2013 bug 87805 test de WDEFLOC
        #If !find([L]WDEFLOC,"",[F:STJ]LOC) : Goto NXT_STJ_SOF : Endif
        ## GH 23/07/2013 bug 91012 test de WDEFLOCTYP
        #If !find([L]WDEFLOCTYP,"","*")
        #   If !clalev([F:STC]) : Local File STOLOC [STC] : Endif
        #   Read [STC]STC0 = [F:STJ]STOFCY;[F:STJ]LOC
        #   If fstat | pat([F:STC]LOCTYP,[L]WDEFLOCTYP)=0  : Goto NXT_STJ_SOF : Endif
        #Endif
        If !find([L]WDEFLOC2,"",[F:STJ]LOC) : Goto NXT_STJ_SOF : Endif
        If !find([L]WDEFLOCTYP2,"","*")
           If !clalev([F:STC]) : Local File STOLOC [STC] : Endif
           Read [STC]STC0 = [F:STJ]STOFCY;[F:STJ]LOC
           If fstat | pat([F:STC]LOCTYP,[L]WDEFLOCTYP2)=0 : Goto NXT_STJ_SOF : Endif
        Endif
        [L]WSTOCOU=0
        #--- Issue X3-53322 : ajout LPN
        Call CLESTO([F:STJ]STOFCY,[F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,[F:STJ]BPSLOT,
&                   [F:STJ]PALNUM,[F:STJ]CTRNUM,[F:STJ]STA,[F:STJ]LOC,[F:STJ]PCU,
&                   [F:STJ]PCUSTUCOE,[F:STJ]SERNUM,[F:STJ]QLYCTLDEM,[F:STJ]OWNER,
&                   [F:STJ]STOFLD1,[F:STJ]STOFLD2,[F:STJ]LPNNUM,[L]WSTOCOU) From STKLIB
        If [L]WSTOCOU=0 : Goto NXT_STJ_SOF : Endif

        # 76887
        If [F:STJ]QTYSTU <= WENTCUMALLQTY
           WSTJQTY = 0
           WENTCUMALLQTY-= [F:STJ]QTYSTU
        Else
           WSTJQTY = [F:STJ]QTYSTU - WENTCUMALLQTY
           WENTCUMALLQTY = 0
        Endif
        If WSTJQTY<=0 : Goto NXT_STJ_SOF : Endif

        # GH 31/07/13 Bug 90797 : # suppression de l'allocation globale
        If WCHGALL=1
           WQTY    = [F:SOQ]ALLQTYSTU
           WQTY1 = 0 : WQTY2 = 0
           Call DIMALL(2, [F:SOQ]SOHNUM, [F:SOQ]SOPLIN, [F:SOQ]SOQSEQ, [F:SOQ]ITMREF, 1 , WQTY, WQTY1, WQTY2,WRET) From STKALL
           If WRET <> 0 : GOK=0 : Break : Endif

           WCHGALL = 2
           WQTE2-= WQTY1
           WSHTQTY-= WQTY2
        Endif

        # GH 27/06/2017 Issue 38509 - consider WSTJQTY and not anymore [F:STJ]QTYSTU
#       If WQTERES > WSTJQTY
#          WQTE1 = [F:STJ]QTYSTU
#       Else
#          WQTE1 = WQTERES
#       Endif
        WQTE1 = min(WQTERES,WSTJQTY)
        WQTERES-= WQTE1

        # qté en ua (GBIDD1)
        GBIDD1 = WQTE1
        Case [F:PTD]STOMGTCOD
            When 3 : If [F:STJ]POT <> 0
                         GBIDD1 = WQTE1*[F:STJ]POT/100
                     Endif
            When 4 : If [F:STJ]ACT <> 0
                        GBIDD1 = WQTE1*[F:STJ]ACT
                     Endif
        Endcase
        Call QTEARR(GBIDD1,[F:STJ]STU) From TRTDIV
        Raz GBIDC1

        #--- TS 106217 ajout paramètre LECC (avant dernier)
        Call CREALL(2,[F:STJ]STOFCY,[F:STJ]ITMREF,WSTOCOU,[F:PTD]RCPDAT,WQTE1,
&                   GBIDD1,2,[F:SOQ]SOHNUM,[F:SOQ]SOPLIN,[F:SOQ]SOQSEQ,GBIDC1,[F:SOQ]SHIDAT,
&                   "","","","","","",0,0,WDEFLOC,WDEFLOCTYP,"","",1,"",WRETOUR) From STKALL
        If WRETOUR <> 0 : GOK = 0 : Break : Endif
        WQTE2+= WQTE1
        SAV_WALLQTY+= WQTE1       # GH 23/07/2013 bug 87805

$NXT_STJ_SOF
    Next
    If GOK < 1 : Return : Endif

   # GH 23/07/2013 bug 87805
    If SAV_WALLQTY <> 0  : # WCHGALL=2
       If WCHGALL : WQTY = [F:SOQ]SHTQTYSTU : # suppression du manquant global  # GH 31/07/13 Bug 90797
       Else       : WQTY = SAV_WALLQTY      : # diminution du manquant détail
       Endif
       If WQTY<>0
          WQTY1 = 0 : WQTY2 = 0
          Call DIMALL(2, [F:SOQ]SOHNUM, [F:SOQ]SOPLIN, [F:SOQ]SOQSEQ, [F:SOQ]ITMREF, 2, WQTY, WQTY1, WQTY2,WRET) From STKALL
          If WRET <> 0 : Return : Endif
          WSHTQTY-= WQTY2
       Endif

       If WCHGALL
          # GH 31/07/13 Bug 90797 : # allocation en détaillé
          Local Libelle WIMPCLI, WGENSHT
          Local Char    WPARAM(1)
          Call PARAM([F:SOQ]SALFCY,"USERERBPC",WPARAM) From ADOVAL : WIMPCLI=min(2,val(WPARAM))
          If find([F:SOP]LINTYP,2,3,4,5,10,11,12,13)
             WGENSHT=2
          Else
             Call PARAM([F:SOQ]STOFCY,"GENSHT",WPARAM) From ADOVAL : WGENSHT=val(WPARAM)
          Endif

          [F:SOQ]ALLTYP = 2

          WSHTQTY+= [F:SOQ]SHTQTYSTU-SAV_WALLQTY
          ## GH 23/06/14 Bug 100441
          If WSHTQTY<0 : WSHTQTY=0 : Endif
          If WSHTQTY<>0 & WGENSHT=2 : # GH 23/06/14 Bug 100441
             # Création du manquant détail
             #--- TS 106217 ajout paramètre LECC (avant dernier)
             Call CREALL(4,[F:SOQ]STOFCY,[F:SOQ]ITMREF,0,[31/12/2999],0,
&                        WSHTQTY,2,[F:SOQ]SOHNUM,[F:SOQ]SOPLIN,[F:SOQ]SOQSEQ,"",max(date$,[F:SOQ]SHIDAT),
&                        [F:SOQ]LOT,"",[F:SOQ]STA,WDEFLOC2,"","",0,0,"","","","",1,[F:SOQ]ECCVALMAJ,WRET) From STKALL
             If WRET <> 0 : Return : Endif
          Endif
          ##

          If [F:SOQ]ALLQTYSTU<>0
              WQTY = [F:SOQ]ALLQTYSTU : WQTY2 = 0
              Call GENALLORD("","","C", WIMPCLI, WGENSHT, 0, WQTY, WQTY2, WRET) From TRTVENALL
              If WRET <> 0 : Return : Endif
              WQTE2+= WQTY
              WSHTQTY+= WQTY2
          Endif

          # WCHGALL = 3
       Endif
    Endif

Endif
If WRETOUR <> 0     : Return : Endif
If SAV_WALLQTY = 0  : Return : Endif

#----- Si entête commande bloquée logiquement --> abandon -----#
SYMBOLE = "SOH"+[F:SOQ]SOHNUM
Lock =SYMBOLE With lockwait=0
If fstat
   # Commande client ... Modification en cours sur un autre poste
   GMESSAGE=mess(1,306,1)-[F:SOQ]SOHNUM+"\"+mess(10,100,1) : GERR=1
   GOK=0 : Return
Endif

#----- Lecture entête et ligne commande avec blocage physique -----#
Readlock [SOH]SOH0=[M:MLIK]DEMNUM
#----- Pas de màj et pas d'erreur en import si commande n'existe pas -----#
If GIMPORT & fstat
    Raz [F:SOH] : Goto MAJ_FIN
Elsif fstat = 1
    GOK = -1 : GLOCK = "$SORDER"-[M:MLIK]DEMNUM : Goto MAJ_FIN
Elsif fstat
    GOK = 0 : Call RSTA("SOH",[M:MLIK]DEMNUM) From GLOCK : Goto MAJ_FIN
Endif

#----- Mise à jour ligne de commande quantité [F:POQ] -----#
Readlock [SOQ]SOQ0=[M:MLIK]DEMNUM;[M:MLIK]DEMLIN;[M:MLIK]DEMSEQ
If fstat = 1
    GOK = -1 : GLOCK = "$SORDERQ"-[M:MLIK]DEMNUM-num$([M:MLIK]DEMLIN) : Goto MAJ_FIN
Elsif fstat
    GOK = 0 : Call RSTA("SOQ",[M:MLIK]DEMNUM-num$([M:MLIK]DEMLIN)) From GLOCK : Goto MAJ_FIN
Endif

#[F:SOQ]SHTQTY    = WSHTQTY : # GH 14/09/2012 bug 81610
[F:SOQ]SHTQTYSTU = WSHTQTY

If [F:SOH]SOHCAT = 3
    WQTE1 = [F:SOQ]INVQTYSTU
Else
    WQTE1 = [F:SOQ]DLVQTYSTU
Endif
If [F:SOQ]ALLQTYSTU + [F:SOQ]ODLQTYSTU + WQTE1 >= [F:SOQ]QTYSTU &
&  [F:SOQ]SHTQTYSTU = 0 & ([F:SOQ]STOMGTCOD <> 1  | find([F:SOP]LINTYP,2,10))
#--- La ligne etait allouée
    GBIDI2 = 2
Else
# --- La ligne n'etait pas allouée
    GBIDI2 = 1
Endif

#-----------------------------------------#
# mise à jour détail de commande de vente #
#-----------------------------------------#
#-- WQTE2 contient la quantité allouée ou désallouée réellement
[F:SOQ]ALLQTYSTU+= WQTE2
If [F:SOQ]ALLQTYSTU < 0 : [F:SOQ]ALLQTYSTU = 0 : Endif

#-------- lecture SORDERP pour recuperer UV ----#
If [F:SOP]SAU <> [F:SOP]STU
    GBIDD1 = WQTE2*(1/[F:SOP]SAUSTUCOE)
    Call QTEARR(GBIDD1, [F:SOP]SAU) From TRTDIV
    [F:SOQ]ALLQTY+= GBIDD1
Else
    [F:SOQ]ALLQTY+= WQTE2
Endif
If [F:SOQ]ALLQTY < 0 : [F:SOQ]ALLQTY = 0 : Endif

# GH 14/09/2012 bug 81610
If [F:SOP]SAU = [F:SOP]STU
    [F:SOQ]SHTQTY =  WSHTQTY
Else
    GBIDD1 =  WSHTQTY*(1/[F:SOP]SAUSTUCOE)
    Call QTEARR(GBIDD1, [F:SOP]SAU) From TRTDIV
    [F:SOQ]SHTQTY = GBIDD1
Endif

[F:SOQ]ALLTYP = 2

Rewrite [SOQ]
If fstat
    GOK = 0 : Call FSTA ("SOQ") From GLOCK : Goto MAJ_FIN
Endif

# GH 04/05/2016 bug 111768 : reimplementation of the entry point MAJCTMALL previously in SUBPTHA.$MAJ_ALLOC_CTM
GPOINT="MAJSOFALL" : Gosub ENTREE From EXEFNC
If GOK<1 : Goto MAJ_FIN : Endif

# La ligne est passée du statut non alloué au statut alloué
# If [F:SOQ]ALLQTYSTU + [F:SOQ]ODLQTYSTU >= [F:SOQ]QTYSTU # Issue 117459 GH 07/12/16 - WQTE1 has to be considered
If [F:SOQ]ALLQTYSTU + [F:SOQ]ODLQTYSTU + WQTE1 >= [F:SOQ]QTYSTU &
&  [F:SOQ]SHTQTYSTU = 0 & ([F:SOQ]STOMGTCOD <> 1 | find([F:SOP]LINTYP,2,10)) & GBIDI2 = 1
    GBIDI3 = -1
# La ligne a passé du statut alloué au statut non alloué
# If [F:SOQ]ALLQTYSTU + [F:SOQ]ODLQTYSTU < [F:SOQ]QTYSTU # Issue 117459 GH 07/12/16 - WQTE1 has to be considered
Elsif ([F:SOQ]ALLQTYSTU + [F:SOQ]ODLQTYSTU + WQTE1 < [F:SOQ]QTYSTU
&       | [F:SOQ]SHTQTYSTU <> 0) & ([F:SOQ]STOMGTCOD <> 1  | find([F:SOP]LINTYP,2,10))
&       &  GBIDI2 = 2
    GBIDI3 = 1
Else
# La ligne n'a pas changé d'état
    GBIDI3 = 0
Endif
#-----------------------------------------#
# mise à jour entete de commande de vente #
#-----------------------------------------#
If GBIDI3 <> 0 : # la ligne a changé d'état
    [F:SOH]ALLLINNBR+= GBIDI3
Endif
If [F:SOH]ALLLINNBR <= 0
    [F:SOH]ALLLINNBR = 0
    [F:SOH]ALLSTA = 3
Elsif [F:SOH]ALLLINNBR < [F:SOH]LINNBR | [F:SOQ]ALLQTY <> 0
    [F:SOH]ALLSTA = 2
Else
    [F:SOH]ALLSTA = 1
Endif
Rewrite [SOH]
If fstat : GOK=0 : Call FSTA ("SOH") From GLOCK : Goto MAJ_FIN : Endif

#   Si Composé de kit/sous-traité, il faut allouer les composants
If find([F:SOP]LINTYP,2,10) & WQTE2 <> 0
    Local Char WSOQ_TRTLIG
    Local Decimal WSOQ_ALLSTU
    If WQTE2<0
        # --- C'est une diminution/annulation de l'allocation
        WSOQ_TRTLIG = "D"
        WSOQ_ALLSTU = -WQTE2
    Else
        # --- C'est une augmentation de l'allocation
        If [F:SOQ]ALLQTYSTU=WQTE2 : WSOQ_TRTLIG="C" : Else WSOQ_TRTLIG="M" : Endif
        WSOQ_ALLSTU = [F:SOQ]ALLQTYSTU
    Endif
    # Récupération du paramètre vente : USERERBPC : Consommation réservations clients
    Local Char WSOQ_PARAM(10) : Call PARAM([F:SOH]SALFCY,"USERERBPC",WSOQ_PARAM) From ADOVAL
    Call GENALLKIT ([F:SOH]SOHNUM, [F:SOQ]SOPLIN, [F:SOQ]SOQSEQ, WSOQ_TRTLIG, val(WSOQ_PARAM), 2, 0, 1, 0,
&                   WSOQ_ALLSTU, WRETOUR) From TRTVENALL
    If WRETOUR <> 0 : GOK = 0 : Goto MAJ_FIN : Endif
Endif
#--------------------------------------#
# Màj de l'encours SOF ou TPF (ventes) #
#--------------------------------------#

[M:ORDK]MAJCOD = "M"
If [F:SOH]BETFCY = 2 & [F:SOH]BETCPY <> 2
    [M:ORDK]WIPTYP = 8
Else
    [M:ORDK]WIPTYP = 1
Endif
[M:ORDK]WIPSTA    = [F:SOQ]DEMSTA
[M:ORDK]WIPNUM    = [F:SOQ]DEMNUM
[M:ORDK]ITMREF    = [F:SOQ]ITMREF
[M:ORDK]ORIFCY    = [F:SOH]SALFCY
[M:ORDK]STOFCY    = [F:SOQ]STOFCY
[M:ORDK]PJT       = [F:SOH]PJT
[M:ORDK]BPRNUM    = [F:SOH]BPCORD
[M:ORDK]STRDAT    = [F:SOQ]ORDDAT
[M:ORDK]ENDDAT    = [F:SOQ]SHIDAT
[M:ORDK]VCRTYP    = 2
[M:ORDK]VCRNUM    = [F:SOQ]SOHNUM
[M:ORDK]VCRLIN    = [F:SOQ]SOPLIN
[M:ORDK]VCRSEQ    = [F:SOQ]SOQSEQ
[M:ORDK]EXTQTY    = [F:SOQ]QTYSTU
If [F:SOH]SOHCAT = 3
    [M:ORDK]CPLQTY = [F:SOQ]INVQTYSTU
Else
    [M:ORDK]CPLQTY = [F:SOQ]DLVQTYSTU
Endif

## GH 02/07/2014 bug 93888
# [M:ORDK]ALLQTY  = [F:SOQ]ALLQTYSTU + [F:SOQ]ODLQTYSTU
# [M:ORDK]SHTQTY  = [F:SOQ]SHTQTYSTU
Raz WALL, WSHT
If [F:SOQ]OPRQTYSTU+[F:SOQ]PREQTYSTU>0
   Gosub WIP_ALLSHT From TRTVENMAJ
Endif
[M:ORDK]ALLQTY  = [F:SOQ]ALLQTYSTU + WALL + [F:SOQ]ODLQTYSTU
[M:ORDK]SHTQTY  = [F:SOQ]SHTQTYSTU + WSHT
##

## GH 04/07/13 bug 89781
# [M:ORDK]FMI       = 3
# [M:ORDK]ABBFIL    = "SOQ"
If [F:SOH]SOHCAT = 4
   [M:ORDK]ABBFIL  = "SOC"
   [M:ORDK]FMI     = 1
Else
   [M:ORDK]ABBFIL  = "SOQ"
   [M:ORDK]FMI     = [F:SOQ]FMI
Endif
##

[M:ORDK]MRPMES    = 1
[M:ORDK]VCRTYPORI = 0
[M:ORDK]VCRNUMORI = ""
[M:ORDK]VCRLINORI = 0
[M:ORDK]VCRSEQORI = 0
[M:ORDK]BOMALT    = 0
[M:ORDK]ORI       = 2
Call WIP From TRTWIP
If GOK < 1 : GMESSAGE=mess(013,100,1)-"ORDERS:"-[F:SOQ]DEMNUM : Goto MAJ_FIN : Endif

# 76887 sauvegarde du cumul alloué
If [M:MLIK]MAJCOD = "E" : ENT_CUMALLQTY+= SAV_WALLQTY : Endif

Goto MAJ_FIN

#----- Déblocage logique de la commande de vente / Ordre de fabrication / Ordre de sous-traitance -----#
$MAJ_FIN
Unlock = SYMBOLE
Return

# Process PJM demands (X3-70716)
$MAJ_PJM

  Local Integer IRET
  Local Integer ILINTAS
  Local Integer ILINRITT
  Local Char SKEYCONCAT(GLONPIM)
  Local Char PROJECT(GLONPIM)
  Local Char BUDGET(GLONPBU)
  Local Char TASK(GLONTAC)
  Local Char SMESSAGE(250)
  Local Integer WCHGALL
  Local Tinyint WIMPCLI
  Local Tinyint WGENSHT
  Local Char WPARAM(1)
  Local Char LOT(30)
  Local Char STA(30)
  Local Char SECCVALMAJ(GLONECS)
  Local Instance ZINSPJM Using C_OPPOR           # Project
  Local Instance ZTECALLITM Using C_TECALLITM

  ZINSPJM = NewInstance C_OPPOR AllocGroup null

  IRET = func PJMTSK_CSTD_PROGS.GET_KEYCONCAT_FROM_TASNUM(ZINSPJM.ACTX, [M:MLIK]DEMNUM, SKEYCONCAT, SMESSAGE)# Determine project+task from task number
  IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(ZINSPJM.ACTX, SKEYCONCAT, PROJECT, BUDGET, TASK)                # Split project+task into project, (budget) and task
  ZINSPJM.TCHTOREAD = "PJM"
  IRET = fmet ZINSPJM.AREAD(PROJECT)
  ILINTAS = fmet ZINSPJM.PJM(1).TAS_GET_INDEX(TASK)
  ILINRITT = fmet ZINSPJM.PJM(1).TAS(ILINTAS).RITT_GET_INDEX_ITMREF([M:MLIK]ITMREF)
  If ILINRITT = 0 Then
    Goto MAJ_FIN_PJM
  Endif

If ([M:MLIK]MAJCOD = "S")
  For [STJ] STJ1 Where STOFCY = [F:PTD]PRHFCY
&                    & VCRTYP=6
&                    & VCRNUM = [F:PTD]PTHNUM
&                    & VCRLIN = [F:PTD]PTDLIN
&                    & REGFLG <> 2
&                    & TRSTYP <> 29

    Raz WSTOCOU
    Call CLESTO([F:STJ]STOFCY,[F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,[F:STJ]BPSLOT,
&               [F:STJ]PALNUM,[F:STJ]CTRNUM,[F:STJ]STA,[F:STJ]LOC,[F:STJ]PCU,
&               [F:STJ]PCUSTUCOE,[F:STJ]SERNUM,[F:STJ]QLYCTLDEM,[F:STJ]OWNER,[F:STJ]STOFLD1,
&               [F:STJ]STOFLD2,WSTOCOU) From STKLIB
      If GOK < 1
        Break
      Endif

      For [STA]STA1 Where VCRTYP = 2
&                       & STOCOU = WSTOCOU
&                       & VCRNUM = [M:MLIK]DEMNUM
&                       & VCRLIN = [M:MLIK]DEMLIN
&                       & VCRSEQ = [M:MLIK]DEMSEQ
        Call SUPALL([F:STA]STOFCY,[F:STA]ITMREF,[F:STA]STOCOU,[F:STA]SEQ,WRETOUR) From STKALL
        If (WRETOUR <> 0)
          GOK = 0
          Break
        Endif
        WQTE2 -= [F:STA]QTYSTU
        SAV_WALLQTY -= [F:STA]QTYSTU
      Next

      If (GOK < 1)
        Break
      Endif
    Next

    If (GOK < 1)
      Goto MAJ_FIN_PJM
    Endif
Else
  # Calculate shortage qty. and qty. to allocate
  #
  WSHTQTY = ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).SHTQTY
  WQTERES = ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).WALLQTY
  If (WQTERES <= 0)
    Goto MAJ_FIN_PJM
  Endif

  If (WQTERES > [M:MLIK]LIKQTY)
    WQTERES = [M:MLIK]LIKQTY
  Endif
  If (WQTERES <= 0)
    Goto MAJ_FIN_PJM
  Endif

  If (WQTERES >= [F:PTD]QTYSTU)
    WQTERES = [F:PTD]QTYSTU
  Endif
  Gosub POINT_CHGALLQTY From SUBPTHA
  If (WQTERES > [F:PTD]QTYSTU)
    WQTERES = [F:PTD]QTYSTU
  Endif

  # Note:- project task product quantities = stock unit, no conversion necessary

  # Determine the exclusive consumption location/location type
  #
  Raz WDEFLOC, WDEFLOCTYP
  Call RECH_PICLOC(2,
&                      ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).STOFCY,
&                      ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).ITMREF,
&                      AVOID.ACHAR,AVOID.ACHAR,1,1,"O",WDEFLOC,WDEFLOCTYP) From STKALL
  Raz WDEFLOC2, WDEFLOCTYP2
  Call RECH_PICLOC(-2,
&                      ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).STOFCY,
&                      ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).ITMREF,
&                      AVOID.ACHAR,AVOID.ACHAR,1,1,"O",WDEFLOC2,WDEFLOCTYP2) From STKALL

  # Change project task product allocation type from global to detailed (if no existing allocations)
  #
  WCHGALL = (ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).ALLTYP = 1)
  If (WCHGALL = [V]CST_ATRUE & ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).ALLQTY = 0)
    WCHGALL = 2
  Endif

  WENTCUMALLQTY = ENT_CUMALLQTY

  # Filter 'receipt' (STOJOU stock journal) records for processing
  #
  For [STJ]STJ1 Where STOFCY = [F:PTD]PRHFCY
&                    & VCRTYP = 6
&                    & VCRNUM = [F:PTD]PTHNUM
&                    & VCRLIN = [F:PTD]PTDLIN
&                    & REGFLG <> 2
&                    & TRSTYP <> 29
    If (WQTERES <= 0)
      Break
    Endif

    # Check 'receipt' location/location type matches exclusive consumption location/location type, or
    # blank
    #
    If (!find(WDEFLOC2,AVOID.ACHAR,[F:STJ]LOC))
      Goto NEXT_STJ_PJM
    Endif
    If (!find(WDEFLOCTYP2,AVOID.ACHAR,"*"))
      If (!clalev([F:STC]))
        Local File STOLOC [STC]
      Endif
      Read [STC]STC0 = [F:STJ]STOFCY;[F:STJ]LOC
      If (fstat | pat([F:STC]LOCTYP,WDEFLOCTYP2) = 0)
        Goto NEXT_STJ_PJM
      Endif
    Endif

    # Determine the chronological stock value WSTOCOU (STOCK stock)
    #
    WSTOCOU=0
    Call CLESTO([F:STJ]STOFCY,[F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,[F:STJ]BPSLOT,
&               [F:STJ]PALNUM,[F:STJ]CTRNUM,[F:STJ]STA,[F:STJ]LOC,[F:STJ]PCU,
&               [F:STJ]PCUSTUCOE,[F:STJ]SERNUM,[F:STJ]QLYCTLDEM,[F:STJ]OWNER,
&               [F:STJ]STOFLD1,[F:STJ]STOFLD2,WSTOCOU) From STKLIB
    If (WSTOCOU = 0)
      Goto NEXT_STJ_PJM
    Endif

    # Maintain WENTCUMALLQTY (ENT_CUMALLQTY)
    #
    If ([F:STJ]QTYSTU <= WENTCUMALLQTY)
      WSTJQTY = 0
      WENTCUMALLQTY-= [F:STJ]QTYSTU
    Else
      WSTJQTY = [F:STJ]QTYSTU - WENTCUMALLQTY
      WENTCUMALLQTY = 0
    Endif
    If (WSTJQTY <= 0)
      Goto NEXT_STJ_PJM
    Endif

    # 'Suppress' shortages (project task product allocation type = global)
    #
    If (WCHGALL = 1)
      WQTY = ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).ALLQTY
      WQTY1 = 0
      WQTY2 = 0
      Call DIMALL(2,[M:MLIK]DEMNUM,[M:MLIK]DEMLIN,[M:MLIK]DEMSEQ,ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).ITMREF,
&                 1,WQTY,WQTY1,WQTY2,WRET) From STKALL
      If (WRET <> 0)
        GOK = 0
        Break
      Endif
      # Change project task product allocation type from global to detailed
      #
      WCHGALL = 2
      WQTE2 -= WQTY1
      WSHTQTY -= WQTY2
    Endif

    WQTE1 = min(WQTERES,WSTJQTY)
    WQTERES -= WQTE1

    # Apply potency of receipt
    #
    GBIDD1 = WQTE1
    Case [F:PTD]STOMGTCOD
      When 3 : If ([F:STJ]POT <> 0)
                 GBIDD1 = WQTE1 * [F:STJ]POT / 100
               Endif
      When 4 : If ([F:STJ]ACT <> 0)
                 GBIDD1 = WQTE1 * [F:STJ]ACT
               Endif
    Endcase
    Call QTEARR(GBIDD1,[F:STJ]STU) From TRTDIV
    Raz GBIDC1

    # Create allocation - detailed
    #
    # NB.- ZPJMTSK.RITT(RITTROW).REQDAT = requirement date
    Call CREALL(2,[F:STJ]STOFCY,[F:STJ]ITMREF,WSTOCOU,[F:PTD]RCPDAT,
&               WQTE1,GBIDD1,2,[M:MLIK]DEMNUM,[M:MLIK]DEMLIN,
&               [M:MLIK]DEMSEQ,GBIDC1,ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).REQDAT,AVOID.ACHAR,AVOID.ACHAR,
&               AVOID.ACHAR,AVOID.ACHAR,AVOID.ACHAR,AVOID.ACHAR,0,
&               0,WDEFLOC,WDEFLOCTYP,AVOID.ACHAR,AVOID.ACHAR,
&               1,AVOID.ACHAR,WRETOUR) From STKALL
    If (WRETOUR <> 0)
      GOK = 0
      Break
    Endif
    WQTE2 += WQTE1
    SAV_WALLQTY += WQTE1

$NEXT_STJ_PJM
  Next
  If (GOK < 1)
    Goto MAJ_FIN_PJM
  Endif

  # 'Suppress' shortages
  #
  If (SAV_WALLQTY <> 0)
    If (WCHGALL)
      WQTY = ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).SHTQTY
    Else
      WQTY = SAV_WALLQTY
    Endif
    If (WQTY<>0)
      WQTY1 = 0
      WQTY2 = 0
      Call DIMALL(2,[M:MLIK]DEMNUM,[M:MLIK]DEMLIN,[M:MLIK]DEMSEQ,ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).ITMREF,
&                 2,WQTY,WQTY1,WQTY2,WRET) From STKALL
      If (WRET <> 0)
        Goto MAJ_FIN_PJM
      Endif
      WSHTQTY -= WQTY2
    Endif

    # Create allocation - detailed shortage (shortage remains)
    #
    If (WCHGALL)
      WIMPCLI = min(2,ZINSPJM.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY,ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).STOFCY,"USERERBPC"))
      WGENSHT = val(ZINSPJM.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFCY,ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).STOFCY,"GENSHT"))

      WSHTQTY += ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).SHTQTY - SAV_WALLQTY
      If (WSHTQTY < 0)
        WSHTQTY=0
      Endif
      If (WSHTQTY <> 0 & WGENSHT = 2)
        # Create (shortage) allocation - detailed
        #
        # NB.- ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).REQDAT = requirement date
        # NB.- REQDAT is not available in V11 use TASENDDT
        # NB.- LOT = filter lot; STA = filter status
        Raz LOT
        Raz STA
        Call CREALL(4,ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).STOFCY,ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).ITMREF,0,[31/12/2999],
&                   0,WSHTQTY,2,[M:MLIK]DEMNUM,[M:MLIK]DEMLIN,
&                   [M:MLIK]DEMSEQ,AVOID.ACHAR,max(date$,ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).REQDAT),LOT,AVOID.ACHAR,
&                   STA,WDEFLOC2,AVOID.ACHAR,AVOID.ACHAR,0,
&                   0,AVOID.ACHAR,AVOID.ACHAR,AVOID.ACHAR,AVOID.ACHAR,
&                   1,ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).ECCVALMAJ,WRET) From STKALL
        If (WRET <> 0)
          Goto MAJ_FIN_PJM
        Endif
      Endif
      If (ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).ALLQTY <> 0)
        WQTY = ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).ALLQTY
        WQTY2 = 0
        Call GENALLORD(AVOID.ACHAR,AVOID.ACHAR,"C",WIMPCLI,WGENSHT,
&                      0,WQTY,WQTY2,WRET) From TRTVENALL
        If (WRET <> 0)
          Goto MAJ_FIN_PJM
        Endif
        WQTE2 += WQTY
        WSHTQTY += WQTY2
      Endif
    Endif
  Endif
Endif

If (WRETOUR <> 0)
  Goto MAJ_FIN_PJM
Endif
If (SAV_WALLQTY = 0)
  Goto MAJ_FIN_PJM
Endif

##############
# Update PJM #
##############
  ZTECALLITM = NewInstance C_TECALLITM AllocGroup null
  # MANUF_ADD_LINE: Add project, product, unit(project task product), allocated quantity to
  #                 TECALLITM parameters class collection..
  IRET = fmet ZTECALLITM.MANUF_ADD_LINE(SKEYCONCAT,ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).ITMREF,ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).UOM,WQTE2)
  # PJM_TASK_RITT_ALLOCATION: Update project from TECALLITM parameters class collection..
  IRET = fmet ZINSPJM.PJM_TASK_RITT_ALLOCATION(ZINSPJM.OPPNUM,ZTECALLITM)
  If (IRET >= CST_AWARNING)
    If (func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(ZINSPJM,GMESSAGE) = CST_AWARNING)
      GERR = 2
    Else
      GOK = 0
      GERR = 1
    Endif
  Endif
  If (GOK < 1)
    Goto MAJ_FIN_PJM
  Endif

#################
# Update ORDERS #
#################
[M:ORDK]MAJCOD    = "M"
[M:ORDK]WIPTYP    = 14  # Project demand
[M:ORDK]WIPSTA    = 1   # 1=Firm, 2=Planned, 3=Suggested, 4=Closed
[M:ORDK]WIPNUM    = ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).WIPNUM
[M:ORDK]ITMREF    = ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).ITMREF
[M:ORDK]ORIFCY    = ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).STOFCY
[M:ORDK]STOFCY    = ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).STOFCY
[M:ORDK]PJT       = SKEYCONCAT
# Customer
If ZINSPJM.OPPCMP <> AVOID.ACHAR Then
  [M:ORDK]BPRNUM  = ZINSPJM.OPPCMP
Else
  Raz [M:ORDK]BPRNUM
Endif
[M:ORDK]STRDAT    = ZINSPJM.PJM(1).TAS(ILINTAS).TASSTARTDT
[M:ORDK]ENDDAT    = ZINSPJM.PJM(1).TAS(ILINTAS).TASENDDT
[M:ORDK]VCRTYP    = 40  # Project
[M:ORDK]VCRNUM    = [M:MLIK]DEMNUM
[M:ORDK]VCRLIN    = [M:MLIK]DEMLIN
[M:ORDK]VCRSEQ    = [M:MLIK]DEMSEQ
[M:ORDK]EXTQTY    = ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).ITTQTY
[M:ORDK]CPLQTY    = ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).DLVQTY
[M:ORDK]ALLQTY    = ZINSPJM.PJM(1).TAS(ILINTAS).RITT(ILINRITT).ALLQTY + WQTE2
[M:ORDK]SHTQTY    = WSHTQTY
[M:ORDK]MRPMES    = 1
[M:ORDK]VCRTYPORI = 0
[M:ORDK]VCRNUMORI = AVOID.ACHAR
[M:ORDK]VCRLINORI = 0
[M:ORDK]VCRSEQORI = 0
[M:ORDK]BOMALT    = 0
[M:ORDK]ORI       = 7
[M:ORDK]PIO       = 1
[M:ORDK]ABBFIL    = AVOID.ACHAR
[M:ORDK]FMI       = 1

Call WIP From TRTWIP
If (GOK < 1)
  GMESSAGE = mess(013,100,1)-"ORDERS:"-[M:MLIK]DEMNUM
Elsif ([M:MLIK]MAJCOD = "E")
  ENT_CUMALLQTY+= SAV_WALLQTY
Endif

$MAJ_FIN_PJM
  If ZTECALLITM <> null Then
    FreeGroup ZTECALLITM
    Raz ZTECALLITM
  Endif
  If ZINSPJM <> null Then
    FreeGroup ZINSPJM
    Raz ZINSPJM
  Endif

Return

