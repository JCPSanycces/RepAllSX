################################################################################
#    SOUS-PROGRAMMES COMMUNS A LA GESTION DES ECARTS ENTRE PLANS
#*********************************************************************
#    Modification
#   MDJ   24.10.2013 - FQ93596 - Amélioration performances
#   CBO   28.05.2013 - FQ88911- ajout IS_LNK_POSTED_PLNS_CNX
#   MDJ   07.03.2013 - FQ88510- ajout test dans IS_LNK_POSTED_ISS_FUTURE : rowcount([LIEN]) > 0 car plantage si pas d'enreg. trouvé
#   MDJ   08.08.2012 - FQ81074 - Optimisation suite SPIKE Performances contextes
# - GLE - 24.09.2010 - FQ67557 - Optimisation de la fonction IS_LNK_POSTED_ISS_FUTURE (ajout de l'index DEP8 sur DEPREC)
###############################################################################
End

##########################################################################
# Permet de savoir si un contexte donné n'a pas de "A comptabiliser"
# en attente sur ses DEPREC pour les écarts entre plans
#
# Renvoie G_OUI si le contexte est comptabilisé, G_NON sinon
##########################################################################
Funprog IS_LNK_POSTED(PCPY, PCNX, PDATENDFIY, PDATENDPER)
Value Char       PCPY
Value Integer    PCNX
Value Date       PDATENDFIY
Value Date       PDATENDPER

  Local Integer RTLSTPLN(1)    # Tableau bidon.
  Local Integer RTLSTNBE(1)    # Tableau bidon

End func GLOLNK.IS_LNK_POSTED_FILLTAB(PCPY, PCNX, 1, "", PDATENDFIY, PDATENDPER, RTLSTPLN, RTLSTNBE)

##########################################################################
# Permet de savoir si un contexte donné n'a pas de "A comptabiliser"
# en attente sur ses DEPREC pour les écarts entre plans
#
# S'il y a du à comptabilisé, renvoie le tableau des plans avec le
# nombre d'écarts non compatbilisés
##########################################################################
Funprog IS_LNK_POSTED_FILLTAB(PCPY, PCNX, PFILLTAB, PPNAME, PDATENDFIY, PDATENDPER, TLSTPLN, TLSTNBE)
Value Char       PCPY
Value Integer    PCNX
Value Integer    PFILLTAB     # Type d'alimentation :
                              #    (1) : Oui ou Non tous les événements sont comptabilisés
                              #    (2) : alimente les tableaux TLSTxxx
                              #    (3) : appelle l'étiquette IS_LNK_POSTED_FILLTAB du traitement PPNAME
Value    Char    PPNAME       # Nom du programme à appeler dans la boucle principale
Value Date       PDATENDFIY
Value Date       PDATENDPER
Variable Integer TLSTPLN()    # Tableau des plans pour lesquels il reste des événements non comptabilisés.
Variable Integer TLSTNBE()    # Tableau des compteurs d'événements non comptabilisés

  Local Char    CRITERE(255)
  Local Integer RRET    : RRET = G_OUI
  Local Integer N_PLN
  Local Integer N_COUNT
  Local Integer N_FILL  : N_FILL = 0

  If !clalev([F:WCNX]) : Local File CONTEXT  [WCNX] : Endif
  If !clalev([F:WFIS]) : Local File FISCYEAR [WFIS] : Endif
  If !clalev([F:WDEP]) : Local File DEPREC   [WDEP] : Endif

  Read [WCNX]CNX0=PCPY;PCNX
  Read [WFIS]FIY2=PCPY;PCNX;PDATENDFIY

  For N_PLN=0 To [F:WCNX]NBPLC-1
    If func SUBTPE.LNK_COMPTABILISE([F:WCNX]CPY, [F:WCNX]PLNCAA(N_PLN), G_OUI) = G_OUI Then
     If [F:WCNX]LNKPLN(N_PLN)<>0
       If [F:WFIS]TYPPST([F:WFIS]INDCURPER-1) = GVML_TPSTDEF or [F:WFIS]DATENDPER([F:WFIS]INDCURPER-1) = [F:WFIS]DATENDFIY Then
         If [F:WFIS]DATENDPER([F:WFIS]INDCURPER-1) = [F:WFIS]DATENDFIY Then
           # Sur la dernière période de l'exercice, on contrôle que toutes les dotations de l'exercice sont comptabilisées
           #93596CRITERE="FLGLNKDEV=G_OUI&CPY=[F:WCNX]CPY&FIYENDDAT=[F:WFIS]DATENDFIY&DPRPLN=[F:WCNX]PLNCAA(N_PLN)"
           CRITERE="CPY=[F:WCNX]CPY&FLGLNKDEV=G_OUI&CNX=[F:WCNX]CNX&FIYENDDAT=[F:WFIS]DATENDFIY&PERENDDAT=PDATENDPER&DPRPLN=[F:WCNX]PLNCAA(N_PLN)"
         Else
           # Sur une période lambda, seules la comptabilisation des dotations de la période est contrôlée.
           CRITERE="FLGLNKDEV=G_OUI&CPY=[F:WCNX]CPY&FIYENDDAT=[F:WFIS]DATENDFIY&PERENDDAT=[F:WFIS]DATENDPER([F:WFIS]INDCURPER-1)&DPRPLN=[F:WCNX]PLNCAA(N_PLN)"
         Endif

         Filter [WDEP] Where evalue(CRITERE)
         N_COUNT = rowcount([F:WDEP])

         If N_COUNT > 0
           RRET = G_NON
           Case PFILLTAB
             When 1 :
               Break
             When 2 :
               TLSTPLN(N_FILL) = [F:WCNX]PLNCAA(N_PLN)
               TLSTNBE(N_FILL) = N_COUNT
               N_FILL += 1
             When 3 :
               Gosub IS_LNK_POSTED_FILLTAB From =PPNAME
           Endcase
         Endif

         Filter [WDEP]

         If PFILLTAB = G_NON & RRET = G_NON : Break : Endif
       Endif
     Endif
    Endif
  Next N_PLN
End RRET

##########################################################################
# Vérification qu'il n'existe pas, pour les biens sortis dans l'exercice,
# du "A comptabiliser" pour les écarts entre plans
# sur des périodes futures en comptabilisation définitives
#
# Renvoie G_OUI si le contexte est comptabilisé pour ces biens, G_NON sinon
##########################################################################
Funprog IS_LNK_POSTED_ISS_FUTURE(PCPY, PCNX)
Value Char    PCPY
Value Integer PCNX

  Local Integer RRET    : RRET = G_OUI
  Local Integer N_PER

  If !clalev([F:WFAS]) : Local File FXDASSETS [WFAS] : Endif
  If !clalev([F:WDEP]) : Local File DEPREC    [WDEP] : Endif
  If !clalev([F:WFIS]) : Local File FISCYEAR  [WFIS] : Endif
  If !clalev([F:WFI2]) : Local File FISCYEAR  [WFI2] : Endif

  Read [WFIS]FIY1=PCPY;PCNX;GVML_TECOURA
  Read [WFI2]FIY1=PCPY;PCNX;GVML_TESUIV

  For N_PER = 0 To [F:WFI2]NBRPER-1
    If [F:WFI2]TYPPST(N_PER) = GVML_TPSTDEF
      Link [WDEP] With [WFAS]FAS0=AASREF As [LIEN]
&     Where [WFAS]CPY=PCPY and [WFAS]ISSDAT>=[F:WFIS]DATSTRFIY and [WFAS]ISSDAT<=[F:WFIS]DATENDFIY and [WFAS]EXTISSFLG=G_NON
&       and [WDEP]CPY=PCPY and [WDEP]FLGLNKDEV=G_OUI and [WDEP]CNX=PCNX and [WDEP]FIYENDDAT=[F:WFI2]DATENDFIY and [WDEP]PERENDDAT=[F:WFI2]DATENDPER(N_PER)
# FQ67557 : optimisation (va avec l'ajout de l'index DEP8 dans DEPREC)
#&       and [WDEP]FLGLNKDEV=G_OUI and [WDEP]CNX=PCNX and [WDEP]FIYENDDAT=[F:WFI2]DATENDFIY and [WDEP]PERENDDAT=[F:WFI2]DATENDPER(N_PER)
        If rowcount([LIEN]) > 0 #*Fq-88510
           #*Fq-88510 Look[LIEN]
           #*Fq-88510  If fstat= 0
              RRET = G_NON
           #*Fq-88510 Endif
      Endif
    Endif
  Next
End RRET

##########################################################################
# Permet de savoir si il y a déjà eu comptabilisation en réel pour
# le plan et la société passés en paramétre.
#
# Renvoie G_OUI si le plan a déjà été comptabilisé, G_NON sinon
##########################################################################
Funprog IS_LNK_POSTED_PLN(PCPY, PDPRPLN)
Value Char PCPY
Value Integer PDPRPLN

  Local Integer RRET

  If !clalev([F:WDEP]) : Local File DEPREC    [WDEP] : Endif
    #Fq-81074  Filter [F:WDEP] Where CPY=PCPY & DPRPLN=PDPRPLN & FLGPSTLNK=G_OUI
    #Fq-93596 Look[WDEP]DEP9 = PCPY; PDPRPLN; G_OUI
    Look[WDEP]DEP9(3) = PCPY; PDPRPLN; G_OUI
    #Fq-81074 If rowcount([F:WDEP])
    If fstat=0
     RRET=G_OUI
    Else
     RRET=G_NON
    Endif
  #Fq-81074 Filter [F:WDEP]


End RRET

##########################################################################
# Permet de savoir si un contexte donné a du "comptabilisé" pour 1 per donnée
# FQ 88911
##########################################################################
Funprog IS_LNK_POSTED_PLNS_CNX(PCPY, PCNX, PDATENDFIY, PDATENDPER)
Value Char       PCPY
Value Integer    PCNX
Value Date       PDATENDFIY
Value Date       PDATENDPER

  Local Char    CRITERE(255)
  Local Integer RRET
  Local Integer N_PLN

  RRET = G_NON
  If !clalev([F:WCNX]) : Local File CONTEXT  [WCNX] : Endif
  If !clalev([F:WDEP]) : Local File DEPREC   [WDEP] : Endif

  Read [WCNX]CNX0 = PCPY; PCNX

  For N_PLN = 0 To [F:WCNX]NBPLC - 1

    If func SUBTPE.LNK_COMPTABILISE(PCPY, [F:WCNX]PLNCAA(N_PLN), G_OUI) = G_OUI Then

      CRITERE  = "CPY = PCPY and DPRPLN = [F:WCNX]PLNCAA(N_PLN) and FLGPSTLNK = G_OUI"
      CRITERE -= "and FIYENDDAT = PDATENDFIY and PERENDDAT = PDATENDPER"

      Filter [WDEP] Where evalue(CRITERE)
      #FQ93596 Look[WDEP]DEP9 First
      Look[WDEP]DEP9(5) First
      Filter [WDEP]

      If fstat=0
        RRET = G_OUI
        Break
      Endif

    Endif
  Next N_PLN
End RRET
