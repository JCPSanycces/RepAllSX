#<AdxTL>@(#)1.0.0.0 $Revision$
Call SOLUSR
End

#--------------------------------------------------------------#
Subprog SOLUSR
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","UUSOLUSR","UUSOLUSR",3,"") From GTRAITE
End

#--------------------------------------------------------------#
$ACTION
Case ACTION
 When "INIT_DIA" : Gosub INIT_DIA
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
Endcase
Return

#--------------------------------------------------------------#
$INIT_DIA
[M:UUS]DATTST = date$-90
Return

#--------------------------------------------------------------#
$CONTROLE
Local Date    DAT_TST
DAT_TST = [M:UUS]DATTST
TMP = 1
TRA = 1
TIT = mess(158,125,1) : # Utilisateurs actifs d'une solution
Return

#--------------------------------------------------------------#
$EXEC

# Utilisateurs actifs d'une solution
If !GSERVEUR
 Call OUVRE_BOITE("",0) From GESECRAN
 Call OUVRE_TRACE(TIT) From LECFIC
Endif

Local Integer NB_AUS , SI_ERR , NB_DOSS , I , J , K , N , P , NB_TOT
Local Char    TEXTE(250)

# Décompte préliminaire pour dimensionner les variables

If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif

Raz NB_AUS , NB_DOSS
For [ADS]
    Gosub OUV_DOSS
    If SI_ERR=0
        NB_DOSS += 1
        If NB_AUS+nbrecord([AUS])>32767
             NB_AUS = -1 : Break
        Endif
        NB_AUS += nbrecord([AUS])
    Endif
    Gosub FERME_DOSS
Next

# Ne devrait pas arriver
If NB_AUS<0
    Call ECR_TRACE(mess(6,948,1),1) From GESECRAN : # Trop d'utilisateurs
    Return
Elsif NB_AUS=0
    Call ECR_TRACE(mess(159,125,1),1) From GESECRAN : # Aucun dossier à traiter
    Return
Endif

# Déclarations

# Pour la version 130

If dim(GLONAUS)<0
    Local Integer GLONAUS : GLONAUS=5
Endif

If dim(GLONADS)<0
    Local Integer GLONADS : GLONADS=10
Endif

If dim(GLONDES)<0
    Local Integer GLONDES : GLONDES=30
Endif

Local Char UTILIS(GLONAUS)(1..NB_AUS)
Local Char DOSSIERS(GLONADS)(1..NB_DOSS)
Local Char NOMUTILIS(GLONDES)(1..NB_AUS)

Local Date DATCON(1..NB_AUS,1..NB_DOSS)
Local Libelle ACTIF(1..NB_AUS,1..NB_DOSS)
Local Integer USR_RANG(1..NB_AUS)

Local Integer TITAUS,TITNOM
TITAUS=GLONAUS+6
TITNOM=15

Call SET_BOITE(TIT,NB_DOSS) From GESECRAN

# Préparation des tableaux de variables

Raz NB_AUS,NB_DOSS

For [ADS]
    Gosub OUV_DOSS
    If SI_ERR=0
        NB_DOSS+=1 : DOSSIERS(NB_DOSS)=[ADS]DOSSIER
        For [AUS]CODUSR
            I=find([AUS]USR,UTILIS(1..NB_AUS))
            If I=0
                NB_AUS+=1 : I=NB_AUS : UTILIS(NB_AUS)=[AUS]USR : USR_RANG(NB_AUS)=NB_AUS
                NOMUTILIS(NB_AUS)=[AUS]NOMUSR
            Endif
            If vireblc(vireblc(ctrans(toupper( NOMUTILIS(NB_AUS) )),5),2) <> 
&              vireblc(vireblc(ctrans(toupper(  [AUS]NOMUSR      )),5),2)
                NOMUTILIS(NB_AUS)="****"
            Endif
            DATCON(I,NB_DOSS)=[AUS]DATCONN
            If [AUS]ENAFLG=2
                ACTIF(I,NB_DOSS)=2
            Else
                ACTIF(I,NB_DOSS)=1
            Endif
        Next
    Endif
    Gosub FERME_DOSS
    Call AFF_BOITE("",NB_DOSS,K) From GESECRAN
Next ADS

# Tri des utilisateurs et préparation de la trace

Sorta NB_AUS UTILIS(1..NB_AUS),USR_RANG(1..NB_AUS)

P = 7
For N=1 To NB_DOSS Step P

    TEXTE = ""
    Gosub TRACE
    Gosub TRAIT
    # Utilisateur/Nom utilisateur
    TEXTE=format$("K:"+num$(TITAUS)+"X",mess(37,133,1))+"!"+format$("K=:"+num$(TITNOM)+"X",mess(38,100,1))+"!"
    For I=N To min(N+P-1,NB_DOSS)
        TEXTE+=format$("K:"+num$(GLONADS)+"X",DOSSIERS(I))+"!"
    Next I
    Gosub TRACE
    Gosub TRAIT

    # Tableau des utilisateurs par dossier
    For I=1 To NB_AUS
        TEXTE=format$("K:"+num$(TITAUS)+"X",UTILIS(I))+"!"
        TEXTE+=format$("K:"+num$(TITNOM)+"X",NOMUTILIS(USR_RANG(I)))+"!"
        For J=N To min(N+P-1,NB_DOSS)
            If ACTIF(USR_RANG(I),J)=0
                TEXTE+=space$(GLONADS)+"!"
            Elsif ACTIF(USR_RANG(I),J)=1
                TEXTE+=format$("K:"+num$(GLONADS)+"X"," "+mess(1,8,1))+"!" : # Inactif
            Else
                TEXTE+=format$("K:"+num$(GLONADS)+"X",format$("D:[ ]DD[/]MM[/]YY",DATCON(USR_RANG(I),J)))+"!"
            Endif
        Next J
        Gosub TRACE
    Next I

    # Total des actifs
    Gosub TRAIT
    TEXTE=format$("K:"+num$(TITAUS)+"X",mess(160,125,1))+"!"+space$(TITNOM)+"!" : # Nb actifs
    For J=N To min(N+P-1,NB_DOSS)
        TEXTE+=format$("N:"+num$(GLONADS)+"#",sigma(1,NB_AUS,ACTIF(USR_RANG(indcum),J)=2))+"!"
    Next J
    Gosub TRACE

    TEXTE=format$("K:"+num$(TITAUS)+"X",mess(162,125,1))+"!" : # Depuis le
    TEXTE+=format$("K:"+num$(TITNOM)+"X",format$("D:[ ]DD[/]MM[/]YY",DAT_TST))+"!"
    For J=N To min(N+P-1,NB_DOSS)
        TEXTE+=format$("N:"+num$(GLONADS)+"#",sigma(1,NB_AUS,(ACTIF(USR_RANG(indcum),J)=2)
&       & (DATCON(USR_RANG(indcum),J)>=DAT_TST)))+"!"
    Next J
    Gosub TRACE

    # Total des inactifs
    TEXTE=format$("K:"+num$(TITAUS)+"X",mess(161,125,1))+"!"+space$(TITNOM)+"!" : # Nb inactifs
    For J=N To min(N+P-1,NB_DOSS)
        TEXTE+=format$("N:"+num$(GLONADS)+"#",sigma(1,NB_AUS,ACTIF(USR_RANG(indcum),J)=1))+"!"
    Next J
    Gosub TRACE

    # Nombre inexistants
    TEXTE=format$("K:"+num$(TITAUS)+"X",mess(163,125,1))+"!"+space$(TITNOM)+"!" : # Inexistants
    For J=N To min(N+P-1,NB_DOSS)
        TEXTE+=format$("N:"+num$(GLONADS)+"#",sigma(1,NB_AUS,ACTIF(USR_RANG(indcum),J)=0))+"!"
    Next J
    Gosub TRACE

    # Nombre total
    Gosub TRAIT
    TEXTE=format$("K:"+num$(TITAUS)+"X",mess(151,115,1))+"!"+space$(TITNOM)+"!" : # Total
    For J=N To min(N+P-1,NB_DOSS)
        TEXTE+=format$("N:"+num$(GLONADS)+"#",NB_AUS)+"!"
    Next J
    Gosub TRACE

    Gosub TRAIT

Next N

# Utilisateurs actifs connectés dans au moins un dossier depuis le #

NB_TOT = 0
TEXTE  = ""
Gosub TRACE
TEXTE=func AFNC.MES(mess(164,125,1),format$("D:"+GFMDAT4,DAT_TST))
Gosub TRACE
Gosub ENTETE_USR
For I=1 To NB_AUS
    TEXTE=format$("K:"+num$(TITAUS)+"X",UTILIS(I))+"!"+format$("K:"+num$(TITNOM)+"X",NOMUTILIS(USR_RANG(I)))+"!"
    For J=1 To NB_DOSS
        If DATCON(USR_RANG(I),J)<>[0/0/0] & ACTIF(USR_RANG(I),J)<>0
            NB_TOT += 1
            TEXTE+=format$("K:"+num$(GLONADS)+"X",DOSSIERS(J))+"!"
            TEXTE+=format$("K:"+num$(GLONADS)+"X",format$("D:[ ]DD[/]MM[/]YY",DATCON(USR_RANG(I),J)))+"!"
            Gosub TRACE : Break
        Endif
    Next J
Next I
Gosub TRAIT_USR
TEXTE=format$("K:"+num$(TITAUS)+"X",mess(151,115,1))+"!"+format$("N:"+num$(TITNOM)+"#",num$(NB_TOT))+"!"
TEXTE+=format$("K:"+num$(GLONADS)+"X","")+"!"+format$("K=:"+num$(GLONADS)+"X","")+"!"
Gosub TRACE
Gosub TRAIT_USR


# Utilisateurs actifs dans au moins un dossier

NB_TOT = 0
TEXTE = ""
Gosub TRACE
TEXTE=mess(165,125,1)
Gosub TRACE
Gosub ENTETE_USR
For I=1 To NB_AUS
    TEXTE=format$("K:"+num$(TITAUS)+"X",UTILIS(I))+"!"+format$("K:"+num$(TITNOM)+"X",NOMUTILIS(USR_RANG(I)))+"!"
    For J=1 To NB_DOSS
        If ACTIF(USR_RANG(I),J)<>0
            NB_TOT += 1
            TEXTE+=format$("K:"+num$(GLONADS)+"X",DOSSIERS(J))+"!"
            TEXTE+=format$("K:"+num$(GLONADS)+"X",format$("D:[ ]DD[/]MM[/]YY",DATCON(USR_RANG(I),J)))+"!"
            Gosub TRACE : Break
        Endif
    Next J
Next I
Gosub TRAIT_USR
TEXTE=format$("K:"+num$(TITAUS)+"X",mess(151,115,1))+"!"+format$("N:"+num$(TITNOM)+"#",num$(NB_TOT))+"!"
TEXTE+=format$("K:"+num$(GLONADS)+"X","")+"!"+format$("K=:"+num$(GLONADS)+"X","")+"!"
Gosub TRACE
Gosub TRAIT_USR

If !GSERVEUR
 Call FERME_TRACE From LECFIC
 Call FERME_BOITE From GESECRAN
Endif

Return

#--------------------------------------------------------------#
$OUV_DOSS
SI_ERR=0
Onerrgo ERR_OUVRE
Local File =[F:ADS]DOSSIER+".AUTILIS" [AUS]
Onerrgo
Return

#--------------------------------------------------------------#
$FERME_DOSS
If SI_ERR=0
    Close Local File [AUS]
Endif
Return

#--------------------------------------------------------------#
$ERR_OUVRE
SI_ERR=1
Resume

#--------------------------------------------------------------#
$TRAIT
TEXTE=string$(TITAUS,"=")+"+"+string$(TITNOM,"=")+"+"
For K=N To min(N+P-1,NB_DOSS)
    TEXTE+=string$(GLONADS,"=")+"+"
Next K
Gosub TRACE
Return

#--------------------------------------------------------------#
$ENTETE_USR
Gosub TRAIT_USR
# Utilisateur/Nom utilisateur/Dossier/Date
TEXTE=format$("K:"+num$(TITAUS)+"X",mess(37,133,1))+"!"+format$("K=:"+num$(TITNOM)+"X",mess(38,100,1))+"!"
TEXTE+=format$("K:"+num$(GLONADS)+"X",mess(85,115,1))+"!"+format$("K=:"+num$(GLONADS)+"X",mess(88,100,1))+"!"
Gosub TRACE
Gosub TRAIT_USR
Return

#--------------------------------------------------------------#
$TRAIT_USR
TEXTE=string$(TITAUS,"=")+"+"+string$(TITNOM,"=")+"+"+string$(GLONADS,"=")+"+"+string$(GLONADS,"=")+"+"
Gosub TRACE
Return

#--------------------------------------------------------------#
$TRACE
Call ECR_TRACE("|"+TEXTE,0) From GESECRAN
Return
