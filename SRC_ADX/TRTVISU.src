#<AdxTL>@(#)4.0.0.0 $Revision$
# Issue 107498/18 - 2016-08-15 by JUSYN : Check for activity code PJM
#---------------------------------------------------------------------------#
# Actions de visualisation pour les traitements automatiques:               #
# - VISUMAUTR    Lancement automatique                                      #
# - VISUMAUTF    Contremarque automatique                                   #
#---------------------------------------------------------------------------#

$ACTION
Case ACTION
    When "OUVRE"         :   Case GACTION :
                                 When "VISUMAUTR" : Gosub OUVRE_MAUTR
                                 When "VISUMAUTF" : Gosub OUVRE_MAUTF
                             Endcase
    When "DEBUT"         :   Case GACTION :
                                 When "VISUMAUTR" : Gosub DEB_MAUTR
                                 When "VISUMAUTF" : Gosub DEB_MAUTF
                             Endcase
    When "BOUTON"        :   Gosub BOUT_MAUTR
    When "AVANT_OK"      :   Case GACTION :
                                 When "VISUMAUTR" : Gosub AVOK_MAUTR
                                 When "VISUMAUTF" : Gosub AVOK_MAUTF
                             Endcase
    When "OK"            :   Case GACTION :
                                 When "VISUMAUTR" : Gosub OK_MAUTR
                                 When "VISUMAUTF" : Gosub OK_MAUTF
                             Endcase
Endcase

Return

#########################################################################
$OUVRE_MAUTR
Local Integer  NBOF
Local Char     TIT(50)
Local Char     CRITERE(255)
Local Char     CRITERE1(255)
Local Char     CRITERE2(255)
# sr 09.01 CUSFLT zone de filtres supplémentaires demande 10405
Local Char    CUSFLT(255)
#
Local Char     FORMULE1(255)
Local Char     WMESS(100)
Local Char     WMESS1(85)
Local Char     WMESS2(85)
Local Integer  WRET
Local Char     WITMREF(GLONITM)
Local Char     WSTOFCY(GLONFCY)
Local Char     WVCRNUM(GLONVCR)
Local Integer  WVCRLIN
Local Date     WSTRDAT
Local Integer  WSTA
Local Char     WROUNUM(GLONROH)
Local Decimal  WROUALT                # llc 09.01 10266
Local Char     WLOT(GLONLOT)
Local Char     ETAT(20)
Global Char    GDEFIMP(50)            # llc 01.01 7063
Local  Decimal WBOMALT
Local Integer  DOSOK

# impression 140
Local Char    LPRT(GLONAIM)
Local Integer LOBL
Local Char PARAM_CLC(250)(1..14) , VAL_CLC(250)


# --- Déclaration classes ecran --- #
Local Mask ORDK    [ORDK]
Local Mask ORCK    [ORCK]
Local Mask MFGK    [MFGK]

Return

#########################################################################
$DEB_MAUTR
# Issue 111414/10 - 2016-01 by GH - Optimisation for implementation of versioning
If dim([M:VIS1]ECCVALMAJ)>0 & !clalev([F:EVL]) : Local File ECCVAL [EVL] : Endif
If dim([M:VIS1]ECCVALMAJ)>0 & !clalev([F:ECS]) : Local File ECCSTA [ECS] : Endif
If dim([M:VIS1]ROUECCMAJ)>0 & !clalev([F:RVV]) : Local File RVMVAL [RVV] : Endif

Local Integer WMAX : WMAX = dim([M:VIS1]PECFLG)
# titre de l'écran
TIT = mess(317,198,1)
Raz [M:VIS1]

[M:VIS1]MFGFCY = [M:DIA]MFGFCY
Call LECTURE("FCY",[M:VIS1]MFGFCY,"") From CONTOBJ
[M:VIS1]FCYDES = [F:FCY]FCYNAM

# préparation des critères de filtre
Gosub SEL_OF From FUNMAUTR
nolign = 0

Raz CUSFLT
GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
If CUSFLT = "" : CUSFLT = "1=1" : Endif

# Issue 72161 - 2011-03-08 by CCC : Lien avec les tables ITM et ITF qui peuvent être utilisées dans la formule
#If CRITERE2 <> ""
#    Filter [ORD] Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CUSFLT) & evalue(FORMULE1)
#&                      Order By Key ORD0
#Else
#    Filter [ORD] Where evalue(CRITERE1) & evalue(CUSFLT) & evalue(FORMULE1)
#&                      Order By Key ORD0
#Endif

If CRITERE2 <> ""
    Link [ORD] With [ITM]ITM0~=[F:ORD]ITMREF, [F:ITF]ITF0~=[F:ORD]ITMREF;[F:ORD]STOFCY
&              As [LNK]
&              Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CUSFLT) & evalue(FORMULE1)
&              Order By Key KLNK=[F:ORD]WIPTYP;[F:ORD]WIPNUM;[F:ORD]ITMREF
Else
    Link [ORD] With [ITM]ITM0~=[F:ORD]ITMREF, [F:ITF]ITF0~=[F:ORD]ITMREF;[F:ORD]STOFCY
&              As [LNK]
&              Where evalue(CRITERE1) & evalue(CUSFLT) & evalue(FORMULE1)
&              Order By Key KLNK=[F:ORD]WIPTYP;[F:ORD]WIPNUM;[F:ORD]ITMREF
Endif

# boucle de lecture
For  [LNK] With Nohint
      Read [ORD]ORD0=[F:ORD]WIPTYP;[F:ORD]WIPNUM;[F:ORD]ITMREF
      If nolign = WMAX : Break : Endif
      nolign += 1
      WITMREF = [F:ORD]ITMREF
      WSTOFCY = [F:ORD]STOFCY
      WVCRNUM = [F:ORD]VCRNUM
      WVCRLIN = [F:ORD]VCRLIN
      WSTRDAT = [F:ORD]STRDAT
      WSTA    = [F:ORD]WIPSTA
      Gosub CHARGE_TAB

$NXT2
Next
#
Filter [ORD]

[M:VIS1]NBLIG = nolign

If [M:VIS1]NBLIG > 0
    Affzo [M:VIS1]
Endif


Return

#########################################################################
$BOUT_MAUTR
Local Integer I

Case BOUT
    When "a" :    # réinitialiser
                  OK = 2
                  Call OUINON(mess(420,198,1),OK) From GESECRAN
                  If OK = 2
                      Raz [M:VIS1]
                      Case GACTION
                          When "VISUMAUTR" : Gosub DEB_MAUTR
                          When "VISUMAUTF" : Gosub DEB_MAUTF
                      Endcase
                  Endif
    When "b" :    # inclure
                  Gosub INC_ALL
    When "c" :    # exclure
                  Gosub EXC_ALL
Endcase
Return

#########################################################################
$INC_ALL
For  I = 0 To [M]NBLIG - 1
    [M]PECFLG(I)  = 2
    J=0
    If GACTION = "VISUMAUTR"
       Read [MFG]MFG0=[M]VCRNUM(I)
       If !fstat
           # OF matières seules
           If [F:MFG]MFGMOD = 2
               If [M]ROUNUM(I)="" & [M]ROUALT(I)= 0
                   # Lcmt matière seule autorisée par trs
                   If [F:MTS]MFGMODM = 2
                      J=1
                   Endif
                Endif
           Endif
       Endif
    Elsif GACTION = "VISUMAUTF"
        # OF matières seules
        If [M]ROUNUM(I)="" & [M]ROUALT(I)= 0
            # Lcmt matière seule autorisée par trs
            If [F:MTS]MFGMODM = 2
               J=1
            Endif
        Endif
    Endif
    If J
       If [M]STRDAT(I) < date$ | [M]BOMALT(I) = 0 | [M]EXTQTY(I) = 0
          [M]PECFLG(I)  = 1 : Goto NEXT_REC
       Endif
    Elsif [M]STRDAT(I) < date$ | [M]ROUNUM(I) = "" | [M]ROUALT(I) = 0  | [M]BOMALT(I) = 0 | [M]EXTQTY(I) = 0
          [M]PECFLG(I)  = 1 : Goto NEXT_REC
    Endif

    # Issue 111414 - 2016-01 by GH - Implementation of versioning
    If dim([M:VIS1]ECCVALMAJ)>0 & func ECCLIB.NBRCPN([M:VIS1]ITMREF(I))
       Call CTRECC([M:VIS1]ITMREF(I),"VIS1","STRDAT",[M:VIS1]ECCVALMAJ(I),[M:VIS1]ECCVALMIN(I),
&                  [M:VIS1]STRDAT(I),GERR,GMESSAGE) From ECCLIB
       If find(GERR,1,4)
          [M]PECFLG(I)  = 1
       Endif
       Raz GERR, GMESSAGE
       If [M]PECFLG(I)  = 1 : Goto NEXT_REC : Endif
    Endif
    If [M:VIS1]ROUNUM(I)<>"" & dim([M:VIS1]ROUECCMAJ)>0 & func RVMLIB.NBRCPNROU([M:VIS1]ROUNUM(I))
       Call CTRROUECC([M:VIS1]ROUNUM(I),[M:VIS1]MFGFCY,"VIS1","STRDAT",[M:VIS1]ROUECCMAJ(I),[M:VIS1]ROUECCMIN(I),
&                     [M:VIS1]STRDAT(I),GERR,GMESSAGE) From RVMLIB
       If find(GERR,1,4)
          [M]PECFLG(I)  = 1
       Endif
       Raz GERR, GMESSAGE
       If [M]PECFLG(I)  = 1 : Goto NEXT_REC : Endif
    Endif
$NEXT_REC
Next I

Affzo [M]1-99

Return

#########################################################################
$EXC_ALL
For  I = 0 To [M]NBLIG - 1
    [M]PECFLG(I)  = 1
Next I
Affzo [M]1-99

Return

#########################################################################
# alimentation du tableau
$CHARGE_TAB
Raz WROUNUM,WROUALT
# Issue 107498/109 - 2016-06-01 by JUSYN : Project management. Filter out WOS that
#                                          shall not be released because project taskline not launched.

# check flag for project management treatment 1 = okay 0 = not okay
Local Integer LMTXFLG(1)
# Issue number 107498/18 - 2016-08-15 by JUSYN : Only when activity code PJM active
If func AFNC.ACTIV("PJM")
    Gosub CHECK_PROJECT_CONDITIONS From FUNMAUTR
Else
    LMTXFLG = 1
Endif

If LMTXFLG = 0
    nolign -= 1
    Return
Endif
#
#
Case WSTA
    When 1,2:  For [SCH]SCH0 Where MFGNUM = WVCRNUM
                   WROUNUM = [F:SCH]ROUNUM
                   WROUALT = [F:SCH]ROUALT
                   Break
               Next
               Read [MFI]MFI0=WVCRNUM;WVCRLIN
               If fstat : Raz [F:MFI]: nolign -=1 : Return : Endif
               WLOT = [F:MFI]LOT
    When 3:    For [SCH]SCH0 Where MFGNUM = WVCRNUM
                   WROUNUM = [F:SCH]ROUNUM
                   WROUALT = [F:SCH]ROUALT
                   Break
               Next
               If [F:ORD]BOMALT = 0 | WROUNUM = "" | WROUALT = 0
                   Read [ITF]ITF0=WITMREF;WSTOFCY
                   If fstat : Raz [F:ITF] : Endif
                   Read [ITM]ITM0=WITMREF
                   If fstat : Raz [F:ITM] : Endif
               Endif
               If [F:ORD]BOMALT = 0
                   Call RECH_NOM([F:ORD]STOFCY, WSTRDAT, WBOMALT,2) From BENCHLIB
                   [F:ORD]BOMALT = WBOMALT
               Else : # GH 27/03/2014 bug 84721
                   WBOMALT = [F:ORD]BOMALT
                   Call CHECK_NOM([F:ORD]STOFCY, WSTRDAT, WBOMALT) From BENCHLIB
                   If WBOMALT = 0 : Call RECH_NOM([F:ORD]STOFCY, WSTRDAT, WBOMALT,2) From BENCHLIB : Endif
                   [F:ORD]BOMALT = WBOMALT
               Endif
               If WROUNUM = "" | WROUALT = 0           # llc 09.01 10266
                   If [F:ITF]MFGROU = ""
                       WROUNUM = WITMREF
                   Else
                       WROUNUM = [F:ITF]MFGROU
                   Endif
                   Call RECH_GAM(WSTOFCY, WSTRDAT, WROUNUM, [F:ORD]EXTQTY,
&                      [F:ITM]STU, [F:ORD]BOMALT, WROUALT) From BENCHLIB
                   If WROUALT = 0 : WROUNUM = "" : Endif        # llc 06.04 22880
                Endif
                WLOT=""
Endcase

Case [M:DIA]APSTA
    When 1: [M:VIS1]PLNTYP(nolign-1) = mess(5,341,1)+mess(2,342,1)
    When 2: [M:VIS1]PLNTYP(nolign-1) = mess(5,341,1)+mess(1,342,1)
Endcase
[M:VIS1]ITMREF(nolign-1)  = WITMREF
# lecture article
If [F:ITM]ITMREF <> [M:VIS1]ITMREF(nolign-1)
    Read [ITM]ITM0=[M:VIS1]ITMREF(nolign-1)
    If fstat : Raz [F:ITM] : Endif
Endif
#[M:VIS1]ITMDES1(nolign-1)    = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:VIS1]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:VIS1]MGTCOD(nolign-1)     = [F:ITM]STDFLG
[M:VIS1]EXTQTY(nolign-1)     = [F:ORD]EXTQTY
[M:VIS1]PRVQTY(nolign-1)     = [F:ORD]EXTQTY
[M:VIS1]STU(nolign-1)        = [F:ITM]STU
[M:VIS1]STRDAT(nolign-1)     = [F:ORD]STRDAT
[M:VIS1]ENDDAT(nolign-1)     = [F:ORD]ENDDAT
[M:VIS1]BOMALT(nolign-1)     = [F:ORD]BOMALT
[M:VIS1]ROUNUM(nolign-1)     = WROUNUM
[M:VIS1]ROUALT(nolign-1)     = WROUALT
[M:VIS1]PJT(nolign-1)        = [F:ORD]PJT
[M:VIS1]LOT(nolign-1)        = WLOT
[M:VIS1]FMI(nolign-1)        = [F:ORD]FMI
[M:VIS1]BPRNUM(nolign-1)     = [F:ORD]BPRNUM
[M:VIS1]VCRTYPORI(nolign-1)  = [F:ORD]VCRTYPORI
[M:VIS1]VCRNUMORI(nolign-1)  = [F:ORD]VCRNUMORI
[M:VIS1]VCRLINORI(nolign-1)  = [F:ORD]VCRLINORI
[M:VIS1]VCRSEQORI(nolign-1)  = [F:ORD]VCRSEQORI
[M:VIS1]PIO(nolign-1)        = [F:ORD]PIO
[M:VIS1]TCLCOD(nolign-1)     = [F:ITM]TCLCOD
[M:VIS1]VCRNUM(nolign-1)     = WVCRNUM
[M:VIS1]VCRLIN(nolign-1)     = WVCRLIN
[M:VIS1]WIPTYP(nolign-1)     = [F:ORD]WIPTYP
[M:VIS1]WIPNUM(nolign-1)     = [F:ORD]WIPNUM
[M:VIS1]WIPSTA(nolign-1)     = [F:ORD]WIPSTA
Read [MFI]MFI0=WVCRNUM;WVCRLIN
If !fstat
    [M:VIS1]MFGDES(nolign-1)    = [F:MFI]MFGDES
Endif

Read [ITF]ITF0=WITMREF;WSTOFCY
If !fstat
    [M:VIS1]PLANNER2(nolign-1)  = [F:ITF]PLANNER
Endif
# Issue 111414/10 - 2016-01-21 by JUSYN : Load of BOM versions
If dim([M:VIS1]ECCVALMAJ(nolign-1)) > 0
    [M:VIS1]ECCVALMAJ(nolign-1) = [F:ORD]ECCVALMAJ
    [M:VIS1]ECCVALMIN(nolign-1) = [F:ORD]ECCVALMIN
Endif

# OF matières seules
Read [MFG]MFG0 = WVCRNUM
If !fstat
    If [F:MFG]MFGMOD = 2
        If [M:VIS1]ROUNUM(nolign-1)="" & [M:VIS1]ROUALT(nolign-1)= 0
            # Lcmt matière seule autorisée par trs
            If [F:MTS]MFGMODM = 2
                If [M:VIS1]STRDAT(nolign-1) < date$ |[M:VIS1]BOMALT(nolign-1) = 0
                    [M:VIS1]PECFLG(nolign-1) = 1
                Else
                    [M:VIS1]PECFLG(nolign-1) = 2
                Endif
                Return
             Endif
        Endif
    Endif
Endif

# Issue 111414/10 - 2016-01-21 by JUSYN : LOAD OF ROUTE VERSIONS
If dim([M:VIS1]ROUECCMAJ(nolign-1)) > 0
    If find(WSTA,1,2)
        [M:VIS1]ROUECCMAJ(nolign-1) = [F:MFG]ROUECCMAJ
        [M:VIS1]ROUECCMIN(nolign-1) = [F:MFG]ROUECCMIN
    Else
        Call INIECCROU([M:VIS1]ROUNUM(nolign-1),[M:VIS1]MFGFCY,[M:VIS1]STRDAT(nolign-1),[M:VIS1]ROUALT(nolign-1),[M:VIS1]ROUECCMAJ(nolign-1),[M:VIS1]ROUECCMIN(nolign-1)) From RVMLIB
   Endif
Endif

If [M:VIS1]STRDAT(nolign-1) < date$ | [M:VIS1]ROUNUM(nolign-1) = "" | [M:VIS1]ROUALT(nolign-1) = 0  |
&   [M:VIS1]BOMALT(nolign-1) = 0
    [M:VIS1]PECFLG(nolign-1) = 1
Else
    [M:VIS1]PECFLG(nolign-1) = 2
Endif
Return

#########################################################################
$AVOK_MAUTR
Local Integer I, J, K

For J=0 To [M:VIS1]NBLIG-1
    If [M:VIS1]PECFLG(J)=2
        K=0
        # On ne lance pas un WOx qui n'a pas d'alternative de nomenclature
        If [M:VIS1]BOMALT(J) = 0 & [F:MTS]MFGMODO <> 2
           # Issue 84916 GA 10/2012
           # autoriser BOMALT=0 dès lors que la transaction accepte "Opérations seules"
           K=1
         Elsif dim([M:VIS1]ECCVALMAJ)>0 : # Issue 111414/10 - 2016-01 by GH - Implementation of versioning
          I = func ECCLIB.NBRCPN([M:VIS1]ITMREF(J))
          If (I & [M:VIS1]ECCVALMAJ(J)="") | (I=2 & [M:VIS1]ECCVALMIN(J)="")
             K=1
          Endif
        Endif
        If !K
          # si mode de lcmt <> "matières seules", WROUNUM et WROUALT doivent être alimentées
          If [M:VIS1]ROUNUM(J)="" & [M:VIS1]ROUALT(J)=0
              Read [MFG]MFG0=[M:VIS1]VCRNUM(J)
              If !fstat & [F:MFG]MFGMOD<>2
                 K=1
              Endif
          Elsif [M:VIS1]ROUNUM(J)<>"" & dim([M:VIS1]ROUECCMAJ)>0 : # Issue 111414/10 - 2016-01 by GH - Implementation of versioning
            I = func RVMLIB.NBRCPNROU([M:VIS1]ROUNUM(J))
            If (I & [M:VIS1]ROUECCMAJ(J)="") | (I=2 & [M:VIS1]ROUECCMIN(J)="")
               K=1
            Endif
          Endif
        Endif
        If K
           Call MESSAGE(mess(156,197,1)-mess([M:VIS1]WIPSTA(J),317,1)-[M:VIS1]VCRNUM(J)-mess(258,193,1)) From GESECRAN
           FOK = 0 : GERR = 1 : FIN =0
        Endif
    Endif
Next J
Return

#########################################################################
$OK_MAUTR
TRA = 1
If GTRACE = ""
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("MAUTREL","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif

Gosub TRT_OF

Call TEMPOFF From GESECRAN
# fermeture trace
Call FERME_TRACE From LECFIC
# aucune génération effectuée ou lecture trace
If !NBOF
    GERR = 2 : GMESSAGE = mess(88,193,1)
Endif
# lecture trace
Call LEC_TRACE From LECFIC
If GFONC1 = "FUNMAUT" : Raz GFONC1 : Endif
Return

#########################################################################
$TRT_OF
Local Integer J

For J=0 To [M:VIS1]NBLIG-1
    If [M:VIS1]PECFLG(J) <> 2 : Goto NXT_OF : Endif
    Gosub VERROU
    If !OK : Goto NXT_OF : Endif
    Call DEBTRANS From GLOCK
    Gosub MAJ_OF
    Gosub DEVERROU
$NXT_OF
Next J
Return

#########################################################################
$MAJ_OF
Local Char    WTRS(GLONTRS)

WMESS   = mess(156,197,1)-mess([M:VIS1]WIPSTA(J),317,1)-[M:VIS1]VCRNUM(J)

Trbegin [MFG]
    Case [M:VIS1]WIPSTA(J)
    When 2 : # WOP
        Read [MFG]MFG0 = [M:VIS1]VCRNUM(J)
        If !fstat
            # Si Mode lcmt OF ="Matières seules" et seul mode lcmt autorisé par
            # la transaction = "OP seules" ou l'inverse
            # ou si mode de lcmt complet et la transaction n'autorise pas le mode de lcmt complet
            If [F:MFG]MFGMOD = 2 & ([F:MTS]MFGMODM=1 & [F:MTS]MFGMODC=1) |
&            [F:MFG]MFGMOD = 3 & ([F:MTS]MFGMODO=1 & [F:MTS]MFGMODC=1) |
&            [F:MFG]MFGMOD = 1 & [F:MTS]MFGMODC=1
                If [M:DIA]MFGTRS <>"" WTRS = [M:DIA]MFGTRS
                Else                  WTRS  = GMFGMTSNUM
                Endif
                Call ECR_TRACE(WMESS-mess(257,193,1)-WTRS,0) From GESECRAN
                Goto AB_TRTAUTO
            Endif
        Endif
    When 3 : # WOS
# Issue 109221 - 2015-10-21 by GH
#            If [F:MTS]MFGMODC=1
#                If [M:DIA]MFGTRS <>"" WTRS = [M:DIA]MFGTRS
#                Else                  WTRS = GMFGMTSNUM
#                Endif
#                Call ECR_TRACE(WMESS-mess(257,193,1)-WTRS,0) From GESECRAN
#                Goto AB_TRTAUTO
#            Endif
    Endcase

    # maj historique si WOP vers WOF
    If [M:VIS1]WIPSTA(J) = 2 & [M:DIA]APSTA = 2
        Raz [M:ORCK]
        [M:ORCK]MAJCOD = "C"
        [M:ORCK]WIPNUM = [M:VIS1]WIPNUM(J)
        [M:ORCK]WIPTYP = [M:VIS1]WIPTYP(J)
        [M:ORCK]ITMREF = [M:VIS1]ITMREF(J)
        [M:ORCK]COVQTY = [M:VIS1]EXTQTY(J)
        [M:ORCK]VCRTYPDST = 10
        [M:ORCK]VCRNUMDST = [M:VIS1]VCRNUM(J)
        [M:ORCK]VCRLINDST = [M:VIS1]VCRLIN(J)
        [M:ORCK]VCRSEQDST = 0
        [M:ORCK]WIPSTADST = 1
        [M:ORCK]WIPTYPDST = 5
        Read [MFG]MFG0=[M:VIS1]VCRNUM(J)
        If !fstat
            [M:ORCK]ROUNUM = [F:MFG]ROUNUM
            [M:ORCK]ROUALT = [F:MFG]ROUALT
        Endif
        Call COVER From TRTWIP
    Endif

    Raz [M:MFGK]
    WSTA =[M:VIS1]WIPSTA(J)
    Case WSTA
        When 1,2 : [M:MFGK]CODMAJ = "M"
        When 3   : [M:MFGK]CODMAJ = "R"
    Endcase
    [M:MFGK]CODTRS = 0
    [M:MFGK]MFGNUM = [M:VIS1]VCRNUM(J)
    [M:MFGK]MFGLIN = [M:VIS1]VCRLIN(J)
    [M:MFGK]MFGFCY = [M:VIS1]MFGFCY
    Case [M:DIA]APSTA
        When 1: [M:MFGK]MFGSTA = 2
        When 2: [M:MFGK]MFGSTA = 1
        When Default: [M:MFGK]MFGSTA = 1
    Endcase
    [M:MFGK]ITMREF     = [M:VIS1]ITMREF(J)
    [M:MFGK]PRVQTY     = [M:VIS1]PRVQTY(J)
    [M:MFGK]EXTQTY     = [M:VIS1]EXTQTY(J)
    [M:MFGK]STRDAT     = [M:VIS1]STRDAT(J)
    [M:MFGK]ENDDAT     = [M:VIS1]ENDDAT(J)
    [M:MFGK]BOMALT     = [M:VIS1]BOMALT(J)
    [M:MFGK]BOMALT     = [M:VIS1]BOMALT(J)
    [M:MFGK]ROUNUM     = [M:VIS1]ROUNUM(J)
    [M:MFGK]ROUALT     = [M:VIS1]ROUALT(J)
    ## GH 03/04/2014 bug 93360
    # pour éviter de perdre l'affaire dans MFGAUTLIB
    #Read [MFI]MFI0 = [M:VIS1]VCRNUM(J);[M:VIS1]VCRLIN(J)
    #If !fstat : [F:MFI]PJT =  [M:VIS1]PJT(J) : Rewrite [MFI] : Endif
    #
    [M:MFGK]PJT        = [M:VIS1]PJT(J)
    ##
    [M:MFGK]LOT        = [M:VIS1]LOT(J)
    [M:MFGK]FMI        = [M:VIS1]FMI(J)
    [M:MFGK]BPRNUM     = [M:VIS1]BPRNUM(J)
    [M:MFGK]PIO        = [M:VIS1]PIO(J)
    [M:MFGK]VCRTYPORI  = [M:VIS1]VCRTYPORI(J)
    [M:MFGK]VCRNUMORI  = [M:VIS1]VCRNUMORI(J)
    [M:MFGK]VCRLINORI  = [M:VIS1]VCRLINORI(J)
    [M:MFGK]VCRSEQORI  = [M:VIS1]VCRSEQORI(J)
    [M:MFGK]WIPTYP     = [M:VIS1]WIPTYP(J)
    [M:MFGK]WIPNUM     = [M:VIS1]WIPNUM(J)
    [M:MFGK]AUTOTRT    = 2
# Issue number 111414/10 - 2016-01-21 by JUSYN : Transfer of BOM and Routing versions to buffer
    If dim([M:VIS1]ECCVALMAJ) > 0
        [M:MFGK]ECCVALMAJ = [M:VIS1]ECCVALMAJ(J)
        [M:MFGK]ECCVALMIN = [M:VIS1]ECCVALMIN(J)
    Endif
    If dim([M:VIS1]ROUECCMAJ) > 0
        [M:MFGK]ROUECCMAJ = [M:VIS1]ROUECCMAJ(J)
        [M:MFGK]ROUECCMIN = [M:VIS1]ROUECCMIN(J)
    Endif
    Case [F:MTS]SCDMODSAI
        When 1:    [M:MFGK]SCDMOD = 1
        When 2:    [M:MFGK]SCDMOD = 2
        When Default: [M:MFGK]SCDMOD = 1
    Endcase
    Call MAJ_OF From MFGAUTLIB
    If [M:MFGK]CODRET <> 0 : Goto AB_TRTAUTO : Endif

    WMESS -= mess(179,197,1)-mess([M:DIA]APSTA,309,1)
    If [M:VIS1]WIPSTA(J) = 3 : WMESS1 = "("+[M:MFGK]MFGNUM+")" : Endif

    # traces
    Call ECR_TRACE(WMESS,0) From GESECRAN
    If WMESS1 <> "" : Call ECR_TRACE(WMESS1,0) From GESECRAN : Endif
    Raz WMESS, WMESS1, WMESS2

    NBOF += 1
Commit

# llc 01.01 7063
#If GFONC1 = "FUNMAUT" & (dim(GMAUTRB) <= 0) & [M:MFGK]MFGSTA = 1
# GH 27/03/2014 bug 84721 GMAUTRB plus utilisé
If [M:MFGK]MFGSTA = 1 & [M:MFGK]AUTOTRT=2 & dim([M:DIA]IMPFLG)>0 & [M:DIA]IMPFLG = 2
    DOSOK = 0
    Call TEST_DOSSIER(DOSOK) From MFGAUTLIB
    If DOSOK =1
       If dim([M:DIA]PRT)=1 : GDEFIMP = [M:DIA]PRT : Else GDEFIMP = "" : Endif
        Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
        Read [F:MFP]MFP0 = [M:MFGK]MFGNUM
        If fstat : Raz [F:MFP] : Endif
        TBPAR(1)="codimp"        : TBVAL(1) = num$([F:MFP]MFGFDRFLG)
        TBPAR(2)="mfgfcydeb"     : TBVAL(2) = [M:MFGK]MFGFCY
        TBPAR(3)="mfgfcyfin"     : TBVAL(3) = [M:MFGK]MFGFCY
        TBPAR(4)="mfgnumdeb"     : TBVAL(4) = [M:MFGK]MFGNUM
        TBPAR(5)="mfgnumfin"     : TBVAL(5) = [M:MFGK]MFGNUM
        Call ETAT("DOSFAB",GDEFIMP,"",1,"",TBPAR,TBVAL) From AIMP3
    Endif
Endif

## GH 09/04/2014 bug 99047 lancé via MFGAUTLIB
## GH 27/03/2014 bug 84721 à ne faire que si la transaction sur OF est OK
##--------------------------------------------------#
## v 140 Calcul automatique des coûts prévisionnels # (CPT et CPL)
##--------------------------------------------------#
## Issue 77922 - 2011-11-16 by CCC
#If (GCLCWOCAUT>=2 & [M:MFGK]CODMAJ="R") | (GCLCWOCAUT=3 & [M:MFGK]CODMAJ="M")
#    # appel direct possible car aucune saisie (compatible Web ?)
#    # charger les paramètres (! ne pas écraser les PARAM de ce GTRAITE)
#    Raz [L]PARAM_CLC
#    PARAM_CLC(1) = [M:MFGK]MFGFCY
#    PARAM_CLC(2) = [M:MFGK]MFGNUM
#    PARAM_CLC(4) = "1"
#    PARAM_CLC(5) = "4"
#
#    Case [F:MTS]MCCIMPMOD :
#         When 0,1   : PARAM_CLC(12) = "2"
#                      PARAM_CLC(13) = "0"
#         When 2     : PARAM_CLC(13) = "0"
#         When 3     : PARAM_CLC(12) = "2"
#    Endcase
#    # positionner PARAM(12) à "2" SI ON NE VEUT PAS l'édition du calcul
#    # positionner PARAM(13) & "2" si on ne veut pas la trace
#    # pas d'impression si traitement en masse
#    If [M:MFGK]AUTOTRT = 2
#        PARAM_CLC(12) = "2"
#        PARAM_CLC(13) = "0"   # Issue 89622 - 2013-06-05 by CCC
#    Endif
#
#    PARAM_CLC(14) = "10"
#    Call TRAITE_CHAR(VAL_CLC,PARAM_CLC,"","SUBMCC","",3,"") From GTRAITE
#Endif
Return

#-----------------------------------------------------------------------#
# Positionnement d'un verrou sur l'entête OF                            #
#-----------------------------------------------------------------------#
$VERROU
SYMBOLE = "MFG"+[M:VIS1]VCRNUM(J)
## GH 27/03/2014 bug 84721 pour ne pas delocker l'OF si locké en amont
Call TESTLOCK(SYMBOLE,OK) From GLOCKM
If OK
   SYMBOLE=""
   Return
Endif
##
Lock = SYMBOLE With lockwait = 0
If fstat
    Call ECR_TRACE(mess(10,701,1)-right$(SYMBOLE,4)-":"-mess(10,100,1),1) From GESECRAN
    OK = 0
Else
    OK = 1
Endif
Return

#-----------------------------------------------------------------------#
# Suppression du verrou sur l'entête OF                                 #
#-----------------------------------------------------------------------#
$DEVERROU
## GH 27/03/2014 bug 84721 ne pas delocker la cde/l'OF si locké en amont
# Unlock=SYMBOLE
If SYMBOLE<>""
   Unlock=SYMBOLE
   SYMBOLE=""
Endif
Return

#########################################################################
$AB_TRTAUTO
If adxlog : Rollback : Endif : # GH 21/01/2016 bug 97868 on est hors transaction
Call ECR_TRACE(WMESS-":"-mess(18,114,1),1) From GESECRAN
Return

#########################################################################
$OUVRE_MAUTF
Local    Integer LRET : LRET = 0

Local Integer  OK
Local Integer  NBFMI
Local Char     WVCRNUM(GLONVCR)
Local Integer  WVCRLIN
Local Integer  WVCRSEQ
Local Char     TIT(50)
Local Char     CRITERE(255)
Local Char     CRITERE1(255)
Local Char     CRITERE2(255)
Local Char     WMESS(255)
Local Char     WMESS1(255)
Local Char     WMESS2(255)
Local Date     WORIDAT
Local Char     WORIFCY(GLONFCY)
Local Integer  WLTI
Local Char     WART(GLONITM)
Local Date     WMEMDAT
Local Integer  WMAX
Local Decimal  XLTI
Local Integer  ILTI
Local Decimal  WRMD
Local Decimal  WQTY
Local Date     WOBJ
Local Date     TODAY : TODAY = date$
Local Integer  WRET
Local Char     ETAT(20)
Local Char     PARAM1(10)             # mm  12.02
Local Integer  WCDTSTA                # sr  04/01 8652
Global Char    GDEFIMP(50)            # llc 01.01 7063
Local Char     WFCY(GLONFCY)          # mm 12.02
Local Integer  WSEARCH
Local Integer  WALT

# impression 140
Local Char    LPRT(GLONAIM)
Local Integer LOBL
Local Integer DOSOK

# --- Déclaration classes ecran --- #
Local Mask ORDK    [ORDK]
Local Mask MFGK    [MFGK]

Return

#########################################################################
$DEB_MAUTF
# Issue 111414/12 - 2016-01 by GH - Optimisation for implementation of versioning
If dim([M:VIS1]ECCVALMAJ)>0 & !clalev([F:EVL]) : Local File ECCVAL [EVL] : Endif
If dim([M:VIS1]ECCVALMAJ)>0 & !clalev([F:ECS]) : Local File ECCSTA [ECS] : Endif
If dim([M:VIS1]ROUECCMAJ)>0 & !clalev([F:RVV]) : Local File RVMVAL [RVV] : Endif

Local Integer WMAX : WMAX = dim([M:VIS1]PECFLG)
# titre de l'écran
TIT = mess(317,198,1)
Raz [M:VIS1]

[M:VIS1]MFGFCY = [M:DIA]MFGFCY
Call LECTURE("FCY",[M:VIS1]MFGFCY,"") From CONTOBJ
[M:VIS1]FCYDES = [F:FCY]FCYNAM

# préparation des critères de filtre
Gosub SEL_FMI From FUNMAUTF
nolign = 0

# traitement des contremarques
If CRITERE2 <> ""
    Filter [ORD] Where evalue(CRITERE1) & evalue(CRITERE2)
&                      Order By Key ORD0
Else
    Filter [ORD] Where evalue(CRITERE1)
&                      Order By Key ORD0
Endif

WFCY = [M:DIA]MFGFCY                                                           # mm  12.02
Call PARAM (WFCY,"DIRORDCTL",PARAM1) From ADOVAL  : GDIRORDCTL=val(PARAM1)     # mm  12.02

# boucle de lecture
For  [ORD]
      If nolign = WMAX : Break : Endif
      nolign += 1
      WVCRNUM = [F:ORD]VCRNUM
      WVCRLIN = [F:ORD]VCRLIN
      WVCRSEQ = [F:ORD]VCRSEQ
      # llc 12.00 7259     (ne pas générer OF si déjà existant)
      Read [SOQ]SOQ0=WVCRNUM;WVCRLIN;WVCRSEQ
      If !fstat & [F:SOQ]FMINUM <> "" : nolign -= 1 : Goto N_ORD : Endif

      #----- Vérification si commande bloquée  sr 04/01 8652 -----#
      Read [SOH]SOH0=WVCRNUM
      #If fstat : Raz [F:SOH] : Endif : # GH 27/03/2014 bug 84721
      If fstat : nolign -= 1 : Goto N_ORD : Endif

      # demande 19414  MM 09.03
      # point d'entree permettant d'empêcher la génération d'un OF
      GPE =0
      GPOINT="TRTAUTFMI" : Gosub ENTREE From EXEFNC
      # If GPE : Goto N_ORD : Endif : # GH 27/03/2014 bug 84721
      If GPE : nolign -= 1 : Goto N_ORD : Endif
      #
      # Bug 48964 : Ctrl sur clt facture (et non sur clt commande)
      Call SDCDTSTA([F:SOH]SOHNUM,[F:SOH]BPCINV,[F:SOH]CHGTYP,0,[F:SOH]CUR,[F:SOH]ORDDAT,
&                 [F:SOH]UNL,1,WCDTSTA,GBIDD1,GBIDD2) From TRTVENCDT
      Case WCDTSTA
          When 2:  nolign -= 1 : Goto N_ORD        # bloqué
          When 3:  If GDIRORDCTL = 1
                       nolign -= 1 : Goto N_ORD    # dépassement en cours
                   Endif
      Endcase
      Gosub CHARGE_ORD
$N_ORD
Next
#
Filter [ORD]
#

[M:VIS1]NBLIG = nolign

If [M:VIS1]NBLIG > 0
    Affzo [M:VIS1]
Endif
Return

#########################################################################
$CHARGE_ORD

Case [M:DIA]APSTA
    When 1: [M:VIS1]PLNTYP(nolign-1)    = mess(5,341,1)+mess(2,342,1)
    When 2: [M:VIS1]PLNTYP(nolign-1)    = mess(5,341,1)+mess(1,342,1)
Endcase

#   lecture article
If [F:ITM]ITMREF <> [F:ORD]ITMREF
    Read [ITM]ITM0=[F:ORD]ITMREF
    If fstat : Return : Endif
Endif
#   lecture article/site
If [F:ITF]ITMREF <> [F:ORD]ITMREF | [F:ITF]STOFCY<>[M:VIS1]MFGFCY
    Read [ITF]ITF0=[F:ORD]ITMREF;[M:VIS1]MFGFCY
    If fstat : Return : Endif
Endif
#
[M:VIS1]ITMREF(nolign-1)     = [F:ORD]ITMREF
#[M:VIS1]ITMDES1(nolign-1)    = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:VIS1]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:VIS1]EXTQTY(nolign-1)     = [F:ORD]RMNEXTQTY - [F:ORD]ALLQTY
If [M:VIS1]EXTQTY(nolign-1) < 0  : [M:VIS1]EXTQTY(nolign-1) =0 : Endif
If [F:ITF]SHR <> 0
    [M:VIS1]EXTQTY(nolign-1) = [M:VIS1]EXTQTY(nolign-1) + ([M:VIS1]EXTQTY(nolign-1) * ([F:ITF]SHR / 100))
    Call QTEARR([M:VIS1]EXTQTY(nolign-1),[F:ITM]STU) From TRTDIV
Endif
[M:VIS1]STU(nolign-1)        = [F:ITM]STU
[M:VIS1]STRDAT(nolign-1)     = [F:ORD]STRDAT

## Issue 111543 - 2015-11-03 by GH - Consideration of QC delay
#[M:VIS1]ENDDAT(nolign-1)     = [F:ORD]ENDDAT
#[M:VIS1]ENDDAT2(nolign-1)    = [F:ORD]ENDDAT
If [F:ITF]QUALTI=0
   [M:VIS1]ENDDAT(nolign-1) = [F:ORD]ENDDAT
Else
   WORIDAT = [F:ORD]ENDDAT
   WORIFCY = [M:VIS1]MFGFCY
   WLTI    = [F:ITF]QUALTI
   Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:VIS1]ENDDAT(nolign-1)) From MFGLIB
Endif
[M:VIS1]ENDDAT2(nolign-1)    = [M:VIS1]ENDDAT(nolign-1)
##

WORIDAT = [M:VIS1]ENDDAT(nolign-1)
WORIFCY = [M:VIS1]MFGFCY
WLTI = 0
WQTY = [M:VIS1]EXTQTY(nolign-1)
# calcul délai
Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD <> 0 : ILTI += 1 : Endif
WLTI=ILTI

# révision calendriers (llc 06.00)
Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:VIS1]STRDAT(nolign-1)) From MFGLIB

#   si date début dans le passé, recalcul en aval à partir du jour
If [M:VIS1]STRDAT(nolign-1) < TODAY
    [M:VIS1]STRDAT(nolign-1) = TODAY
    WORIDAT = [M:VIS1]STRDAT(nolign-1)

    # Issue 119766 GH 03/04/2017 - check if start date is still a working day
    #                              if not, shifts it to the first working day after to the start date
    mkstat=0
    Call CONTROL_DATE_PLN(WORIDAT,WORIFCY) From MFGLIB
    If mkstat
       GMESSAGE=""
       Call CALCUL_DATE_PLN(WORIDAT, 1,  WORIFCY, 0, [M:VIS1]STRDAT(nolign-1)) From MFGLIB
       WORIDAT = [M:VIS1]STRDAT(nolign-1)
    Endif

    #Call CALCUL_DATE_OF(WORIDAT, WLTI, WORIFCY, 0, 0, [M:VIS1]ENDDAT(nolign-1)) From MFGLIB
    # révision calendriers (llc 06.00)
    Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, [M:VIS1]ENDDAT(nolign-1)) From MFGLIB
Endif

## Issue 111414/12 - 2016-01 by GH - Implementation of versioning
If func ECCLIB.NBRCPN([M:VIS1]ITMREF(nolign-1))
  [M:VIS1]ECCVALMAJ(nolign-1) = [F:ORD]ECCVALMAJ
  [M:VIS1]ECCVALMIN(nolign-1) = [F:ORD]ECCVALMIN
  If [M:VIS1]ECCVALMAJ(nolign-1)=""
     WALT = [M:VIS1]BOMALT(nolign-1)
     Raz [M:VIS1]ECCVALMIN(nolign-1)
     Call INIECCBOM([M:VIS1]ITMREF(nolign-1), [M:VIS1]MFGFCY, [M:VIS1]STRDAT(nolign-1), 2, [M:VIS1]ECCVALMAJ(nolign-1),[M:VIS1]ECCVALMIN(nolign-1), WALT) From MFGECCLIB
     [M:VIS1]BOMALT(nolign-1)= WALT
  Endif
Endif

WSEARCH = ([M:VIS1]BOMALT(nolign-1)=0)

$ALT_SEARCH : # GH 11/09/2015 bug 108066
If [M:VIS1]BOMALT(nolign-1)=0
    Call RECH_NOM([M:VIS1]MFGFCY, [M:VIS1]STRDAT(nolign-1), [M:VIS1]BOMALT(nolign-1),2) From BENCHLIB
Endif

# Si seul lancement autorisé par la transaction = matières seules
If [F:MTS]MFGMODC = 1 & [F:MTS]MFGMODO = 1
    [M:VIS1]ROUALT(nolign-1)  = 0
    [M:VIS1]ROUNUM(nolign-1)  = ""
Elsif [M:VIS1]BOMALT(nolign-1) <> 0 | [F:MTS]MFGMODO <> 1
    If [F:ITF]MFGROU = ""
        [M:VIS1]ROUNUM(nolign-1) = [M:VIS1]ITMREF(nolign-1)
    Else
        [M:VIS1]ROUNUM(nolign-1) = [F:ITF]MFGROU
    Endif

    # Issue 111414/12 - 2015-01 by GH : implementing route versioning
    [M:VIS1]ROUALT(nolign-1) = func RVMLIB.GETRVMALT([M:VIS1]ROUNUM(nolign-1),[M:VIS1]MFGFCY,[M:VIS1]STRDAT(nolign-1))
    If [M:VIS1]ROUALT(nolign-1) = 0
       Call RECH_GAM([M:VIS1]MFGFCY, [M:VIS1]STRDAT(nolign-1), [M:VIS1]ROUNUM(nolign-1), [M:VIS1]EXTQTY(nolign-1),
&                    [F:ITM]STU, [M:VIS1]BOMALT(nolign-1), [M:VIS1]ROUALT(nolign-1)) From BENCHLIB
    Else
       WALT=[M:VIS1]ROUALT(nolign-1)
       Call CONT_ROUALT([M:VIS1]MFGFCY, WALT, [M:VIS1]ROUNUM(nolign-1), [M:VIS1]STRDAT(nolign-1), [M:VIS1]EXTQTY(nolign-1),
&                       [F:ITM]STU, [M:VIS1]BOMALT(nolign-1)) From BENCHLIB
       If WALT=0 : [M:VIS1]ROUALT(nolign-1)=0 : GMESSAGE="" : Endif
    Endif
    If [M:VIS1]ROUALT(nolign-1) = 0 & [F:MTS]MFGMODM = 2 : Raz [M:VIS1]ROUNUM(nolign-1) : Endif

    If [F:MTS]MFGMODM = 1 & [M:VIS1]ROUALT(nolign-1) = 0
       If [M:VIS1]BOMALT(nolign-1)<>0 & WSEARCH
          Filter [BOH] Where BOMALT>[M:VIS1]BOMALT(nolign-1)
          WSEARCH=9 : [M:VIS1]BOMALT(nolign-1)=0 : : Goto ALT_SEARCH
       Endif
    Endif
Endif
If WSEARCH=9
   Filter [BOH] : WSEARCH=0
   # if not found a routing compatible with BOM, then reset the first BOM initally found
   If [M:VIS1]BOMALT(nolign-1)=0 : Goto ALT_SEARCH : Endif
Endif

# Issue 111414/12 - 2015-01 by GH : implementing route versioning
If dim([M:VIS1]ROUECCMAJ)>0 & func RVMLIB.NBRCPNROU([M:VIS1]ROUNUM(nolign-1))
   Call INIECCROU([M:VIS1]ROUNUM(nolign-1),[M:VIS1]MFGFCY,[M:VIS1]STRDAT(nolign-1),[M:VIS1]ROUALT(nolign-1)
&                ,[M:VIS1]ROUECCMAJ(nolign-1),[M:VIS1]ROUECCMIN(nolign-1)) From RVMLIB
Endif

[M:VIS1]PJT(nolign-1)        = [F:ORD]PJT
[M:VIS1]LOT(nolign-1)        = ""
[M:VIS1]FMI(nolign-1)        = [F:ORD]FMI
[M:VIS1]BPRNUM(nolign-1)     = [F:ORD]BPRNUM
[M:VIS1]PIO(nolign-1)        = [F:ORD]PIO
[M:VIS1]VCRTYPORI(nolign-1)  = 2
[M:VIS1]VCRNUMORI(nolign-1)  = WVCRNUM
[M:VIS1]VCRLINORI(nolign-1)  = WVCRLIN
[M:VIS1]VCRSEQORI(nolign-1)  = WVCRSEQ
[M:VIS1]WIPTYP(nolign-1)     = [F:ORD]WIPTYP
[M:VIS1]WIPNUM(nolign-1)     = [F:ORD]WIPNUM
[M:VIS1]MGTCOD(nolign-1)     = [F:ITM]STDFLG

# cocher ou non la ligne ?
[M:VIS1]PECFLG(nolign-1) = 2
# OF matières seules & Lcmt matière seule autorisée par trs
If [M:VIS1]ROUNUM(nolign-1)="" & [M:VIS1]ROUALT(nolign-1)= 0 & [F:MTS]MFGMODM = 2
    If [M:VIS1]STRDAT(nolign-1) < date$ |[M:VIS1]BOMALT(nolign-1) = 0 | [M:VIS1]EXTQTY(nolign-1) = 0
        [M:VIS1]PECFLG(nolign-1) = 1
    Endif
Elsif [M:VIS1]STRDAT(nolign-1) < date$ | [M:VIS1]ROUNUM(nolign-1) = "" | [M:VIS1]ROUALT(nolign-1) = 0  |
&   [M:VIS1]BOMALT(nolign-1) = 0  | [M:VIS1]EXTQTY(nolign-1) = 0
    [M:VIS1]PECFLG(nolign-1) = 1
Endif

# Issue 111414/12 - 2016-01 by GH - Implementation of versioning
If [M:VIS1]PECFLG(nolign-1) = 2 & dim([M:VIS1]ECCVALMAJ)>0 & func ECCLIB.NBRCPN([M:VIS1]ITMREF(nolign-1))
   Call CTRECC([M:VIS1]ITMREF(nolign-1),"VIS1","STRDAT",[M:VIS1]ECCVALMAJ(nolign-1),[M:VIS1]ECCVALMIN(nolign-1),
&              [M:VIS1]STRDAT(nolign-1),GERR,GMESSAGE) From ECCLIB
   If find(GERR,1,4)
      [M:VIS1]PECFLG(nolign-1) = 1
   Endif
   Raz GERR, GMESSAGE
Endif
If [M:VIS1]PECFLG(nolign-1) = 2 & [M:VIS1]ROUNUM(nolign-1)<>"" & dim([M:VIS1]ROUECCMAJ)>0
   I = func RVMLIB.NBRCPNROU([M:VIS1]ROUNUM(nolign-1))
   If (I & [M:VIS1]ROUECCMAJ(nolign-1)="") | (I=2 & [M:VIS1]ROUECCMIN(nolign-1)="")
      [M:VIS1]PECFLG(nolign-1) = 1
   Endif
Endif
Return

#########################################################################
$AVOK_MAUTF
Local Integer I, J, K

For J=0 To [M:VIS1]NBLIG-1
    If [M:VIS1]PECFLG(J)=2
        K = 0
        # On ne lance pas un WOx qui n'a pas d'alternative de nomenclature
        If [M:VIS1]BOMALT(J) = 0 & [F:MTS]MFGMODO <> 2
          # Issue 84916 GA 10/2012
          # autoriser BOMALT=0 dès lors que la transaction accepte "Opérations seules"
          K=1
        Elsif dim([M:VIS1]ECCVALMAJ)>0 : # Issue 111414/12 - 2016-01 by GH - Implementation of versioning
          I = func ECCLIB.NBRCPN([M:VIS1]ITMREF(J))
          If (I & [M:VIS1]ECCVALMAJ(J)="") | (I=2 & [M:VIS1]ECCVALMIN(J)="")
             K=1
          Endif
        Endif
        If !K
          # si mode de lcmt <> "matières seules", WROUNUM et WROUALT doivent être alimentées
          If [M:VIS1]ROUNUM(J)="" & [M:VIS1]ROUALT(J)=0 & [F:MTS]MFGMODM <> 2
             K=1
          Elsif [M:VIS1]ROUNUM(J)<>"" & dim([M:VIS1]ROUECCMAJ)>0 : # Issue 111414/12 - 2016-01 by GH - Implementation of versioning
             I = func RVMLIB.NBRCPNROU([M:VIS1]ROUNUM(J))
             If (I & [M:VIS1]ROUECCMAJ(J)="") | (I=2 & [M:VIS1]ROUECCMIN(J)="")
                K=1
             Endif
          Endif
        Endif
        If K
          Call MESSAGE(mess(230,123,1)-num$(J+1)) From GESECRAN
          FOK = 0 : GERR = 1 : FIN =0
        Endif
    Endif
Next J
Return

#########################################################################
$OK_MAUTF

TRA = 1
If GTRACE = ""
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("MAUTREL","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif

Gosub TRT_FMI

Return

#########################################################################
$TRT_FMI
Local Integer J

For J=0 To [M:VIS1]NBLIG-1
    If [M:VIS1]PECFLG(J) <> 2 : Goto NXT_FMI : Endif
    Gosub VERROU_FMI
    If !OK : Goto NXT_FMI : Endif
    Call DEBTRANS From GLOCK
    Gosub MAJ_FMI
    Gosub DEVERROU
$NXT_FMI
Next J

# aucune génération effectuee ou lecture trace
If !NBFMI
    GERR=2 : WMESS = mess(107,193,1)
    Call ECR_TRACE(WMESS,0) From GESECRAN
    Raz WMESS
Endif
# fermeture trace
Call FERME_TRACE From LECFIC
# lecture trace
Call LEC_TRACE From LECFIC

If GFONC1 = "FUNMAUT" : Raz GFONC1 : Endif

Return

#########################################################################
$MAJ_FMI
# GH 02/04/2014 bug 97868 on est hors transaction
#Trbegin [MFG]

    WMESS = mess(2,701,1)-[M:VIS1]VCRNUMORI(J)+"/"+num$([M:VIS1]VCRLINORI(J))+"/"+num$([M:VIS1]VCRSEQORI(J))

    Raz [M:MFGK]
    [M:MFGK]CODMAJ = "P"
    [M:MFGK]CODTRS = 1        : # GH 02/04/2014 bug 97868 : [M:MFGK]CODTRS = 0
    [M:MFGK]MFGNUM = ""
    [M:MFGK]MFGLIN = 0
    [M:MFGK]MFGFCY = [M:VIS1]MFGFCY
    Case [M:DIA]APSTA
        When 1: [M:MFGK]MFGSTA = 2
        When 2: [M:MFGK]MFGSTA = 1
        When Default : [M:MFGK]MFGSTA = 1
    Endcase
    [M:MFGK]ITMREF = [M:VIS1]ITMREF(J)
    [M:MFGK]EXTQTY = [M:VIS1]EXTQTY(J)
    If [M:MFGK]EXTQTY <= 0 : Return : Endif
    [M:MFGK]STRDAT = [M:VIS1]STRDAT(J)
    [M:MFGK]ENDDAT = [M:VIS1]ENDDAT(J)
    [M:MFGK]BOMALT = [M:VIS1]BOMALT(J)
    [M:MFGK]ROUALT = [M:VIS1]ROUALT(J)
    [M:MFGK]ROUNUM = [M:VIS1]ROUNUM(J)
    ## Issue 111414/12 - 2016-01 by GH - Implementation of versioning
    If dim([M:VIS1]ECCVALMAJ)>0 ## Issue 102319 GH 14/08/2018 - It crashed for a folder with no versioning
     [M:MFGK]ECCVALMAJ = [M:VIS1]ECCVALMAJ(J)
     [M:MFGK]ECCVALMIN = [M:VIS1]ECCVALMIN(J)
    Endif
    If dim([M:VIS1]ROUECCMAJ)>0
     [M:MFGK]ROUECCMAJ = [M:VIS1]ROUECCMAJ(J)
     [M:MFGK]ROUECCMIN = [M:VIS1]ROUECCMIN(J)
    Endif
    #
    [M:MFGK]PJT    = [M:VIS1]PJT(J)
    [M:MFGK]LOT    = [M:VIS1]LOT(J)
    [M:MFGK]FMI    = [M:VIS1]FMI(J)
    [M:MFGK]BPRNUM = [M:VIS1]BPRNUM(J)
    [M:MFGK]PIO    = [M:VIS1]PIO(J)
    [M:MFGK]VCRTYPORI = 2
    [M:MFGK]VCRNUMORI = [M:VIS1]VCRNUMORI(J)
    [M:MFGK]VCRLINORI = [M:VIS1]VCRLINORI(J)
    [M:MFGK]VCRSEQORI = [M:VIS1]VCRSEQORI(J)
    [M:MFGK]WIPTYP = [M:VIS1]WIPTYP(J)
    [M:MFGK]WIPNUM = [M:VIS1]WIPNUM(J)
    # mode de jalonnement
    Case [F:MTS]SCDMODSAI
        When 1:    [M:MFGK]SCDMOD = 1
        When 2:    [M:MFGK]SCDMOD = 2
        When Default: [M:MFGK]SCDMOD = 1
    Endcase
    # llc 7063 11.00 - si traitement de masse, pas d'édition dossier
    [M:MFGK]AUTOTRT = 2
    Call MAJ_OF From MFGAUTLIB
    If [M:MFGK]CODRET <> 0 : Goto AB_TRTAUTO : Endif

    # traces
    Case [M:MFGK]MFGSTA
        When 1:    WMESS -= mess(197,197,1)-"\("+[M:MFGK]MFGNUM+")"
        When 2:    WMESS -= mess(198,197,1)-"\("+[M:MFGK]MFGNUM+")"
    Endcase
    WMESS1  = ""

    # lecture OF pour comparaison dates    llc 02.01 8003
    Read [MFG]MFG0=[M:MFGK]MFGNUM
    #If !fstat & [M:VIS1]ENDDAT2(nolign-1) < [F:MFG]ENDDAT : # 2015-11-03 by GH
    If !fstat & [M:VIS1]ENDDAT2(J) < [F:MFG]ENDDAT
       WMESS1 = "          "+mess(95,190,1)
    Endif
    Call ECR_TRACE(WMESS,0) From GESECRAN
    If WMESS1 <> "" : Call ECR_TRACE(WMESS1,0) From GESECRAN : Endif
    Raz WMESS, WMESS1, WMESS2

    NBFMI += 1
#Commit

# llc 01.01 7063
#If GFONC1 = "FUNMAUT" & (dim(GMAUTFB) <= 0) & [M:MFGK]MFGSTA = 1 & [M:DIA]IMPFLG = 2
# GH 27/03/2014 bug 84721 GMAUTFB plus utilisé
If [M:MFGK]MFGSTA = 1 & [M:MFGK]AUTOTRT=2 & dim([M:DIA]IMPFLG)=1 & [M:DIA]IMPFLG = 2
    DOSOK = 0
    Call TEST_DOSSIER(DOSOK) From MFGAUTLIB
    If DOSOK =1
        If dim([M:DIA]PRT)=1 : GDEFIMP = [M:DIA]PRT : Else GDEFIMP = "" : Endif
        Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
        Read [F:MFP]MFP0 = [M:MFGK]MFGNUM
        If fstat : Raz [F:MFP] : Endif
        TBPAR(1)="codimp"        : TBVAL(1) = num$([F:MFP]MFGFDRFLG)
        TBPAR(2)="mfgfcydeb"     : TBVAL(2) = [M:MFGK]MFGFCY
        TBPAR(3)="mfgfcyfin"     : TBVAL(3) = [M:MFGK]MFGFCY
        TBPAR(4)="mfgnumdeb"     : TBVAL(4) = [M:MFGK]MFGNUM
        TBPAR(5)="mfgnumfin"     : TBVAL(5) = [M:MFGK]MFGNUM
        Call ETAT("DOSFAB",GDEFIMP,"",1,"",TBPAR,TBVAL) From AIMP3
    Endif
Endif
Return

#-----------------------------------------------------------------------#
# Positionnement d'un verrou sur l'entête de commande                   #
#-----------------------------------------------------------------------#
$VERROU_FMI
SYMBOLE = "SOH"+[M:VIS1]VCRNUMORI(J) : # SYMBOLE = "SOH"+[M:VIS1]VCRNUM(J) : # GH 09/09/2015 bug 110891
## GH 27/03/2014 bug 84721 pour ne pas delocker la cde si lockée en amont
Call TESTLOCK(SYMBOLE,OK) From GLOCKM
If OK
   SYMBOLE=""
   Return
Endif
##
Lock = SYMBOLE With lockwait = 0
If fstat
    Call ECR_TRACE(mess(2,701,1)-right$(SYMBOLE,4)-":"-mess(10,100,1),1) From GESECRAN
    OK = 0
Else
    OK = 1
Endif
Return

