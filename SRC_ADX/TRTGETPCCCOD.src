#============================================================
#================ Get PCCCOD --------------------------------
#== TRTGETPCCCOD.src
#============================================================
Funprog GET_PCCCOD_CTA(CODECTA)
Value Char  CODECTA
#------------------------------------------------------------
Local Char PCCCOD(15) : PCCCOD=""
If !clalev([F:CTA]) Local File PRPTSKCAT[CTA] : Endif
Read[CTA]CTA0=CODECTA
If fstat=0 :
   PCCCOD = [F:CTA]PCCCOD :
Endif
If clalev([F:CTA]) Close Local File [CTA] : Endif
End PCCCOD
#============================================================
Funprog GET_PCCCOD_TSK(WOPPNUM,WTASK)
Value Char      WOPPNUM
Value Char      WTASK
#------------------------------
Local Integer   WRET
Local Char      WPCCCOD(15) :

Local Instance  WTSK Using C_PRPTSK

 WPCCCOD=""
 WTSK=NewInstance C_PRPTSK  AllocGroup null
 WRET = fmet WTSK.AREAD (WOPPNUM,WTASK)
 If WRET=0
   #-- search nature depense from PRPTSKCAT categorie --------
   WPCCCOD = func GET_PCCCOD_CTA(WTSK.TCACOD)
 Endif
 #-- V7.1 ----------------------------------------------------
 FreezeInstance WTSK: #-- memory free
End WPCCCOD
# ==============================================================
Funprog GET_PCCCOD (WOPPNUM,WTASK)
Value Char      WOPPNUM
Value Char      WTASK
#---------------------------
End func GET_PCCCOD_TSK(WOPPNUM,WTASK)
# ==============================================================

