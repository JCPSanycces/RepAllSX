#<AdxTL>@(#)0.0.0.0 $Revision$
# Representation script: CCMIMPITMDET_RSTD, Change Request - sales order lines Collection
# Issue 109095/4 - 2015-11-17 by BAKHA : when enabling/disabling fields, check NCM planner
# Issue 110863/6/8 - 2015-11-17 by BAKHA : allow comment to be amended by actioner

#####################
# METHODS           #
#####################
$METHODS

  Case CURPTH
    When ""
      Case ACTION
        When "AQUERY_TRANS_AFTER"
          Gosub POPULATE_ACTIONDESC_QUERY
      Endcase
    When "CCMITMD"
      Case ACTION
        When "AREAD_AFTER"
          Gosub POPULATE_ACTIONDESC
          Gosub ACTIVATE_PROPERTIES
      Endcase
  Endcase
Return

# --------------------------------------------------
# Populate representation-only property ACTIONDESC (Query facet) ...
$POPULATE_ACTIONDESC_QUERY

  Local Integer LOCSTATUS
  Local Instance CCMACTION Using C_CCMACTION
  CCMACTION = NewInstance C_CCMACTION AllocGroup null

  If (this.CCMITMD.ACTIONID <> "")
    LOCSTATUS = fmet CCMACTION.AREAD(this.CCMITMD.ACTIONID)
    If (LOCSTATUS <> CST_AOK)
      this.CCMITMD.ACTIONDESC = ""
    Else
      this.CCMITMD.ACTIONDESC = mess(CCMACTION.TRANACTION,2032,1)
    Endif
  Else
    this.CCMITMD.ACTIONDESC = ""
  Endif

  FreeGroup CCMACTION

Return

# --------------------------------------------------
# Populate the Representation only (Action) Description.
$POPULATE_ACTIONDESC

  Local Instance CCMACTION Using C_CCMACTION
  CCMACTION = NewInstance C_CCMACTION AllocGroup null

  If (this.ACTIONID <> "")
    ASTATUS = fmet CCMACTION.AREAD(this.ACTIONID)

    If (ASTATUS <> CST_AOK)
      this.ACTIONDESC = ""
    Else
      this.ACTIONDESC = mess(CCMACTION.TRANACTION,2032,1)
    Endif
  Else
    this.ACTIONDESC = ""
  Endif

  FreeGroup CCMACTION

Return

# --------------------------------------------------
# Disable properties at run-time ...
$ACTIVATE_PROPERTIES

  Local Instance CHANGE_REQUEST Using C_CCMCHGREQ
  CHANGE_REQUEST = NewInstance C_CCMCHGREQ AllocGroup null
  Local Instance CCMIMPITM Using C_CCMIMPITM
  CCMIMPITM = NewInstance C_CCMIMPITM AllocGroup null
  Local Integer LOCAL_ASTATUS
  # Issue 109095/4 - if NCM, check for NCM Planner
  Local Integer IS_PLANNER

  LOCAL_ASTATUS = fmet CHANGE_REQUEST.AREAD(this.CRID)

  IS_PLANNER = CST_AFALSE
  # for change request check planner
  If (CHANGE_REQUEST.NCSREC<>2 and this.ACTX.USER = CHANGE_REQUEST.PLANNER)
    IS_PLANNER = CST_ATRUE
  # for non-conformance, check NCS Planner
  Elsif (CHANGE_REQUEST.NCSREC=2 and this.ACTX.USER = CHANGE_REQUEST.NCSPLANNER)
    IS_PLANNER = CST_ATRUE
  Endif
  FreeGroup CHANGE_REQUEST

  LOCAL_ASTATUS = fmet CCMIMPITM.AREAD(this.CRID)

  # All disabled (default) ...
  LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("ACTIONID",     "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("COMPLETEDATE", "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("COMMENT",      "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("LINESTATUS",   "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("ACTIONER",     "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("LINENO",      "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("STOFCY",      "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("ITMREF",      "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("ACTIONDESC",  "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("STARTDATE",   "$isDisabled", "true")
  LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("ENDDATE",     "$isDisabled", "true")

 # Enable by exception ...
  If (IS_PLANNER and CCMIMPITM.IMPLEMENT <> 2)
    LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("ACTIONID",     "$isDisabled", "false")
    LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("COMPLETEDATE", "$isDisabled", "false")
    LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("COMMENT",      "$isDisabled", "false")
    LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("ACTIONER", "$isDisabled", "false")
  Elsif (IS_PLANNER and CCMIMPITM.IMPLEMENT = 2 and this.LINESTATUS <> 3)
    LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("ACTIONER", "$isDisabled", "false")
  Endif

  If (CCMIMPITM.IMPLEMENT = 2 and this.ACTX.USER = this.ACTIONER and this.LINESTATUS <> 3)
# Issue 110863/6/8 - allow comment to be editied by actioner
     LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("COMMENT",  "$isDisabled", "false")
     LOCAL_ASTATUS = fmet this.ASETATTRIBUTE("LINESTATUS", "$isDisabled", "false")
  Endif
# End issue 109095/4

  FreeGroup CCMIMPITM

Return

$PROPERTIES

  Local Char PROPERTYACTION(50)
  PROPERTYACTION = CURPRO +"." +ACTION

  Case PROPERTYACTION
    When "CCMITMD.ACTIONID.PROPAGATE"     : Gosub POPULATE_ACTIONDESC

  Endcase

Return


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

