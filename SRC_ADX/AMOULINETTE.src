######################################################################################
Subprog IB_NBPLAN
If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif
Read [AI1]AI11=[M:AM5]MPLAN(nolign-1)

Case [F:AI1]STATUT
  When 1 : GBOUT2=""
  When 2,6,7,8 : GBOUT1=""
Endcase

If [F:AI1]NOMTRACE="" : GBOUT2="" : Endif
If nomap<>GDOSX3 : GBOUT1="" : Endif

End

# -----------------------------------------------------------------------------

Subprog B1_NBPLAN

Local Integer OKP
# Confirmez vous la suppresssion du plan ?
Call OUINON(mess(12,7902,1)-[M:AM5]MPLAN(nolign-1),OKP) From GESECRAN
If OKP<>2 : End : Endif
If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif
If clalev([F:AI2])=0 : Local File AMOULIN2 [AI2] : Endif
Trbegin [AI1],[AI2]
Delete [AI1] Where PLAN=[M:AM5]MPLAN(nolign-1)
Delete [AI2] Where PLAN=[M:AM5]MPLAN(nolign-1)
Commit
Call DISPLISTPLAN
End

# -----------------------------------------------------------------------------

Subprog B2_NBPLAN
If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif
Read [AI1]AI11=[M:AM5]MPLAN(nolign-1)
If fstat=0 and [F:AI1]NOMTRACE<>""
  Local Char SAVGTRACE(250) : SAVGTRACE=GTRACE
  GTRACE=[F:AI1]NOMTRACE
  Call CONS_TRACE From LECFIC
  GTRACE=SAVGTRACE
Endif
End


