#<AdxTL>@(#)10.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"AMOULIN","AMOULINETTE","") From GSAISIE
End


$ACTION
Case ACTION
  When "SETBOUT"         : Gosub SETBOUT
  When "DEBUT"           : Gosub DEBUT
  When "AP_CHOIX"        : Gosub BOUTON
  When "BOUTON"          : Gosub EXEBOUT
  When "APRES_MODIF"     : Gosub APRESMOD
  When "SUI"             : Gosub PLANSUI
  When "PRE"             : Gosub PLANPRE
Endcase
Return



# --------------------- Statuts des moulinettes et plan : menu 7944 ---------------------------------------------
#
#  1 : En attente                 2 : En cours           3 : Terminé  4 : Terminé avec erreurs  5 : Interrompu
#  6 : En attente interruption    7 : En attente arrêt   8 : Lancé    9 : Arrêté               10 : Bloqué     11 : Débrayé
#
# ---------------------------------------------------------------------------------------------------------------

$SETBOUT
Call VIREBOUT(CHMEN,"DEF") From GOBJET
Case [M:AM0]ISNEW
  When 1 : CHMEN+="D"
  When 2 : CHMEN+="E"
Endcase
If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif
Read [AI1]AI11=[M]PLAN
If fstat=0 and [F:AI1]NOMTRACE<>""
  CHMEN+="F"
Endif
Gosub SET_BOUT_SPE From GSAISIE


If [M:AM0]ISNEW=0
  If clalev([F:AI_1])=0 : Local File AMOULIN1 [AI_1] : Endif
  Read [AI_1]AI11>[M]PLAN
  If fstat<>0
    Call VIREBOUT(CHBOU,">") From GOBJET
  Endif
  Read [AI_1]AI11=[M]PLAN
  Read [AI_1]AI11 Prev
  If fstat<>0
    Call VIREBOUT(CHBOU,"<") From GOBJET
  Endif
Endif


$SETICONE
If nomap=GDOSX3
  Actzo[M:AM0]ARRET,ACTIV,INTERR,RAFR,BLOQUER,DEBLOQUER
Else
  Diszo [M:AM0]
Endif
If [M:AM0]ISNEW>0
  Diszo [M:AM0]RAFR,ARRET,ACTIV,INTERR,BLOQUER,DEBLOQUER
  Return
Endif

If [M:AM0]STATUT=2 or [M:AM0]STATUT=3  or [M:AM0]STATUT=8
  Diszo [M:AM0]ACTIV
Endif
If [M:AM0]STATUT=1 or [M:AM0]STATUT=3 or [M:AM0]STATUT=4 or [M:AM0]STATUT=5 or [M:AM0]STATUT=6 or [M:AM0]STATUT=7 or [M:AM0]STATUT=9
  Diszo [M:AM0]ARRET
Endif
If [M:AM0]STATUT=1 or [M:AM0]STATUT=3 or [M:AM0]STATUT=4 or [M:AM0]STATUT=5 or [M:AM0]STATUT=6 or [M:AM0]STATUT=9
  Diszo [M:AM0]INTERR
Endif
If [M:AM0]STATUT=1 :  Diszo [M:AM0]RAFR  : Endif
If clalev([F:AI2])=0 : Local File AMOULIN2 [AI2] : Endif
Local Integer NBAT,NBBL
Filter [AI2] Where PLAN=[M]PLAN
For [AI2]
  If [F:AI2]STATUT=1  : NBAT+=1 : Endif
  If [F:AI2]STATUT=10 : NBBL+=1 : Endif
Next
If NBAT=0 : Diszo [M:AM0]BLOQUER : Endif
If NBBL=0 : Diszo [M:AM0]DEBLOQUER : Endif
Filter [AI2]
Return

$PLANSUI
If [M:AM0]ISNEW<>0 : Return : Endif
If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif
Read [AI1]AI11>[M]PLAN
If fstat=0
 [M]PLAN=[F:AI1]PLAN
 Call RAFRAICHI([M]PLAN)
Endif
Return

$PLANPRE
If [M:AM0]ISNEW<>0 : Return : Endif
If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif
Read [AI1]AI11=[M]PLAN
If fstat=0
 Read [AI1]AI11 Prev
 If fstat=0
   [M]PLAN=[F:AI1]PLAN
   Call RAFRAICHI([M]PLAN)
 Endif
Endif
Return


#--------------------------------------------------#
$EXEBOUT
Case BOUT
  When "D"
    Local Integer OKP
    Call CREPLAN([M:AM0]PLAN,[M:AM0]INTIT,[M:AM0]STATUT,[M:AM0]DOSSIER,[M:AM0]NBPARL,[M:AM0]PHASEAUTO,[M:AM0]POSTAUTO,OKP)
    If [M:AM2]DAAFIL<>"" | [M:AM2]IDXFIL<>""
      Call UPDATEPLAN([M:AM0]PLAN,[M:AM0]INTIT,[M:AM0]STATUT,[M:AM0]DOSSIER,[M:AM0]NBPARL,[M:AM0]PHASEAUTO,[M:AM0]POSTAUTO,[M:AM2]DAAFIL,[M:AM2]IDXFIL)
    Endif
    [M:AM0]ISNEW=0
    Call RAFRAICHI([M:AM0]PLAN)
  When "E" :
    Local Integer AAPHASEAUTO,AAPOSTAUTO
    If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif
    Read [AI1]AI11=[M:AM0]PLAN
    If fstat=0
      If [M:AM0]PHASEAUTO<>[F:AI1]PHASEAUTO : AAPHASEAUTO=2 : Endif
      If [M:AM0]POSTAUTO<>[F:AI1]POSTAUTO: AAPOSTAUTO=2 : Endif
    Endif
    Call UPDATEPLAN([M:AM0]PLAN,[M:AM0]INTIT,[M:AM0]STATUT,[M:AM0]DOSSIER,[M:AM0]NBPARL,[M:AM0]PHASEAUTO,[M:AM0]POSTAUTO,[M:AM2]DAAFIL,[M:AM2]IDXFIL)
    [M:AM0]ISNEW=0
    If AAPHASEAUTO=2 or AAPOSTAUTO=2
      Gosub UPDSTATPLAN
    Endif
    Call RAFRAICHI([M:AM0]PLAN)
  When "F" :
     If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif
     Read [AI1]AI11=[M]PLAN
     If fstat=0 and [F:AI1]NOMTRACE<>""
       Local Char SAVGTRACE(250) : SAVGTRACE=GTRACE
       GTRACE=[F:AI1]NOMTRACE
       Call CONS_TRACE From LECFIC
       GTRACE=SAVGTRACE
     Endif
Endcase
Return


$APRESMOD
If [M:AM0]ISNEW=0 and COUZON<>"PLAN"
  [M:AM0]ISNEW=2
Endif
Return


$DEBUT
If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif
Local Date DATCOU
Local Char HEUCOU(30)
Effzo [M:AM0]10,20
Raz [M:AM1]
Raz [M:AM2]
If GTYPDBA=1 : #Oracle
  [M:AM2]INTITFIL=mess(114,124,1)-"/"-mess(2,23,1)
Else
  [M:AM2]INTITFIL=func RDM("ADS1","GRPFIL")-"/"-mess(4,23,1)
Endif
For [AI1]
  If [F:AI1]DATEEC > DATCOU or ([F:AI1]DATEEC = DATCOU and [F:AI1]HEUEC > HEUCOU)
    [M:AM0]PLAN=[F:AI1]PLAN
    DATCOU=[F:AI1]DATEEC
    HEUCOU=[F:AI1]HEUEC
  Endif
Next

If [M:AM0]PLAN<>""
  Call RAFRAICHI([M:AM0]PLAN)
Else
  Call DISPLISTPLAN
Endif
Return

$CALCULLIC
#109897 Raz [M]NBLICBATCH,NBPROPAR

#87108
# 99551
#Local Char VALMAX(250)
#If fmet GACTX.AGETLICPAR("MAXBATCH",VALMAX)=[V]CST_ATRUE
# [M]NBLICBATCH="("+VALMAX+")"
#Endif

#109897
#If clalev([F:ABP])=0 : Local File ABATPAR [ABP] : Endif
#Read [ABP]SPOOL First
#If fstat=0
#  [M]NBPROPAR="/"+num$([F:ABP]NBTACHE)
#Endif
Return



$BOUTON
If REPONSE=GSTANEW
  Effzo [M:AM0]10,20
  Effzo [M:AM0]DATEL,HEUL,DATEEC,HEUEC,ELAPSEDG
  Raz [M:AM1]
  Raz [M:AM2]
  If GTYPDBA=1 : #Oracle
    [M:AM2]INTITFIL=mess(114,124,1)-"/"-mess(2,23,1)
  Else
    [M:AM2]INTITFIL=func RDM("ADS1","GRPFIL")-"/"-mess(4,23,1)
  Endif
  Affzo [M:AM0]
  Affzo [M:AM1]
  Affzo [M:AM2]
  [M:AM0]ISNEW=1
Endif
Return


# --------------------------------------------------------------------------

Subprog UPDATEPLAN(PLAN,INTIT,STATUT,DOSSIER,NBPARL,PHASEAUTO,POSTAUTO,DAAFIL,IDXFIL)
Value Char PLAN
Value Char INTIT
Value Integer STATUT
Value Char DOSSIER
Value Integer NBPARL
Value Integer PHASEAUTO
Value Integer POSTAUTO
Value Char DAAFIL()
Value Char IDXFIL()

If [L]PLAN="" : End : Endif

If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif
Trbegin [AI1]
Read [AI1]AI11=[L]PLAN
If fstat<>0 : End : Endif
[F:AI1]INTIT=[L]INTIT
[F:AI1]DOSSIER=[L]DOSSIER
[F:AI1]STATUT=max([L]STATUT,1)
[F:AI1]NBPARL=max([L]NBPARL,1)
[F:AI1]PHASEAUTO=max([L]PHASEAUTO,1)
[F:AI1]POSTAUTO=max([L]POSTAUTO,1)
[F:AI1]DAAFIL=[L]DAAFIL
[F:AI1]IDXFIL=[L]IDXFIL
Rewrite [AI1]
Commit
End

# --------------------------------------------------------------------------

Subprog CREPLAN(PLAN,INTIT,STATUT,DOSSIER,NBPARL,PHASEAUTO,POSTAUTO,OK)
Value Char PLAN
Value Char INTIT
Value Integer STATUT
Value Char DOSSIER
Value Integer NBPARL
Value Integer PHASEAUTO
Value Integer POSTAUTO
Variable Integer OK

#    OK   = 1  plan crée
#         = 2  nom de plan "blanc"
#         = 3  plan existe déjà

OK=1
Local Integer CREPLAN,I
If [L]PLAN="" : OK=2 : End : Endif

If clalev([F:AI0])=0 : Local File AMOULIN  [AI0] : Endif
If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif
If clalev([F:AI2])=0 : Local File AMOULIN2 [AI2] : Endif
Trbegin [AI1],[AI2]
Read [AI1]AI11=[L]PLAN
If fstat=0 : OK=3 : End : Endif
Raz [F:AI1]
[F:AI1]PLAN=[L]PLAN
[F:AI1]INTIT=[L]INTIT
[F:AI1]DOSSIER=[L]DOSSIER
[F:AI1]STATUT=max([L]STATUT,1)
[F:AI1]NBPARL=max([L]NBPARL,1)
[F:AI1]PHASEAUTO=max([L]PHASEAUTO,1)
[F:AI1]POSTAUTO=max([L]POSTAUTO,1)
If GTRACE<>""
  [F:AI1]NOMTRACE=GTRACE
Endif
Write [AI1]

Delete [AI2] Where PLAN=[L]PLAN

Local Integer RANGMODREF,PHASEREF
Filter [AI0] Where PLAN=[L]PLAN and ACTIF=2 Order By INDICEM
For [AI0]
  Raz [F:AI2]
  [F:AI2]PLAN=[L]PLAN
  [F:AI2]INDICEM=[F:AI0]INDICEM
  [F:AI2]MODULE=[F:AI0]MODULE
  [F:AI2]CODE=[F:AI0]CODE
  [F:AI2]PHASE=[F:AI0]PHASE
  [F:AI2]RANG=[F:AI0]RANG
  [F:AI2]RANGMOD=[F:AI0]RANGMOD
  If RANGMODREF=0 : RANGMODREF=[F:AI2]RANGMOD : Endif
  If PHASEREF=0 : PHASEREF=[F:AI2]PHASE: Endif
  [F:AI2]STATUT=1
  If PHASEAUTO<>2 and (RANGMODREF<>[F:AI2]RANGMOD or PHASEREF<>[F:AI2]PHASE) : [F:AI2]STATUT=10 : Endif
  If [F:AI2]RANGMOD=4 and [F:AI1]POSTAUTO<>2 : [F:AI2]STATUT=10 : Endif
  Write [AI2]
Next
Filter [AI0]

Commit
End



# -------------------------------------------------------------------------------------

Subprog ACTIVPLAN(PLAN,OK)
Value Char PLAN
Variable Integer OK

#  OK : 1 Plan activé
#       2 Plan n'existe pas
#       3 Statut du plan incorrect pour le lancer

  OK=1
  If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif
  If clalev([F:AI2])=0 : Local File AMOULIN2 [AI2] : Endif
  Local Integer NBM,I,OKP
  Read [AI1]AI11=PLAN
  If fstat<>0 : OK=2 : End : Endif
  If [F:AI1]STATUT<>1 and [F:AI1]STATUT<>5 and [F:AI1]STATUT<>6
& and [F:AI1]STATUT<>7 and [F:AI1]STATUT<>9 and [F:AI1]STATUT<>10
    OK=3
    End
  Endif
  Trbegin [AI1]
  If [F:AI1]STATUT=1
    [F:AI1]DATEL=date$
    [F:AI1]HEUL=left$(time$,2)+mid$(time$,4,2)
  Else
    [F:AI1]NBREL+=1
  Endif
  [F:AI1]DATEEC=date$
  [F:AI1]HEUEC=left$(time$,2)+mid$(time$,4,2)
  [F:AI1]STATUT=2
  Rewrite [AI1]
  Commit

#  On vérifie si il y a des moulinettes interrompues ou en attente d'interruption et on propose de les réactiver

# --------------------- Statuts des moulinettes et plan : menu 7944 ---------------------------------------------
#
#  1 : En attente                 2 : En cours           3 : Terminé  4 : Terminé avec erreurs  5 : Interrompu
#  6 : En attente interruption    7 : En attente arrêt   8 : Lancé    9 : Arrêté               10 : Bloqué     11 : Débrayé
#
# ---------------------------------------------------------------------------------------------------------------


  Local Integer NBMINT
  Filter [AI2] Where PLAN=[L]PLAN and (STATUT=5 or STATUT=6)
  For [AI2]
    NBMINT+=1
  Next
  Filter [AI2]
  If NBMINT>0
#  Voulez vous remettre en attente les procédures interrompues et en cours les procédures en attente d'interruption ?
    Call OUINON(mess(24,7902,1),OKP) From GESECRAN
    If OKP=2
      Trbegin [AI2]
      Filter [AI2] Where PLAN=[L]PLAN and (STATUT=5 or STATUT=6)
      For [AI2]
        If [F:AI2]STATUT=6 or [F:AI2]STATUT=7   : [F:AI2]STATUT=2 : Endif
        If [F:AI2]STATUT=5   : [F:AI2]STATUT=1 : Endif
        Rewrite [AI2]
      Next
      Filter [AI2]
      Commit
    Endif
  Endif

  Local Char NEXTM(30),CODE(30)
  For I=1 To [F:AI1]NBPARL
    Gosub NEXTMOULIN
    If NEXTM="" : Break 1 : Endif
    Call LANCEMOUL(PLAN,NEXTM,OKP)
  Next I
End

# -------------------------------------------------------------------------

Subprog STOPPLAN(PLAN,TYPSTOP,OK)
Value Char PLAN
Value Char TYPSTOP
Variable Integer OK

#  OK : 1 Plan stoppé
#       2 Plan n'existe pas
#       3 Statut du plan incorrect pour l'arrêter


#  TYPSTOP : STOP  ou  INTERR
  OK=1
  If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif
  If clalev([F:AI2])=0 : Local File AMOULIN2 [AI2] : Endif
  Local Integer NBM,I
  Read [AI1]AI11=PLAN
  If fstat<>0 : OK=2 : End : Endif
  If [F:AI1]STATUT<>2 and [F:AI1]STATUT<>8 : OK=3 : End : Endif
  Trbegin [AI1],[AI2]
  If TYPSTOP="STOP"   : [F:AI1]STATUT=7 : Endif
  If TYPSTOP="INTERR" : [F:AI1]STATUT=6 : Endif

  [F:AI1]DATEEC=date$
  [F:AI1]HEUEC=left$(time$,2)+mid$(time$,4,2)
  Rewrite [AI1]

  Filter [AI2] Where PLAN=[L]PLAN and (STATUT=2 or STATUT=8)
  For [AI2]
    If TYPSTOP="STOP"   : [F:AI2]STATUT=7 : Endif
    If TYPSTOP="INTERR" : [F:AI2]STATUT=6 : Endif
    Rewrite [AI2]
  Next
  Filter [AI2]
  Commit

  Call RAFRAICHI(PLAN)
End

# -------------------------------------------------------------------------

Subprog LANCENEXTMOUL(PLAN,CODEC,OK)
Value Char PLAN
Value Char CODEC
Variable Integer OK

#  Si OK =1  moulinette suivante lancée
#         2  il n'y a pas de moulinette à lancer
#         6  le plan est arrêté ou interrompu

OK=1
If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif
If clalev([F:AI2])=0 : Local File AMOULIN2 [AI2] : Endif
Read [AI1]AI11=PLAN
If fstat<>0 : OK=2 : End : Endif
If [F:AI1]STATUT=5 or [F:AI1]STATUT=6 or [F:AI1]STATUT=7 or [F:AI1]STATUT=9 : OK=6 : End : Endif

Local Char NEXTM(30)
Gosub NEXTMOULIN
If [F:AI1]STATUT=1  : [F:AI1]STATUT=8 : Endif
If NEXTM=""
 OK=1
 If [F:AI1]STATUT<>3 and [F:AI1]STATUT<>4
  Trbegin [AI1]
  If (NBMOULSTA(3)+NBMOULSTA(4)=NBM)
    If NBMOULSTA(4)=0
      [F:AI1]STATUT=3
    Else
      [F:AI1]STATUT=4
    Endif
  Endif
# Le plan est-il entièrement stoppé ?
  If NBMOULSTA(3)+NBMOULSTA(4)+NBMOULSTA(11)+NBMOULSTA(5)=NBM and NBMOULSTA(5)>0 and [F:AI1]STATUT=7
    [F:AI1]STATUT=5
  Endif
  [F:AI1]DATEEC=date$
  [F:AI1]HEUEC=left$(time$,2)+mid$(time$,4,2)
  Rewrite [AI1]
  Commit
  #84463 add message at the end of folder validation trace file
  If [F:AI1]NOMTRACE<>"" & find([F:AI1]STATUT,3,4)>0
   Openo filpath("TRA",[F:AI1]NOMTRACE,"tra"), -1 Using [TRA]
   adxifs = ""
   adxirs = chr$(10)
   adxium = GTRAFOR
   Wrseq Using [TRA]
   Wrseq func AFNC.MES2(mess(324,123,1),PLAN,mess([F:AI1]STATUT,7944,1)) Using [TRA]
   Wrseq Using [TRA]
   Openo Using [TRA]
  Endif
 Endif
 End
Endif

Call LANCEMOUL(PLAN,NEXTM,OK)

# On vérifie si on peut en lancer plus

Local Integer I
For I=1 To [F:AI1]NBPARL-NBMOULSTA(2)-1
  Gosub NEXTMOULIN
  If NEXTM="" : Break 1 : Endif
  Call LANCEMOUL(PLAN,NEXTM,OK)
Next I

Trbegin [AI1]
[F:AI1]STATUT=2
[F:AI1]DATEEC=date$
[F:AI1]HEUEC=left$(time$,2)+mid$(time$,4,2)
Rewrite [AI1]
Commit

End

# --------------------- Statuts des moulinettes et plan : menu 7944 ---------------------------------------------
#
#  1 : En attente                 2 : En cours           3 : Terminé  4 : Terminé avec erreurs  5 : Interrompu
#  6 : En attente interruption    7 : En attente arrêt   8 : Lancé    9 : Arrêté               10 : Bloqué    11 : Débrayé
#
# ---------------------------------------------------------------------------------------------------------------

$NEXTMOULIN

# On lance à l'intérieur d'une étape séquentiellement pour chaque phase, et toutes les tâches d'une phase sans attente de fin


    Local Integer NBM,VINDICEM(1..200),VMODULE(1..200),VPHASE(1..200),VRANG(1..200),VSTATUT(1..200),VRANGMOD(1..200)
    Local Char VCODE(12)(1..200)
    Local Integer IATT,IREC,NBMOULACT,NBRUN,NBMOULSTA(1..11),IACODEC
    Filter [AI2] Where PLAN=[L]PLAN Order By INDICEM
    For [AI2]
      NBM+=1
      VCODE(NBM)=[F:AI2]CODE
      If [F:AI1]CODEEC=[F:AI2]CODE : IACODEC=NBM : Endif
      VINDICEM(NBM)=[F:AI2]INDICEM
      VMODULE(NBM)=[F:AI2]MODULE
      VPHASE(NBM)=[F:AI2]PHASE
      VRANG(NBM)=[F:AI2]RANG
      VSTATUT(NBM)=[F:AI2]STATUT
      If VSTATUT(NBM)>=1 and VSTATUT(NBM)<=11
          NBMOULSTA(VSTATUT(NBM))+=1
      Endif
      VRANGMOD(NBM)=[F:AI2]RANGMOD
      If IATT=0 and VSTATUT(NBM)=1 : IATT=NBM : Endif
    Next
    Filter [AI2]

   If IATT=1 : NEXTM=VCODE(1) : Return : Endif
   If IATT=0 : NEXTM=""       : Return : Endif

#  Contrôle si on peut lancer encore des moulinettes
   For IREC=1 To NBM
     If VSTATUT(IREC)=2 or VSTATUT(IREC)=8
       NBRUN+=1
     Endif
   Next IREC
   If NBRUN>=[F:AI1]NBPARL : NEXTM="" : Return : Endif

#  Contrôles sur les droits de lancement de la moulinette
   Local Integer SELECTM
   NEXTM=""
   While SELECTM=0
     Gosub CONTM
     If SELECTM=0
       IATT+=1
       If IATT>NBM : Break 1 : Endif
     Endif
   Wend
   Return


$CONTM
   If VSTATUT(IATT)<>1  : Return : Endif
   SELECTM=1
   For IREC=1 To IATT-1
     If (VRANGMOD(IREC)<VRANGMOD(IATT) and (VSTATUT(IREC)<>3 and VSTATUT(IREC)<>11)) or
&       (VRANGMOD(IREC)=VRANGMOD(IATT) and VPHASE(IREC)<VPHASE(IATT)  and (VSTATUT(IREC)<>3 and VSTATUT(IREC)<>11))
       SELECTM=0 : Break 1
     Endif
   Next IREC
  If SELECTM=1 : NEXTM=VCODE(IATT) : Endif
Return

#---------------------------------------------------------------------------------------------------------

Subprog LANCEMOUL(PLAN,CODE,OK)
Value Char PLAN
Value Char CODE
Variable Integer OK

OK=1
If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif
If clalev([F:AI2])=0 : Local File AMOULIN2 [AI2] : Endif
Read [AI1]AI11=PLAN
If fstat<>0 : OK=2 : End : Endif

Read [AI2]AI21=PLAN;CODE
If fstat=0
 If [F:AI2]STATUT=1 or [F:AI2]STATUT=4 or [F:AI2]STATUT=11
  If [F:AI2]STATUT=1
    [F:AI2]DATEL=date$
    [F:AI2]HEUL=left$(time$,2)+mid$(time$,4,2)
  Endif
  [F:AI2]STATUT=8
  [F:AI2]DATEMAJ=date$
  [F:AI2]HEUMAJ=left$(time$,2)+mid$(time$,4,2)

#  Création d'une requête dans le serveur batch
  Local Integer REQUETE
  Local Mask AMOULIN4 [AM4]
  [M:AM4]DOSSIER=[F:AI1]DOSSIER
  [M:AM4]CRIT1=PLAN+":"+CODE
  #109897
  #Call CRERQT(GDOSX3,GUSER,"",0,"AMOULIN4",1,date$,left$(time$,2)+mid$(time$,4,2),"","AM4",REQUETE) From REQUETES
  Call CRERQTLAN(GDOSX3,GUSER,GLANGUE,"",0,"AMOULIN4",1,date$,left$(time$,2)+mid$(time$,4,2),"","AM4",REQUETE) From REQUETES
#  Infbox(mess(4,7902,1)-num$(REQUETE))
  [F:AI2]NUMREQ=REQUETE
  Trbegin [AI2],[AI1]
  Rewrite [AI2]
  [F:AI1]CODEEC=CODE
  Rewrite [AI1]
  Commit
 Else
  OK=4
  If [F:AI2]STATUT=2 : GMESSAGE=mess(1,7902,1) : Endif
  If [F:AI2]STATUT=3 : GMESSAGE=mess(2,7902,1) : Endif
 Endif
Else
  OK=3 : GMESSAGE=mess(3,7902,1)
Endif
End

# -------------------------------------------------------------------------

Subprog STOPMOUL(PLAN,CODE,OK)
Value Char PLAN
Value Char CODE
Value Integer OK

OK=2
If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif
If clalev([F:AI2])=0 : Local File AMOULIN2 [AI2] : Endif
Read [AI2]AI21=PLAN;CODE
If fstat=0 and ([F:AI2]STATUT=2 or [F:AI2]STATUT=6 or [F:AI2]STATUT=8)
  Trbegin [AI2]
  [F:AI2]STATUT=6
  [F:AI2]DATEMAJ=date$
  [F:AI2]HEUMAJ=left$(time$,2)+mid$(time$,4,2)
  Rewrite [AI2]
  Commit
  OK=1
Endif
End

# -------------------------------------------------------------------------

$CONTREQUETES
If clalev([F:ABR])=0 : Local File ABATRQT [ABR] : Endif
If clalev([F:AI2])=0 : Local File AMOULIN2 [AI2] : Endif
Filter [AI2] Where PLAN=APLAN and (STATUT=2 or STATUT=8)  and NUMREQ<>0
For [AI2]
  Read [ABR]NUMREQ = [F:AI2]NUMREQ
  If fstat=0 and ([F:ABR]FLAG=3 or [F:ABR]FLAG=6 or [F:ABR]FLAG=7)
    Trbegin [AI2]
    [F:AI2]STATUT=4
    If [F:ABR]FLAG=3 : [F:AI2]STATUT=3 : Endif
    Rewrite [AI2]
    Commit
  Endif
Next
Filter [AI2]
Return

# ------------------------------------------------------------------------------------------------------------

Subprog RAFRAICHI(APLAN)
Value Char APLAN
If APLAN="" : End : Endif
If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif
If clalev([F:AI2])=0 : Local File AMOULIN2 [AI2] : Endif
If clalev([F:AI0])=0 : Local File AMOULIN [AI0] : Endif

Gosub CONTREQUETES
Local Integer NBM
Effzo [M:AM1]
Effzo [M:AM2]
If GTYPDBA=1 : #Oracle
  [M:AM2]INTITFIL=mess(114,124,1)-"/"-mess(2,23,1)
Else
  [M:AM2]INTITFIL=func RDM("ADS1","GRPFIL")-"/"-mess(4,23,1)
Endif
Effzo [M:AM0]INTIT,STATUT,DOSSIER,NBPARL
Effzo [M:AM0]NBM1,NBM2,NBM3,NBM4,NBM5,NBM6,NBM7,NBM8,NBM10,NBM11
Read [AI1]AI11=APLAN
If fstat=0
  Local Integer HOURMAX,HOURNOWMAX,HOURSTARTMAX
  [M:AM0]INTIT=[F:AI1]INTIT
  [M:AM0]DOSSIER=[F:AI1]DOSSIER
  [M:AM0]STATUT=[F:AI1]STATUT
  [M:AM0]DATEL=[F:AI1]DATEL
  [M:AM0]HEUL=[F:AI1]HEUL
  [M:AM0]DATEEC=[F:AI1]DATEEC
  [M:AM0]HEUEC=[F:AI1]HEUEC
  [M:AM0]NBPARL=[F:AI1]NBPARL
  [M:AM0]PHASEAUTO=[F:AI1]PHASEAUTO
  [M:AM0]POSTAUTO=[F:AI1]POSTAUTO
  [M]DAAFIL=[F:AI1]DAAFIL
  [M]IDXFIL=[F:AI1]IDXFIL
#  Calcul de ELAPSEDG
  If [M]STATUT=1
    [M:AM0]ELAPSEDG=""
  Else
    Local Integer HOURNOW,HOURSTART,HHELP,MNELP
    HOURSTART=val(left$([M:AM0]HEUL,2))*60+val(right$([M:AM0]HEUL,3))
    HOURSTARTMAX=HOURSTART
    If [M:AM0]STATUT=2
      HOURNOW=val(left$(time$,2))*60+val(mid$(time$,4,2))+(date$-[M:AM0]DATEL)*24*60
    Else
      HOURNOW=val(left$([M:AM0]HEUEC,2))*60+val(right$([M:AM0]HEUEC,3))+([M:AM0]DATEEC-[M:AM0]DATEL)*24*60
    Endif
    HOURNOW-=HOURSTART
    HHELP=HOURNOW/60
    MNELP=HOURNOW-60*HHELP
    [M:AM0]ELAPSEDG=format$("N0:###",HHELP)+":"+format$("N0:##",MNELP)
  Endif
  Filter [AI2] Where PLAN=APLAN Order By INDICEM
  For [AI2]
   [M]INDICEM(NBM)=[F:AI2]INDICEM
   [M]CODE(NBM)=[F:AI2]CODE
   [M]MODULE(NBM)=[F:AI2]MODULE
   [M]PHASE(NBM)=[F:AI2]PHASE
   [M]RANG(NBM)=[F:AI2]RANG
   [M]RANGMOD(NBM)=[F:AI2]RANGMOD
   [M]STATUTM(NBM)=[F:AI2]STATUT
   [M]DATELM(NBM)=[F:AI2]DATEL
   [M]HEULM(NBM)=[F:AI2]HEUL
   [M]DATEMAJ(NBM)=[F:AI2]DATEMAJ
   [M]HEUMAJ(NBM)=[F:AI2]HEUMAJ
   [M]NBENREG(NBM)=[F:AI2]NBENREG
   [M]NBENREGT(NBM)=[F:AI2]NBENREGT
   [M]ELAPSED(NBM)=""
    Case [F:AI2]STATUT
      When 1  : [M]NBM1+=1   : #  En Attente
      When 2  : [M]NBM2+=1   : #  En cours
      When 3  : [M]NBM3+=1   : #  Terminé
      When 4  : [M]NBM4+=1   : #  Terminé avec erreurs
      When 5  : [M]NBM5+=1   : #  Interrompu
      When 6  : [M]NBM6+=1   : #  En attente interruption
      When 7  : [M]NBM7+=1   : #  En attente d'arrêt
      When 8  : [M]NBM8+=1   : #  Lancé
      When 10 : [M]NBM10+=1  : #  Bloqué
      When 11 : [M]NBM11+=1  : #  Débrayé
    Endcase

#  Calcul de ELAPSED
   If [M]STATUTM(NBM)=1 or [M]STATUTM(NBM)=10
     [M]ELAPSED(NBM)=""
   Else
     Local Integer HOURNOW,HOURSTART,HHELP,MNELP
     HOURSTART=val(left$([M]HEULM(NBM),2))*60+val(right$([M]HEULM(NBM),3))
     If [M]STATUTM(NBM)=2
       HOURNOW=val(left$(time$,2))*60+val(mid$(time$,4,2))+(date$-[M]DATELM(NBM))*24*60
     Else
       HOURNOW=val(left$([M]HEUMAJ(NBM),2))*60+val(right$([M]HEUMAJ(NBM),3))+([M]DATEMAJ(NBM)-[M]DATELM(NBM))*24*60
     Endif
     HOURNOW-=HOURSTART
     HHELP=HOURNOW/60
     MNELP=HOURNOW-60*HHELP
     [M]ELAPSED(NBM)=format$("N0:###",HHELP)+":"+format$("N0:##",MNELP)
   Endif

   If [M]DATEMAJ(NBM)<>[0/0/0]
     If [M]STATUTM(NBM)=2
       HOURNOWMAX=val(left$(time$,2))*60+val(mid$(time$,4,2))+(date$-[M:AM0]DATEL)*24*60
     Else
       HOURNOWMAX=val(left$([M]HEUMAJ(NBM),2))*60+val(right$([M]HEUMAJ(NBM),3))+([M]DATEMAJ(NBM)-[M:AM0]DATEL)*24*60
     Endif
     HOURNOWMAX-=HOURSTARTMAX
     HOURMAX=max(HOURMAX,HOURNOWMAX)
   Endif

   Read [AI0]AI01=[M]CODE(NBM)
   If fstat=0
     Call TEXTE([F:AI0]INTIT,[M]INTITM(NBM)) From OBJDIV
   #  Call LECTEXTRA([M]INTITM(NBM),"AMOULIN","INTIT",[M]CODE(NBM),"") From ATEXTRA
   Endif
   NBM+=1
  Next
  [M]NBLIG=NBM
  Filter [AI2]

  #Gosub CALCULLIC

  If HOURMAX>0
   HHELP=HOURMAX/60
   MNELP=HOURMAX-60*HHELP
   [M:AM0]ELAPSEDG=format$("N0:###",HHELP)+":"+format$("N0:##",MNELP)
  Endif

#   Rectification statut global
  Local Integer MODIF
  If [F:AI1]STATUT=6 and [M]NBM6=0 : [F:AI1]STATUT=5 : MODIF=1 : Endif
  If [F:AI1]STATUT=7 and [M]NBM7=0 : [F:AI1]STATUT=9 : MODIF=1 : Endif
  If [F:AI1]STATUT=2 and ([M]NBM3+[M]NBM4=NBM)
    [F:AI1]STATUT=3
    If [M]NBM4>0 : [F:AI1]STATUT=4 : Endif
    MODIF=1
  Endif
  If MODIF=1
    [M]STATUT=[F:AI1]STATUT
    Trbegin [AI1]
    Rewrite [AI1]
    Commit
    #84463 add message at the end of folder validation trace file
    If [F:AI1]NOMTRACE<>"" & find([F:AI1]STATUT,3,4)>0
     Openo filpath("TRA",[F:AI1]NOMTRACE,"tra"), -1 Using [TRA]
     adxifs = ""
     adxirs = chr$(10)
     adxium = GTRAFOR
     Wrseq Using [TRA]
     Wrseq func AFNC.MES2(mess(324,123,1),PLAN,mess([F:AI1]STATUT,7944,1)) Using [TRA]
     Wrseq Using [TRA]
     Openo Using [TRA]
    Endif
  Endif

  Case [M]STATUT
      When 1   : Chgstl [M:AM0]STATUT With "CPYFLD"      : #  En Attente
      When 2   : Chgstl [M:AM0]STATUT With "BACKGREEN"   : #  En cours
      When 3   : Chgstl [M:AM0]STATUT With "BACKYELLOW"  : #  Terminé
      When 4   : Chgstl [M:AM0]STATUT With "AERROR"      : #  Terminé avec erreurs
      When 5,9 : Chgstl [M:AM0]STATUT With "BACKORANGE"  : #  Interrompu
      When 6   : Chgstl [M:AM0]STATUT With "BACKGREY"    : #  En attente interruption
      When 7   : Chgstl [M:AM0]STATUT With "BACKRED"     : #  En attente d'arrêt
      When 8   : Chgstl [M:AM0]STATUT With "AMKCUR"      : #  Lancé
  Endcase

  Affzo [M:AM1]
  Affzo [M:AM2]
  Affzo [M:AM0]
  Call DISPLISTPLAN
  For I=0 To NBM-1
    Case [M:AM1]STATUTM(I)
      When 1 : Chgstl [M:AM1]CODE(I),STATUTM(I) With "CPYFLD"      : #  En Attente
      When 2 : Chgstl [M:AM1]CODE(I),STATUTM(I) With "BACKGREEN"   : #  En cours
      When 3 : Chgstl [M:AM1]CODE(I),STATUTM(I) With "BACKYELLOW"  : #  Terminé
      When 4,11 : Chgstl [M:AM1]CODE(I),STATUTM(I) With "AERROR"      : #  Terminé avec erreurs
      When 5 : Chgstl [M:AM1]CODE(I),STATUTM(I) With "BACKORANGE"  : #  Stoppé
      When 6 : Chgstl [M:AM1]CODE(I),STATUTM(I) With "BACKGREY"    : #  A relancer
      When 7 : Chgstl [M:AM1]CODE(I),STATUTM(I) With "BACKRED"     : #  En attente d'arrêt
      When 8 : Chgstl [M:AM1]CODE(I),STATUTM(I) With "AMKCUR"      : #  Lancé
      When 10 : Chgstl [M:AM1]CODE(I),STATUTM(I) With "AEXPEXCUM"  : #  Bloqué
    Endcase
  Next I
  Affzo [M:AM1]
Endif
Gosub SETICONE
End

# ------------------------------------------------------------------------------------

Subprog DISPLISTPLAN

If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif

  Local Integer NL
  Raz [M:AM5]
#109200
Filter [AI1] Order By CREDATTIM Desc;PLAN Asc
  For [AI1]
    If NL>=dim([M:AM5]MPLAN)
     Call ERREUR(mess(136,133,1)-":"-func RDM("AMOULIN5","")) From GESECRAN : # Trop de lignes
     Break
    Endif
    [M:AM5]MPLAN(NL)=[F:AI1]PLAN
    [M:AM5]MDOSSIER(NL)=[F:AI1]DOSSIER
    [M:AM5]MSTATUT(NL)=[F:AI1]STATUT
    [M:AM5]MINTIT(NL)=[F:AI1]INTIT
    [M:AM5]MDATEL(NL)=[F:AI1]DATEL
    [M:AM5]MHEUL(NL)=[F:AI1]HEUL
    [M:AM5]MDATEEC(NL)=[F:AI1]DATEEC
    [M:AM5]MHEUEC(NL)=[F:AI1]HEUEC
#  Calcul de MELAPSED
    If [F:AI1]STATUT=1
     [M:AM5]MELAPSED(NL)=""
    Else
     Local Integer HOURNOW,HOURSTART,HHELP,MNELP
     HOURSTART=val(left$([M:AM5]MHEUL(NL),2))*60+val(right$([M:AM5]MHEUL(NL),3))
     If [F:AI1]STATUT=2
       HOURNOW=val(left$(time$,2))*60+val(mid$(time$,4,2))+(date$-[M:AM5]MDATEL(NL))*24*60
     Else
       HOURNOW=val(left$([M:AM5]MHEUEC(NL),2))*60+val(right$([M:AM5]MHEUEC(NL),3))+([M:AM5]MDATEEC(NL)-[M:AM5]MDATEL(NL))*24*60
     Endif
     HOURNOW-=HOURSTART
     HHELP=HOURNOW/60
     MNELP=HOURNOW-60*HHELP
     [M:AM5]MELAPSED(NL)=format$("N0:###",HHELP/60)+":"+format$("N0:##",MNELP)
    Endif
    NL+=1
  Next
Filter [AI1] : #109200
  [M:AM5]NBPLAN=NL
  Affzo [M:AM5]
End




#---------------------------------------------------------------------------------------------
# Gestion du masque AMOULIN0


Subprog CL_RAFR(VALEUR)
Variable Char    VALEUR()

If [M]PLAN="" : End : Endif
Local Integer OK
Call LANCENEXTMOUL([M]PLAN,"",OK)
Call RAFRAICHI([M]PLAN)
End

#---------------------------------------------------------------------------------------------

Subprog CL_ACTIV(VALEUR)
Variable Char    VALEUR()

If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif
Read [AI1]AI11=[M]PLAN
If fstat<>0 or ([F:AI1]STATUT<>1 and [F:AI1]STATUT<>5 and [F:AI1]STATUT<>6 and [F:AI1]STATUT<>7 and [F:AI1]STATUT<>9) : End : Endif

Local Integer OK,OKP

If [F:AI1]STATUT=1
# Voulez vous lancer le plan
  Call OUINON(mess(10,7902,1)-[M]PLAN,OKP) From GESECRAN
Else
# Voulez vous reprendre l'exécution du plan
  Call OUINON(mess(17,7902,1)-[M]PLAN,OKP) From GESECRAN
Endif
If OKP=2
  Call ACTIVPLAN([M]PLAN,OK)
Endif

Call RAFRAICHI([M]PLAN)

Actzo[M:AM0]ARRET,INTERR,RAFR
Diszo[M:AM0]ACTIV

End

#---------------------------------------------------------------------------------------------

Subprog CL_ARRET(VALEUR)
Variable Char    VALEUR()
Local Integer OK,OKP

If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif
Read [AI1]AI11=[M]PLAN
If fstat<>0  : End : Endif
If [F:AI1]STATUT<>2 and [F:AI1]STATUT<>5  and [F:AI1]STATUT<>8 : OK=3 : End : Endif

# Voulez vous arrêter le plan en cours (les moulinettes en cours seront terminées)?
Call OUINON(mess(20,7902,1),OKP) From GESECRAN
If OKP=2
  Call STOPPLAN([M]PLAN,"STOP",OK)
  Affzo [M]
Endif
Call RAFRAICHI([M]PLAN)

End

#---------------------------------------------------------------------------------------------

Subprog CL_INTERR(VALEUR)
Variable Char    VALEUR()
Local Integer OK,OKP

If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif
Read [AI1]AI11=[M]PLAN
If fstat<>0  : End : Endif
If [F:AI1]STATUT<>2 and [F:AI1]STATUT<>7 and [F:AI1]STATUT<>8 : OK=3 : End : Endif

# Voulez vous interrompre le plan en cours (les moulinettes en cours seront interrompues) ?
Call OUINON(mess(11,7902,1),OKP) From GESECRAN
If OKP=2
  Call STOPPLAN([M]PLAN,"INTERR",OK)
  Affzo [M]
Endif
Call RAFRAICHI([M]PLAN)
End

#---------------------------------------------------------------------------------------------

Subprog CL_BLOQUER(VALEUR)
Variable Char    VALEUR()

If clalev([F:AI2])=0 : Local File AMOULIN2 [AI2] : Endif
Filter [AI2] Where PLAN=[M]PLAN  and STATUT=1
Trbegin [AI2]
For [AI2]
  [F:AI2]STATUT=10
  Rewrite [AI2]
Next
Filter [AI2]
Commit
Diszo [M:AM0]BLOQUER
Actzo [M:AM0]DEBLOQUER

Call RAFRAICHI([M]PLAN)
End

#---------------------------------------------------------------------------------------------

Subprog CL_DEBLOQUER(VALEUR)
Variable Char    VALEUR()

If clalev([F:AI2])=0 : Local File AMOULIN2 [AI2] : Endif
Filter [AI2] Where PLAN=[M]PLAN  and STATUT=10
Trbegin [AI2]
For [AI2]
  [F:AI2]STATUT=1
  Rewrite [AI2]
Next
Filter [AI2]
Commit
Actzo [M:AM0]BLOQUER
Diszo [M:AM0]DEBLOQUER

Call RAFRAICHI([M]PLAN)
End

#---------------------------------------------------------------------------------------------




Subprog C_PLAN(VALEUR)
Variable Char    VALEUR()

If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif

Read [AI1]AI11=VALEUR
If fstat<>0 and [M:AM0]ISNEW<>1
    GMESSAGE=mess(9,7902,1) : # Le plan n'existe pas
    mkstat=2
Endif
End

Subprog AP_PLAN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif
  Read [AI1]AI11=VALEUR
  If fstat=0
    Call RAFRAICHI(VALEUR)
    [M:AM0]ISNEW=0
  Elsif fstat<>0 and [M:AM0]ISNEW=1

#   On charge un nouveau plan dans le masque
    If clalev([F:AI0])=0 : Local File AMOULIN [AI0] : Endif
    Local Integer NBM
   [M:AM0]STATUT=1
    Filter  [AI0] Where ACTIF=2 Order By INDICEM
    For [AI0]
      [M:AM1]INDICEM(NBM)=[F:AI0]INDICEM
      [M:AM1]MODULE(NBM)=[F:AI0]MODULE
      [M:AM1]CODE(NBM)=[F:AI0]CODE
      [M:AM1]PHASE(NBM)=[F:AI0]PHASE
      [M:AM1]RANG(NBM)=[F:AI0]RANG
      [M:AM1]RANGMOD(NBM)=[F:AI0]RANGMOD
      [M:AM1]STATUTM(NBM)=1
      Call TEXTE([F:AI0]INTIT,[M:AM1]INTITM(NBM)) From OBJDIV
#      Call LECTEXTRA([M:AM1]INTITM(NBM),"AMOULIN","INTIT",[M:AM1]CODE(NBM),"") From ATEXTRA
      NBM+=1
    Next
    Filter [AI0]
   [M:AM1]NBLIG=NBM
   Affzo [M:AM1]
   Affzo [M:AM0]STATUT
  Endif
Endif
End

Subprog S_PLAN(VALEUR)
Variable Char    VALEUR()
Local Integer NBLIB,IND
Local Char TBLIB(60)(0..)

If clalev([F:AI1])=0 : Local File AMOULIN1 [AI1] : Endif

#109200
Filter [AI1] Order By CREDATTIM Desc;PLAN Asc
For [AI1]
  NBLIB += 1
  TBLIB(NBLIB) = [F:AI1]PLAN-":"-[F:AI1]INTIT-":"-mess([F:AI1]STATUT,7944,1)
Next
Filter [AI1] : #109200
Call SAITEX(NBLIB,TBLIB,IND,mess(7,7902,1)) From GESECRAN
If IND<>0
  VALEUR=left$(TBLIB(IND),instr(1,TBLIB(IND),":")-2)
Endif
End


# ------------------------------------------------------------------------------------

Subprog B1_NBLIG
#   Reprendre

If clalev([F:AI2])=0 : Local File AMOULIN2 [AI2] : Endif
Read [AI2]AI21=[M]PLAN;[M]CODE(nolign-1)
If fstat<>0 : End : Endif


Local Integer OK,OKP
If [F:AI2]STATUT<>4 and [F:AI2]STATUT<>5 and [F:AI2]STATUT<>9 and [F:AI2]STATUT<>11
# Vous ne pouvez reprendre qu'une procédure stoppée, débrayée ou en erreur
  Call ERREUR(mess(13,7902,1)) From GESECRAN
  End
Endif

# Contrôle supplémentaire : On interdit "Reprendre" (GBOUT1) si statut amigkey=3 et statutm=4
If [F:AI2]STATUT=4
  If clalev([F:AMY])=0 : Local File AMIGKEY [AMY] : Endif
  Read [AMY]AMY0=[M:AM0]DOSSIER;[M]CODE(nolign-1)
  If fstat=0 and [F:AMY]PROENDFLG=3
    End
  Endif
Endif


# Voulez vous reprendre après le dernier point d'arrêt la procédure xxxx ?
Call OUINON(mess(19,7902,1)-[M]CODE(nolign-1),OKP) From GESECRAN
If OKP<>2 : End : Endif

[F:AI2]STATUT=1
[F:AI2]NBREL+=1
Trbegin [AI2]
Rewrite [AI2]
Commit
[M]STATUTM(nolign-1)=1
Affzo [M:AM1]STATUTM(nolign-1)
Call LANCENEXTMOUL([M]PLAN,[M]CODE(nolign-1),OK)
Call RAFRAICHI([M:AM0]PLAN)
End

# ------------------------------------------------------------------------------------

Subprog B2_NBLIG
#  Interrompre
Local Integer OK
Call STOPMOUL([M]PLAN,[M]CODE(nolign-1),OK)
If clalev([F:AI2])=0 : Local File AMOULIN2 [AI2] : Endif
Read [AI2]AI21=[M]PLAN;[M]CODE(nolign-1)
If fstat=0
  [M]STATUTM(nolign-1)=[F:AI2]STATUT
  [M]DATEMAJ(nolign-1)=[F:AI2]DATEMAJ
  [M]HEUMAJ(nolign-1)=[F:AI2]HEUMAJ
  Affzo [M:AM1]STATUTM(nolign-1)
  Affzo [M:AM1]DATEMAJ(nolign-1)
  Affzo [M:AM1]HEUMAJ(nolign-1)
Endif
Call RAFRAICHI([M:AM0]PLAN)
End

# ------------------------------------------------------------------------------------

Subprog B3_NBLIG
# Lecture trace
If clalev([F:AI2])=0 : Local File AMOULIN2 [AI2] : Endif
Read [AI2]AI21=[M]PLAN;[M]CODE(nolign-1)
If fstat=0 and [F:AI2]FICTRA<>""
  Local Char SAVGTRACE(250) : SAVGTRACE=GTRACE
  GTRACE=[F:AI2]FICTRA
  Call CONS_TRACE From LECFIC
  GTRACE=SAVGTRACE
Endif
End

# ------------------------------------------------------------------------------------

Subprog B4_NBLIG
# Relancer


If clalev([F:AI2])=0 : Local File AMOULIN2 [AI2] : Endif
If clalev([F:AI21])=0 : Local File AMOULIN2 [AI21] : Endif
Read [AI2]AI21=[M]PLAN;[M]CODE(nolign-1)
If fstat<>0
  End
Elsif find([F:AI2]STATUT,6,7)>0 and [F:AI2]NUMREQ=0
Elsif ([F:AI2]STATUT<>3 and [F:AI2]STATUT<>4 and [F:AI2]STATUT<>5 and [F:AI2]STATUT<>9 and [F:AI2]STATUT<>11)
  End
Endif

Local Integer OKP,OK,STAT
# Voulez vous relancer depuis le début la procédure xxxxx ?
Call OUINON(mess(18,7902,1)-[M]CODE(nolign-1),OKP) From GESECRAN
If OKP<>2 : End : Endif



If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
#107271
#Read [ADS] DOSSIER=[M:AM0]DOSSIER
#If fstat : Raz [F:ADS] : Endif
STAT=func DOSSUB.FILL_ADS([M:AM0]DOSSIER)
Global Char GMIGPLAN(30) : GMIGPLAN=[M]PLAN
Global Char GMIGPROC(30)
Local Char PRGTOCALL(30)


#On appelle le sous programme RAZ de la procédure et on relance derrière
GMIGPROC=[M]CODE(nolign-1)
Read [AI2]AI21=[M]PLAN;[M]CODE(nolign-1)

Local Char PRGTOCALL(30) : PRGTOCALL=[M]CODE(nolign-1)
Call ="RAZ_"+PRGTOCALL With [F:ADS]DOSSIER From =PRGTOCALL
Kill GMIGPROC,GMIGPLAN
[F:AI2]STATUT=1
[F:AI2]NBREL+=1
Trbegin [AI2]
Rewrite [AI2]
Commit
[M]STATUTM(nolign-1)=1
Affzo [M:AM1]STATUTM(nolign-1)



# On propose de remettre en attente d'autres procédures qui peuvent être liées

#Voulez vous également reprendre toutes les procédures de rang inférieur qui sont terminées ou interrompues ?
#Call OUINON(mess(25,7902,1)-[M]CODE(nolign-1)-"?",OKP) From GESECRAN
#Voulez vous également reprendre toutes les procédures qui sont terminées ou interrompues
#- de l'étape avec une phase supérieure
#- des étapes suivantes
Call OUINON(mess(35,7902,1)+chr$(10)+mess(36,7902,1)+chr$(10)+mess(37,7902,1),OKP) From GESECRAN

If OKP=2
  Filter [AI2] Where PLAN=[M]PLAN and RANGMOD=[M:AM1]RANGMOD(nolign-1) and PHASE>[M:AM1]PHASE(nolign-1)
&                    and (STATUT=3 or STATUT=4 or STATUT=5 or STATUT=11)
  For [AI2]
    Read [AI21]AI21=[M]PLAN;[F:AI2]CODE
    GMIGPROC=[F:AI2]CODE
    PRGTOCALL=GMIGPROC
    Call ="RAZ_"+PRGTOCALL With [F:ADS]DOSSIER From =PRGTOCALL
    [F:AI21]STATUT=1
    [F:AI21]NBREL+=1
    Trbegin [AI21]
    Rewrite [AI21]
    Commit
  Next
  Filter [AI2] Where PLAN=[M]PLAN and RANGMOD>[M:AM1]RANGMOD(nolign-1)
&                    and (STATUT=3 or STATUT=4 or STATUT=5 or STATUT=11)

  For [AI2]
    Read [AI21]AI21=[M]PLAN;[F:AI2]CODE
    GMIGPROC=[F:AI2]CODE
    PRGTOCALL=GMIGPROC
    Call ="RAZ_"+PRGTOCALL With [F:ADS]DOSSIER From =PRGTOCALL
    [F:AI21]STATUT=1
    [F:AI21]NBREL+=1
    Trbegin [AI21]
    Rewrite [AI21]
    Commit
  Next
  Filter [AI2]
Endif


Call LANCENEXTMOUL([M]PLAN,[M]CODE(nolign-1),OK)
Call RAFRAICHI([M:AM0]PLAN)
End

# ------------------------------------------------------------------------------------

Subprog B5_NBLIG
#   Bloquer

If clalev([F:AI2])=0 : Local File AMOULIN2 [AI2] : Endif
Read [AI2]AI21=[M]PLAN;[M]CODE(nolign-1)
If fstat<>0 : End : Endif

Local Integer OK,OKP
If [F:AI2]STATUT<>1
# Vous ne pouvez bloquer qu'une procédure en attente
  Call ERREUR(mess(27,7902,1)) From GESECRAN
  End
Endif


# Souhaitez vous bloquer toutes les procédures en attente de la phase ?
Call OUINON(mess(21,7902,1),OKP) From GESECRAN
Trbegin [AI2]
If OKP<>2
  [F:AI2]STATUT=10
  Rewrite [AI2]
Else
  Filter [AI2] Where PLAN=[M]PLAN and PHASE=[M:AM1]PHASE(nolign-1) and RANGMOD=[M:AM1]RANGMOD(nolign-1) and STATUT=1
  For [AI2]
    [F:AI2]STATUT=10
    Rewrite [AI2]
  Next
  Filter [AI2]
Endif
Commit
Call RAFRAICHI([M:AM0]PLAN)
End

# ------------------------------------------------------------------------------------

Subprog B6_NBLIG
#   Débloquer

If clalev([F:AI2])=0 : Local File AMOULIN2 [AI2] : Endif
Read [AI2]AI21=[M]PLAN;[M]CODE(nolign-1)
If fstat<>0 : End : Endif


Local Integer OK,OKP
If [F:AI2]STATUT<>10
# Vous ne pouvez débloquer qu'une procédure bloquée
  Call ERREUR(mess(23,7902,1)) From GESECRAN
  End
Endif


# Souhaitez vous débloquer toute la phase ?
Call OUINON(mess(22,7902,1),OKP) From GESECRAN
Trbegin [AI2]
If OKP<>2
  [F:AI2]STATUT=1
  Rewrite [AI2]
Else
  Filter [AI2] Where PLAN=[M]PLAN and PHASE=[M:AM1]PHASE(nolign-1) and RANGMOD=[M:AM1]RANGMOD(nolign-1) and STATUT=10
  For [AI2]
    [F:AI2]STATUT=1
    Rewrite [AI2]
  Next
  Filter [AI2]
Endif
Commit
Call LANCENEXTMOUL([M]PLAN,"",OK)
Call RAFRAICHI([M:AM0]PLAN)

End

# ------------------------------------------------------------------------------------

Subprog B7_NBLIG
#   Débrayer

If clalev([F:AI2])=0 : Local File AMOULIN2 [AI2] : Endif
Read [AI2]AI21=[M]PLAN;[M]CODE(nolign-1)
If fstat<>0 or [F:AI2]STATUT<>4: End : Endif

Local Integer OKP,OK

# Etes vous sûr de vouloir débrayer cette procédure et de débloquer ainsi l'exécution des phases suivantes ?
Call OUINON(mess(32,7902,1),OKP) From GESECRAN
If OKP<>2 : End : Endif

[F:AI2]STATUT=11
[F:AI2]NBREL+=1
Trbegin [AI2]
Rewrite [AI2]
Commit

Call LANCENEXTMOUL([M:AM0]PLAN,"",OK)
Call RAFRAICHI([M:AM0]PLAN)

End

# ------------------------------------------------------------------------------------

Subprog B8_NBLIG
# Relancer avec nouveau filtre


If clalev([F:AI2])=0 : Local File AMOULIN2 [AI2] : Endif
If clalev([F:AI21])=0 : Local File AMOULIN2 [AI21] : Endif
Read [AI2]AI21=[M]PLAN;[M]CODE(nolign-1)
If fstat<>0 or ([F:AI2]STATUT<>3 and [F:AI2]STATUT<>4 and [F:AI2]STATUT<>5 and [F:AI2]STATUT<>9 and [F:AI2]STATUT<>11)
  End
Endif

Local Integer OKP,OK
# Voulez vous relancer avec un nouveau filtre que vous avez initialisé la procédure xxxx ?
Call OUINON(mess(33,7902,1)-[M]CODE(nolign-1),OKP) From GESECRAN
If OKP<>2 : End : Endif



If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
#107271
#Read [ADS] DOSSIER=[M:AM0]DOSSIER
#If fstat : Raz [F:ADS] : Endif
STAT=func DOSSUB.FILL_ADS([M:AM0]DOSSIER)
Global Char GMIGPLAN(30) : GMIGPLAN=[M]PLAN
Global Char GMIGPROC(30)
Local Char PRGTOCALL(30)


#On appelle le sous programme RAZ de la procédure et on relance derrière
GMIGPROC=[M]CODE(nolign-1)
Read [AI2]AI21=[M]PLAN;[M]CODE(nolign-1)

Local Char PRGTOCALL(30) : PRGTOCALL=[M]CODE(nolign-1)
#Call ="RAZ_"+PRGTOCALL With [F:ADS]DOSSIER From =PRGTOCALL
Kill GMIGPROC,GMIGPLAN
[F:AI2]STATUT=1
[F:AI2]NBREL+=1
Trbegin [AI2]
Rewrite [AI2]
Commit
[M]STATUTM(nolign-1)=1
Affzo [M:AM1]STATUTM(nolign-1)


Call LANCENEXTMOUL([M]PLAN,[M]CODE(nolign-1),OK)
Call RAFRAICHI([M:AM0]PLAN)
End

# ------------------------------------------------------------------------------------

Subprog IB_NBLIG
If [M]STATUTM(nolign-1)<>4 and [M]STATUTM(nolign-1)<>5 and [M]STATUTM(nolign-1)<>9 and [M]STATUTM(nolign-1)<>11
  GBOUT1=""
Endif
If [M]STATUTM(nolign-1)<>2 and  [M]STATUTM(nolign-1)<>7 and  [M]STATUTM(nolign-1)<>8
  GBOUT2=""
Endif

If clalev([F:AI2])=0 : Local File AMOULIN2 [AI2] : Endif
Read [AI2]AI21=[M]PLAN;[M]CODE(nolign-1)
If fstat<>0 or [F:AI2]FICTRA=""
  GBOUT3=""
Endif

If find([F:AI2]STATUT,6,7)>0 and [F:AI2]NUMREQ=0
  GBOUT8=""
Elsif [M]STATUTM(nolign-1)<>3 and [M]STATUTM(nolign-1)<>4 and [M]STATUTM(nolign-1)<>5 and [M]STATUTM(nolign-1)<>9 and [M]STATUTM(nolign-1)<>11
  GBOUT4="" : GBOUT8=""
Endif
If [M]STATUTM(nolign-1)<>1
  GBOUT5=""
Endif
If [M]STATUTM(nolign-1)<>10
  GBOUT6=""
Endif
If [M]STATUTM(nolign-1)<>4
  GBOUT7=""
Endif

# Contrôle supplémentaire : On interdit "Reprendre" (GBOUT1) si statut amigkey=3 et statutm=4
If [M]STATUTM(nolign-1)=4 and GBOUT1<>""
  If clalev([F:AMY])=0 : Local File AMIGKEY [AMY] : Endif
  Read [AMY]AMY0=[M:AM0]DOSSIER;[M]CODE(nolign-1)
  If fstat=0 and [F:AMY]PROENDFLG=3
    GBOUT1=""
  Endif
Endif

If nomap<>GDOSX3
 GBOUT1="" :  GBOUT2="" :  GBOUT4="" :  GBOUT5="" :  GBOUT6="" :  GBOUT7="" : GBOUT8=""
Endif

End




