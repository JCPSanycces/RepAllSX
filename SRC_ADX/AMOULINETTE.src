## Etiquette ajoutée par le superviseur (écran AMOULIN0) 04/05/2012 10:47:26 (CCORA)
######################################################################################
Subprog AM_PHASEAUTO(VALEUR)
Variable Integer VALEUR

End


Subprog AM_POSTAUTO(VALEUR)
Variable Integer VALEUR

End

$UPDSTATPLAN

# Si le plan a démarré on doit tenir compte de là ou il en est
Local Integer RANGMODREF,PHASEREF
If clalev([F:AI2])=0 : Local File AMOULIN2 [AI2] : Endif
If clalev([F:AI21])=0 : Local File AMOULIN2 [AI21] : Endif
If [F:AI1]CODEEC<>""
  Read [AI2]AI21=[M:AM0]PLAN;[F:AI1]CODEEC
  If fstat=0 : RANGMODREF=[F:AI2]RANGMOD : PHASEREF=[F:AI2]PHASE : Endif
Endif
Filter [AI2] Where PLAN=[M:AM0]PLAN
Trbegin [AI2]
For [AI2]
  If AAPHASEAUTO=2 and ([F:AI2]RANGMOD>RANGMODREF or ([F:AI2]RANGMOD=RANGMODREF and [F:AI2]PHASE>PHASEREF))
&                  and [F:AI2]RANGMOD<4
    If [M:AM0]PHASEAUTO=2 and [F:AI2]STATUT=10
      Read [AI21]AI21=[M:AM0]PLAN;[F:AI2]CODE
      [F:AI21]STATUT=1
      Rewrite [AI21]
    Endif
    If [M:AM0]PHASEAUTO=1 and [F:AI2]STATUT=1
      Read [AI21]AI21=[M:AM0]PLAN;[F:AI2]CODE
      [F:AI21]STATUT=10
      Rewrite [AI21]
    Endif
  Endif
  If AAPOSTAUTO=2 and [F:AI2]RANGMOD=4 and RANGMODREF<>4
    If [M:AM0]POSTAUTO=2 and [F:AI2]STATUT=10
      Read [AI21]AI21=[M:AM0]PLAN;[F:AI2]CODE
      [F:AI21]STATUT=1
      Rewrite [AI21]
    Endif
    If [M:AM0]POSTAUTO=1 and [F:AI2]STATUT=1
      Read [AI21]AI21=[M:AM0]PLAN;[F:AI2]CODE
      [F:AI21]STATUT=10
      Rewrite [AI21]
    Endif
  Endif
Next
Filter [AI2]
Commit
Return


