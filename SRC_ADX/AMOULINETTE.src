Subprog S_DOSSIER(VALEUR)
Variable Char    VALEUR()
#Call SELECT("ADS","",VALEUR,"") From SELOBJ
#End
Gosub DEFSEL2
If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
  For [ADS]
    NBTEX+= 1
    TEX(NBTEX,1) = [F:ADS]DOSSIER
    TEX(NBTEX,2) = [F:ADS]NOMDOS
    If [F:ADS]DOSHIS<>""
     NBTEX+= 1
     TEX(NBTEX,1) = [F:ADS]DOSHIS
     TEX(NBTEX,2) = mess(291,125,1)-[F:ADS]DOSSIER
    Endif
  Next
  CHOI = 0
  TIT(0) = mess(22,123,1) # Sélection
  TIT(1) = func AMK_TOOL.GET_FIELD_LABEL("ADS0", "DOSSIER")
  TIT(2) = func AMK_TOOL.GET_FIELD_LABEL("ADS0", "NOMDOS")
  Call SAITEX_COL_MAX(NBTEX,TEX,CHOI,TIT,240,80) From GESECRAN
  If status<>7 & CHOI<>0
   VALEUR = TEX(CHOI,1)
  Endif
End

$DEFSEL2
Local Integer NBTEX, CHOI,I
Local Char    TEX(GLONDES)(1..500,1..2) , TIT(GLONDES)(0..2) , CRITERE(250)
Return



###################################################################################################
###################################################################################################
# Textes du dictionnaire (ATEXTE)
Funprog RDT(I)
Value Integer I
 If clalev([ZATX])=0 : Local File ATEXTE [ZATX] : Endif
 Read [ZATX]NUMERO=GLANGUE;I
 If fstat<>0
    If GLANGUE<>"FRA"
        Read [ZATX]NUMERO="FRA";I
        If fstat=0
            [ZATX]TEXTE="["+[ZATX]TEXTE+"]"
        Else
            Raz [ZATX]
        Endif
    Else
        Raz [ZATX]
    Endif
 Endif
End [ZATX]TEXTE

# Textes du dictionnaire par référence au champ d'un écran
# (ou au titre de l'écran si le champ est vide, ou au titre du bloc si on retrouve un champ numérique)
# A utiliser dès qu'on a besoin d'un texte "constant" déjà traduit (le numéro de ATEXTE n'est pas constant)
#
Funprog RDM(MASQ,CHAMP)
Value Char MASQ(),CHAMP()

 If clalev([AMK1])=0 : Local File AMSK [AMK1] : Endif
 If clalev([AMZ1])=0 : Local File AMSKZON [AMZ1] : Endif
 If pat(CHAMP,"#*")
    Read [AMK1]CODMSK=MASQ
    If fstat=0
        If [AMK1]TITBLOC(val(CHAMP))<>0
            End func RDT([AMK1]TITBLOC(val(CHAMP)))
        Endif
    Endif
 Elsif CHAMP<>""
    Read [AMZ1]CODE=MASQ;CHAMP
    If fstat=0
        If [AMZ1]INTIT<>0
            End func RDT([AMZ1]INTIT)
        Endif
    Endif
 Else
    Read [AMK1]CODMSK=MASQ
    If fstat=0
        If [AMK1]INTMSK<>0
            End func RDT([AMK1]INTMSK)
        Endif
    Endif
  Endif
End ""
