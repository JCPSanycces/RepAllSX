#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMOPE0 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:48"
A_USER  = "DOC"
A_STAMP = "20181109230548"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMOPE0 [PJOPE0]
Gosub HORODAT
Local Inpbox "PJMOPE0" From GFONCTION At A_STAMP With A_WINDPREV Mask [PJOPE0] As [SIM_]
Grizo [PJOPE0]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [PJOPE0]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=137 : Y1(0)=1 : Y2(0)=20
X1(1)=1 : X2(1)=-2 : Y1(1)=1 : Y2(1)=0
Return

$ON_OPPNUM
Return

$ON_ZOPPNUM
Onevent BEFORE_AREA Gosub AV_ZOPPNUM From W1PJMOPE0
Return

$AV_ZOPPNUM
Call LECTEXTRA(zc,"PIMPL","PIMDESAXX",num$([M]OPPNUM(indice)),"") From ATEXTRA
Gosub _AFF
Return

$ON_TASCOD
Return

$ON_OPENUM
Return

$ON_EXTQTY
Onevent BEFORE_AREA Gosub AV_EXTQTY From W1PJMOPE0
Return

$AV_EXTQTY
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find([M:PJOPE0]OPEUOM2,GUNITE(1..GNBUNT)),1))
Endif
Chgfmt [M]EXTQTY(indice) With "NP+z:"+GUNTFMT
Gosub _AFF
Return

$ON_CSMQTY
Onevent BEFORE_AREA Gosub AV_CSMQTY From W1PJMOPE0
Return

$AV_CSMQTY
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find([M:PJOPE0]OPEUOM2,GUNITE(1..GNBUNT)),1))
Endif
Chgfmt [M]CSMQTY(indice) With "NPz:"+GUNTFMT
Gosub _AFF
Return

$ON_RMNQTY
Onevent BEFORE_AREA Gosub AV_RMNQTY From W1PJMOPE0
Onevent AFTER_CHANGE Gosub AMM_RMNQTY From W1PJMOPE0
Onevent CONTROL Call C_RMNQTY(zc) From W1PJMOPE0
Return

$AV_RMNQTY
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find([M:PJOPE0]OPEUOM2,GUNITE(1..GNBUNT)),1))
Endif
Chgfmt [M]RMNQTY(indice) With "N+z:"+GUNTFMT
Gosub _AFF
Return

Subprog C_RMNQTY(VALEUR)
Variable Decimal VALEUR
Gosub _AFF
End

$AMM_RMNQTY
Call AM_RMNQTY(zc)
If !mkstat & GOBJET
 zoncou = "RMNQTY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_RMNQTY(VALEUR)
Variable Decimal VALEUR
## Action STD
Call AM_RMNQTY(VALEUR) From SUBPJOPE
If mkstat : GERR = 1 : GZONE = "RMNQTY" : GZNUM = 42118 : Endif
Gosub _AFF
End

$ON_OPEUOM2
Return

$ON_ZOPEUOM2
Onevent BEFORE_AREA Gosub AV_ZOPEUOM2 From W1PJMOPE0
Return

$AV_ZOPEUOM2
Call LECTEXTRA(zc,"TABUNIT","DES",num$([M]OPEUOM2(indice)),"") From ATEXTRA
Gosub _AFF
Return

$CHG_STY
Return


