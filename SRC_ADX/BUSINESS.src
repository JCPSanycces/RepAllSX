#<AdxTL>@(#)7.0.0.0 $Revision$
#########################################################################
# BUSINESS : Activité commerciale par date ou par représentant          #
# --------------------------------------------------------------------- #
# Chargement des paramètres                                             #
#      Etat BUSINESS1 : Activité commerciale par date                   #
#      Etat BUSINESS2 : Activité commerciale par représentant           #
#########################################################################

$ACTION
Case ACTION
  When "OUVRE"   : Gosub OUVRE2
  When "INIPAR"  : Gosub INIPAR
  When "INIPAR2" : Gosub INIPAR
Endcase
Return

$OUVRE2
If GAUSCRMF<>"" & GAUSCRMA=2 & (dim(GAUSCRMROL)<1 | (dim(GAUSCRMROL)>0 & GAUSCRMROL<>1))
  GBIDI2=find("REP",[M:RPT]PARTYP)
  If GBIDI2
    [M:RPT]VALEUR1(GBIDI2-1)=GAUSCRMF
    [M:RPT]VALINT1(GBIDI2-1)=GAUSCRMF
    [M:RPT]VALEUR2(GBIDI2-1)=GAUSCRMF
    [M:RPT]VALINT2(GBIDI2-1)=GAUSCRMF
    Affzo [M:RPT]VALEUR1(GBIDI2-1), VALEUR2(GBIDI2-1)
  Endif  
Endif
Return

$INIPAR
If GAUSCRMF<>"" & GAUSCRMA=2 & [M:RPT]PARTYP(nolign-1)="REP"  mkstat=2 : Endif
Return

######################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)

End

######################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Value Integer    NBPAR 
Variable Char    PARAMETRE()()
#----------------------------------------------------------------
#   When "usr"             : [L]PARAMETRE(I) = "usr="+GUSER
#   When "etat"            : [L]PARAMETRE(I) = "etat="+[L]ETAT
#----------------------------------------------------------------
Gosub OUVRE 
If GERREUR : GERREUR=0 : End : Endif 
Gosub DECLARE 

Raz WNUMLIG 
 
[L]CRITERE  = "1=1"
[L]CRITERE1 = "& 1=1"
[L]CRITERE2 = "& 1=1"
[L]CRITERE3 = "& 1=1"
[L]CRITDON1 -= "& 1=1"
[L]CRITDON2 -= "& 1=1"
[L]CRITDON3 -= "& 1=1"

For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "X3ETA"           : [L]ETAT = [L]VALEUR
   When "__REQUETE"       : [L]NUMREQ = val([L]VALEUR)
   When "numedt"          : [L]PARAMETRE(I) = "numedt="  +num$([L]NUMREQ)

   When "actiondeb"       : IACTLOW = val([L]VALEUR)
   When "actionfin"       : IACTHIGH = val([L]VALEUR)

   When "typact"          : If val([L]VALEUR) = 2
                                [L]CRITDON1 -= "& TSKDON<>2"
                                [L]CRITDON2 -= "& CLLDON<>2"
                                [L]CRITDON3 -= "& APTDON<>2"
                            Else
                                [L]CRITDON1 -= "& TSKDON=2"
                                [L]CRITDON2 -= "& CLLDON=2"
                                [L]CRITDON3 -= "& APTDON=2"
                            Endif

   When "sitedeb"         : [L]CRITERE  -= "& SALFCY>='"  +[L]VALEUR+"'"
   When "sitefin"         : [L]CRITERE  -= "& SALFCY<='"  +[L]VALEUR+"'"

   When "datedeb"         : [L]DDATREF   =  gdat$(val(right$([L]VALEUR,7)),
&                                          val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                            [L]CRITERE1 -= "& TSKDAT >=["+format$(GFMD,[L]DDATREF)+"]"
                            [L]CRITERE2 -= "& CLLDATX >=["+format$(GFMD,[L]DDATREF)+"]"
                            [L]CRITERE3 -= "& APTDATX >=["+format$(GFMD,[L]DDATREF)+"]"


   When "datefin"         : [L]DDATREF   =  gdat$(val(right$([L]VALEUR,7)),
&                                          val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                            [L]CRITERE1 -= "& TSKDAT <=["+format$(GFMD,[L]DDATREF)+"]"
                            [L]CRITERE2 -= "& CLLDATX <=["+format$(GFMD,[L]DDATREF)+"]"
                            [L]CRITERE3 -= "& APTDATX <=["+format$(GFMD,[L]DDATREF)+"]"

 Endcase
 Endif
Next

#Optimisation performances
Local Integer IPERF
Local Integer IPBL    #Statut d'erreur
Local Integer INTR
IPERF = 0
IPBL = 0
INTR = 0

#Jauge
Local Integer IMAX
Local Integer ICOUNT
Local Integer IAFFOK
Local Char SZMESS
SZMESS = mess(392, 196, 1)  #Préparation des données

Case IACTLOW
    When 1
        Case IACTHIGH
            When 1
                Gosub TRT_TSK  
            When 2
                Gosub TRT_TSK  
                If !IPBL : Gosub TRT_CLL : Endif
            When 3
                Gosub TRT_TSK  
                If !IPBL : Gosub TRT_CLL : Endif
                If !IPBL : Gosub TRT_BAP : Endif
            When Default
        Endcase
    When 2
        Case IACTHIGH
            When 2
                Gosub TRT_CLL
            When 3
                Gosub TRT_CLL
                If !IPBL : Gosub TRT_BAP : Endif
            When Default
        Endcase

    When 3
          Gosub TRT_BAP
    When Default
Endcase

End

###################################################################
# Taches 
###################################################################
$TRT_TSK

IPERF = 0
IPBL = 0
INTR = 0

If !GINTRA
    IMAX = nbrecord([F:TSK])
    ICOUNT = 0
    IAFFOK = 1
    Call OUVRE_BOITE(SZMESS, IMAX) From GESECRAN
Endif

Filter [F:TSK] Where evalue([L]CRITERE + [L]CRITERE1 + [L]CRITDON1) 
For [F:TSK]TSK0 
    WNUM = [F:TSK]TSKNUM 
    WFCY = [F:TSK]SALFCY 
    WREP = [F:TSK]TSKREP 
    WCLI = [F:TSK]TSKCMP
    WAFF = [F:TSK]TSKPJT
    WINT = [F:TSK]TSKCCN
    WTYP = 1 
    WDAT = [F:TSK]TSKDAT 

    If IPERF = 0
        Call DEBTRANS From GLOCK 
        Trbegin [ARM]
        INTR = 1
    Endif

    WNUMLIG      += 1

    Raz [F:ARM]
    [F:ARM]USR     = GUSER
    [F:ARM]RPTCOD  = [L]ETAT
    [F:ARM]NUMREQ  = [L]NUMREQ
    [F:ARM]NUMLIG  = WNUMLIG
    [F:ARM]CLEA1   = WNUM
    [F:ARM]CLEA2   = WFCY
    [F:ARM]CLEA3   = WREP 
    [F:ARM]CLEA4   = WCLI
    [F:ARM]CLEA5   = WAFF
    [F:ARM]CLEA6   = WINT
    [F:ARM]CLEN1   = WTYP
    [F:ARM]CLED1   = WDAT
    [F:ARM]CREDAT  = date$
    Write [F:ARM]   
    If fstat
        IPBL = 1
        GMESSAGE = mess(100,141,1) #Erreur création
        GERR = 1
        Rollback
        INTR = 0
        Break
    Else
        If IPERF >= 1000
            Commit
            IPERF = 0
            INTR = 0
        Else
            IPERF += 1
        Endif
    Endif

    If !GINTRA
        ICOUNT += 1
        Call AFF_BOITE (SZMESS, ICOUNT, IAFFOK) From GESECRAN
    Endif
Next 

If INTR
    If !IPBL
        Commit
    Endif
Endif

If !GINTRA
    Call FERME_BOITE From GESECRAN
Endif

Return

###################################################################
# Appel 
###################################################################
$TRT_CLL

IPERF = 0
IPBL = 0
INTR = 0

If !GINTRA
    IMAX = nbrecord([F:CLL])
    ICOUNT = 0
    IAFFOK = 1
    Call OUVRE_BOITE(SZMESS, IMAX) From GESECRAN
Endif

Filter [F:CLL] Where evalue([L]CRITERE + [L]CRITERE2 + [L]CRITDON2) 
For [F:CLL]CLL0 
    WNUM = [F:CLL]CLLNUM 
    WFCY = [F:CLL]SALFCY 
    WREP = [F:CLL]CLLREP 
    WCLI = [F:CLL]CLLCMP
    WAFF = [F:CLL]CLLOPP
    WINT = [F:CLL]CLLCCN
    WTYP = 2 
    WDAT = [F:CLL]CLLDATX 

    If IPERF = 0
        Call DEBTRANS From GLOCK 
        Trbegin [ARM]
        INTR = 1
    Endif

    WNUMLIG      += 1

    Raz [F:ARM]
    [F:ARM]USR     = GUSER
    [F:ARM]RPTCOD  = [L]ETAT
    [F:ARM]NUMREQ  = [L]NUMREQ
    [F:ARM]NUMLIG  = WNUMLIG
    [F:ARM]CLEA1   = WNUM
    [F:ARM]CLEA2   = WFCY
    [F:ARM]CLEA3   = WREP 
    [F:ARM]CLEA4   = WCLI
    [F:ARM]CLEA5   = WAFF
    [F:ARM]CLEA6   = WINT
    [F:ARM]CLEN1   = WTYP
    [F:ARM]CLED1   = WDAT
    [F:ARM]CREDAT  = date$
    Write [F:ARM]   
    If fstat
        IPBL = 1
        GMESSAGE = mess(100,141,1) #Erreur création
        GERR = 1
        Rollback
        INTR = 0
        Break
    Else
        If IPERF >= 1000
            Commit
            IPERF = 0
            INTR = 0
        Else
            IPERF += 1
        Endif
    Endif

    If !GINTRA
        ICOUNT += 1
        Call AFF_BOITE (SZMESS, ICOUNT, IAFFOK) From GESECRAN
    Endif
Next 

If INTR
    If !IPBL
        Commit
    Endif
Endif

If !GINTRA
    Call FERME_BOITE From GESECRAN
Endif

Return

###################################################################
# Rendez-vous 
###################################################################
$TRT_BAP

IPERF = 0
IPBL = 0
INTR = 0

If !GINTRA
    IMAX = nbrecord([F:BAP])
    ICOUNT = 0
    IAFFOK = 1
    Call OUVRE_BOITE(SZMESS, IMAX) From GESECRAN
Endif

Filter [F:BAP] Where evalue([L]CRITERE + [L]CRITERE3 + [L]CRITDON3) 
For [F:BAP]APP0 
    WNUM = [F:BAP]APTNUM 
    WFCY = [F:BAP]SALFCY 
    WREP = [F:BAP]APTREPNUM 
    WCLI = [F:BAP]APTCMP
    WAFF = [F:BAP]APTPJT
    WINT = [F:BAP]APTCCNNUM
    WTYP = 3 
    WDAT = [F:BAP]APTDATX 

    If IPERF = 0
        Call DEBTRANS From GLOCK 
        Trbegin [ARM]
        INTR = 1
    Endif

    WNUMLIG      += 1

    Raz [F:ARM]
    [F:ARM]USR     = GUSER
    [F:ARM]RPTCOD  = [L]ETAT
    [F:ARM]NUMREQ  = [L]NUMREQ
    [F:ARM]NUMLIG  = WNUMLIG
    [F:ARM]CLEA1   = WNUM
    [F:ARM]CLEA2   = WFCY
    [F:ARM]CLEA3   = WREP 
    [F:ARM]CLEA4   = WCLI
    [F:ARM]CLEA5   = WAFF
    [F:ARM]CLEA6   = WINT
    [F:ARM]CLEN1   = WTYP
    [F:ARM]CLED1   = WDAT
    [F:ARM]CREDAT  = date$
    Write [F:ARM]   
    If fstat
        IPBL = 1
        GMESSAGE = mess(100,141,1) #Erreur création
        GERR = 1
        Rollback
        INTR = 0
        Break
    Else
        If IPERF >= 1000
            Commit
            IPERF = 0
            INTR = 0
        Else
            IPERF += 1
        Endif
    Endif

    If !GINTRA
        ICOUNT += 1
        Call AFF_BOITE (SZMESS, ICOUNT, IAFFOK) From GESECRAN
    Endif
Next 

If INTR
    If !IPBL
        Commit
    Endif
Endif

If !GINTRA
    Call FERME_BOITE From GESECRAN
Endif

Return

########################################################################### 
 
$OUVRE 
Local File TASK [TSK], PHONECALL[CLL], BAPPOINT[BAP], AREPORTM [ARM]
Return 
 
$DECLARE 
Local Char    CRITERE(255),CRITERE1(250),CRITERE2(250),CRITERE3(250)
Local Char    CRITDON1(250),CRITDON2(250),CRITDON3(250)
Local Char    PARAM(30),VALEUR(30),ETAT(GLONARP),WNUM(GLONVCR),WFCY(GLONFCY),WREP(GLONREP),WCLI(GLONBPN),WAFF(GLONVCR),WINT(GLONAIN)
Local Integer WTYP, NUMREQ 
Local Date    WDAT    
Local Date DDATREF
Local Integer WNUMLIG

Local Integer IACTLOW
Local Integer IACTHIGH
IACTLOW = 0
IACTHIGH = 0

Return 
