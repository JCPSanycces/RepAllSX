# Class AQCINTERFACE


##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "INDEXP1"  : Gosub INDEXP1
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
Case [L]AOPERATION
Endcase
Return

##########################################################################################################

$INDEXP1
Case [L]ARULE
  When "PROPAGATE"  : Gosub INDEXP1_PROPAGATE
Endcase
Return


$INDEXP1_PROPAGATE
Local Integer MY_STATUS,LINE

# Remove current lines
For LINE=maxtab(this.COLINTERFACE) To 1 Step -1
If this.COLINTERFACE(LINE).ASTALIN<>[V]CST_ADEL & this.COLINTERFACE(LINE).ASTALIN<>[V]CST_ANEWDEL
#  If !find(this.COLINTERFACE(LINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)
    [L]MY_STATUS = fmet this.ASETERROR("COLINTERFACE", "Line status"-num$(LINE)-this.COLINTERFACE(LINE).FIELD1-num$(this.COLINTERFACE(LINE).ASTALIN), [V]CST_AINFO)
    [L]MY_STATUS = fmet this.ADELLINE("COLINTERFACE", LINE)
    If [L]MY_STATUS <> [V]CST_AOK
      [L]MY_STATUS = fmet this.ASETERROR("COLINTERFACE", "Message on delete"-num$(LINE)-num$([L]MY_STATUS), [V]CST_AERROR)
    Else
      [L]MY_STATUS = fmet this.ASETERROR("COLINTERFACE", "Delete line ok"-num$(LINE)-num$([L]MY_STATUS), [V]CST_AINFO)
    Endif
  Endif
Next


# Add new lines
Local File AQCINTERFACE [AQI1]
For [AQI1] Where INDEXP1=this.INDEXP1
  [L]LINE = fmet this.ADDLINE("COLINTERFACE",[V]CST_ALASTPOS)
  [L]MY_STATUS = fmet this.COLINTERFACE(LINE).AINIT()
  this.COLINTERFACE(LINE).INDEXP2 = [F:AQI1]INDEXP2
  this.COLINTERFACE(LINE).FIELD1 = [F:AQI1]FIELD1
  this.COLINTERFACE(LINE).FIELD2 = [F:AQI1]FIELD2
Next
Close Local File [AQI1]
Return

