#<AdxTL>@(#)4.0.0.0 $Revision$
################################################################################################
# Les clÃĐs d'optimisation suivantes doivent ÃŠtre activÃĐes pour amÃĐliorer les temps de traitement
# PAYMENTH : CPY+PAYTYP+ACCDAT+NUM
# GACCENTRY : CPY+ACCDAT+TYP+NUM et CPY+RVSDAT+TYP+NUM
# GACCENTRYD : CPY+FCYLIN+LEDTYP+ACC+BPR+MTC+ACCDAT+ACCNUM
#         et : CPY+LEDTYP+ACCDAT+MTC+ACCNUM
################################################################################################
Subprog VERF(SOCIETE,DAT_DEB,DAT_FIN,EXERCICE,PERIODE,TYPLED,DER_PER,OK)
Value    Char    SOCIETE()    : # Code sociÃĐtÃĐ Ã  clÃīturer
Value    Date    DAT_DEB      : # Date dÃĐbut pÃĐriode Ã  clÃīturer
Value    Date    DAT_FIN      : # Date fin   pÃĐriode Ã  clÃīturer
Value    Integer EXERCICE     : # No exercice Ã  clÃīturer
Value    Integer PERIODE      : # No pÃĐriode de l'exercice Ã  clÃīturer
Value    Integer TYPLED       : # Type rÃĐfÃĐrentiel
Value    Libelle DER_PER      : # DerniÃĻre pÃĐriode de l'exercice NON/OUI
Variable Integer OK           : # Statut retour, 1=OK 0=Pas bon

Local Integer OK2, ERR
Local Libelle NIV_VALID       : # Niveau de validation requis pour rÃĻglement
Local Libelle NIV_VALID2      : # Niv. de valid "supÃĐrieur" (gÃĻre les modifs faites sur 1 transac)
Local Libelle NIV_VALID3      : # Niveau de validation "supÃĐrieur"
Local Integer NB_ANOM         : # Nbre anomalie ctl balance
Local Libelle TYPTRC          : # =2 : Trace exhaustive, <>2 trace rÃĐduite
Local Libelle OTRACE          : # =1 si trace dÃĐjÃ  ouverte
Local Integer CAS

Local Char    CODLED(GLONLED) : # Code rÃĐfÃĐrentiel
Local Char    DEVLED(GLONLED) : # Devise rÃĐfÃĐrentiel
Local Char    COALED(GLONCOA) : # Code plan
Local Integer CPTGEN          : # Cpta gÃĐnÃĐ NON/OUI
Local Integer CPTANA          : # Cpta ana  NON/OUI
Local Integer CPTEQL          : # Equilibre NON/OUI
Local Integer FLGAUT          : # RÃĐfÃĐrentiel automatique NON/OUI
Local Libelle LEDTYPGEN       : # Type de rÃĐfÃĐrentiel du RÃĐfÃĐrentiel gÃĐnÃĐral principal
Local Libelle LEDTYPANA       : # Type de rÃĐfÃĐrentiel du RÃĐfÃĐrentiel analytique principal

If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif
If clalev([F:LED])=0  : Local File GLED       [LED]  : Endif
If clalev([F:COA])=0  : Local File GCOA       [COA]  : Endif

Call LECLED(SOCIETE,TYPLED,CODLED,DEVLED) From CPTDIV
Call LECTURE("LED",CODLED,"") From CONTOBJ
Call LEDTYPAUT(SOCIETE,TYPLED,FLGAUT) From CPTDIV
Call SETMAINREF(SOCIETE,LEDTYPGEN,LEDTYPANA) From CPTDIV

COALED = [F:LED]COA
CPTGEN = [F:LED]GEN
CPTANA = [F:LED]ANA
CPTEQL = [F:LED]BAL
CPTECH = (TYPLED=LEDTYPGEN)

TYPTRC=OK
OTRACE=(GTRACE<>"")
OK = 1

If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
Call LECTURE("CPY",SOCIETE,"") From CONTOBJ

If !GSERVEUR & !OTRACE
 Call OUVRE_TRACE(SOCIETE-mess(39,101,1)-mess(40,101,1)
&                -format$("D:"+GFMDAT,DAT_DEB)-mess(41,101,1)
&                -format$("D:"+GFMDAT,DAT_FIN)
&                ) From LECFIC
Endif

Local Integer VERF_SIH, VERF_PIH, VERF_PYH, VERF_BAL, VERF_BCG
Local Integer VERF_CPT, VERF_ECH, VERF_HAE
Local Integer VERF_GAF, VERF_LOT, VERF_SEC, VERF_SLD, VERF_CUR, VERF_FAR, VERF_GIC
Local Integer VERF_TMP, VERF_STK, VERF_FAS
Local Integer VERF_SVC
Local Integer FLGCSL, VERF_BALCSL, VERF_BCGCSL

# Toujours
VERF_HAE = 1
VERF_GAF = 1
VERF_LOT = 1
VERF_GIC = 1


# Si clÃīture gÃĐnÃĐ
If CPTGEN = 2
 If GMODU(3)=2 or GMODU(5)=2 : VERF_SIH = 1 : Endif
 If GMODU(3)=2 or GMODU(6)=2 : VERF_PIH = 1 : Endif
 If GMODU(3)=2 : VERF_PYH = 1 : Endif
 If GMODU(7)=2 : VERF_STK = 1 : Endif
 If GMODU(14)=2: VERF_FAS = 1 : Endif
 VERF_CPT = 1
 VERF_ECH = 1
 VERF_CUR = 1
 If GMODU(6)=2 : VERF_FAR = 1 : Endif
 VERF_TMP = 1
 If DER_PER=2
  VERF_SLD = 1
  VERF_BAL = 1
  VERF_BCG = 1
  FLGCSL = func AFNC.ACTIV("PRCSL")
  If FLGCSL=1 & [F:LED]CSL=2
   VERF_BALCSL = 1
   VERF_BCGCSL = 1
  Endif
 Endif
 VERF_SVC = 1
Endif

GPOINT = "OUVRE" : Gosub ENTREE From EXEFNC


########################################################
# VÃĐrif. validation des factures ventes
########################################################
If VERF_SIH
 Gosub VERF_SIH
 Gosub VERF_SIH_INTCO
Endif

########################################################
# VÃĐrif. validation des factures achats
########################################################
If VERF_PIH
 Gosub VERF_PIH
 Gosub VERF_PIH_INTCO
Endif

########################################################
# VÃĐrif. validation bordereaux de rÃĻglement
########################################################
If VERF_PYH
 Gosub VERF_PYH
Endif

########################################################
# VÃĐrif. ÃĐcritures provisoires et simulations
########################################################
If VERF_HAE
 Gosub VERF_HAE
Endif

########################################################
# VÃĐrif. ÃĐcritures d'abonnements
########################################################
If VERF_GAF
 Gosub VERF_GAF
Endif

########################################################
# VÃĐrif. ÃĐcritures lots
########################################################
If VERF_LOT
 Gosub VERF_LOT
Endif

########################################################
# Intercompany Journals Verification
########################################################
If VERF_GIC
 Gosub VERF_GIC
Endif

########################################################
# VÃĐrif. ÃĐcritures en devise
########################################################
If VERF_CUR
 Gosub VERF_CUR
Endif

########################################################
# VÃĐrif. ÃĐcritures en devise
########################################################
If VERF_FAR
 Gosub VERF_FAR
Endif

########################################################
# VÃĐrif ÃĐcritures en attente de validation
########################################################
If VERF_TMP
 Gosub VERF_TMP
Endif

########################################################
# VÃĐrif. interfaces stock et prod passÃĐes
########################################################
If VERF_STK
 Gosub VERF_STK
Endif

########################################################
# VÃĐrif. pÃĐriode immo close
########################################################
If VERF_FAS
 Gosub VERF_FAS
Endif

########################################################
# On passe au choses sÃĐrieuses
# VÃĐrif pour la fin d'exercice ...
########################################################
If VERF_SVC    : Gosub VERF_SVC : Endif
If VERF_BAL    : Gosub BAL      : Endif
If VERF_BCG    : Gosub BCG      : Endif
If VERF_BALCSL : Gosub BALCSL   : Endif
If VERF_BCGCSL : Gosub BCGCSL   : Endif
If VERF_CPT    : Gosub CPT      : Endif
If VERF_ECH    : Gosub ECH      : Endif
If VERF_SEC    : Gosub SEC      : Endif
If VERF_SLD    : Gosub SLD      : Endif
Gosub SPE

If !GSERVEUR & !OTRACE
 Call FERME_TRACE From LECFIC
Endif

End


########################################################
# VÃĐrif. validation des factures ventes
########################################################
$VERF_SIH
If clalev([F:SIH])=0 : Local File SINVOICE [SIH] : Endif
Filter [SIH] Where ACCDAT>=DAT_DEB & ACCDAT<=DAT_FIN & CPY=SOCIETE & INVTYP<5 & STA<3

For [SIH]SIH3
 ## Facture client non validÃĐe :
 Call ECR_TRACE("$VERF_SIH"-mess(66,100,1)-[F:SIH]NUM,1) From GESECRAN : OK = 0
 If TYPTRC<>2 : Break : Endif
Next

Close Local File [SIH]
Return


##########################################################################################################
## Intercompany Customers Invoices : verification that the company for which the period
## has to be closed is not included to an intercompany invoices not yet posted
##########################################################################################################
$VERF_SIH_INTCO
If !func AFNC.ACTIV("INTCO") & func AFNC.PARAM("INTCPYINV",SOCIETE)<>"2" : Return : Endif

If clalev([F:SIH])=0 : Local File SINVOICE [SIH] : Endif
If clalev([F:ICF])=0 : Local File INTCOFLO [ICF] : Endif

Link [ICF] With [SIH]SIH0=[F:ICF]NUM
&          As [LICF]
&          Where ABRFIC="SIH" & ACCDAT>=DAT_DEB & ACCDAT<=DAT_FIN & CPYSRC<>SOCIETE & CPYTGR=SOCIETE & FCYTGR="" & NUMVCR = ""
&          Order By Key CLE=NUM

For [LICF]CLE Where [F:SIH]INVTYP<5
 Call ECR_TRACE("$VERF_SIH"-mess(325,107,1)-":"-[F:SIH]NUM,1) From GESECRAN : OK = 0
 If TYPTRC<>2 : Break : Endif
Next

Close Local File [SIH], [ICF]
Return


########################################################
# VÃĐrif. validation des factures achats
########################################################
$VERF_PIH
If clalev([F:PIH])=0 : Local File PINVOICE [PIH] : Endif
Filter [PIH] Where ACCDAT>=DAT_DEB & ACCDAT<=DAT_FIN & CPY=SOCIETE & INVTYP<5 & STA<3

For [PIH]PIH3
 ## Facture four. non validÃĐe :
 Call ECR_TRACE("$VERF_PIH"-mess(155,100,1)-[F:PIH]NUM,1) From GESECRAN : OK = 0
 If TYPTRC<>2 : Break : Endif
Next

Close Local File [PIH]
Return


##########################################################################################################
## Intercompany Suppliers Invoices in AP/AR Module : verification that the company for which the period
## has to be closed is not included to an Intercompany Invoices not yet posted
##########################################################################################################
$VERF_PIH_INTCO
If !func AFNC.ACTIV("INTCO") & func AFNC.PARAM("INTCPYINV",SOCIETE)<>"2" : Return : Endif

If clalev([F:PIH])=0 : Local File PINVOICE [PIH] : Endif
If clalev([F:ICF])=0 : Local File INTCOFLO [ICF] : Endif

Link [ICF] With [PIH]PIH0=[F:ICF]NUM
&          As [LICF]
&          Where ABRFIC="PIH" & ACCDAT>=DAT_DEB & ACCDAT<=DAT_FIN & CPYSRC<>SOCIETE & CPYTGR=SOCIETE & FCYTGR="" & NUMVCR = ""
&          Order By Key CLE=NUM

For [LICF]CLE Where [F:PIH]INVTYP<5
 Call ECR_TRACE("$VERF_PIH"-mess(326,107,1)-":"-[F:PIH]NUM,1) From GESECRAN : OK = 0
 If TYPTRC<>2 : Break : Endif
Next

Close Local File [PIH], [ICF]
Return


########################################################
# VÃĐrif. validation bordereaux de rÃĻglement
########################################################
$VERF_PYH
If clalev([F:PYH])=0 : Local File PAYMENTH  [PYH] : Endif
If clalev([F:TPY])=0 : Local File TABPAYTYP [TPY] : Endif

For [TPY]TPY0
 # Il faut dÃĐtecter le niveau de validation en fct du type de rÃĻglement
 # Il n'y a que 3 ÃĐtapes qui nous intÃĐressent :
 #    - 3 Mise en portefeuille
 #    - 8 Remise sur compte intermÃĐdiaire
 #    - 9 Remise en banque
 ## Bug 17167 : Mauvaise gestion du contrÃīle des rÃĻglements non comptabilisÃĐs lorsque
 ## le paramÃĐtrage de la tansaction de rÃĻglement a ÃĐtÃĐ modifiÃĐ (rajout d'une ÃĐtape de
 ## comptabilisation par exemple)
 ## Rajout de la gestion des NIV_VALID2 et NIV_VALID3 pour regarder si l'ÃĐtape suivante
 ## n'a pas ÃĐtÃĐ finalement comptabilisÃĐe...

 If [F:TPY]STA3<>2 & [F:TPY]STA8<>2 & [F:TPY]STA9=2
   CAS = 1 : NIV_VALID=9
 Elsif [F:TPY]STA3<>2 & [F:TPY]STA8=2
   CAS = 2 : NIV_VALID=8 : NIV_VALID2=9
 Elsif [F:TPY]STA3=2
   CAS = 3 : NIV_VALID=3 : NIV_VALID2=8 : NIV_VALID3=9
 Else
   NIV_VALID=0
 Endif

 If NIV_VALID
  Case CAS
   When 1
    Filter [PYH] Where PAYTYP=[F:TPY]PAYTYP & ACCDAT>=DAT_DEB & ACCDAT<=DAT_FIN & CPY=SOCIETE
&                    & STAFLG([L]NIV_VALID-1)<>2
&                Order By Key CLE = CPY;PAYTYP;ACCDAT;NUM
   When 2
    Filter [PYH] Where PAYTYP=[F:TPY]PAYTYP & ACCDAT>=DAT_DEB & ACCDAT<=DAT_FIN & CPY=SOCIETE
&                    & STAFLG([L]NIV_VALID-1)<>2 & STAFLG([L]NIV_VALID2-1)<>2
&                Order By Key CLE = CPY;PAYTYP;ACCDAT;NUM
   When 3
    Filter [PYH] Where PAYTYP=[F:TPY]PAYTYP & ACCDAT>=DAT_DEB & ACCDAT<=DAT_FIN & CPY=SOCIETE
&                    & STAFLG([L]NIV_VALID-1)<>2 & STAFLG([L]NIV_VALID2-1)<>2
&                    & STAFLG([L]NIV_VALID3-1)<>2
&                Order By Key CLE = CPY;PAYTYP;ACCDAT;NUM
  Endcase
  For [PYH]CLE
   #### RÃĻglement non comptabilisÃĐ :
   Call ECR_TRACE("$VERF_PYH"-mess(127,117,1)-[F:PYH]NUM-"("+[F:PYH]PAYTYP+")",1) From GESECRAN
   OK=0
   If TYPTRC<>2 : Break 2 : Endif
  Next
 Endif
Next

Close Local File [PYH], [TPY]
Return


########################################################
# VÃĐrif. ÃĐcritures provisoires et simulations
########################################################
$VERF_HAE
If clalev([F:HAE])=0 : Local File GACCENTRY  [HAE] : Endif
If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif

Filter [HAE]
&      Where ACCDAT>=DAT_DEB & ACCDAT<=DAT_FIN & CPY=SOCIETE
&          & CAT<5
&          & STA<2
&      Order By Key CLE=CPY;ACCDAT;TYP;NUM
# CAT LA618 1=RÃĐÃĐl ou 4=Hors-bilan
# CAT LA618 2=Simulation active ou 3=Simulation inactive
# STA LA617 < DÃĐfinitif
# STA vaut 0

GPOINT = "FILTERHAE" : Gosub ENTREE From EXEFNC

For [HAE]CLE
 ## On regarde si la piÃĻce (provisoire ou de simulation...) contient au moins une ligne sur le type
 ## de rÃĐfÃĐrentiel concernÃĐ par la clÃīture (contrÃīle inutile si on stocke les rÃĐfÃĐrentiels mouvementÃĐs
 ## dans l'en-tÃŠte de piÃĻce (table GACCENTRYD)
 Filter [DAE] Where TYP=[F:HAE]TYP & NUM=[F:HAE]NUM & LEDTYP=TYPLED
 Read [DAE]DAE0 First
 Filter [DAE]
 If !fstat
  #### PiÃĻce provisoire : XXX YYYYY Sur le journal : ZZZ
  Call ECR_TRACE("$VERF_HAE"-mess(68,100,1)-[F:HAE]TYP-[F:HAE]NUM-mess(69,100,1)-[F:HAE]JOU
&               -mess([F:HAE]CAT,618,1),1) From GESECRAN : OK = 0
  If TYPTRC<>2 : Break : Endif
 Endif
Next


########################################################
# VÃĐrif. ÃĐcritures Ã  extourner
########################################################
Filter [HAE] Where RVSDAT>=DAT_DEB & RVSDAT<=DAT_FIN & CPY=SOCIETE & CAT<5 & RVS=2
&            Order By Key CLE=CPY;RVSDAT;TYP;NUM
# CAT LA618 1=RÃĐÃĐl ou 4=Hors-bilan
# CAT LA618 2=Simulation active ou 3=Simulation inactive
# RVS LA619 A extourner

For [HAE]CLE
 Filter [DAE] Where TYP=[F:HAE]TYP & NUM=[F:HAE]NUM & LEDTYP=TYPLED
 Read [DAE]DAE0 First
 Filter [DAE]
 If !fstat
  #### PiÃĻce : XXX YYYYY A extourner xx/xx/xx
  Call ECR_TRACE("$VERF_HAE2"-mess(12,107,1)-[F:HAE]TYP-[F:HAE]NUM-mess(02,619,1)
&             -format$("D:"+GFMDAT,[F:HAE]RVSDAT),1) From GESECRAN : OK = 0
  If TYPTRC<>2 : Break : Endif
 Endif
Next

Close Local File [HAE]
Return

########################################################
# VÃĐrif. ÃĐcritures d'abonnements
########################################################
$VERF_GAF
If clalev([F:GAF])=0 : Local File GACCFIX   [GAF] : Endif
If clalev([F:HAE])=0 : Local File GACCENTRY [HAE] : Endif

Local Date  PREM_DAT, DER_DAT, OLD_DAT, NEW_DAT

If CPTGEN <> 2 : Return : Endif

Link [GAF] With [HAE]HAE0=[GAF]REFTYP;[GAF]REFNUM
&          As [LGAF]
&          Where STRDAT>=DAT_DEB & STRDAT<=DAT_FIN & LASDAT(0)<DAT_FIN & [HAE]CPY=SOCIETE & ENAFLG=2
&          Order By Key CLE=COD

For [LGAF]CLE
 OLD_DAT = [F:GAF]LASDAT
 If [F:GAF]TYP=2
  PREM_DAT = addmonth([F:GAF]STRDAT,-[F:GAF]PERNBR)
  PREM_DAT = eomonth(PREM_DAT)
  DER_DAT  = eomonth([F:GAF]ENDDAT)
 Else
  PREM_DAT = [F:GAF]STRDAT-1
 Endif
 If OLD_DAT=[0/0/0] | OLD_DAT<[F:GAF]STRDAT
  OLD_DAT = PREM_DAT
  NEW_DAT = [F:GAF]STRDAT
 Else
  Call INCDATE(OLD_DAT,NEW_DAT,[F:GAF]STRDAT,[F:GAF]PERNBR,[F:GAF]PERTYP) From VALGAF
 Endif
 If NEW_DAT<=[F:GAF]ENDDAT & NEW_DAT>=DAT_DEB & NEW_DAT<=DAT_FIN
  ### Ecriture d'abonnement non gÃĐnÃĐrÃĐe
  Call ECR_TRACE("$VERF_GAF"-[F:GAF]COD-mess(085,107,1)-format$("D:"+GFMDAT,NEW_DAT),1)
&   From GESECRAN
  OK=0
  If TYPTRC<>2 : Break : Endif
 Endif
Next

Close Local File [GAF], [HAE]
Return

########################################################
# VÃĐrif. ÃĐcritures lots
########################################################
$VERF_LOT

If clalev([F:LOT])=0 : Local File GENTLOT  [LOT] : Endif
If clalev([F:LOH])=0 : Local File GENTLOTH [LOH] : Endif
If clalev([F:LOD])=0 : Local File GENTLOTD [LOD] : Endif

Link [LOH] With [LOT]LOT0=[LOH]LOT
&          As [LLOH]
&          Where [LOH]ACCDAT>=DAT_DEB & [LOH]ACCDAT<=DAT_FIN
&              & [LOT]UPDFLG<2
&              & [LOT]CPY=SOCIETE
&          Order By Key CLE=LOT;ORNVCR

For [LLOH]CLE
 Filter [LOD] Where LOT=[F:LOH]LOT & find([L]TYPLED,[F:LOD]LEDTYP(0..dim([F:LOD]LEDTYP)-1))
 Read [LOD]LOD0 First
 Filter [LOD]
 If !fstat
  #### Lot ÃĐcritures non validÃĐ
  Call ECR_TRACE("$VERF_LOT"-[F:LOH]LOT-num$([F:LOH]ORNVCR)-mess(203,100,1),1) From GESECRAN : OK=0
  If TYPTRC<>2 : Break : Endif
 Endif
Next

Close Local File [LOT], [LOH], [LOD]


########################################################
# VÃĐrif. ÃĐcritures lots Ã  extourner
########################################################
$VERF_LOT2

If clalev([F:LOT])=0 : Local File GENTLOT  [LOT] : Endif
If clalev([F:LOH])=0 : Local File GENTLOTH [LOH] : Endif
If clalev([F:LOD])=0 : Local File GENTLOTD [LOD] : Endif

Link [LOH] With [LOT]LOT0=[LOH]LOT
&          As [LLOH]
&          Where [LOH]RVSDAT>=DAT_DEB & [LOH]RVSDAT<=DAT_FIN
&              & [LOH]RVS=2
&              & [LOT]UPDFLG<2
&              & [LOT]CPY=SOCIETE
&          Order By Key CLE=LOT;ORNVCR

For [LLOH]CLE
 Filter [LOD] Where LOT=[F:LOH]LOT & find([L]TYPLED,[F:LOD]LEDTYP(0..dim([F:LOD]LEDTYP)-1))
 Read [LOD]LOD0 First
 Filter [LOD]
 If !fstat
  #### Lot XXXX NNNN A extourner (xx/xx/xx)
  Call ECR_TRACE("$VERF_LOT2"-mess(23,107,1)-[F:LOH]LOT-num$([F:LOH]ORNVCR)-mess(2,619,1)
&             +"("+format$("D:"+GFMDAT,[F:LOH]RVSDAT)+")",1) From GESECRAN : OK=0
  If TYPTRC<>2 : Break : Endif
 Endif
Next

Close Local File [LOT], [LOH], [LOD]
Return


########################################################
# Intercompany Journals Verification
########################################################
$VERF_GIC
If !func AFNC.ACTIV("INTCO") : Return : Endif

If clalev([F:GIC])=0 : Local File GACCINTCPY [GIC] : Endif
If clalev([F:ICF])=0 : Local File INTCOFLO   [ICF] : Endif

Link [ICF] With [GIC]GIC0=[F:ICF]NUM
&          As [LICF]
&          Where ABRFIC="GIC" & ACCDAT>=DAT_DEB & ACCDAT<=DAT_FIN & ((CPYSRC=SOCIETE & CPYTGR=SOCIETE & FCYTGR="") | (CPYSRC<>SOCIETE & CPYTGR=SOCIETE & FCYTGR=""))
&          Order By Key CLE=NUM

For [LICF]CLE Where [F:GIC]FLGPST<>3
 Call ECR_TRACE("$VERF_GIC"-mess(331,107,1)-":"-[F:GIC]NUM,1) From GESECRAN : OK = 0
 If TYPTRC<>2 : Break : Endif
Next

Close Local File [GIC], [ICF]
Return


########################################################
# VÃĐrif. ÃĐcritures FAR
########################################################
$VERF_FAR
If CPTGEN<>2 : Return : Endif

Local File PRECEIPT [PTH], FACILITY [FCY]
Local Char OPTFAR(1)

Call PARAM(SOCIETE,"FARCLOPER",OPTFAR) From ADOVAL

If OPTFAR = "1" | (OPTFAR = "2" & DER_PER=2)
 Link [PTH] With [FCY]FCY0 = [F:PTH]PRHFCY As [LNK]
 Filter [LNK] Where [F:PTH]RCPDAT>=DAT_DEB & [F:PTH]RCPDAT<=DAT_FIN & [F:PTH]INVFLG<3 & [F:PTH]BETFCY<2
&                 & [F:PTH]PSTFLG<2 & [F:FCY]LEGCPY=SOCIETE
&                 & [F:PTH]LINNBR>[F:PTH]INVLINNBR+[F:PTH]PSTLINNBR
 For [LNK]
  Call ECR_TRACE("$VERF_FAR"-[F:PTH]PTHNUM-format$("D:"+GFMDAT,[F:PTH]RCPDAT)-mess(86,107,1),1) From GESECRAN
  OK = 0
 Next
Endif

Close Local File [PTH], [FCY]
Return

########################################################
# VÃĐrif. interfaces stock et prod passÃĐes
########################################################
$VERF_STK
Local Char OPTSTO(1)
Call PARAM(SOCIETE,"STOCLOPER",OPTSTO) From ADOVAL
#1=Bloquant par pÃĐriode 2=Bloquant par exercice
If OPTSTO="1"
  If func STKVALMAJ.PERCLOCTR([F:CPY]LEG,SOCIETE,DAT_DEB,DAT_FIN)<>0
    OK = 0
  Endif
Elsif OPTSTO="2" & DER_PER=2
 If !clalev([FIY]) : Local File FISCALYEAR [FIY] : Endif
 Read [FIY]=SOCIETE;TYPLED;EXERCICE
 If func STKVALMAJ.PERCLOCTR([F:CPY]LEG,SOCIETE,[F:FIY]FIYSTR,[F:FIY]FIYEND)<>0
  OK = 0
 Endif
 Close Local File [FIY]
Endif
Return

########################################################
# VÃĐrif. pÃĐriode immo close
########################################################
$VERF_FAS
If !clalev([WFIS]) : Local File FISCYEAR [WFIS] : Endif
Local Shortint OKI
Local Integer  PLANFAS, CTXFAS
Raz [F:WFIS]
# This control is always executed even if the parameter FRADGI<>2
OKI = 1
Call IS_PER_CLOSED(SOCIETE,CODLED,DAT_DEB,DAT_FIN,OKI,PLANFAS,CTXFAS) From GLOBIENS
If OKI=0
 # PÃĐriode non close dans les immobilisations sur le contexte xxx type de plan xxxx
 Call ECR_TRACE(num$(DAT_DEB)-num$(DAT_FIN)-func AFNC.MES2(mess(65,101,1),mess(CTXFAS,3100,1),mess(PLANFAS,3101,1)),1) From GESECRAN
 OK = 0
Elsif OKI=-1
 # Aucun contexte d'amortissements ne correspond Ã  la pÃĐriode
 Call ECR_TRACE(mess(67,101,1),1) From GESECRAN
 OK = 0
Elsif OKI=1 & DER_PER=2 & [F:WFIS]STAPER<>4 & [F:WFIS]CPY<>""
 # Exercice non clos dans les immobilisations sur le contexte xxx type de plan xxx
 Call ECR_TRACE(func AFNC.MES2(mess(66,101,1),mess(CTXFAS,3100,1),mess(PLANFAS,3101,1)),1) From GESECRAN
 OK = 0
Endif

Close Local File [WFIS]

Return

########################################################
# VÃĐrif. CCA/PCA
########################################################
$VERF_SVC
If CPTGEN<>2 : Return : Endif
If !func AFNC.ACTIV("SVC") : Return : Endif

Local Char OPTSVC(1)
Call PARAM(SOCIETE,"SVCCLOPER",OPTSVC) From ADOVAL  # 1: Bloquant  2: Non bloquant

Local Integer COLOURS
COLOURS = -1  # Message d'avertissement
If OPTSVC = "1"
 COLOURS = 1
Else
 If DER_PER=2 : COLOURS = 1 : Endif
Endif

Local Integer FLGOK
FLGOK=1

Local File SINVOICE [SIH], PINVOICE [PIH]

If GMODU(3)=2
 # Facture Tiers Client
 Local File BPCINVLIG [SIL]
 Link [SIL] With [F:SIH]SIH0=[F:SIL]NUM
&   As [LNK]
&   Where  [F:SIH]CPY=SOCIETE & [F:SIH]LASDATSVC<DAT_FIN & [F:SIH]ACCDAT<DAT_FIN &
&           [F:SIL]STRDAT<>[00/00/00] & [F:SIL]ENDDAT<>[00/00/00] & [F:SIL]ENDDAT>DAT_FIN

 For [LNK]
  # Produit constatÃĐ d'avance non comptabilisÃĐ
  Call ECR_TRACE("$VERF_SVC"-[F:SIH]NUM-mess(122,107,1),COLOURS) From GESECRAN
  FLGOK = 0
 Next
 Close Local File [SIL]

 # Facture Tiers Fournisseur
 Local File BPSINVLIG [PIL]
 Link [PIL] With [F:PIH]PIH0=[F:PIL]NUM
&   As [LNK]
&   Where  [F:PIH]CPY=SOCIETE & [F:PIH]LASDATSVC<DAT_FIN & [F:PIH]ACCDAT<DAT_FIN &
&          [F:PIL]STRDAT<>[00/00/00] & [F:PIL]ENDDAT<>[00/00/00] & [F:PIL]ENDDAT>DAT_FIN

 For [LNK]
  # Charge constatÃĐe d'avance non comptabilisÃĐ
  Call ECR_TRACE("$VERF_SVC"-[F:PIH]NUM-mess(121,107,1),COLOURS) From GESECRAN
  FLGOK = 0
 Next
 Close Local File [PIL]

Endif

If GMODU(5)=2
 # Facture Vente
 Local File SINVOICED [SID]
 Link [SID] With [F:SIH]SIH0=[F:SID]NUM
&   As [LNK]
&   Where  [F:SIH]CPY=SOCIETE & [F:SIH]LASDATSVC<DAT_FIN & [F:SIH]ACCDAT<DAT_FIN &
&           [F:SID]STRDAT<>[00/00/00] & [F:SID]ENDDAT<>[00/00/00] & [F:SID]ENDDAT>DAT_FIN

 For [LNK]
  # Produit constatÃĐ d'avance non comptabilisÃĐ
  Call ECR_TRACE("$VERF_SVC"-[F:SIH]NUM-mess(122,107,1),COLOURS) From GESECRAN
  FLGOK = 0
 Next
 Close Local File [SID]
Endif

If GMODU(6)=2
 # Facture Tiers Fournisseur
 Local File PINVOICED [PID]
 Link [PID] With [F:PIH]PIH0=[F:PID]NUM
&   As [LNK]
&   Where  [F:PIH]CPY=SOCIETE & [F:PIH]LASDATSVC<DAT_FIN & [F:PIH]ACCDAT<DAT_FIN &
&          [F:PID]STRDAT<>[00/00/00] & [F:PID]ENDDAT<>[00/00/00] & [F:PID]ENDDAT>DAT_FIN

 For [LNK]
  # Charge constatÃĐe d'avance non comptabilisÃĐ
  Call ECR_TRACE("$VERF_SVC"-[F:PIH]NUM-mess(121,107,1),COLOURS) From GESECRAN
  FLGOK = 0
 Next
 Close Local File [PID]
Endif

# Arret de la clÃīture
If FLGOK=0 & COLOURS=1
 OK=0
Endif

Close Local File [PIH], [SIH]
Return


########################################################
# VÃĐrif ÃĐcritures en attente
########################################################
$VERF_TMP
Local File GACCTMP [HAT]

If PERIODE>1
 Filter [HAT] Where CPY=SOCIETE & FIY=EXERCICE & PER=PERIODE
Else
 Filter [HAT] Where CPY=SOCIETE & FIY=EXERCICE & PER<=PERIODE
Endif
For [HAT]HAT0
 If [F:HAT]FLG<100
  If [F:HAT]FLG<>1
   # PiÃĻce en attente de validation
   Call ECR_TRACE("$VERF_TMP"-[F:HAT]TYP-[F:HAT]NUM-mess(37,104,1),1) From GESECRAN
  Else
   # PiÃĻce que la tÃĒche batch n'a pas pu valider
   Call ECR_TRACE("$VERF_TMP"-[F:HAT]TYP-[F:HAT]NUM-mess(70,101,1),1) From GESECRAN
  Endif
  OK = 0
  If TYPTRC<>2 : Break : Endif
 Else
  If [F:HAT]FLG<>101
   # Des piÃĻces comptables sont en attente de MAJ Balances
   Call ECR_TRACE("$VERF_TMP"-[F:HAT]TYP-[F:HAT]NUM-mess(49,114,1),1) From GESECRAN
  Else
   # PiÃĻce que la tÃĒche batch n'a pas pu MAJ Balances
   Call ECR_TRACE("$VERF_TMP"-[F:HAT]TYP-[F:HAT]NUM-mess(50,114,1),1) From GESECRAN
  Endif
  OK = 0
  If TYPTRC<>2 : Break : Endif
 Endif
Next
Close Local File [HAT]
Return


########################################################
# Balance gÃĐnÃĐrale ÃĐquilibrÃĐe ?
########################################################
$BAL
#### RECUPBAL(SOCIETE,TOUSITE,SITE,LEDTYP,EXERCICE,DEVISE,BALGEN,COMPTE,BATCH,DIRECT,ANOM)
#### TOUSIT Oui/Non
#### BALGEN 1=Equilibre, 2=Gd Livre, 3=RÃĐcup
If CPTEQL<>2 : Return : Endif
Raz NB_ANOM
Call RECUPBAL(SOCIETE,2,"",TYPLED,EXERCICE,"",1,"",1,0,NB_ANOM) From RECUPBAL
If NB_ANOM
 OK = 0
Endif
Return

########################################################
# Balance de contrÃīle gÃĐnÃĐrale
########################################################
$BCG
#### RECUPBAL(SOCIETE,TOUSITE,SITE,LEDTYP,EXERCICE,DEVISE,BALGEN,COMPTE,BATCH,DIRECT,ANOM)
#### TOUSIT Oui/Non
#### BALGEN 1=Equilibre, 2=Gd Livre, 3=RÃĐcup
Raz NB_ANOM
Call RECUPBAL(SOCIETE,2,"",TYPLED,EXERCICE,"",2,"",1,0,NB_ANOM) From RECUPBAL
If NB_ANOM
 OK = 0
Endif
Return

########################################################
# Balance prÃĐconsolidÃĐe ÃĐquilibrÃĐe ?
# Balance verification
########################################################
$BALCSL
If CPTEQL<>2 : Return : Endif
Raz NB_ANOM
Call RECUPBLP(SOCIETE,2,"",TYPLED,EXERCICE,"",1,"",1,NB_ANOM) From RECUPBLP
If NB_ANOM
 OK = 0
Endif
Return

########################################################
# Balance prÃĐconsolidÃĐe correspond au Grand livre ?
# Ledger verification
########################################################
$BCGCSL
Raz NB_ANOM
Call RECUPBLP(SOCIETE,2,"",TYPLED,EXERCICE,"",2,"",1,NB_ANOM) From RECUPBLP
If NB_ANOM
 OK = 0
Endif
Return

########################################################
# Comptes inexistants
########################################################
$CPT
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
If clalev([F:HAE])=0 : Local File GACCENTRY  [HAE] : Endif
If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif

Link [DAE] With [HAE]HAE0=[DAE]TYP;[DAE]NUM   As [LDAE]
&          Where [DAE]ACCDAT>=DAT_DEB & [DAE]ACCDAT<=DAT_FIN & [DAE]CPY=SOCIETE & [DAE]LEDTYP=TYPLED

For [LDAE]DAE1(4)
 Read [GAC]GAC0 = [F:DAE]COA;[F:DAE]ACC
 If fstat
  Call ECR_TRACE("$CPT"-[F:DAE]NUM+" "+format$("K>:5X",num$([F:DAE]LIN))-mess(87,100,1)
&               -[F:DAE]COA-"/"-[F:DAE]ACC,1) From GESECRAN : OK = 0
  #### Inexistant
 Else
  For [LDAE]DAE1(5)
   If [F:DAE]BPR<>"" & [F:GAC]SAC<>2 : # LA603 Collectif
    Call ECR_TRACE("$CPT"-[F:DAE]TYP-[F:DAE]NUM+" "+format$("K>:5X",num$([F:DAE]LIN))-mess(45,106,1)
&                -[F:DAE]BPR-[F:DAE]COA-[F:DAE]ACC,1) From GESECRAN : OK = 0
    #### Tiers incompatible avec le collectif
   Elsif [F:DAE]BPR<>""
    Look [BPR]BPR0 = [F:DAE]BPR
    If fstat
     Call ECR_TRACE("$CPT"-[F:DAE]TYP-[F:DAE]NUM+" "+format$("K>:5X",num$([F:DAE]LIN))-mess(50,102,1)
&                -[F:DAE]BPR,1) From GESECRAN : OK = 0
     #### Tiers incorrect
    Endif
   Endif
  Next
 Endif
Next

Close Local File [DAE], [GAC], [BPR], [HAE]
Return

########################################################
# Sections inexistantes
########################################################
$SEC
If clalev([F:DAA])=0 : Local File GACCENTRYA [DAA] : Endif
If clalev([F:CCE])=0 : Local File CACCE [CCE] : Endif

Local Integer IJ

Call LECTURE("LED",CODLED,"") From CONTOBJ

For IJ=0 To dim([F:DAA]CCE)-1
 Filter [DAA] Where [DAA]ACCDAT>=DAT_DEB & [DAA]ACCDAT<=DAT_FIN & [DAA]CPY=SOCIETE & [DAA]LEDTYP=TYPLED & [DAA]CCE(IJ)<>""
&                    Order By Key CLE=[DAA]CPY;LEDTYP;[DAA]CCE(IJ);[DAA]ACCDAT

 For [DAA]CLE(3)
  If !find([F:DAA]DIE,[F:LED]DIE(0..[F:LED]DIENBR-1))
   #### Axe erronÃĐ
   Call ECR_TRACE("$SEC"-mess(2,103,1)+" "+format$("LA601:14X",IJ+1)+"("+num$(IJ+1)+") : "
&                +[F:DAA]TYP-[F:DAA]NUM-num$([F:DAA]LIN)-mess(TYPLED,2644,1)
&                -mess(22,103,1)-num$(IJ+1),1) From GESECRAN : OK = 0
  Else
   Read [CCE]CCE0=[F:DAA]DIE(IJ);[F:DAA]CCE(IJ)
   If fstat
    #### Section inexistante
    Call ECR_TRACE("$SEC"-mess(2,103,1)+" "+[F:DAA]DIE(IJ)+" : "
&                 +[F:DAA]TYP-[F:DAA]NUM-num$([F:DAA]LIN)-mess(TYPLED,2644,1)
&                 -mess(35,106,1)-[F:DAA]CCE(IJ),1) From GESECRAN : OK = 0
   Endif
  Endif
 Next
Next IJ
Filter [DAA]

Close Local File [DAA], [CCE]
Return

########################################################
# Equilibre des ÃĐchÃĐances
########################################################
$ECH

If !CPTECH or FLGAUT=2 : Return : Endif

If clalev([F:HAE])=0 : Local File GACCENTRY  [HAE] : Endif
If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif
If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif

Local Decimal MT_ECHE

Link [DAE] With [HAE]HAE0=[DAE]TYP;[DAE]NUM    As [LDAE]
&          Where [DAE]ACCDAT>=DAT_DEB & [DAE]ACCDAT<=DAT_FIN & [DAE]CPY=SOCIETE
&              & [DAE]LEDTYP=TYPLED & [DAE]BPR<>""
&              & ([HAE]CAT=1 | [HAE]CAT=4)
#&          Order By Key CLE=[DAE]CPY;[DAE]LEDTYP;[DAE]BPR;[DAE]ACCDAT;[DAE]ACCNUM
# CAT LA618 1=RÃĐÃĐl ou 4=Hors-bilan

For [LDAE]DAE5
 MT_ECHE = 0
 For [DUD]DUD0 Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LIG=[F:DAE]LIN
  MT_ECHE += [F:DUD]AMTLOC
 Next
 If MT_ECHE<>[F:DAE]AMTLED
  #### Total des ÃĐchÃĐances incorrect
  Call ECR_TRACE("$ECH"-[F:DAE]TYP-[F:DAE]NUM+" "+format$("K>:5X",num$([F:DAE]LIN))-mess(24,119,1)
&               -num$(MT_ECHE)-num$([F:DAE]AMTLED),1) From GESECRAN : OK = 0
 Endif
Next

Close Local File [HAE], [DAE], [DUD]
Return


###################################################################################################
# ContrÃīle non bloquant sens solde
# ContrÃīle fait par rapport aux montants en devise rÃĐfÃĐrentiel (=> pas de filtre sur la devise
# d'origine [BAL]CUR)
###################################################################################################
$SLD
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
If clalev([F:BAL])=0 : Local File BALANCE  [BAL] : Endif

Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
Filter [GAC] Where COA=COALED

For [GAC]GAC0 Where SNSBLC<>3 : # ML 610 IndÃĐterminÃĐ
 TDEBLED = 0 : TCDTLED = 0
 Filter [BAL] Where LEDTYP=TYPLED & CPY=SOCIETE & FCY="" & FIY=EXERCICE & ACC=[F:GAC]ACC & BPR=""
 For [BAL]BAL0
  TDEBLED += [F:BAL]DEBLED(0..dim([F:BAL]DEBLED)-1)
  TCDTLED += [F:BAL]CDTLED(0..dim([F:BAL]CDTLED)-1)
 Next
 Filter [BAL]
 If [F:GAC]SNSBLC=1 & TDEBLED-TCDTLED<0
  ## XXX Sens par dÃĐfaut YYY - Total balance Solde crÃĐditeur
  Call ECR_TRACE("$SLD"-[F:GAC]ACC-mess(410,200,1)-mess([F:GAC]SNSBLC,610,1)-"-"
&               -mess(65,116,1)-mess(6,109,1),0) From GESECRAN
 Elsif [F:GAC]SNSBLC=2 & TCDTLED-TDEBLED<0
  ## XXX Sens par dÃĐfaut YYY - Total balance Solde dÃĐbiteur
  Call ECR_TRACE("$SLD"-[F:GAC]ACC-mess(410,200,1)-mess([F:GAC]SNSBLC,610,1)-"-"
&                -mess(65,116,1)-mess(5,109,1),0) From GESECRAN
 Endif
 If [F:GAC]SAC=2 : # Collectif
  # ContrÃīle sur les comptes individuels...
  Filter [BAL] Where LEDTYP=TYPLED & CPY=SOCIETE & FCY="" & FIY=EXERCICE & ACC=[F:GAC]ACC & BPR<>""
  For [BAL]BAL0(6)
   TDEBLED = 0
   TCDTLED = 0
   For [BAL]BAL0
    TDEBLED += [F:BAL]DEBLED(0..dim([F:BAL]DEBLED)-1)
    TCDTLED += [F:BAL]CDTLED(0..dim([F:BAL]CDTLED)-1)
   Next
   If [F:GAC]SNSBLC=1 & TDEBLED-TCDTLED<0
    ## XXX Sens par dÃĐfaut YYY - Total balance Solde crÃĐditeur
    Call ECR_TRACE("$SLD"-[F:GAC]ACC-[F:BAL]BPR-mess(410,200,1)-mess([F:GAC]SNSBLC,610,1)-"-"
&                 -mess(65,116,1)-mess(6,109,1),0) From GESECRAN
   Elsif [F:GAC]SNSBLC=2 & TCDTLED-TDEBLED<0
    ## XXX Sens par dÃĐfaut YYY - Total balance Solde dÃĐbiteur
    Call ECR_TRACE("$SLD"-[F:GAC]ACC-[F:BAL]BPR-mess(410,200,1)-mess([F:GAC]SNSBLC,610,1)-"-"
&                 -mess(65,116,1)-mess(5,109,1),0) From GESECRAN
   Endif
  Next
  Filter [BAL]
 Endif
Next
Filter [GAC]
Close Local File [GAC], [BAL]
Return

########################################################
# VÃĐrifications ÃĐcritures en devises
# ContrÃīle non bloquant sur ÃĐcritures en devises
########################################################
$VERF_CUR
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif

Call LECTURE("CPY",SOCIETE,"") From CONTOBJ

Link [DAE] With [GAC]GAC0 = [F:DAE]ACC As [LNK]
Filter [LNK] Where [F:GAC]CUR<>"" & [F:GAC]CUR<>DEVLED & [F:DAE]CUR<>[F:GAC]CUR
& & [F:DAE]ACCDAT>=DAT_DEB & [F:DAE]ACCDAT<=DAT_FIN
& & [F:DAE]CPY=SOCIETE & [F:DAE]LEDTYP=TYPLED
For [LNK]
 # Devise de piÃĻce, devise du compte
 Call ECR_TRACE("$CUR"-[F:DAE]TYP-[F:DAE]NUM-num$([F:DAE]LIN)-mess(86,115,1)+":"-[F:DAE]CUR-","
& -[F:GAC]ACC-mess(13,106,1)-[F:GAC]CUR,0) From GESECRAN
Next

Close Local File [DAE], [GAC]
Return

########################################################
# VÃĐrifications spÃĐcifiques
########################################################
$SPE
GPOINT = "VERIF" : Gosub ENTREE From EXEFNC
Return

##########################################################################################################
# The PATCH subprogramm has been added just to avoid problems during the continuous integration due to   #
# the name of the processing UTI*                                                                        #
##########################################################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
End

