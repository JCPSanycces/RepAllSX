#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################################################
#   Traitement de recherche d'une demande de service par chrono client    Module CRM        25 juin 2003
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  If !clalev([F:SRE]) : Local File SERREQUEST [SRE] : Endif
  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  If !clalev([F:QUE]) : Local File QUEUE [QUE] : Endif
  #PARAM(1) = Code tiers
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If [M:LKP5]NBLIG > 0 Then
    ETABOU(GVALI) = 1
  Else
    ETABOU(GVALI) = 0
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  [M:LKP5]CLOFLG = 2
  If PARAM(1) = "" Then
    [M:LKP5]BPC = ""
    Grizo [M:LKP5]NUM
  Else
    [M:LKP5]BPC = PARAM(1)
    Actzo [M:LKP5]NUM
  Endif
  If [M:LKP5]BPC <> "" Then
    Gosub LOADLKP5
  Endif
  Affzo [M:LKP5]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  Raz [M:LKP5]
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "A"
      Gosub LOADALL
      Affzo [M:LKP5]1-99
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
$ONOK
  VALEUR = [M:LKP5]SRENUM(nolign-1)
  mkstat = 4
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESSRE" Then
      [M:SRE0]LKP5SEAFLG = 1
    Endif
  Endif
Return

##########################################################################################################
$LOADLKP5
Local Char SZFILTER(250)
Local Integer ITER2

  Raz [M:LKP5]NBLIG
  Raz [M:LKP5]SRENUM
  Raz [M:LKP5]SRENUMBPC
  Raz [M:LKP5]SRETTR
  Raz [M:LKP5]SREASS
  Raz [M:LKP5]SREDET
  Raz [M:LKP5]SREDETCLA
  Raz [M:LKP5]CREDAT
  Raz [M:LKP5]SRERESDAT
  Raz [M:LKP5]SRERESHOU
  If [M:LKP5]CLOFLG = 2 Then
    Filter [SRE] Where [F:SRE]SREBPC = [M:LKP5]BPC and [F:SRE]SRENUMBPC <> "" Order By [F:SRE]SREINUMBPC Desc
  Else
    Filter [SRE] Where [F:SRE]SREBPC = [M:LKP5]BPC and [F:SRE]SRENUMBPC <> "" and [F:SRE]SREASS <> 5 Order By [F:SRE]SREINUMBPC Desc
  Endif
  ITER2 = 0
  nolign = 0
  For [SRE] Hint Key SRE5
    If ITER2 >= dim([M:LKP5]SRENUM) Then
      Break
    Endif
    #Transclass
    nolign += 1
    [M:LKP5] = [F:SRE]
    [M:LKP5]SREDETCLA(ITER2) = ""
    Case [M:LKP5]SREASS(ITER2)
      When 1 
        If [M:LKP5]SREDET(ITER2) <> "" Then
          Read [FCY]FCY0=[M:LKP5]SREDET(ITER2)
          If !fstat Then
            [M:LKP5]SREDETCLA = [F:FCY]FCYNAM
          Endif
        Endif
      When 2
        If [M:LKP5]SREDET(ITER2) <> "" Then
          Read [AUS]CODUSR=[M:LKP5]SREDET(ITER2)
          If !fstat Then
            [M:LKP5]SREDETCLA = [F:AUS]NOMUSR
          Endif
        Endif
      When 3
        If [M:LKP5]SREDET(ITER2) <> "" Then
          Read [QUE]QUE0=[M:LKP5]SREDET(ITER2)
          If !fstat Then
            # FGR 23/09/2009 : X3SUIVI58037
            #[M:LKP5]SREDETCLA = [F:QUE]TTR
            Call LECTEXTRA([M:LKP5]SREDETCLA,"QUEUE","QUEDESAXX",[F:QUE]NUM,"") From ATEXTRA
          Endif
        Endif
      When Default
    Endcase
    ITER2 += 1
  Next
  Filter [SRE]
  [M:LKP5]NBLIG = ITER2
Return

##########################################################################################################
$LOADALL
Local Char SZFILTER(250)
Local Integer ITER3

  Raz [M:LKP5]NBLIG
  Raz [M:LKP5]SRENUM
  Raz [M:LKP5]SRENUMBPC
  Raz [M:LKP5]SRETTR
  Raz [M:LKP5]SREASS
  Raz [M:LKP5]SREDET
  Raz [M:LKP5]SREDETCLA
  Raz [M:LKP5]CREDAT
  Raz [M:LKP5]SRERESDAT
  Raz [M:LKP5]SRERESHOU
  If [M:LKP5]CLOFLG = 2 Then
    Filter [SRE] Where [F:SRE]SREBPC = [M:LKP5]BPC Order By [F:SRE]SREINUMBPC Desc
  Else
    Filter [SRE] Where [F:SRE]SREBPC = [M:LKP5]BPC and [F:SRE]SREASS <> 5 Order By [F:SRE]SREINUMBPC Desc
  Endif
  ITER3 = 0
  nolign = 0
  For [SRE] Hint Key SRE5
    If ITER3 >= dim([M:LKP5]SRENUM) Then
      Break
    Endif
    #Transclass
    nolign += 1
    [M:LKP5] = [F:SRE]
    [M:LKP5]SREDETCLA(ITER3) = ""
    Case [M:LKP5]SREASS(ITER3)
      When 1 
        If [M:LKP5]SREDET(ITER3) <> "" Then
          Read [FCY]FCY0=[M:LKP5]SREDET(ITER3)
          If !fstat Then
            [M:LKP5]SREDETCLA = [F:FCY]FCYNAM
          Endif
        Endif
      When 2
        If [M:LKP5]SREDET(ITER3) <> "" Then
          Read [AUS]CODUSR=[M:LKP5]SREDET(ITER3)
          If !fstat Then
            [M:LKP5]SREDETCLA = [F:AUS]NOMUSR
          Endif
        Endif
      When 3
        If [M:LKP5]SREDET(ITER3) <> "" Then
          Read [QUE]QUE0=[M:LKP5]SREDET(ITER3)
          If !fstat Then
            # FGR 23/09/2009 : X3SUIVI58037
            #[M:LKP5]SREDETCLA = [F:QUE]TTR
            Call LECTEXTRA([M:LKP5]SREDETCLA,"QUEUE","QUEDESAXX",[F:QUE]NUM,"") From ATEXTRA
          Endif
        Endif
      When Default
    Endcase
    ITER3 += 1
  Next
  Filter [SRE]
  [M:LKP5]NBLIG = ITER3
Return
