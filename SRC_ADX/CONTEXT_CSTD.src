#<AdxTL>@(#)5.0.0.0 $Revision$
# Classe CONTEXT

$ACTION
  case CURPRO
    when ""         : gosub CLASS      : # If CURPRO is empty, we are on class methods
    when default    : gosub PROPERTIES : # Otherwise it is a hook called on properties
  endcase
return

###############
# CLASS
###############
$CLASS
  case CURPTH
    when ""
      case ACTION
        when "AREAD_AFTER" : gosub AREAD_AFTER_CONTEXT
      endcase
  endcase
return

$AREAD_AFTER_CONTEXT
return

###############
# PROPERTIES
###############
$PROPERTIES
  case CURPRO
    when default
  endcase
return

$METHODS
Return


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

