# Gestion du masque SMXUPD2

Subprog C_POT(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 : mkstat = 2 : Endif
End

Subprog C_REFPER(VALEUR)
Variable Date    VALEUR
If VALEUR > [31/12/2999] : mkstat = 2 : Endif
End

Subprog AM_REFPER(VALEUR)
Variable Date    VALEUR
Local    Integer  WCOD
Local    Date     WREF : WREF = VALEUR
Local    Integer  WSHL : WSHL = [M:SUD2]SHL    (nolign-1)
Local    Date     WPER
Local    Integer  WUOM : WUOM = [M:SUD2]SHLUOM (nolign-1)
Local    Decimal  WDLU : WDLU = [M:SUD2]DLU    (nolign-1)
Local    Date     WEXY
Local    Integer  WLTI


If [F:ITM]ITMREF  <> [M:SUD2]ITMREF (nolign-1)
    Read [ITM]ITM0=  [M:SUD2]ITMREF (nolign-1)
    If fstat : Raz [ITM] : Endif
Endif
WCOD = [F:ITM]EXYMGTCOD

Call CALPER(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
[M:SUD2]SHLDAT      (nolign-1) = WPER
Affzo [M:SUD2]SHLDAT(nolign-1)

WEXY = WPER
Call CALDLU(WCOD,WREF,WEXY,WDLU,"",WPER,WLTI) From STKLIB
[M:SUD2]DLUDAT      (nolign-1) = WPER
Affzo [M:SUD2]DLUDAT(nolign-1)
[M:SUD2]DLULTI      (nolign-1) = WLTI
Affzo [M:SUD2]DLULTI(nolign-1)


WSHL = [M:SUD2]SHLLTI   (nolign-1)
WUOM = [M:SUD2]SHLLTIUOM(nolign-1)
Call CALLTI(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
[M:SUD2]NEWLTIDAT   (nolign-1) = WPER
#       si date recontrole > date limite utilisation : date recontrole = date limite utilisation
If [M:SUD2]NEWLTIDAT(nolign-1) <> [31/12/2999]
   If [M:SUD2]NEWLTIDAT(nolign-1)  > [M:SUD2]DLUDAT(nolign-1)
      [M:SUD2]NEWLTIDAT(nolign-1)  = [M:SUD2]DLUDAT(nolign-1)
   Endif
Endif
Affzo [M:SUD2]NEWLTIDAT(nolign-1)


End

########################################
Subprog AM_SHL(VALEUR)
Variable Decimal VALEUR
Local    Integer  WCOD
Local    Date     WREF : WREF = [M:SUD2]REFPER(nolign-1)
Local    Integer  WSHL : WSHL = VALEUR
Local    Date     WPER
Local    Integer  WUOM : WUOM = [M:SUD2]SHLUOM(nolign-1)
Local    Decimal  WDLU : WDLU = [M:SUD2]DLU   (nolign-1)
Local    Date     WEXY
Local    Integer  WLTI


If [F:ITM]ITMREF  <> [M:SUD2]ITMREF(nolign-1)
    Read [ITM]ITM0=  [M:SUD2]ITMREF(nolign-1)
    If fstat : Raz [ITM] : Endif
Endif
WCOD = [F:ITM]EXYMGTCOD

Call CALPER(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
[M:SUD2]SHLDAT      (nolign-1) = WPER
Affzo [M:SUD2]SHLDAT(nolign-1)

WEXY = WPER
Call CALDLU(WCOD,WREF,WEXY,WDLU,"",WPER,WLTI) From STKLIB
[M:SUD2]DLUDAT      (nolign-1) = WPER
Affzo [M:SUD2]DLUDAT(nolign-1)
[M:SUD2]DLULTI      (nolign-1) = WLTI
Affzo [M:SUD2]DLULTI(nolign-1)

WSHL = [M:SUD2]SHLLTI   (nolign-1)
WUOM = [M:SUD2]SHLLTIUOM(nolign-1)
Call CALLTI(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
[M:SUD2]NEWLTIDAT   (nolign-1) = WPER
#       si date recontrole > date limite utilisation : date recontrole = date limite utilisation
If [M:SUD2]NEWLTIDAT(nolign-1) <> [31/12/2999]
   If [M:SUD2]NEWLTIDAT(nolign-1)  > [M:SUD2]DLUDAT(nolign-1)
      [M:SUD2]NEWLTIDAT(nolign-1)  = [M:SUD2]DLUDAT(nolign-1)
   Endif
Endif
Affzo [M:SUD2]NEWLTIDAT(nolign-1)

End

Subprog C_SHLDAT(VALEUR)
Variable Date    VALEUR
If VALEUR > [31/12/2999] : mkstat = 2 : Endif
#MAE, bg 77614
If VALEUR = [0/0/0]
   GMESSAGE=mess(382,184,1)  # Date de péremption obligatoire
   mkstat = 2
Endif

End

Subprog AS_POT(VALEUR)
Variable Decimal VALEUR

If [F:ITM]STOMGTCOD <= 1
   mkstat = 2
   End
Endif

#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF]STOFCY <> [M:SUD2]STOFCY | [F:ITF]ITMREF <> [M:SUD2]ITMREF(nolign-1)
   Read [ITF]ITF0 = [M:SUD2]ITMREF(nolign-1);[M:SUD2]STOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif

# si pas de titre
If [F:ITF]STOMGTCOD < 3 : mkstat = 2 : Endif
End

Subprog AS_REFPER(VALEUR)
Variable Date    VALEUR
If [F:ITM]ITMREF  <> [M:SUD2]ITMREF(nolign-1)
    Read [ITM]ITM0=  [M:SUD2]ITMREF(nolign-1)
    If fstat : Raz [ITM] : Endif
Endif
# si pas de peremption
If !find([F:ITM]EXYMGTCOD,2,3,4,5,6) : mkstat = 2 : Endif     # v6per
End

