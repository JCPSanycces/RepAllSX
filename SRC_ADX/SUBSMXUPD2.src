Subprog AS_NEWLTIDAT(VALEUR)
Variable Date    VALEUR
If [F:ITM]ITMREF  <> [M:SUD2]ITMREF(nolign-1)
    Read [ITM]ITM0=  [M:SUD2]ITMREF(nolign-1)
    If fstat : Raz [ITM] : Endif
Endif
# si pas de peremption
If !find([F:ITM]EXYMGTCOD,2,3,4,5,6) : mkstat = 2 : Endif

End

Subprog C_NEWLTIDAT(VALEUR)
Variable Date    VALEUR
If VALEUR <> [31/12/2999]
   If VALEUR > [M:SUD2]DLUDAT(nolign-1)
      GMESSAGE=mess(309,184,1)  # Date re-contrôle  > date limite utilisation !
      mkstat = 2
   #MAE, bg 77614
   Else If VALEUR =[0/0/0]
        GMESSAGE=mess(10,123,1)  # Date re-contrôle obligatoire !
        mkstat = 2
       Endif
   Endif
Endif
End

Subprog C_DLU(VALEUR)
Variable Decimal VALEUR
If VALEUR > 1 | VALEUR < 0 | VALEUR = 0
   GMESSAGE = mess(83,123,1) #"valeur incorrecte"
   mkstat = 2
Endif
End




Subprog C_DLUDAT(VALEUR)
Variable Date    VALEUR
If VALEUR > [M:SUD2]SHLDAT (nolign-1)
   GMESSAGE=mess(313,184,1)  # Date re-contrôle  > date limite utilisation !
   mkstat = 2
Endif

End


Subprog AM_SHLDAT(VALEUR)
Variable Date    VALEUR
Local    Integer  WCOD : WCOD = [F:ITM]EXYMGTCOD
Local    Decimal  WDLU : WDLU = [M:SUD2]DLU
Local    Date     WREF : WREF = [M:SUD2]REFPER
Local    Date     WPER
Local    Date     WEXY : WEXY = VALEUR
Local    Integer  WLTI


Call CALDLU(WCOD,WREF,WEXY,WDLU,"",WPER,WLTI) From STKLIB

[M:SUD2]DLUDAT      (nolign-1) = WPER
Affzo [M:SUD2]DLUDAT(nolign-1)
[M:SUD2]DLULTI      (nolign-1) = WLTI
Affzo [M:SUD2]DLULTI(nolign-1)



End


