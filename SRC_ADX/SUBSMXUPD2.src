[M:SUD2]NEWLTIDAT   (nolign-1) = WPER
#       si date recontrole > date limite utilisation : date recontrole = date limite utilisation
If [M:SUD2]NEWLTIDAT(nolign-1) <> [31/12/2999]
   If [M:SUD2]NEWLTIDAT(nolign-1)  > [M:SUD2]DLUDAT(nolign-1)
