Subprog AS_DLU(VALEUR)
Variable Decimal VALEUR
If [F:ITM]ITMREF  <> [M:SUD2]ITMREF(nolign-1)
    Read [ITM]ITM0=  [M:SUD2]ITMREF(nolign-1)
    If fstat : Raz [ITM] : Endif
Endif
# si pas de peremption
If !find([F:ITM]EXYMGTCOD,2,5,6) : mkstat = 2 : Endif      # hcb dlu

End

Subprog AM_DLU(VALEUR)
Variable Decimal VALEUR
Local    Integer  WCOD
Local    Date     WREF : WREF = [M:SUD2]REFPER(nolign-1)
Local    Integer  WSHL : WSHL = [M:SUD2]SHL   (nolign-1)
Local    Date     WPER
Local    Integer  WUOM : WUOM = [M:SUD2]SHLUOM(nolign-1)
Local    Decimal  WDLU : WDLU = VALEUR
Local    Date     WEXY : WEXY = [M:SUD2]SHLDAT(nolign-1)
Local    Integer  WLTI


If [F:ITM]ITMREF  <> [M:SUD2]ITMREF(nolign-1)
    Read [ITM]ITM0=  [M:SUD2]ITMREF(nolign-1)
    If fstat : Raz [ITM] : Endif
Endif
WCOD = [F:ITM]EXYMGTCOD

Call CALDLU(WCOD,WREF,WEXY,WDLU,"",WPER,WLTI) From STKLIB
[M:SUD2]DLUDAT      (nolign-1) = WPER
Affzo [M:SUD2]DLUDAT(nolign-1)
[M:SUD2]DLULTI      (nolign-1) = WLTI
Affzo [M:SUD2]DLULTI(nolign-1)

#       si date recontrole > date limite utilisation : date recontrole = date limite utilisation
If [M:SUD2]NEWLTIDAT(nolign-1) <> [31/12/2999]
   If [M:SUD2]NEWLTIDAT(nolign-1)  > [M:SUD2]DLUDAT(nolign-1)
      [M:SUD2]NEWLTIDAT(nolign-1)  = [M:SUD2]DLUDAT(nolign-1)
   Endif
Endif
Affzo [M:SUD2]NEWLTIDAT(nolign-1)

End

Subprog AS_DLUDAT(VALEUR)
Variable Date    VALEUR
If [F:ITM]ITMREF  <> [M:SUD2]ITMREF(nolign-1)
    Read [ITM]ITM0=  [M:SUD2]ITMREF(nolign-1)
    If fstat : Raz [ITM] : Endif
Endif
# si pas de peremption
If !find([F:ITM]EXYMGTCOD,2,5,6) : mkstat = 2 : Endif              # hcb dlu

End

Subprog AM_DLUDAT(VALEUR)
Variable Date    VALEUR
#       si date recontrole > date limite utilisation : date recontrole = date limite utilisation
If [M:SUD2]NEWLTIDAT(nolign-1) <> [31/12/2999]
   If [M:SUD2]NEWLTIDAT(nolign-1)  > VALEUR
      [M:SUD2]NEWLTIDAT(nolign-1)  = VALEUR
   Endif
Endif
Affzo [M:SUD2]NEWLTIDAT(nolign-1)
[M:SUD2]DLULTI(nolign-1) = nday(VALEUR) -nday([M:SUD2]REFPER(nolign-1))
Affzo [M:SUD2]DLULTI(nolign-1)

End

