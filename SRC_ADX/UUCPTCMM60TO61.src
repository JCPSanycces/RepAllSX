#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################
# UTICPTCMM60TO61 - Moulinette pour Engagements Multi-référentiel        #
#            Ajustement/correction des tables d'engagement               #
#            suite au passage en multi-référentiel                       #                     
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Correction GCOMMIT/GCOMMITD") From LECFIC

  Call MAJ_UTICPTCMM60TO61(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTICPTCMM60TO61(DOSSIER)
Value Char DOSSIER
Local Integer COMPTEUR

#---- Declaration des variable utilisé pour le réarrangement des données ----#
Local Integer STAT
Local Char MESSA(250)
Local Libelle LEDTYPANA,LEDTYPGEN
Local Char LEDORG(GLONLED),CURLEDORG(GLONCUR)
Local Char COAORG(GLONCOA),ACCORG(GLONGAC)
Local Decimal RATMLTORG,RATDIVORG,AMTLEDORG
Local Char DIEORG(GLONDIE)(0..8)
Local Char CCEORG(GLONCCE)(0..8)

Call ECR_TRACE("UTICPTCMM60TO61 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:CMM])  =0  Local File =DOSSIER+".GCOMMIT"   [CMM] : Endif
If clalev([F:CMD])  =0  Local File =DOSSIER+".GCOMMITD"  [CMD] : Endif
If clalev([F:GCM])  =0  Local File =DOSSIER+".GACM"      [GCM] : Endif
If clalev([F:CPY])  =0  Local File =DOSSIER+".COMPANY"   [CPY] : Endif
If clalev([F:LED])  =0  Local File =DOSSIER+".GLED"      [LED] : Endif

Raz COMPTEUR
Call DEBTRANS From GLOCK
Local Integer DOIT,J 
Trbegin [CMM],[CMD]
For [CMM]
 #A n'executer que sur les monoréf via DOIT
 DOIT=1
 J=0
 For I=0 To dim([F:CMM]LED)-1
  If [F:CMM]LED(I)<>"" : J+=1 : Endif
  If J>1 : DOIT=0 : Break : Endif   
 Next
 If DOIT & [F:CMM]LED(0)<>""  
   Readlock [CMM] Curr    
   If !fstat
    #Les donnés d'origine telles qu'elles sont, cad dire non classées dans GCOMMIT
    LEDORG    = [F:CMM]LED(0)
    RATMLTORG = [F:CMM]RATMLT(0)
    RATDIVORG = [F:CMM]RATDIV(0)    
    Call SETMAINREF([F:CMM]CPY,LEDTYPGEN,LEDTYPANA) From CPTDIV
    # Initialisation des globales en fonction de la société(site)
    # permet de récupérer toute les données liés aux référentiels flagués engagements
    # (types de référentiels, plans, axes )
    If LEDTYPANA>=1
      Gosub DECLARE_GLOBAL From SUBCMM
      Call INI_GLOBAL([F:CMM]CPY,STAT,MESSA) From SUBCMM
      
      For [CMD]CMD0 Where NUM=[F:CMM]NUM
       Readlock [CMD]CMD0 = [F:CMD]NUM;[F:CMD]LIN
       If !fstat
       #Les donnés d'origine telles qu'elles sont, cad dire non classées dans GCOMMITD
        COAORG = [F:CMD]COA(0)
        ACCORG = [F:CMD]ACC(0)
        CURLEDORG = [F:CMD]CURLED(0)
        AMTLEDORG = [F:CMD]AMTLED(0)
        #AXES ET SECTIONS
        For I=0 To 8
         DIEORG(I)=[F:CMD]DIE(I)
         CCEORG(I)=[F:CMD]CCE(I)
        Next
        # --- alimentation des champs et réécriture enreg
        Raz [F:CMD]CURLED,AMTLED,COA,ACC,DIE,CCE
        [F:CMD]COA(LEDTYPANA-1) = COAORG
        [F:CMD]ACC(LEDTYPANA-1) = ACCORG
        [F:CMD]LED(LEDTYPANA-1) = LEDORG
        [F:CMD]CURLED(LEDTYPANA-1) = CURLEDORG
        [F:CMD]AMTLED(LEDTYPANA-1) = AMTLEDORG  
        For I=0 To 8
         K= find(DIEORG(I),GENGAXE(1..max(20,GOPTCANA)))
         If K
          [F:CMD]DIE(K-1)=DIEORG(I)
          [F:CMD]CCE(K-1)=CCEORG(I)
         Endif
        Next    
        Rewrite [F:CMD]
        If !fstat COMPTEUR += 1 Endif
       Endif
      Next
      Raz [F:CMM]LED,RATMLT,RATDIV
      [F:CMM]LED(LEDTYPANA-1)    = LEDORG
      [F:CMM]CURLED(LEDTYPANA-1) = CURLEDORG
      [F:CMM]RATMLT(LEDTYPANA-1) = RATMLTORG
      [F:CMM]RATDIV(LEDTYPANA-1) = RATDIVORG
      # --- alimentation des champs et réécriture enreg
      Rewrite [F:CMM]
      If !fstat COMPTEUR += 1 Endif
    Endif
   Endif
 Endif
Next

Commit

Close Local File [CMM],[CMD]

Call ECR_TRACE("UTICPTCMM60TO61 : "+num$(COMPTEUR)+" records processed",0) From GESECRAN

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif                                 : # N= no module
If filinfo(filpath("FIL","GCOMMIT","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= code table  
Call MAJ_UTICPTCMM60TO61(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If [F:ADS]MODULE(2)<>2 : End : Endif                                 : # N= no module
If filinfo(filpath("FIL","GCOMMIT","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= code table  
Call MAJ_UTICPTCMM60TO61(APPLI)
End
