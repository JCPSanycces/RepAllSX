###################################################################
# sélection des postes de charge                                  #
###################################################################
$S_WST
Local Char FCY        : FCY = PARAM(1)
Local Char WCENTER    : WCENTER = PARAM(2)
Local Integer WWSTTYP : WWSTTYP = val(PARAM(3))
If clalev ([F:ATZ])=0 : Local File ATABZON    : Endif
If clalev ([F:MWS])=0 : Local File WORKSTATIO : Endif
If clalev ([F:AXX])=0 : Local File ATEXTRA    : Endif        # 03.09 mm - libellé traduisible
Local Char CODFIC     : CODFIC = "WORKSTATIO"

Link [MWS] With [AXX]AXX0="WORKSTATIO";"WSTDESAXX";GLANGUE;[F:MWS]WST;[F:MWS]WCRFCY
&            As [LNK]
Default File [LNK]
# 10/08/10 bug 66640
Case WCENTER
    When "" : If ( WWSTTYP=2 |WWSTTYP=3 )
                 CRITERE = 'WCRFCY= "'+FCY+'" & WSTTYP = '+num$(WWSTTYP) # selection des postes MO ou ST
              Elsif FCY <> ""
                 CRITERE = 'WCRFCY= "'+FCY+'"'                    # selection de l'ENSEMBLE DES POSTES DU SITE
              Else
                 CRITERE = '1=1'                            # Tout
              Endif
    When Default :  CRITERE = 'WCRFCY = "'+FCY+'" & WCR = "'+WCENTER+'"'   #selection de l'ENSEMBLE DES POSTES DU CENTRE
Endcase


START ='WST'
ORDRE ='WST;WCRFCY'

TIT(0)= mess(12, 123, 1)
NBCOL = 0
NBCOL +=1 : COL(NBCOL)="WST"    : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="WCRFCY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="WCR"    : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="mess([F:MWS]WSTTYP,313,1)"
Call TEXTFIC(CODFIC , "WSTTYP", 1,TIT(NBCOL) ) From OBJDIV
NBCOL +=1 : COL(NBCOL)="[F:AXX]TEXTE" : Call TEXTFIC(CODFIC,"WSTDESAXX", 1, TIT(NBCOL) ) From OBJDIV

# FQ 63783 GA 04/2010 Pagination
DEFPAG = 1
Return

###################################################################
# sélection des postes de charge  avec récup des données          #
###################################################################
$S_WSTB
Local Char WPOSTE     : WPOSTE = PARAM(1)
Local Char FCY        : FCY = PARAM(2)
If clalev ([F:ATZ])=0 : Local File ATABZON    : Endif
