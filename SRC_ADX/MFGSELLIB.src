If clalev ([F:AXX])=0 : Local File ATEXTRA    : Endif        # 03.09 mm - libellé traduisible
Local Char CODFIC     : CODFIC = "WORKSTATIO"

Link [MWS] With [AXX]AXX0="WORKSTATIO";"WSTDESAXX";GLANGUE;[F:MWS]WST;[F:MWS]WCRFCY
&            As [LNK]
Default File [LNK]

CRITERE = '1=1'                            # Tout

START ='WST'
ORDRE ='WST;WCRFCY'

TIT(0)= mess(12, 123, 1)
NBCOL = 0
NBCOL +=1 : COL(NBCOL)="WST"    : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="WCRFCY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="WCR"    : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="mess([F:MWS]WSTTYP,313,1)"
Call TEXTFIC(CODFIC , "WSTTYP", 1,TIT(NBCOL) ) From OBJDIV
NBCOL +=1 : COL(NBCOL)="[F:AXX]TEXTE" : Call TEXTFIC(CODFIC,"WSTDESAXX", 1, TIT(NBCOL) ) From OBJDIV

# FQ 63783 GA 04/2010 Pagination
DEFPAG = 1
Return

###################################################################
