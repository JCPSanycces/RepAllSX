ORDRE ='WST;WCRFCY'

NBCOL = 0
NBCOL +=1 : COL(NBCOL)="WCR"    : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="WCRFCY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="WST"    : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="mess([F:MWS]WSTTYP,313,1)"
Call TEXTFIC(CODFIC , "WSTTYP", 1,TIT(NBCOL) ) From OBJDIV
NBCOL +=1 : COL(NBCOL)="[F:AXX]TEXTE" : Call TEXTFIC(CODFIC,"WSTDESAXX", 1, TIT(NBCOL) ) From OBJDIV

# FQ 63783 GA 04/2010 Pagination
DEFPAG = 1
Return
###################################################################
# sélection des N° de suivi                                       #
###################################################################
$S_MFGTNUM
If clalev ([F:ATZ])=0 : Local File ATABZON    : Endif
If clalev ([F:MTK])=0 : Local File MFGHEADTRK : Endif

Local Char FCY         : FCY = PARAM(1)
Local Integer OPEFLG   : OPEFLG = val(PARAM(2))
Local Integer MATFLG   : MATFLG = val(PARAM(3))
Local Char CODFIC  : CODFIC = "MFGHEADTRK"
Default File [MTK]
# 10/08/10 bug 66640
If OPEFLG = 2
    CRITERE = 'MFGFCY = "'+FCY+'" & OPETRKFLG = '+num$(OPEFLG)
Elsif MATFLG = 2
    CRITERE = 'MFGFCY = "'+FCY+'" & MATTRKFLG = '+num$(MATFLG)
Else
    CRITERE = 'MFGFCY = "'+FCY+'" & ITMTRKFLG=2'
Endif

START='MFGTRKNUM'
ORDRE='MFGTRKNUM'

TIT(0)= mess(12, 123, 1)
NBCOL = 0
NBCOL +=1 : COL(NBCOL)="MFGTRKNUM" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="MFGFCY"    : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="MFGNUM"    : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="MFGTRKDAT" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="CREUSR"    : Gosub TEXTE

# FQ 63783 GA 04/2010 Pagination
DEFPAG = 1
Return

# CATUA X3-68685.sn Additional filter to only display container in WO
$S_CTNMFG
If clalev ([F:MFMC])=0        : Local File MFGMAT   [MFMC]    : Endif

Local Char WMFGNUM(GLONVCR) : WMFGNUM = PARAM(1)
Local Integer NBCTN         : NBCTN = 0
Local Char WCTN(8)(0..100)

Filter [F:MFMC] Where MFGNUM = WMFGNUM & CTN<>""
For [F:MFMC]MFM0
  If NBCTN<>0
    If find([F:MFMC]CTN,WCTN(0..NBCTN-1)) : Goto NEXT_CTN : Endif
  Endif
  WCTN(NBCTN) = [F:MFMC]CTN
  NBCTN += 1
$NEXT_CTN
Next
Filter [F:MFMC]

CRITERE='find(CTN, WCTN)'

OBJET="CTN"
Return
# CATUA X3-68685.en

###################################################################
# Filtre pour sélection des alt de gamme                          #
###################################################################
$S_ROUNUM
If clalev ([F:ATZ])=0 : Local File ATABZON    : Endif
If clalev ([F:TRO])=0 : Local File TABROUALT  : Endif
If clalev ([F:ROH])=0 : Local File ROUTING : Endif

Local Char WFCY(GLONFCY): WFCY = PARAM(1)
Local Char WITM(GLONITM): WITM = PARAM(2)
Local Integer WNIVEAU   : WNIVEAU= val(PARAM(3))
Local Integer NBTRO     : NBTRO=0
Local Char CODFIC       : CODFIC ="ROUTING"

#   sélectionner les alt. de gammes compatibles avec site de prod
Filter [TRO] Where ([F:TRO]FCY=WFCY  | [F:TRO]FCY="") & [F:TRO]MFGUSE=2
For [TRO]TRO0
    GROUALT (NBTRO) = [F:TRO]ROUALT
    NBTRO += 1
Next
Filter [TRO]

Default File [ROH]

# FQ 64642 & 65276 GA 06/2010 pb sur Page suivante
#CRITERE='find(ROUALT, GROUALT) & ITMREF=WITM  & FCY=WFCY'
CRITERE='find(ROUALT, GROUALT) & ITMREF="'+WITM+'"  & FCY="'+WFCY+'"'
If WNIVEAU =1    : START ='ITMREF'
Elsif WNIVEAU =2 : START ='ROUALT'
Endif

ORDRE ='ROUALT'

# FQ 63783 GA 04/2010 Pagination
DEFPAG = 1

#Goto $GAMME
TIT(0) = mess(12, 123, 1)
NBCOL = 0
#---------
# PE si GPE = 1 autres colonnes qu'en standard - GH 08/11/12 FQ 85258
GPE = 0
GPOINT = "ADDCOLTRO"
Gosub  ENTREE From EXEFNC
If GPE : Return : Endif
#---------
NBCOL += 1 : COL(NBCOL)="ITMREF"   : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="ROUALT"   : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="FCY"      : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="ROUSTRDAT": Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="ROUENDDAT": Gosub TEXTE
Return

###################################################################
# sélection des n° OF                                             #
###################################################################
$S_MFGNUM
Local Integer WMFGSTA : WMFGSTA = val(PARAM(2))

CRITERE = '[MFG]MFGFCY="'+PARAM(1)+'"'
If WMFGSTA <>0
  # FQ 64642 GA 05/2010
  #CRITERE = 'MFGFCY = WFCY & MFGSTA< WMFGSTA'
   CRITERE-= '& [MFG]MFGSTA='+num$(WMFGSTA)
Endif

START='[MFG]MFGNUM'
ORDRE='[MFG]MFGNUM'
OBJET='SELOF'
Return

###################################################################
# sélection des n° OF ferme /planif. / sugg.                      #
###################################################################
$S_MFGNUM2
If clalev ([F:ATZ])=0 : Local File ATABZON    : Endif
If clalev ([F:ORD])=0 : Local File ORDERS    : Endif

Local Char FCY        : FCY = PARAM(1)
Local Integer WOSFLG  : WOSFLG= val(PARAM(2))
Local Integer WOPFLG  : WOPFLG= val(PARAM(3))
Local Integer WOFFLG  : WOFFLG= val(PARAM(4))
Local Char    CODFIC : CODFIC = "ORDERS"
Local Integer I:  I=0
Default File [ORD]
# 10/08/10 bug 66640
CRITERE = 'STOFCY = "'+FCY+'"'
CRITERE +='&('
If WOSFLG = 2
    CRITERE+='WIPSTA=3'
    I+=1
Endif
If WOPFLG = 2
    If I<>0 : CRITERE+='|' : Endif
    CRITERE+='WIPSTA=2'
    I+=1
Endif

If WOFFLG = 2
    If I<>0 : CRITERE+='|' : Endif
    CRITERE+='WIPSTA=1'
    I+=1
Endif
CRITERE +=')&'

CRITERE+='WIPTYP=5'

START='VCRNUM'
ORDRE='WIPTYP;WIPNUM;ITMREF'

TIT(0)= mess(12, 123, 1)
NBCOL = 0
NBCOL +=1 : COL(NBCOL)="mess([F:ORD]WIPSTA,317,1)"
 Call TEXTFIC(CODFIC , "WIPSTA", 1,TIT(NBCOL) ) From OBJDIV
NBCOL +=1 : COL(NBCOL)="VCRNUM" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ORIFCY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="STOFCY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ITMREF" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ENDDAT" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="RMNEXTQTY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="BPRNUM" : Gosub TEXTE

# FQ 63783 GA 04/2010 Pagination
DEFPAG = 1
Return

###################################################################
# sélection des n° OF planif. / sugg.                             #
###################################################################
$S_MFGNUM3
If clalev ([F:ATZ])=0 : Local File ATABZON    : Endif
If clalev ([F:ORD])=0 : Local File ORDERS    : Endif

Local Char FCY        : FCY = PARAM(1)
Local Integer WAVSTA  : WAVSTA= val(PARAM(2))
Local Char    CODFIC  : CODFIC = "ORDERS"
Default File [ORD]
# 10/08/10 bug 66640
CRITERE = 'STOFCY = "'+FCY+'"'
If WAVSTA  =1
   CRITERE+='& WIPSTA =3'
Elsif WAVSTA  =2
   CRITERE+='& WIPSTA =2'
Endif
CRITERE+='& WIPTYP=5'

START='VCRNUM'
ORDRE='WIPTYP;WIPNUM;ITMREF'

TIT(0)= mess(12, 123, 1)
NBCOL = 0
NBCOL +=1 : COL(NBCOL)="mess([F:ORD]WIPSTA,317,1)"
 Call TEXTFIC(CODFIC , "WIPSTA", 1,TIT(NBCOL) ) From OBJDIV
NBCOL +=1 : COL(NBCOL)="VCRNUM" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ORIFCY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="STOFCY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ITMREF" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ENDDAT" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="RMNEXTQTY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="BPRNUM" : Gosub TEXTE

# FQ 63783 GA 04/2010 Pagination
DEFPAG = 1
Return

###################################################################
# Selection of WOs for FDMA calulation                            #
###################################################################
$S_MFGNUM4
Local Integer WMFGSTA : WMFGSTA = val(PARAM(2))

CRITERE = '[MFG]MFGFCY="'+PARAM(1)+'"'
If WMFGSTA = 1
    CRITERE -= '& [MFG]OPTFLG=2 & [MFG]MFGTRKFLG<=3'
Elsif WMFGSTA = 2
    CRITERE -= '& (([MFG]OPTFLG=2 | [MFG]SCDFLG=4) & [MFG]MFGTRKFLG<=3)'
Elsif WMFGSTA = 3
    CRITERE -= '& (([MFG]OPTFLG=2 | [MFG]SCDFLG=4) & [MFG]MFGTRKFLG<=4)'
Endif

START='[MFG]MFGNUM'
ORDRE='[MFG]MFGNUM'
OBJET='SELOF'
Return

###################################################################
# sélection des n° OF  depuis les suivis de fabrication           #
###################################################################
$S_MTKMFG
Local Integer WMFGSTA   : WMFGSTA   = val(PARAM(2))
Local Integer WOKDOSFAB : WOKDOSFAB = val(PARAM(3))
Local Integer WMFGMOD   : WMFGMOD   = val(PARAM(4))
Local Integer WSUSFLG   : WSUSFLG   = val(PARAM(5))

CRITERE = '[MFG]MFGFCY="'+PARAM(1)+'"'
If WMFGSTA <>0
   CRITERE-= '& [MFG]MFGSTA='+num$(WMFGSTA)
Endif
If val(PARAM(3)) = 2
   If GDOSFAB = 2 : CRITERE-='& find([MFG]MFGTRKFLG,1,2,6)=0'
   Else           : CRITERE-='& find([MFG]MFGTRKFLG,2,6)=0'
   Endif
Endif
If WSUSFLG<>0
   CRITERE-= '& [MFG]SUSFLG<>'+num$(WSUSFLG)
Endif
# si MFGMOD n'est pas passé en paramètre (suivi standard) on définit le filtre selon la transaction de suivi utilisée
# on ne vient ici que lors du suivi standard donc dans les autres cas on passe 4 dans WMFGMOD pour prendre tous les OF
If WMFGMOD <> 0
   CRITERE-= '& [MFG]MFGMOD<>'+num$(WMFGMOD)
Elsif [F:MTS]OPETRKFLG = 1
   CRITERE-= '& [MFG]MFGMOD<>3'
Elsif [F:MTS]MATTRKFLG = 1
   CRITERE-= '& [MFG]MFGMOD<>2'
Endif

START='[MFG]MFGNUM'
ORDRE='[MFG]MFGNUM'
OBJET='SELOF'
Return

$CHX_MTKMFG
If GVTMOD<>0  # CCC (2009-10-29) Bug 55090 en VT, on supprime la colonne MFGFCY
   I=find("[F:MFG]MFGFCY",COL(1..NBCOL))
   If I<>0 : Dela I COL,FMTCOL,TIT : NBCOL-=1 : Endif
Endif
Return

###################################################################
# sélection des n° OF  depuis les suivis de fabrication           #
###################################################################
$S_MFCMFG
Local Integer WMFGSTA        : WMFGSTA    = val(PARAM(2))
Local Char    WMFGTRKFLG(10) : WMFGTRKFLG = PARAM(3)
Local Integer WSUSFLG        : WSUSFLG    = val(PARAM(4))

CRITERE = '[MFG]MFGFCY="'+ PARAM(1)+'"'
If WMFGSTA <>0
   CRITERE-= '& [MFG]MFGSTA = '+num$(WMFGSTA)
Endif
If WMFGTRKFLG<>""
    If left$(WMFGTRKFLG,1)<>","
        WMFGTRKFLG = ","+WMFGTRKFLG
    Endif
    CRITERE-= '& find([MFG]MFGTRKFLG'+WMFGTRKFLG+')'
Endif
If WSUSFLG<>0
   CRITERE-= '& [MFG]SUSFLG<>'+num$(WSUSFLG)
Endif

START ='[MFG]MFGNUM'
ORDRE ='[MFG]MFGNUM'
OBJET='SELOF'
Return

###################################################################
# sélection des n° OF  depuis le plan de pesée                    #
###################################################################
$S_WEIMFG
CRITERE = '[MFG]MFGFCY="'+PARAM(1)+'" & [MFG]MFGSTA=1 & [MFG]MFGMOD<>3 & [MFG]WGGFLG>1 & [MFG]WGGFLG<4 & [MFG]WGGSTA<2'
START='[MFG]MFGNUM'
ORDRE='[MFG]MFGNUM'
OBJET='SELOF'
Return

###################################################################
# sélection des n° OF  depuis la pesée                            #
###################################################################
$S_SCAMFG
CRITERE = '[MFG]MFGFCY="'+PARAM(1)+'" & [MFG]WGGFLG=3'
START='[MFG]MFGNUM'
ORDRE='[MFG]MFGNUM'
OBJET='SELOF'
Return

#####################################################################################
# Sélection n° pesée (N° de suivi) depuis la Réconciliation - DT-18/06/2010         #
#####################################################################################
$S_SCAMTK
If clalev ([F:ATZ])=0 : Local File ATABZON    : Endif
If clalev ([F:WGG])=0 : Local File WEIGHING    : Endif

Local Char    WFCY          : WFCY      = PARAM(1)
Local Char    WMFGNUM       : WMFGNUM   = PARAM(2)
Local Integer WBOMOPE       : WBOMOPE   = val(PARAM(3))
Local Integer WFUNCTION     : WFUNCTION = val(PARAM(4))
Local Char    WCTN          : WCTN      = PARAM(5) # CATUA X3-68685 Add container fields in reconciliation
Local Char    CODFIC        : CODFIC    = "WEIGHING"
Default File [WGG]

CRITERE  = 'FCY = "'+WFCY+'"'
CRITERE += '& MFGNUM = "'+WMFGNUM+'"'

#CATUA X3-68685.sn
#Add container fields in reconciliation
Case GRECONCIL
  When 2 # Reconcile by phase
    If WBOMOPE<>0
      CRITERE += '& BOMOPE ='+num$(WBOMOPE)
    Endif
  When 3 # Reconcile by container
    CRITERE += '& CTN = "'+WCTN+'"'
Endcase
#CATUA X3-68685.en

Case WFUNCTION
  When 1: # réconciliation
          CRITERE += '& WEIFLG<>4 & WEIFLG<>5 & CCLDAT=[0/0/0] & (PKC=2 |PKC=4|PKC=6)& RCLCOD=1'
  When 2: # engagement
          CRITERE += '& WEIFLG<>4 & WEIFLG<>5 & CCLDAT=[0/0/0] & (PKC=2 |PKC=4|PKC=6)& ENGCOD=1'
  When 3 : # annulation réconciliation
          CRITERE += '& WEIFLG<>4 & WEIFLG<>5 & CCLDAT=[0/0/0] & (PKC=2 |PKC=4|PKC=6)& RCLCOD=2 & RCLDAT<>[0/0/0]'
  When 4 : # annulation engagement
          CRITERE += '& WEIFLG<>4 & WEIFLG<>5 & CCLDAT=[0/0/0] & (PKC=2 |PKC=4|PKC=6)& ENGCOD=2 & ENGDAT<>[0/0/0]'
Endcase

START='MFGTRKNUM'
ORDRE ='MFGTRKNUM'

# GA 29/12/08 : Affectation de DEFPAG pour permettre la pagination
DEFPAG = 1

TIT(0)= mess(42,2324,1)  :# "Choix Pesée"
NBCOL = 0

NBCOL +=1 : COL(NBCOL)="MFGTRKNUM" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="MFGNUM"    : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="BOMOPE"    : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ITMREF"    : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="LOT"       : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="WEIWEI"    : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="WEI"       : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="WEU"       : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="mess([F:WGG]RCLCOD,1,1)"
 Call TEXTFIC(CODFIC , "RCLCOD", 1,TIT(NBCOL) ) From OBJDIV
NBCOL +=1 : COL(NBCOL)="mess([F:WGG]WEIFLG,2344,1)"
 Call TEXTFIC(CODFIC , "WEIFLG", 1,TIT(NBCOL) ) From OBJDIV
NBCOL +=1 : COL(NBCOL)="mess([F:WGG]WGGOPT,2335,1)"
 Call TEXTFIC(CODFIC , "WGGOPT", 1,TIT(NBCOL) ) From OBJDIV

# FQ 63783 GA 04/2010 Pagination
DEFPAG = 1
Return

#######################################################################
# SELSCAOPE : sélection d'une opération d'of de pesée - DT-23/08/2010 #
#######################################################################
$S_SCAOPE
Local Char    WFCY          : WFCY      = PARAM(1)
Local Char    WMFGNUM       : WMFGNUM   = PARAM(2)
Local Char     CODFIC

If clalev ([F:ATZ])=0 : Local File ATABZON    [ATZ] : Endif
If clalev ([F:MFO])=0 : Local File MFGOPE     [MFO] : Endif

Default File [MFO]
CODFIC ="MFGOPE"
START='OPENUM'
ORDRE='OPENUM'
DEFPAG = 1

CRITERE  = 'MFGNUM = "'+WMFGNUM+'"'
CRITERE += '& MFGFCY = "'+WFCY+'"'
TIT(0) = mess(55,2324, 1)

NBCOL = 0
NBCOL +=1  : COL(NBCOL)="OPENUM" : Gosub TEXTE
NBCOL +=1  : COL(NBCOL)="MFGNUM" : Gosub TEXTE
NBCOL +=1  : COL(NBCOL)="MFGFCY" : Gosub TEXTE

DEFPAG = 1
Return

#####################################################################################
# Sélection articles pesés - DT-23/08/2010                                          #
#####################################################################################
$S_SCAITM
If clalev ([F:ATZ])=0 : Local File ATABZON    : Endif
If clalev ([F:WGG])=0 : Local File WEIGHING    : Endif

Local Char    WFCY          : WFCY      = PARAM(1)
Local Char    WMFGNUM       : WMFGNUM   = PARAM(2)
Local Integer WBOMOPE       : WBOMOPE   = val(PARAM(3))
Local Char CODFIC           : CODFIC    = "WEIGHING"
Default File [WGG]

CRITERE  = 'FCY = "'+WFCY+'"'
CRITERE += '& MFGNUM = "'+WMFGNUM+'"'
# 10/08/10 bug 66640
If WBOMOPE <>0
    CRITERE += '& BOMOPE ='+num$(WBOMOPE)
Endif

CRITERE += '& WEIFLG<>4 & WEIFLG<>5 & CCLDAT=[0/0/0] & (PKC=2 |PKC=4|PKC=6)'


START='ITMREF'
ORDRE ='ITMREF'

# GA 29/12/08 : Affectation de DEFPAG pour permettre la pagination
DEFPAG = 1

TIT(0)= mess(56,2324,1)  :# "Choix articles Pesés"
NBCOL = 0

NBCOL +=1 : COL(NBCOL)="ITMREF"    : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="MFGNUM"    : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="BOMOPE"    : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="MFGTRKNUM" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="LOT"       : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="WEIWEI"    : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="WEI"       : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="WEU"       : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="mess([F:WGG]RCLCOD,1,1)"
 Call TEXTFIC(CODFIC , "RCLCOD", 1,TIT(NBCOL) ) From OBJDIV
NBCOL +=1 : COL(NBCOL)="mess([F:WGG]WEIFLG,2344,1)"
 Call TEXTFIC(CODFIC , "WEIFLG", 1,TIT(NBCOL) ) From OBJDIV
NBCOL +=1 : COL(NBCOL)="mess([F:WGG]WGGOPT,2335,1)"
 Call TEXTFIC(CODFIC , "WGGOPT", 1,TIT(NBCOL) ) From OBJDIV

# FQ 63783 GA 04/2010 Pagination
DEFPAG = 1
Return

###################################################################
#  SELBPCNUM : sélection destinataires                            #
###################################################################
$S_BPCNUM
If clalev ([F:ATZ])=0 : Local File ATABZON : Endif
If clalev ([F:FCY])=0 : Local File FACILITY: Endif
If clalev ([F:BPR])=0 : Local File BPARTNER: Endif

Global Char GBPRSEL(30)
Local Integer WTYP : WTYP=val(PARAM(1))

Case WTYP
    When 1 :
            OBJET="FCY"
            ORDRE ='FCY'
            OPTIONS = 'D'
    When 2 :
            GBPRSEL= "BPCFLG=2"
            OBJET="BPR"
            ORDRE = 'BPRNUM'
            OPTIONS = 'B'
Endcase

Return

###################################################################
#  SELBPCNUMC : sélection destinataires client                     #
###################################################################
$S_BPCNUMC
If clalev ([F:ATZ])=0 : Local File ATABZON : Endif
If clalev ([F:BPR])=0 : Local File BPARTNER: Endif

Global Char GBPRSEL(30)


GBPRSEL= "BPCFLG=2"
OBJET="BPR"
ORDRE = 'BPRNUM'
OPTIONS = 'B'


Return

###################################################################
#  SELBPCNUMF : sélection destinataires site                      #
###################################################################
$S_BPCNUMF
If clalev ([F:ATZ])=0 : Local File ATABZON : Endif
If clalev ([F:FCY])=0 : Local File FACILITY: Endif

OBJET="FCY"
ORDRE ='FCY'
OPTIONS = 'D'

Return

###################################################################
# sélection des sections de valorisation                          #
###################################################################
$S_VLTCCE
If clalev ([F:ATZ])=0 : Local File ATABZON    : Endif
If clalev ([F:MWC])=0 : Local File WORKCOST   : Endif
If clalev ([F:AXX])=0 : Local File ATEXTRA    : Endif

Local Char WFCY    : WFCY   = PARAM(1)
Local Char CODFIC  : CODFIC = "WORKCOST"
Link [MWC] With [AXX]AXX0="WORKCOST";"WCTDESAXX";GLANGUE;[F:MWC]VLTCCE;[F:MWC]VLTFCY
&            As [LNK]
Default File [LNK]


CRITERE = 'VLTFCY="'+WFCY+'"'
START='VLTCCE'
ORDRE='VLTCCE;VLTFCY'
# GA 29/12/08 : Affectation de DEFPAG pour permettre la pagination
DEFPAG = 1

TIT(0)= mess(12, 123, 1)
NBCOL = 0
NBCOL +=1 : COL(NBCOL)="[F:MWC]VLTCCE" : Call TEXTFIC(CODFIC, "VLTCCE", 1, TIT(NBCOL) ) From OBJDIV
NBCOL +=1 : COL(NBCOL)="[F:MWC]VLTFCY" : Call TEXTFIC(CODFIC, "VLTFCY", 1, TIT(NBCOL) ) From OBJDIV
NBCOL +=1 : COL(NBCOL)="[F:AXX]TEXTE" : Call TEXTFIC(CODFIC, "WCTDESAXX", 1, TIT(NBCOL) ) From OBJDIV

Return

###################################################################
# sélection des emplacements à rangement illimité                 #
###################################################################
$S_STOLOC
If clalev ([F:ATZ])=0 : Local File ATABZON    : Endif
If clalev ([F:STC])=0 : Local File STOLOC     : Endif

Local Char WFCY   : WFCY   = PARAM(1)
Local Char CODFIC : CODFIC = "STOLOC"
Default File [STC]

CRITERE = 'STOFCY="'+WFCY+'"'
START='LOC'
ORDRE='STOFCY;LOC'
# GA 29/12/08 : Affectation de DEFPAG pour permettre la pagination
DEFPAG = 1

TIT(0)= mess(12, 123, 1)
NBCOL = 0
NBCOL +=1 : COL(NBCOL)="STOFCY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="LOC"    : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="LOCTYP" : Gosub TEXTE

# FQ 63783 GA 04/2010 Pagination
DEFPAG = 1
Return

###################################################################
# sélection des n° de commande                                    #
###################################################################
$S_POHNUM
If clalev ([F:ATZ])=0 : Local File ATABZON    : Endif
If clalev ([F:POQ])=0 : Local File PORDERQ    : Endif
If clalev ([F:ITM])=0 : Local File ITMMASTER  : Endif


Link  [POQ] With [ITM]ITM0=ITMREF As [NEW] Where [F:ITM]SCSFLG=2 Order By Key CLE=[F:POQ]POHNUM
Local Char CODFIC : CODFIC = "PORDERQ"
Local Char WBPSNUM1 : WBPSNUM1 = PARAM(1)
Local Char WBPSNUM2 : WBPSNUM2 = PARAM(2)
Local Date WORDDAT1 : WORDDAT1 = PARAM(3)
Local Date WORDDAT2 : WORDDAT2 = PARAM(4)

Default File [NEW]


CRITERE="1=1"
If WBPSNUM1=WBPSNUM2 & WBPSNUM1<>""    # un seul fournisseur
   CRITERE+='& [F:POQ]BPSNUM="'+WBPSNUM1+'"'
Else
   If WBPSNUM1<>""
      CRITERE+='& [F:POQ]BPSNUM>="'+WBPSNUM1+'"'
   Endif
   If WBPSNUM2<>""
      CRITERE+='& [F:POQ]BPSNUM<="'+WBPSNUM2+'"'
   Endif
Endif
# FQ 66354 GA 07/2010 incompatibilité de type CRITERE, ajout du format sur les dates
If WORDDAT1 <>[0/0/0]    # dates de l'intervalle
   CRITERE+=' & [F:POQ]ORDDAT>=['+format$(GFMD,WORDDAT1)+']'
Endif
If WORDDAT2 <>[0/0/0]    # dates de l'intervalle
   CRITERE+=' & [F:POQ]ORDDAT<=['+format$(GFMD,WORDDAT2)+']'
Endif

START = 'POHNUM'
ORDRE = 'POHNUM;POPLIN;POQSEQ'

TIT(0)= mess(12, 123, 1)
NBCOL = 0
NBCOL +=1 : COL(NBCOL)="POHNUM" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ITMREF" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="BPSNUM" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ORDDAT" : Gosub TEXTE

# GA 29/12/08 : Affectation de DEFPAG pour permettre la pagination
DEFPAG = 1
Return

###################################################################
# sélection pièce                                                 #
###################################################################
$S_VCRNUM
If find(GBOITE,"DAUTMTO","DDESMTO") & [M]FLGSEL=0 : OK=0 : Return : Endif

If clalev ([F:ATZ])=0 : Local File ATABZON    : Endif
If clalev ([F:ORD])=0 : Local File ORDERS     : Endif
If clalev ([F:ITM])=0 : Local File ITMMASTER  : Endif   # FQ 63043

Local Integer WTYP : WTYP = val(PARAM(1))
Local Integer WSTA : WSTA = val(PARAM(2))
Local Char    WFCY(GLONFCY) : WFCY = PARAM(3)
Local Char    WFILX(250)
If PARAM(4) <> "" :  WFILX = PARAM(4) : Else : WFILX = "1=1" : Endif
Local Char    CODFIC : CODFIC = "ORDERS"
Local Integer NBCR

NBCR = 0
If WFCY <> ""    :   CRITERE = 'STOFCY="' + WFCY +'"'   : NBCR += 1 : Endif
If WTYP <> 0
    If NBCR > 0 : CRITERE += '&' : Endif
    CRITERE += 'WIPTYP='+num$(WTYP)
    NBCR += 1
Endif
If WSTA <> 0
    If NBCR > 0 : CRITERE += '&' : Endif
    CRITERE += 'WIPSTA='+num$(WSTA)
Endif
If CRITERE="" : CRITERE="1=1" : Endif : # GH 07/08/13 bug 91721

Link [ORD] With [ITM]ITM0=[F:ORD]ITMREF As [LNK]
&          Where evalue(CRITERE) & evalue(WFILX)
&          Order By Key ORD0

Default File [LNK]
START='VCRNUM'
# GA 29/12/08 : Affectation de DEFPAG pour permettre la pagination
DEFPAG = 1

TIT(0)= mess(12, 123, 1)
NBCOL = 0
NBCOL +=1 : COL(NBCOL)="mess([F:ORD]WIPTYP,341,1)+mess([F:ORD]WIPSTA,342,1)"
Call TEXTFIC(CODFIC , "WIPTYP", 1,TIT(NBCOL) ) From OBJDIV
NBCOL +=1 : COL(NBCOL)="mess([F:ORD]WIPSTA,317,1)"
Call TEXTFIC(CODFIC , "WIPSTA", 1,TIT(NBCOL) ) From OBJDIV
NBCOL +=1 : COL(NBCOL)="VCRNUM" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ORIFCY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="STOFCY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ITMREF" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ENDDAT" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="RMNEXTQTY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="BPRNUM" : Gosub TEXTE
SIZLIG = 90
SIZCOL = 340

# FQ 63783 GA 04/2010 Pagination
DEFPAG = 1
Return

###################################################################
$FIN_VCRNUM
Filter [ORD]
If mkstat=2 : Return : Endif
Case GBOITE
 When "DAUTMTO","DDESMTO" : # Affectation, Désaffectation
                    VALEUR                    = [F:ORD]VCRNUM
                    If (func CBNLIB.ISDEM([F:ORD]WIPTYP))
                      [M]DEMTYP               = [F:ORD]VCRTYP
                      [M]DEMLIN               = [F:ORD]VCRLIN
                      [M]DEMSEQ               = [F:ORD]VCRSEQ
                      [M]DEMWIP               = [F:ORD]WIPTYP
                      [M]DEMITM               = [F:ORD]ITMREF
                     Else
                      [M]RESSTYP              = [F:ORD]VCRTYP
                      [M]RESSLIN              = [F:ORD]VCRLIN
                      [M]RESSSEQ              = [F:ORD]VCRSEQ
                      [M]RESSWIP              = [F:ORD]WIPTYP
                      [M]RESSITM              = [F:ORD]ITMREF
                     Endif
 Return
Endcase
Case GFONCTION
  When "GESMFG":     [M:MFG1]VCRTYPORI(nolign-1) = [F:ORD]VCRTYP
                     [M:MFG1]VCRLINORI(nolign-1) = [F:ORD]VCRLIN
                     [M:MFG1]VCRSEQORI(nolign-1) = [F:ORD]VCRSEQ

  When "MULTIWOX":   [M]VCRTYPORI                = [F:ORD]VCRTYP
                     [M]VCRLINORI                = [F:ORD]VCRLIN
                     [M]VCRSEQORI                = [F:ORD]VCRSEQ
Endcase
Return

###################################################################
# sélection pièce origine                   # FQ 58982 GA 10/2009 #
###################################################################
$S_VCRORI
If clalev ([F:ATZ])=0 : Local File ATABZON    : Endif
If clalev ([F:ORD])=0 : Local File ORDERS     : Endif

Local Integer WTYP : WTYP = val(PARAM(1))
Local Integer WSTA : WSTA = val(PARAM(2))
Local Char    WFCY(GLONFCY) : WFCY = PARAM(3)
Local Char    CODFIC : CODFIC = "ORDERS"
Local Integer NBCR
Default File [ORD]

NBCR = 0
If WFCY <> ""
   # FQ 64642 & 65276 GA 06/2010 pb sur Page suivante
   #CRITERE = 'STOFCY=WFCY'
   CRITERE = 'STOFCY="'+WFCY+'"'
   NBCR += 1
Endif
# 10/08/10 bug 66640
If WTYP <> 0
    If NBCR > 0 : CRITERE += '&' : Endif
    CRITERE += 'WIPTYP='+num$(WTYP)
    NBCR += 1
Endif
If WSTA <> 0
    If NBCR > 0 : CRITERE += '&' : Endif
    CRITERE += 'WIPSTA='+num$(WSTA)
Endif

If NBCR > 0 : CRITERE += '&' : Endif
CRITERE += 'VCRNUMORI<>""'

START='VCRNUMORI'
ORDRE='WIPTYP;WIPNUM;ITMREF'

TIT(0)= mess(12, 123, 1)
NBCOL = 0
NBCOL +=1 : COL(NBCOL)="mess([F:ORD]WIPSTA,317,1)"
 Call TEXTFIC(CODFIC , "WIPSTA", 1,TIT(NBCOL) ) From OBJDIV
NBCOL +=1 : COL(NBCOL)="VCRNUMORI" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ORIFCY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="STOFCY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ITMREF" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ENDDAT" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="RMNEXTQTY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="BPRNUM" : Gosub TEXTE
SIZLIG = 90
SIZCOL = 330
Return

###################################################################
$FIN_VCRORI
Filter [ORD]
Return

