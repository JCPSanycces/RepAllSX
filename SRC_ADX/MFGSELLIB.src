#<AdxTL>@(#)9.0.0.0 $Revision$
#                                                                 #
#        traitement de sélection dans la GP                       #
#                                                                 #
###################################################################
# Actions :                                                       #
#                                                                 #
#  SELGAM   : sélection des différentes gammes associées à une    #
#  alternative (de gamme)                                         #
#  SELGAM2   : sélection des gammes associées à des OF fermes     #
#  SELGAM3   : sélection d'OF dont situation= en cours et soldés  #
#  SELOF     : sélection d'OF dont situation est au - en cours    #
#  SELTRO    : sélection des alternatives de gamme associées à    #
#              un site                                            #
#  SELITMBOH : sélection d'un article pour nomenclature           #
#  SELCPNMBM : sélection d'un composant d'OF ou de nomenclature   #
#  SELITMMBI2: sélection d'un article   d'OF ou nomenclature      #
#  SELOPEMBO : sélection d'une opération d'OF ou de gamme         #
#  SELTBO    : sélection des alternatives de nomenclature         #
#  SELTBOA   : sélection des alternatives de nomenclature         #
#  SELWCR    : sélection des centres de charge                    #
#  SELMAKFCY : sélection des sites de production                  #
#  SELSTDOPE : sélection des opérations std                       #
#  SELSCOITM : sélection des articles ss-traitance                #
#  SELEMPNUM : sélection des matricules                           #
#  SELMSGNUM : sélection des messages                             #
#  SELSCANUM : sélection des messages d'erreur                    #
#  SWST      : sélection des postes de charge                     #
#  SWSTB     : sélection des postes de charge                     #
#  SWCR      : sélection des centres de charge d'un site donné    #
#  SELMFGTNUM: sélection des N° de suivi                          #
#  SELROUNUM : Filtre pour sélection des alt de gamme             #
#  SELMFGNUM : sélection des n° OF                                #
#  SELMFGNUM2: sélection des n° OF ferme /planif. / sugg.         #
#  SELMFGNUM3: sélection des n° OF planif. / sugg.                #
#  SELBPCNUM : sélection destinataires                            #
#  SELBPCNUMC: sélection destinataires client                     #
#  SELBPCNUMF: sélection destinataires site                       #
#  SELVLTCCE : sélection des sections de valorisation             #
#  SELSTOLOC : selection des emplacements à rangement illimité    #
#  SELPOHNUM : selection des n° de commande                       #
#  SELVCRNUM : sélection pièce                                    #
#  SELMTKMFG : sélection des n° OF en suivi de fabrication        #
#  SELMFCMFG : sélection des n° OF en suivi de fabrication        #
#  SELWEIMFG : sélection des n° OF en plan de pesée               #
#  SELSCAMFG : sélection des n° OF en pesée                       #
#  SELSCAMTK : sélection des n° de suivi de pesée                 # -DT-18/06/2010
#  SELSCAOPE : sélection d'une opération d'OF en pesée            # -DT-23/08/2010
#  SELSCAITM : sélection des articles de pesée                    # -DT-23/08/2010
#  SELRTPCOD : sélection des codes état                           #
#  SELMDL    : sélection des codes plan de travail                #
#  SELMRL    : sélection des regroupements                        #
#  SELMFL    : sélection des transaction OF auto                  #
#  SELMOL    : sélection des transactions de suivi des temps      #
#  SELMIL    : sélection des transactions de décl. de production  #
#  SELMML    : sélection des transactions de conso matière        #
#  SELMRE    : sélection des transactions de réintégration        #
#  SELMCL    : sélection des transactions de gestion des fic tec  #
#  SELOPEUOM : sélection d'une unité opération                    #
#  SELMFGNOM : sélection d'une nomenclature                       #
#  SELOPE1   : sélection d'une opération d'OF ou de gamme         #
#  SELITMMBI : sélection d'un article d'OF ou de nomenclature     #
#  SELCONT   : sélection d'un contrat Achat                       #
#  SELFCYPJA : sélection des sites présents dans [PJA]            #
#  SELOPEMBM : sélection d'une opé d'OF ou de nomenclature        #
#  SELLOTREI : sélection d'un lot à réintégrer                    #
#  SELSLOREI : sélection d'un sous-lot à réintégrer               #
#  SELMFGLIN : sélection d'une ligne OF                           #
#  SELRPLWST : sélection d'un poste remplaçant                    #
#  SELOPE    : sélection opérations                               #
#  SELMFGNUM4: selection of WO for FDMA recalculation             #
###################################################################
# Issue X3-48941 - 2017-08-16 by BAKHA : when selecting MFGLIN, for user with permissions,
#                                        select versioned products as well

$ACTION
Case ACTION
    When "SEL_TABLE"    : Gosub SEL_TABLE
    When "CHX_TABLE"    : Gosub CHX_TABLE
    When "FIN_TABLE"    : Gosub FIN_TABLE
    When "SEL_LISTE"    : Gosub SEL_LISTE
Endcase
Return

###################################################################
#    Choix dans les tables                                        #
###################################################################

$SEL_TABLE
Case TABLE
    When "SELGAM"    : Gosub S_GAM
    When "SELGAM2"   : Gosub S_GAM2
    When "SELGAM3"   : Gosub S_GAM3
    When "SELCPNMBM" : Gosub S_CPNMBM
    When "SELOPEMBO" : Gosub S_OPEMBO
    When "SELITMBOH" : Gosub S_ITMBOH
    When "SELITMMBI2": Gosub S_ITMMBI2
    When "SELOF"     : Gosub S_OF
    When "SELTRO"    : Gosub S_TRO
    When "SELTBO"    : Gosub S_TBO
    When "SELTBOA"   : Gosub S_TBOA
    When "SELWCR"    : Gosub S_SWCR
    When "SELMAKFCY" : Gosub S_MAKFCY
    When "SELSTDOPE" : Gosub S_OPESTD
    When "SELSCOITM" : Gosub S_SELSCOITM
    When "SELEMPNUM" : Gosub S_EMPNUM
    When "SELMSGNUM" : Gosub S_MSGNUM
    When "SELSCANUM" : Gosub S_SCANUM
    When "SWST"      : Gosub S_WST
    When "SWSTB"     : Gosub S_WSTB
    When "SWCR"      : Gosub S_WCR
    When "SELMFGTNUM": Gosub S_MFGTNUM
    When "SELROUNUM" : Gosub S_ROUNUM
    When "SELMFGNUM" : Gosub S_MFGNUM
    When "SELMFGNUM2": Gosub S_MFGNUM2
    When "SELMFGNUM3": Gosub S_MFGNUM3
    When "SELBPCNUM" : Gosub S_BPCNUM
    When "SELBPCNUMC": Gosub S_BPCNUMC
    When "SELBPCNUMF": Gosub S_BPCNUMF
    When "SELVLTCCE" : Gosub S_VLTCCE
    When "SELSTOLOC" : Gosub S_STOLOC
    When "SELPOHNUM" : Gosub S_POHNUM
    When "SELVCRNUM" : Gosub S_VCRNUM
    When "SELVCRORI" : Gosub S_VCRORI     # FQ 58982 GA 10/2009
    When "SELMTKMFG" : Gosub S_MTKMFG
    When "SELMFCMFG" : Gosub S_MFCMFG
    When "SELWEIMFG" : Gosub S_WEIMFG
    When "SELSCAMFG" : Gosub S_SCAMFG
    When "SELSCAMTK" : Gosub S_SCAMTK    # DT-18/06/2010
    When "SELSCAOPE" : Gosub S_SCAOPE    # DT-23/08/2010
    When "SELSCAITM" : Gosub S_SCAITM    # DT-23/08/2010
    When "SELRPTCOD" : Gosub S_RPTCOD
    When "SELMGL"    : Gosub S_MGL
    When "SELMDL"    : Gosub S_MDL
    When "SELMRL"    : Gosub S_MRL
    When "SELMFL"    : Gosub S_MFL
    When "SELMOL"    : Gosub S_MOL
    When "SELMIL"    : Gosub S_MIL
    When "SELMML"    : Gosub S_MML
    When "SELMRE"    : Gosub S_MRE
    When "SELMCL"    : Gosub S_MCL
    When "SELMFGNOM" : Gosub S_MFGNOM
    When "SELCONT"   : Gosub S_CONT
    When "SELFCYPJA" : Gosub S_FCYPJA
    When "SELOPE"    : Gosub S_SELOPE
    When "SELMFGNUM4": Gosub S_MFGNUM4
    When "SELCTNMFG" : Gosub S_CTNMFG   # CATUA X3-68685 Additional filter to only display container in WO
Endcase
Return

$CHX_TABLE
Case TABLE
    When "SELMTKMFG" : Gosub CHX_MTKMFG
Endcase
Return

$VERF_TABLE
Case TABLE
   When "SELOPEMBO" : Gosub VERF_OPEMBO
Endcase
Return


$FIN_TABLE
Case TABLE
   When "SELOPEMBO" : Gosub FIN_OPEMBO
   When "SELITMMBI2": Gosub FIN_ITMMBI2
   When "SELCPNMBM" : Gosub FIN_CPNMBM
   When "SELVCRNUM" : Gosub FIN_VCRNUM
   When "SELVCRORI" : Gosub FIN_VCRORI     # FQ 58982 GA 10/2009
Endcase
Return

$SEL_LISTE
Case LISTE
    When "SELOPEUOM" : Gosub S_OPEUOM
    When "SELOPE1"   : Gosub S_OPE
    When "SELITMBOH" : Gosub S_ITMBOH
    When "SELITMMBI" : Gosub S_ITMMBI
    When "SELOPEMBM" : Gosub S_OPEMBM
    When "SELLOTREI" : Gosub S_LOTREI
    When "SELSLOREI" : Gosub S_SLOREI
    When "SELMFGLIN" : Gosub S_MFGLIN
    When "SELRPLWST" : Gosub S_RPLWST
    When "SELTROTBO" : Gosub S_TROTBO
Endcase
Return


###################################################################
# sélection des différentes gammes associées à une alternative    #
# (de gamme)                                                      #
###################################################################
$S_GAM

Local Char WFCY(GLONFCY) : WFCY = PARAM(1)
Local Integer ALT1 : ALT1 = val(PARAM(2) )
Local Integer ALT2 : ALT2 = val(PARAM(3) )
Local Char WITMREF : WITMREF = PARAM(4)
Local Char WGREP   :  Raz WGREP
If GFONCTION = "GESROU"
   WGREP   = GREP
Endif
Gosub SEL_GAM

Return

###################################################################
$SEL_GAM
If clalev ([F:ATZ])=0 : Local File ATABZON : Endif
If clalev ([F:ROH])=0 : Local File ROUTING : Endif
If clalev ([F:TRO])=0 : Local File TABROUALT: Endif
If clalev ([F:ITM])=0 : Local File ITMMASTER : Endif
If clalev ([F:AXX])=0 : Local File ATEXTRA   [AXX]  : Endif  # FGR 07/06/2009 : X3SUIVI56380

Local Char CODFIC
Local Integer NBTRO     : NBTRO=0

  If !find(WGREP,"C","D")
    # MHB 16/10/08 : si on laisse les variables comme WFCY directement dans CRITERE, ça marche pour l'affichage
    # de la 1ère fenêtre de sélection, mais ça plante lorsqu'on veut passer aux pages suivantes car dans GACTION,
    # on fait un "Call SUIGAUCHE"... d'où la perte des variables
    Case WFCY
      When "" :      # 33284 mm 11.05
                     # If WITMREF <>"" : CRITERE ='ITMREF>=WITMREF': Endif
                     # If ALT1 <> 0
                     #     If CRITERE<>"" : CRITERE +='& (ROUALT >= ALT1 & ROUALT<= ALT2)'
                     #     Else : CRITERE ='ROUALT >= ALT1 & ROUALT<= ALT2': Endif
                     # Endif
                     # MHB 22/10/08 : on supprime le critère sur WITMREF car sinon, on ne peut pas remonter dans
                     # les pages précédentes (voir plus bas ce qui a été ajouté sur CRITCAR)
                     # If WITMREF <>"" : CRITERE ='ITMREF>="' + WITMREF + '"' : Endif
                     If ALT1 <> 0
                       If CRITERE<>"" : CRITERE +='& (ROUALT >= ' + num$(ALT1) + ' & ROUALT <= ' + num$(ALT2) + ')'
                       Else : CRITERE ='ROUALT >= ' + num$(ALT1) + ' & ROUALT<= ' + num$(ALT2) : Endif
                     Endif
                     If CRITERE ="" :  CRITERE = "1=1" : Endif
      When Default : # If ALT1 <> 0 : CRITERE ='(FCY=WFCY |FCY="") & ROUALT >= ALT1 & ROUALT<= ALT2'
                     # Else CRITERE = 'FCY=WFCY |FCY=""'
                     If ALT1 <> 0 : CRITERE ='(FCY="' + WFCY +'"|FCY="") & ROUALT >= ' +num$(ALT1) + '& ROUALT<=' + num$(ALT2)
                     Else CRITERE = 'FCY="' + WFCY + '" | FCY=""'
                     Endif
    Endcase
    If find(GFONCTION,"GESMFG","FUNGBENCH","FUNDBENCH","FUNMPICK")
      #   sélectionner les alt. de gammes compatibles avec site de prod
      Filter [TRO] Where ([F:TRO]FCY=WFCY  | [F:TRO]FCY="") & [F:TRO]MFGUSE=2
      For [TRO]TRO0
        GROUALT (NBTRO) = [F:TRO]ROUALT
        NBTRO += 1
      Next
      Filter [TRO]
      CRITERE+='& find(ROUALT, GROUALT)'
    Endif
    # MHB 20/10/08 : pour se positionner au bon endroit, on utilise CRITCAR. Attention à ne pas utiliser CRITERE, sinon
    # on est bien positionné, mais on ne peut pas remonter dans la sélection
    If WITMREF<>"" Then
      If CRITCAR = "" Then CRITCAR = "1=1" Endif
      CRITCAR += " & ITMREF>= '" + WITMREF + "'"
    Endif

    CODFIC ="ROUTING"
    # FGR 02/10/2009 : X3SUIVI58337
    Link [ROH] With [AXX]AXX0="ROUTING";"ROUDESAXX";GLANGUE;[F:ROH]IDENT1;[F:ROH]FCY As [NEW]
    #Default File [ROH]
    Default File [NEW]

    START = 'ITMREF'
    # ORDRE = 'FCY;ITMREF;ROUALT'
    ORDRE = 'ITMREF;ROUALT;FCY'
    # MHB 16/10/08 : Affectation de DEFPAG pour permettre la pagination
    DEFPAG = 1

    $GAMME
    TIT(0) = mess(12, 123, 1)-mess(240,190,1)
    NBCOL = 0
    #---------
    # PE si GPE = 1 autres colonnes qu'en standard - 47420 mm 05.08
    GPE = 0
    GPOINT = "ADDCOL"
    Gosub  ENTREE From EXEFNC
    If GPE : Return : Endif
    #---------
    NBCOL += 1 : COL(NBCOL)="ITMREF"   : Gosub TEXTE
    # FGR 02/10/2009 : X3SUIVI58337
    #NBCOL += 1 : COL(NBCOL)="ROUDES"  : Gosub TEXTE
    NBCOL += 1 : COL(NBCOL)="ROUDESAXX": Gosub TEXTE : COL(NBCOL)="[F:AXX]TEXTE"
    NBCOL += 1 : COL(NBCOL)="ROUALT"   : Gosub TEXTE
    NBCOL += 1 : COL(NBCOL)="FCY"      : Gosub TEXTE
    NBCOL += 1 : COL(NBCOL)="ROUSTRDAT": Gosub TEXTE
    NBCOL += 1 : COL(NBCOL)="ROUENDDAT": Gosub TEXTE
  Else
    Link [ITM] With [AXX]AXX0="ITMMASTER";"DES1AXX";GLANGUE;ITMREF;"" As [NEW] # FGR 07/06/2009 : X3SUIVI56380
    CODFIC ="ITMMASTER"
    #Default File [ITM]
    Default File [NEW]                                                  # FGR 07/06/2009 : X3SUIVI56380
    # If WITMREF <>"" : CRITERE ='ITMREF>=WITMREF'
    # MHB 22/10/08 : on supprime le critère sur WITMREF car sinon, on ne peut pas remonter dans
    # les pages précédentes
    # If WITMREF <>"" : CRITERE ='ITMREF>="' + WITMREF + '"'
    # Else            : CRITERE = '1=1'
    # Endif
    CRITERE = '1=1'
    # MHB 22/10/08 : pour se positionner au bon endroit, on utilise CRITCAR.
    If WITMREF<>"" Then
      If CRITCAR = "" Then CRITCAR = "1=1" Endif
      CRITCAR += " & ITMREF>= '" + WITMREF + "'"
    Endif

    START = 'ITMREF'
    ORDRE = 'ITMREF'
    # MHB 16/10/08 : Affectation de DEFPAG pour permettre la pagination
    DEFPAG = 1

    $ITM
    TIT(0) = mess(12, 123, 1)-mess(240,190,1)
    NBCOL = 0
    #---------
    # PE si GPE = 1 autres colonnes qu'en standard - 47420 mm 05.08
    GPE = 0
    GPOINT = "ADDCOL"
    Gosub  ENTREE From EXEFNC
    If GPE : Return : Endif
    #---------
    NBCOL += 1 : COL(NBCOL) = "ITMREF"   : Gosub TEXTE
    #NBCOL += 1 : COL(NBCOL) = "ITMDES1"  : Gosub TEXTE
    #NBCOL += 1 : COL(NBCOL) = "DES1AXX"  : Gosub TEXTE : COL(NBCOL)="[F:AXX]TEXTE"  # FGR 07/06/2009 : X3SUIVI56380
    NBCOL += 1 : COL(NBCOL) = "DES1AXX"  : Gosub TEXTE : COL(NBCOL)="string$(1,[F:AXX]TEXTE)+string$(len([F:AXX]TEXTE)=0,[F:ITM]ITMDES1)"  # FGR 29/09/2009 : X3SUIVI57887
    COLTYP(NBCOL) = 30  # FGR 01/02/2010  X3SUIVI62036
    NBCOL += 1 : COL(NBCOL) = "TCLCOD"   : Gosub TEXTE
    NBCOL += 1 : COL(NBCOL) = "ITMSTA"   : Gosub TEXTE : COL(NBCOL)="mess(ITMSTA,246,1)"
  Endif
Return


###################################################################
#    sélection des gammes associées à des OF fermes               #
###################################################################
$S_GAM2
CRITERE = '[MFG]MFGFCY="'+ PARAM(1)+'" & [MFG]MFGSTA<=1 & [MFG]MFGTRKFLG>=4' # 10/08/10 bug 66640
START='[MFG]ROUNUM'
ORDRE='[MFG]MFGNUM'
OBJET='SELOF'
Return

###################################################################
#  sélection d'OF dont situation= en cours et soldés              #
###################################################################
$S_GAM3
CRITERE='[MFG]MFGFCY="'+PARAM(1)+'"'
# 10/08/10 bug 66640
Case GMFGCLOSE
     When "3": CRITERE-='& [MFG]MFGSTA=1 & find([MFG]MFGTRKFLG,4,5)<>0'
               If clalev ([F:MFG])=0 : Local File MFGHEAD [MFG] : Endif
               If dim([F:MFG]WGGFLG) > 0
                   CRITERE-='& find([MFG]WGGFLG,3,4,8)=0'   # mm 05.11
               Endif
     When "4": CRITERE-='& [MFG]MFGSTA=4 & [MFG]MFGTRKFLG<6'
     When Default:  CRITERE-='& [MFG]MFGSTA=1'
Endcase
START='[MFG]MFGNUM'
ORDRE='[MFG]MFGNUM'
OBJET='SELOF'
SENS=2
Return

###################################################################
#   sélection d'un composant d'of ou de nomenclatureen plan       #
###################################################################
$S_CPNMBM
Local Char     WFCY(GLONFCY)   : WFCY       = PARAM(1)
Local Char     WMFGNUM(GLONVCR): WMFGNUM    = PARAM(2)
Local Char     WBOMNUM(GLONVCR): WBOMNUM    = PARAM(3)
Local Integer  WBOMALT         : WBOMALT    = val(PARAM(4))
Local Integer  WMATTYP         : WMATTYP    = val(PARAM(5))
Local Integer  WBOMSEQ         : WBOMSEQ    = val(PARAM(6))
Local Integer  WMFGLIN         : WMFGLIN    = val(PARAM(7))
Local Integer  WOPENUM         : WOPENUM    = val(PARAM(8))
Local Char   CODFIC

If clalev ([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev ([F:MFM])=0 : Local File MFGMAT  [MFM] : Endif
If clalev ([F:MFI])=0 : Local File MFGITM  [MFI] : Endif
If clalev ([F:BOD])=0 : Local File BOMD    [BOD] : Endif
# 10/08/10 bug 66640
Case WMATTYP
    When 1 :
        Default File [MFM]
        CODFIC ="MFGMAT"
        START='ITMREF'
#        ORDRE='BOMSEQ'
        CRITERE = 'MFGNUM = "'+WMFGNUM+'" & MATSTA <> 4 & CPNTYP <> 5'
        TIT(0) = mess(12, 123, 1)
        NBCOL = 0
        NBCOL +=1  : COL(NBCOL)="ITMREF" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="BOMOPE" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="BOMSEQ" : Gosub TEXTE
    When 2 :
        Default File [BOD]
        CODFIC ="BOMD"
        START='CPNITMREF'
 #       ORDRE='BOMSEQ'
        CRITERE = 'ITMREF = "'+WBOMNUM+'" & BOMALT = '+num$(WBOMALT)+' & find(CPNTYP,5,6)=0'
        TIT(0) = mess(12, 123, 1)
        NBCOL = 0
        NBCOL +=1  : COL(NBCOL)="CPNITMREF" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="CPNOPE"    : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="BOMSEQ"    : Gosub TEXTE
Endcase
# FQ 63783 GA 04/2010 Pagination
DEFPAG = 1
Return


###################################################################
#   sélection d'un article d'of ou  nomenclatureen plan           #
###################################################################
$S_ITMMBI2
Local Char     WFCY(GLONFCY)   : WFCY       = PARAM(1)
Local Char     WMFGNUM(GLONVCR): WMFGNUM    = PARAM(2)
Local Integer  WPRODTYP        : WPRODTYP   = val(PARAM(3))
Local Integer  WMFGLIN         : WMFGLIN    = val(PARAM(4))
Local Char   CODFIC

If clalev ([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev ([F:MFI])=0 : Local File MFGITM  [MFI] : Endif
If clalev ([F:BOH])=0 : Local File BOM     [BOH] : Endif

# 10/08/10 bug 66640
Case WPRODTYP
    When 1 :
        Default File [MFI]
        CODFIC ="MFGITM"
        START='ITMREF'
        ORDRE='MFGLIN'
        CRITERE = 'MFGNUM = "'+WMFGNUM+'" & ITMSTA <> 4'
        TIT(0) = mess(12, 123, 1)
        NBCOL = 0
        NBCOL +=1  : COL(NBCOL)="ITMREF" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="BOMALT" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="EXTQTY" : Gosub TEXTE
    When 2 :
        Default File [BOH]
        CODFIC ="BOM"
        START='ITMREF'
        ORDRE='ITMREF'
        CRITERE = 'BOMALTTYP = 2'
        TIT(0) = mess(12, 123, 1)
        NBCOL = 0
        NBCOL +=1  : COL(NBCOL)="ITMREF" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="BOMALT" : Gosub TEXTE
Endcase
# FQ 63783 GA 04/2010 Pagination
DEFPAG = 1
Return


###################################################################
#   sélection d'une operation d'of ou  de gamme plan           #
###################################################################
$S_OPEMBO
Local Char     WFCY(GLONFCY)   : WFCY       = PARAM(1)
Local Char     WMFGNUM(GLONVCR): WMFGNUM    = PARAM(2)
Local Integer  WTIMTYP         : WTIMTYP    = val(PARAM(3))
Local Char     WROUNUM(GLONVCR): WROUNUM    = PARAM(4)
Local Integer  WROUALT         : WROUALT    = val(PARAM(5))
Local Integer  WOPESPLNUM      : WOPESPLNUM = val(PARAM(6))
Local Date     WDAT            : WDAT       = PARAM(7)
Local Char   CODFIC

If clalev ([F:ATZ])=0 : Local File ATABZON    [ATZ] : Endif
If clalev ([F:MFO])=0 : Local File MFGOPE     [MFO] : Endif
If clalev ([F:ROO])=0 : Local File ROUOPE     [ROO] : Endif
If clalev ([F:MWS])=0 : Local File WORKSTATIO [MWS] : Endif
Case WTIMTYP
    When 1 :
        Default File [MFO]
        CODFIC ="MFGOPE"
        START='OPENUM'
        ORDRE='OPENUM'
        CRITERE = 'MFGNUM = "'+WMFGNUM+'" & OPESTA < 6'
        TIT(0) = mess(12, 123, 1)
        NBCOL = 0
        NBCOL +=1  : COL(NBCOL)="OPENUM" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="EXTWST" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="EXTQTY" : Gosub TEXTE
    When 2 :
        Default File [ROO]
        CODFIC ="ROO"
        START='OPENUM'
        ORDRE='OPENUM'
        CRITERE = 'ITMREF = "'+WROUNUM+'" & ROUALT = '+num$(WROUALT)
        CRITERE += '& ((VALENDDAT >= ['+format$(GFMD,WDAT)+'] & VALENDDAT<>[0/0/0]) | VALENDDAT=[0/0/0])'
        # FQ 77863 GA 11/2011 vérifier aussi VALSTRDAT
        CRITERE += '& ((VALSTRDAT <= ['+format$(GFMD,WDAT)+'] & VALSTRDAT<>[0/0/0]) | VALSTRDAT=[0/0/0])'
        TIT(0) = mess(12, 123, 1)
        NBCOL = 0
        NBCOL +=1  : COL(NBCOL)="OPENUM" : Gosub TEXTE
        NBCOL +=1  : COL(NBCOL)="WST"    : Gosub TEXTE
Endcase
# FQ 63783 GA 04/2010 Pagination
DEFPAG = 1
Return

###################################################################
#   sélection d'OF dont situation= en cours et soldés             #
###################################################################
$S_OF
## GH 08/01/13 dm 77455 la sélection OF est paramétrable pour ses colonnes et son titre via le browser SELOF
Local Integer I : I=0

If PARAM(1)<>""
    Call ADDCRIT(CRITERE,I,"","[MFG]MFGFCY='"+PARAM(1)+"'","&") From GOBJSUB
Endif
Call ADDCRIT(CRITERE,I,"",PARAM(2),"&") From GOBJSUB

START='[MFG]MFGNUM'
ORDRE='[MFG]MFGNUM'
OBJET='SELOF'
Return

###################################################################
#  sélection des alternatives de gamme                            #
###################################################################
$S_TRO
If clalev ([F:ATZ])=0 : Local File ATABZON : Endif
If clalev ([F:ROH])=0 : Local File ROUTING: Endif
If clalev ([F:TRO])=0 : Local File TABROUALT: Endif
If clalev ([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif  # FGR 18/09/2009 : X3SUIVI57927

Local Char WITMREF  : WITMREF = PARAM(1)
Local Char CODFIC
Local Char WGREP    : Raz WGREP

  If GFONCTION = "GESROU" : WGREP = GREP : Endif
  If !find(WGREP,"C","D")
    CODFIC  ="ROUTING"
    # FGR 02/10/2009 : X3SUIVI58337
    Link [ROH] With [AXX]AXX0="ROUTING";"ROUDESAXX";GLANGUE;[F:ROH]IDENT1;[F:ROH]FCY As [NEW]
    #Default File [ROH]
    Default File [NEW]

    # CRITERE = "ITMREF=WITMREF"
    CRITERE = "ITMREF='" + WITMREF + "'"
    START ='ROUALT'
    ORDRE ='ITMREF;ROUALT;FCY'

    TIT(0) = mess(12, 123, 1)-mess(241,190,1)
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL)="ROUALT"    : Gosub TEXTE
    # FGR 02/10/2009 : X3SUIVI58337
    #NBCOL += 1 : COL(NBCOL)="ROUDES"   : Gosub TEXTE
    NBCOL += 1 : COL(NBCOL)="ROUDESAXX" : Gosub TEXTE : COL(NBCOL)="[F:AXX]TEXTE"
    NBCOL += 1 : COL(NBCOL)="FCY"       : Gosub TEXTE
  Else
    CODFIC  ="TABROUALT"
    # FGR 03/11/2009 : X3SUIVI58372
    Link [TRO] With [AXX]AXX0="TABROUALT";"TRODESAXX";GLANGUE;num$(ROUALT);"" As [NEW] # FGR 18/09/2009 : X3SUIVI57927
    # FGR 18/09/2009 : X3SUIVI57908
    #Default File [TRO]
    Default File [NEW] # FGR 18/09/2009 : X3SUIVI57927

    CRITERE = '1=1'
    START ='ROUALT'
    ORDRE ='ROUALT'
    DEFPAG = 1
    # MHB 22/10/08 : pour se positionner au bon endroit, on utilise CRITCAR. Attention à ne pas utiliser CRITERE, sinon
    # on est bien positionné, mais on ne peut pas remonter dans la sélection
    If VALEUR>0 Then
      If CRITCAR = "" Then CRITCAR = "1=1" Endif
      CRITCAR += " & ROUALT>= " + num$(VALEUR)
    Endif

    TIT(0) = mess(12, 123, 1)-mess(241,190,1)
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL)="ROUALT" : Gosub TEXTE
    #NBCOL += 1 : COL(NBCOL)="TRODES" : Gosub TEXTE
    NBCOL += 1 : COL(NBCOL)="TRODESAXX" : Gosub TEXTE : COL(NBCOL)="[F:AXX]TEXTE"  # FGR 18/09/2009 : X3SUIVI57927
  Endif
Return

###################################################################
#  sélection des alternatives de nomenclature                     #
###################################################################
$S_TBO
Local   Char    WFCY(GLONFCY)
Local   Integer WALTTYP : WALTTYP = 2
If PARAM(1) <> "" : WFCY    = PARAM(1)      : Endif
If PARAM(2) <> "" : WALTTYP = val(PARAM(2)) : Endif
If WFCY <> ""
   # FQ 64642 & 65276 GA 06/2010 pb sur Page suivante
   # CRITERE(1)= '(FCY=WFCY | FCY= "") & BOMALTTYP = WALTTYP & MFGUSE=2'
    CRITERE(1)= '(FCY="'+WFCY+'" | FCY= "") & BOMALTTYP = '+num$(WALTTYP)+' & MFGUSE=2'
Else
    CRITERE(1)= 'BOMALTTYP = '+num$(WALTTYP)+' & MFGUSE=2'
Endif
OBJET ="TBO"
OPTIONS="#"

Return

###################################################################
#  sélection des alternatives de nomenclature                     #
###################################################################
$S_TBOA
Local   Char WFCY(GLONFCY)
Local   Char WOPT
If PARAM(1) <> "" : WOPT = PARAM(1) : Endif
If PARAM(2) <> "" : WFCY = PARAM(2) : Endif
CRITERE(1) = "1=1"
If WFCY <> ""
   # FQ 64642 & 65276 GA 06/2010 pb sur Page suivante
   # CRITERE(1) += '& (FCY=WFCY | FCY= "")'
   CRITERE(1) += '& (FCY="'+WFCY+'" | FCY= "")'
Endif
Case WOPT
    When "A" : CRITERE(1) += "&BOMALTTYP=1"
    When "B":  CRITERE(1) += "&BOMALTTYP=2& MFGUSE=2"
    When "D":  CRITERE(1) += "&BOMALTTYP=3"
Endcase
START="BOMALT"
ORDRE="BOMALT"
OBJET ="TBO"
OPTIONS="#"

Return

###################################################################
#  sélection des alternatives de nomenclature de coût             #
###################################################################
$S_TBOCST
Local   Char    WFCY(GLONFCY)
Local   Integer WALTTYP : WALTTYP = 2
If PARAM(1) <> "" : WFCY    = PARAM(1)      : Endif
If PARAM(2) <> "" : WALTTYP = val(PARAM(2)) : Endif
If WFCY <> ""
   # FQ 64642 & 65276 GA 06/2010 pb sur Page suivante
   # CRITERE(1)= '(FCY=WFCY | FCY= "") & BOMALTTYP = WALTTYP & CSTUSE=2'
    CRITERE(1)= '(FCY="'+WFCY+'" | FCY= "") & BOMALTTYP = '+num$(WALTTYP)+' & CSTUSE=2'
Else
    CRITERE(1)= 'BOMALTTYP = '+num$(WALTTYP)+' & CSTUSE=2'
Endif
OBJET ="TBO"
OPTIONS="#"

Return

