###################################################################
$S_STDOPENUM

If clalev ([F:ATZ])=0 : Local File ATABZON : Endif
If clalev ([F:ROT])=0 : Local File ROUOPESTD: Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA   [AXX]  : Endif  # FGR 21/09/2009 : X3SUIVI57981

Local Char CODFIC    : CODFIC = "ROUOPESTD"
  # bug 52563 pas de pagination de la selection
  DEFPAG=1
  CRITCAR="STDOPENUM >="+num$(VALEUR)

  # FGR 21/09/2009 : X3SUIVI57981
  Link [ROT] With [AXX]AXX0="ROUOPESTD";"STDOPEDESAXX";GLANGUE;num$([F:ROT]STDOPENUM);[F:ROT]FCY As [LNK]

  # FGR 21/09/2009 : X3SUIVI57981
  #Default File [ROT]
  Default File [LNK]

  If SIT <> ""
#    CRITERE ="(STDOPENUM<>0 & FCY=SIT)"
    CRITERE ="(STDOPENUM<>0 & FCY='" + SIT +"')"
  Else
    CRITERE ="STDOPENUM<>0"
  Endif

  START = 'STDOPENUM'
  ORDRE = 'STDOPENUM;FCY'
  TIT(0) = mess(12, 123, 1)

  NBCOL = 0
  NBCOL += 1 : COL(NBCOL)="STDOPENUM"    : Gosub TEXTE
  # FGR 21/09/2009 : X3SUIVI57981
  #NBCOL += 1 : COL(NBCOL)="STDOPEDES"    : Gosub TEXTE
  NBCOL += 1 : COL(NBCOL)="STDOPEDESAXX" : Gosub TEXTE : COL(NBCOL) = "[F:AXX]TEXTE"
  NBCOL += 1 : COL(NBCOL)="FCY"          : Gosub TEXTE
Return


