###################################################################
#  SELMFGNOM    : sélection des nomenclatures                     #
###################################################################
$S_MFGNOM
Local    Char    WFCY(GLONFCY): WFCY = PARAM(1)
Local    Char    WITM     : WITM = PARAM(2)
Local    Char    CODFIC   : CODFIC = "BOM"

If clalev([F:ATZ]) = 0 : Local File ATABZON    [ATZ] : Endif
If clalev([F:TBO]) = 0 : Local File TABBOMALT  [TBO] : Endif
If clalev([F:BOH]) = 0 : Local File BOM        [BOH] : Endif
If clalev([F:AXX])=0   : Local File ATEXTRA    [AXX] : Endif  # FGR 02/10/2009 : X3SUIVI57935

# FGR 02/10/2009 : X3SUIVI57935
#Link [BOH] With [TBO]TBO0=2;BOMALT As [NEW]
# FQ 69633 GA 12/2010 il manque GLANGUE dans l'accès AXX0
  Link [BOH] With [TBO]TBO0=2;BOMALT,
&                 [AXX]AXX0="BOM";"BOMDESAXX";GLANGUE;[F:BOH]IDENT1;num$([F:BOH]BOMALTTYP)
&              As [NEW]

# FQ 64642 & 65276 GA 06/2010 pb sur Page suivante
#CRITERE= '([F:TBO]FCY=WFCY | [F:TBO]FCY="") & [F:TBO]MFGUSE=2 & [F:BOH]ITMREF = WITM & BOMALTTYP=2'
CRITERE= '([F:TBO]FCY="'+WFCY+'" | [F:TBO]FCY="") & [F:TBO]MFGUSE=2 & [F:BOH]ITMREF="'+WITM+'" & BOMALTTYP=2'
Default File [NEW]

ORDRE='ITMREF;BOMALT'
TIT(0)= mess(153,198,1)
NBCOL = 0
NBCOL +=1 : COL(NBCOL)="BOMALT"    : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ITMREF"    : Gosub TEXTE
#NBCOL +=1 : COL(NBCOL)="BOMDES"    : Gosub TEXTE
NBCOL +=1  : COL(NBCOL)="BOMDESAXX" : Gosub TEXTE : COL(NBCOL)="[F:AXX]TEXTE"  # FGR 02/10/2009 : X3SUIVI57935
NBCOL +=1 : COL(NBCOL)="BOHENDDAT" : Gosub TEXTE
Return

###################################################################
#  SELOPEUOM    : sélection d'une unité d'opération               #
###################################################################
$S_OPEUOM
Local Char  WSTU         : WSTU    = PARAM(1)
Local Char  WOPEUOM      : WOPEUOM = PARAM(2)
Local Char    TEX(30)(0..100) , TEXTE(50)(0..100)
Local Char    TIT(30)
Local Integer NBTEX

TIT = mess(114,195,1)
NBTEX  = 0
If WOPEUOM <> ""
    NBTEX += 1 : TEX(NBTEX) = WSTU
    NBTEX += 1 : TEX(NBTEX) = WOPEUOM
Else
   #----- Ouverture et lecture des fichiers si nécessaire -----#
    If clalev([F:TUN])=0    Local File TABUNIT   [TUN] : Endif
    Call SELECT("TUN","",VALEUR,"") From SELOBJ
    Return
Endif

Return

###################################################################
#  SELOPE1   : sélection d'une opération  d'OF ou de gamme        #
###################################################################
$S_OPE
Local Char     WMFGNUM(GLONVCR): WMFGNUM    = PARAM(1)
Local Char     WFCY(GLONFCY)   : WFCY       = PARAM(2)
Local Char     WROUNUM(GLONVCR): WROUNUM    = PARAM(3)
Local Integer  WROUALT         : WROUALT    = val(PARAM(4))
Local Integer  WTIMTYP         : WTIMTYP    = val(PARAM(5))
Local Date     WDAT            : WDAT       = PARAM(6)
Local Char    TEXTE(GLONWST)(0..100,1..3)
Local Integer NBTEX
#Local Char    TLIN(GLONWST)(99,1..3)
#Local Integer NLIN : NLIN = 0
#Local Integer WLIN : WLIN = 0


If clalev([F:MFO]) = 0 : Local File MFGOPE     [MFO] : Endif
If clalev([F:MWS]) = 0 : Local File WORKSTATIO [MWS] : Endif
If clalev([F:SCH]) = 0 : Local File SCHEDULING [SCH] : Endif

TIT = mess(114,195,1)
TIT(1) = "N° opé"
TIT(2) = "Poste"
TIT(3) = "Désignation"
NBTEX  = 0
Case WTIMTYP
    When 1 :
        For [F:MFO] Where MFGNUM = WMFGNUM & OPESTA <> 6
                #S'agit-il d'une opération de sous-traitance
                  Read [F:MWS]WST0 = [F:MFO]EXTWST;[F:MFO]MFGFCY
                  If !fstat & [F:MWS]WSTTYP <> 3
                  #L'opération doit-elle être suivie
                     Read [F:SCH]SCH0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
                     If !fstat & [F:SCH]DACMST > 1
                         TEX(NBTEX+1) = num$([F:MFO]OPENUM)
                         TEXTE(NBTEX,1) = num$([F:MFO]OPENUM)
                         TEXTE(NBTEX,2) = [F:MFO]EXTWST
                         TEXTE(NBTEX,3) = [F:MWS]WSTSHO
                         NBTEX += 1
                     Endif
                   Endif
         Next
     When 2 :
       # FQ 77863 GA 11/2011 vérifier aussi VALSTRDAT
        For [F:ROO] Where FCY = WFCY & ITMREF = WROUNUM & ROUALT = WROUALT
&             & (VALENDDAT=[0/0/0] | (VALENDDAT >= WDAT & VALENDDAT<>[0/0/0]) )
&             & (VALSTRDAT=[0/0/0] | (VALSTRDAT <= WDAT & VALSTRDAT<>[0/0/0]) )
           #S'agit-il d'une opération de sous-traitance
                  Read [F:MWS]WST0 = [F:ROO]WST;[F:ROO]FCY
                  If !fstat & [F:MWS]WSTTYP <> 3
                       TEX(NBTEX+1) = num$([F:ROO]OPENUM)
                       TEXTE(NBTEX,1) = num$([F:ROO]OPENUM)
                       TEXTE(NBTEX,2) = [F:ROO]WST
                       TEXTE(NBTEX,3) = [F:MWS]WSTSHO
                       NBTEX += 1
                  Endif
        Next
Endcase
SIZLIG = 75
SIZCOL = 300
Return

###################################################################
#  SELITMMBI   : sélection d'un article d'OF ou de nomenclature   #
###################################################################
$S_ITMMBI
Local Char     WFCY(GLONFCY)   : WFCY       = PARAM(1)
Local Char     WMFGNUM(GLONVCR): WMFGNUM    = PARAM(2)
Local Integer  WBOMALT         : WROUALT    = val(PARAM(3))
Local Integer  WPRODTYP        : WPRODTYP    = val(PARAM(4))
Local Char    TEX(30)(0..100) , TEXTE(50)(0..100)
Local Char    TIT(30)
Local Integer NBTEX
Local Char    TLIN(60)(99)
Local Char    TLIN1(60)(99)
Local Integer NLIN : NLIN = 0
Local Integer WLIN : WLIN = 0
If clalev([F:MFI]) = 0 : Local File MFGITM     [MFI] : Endif
If clalev([F:BOH]) = 0 : Local File BOM        [BOH] : Endif
Case WPRODTYP
    When 1 :
        TIT = mess(86,195,1)
        Filter [F:MFI] Where MFGNUM = WMFGNUM & ITMSTA <> 4
        For [F:MFI]
            TLIN(NLIN)    = format$("K:20X",[F:MFI]ITMREF)+
&                           format$("K:5X", num$([F:MFI]BOMALT))
            TLIN1(NLIN)   = [F:MFI]ITMREF
            If NLIN = 98 : Break : Endif
            NLIN += 1
        Next
        Filter [F:MFI]
        If NLIN <> 0
            For WLIN = 0 To NLIN-1
                NBTEX += 1
                TEX(NBTEX)   = vireblc(left$(TLIN1(WLIN),20),1)
                TEXTE(NBTEX) = TLIN(WLIN)
            Next
        Endif
    When 2 :
        TIT = mess(139,195,1)
        Link [BOH] With [TBO]TBO0 = [F:BOH]BOMALTTYP;[F:BOH]BOMALT As [BOHX] Where find([F:TBO]FCY,WFCY,"")<>0
        For [F:BOHX] Where BOMALTTYP = 2
            TLIN(NLIN)    = format$("K:20X",[F:BOH]ITMREF)+
&                           format$("K:5X", num$([F:BOH]BOMALT))
            TLIN1(NLIN)   = [F:BOH]ITMREF
            If NLIN = 98 : Break : Endif
            NLIN += 1
        Next
        If NLIN <> 0
            For WLIN = 0 To NLIN-1
                NBTEX += 1
                TEX(NBTEX)   = vireblc(left$(TLIN1(WLIN),20),1)
                TEXTE(NBTEX) = TLIN(WLIN)
            Next
        Endif
Endcase

SIZLIG = 75
SIZCOL = 300
Return

###################################################################
#  S_CONT   : sélection contrat Achat                             #
###################################################################
$S_CONT
Local    Char     WITM    :    WITM = PARAM(2)
Local    Char     WFCY(GLONFCY):    WFCY = PARAM(3)
Local    Date     WDAT    :    WDAT = date$
Local    Char     CODFIC  :    CODFIC = "PORDERC"

If clalev ([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev ([F:POC])=0 : Local File PORDERC [POC] : Endif
If clalev ([F:POH])=0 : Local File PORDER  [POH] : Endif

# GH 27/06/2012 bug 83199
#Link [POC] With [POH]POH0=POHNUM As [NEW] Where [F:POC]ITMREF = WITM & [F:POC]PRHFCY = WFCY & [F:POC]ENDDAT >= WDAT &
#&                                               find([F:POH]APPFLG,3,4,5)<>0
Link [POC] With [POH]POH0=POHNUM As [NEW] Where [POC]ITMREF = WITM & [POC]PRHFCY = WFCY & [POC]ENDDAT >= WDAT & [POC]STRDAT <= WDAT
&                                             & find([POH]APPFLG,3,4,5)<>0
Default File [NEW]

START='POHNUM'
ORDRE='POHNUM;POPLIN'

TIT(0)= mess(12, 123, 1)
NBCOL = 0
NBCOL +=1 : COL(NBCOL)="PRHFCY" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="POHNUM" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ITMREF" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="STRDAT" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="ENDDAT" : Gosub TEXTE
NBCOL +=1 : COL(NBCOL)="BPSNUM" : Gosub TEXTE

Return

###################################################################
#  S_FCYPJA   : sélection des sites présents dans [PJA]           #
###################################################################
$S_FCYPJA
If clalev ([F:ATZ])=0 : Local File ATABZON  [ATZ] : Endif
If clalev ([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev ([F:PJA])=0 : Local File PARJAL   [PJA] : Endif
Local  Char CODFIC


Link  [PJA] With [FCY]FCY0=[F:PJA]MFGFCY As [NEW] Where [F:FCY]MFGFLG=2
Default File [NEW]

START='MFGFCY'
ORDRE='MFGFCY'


TIT(0)= mess(12, 123, 1)
NBCOL = 0
CODFIC = "PARJAL"
NBCOL +=1 : COL(NBCOL)="FCY" : Gosub TEXTE : COL(NBCOL)="[F:PJA]MFGFCY"
CODFIC = "FACILITY"
NBCOL +=1 : COL(NBCOL)="FCYNAM" : Gosub TEXTE : COL(NBCOL)="[F:FCY]FCYNAM"

Return


###################################################################
$VERF_OPEMBO
Case WTIMTYP
    When 1 : Read [F:MFO]MFO0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
             If fstat
                  Raz [F:MFO] : mkstat=1 : GERR=1
             Else
                  Read [F:MWS]WST0 = [F:MFO]EXTWST
                  If fstat | [F:MWS]WSTTYP = 3 : mkstat = 1 : GERR = 1 : Endif
             Endif
    When Default:
Endcase
Return


###################################################################
$FIN_CPNMBM
If VALEUR <> ""
    Case WMATTYP
        When 1 :
               PARAM(6) = num$([F:MFM]MFGLIN)
               PARAM(7) = num$([F:MFM]BOMSEQ)
               PARAM(8) = num$([F:MFM]BOMOPE)
               If !GVTMOD & [F:MFM]MFGLIN <> 0
                   Read [F:MFI]MFI0 = [F:MFM]MFGNUM;[F:MFM]MFGLIN
                   If !fstat
                        [M:MBM]BOMNUM(nolign-1) = [F:MFI]ITMREF
                        [M:MBM]BOMALT(nolign-1) = [F:MFI]BOMALT
                        Affzo [M:MBM]BOMNUM(nolign-1), BOMALT(nolign-1)

                   Endif
               Endif
        When 2 :
               PARAM(7) = num$([F:BOD]BOMSEQ)
               PARAM(8) = num$([F:BOD]CPNOPE)
    Endcase
Endif
Return

###################################################################
$FIN_ITMMBI2
If VALEUR <> ""
    Case WPRODTYP
        When 1 :
               PARAM(4) = num$([F:MFI]MFGLIN)
        When 2 :
    Endcase
Endif
Return

###################################################################
$FIN_OPEMBO
If VALEUR <> 0
    Case WTIMTYP
        When 1 :
               PARAM(6) = num$([F:MFO]OPESPLNUM)
        When 2 :
    Endcase
Endif
Return



###################################################################
#  SELOPEMBM   : sélection d'une opé d'OF ou de nomenclature      #
###################################################################
$S_OPEMBM
Local Char     WFCY(GLONFCY)   : WFCY       = PARAM(1)
Local Char     WMFGNUM(GLONVCR): WMFGNUM    = PARAM(2)
Local Integer  WMFGLIN         : WMFGLIN    = val(PARAM(3))
Local Char     WITMREF(GLONITM): WITMREF    = PARAM(4)
Local Char     WBOMNUM(GLONVCR): WBOMNUM    = PARAM(5)
Local Integer  WBOMALT         : WBOMALT    = val(PARAM(6))
Local Integer  WMATTYP         : WMATTYP    = val(PARAM(7))
Local Date     WDAT            : WDAT       = PARAM(8)
Local Char    TEX(30)(0..100) , TEXTE(80)(1..100,1..3)
Local Char    TIT(80)(0..3)
Local Integer NBTEX, I
Local Char    TLIN(60)(99)
Local Char    TLIN1(60)(99)
Local Char    TLIN2(60)(99)
Local Integer NLIN : NLIN = 0
Local Integer WLIN : WLIN = 0
If clalev([F:MFM]) = 0 : Local File MFGMAT     [MFM] : Endif
If clalev([F:MFO]) = 0 : Local File MFGOPE     [MFO] : Endif
If clalev([F:MWS]) = 0 : Local File WORKSTATIO [MWS] : Endif
If clalev([F:BOD]) = 0 : Local File BOMD       [BOD] : Endif

TIT = mess(233,190,1)          # sélection d'un numéro d'opération
TIT(1) = mess(5,159,1)         # numéro
TIT(2) = mess(87,134,1)        # Poste
TIT(3) = mess(82,123,1)        # Intitulé

Case WMATTYP
     When 1 :
        Filter [F:MFM] Where MFGNUM = WMFGNUM & MFGLIN = WMFGLIN &
&                            ITMREF = WITMREF
        For [F:MFM]
            Filter [F:MFO] Where MFGNUM = [F:MFM]MFGNUM & OPENUM = [F:MFM]BOMOPE
            Read [F:MFO]MFO0 First
            If !fstat
                Read [F:MWS]WST0 = [F:MFO]EXTWST;[F:MFO]MFGFCY
                If !fstat
                     TLIN(NLIN)    = num$([F:MFO]OPENUM)
                     TLIN1(NLIN)   = [F:MFO]EXTWST
                     TLIN2(NLIN)   = [F:MWS]WSTSHO
                    If NLIN = 98 : Break : Endif
                     NLIN += 1
                Endif
            Endif
        Next
        Filter [F:MFO]
        If NLIN <> 0
            For WLIN = 0 To NLIN-1
                NBTEX += 1
                TEX(NBTEX)  = TLIN(WLIN)
                TEXTE(NBTEX,1) = TLIN(WLIN)
                TEXTE(NBTEX,2) = TLIN1(WLIN)
                TEXTE(NBTEX,3) = TLIN2(WLIN)
            Next
        Endif
    When 2 :
        TIT(2) = mess(69,190,1)           # Composants
        TIT(3) = ""
        Filter [F:BOD] Where ITMREF = WBOMNUM & BOMALT = WBOMALT &
&                             BOMALTTYP = 2 &
&                             CPNITMREF = WITMREF &
&                   (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <> [0/0/0] & BOMSTRDAT <= WDAT)) &
&                   (BOMENDDAT = [0/0/0] | (BOMENDDAT <> [0/0/0] & BOMENDDAT >= WDAT)) &
&                    find(CPNTYP,5,6)=0
        For [F:BOD]BOD1
                     TLIN(NLIN)    = num$([F:BOD]CPNOPE)
                     TLIN1(NLIN)   = [F:BOD]CPNITMREF
                    If NLIN = 98 : Break : Endif
                     NLIN += 1
        Next
        Filter [F:BOD]
        If NLIN <> 0
            For WLIN = 0 To NLIN-1
                NBTEX += 1
                TEX(NBTEX)  = TLIN(WLIN)
                TEXTE(NBTEX,1) = TLIN(WLIN)
                TEXTE(NBTEX,2) = TLIN1(WLIN)
            Next
        Endif
     When 9 :
        If [M:MFG3]NBLIG = 0 : Return : Endif
        For I = 0 To [M:MFG3]NBLIG - 1
             TLIN(NLIN)   = num$([M:MFG3]OPENUM(I))
             TLIN1(NLIN)  = [M:MFG3]EXTWST(I)
             TLIN2(NLIN)  = [M:MFG3]EXTWSTSHO(I)
            If NLIN = 98 : Break : Endif
            NLIN += 1
        Next
        If NLIN <> 0
            For WLIN = 0 To NLIN-1
                NBTEX += 1
                TEX(NBTEX)  = TLIN(WLIN)
                TEXTE(NBTEX,1) = TLIN(WLIN)
                TEXTE(NBTEX,2) = TLIN1(WLIN)
                TEXTE(NBTEX,3) = TLIN2(WLIN)
            Next
        Endif
Endcase
Return




###################################################################
#  SELLOTREI   : Sélection d'un lot en réintégration              #
###################################################################
$S_LOTREI
Local Char     WFCY(GLONFCY)   : WFCY       = PARAM(1)
Local Char     WITMREF         : WITMREF    = PARAM(2)
Local Char     WVCRNUMORI      : WVCRNUMORI = PARAM(3)
Local Integer  WVCRLINORI      : WVCRLINORI = val(PARAM(4))
Local Integer  WVCRSEQSEQ      : WVCRSEQORI = val(PARAM(5))
Local Char     WBOMNUM         : WBOMNUM    = PARAM(6)
Local Integer  WBOMALT         : WBOMALT    = val(PARAM(7))
Local Integer  WMATTYP         : WMATTYP    = val(PARAM(8))
Local Char    TEX(30)(0..100) , TEXTE(50)(0..100)
Local Char    TIT(30)
Local Integer NBTEX
Local Char    TLIN(60)(99)
Local Char    TLIN1(60)(99)
Local Integer NLIN : NLIN = 0
Local Integer WLIN : WLIN = 0

If clalev([F:STJ]) <= 0  : Local File STOJOU [STJ] : Endif
Case WMATTYP
    When 3 :
# CCC (29/10/07) Bug 43601 : Ajout de ITMREF dans le filtre
            Filter [F:STJ] Where STOFCY = WFCY & VCRNUMORI = WVCRNUMORI & VCRLINORI = WVCRLINORI
&               & VCRSEQORI = WVCRSEQORI & ITMREF=WITMREF & UPDFLG <> 2
    When 4 :
            Filter [F:STJ] Where STOFCY = WFCY & VCRNUMORI = WBOMNUM & VCRLINORI = WBOMALT
&               & ITMREF=WITMREF &  UPDFLG <> 2

Endcase

For [F:STJ]
           If find([F:STJ]LOT,TLIN1(0..NLIN-1)) : Goto NEXT_STJ : Endif
           TLIN(NLIN)    = format$("K:15X", [F:STJ]LOT)
           TLIN1(NLIN)   = [F:STJ]LOT
           If NLIN = 98 : Break : Endif
           NLIN += 1
$NEXT_STJ
Next
Filter [F:STJ]
If NLIN <> 0
   For WLIN = 0 To NLIN-1
       NBTEX += 1
       TEX(NBTEX)   = vireblc(left$(TLIN1(WLIN),20),1)
       TEXTE(NBTEX) = TLIN(WLIN)
   Next
Endif

Return


###################################################################
#  SELSLOREI   : Sélection d'un sous-lot en réintégration         #
###################################################################
$S_SLOREI
Local Char     WFCY(GLONFCY)   : WFCY       = PARAM(1)
Local Char     WLOT            : WLOT       = PARAM(2)
Local Char     WVCRNUMORI      : WVCRNUMORI = PARAM(3)
Local Integer  WVCRLINORI      : WVCRLINORI = val(PARAM(4))
Local Integer  WVCRSEQSEQ      : WVCRSEQORI = val(PARAM(5))
Local Char     WBOMNUM         : WBOMNUM    = PARAM(6)
Local Integer  WBOMALT         : WBOMALT    = val(PARAM(7))
Local Integer  WMATTYP         : WMATTYP    = val(PARAM(8))
Local Char     WITMREF(GLONITM): WITMREF    = PARAM(9)
Local Char    TEX(30)(0..100) , TEXTE(50)(0..100)
Local Char    TIT(30)
Local Integer NBTEX
Local Char    TLIN(60)(99)
Local Char    TLIN1(60)(99)
Local Integer NLIN : NLIN = 0
Local Integer WLIN : WLIN = 0

If clalev([F:STJ]) <= 0  : Local File STOJOU [STJ] : Endif
Case WMATTYP
    When 3 :
# CCC (29/10/07) Bug 43601 : Ajout de ITMREF dans le filtre
        Filter [F:STJ] Where STOFCY = WFCY & VCRNUMORI = WVCRNUMORI & VCRLINORI = WVCRLINORI
&               & VCRSEQORI = WVCRSEQORI & ITMREF=WITMREF & UPDFLG <> 2 & LOT = WLOT
    When 4 :
        Filter [F:STJ] Where STOFCY = WFCY & VCRNUMORI = WBOMNUM & VCRLINORI = WBOMALT
&               & ITMREF=WITMREF & UPDFLG <> 2 & LOT = WLOT

Endcase

For [F:STJ]
    If find([F:STJ]SLO,TLIN1(0..NLIN-1)) : Goto NEXT_STJ_S : Endif
    TLIN(NLIN)    = format$("K:5X", [F:STJ]SLO)
    TLIN1(NLIN)   = [F:STJ]SLO
    If NLIN = 98 : Break : Endif
    NLIN += 1
$NEXT_STJ_S
Next
Filter [F:STJ]
If NLIN <> 0
   For WLIN = 0 To NLIN-1
       NBTEX += 1
       TEX(NBTEX)   = vireblc(left$(TLIN1(WLIN),20),1)
       TEXTE(NBTEX) = TLIN(WLIN)
   Next
Endif

Return

###################################################################
#  SELMFGLIN   : sélection d'une ligne OF                         #
###################################################################
$S_MFGLIN
Local Char    TEX(30)(0..100) , TEXTE(50)(0..100)
Local Char    TIT(30)
Local Integer NBTEX, I

# GH 27/01/2015 bug 105738
#Local Char    TLIN(60)(99)
#Local Char    TLIN1(60)(99)
#Local Integer NLIN : NLIN = 0
#Local Integer WLIN : WLIN = 0
#
#NLIN = 0
#For I=0 To [M:MFG1]NBLIG-1
#    If [M:MFG1]ITMTYP <> 2
#        TLIN(NLIN)    = format$("K:8X",num$([M:MFG1]MFGLIN(I)))+
#&                       format$("K:20X", [M:MFG1]ITMREF(I))+
#&                       format$("K:30X", [M:MFG1]ITMDES1(I))
#        TLIN1(NLIN)   = num$([M:MFG1]MFGLIN(I))
#        NLIN += 1
#    Endif
#Next
#If NLIN <> 0
#    For WLIN = 0 To NLIN-1
#        NBTEX += 1
#        TEX(NBTEX)   = vireblc(left$(TLIN1(WLIN),8),1)
#        TEXTE(NBTEX) = TLIN(WLIN)
#    Next
#Endif

For I=0 To [M:MFG1]NBLIG-1
    # X3-48941 - if user has permissions (GWOCRICHG),select versioned products as well
    If [M:MFG1]ITMTYP(I) <> 2
&     & (dim([M:MFG1]ECCVALMAJ)<0 | GWOCRICHG | [M:MFG1]ECCVALMAJ(I)="")    # 107513
        If NBTEX>=dim([L]TEXTE)-1 : Break : Endif
        NBTEX += 1
        TEX(NBTEX)   = vireblc(left$(num$([M:MFG1]MFGLIN(I)),8),1)
        TEXTE(NBTEX) = format$("K:8X",num$([M:MFG1]MFGLIN(I)))+
&                      format$("K:20X", [M:MFG1]ITMREF(I))+
&                      format$("K:30X", [M:MFG1]ITMDES1(I))
    Endif
Next I
Return

###################################################################
#  SELRPLWST   : sélection d'un poste remplaçant                  #
###################################################################
$S_RPLWST
Local Char    TEX(GLONWST)(0..100) , TEXTE(80)(1..100,1..2)
Local Char    TIT(80)(0..2)
Local Integer NBTEX, I
Local Char    TLIN(60)(99)
Local Char    TLIN1(60)(99)
Local Integer NLIN : NLIN = 0
Local Integer WLIN : WLIN = 0

TIT = mess(5, 81,1)        # sélection dans liste
TIT(1) = mess(232,190,1)   # Poste remplaçant
TIT(2) = mess(59,100,1)    # Type


NLIN = 0
# Recherche des différents postes de remplacement
For I=0 To 24
    If [F:RPW]RPLWST(I) <> ""
        TLIN(NLIN) = [F:RPW]RPLWST(I)
        TLIN1(NLIN)= mess([F:RPW]WSTTYP(I),313,1)
        NLIN += 1
    Endif
Next I

If NLIN <> 0
    For WLIN = 0 To NLIN-1
        NBTEX += 1
        TEX(NBTEX)     = TLIN(WLIN)
        TEXTE(NBTEX,1) = TLIN(WLIN)
        TEXTE(NBTEX,2) = TLIN1(WLIN)
    Next
Endif
Return

###################################################################
#  SELTROTBO   : sélection alternative nomenclature associée      #
###################################################################
$S_TROTBO
Local Integer WTRO : WTRO = val(PARAM(1))
Local Char    TEX(30)(0..100) , TEXTE(50)(0..100)
Local Char    TIT(30)
Local Integer NBTEX
Local Char    TLIN(60)(99)
Local Char    TLIN1(60)(99)
Local Integer NLIN : NLIN = 0
Local Integer WLIN : WLIN = 0
Local Char    SZTBODESAXX(GLONDES) # FGR 16/09/2009 : X3SUIVI57824

If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif  # FGR 16/09/2009 : X3SUIVI57824

NLIN = 0

Read [TRO]TRO0=WTRO
If fstat : Return : Endif

If [F:TRO]BOMALT1 <> 0
    Read [TBO]TBO0=2;[F:TRO]BOMALT1
    If !fstat
        # FGR 16/09/2009 : X3SUIVI57824
        Call LECTEXTRA(SZTBODESAXX,"TABBOMALT","TBODESAXX",num$([F:TBO]BOMALTTYP),num$([F:TBO]BOMALT)) From ATEXTRA
#        TLIN(NLIN)= format$("K:5X",num$([F:TBO]BOMALT))+
#&                   format$("K:30X", [F:TBO]TBODES)
        TLIN(NLIN)= format$("K:5X",num$([F:TBO]BOMALT))+ format$("K:30X", SZTBODESAXX)

        TLIN1(NLIN)= num$([F:TBO]BOMALT)
        NLIN += 1
    Endif
Endif

If [F:TRO]BOMALT2 <> 0
    Read [TBO]TBO0=2;[F:TRO]BOMALT2
    If !fstat
        # FGR 16/09/2009 : X3SUIVI57824
        Call LECTEXTRA(SZTBODESAXX,"TABBOMALT","TBODESAXX",num$([F:TBO]BOMALTTYP),num$([F:TBO]BOMALT)) From ATEXTRA
#        TLIN(NLIN)= format$("K:5X",num$([F:TBO]BOMALT))+
#&                format$("K:30X", [F:TBO]TBODES)
        TLIN(NLIN)= format$("K:5X",num$([F:TBO]BOMALT))+ format$("K:30X", SZTBODESAXX)

        TLIN1(NLIN)= num$([F:TBO]BOMALT)
        NLIN += 1
    Endif
Endif

If [F:TRO]BOMALT3 <> 0
    Read [TBO]TBO0=2;[F:TRO]BOMALT3
    If !fstat
        # FGR 16/09/2009 : X3SUIVI57824
        Call LECTEXTRA(SZTBODESAXX,"TABBOMALT","TBODESAXX",num$([F:TBO]BOMALTTYP),num$([F:TBO]BOMALT)) From ATEXTRA
#        TLIN(NLIN)= format$("K:5X",num$([F:TBO]BOMALT))+
#&                format$("K:30X", [F:TBO]TBODES)
        TLIN(NLIN)= format$("K:5X",num$([F:TBO]BOMALT))+ format$("K:30X", SZTBODESAXX)

        TLIN1(NLIN)= num$([F:TBO]BOMALT)
        NLIN += 1
    Endif
Endif

If NLIN <> 0
    For WLIN = 0 To NLIN-1
        NBTEX += 1
        TEX(NBTEX)   = vireblc(left$(TLIN1(WLIN),5),1)
        TEXTE(NBTEX) = TLIN(WLIN)
    Next
Endif
Return

###################################################################
$TEXTE
Call TEXTFIC(CODFIC ,  COL(NBCOL), 1, TIT(NBCOL) ) From OBJDIV
Return

###################################################################
# SELOPE sélection opérations
###################################################################
# 08.07 42167 Sélection opération au lien de nomenclature
###################################################################
$S_SELOPE
If clalev([F:ATZ]) = 0 : Local File ATABZON    [ATZ] : Endif

Local    Char ITM(GLONITM)       : ITM    = PARAM(1)
Local    Decimal ALT    : ALT    = val(PARAM(2))
Global Integer SELTRO(100) # défini en global pour conserver le find dans CRITERE
Local Integer NBTRO, NBROH
Local Char   CODFIC(GLONATB)
Local Char  LCDATREF(10)
DEFPAG=1
#Recherche des des alternatives de gamme
Local File TABROUALT [TRO] Where BOMALT1=ALT | BOMALT2=ALT | BOMALT3=ALT
For [TRO]TRO0
    SELTRO (NBTRO) = [F:TRO]ROUALT
    NBTRO += 1
Next

If clalev([F:ROO]) = 0 : Local File ROUOPE     [ROO] : Endif

Default File [ROO]

TIT(0) = mess(108,197,1)
CODFIC = "ROUOPE"
START='OPENUM'
# Issue X3-38673 - 2017-06-16 by GEBIL : Creation and initialization of the local variable LCDATREF in order to use it in the search
If GDATEREF = [0/0/0]
  LCDATREF = "0/0/0"
Else
  LCDATREF = format$(GFMD,GDATEREF)
Endif

# FQ 77863 GA 11/2011 vérifier aussi VALSTRDAT
#CRITERE = '(VALENDDAT >= GDATEREF | VALENDDAT =[0/0/0])'
CRITERE  = '((VALENDDAT >= ['+LCDATREF+'] & VALENDDAT<>[0/0/0]) | VALENDDAT=[0/0/0])'
CRITERE += ' & ((VALSTRDAT <= ['+LCDATREF+'] & VALSTRDAT<>[0/0/0]) | VALSTRDAT=[0/0/0])'
#CRITERE = CRITERE - '& find (ITMREF, SELITMREF) & find (ROUALT, SELTRO)'
# 10/08/10 bug 66640
CRITERE = CRITERE - '& ITMREF = "'+ITM+'" & find (ROUALT, SELTRO)'
ORDRE ='OPENUM;ROUALT'

NBCOL = 0
NBCOL += 1 : COL(NBCOL)="OPENUM"   : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="ROODES"   : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="ITMREF"   : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="ROUALT"   : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="RPLIND"   : Gosub TEXTE

Return

