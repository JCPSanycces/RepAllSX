###################################################################
$S_WCR
Local Char FCY        : FCY = PARAM(1)
If clalev ([F:ATZ])=0 : Local File ATABZON    : Endif
If clalev ([F:MWS])=0 : Local File WORKSTATIO : Endif
If clalev ([F:AXX])=0 : Local File ATEXTRA    : Endif        # 03.09 mm - libellé traduisible
Local Char CODFIC     : CODFIC = "WORKSTATIO"

