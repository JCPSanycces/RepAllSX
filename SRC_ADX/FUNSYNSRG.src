#<AdxTL>@(#)11.0.0.0 $Revision$
#########################################################################
#                                                                       #
#     Resynchronisation STOSRG  STOSRGW                                 #
#                                                                       #
#     - Traitement   : FUNSYNSRG                                        #
#     - Action       : TRTSYNSRG  (Traitement standard)                 #
#                                                                       #
#  - 291203 verification qu il ni ai pas de STAFLG à 2 à tord ds STOSRG #
#  - 291203 si pas de ligne de stock correspondante on supprime  STOSRG #
#  - 291203 coherence STOSRG / STOSRGW (existence liste à ranger)       #
#  - 230904 message si QTYSTU > QTYSTUACT                               #
#  - 230904 controle QTYSTUACT                                          #
#                                                                       #
#########################################################################

#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
#--- Actions liées au traitement standard 
Case ACTION
When "OUVRE_BATCH" : Gosub OUVRE_BATCH
When "INIT"        : Gosub INIT
When "EXEC"        : Gosub EXEC
When "TERMINE"     : Gosub TERMINE
When Default
Endcase
Return

#########################################################################
$INIT
Gosub OPEN_FILE
Local Integer I, J , K , L , WREW
Local Integer WADXUID(1..500)
Local Integer WDIM
Local Char    WSTOFCY(GLONFCY)
Local Char    WCRIT(80)
WSTOFCY=PARAM(1)

# En batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

Return
############################################################
$OUVRE_BATCH
Gosub OPEN_FILE
Return
############################################################
$OPEN_FILE
Local File STOSRG    [SRG]
Local File STOSRGW   [SGW]
Local File STOCK     [STO]
Local File TABWIPSTO [TWS]
Return
#########################################################################
$EXEC
Local Integer WTRBEGIN : Raz WTRBEGIN

Call UIDADX(WADXUID,WDIM) From TRTX3

If !GSERVEUR  & GFONCTION1="FUNSYNSRG"
# Ouverture de la trace
    Call OUVRE_TRACE("TRTSYNSRG") From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
    Call ECR_TRACE(mess(869,196,1),0) From GESECRAN    # Resynchronisation fichiers STOSRG / STOSRGW
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN 
Endif

If WSTOFCY<>""
   WCRIT='STOFCY=WSTOFCY'
Else
   WCRIT='1=1'
Endif

# Si pas de transaction en cours
If adxlog<>1 
   Trbegin [SRG]
   GOK=1 
   WTRBEGIN=1
Endif
# premier passage :   verification existence ligne de stock le cas echeant suppression STOSRG
#                     verification coherence STAFLG                                            
Lock [SRG]
If !fstat
   Raz I, J , K , L 
   For [SRG] Where evalue(WCRIT)


   SYMBOLE2 = "SRG"+[F:SRG]STOFCY+"\"+num$([F:SRG]VCRTYP)+"\"+[F:SRG]VCRNUM+"\"+num$([F:SRG]VCRLIN)
   Lock = SYMBOLE2
# modification en cours sur un autre poste
   If fstat
      GERR=1
      Call ECR_TRACE([F:SRG]STOFCY+":"+num$([F:SRG]VCRTYP)+":"+[F:SRG]VCRNUM+":"+num$([F:SRG]VCRLIN)-":"-mess(10,100,1),0) From GESECRAN
        SYMBOLE2 = "SRG"+[F:SRG]STOFCY+"\"+num$([F:SRG]VCRTYP)+"\"+[F:SRG]VCRNUM+"\"+num$([F:SRG]VCRLIN)
        Unlock = SYMBOLE2
       Lock = SYMBOLE2
    # modification en cours sur un autre poste
       If fstat
          GERR=1
          Call ECR_TRACE([F:SRG]STOFCY+":"+num$([F:SRG]VCRTYP)+":"+[F:SRG]VCRNUM+":"+num$([F:SRG]VCRLIN)-":"-mess(10,100,1),0) From GESECRAN
          Goto NEXTSRG
       Endif
   Endif
   WECR = 0
   Readlock [SRG]Curr
   If !fstat
       K+=1
      
       Read [STO] STO0=[F:SRG]STOFCY;[F:SRG]STOCOU
       If fstat
          Delete [F:SRG]
          I+=1
          Goto ANEXTSRG               # si pas de ligne de stock correspondant on delete
       Endif
       If [F:SRG]SRGPPS    =  "" &
&         ([F:SRG]PCU       <> "" |
&         [F:SRG]PCUSTUCOE <> 0  |
&         [F:SRG]QTYSTU    <> 0  |
&         [F:SRG]QTYPCU    <> 0 )
          Raz   [F:SRG]PCU, [F:SRG]PCUSTUCOE, [F:SRG]QTYSTU, [F:SRG]QTYPCU
          WECR = 1 
       Endif
       If [F:SRG]QTYSTUACT = 0
          If [F:SRG]QTYSTU <> 0
             [F:SRG]QTYSTUACT = [F:SRG]QTYSTU  # si qte a ranger = 0 on recupere la qte ranger 
             WECR = 1                          # de la liste si existante sinon on delete 
          Else                                 
             Delete [F:SRG]              
             I+=1
             Goto ANEXTSRG               
          Endif
       Endif          
       If [F:SRG]QTYSTU > [F:SRG]QTYSTUACT
          Call ECR_TRACE(mess(158,184,1)-" : "-[F:SRG]SRGPPS-" "-[F:SRG]ITMREF-" "-[F:SRG]LOC,0) From GESECRAN    
       Endif
   
       If [F:SRG]STAFLG = 2
          [F:SRG]STAFLG = 1
          WECR = 1 
       Endif
       If WECR = 1
          J+=1
          Rewrite [SRG]
          If fstat
             GOK = 0 : Call FSTA("SRG") From GLOCK 
             SYMBOLE2 = "SRG"+[F:SRG]STOFCY+"\"+num$([F:SRG]VCRTYP)+"\"+[F:SRG]VCRNUM+"\"+num$([F:SRG]VCRLIN)
             Unlock = SYMBOLE2
             Break
          Endif
       Endif
   Endif
$ANEXTSRG
   SYMBOLE2 = "SRG"+[F:SRG]STOFCY+"\"+num$([F:SRG]VCRTYP)+"\"+[F:SRG]VCRNUM+"\"+num$([F:SRG]VCRLIN)
   Unlock = SYMBOLE2
$NEXTSRG
   Next
   If GOK=0 Return Endif

   If GFONCTION1="FUNSYNSRG"
      Call ECR_TRACE(mess(870,196,1)-num$(K),0)  From GESECRAN   # Nombre de lignes  STOSRG lues  
      Call ECR_TRACE(mess(871,196,1)-num$(I),0)  From GESECRAN   # Nombre de lignes  STOSRG supprimées  
      Call ECR_TRACE(mess(872,196,1)-num$(J),0)  From GESECRAN   # Nombre de lignes  STOSRG corrigées  
   Endif
Else
   If GFONCTION1="FUNSYNSRG"
      Call ECR_TRACE(mess(873,196,1),1)  From GESECRAN           # Traitement impossible table STOSRG en cours d utilisation !
   Endif
Endif

Unlock [SRG]
# deuxieme passage :  verification existance STOSRG 
Lock [SGW]
If !fstat
   Raz I, J
   For [SGW]SGW0 Where evalue(WCRIT)    & 
&                ORICOD = 1     
   J+=1
   Read [SRG] SRG0=[F:SGW]STOCOU;[F:SGW]VCRTYP;[F:SGW]VCRNUM;[F:SGW]VCRLIN
   If fstat | [F:SGW]SRGPPS <> [F:SRG]SRGPPS
      Delete [F:SGW]
      I+=1
   Endif
   Next
   If GFONCTION1="FUNSYNSRG"
      Call ECR_TRACE(mess(874,196,1)-num$(J),0)   From GESECRAN   # Nombre de lignes  STOSRGW lues  :
      Call ECR_TRACE(mess(875,196,1)-num$(I),0)   From GESECRAN   # Nombre de lignes  STOSRGW supprimées  :
   Endif
Else
   If GFONCTION1="FUNSYNSRG"
      Call ECR_TRACE(mess(876,196,1),1)           From GESECRAN  # Traitement impossible table STOSRGW en cours d utilisation !
   Endif
Endif

Unlock [SGW]


# Troisieme  passage :  verification existance à tord TABWIPSTO 
Lock [TWS]
If !fstat
   Raz I, J
   For [TWS]TWS0 Where evalue(WCRIT)    
       J+=1
       Filter [SGW] Where [F:SGW]STOCOU     = [F:TWS]STOCOU &
&                         [F:SGW]STOSEQTWS  = [F:TWS]STOSEQ
&               Order By Key SGW0

       Look [SGW]SGW0 First
       Filter [SGW]
       If fstat
          Delete [F:TWS]
          I+=1
       Endif
   Next
   If GFONCTION1="FUNSYNSRG"
      Call ECR_TRACE(mess(886,196,1)-num$(J),0)   From GESECRAN   # Nombre de lignes TABWIPSTO lues  :
      Call ECR_TRACE(mess(887,196,1)-num$(I),0)   From GESECRAN   # Nombre de lignes TABWIPSTO supprimées  :
   Endif
Else
   If GFONCTION1="FUNSYNSRG"
      Call ECR_TRACE(mess(888,196,1),1)           From GESECRAN  # Traitement impossible table TABWIPSTO en cours d utilisation !
   Endif
Endif

Unlock [SGW]

# Si on a ouvert une transaction
If WTRBEGIN=1 
   Commit
   Raz WTRBEGIN
Endif

If !GSERVEUR & GFONCTION1="FUNSYNSRG"
   Call FERME_TRACE From LECFIC
   TRA=1
Endif

Return

#########################################################################
$TERMINE
Close File [SRG]
Close File [SGW]
Close File [STO]

Return

#########################################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

