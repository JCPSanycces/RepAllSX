#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HLY1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone FCY
mkstat = 0
zoncou = "FCY"
indice = 0
WCHAR = [M]FCY
If varmode([M]FCY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "FCY" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "ACONTFCY"
 Call CONTSITE([M]FCY) From SUBAGF
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("FCY","!",[M]FCY,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]FCY or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_FCY([M]FCY) From SUBHLY
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone YEA
mkstat = 0
zoncou = "YEA"
indice = 0
If varmode([M]YEA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "YEA" : Gosub ACTION From =IMPTRT
 Endif
 If [M]YEA=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "YEA" : GZNUM = 1879 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTOBJW"
  PARAM(1) = "HLY"
  Local Decimal VALEUR
  VALEUR = [M]YEA
  Call S_AFF_NUM(VALEUR,PARAM,"CONTOBJW","CONTOBJ","") From GACTION
  [M]YEA = VALEUR
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "YEA" : GZNUM = 1879 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_YEA([M]YEA) From SUBHLY
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "YEA" : GZNUM = 1879 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
WCHAR = [M]LEG
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"909","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]LEG,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "LEG" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]LEG,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]LEG,"909","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]LEG,"909",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]LEG or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_LEG([M]LEG) From SUBHLY
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone CPY
mkstat = 0
zoncou = "CPY"
indice = 0
If varmode([M]CPY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CPY" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "ACONTCPY"
 Call CONTSOC([M]CPY) From SUBAGF
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("CPY","!",[M]CPY,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CPY" : GZNUM = 1343 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBRDAY
mkstat = 0
zoncou = "NBRDAY"
indice = 0
status = 1
zoncou = "NBRDAY"
If varmode([M]NBRDAY,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NBRDAY From SUBHLY
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NBRDAY : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRDAY" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRDAY
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRDAY = nolign
   status = 75
   Call SAI_NBRDAY(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBRDAY(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRDAY
mkstat = 0
zoncou = "NBRDAY"

## Zone HLYDAY
mkstat = 0
zoncou = "HLYDAY"
WDATE = [M]HLYDAY(indice)
If varmode([M]HLYDAY,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_HLYDAY([M]HLYDAY(indice)) From SUBHLY
 GACTION = SAVACT
 If mkstat=1 : Raz [M]HLYDAY(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "HLYDAY" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If [M]HLYDAY(indice)=[0/0/0]
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "HLYDAY" : GZNUM = 212 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_HLYDAY([M]HLYDAY(indice)) From SUBHLY
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "HLYDAY" : GZNUM = 212 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WDATE<>[M]HLYDAY(indice) or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_HLYDAY([M]HLYDAY(indice)) From SUBHLY
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "HLYDAY" : GZNUM = 212 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone NBRDAY
mkstat = 0
zoncou = "NBRDAY"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "HLY1"
Return

