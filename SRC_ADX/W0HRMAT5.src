#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT5 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone RSAID
mkstat = 0
zoncou = "RSAID"
indice = 0
If varmode([M]RSAID,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "RSAID" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_RSAID([M]RSAID) From SUBEML2
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "RSAID" : GZNUM = 55146 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone EMPUID
mkstat = 0
zoncou = "EMPUID"
indice = 0
If varmode([M]EMPUID,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EMPUID" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone BRNCERNUM
mkstat = 0
zoncou = "BRNCERNUM"
indice = 0
If varmode([M]BRNCERNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BRNCERNUM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone ETHGRP
mkstat = 0
zoncou = "ETHGRP"
indice = 0
IMPENT = [M]ETHGRP
If varinit([M]ETHGRP,indice)=0
 IMPENT = 1
Endif
If varmode([M]ETHGRP,indice)=0
 [M]ETHGRP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ETHGRP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ETHGRP(indice)
 Endif
Endif
[M]ETHGRP = IMPENT

## Zone GRATAXNUM
mkstat = 0
zoncou = "GRATAXNUM"
indice = 0
If varmode([M]GRATAXNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "GRATAXNUM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone PINNUM
mkstat = 0
zoncou = "PINNUM"
indice = 0
If varmode([M]PINNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PINNUM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone RCEGRP
mkstat = 0
zoncou = "RCEGRP"
indice = 0
IMPENT = [M]RCEGRP
If varinit([M]RCEGRP,indice)=0
 IMPENT = 1
Endif
If varmode([M]RCEGRP,indice)=0
 [M]RCEGRP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "RCEGRP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]RCEGRP(indice)
 Endif
Endif
[M]RCEGRP = IMPENT

## Zone LNRSKL
mkstat = 0
zoncou = "LNRSKL"
indice = 0
IMPENT = [M]LNRSKL
If varinit([M]LNRSKL,indice)=0
 IMPENT = 1
Endif
If varmode([M]LNRSKL,indice)=0
 [M]LNRSKL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "LNRSKL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]LNRSKL(indice)
 Endif
Endif
[M]LNRSKL = IMPENT

## Zone DMYFLD
mkstat = 0
zoncou = "DMYFLD"
indice = 0
If varmode([M]DMYFLD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DMYFLD" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DMYFLDNA
mkstat = 0
zoncou = "DMYFLDNA"
indice = 0
If varmode([M]DMYFLDNA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DMYFLDNA" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBRCTRSA
mkstat = 0
zoncou = "NBRCTRSA"
indice = 0
status = 1
zoncou = "NBRCTRSA"
If varinit([M]NBRCTRSA,indice)=0
 [M]NBRCTRSA = 0
Endif
If !mkstat
 NBLIG = [M]NBRCTRSA
 For nolign=1 To NBLIG
  indice = nolign-1
  [M]NBRCTRSA = nolign
  status = 75
  Call SAI_NBRCTRSA(IMPFIC,ACTION,IMPTRT)
  If mkstat : Break : Endif
 Next nolign
 If mkstat : End : Endif
 indice = 0
Endif

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone NBRCTRAFR
mkstat = 0
zoncou = "NBRCTRAFR"
indice = 0
status = 1
zoncou = "NBRCTRAFR"
If varinit([M]NBRCTRAFR,indice)=0
 [M]NBRCTRAFR = 0
Endif
If !mkstat
 NBLIG = [M]NBRCTRAFR
 For nolign=1 To NBLIG
  indice = nolign-1
  [M]NBRCTRAFR = nolign
  status = 75
  Call SAI_NBRCTRAFR(IMPFIC,ACTION,IMPTRT)
  If mkstat : Break : Endif
 Next nolign
 If mkstat : End : Endif
 indice = 0
Endif

####################################
## Bloc liste 4
####################################
IMPTBL = 0

## Zone TFNNUM
mkstat = 0
zoncou = "TFNNUM"
indice = 0
WCHAR = [M]TFNNUM
If varmode([M]TFNNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TFNNUM" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_TFNNUM([M]TFNNUM) From SUBEML2
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "TFNNUM" : GZNUM = 55107 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WCHAR<>[M]TFNNUM or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_TFNNUM([M]TFNNUM) From SUBEML2
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "TFNNUM" : GZNUM = 55107 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone TFNREN
mkstat = 0
zoncou = "TFNREN"
indice = 0
IMPENT = [M]TFNREN
If varinit([M]TFNREN,indice)=0
 IMPENT = 1
Endif
If varmode([M]TFNREN,indice)=0
 [M]TFNREN(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "TFNREN" : Gosub ACTION From =IMPTRT
  IMPENT = [M]TFNREN(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_TFNREN(IMPENT) From SUBEML2
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "TFNREN" : GZNUM = 2675 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]TFNREN = IMPENT

## Zone AUSRDE
mkstat = 0
zoncou = "AUSRDE"
indice = 0
IMPENT = [M]AUSRDE
If varinit([M]AUSRDE,indice)=0
 IMPENT = 2
Endif
If varmode([M]AUSRDE,indice)=0
 [M]AUSRDE(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "AUSRDE" : Gosub ACTION From =IMPTRT
  IMPENT = [M]AUSRDE(indice)
 Endif
Endif
[M]AUSRDE = IMPENT

####################################
## Bloc liste 5
####################################
IMPTBL = 0

## Zone SSCFDS
mkstat = 0
zoncou = "SSCFDS"
indice = 0
IMPENT = [M]SSCFDS
If varinit([M]SSCFDS,indice)=0
 IMPENT = 1
Endif
If varmode([M]SSCFDS,indice)=0
 [M]SSCFDS(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "SSCFDS" : Gosub ACTION From =IMPTRT
  IMPENT = [M]SSCFDS(indice)
 Endif
Endif
[M]SSCFDS = IMPENT

## Zone SSCSIT
mkstat = 0
zoncou = "SSCSIT"
indice = 0
If varinit([M]SSCSIT,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]SSCSIT,"11705","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]SSCSIT,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "SSCSIT" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]SSCSIT,"11705","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "SSCSIT" : GZNUM = 1002843 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]SSCSIT,"11705",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "SSCSIT" : GZNUM = 1002843 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone SSCDAT
mkstat = 0
zoncou = "SSCDAT"
indice = 0
If varmode([M]SSCDAT,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_SSCDAT([M]SSCDAT) From SUBEML2
 GACTION = SAVACT
 If mkstat=1 : Raz [M]SSCDAT : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "SSCDAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone HLTNSS
mkstat = 0
zoncou = "HLTNSS"
indice = 0
IMPENT = [M]HLTNSS
If varinit([M]HLTNSS,indice)=0
 IMPENT = 1
Endif
If varmode([M]HLTNSS,indice)=0
 [M]HLTNSS(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "HLTNSS" : Gosub ACTION From =IMPTRT
  IMPENT = [M]HLTNSS(indice)
 Endif
Endif
[M]HLTNSS = IMPENT

## Zone TAXLIANUM
mkstat = 0
zoncou = "TAXLIANUM"
indice = 0
If varmode([M]TAXLIANUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TAXLIANUM" : Gosub ACTION From =IMPTRT
 Endif
Endif

####################################
## Bloc liste 6
####################################
IMPTBL = 0

## Zone RETNUM
mkstat = 0
zoncou = "RETNUM"
indice = 0
If varmode([M]RETNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "RETNUM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone RETDAT
mkstat = 0
zoncou = "RETDAT"
indice = 0
If varmode([M]RETDAT,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_RETDAT([M]RETDAT) From SUBEML2
 GACTION = SAVACT
 If mkstat=1 : Raz [M]RETDAT : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "RETDAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone RETFDSNUM
mkstat = 0
zoncou = "RETFDSNUM"
indice = 0
If varinit([M]RETFDSNUM,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]RETFDSNUM,"11705","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]RETFDSNUM,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "RETFDSNUM" : Gosub ACTION From =IMPTRT
  Endif
  SAVACT = GACTION : GACTION = "CONTADI"
  Call CONTADI([M]RETFDSNUM,"11705","") From SUBADI
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "RETFDSNUM" : GZNUM = 55466 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("ADI","!",[M]RETFDSNUM,"11705",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "RETFDSNUM" : GZNUM = 55466 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 7
####################################
IMPTBL = 0

## Zone RDEPITNUM
mkstat = 0
zoncou = "RDEPITNUM"
indice = 0
If varmode([M]RDEPITNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "RDEPITNUM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone EMPNUM
mkstat = 0
zoncou = "EMPNUM"
indice = 0
If varmode([M]EMPNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "EMPNUM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone UIDCRDNUM
mkstat = 0
zoncou = "UIDCRDNUM"
indice = 0
If varmode([M]UIDCRDNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "UIDCRDNUM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone TAXRAT
mkstat = 0
zoncou = "TAXRAT"
indice = 0
If varmode([M]TAXRAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TAXRAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBRCTRSA(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRCTRSA
mkstat = 0
zoncou = "NBRCTRSA"

## Zone TAXSTA
mkstat = 0
zoncou = "TAXSTA"
IMPENT = [M]TAXSTA(indice)
If varinit([M]TAXSTA,indice)=0
 IMPENT = 1
Endif
[M]TAXSTA(indice) = IMPENT

## Zone TAXLEGRET
mkstat = 0
zoncou = "TAXLEGRET"
IMPENT = [M]TAXLEGRET(indice)
If varinit([M]TAXLEGRET,indice)=0
 IMPENT = 1
Endif
[M]TAXLEGRET(indice) = IMPENT

## Zone TAXFORFLG
mkstat = 0
zoncou = "TAXFORFLG"
IMPENT = [M]TAXFORFLG(indice)
If varinit([M]TAXFORFLG,indice)=0
 IMPENT = 1
Endif
[M]TAXFORFLG(indice) = IMPENT

## Zone TAXCLCTYP
mkstat = 0
zoncou = "TAXCLCTYP"
IMPENT = [M]TAXCLCTYP(indice)
If varinit([M]TAXCLCTYP,indice)=0
 IMPENT = 1
Endif
[M]TAXCLCTYP(indice) = IMPENT

## Zone UIFSTA
mkstat = 0
zoncou = "UIFSTA"
IMPENT = [M]UIFSTA(indice)
If varinit([M]UIFSTA,indice)=0
 IMPENT = 1
Endif
[M]UIFSTA(indice) = IMPENT

## Zone NBRCTRSA
mkstat = 0
zoncou = "NBRCTRSA"

End

####################################
## Bloc tableau 3
####################################
Subprog SAI_NBRCTRAFR(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRCTRAFR
mkstat = 0
zoncou = "NBRCTRAFR"

## Zone TAXSTAAFR
mkstat = 0
zoncou = "TAXSTAAFR"
IMPENT = [M]TAXSTAAFR(indice)
If varinit([M]TAXSTAAFR,indice)=0
 IMPENT = 1
Endif
[M]TAXSTAAFR(indice) = IMPENT

## Zone EMPPOS
mkstat = 0
zoncou = "EMPPOS"
IMPENT = [M]EMPPOS(indice)
If varinit([M]EMPPOS,indice)=0
 IMPENT = 1
Endif
[M]EMPPOS(indice) = IMPENT

## Zone VEHRAT
mkstat = 0
zoncou = "VEHRAT"
If varinit([M]VEHRAT,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]VEHRAT(indice),"","") From SUBADI
 GACTION = SAVACT
Endif

## Zone PARTIMDIR
mkstat = 0
zoncou = "PARTIMDIR"
IMPENT = [M]PARTIMDIR(indice)
If varinit([M]PARTIMDIR,indice)=0
 IMPENT = 1
Endif
[M]PARTIMDIR(indice) = IMPENT

## Zone NBRCTRAFR
mkstat = 0
zoncou = "NBRCTRAFR"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "HRMAT5"
Return

