#<AdxTL>@(#)5.0.0.0 $Revision$
######################################################
## Versioning management for routings
## GH 11/2015
######################################################
# Issue X3-40395 - 2017-05-24 by BAKHA : Routing version import changes

$ACTION
Case ACTION
 When "SEL_TABLE"        : Case COUZON
                             When "ROUECCMAJ","ROUECCMIN" : Gosub SELROUECC
                           Endcase
 When "VERF_TABLE"       : Case COUZON
                             When "ROUECCMAJ"             : Gosub SELROUECCMIN
                           Endcase
 When "REVISION"         : Gosub REVISION
Endcase
Return

######################################################################################

$OUVRE
If clalev([F:RVV])=0 : Local File RVMVAL [RVV] : Endif
Return

######################################################

$STATUT
Case BOUT
  When "n","v" : # revision, validation
    OK=0
    If val([L]PARBOUT(3))>0
       Read [RVV]RVV0 = [L]PARBOUT(1);[L]PARBOUT(2);val([L]PARBOUT(3))
       If !fstat
          Read [ROH]ROH0 = [F:RVV]ITMREF;[F:RVV]ROUALT;[F:RVV]FCY
          If !fstat
             If VERROU : Gosub DEVERROU From GOBJET : Endif
             Gosub LECTURE From GOBJSUB
             OK=1
          Endif
       Endif
    Endif
    If !OK : Gosub RELIT From GOBJSUB : Endif
  When "g" : # management
    Gosub RELIT From GOBJSUB
Endcase
Return

######################################################

$APRES_MODIF
Case COUZON
 When "ROUALT", "FCY"
     If find(GREP,"","C","D") & dim([M:ROU0]ECCSEQ)=1
        If varmode([M:ROU0]ROUECCMAJ)
           [M:ROU0]ECCSEQ=0 : Return
        Endif
        If COUZON="ROUALT"
           Read [TRO]TRO0 = zc
           If fstat | [F:TRO]FCY="" : Return : Endif
        Endif
        Local Integer WALT
        Local Char    WFCY(GLONFCY)
        If COUZON="ROUALT" : WALT=zc : Else WALT =[M:ROU0]ROUALT : Endif
        If COUZON="FCY"    : WFCY=zc : Else WFCY =[M:ROU0]FCY    : Endif
        Read [ROH]ROH0 = [M:ROU0]ITMREF;WALT;WFCY
        If !fstat : Return : Endif
        Filter [RVV] Where ITMREF=[M:ROU0]ITMREF & FCY=WFCY
        If rowcount([RVV])>0 : GMESSAGE = mess(7,123,1) : OK=0 : Endif : # Création impossible
        Filter [RVV]
        If OK
          Filter [ROH] Where USESTA=1
          Read [ROH]ROH0(1) = [M:ROU0]ITMREF
          If fstat>2
             Filter [ROH] Where USESTA=2
             Read [ROH]ROH0(1) = [M:ROU0]ITMREF
             If fstat<=2 & [F:ROH]ROUALT=WALT
                GMESSAGE = mess(7,123,1) : OK=0 : # Création impossible
             Endif
          Elsif [F:ROH]ROUALT<>WALT
             GMESSAGE = mess(7,123,1) : OK=0 : # Création impossible
          Endif
          Filter [ROH]
        Endif
        If OK & GREP="D"
           For I=0 To [M:ROU1]NBLIG-1
&              If [M:ROU1]VALSTRDAT(I)<>[M:ROU0]ROUSTRDAT | [M:ROU1]VALENDDAT(I)<>[M:ROU0]ROUENDDAT
                  GMESSAGE=mess(206,192,1) : OK=0 : Break : # Duplication impossible
               Endif
           Next
       Endif
       If !OK : Return : Endif
       [M:ROU0]ECCSEQ=-1 : [M:ROU0]USESTA=1 : Affzo [ROU0]USESTA
     Endif
 When "DATREF"
     If !GIMPORT & dim([M:ROU0]ROUECCMAJ)=1 : Affzo [ROU0]ROUECCMAJ, ROUECCMIN : Endif
 When "ROUECCMAJ","ROUECCMIN"
     OK = -1
     If COUZON="ROUECCMAJ"
        If CZ=""
           [M:ROU0]ROUECCMIN=""
        Elsif func RVMLIB.NBRCPNROU([M:ROU0]ITMREF)=2 & [M:ROU0]ROUECCMIN=""
           Return
       Endif
     Endif
     Assign "[M:ROU0]"+COUZON  With CZ : # because [M] is not already loaded ! 04/03/03 (17507)
     If GREP="D" : Return : Endif
     Raz [M:ROU1] : Raz [M:ROU3]
     Gosub LIENS From SUBROUA : # read again the lines and load screen
     If !GIMPORT
       If dim([M:ROU0]ROUECCMAJ)=1 : Affzo [ROU0]ROUECCMAJ, ROUECCMIN : Endif
       Affzo [ROU1] : Affzo [ROU3]
     Endif
Endcase
Return

######################################################

$LIENS1
If dim([M:ROU0]ROUECCMAJ)=1
   Raz [M:ROU0]ECCDAT, [M:ROU0]ECCSEQ, [M:ROU0]TYPREV, [M:ROU0]ECCSTRDAT, [M:ROU0]ECCENDDAT
   Call ECCAFF([M:ROU0]ITMREF) From ECCROU
   If varmode([M:ROU0]ROUECCMAJ)=0
      If [M:ROU0]DATREF=[0/0/0]
         If !find(GREP,"C","D") : [M:ROU0]ROUECCMAJ="" : [M:ROU0]ROUECCMIN="" : Endif
         Filter [RVV] Where ITMREF=[M:ROU0]ITMREF & FCY=[M:ROU0]FCY
         If rowcount([RVV])=1    : [M:ROU0]ECCSEQ=1
         Elsif [M:ROU0]USESTA=2  : [M:ROU0]ECCSEQ=-2
         Endif
         Filter [RVV]
      Endif
      If [M:ROU0]ECCSEQ=0
        If [M:ROU0]USESTA=1
           Filter [RVV] Where ITMREF=[M:ROU0]ITMREF & FCY=[M:ROU0]FCY & USESTA=1
        Else
           Filter [RVV] Where ITMREF=[M:ROU0]ITMREF & FCY=[M:ROU0]FCY & USESTA=2
&                           & [M:ROU0]DATREF>=[F:RVV]STRDAT & ([M:ROU0]DATREF<=[F:RVV]ENDDAT | [F:RVV]ENDDAT=[0/0/0])
        Endif
        Read [RVV]RVV0 Last
        If fstat>2
           Filter [RVV] Where ITMREF=[M:ROU0]ITMREF & FCY=[M:ROU0]FCY
           Read [RVV]RVV0 Last
        Endif
        Filter [RVV]
        If fstat<=2
           [M:ROU0]ECCSEQ    = [F:RVV]ECCSEQ
           If [M:ROU0]DATREF<>[0/0/0]
              [M:ROU0]ROUECCMAJ = [F:RVV]ECCVALMAJ
              [M:ROU0]ROUECCMIN = [F:RVV]ECCVALMIN
              If [M:ROU0]DATREF<[F:RVV]STRDAT | ([M:ROU0]DATREF>[F:RVV]ENDDAT & [F:RVV]ENDDAT<>[0/0/0])
                # Issue X3-40395 : during import don't set GDATEREF & [M]DATREF otherwise the screen is not filled completely
                If !GIMPORT
                  [M:ROU0]DATREF = [F:RVV]STRDAT : GDATEREF = [M:ROU0]DATREF
                Endif
             Endif
           Endif
        Endif
      Endif

      If [M:ROU0]ECCSEQ>0
        If [F:RVV]ITMREF<>[M:ROU0]ITMREF | [F:RVV]ECCSEQ<>[M:ROU0]ECCSEQ | [F:RVV]FCY<>[M:ROU0]FCY
           Read [RVV]RVV0 = [M:ROU0]ITMREF;[M:ROU0]FCY;[M:ROU0]ECCSEQ
        Else
           fstat=0
        Endif
        If !fstat
           [M:ROU0]ECCDAT = [F:RVV]STRDAT
           [M:ROU0]ECCSTRDAT = [F:RVV]STRDAT
           [M:ROU0]ECCENDDAT = [F:RVV]ENDDAT
        Endif
      Elsif [M:ROU0]ECCSEQ=0 & find(GREP,"C","D")   # precaution
        [M:ROU0]ECCSEQ=-1 : [M:ROU0]USESTA=1 : Affzo [ROU0]USESTA
      Endif
   Endif
   If varmode([M:ROU0]ECCSTRDAT)<>3 # GH 12/10/2015 bug 111671
      Affzo [ROU0] ECCSTRDAT, ECCENDDAT
   Endif
Endif
Return

######################################################

$LIENS2
# no style for lines for BOM available to use or first version in developpement
If dim([M:ROU0]ECCSEQ)=1 & !GIMPORT
   If  !([M:ROU0]USESTA=1 & [M:ROU0]ECCSEQ>1)
     Chgstl [ROU1] With  ""
   Elsif [M:ROU1]NBLIG>0
     Affzo [ROU1]
     Call HIGHLIGHT
   Endif
Endif
Return

######################################################

$RAZDUP
If !GIMPORT & dim([M:ROU0]ECCSEQ)=1
   Effzo [ROU1]RPLIND
   If [M:ROU0]ROUECCMAJ<>"" & varmode([M:ROU0]ROUECCMAJ) : Effzo [ROU0]ROUECCMAJ : Endif
   If [M:ROU0]ROUECCMIN<>"" & varmode([M:ROU0]ROUECCMIN) : Effzo [ROU0]ROUECCMIN : Endif
   Effzo [ROU0] ECCSTRDAT, ECCENDDAT
   If [M:ROU0]ROUECCMAJ=""
      [M:ROU0]ECCSEQ=0
   Else
     Effzo [ROU0] ROUENDDAT
     For nolign = 1 To [M:ROU1]NBLIG
          [M:ROU1]VALSTRDAT(nolign-1) = [M:ROU0]ROUSTRDAT
          [M:ROU1]VALENDDAT(nolign-1) = [M:ROU0]ROUENDDAT
     Next
     Affzo [ROU1] VALSTRDAT
     Affzo [ROU1] VALENDDAT
   Endif
Endif
Return

######################################################

$APRES_CRE
If dim([M:ROU0]ECCSEQ)=1 & [M:ROU0]ECCSEQ=-1
   [M:ROU0]ECCSEQ = 1
   [M:ROU0]ECCDAT = [M:ROU0]ROUSTRDAT
   If GDATEREF<[M:ROU0]ROUSTRDAT
&   & !GIMPORT  # Issue X3-40395 : during import don't set GDATEREF & [M]DATREF otherwise the screen is not filled completely
     GDATEREF=[M:ROU0]ROUSTRDAT
   Endif
Endif
Return

######################################################

$MODIF
If dim([M:ROU0]ECCSEQ)=1 & [M:ROU0]ECCSEQ=1 & [M:ROU0]USESTA=1
   # modification of starting/ending dates for the first version in development
   Readlock [RVV]RVV0 = [M:ROU0]ITMREF;[M:ROU0]FCY;1
   If fstat=1
      GOK=-1 : GLOCK="$RVMVAL"-[M:ROU0]ITMREF-[M:ROU0]FCY-"1" : Return
   Elsif fstat
      GOK=0 : Call FSTA("RVV") From GLOCK : Return
   Endif
   [F:RVV]STRDAT    = [M:ROU0]ROUSTRDAT
   [F:RVV]ENDDAT    = [M:ROU0]ROUENDDAT
   Rewrite [RVV]
   If fstat
      GOK=0 : Call FSTA("RVV") From GLOCK : Return
   Endif
Endif
Return

######################################################

$APRES_MOD
If [M:ROU0]USESTA=2 & !(dim([L]TRTGBM)=1 & [L]TRTGBM="VALRVV")
   Filter [RVV] Where ITMREF=[ROU0]ITMREF & FCY=[M:ROU0]FCY & USESTA=1
   Look [RVV]RVV0 Last
   If fstat<=2
      # If necessary, transfer manually modifications on the routing in development
      Call MESSAGE(mess(342,193,1)) From GESECRAN
   Endif
   Filter [RVV]
Endif
Return

######################################################

$CREATION
If dim([L]TRTGBM)=1 & [L]TRTGBM<>""
   # version in development creation or revision
   Local Char SAVACTION(20) : SAVACTION = ACTION
   ACTION = "CREATION" : Gosub ACTION From =[L]TRTGBM
   ACTION = SAVACTION
   If GOK<1 : Return : Endif

Elsif dim([M:ROU0]ROUECCMAJ)=1 & [M:ROU0]ROUECCMAJ<>""
   # first version in development creation
   Raz [F:RVV]
   [F:RVV] = [M:ROU0]
   [F:RVV]ECCSEQ    = 1
   [F:RVV]FCY       = [M:ROU0]FCY
   [F:RVV]ECCVALMAJ = [M:ROU0]ROUECCMAJ
   [F:RVV]ECCVALMIN = [M:ROU0]ROUECCMIN
   [F:RVV]STRDAT    = [M:ROU0]ROUSTRDAT
   [F:RVV]ENDDAT    = [M:ROU0]ROUENDDAT
   [F:RVV]EXNFLG    = 1
   Write [RVV]
   If fstat
      GOK=0 : Call FSTA("RVV") From GLOCK : Return
   Endif

   Readlock [ITM]ITM0 = [M:ROU0]ITMREF
   If fstat
      GOK=0 : Call RSTA("ITM",[M:ROU0]ITMREF) From GLOCK : Return
   Endif
   Assign "[F:ITM]ECCROUALT(0)" With [M:ROU0]ROUALT
   Rewrite [ITM]
   If fstat
      GOK=0 : Call FSTA("ITM") From GLOCK : Return
   Endif
Endif
Return

######################################################

$SETBOUT
# head menu for versioning
If CLECUR & GREP="" & dim([M:ROU0]ECCSEQ)=1 & [M:ROU0]ECCSEQ<>0
   CHMEN+="ag" : # Route codes, management
   If [M:ROU0]USESTA=2 & VERROU : CHMEN+="n"  : Endif : # revision
   If [M:ROU0]USESTA=1 & VERROU : CHMEN+="v"  : Endif : # validation
Endif
Return

######################################################

$VERF_ANU
If dim([M:ROU0]ECCSEQ)<>1 | [M:ROU0]ECCSEQ=0  : Return : Endif
If dim([M:ROU0]NEWALT)=1 & [M:ROU0]NEWALT<>0 : Return : Endif

If [F:AN__]USESTA=2
  # Deletion of a routing available to use with versioning
  If !clalev([F:RVV])  : Local File RVMVAL   [RVV] : Endif
  Filter [RVV] Where ITMREF=[F:AN__]ITMREF & FCY=[F:AN__]FCY & USESTA=1
  Look [RVV]RVV0 Last
  Filter [RVV]
  If fstat<=2
     GERR=1 : GMESSAGE = mess(341,193,1) : # Delete before the routing in development
     OK = 0 : Return
  Endif
Endif
Return

$AFFMASK
If [M:ROU0]ITMREF<>""
   Call ECCAFF([M:ROU0]ITMREF) From ECCROU
Endif
Return

######################################################################################
# Text not changeable for operations of a routing avalaible to use
######################################################################################

$AB4_NBLIG
Local Integer SAVCONSDIA : SAVCONSDIA = GCONSDIA
mkstat=0 : Call PASRVMUSE2 From RVMLIB
If mkstat=2 : mkstat=0 : GCONSDIA=1 : Endif
Return

$BB4_NBLIG
GCONSDIA = SAVCONSDIA
Return

######################################################################################
## Labels for header screen
######################################################################################
# [M:ROU0]ECCSEQ = 0  => Item with no versioning
# [M:ROU0]ECCSEQ = x  => Item with version x (in development or available to use)
# [M:ROU0]ECCSEQ = -1 => Item with version 1 in creation (in developement)
# [M:ROU0]ECCSEQ = -2 => Item with all versions (if more than 1 version)

Subprog ECCAFF(ITM)
Value Char ITM()

If dim([M:ROU0]ROUECCMAJ)<0 : End : Endif

Local Integer I
I=func RVMLIB.NBRCPNROU(ITM)

If !I
     Diszo [ROU0]ROUECCMAJ, ROUECCMIN
Else
     If I=1 : Actzo [ROU0]ROUECCMAJ : Diszo [ROU0] ROUECCMIN
     Else   : Actzo [ROU0]ROUECCMAJ, ROUECCMIN
     Endif
Endif
End

######################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

Call ECCAFF(VALEUR)
End

######################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

If !GIMPORT & dim([M:ROU0]ECCSEQ)=1 & GREP="D": mkstat=4 : Endif
End

#####################################################
Subprog AS_ROUSTRDAT(VALEUR)
Variable Date    VALEUR

If dim([M:ROU0]ECCSEQ)<>1 | [M:ROU0]ECCSEQ=0 : End : Endif

If [M:ROU0]USESTA=2 | [M:ROU0]ECCSEQ>1
   # Version available to use or not first version => starting date not enterable
   mkstat=2
Endif
End

######################################################
Subprog C_ROUSTRDAT(VALEUR)
Variable Date     VALEUR
If dim([M:ROU0]ECCSEQ)<>1 | [M:ROU0]ECCSEQ=0 : End : Endif

If VALEUR=[0/0/0]
   GMESSAGE=mess(10,123,1) : mkstat=2 : End :  # Mandatory field
Endif
End

######################################################
Subprog AM_ROUSTRDAT(VALEUR)
Variable Date     VALEUR

If dim([M:ROU0]ECCSEQ)<>1 | [M:ROU0]ECCSEQ=0 : End : Endif

# Issue X3-40395 : During import, when modifying the date the previous value is not known in the screen
Local Date LROUSTRDAT
LROUSTRDAT = [M:ROU0]ROUSTRDAT
If GIMPORT & [M:ROU1]NBLIG>0
    If clalev([F:ROH2])=0 : Local File ROUTING [ROH2] : Endif
    Read [F:ROH2]ROH0=[M:ROU0]ITMREF;[M:ROU0]BOMALT;[M:ROU0]FCY
    If !fstat
        LROUSTRDAT = [F:ROH2]ROUSTRDAT
    Endif
Endif

# first version in development => all lines have same validity period than header
For nolign = 1 To [M:ROU1]NBLIG
  If [M:ROU1]VALSTRDAT(nolign-1) = LROUSTRDAT
    [M:ROU1]VALSTRDAT(nolign-1) = VALEUR : Affzo [ROU1]VALSTRDAT(nolign-1)
    [M:ROU1]UPDFLG(nolign-1)=1
  Endif
Next

[M:ROU0]ECCDAT=VALEUR
End

######################################################
Subprog AS_ROUENDDAT(VALEUR)
Variable Date    VALEUR
If dim([M:ROU0]ECCSEQ)<>1 | [M:ROU0]ECCSEQ=0 : End : Endif

If [M:ROU0]USESTA=1
   # version in development => no ending date, field not enterable date
   mkstat=1
Else
   # version available to use => ending date not enterable
   mkstat=2
Endif
End

######################################################
Subprog AS_USESTA(VALEUR)
Variable Integer VALEUR

If dim([M:ROU0]ECCSEQ)<>1 |  [M:ROU0]ECCSEQ=0 : End : Endif
If find(GREP,"C","D") : VALEUR=1 : Endif
mkstat=2
End

######################################################################################
## new fields for versioning management
######################################################################################


Subprog AS_ROUECCMAJ(VALEUR)
Variable Char    VALEUR()
If GREP="M"
   mkstat = 2
Endif
End

######################################################

Subprog C_ROUECCMAJ(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
   Filter [RVV] Where ITMREF=[M:ROU0]ITMREF & FCY=[M:ROU0]FCY & USESTA=[M:ROU0]USESTA
   If rowcount([RVV])=0
      GMESSAGE = mess(10,123,1) : mkstat=2 : # Mandatory field
   Else
      GDATEREF=[0/0/0] : [M:ROU0]DATREF=GDATEREF : Affzo [ROU0]DATREF
   Endif
   Filter [RVV]
   End
Endif

Local Integer OK
Local Char FMT(GLONICVVAL)
Filter [RVV] Where USESTA=[M:ROU0]USESTA
Read [RVV]RVV1(3) = [M:ROU0]ITMREF;[M:ROU0]FCY;VALEUR
If fstat>2 & find(GREP,"C","D")
   If !func ECCLIB.CTLCPN([M:ROU0]ITMREF,1,VALEUR,FMT)
     If FMT=""
        GMESSAGE = mess(209,187,1)
     Else
        GMESSAGE = mess(209,187,1)-"("+FMT+")"+string$(GMESSAGE<>"","\")+GMESSAGE
     Endif
     mkstat=2 :  # Incorrect format for version
   Endif
Elsif fstat>2
   GMESSAGE = mess(308,193,1) : mkstat=2 : # Non existing version
Elsif VALEUR<>[M:ROU0]ROUECCMAJ & func RVMLIB.NBRCPNROU([M:ROU0]ITMREF)=1
   OK=1
Elsif VALEUR<>[M:ROU0]ROUECCMAJ & func RVMLIB.NBRCPNROU([M:ROU0]ITMREF)=2
   Read [RVV]RVV1 = [M:ROU0]ITMREF;[M:ROU0]FCY;VALEUR;[M:ROU0]ROUECCMIN
   If fstat<2 : OK=1 : Else Effzo [ROU0]ROUECCMIN : Endif
Endif
Filter [RVV]
If OK & ([M:ROU0]DATREF<[F:RVV]STRDAT | ([M:ROU0]DATREF>[F:RVV]ENDDAT & [F:RVV]ENDDAT<>[0/0/0]))
   GDATEREF=[F:RVV]STRDAT : [M:ROU0]DATREF=GDATEREF : Affzo [ROU0]DATREF
Endif
End

######################################################
Subprog AS_ROUECCMIN(VALEUR)
Variable Char    VALEUR()

If GREP="M"
   mkstat=2
Elsif [M:ROU0]ROUECCMAJ="" | func RVMLIB.NBRCPNROU([M:ROU0]ITMREF)<2
   mkstat=1
Endif
End

######################################################
Subprog C_ROUECCMIN(VALEUR)
Variable Char    VALEUR()

Filter [RVV] Where USESTA=[M:ROU0]USESTA
Read [RVV]RVV1 = [M:ROU0]ITMREF;[M:ROU0]FCY;[M:ROU0]ROUECCMAJ;VALEUR
Filter [RVV]
If fstat>2 & find(GREP,"C","D")
   Local Char FMT(GLONICVVAL)
   If !func ECCLIB.CTLCPN([M:ROU0]ITMREF,2,VALEUR,FMT)
     If FMT=""
        GMESSAGE = mess(209,187,1)
     Else
        GMESSAGE = mess(209,187,1)-"("+FMT+")"+string$(GMESSAGE<>"","\")+GMESSAGE
     Endif
     mkstat=2 :  # Incorrect format for version
   Endif
Elsif fstat>2
   GMESSAGE = mess(308,193,1) : mkstat=2 : # Non existing version
Elsif [M:ROU0]DATREF<[F:RVV]STRDAT | ([M:ROU0]DATREF>[F:RVV]ENDDAT & [F:RVV]ENDDAT<>[0/0/0])
   GDATEREF=[F:RVV]STRDAT : [M:ROU0]DATREF=GDATEREF : Affzo [ROU0]DATREF
Endif
End

######################################################
$SELROUECC
OBJET="RVV1"
CRITERE="ITMREF='"+[M:ROU0]ITMREF+"' & FCY='"+[M:ROU0]FCY+"' & USESTA="+num$([M:ROU0]USESTA)
Case COUZON
  When "ROUECCMAJ"
       EXPSTART="ECCVALMAJ='"+VALEUR+"' & ECCVALMIN='"+[M:ROU0]ROUECCMIN+"'"
  When "ROUECCMIN"
       CRITERE-="& ECCVALMAJ='"+[M:ROU0]ROUECCMAJ+"'"
       EXPSTART="ECCVALMAJ='"+[M:ROU0]ROUECCMAJ+"' & ECCVALMIN='"+VALEUR+"'"
       START="ECCVALMIN"
Endcase
Return

$SELROUECCMIN
VALEUR = [F:RVV]ECCVALMAJ
START  = ""

If ([F:RVV]ECCVALMAJ<>[M:ROU0]ROUECCMAJ | [F:RVV]ECCVALMIN<>[M:ROU0]ROUECCMIN)
&  & ([M:ROU0]DATREF<[F:RVV]STRDAT | ([M:ROU0]DATREF>[F:RVV]ENDDAT & [F:RVV]ENDDAT<>[0/0/0]))
   GDATEREF=[F:RVV]STRDAT : [M:ROU0]DATREF=GDATEREF : Affzo [ROU0]DATREF
Endif

If [F:RVV]ECCVALMIN<>[M:ROU0]ROUECCMIN
   [M:ROU0]ROUECCMIN = [F:RVV]ECCVALMIN
   Affzo [ROU0]ROUECCMIN
   mkstat=4
Endif
Return

######################################################
# Tab screens (also record entry)
######################################################

$SETNOL
Local Integer NOL
If dim([M]OPENUM)=1 : NOL=0 : Else NOL=nolign-1 : Endif
Return

######################################################

Subprog C_OPENUM(VALEUR)
Variable Decimal  VALEUR

If dim([M:ROU0]ECCSEQ)<>1 | [M:ROU0]ECCSEQ=0 : End : Endif

If find([M:ROU0]ECCSEQ,-1,1)
   # first version in development
   Local Integer I
   I=find(VALEUR,[M:ROU1]OPENUM(0..nolign-2),[M:ROU1]OPENUM(nolign..[M:ROU1]NBLIG-1))
   If I
      GMESSAGE = mess(24,123,1)-num$(I+(I>nolign-1)) : # Code déjà existant en ligne
      mkstat=2
   Endif
Elsif VALEUR=[M:ROU1]OPENUM(nolign)
   # same operation number then the following line
   mkstat=2
Elsif nolign>1 & VALEUR=[M:ROU1]OPENUM(nolign-2) & [M:ROU1]VALENDDAT(nolign-2)=[0/0/0]
   # same operation number then the previous line which is still avaliable
   mkstat=2
Endif
End

######################################################

Subprog D_VALSTRDAT(VALEUR)
Variable Date     VALEUR

If dim([M:ROU0]ECCSEQ)=1 & !find([M:ROU0]ECCSEQ,0,-1)
  Gosub SETNOL
  If [M]CREFLG(NOL)=0
     VALEUR = [M:ROU0]ECCDAT
  Endif
Endif
End

######################################################

Subprog AS_VALSTRDAT(VALEUR)
Variable Date    VALEUR

If dim([M:ROU0]ECCSEQ)<>1 | [M:ROU0]ECCSEQ=0 : End : Endif
Gosub SETNOL

If [M:ROU0]ECCSEQ=-1
   # first version in development
   VALEUR = [M:ROU0]ROUSTRDAT
Elsif [M:ROU0]USESTA=1 & [M]CREFLG(NOL)=0
   # new line for a version in development
   VALEUR = [M:ROU0]ECCDAT
Endif
mkstat=2
End

######################################################

Subprog AS_VALENDDAT(VALEUR)
Variable Date    VALEUR

If dim([M:ROU0]ECCSEQ)<>1 | [M:ROU0]ECCSEQ=0 : End : Endif
Gosub SETNOL

If [M:ROU0]USESTA=1 & [M]CREFLG(NOL)=0
   VALEUR = [M:ROU0]ROUENDDAT
Endif
mkstat=2
End

######################################################

Subprog IB_NBLIG

#GBOUT10 = "Revision line"
#GBOUT11 = "Exclude line"
#GBOUT12 = "Reintegrate line"
If dim([M:ROU0]ECCSEQ)<>1 | [M:ROU0]USESTA=2 | [M:ROU0]ECCDAT=[0/0/0] | [M:ROU1]OPENUM(nolign-1)=0
&   | ([M:ROU1]VALSTRDAT(nolign-1)=[M:ROU0]ECCDAT & [M:ROU1]VALENDDAT(nolign-1)=[M:ROU0]ROUENDDAT)
   Raz GBOUT10, GBOUT11, GBOUT12
Elsif [M:ROU1]VALENDDAT(nolign-1)=[M:ROU0]ROUENDDAT & [M:ROU1]VALSTRDAT(nolign-1)<>[M:ROU0]ECCDAT
   Raz GBOUT12
Elsif  [M:ROU1]VALENDDAT(nolign-1)=[M:ROU0]ECCDAT-1
   Raz GBOUT10, GBOUT11
Else
   Raz GBOUT10, GBOUT11, GBOUT12
Endif
End

#########################################################################
## Version available       => no line with type Normal addable/deletable
## Version in development  => line of previous versions not deletable

Subprog C_NBLIG
If dim([M:ROU0]ECCSEQ)<>1 | [M:ROU0]ECCSEQ=0 : End : Endif

If find(status,73,82) & [M:ROU0]USESTA=2   : # Insert line, Add in last line
   mkstat=2
Elsif find(status,65,83)                   : # Delete line or lines
   Local Integer I, J
   If status=83 : J=nolign1 : Else J=nolign : Endif
   For I=nolign To J
      If [M:ROU0]USESTA=2 | ([M:ROU0]USESTA=1 & [M:ROU1]VALSTRDAT(I-1)<>[M:ROU0]ECCDAT)
         mkstat=2 : Break
      Endif
   Next I
   If mkstat
    GMESSAGE=mess(422,198,1)+"\"+mess(186,123,1) : End : # Delete line \ Action not possible
   Endif
Endif
End

######################################################
## Revision line
Subprog B10_NBLIG
If [M:ROU1]NBLIG >= dim([M:ROU1]OPENUM)
   GMESSAGE = mess(26,100,1) : mkstat=2 : # Table is full
   End
Endif

Local Integer NOL, OK
Local Date    SAVDATF

NOL = nolign-1
SAVDATF = [M:ROU1]VALENDDAT(NOL)
[M:ROU1]VALENDDAT(NOL)=[M:ROU0]ECCDAT-1

# line revisioned (destination)
Insa NOL+1,1 [M:ROU1]NBLIG
indice = NOL+1 : nolign = indice+1
[M:ROU1]VALSTRDAT(indice) = [M:ROU0]ECCDAT
[M:ROU1]VALENDDAT(indice) = [M:ROU0]ROUENDDAT
[M:ROU1]ROOTEX(indice)    = [M:ROU1]ROOTEX(indice-1)
If clalev([F:AWI])=0 : Local File AWINDOW [AWI] : Endif
If [F:AWI]WIN<>GBOITE
   Read [AWI]AWI0  = GBOITE
Endif
OK=GIMPORT
GIMPORT=1
Call SAI_NBLIG("","REVISION","ECCROU") From ="W0"+[F:AWI]NOMMSK(1) : # ROOTEX not managed
GIMPORT=OK
If mkstat
    Dela NOL+1,1 [M:ROU1]NBLIG
    [M:ROU1]VALENDDAT(NOL)=SAVDATF
    End
Endif
Call DUP_CLOB("ROO",[M:ROU1]ROOTEX(NOL+1),OK) From TRTX3TEX
If OK<1 : Raz [M:ROU1]ROOTEX(NOL+1) : Endif

# line to be revisioned (origin)
[M:ROU1]UPDFLG(NOL)=1
# [M:ROU1]VALENDDAT(NOL)=[M:ROU0]ECCDAT-1 : # already done above
Affzo [ROU1]VALENDDAT(NOL)
[M:ROU1]NBLIG+=1

If GIMPORT : End : Endif
Affzo [ROU1]

Call HIGHLIGHT
Goto FIN_ROO_BOUT

$REVISION
If !find(IMPZON,"VALSTRDAT","VALENDDAT","CTIMCOE","HCTIMCOE")
   Assign "[M:ROU1]"+IMPZON+"(indice)" With evalue("[M:ROU1]"+IMPZON+"(indice-1)")
Endif
Return

######################################################
## Exclude line
Subprog B11_NBLIG
If !([M:ROU1]VALENDDAT(nolign-1)=[M:ROU0]ROUENDDAT & [M:ROU1]VALSTRDAT(nolign-1)<>[M:ROU0]ECCDAT) : End : Endif

[M:ROU1]UPDFLG(nolign-1)=1
[M:ROU1]VALENDDAT(nolign-1)=[M:ROU0]ECCDAT-1 : Affzo [ROU1]VALENDDAT(nolign-1)

Gosub HIGHLIGHT_LINE
Goto FIN_ROO_BOUT

######################################################
## Reintegrate line
Subprog B12_NBLIG
If [M:ROU1]VALENDDAT(nolign-1)<>[M:ROU0]ECCDAT-1 : End : Endif

[M:ROU1]UPDFLG(nolign-1)=1
[M:ROU1]VALENDDAT(nolign-1)=[M:ROU0]ROUENDDAT : Affzo [ROU1]VALENDDAT(nolign-1)

Local Integer I, L
L=0
For I=0 To [M]NBLIG-1
   If I<>nolign-1 & [M:ROU1]OPENUM(I)=[M:ROU1]OPENUM(nolign-1)
      If [M:ROU1]VALSTRDAT(I)=[M:ROU0]ECCDAT : L=I+1 : Endif
   Endif
Next
If L
    Dela L-1,1 [M:ROU1]NBLIG
    [M:ROU1]NBLIG-=1
    If !GIMPORT
       Affzo [ROU1]
       Call HIGHLIGHT
    Endif
Endif

If GIMPORT : End : Endif
Gosub HIGHLIGHT_LINE
Goto FIN_ROO_BOUT

######################################################

$FIN_ROO_BOUT
If GREP="" : mkstat=4 : # to force to enter in modification
Else       : mkstat=3 : # to force to redo IB_NBLIG
Endif
End

######################################################

Subprog HIGHLIGHT
Local Integer NOL
NOL=nolign
For nolign=1 To [M:ROU1]NBLIG
   Gosub HIGHLIGHT_LINE
Next
nolign=NOL
End

$HIGHLIGHT_LINE
If [M:ROU1]VALENDDAT(nolign-1)=[M:ROU0]ECCDAT-1
   Chgstl [ROU1]NBLIG(nolign-1) With  "ECCBODA"    : # line excluded from the version => red
Elsif [M:ROU1]VALSTRDAT(nolign-1)=[M:ROU0]ECCDAT
   Chgstl [ROU1]NBLIG(nolign-1) With  "ECCBODC"    : # line added to the version => green
Elsif  [M:ROU1]VALENDDAT(nolign-1)<>[0/0/0] &  [M:ROU1]VALENDDAT(nolign-1)<[M:ROU0]ECCDAT
   Chgstl [ROU1]NBLIG(nolign-1) With  "ECCBODB"    : # line excluded from a former version => grey
Else
   Chgstl [ROU1]NBLIG(nolign-1) With  ""           : # line preserved from a former version => no style
Endif
Return

######################################################

Subprog C_BASTAB
If dim([M:ROU0]ECCSEQ)<>1 | [M:ROU0]ECCSEQ=0 : End : Endif
If dim([M:ROU0]NEWALT)=1 & [M:ROU0]NEWALT<>0 : End : Endif

If status=75 & [M:ROU3]OPENUM(nolign-1)<>0
   Local Integer VOPE
   VOPE = [M:ROU3]OPENUM(nolign-1)
   Gosub MOD_ROU3
Endif
End

$MOD_ROU3
If [M:ROU0]USESTA=2
   # Version available to use
   mkstat=2
Else
   Local Integer NOL
   For NOL=0 To [M:ROU1]NBLIG-1
       If [M:ROU1]OPENUM(NOL)=VOPE & [M:ROU1]VALSTRDAT(NOL)<>[M:ROU0]ECCDAT : mkstat=2 : Break : Endif
   Next
   If mkstat : Return : Endif
   If [M:ROU0]DATREF<>[0/0/0]
       If !clalev([F:ROO]) : Local File ROUOPE [ROO] : Endif
       #  consider the hidden operations
       Filter [ROO] Where (VALSTRDAT > [M:ROU0]DATREF | (VALENDDAT < [M:ROU0]DATREF & VALENDDAT<>[0/0/0]))
       Look [ROO]ROO0(4) = [M:ROU0]FCY;[M:ROU0]ITMREF;[M:ROU0]ROUALT;VOPE
       If fstat<=2 : mkstat=2 : Endif
       Filter [ROO]
    Endif
Endif
Return

