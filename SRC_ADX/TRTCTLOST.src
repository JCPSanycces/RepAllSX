#<AdxTL>@(#)10.0.0.0 $Revision$
#########################################################################################################
# Test de la saisie des codes paramètres : Niveau de ctrl de l'en-cours (Cyril Chaize mars 2006)        #
#                                                                                                       #
# - OSTCTL  (Ventes)                                                                                    #
# - OSTSCTL (Achats)                                                                                    #
#                                                                                                       #
# Valeurs possibles : 1 Dossier, 2 Société                                                              #
#                                                                                                       #
# Si Dossier mono-société, les 2 valeurs sont possibles                                                 #
# Si Dossier multi-société, si les champs encours sont déclinés par société, Valeur forcément=2         #
# Si Dossier multi-société, si les champs encours ne sont pas déclinés par société, Valeur forcément=1  #
#                                                                                                       #
#########################################################################################################

Subprog VERF_PARAM(PARAM, TSTVALEUR, OK)
Value    Char    PARAM
Value    Char    TSTVALEUR
Variable Integer OK

OK = 1

If !find(PARAM, "OSTCTL", "OSTSCTL")
    #Erreur dans le code paramètre
    GMESSAGE = mess(204, 196, 2)
    GERR = 1
    OK = 0
    End
Endif

If !clalev([F:ACV]) : Local File ACTIV [ACV] : Endif

Read [ACV] CODACT = "MUL"
If fstat
    #Aucun contrôle de conformité du code n'a pu être effectué. Création refusé.
    GMESSAGE = mess(205, 196, 2)
    GERR = 1
    OK = 0
    End
Endif

#----- Si la table PARCPY n'existe pas, c'est fini ! -----#
If filinfo(filpath("FIL","PARCPY","fde",-1),0)<0  End : Endif
#-----
#CHECK IGNORE_BEGIN
If !clalev([F:PCY]) : Local File PARCPY [PCY] : Endif

If [F:ACV]FLACT=2
    Raz [F:PCY]
    # Vérifier si déclinaison champs en-cours client (ou fournisseur) par société
    Case PARAM
        When "OSTCTL" :
            Read [PCY]PCY0 = 2
        When "OSTSCTL" :
            Read [PCY]PCY0 = 3
    Endcase
    # Si pas de gestion par société des en-cours => valeur="dossier(1)"...
    If fstat | !find("OSTCTL",[F:PCY]FLD)
        If TSTVALEUR="2"
            OK=0
            GMESSAGE = mess(6,199,1)
            GERR=1
        Endif
    # ... sinon valeur="société(2)"
    Else
        If TSTVALEUR="1"
            OK=0
            GMESSAGE = mess(6,199,1)
            GERR=1
        Endif
    Endif
Endif
#CHECK IGNORE_END
End

