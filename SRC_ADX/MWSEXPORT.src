#<AdxTL>@(#)2.0.0.0 $Revision$
$ACTION
Case ACTION
    When "EXP_ZONE" :        Gosub EXP_ZONE
Endcase
Return


###################################################################################
$EXP_ZONE
If EXPFIC="MWS" & GACTION="MESINT" : #interface MES
    If EXPZON="[F:MWS]WSTDES"
        If [F:MWS]WSTDES=""
            Call LECTEXTRA([F:MWS]WSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
        Elsif [F:MWS]WSTSHO=""
            Call LECTEXTRA([F:MWS]WSTSHO,"WORKSTATIO","WSTSHOAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
        Endif
    Endif
Endif
Return





