#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CREUSR2 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBRUSR
mkstat = 0
zoncou = "NBRUSR"
indice = 0
status = 1
zoncou = "NBRUSR"
If varmode([M]NBRUSR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRUSR" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRUSR
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRUSR = nolign
   status = 75
   Call SAI_NBRUSR(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBRUSR(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRUSR
mkstat = 0
zoncou = "NBRUSR"

## Zone FLGVAL
mkstat = 0
zoncou = "FLGVAL"
IMPENT = [M]FLGVAL(indice)
If varinit([M]FLGVAL,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGVAL,indice)=0
 [M]FLGVAL(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGVAL" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGVAL(indice)
 Endif
Endif
[M]FLGVAL(indice) = IMPENT

## Zone LEG
mkstat = 0
zoncou = "LEG"
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG(indice),"909","") From SUBADI
 GACTION = SAVACT
Endif

## Zone NBRUSR
mkstat = 0
zoncou = "NBRUSR"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CREUSR2"
Return

