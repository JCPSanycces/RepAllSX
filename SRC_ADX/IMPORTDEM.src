#<AdxTL>@(#)1.0.0.0 $Revision$
Call IMPORTATION("DEMANDE") From GIMPOBJ
End

###################################################################################
$ACTION

  Case ACTION
    When "OUVRE"     : Gosub OUVRE
    When "RAZCRE"    : Gosub RAZCRE
    When "SAIMSK"    : Gosub SAIMSK
    When "VALID"     : Gosub VALID
  Endcase
Return


###################################################################################
$OUVRE

  Local Mask DEM0 [DEM0], DEM1 [DEM1], DEM3 [DEM3]

  If clalev([F:DEM])=0 : Local File DEMANDE [DEM] : Endif
  If clalev([F:DML])=0 : Local File DEMLIG  [DML] : Endif

  nolign=0
Return

###################################################################################
$RAZCRE

  #Initialisation des masks et des variables
  Raz [M:DEM0], [M:DEM1], [M:DEM3]
  nolign=0
Return

Subprog CREATE_ADI(NUMTAB, CODE)
Value Integer NUMTAB
Value Char    CODE

  Readlock [F:ADI]CODE=NUMTAB;CODE
  If fstat>1 Then
    [F:ADI]NUMTAB = NUMTAB
    [F:ADI]CODE   = CODE
    Write [F:ADI]
  Endif
  If fstat
    GOK=0 : Call FSTA("ADI") From GLOCK : End
  Endif
End

###################################################################################
$SAIMSK

  #Affectation des masks
  Case IMPFIC
    When "DEM"
      [M:DEM0] = [F:DEM]
      [M:DEM1] = [F:DEM]
      [M:DEM3] = [F:DEM]
      # Création du domaine s'il n'existe pas
      If [F:DEM]DOM<>""    Then Call CREATE_ADI(381, [F:DEM]DOM)       : Endif
      # Création du thème s'il n'existe pas
      If [F:DEM]THM<>""    Then Call CREATE_ADI(457, [F:DEM]THM)       : Endif

    #Ligne
    When "DML"
#      nolign = [F:DML]NUMLIG
      nolign = [F:DML]NUMLIG+1 :# FQ93180 - SEGAY 24/10/13 - ligne de DML commence à 0
      [M:DEM0] = [F:DEM]
      [M:DEM1] = [F:DEM]
      [M:DEM3] = [F:DML]
#      [M:DEM3]NBRDEM += 1
#      [M:DEM3]STA(nolign)=[F:DML]STA
#      [M:DEM3]NBREMP(nolign)=[F:DML]NBREMP
      # Création de l'âge s'il n'existe pas
      If [F:DML]AGE<>""    Then Call CREATE_ADI(454, [F:DML]AGE)       : Endif
      # Création du type de financement s'il n'existe pas
      If [F:DML]TYPFIN<>"" Then Call CREATE_ADI(462, [F:DML]TYPFIN)    : Endif
      # Création de la catégorie 2483 sil elle n'existe pas
      If [F:DML]CATFRT<>"" Then Call CREATE_ADI(453, [F:DML]CATFRT)    : Endif
      Readlock [F:DML]DML0=[M:DEM0]DEMNUM;nolign-1 :# FQ93180 - SEGAY 24/10/13 - ligne de DML commence à 0
     If fstat>1
#        Gosub AFFECT_DML
        Write [F:DML]
      Elsif !fstat & [M:AOE1]OPTUPD=2
        Gosub AFFECT_DML
        Rewrite [F:DML]
      Endif
      If fstat
        GOK=0 : Call FSTA("DML") From GLOCK : Return
      Endif
  Endcase
Return

###################################################################################
$VALID

  GOK=1
  If nolign=0 : Return : Endif
  If GOK=0 : GERREUR=1 : Return : Endif

  Call DEBTRANS From GLOCK
  Gosub TR1
  If GOK<0 : GERREUR=1 : Goto AB_TR1 : Endif
Return

#######################################################################################
#                ENREGISTREMENT DES DONNEES DANS LES TABLES
#######################################################################################
$TR1

  Trbegin [DEM], [DML]

  Readlock [F:DEM]DEM0=[M:DEM0]DEMNUM
  If fstat>1
    Gosub AFFECT_DEM
    If dim([F:DEM]CREDAT)>0 : [F:DEM]CREDAT = date$ : Endif
    If dim([F:DEM]CREUSR)>0 : [F:DEM]CREUSR = GUSER : Endif
    If dim([F:DEM]CRETIM)>0 : [F:DEM]CRETIM = time  : Endif
    If dim([F:DEM]EXPNUM)>0 : [F:DEM]EXPNUM = [C]EXPORT : Endif
    Write [F:DEM]
    Call TRACE(0,mess(13,10717,1)-[M:DEM0]DEMNUM) From SUBIMPOBJ
  Elsif !fstat & [M:AOE1]OPTUPD=2
    Gosub AFFECT_DEM
    If dim([F:DEM]UPDDAT)>0 : [F:DEM]UPDDAT = date$ : Endif
    If dim([F:DEM]UPDUSR)>0 : [F:DEM]UPDUSR = GUSER : Endif
    If dim([F:DEM]UPDTIM)>0 : [F:DEM]UPDTIM = time  : Endif
    Rewrite [F:DEM]
    Call TRACE(1,mess(13,10717,1)-[M:DEM0]DEMNUM) From SUBIMPOBJ
  Endif
  If fstat
    GOK=0 : Call FSTA("DEM") From GLOCK : Return
  Endif

  Commit
Return

#########################
$AFFECT_DEM

  Raz [F:DEM]
  [F:DEM]=[M:DEM0]
  [F:DEM]=[M:DEM1]
  [F:DEM]=[M:DEM3]
Return

#########################
$AFFECT_DML

  Raz [F:DML]
  [F:DML]DEMNUM = [M:DEM0]DEMNUM
  [F:DML]=[M:DEM3]
#  [F:DML]NUMLIG=nolign
  [F:DML]NUMLIG=nolign-1 :# FQ93180 - SEGAY 24/10/13 - ligne de DML commence à 0
Return

#########################
$AB_TR1
Rollback
#Rollback suite à erreur dans la transaction
Call TRACE(2,mess(17,107,1)) From SUBIMPOBJ
Return
