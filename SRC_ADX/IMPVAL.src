#<AdxTL>@(#)1.0.0.0 $Revision$
#########################################################
## Import de variable de paye (modèle VALEUR)
#########################################################

$ACTION
Case ACTION
 When "IMP_OUVRE"     : Gosub IMP_OUVRE
 #When "IMP_VERIF_CRE" : Gosub IMP_VERIF_CRE
 #When "IMP_VERIF_MOD" : Gosub IMP_VERIF_MOD
 When "AP_IMPORT"     : Gosub AP_IMPORT
 When "EXP_OUVRE"     : Gosub EXP_OUVRE
 When "EXP_ZONE"      : Gosub EXP_ZONE
 When "IMP_FERME"     : Gosub IMP_FERME
Endcase
Return

$IMP_OUVRE
If clalev([F:ID])=0    : Local File EMPLOID  [ID]     : Endif
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR]  : Endif
If clalev([F:VEP])=0   : Local File VALEMP   [VEP]    : Endif
If clalev([F:VRA])=0   : Local File VARIA    [VRA]    : Endif
If clalev([F:CPY])=0   : Local File COMPANY  [CPY]    : Endif
If clalev([F:FCY])=0   : Local File FACILITY [FCY]    : Endif

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG : Endif
Return

$AP_IMPORT
[F:VLA]TYP = 4 : # Variable salarié
Gosub VERIF
Return

$IMP_VERIF_MOD
If GOK=0 : OK=0 : Endif
Return

$IMP_VERIF_CRE
If GOK=0 : OK=0 : Endif
Return

$VERIF
Look [ID]ID0 = [F:VLA]EMP
If fstat
 # Matricule inexistant
 Call TRACE(-2,[F:VLA]EMP-":"-mess(83,10702,1)) From SUBIMPOBJ
 GOK = 0 : Return
Endif
If GIMP(1)<>""
 Filter [HRCTR] Where REFNUM=[F:VLA]EMP & CTRNUM=GIMP(1)
 Read [HRCTR]CTR0 Last
 Filter [HRCTR]
 If fstat
  # Contrat inexistant
  Call TRACE(-2,GIMP(1)-":"-mess(26,10701,1)) From SUBIMPOBJ
  GOK=0 : Return
 Endif

 Call LECTURE("FCY",[F:HRCTR]ETRFCY,"") From CONTOBJ
 Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
 If dim([F:CPY]LEG)>0
  GCURLEG=[F:CPY]LEG
 Endif
 If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif

 Filter [VEP] Where EMP=[F:VLA]EMP & CTRNUM=GIMP(1)
Else
 Filter [VEP] Where EMP=[F:VLA]EMP
#JASMI - 2017-10-26 - X3-61464 - START
 Read [F:ID]ID0 = [F:VLA]EMP
 If fstat
  # Contrat inexistant
  Call TRACE(-2,[F:VLA]EMP-":"-mess(94,10717,1)) From SUBIMPOBJ
  GOK=0 : Return
 Endif
 Call LECTURE("FCY",[F:ID]FCYORI,"") From CONTOBJ
 GCURLEG=[F:FCY]LEG
#JASMI - 2017-10-26 - X3-61464 - END
Endif
Read [VEP]VEP0 Last
Filter [VEP]
If fstat>2
 # Paie inexistante
 Call TRACE(-2,[F:VLA]EMP-":"-mess(41,10702,1)) From SUBIMPOBJ
 GOK = 0 : Return
Endif
If [F:VLA]DAT=[0/0/0]
 [F:VLA]DAT = [F:VEP]PYRDAT
Elsif [F:VLA]DAT<>[F:VEP]PYRDAT
 # Date incorrecte
 Call TRACE(-2,[F:VLA]EMP-format$("D:"+GFMDAT4,[F:VLA]DAT)-":"-mess(78,10702,1)) From SUBIMPOBJ
 GOK = 0 : Return
Endif
If [F:VEP]PST>1
 # Feuille de paie non modifiable
 Call TRACE(-2,[F:VLA]EMP-format$("D:"+GFMDAT4,[F:VLA]DAT)-":"-mess(12,10703,1)) From SUBIMPOBJ
 GOK = 0 : Return
Endif
# Verrouillé US 2022 65062
If [F:VEP]FLGLOCK=2
 # Feuille de paie non modifiable Opération impossible : ce bulletin est verrouillé.
 Call TRACE(-2,[F:VLA]EMP-format$("D:"+GFMDAT4,[F:VLA]DAT)-":"-mess(224,10703,1)) From SUBIMPOBJ
 GOK = 0 : Return
Endif
# END 65062
Read [VRA]VRA0 = GCURLEG;[F:VLA]VARCOD
If fstat
 # Variable inexistante
 Call TRACE(-2,[F:VLA]VARCOD-":"-mess(13,10702,1)) From SUBIMPOBJ
 GOK = 0 : Return
Endif
If [F:VRA]FLGEMP<>2
 # Variable non modifiable
 Call TRACE(-2,[F:VLA]VARCOD-":"-mess(29,10702,1)) From SUBIMPOBJ
 GOK = 0 : Return
Endif
[F:VLA]BUL = [F:VEP]BUL
Return

$EXP_OUVRE
If clalev([F:VEP])=0  : Local File VALEMP [VEP]  : Endif
Return

$EXP_ZONE
If EXPZON="GIMP(1)"
 Read [VEP]VEP5=[F:VLA]BUL
 If !fstat
  GIMP(1) = [F:VEP]CTRNUM
 Endif
Endif
Return

$IMP_FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

