#<AdxTL>@(#)4.0.0.0 $Revision$ Gestion du fichier VALCPY
Local Char PARAM(10)(1..2) , VALEUR(10)
GACTION = "SAIVALPAY"
GFONC1 = "GESVCP"
Call TRAITE_CHAR(VALEUR,PARAM,"","SAIVALPAY","SAIVALPAY",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "AVANT_OUVRE" : Gosub AVANT_OUVRE
 When "OUVRE"       : Gosub OUVRE
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "RAZCRE"      : Gosub RAZCRE
 When "LIENS"       : Gosub LIENS
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "TITRE"       : Gosub TIT
 When "SETBOUT"     : Gosub SETBOUT
 When "ANNULE"      : Gosub ANNULE
 When "FILTRE"      : Gosub FILTRE
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "FERME"       : Gosub GIV_GLOB From SUBVFD
 When Default
Endcase
Return

$AVANT_OUVRE
Gosub SAV_GLOB From SUBVFD
# Window and screens, can be differents by legislation
# Then their generation needs to be execute everytime when the folder manage several legislation
# Not depending on general parameter like in V6
#Local Integer FLWIN
#Call LECTURE(FLWIN,10335) From SUBVFD
#If FLWIN
#MIPEA - 2018-06-07-  X3-94500- START
Call GENSOC(nomap) From GENSAI
#If GNBLEG>1
# Call GENSOC(nomap) From GENSAI
#Endif
#MIPEA - 2018-06-07-  X3-94500- END
#Call RAZFLAG(10335) From SUBVFD
#Endif
Return

$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET
Return

$OUVRE
If clalev ([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
Gosub CHARGE_TABLE
Local Char    TITFOLD(40)(1..12)
Return

$RAZCRE
Gosub CHARGE_TABLE
Return

$TIT
For I=1 To NBECRAN
 TITFOLD(I) = [M:VCP0]TABSHO(I-1)
Next I
Return

$CHARGE_TABLE
Local Integer NBECRAN
NBECRAN = 0
For [ADI]CODE Where NUMTAB=10335 & LEG=GCURLEG     #table diverse "société"
 NBECRAN += 1
 [M:VCP0]TABCOD(NBECRAN-1) = [F:ADI]CODE
 Call LECTEXTRA([M:VCP0]TABLIB(NBECRAN-1),"ATABDIV","LNGDES","10335",[F:ADI]CODE) From ATEXTRA
 Call LECTEXTRA([M:VCP0]TABSHO(NBECRAN-1),"ATABDIV","SHODES","10335",[F:ADI]CODE) From ATEXTRA
Next

#Initialisation des zones "CODPAG" des différents écrans

For I=1 To NBECRAN
 Gosub SETMASK
 [M]CODPAG = [M:VCP0]TABCOD(I-1)
 [M]LIBPAG = [M:VCP0]TABLIB(I-1)   #Initialisation du libellé de l'onglet
 Affzo CODPAG,LIBPAG
Next I
Return

$SETMASK
Case I
 When 1 : Default Mask [VCP1]
 When 2 : Default Mask [VCP2]
 When 3 : Default Mask [VCP3]
 When 4 : Default Mask [VCP4]
 When 5 : Default Mask [VCP5]
 When 6 : Default Mask [VCP6]
 When 7 : Default Mask [VCP7]
 When 8 : Default Mask [VCP8]
 When 9 : Default Mask [VCP9]
 When 10 : Default Mask [VCPA]
 When 11 : Default Mask [VCPB]
 When 12 : Default Mask [VCPC]
Endcase
Return

$FILTRE
FILTSUP = "[F:CPY]LEG='"+GCURLEG+"'"
Return

$FILGAUCHE
FILGAUSUP ="[F:CPY]LEG='"+GCURLEG+"'"
Return

$LIENS
Gosub CHARGE_TABLE
    For I=1 To NBECRAN
 Gosub SETMASK
 Raz [M]TBL
Next I
For [VLA]VLA0 Where TYP=2 & CPY=[F:VCP]CPY & DAT=[F:VCP]DAT
 Read [F:VRA]VRA0=GCURLEG;[F:VLA]VARCOD
 If !fstat
  I = find([F:VRA]PAGCPY,[M:VCP0]TABCOD(0..NBECRAN-1))
  Gosub SETMASK
 Endif
 If I
  nolign = [M]TBL+1
  [M] = [F:VLA]
  [M]VARCOD(nolign-1) = [F:VLA]VARCOD
  [M]VALEUR(nolign-1) = [F:VLA]VARVAL
  [M]RANG(nolign-1)   = [F:VRA]ROWCPY
  [M]TBL += 1
 Endif
Next
For I=1 To NBECRAN
 Gosub SETMASK
 Sorta [M]TBL [M]TBL Order By [M]RANG(indice)
Next I
Return


$CREATION
For I=1 To NBECRAN
 Gosub SETMASK
 For indice=0 To [M]TBL-1
  Raz [F:VLA]
  nolign = indice+1
  [F:VLA] = [M]
  [F:VLA]VARCOD = [M]VARCOD(indice)
  [F:VLA]VARVAL = [M]VALEUR(indice)
  [F:VLA]CPY = [M:VCP0]CPY
  [F:VLA]DAT = [M:VCP0]DAT
  [F:VLA]TYP = 2 : # Société
  [F:VLA]LEG = GCURLEG
  #[F:VLA]LEG = ""
  Write [VLA]
  If fstat : GOK=0 : Call FSTA("VLA") From GLOCK : Break : Endif
 Next indice
 If GOK<1 : Return : Endif
Next I
Return

#############################
$MODIF
Delete [VLA] Where TYP=2 and CPY=[F:VCP]CPY and DAT=[F:VCP]DAT
Goto CREATION
Return

########################################
$ANNULE
If clalev([F:VLA])=0 : Local File VALEUR [VLA] : Endif
Delete [VLA] Where TYP=2 & CPY=[F:VCP]CPY & DAT=[F:VCP]DAT
If fstat
 GOK = -1 : GLOCK = "$VALEUR" : Return
Endif
Return

########################################
$SEL_TABLE
Case TABLE
 When "SELVRA2"
 OBJET = "VRA"
 START = "COD"
 ORDRE = "COD"
 Case GABREV
  When "VCP"
   CRITERE = 'FLGCPY=2 & PAGCPY="'+[M]CODPAG+'"'
  When "VFC"
   CRITERE = 'FLGFCY=2 & PAGFCY="'+[M]CODPAG+'"'
  When "VFD"
   CRITERE = 'FLGFDR=2 & PAGFDR="'+[M]CODPAG+'"'
  When "VEP"
    #FRLAA - 2016-04-13 - REQUIREMENT 114309 US 112 - START
    # Test is done on actiivty code and not legislation - will be applicable for all SA development
    If func DIVPAYE.IS_ZA_DEV()
      OBJET = "CVR"
      If [M:VEP1]PRF <> ""
        CRITERE = 'PRFCOD = "'+[M:VEP1]PRF+'"' + ' & FLGEMP=2 & ENAFLG=2 & PAGEMP="'+[M]CODPAG+'"'
      Else
        CRITERE = 'FLGEMP=2 & PAGEMP="'+[M]CODPAG+'"'
      Endif
    Else
        CRITERE = 'FLGEMP=2 & PAGEMP="'+[M]CODPAG+'"'
    Endif
    #CRITERE = 'FLGEMP=2 & PAGEMP="'+[M]CODPAG+'"'
    #FRLAA - 2016-04-13 - REQUIREMENT 114309 US 112 - END
 Endcase
 CRITERE -= '& LEG="'+GCURLEG+'"'
Endcase
Return

########################################
Subprog AS_VARCOD(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Gosub SETNOL
 Gosub VERF_ACCES
Endif
End

Subprog C_VARCOD(VALEUR)
Variable Char    VALEUR()
Local Integer IND   #récupère l'indice du tableau des codes
#contrôle de cohérence.........

Call LECTURE("VRA",VALEUR,GCURLEG) From CONTOBJ
If [F:VRA]FLGCPY<>2
 #variable non saisie au niveau de la société
 Call ERREUR(mess(35,10702,1)) From GESECRAN
 mkstat = 2 : End
Else
 IND = find([VRA]PAGCPY,[M:VCP0]TABCOD(0..7))
 If IND
  If [M]CODPAG<>[M:VCP0]TABCOD(IND-1)
   Call ERREUR (mess(30,10702,1)-num$([M:VCP0]TABSHO(IND-1))) From GESECRAN
# Variable à saisir dans l'onglet
   mkstat = 2 : End
  Endif
 Endif
Endif

#contrôle d'unicité sur la colonne
Call UNICITE(VALEUR,[M]VARCOD) From OBJDIV
# contrôle code d'accès
If VALEUR<>[M]VARCOD(nolign-1) & [F:VRA]CODACC<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;ACCES
 If fstat or [F:ACC]EXEC<>2
  GMESSAGE = mess(41,10703,1)-[M]VARCOD(nolign-1) : # Accès interdit à cette variable
  mkstat = 2 : End
 Endif
Endif
If [F:VRA]CODACT<>""
 Read [ACV]CODACT = [F:VRA]CODACT
 If fstat or [F:ACV]FLACT<>2
  GMESSAGE = mess(42,10703,1) : # Variable inactive
  mkstat = 2 : End
 Endif
Endif
End

Subprog C_DAT(VALEUR)
Variable Date    VALEUR
End

Subprog D_DATF(VALEUR)
Variable Date    VALEUR
Filter [F:VCP] Where [F:VCP]CPY=[M:VCP0]CPY & [F:VCP]DAT>[M:VCP0]DAT
Read [F:VCP]VCP0 First
If fstat<=2 : VALEUR = [F:VCP]DAT-1 : Else : VALEUR = [0/0/0] : Endif
Filter [VCP]
End

Subprog C_TBL
Gosub SETNOL
If status=65
 Gosub VERF_ACCES
Elsif status=68 or status=83
 For NOL=nolign-1 To nolign1-1
  Gosub VERF_ACCES
  If mkstat : Break : Endif
 Next
Endif
If mkstat
 GMESSAGE = mess(41,10703,1)-[M]VARCOD(NOL)
Endif
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

$VERF_ACCES
If GUSRACS<>2
 Call LECTURE("VRA",[M]VARCOD(NOL),GCURLEG) From CONTOBJ
 If [F:VRA]CODACC<>""
  Read [ACC]CODACC = GUSER;[F:VRA]CODACC
  If fstat or [F:ACC]EXEC<>2 : mkstat = 2 : Endif
 Endif
Endif
Return

Subprog B1_TBL
Local Integer NBVAR
NBVAR=0
For [VRA]VRA0 Where FLGCPY=2 & PAGCPY=[M]CODPAG & LEG=GCURLEG
 #60421
 OK=1
 If [F:VRA]CODACT<>""
  Read [ACV]CODACT = [F:VRA]CODACT
  If fstat | [F:ACV]FLACT<>2 : OK=0 :   Endif
 Endif
 #
 If OK & !find([F:VRA]COD,[M]VARCOD(0..[M]TBL-1))
  [M]VARCOD([M]TBL) = [F:VRA]COD
  [M]TBL += 1
  NBVAR +=1
 Endif
Next
If NBVAR=0
 # Aucune variable a précharger
 Call MESSAGE(mess(90,10702,1)) From GESECRAN
Else
 Affzo 10
 mkstat = 4
Endif
End

Subprog AS_VALEUR(VALEUR)
Variable Decimal VALEUR()
Gosub SETNOL
Gosub VERF_ACCES
End


######################################################################################

