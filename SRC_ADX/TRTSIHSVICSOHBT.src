$ACTION_GS

  Case GWACTION_GS
    When "READ_DETAIL"
      Gosub READ_DETAIL
    When "MSK_ENTETE"
      Gosub MSK_ENTETE From TRTSIHSVICSOH
    When "MSK_DETAIL"
      Gosub MSK_DETAIL From TRTSIHSVICSOH
    When "ERREUR"
      Gosub ERREUR
    When "CREATION"
      #Call ECR_TRACE(mess(51,197,1)-mess(1016,182,1)-[F:SIH]NUM,0) From GESECRAN
  Endcase

Return
