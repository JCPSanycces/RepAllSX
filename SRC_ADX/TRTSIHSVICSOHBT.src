$READ_DETAIL

  nolign = 0
  LIG_DETAIL = "C" # uniquement de la creation
  If LEC_DETAIL = 0 Then
    LEC_DETAIL=1
  Else
    Read [SVICLNK] Next
    If !fstat

    Elsif fstat = 4 Then
      # fin lecture
      LEC_DETAIL = 2
      Raz [SVICD]
    Else
      # erreur
      LEC_DETAIL = 3
      Raz [SVICD]
    Endif
  Endif

  #--A VIRER !! pour mock
  #GCPO_NBREAD+=1
  ##Call ECR_TRACE("Itérations : "+num$(GCPO_NBREAD),0) From GESECRAN
  #If GCPO_NBREAD>150 : Raz [SVICD] : LEC_DETAIL=3 : Return Endif
  #--

Return
