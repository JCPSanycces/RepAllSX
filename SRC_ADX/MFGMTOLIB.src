#<AdxTL>@(#)12.0.0.0 $Revision$
#---------------------------------------------------------------------------#
# voir aussi MFGMTOLIB,SCOMTOLIB,PURMTOLIB,SALMTOLIB en cas de mise à jour  #
#---------------------------------------------------------------------------#
# $AVANT_MODFIC    Action  AVANT_MODFIC         de SUBMFGA
# $MAJ_MTO_AP_ALL  Actions APRES_CRE, APRES_MOD de SUBMFGA
# $SUP_MTO_AV_ALL  Action  AV_ANNULE            de SUBMFGA
# $VERF_ANU        Action  VERF_ANU             de SUBMFGA
# $TEST_ANU_LIG    Etiq    TEST_ANU             de SUBMFGA
#---------------------------------------------------------------------------#
# $SUP_MTO_MFI     Appel de SUP_OFFP         MFGAUTLIB
# $SUP_MTO_MFM     Appel de SUP_OFFP,MAJ_MAT MFGAUTLIB
# $MAJ_MTO_MFI     Appel de MAJ_OF  ,CREMFI  MFGAUTLIB
# $MAJ_MTO_MFM     Appel de MAJ_OF  ,GEN_MAT MFGAUTLIB
# $CRE_MTO_SO_WO   Appel de CRE_OFFP         MFGAUTLIB
# $CTL_MAJ_OFFP    Appel de C_MFGSTA         SUBMFG
#---------------------------------------------------------------------------#
# FQ 73203 GA 04/2011 Problème suite FQ 71360 remplacer [ORD1] par [ORDB]
#                     sinon à l'ouverture on perd la classe [F] en création d'OF
########################################################################
$AVANT_MODFIC
Local Integer I

Gosub CHECK_MTO From MTOLINKLIB

# V6 Affectations
# ici il faut supprimer les affectations des:
#     - OFs passés de ferme à planifié
#     - articles lancés présents dans l'OF avant modification et absents du tableau
#     - articles lancés soldés
#     - matières exclues/soldées
# car la suppression des affectations s'appuie sur les encours

# les articles lancés supprimés
For [MFI]MFI0 Where MFGNUM = [M:MFG0]MFGNUM
    If !find([F:MFI]MFGLIN,[M:MFG1]MFGLIN(0..[M:MFG1]NBLIG - 1)) : Gosub SUP_MTO_AV_MFI : Endif
Next

If [M:MFG0]MFGSTA = 2 & [F:MFG]MFGSTA = 1
   # si passage de ferme à planifié
   Gosub SUP_MTO_AV_ALL

Else
   # les articles lancés soldés
    For I = 0 To [M:MFG1]NBLIG - 1
     If [M:MFG1]ITMSTA(I) > 2
         Gosub SUP_MTO_AV_MFG1
     Endif
   Next I

   # les matières soldées, exclues
   For I = 0 To [M:MFG2]NBLIG - 1
       If [M:MFG2]MATSTA(I) > 2 & [M:MFG2]CPNTYP(I) = 1
          Gosub SUP_MTO_AV_MFG2
       Endif
   Next I
Endif
Return

#########################################################################
$SUP_MTO_AV_ALL
Local Integer I

Gosub CHECK_MTO From MTOLINKLIB

# boucle sur les articles lancés
For I = 0 To [M:MFG1]NBLIG - 1

    # raz des affectations
    Raz [M:MLIK]
    ## GH 18/06/12
    #If func MTOLINKLIB.IS_DIRECT_ORDER([M:MFG0]MFGFCY, 10, [M:MFG0]MFGNUM, [M:MFG1]MFGLIN(I), 0)
    #    [M:MLIK]FMIFLG = 9  # pour forcer la suppression
    #Else
    #    [M:MLIK]FMIFLG = 1
    #Endif
    [M:MLIK]MAJCOD    = "Z"
    [M:MLIK]STOFCY    = [M:MFG0]MFGFCY
    [M:MLIK]ITMREF    = [M:MFG1]ITMREF(I)
    [M:MLIK]RESSTYP   = 10
    [M:MLIK]RESSNUM   = [M:MFG0]MFGNUM
    [M:MLIK]RESSLIN   = [M:MFG1]MFGLIN(I)
    [M:MLIK]RESSSEQ   = 0
    [M:MLIK]FRCPRO    = 2                # pour supprimer les affectations forcées
    [M:MLIK]FMIFLG    = 9                # pour supprimer les affectations de contremarque  # GH 18/06/12
    [M:MLIK]FEEDBACK  = 1

    GOK=1
    Call UPDMTOLINK From MTOLINKLIB
    GOK=1
Next I

# boucle sur les matières
For I = 0 To [M:MFG2]NBLIG - 1

    If [M:MFG2]CPNTYP(I) <> 1 : Goto NXT_SUP_MTOMT : Endif

    # raz des affectations
    Raz [M:MLIK]
    [M:MLIK]MAJCOD    = "Z"
    [M:MLIK]STOFCY    = [M:MFG0]MFGFCY
    [M:MLIK]ITMREF    = [M:MFG2]ITMREF(I)
    [M:MLIK]DEMTYP    = 10
    [M:MLIK]DEMNUM    = [M:MFG0]MFGNUM
    [M:MLIK]DEMLIN    = [M:MFG2]MFGLIN(I)
    [M:MLIK]DEMSEQ    = [M:MFG2]BOMSEQ(I)
    [M:MLIK]DWIPTYP   = 6
    [M:MLIK]FRCPRO    = 2                # pour supprimer les affectations forcées
    [M:MLIK]FEEDBACK  = 1

    GOK=1
    Call UPDMTOLINK From MTOLINKLIB
    GOK=1
$NXT_SUP_MTOMT
Next I
Return

