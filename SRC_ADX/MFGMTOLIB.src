#########################################################################
$VERF_ANU
Local Integer I, WRET

Gosub CHECK_MTO From MTOLINKLIB

For I = 0 To [M:MFG1]NBLIG - 1
    WRET = 0
    Call CHECK_FRCQTY([M:MFG0]MFGFCY, [M:MFG1]ITMREF(I), 10, [M:MFG0]MFGNUM, [M:MFG1]MFGLIN(I), 0, 5, WRET) From MTOLINKLIB
    If WRET
        # lecture règle si nécessaire
        If [F:PTO]PTOCOD <> [M:MFG1]PTOCOD(I)
            Read [PTO]PTO0=[M:MFG1]PTOCOD(I)
            If fstat : Raz [F:PTO] : Endif
        Endif
        If [F:PTO]FRCPRO <> 2
            OK = 1
            # Les affectations forcées pour cet ordre de fabrication vont être supprimées. \Souhaitez vous continuer ?
            Call OUINON(mess(227,190,1),OK) From GESECRAN
            If OK = 1 : OK = 0 : Break : Endif
        Endif
    Endif
Next I

Return

#########################################################################
$TEST_ANU_LIG
Local Integer WRET

Gosub CHECK_MTO From MTOLINKLIB

WRET = 0
Call CHECK_FRCQTY([M:MFG0]MFGFCY, [M:MFG1]ITMREF(nolign-1), 10, [M:MFG0]MFGNUM, [M:MFG1]MFGLIN(nolign-1), 0, 5, WRET) From MTOLINKLIB
If WRET
    # lecture règle si nécessaire
    If [F:PTO]PTOCOD <> [M:MFG1]PTOCOD(nolign-1)
        Read [PTO]PTO0=[M:MFG1]PTOCOD(nolign-1)
        If fstat : Raz [F:PTO] : Endif
    Endif
    If [F:PTO]FRCPRO <> 2
        OK = 1
        # Les affectations forcées pour cet ordre de fabrication vont être supprimées. \Souhaitez vous continuer ?
        Call OUINON(mess(227,190,1),OK) From GESECRAN
        If OK = 1 : mkstat = 2 : Endif
    Endif
Endif
Return

#########################################################################
$CTL_MAJ_OFFP
# passage du statut Ferme à Planifié: ctrl de présence d'affectations
Local Integer I, IFRC, WRET

Gosub CHECK_MTO From MTOLINKLIB

IFRC = 0
For I = 0 To [M:MFG1]NBLIG - 1
    WRET = 0
    Call CHECK_FRCQTY([M:MFG0]MFGFCY, [M:MFG1]ITMREF(I), 10, [M:MFG0]MFGNUM, [M:MFG1]MFGLIN(I), 0, 5, WRET) From MTOLINKLIB
    If WRET
        # lecture règle si nécessaire
        If [F:PTO]PTOCOD <> [M:MFG1]PTOCOD(I)
            Read [PTO]PTO0=[M:MFG1]PTOCOD(I)
            If fstat : Raz [F:PTO] : Endif
        Endif
        If [F:PTO]FRCPRO <> 2 : IFRC = 1 : Break : Endif
    Endif
Next

OK = 2
If IFRC
  # Les affectations forcées pour cet ordre de fabrication vont être supprimées. \Souhaitez vous continuer ?
  Call OUINON(mess(227,190,1),OK) From GESECRAN
Endif
Return

#########################################################################
$MAJ_MTO_AP_ALL
Local Integer I, K,  N
Local Libelle WMTOMAJ
Local Decimal WDEMQTY, WFRCQTY
#Local Integer WTYP2, WLIN2, WSEQ2
#Local Char    WNUM2(GLONVCR)

I = [M:MFG1]NBLIG + [M:MFG2]NBLIG
If I>0
 Local Char    TITM(GLONITM) (I)
 Local Libelle TFRC(I)
Endif

Gosub CHECK_MTO From MTOLINKLIB

# boucle sur les articles
For I = 0 To [M:MFG1]NBLIG - 1

    # si contremarque, on modifie la qté de l'affectation
    If func MTOLINKLIB.IS_DIRECT_ORDER([M:MFG0]MFGFCY, 10, [M:MFG0]MFGNUM, [M:MFG1]MFGLIN(I), 0)
# GH 09/07/2014 bug 101361
#        Call GET_DIRECT_ORDER([M:MFG0]MFGFCY, [M:MFG1]ITMREF(I), 10, [M:MFG0]MFGNUM, [M:MFG1]MFGLIN(I), 0, 5,
#&                             WTYP2, WNUM2, WLIN2, WSEQ2) From MTOLINKLIB
        GOK=0
        If !clalev([F:ORDB]) :  Local File ORDERS   [ORDB] : Endif
        Filter [ORDB] Where ITMREF=[M:MFG1]ITMREF(I)
        Read [ORDB]ORD3 = [M:MFG0]MFGFCY;2;[M:MFG1]VCRNUMORI(I);[M:MFG1]VCRLINORI(I);[M:MFG1]VCRSEQORI(I)
        #Read [ORDB]ORD3 = [M:MFG0]MFGFCY;2;WNUM2;WLIN2;WSEQ2
        If !fstat
            WDEMQTY = [F:ORDB]RMNEXTQTY - [F:ORDB]ALLQTY
            Filter [ORDB] Where WIPTYP=5 & ITMREF=[M:MFG1]ITMREF(I)
            Read [ORDB]ORD3 = [M:MFG0]MFGFCY;10;[M:MFG0]MFGNUM;[M:MFG1]MFGLIN(I);0
            If !fstat
               WDEMQTY = min([F:ORDB]RMNEXTQTY,WDEMQTY)               # 05.2011
               GOK=1
            Endif
        Endif
        Filter [ORDB]
        If !GOK : GOK=1 : Goto NXT_MAJ_MTOI : Endif

        Trbegin [MLK]
            Raz [M:MLIK]
            [M:MLIK]MAJCOD  = "M"
            [M:MLIK]ITMREF  = [M:MFG1]ITMREF(I)
            [M:MLIK]STOFCY  = [M:MFG0]MFGFCY
            # la demande
            [M:MLIK]DEMTYP  = 2
            #[M:MLIK]DEMNUM  = WNUM2
            #[M:MLIK]DEMLIN  = WLIN2
            #[M:MLIK]DEMSEQ  = WSEQ2
            [M:MLIK]DEMNUM  = [M:MFG1]VCRNUMORI(I)
            [M:MLIK]DEMLIN  = [M:MFG1]VCRLINORI(I)
            [M:MLIK]DEMSEQ  = [M:MFG1]VCRSEQORI(I)
            [M:MLIK]DWIPTYP = 1
            # la ressource
            [M:MLIK]RESSTYP = 10
            [M:MLIK]RESSNUM = [M:MFG0]MFGNUM
            [M:MLIK]RESSLIN = [M:MFG1]MFGLIN(I)
            [M:MLIK]RESSSEQ = 0
            # la quantité
            [M:MLIK]LIKQTY  = WDEMQTY
            [M:MLIK]FRCFLG  = 2
            [M:MLIK]FMIFLG  = 2

            Call UPDMTOLINK             From MTOLINKLIB
            If GOK>0 & ![M:MLIK]RET : # GH 13/10/2015 bug 111344 [M:MLIK]RET<>0 indicates something is wrong
             Call UPDORDERS_FROM_MLIK    From MTOLINKLIB
            Endif
        If GOK : Commit : Else : Rollback : Endif

        Goto NXT_MAJ_MTOI
    Endif

    # lecture règle si nécessaire
    If [F:PTO]PTOCOD <> [M:MFG1]PTOCOD(I)
        Read [PTO]PTO0=[M:MFG1]PTOCOD(I)
        If fstat : Raz [F:PTO] : Endif
    Endif

    WMTOMAJ = ([F:PTO]PTOREAL=2 & [F:PTO]REAL4RESS=2)

    If WMTOMAJ
        K=find([M:MFG1]ITMREF(I),TITM(0..N-1))-1
        If K<0
           TITM(N)=[M:MFG1]ITMREF(I)
           TFRC(N)=1+([F:PTO]FRCPRO=2)
           K=N : N+=1
        Endif
    Endif

    If !WMTOMAJ | TFRC(K) <> 2
       If !clalev([F:ORDB]) :  Local File ORDERS   [ORDB] : Endif
       Filter [ORDB] Where WIPTYP=5 & ITMREF=[M:MFG1]ITMREF(I)
       Read [ORDB]ORD3 = [M:MFG0]MFGFCY;10;[M:MFG0]MFGNUM;[M:MFG1]MFGLIN(I);0
       Filter [ORDB]
       If !fstat
        If !WMTOMAJ
            Call GET_FRCQTY([M:MFG0]MFGFCY, [M:MFG1]ITMREF(I), -10, [M:MFG0]MFGNUM, [M:MFG1]MFGLIN(I), 0, 5, WDEMQTY) From MTOLINKLIB
         Endif
         Call GET_FRCQTY([M:MFG0]MFGFCY, [M:MFG1]ITMREF(I), 10, [M:MFG0]MFGNUM, [M:MFG1]MFGLIN(I), 0, 5, WFRCQTY) From MTOLINKLIB
         If WFRCQTY > [F:ORDB]RMNEXTQTY | (!WMTOMAJ & WDEMQTY > [F:ORDB]RMNEXTQTY) : # ressource sur-affectée
            GOK=1
            Trbegin [MLK]
                Raz [M:MLIK]
                If !WMTOMAJ
                    [M:MLIK]MAJCOD    = "R"
                    [M:MLIK]PRPTYP    = 1                # annule & remplace
                    [M:MLIK]PRPMOD    = 1                # mise à jour
                Else
                    [M:MLIK]MAJCOD    = "Z"
                Endif
                [M:MLIK]STOFCY    = [M:MFG0]MFGFCY
                [M:MLIK]ITMREF    = [M:MFG1]ITMREF(I)
                [M:MLIK]RESSTYP   = 10
                [M:MLIK]RESSNUM   = [M:MFG0]MFGNUM
                [M:MLIK]RESSLIN   = [M:MFG1]MFGLIN(I)
                [M:MLIK]RESSSEQ   = 0
                [M:MLIK]FRCPRO    = 1 + (WMTOMAJ | WFRCQTY > [F:ORDB]RMNEXTQTY)
                [M:MLIK]FEEDBACK  = 1
                Call UPDMTOLINK From MTOLINKLIB
            If GOK>0 : Commit : Else Rollback : Endif
         Endif
       Endif
    Endif

$NXT_MAJ_MTOI
Next I

# boucle sur les matières
For I = 0 To [M:MFG2]NBLIG - 1

    # si matière soldée ou exclue
    If [M:MFG2]MATSTA(I) > 2  : Goto NXT_MAJ_MTOM : Endif

    If [M:MFG2]CPNTYP(I) <> 1 : Goto NXT_MAJ_MTOM : Endif

    # lecture règle si nécessaire
    If [F:PTO]PTOCOD <> [M:MFG2]PTOCOD(I)
        Read [PTO]PTO0=[M:MFG2]PTOCOD(I)
        If fstat : Raz [F:PTO] : Endif
    Endif

    WMTOMAJ = ([F:PTO]PTOREAL=2 & [F:PTO]REAL4DEM=2)

    If WMTOMAJ
        K=find([M:MFG2]ITMREF(I),TITM(0..N-1))-1
        If K<0
           TITM(N)=[M:MFG2]ITMREF(I)
           TFRC(N)=1+([F:PTO]FRCPRO=2)
           K=N : N+=1
        Endif
    Endif

    If !WMTOMAJ | TFRC(K) <> 2
       If !clalev([F:ORDB]) :  Local File ORDERS   [ORDB] : Endif
       Filter [ORDB] Where WIPTYP=6 & ITMREF=[M:MFG2]ITMREF(I)
       Read [ORDB]ORD3 = [M:MFG0]MFGFCY;10;[M:MFG0]MFGNUM;[M:MFG2]MFGLIN(I);[M:MFG2]BOMSEQ(I)
       Filter [ORDB]
       If !fstat
         If !WMTOMAJ
            Call GET_FRCQTY([M:MFG0]MFGFCY, [M:MFG2]ITMREF(I), -10, [M:MFG0]MFGNUM, [M:MFG2]MFGLIN(I), [M:MFG2]BOMSEQ(I), 6, WDEMQTY) From MTOLINKLIB
         Endif
         Call GET_FRCQTY([M:MFG0]MFGFCY, [M:MFG2]ITMREF(I), 10, [M:MFG0]MFGNUM, [M:MFG2]MFGLIN(I), [M:MFG2]BOMSEQ(I), 6, WFRCQTY) From MTOLINKLIB
         If WFRCQTY > ([F:ORDB]RMNEXTQTY-[F:ORDB]ALLQTY) | (!WMTOMAJ & WDEMQTY > ([F:ORDB]RMNEXTQTY- [F:ORDB]ALLQTY))
            # demande sur-affectée
            GOK=1
            Trbegin [MLK]
                Raz [M:MLIK]
                If !WMTOMAJ
                    [M:MLIK]MAJCOD    = "R"
                    [M:MLIK]PRPTYP    = 1                # annule & remplace
                    [M:MLIK]PRPMOD    = 1                # mode mise à jour
                Else
                    [M:MLIK]MAJCOD    = "Z"
                Endif
                [M:MLIK]STOFCY    = [M:MFG0]MFGFCY
                [M:MLIK]ITMREF    = [M:MFG2]ITMREF(I)
                [M:MLIK]DEMTYP    = 10
                [M:MLIK]DEMNUM    = [M:MFG0]MFGNUM
                [M:MLIK]DEMLIN    = [M:MFG2]MFGLIN(I)
                [M:MLIK]DEMSEQ    = [M:MFG2]BOMSEQ(I)
                [M:MLIK]DWIPTYP   = 6
                [M:MLIK]FRCPRO    = 1 + (WMTOMAJ | WFRCQTY > ([F:ORDB]RMNEXTQTY- [F:ORDB]ALLQTY))
                [M:MLIK]FEEDBACK  = 1
                Call UPDMTOLINK From MTOLINKLIB
            If GOK>0 : Commit : Else Rollback : Endif
         Endif
       Endif
    Endif

$NXT_MAJ_MTOM
Next I

For I = 0 To N - 1
   # recalcul complet des affectations de l'article suivant la règle
   GOK=1
   Trbegin [MLK]
        Raz [M:MLIK]
        [M:MLIK]MAJCOD    = "P"
        [M:MLIK]PRPTYP    = 1                    # annule & remplace
        [M:MLIK]PRPMOD    = 1                    # mode mise à jour
        [M:MLIK]STOFCY    = [M:MFG0]MFGFCY
        [M:MLIK]ITMREF    = TITM(I)
        [M:MLIK]FEEDBACK  = 1
        [M:MLIK]FRCPRO    = TFRC(I)
        Call UPDMTOLINK From MTOLINKLIB
    If GOK>0 : Commit : Else Rollback : Endif
Next I
Return

#########################################################################
$MAJ_MTO_MFI
Local Decimal WDEMQTY, WFRCQTY
Local Libelle WMTOMAJ
Local Char    WPTOCOD(GLONPTO) : # V6 Règle d'affectation
#Local Integer WTYP2, WLIN2, WSEQ2
#Local Char    WNUM2(GLONVCR)

Gosub CHECK_MTO From MTOLINKLIB

If func MTOLINKLIB.IS_DIRECT_ORDER([F:MFI]MFGFCY, 10, [F:MFI]MFGNUM, [F:MFI]MFGLIN, 0)
# GH 09/07/2014 bug 101361
#    Call GET_DIRECT_ORDER([F:MFI]MFGFCY, [F:MFI]ITMREF, 10,  [F:MFI]MFGNUM, [F:MFI]MFGLIN, 0, 5,
#&                          WTYP2, WNUM2, WLIN2, WSEQ2) From MTOLINKLIB
    GOK=0
    If !clalev([F:ORDB]) :  Local File ORDERS   [ORDB] : Endif
    Filter [ORDB] Where ITMREF = [F:MFI]ITMREF
    Read [ORDB]ORD3 = [F:MFI]MFGFCY;2;[F:MFI]VCRNUMORI;[F:MFI]VCRLINORI;[F:MFI]VCRSEQORI
    #Read [ORDB]ORD3 = [F:MFI]MFGFCY;2;WNUM2;WLIN2;WSEQ2
    If !fstat
        WDEMQTY = [F:ORDB]RMNEXTQTY - [F:ORDB]ALLQTY
        Filter [ORDB] Where WIPTYP=5 & ITMREF=[F:MFI]ITMREF
        Read [ORDB]ORD3 = [F:MFI]MFGFCY;10;[F:MFI]MFGNUM;[F:MFI]MFGLIN;0
        If !fstat
           WDEMQTY = min([F:ORDB]RMNEXTQTY,WDEMQTY)               # 05.2011
           GOK=1
        Endif
    Endif
    Filter [ORDB]
    If !GOK : GOK=1 : Return : Endif

    Raz [M:MLIK]
    [M:MLIK]MAJCOD  = "M"
    [M:MLIK]ITMREF  = [F:MFI]ITMREF
    [M:MLIK]STOFCY  = [F:MFI]MFGFCY
    # la demande
    [M:MLIK]DEMTYP  = 2
    #[M:MLIK]DEMNUM  = WNUM2
    #[M:MLIK]DEMLIN  = WLIN2
    #[M:MLIK]DEMSEQ  = WSEQ2
    [M:MLIK]DEMNUM  = [F:MFI]VCRNUMORI
    [M:MLIK]DEMLIN  = [F:MFI]VCRLINORI
    [M:MLIK]DEMSEQ  = [F:MFI]VCRSEQORI
    [M:MLIK]DWIPTYP = 1
    # la ressource
    [M:MLIK]RESSTYP = 10
    [M:MLIK]RESSNUM = [F:MFI]MFGNUM
    [M:MLIK]RESSLIN = [F:MFI]MFGLIN
    [M:MLIK]RESSSEQ = 0
    # la quantité
    [M:MLIK]LIKQTY  = WDEMQTY
    [M:MLIK]FRCFLG  = 2
    [M:MLIK]FMIFLG  = 2

    Call UPDMTOLINK             From MTOLINKLIB
    If GOK>0 & ![M:MLIK]RET : # GH 13/10/2015 bug 111344 [M:MLIK]RET<>0 indicates something is wrong
     Call UPDORDERS_FROM_MLIK    From MTOLINKLIB
    Endif

    Return
Endif

WPTOCOD = func ITMLIB.GET_PTOCOD([F:MFI]ITMREF,[F:MFI]MFGFCY)
# lecture règle si nécessaire
If [F:PTO]PTOCOD <> WPTOCOD
   Read [PTO]PTO0=WPTOCOD
   If fstat : Raz [F:PTO] : Endif
Endif

WMTOMAJ = ([F:PTO]PTOREAL=2 & [F:PTO]REAL4RESS=2)

If !WMTOMAJ | [F:PTO]FRCPRO <> 2
   If !clalev([F:ORDB]) :  Local File ORDERS   [ORDB] : Endif
   Filter [ORDB] Where WIPTYP=5 & ITMREF=[F:MFI]ITMREF
   Read [ORDB]ORD3 = [F:MFI]MFGFCY;10;[F:MFI]MFGNUM;[F:MFI]MFGLIN;0
   Filter [ORDB]
   If !fstat
     If !WMTOMAJ
        Call GET_FRCQTY([F:MFI]MFGFCY, [F:MFI]ITMREF, -10, [F:MFI]MFGNUM, [F:MFI]MFGLIN, 0, 5, WDEMQTY) From MTOLINKLIB
     Endif
     Call GET_FRCQTY([F:MFI]MFGFCY, [F:MFI]ITMREF, 10, [F:MFI]MFGNUM, [F:MFI]MFGLIN, 0, 5, WFRCQTY) From MTOLINKLIB
     If WFRCQTY > [F:ORDB]RMNEXTQTY | (!WMTOMAJ & WDEMQTY > [F:ORDB]RMNEXTQTY) : # ressource sur-affectée
        Raz [M:MLIK]
        If !WMTOMAJ
            [M:MLIK]MAJCOD    = "R"
            [M:MLIK]PRPTYP    = 1                # annule & remplace
            [M:MLIK]PRPMOD    = 1                # mode mise à jour
        Else
            [M:MLIK]MAJCOD    = "Z"
        Endif
        [M:MLIK]STOFCY    = [F:MFI]MFGFCY
        [M:MLIK]ITMREF    = [M:MFG1]ITMREF(I)
        [M:MLIK]RESSTYP   = 10
        [M:MLIK]RESSNUM   = [F:MFI]MFGNUM
        [M:MLIK]RESSLIN   = [F:MFI]MFGLIN
        [M:MLIK]RESSSEQ   = 0
        [M:MLIK]FRCPRO    = 1 + (WMTOMAJ | WFRCQTY > [F:ORDB]RMNEXTQTY)
        [M:MLIK]FEEDBACK  = 1
        GOK=1
        Call UPDMTOLINK From MTOLINKLIB
     Endif
   Endif
Endif

If WMTOMAJ
    # recalcul complet des affectations de l'article suivant la règle
    Raz [M:MLIK]
    [M:MLIK]MAJCOD    = "P"
    [M:MLIK]PRPTYP    = 1                    # annule & remplace
    [M:MLIK]PRPMOD    = 1                    # mode mise à jour
    [M:MLIK]STOFCY    = [F:MFI]MFGFCY
    [M:MLIK]ITMREF    = [F:MFI]ITMREF
    [M:MLIK]FRCPRO    = [F:PTO]FRCPRO
    [M:MLIK]FEEDBACK  = 1
    GOK=1
    Call UPDMTOLINK From MTOLINKLIB
Endif
Return

#########################################################################
$MAJ_MTO_MFM
Local Char    WPTOCOD(GLONPTO)
Local Decimal WFRCQTY, WDEMQTY
Local Libelle WMTOMAJ

Gosub CHECK_MTO From MTOLINKLIB

# pas de contremarque

WPTOCOD = func ITMLIB.GET_PTOCOD([F:MFM]ITMREF,[F:MFM]MFGFCY)
# lecture règle si nécessaire
If [F:PTO]PTOCOD <> WPTOCOD
   Read [PTO]PTO0=WPTOCOD
   If fstat : Raz [F:PTO] : Endif
Endif

WMTOMAJ = ([F:PTO]PTOREAL=2 & [F:PTO]REAL4DEM=2)

If !WMTOMAJ | [F:PTO]FRCPRO <> 2
   If !clalev([F:ORDB]) :  Local File ORDERS   [ORDB] : Endif
   Filter [ORDB] Where WIPTYP=6 & ITMREF=[F:MFM]ITMREF
   Read [ORDB]ORD3 = [F:MFM]MFGFCY;10;[F:MFM]MFGNUM;[F:MFM]MFGLIN;[F:MFM]BOMSEQ
   Filter [ORDB]
   If !fstat
     If !WMTOMAJ
        Call GET_FRCQTY([F:MFM]MFGFCY, [F:MFM]ITMREF, -10, [F:MFM]MFGNUM, [F:MFM]MFGLIN, [F:MFM]BOMSEQ, 6, WDEMQTY) From MTOLINKLIB
     Endif
     Call GET_FRCQTY([F:MFM]MFGFCY, [F:MFM]ITMREF, 10, [F:MFM]MFGNUM, [F:MFM]MFGLIN, [F:MFM]BOMSEQ, 6, WFRCQTY) From MTOLINKLIB
     If WFRCQTY > ([F:ORDB]RMNEXTQTY-[F:ORDB]ALLQTY) | (!WMTOMAJ & WDEMQTY > ([F:ORDB]RMNEXTQTY-[F:ORDB]ALLQTY))
        # demande sur-affectée
        Raz [M:MLIK]
        If !WMTOMAJ
            [M:MLIK]MAJCOD    = "R"
            [M:MLIK]PRPTYP    = 1                # annule & remplace
            [M:MLIK]PRPMOD    = 1                # mode mise à jour
        Else
            [M:MLIK]MAJCOD    = "Z"
        Endif
        [M:MLIK]STOFCY    = [F:MFM]MFGFCY
        [M:MLIK]ITMREF    = [F:MFM]ITMREF
        [M:MLIK]DEMTYP    = 10
        [M:MLIK]DEMNUM    = [F:MFM]MFGNUM
        [M:MLIK]DEMLIN    = [F:MFM]MFGLIN
        [M:MLIK]DEMSEQ    = [F:MFM]BOMSEQ
        [M:MLIK]DWIPTYP   = 6
        [M:MLIK]FRCPRO    = 1 + (WMTOMAJ | WFRCQTY > ([F:ORDB]RMNEXTQTY- [F:ORDB]ALLQTY))
        [M:MLIK]FEEDBACK  = 1
        GOK=1
        Call UPDMTOLINK From MTOLINKLIB
     Endif
   Endif
Endif

If WMTOMAJ
    # recalcul complet des affectations de l'article suivant la règle
    Raz [M:MLIK]
    [M:MLIK]MAJCOD    = "P"
    [M:MLIK]PRPTYP    = 1                    # annule & remplace
    [M:MLIK]PRPMOD    = 1                    # mode mise à jour
    [M:MLIK]STOFCY    = [F:MFM]MFGFCY
    [M:MLIK]ITMREF    = [F:MFM]ITMREF
    [M:MLIK]FRCPRO    = [F:PTO]FRCPRO
    [M:MLIK]FEEDBACK  = 1
    GOK=1
    Call UPDMTOLINK From MTOLINKLIB
Endif
Return


#########################################################################
# X3-69678 - STWIL - This sub-routine now creates an assignment between all type of demands and a work order
# création affectation entre SO et WO (PEC ou contremarque)
$CRE_MTO_SO_WO
# GH 25/04/2014 bug 84573 affectation générée ssi cde vente sans ctm ou avec ctm=production
If !find([M:MFGK]FMI,1,5) : Return : Endif

Gosub CHECK_MTO From MTOLINKLIB

If [M:MFGK]FMI <> 5
  Local Char WPTOCOD(GLONPTO)
  WPTOCOD = func ITMLIB.GET_PTOCOD([M:MFGK]ITMREF,[M:MFGK]MFGFCY)
  # lecture règle si nécessaire
  If [F:PTO]PTOCOD <> WPTOCOD
     Read [PTO]PTO0=WPTOCOD
     If fstat : Raz [F:PTO] : Endif
  Endif

  # si affectation temps réel non active et pas une contremarque -> pas d'affectation
  If  [F:PTO]PTOREAL < 2 : Return : Endif
Endif

GOK=0
Local Decimal WDEMQTY
If !clalev([F:ORDB]) :  Local File ORDERS   [ORDB] : Endif
Filter [ORDB] Where ITMREF=[M:MFGK]ITMREF
# X3-69678 - STWIL - Allow for other demands as well as sales orders
Read [ORDB]ORD3 = [M:MFGK]MFGFCY;[M:MFGK]VCRTYPORI;[M:MFGK]VCRNUMORI;[M:MFGK]VCRLINORI;[M:MFGK]VCRSEQORI
If !fstat
 If ([M:MFGK]FMI<>5 & [F:PTO]PTODIR<>2) | [F:ORDB]MTOQTY=0                   # GH 25/04/2014 bug 84573
   WDEMQTY = [F:ORDB]RMNEXTQTY - [F:ORDB]ALLQTY - [F:ORDB]MTOQTY             # GH 11/10/2012 bug 84918 # [F:ORDB]EXTQTY - [F:ORDB]ALLQTY
   Filter [ORDB] Where WIPTYP=5 & ITMREF=[M:MFGK]ITMREF
   Read [ORDB]ORD3 = [M:MFGK]MFGFCY;10;[M:MFGK]MFGNUM;[M:MFGK]MFGLIN;0
   If !fstat
    If ([M:MFGK]FMI<>5 & [F:PTO]PTODIR<>2) | [F:ORDB]MTOQTY=0                # GH 25/04/2014 bug 84573
      WDEMQTY = min([F:ORDB]RMNEXTQTY-[F:ORDB]MTOQTY,WDEMQTY)                # GH 11/10/2012 bug 84918 # min([F:ORDB]RMNEXTQTY,WDEMQTY)
      If [M:MFGK]CODMAJ ="S" : WDEMQTY = min(WDEMQTY,[M:MFGK]EXTQTY) : Endif # GH 15/05/2014 bug 99197
      If WDEMQTY>0 : GOK=1 : Endif
    Endif
   Endif
 Endif
Endif
Filter [ORDB]
If !GOK : GOK=1 : Return : Endif

Raz [M:MLIK]
[M:MLIK]MAJCOD  = "C"
[M:MLIK]STOFCY  = [M:MFGK]MFGFCY
[M:MLIK]ITMREF  = [M:MFGK]ITMREF
# la demande
# X3-69678 - STWIL - Allow for other demands as well as sales orders
[M:MLIK]DEMTYP  = [M:MFGK]VCRTYPORI
[M:MLIK]DEMNUM  = [M:MFGK]VCRNUMORI
[M:MLIK]DEMLIN  = [M:MFGK]VCRLINORI
[M:MLIK]DEMSEQ  = [M:MFGK]VCRSEQORI
# X3-69678 - STWIL - Allow for other demands as well as sales orders
[M:MLIK]DWIPTYP = [M:MFGK]WIPTYP
# la ressource
[M:MLIK]RESSTYP = 10
[M:MLIK]RESSNUM = [M:MFGK]MFGNUM
[M:MLIK]RESSLIN = [M:MFGK]MFGLIN
[M:MLIK]RESSSEQ = 0
# la quantité
[M:MLIK]LIKQTY  = WDEMQTY
[M:MLIK]FRCFLG  = 2
If [M:MFGK]FMI  = 5 : [M:MLIK]FMIFLG  = 2 : Else [M:MLIK]FMIFLG  = 1 : Endif

Call UPDMTOLINK             From MTOLINKLIB
If GOK>0 & ![M:MLIK]RET : # GH 13/10/2015 bug 111344 [M:MLIK]RET<>0 indicates something is wrong
   Call UPDORDERS_FROM_MLIK    From MTOLINKLIB
Endif
Return

#########################################################################
# X3-69678 - STWIL - This sub-routine now creates an assignment between all type of demands and a work order
# création affectation entre SO et WO (PEC ou contremarque)
$CRE_MTO_SO_WO_MFI
# GH 25/04/2014 bug 84573 affectation générée ssi cde vente sans ctm ou avec ctm=production
If !find([F:MFI]FMI,1,5) : Return : Endif

Gosub CHECK_MTO From MTOLINKLIB

If [F:MFI]FMI <> 5
  Local Char WPTOCOD(GLONPTO)

  WPTOCOD = func ITMLIB.GET_PTOCOD([F:MFI]ITMREF,[F:MFI]MFGFCY)
  # lecture règle si nécessaire
  If [F:PTO]PTOCOD <> WPTOCOD
     Read [PTO]PTO0=WPTOCOD
     If fstat : Raz [F:PTO] : Endif
  Endif

  # si affectation temps réel non active et pas une contremarque -> pas d'affectation
  If [F:PTO]PTOREAL < 2 : Return : Endif
Endif

GOK=0
Local Decimal WDEMQTY
If !clalev([F:ORDB]) :  Local File ORDERS   [ORDB] : Endif
Filter [ORDB] Where ITMREF=[F:MFI]ITMREF
# X3-69678 - STWIL - Allow for other demands as well as sales orders
Read [ORDB]ORD3 = [F:MFI]MFGFCY;[F:MFI]VCRTYPORI;[F:MFI]VCRNUMORI;[F:MFI]VCRLINORI;[F:MFI]VCRSEQORI
If !fstat
 If ([F:MFI]FMI<>5 & [F:PTO]PTODIR<>2) | [F:ORDB]MTOQTY=0          # GH 25/04/2014 bug 84573
   WDEMQTY = [F:ORDB]RMNEXTQTY - [F:ORDB]ALLQTY - [F:ORDB]MTOQTY   # GH 11/10/2012 bug 84918 # [F:ORDB]EXTQTY - [F:ORDB]ALLQTY
   Filter [ORDB] Where WIPTYP=5 & ITMREF=[F:MFI]ITMREF
   Read [ORDB]ORD3= [F:MFI]MFGFCY;10;[F:MFI]MFGNUM;[F:MFI]MFGLIN;0
   If !fstat
    If ([F:MFI]FMI<>5 & [F:PTO]PTODIR<>2)  | [F:ORDB]MTOQTY=0      # GH 25/04/2014 bug 84573
      WDEMQTY = min([F:ORDB]RMNEXTQTY-[F:ORDB]MTOQTY,WDEMQTY)      # GH 11/10/2012 bug 84918 # min([F:ORDB]RMNEXTQTY,WDEMQTY)
      If WDEMQTY>0 : GOK=1 : Endif
    Endif
   Endif
 Endif
Endif
Filter [ORDB]
If !GOK : GOK=1 : Return : Endif

Raz [M:MLIK]
[M:MLIK]MAJCOD  = "C"
[M:MLIK]STOFCY  = [F:MFI]MFGFCY
[M:MLIK]ITMREF  = [F:MFI]ITMREF
# la demande
# X3-69678 - STWIL - Allow for other demands as well as sales orders
[M:MLIK]DEMTYP  = [F:MFI]VCRTYPORI
[M:MLIK]DEMNUM  = [F:MFI]VCRNUMORI
[M:MLIK]DEMLIN  = [F:MFI]VCRLINORI
[M:MLIK]DEMSEQ  = [F:MFI]VCRSEQORI
# X3-69678 - STWIL - Allow for other demands as well as sales orders.
# Convert VCRTYP to WIPTYP
[M:MLIK]DWIPTYP = func CBNLIB.VCR2WIPTYP([F:MFI]VCRTYPORI)
# la ressource
[M:MLIK]RESSTYP = 10
[M:MLIK]RESSNUM = [F:MFI]MFGNUM
[M:MLIK]RESSLIN = [F:MFI]MFGLIN
[M:MLIK]RESSSEQ = 0
# la quantité
[M:MLIK]LIKQTY  = WDEMQTY
[M:MLIK]FRCFLG  = 2
#If [M:MFGK]FMI  = 5 : [M:MLIK]FMIFLG  = 2 : Else [M:MLIK]FMIFLG  = 1 : Endif : # GH 25/03/2013 bug 88910
If [F:MFI]FMI  = 5 : [M:MLIK]FMIFLG  = 2 : Else [M:MLIK]FMIFLG  = 1 : Endif

Call UPDMTOLINK             From MTOLINKLIB
If GOK>0 & ![M:MLIK]RET : # GH 13/10/2015 bug 111344 [M:MLIK]RET<>0 indicates something is wrong
   Call UPDORDERS_FROM_MLIK    From MTOLINKLIB
Endif
Return

