#<AdxTL>@(#)11.0.0.0 $Revision$ Mise ࠪour du champ organisme dans la table VALEMP
################################################################################
# Mise à jour du champ ORG dans la table VALEMP                           #
################################################################################

##################################################################
#Comments(1)                                                     #
# Manips à faire                                                 #
#   1. Remplacer UTIXXX par le nom de votre programme            #
#   2. Action OUVRE_TRACE : mettre un titre                      #
#   3. cf Comments(2)                                            #
#   4. cf Comments(3)                                            #
##################################################################

Local Char DOSSIER(30)
DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>""
 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UTIVEP: Mise à jour du champ ORG dans la table VALEMP") From LECFIC
 Call EXE_UTIVEP(DOSSIER)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

###################################################################################################
#Comments(2)                                                                                      #
# Pour exécution automatique en gestion de patch de EXE_UTIXXX                                    #
#   1. Ne pas faire de ouvre_trace/ferme_trace/lec_trace dans cette partie de programme           #
#      (le fichier trace est déjà ouvert / l'intégration de patch peut se faire en batch )        #
#                                             
#   2. Pour les ecr_trace :                                                                       #
#         Utiliser des messages avec l'instruction mess(nnn,ccc,1) ou alors des textes en anglais #
#                                             
#   3. Attention à la déclaration des fichiers : pensez que le client n'a pas forcémment activer  #
#      tous les modules dans ses dossiers
#                                             
#   4. Attention aux moulinettes sur de gros volumes (Erreur Rollback en Oracle)                  #
###################################################################################################

Subprog EXE_UTIVEP(APPLI)
Value Char APPLI
Local Integer OK ,I

Call ECR_TRACE("UTIVEP: Process Start on : "+APPLI,0) From GESECRAN

#### Corps de la moulinette - début

Local File  =APPLI+".VALEMP"    [VEP]
Local File  =APPLI+".ORGANISME" [ORG]
Local File  =APPLI+".CAISSE"    [PCA]
Local File  =APPLI+".FACILITY"  [FCY]
Local File  =APPLI+".COMPANY"   [CPY]

Call DEBTRANS From GLOCK
Gosub MAJVEP

#### Corps de la moulinette - fin 

Call ECR_TRACE("UTIVEP: Process End on : "+APPLI,0) From GESECRAN

Close Local File [VEP], [ORG], [PCA], [FCY], [CPY]

End


$MAJVEP
Trbegin [VEP]
GOK = 1
For [F:VEP]VEP0 Where ORG=""
 If GINDURS>0
  I = GINDURS-1
  Gosub ORGANISME
 Else
  I = 0
  Gosub ORGANISME
 Endif
 Rewrite [F:VEP]
 If fstat
  GOK = 0 : Call FSTA("VEP") From GLOCK : Break 
 Endif
 Call ECR_TRACE("Bulletin :"-[F:VEP]EMP-num$([F:VEP]PYRDAT)-": Mise à jour effectuée",0) From GESECRAN
Next
If GOK=0 : Goto AB_MAJVEP : Endif
Commit
Return

$AB_MAJVEP
Rollback
Return

# 40756

$ORGANISME 
Raz [F:VEP]ORG
## Recherche au niveau Salarié
If [F:VEP]EMP<>""
 Read[PCA]PCA0=4;"";"";"";[F:VEP]EMP
 If !fstat
  [F:VEP]ORG = [F:PCA]ORG(I)
 Endif
Endif
## Recherche au niveau Site ou Société
If [F:VEP]ORG="" & [F:VEP]FCY<>""
 Read[CPY]CPY0=[F:VEP]FCY
 If !fstat : # C'est une société
  Read[PCA]PCA0=2;"";[F:VEP]FCY;"";""
  If !fstat
   [F:VEP]ORG = [F:PCA]ORG(I)
  Endif
 Else : # C'est un site
  Read[PCA]PCA0=3;"";"";[F:VEP]FCY;""
  If !fstat
   [F:VEP]ORG = [F:PCA]ORG(I)
  Endif
  If [F:VEP]ORG=""
    Read[FCY]FCY0=[F:VEP]FCY
    If !fstat
     Read[PCA]PCA0=2;"";[F:FCY]LEGCPY;"";""
     If !fstat
      [F:VEP]ORG = [F:PCA]ORG(I)
     Endif
    Endif
  Endif 
 Endif
Endif

If [F:VEP]ORG=""
 ## Recherche au niveau Dossier
 Read[PCA]PCA0=1;"";"";"";""
 If !fstat
 [F:VEP]ORG = [F:PCA]ORG(I)
 Endif
Endif
Return


###################################################################################################
#Comments(3)                                                                                      #
# Pour exécution automatique  en gestion de patch                                                 #
#   1. Si le traitement ne doit pas s'éxécuter dans le dossier X3 (moulinette applicative)        #
#        ==> Décocher la ligne 1                                                                  #
#                                                                                                 #
#   2. Si le traitement doit s'éxécuter uniquement dans les dossiers ayant activé un module donné #
#        ==> Décocher la ligne 2  et renseigner le n° de module                                   #
#            attention à la numérotation du module qui commence à 0 :                             #
#             (0=superviseur / 1= compta / 2= tiers ... etc ... )                                 #
###################################################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

##1## IF APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
##2## If [F:ADS]MODULE(1) <> 2 : End : Endif
Call EXE_UTIVEP(APPLI)
End

