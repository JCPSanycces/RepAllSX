#<AdxTL>@(#)150.0.0.0 $Revision$
#-------------------------------------------------------------#
#  Ajout d'enreg sur fichier ESPION
#-------------------------------------------------------------#

Subprog ESPION(FICH,NATURE,PAR1,PAR2)
Value Char    FICH
Value Integer NATURE
Value Char    PAR1 , PAR2

Local Integer I

Onerrgo ERREUR

#-----------------------------------------------------#
# Natures
#-----------------------------------------------------#
# 1 Création
# 2 Modification
# 3 Annulation
# 4 Validation
# 5 Impression
# 6 Changement de code
# 7 Historique des mots de passe
# 8 Historique des mots de passe BI
#-----------------------------------------------------#
# Trace des opérations (GESPION)
#-----------------------------------------------------#
# 1 Non
# 2 Oui
# 3 Annulation & Chgt de code
#-----------------------------------------------------#

If (find(NATURE,7,8) or GESPION=2 or (GESPION=3 & find(NATURE,3,6)))
 If clalev([F:AES])=0 : Local File AESPION [AES] : Endif
 If dim([F:AES]ESPFNC)>0 : # Table à jour
  If !adxlog
   Gosub TR1
  Else
   Gosub MAJ
  Endif
 Endif
Endif
GOK=1 : # pour éviter des bugs quand on teste GOK
Onerrgo
End

#--------------#
$TR1
GOK=1
Trbegin [AES]
 Gosub MAJ
 If GOK=0 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
Return

#--------------#
$MAJ
[F:AES]ESPDAT = date$
[F:AES]ESPTIM = time$
[F:AES]ESPUSR = GUSER
I = instr(1,FICH,"~")
If I
 [F:AES]ESPTAB = left$(FICH,I-1)
 If dim([F:AES]ESPMOT)>0
  [F:AES]ESPMOT = right$(FICH,I+1)
 Endif
Else
 [F:AES]ESPTAB = FICH
 If dim([F:AES]ESPMOT)>0
  [F:AES]ESPMOT = ""
 Endif
Endif
[F:AES]ESPFNC = GFONCTION
[F:AES]ESPNAT = NATURE
[F:AES]ESP1   = PAR1
[F:AES]ESP2   = PAR2
Write [AES]
If fstat
 GOK=0 : Call FSTA("AES") From GLOCK
Endif
Return

#-----------------------------------------------------------------------------------------------#
# Trace dans le fichier tmp/espion.tra (espionnage de la maintenance en lignes/colonnes)
#-----------------------------------------------------------------------------------------------#

Subprog TRACE(DOSSIER,TABLE,CLE,COMMENT,PROG)
Value Char    DOSSIER , TABLE , CLE , COMMENT , PROG

Local Char    FICTRA(GDIMFIC) , MACHINE(GDIMFIC) , APPLI(GDIMFIC) , VOLUME(80)
Local Char    SYMBOLE(30) , MOTIF(GLONADI) , FICHIER(GLONATB)
Local Integer I 

Onerrgo ERREUR

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
Call VOLUME(MACHINE,APPLI,VOLUME) From ORDSYS

FICTRA = filpath("tmp","espion","tra",APPLI,VOLUME,MACHINE)
SYMBOLE = "ESPION"
GROLL = 0

I = instr(1,TABLE,"~")
If I
 FICHIER = left$(TABLE,I-1)
 MOTIF = right$(TABLE,I+1)
Else
 FICHIER = TABLE
 MOTIF = ""
Endif

#-----------------#
$ESP
Lock =SYMBOLE With lockwait=0
If fstat
 GLOCK = "%"+SYMBOLE
 Call ROLL From GLOCK
 If GROLL : End : Else : Goto ESP : Endif
Endif

Openo FICTRA , -1 Using [AESP]
Iomode adxifs "" Using [AESP]
Iomode adxirs chr$(10) Using [AESP]
Iomode adxium GASCII Using [AESP]
Wrseq GUSER-format$("D:"+GFMDAT4,date$)-time$-MOTIF-FICHIER-CLE-COMMENT Using [AESP]
If PROG<>""
 Gosub TRACE_ESPION From =PROG
Endif
Openo Using [AESP]
Unlock =SYMBOLE
Onerrgo
End

#-------------------------------------------------------------------------------------------------#
# Trace dans le fichier TRA/ORDSYS.tra (espionnage des ordres/transactions systèmes)
#-------------------------------------------------------------------------------------------------#

Subprog TRACE_ORDRE(MOTIF,COMMENT)
Value Char MOTIF , COMMENT
Call TRACE_ESPION("ORDSYS",MOTIF,COMMENT)
End

#-------------------------------------------------------------------------------------------------#
# Traces espionnage
#-------------------------------------------------------------------------------------------------#

Subprog TRACE_ESPION(SYMBOLE,MOTIF,COMMENT)
Value Char SYMBOLE , MOTIF , COMMENT

Local Char FICTRA(GDIMFIC)
Local Integer OFSTAT
OFSTAT = fstat
Onerrgo ERREUR
FICTRA = filpath("TRA",SYMBOLE,"tra")
GROLL = 0

$LOK
Lock =SYMBOLE With lockwait=0
If fstat
 GLOCK = "%"+SYMBOLE
 Call ROLL From GLOCK
 If GROLL : Goto ELOK : Else : Goto LOK : Endif
Endif
Openo FICTRA , -1 Using [AESP]
Iomode adxifs "" Using [AESP]
Iomode adxirs chr$(10) Using [AESP]
Iomode adxium GASCII Using [AESP]
Wrseq GUSER-format$("D:"+GFMDAT,date$)-time$-MOTIF Using [AESP]
Wrseq COMMENT Using [AESP]
Openo Using [AESP]
Unlock =SYMBOLE

$ELOK
fstat = OFSTAT
Onerrgo
End

#-----------------#
$ERREUR
# on va pas faire des salades pour un fichier espion !
End
