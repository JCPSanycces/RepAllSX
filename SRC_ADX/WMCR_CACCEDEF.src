#<AdxTL>@(#)0.0.0.0 $Revision$Class Default dimensions
# Supervisor
## CRUD-CLASSE ## CACCEDEF
# 2018-11-06 07:04:07 007


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File CACCEDEF [CDE_]

If !SILENCE : Call TRACE("2 --> Local Instance C_CACCEDEF") From ASYRCOM : Endif
Local Instance CACCEDEF Using C_CACCEDEF

If !SILENCE : Call TRACE("3 --> New Instance C_CACCEDEF") From ASYRCOM : Endif
CACCEDEF = NewInstance C_CACCEDEF AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [CDE_]CDE0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of CACCEDEF") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet CACCEDEF.AREAD([CDE_]COD,[CDE_]CPY))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("CACCEDEF.COD ="-num$(CACCEDEF.COD)) From ASYRCOM
 Call TRACE("CACCEDEF.CPY ="-num$(CACCEDEF.CPY)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(CACCEDEF.AKEYS)
  Call TRACE("-"-num$(I)-":"-CACCEDEF.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [CDE_]
FreeGroup CACCEDEF
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(CACCEDEF,ACLE,ASTATUS,_ETAG)
Variable Instance CACCEDEF Using C_CACCEDEF
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Char _COD(10)
Local Char _CPY(5)
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_COD = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_CPY = num$([L]CLE(2)) : Endif
Raz [L]_ETAG
Local File CACCEDEF [CDE]
Default File [F:CDE]
Read [F:CDE]CDE0 = [L]_COD;[L]_CPY
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:CDE]UPDTICK)>0
 [L]_ETAG = num$([F:CDE]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(CACCEDEF,ACLE,ASTATUS)
Variable Instance CACCEDEF Using C_CACCEDEF
Value Char ACLE
Variable Integer ASTATUS
Local Char _COD(10)
Local Char _CPY(5)
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_COD = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_CPY = num$([L]CLE(2)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet CACCEDEF.AREAD([L]_COD,[L]_CPY))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(CACCEDEF,_COD,_CPY,ASTATUS)
Variable Instance CACCEDEF Using C_CACCEDEF
Value Char _COD
Value Char _CPY
Variable Integer ASTATUS

If CACCEDEF = null : End : Endif

Gosub AVARIABLES From WMC00CACCEDEF
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If CACCEDEF.APARENT=null
 [L]A_I = CACCEDEF.freeSnapshot
 CACCEDEF.snapshotEnabled = 0
 CACCEDEF.setAccessorEnabled = 0
Endif

Gosub ATRT_AREAD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & CACCEDEF.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet CACCEDEF._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If CACCEDEF.APARENT=null
 CACCEDEF.snapshotEnabled = 1
 CACCEDEF.setAccessorEnabled = 1
Endif
LogicClose File [CDE]
End

#-----------------------------------------------------#
$ATRT_AREAD
[L]ASTATUS = max([L]ASTATUS,fmet CACCEDEF._ACTION_PARAM("AREAD_BEFORE",[L]_COD,[L]_CPY))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Default File [F:CDE]
Read [F:CDE]CDE0 = [L]_COD;[L]_CPY
If fstat
[L]A_ERROR = [L]_COD+"~"+[L]_CPY
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(CACCEDEF,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If dim([F:CDE]AUUID)>0 & [F:CDE]AUUID=NullUuid
 [F:CDE]AUUID = getUuid
Endif
SetInstance CACCEDEF With [F:CDE]
CACCEDEF.ASTALIN = [V]CST_ALL

[L]A_NEWCOL = 0
For [L]A_I=1 To min(20,CACCEDEF.NBRDIE)
 [L]A_NEWCOL += 1
 CACCEDEF.DIMCEN(A_NEWCOL) = NewInstance  C_CACCEDEF_DIMCEN(CACCEDEF.ACTX,NullUuid,[L]A_I,CACCEDEF,"DIMCEN") AllocGroup CACCEDEF
 CACCEDEF.DIMCEN(A_NEWCOL).DIE = [F:CDE]DIE([L]A_I-1)
 [L]ASTATUS = max([L]ASTATUS,fmet CACCEDEF.DIMCEN(A_NEWCOL).ACTION("AREAD_AFTER"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 For [AXX] Where CODFIC="GDIE" & ZONE="DESTRA" & IDENT1=CACCEDEF.DIMCEN(A_NEWCOL).DIE & IDENT2=""
  Call ASETTEXTRA(CACCEDEF.DIMCEN(A_NEWCOL).AXX,CACCEDEF.DIMCEN(A_NEWCOL).AllocGrp(),"DESDIE",[F:AXX]TEXTE,[F:AXX]LANGUE) From ASYRSUB
  CACCEDEF.DIMCEN(A_NEWCOL).AXX(maxtab(CACCEDEF.DIMCEN(A_NEWCOL).AXX)).FLG = 0
 Next AXX
 If !len(fmet CACCEDEF.DIMCEN(A_NEWCOL).AGETTEXTRA("DESDIE"))
  Call ASETTEXTRA(CACCEDEF.DIMCEN(A_NEWCOL).AXX,CACCEDEF.DIMCEN(A_NEWCOL).AllocGrp(),"DESDIE",
& fmet CACCEDEF.DIMCEN(A_NEWCOL).AGETTEXTRALAN("DESDIE",CACCEDEF.DIMCEN(A_NEWCOL).ACTX.AFOLD.ALANGDEF),
& CACCEDEF.DIMCEN(A_NEWCOL).ACTX.LAN) From ASYRSUB
 Endif
Next
[L]A_NEWCOL = 0
For [L]A_I=1 To 25
 If ([F:CDE]FLD([L]A_I-1)<>"")
  [L]A_NEWCOL += 1
  CACCEDEF.IDENT(A_NEWCOL) = NewInstance  C_CACCEDEF_IDENT(CACCEDEF.ACTX,NullUuid,[L]A_I,CACCEDEF,"IDENT") AllocGroup CACCEDEF
  CACCEDEF.IDENT(A_NEWCOL).FLD = [F:CDE]FLD([L]A_I-1)
  [L]ASTATUS = max([L]ASTATUS,fmet CACCEDEF.IDENT(A_NEWCOL).ACTION("AREAD_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Endif
Next
[L]A_NEWCOL = 0
For [L]A_I=1 To min(5,CACCEDEF.NBLIG)
 [L]A_NEWCOL += 1
 CACCEDEF.LISCCE(A_NEWCOL) = NewInstance  C_CACCEDEF_LISCCE(CACCEDEF.ACTX,NullUuid,[L]A_I,CACCEDEF,"LISCCE") AllocGroup CACCEDEF
 CACCEDEF.LISCCE(A_NEWCOL).CCE1 = [F:CDE]CCE1([L]A_I-1)
 CACCEDEF.LISCCE(A_NEWCOL).CCE2 = [F:CDE]CCE2([L]A_I-1)
 CACCEDEF.LISCCE(A_NEWCOL).CCE3 = [F:CDE]CCE3([L]A_I-1)
 CACCEDEF.LISCCE(A_NEWCOL).CCE4 = [F:CDE]CCE4([L]A_I-1)
 CACCEDEF.LISCCE(A_NEWCOL).CCE5 = [F:CDE]CCE5([L]A_I-1)
 CACCEDEF.LISCCE(A_NEWCOL).CCE6 = [F:CDE]CCE6([L]A_I-1)
 CACCEDEF.LISCCE(A_NEWCOL).CCE7 = [F:CDE]CCE7([L]A_I-1)
 CACCEDEF.LISCCE(A_NEWCOL).CCE8 = [F:CDE]CCE8([L]A_I-1)
 CACCEDEF.LISCCE(A_NEWCOL).CCE9 = [F:CDE]CCE9([L]A_I-1)
 CACCEDEF.LISCCE(A_NEWCOL).CCE10 = [F:CDE]CCE10([L]A_I-1)
 CACCEDEF.LISCCE(A_NEWCOL).CCE11 = [F:CDE]CCE11([L]A_I-1)
 CACCEDEF.LISCCE(A_NEWCOL).CCE12 = [F:CDE]CCE12([L]A_I-1)
 CACCEDEF.LISCCE(A_NEWCOL).CCE13 = [F:CDE]CCE13([L]A_I-1)
 CACCEDEF.LISCCE(A_NEWCOL).CCE14 = [F:CDE]CCE14([L]A_I-1)
 CACCEDEF.LISCCE(A_NEWCOL).CCE15 = [F:CDE]CCE15([L]A_I-1)
 CACCEDEF.LISCCE(A_NEWCOL).CCE16 = [F:CDE]CCE16([L]A_I-1)
 CACCEDEF.LISCCE(A_NEWCOL).CCE17 = [F:CDE]CCE17([L]A_I-1)
 CACCEDEF.LISCCE(A_NEWCOL).CCE18 = [F:CDE]CCE18([L]A_I-1)
 CACCEDEF.LISCCE(A_NEWCOL).CCE19 = [F:CDE]CCE19([L]A_I-1)
 CACCEDEF.LISCCE(A_NEWCOL).CCE20 = [F:CDE]CCE20([L]A_I-1)
 [L]ASTATUS = max([L]ASTATUS,fmet CACCEDEF.LISCCE(A_NEWCOL).ACTION("AREAD_AFTER"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Next
[L]ASTATUS = max([L]ASTATUS,fmet CACCEDEF.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

For [AXX] Where CODFIC="CACCEDEF" & ZONE="DESTRA" & IDENT1=CACCEDEF.COD & IDENT2=""
 Call ASETTEXTRA(CACCEDEF.AXX,CACCEDEF.AllocGrp(),"DESTRA",[F:AXX]TEXTE,[F:AXX]LANGUE) From ASYRSUB
 CACCEDEF.AXX(maxtab(CACCEDEF.AXX)).FLG = 0
Next AXX
If !len(fmet CACCEDEF.AGETTEXTRA("DESTRA"))
 Call ASETTEXTRA(CACCEDEF.AXX,CACCEDEF.AllocGrp(),"DESTRA",
& fmet CACCEDEF.AGETTEXTRALAN("DESTRA",CACCEDEF.ACTX.AFOLD.ALANGDEF),
& CACCEDEF.ACTX.LAN) From ASYRSUB
Endif
For [AXX] Where CODFIC="CACCEDEF" & ZONE="SHOTRA" & IDENT1=CACCEDEF.COD & IDENT2=""
 Call ASETTEXTRA(CACCEDEF.AXX,CACCEDEF.AllocGrp(),"SHOTRA",[F:AXX]TEXTE,[F:AXX]LANGUE) From ASYRSUB
 CACCEDEF.AXX(maxtab(CACCEDEF.AXX)).FLG = 0
Next AXX
If !len(fmet CACCEDEF.AGETTEXTRA("SHOTRA"))
 Call ASETTEXTRA(CACCEDEF.AXX,CACCEDEF.AllocGrp(),"SHOTRA",
& fmet CACCEDEF.AGETTEXTRALAN("SHOTRA",CACCEDEF.ACTX.AFOLD.ALANGDEF),
& CACCEDEF.ACTX.LAN) From ASYRSUB
Endif

Return



