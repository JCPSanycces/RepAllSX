########################################
Subprog C_CPLLAB(VALEUR)
Variable Char    VALEUR()

Local Integer OK

# contrôle existence et poste de type main-d'oeuvre
If VALEUR <> ""
   If VALEUR = [M:MBO]CPLWST(nolign-1) : GMESSAGE=mess(26,193,1) : mkstat=1 : End : Endif
   Read [MWS]WST0=VALEUR;[M:MBO]FCY
   If fstat
      GMESSAGE=mess(23,100,1)
      mkstat=2
      End
   Else
      If [F:MWS]WSTTYP <> 2
         GMESSAGE=VALEUR - mess(4,193,1) : mkstat=2
         End
      Endif
      If [F:MWS]WCRFCY <> [M:MBO]FCY
         GMESSAGE = mess(116,193,1) - [M:MBO]FCY
         mkstat = 1
         End
      Endif
   Endif
Endif
#
# Issue 110979/2 - 2016-03-25 by CCC : Warning message when modifying an existing operation of a versioned routing
If VALEUR<>[M:MBO]CPLLAB(nolign-1) & [M:MBO]ROUOPENUM(nolign-1)<>0
    If [F:MFG]MFGNUM<>[M:MBO]MFGNUM(nolign-1)
        Read [F:MFG]MFG0 = [M:MBO]MFGNUM(nolign-1)
    Endif
    If [F:MFG]ROUECCMAJ <> ""
        If [F:MFO]MFGNUM<>[M:MBO]MFGNUM(nolign-1) | [F:MFO]OPENUM<>[M:MBO]OPENUM(nolign-1) | [F:MFO]OPESPLNUM<>[M:MBO]OPESPLNUM(nolign-1)
            Raz [F:MFO]
            Read [F:MFO]MFO0 = [M:MBO]MFGNUM(nolign-1);[M:MBO]OPENUM(nolign-1);[M:MBO]OPESPLNUM(nolign-1)
        Endif
        If [F:MFO]MFGNUM<>"" & VALEUR<>[F:MFO]EXTLAB
            OK=1
            Call AVERTIR(mess(346,193,1),OK) From GESECRAN
            If OK = 1 : mkstat=1 : End : Endif # Cancel
        Endif
    Endif
Endif
End

########################################
Subprog S_WCDED(VALEUR)
Variable Char    VALEUR()
Local    Integer WTYP, WSTA(4)
Local    Integer I : I = 0
Local    Char    WWIP(GLONVCR)
Local    Char    WITM(GLONITM)
Local    Char    WVCR(GLONVCR) : WVCR = VALEUR            # llc 02.02 12863

Raz WSTA
WSTA(I) = 1
WITM = ""
WTYP = 1
Call SELVCR(WTYP, [M:MBO]FCY, WSTA, WITM, WWIP, WVCR, "","") From MFGLIB
If WWIP <> ""
    Read [F:ORD]ORD0=WTYP;WWIP;WITM
    If fstat : mkstat = 2 : End : Endif
    VALEUR = [F:ORD]VCRNUM
Else
    mkstat = 2
Endif
End

########################################
Subprog S_WCDEF(VALEUR)
Variable Char    VALEUR()
Local    Integer WTYP, WSTA(4)
Local    Integer I : I = 0
Local    Char    WWIP(GLONVCR)
Local    Char    WITM(GLONITM)
Local    Char    WVCR(GLONVCR) : WVCR = VALEUR            # llc 02.02 12863

Raz WSTA
WSTA(I) = 1
WITM = ""
WTYP = 1
Call SELVCR(WTYP, [M:MBO]FCY, WSTA, WITM, WWIP, WVCR, "","") From MFGLIB
If WWIP <> ""
    Read [F:ORD]ORD0=WTYP;WWIP;WITM
    If fstat : mkstat = 2 : End : Endif
    VALEUR = [F:ORD]VCRNUM
Else
    mkstat = 2
Endif
End


########################################
Subprog AS_OPEUOM(VALEUR)
Variable Char    VALEUR()
If [M:MBO]TIMTYP(nolign-1) = 3 | [F:BTS]OPEUOMMOD = 1 & [M:MBO]ROUOPENUM(nolign-1) <> 0
    mkstat = 2
Endif
End

########################################
Subprog C_OPEUOM(VALEUR)
Variable Char    VALEUR()
If [M:MBO]TIMTYP(nolign-1) = 3 : End : Endif
Read [TUN]TUN0 = VALEUR
If fstat : GMESSAGE = mess(23,100,1)
           mkstat = 1
           End
Endif
If [M:MBO]ROUOPENUM(nolign-1) <> 0 & !find(VALEUR,[M:MBO]STU(nolign-1),[M:MBO]XOPEUOM(nolign-1))
           GMESSAGE = mess(23,100,1)
           mkstat = 1
           End
Endif
End

########################################
Subprog AM_OPEUOM(VALEUR)
Variable Char    VALEUR()
If [M:MBO]ROUOPENUM(nolign-1) = 0 : [M:MBO]XOPEUOM(nolign-1) = VALEUR
                                    [M:MBO]OPESTUCOE(nolign-1) = 1
                                    [M:MBO]OPEWORCOE(nolign-1) = 1
Endif
If VALEUR = [M:MBO]XOPEUOM(nolign-1)
   [M:MBO]OPESTUCOE(nolign-1) = [M:MBO]OPEWORCOE(nolign-1)
   [M:MBO]CPLQTY(nolign-1)    = [M:MBO]CPLQTY(nolign-1)    * [M:MBO]OPESTUCOE(nolign-1)
   [M:MBO]REJCPLQTY(nolign-1) = [M:MBO]REJCPLQTY(nolign-1) * [M:MBO]OPESTUCOE(nolign-1)
   [M:MBO]WQTY(nolign-1)      = [M:MBO]WQTY(nolign-1)      * [M:MBO]OPESTUCOE(nolign-1)
   [M:MBO]CPLUNTTIM(nolign-1) = [M:MBO]CPLUNTTIM(nolign-1) / [M:MBO]OPESTUCOE(nolign-1)
   [M:MBO]OPEWORCOE(nolign-1) = 1
Else
   [M:MBO]CPLQTY(nolign-1)    = [M:MBO]CPLQTY(nolign-1)    / [M:MBO]OPESTUCOE(nolign-1)
   [M:MBO]REJCPLQTY(nolign-1) = [M:MBO]REJCPLQTY(nolign-1) / [M:MBO]OPESTUCOE(nolign-1)
   [M:MBO]WQTY(nolign-1)      = [M:MBO]WQTY(nolign-1)      / [M:MBO]OPESTUCOE(nolign-1)
   [M:MBO]CPLUNTTIM(nolign-1) = [M:MBO]CPLUNTTIM(nolign-1) * [M:MBO]OPESTUCOE(nolign-1)
   [M:MBO]OPEWORCOE(nolign-1) = [M:MBO]OPESTUCOE(nolign-1)
   [M:MBO]OPESTUCOE(nolign-1) = 1
Endif
# 11.06 demande 38402
[M:MBO]CPLUNTTIM(nolign-1) = func TRTX3.ARRTYP("","","TIH",[M:MBO]CPLUNTTIM(nolign-1))
Affzo [M:MBO]OPEWORCOE(nolign-1),CPLQTY(nolign-1),REJCPLQTY(nolign-1)
End

