##########################################################################
## Etiquette ajoutée par le superviseur 13/06/2003 15:20:20 (SR)
##########################################################################
Subprog IB_NBLIG
Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4, GBOUT5, GBOUT6, GBOUT7, GBOUT8, GBOUT9, GBOUT10, GBOUT11, GBOUT12, GBOUT13
#GBOUT1  = "Fiche technique"
#GBOUT2  = "Ordre de fabrication"
#GBOUT3  = "Détail opération" si TIMTYP = 1
#GBOUT4  = "etat suivi" si TIMTYP = 1
#GBOUT5  = "Consommation matières" selon MATFLG
#GBOUT6  = "Déclaration de production" selon ITMFLG et si opé de production
#GBOUT8  = "Texte"
#GBOUT11 = "Gamme"
#GBOUT12 = "Poste"
#GBOUT13 = "Sections analytiques"
Local Integer W_SAICCE, I
#Local Integer WNOLIGN : WNOLIGN = nolign
If [M:MBO]TECCRD(nolign-1) <> "" : GBOUT1 = mess(77,198,1) : Endif
If [M:MBO]TIMTYP(nolign-1) = 1
   Read [F:MFG]MFG0 = [M:MBO]MFGNUM(nolign-1)
   If fstat : Raz [F:MFG] : Endif
   If  [M:MBO]MFGNUM(nolign-1) <> ""
       GBOUT2 = mess(166,198,1)
   Endif
   If find([F:BTS]MATFLG,2,4)  & [F:MFG]MFGMOD = 1 & [M:MBO]ROUOPENUM(nolign-1) <> 0
      GBOUT5 = mess(402,198,1)
   Endif
   If find([F:BTS]ITMFLG,2,4)  & [M:MBO]MFGMST(nolign-1) = 2
      GBOUT6 = mess(404,198,1)
   Endif
   If [M:MBO]OPENUM(nolign-1) <> 0
      GBOUT3 = mess(243,198,1)
      GBOUT4 = mess(242,198,1)
   Endif
Elsif [M:MBO]TIMTYP(nolign-1) = 2
    If [M:MBO]WROUVAL(nolign-1) = 1
       GBOUT11 = mess(63,198,1)
    Endif
    If find([F:BTS]MATFLG,2,4) & [M:MBO]BOMNUM(nolign-1) <> "" & [M:MBO]BOMALT(nolign-1) <> 0 &
&           [M:MBO]ROUOPENUM(nolign-1) <> 0
       GBOUT5 = mess(402,198,1)
    Endif
    If find([F:BTS]ITMFLG,2,4)  & [M:MBO]BOMNUM(nolign-1) <> "" & [M:MBO]BOMALT(nolign-1) <> 0 &
&                                 [M:MBO]MFGMST(nolign-1) = 2
      GBOUT6 = mess(404,198,1)
    Endif
Elsif [M:MBO]TIMTYP(nolign-1) = 3 :    GBOUT12 = mess(29,198,1)
Endif
If [M:MBO]CPLWST(nolign-1) <> ""
       GBOUT8 = mess(38,198,1)
Endif
# bouton pour saisie des sections ana si une section au moins est définie saisie
# dans la section de valo associée au poste principal
If clalev([F:MWC]) = 0 Local File WORKCOST [MWC] Endif
Raz [F:MWS]
Read [F:MWS]WST0 = [M:MBO]CPLWST(nolign-1);[M:MBO]FCY
Read [F:MWC]WCT0 = [F:MWS]VLTCCE;[M:MBO]FCY
If !fstat
  For I=0 To GOPTCANA-1
    If [F:MWC]CCECOD(I) = 1 : W_SAICCE = 1 : Break : Endif
  Next
  If W_SAICCE = 1
    GBOUT13 = mess(36,103,1)
  Endif
Endif
End

