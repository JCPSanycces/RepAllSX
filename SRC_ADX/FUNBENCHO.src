#<AdxTL>@(#)10.0.0.0 $Revision$
##############################################################################
# ACTION = SAIBENCHO
##############################################################################
$ACTION
Case ACTION
    When "INIT"          : Gosub INIT
    When "SEL_LISTE"     : Gosub SEL_LISTE
    When "FIN_LISTE"     : Gosub FIN_LISTE
    When "CONTROLE"      : Gosub CONTROLE
    When "OUVRE"         : Gosub OUVRE
    When "TITRE"         : Gosub TIT
    When "DEBUT"         : Gosub DEBUT
    When "SETBOUT"       : Gosub SETBOUT
    When "BOUTON"        : Gosub BOUTON
    When "ABA"           : Effzo [M:MBO]
                           Gosub DEL_QLYWRK From MTKLIB
                           Gosub DEBUT
    When "FIN"           : GFONC1 = SAV_GFONC1
                           GCONSULT = GCONSLCT
                           Gosub DEL_QLYWRK From MTKLIB
                           Kill GOPELIN, GMOLNUM
                           Raz GORITITCOL
                           Call IMPSCR From ATRTX3
                           Gosub FIN         #01.10 mm 61503
    When "BB3_NBLIG"     : Gosub LECTURE_BTS
    When "AB5_NBLIG"     : Gosub AB5_NBLIG
    When "BB5_NBLIG"     : Gosub BB5_NBLIG
    When "AB6_NBLIG"     : Gosub AB6_NBLIG
    When "BB6_NBLIG"     : Gosub BB6_NBLIG
    When "AB11_NBLIG"    : Gosub AB11_NBLIG
    When "AP_CHOIX"      : Gosub AP_CHOIX
Endcase
Return

###########################################################################
$INIT
Local Char        LFCY(GLONFCY)   : LFCY   = PARAM(1)
Local Char        LORI(10)        : LORI   = PARAM(2)
Local Char        LUSR(GLONAUS)   : LUSR   = PARAM(3)
Local Integer     LRETOK          : LRETOK = val(PARAM(4))
Local Integer     OK
Global Char       GMOLNUM(GLONTRS): GMOLNUM = ""
Raz GSTATUT

Return

###########################################################################
# selection de la transaction
$SEL_LISTE
# 10.05 demande 32570
Local Char     TABACS(10)(100)
Local Integer  NBACS
Local Char     TEX(30)(0..100) , TEXTE(50)(0..100)
Local Char     TIT(30)
Local Integer  NBTEX

If clalev ([F:BTS])=0  : Local File BENCHTRS [BTS] : Endif
# si on vient du pilotage, on vérifie si un code transaction est passé
If GFONCTION = "FUNBENPLT"
    If [M:MBP]MOLTRS <> ""
        Read [BTS]BTS0=60;[M:MBP]MOLTRS
        If fstat | [F:BTS]ENAFLG=1  : Return : Endif
        GMOLNUM = [F:BTS]BTSNUM
        OK = 0
        Return
    Endif
Endif

If clalev([F:ACC]) = 0 : Local File ACCES [ACC] : Endif
CRITERE = "BTSTYP=60&ENAFLG=2"
# 10.05 demande 32570
If GPROFIL <> GSUPER
    For [ACC]CODACC Where USR=GUSER
       If [F:ACC]EXEC=2 [L]TABACS(NBACS)=vireblc([F:ACC]CODACC,1) : NBACS +=1
       Endif
       If NBACS>99 Break : Endif
    Next
    CRITERE += "& (ACSCOD = ''  | find(ACSCOD,TABACS(0..99)))"
Endif
If GFLAG=""
    Filter [BTS] Where evalue(CRITERE)
    If rowcount([BTS])=1
        Read [BTS] First
        If !fstat
            GFLAG=[F:BTS]BTSNUM
        Endif
    Endif
    Filter [BTS]
Endif
If GFLAG<>""
    Filter [BTS] Where evalue(CRITERE)
    Read [BTS]BTS0=60;GFLAG
    Filter [BTS]
    If !fstat
        If dim(GMOLNUM)<=0
            Global Char    GMOLNUM(GLONTRS)
        Endif
        GMOLNUM = [F:BTS]BTSNUM
        OK=0
    Endif
Endif
If GMOLNUM=""
    For [F:BTS] Where evalue(CRITERE)
        NBTEX+= 1
        TEX(NBTEX)   =[F:BTS]BTSNUM
        Call LECTEXTRA(TEXTE(NBTEX),"BENCHTRS","DESAXX",num$([F:BTS]BTSTYP),[F:BTS]BTSNUM) From ATEXTRA
        TEXTE(NBTEX) = TEX(NBTEX)-TEXTE(NBTEX)
    Next
    TIT(0) = mess(3,126,1) # Choix transactions
Endif
Return

###########################################################################
$FIN_LISTE
GMOLNUM = TEX(CHOIX)
Return

###########################################################################
$CONTROLE
If clalev ([F:BTS]) <= 0  : Local File BENCHTRS [BTS] : Endif
Read [BTS]BTS0=60;GMOLNUM
If fstat  | [F:BTS]ENAFLG = 1 : FIN = 1 : Return : Endif

# Dépôt entête obligatoire ou non
If GWRHACT=2
  GWRHOBY = [F:BTS]WRHOBY
Else
  GWRHOBY = 1
Endif
Return

###########################################################################
$OUVRE
#01.10 mm 61503 - Si on vient par tunnel il faut sauvegarder les variables globales
Gosub SAUV_GLOB From TRTX3GLOB
#
Local Char        LFCY(GLONFCY)  : LFCY   = PARAM(1)
Local Char        LORI(10)       : LORI   = PARAM(2)
Local Char        LUSR(GLONAUS)  : LUSR   = PARAM(3)
Local Integer     LRETOK : LRETOK = val(PARAM(4))

Local  Integer RETOUR
Local  Integer WRET
Local  Integer TRA : TRA = 0
Local Char     WMASQUE(20)
Global Integer GOPELIN: GOPELIN = 1
Global Integer GSUIVOK
Global Integer FICTECOK
Global Integer GCONSLCT : GCONSLCT = GCONSULT
Global Char    SAV_GFONC1(20) : SAV_GFONC1 = GFONC1

If LFCY <> ""
    GFCY = LFCY
Else
    Call FIND_GFCYDEF(8) From TRTX3  # FQ 54218
Endif

Gosub OUVRE_INIT

Return

###########################################################################
$OUVRE_INIT
# CCC (2009-09-02) Bug 57423 : L'initialisation du lot est faite juste avant
#Call FIND_GFCYDEF(8) From TRTX3  # FQ 54218
Raz GCONSULT
Raz GSOC_ACTIVE
GFONC1 = "FUNBENCHO"

If !clalev([STW]) Local Mask STOWORK [STW] : Endif
Gosub STK_INILOC From STKLOC

If !clalev([M:SVW]) : Local Mask STOVALWORK [SVW] : Endif
If !clalev([M:ALP])  Local Mask ALLPAR     [ALP]   Endif
If !clalev([M:SOW])  Local Mask STOSORW    [SOW]   Endif
If !clalev([M:MTB1]) Local Mask MTKBCRIT1 [MTB1]   Endif  # 15806 MM 05.05 : gestion memo STD
If GMODU(2)=2 : # Si module compta actif
  If !clalev([F:GCM])   Local File GACM       [GCM] : Endif
Endif

Gosub OPEN_FILE
Gosub CHARG_PARAM

Gosub LECTURE_BTS
If GVTMOD : Return : Endif

# substitution fenêtre
BOITE     = "WIMBO"+GMOLNUM
WMASQUE   = "WT60"+GMOLNUM+"1"

#MAE, le 31/01/08, GRP_SITE
GGRPFCY = [F:BTS]GFY
Gosub CHANGE_AWI  From BENCHLIB
GORITITCOL = 1

Return

#########################################################################
$TIT
    Call LECTEXTRA(TIT,"BENCHTRS","DESAXX",num$([F:BTS]BTSTYP),[F:BTS]BTSNUM) From ATEXTRA
    If !clalev([F:AWI]) : Local File AWINDOW : Endif
    Read [AWI]AWI0=BOITE
    Call TEXTE([F:AWI]DES,GBIDC1) From OBJDIV
    TIT = GBIDC1-[F:BTS]BTSNUM-":"-TIT
Return

####################################################################################
$DEBUT
Raz    [M:MBO]
[M:MBO]FCY = GFCY
Gosub WRH_ETAT

#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL

Case [F:BTS]CRIT1
     When 1 : [M:MBO]WSRT += 1
     When 2 : [M:MBO]WSRT += 2
     When 3 : [M:MBO]WSRT += 4
     When 4 : [M:MBO]WSRT += 8
Endcase
Case [F:BTS]CRIT2
     When 1 : [M:MBO]WSRT += 16
     When 2 : [M:MBO]WSRT += 32
     When 3 : [M:MBO]WSRT += 64
     When 4 : [M:MBO]WSRT += 128
Endcase

[M:MBO]LORI = LORI
If [F:BTS]FILTFLG < 3 : [M:MBO]FILTOPE = [F:BTS]FILTDEF : Endif
#
If LUSR <> ""
    Filter [F:TMA] Where USR = LUSR
Else
    Filter [F:TMA] Where USR = GUSER
Endif
Read [F:TMA]TMA1 First
If !fstat : [M:MBO]WEMPNUM = [F:TMA]EMPNUM : Endif
Filter [F:TMA]
If LORI = "PILOT"
    Gosub CHARG_MASKB
Endif

# 15806 MM 05.05 : application memo STD
If LORI =""
    If filinfo(filpath("ETM",GUSER+"_"+GMOLNUM+"_"+"STD","mbo",0),0)>=0
        Call LECMEMO("STD","[M:MTB1]",GMOLNUM+"~mbo") From GMEMO
        [M:MBO] = [M:MTB1]
        Affzo [M:MBO]10
    Endif
Endif

Return


#------------------------------------------------------------------------#
# Affichage entêtes colonnes variables ( sections analytiques)           #
#------------------------------------------------------------------------#
$AFF_TITCOL

If GSOC_UPDFLG & !GIMPORT & !GVTMOD
  Local Char BASPAG(10)
  If (dim([M:MBO]CCE1)>0)
      BASPAG="NBLIG" : Gosub TIT_COL From ="W1WT60"+GMOLNUM+"1"
      If [M:MBO]NBLIG = 0 : [M:MBO]NBLIG = 1 : Affzo [M:MBO]15 : Effzo [M:MBO]15 : Endif
  Endif
Endif
Raz GSOC_UPDFLG
Return


#########################################################################
$SETBOUT
# Pour interdire la navigation
GREP="M"

ETABOU(GSPE1) = 1                                     # recherche
ETABOU(GSPE2) = 1                                     # critères
ETABOU(GSPE3) = 1                                     # validation
ETABOU(GABAN) = 1
If LORI = "PILOT"
    ETABOU(GSPE1) = 0                                     # recherche
    ETABOU(GSPE2) = 0                                     # critères
Endif
Return

########################################################################
$BOUTON
Case BOUT
    When "1"       :     Gosub CHARG_MASK
    When "2"       :     If [M:MBO]REACT = 2 : Gosub CHARG_MASK : [M:MBO]REACT = 1 : Endif
    When "3"       :     Gosub VALIDATION
Endcase
Return

#########################################################################
$AP_CHOIX
# interception de la touche return
If REPONSE = GSTARET
    Gosub CHARG_MASK
Endif
Return


#######################################################################
$OPEN_FILE
If clalev([M:OPSK])=0 : Local Mask OPSK      [OPSK] : Endif       # masque encours charge
If clalev([M:MTOK])=0 : Local Mask MTOK      [MTOK] : Endif       # masque buffer suivi opé
If clalev([M:MTMK])=0 : Local Mask MTMK      [MTMK] : Endif       # masque buffer suivi matière
If clalev([M:MTIK])=0 : Local Mask MTIK      [MTIK] : Endif       # masque buffer decl prod
If clalev([F:ITM])<=0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF])<=0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITG])<=0 : Local File ITMCATEG   [ITG] : Endif
If clalev([F:MFG])<=0 : Local File MFGHEAD    [MFG] : Endif
If clalev([F:MFI])<=0 : Local File MFGITM     [MFI] : Endif
If clalev([F:MFM])<=0 : Local File MFGMAT     [MFM] : Endif
If clalev([F:MFO])<=0 : Local File MFGOPE     [MFO] : Endif
If clalev([F:MTK])<=0 : Local File MFGHEADTRK [MTK] : Endif
If clalev([F:MKI])<=0 : Local File MFGITMTRK  [MKI] : Endif
If clalev([F:MKO])<=0 : Local File MFGOPETRK  [MKO] : Endif
If clalev([F:MWS])<=0 : Local File WORKSTATIO [MWS] : Endif
If clalev([F:MTA])<=0 : Local File MTKCRDASW  [MTA] : Endif
If clalev([F:QLW])<=0 : Local File QLYWRK     [QLW] : Endif
If clalev([F:ROH])<=0 : Local File ROUTING    [ROH] : Endif
If clalev([F:ROS])<=0 : Local File ROUSCD     [ROS] : Endif
If clalev([F:ROO])<=0 : Local File ROUOPE     [ROO] : Endif
If clalev([F:ROT])<=0 : Local File ROUOPESTD  [ROT] : Endif
If clalev([F:SCH])<=0 : Local File SCHEDULING [SCH] : Endif
If clalev([F:TRO])<=0 : Local File TABROUALT  [TRO] : Endif
If clalev([F:TMA])<=0 : Local File TABMAT     [TMA] : Endif
If clalev([F:TSR])<=0 : Local File TABSCA     [TSR] : Endif
If clalev([F:TMS])<=0 : Local File TABMSG     [TMS] : Endif
If clalev([F:TCA])<=0 : Local File TABCOUAFF  [TCA] : Endif
If clalev([F:TUN])<=0 : Local File TABUNIT    [TUN] : Endif
If clalev([F:ORD])<=0 : Local File ORDERS     [ORD] : Endif
If clalev([F:TFO])<=0 : Local File TABFOR     [TFO] : Endif
If clalev([F:BTS])<=0 : Local File BENCHTRS   [BTS] : Endif
If clalev([F:BOH])<=0 : Local File BOM        [BOH] : Endif
If clalev([F:SRU])<=0 : Local File TABSTORUL  [SRU] : Endif
If clalev([F:OPS])<=0 : Local File OPERATIONS [OPS] : Endif
If clalev([F:FCY])<=0 : Local File FACILITY   [FCY] : Endif
If GWRHACT=2
   If !clalev([F:WRH])  Local File WAREHOUSE  [WRH] : Endif
   If !clalev([F:ITW])  Local File ITMWRH     [ITW] : Endif
Endif
# 08.02 demande 15029
Local Mask JALK   [JALK]                                             # ecran pour jalonnement
If clalev([F:PJA])<=0 : Local File PARJAL     [PJA] : Endif          # Paramètres jalonnement
#
If clalev([F:CAL])<=0 : Local File CPTANALIN  [CAL] : Endif
If clalev([F:DTR])<=0 : Local File DIETRS     [DTR] : Endif
# 04.07 Demande 40752
If clalev([F:MKI2])<=0 : Local File MFGITMTRK  [MKI2] : Endif        # Pour régul des manquants

Return

########################################################################
$CHARG_PARAM

Call GETCPY(GFCY,"BTS",60,GMOLNUM) From TRTX3CPT

#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return

########################################################################
$LECTURE_BTS
#----- Relecture transaction de saisie  -----#
If [F:BTS]BTSTYP <> 60 | [F:BTS]BTSNUM <> GMOLNUM
    Read [BTS]BTS0=60;GMOLNUM : If fstat Raz [F:BTS] : Endif
Endif
Return

###############################################################
$CHARG_MASK
Local Char    WFCY(GLONFCY)
Local Integer WALT
Local Date    WDAT
Local Integer WMSG
Local Integer I
Local Char CRITERE2(90)
Local Char CRITERE(255)
Local Char CRITERE3(255)
# 09.01 CUSFLT zone de filtres supplémentaires demande 10405
Local Char CUSFLT(255)
Local Char FORMULE1(255)

# 09.02 demande 11578 1.4.0
Local Decimal WCPLTIMGLO        # Temps réalisé global saisie en entête
Local Decimal WEXTTIMGLO        # Temps prévu global exprimé dans l'unité du temps global réalisé
Local Decimal WCOEFF_CPLOPETIM  # % du temps prévu de l'opé par rapport au temps prévu total

WCPLTIMGLO = [M:MBO]CPLTIMGLO

Local Integer WMAX : WMAX = dim([M:MBO]TIMTYP) - 2

Gosub DEL_QLYWRK From MTKLIB

CRITERE = "1=1"
Raz CRITERE2
Raz CRITERE3
Raz FORMULE1
Raz WEXTTIMGLO
Raz WCOEFF_CPLOPETIM

Raz [F:MFG]
Effzo [M:MBO]15

Call STKCTRIPT(date$,[M:MBO]FCY,"1") From STKLIB
If GMESSAGE <> "" : Return : Endif

GOPELIN = 1
If  ([M:MBO]WROUNUMF <> "" & [F:BTS]GAMFLG = 2) | [F:BTS]OFFLG = 1
     CRITERE += "& FCY = [M:MBO]FCY"
    If [M:MBO]WROUNUMF <> ""
        CRITERE += "& ITMREF >=[M:MBO]WROUNUMD & ITMREF <= [M:MBO]WROUNUMF"
    Endif
    If [M:MBO]WROUALTF <> 0
        CRITERE += "& ROUALT >= [M:MBO]WROUALTD & ROUALT <= [M:MBO]WROUALTF"
    Endif
    If [M:MBO]WWSTF <> ""
      CRITERE += "& WST >= [M:MBO]WWSTD & WST <= [M:MBO]WWSTF"
    Endif
    # 05.02 demande 14201
    CRITERE2 = "((VALSTRDAT <= date$ | VALSTRDAT = [0/0/0]) & (VALENDDAT > date$ | VALENDDAT = [0/0/0]))"
    # Point d'entrée pour permettre à l'utilisateur de rajouter des sélections
    # 09.01 demande 10405
      Raz CUSFLT
      GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
      If CUSFLT = "" : CUSFLT = "1=1" : Endif
#
    Gosub ANALYSE_FORMULE
    If FORMULE1 = "" : FORMULE1 = "1=1" : Endif

    If CRITERE2 <> ""
        Filter [F:ROO] Where evalue(CRITERE) & evalue(CRITERE2) & evalue(CUSFLT) & evalue(FORMULE1)
    Else
      Filter [F:ROO] Where evalue(CRITERE) & evalue(CUSFLT) & evalue(FORMULE1)
    Endif
    nolign = 0
    For [F:ROO]
        # 07.01 récuperer le poste
        Read [F:MWS]WST0 = [F:ROO]WST;[F:ROO]FCY
        If !fstat & [F:MWS]WSTTYP <> 3
          #L'opération doit-elle être suivie
           Read [ROS]ROS0=[F:ROO]FCY;[F:ROO]ITMREF;[F:ROO]ROUALT;[F:ROO]OPENUM
           If !fstat & [F:ROS]DACMST > 1
               If nolign+1 > WMAX : Break : Endif
               Read [F:TRO]TRO0 = [F:ROO]ROUALT
               If [F:TRO]FCY = "" | [F:TRO]FCY = [M:MBO]FCY
                   WDAT= date$
                   WMSG=1
                   WFCY=[M:MBO]FCY
#                  Lecture ROUTING
                   Read [F:ROH]ROH0=[F:ROO]ITMREF;[F:ROO]ROUALT;[F:ROO]FCY : # Beryl Site en fin de clé primaire
                   If !fstat
                         Call CONTMFGGAM(WFCY,WALT,WDAT,WMSG)
                         If WALT <> 0
                                nolign += 1
                               [M:MBO]IPTDAT(nolign-1) = date$
                               [M:MBO]TIMTYP(nolign-1)    = 2
                               Gosub CHARG_ROO
                               [M:MBO]WINDIC(nolign-1) = 1
                               [M:MBO]WROUVAL(nolign-1)   = 1
                               [M:MBO]WLINUM(nolign-1)    = GOPELIN
                               GOPELIN               += 1
                               # 09.02 demande 11578 1.4.0
                               #si un temps à ventiler est saisi, on cumule les temps opé prévus
                               #on enlève  le temps de réglage du temps total saisi
                               If [M:MBO]CPLTIMGLO <> 0 & [F:BTS]CPLUPDFLG = 2
                                   If [M:MBO]CPLUOMCOD <> [M:MBO]TIMUOMCOD(nolign-1)
                                      Case [M:MBO]CPLUOMCOD
                                           When 1 : # le temps total est en heure et le temps de l'opé est en minute
                                                    # on ramène le temps de l'opé en heure
                                                    If [M:MBO]CPLOPETIM(nolign-1) <> 0
                                                        WEXTTIMGLO += [M:MBO]CPLOPETIM(nolign-1) / 60
                                                    Endif
                                                    If [M:MBO]CPLSETTIM(nolign-1) <> 0
                                                       If WCPLTIMGLO = 0 : Raz [M:MBO]CPLSETTIM(nolign-1)
                                                       Else
                                                          WCPLTIMGLO -= [M:MBO]CPLSETTIM(nolign-1) / 60
                                                       Endif
                                                    Endif
                                           When 2 : # le temps total est en minute et le temps de l'opé est en heure
                                                    # on ramène le temps de l'opé en minute
                                                    If [M:MBO]CPLOPETIM(nolign-1) <> 0
                                                        WEXTTIMGLO += [M:MBO]CPLOPETIM(nolign-1) * 60
                                                    Endif
                                                    If [M:MBO]CPLSETTIM(nolign-1) <> 0
                                                       If WCPLTIMGLO = 0 : Raz [M:MBO]CPLSETTIM(nolign-1)
                                                       Else
                                                          WCPLTIMGLO -= [M:MBO]CPLSETTIM(nolign-1) * 60
                                                       Endif
                                                    Endif
                                      Endcase
                                   Else
                                       If [M:MBO]CPLOPETIM(nolign-1) <> 0
                                           WEXTTIMGLO += [M:MBO]CPLOPETIM(nolign-1)
                                       Endif
                                       If [M:MBO]CPLSETTIM(nolign-1) <> 0
                                          If WCPLTIMGLO = 0 : Raz [M:MBO]CPLSETTIM(nolign-1)
                                          Else
                                              WCPLTIMGLO -= [M:MBO]CPLSETTIM(nolign-1)
                                          Endif
                                       Endif
                                    Endif
                                    If WCPLTIMGLO < 0 : Raz WCPLTIMGLO : Endif
                                Endif
                         Endif
                   Endif
               Endif
           Endif
        Endif
    Next
    [M:MBO]NBLIG = nolign
    Filter [F:ROO]
Elsif [F:BTS]OFFLG = 2
    CRITERE += "&MFGFCY=[M:MBO]FCY"
    If [M:MBO]WMFGNUMF <> ""
       CRITERE += "&MFGNUM>=[M:MBO]WMFGNUMD&MFGNUM<=[M:MBO]WMFGNUMF"
    Endif
    If [M:MBO]WOPENUMF <> 0
       CRITERE += "&OPENUM>=[M:MBO]WOPENUMD&OPENUM<=[M:MBO]WOPENUMF"
    Endif
    If [M:MBO]WWSTF <> ""
      CRITERE += "&EXTWST>=[M:MBO]WWSTD&EXTWST<=[M:MBO]WWSTF"
    Endif
    If [M:MBO]ENDDATEND <> [0/0/0]
      CRITERE2 = "OPEEND>=[M:MBO]ENDDATSTR&OPEEND<=[M:MBO]ENDDATEND"
    Endif
    If [F:BTS]FILTFLG < 3
        Case [M:MBO]FILTOPE
              When 1 : CRITERE -= "&MFOTRKFLG<"+num$(5)
              When 2 : CRITERE -= "&MFOTRKFLG="+num$(5)
        Endcase
    Else
       Case [F:BTS]FILTDEF
              When 1 : CRITERE -= "&MFOTRKFLG<"+num$(5)
              When 2 : CRITERE -= "&MFOTRKFLG="+num$(5)
        Endcase
    Endif

    CRITERE += "&OPESTA<"+num$(6)

#
# Point d'entrée pour permettre à l'utilisateur de rajouter des sélections
# 09.01 demande 10405
    Raz CUSFLT
    GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
    If CUSFLT = "" : CUSFLT = "1=1" : Endif
#
    Gosub ANALYSE_FORMULE
    If FORMULE1 = "" : FORMULE1 = "1=1" : Endif

    If CRITERE2 <> ""
       Filter [F:MFO] Where evalue(CRITERE) & evalue(CRITERE2) & evalue(CUSFLT) & evalue(FORMULE1)
&              Order By Key MFO0
    Else
       Filter [F:MFO] Where evalue(CRITERE) & evalue(CUSFLT) & evalue(FORMULE1)
&               Order By Key MFO0
    Endif
    nolign = 0
    For [MFO]
         If [F:MFG]MFGNUM <> [F:MFO]MFGNUM
             Read [MFG]MFG0 = [F:MFO]MFGNUM
             If fstat : Raz [F:MFG] : Endif
         Endif
         #L'OF doit être complet
         If [F:MFG]TYPMOD = 1    : Goto NEXTMFO1  : Endif
         #L'OF doit être ferme et alloué complètement
         If [F:MFG]MFGSTA <> 1   : Goto NEXTMFO1 : Endif
         #L'OF ne doit pas être suspendu
         If [F:MFG]SUSFLG = 2    : Goto NEXTMFO1 : Endif
         #Selon paramètre général l'OF doit être alloué complètement
         If GMTKALLMGT = 2 & !find([F:MFG]ALLSTA,3,5) & [F:MFG]MATLINNBR <> 0
             Goto NEXTMFO1
         Endif
         #Selon paramètre général, l'OF doit être édité
         If  [F:MFG]MFGTRKFLG < 3 & GDOSFAB = 2 : Goto NEXTMFO1 : Endif

         # FQ 62819 GA 03/2010 ajout d'un test GPE idem FUNBENCHM(CUSCTLSUP) et FUNBENCHO(CUSSELENR)
         #sr 10.02 demande 16112 Point d'entrée pour permettre à l'utilisateur d'intervenir
         #dans la boucle de lecture de MFGOPE
         GPOINT = "CUSSELENR" : GPE=1 : Gosub ENTREE From EXEFNC
         If !GPE  : Goto NEXTMFO1  : Endif

         # boucle d'analyse des matières bloquantes si rupture
         mkstat = 0
         For [MFM]MFM0 Where MFGNUM = [F:MFG]MFGNUM                    # 10.02 Performances
                 If [F:MFM]SHTQTY <> 0
                    Read [ITF]ITF0=[F:MFM]ITMREF;[F:MFM]MFGFCY
                    If !fstat & [F:ITF]MFGSHTCOD = 1
                        mkstat = 1 : Break
                    Endif
                 Endif
         Next
         If mkstat = 1 : Goto NEXTMFO1 : Endif

         # 10.01 filtrer sur l'article fabriqué   demande 10676
         If [M:MBO]WITMREFF <> "" | [M:MBO]WCDEF <> "" | [M:MBO]WPJTF <> ""
             # GH 06/12/2013 bug 94706
             mkstat = 0
             For [MFI] Where MFGNUM = [F:MFG]MFGNUM
                 If [M:MBO]WITMREFF <> "" & ([F:MFI]ITMREF < [M:MBO]WITMREFD | [F:MFI]ITMREF > [M:MBO]WITMREFF)
                    mkstat = 1 : Break
                 Endif
                 If [M:MBO]WCDEF <> "" & ([F:MFI]VCRNUMORI < [M:MBO]WCDED | [F:MFI]VCRNUMORI > [M:MBO]WCDEF)
                    mkstat = 1 : Break
                 Endif
                 If [M:MBO]WPJTF <> "" & ([F:MFI]PJT < [M:MBO]WPJTD | [F:MFI]PJT > [M:MBO]WPJTF)
                    mkstat = 1 : Break
                 Endif
            Next
            If mkstat = 1 : Goto NEXTMFO1 : Endif
         Endif

         If nolign+1 > WMAX : Break : Endif
         Read [F:MWS]WST0 = [F:MFO]EXTWST;[F:MFO]MFGFCY
         If !fstat & [F:MWS]WSTTYP <> 3
              Read [F:SCH]SCH0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
              If !fstat & [F:SCH]DACMST > 1
                nolign += 1
                [M:MBO]IPTDAT(nolign-1) = date$
                [M:MBO]TIMTYP(nolign-1) = 1
                Gosub CHARG_MFO
                [M:MBO]WINDIC(nolign-1) = 1
                [M:MBO]WLINUM(nolign-1) = GOPELIN
                GOPELIN += 1
                # 09.02 demande 11578 1.4.0
                #si un temps à ventiler est saisi, on cumule les temps opé prévus
                #on enlève le temps de réglage du temps global saisi
                If [M:MBO]CPLTIMGLO <> 0 & [F:BTS]CPLUPDFLG = 2
                   If [M:MBO]CPLUOMCOD <> [M:MBO]TIMUOMCOD(nolign-1)
                      Case [M:MBO]CPLUOMCOD
                           When 1 : # le temps total est en heure et le temps de l'opé est en minute
                                    # on ramène le temps de l'opé en heure
                                    If [M:MBO]CPLOPETIM(nolign-1) <> 0
                                        WEXTTIMGLO += [M:MBO]CPLOPETIM(nolign-1) / 60
                                    Endif
                                    If [M:MBO]CPLSETTIM(nolign-1) <> 0
                                       If WCPLTIMGLO = 0 : Raz [M:MBO]CPLSETTIM(nolign-1)
                                       Else
                                          WCPLTIMGLO -= [M:MBO]CPLSETTIM(nolign-1) / 60
                                       Endif
                                    Endif
                           When 2 : # le temps total est en minute et le temps de l'opé est en heure
                                    # on ramène le temps de l'opé en minute
                                    If [M:MBO]CPLOPETIM(nolign-1) <> 0
                                        WEXTTIMGLO += [M:MBO]CPLOPETIM(nolign-1) * 60
                                    Endif
                                    If [M:MBO]CPLSETTIM(nolign-1) <> 0
                                       If WCPLTIMGLO = 0 : Raz [M:MBO]CPLSETTIM(nolign-1)
                                       Else
                                          WCPLTIMGLO -= [M:MBO]CPLSETTIM(nolign-1) * 60
                                       Endif
                                    Endif
                      Endcase
                   Else
                       If [M:MBO]CPLOPETIM(nolign-1) <> 0
                           WEXTTIMGLO += [M:MBO]CPLOPETIM(nolign-1)
                       Endif
                       If [M:MBO]CPLSETTIM(nolign-1) <> 0
                          If WCPLTIMGLO = 0 : Raz [M:MBO]CPLSETTIM(nolign-1)
                          Else
                              WCPLTIMGLO -= [M:MBO]CPLSETTIM(nolign-1)
                          Endif
                       Endif
                    Endif
                    If WCPLTIMGLO < 0 : Raz WCPLTIMGLO : Endif
                Endif
              Endif
          Endif
    $NEXTMFO1
    Next
    If WCPLTIMGLO < 0 : Raz WCPLTIMGLO : Endif
    [M:MBO]NBLIG = nolign
    Filter [F:MFO]
Endif
# 09.02 demande 11578 1.4.0
# si un temps global a été saisi et que l'on doit précharger le réalisé
If [M:MBO]CPLTIMGLO <> 0  & [F:BTS]CPLUPDFLG = 2 : Gosub VENTILE_CPLTIMGLO : Endif

# 11.04 demande 26502 chargement spécifique du masque MBO
GPOINT = "LOAMSKMBO" : Gosub ENTREE From EXEFNC

Gosub AFF_TABLEAU
Return

##################################################
$CHARG_MASKB
Local Integer I,WI
Local Integer WMAX : WMAX = dim([M:MBO]TIMTYP) - 2

Raz I,WI
nolign = 0
[M:MBO]CPLUOMCOD = 1
Effzo [M:MBO]15

Call STKCTRIPT(date$,[M:MBO]FCY,"1") From STKLIB
If GMESSAGE <> "" : Return : Endif

For WI = 0 To [M:MTPK]NBLIG-1
    Read [F:MFG]MFG0 = [M:MTPK]MFGNUM(WI)
    Case [F:BTS]FILTDEF
        When 1 :    Filter [F:MFO] Where MFGNUM = [M:MTPK]MFGNUM(WI) & OPESTA < 6 & MFOTRKFLG <5
        When 2 :    Filter [F:MFO] Where MFGNUM = [M:MTPK]MFGNUM(WI) & OPESTA < 6 & MFOTRKFLG =5
        When 3 :    Filter [F:MFO] Where MFGNUM = [M:MTPK]MFGNUM(WI) & OPESTA < 6
    Endcase
    For [F:MFO]
         # boucle d'analyse des matières bloquantes si rupture
         For [MFM]MFM0 Where MFGNUM = [F:MFG]MFGNUM
                 If [F:MFM]SHTQTY <> 0
                    Read [ITF]ITF0=[F:MFM]ITMREF;[F:MFM]MFGFCY
                    If !fstat & [F:ITF]MFGSHTCOD = 1
                        mkstat = 1
                        Break
                    Endif
                 Endif
         Next
         If mkstat = 1 : Goto NEXTMFO2 : Endif
         If nolign+1 > WMAX : BREAK2 : Endif
         Read [F:MWS]WST0 = [F:MFO]EXTWST;[F:MFO]MFGFCY
         If !fstat & [F:MWS]WSTTYP <> 3
              Read [F:SCH]SCH0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
              If !fstat & [F:SCH]DACMST > 1
                nolign += 1
                [M:MBO]IPTDAT(nolign-1) = date$
                [M:MBO]TIMTYP(nolign-1) = 1
                Gosub CHARG_MFO
                [M:MBO]WINDIC(nolign-1) = 1
                [M:MBO]WLINUM(nolign-1) = GOPELIN
                GOPELIN += 1
              Endif
        Endif
    $NEXTMFO2
    Next
Next
[M:MBO]NBLIG = nolign
Filter [F:MFO]
# 11.04 demande 26502 chargement spécifique du masque MBO
GPOINT = "LOAMSKMBO" : Gosub ENTREE From EXEFNC
Grizo [M:MBO]5,7,10
Affzo [M:MBO]7
Gosub AFF_TABLEAU

Return

##################################################
$ANALYSE_FORMULE
# analyse présence formule de sélection
If [M:MBO]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
Else
    Read [F:TFO]TFO0=14;[M:MBO]FORMULE
    If fstat
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
    Else
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif

Return

##################################################
$CHARG_MFO
Local Char    WCCE(15)
Local Integer J, LRET
# 04.02 demande 9134 + demande 33513
Local Decimal WCPLQTY, WCPLOPETIM, WCPLSETTIM
# llc 09.02 15971
Local Decimal WUNTTIM
#
[M:MBO]                     = [F:MFO]
[M:MBO]MKOTEX(nolign-1)     = [F:MFO]MFOTEX
# FQ 64589 GA 05/2010 If [F:BTS]MATRICULE <> 3 (ne pas écraser la valeur)
If [F:BTS]MATRICULE <> 3 & [M:MBO]WEMPNUM<>0
    [M:MBO]EMPNUM(nolign-1) = [M:MBO]WEMPNUM
Endif
[M:MBO]CPLWST(nolign-1)    = [F:MFO]EXTWST
[M:MBO]CPLLAB(nolign-1)    = [F:MFO]EXTLAB
[M:MBO]OPESPLNUM(nolign-1) = [F:MFO]OPESPLNUM
[M:MBO]TIMUOMCOD(nolign-1) = [F:MFO]TIMUOMCOD
[M:MBO]XOPEUOM(nolign-1)   = [F:MFO]OPEUOM
[M:MBO]STU(nolign-1)       = [F:MFG]STU
[M:MBO]OPESTUCOE(nolign-1) = [F:MFO]OPESTUCOE
# Issue 88551 - 2013-03-13 by CCC
If [M:MBO]EFF(nolign-1)=0
    [M:MBO]EFF(nolign-1)=100
Endif
# 11.02 demande 16654
# opération ajoutée à l'OF on doit la voir comme une opé d'OF normale
If [M:MBO]ROUOPENUM(nolign-1) = 0 : [M:MBO]ROUOPENUM(nolign-1) = [M:MBO]OPENUM(nolign-1) : Endif

#nouvelle gestion des qtés en UO ou US selon transaction
Case [F:BTS]OPEUOMMOD
    When 1 :  [M:MBO]OPEUOM(nolign-1)           = [F:MFO]OPEUOM
              [M:MBO]OPEWORCOE(nolign-1)        = 1
    When 2 :  Case [F:BTS]OPEUOMTYP
                  When 1 : [M:MBO]OPEUOM(nolign-1)    = [F:MFO]OPEUOM
                           [M:MBO]OPEWORCOE(nolign-1) = 1
                  When 2 : [M:MBO]OPEUOM(nolign-1)    = [F:MFG]STU
                           [M:MBO]OPEWORCOE(nolign-1) = [F:MFO]OPESTUCOE
                   # 10.06 demande 38192 tenir compte du coeff US-UO suite
                   [M:MBO]OPESTUCOE(nolign-1) = 1
              Endcase
Endcase
#
If [M:MBO]OPEWORCOE(nolign-1) = 0 : [M:MBO]OPEWORCOE(nolign-1) = 1 : Endif
#
# llc 09.02 15971
If [F:MFO]EXTQTY > 0
    WUNTTIM = [F:MFO]EXTOPETIM / [F:MFO]EXTQTY
Endif
# 08.01 si opération soldée, le flag solde est positionné à oui
# On ne propose ni quantité ni temps réalisés
If [F:MFO]MFOTRKFLG = 5
   [M:MBO]CLEFLG(nolign-1) = 2
    Raz [M:MBO]CPLSETTIM(nolign-1), [M:MBO]CPLOPETIM(nolign-1), [M:MBO]CPLQTY(nolign-1),
&   [M:MBO]WQTY(nolign-1)
# 02.02 on garde toujours le temps unitaire demande 13045
    [M:MBO]CPLUNTTIM(nolign-1) = WUNTTIM * [M:MBO]OPEWORCOE(nolign-1)        # llc 09.02 15971
Else
    If [F:BTS]CPLUPDFLG = 2
# 04.02 demande 9134
        Gosub CALC_WCPLQTY
        [M:MBO]CPLSETTIM(nolign-1) = [F:MFO]EXTSETTIM - WCPLSETTIM
        If [M:MBO]CPLSETTIM(nolign-1) < 0 : Raz [M:MBO]CPLSETTIM(nolign-1) : Endif
        # 11.05 demande 33513
#        [M:MBO]CPLOPETIM(nolign-1) = [F:MFO]EXTOPETIM - [F:MFO]CPLOPETIM
        [M:MBO]CPLOPETIM(nolign-1) = [F:MFO]EXTOPETIM - WCPLOPETIM
        If [M:MBO]CPLOPETIM(nolign-1) < 0 : Raz [M:MBO]CPLOPETIM(nolign-1) : Endif
        [M:MBO]CPLUNTTIM(nolign-1) = WUNTTIM * [M:MBO]OPEWORCOE(nolign-1)    # llc 09.02 15971
        [M:MBO]CPLQTY(nolign-1)    = ([F:MFO]EXTQTY- WCPLQTY) / [M:MBO]OPEWORCOE(nolign-1)
        If [M:MBO]CPLQTY(nolign-1) < 0 : Raz [M:MBO]CPLQTY(nolign-1) : Endif
        [M:MBO]WQTY(nolign-1)      = [M:MBO]CPLQTY(nolign-1)
# 04.02 demande 9134
        Call CONT_SOLDE_OPE([M:MBO]FCY,[M:MBO]CPLWST(nolign-1),[M:MBO]CPLQTY(nolign-1),[M:MBO]WQTY(nolign-1),LRET) From MFGLIBO
        If LRET = 1 : [M:MBO]CLEFLG(nolign-1) = 2
        Else          [M:MBO]CLEFLG(nolign-1) = 1
        Endif
    Else
# 04.02 demande 9134
        Gosub CALC_WCPLQTY
        [M:MBO]WQTY(nolign-1)    = ([F:MFO]EXTQTY- WCPLQTY) / [M:MBO]OPEWORCOE(nolign-1)
        If [M:MBO]WQTY(nolign-1) < 0 : Raz [M:MBO]WQTY(nolign-1) : Endif
        Raz [M:MBO]CPLSETTIM(nolign-1), [M:MBO]CPLOPETIM(nolign-1), [M:MBO]CPLQTY(nolign-1)
        # 02.02 on garde toujours le temps unitaire demande 13045
        [M:MBO]CPLUNTTIM(nolign-1) = WUNTTIM * [M:MBO]OPEWORCOE(nolign-1)    # llc 09.02 15971
        [M:MBO]CLEFLG(nolign-1) = 1
    Endif
Endif
Raz [M:MBO]REJCPLQTY(nolign-1)
[M:MBO]TECCRD(nolign-1)     = [F:MFO]TECCRD
[M:MBO]MFOEXTQTY(nolign-1)  = [F:MFO]EXTQTY
[M:MBO]MFOCPLQTY(nolign-1)  = [F:MFO]CPLQTY
[M:MBO]MFOREJQTY(nolign-1)  = [F:MFO]REJCPLQTY
[M:MBO]MFOOKQTY(nolign-1)   = [M:MBO]MFOCPLQTY(nolign-1)-[M:MBO]MFOREJQTY(nolign-1)
[M:MBO]MFOESETTIM(nolign-1) = [F:MFO]EXTSETTIM
[M:MBO]MFOCSETTIM(nolign-1) = [F:MFO]CPLSETTIM
[M:MBO]MFOEOPETIM(nolign-1) = [F:MFO]EXTOPETIM
[M:MBO]MFOCOPETIM(nolign-1) = [F:MFO]CPLOPETIM
[M:MBO]WROUVAL(nolign-1)= 0
[M:MBO]DACMST(nolign-1) = [F:SCH]DACMST
[M:MBO]SCDCOD(nolign-1) = [F:SCH]SCDCOD
[M:MBO]NEXOPENUM(nolign-1) = [F:SCH]NEXOPENUM
[M:MBO]INFCAPSTR(nolign-1)  = [F:SCH]OPESTRDAT
[M:MBO]INFCAPEND(nolign-1)  = [F:SCH]OPEENDDAT
[M:MBO]MFGMST(nolign-1)     = [F:SCH]MFGMST
[M:MBO]OPEPREC(nolign-1) = 0    # Issue 84311 - 2012-09-06 by CCC
Filter [F:SCH] Where MFGNUM = [M:MBO]MFGNUM(nolign-1) & NEXOPENUM = [M:MBO]OPENUM(nolign-1)
Read [F:SCH]SCH0 First
If !fstat : [M:MBO]OPEPREC(nolign-1) = [F:SCH]OPENUM : Endif
Filter [F:SCH]
If [F:MFG]MFGNUM <> [F:MFO]MFGNUM
   Read [F:MFG]MFG0        = [F:MFO]MFGNUM
   If fstat : Raz [F:MFG] : Endif
Endif
[M:MBO]ITMREF(nolign-1) = [F:MFG]ROUNUM
[M:MBO]ROUALT(nolign-1) = [F:MFG]ROUALT
If [F:MFI]MFGNUM <> [F:MFO]MFGNUM
   Filter [MFI] Where MFGNUM = [F:MFO]MFGNUM
   Read [MFI]MFI0 First
   If fstat : Raz [F:MFI] : Endif
   Filter [MFI]
Endif
[M:MBO]BOMNUM(nolign-1)  =  [F:MFI]ITMREF
[M:MBO]BOMALT(nolign-1)  =  [F:MFI]BOMALT
[M:MBO]WMATOK(nolign-1)  =  1

#Chargement des sections ana
For J = 1 To GNBDIE
      Call INISEC(WCCE,"MKOB", J ) From TRTX3CPT
      Assign "[M:MBO]CCE"+num$(J)+"(nolign-1)" With WCCE
Next
If [F:MFO]EXTLAB <> ""
  # lecture poste main d'oeuvre pour section de valo (contenant les CCE)(18/09)
  Read [MWS]WST0=[F:MFO]EXTLAB;[F:MFO]MFGFCY
  For J = 1 To GNBDIE
      Call INISEC(WCCE,"MKOLABB", J ) From TRTX3CPT
      Assign "[M:MBO]LABCCE"+num$(J)+"(nolign-1)" With WCCE
  Next
Endif
# 11.06 demande 38402
[M:MBO]CPLUNTTIM(nolign-1) = func TRTX3.ARRTYP("","","TIH",[M:MBO]CPLUNTTIM(nolign-1))
[M:MBO]CPLOPETIM(nolign-1) = func TRTX3.ARRTYP("","","TIH",[M:MBO]CPLOPETIM(nolign-1))
[M:MBO]CPLSETTIM(nolign-1) = func TRTX3.ARRTYP("","","TIH",[M:MBO]CPLSETTIM(nolign-1))

Return

#######################################################
$CHARG_ROO
Local Char    WCCE(15)
Local Integer J
#
If [F:ITM]ITMREF <> [F:ROO]ITMREF
   Read [F:ITM]ITM0 = [F:ROO]ITMREF
   If fstat : Raz [F:ITM] : Endif
Endif
[M:MBO]                 = [F:ROO]
[M:MBO]MKOTEX(nolign-1) = [F:ROO]ROOTEX
# FQ 64589 GA 05/2010 If [F:BTS]MATRICULE <> 3 (ne pas écraser la valeur)
If [F:BTS]MATRICULE <> 3 & [M:MBO]WEMPNUM<>0
    [M:MBO]EMPNUM(nolign-1)    = [M:MBO]WEMPNUM
Endif
[M:MBO]XOPEUOM(nolign-1)   = [F:ROO]OPEUOM
[M:MBO]STU(nolign-1)       = [F:ITM]STU
# 08.02 1.4.0 récup éventuelle de la formule
If [F:ROO]OPESTUFOR <> ""
   Read [F:TFO]TFO0=2;[F:ROO]OPESTUFOR
   If !fstat
       If [F:ITF]ITMREF <> [F:ITM]ITMREF | [F:ITF]STOFCY <> [M:MBO]FCY
           Read [F:ITF]ITF0 = [F:ITM]ITMREF;[M:MBO]FCY
           If fstat : Raz [F:ITF] : Endif
       Endif
       If evalue([F:TFO]FORFOR) <> 0
           [M:MBO]OPESTUCOE(nolign-1) = evalue([F:TFO]FORFOR)
       Elsif [F:ROO]OPESTUCOE <> 0
           [M:MBO]OPESTUCOE(nolign-1) = [F:ROO]OPESTUCOE
       Else
            [M:MBO]OPESTUCOE(nolign-1) = 1
       Endif
   Else
    [M:MBO]OPESTUCOE(nolign-1) = [F:ROO]OPESTUCOE
   Endif
Else
   [M:MBO]OPESTUCOE(nolign-1) = [F:ROO]OPESTUCOE
Endif
#nouvelle gestion des qtés en UO ou US selon transaction
Case [F:BTS]OPEUOMMOD
    When 1 :  [M:MBO]OPEUOM(nolign-1)           = [F:ROO]OPEUOM
              [M:MBO]OPEWORCOE(nolign-1)        = 1
    When 2 :  Case [F:BTS]OPEUOMTYP
                  When 1 : [M:MBO]OPEUOM(nolign-1)    = [F:ROO]OPEUOM
                           [M:MBO]OPEWORCOE(nolign-1) = 1
                  When 2 : [M:MBO]OPEUOM(nolign-1)    = [F:ITM]STU
                           [M:MBO]OPEWORCOE(nolign-1) = [M:MBO]OPESTUCOE(nolign-1)
                   # 10.06 demande 38192 tenir compte du coeff US-UO suite
                   [M:MBO]OPESTUCOE(nolign-1) = 1
              Endcase
Endcase
#
If [M:MBO]OPEWORCOE(nolign-1) = 0 : [M:MBO]OPEWORCOE(nolign-1) = 1 : Endif

[M:MBO]ROUOPENUM(nolign-1) = [F:ROO]OPENUM
[M:MBO]OPEEND(nolign-1)    = [F:ROO]VALENDDAT
[M:MBO]CPLWST(nolign-1)    = [F:ROO]WST
[M:MBO]CPLLAB(nolign-1)    = [F:ROO]LABWST
[M:MBO]TIMUOMCOD(nolign-1) = [F:ROH]TIMUOMCOD
#
#Calcul du temps unitaire 07.01
Case [F:ROO]ROOTIMCOD    # suivant type tps opératoire
     When 1: # proportionnel
               [M:MBO]CPLUNTTIM(nolign-1)= ([F:ROO]OPETIM  / [F:ROO]BASQTY) * [M:MBO]OPEWORCOE(nolign-1)
     When 2: # cadence
               [M:MBO]CPLUNTTIM(nolign-1) = [F:ROO]CAD  * [M:MBO]OPEWORCOE(nolign-1)
     When 3: # forfaitaire
               [M:MBO]CPLUNTTIM(nolign-1) = [F:ROO]OPETIM
Endcase
Case GWSTEFFINH
     When 1:    # 04.05 13839
                If GOPEEFFAPP = 1
                    [M:MBO]CPLSETTIM(nolign-1) =  [F:ROO]SETTIM   /
&                                             ([F:ROO]EFF / 100) /
&                                             ([F:MWS]EFF    / 100)
                Else
                    [M:MBO]CPLSETTIM(nolign-1) =  [F:ROO]SETTIM
                Endif
                # CCC (14/09/07) Bug 42719
                [M:MBO]CPLUNTTIM(nolign-1) = [F:ROO]OPETIM    /
&                                            ([F:ROO]EFF / 100) /
&                                            ([F:MWS]EFF / 100)
                [M:MBO]EFF(nolign-1) = ([F:ROO]EFF / 100) * ([F:MWS]EFF / 100)  # Issue 88551 - 2013-03-13 by CCC
     When Default: # 04.05 13839
                   If GOPEEFFAPP = 1
                       [M:MBO]CPLSETTIM(nolign-1) = [F:ROO]SETTIM    /
&                                               ([F:ROO]EFF / 100)
                   Else
                       [M:MBO]CPLSETTIM(nolign-1) = [F:ROO]SETTIM
                   Endif
                # CCC (14/09/07) Bug 42719
                [M:MBO]CPLUNTTIM(nolign-1) = [F:ROO]OPETIM    /
&                                            ([F:ROO]EFF / 100)
                [M:MBO]EFF(nolign-1) = [F:ROO]EFF / 100    # Issue 88551 - 2013-03-13 by CCC
Endcase
# 07.01
#
If [M:MBO]EFF(nolign-1)=0
    [M:MBO]EFF(nolign-1)=100
Endif

Raz [M:MBO]CPLQTY(nolign-1), [M:MBO]REJCPLQTY(nolign-1), [M:MBO]CPLOPETIM(nolign-1)

Read [ROS]ROS0=[M:MBO]FCY;[M:MBO]ITMREF(nolign-1);[M:MBO]ROUALT(nolign-1);[M:MBO]OPENUM(nolign-1)
If !fstat
   [M:MBO]DACMST(nolign-1) = [F:ROS]DACMST
   [M:MBO]SCDCOD(nolign-1) = [F:ROS]SCDCOD
   [M:MBO]NEXOPENUM(nolign-1) = [F:ROS]NEXOPENUM
   [M:MBO]MFGMST(nolign-1)     = [F:ROS]MFGMST
   [M:MBO]OPEPREC(nolign-1) = 0     # Issue 84311 - 2012-09-06 by CCC
   Filter [F:ROS] Where FCY = [M:MBO]FCY & ITMREF = [M:MBO]ITMREF(nolign-1) & ROUALT = [M:MBO]ROUALT(nolign-1)
&                     & NEXOPENUM = [M:MBO]OPENUM(nolign-1)
   Read [F:ROS]ROS1 First                                        # 10.02 Performances
   If !fstat : [M:MBO]OPEPREC(nolign-1) = [F:ROS]OPENUM : Endif
   Filter [F:ROS]
Endif
[M:MBO]WMATOK(nolign-1)  =  1

#chargement des sections ana
Read [MWS]WST0=[F:ROO]WST;[M:MBO]FCY
For J = 1 To GNBDIE
  Call INISEC(WCCE,"MKOB", J ) From TRTX3CPT
  Assign "[M:MBO]CCE"+num$(J)+"(nolign-1)" With WCCE
Next
If [F:ROO]LABWST <> ""
  # lecture poste main d'oeuvre pour section de valo (contenant les CCE)(18/09)
  Read [MWS]WST0=[F:ROO]LABWST;[M:MBO]FCY
  For J = 1 To GNBDIE
    Call INISEC(WCCE,"MKOLABB", J) From TRTX3CPT
    Assign "[M:MBO]LABCCE"+num$(J)+"(nolign-1)" With WCCE
  Next
Endif
# sr 11.01 demande 11459 arrondir les temps calculés
[M:MBO]CPLSETTIM(nolign-1) = func TRTX3.ARRTYP("","","TIH",[M:MBO]CPLSETTIM(nolign-1))
[M:MBO]CPLOPETIM(nolign-1) = func TRTX3.ARRTYP("","","TIH",[M:MBO]CPLOPETIM(nolign-1))

# 11.06 demande 38402
[M:MBO]CPLUNTTIM(nolign-1) = func TRTX3.ARRTYP("","","TIH",[M:MBO]CPLUNTTIM(nolign-1))

Return

################################
# 04.02 demande 9134
$CALC_WCPLQTY
Local Integer I
WCPLQTY = [F:MFO]CPLQTY
WCPLOPETIM = [F:MFO]CPLOPETIM
WCPLSETTIM = [F:MFO]CPLSETTIM
If nolign > 1
   For I = 0 To nolign-2
       If [M:MBO]IPTDAT(I) = [M:MBO]IPTDAT(nolign-1) &
&         [M:MBO]MFGNUM(I) = [M:MBO]MFGNUM(nolign-1) &
&         [M:MBO]OPENUM(I) = [M:MBO]OPENUM(nolign-1)
          WCPLQTY += [M:MBO]CPLQTY(I)
          WCPLOPETIM += [M:MBO]CPLOPETIM(I)
          WCPLSETTIM += [M:MBO]CPLSETTIM(I)
       Endif
   Next
Endif
Return

#################################
# 09.02 demande 11578 1.4.0
$VENTILE_CPLTIMGLO
Local Integer I, LRET
Local Decimal WCPLOPETIM
# Issue 65361 - 2010-06-16 by CCC : la répartition des temps opératoire ne doit pas inclure des temps de réglage
Local Decimal WOPETIMGLO : WOPETIMGLO=WCPLTIMGLO

For I = 0 To [M:MBO]NBLIG-1
    # si il reste du temps à ventiler
    If WCPLTIMGLO <> 0
         # application du  % sur le temps prévu de l'opé si besoin
            If [M:MBO]CPLOPETIM(I) <> 0 & [M:MBO]CPLUNTTIM(I) <> 0
                 # calculer le % à appliquer
                If [M:MBO]CPLUOMCOD <> [M:MBO]TIMUOMCOD(I)
                   Case [M:MBO]CPLUOMCOD
                        When 1 : # le temps total est en heure et le temps de l'opé est en minute
                                 WCPLOPETIM = [M:MBO]CPLOPETIM(I) / 60
                        When 2 : # le temps total est en minute et le temps de l'opé est en heure
                                 WCPLOPETIM = [M:MBO]CPLOPETIM(I) * 60
                   Endcase
                Else
                   WCPLOPETIM = [M:MBO]CPLOPETIM(I)
                Endif
                # le coeff est le temps prévu total / le temps prévu de l'opé
                WCOEFF_CPLOPETIM = WEXTTIMGLO / WCPLOPETIM
                If WCOEFF_CPLOPETIM = 0 : WCOEFF_CPLOPETIM = 1 : Endif

                # calcul du réalisé pour l'opé
                # Issue 65361 - 2010-06-16 by CCC : la répartition des temps opératoire ne doit pas inclure des temps de réglage
                #WCPLOPETIM = [M:MBO]CPLTIMGLO / WCOEFF_CPLOPETIM
                WCPLOPETIM = WOPETIMGLO / WCOEFF_CPLOPETIM
                If WCPLOPETIM > WCPLTIMGLO : WCPLOPETIM = WCPLTIMGLO : Endif
                If [M:MBO]CPLUOMCOD <> [M:MBO]TIMUOMCOD(I)
                     Case [M:MBO]CPLUOMCOD
                          When 1 : # le temps total est en heure et le temps de l'opé est en minute
                                   [M:MBO]CPLOPETIM(I) = WCPLOPETIM * 60
                          When 2 : # le temps total est en minute et le temps de l'opé est en heure
                                   [M:MBO]CPLOPETIM(I) = WCPLOPETIM / 60
                     Endcase
                Else
                    [M:MBO]CPLOPETIM(I) = WCPLOPETIM
                Endif
                [M:MBO]CPLOPETIM(I) = func TRTX3.ARRTYP("","","TIH",[M:MBO]CPLOPETIM(I))
                # Issue 84897 - 2012-10-03 by CCC : WCPLTIMGLO et [M]CPLOPETIM n'ont pas forcément la même unité
                #WCPLTIMGLO -= [M:MBO]CPLOPETIM(I)
                WCPLTIMGLO -= WCPLOPETIM
            Else
               Raz [M:MBO]CPLOPETIM(I)
            Endif
    Else
            Raz [M:MBO]CPLOPETIM(I)
    Endif
    If [M:MBO]CPLUNTTIM(I) = 0 : Raz [M:MBO]CPLOPETIM(I)
    Else
        #    Ajustement de la quantité réalisée
# CCC (2010-04-07) Bug 63699
#        Case [M:MBO]TIMTYP(I)
#            When 1 : If [M:MBO]ROOTIMCOD(I) <> 3
#                        [M:MBO]CPLQTY(I) = [M:MBO]CPLOPETIM(I) / [M:MBO]CPLUNTTIM(I)
#                     Endif
#            When 2 : If [M:MBO]ROOTIMCOD(I) = 1
#                        [M:MBO]CPLQTY(I) = [M:MBO]CPLOPETIM(I) / [M:MBO]CPLUNTTIM(I)
#                     Elsif [M:MBO]ROOTIMCOD(I) = 2
#                        If [M:MBO]CAD(I) <> 0
#                            [M:MBO]CPLQTY(I) = [M:MBO]CPLOPETIM(I) * [M:MBO]CAD(I)
#                        Endif
#                     Endif
#        Endcase
        If find([M:MBO]TIMTYP(I),1,2)
            Case [M:MBO]ROOTIMCOD(I)
                When 1 : # Proportionnel
                        [M:MBO]CPLQTY(I) = [M:MBO]CPLOPETIM(I) / [M:MBO]CPLUNTTIM(I)
                When 2 : # Cadence
                        If [M:MBO]CAD(I) <> 0
                            # Issue 88551 - 2013-03-13 by CCC
                            #[M:MBO]CPLQTY(I) = [M:MBO]CPLOPETIM(I) * [M:MBO]CAD(I)
                            # GH 01/10/2014  bug 101352
                            #[M:MBO]CPLQTY(I) = [M:MBO]CPLOPETIM(I) * [M:MBO]CAD(I) * [M:MBO]EFF(I)/100
                            [M:MBO]CPLQTY(I) = [M:MBO]CPLOPETIM(I) / [M:MBO]OPEWORCOE(I) * [M:MBO]CAD(I) * [M:MBO]EFF(I)/100
                        Endif
            Endcase
        Endif
    Endif
    Call QTEARR([M:MBO]CPLQTY(I),[M:MBO]OPEUOM(I)) From TRTDIV
    Call CONT_SOLDE_OPE([M:MBO]FCY,[M:MBO]CPLWST(I),[M:MBO]CPLQTY(I),[M:MBO]WQTY(I),LRET) From MFGLIBO
    If LRET = 1 : [M:MBO]CLEFLG(I) = 2
    Else          [M:MBO]CLEFLG(I) = 1
    Endif
Next

# si il y a un reliquat, on l'applique à la dernière opé si tant est que l'on ait au moins une opération chargée !!!
If WCPLTIMGLO <> 0  & [M:MBO]NBLIG > 0
   I = [M:MBO]NBLIG-1
   If [M:MBO]CPLUOMCOD <> [M:MBO]TIMUOMCOD(I)
      Case [M:MBO]CPLUOMCOD
           When 1 : # le temps total est en heure et le temps de l'opé est en minute
                    [M:MBO]CPLOPETIM(I) += WCPLTIMGLO * 60
           When 2 : # le temps total est en minute et le temps de l'opé est en heure
                    [M:MBO]CPLOPETIM(I) += WCPLTIMGLO / 60
      Endcase
   Else
      [M:MBO]CPLOPETIM(I) += WCPLTIMGLO
   Endif
    [M:MBO]CPLOPETIM(I) = func TRTX3.ARRTYP("","","TIH",[M:MBO]CPLOPETIM(I))
   Raz  WCPLTIMGLO
   If [M:MBO]CPLUNTTIM(I) = 0 : Raz [M:MBO]CPLOPETIM(I)
   Else
        #    Ajustement de la quantité réalisée
#        Case [M:MBO]TIMTYP(I)
#            When 1 : If [M:MBO]ROOTIMCOD(I) <> 3
#                        [M:MBO]CPLQTY(I) = [M:MBO]CPLOPETIM(I) / [M:MBO]CPLUNTTIM(I)
#                     Endif
#            When 2 : If [M:MBO]ROOTIMCOD(I) = 1
#                        [M:MBO]CPLQTY(I) = [M:MBO]CPLOPETIM(I) / [M:MBO]CPLUNTTIM(I)
#                     Elsif [M:MBO]ROOTIMCOD(I) = 2
#                        If [M:MBO]CAD(I) <> 0
#                            [M:MBO]CPLQTY(I) = [M:MBO]CPLOPETIM(I) * [M:MBO]CAD(I)
#                        Endif
#                     Endif
#        Endcase
# CCC (2010-04-07) Bug 63699
        If find([M:MBO]TIMTYP(I),1,2)
            Case [M:MBO]ROOTIMCOD(I)
                When 1 : # Proportionnel
                        [M:MBO]CPLQTY(I) = [M:MBO]CPLOPETIM(I) / [M:MBO]CPLUNTTIM(I)
                When 2 : # Cadence
                        If [M:MBO]CAD(I) <> 0
                            # Issue 88551 - 2013-03-13 by CCC
                            #[M:MBO]CPLQTY(I) = [M:MBO]CPLOPETIM(I) * [M:MBO]CAD(I)
                            # GH 01/10/2014  bug 101352
                            #[M:MBO]CPLQTY(I) = [M:MBO]CPLOPETIM(I) * [M:MBO]CAD(I) * [M:MBO]EFF(I)/100
                            [M:MBO]CPLQTY(I) = [M:MBO]CPLOPETIM(I) / [M:MBO]OPEWORCOE(I) * [M:MBO]CAD(I) * [M:MBO]EFF(I)/100
                        Endif
            Endcase
        Endif
    Endif
    Call QTEARR([M:MBO]CPLQTY(I),[M:MBO]OPEUOM(I)) From TRTDIV
    Call CONT_SOLDE_OPE([M:MBO]FCY,[M:MBO]CPLWST(I),[M:MBO]CPLQTY(I),[M:MBO]WQTY(I),LRET) From MFGLIBO
    If LRET = 1 : [M:MBO]CLEFLG(I) = 2
    Else          [M:MBO]CLEFLG(I) = 1
    Endif
Endif

Return

###########################################
$AFF_TABLEAU
# llc 03.02 13304 ajout tri operation partout (si suivi sur gamme, il n'y a pas de date, d'OF ...)
Case [M:MBO]WSRT
     When 33  : Sorta [M:MBO]NBLIG [M:MBO]NBLIG Order By [M:MBO]OPEEND(indice),
&                                                        [M:MBO]MFGNUM(indice), [M:MBO]OPENUM(indice)
     When 65  : Sorta [M:MBO]NBLIG [M:MBO]NBLIG Order By [M:MBO]OPEEND(indice),
&                                                        [M:MBO]ITMREF(indice), [M:MBO]OPENUM(indice)
     When 129 : Sorta [M:MBO]NBLIG [M:MBO]NBLIG Order By [M:MBO]OPEEND(indice),
&                                                        [M:MBO]CPLWST(indice), [M:MBO]OPENUM(indice)
     When 18  : Sorta [M:MBO]NBLIG [M:MBO]NBLIG Order By [M:MBO]MFGNUM(indice),
&                                                        [M:MBO]OPEEND(indice), [M:MBO]OPENUM(indice)
     When 66  : Sorta [M:MBO]NBLIG [M:MBO]NBLIG Order By [M:MBO]MFGNUM(indice),
&                                                        [M:MBO]ITMREF(indice), [M:MBO]OPENUM(indice)
     When 130 : Sorta [M:MBO]NBLIG [M:MBO]NBLIG Order By [M:MBO]MFGNUM(indice),
&                                                        [M:MBO]CPLWST(indice), [M:MBO]OPENUM(indice)
     When  20 : Sorta [M:MBO]NBLIG [M:MBO]NBLIG Order By [M:MBO]ITMREF(indice),
&                                                        [M:MBO]OPEEND(indice), [M:MBO]OPENUM(indice)
     When  36 : Sorta [M:MBO]NBLIG [M:MBO]NBLIG Order By [M:MBO]ITMREF(indice),
&                                                        [M:MBO]MFGNUM(indice), [M:MBO]OPENUM(indice)
     When 132 : Sorta [M:MBO]NBLIG [M:MBO]NBLIG Order By [M:MBO]ITMREF(indice),
&                                                        [M:MBO]CPLWST(indice), [M:MBO]OPENUM(indice)
     When  24 : Sorta [M:MBO]NBLIG [M:MBO]NBLIG Order By [M:MBO]CPLWST(indice),
&                                                        [M:MBO]OPEEND(indice), [M:MBO]OPENUM(indice)
     When  40 : Sorta [M:MBO]NBLIG [M:MBO]NBLIG Order By [M:MBO]CPLWST(indice),
&                                                        [M:MBO]MFGNUM(indice), [M:MBO]OPENUM(indice)
     When  72 : Sorta [M:MBO]NBLIG [M:MBO]NBLIG Order By [M:MBO]CPLWST(indice),
&                                                        [M:MBO]ITMREF(indice), [M:MBO]OPENUM(indice)
Endcase
Affzo [M:MBO]10,15
Return

################################################################################################
$VALIDATION
# Issue 73286 - GA 01/2012
GPE=0 : GPOINT = "BEFVALID" : Gosub  ENTREE From EXEFNC
If GPE <> 0 : Return : Endif

# 04.07 Demande 40752
Local Char WFILTRE(80)

Gosub CRE_SUIVI
If !FICTECOK : Return : Endif

# 04.07 Demande 40752
# Issue 68937 - 2010-11-08 by CCC : Pb perf si les n° de documents ne sont pas consécutifs
For I=0 To [M:MBO]NBLIG-1
   If WMTKNUM(I)<>"" & (I=0 | WMTKNUM(I)<>WMTKNUM(I-1)) : # If WMTKNUM(I)<>"" : # GH 02/2016 bug 108954 optimisation
      #----- Régularisation des manquants et alloc pour articles lancés -----#
      # CCC (17/11/08) Bug 50329
      #For [MKI2] MKI0 Where MFGTRKNUM=[F:MTK]MFGTRKNUM
      #  WFILTRE="[F:MKI]MFGTRKNUM=[F:MKI2]MFGTRKNUM & [F:MKI]ITMTRKLIN=[F:MKI2]ITMTRKLIN"
      WFILTRE="[F:MKI]MFGTRKNUM='"+WMTKNUM(I)+"'"
      Call REGFROMENT(1,"MKI",WFILTRE,"ITMREF",[M:MBO]FCY) From TRTSHTCOM
      #Next
   Endif
Next

# 83588 # Issue 92291 before " PILOT"
If !GSERVEUR & LORI <> "PILOT"
     Call FERME_TRACE From LECFIC
     If TRA = 1
        # demande 12362 ne pas afficher la trace
        # Mettre GPOINT = "" pour inhiber l'action standard
        GPOINT = "AFFTRA"
        Gosub  ENTREE From EXEFNC
        If GPOINT <> ""
           Call LEC_TRACE From LECFIC
        Endif
     Endif
     TRA = 0
Endif

# GH 02/2016 bug 108954 don't lose entries if the validation didn't totally succeed
# Effzo [MBO]15
J=0
For I=0 To [M:MBO]NBLIG-1
  If WMTKNUM(I)="" & ([M:MBO]CPLSETTIM(I) <> 0 | [M:MBO]CPLOPETIM(I) <> 0 | [M:MBO]CPLQTY(I) <> 0)
     J=1 : Break
  Endif
Next
If !J
   # all what should be validated was => clear the grid
   Effzo [MBO]15
   [M:MBO]NBLIG=0
Else
   # all what should be validated was not => remove validated lines of the grid to make a new try of validation
   I=0
   While I<[M:MBO]NBLIG
     If WMTKNUM(I)<>""
        Dela I, 1 [M:MBO]NBLIG : [M:MBO]NBLIG-=1 : I-=1
     Endif
     I+=1
   Wend
   Affzo [MBO]15
Endif

If dim(GOPELIN)>0  # CCC (2009-11-25) Bug 60328 : Cette variable n'existe pas en VT
   Raz  GOPELIN
Endif
Return

################################################################################################
$FIN
# 01.10 mm 61503
Gosub REST_GLOB From TRTX3GLOB
Return

################################################################################################
#Création du suivi                                                                             #
#Rappel de fonctionnement selon la valeur de TIMTYP :                                          #
#     - 1 : On suit une opération d'OF (l'OF est renseigné ainsi que le n° d'OP)               #
#     - 2 :                                                                                    #
#           Si l'article ET l'alternative sont renseignés                                      #
#               On suit une opération de gamme (la gamme est renseigné ainsi que le n° d'OP)   #
#           Si l'article est renseigné et pas l'alternative                                    #
#               On suit un poste en terme de temps(réglage-opératoire) et de quantité réalisée #
#               (IL n'y a pas de numéro d'opération)                                           #
#     - 3 : On suit un poste pour un temps opératoire passé(ni temps de réglage ni qté)        #
################################################################################################
$CRE_SUIVI
Local Integer I,J,OK, WOK, WLIN, WOPECLENBR, WMATCLENBR , WITMCLENBR, WNBMAT, WNBOPE, WNBITM, WI
Local Integer STAT, LRET, WRETOUR, WNOLIGN, WCTLFICTEC
Local Date    WDAT
Local Char    WMFGNUM(GLONVCR), WWMFGNUM(GLONVCR), WMFGTRKNUM(GLONVCR), TIT(80)
Local Char    WNUMTEX (12)
Local Decimal WCPLQTY, WQUAQTY, WREJQTY
Local Char    WMTKNUMSTR(GLONVCR), WMTKNUMEND(GLONVCR), WMTKNUM(GLONVCR)(max(1,[M:MBO]NBLIG))
Local Integer WCRETRK, WNEW
Local Integer WMFGMKO                                         # GH 17/09/2015 bug 110557

Raz WMTKNUMSTR, WMTKNUMEND, WMTKNUM
#
# en mode VT tout est ok et pas de message
FICTECOK = 1
If !GVTMOD
    #1ere chose y a-t-il quelque chose à suivre ?
    If [M:MBO]NBLIG = 0 : Return : Endif
    WOK = 0
    For I = 0 To [M:MBO]NBLIG-1
        If [M:MBO]CPLSETTIM(I) <> 0 | [M:MBO]CPLOPETIM(I) <> 0 | [M:MBO]CPLQTY(I) <> 0
            WOK = 1
            Break
        Endif
    Next I
    If WOK = 0 : Call ERREUR(mess(219,193,1)) From GESECRAN : FICTECOK = 0 : Return : Endif

    #Contrôle que les fiches techniques ont bien été renseignées
    For I = 0 To [M:MBO]NBLIG-1
        # Issue 70415 - 2011-01-07 by CCC : S'assurer que l'opération est suivie avant de faire un contrôle dessus
        If [M:MBO]TECCRD(I) <> "" & GCTLFICTEC <> 1
&        & ([M:MBO]CPLSETTIM(I)<>0 | [M:MBO]CPLOPETIM(I)<>0 | [M:MBO]CPLQTY(I)<>0)
#&        & ([M:MBO]CPLSETTIM(nolign-1)<>0 | [M:MBO]CPLOPETIM(nolign-1)<>0 | [M:MBO]CPLQTY(nolign-1)<>0) : # GH 21/02/2014 bug 97139
           WCTLFICTEC = GCTLFICTEC
           If find(WCTLFICTEC,4,5)
              If [M:MBO]TIMTYP(I) = 1
                  # si on est sur le premier suivi alors fonctionnement selon valeur 2 ou 3
                  # Si on est sur le Xieme suivi, alors pas de contrôle
                  Filter [MKO] Where MFGNUM = [M:MBO]MFGNUM(I) & OPENUM = [M:MBO]OPENUM(I)
                  Look [MKO]MKO1(1) First
                  If fstat : WCTLFICTEC -= 2
                  Else     : WCTLFICTEC  = 1
                  Endif
                  Filter [MKO]
              Else
                  # si on est sur un suivi sur Gamme les valeurs 4 et 5 n'ont aucun sens
                  WCTLFICTEC -= 2
              Endif
           Endif
           Filter [QLW] Where PRONUM = adxuid(1) & LINNUM = [M:MBO]WLINUM(I)
           Look [QLW]QLW0 First
           Filter [QLW]
           If fstat
              Case WCTLFICTEC
                    When 2 : Call AVERTIR(mess(108,190,1)-num$(I+1),WOK) From GESECRAN
                             #Call AVERTIR(mess(108,190,1)+num$([M:MBO]WLINUM(I)),WOK) From GESECRAN : # GH 21/02/2014 bug 97139
                             If WOK <> 2 : FICTECOK = 0 :  Break : Endif
                    When 3 : Call ERREUR(mess(108,190,1)-num$(I+1)) From GESECRAN
                             #Call ERREUR(mess(108,190,1)-num$([M:MBO]WLINUM(I))) From GESECRAN : # GH 21/02/2014 bug 97139
                             FICTECOK = 0 : Break
              Endcase
           Endif
         Endif

         OK = 0
         #Si opération précedente non suivie message d'erreur selon GCTLOPEPRE
         # 02.02 controle uniquement si opé suivi demande 13159
         # 06.02 contrôle que si précédente non exclue demande 14752
         If GCTLOPEPRE > 1 & [M:MBO]OPEPREC(I) <> 0 & [M:MBO]TIMTYP(I) = 1
&         & ([M:MBO]CPLQTY(I)<>0 | [M:MBO]CPLOPETIM(I)<>0 | [M:MBO]CPLSETTIM(I) <> 0)
            Filter [MFO] Where MFGNUM = [M:MBO]MFGNUM(I) & OPENUM = [M:MBO]OPEPREC(I)
            Read [MFO]MFO0 First
            If fstat : Raz [F:MFO] : Endif
            Filter [MFO]
            If [F:MFO]TRKFIRST <> [0/0/0] | [F:MFO]OPESTA = 6 : Goto NEXTI : Endif
            Read [F:SCH]SCH0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
            If fstat : Raz [F:SCH] : Endif
            If [F:SCH]DACMST = 1 : Goto NEXTI : Endif
            For J = 0 To [M:MBO]NBLIG-1
                If [M:MBO]MFGNUM(J) = [M:MBO]MFGNUM(I) & [M:MBO]OPENUM(J) = [M:MBO]OPEPREC(I)
&                & ([M:MBO]CPLQTY(J)<>0 | [M:MBO]CPLOPETIM(J)<>0 | [M:MBO]CPLSETTIM(J)<>0)
                    OK = 1 : Break
                Endif
            Next J
            If OK = 0
                Case GCTLOPEPRE
                    When 2 :
                        #Call AVERTIR(mess(22,190,1)+num$([M:MBO]WLINUM(I)),WOK) From GESECRAN : # Issue 84311 - 2012-09-06 by CCC
                        #Call AVERTIR(mess(22,190,1)+num$([M:MBO]OPEPREC(I)),WOK) From GESECRAN : # GH 21/02/2014 bug 97139
                        Call AVERTIR(mess(22,190,1)-num$([M:MBO]OPEPREC(I))-"("+mess(61,100,1)-num$(I+1)+")",WOK) From GESECRAN
                        If WOK <> 2 :  FICTECOK = 0 :  Break : Endif
                    When 3 :
                        #Call ERREUR(mess(22,190,1)-num$([M:MBO]WLINUM(I))) From GESECRAN : # Issue 84311 - 2012-09-06 by CCC
                        #Call ERREUR(mess(22,190,1)-num$([M:MBO]OPEPREC(I))) From GESECRAN  : # GH 21/02/2014 bug 97139
                        Call ERREUR(mess(22,190,1)-num$([M:MBO]OPEPREC(I))-"("+mess(61,100,1)-num$(I+1)+")") From GESECRAN
                        FICTECOK = 0 : Break
                Endcase
            Endif
         Endif
    $NEXTI
    Next I
    If FICTECOK = 0 : Return : Endif

    # 07.02 demande 15144 contrôles supplémentaires avant de lancer la mise à jour.
    # sortie, si GPOINT = "", c'est que ce n'est pas OK et on sort
    GPOINT = "CUSCTRL" : Gosub  ENTREE From EXEFNC
    If GPOINT = "" : FICTECOK = 0 : Return : Endif
    #
    #
    #Un petit message de confirmation...
    OK = 1
    Call OUINON(mess(20,196,1),OK) From GESECRAN
    If OK <> 2 : FICTECOK = 0 : Return : Endif
    #
Endif

# FQ 73634 GA 05/2011 ctrl déplacé après la Question ...
# CCC (2010-04-28) Bug 54558 : Vérifier que l'OF n'est pas en cours de modif
For I=0 To [M:MBO]NBLIG-1
    #If func MFGLIB.CHKMFGLOCK([M:MBM]MFGNUM(I),0) : # GH 21/02/2014 bug 94986
    If ([M:MBO]CPLSETTIM(I)<>0 | [M:MBO]CPLOPETIM(I)<>0 | [M:MBO]CPLQTY(I)<>0)
&      & !sigma(0,I-1,[M:MBO]MFGNUM(indcum)=[M:MBO]MFGNUM(I)
&                     & ([M:MBO]CPLSETTIM(indcum)<>0 | [M:MBO]CPLOPETIM(indcum)<>0 | [M:MBO]CPLQTY(indcum)<>0))
&      & func MFGLIB.CHKMFGLOCK([M:MBO]MFGNUM(I),0)
        Call ERREUR([M:MBO]MFGNUM(I)-":"-mess(280,193,1)) From GESECRAN
        FICTECOK=0 : Break
    Endif
Next
If FICTECOK = 0 : Return : Endif

#On y va ...

# 83588
If !GSERVEUR & LORI <> "PILOT"
    TIT = mess(196,195,1)
    TRA=0
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif

#
# Issue 101365 - 2014-09-30 by CCC : WCRETRK%1 => no standard sorting ; WCRETRK%2 => use next entry point
Raz WCRETRK
GPOINT="MBOTRKCRE"
Gosub ENTREE From EXEFNC
If mod(WCRETRK,2)=0
    Sorta [M:MBO]NBLIG [M:MBO]NBLIG Order By [M:MBO]IPTDAT(indice),
&                                            [M:MBO]TIMTYP(indice),
&                                            [M:MBO]MFGNUM(indice),
&                                            [M:MBO]OPENUM(indice),
&                                            [M:MBO]CLEFLG(indice)
Endif

#Récupération du compteur
Call LECTCA(8,OK) From SUBTCA
If OK=0 : Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN : Return : Endif
GCODNUM    = [F:TCA]CODNUM(2)   # compteur suivi
GMANCOU    = [F:TCA]MANCOU(2)
GOPS       = [F:TCA]CODNUM(4)   # compteur encours opérations
#
Raz [L]WLIN
For nolign = 1 To [M:MBO]NBLIG
  If [M:MBO]CPLSETTIM(nolign-1)<>0 | [M:MBO]CPLOPETIM(nolign-1)<>0 | [M:MBO]CPLQTY(nolign-1)<>0

    # Issue 101365 - 2014-09-30 by CCC : WNEW=1 to create a new tracking number
    Raz WNEW
    If mod(WCRETRK,4)>=2
        GPOINT="MBOTRKLIN"
        Gosub ENTREE From EXEFNC
    Endif

    If [L]WLIN = 0
        WNEW = 1
    Elsif [M:MBO]IPTDAT(nolign-1) <> WDAT
        WNEW = 1
    Endif

    If WNEW = 1
       If WNBOPE<>0 : # GH 17/09/2015 bug 110557 if WLIN<>0
          If WWMFGNUM <> ""
             Gosub MAJ_ENTOF
             Raz WWMFGNUM
          Endif
          Gosub CRE_ENTETE
          If GOK<1 : Break : Endif
       Elsif adxlog : Rollback # GH 17/09/2015 bug 110557
       Endif
       WDAT = [M:MBO]IPTDAT(nolign-1)
       If [M:MBO]TIMTYP(nolign-1) = 1 : WMFGNUM  = [M:MBO]MFGNUM(nolign-1)
                                        WWMFGNUM = [M:MBO]MFGNUM(nolign-1)
       Endif
       Call DEBTRANS From GLOCK
       Trbegin [MKO]
       Call NUMERO(GCODNUM,[M:MBO]FCY,WDAT,"",WMFGTRKNUM,STAT) From SUBANM
       If STAT
          Call ERREUR(mess(60,199,1)-GCODNUM-num$([L]STAT)) From GESECRAN
          GOK = 0
          Break
       Endif
       WMTKNUM(nolign-1) = WMFGTRKNUM
    Else
        If [M:MBO]MFGNUM(nolign-1) <> WMFGNUM : Raz WMFGNUM : Endif
        If [M:MBO]MFGNUM(nolign-1) <> WWMFGNUM & WWMFGNUM <> ""
            Gosub MAJ_ENTOF
            Raz WWMFGNUM
            If GOK<1 : Break : Endif
            If [M:MBO]TIMTYP(nolign-1) = 1 : WWMFGNUM = [M:MBO]MFGNUM(nolign-1) : Endif
        Endif
    Endif

    Raz [M:MTOK]
    [M:MTOK]          = [M:MBO]
    [M:MTOK]MFGFCY    = [M:MBO]FCY
    If dim([M:MBO]WRHE)>0
        [M:MTOK]WRH       = [M:MBO]WRHE
    Endif
    [M:MTOK]MATFLG    = [F:BTS]MATFLG
    [M:MTOK]CONSMAT   = [F:BTS]CONSMAT
    [M:MTOK]ITMFLG    = [F:BTS]ITMFLG
    # 04.07  Demande 40665 Stockage des paramètres stocks
    [M:MTOK]ENTCOD    = [F:BTS]ENTCOD
    [M:MTOK]ENTCODS   = [F:BTS]ENTCODS
    [M:MTOK]PRNCOD    = [F:BTS]PRNCOD1
    [M:MTOK]PRNNBRFLG = [F:BTS]PRNNBFLG1
    [M:MTOK]TRSCOD    = [F:BTS]TRSCOD
    [M:MTOK]TRSCODS   = [F:BTS]TRSCODS
    [M:MTOK]TRSFAM    = [F:BTS]TRSFAM
    [M:MTOK]TRSFAMS   = [F:BTS]TRSFAMS
    [M:MTOK]MATFLTFLG = [F:BTS]MATFLTFLG
    [M:MTOK]ITMFLTFLG = [F:BTS]ITMFLTFLG
    [M:MTOK]MFGTRKNUM = WMFGTRKNUM
    [M:MTOK]OPETRKLIN = [L]WLIN
    [M:MTOK]WNBMAT    = WNBMAT
    [M:MTOK]WNBITM    = WNBITM
    # 07.02
    [M:MTOK]WOPECLENBR   = WOPECLENBR
    [M:MTOK]WMATCLENBR   = WMATCLENBR
    [M:MTOK]WITMCLENBR   = WITMCLENBR

    # 11.01 demande 11423 Ajouter STOCODMAN
    [M:MTOK]STOCODMAN    = [F:BTS]STOCODMAN
    #Pour suivre correctement les opé à suivre par borne sr 06.01
    If [M:MBO]TIMTYP(nolign-1) =  1
       If [M:MBO]MFOEXTQTY(nolign-1) <> 0 & [M:MBO]ROUOPENUM(nolign-1) <> 0
           [M:MTOK]WCOEFF    = [M:MTOK]CPLQTY / ([M:MBO]MFOEXTQTY(nolign-1)/ [M:MBO]OPEWORCOE(nolign-1))
           [M:MTOK]WCOEFF1   = [M:MTOK]REJCPLQTY / ([M:MBO]MFOEXTQTY(nolign-1)/ [M:MBO]OPEWORCOE(nolign-1))
       Else
           [M:MTOK]WCOEFF  = 1
           [M:MTOK]WCOEFF1 = 1
       Endif
       # CCC (09/12/08) Bug 50667 : le coef ne doit pas être arrondi sinon les qtés calculées sont fausses
       # Ce sont les quantités qui sont arrondies
       ## 01.02 demande 12597
       #[M:MTOK]WCOEFF = arr([M:MTOK]WCOEFF,0.00000001)
       #[M:MTOK]WCOEFF1 = arr([M:MTOK]WCOEFF1,0.00000001)
       #
    Endif

     For WI = 1 To 15
        [M:MTOK]SCANUM(WI-1)    = evalue("[M:MBO]SCANUM"+num$(WI)+"(nolign-1)")
        [M:MTOK]TABREJQTY(WI-1) = evalue("[M:MBO]TAREJQTY"+num$(WI)+"(nolign-1)")
      Next


#Création de la ligne suivi selon le type de temps
    Case [M:MBO]TIMTYP(nolign-1)
         When 1 : If [M:MBO]ROUOPENUM(nolign-1) <> 0
                      Local Integer WOPENUM : WOPENUM = [M:MBO]OPENUM(nolign-1)
                      If [M:MBO]DACMST(nolign-1) = 3
                          Local Shortint WOPE
                          Local Integer WBREAK
                          #Recherche de la précédente opération à suivre (normale ou borne)
                          Raz WBREAK,WOPE
                          Filter [F:MFO] Where MFGNUM = [M:MBO]MFGNUM(nolign-1) & OPENUM < [M:MBO]OPENUM(nolign-1)
&                                Order By Key MFO0 Desc
                          For [F:MFO]
                              Read [F:SCH]SCH0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
                              If !fstat & [F:SCH]DACMST >1 : WBREAK = 1 : Break : Endif
                          Next
                          If WBREAK = 1 : WOPE = [F:MFO]OPENUM : Endif
                          Filter [F:MFO]
           #Traitement des opé entre les deux bornes(borne supérieure comprise)
                          Filter [F:MFO] Where MFGNUM = [M:MBO]MFGNUM(nolign-1) &
&                                              OPENUM > WOPE & OPENUM <= [M:MBO]OPENUM(nolign-1)
                      Else
                          Filter [F:MFO] Where MFGNUM    = [M:MBO]MFGNUM(nolign-1) &
&                                              OPENUM    = [M:MBO]OPENUM(nolign-1) &
&                                              OPESPLNUM = [M:MBO]OPESPLNUM(nolign-1)
                      Endif
                      For [MFO]
                          WNOLIGN = nolign
                          [M:MTOK]TYPTRT = 2
                          Call CRE_MKO From MTKAUTLIB
                          If GOK < 1 : TRA = 1 : Break 2 : Endif
                          nolign = WNOLIGN
                          ## GH 17/09/2015 bug 110557
                          WNBOPE    += [M:MTOK]WNBOPE : # WNBOPE += 1
                          WMFGMKO   += [M:MTOK]WNBOPE
                          ##
                          [L]WLIN    = [M:MTOK]OPETRKLIN
                          WOPECLENBR = [M:MTOK]WOPECLENBR
                          WMATCLENBR = [M:MTOK]WMATCLENBR
                          WITMCLENBR = [M:MTOK]WITMCLENBR
                          WNBMAT     = [M:MTOK]WNBMAT
                          WNBITM     = [M:MTOK]WNBITM
                          WCPLQTY   += [M:MTOK]WCPLQTY
                          WREJQTY   += [M:MTOK]WREJCPLQTY
                          WQUAQTY   += [M:MTOK]WQUACPLQTY
                      $NEXTMFO
                      Next
                      Filter  [F:MFO]
                  Else
                      WNOLIGN = nolign
                      [M:MTOK]TYPTRT = 10
                      Call CRE_MKO From MTKAUTLIB
                      If GOK < 1 : TRA = 1 : Break : Endif
                      nolign = WNOLIGN
                      ## GH 17/09/2015 bug 110557
                      WNBOPE    += [M:MTOK]WNBOPE : # WNBOPE += 1
                      WMFGMKO   += [M:MTOK]WNBOPE
                      ##
                      [L]WLIN  = [M:MTOK]OPETRKLIN
                  Endif
         When 2 : If [M:MBO]WROUVAL(nolign-1) = 1 & [M:MBO]ROUOPENUM(nolign-1) <> 0
                      Local Integer WOPENUM : WOPENUM = [M:MBO]OPENUM(nolign-1)
                      If [M:MBO]DACMST(nolign-1) = 3
                          Local Shortint WOPE
                          Local Integer WBREAK
                          #Recherche de la précédente opération à suivre (normale ou borne)
                          Raz WBREAK,WOPE
                          # FQ 77863 GA 11/2011 vérifier aussi VALSTRDAT (?)
                          Filter [F:ROO] Where FCY = [M:MBO]FCY & ITMREF = [M:MBO]ITMREF(nolign-1) & ROUALT = [M:MBO]ROUALT(nolign-1)
&                                            &  OPENUM < [M:MBO]OPENUM(nolign-1)
&                                            & (VALENDDAT=[0/0/0] | (VALENDDAT >= date$ & VALENDDAT<>[0/0/0]) )
&                                            & (VALSTRDAT=[0/0/0] | (VALSTRDAT <= date$ & VALSTRDAT<>[0/0/0]) )
&                                              Order By Key ROO0 Desc
                          For [F:ROO]
                              Read [F:ROS]ROS0 = [F:ROO]FCY;[F:ROO]ITMREF;[F:ROO]ROUALT;[F:ROO]OPENUM
                              If !fstat & [F:ROS]DACMST >1 : WBREAK = 1 : Break : Endif
                          Next
                          If WBREAK = 1 : WOPE = [F:ROO]OPENUM : Endif
                          Filter [F:ROO]
           #Traitement des opé entre les deux bornes(borne supérieure comprise)
                          # FQ 77863 GA 11/2011 vérifier aussi VALSTRDAT (?)
                          Filter [F:ROO] Where ITMREF = [M:MBO]ITMREF(nolign-1)
&                                            &  ROUALT = [M:MBO]ROUALT(nolign-1)
&                                            &  OPENUM > WOPE & OPENUM <= [M:MBO]OPENUM(nolign-1)
&                                            & (VALENDDAT=[0/0/0] | (VALENDDAT >= date$ & VALENDDAT<>[0/0/0]) )
&                                            & (VALSTRDAT=[0/0/0] | (VALSTRDAT <= date$ & VALSTRDAT<>[0/0/0]) )
                      Else
                          Filter [F:ROO] Where ITMREF    = [M:MBO]ITMREF(nolign-1) &
&                                              ROUALT    = [M:MBO]ROUALT(nolign-1) &
&                                              OPENUM    = [M:MBO]OPENUM(nolign-1) &
&                                              RPLIND    = [M:MBO]RPLIND(nolign-1)
                      Endif
                      For [ROO]
                           WNOLIGN = nolign
                           [M:MTOK]TYPTRT = 6
                           Call CRE_MKO From MTKAUTLIB
                           If GOK < 1 : TRA = 1 : Break 2 : Endif
                           nolign = WNOLIGN
                           ## GH 17/09/2015 bug 110557
                           WNBOPE    += [M:MTOK]WNBOPE : # WNBOPE += 1
                           WMFGMKO   += [M:MTOK]WNBOPE
                           ##
                           [L]WLIN = [M:MTOK]OPETRKLIN
                           WNBMAT  = [M:MTOK]WNBMAT
                           WNBITM  = [M:MTOK]WNBITM
                      Next
                  Else
                         #Création enregistrement suivi opé
                         WNOLIGN = nolign
                         [M:MTOK]TYPTRT = 11
                         Call CRE_MKO From MTKAUTLIB
                         If GOK < 1 : TRA = 1 : Break : Endif
                         nolign = WNOLIGN
                         ## GH 17/09/2015 bug 110557
                         WNBOPE    += [M:MTOK]WNBOPE : # WNBOPE += 1
                         WMFGMKO   += [M:MTOK]WNBOPE
                         ##
                         [L]WLIN = [M:MTOK]OPETRKLIN
                  Endif
         When Default :
                  Read [F:MWS]WST0 = [M:MBO]CPLWST(nolign-1);[M:MBO]FCY
                  If !fstat
                      WNOLIGN = nolign
                      [M:MTOK]TYPTRT = 9
                      Call CRE_MKO From MTKAUTLIB
                      If GOK < 1 : TRA = 1 : Break : Endif
                      nolign = WNOLIGN
                      ## GH 17/09/2015 bug 110557
                      WNBOPE    += [M:MTOK]WNBOPE : # WNBOPE += 1
                      WMFGMKO   += [M:MTOK]WNBOPE
                      ##
                      [L]WLIN = [M:MTOK]OPETRKLIN
                 Endif
    Endcase
  Endif
Next
If GOK > 0 & WWMFGNUM <> "" : Gosub MAJ_ENTOF  : Endif
If GOK < 1
   If adxlog : Gosub AB_TR : Endif
Else
   If WNBOPE <> 0 : Gosub CRE_ENTETE
   Elsif adxlog : Rollback # GH 17/09/2015 bug 110557
   Endif
Endif

If GOK < 1
   # GH 02/2016 bug 108954  cancel the tracking number set on the associated lines
   If WMFGTRKNUM<>""
      Look [MTK]MTK0 = WMFGTRKNUM
      If fstat
        For I=0 To [M:MBO]NBLIG-1
            If WMTKNUM(I) = WMFGTRKNUM : WMTKNUM(I)="" : Endif
        Next I
      Endif
   Endif
   Return
Endif

# 11.02 demande 16662 point d'entrée permettant d'effectuer un traitement supplémentaire
# en fin de plan, exemple, lancer une impression
GPOINT = "CUSTRTSUP" : Gosub  ENTREE From EXEFNC
Return

############################################

$MAJ_ENTOF
If WMFGMKO<>0  : # GH 17/09/2015 bug 110557 test WMFGMKO
    #Maj entête d'OF
    Readlock [F:MFG]MFG0 = WWMFGNUM
    If fstat=1  GOK=-1 : GLOCK="$MFGHEAD"-num$(WWMFGNUM) : Return
    Elsif fstat GOK=0  : Call RSTA("MFG",num$(WWMFGNUM)) From GLOCK : Return
    Endif
    [F:MFG]OPECLENBR += WOPECLENBR
    [F:MFG]MATCLENBR += WMATCLENBR
    [F:MFG]ITMCLENBR += WITMCLENBR
    If [F:MFG]OPECLENBR = [F:MFG]OPELINNBR &
&      [F:MFG]ITMCLENBR = [F:MFG]ITMLINNBR &
&      [F:MFG]MATCLENBR = [F:MFG]MATLINNBR
       [F:MFG]MFGTRKFLG = 5
        # CCC (10/01/08) DM 44021
    #   [F:MFG]TRKLAST   = WDAT
    Else
       [F:MFG]MFGTRKFLG = 4
        # CCC (10/01/08) DM 44021
    #   Raz [F:MFG]TRKLAST
    Endif
    # CCC (10/01/08) DM 44021
    If [F:MFG]TRKLAST<WDAT
       [F:MFG]TRKLAST   = WDAT
    Endif
    If [F:MFG]TRKLASTC<date$
       [F:MFG]TRKLASTC  = date$
    Endif
    If [F:MFG]TRKFIRST>WDAT | [F:MFG]TRKFIRST = "00/00/00"
        [F:MFG]TRKFIRST = WDAT
    Endif
    If [F:MFG]TRKFIRSTC>date$ | [F:MFG]TRKFIRSTC = "00/00/00"
        [F:MFG]TRKFIRSTC = date$
    Endif

    [F:MFG]CPLQTY    += WCPLQTY
    [F:MFG]REJCPLQTY += WREJQTY
    [F:MFG]QUACPLQTY += WQUAQTY
    If [F:MFG]ITMLINNBR = [F:MFG]ITMCLENBR
       [F:MFG]RMNEXTQTY = 0
    Else
       [F:MFG]RMNEXTQTY =  [F:MFG]EXTQTY - [F:MFG]CPLQTY
    Endif
    Call QTEARR([F:MFG]RMNEXTQTY,[F:MFG]STU) From TRTDIV
    If [F:MFG]RMNEXTQTY < 0 : [F:MFG]RMNEXTQTY = 0 : Endif
    If [F:MFG]CPLQTY >= [F:MFG]EXTQTY : Raz [F:MFG]RMNEXTQTY : Endif
    If [F:MFG]RMNEXTQTY > [F:MFG]EXTQTY : [F:MFG]RMNEXTQTY = [F:MFG]EXTQTY : Endif
    Rewrite [F:MFG]
    If fstat
       GOK = 0 : Call FSTA("MFG") From GLOCK : Return
    Endif
    #----- MISE à jour statistiques entête OF -----#
    Call VALSTA("MFG",1) From SUBPS2
    If GOK < 1 : Return : Endif
    # FQ 73284 GA 04/2011 idem MKOIMPORT, et *MTK* éviter de rejalonner
    Raz GPE
    GPOINT="UPDSCD"
    Gosub ENTREE From EXEFNC
    If !GPE
      # 08.02 si besoin maj de WORKLOAD demande 15029
      If find([F:MFG]SCDFLG,2,4)
            [M:JALK]CODORI = 1
            [M:JALK]CODMAJ = 0
            [M:JALK]CODTRS = 0                    # llc 11.02 16716
            [M:JALK]MFGFCY = [F:MFG]MFGFCY
            [M:JALK]MFGNUM = [F:MFG]MFGNUM
            [M:JALK]MFGSTA = [F:MFG]MFGSTA
            # llc 12.02 16779
            If [F:PJA]MFGFCY <> [M:JALK]MFGFCY
                Read [PJA]PJA0=[M:JALK]MFGFCY
                If !fstat : [M:JALK]JAVFLG = [F:PJA]AUTFRWSCD : Endif
            Endif
            Call DEJALONNE From JALLIBA
            If [M:JALK]CODRET = 0
                Call JALONNE From JALLIB
            Endif
            If GOK < 1 : Return : Endif
      Endif
    Endif
Endif

Raz WOPECLENBR, WMATCLENBR, WITMCLENBR, WCPLQTY, WREJQTY, WQUAQTY, WMFGMKO : # GH 17/09/2015 bug 110557 raz WMFGMKO
Return

############################################################
#Création entête de suivi
$CRE_ENTETE
If GOK = 1
    Raz [F:MTK]
    If WMFGNUM <> ""
       Read [F:MFG] = WMFGNUM
       If !fstat : [F:MTK] = [F:MFG] : Endif
    Endif
    [F:MTK]MFGFCY    = [M:MBO]FCY
    [F:MTK]TRSCOD    = [M:MTOK]TRSCOD
    [F:MTK]TRSCODS   = [M:MTOK]TRSCODS
    [F:MTK]MFGTRKNUM = WMFGTRKNUM
    [F:MTK]MFGTRKDAT = WDAT
    [F:MTK]CREDAT    = date$
    [F:MTK]CREUSR    = GUSER
    [F:MTK]EXPNUM    = [C]EXPORT
    Raz [F:MTK]UPDUSR
    Raz [F:MTK]UPDDAT
    [F:MTK]OPETRKFLG = 2
    [F:MTK]ITMTRKFLG = 1
    [F:MTK]MATTRKFLG = 1
    [F:MTK]NBROPE    = WNBOPE
    [F:MTK]NBRMAT    = WNBMAT
    [F:MTK]NBRITM    = WNBITM
    If [F:MTK]NBRMAT <> 0 : [F:MTK]MATTRKFLG = 2 : Endif
    If [F:MTK]NBRITM <> 0 : [F:MTK]ITMTRKFLG = 2 : Endif
    # Issue 74667 - 2011-07-12 by CCC
    If [F:MFG]MFGTEX <> ""
       [F:MTK]MTKTEX = [F:MFG]MFGTEX
       If left$([F:MTK]MTKTEX,3)="MFG"
          Call DUP_CLOB("MTK",[F:MTK]MTKTEX,GOK) From TRTX3TEX
       Endif
    Endif
    #point d'entrée  pour mise à jour de tables spécifiques liées à [MTK] sr 01.02 demande 12361
    GPOINT = "BENMTKMAJ" : Gosub ENTREE From EXEFNC
    #
    Write [F:MTK]
    If fstat : GOK = 0 : Call FSTA("MTK") From GLOCK : Endif
Endif
If GOK < 1
    Gosub AB_TR
Else
    Commit
    TRA=1
    Call ECR_TRACE(mess(79,190,1)-[F:MTK]MFGTRKNUM,0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

    If WMTKNUMSTR = ""
       WMTKNUMSTR = [F:MTK]MFGTRKNUM
       WMTKNUMEND = [F:MTK]MFGTRKNUM
       # Issue 68937 - 2010-11-08 by CCC : Les n° de documents ne sont pas nécessairement créés de façon croissante
    Elsif WMTKNUMEND < [F:MTK]MFGTRKNUM
       WMTKNUMEND = [F:MTK]MFGTRKNUM
    Elsif WMTKNUMSTR > [F:MTK]MFGTRKNUM
       WMTKNUMSTR = [F:MTK]MFGTRKNUM
    Endif

    Raz WMFGTRKNUM

    # Issue 67416 - 2010-09-22 by CCC : C'est seulement une fois le suivi créé (commités) que l'on peut lancer l'impression
    #--- Impression des étiquettes ----#
    If [F:BTS]PRNCOD1 > 1 & !GIMPORT & !GWEBSERV & !GVTMOD
        Filter [MKI] Where MFGTRKNUM=[F:MTK]MFGTRKNUM
        Look [MKI]MKI0 First
        Filter [MKI]
        If !fstat
            Local Char WPARAM(GLONVCR)(1..4) , WVALEUR(10)
            WPARAM(1) = [F:MTK]MFGFCY
            WPARAM(2) = "15"
            WPARAM(3) = [F:MTK]MFGTRKNUM
            WPARAM(4) = [F:MTK]MFGTRKNUM
            Call TRAITE_CHAR(WVALEUR,WPARAM,"ISTOLBE","SUBSLP","",4,"SPESLP") From GTRAITE
        Endif
    Endif
Endif

Raz WNBOPE, WMFGNUM, WWMFGNUM, WNBMAT, WNBITM, WLIN
Return

$AB_TR
Rollback
If GOK<0 & GLOCK<>"" :  # GH 02/2016 bug 108954 put an error in the log in case of lock
   Call ECR_LOCK("") From GLOCK : GLOCK=""
   TRA=1
Endif
If !GVTMOD
   Call ECR_TRACE("",0) From GESECRAN
   Call ECR_TRACE(mess(254,193,1)+"\"+mess(255,193,1),1) From GESECRAN
   TRA=1
Endif
Return

############################################################
$EFFAC_LIG_QLYWRK
Call DEBTRANS From GLOCK
If clalev ([F:QLW]) <= 0 : Local File QLYWRK [QLW] : Endif
Trbegin [QLW]
Delete [F:QLW] Where PRONUM = adxuid(1) & LINNUM = [M:MBO]WLINUM(nolign-1)
If fstat
   Rollback
   Call ECR_TRACE(mess(254,193,1)+"\"+mess(255,193,1),1) From GESECRAN
Else
   Commit
Endif
Return

###########################################################
# Contrôle de validité (pour prod) d'une alternative      #
# TRO & ROH doivent être chargés ...                      #
#---------------------------------------------------------#
Subprog CONTMFGGAM(LFCY, LALT, LDAT, LMSG)
Variable Char     LFCY
Variable Integer  LALT
Variable Date     LDAT
Value    Integer  LMSG
#
LALT=0

# Opérateur autorisé ?
If clalev([F:ACC]) = 0 : Local File ACCES [ACC] : Endif
Read [ACC]CODACC=GUSER;[F:TRO]ACSCOD
If (!fstat & [F:ACC]EXEC = 1)
    If LMSG<>0 : GMESSAGE=mess(46,193,1) : Endif
    End
Endif

# Site ?
If ([F:TRO]FCY<>"" & [F:TRO]FCY<>LFCY)
    If LMSG<>0 : GMESSAGE=mess(48,193,1) : Endif
    End
Endif

# Utilisable en production ?
If [F:TRO]MFGUSE<>2
    If LMSG<>0 : GMESSAGE=mess(49,193,1) : Endif
    End
Endif

# Utilisable en exploitation ?
If [F:ROH]USESTA<>2
    If LMSG<>0 : GMESSAGE=mess(54,193,1) : Endif
    End
Endif

# Gamme valide ?
If ([F:ROH]ROUSTRDAT <> [0/0/0] & LDAT < [F:ROH]ROUSTRDAT)
     If LMSG<>0 : GMESSAGE=mess(55,193,1) : Endif
     End
Endif
If ([F:ROH]ROUENDDAT <> [0/0/0] & LDAT > [F:ROH]ROUENDDAT)
     If LMSG<>0 : GMESSAGE=mess(55,193,1) : Endif
     End
Endif

# Gamme validée
If [F:ROH]CFMFLG<>2
    If LMSG<>0 : GMESSAGE=mess(56,193,1) : Endif
    End
Endif

#
LALT=[F:ROH]ROUALT
End

#
#
#---------------------------------------------------------#
#    Actions sur les zones du masque MTKBENCHO            #
#---------------------------------------------------------#
#
#

###########################################################################
$AB5_NBLIG
#------------------------------------------------------#
# Avant exécution du bouton plan de conso              #
#------------------------------------------------------#
Local Shortint NOL       : NOL=nolign-1
Local Decimal WCOEFF
Local Integer WCONSMAT
# 03.05 Si suivi sur of, on passe un coefficient de rélaisation
# si suivi sur gamme, il faut passer une quantité réalisée ramenée dans l'unité de l'article produit
# OPEWORCOE = coeff entre unité opé et unité du suivi
# OPESTUCOE = coeff entre unité opé et unité article porduit
Case [M:MBO]TIMTYP(NOL)
    When 1 :
            WCOEFF = ([M:MBO]CPLQTY(NOL) * [M:MBO]OPEWORCOE(NOL)) / [M:MBO]MFOEXTQTY(NOL)
            # CCC (09/12/08) Bug 50667 : le coef ne doit pas être arrondi sinon les qtés calculées sont fausses
            # Ce sont les quantités qui sont arrondies
            #WCOEFF = arr(WCOEFF,0.00000001)
            WCONSMAT = [F:BTS]CONSMAT
    When 2 :
            If [M:MBO]OPESTUCOE(NOL) = 0 : [M:MBO]OPESTUCOE(NOL) = 1 : Endif
            WCOEFF = [M:MBO]CPLQTY(NOL) / [M:MBO]OPESTUCOE(NOL)
            Call QTEARR(WCOEFF,[M:MBO]OPEUOM(NOL)) From TRTDIV
Endcase
Return

###########################################################################
$BB5_NBLIG
#colorisation de la date selon ce qui a été fait dans le plans de conso
Call AV_IPTDAT([M:MBO]IPTDAT(nolign-1))
Affzo [M:MBO]IPTDAT(nolign-1)
Gosub LECTURE_BTS
Return

###########################################################################
$AB6_NBLIG
#------------------------------------------------------#
# Avant exécution du bouton plan de déclaration de prod#
#------------------------------------------------------#
Local Shortint NOL       : NOL=nolign-1
Local Decimal WCOEFF
If [M:MBO]OPESTUCOE(NOL) = 0 : [M:MBO]OPESTUCOE(NOL) = 1 : Endif
WCOEFF = ([M:MBO]CPLQTY(NOL) * [M:MBO]OPEWORCOE(NOL)) / [M:MBO]MFOEXTQTY(NOL)
# CCC (09/12/08) Bug 50667 : le coef ne doit pas être arrondi sinon les qtés calculées sont fausses
# Ce sont les quantités qui sont arrondies
#WCOEFF = arr(WCOEFF,0.00000001)
Return

###########################################################################
$BB6_NBLIG
#colorisation de la date selon ce qui a été fait dans le plans de prod
Call AV_IPTDAT([M:MBO]IPTDAT(nolign-1))
Affzo [M:MBO]IPTDAT(nolign-1)
Gosub LECTURE_BTS
Return


###########################################################################
$AB11_NBLIG
Local Char     WOBJET(GLONAOB)
Local Char     WCLE1(GLONVCR)
Local Char     WCLE2(GLONVCR) (2)

WCLE2(0) = [M:MBO]FCY
WCLE2(1) = num$([M:MBO]ROUALT(nolign-1))
#    If clalev([F:TRO])<=0 : Local File TABROUALT [TRO] : Endif
#    Local Integer NBTRO
#    #   SéLECTIONNER les alt. de gammes compatibles avec site de prod
#    Filter [TRO] Where ([F:TRO]FCY=[M:MBO]FCY | [F:TRO]FCY="") & [F:TRO]MFGUSE=2
#    For [TRO]TRO0
#         GROUALT (NBTRO) = [F:TRO]ROUALT
#         NBTRO += 1
#    Next
#    Filter [TRO]
WCLE1       = [M:MBO]ITMREF(nolign-1)
#Local File ROUTING [ROH] Where find(ROUALT, GROUALT) & ITMREF>=WCLE1 & FCY = [M:MBO]FCY
Local File ROUTING [ROH] Where ROUALT = [M:MBO]ROUALT(nolign-1) & ITMREF=WCLE1 & FCY = [M:MBO]FCY
GDATEREF   = [M:MBO]IPTDAT(nolign-1)
Return


########################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
Effzo [M:MBO]15
If VALEUR <> GFCY : GFCY = VALEUR : Gosub CHARG_PARAM : Endif
[M]FCY = VALEUR
If dim([M:MBO]WRHE)>0
    Effzo [M:MBO]WRHE
    If [F:BTS]ITMFLG=2
        Call WRHINIT([M:MBO]WRHE,VALEUR,2) From STKWRH
    Elsif [F:BTS]MATFLG=2
        Call WRHINIT([M:MBO]WRHE,VALEUR,8) From STKWRH
    Endif
    Affzo [M:MBO]WRHE
Endif
Gosub WRH_ETAT
# Issue 73720 - 2011-05-18 by CCC
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL
End

########################################
Subprog AM_ENDDATSTR(VALEUR)
Variable Date    VALEUR
If VALEUR <> [0/0/0] : [M:MBO]ENDDATEND = VALEUR : Affzo [M:MBO]ENDDATEND : Endif
End

########################################
Subprog C_ENDDATEND(VALEUR)
Variable Date    VALEUR
If VALEUR < [M:MBO]ENDDATSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

########################################
Subprog C_NBLIG
Local Integer OK, NOL
GMODIF = 2
NOL = nolign-1
#En ajout de ligne récupération d'un numéro unique
If status=73 | status=82
    If dim([M:MBO]TIMTYP)<[M:MBO]NBLIG+2
          GMESSAGE=mess(122,199,1)
          mkstat=2
          End
    Endif
    [M:MBO]WLINUM(NOL) = GOPELIN
    GOPELIN += 1
Elsif status = 75
    OK = 0
    #Si opération précedente non suivie message d'erreur selon GCTLOPEPRE
    # 06.02 Contrôle que si opé précédente non exclue demande 14752
    If GCTLOPEPRE <> 3 | [M:MBO]OPEPREC(NOL) = 0 | [M:MBO]TIMTYP(NOL) <> 1:  End : Endif
    Filter [MFO] Where MFGNUM = [M:MBO]MFGNUM(NOL) & OPENUM = [M:MBO]OPEPREC(NOL)
    Read [MFO]MFO0 First
    If fstat : Raz [F:MFO] : Endif
    Filter [MFO]
    If [F:MFO]TRKFIRST <> [0/0/0]  | [F:MFO]OPESTA = 6 : End : Endif
    # GH 05/12/2013 bug 90095 test que l'opération précédente peut être suivie
    Read [SCH]SCH0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
    If fstat : Raz [F:SCH] : Endif
    If [F:SCH]DACMST = 1 : End : Endif
    #
    For J = 0 To [M:MBO]NBLIG-1
        If [M:MBO]MFGNUM(J) = [M:MBO]MFGNUM(NOL) & [M:MBO]OPENUM(J) = [M:MBO]OPEPREC(NOL)
&        &([M:MBO]CPLQTY(J)<>0 | [M:MBO]CPLOPETIM(J)<>0 | [M:MBO]CPLSETTIM(J) <> 0)
           OK = 1 : Break
        Endif
    Next J
    If OK = 1 : End : Endif
    GMESSAGE = mess(22,190,1)-num$([M:MBO]OPENUM(NOL))
    mkstat = 1 : GMODIF = 1 : End
Endif
End

#########################################
Subprog AVANT_NBLIG
#Si suppression d'une ligne, suppression éventuelle des réponses fiche technique
If status=65 | status=68 | status=83
   If [M:MBO]TECCRD(nolign-1) <> ""
       Gosub EFFAC_LIG_QLYWRK
   Endif
Endif
End


End

########################################
Subprog AS_MFGNUM(VALEUR)
Variable Char    VALEUR()
# FQ 61131 GA 01/2010 pas de maj de MFGNUM si l'article lancé a déjà été choisi
If [M:MBO]MFGNUM(nolign-1)<>"" & [M:MBO]ITMREF(nolign-1)<>""
   mkstat=2
Endif

End

########################################
Subprog C_MFGNUM(VALEUR)
Variable Char    VALEUR()
Read [F:MFG]MFG0 = VALEUR
If fstat : GMESSAGE = mess(23,100,1)
    mkstat = 1
    End
Endif
If [F:MFG]MFGFCY <> [M:MBO]FCY
    GMESSAGE = mess(23,100,1)
    mkstat = 1
    End
Endif
#L'OF doit être complet
If [F:MFG]TYPMOD = 1    : GMESSAGE = mess(51,190,1) : mkstat = 1 : End : Endif
#L'OF doit être ferme
If [F:MFG]MFGSTA <> 1   : GMESSAGE = mess(19,190,1) : mkstat = 1 : End : Endif
#L'OF ne doit pas être suspendu
If [F:MFG]SUSFLG = 2    : GMESSAGE = mess(180,190,1) : mkstat = 1 : End : Endif
#Selon paramètre général l'OF doit être alloué complètement
If GMTKALLMGT = 2 & !find([F:MFG]ALLSTA,3,5) & [F:MFG]MATLINNBR <> 0
     GMESSAGE = mess(18,190,1)
     mkstat = 1
     End
Endif
#Selon paramètre général, l'OF doit être édité
If  [F:MFG]MFGTRKFLG < 3 &  GDOSFAB = 2 : GMESSAGE = mess(20,190,1) : mkstat = 1 : End : Endif
mkstat = 0
# boucle d'analyse des matières bloquantes si rupture
For [MFM]MFM0 Where MFGNUM = [F:MFG]MFGNUM                        # 10.02 Performances
    If [F:MFM]SHTQTY <> 0
       Read [ITF]ITF0=[F:MFM]ITMREF;[F:MFM]MFGFCY
       If !fstat & [F:ITF]MFGSHTCOD = 1
          GMESSAGE = mess(105,193,1)+" ("+[F:MFM]ITMREF+")"
          mkstat = 1
          Break
       Endif
    Endif
Next
If mkstat = 1 : End : Endif
End

########################################
Subprog AM_MFGNUM(VALEUR)
Variable Char  VALEUR
Read [F:MFG]MFG0 = VALEUR
If fstat : Raz [F:MFG] : Endif
[M:MBO]ITMREF(nolign-1) = [F:MFG]ROUNUM
[M:MBO]ROUALT(nolign-1) = [F:MFG]ROUALT
[M:MBO]STU(nolign-1)    = [F:MFG]STU

Read [F:ROH]ROH0=[F:MFG]ROUNUM;[F:MFG]ROUALT;[F:MFG]MFGFCY     : # Beryl Site en fin de clé primaire
If !fstat :[M:MBO]TIMUOMCOD(nolign-1) = [F:ROH]TIMUOMCOD : Endif
#
# FQ 61131 GA 01/2010 idem FUNBENCHI, FUNBENCHM et FUNBENCHO
If [F:MFG]ITMLINNBR = 1 & [M:MBO]BOMNUM(nolign-1)=""
    Filter [MFI] Where MFGNUM = VALEUR
    Read [MFI]MFI0 First
    If !fstat
        [M:MBO]BOMNUM(nolign-1) = [F:MFI]ITMREF
        [M:MBO]BOMALT(nolign-1) = [F:MFI]BOMALT
    Endif
    Filter [MFI]
Endif
End

########################################
Subprog C_OPENUM(VALEUR)
Variable Decimal VALEUR
Local Integer I,OK
If VALEUR = 0 : mkstat = 1 : End : Endif
Case [M:MBO]TIMTYP(nolign-1)
    When 1 :
# 04.02 demande 9134 : laisser la possibilité de saisir la même opé/même date
#             If nolign > 1
#                 For I = 0 To nolign-2
#                     If [M:MBO]IPTDAT(I) = [M:MBO]IPTDAT(nolign-1) &
#&                       [M:MBO]MFGNUM(I) = [M:MBO]MFGNUM(nolign-1) &
#&                       [M:MBO]OPENUM(I) = VALEUR
#                        GMESSAGE = mess(135,193,1) + num$(I+1)
#                        mkstat = 1
#                        Break
#                     Endif
#                 Next
#             Endif
#             If mkstat = 1 : End : Endif
             Read [F:MFO]MFO0 = [M:MBO]MFGNUM(nolign-1);VALEUR;0
             If fstat : [M:MBO]ROUOPENUM(nolign-1) = 0 : End :  Endif
             If [F:MFO]OPESTA = 6 : GMESSAGE = mess(83,193,1) : End : Endif
             Read [F:MWS]WST0 = [F:MFO]EXTWST;[F:MFO]MFGFCY
             If fstat : GMESSAGE = mess(133,193,1)
                         mkstat = 1
                         End
             Endif
             If [F:MWS]WSTTYP = 3
                         GMESSAGE = mess(30,190,1)
                         mkstat = 1
                         End
             Endif
            #L'opération doit-elle être suivie
             Read [F:SCH]SCH0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
             If fstat | [F:SCH]DACMST = 1
                 GMESSAGE = mess(134,193,1)
                 mkstat = 1
                 End
             Endif
             [M:MBO]ROUOPENUM(nolign-1) = VALEUR
  When 2:
# demande 9134 : laisser la possibilité de saisir la même opé/même date
#            If nolign > 1
#                  For I = 0 To nolign-2
#                     If [M:MBO]MFGNUM(I) = [M:MBO]MFGNUM(nolign-1) &
#&                       [M:MBO]IPTDAT(I) = [M:MBO]IPTDAT(nolign-1) &
#&                       [M:MBO]ITMREF(I) = [M:MBO]ITMREF(nolign-1) &
#&                       [M:MBO]ROUALT(I) = [M:MBO]ROUALT(nolign-1) &
#&                       [M:MBO]OPENUM(I) = VALEUR
#                        GMESSAGE = mess(135,193,1) + num$(I+1)
#                        mkstat = 1
#                        Break
#                     Endif
#                  Next
#             Endif
#             If mkstat = 1 :  End : Endif
             # FQ 77863 GA 11/2011 vérifier aussi VALSTRDAT (?)
             Filter [F:ROO] Where FCY    = [M:MBO]FCY              &
&                                 ITMREF = [M:MBO]ITMREF(nolign-1) &
&                                 ROUALT = [M:MBO]ROUALT(nolign-1) &
&                                 OPENUM = VALEUR
&                               & (VALENDDAT=[0/0/0] | (VALENDDAT >= date$ & VALENDDAT<>[0/0/0]) )
&                               & (VALSTRDAT=[0/0/0] | (VALSTRDAT <= date$ & VALSTRDAT<>[0/0/0]) )
             Read [F:ROO]ROO0 First
             If fstat : Raz [F:ROO] : Filter [F:ROO] : [M:MBO]ROUOPENUM(nolign-1) = 0 : End : Endif
             Filter [F:ROO]
             Read [F:MWS]WST0 = [F:ROO]WST;[F:ROO]FCY
             If fstat : GMESSAGE = mess(133,193,1)
                         mkstat = 1
                         End
             Endif
             If [F:MWS]WSTTYP = 3
                         GMESSAGE = mess(30,190,1)
                         mkstat = 1
                         End
             Endif
            #L'opération doit-elle être suivie
             Read [F:ROS]ROS0 = [F:ROO]FCY;[F:ROO]ITMREF;[F:ROO]ROUALT;[F:ROO]OPENUM
             If fstat | [F:ROS]DACMST = 1
                 GMESSAGE = mess(134,193,1)
                 mkstat = 1
                 End
             Endif
             [M:MBO]ROUOPENUM(nolign-1) = VALEUR
 When Default
Endcase
End


########################################
Subprog AP_ENDDATEND(VALEUR)
Variable Date    VALEUR
End

########################################
Subprog C_WEMPNUM(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 & [F:BTS]MATRICULE = 2 : Raz [F:TMA] : End : Endif
# GH 21/11/13 bug 94623
Call CONTROLE("TMA","",num$(VALEUR),"",mkstat) From CONTOBJ
#Read [F:TMA]TMA0 = VALEUR
#If fstat : GMESSAGE = mess(23,100,1)
#    mkstat = 1
#    End
#Endif
[M:MBO]EMPDES = [F:TMA]EMPDES
End

########################################
Subprog AM_TIMTYP(VALEUR)
Variable Integer VALEUR
Local Integer NOL : NOL = nolign-1
Local Integer I
Raz [M:MBO]MFGNUM(NOL), [M:MBO]ITMREF(NOL), [M:MBO]ROUALT(NOL), [M:MBO]OPENUM(NOL), [M:MBO]CPLWST(NOL),
&   [M:MBO]CPLSETTIM(NOL), [M:MBO]CPLOPETIM(NOL), [M:MBO]CPLQTY(NOL), [M:MBO]REJCPLQTY(NOL), [M:MBO]OPEUOM(NOL),
&   [M:MBO]TIMUOMCOD(NOL), [M:MBO]WINDIC(NOL), [M:MBO]WROUVAL(nolign-1),[M:MBO]MFGNUM(NOL),
&   [M:MBO]TECCRD(NOL), [M:MBO]CLEFLG(NOL), [M:MBO]SCDCOD(NOL), [M:MBO]OPEPREC(NOL), [M:MBO]NEXOPENUM(NOL),
&   [M:MBO]MFGMST(NOL),[M:MBO]DACMST(NOL),[M:MBO]ROUOPENUM(NOL)
For I = 1 To GNBDIE
    Assign "[M:MBO]CCE" + num$(I)+"(" +num$(nolign-1)+")" With ""
Next
For I = 1 To 15
    Assign "[M:MBO]SCANUM" + num$(I)+"(" +num$(nolign-1)+")" With 0
    Assign "[M:MBO]TAREJQTY" + num$(I)+"(" +num$(nolign-1)+")" With 0
Next
# FQ 64948 GA 05/2010 Matricule renseigné sur tous les types d'opérations (comme en saisie directe)
# sr 08.03 demande 18046 on initialise ici le matricule dans le cas d'un suivi divers
#If VALEUR = 3
  # FQ 64589 GA 05/2010 If [F:BTS]MATRICULE <> 3 (ne pas écraser la valeur)
   If [F:BTS]MATRICULE <> 3 & [M:MBO]WEMPNUM<>0
      [M:MBO]EMPNUM(NOL) = [M:MBO]WEMPNUM
   Endif
#Endif
End

########################################
Subprog AM_OPENUM(VALEUR)
Variable Decimal VALEUR
Case [M:MBO]TIMTYP(nolign-1)
     When 1 : If [M:MBO]ROUOPENUM(nolign-1) <> 0 : Gosub CHARG_MFO : Endif
     When 2 : If [M:MBO]ROUOPENUM(nolign-1) <> 0 : Gosub CHARG_ROO : Endif
Endcase
End

########################################
Subprog AM_WEMPNUM(VALEUR)
Variable Decimal VALEUR
[M:MBO]EMPDES = [F:TMA]EMPDES
Affzo [M:MBO]EMPDES
End

########################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
Read [F:ITF]ITF0 = VALEUR;[M:MBO]FCY
If fstat : GMESSAGE = mess(23,100,1)
           mkstat = 1
           End
Endif
End

########################################
Subprog C_ROUALT(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 : End : Endif
Read [F:ROH]ROH0=[M:MBO]ITMREF(nolign-1);VALEUR;[M:MBO]FCY    : # Beryl Site en fin de clé primaire
If fstat : GMESSAGE = mess(23,100,1)
            mkstat = 1
            End
Endif
End

########################################
Subprog C_CPLWST(VALEUR)
Variable Char    VALEUR()
Local Integer OK

Read [MWS]WST0=VALEUR;[M:MBO]FCY
If fstat
   GMESSAGE= mess(133,193,1)
    mkstat=1
Else
#Pas de poste de sous-traitance
    If [F:MWS]WSTTYP = 3
       GMESSAGE = mess(30,190,1)
        mkstat = 1
        End
    Endif
Endif
#
# Issue 110979/2 - 2016-03-25 by CCC : Warning message when modifying an existing operation of a versioned routing
If VALEUR<>[M:MBO]CPLWST(nolign-1) & [M:MBO]ROUOPENUM(nolign-1)<>0
    If [F:MFG]MFGNUM<>[M:MBO]MFGNUM(nolign-1)
        Read [F:MFG]MFG0 = [M:MBO]MFGNUM(nolign-1)
    Endif
    If [F:MFO]MFGNUM<>[M:MBO]MFGNUM(nolign-1)
        Read [F:MFO]MFO0 = [M:MBO]MFGNUM(nolign-1);[M:MBO]OPENUM(nolign-1);[M:MBO]OPESPLNUM(nolign-1)
    Endif
    If [F:MFG]ROUECCMAJ <> ""
        If [F:MFO]MFGNUM<>[M:MBO]MFGNUM(nolign-1) | [F:MFO]OPENUM<>[M:MBO]OPENUM(nolign-1) | [F:MFO]OPESPLNUM<>[M:MBO]OPESPLNUM(nolign-1)
            Raz [F:MFO]
            Read [F:MFO]MFO0 = [M:MBO]MFGNUM(nolign-1);[M:MBO]OPENUM(nolign-1);[M:MBO]OPESPLNUM(nolign-1)
        Endif
        If [F:MFO]MFGNUM<>"" & !find(VALEUR,[F:MFO]EXTWST,[F:MFO]EXTLAB)
            OK=1
            Call AVERTIR(mess(346,193,1),OK) From GESECRAN
            If OK = 1 : mkstat=1 : End : Endif # Cancel
        Endif
    Endif
Endif
End

#CHECK IGNORE_BEGIN
