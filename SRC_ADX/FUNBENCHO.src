Subprog AM_CPLUNTTIM(VALEUR)
Variable Decimal VALEUR
#Recalcul du tps opé réalisé
[M:MBO]CPLOPETIM(nolign-1) = [M:MBO]CPLQTY(nolign-1) * VALEUR
# 11.06 demande 38402
[M:MBO]CPLOPETIM(nolign-1) = func TRTX3.ARRTYP("","","TIH",[M:MBO]CPLOPETIM(nolign-1))
Affzo [M:MBO]CPLOPETIM(nolign-1)
End

