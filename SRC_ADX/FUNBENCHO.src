End

########################################
Subprog AM_CPLQTY(VALEUR)
Variable Decimal VALEUR
Local Integer LRET, NOL, OK
NOL = nolign-1

If [M:MBO]TIMTYP(nolign-1) = 1 & [M:MBO]ROUOPENUM(nolign-1) <> 0 & VALEUR > [M:MBO]WQTY(NOL)
        Call AVERTIR(mess(54,190,1),OK) From GESECRAN
        If OK = 1 : mkstat = 1 : End
        Else [M:MBO]CLEFLG(NOL) = 2
        Endif
Endif
[M:MBO]CPLQTY(NOL) = VALEUR
#    Proposition de solde si qté prévue - qté réalisée correspond <= % de tolérance
Call CONT_SOLDE_OPE([M:MBO]FCY,[M:MBO]CPLWST(NOL),VALEUR,[M:MBO]WQTY(NOL),LRET) From MFGLIBO
If LRET = 1 : [M:MBO]CLEFLG(NOL) = 2
Else          [M:MBO]CLEFLG(NOL) = 1
Endif
#    Ajustement du tps réalisé opé ssi tpsnon forfaitaire
# 11.01 demande 11459 Tenir compte de la cadence pour le suivi sur gamme
# CCC (2010-04-07) Bug 63699
#Case [M:MBO]TIMTYP(NOL)
#    When 1 : If [M:MBO]ROOTIMCOD(NOL) <> 3
#                [M:MBO]CPLOPETIM(NOL) = VALEUR *[M:MBO]CPLUNTTIM(NOL)
#             Endif
#    When 2 : If [M:MBO]ROOTIMCOD(NOL) = 1
#                [M:MBO]CPLOPETIM(NOL) = VALEUR *[M:MBO]CPLUNTTIM(NOL)
#             Elsif [M:MBO]ROOTIMCOD(NOL) = 2
#                # llc 02.02 13175
#                If [M:MBO]CAD(NOL) <> 0
#                    [M:MBO]CPLOPETIM(NOL) = VALEUR   / [M:MBO]CAD(NOL)
#                Endif
#             Endif
#Endcase
If find([M:MBO]TIMTYP(NOL),1,2)
    Case [M:MBO]ROOTIMCOD(NOL)
        When 1 : # Proportionnel
                [M:MBO]CPLOPETIM(NOL) = VALEUR *[M:MBO]CPLUNTTIM(NOL)
        When 2 : # Cadence
                If [M:MBO]CAD(NOL) <> 0
                    # Issue 88551 - 2013-03-13 by CCC
                    #[M:MBO]CPLOPETIM(NOL) = VALEUR   / [M:MBO]CAD(NOL)
                    # GH 01/10/2014  bug 101352
                    #[M:MBO]CPLOPETIM(NOL) = VALEUR   / ([M:MBO]CAD(NOL) * [M:MBO]EFF(NOL)/100)
                    [M:MBO]CPLOPETIM(NOL) = VALEUR * [M:MBO]OPEWORCOE(NOL) / ([M:MBO]CAD(NOL) * [M:MBO]EFF(NOL)/100)
                Endif
    Endcase
Endif

If VALEUR = 0 : Raz [M:MBO]CPLOPETIM(NOL)
                Raz [M:MBO]CPLSETTIM(NOL)
Endif

# llc 01.02 demande 12709 arrondir les temps calculés
[M:MBO]CPLSETTIM(NOL) = func TRTX3.ARRTYP("","","TIH",[M:MBO]CPLSETTIM(NOL))
[M:MBO]CPLOPETIM(NOL) = func TRTX3.ARRTYP("","","TIH",[M:MBO]CPLOPETIM(NOL))
# 02.02 demande 13027
Affzo [M:MBO]CPLOPETIM(NOL), CLEFLG(NOL)

End

