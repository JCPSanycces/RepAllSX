######################################################################################
$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE > GNBDIE : Return : Endif
If [F:MWS]WST <> [M:MBO]CPLWST(nolign-1) | [F:MWS]WCRFCY <> [M:MBO]FCY
    Read [MWS]WST0=[M:MBO]CPLWST(nolign-1);[M:MBO]FCY
    If fstat : Raz [F:MWS] : Endif
Endif
Call INIT_CCE(VALEUR,AXE,"MKOB","",0) From TRTX3CPT
Return

$D_LABCCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE > GNBDIE : Return : Endif
If [M:MBO]CPLLAB(nolign-1) = "" : Return : Endif
If [F:MWS]WST <> [M:MBO]CPLLAB(nolign-1) | [F:MWS]WCRFCY <> [M:MBO]FCY
    Read [MWS]WST0=[M:MBO]CPLLAB(nolign-1);[M:MBO]FCY
    If fstat : Raz [F:MWS] : Endif
Endif
Call INIT_CCE(VALEUR,AXE,"MKOLABB","",0) From TRTX3CPT
Return

$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
Return

$AS_LABCCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#
If [M:MBO]CPLLAB(nolign-1) = "" : mkstat = 2 : Return : Endif
Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
# Issue 72051 - 2011-03-04 by CCC : initialisation de la date avec la date d'imputation
Local Date WDATE : WDATE = [M:MBO]IPTDAT(nolign-1)
Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,WDATE) From TRTX3CPT
Return



######################################################################################
## Etiquette ajoutée par le superviseur (écran MTKBENCHO) 13/10/2009 11:44:33 (CCC)
######################################################################################
Subprog AS_WRHE(VALEUR)
Variable Char    VALEUR()
If GWRHOBY=2 & VALEUR<>"" & [M]NBLIG<>0
   GMESSAGE=mess(342,184,1) : mkstat=2
Endif
End


######################################################################################
# Actzo ou Grizo des dépôts selon le site
######################################################################################
$WRH_ETAT
If GWRHACT<>2 Return Endif
If [M]FCY<>[F:FCY]FCY
  Read [FCY]FCY0=[M]FCY
Endif
If [F:FCY]WRHGES=2
  Actzo [M:MBO]WRHE
Else
  Grizo [M:MBO]WRHE
Endif
Return

