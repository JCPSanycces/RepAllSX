########################################
Subprog AM_CPLOPETIM(VALEUR)
Variable Decimal VALEUR
#recalcul du tps unitaire
If [M:MBO]CPLQTY(nolign-1) <> 0
    [M:MBO]CPLUNTTIM(nolign-1) =  VALEUR / [M:MBO]CPLQTY(nolign-1)
    # 11.06 demande 38402
    [M:MBO]CPLUNTTIM(nolign-1) = func TRTX3.ARRTYP("","","TIH",[M:MBO]CPLUNTTIM(nolign-1))
Endif
End

########################################
Subprog C_STDOPENUM(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 : End : Endif
Read [F:ROT]ROT0 = VALEUR;[M:MBO]FCY
If fstat : GMESSAGE = mess(133,193,1) : mkstat = 1 : End : Endif
#Pas d'opération de sous-traitance
If [F:ROT]SCOCOD <> 1 : GMESSAGE = mess(30,190,1) : mkstat = 1 : End : Endif
End

########################################
Subprog AM_STDOPENUM(VALEUR)
Variable Decimal VALEUR
Local Integer OK
If VALEUR <> 0
    OK=1
    Call OUINON(mess(1,190,1),OK) From GESECRAN
    If OK=2
    Read [ROT]ROT0=VALEUR;[M:MBO]FCY
    If !fstat
         If [F:ROT]OPEUOM = ""
            Case [M:MBO]TIMTYP(nolign-1)
                 When 1 : Read [F:MFG]MFG0 = [M:MBO]MFGNUM(nolign-1)
                          If fstat : Raz [F:MFG] : Endif
                          [F:ROT]OPEUOM = [F:MFG]STU
                 When 2 : Read [F:ITM]ITM0 = [M:MBO]ITMREF(nolign-1)
                          If fstat : Raz [F:ITM] : Endif
                          [F:ROT]OPEUOM = [F:ITM]STU
            Endcase
         Endif
         [M:MBO]                   = [F:ROT]
         [M:MBO]CPLWST(nolign-1)   = [F:ROT]WST
         [M:MBO]CPLLAB(nolign-1)   = [F:ROT]LABWST
         [M:MBO]TECCRD(nolign-1)   = [F:ROT]TECCRD
         # FGR 21/09/2009 : X3SUIVI57981
         #[M:MBO]ROODES(nolign-1)   = [F:ROT]STDOPEDES  : Affzo  [M:MBO]ROODES(nolign-1)   # 16838 12.02 MM
         # FGR 01/10/2009 : X3SUIVI58277 : il y avait GLANGUE comme paramètre en trop
         Call LECTEXTRA([M:MBO]ROODES(nolign-1),"ROUOPESTD","STDOPEDESAXX",num$([F:ROT]STDOPENUM),[F:ROT]FCY) From ATEXTRA
         Affzo  [M:MBO]ROODES(nolign-1)
         [M:MBO]XOPEUOM(nolign-1)  = [M:MBO]OPEUOM(nolign-1)
    Endif
  Endif
Endif
End

