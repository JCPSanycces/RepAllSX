########################################
Subprog AM_CPLWST(VALEUR)
Variable Char    VALEUR()
Local Char    WCCE(15)
Local Integer J
Case [M:MBO]TIMTYP(nolign-1)
    When 1 :
            Read [F:MFO]MFO0 = [M:MBO]MFGNUM(nolign-1);[M:MBO]OPENUM(nolign-1);[M:MBO]OPESPLNUM(nolign-1)
            If fstat : Raz [F:MFO] : Endif

            #Chargement des sections ana
            For J = 1 To GNBDIE
                  Call INISEC(WCCE,"MKOB", J) From TRTX3CPT
                  Assign "[M:MBO]CCE"+num$(J)+"(nolign-1)" With WCCE
            Next
    When 2,3 :
            For J = 1 To GNBDIE
                  Call INISEC(WCCE,"MKOB", J) From TRTX3CPT
                  Assign "[M:MBO]CCE"+num$(J)+"(nolign-1)" With WCCE

            Next

    When Default :
Endcase
End

########################################
Subprog AM_CPLLAB(VALEUR)
Variable Char    VALEUR()
Local Char    WCCE(15)
Local Integer J
Case [M:MBO]TIMTYP(nolign-1)
    When 1 :
            Read [F:MFO]MFO0 = [M:MBO]MFGNUM(nolign-1);[M:MBO]OPENUM(nolign-1);[M:MBO]OPESPLNUM(nolign-1)
            If fstat : Raz [F:MFO] : Endif

            For J = 1 To GNBDIE
                   Call INISEC(WCCE,"MKOLABB", J) From TRTX3CPT
                   Assign "[M:MBO]LABCCE"+num$(J)+"(nolign-1)" With WCCE
            Next
    When 2,3 :
             For J = 1 To GNBDIE
                   Call INISEC(WCCE,"MKOLABB", J) From TRTX3CPT
                   Assign "[M:MBO]LABCCE"+num$(J)+"(nolign-1)" With WCCE
             Next
    When Default :
Endcase
End

