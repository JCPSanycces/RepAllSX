Subprog AS_TIMTYP(VALEUR)
Variable Integer VALEUR
If [F:BTS]OFFLG  = 1 : GMENLOC(1) = 1 :  Endif
If [F:BTS]GAMFLG = 1 : GMENLOC(2) = 1 :  Endif
If [F:BTS]DIVFLG = 1 : GMENLOC(3) = 1 :  Endif
If sum(GMENLOC(1..3)) = 2
   VALEUR = find(0,GMENLOC(1..3))
   mkstat = 2
Endif
End

