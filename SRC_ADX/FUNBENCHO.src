########################################
Subprog AP_OPENUM(VALEUR)
Variable Decimal VALEUR
Local Integer OK
# Warning only if new line (OPENUM=0)
If [M:MBO]ROUOPENUM(nolign-1) = 0 & [M:MBO]OPENUM(nolign-1)=0
    # Issue 110979/2 - 2016-03-25 by CCC : Warning message when routing is versioned (warning on the first add)
    If [F:MFG]MFGNUM<>[M:MBO]MFGNUM(nolign-1)
        Read [F:MFG]MFG0 = [M:MBO]MFGNUM(nolign-1)
    Endif
    If [F:MFG]ROUECCMAJ <> ""
        OK=1
        Call AVERTIR(mess(345,193,1),OK) From GESECRAN
        If OK = 1 : mkstat=1 : End : Endif # Cancel
    Else
        OK = 1
        Call AVERTIR(mess(116,190,1),OK) From GESECRAN
        If OK = 1 : mkstat = 1 : End : Endif
    Endif
#   [M:MBO]OPEUOM(nolign-1)    = [M:MBO]STU(nolign-1)
#   [M:MBO]XOPEUOM(nolign-1)   = [M:MBO]STU(nolign-1)
   [M:MBO]OPESTUCOE(nolign-1) = 1
   [M:MBO]OPEWORCOE(nolign-1) = 1
   [M:MBO]CLEFLG(nolign-1)    = 2
   [M:MBO]DACMST(nolign-1)    = 2
Endif
End

