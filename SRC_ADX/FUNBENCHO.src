######################################################################################
## Etiquette ajoutée par le superviseur (écran MTKBENCHO) 13/01/2005 09:14:35 (SR)
######################################################################################
Subprog AM_CPLTIMGLO(VALEUR)
Variable Decimal VALEUR
If [M:MBO]LORI <> "PILOT" | [F:BTS]CPLUPDFLG <> 2 : End : Endif
[M:MBO]CPLTIMGLO = VALEUR
Gosub RECALCUL_TPS
End

Subprog AM_CPLUOMCOD(VALEUR)
Variable Integer VALEUR
If [M:MBO]LORI <> "PILOT" | [F:BTS]CPLUPDFLG <> 2 : End : Endif
Gosub RECALCUL_TPS
End

#######################################################################
$RECALCUL_TPS
Local Integer I
Local Decimal WCPLTIMGLO        # Temps réalisé global saisie en entête
Local Decimal WEXTTIMGLO        # Temps prévu global exprimé dans l'unité du temps global réalisé
Local Decimal WCOEFF_CPLOPETIM  # % du temps prévu de l'opé par rapport au temps prévu total

WCPLTIMGLO = [M:MBO]CPLTIMGLO

#si un temps à ventiler est saisi, on cumule les temps opé prévus
#on enlève  le temps de réglage du temps total saisi
For I = 0 To [M:MBO]NBLIG
       If [M:MBO]CPLUOMCOD <> [M:MBO]TIMUOMCOD(I)
        Case [M:MBO]CPLUOMCOD
            When 1 : # le temps total est en heure et le temps de l'opé est en minute
                     # on ramène le temps de l'opé en heure
                     If [M:MBO]CPLOPETIM(I) <> 0
                        WEXTTIMGLO += [M:MBO]CPLOPETIM(I) / 60
                     Endif
                    If [M:MBO]CPLSETTIM(I) <> 0
                       If WCPLTIMGLO = 0 : Raz [M:MBO]CPLSETTIM(I)
                        Else
                           WCPLTIMGLO -= [M:MBO]CPLSETTIM(I) / 60
                        Endif
                    Endif
            When 2 : # le temps total est en minute et le temps de l'opé est en heure
                     # on ramène le temps de l'opé en minute
                     If [M:MBO]CPLOPETIM(I) <> 0
                        WEXTTIMGLO += [M:MBO]CPLOPETIM(I) * 60
                     Endif
                     If [M:MBO]CPLSETTIM(I) <> 0
                        If WCPLTIMGLO = 0 : Raz [M:MBO]CPLSETTIM(I)
                        Else
                           WCPLTIMGLO -= [M:MBO]CPLSETTIM(I) * 60
                        Endif
                     Endif
      Endcase
     Else
      If [M:MBO]CPLOPETIM(I) <> 0
         WEXTTIMGLO += [M:MBO]CPLOPETIM(I)
      Endif
      If [M:MBO]CPLSETTIM(I) <> 0
         If WCPLTIMGLO = 0 : Raz [M:MBO]CPLSETTIM(I)
         Else
            WCPLTIMGLO -= [M:MBO]CPLSETTIM(I)
         Endif
      Endif
    Endif
    If WCPLTIMGLO < 0 : Raz WCPLTIMGLO : Endif
Next
Gosub VENTILE_CPLTIMGLO
Affzo [M:MBO]15
Return


