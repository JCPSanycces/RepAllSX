########################################
Subprog S_CPLWST(VALEUR)
Variable Char    VALEUR()
Filter [F:MWS] Where WCRFCY = [M:MBO]FCY
Call SELECT("MWS","",[M:MBO]FCY,"") From SELOBJ
Filter [F:MWS]
If status = 7 : End
Else
    VALEUR = [F:MWS]WST
Endif
End

########################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
#on recherche une alternative
If VALEUR <> ""
    [M:MBO]STU(nolign-1)    =[F:ITM]STU
    #--------------------------------#
    # Recherche alternative valide   #
    # pour proposition auto.         #
    #--------------------------------#
    Local Char    WFCY(GLONFCY)
    Local Integer WALT
    Local Date    WDAT
    Local Integer WMSG
    Local Integer I
    Local Integer  TABTBO(3)
#
    WDAT= date$
    WMSG=1
    WFCY=[M:MBO]FCY
    If [F:ITF]STOFCY <> WFCY | [F:ITF]ITMREF <> VALEUR
        Read [F:ITF]ITF0 = VALEUR;WFCY
        If fstat : Raz [F:ITF] : Endif
    Endif
#    Lecture ROUTING
    If [F:ITF]MFGROUALT <> 0
        Read [F:ROH]ROH0=VALEUR;[F:ITF]MFGROUALT;[M:MBO]FCY     : # Beryl Site en fin de clé primaire
        If !fstat
            Read [F:TRO]TRO0=[F:ITF]MFGROUALT
            If !fstat
                 Call CONTMFGGAM(WFCY,WALT,WDAT,WMSG)
                If WALT <> 0
                    [M:MBO]ROUALT(nolign-1)  = WALT
                    [M:MBO]WROUVAL(nolign-1) = 1
                    [M:MBO]TIMUOMCOD(nolign-1) = [F:ROH]TIMUOMCOD
                Endif
            Endif
        Endif
    Endif
#
    For [ROH] Where [F:ROH]FCY = [M:MBO]FCY & [F:ROH]ITMREF= VALEUR
        Read [TRO]TRO0=[F:ROH]ROUALT
        If !fstat
            Call CONTMFGGAM(WFCY,WALT,WDAT,WMSG)
            If WALT <> 0
                [M:MBO]ROUALT(nolign-1)  = WALT
                [M:MBO]WROUVAL(nolign-1) = 1
                [M:MBO]TIMUOMCOD(nolign-1) = [F:ROH]TIMUOMCOD
                Break
            Endif
        Endif
    Next
Endif
Affzo [M:MBO]ROUALT(nolign-1)
End

########################################
Subprog AM_ROUALT(VALEUR)
Variable Decimal VALEUR
Local Char    WFCY(GLONFCY)
Local Integer WALT
Local Date    WDAT
Local Integer WMSG
Local Integer I
WFCY = [M:MBO]FCY
WALT = VALEUR
WDAT = date$
WMSG = 1
Read [F:ROH]ROH0=[M:MBO]ITMREF(nolign-1);VALEUR;[M:MBO]FCY  : # Beryl Site en fin de clé primaire
If !fstat
    Read [F:TRO]TRO0=VALEUR
    If !fstat
        Call CONTMFGGAM(WFCY,WALT,WDAT,WMSG)
        If GMESSAGE <> ""
           Call ERREUR(GMESSAGE) From GESECRAN
           mkstat = 1
           [M:MBO]WROUVAL(nolign-1) = 0
           End
        Endif
    Else [M:MBO]WROUVAL(nolign-1) = 0
         End
    Endif
Else [M:MBO]WROUVAL(nolign-1) = 0
     End
Endif
[M:MBO]WROUVAL(nolign-1) = 1
End

