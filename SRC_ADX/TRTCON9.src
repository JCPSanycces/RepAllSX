#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################################################
# Traitement de gestion de la sélection d'un modèle de contrat de service Module CRM    19 septembre 2000
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  #PARAM(1) = Catégorie du contrat.
  Global Integer GIHBDISP

  GIHBDISP = 0
  If !clalev([F:COT]) : Local File CONTTEMPL [COT] : Endif
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  #Renseigne l'en-tête
Local Integer ISEMPTY

  [M:CON9]CONCAT = val(PARAM(1))
  ISEMPTY = 0
  [M:CON9]TPLTYP = mess([M:CON9]CONCAT,2976,1)
  #Charge le tableau
  Call LOADTPL(ISEMPTY)
  If ISEMPTY Then
    FIN = 1
    #Aucun modèle n'a été défini pour la catégorie : XXXXXX
    GMESSAGE = mess(349,182,1) - mess([M:CON9]CONCAT,2976,1)
    GERR = 2
  Else
    GIHBDISP = 1
  Endif
  GICON9OPGFLG = 1
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  If GIHBDISP Then
    Raz [M:CON9]
  Endif
  Kill GIHBDISP
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
Local Integer ICHOIX

  ICHOIX = 0
  Case BOUT
    When "A"
      #Demande si l'utilisateur souhaite sélectionner un modèle de contrat.
      #Confirmez-vous la qualification du contrat avec les informations du modèle sélectionné ?
      Call OUINON(mess(348,182,1), ICHOIX) From GESECRAN
      If ICHOIX = 1 Then
        #Non
        GISETFCOT = 0
        FIN = 1
      Elsif ICHOIX = 2 Then
        Local Char SZMODELECON(GLONVCR)

        SZMODELECON = [M:CON9]TPLNUM(nolign-1)
        VALEUR = SZMODELECON
        Gosub ONSELECT
        mkstat = 4
        FIN = 1
      Endif
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
# Sous-programmes
##########################################################################################################
# Chargement du tableau des modèles de contrats de service
#########################################################################
Subprog LOADTPL(EMPTY)
Variable Integer EMPTY

Local Integer IB

  Raz [M:CON9]NBTPL
  Raz [M:CON9]TPLNAM
  Raz [M:CON9]TPLNUM
  IB = 0
  Filter [COT] Where [F:COT]CONCAT = [M:CON9]CONCAT
  For [COT]COT0
    [M:CON9]TPLNAM(IB) = [F:COT]TPLNAM
    [M:CON9]TPLNUM(IB) = [F:COT]CONNUM
    IB += 1
  Next
  If IB = 0 Then
    EMPTY = 1
  Else
    EMPTY = 0
    [M:CON9]NBTPL = IB
    Affzo [M:CON9]1-99
  Endif
  Filter [COT]
End

#########################################################################
Subprog SELECTCOT (SZMODELE, SZORIGINE)
Value Char SZMODELE    # FGR 10/08/2009 : X3SUIVI57084
Value Char SZORIGINE

Local Char SZMODELECON(GLONVCR)

  SZMODELECON = SZMODELE
  Gosub ONSELECT
End

##########################################################################################################
# Gestion du bouton Sélectionner
#########################################################################
$ONSELECT
Local Integer IDPT
Local Integer INBITM
Local Integer I
Local Char SZPTE(GLONPTE)     # Condition de paiement

  # FGR 18/03/2009 : X3SUIVI53591
  If dim(SZCONNUM) < 0 Then
    Local Char SZCONNUM(GLONVCR)  # N° de contrat
  Endif

  I = 0
  IDPT = 0
  INBITM = 0
  SZCONNUM = [M:CON0]CONNUM
  Read [COT]COT0=SZMODELECON
  If !fstat Then
    GISETFCOT = 1
    #LSE 03/10/2005 FQ 32334
    SZPTE = [M:CON8]PTE
    #Transclass
    [M:CON0] = [F:COT]
    [M:CON1] = [F:COT]
    [M:CON4] = [F:COT]
    [M:CON8] = [F:COT]
    [M:CONG] = [F:COT]
    If SZCONNUM <> "" Then
      [M:CON0]CONNUM = SZCONNUM
    Else
      [M:CON0]CONNUM = ""
    Endif
    GSZPCOCUR = [F:COT]CUR
    #référence du contrat 
    [M:CON1]CONCOT = SZMODELECON
    #Dénomination du contrat
    If [M:CON1]CONNAM = "" Then
      [M:CON1]CONNAM = [F:COT]TPLNAM
    Endif
    #Litiges acceptés
    For I = 0 To dim([F:COT]ACPDPTCOD)-1
      If [F:COT]ACPDPTCOD(I) = "" Then
        Break
      Else
        [M:CON8]ACPDPTCOD(I) = [F:COT]ACPDPTCOD(I)
      Endif
      IDPT += 1
    Next
    [M:CON8]NBDPT = IDPT 
    #Condition de paiement
    If [F:COT]PTE = "" Then
      [M:CON8]PTE = SZPTE
    Endif
    #Résiliation
    [M:CON5]RSIFLG = 1
    [M:CON5]FDDFLG = 1
    [M:CON5]RSIDAT = [00/00/00]
    [M:CON5]RSIREN = ""
    [M:CON5]FDDUSR = ""
    #Calcul de la date de début et de fin courante du contrat.
    Call SETSTRDAT([M:CON4]SIUDAT, [M:CON4]CONSTRDAT) From SUBCOND
    Call SETENDDAT([M:CON4]CONSTRDAT, [M:CON4]REWFRY, [M:CON4]REWFRYBAS, [M:CON4]CONENDDAT) From SUBCOND
    #Calcul la date et le montant de la prochaine facture.
    Call SNEXINVDAT([M:CON2]LASINVDAT, [M:CON8]INVFRY, [M:CON8]INVFRYBAS, [M:CON4]SIUDAT, [M:CON4]CONSTRDAT, [M:CON2]NEXINVDAT) From SUBCOND
    Call SNEXSHIINV([M:CON2]NEXINVDAT, [M:CON8]INVLTI, [M:CON8]INVLTIBAS, [M:CON2]NEXSHIINV) From SUBCOND
    Call SNEXINVAMT([M:CON4]CONAMT, [M:CON8]INVFRY, [M:CON8]INVFRYBAS, [M:CON8]INVFRYCOE, [M:CON2]NEXINVAMT) From SUBCOND
    #Calcul de la dernière valeur d'index utilisée et de sa date
    If [M:CON4]RVASSP = 1 Then
      Call SLASVALIDX([M:CON4]CONBASIDX, [M:CON4]SIUDAT, [M:CON4]LASVALIDX) From SUBCOND
      Call SLASIDXDAT([M:CON4]CONBASIDX, [M:CON4]SIUDAT, [M:CON4]LASIDXDAT) From SUBCOND
      [M:CON4]RVADAT = [M:CON4]SIUDAT
    Elsif [M:CON4]RVASSP = 2 Then
      [M:CON4]LASVALIDX = 0
      [M:CON4]LASIDXDAT = [00/00/00]
      [M:CON4]RVADAT = [M:CON4]SIUDAT
    Else
      [M:CON4]LASVALIDX = 0
      [M:CON4]LASIDXDAT = [00/00/00]
      [M:CON4]RVADAT = [M:CON4]SIUDAT
    Endif
    #Code article
    If [M:CON1]CONCAT = 1 Then
      # Garantie : pas d'article puisque non facturable
      [M:CONG]ITMREF = ""
      [M:CONG]SAU = ""
    Else
      INBITM = 0
      [M:CONG]ITMREF = ""
      Filter [ITM] Where [F:ITM]TPLCONSRV = SZMODELECON
      For [ITM]
        [M:CONG]ITMREF = [F:ITM]ITMREF
        INBITM += 1
      Next
      Filter [ITM]
      If INBITM <> 1 Then
        [M:CONG]ITMREF = GDEFCONITM
      Endif
    Endif
    #Renouvellement
    [M:CON4]MANREWFLG = 1
    [M:CON4]MANREWAMT = 0
    #Effectue le contrôle de grisage des champs
    Call SETGRAY From SUBCONB1
    Affzo [M:CON0]1-99
    Affzo [M:CON1]1-99
    Affzo [M:CON2]1-99
    Affzo [M:CON4]1-99
    Affzo [M:CON5]1-99
    Affzo [M:CON8]1-99
    Affzo [M:CONG]1-99
  Endif
Return

##########################################################################################################
# Chargement du tableau des contraintes qualité
#########################################################################
Subprog LOADTQUAL (SZMODELE) 
Value Char SZMODELE

Local Char SZCOTCUR(GLONCUR)
Local Integer IBDEBTRANSFLG
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  Call RAZQUAL("CON", [M:CON0]CONNUM, IERRINF, ICHAPTER, IBRETOUR) From TRTCON3
  If IBRETOUR = 0 Then
    GMESSAGE = mess(IERRINF,ICHAPTER,1)
    GERR = 1
    End
  Endif
  #Obtient la devise du modèle utilisé
  Read [COT]COT0=SZMODELE
  If fstat Then
    SZCOTCUR = [M:CON0]CUR
  Else
    SZCOTCUR = [F:COT]CUR
  Endif
  Local File CONTQUAL [CQL2]
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [CQL]
  Endif
  Filter [CQL2] Where [F:CQL2]CONNUM = SZMODELE and [F:CQL2]TPL = 2
  For [CQL2]
    Raz [F:CQL]
    [F:CQL] = [F:CQL2]
    [F:CQL]CONNUM = [M:CON0]CONNUM
    [F:CQL]TPL = 1
    #Calcul la date de fin d'intervention sur site
    Call SITTDATEND([M:CON4]CONSTRDAT, [F:CQL]ITTDUR, [F:CQL]ITTDURBAS, [F:CQL]ITTDATEND) From SUBCOND
    #Calcul les pénalités de retard dans la devise effective du contrat
    Call SETAMTPLY([M:CON0]SALFCY, [M:CON0]CUR, SZCOTCUR, [F:CQL2]AMTPLY, [F:CQL]AMTPLY) From SUBCOND
    Write [CQL]
    If fstat Then
      #Erreur lors de la génération des contraintes qualité sur la base du modèle sélectionné.
      GMESSAGE = mess(347,182,1)
      GERR = 1
      Break
    Endif
  Next
  Filter [CQL2]
  If IBDEBTRANSFLG = 0 Then
    If GERR Then
      Rollback
    Else
      Commit
    Endif
  Endif
  Close Local File [CQL2]
End

##########################################################################################################
# Chargement du tableau des familles de compétences et de la couverture article
#########################################################################
Subprog LOADPBLMAC (SZMODELE) 
Value Char SZMODELE

Local Integer ICXTFLG
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer IBDEBTRANSFLG

  ICXTFLG = 0
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  If [M:CON0]COVLOWLEV = 0 Then
    #Création normale suite à la sélection d'un modèle de contrat
    Call RAZPBL("CON", [M:CON0]CONNUM, IERRINF, ICHAPTER, IBRETOUR) From TRTCONH
    If IBRETOUR = 0 Then
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GERR = 1
      End  # FGR 29/03/2010 : X3SUIVI62472 : et pas Return
    Endif
    #
    Call RAZPCOV("CON", [M:CON0]CONNUM, IERRINF, ICHAPTER, IBRETOUR) From TRTCONH
    If IBRETOUR = 0 Then
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GERR = 1
      End  # FGR 29/03/2010 : X3SUIVI62472 : et pas Return
    Endif
    #
    If [M:CON1]EVRPBL = 2 Then
      If [M:CON1]EVRMAC = 2 Then
        End
      Endif
    Endif
    If adxlog = 1 Then
      IBDEBTRANSFLG = 1
    Else
      IBDEBTRANSFLG = 0
    Endif
    Local File CONTCOV [CCV2]
    If IBDEBTRANSFLG = 0 Then
      Call DEBTRANS From GLOCK
      Trbegin [CCV2]
    Endif
    Filter [CCV2] Where [F:CCV2]CONNUM = SZMODELE and [F:CCV2]TPL = 2
    For [CCV2]
      Raz [F:CCV]
      [F:CCV] = [F:CCV2]
      [F:CCV]CONNUM = [M:CON0]CONNUM
      [F:CCV]TPL = 1
      [F:CCV]BPC = [M:CON0]CONBPC
      Write [CCV]
      If fstat Then
        #Erreur lors de la génération de la couverture article et compétences sur la base du modèle sélectionné.
        GMESSAGE = mess(346,182,1)
        GERR = 1
        Break
      Endif
    Next
    Filter [CCV2]
    If IBDEBTRANSFLG = 0 Then
      If GERR Then
        Rollback
      Else
        Commit
      Endif
    Endif
    Close Local File [CCV2]
  Else
    If type(GSZMACNUMRULE) < 0 Then
      If GPILNAV > 1 Then
        If GNAVIG(GPILNAV-1) = "GESMAC" Then
          Global Char GSZMACNUMRULE(GLONVCR)

          ICXTFLG = 1
          GSZMACNUMRULE = [M:MAC0]MACNUM
        Endif
      Endif
    Endif
    Call LOADFROMRULES([M:CON0]CONNUM, [M:CON0]CONBPC, SZMODELE, IERRINF, ICHAPTER, IBRETOUR)
    If IBRETOUR = 0 Then
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GERR = 1
    Endif
    If ICXTFLG > 0 Then
      Call CREMINCOV([M:CON0]CONNUM, GSZMACNUMRULE, [M:CON0]CONBPC, IERRINF,ICHAPTER,IBRETOUR) From TRTMACRULE
      Kill GSZMACNUMRULE
      If IBRETOUR = 0 Then
        GMESSAGE = mess(IERRINF,ICHAPTER,1)
        GERR = 1
      Endif
    Endif
  Endif
End

##########################################################################################################
# Chargement du tableau des familles de compétences et de la couverture article depuis le composant TRTMACRULE
#########################################################################
Subprog LOADFROMRULES(SZPCONNUM, SZBPC, SZCOTNUM, IERRINF, ICHAPTER, IBRETOUR)
Value Char SZPCONNUM  # FGR 18/03/2009 : X3SUIVI53591
Value Char SZBPC
Value Char SZCOTNUM
Variable Integer IERRINF
Variable Integer ICHAPTER
Variable Integer IBRETOUR

Local Integer IITMLEVEL
Local Char SZCOTRECNUM
Local Integer IRECNUM
Local Char SZRECNUM
Local Char SZITMFAMCIA
Local Char SZITMREF
Local Integer IBDEBTRANSFLG
Local Char SZCONNUM(GLONVCR)  # FGR 18/03/2009 : X3SUIVI53591

  SZCONNUM = SZPCONNUM  # FGR 18/03/2009 : X3SUIVI53591
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  #Création dans le cadre d'une création automatisés de parc ou assistée de contrat depuis une fiche parc
  #On recherche s'il existe une couverture au niveau référence article.
  If !clalev([F:MAC]) : Local File MACHINES [MAC] : Endif
  IITMLEVEL = 0
  IRECNUM = 0
  SZITMFAMCIA = ""
  SZITMREF = ""
  Read [MAC]MAC0=GSZMACNUMRULE
  If fstat Then
    #Erreur lors de l'obtention du code article de la fiche parc à couvrir.
    IERRINF = 442
    ICHAPTER = 182
    IBRETOUR = 0
    GOK = 0
    End
  Else
    SZITMREF = [F:MAC]MACPDTCOD
  Endif
  If SZITMREF = "" Then
    #Erreur lors de l'obtention du code article de la fiche parc à couvrir.
    IERRINF = 442
    ICHAPTER = 182
    IBRETOUR = 0
    GOK = 0
    End       # FGR 04/01/2010 : X3SUIVI70100 : c'est mieux de sortir quand il y a une erreur
  Endif
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  Local File CONTCOV [CCV2]
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [CCV2]
  Endif
  #Calcul le dernier RECNUM
  IRECNUM = 0
  Call CPTCOVNUM(SZCONNUM, 0, "", SZRECNUM, IRECNUM) From SUBMACB
  #Obtient la famille commerciale de produit du parc
  Read [ITM]ITM0=SZITMREF
  If !fstat Then
    SZITMFAMCIA = [F:ITM]TSICOD(GFAMCIA-1)
  Endif
  #NIVEAU REFERENCE ARTICLE
  #Couverture parc
  Filter [CCV2] Where [F:CCV2]CONNUM = SZCOTNUM and [F:CCV2]TPL = 2 and [F:CCV2]RECTYP = "MAC" and [F:CCV2]SBBRECTYP = "ITM" and [F:CCV2]CMT = SZITMREF and [F:CCV2]PAEKEY(0) = ""
  For [CCV2]
    IITMLEVEL += 1
    Raz [F:CCV]
    [F:CCV] = [F:CCV2]
    [F:CCV]CONNUM = SZCONNUM
    [F:CCV]TPL = 1
    [F:CCV]BPC = SZBPC
    [F:CCV]SBBRECTYP = "MAC"
    [F:CCV]RECNUM = num$(IRECNUM)
    [F:CCV]CMT = GSZMACNUMRULE
    [F:CCV]CPNSRT = "CMACMAC"
    SZCOTRECNUM = [F:CCV2]RECNUM
    Write [CCV]
    If fstat Then
      #Erreur lors de la génération de la couverture article et compétences sur la base du modèle sélectionné.
      IERRINF = 346
      ICHAPTER = 182
      IBRETOUR = 0
      GOK = 0
      Break
    Endif
  Next
  Filter [CCV2]
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
      #Close Local File [CCV2]   # FGR 04/01/2011 : X3SUIVI70100 : là c'est pas top
      #End                       # FGR 04/01/2011 : X3SUIVI70100 : là c'est pas top
    Endif
  Endif
  If GOK < 1 Then                # FGR 04/01/2011 : X3SUIVI70100 : là c'est mieux
    Close Local File [CCV2]
    End
  Endif
  #S'il n'y a pas de couverture de niveau ref article, on switch sur une couverture de niveau famille commerciale
  If IITMLEVEL = 0 Then
    If SZITMFAMCIA <> "" Then
      Gosub DO_CIA_LEVEL
      If GOK = 1 Then
        Gosub DO_CRS_PBLITM
      Endif
    Endif
    If IBDEBTRANSFLG = 0 Then
      If GOK < 1 Then
        Rollback
      Else
        Commit
      Endif
    Endif
    Close Local File [CCV2]
    End
  Endif
  #Couverture composant
  Filter [CCV2] Where [F:CCV2]CONNUM = SZCOTNUM
&                 and [F:CCV2]TPL = 2
&                 and [F:CCV2]RECTYP = "CPN"
&                 and [F:CCV2]SBBRECTYP = ""
&                 and [F:CCV2]CMT = SZITMREF
&                 and [F:CCV2]PAEKEY(1) = SZCOTRECNUM
&                 and [F:CCV2]PAEKEYTYP(1) = "ITM"
&                 and [F:CCV2]PAEKEY(0) = ""
  For [CCV2]
    Raz [F:CCV]
    [F:CCV] = [F:CCV2]
    [F:CCV]CONNUM = SZCONNUM
    [F:CCV]TPL = 1
    [F:CCV]BPC = SZBPC
    [F:CCV]CMT = GSZMACNUMRULE
    [F:CCV]CPNSRT = "CCPNMAC"
    [F:CCV]PAEKEY(1) = num$(IRECNUM)
    [F:CCV]PAEKEYTYP(1) = "MAC"
    Write [CCV]
    If fstat Then
      #Erreur lors de la génération de la couverture article et compétences sur la base du modèle sélectionné.
      IERRINF = 346
      ICHAPTER = 182
      IBRETOUR = 0
      GOK = 0
      Break
    Endif
  Next
  Filter [CCV2]
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
      #Close Local File [CCV2]   # FGR 04/01/2011 : X3SUIVI70100 : là c'est pas top
      #End                       # FGR 04/01/2011 : X3SUIVI70100 : là c'est pas top
    Endif
  Endif
  If GOK < 1 Then                # FGR 04/01/2011 : X3SUIVI70100 : là c'est mieux
    Close Local File [CCV2]
    End
  Endif
  #Couverture financière d'une référence article
  Filter [CCV2] Where [F:CCV2]CONNUM = SZCOTNUM
&                 and [F:CCV2]TPL = 2
&                 and [F:CCV2]RECTYP = "AAA"
&                 and [F:CCV2]CMT = SZITMREF
&                 and [F:CCV2]PAEKEY(1) = SZCOTRECNUM
&                 and [F:CCV2]PAEKEYTYP(1) = "ITM"
&                 and [F:CCV2]PAEKEY(0) = ""
  For [CCV2]
    Raz [F:CCV]
    [F:CCV] = [F:CCV2]
    [F:CCV]CONNUM = SZCONNUM
    [F:CCV]TPL = 1
    [F:CCV]BPC = SZBPC
    [F:CCV]CMT = GSZMACNUMRULE
    [F:CCV]CPNSRT = "CAAACPNMAC"
    [F:CCV]PAEKEY(1) = num$(IRECNUM)
    [F:CCV]PAEKEYTYP(1) = "MAC"
    Write [CCV]
    If fstat Then
      #Erreur lors de la génération de la couverture article et compétences sur la base du modèle sélectionné.
      IERRINF = 346
      ICHAPTER = 182
      IBRETOUR = 0
      GOK = 0
      Break
    Endif
  Next
  Filter [CCV2]
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
      #Close Local File [CCV2]   # FGR 04/01/2011 : X3SUIVI70100 : là c'est pas top
      #End                       # FGR 04/01/2011 : X3SUIVI70100 : là c'est pas top
    Endif
  Endif
  If GOK < 1 Then                # FGR 04/01/2011 : X3SUIVI70100 : là c'est mieux
    Close Local File [CCV2]
    End
  Endif
  #Couverture financière d'un composant
  Filter [CCV2] Where [F:CCV2]CONNUM = SZCOTNUM
&                 and [F:CCV2]TPL = 2
&                 and [F:CCV2]RECTYP = "AAA"
&                 and [F:CCV2]CMT = SZITMREF
&                 and [F:CCV2]PAEKEY(1) = SZCOTRECNUM
&                 and [F:CCV2]PAEKEY(2) <> ""
&                 and [F:CCV2]PAEKEYTYP(1) = "ITM"
&                 and [F:CCV2]PAEKEY(0) = ""
  For [CCV2]
    Raz [F:CCV]
    [F:CCV] = [F:CCV2]
    [F:CCV]CONNUM = SZCONNUM
    [F:CCV]TPL = 1
    [F:CCV]BPC = SZBPC
    [F:CCV]CMT = GSZMACNUMRULE
    [F:CCV]CPNSRT = "CAAACPNMAC"
    [F:CCV]PAEKEY(1) = num$(IRECNUM)
    [F:CCV]PAEKEYTYP(1) = "MAC"
    Write [CCV]
    If fstat Then
      #Erreur lors de la génération de la couverture article et compétences sur la base du modèle sélectionné.
      IERRINF = 346
      ICHAPTER = 182
      IBRETOUR = 0
      GOK = 0
      Break
    Endif
  Next
  Filter [CCV2]
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
      #Close Local File [CCV2]   # FGR 04/01/2011 : X3SUIVI70100 : là c'est pas top
      #End                       # FGR 04/01/2011 : X3SUIVI70100 : là c'est pas top
    Endif
  Endif
  If GOK < 1 Then                # FGR 04/01/2011 : X3SUIVI70100 : là c'est mieux
    Close Local File [CCV2]
    End
  Endif
  #Définition des couvertures croisées (Compétences / Articles)
  Gosub DO_CRS_PBLITM
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
    Else
      Commit
    Endif
  Endif
  Close Local File [CCV2]
  #SZCONNUM
End

##########################################################################################################
# Chargement des plans d'entretien
#########################################################################
Subprog LOADPCARE (SZMODELE)
Value Char SZMODELE

Local Char SZCOTCUR
Local Integer IBDEBTRANSFLG

  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  Local File CONTCARE [CCA2]
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [CCA2]
  Endif
  Call RAZPCARE ("CON", [M:CON0]CONNUM) From TRTCONI
  If GOK = 1 Then
    Filter [CCA2] Where [F:CCA2]CONNUM = SZMODELE and [F:CCA2]TPL = 2
    For [CCA2]
      Raz [F:CCA]
      [F:CCA] = [F:CCA2]
      [F:CCA]CONNUM = [M:CON0]CONNUM
      [F:CCA]TPL = 1
      Write [CCA]
      If fstat Then
        #Erreur lors de la génération des plans d'entretiens sur la base du modèle sélectionné.
        GMESSAGE = mess(199,177,1)
        GERR = 1
        GOK = 0
        Break
      Endif
    Next
    Filter [CCA2]
  Endif
  If IBDEBTRANSFLG = 0 Then
    If GOK < 1 Then
      Rollback
    Else
      Commit
    Endif
  Endif
  Close Local File [CCA2]
End

##########################################################################################################
$DO_CIA_LEVEL
  #NIVEAU FAMILLE COMMERCIALE DE PRODUIT
  #Couverture parc
  Filter [CCV2] Where [F:CCV2]CONNUM = SZCOTNUM
&                 and [F:CCV2]TPL = 2
&                 and [F:CCV2]RECTYP = "MAC"
&                 and [F:CCV2]SBBRECTYP = "CIA"
&                 and [F:CCV2]CMT = SZITMFAMCIA
&                 and [F:CCV2]PAEKEY(0) = ""
  For [CCV2]
    IITMLEVEL += 1
    Raz [F:CCV]
    [F:CCV] = [F:CCV2]
    [F:CCV]CONNUM = SZCONNUM
    [F:CCV]TPL = 1
    [F:CCV]BPC = SZBPC
    [F:CCV]SBBRECTYP = "MAC"
    [F:CCV]RECNUM = num$(IRECNUM)
    [F:CCV]CMT = GSZMACNUMRULE
    [F:CCV]CPNSRT = "CMACMAC"
    SZCOTRECNUM = [F:CCV2]RECNUM
    Write [CCV]
    If fstat Then
      #Erreur lors de la génération de la couverture article et compétences sur la base du modèle sélectionné.
      IERRINF = 346
      ICHAPTER = 182
      IBRETOUR = 0
      GOK = 0    
      Break
    Endif
    Break
  Next
  Filter [CCV2]
  If GOK < 1 Then
    Return
  Endif
  #Couverture composant
  Filter [CCV2] Where [F:CCV2]CONNUM = SZCOTNUM
&                 and [F:CCV2]TPL = 2
&                 and [F:CCV2]RECTYP = "CPN"
&                 and [F:CCV2]SBBRECTYP = ""
&                 and [F:CCV2]CMT = SZITMFAMCIA
&                 and [F:CCV2]PAEKEY(1) = SZCOTRECNUM
&                 and [F:CCV2]PAEKEYTYP(1) = "CIA"
&                 and [F:CCV2]PAEKEY(0) = ""
  For [CCV2]
    IITMLEVEL += 1
    Raz [F:CCV]
    [F:CCV] = [F:CCV2]
    [F:CCV]CONNUM = SZCONNUM
    [F:CCV]TPL = 1
    [F:CCV]BPC = SZBPC
    [F:CCV]CMT = GSZMACNUMRULE
    [F:CCV]CPNSRT = "CCPNMAC"
    [F:CCV]PAEKEY(1) = num$(IRECNUM)
    [F:CCV]PAEKEYTYP(1) = "MAC"
    Write [CCV]
    If fstat Then
      #Erreur lors de la génération de la couverture article et compétences sur la base du modèle sélectionné.
      IERRINF = 346
      ICHAPTER = 182
      IBRETOUR = 0
      GOK = 0
      Break
    Endif
  Next
  Filter [CCV2]
  If GOK < 1 Then
    Return
  Endif
  #Couverture financière
  Filter [CCV2] Where [F:CCV2]CONNUM = SZCOTNUM
&                 and [F:CCV2]TPL = 2
&                 and [F:CCV2]RECTYP = "AAA"
&                 and [F:CCV2]CMT = SZITMFAMCIA
&                 and [F:CCV2]PAEKEY(1) = SZCOTRECNUM
&                 and [F:CCV2]PAEKEYTYP(1) = "CIA"
&                 and [F:CCV2]PAEKEY(0) = ""
  For [CCV2]
    IITMLEVEL += 1
    Raz [F:CCV]
    [F:CCV] = [F:CCV2]
    [F:CCV]CONNUM = SZCONNUM
    [F:CCV]TPL = 1
    [F:CCV]BPC = SZBPC
    [F:CCV]CMT = GSZMACNUMRULE
    [F:CCV]CPNSRT = "CAAACPNMAC"
    [F:CCV]PAEKEY(1) = SZCOTRECNUM
    [F:CCV]PAEKEYTYP(1) = "MAC"
    Write [CCV]
    If fstat Then
      #Erreur lors de la génération de la couverture article et compétences sur la base du modèle sélectionné.
      IERRINF = 346
      ICHAPTER = 182
      IBRETOUR = 0
      GOK = 0
      Break
    Endif
  Next
  Filter [CCV2]
  If GOK < 1 Then
    Return
  Endif
  #Couverture financière d'un composant
  Filter [CCV2] Where [F:CCV2]CONNUM = SZCOTNUM
&                 and [F:CCV2]TPL = 2
&                 and [F:CCV2]RECTYP = "AAA"
&                 and [F:CCV2]CMT = SZITMFAMCIA
&                 and [F:CCV2]PAEKEY(1) = SZCOTRECNUM
&                 and [F:CCV2]PAEKEY(2) <> ""
&                 and [F:CCV2]PAEKEYTYP(1) = "CIA"
&                 and [F:CCV2]PAEKEY(0) = ""
  For [CCV2]
    Raz [F:CCV]
    [F:CCV] = [F:CCV2]
    [F:CCV]CONNUM = SZCONNUM
    [F:CCV]TPL = 1
    [F:CCV]BPC = SZBPC
    [F:CCV]CMT = GSZMACNUMRULE
    [F:CCV]CPNSRT = "CAAACPNMAC"
    [F:CCV]PAEKEY(1) = num$(IRECNUM)
    [F:CCV]PAEKEYTYP(1) = "MAC"
    Write [CCV]
    If fstat Then
      #Erreur lors de la génération de la couverture article et compétences sur la base du modèle sélectionné.
      IERRINF = 346
      ICHAPTER = 182
      IBRETOUR = 0
      GOK = 0
      Break
    Endif
  Next
  Filter [CCV2]
Return

##########################################################################################################
$DO_CRS_PBLITM
Local Integer IPBLDEFINED

  #On commence d'abord par générer les compétences couvertes hors croisement.
  #COMPETENCE
  Filter [CCV2] Where [F:CCV2]CONNUM = SZCOTNUM and [F:CCV2]TPL = 2 and [F:CCV2]RECTYP = "PBL"
  For [CCV2]
    IPBLDEFINED = 0
    Filter [CCV] Where [F:CCV]CONNUM = SZCONNUM and [F:CCV]TPL = 1 and [F:CCV]RECTYP = "PBL" and [F:CCV]RECNUM = [F:CCV2]RECNUM
    For [CCV]
      IPBLDEFINED += 1
    Next
    Filter [CCV]
    If IPBLDEFINED = 0 Then
      Raz [F:CCV]
      [F:CCV] = [F:CCV2]
      [F:CCV]CONNUM = SZCONNUM
      [F:CCV]TPL = 1
      [F:CCV]BPC = SZBPC
      Write [CCV]
      If fstat Then
        #Erreur lors de la génération de la couverture article et compétences sur la base du modèle sélectionné.
        IERRINF = 346
        ICHAPTER = 182
        IBRETOUR = 0
        GOK = 0
        Break
      Endif
    Endif
  Next
  Filter [CCV2]
  If GOK < 1 Then
    Return
  Endif
  #COUVERTURE FINANCIERE COMPETENCE
  Filter [CCV2] Where [F:CCV2]CONNUM = SZCOTNUM
&                 and [F:CCV2]TPL = 2
&                 and [F:CCV2]RECTYP = "AAA"
&                 and [F:CCV2]PAEKEY(0) <> ""
&                 and [F:CCV2]PAEKEY(1) = ""
&                 and [F:CCV2]PAEKEY(2) = ""
  For [CCV2]
    IPBLDEFINED = 0
    Filter [CCV] Where [F:CCV]CONNUM = SZCONNUM
&                  and [F:CCV]TPL = 1
&                  and [F:CCV]RECTYP = "AAA"
&                  and [F:CCV]SBBRECTYP = [F:CCV2]SBBRECTYP
&                  and [F:CCV]RECNUM = [F:CCV2]RECNUM
&                  and [F:CCV]PAEKEY(0) = [F:CCV2]PAEKEY(0)
&                  and [F:CCV]PAEKEY(1) = [F:CCV2]PAEKEY(1)
&                  and [F:CCV]PAEKEY(2) = [F:CCV2]PAEKEY(2)
    For [CCV]
      IPBLDEFINED += 1
    Next
    Filter [CCV]
    If IPBLDEFINED = 0 Then
      Raz [F:CCV]
      [F:CCV] = [F:CCV2]
      [F:CCV]CONNUM = SZCONNUM
      [F:CCV]TPL = 1
      [F:CCV]BPC = SZBPC
      Write [CCV]
      If fstat Then
        #Erreur lors de la génération de la couverture article et compétences sur la base du modèle sélectionné.
        IERRINF = 346
        ICHAPTER = 182
        IBRETOUR = 0
        GOK = 0
        Break
      Endif
    Endif
  Next
  Filter [CCV2]
  If GOK < 1 Then
    Return
  Endif
  #COUVERTURE CROISEE
  Local File CONTCOV [CCV3]
  Filter [CCV3] Where [F:CCV3]CONNUM = SZCOTNUM and [F:CCV3]TPL = 2 and [F:CCV3]RECTYP = "PBL"
  For [CCV3]
    #Calcul le dernier RECNUM
    IRECNUM = 0
    Call CPTCOVNUM(SZCONNUM, 1, [F:CCV3]RECNUM, SZRECNUM, IRECNUM) From SUBMACB
    IITMLEVEL = 0
    #Couverture parc
    Filter [CCV2] Where [F:CCV2]CONNUM = SZCOTNUM
&                   and [F:CCV2]TPL = 2
&                   and [F:CCV2]RECTYP = "MAC"
&                   and [F:CCV2]SBBRECTYP = "ITM"
&                   and [F:CCV2]CMT = SZITMREF
&                   and [F:CCV2]PAEKEY(0) = [F:CCV3]RECNUM
    For [CCV2]
      IITMLEVEL += 1
      Raz [F:CCV]
      [F:CCV] = [F:CCV2]
      [F:CCV]CONNUM = SZCONNUM
      [F:CCV]TPL = 1
      [F:CCV]BPC = SZBPC
      [F:CCV]SBBRECTYP = "MAC"
      [F:CCV]RECNUM = num$(IRECNUM)
      [F:CCV]CMT = GSZMACNUMRULE
      [F:CCV]CPNSRT = "CMACMAC"
      SZCOTRECNUM = [F:CCV2]RECNUM
      Write [CCV]
      If fstat Then
        #Erreur lors de la génération de la couverture article et compétences sur la base du modèle sélectionné.
        IERRINF = 34
        ICHAPTER = 182
        IBRETOUR = 0
        GOK = 0
        Break
      Endif
      Break
    Next
    Filter [CCV2]
    If GOK < 1 Then
      Break
    Endif
    #S'il n'y a pas de couverture de niveau ref article, on switch sur une couverture de niveau famille commerciale
    If IITMLEVEL = 0 Then
      If SZITMFAMCIA <> "" Then
        Gosub DO_CRSCIA
        If GOK < 1 Then
          Break
        Endif
      Endif
    Else
      Gosub DO_CRSITM
      If GOK < 1 Then
        Break
      Endif
    Endif
  Next
  Filter [CCV3]
  Close Local File [CCV3]
Return

##########################################################################################################
$DO_CRSITM
  #Couverture composant
  Filter [CCV2] Where [F:CCV2]CONNUM = SZCOTNUM
&                 and [F:CCV2]TPL = 2
