    [F:CCV]BPC = SZBPC
    [F:CCV]CMT = GSZMACNUMRULE
    [F:CCV]CPNSRT = "CAAACPNMAC"
    [F:CCV]PAEKEY(1) = num$(IRECNUM)
    [F:CCV]PAEKEYTYP(1) = "MAC"
    Write [CCV]
    If fstat Then
      #Erreur lors de la génération de la couverture article et compétences sur la base du modèle sélectionné.
      IERRINF = 346
      ICHAPTER = 182
      IBRETOUR = 0
      GOK = 0
      Break
    Endif
  Next
  Filter [CCV2]
  If GOK < 1 Then
    Return
  Endif
  #Couverture financière d'un composant
  Filter [CCV2] Where [F:CCV2]CONNUM = SZCOTNUM
&                 and [F:CCV2]TPL = 2
&                 and [F:CCV2]RECTYP = "AAA"
&                 and [F:CCV2]CMT = SZITMREF
&                 and [F:CCV2]PAEKEY(0) = [F:CCV3]RECNUM
&                 and [F:CCV2]PAEKEY(1) = SZCOTRECNUM
&                 and [F:CCV2]PAEKEY(2) <> ""
&                 and [F:CCV2]PAEKEYTYP(1) = "ITM"
  For [CCV2]
    Raz [F:CCV]
    [F:CCV] = [F:CCV2]
    [F:CCV]CONNUM = SZCONNUM
    [F:CCV]TPL = 1
    [F:CCV]BPC = SZBPC
    [F:CCV]CMT = GSZMACNUMRULE
    [F:CCV]CPNSRT = "CAAACPNMAC"
    [F:CCV]PAEKEY(1) = num$(IRECNUM)
    [F:CCV]PAEKEYTYP(1) = "MAC"
    Write [CCV]
    If fstat Then
      #Erreur lors de la génération de la couverture article et compétences sur la base du modèle sélectionné.
      IERRINF = 346
      ICHAPTER = 182
      IBRETOUR = 0
      GOK = 0
      Break
    Endif
  Next
  Filter [CCV2]
Return

