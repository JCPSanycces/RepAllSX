##########################################################################################################
#     ENSEMBLE de sous-programmes utilitaires créés pour le CRM
##########################################################################################################
##########################################################################################################
#  GETDEFCNT  : Renvoie le contact par défaut d'un tiers
##########################################################################################################
##########################################################################################################
Funprog GETDEFCNT(SZBPRNUM)
Value Char SZBPRNUM

Local Char SZDEFCNT(GLONAIN)
Local Char SZBPRTYP(GLONDCO)
Local Char SZBPXAOB(GLONAOB)
Local Char SARENDRE(GLONAIN)

  Raz SARENDRE
  # ------------------------------------------
  If SZBPRNUM = "" Then
    End
  Endif
  # ------------------------------------------
  Local File BPARTNER [BPR]
  Local File CONTACT [CNT]
  # ------------------------------------------
  Read [BPR]BPR0=SZBPRNUM
  If fstat Then
    End
  Endif
  # ------------------------------------------
  Call GETBPRTYP(SZBPRNUM, SZBPRTYP, SZBPXAOB) From CRM_UTIL_SYRA
  # ------------------------------------------
  Case SZBPXAOB
    When "BPC", "BPP"
      Local File BPCUSTOMER [BPC]
      Read [BPC]BPC0=SZBPRNUM
      If !fstat Then
        SZDEFCNT = [F:BPC]CNTNAM
      Endif
    When "BPS"
      Local File BPSUPPLIER [BPS]
      Read [BPS]BPS0=SZBPRNUM
      If !fstat Then
        SZDEFCNT = [F:BPS]CNTNAM
      Endif
    When "BPT"
      Local File BPCARRIER [BPT]
      Read [BPT]BPT0=SZBPRNUM
      If !fstat Then
        SZDEFCNT = [F:BPT]CNTNAM
      Endif
    When "BPR", "REP"
      SZDEFCNT = [F:BPR]CNTNAM
    When Default
      Raz SARENDRE
  Endcase
  # ------------------------------------------
  If SZDEFCNT = "" Then
    # Si on ne l'a pas trouvé sur le tiers, on prend le premier des contacts
    Filter [CNT] Where [F:CNT]BPATYP = 1 and [F:CNT]BPANUM = SZBPRNUM Order By [F:CNT]CCNCRM Asc
    For [CNT]
      SARENDRE = [F:CNT]CCNCRM
      Break
    Next
    Filter [CNT]
  Else
    Read [CNT]CNT0=1;SZBPRNUM;SZDEFCNT
    If !fstat Then
      SARENDRE = SZDEFCNT
    Endif
  Endif
End SARENDRE

##########################################################################################################
# Reconstruit le com complet d'un interlocuteur
##########################################################################################################
Funprog BUILDFULNAM(CTX, SZCLASSF, SKEYREAD)
Value Instance CTX Using C_WMACONTEXT
Value Char SZCLASSF
Value Char SKEYREAD

Local Integer ICIV
Local Char SZCIV(50)
Local Char SZFNA(50)
Local Char SZLNA(50)
Local Char SZFULNAM(GLONNAM)
Local Integer IFMTFULNAM

  If SZCLASSF = "COR" Then
    Local File CORRESPOND [COR]
    Read [COR]COR0=SKEYREAD
    ICIV = [F:COR]TTL
    SZFNA = [F:COR]FNA
    SZLNA = [F:COR]LNA
  Else
    Local File CONTACTCRM [AIN]
    Read [AIN]AIN0=SKEYREAD
    ICIV = [F:AIN]CNTTTL
    SZFNA = [F:AIN]CNTFNA
    SZLNA = [F:AIN]CNTLNA
  Endif
  # ----------------------
  SZCIV = mess(ICIV,941,1)
  IFMTFULNAM = fmet CTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, CTX.AFOLDER, "FMTFULNAM")
  Case IFMTFULNAM
    When 1
      SZFULNAM = SZCIV - SZFNA - SZLNA
    When 2
      SZFULNAM = SZCIV - SZLNA - SZFNA
    When 3
      SZFULNAM = SZFNA - SZLNA - SZCIV
    When 4
      SZFULNAM = SZFNA - SZCIV - SZLNA
    When 5
      SZFULNAM = SZLNA - SZFNA - SZCIV
    When 6
      SZFULNAM = SZLNA - SZCIV - SZFNA
    When Default
      SZFULNAM = SZCIV - SZFNA - SZLNA
  Endcase
End SZFULNAM

##########################################################################################################
# Programme de renvoi du code par défaut d'une table diverse.
##########################################################################################################
Funprog DEFVALADI(CODETAB)
Value Integer CODETAB

  Local File ATABDIV [ADI]

Local Char PIODEF(type([F:ADI]CODE)-10)

  PIODEF = ""
  Filter [ADI] Where [F:ADI]NUMTAB = CODETAB Order By [F:ADI]CODE Asc
  For [ADI]
    If [F:ADI]DEFVAL = 2 Then
      PIODEF = [F:ADI]CODE
      Break
    Endif
  Next
  Filter [ADI]
End PIODEF

