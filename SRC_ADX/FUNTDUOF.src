#<AdxTL>@(#)8.0.0.0 $Revision$ Gestion du masque TDUOF1
#########################################################################
#                                                                       #
#    MODELISATION E-COMMERCE                                            #
#                                                                       #
# ACTION  : TRTTDUOF  : Action traitement de modification en série des  #
#           objectifs                                                   #
#                                                        10.02 MM       #
#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "INIT"       : Gosub INIT
 When "INIT_DIA"   : Gosub INIT_DIA
 When "TERMINE"    : Gosub TERMINE
 When Default
Endcase

#--- Actions liées à la fenêtre de saisie
Case ACTION
 When "SETBOUT"    : Gosub SETBOUT
 When "OUVRE"      : Gosub OUVRE
 When "DEBUT"      : Gosub DEBUT
 When "APRES_MODIF": Gosub APRES_MODIF
 When "ENR"        : Gosub ENREGISTRE
 When "ABA"        : Gosub ABORT
 When "FIN"        : Gosub FIN
 When Default
Endcase

#########################################################################
#    Actions liés au type traitement et affichage divers                #
#########################################################################

$INIT
Case GACTION
 When "TRTTDUOF"  : Gosub INI_TRTTDUOF
Endcase
Return

#########################################################################
$INI_TRTTDUOF
#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:MFG]) = 0 : Local File MFGHEAD    [MFG] : Endif
If clalev([F:ORD]) = 0 : Local File ORDERS     [ORD] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:MFI]) = 0 : Local File MFGITM     [MFI] : Endif
If clalev ([M:MFGK])= 0: Local Mask MFGK       [MFGK]: Endif

Return
#########################################################################
$INIT_DIA
Local Char    TIT(50) : TIT =mess(178,190,1)
Raz [M:DIA]
Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
[M:DIA]MFGFCY    = GFCY
Gosub CHARG_PARAM                 # mm 12.02

Return
#########################################################################
$TERMINE
TRA=1
Call FERME_TRACE From LECFIC

Return
#########################################################################
$SETBOUT
Raz ETABOU
ETABOU(GENRE) = 1
ETABOU(GABAN) = 1
ETABOU(GBFIN) = 1

Return
#########################################################################
$OUVRE
Local Char     CRITERE(255), CRITERE1(255),CRITERE2(255),CRITERE3(255)
Local Integer  WMAX : WMAX = 300
Local Integer  NBMODIF, I

Gosub SEL_OF

Return
#########################################################################
$SEL_OF
#--> critères de saisie
Raz CRITERE
Raz CRITERE1
Raz CRITERE2
Raz CRITERE3
CRITERE2="1=1"
CRITERE3="1=1"

If [M:DIA]WOFFLG = 2
   CRITERE  = "[F:MFG]MFGSTA=1"
   Gosub LOAD_CRITERE
Endif

If [M:DIA]WOPFLG = 2
    CRITERE  = "[F:MFG]MFGSTA=2"
    Gosub LOAD_CRITERE
Endif

# fin de la première partie
CRITERE1 += ")"

# case non cochée : on exclue les OF optimisés
If [M:DIA]OPTFLG =1
   CRITERE  = "[F:MFG]OPTFLG<>2"
   Gosub LOAD_CRITERE2
Endif

CRITERE ="([F:MFG]MFGTRKFLG=1|[F:MFG]MFGTRKFLG=3|[F:MFG]MFGTRKFLG=4)"    # on ignore les ordres soldés
Gosub LOAD_CRITERE2

CRITERE = "[F:MFG]SCDFLG<>1"                               # on ignore les ordres non jalonnés
Gosub LOAD_CRITERE2


CRITERE  = "[F:MFG]MFGFCY = [M:DIA]MFGFCY"     # site de production
Gosub LOAD_CRITERE2

If [M:DIA]MFGNUMDEB <> ""               # borne début OF
    CRITERE = "[F:MFG]MFGNUM >= [M:DIA]MFGNUMDEB"
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]MFGNUMFIN <> ""               # borne fin   OF
    CRITERE = "[F:MFG]MFGNUM <= [M:DIA]MFGNUMFIN"
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]PJTDEB <> ""                  # borne début affaire
    CRITERE = "[F:MFI]PJT >= [M:DIA]PJTDEB"
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]PJTFIN <> ""                  # borne fin   affaire
    CRITERE = "[F:MFI]PJT <= [M:DIA]PJTFIN"
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]BPCNUMDEB <> ""               # borne début destin.
    CRITERE = "[F:MFI]BPCNUM >= [M:DIA]BPCNUMDEB"
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]BPCNUMFIN <> ""               # borne fin   destin.
    CRITERE = "[F:MFI]BPCNUM <= [M:DIA]BPCNUMFIN"
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]VCRNUMDEB <> ""               # borne début pièce ori.
    CRITERE = "[F:MFI]VCRNUMORI >= [M:DIA]VCRNUMDEB"
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]VCRNUMFIN <> ""               # borne fin   pièce ori.
    CRITERE = "[F:MFI]VCRNUMORI <= [M:DIA]VCRNUMFIN"
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]ITMREFDEB <> ""               # borne début article lancé
    CRITERE = "[F:MFI]ITMREF >= [M:DIA]ITMREFDEB"
    Gosub LOAD_CRITERE3
Endif

If [M:DIA]ITMREFFIN <> ""               # borne fin   article lancé
    CRITERE = "[F:MFI]ITMREF <= [M:DIA]ITMREFFIN"
    Gosub LOAD_CRITERE3
Endif

If [M:DIA]STRDATDEB <> [0/0/0]          # borne début date
    CRITERE = "[F:MFG]STRDAT >= [M:DIA]STRDATDEB"
    Gosub LOAD_CRITERE3
Endif

If [M:DIA]STRDATFIN <> [0/0/0]          # borne fin   date
    CRITERE = "[F:MFG]STRDAT <= [M:DIA]STRDATFIN"
    Gosub LOAD_CRITERE3
Endif


Return

############################################################
$LOAD_CRITERE
If len(CRITERE1)=0
    CRITERE1 += "("
Else
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE
Return

############################################################
$LOAD_CRITERE2
If len(CRITERE)+len(CRITERE1)+1 < 225
  CRITERE1 += "&"
  CRITERE1 += CRITERE
Else
  If CRITERE2 <> ""
     CRITERE2 += "&"
  Endif
  CRITERE2 += CRITERE
Endif
Return

############################################################
$LOAD_CRITERE3
If CRITERE3 <> ""
  CRITERE3 += "&"
Endif
CRITERE3 += CRITERE
Return

############################################################
$DEBUT
Local Char    TIT(50) : TIT = mess(178,190,1)


Default File [MFG]
Default Mask [TOF2]
Gosub LIRE
If [M:TOF2]NBLIG=0
    GERR=2 : GMESSAGE=mess(177,190,1)
    FIN=1
Endif


Return
############################################################
$LIRE

REP=""
Raz [M]
nolign=0
If GTRACE = ""
    Call OUVRE_TRACE (TIT) From LECFIC
Endif


[M]MFGFCY = [M:DIA]MFGFCY
Call LECTURE("FCY",[M]MFGFCY,"") From CONTOBJ
[M]FCYDES = [F:FCY]FCYNAM
Link [MFG] With [F:MFI]MFI2 = [F:MFG]MFGNUM As [LIE]
&     Where evalue (CRITERE1) & evalue (CRITERE2) & evalue (CRITERE3) Order By Key MFG0

For [LIE]
  If find([F:MFG]MFGNUM, [M:TOF2]MFGNUM(0..[M:TOF2]NBLIG-1)): Goto NEXT_MFGNUM : Endif
  nolign+=1
  [M:TOF2]MFGNUM(nolign-1)     = [F:MFG]MFGNUM
  [M:TOF2]MFGSTA(nolign-1)     = [F:MFG]MFGSTA
  [M:TOF2]MFGTRKFLG(nolign-1)  = [F:MFG]MFGTRKFLG
  [M:TOF2]ROUNUM(nolign-1)     = [F:MFG]ROUNUM
  [M:TOF2]ROUALT(nolign-1)     = [F:MFG]ROUALT
  [M:TOF2]STU(nolign-1)        = [F:MFG]STU
  [M:TOF2]EXTQTY(nolign-1)     = [F:MFG]EXTQTY
  [M:TOF2]RMNEXTQTY(nolign-1)  = [F:MFG]RMNEXTQTY
  [M:TOF2]STRDAT(nolign-1)     = [F:MFG]STRDAT
  [M:TOF2]ENDDAT(nolign-1)     = [F:MFG]ENDDAT
  [M:TOF2]OBJDAT(nolign-1)     = [F:MFG]OBJDAT
  [M:TOF2]MFGPIO(nolign-1)     = [F:MFG]MFGPIO
  [M:TOF2]SCDFLG(nolign-1)     = [F:MFG]SCDFLG
  [M:TOF2]ALLSTA(nolign-1)     = [F:MFG]ALLSTA
  [M:TOF2]SCDMOD(nolign-1)     = [F:MFG]SCDMOD
  [M:TOF2]PJT(nolign-1)        = [F:MFI]PJT
  [M:TOF2]BPCNUM(nolign-1)    =  [F:MFI]BPCNUM
  [M:TOF2]VCRNUM(nolign-1)    =  [F:MFI]VCRNUMORI
  If ([M:TOF2]OBJDAT(nolign-1)<>[0/0/0]) & ([M:TOF2]ENDDAT(nolign-1)<>[0/0/0])
      [M:TOF2]AVRT(nolign-1)= ([M:TOF2]OBJDAT(nolign-1))- ([M:TOF2]ENDDAT(nolign-1))
  Endif
  [M:TOF2]NBLIG +=1
If nolign = WMAX : Break : Endif
$NEXT_MFGNUM
Next

Filter [LIE]
Gosub TRI_TAB

Affzo [M:TOF2]

Return

#########################################################################
$TRI_TAB
If [M:TOF2]NBLIG<>0
    Case [M:DIA]TRI
        When 1 : Sorta [M:TOF2]NBLIG [M:TOF2]NBLIG Order By [M:TOF2]STRDAT(indice),
&                                                           [M:TOF2]AVRT(indice)
        When 2 : Sorta [M:TOF2]NBLIG [M:TOF2]NBLIG Order By [M:TOF2]AVRT(indice),
&                                                           [M:TOF2]STRDAT(indice)
    Endcase
Endif
Return
#########################################################################
$APRES_MODIF
REP="M"
Gosub SETBOUT
Return
############################################################
$ENREGISTRE
Gosub MODIF
FIN=1
#GERR=2 : GMESSAGE=mess(363,197,1) # Issue 105127 GH 08/10/2018 - message not necessary
Return
############################################################
# Enregistrement des modifications
$MODIF
Call TEMPON("V") From GESECRAN

If GTRACE = ""
    Call OUVRE_TRACE (TIT) From LECFIC
Endif
Gosub MOD_OF
If !NBMODIF
    WMESS1=mess(371,197,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
Return : Endif
Call TEMPOFF From GESECRAN

Return
############################################################
$MOD_OF
Gosub MAJOF
If NBMODIF
    WMESS1=num$(NBMODIF)-mess(362,197,1)
    Call ECR_TRACE(WMESS1,0) From GESECRAN
Endif

Return
############################################################
$MAJOF
NBMODIF=0
# Issue 105127 GH 08/10/2018 - use I instead nolign for the loop
For I=0 To [M:TOF2]NBLIG-1
    Read [MFG]MFG0=[M:TOF2]MFGNUM(I)
    If fstat : Goto NEXTOF : Endif
    # pas la peine de modifier si rien n'a changé
    If [F:MFG]STRDAT = [M:TOF2]STRDAT(I)&
&      [F:MFG]ENDDAT = [M:TOF2]ENDDAT(I)&
&      [F:MFG]OBJDAT = [M:TOF2]OBJDAT(I)&
&      [F:MFG]MFGPIO = [M:TOF2]MFGPIO(I)
       Goto NEXTOF
    Endif
    Raz [M:MFGK]
    [M:MFGK]CODMAJ= "M"
    [M:MFGK]CODTRS=  3
    [M:MFGK]MFGNUM = [M:TOF2]MFGNUM(I)

    [M:MFGK]MFGSTA = [M:TOF2]MFGSTA(I)
    [M:MFGK]STRDAT = [M:TOF2]STRDAT(I)
    [M:MFGK]ENDDAT = [M:TOF2]ENDDAT(I)
    [M:MFGK]OBJDAT = [M:TOF2]OBJDAT(I)
    [M:MFGK]ITMREF = [M:TOF2]ROUNUM(I)
    [M:MFGK]ROUNUM = [M:TOF2]ROUNUM(I)
    [M:MFGK]ROUALT = [M:TOF2]ROUALT(I)
    [M:MFGK]MFGFCY = [M:TOF2]MFGFCY
    [M:MFGK]PIO    = [M:TOF2]MFGPIO(I)
    [M:MFGK]CODRET = 9                          # 08.03 19228
    [M:MFGK]AUTOTRT= 2  # Issue 105127 GH 08/10/2018 - avoid message displays about costs ...

    For [ORD]ORD3 Where STOFCY=[M:TOF2]MFGFCY & VCRTYP = 10 & VCRNUM = [M:TOF2]MFGNUM(I) & WIPTYP = 5
        [M:MFGK]MFGLIN = [F:ORD]VCRLIN
        [M:MFGK]BOMALT = [F:ORD]BOMALT
        [M:MFGK]EXTQTY = [F:ORD]EXTQTY

        Call MAJ_OF From MFGAUTLIB
    Next

    Call ECR_TRACE(mess(229,197,1),0) From GESECRAN
    Case [M:MFGK]MFGSTA
        When 1: MESS1 = mess(231,197,1)-[M:MFGK]MFGNUM-mess(232,197,1)
        When 2: MESS1 = mess(230,197,1)-[M:MFGK]MFGNUM-mess(232,197,1)
    Endcase
    Call ECR_TRACE(MESS1,0) From GESECRAN

    NBMODIF+= 1
$NEXTOF
Next I

Return
############################################################
$ABORT
Raz [M]
Affzo [M]
Gosub LIRE
Return

############################################################
$FIN
#-- Appel l'état "PRTSCR"
Call IMPSCR From ATRTX3
Return

########################################################################
# mm 12.02
$CHARG_PARAM
#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return

#######################################################################
#                     ACTIONS CHAMPS                                  #
#######################################################################

########################################
Subprog AM_MFGNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <>"" : [M:DIA]MFGNUMFIN = VALEUR : Endif
End

########################################
Subprog AM_PJTDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <>"" : [M:DIA]PJTFIN = VALEUR : Endif
End

########################################
Subprog AM_BPCNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]BPCNUMFIN = VALEUR : Endif
End

########################################
Subprog AM_VCRNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]VCRNUMFIN = VALEUR : Endif
End

########################################
Subprog AM_ITMREFDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]ITMREFFIN = VALEUR : Endif
End

########################################
Subprog C_STRDATFIN(VALEUR)
Variable Date    VALEUR
If VALEUR < [M:DIA]STRDATDEB : mkstat= 2 : Endif
End
########################################
Subprog S_MFGNUMDEB(VALEUR)
Variable Char    VALEUR()
Local    Integer WTYP,WSTA(4)
Local    Integer I : I = 0
Local    Char    WWIP
Local    Char    WITM
Local    Char    WVCR : WVCR = VALEUR

Raz WSTA
If [M:DIA]WOPFLG = 2
    WSTA(I) = 2
    I += 1
Endif
If [M:DIA]WOFFLG = 2
    WSTA(I) = 1
    I += 1
Endif
WITM = ""
WTYP = 5
Call SELVCR(WTYP, [M:DIA]MFGFCY, WSTA, WITM, WWIP, WVCR, "","") From MFGLIB
If WWIP <> ""
    Read [F:ORD]ORD0=WTYP;WWIP;WITM
    If fstat : mkstat = 2 : End : Endif
    VALEUR = [F:ORD]VCRNUM
Else
    mkstat = 2
Endif

End

########################################
Subprog S_MFGNUMFIN(VALEUR)
Variable Char    VALEUR()
Local    Integer WTYP,WSTA(4)
Local    Integer I : I = 0
Local    Char    WWIP
Local    Char    WITM
Local    Char    WVCR : WVCR = VALEUR

Raz WSTA
If [M:DIA]WOPFLG = 2
    WSTA(I) = 2
    I += 1
Endif
If [M:DIA]WOFFLG = 2
    WSTA(I) = 1
    I += 1
Endif
WITM = ""
WTYP = 5
Call SELVCR(WTYP, [M:DIA]MFGFCY, WSTA, WITM, WWIP, WVCR, "","") From MFGLIB
If WWIP <> ""
    Read [F:ORD]ORD0=WTYP;WWIP;WITM
    If fstat : mkstat = 2 : End : Endif
    VALEUR = [F:ORD]VCRNUM
Else
    mkstat = 2
Endif

End

########################################
Subprog S_VCRNUMDEB(VALEUR)
Variable Char    VALEUR()
Local    Integer WTYP,WSTA(4)
Local    Integer I : I = 0
Local    Char    WWIP
Local    Char    WITM
Local    Char    WVCR : WVCR = VALEUR
Raz WSTA
WSTA(I) = 1
WITM = ""
WTYP = 1
Call SELVCR(WTYP, [M:DIA]MFGFCY, WSTA, WITM, WWIP, WVCR, "","") From MFGLIB
If WWIP <> ""
    Read [F:ORD]ORD0=WTYP;WWIP;WITM
    If fstat : mkstat = 2 : End : Endif
    VALEUR = [F:ORD]VCRNUM
Else
    mkstat = 2
Endif

End

########################################
Subprog S_VCRNUMFIN(VALEUR)
Variable Char    VALEUR()
Local    Integer WTYP,WSTA(4)
Local    Integer I : I = 0
Local    Char    WWIP(GLONVCR)
Local    Char    WITM(GLONITM)
Local    Char    WVCR(GLONVCR) : WVCR = VALEUR

Raz WSTA
WSTA(I) = 1
WITM = ""
WTYP = 1
Call SELVCR(WTYP, [M:DIA]MFGFCY, WSTA, WITM, WWIP, WVCR, "","") From MFGLIB
If WWIP <> ""
    Read [F:ORD]ORD0=WTYP;WWIP;WITM
    If fstat : mkstat = 2 : End : Endif
    VALEUR = [F:ORD]VCRNUM
Else
    mkstat = 2
Endif

End


########################################
Subprog C_WOPFLG(VALEUR)
Variable Integer VALEUR
If [M:DIA]WOFFLG = 1 & VALEUR = 1
    mkstat = 2  # une case au moins doit être cochée !
Endif

End

########################################
Subprog IB_NBLIG
GBOUT1= mess(336,198,1)    # Gestion OF
GBOUT2= mess(119,195,1)    # Plan de travail
End

########################################
Subprog B1_NBLIG
Local Char    WNUM(GLONVCR)
WNUM=[M:TOF2]MFGNUM(nolign-1)
Call OBJET("MFG",WNUM,"") From GOBJET
End

########################################
Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
Local    Date    WORIDAT
Local    Char    WORIFCY
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WQTY
Local    Decimal WRMD
Local    Date    WENDDAT

WENDDAT = [M:TOF2]ENDDAT(nolign-1)

# cas du jalonnement AMONT
If [M:TOF2]SCDMOD(nolign-1) =1 &  VALEUR > [M:TOF2]ENDDAT(nolign-1) : mkstat =2 : End : Endif

# antériorité par rapport à la date du jour ?
Call CHECK_PAST(VALEUR, 2)  From MFGLIB

If [M:TOF2]SCDMOD(nolign-1) =1 : End : Endif

# recalcul date fin
Call TEMPON(mess(81,195,1)) From GESECRAN

WORIDAT=VALEUR
WORIFCY=[M:TOF2]MFGFCY
WLTI=0

# lecture article site
Read [ITF]ITF0=[M:TOF2]ROUNUM(nolign-1);[M:TOF2]MFGFCY
If fstat : End : Endif
WQTY = [M:TOF2]EXTQTY(nolign-1)
Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD <> 0 : ILTI += 1 : Endif
WLTI=ILTI

# révision calendriers (llc 06.00)
Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, [M:TOF2]ENDDAT(nolign-1)) From MFGLIB

Call TEMPOFF From GESECRAN
Affzo [M:TOF2]ENDDAT(nolign-1)

# Si date fin change, on modifie A/R
If WENDDAT <> [M:TOF2]ENDDAT(nolign-1)
 If ([M:TOF2]OBJDAT(nolign-1)<>[0/0/0])
    [M:TOF2]AVRT(nolign-1) = [M:TOF2]OBJDAT(nolign-1)-[M:TOF2]ENDDAT(nolign-1)
    Affzo [M:TOF2]AVRT(nolign-1)
 Endif
Endif

End


########################################
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : mkstat=2 : End : Endif

# révision calendriers
Call CONTROL_DATE_PLN(VALEUR, [M:TOF2]MFGFCY) From MFGLIB

End

########################################
Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR
Local    Date    WORIDAT
Local    Char    WORIFCY
Local    Decimal XLTI
Local    Integer ILTI
Local    Decimal WQTY
Local    Decimal WRMD

If [M:TOF2]SCDMOD(nolign-1)=2 & VALEUR < [M:TOF2]STRDAT(nolign-1) : mkstat = 2 : End : Endif

Call CHECK_PAST(VALEUR, 2) From MFGLIB
If [M:TOF2]SCDMOD(nolign-1)= 2 : End : Endif
# recalcul date debut
Call TEMPON(mess(81,195,1)) From GESECRAN

WORIDAT=VALEUR
WORIFCY=[M:TOF2]MFGFCY
WLTI=0

# lecture article site
Read [ITF]ITF0=[M:TOF2]ROUNUM(nolign-1);[M:TOF2]MFGFCY
If fstat : End : Endif
WQTY = [M:TOF2]EXTQTY(nolign-1)
Call CALCUL_DELAI([F:ITF]MFGLTI, WQTY, XLTI) From MFGLIB
ILTI    = int(XLTI)
WRMD    = XLTI - ILTI
If WRMD <> 0 : ILTI += 1 : Endif
WLTI=ILTI

# révision calendriers
Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 1, [M:TOF2]STRDAT(nolign-1)) From MFGLIB

Call TEMPOFF From GESECRAN

Affzo [M:TOF2]STRDAT(nolign-1)
Call CHECK_PAST([M:TOF2]STRDAT(nolign-1), 2) From MFGLIB

End

########################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : mkstat=2 : End : Endif

# révision calendriers
Call CONTROL_DATE_PLN(VALEUR, [M:TOF2]MFGFCY) From MFGLIB
If mkstat : End : Endif

#quand date fin change, on modifie A/R
If VALEUR <> [M:TOF2]ENDDAT(nolign-1)
 If ([M:TOF2]OBJDAT(nolign-1)<>[0/0/0])
    [M:TOF2]AVRT(nolign-1) = [M:TOF2]OBJDAT(nolign-1)-VALEUR
    Affzo [M:TOF2]AVRT(nolign-1)
 Endif
Endif

End

########################################
Subprog AM_OBJDAT(VALEUR)
Variable Date    VALEUR
#Si date objectif change, on modifie A/R
If (VALEUR <> [M:TOF2]OBJDAT(nolign-1)) &  (VALEUR <>[0/0/0])
 If ([M:TOF2]ENDDAT(nolign-1)<>[0/0/0])
    [M:TOF2]AVRT(nolign-1) = VALEUR -[M:TOF2]ENDDAT(nolign-1)
    Affzo [M:TOF2]AVRT(nolign-1)
 Endif
Endif
End

########################################
# mm 12.02
Subprog AM_MFGFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> GFCY
    GFCY=VALEUR
    Gosub CHARG_PARAM
Endif
End

