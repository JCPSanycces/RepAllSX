#<AdxTL>@(#)%I%
# Supervisor
# Inquiry CAA

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "08:11:00"
A_USER  = "ADMIN"
A_STAMP = "20181109081100"
Return

$DEFAUT
Return

$OUVFIC
Return

$NOMFIC
Local Char    TIT(GLONDES) , TITT(GLONDES)
Local Char    PROGSTD(GLONADC) , PROGSPE(GLONADC)
Local Char    ABMSK(GLONABR)(16) , NOMMSK(GLONAMK)(16) , CABMSK(GLONABR) , CNOMMSK(GLONAMK)
Local Char    BOITE(GLONFEN) , CBOITE(GLONFEN)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , OBJDERLU(GLONAOB)
Local Char    CODMSKDEF(GLONAMK) , CMEMO(GLONAMM)
Local Libelle MAGNETO
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA)
Call TEXTE(57009,TITT) From OBJDIV
TIT        = mess(15,126,1)
If dim(CNSCOD)>0 : TIT -= CNSCOD : Endif
PROGSTD    = "CNSCAASTD"
PROGSPE    = "CNSCAASPE"
BOITE      = "FCNSCAA"
NOMMSK(0)  = "CNSCAA0"
ABMSK(0)   = "CRI"
NOMMSK(1)  = "CNSCAAD"
ABMSK(1)   = "RES"
MAGNETO    = 1
Return

$SETCLE
Local Char    CLE(10), CLECMP(10)(0..0), CLEMSK(10)(0..0)
Local Integer NBCMP
Local Char    FILTRE(250)
CLE = ""
NBCMP = 0
CLECMP = "" : CLEMSK = ""
Return

$OUVRE
If clalev([F:HAE])=0 : Local File GACCENTRY    [HAE] : Endif
If clalev([F:DAE])=0 : Local File GACCENTRYD   [DAE] : Endif
If clalev([F:FCY])=0 : Local File FACILITY     [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY      [CPY] : Endif
If clalev([F:TCU])=0 : Local File TABCUR       [TCU] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT     [GAC] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER     [BPR] : Endif
Return

$OUVRE_MSK
Case MA
 When  0 : Local Mask =NOMMSK(0) [CRI]
 When  1 : Local Mask =NOMMSK(1) [RES]
Endcase
Return

$GRISE_MSK
Case MA
 When  0 : Grizo [CRI]
 When  1 : Grizo [RES]
Endcase
Return

$GRISE_CLE
Return

$GRISE_CRIT
Return

$FERME_MSK
Case MA
 When  0 : If clalev([M:CRI])>0 : Close Local Mask [CRI] : Endif
 When  1 : If clalev([M:RES])>0 : Close Local Mask [RES] : Endif
Endcase
Return

$SETMASK
Case MA
 When  0 : Default Mask [CRI]
 When  1 : Default Mask [RES]
Endcase
Return

$RAZMASK
Case MA
 When  0 : Raz [M:CRI]
 When  1 : Raz [M:RES]
Endcase
Return

$CRITENT
Return

$ENTCRIT
Return

$CRITAFF
Local Integer NBCA
Local Char    CRITAFF(10)(1..1) , CRITAFF2(10)(1..1)
NBCA = 0
Return

$STYLEPLAG
Return

Subprog GETACT(NOL,TITBOUT,VALBOUT)
Value Integer NOL
Variable Char TITBOUT()(1..) , VALBOUT()(1..)
Local Integer ONOL , NBBOUT
ONOL   = nolign
nolign = NOL
indice = max(0,nolign-1)
Call AS_NBLIG From ="W1CNSCAAD"
NBBOUT = 0
If GBOUT1<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT1
 VALBOUT(NBBOUT) = "CAA"
 VALBOUT(NBBOUT) += "~B1"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans(GBIDC2,"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans(GBIDC1,"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans(GBIDC3,"~","¨")
 Onerrgo
Endif
If GBOUT2<>""
 NBBOUT += 1
 TITBOUT(NBBOUT) = GBOUT2
 VALBOUT(NBBOUT) = "CAA"
 VALBOUT(NBBOUT) += "~B2"
 VALBOUT(NBBOUT) += "~"+num$(nolign)
 Onerrgo RIEN
 VALBOUT(NBBOUT) += "~"+ctrans([M:RES]ACC(nolign-1),"~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans("GAC","~","¨")
 VALBOUT(NBBOUT) += "~"+ctrans([M:RES]COA(nolign-1),"~","¨")
 Onerrgo
Endif
nolign = ONOL
indice = max(0,nolign-1)
End

Subprog ACTRUN(INFO)
Value Char INFO
Local Char    BOUT(3)
Local Integer ONOL
ONOL    = nolign
BOUT    = func AFNC.PART(INFO,1)
nolign  = val(func AFNC.PART(INFO,2))
indice  = max(0,nolign-1)
Gosub NOMFIC
For MA=0 to dim(NOMMSK)-1
 Gosub OUVRE_MSK
Next MA
For MA=0 to dim(NOMMSK)-1
 Gosub SETMASK
Next MA
Case BOUT
 When "B1"
  Onerrgo RIEN
  Assign "GBIDC2" With ctrans(func AFNC.PART(INFO,3),"¨","~")
  Assign "GBIDC1" With ctrans(func AFNC.PART(INFO,4),"¨","~")
  Assign "GBIDC3" With ctrans(func AFNC.PART(INFO,5),"¨","~")
  Onerrgo
  Call B1_NBLIG From ="W1CNSCAAD"
 When "B2"
  Onerrgo RIEN
  Assign "[M:RES]ACC(nolign-1)" With ctrans(func AFNC.PART(INFO,3),"¨","~")
  Assign "[M:RES]COA(nolign-1)" With ctrans(func AFNC.PART(INFO,5),"¨","~")
  Onerrgo
  Call B2_NBLIG From ="W1CNSCAAD"
Endcase
nolign = ONOL
indice = max(0,nolign-1)
End

$RIEN
Resume


