#<AdxTL>@(#)5.0.0.0 $Revision$
Local Char    VALEUR(30), PARAM(250)(1..20)
GABREV = "AMK"
PARAM(1) = GABREV
Call SAISIE_CHAR(VALEUR,PARAM,"AOBJTXT2","SELOBJTXT","XWGOBJTXT") From GSAISIE
End

#-------------------------------------------------------------------------------------------------------#
$ACTION
Case ACTION
 When "SEL_TABLE"
  Case TABLE
   When "SELTXTMOT"  : Gosub SELTXTMOT : # Sélection pièces jointes d'après un mot-clé (action SELTXTMOT) 
   When "SELTXTMOD"  : Gosub SELTXTMOD : # Sélection fichiers (rtf/txt) d'après un modèle (action SELTXTMOD)
  Endcase
 When "VERF_TABLE"
  Case TABLE
   When "SELTXTMOT"  : Gosub VERFTXTMOT
   When "SELTXTMOD"  : Gosub VERFTXTMOD
  Endcase
 When "SEL_LISTE"
  Case LISTE
   When "SELMOTCLE"  : Gosub SELMOTCLE : # Sélection des mot-clés existants (action SELMOTCLE)
  Endcase
 When Default
  If dim(BOITE)>0
   Case BOITE
    When "AOBJTXTA" : Gosub ACT_SAIMOT : # Sélection pièces jointes d'après un mot-clé (action SAITXTMOT)
    When "AOBJTXTB" : Gosub ACT_SAIMOD : # Sélection fichiers (rtf/txt) d'après un modèle (action SAITXTMOD)
    When "AOBJTXT2" : Gosub ACT_SELTXT : # Sélection d'un objet d'après un mot-clé (Menu barre Sélection)
   Endcase
  Endif
Endcase
Return

#----------------------------------------------------------------------------------------------------#
# Recherche d'un objet par mot clé
#----------------------------------------------------------------------------------------------------#

$ACT_SELTXT
Case ACTION
 When "OUVRE"     : Gosub OUVRE_SELTXT
 When "DEBUT"     : Gosub DEBUT_SELTXT
 When "OK"        : Gosub OK_SELTXT
 When "FIN"       : Gosub FIN_SELTXT
Endcase
Return

#---------------------------------------#
$OUVRE_SELTXT
Local Char    ABREV(GLONAOB), CRITERE(250), FILTSUP(250)
Local Integer OK, K, L, SAVMXL
Local Char    CLE_JOI(250), CLE2_JOI(250), CRIT_JOI(250), INTERM(10)
Local Char    PROGOBJ(GLONADC)

If PARAM(1)=""
 FIN = 1 : Return
Else
 ABREV = PARAM(1)
Endif
If PARAM(2)<>""
 CRITERE = PARAM(2)
Else
 CRITERE = "1=1"
Endif
If PARAM(3)<>""
 FILTSUP = PARAM(3)
Else
 FILTSUP = "1=1"
Endif
OK = 1

PROGOBJ = "WO"+ABREV
Gosub NOMFIC From =PROGOBJ

If evalue("clalev([F:"+ABFIC+"])") = 0
 Gosub OUVFIC From =PROGOBJ
Endif
If clalev([F:AOX])=0 : Local File AOBJTXT  [AOX] : Endif  
If clalev([F:AOM])=0 : Local File AOBJTXTA [AOM] : Endif  

Return

#---------------------------------------#
$DEBUT_SELTXT
Raz [M:DIA]
[M:DIA]ALLTYP=2
Return

#---------------------------------------#
$FIN_SELTXT
PARAM(4) = num$(OK)
Return

#---------------------------------------#
$OK_SELTXT
Gosub OUVRE_JOIN From =PROGOBJ
Gosub SETCLE     From =PROGOBJ
Gosub DEFAUT     From =PROGOBJ
Gosub CRIT_JOIN

Filter [F] Where evalue(CRITERE)

NBCLE=1    
For I=0 To dim(CLESEC)-1
 If CLESEC(I)<>""
  NBCLE += 1
 Else
  Break
 Endif
Next I
 
Assign "[G:"+ABFIC+"]currind" With 1 
If TYPGES=3 : Assign "[G:"+ABFIC+"]currlen" With dim(CLESEC) : Endif
K = 0
For [AOX] Where evalue(CRIT_JOI)
 NB = 1
 CLE2_JOI = [F:AOX]IDENT1
 Gosub MAJ
 CLE_JOI = [F:AOX]IDENT2
 While CLE_JOI<>"" & NB<NBCLE
  NB += 1
  L = instr(1,CLE_JOI,"~")
  If L
   CLE2_JOI = left$(CLE_JOI,L-1)
   CLE_JOI = right$(CLE_JOI,L+1)
   Gosub MAJ
  Else
   CLE2_JOI = CLE_JOI
   CLE_JOI = ""
   Gosub MAJ
  Endif
 Wend
 Read [F]=
 If !fstat
  K += 1
  Gosub MAJ2
  If K=GNBSEL : Break : Endif
 Endif
Next
Filter [F]

## Affichage du résultat
If !K 
 Call MESSAGE(mess(99,100,1)) From GESECRAN 
 OK = 0 : Return
Endif

## La VTB est classée sur tout les éléments du tableau
For I=K+1 To GNBSEL
 Case type(A_BUFJ1(I))
  When 1         : A_BUFJ1(I) = 255
  When 2         : A_BUFJ1(I) = 32767
  When 3         : A_BUFJ1(I) = "29991231"
  When 4,5,6,8,9 : A_BUFJ1(I) = 9*10^8
  When 7         : A_BUFJ1(I) = 9*10^79
  When Default   : A_BUFJ1(I) = chr$(255)
 Endcase
 If NBCLE>1
  Case type(A_BUFJ2(I))
   When 1         : A_BUFJ2(I) = 255
   When 2         : A_BUFJ2(I) = 32767
   When 3         : A_BUFJ2(I) = "29991231"
   When 4,5,6,8,9 : A_BUFJ2(I) = 9*10^8
   When 7         : A_BUFJ2(I) = 9*10^79
   When Default   : A_BUFJ2(I) = chr$(255)
  Endcase
 Endif
Next I

SAVMXL = adxmxl
adxmxl = K
Gosub TIT_JOIN From =PROGOBJ
Case dim(TITJOI)
 When 1
  Choose [PCEJ] Order With ORDRE_JOI Using
& A_TABJ1 Titled TITJOI(1)
& Sized(80,240) Titled mess(8,31,1)
 When 2
  Choose [PCEJ] Order With ORDRE_JOI Using
& A_TABJ1 Titled TITJOI(1), A_TABJ2 Titled TITJOI(2)
& Sized(80,240) Titled mess(8,31,1)
 When 3
  Choose [PCEJ] Order With ORDRE_JOI Using
& A_TABJ1 Titled TITJOI(1), A_TABJ2 Titled TITJOI(2), A_TABJ3 Titled TITJOI(3)
& Sized(80,240) Titled mess(8,31,1)
 When 4
  Choose [PCEJ] Order With ORDRE_JOI Using
& A_TABJ1 Titled TITJOI(1), A_TABJ2 Titled TITJOI(2), A_TABJ3 Titled TITJOI(3), A_TABJ4 Titled TITJOI(4)
& Sized(80,240) Titled mess(8,31,1)
 When 5
  Choose [PCEJ] Order With ORDRE_JOI Using
& A_TABJ1 Titled TITJOI(1), A_TABJ2 Titled TITJOI(2), A_TABJ3 Titled TITJOI(3), A_TABJ4 Titled TITJOI(4)
& , A_TABJ5 Titled TITJOI(5)
& Sized(80,240) Titled mess(8,31,1)
 When 6
  Choose [PCEJ] Order With ORDRE_JOI Using
& A_TABJ1 Titled TITJOI(1), A_TABJ2 Titled TITJOI(2), A_TABJ3 Titled TITJOI(3), A_TABJ4 Titled TITJOI(4)
& , A_TABJ5 Titled TITJOI(5), A_TABJ6 Titled TITJOI(6)
& Sized(80,240) Titled mess(8,31,1)
 When 7
  Choose [PCEJ] Order With ORDRE_JOI Using
& A_TABJ1 Titled TITJOI(1), A_TABJ2 Titled TITJOI(2), A_TABJ3 Titled TITJOI(3), A_TABJ4 Titled TITJOI(4)
& , A_TABJ5 Titled TITJOI(5), A_TABJ6 Titled TITJOI(6), A_TABJ7 Titled TITJOI(7)
& Sized(80,240) Titled mess(8,31,1)
 When 8
  Choose [PCEJ] Order With ORDRE_JOI Using
& A_TABJ1 Titled TITJOI(1), A_TABJ2 Titled TITJOI(2), A_TABJ3 Titled TITJOI(3), A_TABJ4 Titled TITJOI(4)
& , A_TABJ5 Titled TITJOI(5), A_TABJ6 Titled TITJOI(6), A_TABJ7 Titled TITJOI(7), A_TABJ8 Titled TITJOI(8)
& Sized(80,240) Titled mess(8,31,1)
 When 9
  Choose [PCEJ] Order With ORDRE_JOI Using
& A_TABJ1 Titled TITJOI(1), A_TABJ2 Titled TITJOI(2), A_TABJ3 Titled TITJOI(3), A_TABJ4 Titled TITJOI(4)
& , A_TABJ5 Titled TITJOI(5), A_TABJ6 Titled TITJOI(6), A_TABJ7 Titled TITJOI(7), A_TABJ8 Titled TITJOI(8)
& , A_TABJ9 Titled TITJOI(9)
& Sized(80,240) Titled mess(8,31,1)
 When 10
  Choose [PCEJ] Order With ORDRE_JOI Using
& A_TABJ1 Titled TITJOI(1), A_TABJ2 Titled TITJOI(2), A_TABJ3 Titled TITJOI(3), A_TABJ4 Titled TITJOI(4)
& , A_TABJ5 Titled TITJOI(5), A_TABJ6 Titled TITJOI(6), A_TABJ7 Titled TITJOI(7), A_TABJ8 Titled TITJOI(8)
& , A_TABJ9 Titled TITJOI(9), A_TABJ10 Titled TITJOI(10)
& Sized(80,240) Titled mess(8,31,1)
 When 11
  Choose [PCEJ] Order With ORDRE_JOI Using
& A_TABJ1 Titled TITJOI(1), A_TABJ2 Titled TITJOI(2), A_TABJ3 Titled TITJOI(3), A_TABJ4 Titled TITJOI(4)
& , A_TABJ5 Titled TITJOI(5), A_TABJ6 Titled TITJOI(6), A_TABJ7 Titled TITJOI(7), A_TABJ8 Titled TITJOI(8)
& , A_TABJ9 Titled TITJOI(9), A_TABJ10 Titled TITJOI(10), A_TABJ11 Titled TITJOI(11)
& Sized(80,240) Titled mess(8,31,1)
 When 12
  Choose [PCEJ] Order With ORDRE_JOI Using
& A_TABJ1 Titled TITJOI(1), A_TABJ2 Titled TITJOI(2), A_TABJ3 Titled TITJOI(3), A_TABJ4 Titled TITJOI(4)
& , A_TABJ5 Titled TITJOI(5), A_TABJ6 Titled TITJOI(6), A_TABJ7 Titled TITJOI(7), A_TABJ8 Titled TITJOI(8)
& , A_TABJ9 Titled TITJOI(9), A_TABJ10 Titled TITJOI(10), A_TABJ11 Titled TITJOI(11)
& , A_TABJ12 Titled TITJOI(12)
& Sized(80,240) Titled mess(8,31,1)
 When 13
  Choose [PCEJ] Order With ORDRE_JOI Using
& A_TABJ1 Titled TITJOI(1), A_TABJ2 Titled TITJOI(2), A_TABJ3 Titled TITJOI(3), A_TABJ4 Titled TITJOI(4)
& , A_TABJ5 Titled TITJOI(5), A_TABJ6 Titled TITJOI(6), A_TABJ7 Titled TITJOI(7), A_TABJ8 Titled TITJOI(8)
& , A_TABJ9 Titled TITJOI(9), A_TABJ10 Titled TITJOI(10), A_TABJ11 Titled TITJOI(11)
& , A_TABJ12 Titled TITJOI(12), A_TABJ13 Titled TITJOI(13)
& Sized(80,240) Titled mess(8,31,1)
 When 14
  Choose [PCEJ] Order With ORDRE_JOI Using
& A_TABJ1 Titled TITJOI(1), A_TABJ2 Titled TITJOI(2), A_TABJ3 Titled TITJOI(3), A_TABJ4 Titled TITJOI(4)
& , A_TABJ5 Titled TITJOI(5), A_TABJ6 Titled TITJOI(6), A_TABJ7 Titled TITJOI(7), A_TABJ8 Titled TITJOI(8)
& , A_TABJ9 Titled TITJOI(9), A_TABJ10 Titled TITJOI(10), A_TABJ11 Titled TITJOI(11)
& , A_TABJ12 Titled TITJOI(12), A_TABJ13 Titled TITJOI(13), A_TABJ14 Titled TITJOI(14)
& Sized(80,240) Titled mess(8,31,1)
 When 15
  Choose [PCEJ] Order With ORDRE_JOI Using
& A_TABJ1 Titled TITJOI(1), A_TABJ2 Titled TITJOI(2), A_TABJ3 Titled TITJOI(3), A_TABJ4 Titled TITJOI(4)
& , A_TABJ5 Titled TITJOI(5), A_TABJ6 Titled TITJOI(6), A_TABJ7 Titled TITJOI(7), A_TABJ8 Titled TITJOI(8)
& , A_TABJ9 Titled TITJOI(9), A_TABJ10 Titled TITJOI(10), A_TABJ11 Titled TITJOI(11)
& , A_TABJ12 Titled TITJOI(12), A_TABJ13 Titled TITJOI(13), A_TABJ14 Titled TITJOI(14)
& , A_TABJ15 Titled TITJOI(15)
& Sized(80,240) Titled mess(8,31,1)
 When 16
  Choose [PCEJ] Order With ORDRE_JOI Using
& A_TABJ1 Titled TITJOI(1), A_TABJ2 Titled TITJOI(2), A_TABJ3 Titled TITJOI(3), A_TABJ4 Titled TITJOI(4)
& , A_TABJ5 Titled TITJOI(5), A_TABJ6 Titled TITJOI(6), A_TABJ7 Titled TITJOI(7), A_TABJ8 Titled TITJOI(8)
& , A_TABJ9 Titled TITJOI(9), A_TABJ10 Titled TITJOI(10), A_TABJ11 Titled TITJOI(11)
& , A_TABJ12 Titled TITJOI(12), A_TABJ13 Titled TITJOI(13), A_TABJ14 Titled TITJOI(14)
& , A_TABJ15 Titled TITJOI(15), A_TABJ16 Titled TITJOI(16)
& Sized(80,240) Titled mess(8,31,1)
 When 17
  Choose [PCEJ] Order With ORDRE_JOI Using
& A_TABJ1 Titled TITJOI(1), A_TABJ2 Titled TITJOI(2), A_TABJ3 Titled TITJOI(3), A_TABJ4 Titled TITJOI(4)
& , A_TABJ5 Titled TITJOI(5), A_TABJ6 Titled TITJOI(6), A_TABJ7 Titled TITJOI(7), A_TABJ8 Titled TITJOI(8)
& , A_TABJ9 Titled TITJOI(9), A_TABJ10 Titled TITJOI(10), A_TABJ11 Titled TITJOI(11)
& , A_TABJ12 Titled TITJOI(12), A_TABJ13 Titled TITJOI(13), A_TABJ14 Titled TITJOI(14)
& , A_TABJ15 Titled TITJOI(15), A_TABJ16 Titled TITJOI(16), A_TABJ17 Titled TITJOI(17)
& Sized(80,240) Titled mess(8,31,1)
 When Default
  Choose [PCEJ] Order With ORDRE_JOI Using
& A_TABJ1 Titled TITJOI(1), A_TABJ2 Titled TITJOI(2), A_TABJ3 Titled TITJOI(3), A_TABJ4 Titled TITJOI(4)
& , A_TABJ5 Titled TITJOI(5), A_TABJ6 Titled TITJOI(6), A_TABJ7 Titled TITJOI(7), A_TABJ8 Titled TITJOI(8)
& , A_TABJ9 Titled TITJOI(9), A_TABJ10 Titled TITJOI(10), A_TABJ11 Titled TITJOI(11)
& , A_TABJ12 Titled TITJOI(12), A_TABJ13 Titled TITJOI(13), A_TABJ14 Titled TITJOI(14)
& , A_TABJ15 Titled TITJOI(15), A_TABJ16 Titled TITJOI(16), A_TABJ17 Titled TITJOI(17)
& , A_TABJ18 Titled TITJOI(18)
& Sized(80,240) Titled mess(8,31,1)
Endcase
adxmxl = SAVMXL

## récupération de la sélection
If status<>0 & status<>7      
 If NBCLE=1
  Assign "[F:"+ABFIC+"]"+CLEPRIM With evalue("[F:PCEJ]A_TABJ1")
 Else 
  Assign "[F:"+ABFIC+"]"+CLEPRIM With evalue("[F:PCEJ]A_TABJ2")
  Assign "[F:"+ABFIC+"]"+CLESEC(0) With evalue("[F:PCEJ]A_TABJ1")
  For I=1 To NBCLE-2
   Assign "[F:"+ABFIC+"]"+CLESEC(I) With evalue("[F:PCEJ]A_TABJ"+num$(2+I))
  Next
 Endif
 OK = 1
Else
 OK = 0
Endif
Return

#---------------------------------------#
$CRIT_JOIN
Raz CRIT_JOI
CRIT_JOI = "[F:AOX]ABREV="+'"'+ABREV+'"'
CRIT_JOI +="& find([M:DIA]MOTCLE2,[F:AOX]MOTCLE)<>0"
If [M:DIA]ALLTYP <> 2 
 CRIT_JOI += "& [F:AOX]TYPDOC="+'"'+[M:DIA]TYPDOC+'"'
Endif
Return

$MAJ
If NBCLE=1 or NB=1
 If evalue("type([F:"+ABFIC+"]"+CLEPRIM+")")>=10
  Assign "[F:"+ABFIC+"]"+CLEPRIM With CLE2_JOI
 Elsif evalue("type([F:"+ABFIC+"]"+CLEPRIM+")")=3
  CLE2_JOI=right$(CLE2_JOI,7)+mid$(CLE2_JOI,4,2)+left$(CLE2_JOI,2)
  Assign "[F:"+ABFIC+"]"+CLEPRIM With CLE2_JOI
 Else
  Assign "[F:"+ABFIC+"]"+CLEPRIM With val(CLE2_JOI)
 Endif
Else
 If evalue("type([F:"+ABFIC+"]"+CLESEC(NB-2)+")")>=10
  Assign "[F:"+ABFIC+"]"+CLESEC(NB-2) With CLE2_JOI
 Elsif evalue("type([F:"+ABFIC+"]"+CLESEC(NB-2)+")")=3
  CLE2_JOI=right$(CLE2_JOI,7)+mid$(CLE2_JOI,4,2)+left$(CLE2_JOI,2)
  Assign "[F:"+ABFIC+"]"+CLESEC(NB-2) With CLE2_JOI
 Else
  Assign "[F:"+ABFIC+"]"+CLESEC(NB-2) With val(CLE2_JOI)
 Endif
Endif
Return 

$MAJ2
If NBCLE = 1
 A_BUFJ1(K) = evalue("[F:"+ABFIC+"]"+CLEPRIM)
 A_BUFJ2(K) = [F:AOX]TYPDOC
 A_BUFJ3(K) = [F:AOX]NAM
Else
 A_BUFJ2(K)= evalue("[F:"+ABFIC+"]"+CLEPRIM)
 A_BUFJ1(K)= evalue("[F:"+ABFIC+"]"+CLESEC(0))
 For I=1 To NBCLE-2
  Assign "A_BUFJ"+num$(2+I)+"("+num$(K)+")" With evalue("[F:"+ABFIC+"]"+CLESEC(I))
 Next
 Assign "A_BUFJ"+num$(NBCLE+1)+"("+num$(K)+")" With [F:AOX]TYPDOC
 Assign "A_BUFJ"+num$(NBCLE+2)+"("+num$(K)+")" With [F:AOX]NAM
Endif
Return

#----------------------------------------------------------------------------------------------------#
# Sélections
#----------------------------------------------------------------------------------------------------#

$ACT_SAIMOT
Case ACTION
 When "DEBUT" : [M:DIA]TYPDOC = PARAM(3) : Affzo TYPDOC
 When "OK"    : PARAM(1) = [M:DIA]MOTCLE : PARAM(2) = [M:DIA]TYPDOC
 When "END"   : PARAM(1) = ""
Endcase
Return

#---------------------------------------#
$ACT_SAIMOD
Case ACTION
 When "DEBUT" : [M:DIA]TYPDOC = PARAM(3) : Affzo TYPDOC
 When "OK"    : PARAM(1) = [M:DIA]MODELE : PARAM(2) = [M:DIA]TYPDOC
 When "END"   : PARAM(1) = ""
Endcase
Return

#---------------------------------------#
$SELTXTMOT
If PARAM(1) = "" : OK = 0 : Return : Endif
If clalev([AOX])=0 : Local File AOBJTXT  [AOX] : Endif
If clalev([AOM])=0 : Local File AOBJTXTA [AOM] : Endif
Link [AOM] With [AOX]AOX0=[F:AOM]ABREV;[F:AOM]IDENT1;[F:AOM]IDENT2;[F:AOM]IDENT3 As [LNK] 
Default File [LNK]
CRITERE = '[F:AOM]MOTCLE<>"" & [F:AOM]MOTCLE="'+PARAM(1)+'"'
CRITERE += ' & [F:AOM]ABREV = "'+GABREV+'"'
If PARAM(2)<>""
 CRITERE += ' & [F:AOX]TYPDOC = "'+PARAM(2)+'"'
Endif
START = "[AOX]NAM"
ORDRE = "[AOX]NAM;ABREV;[AOX]TYPDOC;IDENT1;IDENT2;IDENT3;MOTCLE"
NBCOL  = 1 : COL(NBCOL) = "[F:AOX]NAM"     : TIT(NBCOL) = mess(92,151,1)     : # Nom du fichier
NBCOL += 1 : COL(NBCOL) = "[F:AOX]TYPDOC"  : TIT(NBCOL) = mess(59,100,1)     : # Type
NBCOL += 1 : COL(NBCOL) = "[F:AOM]ABREV"   : TIT(NBCOL) = mess(33,115,1)     : # Objet
NBCOL += 1 : COL(NBCOL) = "[F:AOM]IDENT1"  : TIT(NBCOL) = mess(55,123,1)+"1" : # Clé
NBCOL += 1 : COL(NBCOL) = "[F:AOM]IDENT2"  : TIT(NBCOL) = mess(55,123,1)+"2" : # Clé
NBCOL += 1 : COL(NBCOL) = "[F:AOM]IDENT3"  : TIT(NBCOL) = mess(55,123,1)+"3" : # Clé
NBCOL += 1 : COL(NBCOL) = "[F:AOM]MOTCLE"  : TIT(NBCOL) = mess(119,124,1)    : # Mot-clé
TIT = mess(121,124,1)-PARAM(1) : # Recherche par mot-clé
If PARAM(2)<>""
 TIT -= "("+PARAM(2)+")"
Endif
Return

#---------------------------------------#
$VERFTXTMOT
If clalev([M:AOX])=0 : Return : Endif
[M:AOX]SELDOC = [F:AOX]TYPDOC
[M:AOX]SELOBJ = [F:AOM]ABREV
[M:AOX]SELID1 = [F:AOM]IDENT1
[M:AOX]SELID2 = [F:AOM]IDENT2
[M:AOX]SELID3 = [F:AOM]IDENT3
mkstat = 99
Return

#---------------------------------------#
$SELTXTMOD
If PARAM(1)="" : OK = 0 : Return : Endif
If clalev([AOX])=0 : Local File AOBJTXT  [AOX] : Endif
Default File [AOX]
CRITERE = 'pat(NAM,"'+PARAM(1)+'")'
CRITERE += ' & [F:AOX]ABREV = "'+GABREV+'"'
If PARAM(2)<>""
 CRITERE += ' & [F:AOX]TYPDOC = "'+PARAM(2)+'"'
Endif
START = "[F:AOX]NAM"
ORDRE = "NAM;TYPDOC;ABREV;IDENT1;IDENT2;IDENT3"
NBCOL  = 1 : COL(NBCOL) = "[F:AOX]NAM"     : TIT(NBCOL) = mess(92,151,1)     : # Nom du fichier
NBCOL += 1 : COL(NBCOL) = "[F:AOX]TYPDOC"  : TIT(NBCOL) = mess(59,100,1)     : # Type
NBCOL += 1 : COL(NBCOL) = "[F:AOX]ABREV"   : TIT(NBCOL) = mess(33,115,1)     : # Objet
NBCOL += 1 : COL(NBCOL) = "[F:AOX]IDENT1"  : TIT(NBCOL) = mess(55,123,1)+"1" : # Clé
NBCOL += 1 : COL(NBCOL) = "[F:AOX]IDENT2"  : TIT(NBCOL) = mess(55,123,1)+"2" : # Clé
NBCOL += 1 : COL(NBCOL) = "[F:AOX]IDENT3"  : TIT(NBCOL) = mess(55,123,1)+"3" : # Clé
TIT = mess(118,124,1)-PARAM(1) : # Pièces jointes
If PARAM(2)<>""
 TIT -= "("+PARAM(2)+")"
Endif
Return

#---------------------------------------#
$VERFTXTMOD
If clalev([M:AOX])=0 : Return : Endif
[M:AOX]SELDOC = [F:AOX]TYPDOC
[M:AOX]SELOBJ = [F:AOX]ABREV
[M:AOX]SELID1 = [F:AOX]IDENT1
[M:AOX]SELID2 = [F:AOX]IDENT2
[M:AOX]SELID3 = [F:AOX]IDENT3
mkstat = 99
Return

#---------------------------------------#
$SELMOTCLE
If clalev([AOM])=0 : Local File AOBJTXTA [AOM] : Endif
Filter [AOM] Where MOTCLE<>"" & ABREV=GABREV & MOTCLE>VALEUR
NBTEX = 0
For [AOM]AOM1(1)
 NBTEX += 1
 TEX(NBTEX) = [F:AOM]MOTCLE
Next
TIT = mess(120,124,1) : # Mot-clé
Return

#----------------------------------------------------------------------------------------------------#
# Etiquettes écran AOBJTXT2
#----------------------------------------------------------------------------------------------------#

Subprog AS_TYPDOC(VALEUR)
Variable Char  VALEUR
