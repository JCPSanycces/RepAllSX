$AREAD_AFTER
Local Integer IRET, WI

  #If this.ADDBPC = null Then
  #  IRET = fmet this.ADDINSTANCE("ADDBPC")
  #Endif
  #If this.ADDBPD = null Then
  #  IRET = fmet this.ADDINSTANCE("ADDBPD")
  #Endif


  # -----------------------------------
  #IRET = fmet this.ADDBPC.INIT_SALADDRESS("SOHBPC", this.BPCORD, this.BPAORD, this.CNTNAM)
  #IRET = fmet this.ADDBPD.INIT_SALADDRESS("SOHBPD", this.BPCORD, this.BPAADD, this.CNDNAM)
  # -----------------------------------

  #For WI = 1 To maxtab(this.C_INVDTAAMT)
   # If this.C_INVDTAAMT(WI) <> null
   #     # INVCDTA = INVDTA en alpha (Pour le passage des paramètres de SHOAXX)
   #     this.C_INVDTAAMT(WI).INVCDTA = num$(this.C_INVDTAAMT(WI).INVDTA)
   # Endif
  #Next

  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  # -----------------------------------
  #--Loading of the different _LEG properties associated to the multilegislation associated properties
  #--VACBPR, DEP, PTE, SDHTYP, EECNAT, EECSCH

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this, this.CPY, this.SALFCY, this.LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_SRHTYP_LEG(this, this.SRHTYP, this.CPY, this.SALFCY, this.LEG, this.SRHTYP_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  If func ASYRFNC.ACTIV("DEB")>0 #AFNC.ACTIV("DEB") = 1 # Issue X3-38343 - 2017-06-07 by CPO : Legislation property in SINVOICEV class
    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_EECNAT_LEG(this, this.EECNAT, this.CPY, this.SALFCY, this.LEG, this.EECNAT_LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_EECSCH_LEG(this, this.EECSCH, this.CPY, this.SALFCY, this.LEG, this.EECSCH_LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  Endif

Return
#######################################################################################
# Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
$AREAD_BEFORE_SRD

  If this.APARENT<>null
    this.LEG = this.APARENT.LEG
  Endif

Return

