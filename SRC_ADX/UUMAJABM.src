#<AdxTL>@(#)0.0.0.0 $Revision$
Call OUVRE_TRACE("MAJ patch BO") From LECFIC
Call PATCH_X3(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

Subprog PATCH_X3(APPLI)
Value Char APPLI
Goto EXEC

Subprog PATCH(APPLI)
Value Char APPLI

$EXEC

If filinfo(filpath("FIL","ABIDATMRT","fde",APPLI),0) <0 or func AFNC.ACTIV("ABI")<1
 End
Endif


Local File =APPLI+".ABIDATMRT"    [ABM]
Call ECR_TRACE(mess(81,125,1)-"ABIDATMRT"-time$,0) From GESECRAN

Trbegin [ABM]
 For [ABM]ABM0
  If dim([F:ABM]PREFIX)>0 & [F:ABM]PREFIX = 0
   [F:ABM]PREFIX=2
  Endif
  If dim([F:ABM]SCLASS)>0 & [F:ABM]SCLASS = 0
   [F:ABM]SCLASS=1
  Endif
  Rewrite [F:ABM]
  If fstat
   Call ERREUR("ABIDATMRT"-[F:ABM]COD,1) From DOSDIC
  Endif
 Next
Commit

Close Local File [ABM]

End
