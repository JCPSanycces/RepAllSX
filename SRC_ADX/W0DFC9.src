#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque DFC9 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone FLGLIC
mkstat = 0
zoncou = "FLGLIC"
indice = 0
IMPENT = [M]FLGLIC
If varinit([M]FLGLIC,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGLIC,indice)=0
 [M]FLGLIC(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGLIC" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGLIC(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_FLGLIC(IMPENT) From SUBDFC
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "FLGLIC" : GZNUM = 47427 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]FLGLIC = IMPENT

## Zone NUMLIC
mkstat = 0
zoncou = "NUMLIC"
indice = 0
If varmode([M]NUMLIC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NUMLIC" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone FLGLAB
mkstat = 0
zoncou = "FLGLAB"
indice = 0
IMPENT = [M]FLGLAB
If varinit([M]FLGLAB,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGLAB,indice)=0
 [M]FLGLAB(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGLAB" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGLAB(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_FLGLAB(IMPENT) From SUBDFC
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "FLGLAB" : GZNUM = 47428 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]FLGLAB = IMPENT

## Zone NUMLAB
mkstat = 0
zoncou = "NUMLAB"
indice = 0
If varmode([M]NUMLAB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NUMLAB" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone CCSFLG
mkstat = 0
zoncou = "CCSFLG"
indice = 0
IMPENT = [M]CCSFLG
If varinit([M]CCSFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]CCSFLG,indice)=0
 [M]CCSFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CCSFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CCSFLG(indice)
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call C_CCSFLG(IMPENT) From SUBDFC
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CCSFLG" : GZNUM = 47429 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]CCSFLG = IMPENT

## Zone NUMCCS
mkstat = 0
zoncou = "NUMCCS"
indice = 0
If varmode([M]NUMCCS,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NUMCCS" : Gosub ACTION From =IMPTRT
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "DFC9"
Return

