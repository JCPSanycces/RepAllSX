#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Representation EDISIHFA  JUCON 01/09/2016                                   #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AREAD_AFTER"           : Gosub AREAD_AFTER
    Endcase
Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_AFTER_LOAD_REPRESENTATION" :  Gosub MET_AFTER_LOAD_REPRESENTATION
  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return

$AREAD_AFTER
  Gosub GETVALPARAMURL From TRTFUNEDI
Return

#********************************************************************
# Method MET_AFTER_LOAD_REPRESENTATION
#********************************************************************
#
#*
#* @param WCATACT
#* @param WCATCOD
#* @param WPARCOD
#* @param WDUPLICATE
#* @param WTEST
#* @param WSEPDEC
#* @param WERR
#* @return [V]CST_AOK/[V]CST_AERROR
#*!
$MET_AFTER_LOAD_REPRESENTATION
  Local Integer I, J
  Local Integer WOK, WOKK : WOK     = [V]CST_AOK
  Local Integer WSTATUS   : WSTATUS = [V]CST_AOK

  WOKK=func EDIRUN_CSTD.CHECK_AUTHORIZATION_SITE(this.ACTX.USER,WCATCOD,this.ETC.PIH.FCY,WCATACT)### pending check
WOKK=1
  If WOKK=0
    WSTATUS = [V]CST_AERROR
    WERR = mess(74,100,1)    #Unauthorized Function
  Else
    Case WCATACT
      When 1 :
        Case WPARCOD
          When "FACTURAE" : Gosub FACTURAE_ISSUE
          When Default  : WSTATUS = [V]CST_AERROR : WERR = ""
        Endcase
      When 2 :
        Case WPARCOD
          When "FACTURAE" : Gosub FACTURAE_RECEIPT
          When Default  : WSTATUS = [V]CST_AERROR : WERR = ""
        Endcase
    Endcase
  Endif

  ARET_VALUE = WSTATUS
Return

################################################################################
$FACTURAE_RECEIPT
  #####################################
  #####           HEAD          #######
  #####################################
  Local Char WCODE(20), WREP(20), WLEG(3), WLAN(3), WPROP(25), WCPY(5), WFCY(5), WBPR(15), WSAC(4)
  Local Char WNODE(20), WTYP(20), WBPSPRICE(10)
  Local Integer WTAB
  Local Integer WNB: WNB=1

  Local Integer WSTAT
  Local Char WREST(250)

  WREP=right$(this.AINF.NAMCLA,3)
  WLEG=this.ETC.PIH(WNB).LEG
  WLAN=this.ACTX.LAN

  Local Char WSEPDEC(1)

  If WSEPDEC="": WSEPDEC=".": Endif

  ########################
  # Filling Batch values #
  ########################

# Searching BP's EDI code
  Local File EDIBPRPAR [EBP]

  If WSTATUS = [V]CST_AOK
    If this.ETC.BPRCRN <>""
      Filter [EBP] Where PARCOD = WPARCOD and EXCEDICOD = this.ETC.BPRCRN
      Read First
      If fstat = [V]CST_AOK
        this.ETC.PIH.BPR = [F:EBP]BPANUM
        WBPR=this.ETC.PIH.BPR
        this.ETC.PIH.BPAINV = [F:EBP]BPAADD
      Else
        WSTATUS = [V]CST_AERROR
        WERR = mess(127,2006,1) #Cannot find the BP or ADDRESS code
        Goto EXITGEN
      Endif
    Endif
  Endif

  If this.ETC.PIH.BPR<>""
    Local File BPSUPPLIER [XBPS]
    Read [XBPS]BPS0=WBPR
    If fstat<>[V]CST_AOK
      WSTATUS = [V]CST_AERROR
      WERR = WBPR-mess(107,116,1) #is not a supplier
      Goto EXITGEN
    Endif
    LogicClose File [XBPS]
  Endif

#.- FILLING COMPANY and SITE FIELDS

  If WSTATUS = [V]CST_AOK

    this.ETC.PIH.FCY = func TRTFUNEDI.ORD_EDICODE_SE(this.ETC.CPYCRN,WPARCOD,this.ETC.PIH.BPR,1)
    this.ETC.PIH.CPY = func TRTFUNEDI.ORD_EDICODE_SE(this.ETC.CPYCRN,WPARCOD,this.ETC.PIH.BPR,2)
    WCPY=this.ETC.PIH.CPY
    WFCY=this.ETC.PIH.FCY

    Local File FACILITY [FCY]
    Read [FCY]FCY0=this.ETC.PIH.FCY
    If fstat=[V]CST_AOK
      WLEG=[F:FCY]LEG
      If [F:FCY]LEGCPY<> this.ETC.PIH.CPY
         WERR=mess(125,2006,1)   #Site does not belong to the company
         WSTATUS = [V]CST_AERROR
#       Else
#         this.PIH.LEG   =[F:FCY]LEG
       Endif
    Endif
    LogicClose File [FCY]

  Endif

  If WSTATUS = [V]CST_AOK
    If this.ETC.PIH.CPY=""
      WSTATUS = [V]CST_AERROR
      WERR = mess(126,2006,1) #Cannot find the site code
    Endif
  Endif
  LogicClose File [EBP]

# (X3-84850) Edi - CHECK FLOW By BP/COMPANY IN RECEIPT (JUCON 02/04/2018)
  If WSTATUS = [V]CST_AOK
    Local Integer WFLOK
    WFLOW=func EDIRUN_CSTD.TEST_EDIBPRCPY(this.ETC.PIH.BPR,this.ETC.PIH.CPY, WPARCOD, WCATCOD, [ETC]FLOCOD, [ETC]FLOREL)
    If WFLOW<>[V]CST_AINFO # If AINFO then valid flow
      Case WFLOW
        When 3: WERR=mess(41,2006,1)+"."-mess(4,2017,1)+":"- this.ETC.PIH.BPR+"/"+this.ETC.PIH.CPY  # Invalid flow. Checking EDI flow and BPs/companies association
        When 4: WERR=mess(31,2006,1)+"."-mess(4,2017,1)+":"- this.ETC.PIH.BPR+"/"+this.ETC.PIH.CPY  # Flow not defined. Checking EDI flow and BPs/companies association
      Endcase
      WSTATUS = [V]CST_AERROR
    Endif
  Endif

  Local Decimal RETEN, ANTIC
  Local Integer K,OKTVT, DTARET(1..)

  Local File BPARTNER [BPR]
  Local Integer WOKK
  Local Char WACCCOD(15)
#  Filter [BPR] Where CRN=this.ETC.BPRCRN  and BPSFLG=2
   Read [BPR]BPR0=WBPR
   If fstat=[V]CST_AOK
#    WBPR=[F:BPR]BPRNUM
     WTYP="F"
     Local File BPSUPPLIER [XBPS]
     Read [XBPS]BPS0=WBPR
     If fstat=[V]CST_AOK: WOKK=1:  WACCCOD=[F:XBPS]ACCCOD: WBPSPRICE=[F:XBPS]PLISTC  :Endif      # Price structure code
     LogicClose File [XBPS]
     If WOKK=1: WSAC=func TRTFUNEDI.FACEPIH_BPRSAC(WBPR,WCPY,WTYP,WACCCOD): Endif
     If WSAC="": WERR = WBPR+":"-mess(50,102,1)+"."-mess(9,106,1) # BP: Incorrect business partner. Nonexistent control account
     Endif
  Else
    WERR =WBPR+":"-mess(245,107,1)  #BP: Not managed as a BP or without site tax ID number
  Endif
  LogicClose File [BPR]

  If WERR<>"":  WSTATUS = [V]CST_AERROR:  Goto EXITGEN : Endif

  ####################
  ## INVOICE LEVEL ###
  ####################
  Local Integer NBFAC: NBFAC=1    # For future use when a lot of invoices will be possible

  For WNB=1 To NBFAC
    Local File TABPIVTYP [TPV]

    this.ETC.PIH(WNB).E="E"              # Indicator header for import template model
    this.ETC.PIH(WNB).CPY   =WCPY        # Filling CPY property
    this.ETC.PIH(WNB).FCY   =WFCY        # Filling FCY property
    this.ETC.PIH(WNB).BPR   =WBPR        # Filling BPR property
    this.ETC.PIH(WNB).BPRSAC=WSAC        # Filling SAC property

    # Filling PIVTYP property
    If this.ETC.PIH(WNB).EDIPIVTYP="OR"
      Filter [TPV] Where LEG=WLEG and INVTYP=2
      Read First
      If fstat=[V]CST_AOK
        this.ETC.PIH(WNB).PIVTYP=[F:TPV]PIVTYP
      Else
        Filter [TPV]
        Filter [TPV] Where LEG="" and INVTYP=2
        Read First
        If fstat=[V]CST_AOK
         this.ETC.PIH(WNB).PIVTYP=[F:TPV]PIVTYP
        Else
          WSTATUS = [V]CST_AERROR
        Endif
      Endif
    Else
      Filter [TPV] Where LEG=WLEG and INVTYP=1
      Read First
      If fstat=[V]CST_AOK
        this.ETC.PIH(WNB).PIVTYP=[F:TPV]PIVTYP
      Else
        Filter [TPV]
        Filter [TPV] Where LEG="" and INVTYP=1
        Read First
        If fstat=[V]CST_AOK
          this.ETC.PIH(WNB).PIVTYP=[F:TPV]PIVTYP
        Else
          WSTATUS = [V]CST_AERROR
        Endif
      Endif
    Endif
    If WSTATUS=[V]CST_AERROR
      WERR = mess(54,119,1)   # Invoice type not defined
      Break
    Endif

    Local File ASHWPAR [ASWP]   # Transcoding EDICUR (in STD table 223)
    Filter [ASWP] Where CODREP=WREP and CODLNK="EDICUR"
    Read First
    If fstat=[V]CST_AOK
      Local Char WNODE(20), WTYP(20)
      Local Integer WTAB
      WTYP=this.ETC.PIH(WNB).EDICUR
      WTAB=val([F:ASWP]VALEUR)
      WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
      this.ETC.PIH(WNB).CUR= left$(WNODE,3)
    Endif
    If this.ETC.PIH(WNB).CUR="": this.ETC.PIH(WNB).CUR=this.ETC.PIH(WNB).EDICUR: Endif
    LogicClose File [ASWP]

    # Filling INVREF property
    this.ETC.PIH(WNB).INVREF=mess(182,2006,1)   # FACTURAE imported by EDI

    # Filling BPRDAT property
    this.ETC.PIH(WNB).BPRDAT=this.ETC.PIH(WNB).ACCDAT


####################################
  #   LINES
  ####################################
  #Filling ETC.PIH.PID collection
  If WSTATUS = [V]CST_AOK
    For I = 1 To maxtab(this.ETC.PIH(WNB).PID)

      this.ETC.PIH(WNB).PID(I).L="L"   #Indicator lines for import template model

    If this.ETC.PIH(WNB).PID(I).EDIORDNUM<>"" and val(this.ETC.PIH(WNB).PID(I).EDILINORD)<>0
        this.ETC.PIH(WNB).PID(I).LINORI=val(this.ETC.PIH(WNB).PID(I).EDILINORD)
        Local File PORDERQ [POQ]
        Filter [POQ] Where POHNUM=this.ETC.PIH(WNB).PID(I).EDIORDNUM and POPLIN=this.ETC.PIH(WNB).PID(I).LINORI
        Read [POQ]POQ0 First
        If fstat=[V]CST_AOK
          this.ETC.PIH(WNB).PID(I).TYPORI=1
          this.ETC.PIH(WNB).PID(I).NUMORI=[F:POQ]POHNUM
          this.ETC.PIH(WNB).PID(I).SEQORI=[F:POQ]POQSEQ
        Else
          this.ETC.PIH(WNB).PID(I).TYPORI=5
          this.ETC.PIH(WNB).PID(I).NUMORI=""
          this.ETC.PIH(WNB).PID(I).LINORI=0
          this.ETC.PIH(WNB).PID(I).SEQORI=0
        Endif
        LogicClose File [POQ]
      Else
        this.ETC.PIH(WNB).PID(I).TYPORI=5
        this.ETC.PIH(WNB).PID(I).NUMORI=""
        this.ETC.PIH(WNB).PID(I).LINORI=0
        this.ETC.PIH(WNB).PID(I).SEQORI=0
      Endif

      #Searching ITMREF
      If this.ETC.PIH(WNB).PID(I).ITMREFCOD=""
        WSTATUS = [V]CST_AERROR
        WERR =  mess(141,2006,1) #Mandatory field EANCOD is empty
        Break
      Else
        this.ETC.PIH(WNB).PID(I).ITMREF = func TRTFUNEDI.ORD_ITMREF(this.ETC.PIH(WNB).PID(I).ITMREFCOD,1)
        If this.ETC.PIH(WNB).PID(I).ITMDES = ""
          this.ETC.PIH(WNB).PID(I).ITMDES = func TRTFUNEDI.ORD_ITMREF(this.ETC.PIH(WNB).PID(I).ITMREFCOD,2)
      Endif
      If this.ETC.PIH(WNB).PID(I).ITMREF=""
        WSTATUS = [V]CST_AERROR
        WERR = mess(3,40,1)-num$(I)+":"-this.ETC.PIH(WNB).PID(I).ITMREFCOD+"."-mess(142,2006,1)#Cannot find a product for this EANCOD
        Break
       Endif
      Endif
      # Transcoding EDIUOM  properties (in STD table 228)
      Local File ASHWPAR [ASWP]
      Filter [ASWP] Where CODREP=WREP and CODLNK="EDIUOM"
      Read First
      If fstat=[V]CST_AOK
        WTYP  = this.ETC.PIH(WNB).PID(I).EDIUOM
        WTAB  = val([F:ASWP]VALEUR)
        WNODE = func TRTFUNEDI.TRANSCODE(WTYP, WTAB, WCATACT)
        If left$(WNODE,3) = ""
          this.ETC.PIH(WNB).PID(I).UOM = this.ETC.PIH(WNB).PID(I).EDIUOM  #STD import will make the final control
        Else
          this.ETC.PIH(WNB).PID(I).UOM = left$(WNODE,3)
        Endif
      Endif
      LogicClose File [ASWP]

    $EXIT
    Next

    #################
    # Foot elements #
    #################
    Local Char WFDES(50)(99), WFDCT(50)(99), WFCHG(50)(99), WCODE(5)(99)
    Local Decimal WFAMTD(99), WFRATD(99), WFAMTC(99), WFRATC(99)
    Local Integer H, WPOS, WBNFOOT, WINVPOS, WFIND


  Endif

  Next

  $EXITGEN

  If WSTATUS = [V]CST_AINFO
    WSTAT = [V]CST_AINFO
    Call ADDDIAGNOSE(this.ACTX,WERR,WSTAT) From ASYRASYNC
    WSTATUS = [V]CST_AOK
  Endif

  WREST=mess(280,143,1) # Displayed properties updated
  If WSTATUS = [V]CST_AOK
    WREST=WREST-": OK"
    WSTAT=[V]CST_AINFO
  Else
    WREST=WREST-": KO"
    WSTAT=[V]CST_AERROR
  Endif
  Call ADDDIAGNOSE(this.ACTX,WREST,WSTAT) From ASYRASYNC
  Raz WREST

Return

################################################################################
$FACTURAE_ISSUE
Return

