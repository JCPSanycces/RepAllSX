#<AdxTL>@(#)0.0.0.0 $Revision$
Funprog CONTTVC(CTX,PCOD,PLEG,PFCY,PGROUPE,PCPY, VMESSA)
Value Instance   CTX Using C_WMACONTEXT : # Référence sur le contexte
Variable Char    PCOD
Value    Char    PLEG
Value    Char    PFCY
Value    Char    PGROUPE
Value    Char    PCPY
Variable Char    VMESSA

Local Integer 	 WRET : WRET = [V]CST_AOK
Local Char       WTMPLEG(GLONADI)

Raz VMESSA : # 101874 : V9 : Taxe code control

If PCOD="" : End WRET : Endif

If CTX = null
  CTX = GACTX
Endif

Local File TABVAC 	[TVC]
Local File COMPANY  [CPY]
Local File FACILITY [FCY]

If CTX.AFOLD.ANBLEG = 1 Then
  PLEG = CTX.AFOLD.ALISTLEG(1)
Endif
#CAS = 1 : # Legislation is empty

#--Cas particulier : pas de GCURLEG mais société ou site en ligne
If ([L]PCPY<>"" | [L]PFCY<>"")
	If [L]PFCY<>""
		Read [F:FCY]FCY0=[L]PFCY
		If fstat : Raz [F:FCY] Endif
		If [L]PCPY="" : [L]PCPY=[F:FCY]LEGCPY : Endif
	Endif
	If [L]PCPY<>""
		Read [F:CPY]CPY0=[L]PCPY
		If fstat : Raz [F:CPY] Endif
		[L]WTMPLEG=[F:CPY]LEG
	Endif
Endif

If WTMPLEG<>""
  If PLEG=""
    [L]PLEG = WTMPLEG
  Elsif [L]PLEG<>[L]WTMPLEG
    If [L]PFCY<>""
      WRET = [V]CST_AERROR
      VMESSA=mess(498,197,1)-[F:FCY]FCY-mess(138,187,1)-[F:CPY]LEG
      End WRET
    Elsif [L]PCPY<>""
      WRET = [V]CST_AERROR
      VMESSA=mess(142,187,1)-[F:CPY]CPY-mess(138,187,1)-[F:CPY]LEG
      End WRET
    Endif
  Endif
Endif

If PLEG<>""
 Read [TVC]TVC0=PCOD;PLEG
 If fstat
  Read [TVC]TVC0=PCOD;""
 Endif
Else
 Read [TVC]TVC0(1)=PCOD
 If !fstat
  PLEG = [F:TVC]LEG
 Endif
Endif
If fstat
 Filter [TVC] Where COD=[L]PCOD
 Look [TVC]TVC0 First
 If !fstat
  # Fiche inexistante pour la législation courante
  VMESSA = [L]PCOD-":"-mess(232,107,1)-"["+[L]PLEG+"]"
 Else
  # Fiche inexistante
  VMESSA = [L]PCOD-":"-mess(23,100,1)
 Endif
 Filter [TVC]
 End [V]CST_AERROR
Endif

If [F:TVC]ENAFLG <> [V]CST_AYES
  VMESSA = [L]PCOD-":"-mess(2,126,1)-"["+[L]PLEG+"]" : # Fiche inactive
  WRET = [V]CST_AERROR
  End WRET
Endif

#--Filtrage par groupe de société
#--Dans ce cas particulier ou nous pouvons avoir que le CPY de renseigné (paramètrage pour une société)
#--Du fait du type de donné AGF sur le champ GRP de TABVACBPR, il n'y aura que le filtrage sur site ! (en fonction de GCURFCY)
If [L]PCPY<>"" and [L]PFCY=""
  If [F:TVC]GRP<>""
  	Local File AGRPFCY [AGF]
		Read [AGF]AGF0=[F:TVC]GRP
		If !fstat
  		If [F:AGF]FLGLEG=2
    		#--Société
				If [F:TVC]GRP<>[L]PCPY
          VMESSA += PCOD-PLEG+"\"+mess(63,127,1)-":"-[F:TVC]GRP : # Réservé au groupe de société
          End [V]CST_AERROR
				Endif
  		Elsif [F:AGF]FLGCPY=2
        Local File AGRPCPY [AGC]
        Look [AGC]AGC0 = [F:TVC]GRP;[L]PCPY
        If fstat
          VMESSA += PCOD-PLEG+"\"+mess(63,127,1)-":"-[F:TVC]GRP : # Réservé au groupe de société
          End [V]CST_AERROR
        Endif
      Endif
    Endif
  Endif

Elsif [L]PFCY<>""
	## Filtrage par groupe de site

    If [F:TVC]GRP<>""
     Local File FACGROUP [FGR]
     Look [FGR]FGR0 = [F:TVC]GRP;[L]PFCY
     If fstat
        VMESSA += PCOD-PLEG+"\"+mess(23,127,1)-":"-[F:TVC]GRP : # Réservé au groupe de site
        End [V]CST_AERROR
     Endif
    Endif

Elsif [L]PCPY<>""
  ## Filtrage par groupe de société

    If [F:TVC]GRP<>""
     Local File AGRPCPY [AGC]
     Look [AGC]AGC0 = [F:TVC]GRP;[L]PCPY
     If fstat
        VMESSA += PCOD-PLEG+"\"+mess(63,127,1)-":"-[F:TVC]GRP : #  # Réservé au groupe de société
        End [V]CST_AERROR
     Endif
    Endif

Endif
#--

#--Contrôle de cohérence entre le groupe de la taxe et la législation
If [F:TVC]GRP<>"" and PLEG<>""
	WRET = func TRTVENCTL_SYRA.CTLGFYLEG(CTX,[F:TVC]GRP,PLEG,VMESSA) #From TRTVENCTL
	If WRET>=[V]CST_AERROR or VMESSA<>"" : End WRET : Endif
Endif

#--Contrôle de cohérence entre le groupe passé en paramètre et la législation de l'enregistrement retenu
If PGROUPE<>"" and [F:TVC]LEG<>""
	WRET = func TRTVENCTL_SYRA.CTLGFYLEG(CTX,PGROUPE,[F:TVC]LEG, VMESSA) #From TRTVENCTL
	If WRET>=[V]CST_AERROR or VMESSA<>"" : End WRET : Endif
Endif

#--Contrôle de la cohérence entre le groupe passé en param et celui de la taxe à contrôler
#--uniquement si le groupe passé est renseigné
#--uniquement si pas de contexte site ou société !
If PGROUPE<>""
  If PCPY="" & PFCY="" & [F:TVC]GRP<>"" & [F:TVC]GRP<>PGROUPE
  		#--Les groupes doivent avoir au moins une société en commun
  		Gosub CTLGFYGRP_TVC
			If WRET>=[V]CST_AERROR or VMESSA<>"" : End WRET : Endif
  Endif
Endif

#--Cohérence [TVB]VAT et paramètres
If WRET>=[V]CST_AERROR or VMESSA<>"" : End WRET : Endif

If [TVC]VACBPR<>""
  #--Cohérence [TVC]VACBPR et paramètres
  WRET = func CONTTVB(CTX, [TVC]VACBPR,PLEG,PFCY,PGROUPE,PCPY,VMESSA)
  If WRET>=[V]CST_AERROR or VMESSA<>""
		If [F:TVC]LEG=""
			VMESSA = [L]PCOD-":"-mess(620,197,1)-VMESSA
		Else
			VMESSA = [L]PCOD-"["+[F:TVC]LEG+"]"-":"-mess(620,197,1)-VMESSA
		Endif
    End WRET
  Endif
Endif

If [TVC]VACITM<>""
  #--Cohérence [TVC]VACITM et paramètres
  WRET = func CONTTVI(CTX, [TVC]VACITM,PLEG,PFCY,PGROUPE,PCPY,VMESSA)
  If WRET>=[V]CST_AERROR or VMESSA<>""
		If [F:TVC]LEG=""
			VMESSA = [L]PCOD-":"-mess(2075,200,1)-VMESSA
		Else
			VMESSA = [L]PCOD-"["+[F:TVC]LEG+"]"-":"-mess(2075,200,1)-VMESSA
		Endif
    End WRET
  Endif
Endif

If [F:TVC]VAT<>""
  #--Cohérence [TVC]VAT et paramètres
  WRET = func CONTTVT(CTX, [TVC]VAT,PLEG,PFCY,PGROUPE,PCPY,VMESSA)
  If WRET>=[V]CST_AERROR or VMESSA<>""
		If [F:TVC]LEG=""
			VMESSA = [L]PCOD-":"-mess(39,105,1)-VMESSA
		Else
			VMESSA = [L]PCOD-"["+[F:TVC]LEG+"]"-":"-mess(39,105,1)-VMESSA
		Endif
    End WRET
  Endif
Endif

WRET= [V]CST_ASUCCESS

End WRET
###################################################################################################
#-------------------------------
$CTLGFYGRP_TVC
Local Integer ERR
Local Char    SZVIEW(GLONAVW)

Return
####################################################################################################
##---------------------------------------------------------------------------------#
## Controle cohérence entre un groupe de site/soc est une législation              #
## Si Société       - elle doit être de même législation                           #
## Si Grp. sociétés - au moins une des sociétés du groupe doit être de même lég.   #
## Si Grp. de sites - au moins un site doit appartenir à une société de même lég.  #
##---------------------------------------------------------------------------------#
#Funprog CTLGFYLEG(CTX,AZC,PLEG, VMESSA)
#Value Instance   CTX Using C_WMACONTEXT : # Référence sur le contexte
#Variable Char    AZC
#Value    Char    PLEG
#Variable Char    VMESSA
#
#Local Integer WRET
#
#Local File FACILITY   [FCY]
#Local File COMPANY    [CPY]
#Local File FACGROUP   [FGR]
#Local File AGRPFCY    [AGF]
#Local File AGRPCPY    [AGC]
#
##--Pas de contrôle si vide
#If AZC ="" : End [V]CST_AOK : Endif
#
#If CTX = null
#  CTX = GACTX
#Endif
#
##--Pas de contrôle sur législation si vide
#If PLEG="" : End [V]CST_AOK : Endif
#
#Read [AGF]AGF0=AZC
#If !fstat
#  If [F:AGF]FLGLEG=2
#    #--Société
#    Read [CPY]CPY0=[F:AGF]GRP
#    If !fstat
#      If [F:CPY]LEG<>PLEG
#        WRET = [V]CST_AERROR
#        VMESSA=mess(142,187,1)-[F:CPY]CPY-mess(138,187,1)-[F:CPY]LEG
#        End WRET
#      Endif
#    Endif
#  Elsif [F:AGF]FLGCPY=2
#    #--Groupe de sociétés
#    Link [F:CPY] With [F:AGC]AGC0~=AZC;[F:CPY]CPY As [CPYL]
#    Filter [F:CPYL] Where [F:CPY]LEG=PLEG | [F:CPY]LEG=""
#    If rowcount([F:CPYL])=0
#      WRET = [V]CST_AERROR
#      VMESSA=mess(139,187,1)-AZC-mess(140,187,1)-PLEG
#      End WRET
#    Endif
#    Filter [F:CPYL]
#  Else
#    #--Groupe de sites
#    Link [F:CPY] With [F:FCY]FCY1~=[F:CPY]CPY;[F:FGR]FCY,[F:FGR]FGR0(1)=AZC  As [CPYL]
#    Filter [F:CPYL] Where [F:CPY]LEG=PLEG | [F:CPY]LEG=""
#    If rowcount([F:CPYL])=0
#      WRET = [V]CST_AERROR
#      VMESSA=mess(139,187,1)-AZC-mess(141,187,1)-PLEG
#      End WRET
#    Endif
#    Filter [F:CPYL]
#  Endif
#Endif
#
#WRET = [V]CST_ASUCCESS
#
#End WRET
###################################################################################################
Funprog CONTTVB(CTX,COD,LEG,FCY,GROUPE,CPY, VMESSA)
Value Instance   CTX Using C_WMACONTEXT : # Référence sur le contexte
Variable Char    COD
Value    Char    LEG
Value    Char    FCY
Value    Char    GROUPE
Value    Char    CPY
Variable Char    VMESSA

Local Integer WRET : WRET = [V]CST_AOK
Local Char    WTMPLEG(GLONADI)

Raz VMESSA : # 101874 : V9 : Taxe code control

If [L]COD="" : End WRET : Endif

If CTX = null
  CTX = GACTX
Endif

Local File TABVACBPR  [TVB]
Local File COMPANY    [CPY]
Local File FACILITY   [FCY]

If CTX.AFOLD.ANBLEG = 1 Then
  [L]LEG = CTX.AFOLD.ALISTLEG(1)
Endif

#--Cas particulier : pas de GCURLEG mais société ou site en ligne
If ([L]CPY<>"" | [L]FCY<>"")
	If [L]FCY<>""
		Read [F:FCY]FCY0=[L]FCY
		If fstat : Raz [F:FCY] Endif
		If [L]CPY="" : [L]CPY=[F:FCY]LEGCPY : Endif
	Endif
	If [L]CPY<>""
		Read [F:CPY]CPY0=[L]CPY
		If fstat : Raz [F:CPY] Endif
		[L]WTMPLEG=[F:CPY]LEG
	Endif
Endif
#--/

If WTMPLEG<>""
  If [L]LEG=""
    [L]LEG = WTMPLEG
  Elsif [L]LEG<>[L]WTMPLEG
    If [L]FCY<>""
      VMESSA=mess(498,197,1)-[F:FCY]FCY-mess(138,187,1)-[F:CPY]LEG
      End [V]CST_AERROR
    Elsif [L]CPY<>""
      VMESSA=mess(142,187,1)-[F:CPY]CPY-mess(138,187,1)-[F:CPY]LEG
      End [V]CST_AERROR
    Endif
  Endif
Endif

If [L]LEG<>""
 Read [TVB]TVB0=[L]COD;[L]LEG
 If fstat
  Read [TVB]TVB0=[L]COD;""
 Endif
Else
 Read [TVB]TVB0(1)=[L]COD
 If !fstat
  [L]LEG = [F:TVB]LEG
 Endif
Endif
If fstat
 Filter [TVB] Where VACBPR=[L]COD
 Look [TVB]TVB0 First
 If !fstat
  # Fiche inexistante pour la législation courante
  VMESSA = [L]COD-":"-mess(232,107,1)-"["+[L]LEG+"]"
 Else
  # Fiche inexistante
  VMESSA = [L]COD-":"-mess(23,100,1)
 Endif
 Filter [TVB]
 End [V]CST_AERROR
Endif

If [F:TVB]ENAFLG <> [V]CST_AYES
  VMESSA = [L]COD-":"-mess(2,126,1)-"["+[L]LEG+"]" : # Fiche inactive
  End [V]CST_AERROR
Endif

#--Filtrage par groupe de société
#--Dans ce cas particulier ou nous pouvons avoir que le CPY de renseigné (paramètrage pour une société)
#--Du fait du type de donné AGF sur le champ GRP de TABVACBPR, il n'y aura que le filtrage sur site ! (en fonction de GCURFCY)
If [L]CPY<>"" and [L]FCY=""
  If [F:TVB]SOC<>""
  	Local File AGRPFCY [AGF]
		Read [AGF]AGF0=[F:TVB]SOC
		If !fstat
  		If [F:AGF]FLGLEG=2
    		#--Société
				If [F:TVB]SOC<>[L]CPY
          VMESSA += [L]COD-[L]LEG+"\"+mess(63,127,1)-":"-[F:TVB]SOC : # Réservé au groupe de société
          End [V]CST_AERROR
				Endif
  		Elsif [F:AGF]FLGCPY=2
        Local File AGRPCPY [AGC]
        Look [AGC]AGC0 = [F:TVB]SOC;[L]CPY
        If fstat
          VMESSA += [L]COD-[L]LEG+"\"+mess(63,127,1)-":"-[F:TVB]SOC : # Réservé au groupe de société
          End [V]CST_AERROR
        Endif
      Endif
    Endif
  Endif

Elsif [L]FCY<>""
	## Filtrage par groupe de site

    If [F:TVB]SOC<>""
     Local File FACGROUP [FGR]
     Look [FGR]FGR0 = [F:TVB]SOC;[L]FCY
     If fstat
        VMESSA += [L]COD-[L]LEG+"\"+mess(23,127,1)-":"-[F:TVB]SOC : # Réservé au groupe de site
        End [V]CST_AERROR
     Endif
    Endif

Elsif [L]CPY<>""
  ## Filtrage par groupe de société

    If [F:TVB]SOC<>""
     Local File AGRPCPY [AGC]
     Look [AGC]AGC0 = [F:TVB]SOC;[L]CPY
     If fstat
        VMESSA += [L]COD-[L]LEG+"\"+mess(63,127,1)-":"-[F:TVB]SOC : #  # Réservé au groupe de société
        End [V]CST_AERROR
     Endif
    Endif

Endif
#--

#--Contrôle de cohérence entre le groupe de la taxe et la législation
If [F:TVB]SOC<>"" and [L]LEG<>""
	WRET = func TRTVENCTL_SYRA.CTLGFYLEG(CTX, [F:TVB]SOC,[L]LEG,VMESSA) #From
	If WRET>=[V]CST_AERROR or VMESSA<>"" : End WRET : Endif
Endif

#--Contrôle de cohérence entre le groupe passé en paramètre et la législation de l'entrée retenue
If GROUPE <> "" and [F:TVB]LEG <> "" Then
  WRET = func TRTVENCTL_SYRA.CTLGFYLEG(CTX, [L]GROUPE, [F:TVB]LEG, VMESSA) #From TRTVENCTL
  If WRET>=[V]CST_AERROR or VMESSA<>"" : End WRET : Endif
Endif

#--Contrôle de la cohérence entre le groupe passé en param et celui de l'escompte courant
#--uniquement si pas de contexte site ou société !
#--Il faut que le groupe de la taxes et celui du paramétrage aient au moins une soc en commun
If GROUPE<>""
	If [L]CPY="" & [L]FCY="" & [F:TVB]SOC<>"" & [F:TVB]SOC<>[L]GROUPE
  	#--Les groupes doivent avoir au moins une société en commun
  	Gosub CTLSOCGRP_TVB
		If WRET>=[V]CST_AERROR or VMESSA<>"" : End WRET : Endif
	Endif
Endif

#--Contrôle global de cohérence avant enregistrement
#--Cohérence [TVB]VAT et paramètres
If WRET>=[V]CST_AERROR or VMESSA<>"" : End WRET : Endif

#--CPO 24/02/2014 Pas de contrôle pour la taxe car donnée par le Rechvatcod
#If [F:TVB]VAT<>"x"
#
#  WRET = func CONTTVT(CTX, [TVB]VAT,[L]LEG,[L]FCY,GROUPE,[L]CPY, VMESSA)
#  If WRET>=[V]CST_AERROR or VMESSA<>""
#  	If [F:TVB]LEG=""
#  		VMESSA = [L]COD-":"-mess(39,105,1)-VMESSA
#  	Else
#  		VMESSA = [L]COD-"["+[F:TVB]LEG+"]"-":"-mess(39,105,1)-VMESSA
#  	Endif
#  	End [V]CST_AERROR
#  Endif
#Endif

WRET = [V]CST_ASUCCESS

End WRET
#-------------------------------
$CTLSOCGRP_TVB
Local Integer ERR
Local Char    SZVIEW(GLONAVW)
If [F:TVB]LEG=""
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTVBZGRP"
    Local File =SZVIEW [TVBZ]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, pas de contrôle
    Return
  Endif

  Read [F:TVBZ]TVBZ0 = [L]GROUPE;[F:TVB]VACBPR;[F:TVB]SOC;[F:TVB]LEG
  If fstat
    VMESSA = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:TVB]SOC-":"-mess(178,187,1)
    WRET = [V]CST_AERROR
    Return
  Endif
Else
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTVBYGRP"
    Local File =SZVIEW [TVBY]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, pas de contrôle
    Return
  Endif

  Read [F:TVBY]TVBY0 = [L]GROUPE;[F:TVB]VACBPR;[F:TVB]SOC;[F:TVB]LEG
  If fstat
    VMESSA = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:TVB]SOC-":"-mess(178,187,1)
    WRET = [V]CST_AERROR
    Return
  Endif
Endif

Return
###################################################################################################
$ERRVUE
  If ERR = 0 Then
    ERR = -1
    #Call MAJVUE(SZVIEW, nomap) From DOSVUE
  Else
    ERR = errn
  Endif
Resume
###################################################################################################
Funprog CONTTVT(CTX, VAT,LEG,FCY,GROUPE,CPY,VMESSA)
Value Instance   CTX Using C_WMACONTEXT : # Référence sur le contexte
Variable Char    VAT
Value    Char    LEG
Value    Char    FCY
Value    Char    GROUPE
Value    Char    CPY
Variable Char    VMESSA

Local Integer  WRET : WRET = [V]CST_AOK
Local Char     WTMPLEG(GLONADI)

Raz VMESSA : # 101874 : V9 : Taxe code control

If VAT="" : End WRET : Endif

Local File TABVAT   [TVT]
Local File COMPANY  [CPY]
Local File FACILITY [FCY]

If CTX = null
  CTX = GACTX
Endif

If CTX.AFOLD.ANBLEG = 1 Then
  [L]LEG = CTX.AFOLD.ALISTLEG(1)
Endif

#--Cas particulier : pas de GCURLEG mais société ou site en ligne
If [L]CPY<>"" | [L]FCY<>""
  If [L]FCY<>""
    Read [F:FCY]FCY0=[L]FCY
    If fstat : Raz [F:FCY] Endif
    If [L]CPY="" : [L]CPY=[F:FCY]LEGCPY : Endif
  Endif
  If [L]CPY<>""
    Read [F:CPY]CPY0=[L]CPY
    If fstat : Raz [F:CPY] Endif
    [L]WTMPLEG=[F:CPY]LEG
  Endif
Endif

If WTMPLEG<>""
  If [L]LEG=""
    [L]LEG = WTMPLEG
  Elsif [L]LEG<>[L]WTMPLEG
    If [L]FCY<>""
      VMESSA=mess(498,197,1)-[F:FCY]FCY-mess(138,187,1)-[F:CPY]LEG
      End [V]CST_AERROR
    Elsif [L]CPY<>""
      VMESSA=mess(142,187,1)-[F:CPY]CPY-mess(138,187,1)-[F:CPY]LEG
      End [V]CST_AERROR
    Endif
  Endif
Endif

If [L]LEG<>""
  Read [TVT]TVT0=[L]VAT;[L]LEG
  If fstat
    Read [TVT]TVT0=[L]VAT;""
  Endif
Else
  Read [TVT]TVT0(1)=[L]VAT
  If !fstat
    [L]LEG = [F:TVT]LEG
  Endif
Endif
If fstat
  Filter [TVT] Where VAT=[L]VAT
  Look [TVT]TVT0 First
  If !fstat
    # Fiche inexistante pour la législation courante
    VMESSA = [L]VAT-":"-mess(232,107,1)-"["+[L]LEG+"]"
  Else
    # Fiche inexistante
    VMESSA = [L]VAT-":"-mess(23,100,1)
  Endif
  Filter [TVT]
  End [V]CST_AERROR
Endif

If dim([F:TVT]ENAFLG)>0 and [F:TVT]ENAFLG <> [V]CST_AYES
  VMESSA = [L]VAT-":"-mess(2,126,1)-"["+[L]LEG+"]" : # Fiche inactive
  End [V]CST_AERROR
Endif

#--Filtrage par groupe de société
#--Dans ce cas particulier ou nous pouvons avoir que le CPY de renseigné (paramètrage pour une société)
#--Du fait du type de donné AGF sur le champ GRP de TABVAT, il n'y aura que le filtrage sur site ! (en fonction de GCURFCY)
If [L]CPY<>"" and [L]FCY=""
  If [F:TVT]GRP<>""
    Local File AGRPFCY    [AGF]
    Read [AGF]AGF0=[F:TVT]GRP
    If !fstat
      If [F:AGF]FLGLEG=2
        #--Société
        If [F:TVT]GRP<>[L]CPY
          VMESSA += [L]VAT+"\"+mess(63,127,1)-":"-[F:TVT]GRP : # Réservé au groupe de société
          End [V]CST_AERROR
        Endif
      Elsif [F:AGF]FLGCPY=2
        Local File AGRPCPY [AGC]
        Look [AGC]AGC0 = [F:TVT]GRP;[L]CPY
        If fstat
          VMESSA += [L]VAT+"\"+mess(63,127,1)-":"-[F:TVT]GRP : # Réservé au groupe de société
          End [V]CST_AERROR
        Endif
      Endif
    Endif
  Endif

Elsif [L]FCY<>""
	## Filtrage par groupe de site

    If [F:TVT]GRP<>""
     Local File FACGROUP [FGR]
     Look [FGR]FGR0 = [F:TVT]GRP;[L]FCY
     If fstat
        VMESSA += [L]VAT-[L]LEG+"\"+mess(23,127,1)-":"-[F:TVT]GRP : # Réservé au groupe de site
        End [V]CST_AERROR
     Endif
    Endif

Elsif [L]CPY<>""
  ## Filtrage par groupe de société

    If [F:TVT]GRP<>""
     Local File AGRPCPY [AGC]
     Look [AGC]AGC0 = [F:TVT]GRP;[L]CPY
     If fstat
        VMESSA += [L]VAT-[L]LEG+"\"+mess(63,127,1)-":"-[F:TVT]GRP : #  # Réservé au groupe de société
        End [V]CST_AERROR
     Endif
    Endif

Endif
#--

#--Contrôle de cohérence entre le groupe de la taxe et la législation
If [F:TVT]GRP<>"" and [L]LEG<>""
  WRET = func TRTVENCTL_SYRA.CTLGFYLEG(CTX, [F:TVT]GRP,[L]LEG,VMESSA) #From TRTVENCTL
  If WRET>=[V]CST_AERROR or VMESSA<>"" : End WRET : Endif
Endif

#--Contrôle de cohérence entre le groupe passé en paramètre et la législation de l'enregistrement retenu
If [L]GROUPE<>"" and [F:TVT]LEG<>""
  WRET = func TRTVENCTL_SYRA.CTLGFYLEG(CTX, [L]GROUPE,[F:TVT]LEG,VMESSA) #From TRTVENCTL
  If WRET>=[V]CST_AERROR or VMESSA<>"" : End WRET : Endif
Endif

#--Contrôle de la cohérence entre le groupe passé en param et celui de la taxe à contrôler
#--uniquement si le groupe passé est renseigné
#--uniquement si pas de contexte site ou société !
If GROUPE<>""
  If [L]CPY="" & [L]FCY="" & [F:TVT]GRP<>"" & [F:TVT]GRP<>[L]GROUPE
    #--Les groupes doivent avoir au moins une société en commun
    Gosub CTLGFYGRP_TVT
    If WRET>=[V]CST_AERROR or VMESSA<>"" : End WRET : Endif
  Endif
Endif

WRET = [V]CST_ASUCCESS

End WRET
#-------------------------------
$CTLGFYGRP_TVT
Local Integer ERR
Local Char    SZVIEW(GLONAVW)
If [F:TVT]LEG=""
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTVTZGRP"
    Local File =SZVIEW [TVTZ]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, pas de contrôle
    Return
  Endif

  Read [F:TVTZ]TVTZ0 = [L]GROUPE;[F:TVT]VAT;[F:TVT]GRP;[F:TVT]LEG
  If fstat
    VMESSA = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:TVT]GRP-":"-mess(178,187,1)
    WRET = [V]CST_AERROR
  Return
  Endif
Else
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTVTYGRP"
    Local File =SZVIEW [TVTY]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, pas de contrôle
    Return
  Endif

  Read [F:TVTY]TVTZ0 = [L]GROUPE;[F:TVT]VAT;[F:TVT]GRP;[F:TVT]LEG
  If fstat
    VMESSA = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:TVT]GRP-":"-mess(178,187,1)
    WRET = [V]CST_AERROR
  Return
  Endif
Endif

Return
######################################################################################
Funprog CONTTVI(CTX, VACITM,LEG,FCY,GROUPE,CPY, VMESSA)
Value Instance   CTX Using C_WMACONTEXT : # Référence sur le contexte
Variable Char    VACITM
Value    Char    LEG
Value    Char    FCY
Value    Char    GROUPE
Value    Char    CPY
Variable Char    VMESSA

Local Integer  WRET : WRET = [V]CST_AOK
Local Char     WTMPLEG(GLONADI)

Raz VMESSA : # 101874 : V9 : Taxe code control

If [L]VACITM="" : End WRET : Endif

Local File TABVACITM [TVI]
Local File COMPANY   [CPY]
Local File FACILITY  [FCY]

If CTX = null
  CTX = GACTX
Endif

If CTX.AFOLD.ANBLEG = 1 Then
  [L]LEG = CTX.AFOLD.ALISTLEG(1)
Endif

#--Cas particulier : pas de GCURLEG mais société ou site en ligne
If ([L]CPY<>"" | [L]FCY<>"")
  If [L]FCY<>""
    Read [F:FCY]FCY0=[L]FCY
    If fstat : Raz [F:FCY] Endif
    If [L]CPY="" : [L]CPY=[F:FCY]LEGCPY : Endif
  Endif
  If [L]CPY<>""
    Read [F:CPY]CPY0=[L]CPY
    If fstat : Raz [F:CPY] Endif
    [L]WTMPLEG=[F:CPY]LEG
   Endif
Endif

If WTMPLEG<>""
  If [L]LEG=""
    [L]LEG = WTMPLEG
  Elsif [L]LEG<>[L]WTMPLEG
    If [L]FCY<>""
      VMESSA=mess(498,197,1)-[F:FCY]FCY-mess(138,187,1)-[F:CPY]LEG
      End [V]CST_AERROR
    Elsif [L]CPY<>""
      VMESSA=mess(142,187,1)-[F:CPY]CPY-mess(138,187,1)-[F:CPY]LEG
      End [V]CST_AERROR
    Endif
  Endif
Endif


If [L]LEG<>""
 Read [TVI]TVI0=[L]VACITM;[L]LEG
 If fstat
  Read [TVI]TVI0=[L]VACITM;""
 Endif
Else
 Read [TVI]TVI0(1)=[L]VACITM
 If !fstat
  [L]LEG = [F:TVI]LEG
 Endif
Endif

If fstat
 Filter [TVI] Where VACITM=[L]VACITM
 Look [TVI]TVI0 First
 If !fstat
  # Fiche inexistante pour la législation courante
  VMESSA= [L]VACITM-":"-mess(232,107,1)-"["+[L]LEG+"]"
 Else
  # Fiche inexistante
  VMESSA = [L]VACITM-":"-mess(23,100,1)
 Endif
 Filter [TVI]
 End [V]CST_AERROR
Endif

If [F:TVI]ENAFLG <> [V]CST_AYES
  VMESSA = [L]VACITM-":"-mess(2,126,1)-"["+[L]LEG+"]" : # Fiche inactive
  End [V]CST_AERROR
Endif

#--Filtrage par groupe de société
#--Dans ce cas particulier ou nous pouvons avoir que le CPY de renseigné (paramètrage pour une société)
#--Du fait du type de donné AGF sur le champ SOC de TABVACITM, il n'y aura que le filtrage sur site ! (en fonction de GCURFCY)
If [L]CPY<>"" and [L]FCY=""
  If [F:TVI]SOC<>""
  	Local File AGRPFCY [AGF]
		Read [AGF]AGF0=[F:TVI]SOC
		If !fstat
  		If [F:AGF]FLGLEG=2
    		#--Société
				If [F:TVI]SOC<>[L]CPY
          VMESSA += [L]VACITM +"\"+mess(63,127,1)-":"-[F:TVI]SOC : # Réservé au groupe de société
          End [V]CST_AERROR
				Endif
  		Elsif [F:AGF]FLGCPY=2
        Local File AGRPCPY [AGC]
        Look [AGC]AGC0 = [F:TVI]SOC;[L]CPY
        If fstat
          VMESSA += [L]VACITM +"\"+mess(63,127,1)-":"-[F:TVI]SOC : # Réservé au groupe de société
          End [V]CST_AERROR
        Endif
      Endif
    Endif
  Endif

Elsif [L]FCY<>""
	## Filtrage par groupe de site

    If [F:TVI]SOC<>""
     Local File FACGROUP [FGR]
     Look [FGR]FGR0 = [F:TVI]SOC;[L]FCY
     If fstat
        VMESSA += [L]VACITM-[L]LEG+"\"+mess(23,127,1)-":"-[F:TVI]SOC : # Réservé au groupe de site
        End [V]CST_AERROR
     Endif
    Endif

Elsif [L]CPY<>""
  ## Filtrage par groupe de société

    If [F:TVI]SOC<>""
     Local File AGRPCPY [AGC]
     Look [AGC]AGC0 = [F:TVI]SOC;[L]CPY
     If fstat
        VMESSA += [L]VACITM-[L]LEG+"\"+mess(63,127,1)-":"-[F:TVI]SOC : #  # Réservé au groupe de société
        End [V]CST_AERROR
     Endif
    Endif

Endif
#--

#--Contrôle de cohérence entre le groupe de la taxe et la législation
If [F:TVI]SOC<>"" and [L]LEG<>""
  WRET = func TRTVENCTL_SYRA.CTLGFYLEG(CTX,[F:TVI]SOC,[L]LEG,VMESSA) #From TRTVENCTL
  If WRET>=[V]CST_AERROR or VMESSA <>"" : End WRET : Endif
Endif

#--Contrôle de cohérence entre le groupe passé en paramètre et la législation de l'enregistrement retenu
If [L]GROUPE<>"" and [F:TVI]LEG<>""
	WRET =func TRTVENCTL_SYRA.CTLGFYLEG(CTX, [L]GROUPE,[F:TVI]LEG,VMESSA) #From TRTVENCTL
	If WRET>=[V]CST_AERROR or VMESSA <>"" : End WRET : Endif
Endif

#--Contrôle de la cohérence entre le groupe passé en param et celui de la taxe à contrôler
#--uniquement si le groupe passé est renseigné
#--uniquement si pas de contexte site ou société !
If [L]GROUPE<>""
  If [L]CPY="" & [L]FCY="" & [F:TVI]SOC<>"" & [F:TVI]SOC<>[L]GROUPE
    #--Les groupes doivent avoir au moins une société en commun
    Gosub CTLGFYGRP_TVI
    If WRET>=[V]CST_AERROR or VMESSA <>"" : End WRET : Endif
  Endif
Endif

WRET= [V]CST_ASUCCESS

End WRET
############################
#  $CTLGFYGRP
############################
$CTLGFYGRP_TVI
Local Integer ERR
Local Char    SZVIEW(GLONAVW)
If [F:TVI]LEG=""
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTVIZGRP"
    Local File =SZVIEW [TVIZ]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, pas de contrôle
    Return
  Endif

  Read [F:TVIZ]TVIZ0 = [L]GROUPE;[F:TVI]VACITM;[F:TVI]SOC;[F:TVI]LEG
  If fstat
    VMESSA = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:TVI]SOC-":"-mess(178,187,1)
    WRET = [V]CST_AERROR
    Return
  Endif
Else
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTVIYGRP"
    Local File =SZVIEW [TVIY]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, pas de contrôle
    Return
  Endif

  Read [F:TVIY]TVIY0 = [L]GROUPE;[F:TVI]VACITM;[F:TVI]SOC;[F:TVI]LEG
  If fstat
    VMESSA = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:TVI]SOC-":"-mess(178,187,1)
    WRET = [V]CST_AERROR
    Return
  Endif
Endif

Return
######################################################################################
#-- Données par législation pour le Condition de paiement
######################################################################################
Funprog CONTTPT (CTX,COD,LEG,FCY,GROUPE,CPY,VMESSA)
Value Instance   CTX Using C_WMACONTEXT : # Référence sur le contexte
Value    Char    COD
Value    Char    LEG
Value    Char    FCY
Value    Char    GROUPE
Value    Char    CPY
Variable Char    VMESSA

#Local Integer WNBTOT, WI, WNO_ERR,  WENROK
#Local Char    WLEG  (GLONADI), WMESS1 (120), WMESS2 (120), WMESS3 (120)

Local Integer  WRET : WRET = [V]CST_AOK
Local Char     WTMPLEG(GLONADI)

#--Cas particulier : pas de GCURLEG mais société ou site en ligne
Local File COMPANY    [CPY]
Local File FACILITY   [FCY]
Local File TABPAYTERM [TPT]

Raz VMESSA : # 101874 : V9 : Taxe code control

If [L]COD="" : End WRET : Endif

If CTX = null
  CTX = GACTX
Endif

If CTX.AFOLD.ANBLEG = 1 Then
  [L]LEG = CTX.AFOLD.ALISTLEG(1)
Endif

#--Cas particulier : pas de GCURLEG mais société ou site en ligne
If ([L]CPY<>"" | [L]FCY<>"")
 If [L]FCY<>""
  Read [F:FCY]FCY0=[L]FCY
  If fstat : Raz [F:FCY] Endif
  If [L]CPY="" : [L]CPY=[F:FCY]LEGCPY : Endif
 Endif

 If [L]CPY<>""
  Read [F:CPY]CPY0=[L]CPY
  If fstat : Raz [F:CPY] Endif
  [L]WTMPLEG=[F:CPY]LEG
 Endif
Endif

If [L]WTMPLEG<>""
  If [L]LEG=""
    [L]LEG = [L]WTMPLEG
  Elsif [L]LEG<>[L]WTMPLEG
    If [L]FCY<>""
      WRET = [V]CST_AERROR
      VMESSA=mess(498,197,1)-[F:FCY]FCY-mess(138,187,1)-[F:CPY]LEG
      End WRET
    Elsif [L]CPY<>""
      VMESSA=mess(142,187,1)-[F:CPY]CPY-mess(138,187,1)-[F:CPY]LEG
      End [V]CST_AERROR
    Endif
  Endif
Endif
If [L]LEG<>""
 Read [TPT]TPT0=[L]COD;[L]LEG;1
 If fstat
  Read [TPT]TPT0=[L]COD;"";1
 Endif
Else
 Read [TPT]TPT0(1)=[L]COD
 If !fstat
  [L]LEG = [F:TPT]LEG
 Endif
Endif
If fstat
 Filter [TPT] Where PTE=[L]COD
 Look [TPT]TPT0 First
 If !fstat
  # Fiche inexistante pour la législation courante
  VMESSA = [L]COD-":"-mess(232,107,1)-"["+[L]LEG+"]"
 Else
  # Fiche inexistante
  VMESSA = [L]COD-":"-mess(23,100,1)
 Endif
 Filter [TPT]
 End [V]CST_AERROR
Endif

If dim([F:TPT]ENAFLG)>0 and [F:TPT]ENAFLG <> [V]CST_AYES
  VMESSA = [L]COD-":"-mess(2,126,1)-"["+[L]LEG+"]" : # Fiche inactive
  End [V]CST_AERROR
Endif

#----------------------------------------------------------------------------------------------------------------------#
#--Filtrage par groupe de société3

#--Dans ce cas particulier ou nous pouvons avoir que le CPY de renseigné (paramètrage pour une société)
#--Du fait du type de donné AGF sur le champ GFY de TABPAYTERM, il n'y aura que le filtrage sur site ! (en fonction de GCURFCY)
#----------------------------------------------------------------------------------------------------------------------#
If [L]CPY<>"" and [L]FCY=""
  If [F:TPT]GFY<>""
    Local File AGRPFCY [AGF]
    Read [AGF]AGF0=[F:TPT]GFY
    If !fstat
      If [F:AGF]FLGLEG=2
        #--Société
        If [F:TPT]GFY<>[L]CPY
          VMESSA += [L]COD+"\"+mess(63,127,1)-":"-[F:TPT]GFY : # Réservé au groupe de société
          End [V]CST_AERROR
        Endif
      Elsif [F:AGF]FLGCPY=2
        Local File AGRPCPY [AGC]
        Look [AGC]AGC0 = [F:TPT]GFY;[L]CPY
        If fstat
          VMESSA += [L]COD+"\"+mess(63,127,1)-":"-[F:TPT]GFY : # Réservé au groupe de société
          End [V]CST_AERROR
        Endif
      Endif
    Endif
  Endif

Elsif [L]FCY<>""
	## Filtrage par groupe de site

    If [F:TPT]GFY<>""
     Local File FACGROUP [FGR]
     Look [FGR]FGR0 = [F:TPT]GFY;[L]FCY
     If fstat
        VMESSA += [L]COD-[L]LEG+"\"+mess(23,127,1)-":"-[F:TPT]GFY : # Réservé au groupe de site
        End [V]CST_AERROR
     Endif
    Endif

Elsif [L]CPY<>""
  ## Filtrage par groupe de société

    If [F:TPT]GFY<>""
     Local File AGRPCPY [AGC]
     Look [AGC]AGC0 = [F:TPT]GFY;[L]CPY
     If fstat
        VMESSA += [L]COD-[L]LEG+"\"+mess(63,127,1)-":"-[F:TPT]GFY : #  # Réservé au groupe de société
        End [V]CST_AERROR
     Endif
    Endif

Endif
#--

#--Contrôle de cohérence entre le groupe  et la législation
If [F:TPT]GFY<>"" and [L]LEG<>""
  WRET = func TRTVENCTL_SYRA.CTLGFYLEG(CTX,[F:TPT]GFY,[L]LEG,VMESSA) #From TRTVENCTL
  If WRET>=[V]CST_AERROR or VMESSA<>"" : End WRET : Endif
Endif
#--Contrôle de cohérence entre le groupe passé en paramètre et la législation de l'enregistrement retenu
If [L]GROUPE<>"" and [F:TPT]LEG<>""
  WRET = func TRTVENCTL_SYRA.CTLGFYLEG(CTX,[L]GROUPE,[F:TPT]LEG,VMESSA) #From TRTVENCTL
  If WRET>=[V]CST_AERROR or VMESSA<>"" : End WRET : Endif
Endif

#--Contrôle de la cohérence entre le groupe passé en param et celui courant
#--uniquement si pas de contexte site ou société !
#--Il faut que le groupe  et celui du paramétrage aient au moins une soc en commun
If [L]GROUPE<>""
  If [L]CPY="" & [L]FCY="" & [F:TPT]GFY<>"" & [F:TPT]GFY<>GROUPE
    #--Les groupes doivent avoir au moins une société en commun
    Gosub CTLGFYGRP_TPT
    If WRET>=[V]CST_AERROR or VMESSA<>"" : End WRET : Endif
  Endif
Endif

WRET = [V]CST_ASUCCESS

End WRET

###############################
$CTLGFYGRP_TPT
Local Integer ERR
Local Char    SZVIEW(GLONAVW)
If [F:TPT]LEG=""
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTPTZGRP"
    Local File =SZVIEW [TPTZ]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, pas de contrôle
    Return
  Endif

  Read [F:TPTZ]TPTZ0 = [L]GROUPE;[F:TPT]PTE;[F:TPT]GFY;[F:TPT]LEG
  If fstat
    VMESSA = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:TPT]GFY-":"-mess(178,187,1)
    WRET = [V]CST_AERROR
    Return
  Endif
Else
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTPTYGRP"
    Local File =SZVIEW [TPTY]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    #-- Si problème, pas de contrôle
    Return
  Endif

  Read [F:TPTY]TPTY0 = [L]GROUPE;[F:TPT]PTE;[F:TPT]GFY;[F:TPT]LEG
  If fstat
   VMESSA = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:TPT]GFY-":"-mess(178,187,1)
   WRET = [V]CST_AERROR
   Return
  Endif
Endif
Return





