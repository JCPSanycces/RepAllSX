#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion objet TKI
Call OBJET ("TKI", GBIDC1, GBIDC2) From GOBJET
End

#######################################################################
# SUBTKI : Interrogation suivis par OF                                #
#######################################################################
#######################################################################
# (version modelisée du FUNMTKI V130)                 MM - JUIN  2003 #
#######################################################################
$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE   
 When "FILTRE"     : Gosub FILTRE    
 When "LIENS"      : Gosub LIENS
 When "CLE_GAUCHE" : Gosub CLE_GAUCHE
 When "FERME"      : Gosub FERME                # 12.05 33913
 When default
Endcase
Return


#######################################################################
$OUVRE       
If clalev ([F:MKI]) <= 0 : Local File MFGITMTRK  [MKI] : Endif 
If clalev ([F:MKM]) <= 0 : Local File MFGMATTRK  [MKM] : Endif 
If clalev ([F:MKO]) <= 0 : Local File MFGOPETRK  [MKO] : Endif 
If clalev ([F:ITM]) <= 0 : Local File ITMMASTER  [ITM] : Endif
If clalev ([F:MWS]) <= 0 : Local File WORKSTATIO [MWS] : Endif  
If clalev ([F:MTK]) <= 0 : Local File MFGHEADTRK [MTK] : Endif
If clalev ([F:MFO]) <= 0 : Local File MFGOPE     [MFO] : Endif
GCONSULT = 1
Return

#######################################################################
# 12.05 33913
$FERME
GCONSULT = 0
Return

#######################################################################
$FILTRE    
Default File [MFG]
FILTSUP+="MFGTRKFLG>3"  
Return

#######################################################################
$LIENS   
Local Integer I

Read [MFG]MFG0=[M:MKI0]MFGNUM
If fstat : Return : Endif
#
[M:MKI0]MFGSTA  = [F:MFG]MFGSTA
[M:MKI0]XMFGSTA = mess([M:MKI0]MFGSTA,317,1)
#
I=0
For [MKI]MKI1 Where MFGNUM=[M:MKI0]MFGNUM                    # llc 05.02 14394 Performances
    # llc 04.02    12772
    nolign = I + 1
    [M:MKI1] = [F:MKI]

    [M:MKI1]CPLQTY(I)     = [F:MKI]CPLQTY
    [M:MKI1]FMI(I)        = [F:MKI]FMI
    [M:MKI1]IPTDAT(I)     = [F:MKI]IPTDAT
    [M:MKI1]ITMREF(I)     = [F:MKI]ITMREF
    [M:MKI1]MFGTRKNUM(I)  = [F:MKI]MFGTRKNUM
    [M:MKI1]STU(I)        = [F:MKI]STU
    [M:MKI1]UOM(I)        = [F:MKI]UOM
    [M:MKI1]UOMCPLQTY(I)  = [F:MKI]UOMCPLQTY
    [M:MKI1]UOMSTUCOE(I)  = [F:MKI]UOMSTUCOE
    Read [ITM]ITM0 = [F:MKI]ITMREF
    #If !fstat : [M:MKI1]ITMDES1(I) = [F:ITM]ITMDES1 : Endif
    If !fstat
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MKI1]ITMDES1(I), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    Endif
    I += 1
Next
[M:MKI1]NBLIG = I
#
I=0
For [MKM]MKM1 Where MFGNUM=[M:MKI0]MFGNUM                    # llc 05.02 14394 Performances
    # llc 04.02    12772
    nolign = I + 1
    [M:MKI2] = [F:MKM]
    [M:MKI2]MATTYP(I)     = [F:MKM]MATTYP
    [M:MKI2]BOMSEQ(I)     = [F:MKM]BOMSEQ
    [M:MKI2]CUMMATSUI(I)  = [F:MKM]CUMMATSUI
    [M:MKI2]IPTDAT(I)     = [F:MKM]IPTDAT
    [M:MKI2]MFGTRKNUM(I)  = [F:MKM]MFGTRKNUM
    [M:MKI2]MFMITMREF(I)  = [F:MKM]ITMREF
    [M:MKI2]STU(I)        = [F:MKM]STU
    [M:MKI2]USEQTY(I)     = [F:MKM]USEQTY
    If dim([M:MKI2]TYPQTY(I)) > 0 : [M:MKI2]TYPQTY(I)     = [F:MKM]TYPQTY 
                                    If [M:MKI2]TYPQTY(I) = 0
                                       [M:MKI2]TYPQTY(I) = 2
                                    Endif
    Endif
    Read [ITM]ITM0 = [F:MKM]ITMREF
    #If !fstat : [M:MKI2]ITMDES1(I) = [F:ITM]ITMDES1 : Endif
    If !fstat
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MKI2]ITMDES1(I), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    Endif
    I += 1
Next
[M:MKI2]NBLIG = I
#
I=0
For [MKO]MKO1 Where MFGNUM=[M:MKI0]MFGNUM                    # llc 05.02 14394 Performances
    # llc 04.02    12772
    nolign = I + 1
    [M:MKI3] = [F:MKO]
    # sr 06.02 afficher la date de suivi dans l'onglet opération demande 14436
    Read [F:MTK]MTK0 = [F:MKO]MFGTRKNUM
    If fstat : Raz [F:MTK] : Endif
    [M:MKI3]MFGTRKDAT(I) = [F:MTK]MFGTRKDAT
    Read [F:MFO]MFO0 = [F:MKO]MFGNUM;[F:MKO]OPENUM;[F:MKO]OPESPLNUM
    If fstat : Raz [F:MFO] : Endif
    Read [MWS]WST0=[F:MKO]CPLWST;[F:MKO]MFGFCY
    If !fstat
        [M:MKI3]CPLWCR(I)    = [F:MWS]WCR
        [M:MKI3]CPLWSTTYP(I) = [F:MWS]WSTTYP
    Endif  
    Read [MWS]WST0=[F:MKO]CPLLAB;[F:MKO]MFGFCY
    If !fstat
        [M:MKI3]CPLLABWCR(I) = [F:MWS]WCR
    Endif  
    I += 1
Next
[M:MKI3]NBLIG = I

# CCC (01/08/08) Bug 48617 : le champ SCANUM est dimensionné dans la table MKO => le transclasse s'y perd
Raz I
Columns [MKO] (SCANUM)
For [MKO]MKO1 Where MFGNUM=[M:MKI0]MFGNUM
    [M:MKI3]SCANUM(I)     = [F:MKO]SCANUM(0)
    I+=1
Next
Columns [MKO]
#


Return

#######################################################################
$CLE_GAUCHE  
CLELISTE = "STRDAT desc;MFGNUM desc"
Return
