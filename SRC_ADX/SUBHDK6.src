#<AdxTL>@(#)11.0.0.0 $Revision$ Gestion du masque HDK6
########################################
Subprog AM_HDKFCY(VALEUR)
Variable Char    VALEUR()

  Raz [M:HDK6]NBREP
  Raz [M:HDK6]HDKREP
  Raz [M:HDK6]NBRSRE
  [M:HDK6]HDKFCY = VALEUR
  Gosub LOADREP From TRTHDK6
  If [M:HDK6]HDKFCY = "" and VALEUR <> "" Then
    VALEUR = ""
    GMESSAGE = mess(320,196,1) #Aucun collaborateur n'est affecté à ce site. Tous les collaborateurs vont être affichés.
    GERR = 2
  Endif
End

########################################
Subprog AS_NBREP

  If nolign > 0 Then
    GSZSELREP = [M:HDK6]HDKREP(nolign-1)
  Endif
End

########################################
Subprog C_NBREP

  If nolign > 0 Then
    GSZSELREP = [M:HDK6]HDKREP(nolign-1)
  Endif
End

##########################################################################
Subprog IB_NBREP
Local Integer ISOPEN

  ISOPEN = 0
  Raz GBOUT1
  Raz GBOUT2
  #Détail
  Call TEXTE(5562, GBOUT1) From OBJDIV
  Call ISFUNOPEN("GESSRE", ISOPEN) From CRMUTIL140
  If !ISOPEN Then
    #Demandes de service
    Call TEXTE(14508, GBOUT2) From OBJDIV
  Endif
End
