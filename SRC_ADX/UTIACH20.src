#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################
# UTIACH20      Utilitaire de resynchronisation des         Module ACHAT #
#               lignes comptabilisées en entête                          #
#               de réception                                  19/07/2010 #
# ---------------------------------------------------------------------- #
# Champs de l'entête de réception vérifiés et réajustés si nécessaire    #
#   [F:PTH]LINNBR    : Nombre de lignes de la réception                  #
#   [F:PTH]INVLINNBR : Nombre de lignes entièrement facturée             #
#   [F:PTH]PSTLINNBR : Nombre de lignes comptabilisées (FAR)             #
#   [F:PTH]INVFLG    : Indicateur facturé (1=Non, 2=Partiel, 3=Total)    #
#   [F:PTH]PSTFLG    : Indicateur totalement comptabilisé (1=Non, 2=Oui) #
# ---------------------------------------------------------------------- #
# Une réception est considérée comme totalement comptabilisée si         #
#   - PSTFLG = 3                                                         #
#   - INVLINNBR + PSTLINNBR supérieur ou égal à LINNBR                   #
##########################################################################


Call MAJ_UTIACH20
End


Subprog MAJ_UTIACH20
Local Char DOSSIER(30)
DOSSIER=nomap
Call SAIDOS(DOSSIER,"UTIACH20 - Resynchro lignes comptabilisées en réception") From SAIDOS
If DOSSIER<>""
  #-----
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIACH20 : Utilitaire resynchro lignes comptabilisées en réception") From LECFIC
  Call EXE_UTIACH20(DOSSIER)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
End


Subprog EXE_UTIACH20(DOSSIER)
Value Char     DOSSIER
#----- Variables locales -----#
Local Char     WMSG(90), WCRITERE(100)
Local Integer  NBENR, NBCOR
Local Char     WCLE1(GLONPTH)
Local Char     WPTHNUM(GLONPTH)
Local Integer WCOMPTEUR, WSTOP
Local Integer  WINVLINNBR, WPSTLINNBR, WINVCTR, WLINNBR
Local Libelle  WINVFLG, WPSTFLG, WFLAG
Local Libelle  WTRACE : WTRACE=2 : # WTRACE=2 --> Trace détaillée
#-----
Call ECR_TIME("UTIACH20 : Début traitement du dossier "+DOSSIER) From DOSSUB
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
#----- Ouverture des fichiers -----#
If !clalev([F:PTH])  Local File =DOSSIER+".PRECEIPT"    [PTH] : Endif
If !clalev([F:PTD])  Local File =DOSSIER+".PRECEIPTD"   [PTD] : Endif
#----- Début du traitement -----#
Raz NBENR, NBCOR
Gosub TRT_PSTLIN
#----- Fin du traitement -----#
$FIN_UTIACH20
Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
WMSG ="UTIACH20 : Nbre d'enregistrements traités :"-num$(NBENR)
WMSG+=" dont corrigés :"-num$(NBCOR)
Call ECR_TIME(WMSG) From DOSSUB
Close Local File [PTH], [PTD] 
End


#------------#
# Traitement #
#------------#
$TRT_PSTLIN
Call DEBTRANS From GLOCK
Raz WCLE1, WSTOP
#-----
$BOUCLE_PSTLIN
GOK=1
#sr 08.12 Demande 84225
If WSTOP=1
   WSTOP=0 : WCRITERE='PTHNUM>'+'"'+num$(WCLE1)+'"'  
Else
  WCRITERE="1=1"
Endif
Raz WCOMPTEUR
#-----
Trbegin [PTH]
  For [PTH] PTH1 Where evalue(WCRITERE)
    NBENR+=1
    WPTHNUM=[F:PTH]PTHNUM
    Raz WINVLINNBR, WPSTLINNBR, WINVCTR, WLINNBR, WFLAG
    #-----
    For [PTD] PTD1 Where PTHNUM=[F:PTH]PTHNUM
      WLINNBR+=1
      If [F:PTD]LININVFLG=2  WINVLINNBR+=1 : Endif
      If [F:PTD]LINPSTFLG=2  WPSTLINNBR+=1 : Endif
      If [F:PTD]INVQTYPUU<>0 | [F:PTD]INVQTYSTU<>0
        WINVCTR+=1
      Endif
    Next
    #-----
    If [F:PTH]INVFLG<>3
      If WINVLINNBR>=WLINNBR
        WINVFLG=3
      Elsif WINVLINNBR<>0 | WINVCTR<>0
        WINVFLG=2
      Else
        WINVFLG=1
      Endif
    Else
      WINVFLG=[F:PTH]INVFLG
    Endif
    #-----
    If WPSTLINNBR>=WLINNBR
      WPSTFLG=2
    Else
      WPSTFLG=1
    Endif
    #-----
    If [F:PTH]LINNBR<>WLINNBR
      WFLAG=1
      If WTRACE=2
        WMSG ="Réception"-[F:PTH]PTHNUM-string$(1+GLONPTH-len([F:PTH]PTHNUM),".")
        WMSG-="LINNBR    :"-num$([F:PTH]LINNBR)-"-->"-num$(WLINNBR)
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
    Endif
    If [F:PTH]INVLINNBR<>WINVLINNBR
      WFLAG=1
      If WTRACE=2
        WMSG ="Réception"-[F:PTH]PTHNUM-string$(1+GLONPTH-len([F:PTH]PTHNUM),".")
        WMSG-="INVLINNBR :"-num$([F:PTH]INVLINNBR)-"-->"-num$(WINVLINNBR)
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
    Endif
    If [F:PTH]PSTLINNBR<>WPSTLINNBR
      WFLAG=1
      If WTRACE=2
        WMSG ="Réception"-[F:PTH]PTHNUM-string$(1+GLONPTH-len([F:PTH]PTHNUM),".")
        WMSG-="PSTLINNBR :"-num$([F:PTH]PSTLINNBR)-"-->"-num$(WPSTLINNBR)
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
    Endif
    If [F:PTH]INVFLG<>WINVFLG
      WFLAG=1
      If WTRACE=2
        WMSG ="Réception"-[F:PTH]PTHNUM-string$(1+GLONPTH-len([F:PTH]PTHNUM),".")
        WMSG-="INVFLG    :"-num$([F:PTH]INVFLG)-"-->"-num$(WINVFLG)
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
    Endif
    If [F:PTH]PSTFLG<>WPSTFLG
      WFLAG=1
      If WTRACE=2
        WMSG ="Réception"-[F:PTH]PTHNUM-string$(1+GLONPTH-len([F:PTH]PTHNUM),".")
        WMSG-="PSTFLG    :"-num$([F:PTH]PSTFLG)-"-->"-num$(WPSTFLG)
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
    Endif
    #-----
    If WFLAG
      Update [PTH] Where PTHNUM=WPTHNUM
&                  With LINNBR=WLINNBR, INVLINNBR=WINVLINNBR, PSTLINNBR=WPSTLINNBR, INVFLG=WINVFLG, PSTFLG=WPSTFLG
      If fstat
        WMSG=mess(13,100,1)-"PRECEIPT"-WPTHNUM
        Call ECR_TRACE(WMSG-"Error="+num$(fstat),1) From GESECRAN
        WSTOP=0 : Break
      #-----
      Endif
      WCOMPTEUR+=1 : NBCOR+=1
    Endif
    #-----
    If WCOMPTEUR>GMAXUPDTRS
      WCLE1=[F:PTH]PTHNUM : WSTOP=1 : Break
    Endif
  Next
Commit
#-----
If WSTOP  Goto BOUCLE_PSTLIN : Endif
#-----
Return


###################################################
# Pour exécution automatique  en gestion de patch #
###################################################
Subprog PATCH (DOSSIER)
Value Char DOSSIER
#-----
End : # Il n'est pas nécessaire de lancer cet utilitaire !
If DOSSIER=GDOSX3  End : Endif
#-----
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=DOSSIER : If fstat  Raz [F:ADS] : Endif
#-----
If [F:ADS]MODULE(5)=2
  Call EXE_UTIACH20(DOSSIER)
Endif
#-----       
End


#########################################################
# Pour exécution depuis DOSMAJ au changement de version #
#########################################################
Subprog UTI_MOUL (DOSSIER)
Value Char DOSSIER
#-----
End : # Il n'est pas nécessaire de lancer cet utilitaire !
If DOSSIER=GDOSX3  End : Endif
#-----
If [F:ADS]MODULE(5)=2
  Call EXE_UTIACH20(DOSSIER)
Endif
#-----
End
