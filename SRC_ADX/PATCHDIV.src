#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char PARAM(30)(1..1) , VALEUR(250)
Call TRAITE_CHAR(VALEUR,PARAM,"","PATCH","PATCH",3,"") From GTRAITE
End

##################################################
## Intégration d'une table quelconque
##################################################
$DIVERS
If left$(TYPOBJ,1)="~"
 TYPOBJ = right$(TYPOBJ,2)
Endif
Read [ATB]ABRFIC = TYPOBJ
If fstat
 Call ECR_TRACE("---"-mess(34,115,1),0) From GESECRAN
# Type d'objet inconnu
 Gosub FIN_OBJ From PATCH
 Return
Endif
If [F:ATB]TYPFIC=3 & APPLI<>GDOSX3
 Call ECR_TRACE("---"-TYPOBJ-":"-func AFNC.MES(mess(155,139,1),GDOSX3),0) From GESECRAN
# Ce type d'objet ne peut être intégré que dans le dossier
 Gosub FIN_OBJ From PATCH
 Return
Endif
If filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",DOSSIER(D)),0)<0
 Call ECR_TRACE([F:ATB]CODFIC-":"-mess(124,124,1),0) From GESECRAN
# Table inexistante
 Gosub FIN_OBJ From PATCH
 Return
Endif
Read [ATI]NUMLIG(2) = [F:ATB]CODFIC;1
If fstat
 Call ECR_TRACE("---"-mess(34,115,1),0) From GESECRAN
# Type d'objet inconnu
 Gosub FIN_OBJ From PATCH
 Return
Endif
Gosub SET_FLDLEG
NBCLE = 0
CHAINE = [F:ATI]DESCRIPT
While CHAINE<>""
 I1 = instr(1,CHAINE,"+")
 I2 = instr(1,CHAINE,"-")
 If    I1 & I2  : I1 = min(I1,I2)
 Elsif I2 & !I1 : I1 = I2
 Endif
 If I1
  SCHAINE = left$(CHAINE,I1-1) : CHAINE = right$(CHAINE,I1+1)
 Else
  SCHAINE = CHAINE : CHAINE = ""
 Endif
 If SCHAINE<>""
  NBCLE += 1
  CLE(NBCLE) = SCHAINE
 Endif
Wend
If TYPOBJ="ACC"
 Gosub ACCES
Else
 If TYPENR=2 :#SCM deletion
  FICHIER = [F:ATB]CODFIC : ABR = "NEW"
  Local File =DOSSIER(D)+"."+[F:ATB]CODFIC [OLD]
  Local File =DOSSIER(D)+"."+[F:ATB]CODFIC [NEW]
  If TABLNK<>"" : Local File =DOSSIER(D)+"."+TABLNK [AREF] : Endif
  Call DEBTRANS From GLOCK
  Gosub TR_DIV
  Close Local File [OLD] , [NEW]
  If clalev([AREF])>0 : Close Local File [AREF] : Endif
 Elsif TYPENR=-2 :#SCM deletion
  Local File =DOSSIER(D)+"."+[F:ATB]CODFIC [NEW]
  Gosub DEL_DIV
  Onerrgo
  Close Local File [NEW]
  Gosub FIN_OBJ From PATCH
 Endif
Endif
Return

$ERR
Call ECR_TRACE("|"+errp-mess(93,100,1)-num$(errl)+"\"+errmes$(errn)-errm,1) From GESECRAN
Call ECR_TRACE("|"+mess(1,115,1),1) From GESECRAN :  # SUPPRESSION IMPOSSIBLE
ER = 1
Resume

$DEL_DIV
Local Char DIVCLE(250)(0..)
Local Integer POS, INDCLE
Raz DIVCLE, INDCLE
[L]DIVCLE(0) = NOMOBJ
POS = instr(1,NOMOBJ,"~")
While POS>0
    DIVCLE(INDCLE+1) = right$(DIVCLE(INDCLE),POS+1)
    DIVCLE(INDCLE) = left$(DIVCLE(INDCLE),POS-1)
    INDCLE +=1
    POS = instr(1,DIVCLE(INDCLE),"~")
Wend

Call ECR_TRACE("TYPOBJ"-TYPOBJ-"NOMOBJ"-NOMOBJ-sigma(0,INDCLE," DIVCLE("+num$(indcum)+")='"+DIVCLE(indcum)+"'")-"[F:ATB]CODFIC="+[F:ATB]CODFIC,0) From GESECRAN
Onerrgo ERR
Case TYPOBJ
 When "AAR" : Filter [NEW] Where CODPAR=NOMOBJ

 When "AI0" : Filter [NEW] Where CODE=NOMOBJ

 When "AOP" : Filter [NEW] Where OBJ=NOMOBJ

 When "APP" : Filter [NEW] Where APPTYP = val([L]DIVCLE(0))
&                            and APPCOD = [L]DIVCLE(1)

 When "ARV" : Filter [NEW] Where FONCTION = [L]DIVCLE(0)
&                            and TYPCOD   = val([L]DIVCLE(1))
&                            and ETAT     = [L]DIVCLE(2)

 When "ARX" : Filter [NEW] Where INTCOD=NOMOBJ

 When "ASB" : Filter [NEW] Where CAT    = [L]DIVCLE(0)
&                            and CODFIC = [L]DIVCLE(1)

 When "ATP" : Filter [NEW] Where CODFA=NOMOBJ

 When "AVR" : Filter [NEW] Where TYP = val([L]DIVCLE(0))
&                            and FCT = [L]DIVCLE(1)

 When "TCA" : Filter [NEW] Where MODULE = val([L]DIVCLE(0))
&                            and LEG    = [L]DIVCLE(1)

 When "GTC" : Filter [NEW] Where CNSCOD = [L]DIVCLE(0)
&                            and COD    = [L]DIVCLE(1)
 When Default : Return
Endcase
If ER>0 : Return : Endif
Read [NEW] First
Filter [NEW]
If !fstat
  Gosub DEF_WWCLE
  Call DEBTRANS From GLOCK
  Trbegin [NEW]
   Case TYPOBJ
    When "AOP"
     Delete [AXX] Where CODFIC="AOBJPROP" & ZONE = "INTIT"  & IDENT1=[L]DIVCLE(0)
     Delete [NEW] Where CODE=[L]DIVCLE(0)

    When "ARV"
     Delete [NEW] Where FONCTION = [L]DIVCLE(0)
&                   and TYPCOD   = val([L]DIVCLE(1))
&                   and ETAT     = [L]DIVCLE(2)

    When "ARX"
     Delete [NEW] Where INTCOD=[L]DIVCLE(0)

    When "AVR"
     Delete [NEW] Where TYP = val([L]DIVCLE(0))
&                   and FCT = [L]DIVCLE(1)

    When "GTC"
     Delete [AXX] Where CODFIC="GTABACC" & ZONE = "INTIT"  & IDENT1=[L]DIVCLE(0) & IDENT2=[L]DIVCLE(1)
     Delete [NEW] Curr

    When "TCA"
     Delete [NEW] Where MODULE=val([L]DIVCLE(0)) and LEG=[L]DIVCLE(1)

    When Default
     Delete [NEW] Curr

   Endcase
  If fstat
    Rollback
    GOK = 0 : ER = 99 : ERFIC = [F:ATB]CODFIC
    Return
  Else
    Commit
  Endif
  If [L]ISOKSPOTTING=2
   If TYPOBJ="AI0"
    Call TRACE_COR_PATCH("AM3",WWCLE1,WWCLE2,"A") From GOBJET
   Else
    Call TRACE_COR_PATCH(TYPOBJ,WWCLE1,WWCLE2,"A") From GOBJET
   Endif
  Endif
  Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Endif
Return

$TR_DIV
Local Integer DIV : DIV=0
NBENR = 0
Trbegin [OLD] , [NEW]
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Le fichier
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "DIV"
      DIV=1
      Gosub DIV1
     When "sel","glo" : # Fichier mémos transférés avec type AOS
      FIC = [F:NEW]USR+"_"+[F:NEW]CODE+"_"+[F:NEW]MEMO
      If [F:NEW]ALL=2
       FIC += ".glo"
      Else
       FIC += ".sel"
      Endif
      Gosub MEMOS
     When Default
      ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER : Break : Endif
 Until 1=0
 If ER
  Repeat
   Gosub LIRE From PATCH
   If TYPENR=7 : Break : Endif
  Until 1=0
  Goto ABORT
 Endif
Commit
If DIV & [L]ISOKSPOTTING=2 :
 Gosub DEF_WWCLE
 Call TRACE_COR_PATCH(TYPOBJ,WWCLE1,WWCLE2,string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET :
Endif
# Validation/Enregistrements mis à jour
If left$(NOMOBJ,11)="(CREDATTIM>="
 Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-FICHIER-"("+num$(NBENR)-mess(192,124,1)+")",0) From GESECRAN
Else
 Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ-"("+num$(NBENR)-mess(192,124,1)+")",0) From GESECRAN
Endif
Return

$DEF_WWCLE
Local Char WWCLE1(250), WWCLE2(250)(0..16)
Case TYPOBJ
 When "AI0" :  WWCLE1=num$(evalue("[F:NEW]CODE"))
 When "AAR" :  WWCLE1=num$(evalue("[F:NEW]CODPAR"))
 When "APP" :  WWCLE1=num$(evalue("[F:NEW]APPCOD")) : WWCLE2(0)=num$(evalue("[F:NEW]APPTYP"))
 When "ARV" :  WWCLE1=num$(evalue("[F:NEW]TYPCOD")) : WWCLE2(0)=num$(evalue("[F:NEW]FONCTION")) : WWCLE2(1)=num$(evalue("[F:NEW]ETAT")) : WWCLE2(2)=num$(evalue("[F:NEW]PARAM"))
 When "APE" :  WWCLE1=num$(evalue("[F:NEW]OBJ")) :    WWCLE2(0)=num$(evalue("[F:NEW]TRTSTD")) : WWCLE2(1)=num$(evalue("[F:NEW]TRTSPE"))
 When "AVR" :  WWCLE1=num$(evalue("[F:NEW]FCT")) :    WWCLE2(0)=num$(evalue("[F:NEW]TYP")) :    WWCLE2(1)=num$(evalue("[F:NEW]COD"))
 When "ATP" :  WWCLE1=num$(evalue("[F:NEW]CODFA"))
 When "ASB" :  WWCLE1=num$(evalue("[F:NEW]CODFIC")) :    WWCLE2(0)=num$(evalue("[F:NEW]CAT"))
 When "ARX" :  WWCLE1=num$(evalue("[F:NEW]INTCOD"))
 When "GTC" :  WWCLE1=num$(evalue("[F:NEW]COD")) : WWCLE2(0)=num$(evalue("[F:NEW]CNSCOD"))
 When "AMM" :  WWCLE1=num$(evalue("[F:NEW]MEMO"))
 When "AOP" :  WWCLE1=num$(evalue("[F:NEW]OBJ")) :     WWCLE2(0)=num$(evalue("[F:NEW]NUM"))
 When "TCA" :  WWCLE1=num$(evalue("[F:NEW]LEG")) :    WWCLE2(0)=num$(evalue("[F:NEW]MODULE")) : WWCLE2(1)=num$(evalue("[F:NEW]CPY"))
Endcase
Return

$DIV1
ACT = 0
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  If VARIA="CODACT"
   ACT = 1
  Endif
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
CHAINE = ""
For I1=1 To NBCLE
 If CHAINE<>"" : CHAINE += "/" : Endif
 CHAINE += num$(evalue("[F:NEW]"+CLE(I1)))
Next I1
If FLDLEG<>""
 Gosub SET_NEWLEG
 If NEWLEG<>"" & !find(NEWLEG,LEGREF(1..NBLEGREF))
  # Législation non gérée par le dossier
  Call ECR_TRACE("---"-CHAINE-"("+NEWLEG+")"-":"-mess(249,133,1)-DOSSIER(D),0) From GESECRAN
  Return
 Endif
Endif
[F:OLD] = [F:NEW]
Case TYPOBJ
 When "APE"
  Read [OLD] =
  If !fstat
   [F:NEW]RNG = [F:OLD]RNG
  Endif
 When "ANX"
  Local File =DOSSIER(D)+".AINDEX" [OLD2]
  I1 = 0
  For [OLD2]
   I1 = max(I1,[F:OLD2]LIG)
  Next OLD2
  Read [OLD]ANX2 =
  If !fstat
   Delete [OLD] Curr
  Endif
  fstat = 5
  Close Local File [OLD2]
  [F:NEW]LIG = I1+1
 When Default
  [G:OLD]currind = 1
  [G:OLD]currlen = 0
  Read [OLD] =
Endcase
If fstat
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  If dim([F:NEW]CREDAT)>0 : [F:NEW]CREDAT = date$ : Endif
  If dim([F:NEW]CREUSR)>0 : [F:NEW]CREUSR = GUSER : Endif
  If dim([F:NEW]CRETIM)>0 : [F:NEW]CRETIM = time  : Endif
  If dim([F:NEW]UPDDAT)>0 : [F:NEW]UPDDAT = date$ : Endif
  If dim([F:NEW]UPDUSR)>0 : [F:NEW]UPDUSR = GUSER : Endif
  If dim([F:NEW]UPDTIM)>0 : [F:NEW]UPDTIM = time  : Endif
 Endif
 Write [NEW]
 NEWOBJ = 1
Else
 If ACT & dim([F:OLD]CODACT)>0 & [F:OLD]CODACT>="X" & !find([F:OLD]CODACT,ACTIV(1..NBACT))
  Call ECR_TRACE("---"-CHAINE-mess(37,115,1),0) From GESECRAN : # Objet spécifique
  Return
 Else
  If FLDLEG<>""
   Gosub SET_OLDLEG
   If OLDLEG<>NEWLEG
    # $1$ : Législation origine $2$ différente législation destination $3$
    Call ECR_TRACE(func AFNC.MES3(mess(78,127,1),"---"-CHAINE,NEWLEG,OLDLEG),-1) From GESECRAN
    Return
   Endif
  Endif
  [F:OLD] = [F:NEW]
  If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
   If dim([F:OLD]UPDDAT)>0 : [F:OLD]UPDDAT = date$ : Endif
   If dim([F:OLD]UPDUSR)>0 : [F:OLD]UPDUSR = GUSER : Endif
   If dim([F:OLD]UPDTIM)>0 : [F:OLD]UPDTIM = time  : Endif
  Endif
  Rewrite [OLD]
  NEWOBJ = 0
 Endif
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = [F:ATB]CODFIC : Return
Endif
CHAINE = ""
For I1=1 To NBCLE
 If CHAINE<>"" : CHAINE += "/" : Endif
 CHAINE += num$(evalue("[F:NEW]"+CLE(I1)))
Next I1
NBENR += 1
#Call ECR_TRACE("---"-CHAINE,0) From GESECRAN
If [L]ISOKSPOTTING=2 :
 Local Char WWCLE1(250), WWCLE2(250)(0..16)
 Case TYPOBJ
  When "AAR" :  WWCLE1=num$(evalue("[F:NEW]CODPAR"))
  When "APP" :  WWCLE1=num$(evalue("[F:NEW]APPCOD")) : WWCLE2(0)=num$(evalue("[F:NEW]APPTYP"))
  When "ARV" :  WWCLE1=num$(evalue("[F:NEW]TYPCOD")) : WWCLE2(0)=num$(evalue("[F:NEW]FONCTION")) : WWCLE2(1)=num$(evalue("[F:NEW]ETAT")) : WWCLE2(2)=num$(evalue("[F:NEW]PARAM"))
  When "APE" :  WWCLE1=num$(evalue("[F:NEW]OBJ")) :    WWCLE2(0)=num$(evalue("[F:NEW]TRTSTD")) : WWCLE2(1)=num$(evalue("[F:NEW]TRTSPE"))
  When "AVR" :  WWCLE1=num$(evalue("[F:NEW]FCT")) :    WWCLE2(0)=num$(evalue("[F:NEW]TYP")) :    WWCLE2(1)=num$(evalue("[F:NEW]COD"))
  When "ATP" :  WWCLE1=num$(evalue("[F:NEW]CODFA"))
  When "ASB" :  WWCLE1=num$(evalue("[F:NEW]CAT")) :    WWCLE2(0)=num$(evalue("[F:NEW]CODFIC"))
  When "ARX" :  WWCLE1=num$(evalue("[F:NEW]TYPCOD")) : WWCLE2(0)=num$(evalue("[F:NEW]INTCOD")) : WWCLE2(1)=num$(evalue("[F:NEW]EXTCOD")) : WWCLE2(2)=num$(evalue("[F:NEW]LAN"))
  When "GTC" :  WWCLE1=num$(evalue("[F:NEW]CNSCOD")) : WWCLE2(0)=num$(evalue("[F:NEW]COD"))
  When "AMM" :  WWCLE1=num$(evalue("[F:NEW]MEMO"))
  When "AOP" :  WWCLE1=num$(evalue("[F:NEW]OBJ")) :     WWCLE2(0)=num$(evalue("[F:NEW]NUM"))
  When "TCA" :  WWCLE1=num$(evalue("[F:NEW]LEG")) :    WWCLE2(0)=num$(evalue("[F:NEW]MODULE")) : WWCLE2(1)=num$(evalue("[F:NEW]CPY"))
 Endcase
 Call TRACE_COR_PATCH(TYPOBJ,WWCLE1,WWCLE2,string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET :
Endif
Return

$ABORT
Rollback
Return

##############################
$SET_NEWLEG
If TABLNK=""
 NEWLEG = evalue("[F:NEW]"+FLDLEG)
Else
 K = 0
 For J=1 To min(NBVAL,NBLNK)
  If VALLNK(J)="[V]GSUPCLE"
   K = J : Break
  Elsif VALLNK(J)=""
   Case evalue("type([F:AREF]"+CLELNK(J)+")")
    When 1,2,4,5,6,7,8,9 : Assign "[F:AREF]"+CLELNK(J) With 0
    When 3               : Assign "[F:AREF]"+CLELNK(J) With [0/0/0]
    When Default         : Assign "[F:AREF]"+CLELNK(J) With ""
   Endcase
  Elsif pat(VALLNK(J),"!*")<1
   Assign "[F:AREF]"+CLELNK(J) With evalue(VALLNK(J))
  Else
   Assign "[F:AREF]"+CLELNK(J) With evalue("[F:NEW]"+VALLNK(J))
  Endif
 Next J
 If K : [G:AREF]currlen = K-1 : Endif
 Read [AREF] =
 If fstat
  NEWLEG = ""
 Else
  NEWLEG = evalue("[F:AREF]"+FLDLEG)
 Endif
Endif
Return

##############################
$SET_OLDLEG
If TABLNK=""
 OLDLEG = evalue("[F:OLD]"+FLDLEG)
Else
 K = 0
 For J=1 To min(NBVAL,NBLNK)
  If VALLNK(J)="[V]GSUPCLE"
   K = J : Break
  Elsif VALLNK(J)=""
   Case evalue("type([F:AREF]"+CLELNK(J)+")")
    When 1,2,4,5,6,7,8,9 : Assign "[F:AREF]"+CLELNK(J) With 0
    When 3               : Assign "[F:AREF]"+CLELNK(J) With [0/0/0]
    When Default         : Assign "[F:AREF]"+CLELNK(J) With ""
   Endcase
  Elsif pat(VALLNK(J),"!*")<1
   Assign "[F:AREF]"+CLELNK(J) With evalue(VALLNK(J))
  Else
   Assign "[F:AREF]"+CLELNK(J) With evalue("[F:NEW]"+VALLNK(J))
  Endif
 Next J
 If K : [G:AREF]currlen = K-1 : Endif
 Read [AREF] =
 If fstat
  OLDLEG = ""
 Else
  OLDLEG = evalue("[F:AREF]"+FLDLEG)
 Endif
Endif
Return

##############################
$SET_FLDLEG
Raz FLDLEG , TABLNK , VALLNK , NBLNK , NBVAL
If [F:ATB]FLGLEG<>2
 Return
Endif
K = 0
For [ATZ]CODZONE Where CODFIC=[F:ATB]CODFIC & CHPLEG=2
 K = 1 : Break
Next ATZ
If K
 If [F:ATZ]CODTYP="ADI"
  Read [AMP]CODPAR=2;[F:ATZ]CODFIC;[F:ATZ]CODZONE;"ADI"
  If !fstat & num$(evalue([F:AMP]VALPAR))="909"
   FLDLEG = [F:ATZ]CODZONE
  Endif
 Else
  TABLNK = [F:ATZ]LIEN
  CHAINE = [F:ATZ]EXPLIEN
  If CHAINE=""
   NBVAL = 1
   VALLNK = [F:ATZ]CODZONE
  Else
   Raz NBVAL , VALLNK
   While CHAINE<>""
    NBVAL += 1
    J = instr(1,CHAINE,";")
    If J
     VALLNK(NBVAL) = left$(CHAINE,J-1)
     CHAINE = right$(CHAINE,J+1)
    Else
     VALLNK(NBVAL) = CHAINE
     CHAINE = ""
    Endif
   Wend
  Endif
  K = 0
  For [ATZ]CODZONE Where CODFIC=TABLNK & CHPLEG=2 & CODTYP="ADI"
   K = 1 : Break
  Next ATZ
  If K
   Read [AMP]CODPAR=2;[F:ATZ]CODFIC;[F:ATZ]CODZONE;"ADI"
   If !fstat & num$(evalue([F:AMP]VALPAR))="909"
    FLDLEG = [F:ATZ]CODZONE
    Read [ATI]NUMLIG(2)=[F:ATZ]CODFIC;1
    CHAINE = [F:ATI]DESCRIPT
    Raz NBLNK , CLELNK
    While CHAINE<>""
     NBLNK += 1
     J = instr(1,CHAINE,"+")
     K = instr(1,CHAINE,"-")
     If    J & K  : J = min(J,K)
     Elsif K & !J : J = K
     Endif
     If J
      CLELNK(NBLNK) = left$(CHAINE,J-1)
      CHAINE = right$(CHAINE,J+1)
     Else
      CLELNK(NBLNK) = CHAINE
      CHAINE = ""
     Endif
    Wend
   Endif
  Endif
 Endif
Endif
Return

################################################################
# Traitement non flushable -> il faut redemarrer la session
################################################################
Subprog TRT_USED(TRT,OK)
Value    Char    TRT
Variable Integer OK
OK = find(TRT,"GESUSER","MENU","EXEFNC")
End

###################################################
## Intégration d'un traitement source
###################################################
$TRAITE
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
SAVPOS = adxseek(0)
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8


If TYPENR=-2 :#SCM deletion
 FICSRC = filpath("TRT",NOMOBJ,"src",DOSSIER(D))
 FICOLD = filpath("TRT",NOMOBJ,"old",DOSSIER(D))
 Call EFFACE(FICOLD, STAT) From ORDSYS
 Call EFFACE_ADX("", DOSSIER(D), NOMOBJ, STAT) From ORDSYS
 Call EFFACE(FICSRC, STAT) From ORDSYS
 Call TRACE_COR_PATCH("ADC",NOMOBJ,"","A") From GOBJET
 Call ECR_TRACE(func AFNC.MES1(mess(241,139,1),NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
 Openi FICPATCH , SAVPOS
 Goto FINTRT
Endif


## On ne l'installe que sur le superviseur
## ou sur un dossier de test
REP = "TRT" : EXT1 = "src"
Gosub TSTSUP
If !OK
 Repeat
  Rdseq CHAINE
 Until fstat or CHAINE=string$(10,"*")
 If fstat
  ER = 33 : Return
 Endif
Else
 FICSRC = filpath("TRT",NOMOBJ,"src",DOSSIER(D))
 If filinfo(FICSRC,0)>=0
  FICOLD = filpath("TRT",NOMOBJ,"old",DOSSIER(D))
  Call MOVE(FICSRC,FICOLD,STAT) From ORDSYS
 Endif
 Openi FICPATCH , SAVPOS
 Openo FICSRC , 0
 Rdseq CHAINE
 While fstat=0 & CHAINE<>string$(10,"*")
  Wrseq CHAINE
  Rdseq CHAINE
 Wend
 If fstat
  ER = 33 : Return
 Endif
 Openo
 SAVPOS = adxseek(0)
 Openi
 Onerrgo RIEN
 Call MAJDICTRT(NOMOBJ,APPLI,"",0,"") From SUBADC
 Onerrgo
 Call VALID("TRT",NOMOBJ,APPLI,STAT) From VALMSKSUB
 If STAT
  Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
 Endif
 Openi FICPATCH , SAVPOS
Endif
$FINTRT
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Gosub LIRE From PATCH
If TYPENR<>7
 ER = 34 : Return
Endif
If dim(ISTRTUSED)>0 & ISTRTUSED<1
 Call TRT_USED(NOMOBJ,ISTRTUSED)
Endif
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ADC",NOMOBJ,"","M") From GOBJET : Endif
Return

## Test d'intégration d'un traitement/état

$TSTSUP
OK = 0
# Dans le dossier X3, on intègre toujours
If filinfo(filpath("FIL","ADOSSIER","fde",DOSSIER(D)),0)>=0
 OK = 1 : Return
Endif
# Dans un dossier "test" aussi
Read [ADW]ADW0 = "";"";"TEST"
If !fstat & val([F:ADW]VALEUR)=2
 OK = 1 : Return
Endif
# Si le nom du patch commence par src, aussi
If pat(toupper(TRAIT(P)),"SRC*")
 OK = 1 : Return
Endif
# Si l'objet est spécifique et qu'il existe ou que c'est un dossier spécif, aussi
If find(left$(NOMOBJ,1),"X","Y","Z")
&  or left$(NOMOBJ,3)="SPE" or left$(NOMOBJ,3)="SPV"
&  or pat(NOMOBJ,"CNS*SPE")<>0 or pat(NOMOBJ,"CNS*SPV")<>0
 If filinfo(filpath(REP,NOMOBJ,EXT1,DOSSIER(D)),0)>0
  OK = 1 : Return
 Else
  Read [ADW]ADW0 = "";"";"SPECIF"
  If !fstat & val([F:ADW]VALEUR)=2
   OK = 1 : Return
  Endif
 Endif
Endif
Return

##################################################################
## Intégration d'un traitement compilé (obsoltète 14.6.6)
##################################################################
$TRTADX
REP = "TRT" : EXT1 = "adx" : EXT2 = "bak" : Gosub BINAIRE
Return

$ETAT
REP = "REPORT" : EXT1 = "rpt" : EXT2 = "bak" : Gosub BINAIRE
Return

$BINAIRE
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
SAVPOS = adxseek(0)
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
## On ne l'installe que sur le superviseur
Gosub TSTSUP
If !OK
 Repeat
  Rdseq CHAINE
 Until fstat or CHAINE=string$(10,"*")
 If fstat
  ER = 33 : Return
 Endif
Else
 FICSRC = filpath(REP,NOMOBJ,EXT1,DOSSIER(D))
 If filinfo(FICSRC,0)>=0 & EXT2<>""
  FICOLD = filpath(REP,NOMOBJ,EXT2,DOSSIER(D))
  Call MOVE(FICSRC,FICOLD,STAT) From ORDSYS
 Endif
 Openi FICPATCH , SAVPOS
 Openo FICSRC , 0
 Rdseq CHAINE
 While fstat=0 & CHAINE<>string$(10,"*")
  Gosub ECR_ADX
  Rdseq CHAINE
 Wend
 If fstat
  ER = 33 : Return
 Endif
 Openo
Endif
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Gosub LIRE From PATCH
If TYPENR<>7
 ER = 34 : Return
Endif
Return

$ECR_ADX
While CHAINE<>""
 I1 = instr(1,CHAINE,",")
 If I1
  LIBEL = val(left$(CHAINE,I1-1)) : CHAINE = right$(CHAINE,I1+1)
 Else
  LIBEL = val(CHAINE) : CHAINE = ""
 Endif
 Putseq 1,LIBEL
Wend
Return

#################################################################
## Intégration d'un fichier mémo
#################################################################
$MEMOS
If instr(1,FIC,".")=0
 Raz EXT , FIC
Else
 EXT = right$(FIC,instr(1,FIC,".")+1)
 FIC = left$(FIC,instr(1,FIC,".")-1)
Endif
REP = "ETM" : SREP = "" : EXT1 = EXT : EXT2 = "BAK" : Gosub NEWBIN
Return

#################################################################
## Intégration d'un fichier pattern pour imprimante ZPL
#################################################################
$PATTERN
REP = "PAT" : SREP = "" : EXT1 = "PAT" : EXT2 = "BAK" : FIC = NOMOBJ : Gosub NEWBIN
Return

###################################################
## Intégration d'un traitement compilé
###################################################
$TRTBIN
REP = "TRT" : SREP = "" : EXT1 = "adx" : EXT2 = "bak" : FIC = NOMOBJ : Gosub NEWBIN
Return

$ETABIN
Repeat
 Gosub LIRE From PATCH
 Case TYPENR
  When 3 : REP = "REPORT" : SREP = CHAMP(1) : EXT1 = "rpt" : EXT2 = "bak" : FIC = NOMOBJ : Gosub NEWBIN
 Endcase
Until TYPENR=7 or ER
Return

$TABNEUTRE
Local Integer OKEXT(1..4)
Local Char    TYPDBA(1)
If instr(1,DOSSIER(D),"@")
 Repeat
  Rdseq CHAINE
 Until fstat or CHAINE=string$(10,"*")
 If fstat
  ER = 33 : Return
 Endif
 Return
Endif
Raz OKEXT
REP = "SVG"
FICSRC = filpath(REP,"","",APPLI)
If filinfo(FICSRC,0)<0
 SAVPOS = adxseek(0)
 Call SYSTEME(adxmac(0),'ae_mkdir'-'"'+FICSRC+'"',"",STAT) From ORDSYS
 Openi FICPATCH , SAVPOS
Endif
Repeat
 Gosub LIRE From PATCH
 If TYPENR=3
  EXT1 = CHAMP(1)
  Case EXT1
   When "srf" : OKEXT(1) = 1
   When "fde" : OKEXT(2) = 1
   When "seq" : OKEXT(3) = 1
   When "dat" : OKEXT(4) = 1
  Endcase
  FICSRC = filpath(REP,NOMOBJ,EXT1,DOSSIER(D))
  Openo FICSRC , 0
  Rdseq NOCT
  Repeat
   NB = dim(BUFFER)
   If NOCT>NB
    Getseq NB , BUFFER
    Putseq NB , BUFFER
    NOCT -= NB
   Else
    Getseq NOCT , BUFFER
    Putseq NOCT , BUFFER
    NOCT = 0
   Endif
  Until NOCT=0
  Repeat
   Rdseq CHAINE
  Until fstat or CHAINE=string$(10,"*")
  If fstat
   ER = 33 : Break
  Endif
  Openo
 Endif
Until TYPENR<>3
If ER : Return : Endif
If TYPENR<>7
 ER = 34 : Return
Endif
If sum(OKEXT)=4
 Case [F:ADS]TYPDBA
  When 1 : TYPDBA = "3" : # Oracle
  When 2 : TYPDBA = "5" : # SQL-Serveur
  When 3 : TYPDBA = "2" : # C-Isam
  When 4 : TYPDBA = "6" : # DB2
 Endcase
 SAVPOS = adxseek(0)
 Read [ATB]CODFIC = NOMOBJ
 If !fstat & dim([F:ATB]FLG130)>0 & [F:ATB]FLG130=2
  Call RESTAURE(NOMOBJ,APPLI,TYPDBA,REP,2,1,[F:ADS]CODDBA,1,STAT) From DOSINTEG
 Else
  Call RESTAURE(NOMOBJ,APPLI,TYPDBA,REP,2,1,[F:ADS]CODDBA,0,STAT) From DOSINTEG
 Endif
 Openi FICPATCH , SAVPOS
Endif
Return

$NEWBIN
Rdseq NOCT
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
SAVPOS = adxseek(0)
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
## pour un fichier pattern, on vérifie si le répertoire PAT existe
If REP="PAT" & filinfo(filpath("PAT","","",DOSSIER(D)),0)<0
 SAVPOS = adxseek(0)
 Call SYSTEME(adxmac(0),"ae_mkdir"-filpath("PAT","","",DOSSIER(D)),"",STAT) From ORDSYS
 Openi FICPATCH , SAVPOS
 If filinfo(filpath("PAT","","",DOSSIER(D)),0)<0
  OK = 0
 Endif
Endif
## Pour un fichier mémos
If REP="ETM" & FIC=""
 OK = 0
Endif
## Pour un traitement, on vérifie s'il peut être installé dans cette appli
If REP="TRT" or REP="REPORT"
 Gosub TSTSUP
Endif
## Pour un état, on vérifie si le répertoire langue existe
If OK & REP="REPORT" & SREP<>""
 OK = (filinfo(filpath("REPORT",SREP,"",DOSSIER(D)),0)>=0)
Endif
If !OK
 Repeat
  NB = dim(BUFFER)
  If NOCT>NB
   Getseq NB , BUFFER
   NOCT -= NB
  Else
   Getseq NOCT , BUFFER
   NOCT = 0
  Endif
 Until NOCT=0
 Repeat
  Rdseq CHAINE
 Until fstat or CHAINE=string$(10,"*")
 If fstat
  ER = 33 : Return
 Endif
Else
 If SREP=""
  FICSRC = filpath(REP,FIC,EXT1,DOSSIER(D))
  FICOLD = filpath(REP,FIC,EXT2,DOSSIER(D))
 Else
  FICSRC = filpath(filpath(REP,SREP,"",DOSSIER(D)),FIC,EXT1,DOSSIER(D))
  FICOLD = filpath(filpath(REP,SREP,"",DOSSIER(D)),FIC,EXT2,DOSSIER(D))
 Endif
 If filinfo(FICSRC,0)>=0
  Call MOVE(FICSRC,FICOLD,STAT) From ORDSYS
 Endif
 Openi FICPATCH , SAVPOS
 Openo FICSRC , 0
 Repeat
  NB = dim(BUFFER)
  If NOCT>NB
   Getseq NB , BUFFER
   Putseq NB , BUFFER
   NOCT -= NB
  Else
   Getseq NOCT , BUFFER
   Putseq NOCT , BUFFER
   NOCT = 0
  Endif
 Until NOCT=0
 Repeat
  Rdseq CHAINE
 Until fstat or CHAINE=string$(10,"*")
 If fstat
  ER = 33 : Return
 Endif
 Openo
Endif
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Gosub LIRE From PATCH
If !find(TYPENR,6,7)
 ER = 34 : Return
Endif
If OK & REP="TRT"
 # Avant d'intégrer dans l'archive, il faut effacer le traitement
 System CHAINE=MACHINE+'@archive -d'-APPLI-'-t'-'-e'-'"'+NOMOBJ+'"'
 OK=pullScript(MACHINE,APPLI,NOMOBJ)
 System CHAINE=MACHINE+'@archive -d'-APPLI-'-t'-'-s'-'"'+NOMOBJ+'"'
 OK=pushScript(MACHINE,APPLI,NOMOBJ)
 OK=1
 #adxmpr = adxmpr
 Onerrgo RIEN
 Call MAJDICTRT(NOMOBJ,APPLI,"",0,"") From SUBADC
 Onerrgo
 If dim(ISTRTUSED)>0 & ISTRTUSED<1
  Call TRT_USED(NOMOBJ,ISTRTUSED)
 Endif
Endif
Return

$RIEN
Resume

############################################################
## Intégration d'un composant WEB
############################################################
$TRTWEB
Rdseq NOCT
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
SAVPOS = adxseek(0)
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
## On ne l'installe que sur le superviseur
If filinfo(filpath("FIL","ADOSSIER","fde",DOSSIER(D)),0)<0
 Repeat
  NB = dim(BUFFER)
  If NOCT>NB
   Getseq NB , BUFFER
   NOCT -= NB
  Else
   Getseq NOCT , BUFFER
   NOCT = 0
  Endif
 Until NOCT=0
 Repeat
  Rdseq CHAINE
 Until fstat or CHAINE=string$(10,"*")
 If fstat
  ER = 33 : Return
 Endif
Else
 Case GOS(1)
  When "unix"  : SEP = "/"
  When Default : SEP = "\"
 Endcase
 FIC = ctrans(NOMOBJ,"/\",SEP+SEP)
 K = instr(1,FIC,".")
 If K
  EXT1 = right$(FIC,K+1)
  FIC  = left$(FIC,K-1)
 Else
  EXT1 = ""
 Endif
 If EXT1="tar"
  If instr(1,toupper(FIC),"ADX_PORTAL")<>0 and instr(1,toupper(FIC),"ARCHIVES")<>0
   DETAR_WEB = 1
  Elsif instr(1,toupper(FIC),"X3_ROOT")<>0 and instr(1,toupper(FIC),"RESSTD")<>0
   DETAR_STD = 1
  Elsif instr(1,toupper(FIC),"X3_ROOT")<>0 and instr(1,toupper(FIC),"RESVER")<>0
   DETAR_VER = 1
  Elsif instr(1,toupper(FIC),"X3_ROOT")<>0 and instr(1,toupper(FIC),"RESPER")<>0
   DETAR_PER = 1
  Elsif instr(1,toupper(FIC),"X3_ROOT")<>0 and instr(1,toupper(FIC),"X3CLI")<>0
   DETAR_X3C = 1
  Elsif instr(1,toupper(FIC),"X3_CLIENT")<>0
   DETAR_CLI = 1
  Endif
 Endif
 EXT2 = "bak"
 REPERT = filpath("","","","X3_PUB")
 FICSRC = REPERT+SEP+FIC
 If EXT1<>""
  FICSRC = FICSRC+"."+EXT1
 Endif
 FICOLD = REPERT+SEP+FIC+"."+EXT2
 K = 0
 Repeat
  J = instr(K+1,FICSRC,SEP)
  If J : K = J : Endif
 Until J=0
 REPERT = left$(FICSRC,K-1)
 If filinfo(REPERT,0)<0
  K = instr(1,REPERT,"@")
  If K : REPERT = right$(REPERT,K+1) : Endif
  Call SYSTEME(adxmac(0),"ae_mkdir"-REPERT,"",STAT) From ORDSYS
 Endif
 If filinfo(FICSRC,0)>=0
  Call MOVE(FICSRC,FICOLD,STAT) From ORDSYS
 Endif
 Openi FICPATCH , SAVPOS
 Openo FICSRC , 0
 Repeat
  NB = dim(BUFFER)
  If NOCT>NB
   Getseq NB , BUFFER
   Putseq NB , BUFFER
   NOCT -= NB
  Else
   Getseq NOCT , BUFFER
   Putseq NOCT , BUFFER
   NOCT = 0
  Endif
 Until NOCT=0
 Repeat
  Rdseq CHAINE
 Until fstat or CHAINE=string$(10,"*")
 If fstat
  ER = 33 : Return
 Endif
 Openo
Endif
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Gosub LIRE From PATCH
If !find(TYPENR,6,7)
 ER = 34 : Return
Endif
Return

###################################################
## Intégration d'un fichier texte
###################################################
$TEXTE
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
SAVPOS = adxseek(0)
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
If left$(NOMOBJ,1)="'" | left$(NOMOBJ,1)='"'
 FIC = seg$(NOMOBJ,2,len(NOMOBJ)-1)
Else
 FIC = NOMOBJ
Endif
REPERT = filpath("TXT","","",DOSSIER(D))
If filinfo(REPERT,0)<0
 K = instr(1,REPERT,"@")
 If K
  REPERT = right$(REPERT,K+1)
 Endif
 Call SYSTEME(adxmac(0),"ae_mkdir"-REPERT,"",STAT) From ORDSYS
Endif
FICSRC = filpath("TXT",FIC,"txt",DOSSIER(D))
If filinfo(FICSRC,0)>=0
 FICOLD = filpath("TXT",FIC,"old",DOSSIER(D))
 Call MOVE(FICSRC,FICOLD,STAT) From ORDSYS
Endif
Openi FICPATCH , SAVPOS
Openo FICSRC , 0
Rdseq CHAINE
While fstat=0 & CHAINE<>string$(10,"*")
 Wrseq CHAINE
 Rdseq CHAINE
Wend
If fstat
 ER = 33 : Return
Endif
Openo
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Gosub LIRE From PATCH
If TYPENR<>7
 ER = 34 : Return
Endif
Return

######################################################
## Intégration d'une consultation
######################################################
$CONSULT
Read [ACN]ACN0 = NOMOBJ
If TYPENR=2 :#SCM deletion
 If fstat
  NEWOBJ = 1
  Raz [F:ACN]
 Elsif [F:ACN]CODACT>="X" & !find([F:ACN]CODACT,ACTIV(1..NBACT))
  Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN : # Objet spécifique
  Gosub FIN_OBJ From PATCH
  Return
 Else
  NEWOBJ = 0
 Endif
 Call DEBTRANS From GLOCK
 Gosub TR_CNS
Elsif TYPENR=-2 :#SCM deletion
 If !fstat
  Call DEBTRANS From GLOCK
  Gosub DEL_CNS
 Endif
 Gosub FIN_OBJ From PATCH
Endif
Return

$TR_CNS
Trbegin [ACN] , [ATX]

 NBZ = 0
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # La consultation
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "ACN"   : Gosub CNS1
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif

Commit

## Validation de la consultation
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ACN",[F:ACN]COD,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif

If APPLI<>GDOSX3 : # mb 2.12.2 bug 16737 Pour éviter les erreurs en cas d'écran non généré sur appli X3
 Gosub SAV_OPENI From PATCH
 Call GENTRT(DOSSIER(D),NOMOBJ) From ACNTRT
 Gosub REST_OPENI From PATCH
Endif
adxmbm      = adxmbm
Return

$DEL_CNS
Trbegin [ACN]
 Delete [ACN] Curr
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ACONSULT"-NOMOBJ : Return
 Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ACN",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),[L]NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

## Lecture consult

$CNS1
FICHIER = "ACONSULT" : ABR = "ACN"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  If !NEWOBJ & VARIA="PRGSPE" & TYPPTC<>3
   OK = 0
  Endif
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
MODOBJ = max(1,[F:ACN]MODULE)
If [F:ADS]MODULE(MODOBJ-1)<>2
 OKOBJ = 0 : Return
Endif
ACVOBJ = [F:ACN]CODACT
If ACVOBJ<>"" & [F:ADS]DOSSIER<>GDOSX3
 Read [ACV]CODACT = ACVOBJ
 If fstat | [F:ACV]FLACT<>2
  OKOBJ = 0 : Return
 Endif
Endif
If NEWOBJ
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ACN]CREDAT = date$
  [F:ACN]CREUSR = GUSER
  If dim([F:ACN]CRETIM)>0 : [F:ACN]CRETIM = time  : Endif
  [F:ACN]UPDDAT = date$
  [F:ACN]UPDUSR = GUSER
  If dim([F:ACN]UPDTIM)>0 : [F:ACN]UPDTIM = time  : Endif
 Endif
 Write [ACN]
Else
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ACN]UPDDAT = date$
  [F:ACN]UPDUSR = GUSER
  If dim([F:ACN]UPDTIM)>0 : [F:ACN]UPDTIM = time  : Endif
 Endif
 Rewrite [ACN]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ACONSULT"-[F:ACN]COD : Return
Endif
Return

######################################################
## Transaction type integration ATN
######################################################
$TRANSAC
Local File =DOSSIER(D)+".ATRANSAC"  [ATN]

Read [ATN]ATN0 = NOMOBJ
If fstat = 0
  #for SCM deletion (typenr=-2 only in scm at the moment)
  If TYPENR=-2
      Gosub DEL_ATN
      Gosub FIN_OBJ From PATCH
  Else
      If [F:ATN]CODACT>="X" & !find([F:ATN]CODACT,ACTIV(1..NBACT))
            # specific Objet
            Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN
            OKSPE = 1
            Gosub FIN_OBJ From PATCH
      Else
            NEWOBJ = 0
            Gosub TR_TRN
      Endif
  Endif
Else
  # creation only if typenr <> - 2 (typenr=-2 only in scm at the moment)
  If TYPENR<>-2
      NEWOBJ = 1
      Raz [F:ATN]
      Gosub TR_TRN
  Else
      Gosub FIN_OBJ From PATCH
  Endif
Endif

LogicClose File [ATN]
#Close Local File [ATN]
Return

#--------------------------
# deletion at the moment only for scm#
#-------------------------
$DEL_ATN
Call DEBTRANS From GLOCK
Trbegin [ATN]
  Delete [ATN] Curr
  If fstat
        GOK = 0 : ER = 99 : ERFIC = "ATRANSAC"-NOMOBJ : Rollback : Return
  Endif
Commit
#
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ATN",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),[L]NOMOBJ),0) From GESECRAN
Return

#--------------------------
#
#-------------------------
$TR_TRN
Call DEBTRANS From GLOCK
Trbegin [ATN]
  NBZ = 0
  Repeat
      Gosub LIRE From PATCH
      Case TYPENR
          When 7,13 : Break : # Fin normale
          When 3 : # La transaction
                  IDENT = CHAMP(2)
                  Case CHAMP(1)
                        When "ATN"   : Gosub TRN1
                        When Default : ER = 31
                  Endcase
          When Default:  ER = 32
      Endcase
      If ER or !OKOBJ : Break : Endif
  Until 1=0
  If ER or !OKOBJ : Goto ABORT : Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ATN",[F:ATN]COD,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
Return

#--------------------
## read transac
#--------------------
$TRN1
FICHIER = "ATRANSAC" : ABR = "ATN"
Repeat
  Gosub LIRE_ZONE From PATCH
  If ER : Break : Endif
  If DIME>0 & IND+1<=DIME
        OK = 1
        # Patch not for scm - ISFULLMOD = 2 when SCM
        If !NEWOBJ & find(VARIA,"ENAFLG") and [L]ISFULLMOD<>2
              OK = 0
        Endif
        If OK
              Gosub AFF_ZONE From PATCH
              If GOK<1 : ER = 99 : Break : Endif
        Endif
  Endif
Until TYPENR=6
If ER : Return : Endif

MODOBJ = max(1,[F:ATN]MODULE)
If [F:ADS]MODULE(MODOBJ-1)<>2
    OKOBJ = 0 : Return
Endif
ACVOBJ = [F:ATN]CODACT
If ACVOBJ<>"" & [F:ADS]DOSSIER<>GDOSX3
    Read [ACV]CODACT = ACVOBJ
    If fstat | [F:ACV]FLACT<>2
          OKOBJ = 0 : Return
    Endif
Endif

If NEWOBJ
   If [L]ISFULLMOD<>2  : # Patch not for scm - ISFULLMOD = 2 when SCM
        Call FLDCRE("ATN") From OBJDIV
   Endif
   Write [ATN]
   If fstat
        Call LOG_ERROR_DETAILS(1, "ATN",num$([F:ATN]COD),"") From GLOCK
   Endif
Else
   If [L]ISFULLMOD<>2  : # Patch not for scm - ISFULLMOD = 2 when SCM
        Call FLDUPD("ATN") From OBJDIV
   Endif
   Rewrite [ATN]
   If fstat
        Call LOG_ERROR_DETAILS(2, "ATN",num$([F:ATN]COD),"") From GLOCK
   Endif
Endif
If fstat
    GOK = 0 : ER = 99 : ERFIC = "ATRANSAC"-[F:ATN]COD : Return
Endif
Return


######################################################
## Intégration d'un traitement
######################################################
$DICTRT
Read [ADC]ADC0 = NOMOBJ
If TYPENR=2 :#SCM deletion
 If fstat
  NEWOBJ = 1
  Raz [F:ADC]
 Elsif [F:ADC]CODACT>="X" & !find([F:ADC]CODACT,ACTIV(1..NBACT))
  Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN : # Objet spécifique
  Gosub FIN_OBJ From PATCH
  Return
 Else
  NEWOBJ = 0
 Endif
 Call DEBTRANS From GLOCK
 Gosub TR_TRT
Elsif TYPENR=-2 :#SCM deletion
 If !fstat
  Call DEBTRANS From GLOCK
  Gosub DEL_TRT
 Endif
 Gosub FIN_OBJ From PATCH
Endif
Return

$TR_TRT
