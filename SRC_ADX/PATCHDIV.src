Elsif TYPENR=-2 :#SCM deletion
 If !fstat
  Call DEBTRANS From GLOCK
  Gosub DEL_AWE
 Endif
 Gosub FIN_OBJ From PATCH
Endif
Close Local File [AWE],[AWY],[ASU]
Return

