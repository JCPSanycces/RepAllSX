Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif

If NEWOBJ
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ACD]CREDAT = date$
  [F:ACD]CREUSR = GUSER
  If dim([F:ACD]CRETIM)>0 : [F:ACD]CRETIM = time  : Endif
  [F:ACD]UPDDAT = date$
  [F:ACD]UPDUSR = GUSER
  If dim([F:ACD]UPDTIM)>0 : [F:ACD]UPDTIM = time  : Endif
 Endif
 Write [ACD]
Else
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ACD]UPDDAT = date$
  [F:ACD]UPDUSR = GUSER
  If dim([F:ACD]UPDTIM)>0 : [F:ACD]UPDTIM = time  : Endif
 Endif
 Rewrite [ACD]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ACTLDEV" : Return
Endif
Return

######################################################
## Intégration d'un processus
######################################################
$PROCESSUS
K = instr(1,NOMOBJ,"~")
If K
 [L]TYPS = left$(NOMOBJ,K-1)
 [L]CODS = right$(NOMOBJ,K+1)
Else
 Gosub FIN_OBJ From PATCH
 Return
Endif
Local File =DOSSIER(D)+".APROCESSUS"   [APR]
Local File =DOSSIER(D)+".APROCTEXTE"   [AXP]
Read [APR]APR1 = [L]TYPS;[L]CODS
If TYPENR=2 :#SCM deletion
 If fstat
  NEWOBJ = 1
  Raz [F:APR]
  Call DEBTRANS From GLOCK
  Gosub TR_APR
 Elsif [F:APR]CODACT>"X" & !find([F:APR]CODACT,ACTIV(1..NBACT))
  Call ECR_TRACE("---"-[F:APR]CODPRO-mess(37,115,1),0) From GESECRAN : # Objet spécifique
  Gosub FIN_OBJ From PATCH
 Else
  OLDLEG = [F:APR]CODLEG
  NEWOBJ = 0
  Call DEBTRANS From GLOCK
  Gosub TR_APR
 Endif
Elsif TYPENR=-2 :#SCM deletion
 If !fstat
  Call DEBTRANS From GLOCK
  Gosub DEL_APR
 Endif
 Gosub FIN_OBJ From PATCH
Endif
Close Local File [APR],[AXP]
Return

$TR_APR
Trbegin [APR]
 NBZ = 0
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7,13 : # Fin normale
    Break
   When 3 : # Variable
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "APR"   : Gosub APR1
     When "AXP"   : Gosub APR2
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("APR",[F:APR]CODPRO,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif

#94154 Génération JSON Processus
If !ER & OKOBJ
  If func ARECOPRO.GENE_SYRA_JSON(DOSSIER(D),[L]CODS,[L]TYPS)
   Call ECR_TRACE(mess(6,123,1)-mess(138,127,1)-[L]TYPS+"~"+[L]CODS,0) From GESECRAN
   ER=99
  Endif
Endif

Return

$DEL_APR
Trbegin [APR],[AXP],[AXX]
 Delete [AXX] Where CODFIC="APROCESSUS" & ZONE="INTIT1" & IDENT1=[L]TYPS & IDENT2=[L]CODS
 Delete [AXP] Where CODLEG=[L]TYPS & CODPRO=[L]CODS
 Delete [APR] Curr
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "APR"-[L]TYPS+"~"+[L]CODS: Return
 Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("APR",[L]CODS,[L]TYPS,"A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),[L]NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

$APR1
FICHIER = "APROCESSUS" : ABR = "APR"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif

MODOBJ = max(1,[F:APR]MODULE)
If [F:ADS]MODULE(MODOBJ-1)<>2
 OKOBJ = 0 : Return
Endif
ACVOBJ = [F:ACN]CODACT
If ACVOBJ<>"" & [F:ADS]DOSSIER<>GDOSX3
 Read [ACV]CODACT = ACVOBJ
 If fstat | [F:ACV]FLACT<>2
  OKOBJ = 0 : Return
 Endif
Endif
If [F:APR]CODLEG<>"" & !find([F:APR]CODLEG,LEGREF(1..NBLEGREF))
 # Législation non gérée par le dossier
 Call ECR_TRACE("---"-[F:APR]CODPRO-"("+[F:APR]CODLEG+")"-":"-mess(249,133,1)-DOSSIER(D),0) From GESECRAN
 Return
Endif
If NEWOBJ
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:APR]CREDAT = date$
  [F:APR]CREUSR = GUSER
  If dim([F:APR]CRETIM)>0 : [F:APR]CRETIM = time  : Endif
  [F:APR]UPDDAT = date$
  [F:APR]UPDUSR = GUSER
  If dim([F:APR]UPDTIM)>0 : [F:APR]UPDTIM = time  : Endif
 Endif
 Write [APR]
Else
 If [F:APR]CODLEG<>OLDLEG
  # $1$ : Législation origine $2$ différente législation destination $3$
  Call ECR_TRACE(func AFNC.MES3(mess(78,127,1),"---"-[F:APR]CODPRO,[F:APR]CODLEG,OLDLEG),-1) From GESECRAN
  Return
 Endif
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:APR]UPDDAT = date$
  [F:APR]UPDUSR = GUSER
  If dim([F:APR]UPDTIM)>0 : [F:APR]UPDTIM = time  : Endif
 Endif
 Rewrite [APR]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "APROCESSUS" : Return
Endif
I = 0
While I<dim([L]LANPATCH)
 I += 1
    # cg fev  2012  en attendant d avoir mieux
    # comme on ne teste pas les langues du patch en integration aproctexte
    # et qu on ne fait que des write.. on ne doit plus tester les codes langues du dossier
    # il faut virer toutes les trads presente dans la mnt
    # If !find([L]LANPATCH(I),[F:ADS]LAN(0..[F:ADS]NBRLAN-1))
  Delete [AXP] Where CODLEG=[L]TYPS & CODPRO=[L]CODS & LANG=[L]LANPATCH(I)
  If fstat : GOK = 0 : ER = 99 : ERFIC = "APROCTEXTE"-[L]TYPS +"~"+CODS+"~"+[L]LANPATCH(I): Break : Endif
Wend
If ER : Return : Endif
Return

## Lecture d'une aide sur champ
$APR2
FICHIER = "APROCTEXTE" : ABR = "AXP"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
 [F:AXP]CREDAT = date$
 [F:AXP]CREUSR = GUSER
 If dim([F:AXP]CRETIM)>0 : [F:AXP]CRETIM = time  : Endif
 [F:AXP]UPDDAT = date$
 [F:AXP]UPDUSR = GUSER
 If dim([F:AXP]UPDTIM)>0 : [F:AXP]UPDTIM = time  : Endif
Endif
Write [AXP]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "APROCTEXTE"-[L]TYPS +"~"+CODS+"~"+[F:AXP]LANG: Return
Endif

Return

######################################################
## Intégration d'une formule
######################################################
$TABFOR
Local Integer  TNB,TK

K = instr(1,NOMOBJ,"~")
If K
    [L]TYPS   = left$(NOMOBJ,K-1)
    [L]CODS   = right$(NOMOBJ,K+1)
Else
     Gosub FIN_OBJ From PATCH
     Return
Endif

Local File =DOSSIER(D)+".TABFOR"    [TFO]
Local File =DOSSIER(D)+".ATEXTRA"   [AXXP]

# here due to the need of dim FORFOR
Local Char     TFOR(250)(0..dim([F:TFO]FORFOR)-1), TLEG(GLONADI)(0..dim([F:TFO]FORFOR)-1)

Read [TFO]TFO0 = val([L]TYPS);[L]CODS
If fstat = 0
  #for SCM deletion (typenr=-2 only in scm at the moment)
  If TYPENR=-2
      Gosub DEL_TFO
      Gosub FIN_OBJ From PATCH
  Else
      Raz TFOR,TLEG,TNB,TK
      For I=0 To dim([F:TFO]FORFOR)-1
              TFOR(TNB) = [F:TFO]FORFOR(I)
              TLEG(TNB) = [F:TFO]LEG(I)
              TNB += 1
      Next I
      NEWOBJ = 0
      Gosub TR_TFO
  Endif
Else
  # creation only if typenr <> - 2 (typenr=-2 only in scm at the moment)
  If TYPENR<>-2
      NEWOBJ = 1
      Raz [F:TFO]
      Raz TFOR,TLEG,TNB,TK
      Gosub TR_TFO
  Else
      Gosub FIN_OBJ From PATCH
  Endif
Endif

LogicClose File [TFO],[AXXP]
#Close Local File [TFO]
Return

#-------------------#
# deletion at the moment only for scm
#-------------------#
$DEL_TFO
Call DEBTRANS From GLOCK
Trbegin [TFO],[AXXP]
  Delete [AXXP] Where CODFIC="TABFOR" & IDENT1=[L]TYPS & IDENT2=[L]CODS
  If fstat
     GOK = 0 : ER = 99 : ERFIC = "TABFOR"-[L]TYPS-"/"-[L]CODS : Rollback: Return
  Endif
  Delete [TFO] Curr
  If fstat
     GOK = 0 : ER = 99 : ERFIC = "TABFOR"-[L]TYPS-"/"-[L]CODS : Rollback : Return
  Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("TFO",[L]CODS,[L]TYPS,"A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),[L]TYPS-"/"-[L]CODS),0) From GESECRAN
Return

#-------------------#
# write or rewrite
#-------------------#
$TR_TFO
Call DEBTRANS From GLOCK
Trbegin [TFO]
   NBZ = 0
   Repeat
       Gosub LIRE From PATCH
       Case TYPENR
            When 7 , 13 : Break :# Fin normale
            When 3 : # Variable
                     IDENT = CHAMP(2)
                     Case CHAMP(1)
                        When "TFO"   : Gosub TFO1
                        When Default : ER = 31
                     Endcase
            When Default :   ER = 32
       Endcase
       If ER or !OKOBJ : Break : Endif
   Until 1=0
   If ER or !OKOBJ : Goto ABORT : Endif

Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("TFO",num$([F:TFO]FORTYP),[F:TFO]FORCOD,string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
Return

#------------------------------#
## Read TFO
#------------------------------#
$TFO1
FICHIER = "TABFOR" : ABR = "TFO"
Repeat
    Gosub LIRE_ZONE From PATCH
    If ER : Break : Endif
    If DIME>0 & IND+1<=DIME
          Gosub AFF_ZONE From PATCH
          If GOK<1 : ER = 99 : Break : Endif
    Endif
Until TYPENR=6
If ER : Return : Endif
If NEWOBJ
    For I=0 To dim([F:TFO]FORFOR)-1
         If !find([F:TFO]LEG(I),LEGREF(1..NBLEGREF)) & [F:TFO]FORFOR(I)<>""
              [F:TFO]LEG(I)    = ""
              [F:TFO]FORFOR(I) = ""
         Endif
    Next I
    If [L]ISFULLMOD<>2  : # Patch not for scm - ISFULLMOD = 2 when SCM
           Call FLDCRE("TFO") From OBJDIV
    Endif
    Sorta dim([F:TFO]LEG) LEG,FORFOR Order By LEG(indice) Desc
    Write [TFO]
    If fstat
            Call LOG_ERROR_DETAILS(1, "TFO",num$([F:TFO]FORTYP)+"~"+[F:TFO]FORCOD,"") From GLOCK
    Endif
Else
    For I=0 To dim([F:TFO]FORFOR)-1
          If [F:TFO]FORFOR(I)<>""
               If !find([F:TFO]LEG(I),LEGREF(1..NBLEGREF)) & [F:TFO]FORFOR(I)<>"" & [F:TFO]LEG(I)<>""
                    [F:TFO]LEG(I)    = ""
                    [F:TFO]FORFOR(I) = ""
               Endif
          Endif
    Next I
    Sorta dim([F:TFO]LEG) LEG,FORFOR Order By LEG(indice) Desc
    TK = find("",[F:TFO]LEG)-1
    If TK<0
          TK = dim([F:TFO]LEG)
    Endif
    For I=0 To TNB-1
        If TK<dim([F:TFO]FORFOR)-1
            J = find(TLEG(I),[F:TFO]LEG)
            If !J
                  [F:TFO]FORFOR(TK) = TFOR(I)
                  [F:TFO]LEG(TK)    = TLEG(I)
                  TK += 1
            Endif
        Endif
    Next I
    If [L]ISFULLMOD<>2  : # Patch not for scm - ISFULLMOD = 2 when SCM
            Call FLDUPD("TFO") From OBJDIV
    Endif
    Rewrite [TFO]
    If fstat
            Call LOG_ERROR_DETAILS(2, "TFO",num$([F:TFO]FORTYP)+"~"+[F:TFO]FORCOD,"") From GLOCK
    Endif
Endif
If fstat
       GOK = 0 : ER = 99 : ERFIC = "TABFOR"-[L]TYPS-"/"-[L]CODS : Return
Endif
Return
######################################################
