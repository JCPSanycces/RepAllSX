## Lecture d'un style

$ASY1
FICHIER = "ASTYLE" : ABR = "ASY"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If NEWOBJ
 MAXLIG = 0
 For [AS2]ASY0
  If [AS2]LIG > MAXLIG
   MAXLIG = [F:AS2]LIG
  Endif
 Next AS2
 MAXLIG +=1
 [F:ASY]LIG = MAXLIG
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ASY]CREDAT = date$
  [F:ASY]CREUSR = GUSER
  If dim([F:ASY]CRETIM)>0 : [F:ASY]CRETIM = time  : Endif
  [F:ASY]UPDDAT = date$
  [F:ASY]UPDUSR = GUSER
  If dim([F:ASY]UPDTIM)>0 : [F:ASY]UPDTIM = time  : Endif
 Endif
 Write [ASY]
Else
 Read [AS2]ASY0 = [ASY]COD
 If !fstat : [ASY]LIG = [AS2]LIG : Endif
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ASY]UPDDAT = date$
  [F:ASY]UPDUSR = GUSER
  If dim([F:ASY]UPDTIM)>0 : [F:ASY]UPDTIM = time  : Endif
 Endif
 Rewrite [ASY]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ASTYLE" : Return
Endif
Return

