 If ER or !OKOBJ : Goto ABORT : Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ACD",[F:ACD]COD,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
Return

$DEL_ACD
Trbegin [ACD],[AXX]
 Delete [AXX] Where CODFIC="ACTLDEV" & ZONE='INTCOD' & IDENT1=[L]NOMOBJ
 Delete [ACD] Curr
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ACTLDEV"-NOMOBJ: Return
 Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ACD",[L]NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),[L]ACTL),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

$ACD1
