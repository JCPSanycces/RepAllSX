 NBZ = 0
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Prototype
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "ATYP"   : Gosub ATYP1
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ATYP",[F:ATYP]COD,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif

