$TR_ACC
Trbegin [ACC]
 NBZ = 0
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Variable
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "DIV"   : Gosub ACC1
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit
