## Lecture Prototype
$ATYP1
FICHIER = "ATYPEPRO" : ABR = "ATYP"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
MODOBJ = max(1,[F:ATYP]MODULE)
If [F:ADS]MODULE(MODOBJ-1)<>2
 OKOBJ = 0 : Return
Endif
ACVOBJ = [F:ATYP]CODACT
If ACVOBJ<>"" & [F:ADS]DOSSIER<>GDOSX3
 Read [ACV]CODACT = ACVOBJ
 If fstat | [F:ACV]FLACT<>2
  OKOBJ = 0 : Return
 Endif
Endif
If NEWOBJ
 Write [ATYP]
Else
 Rewrite [ATYP]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ATYPEPRO"-[F:ATYP]COD : Return
Endif
Return
######################################################
## Intégration d'un sous programme
######################################################
$SUBPRG
K = instr(1,NOMOBJ,"~")
If K
 [L]PRG = left$(NOMOBJ,K-1)
 [L]SUBPRG = right$(NOMOBJ,K+1)
Else
 Gosub FIN_OBJ From PATCH
 Return
Endif
Local File =DOSSIER(D)+".ASUBPROG"   [ASU]
Onerrgo RIEN
Local File =DOSSIER(D)+".ASUBPROGD"  [ASP]
Onerrgo
Read [ASU]ASU0 = [L]PRG;[L]SUBPRG
If TYPENR=2 :#SCM deletion
 If !fstat & [F:ASU]CODACT>="X" & !find([F:ASU]CODACT,ACTIV(1..NBACT))
  Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN : # Objet spécifique
  Gosub FIN_OBJ From PATCH
 Else
  If fstat
   NEWOBJ = 1
   Raz [F:ASU]
  Else
   NEWOBJ = 0
  Endif
  Call DEBTRANS From GLOCK
  Gosub TR_ASU
 Endif
Elsif TYPENR=-2 :#SCM deletion
 If !fstat
  Call DEBTRANS From GLOCK
  Gosub DEL_ASU
 Endif
 Gosub FIN_OBJ From PATCH
Endif
Close Local File [ASU]
Onerrgo RIEN
Close Local File [ASP]
Onerrgo
Return

$TR_ASU
Trbegin [ASU]
 NBZ = 0
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 : # Variable
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "ASU"   : Gosub ASU1
     When "ASP"   : Gosub ASU2
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : BREADK : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ASU",[F:ASU]PRG,[F:ASU]SUBPRG,string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
Return

$DEL_ASU
Trbegin [ASU],[ASP]
Delete [ASP] Where PRG=[L]PRG & SUBPRG=[L]SUBPRG
Delete [ASU] Curr
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ASU"-[L]PRG+"~"+[L]SUBPRG: Return
Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ASU",[L]PRG,[L]SUBPRG,"A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),[L]NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

