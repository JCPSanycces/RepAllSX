  [F:ACTX]UPDUSR = GUSER
  If dim([F:ACTX]UPDTIM)>0 : [F:ACTX]UPDTIM = time  : Endif
 Endif
 Write [ACTX]
Else
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ACTX]UPDDAT = date$
  [F:ACTX]UPDUSR = GUSER
  If dim([F:ACTX]UPDTIM)>0 : [F:ACTX]UPDTIM = time  : Endif
 Endif
 Rewrite [ACTX]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ACONTEXT"-[F:ACTX]CODCTX : Return
Endif
Return

