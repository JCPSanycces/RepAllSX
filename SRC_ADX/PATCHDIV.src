## Lecture d'un code d'accés

$ACC1
FICHIER = "ACCES" : ABR = "ACC"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If [ACC]PRFCOD =""
 Read [ACC_]CODACC  = [F:ACC]USR;[F:ACC]CODACC
 If fstat
  NEWOBJ = 1
 Else
  NEWOBJ = 0
 Endif
Else
 NEWOBJ = 1
 For [ACC_] Where USR=[F:ACC]USR & CODACC=[F:ACC]CODACC & PRFCOD=[F:ACC]PRFCOD
  NEWOBJ = 0
  Break
 Next
Endif
If NEWOBJ
 Write [ACC]
Else
 Rewrite [ACC]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ACCES" : Return
Endif
Return

