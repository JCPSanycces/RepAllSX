######################################################
## Intégration requetes
######################################################
$REQUETES
Local File =DOSSIER(D)+".ALISTEH"   [ALH]
Local File =DOSSIER(D)+".ALISTED"   [ALD]
Local File =DOSSIER(D)+".ALISTET"   [ALT]
Local File =DOSSIER(D)+".ALISTEC"   [ALC]
Local File =DOSSIER(D)+".ALISTEL"   [ALL]
Read [ALH]ALH0 = NOMOBJ
If TYPENR=2 :#SCM deletion
 If fstat
  NEWOBJ = 1
  Raz [F:ALH]
 Else
  NEWOBJ = 0
 Endif
 Call DEBTRANS From GLOCK
 Gosub TR_REQUETES
Elsif TYPENR=-2 :#SCM deletion
 If !fstat
  Call DEBTRANS From GLOCK
  Gosub DEL_REQUETES
 Endif
 Gosub FIN_OBJ From PATCH
Endif
Close Local File [ALH],[ALD],[ALT],[ALC],[ALL]
Return

$TR_REQUETES
Trbegin [ALH],[ALD],[ACB]
 NBZ = 0
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Fin normale
    Break
   When 3 :
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "ALH"   : Gosub ALH1
     When "ALD"   : Gosub ALD1
     When "ALT"   : Gosub ALT1
     When "ALC"   : Gosub ALC1
     When "ALL"   : Gosub ALL1
     When "ACB"   : Gosub ACB1
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif
Commit

# Validation requete
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH(TYPOBJ,[F:ALH]COD,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET : Endif
Gosub SAV_OPENI From PATCH
If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
 If TYPOBJ = "ALH"
  Call VALIDE([F:ALH]COD,DOSSIER(D),0,1) From SUBALH1
 Elsif TYPOBJ = "ALQ" & APPLI=nomap & (APPLI<>GDOSX3 or GADONIX=2)
  Call REQUETE([F:ALH]COD,APPLI,MOK) From SUBALQ
 Elsif TYPOBJ = "ALT"
  Call VALIDE([F:ALH]COD,DOSSIER(D),0,1) From SUBALT1
 Endif
Endif
Gosub REST_OPENI From PATCH

Return

$DEL_REQUETES
Trbegin [ALH],[ALD],[ALC],[ALT],[ALL],[ACB]

 Delete [AXX] Where CODFIC="ALISTEH" & ZONE='INTIT' & IDENT1=NOMOBJ
 Delete [ACB] Where CODBLB="RQ_ALH" & IDENT1=[L]NOMOBJ
 Delete [ALD] Where COD=[L]NOMOBJ
 Delete [ALC] Where COD=[L]NOMOBJ
 Delete [ALT] Where COD=[L]NOMOBJ
 Delete [ALL] Where COD=[L]NOMOBJ
 Delete [ALH] Curr
 If fstat
  GOK = 0 : ER = 99 : ERFIC = TYPOBJ-NOMOBJ: Return
 Endif
Commit
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH(TYPOBJ,[L]NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),[L]NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

Return

## Lecture requete

$ALH1
FICHIER = "ALISTEH" : ABR = "ALH"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
If NEWOBJ
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ALH]CREDAT = date$
  [F:ALH]CREUSR = GUSER
  If dim([F:ALH]CRETIM)>0 : [F:ALH]CRETIM = time  : Endif
  [F:ALH]UPDDAT = date$
  [F:ALH]UPDUSR = GUSER
  If dim([F:ALH]UPDTIM)>0 : [F:ALH]UPDTIM = time  : Endif
 Endif
 Write [ALH]
Else
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ALH]UPDDAT = date$
  [F:ALH]UPDUSR = GUSER
  If dim([F:ALH]UPDTIM)>0 : [F:ALH]UPDTIM = time  : Endif
 Endif
 Rewrite [ALH]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ALISTEH"-[F:ALH]COD: Return
Endif
Delete [ALD] Where COD = [ALH]COD
If fstat : GOK = 0 : ER = 99 : ERFIC = "ALISTED"-[ALH]COD  : Endif
If TYPOBJ = "ALQ"
 Gosub PFIX From SUBALQ
 Delete [ACB] Where CODBLB=[L]IDCLOB & IDENT1=[ALH]COD
 If fstat : GOK = 0 : ER = 99 : ERFIC = "ACLOB"-[ALH]COD  : Endif
Elsif TYPOBJ = "ALT"
 Delete [ALT] Where COD=[ALH]COD
 If fstat : GOK = 0 : ER = 99 : ERFIC = "ALISTET"-[ALH]COD  : Endif
 Delete [ALL] Where COD=[ALH]COD
 If fstat : GOK = 0 : ER = 99 : ERFIC = "ALISTEL"-[ALH]COD  : Endif
 Delete [ALC] Where COD=[ALH]COD
 If fstat : GOK = 0 : ER = 99 : ERFIC = "ALISTEC"-[ALH]COD  : Endif
Endif
Return

