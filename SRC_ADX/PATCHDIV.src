$ATYPEPRO
If clalev([ATYP]) : Close File [ATYP] : Endif
Local File =DOSSIER(D)+".ATYPEPRO"  [ATYP]
Read [ATYP]ATYP0 = NOMOBJ
If TYPENR=2 :#SCM deletion
 If !fstat & [F:ATYP]CODACT>="X" & !find([F:ATYP]CODACT,ACTIV(1..NBACT))
  Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN : # Objet spécifique
  Gosub FIN_OBJ From PATCH
 Else
  If fstat
   NEWOBJ = 1
   Raz [F:ATYP]
  Else
   NEWOBJ = 0
  Endif
  Call DEBTRANS From GLOCK
  Gosub TR_ATYP
 Endif
Elsif  TYPENR=-2 :#SCM deletion
 If !fstat
  Call DEBTRANS From GLOCK
  Gosub DEL_ATYP
 Endif
 Gosub FIN_OBJ From PATCH
Endif
Close Local File [ATYP]
Return

