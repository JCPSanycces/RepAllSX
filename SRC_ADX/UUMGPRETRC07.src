#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################################
# UUMGPRETRC07   Pre-migration clients                       Module TRC    #
# Gestion des adresses                                                     #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
   #--- Issue 108760 by TS
   #Call SAIDOS(DOSSIER,"") From SAIDOS
   Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
   #---
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  #--- Issue 108760 By TS
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  #---
  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPRETRC07") From LECFIC
  Endif
  Call MAJ_UUMGPRETRC07(DOSSIER)
  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End


###################################################################################
Subprog MAJ_UUMGPRETRC07(DOSSIER)
Value Char DOSSIER

# Issue 108760 by TS
If func DOSSUB.ISHISTFOLD(DOSSIER) : End : Endif

Call ECR_TIME("UUMGPRETRC07 Sales Order Process : Update BPCUSTOMER") From DOSSUB
Call ECR_TRACE("UUMGPRETRC07 : Process Start on : "+DOSSIER,0) From GESECRAN
Local Integer COMPTEUR
Local Integer ERR

#----- Récupération du n° de version
Local Char VERSION
Call VERSION (DOSSIER,VERSION) From DOSSUB
If val(VERSION)=0
  # N° de version incorrecte
  Call ECR_TRACE("UUMGPRETRC07 : Error on release number : "+VERSION,0) From GESECRAN
  End
Endif
#----- Avoir les globales pour tester les versions
Gosub DEF_VERSIONSX3 From TRTMIGTABX3

# Passage en V6
If val(VERSION)<GMIGX3VER60
  # Mise à jour des champs par boucle de lecture de la table et maj

  # ----------------------------------------
  # 1- ajouter les colonnes dans la table BPC
  # ----------------------------------------
  Gosub ADDCOLV6
  If ERR : Goto FIN : Endif

  # Champs à alimenter à partir de la V6
  Gosub TRT_X3_V6
  #--------------- Suppression index ----------#
  Call MIGINDDEL (DOSSIER,"BPCUSTOMER",ERR) From TRTMIG
  If ERR : Goto FIN : Endif
Endif
# Passage en V7
If val(VERSION)<GMIGX3VER70
  # Mise à jour des champs par boucle de lecture de la table et maj

  # ----------------------------------------
  # 1- ajouter les colonnes dans la table BPC
  # ----------------------------------------
  Gosub ADDCOLV7
  If ERR : Goto FIN : Endif

  # Champs à alimenter à partir de la V6
  Gosub TRT_X3_V7
  #--------------- Suppression index ----------#
  Call MIGINDDEL (DOSSIER,"BPCUSTOMER",ERR) From TRTMIG
  If ERR : Goto FIN : Endif
Endif


$FIN
Call ECR_TIME("UUMGPRETRC07 : "+num$(COMPTEUR)+" records processed.")  From DOSSUB
End

########################################################################
# 1- ajouter les colonnes dans la table BPC
# ----------------------------------------

# Ajout des champs
# ----------------
$ADDCOLV6
  # Ajout du champ BPAPAY : Adresse tiers payé
  Call MIGADDCOL (DOSSIER,"BPCUSTOMER","BPAPYR","A",5,1,ERR) From TRTMIG
  If ERR : Goto FIN : Endif
  # Ajout du champ BPAINV : Adresse client facture
  Call MIGADDCOL (DOSSIER,"BPCUSTOMER","BPCRSK","BPR",0,1,ERR) From TRTMIG
  If ERR : Goto FIN : Endif
  # Ajout du champ CUR : Devise
  Call MIGADDCOL (DOSSIER,"BPCUSTOMER","CUR","CUR",0,1,ERR) From TRTMIG
  If ERR : Goto FIN : Endif
  # Ajout du champ CNTNAM : Contact par defaut
  Call MIGADDCOL (DOSSIER,"BPCUSTOMER","CNTNAM","NAM",0,1,ERR) From TRTMIG
  If ERR : Goto FIN : Endif

  # Ajout du champ BPAADD : Adresse par defaut
  Call MIGINDCRE (DOSSIER,"BPCUSTOMER","","BPAADD","A",5,ERR) From TRTMIG
  If ERR : Goto FIN : Endif
Return
########################################################################
#en V7
$ADDCOLV7
  # Ajout du champ DAYMON : Quantiéme
  Call MIGADDCOL (DOSSIER,"BPCUSTOMER","DAYMON","C",2,6,ERR) From TRTMIG
  If ERR : Goto FIN : Endif

  # Ajout du champ DAYMON : Indisponibilité
  Call MIGADDCOL (DOSSIER,"BPCUSTOMER","UVYCOD2","UVY",0,1,ERR) From TRTMIG
  If ERR : Goto FIN : Endif

Return

########################################################################
$TRT_X3_V6
# 2- alimenter les nouvelles colonnes si vide
# -------------------------------------------

#----- Ouverture des fichiers -----#
If clalev([F:BPC]) : Close File [BPC] : Endif
If clalev([F:BPC])  = 0 : Local File =DOSSIER+".BPCUSTOMER"  [BPC]  : Endif
If clalev([F:BPR])  = 0 : Local File =DOSSIER+".BPARTNER"    [BPR]  : Endif


#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB
Local Char CRITERE(250)
Local Char ACLE1, ACLE2, ACLE3
Raz COMPTEUR, STOP, CRITERE

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_BPC
Raz NB
If STOP=1
 STOP = 0
 CRITERE  = "[F:BPC]BPCNUM>ACLE1 "
Else
 CRITERE  = "1=1"
Endif

Trbegin [BPC]
GOK = 1

For [BPC]BPC0 Where evalue(CRITERE)

  # --- alimentation des champs
  Gosub RECUP_BPR

  Rewrite [F:BPC]
  If fstat
    Call ECR_TRACE("File BPCUSTOMER(BPCNUM)"-[F:BPC]BPCNUM+", Error ="-num$(fstat),1) From GESECRAN
    GOK=0 : Break
  Endif

  COMPTEUR += 1
  NB+=1
  If NB>GMAXUPDTRS
    ACLE1 = [F:BPC]BPCNUM
    STOP=1
    Break
  Endif

$SUITE_LOOP_BPC
Next

If GOK<1
  Rollback
Else
  Commit
  If STOP
    Goto LOOP_BPC
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [BPC], [BPR]

Return
########################################################################
$TRT_X3_V7
# 2- alimenter les nouvelles colonnes si vide
# -------------------------------------------

#----- Ouverture des fichiers -----#
If clalev([F:BPC]) : Close File [BPC] : Endif
If clalev([F:BPC])  = 0 : Local File =DOSSIER+".BPCUSTOMER"  [BPC]  : Endif
If clalev([F:BPR])  = 0 : Local File =DOSSIER+".BPARTNER"    [BPR]  : Endif


#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB
Local Char CRITERE(250)
Local Char ACLE1, ACLE2, ACLE3
Raz COMPTEUR, STOP, CRITERE

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_BPCV7
Raz NB
If STOP=1
 STOP = 0
 CRITERE  = "[F:BPC]BPCNUM>ACLE1 "
Else
 CRITERE  = "1=1"
Endif

Trbegin [BPC]
GOK = 1

For [BPC]BPC0 Where evalue(CRITERE)

  # --- alimentation des champs
  If dim([F:BPC]YFDIA1)>0 [F:BPC]DAYMON(0) = [F:BPC]YFDIA1 Endif
  If dim([F:BPC]YFDIA2)>0 [F:BPC]DAYMON(1) = [F:BPC]YFDIA2 Endif
  If dim([F:BPC]YFDIA3)>0 [F:BPC]DAYMON(2) = [F:BPC]YFDIA3 Endif
  If dim([F:BPC]YFDIA4)>0 [F:BPC]DAYMON(3) = [F:BPC]YFDIA4 Endif


  Rewrite [F:BPC]
  If fstat
    Call ECR_TRACE("File BPCUSTOMER(BPCNUM)"-[F:BPC]BPCNUM+", Error ="-num$(fstat),1) From GESECRAN
    GOK=0 : Break
  Endif

  COMPTEUR += 1
  NB+=1
  If NB>GMAXUPDTRS
    ACLE1 = [F:BPC]BPCNUM
    STOP=1
    Break
  Endif

$SUITE_LOOP_BPCV7
Next

If GOK<1
  Rollback
Else
  Commit
  If STOP
    Goto LOOP_BPCV7
  Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [BPC], [BPR]

Return


########################################################################
$RECUP_BPR

If [F:BPC]BPCPYR<>"" & [F:BPC]BPAPYR=""
    If [F:BPR]BPRNUM<>[F:BPC]BPCPYR
      Read [BPR]BPR0=[F:BPC]BPCPYR : If fstat Raz [F:BPR] Endif
    Endif
    [F:BPC]BPAPYR=[F:BPR]BPAADD
Endif
# Init. tiers risque avec le client facture car jusqu'à présent le ctrl encours est fait sur le client facture
If [F:BPC]BPCRSK="" [F:BPC]BPCRSK=[F:BPC]BPCINV Endif
If [F:BPC]CUR="" | [F:BPC]BPAADD="" | [F:BPC]CNTNAM=""
  If [F:BPR]BPRNUM<>[F:BPC]BPCNUM
    Read [BPR]BPR0=[F:BPC]BPCNUM : If fstat Raz [F:BPR] Endif
  Endif
  If [F:BPC]CUR=""    [F:BPC]CUR=[F:BPR]CUR : Endif
  If [F:BPC]BPAADD="" [F:BPC]BPAADD=[F:BPR]BPAADD : Endif
  If [F:BPC]CNTNAM="" [F:BPC]CNTNAM=[F:BPR]CNTNAM : Endif
Endif
Return

