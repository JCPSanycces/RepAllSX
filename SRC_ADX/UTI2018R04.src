#<AdxTL>@(#)0.0.0.0 $Revision$ 
##########################################################################
# UTI2018R04 UTI process for 2018Rn of X3
# ---------------------------------------------------------------------- #
#      moulinettes à passer en fin du patch de la 2018Rn - passage de Rn-1 vers Rn
#
#      correction utility to be done at the end of the patch - move from Rn-1 to Rn
#
##########################################################################
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTI2018R04 Processing") From LECFIC
  Call PATCH(nomap)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
# -----------------------------------------------------------------    #
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

#-------------------------------------------------------------#
# le test du dossier mère doit etre fait dans chaque uti.. pas ici
# Test of the mother folder must be done in each utixxx.. not HERE
#-------------------------------------------------------------#
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

Call EXE_UTI2018R04 (APPLI)

End

###################################################
Subprog EXE_UTI2018R04(LDOSSIER)
Value Char LDOSSIER

Call ECR_TRACE("START : UTI2018R04-Phase for folder "+LDOSSIER,0) From GESECRAN

#-------------------------------------------------------------#
# implementer ici l'appel de chaque uti necessaire
# le test du dossier mère doit etre fait dans chaque uti..
#
# implement here the call of each necessary uti
# Test of the mother folder must be done in each utixxx..
#-------------------------------------------------------------#

#  Call PATCH  (LDOSSIER) From UTIXXX
  If [F:ADS]MODULE(8) = 2 Then
    Call PATCH(LDOSSIER) From CNSPIVSTD          # Issue X3-70238 - 2018-03-28 by FGR
    Call PATCH(LDOSSIER) From UTIPJM201804001    # Issue X3-69372 - 2018-04-20 by FGR
  Endif

# Issue X3-68900 - 2018-04-06 by MUARN : purchase order, and receipt transaction
If [F:ADS]MODULE(5) = 2
  Call PATCH(LDOSSIER) From SUBPTC
  Call PATCH(LDOSSIER) From SUBPTR
  # Issue X3-83999 - 2018-03-26 by SR : Purchase returns transaction
  Call PATCH(LDOSSIER) From SUBPTN
Endif

#MIPEA - 2018-05-03 - X3-89706 - START
If [F:ADS]MODULE(8)=2
  Call PATCH(LDOSSIER) From UTIHRM009
Endif
#MIPEA - 2018-05-03 - X3-89706 - END


# Issue X3-7673 - 2018-05-02 by RBA : EDI_improvements_CRUD_method_for_receipt
  If [F:ADS]MODULE(8) = 2 Then
    Call PATCH(LDOSSIER) From EDIUTI2018R4
  Endif


# Issue X3-77876 - 2018-05-04 by JUSYN : Purchase receipt header NC creation
If [F:ADS]MODULE(5) = 2
  Call PATCH(LDOSSIER) From SUBPTR
Endif
# End issue X3-77876

Call ECR_TRACE("END : UTI2018R04-Phase for folder "+LDOSSIER,0) From GESECRAN
#----- Fin du traitement -----#
$FIN_UTI2018R04
End
