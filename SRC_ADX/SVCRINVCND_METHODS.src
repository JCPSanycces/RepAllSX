#* according to the new quantity as input parameter
#* Input
#* PVCRINVCNDLIN The line concerned by the splitting
#* PAMTTOREACH   The amount the has to remain on the present splitted/grouped line
#* (the difference has to go to a new line with 'To be invoice' status, if less)
#* (the difference has to come from existing lines with 'To be invoice' status, if greater)
#* It returns [V]CST_AERROR or [V]CST_AOK
#*!
$SET_INVOICE_AMT_CHANGED


Return
#---------------------------------------------------------------
#**
#* Class method SET_CLOSED_SCHEDINV_LINES is used set to "Close" all schedule invoice line that are not previously invoiced
#* It returns [V]CST_AERROR or [V]CST_AOK
#*!
$SET_CLOSED_SCHEDINV_LINES
Local Integer WLINE
  [L]ARET_VALUE = [V]CST_AOK

  For WLINE=1 To maxtab(this.VCRINVCNDLIN)
    If this.VCRINVCNDLIN(WLINE)<>null and find(this.VCRINVCNDLIN(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      If this.VCRINVCNDLIN(WLINE).INVCNDSTA<=1
        this.VCRINVCNDLIN(WLINE).INVCNDSTA = 4 #--"Closed"
      Endif
    Endif
  Next

Return
#---------------------------------------------------------------
#**
#* Class method SET_NOTCLOSED_SCHEDINV_LINES is used set to "To be invoiced" all schedule invoice line that are previously "Closed"
#* It returns [V]CST_AERROR or [V]CST_AOK
#*!
$SET_NOTCLOSED_SCHEDINV_LINES
Local Integer WLINE
  [L]ARET_VALUE = [V]CST_AOK

  For WLINE=1 To maxtab(this.VCRINVCNDLIN)
    If this.VCRINVCNDLIN(WLINE)<>null and find(this.VCRINVCNDLIN(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      If this.VCRINVCNDLIN(WLINE).INVCNDSTA=4
        this.VCRINVCNDLIN(WLINE).INVCNDSTA = 1 #--"To be invoiced"
      Endif
    Endif
  Next

Return
#---------------------------------------------------------------
#**
#* Class method SET_LINE_STATUS is used set to a new value (given as parameter) the invoice status of the line number also given as parameter
#* It returns [V]CST_AERROR or [V]CST_AOK
#* @param PVCRINVCNDLIN line number part of the key
#* @param PINVCNDSTA the new line status
#*!
$SET_LINE_STATUS
Local Integer WLINE
Local Tinyint WPREVINVCNDSTA

  [L]ARET_VALUE = [V]CST_AOK

  For WLINE=1 To maxtab(this.VCRINVCNDLIN)
    If this.VCRINVCNDLIN(WLINE)<>null and find(this.VCRINVCNDLIN(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      If this.VCRINVCNDLIN(WLINE).VCRINVCNDLIN = PVCRINVCNDLIN
        #--Updating the header totals
        WPREVINVCNDSTA = this.VCRINVCNDLIN(WLINE).INVCNDSTA

#If GUSER ="LD"
#  Infbox "this.VCRINVCNDLIN(WLINE).INVCNDSTA="-num$(this.VCRINVCNDLIN(WLINE).INVCNDSTA)
#Endif
        # 107888 : Scheduled invoices : X3-7222 (LD:28/11/16)
        # Invoice and credit note posting :
        # Invoice qty and invoice amount don't have to be modified
        # Just the status
#        If find(WPREVINVCNDSTA,2,3,4,5,6)>0
#          [L]ARET_VALUE=fmet this.TOTAL_REMOVE_FROM_INVOICE(PVCRINVCNDLIN)
#          If [L]ARET_VALUE>=[V]CST_AERROR
#            [L]ARET_VALUE = fmet this.ASETERROR("SET_LINE_STATUS","Error updating header totals",[V]CST_AERROR)
#            Return
#          Endif
#        Endif
        If find(WPREVINVCNDSTA,2,3,4,5,6)>0
          If find(PINVCNDSTA,2,3)=0
            [L]ARET_VALUE=fmet this.TOTAL_REMOVE_FROM_INVOICE(PVCRINVCNDLIN)
            If [L]ARET_VALUE>=[V]CST_AERROR
#              [L]ARET_VALUE = fmet this.ASETERROR("SET_LINE_STATUS","Error updating header totals",[V]CST_AERROR)
              [L]ARET_VALUE = fmet this.ASETERROR("SET_LINE_STATUS", mess(546,192,1),[V]CST_AERROR) # JUCON 20/01/17
              Return
            Endif
          Endif
        Endif
        # 107888 : Scheduled invoices : X3-7222 (LD:28/11/16)

        this.VCRINVCNDLIN(WLINE).INVCNDSTA = PINVCNDSTA

        If find(PINVCNDSTA,1,4)
          this.VCRINVCNDLIN(WLINE).IS_EXTRABILL=[V]CST_ANO
          this.VCRINVCNDLIN(WLINE).LIN_EXT_QTY=AVOID.ADEC
          this.VCRINVCNDLIN(WLINE).LIN_EXT_AMT=AVOID.ADEC
        Endif

        # 107888 : Scheduled invoices : X3-7222 (LD:28/11/16)
#        If find(PINVCNDSTA,2,3,5,6)>0
#          [L]ARET_VALUE=fmet this.TOTAL_ADD_FROM_INVOICE(PVCRINVCNDLIN)
#          If [L]ARET_VALUE>=[V]CST_AERROR
#            [L]ARET_VALUE = fmet this.ASETERROR("SET_LINE_STATUS","Error updating header totals",[V]CST_AERROR)
#            Return
#          Endif
#        Endif
        If find(PINVCNDSTA,2,3,5,6)>0
          If find(PINVCNDSTA,2,3)=0
            [L]ARET_VALUE=fmet this.TOTAL_ADD_FROM_INVOICE(PVCRINVCNDLIN)
            If [L]ARET_VALUE>=[V]CST_AERROR
#              [L]ARET_VALUE = fmet this.ASETERROR("SET_LINE_STATUS","Error updating header totals",[V]CST_AERROR)
              [L]ARET_VALUE = fmet this.ASETERROR("SET_LINE_STATUS", mess(546,192,1),[V]CST_AERROR) # JUCON 20/01/17
              Return
            Endif
          Endif
        Endif
        # 107888 : Scheduled invoices : X3-7222 (LD:28/11/16)
        Break
      Endif
    Endif
  Next

Return
#---------------------------------------------------------------
#**
#* Class method SET_LINE_INVOICE_NUM is used set to a new value (given as parameter) the invoice number/invoice line of the line number also given as parameter
#* It returns [V]CST_AERROR or [V]CST_AOK
#* @param PVCRINVCNDLIN line number part of the key
#* @param PSIHNUM the invoice number
#* @param PSIDLIN the invoice line number
#*!
$SET_LINE_INVOICE_NUM
Local Integer WLINE
  [L]ARET_VALUE = [V]CST_AOK

  For WLINE=1 To maxtab(this.VCRINVCNDLIN)
    If this.VCRINVCNDLIN(WLINE)<>null and find(this.VCRINVCNDLIN(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      If this.VCRINVCNDLIN(WLINE).VCRINVCNDLIN = PVCRINVCNDLIN
        this.VCRINVCNDLIN(WLINE).SIHNUM = PSIHNUM
        this.VCRINVCNDLIN(WLINE).SIDLIN = PSIDLIN
      Endif
    Endif
  Next

Return
#---------------------------------------------------------------
#**
#* Class method DISPATCH_ON_LASTLINE is used to dispatch a change of total header quantity/price/amount on the last scheduling line
#*!
$DISPATCH_ON_LASTLINE

  #--As every difference is dispatched on last line, percentages are to be in phase with header properties (quantity or amount)
  #--Exp : diminushing a original document line's quantity/amount that leads to a different percentage on a "invoiced" schdedule line
  Gosub RECALC_PERCENT_ALL_LINES
  If [L]ASTATUS>=[V]CST_AERROR : [L]ARET_VALUE=[L]ASTATUS: Return : Endif

  #--Control and re-dispatch on last line
  #--!! Due to rouding issues, it is possible that percentage of all other line to be slightly modified!!
  Gosub _CONTROL_DISPATCH_TOTALLINES
  If [L]ASTATUS>=[V]CST_AERROR : [L]ARET_VALUE=[L]ASTATUS: Return : Endif

Return
#---------------------------------------------------------------
#**
#* Class method DISPATCH_ON_ALL_LINES is used to dispatch a change of total header quantity/price/amount on all scheduling lines
#*!
$DISPATCH_ON_ALL_LINES

  #--We should re-calculate the qty/amounts
  #--Option 1 : according to the line's percentage in this method
  Gosub _RECALC_INVCNDQTY_ALL_LINES
  If [L]ASTATUS>=[V]CST_AERROR : [L]ARET_VALUE=[L]ASTATUS: Return : Endif
  #--Option 2 : I think it's better to delete line and re-start from scratch (?? What about lines beeing Invoiced/closed ??)

Return

#---------------------------------------------------------------
#**
#* Class method EQUIL_TOT_PERCENT_ON_LAST_LINE is used to dispatch the difference between 100% and total lines percentage on the last scheduling invoice line's percentage
#*!
$EQUIL_TOT_PERCENT_ON_LAST_LINE

  #--If total invpercent is <>100%, it add the delta on the last line's percentage
  Gosub _DISPATCH_TOTALLINES_INVPERCENT
  If [L]ASTATUS>=[V]CST_AERROR : [L]ARET_VALUE=[L]ASTATUS: Return : Endif

Return

#---------------------------------------------------------------
#**
#* Class method EQUIL_TOT_PERCENT_ON_LAST_LINE is used recalculate all scheduling invoices line's percentages (exp. in case of a total header quantity/price/amount modification)
#*!
$RECALC_PERCENT_ALL_LINES
Local Integer WLINE

  #--Line's percentages are re-calculated according to line's quantity and header quantity
  For WLINE=1 To maxtab(this.VCRINVCNDLIN)
    If this.VCRINVCNDLIN(WLINE)<>null and find(this.VCRINVCNDLIN(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
#&  and this.VCRINVCNDLIN(WLINE).INVCNDSTA<=1 #--Only changing "To be invoiced" lines
      #--% are re-calculated according to the line qty and header qty
      If   this.QTY>0
        this.VCRINVCNDLIN(WLINE).IS_PROP_CHG =[V]CST_AYES
        this.VCRINVCNDLIN(WLINE).INVPERCENT = arr((this.VCRINVCNDLIN(WLINE).INVCNDQTY*100/this.QTY),0.01)
        this.VCRINVCNDLIN(WLINE).IS_PROP_CHG =[V]CST_ANO
        #--In case of a changed price
        If this.VCRINVCNDLIN(WLINE).INVCNDSTA<=1
          If this.PRITYP = 2
            If this.NETPRIATI<>this.VCRINVCNDLIN(WLINE).DNETPRIATI
              #--Only +Vat fields filled
              this.VCRINVCNDLIN(WLINE).DNETPRINOT    = 0
              this.VCRINVCNDLIN(WLINE).DNETPRIATI    = this.NETPRIATI
              this.VCRINVCNDLIN(WLINE).INVCNDAMTNOT  = 0
              this.VCRINVCNDLIN(WLINE).INVCNDAMTATI  = arr((this.VCRINVCNDLIN(WLINE).INVCNDQTY*this.VCRINVCNDLIN(WLINE).DNETPRIATI),10^(-this.CUR_DECNBR))
            Endif
          Else
            If this.NETPRINOT<>this.VCRINVCNDLIN(WLINE).DNETPRINOT
              #--Only -Vat fields filled
              this.VCRINVCNDLIN(WLINE).DNETPRINOT    = this.NETPRINOT
              this.VCRINVCNDLIN(WLINE).DNETPRIATI    = 0
              this.VCRINVCNDLIN(WLINE).INVCNDAMTNOT  = arr((this.VCRINVCNDLIN(WLINE).INVCNDQTY*this.VCRINVCNDLIN(WLINE).DNETPRINOT),10^(-this.CUR_DECNBR))
              this.VCRINVCNDLIN(WLINE).INVCNDAMTATI  = 0
            Endif
          Endif
        Endif
      Else
        If this.PRITYP = 2
          #--Only +Vat fields filled
          If this.VCRINVCNDLIN(WLINE).INVCNDSTA<=1
            this.VCRINVCNDLIN(WLINE).DNETPRINOT   = 0
            this.VCRINVCNDLIN(WLINE).DNETPRIATI   = this.NETPRIATI
          Endif
          this.VCRINVCNDLIN(WLINE).IS_PROP_CHG =[V]CST_AYES
          this.VCRINVCNDLIN(WLINE).INVCNDAMTNOT = 0
          If this.AMTATI<>0
            this.VCRINVCNDLIN(WLINE).INVPERCENT = arr((this.VCRINVCNDLIN(WLINE).INVCNDAMTATI*100/this.AMTATI),0.01)
          Else
            this.VCRINVCNDLIN(WLINE).INVPERCENT = 0
          Endif
          this.VCRINVCNDLIN(WLINE).IS_PROP_CHG =[V]CST_ANO
        Else
          #--Only -Vat fields filled
          If this.VCRINVCNDLIN(WLINE).INVCNDSTA<=1
            this.VCRINVCNDLIN(WLINE).DNETPRINOT   = this.NETPRINOT
            this.VCRINVCNDLIN(WLINE).DNETPRIATI   = 0
          Endif
          this.VCRINVCNDLIN(WLINE).IS_PROP_CHG =[V]CST_AYES
          this.VCRINVCNDLIN(WLINE).INVCNDAMTATI = 0
          If this.AMTNOT<>0
            this.VCRINVCNDLIN(WLINE).INVPERCENT = arr((this.VCRINVCNDLIN(WLINE).INVCNDAMTNOT*100/this.AMTNOT),0.01)
          Else
            this.VCRINVCNDLIN(WLINE).INVPERCENT = 0
          Endif
          this.VCRINVCNDLIN(WLINE).IS_PROP_CHG =[V]CST_ANO
        Endif
      Endif
    Endif
  Next
  #--Control and re-dispatch on last line
  #--!! Due to rounding issues, the percentage of all other lines could slightly be modified, also!!
  Gosub _CONTROL_DISPATCH_TOTALLINES
  If [L]ASTATUS>=[V]CST_AERROR : [L]ARET_VALUE=[L]ASTATUS: Return : Endif

Return
#---------------------------------------------------------------
#**
#* Class method INIT_FROM_ORDER is used initialized header properties of an scheduling invoice header having an sales order as origin
#* The instance's header properties VCRNUMORI,VCRLINORI,VCRSEQORI have to be already filled
#*!
$INIT_FROM_ORDER

  [L]ASTATUS = func LIBSAL_INVCND_SOH.INIT_SVCRINVCND_FROM_ORDER_F(this.VCRNUMORI,this.VCRLINORI,this.VCRSEQORI,this)
  If ([L]ASTATUS >= [V]CST_AERROR)
    Return
  Endif

Return
#---------------------------------------------------------------
#**
#* Class method CHANGE_SCHEDULING_DATE is used to recalculate starting date/ending date an invoicing date for all lines
#* @param PNEWDATE Is the new date to start from
#*!
$CHANGE_SCHEDULING_DATE
#PNEWDATE : New date

Local Integer WSIGMA,WTEMPSIGMA
  #--Does the schedule invoice have ohter lines than 'To be invoiced' ?
  WTEMPSIGMA = sigma(1,maxtab(this.VCRINVCNDLIN),
&   (     this.VCRINVCNDLIN(indcum)<>null and
&         this.VCRINVCNDLIN(indcum).INVCNDSTA>1 and
&    find(this.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0)
&  &( WSIGMA=0 and sigma(WSIGMA=1,1,1)))
  #--If 'Yes', we can't proceed
  If WTEMPSIGMA>0
    [L]ARET_VALUE = fmet this.ASETERROR("CHANGE_SCHEDULING_DATE",mess(500,192,1),[V]CST_AERROR)
    Return
  Endif

Local File TABINVCND    [INVCND]
Local File TABINVCNDLIN [INVCNDD]
Local File SVCRINVCND   [SVIC]
Local File SVCRINVCNDD  [SVICD]
Local File FACILITY     [FCY]

Local Integer WLINE
Local Char    WMESS(255)

Local Date     PSTARTDATE : PSTARTDATE = PNEWDATE

  this.VCRINVCNDDAT=PNEWDATE


  #--Reading the right INVCND entry
  If this.INVCND<>AVOID.ACHAR
    Read [INVCND]INVCND0 = this.INVCND;this.LEG
    If fstat<>[V]CST_AOK
      #--Message...
      #--"Error reading the INVCND code.."
      [L]ARET_VALUE = fmet this.ASETERROR("CHANGE_SCHEDULING_DATE",func AFNC.MES1(mess(453,192,1),this.INVCND+"~"+this.LEG),[V]CST_AERROR)
      Return
    Endif
  Else
    Raz [F:INVCND]
  Endif

  If [F:FCY]FCY<>this.SALFCY
    Read [FCY]FCY0 = this.SALFCY
    If fstat : Raz [F:FCY] : Endif
  Endif

  #--Line's percentages are re-calculated according to line's quantity and header quantity
  For WLINE=1 To maxtab(this.VCRINVCNDLIN)
    If this.VCRINVCNDLIN(WLINE)<>null and find(this.VCRINVCNDLIN(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
&  and this.VCRINVCNDLIN(WLINE).INVCNDSTA<=1 #--Only changing "To be invoiced" lines
      Case [F:INVCND]INVCNDTYP
        When 0 :#--1 line having 100% of header's values

        When 1 :#--Normal

        When 2 :#--Fixed percent
                #--Reading the right INVCND entry
                If this.INVCND<>AVOID.ACHAR and this.VCRINVCNDLIN(WLINE).INVCNDLIN<>AVOID.AINT
                  Read [INVCNDD]INVCNDD0 = this.INVCND;this.LEG;this.VCRINVCNDLIN(WLINE).INVCNDLIN
                  If fstat<>[V]CST_AOK
                    Raz [F:INVCNDD]
                  Endif
                Else
                  Raz [F:INVCNDD]
                Endif
                Gosub _SET_VCRINVCNDLIN_VCRINVCNDDAT_TYPE_FIXEDPERCENT
        When 3 :#--Periodicity
                Gosub _SET_VCRINVCNDLIN_VCRINVCNDDAT_TYPE_PERIODICITY
        When Default :#--Other that don't need a invoice conditionning

      Endcase
      If [L]ARET_VALUE>=[V]CST_AERROR : Break : Endif
    Endif
  Next

Return
#---------------------------------------------------------------
#**
#* Class method CREATE_DETAIL_SCHEDINV is used to create the scheduling invoice's lines for the original header document and according to the invoice condition
#* Warning : if the scheduling invoice already has lines, those will be deleted
#*!
$CREATE_DETAIL_SCHEDINV
Local File TABINVCND    [INVCND]
Local File TABINVCNDLIN [INVCNDD]
Local File SVCRINVCND   [SVIC]
Local File SVCRINVCNDD  [SVICD]
Local File FACILITY     [FCY]

Local Date     PSTARTDATE : PSTARTDATE = this.DOCDAT
If this.VCRINVCNDDAT<>[0/0/0]
  PSTARTDATE = this.VCRINVCNDDAT
Endif

  #--Reading the right INVCND entry
  If this.INVCND<>AVOID.ACHAR
    Read [INVCND]INVCND0 = this.INVCND;this.LEG
    If fstat<>[V]CST_AOK
      #--Message...
      #--"Error reading the INVCND code.."
      [L]ARET_VALUE = fmet this.ASETERROR("CREATE_DETAIL_SCHEDINV",func AFNC.MES1(mess(453,192,1),this.INVCND+"~"+this.LEG),[V]CST_AERROR)
      Return
    Endif
  Else
    Raz [F:INVCND]
  Endif

  Case [F:INVCND]INVCNDTYP
    When 0 :#--1 line having 100% of header's values
           Gosub _CREATE_DETAIL_SCHEDINV_100_FIXEDPERCENT
    When 1 :#--Normal
           Gosub _CREATE_DETAIL_SCHEDINV_TYPE_NORMAL
    When 2 :#--Fixed percent
           Gosub _CREATE_DETAIL_SCHEDINV_TYPE_FIXEDPERCENT
    When 3 :#--Periodicity
           Gosub _CREATE_DETAIL_SCHEDINV_TYPE_PERIODICITY
    When Default :#--Other that don't need a invoice conditionning

  Endcase
Return
##################################################################################################
#--------------------------------------
$_CREATE_DETAIL_SCHEDINV_TYPE_NORMAL

  If this.INVCNDTYP<>1 : Return : Endif  #--Normal type only

Local Integer WLINE,WIJCPO

  #--An error is thrown if there already are collections items
  If maxtab(this.VCRINVCNDLIN)>0
    For WLINE=1 To maxtab(this.VCRINVCNDLIN)
      If this.VCRINVCNDLIN(WLINE)<>null and find(this.VCRINVCNDLIN(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
        WIJCPO=fmet this.ADELLINE("VCRINVCNDLIN",this.VCRINVCNDLIN(WLINE).AORDER)
        If WIJCPO=[V]CST_ANOTDEFINED
          [L]ARET_VALUE = fmet this.ASETERROR("VCRINVCNDLIN",func AFNC.MES1(mess(454,192,1),num$(this.VCRINVCNDLIN(WLINE).AORDER)),[V]CST_AERROR)
          Return
        Endif
      Endif
    Next
  Endif

Return
#--------------------------------------
$_CREATE_DETAIL_SCHEDINV_TYPE_FIXEDPERCENT

  If this.INVCNDTYP<>2 : Return : Endif #--Fixed percent only

Local Integer WLINE,WIJCPO

  #--An error is thrown if there already are collections items
  If maxtab(this.VCRINVCNDLIN)>0
    For WLINE=1 To maxtab(this.VCRINVCNDLIN)
      If this.VCRINVCNDLIN(WLINE)<>null and find(this.VCRINVCNDLIN(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
        WIJCPO=fmet this.ADELLINE("VCRINVCNDLIN",this.VCRINVCNDLIN(WLINE).AORDER)
        If WIJCPO=[V]CST_ANOTDEFINED
          [L]ARET_VALUE = fmet this.ASETERROR("VCRINVCNDLIN",func AFNC.MES1(mess(454,192,1),num$(this.VCRINVCNDLIN(WLINE).AORDER)),[V]CST_AERROR)
          Return
        Endif
      Endif
    Next
  Endif

  #--This type on scheduled invoice term already is splited into one or more lines
  #--The creation is done by following those lines one to one into the SVCRINVCND scheduled table

  #--1st : addind the same number of invoices term into the SVCRINVCND table
  #--2nd : setting the dates according to the parameters filled for each line
  #--3rd : spliting the quantity and amount of the original document line for each scheduled line

Local Decimal WTOTINVPERCENT,WTOTQTY
Local Integer WTIM_OK : #-- 0-pas traité , 1-encours 2-terminé
Local Integer WNBLIGCOLL,WLINE : WNBLIGCOLL=0
#--For $_SET_VCRINVCNDLIN_VCRINVCNDDAT

Local Char    WMESS(255)
Local Date    DAT_PERFROM, DAT_PERTO
Local Integer WMAXTAB,WIJQTY
Local Decimal WMINAMTNOT_CONV, WSKYP_PREV_INVPERCENT,WPREV_INVCNDD_MINAMT,WPREV_QTY,WTEMP_PERCENT,WTEMP_IFQTY
Local Integer WSKYP_CURRENT,WROWCOUNT_INVCNDD,WCOUNT_INVCNDD,WTODELCURRLINE

# 107888 : Scheduled invoices : X3-7222 (LD:28/11/16)
Local Integer WNETPRINOT
# 107888 : Scheduled invoices : X3-7222 (LD:28/11/16)

  If [F:FCY]FCY<>this.SALFCY
    Read [FCY]FCY0 = this.SALFCY
    If fstat : Raz [F:FCY] : Endif
  Endif

  WTIM_OK               = 0
  WSKYP_CURRENT         = 0
  WSKYP_PREV_INVPERCENT = 0
  WCOUNT_INVCNDD        = 0
  WPREV_QTY             = 0

  Filter [INVCNDD] Where INVCND=this.INVCND & LEG=this.LEG
&                    Order By Key MACLE=INVCND Asc;INVNBMONTHS Asc;INVNBDAYS Asc;INVDAYMON Asc
  WROWCOUNT_INVCNDD = rowcount([F:INVCNDD])
  If WROWCOUNT_INVCNDD=0 and this.LEG<>AVOID.ACHAR
    #--New try with empty leg
    this.LEG = AVOID.ACHAR
    Filter [INVCNDD] Where INVCND=this.INVCND & LEG=this.LEG
&                    Order By Key MACLE=INVCND Asc;INVNBMONTHS Asc;INVNBDAYS Asc;INVDAYMON Asc
    WROWCOUNT_INVCNDD = rowcount([F:INVCNDD])
  Endif
  For [INVCNDD]MACLE
    WTIM_OK=1
    WCOUNT_INVCNDD += 1
    If WSKYP_CURRENT = 0
      #--We keep adding a line if not on the last INVCNDD record or if the last record does not have a min amount filled
      WLINE_PREV = WLINE
      WLINE = fmet this.ADDLINE("VCRINVCNDLIN",[V]CST_ALASTPOS)
      If WLINE=[V]CST_ANOTDEFINED
        #--Message...
        #--"Error inserting into VCRINVCNDLIN collection"
        [L]ARET_VALUE = fmet this.ASETERROR("_SET_VCRINVCNDLIN_FROM_TABINVCND",mess(455,192,1),[V]CST_AERROR)
        Break
      Endif
      WSKYP_PREV_INVPERCENT = 0

      # 107888 : Scheduled invoices : X3-7222 (LD:28/11/16)
      #WNETPRINOT = this.VCRINVCNDLIN(WLINE).DNETPRINOT
      WNETPRINOT = this.NETPRINOT
      # 107888 : Scheduled invoices : X3-7222 (LD:28/11/16)

      WPREV_INVCNDD_MINAMT  = [F:INVCNDD]MINAMTNOT
      #--Setting properties from TABINVCND to the actual collection line
      #--It is done during the ADDLINE_AFTER event...
      this.VCRINVCNDLIN(WLINE).INVCNDLIN=[F:INVCNDD]INVCNDLIN
      If this.VCRINVCNDLIN(WLINE).INVPERCENT=0 #--Could have be done by ADDLINE_AFTER

        #--This will prevent triggering set/propagate accessor
        this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_AYES
        this.VCRINVCNDLIN(WLINE).INVPERCENT=[F:INVCNDD]INVPERCENT
        this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_ANO

        If this.VCRINVCNDLIN(WLINE).INVCNDQTY=0
          this.VCRINVCNDLIN(WLINE).INVCNDQTY = arr((this.VCRINVCNDLIN(WLINE).INVPERCENT*this.QTY)/100,10^(-this.SAU_UOMDEC))
        Endif
      Endif
      WPREV_QTY = this.VCRINVCNDLIN(WLINE).INVCNDQTY
      #--No need to get further with adding lines if already reached the original document's quantity/amount
      #If sum(this.VCRINVCNDLIN(1..maxtab(this.VCRINVCNDLIN)).INVCNDQTY)>= this.QTY
      WTODELCURRLINE=[V]CST_ANO
      #--CPO 05/09/2016 No sigma because of the <>null test and the use of *
      If 1=1
        WTEMP_IFQTY = sigma(1,maxtab(this.VCRINVCNDLIN),
&          this.VCRINVCNDLIN(indcum).INVCNDQTY*(find(this.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0))
#        If sigma(1,maxtab(this.VCRINVCNDLIN),
#&          this.VCRINVCNDLIN(indcum).INVCNDQTY*(find(this.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0))> this.QTY
      Else
        WTEMP_IFQTY = 0
        For WIJQTY=1 To maxtab(this.VCRINVCNDLIN)
          If this.VCRINVCNDLIN(indcum)<>null and find(this.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
            WTEMP_IFQTY += this.VCRINVCNDLIN(indcum).INVCNDQTY
          Endif
        Next
      Endif
      If WTEMP_IFQTY > this.QTY
      #--End no sigma
        #--If a user has a invoice condition 50%/25%/25% and no rounding for his unit and a quantity of 10 for exp
        #--The system creates 2 invoice schedule lines : 50% and 50%
        #--Because rounding(10*25%,0)=3 for both lines at 25%
        #--Therefore, here the condition of the sigma if true : Sigma returns 5+3+3=11>10 and deletes the last generated line
        #--and add the remainder on the previous line.
        #--In this case, we should try to compute last line according to the previous one's percentage
        #--Previous lilne percentage is 30% (because of rounding the quantity that redefines the percentage at 30%)
        #--So, we'll try to apply to the last line the 100% minus Sigma of previous line's percentage
        #--CPO 05/09/2016 No sigma because of the <>null test and the use of *
        If 1=1
          WTEMP_PERCENT = (100-sigma(1,maxtab(this.VCRINVCNDLIN)-1,
&           this.VCRINVCNDLIN(indcum).INVPERCENT*(find(this.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0))-[F:INVCNDD]INVPERCENT)
        Else
          For WIJQTY=1 To maxtab(this.VCRINVCNDLIN)-1
            If this.VCRINVCNDLIN(indcum)<>null and find(this.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
              WTEMP_PERCENT += this.VCRINVCNDLIN(indcum).INVPERCENT
            Endif
          Next
          WTEMP_PERCENT = 100 - WTEMP_PERCENT -[F:INVCNDD]INVPERCENT
        Endif
        #--End no sigma
        #--This will prevent triggering set/propagate accessor
        this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_AYES
        this.VCRINVCNDLIN(WLINE).INVPERCENT=[F:INVCNDD]INVPERCENT+WTEMP_PERCENT
        this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_ANO

        this.VCRINVCNDLIN(WLINE).INVCNDQTY = arr((this.VCRINVCNDLIN(WLINE).INVPERCENT*this.QTY)/100,10^(-this.SAU_UOMDEC))

        WPREV_QTY = this.VCRINVCNDLIN(WLINE).INVCNDQTY


        #--CPO 05/09/2016 No sigma because of the <>null test and the use of *
        If 1=1
#        If sigma(1,maxtab(this.VCRINVCNDLIN),
#&         this.VCRINVCNDLIN(indcum).INVCNDQTY*(find(this.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0))> this.QTY
          WTEMP_IFQTY = sigma(1,maxtab(this.VCRINVCNDLIN),
&          this.VCRINVCNDLIN(indcum).INVCNDQTY*(find(this.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0))
        Else
          WTEMP_IFQTY = 0
          For WIJQTY=1 To maxtab(this.VCRINVCNDLIN)
            If this.VCRINVCNDLIN(indcum)<>null and find(this.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
              WTEMP_IFQTY += this.VCRINVCNDLIN(indcum).INVCNDQTY
            Endif
          Next
        Endif
        If WTEMP_IFQTY > this.QTY
        #--End no sigma
          WROWCOUNT_INVCNDD = WCOUNT_INVCNDD
          WTODELCURRLINE=[V]CST_AYES
        Endif
      Endif
      #--First, check with the min amount of the invoice conditionning, if any
      If WCOUNT_INVCNDD=WROWCOUNT_INVCNDD and [F:INVCNDD]MINAMTNOT>0 and this.VCRINVCNDLIN(WLINE).INVCNDQTY>0
        #--Always controlling the -Vat amount
        #--First convert the MINAMTNOT into the document's currency
        [L]WMINAMTNOT_CONV = [F:INVCNDD]MINAMTNOT
        If [F:INVCNDD]MINAMTNOTCUR<>this.CUR
          Call CONVERT(this.ACTX,[F:INVCNDD]MINAMTNOTCUR,this.CUR,AVOID.ACHAR,AVOID.AINT,this.DOCDAT,[F:INVCNDD]MINAMTNOT,WMINAMTNOT_CONV,ARET_VALUE) From TRTDEV_SYRA
          If [L]ARET_VALUE > 0
            [L]ARET_VALUE = fmet this.ASETERROR("",mess(463,192,1),[V]CST_AERROR)
            Break
          Endif
        Endif
        #--
        # 107888 : Scheduled invoices : X3-7222 (LD:28/11/16)
        #If arr((this.VCRINVCNDLIN(WLINE).INVCNDQTY*this.VCRINVCNDLIN(WLINE).DNETPRINOT),10^(-this.CUR_DECNBR))<WMINAMTNOT_CONV
        If arr((this.VCRINVCNDLIN(WLINE).INVCNDQTY*WNETPRINOT),10^(-this.CUR_DECNBR))<WMINAMTNOT_CONV
        # 107888 : Scheduled invoices : X3-7222 (LD:28/11/16)
          #--We dont't need the added last line anymore
          [L]ARET_VALUE = fmet this.ADELLINE("VCRINVCNDLIN",this.VCRINVCNDLIN(WLINE).AORDER)
          If [L]ARET_VALUE=[V]CST_ANOTDEFINED
            #--"Error deleting line from VCRINVCNDLIN collection"
            [L]ARET_VALUE = fmet this.ASETERROR("_SET_VCRINVCNDLIN_FROM_TABINVCND",func AFNC.MES1(mess(454,192,1),num$(this.VCRINVCNDLIN(WLINE).AORDER)),[V]CST_AERROR)
            Break
          Endif
          #--All is added to the previous line
          WLINE = WLINE_PREV
          #--This will trigger set/propagate accessor
          this.VCRINVCNDLIN(WLINE).INVPERCENT += [F:INVCNDD]INVPERCENT
          this.VCRINVCNDLIN(WLINE).INVCNDQTY  += arr(([F:INVCNDD]INVPERCENT*this.QTY)/100,10^(-this.SAU_UOMDEC))
        Endif
      Elsif WCOUNT_INVCNDD=WROWCOUNT_INVCNDD and (WTODELCURRLINE=[V]CST_AYES or this.VCRINVCNDLIN(WLINE).INVCNDQTY<=0)
        #--Second, if non min amount, check if the last line's qty >0, if not, we skyp the last line and add everything to the previous one
        #--We dont't need the added last line anymore
        [L]ARET_VALUE = fmet this.ADELLINE("VCRINVCNDLIN",this.VCRINVCNDLIN(WLINE).AORDER)
        If [L]ARET_VALUE=[V]CST_ANOTDEFINED
          #--"Error deleting line from VCRINVCNDLIN collection"
          [L]ARET_VALUE = fmet this.ASETERROR("_SET_VCRINVCNDLIN_FROM_TABINVCND",func AFNC.MES1(mess(454,192,1),num$(this.VCRINVCNDLIN(WLINE).AORDER)),[V]CST_AERROR)
          Break
        Endif
        #--All is added to the previous line
        WLINE = WLINE_PREV
        #--This will trigger set/propagate accessor
        this.VCRINVCNDLIN(WLINE).INVPERCENT += [F:INVCNDD]INVPERCENT
        this.VCRINVCNDLIN(WLINE).INVCNDQTY  += arr(([F:INVCNDD]INVPERCENT*this.QTY)/100,10^(-this.SAU_UOMDEC))
      Endif
    Else
      WSKYP_CURRENT = 0
      this.VCRINVCNDLIN(WLINE).INVCNDLIN=[F:INVCNDD]INVCNDLIN

      # 107888 : Scheduled invoices : X3-7222 (LD:28/11/16)
      #WNETPRINOT = this.VCRINVCNDLIN(WLINE).DNETPRINOT
      WNETPRINOT = this.NETPRINOT
      # 107888 : Scheduled invoices : X3-7222 (LD:28/11/16)

      #--This will prevent triggering set/propagate accessor
      this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_AYES
      this.VCRINVCNDLIN(WLINE).INVPERCENT= WSKYP_PREV_INVPERCENT+[F:INVCNDD]INVPERCENT
      this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_ANO

      this.VCRINVCNDLIN(WLINE).INVCNDQTY = arr((this.VCRINVCNDLIN(WLINE).INVPERCENT*this.QTY)/100,10^(-this.SAU_UOMDEC))
      #--After the eventual ADELLINE
      #WSKYP_PREV_INVPERCENT = 0

      #--No need to get further with adding lines if already reached the original document's quantity/amount
      #If sum(this.VCRINVCNDLIN(1..maxtab(this.VCRINVCNDLIN)).INVCNDQTY)>= this.QTY
      WTODELCURRLINE=[V]CST_ANO
      #--CPO 05/09/2016 No sigma because of the <>null test and the use of *
      If 1=1
#      If sigma(1,maxtab(this.VCRINVCNDLIN),
#&        this.VCRINVCNDLIN(indcum).INVCNDQTY*(find(this.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0))> this.QTY
        WTEMP_IFQTY = sigma(1,maxtab(this.VCRINVCNDLIN),
&        this.VCRINVCNDLIN(indcum).INVCNDQTY*(find(this.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0))
      Else
        WTEMP_IFQTY = 0
        For WIJQTY=1 To maxtab(this.VCRINVCNDLIN)
          If this.VCRINVCNDLIN(indcum)<>null and find(this.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
            WTEMP_IFQTY += this.VCRINVCNDLIN(indcum).INVCNDQTY
          Endif
        Next
      Endif
      If WTEMP_IFQTY > this.QTY
      #--End no sigma
        WROWCOUNT_INVCNDD = WCOUNT_INVCNDD
        WTODELCURRLINE=[V]CST_AYES
      Endif

      #--------
      If WCOUNT_INVCNDD=WROWCOUNT_INVCNDD and (WTODELCURRLINE=[V]CST_AYES or this.VCRINVCNDLIN(WLINE).INVCNDQTY<=0)
        #--Second, if non min amount, check if the last line's qty >0, if not, we skyp the last line and add everything to the previous one
        #--We dont't need the added last line anymore
        [L]ARET_VALUE = fmet this.ADELLINE("VCRINVCNDLIN",this.VCRINVCNDLIN(WLINE).AORDER)
        If [L]ARET_VALUE=[V]CST_ANOTDEFINED
          #--"Error deleting line from VCRINVCNDLIN collection"
          [L]ARET_VALUE = fmet this.ASETERROR("_SET_VCRINVCNDLIN_FROM_TABINVCND",func AFNC.MES1(mess(454,192,1),num$(this.VCRINVCNDLIN(WLINE).AORDER)),[V]CST_AERROR)
          Break
        Endif
        #--All is added to the previous line
        WLINE = WLINE_PREV
        this.VCRINVCNDLIN(WLINE).INVCNDLIN=[F:INVCNDD]INVCNDLIN

        #--This will prevent triggering set/propagate accessor
        this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_AYES
        this.VCRINVCNDLIN(WLINE).INVPERCENT+= WSKYP_PREV_INVPERCENT+[F:INVCNDD]INVPERCENT
        this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_ANO

        this.VCRINVCNDLIN(WLINE).INVCNDQTY = arr((this.VCRINVCNDLIN(WLINE).INVPERCENT*this.QTY)/100,10^(-this.SAU_UOMDEC))
      Endif
      #X3-109669 (LCC 25/09/18) VCRINVCND : Error message
      #If the previous line has not been took into account (QTY <=0) the variable WSKYP_PREV_INVPERCENT can't be initialized
      #WSKYP_PREV_INVPERCENT = 0
      #End X3-109669 (LCC 25/09/18) VCRINVCND : Error message
      #--------
    Endif

    #--Is the calculated amount greater then the min amount of the scheduling invoice condition ?
    If [F:INVCNDD]MINAMTNOT<>0 and this.VCRINVCNDLIN(WLINE).INVCNDQTY>0
      #--Always controlling the +Vat amount
      #--First convert the MINAMTNOT into the document's currency
      [L]WMINAMTNOT_CONV = [F:INVCNDD]MINAMTNOT
      If [F:INVCNDD]MINAMTNOTCUR<>this.CUR
        Call CONVERT(this.ACTX,[F:INVCNDD]MINAMTNOTCUR,this.CUR,AVOID.ACHAR,AVOID.AINT,this.DOCDAT,[F:INVCNDD]MINAMTNOT,WMINAMTNOT_CONV,ARET_VALUE) From TRTDEV_SYRA
        If [L]ARET_VALUE > 0
          [L]ARET_VALUE = fmet this.ASETERROR("",mess(463,192,1),[V]CST_AERROR)
          Break
        Endif
      Endif
      #--
      # 107888 : Scheduled invoices : X3-7222 (LD:28/11/16)
      #If arr((this.VCRINVCNDLIN(WLINE).INVCNDQTY*this.VCRINVCNDLIN(WLINE).DNETPRINOT),10^(-this.CUR_DECNBR))<WMINAMTNOT_CONV
      If arr((this.VCRINVCNDLIN(WLINE).INVCNDQTY*WNETPRINOT),10^(-this.CUR_DECNBR))<WMINAMTNOT_CONV
      # 107888 : Scheduled invoices : X3-7222 (LD:28/11/16)

        #--The last line
        If WCOUNT_INVCNDD<WROWCOUNT_INVCNDD
          WSKYP_CURRENT = 1
          WSKYP_PREV_INVPERCENT += [F:INVCNDD]INVPERCENT #this.VCRINVCNDLIN(WLINE).INVPERCENT
        Else
          #--We have to continue filling for the last line (in this case, WLINE is the previous good line)
          WSKYP_CURRENT = 1
          #--Does the modified previous line respect the min amount ?
          # 107888 : Scheduled invoices : X3-7222 (LD:28/11/16)
          #If arr((this.VCRINVCNDLIN(WLINE).INVCNDQTY*this.VCRINVCNDLIN(WLINE).DNETPRINOT),10^(-this.CUR_DECNBR))<WPREV_INVCNDD_MINAMT
          If arr((this.VCRINVCNDLIN(WLINE).INVCNDQTY*WNETPRINOT),10^(-this.CUR_DECNBR))<WPREV_INVCNDD_MINAMT
          # 107888 : Scheduled invoices : X3-7222 (LD:28/11/16)
            [L]WSKYP_CURRENT = 0
          Endif
        Endif
      Endif
    #--Does the current line has a qty ?
    Elsif this.VCRINVCNDLIN(WLINE).INVCNDQTY<=0
      If WCOUNT_INVCNDD<WROWCOUNT_INVCNDD
        WSKYP_CURRENT = 1
        WSKYP_PREV_INVPERCENT += [F:INVCNDD]INVPERCENT #this.VCRINVCNDLIN(WLINE).INVPERCENT
      Else
        #--We have to continue filling for the last line (in this case, WLINE is the previous good line)
        [L]WSKYP_CURRENT = 0#
      Endif
    Endif
    If [L]WSKYP_CURRENT=0
      #--..
      #--Setting the PERFROM/PERTO/NEXINVDAT properties
      Gosub _SET_VCRINVCNDLIN_VCRINVCNDDAT_TYPE_FIXEDPERCENT
      If [L]ARET_VALUE>=[V]CST_AERROR
        Break
      Endif
      #--Setting properties from order line
      Gosub _SET_VCRINVCNDLIN_DISPATCH_HEADER
      If [L]ARET_VALUE>=[V]CST_AERROR
        Break
      Endif

      #--Very important !
      #--Check if accessors triggered errors
      [L]ARET_VALUE = fmet this.AGETMAXERROR('')
      If [L]ARET_VALUE>=[V]CST_AERROR : Break : Endif
    Endif
  Next
  Filter [F:INVCNDD]

  #--If error, no need to go further...
  If [L]ARET_VALUE>=[V]CST_AERROR : Return : Endif
  If WTIM_OK=1
    #--For rounding causes, we'll have to eventually fill the last line with the difference
    #--Done in AINSERT/AUPDATE CONTROL_BEFORE
    Gosub _CONTROL_DISPATCH_TOTALLINES
    If [L]ASTATUS>=[V]CST_AERROR : [L]ARET_VALUE=[L]ASTATUS: Return : Endif
  Else
    #--Message...
    #--"No entry found for the current INVCND code"
    [L]ARET_VALUE = fmet this.ASETERROR("_SET_VCRINVCNDLIN_FROM_TABINVCND",func AFNC.MES1(mess(453,192,1),this.INVCND+"~"+this.LEG),[V]CST_AERROR)
  Endif

Return
#--------------------------------------
$_CREATE_DETAIL_SCHEDINV_TYPE_PERIODICITY

  If this.INVCNDTYP<>3 : Return : Endif #--Periodicity type only

Local Integer WLINE,WIJCPO

  #--An error is thrown if there already are collections items
  If maxtab(this.VCRINVCNDLIN)>0
    For WLINE=1 To maxtab(this.VCRINVCNDLIN)
      If this.VCRINVCNDLIN(WLINE)<>null and find(this.VCRINVCNDLIN(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
        WIJCPO=fmet this.ADELLINE("VCRINVCNDLIN",this.VCRINVCNDLIN(WLINE).AORDER)
        If WIJCPO=[V]CST_ANOTDEFINED
          [L]ARET_VALUE = fmet this.ASETERROR("VCRINVCNDLIN",func AFNC.MES1(mess(454,192,1),num$(this.VCRINVCNDLIN(WLINE).AORDER)),[V]CST_AERROR)
          Return
        Endif
      Endif
    Next
  Endif

  #--1st : addind the same number of invoices term into the SVCRINVCND table
  #--2nd : setting the dates according to the parameters filled for each line
  #--3rd : spliting the quantity and amount of the original document line for each scheduled line

Local Decimal WTOTINVPERCENT,WTOTQTY
Local Integer WTIM_OK : #-- 0-pas traité , 1-encours 2-terminé
Local Integer WNBLIGCOLL,WLINE : WNBLIGCOLL=0
Local Integer WLINE
Local Char    WMESS(255)
Local Date    DAT_PERFROM, DAT_PERTO
Local Integer WMAXTAB,WIJQTY
Local Decimal WMINAMTNOT_CONV, WSKYP_PREV_INVPERCENT,WPREV_INVCNDD_MINAMT,WPREV_QTY,WSKYP_PREV_QTY,WTEMP_QTY,WTEMP_IFQTY
Local Integer WSKYP_CURRENT,WROWCOUNT_INVCNDD,WCOUNT_INVCNDD,WTODELCURRLINE

  If [F:FCY]FCY<>this.SALFCY
    Read [FCY]FCY0 = this.SALFCY
    If fstat : Raz [F:FCY] : Endif
  Endif

  WTIM_OK=0

  #--There is only one entry into the TABINVCND table
  #--The number of lines to be added is given by TABINVCND's property:
  #--FREQINV
  Read [F:INVCND]INVCND0=this.INVCND;this.LEG
  If fstat
    this.LEG=AVOID.ACHAR
    Read [F:INVCND]INVCND0=this.INVCND;this.LEG
    If fstat
      #--Message...
      #--"No entry found for the current INVCND code"
      [L]ARET_VALUE = fmet this.ASETERROR("_SET_VCRINVCNDLIN_FROM_TABINVCND",func AFNC.MES1(mess(453,192,1),this.INVCND+"~"+this.LEG),[V]CST_AERROR)
    Endif
  Endif
  If [L]ARET_VALUE>=[V]CST_AERROR : Return : Endif

  WSKYP_CURRENT         = 0
  WSKYP_PREV_INVPERCENT = 0
  WSKYP_PREV_QTY        = 0
  WCOUNT_INVCNDD        = 0
  WPREV_QTY             = 0
  WROWCOUNT_INVCNDD     = [F:INVCND]FREQINV

  For WNBLIGCOLL=1 To [F:INVCND]FREQINV
    WCOUNT_INVCNDD += 1
    If WSKYP_CURRENT = 0
      #--We keep adding a line if not on the last INVCNDD record or if the last record does not have a min amount filled
      WLINE_PREV = WLINE
      WLINE = fmet this.ADDLINE("VCRINVCNDLIN",[V]CST_ALASTPOS)
      If WLINE=[V]CST_ANOTDEFINED
        #--Message...
        #--"Error inserting into VCRINVCNDLIN collection"
        [L]ARET_VALUE = fmet this.ASETERROR("VCRINVCNDLIN",MES(455,192,1),[V]CST_AERROR)
        Break
      Endif
      WSKYP_PREV_INVPERCENT = 0
      WSKYP_PREV_QTY        = 0
      #--Setting properties from TABINVCND to the actual collection line
      #--It is done during the ADDLINE_AFTER event...
      this.VCRINVCNDLIN(WLINE).INVCNDLIN=0
      If this.VCRINVCNDLIN(WLINE).INVPERCENT=0 #--Could have be done by ADDLINE_AFTER

        #--This will prevent triggering set/propagate accessor
        If [F:INVCND]FREQINV<>0
          this.VCRINVCNDLIN(WLINE).INVCNDQTY  = arr((this.QTY/[F:INVCND]FREQINV),10^(-this.SAU_UOMDEC))
        Else
          this.VCRINVCNDLIN(WLINE).INVCNDQTY  = 0
        Endif
        If this.VCRINVCNDLIN(WLINE).INVCNDQTY > 0 #--Exp: freqinv=12 and qty=5 => 5/12=0.42 => if sau_uomdec=0 => =0 !
          this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_AYES
          If this.QTY<>0
            this.VCRINVCNDLIN(WLINE).INVPERCENT = arr((this.VCRINVCNDLIN(WLINE).INVCNDQTY*100/this.QTY),0.01)
          Else
            this.VCRINVCNDLIN(WLINE).INVPERCENT = 0
          Endif
          this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_ANO
        Else
          this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_AYES
          If [F:INVCND]FREQINV<>0
            this.VCRINVCNDLIN(WLINE).INVPERCENT = arr(100/[F:INVCND]FREQINV,0.01)
          Else
            this.VCRINVCNDLIN(WLINE).INVPERCENT = 0
          Endif
          this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_ANO
          this.VCRINVCNDLIN(WLINE).INVCNDQTY =arr((this.VCRINVCNDLIN(WLINE).INVPERCENT*this.QTY)/100,10^(-this.SAU_UOMDEC))
        Endif
      Endif

      #--No need to get further with adding lines if already reached the original document's quantity/amount
      WTODELCURRLINE=[V]CST_ANO
      #If sum(this.VCRINVCNDLIN(1..maxtab(this.VCRINVCNDLIN)).INVCNDQTY)>= this.QTY

      #--CPO 05/09/2016 No sigma because of the <>null test and the use of *
      If 1=1
#      If sigma(1,maxtab(this.VCRINVCNDLIN),
#&        this.VCRINVCNDLIN(indcum).INVCNDQTY*(find(this.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0))> this.QTY
        WTEMP_IFQTY = sigma(1,maxtab(this.VCRINVCNDLIN),
&        this.VCRINVCNDLIN(indcum).INVCNDQTY*(find(this.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0))
      Else
        WTEMP_IFQTY = 0
        For WIJQTY=1 To maxtab(this.VCRINVCNDLIN)
          If this.VCRINVCNDLIN(indcum)<>null and find(this.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
            WTEMP_IFQTY += this.VCRINVCNDLIN(indcum).INVCNDQTY
          Endif
        Next
      Endif
      If WTEMP_IFQTY > this.QTY
      #--End no sigma
        WROWCOUNT_INVCNDD = WCOUNT_INVCNDD
        WTODELCURRLINE=[V]CST_AYES
      Endif

      If WCOUNT_INVCNDD=WROWCOUNT_INVCNDD and (WTODELCURRLINE=[V]CST_AYES or this.VCRINVCNDLIN(WLINE).INVCNDQTY<=0 )
        #--Second, if non min amount, check if the last line's qty >0, if not, we skyp the last line and add everything to the previous one
        #--We dont't need the added last line anymore
        [L]ARET_VALUE = fmet this.ADELLINE("VCRINVCNDLIN",this.VCRINVCNDLIN(WLINE).AORDER)
        If [L]ARET_VALUE=[V]CST_ANOTDEFINED
          #--"Error deleting line from VCRINVCNDLIN collection"
          [L]ARET_VALUE = fmet this.ASETERROR("VCRINVCNDLIN",func AFNC.MES1(mess(454,192,1),num$(this.VCRINVCNDLIN(WLINE).AORDER)),[V]CST_AERROR)
          Break
        Endif
        #--All is added to the previous line
        WLINE = WLINE_PREV
        #--This will trigger set/propagate accessor
        WTEMP_QTY = 0
        If [F:INVCND]FREQINV<>0
          WTEMP_QTY = arr(this.QTY/[F:INVCND]FREQINV,10^(-this.SAU_UOMDEC))
        Endif
        If WTEMP_QTY>0
          #If this.VCRINVCNDLIN(WLINE).INVCNDQTY > 0 #--Exp: freqinv=12 and qty=5 => 5/12=0.42 => if sau_uomdec=0 => =0 !
          this.VCRINVCNDLIN(WLINE).INVCNDQTY += WTEMP_QTY #arr(this.QTY/[F:INVCND]FREQINV,10^(-this.SAU_UOMDEC))

          this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_AYES
          If this.QTY<>0
            this.VCRINVCNDLIN(WLINE).INVPERCENT  = arr((this.VCRINVCNDLIN(WLINE).INVCNDQTY*100/this.QTY),0.01)
          Else
            this.VCRINVCNDLIN(WLINE).INVPERCENT  = 0
          Endif
          this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_ANO
        Else
          this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_AYES

          If [F:INVCND]FREQINV<>0
            this.VCRINVCNDLIN(WLINE).INVPERCENT += arr(100/[F:INVCND]FREQINV,0.01)
          Else
            this.VCRINVCNDLIN(WLINE).INVPERCENT += 0
          Endif
          this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_ANO
          this.VCRINVCNDLIN(WLINE).INVCNDQTY =arr((this.VCRINVCNDLIN(WLINE).INVPERCENT*this.QTY)/100,10^(-this.SAU_UOMDEC))
        Endif
      Endif
    Else
      WSKYP_CURRENT = 0
      this.VCRINVCNDLIN(WLINE).INVCNDLIN=0

      #--This will prevent triggering set/propagate accessor
      this.VCRINVCNDLIN(WLINE).INVCNDQTY  = WSKYP_PREV_QTY+arr(this.QTY/[F:INVCND]FREQINV,10^(-this.SAU_UOMDEC))
      If this.VCRINVCNDLIN(WLINE).INVCNDQTY > 0 #--Exp: freqinv=12 and qty=5 => 5/12=0.42 => if sau_uomdec=0 => =0 !
        this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_AYES
        If this.QTY<>0
          this.VCRINVCNDLIN(WLINE).INVPERCENT = arr((this.VCRINVCNDLIN(WLINE).INVCNDQTY*100/this.QTY),0.01)
        Else
          this.VCRINVCNDLIN(WLINE).INVPERCENT = 0
        Endif
        this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_ANO
      Else
        this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_AYES
        If [F:INVCND]FREQINV<>0
          this.VCRINVCNDLIN(WLINE).INVPERCENT = WSKYP_PREV_INVPERCENT+arr(100/[F:INVCND]FREQINV,0.01)
        Else
          this.VCRINVCNDLIN(WLINE).INVPERCENT = 0
        Endif
        this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_ANO

        this.VCRINVCNDLIN(WLINE).INVCNDQTY = arr((this.VCRINVCNDLIN(WLINE).INVPERCENT*this.QTY)/100,10^(-this.SAU_UOMDEC))
      Endif
      #--After the eventual ADELLINE
      #--No need to get further with adding lines if already reached the original document's quantity/amount
      WTODELCURRLINE=[V]CST_ANO

      #--CPO 05/09/2016 No sigma because of the <>null test and the use of *
      If 1=1
#      If sigma(1,maxtab(this.VCRINVCNDLIN),
#&        this.VCRINVCNDLIN(indcum).INVCNDQTY*(find(this.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0))> this.QTY
        WTEMP_IFQTY = sigma(1,maxtab(this.VCRINVCNDLIN),
&        this.VCRINVCNDLIN(indcum).INVCNDQTY*(find(this.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0))
      Else
        WTEMP_IFQTY = 0
        For WIJQTY=1 To maxtab(this.VCRINVCNDLIN)
          If this.VCRINVCNDLIN(indcum)<>null and find(this.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
            WTEMP_IFQTY += this.VCRINVCNDLIN(indcum).INVCNDQTY
          Endif
        Next
      Endif
      If WTEMP_IFQTY > this.QTY
      #--End no sigma
        WROWCOUNT_INVCNDD = WCOUNT_INVCNDD
        WTODELCURRLINE=[V]CST_AYES
      Endif

      If WCOUNT_INVCNDD=WROWCOUNT_INVCNDD and (WTODELCURRLINE=[V]CST_AYES or this.VCRINVCNDLIN(WLINE).INVCNDQTY<=0 )
        #--Second, if non min amount, check if the last line's qty >0, if not, we skyp the last line and add everything to the previous one
        #--We dont't need the added last line anymore
        [L]ARET_VALUE = fmet this.ADELLINE("VCRINVCNDLIN",this.VCRINVCNDLIN(WLINE).AORDER)
        If [L]ARET_VALUE=[V]CST_ANOTDEFINED
          #--"Error deleting line from VCRINVCNDLIN collection"
          [L]ARET_VALUE = fmet this.ASETERROR("VCRINVCNDLIN",func AFNC.MES1(mess(454,192,1),num$(this.VCRINVCNDLIN(WLINE).AORDER)),[V]CST_AERROR)
          Break
        Endif
        #--All is added to the previous line
        WLINE = WLINE_PREV

        WTEMP_QTY = 0
        If [F:INVCND]FREQINV<>0
          WTEMP_QTY = WSKYP_PREV_QTY+arr(this.QTY/[F:INVCND]FREQINV,10^(-this.SAU_UOMDEC))
        Endif
        If WTEMP_QTY > 0
          this.VCRINVCNDLIN(WLINE).INVCNDQTY  += WTEMP_QTY #WSKYP_PREV_QTY+arr(this.QTY/[F:INVCND]FREQINV,10^(-this.SAU_UOMDEC))
        #If this.VCRINVCNDLIN(WLINE).INVCNDQTY > 0 #--Exp: freqinv=12 and qty=5 => 5/12=0.42 => if sau_uomdec=0 => =0 !
          this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_AYES
          If this.QTY<>0
            this.VCRINVCNDLIN(WLINE).INVPERCENT = arr((this.VCRINVCNDLIN(WLINE).INVCNDQTY*100/this.QTY),0.01)
          Else
            this.VCRINVCNDLIN(WLINE).INVPERCENT = 0
          Endif
          this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_ANO
        Else
          this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_AYES
          If [F:INVCND]FREQINV<>0
            this.VCRINVCNDLIN(WLINE).INVPERCENT+= WSKYP_PREV_INVPERCENT+arr(100/[F:INVCND]FREQINV,0.01)
          Else
            this.VCRINVCNDLIN(WLINE).INVPERCENT+= 0
          Endif
          this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_ANO
          this.VCRINVCNDLIN(WLINE).INVCNDQTY = arr((this.VCRINVCNDLIN(WLINE).INVPERCENT*this.QTY)/100,10^(-this.SAU_UOMDEC))
        Endif
      Endif
      WSKYP_PREV_INVPERCENT = 0
      WSKYP_PREV_QTY        = 0
    Endif

    #--Does the current line has a qty ?
    If this.VCRINVCNDLIN(WLINE).INVCNDQTY<=0
      If WCOUNT_INVCNDD<WROWCOUNT_INVCNDD
        WSKYP_CURRENT = 1
        WSKYP_PREV_INVPERCENT += this.VCRINVCNDLIN(WLINE).INVPERCENT
        WSKYP_PREV_QTY        += this.VCRINVCNDLIN(WLINE).INVCNDQTY
      Else
        #--We have to continue filling for the last line (in this case, WLINE is the previous good line)
        [L]WSKYP_CURRENT = 0
      Endif
    Endif
    #--
    If [L]WSKYP_CURRENT=0
      #--..
      #--Setting the PERFROM/PERTO/NEXINVDAT properties
      Gosub _SET_VCRINVCNDLIN_VCRINVCNDDAT_TYPE_PERIODICITY
      If [L]ARET_VALUE>=[V]CST_AERROR
        Break
      Endif
      #--Setting properties from order line
      Gosub _SET_VCRINVCNDLIN_DISPATCH_HEADER
      If [L]ARET_VALUE>=[V]CST_AERROR
        Break
      Endif
    Endif
  Next WNBLIGCOLL
  #--For rounding causes, we'll have to eventually fill the last line with the difference
  #--Done in AINSERT/AUPDATE CONTROL_BEFORE
  Gosub _CONTROL_DISPATCH_TOTALLINES
  If [L]ASTATUS>=[V]CST_AERROR : [L]ARET_VALUE=[L]ASTATUS: Return : Endif

Return
#--------------------------------------
$_CREATE_DETAIL_SCHEDINV_100_FIXEDPERCENT

  If this.INVCNDTYP<>0 : Return : Endif #--Fixed percent only

Local Integer WLINE,WIJCPO
  #--An error is thrown if there already are collections items
  If maxtab(this.VCRINVCNDLIN)>0
    For WLINE=1 To maxtab(this.VCRINVCNDLIN)
      If this.VCRINVCNDLIN(WLINE)<>null and find(this.VCRINVCNDLIN(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
        WIJCPO=fmet this.ADELLINE("VCRINVCNDLIN",this.VCRINVCNDLIN(WLINE).AORDER)
        If WIJCPO=[V]CST_ANOTDEFINED
          [L]ARET_VALUE = fmet this.ASETERROR("VCRINVCNDLIN",func AFNC.MES1(mess(454,192,1),num$(this.VCRINVCNDLIN(WLINE).AORDER)),[V]CST_AERROR)
          Return
        Endif
      Endif
    Next
  Endif

  #--This will create one single line having a 100% value

Local Integer WLINE
Local Char    WMESS(255)
Local Date    DAT_PERFROM, DAT_PERTO

  If [F:FCY]FCY<>this.SALFCY
    Read [FCY]FCY0 = this.SALFCY
    If fstat : Raz [F:FCY] : Endif
  Endif

  #--We keep adding a line if not on the last INVCNDD record or if the last record does not have a min amount filled
  WLINE = fmet this.ADDLINE("VCRINVCNDLIN",[V]CST_ALASTPOS)
  If WLINE=[V]CST_ANOTDEFINED
    #--Message...
    #--"Error inserting into VCRINVCNDLIN collection"
    [L]ARET_VALUE = fmet this.ASETERROR("VCRINVCNDLIN",mess(455,192,1),[V]CST_AERROR)
    Return
  Endif

  #--It is done during the ADDLINE_AFTER event...
  this.VCRINVCNDLIN(WLINE).INVCNDLIN=0
  If this.VCRINVCNDLIN(WLINE).INVPERCENT=0 #--Could have be done by ADDLINE_AFTER
    #--This will prevent triggering set/propagate accessor
    this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_AYES
    this.VCRINVCNDLIN(WLINE).INVPERCENT=100           #--Fixed value of 100%
    this.VCRINVCNDLIN(WLINE).IS_PROP_CHG=[V]CST_ANO

    If this.VCRINVCNDLIN(WLINE).INVCNDQTY=0
      this.VCRINVCNDLIN(WLINE).INVCNDQTY = arr(this.QTY,10^(-this.SAU_UOMDEC))
    Endif
  Endif

  #--..
  #--Setting the PERFROM/PERTO/NEXINVDAT properties
  this.VCRINVCNDLIN(WLINE).NEXINVDAT = PSTARTDATE
  this.VCRINVCNDLIN(WLINE).PERFROM   = PSTARTDATE
  this.VCRINVCNDLIN(WLINE).PERTO     = PSTARTDATE

  Gosub _SET_VCRINVCNDLIN_DISPATCH_HEADER
  If [L]ARET_VALUE>=[V]CST_AERROR : Return : Endif

  #--Very important !
  #--Check if accessors triggered errors
  [L]ARET_VALUE = fmet this.AGETMAXERROR('')
  If [L]ARET_VALUE>=[V]CST_AERROR : Return : Endif

Return
#--------------------------------------
$_SET_VCRINVCNDLIN_VCRINVCNDDAT_TYPE_FIXEDPERCENT
Local Integer IJL,PREVIOUS_LINE

  #--First, check if lines beeing updated/deleted exists
  #--as this $ is also called from AINSERT/AUPDATE_CONTROL_BEFORE, I'll have to test ASTALIN !!!
  #--VCRINVCNDLIN(LINE-1) is beeing used without testing the ASTALIN flag
  For IJL = WLINE-1 To 1 Step -1
    If this.VCRINVCNDLIN(IJL)<>null and find(this.VCRINVCNDLIN(IJL).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      PREVIOUS_LINE = IJL
      Break
    Endif
  Next

  If [F:INVCND]INVCNDTYP=2
    WTIM_OK=1

    this.VCRINVCNDLIN(WLINE).NEXINVDAT = PSTARTDATE

    [L]ARET_VALUE = func SVCRINVCND_LIB.CALDATE(this.ACTX,PSTARTDATE,
&                        this.INVCND,this.LEG,this.VCRINVCNDLIN(WLINE).INVCNDLIN,
&                        this.SALFCY,[F:FCY]UVYCOD,this.VCRINVCNDLIN(WLINE).NEXINVDAT,WMESS)

    If [L]ARET_VALUE>[V]CST_AOK
      [L]ARET_VALUE = fmet this.ASETERROR("_SET_VCRINVCNDLIN_VCRINVCNDDAT",WMESS,[L]ARET_VALUE)
      If [L]ARET_VALUE>=[V]CST_AERROR
        Return
      Endif
    Endif

    this.VCRINVCNDLIN(WLINE).VCRINVCNDDAT = date$
    #--Filling Periode from/to date
    DAT_PERTO      = this.VCRINVCNDLIN(WLINE).NEXINVDAT
    If PREVIOUS_LINE=0
      DAT_PERFROM = PSTARTDATE
    Else
      If    DAT_PERTO>this.VCRINVCNDLIN(PREVIOUS_LINE).PERTO
        DAT_PERFROM = this.VCRINVCNDLIN(PREVIOUS_LINE).PERTO+1
      Elsif DAT_PERTO=this.VCRINVCNDLIN(PREVIOUS_LINE).PERTO
        DAT_PERFROM = this.VCRINVCNDLIN(PREVIOUS_LINE).PERFROM
      Else
        WMESS = mess(456,192,1)
        [L]ARET_VALUE = fmet this.ASETERROR("",WMESS,[L]ARET_VALUE)
        Return
      Endif
    Endif

    this.VCRINVCNDLIN(WLINE).PERFROM   = DAT_PERFROM
    this.VCRINVCNDLIN(WLINE).PERTO     = DAT_PERTO

  Endif

Return
#--------------------------------------
$_SET_VCRINVCNDLIN_VCRINVCNDDAT_TYPE_PERIODICITY
Local Integer IJL,PREVIOUS_LINE

  #--First, check if lines beeing updated/deleted exists
  #--as this $ is also called from AINSERT/AUPDATE_CONTROL_BEFORE, I'll have to test ASTALIN !!!
  #--VCRINVCNDLIN(LINE-1) is beeing used without testing the ASTALIN flag
  For IJL = WLINE-1 To 1 Step -1
    If this.VCRINVCNDLIN(IJL)<>null and find(this.VCRINVCNDLIN(IJL).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      PREVIOUS_LINE = IJL
      Break
    Endif
  Next

  If this.INVCNDTYP=3

    WTIM_OK=1
    If PREVIOUS_LINE=0
      WRET = func SVCRINVCND_LIB.GET_PERFROM_PERTO([F:INVCND]PERINV,PSTARTDATE,[0/0/0],
&                  this.VCRINVCNDLIN(WLINE).PERFROM,this.VCRINVCNDLIN(WLINE).PERTO,WMESS)
    Else
      WRET = func SVCRINVCND_LIB.GET_PERFROM_PERTO([F:INVCND]PERINV,PSTARTDATE,this.VCRINVCNDLIN(PREVIOUS_LINE).PERTO,
&                  this.VCRINVCNDLIN(WLINE).PERFROM,this.VCRINVCNDLIN(WLINE).PERTO,WMESS)
    Endif
    If [L]ARET_VALUE>[V]CST_AOK
      [L]ARET_VALUE = fmet this.ASETERROR("_SET_VCRINVCNDLIN_VCRINVCNDDAT",WMESS,[L]ARET_VALUE)
      If [L]ARET_VALUE>=[V]CST_AERROR
        Return
      Endif
    Endif

    If    [F:INVCND]INVMETH<=1
      #Pré-facturation (Terme à échoir)
      this.VCRINVCNDLIN(WLINE).NEXINVDAT=this.VCRINVCNDLIN(WLINE).PERFROM
    Elsif [F:INVCND]INVMETH=2
      #Post-facturation (Terme échu)
      this.VCRINVCNDLIN(WLINE).NEXINVDAT=this.VCRINVCNDLIN(WLINE).PERTO
    Else

    Endif

    [L]ARET_VALUE = func SVCRINVCND_LIB.CALDATE(this.ACTX,this.VCRINVCNDLIN(WLINE).PERFROM,
&                        this.INVCND,this.LEG,this.VCRINVCNDLIN(WLINE).INVCNDLIN,
&                        this.SALFCY,[F:FCY]UVYCOD,this.VCRINVCNDLIN(WLINE).NEXINVDAT,WMESS)

    If [L]ARET_VALUE>[V]CST_AOK
      [L]ARET_VALUE = fmet this.ASETERROR("_SET_VCRINVCNDLIN_VCRINVCNDDAT",WMESS,[L]ARET_VALUE)
      If [L]ARET_VALUE>=[V]CST_AERROR
        Return
      Endif
    Endif
    ## X3-19101
    If WLINE=1 & this.VCRINVCNDLIN(WLINE).NEXINVDAT<PSTARTDATE & [F:INVCND]INVMETH=1
       this.VCRINVCNDLIN(WLINE).NEXINVDAT=PSTARTDATE
       If day(this.VCRINVCNDLIN(WLINE).NEXINVDAT)<[F:INVCND]INVDAY
          this.VCRINVCNDLIN(WLINE).NEXINVDAT=gdat$([F:INVCND]INVDAY, month(this.VCRINVCNDLIN(WLINE).NEXINVDAT),year(this.VCRINVCNDLIN(WLINE).NEXINVDAT))
       Endif
    Endif
    ## END X3-19101

    this.VCRINVCNDLIN(WLINE).VCRINVCNDDAT = date$
    this.VCRINVCNDLIN(WLINE).INVCNDLIN = 0
  Endif

Return
#--------------------------------------------------------------------------------------------------
$_SET_VCRINVCNDLIN_DISPATCH_HEADER

  this.VCRINVCNDLIN(WLINE).INVCNDSTA = 1

  this.VCRINVCNDLIN(WLINE).IS_PROP_CHG = [V]CST_AYES #--Prevent trigerring the propagate

  this.VCRINVCNDLIN(WLINE).INVCNDQTY   = arr((this.VCRINVCNDLIN(WLINE).INVPERCENT*this.QTY)/100,10^(-this.SAU_UOMDEC))
  #--In order to have a percentage that reflects well the Qty (Qty beeing unit rouding dependent !)
  If this.QTY<>0
    this.VCRINVCNDLIN(WLINE).INVPERCENT  = arr((this.VCRINVCNDLIN(WLINE).INVCNDQTY*100/this.QTY),0.01)
  Else
    this.VCRINVCNDLIN(WLINE).INVPERCENT  = 0
  Endif

  If this.PRITYP = 2
    #--Only +Vat fields filled
    this.VCRINVCNDLIN(WLINE).DNETPRINOT    = 0
    this.VCRINVCNDLIN(WLINE).DNETPRIATI    = this.NETPRIATI
    this.VCRINVCNDLIN(WLINE).INVCNDAMTNOT = 0
    this.VCRINVCNDLIN(WLINE).INVCNDAMTATI = arr((this.VCRINVCNDLIN(WLINE).INVCNDQTY*this.VCRINVCNDLIN(WLINE).DNETPRIATI),10^(-this.CUR_DECNBR))
  Else
    #--Only -Vat fields filled
    this.VCRINVCNDLIN(WLINE).DNETPRINOT    = this.NETPRINOT
    this.VCRINVCNDLIN(WLINE).DNETPRIATI    = 0
    this.VCRINVCNDLIN(WLINE).INVCNDAMTNOT = arr((this.VCRINVCNDLIN(WLINE).INVCNDQTY*this.VCRINVCNDLIN(WLINE).DNETPRINOT),10^(-this.CUR_DECNBR))
    this.VCRINVCNDLIN(WLINE).INVCNDAMTATI = 0
  Endif
  this.VCRINVCNDLIN(WLINE).SAU        = this.SAU
#Else
#  #--It is not the QTY, but the AMTNOT/AMTATI that has to drive the calculation
#  #TODO CPO Amount driven schedule
#Endif
  this.VCRINVCNDLIN(WLINE).MODFLG     = 1          #--'Non'
  this.VCRINVCNDLIN(WLINE).MODDAT     = [0/0/0]

  this.VCRINVCNDLIN(WLINE).IS_PROP_CHG = [V]CST_ANO #--Allow trigerring the propagate
Return
#--------------------------------------
#--Control and re-dispatch on last line
#--!! Due to rounding issues, the percentage of all other lines could slightly be modified, also!!
$_CONTROL_DISPATCH_TOTALLINES
Local Decimal WTOTINVPERCENT,WTOTQTY,WINVPERCENTLASTLINE,WTOTQTY_CLOSED_LINES,WTOTAMT,WHEADERAMT,WMAXTAB_AMT
Local Decimal PERCENT_TO_DISTRIB,PERCENT_TO_DISTRIB_PER_LINE,PERCENT_TO_DISTRIB_PER_LINE_LAST_LINE
Local Integer IJL,W,TROUVE,WMAXTAB,WNB_UPDATABLE_LINES,WNB_CLOSED_LINES,WMAXTAB_CLOSED,WMAXTAB_PREV,WDOLOOP_WHILE_LAST_LINE_IS_ZERO
Local Date    WDATE_FROM,WDATE_TO,WNEXINVDAT
Local Integer WMAXTAB_ONINVOICE
Local Integer WMAXAERROR

  #--First, check if lines beeing updated/deleted exists
  #--as this $ is also called from AINSERT/AUPDATE_CONTROL_BEFORE, I'll have to test ASTALIN !!!
  WDOLOOP_WHILE_LAST_LINE_IS_ZERO = [V]CST_AYES
  While WDOLOOP_WHILE_LAST_LINE_IS_ZERO = [V]CST_AYES
    WMAXTAB             = 0
    WMAXTAB_PREV        = 0
    WMAXTAB_CLOSED      = 0
    WNB_UPDATABLE_LINES = 0
    WNB_CLOSED_LINES    = 0
    WTOTQTY_CLOSED_LINES= 0
    WTOTINVPERCENT      = 0
    WTOTQTY             = 0
    WTOTAMTATI          = 0
    WINVPERCENTLASTLINE = 0
    WTOTQTY_CLOSED_LINES= 0

    If this.PRITYP=2
      WHEADERAMT = this.AMTATI
    Else
      WHEADERAMT = this.AMTNOT
    Endif

    For IJL=1 To maxtab(this.VCRINVCNDLIN)
      If this.VCRINVCNDLIN(IJL)<>null and find(this.VCRINVCNDLIN(IJL).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
        WTOTINVPERCENT += this.VCRINVCNDLIN(IJL).INVPERCENT
        WTOTQTY        += this.VCRINVCNDLIN(IJL).INVCNDQTY
        If this.PRITYP=2
          WTOTAMTATI   += this.VCRINVCNDLIN(IJL).INVCNDAMTATI
        Else
          WTOTAMTATI   += this.VCRINVCNDLIN(IJL).INVCNDAMTNOT
        Endif
        If this.VCRINVCNDLIN(IJL).INVCNDSTA<=1
          WMAXTAB               = IJL #--Last indice of a "To be invoiced" line
          WMAXTAB_PREV          = WMAXTAB-1
          WNB_UPDATABLE_LINES  += 1
        Else
          WMAXTAB_CLOSED        = IJL #--Last indice of an "Invoiced/Credit memo/Closed" line
          WNB_CLOSED_LINES     += 1
          WTOTQTY_CLOSED_LINES += this.VCRINVCNDLIN(IJL).INVCNDQTY
          If this.VCRINVCNDLIN(IJL).INVCNDSTA=5 #--'On invoice'
            WMAXTAB_ONINVOICE        = IJL #--Last indice of an "Invoiced/Credit memo/Closed" line
          Endif
        Endif
      Endif
    Next
    If WMAXTAB=0
      If dim(WINDEX_CURENT_MOD_LINE)>0 and WINDEX_CURENT_MOD_LINE>0 and WMAXTAB_ONINVOICE>0 and WINDEX_CURENT_MOD_LINE<=WMAXTAB_ONINVOICE
        WMAXTAB = WINDEX_CURENT_MOD_LINE : WINDEX_CURENT_MOD_LINE=[V]CST_ANOTDEFINED
      Else
        Return
      Endif
    Endif

    WINVPERCENTLASTLINE = this.VCRINVCNDLIN(WMAXTAB).INVPERCENT
    If this.QTY<>0
      If WTOTQTY<>this.QTY

        this.VCRINVCNDLIN(WMAXTAB).IS_PROP_CHG = [V]CST_AYES #--Prevent the execution of the propagate

        this.VCRINVCNDLIN(WMAXTAB).INVCNDQTY += this.QTY - WTOTQTY
        this.VCRINVCNDLIN(WMAXTAB).INVPERCENT = arr((this.VCRINVCNDLIN(WMAXTAB).INVCNDQTY*100/this.QTY),0.01)
        If this.PRITYP = 2
          #--Only +Vat fields filled
          this.VCRINVCNDLIN(WMAXTAB).DNETPRINOT   = 0
          If this.VCRINVCNDLIN(WMAXTAB).INVCNDSTA<=1
            this.VCRINVCNDLIN(WMAXTAB).DNETPRIATI = this.NETPRIATI
          Endif
          this.VCRINVCNDLIN(WMAXTAB).INVCNDAMTNOT = 0
          this.VCRINVCNDLIN(WMAXTAB).INVCNDAMTATI = arr((this.VCRINVCNDLIN(WMAXTAB).INVCNDQTY*this.VCRINVCNDLIN(WMAXTAB).DNETPRIATI),10^(-this.CUR_DECNBR))
        Else
          #--Only -Vat fields filled
          If this.VCRINVCNDLIN(WMAXTAB).INVCNDSTA<=1
            this.VCRINVCNDLIN(WMAXTAB).DNETPRINOT = this.NETPRINOT
          Endif
          this.VCRINVCNDLIN(WMAXTAB).DNETPRIATI   = 0
          this.VCRINVCNDLIN(WMAXTAB).INVCNDAMTNOT = arr((this.VCRINVCNDLIN(WMAXTAB).INVCNDQTY*this.VCRINVCNDLIN(WMAXTAB).DNETPRINOT),10^(-this.CUR_DECNBR))
          this.VCRINVCNDLIN(WMAXTAB).INVCNDAMTATI = 0
        Endif

        If this.VCRINVCNDLIN(WMAXTAB).INVCNDQTY>0
          WDOLOOP_WHILE_LAST_LINE_IS_ZERO = [V]CST_ANO
        Endif

        this.VCRINVCNDLIN(WMAXTAB).IS_PROP_CHG = [V]CST_ANO  #--Prevent the execution of the propagate
      Else
        #--The total qty is identical with the header, but does the prices/amounts ?
      Endif
    Elsif WHEADERAMT<>0
      If WTOTAMT<>WHEADERAMT
        this.VCRINVCNDLIN(WMAXTAB).IS_PROP_CHG = [V]CST_AYES #--Prevent the execution of the propagate

        If this.PRITYP = 2
          #--Only +Vat fields filled
          this.VCRINVCNDLIN(WMAXTAB).DNETPRINOT   = 0
          If this.VCRINVCNDLIN(WMAXTAB).INVCNDSTA<=1
            this.VCRINVCNDLIN(WMAXTAB).DNETPRIATI = this.NETPRIATI
          Endif
          this.VCRINVCNDLIN(WMAXTAB).INVCNDAMTNOT = 0
          this.VCRINVCNDLIN(WMAXTAB).INVCNDAMTATI+= WHEADERAMT-WTOTAMT
          this.VCRINVCNDLIN(WMAXTAB).INVPERCENT   = arr((this.VCRINVCNDLIN(WMAXTAB).INVCNDAMTATI*100/WHEADERAMT),0.01)

          If this.VCRINVCNDLIN(WMAXTAB).INVCNDAMTATI>0
            WDOLOOP_WHILE_LAST_LINE_IS_ZERO = [V]CST_ANO
          Endif
        Else
          #--Only -Vat fields filled
          If this.VCRINVCNDLIN(WMAXTAB).INVCNDSTA<=1
            this.VCRINVCNDLIN(WMAXTAB).DNETPRINOT = this.NETPRINOT
          Endif
          this.VCRINVCNDLIN(WMAXTAB).DNETPRIATI   = 0
          this.VCRINVCNDLIN(WMAXTAB).INVCNDAMTNOT+= WHEADERAMT-WTOTAMT
          this.VCRINVCNDLIN(WMAXTAB).INVCNDAMTATI = 0
          this.VCRINVCNDLIN(WMAXTAB).INVPERCENT   = arr((this.VCRINVCNDLIN(WMAXTAB).INVCNDAMTNOT*100/WHEADERAMT),0.01)

          If this.VCRINVCNDLIN(WMAXTAB).INVCNDAMTNOT>0
            WDOLOOP_WHILE_LAST_LINE_IS_ZERO = [V]CST_ANO
          Endif
        Endif

        this.VCRINVCNDLIN(WMAXTAB).INVCNDQTY  = 0

        this.VCRINVCNDLIN(WMAXTAB).IS_PROP_CHG = [V]CST_ANO  #--Prevent the execution of the propagate
      Endif
    Else
      this.VCRINVCNDLIN(WMAXTAB).IS_PROP_CHG = [V]CST_AYES #--Prevent the execution of the propagate

      this.VCRINVCNDLIN(WMAXTAB).INVCNDQTY    = 0
      this.VCRINVCNDLIN(WMAXTAB).INVPERCENT   = 0
      this.VCRINVCNDLIN(WMAXTAB).DNETPRINOT   = 0
      this.VCRINVCNDLIN(WMAXTAB).DNETPRIATI   = 0
      this.VCRINVCNDLIN(WMAXTAB).INVCNDAMTNOT = 0
      this.VCRINVCNDLIN(WMAXTAB).INVCNDAMTATI = 0
      WMAXTAB_AMT = 0
      this.VCRINVCNDLIN(WMAXTAB).IS_PROP_CHG = [V]CST_ANO  #--Prevent the execution of the propagate
    Endif

    If this.PRITYP=2
      WMAXTAB_AMT = this.VCRINVCNDLIN(WMAXTAB).INVCNDAMTATI
    Else
      WMAXTAB_AMT = this.VCRINVCNDLIN(WMAXTAB).INVCNDAMTNOT
    Endif

    #--As the INVPERCENT of the last line may have been changed..
    WTOTINVPERCENT += this.VCRINVCNDLIN(WMAXTAB).INVPERCENT-WINVPERCENTLASTLINE
    If WTOTINVPERCENT<>100
      PERCENT_TO_DISTRIB = 100-WTOTINVPERCENT
      #--(WNB_UPDATABLE_LINES+WNB_CLOSED_LINES) because all percentage have to be re-calculated in order to have 100%
      #--Have to use an 0.001 rounding in order to avoid cases like arr(0.01/2,10^-0.01)=0.01 => should not round in this case
      PERCENT_TO_DISTRIB_PER_LINE = arr(PERCENT_TO_DISTRIB/(WNB_UPDATABLE_LINES+WNB_CLOSED_LINES),0.001) #--0.001 is wanted here !
      If    PERCENT_TO_DISTRIB>0 and PERCENT_TO_DISTRIB_PER_LINE<0.01
        PERCENT_TO_DISTRIB_PER_LINE=0
      Elsif PERCENT_TO_DISTRIB<0 and PERCENT_TO_DISTRIB_PER_LINE>-0.01
        PERCENT_TO_DISTRIB_PER_LINE=0
      Else
        PERCENT_TO_DISTRIB_PER_LINE = arr(PERCENT_TO_DISTRIB/(WNB_UPDATABLE_LINES+WNB_CLOSED_LINES),0.01)
      Endif

      If (WNB_UPDATABLE_LINES+WNB_CLOSED_LINES)*PERCENT_TO_DISTRIB_PER_LINE<>PERCENT_TO_DISTRIB
        PERCENT_TO_DISTRIB_PER_LINE_LAST_LINE = PERCENT_TO_DISTRIB-(WNB_UPDATABLE_LINES+WNB_CLOSED_LINES)*PERCENT_TO_DISTRIB_PER_LINE
      Endif
      #--Now, we add the percentage to distribute
      If PERCENT_TO_DISTRIB_PER_LINE<>0
        For IJL=1 To maxtab(this.VCRINVCNDLIN) #WMAXTAB
          If this.VCRINVCNDLIN(IJL)<>null and find(this.VCRINVCNDLIN(IJL).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
#&            and this.VCRINVCNDLIN(IJL).INVCNDSTA<=1 #TODO-- Only lines having INVCNDSTA=1 ??
            this.VCRINVCNDLIN(IJL).IS_PROP_CHG =[V]CST_AYES
            this.VCRINVCNDLIN(IJL).INVPERCENT += PERCENT_TO_DISTRIB_PER_LINE
            this.VCRINVCNDLIN(IJL).IS_PROP_CHG =[V]CST_ANO
          Endif
        Next
      Endif
      If PERCENT_TO_DISTRIB_PER_LINE_LAST_LINE<>0
        this.VCRINVCNDLIN(WMAXTAB).IS_PROP_CHG =[V]CST_AYES
        this.VCRINVCNDLIN(WMAXTAB).INVPERCENT += PERCENT_TO_DISTRIB_PER_LINE_LAST_LINE
        this.VCRINVCNDLIN(WMAXTAB).IS_PROP_CHG =[V]CST_ANO
      Endif
    Endif

    #--Now, if last line's percentage or qty are 0, we delete it
    #--This can happen by diminuishing the original document lines's quantity (for example)
    If (this.QTY<>0 and this.VCRINVCNDLIN(WMAXTAB).INVCNDQTY<=0) or
&      this.VCRINVCNDLIN(WMAXTAB).INVPERCENT<=0 or
&      (WHEADERAMT<>0 and WMAXTAB_AMT<= 0)
      #--Before deleting, we'll have to make sur not to leave gaps bettween periodes
      If WMAXTAB_PREV>0 and WMAXTAB<WMAXTAB_CLOSED
        this.VCRINVCNDLIN(WMAXTAB_PREV).IS_PROP_CHG =[V]CST_AYES
        this.VCRINVCNDLIN(WMAXTAB_PREV).PERTO     = this.VCRINVCNDLIN(WMAXTAB).PERTO
        this.VCRINVCNDLIN(WMAXTAB_PREV).NEXINVDAT = this.VCRINVCNDLIN(WMAXTAB).NEXINVDAT
        this.VCRINVCNDLIN(WMAXTAB_PREV).IS_PROP_CHG =[V]CST_ANO
        #--Last line's quantity is 0, we have to re-dispatch the percentage PERCENT_TO_DISTRIB_PER_LINE_LAST_LINE
        If this.VCRINVCNDLIN(WMAXTAB).INVCNDQTY=0
          this.VCRINVCNDLIN(WMAXTAB_PREV).IS_PROP_CHG =[V]CST_AYES
          this.VCRINVCNDLIN(WMAXTAB_PREV).INVPERCENT += PERCENT_TO_DISTRIB_PER_LINE_LAST_LINE
          this.VCRINVCNDLIN(WMAXTAB_PREV).IS_PROP_CHG =[V]CST_ANO
        Endif
      Endif
      [L]ASTATUS = fmet this.ADELLINE("VCRINVCNDLIN",this.VCRINVCNDLIN(WMAXTAB).AORDER)
      If [L]ASTATUS = [V]CST_ANOTDEFINED
        [L]ASTATUS = fmet this.ASETERROR("VCRINVCNDLIN", func AFNC.MES1(mess(454,192,1),num$(this.VCRINVCNDLIN(WMAXTAB).AORDER)),[V]CST_AERROR)
        Break
      Endif
      WMAXAERROR=[L]ASTATUS #--To prevent loosing an blocking error set before !
      [L]ASTATUS = max(WMAXAERROR, fmet this.ASETERROR("VCRINVCNDLIN",mess(488,192,1),[V]CST_AINFO))

      If WMAXTAB_PREV=0 or WMAXTAB=0
        WDOLOOP_WHILE_LAST_LINE_IS_ZERO=[V]CST_ANO
      Else
        WDOLOOP_WHILE_LAST_LINE_IS_ZERO=[V]CST_AYES
      Endif
    Else
      WDOLOOP_WHILE_LAST_LINE_IS_ZERO=[V]CST_ANO
    Endif

  Wend
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
  #--Very important !
  #--Check if accessors triggered errors
  [L]ASTATUS = fmet this.AGETMAXERROR('')
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
#---------------------------------------------------------------
$_DISPATCH_TOTALLINES_INVPERCENT
Local Decimal WTOTINVPERCENT
Local Integer IJL,W,TROUVE,WMAXTAB

  #--First, check if lines beeing updated/deleted exists
  #--as this $ is also called from AINSERT/AUPDATE_CONTROL_BEFORE, I'll have to test ASTALIN !!!
  For IJL=1 To maxtab(this.VCRINVCNDLIN)
    If this.VCRINVCNDLIN(IJL)<>null and find(this.VCRINVCNDLIN(IJL).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      WTOTINVPERCENT += this.VCRINVCNDLIN(IJL).INVPERCENT
      If this.VCRINVCNDLIN(IJL).INVCNDSTA <= 1 #--also lines in "stand by" mode
        WMAXTAB         = IJL #--Last "good" indice
      Endif
    Endif
  Next
  If WMAXTAB=0 : Return :Endif
  If WTOTINVPERCENT<>100
      #--VERY IMPORTANT : it's only the percentage that has to be dispatched
      #--We only want rounding the % to adapt to the rounding problems of the qty (especially if qty has zero decimal units !)
      this.VCRINVCNDLIN(WMAXTAB).IS_PROP_CHG = [V]CST_AYES #--Prevent the execution of the propagate
      this.VCRINVCNDLIN(WMAXTAB).INVPERCENT += 100-WTOTINVPERCENT
      this.VCRINVCNDLIN(WMAXTAB).IS_PROP_CHG = [V]CST_ANO  #--Prevent the execution of the propagate
  Endif
  #--Very important !
  #--Check if accessors triggered errors
  [L]ASTATUS = fmet this.AGETMAXERROR('')
  If [L]ASTATUS>=[V]CST_AERROR : [L]ARET_VALUE=[L]ASTATUS : Return : Endif

Return
#---------------------------------------------------------------
$_RECALC_INVCNDQTY_ALL_LINES
Local Integer WLINE, WMAXAERROR
  #--First, we have to sum the quantity of lines having status "Invoiced"/"Credit memo"/"Closed"
  #--These lines are not updatable, so their quantity has to be sustract from the total quantity to be re-distributed
  #-- X3-25620
  Local Decimal WQTYINV: Raz WQTYINV # quantity of lines having status "Invoiced"/"Credit memo"/"Closed"
  For WLINE=1 To maxtab(this.VCRINVCNDLIN)
    If this.VCRINVCNDLIN(WLINE)<>null and find(this.VCRINVCNDLIN(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
       If this.VCRINVCNDLIN(WLINE).INVCNDSTA<=1
          WQTYINV+=this.VCRINVCNDLIN(WLINE).INVCNDQTY
       Endif
    Endif
  Next
  #-- End X3-25620

  #--Line's percentages are re-calculated according to line's quantity and header quantity
  For WLINE=1 To maxtab(this.VCRINVCNDLIN)
    If this.VCRINVCNDLIN(WLINE)<>null and find(this.VCRINVCNDLIN(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      If this.VCRINVCNDLIN(WLINE).INVCNDSTA<=1 #--Only changing "To be invoiced" lines
        #--% are re-calculated according to the line qty and header qty
        #If   this.QTY>0                 #X3-25620
        If   this.QTY>0 and WQTYINV>0    #X3-25620
          this.VCRINVCNDLIN(WLINE).IS_PROP_CHG =[V]CST_AYES
          #this.VCRINVCNDLIN(WLINE).INVCNDQTY  = arr((this.VCRINVCNDLIN(WLINE).INVPERCENT*this.QTY/100),10^(-this.SAU_UOMDEC))  #X3-25620
          this.VCRINVCNDLIN(WLINE).INVCNDQTY  = arr(this.VCRINVCNDLIN(WLINE).INVCNDQTY*(this.QTY/WQTYINV),10^(-this.SAU_UOMDEC)) #X3-25620

          this.VCRINVCNDLIN(WLINE).INVPERCENT = arr((this.VCRINVCNDLIN(WLINE).INVCNDQTY*100/this.QTY),0.01)
          If this.PRITYP = 2
            #--Only +Vat fields filled
            this.VCRINVCNDLIN(WLINE).DNETPRINOT    = 0
            this.VCRINVCNDLIN(WLINE).DNETPRIATI    = this.NETPRIATI
            this.VCRINVCNDLIN(WLINE).INVCNDAMTNOT  = 0
            this.VCRINVCNDLIN(WLINE).INVCNDAMTATI  = arr((this.VCRINVCNDLIN(WLINE).INVCNDQTY*this.VCRINVCNDLIN(WLINE).DNETPRIATI),10^(-this.CUR_DECNBR))
          Else
            #--Only -Vat fields filled
            this.VCRINVCNDLIN(WLINE).DNETPRINOT    = this.NETPRINOT
            this.VCRINVCNDLIN(WLINE).DNETPRIATI    = 0
            this.VCRINVCNDLIN(WLINE).INVCNDAMTNOT  = arr((this.VCRINVCNDLIN(WLINE).INVCNDQTY*this.VCRINVCNDLIN(WLINE).DNETPRINOT),10^(-this.CUR_DECNBR))
            this.VCRINVCNDLIN(WLINE).INVCNDAMTATI  = 0
          Endif
          this.VCRINVCNDLIN(WLINE).IS_PROP_CHG =[V]CST_ANO
          #--Now, if line's percentage or qty are 0, we delete it
          #--This can arrive by diminuishing the original document lines's quantity (for example)
          If this.VCRINVCNDLIN(WLINE).INVCNDQTY<=0 or this.VCRINVCNDLIN(WLINE).INVPERCENT<=0
            [L]ASTATUS = fmet this.ADELLINE("VCRINVCNDLIN",this.VCRINVCNDLIN(WLINE).AORDER)
            If [L]ASTATUS = [V]CST_ANOTDEFINED
              [L]ARET_VALUE = fmet this.ASETERROR("VCRINVCNDLIN", func AFNC.MES1(mess(454,192,1),num$(this.VCRINVCNDLIN(WLINE).AORDER)),[V]CST_AERROR)
              Return
            Endif
            WMAXAERROR=[L]ARET_VALUE #--To prevent loosing an blocking error set before !
            [L]ARET_VALUE = max(WMAXAERROR,fmet this.ASETERROR("VCRINVCNDLIN",mess(488,192,1),[V]CST_AINFO))
          Endif
        Else
          this.VCRINVCNDLIN(WLINE).IS_PROP_CHG =[V]CST_AYES
          this.VCRINVCNDLIN(WLINE).INVCNDQTY = 0
          If this.PRITYP = 2
            #--Only +Vat fields filled
            this.VCRINVCNDLIN(WLINE).DNETPRINOT   = 0
            this.VCRINVCNDLIN(WLINE).DNETPRIATI   = this.NETPRIATI

            this.VCRINVCNDLIN(WLINE).INVCNDAMTNOT = 0
            If this.AMTATI<>0
              this.VCRINVCNDLIN(WLINE).INVCNDAMTATI = arr((this.VCRINVCNDLIN(WLINE).INVPERCENT*this.AMTATI/100),10^(-this.CUR_DECNBR))
              this.VCRINVCNDLIN(WLINE).INVPERCENT   = arr((this.VCRINVCNDLIN(WLINE).INVCNDAMTATI*100/this.AMTATI),0.01)
            Else
              this.VCRINVCNDLIN(WLINE).INVCNDAMTATI = 0
              this.VCRINVCNDLIN(WLINE).INVPERCENT   = 0
            Endif
          Else
            #--Only -Vat fields filled
            this.VCRINVCNDLIN(WLINE).DNETPRINOT   = this.NETPRINOT
            this.VCRINVCNDLIN(WLINE).DNETPRIATI   = 0

            this.VCRINVCNDLIN(WLINE).INVCNDAMTATI = 0
            If this.AMTNOT<>0
              this.VCRINVCNDLIN(WLINE).INVCNDAMTNOT = arr((this.VCRINVCNDLIN(WLINE).INVPERCENT*this.AMTNOT/100),10^(-this.CUR_DECNBR))
              this.VCRINVCNDLIN(WLINE).INVPERCENT   = arr((this.VCRINVCNDLIN(WLINE).INVCNDAMTNOT*100/this.AMTNOT),0.01)
            Else
              this.VCRINVCNDLIN(WLINE).INVCNDAMTNOT = 0
              this.VCRINVCNDLIN(WLINE).INVPERCENT   = 0
            Endif
          Endif
          this.VCRINVCNDLIN(WLINE).IS_PROP_CHG =[V]CST_ANO
          #--Now, if line's percentage or qty are 0, we delete it
          #--This can arrive by diminuishing the original document lines's quantity (for example)
          If this.VCRINVCNDLIN(WLINE).INVPERCENT<=0 or
&            (this.PRITYP =2 and this.VCRINVCNDLIN(WLINE).INVCNDAMTATI<=0) or
&            (this.PRITYP<>2 and this.VCRINVCNDLIN(WLINE).INVCNDAMTNOT<=0)
            [L]ASTATUS = fmet this.ADELLINE("VCRINVCNDLIN",this.VCRINVCNDLIN(WLINE).AORDER)
            If [L]ASTATUS = [V]CST_ANOTDEFINED
              [L]ARET_VALUE = fmet this.ASETERROR("VCRINVCNDLIN", func AFNC.MES1(mess(454,192,1),num$(this.VCRINVCNDLIN(WLINE).AORDER)),[V]CST_AERROR)
              Return
            Endif
            WMAXAERROR=[L]ARET_VALUE #--To prevent loosing an blocking error set before !
            [L]ARET_VALUE = max(WMAXAERROR,fmet this.ASETERROR("VCRINVCNDLIN",mess(488,192,1),[V]CST_AINFO))
          Endif
        Endif
      Else
        #--Line's percentage has to be re-calculated according to the new header quantity
        If this.QTY<>0
          this.VCRINVCNDLIN(WLINE).IS_PROP_CHG =[V]CST_AYES
          this.VCRINVCNDLIN(WLINE).INVPERCENT  = arr((this.VCRINVCNDLIN(WLINE).INVCNDQTY*100/this.QTY),0.01)
          this.VCRINVCNDLIN(WLINE).IS_PROP_CHG =[V]CST_ANO
        Else
          If this.PRITYP=2
            this.VCRINVCNDLIN(WLINE).IS_PROP_CHG =[V]CST_AYES
            If this.AMTATI<>0
              this.VCRINVCNDLIN(WLINE).INVPERCENT = arr((this.VCRINVCNDLIN(WLINE).INVCNDAMTATI*100/this.AMTATI),0.01)
            Else
              this.VCRINVCNDLIN(WLINE).INVPERCENT = 0
            Endif
            this.VCRINVCNDLIN(WLINE).IS_PROP_CHG =[V]CST_ANO
          Else
            this.VCRINVCNDLIN(WLINE).IS_PROP_CHG =[V]CST_AYES
            If this.AMTNOT<>0
              this.VCRINVCNDLIN(WLINE).INVPERCENT  = arr((this.VCRINVCNDLIN(WLINE).INVCNDAMTNOT*100/this.AMTNOT),0.01)
            Else
              this.VCRINVCNDLIN(WLINE).INVPERCENT = 0
            Endif
            this.VCRINVCNDLIN(WLINE).IS_PROP_CHG =[V]CST_ANO
          Endif
        Endif
      Endif
    Endif
  Next
  #--Control and re-dispatch on last line
  #--!! Due to rounding issues, the percentage of all other lines could slightly be modified, also!!
  Gosub _CONTROL_DISPATCH_TOTALLINES
  If [L]ASTATUS>=[V]CST_AERROR : [L]ARET_VALUE=[L]ASTATUS: Return : Endif

Return
#---------------------------------------------------------------
Funprog GET_LINE_INDEX_FOR_VCRINVCNDLIN(VINSTANCE, PVCRINVCNDLIN)
Variable Instance VINSTANCE Using C_SVCRINVCND
Value Integer     PVCRINVCNDLIN

Local Integer WLINE_INDEX : WLINE_INDEX = [V]CST_ANOTDEFINED

If VINSTANCE = null or PVCRINVCNDLIN=AVOID.AINT : End WLINE_INDEX : Endif

  #--Getting the line index for the VCRINVCNDLIN key part
  WLINE_INDEX = sigma(1,maxtab(VINSTANCE.VCRINVCNDLIN),
&   (indcum)*(VINSTANCE.VCRINVCNDLIN(indcum)<>null and
&             VINSTANCE.VCRINVCNDLIN(indcum).VCRINVCNDLIN=PVCRINVCNDLIN and
&             find(VINSTANCE.VCRINVCNDLIN(indcum).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0))

  If WLINE_INDEX=0 : WLINE_INDEX=[V]CST_ANOTDEFINED : Endif

End WLINE_INDEX

