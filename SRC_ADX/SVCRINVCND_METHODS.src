#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------------- METHODS --------------------------------
$SET_CREDITNOTE_UPDTOTALS
#PVCRINVCNDLIN  Integer
#PCNQTY         Decimal
#PCNAMOUNT      Decimal

  Local Integer WLINEF

  If PVCRINVCNDLIN>0
    WLINE = func GET_LINE_INDEX_FOR_VCRINVCNDLIN(this,PVCRINVCNDLIN)
  Else
    Return
  Endif

  If find(this.VCRINVCNDLIN(WLINE).INVCNDSTA,2,3,5,6)=0 : Return : Endif

  VINVCNDSTA = this.VCRINVCNDLIN(WLINE).INVCNDSTA

  Case this.VCRINVCNDLIN(WLINE).INVCNDSTA
    When 2 :  #--'Invoiced' : for now, from the credit note, we update the invoice's schedule invoice line totals
              this.VCRINVCNDLIN(WLINE).LIN_CN_QTY += PCNQTY
              this.VCRINVCNDLIN(WLINE).LIN_CN_AMT += PCNAMOUNT
              #--
    When Default : Return
  Endcase

Return
#---------------------------------------------------------------
$GET_INVOICED_VALUES
#PVCRINVCNDLIN  Integer
#VINV_QTY_P     Decimal
#VINV_QTY_NP    Decimal
#VCN_QTY_P      Decimal
#VCN_QTY_NP     Decimal
#VEXTINV_QTY_P  Decimal
#VEXTINV_QTY_NP Decimal
#VEXTCN_QTY_P   Decimal
#VEXTCN_QTY_NP  Decimal
#VINV_AMT_P     Decimal
#VINV_AMT_NP    Decimal
#VCN_AMT_P      Decimal
#VCN_AMT_NP     Decimal
#VEXTINV_AMT_P  Decimal
#VEXTINV_AMT_NP Decimal
#VEXTCN_AMT_P   Decimal
#VEXTCN_AMT_NP  Decimal

  VINV_QTY_P    = AVOID.ADEC
  VINV_QTY_NP   = AVOID.ADEC
  VCN_QTY_P     = AVOID.ADEC
  VCN_QTY_NP    = AVOID.ADEC
  VEXTINV_QTY_P = AVOID.ADEC
  VEXTINV_QTY_NP= AVOID.ADEC
  VEXTCN_QTY_P  = AVOID.ADEC
  VEXTCN_QTY_NP = AVOID.ADEC
  #--
  VINV_AMT_P    = AVOID.ADEC
  VINV_AMT_NP   = AVOID.ADEC
  VCN_AMT_P     = AVOID.ADEC
  VCN_AMT_NP    = AVOID.ADEC
  VEXTINV_AMT_P = AVOID.ADEC
  VEXTINV_AMT_NP= AVOID.ADEC
  VEXTCN_AMT_P  = AVOID.ADEC
  VEXTCN_AMT_NP = AVOID.ADEC
  #--

  Local Integer WLINE
  Local Decimal WLIN_INV_QTY
  Local Decimal WLIN_EXT_QTY
  Local Decimal WLIN_INV_AMT
  Local Decimal WLIN_EXT_AMT
  Local Tinyint WINVCNDSTA

  If PVCRINVCNDLIN>0 #--A specific line
    WLINE = func GET_LINE_INDEX_FOR_VCRINVCNDLIN(this,PVCRINVCNDLIN)
    If WLINE=[V]CST_ANOTDEFINED : [L]ARET_VALUE=[V]CST_AERROR : Endif
    [L]ARET_VALUE = fmet this.GET_LINE_INVOICED_VALUES(this.VCRINVCNDLIN(WLINE).VCRINVCNDLIN,
&                                                      WLIN_INV_QTY, WLIN_EXT_QTY, WLIN_INV_AMT, WLIN_EXT_AMT, WINVCNDSTA)
    If [L]ARET_VALUE>=[V]CST_AERROR : Return : Endif
    #--
    Case this.VCRINVCNDLIN(WLINE).INVCNDSTA
      When 2 : #--'Invoiced' (posted)
        VINV_QTY_P   += WLIN_INV_QTY
        VEXTINV_QTY_P+= WLIN_EXT_QTY
        #--
        VINV_AMT_P   += WLIN_INV_AMT
        VEXTINV_AMT_P+= WLIN_EXT_AMT

        #TODO When developping the V2 credit note handling (new schedule invoice line as credit note/On credit note), comment this code !
        VCN_QTY_P     += this.VCRINVCNDLIN(WLINE).LIN_CN_QTY
        #--
        VCN_AMT_P     += this.VCRINVCNDLIN(WLINE).LIN_CN_AMT

      When 3 : #--'Credit note' (posted)
        VCN_QTY_P     += WLIN_INV_QTY
        #VEXTCN_QTY_nP  += WLIN_EXT_QTY
        #--
        VCN_AMT_P     += WLIN_INV_AMT
        #VEXTCN_AMT_nP  += WLIN_EXT_AMT

      When 5 : #--'On invoice' (not posted)
        VINV_QTY_NP   += WLIN_INV_QTY
        VEXTINV_QTY_NP+= WLIN_EXT_QTY
        #--
        VINV_AMT_NP   += WLIN_INV_AMT
        VEXTINV_AMT_NP+= WLIN_EXT_AMT

      When 6 : #--'On Credit note' (not posted)
        VCN_QTY_NP     += WLIN_INV_QTY
        #VEXTCN_QTY_nP  += WLIN_EXT_QTY
        #--
        VCN_AMT_NP     += WLIN_INV_AMT
        #VEXTCN_AMT_nP  += WLIN_EXT_AMT
      When Default :
    Endcase
  Else
    #--All lines
    For WLINE=1 To maxtab(this.VCRINVCNDLIN)
      If this.VCRINVCNDLIN(WLINE)<>null and find(this.VCRINVCNDLIN(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
&                                       and find(this.VCRINVCNDLIN(WLINE).INVCNDSTA,2,3,5,6)>0

        [L]ARET_VALUE = fmet this.GET_LINE_INVOICED_VALUES(this.VCRINVCNDLIN(WLINE).VCRINVCNDLIN,
&                                                          WLIN_INV_QTY, WLIN_EXT_QTY, WLIN_INV_AMT, WLIN_EXT_AMT, WINVCNDSTA)
        If [L]ARET_VALUE>=[V]CST_AERROR : Break : Endif
        #--
        Case this.VCRINVCNDLIN(WLINE).INVCNDSTA
          When 2 : #--'Invoiced' (posted)
            VINV_QTY_P   += WLIN_INV_QTY
            VEXTINV_QTY_P+= WLIN_EXT_QTY
            #--
            VINV_AMT_P   += WLIN_INV_AMT
            VEXTINV_AMT_P+= WLIN_EXT_AMT

            #TODO When developping the V2 credit note handling (new schedule invoice line as credit note/On credit note), comment this code !
            VCN_QTY_P     += this.VCRINVCNDLIN(WLINE).LIN_CN_QTY
            #--
            VCN_AMT_P     += this.VCRINVCNDLIN(WLINE).LIN_CN_AMT

          When 3 : #--'Credit note' (posted)

            VCN_QTY_P     += WLIN_INV_QTY
            #VEXTCN_QTY_P  += WLIN_EXT_QTY
            #--
            VCN_AMT_P     += WLIN_INV_AMT
            #VEXTCN_AMT_P  += WLIN_EXT_AMT

          When 5 : #--'On invoice' (not posted)
            VINV_QTY_NP   += WLIN_INV_QTY
            VEXTINV_QTY_NP+= WLIN_EXT_QTY
            #--
            VINV_AMT_NP   += WLIN_INV_AMT
            VEXTINV_AMT_NP+= WLIN_EXT_AMT

          When 6 : #--'On Credit note' (not posted)
            VCN_QTY_P     += WLIN_INV_QTY
            #VEXTCN_QTY_P  += WLIN_EXT_QTY
            #--
            VCN_AMT_P     += WLIN_INV_AMT
            #VEXTCN_AMT_P  += WLIN_EXT_AMT
          When Default :
        Endcase
      Endif
    Next
  Endif
  If [L]ARET_VALUE>=[V]CST_AERROR
    VINV_QTY_P    = AVOID.ADEC
    VINV_QTY_NP   = AVOID.ADEC
    VCN_QTY_P     = AVOID.ADEC
    VCN_QTY_NP    = AVOID.ADEC
    VEXTINV_QTY_P = AVOID.ADEC
    VEXTINV_QTY_NP= AVOID.ADEC
    VEXTCN_QTY_P  = AVOID.ADEC
    VEXTCN_QTY_NP = AVOID.ADEC
    #--
    VINV_AMT_P    = AVOID.ADEC
    VINV_AMT_NP   = AVOID.ADEC
    VCN_AMT_P     = AVOID.ADEC
    VCN_AMT_NP    = AVOID.ADEC
    VEXTINV_AMT_P = AVOID.ADEC
    VEXTINV_AMT_NP= AVOID.ADEC
    VEXTCN_AMT_P  = AVOID.ADEC
    VEXTCN_AMT_NP = AVOID.ADEC
    #--
    Return
  Endif

Return
#---------------------------------------------------------------
$GET_LINE_INVOICED_VALUES
#PVCRINVCNDLIN Integer
#VLIN_INV_QTY  Decimal
#VLIN_EXT_QTY  Decimal
#VLIN_INV_AMT  Decimal
#VLIN_EXT_AMT  Decimal
#VINVCNDSTA    Tinyint

  VLIN_INV_QTY = AVOID.ADEC
  VLIN_EXT_QTY = AVOID.ADEC
  #--
  VLIN_INV_AMT = AVOID.ADEC
  VLIN_EXT_AMT = AVOID.ADEC
  #--
  VINVCNDSTA   = 0

  Local Integer WLINE

  If PVCRINVCNDLIN>0
    WLINE = func GET_LINE_INDEX_FOR_VCRINVCNDLIN(this,PVCRINVCNDLIN)
  Else
    Return
  Endif

  If find(this.VCRINVCNDLIN(WLINE).INVCNDSTA,2,3,5,6)=0 : Return : Endif

  VINVCNDSTA = this.VCRINVCNDLIN(WLINE).INVCNDSTA

  Case this.VCRINVCNDLIN(WLINE).INVCNDSTA
    When 2,5 :#--'Invoiced'/'On invoice'
              VLIN_INV_QTY = this.VCRINVCNDLIN(WLINE).INVCNDQTY
              VLIN_EXT_QTY = this.VCRINVCNDLIN(WLINE).LIN_EXT_QTY
              #--
              If this.PRITYP=2
                VLIN_INV_AMT = this.VCRINVCNDLIN(WLINE).INVCNDAMTATI
              Else
                VLIN_INV_AMT = this.VCRINVCNDLIN(WLINE).INVCNDAMTNOT
              Endif
              VLIN_EXT_AMT = this.VCRINVCNDLIN(WLINE).LIN_EXT_AMT
              #--
    When 3,6 : #--'Credit note'/'On credit note'
              VLIN_INV_QTY = abs(this.VCRINVCNDLIN(WLINE).INVCNDQTY)
              #VLIN_EXT_QTY = abs(this.VCRINVCNDLIN(WLINE).LIN_EXT_QTY)
              #--
              If this.PRITYP=2
                VLIN_INV_AMT = abs(this.VCRINVCNDLIN(WLINE).INVCNDAMTATI)
              Else
                VLIN_INV_AMT = abs(this.VCRINVCNDLIN(WLINE).INVCNDAMTNOT)
              Endif
              #VLIN_EXT_AMT = abs(this.VCRINVCNDLIN(WLINE).LIN_EXT_AMT)
              #--
    When Default : Return
  Endcase

Return
#---------------------------------------------------------------
$GET_REMAINING_TO_INVOICE

Local Integer WLINE,WIJLINE

  [L]ARET_VALUE = [V]CST_AOK

  If PVCRINVCNDLIN>0
    WIJLINE = func GET_LINE_INDEX_FOR_VCRINVCNDLIN(this,PVCRINVCNDLIN)
  Else
    Return
  Endif

  Raz VIS_LASTLINE_TOINVOICE
  Raz VQTY_TOINVOICE,VPRC_TOINVOICE, VAMT_TOINVOICE

  VIS_LASTLINE_TOINVOICE = [V]CST_ATRUE
  For WLINE=1 To maxtab(this.VCRINVCNDLIN)
    If this.VCRINVCNDLIN(WLINE)<>null and find(this.VCRINVCNDLIN(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      If this.VCRINVCNDLIN(WLINE).INVCNDSTA<=1
        VPRC_TOINVOICE += this.VCRINVCNDLIN(WLINE).INVPERCENT
        VQTY_TOINVOICE += this.VCRINVCNDLIN(WLINE).INVCNDQTY
        If this.PRITYP=2
          VAMT_TOINVOICE += this.VCRINVCNDLIN(WLINE).INVCNDAMTATI
        Else
          VAMT_TOINVOICE += this.VCRINVCNDLIN(WLINE).INVCNDAMTNOT
        Endif
        If WLINE<>WIJLINE
          VIS_LASTLINE_TOINVOICE = [V]CST_AFALSE
        Endif
      Endif
    Endif
  Next

Return
#---------------------------------------------------------------
$TOTAL_ADD_FROM_INVOICE
Local Integer WIJLINE

  If PVCRINVCNDLIN<=0 : Return : Endif

  WIJLINE = func GET_LINE_INDEX_FOR_VCRINVCNDLIN(this,PVCRINVCNDLIN)

#If GUSER ="LD"
#  Infbox "ADD BEFORE this.TOT_INV_QTY="-num$(this.TOT_INV_QTY)
#Endif

  #TODO Also test the line's CUR and SAU units and the header's ones

  If this.VCRINVCNDLIN(WIJLINE)<>null and find(this.VCRINVCNDLIN(WIJLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 and
&    find(this.VCRINVCNDLIN(WIJLINE).INVCNDSTA,5,6)>0

    #--Total invoiced
    If this.VCRINVCNDLIN(WIJLINE).INVCNDSTA = 5
      this.TOT_INV_QTY += this.VCRINVCNDLIN(WIJLINE).INVCNDQTY

      If this.PRITYP=2
        this.TOT_INV_AMT += this.VCRINVCNDLIN(WIJLINE).INVCNDAMTATI
      Else
        this.TOT_INV_AMT += this.VCRINVCNDLIN(WIJLINE).INVCNDAMTNOT
      Endif

      #--Total extra-billing
      this.TOT_EXT_QTY += this.VCRINVCNDLIN(WIJLINE).LIN_EXT_QTY
      this.TOT_EXT_AMT += this.VCRINVCNDLIN(WIJLINE).LIN_EXT_AMT
    #--Total on credit note
    Elsif this.VCRINVCNDLIN(WIJLINE).INVCNDSTA=6
      this.TOT_CN_QTY += this.VCRINVCNDLIN(WIJLINE).INVCNDQTY

      If this.PRITYP=2
        this.TOT_CN_AMT += this.VCRINVCNDLIN(WIJLINE).INVCNDAMTATI
      Else
        this.TOT_CN_AMT += this.VCRINVCNDLIN(WIJLINE).INVCNDAMTNOT
      Endif
    Endif
  Endif

#If GUSER ="LD"
#  Infbox "ADD AFTER this.TOT_INV_QTY="-num$(this.TOT_INV_QTY)
#Endif

Return
#---------------------------------------------------------------
$TOTAL_REMOVE_FROM_INVOICE
Local Integer WIJLINE

  If PVCRINVCNDLIN<=0 : Return : Endif

  WIJLINE = func GET_LINE_INDEX_FOR_VCRINVCNDLIN(this,PVCRINVCNDLIN)

#If GUSER ="LD"
#  Infbox "REMOVE BEFORE this.TOT_INV_QTY="-num$(this.TOT_INV_QTY)
#Endif

  #TODO Also test the line's CUR and SAU units and the header's ones
  If this.VCRINVCNDLIN(WIJLINE)<>null and find(this.VCRINVCNDLIN(WIJLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 and
&    find(this.VCRINVCNDLIN(WIJLINE).INVCNDSTA,1,5,6)>0

    #--Total invoiced
    If this.VCRINVCNDLIN(WIJLINE).INVCNDSTA = 5
      this.TOT_INV_QTY -= this.VCRINVCNDLIN(WIJLINE).INVCNDQTY

      If this.PRITYP=2
        this.TOT_INV_AMT -= this.VCRINVCNDLIN(WIJLINE).INVCNDAMTATI
      Else
        this.TOT_INV_AMT -= this.VCRINVCNDLIN(WIJLINE).INVCNDAMTNOT
      Endif

      #--Total extra-billing
      this.TOT_EXT_QTY -= this.VCRINVCNDLIN(WIJLINE).LIN_EXT_QTY
      this.TOT_EXT_AMT -= this.VCRINVCNDLIN(WIJLINE).LIN_EXT_AMT
    #--Total on credit note
    Elsif this.VCRINVCNDLIN(WIJLINE).INVCNDSTA = 6
      this.TOT_CN_QTY -= this.VCRINVCNDLIN(WIJLINE).INVCNDQTY

      If this.PRITYP=2
        this.TOT_CN_AMT -= this.VCRINVCNDLIN(WIJLINE).INVCNDAMTATI
      Else
        this.TOT_CN_AMT -= this.VCRINVCNDLIN(WIJLINE).INVCNDAMTNOT
      Endif

    Endif
  Endif

#If GUSER ="LD"
#  Infbox "REMOVE AFTER this.TOT_INV_QTY="-num$(this.TOT_INV_QTY)
#Endif

Return
#---------------------------------------------------------------
#**
#* Class method SET_INVOICE_PRC_CHANGED is used set to split/group a schedule invoice 'On invoice' status line
#* according to the new percentage as input parameter
#* Input
#* PVCRINVCNDLIN The line key number concerned by the splitting
#* PNEWPERCENT   The wanted percentage value
#* (the difference has to go to a new line with 'To be invoice' status, if less)
#* (the difference has to come from existing lines with 'To be invoice' status, if greater)
#* It returns [V]CST_AERROR or [V]CST_AOK
#*!
$SET_INVOICE_PRC_CHANGED
Local Integer WLINE_INDEX
Local Decimal WQTYTOREACH

  #--Nothing to do if no line given
  If PVCRINVCNDLIN = AVOID.AINT : Return : Endif
  #--Nothing to do if no quantity given
  If PNEWPERCENT   = AVOID.ADEC : Return : Endif

  #--First, we'll have to find the collection line index that contains the PVCRINVCNDLIN key line number
  WLINE_INDEX = func GET_LINE_INDEX_FOR_VCRINVCNDLIN(this,PVCRINVCNDLIN)

  If WLINE_INDEX = [V]CST_ANOTDEFINED
    [L]ARET_VALUE=fmet this.ASETERROR("",mess(3,61,1)-num$(PVCRINVCNDLIN)-mess(40,9016,1),[V]CST_AERROR)
    Return
  Endif

  PVCRINVCNDLIN = WLINE_INDEX

  #--Error if given line number does not exist
  If this.VCRINVCNDLIN(PVCRINVCNDLIN)=null
    [L]ARET_VALUE=fmet this.ASETERROR("",mess(3,61,1)-num$(PVCRINVCNDLIN)-mess(40,9016,1),[V]CST_AERROR)
    Return
  Endif

  #--Error if the given line number has a ASTALIN within ([V]cst_adel,[V]cst_anewdel)
  If find(this.VCRINVCNDLIN(PVCRINVCNDLIN).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
    [L]ARET_VALUE = fmet this.ASETERROR("",mess(3,61,1)-num$(PVCRINVCNDLIN)-mess(521,192,1),[V]CST_AERROR)
    Return
  Endif

  #--Error if given line number is 'Invoiced'/'Credit note'/'Closed'/'Included on credit note'
  If find(this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDSTA,2,3,4,6)>0
    [L]ARET_VALUE = fmet this.ASETERROR("",mess(3,61,1)-num$(PVCRINVCNDLIN)-func AFNC.MES1(mess(474,192,1),mess(1,2419,1)),[V]CST_AERROR)
    Return
  Endif

  #--Nothing to do if same percentage
  If this.VCRINVCNDLIN(PVCRINVCNDLIN).INVPERCENT=PNEWPERCENT and
&    this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_QTY=AVOID.ADEC and
&    this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_AMT=AVOID.ADEC
    Return
  Endif

  If this.QTY<>0
    #--Quantity driven schedule invoice
    Local Decimal WQTYTOREACH
    WQTYTOREACH = arr(this.QTY*PNEWPERCENT/100,10^(-this.SAU_UOMDEC))
    [L]ARET_VALUE=fmet this.SET_INVOICE_QTY_CHANGED(this.VCRINVCNDLIN(PVCRINVCNDLIN).VCRINVCNDLIN,WQTYTOREACH,PIS_EXTRABILL)
    If [L]ARET_VALUE>=[V]CST_AERROR
      Return
    Endif
  Else
    Local Decimal WAMTTOREACH
    If this.PRITYP=2
      #--AMTATI driven
      WAMTTOREACH = arr(this.AMTATI*PNEWPERCENT/100,10^(-this.CUR_DECNBR))
    Else
      #--AMTNOT driven
      WAMTTOREACH = arr(this.AMTNOT*PNEWPERCENT/100,10^(-this.CUR_DECNBR))
    Endif
    [L]ARET_VALUE=fmet this.SET_INVOICE_AMT_CHANGED(this.VCRINVCNDLIN(PVCRINVCNDLIN).VCRINVCNDLIN,WAMTTOREACH,PIS_EXTRABILL)
    If [L]ARET_VALUE>=[V]CST_AERROR
      Return
    Endif
  Endif

Return
#---------------------------------------------------------------
#**
#* Class method SET_INVOICE_QTY_CHANGED is used set to split/group a schedule invoice 'On invoice' status line
#* according to the new quantity as input parameter
#* Input
#* PVCRINVCNDLIN The line key number concerned by the splitting
#* PQTYTOREACH   The wanted quantity
#* (the difference has to go to a new line with 'To be invoice' status, if less)
#* (the difference has to come from existing lines with 'To be invoice' status, if greater)
#* It returns [V]CST_AERROR or [V]CST_AOK
#*!
$SET_INVOICE_QTY_CHANGED
Local Integer WLINE_INDEX

  #--Nothing to do if no line given
  If PVCRINVCNDLIN = AVOID.AINT : Return : Endif
  #--Nothing to do if no quantity given
  If PQTYTOREACH   = AVOID.ADEC : Return : Endif

  #--First, we'll have to find the collection line index that contains the PVCRINVCNDLIN key line number
  WLINE_INDEX = func GET_LINE_INDEX_FOR_VCRINVCNDLIN(this,PVCRINVCNDLIN)

  If WLINE_INDEX = [V]CST_ANOTDEFINED
    [L]ARET_VALUE=fmet this.ASETERROR("",mess(3,61,1)-num$(PVCRINVCNDLIN)-mess(40,9016,1),[V]CST_AERROR)
    Return
  Endif

  PVCRINVCNDLIN = WLINE_INDEX

  #--Error if given line number does not exist
  If this.VCRINVCNDLIN(PVCRINVCNDLIN)=null
    [L]ARET_VALUE=fmet this.ASETERROR("",mess(3,61,1)-num$(PVCRINVCNDLIN)-mess(40,9016,1),[V]CST_AERROR)
    Return
  Endif

  #--Error if the given line number has a ASTALIN within ([V]cst_adel,[V]cst_anewdel)
  If find(this.VCRINVCNDLIN(PVCRINVCNDLIN).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
    [L]ARET_VALUE = fmet this.ASETERROR("",mess(3,61,1)-num$(PVCRINVCNDLIN)-mess(521,192,1),[V]CST_AERROR)
    Return
  Endif

  #--Error if given line number is 'Invoiced'/'Credit note'/'Closed'/'Included on credit note'
  If find(this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDSTA,2,3,4,6)>0
    [L]ARET_VALUE = fmet this.ASETERROR("",mess(3,61,1)-num$(PVCRINVCNDLIN)-func AFNC.MES1(mess(474,192,1),mess(1,2419,1)),[V]CST_AERROR)
    Return
  Endif

  #--Nothing to do if same quantity
  If this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDQTY=PQTYTOREACH and
&    this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_QTY=AVOID.ADEC and
&    this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_AMT=AVOID.ADEC
    Return
  Endif

  #--
  If abs(this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDQTY+this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_QTY)<abs(PQTYTOREACH)
    Gosub _GROUP_LINE_BY_QTY
  Else
    Gosub _SPLIT_LINE_BY_QTY
  Endif

Return
#---------------------------------------------------------------
# Input
# PVCRINVCNDLIN The line concerned by the splitting
# PQTYTOREACH   The quantity the has to remain on the present splitted/grouped line
# (the difference has to go to a new line with 'To be invoice' status, if less)
$_SPLIT_LINE_BY_QTY
Local Decimal WDELTAQTY,WAMT,WPREVQTY
Local Integer WLINE,WINVCNDLIN
Local Integer WLINORISPLIT,WIS_RES_SPLIT,WSAVEUPDTICK,WINDEX_CURENT_MOD_LINE
Local Decimal WEXTRA_AMT

Local Uuident WSAVEUUID

Local File SVCRINVCNDD [SVICD] #--used to copy properties from current line to the new one

  WINDEX_CURENT_MOD_LINE = PVCRINVCNDLIN

  #--Updating the header totals : removing
  If find(this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDSTA,5,6)>0
    [L]ARET_VALUE=fmet this.TOTAL_REMOVE_FROM_INVOICE(this.VCRINVCNDLIN(PVCRINVCNDLIN).VCRINVCNDLIN)
    If [L]ARET_VALUE>=[V]CST_AERROR
#      [L]ARET_VALUE = fmet this.ASETERROR("_SPLIT_LINE_BY_QTY","Error updating header totals",[V]CST_AERROR)
      [L]ARET_VALUE = fmet this.ASETERROR("_SPLIT_LINE_BY_QTY", mess(546,192,1),[V]CST_AERROR) # JUCON 20/01/17
      Return
    Endif
  Endif

  #--First, let's diminue the extra-bill quantity, if any
  If find(this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDSTA,5,6)>0
    If this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_QTY>0
      this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_QTY -= (this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDQTY+this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_QTY)-PQTYTOREACH
      If this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_QTY<0
        #--Consumming all extra-billing quantity
        this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_QTY = AVOID.ADEC
    Elsif this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDQTY<>0 and this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_AMT>0
      #--Amount driven schedule invoice
      #TODO
      Endif
    Endif
  Endif

  WPREVQTY = this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDQTY

  #--This will trigger the propagate, hence the calculation of other properties depending of
  this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDQTY=PQTYTOREACH-this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_QTY

  this.VCRINVCNDLIN(PVCRINVCNDLIN).MODFLG = 4 #--'Split'
  this.VCRINVCNDLIN(PVCRINVCNDLIN).MODDAT = date$

  If find(this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDSTA,5,6)>0
    this.VCRINVCNDLIN(PVCRINVCNDLIN).IS_EXTRABILL=[V]CST_ANO

    If this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_INV_PRI = 0 and
&      this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_AMT = 0
      If this.PRITYP=2
        this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_INV_PRI = this.VCRINVCNDLIN(PVCRINVCNDLIN).DNETPRIATI
      Else
        this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_INV_PRI = this.VCRINVCNDLIN(PVCRINVCNDLIN).DNETPRINOT
      Endif
    Endif
    [L]WEXTRA_AMT = arr(this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_INV_PRI*this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_QTY,10^(-this.CUR_DECNBR)) #TODO Revoir; il faudrait partir la facture
    If this.PRITYP=2
      WEXTRA_AMT += arr((this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_INV_PRI-this.VCRINVCNDLIN(PVCRINVCNDLIN).DNETPRIATI)*this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDQTY,10^(-this.CUR_DECNBR))
    Else
      WEXTRA_AMT += arr((this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_INV_PRI-this.VCRINVCNDLIN(PVCRINVCNDLIN).DNETPRINOT)*this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDQTY,10^(-this.CUR_DECNBR))
    Endif
    this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_AMT=WEXTRA_AMT

    If this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_AMT<>0 or this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_QTY<>0
      this.VCRINVCNDLIN(PVCRINVCNDLIN).IS_EXTRABILL=[V]CST_AYES
    Endif
  Endif

  #--As the propagate might have rounded the assigned value, it's here that the delta is to be set
  If PQTYTOREACH <> this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDQTY
    [L]ARET_VALUE = fmet this.ASETERROR("_SPLIT_LINE_BY_QTY",mess(543,192,1),[V]CST_AINFO)
  Endif
  PQTYTOREACH = this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDQTY

  WDELTAQTY=WPREVQTY-PQTYTOREACH

  #--Updating the header totals : adding
  If find(this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDSTA,5,6)>0
    [L]ARET_VALUE=fmet this.TOTAL_ADD_FROM_INVOICE(this.VCRINVCNDLIN(PVCRINVCNDLIN).VCRINVCNDLIN)
    If [L]ARET_VALUE>=[V]CST_AERROR
#      [L]ARET_VALUE = fmet this.ASETERROR("_SPLIT_LINE_BY_QTY","Error updating header totals",[V]CST_AERROR)
      [L]ARET_VALUE = fmet this.ASETERROR("_SPLIT_LINE_BY_QTY", mess(546,192,1),[V]CST_AERROR) # JUCON 20/01/17
      Return
    Endif
  Endif

  #--Searching if the actual line to split was already splited before
  WLINORI_SPLIT = [V]CST_ANOTDEFINED
  For WLINE=1 To maxtab(this.VCRINVCNDLIN)
    If this.VCRINVCNDLIN(WLINE)<>null and find(this.VCRINVCNDLIN(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 and
&      this.VCRINVCNDLIN(WLINE).INVCNDSTA<=1 and this.VCRINVCNDLIN(WLINE).LINORI_SPLIT=this.VCRINVCNDLIN(PVCRINVCNDLIN).VCRINVCNDLIN and
&      this.VCRINVCNDLIN(WLINE).IS_RES_SPLIT=[V]CST_AYES and
&      this.VCRINVCNDLIN(WLINE).NEXINVDAT = this.VCRINVCNDLIN(PVCRINVCNDLIN).NEXINVDAT and
&      this.VCRINVCNDLIN(WLINE).VCRINVCNDLIN<>this.VCRINVCNDLIN(PVCRINVCNDLIN).VCRINVCNDLIN
      WLINORI_SPLIT = WLINE
      Break
    Endif
  Next

  If WLINORI_SPLIT=[V]CST_ANOTDEFINED
    WLINE=fmet this.ADDLINE("VCRINVCNDLIN",[V]CST_ALASTPOS)
    If WLINE=[V]CST_ANOTDEFINED
      #--"Error inserting into VCRINVCNDLIN collection"
      [L]ARET_VALUE = fmet this.ASETERROR("_SPLIT_LINE_BY_QTY",mess(455,192,1),[V]CST_AERROR)
      Return
    Endif
  Else
    WLINE = WLINORI_SPLIT
  Endif

  WSAVEUUID    = this.VCRINVCNDLIN(WLINE).AUUID
  WSAVEUPDTICK = this.VCRINVCNDLIN(WLINE).updTick
  #--We start by copying all properties from the current line to the new one
  #----------
  this.VCRINVCNDLIN(WLINE).IS_PROP_CHG =[V]CST_AYES #--Preventing the propagate

  WINVCNDLIN = this.VCRINVCNDLIN(WLINE).VCRINVCNDLIN

  SetInstance [F:SVICD] With this.VCRINVCNDLIN(PVCRINVCNDLIN)
  #--Changing the values that we need to change
  [F:SVICD]AUUID        = WSAVEUUID
  [F:SVICD]INVCNDSTA    = 1 #--'To be invoiced'
  [F:SVICD]SIHNUM       = AVOID.ACHAR
  [F:SVICD]SIDLIN       = AVOID.AINT
  [F:SVICD]VCRINVCNDLIN = WINVCNDLIN
  [F:SVICD]LIN_EXT_AMT  = AVOID.ADEC
  [F:SVICD]LIN_INV_PRI  = AVOID.ADEC
  [F:SVICD]LIN_EXT_QTY  = AVOID.ADEC
  [F:SVICD]IS_CONS_GRP  = [V]CST_ANO
  [F:SVICD]IS_EXTRABILL = [V]CST_ANO
  [F:SVICD]IS_RES_SPLIT = [V]CST_AYES
  [F:SVICD]LINORI_SPLIT = this.VCRINVCNDLIN(PVCRINVCNDLIN).VCRINVCNDLIN
  [F:SVICD]MODDAT       = AVOID.ADATE
  [F:SVICD]MODFLG       = AVOID.AINT
  #[F:SVICD]updTick      = WSAVEUPDTICK
  #--
  SetInstance this.VCRINVCNDLIN(WLINE) With [F:SVICD]

  #--Changing the values that we need to change
  this.VCRINVCNDLIN(WLINE).updTick = WSAVEUPDTICK

  this.VCRINVCNDLIN(WLINE).IS_RES_SPLIT=[V]CST_AYES
  this.VCRINVCNDLIN(WLINE).LINORI_SPLIT=this.VCRINVCNDLIN(PVCRINVCNDLIN).VCRINVCNDLIN

  this.VCRINVCNDLIN(WLINE).IS_PROP_CHG =[V]CST_ANO #--Allowing the propagate
  #----------

  #----------
  #--This will trigger the propagate, hence the calculation of other properties depending of
  this.VCRINVCNDLIN(WLINE).INVCNDQTY = WDELTAQTY
  #----------
  this.VCRINVCNDLIN(WLINE).MODFLG = 6 #--'Generated'
  this.VCRINVCNDLIN(WLINE).MODDAT = date$
  #----------
  #--finally, we have to control and re-dispatch on last line
  #--!! Due to rounding issues, the percentage of all other lines could slightly be modified, also!!
  Gosub _CONTROL_DISPATCH_TOTALLINES
  If [L]ASTATUS>=[V]CST_AERROR : [L]ARET_VALUE=[L]ASTATUS: Return : Endif
  #----------

  LogicClose File [SVICD]

Return
#---------------------------------------------------------------
# Input
# PVCRINVCNDLIN The line concerned by the splitting
# PQTYTOREACH   The quantity the has to remain on the present splitted/grouped line
# (the difference has to come from existing lines with 'To be invoice' status, if greater)
# whatever the origin of the quantites to group, the PERFROM and PERTO of the present line
# will be extended to include the grouped line's PERFROM and PERTO dates
# The NEXINVDAT will remain the same on the present line
# Condition to be fullfilled by to be grouped lines :
# INVCNDSTA = 1 'To be invoiced'
# NETPRINOT/NETPRIATI the same as those for the present line
$_GROUP_LINE_BY_QTY
Local Decimal WDELTAQTY,WAMT,WDELTAAMT,WOLDQTY,WOLDAMT,WDELTAPRICE
Local Integer WLINE,WORDER,WMAXORDER,WINDEX_CURENT_MOD_LINE
Local Char WSORT_FIELDS(GLONAVA)(0..)
Local Integer WMAXAERROR

  #--This will contain the quantity to add from other lines
  WDELTAQTY=PQTYTOREACH-this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDQTY

  If WDELTAQTY = 0 : Return : Endif

  WINDEX_CURENT_MOD_LINE = PVCRINVCNDLIN

  WOLDQTY = this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDQTY
  If this.PRITYP=2
    WOLDAMT = this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDAMTATI
  Else
    WOLDAMT = this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDAMTNOT
  Endif

  #--Only if not extra-billing asked
  If PIS_EXTRABILL<>[V]CST_AYES

    #--Updating the header totals : removing
    If find(this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDSTA,5,6)>0
      [L]ARET_VALUE=fmet this.TOTAL_REMOVE_FROM_INVOICE(this.VCRINVCNDLIN(PVCRINVCNDLIN).VCRINVCNDLIN)
      If [L]ARET_VALUE>=[V]CST_AERROR
#        [L]ARET_VALUE = fmet this.ASETERROR("_GROUP_LINE_BY_QTY","Error updating header totals",[V]CST_AERROR)
        [L]ARET_VALUE = fmet this.ASETERROR("_GROUP_LINE_BY_QTY", mess(546,192,1),[V]CST_AERROR) # JUCON 20/01/17
        Return
      Endif
    Endif

    #--Before doing this, we'll have to set to null the existing extra-billing values
    #--Not the LIN_INV_PRI because of an eventually former invoice price modification
    this.VCRINVCNDLIN(PVCRINVCNDLIN).IS_EXTRABILL = [V]CST_ANO
    this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_QTY  = AVOID.ADEC
    this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_AMT  = AVOID.ADEC

    #--Consommer dans l'ordre de la date de facture !!!
    #--First, the VCRINVCNDLIN has to be sorted according to the NEXINVDAT and VCRINVCNDLIN
    WSORT_FIELDS(0)="NEXINVDAT"
    WSORT_FIELDS(1)="VCRINVCNDLIN"

    [L]ARET_VALUE = fmet this.SORT3("VCRINVCNDLIN",WSORT_FIELDS(0),WSORT_FIELDS(1),"")
    If [L]ARET_VALUE=[V]CST_ANOTDEFINED
      [L]ARET_VALUE = fmet this.ASETERROR("_GROUP_LINE_BY_QTY","Error sorting VCRINVCNDLIN collection",[V]CST_AERROR)
      Return
    Endif
    WORDER = min(this.VCRINVCNDLIN(1..maxtab(this.VCRINVCNDLIN)).AORDER)
    WMAXORDER=max(this.VCRINVCNDLIN(1..maxtab(this.VCRINVCNDLIN)).AORDER)
    If WORDER<1 : Return : Endif

    WLINE=fmet this.AGETINDBYLINE("VCRINVCNDLIN",WORDER)
    While WLINE<>[V]CST_ANOTDEFINED and WLINE<=maxtab(this.VCRINVCNDLIN)
      If WLINE>0 and this.VCRINVCNDLIN(WLINE)<>null and find(this.VCRINVCNDLIN(WLINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
&                and this.VCRINVCNDLIN(WLINE).INVCNDSTA<=1
&                and this.VCRINVCNDLIN(WLINE).NEXINVDAT>=this.VCRINVCNDLIN(PVCRINVCNDLIN).NEXINVDAT
&                and WLINE<>PVCRINVCNDLIN
        If WDELTAQTY>=this.VCRINVCNDLIN(WLINE).INVCNDQTY
          #--We can group all present line's quantity

          #--This will trigger the propagate, hence the calculation of other properties depending of
          this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDQTY += this.VCRINVCNDLIN(WLINE).INVCNDQTY

          this.VCRINVCNDLIN(PVCRINVCNDLIN).MODFLG = 5 #--'Group'
          this.VCRINVCNDLIN(PVCRINVCNDLIN).MODDAT = date$

          this.VCRINVCNDLIN(WLINE).MODFLG = 4 #--'Split'
          this.VCRINVCNDLIN(WLINE).MODDAT = date$

          #--Diminushing the quantity to group
          WDELTAQTY-=this.VCRINVCNDLIN(WLINE).INVCNDQTY

          #--Now, let's delete the present line, qty was added on the PVCRINVCNDLIN line
          [L]ARET_VALUE = fmet this.ADELLINE("VCRINVCNDLIN",this.VCRINVCNDLIN(WLINE).AORDER)
          If [L]ARET_VALUE=[V]CST_ANOTDEFINED
            #--"Error deleting line from VCRINVCNDLIN collection"
            [L]ARET_VALUE = fmet this.ASETERROR("_GROUP_LINE_BY_QTY",func AFNC.MES1(mess(454,192,1),num$(this.VCRINVCNDLIN(WLINE).AORDER)),[V]CST_AERROR)
            Break
          Endif

          #--Because the ADELLINE deletes the AORDER value and re-number the following ones
          #--we'll have the decrease the WORDER's value
          WORDER-=1

          #--No need to continue if WDELTAQTY=0
          If WDELTAQTY=0 : Break : Endif
        Else
          #--We take what we need from the present line

          #--This will trigger the propagate, hence the calculation of other properties depending of
          this.VCRINVCNDLIN(WLINE).INVCNDQTY -= WDELTAQTY

          #--Let's flag the consumption
          this.VCRINVCNDLIN(WLINE).IS_CONS_GRP   =[V]CST_AYES
          this.VCRINVCNDLIN(WLINE).QTY_CONS_GRP += WDELTAQTY

          #--This will trigger the propagate, hence the calculation of other properties depending of
          this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDQTY += WDELTAQTY

          this.VCRINVCNDLIN(PVCRINVCNDLIN).MODFLG = 5 #--'Group'
          this.VCRINVCNDLIN(PVCRINVCNDLIN).MODDAT = date$

          this.VCRINVCNDLIN(WLINE).MODFLG = 4 #--'Split'
          this.VCRINVCNDLIN(WLINE).MODDAT = date$

          Break #--We've consumed all the quantity to group
        Endif
      Endif
      WORDER+=1
      WMAXORDER=max(this.VCRINVCNDLIN(1..maxtab(this.VCRINVCNDLIN)).AORDER) #--re-doing this because of the ADELLINE
      If WORDER>WMAXORDER : Break : Endif
      WLINE=fmet this.AGETINDBYLINE("VCRINVCNDLIN",WORDER)
    Wend
    #--
    If [L]ARET_VALUE>=[V]CST_AERROR : Return : Endif

    #--Updating the header totals : adding new values
    If find(this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDSTA,5,6)>0
      [L]ARET_VALUE=fmet this.TOTAL_ADD_FROM_INVOICE(this.VCRINVCNDLIN(PVCRINVCNDLIN).VCRINVCNDLIN)
      If [L]ARET_VALUE>=[V]CST_AERROR
#        [L]ARET_VALUE = fmet this.ASETERROR("_GROUP_LINE_BY_QTY","Error updating header totals",[V]CST_AERROR)
        [L]ARET_VALUE = fmet this.ASETERROR("_GROUP_LINE_BY_QTY", mess(546,192,1),[V]CST_AERROR) # JUCON 20/01/17
        Return
      Endif
    Endif

    #--finally, we have to control and re-dispatch on last line
    #--!! Due to rounding issues, the percentage of all other lines could slightly be modified, also!!
    Gosub _CONTROL_DISPATCH_TOTALLINES
    If [L]ASTATUS>=[V]CST_AERROR : [L]ARET_VALUE=[L]ASTATUS: Return : Endif
    #----------

    #--Now, due to the rounding done in the previous gosub, let's check again the wanted quantity
    WDELTAQTY=PQTYTOREACH-this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDQTY
  Endif

  #--If there are not enough 'To be invoiced' lines for quantity to group, we consider as extra-billing
  If WDELTAQTY>=0
    #--Updating the header totals : adding new values
    If find(this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDSTA,5,6)>0
      [L]ARET_VALUE=fmet this.TOTAL_REMOVE_FROM_INVOICE(this.VCRINVCNDLIN(PVCRINVCNDLIN).VCRINVCNDLIN)
      If [L]ARET_VALUE>=[V]CST_AERROR
#        [L]ARET_VALUE = fmet this.ASETERROR("_GROUP_LINE_BY_QTY","Error updating header totals",[V]CST_AERROR)
        [L]ARET_VALUE = fmet this.ASETERROR("_GROUP_LINE_BY_QTY", mess(546,192,1),[V]CST_AERROR) # JUCON 20/01/17
        Return
      Endif

      If this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_INV_PRI = 0 and
&        this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_AMT = 0
        If this.PRITYP=2
          this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_INV_PRI = this.VCRINVCNDLIN(PVCRINVCNDLIN).DNETPRIATI
        Else
          this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_INV_PRI = this.VCRINVCNDLIN(PVCRINVCNDLIN).DNETPRINOT
        Endif
      Endif

      this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_QTY=WDELTAQTY

      [L]WDELTAAMT = arr(this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_INV_PRI*WDELTAQTY,10^(-this.CUR_DECNBR)) #TODO Revoir; il faudrait partir sur facture
      If this.PRITYP=2
        WDELTAPRICE = this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_INV_PRI-this.VCRINVCNDLIN(PVCRINVCNDLIN).DNETPRIATI
      Else
        WDELTAPRICE = this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_INV_PRI-this.VCRINVCNDLIN(PVCRINVCNDLIN).DNETPRINOT
      Endif
      [L]WDELTAAMT += arr(WDELTAPRICE*this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDQTY,10^(-this.CUR_DECNBR))

      this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_AMT = WDELTAAMT
      [L]ARET_VALUE=fmet this.TOTAL_ADD_FROM_INVOICE(this.VCRINVCNDLIN(PVCRINVCNDLIN).VCRINVCNDLIN)
      If [L]ARET_VALUE>=[V]CST_AERROR
#        [L]ARET_VALUE = fmet this.ASETERROR("_GROUP_LINE_BY_QTY","Error updating header totals",[V]CST_AERROR)
        [L]ARET_VALUE = fmet this.ASETERROR("_GROUP_LINE_BY_QTY", mess(546,192,1),[V]CST_AERROR) # JUCON 20/01/17
        Return
      Endif

      If WDELTAQTY>0
        WMAXAERROR=[L]ARET_VALUE #--To prevent loosing an blocking error set before !
        [L]ARET_VALUE = max(WMAXAERROR,fmet this.ASETERROR("",func AFNC.MES1(mess(519,192,1),"'"+mess(1,2419,1)+"'")+"."-mess(520,192,1)-":"-num$(WDELTAQTY),[V]CST_AWARNING))
      Endif

      this.VCRINVCNDLIN(PVCRINVCNDLIN).IS_EXTRABILL = [V]CST_AYES
      If this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_AMT=0 and this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_QTY=0
        this.VCRINVCNDLIN(PVCRINVCNDLIN).IS_EXTRABILL = [V]CST_ANO
      Endif
    Endif
  Endif

Return
#---------------------------------------------------------------
#**
#* Class method SET_INVOICE_PRICE_CHANGED is used set a new price for a schedule invoice line
#* Input
#* PVCRINVCNDLIN The line key number concerned by the splitting
#* PNEWPRICE     The new price
#* (the difference has to go to a new line with 'To be invoice' status, if less)
#* (the difference has to come from existing lines with 'To be invoice' status, if greater)
#* It returns [V]CST_AERROR or [V]CST_AOK
#*!
$SET_INVOICE_PRICE_CHANGED
Local Integer WLINE_INDEX,WDELTAPRICE
Local Decimal WEXTRA_AMT
Local Integer WMAXAERROR

  #--Nothing to do if no line given
  If PVCRINVCNDLIN = AVOID.AINT : Return : Endif

  #--First, we'll have to find the collection line index that contains the PVCRINVCNDLIN key line number
  WLINE_INDEX = func GET_LINE_INDEX_FOR_VCRINVCNDLIN(this,PVCRINVCNDLIN)

  If WLINE_INDEX = [V]CST_ANOTDEFINED
    [L]ARET_VALUE=fmet this.ASETERROR("",mess(3,61,1)-num$(PVCRINVCNDLIN)-mess(40,9016,1),[V]CST_AERROR)
    Return
  Endif

  PVCRINVCNDLIN = WLINE_INDEX

  #--Error if given line number does not exist
  If this.VCRINVCNDLIN(PVCRINVCNDLIN)=null
    [L]ARET_VALUE=fmet this.ASETERROR("",mess(3,61,1)-num$(PVCRINVCNDLIN)-mess(40,9016,1),[V]CST_AERROR)
    Return
  Endif

  If this.PRITYP=2
    WDELTAPRICE = PNEWPRICE - this.VCRINVCNDLIN(PVCRINVCNDLIN).DNETPRIATI
  Else
    WDELTAPRICE = PNEWPRICE - this.VCRINVCNDLIN(PVCRINVCNDLIN).DNETPRINOT
  Endif

  #--Error if the given line number has a ASTALIN within ([V]cst_adel,[V]cst_anewdel)
  If find(this.VCRINVCNDLIN(PVCRINVCNDLIN).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)>0
    [L]ARET_VALUE = fmet this.ASETERROR("",mess(3,61,1)-num$(PVCRINVCNDLIN)-mess(521,192,1),[V]CST_AERROR)
    Return
  Endif

  #--Error if given line number is 'Invoiced'/'Credit note'/'Closed'/'Included on credit note'
  If find(this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDSTA,2,3,4,6)>0
    [L]ARET_VALUE = fmet this.ASETERROR("",mess(3,61,1)-num$(PVCRINVCNDLIN)-func AFNC.MES1(mess(474,192,1),mess(1,2419,1)),[V]CST_AERROR)
    Return
  Endif

  #--Updating the header totals : removing previous values
  If find(this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDSTA,5,6)>0

    [L]ARET_VALUE=fmet this.TOTAL_REMOVE_FROM_INVOICE(this.VCRINVCNDLIN(PVCRINVCNDLIN).VCRINVCNDLIN)
    If [L]ARET_VALUE>=[V]CST_AERROR
#      [L]ARET_VALUE = fmet this.ASETERROR("_GROUP_LINE_BY_QTY","Error updating header totals",[V]CST_AERROR)
      [L]ARET_VALUE = fmet this.ASETERROR("_GROUP_LINE_BY_QTY", mess(546,192,1),[V]CST_AERROR) # JUCON 20/01/17
      Return
    Endif

    #--Adding price incidence
    this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_INV_PRI=PNEWPRICE

    #--for the line (it will be taken into account)
    [L]WEXTRA_AMT  = arr(WDELTAPRICE*this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDQTY,10^(-this.CUR_DECNBR)) #TODO Revoir; il faudrait partir la facture
    #--for the LIN_EXT_QTY for the WDELTAPRICE!
    [L]WEXTRA_AMT += arr(PNEWPRICE*this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_QTY,10^(-this.CUR_DECNBR)) #TODO Revoir; il faudrait partir la facture

    this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_AMT = [L]WEXTRA_AMT

    this.VCRINVCNDLIN(PVCRINVCNDLIN).IS_EXTRABILL = [V]CST_AYES

  Endif

  If this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_AMT=0 and this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_QTY=0
    this.VCRINVCNDLIN(PVCRINVCNDLIN).IS_EXTRABILL = [V]CST_ANO
    this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_INV_PRI  = AVOID.ADEC
  Endif

  #--Updating the header totals : adding new values
  If find(this.VCRINVCNDLIN(PVCRINVCNDLIN).INVCNDSTA,5,6)>0
      [L]ARET_VALUE=fmet this.TOTAL_ADD_FROM_INVOICE(this.VCRINVCNDLIN(PVCRINVCNDLIN).VCRINVCNDLIN)
      If [L]ARET_VALUE>=[V]CST_AERROR
#        [L]ARET_VALUE = fmet this.ASETERROR("_GROUP_LINE_BY_QTY","Error updating header totals",[V]CST_AERROR)
        [L]ARET_VALUE = fmet this.ASETERROR("_GROUP_LINE_BY_QTY", mess(546,192,1),[V]CST_AERROR) # JUCON 20/01/17
        Return
      Endif
  Endif

  If WDELTAPRICE>0
    WMAXAERROR=[L]ARET_VALUE #--To prevent loosing an blocking error set before !
    [L]ARET_VALUE = max(WMAXAERROR,fmet this.ASETERROR("",mess(522,192,1)+"."-mess(520,192,1)-":"-num$(this.VCRINVCNDLIN(PVCRINVCNDLIN).LIN_EXT_AMT),[V]CST_AWARNING))
  Endif

Return
