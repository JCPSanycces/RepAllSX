#<AdxTL>@(#)2.0.0.0 $Revision$
#
#--- Programme de mise a jour de la table TANKS  / Centrale de pesée
#

Call OBJET ("TGT" , GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
When "OUVRE"             : Gosub  OUVRE
When "CREATION"          : Gosub  CREATION
When "APRES_CRE"         : Gosub  APRES_CRE
When "LIENS"             : Gosub  LIENS
When "MODIF"             : Gosub  MODIF
When "APRES_MOD"         : Gosub  APRES_MOD
When "ANNULE"            : Gosub  ANNULE
When "FILTRE"            : Gosub  FILTRE
When "DEFLIG"            : Gosub  DEFLIG
When "INICRE_LIG"        : Gosub  INILIG
When "INIMOD_LIG"        : Gosub  INILIG
When "VERIF_CRE"         : Gosub  VERIFCRE
When "CHANGE"            : Call CHANGE_AXX ("TANKS",[L]SUPP(0),[L]OCODE,[L]SUPP(0),[L]NCODE) From TRTX3TEX

 When Default
Endcase
Return
$OUVRE
Gosub DECLARE     From TABLEAUX
Return

$CREATION
Gosub CREATION    From TABLEAUX
If GOK < 1 Return Endif
#--- maj de la table des libéllés traduisibles
Call MAJTEXTRA([M:TGT0]TKSDESAXX,"TANKS","TKSDESAXX",[M:TGT0]TKS,[M:TGT0]FCY) From ATEXTRA
Call MAJTEXTRA([M:TGT0]TKSSHOAXX,"TANKS","TKSSHOAXX",[M:TGT0]TKS,[M:TGT0]FCY) From ATEXTRA

Return

$APRES_CRE
Gosub LIENS       From TABLEAUX
Return

$LIENS
Gosub LIENS       From TABLEAUX
Return

$MODIF
Gosub MODIF       From TABLEAUX
If GOK < 1 Return Endif
#--- maj de la table des libéllés traduisibles
Call MAJTEXTRA([M:TGT0]TKSDESAXX,"TANKS","TKSDESAXX",[M:TGT0]TKS,[M:TGT0]FCY) From ATEXTRA
Call MAJTEXTRA([M:TGT0]TKSSHOAXX,"TANKS","TKSSHOAXX",[M:TGT0]TKS,[M:TGT0]FCY) From ATEXTRA

Return

$APRES_MOD
Gosub LIENS       From TABLEAUX
Return

$ANNULE
Gosub ANNULE      From TABLEAUX
If GOK < 1 Return Endif
#--- maj de la table des libéllés traduisibles
Delete [AXX] Where CODFIC="TANKS" & IDENT1=[L]SUPP(0) & IDENT2=[L]CODE
If fstat=1 | fstat>5
 # FGR 12/01/2010 : X3SUIVI60986
 #GOK=0 : Call RSTA([AXX],[L]SUPP(0)-[L]CODE) From GLOCK : Return
 GOK=0 : Call RSTA("AXX",[L]SUPP(0)-[L]CODE) From GLOCK : Return
Endif
Return

$FILTRE
Default File [TKS]
Return

$DEFLIG
#Definition du fichier TGT  Affectations Cuves Vannes
#Critere de lecture      CRIT
#Nom du fichier          FICLIG
#Abreviation du fichier  ABLIG
#Zone numero de ligne    ZONLIG
Default Mask [TGT2]
Default File [TGT]
CRIT   = '[F:TGT]TGTTKS="'+[M:TGT0]TKS+'"'
FICLIG = "TANKSGATES"
ABLIG  = "TGT"
ZONLIG = "TGTLIN"
Return

$INILIG
#Alimentation Cuve
[F:TGT]TGTTKS = [F:TKS]TKS
[F:TGT]FCY    = [F:TKS]FCY

Return


$VERIFCRE
# Une vanne est unique elle ne peut etre affectee qu a une seule cuve
If GREP = "D" 

I = 0

For I = 0 To [M:TGT2]NBLIG - 1
    If [M:TGT2]TGTGTS (I) <> ""
    
       Filter [F:TGT] Where TGTGTS = [M:TGT2]TGTGTS (I)  and FCY = [M:TGT0]FCY

        For [TGT] 
        GMESSAGE = mess(1,2324,2)
        GOK = 1 
        Break
        Next 
        Filter [F:TGT]
    Endif
Next
Endif

Return


# Une vanne est unique elle ne peut etre affectee qu a une seule cuve
########################################
Subprog C_TGTGTS(VALEUR)
Variable Char    VALEUR()

Filter [F:TGT] Where TGTGTS = VALEUR   and FCY = [M:TGT0]FCY

For [TGT] 
    GMESSAGE = mess(1,2324,2)
    mkstat = 1 
    Break
Next 
Filter [F:TGT]

Local Integer I1
Local Integer I2
I2 = (nolign-1 -1)

For I1 = 0 To I2 Step 1 
    If [M:TGT2]TGTGTS (I1) = VALEUR
       GMESSAGE = mess(1,2324,2)
       mkstat = 1 
       Break
    Endif
Next I1
End

########################################
Subprog C_BOX(VALEUR)
Variable Char    VALEUR()

If clalev ([SBX])=0 : Local File STATIONBOX [SBX] : Endif   
# contrôle existence
   Read [SBX]SBX0=VALEUR;[M:TGT0]FCY
   If fstat : GMESSAGE = mess(23,100,1) : mkstat = 1 : Endif


#Controle redondance pour lieu box                        
Subprog C_PCN(VALEUR)

Variable Char    VALEUR()

Local Integer I
If VALEUR <> "" 
   For I = 0 To [M:TGT2]NBLIG - 1  Step 1
     If I <> indice  
       If [M:TGT2]BOX (I) = VALEUR and [M:TGT2]STI (I) = [F:SBX]STI
          : GMESSAGE = mess(4,2324,1) : mkstat = 1 : Break : Endif
     Endif   
 Next I
Endif
End

########################################
Subprog AM_BOX(VALEUR)
Variable Char    VALEUR()

[M:TGT2]STI(nolign-1)       = [F:SBX]STI
Affzo [M:TGT2]STI(nolign-1)
End

