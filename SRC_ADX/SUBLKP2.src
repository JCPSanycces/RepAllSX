#<AdxTL>@(#)10.0.0.0 $Revision$
##############################################
Subprog AS_NBLIG
If nolign > 0
    [M:LKP2]SELITM = [M:LKP2]CPNITMREF(nolign - 1)
Endif
End

##############################################
Subprog C_NBLIG
If nolign > 0
    [M:LKP2]SELITM = [M:LKP2]CPNITMREF(nolign - 1)
Endif
End

######################################################################################
Subprog IB_NBLIG
Local Integer ISSREOPEN
ISSREOPEN = 0
Raz GBOUT3

If [M:LKP2]CXT = "MAC"
    If [M:MAC1]MACITNTYP = 1
        If [M:MAC1]BPCNUM <> ""
            If [M:LKP2]CPNITMREF(nolign - 1) <> ""
                If [M:LKP2]SELITM <> ""
                    Call ISFUNOPEN("GESSRE", ISSREOPEN) From CRMUTIL140
                    If ISSREOPEN = 0
                        Call TEXTE(14603, GBOUT3) From OBJDIV      #Demande de service
                        [M:MAC0]CPNFORSRE = [M:LKP2]SELITM
                    Endif
                Endif
            Endif
        Endif
    Endif
Endif

End



