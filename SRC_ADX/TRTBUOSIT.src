#<AdxTL>@(#)0.0.0.0 $Revision$
###################################
#     Trt de l'état BUOSIT        #
###################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)


If clalev([CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([FCY])=0 : Local File FACILITY [FCY] : Endif


####################################################
## Récup paramètres
####################################################
Local Integer TYPETAT
Local Char    PARAM(30) , ETAT(GLONARP), NOM_ETAT(GLONARP)
Local Integer NUMREQ , LIGNE
Local Integer K,I,J

Local Char    SOCIETE(GLONCPY) , SITE(GLONFCY)

Call GETPARAM("societe",NBPAR,PARAMETRE,[L]SOCIETE) From ETAT
Call GETPARAM("site",NBPAR,PARAMETRE,[L]SITE) From ETAT

If SOCIETE<>"" & SITE=""
 Local Integer SOC,J
 Local Char LISTFCY(GLONFCY)(1..GNBSITE)
 Local Char LISTESITE(255)
 SOC=find(SOCIETE,GSOC(1..GNBSOC))
 If SOC
  J=1
  For [FCY]FCY0 Where LEGCPY=GSOC(SOC)
   LISTFCY(J)=[F:FCY]FCY
   If LISTESITE<>"" : LISTESITE += "," : Endif
   LISTESITE += [F:FCY]FCY
   J+=1
  Next
  Call SETPARAM("liste_site",NBPAR,PARAMETRE,LISTESITE) From ETAT
 Endif
Endif

Local Char DATDEB, DATFIN
Local Char EXED, EXEF
Local Libelle LEDTYPGEN,LEDTYPANA
Local Decimal EXERCICE,FIYDEB,FIYFIN
Call GETPARAM("datdeb",NBPAR,PARAMETRE,[L]DATDEB) From ETAT
Call GETPARAM("datfin",NBPAR,PARAMETRE,[L]DATFIN) From ETAT
If SOCIETE="" & SITE<>""
 Call LECTURE("FCY",SITE,"") From CONTOBJ
 SOCIETE=[F:FCY]LEGCPY
Endif
Local Date DDEB, DFIN
DDEB=[L]DATDEB
DFIN=[L]DATFIN
Call SETMAINREF(SOCIETE,LEDTYPGEN,LEDTYPANA) From CPTDIV
Call GETEXE(SOCIETE,LEDTYPANA,DDEB,EXERCICE) From CPTSUB
FIYDEB=EXERCICE
EXED=num$(FIYDEB)
Call GETEXE(SOCIETE,LEDTYPANA,DFIN,EXERCICE) From CPTSUB
FIYFIN=EXERCICE
EXEF=num$(FIYFIN)
Call SETPARAM("fiyd",NBPAR,PARAMETRE,EXED) From ETAT
Call SETPARAM("fiyf",NBPAR,PARAMETRE,EXEF) From ETAT
End
