#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIPJM201807006
# Issue X3-102495 - 2018-08-27 by FGR
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM201807006(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM201807006(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Char WOBJET(GLONAOB)
Local Integer WNBR
Local Integer B_OK

  Call ECR_TRACE("UTIPJM201807006: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".AOBJET"  [AOB]
  Raz COMPTEUR
  #
  For WOBJET="CTA"
    Read [AOB]ABREV=WOBJET
    If !fstat Then
      If [F:AOB]TYPGES <> 4 Then
        # Pas de fenêtre pour les browsers
        Call VALID("O" + WOBJET, DOSSIER, 1, B_OK) From VALWIN
        If B_OK <> 1 Then
          Call ECR_TRACE("Error during window validation O" + WOBJET, 1) From GESECRAN
        Endif
      Endif
      #
      COMPTEUR += 1
    Endif
  Next WOBJET

  # -----------------
  Call ECR_TRACE("UTIPJM201807006 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","AOBJET","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AOBJET") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM201807006(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If filinfo(filpath("FIL","AOBJET","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AOBJET") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM201807006(APPLI)
End

