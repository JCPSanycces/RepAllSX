#<AdxTL>@(#)3.0.0.0 $Revision$
Raz GPILOBJ,GNBMASKOUV
Local Char PARAM(10)(1..3) , VALEUR(10)
PARAM(1) = "TESYCO1" : #"TABCOUNTRY"
Call TRAITE_CHAR(VALEUR,PARAM,"","ABIIMP","ABIIMP",4,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "GAU"         : Gosub GAU
 When "SVG"         : Gosub SVG
 When "PRG"         : Gosub PRG
 When "FIR"         : Gosub PREMIER
 When "LAS"         : Gosub DERNIER
 When "PRE"         : Gosub PRECEDENT
 When "SUI"         : Gosub SUIVANT
 When "HLP"         : Gosub HLP
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_MODIF" : Gosub APRES_MODIF
Endcase
Return

##############################################
## GTRAITE
##############################################
$INIT
Local Mask ABIIMP [RPT]
Return

##############################################
## GSAISIE
##############################################
$OUVRE
Local Char ETAT(GLONABO)
Gosub OUVFIC
Return

$OUVFIC
If clalev([F:ABO])=0 : Local File ABIREPORT  [ABO] : Endif
If clalev([F:ABQ])=0 : Local File ABIREPORTD [ABQ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE      [ATY] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV    [ADI] : Endif
If clalev([F:ARX])=0 : Local File AREPORTX   [ARX] : Endif
If clalev([F:ARV])=0 : Local File AREPORTV   [ARV] : Endif
If clalev([F:ACC])=0 : Local File ACCES      [ACC] : Endif
If clalev([F:ACV])=0 : Local File ACTIV      [ACV] : Endif
Return

$DEBUT
Raz [M]
ETAT = PARAM(1)
[M]ETAT = ETAT
If [M]ETAT<>""
 Gosub CHARGE
 Diszo COD
Else
 Actzo COD
 Gosub REMPLIT From GSAISIE
 Raz [F:ABO]
Endif
Return

$FILGAUCHE
FILGAUSUP = '[F:ABO]ENAFLG=2 & [F:ACC]EXEC=2'
Return

$SVG
$PRG
If [M]ETAT<>""
 FOK = 0
Endif
Return

$GAU
ETAT = [F:ABO]COD
If !func AFNC.ACTIV([F:ABO]ACV) : Call ERREUR( mess(3,135,1)) From GESECRAN : Raz [M] : Affzo : Return : Endif
Gosub CHARGE
Return

$HLP
Hlpbox "ABO_"+[M]COD
Return

$APRES_MODIF
Case zoncou
 When "COD"
  ETAT = zc
  If !func AFNC.ACTIV([F:ABO]ACV) : Call ERREUR( mess(3,135,1)) From GESECRAN : Raz [M] : Affzo : Return : Endif
  Gosub CHARGE
Endcase
Return

$CHARGE
Call CHANGE_COD(ETAT)
Affzo
Return

$SETBOUT
Raz GBIDC1,GBIDC2,GBIDC3,GBIDI1,GBIDI2
Call VARPSEBO(GUSER,GBIDC1,GBIDC2,GBIDC3,GBIDI1,GBIDI2) From GESUSER
If !GBIDI2 & GFUSION=0
 Call VIREBOUT(CHMEN,"0123") From GOBJET
 Return
Endif
Raz CHBOU,CHMEN
If [M]ETAT=""
 CHBOU += "09"
 If [M]COD<>""
  CHBOU += "<>"
 Endif
Endif
If [M]COD<>""
 CHMEN += "0123"
Endif
Return

$PREMIER
Read [ABO]ABO0 First
If !func AFNC.ACTIV([F:ABO]ACV) : Call ERREUR( mess(3,135,1)) From GESECRAN : Raz [M] : Affzo : Return : Endif
If fstat<=2 : ETAT = [F:ABO]COD : Gosub CHARGE : Endif
Return

$DERNIER
Read [ABO]ABO0 Last
If !func AFNC.ACTIV([F:ABO]ACV) : Call ERREUR( mess(3,135,1)) From GESECRAN : Raz [M] : Affzo : Return : Endif
If fstat<=2 : ETAT = [F:ABO]COD : Gosub CHARGE : Endif
Return

$SUIVANT
Read [ABO]ABO0 > [M]COD
If !func AFNC.ACTIV([F:ABO]ACV) : Call ERREUR( mess(3,135,1)) From GESECRAN : Raz [M] : Affzo : Return : Endif
If fstat<=2 : ETAT = [F:ABO]COD : Gosub CHARGE : Endif
Return

$PRECEDENT
Read [ABO]ABO0 < [M]COD
If !func AFNC.ACTIV([F:ABO]ACV) : Call ERREUR( mess(3,135,1)) From GESECRAN : Raz [M] : Affzo : Return : Endif
If fstat<=2 : ETAT = [F:ABO]COD : Gosub CHARGE : Endif
Return

######################################################################################
Subprog CHANGE_COD(ETAT)
Value Char ETAT

Local Char    TYPFMT(20) , OPTFMT(20) , CHFMT(50) , NUMFMT(10)
Local Integer LNGFMT , I , ERR , OKACS , NOL ,STAT
Local Char    VALS(250),VALS2(250),VALS3(250)

Raz [M]
Read [ABO]ABO0 = ETAT

[M]COD = ETAT
Call TEXTE([F:ABO]DES,[M]DES) From OBJDIV

# Chargement des paramètres
nolign = 0
For [ABQ]ABQ0 Where COD=ETAT & DAC=2
 If [F:ABQ]PARACS<>""
  Call LECACC([F:ABQ]PARACS,OKACS) From SUBACS
 Else
  OKACS = 1
 Endif
 If OKACS
  nolign += 1
  [M] = [F:ABQ]
  NOL = nolign-1
  If [F:ABQ]INTEVAL <> ""
   Onerrgo
   [M]PARDES(NOL) = evalue([F:ABQ]INTEVAL)
   Onerrgo
  Else
   Call TEXTE([F:ABQ]TEX,[M]PARDES(NOL)) From OBJDIV
  Endif
  Call LECTURE("ATY",[F:ABQ]TYP,"") From CONTOBJ
  [M]TYPTYP(NOL)   = [F:ATY]TYPTYP
  [M]OBJET(NOL)    = [F:ATY]OBJLIEN
  If [F:ABQ]TYP="ADI"
   [M]MENLOC(NOL) = [F:ABQ]TABDIV
  Endif

  LNGFMT = [M]LNG(NOL)
  If LNGFMT=0
   LNGFMT = [F:ATY]LNGTYP
  Endif
  Call FORMA(20,[M]TYPTYP(NOL),LNGFMT,[M]MENLOC(NOL),[F:ATY]OPTION,[F:ATY]FORTYP
&           ,TYPFMT,OPTFMT,CHFMT,NUMFMT) From SUBFMT
  If [F:ATY]TYPTYP=1
   [M]FMT(NOL) = "Nzf:3#"
  Elsif [F:ATY]TYPTYP=8
   [M]FMT(NOL) = TYPFMT+OPTFMT+"Zz:"+CHFMT
  Else
   [M]FMT(NOL) = TYPFMT+OPTFMT+"z:"+CHFMT
  Endif
  If left$([M]FMT(NOL),1)="="
   If mid$([M]FMT(NOL),2,2)='"K' or mid$([M]FMT(NOL),2,2)="'K"
    [M]FMT(NOL)    = "K:30X"
    [M]LONG(NOL)   = 30
   Else
    Onerrgo RIEN
    ERR = 0
    [M]FMT(NOL) = evalue(right$([M]FMT(NOL),2))
    Onerrgo
    If ERR
     [M]FMT(NOL)    = "K:30X"
     [M]LONG(NOL)   = 30
    Endif
   Endif
  Endif
  If [M]TYPBO(NOL) <> 2
   If [F:ABQ]VALDEF<>""
    Call EVALE([F:ABQ]VALDEF,[M]VALEUR1(NOL),[F:ATY]TYPTYP)
   Elsif [F:ATY]TYPTYP=1
    [M]VALEUR1(NOL) = "1"
   Endif
  Else
   If [F:ABQ]VALDEF<>""
     VALS = [F:ABQ]VALDEF
     J=instr(1,VALS,";")
     While J
      VALS2 = left$(VALS,J-1)
      VALS  = right$(VALS,J+1)
      Call EVALE(VALS2,VALS3,[F:ATY]TYPTYP)
      If [M]VALEURS(NOL) = ""
       [M]VALEURS(NOL) = VALS3
      Else
       [M]VALEURS(NOL) += ";"+VALS3
      Endif
      J=instr(1,VALS,";")
     Wend
     Call EVALE(VALS,VALS3,[F:ATY]TYPTYP)
     If [M]VALEURS(NOL) = ""
      [M]VALEURS(NOL) = VALS3
     Else
      [M]VALEURS(NOL) += ";"+VALS3
     Endif
   Elsif [F:ATY]TYPTYP=1
    [M]VALEURS(NOL) = "1"
   Endif
  Endif
 Endif
Next
[M]NBRPAR = nolign

## Dates par défaut

For I=1 To [M]NBRPAR
 If [M]TYPTYP(I-1)=8
  If [M]VALEUR1(I-1)=""
   If find([M]STREND(I-1),1,2)
    If GDATEDEB<>[0/0/0]
     [M]VALEUR1(I-1) = format$("D:"+GFMDAT4,GDATEDEB)
    Else
     [M]VALEUR1(I-1) = format$("D:"+GFMDAT4,gdat$(1,1,year(datesyst)))
    Endif
   Else
    If GDATEFIN<>[0/0/0]
     [M]VALEUR1(I-1) = format$("D:"+GFMDAT4,GDATEFIN)
    Else
     [M]VALEUR1(I-1) = format$("D:"+GFMDAT4,gdat$(31,12,year(datesyst)))
    Endif
   Endif
  Endif
 Endif
Next I

# Mémo

Call LECMEMO([M:RPT]COD,"bo","STD") From ABIIMP4

# Si imprime via menu et parmetrage dans ARX
If dim(GFCTIMP)>0 & GFCTIMP<>""
 For I=0 To [M]NBRPAR-1
  If [M]TYPBO(I) <> 2
   Read[ARV]ARV0 = [V]GFCTIMP;[V]GTYPIMP;ETAT;num$(I+1)
   If !fstat
    If [M]TYPBO(I) <> 2
     [M]VALEUR1(I) = [F:ARV]VALDEF1
     If [F:ARV]VALDEF1<>""
      Call EVALE([F:ARV]VALDEF1,[M]VALEUR1(I),[M]TYPTYP(I))
     Endif
    Else
     [M]VALEURS(I) = [F:ARV]VALDEF1
    Endif
   Endif
  Endif
 Next
Endif

# Init valint
For I=0 To [M]NBRPAR-1
 If [M]TYPBO(I) <> 2
  Call CHARGE([M]VALEUR1(I),[M]TYP(I),[M]MENLOC(I),[M]LNG(I),[M]VALINT1(I)) From FMTVAR
 Else
  VALS = [M]VALEURS(I)
  Raz [M]VALEURS(I),[M]VALINT1(I)
  J=instr(1,VALS,";")
  While J
   VALS2 = left$(VALS,J-1)
   VALS  = right$(VALS,J+1)
   Call CHARGE(VALS2,[M]TYP(I),[M]MENLOC(I),[M]LNG(I),VALS3) From FMTVAR
   If [M]VALEURS(I) = ""
    [M]VALINT1(I) = VALS3
    [M]VALEURS(I) = VALS2
   Else
    [M]VALINT1(I) += ";"+VALS3
    [M]VALEURS(I) += ";"+VALS2
   Endif
   J=instr(1,VALS,";")
  Wend
  Call CHARGE(VALS,[M]TYP(I),[M]MENLOC(I),[M]LNG(I),VALS3) From FMTVAR
  If [M]VALEURS(I) = ""
   [M]VALINT1(I) = VALS3
   [M]VALEURS(I) = VALS
  Else
   [M]VALINT1(I) += ";"+VALS3
   [M]VALEURS(I) += ";"+VALS
  Endif
 Endif
Next I
End

$RIEN
Resume

Subprog EVALE(EXPRESSION,RESULTAT,TYP)
Value    Char    EXPRESSION
Variable Char    RESULTAT()
Value    Integer TYP
If left$(EXPRESSION,6)="PARAM("
 Local Char PARAM(10)
 PARAM = vireblc(toupper(seg$(EXPRESSION,7,len(EXPRESSION)-1)),2)
 Call PARAM("",PARAM,RESULTAT) From ADOVAL
Else
 Onerrgo RIEN
 If TYP=8
  RESULTAT = evalue(EXPRESSION)
 Else
  RESULTAT = num$(evalue(EXPRESSION))
 Endif
 Onerrgo
Endif
End

######################################################################################
## Ecran ABIIMP
######################################################################################
Subprog C_VALEUR1(VALEUR)
Variable Char    VALEUR()
Gosub CONT1
End

$CONT1
Local Char    VALCONT(250)
Local Integer OK
VALCONT = [M]VALINT1(nolign-1)
If [M]OBJET(nolign-1)<>"" & [M]STREND(nolign-1)<2
 Local Char SUPP(10)
 If [M]OBJET(nolign-1)="ADI"
  SUPP = num$([M]MENLOC(nolign-1))
 Elsif [M]PAR(nolign-1)<>""
  SUPP = num$(evalue([M]PAR(nolign-1)))
 Endif
  Call CONTROLE([M]OBJET(nolign-1),"!$"+[M]OPT(nolign-1),VALCONT,SUPP,mkstat) From CONTOBJ
  If mkstat : Return : Endif
Endif
Case [M]TYPTYP(nolign-1)
 When 1         : Local Integer VALPAR      : VALPAR = val(VALCONT)
 When 2,3,4,5,6 : Local Decimal VALPAR      : VALPAR = val(VALCONT)
 When 7         : Local Char    VALPAR(250) : VALPAR = VALCONT
 When 8         : Local Date    VALPAR      : VALPAR = gdat$(VALCONT)
Endcase
If [M]CTL(nolign-1)<>""
 Call EVALCONT(OK,[M]CTL(nolign-1),VALPAR)
 If !OK
  GMESSAGE = mess(7,135,1) : # Valeur incorrecte
  mkstat = 2 : Return
 Endif
Endif
If [M]TABDIV(nolign-1)<>0 & [M]OBJET(nolign-1)="ADI" & VALCONT<>"" & [M]STREND(nolign-1)<2
Read [ADI]CODE = [M]TABDIV(nolign-1);VALCONT
 If fstat
  GMESSAGE = mess(7,135,1) : # Valeur incorrecte
  mkstat = 2 : Return
 Endif
Endif
Return

Subprog EVALCONT(OK,EXPRESSION,VALEUR)
Variable Integer OK
Value    Char    EXPRESSION
Onerrgo RIEN
OK = evalue(EXPRESSION)
Onerrgo
End

Subprog AS_VALEUR1(VALEUR)
Variable Char    VALEUR()
If [M]TYPBO(nolign-1)  = 2
 mkstat = 1
Endif
End

Subprog AS_VALEURS(VALEUR)
Variable Char    VALEUR()
If [M]TYPBO(nolign-1)  <> 2
 mkstat = 1
Endif
End

Subprog C_VALEURS(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" : [M]VALINT1(nolign-1)  = "" : End  : Endif
Local Char VALINT2(250),VALEUR2(250),VALEUR3(250)
Local Integer J
VALEUR3 = VALEUR
[M]VALINT1(nolign-1) = ""
J = instr(1,VALEUR3,";")
While J
 VALEUR2 = left$(VALEUR3,J-1)
 VALEUR3 = right$(VALEUR3,J+1)
 VALINT2= VALEUR2
 Call CONTROLE(VALEUR2,[M]TYP(nolign-1),[M]MENLOC(nolign-1),[M]LNG(nolign-1),VALINT2) From FMTVAR
 If mkstat : GERR = 1 : GZONE = "VALEURS" : GZNUM = 122 :  Endif
 If [M]VALINT1(nolign-1) = ""
  [M]VALINT1(nolign-1) = VALINT2
  VALEUR = VALEUR2
 Else
  [M]VALINT1(nolign-1) += ";"+VALINT2
  VALEUR += ";"+VALEUR2
 Endif
 J = instr(1,VALEUR3,";")
Wend
Call CONTROLE(VALEUR3,[M]TYP(nolign-1),[M]MENLOC(nolign-1),[M]LNG(nolign-1),VALINT2) From FMTVAR
If mkstat : GERR = 1 : GZONE = "VALEURS" : GZNUM = 122 :  Endif
If [M]VALINT1(nolign-1) = ""
 [M]VALINT1(nolign-1) = VALINT2
 VALEUR = VALEUR3
Else
 [M]VALINT1(nolign-1) += ";"+VALINT2
 VALEUR += ";"+VALEUR3
Endif
End

Subprog S_VALEURS(VALEUR)
Variable Char    VALEUR()
Local Char    PARMSK(250)(1..20) , SAVACT(20), VALEUR2(250)
PARMSK(1) = [M]TYP(nolign-1)
PARMSK(2) = num$([M]MENLOC(nolign-1))
PARMSK(3) = num$([M]LNG(nolign-1))
PARMSK(4) = [M]VALINT1(nolign-1)
PARMSK(5) = [M]PAR(nolign-1)
PARMSK(6) = [M]PARCTL(nolign-1)
PARMSK(7) = ""
Call S_TAB_CHAR(VALEUR2,PARMSK,"","FMTVAR","") From GACTION
Call S_LIS_CHAR(VALEUR2,PARMSK,"","FMTVAR","") From GACTION
If VALEUR = ""
 VALEUR = VALEUR2
 [M]VALINT1(nolign-1) = PARMSK(4)
Else
 If instr(1,VALEUR,VALEUR2) : End : Endif
 VALEUR = VALEUR +";"+ VALEUR2
 [M]VALINT1(nolign-1) += ";"+ PARMSK(4)
Endif
End

Subprog IB_VALEURS
If [M]OBJET(nolign-1) = "" & [M]MENLOC(nolign-1) =0
 GBOUTS = ""
Endif
End

Subprog C_COD(VALEUR)
Variable Char    VALEUR()
Local Integer STAT
Call CONT_COD(VALEUR,GMESSAGE,STAT)
mkstat = STAT
End

Subprog CONT_COD(VALEUR,MESSAGE,STAT)
Value    Char    VALEUR
Variable Char    MESSAGE
Variable Integer STAT
Raz STAT , MESSAGE
Read [ABO]ABO0 = VALEUR
If fstat
 MESSAGE = mess(6,135,1) : # Etat inexistant
 STAT = 2 : End
Elsif [F:ABO]ENAFLG<>2
 MESSAGE = mess(17,135,1)-VALEUR+"\"+mess(2,126,1) : # Etat x\Fiche inactive
 STAT = 2 : End
Else
 Local Integer OK
 OK = 1
 If [F:ABO]ACV<>""
  Read [ACV]CODACT=[F:ABO]ACV
  If fstat or [F:ACV]FLACT<>2
   OK = 0
  Endif
 Endif
 If OK
  Call VERF_DROIT(VALEUR,GUSER,OK,[M]AUTSIT)
 Endif
 If !OK
  MESSAGE = mess(3,135,1) : # Vous n'avez pas accès à cet état
  STAT = 2 : End
 Endif
Endif
End

Subprog VERF_DROIT(ETAT,USER,OK,AUTSIT)
Value    Char    ETAT
Value    Char    USER
Variable Integer OK
Variable Char    AUTSIT()
Local    Integer I , USRACC(1..2)
Local    Char    FONCIMP(GLONAFC)
If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
If filinfo(filpath("FIL","AMETUTI","fde"),0)>0
 If clalev([F:AME])=0 : Local File AMETUTI [AME] : Endif
Endif
If clalev([F:AFT])=0 : Local File AFCTFCT [AFT] : Endif
Call LECTURE("AUS",USER,"") From CONTOBJ
If [F:AUS]PRFFCT="" & clalev([F:AME])>0
 Read [AME]AME0 = [F:AUS]CODMET
 Call LECTURE("AFT",[F:AME]PRFFCT,"") From CONTOBJ
Else
 Call LECTURE("AFT",[F:AUS]PRFFCT,"") From CONTOBJ
Endif
If clalev([F:ABO])=0 : Local File ABIREPORT [ABO] : Endif

Read [ABO]ABO0 = ETAT
If fstat : OK = 0 : End : Endif

# Code d'accès
mkstat = 0
Call CONTEXE([F:ABO]ACS) From SUBACS
If mkstat : OK = 0 : End : Endif

# Accès à toutes les fonctions (AUTSIT ne sert plus à rien à 140)
If [F:AFT]ALLFCT=2 : AUTSIT = "*" : OK = 1 : End : Endif

# Verif par rapport au filtre
If GFILTETAT<>""
 If !pat(ETAT,GFILTETAT) : OK = 0 : End : Endif
Endif

OK = 1
End




######################################################################################
