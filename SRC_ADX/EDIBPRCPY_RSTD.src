###############################################################################
# Representation Class EDIBPRCPY                                              #
# Author : RBA + JUCON                                                        #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
         When "AQUERY_TRANS_AFTER"    : Gosub AQUERY_TRANS_AFTER
      Endcase
    When "EBC"
      Case [L]AEVENT
        When "AREAD_AFTER"           : Gosub EBC_AREAD_AFTER
      Endcase
    When "EBC.EBCD"
      Case [L]AEVENT
        When "AREAD_AFTER"           : Gosub EBC_EBCD_AREAD_AFTER
      Endcase
  Endcase
Return
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Return

#####################################################################

#********************************************************************
# Method AQUERY_TRANS_AFTER
#********************************************************************
#* Goal:
#*!
$AQUERY_TRANS_AFTER
  Local Integer WOK
  Local Char WBPRNAM(35)
  WOK = func EDILIBB.GET_BPRNAM(this.EBC.BPRNUM, WBPRNAM)
  this.EBC.BPRNAM = WBPRNAM
  this.EBC.CPYNAM = fmet this.ACTX.ACACHE.ACPY.AGETVALCHAR(this.EBC.CPY,"CPYNAM")
  this.EBC.PARDES = fmet this.ACTX.ACACHE.EPR.AGETVALCHAR(this.EBC.PARCOD,"PARDES")
Return

$EBC_AREAD_AFTER
  Local Integer WOK
  Local Char WBPRNAM(35)
  WOK = func EDILIBB.GET_BPRNAM(this.BPRNUM, WBPRNAM)
  this.BPRNAM = WBPRNAM
  this.PARDES = fmet this.ACTX.ACACHE.EPR.AGETVALCHAR(this.PARCOD,"PARDES")
  this.CPYNAM = fmet this.ACTX.ACACHE.ACPY.AGETVALCHAR(this.CPY,"CPYNAM")
Return

$EBC_EBCD_AREAD_AFTER
  this.CATDES = fmet this.ACTX.ACACHE.ECA.AGETVALCHAR(this.CATCOD,"CATDES")
  this.FLODES = fmet this.ACTX.ACACHE.EFL.AGETVALCHAR(this.FLOCOD,this.FLOREL,"FLODES")
  this.FLGACT = fmet this.ACTX.ACACHE.EFL.AGETVALNUM(this.FLOCOD,this.FLOREL,"FLGACT")
  Local Integer WCATOPE # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
  WCATOPE = fmet this.ACTX.ACACHE.ECA.AGETVALNUM(this.CATCOD,"CATOPE")
  If WCATOPE = 0
    this.CATOPE = 2 #Create
  Else
    this.CATOPE = WCATOPE
  Endif
Return

