#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Classe OPPOR
###################################################################################################
# COMmon SUBROUTINES
###################################################################################################
Funprog COPY_ATEXTRA_TRANSLATED(SLAN, SCODFIC, SZONE, SORITXT, SORIIDENT1, SORIIDENT2, SDESTXT, SDESIDENT1, SDESIDENT2)
Value Char SLAN
Value Char SCODFIC
Value Char SZONE
Value Char SORITXT
Value Char SORIIDENT1
Value Char SORIIDENT2
Value Char SDESTXT
Value Char SDESIDENT1
Value Char SDESIDENT2

Local Integer ARENDRE
Local Integer IADXLOG

  ARENDRE = [V]CST_AOK
  # -----------------------
  If SORITXT = SDESTXT Then
    # If target text is the same than the original one
    # ----------------
    Local File ATEXTRA [AXX]
    Local File ATEXTRA [AX1]
    # ----------------
    IADXLOG = adxlog
    If !IADXLOG Then
      Trbegin [F:AX1]
    Endif
    # ----------------
    Filter [AXX] Where [F:AXX]CODFIC = SCODFIC and [F:AXX]ZONE = SZONE and [F:AXX]IDENT1 = SORIIDENT1 and [F:AXX]IDENT2 = SORIIDENT2 and [F:AXX]LANGUE <> SLAN
    For [F:AXX]
      [F:AX1] = [F:AXX]
      [F:AX1]IDENT1 = SDESIDENT1
      [F:AX1]IDENT2 = SDESIDENT2
      Write [F:AX1]
      If fstat Then
        ARENDRE = [V]CST_AERROR
        Break
      Endif
    Next
    Filter [AXX]
    # ----------------
    If !IADXLOG Then
      If ARENDRE >= [V]CST_AERROR Then
        Rollback
      Else
        Commit
      Endif
    Endif
  Endif
  # -----------------------
End ARENDRE

###################################################################################################
Funprog GET_PIMDESAXX(SPIMNUM)
Value Char SPIMNUM

Local Char SARENDRE(80)

  Raz ZARENDRE
  Local File PIMPL [PIM]
  Read [PIM]PIM0=SPIMNUM
  If !fstat Then
    Call LECTEXTRA(SARENDRE, "PIMPL", "PIMDESAXX", [F:PIM]PIMNUM, "") From ATEXTRA
  Endif
End SARENDRE

###################################################################################################
Funprog GET_DEF_SITE_PROFIL(CTX, IMODULE)
Variable Instance CTX Using OBJECT
Value Integer IMODULE

Local Char SARENDRE(GLONFCY)

  Raz SARENDRE
  If IMODULE >= 1 Then
    # ----------------------------
    Local File AFCTFCT [AFT]
    # ----------------------------
    Read [AFT]AFT0=CTX.APRFCOD
    If fstat Then
      Raz [F:AFT]
    Endif
    # ----------------------------
    SARENDRE = [F:AFT]FCYDEF(IMODULE-1)
    # ----------------------------
  Endif
End SARENDRE

###################################################################################################
Funprog GET_CUR_VALUE(ACTX, SOPPNUM, SMESSAGE)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value Char SOPPNUM
Variable Char SMESSAGE

Local Char SARENDRE(GLONCPY)

  Raz SARENDRE
  Raz SMESSAGE
  If SOPPNUM = AVOID.ACHAR Then
    SMESSAGE = mess(9,135,1)
  Else
    Local File OPPOR [OPP]
    Read [OPP]OPP0=SOPPNUM
    If fstat Then
      SMESSAGE = mess(243,107,1) - SOPPNUM
    Else
      SARENDRE = [F:OPP]CUR
    Endif
  Endif
End SARENDRE

###################################################################################################
Funprog GET_PROPERTY_TITLE(CTX, SPRO)
Variable Instance CTX Using OBJECT
Value Char SPRO

Local Char SARENDRE(GLONDES)
Local Char SREQ(250)(0..)
Local Integer IREQ
Local Char STYPDBA(GLONVCR)

  # Issue X3-85933 - 2018-06-19 by FGR :
  Raz SARENDRE
  If SPRO <> AVOID.ACHAR and CTX <> null Then
    Raz SREQ
    IREQ = -1
    STYPDBA = num$((fmet CTX.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, CTX.ACTX.AFOLDER, "TYPDBA") * 2) + 1)
    IREQ += 1 : SREQ(IREQ) -= "SELECT ATX.TEXTE_0"
    IREQ += 1 : SREQ(IREQ) -= "FROM ACLAFLD ACLAF, ATEXTE ATX"
    IREQ += 1 : SREQ(IREQ) -= "WHERE ACLAF.CODCLA_0 = '" + mid$(CTX.ObjectType,3,len(CTX.ObjectType)) + "'"
    IREQ += 1 : SREQ(IREQ) -= "  AND ACLAF.FLDCLA_0 = '" + SPRO + "'"
    IREQ += 1 : SREQ(IREQ) -= "  AND ATX.NUMERO_0 = ACLAF.INTFLD_0"
    IREQ += 1 : SREQ(IREQ) -= "  AND ATX.LAN_0 = '" + CTX.ACTX.LAN + "'"
    For (Char SFIELD(GLONDES)) From STYPDBA Sql SREQ As [WWW]
      SARENDRE = func AFNC.MES2(mess(1094,2260,1), SPRO, [F:WWW]SFIELD)
    Next
    If SARENDRE = AVOID.ACHAR Then
      SARENDRE = SPRO
    Endif
  Endif
End SARENDRE

