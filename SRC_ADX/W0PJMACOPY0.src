#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMACOPY0 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone OPPNUM
mkstat = 0
zoncou = "OPPNUM"
indice = 0
WCHAR = [M]OPPNUM
If varmode([M]OPPNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "OPPNUM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]OPPNUM,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 1886 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("PIM","A",[M]OPPNUM,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 1886 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WCHAR<>[M]OPPNUM or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_OPPNUM([M]OPPNUM) From SUBPJMACOPY
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "OPPNUM" : GZNUM = 1886 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone OPPSTATE
mkstat = 0
zoncou = "OPPSTATE"
indice = 0
IMPENT = [M]OPPSTATE
If varinit([M]OPPSTATE,indice)=0
 IMPENT = 1
Endif
[M]OPPSTATE = IMPENT

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone CRMFLG
mkstat = 0
zoncou = "CRMFLG"
indice = 0
IMPENT = [M]CRMFLG
WNUM = IMPENT
If varinit([M]CRMFLG,indice)=0
 IMPENT = 1
Endif
If varmode([M]CRMFLG,indice)=0
 [M]CRMFLG(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "CRMFLG" : Gosub ACTION From =IMPTRT
  IMPENT = [M]CRMFLG(indice)
 Endif
 If WNUM<>IMPENT or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_CRMFLG(IMPENT) From SUBPJMACOPY
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CRMFLG" : GZNUM = 1002876 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif
[M]CRMFLG = IMPENT

## Zone CRMOPP
mkstat = 0
zoncou = "CRMOPP"
indice = 0
SAVACT = GACTION : GACTION = "STD"
Call AV_CRMOPP([M]CRMOPP) From SUBPJMACOPY
GACTION = SAVACT
If mkstat=1 : Raz [M]CRMOPP : Endif
If !mkstat
 If varmode([M]CRMOPP,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "CRMOPP" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]CRMOPP,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "CRMOPP" : GZNUM = 1002877 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("PIM","D",[M]CRMOPP,"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "CRMOPP" : GZNUM = 1002877 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call AP_CRMOPP([M]CRMOPP) From SUBPJMACOPY
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CRMOPP" : GZNUM = 1002877 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone DESTAFF
mkstat = 0
zoncou = "DESTAFF"
indice = 0
If varmode([M]DESTAFF,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DESTAFF" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "STD"
 Call AP_DESTAFF([M]DESTAFF) From SUBPJMACOPY
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "DESTAFF" : GZNUM = 55983 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone DESDES
mkstat = 0
zoncou = "DESDES"
indice = 0
If varmode([M]DESDES,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DESDES" : Gosub ACTION From =IMPTRT
 Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PJMACOPY0"
Return

