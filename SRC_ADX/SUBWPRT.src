#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
 When "OUVRE" : Gosub OUVRE
 When "OK"    : Gosub OK
 When "IMPRIME"  : Gosub IMPRIME
Endcase
Return

######################################################################################
$OUVRE
Local Char WPRN
Local Char ETAT_RPT (20)   # 90424 mm 12.2013

If clalev([M:WPRT]) = 0 : Local Mask IWEIPRT [WPRT] : Endif
If clalev([F:WGG]) = 0 : Local File WEIGHING [WGG] : Endif
If clalev([F:MFM]) = 0 : Local File MFGMAT [MFM] : Endif
If clalev([F:HSH]) = 0 : Local File HANDLING [HSH] : Endif
If clalev([F:HSR]) = 0 : Local File HANDLINGR [HSR] : Endif
If clalev([F:CTN]) = 0 : Local File CONTAINERS [CTN] : Endif

#Affectation du mask avec les paramètres
[M:WPRT]MFGNUM = PARAM(1)
[M:WPRT]BOMOPE = val(PARAM(2))
[M:WPRT]ITMREF = PARAM(3)
[M:WPRT]MFGLIN = val(PARAM(4))
[M:WPRT]BOMSEQ = val(PARAM(5))
[M:WPRT]CBTDAT = num$(PARAM(6))
[M:WPRT]MVTSEQ = val(PARAM(7))

#On fixe le nombre d'exemplaires à 1 par défaut
[M:WPRT]NBPRINT = 1

# Lecture de WEIGHING
Read [WGG]WGG0=[M:WPRT]MFGNUM;[M:WPRT]BOMOPE;[M:WPRT]ITMREF;[M:WPRT]MFGLIN;[M:WPRT]BOMSEQ;[M:WPRT]CBTDAT;[M:WPRT]MVTSEQ
If fstat
  Raz [WGG]
Endif
[M:WPRT]WEIWEI = [F:WGG]WEIWEI
[M:WPRT]STU = [F:WGG]STU

# Lecture de MFGMAT
Read [MFM]MFM0=[M:WPRT]MFGNUM;[M:WPRT]MFGLIN;[M:WPRT]BOMSEQ;[M:WPRT]ITMREF
If fstat
  Raz [MFM]
Endif
[M:WPRT]MFMTRKFLG = [F:MFM]MFMTRKFLG
[M:WPRT]TRKFIRST = [F:MFM]TRKFIRST

# la référence de l'état est donnée par le couple ISM/récipient
# Lecture de la fiche ISM
Read [HSH]HSH0=[F:WGG]ISM
If fstat : Raz [HSH] :Endif

# Lecture du récipient
Read [CTN]CTN0=[F:WGG]USECTN
If fstat :  Raz [CTN]  : Endif

# 90424 mm 12.2013
# Lecture de la fiche ISM récipient
Filter [HSR] Where HSH = [F:WGG]ISM & WEU = [F:CTN]CTNWEU & CTN= [F:CTN]CTN
  Read [HSR]HSR0 First
Filter [HSR]
If fstat : Raz [HSR] : Endif

# 90424 mm 12.2013
ETAT_RPT =[F:HSH]LBECTS          # Contenu étiquette fiche ISM
If [F:HSR]LBEFMT <> ""
  ETAT_RPT += [F:HSR]LBEFMT          # Format étiquette fiche ISM
Else
  ETAT_RPT +=  [F:CTN]CTNLBEFMT     # Format étiquette récipient
Endif
# si rien de spécial paramétré on prend GWEIRPTETI
If ETAT_RPT = "" & GWEIRPTETI<> ""
   ETAT_RPT = GWEIRPTETI
Endif
[M:WPRT]RPTCOD =ETAT_RPT

#Fermeture des tables
Close Local File [WGG]
Close Local File [MFM]
Close Local File [HSH]
Close Local File [CTN]

Return

######################################################################################
$OK
Local Integer PRINTSEQ
Local Char TBPAR(30)(1..50),TBVAL(30)(1..50)
Local Integer NBPAR
Local Char WVALEUR

PRINTSEQ=0
# on lit la table des impression d'étiquettes pour récupérer le bon nombre
If clalev([F:WGP]) = 0 : Local File WEIGHPRT [WGP] : Endif
Filter [WGP] Where MFGNUM=[M:WPRT]MFGNUM and
&                  BOMOPE=[M:WPRT]BOMOPE and
&                  ITMREF=[M:WPRT]ITMREF and
&                  MFGLIN=[M:WPRT]MFGLIN and
&                  BOMSEQ=[M:WPRT]BOMSEQ and
&                  CBTDAT=[M:WPRT]CBTDAT and
&                  MVTSEQ=[M:WPRT]MVTSEQ
PRINTSEQ=rowcount([WGP])+1
Trbegin [WGP]
Raz [F:WGP]
[F:WGP]MFGNUM = [M:WPRT]MFGNUM
[F:WGP]BOMOPE = [M:WPRT]BOMOPE
[F:WGP]ITMREF = [M:WPRT]ITMREF
[F:WGP]MFGLIN = [M:WPRT]MFGLIN
[F:WGP]BOMSEQ = [M:WPRT]BOMSEQ
[F:WGP]CBTDAT = [M:WPRT]CBTDAT
[F:WGP]MVTSEQ = [M:WPRT]MVTSEQ
[F:WGP]CREDAT = date$
[F:WGP]CRETIM = time
[F:WGP]CREUSR = GUSER
[F:WGP]PRTSEQ = PRINTSEQ
[F:WGP]NBPRINT = [M:WPRT]NBPRINT
[F:WGP]PRT = [M:WPRT]PRT
[F:WGP]RPTCOD = [M:WPRT]RPTCOD
[F:WGP]PRTREASON = [M:WPRT]PRTREASON

Write[WGP]
If fstat
 Rollback
Else
 Commit
Endif
Raz GBIDI1
NBPAR = 0

# 90424 mm 12.2013
NBPAR+=1 : TBPAR(NBPAR) = "BOMOPE" : TBVAL(NBPAR)= num$([M:WPRT]BOMOPE)
NBPAR+=1 : TBPAR(NBPAR) = "ITMREF" : TBVAL(NBPAR)= [M:WPRT]ITMREF
NBPAR+=1 : TBPAR(NBPAR) = "MFGLIN" : TBVAL(NBPAR)= num$([M:WPRT]MFGLIN)
NBPAR+=1 : TBPAR(NBPAR) = "BOMSEQ" : TBVAL(NBPAR)= num$([M:WPRT]BOMSEQ)
NBPAR+=1 : TBPAR(NBPAR) = "CBTDAT" : TBVAL(NBPAR)= [M:WPRT]CBTDAT
NBPAR+=1 : TBPAR(NBPAR) = "MVTSEQ" : TBVAL(NBPAR)= num$([M:WPRT]MVTSEQ)
NBPAR+=1 : TBPAR(NBPAR) = "MFGNUM" : TBVAL(NBPAR)= [M:WPRT]MFGNUM
NBPAR+=1 : TBPAR(NBPAR) = "REEDIT" : TBVAL(NBPAR)= num$(2)

NBPAR+=1 : TBPAR(NBPAR) = "_printercopies" : TBVAL(NBPAR)=  num$([M:WPRT]NBPRINT)
If [M:WPRT]NBPRINT
  For I = 1 To [M:WPRT]NBPRINT
    Call ETAT([M:WPRT]RPTCOD,[M:WPRT]PRT,"",0,"",TBPAR,TBVAL) From AIMP3
      If I = 1
       # Mise à jour de [WGG] -> étiquette imprimée ou ré-imprimée
       Gosub MAJ_WGG
      Endif
  Next I
Endif

Return

######################################################################################
$MAJ_WGG
# 90424 mm 12.2013 - Mise à jour de [WGG]


Call DEBTRANS From GLOCK
Trbegin [WGG]
# Lecture de WEIGHING
Readlock [WGG]WGG0=[M:WPRT]MFGNUM;[M:WPRT]BOMOPE;[M:WPRT]ITMREF;[M:WPRT]MFGLIN;[M:WPRT]BOMSEQ;[M:WPRT]CBTDAT;[M:WPRT]MVTSEQ
If fstat=1     GOK=-1 : GLOCK="$WGG"- [M:WPRT]MFGNUM : Goto AB_ETIPESEE
Elsif fstat GOK=0  : Call RSTA("WGG", [M:WPRT]MFGNUM) From GLOCK : Goto AB_ETIPESEE
Endif

#flag etiquette pesée ré-imprimée
If [F:WGG]LBEPRNCOD = 2
    [F:WGG]LBEPRNCOD = 3
Elsif [F:WGG]LBEPRNCOD = 3
    [F:WGG]LBEPRNCOD = 4
Endif

Rewrite [F:WGG]
If fstat : Goto AB_ETIPESEE
Else
    Commit
Endif

Return

######################################################################################
$AB_ETIPESEE
Rollback
Return


######################################################################################
$IMPRIME
Return

# Gestion du masque IWEIPRT

######################################################################################
## Etiquette ajoutée par le superviseur (écran IWEIPRT) 09/02/2011 11:05:55 (GBE)
######################################################################################
Subprog AM_NBPRINT(VALEUR)
Variable Decimal VALEUR
End


######################################################################################
