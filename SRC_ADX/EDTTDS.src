#<AdxTL>@(#)10.0.0.0 $Revision$

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
Call EDTTDS(NBPAR,PARAMETRE)
End

######################################################################
Subprog EDTTDS(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Raz fstat
Gosub OUVRE
Lock EDTTDS
If fstat : GOK = 0 : Goto SORTIE : Endif

Gosub DECLARE
For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  If [L]PARAM = "nomfic" : NOMFIC = [L]VALEUR
  Endif
 Endif
Next

I = instr(1,NOMFIC,".")
If I
 FICH = left$(NOMFIC,I-1)
 EXT  = right$(NOMFIC,I+1)
Else
 FICH = NOMFIC
 EXT=""
Endif
NOMFIC = "[BQE]/"+FICH : If EXT<>"" : NOMFIC += "."+EXT : Endif
SOURCE = "[BQE]/"+FICH+"X" :  : If EXT<>"" : SOURCE += "."+EXT : Endif
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
If func ASYRSTO.CTL_VOLFIL(2, NOMFIC, NOMFIC, E_TYPE_FILEREAD, GMESSAGE)<>0
 Call ERREUR(NOMFIC-mess(101,100,1)) From GESECRAN : # Fichier inexistant
 GOK = 0
 Goto SORTIE
Endif
If func ASYRSTO.CTL_VOLFIL(2, SOURCE, SOURCE, E_TYPE_FILEREAD, GMESSAGE)<>0
 Call ERREUR(SOURCE-mess(101,100,1)) From GESECRAN : # Fichier inexistant
 GOK = 0
 Goto SORTIE
Endif
If EXT="TDS"
 DIMFIL = 188
 Local Schar    FILLER(DIMFIL)(3) : # Enreg TDS de 564 (3*188)
Elsif EXT="TDB"
 DIMFIL = 224
 Local Schar    FILLER(DIMFIL)(3) : # Enreg TDS Bilatérale de 672 (3*224)
Endif
Gosub CHARGE_TAB

$SORTIE
Unlock EDTTDS
End

$CHARGE_TAB
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

Call DEBTRANS From GLOCK

Trbegin [ETD]
 Delete [ETD] Where 1=1
 If fstat=1 | fstat>5
  GOK=-1 : Call RSTA("ETD","") From GLOCK : Goto ABANDON
 Endif
 Raz fstat, [L]RECTYP, OLDRECTYP, P, DEBORD
 While fstat=0                     : # fstat<>0 quand fin de fichier NOMFIC
  adxifs = chr$(9)
  adxirs = chr$(10)
  Openi SOURCE,P(0)
  Rdseq [L]RECTYP, NBREC
  P(0) = adxseek(0)
  For J=1 To NBREC
   Raz LNGDEB
   If EXT="TDS"
    Filter [TFT] Where COD="TDS" & RECTYP=[L]RECTYP
   Else
    Filter [TFT] Where COD="TDSBI" & RECTYP=[L]RECTYP
   Endif
   Read [TFT]First
   adxifs = ""
   adxirs = ""
   Openi NOMFIC,P(1)
   For I=0 To 2
    Getseq 1, FILLER(I)
    P(1) = adxseek(0)
    LG = 1
    While LG<=DIMFIL & fstat=0      : # fstat<>0 quand fin de fichier TFT
     Gosub ECR_ETD
     If !GOK : Goto ABANDON : Endif
     If LG+[F:TFT]LNG-LNGDEB>DIMFIL : # La zone est à cheval sur 2 fillers
      LNGDEB = DIMFIL-(LG-1)
      LG +=[F:TFT]LNG
      Read [TFT]Prev
     Else
      If LNGDEB<>0
       LG +=[F:TFT]LNG -LNGDEB
       LNGDEB = 0
      Else
       LG +=[F:TFT]LNG
      Endif
     Endif
     Read [TFT]Next
    Wend
   Next I
  Next J
 Wend
Commit
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Return

$ECR_ETD
# siret et siren sont les premières zones des enregistrements
If OLDRECTYP<>[L]RECTYP             : # Nouvel enregistrement
 OLDRECTYP = [L]RECTYP
 Raz [F:ETD]
 Case [F:TFT]RECTYP
  When 1  : # Drapeau début
   [F:ETD]SIREN = string$(9,"0")
   [F:ETD]CRN   = string$(14,"0")
  When 2  : # Entête entreprise
   [F:ETD]SIREN = mid$(FILLER(I),LG,[F:TFT]LNG)
   [F:ETD]CRN   = string$(14,"0")
  When 3  : # Entête établissement
   [F:ETD]SIREN = mid$(FILLER(I),LG,[F:TFT]LNG)
   [F:ETD]CRN   = mid$(FILLER(I),LG,[F:TFT]LNG)
  When 4  : # Lignes honoraires
   [F:ETD]SIREN = mid$(FILLER(I),LG,[F:TFT]LNG)
   [F:ETD]CRN   = mid$(FILLER(I),LG,[F:TFT]LNG)
  When 5  : # Total établissement
   [F:ETD]SIREN = mid$(FILLER(I),LG,[F:TFT]LNG)
   [F:ETD]CRN   = mid$(FILLER(I),LG,[F:TFT]LNG)
  When 6  : # Total entreprise
   [F:ETD]SIREN = mid$(FILLER(I),LG,[F:TFT]LNG)
   [F:ETD]CRN   = string$(14,"9")
  When 7  : # Drapeau fin
   [F:ETD]SIREN = string$(9,"9")
   [F:ETD]CRN   = string$(14,"9")
 Endcase
Endif
[F:ETD]NUMLIN = J
[F:ETD]RECTYP = [F:TFT]RECTYP
[F:ETD]NUM    = [F:TFT]NUM
[F:ETD]DES    = [F:TFT]DESLIN
If (LG-1) + [F:TFT]LNG > DIMFIL
 DEBORD = 1
 [F:ETD]VALTDS = right$(FILLER(I),LG)
Else
 If DEBORD = 1
  [F:ETD]VALTDS +=mid$(FILLER(I),LG,[F:TFT]LNG-LNGDEB)
  DEBORD = 0
 Else
  [F:ETD]VALTDS = mid$(FILLER(I),LG,[F:TFT]LNG-LNGDEB)
 Endif
Endif
If !DEBORD
 Write [ETD]
 If fstat
  GOK = 0
  Call FSTA("ETD") From GLOCK
 Endif
Endif
Return

$ABANDON
Rollback
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Return

$OUVRE
Local File EDTTDS[ETD], TABFILTDS[TFT]
Return

$DECLARE
Local Shortint J
Local Integer  I, LNGDEB, RECTYP, OLDRECTYP
Local Integer  DIMFIL              : # Enreg TDS de 564 (3*188)
Local Integer  P(2)                : # Position courante des fichiers SOURCE et NOMFIC
Local Integer  NBREC               : # Nombre d'enregistrements de même TYPREC
Local Integer  DEBORD              : # Flag de débordement d'1 zone sur 2 fillers
Local Char     NOMFIC(GDIMFIC)
Local Char     SOURCE(GDIMFIC)
Local Char     FICH(250)
Local Char     EXT(5)
Local Char     PARAM(30)
Local Char     VALEUR(250)
Local Char     SAVIFS(5),SAVIRS(5) :# Bug 20475    -  CC 30/12/2003
Local Integer SAVIUM
Return
