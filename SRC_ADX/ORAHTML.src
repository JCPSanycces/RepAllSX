#<AdxTL>@(#)0.0.0.0 $Revision$
# DĂŠclarations
Local Char MODELE(20)
Local File HLP
Local Integer I
Local Char TEXTE_HTML(255)
Local Integer LIST_OPEN : # vaut 1 si <LI> ouvert
Local Integer NEW_PARA  : # vaut 1 si un nouveau paragraphe a ĂŠtĂŠ ouvert
Local Char REPERT_ORI(100),REPERT_DES(100),FICHIER_CONFIG(100),REPERT_BASE(100)

# A modifier selon le cas
# Si des chemin absolu sont mis, il sont respectĂŠs par le Call INIT
# Sinon, les chemins sont relatifs par rapport Ă  REPERT_BASE
# Si REPERT_BASE est vide, il est renseignĂŠ par le Call INIT
REPERT_BASE=""
REPERT_ORI="hl1"
REPERT_DES="hlp"  : # InutilisĂŠ
FICHIER_CONFIG="" : # InutilisĂŠ

Call INIT(REPERT_BASE,REPERT_ORI,REPERT_DES,FICHIER_CONFIG) From DEFHTML

# vide pour tout faire, sinon mettre le nom Ă  revalider
  MODELE=""

# Initialisations
  adxirs=chr$(13)+chr$(10) : # Pour produire du texte MS-DOS
  If MODELE="" : MODELE="1" : Else MODELE="MOTCLE='"+MODELE+"'": Endif

# La boucle sur les fichiers d'aide
  For [AID]MOTCLE(1) Where evalue(MODELE)
    Call TEMPON("Traitement"- MOTCLE) From GESECRAN
    Openo REPERT_ORI+"/"+MOTCLE+".htm",0
    Call WRITE_HEADER
    For [AID]MOTCLE
    If TEXTE=" " | TEXTE=""
      If LIST_OPEN>0
        While LIST_OPEN>0
          Call CLOSE_LIST : LIST_OPEN-=1
        Wend
      Elsif NEW_PARA
        Call CLOSE_PARAGRAPH : Call OPEN_PARAGRAPH
      Else
        NEW_PARA=1
      Endif
    Else
      If NEW_PARA
        Call CLOSE_PARAGRAPH : Call OPEN_PARAGRAPH
        NEW_PARA=0
      Endif
      If left$(vireblc(TEXTE,0),1)="-" & pat(TEXTE,"*-----*")=0
        If LIST_OPEN=0
          Call OPEN_LIST : LIST_OPEN=1
          Call TRANSCODE(right$(vireblc(TEXTE,0),2),TEXTE_HTML)
        Elsif LIST_OPEN=1
          If left$(vireblc(TEXTE,0),2)="--"
            Call OPEN_LIST : LIST_OPEN=2
            Call TRANSCODE(right$(vireblc(TEXTE,0),3),TEXTE_HTML)
          Else
            Call TRANSCODE(right$(vireblc(TEXTE,0),2),TEXTE_HTML)
          Endif
        Elsif LIST_OPEN=2
          If left$(vireblc(TEXTE,0),2)<>"--"
            Call CLOSE_LIST : LIST_OPEN=1
            Call TRANSCODE(right$(vireblc(TEXTE,0),2),TEXTE_HTML)
          Else
            Call TRANSCODE(right$(vireblc(TEXTE,0),3),TEXTE_HTML)
          Endif
        Endif
        Call LIST_LINE
        Wrseq TEXTE_HTML
      Else
        Call TRANSCODE(vireblc(TEXTE,0),TEXTE_HTML)
        Wrseq TEXTE_HTML
      Endif
    Endif
  Next
  Call WRITE_FOOTER
  Openo
  Call TEMPOFF From GESECRAN
# I+=1 : Break mod(I,20) = 0
Next
End

Subprog TRANSCODE(T1,T2)
Value Char T1() : Variable Char T2()
Local Char CHAI
Local Char T3(255),TEXTE_CLE(255)
  If ctrans(T1)=T1
    T3=T1
  Else
    T3=""
    For I=1 To len(T1)
      CHA=mid$(T1,I,1)
      Case CHA
        When "ĂŠ" : T3+="&"+ctrans(CHA)+"acute;"
        When "Ă ","Ă¨","Ăš" : T3+="&"+ctrans(CHA)+"grave;"
        When "Ă˘","ĂŞ","Ăť","ĂŽ","Ă´" : T3+="&"+ctrans(CHA)+"circ;"
        When "Ă¤","ĂŤ","Ăź","ĂŻ","Ăś" : T3+="&"+ctrans(CHA)+"uml;"
        When "Ă§" : T3+="&ccedil;"
        When "<" : T3+="&lt;"
        When ">" : T3+="&gt;"
        When '"' : T3+="&quot;"
        When "&" : T3+="&amp;"
        When Default : T3+=CHA
      Endcase
    Next I
  Endif


  I=instr(1,T3,"\")
  I=0 : # Rajout Dom : les backshlashes restent...
  If I=0 : T2=T3 : End : Endif
  T2=""
  While I
    T2=left$(T3,I-1) : T3=right$(T3,I+1)
    I=instr(1,T3,"\")
    If I=0 : # un seul backshash : on ignore !
      T2+=T3 : Break
    Endif
    TEXTE_CLE=left$(T3,I-1) : T3=right$(T3,I+1)
    I=instr(1,T3,"\")
    If I=0 : # deux backshlashes : on ignore aussi !
      T2+=TEXTE_CLE+T3 : Break
    Endif
    T2+='<a href="'+tolower(left$(T3,I-1))+'.rtf">'+TEXTE_CLE+"</a>"
    T3=right$(T3,I+1)
    I=instr(1,T3,"\")
  Wend
  T2+=T3
End

Subprog WRITE_HEADER
 Wrseq "<HTML>"
 Wrseq "<HEAD>"
 Wrseq '<META HTTP-EQUIV="Content-Type" CONTENT="text/html; charset=windows-1252">'
 Wrseq '<META NAME="Generator" CONTENT="Microsoft Word 97">'
 Wrseq '<TITLE>Aide en ligne'-MOTCLE-'X3</TITLE>'
 Wrseq '</HEAD>'
 Wrseq '<BODY>'
 Call OPEN_PARAGRAPH
End

Subprog OPEN_PARAGRAPH
 Wrseq '<FONT FACE="Comic Sans MS" SIZE=3 COLOR="#000000"><P ALIGN="JUSTIFY">'
End

Subprog CLOSE_PARAGRAPH
 Wrseq '</P>'
End

Subprog WRITE_FOOTER
 Wrseq "</P></FONT></BODY></HTML>"
End

Subprog OPEN_LIST
  Wrseq "<UL>"
End

Subprog LIST_LINE
  Wrseq "<LI>"
End

Subprog CLOSE_LIST
  Wrseq "</UL>"
End
