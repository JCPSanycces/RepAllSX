$_GET_RES_STRING
Local Char RES(250)
Case _LAN
 When "FRA":
  Case _ID
   When 57064: RES='Codes type import bancaire'
   When 57065: RES='Code type banque'
   When 7475: RES='Banque'
  Endcase
 When "ENG":
  Case _ID
   When 57064: RES='Bank import type codes'
   When 57065: RES='Bank type code'
   When 7475: RES='Bank'
  Endcase
 When "ITA":
  Case _ID
   When 57064: RES='Codes type import bancaire'
   When 57065: RES='Code type banque'
   When 7475: RES='Banca'
  Endcase
 When "POR":
  Case _ID
   When 57064: RES='Cód. tipo importação banc.'
   When 57065: RES='Cód. tipo banco'
   When 7475: RES='Banco'
  Endcase
 When "SPA":
  Case _ID
   When 57064: RES='Códigos tipo import. bancaria'
   When 57065: RES='Código tipo banco'
   When 7475: RES='Banco'
  Endcase
 When "BRI":
  Case _ID
   When 57064: RES='Bank import type codes'
   When 57065: RES='Bank type code'
   When 7475: RES='Bank'
  Endcase
 When "GER":
  Case _ID
   When 57064: RES='Bankimporttypcodes'
   When 57065: RES='Banktypcode'
   When 7475: RES='Bank'
  Endcase
 When "POL":
  Case _ID
   When 57064: RES='Kody typów importu bankowego'
   When 57065: RES='Kod typu bankowwgo'
   When 7475: RES='Bank'
  Endcase
 When "CHI":
  Case _ID
   When 57064: RES='银行导入类型代码'
   When 57065: RES='银行类型代码'
   When 7475: RES='银行'
  Endcase
 When "ARB":
  Case _ID
   When 57064: RES='Codes type import bancaire'
   When 57065: RES='Code type banque'
   When 7475: RES='البنك'
  Endcase
Endcase
Return
