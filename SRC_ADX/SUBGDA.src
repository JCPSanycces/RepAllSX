#<AdxTL>@(#)1.0.0.0 $Revision$
Call OBJET("GDA",GBIDC1,GBIDC2) From GOBJET
End

$ACTION

Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "LIENS"       : Gosub LIENS
 When "GAUCHE"      : Gosub GAUCHE
 When "SETBOUT"     : Gosub SETBOUT
 When "RAZCRE"      : Gosub RAZCRE
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "ANNULE"      : Gosub ANNULE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "AP_CHANGE"   : Gosub AP_CHANGE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
Endcase
Return


$INICRE
$INIMOD
If dim([F:GDA]DES)>0
 [F:GDA]DES = [M:GDA1]DESTRA
Endif
Return

$OUVRE
If clalev([F:GDC])=0 : Local File GDIAACCD [GDC] : Endif
If clalev([F:COA])=0 : Local File GCOA     [COA] : Endif
If clalev([F:DIE])=0 : Local File GDIE     [DIE] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER [BPR] : Endif

Local Integer M, N, C, S, X, NOLI, NUMCOA
Return

$OUVRE_BOITE
Local Integer BROWGAC
Local Char    BOXGAC(10)
BROWGAC = find("GAC", OBJLIS(1..8)) : BOXGAC = "GAU_CHE"+num$(BROWGAC)
Return

$LIENS
Local Char INTIT(250)
Gosub INIFMT_ACC
Gosub INIFMT_CCE
N=0
For [GDC]GDC0 Where DIA=[M]DIA
 [M]DSP(N) = [F:GDC]DSP
 [M]COE(N) = [F:GDC]COE
 For M=1 To dim([M:GDA1]COA)
  Assign "[M]ACC"+num$(M)+"("+num$(N)+")" With evalue("[F:GDC]ACC("+num$(M-1)+")")
 Next
 For M=1 To dim([M:GDA1]DIE)
  Assign "[M]CCE"+num$(M)+"("+num$(N)+")" With evalue("[F:GDC]CCE("+num$(M-1)+")")
 Next
 [M]BPR(N)    = [F:GDC]BPR
 [M]VAT(N)    = [F:GDC]VAT
 [M]LIGDES(N) = [F:GDC]LIGDES
 N+=1
Next
[M]NBRACC = N

Call LECTEXTRA([M:GDA1]DESTRA,"GDIAACC","DESTRA",[M:GDA1]DIA,"") From ATEXTRA
Call LECTEXTRA([M:GDA1]SHOTRA,"GDIAACC","SHOTRA",[M:GDA1]DIA,"") From ATEXTRA
Return

$GAUCHE
Case currbox
 When BOXGAC
  # récupérer la longueur des champs ACC* du masque (type GAC)
  If [M]NBRACC<dim([M]ACC)
   OK = 0
   Case REP
    When "C","M","D"
     OK = 1
    When ""
     If CLECUR & VERROU & ACTMOD & !GCONSULT
      OK = 1
     Endif
   Endcase
   If OK
    mkstat = 0
    nolign = [M]NBRACC+1
    Read [GAC]GAC0 = [F:GAC]COA;[F:GAC]ACC
    If mkstat
     OK = 0
    Endif
   Endif
   If OK
    [M]ACC1([M]NBRACC) = [F:GAC]ACC
    Read [GAC]GAC0=[M]COA(0);[M]ACC1([M]NBRACC)
    Local Integer R
    For N=0 To dim([GAC]OTHCOA)-1
     If [GAC]OTHCOA(N)="" : Break : Endif
     R=find([GAC]OTHCOA(N), [M]COA)
     If R<>0 # trouvé !
      Assign "[M]ACC"+num$(R)+"("+num$([M]NBRACC)+")" With [GAC]DEFACC(N)
     Endif
    Next
    [M]NBRACC += 1
    Affzo
    If REP=""
     Gosub ENTRE_MODIF From GOBJSUB
    Endif
   Endif
  Endif
Endcase
Return

$SETBOUT
If CLECUR
 Local Integer OKACC
 Call LECACC([F:GDA]ACS,OKACC) From CPTSUB
 If !OKACC
  Call VIREBOUT(CHAINE,"MAH") From GOBJET
 Endif
Endif
Return

$RAZCRE
[M]COANBR=0
[M]NBRDIE=0
INTIT=""
FMT="-K:10X"
For N=1 To dim([M]COA)
 Gosub INTIT_ACC
Next
For N=1 To dim([M]DIE)
 Gosub INTIT_CCE
Next
zoncou="NBRACC" # nécessaire pour déclencher l'affichage/masquage des colonnes dans $CHG_FMT From W1GDA1
If !GIMPORT
 Gosub CHG_FMT From W1GDA1
Endif
Affzo 30
Return

$VERIF_CRE
Gosub VERIF
Return

$VERIF_MOD
Gosub VERIF
Return

$VERIF
OK=1
If [M]COANBR=0
 # Au moins un code plan doit être renseigné
 OK = 0 :  GMESSAGE = mess(131,107,1) : Return
Endif
If [M]NBRACC=0
 # Il doit y avoir au moins une ligne
 OK = 0 : GMESSAGE = mess(178,123,1) : Return
Endif
If !OK : Return : Endif
For NOLI=0 To [M]NBRACC-1
 X = 0
 For NUMCOA=1 To [M]COANBR
  If evalue("[M]ACC"+num$(NUMCOA)+"("+num$(NOLI)+")")<>"" : X+=1 : Endif
 Next
 If X=0
  ## Ligne X : Vous devez définir au moins un compte par ligne
  OK = 0 : GMESSAGE = mess(3,61,1)-num$(NOLI+1)-":"-mess(106,104,1) : Break
 Endif
Next
If !OK : Return : Endif
Return


$ANNULE
Delete [GDC]GDC0=[M:GDA1]DIA
If fstat=1
 GOK = -1 : Call RSTA("GDC",[GDA1]DIA) From GLOCK : Return
Endif

Call SUPTEXTRA("GDIAACC","DESTRA",[M:GDA1]DIA,"") From ATEXTRA
Call SUPTEXTRA("GDIAACC","SHOTRA",[M:GDA1]DIA,"") From ATEXTRA
Return

$CREATION
For N=1 To [M]NBRACC
 Raz [F:GDC]
 [F:GDC]DIA    = [M]DIA
 [F:GDC]LINNUM = N
 [F:GDC]DSP    = [M]DSP(N-1)
 [F:GDC]COE    = [M]COE(N-1)
 For M=1 To dim([M:GDA1]COA)
  Assign "[F:GDC]ACC("+num$(M-1)+")" With evalue("[M]ACC"+num$(M)+"("+num$(N-1)+")")
 Next
 For M=1 To dim([M:GDA1]DIE)
  Assign "[F:GDC]CCE("+num$(M-1)+")" With evalue("[M]CCE"+num$(M)+"("+num$(N-1)+")")
 Next
 [F:GDC]BPR    = [M]BPR(N-1)
 [F:GDC]VAT    = [M]VAT(N-1)
 [F:GDC]LIGDES = [M]LIGDES(N-1)
 Write [F:GDC]
 If fstat
  GOK = 0 : Call FSTA("GDC") From GLOCK : Break
 Endif
Next
If GOK<1 : Return : Endif

Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$MODIF
Delete [GDC] Where DIA=[M]DIA
If fstat=1
 GOK = -1 : Call RSTA("GDC",[M:GDA1]DIA) From GLOCK : Return
Endif
For N=1 To [M]NBRACC
 Raz [F:GDC]
 [F:GDC]DIA    = [M]DIA
 [F:GDC]LINNUM = N
 [F:GDC]DSP = [M]DSP(N-1)
 [F:GDC]COE = [M]COE(N-1)
 For M=1 To dim([M:GDA1]COA)
  Assign "[F:GDC]ACC("+num$(M-1)+")" With evalue("[M]ACC"+num$(M)+"("+num$(N-1)+")")
 Next
 For M=1 To dim([M:GDA1]DIE)
  Assign "[F:GDC]CCE("+num$(M-1)+")" With evalue("[M]CCE"+num$(M)+"("+num$(N-1)+")")
 Next
 [F:GDC]BPR    = [M]BPR(N-1)
 [F:GDC]VAT    = [M]VAT(N-1)
 [F:GDC]LIGDES = [M]LIGDES(N-1)
 Write [F:GDC]
 If fstat
  GOK = 0 : Call FSTA("GDC") From GLOCK : Break
 Endif
Next
If GOK<1 : Return : Endif

Gosub TEXTRA
If GOK<1 : Return : Endif
Return


$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GDIAACC","DESTRA",CLECUR1,"","GDIAACC","DESTRA",[M:GDA1]DIA,"")  From ATEXTRA
 Call DUPTEXTRA("GDIAACC","SHOTRA",CLECUR1,"","GDIAACC","SHOTRA",[M:GDA1]DIA,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M:GDA1]DESTRA,"GDIAACC","DESTRA",[M:GDA1]DIA,"") From ATEXTRA
Call MAJTEXTRA([M:GDA1]SHOTRA,"GDIAACC","SHOTRA",[M:GDA1]DIA,"") From ATEXTRA
Return

$AP_CHANGE
#Call CHGTEXTRA("GDIAACC","DESTRA",[M:GDA1]DIA,"",NCODE,"") From ATEXTRA
#Call CHGTEXTRA("GDIAACC","SHOTRA",[M:GDA1]DIA,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("GDIAACC","DESTRA",OCODE,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("GDIAACC","SHOTRA",OCODE,"",NCODE,"") From ATEXTRA
Return

$FILGAUCHE
If [M]COANBR<>0
 FILGAUSUP(0) = 'COA="'+[M]COA(0)+'"'
Else
 FILGAUSUP(0) = ""
Endif
Return

$APRES_MODIF
Case COUZON
 When "COA"
  If indice = 0
   Gosub REMPLIT From GOBJSUB
  Endif
Endcase
Return


$INIFMT_ACC
Local Integer COANBR
[L]COANBR=[M]COANBR
# affichage des colonnes
For N=1 To [L]COANBR
 If [M]COA(N-1)<>""
  # lecture du format
  Call INIACCFMT([M]COA(N-1)) From SETGLBCOA
  FMT = "K:"+GFMTACC
  Call LECTEXTRA(INTIT,"GCOA","COLHEA",[M]COA(N-1),"") From ATEXTRA
 Else
  INTIT = ""
 Endif
 Gosub INTIT_ACC
Next
# masquage des colonnes restantes...
INTIT=""
FMT = "-K:10X"
For N=[L]COANBR+1 To dim([M]COA)
 Gosub INTIT_ACC
Next
Return

$INIFMT_CCE
Local Integer DIENBR
[L]DIENBR=[M]NBRDIE
# affichage des colonnes
For N=1 To [L]DIENBR
 If [M]DIE(N-1)<>""
  # lecture du format
  Call INICCEFMT([M]DIE(N-1)) From SETGLBDIE
  FMT = "K:"+GCCEFMT
  Call LECTEXTRA(INTIT,"GDIE","COLHEA",[M]DIE(N-1),"") From ATEXTRA
 Else
  INTIT = ""
 Endif
 Gosub INTIT_CCE
Next
# masquage des colonnes
INTIT=""
FMT = "-K:10X"
For N=[L]DIENBR+1 To dim([M]DIE)
 Gosub INTIT_CCE
Next
Return

$INTIT_ACC
If GIMPORT : Return : Endif
If INTIT=""
 For L=0 To [M]NBRACC-1
  Assign "[M:GDA1]ACC"+num$(N)+"("+num$(L)+")" With ''
 Next
Endif
Case N
 When 1 : Titcol [M]NBRACC INTIT For ACC1
 When 2 : Titcol [M]NBRACC INTIT For ACC2
 When 3 : Titcol [M]NBRACC INTIT For ACC3
 When 4 : Titcol [M]NBRACC INTIT For ACC4
 When 5 : Titcol [M]NBRACC INTIT For ACC5
 When 6 : Titcol [M]NBRACC INTIT For ACC6
 When 7 : Titcol [M]NBRACC INTIT For ACC7
 When 8 : Titcol [M]NBRACC INTIT For ACC8
 When 9 : Titcol [M]NBRACC INTIT For ACC9
Endcase
If FMT<>"" : Assign "[M:GDA1]FMTACC"+num$(N) With FMT : Endif
Return

$INTIT_CCE
If GIMPORT : Return : Endif
If INTIT=""
 For L=0 To [M]NBRACC-1
  Assign "[M:GDA1]CCE"+num$(N)+"("+num$(L)+")" With ''
 Next
Endif
Case N
 When 1  : Titcol [M]NBRACC INTIT For CCE1
 When 2  : Titcol [M]NBRACC INTIT For CCE2
 When 3  : Titcol [M]NBRACC INTIT For CCE3
 When 4  : Titcol [M]NBRACC INTIT For CCE4
 When 5  : Titcol [M]NBRACC INTIT For CCE5
 When 6  : Titcol [M]NBRACC INTIT For CCE6
 When 7  : Titcol [M]NBRACC INTIT For CCE7
 When 8  : Titcol [M]NBRACC INTIT For CCE8
 When 9  : Titcol [M]NBRACC INTIT For CCE9
 When 10 : Titcol [M]NBRACC INTIT For CCE10
 When 11 : Titcol [M]NBRACC INTIT For CCE11
 When 12 : Titcol [M]NBRACC INTIT For CCE12
 When 13 : Titcol [M]NBRACC INTIT For CCE13
 When 14 : Titcol [M]NBRACC INTIT For CCE14
 When 15 : Titcol [M]NBRACC INTIT For CCE15
 When 16 : Titcol [M]NBRACC INTIT For CCE16
 When 17 : Titcol [M]NBRACC INTIT For CCE17
 When 18 : Titcol [M]NBRACC INTIT For CCE18
 When 19 : Titcol [M]NBRACC INTIT For CCE19
 When 20 : Titcol [M]NBRACC INTIT For CCE20
Endcase
If FMT<>"" : Assign "[M:GDA1]FMTCCE"+num$(N) With FMT : Endif
Return


##################################################################
# Etiquettes masque GDA1
##################################################################
Subprog AM_COA(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]COA) From OBJDIV
If mkstat : End : Endif
If [M]OCOA<>""
 Case nolign
  When 1 : Raz [M]ACC1
  When 2 : Raz [M]ACC2
  When 3 : Raz [M]ACC3
  When 4 : Raz [M]ACC4
  When 5 : Raz [M]ACC5
  When 6 : Raz [M]ACC6
  When 7 : Raz [M]ACC7
  When 8 : Raz [M]ACC8
  When 9 : Raz [M]ACC9
 Endcase
Endif
End

Subprog AM_DIE(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]DIE) From OBJDIV
If mkstat : End : Endif
If [M]ODIE<>""
 Case nolign
  When 1  : Raz [M]CCE1
  When 2  : Raz [M]CCE2
  When 3  : Raz [M]CCE3
  When 4  : Raz [M]CCE4
  When 5  : Raz [M]CCE5
  When 6  : Raz [M]CCE6
  When 7  : Raz [M]CCE7
  When 8  : Raz [M]CCE8
  When 9  : Raz [M]CCE9
  When 10 : Raz [M]CCE10
  When 11 : Raz [M]CCE11
  When 12 : Raz [M]CCE12
  When 13 : Raz [M]CCE13
  When 14 : Raz [M]CCE14
  When 15 : Raz [M]CCE15
  When 16 : Raz [M]CCE16
  When 17 : Raz [M]CCE17
  When 18 : Raz [M]CCE18
  When 19 : Raz [M]CCE19
  When 20 : Raz [M]CCE20
 Endcase
Endif
End

Subprog AVANT_COANBR
[M]OCOA = [M]COA(nolign-1)
End

Subprog APRES_COANBR
Local Integer COANBR
If status=65 # annulation de ligne
 Call DECALE([M]COANBR, "ACC", 1)
 [L]COANBR=[M]COANBR-1
 Gosub AFFCOA
 Affzo
Elsif find(status,1,71) # ajout/insertion ou modif de ligne
 If [M]OCOA='' # ajout/insertion de ligne
  Call DECALE([M]COANBR, "ACC", 2)
  If nolign>[M]COANBR
   [L]COANBR=[M]COANBR+1
  Else
   [L]COANBR=[M]COANBR
  Endif
  Gosub AFFCOA
  zoncou = "NBRACC"
  Gosub CHG_FMT From W1GDA1
 Else # modif de ligne
  [L]COANBR=[M]COANBR
  Gosub AFFCOA
 Endif
 Affzo
Endif
End

Subprog AVANT_NBRDIE
[M]ODIE = [M]DIE(nolign-1)
End

Subprog APRES_NBRDIE
Local Integer DIENBR
If status=65 # annulation de ligne
 Call DECALE([M]NBRDIE, "CCE", 1)
 [L]DIENBR=[M]NBRDIE-1
 Gosub AFFDIE
 Affzo
Elsif find(status,1,71) # ajout/insertion ou modif de ligne
 If [M]ODIE='' # ajout/insertion de ligne
  Call DECALE([M]NBRDIE, "CCE", 2)
  If nolign>[M]NBRDIE
   [L]DIENBR=[M]NBRDIE+1
  Else
   [L]DIENBR=[M]NBRDIE
  Endif
  Gosub AFFDIE
  zoncou = "NBRACC"
  Gosub CHG_FMT From W1GDA1
 Else # modif de ligne
  [L]DIENBR=[M]NBRDIE
  Gosub AFFDIE
 Endif
 Affzo
Endif
End

Subprog B1_NBRDIE
Local Integer DIENBR
Local Char DIE(GLONDIE)
#Call DIELOAD('') From CPTBOUT
# Pré-chargement des axes selon la liste des codes plan croisés avec les référentiels.
For I=1 To GLEDNBR
 If find(GLEDCOA(I),[M]COA(0..[M]COANBR-1))
  For J=1 To GLEDDIENBR(I)
   DIE = evalue("GDIE"+num$(J)-"("+num$(I)+")")
   If !find(DIE,[M]DIE(0..dim([M]DIE)-1))
    [M]DIE([M]NBRDIE) = DIE
    [M]NBRDIE += 1
   Endif
   If [M]NBRDIE>=dim([M]DIE) : Break 2 : Endif
  Next
 Endif
Next 
[L]DIENBR = [M]NBRDIE
status=1
Gosub AFFDIE
zoncou = "NBRACC"
Gosub CHG_FMT From W1GDA1
Affzo
End

$AFFCOA
Local Char INTIT(250)
For N=1 To [L]COANBR
 # lecture du format
 If status=65 and N>=nolign # annulation d'une ligne
  Call LECTEXTRA(INTIT,"GCOA","COLHEA",[M]COA(N),"") From ATEXTRA
  Call INIACCFMT([M]COA(N)) From SETGLBCOA
 Elsif (status=71 or status=73) and N>=nolign # ajout/insertion d'une ligne
  If N-1>=0 #and N<>nolign
   Call LECTEXTRA(INTIT,"GCOA","COLHEA",[M]COA(N-1),"") From ATEXTRA
  Else
   INTIT=""
  Endif
  Call INIACCFMT([M]COA(N-1)) From SETGLBCOA
 Else
  Call LECTEXTRA(INTIT,"GCOA","COLHEA",[M]COA(N-1),"") From ATEXTRA
  Call INIACCFMT([M]COA(N-1)) From SETGLBCOA
 Endif
 FMT = "K:"+GFMTACC
 Gosub INTIT_ACC
Next
# masquage des colonnes
INTIT=""
FMT = "-K:10X"
For N=[L]COANBR+1 To 9
 Gosub INTIT_ACC
Next
Return

$AFFDIE
Local Char INTIT(250)
# affichage des colonnes
For N=1 To [L]DIENBR
 # lecture du format
 If status=65 and N>=nolign # annulation d'une ligne
  Call LECTEXTRA(INTIT,"GDIE","COLHEA",[M]DIE(N),"") From ATEXTRA
  Read [DIE]DIE0=[M]DIE(N)
 Elsif (status=71 or status=73) and N>=nolign # ajout/insertion d'une ligne
  If N-1>=0 #and N<>nolign
   Call LECTEXTRA(INTIT,"GDIE","COLHEA",[M]DIE(N-1),"") From ATEXTRA
  Else
   INTIT=""
  Endif
  Read [DIE]DIE0=[M]DIE(N-1)
 Else
  Call LECTEXTRA(INTIT,"GDIE","COLHEA",[M]DIE(N-1),"") From ATEXTRA
  Read [DIE]DIE0=[M]DIE(N-1)
 Endif
 FMT = "K:"+[DIE]CCEFMT
 Gosub INTIT_CCE
Next
# masquage des colonnes
INTIT=""
FMT = "-K:10X"
For N=[L]DIENBR+1 To dim([M]DIE)
 Gosub INTIT_CCE
Next
Return



######################################################################################
Subprog D_ACC2(VALEUR)
Variable Char    VALEUR()
Local Integer NUMCOA
NUMCOA = 2 : Goto INITACC
Subprog D_ACC3(VALEUR)
Variable Char    VALEUR()
Local Integer NUMCOA
NUMCOA = 3 : Goto INITACC
Subprog D_ACC4(VALEUR)
Variable Char    VALEUR()
Local Integer NUMCOA
NUMCOA = 4 : Goto INITACC
Subprog D_ACC5(VALEUR)
Variable Char    VALEUR()
Local Integer NUMCOA
NUMCOA = 5 : Goto INITACC
Subprog D_ACC6(VALEUR)
Variable Char    VALEUR()
Local Integer NUMCOA
NUMCOA = 6 : Goto INITACC
Subprog D_ACC7(VALEUR)
Variable Char    VALEUR()
Local Integer NUMCOA
NUMCOA = 7 : Goto INITACC
Subprog D_ACC8(VALEUR)
Variable Char    VALEUR()
Local Integer NUMCOA
NUMCOA = 8 : Goto INITACC
Subprog D_ACC9(VALEUR)
Local Integer NUMCOA
NUMCOA = 9 : Goto INITACC

$INITACC

Local Char ACC(GLONGAC),SCR(30)
For I=1 To [L]NUMCOA-1
 [L]ACC = evalue("[M]ACC"+num$(I)+"("-num$(nolign-1)-")")
 If [L]ACC<>""
  Call INIACC([M]COA(I-1),[L]ACC,[M]COA(NUMCOA-1),VALEUR,SCR) From CPTINI
  If VALEUR<>"" : Break : Endif
 Endif
Next  
End

######################################################################################


Subprog C_ACC1(VALEUR)
Variable Char    VALEUR()
Local Integer NUMCOA
NUMCOA = 1 : Goto CONTLIN
Subprog C_ACC2(VALEUR)
Variable Char    VALEUR()
Local Integer NUMCOA
NUMCOA = 2 : Goto CONTLIN
Subprog C_ACC3(VALEUR)
Variable Char    VALEUR()
Local Integer NUMCOA
NUMCOA = 3 : Goto CONTLIN
Subprog C_ACC4(VALEUR)
Variable Char    VALEUR()
Local Integer NUMCOA
NUMCOA = 4 : Goto CONTLIN
Subprog C_ACC5(VALEUR)
Variable Char    VALEUR()
Local Integer NUMCOA
NUMCOA = 5 : Goto CONTLIN
Subprog C_ACC6(VALEUR)
Variable Char    VALEUR()
Local Integer NUMCOA
NUMCOA = 6 : Goto CONTLIN
Subprog C_ACC7(VALEUR)
Variable Char    VALEUR()
Local Integer NUMCOA
NUMCOA = 7 : Goto CONTLIN
Subprog C_ACC8(VALEUR)
Variable Char    VALEUR()
Local Integer NUMCOA
NUMCOA = 8 : Goto CONTLIN
Subprog C_ACC9(VALEUR)
Variable Char    VALEUR()
Local Integer NUMCOA
NUMCOA = 9 : Goto CONTLIN

$CONTLIN
Local Integer X
X=0
If VALEUR="" & NUMCOA=[M]COANBR
 For I=1 To [M]COANBR
  If I<>NUMCOA & evalue("[M]ACC"+num$(I)+"("+num$(nolign-1)+")")<>"" : X+=1 : Endif
 Next
 If X=0
  ## Vous devez définir au moins un compte par ligne
  GMESSAGE = mess(106,104,1)
  mkstat = 2 : End
 Endif
Endif
If NUMCOA>1
 Assign "[M]ACC"+num$(NUMCOA)+"("+num$(nolign-1)+")" With VALEUR
 Local Char    TPLAN(GLONCOA)(1..NUMCOA),TCOMPTE(GLONGAC)(1..NUMCOA), MESSA(250)
 Local Integer I, STAT : STAT = 0
 For I=1 To NUMCOA
  TPLAN(I)   = evalue("[M]COA("+num$(I-1)+")")
  TCOMPTE(I) = evalue("[M]ACC"+num$(I)+"("+num$(nolign-1)+")")
 Next
 Call CNTIPTACC(NUMCOA,TPLAN,TCOMPTE,MESSA,STAT) From CPTCNT
 If STAT : GMESSAGE = MESSA : mkstat = 2 : End : Endif
Endif 
End

######################################################################################
Subprog AS_BPR(VALEUR)
Variable Char    VALEUR()
If !clalev([F:GAC]) : Local File =GTABCPT+"GACCOUNT"     [GAC] : Endif

Gosub SETNOL
Local Integer I, OK
Local Char ACC(GLONGAC)
Raz OK
For I=1 To [M]COANBR
 [L]ACC = evalue("[M]ACC"+num$(I)+"("-num$(NOL)-")")
 If [L]ACC<>""
  If [F:GAC]COA<>[M]COA(I-1) | [F:GAC]ACC<>[L]ACC
   Read [GAC]GAC0 = [M]COA(I-1);[L]ACC
  Endif
  If [F:GAC]SAC=2 : OK=-1 : Break : Endif
 Else
  OK +=1  
 Endif
Next

# Le tiers est accessible si aucun compte saisi ou si un des comptes saisi est collectif.
If OK<>[M]COANBR and OK>-1 : mkstat=1 : Endif
End

Subprog C_BPR(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
Gosub SETNOL
Local Integer I, OK
Local Char ACC(GLONGAC)

If !clalev([F:GAC]) : Local File =GTABCPT+"GACCOUNT"     [GAC] : Endif

For I=1 To [M]COANBR
 [L]ACC = evalue("[M]ACC"+num$(I)+"("-num$(NOL)-")")
 If [L]ACC<>""
  If [F:GAC]COA<>[M]COA(I-1) | [F:GAC]ACC<>[L]ACC
   Read [GAC]GAC0 = [M]COA(I-1);[L]ACC
  Endif
  If [F:GAC]SAC=2 
   Gosub CONTBPRACC
   If mkstat : Break : Endif
  Endif
 Endif
Next
End

$CONTBPRACC
Raz OK , GMESSAGE
If [F:BPR]BPCFLG=2 & [F:GAC]AUZBPR(0)=2
 If clalev([F:BPC])=0 : Local File =GTABCPT+"BPCUSTOMER" [BPC] : Endif
 Call LECTURE("BPC",VALEUR,"") From CONTOBJ
 If [F:BPC]BPCSTA<>2
  # Client non actif
  GMESSAGE = mess(4,119,1)
  mkstat = 2 : Return
 Else
  OK+=1
 Endif
Endif
If [F:BPR]BPSFLG=2 & [F:GAC]AUZBPR(1)=2
 If clalev([F:BPS])=0 : Local File =GTABCPT+"BPSUPPLIER" [BPS] : Endif
 Call LECTURE("BPS",VALEUR,"") From CONTOBJ
 If [F:BPS]ENAFLG<>2
  # Fournisseur non actif
  GMESSAGE = mess(5,119,1)
  mkstat = 2 : End
 Else
  OK+=1
 Endif
Endif
OK += [F:BPR]BPTFLG=2 & [F:GAC]AUZBPR(2)=2
OK += [F:BPR]FCTFLG=2 & [F:GAC]AUZBPR(3)=2
OK += [F:BPR]REPFLG=2 & [F:GAC]AUZBPR(4)=2
OK += [F:BPR]BPRACC=2 & [F:GAC]AUZBPR(5)=2
If OK : Return : Endif
If GMESSAGE=""
 # Tiers incompatible avec le collectif
 GMESSAGE = mess(45,106,1)
 mkstat = 2
Endif
Return

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

######################################################################################
Subprog AS_VAT(VALEUR)
Variable Char    VALEUR()
Local Integer I, OK
Local Char ACC(GLONGAC)

# Compte non soumis, pas de saisie du taux de taxe
Gosub SETNOL

Raz OK  : mkstat = 1 

For I=1 To [M]COANBR
 [L]ACC = evalue("[M]ACC"+num$(I)+"("-num$(NOL)-")")
 If [L]ACC<>""
  If [F:GAC]COA<>[M]COA(I-1) | [F:GAC]ACC<>[L]ACC
   Read [GAC]GAC0 = [M]COA(I-1);[L]ACC
  Endif
  If [F:GAC]FLGVAT>1 : OK=1 : Break : Endif
 Endif
Next
If OK
 Raz mkstat
 # par défaut, c’est le code taxe du compte qui est proposé, mais il est modifiable
 If VALEUR="" : VALEUR = [F:GAC]VAT(0) : Endif
Endif
End

Subprog C_VAT(VALEUR)
Variable Char    VALEUR()
Local Integer I, OK
Local Char ACC(GLONGAC)
If VALEUR<>"" : End : Endif
Gosub SETNOL
Raz OK

For I=1 To [M]COANBR
 [L]ACC = evalue("[M]ACC"+num$(I)+"("-num$(NOL)-")")
 If [L]ACC<>""
  If [F:GAC]COA<>[M]COA(I-1) | [F:GAC]ACC<>[L]ACC
   Read [GAC]GAC0 = [M]COA(I-1);[L]ACC
  Endif
  If [F:GAC]FLGVAT>1 & [F:GAC]FLGVAT<5 :  OK=1 : Break : Endif
 Endif
Next
If OK : 
 GMESSAGE = [F:GAC]ACC-"("+[F:GAC]COA+")\"-mess(10,123,1) # Zone obligatoire
 mkstat =2 : End
Endif
End


######################################################################################
Subprog AS_CCE1(VALEUR)
Variable Char    VALEUR()
AXE = 1 : Goto AS_CCE
Subprog AS_CCE2(VALEUR)
Variable Char    VALEUR()
AXE = 2 : Goto AS_CCE
Subprog AS_CCE3(VALEUR)
Variable Char    VALEUR()
AXE = 3 : Goto AS_CCE
Subprog AS_CCE4(VALEUR)
Variable Char    VALEUR()
AXE = 4 : Goto AS_CCE
Subprog AS_CCE5(VALEUR)
Variable Char    VALEUR()
AXE = 5 : Goto AS_CCE
Subprog AS_CCE6(VALEUR)
Variable Char    VALEUR()
AXE = 6 : Goto AS_CCE
Subprog AS_CCE7(VALEUR)
Variable Char    VALEUR()
AXE = 7 : Goto AS_CCE
Subprog AS_CCE8(VALEUR)
Variable Char    VALEUR()
AXE = 8 : Goto AS_CCE
Subprog AS_CCE9(VALEUR)
Variable Char    VALEUR()
AXE = 9 : Goto AS_CCE
Subprog AS_CCE10(VALEUR)
Variable Char    VALEUR()
AXE = 10 : Goto AS_CCE
Subprog AS_CCE11(VALEUR)
Variable Char    VALEUR()
AXE = 11 : Goto AS_CCE
Subprog AS_CCE12(VALEUR)
Variable Char    VALEUR()
AXE = 12 : Goto AS_CCE
Subprog AS_CCE13(VALEUR)
Variable Char    VALEUR()
AXE = 13 : Goto AS_CCE
Subprog AS_CCE14(VALEUR)
Variable Char    VALEUR()
AXE = 14 : Goto AS_CCE
Subprog AS_CCE15(VALEUR)
Variable Char    VALEUR()
AXE = 15 : Goto AS_CCE
Subprog AS_CCE16(VALEUR)
Variable Char    VALEUR()
AXE = 16 : Goto AS_CCE
Subprog AS_CCE17(VALEUR)
Variable Char    VALEUR()
AXE = 17 : Goto AS_CCE
Subprog AS_CCE18(VALEUR)
Variable Char    VALEUR()
AXE = 18 : Goto AS_CCE
Subprog AS_CCE19(VALEUR)
Variable Char    VALEUR()
AXE = 19 : Goto AS_CCE
Subprog AS_CCE20(VALEUR)
Variable Char    VALEUR()
AXE = 20 : Goto AS_CCE

$AS_CCE
# si la répartition est renseignée, on ne saisit pas les sections
If [M]DSP(nolign-1)<>""
 VALEUR = "" : mkstat=2 : End
Endif

# Axe est il accessible ?
# si oui, l'initialiser.

Local Char ACC(GLONGAC)
Local Integer IND, AXI, NB

If !clalev([F:GAC]) : Local File =GTABCPT+"GACCOUNT"     [GAC] : Endif

For I=1 To [M]COANBR
 [L]ACC = evalue("[M]ACC"+num$(I)+"("-num$(nolign-1)-")")
 If [L]ACC<>""
  NB +=1 # Compte saisi
  #--- Axe est-il suivi sous le compte 'saisi' 
  If [F:GAC]COA<>[M]COA(I-1) | [F:GAC]ACC<>[L]ACC
   Read [GAC]GAC0 = [M]COA(I-1);[L]ACC
  Endif
  IND = find([M]DIE(AXE-1),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1)) 
  If IND
   If VALEUR = "" : VALEUR = [F:GAC]CCEDEF(IND-1) : Endif
  Else
   NB -= 1  # Axe non suivi pour ce compte.
  Endif
 Endif
Next  

# Si aucun compte saisissable n'est suivi pour cette axe, L'axe devient inacessible.
If !NB : mkstat =1 : Endif
End

Subprog C_CCE1(VALEUR)
Variable Char    VALEUR()
AXE = 1 : Goto C_SECTION
Subprog C_CCE2(VALEUR)
Variable Char    VALEUR()
AXE = 2 : Goto C_SECTION
Subprog C_CCE3(VALEUR)
Variable Char    VALEUR()
AXE = 3 : Goto C_SECTION
Subprog C_CCE4(VALEUR)
Variable Char    VALEUR()
AXE = 4 : Goto C_SECTION
Subprog C_CCE5(VALEUR)
Variable Char    VALEUR()
AXE = 5 : Goto C_SECTION
Subprog C_CCE6(VALEUR)
Variable Char    VALEUR()
AXE = 6 : Goto C_SECTION
Subprog C_CCE7(VALEUR)
Variable Char    VALEUR()
AXE = 7 : Goto C_SECTION
Subprog C_CCE8(VALEUR)
Variable Char    VALEUR()
AXE = 8 : Goto C_SECTION
Subprog C_CCE9(VALEUR)
Variable Char    VALEUR()
AXE = 9 : Goto C_SECTION
Subprog C_CCE10(VALEUR)
Variable Char    VALEUR()
AXE = 10 : Goto C_SECTION
Subprog C_CCE11(VALEUR)
Variable Char    VALEUR()
AXE = 11 : Goto C_SECTION
Subprog C_CCE12(VALEUR)
Variable Char    VALEUR()
AXE = 12 : Goto C_SECTION
Subprog C_CCE13(VALEUR)
Variable Char    VALEUR()
AXE = 13 : Goto C_SECTION
Subprog C_CCE14(VALEUR)
Variable Char    VALEUR()
AXE = 14 : Goto C_SECTION
Subprog C_CCE15(VALEUR)
Variable Char    VALEUR()
AXE = 15 : Goto C_SECTION
Subprog C_CCE16(VALEUR)
Variable Char    VALEUR()
AXE = 16 : Goto C_SECTION
Subprog C_CCE17(VALEUR)
Variable Char    VALEUR()
AXE = 17 : Goto C_SECTION
Subprog C_CCE18(VALEUR)
Variable Char    VALEUR()
AXE = 18 : Goto C_SECTION
Subprog C_CCE19(VALEUR)
Variable Char    VALEUR()
AXE = 19 : Goto C_SECTION
Subprog C_CCE20(VALEUR)
Variable Char    VALEUR()
AXE = 20 : Goto C_SECTION
$C_SECTION
## Pas de contrôle sur au moins une section à renseigner (on ne sait pas à ce niveau si le compte est
## suivi en analytique. Cela dépend du modèle comptable et des référentiels associés...
## CONTROLES INTERDICTIONS COMPTES/SECTIONS et SECTIONS/SECTIONS A RAJOUTER

#--- Contrôle code interdiction compte/section
If !clalev([F:CAZ]) : Local File =GTABCPT+"CAAUZ" [CAZ] : Endif
If !clalev([F:GAC]) : Local File GACCOUNT  [GAC] : Endif
Local Char WACC(GLONGAC)
Local Integer I, IND
For I=1 To [M]COANBR
 [L]WACC = evalue("[M]ACC"+num$(I)+"("-num$(nolign-1)-")")
 If [L]WACC<>""
  #--- Axe est-il suivi sous le compte 'saisi' 
  If [F:GAC]COA<>[M]COA(I-1) | [F:GAC]ACC<>[L]WACC
   Read [GAC]GAC0 = [M]COA(I-1);[L]WACC
  Endif
  IND = find([M]DIE(AXE-1),[F:GAC]DIE(0..[F:GAC]DACDIENBR-1)) 
  If IND
   Look [CAZ]CAZ0 = 2 ; [F:GAC]AUZ ; [F:CCE]AUZ 
   If !fstat
    GMESSAGE = VALEUR-mess(27,106,1)-[L]WACC : # Interdit avec le compte
    mkstat = 1 : End
   Endif
  Endif
 Endif
Next  

#--- Contrôle code interdiction section/section
If !clalev([F:CCE2]) : Local File =GTABCPT+"CACCE" [CCE2] : Endif
Local Char WCCE(GLONCCE)
For I=1 To AXE
 WCCE = evalue("[M]CCE"+num$(I)+"("+num$(nolign-1)+")")
 If WCCE<>"" : # Section vide => pas d'interdiction
  Read [CCE2]CCE0 = [M]DIE(I-1);[L]WCCE
  Look [CAZ]CAZ0 = 1 ; [F:CCE]AUZ ; [F:CCE2]AUZ
  If !fstat
   # Interdit avec la section
   GMESSAGE = VALEUR-mess(26,106,1)-[F:CCE2]CCE
   mkstat = 1 : Break
  Endif
 Endif
Next I

End

# Décalage des valeurs des champs ACCx ou CCEx du 3e tableau vers la gauche ou la droite
# SENS : 1 = gauche, 2 = droite
Subprog DECALE(NBLIG, CHAMP, SENS)
Value Integer NBLIG
Value Char CHAMP
Value Integer SENS
Local Integer L, N

If SENS=1
 For L=0 To [M]NBRACC-1
  For N=nolign+1 To [L]NBLIG  # décalage des valeurs vers la gauche
   Assign "[M]"+[L]CHAMP+num$(N-1)+"("+num$(L)+")" With evalue("[M]"+[L]CHAMP+num$(N)+"("+num$(L)+")")
  Next
 Next
Elsif SENS=2
 For L=0 To [M]NBRACC-1
  For N=[L]NBLIG To nolign Step -1 # décalage des valeurs vers la droite
   Assign "[M]"+[L]CHAMP+num$(N+1)+"("+num$(L)+")" With evalue("[M]"+[L]CHAMP+num$(N)+"("+num$(L)+")")
  Next
  Assign "[M]"+[L]CHAMP+num$(nolign)+"("+num$(L)+")" With ""
 Next
Endif
End
