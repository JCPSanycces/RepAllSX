#<AdxTL>@(#)0.0.0.0 $Revision$
########################################
Subprog AV_NBLIG
Local Integer L : L = nolign - 1

If [M:MFS4]REJCPLQTY(L) <> 0
  pcolor = GCOUL(1)
Else
  pcolor = GCOUL(0)
Endif

End

########################################
Subprog B2_NBLIG
Local Integer WDACMST, WPREC, WOPECLENBR, WSENS
If clalev ([F:MFOX]) <= 0 : Local File MFGOPE      [MFOX] : Endif
Call DEBTRANS From GLOCK
Trbegin [MFG]
Read [F:MFO]MFO0 = [M:MFS0]MFGNUM;[M:MFS4]OPENUM(nolign-1);[M:MFS4]OPESPLNUM(nolign-1)
If fstat Raz [F:MFO] : End : Endif
If [F:MFO]OPESTA = 5
     WSENS = 2
Else
    WSENS = 1
Endif
#Récup de DACMST
Read [F:SCH]SCH0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
If fstat : Raz [F:SCH] : Endif
WDACMST = [F:SCH]DACMST
#Si opération borne il faut solder/désolder les opé à suivre en même temps
If [F:SCH]DACMST = 3
   Local Shortint WOPE
   Local Integer WBREAK
#Recherche de la précédente opération à suivre (normale ou borne)
   Raz WBREAK,WOPE
   Filter [F:MFOX] Where MFGNUM = [F:MFO]MFGNUM & OPENUM < [F:MFO]OPENUM Order By Key MFO0 Desc
   For [F:MFOX]
       Read [F:SCH]SCH0 = [F:MFOX]MFGNUM;[F:MFOX]OPENUM;[F:MFOX]OPESPLNUM
       If !fstat & [F:SCH]DACMST >1 : WBREAK = 1 : Break : Endif
   Next
   If WBREAK = 1 : WOPE = [F:MFOX]OPENUM
   Else WOPE = 0
   Endif
#Traitement des opé entre les deux bornes(borne supérieure comprise)
   Filter [F:MFOX] Where MFGNUM = [F:MFO]MFGNUM & OPENUM > WOPE & OPENUM <= [F:MFO]OPENUM
Else
   Filter [F:MFOX] Where MFGNUM = [F:MFO]MFGNUM & OPENUM = [F:MFO]OPENUM &
&                            OPESPLNUM = [F:MFO]OPESPLNUM
Endif
For [F:MFOX]
       If [F:MFG]MFGNUM <> [F:MFOX]MFGNUM
          Read [F:MFG]MFG0 = [F:MFOX]MFGNUM
          If fstat : Raz [F:MFG] : Endif
       Endif
       If WPREC = 0 : WPREC = [F:MFOX]OPENUM
       Elsif WPREC <> [F:MFOX]OPENUM
             If WSENS = 1 : Gosub CTR_SOLDE From FUNMFGS
             Else         : Gosub CTR_DESOLDE From FUNMFGS
             Endif
             WPREC = [F:MFOX]OPENUM
       Endif
       If WSENS = 1
           [F:MFOX]OPESTA = 5
           [F:MFOX]MFOTRKFLG = 5
       Else
           If [F:MFOX]CPLQTY <> 0
               [F:MFOX]OPESTA = 4
               [F:MFOX]MFOTRKFLG = 4
           Else
               [F:MFOX]OPESTA = 1
               If [M:MFS0]WPRN = 2 : [F:MFOX]MFOTRKFLG = 3
               Else                : [F:MFOX]MFOTRKFLG = 1
               Endif
           Endif
       Endif
       Gosub MAJ_SUIVANTE
       If [F:MFOX]OPESTA = 1 : Gosub LEC_PREC : Endif
       If GOK < 1 : Break : Endif
       Rewrite [F:MFOX]
       If fstat
          GOK = 0 : Call FSTA("MFO") From GLOCK : Break
       Endif
       [F:MFO] = [F:MFOX]
       Filter [MFI] Where MFGNUM = [F:MFOX]MFGNUM
       Read [F:MFI]MFI0 First
       If !fstat
           If WSENS = 1
               Call UPDATE_OWX("SA",[F:MFI]PJT) From MFGLIBO
           Else
               Call UPDATE_OWX("SM",[F:MFI]PJT) From MFGLIBO
           Endif
       Endif
       Filter [MFI]
       If [F:MWS]WSTTYP <> 3
          If WSENS = 1 : WOPECLENBR += 1
          Else         : WOPECLENBR -= 1
          Endif
       Endif
Next
If WSENS = 1 : Gosub CTR_SOLDE   From FUNMFGS
Else         : Gosub CTR_DESOLDE From FUNMFGS
Endif
#----------------------- Maj  Entête OF ------------------------------------#
Readlock [F:MFG]MFG0 = [M:MFS0]MFGNUM
If fstat=1  GOK=-1 : GLOCK="$MFGHEAD"-num$([M:MFS0]MFGNUM) : Goto TR_ROLL
Elsif fstat GOK=0  : Call RSTA("MFG",num$([M:MFS0]MFGNUM)) From GLOCK :Goto TR_ROLL
Endif
[F:MFG]OPECLENBR   += WOPECLENBR
If [F:MFG]OPECLENBR = [F:MFG]OPELINNBR &
&  [F:MFG]ITMCLENBR = [F:MFG]ITMLINNBR &
&  [F:MFG]MATCLENBR = [F:MFG]MATLINNBR : [F:MFG]MFGTRKFLG = 5
Else                                   : [F:MFG]MFGTRKFLG = 4
Endif
Rewrite [F:MFG]
If fstat
   GOK = 0 : Call FSTA("MFG") From GLOCK : Goto TR_ROLL
Else Commit
     Gosub CHARG_MFS4
     Affzo [M:MFS1]MFGTRKFLG
     Affzo [M:MFS4]
     mkstat = 4
     Goto FIN
Endif

$TR_ROLL
Rollback

$FIN
End


########################################
Subprog IB_NBLIG
#GBOUT2 = "Solde" "Annulation solde"
Raz GBOUT1, GBOUT2
# Issue 104610 - 2015-02-03 by JUSYN : Additionally GESMFG allowed to close.
# If GFONC1 <> "FUNMCLOSE" : End : Endif
If GFONC1 <> "FUNMCLOSE" & GFONC1 <> "GESMFG" : End : Endif
# sr 11.04
Read [F:MFG]MFG0 = [M:MFS0]MFGNUM
If fstat : Raz [F:MFG] : End : Endif
If [F:MFG]MFGTRKFLG < 4  : End : Endif
If [F:MFG]MFGSTA    = 4  : End : Endif
If [M:MFS4]DACMST(nolign-1) = 1 : End : Endif
If [M:MFS4]ROUOPENUM(nolign-1) = 0 : End : Endif
If clalev ([F:MWS]) <= 0 : Local File WORKSTATIO  [MWS] : Endif
#si il s'agit d'une opération de sous-traitance, vérification que la ligne de cde liée est
#soldée ou non
Read [F:MFO]MFO0 = [M:MFS0]MFGNUM;[M:MFS4]OPENUM(nolign-1);[M:MFS4]OPESPLNUM(nolign-1)
If fstat : End : Endif
Read [F:MWS]WST0 =[F:MFO]EXTWST;[F:MFO]MFGFCY
If fstat : Raz [F:MWS] : Endif
If [F:MWS]WSTTYP = 3 & GMODU(6) = 2 & [M:MFS4]OPESTA(nolign-1) >= 4
   If clalev ([F:OPS]) <= 0 : Local File OPERATIONS  [OPS] : Endif
   If clalev ([F:POQ]) <= 0 : Local File PORDERQ     [POQ] : Endif
   Read [F:OPS]OPS1 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
   If fstat : Raz [F:OPS] : End : Endif
   Read [F:POQ]POQ0 = [F:OPS]POHNUM;[F:OPS]POPLIN;[F:OPS]POPSEQ
   If fstat : Raz [F:POQ] : End : Endif
   If [M:MFS4]OPESTA(nolign-1) < 5 & [F:POQ]LINCLEFLG <> 2 : End : Endif
   If [M:MFS4]OPESTA(nolign-1) = 5 & [F:POQ]LINCLEFLG =  2 : End : Endif
Endif
# Issue 104610 - 2015-02-03 by JUSYN : Activate Buttons only with closing action.
If GACTION = "TRTMCLOSE"
    If    [M:MFS4]OPESTA(nolign-1) < 5 : GBOUT2 = mess(012,198,1)
    Elsif [M:MFS4]OPESTA(nolign-1) = 5 : GBOUT2 = mess(400,198,1)
    Endif
Endif
End

##########################################
$CHARG_MFS4
Local Integer I
I=0
For [MFO]MFO0 Where MFGNUM=[M:MFS0]MFGNUM
    [M:MFS4]BPSNUM(I)     = [F:MFO]BPRNUM
    [M:MFS4]CPLLAB(I)     = [F:MFO]CPLLAB
    [M:MFS4]CPLOPETIM(I)  = [F:MFO]CPLOPETIM
    [M:MFS4]CPLQTY(I)     = [F:MFO]CPLQTY
    [M:MFS4]CPLSETTIM(I)  = [F:MFO]CPLSETTIM
    [M:MFS4]CPLWST(I)     = [F:MFO]CPLWST
    [M:MFS4]CPLWSTNBR(I)  = [F:MFO]CPLWSTNBR
    [M:MFS4]CPLLABNBR(I)  = [F:MFO]CPLLABNBR
    [M:MFS4]EXTLAB(I)     = [F:MFO]EXTLAB
    [M:MFS4]EXTOPETIM(I)  = [F:MFO]EXTOPETIM
    [M:MFS4]EXTQTY(I)     = [F:MFO]EXTQTY
    [M:MFS4]EXTSETTIM(I)  = [F:MFO]EXTSETTIM
    [M:MFS4]EXTWST(I)     = [F:MFO]EXTWST
    [M:MFS4]EXTWSTNBR(I)  = [F:MFO]EXTWSTNBR
    [M:MFS4]EXTLABNBR(I)  = [F:MFO]EXTLABNBR
    [M:MFS4]OPEEND(I)     = [F:MFO]OPEEND
    [M:MFS4]OPENUM(I)     = [F:MFO]OPENUM
    [M:MFS4]OPESPLNUM(I)  = [F:MFO]OPESPLNUM
    [M:MFS4]OPESTA(I)     = [F:MFO]OPESTA
    [M:MFS4]OPESTR(I)     = [F:MFO]OPESTR
    [M:MFS4]OPEUOM(I)     = [F:MFO]OPEUOM
    [M:MFS4]POHNUM(I)     = [F:MFO]POHNUM
    [M:MFS4]POPLIN(I)     = [F:MFO]POPLIN
    [M:MFS4]POPSEQ(I)     = [F:MFO]POPSEQ
    [M:MFS4]REJCPLQTY(I)  = [F:MFO]REJCPLQTY
    [M:MFS4]TIMUOMCOD(I)  = [F:MFO]TIMUOMCOD
    Read [MWS]WST0=[F:MFO]EXTWST;[F:MFO]MFGFCY
    If !fstat
        [M:MFS4]WCR(I)    = [F:MWS]WCR
        [M:MFS4]WSTTYP(I) = [F:MWS]WSTTYP
    Endif
    Read [MWS]WST0=[F:MFO]EXTLAB;[F:MFO]MFGFCY
    If !fstat
        [M:MFS4]LABWCR(I) = [F:MWS]WCR
    Endif
    Read [F:SCH]SCH0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
    If fstat : Raz [F:SCH] : Endif
    [M:MFS4]DACMST(I) = [F:SCH]DACMST
    I += 1
Next
[M:MFS4]NBLIG = I
Return

################
$LEC_PREC
#Recup du statut de l'opération précédente
Local Integer J
If clalev([F:MFOW])<=0 : Local File MFGOPE [MFOW] : Endif
Filter [F:SCH] Where MFGNUM = [F:MFOX]MFGNUM & NEXOPENUM = [F:MFOX]OPENUM
Read [F:SCH]SCH0  First
If !fstat
    Read  [F:MFOW]MFO0=[F:MFOX]MFGNUM;[F:SCH]OPENUM
    If !fstat
       Case [F:MFOW]OPESTA :
            When 4 :       [F:MFOX]OPESTA  = 2
            When 5 :       [F:MFOX]OPESTA  = 3
            When Default : [F:MFOX]OPESTA  = 1
       Endcase
    Endif
Endif
Filter [F:SCH]
Return

################
$MAJ_SUIVANTE
#maj du statut de l'opération suivante
Local Integer J
If clalev([F:MFOW])<=0 : Local File MFGOPE [MFOW]     : Endif
If clalev([F:OPS])<=0 : Local File OPERATIONS [OPS] : Endif        :# sr 12/00 dem 7291
Filter [F:SCH]
Filter [F:MFOW]
Read [F:SCH]SCH0 = [F:MFOX]MFGNUM;[F:MFOX]OPENUM;[F:MFOX]OPESPLNUM
If !fstat
    Readlock  [F:MFOW]MFO0=[F:SCH]MFGNUM;[F:SCH]NEXOPENUM
    If !fstat
       If [F:MFOW]OPESTA < 4 & [F:MFOW]OPESTA <> 7
          Case [F:MFOX]OPESTA :
            When 4   :       [F:MFOW]OPESTA  = 2
            When 5   :       [F:MFOW]OPESTA  = 3
            When Default   : [F:MFOW]OPESTA  = 1
          Endcase
          Rewrite [F:MFOW]
          If fstat
             GOK = 0 : Call FSTA("MFOW") From GLOCK : Return
          Endif
       Endif
      # mise à jour du statut dans l'encours de charge demande 7291
       Readlock [F:OPS]OPS1=[F:MFOW]MFGNUM;[F:MFOW]OPENUM;[F:MFOW]OPESPLNUM :# sr 12/00
       If !fstat
           [F:OPS]OPESTA = [F:MFOW]OPESTA
           Rewrite [F:MFOW]
           If fstat
              GOK = 0 : Call FSTA("MFOW") From GLOCK : Return
           Endif
       Endif
    Endif
Endif
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran MFS4) 12/11/2004 15:12:40 (SR)
######################################################################################
Subprog AV_OPENUM(VALEUR)
Variable Decimal VALEUR
If [M:MFS4]ROUOPENUM(nolign-1)  = 0
   pcolor = GCOUL(3)
Else
   pcolor = GCOUL(0)
Endif

End


######################################################################################


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran MFS4) 10/09/2010 08:58:28 (CCC)
######################################################################################
Subprog B2_NBOPE

Local Integer LIND

[M:MFS4]AFFFLG([M:MFS4]NUMLIGOPE(nolign-1)-1) = 1
Affzo [M:MFS4]AFFFLG([M:MFS4]NUMLIGOPE(nolign-1)-1)

For I=[M:MFS4]NUMLIGOPE(nolign-1) To [M:MFS4]NBLIG-1
    [M:MFS4]NUMLIG(I)-=1
Next
Affzo [M:MFS4]NUMLIG

Dela nolign-1, 1 [M:MFS4]NBOPE
[M:MFS4]NBOPE -=1
Affzo [M:MFS4]10

End

######################################################################################
Subprog AM_AFFFLG(VALEUR)
Variable Integer VALEUR
Local Integer I
If VALEUR=1
    Dela [M:MFS4]NUMLIG(nolign-1)-1, 1 [M:MFS4]NBOPE
    [M:MFS4]NBOPE -=1
    Affzo [M:MFS4]10
    For I=nolign To [M:MFS4]NBLIG-1
        [M:MFS4]NUMLIG(I)-=1
    Next
Else
    Insa [M:MFS4]NUMLIG(nolign-1)-1, 1 [M:MFS4]NBOPE
    [M:MFS4]OPENUMG([M:MFS4]NUMLIG(nolign-1)-1)     = num$([M:MFS4]OPENUM(nolign-1))+string$([M:MFS4]OPESPLNUM(nolign-1)>0," / "+num$([M:MFS4]OPESPLNUM(nolign-1)))
    [M:MFS4]STUG([M:MFS4]NUMLIG(nolign-1)-1)        = [M:MFS4]OPEUOM(nolign-1)
    [M:MFS4]EXTQTYG([M:MFS4]NUMLIG(nolign-1)-1)     = [M:MFS4]EXTQTY(nolign-1)
    [M:MFS4]CPLQTYG([M:MFS4]NUMLIG(nolign-1)-1)     = [M:MFS4]CPLQTY(nolign-1)
    [M:MFS4]NUMLIGOPE([M:MFS4]NUMLIG(nolign-1)-1)   = nolign
    [M:MFS4]NBOPE +=1
    Affzo [M:MFS4]10
    For I=nolign To [M:MFS4]NBLIG-1
        [M:MFS4]NUMLIG(I)+=1
    Next
Endif
Affzo [M:MFS4]NUMLIG
End
