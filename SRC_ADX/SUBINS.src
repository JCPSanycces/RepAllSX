# FQ85022 - MABON 23/10/12 - "Appliquer en dessous" ajouté sur certaines zones
Subprog B1_DESTYPFRT(VALEUR)
#Variable Integer VALEUR
Variable Char   VALEUR() : # JML
Local    Integer ZONE

  ZONE=5
  Goto B1_COUT
End

Subprog B2_TYPFIN(VALEUR)
Variable Char    VALEUR()
Local    Integer ZONE

  ZONE=6
  Goto B1_COUT
End

Subprog B2_ORGFIN(VALEUR)
Variable Char    VALEUR()
Local    Integer ZONE

  ZONE=7
  Goto B1_COUT
End

$B1_COUT

  NOL = nolign-1
  For I=NOL To [M:INS2]NBLIG-1
   Case ZONE
    When 5: [M:INS2]DESTYPFRT(I)  = VALEUR
    When 6: [M:INS2]TYPFIN(I)     = VALEUR
    When 7: [M:INS2]ORGFIN(I)     = VALEUR
   Endcase
  Next
  Call APRES_NBLIG
  Affzo [M:INS2]
End
# Fin MABON

