##################################################
# Workflow quand une inscription est saisie
# Gestion de la réponse du manager : Visa ou Refus
##################################################
Subprog WRKSIG(ACTION,CODSTG,CODSES,EMP,CTRNUM,CRIT1)
Value Char ACTION(), CODSTG(), CODSES(), EMP(), CTRNUM(), CRIT1()

If !clalev([F:INS]) : Local File INSCRIPT [INS] : Endif
Local Char CRITERE(250)

Read [F:INS]INS0 = CODSTG;CODSES;EMP
If !fstat Then
  Lock ="INS"+CODSTG+CODSES+EMP
  If fstat
    [V]GOK  =-1
    [V]GLOCK="%INS"+CODSTG+CODSES+EMP
    End
  Endif
  [L]CRITERE  = "[F:INS]STG='"+CODSTG+"' & [F:INS]SES='"+CODSES+"' & [F:INS]REFNUM='"+EMP
&          +"' & [F:INS]CTRNUM='"+CTRNUM+"' & [F:INS]STA=1"
  Case ACTION
    When "VIS"   : Update [F:INS] Where evalue([L]CRITERE) With STA=2 # En cours
    When "REF"   : Update [F:INS] Where evalue([L]CRITERE) With STA=3 # Refusé
    When Default : End
  Endcase
  If fstat
    [V]GOK=0
    Call RSTA("INS",EMP) From GLOCK
    End
  Endif
  If CRIT1<>"" Then : # Délégation
    Local Char GRPDEB
    Case ACTION
      When "VIS"   : Call WORKPLUS(9,"INSSTG","VIS",CRIT1+"~~~"+GUSER+"~~1","",0,0,0,GRPDEB) From AWRK
      When "REF"   : Call WORKPLUS(9,"INSSTG","REF",CRIT1+"~~~"+GUSER+"~~1","",0,0,0,GRPDEB) From AWRK
      When Default : End
    Endcase
  Endif
Endif
End

##################################################
# Workflow quand une inscription est validée par le manager
# Gestion de la réponse du salarié : Visa ou Refus
##################################################
Subprog WRKSIGS(ACTION,CODSTG,CODSES,EMP,CTRNUM)
Value Char ACTION(), CODSTG(), CODSES(), EMP(), CTRNUM()

If !clalev([F:INS]) : Local File INSCRIPT [INS] : Endif
Local Char CRITERE(250)

Read [F:INS]INS0 = CODSTG;CODSES;EMP
If !fstat Then
  Lock ="INS"+CODSTG+CODSES+EMP
  If fstat
    [V]GOK  =-1
    [V]GLOCK="%INS"+CODSTG+CODSES+EMP
    End
  Endif
  [L]CRITERE  = "[F:INS]STG='"+CODSTG+"' & [F:INS]SES='"+CODSES+"' & [F:INS]REFNUM='"+EMP
&          +"' & [F:INS]CTRNUM='"+CTRNUM+"' & [F:INS]STA=2"
  Case ACTION
    When "VIS"   : Update [F:INS] Where evalue([L]CRITERE) With STA=5 # Confirmée
    When "REF"   : Update [F:INS] Where evalue([L]CRITERE) With STA=3 # Refusé
    When Default : End
  Endcase
  If fstat
    [V]GOK=0
    Call RSTA("INS",EMP) From GLOCK
    End
  Endif
Endif
End

