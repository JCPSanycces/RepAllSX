Subprog ADD_LEG(P_CTRNUM)
Variable Char P_CTRNUM()
#LIPET - 2017-05-13 - X3-29550 - START
If clalev([F:HRCTR2])=0 : Local File EMPLOCTR [HRCTR2] : Endif
If clalev([F:FCY2])=0 : Local File FACILITY [FCY2]  : Endif

If P_CTRNUM<>""
   Filter  [HRCTR2] Where CTRNUM=P_CTRNUM
   Read [HRCTR2] Last
   Filter [HRCTR2]
   Read [FCY2]FCY0 = [F:HRCTR2]ETRFCY
   If !fstat
    GCURLEG = [F:FCY2]LEG
    [M:INS0]LEG = GCURLEG
   Affzo [M:INS0]LEG
   Endif
 Endif
#LIPET - 2017-05-13 - X3-29550 - END
End

