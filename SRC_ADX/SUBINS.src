######################################################################################

#**#####################################################################################
#* MABON - 23/09/10
#* Contrôle que l'habilitation fait bien partie des habilitations cibles du stage
#*!
Subprog C_HABAFT(VALEUR)
Variable Char    VALEUR()
Local    Integer IND
# FQ75229 - MABON 22/07/11 - GTRGHAB définie sur 10 caractères au lieu de 5, au cas où...
If dim(GTRGHAB)<0 Then Global Char GTRGHAB(10)(1..50) : Endif

  Call UNICITE(VALEUR,[M:INS6]HABAFT(0..[M:INS6]NBHAB-1)) From OBJDIV
  If mkstat=2 : End : Endif
  Call LECTURE("STG", [M:INS0]STG, "") From CONTOBJ
  IND=1 : Raz GTRGHAB
  For [F:HRSTR] Where COD=[M:INS0]STG
    Call CHARGE_TRG_GEN([F:HRSTR]HABTRG, IND) : # Récupération des habilitations cibles
  Next
  If IND>1 & !find (VALEUR, GTRGHAB(1..IND-1)) Then
    GMESSAGE=mess(57,10720,1) : # Habilitation non définie dans le stage
    mkstat=2 : End
  Endif

#LIPET - 2017-11-15 - X3-63702 - START
  If [F:HRLIC]LEG <> ""
    Call LECTEXTRA([M]DES(nolign-1),"HRLICAUT","DESAXX",VALEUR,[F:HRLIC]LEG) From ATEXTRA
    Else
    Call LECTEXTRA([M]DES(nolign-1),"HRLICAUT","DESAXX",VALEUR,"") From ATEXTRA
  Endif
#LIPET - 2017-11-15 - X3-63702 - END
End

