Return

$RESET_FLGCHG
Local Integer WVAL
Gosub UPDATE_FLGCHG
Return

$UPDATE_FLGCHG
[M]FLGCHG(nolign-1)=WVAL

Return

$RESET_LNKREP
If [M]FLGCHG(nolign-1)=1
  If [M]LNKREP(nolign-1)<>""
    Local Char WTIMSTP(30)
    WTIMSTP=[M]LNKREP(nolign-1)
    If right$(WTIMSTP,len(WTIMSTP))="D"
      WTIMSTP=left$(WTIMSTP,len(WTIMSTP)-1)
    Else
      WTIMSTP+="D"
    Endif
   Local Integer WLIN
   WLIN=find(WTIMSTP,[M]LNKREP(0..[M]NBLIG-1))
   If WLIN
    [M]LNKREP(WLIN-1)=""
   Endif
    [M]LNKREP(nolign-1)=""
  Endif
Endif

Return

$SET_FLGCHG
Local Integer WVAL : WVAL=1
Gosub UPDATE_FLGCHG
Return

