Subprog C_REFPER(VALEUR)
Variable Char    VALEUR()
#LIPET - 2017-05-13 - X3-29550 - START
If VALEUR()<>''
  Case indice
    When 0
      If find(VALEUR,[M:INS2]REFPER(1),[M:INS2]REFPER(2),[M:INS2]REFPER(3))
        mkstat = 2
        Call ERREUR(mess(27,11663,1)) From GESECRAN
      Endif
    When 1
      If find(VALEUR,[M:INS2]REFPER(0),[M:INS2]REFPER(2),[M:INS2]REFPER(3))
        mkstat = 2
        Call ERREUR(mess(27,11663,1)) From GESECRAN
      Endif
    When 2
      If find(VALEUR,[M:INS2]REFPER(0),[M:INS2]REFPER(1),[M:INS2]REFPER(3))
        mkstat = 2
        Call ERREUR(mess(27,11663,1)) From GESECRAN
      Endif
    When 3
      If find(VALEUR,[M:INS2]REFPER(1),[M:INS2]REFPER(2),[M:INS2]REFPER(0))
        mkstat = 2
        Call ERREUR(mess(27,11663,1)) From GESECRAN
      Endif
  Endcase
Endif
#LIPET - 2017-05-13 - X3-29550 - END
End

