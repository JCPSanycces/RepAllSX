Raz GPILOBJ
Call OBJET("INS",GBIDC1,"") From GOBJET
End
########
$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "FERME"      : Gosub FERME
 When "SETBOUT"    : Gosub SETBOUT
 When "EXEBOUT"    : Gosub EXEBOUT
 When "LIENS"      : Gosub LIENS
 When "RAZCRE"     : Gosub RAZCRE
 When "RAZDUP"     : Gosub RAZDUP
 When "ANNULE"     : Gosub ANNULE
 When "VERF_ANU"   : Gosub VERF_ANU
 When "APRES_MODIF": Gosub APRES_MODIF
 When "AVANT_CHOI" : Gosub AVANT_CHOI
 When "APRES_CHOI" : Gosub APRES_CHOI
 When "INICRE"     : Gosub INICRE
 When "INIMOD"     : Gosub INIMOD
 When "VERIF_CRE"  : Gosub VERIF_CRE
 When "VERIF_MOD"  : Gosub VERIF_MOD
 When "FILTRE"     : Gosub FILTRE
 When "FILGAUCHE"  : Gosub FILGAUCHE
 When "ABANDON"    : Gosub ABANDON
 #SEGAY US1840 81085 20/08/2013 action envoyée de SELEMPCTR
# When "BAS_CTRNUM"  : Gosub BAS_CTRNUM From TOOLSHRLEG
Endcase
Return


#####################################
$OUVRE
If clalev([F:INS])=0    : Local File INSCRIPT   [INS]   : Endif
If clalev([F:INJ])=0    : Local File INSJOU     [INJ]   : Endif
If clalev([F:INA])=0    : Local File INSJOUA    [INA]   : Endif
If clalev([F:INS2])=0   : Local File INSCRIPT   [INS2]  : Endif
If clalev([F:STG])=0    : Local File STAGE      [STG]   : Endif
If clalev([F:HRSES])=0  : Local File SESSIONS   [HRSES] : Endif
If clalev([F:SEJ])=0    : Local File SESJOU     [SEJ]   : Endif
If clalev([F:DEM])=0    : Local File DEMANDE    [DEM]   : Endif
If clalev([F:DML])=0    : Local File DEMLIG     [DML]   : Endif
If clalev([F:ADI])=0    : Local File ATABDIV    [ADI]   : Endif
If clalev([F:ADI2])=0   : Local File ATABDIV    [ADI2]  : Endif
If clalev([F:HRSCA])=0  : Local File SCALE      [HRSCA] : Endif
If clalev([F:HRCOR])=0  : Local File COUTREEL   [HRCOR] : Endif
If clalev([F:COU])=0    : Local File COUT       [COU]   : Endif
If clalev([F:CPC])=0    : Local File COMPETENCE [CPC] : Endif
#--STA_EXI 66191 LOT 1
#If clalev([F:ORG])=0    : Local File ORGANISME  [ORG]   : Endif
If clalev([F:OFT])=0    : Local File ORGFINTRA  [OFT]   : Endif
#--END_EXI 66191 LOT 1
# MABON - 24/08/10 - Ajout tables STAGETRG et POPULA pour les cibles
If clalev([F:HRSTR])=0  : Local File STAGETRG   [HRSTR] : Endif
If clalev([F:HRPOA])=0  : Local File POPULA     [HRPOA] : Endif
# MABON - 27/09/10 - Ajout table COURISLIG pour les parcours
If clalev([F:CIL])=0    : Local File COURISLIG  [CIL]   : Endif
Gosub DECLARE

If clalev([F:CPY])=0   : Local File COMPANY  [CPY]   : Endif
If clalev([F:FCY])=0   : Local File FACILITY [FCY]   : Endif
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
If clalev([F:ID2])=0   : Local File EMPLOID  [ID2]   : Endif
If clalev([F:ID3])=0   : Local File EMPLOID  [ID3]   : Endif # FQ61463 - SEGAY 29/07/2013 - Homogénéisation nom prénom\
#LIPET - 2017-05-13 - X3-29550 - START
# SBA X3PEOP-3476
If clalev([F:HRTCR])=0 : Local File HRTRACSTREP     [HRTCR] : Endif

If clalev([F:HRLIC])=0 : Local File HRLICAUT     [HRLIC] : Endif

Gosub DECLARE
#LIPET - 2017-05-13 - X3-29550 - END

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Local Char CRITINS(250)
Return

#####################################
$DECLARE
Local Integer TEMP, NBPAR
Local Decimal TAUX
Global Char    GINTDAT(10)

Return

#####################################
$FERME
  If dim(GINTDAT)>0  Then Kill GINTDAT   Endif
  If dim(GTRGHAB)>0  Then Kill GTRGHAB   Endif
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return
#####################################
$ABANDON
  If dim(SAV_GCURLEG)>0
    GCURLEG=SAV_GCURLEG
  Endif
Return
#####################################
$RAZCRE
[M:INS0]STA=1 : Diszo [M:INS2]DEM : [M:INS4]UPDCPC=1 : [M:INS6]UPDHAB=1
#SEGAY 03/02/11 bug 71267 Période de professionalisation
Raz [M:INS2]FLGPRO
## MABON - 27/08/10 - Initialisation du stage et de la session
  #SBA Dem : 81085-364
If dim(SAV_GCURLEG)>0 & ([M:INS0]SES="")
  GCURLEG=SAV_GCURLEG
Endif
  #SBA Dem : 81085-364

If find("HRSES",GPILCOD(1..GPILOBJ))
  [M:INS0]STG=[F:HRSES]STG : Call AM_STG([M:INS0]STG) : Diszo [M:INS0]STG
  [M:INS0]SES=[F:HRSES]COD : Call AM_SES([M:INS0]SES) : Diszo [M:INS0]SES
Endif
Return

#####################################
$RAZDUP
[M:INS0]STA=1 : Raz [M:INS2]DEM : Diszo [M:INS2]DEM : [M:INS4]UPDCPC=1 : [M:INS6]UPDHAB=1
#SEGAY 22/02/11 bug 71267 Période de professionalisation
Raz [M:INS2]FLGPRO
Affzo [M:INS2]FLGPRO
Return

#####################################
$APRES_MODIF
# FQ81491 US902 - MABON 05/11/12 - GCURLEG ne doit pas être vidé
# GCURLEG=""
# Fin MABON
If COUZON="SES" | COUZON="REFNUM"
 If COUZON="SES"    : [M:INS0]SES=CZ : Endif
 If COUZON="REFNUM" : [M:INS0]REFNUM=CZ : Endif
 If [M:INS0]SES<>"" & [M:INS0]REFNUM<>""
  Filter [F:INS] Where SES=[M:INS0]SES & REFNUM=[M:INS0]REFNUM
  Read [F:INS]INS0 First
  Filter [F:INS]
  If !fstat : Return : Endif
 Endif
 Gosub NBPARTICIP
Endif
Return

#####################################
$AVANT_CHOI
If clalev([F:HRSES])>0 and [F:HRSES]COD="" and [M:INS0]SES<>"" Then
    Call LECTURE("HRSES", [M:INS0]SES, "") From CONTOBJ
  Endif
Return

# FQ81085 - MABON 22/06/12 - Navigate in the records, taking into account GLEGFIL
$FILINS

  CRITINS="1=1"
  If GLEGFIL<>""
    If CRITINS<>"" Then CRITINS-="&" : Endif
    CRITINS -= "(find([F:FCY]LEG,'"+GLEGFIL+"','')>0)"
  Endif
  If GUSRACS<>2
    If CRITINS<>"" Then CRITINS-="&" : Endif
    CRITINS -= '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
    CRITINS -= '& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))>0'
  Endif
  If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
    If CRITINS<>"" Then CRITINS-="&" : Endif
    CRITINS -= 'find([F:ECT]FCY,GUSRFCY(1..GNBAUZ))>0'
  Endif
  If find("HRSES",GPILCOD(1..GPILOBJ))
    If CRITINS<>"" Then CRITINS-="&" : Endif
    CRITINS -= "SES='"+[F:HRSES]COD+"'"
  Endif
  Filter [INS_] Where evalue(CRITINS)
Return
# End MABON

#####################################
# L'exécution du menu "Arrêté formation" se fait dans l'étiquette APRES_CHOI, de façon à pouvoir rafraîchir
# l'écran INS3 (champs TRFTPS, REQNUMSTT, TRFREQ et REQNUMHTT), en positionnant REPONSE à GSTARAF
$APRES_CHOI
  Case REPONSE
    When GSTAITM+1 :
      Local Char    SAVACT(GLONACT)
      Local Integer FLGEXE
      SAVACT = GACTION
      Local Char VALBOUT(250) , PARBOUT(250)(1..20)
      FLGEXE = 1
      GACTION = "HRARRFOR"
      #MABOS-26/07/13-FQ81085-US1833-fenêtre avec mémo-
#     Call TRAITE_CHAR(VALBOUT,PARBOUT,"LISINS","CARRFOR","HRARRFOR",3,"XYARRFOR") From GTRAITE
      Call TRAITE_CHAR(VALBOUT,PARBOUT,"LISINS","CARRFOR","HRARRFOR",4,"XYARRFOR") From GTRAITE

      GACTION = SAVACT
      REPONSE = GSTARAF
    When GSTASUI, GSTAPRE, GSTAFIR,GSTALAS
      Gosub FILINS
      If REPONSE=GSTASUI Then Read [INS_]INS0 > [M:INS0]STG;[M:INS0]SES;[M:INS0]REFNUM  : Endif
      If REPONSE=GSTAPRE Then Read [INS_]INS0 < [M:INS0]STG;[M:INS0]SES;[M:INS0]REFNUM  : Endif
      If REPONSE=GSTAFIR Then Read [INS_]INS0 First                                     : Endif
      If REPONSE=GSTALAS Then Read [INS_]INS0 Last                                      : Endif
      Filter [INS_]
      Gosub SUIVPREC From TOOLSHRLEG
  Endcase
Return
# End MABON

#####################################
$NBPARTICIP
Call LECTURE("HRSES",[M:INS0]SES,"") From CONTOBJ
NBPAR=0
For [F:INS2] Where SES=[M:INS0]SES & STA=1
 NBPAR+=1
Next
If NBPAR+1>[F:HRSES]NBRPRTMAX
 # Création impossible, nb de participants max atteint pour la session
 Call ERREUR (mess(7,123,1)-":"-mess(36,10717,1)-[M:INS0]SES) From GESECRAN
 OK=0 : Return
Endif
Return

#####################################
$VERIF_CRE
Gosub VERIF
Gosub NBPARTICIP
Return

#####################################
$VERIF_MOD
Gosub VERIF
Return

#####################################
$VERIF
Call LECTURE("HRSES",[M:INS0]SES,"") From CONTOBJ
If [F:HRSES]FLGCLO=2
 # Cette session est clôturée
 GMESSAGE = mess(60,10717,1)
 OK = 0 : Return
Endif
If [M:INS0]STG<>""
 If [F:HRSES]STG<>[M:INS0]STG
  #Cette session ne dépend pas du stage
  GMESSAGE = mess(30,10717,1)
  OK = 0 : Return
 Endif
Endif

#54948 : MàJ charge Sal ou Pat du participant si modif calendrier présence
#MIPEA - 2017-11-28- US X3-39318- START
Case [L]REP
 When "C","D" : [F:INS]NBRHOUIPT=[F:HRSES]NBRHOUIPT
 When "M"     : Read [INS]INS0=[M:INS0]STG;[M:INS0]SES;[M:INS0]REFNUM
Endcase
#Case [L]REP
# When "C","D" : [F:INS]NBRHOUIPT=[F:HRSES]NBRHOUIPT
# When "M"     : Read [INS]INS0=[M:INS0]SES;[M:INS0]REFNUM
#Endcase
#MIPEA - 2017-11-28- US X3-39318- END
# 95113 US2213 Test Abscence
Local Integer WVERIF
Local Decimal WNBRHOUIPT
[L]WNBRHOUIPT=[F:INS]NBRHOUIPT
[L]WVERIF=1
Gosub SAUVE_JOUR_ABS
#If [F:INS]NBRHOUIPT<>[M:INS3]NBRHOUIPT
If [L]WNBRHOUIPT<>[M:INS3]NBRHOUIPT
# END 95113 US2213
 J=0
 #LIPET - 2017-05-13 - X3-29550 - START
  Gosub SET_VARS_CALC : # SBA X3PEOP-3476
 #LIPET - 2017-05-13 - X3-29550 - END
 # FQ72847 - MABON 07/04/11 - Selon paramètre utilisateur CALCOUPAR, on calcule ou pas les coûts participant
 If GCALCOUPAR=2 Then
   For [ADI]CODE Where NUMTAB=10451 & (LEG=GCURLEG | LEG="") & N1<3 & N2=1 & find(CODE,[M:INS2]TYPCRG)
    For I=1,2
     Call TAUX_HORAIRE( [M:INS0]REFNUM,[M:INS0]CTRNUM,[F:HRSES]ENDDAT,[L]TAUX,[F:ADI]N1,2,I
&                     ) From TRTCOUT
     If [L]TAUX
      If !J
       Call OUINON(mess(303,10717,1),J) From GESECRAN : # 95113 US2213 Test Abscence
       # Voulez vous mettre à jour les coûts participants calculés
       If J<>2 : Break 2 : Endif
      Endif
      #LIPET - 2017-05-13 - X3-29550 - START
#      [L]TAUX=arr([M:INS3]NBRHOUIPT*[L]TAUX,0.01)
#      K      =find([F:ADI]CODE,[M:INS2]TYPCRG)-1
#      Case I
#       When 1 : [M:INS2]CSTTOTIDV(K)=[L]TAUX
#       When 2 : [M:INS2]CSTIPTIDV(K)=[L]TAUX
#      Endcase
       Gosub NEW_COUPARCAL
       #LIPET - 2017-05-13 - X3-29550 - END
     Endif
    Next
   Next
 Endif
 If J=2
  Affzo [INS2] CSTTOTIDV, CSTIPTIDV
  Call APRES_NBLIG
 Endif
Endif
#LIPET - 2017-05-13 - X3-29550 - START
# Issue 96363 - 2015-07-07 by BRBAN : At least one REFPER field must be filled
If func AFNC.ACTIV("KPO")>0
  If [M:INS2]REFPER(0)='' & [M:INS2]REFPER(1)='' & [M:INS2]REFPER(2)='' & [M:INS2]REFPER(3)=''
    GMESSAGE=mess(28,11663,1)
    OK=0
  Endif
Endif
# -
#LIPET - 2017-05-13 - X3-29550 - END
Return
#LIPET - 2017-05-13 - X3-29550 - START
$NEW_COUPARCAL
Local Integer I

  [L]W_TCRCOD=[M:INS2]TCRCOD
  [L]W_TYPCRG=[F:ADI]CODE
  [L]TAUX*= [L]W_NBRHOUR


  Gosub GET_RECORD_REP
  For I=0 To [M:INS2]NBLIG-1
    If [F:ADI]CODE=[M:INS2]TYPCRG(I) and ([M:INS2]LNKREP(I)="" or right$([M:INS2]LNKREP(I),len([M:INS2]LNKREP(I)))<>"D")
       RESULT(0)=[L]TAUX
       RESULT(1)=[L]TAUX

       If IS_REP
         Call  CALCULATE([M:INS2]TCRCOD,[M:INS2]TYPCRG(I),[M:INS2]TYPFIN(I),[M:INS2]ORGFIN(I),[L]W_NBRHOUR,[L]W_NBRNIGHT,[L]TAUX,RESULT) From SUBHRTCR
       Endif
       Case I
            When 1 :
              [M:INS2]CSTTOTIDV(I)=arr(RESULT(0),0.01)
              If [M]LNKREP(I)<>""
                [M:INS2]CSTTOTIDV(I+1)=arr(RESULT(1),0.01)
              Endif
            When 2 :
              [M:INS2]CSTIPTIDV(I)=arr(RESULT(0),0.01)
              If [M]LNKREP(I)<>""
                [M:INS2]CSTIPTIDV(I+1)=arr(RESULT(1),0.01)
              Endif
       Endcase
      Endif
  Next

Return
#LIPET - 2017-05-13 - X3-29550 - END
