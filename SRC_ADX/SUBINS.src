#####################################
$INICRE
$INIMOD
# 95113 US2213 Test Abscence
Local Integer WVERIF
[L]WVERIF=0
# END 95113
Gosub SAUVE_JOUR_ABS
Gosub SAUVE_JOUR
Gosub SAUVE_COUT
Gosub SAUVE_CSI
Return

#####################################
$SAUVE_JOUR_ABS
Local Integer I, IA, ID, FOUND, CALC2
Local Decimal DIFF_NBRHOUREAA(dim([M:INS5]DATABS)), DIFF_NBRHOUREAA2(dim([M:INS5]DATABS)), DIFF
Local Date    DIFF_DAT(dim([M:INS5]DATABS))
# 95113 US2213 Test Abscence Test sur WVERIF (si oui pas de write dans table) pour les 2 appels depuis VERIF et INIMOD ou INICRE
  Call LECTURE("STG", [F:HRSES]STG, "") From CONTOBJ
  If [F:STG]TYPSTG=2 Then
    ID=0
    For [F:INA] Where STG=[M:INS0]STG & SES=[M:INS0]SES & REFNUM=[M:INS0]REFNUM
      IA=find([F:INA]DATABS,[M:INS5]DATABS(0..[M:INS5]NBLIG5-1))
      If IA>0 Then
        If [F:INA]NBRHOUREAA<>[M:INS5]NBRHOUREAA(IA-1) | [F:INA]NBRHOUREAA2<>[M:INS5]NBRHOUREAA2(IA-1) Then
          DIFF_DAT(ID)         = [F:INA]DATABS
          DIFF_NBRHOUREAA(ID)  = [M:INS5]NBRHOUREAA(IA-1)-[F:INA]NBRHOUREAA
          DIFF_NBRHOUREAA2(ID) = [M:INS5]NBRHOUREAA2(IA-1)-[F:INA]NBRHOUREAA2
          ID += 1
        Endif
      Endif
    Next
  Endif
  If ![L]WVERIF
    Delete [F:INA] Where STG=[M:INS0]STG & SES=[M:INS0]SES & REFNUM=[M:INS0]REFNUM
    If fstat=1 | fstat>5
      GOK=0 : Call RSTA("INA",[F:INJ]STG-[F:INJ]SES-[F:INJ]REFNUM-num$([F:INJ]DAT)) From GLOCK : Return
    Endif
  Endif
  Call LECTURE("HRSES", [M:INS0]SES, "") From CONTOBJ
  For nolign=1 To [M:INS5]NBLIG5
    If ![L]WVERIF
      [F:INA]STG=[M:INS0]STG
      [F:INA]SES=[M:INS0]SES
      [F:INA]REFNUM=[M:INS0]REFNUM
      [F:INA]=[M:INS5]
      Write [F:INA]
      If fstat
       GOK = 0 : Call FSTA("INA") From GLOCK : Break
      Endif
    Endif
    #LIPET - 2017-05-13 - X3-29550 - START
    # Si stage vide et plusieurs jours de présence, on traite comme si TYPSTG=1
    If [F:STG]TYPSTG=1 | ([M:INS0]STG="" & [M:INS3]NBLIG1>1) Then
    #If [F:STG]TYPSTG=1 Then
    #LIPET - 2017-05-13 - X3-29550 - END
      If [M:INS5]COMPLETE(nolign-1)=2 Then
        If ![L]WVERIF
          Delete [F:INJ] Where STG=[M:INS0]STG & SES=[M:INS0]SES & REFNUM=[M:INS0]REFNUM & DAT=[M:INS5]DATABS(nolign-1)
          If fstat=1 | fstat>5
           GOK=0 : Call RSTA("INJ",[F:INJ]STG-[F:INJ]SES-[F:INJ]REFNUM-num$([F:INJ]DAT)) From GLOCK : Return
          Endif
        Endif
        For I=1 To [M:INS3]NBLIG1
          If [M:INS5]DATABS(nolign-1)=[M:INS3]DAT(I-1) Then
            Dela I-1, 1 [M:INS3]NBLIG1
            [M:INS3]NBLIG1 -= 1
            Break
          Endif
        Next
        Call APRES_NBLIG1
        [F:INS]NBRHOUIPT  = [M:INS3]NBRHOUIPT
        [F:INS]NBRDAY     = [M:INS3]NBRDAY
        [F:INS]NBRDAY2    = [M:INS3]NBRDAY2
        [F:INS]NBRHOUIPT2 = [M:INS3]NBRHOUIPT2
      Else
        FOUND = 1
        If [M:INS5]CREFLG(nolign-1)=0 Then
          For I=1 To [M:INS3]NBLIG1
            If [M:INS5]DATABS(nolign-1)=[M:INS3]DAT(I-1) Then
              If [L]WVERIF
                [M:INS3]NBRHOUREA(I-1)  -= [M:INS5]NBRHOUREAA(nolign-1)
                [M:INS3]NBRDAYREA(I-1)  -= [M:INS5]NBRDAYREAA(nolign-1)
                [M:INS3]NBRHOUREA2(I-1) -= [M:INS5]NBRHOUREAA2(nolign-1)
                [M:INS3]NBRDAYREA2(I-1) -= [M:INS5]NBRDAYREAA2(nolign-1)
              Endif
              Call APRES_NBLIG1
              [F:INS]NBRHOUIPT  = [M:INS3]NBRHOUIPT
              [F:INS]NBRDAY     = [M:INS3]NBRDAY
              [F:INS]NBRDAY2    = [M:INS3]NBRDAY2
              [F:INS]NBRHOUIPT2 = [M:INS3]NBRHOUIPT2
              FOUND = 2
              Break
            Endif
          Next
          # La ligne d'absence est passé de complète à incomplète : il faut donc la mettre dans le tableau des
          # supprimées, de façon à ce qu'elle soit recréée de l'autre côté
          If [L]WVERIF
            If FOUND=1 Then
              Read [F:SEJ]SEJ0=[M:INS0]SES;[M:INS5]DATABS(nolign-1)
              If !fstat Then
  #                Call ADD_NBLIG6(nolign-1, [F:SEJ]NBRHOU-[M:INS5]NBRHOUREAA(nolign-1), [F:SEJ]NBRJOU-[M:INS5]NBRDAYREAA(nolign-1), 1)
                Call ADD_NBLIG6(nolign-1, [F:SEJ]NBRHOU-[M:INS5]NBRHOUREAA(nolign-1), [F:SEJ]NBRJOU-[M:INS5]NBRDAYREAA(nolign-1), 0, 0, 1)
              Endif
            Endif
          Endif
        Endif
      Endif
    Else
      If [M:INS5]CREFLG(nolign-1)=0 Then
        IA=find([M:INS5]DATABS(nolign-1), DIFF_DAT)
        # FQ72041 - MABON 04/03/11 - Ajout test sur ID>0, car si pas de date renseignée et uniquement heures, on a
        # IA>0 et c'est valable parce qu'on a effectivement ID>0 aussi
        If IA>0 & ID>0 Then
          If DIFF_NBRHOUREAA(IA-1)<>0  Then [M:INS3]NBRHOUREA(0)  -= DIFF_NBRHOUREAA(IA-1)  : Endif
          If DIFF_NBRHOUREAA2(IA-1)<>0 Then [M:INS3]NBRHOUREA2(0) -= DIFF_NBRHOUREAA2(IA-1) : Endif
          If DIFF_NBRHOUREAA(IA-1)<>0 | DIFF_NBRHOUREAA2(IA-1)<>0 Then
            Call APRES_NBLIG1
            [F:INS]NBRHOUIPT  = [M:INS3]NBRHOUIPT
            [F:INS]NBRHOUIPT2 = [M:INS3]NBRHOUIPT2
          Endif
        Else
          If [L]WVERIF
            [M:INS3]NBRHOUREA(0)  -= [M:INS5]NBRHOUREAA(nolign-1)
            [M:INS3]NBRHOUREA2(0) -= [M:INS5]NBRHOUREAA2(nolign-1)
            # FQ72041 - MABON 04/03/11 - Il faut aussi décrémenter les nombres d'heures totaux
            [M:INS3]NBRHOUIPT     -= [M:INS5]NBRHOUREAA(nolign-1)
            [M:INS3]NBRHOUIPT2    -= [M:INS5]NBRHOUREAA2(nolign-1)
#            [F:INS]NBRHOUIPT  = [M:INS3]NBRHOUIPT
#            [F:INS]NBRHOUIPT2 = [M:INS3]NBRHOUIPT2
          Endif
            #LIPET - 2017-11-06 - START
            [F:INS]NBRHOUIPT  = [M:INS3]NBRHOUIPT
            [F:INS]NBRHOUIPT2 = [M:INS3]NBRHOUIPT2
            #LIPET - 2017-11-06 - END
        Endif
      Endif
    Endif
  Next
  If GOK=0 : Return : Endif

  # Les lignes d'absence supprimées doivent être repositionnées dans les lignes de présence, pour sauvegarde
  For nolign=1 To [M:INS5]NBLIG6
    FOUND=1
    #LIPET - 2017-05-13 - X3-29550 - START
    # Si stage vide et plusieurs jours de présence, on traite comme si TYPSTG=1
    If [F:STG]TYPSTG=1 | ([M:INS0]STG="" & [M:INS3]NBLIG1>1) Then
    #If [F:STG]TYPSTG=1 Then
    #LIPET - 2017-05-13 - X3-29550 - END
      For I=1 To [M:INS3]NBLIG1-1
        If [M:INS5]DATABSS(nolign-1)=[M:INS3]DAT(I-1) Then
          FOUND=2
          Break
        Endif
      Next
      If FOUND=1 Then
        If [M:INS3]NBLIG1>0 Then
          For I=1 To [M:INS3]NBLIG1
            If [M:INS5]DATABSS(nolign-1)<[M:INS3]DAT(I-1) Then
              Insa I-1, 1 [M:INS3]NBLIG1
              [M:INS3]NBLIG1 += 1
              FOUND=2
              Break
            Endif
          Next
          # 95113 US2213 Test Abscence delete absence after lign présence
          If FOUND=1 & [M:INS5]DATABSS(nolign-1)>[M:INS3]DAT([M:INS3]NBLIG1-1) Then
            Insa [M:INS3]NBLIG1, 1 [M:INS3]NBLIG1
            [M:INS3]NBLIG1 += 1
            FOUND=2
            I=[M:INS3]NBLIG1
          Endif
        Else
          Insa 1, 1 [M:INS3]NBLIG1
          [M:INS3]NBLIG1 += 1
          FOUND=2
        Endif
      Endif
      If FOUND=2 Then
        [M:INS3]DAT(I-1)        = [M:INS5]DATABSS(nolign-1)
        [M:INS3]DAY1(I-1)       = day$([M:INS3]DAT(I-1))
        [M:INS3]NBRTIMBRK(I-1)  = [M:INS5]NBRTIMBRKAS(nolign-1)
        CALC2=1
        Read[F:SEJ]SEJ0=[M:INS0]SES;[M:INS5]DATABSS(nolign-1)
        If !fstat Then
          [M:INS3]DEBTIM(I-1)    = [F:SEJ]DEBTIM
          [M:INS3]FINTIM(I-1)    = [F:SEJ]FINTIM
          If [M:INS5]SUPPR(nolign-1)=2 & [M:INS5]COMPLETES(nolign-1)<>2 Then
            If ([M:INS3]NBRHOUREA(I-1)=0 & [M:INS3]NBRHOUREA2(I-1)<>0) | ([M:INS3]NBRHOUREA(I-1)<>0 & [M:INS3]NBRHOUREA2(I-1)=0) Then
              If [M:INS3]DEBTIM(nolign-1)<>"" & [M:INS3]FINTIM(nolign-1)<>"" Then
                CALC2=2
                Call SUMHRS([M:INS3]DEBTIM(I-1), [M:INS3]FINTIM(I-1), DIFF)From SUBHRSES
                If [M:INS3]NBRHOUREA(I-1)=0 & [M:INS3]NBRHOUREA2(I-1)<>0 Then
          # 95113 US2213 Test Abscence delete absence after lign présence
                  [M:INS3]NBRHOUREA2(I-1) = [F:SEJ]NBRHOU
                  [M:INS3]NBRDAYREA2(I-1) = [F:SEJ]NBRJOU
          # END 95113
                  [M:INS3]NBRHOUREA(I-1) = DIFF-[M:INS3]NBRTIMBRK(I-1)-[M:INS3]NBRHOUREA2(I-1)
                  [M:INS3]NBRDAYREA(I-1) = 1-[M:INS3]NBRDAYREA2(I-1)
                Endif
                If [M:INS3]NBRHOUREA(I-1)<>0 & [M:INS3]NBRHOUREA2(I-1)=0 Then
          # 95113 US2213 Test Abscence delete absence after lign présence
                  [M:INS3]NBRHOUREA(I-1) = [F:SEJ]NBRHOU
                  [M:INS3]NBRDAYREA(I-1) = [F:SEJ]NBRJOU
          # END 95113
                  [M:INS3]NBRHOUREA2(I-1) = DIFF-[M:INS3]NBRTIMBRK(I-1)-[M:INS3]NBRHOUREA(I-1)
                  [M:INS3]NBRDAYREA2(I-1) = 1-[M:INS3]NBRDAYREA(I-1)
                Endif
              Endif
            Else
              [M:INS3]NBRHOUREA(I-1) = [F:SEJ]NBRHOU
              [M:INS3]NBRDAYREA(I-1) = [F:SEJ]NBRJOU
              If [M:INS3]DEBTIM(nolign-1)<>"" & [M:INS3]FINTIM(nolign-1)<>"" Then
                Call SUMHRS([M:INS3]DEBTIM(I-1), [M:INS3]FINTIM(I-1), DIFF)From SUBHRSES
                [M:INS3]NBRHOUREA2(I-1) = DIFF-[M:INS3]NBRTIMBRK(I-1)-[M:INS3]NBRHOUREA(I-1)
                [M:INS3]NBRDAYREA2(I-1) = 1-[M:INS3]NBRDAYREA(I-1)
                CALC2=2
              Endif
            Endif
          Else
            [M:INS3]NBRHOUREA(I-1)  = [M:INS5]NBRHOUREAAS(nolign-1)
            [M:INS3]NBRDAYREA(I-1)  = [M:INS5]NBRDAYREAAS(nolign-1)
            If [M:INS3]DEBTIM(nolign-1)<>"" & [M:INS3]FINTIM(nolign-1)<>"" Then
              Call SUMHRS([M:INS3]DEBTIM(I-1), [M:INS3]FINTIM(I-1), DIFF)From SUBHRSES
              [M:INS3]NBRHOUREA2(I-1) = DIFF-[M:INS3]NBRTIMBRK(I-1)-[M:INS3]NBRHOUREA(I-1)
              [M:INS3]NBRDAYREA2(I-1) = 1-[M:INS3]NBRDAYREA(I-1)
              CALC2=2
            Endif
          Endif
        Endif
        [M:INS3]NBRHOUPREV(I-1) = [M:INS5]NBRHOUPREVAS(nolign-1)
        If CALC2=1 Then
          [M:INS3]NBRHOUREA2(I-1) = [M:INS5]NBRHOUREAAS2(nolign-1)
          [M:INS3]NBRDAYREA2(I-1) = [M:INS5]NBRDAYREAAS2(nolign-1)
        Endif
        [M:INS3]TYPFRT(I-1)     = [M:INS5]TYPFRTAS(nolign-1)
#          [M:INS3]NBLIG1 += 1
        Call APRES_NBLIG1
        [F:INS]NBRHOUIPT  = [M:INS3]NBRHOUIPT
        [F:INS]NBRDAY     = [M:INS3]NBRDAY
        [F:INS]NBRDAY2    = [M:INS3]NBRDAY2
        [F:INS]NBRHOUIPT2 = [M:INS3]NBRHOUIPT2
      Endif
    Else
      [M:INS3]NBRHOUREA(0)  += [M:INS5]NBRHOUREAAS(nolign-1)
      [M:INS3]NBRHOUREA2(0) += [M:INS5]NBRHOUREAAS2(nolign-1)
      Call APRES_NBLIG1
      [F:INS]NBRHOUIPT  = [M:INS3]NBRHOUIPT
      [F:INS]NBRHOUIPT2 = [M:INS3]NBRHOUIPT2
    Endif
  Next

  If [M:INS5]NBLIG5>0 | [M:INS5]NBLIG6>0 Then Affzo [M:INS3] : Endif
  [M:INS5]NBLIG6=0
  If GOK=0 : Return : Endif

  For I=1 To [M:INS5]NBLIG5
    [M:INS5]CREFLG(I-1)=I
  Next
  Gosub INIT_COL
Return

#####################################
$SAUVE_JOUR
Delete [F:INJ] Where STG=[M:INS0]STG & SES=[M:INS0]SES & REFNUM=[M:INS0]REFNUM
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("INJ",[F:INJ]STG-[F:INJ]SES-[F:INJ]REFNUM-num$([F:INJ]DAT)) From GLOCK : Return
Else
 For nolign=1 To [M:INS3]NBLIG1
  [F:INJ]STG=[M:INS0]STG
  [F:INJ]SES=[M:INS0]SES
  [F:INJ]REFNUM=[M:INS0]REFNUM
  [F:INJ]DATEND=[M:INS3]DATF(nolign-1)
  [F:INJ]=[M:INS3]
  Write [F:INJ]
  If fstat
   GOK = 0 : Call FSTA("INJ") From GLOCK : Break
  Endif
 Next
 If GOK=0 : Return : Endif
Endif
Return

#####################################
$SAUVE_COUT
Delete [F:HRCOR] Where TYPCOU=3 & SES=[M:INS0]SES & REFNUM=[M:INS0]REFNUM
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("HRCOR",[F:HRCOR]SES-[F:HRCOR]REFNUM-num$([F:HRCOR]NUMLIG)) From GLOCK : Return
Else
 For nolign=1 To [M:INS2]NBLIG
  [F:HRCOR]TYPCOU     = 3
  [F:HRCOR]SES        = [M:INS0]SES
  [F:HRCOR]REFNUM     = [M:INS0]REFNUM
  [F:HRCOR]NUMLIG     = nolign
  [F:HRCOR]TYPCRG2    = [M:INS2]TYPCRG(nolign-1)
  [F:HRCOR]TYPFIN2    = [M:INS2]TYPFIN(nolign-1)
  [F:HRCOR]ORGFIN2    = [M:INS2]ORGFIN(nolign-1)
  [F:HRCOR]DESTYPFRT2 = [M:INS2]DESTYPFRT(nolign-1)
  [F:HRCOR]CSTTOTIDV2 = [M:INS2]CSTTOTIDV(nolign-1)
  [F:HRCOR]CSTIPTIDV2 = [M:INS2]CSTIPTIDV(nolign-1)
  #ADNGO - 2017-06-29 - X3-29550 - START
  [F:HRCOR]LNKREP     = [M:INS2]LNKREP(nolign-1) # X3PEOP-3477
  #ADNGO - 2017-06-29 - X3-29550 - END

  [F:HRCOR]CREUSR     = GUSER
  [F:HRCOR]CREDAT     = date$
  [F:HRCOR]CRETIM     = time
  Write [F:HRCOR]
  If fstat
   GOK = 0 : Call FSTA("HRCOR") From GLOCK : Break
  Endif
 Next
 If GOK=0 : Return : Endif
Endif
Return

#**#####################################################################################
#* Procédure globale de mise à jour des parcours individualisés
#*!
Subprog UPDATE_CSI(CODCSI, CODSES, CODSTG, MAT, ABRINS, STA, LRET)
Value    Char    CODCSI, CODSES, CODSTG, MAT, ABRINS
Value    Integer STA
Variable Integer LRET
Local    Date    DATSTR, DATEND

  LRET=1
  If CODCSI<>"" Then
    Call LECTURE("HRSES", CODSES, "") From CONTOBJ
    Filter [F:INJ] Where STG=CODSTG & SES=CODSES & REFNUM=MAT Order By DAT
    Read [F:INJ] First : DATSTR = [F:INJ]DAT
    Call LECTURE("STG", CODSTG, "") From CONTOBJ
    #LIPET - 2017-05-13 - X3-29550 - START
    # Si stage vide et plusieurs jours de présence, on traite comme si TYPSTG=1
    If [F:STG]TYPSTG=1 | ([M:INS0]STG="" & [M:INS3]NBLIG1>1) Then
    #If [F:STG]TYPSTG=1 Then
    #LIPET - 2017-05-13 - X3-29550 - END
      Read [F:INJ] Last  : DATEND = [F:INJ]DAT
    Else
      DATEND = [F:INJ]DATEND
      If DATEND=[0/0/0] Then DATEND=[F:HRSES]ENDDAT Endif
    Endif
    Filter [F:INJ]

    Filter [F:CIL] Where COD=CODCSI and STG=CODSTG
    For [F:CIL]
      [F:CIL]STA        = STA                                : # Statut
      [F:CIL]STRDATR    = DATSTR                             : # Date début
      [F:CIL]ENDDATR    = DATEND                             : # Date fin
      [F:CIL]NBRDAYREA  = evalue("[F:"+ABRINS+"]NBRDAY")     : # Nombre de jours
      [F:CIL]NBRHOUREA  = evalue("[F:"+ABRINS+"]NBRHOUIPT")  : # Nombre d'heures
      [F:CIL]NBRHOUIPT2 = evalue("[F:"+ABRINS+"]NBRHOUIPT2") : # Nombre d'heures HTT
      Rewrite [F:CIL]
      If fstat LRET = 0 : Call FSTA("CIL") From GLOCK : Break : Endif
    Next
    Filter [F:CIL]
  Endif
End

#**#####################################################################################
#* Mise à jour des parcours individualisés
#*!
$SAUVE_CSI
Local Integer I

  If [M:INS2]DEM<>"" Then
    Call LECTURE("DEM", [M:INS2]DEM, "") From CONTOBJ
    If [F:DEM]ORIDEM=2 Then : # Origine demande = Parcours
      Call UPDATE_CSI([F:DEM]CODCSI, [M:INS0]SES, [M:INS0]STG, [M:INS0]REFNUM, "INS", 2, GOK)
      If GOK=0 Then Return : Endif
    Endif
  Endif
Return

#####################################
$LIENS
# FQ61463 - SBA 26/06/2013 - Homogénéisation nom prénom
Call UPD_NAMSRN([M:INS0]REFNUM,"[M:INS0]","NAM","SRN",0,0) From DIVPAYE

If [M:INS0]CTRNUM <>""
  Read [HRCTR]CTR0(2)=[M:INS0]REFNUM;[M:INS0]CTRNUM
  If !fstat
    Call LECTURE("FCY",[HRCTR]ETRFCY,"") From CONTOBJ
    Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
    GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
  Else
    Read [ID2]ID0=[M:INS0]REFNUM
    If !fstat
     Call LECTURE("CPY",[F:ID2]CPY,"") From CONTOBJ
     GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
    Endif
  Endif
Else
  Read [ID2]ID0=[M:INS0]REFNUM
  If !fstat
   Call LECTURE("CPY",[F:ID2]CPY,"") From CONTOBJ
   GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
  Endif

Endif

#LIPET - 2017-05-13 - X3-29550 - START
Call ADD_LEG([M]CTRNUM)
#LIPET - 2017-05-13 - X3-29550 - END

If GNBLEG=1 : GCURLEG = GDOSLEG : Endif
Gosub CHARGE_COUT
Diszo [M:INS2]DEM
#SEGAY 22/02/11 bug 71267 Période de professionalisation
Call LECTURE("DEM",[M:INS2]DEM,"") From CONTOBJ
If !fstat Then
   [M:INS2]FLGPRO    = [F:DEM]FLGPRO
   # FQ72891 - MABON 12/04/11 - Récupération dispositif demande
   Filter [F:DML] Where DEMNUM=[M:INS2]DEM & EMP=[M:INS0]REFNUM
   Read [F:DML] First
   If !fstat Then
    [M:INS2]TYPFRTDEM = [F:DML]DESTYPFRT
   Else
    #LIPET - 2017-06-28 - X3-29550 - START
    #[M:INS2]TYPFRTDEM = len(mess(0,10455,1)) : # Non défini
    [M:INS2]TYPFRTDEM = ''                   : #<JML> len(mess(0,455,1)) : # Non défini
    #LIPET - 2017-06-28 - X3-29550 - END
   Endif
   Filter [F:DML] : # FQ75580 - MABON 01/09/11 - Oubli du Filter suite fiche 72891
   # Fin MABON
Else
   [M:INS2]FLGPRO = 0
   # FQ72891 - MABON 12/04/11 - Récupération dispositif demande
   #LIPET - 2017-06-28 - X3-29550 - START
   #[M:INS2]TYPFRTDEM = len(mess(0,10455,1)) : # Non défini
   [M:INS2]TYPFRTDEM = '' : # Non défini
   #LIPET - 2017-06-28 - X3-29550 - END
Endif

Gosub CHARGE_JOUR
#LIPET - 2017-05-13 - X3-29550 - START
# SBA X3PEOP-3476
#
# intialisation du champ : TCRCOD
#
If  [F:HRSES]STG<>"" and [F:STG]TCRCOD<>""
  [M:INS2]TCRCOD=[F:STG]TCRCOD
Else
  [M:INS2]TCRCOD=""
Endif
#LIPET - 2017-05-13 - X3-29550 - END
Gosub CHARGE_JOUR_ABS
Gosub CHARGE_CPC
Read [ID]ID0=[M:INS0]REFNUM
If !fstat
 Call GRISE_CTRNUM([F:ID]FLGMULCTR)
Endif
If [F:INS]STA=len(mess(0,10459,1)) Then : # Clôturée
  Diszo [M:INS0]
  Diszo [M:INS2]
  Diszo [M:INS3]
  Diszo [M:INS4]
  Diszo [M:INS5]
  Diszo [M:INS6]
Else
  Actzo [M:INS0]
  Actzo [M:INS2]
  Actzo [M:INS3]
  Actzo [M:INS4]
  Actzo [M:INS5]
  Actzo [M:INS6]

Endif
Gosub CHARGE_HAB
If find("HRSES",GPILCOD(1..GPILOBJ))
  Diszo [M:INS0]STG
  Diszo [M:INS0]SES
Endif

#LIPET - 2017-11-15 - X3-63702 - START
 For nolign=1 To dim([M:INS6]HABAFT)
  If [M:INS6]HABAFT(nolign-1)="":Break:Endif
  Filter [F:HRLIC] Where COD = [M:INS6]HABAFT(nolign-1)
  Read [F:HRLIC] First
  Filter [F:HRLIC]
  If !fstat Then
    If [F:HRLIC]LEG <> ""
      Call LECTEXTRA([M:INS6]DES(nolign-1),"HRLICAUT","DESAXX",[M:INS6]HABAFT(nolign-1),[F:HRLIC]LEG) From ATEXTRA
      Else
      Call LECTEXTRA([M:INS6]DES(nolign-1),"HRLICAUT","DESAXX",[M:INS6]HABAFT(nolign-1),"") From ATEXTRA
    Endif
  Endif
 Next
#LIPET - 2017-11-15 - X3-63702 - END

Call DISPLAY_HIDE() From SUBINSLEG
Return

#####################################
$CHARGE_COUT
nolign=1
Filter[HRCOR] Where TYPCOU=3 & SES=[M:INS0]SES & REFNUM=[M:INS0]REFNUM
For [HRCOR]COR0
 # 97021 test du maxi des tableaux écran
 If nolign>dim([M:INS2]TYPCRG)
    Call ERREUR(mess(304,10717,1)) From GESECRAN   # Tableau plein
    Break
 Endif
 [M:INS2]TYPCRG(nolign-1)    = [F:HRCOR]TYPCRG2
 [M:INS2]TYPFIN(nolign-1)    = [F:HRCOR]TYPFIN2
 [M:INS2]ORGFIN(nolign-1)    = [F:HRCOR]ORGFIN2
 [M:INS2]DESTYPFRT(nolign-1) = [F:HRCOR]DESTYPFRT2
 [M:INS2]CSTTOTIDV(nolign-1) = [F:HRCOR]CSTTOTIDV2
 [M:INS2]CSTIPTIDV(nolign-1) = [F:HRCOR]CSTIPTIDV2
 #ADNGO - 2017-06-29 - X3-29550 - START
 [M:INS2]LNKREP(nolign-1)    = [F:HRCOR]LNKREP # X3PEOP-3477
 #ADNGO - 2017-06-29 - X3-29550 - END
 [M:INS2]CUR                 = [F:HRCOR]CUR
 nolign +=1
Next
Filter [HRCOR]
[M:INS2]NBLIG=nolign-1
Call APRES_NBLIG
Return

#####################################
$CHARGE_JOUR
nolign=1
For [F:INJ]INJ0 Where STG=[M:INS0]STG & SES=[M:INS0]SES & REFNUM=[M:INS0]REFNUM
 [M:INS3]=[F:INJ]
 [M:INS3]DAY1(nolign-1) = day$([M:INS3]DAT(nolign-1))
 If [F:INJ]DATEND<>[0/0/0] Then
  [M:INS3]DATF(nolign-1) = [F:INJ]DATEND
 Endif
 nolign+=1
Next
[M:INS3]NBLIG1=nolign-1

  Call LECTURE("STG", [M:INS0]STG, "") From CONTOBJ
  If [F:STG]TYPSTG=2 Then
    Call LECTURE([M:INS0]STG, [M:INS0]SES, "") From CONTOBJ
  Endif
  If [F:STG]TYPSTG=2 & [F:INJ]NBRHOUPREV=0 Then
    For [F:SEJ]SEJ0 Where SES=[M:INS0]SES
      [M:INS3]NBRHOUPREV(0) = [F:SEJ]NBRHOU
    Next
  Endif

  # MABON - 19/08/10 - On rend invisibles certaines colonnes selon qu'on a un stage court ou long
  Gosub INIT_COL
Return

#####################################
$CHARGE_JOUR_ABS
Local Integer I, J

  nolign=1
  For [F:INA]INA0 Where STG=[M:INS0]STG & SES=[M:INS0]SES & REFNUM=[M:INS0]REFNUM
   [M:INS5]=[F:INA]
   [M:INS5]DAYA(nolign-1)   = day$([M:INS5]DATABS(nolign-1))
   [M:INS5]CREFLG(nolign-1) = nolign
   nolign+=1
  Next
  [M:INS5]NBLIG5=nolign-1

  For I=0 To [M:INS5]NBLIG5-1
    [M:INS5]NUMPRE(I) = -1
    For J=0 To [M:INS3]NBLIG1-1
      If [M:INS3]DAT(J)= [M:INS5]DATABS(I) Then
        [M:INS5]NUMPRE(I) = J
      Endif
    Next
  Next
Return

#####################################
$CHARGE_CPC
For nolign=1 To dim([F:INS]CPCAFT)
 If [F:INS]CPCAFT(nolign-1)="" : Break : Endif
 [M:INS4]CPCAFT(nolign-1)=[F:INS]CPCAFT(nolign-1)
 [M:INS4]LEVAFT(nolign-1)=[F:INS]LEVAFT(nolign-1)
Next
[M:INS4]NBCPC=nolign-1
If [M:INS4]UPDCPC=2
 Grizo [INS4]
Else
 Actzo [INS4]
Endif
Return

#####################################
$CHARGE_HAB

  For nolign=1 To dim([F:INS]HABAFT)
    If [F:INS]HABAFT(nolign-1)="" : Break : Endif
    [M:INS6]HABAFT(nolign-1)=[F:INS]HABAFT(nolign-1)
    [M:INS6]HABSTR(nolign-1)=[F:INS]HABSTR(nolign-1)
    [M:INS6]HABFLG(nolign-1)=[F:INS]HABFLG(nolign-1)
  Next
  [M:INS6]NBHAB=nolign-1
  If [M:INS6]UPDHAB=2
    Grizo [INS6]
  Else
    Actzo [INS6]
  Endif
Return

#**
#*  MABON - 19/08/10 - La 1ère colonne a un intitulé évalué selon qu'on a un stage court ou un autre stage
#*  Et selon le type du stage, des colonnes apparaissent ou disparaissent dans l'onglet Calendrier
#*!
$INIT_COL

  Call LECTURE("STG",[M:INS0]STG,"") From CONTOBJ
  If [F:STG]TYPSTG=2 Then
    GINTDAT=mess(4,10708,1)  : # Date début

    Call LECTURE("HRSES",[M:INS0]SES,"") From CONTOBJ
    If [M:INS3]DATF=[0/0/0] Then
#      [M:INS3]DATF(0) = format$("D:DD[/]MM[/]YY", [F:HRSES]ENDDAT)
      [M:INS3]DATF(0) = [F:HRSES]ENDDAT
    Endif
    # FQ71492 - MABON 11/02/11 - Pas besoin de la rendre visible : c'est déjà fait dans le AV_DAT du traitement de l'écran INS3
#    Chgfmt [M:INS3]DATF        With "K:10X"
    Chgfmt [M:INS3]NBRHOUPREV  With "NP:9.2"
    Chgfmt [M:INS3]DAY1        With "-K:10X"
    Chgfmt [M:INS3]DEBTIM      With "-K:##[:]##"
    Chgfmt [M:INS3]FINTIM      With "-K:##[:]##"
    Chgfmt [M:INS3]NBRTIMBRK   With "-N:9.2"
    Chgfmt [M:INS3]NBRDAYREA   With "-N:4.2"
    Chgfmt [M:INS3]NBRDAYREA2  With "-N:9.2"
    Chgfmt [M:INS3]NBRDAY      With "-N:4.2"
    Chgfmt [M:INS3]NBRDAY2     With "-N:4.2"
    #LIPET - 2017-05-13 - X3-29550 - START
    Chgfmt [M:INS3]NBRNGT      With "-NP:4.2" # X3PEOP-3477
    #LIPET - 2017-05-13 - X3-29550 - END

    Chgfmt [M:INS5]DEBTIMA     With "-K:##[:]##"
    Chgfmt [M:INS5]FINTIMA     With "-K:##[:]##"
    Chgfmt [M:INS5]NBRDAYREAA  With "-N:4.2"
    Chgfmt [M:INS5]NBRDAYREAA2 With "-N:4.2"
  Else
    GINTDAT=mess(88,100,1) : # Date

    # FQ71492 - MABON 11/02/11 - C'est un format date, c'est donc plus propre de mettre un -D qu'un -K
    Chgfmt [M:INS3]DATF        With "-D:"+GFMDAT : # "-K:10X"
    Chgfmt [M:INS3]NBRHOUPREV  With "-N:9.2"
    Chgfmt [M:INS3]DAY1        With "KP:10X"
    Chgfmt [M:INS3]DEBTIM      With "K:##[:]##"
    Chgfmt [M:INS3]FINTIM      With "K:##[:]##"
    Chgfmt [M:INS3]NBRTIMBRK   With "N:9.2"
    Chgfmt [M:INS3]NBRDAYREA   With "N:4.2"
    Chgfmt [M:INS3]NBRDAYREA2  With "N:9.2"
    Chgfmt [M:INS3]NBRDAY      With "N:4.2"
    Chgfmt [M:INS3]NBRDAY2     With "N:4.2"
    #LIPET - 2017-05-13 - X3-29550 - START
    Chgfmt [M:INS3]NBRNGT      With "NP:4.2" # X3PEOP-3477
    #LIPET - 2017-05-13 - X3-29550 - END

    Chgfmt [M:INS5]DEBTIMA     With "K:##[:]##"
    Chgfmt [M:INS5]FINTIMA     With "K:##[:]##"
    Chgfmt [M:INS5]NBRDAYREAA  With "N:4.2"
    Chgfmt [M:INS5]NBRDAYREAA2 With "N:4.2"
  Endif
Return

#####################################
$SETBOUT
Local Char CRITERE(255)
Read [F:ID]ID0=[F:INS]REFNUM
Filter [F:INJ] Where STG=[F:INS]STG & SES=[F:INS]SES & REFNUM=[F:INS]REFNUM Order By DAT Desc
Read [F:INJ] First
If !fstat Then
  # FQ76662 - MABON 29/09/11 - Le format contenu dans GFMDAT4 peut être étranger, et donc le evalue() exécuté ensuite
  # peut ne pas fonctionner après un format$()
#  CRITERE="[F:INJ]DAT<=["+format$("D:"+GFMDAT4,date$)+"]"
  CRITERE="[F:INJ]DAT<=["+num$(date$)+"]"
  # Fin MABON
Else
  CRITERE="1=1"
Endif
Filter [F:INJ]
If (([F:INS]TRFTPS<>2  & [F:ID]FLGTPS=2) | [F:INS]TRFREQ<>2) & evalue(CRITERE)>0 Then
  CHMEN += "A"
Endif
# FQ66191 - MABON 29/10/10 - Ajout d'un état donc décalage pour le clôturé
##If [F:INS]STA=3
#If [F:INS]STA=4
# Call VIREBOUT(CHAINE,"M34") From GOBJET
#Endif
If [F:INS]UPDCPC=2 | [M:INS4]NBCPC=0
 Call VIREBOUT(CHAINE,"3") From GOBJET
Endif
If [F:INS]UPDHAB=2 | [M:INS6]NBHAB=0
 Call VIREBOUT(CHAINE,"4") From GOBJET
Endif
If GREP<>""
 # 39925
 #Call VIREBOUT(CHAINE,"1") From GOBJET
 Call VIREBOUT(CHAINE,"134") From GOBJET
 Call VIREBOUT(CHMEN,"A") From GOBJET
Endif
# MABON 28/12/10 - On n'ajoute A que s'il n'est pas déjà présent dans CHAINE
If CLECUR & instr(1,CHAINE,"A")=0 : CHAINE+="A" : Endif
# 39925
If GHISTO=1 Then
  Call VIREBOUT(CHAINE,"134") From GOBJET
  Call VIREBOUT(CHMEN,"A") From GOBJET
Endif
# fin 39925
# MABON 28/12/10 - On ne peut pas supprimer une inscription clôturée
If [F:INS]STA=len(mess(0,10459,1)) Then
  Call VIREBOUT(CHAINE,"A") From GOBJET
Endif
Return

#####################################
$EXEBOUT
Case BOUT
 When "1","3","4"
  Gosub LECTURE From GOBJSUB
  Gosub REMP_LISGAU From GOBJSUB
Endcase
Return

#####################################
$ANNULE
If [M:INS2]DEM<>""
 Filter [DML] Where DEMNUM=[M:INS2]DEM & EMP=[M:INS0]REFNUM
 Readlock [DML]DML0 First
 Filter [DML]
 If !fstat
  [F:DML]FLGINS=[F:DML]OLDFLGINS    :#Demandes -> retour à l'état antérieur
  Rewrite [F:DML]
  If fstat
   GOK = 0 : Call FSTA("DML") From GLOCK
  Endif
 Endif

 # Si la demande est issue d'un parcours, il faut repasser la ligne au statut Saisi, et annuler les Début et Fin période
 Read [F:DEM]DEM0=[M:INS2]DEM
 If !fstat & [F:DEM]ORIDEM=2 Then : # Origine=Parcours
  Filter [F:CIL] Where COD=[F:DEM]CODCSI & STG=[M:INS0]STG
  Readlock [F:CIL]CIL0 First
  Filter [F:CIL]
  If !fstat Then
    [F:CIL]STA=1           : # Ligne de parcours -> redevient Saisi
    [F:CIL]STRDATR=[0/0/0] : # Début et Fin période redeviennent vides
    [F:CIL]ENDDATR=[0/0/0]
    Rewrite [F:CIL]
    If fstat
     GOK = 0 : Call FSTA("CIL") From GLOCK
    Endif
  Endif
 Endif
Endif
Delete [HRCOR] Where TYPCOU=3 & SES=[M:INS0]SES & REFNUM=[M:INS0]REFNUM
If fstat=1 | fstat>5
 GOK = 0 : Call FSTA("HRCOR") From GLOCK : Return
Endif
# FQ80516 - MABON 05/03/12 - Si suppression d'une inscription, annulation des workflows
Call MAJ_HISSUI
# Fin MABON
Return

#**
#* FQ80516 - MABON 05/03/12 - Si suppression d'une inscription, annulation des workflows
#*
#* @param STA
#*!
Subprog MAJ_HISSUI
Local Char    REP (GLONADI)

  If GWEBSERV : End : Endif

  If clalev([F:AWS])=0 : Local File AWRKHISSUI [AWS] : Endif

  REP = "ANN"

  Update [F:AWS] Where VALCTX3 = [M:INS0]REFNUM
&                    & VALCTX1 = [M:INS0]STG
&                    & VALCTX2 = [M:INS0]SES
&                    & VALCTX4 = [M:INS0]CTRNUM
&                With [F:AWS]FLGSIG = 5
&                   , [F:AWS]ACTSIG = REP
&                   , [F:AWS]USRSIG = GUSER
&                   , [F:AWS]DATSIG = date$

End

#####################################
$VERF_ANU
Local Integer J

  If [F:INS]UPDCPC=2 | [F:INS]UPDHAB=2 Then : # Compétences ou habilitations mises à jour, donc on ne peut pas supprimer
    Call OUINON(mess(194,10717,1)+chr$(10)+mess(195,10717,1),J) From GESECRAN : # Les compétences et/ou les habilitations ont été mises à jour depuis cette inscription. Confirmez-vous la suppression ?
    If J=1 Then
      OK=0
      Return
    Endif
  Endif
  If [F:INS]TRFTPS=2 | [F:INS]TRFREQ=2 Then : # Transféré temps ou hors temps, donc on ne peut pas supprimer
    Call OUINON(mess(196,10717,1)+chr$(10)+mess(195,10717,1),J) From GESECRAN : # L'arrêté de formation a été effectué sur cette inscription. Confirmez-vous la suppression ?
    If J=1 Then
      OK=0
      Return
    Endif
  Endif

 Trbegin [INJ]
 Delete [INJ] Where STG=[M:INS0]STG & SES=[M:INS0]SES & REFNUM=[M:INS0]REFNUM
 If fstat = 1  : # enreg locké
  GLOCK = "$INSJOU" : Goto ROLL_ANN
 Elsif fstat
  Goto AB_ANN
 Endif
Commit
Effzo
Return

$ROLL_ANN
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto VERF_ANU : Endif

$AB_ANN
Rollback
Return



######################################################################################
## Etiquette Ecrans [M:INS0](Entête)
######################################################################################
Subprog AM_STG(VALEUR)
Variable Char    VALEUR()
Call LECTURE("STG",VALEUR,"") From CONTOBJ
#51053
If [M:INS0]SES<>""& GREP<>"D" & GREP<>"C"
 Call LECTURE("HRSES",[M:INS0]SES,"") From CONTOBJ
 If [F:HRSES]STG<>VALEUR
   #Cette session ne dépend pas du stage
   GMESSAGE=mess(30,10717,1)
   mkstat=2 : End
  Endif
Endif
GCURLEG=[F:STG]LEG
If(GLEGFIL<>"" & GCURLEG="")
  GCURLEG=GLEGFIL
Endif
# fin 51053
Gosub MAJ_COMPETENCE
Call MAJ_HABILIT(VALEUR)
End

######################################################################################
# SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini : contrôle du stage
######################################################################################
Subprog C_STG(VALEUR)
Variable Char    VALEUR()
  Call CTL_STG_NON_DEF(VALEUR) From DIVFOR
  If mkstat Then End Endif
End

$MAJ_COMPETENCE
Raz [M:INS4]
For nolign=1 To dim([F:STG]CPCAFT)
 If [F:STG]CPCAFT(nolign-1)="" : Break : Endif
 [M:INS4]CPCAFT(nolign-1)=[F:STG]CPCAFT(nolign-1)
 [M:INS4]LEVAFT(nolign-1)=[F:STG]LEVAFT(nolign-1)
Next
[M:INS4]NBCPC=nolign-1
Affzo[M:INS4]
Return

#**#####################################################################################
#* MABON - 23/08/10 - Sous-pro générique de récupération des cibles
#*!
Subprog CHARGE_TRG_GEN(TRG, IND)
Value    Char    TRG
Variable Integer IND
Local    Integer I, K
Local    Char    TRG_T

  If !clalev([F:HRLIC]) : Local File HRLICAUT [HRLIC] : Endif :#114309 US204

  I=instr(1,TRG,";")
  If I>0 Then
    While instr(1,TRG,";")>0
      I=instr(1,TRG,";")
      TRG_T=mid$(TRG,1,I-1)
      If instr(1,TRG_T,"&")>0 Then
        K=instr(1,TRG_T,"&")
        #114309 US204
#        For [F:ADI] Where NUMTAB=10397 & CODE>=mid$(TRG_T,1,K-1) and CODE<=mid$(TRG_T,K+1,len(TRG_T))
#          GTRGHAB(IND) = [F:ADI]CODE
#          IND += 1
#        Next
        Filter [F:HRLIC] Where (LEG=GCURLEG | LEG="") & ENAFLG=2 & COD>=mid$(TRG_T,1,K-1) & COD<=mid$(TRG_T,K+1,len(TRG_T))
        For [F:HRLIC]
          GTRGHAB(IND) = [F:HRLIC]COD
          IND += 1
        Next
        Filter [F:HRLIC]
        ########################
      Else
        GTRGHAB(IND) = TRG_T
      Endif
      IND += 1
      TRG = right$(TRG,I+1)
    Wend
  Endif
  If instr(1,TRG,"&")>0 Then
    K=instr(1,TRG,"&")
    #114309 US204
#    For [F:ADI] Where NUMTAB=10397 & CODE>=mid$(TRG,1,K-1) and CODE<=mid$(TRG,K+1,len(TRG))
#      GTRGHAB(IND) = [F:ADI]CODE
#      IND += 1
#    Next
    Filter [F:HRLIC] Where (LEG=GCURLEG | LEG="") & ENAFLG=2 & COD>=mid$(TRG,1,K-1) & COD<=mid$(TRG,K+1,len(TRG))
    For [F:HRLIC]
      GTRGHAB(IND) = [F:HRLIC]COD
      IND += 1
    Next
    Filter [F:HRLIC]
    ########################
    IND += 1
  Elsif TRG<>"" Then
    GTRGHAB(IND) = TRG
    IND += 1
  Endif
End

#**#####################################################################################
#* MABON - 23/08/10 - Récupération des habilitations cibles
#*!
Subprog MAJ_HABILIT(CODSTG)
Value Char    CODSTG
Local Integer IND
# FQ75229 - MABON 22/07/11 - GTRGHAB définie sur 10 caractères au lieu de 5, au cas où...
If dim(GTRGHAB)<0 Then Global Char GTRGHAB(10)(1..50) : Endif

  Raz [M:INS6] : IND=1 : Raz GTRGHAB
  For [F:HRSTR] Where COD=CODSTG
    Call CHARGE_TRG_GEN([F:HRSTR]HABTRG, IND) : # Récupération des habilitations cibles
  Next
  Call LECTURE("STG", CODSTG, "") From CONTOBJ
  For nolign=1 To IND-1
    If GTRGHAB(nolign)<>"" Then
      [M:INS6]HABAFT(nolign-1) = GTRGHAB(nolign)
      # FQ71188 - MABON 31/01/11 - On renseigne la date d'obtention des habilitations avec la date de fin de session
      # et non plus avec la date de fin de stage
#      [M:INS6]HABSTR(nolign-1) = [F:STG]ENDVLY
    Else
      Break
    Endif
  Next
  [M:INS6]NBHAB=nolign-1
  Affzo[M:INS6]
End

Subprog C_SES(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("HRSES",VALEUR,"") From CONTOBJ
 If [F:HRSES]FLGCLO=2
  # Cette session est clôturée
  GMESSAGE = mess(60,10717,1)
  mkstat = 2 : End
 Endif
# 51053
# If [M:INS0]STG<>""
#  If [F:HRSES]STG<>[M:INS0]STG
#   #Cette session ne dépend pas du stage
#   GMESSAGE=mess(30,10717,1)
#   mkstat=2 : End
#  Endif
# Else
#  [M:INS0]STG=[F:HRSES]STG
#  #50970
#  #Raz [M:INS0]REFNUM
#  Affzo [M:INS0]
# Endif
 [M:INS0]STG=[F:HRSES]STG
 Affzo [M:INS0]
# Fin 51053
Endif
End

## Session
## En aprés_modif de la session on réinitialise toutes les informations de l'inscription
## en fonction de la session saisie

Subprog AM_SES(VALEUR)
Variable Char    VALEUR()
Local    Integer I,OK,DISPMSG
Local    Char    WLEG(5)
Call LECTURE("HRSES",VALEUR,"") From CONTOBJ
Call LECTURE("STG",[F:HRSES]STG,"") From CONTOBJ
WLEG=""
If [M:INS0]CTRNUM<>"" Then
  Call GET_LEGHRCTR([M:INS0]REFNUM,[M:INS0]CTRNUM,OK,WLEG,DISPMSG) From TOOLSHRLEG
Endif
GCURLEG=[F:HRSES]LEG
If GCURLEG="" & WLEG<>"" Then GCURLEG=WLEG : Endif
If(GLEGFIL<>"" & GCURLEG="")
  # Ligne mise en commentaire, car sinon si connecté FRA avec session sans leg, on ne peut pas sélectionner de matricule/contrat BRI
#  GCURLEG=GLEGFIL
Endif
Gosub MAJ_COMPETENCE
[M:INS0]STG=[F:HRSES]STG
[M:INS0]STA=1
Raz [M:INS2]
#LIPET - 2017-05-13 - X3-29550 - START
# SBA X3PEOP-3476
#
# intialisation du champ : TCRCOD
#
If  [F:HRSES]STG<>"" and [F:STG]TCRCOD<>""
  [M:INS2]TCRCOD=[F:STG]TCRCOD
Else
  [M:INS2]TCRCOD=""
Endif
#LIPET - 2017-05-13 - X3-29550 - END
# FQ85022 - MABON 23/10/12 - Iniialisation du dispositif à Non défini
#LIPET - 2017-06-28 - X3-29550 - START
#[M:INS2]TYPFRTDEM = len(mess(0,10455,1)) : # Non défini
[M:INS2]TYPFRTDEM = '' : # Non défini
#LIPET - 2017-06-28 - X3-29550 - END
# Fin MABON
If GCURLEG="FRA" Then
  [M:INS2]DESNATFIS = [F:HRSES]NATFIS
  [M:INS2]DESCATACN = [F:HRSES]CATACN
Endif
[M:INS0]SES=VALEUR
Gosub INITJOUR
Gosub INITCOUT
Affzo [M:INS0]STG
Affzo [M:INS2]
Affzo [M:INS3]
#LIPET - 2017-11-07 - X3-29550 - START
Call MAJ_HABILIT([F:HRSES]STG)
#LIPET - 2017-11-07 - X3-29550 - END
# FQ71188 - MABON 31/01/11 - On renseigne la date d'obtention des habilitations avec la date de fin de session
# et non plus avec la date de fin de stage
For I=0 To [M:INS6]NBHAB-1
  If [M:INS6]HABSTR(I)=[0/0/0] Then
    [M:INS6]HABSTR(I)=[F:HRSES]ENDDAT
  Endif
Next
Affzo [M:INS6]
End

#####################################
$INITCOUT
Local Decimal MTTIPT, TAUX, MTTTOT
Local Char LEGORG
Local Integer OK
nolign = 1
# Pas de coût relatif au formateur ici
# On prend les coûts prévisionnels "non calculable" de la session
For [COU]COU1 Where TYPCOU=2 & SES=[M:INS0]SES
 Read [ADI]CODE=10451;[F:COU]TYPCRG
#SBA LEG undefined
#If !fstat & (LEG=GCURLEG | LEG="") & [F:ADI]N1=3 & [F:ADI]N2<>2 : # côut non calculé + pas coût formateur
 If !fstat & ([F:ADI]LEG=GCURLEG | [F:ADI]LEG="") & [F:ADI]N1=3 & [F:ADI]N2<>2 : # côut non calculé + pas coût formateur
#SBA fin
#SBA Dem : 81085-364
#SBA add seq1
#I control typfin. we can have blank for TYPCRG ans another legislation for typfin
  Read [ADI]CODE=10462;[F:COU]TYPFIN
  If !fstat & ([F:ADI]LEG=GCURLEG | [F:ADI]LEG="")
   OK=0
   #ajout de la cohérence avec la leg
   Call GET_LEGORFINTRA(2,[F:COU]ORGFIN,OK,LEGORG) From TOOLSHRLEG
    If(OK and (LEGORG="" or LEGORG=GCURLEG))
  #SBA end add seq1
  [M:INS2] = [F:COU]
# MABON - 03/09/10 - On n'a plus de flag DIF : c'est géré maintenant en dispositif comme un autre, donc dans TYPFRT
#  If [F:HRSES]FLGDIF=2
#  If [F:HRSES]TYPFRT=3
#   [M:INS2]DESTYPFRT(nolign-1) = 3
#  Else
#   [M:INS2]DESTYPFRT(nolign-1) = [F:HRSES]TYPFRT
#  Endif
  nolign +=1
#SBA add seq1
  Endif
 Endif
#SBA end add seq1
 Endif

Next
# On calcule les coûts calculables, c'est à dire les charges patronales et salariales du participant
If [M:INS0]REFNUM<>"" & [M:INS0]CTRNUM<>""
  #SBA LEG undefined
 #For [ADI]CODE Where NUMTAB=10451 & (LEG=GCURLEG | LEG="") & N1<3 & N2<>2 :# coût calculé(Sal ou Pat) + pas coût formateur
 For [ADI]CODE Where NUMTAB=10451 & ([F:ADI]LEG=GCURLEG | [F:ADI]LEG="") & N1<3 & N2<>2 :# coût calculé(Sal ou Pat) + pas coût formateur
   # FQ72847 - MABON 07/04/11 - Selon paramètre utilisateur CALCOUPAR, on calcule ou pas les coûts participant
   If [F:ADI]N2=3 | ([F:ADI]N2=1 & GCALCOUPAR=2) Then
    MTTIPT=0 : MTTTOT=0
    # Recherche du taux réel total
    Call TAUX_HORAIRE ([M:INS0]REFNUM,[M:INS0]CTRNUM,[F:HRSES]ENDDAT,TAUX,[F:ADI]N1,2,1) From TRTCOUT
    If !TAUX
     #Taux horaire total non défini
     Call ERREUR ([M:INS0]REFNUM-"/"-[F:ADI]CODE-":"-mess(78,10717,1))From GESECRAN
    Else
  #   MTTTOT=arr(TAUX*[F:HRSES]NBRHOUIPT,0.1) :# Nb d'heures imputables 54948
     MTTTOT=arr(TAUX*[M:INS3]NBRHOUIPT,0.1) :# Nb d'heures imputables
    Endif

    # Recherche du taux réel imputable
    Call TAUX_HORAIRE ([M:INS0]REFNUM,[M:INS0]CTRNUM,[F:HRSES]ENDDAT,TAUX,[F:ADI]N1,2,2) From TRTCOUT
    If !TAUX
     #Taux horaire imputable non défini
     Call ERREUR ([M:INS0]REFNUM-"/"-[F:ADI]CODE-":"-mess(79,10717,1))From GESECRAN
    Else
  #   MTTIPT=arr(TAUX*[F:HRSES]NBRHOUIPT,0.1) :# Nb d'heures imputables 54948
     MTTIPT=arr(TAUX*[M:INS3]NBRHOUIPT,0.1) :# Nb d'heures imputables

    Endif

    If MTTIPT<>0 | MTTTOT<>0
     [M:INS2]TYPCRG(nolign-1)    = [F:ADI]CODE
     If nolign>1
      [M:INS2]TYPFIN(nolign-1)    = [M:INS2]TYPFIN(nolign-2)
      #LIPET - 2017-05-13 - X3-29550 - START
      #[M:INS2]ORGFIN(nolign-1)    = [M:INS2]ORGFIN(nolign-2)
      If [M:INS2]LNKREP(nolign-2)="" | right$([M]LNKREP(nolign-2),len([M]LNKREP(nolign-2)))<>"D"
        [M:INS2]ORGFIN(nolign-1)    = [M:INS2]ORGFIN(nolign-2)
      Else
        [M:INS2]ORGFIN(nolign-1)    = [M:INS2]ORGFIN(nolign-3)
      Endif
      #LIPET - 2017-05-13 - X3-29550 - END
     Else
      Filter [ADI2] Where NUMTAB=10462 & DEFVAL=2
      Read[ADI2]CODE First
      Filter [ADI2]
      #56339
      #If !fstat : [M:INS2]TYPFIN(nolign-1) = [F:ADI]CODE : Endif
      If !fstat : [M:INS2]TYPFIN(nolign-1) = [F:ADI2]CODE : Endif
      #--STA_EXI 66191 LOT 1
  #    Filter [ADI2] Where NUMTAB=10463 & DEFVAL=2
  #    Read[ADI2]CODE First
  #    Filter [ADI2]
  #    #56339
  #    #If !fstat : [M:INS2]ORGFIN(nolign-1) = [F:ADI]CODE : Endif
  #    If !fstat : [M:INS2]ORGFIN(nolign-1) = [F:ADI2]CODE : Endif
      #TODO Que prendre en valeur par défaut OFIDEF
      Call AS_ORGFIN([M:INS2]ORGFIN(nolign-1))
      #--END_EXI 66191 LOT 1

     Endif
     # MABON - 03/09/10 - On n'a plus de flag DIF : c'est géré maintenant en dispositif comme un autre, donc dans TYPFRT
  #   If [F:HRSES]FLGDIF=2
     #ADNGO - 2017-06-28 - X3-29550 - START
#     If [F:HRSES]TYPFRT=3
#      [M:INS2]DESTYPFRT(nolign-1) = 3
#     Else
#      [M:INS2]DESTYPFRT(nolign-1) = [F:HRSES]TYPFRT
#     Endif
     [M:INS2]DESTYPFRT(nolign-1) = [F:HRSES]TYPFRT
     #ADNGO - 2017-06-28 - X3-29550 - END
     [M:INS2]CSTIPTIDV(nolign-1) = MTTIPT
     [M:INS2]CSTTOTIDV(nolign-1) = MTTTOT
     nolign+=1
     #LIPET - 2017-05-13 - X3-29550 - START
     # SBA X3PEOP-3476
     If [M:INS2]TCRCOD<>""
      [L]W_TCRCOD=[M:INS2]TCRCOD
      [L]W_TYPCRG=[M]TYPCRG(nolign-2)
      # Read [F:HRTCR]HRTCR1=[M:INS2]TCRCOD;[M]TYPCRG(nolign-2);[M]TYPFIN(nolign-2);[M:INS2]ORGFIN(nolign-2)
      Gosub GET_RECORD_REP
      If IS_REP
        Local Char TIMESTP(20)
        TIMESTP=timestamp$
        # on
        [M:INS2]TYPFIN(nolign-2)    = [F:HRTCR]TYPFIN
        [M:INS2]ORGFIN(nolign-2)    = [F:HRTCR]ORGFIN

        [M:INS2]TYPCRG(nolign-1)    = [M:INS2]TYPCRG(nolign-2)
        [M:INS2]TYPFIN(nolign-1)    = [M:INS2]TYPFIN(nolign-2)
        [M:INS2]DESTYPFRT(nolign-1) = [M:INS2]DESTYPFRT(nolign-2)
        [M:INS2]ORGFIN(nolign-1)    = [F:HRTCR]ORGFIN2

        [M:INS2]LNKREP(nolign-1)    = TIMESTP+"D" # X3PEOP-3477
        [M:INS2]LNKREP(nolign-2)    = TIMESTP # X3PEOP-3477

        Call  CALCULATE([M:INS2]TCRCOD,[M:INS2]TYPCRG(nolign-2),[M:INS2]TYPFIN(nolign-2),[M:INS2]ORGFIN(nolign-2),[L]W_NBRHOUR,[L]W_NBRNIGHT,MTTIPT,RESULT) From SUBHRTCR
        [M:INS2]CSTIPTIDV(nolign-2) = arr(RESULT(0),0.01)
        [M:INS2]CSTIPTIDV(nolign-1) = arr(RESULT(1),0.01)
        #[M:INS2]CSTIPTIDV(nolign-1) = MTTIPT-[M:INS2]CSTIPTIDV(nolign-2)

         Call  CALCULATE([M:INS2]TCRCOD,[M:INS2]TYPCRG(nolign-2),[M:INS2]TYPFIN(nolign-2),[M:INS2]ORGFIN(nolign-2),[L]W_NBRHOUR,[L]W_NBRNIGHT,MTTTOT,RESULT) From SUBHRTCR
         [M:INS2]CSTTOTIDV(nolign-2) = arr(RESULT(0),0.01)
         [M:INS2]CSTTOTIDV(nolign-1) = arr(RESULT(1),0.01)
         #[M:INS2]CSTTOTIDV(nolign-1) = MTTTOT-[M:INS2]CSTTOTIDV(nolign-2)
         nolign+=1
      Endif
     Endif
     #LIPET - 2017-05-13 - X3-29550 - END
    Endif
  Endif
 Next

Endif
[M:INS2]NBLIG = nolign-1
Call APRES_NBLIG
Call DISPLAY_HIDE() From SUBINSLEG
Return

#####################################
$INITJOUR
nolign=1
Call LECTURE("STG",[M:INS0]STG,"") From CONTOBJ
For [F:SEJ]SEJ0 Where SES=[M:INS0]SES
 [M:INS3]=[F:SEJ]
 If [F:STG]TYPSTG=2 Then
   [M:INS3]DATF(0) = [F:HRSES]ENDDAT
 Endif
 [M:INS3]DAY1(nolign-1)       = day$([M:INS3]DAT(nolign-1))
 [M:INS3]NBRHOUREA(nolign-1)  = [F:SEJ]NBRHOU
 [M:INS3]NBRDAYREA(nolign-1)  = [F:SEJ]NBRJOU
 # MABON 23/08/10 - Récup heures prévues et heures HTT
 If [F:STG]COD<>"" and [F:STG]TYPSTG=2 Then
  [M:INS3]NBRHOUPREV(nolign-1) = [F:SEJ]NBRHOU
  [M:INS3]NBRHOUREA2(nolign-1) = [F:SEJ]NBRHOUHTT
 Endif
 # FQ85022 - MABON 23/10/12 - Récupération du dispositif à partir de celui de la session
 [M:INS3]TYPFRT(nolign-1)     = [F:HRSES]TYPFRT
 # Fin MABON
 nolign+=1
Next
[M:INS3]NBLIG1=nolign-1
Call APRES_NBLIG1
# MABON - 19/08/10 - On rend invisibles certaines colonnes selon qu'on a un stage court ou long
Gosub INIT_COL
Return


## Matricule
## Contrôle que la salarié qui saisit sa demande appartient à la cible du stage

## En aprés_modif du matricule on réinitialise les couts de l'inscription en fonction
## du matricule saisi

Subprog AM_REFNUM(VALEUR)
Variable Char VALEUR()
Local Char    CTR, CATEG(GLONADI)
Local Integer OK
Local Char    CPYSAL(GLONCPY), FCYSAL(GLONFCY), JOTSAL(GLONJOT), POTSAL(GLONPOT)
Local Char    CAT(GLONADI)(0..100), CPY(GLONCPY)(0..100), FCY(GLONFCY)(0..100), JOT(GLONJOT)(0..100)
Local Char    POT(GLONPOT)(0..100), POP(GLONPOP)(0..100)
# FQ61463 - SBA 26/06/2013 - Homogénéisation nom prénom
Call UPD_NAMSRN(VALEUR,"[M:INS0]","NAM","SRN",0,0) From DIVPAYE

If !fstat
 Call GRISE_CTRNUM([F:ID]FLGMULCTR)
 If [F:ID]FLGMULCTR<>2
  Call CHERCHE_CTR(VALEUR,date$,CTR) From DIVPAYE
  Local Integer WOK
  Call CHECK_LEGCTR(VALEUR,CTR,WOK)
  If(WOK=1)
    Call GRISE_CTRNUM(2)
    mkstat=2
    End
  Endif
  Call CAT2483(VALEUR,CTR,CATEG) From SUBDEM
# SBA 06/06/2012 utilisation de la fonction de SUBDEM car même vérif

#  # MABON - 24/08/10 - La catégorie cible n'est plus dans STAGE mais dans STAGETRG, et c'est un champ à valeurs multiples
##  Call LECTURE("STG",[M:INS0]STG,"") From CONTOBJ
#  Read [F:HRSTR]STR0=[M:INS0]STG
##  If [F:STG]CATTRG<>"" & CATEG<>[F:STG]CATTRG & CATEG<>""
#  If !fstat Then
#    If [F:HRSTR]CATTRG<>"" & CATEG<>"" Then
#      Call CALC_TRG([F:HRSTR]CATTRG, "ADI", "453", CAT) From SUBDEM
#      If !find(CATEG, CAT(0..50)) Then
#        OK = 2
#        # Le salarié n'appartient pas à la catégorie ciblée par le stage
#        # FQ74938 - MABON 26/07/11 - Message plus cohérent avec l'erreur
##        Call AVERTIR(mess(10,10717,1),OK) From GESECRAN
#        Call AVERTIR(mess(66,10717,1),OK) From GESECRAN
#        If OK=1 : mkstat=2 : End : Endif
#      Endif
#    Endif
#
#    ## Recherche des infos du salarié/contrat
#    Call INFOS_SAL(VALEUR,CTR,CPYSAL,FCYSAL,JOTSAL,POTSAL) From SUBDEM
#    ## Contrôle que le salarié appartient à la cible société du stage
#    If [F:HRSTR]CPYTRG<>"" and CPYSAL<>"" Then
#      Call CALC_TRG([F:HRSTR]CPYTRG, "COMPANY", "CPY", CPY) From SUBDEM
#      If !find(CPYSAL,CPY(0..50)) Then
#        OK = 2
#        # Le salarié n'appartient pas aux sociétés ciblées par le stage
#        Call AVERTIR(mess(107,10717,1),OK) From GESECRAN
#        If OK=1 : mkstat=2 : End : Endif
#      Endif
#    Endif
#
#    ## Contrôle que le salarié appartient à la cible site du stage
#    If [F:HRSTR]FCYTRG<>"" and FCYSAL<>"" Then
#      Call CALC_TRG([F:HRSTR]FCYTRG, "FACILITY", "FCY", FCY) From SUBDEM
#      If !find(FCYSAL,FCY(0..50)) Then
#        OK = 2
#        # Le salarié n'appartient pas aux sites ciblés par le stage
#        Call AVERTIR(mess(108,10717,1),OK) From GESECRAN
#        If OK=1 : mkstat=2 : End : Endif
#      Endif
#    Endif
#
#    ## Contrôle que le salarié appartient à la cible emploi type du stage
#    If [F:HRSTR]JOTTRG<>"" and JOTSAL<>"" Then
#      Call CALC_TRG([F:HRSTR]JOTTRG, "JOBTYP", "COD", JOT) From SUBDEM
#      If !find(JOTSAL,JOT(0..50)) Then
#        OK = 2
#        # Le salarié n'appartient pas aux emplois types ciblés par le stage
#        Call AVERTIR(mess(109,10717,1),OK) From GESECRAN
#        If OK=1 : mkstat=2 : End : Endif
#      Endif
#    Endif
#
#    ## Contrôle que le salarié appartient à la cible poste du stage
#    If [F:HRSTR]POTTRG<>"" and POTSAL<>"" Then
#      Call CALC_TRG([F:HRSTR]POTTRG, "POSTE", "COD", POT) From SUBDEM
#      If !find(POTSAL,POT(0..50)) Then
#        OK = 2
#        # Le salarié n'appartient pas aux postes ciblés par le stage
#        Call AVERTIR(mess(110,10717,1),OK) From GESECRAN
#        If OK=1 : mkstat=2 : End : Endif
#      Endif
#    Endif
#
#    ## Contrôle que le salarié appartient à la cible population du stage
#    If [F:HRSTR]POPTRG<>"" Then
#      Call CALC_TRG([F:HRSTR]POPTRG, "POPUL", "COD", POP) From SUBDEM
#      OK=1
#      For I=0 To dim(POP)-1
#        Read [F:HRPOA]POA0=POP(I);VALEUR
#        If !fstat Then OK=2 : Break : Endif
#      Next
#      If OK=1 Then
#        OK = 2
#        # Le salarié n'appartient pas aux populations ciblées par le stage
#        Call AVERTIR(mess(111,10717,1),OK) From GESECRAN
#        If OK=1 : mkstat=2 : End : Endif
#      Endif
#    Endif
#  Endif
#  If [F:STG]TRG<>""
#   Gosub OUVRE From WPDEFTABLE
#   MATRI  = VALEUR
#   DATMAT = date$
#   Gosub LECEMP From WPDEFTABLE
#   If evalue([F:STG]TRG)=0
#    OK = 2
#    # Le salarié n'appartient pas au critère "Autre sélection" visé par le stage
#    Call AVERTIR(mess(10,10717,1),OK) From GESECRAN
#    If OK=1 : mkstat=2 : End : Endif
#   Endif
#  Endif
# SBA fin 06/06/2012
  Call VERIF_CIBLEBASE(VALEUR,CTR,[M:INS0]STG)From SUBDEM
  If(mkstat=2)
      Call GRISE_CTRNUM(2)
      End
   Endif
  [M:INS0]CTRNUM = CTR
  Call ADD_LEG(CTR)
  Read [HRCTR]CTR0(2)=VALEUR;CTR
  If !fstat
    Call LECTURE("FCY",[HRCTR]ETRFCY,"") From CONTOBJ
    Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
    GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
  Endif
  If GCURLEG="FRA" Then
    [M:INS2]CATFRT = CATEG
    Affzo [INS2]CATFRT
  Endif
  Affzo [INS0]CTRNUM
  #LIPET - 2017-05-13 - X3-29550 - START
  Affzo [INS2]CATFRT
  #LIPET - 2017-05-13 - X3-29550 - END
 Endif
Else
 Call GRISE_CTRNUM(1)
Endif
Call LECTURE("HRSES",[M:INS0]SES,"") From CONTOBJ
Effzo [M:INS2]20-25
[M:INS0]REFNUM=VALEUR
Gosub INITCOUT
Affzo [M:INS2]20-25
End


#SBA US1840 81085 20/08/2013
Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()
#SBA ne sert à rien, suppression de l'action dans le masque INS0
#If [M:INS0]CTRNUM=""
#  SEGAY - 81085 - 30/05/12 Filter on legislation GLEGFIL
# Call SELCTR([M:INS0]REFNUM,date$,date$,VALEUR) From DIVPAYE

# Call LECTURE("HRSES",[M:INS0]SES,"") From CONTOBJ

 #Call SELCTRMLEG([M:INS0]REFNUM,date$,date$,[F:HRSES]LEG,VALEUR) From TOOLSHRLEG
#Endif
End

Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
Call CAT2483([M:INS0]REFNUM,VALEUR,[M:INS2]CATFRT) From SUBDEM
If GCURLEG="FRA" Then
  Affzo [M:INS2]CATFRT
Endif
Local Char WLEG(GLONADI)
WLEG=GCURLEG
Read [HRCTR]CTR0(2)=[M:INS0]REFNUM;VALEUR
If !fstat
  Call LECTURE("FCY",[HRCTR]ETRFCY,"") From CONTOBJ
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
Endif
#SBA if curleg is different I renitialize actual individual costs
#SBA Dem : 81085-364
If WLEG<>GCURLEG or GREP="C"
    Effzo [M:INS2]20-25
    Gosub INITCOUT
    Affzo [M:INS2]20-25
Endif
#  #SBA Dem : 81085-364

End


