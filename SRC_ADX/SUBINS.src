Subprog WRKRER(KRONO,ADEST)
Value    Char    KRONO
Value    Char    ADEST

 Update [F:AWS2] Where CHRONO = KRONO & DEST = ADEST
&                With  VALCTX8 = DEST

End

#**
#* Sous-pro utilisé dans le workflow de délégation INSSTGDEL, afin d'aider à déterminer si le workflow est éligible à
#* la délégation ou non
#*!
Funprog GETUSERDEL(USER,CODAWH)
Value Char    USER
Value Char    CODAWH
Local Char    NATURE,DEST_DEL
Local Integer I

  If clalev([F:AWH2])=0 : Local File AWRKPARH [AWH2] : Endif
  Read [F:AWH2]AWH0=CODAWH
  DEST_DEL=USER
  I=1
  If [F:AWH2]OPTDEL(I-1)=4 : # Premier de libre
    Filter [AWU2] Where USER=DEST_DEL & VLYSTR<=date$ & (VLYEND=[0/0/0] or VLYEND>=date$)
&                     & (NATURE="" or NATURE=[F:AWH2]NATURE(I-1))
&                     & TYPDEL=2 : # Pouvoir de signature
    Read [AWU2] First
    Filter [AWU2]
    If !fstat
      DEST_DEL = [F:AWU2]USRDEL : # Le premier libre avec pouvoir de signature devient destinataire principal
    Endif
  Endif
End DEST_DEL

