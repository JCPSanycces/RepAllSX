Subprog APRES_NBLIG
Default Mask [M:INS2]
#LIPET - 2017-05-13 - X3-29550 - START
# SBA X3PEOP-3476
If status=6
  Gosub RESET_FLGCHG
Endif
Gosub RESET_LNKREP
#LIPET - 2017-05-13 - X3-29550 - END
