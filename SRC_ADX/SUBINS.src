Subprog C_TYPCRG(VALEUR)
Variable Char    VALEUR()
If clalev([F:ADI])=0 : Local File ATABDIV     [ADI] : Endif
Read[F:ADI]CODE=10451;VALEUR
If !fstat & ([F:ADI]LEG=GCURLEG | [F:ADI]LEG="") & [F:ADI]N2=2
 GMESSAGE=VALEUR-":"-mess(35,10717,1)-mess(71,10717,1) :#Type de coût non autorisé au niveau Inscription
 mkstat=2 : End
Endif
End

Subprog AS_TYPFIN(VALEUR)
Variable Char    VALEUR()
Call AS_TYPFIN(VALEUR) From SUBSTG
End

Subprog AS_ORGFIN(VALEUR)
Variable Char    VALEUR()
#--STA_EXI 66191 LOT 1
Local Char LOFIDEF : #--SEGAY STA_EXI 66191 LOT 1
Local Char LSAVOFIDEF : #--SEGAY STA_EXI 66191 LOT 1
Local Char CPYSAL(GLONCPY), FCYSAL(GLONFCY), JOTSAL(GLONJOT), POTSAL(GLONPOT)

#Dans l'Inscription la valeur par défaut OFIDEF peut-être au niveau de société du matricule
#Call AS_ORGFIN(VALEUR) From SUBSTG
LOFIDEF = ""
## Recherche des infos du salarié/contrat
Call INFOS_SAL([M:INS0]REFNUM,[M:INS0]CTRNUM,CPYSAL,FCYSAL,JOTSAL,POTSAL) From SUBDEM
Call PARAM(CPYSAL,"OFIDEF",LOFIDEF) From ADOVAL
If dim(GOFIDEF )>0
    LSAVOFIDEF =GOFIDEF
    GOFIDEF = LOFIDEF
    Call AS_ORGFIN(VALEUR) From SUBSTG
    GOFIDEF = LSAVOFIDEF
Endif
#--END_EXI 66191 LOT 1
End

Subprog C_ORGFIN(VALEUR)
Variable Char    VALEUR()
# On teste l'unicité de la ligne sur les zones : TYPCRG/TYPFIN/ORGFIN
Local Integer I, OK
# check value
#Local Char TMPLEG, TMPSEL
#TMPLEG=func FGET_LEGSEL(4)
#TMPSEL=func TOOLSHRLEG.FGET_LEGORFINTRA(2,VALEUR)
#If(TMPLEG<>"" and TMPSEL<>TMPLEG)
#GMESSAGE=mess(285,10717,1)-TMPLEG
#mkstat=2
#End
#Endif
# SEGAY 81085 US 460
Local Integer INDEX : INDEX=3
Local Integer WOK : WOK=1
Call CHECKLEG_LIGCOST([M]TYPCRG(nolign-1),[M]TYPFIN(nolign-1),VALEUR,INDEX,1,[M]WLEGLIG(nolign-1),WOK) From SUBSTG

If mkstat=2
  End
Endif
OK = 1
For I=0 To nolign-2
 If [M]TYPCRG(I)=[M]TYPCRG(nolign-1) & [M]TYPFIN(I)=[M]TYPFIN(nolign-1) & [M]ORGFIN(I)=VALEUR
  OK = 0 : Break
 Endif
Next
If OK=1
 For I=nolign To [M:INS2]NBLIG
  If [M]TYPCRG(I)=[M]TYPCRG(nolign-1) & [M]TYPFIN(I)=[M]TYPFIN(nolign-1) & [M]ORGFIN(I)=VALEUR
   OK = 0 : Break
  Endif
 Next
Endif
If OK=0
 # Ligne de coût déjà existante en ligne xx
 GMESSAGE = mess(84,10717,1)-num$(I+1)
 mkstat = 2 : End
Endif
End

Subprog D_DESTYPFRT(VALEUR)
#ADNGO - 2017-06-28 - X3-29547 - START
#Variable Integer VALEUR
Variable Char VALEUR
#ADNGO - 2017-06-28 - X3-29547 - END
If clalev([F:DML])=0 : Local File DEMLIG   [DML] : Endif
If clalev([F:HRSES])=0 : Local File SESSIONS [HRSES] : Endif
If [M:INS2]DEM<>""
 Filter [DML] Where DEMNUM=[M:INS2]DEM & EMP=[M:INS0]REFNUM
 Read[DML]DML0 First
 Filter [DML]
 If !fstat
  VALEUR = [F:DML]DESTYPFRT
 Endif
Else
 Call LECTURE("HRSES",[M:INS0]SES,"") From CONTOBJ
 If !fstat
  VALEUR = [F:HRSES]TYPFRT
 Endif
Endif
End

Subprog AS_DESTYPFRT(VALEUR)
#ADNGO - 2017-06-28 - X3-29547 - START
#Variable Integer VALEUR
Variable Char VALEUR
#GMENLOC(len(mess(0,10455,1)))=1
#ADNGO - 2017-06-28 - X3-29547 - END
End

Subprog C_DESTYPFRT(VALEUR)
#ADNGO - 2017-06-28 - X3-29547 - START
#Variable Integer VALEUR
Variable Char VALEUR
#ADNGO - 2017-06-28 - X3-29547 - END
Local Integer NBFLG
If clalev([F:DML])=0 : Local File DEMLIG   [DML] : Endif
If clalev([F:HRSES])=0 : Local File SESSIONS [HRSES] : Endif
#ADNGO - 2017-06-28 - X3-29547 - START
#If VALEUR=len(mess(0,10455,1)) :#Non défini
If VALEUR='' :#Non défini
#ADNGO - 2017-06-28 - X3-29547 - END
 GMESSAGE = mess(26,10717,1) # Il faut au moins saisir un dispositif
 mkstat=2 : End
Endif
If [M:INS2]DEM<>""
 Filter [DML] Where DEMNUM=[M:INS2]DEM & EMP=[M:INS0]REFNUM
 Read[DML]DML0 First
 Filter [DML]
 #ADNGO - 2017-06-28 - X3-29547 - START
 #If !fstat & [F:DML]DESTYPFRT<>VALEUR & [F:DML]DESTYPFRT<>len(mess(0,10455,1))
 If !fstat & [F:DML]DESTYPFRT<>VALEUR & [F:DML]DESTYPFRT<>''
 #ADNGO - 2017-06-28 - X3-29547 - END
  # Dispositif incompatible avec la demande
  #ADNGO - 2017-06-28 - X3-29547 - START
  #GMESSAGE = mess(41,10717,1)-"\"-mess([F:DML]DESTYPFRT,10455,1)
  GMESSAGE = mess(41,10717,1)-"\"-[F:DML]DESTYPFRT
  #ADNGO - 2017-06-28 - X3-29547 - END
  GERR = 3 : End
 Endif
Else
 Call LECTURE("HRSES",[M:INS0]SES,"") From CONTOBJ
 # MABON - 03/09/10 - On n'a plus de flag DIF : c'est géré maintenant en dispositif comme un autre, donc dans TYPFRT
# If [F:HRSES]TYPFRT<>VALEUR & ([F:HRSES]FLGDIF<>2 | VALEUR<>3) & [F:HRSES]TYPFRT<>len(mess(0,10455,1))
#ADNGO - 2017-06-28 - X3-29547 - START
 #If [F:HRSES]TYPFRT<>VALEUR & ([F:HRSES]TYPFRT<>3 | VALEUR<>3) & [F:HRSES]TYPFRT<>len(mess(0,10455,1))
 If [F:HRSES]TYPFRT<>VALEUR & ([F:HRSES]TYPFRT<>'' | VALEUR<>3) & [F:HRSES]TYPFRT<>''
#ADNGO - 2017-06-28 - X3-29547 - END
  # Dispositif incompatible avec la session
  #ADNGO - 2017-06-28 - X3-29547 - START
  #GMESSAGE = mess(23,10717,1)-"\"-mess([F:HRSES]TYPFRT,10455,1)
  GMESSAGE = mess(23,10717,1)-"\"-[F:HRSES]TYPFRT
  #ADNGO - 2017-06-28 - X3-29547 - END
  GERR = 3 : End
 Endif
Endif
End

Subprog AS_CSTTOTIDV(VALEUR)
Variable Decimal VALEUR
Local Decimal TAUX
Call LECTURE("HRSES",[M:INS0]SES,"") From CONTOBJ
If clalev([F:ADI])=0 : Local File ATABDIV     [ADI] : Endif
Read[F:ADI]CODE=10451;[M:INS2]TYPCRG(nolign-1)
If !fstat & ([F:ADI]LEG=GCURLEG | [F:ADI]LEG="") & [F:ADI]N1<3
 If VALEUR=0
  Call TAUX_HORAIRE ([M:INS0]REFNUM,[M:INS0]CTRNUM,[F:HRSES]ENDDAT,TAUX,[F:ADI]N1,2,1) From TRTCOUT
  If !TAUX
   # FQ68702 - MABON 29/10/10 - quand on saisit, plus besoin de mettre le message
   #Taux horaire total non défini
#   Call ERREUR ([M:INS0]REFNUM-":"-mess(78,10717,1))From GESECRAN
  Else
   VALEUR=arr(TAUX*[F:HRSES]NBRHOUIPT,0.1) :# Nb d'heures imputables
  Endif
 Endif
 mkstat=2
Endif
# 54948 : si Calculé = salarial ou patronal & type = participant alors modifiable
If [F:ADI]N1<>3 & [F:ADI]N2=1 : mkstat=0 : Endif

End

Subprog AS_CSTIPTIDV(VALEUR)
Variable Decimal VALEUR
Local Decimal TAUX
Call LECTURE("HRSES",[M:INS0]SES,"") From CONTOBJ
#Frais d'hebergement imputable individuel = 5*MG*Nb jours
If [M]TYPCRG(nolign-1)="HEB"
 If  VALEUR=0
  Local Decimal VALMG
  Call RECUP_MG("", "", [M:INS0]REFNUM,[F:HRSES]ENDDAT,VALMG) From TRTCOUT
  If [M]CSTTOTIDV(nolign-1)<arr(5*VALMG*[F:HRSES]NBRDAY,0.1)
   VALEUR=[M]CSTTOTIDV(nolign-1)
  Else
   VALEUR=arr(5*VALMG*[F:HRSES]NBRDAY,0.1)
  Endif
 Endif
Else
 If clalev([F:ADI])=0 : Local File ATABDIV     [ADI] : Endif
 Read[F:ADI]CODE=10451;[M:INS2]TYPCRG(nolign-1)
 If !fstat & ([F:ADI]LEG=GCURLEG | [F:ADI]LEG="") & [F:ADI]N1<3
  If VALEUR=0
   Call TAUX_HORAIRE ([M:INS0]REFNUM,[M:INS0]CTRNUM,[F:HRSES]ENDDAT,TAUX,[F:ADI]N1,2,2) From TRTCOUT
   If !TAUX
    # FQ68702 - MABON 29/10/10 - quand on saisit, plus besoin de mettre le message
    #Taux horaire imputable non défini
#    Call ERREUR ([M:INS0]REFNUM-":"-mess(79,10717,1))From GESECRAN
   Else
    VALEUR=arr(TAUX*[F:HRSES]NBRHOUIPT,0.1) :# Nb d'heures imputables
   Endif
  Endif
  mkstat=2
 Endif
 # 54948 : si Calculé = salarial ou patronal & Type = participant alors modifiable
 If [F:ADI]N1<>3 & [F:ADI]N2=1 : mkstat=0 : Endif
Endif
# SEGAY 22/06/12 - 81850 - Initialisation de CSTIPTIDV avec CSTTOTIDV si celui-ci est renseigné
If VALEUR=0  & [M]CSTTOTIDV(nolign-1)<>0 : VALEUR=[M]CSTTOTIDV(nolign-1) : Endif
End

Subprog C_CSTIPTIDV(VALEUR)
Variable Decimal VALEUR
# FQ71546 - MABON 14/02/11 - Le coût total peut être négatif
If [M:INS2]CSTTOTIDV(nolign-1)<>0 & [M:INS2]CSTTOTIDV(nolign-1)>0 Then
  If VALEUR>[M:INS2]CSTTOTIDV(nolign-1) Then
    #Coût imputable supérieur au coût total
    GMESSAGE=mess(7,10717,1)
    mkstat=2 : End
  Endif
  # FQ71546 - MABON 14/02/11 - Si le coût total est positif, le coût imputable doit l'être aussi
  If VALEUR<0 Then
    GMESSAGE=mess(231,10717,1) :# Le coût imputable doit être positif
    mkstat=2 : End
  Endif
Endif
If [M:INS2]CSTTOTIDV(nolign-1)<0 Then
  If VALEUR<=0 Then
    If abs(VALEUR)>abs([M:INS2]CSTTOTIDV(nolign-1)) Then
      #Coût imputable supérieur au coût total
      GMESSAGE=mess(7,10717,1)
      mkstat=2 : End
    Endif
  Else
    GMESSAGE=mess(228,10717,1) : # Le coût imputable ne peut pas être supérieur à 0
    mkstat=2 : End
  Endif
Endif
# Fin MABON
If [M]TYPCRG(nolign-1)="HEB"
 Call LECTURE("HRSES",[M:INS0]SES,"") From CONTOBJ
 Local Decimal VALMG
 Call RECUP_MG("", "", [M:INS0]REFNUM,[F:HRSES]ENDDAT,VALMG) From TRTCOUT
 If VALEUR>arr(5*VALMG*[F:HRSES]NBRDAY,0.1)
  GMESSAGE=mess(51,10717,1) :#Coût imputable supérieur au minimum garanti
  mkstat=2 : End
 Endif
Endif
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran INS3) 29/04/2005 16:02:58 (DBA)
######################################################################################
Subprog APRES_NBLIG1
Local Integer I
Raz [M:INS3]NBRDAY
Raz [M:INS3]NBRHOUIPT
Raz [M:INS3]NBRDAY2
Raz [M:INS3]NBRHOUIPT2
#LIPET - 2017-05-13 - X3-29550 - START
Raz [M:INS3]NBRNGT # X3PEOP-3477
#LIPET - 2017-05-13 - X3-29550 - END
For I=1 To [M:INS3]NBLIG1+1
 [M:INS3]NBRDAY     += [M:INS3]NBRDAYREA(I-1)
 [M:INS3]NBRHOUIPT  += [M:INS3]NBRHOUREA(I-1)
 [M:INS3]NBRDAY2    += [M:INS3]NBRDAYREA2(I-1)
 [M:INS3]NBRHOUIPT2 += [M:INS3]NBRHOUREA2(I-1)
Next
#LIPET - 2017-05-13 - X3-29550 - START
# X3PEOP-3477 Nbre Night
[M:INS3]NBRNGT= func SUBHRSES.CALCULATE_NBNIGHT([F:STG]TYPSTG, [M:INS3]NBLIG1, "[M:INS3]")
#LIPET - 2017-05-13 - X3-29550 - END
Affzo[M:INS3]NBRDAY, NBRHOUIPT, NBRDAY2, NBRHOUIPT2
End

Subprog C_NBLIG1
## Bloque la saisie dans le tableau de présence si inscription validée ou temps à valider
If ([M:INS0]STA=3 | [M:INS3]FLGTPS=2) & !adxgtb
 mkstat=2 : End
Endif
End

##

Subprog AM_DAT(VALEUR)
Variable Date    VALEUR
[M]DAY1(nolign-1) = day$(VALEUR)
End

Subprog C_DAT(VALEUR)
Variable Date    VALEUR
Call UNICITE(VALEUR,[M]DAT) From OBJDIV
If mkstat=2 : End : Endif
If clalev([F:HRSES])=0  : Local File SESSIONS   [HRSES] : Endif
Call LECTURE("HRSES",[M:INS0]SES,"") From CONTOBJ
If VALEUR<[F:HRSES]STRDAT | VALEUR>[F:HRSES]ENDDAT
 # Date en dehors de la période de la session
 GMESSAGE = mess(8,10717,1)
 mkstat = 2 : End
Endif
End

##

Subprog AS_DEBTIM(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & nolign-1>0
 VALEUR=[M:INS3]DEBTIM(nolign-2)
Endif
End

Subprog B1_DEBTIM(VALEUR)
Variable Char    VALEUR()
Local Integer ZONE
Call CONTHM(VALEUR)From OBJDIV
ZONE=3
Goto B1_NBRREA

##

Subprog AS_FINTIM(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & nolign-1>0
 VALEUR=[M:INS3]FINTIM(nolign-2)
Endif
End

Subprog C_FINTIM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M:INS3]DEBTIM(nolign-1)
 #Heure incorrecte
 GMESSAGE = mess(69,134,1)
 mkstat = 2 : End
Endif
End

Subprog B1_FINTIM(VALEUR)
Variable Char    VALEUR()
Local Integer ZONE
Call CONTHM(VALEUR)From OBJDIV
ZONE=4
Goto B1_NBRREA

##

Subprog AS_NBRTIMBRK(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 & nolign-1>0
 VALEUR=[M:INS3]NBRTIMBRK(nolign-2)
Endif
End

Subprog C_NBRTIMBRK(VALEUR)
Variable Decimal VALEUR
Local Decimal DIFF
If [M:INS3]DEBTIM(nolign-1)<>"" & [M:INS3]FINTIM(nolign-1)<>""
 Call SUMHRS([M:INS3]DEBTIM(nolign-1), [M:INS3]FINTIM(nolign-1), DIFF)From SUBHRSES
 If VALEUR & VALEUR>=DIFF
  #Temps de pause supérieur ou égal à la durée de la session
  GMESSAGE=mess(73,10717,1)
  mkstat=2 : End
 Endif
Endif
End

Subprog B1_NBRTIMBRK(VALEUR)
Variable Decimal VALEUR
Local Integer ZONE
ZONE=5
Goto B1_NBRREA

##

Subprog AS_NBRHOUREA(VALEUR)
Variable Decimal VALEUR
Local    Decimal DIFF

  If VALEUR=0 & [M:INS3]DEBTIM(nolign-1)<>"" & [M:INS3]FINTIM(nolign-1)<>"" Then
   Call SUMHRS([M:INS3]DEBTIM(nolign-1), [M:INS3]FINTIM(nolign-1), DIFF)From SUBHRSES
   VALEUR=DIFF-[M:INS3]NBRTIMBRK(nolign-1)
  Endif
End

Subprog C_NBRHOUREA(VALEUR)
Variable Decimal VALEUR
Local Decimal DIFF
# MABON - 19/08/10 - La vérification ne se fait que si on n'est pas dans le cadre d'un stage long
#If [F:STG]TYPSTG<>2 Then
  If [M:INS3]DEBTIM(nolign-1)<>"" & [M:INS3]FINTIM(nolign-1)<>""
   Call SUMHRS([M:INS3]DEBTIM(nolign-1), [M:INS3]FINTIM(nolign-1), DIFF)From SUBHRSES
   If VALEUR>DIFF-[M:INS3]NBRTIMBRK(nolign-1)
    #Nombre d'heures en dehors de l'horaire de la session
    GMESSAGE=mess(46,10717,1) : mkstat=2 : End
   Endif
  Endif
#Endif
End

Subprog AM_NBRHOUREA(VALEUR)
Variable Decimal VALEUR
Local    Decimal DIFF
If VALEUR=0
 [M:INS3]NBRDAYREA(nolign-1) = 0
Endif
If VALEUR>0 Then
  If [M:INS3]DEBTIM(nolign-1)<>"" & [M:INS3]FINTIM(nolign-1)<>"" Then
    Call SUMHRS([M:INS3]DEBTIM(nolign-1), [M:INS3]FINTIM(nolign-1), DIFF)From SUBHRSES
    HRTOT=DIFF-[M:INS3]NBRTIMBRK(nolign-1)
    If VALEUR=HRTOT Then
      [M:INS3]NBRDAYREA(nolign-1)=1
    Else
      [M:INS3]NBRDAYREA(nolign-1)=arr(VALEUR/HRTOT,0.01)
    Endif
  Endif
Endif
End

Subprog B1_NBRHOUREA(VALEUR)
Variable Decimal VALEUR
Local Integer ZONE
ZONE=1
Goto B1_NBRREA

##

Subprog AS_NBRDAYREA(VALEUR)
Variable Decimal VALEUR
Local    Decimal DIFF, HRTOT

If VALEUR=0 & [M:INS3]NBRHOUREA(nolign-1)=0
 mkstat=2 : End
Endif

If VALEUR=0 & [M:INS3]NBRHOUREA(nolign-1)>0 Then
  If [M:INS3]DEBTIM(nolign-1)<>"" & [M:INS3]FINTIM(nolign-1)<>"" Then
    Call SUMHRS([M:INS3]DEBTIM(nolign-1), [M:INS3]FINTIM(nolign-1), DIFF)From SUBHRSES
    HRTOT=DIFF-[M:INS3]NBRTIMBRK(nolign-1)
    If [M:INS3]NBRHOUREA(nolign-1)=HRTOT Then
      VALEUR=1
    Else
      VALEUR=arr([M:INS3]NBRHOUREA(nolign-1)/HRTOT,0.01)
    Endif
  Endif
Endif
End

Subprog C_NBRDAYREA(VALEUR)
Variable Decimal VALEUR
# MABON - 19/08/10 - La vérification ne se fait que si on n'est pas dans le cadre d'un stage long
If [F:STG]TYPSTG<>2 Then
  If VALEUR>1
   #Pas plus de 1 jour par journée calendaire
   GMESSAGE=mess(63,10717,1)  : mkstat=2 : End
  Endif
Endif
If VALEUR=0 & [M:INS3]NBRHOUREA(nolign-1)>0
 # Des heures ont été saisies
 GMESSAGE = mess(87,10717,1)
 mkstat = 2 : End
Endif
End

Subprog AM_NBRDAYREA(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 & [M:INS3]NBRHOUREA(nolign-1)<>0
 [M:INS3]NBRHOUREA(nolign-1) = 0 : Affzo [M:INS3]NBRHOUREA(nolign-1)
Endif
End

Subprog B1_NBRDAYREA(VALEUR)
Variable Decimal VALEUR
Local Integer ZONE
ZONE=2
Goto B1_NBRREA

##

Subprog AS_NBRHOUREA2(VALEUR)
Variable Decimal VALEUR
Local    Decimal DIFF

  If VALEUR=0 & [M:INS3]DEBTIM(nolign-1)<>"" & [M:INS3]FINTIM(nolign-1)<>"" Then
    Call SUMHRS([M:INS3]DEBTIM(nolign-1), [M:INS3]FINTIM(nolign-1), DIFF)From SUBHRSES
    VALEUR=DIFF-[M:INS3]NBRTIMBRK(nolign-1)-[M:INS3]NBRHOUREA(nolign-1)
  Endif
End

Subprog C_NBRHOUREA2(VALEUR)
Variable Decimal VALEUR
Local Decimal DIFF
If [M:INS3]DEBTIM(nolign-1)<>"" & [M:INS3]FINTIM(nolign-1)<>""
 Call SUMHRS([M:INS3]DEBTIM(nolign-1), [M:INS3]FINTIM(nolign-1), DIFF)From SUBHRSES
 If (VALEUR>DIFF-[M:INS3]NBRTIMBRK(nolign-1))
&| (VALEUR+[M:INS3]NBRHOUREA(nolign-1)>DIFF-[M:INS3]NBRTIMBRK(nolign-1))
  # Nb d'heures en dehors de l'horaire de la session
  GMESSAGE = mess(46,10717,1)
  mkstat = 2 : End
 Endif
Endif
End

Subprog AM_NBRHOUREA2(VALEUR)
Variable Decimal VALEUR
Local    Decimal DIFF
If VALEUR=0
 [M:INS3]NBRDAYREA2(nolign-1) = 0
Endif
If VALEUR>0 Then
  If [M:INS3]DEBTIM(nolign-1)<>"" & [M:INS3]FINTIM(nolign-1)<>"" Then
    Call SUMHRS([M:INS3]DEBTIM(nolign-1), [M:INS3]FINTIM(nolign-1), DIFF)From SUBHRSES
    HRTOT=DIFF-[M:INS3]NBRTIMBRK(nolign-1)
    If VALEUR=HRTOT Then
      [M:INS3]NBRDAYREA2(nolign-1)=1
    Else
      If [M:INS3]NBRHOUREA(nolign-1)=0 Then
        [M:INS3]NBRDAYREA2(nolign-1)=arr(VALEUR/HRTOT,0.01)
        [M:INS3]NBRHOUREA(nolign-1)=HRTOT-VALEUR
        [M:INS3]NBRDAYREA(nolign-1)=1-[M:INS3]NBRDAYREA2(nolign-1)
        Affzo [M:INS3]NBRHOUREA(nolign-1), NBRDAYREA(nolign-1)
      Else
        [M:INS3]NBRDAYREA2(nolign-1)=1-[M:INS3]NBRDAYREA(nolign-1)
      Endif
    Endif
  Endif
Endif
End

Subprog B1_NBRHOUREA2(VALEUR)
Variable Decimal VALEUR
Local Integer ZONE
ZONE=6
Goto B1_NBRREA
End

##

Subprog AS_NBRDAYREA2(VALEUR)
Variable Decimal VALEUR
Local    Decimal DIFF

  If VALEUR=0 & [M:INS3]NBRHOUREA2(nolign-1)=0
    mkstat=2 : End
  Endif

  If VALEUR=0 Then
    VALEUR=1-[M:INS3]NBRDAYREA(nolign-1)
  Endif
End

Subprog C_NBRDAYREA2(VALEUR)
Variable Decimal VALEUR
If VALEUR>1 | [M:INS3]NBRDAYREA(nolign-1)+VALEUR>1
 # Pas plus de 1 jour par journée calendaire
 GMESSAGE = mess(63,10717,1)
 mkstat = 2 : End
Endif
If VALEUR=0 & [M:INS3]NBRHOUREA2(nolign-1)>0
 # Des heures ont été saisies
 GMESSAGE = mess(87,10717,1)
 mkstat = 2 : End
Endif
End

Subprog AM_NBRDAYREA2(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 & [M:INS3]NBRHOUREA2(nolign-1)<>0
 [M:INS3]NBRHOUREA2(nolign-1) = 0 : Affzo [M:INS3]NBRHOUREA2(nolign-1)
Endif
End

Subprog B1_NBRDAYREA2(VALEUR)
Variable Decimal VALEUR
Local Integer ZONE
ZONE=7
Goto B1_NBRREA
End


##

Subprog AS_TYPFRT(VALEUR)
#Variable Integer VALEUR
Variable Char   VALEUR() : # JML
#GMENLOC(len(mess(0,10455,1)))=1

  #VALEUR = [F:HRSES]TYPFRT
End

Subprog B1_TYPFRT(VALEUR)
#Variable Integer VALEUR
Variable Char   VALEUR() : # JML
Local Integer ZONE
ZONE=8
Goto B1_NBRREA
End

##

$B1_NBRREA
Local Decimal DIFF
NOL = nolign-1
For I=NOL To [M]NBLIG1-1
 Case ZONE
  When 1 : [M:INS3]NBRHOUREA(I)=VALEUR
  When 2 : [M:INS3]NBRDAYREA(I)=VALEUR
  When 3 : Call SUMHRS(VALEUR, [M:INS3]FINTIM(I), DIFF) From SUBHRSES
           If DIFF-[M:INS3]NBRTIMBRK(I)>0
            [M:INS3]NBRHOUREA(I)=DIFF-[M:INS3]NBRTIMBRK(I)
            [M:INS3]DEBTIM(I)=VALEUR
           Endif
  When 4 : Call SUMHRS([M:INS3]DEBTIM(I),VALEUR, DIFF) From SUBHRSES
           If DIFF-[M:INS3]NBRTIMBRK(I)>0
            [M:INS3]NBRHOUREA(I)=DIFF-[M:INS3]NBRTIMBRK(I)
            [M:INS3]FINTIM(I)=VALEUR
           Endif
  When 5 : Call SUMHRS([M:INS3]DEBTIM(I),[M:INS3]FINTIM(I), DIFF) From SUBHRSES
           If DIFF-VALEUR>0
            [M:INS3]NBRHOUREA(I)=DIFF-VALEUR
            [M:INS3]NBRTIMBRK(I)=VALEUR
           Endif
  When 6: [M:INS3]NBRHOUREA2(I) = VALEUR
  When 7: [M:INS3]NBRDAYREA2(I) = VALEUR
  When 8: [M:INS3]TYPFRT(I)     = VALEUR
 Endcase
Next
Call APRES_NBLIG1
Affzo [M:INS3]
End


######################################################################################
Subprog TUNINS(CLECUR1,CLECUR2,CLECUR3)
Value    Char    CLECUR1 :#stage
Value    Char    CLECUR2 :#session
Value    Char    CLECUR3 :#matricule
Local Char VSES (GLONHRSES)
Local Char VSTGEMP (50)(0..1)
VSES=CLECUR2
VSTGEMP(0)=CLECUR1
VSTGEMP(1)=CLECUR3
Call OBJET_CHAR(VSES,"INS",VSTGEMP) From GOBJET
End


######################################################################################
## Etiquette écran INS4
######################################################################################

Subprog C_CPCAFT(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:INS4]CPCAFT(0..[M:INS4]NBCPC-1)) From OBJDIV
If mkstat=2 : End : Endif
Call LECTURE("STG",[M:INS0]STG,"") From CONTOBJ
If !find (VALEUR, [F:STG]CPCAFT(0..dim([F:STG]CPCAFT)-1))
 #Compétence non définie dans le stage
  GMESSAGE=mess(9,10720,1)
 mkstat=2 : End
Endif
End

Subprog AS_LEVAFT(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Call LECTURE("STG",[M:INS0]STG,"") From CONTOBJ
 I=find ([M:INS4]CPCAFT(nolign-1), [F:STG]CPCAFT(0..dim([F:STG]CPCAFT)-1))
 VALEUR=[F:STG]LEVAFT(I-1)
Endif
End

Subprog C_LEVAFT(VALEUR)
Variable Char    VALEUR()
Local Char VALCHAR (10)
Local Integer I, J
If VALEUR<>""
 If clalev([F:CPC])=0    : Local File COMPETENCE  [CPC]   : Endif
 Call LECTURE("CPC",[M:INS4]CPCAFT(nolign-1),"") From CONTOBJ
 Call LECTURE("HRSCA",[F:CPC]CODSCA,"") From CONTOBJ

 #Egalité parfaite
 For I=0 To dim([F:HRSCA]LEV)-1
  If toupper(ctrans([F:HRSCA]LEV(I)))=toupper(ctrans(VALEUR))
   VALCHAR=[F:HRSCA]LEV(I) : Break
  Endif
 Next
 If VALCHAR=""
  #Débute par...
  For I=len(VALEUR) To 1 Step -1
   For J=0 To dim([F:HRSCA]LEV)-1
    If left$(toupper(ctrans([F:HRSCA]LEV(J))),I)=toupper(ctrans(VALEUR))
     VALCHAR=[F:HRSCA]LEV(J)
     Break 2
    Endif
   Next J
  Next I
 Endif
 If VALCHAR="" : VALCHAR=[F:HRSCA]LEV(0): Endif
 VALEUR = VALCHAR
Endif
End

######################################################################################
## Etiquette écran INS5
######################################################################################

#**#####################################################################################
#* MABON - 24/08/10
#* Dans le cadre d'un stage long, on ne peut avoir qu'une seule ligne dans le calendrier
#*!
Subprog AS_NBLIG1

  Call LECTURE("STG",[M:INS0]STG,"") From CONTOBJ
  If [F:STG]TYPSTG=2 Then
    If [M:INS3]NBLIG1=1 and nolign=2 Then
      mkstat=2
    Endif
  Endif
End

#**#####################################################################################
#* MABON - 17/09/10
#* Des colonnes doivent être masquées selon le type de stage, dont l'une est une date
#* qu'on ne peut masquer dans le OUVRE. On le fait donc sur un AVANT_ZONE d'un champ
#* invisible situé après ce champ de type Date
#*!
Subprog AV_ZONINV(VALEUR)
Variable Char    VALEUR()

  Gosub INIT_COL
End

#**#####################################################################################
#* MABON - 17/09/10
#* Saisie de la date d'absence renseigne automatiquement le jour + l'heure début et fin
#* relatives à ce jour de présence dans l'onglet INS3
#*!
Subprog AM_DATABS(VALEUR)
Variable Date    VALEUR
Local    Integer I

  [M:INS5]DAYA(nolign-1)   = day$(VALEUR)
  Call LECTURE("STG", [M:INS0]STG, "") From CONTOBJ
  [M:INS5]NUMPRE(nolign-1) = -1
    #LIPET - 2017-05-13 - X3-29550 - START
    # Si stage vide et plusieurs jours de présence, on traite comme si TYPSTG=1
    If [F:STG]TYPSTG=1 | ([M:INS0]STG="" & [M:INS3]NBLIG1>1) Then
    #If [F:STG]TYPSTG=1 Then
    #LIPET - 2017-05-13 - X3-29550 - END
    For I=0 To [M:INS3]NBLIG1-1
      If [M:INS3]DAT(I)= VALEUR Then
        [M:INS5]DEBTIMA(nolign-1)     = [M:INS3]DEBTIM(I)     : Affzo [M:INS5]DEBTIMA(nolign-1)
        [M:INS5]FINTIMA(nolign-1)     = [M:INS3]FINTIM(I)     : Affzo [M:INS5]FINTIMA(nolign-1)
        [M:INS5]NBRTIMBRKA(nolign-1)  = [M:INS3]NBRTIMBRK(I)
        [M:INS5]NBRHOUPREVA(nolign-1) = [M:INS3]NBRHOUPREV(I)
        [M:INS5]NBRHOUREAA(nolign-1)  = [M:INS3]NBRHOUREA(I)
        [M:INS5]NBRDAYREAA(nolign-1)  = [M:INS3]NBRDAYREA(I)
        [M:INS5]NBRHOUREAA2(nolign-1) = [M:INS3]NBRHOUREA2(I)
        [M:INS5]NBRDAYREAA2(nolign-1) = [M:INS3]NBRDAYREA2(I)
        [M:INS5]TYPFRTA(nolign-1)     = [M:INS3]TYPFRT(I)
        [M:INS5]NUMPRE(nolign-1)      = I
        Break
      Endif
    Next
    If [M:INS5]NUMPRE(nolign-1)=-1 Then
      GMESSAGE = mess(151,10717,1) : # Date en dehors des jours de présence
      mkstat=2
    Endif
  Endif
End

#**#####################################################################################
#* MABON - 17/09/10
#* Contrôles sur la date d'absence
#*!
Subprog C_DATABS(VALEUR)
Variable Date    VALEUR

  Call LECTURE("STG", [M:INS0]STG, "") From CONTOBJ
  #LIPET - 2017-05-13 - X3-29550 - START
  #If VALEUR=[0/0/0] and [F:STG]TYPSTG=1 Then
  If VALEUR=[0/0/0] and ([F:STG]TYPSTG=1 | ([M:INS0]STG="" & [M:INS3]NBLIG1>1)) Then
  #LIPET - 2017-05-13 - X3-29550 - END
    mkstat=2 : End
  Endif
  If VALEUR<>[0/0/0] Then Call UNICITE(VALEUR,[M]DATABS) From OBJDIV : Endif
  If mkstat=2 : End : Endif
  If clalev([F:HRSES])=0 : Local File SESSIONS [HRSES] : Endif
  Call LECTURE("HRSES",[M:INS0]SES,"") From CONTOBJ
  If VALEUR<>[0/0/0] & (VALEUR<[F:HRSES]STRDAT | VALEUR>[F:HRSES]ENDDAT) Then
    GMESSAGE = mess(8,10717,1) : # Date en dehors de la période de la session
    mkstat = 2 : End
  Endif
End

#**#####################################################################################
#* MABON - 17/09/10
#* Calcul du nombre d'heures et de jours
#*!
Subprog AP_FINTIMA(VALEUR)
Variable Char    VALEUR()
Local    Integer NO

  NO = [M:INS5]NUMPRE(nolign-1)
  If NO>=0 Then
    If [M:INS3]DEBTIM(NO)=[M:INS5]DEBTIMA(nolign-1) & [M:INS3]FINTIM(NO)=VALEUR Then
      Diszo [M:INS5]NBRHOUREAA(nolign-1)
      Diszo [M:INS5]NBRDAYREAA(nolign-1)
      Diszo [M:INS5]NBRHOUREAA2(nolign-1)
      Diszo [M:INS5]NBRDAYREAA2(nolign-1)
#      Read[F:SEJ]SEJ0=[M:INS0]SES;[M:INS5]DATABS(nolign-1)
#      If !fstat Then
#        [M:INS5]NBRHOUREAA(nolign-1)  = [F:SEJ]NBRHOU
#        [M:INS5]NBRDAYREAA(nolign-1)  = [F:SEJ]NBRJOU
#      Endif
      [M:INS5]NBRHOUREAA(nolign-1)  = [M:INS3]NBRHOUREA(NO)
      [M:INS5]NBRDAYREAA(nolign-1)  = [M:INS3]NBRDAYREA(NO)
      [M:INS5]NBRHOUREAA2(nolign-1) = [M:INS3]NBRHOUREA2(NO)
      [M:INS5]NBRDAYREAA2(nolign-1) = [M:INS3]NBRDAYREA2(NO)
      [M:INS5]COMPLETE(nolign-1)=2 : # Journée complète d'absence
    Else
      If [M:INS5]NBRHOUREAA(nolign-1)>0  Then
        Actzo [M:INS5]NBRHOUREAA(nolign-1)
        Actzo [M:INS5]NBRDAYREAA(nolign-1)
      Endif
      If [M:INS5]NBRHOUREAA2(nolign-1)>0 Then
        Actzo [M:INS5]NBRHOUREAA2(nolign-1)
        Actzo [M:INS5]NBRDAYREAA2(nolign-1)
      Endif
      [M:INS5]COMPLETE(nolign-1)=1 : # Journée incomplète en absence
    Endif
  Else
    If [M:INS5]NBRHOUREAA(nolign-1)>0  Then
      Actzo [M:INS5]NBRHOUREAA(nolign-1)
      Actzo [M:INS5]NBRDAYREAA(nolign-1)
    Endif
    If [M:INS5]NBRHOUREAA2(nolign-1)>0 Then
      Actzo [M:INS5]NBRHOUREAA2(nolign-1)
      Actzo [M:INS5]NBRDAYREAA2(nolign-1)
    Endif
    [M:INS5]COMPLETE(nolign-1)=1 : # Journée incomplète en absence
  Endif
End

#**#####################################################################################
#* MABON - 17/09/10
#* Contrôle de l'heure début
#*!
Subprog C_DEBTIMA(VALEUR)
Variable Char    VALEUR()
Local    Integer NO

  NO = [M:INS5]NUMPRE(nolign-1)
  If NO>0 Then
    If [M:INS3]DEBTIM(NO)>VALEUR Then
      mkstat=2
    Endif
  Endif
End

#**#####################################################################################
#* MABON - 17/09/10
#* Contrôle de l'heure fin
#*!
Subprog C_FINTIMA(VALEUR)
Variable Char    VALEUR()
Local    Integer NO

  NO = [M:INS5]NUMPRE(nolign-1)
  If NO>0 Then
    If [M:INS3]FINTIM(NO)<VALEUR Then
      mkstat=2
    Endif
  Endif
End

Subprog ADD_NBLIG6(NUMLIG, NBRHOUREA, NBRDAYREA, NBRHOUREA2, NBRDAYREA2, SUPPR)
Value Integer NUMLIG, SUPPR
Value Decimal NBRHOUREA, NBRDAYREA, NBRHOUREA2, NBRDAYREA2

  [M:INS5]DATABSS([M:INS5]NBLIG6)      = [M:INS5]DATABS(NUMLIG)
  [M:INS5]NBRTIMBRKAS([M:INS5]NBLIG6)  = [M:INS5]NBRTIMBRKA(NUMLIG)
  [M:INS5]NBRHOUPREVAS([M:INS5]NBLIG6) = [M:INS5]NBRHOUPREVA(NUMLIG)
  [M:INS5]NBRHOUREAAS([M:INS5]NBLIG6)  = NBRHOUREA
  [M:INS5]NBRDAYREAAS([M:INS5]NBLIG6)  = NBRDAYREA
#  [M:INS5]NBRHOUREAAS2([M:INS5]NBLIG6) = [M:INS5]NBRHOUREAA2(NUMLIG)
#  [M:INS5]NBRDAYREAAS2([M:INS5]NBLIG6) = [M:INS5]NBRDAYREAA2(NUMLIG)
  [M:INS5]NBRHOUREAAS2([M:INS5]NBLIG6) = NBRHOUREA2
  [M:INS5]NBRDAYREAAS2([M:INS5]NBLIG6) = NBRDAYREA2
  [M:INS5]TYPFRTAS([M:INS5]NBLIG6)     = [M:INS5]TYPFRTA(NUMLIG)
  [M:INS5]SUPPR([M:INS5]NBLIG6)        = SUPPR
  [M:INS5]COMPLETES([M:INS5]NBLIG6)    = [M:INS5]COMPLETE(NUMLIG)
  [M:INS5]NBLIG6 += 1
End

#**#####################################################################################
#* MABON - 17/09/10
#* Gestion de la suppression de lignes
#*!
Subprog C_NBLIG5

  Case status
    When 65 : : # Suppression d'une ligne
#      Call ADD_NBLIG6(nolign-1, [M:INS5]NBRHOUREAA(nolign-1), [M:INS5]NBRDAYREAA(nolign-1), 2)
      Call ADD_NBLIG6(nolign-1, [M:INS5]NBRHOUREAA(nolign-1), [M:INS5]NBRDAYREAA(nolign-1), [M:INS5]NBRHOUREAA2(nolign-1), [M:INS5]NBRDAYREAA2(nolign-1), 2)
    When 71 : # Insertion d'une ligne
      [M:INS5]CREFLG(nolign-1)=0
  Endcase
End

#**#####################################################################################
#* MABON - 17/09/10
#* Grisage des champs NBRHOUREAA et NBRDAYREAA selon contexte
#*!
Subprog AV_NBLIG5
Local Integer I

  Call LECTURE("STG", [M:INS0]STG, "") From CONTOBJ
  For I=0 To [M:INS5]NBLIG5-1
    #LIPET - 2017-05-13 - X3-29550 - START
    # Si stage vide et plusieurs jours de présence, on traite comme si TYPSTG=1
    If [F:STG]TYPSTG=1 | ([M:INS0]STG="" & [M:INS3]NBLIG1>1) Then
    #If [F:STG]TYPSTG=1 Then
    #LIPET - 2017-05-13 - X3-29550 - END
      If [M:INS5]COMPLETE(I)=2 Then
        Diszo [M:INS5]NBRHOUREAA(I)
        Diszo [M:INS5]NBRDAYREAA(I)
        Diszo [M:INS5]NBRHOUREAA2(I)
        Diszo [M:INS5]NBRDAYREAA2(I)
      Else
        If [M:INS5]NBRHOUREAA(nolign-1)>0  Then
          Actzo [M:INS5]NBRHOUREAA(I)
          Actzo [M:INS5]NBRDAYREAA(I)
        Else
          Diszo [M:INS5]NBRHOUREAA(I)
          Diszo [M:INS5]NBRDAYREAA(I)
        Endif
        If [M:INS5]NBRHOUREAA2(nolign-1)>0  Then
          Actzo [M:INS5]NBRHOUREAA2(I)
          Actzo [M:INS5]NBRDAYREAA2(I)
        Else
          Diszo [M:INS5]NBRHOUREAA2(I)
          Diszo [M:INS5]NBRDAYREAA2(I)
        Endif
      Endif
    Else
      Actzo [M:INS5]NBRHOUREAA(I)
      Actzo [M:INS5]NBRDAYREAA(I)
      Actzo [M:INS5]NBRHOUREAA2(I)
      Actzo [M:INS5]NBRDAYREAA2(I)
    Endif
  Next
End

#**#####################################################################################
#* MABON - 17/09/10
#* Réinitialisation du champ CREFLG
#*!
Subprog AM_DEBTIMA(VALEUR)
Variable Char    VALEUR()
Local    Integer NO

  NO = [M:INS5]NUMPRE(nolign-1)
  If NO>0 Then
    If ([M:INS3]DEBTIM(NO)=VALEUR & [M:INS3]FINTIM(NO)=[M:INS5]FINTIMA(nolign-1) & [M:INS5]COMPLETE(nolign-1)=1)
&    | (([M:INS3]DEBTIM(NO)<>VALEUR | [M:INS3]FINTIM(NO)<>[M:INS5]FINTIMA(nolign-1)) & [M:INS5]COMPLETE(nolign-1)=2) Then
      [M:INS5]CREFLG(nolign-1)=0
    Endif
  Else
    If [M:INS5]DEBTIMA(nolign-1)<>VALEUR Then
      [M:INS5]CREFLG(nolign-1)=0
    Endif
  Endif
End

#**#####################################################################################
#* MABON - 17/09/10
#* Réinitialisation du champ CREFLG
#*!
Subprog AM_FINTIMA(VALEUR)
Variable Char    VALEUR()
Local    Integer NO

  NO = [M:INS5]NUMPRE(nolign-1)
  If NO>0 Then
    If ([M:INS3]DEBTIM(NO)=[M:INS5]DEBTIMA(nolign-1) & [M:INS3]FINTIM(NO)=VALEUR & [M:INS5]COMPLETE(nolign-1)=1)
&    | (([M:INS3]DEBTIM(NO)<>[M:INS5]DEBTIMA(nolign-1) | [M:INS3]FINTIM(NO)<>VALEUR) & [M:INS5]COMPLETE(nolign-1)=2) Then
      [M:INS5]CREFLG(nolign-1)=0
    Endif
  Else
    If [M:INS5]FINTIMA(nolign-1)<>VALEUR Then
      [M:INS5]CREFLG(nolign-1)=0
    Endif
  Endif
End

