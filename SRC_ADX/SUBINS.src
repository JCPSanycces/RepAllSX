End

Subprog GRISE_CTRNUM(VALEUR)
Value Integer VALEUR
If VALEUR=2
 Actzo [M:INS0]CTRNUM
Else
 Diszo [M:INS0]CTRNUM
Endif
Affzo [M:INS0]CTRNUM
End

######################################################################################
## Etiquette Ecrans [M:INS2](Coûts)
######################################################################################
#SEGAY 22/02/11 bug 71267 Période de professionalisation
Subprog AM_DEM(VALEUR)
Variable Char    VALEUR()
Call LECTURE("DEM",VALEUR(),"") From CONTOBJ
If !fstat Then
   [M:INS2]FLGPRO = [F:DEM]FLGPRO
Else
   [M:INS2]FLGPRO = 0
Endif
Affzo [M:INS2]FLGPRO
End


Subprog C_DESNATFIS(VALEUR)
#ADNGO - 2017-06-29 - X3-29550 - START
#Variable Integer VALEUR
Variable Char VALEUR
#ADNGO - 2017-06-29 - X3-29550 - END
#ADNGO - 2017-06-29 - X3-29550 - START
#If VALEUR=len(mess(0,10452,1)) :#Non défini
If VALEUR='' :#Non défini
#ADNGO - 2017-06-29 - X3-29550 - END
