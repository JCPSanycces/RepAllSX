Subprog CHECK_LEGCTR(MATRICULE,CTRNUM,OK)
Value Char MATRICULE()
Value Char CTRNUM()
Variable Integer OK

Local Char WLEGSES(GLONADI)
Local Char WLEGCTR(GLONADI)
Local Integer TMP
If(CTRNUM="")
   GMESSAGE = mess(67,10717,1)
   OK=1
  End
Endif
Call GET_LEGHRSES([M:INS0]SES,TMP,WLEGSES,0)From TOOLSHRLEG
Raz TMP
Call GET_LEGHRCTR(MATRICULE,CTRNUM,TMP,WLEGCTR,0)From TOOLSHRLEG
 If(WLEGSES<>"" & WLEGCTR<>"" & WLEGSES<>WLEGCTR)
    GMESSAGE = mess(276,10717,1)- WLEGSES
    OK=1
  Endif
End

Subprog GET_LEGSEL(MLEG,OK)
Variable Char MLEG()
Variable Integer OK
If([M:INS0]SES<>"")
  Call GET_LEGHRSES([M:INS0]SES,OK,MLEG,0) From TOOLSHRLEG
End
Endif
If([M:INS0]STG<>"")
  Call GET_LEGSTG([M:INS0]STG,OK,MLEG,1)From TOOLSHRLEG
  End
Endif
MLEG=GLEGFIL
End

Funprog FGET_LEGSEL(INDFLD)
Value Integer INDFLD
Local Integer OK
Local  Char MLEG
#sba 20120614 : comment GCURLEG=""
MLEG=GLEGFIL
Case INDFLD
  When 1 :
   If([M:INS0]SES<>"")
      Call GET_LEGHRSES([M:INS0]SES,OK,MLEG,0)From TOOLSHRLEG
      GCURLEG=""
   Endif
  When 2 :
   If([M:INS0]STG<>"")
      Call GET_LEGSTG([M:INS0]STG,OK,MLEG,0)From TOOLSHRLEG
      GCURLEG=""
    Endif
  When 3 :
   GCURLEG=""
   Call GET_LEGSEL(MLEG,OK)
  When 4 :
   #sba 20120614
   # GCURLEG=""
   Call GET_LEGHRCTR([M:INS0]REFNUM,[M:INS0]CTRNUM,OK,MLEG,1)From TOOLSHRLEG
Endcase

End MLEG


