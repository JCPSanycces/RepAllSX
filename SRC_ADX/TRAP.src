#<AdxTL>@(#)4.0.0.0 $Revision$
#################################################################################################################
#
#   Tax declaration Austria - Data ouput
#
#   PURPOSE :    Exports or prints Austrian VAT declaration (U30) plus add-ons (AS30, AS31, AS32)
#   AUTHORS :    DNE
#   DATE    :    2012-12-19
#   UPDATES :    2013-08-23 DNE - New CHECKFILEPATH function
#                2014-01-14 DNE - New export and prints for year 2014 (and hopefully later)
#                2014-05-06 DNE - Output is now volume aware and can be downloaded (US #729)
#                2015-08-12 ANGRE New fields 006, 007, 008 SAM# 112760
#
#################################################################################################################

Local Char XMODE(250) : XMODE = "U30"

# < DEBUG> ######################################################################################################
Local Char XPARAM(10)(1..10)
Call GCONSULT( "TRA", "", XPARAM ) From GCONSULT
End
# </DEBUG> ######################################################################################################


#** #############################################################################################################
#*
#* Sub chunk:  ACTION
#*
#* Purpose:    Standard action dispatcher.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param ACTION      Name of the event (action).
#*
#*! #############################################################################################################

$ACTION
    Case ACTION
        When "DEBUT"   : Gosub DEBUT
        When "BOUTON"  : Gosub BOUTON
    Endcase
Return



#** #############################################################################################################
#*
#* Sub chunk:  DEBUT
#*
#* Purpose:    Handler before entering the window
#*             Reads data from the parent screen and prefills the property window.
#*
#*! #############################################################################################################

$DEBUT
    Local Decimal AMTVATBASE
    Local Decimal AMTVAT

    # Copy already collected data from mother window's header screen.
    [M:TRAP] = [M:TRG0]

    # Get company group (if set in base).
    If [M:TRG0]GRP <> ""
        [M:TRAP]CPY = [M:TRG0]GRP
    Endif

# 2014-05-06 DNE MODIF BEGIN
    # Disable/enable VOLFIL field and get the output volume/storage area.
    [M]TYPEXP = 1 # Client
    Call AM_TYPEXP( [M]TYPEXP )
# 2014-05-06 DNE MODIF BEGIN
#    # Get the output directory.
#    [M:TRAP]VOLFIL = func AFNC.PARAM( "VATFILPAT", [M]CPY )
# 2014-05-06 DNE MODIF END

    # Revalidate screen content.
    Affzo [M:TRAP] 1 - 99

    # Enable box 020 extension field if a VAT box 020 entry exists.
    Call GET_BOX_CONTENT( "020", AMTVATBASE, AMTVAT ) From CNSTRASTD
    If AMTVATBASE = 0
        Diszo [M:TRAP]BOX020
    Endif

    # Enable (and set) or disable (and unset) U31 check box.
    If ( [M:TRA5]NBLIG > 0 ) or ( [M:TRA5]FLGTRN = 2 ) or ( [M:TRA5]FLGREI = 2 )
        Actzo [M:TRAP]FLGU31
        [M:TRAP]FLGU31 = 2
        Affzo [M:TRAP]FLGU31
    Else
        [M:TRAP]FLGU31 = 1
        Affzo [M:TRAP]FLGU31
        Diszo [M:TRAP]FLGU31
    Endif
Return



#** #############################################################################################################
#*
#* Sub chunk:  BOUTON
#*
#* Purpose:    Handler for the button action.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param BOUT    The code of the pressed button.
#*
#*! #############################################################################################################

$BOUTON
    Local Integer NODECL : NODECL = 1 # Number of declarations (<ERKLAERUNG/> tags).

    Case BOUT
        When "A" # Button "Print"
            Call OPEN_REPORT( GFONCTION ) From CNSRSGSTDLIB
        When "B" # Button "File"
            # U30 statement
            XMODE = "U30" : Gosub CREATE_TRA_XML

            # Attached statements.
            If [M]FLGU31 = 2

                # AS30 statement
                If [M:TRA5]NBLIG > 0
                    NODECL = 1
                    XMODE = "AS30"
                    Gosub CREATE_TRA_XML
                Endif

                # AS31 statement (transfer)
                If [M:TRA5]FLGTRN = 2
                    NODECL = 1
                    If [M:TRA5]FLGTRN2 = 2
                        NODECL += 1
                    Endif
                    XMODE = "AS31"
                    Gosub CREATE_TRA_XML
                Endif

                # AS32 statement (reimbursement)
                If [M:TRA5]FLGREI = 2
                    NODECL = 1
                    XMODE = "AS32"
                    Gosub CREATE_TRA_XML
                Endif
            Endif
    Endcase
Return



#** #############################################################################################################
#*
#* Sub chunk:  CREATE_TRA_XML
#*
#* Purpose:    Exports an XML file for U30, AS30, AS31 and AS32 statements according to AUT legislation.
#*
#*! #############################################################################################################

$CREATE_TRA_XML
    Local Char    VATBOX(10)
    Local Char    FILEEXTENSION(255)  : FILEEXTENSION = "xml"
# 2014-05-06 DNE DELETE BEGIN (US #729)
#    Local Char    FILES(100)(50)                              # For the "system" call if a file preview is desired.
# 2014-05-06 DNE DELETE END
    Local Integer RC : RC = 0

    # Initialize XML tag stack.
    Gosub XML_INIT From CNSRSGSTDLIB

    # Create file, filename etc.
    Gosub CREATE_TR_FILE_COMMON
    If RC : Return : Endif

    # Open XML file.
    XMLFILENAME = FILENAMETR : Gosub XML_OPEN From CNSRSGSTDLIB
    If XMLFILEERR
        # Signal Error.
        Call ERREUR( mess(317,107,1) + chr$(10) + func CNSRSGSTDLIB.REPLACE( FILENAMETR, "\", "/" ) ) From GESECRAN # "Cannot write file."
        Return
    Endif

    # Create XML tree.
    XMLTAG = "ERKLAERUNGS_UEBERMITTLUNG" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
    XMLTAG = "INFO_DATEN" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
    XMLTAG = "ART_IDENTIFIKATIONSBEGRIFF" : XMLCONTENT = "FASTNR" : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "IDENTIFIKATIONSBEGRIFF" : XMLCONTENT = [M]CRN : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "PAKET_NR" : XMLCONTENT = [M]NOPKG : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "DATUM_ERSTELLUNG" : XMLATTR= "type='datum'" : XMLCONTENT = format$( "D:YYYY[-]MM[-]DD", date$ ) : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "UHRZEIT_ERSTELLUNG" : XMLATTR= "type='uhrzeit'" : XMLCONTENT = time$ : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "ANZAHL_ERKLAERUNGEN" : XMLCONTENT = num$( NODECL ) : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    Gosub XML_POP_TAG From CNSRSGSTDLIB # </INFO_DATEN>

    # Write tax return declaration part (U30, AS30, AS31, AS32).
    Case XMODE
        When "U30"  : Gosub CREATE_TRA_XML_U30
        When "AS30" : Gosub CREATE_TRA_XML_AS30
        When "AS31" : Gosub CREATE_TRA_XML_AS31
        When "AS32" : Gosub CREATE_TRA_XML_AS32
    Endcase


    # Close open tags and close the XML file.
    Gosub XML_CLOSE From CNSRSGSTDLIB

# 2014-05-06 DNE DELETE BEGIN (US #729)
#    # Open file in a program (e. g. internet explorer) if FLGPRV is set to YES (2)
#    # and the output file is a local file and parameter VATFILVIE is set properly.
#    If ( [M]FLGPRV = 2 ) and ( left$( FILENAMETR, 2 ) = "#@" )
#        PARAMETERVALUE = func AFNC.PARAM( "VATFILVIE", [M]CPY )
#        If PARAMETERVALUE = ""  Then
#            Call ERREURT( mess(278,107,1), 1 ) From GESECRAN  # "Parameter: VATFILVIE\Please enter a file view path."
#        Else
#            System FILES = PARAMETERVALUE - '"' + right$( FILENAMETR, 3 ) + '"'
#        Endif
#    Else
#        # Signal success.
#        Call MESSAGE( mess(257,107,1) + chr$(10) + func CNSRSGSTDLIB.REPLACE( FILENAMETR, "\", "/" ) ) From GESECRAN # "File succesfully created."
#    Endif
# 2014-05-06 DNE DELETE END

# 2014-05-06 DNE INSERT BEGIN (US #729)
    # If the file is to be downloaded to the client initiate the download.
    If [M]TYPEXP = 1 : # Client
        Call COPCLI( EXPORTFILE, EXPORTNAME, STAT ) From ORDSYS
        If STAT = 1
            Call ERREUR( mess(164,141,1) ) From GESECRAN # 'File not copied to the client workstation'
        Elsif STAT > 1
            Call ERREUR( mess(159,141,1) - "(" +num$( STAT ) + ")" ) From GESECRAN # 'File or directory do not exist'
        Endif
    Endif
# 2014-05-06 DNE INSERT END
Return



#** #############################################################################################################
#*
#* Sub chunk:  CREATE_TRA_XML_U30
#*
#* Purpose:    Exports the U30 statement part according to AUT legislation.
#*
#*! #############################################################################################################

$CREATE_TRA_XML_U30
    XMLTAG = "ERKLAERUNG" : XMLATTR= "art='U30'" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
    XMLTAG = "SATZNR" : XMLCONTENT = [M]NOREC : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "ALLGEMEINE_DATEN" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
    XMLTAG = "ANBRINGEN" : XMLCONTENT = "U30" : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "ZRVON" : XMLATTR= "type='jahrmonat'" : XMLCONTENT = format$( "D:YYYY[-]MM", [M]DATDEB ) : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "ZRBIS" : XMLATTR= "type='jahrmonat'" : XMLCONTENT = format$( "D:YYYY[-]MM", [M]DATFIN ) : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "FASTNR" : XMLCONTENT = [M]CRN : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "KUNDENINFO" : XMLCONTENT = [M]NOTECUST : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    Gosub XML_POP_TAG From CNSRSGSTDLIB # </ALLGEMEINE_DATEN>
    XMLTAG = "LIEFERUNGEN_LEISTUNGEN_EIGENVERBRAUCH" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
    VATBOX = "000" : Gosub WRITE_TRA_VATBOX
    VATBOX = "001" : Gosub WRITE_TRA_VATBOX
    VATBOX = "021" : Gosub WRITE_TRA_VATBOX
    XMLTAG = "STEUERFREI" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
    VATBOX = "011" : Gosub WRITE_TRA_VATBOX
    VATBOX = "012" : Gosub WRITE_TRA_VATBOX
    VATBOX = "015" : Gosub WRITE_TRA_VATBOX
    VATBOX = "017" : Gosub WRITE_TRA_VATBOX
    VATBOX = "018" : Gosub WRITE_TRA_VATBOX
    VATBOX = "019" : Gosub WRITE_TRA_VATBOX
    VATBOX = "016" : Gosub WRITE_TRA_VATBOX
    If [M]BOX020 <> ""
        XMLTAG = "VST" : XMLCONTENT = [M]BOX020 : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    Endif
    VATBOX = "020" : Gosub WRITE_TRA_VATBOX
    Gosub XML_POP_TAG From CNSRSGSTDLIB # </STEUERFREI>
    XMLTAG = "VERSTEUERT" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
    VATBOX = "022" : Gosub WRITE_TRA_VATBOX
    VATBOX = "029" : Gosub WRITE_TRA_VATBOX
    VATBOX = "006" : Gosub WRITE_TRA_VATBOX
    VATBOX = "025" : Gosub WRITE_TRA_VATBOX
    VATBOX = "037" : Gosub WRITE_TRA_VATBOX
    VATBOX = "052" : Gosub WRITE_TRA_VATBOX
    VATBOX = "007" : Gosub WRITE_TRA_VATBOX
    VATBOX = "038" : Gosub WRITE_TRA_VATBOX
    VATBOX = "056" : Gosub WRITE_TRA_VATBOX
    VATBOX = "057" : Gosub WRITE_TRA_VATBOX
    VATBOX = "048" : Gosub WRITE_TRA_VATBOX
    VATBOX = "044" : Gosub WRITE_TRA_VATBOX
    VATBOX = "032" : Gosub WRITE_TRA_VATBOX
    Gosub XML_POP_TAG From CNSRSGSTDLIB # </VERSTEUERT>
    Gosub XML_POP_TAG From CNSRSGSTDLIB # </LIEFERUNGEN_LEISTUNGEN_EIGENVERBRAUCH>
    XMLTAG = "INNERGEMEINSCHAFTLICHE_ERWERBE" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
    VATBOX = "070" : Gosub WRITE_TRA_VATBOX
    VATBOX = "071" : Gosub WRITE_TRA_VATBOX
    XMLTAG = "VERSTEUERT_IGE" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
    VATBOX = "072" : Gosub WRITE_TRA_VATBOX
    VATBOX = "073" : Gosub WRITE_TRA_VATBOX
    VATBOX = "008" : Gosub WRITE_TRA_VATBOX
    VATBOX = "088" : Gosub WRITE_TRA_VATBOX
    VATBOX = "076" : Gosub WRITE_TRA_VATBOX
    VATBOX = "077" : Gosub WRITE_TRA_VATBOX
    Gosub XML_POP_TAG From CNSRSGSTDLIB # </VERSTEUERT_IGE>
    Gosub XML_POP_TAG From CNSRSGSTDLIB # </INNERGEMEINSCHAFTLICHE_ERWERBE>
    XMLTAG = "VORSTEUER" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
    VATBOX = "060" : Gosub WRITE_TRA_VATBOX
    VATBOX = "061" : Gosub WRITE_TRA_VATBOX
    VATBOX = "083" : Gosub WRITE_TRA_VATBOX
    VATBOX = "065" : Gosub WRITE_TRA_VATBOX
    VATBOX = "066" : Gosub WRITE_TRA_VATBOX
    VATBOX = "082" : Gosub WRITE_TRA_VATBOX
    VATBOX = "087" : Gosub WRITE_TRA_VATBOX
    VATBOX = "089" : Gosub WRITE_TRA_VATBOX
    VATBOX = "064" : Gosub WRITE_TRA_VATBOX
    VATBOX = "062" : Gosub WRITE_TRA_VATBOX
    VATBOX = "063" : Gosub WRITE_TRA_VATBOX
    VATBOX = "067" : Gosub WRITE_TRA_VATBOX
# SAM #93781 DNE MODIF (VAT boxes 027 and 028 are now deprecated)
#    VATBOX = "027" : Gosub WRITE_TRA_VATBOX
#    VATBOX = "028" : Gosub WRITE_TRA_VATBOX
    VATBOX = "090" : Gosub WRITE_TRA_VATBOX
    If [M]FLGU31 = 2
        XMLTAG = "ARE" : XMLCONTENT = "J" : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    Endif
    If [M]FLGINV = 2
        XMLTAG = "REPO" : XMLCONTENT = "J" : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    Endif
    Gosub XML_POP_TAG From CNSRSGSTDLIB # </VORSTEUER>
    Gosub XML_POP_TAG From CNSRSGSTDLIB # </ERKLAERUNG>
Return



#** #############################################################################################################
#*
#* Sub chunk:  CREATE_TRA_XML_AS30
#*
#* Purpose:    Exports the AS30 statement part according to AUT legislation.
#*
#*! #############################################################################################################

$CREATE_TRA_XML_AS30
    XMLTAG = "ERKLAERUNG"       : XMLATTR= "art='SBZ'" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
    XMLTAG = "ALLGEMEINE_DATEN" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
    XMLTAG = "SATZNR"           : XMLCONTENT = [M]NOREC : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "ANBRINGEN"        : XMLCONTENT = "SBZ" : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "FASTNR"           : XMLCONTENT = [M]CRN : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "KUNDENINFO"       : XMLCONTENT = [M]NOTECUST : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    Gosub XML_POP_TAG From CNSRSGSTDLIB # </ALLGEMEINE_DATEN>

    # Lines
    Local Integer II

    For II = 0 To [M:TRA5]NBLIG-1
      XMLTAG = "VERRECHNUNGSWEISUNGEN" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
      XMLTAG = "AA"     : XMLCONTENT = [M:TRA5]TYPLEV(II) : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
      XMLTAG = "ZRVON"  : XMLATTR= "type='jahrmonat'" : XMLCONTENT = format$( "D:YYYY[-]MM", [M:TRA5]DATDEB(II) ) : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
      XMLTAG = "ZRBIS"  : XMLATTR= "type='jahrmonat'" : XMLCONTENT = format$( "D:YYYY[-]MM", [M:TRA5]DATFIN(II) ) : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
      XMLTAG = "BETRAG" : XMLATTR= "type='kz'"        : XMLCONTENT = ctrans( vireblc( format$( "N:10.2", [M:TRA5]AMT(II)), 3 ), ",", "." ) : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
      Gosub XML_POP_TAG From CNSRSGSTDLIB # </VERRECHNUNGSWEISUNGEN>
    Next

   Gosub XML_POP_TAG From CNSRSGSTDLIB # </ERKLAERUNG>
Return



#** #############################################################################################################
#*
#* Sub chunk:  CREATE_TRA_XML_AS321
#*
#* Purpose:    Exports the AS31 statement part according to AUT legislation.
#*
#*! #############################################################################################################

$CREATE_TRA_XML_AS31
    # Transfer ("Übetrag")
    If [M:TRA5]FLGTRN = 2
        XMLTAG = "ERKLAERUNG"       : XMLATTR= "art='UEB'" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
        XMLTAG = "ALLGEMEINE_DATEN" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
        XMLTAG = "SATZNR"           : XMLCONTENT = [M]NOREC : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
        XMLTAG = "ANBRINGEN"        : XMLCONTENT = "UEB" : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
        XMLTAG = "FASTNR"           : XMLCONTENT = [M]CRN : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
        XMLTAG = "FASTNR_ZU"        : XMLCONTENT = [M:TRA5]CRN : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
        XMLTAG = "KUNDENINFO"       : XMLCONTENT = [M]NOTECUST : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
        Gosub XML_POP_TAG From CNSRSGSTDLIB # </ALLGEMEINE_DATEN>
        XMLTAG = "UEBERTRAGENDER_BETRAG" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
        XMLTAG = "BETRAG_UEB" : XMLATTR= "type='kz'" : XMLCONTENT = ctrans( vireblc( format$( "N:10.2", [M:TRA5]AMTTRN), 3 ), ",", "." ) : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
        Gosub XML_POP_TAG From CNSRSGSTDLIB # </UEBERTRAGENDER_BETRAG>
        Gosub XML_POP_TAG From CNSRSGSTDLIB # </ERKLAERUNG>
    Endif

    # Transfer ("Übetrag") 2
    If [M:TRA5]FLGTRN2 = 2
        XMLTAG = "ERKLAERUNG"       : XMLATTR= "art='UEB'" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
        XMLTAG = "ALLGEMEINE_DATEN" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
        XMLTAG = "SATZNR"           : XMLCONTENT = [M]NOREC : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
        XMLTAG = "ANBRINGEN"        : XMLCONTENT = "UEB" : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
        XMLTAG = "FASTNR"           : XMLCONTENT = [M]CRN : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
        XMLTAG = "FASTNR_ZU"        : XMLCONTENT = [M:TRA5]CRN2 : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
        XMLTAG = "KUNDENINFO"       : XMLCONTENT = [M]NOTECUST : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
        Gosub XML_POP_TAG From CNSRSGSTDLIB # </ALLGEMEINE_DATEN>
        XMLTAG = "UEBERTRAGENDER_BETRAG" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
        XMLTAG = "BETRAG_UEB" : XMLATTR= "type='kz'" : XMLCONTENT = ctrans( vireblc( format$( "N:10.2", [M:TRA5]AMTTRN2), 3 ), ",", "." ) : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
        Gosub XML_POP_TAG From CNSRSGSTDLIB # </UEBERTRAGENDER_BETRAG>
        Gosub XML_POP_TAG From CNSRSGSTDLIB # </ERKLAERUNG>
    Endif
Return



#** #############################################################################################################
#*
#* Sub chunk:  CREATE_TRA_XML_AS32
#*
#* Purpose:    Exports the AS32 statement part according to AUT legislation.
#*
#*! #############################################################################################################

$CREATE_TRA_XML_AS32
    XMLTAG = "ERKLAERUNG"       : XMLATTR= "art='RZ'" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
    XMLTAG = "ALLGEMEINE_DATEN" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
    XMLTAG = "SATZNR"           : XMLCONTENT = [M]NOREC : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "ANBRINGEN"        : XMLCONTENT = "RZ" : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "ART_RZ"
    If ( left$( [M:TRA5]IBACOD, 2 ) <> "AT" ) or ( ( [M:TRA5]FLGREI2 = 2 ) and  ( left$( [M:TRA5]IBACOD2, 2 ) <> "AT" ) )
        XMLCONTENT = "A"
    Else
        XMLCONTENT = "I"
    Endif
    Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "FASTNR"           : XMLCONTENT = [M]CRN : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    XMLTAG = "KUNDENINFO"       : XMLCONTENT = [M]NOTECUST : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    Gosub XML_POP_TAG From CNSRSGSTDLIB # </ALLGEMEINE_DATEN>

    # Reimbursement ("Rückzahlung")
    If [M:TRA5]FLGREI = 2
      XMLTAG = "EMPFAENGER" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
      XMLTAG = "NAMEE"      : XMLCONTENT = [F:CPY]CPYNAM : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
      XMLTAG = "BETRAG"     : XMLATTR= "type='kz'" : XMLCONTENT = ctrans( vireblc( format$( "N:10.2", [M:TRA5]AMTREI), 3 ), ",", "." ) : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
      XMLTAG = "UNBAR"      : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
      XMLTAG = "IBAN"       : XMLCONTENT = [M:TRA5]IBACOD : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
      XMLTAG = "BIC"        : XMLCONTENT = [M:TRA5]BICCOD : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
      XMLTAG = "BANK"       : XMLCONTENT = [M:TRA5]BANDES : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
      Gosub XML_POP_TAG From CNSRSGSTDLIB # </UNBAR>
      Gosub XML_POP_TAG From CNSRSGSTDLIB # </EMPFAENGER>
    Endif

    # Reimbursement ("Rückzahlung") 2
    If ( [M:TRA5]FLGREI = 2 ) and ( [M:TRA5]FLGREI2 = 2 )
      XMLTAG = "EMPFAENGER" : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
      XMLTAG = "NAMEE"      : XMLCONTENT = [F:CPY]CPYNAM : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
      XMLTAG = "BETRAG"     : XMLATTR= "type='kz'" : XMLCONTENT = ctrans( vireblc( format$( "N10.2", [M:TRA5]AMTREI2), 3 ), ",", "." ) : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
      XMLTAG = "UNBAR"      : Gosub XML_PUSH_TAG From CNSRSGSTDLIB
      XMLTAG = "IBAN"       : XMLCONTENT = [M:TRA5]IBACOD2 : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
      XMLTAG = "BIC"        : XMLCONTENT = [M:TRA5]BICCOD2 : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
      XMLTAG = "BANK"       : XMLCONTENT = [M:TRA5]BANDES2 : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
      Gosub XML_POP_TAG From CNSRSGSTDLIB # </UNBAR>
      Gosub XML_POP_TAG From CNSRSGSTDLIB # </EMPFAENGER>
    Endif

    Gosub XML_POP_TAG From CNSRSGSTDLIB # </ERKLAERUNG>
Return



#** #############################################################################################################
#*
#* Sub chunk:  WRITE_TRA_VATBOX
#*
#* Purpose:    Searches for a given VAT box in the tax return list and if it finds it, writes a <KZ...>...</KZ...>
#*             tag in the XML file.
#*
#* Parameters:
#*
#* @param VATBOX       Value Char()   Vat box
#*
#*! #############################################################################################################

$WRITE_TRA_VATBOX
    Local Decimal VATBOXVALUE   : VATBOXVALUE = 0
    Local Integer I             : I = 0

    # Search for the given vat box in the result grid.
    I = find( VATBOX, [M:TRG1]REPLINE(0..( [M:TRG1]NBLIG - 1 ) ) ) - 1
    If I >= 0
        If [M:TRG1]AMTVATBASE(I) <> 0
            VATBOXVALUE= [M:TRG1]AMTVATBASE(I)
        Else
            VATBOXVALUE= [M:TRG1]AMTVAT(I)
        Endif
    Endif

    If ( VATBOXVALUE <> 0 ) or ( find( VATBOX, "000", "070" ) <> 0 )
        If ( VATBOXVALUE < 0 ) and ( find( VATBOX, "027", "028", "063", "067", "090" ) = 0 )
            VATBOXVALUE = -VATBOXVALUE
        Endif
        XMLTAG = "KZ" + VATBOX : XMLATTR= "type='kz'" : XMLCONTENT = func CNSRSGSTDLIB.REPLACE( vireblc( format$( "N13.2", VATBOXVALUE), 3 ), ",", "." ) : Gosub XML_CREATE_TAG From CNSRSGSTDLIB
    Endif
Return



#** #############################################################################################################
#*
#* Sub chunk:  CREATE_TR_FILE_COMMON
#*
#* Purpose:    Commen export code fro XML, CSV export. Creates file name and checks for the
#*             existance of a file with that name.
#*
#*
#* Parameters (as variables in the main chunk):
#*
#* @param Local Char FILEEXTENSION(255)     Extension of the file to export.
#*
#*
#* Creates/Returns (as variables for the main chunk):
#*
#*        Local Char FILENAMETR(255)        Returns the final file name
#*        Local Char QUARTDATINFO(255)      ...
#*        Local Char QUARTYEAR(255)         ...
#*
#*
#*! #############################################################################################################

$CREATE_TR_FILE_COMMON
    Local Char    QUARTDATINFO(255)   : QUARTDATINFO = ""
    Local Char    QUARTYEAR(255)      : QUARTYEAR = ""
    Local Char    FILENAMETR(255)     : FILENAMETR = ""
# 2014-05-06 DNE INSERT BEGIN (US #729)
    Local Char    URL(GDIMFIC)        : URL = ""
    Local Char    EXPORTNAME(GDIMFIC) : EXPORTNAME = ""
    Local Char    EXPORTFILE(GDIMFIC) : EXPORTFILE = ""
    Local Integer STAT                : STAT = 0
# 2014-05-06 DNE INSERT END
    Local Integer YESNO               : YESNO = 1           # ... Defaults to NO.
    Local Integer FILEEXISTS

# 2014-05-06 DNE MODIF BEGIN (US #729)
    # Validating file path in server mode.
    If ( [M]TYPEXP = 2 ) & ( func CHECKFILEPATH( [M]DIRXMLDESC ) = 0 ) : RC = 1 : Return : Endif
# 2014-05-06 DNE MODIF ORIG
#    # Validating file path
#    If func CHECKFILEPATH( [M:TRAP]DIRXMLDESC ) = 0 : RC = 1 : Return : Endif
# 2014-05-06 DNE MODIF END

    # Quarter/month/year information for XML output and filename.
    If month([M]DATDEB) = 1 and month([M]DATFIN) = 3
        QUARTYEAR = "1. Quartal"
        QUARTDATINFO = "I-" + format$( "D:YYYY", [M]DATFIN )
    Elsif month([M]DATDEB) = 4 and month([M]DATFIN) = 6
        QUARTYEAR = "2. Quartal"
        QUARTDATINFO = "II-" + format$( "D:YYYY", [M]DATFIN )
    Elsif  month([M]DATDEB) = 7 and month([M]DATFIN) = 9
        QUARTYEAR = "3. Quartal"
        QUARTDATINFO = "III-" + format$( "D:YYYY", [M]DATFIN )
    Elsif  month([M]DATDEB) = 10 and month([M]DATFIN) = 12
        QUARTYEAR = "4. Quartal"
        QUARTDATINFO = "IV-" + format$( "D:YYYY", [M]DATFIN )
    Elsif  month( [M]DATDEB ) = month( [M]DATFIN )
        QUARTYEAR = month$( [M]DATFIN )
        QUARTDATINFO = format$( "D:MM", [M]DATFIN ) + "-" + format$( "D:YYYY", [M]DATFIN )
    Elsif  month([M]DATDEB) = 1 and month([M]DATFIN) = 12
        QUARTYEAR = "Kalenderjahr"
        QUARTDATINFO = format$( "D:YYYY", [M]DATFIN )
    Endif

    # Create the file name from current date and  year/quarter/month information.
# 2014-05-06 DNE INSERT BEGIN (US #729)
    FILENAMETR = "DCLVAT" + [M:TRG0]LEG + "_TR_"
&              + [M]CPY
&              + "_"
&              + format$( "D:YYYYMMDD", date$ )
&              + "_"
&              + QUARTDATINFO
&              + "_"
&              + XMODE
&              + "." + FILEEXTENSION
    If [M]TYPEXP = 1 : # Client
        EXPORTNAME = FILENAMETR
        EXPORTFILE = [M]DIRXMLDESC
        Call SET_FICNAM( FILENAMETR, EXPORTFILE, URL ) From ORDSYS
        FILENAMETR= EXPORTFILE
    Else # Server
# 2014-05-06 DNE INSERT END
# 2014-05-06 DNE MODIF BEGIN
        FILENAMETR = [M]DIRXMLDESC
&                  + func GDPDU1.GETDIRSEPARATOR()
&                  + FILENAMETR
# 2014-05-06 DNE MODIF ORIG
#        FILENAMETR = [M:TRAP]DIRXMLDESC
#&                  + func GDPDU1.GETDIRSEPARATOR()
#&                  + "DCLVAT" + [M:TRG0]LEG + "_TR_"
#&                  + [M]CPY
#&                  + "_"
#&                  + format$( "D:YYYYMMDD", date$ )
#&                  + "_"
#&                  + QUARTDATINFO
#&                  + "_"
#&                  + XMODE
#&                  + "." + FILEEXTENSION
# 2014-05-06 DNE MODIF END
        Call EXISTE( FILENAMETR, FILEEXISTS ) From ORDSYS
        If FILEEXISTS = 1
            Call OUINONT( mess(260,107,1) + chr$(10) + func CNSRSGSTDLIB.REPLACE( FILENAMETR, "\", "/" ), YESNO ) From GESECRAN # "Data already exists.\Do you want to overwrite it?"
            If YESNO = 1 # No --> Cancel.
                RC = 1
            Endif
        Endif
# 2014-05-06 DNE INSERT BEGIN (US #729)
    Endif
# 2014-05-06 DNE INSERT END
Return



#** #############################################################################################################
#*
#* Function that checks if the given Path exists or not
#*
#* @param Value Char PATH        Path to check
#* @return  Integer Result       1 -> exists; 0 -> exists not
#*! #############################################################################################################

Funprog CHECKFILEPATH(PATH)
Value Char PATH
    Local Integer RESULT : RESULT = 1
    Local Integer EXISTS

    If PATH = ""
        Call ERREURT( mess(277,107,1), 1 ) From GESECRAN  # "Parameter: RSGFILPAT\Please set an export directory."
    Else
        Call EXISTE( PATH, EXISTS ) From ORDSYS
        If !EXISTS

            Call ERREURT( mess(111,148,1), 1 ) From GESECRAN # "Non-existent destination directory"
            RESULT = 0
        Endif
    Endif
End RESULT



