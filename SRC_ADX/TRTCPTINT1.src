End

#**
#* Génération des pièces comptables pour un couple :
#*  - Société
#*  - Type d'écriture
#*
#* @param PCPY
#* @param PFCY
#* @param PREF
#* @param PLIN
#* @param PDATMIN
#* @param PDATMAX
#* @param PTPEABREV
#* @param PTYPPST
#* @param PLSTTYPPRO
#* @param PFIY
#* @param PNUMPER
#* @param PSIMU
#* @param PDIRECT
#* @param CDRET
#* @param MSGRET
#*!
Subprog GENERE_CPT(PCPY, PFCY, PREF, PLIN, PDATMIN, PDATMAX, PTPEABREV, PTYPPST, PLSTTYPPRO, PFIY, PNUMPER, PSIMU, PDETANA, PDIRECT, CDRET, MSGRET)
Value    Char    PCPY                # Société
Value    Char    PFCY                # Site
Value    Char    PREF                # Référence pour le mode direct
Value    Integer PLIN                # Ligne pour le mode direct
Value    Date    PDATMIN             # Borne de date inférieure
Value    Date    PDATMAX             # Borne de date supérieure
Value    Char    PTPEABREV           # Abréviation du masque contenant le type d'écriture à utiliser
Value    Integer PTYPPST             # Type de comtpabilisation : définitive ou provisoire
Value    Integer PLSTTYPPRO          # Le type de compta précédent de la période était provisoire
Value    Integer PFIY                # Exercice courant ou suivant : GVML_TECOURA / GVML_TESUIV
Value    Integer PNUMPER             # Numéro de période de rattachement
Value    Integer PSIMU               # Mode simulation
Value    Integer PDETANA             # Détail analytique en simulation
Value    Integer PDIRECT             # Coptabilisation en mode direct
Variable Integer CDRET               # Code retour
Variable Char    MSGRET()()          # Message de retour

#> Contrôle de présence du masque
If PTPEABREV="" & dim([M:TPE]TABCPT)<0
 CDRET  = 1
 MSGRET = "GENERE_CPT"-"Masque [M:TPE] non ouvert : comptabilisation impossible"
 End
Endif
Gosub TRCTEC_PERIODE From TRTCPTINT5
Gosub DEF_CONSTANTES
Gosub DEF_VARIABLES
Gosub CHARGE_VARIABLES
Gosub DEF_CAS
Gosub OUVRE_TABLES
Gosub DEF_CRITERES
Gosub ALIM_TABTEMP
Gosub CPT
$FIN_GENERE_CPT
Gosub VIDE_TABTEMP
Gosub KILL_CONSTANTES
End

#**
#*=============================================================================
#* Définition des constantes
#*=============================================================================
#*!
$DEF_CONSTANTES
 #-> Définition
 Global Integer GMAXCRITGRP                   # Nombre maximum de critères de regroupement
 Global Char    GFMTDATSQL                    # Format des zones dates pour requêtes
 Global Char    GPRFXTABEVT(4)(1..5)          # Préfixe des tables événement
 # Cas du traitement
 Global Integer GCAS_DEPREC
 Global Integer GCAS_EVENT
 Global Integer GCAS_LINK   #@fq64544
 Global Integer GCAS_AUTRE
 Global Integer GCAS_CCNRPR #FQ54343
 # Type de date à utiliser pour la sélection
 #-> Initialisation
 GMAXCRITGRP = 5
 GFMTDATSQL  = "D:" + GFMDAT4
 GPRFXTABEVT(1)="ELOF"
 GPRFXTABEVT(2)="EFAS"
 GPRFXTABEVT(3)="EGRT"
 GPRFXTABEVT(4)="ELEA"
 GPRFXTABEVT(5)="ECCN"
 GCAS_EVENT    = GVML_SRCEVT
 GCAS_DEPREC   = GVML_SRCDEP
 GCAS_LINK     = GVML_SRCLNK #@fq64544
 GCAS_AUTRE    = GVML_SRCOTH
 GCAS_CCNRPR   = GVML_SRCRPR #FQ54343
Return

#**
#*=============================================================================
#* Définition des variables communes
#*=============================================================================
#*!
$DEF_VARIABLES

 #> Paramètres du sous-pro

 Local Char    LCPY                           # Société à traiter
 Local Char    LTAB(GLONATB)                  # Table déclenchante
 Local Integer LSRC                           # Type de source @fq64544
 Local Integer LOBJTYP                        # Type d'objet métier

 #> Critères

 Local Char    LCRITSUP(255)                  # Critère majeur
 Local Char    LCRITPLN(255)                  # Critère de sélection sur plan
 Local Char    LCRITDAT(255)                  # Critère de sélection sur dates
 Local Char    LCRITDIV(255)                  # Critère de sélection précisé sur le type d'écriture
 Local Char    LCRITCPT(255)                  # Critère pour comptabilisation
 Local Char    LREADKEY(255)                  # Order by de parcours de la table déclenchante

 #> Autres

 Local Char    LTABOBJ(GLONATB)               # Table de l'objet métier correspondant
 Local Char    LTABFLDSEL                     # Champ à tester pour savoir si l'enregistrement est à comptabiliser (Toujours ML 1)
 Local Char    LTABFLDCPT                     # Champ à mettre à jour pour indiquer que l'enregistrement a été comptabilisé
 Local Char    LTABFLDPLN                     # Champ plan d'amortissement
 Local Integer LCAS                           # Cas à traiter : 1-DEPREC / 2-Table exévenement / 3-Table autre
 Local Char    LCRITGRP(10)(1..GMAXCRITGRP)   # Critères de regroupement
 Local Char    LFCY                           # Site à traiter
 Local Integer LDPRPLN                        # Plan à traiter
 Local Date    LDATMIN                        # Date de début de sélection
 Local Date    LDATMAX                        # Date de fin de sélection
 Local Char    LDATFLDMIN                     # Champ date à utiliser (autre que EVTDAT ou CPTDATINT)
 Local Char    LDATFLDMAX                     # Champ date à utiliser (autre que EVTDAT ou CPTDATINT)
 Local Integer LTYPDAT                        # Type de date à utiliser 1 - CPTDATINT ou 2 - EVTDAT
 Local Char    LTRTSPE                        # Traitement spé : cas 3
 If dim(ACTION)<0
  Local Char   ACTION                         # Action
 Endif
 Local Char    SACTION                        # Sauvegarde de l'action superviseur courante
 Local Char    LIGNE(115)                     # Pour émission dans la trace
 Local Integer I_SORT
 Local Integer I_PCE
 Local Char    LSORTFLD
 Local Char    LRUPTFLD
 Local Char    LRUPEVAL(255)
 Local Char    LRUPSAVE(255)
 Local Char    LRUPTRCCRIT(255)
 Local Char    LRUPTRCVAL(255)
 Local Integer LTMPPCENUM
 Local Integer LTMPSEQNUM
 Local Char    SCRITGRP(255),TABGRP,FLDGRP
 Local Integer STAT
 Local Char    MESSA(255)
 Local Char    LCASTRT                        # Nom du traitement correspondant au traitement d'un cas / source @fq64544
 Local Char    LLEG                           # Legislation de la société FQ96055

Return

#**
#*=============================================================================
#* Alimentation des variables communes
#*=============================================================================
#*!
$CHARGE_VARIABLES

 LCPY    = PCPY
 LFCY    = PFCY
 LTAB    = [M:TPE]TABCPT
 LSRC    = [M:TPE]SRCTYP #@fq64544
 LTRTSPE = [M:TPE]TRTSPE
 LTABOBJ = [M:TPE]TABOBJ
 LDPRPLN = [M:TPE]DPRPLN
 LDATMIN = PDATMIN
 LDATMAX = PDATMAX
 LLEG    = [F:CPY]LEG : # FQ96055

 Case LTABOBJ
  When "LAYOUTFAS"  : LOBJTYP = GVML_OMDEPEN
  When "FXDASSETS"  : LOBJTYP = GVML_OMBIEN
  When "GRANTS"     : LOBJTYP = GVML_OMSUBV
  When "LEASE"      : LOBJTYP = GVML_OMLOCFI
  When Default     : LOBJTYP = 0
 Endcase

 GSOCIETE = PCPY #Fq66977

Return

#**
#*=============================================================================
#* Destruction des constantes
#*=============================================================================
#*!
$KILL_CONSTANTES
 If dim(GMAXCRITGRP)>0 : Kill GMAXCRITGRP : Endif
 If dim(GFMTDATSQL)>0  : Kill GFMTDATSQL  : Endif
 If dim(GPRFXTABEVT)>0 : Kill GPRFXTABEVT : Endif
Return

#**
#*=============================================================================
#* Alimentation de variables en fonction du cas de comptabilisation
#*=============================================================================
#*!
$DEF_CAS
  If LTAB="DEPREC"
  #@fq64544
  Case LSRC
   When GVML_SRCDEP
    LCAS = GCAS_DEPREC
    LTABFLDSEL  = "FLGDEV=G_OUI"
    LCASTRT     = "TRTCPTINTDEP"
   When GVML_SRCLNK
    LCAS = GCAS_LINK
    LTABFLDSEL  = "FLGLNKDEV=G_OUI"
    LCASTRT     = "TRTCPTINTLNK"
  Endcase
  LTABFLDPLN  = "DPRPLN"
  LDATFLDMIN  = "PERSTRDAT"
  LDATFLDMAX  = "PERENDDAT"
 Elsif LTAB="CCNRPR"
  #FQ54343
  LCAS        = GCAS_CCNRPR
  LTABFLDSEL  = "FLGDEV=G_OUI"
  LTABFLDPLN  = ""
  LDATFLDMIN  = "PERSTRDAT"
  LDATFLDMAX  = "PERENDDAT"
  LCASTRT     = "TRTCPTINTRPR"
 Elsif find(left$(LTAB,4),GPRFXTABEVT)>0
  LCAS = GCAS_EVENT
  LTABFLDSEL = "CPTFLG<>G_OUI"
  LTABFLDPLN = "DPRPLN"
  LCASTRT    = "TRTCPTINTEVT"
 Else
  LCAS = GCAS_AUTRE
  SACTION = ACTION : ACTION ="DEF_CAS" : Gosub ACTION From =LTRTSPE : ACTION = SACTION
 Endif

 Gosub TRCTEC_CAS From TRTCPTINT5

Return

#**
#*=============================================================================
#* Ouverture des tables nécessaires au traitement
#*=============================================================================
#*!
$OUVRE_TABLES

 If !clalev([F:CPT])  : Local File =LTAB          [F:CPT]  : Endif  # Table à parcourir Lecture
 If !clalev([F:TCD])  : Local File TMPCPTDTA      [F:TCD]  : Endif  # Table temporaire de données
 If !clalev([F:WCPT]) : Local File =[M:TPE]TABCPT [F:WCPT] : Endif  # FQ85914 - remonté ici depuis MAJ_FLAG_COMPTA

 If LCAS=GCAS_DEPREC | LCAS=GCAS_EVENT | LCAS=GCAS_CCNRPR | LCAS=GCAS_LINK
  If !clalev([F:OBJ]) : Local File =LTABOBJ   [F:OBJ] : Endif
  #> Préparation du link pour alimentation de la table temporaire
  Case LOBJTYP
   When GVML_OMDEPEN
    If pat(LTAB,"ELOF*")
     Link [CPT] With [OBJ]LOF0=[F:CPT]REF;[F:CPT]LIN As [RDEC]
    Endif
   When GVML_OMBIEN
    If LTAB="DEPREC"
     Link [CPT] With [OBJ]FAS0=[F:CPT]AASREF As [RDEC]
    Elsif LTAB="CCNRPR"
     Link [CPT] With [OBJ]FAS0=[F:CPT]AASREF As [RDEC]
    Elsif LCAS=GCAS_EVENT & pat(LTAB,"EFAS*")
     Link [CPT] With [OBJ]FAS0=[F:CPT]REF As [RDEC]
    Endif
   When GVML_OMSUBV
    If pat(LTAB,"EGRT*")
     Link [CPT] With [OBJ]GRT0=[F:CPT]REF As [RDEC]
    Endif
   When GVML_OMLOCFI
    If pat(LTAB,"ELEA*")
     Link [CPT] With [OBJ]LEA0=[F:CPT]REF As [RDEC]
    Endif
   When GVML_OMINVEN
  Endcase
 Endif

 If LCAS=GCAS_AUTRE
  # Par défaut, la table autre est liée à la table site pour créer le link RDEC.
  # Le link peut être revu dans OUV_TABLES du TRTSPE
  If !clalev([F:FCY]) : Local File FACILITY [FCY]  : Endif
  Link [CPT] With [FCY]FCY0=[F:CPT]FCY As [RDEC]
  SACTION = ACTION : ACTION ="OUVRE_TABLE" : Gosub ACTION From =LTRTSPE : ACTION = SACTION
 Endif

 #> Point d'entrée pour ouvrir d'autres tables

 GPOINT = "CPTOUVTAB" : Gosub ENTREE From EXEFNC
 If GOK<1 : Return : Endif

Return

#**
#*=============================================================================
#* Définition et alimentation des critères de sélection
#* en fonction du cas de comptabilisation
#*=============================================================================
#*!
$DEF_CRITERES

 #> TABLES STANDARDS
 #  ----------------

 If LCAS=GCAS_DEPREC | LCAS=GCAS_EVENT | LCAS=GCAS_CCNRPR | LCAS=GCAS_LINK
  LCRITSUP = "CPY=LCPY & FCY=LFCY &"+LTABFLDSEL
  If (LCAS=GCAS_DEPREC | LCAS=GCAS_CCNRPR) & PDIRECT=G_OUI & PREF<>""
   LCRITSUP += "& AASREF='"+PREF+"'"
  Endif
  If LCAS=GCAS_EVENT & PDIRECT=G_OUI
   Case LOBJTYP
    When GVML_OMBIEN  : LCRITSUP += "& REF='"+PREF+"'"
    When GVML_OMDEPEN : LCRITSUP += "& REF='"+PREF+"'"
    When GVML_OMLOCFI : LCRITSUP += "& REF='"+PREF+"'"
    When GVML_OMSUBV  : LCRITSUP += "& REF='"+PREF+"'"
   Endcase
  Endif

  If LCAS<>GCAS_CCNRPR
   LCRITPLN = LTABFLDPLN+"=LDPRPLN"
  Endif
  If LDATFLDMIN=""
   If    LTYPDAT=1
    LDATFLDMIN = "CPTDATINT"
   Elsif LTYPDAT=1
    LDATFLDMIN = "EVTDAT"
   Else
    LDATFLDMIN = "CPTDATINT"
   Endif
  Endif
  If LDATFLDMAX=""
   If    LTYPDAT=1
    LDATFLDMAX = "CPTDATINT"
   Elsif LTYPDAT=1
    LDATFLDMAX = "EVTDAT"
   Else
    LDATFLDMAX = "CPTDATINT"
   Endif
  Endif
  LCRITDAT = LDATFLDMIN+">=LDATMIN & "+LDATFLDMAX+"<=LDATMAX"
 Endif

 #> AUTRE TABLE
 #  -----------

 If LCAS=GCAS_AUTRE
  LCRITSUP = "CPY=LCPY&FCY=LFCY&"+LTABFLDSEL
  If [M:TPE]DPRPLN
   LCRITPLN = LTABFLDPLN+"=LDPRPLN"
 Else
   LCRITPLN = "1=1"
  Endif
  SACTION = ACTION : ACTION ="DEF_CRITERES" : Gosub ACTION From =LTRTSPE : ACTION = SACTION
 Endif

 LCRITDIV=[F:TPE]DIVCRIT

 If LCRITSUP="" : LCRITSUP="1=1" : Endif
 If LCRITPLN="" : LCRITPLN="1=1" : Endif
 If LCRITDAT="" : LCRITDAT="1=1" : Endif
 If LCRITDIV="" : LCRITDIV="1=1" : Endif

 GPOINT = "CPTDEFCRIT" : Gosub ENTREE From EXEFNC
 If GOK<1 : Return : Endif

 Gosub TRCTEC_CRITERE From TRTCPTINT5

Return

#**
#*=============================================================================
#* Aiguillage de l'alimentation de la table
#* temporaire en fonction du cas de comptabilisation
#*=============================================================================
#*!
$ALIM_TABTEMP
 Case LCAS
   When GCAS_DEPREC : Gosub DEPREC_VERS_TEMP
   When GCAS_LINK   : Gosub DEPLNK_VERS_TEMP #@fq64544
   When GCAS_EVENT  : Gosub EVENT_VERS_TEMP
   When GCAS_AUTRE  : Gosub AUTRE_VERS_TEMP
   When GCAS_CCNRPR : Gosub CCNRPR_VERS_TEMP
 Endcase
Return


#**
#*=============================================================================
#* La table temporaire est préparée : elle contient les enregistrements
#* nécessaires à la génération des n pièces comptables pour le site et la
#* période en cours de traitement.
#* Une transaction par pièce comptable.
#*=============================================================================
#*!
$CPT
 Gosub TRCTEC_DEB_COMPTABILISE From TRTCPTINT5
 # # issue 113163 & 112850 : déplacé + bas pour permettre la suppression des écritures de simulation
# If !LTMPPCENUM
 #   Return
 # Endif
 # End  issue 113163 & 112850
 Gosub CPT_DEF_VAR     # Définition des variables de travail
 Gosub CPT_INIT_VAR    # Initialisation des variables de travail
 Gosub CPT_SET_JOU_GTE # Détermination type de pièce et journal
 Gosub CPT_OPEN_MASK   # Ouverture des masques de travail
 Gosub CPT_OPEN_TABLE  # Ouverture des tables de travail
 Gosub CPT_SET_ACCDAT  # Détermination de la date comptable
 If PSIMU=G_NON & PDIRECT<>G_OUI
  #Fq69824-deb
  If dim(LTRCINFOPER)<0
   Gosub TRC_PER From TRTCPTINT2
   Global Integer LTRCINFOPER
  Endif
  #Fq69824-fin
  Gosub LIST_PCE_HEAD From TRTCPTINT2
 Endif
 Gosub CPT_DEL_PROPCE  # Suppression des pièces provisoires
 #> Boucle sur la table temporaire
 #  ==============================
If LTMPPCENUM > 0 # issue 113163 & 112850
 For I_PCE=1 To LTMPPCENUM
  Gosub TRCTEC_DEB_COMPTABILISE From TRTCPTINT5
  #Fq69824
  ##FQ63347- Erreur en mise à jour de la table à parcourir
  #Raz LPCGPCEFCY,LPCGPCEJOU,LPCGPCETYP,LPCGPCENUM,LPCGPCEREF,LPCGPCEDES,LPCGPCEDAT
  #Raz LIASPCEFCY,LIASPCEJOU,LIASPCETYP,LIASPCENUM,LIASPCEREF,LIASPCEDES,LIASPCEDAT
  Raz LPCEFCY, LPCETYP, LPCENUM, LPCEACCDAT, LPCEREF, LPCEDES, LPCEJOU
  STAT=0
  MESSA=""
  GOK=1
  Trbegin [F:TCD]
  GABNUMPCE+=1
  LCRITCPT = "TRTNUM=GNUMTRT & PCENUM="+num$(I_PCE)
  Gosub CPT_SET_REFINT
  Gosub CPT_SET_REFSIM
  Gosub CPT_DEF_FIX_VAL
  Gosub CPT_SET_FIX_VAL
  Gosub TRCTEC_PARM_COMPTABILISE From TRTCPTINT5
  Gosub CPT_GEN_PCE
  Gosub CPT_TRT_RESULT
  Gosub TRCTEC_FIN_COMPTABILISE From TRTCPTINT5
 Next I_PCE
Endif # End issue 113163 & 112850
 If PSIMU=G_NON & PDIRECT<>G_OUI
 Endif
 If PDIRECT=G_OUI & [M:TPE]DIRCPTTRA=G_OUI
  Call LEC_TRACE From LECFIC
 Endif
Return

#**
#*=============================================================================
#* Définition des variables nécessaires à la création d'une pièce
#* comptable
#*=============================================================================
#*!
$CPT_DEF_VAR
 Local   Char    LACETYP        # Type d'écriture courant
 Local   Date    LFIXACCDAT     # Date comptable déterminée
 Local   Integer LCPTREF        # Réferentiel
 Local   Integer LCPTPROV       # Type de comptabilisation (simu ou réelle)
 Local   Integer LORIMOD        # ?????
 Local   Integer LNBVALIMPOSE   # Nombre valeur imposée pour VALPCE
 Local   Integer LCAT           # Catégorie de la pièce comptable générée

 Local   Char    LREFINT        # Référence interne de la pièce
 Local   Char    LREFSIM        # Référence de simulation
 Local   Char    LTYPPCE        # Type de pièce issu du type d'écriture
 Local   Char    LJOU           # Journal issu du type d'écriture
 Local   Integer LFIY           # Numéro d'exercice de la pièce
 Local   Integer LPER           # Numéro de période de la pièce
 # Variables destinées à contenir les informations de la pièce générée
 Local   Char    LPCEFCY        # Site de la pièce
 Local   Char    LPCETYP        # Type de la pièce
 Local   Char    LPCENUM        # N° de pièce
 Local   Date    LPCEACCDAT     # Date comptable de la pièce
 Local   Char    LPCEREF        # Référence libre de la pièce
 Local   Char    LPCEDES        # Libellé / Désignation de la pièce
 Local   Char    LPCEJOU        # Journal de la pièce
 # Variables destinées uniquement à l'affichage de la trace
 Local   Char    LTRCPER
Return

#**
#*=============================================================================
#* Initialisation des variables nécessaires à la génération d'une pièce
#* comptable
#*=============================================================================
#*!
$CPT_INIT_VAR
 LACETYP  = [M:TPE]ACETYP
 LCPTREF  = [M:TPE]CPTREF
 LCPTPROV = PTYPPST
 LFIY     = PFIY
 LPER     = PNUMPER
Return

#**
#*=============================================================================
#* Fixation du journal et du type de pièce à utiliser en fonction du
#* paramétrage du type d'écriture
#*=============================================================================
#*!
$CPT_SET_JOU_GTE
 If  ([M:TPE]SRCTYP=GVML_SRCDEP | [M:TPE]SRCTYP=GVML_SRCRPR | [M:TPE]SRCTYP=GVML_SRCLNK) & LCPTPROV=G_OUI
  #> Compta provisoire : détermination du type de pièce
  If [M:TPE]GTEPRO<>""
   LTYPPCE=[M:TPE]GTEPRO
  Elsif [M:TPE]GTEPRO="" & [M:TPE]GTE<>""
   LTYPPCE=[M:TPE]GTE
  Else
   LTYPPCE=""
  Endif
  #> Compta provisoire : détermination du journal
  If [M:TPE]JOUPRO<>""
   LJOU=[M:TPE]JOUPRO
  Elsif [M:TPE]JOUPRO="" & [M:TPE]JOU<>""
   LJOU=[M:TPE]JOU
  Else
   LJOU=""
  Endif
 Else
  #> Compta définitive : type de pièce
  If [M:TPE]GTE<>""
   LTYPPCE=[M:TPE]GTE
  Endif
  If [M:TPE]JOU<>""
   LJOU=[M:TPE]JOU
  Else
   LJOU=""
  Endif
 Endif
Return

#**
#*=============================================================================
#* Ouverture des masques nécessaires à la génération d'une pièce comptable
#*=============================================================================
#*!
#TODO - A supprimer ?
$CPT_OPEN_MASK
 If PSIMU=G_OUI
  If !clalev([M:HAE0])  : Local Mask GACCENT0 [HAE0] : Endif
  If !clalev([M:HAE1])  : Local Mask GACCENT1 [HAE1] : Endif
  If !clalev([M:HAE2])  : Local Mask GACCENT2 [HAE2] : Endif
  If !clalev([M:HA2])   : Local Mask GACCENT2 [HA2]  : Endif
  If !clalev([M:VTL])   : Local Mask VENTILE  [VTL]  : Endif
  If !clalev([M:VT2])   : Local Mask VENTILE2 [VT2]  : Endif
 Endif
Return

#**
#*=============================================================================
#* Ouverture des tables nécessaires à la génération d'une pièce comptable
#*=============================================================================
#*!
$CPT_OPEN_TABLE
  If !clalev([F:THAE])   : Local File =GTABCPT+"GACCTMP"    [THAE] : Endif
 If !clalev([F:TDAE])   : Local File =GTABCPT+"GACCTMPD"   [TDAE] : Endif
 If !clalev([F:TDAA])   : Local File =GTABCPT+"GACCTMPA"   [TDAA] : Endif
Return

#**
#*=============================================================================
#* Détermination de la date comptable
#*=============================================================================
#*!
$CPT_SET_ACCDAT
 Case [M:TPE]ACCDATRUL
  When 1 : LFIXACCDAT = [0/0/0] # Date définie sur la pièce automatique
  When 2 : LFIXACCDAT = [M:TPE]TRTSTRPER # Début de période traitée
  When 3 : LFIXACCDAT = [M:TPE]TRTENDPER # Fin de période traitée
  When 4 : LFIXACCDAT = [M:TPE]DATSTRFIY # Début exercice traité
  When 5 : LFIXACCDAT = [M:TPE]DATENDFIY # Fin exercice traité
  When 6 : LFIXACCDAT = [M:TPE]DATSTRPER # Début période courante
  When 7 : LFIXACCDAT = [M:TPE]DATENDPER # Fin période courante
  When 8 : LFIXACCDAT = [M:TPE]ACCDATFIX # Date saisie
  When 9 : GPOINT = "CPTFIXACCDAT" : Gosub ENTREE From EXEFNC
  When Default LFIXACCDAT=PDATMIN
 Endcase
Return

#**
#*=============================================================================
#* Suppression des pièces provisoires déjà générées
#*=============================================================================
#*!
$CPT_DEL_PROPCE
# issue 113163 & 112850 Depuis que la 1ère période de l'exercice peut être de type de compta Réelle, le test sur la variable PLSTTYPPRO
# n'est plus pertinent car il empêche la suppression de certaines  pièces provisoires.
   If (LCAS = GCAS_DEPREC | [M:TPE]SRCTYP=GVML_SRCLNK | LCAS = GCAS_CCNRPR) & PSIMU=G_NON &
&     (PTYPPST = GVML_TPSTPRO | PTYPPST = GVML_TPSTDEF )
#&    (PTYPPST = GVML_TPSTPRO | (PTYPPST = GVML_TPSTDEF & PLSTTYPPRO=G_OUI )

    Local Integer LPROTRC   # Trace pour les pièces provisoires

    If PDIRECT=G_OUI & [M:TPE]DIRCPTTRA=G_OUI
     Call OUVRE_TRACE("") From LECFIC
    Endif
    If PDIRECT=G_OUI
     LPROTRC=[M:TPE]DIRCPTTRA
    Else
     LPROTRC=G_OUI
    Endif

    Call DELETE_CPT_PROVISOIRE(LCPY,
&                              PFCY,
&                              LCPTREF,
&                              PDATMIN,
&                              PDATMAX,
&                              LFIY,
&                              LPER,
&                              G_NON,
&                              LPROTRC,
&                              [M:TPE]ACETYP,
&                              PDIRECT,
&                              CDRET,
&                              MSGRET) From TRTCPTINT4
    #Fq69824
    #If PTYPPST = GVML_TPSTDEF
    # If PDIRECT<>G_OUI #| (PDIRECT=G_OUI & [M:TPE]DIRCPTTRA=G_OUI)
    #  Call ECR_TRACE("    "+mess(82,GML_MSGCPT,1),0) From GESECRAN #"PIECES COMPTABLES DEFINITIVES CREEES"
    #  Call ECR_TRACE("    "+string$(len(mess(82,GML_MSGCPT,1)),"="),0) From GESECRAN
    # Endif
    #Else
    # If PDIRECT<>G_OUI #| (PDIRECT=G_OUI & [M:TPE]DIRCPTTRA=G_OUI)
    #  Call ECR_TRACE("    "+mess(83,GML_MSGCPT,1),0) From GESECRAN #"PIECES COMPTABLES PROVISOIRES CREEES"
    #  Call ECR_TRACE("    "+string$(len(mess(83,GML_MSGCPT,1)),"="),0) From GESECRAN
    # Endif
    #Endif
   Endif
Return

#**
#*=============================================================================
#* Détermination de la valeur imposée référence interne REFINT
#*=============================================================================
#*!
$CPT_SET_REFINT
   If ([M:TPE]SRCTYP=GVML_SRCDEP | [M:TPE]SRCTYP=GVML_SRCLNK | [M:TPE]SRCTYP=GVML_SRCRPR) & LCPTPROV = G_OUI
    LREFINT = "P"+"-"+num$(GNUMTRT)+"-"+num$(GABNUMPCE)
   Else
    LREFINT = "D"+"-"+num$(GNUMTRT)+"-"+num$(GABNUMPCE)
   Endif
Return

#**
#*=============================================================================
#* Détermination de la valeur imposée référence simulation REFSIM
#*=============================================================================
#*!
$CPT_SET_REFSIM
  If ([M:TPE]SRCTYP=GVML_SRCDEP | [M:TPE]SRCTYP=GVML_SRCLNK | [M:TPE]SRCTYP=GVML_SRCRPR) & LCPTPROV = G_OUI & PSIMU=G_NON
   LREFSIM = "ABL"+"-"+num$(GNUMTRT)+"-"+num$(GABNUMPCE)
  Else
   LREFSIM  = ""
  Endif
Return

#**
#*=============================================================================
#* Détermination du nombre de valeurs imposées pour l'appel à VALPCE
#*=============================================================================
#*!
$CPT_DEF_FIX_VAL
  #*X3-39795 LNBVALIMPOSE = 9
  LNBVALIMPOSE = 11
  Local  Char    TZONE(10)(1..LNBVALIMPOSE)
  Local  Char    TVAL (20)(1..LNBVALIMPOSE)
Return

#**
#*=============================================================================
#* Détermination des valeurs imposées pour l'appel à VALPCE
#*=============================================================================
#*!
$CPT_SET_FIX_VAL
  TZONE(1)="TYP"      : TVAL(1)= LTYPPCE

  # CAT - values of local menu 618 Accounting Journal category
  #   1 : Actual
  #   2 : Active simulation
  #   3 : Inactive simulation
  #   4 : Off-balance sheet
  #   5 : Template
  #
  # STA - values  of local menu 617 Accounting Journal Status
  #   1 : Temporary
  #   2 : Final
  #
  If LCPTPROV = G_OUI
   TZONE(2)="CAT"      : TVAL(2)= "2"
   TZONE(3)="STA"      : TVAL(3)= "1" : # FQ100031 : une pièce de simulation est toujours provisoire
   Else
   TZONE(2)="CAT"      : TVAL(2)= "1"
   TZONE(3)=""         : TVAL(3)= ""  : # FQ100031 : Le statut sera celui de la pièce
  Endif
  #TZONE(3)="STA"      : TVAL(3)= 2 : # FQ83298 : gestion du statut par la pièce auto comme en V5

  TZONE(4)="ACCDAT"   : TVAL(4)= LFIXACCDAT
  TZONE(5)="JOU"      : TVAL(5)= LJOU
  TZONE(6)="FIY"      : TVAL(6)= num$(LFIY)
  TZONE(7)="PER"      : TVAL(7)= num$(LPER)
  TZONE(8)="REFSIM"   : TVAL(8)= LREFSIM
  TZONE(9)="REFINT"   : TVAL(9)= LREFINT
  TZONE(10)= "ORIGIN" : TVAL(10)= "2"      :  #Automatic loading  #*X3-39795
  TZONE(11)= "ORICOD"                                             #*X3-39795


Return

#**
#*=============================================================================
#* Détermination du nombre de valeurs imposées pour l'appel à VALPCE
#*=============================================================================
#*!
$CPT_GEN_PCE
 # Pièce auto seule ou groupe de pièce auto
 If [M:TPE]GAU<>""
   TVAL(11)= [M:TPE]GAU      #*X3-39795
   Call VALPCE4([M:TPE]GAU,LCRITCPT,STAT,MESSA,TZONE,TVAL) From CPTAUTO
 Elsif [M:TPE]GRA<>""
  If !clalev([F:GRA]) : Local File GRPAUTACE [GRA] : Endif
  Local Integer I_GAU
  Local Integer SSTAT
  Read [F:GRA]GRA0=[M:TPE]GRA
  If fstat
   GOK=0
   Call ECR_TRACE(mess(138,GML_MSGCPT,1)-[M:TPE]GRA,1) From GESECRAN #"Groupe de pièces automatiques inexistant"
  Else
   For I_GAU=1 To dim([F:GRA]CODACE)
    If [F:GRA]CODACE(I_GAU-1)<>""
     #Call VALPCE4([F:GRA]CODACE,LCRITCPT,STAT,MESSA,TZONE,TVAL) From CPTAUTO : # FQ85914
     TVAL(11)= [F:GRA]CODACE(I_GAU-1)     #*X3-39795
     Call VALPCE4([F:GRA]CODACE(I_GAU-1),LCRITCPT,STAT,MESSA,TZONE,TVAL) From CPTAUTO
     If STAT : SSTAT=1 : Endif
    Endif
   Next I_GAU
  Endif
  If SSTAT : GOK=0 : Endif
 Endif
Return

#**
#*=============================================================================
#* Traitement du résultat de l'interface comptable
#* Boucle de lecture pour récupérer la ou les pièces générées
#* Pour chaque pièce, mise en forme des informations
#*   - Traitement réel : infos d'identification de la pièce
#*   - Traitement de simulation : détail de la pièce générée
#*      + détail analytique optionnel
#*=============================================================================
#*!
$CPT_TRT_RESULT
 If GOK<1 | STAT
  If (PSIMU = G_OUI) : Gosub DETPCEHEAD From TRTCPTINT2 : Endif : # Fq89935 : PSIMU = G_OUI au lieu de PSIMU
  Call ECR_TRACE(MESSA,1) From GESECRAN
  If (PSIMU = G_OUI) : Gosub TRC_LINE From TRTCPTINT2 : Endif   : # Fq89935 : PSIMU = G_OUI au lieu de PSIMU
 Else
  Case PSIMU
   When G_OUI
    # SIMULATION
    For [THAE] Where REFINT=LREFINT
     If PDIRECT<>G_OUI
      If dim(LTRCINFOPER)<0
       Gosub TRC_PER From TRTCPTINT2
       Global Integer LTRCINFOPER
     Endif
     Endif
     LPCEFCY     = [F:THAE]FCY
     LPCETYP     = [F:THAE]TYP
     LPCENUM     = [F:THAE]NUM
     LPCEJOU     = [F:THAE]JOU
     LPCEACCDAT  = [F:THAE]ACCDAT
     LPCEREF     = [F:THAE]REF
     LPCEDES     = [F:THAE]DESVCR
     LCAT = [F:THAE]CAT
     LTRCPER     = format$(GFMDAT4,PDATMIN)-"=>"-format$(GFMDAT4,PDATMAX)
     Gosub DETPCEHEAD From TRTCPTINT2
     If GOK<1 | STAT
      #Gosub DETACE_ERR From TRTCPTINT2
     Else
      Local Integer LLEDTYP, CLEDTYP, SLEDTYP
      Filter [F:TDAE] Where TYP=[F:THAE]TYP & NUM=[F:THAE]NUM
      For [F:TDAE]DAT2
       CLEDTYP=[F:TDAE]LEDTYP
       If CLEDTYP<>SLEDTYP
        LLEDTYP=CLEDTYP
        SLEDTYP=CLEDTYP
       Else
        Raz LLEDTYP
       Endif
       Gosub DETPCESIM From TRTCPTINT2
    Next
      Filter [F:TDAE]
    Endif
     Gosub TRC_LINE From TRTCPTINT2
     Call ECR_TRACE("",0) From GESECRAN
     #
     If PDETANA=G_OUI
      Filter [F:TDAA] Where TYP=[F:THAE]TYP & NUM=[F:THAE]NUM Order By Key CLETMP=LEDTYP;LIN;ANALIN
      If rowcount([F:TDAA])<>0
       Local Integer LLEDTYP(1..10)
       Local Integer LNBDIEMAX
       For [F:TDAA]CLETMP(1) : LLEDTYP([F:TDAA]LEDTYP)=G_OUI : Next
       For ILEDTYP=1 To 10
        If LLEDTYP(ILEDTYP)=G_OUI
         Local Integer I_DIE, LNBDIELED
         For I_DIE=1 To 9
          If evalue("[M:FPC]CCE"+num$(I_DIE)+"(ILEDTYP-1)<>''")
           LNBDIELED+=1
       Endif
         Next I_DIE
         If LNBDIELED>LNBDIEMAX : LNBDIEMAX=LNBDIELED : Endif
      Endif
       Next ILEDTYP
       Gosub DETANAHEAD From TRTCPTINT2  # En-tête détail analytique
       Local Integer LLEDTYP, CLEDTYP, SLEDTYP
       Local Char    LLINNUM, CLINNUM, SLINNUM
       Local Decimal LMNT
       Local Char    LDIECCE(20)(1..LNBDIEMAX)
       For [F:TDAA]CLETMP
        # Gestion de la rupture sur le référentiel
        CLEDTYP=[F:TDAA]LEDTYP
        If CLEDTYP<>SLEDTYP
         LLEDTYP=CLEDTYP
         SLEDTYP=CLEDTYP
        Else
         Raz LLEDTYP
        Endif
        # Gestion de la rupture sur le n° de ligne
        CLINNUM=num$([F:TDAA]LIN)+","+num$([F:TDAA]ANALIN)
        If CLINNUM<>SLINNUM
         LLINNUM=CLINNUM
         SLINNUM=CLINNUM
        Else
         Raz LLINNUM
        Endif
        # Montant
        LMNT = [F:TDAA]AMTLED
        # Alimentation des couples axe / section
        For I_DIE=1 To LNBDIEMAX
         If [F:TDAA]DIE(I_DIE-1)<>""
          LDIECCE(I_DIE)=[F:TDAA]DIE(I_DIE-1)+"/"+[F:TDAA]CCE(I_DIE-1)
         Else
          LDIECCE(I_DIE)=""
         Endif
        Next I_DIE
        Gosub DETPCEANASIM From TRTCPTINT2
       Next
       Gosub TRC_LINE From TRTCPTINT2
      Endif
      Filter [F:TDAA]
     Endif
    Next
   When Default
    # REEL
    For [THAE] Where REFINT=LREFINT
      If dim(LPCEGEN)<0 : Local Integer LPCEGEN : Endif
      If PDIRECT <> G_OUI
      If dim(LTRCINFOPER)<0
       Gosub TRC_PER From TRTCPTINT2
       Global Integer LTRCINFOPER
      Endif
     Endif
     If dim(LTRCTYPPCE)<0
      If PTYPPST = GVML_TPSTDEF
       If PDIRECT<>G_OUI #| (PDIRECT=G_OUI & [M:TPE]DIRCPTTRA=G_OUI)
        Call ECR_TRACE("    "+mess(82,GML_MSGCPT,1),0) From GESECRAN #"PIECES COMPTABLES DEFINITIVES CREEES"
        Call ECR_TRACE("    "+string$(len(mess(82,GML_MSGCPT,1)),"="),0) From GESECRAN
       Endif
      Else
       If PDIRECT<>G_OUI #| (PDIRECT=G_OUI & [M:TPE]DIRCPTTRA=G_OUI)
        Call ECR_TRACE("    "+mess(83,GML_MSGCPT,1),0) From GESECRAN #"PIECES COMPTABLES PROVISOIRES CREEES"
        Call ECR_TRACE("    "+string$(len(mess(83,GML_MSGCPT,1)),"="),0) From GESECRAN
       Endif
      Endif
      Local Integer LTRCTYPPCE
     Endif
     LPCEFCY     = [F:THAE]FCY
     LPCETYP     = [F:THAE]TYP
     LPCENUM     = [F:THAE]NUM
     LPCEJOU     = [F:THAE]JOU
     LPCEACCDAT  = [F:THAE]ACCDAT
     LPCEREF     = [F:THAE]REF
     LPCEDES     = [F:THAE]DESVCR
     LCAT        = [F:THAE]CAT
     LTRCPER     = format$(GFMDAT4,PDATMIN)-"=>"-format$(GFMDAT4,PDATMAX)
      #> Compta directe avec trace
      If (PDIRECT=G_OUI & [M:TPE]DIRCPTTRA=G_OUI)
       If GTRACE=""
        Call OUVRE_TRACE(mess(79,GML_MSGCPT,1)+"."+mess(22,GML_MSGCPT,1)-PCPY) From LECFIC #"Liste des pièces comptables générées. Société"
       Endif
       Local Integer LMESTYPPCE
       Case PTYPPST
        When GVML_TPSTDEF : LMESTYPPCE=82
        When Default      : LMESTYPPCE=83
       Endcase
       Call ECR_TRACE("    "+mess(LMESTYPPCE,GML_MSGCPT,1),0) From GESECRAN #"PIECES COMPTABLES DEFINITIVES CREEES" ou "PIECES COMPTABLES PROVISOIRES CREEES"
       Call ECR_TRACE("    "+string$(len(mess(LMESTYPPCE,GML_MSGCPT,1)),"="),0) From GESECRAN
      Call ECR_TRACE("Pièce Créée"-LPCETYP-LPCENUM-LPCEREF-LPCEDES-format$("D:" + GFMDAT4,LPCEACCDAT),0) From GESECRAN
       LTRCOPE=1
      Endif
     #> Interface comptable
     If PDIRECT <> G_OUI
      Gosub LIST_PCE From TRTCPTINT2
     Endif
     #> Mise à jour flag de comptabilisation et tables de lien
     If PSIMU=G_NON & GOK
      Gosub MAJ_FLAG_COMPTA
     Endif
    Next
    #Fq71309-Aucune pièce n'a été générée, on met à jour les flag de comptabilisation sans générer d'entrée dans la table des liens
    If dim(LPCEGEN)<0
     Raz [F:THAE] : Gosub MAJ_FLAG_COMPTA
    Else
     Kill LPCEGEN
    Endif
  Endcase
 Endif

 If GOK<>1 | STAT | PSIMU=G_OUI
  Rollback
 Else
  Commit
 Endif

Return

#**
#*=============================================================================
#* Transfert des infos de la table DEPREC vers la table temporaire
#* de comptailisation ==> Comptabilisation des dotations
#*=============================================================================
#*!
$DEPREC_VERS_TEMP

 #> Définition du tri de lecture de la table déclenchante :

 If [M:TPE]SORTCCE=G_OUI
  LREADKEY = "[F:OBJ]DSP;[F:OBJ]CCE"
 Endif

 For I_SORT=1 To [M:TPE]NBCRIT
  If [M:TPE]SORTFLDTAB(I_SORT-1)=[M:TPE]TABOBJ
   LSORTFLD="[F:OBJ]"
  Elsif [M:TPE]SORTFLDTAB(I_SORT-1)=[M:TPE]TABCPT
   LSORTFLD="[F:CPT]"
  Endif
  If [M:TPE]SORTFLD(I_SORT-1)<>""
   LSORTFLD+=[M:TPE]SORTFLD(I_SORT-1)
  Endif
  If LSORTFLD<>""
   If LREADKEY<>""
    LREADKEY+=";"
   Endif
   LREADKEY+=LSORTFLD
  Endif
 Next I_SORT

 #> Définition des champs à surveiller pour l'incrément du munéro de pièce

 LRUPTFLD=""
 If find(G_OUI,[M:TPE]RUPPCEFLG)
   For I_SORT=1 To [M:TPE]NBCRIT
    If [M:TPE]SORTFLDTAB(I_SORT-1)=[M:TPE]TABOBJ
     LRUPTFLD="[F:OBJ]"
    Elsif [M:TPE]SORTFLDTAB(I_SORT-1)=[M:TPE]TABCPT
     LRUPTFLD="[F:CPT]"
    Endif
    If [M:TPE]SORTFLD(I_SORT-1)<>""
     LRUPTFLD+=[M:TPE]SORTFLD(I_SORT-1)
    Endif
    If LRUPEVAL<>""
     LRUPEVAL+="+"
     LRUPTRCVAL+="+' / '+"
     LRUPTRCCRIT+=" / "
    Endif
    LRUPEVAL+="num$("+LRUPTFLD+")"
    LRUPTRCVAL +="num$("+LRUPTFLD+")"
    LRUPTRCCRIT +=[M:TPE]SORTFLDDES(I_SORT-1)
    If [M:TPE]RUPPCEFLG(I_SORT-1)=G_OUI
     Break
    Endif
   Next I_SORT
 Endif

 #> Remplissage

 GOK=1
 Trbegin [TCD]
 If LREADKEY<>""
  Call ECR_TRACE(mess(130,126,1)-":"-LREADKEY,0) From GESECRAN
  Filter [RDEC] Where evalue(LCRITSUP) & evalue(LCRITPLN) & evalue(LCRITDAT) & evalue(LCRITDIV) Order With Key CLE=LREADKEY
 Elsif find("SPE_DEP0",[G:RDEC]keyname(0..[G:RDEC]nbind-1)) # FQ96021
  Call ECR_TRACE(mess(74,126,1)-": SPE_DEP0",0) From GESECRAN
  Filter [RDEC] Where evalue(LCRITSUP) & evalue(LCRITPLN) & evalue(LCRITDAT) & evalue(LCRITDIV) Order By Key SPE_DEP0
 Else
  Filter [RDEC] Where evalue(LCRITSUP) & evalue(LCRITPLN) & evalue(LCRITDAT) & evalue(LCRITDIV)
 Endif

 Gosub TRCTEC_VERS_TEMP From TRTCPTINT5

 For [RDEC]
  #> Incrémentation / Raz des compteurs et indicateurs
  If LRUPEVAL<>""
   If evalue(LRUPEVAL+"<>LRUPSAVE")
    LTMPPCENUM +=1
    Raz LTMPSEQNUM
    LRUPSAVE = evalue(LRUPEVAL)
   Endif
   LTMPSEQNUM+=1
  Else
   LTMPPCENUM=1
   LTMPSEQNUM+=1
  Endif
  #> Alimentation de la table de données TMPCPTDTA [TCD]
  Raz [F:TCD]
  [F:TCD]TRTNUM    = GNUMTRT
  [F:TCD]PCENUM    = LTMPPCENUM
  [F:TCD]SEQNUM    = LTMPSEQNUM
  [F:TCD]TYP       = 5 #FQ56798
  [F:TCD]CPTKEY(0) = [F:CPT]AASREF
  [F:TCD]CPTKEY(1) = num$([F:CPT]DPRPLN)
  [F:TCD]CPTKEY(2) = "["+format$("D:DD[/]MM[/]YYYY",[F:CPT]FIYENDDAT)+"]"
  [F:TCD]CPTKEY(3) = "["+format$("D:DD[/]MM[/]YYYY",[F:CPT]PERENDDAT)+"]"
  If LRUPTRCCRIT<>""
   [F:TCD]AGRKEY    = LRUPTRCCRIT-":"-evalue(LRUPTRCVAL)
  Endif
  [F:TCD]CPY       = LCPY
  [F:TCD]FCY       = LFCY
  #If dim([F:TCD]LEG)>0 : [F:TCD]LEG = [M:TPE]LEG : Endif : # FQ96055
  If dim([F:TCD]LEG)>0 : [F:TCD]LEG = LLEG : Endif
  [F:TCD]CPTREF    = [M:TPE]CPTREF
  [F:TCD]REF       = [F:OBJ]AASREF
  #*Fq-85066 Gosub DEPREC_ALIM From TRTCPTINT9
  If [M:TPE]TRTINT<>""
   Gosub ALIM_TCD From =[M:TPE]TRTINT
  Endif
  If GOK
   Write [F:TCD]
   If fstat
    GOK=0
    LIGNE = "TRTCPTINT1-$DEPREC_VERS_TEMP-Write [F:TCD]"-num$(fstat)
    Call ECR_TRACE(LIGNE,1) From GESECRAN
    Break
   Endif
  Endif
  Gosub TRCTEC_VERS_TEMP_VIDE_CPT From TRTCPTINT5
 Next
 Filter [RDEC]
 If GOK
  Commit
 Else
  Rollback
 Endif

 Gosub TRCTEC_TMPTABDTA From TRTCPTINT5 #@dev

Return

#**
#*=============================================================================
#* Transfert des infos de la table DEPREC/Liens entre plans vers la table
#* temporaire de comptailisation ==> Comptabilisation des écarts entre plans
#*=============================================================================
#*!
$DEPLNK_VERS_TEMP
 #> Définition du tri de lecture de la table déclenchante :

 If [M:TPE]SORTCCE=G_OUI
  LREADKEY = "[F:OBJ]DSP;[F:OBJ]CCE"
 Endif

 For I_SORT=1 To [M:TPE]NBCRIT
  If [M:TPE]SORTFLDTAB(I_SORT-1)=[M:TPE]TABOBJ
   LSORTFLD="[F:OBJ]"
  Elsif [M:TPE]SORTFLDTAB(I_SORT-1)=[M:TPE]TABCPT
   LSORTFLD="[F:CPT]"
  Endif
  If [M:TPE]SORTFLD(I_SORT-1)<>""
   LSORTFLD+=[M:TPE]SORTFLD(I_SORT-1)
  Endif
  If LSORTFLD<>""
   If LREADKEY<>""
    LREADKEY+=";"
   Endif
   LREADKEY+=LSORTFLD
  Endif
 Next I_SORT

 #> Définition des champs à surveiller pour l'incrément du munéro de pièce

 LRUPTFLD=""
 If find(G_OUI,[M:TPE]RUPPCEFLG)
   For I_SORT=1 To [M:TPE]NBCRIT
    If [M:TPE]SORTFLDTAB(I_SORT-1)=[M:TPE]TABOBJ
     LRUPTFLD="[F:OBJ]"
    Elsif [M:TPE]SORTFLDTAB(I_SORT-1)=[M:TPE]TABCPT
     LRUPTFLD="[F:CPT]"
    Endif
    If [M:TPE]SORTFLD(I_SORT-1)<>""
     LRUPTFLD+=[M:TPE]SORTFLD(I_SORT-1)
    Endif
    If LRUPEVAL<>""
     LRUPEVAL+="+"
     LRUPTRCVAL+="+' / '+"
     LRUPTRCCRIT+=" / "
    Endif
    LRUPEVAL+="num$("+LRUPTFLD+")"
    LRUPTRCVAL +="num$("+LRUPTFLD+")"
    LRUPTRCCRIT +=[M:TPE]SORTFLDDES(I_SORT-1)
    If [M:TPE]RUPPCEFLG(I_SORT-1)=G_OUI
     Break
    Endif
   Next I_SORT
 Endif

 #> Remplissage

 GOK=1
 Trbegin [TCD]
 If LREADKEY<>""
  Call ECR_TRACE(mess(130,126,1)-":"-LREADKEY,0) From GESECRAN
  Filter [RDEC] Where evalue(LCRITSUP) & evalue(LCRITPLN) & evalue(LCRITDAT) & evalue(LCRITDIV) Order With Key CLE=LREADKEY
 Elsif find("SPE_DEP1",[G:RDEC]keyname(0..[G:RDEC]nbind-1)) # FQ96021
  Call ECR_TRACE(mess(74,126,1)-": SPE_DEP1",0) From GESECRAN
  Filter [RDEC] Where evalue(LCRITSUP) & evalue(LCRITPLN) & evalue(LCRITDAT) & evalue(LCRITDIV) Order By Key SPE_DEP1
 Else
  Filter [RDEC] Where evalue(LCRITSUP) & evalue(LCRITPLN) & evalue(LCRITDAT) & evalue(LCRITDIV)
 Endif

 Gosub TRCTEC_VERS_TEMP From TRTCPTINT5

 For [RDEC]
  #> Incrémentation / Raz des compteurs et indicateurs
  If LRUPEVAL<>""
   If evalue(LRUPEVAL+"<>LRUPSAVE")
    LTMPPCENUM +=1
    Raz LTMPSEQNUM
    LRUPSAVE = evalue(LRUPEVAL)
   Endif
   LTMPSEQNUM+=1
  Else
   LTMPPCENUM=1
   LTMPSEQNUM+=1
  Endif
  #> Alimentation de la table de données TMPCPTDTA [TCD]
  Raz [F:TCD]
  [F:TCD]TRTNUM    = GNUMTRT
  [F:TCD]PCENUM    = LTMPPCENUM
  [F:TCD]SEQNUM    = LTMPSEQNUM
  [F:TCD]TYP       = 5
  [F:TCD]CPTKEY(0) = [F:CPT]AASREF
  [F:TCD]CPTKEY(1) = num$([F:CPT]DPRPLN)
  [F:TCD]CPTKEY(2) = "["+format$("D:DD[/]MM[/]YYYY",[F:CPT]FIYENDDAT)+"]"
  [F:TCD]CPTKEY(3) = "["+format$("D:DD[/]MM[/]YYYY",[F:CPT]PERENDDAT)+"]"
  If LRUPTRCCRIT<>""
   [F:TCD]AGRKEY    = LRUPTRCCRIT-":"-evalue(LRUPTRCVAL)
  Endif
  [F:TCD]CPY       = LCPY
  [F:TCD]FCY       = LFCY
  #If dim([F:TCD]LEG)>0 : [F:TCD]LEG = [M:TPE]LEG : Endif : # FQ96055
  If dim([F:TCD]LEG)>0 : [F:TCD]LEG = LLEG : Endif
  [F:TCD]CPTREF    = [M:TPE]CPTREF
  [F:TCD]REF       = [F:OBJ]AASREF
 #Gosub DEPLNK_ALIM From TRTCPTINT9
  If [M:TPE]TRTINT<>""
   Gosub ALIM_TCD From =[M:TPE]TRTINT
  Endif
  If GOK
   Write [F:TCD]
   If fstat
    GOK=0
    LIGNE = "TRTCPTINT1-$DEPLNK_VERS_TEMP-Write [F:TCD]"-num$(fstat)
    Call ECR_TRACE(LIGNE,1) From GESECRAN
    Break
   Endif
  Endif
  Gosub TRCTEC_VERS_TEMP_VIDE_CPT From TRTCPTINT5
 Next
 Filter [RDEC]
 If GOK
  Commit
 Else
  Rollback
 Endif

 Gosub TRCTEC_TMPTABDTA From TRTCPTINT5 #@dev
Return

#**
#*=============================================================================
#* Transfert des infos de la table événement vers la table temporaire
#* de comptabilisation
#*=============================================================================
#*!
$EVENT_VERS_TEMP
 #> Définition du tri de lecture de la table déclenchante :

 If [M:TPE]SORTCCE=G_OUI
  LREADKEY = "[F:OBJ]DSP"
 Endif

 For I_SORT=1 To [M:TPE]NBCRIT
  If [M:TPE]SORTFLDTAB(I_SORT-1)=[M:TPE]TABOBJ
   LSORTFLD="[F:OBJ]"
  Elsif [M:TPE]SORTFLDTAB(I_SORT-1)=[M:TPE]TABCPT
   LSORTFLD="[F:CPT]"
  Endif
  If [M:TPE]SORTFLD(I_SORT-1)<>""
   LSORTFLD+=[M:TPE]SORTFLD(I_SORT-1)
  Endif
  If LSORTFLD<>""
   If LREADKEY<>""
    LREADKEY+=";"
   Endif
   LREADKEY+=LSORTFLD
  Endif
 Next I_SORT

 #> Définition des champs à surveiller pour l'incrément du munéro de pièce

  If find(G_OUI,[M:TPE]RUPPCEFLG)
   For I_SORT=1 To [M:TPE]NBCRIT
    If [M:TPE]SORTFLDTAB(I_SORT-1)=[M:TPE]TABOBJ
     LRUPTFLD="[F:OBJ]"
    Elsif [M:TPE]SORTFLDTAB(I_SORT-1)=[M:TPE]TABCPT
     LRUPTFLD="[F:CPT]"
    Endif
    If [M:TPE]SORTFLD(I_SORT-1)<>""
     LRUPTFLD+=[M:TPE]SORTFLD(I_SORT-1)
    Endif
    If LRUPEVAL<>""
     LRUPEVAL+="+"
     LRUPTRCVAL+="+' / '+"
     LRUPTRCCRIT+=" / "
    Endif
    LRUPEVAL+="num$("+LRUPTFLD+")"
    LRUPTRCVAL +="num$("+LRUPTFLD+")"
    LRUPTRCCRIT +=[M:TPE]SORTFLDDES(I_SORT-1)
    If [M:TPE]RUPPCEFLG(I_SORT-1)=G_OUI
     Break
    Endif
   Next I_SORT
  Endif

 #> Remplissage

 GOK=1
 Trbegin [TCD]
 If LREADKEY<>""
  Filter [RDEC] Where evalue(LCRITSUP) & evalue(LCRITPLN) & evalue(LCRITDAT) & evalue(LCRITDIV) Order With Key CLE=LREADKEY
 Else
  Filter [RDEC] Where evalue(LCRITSUP) & evalue(LCRITPLN) & evalue(LCRITDAT) & evalue(LCRITDIV)
 Endif

 Gosub TRCTEC_VERS_TEMP From TRTCPTINT5
 For [RDEC]
  #> Incrémentation / Raz des compteurs et indicateurs
  If LRUPEVAL<>""
   If evalue(LRUPEVAL+"<>LRUPSAVE")
    LTMPPCENUM +=1
    Raz LTMPSEQNUM
    LRUPSAVE = evalue(LRUPEVAL)
   Endif
   LTMPSEQNUM+=1
  Else
   LTMPPCENUM=1
   LTMPSEQNUM+=1
  Endif

  #> Alimentation de la table de données TMPCPTDTA [TCD] : PARTIE COMMUNE A TOUS LES TYPES D'EVENEMENT

  Raz [F:TCD]
  [F:TCD]TRTNUM    = GNUMTRT
  [F:TCD]PCENUM    = LTMPPCENUM
  [F:TCD]SEQNUM    = LTMPSEQNUM
  [F:TCD]CPTKEY(0) = [F:CPT]REF
  [F:TCD]CPTKEY(1) = [F:CPT]TIMSTP
  [F:TCD]CPTKEY(2) = num$([F:CPT]DPRPLN)
  If LRUPTRCCRIT<>""
   [F:TCD]AGRKEY    = LRUPTRCCRIT-":"-evalue(LRUPTRCVAL)
  Endif
  [F:TCD]CPY       = LCPY
  [F:TCD]FCY       = LFCY
  [F:TCD]CPTREF    = [M:TPE]CPTREF

  #If dim([F:TCD]LEG)>0 : [F:TCD]LEG = [M:TPE]LEG : Endif  : # FQ96055
  If dim([F:TCD]LEG)>0 : [F:TCD]LEG = LLEG : Endif
  #Fq69032
  [F:TCD]REF       = [F:CPT]REF
  [F:TCD]LIN       = [F:CPT]LIN
  Case LOBJTYP
   When GVML_OMBIEN
    [F:TCD]TYP       = 5 #FQ56798
   When GVML_OMLOCFI
    [F:TCD]TYP       = 6 #FQ56798
   When GVML_OMCCN
    [F:TCD]TYP       = 7 #FQ56798
   When Default
  Endcase
  If [M:TPE]TRTINT<>""
   Gosub ALIM_TCD From =[M:TPE]TRTINT
  Endif

  #Case [M:TPE]EVTTYP
  # When "LOFCIM"    : Gosub EVENEMENT_LOFCIM    From TRTCPTINT9
  # When "LOFVATREG" : Gosub EVENEMENT_LOFVATREG From TRTCPTINT9
  # When "LOFCNL"    : Gosub EVENEMENT_LOFCNL    From TRTCPTINT9
  # When "FASACT"    : Gosub EVENEMENT_FASACT    From TRTCPTINT9
  # When "FASAFFAGE" : Gosub EVENEMENT_FASAFFAGE From TRTCPTINT9
  # When "FASCHGIMP" : Gosub EVENEMENT_FASCHGIMP From TRTCPTINT9
  # When "FASCRT"    : Gosub EVENEMENT_FASCRT    From TRTCPTINT9
  # When "FASIML"    : Gosub EVENEMENT_FASIML    From TRTCPTINT9
  # When "FASISS"    : Gosub EVENEMENT_FASISS    From TRTCPTINT9
  # When "FASMTC"    : Gosub EVENEMENT_FASMTC    From TRTCPTINT9
  # When "FASREEVAL" : Gosub EVENEMENT_FASREEVAL From TRTCPTINT9
  # When "FASVATREG" : Gosub EVENEMENT_FASVATREG From TRTCPTINT9
  # When "FASCNL"    : Gosub EVENEMENT_FASCNL    From TRTCPTINT9
  # When "FASRNW"    : Gosub EVENEMENT_FASRNW    From TRTCPTINT9
  # When "GRTCASH"   : Gosub EVENEMENT_GRTCASH   From TRTCPTINT9
  # When "GRTCRB"    : Gosub EVENEMENT_GRTCRB    From TRTCPTINT9
  # When "GRTCRT"    : Gosub EVENEMENT_GRTCRT    From TRTCPTINT9
  # When "GRTCNL"    : Gosub EVENEMENT_GRTCNL    From TRTCPTINT9
  # When "LEAACTU"   : Gosub EVENEMENT_LEAACTU   From TRTCPTINT9
  # When "LEACRT"    : Gosub EVENEMENT_LEACRT    From TRTCPTINT9
  # When "LEAEND"    : Gosub EVENEMENT_LEAEND    From TRTCPTINT9
  # When "LEAPAY"    : Gosub EVENEMENT_LEAPAY    From TRTCPTINT9
  # When "LEARPU"    : Gosub EVENEMENT_LEARPU    From TRTCPTINT9
  # When "LEATRM"    : Gosub EVENEMENT_LEATRM    From TRTCPTINT9
  # When "LEACNL"    : Gosub EVENEMENT_LEACNL    From TRTCPTINT9
  # When Default     : Gosub EVENEMENT_X         From TRTCPTINT9
  #Endcase

  If GOK
   Write [F:TCD]
   If fstat
    GOK=0
    LIGNE = "TRTCPTINT1-$DEPREC_VERS_TEMP-Write [F:TCD]"-num$(fstat)
    Call ECR_TRACE(LIGNE,1) From GESECRAN
    Break
   Endif
  Endif
 Next
 Filter [RDEC]
 If GOK
  Commit
 Else
  Rollback
 Endif

 Gosub TRCTEC_TMPTABDTA From TRTCPTINT5 #@dev

Return

