#**
#*=============================================================================
#* Transfert des infos d'une table autre vers la table temporaire
#* de comptabilisation
#*=============================================================================
#*!
$AUTRE_VERS_TEMP
 SACTION = ACTION : ACTION ="AVANT_TABTEMP" : Gosub ACTION From =LTRTSPE : ACTION = SACTION

 #> Définition du tri de lecture de la table déclenchante :

 For I_SORT=1 To [M:TPE]NBCRIT
  If [M:TPE]SORTFLDTAB(I_SORT-1)=[M:TPE]TABOBJ
   LSORTFLD="[F:OBJ]"
  Elsif [M:TPE]SORTFLDTAB(I_SORT-1)=[M:TPE]TABCPT
   LSORTFLD="[F:CPT]"
  Endif
  If [M:TPE]SORTFLD(I_SORT-1)<>""
   LSORTFLD+=[M:TPE]SORTFLD(I_SORT-1)
  Endif
  If LSORTFLD<>""
   If LREADKEY<>""
    LREADKEY+=";"
   Endif
   LREADKEY+=LSORTFLD
  Endif
 Next I_SORT

 #> Définition des champs à surveiller pour l'incrément du munéro de pièce

 LRUPTFLD=""
 If find(G_OUI,[M:TPE]RUPPCEFLG)
  For I_SORT=1 To [M:TPE]NBCRIT
   If [M:TPE]SORTFLDTAB(I_SORT-1)=[M:TPE]TABOBJ
    LRUPTFLD="[F:OBJ]"
    Elsif [M:TPE]SORTFLDTAB(I_SORT-1)=[M:TPE]TABCPT
    LRUPTFLD="[F:CPT]"
   Endif
   If [M:TPE]SORTFLD(I_SORT-1)<>""
    LRUPTFLD+=[M:TPE]SORTFLD(I_SORT-1)
   Endif
   If LRUPEVAL<>""
    LRUPEVAL+="+"
    LRUPTRCVAL+="+' / '+"
    LRUPTRCCRIT+=" / "
   Endif
   LRUPEVAL+="num$("+LRUPTFLD+")"
   LRUPTRCVAL +="num$("+LRUPTFLD+")"
   LRUPTRCCRIT +=[M:TPE]SORTFLDDES(I_SORT-1)
   If [M:TPE]RUPPCEFLG(I_SORT-1)=G_OUI
    Break
   Endif
  Next I_SORT
 Endif

 #> Remplissage

 GOK=1
 Trbegin [TCD]
 If LREADKEY<>""
  Filter [RDEC] Where evalue(LCRITSUP) & evalue(LCRITPLN) & evalue(LCRITDAT) & evalue(LCRITDIV) Order With Key CLE=LREADKEY
 Else
  Filter [RDEC] Where evalue(LCRITSUP) & evalue(LCRITPLN) & evalue(LCRITDAT) & evalue(LCRITDIV)
 Endif

 Gosub TRCTEC_VERS_TEMP From TRTCPTINT5

 For [RDEC]
  #> Incrémentation / Raz des compteurs et indicateurs
  If LRUPEVAL<>""
   If evalue(LRUPEVAL+"<>LRUPSAVE")
    LTMPPCENUM +=1
    Raz LTMPSEQNUM
    LRUPSAVE = evalue(LRUPEVAL)
   Endif
   LTMPSEQNUM+=1
  Else
   LTMPPCENUM=1
   LTMPSEQNUM+=1
  Endif
  #> Alimentation de la table de données TMPCPTDTA [TCD]
  Raz [F:TCD]
  [F:TCD]TRTNUM    = GNUMTRT
  [F:TCD]PCENUM    = LTMPPCENUM
  [F:TCD]SEQNUM    = LTMPSEQNUM

  #> raf Alimentation de la clé de l'enreg courant : a faire dans le traitement spe
# [F:TCD]CPTKEY(0) = [F:CPT]AASREF
# [F:TCD]CPTKEY(1) = "["+format$("D:DD[/]MM[/]YYYY",[F:CPT]FIYENDDAT)+"]"
# [F:TCD]CPTKEY(2) = "["+format$("D:DD[/]MM[/]YYYY",[F:CPT]PERENDDAT)+"]"

  If LRUPTRCCRIT<>""
   [F:TCD]AGRKEY    = LRUPTRCCRIT-":"-evalue(LRUPTRCVAL)
  Endif
  [F:TCD]CPY       = LCPY
  [F:TCD]FCY       = LFCY
# [F:TCD]REF       = [F:OBJ]AASREF

  SACTION = ACTION : ACTION ="ALIM_TABTEMP" : Gosub ACTION From =LTRTSPE : ACTION = SACTION

 #Gosub OTHER_ALIM From TRTCPTINT9
  If [M:TPE]TRTINT<>""
   Gosub ALIM_TCD From =[M:TPE]TRTINT
  Endif

  If GOK
   Write [F:TCD]
   If fstat
    GOK=0
    LIGNE = "TRTCPTINT1-$AUTRE_VERS_TEMP-Write [F:TCD]"-num$(fstat)
    Call ECR_TRACE(LIGNE,1) From GESECRAN
    Break
   Endif
  Endif
  Gosub TRCTEC_VERS_TEMP_VIDE_CPT From TRTCPTINT5
 Next
 Filter [RDEC]
 If GOK
  Commit
 Else
  Rollback
 Endif

 #Gosub TRCTEC_TMPTABDTA From TRTCPTINT5 #@dev
 SACTION = ACTION : ACTION ="APRES_TABTEMP" : Gosub ACTION From =LTRTSPE : ACTION = SACTION

Return

#**
#*=============================================================================
#* Mise à jour des flag de comptabilisation des DEPREC ou des événements
#* comptabilisés avec succès
#*=============================================================================
#*!
$MAJ_FLAG_COMPTA

 #Local File =[M:TPE]TABCPT [WCPT] : # FQ85914 - remonté car appel de cette étiquette
 Local Integer KNUMENR
 Local Integer NOPIECE

 If LCAS = GCAS_DEPREC
  Local Char    KAASREF
  Local Integer KDPRPLN
  Local Date    KFIYENDDAT
  Local Date    KPERENDDAT
  Local Decimal KPSTDPE
  Local Decimal KPSTEXC
  Local Decimal KPSTDER
  Local Decimal KPSTDERRVE
  Local Decimal KPSTRVETRF
  Local Decimal KPSTRVACRB
  If G_ACTCCN=G_OUI
   Local Decimal KPSTCADCRB
  Endif
 Endif

 If LCAS = GCAS_LINK
  Local Char    KAASREF
  Local Integer KDPRPLN
  Local Date    KFIYENDDAT
  Local Date    KPERENDDAT
  Local Decimal KPSTLNK
 Endif

 If LCAS = GCAS_CCNRPR
  Local Char    KAASREF
  Local Date    KFIYENDDAT
  Local Date    KPERENDDAT
  Local Decimal KPSTACGRPR
  Local Decimal KPSTFISRPR
 Endif

 If LCAS = GCAS_EVENT
  Local Char    KREF
  Local Char    KTIMSTP
 Endif

 If LCAS = GCAS_AUTRE
  SACTION = ACTION : ACTION ="AVANT_MAJ_FLAG_COMPTA" : Gosub ACTION From =LTRTSPE : ACTION = SACTION
 Endif

 #Fq69824
 #If LCPTREF=GVML_TLSOC & LPCGPCETYP="" & LPCGPCENUM="" : NOPIECE=1 : Endif
 #If LCPTREF=GVML_TLIAS & LIASPCETYP="" & LIASPCENUM="" : NOPIECE=1 : Endif
  If LPCETYP="" & LPCENUM="" : NOPIECE=1 : Endif

 #Fq89935 : ajout de l'indx TCD0. Si on ne met pas d'index, le Read qui peut être fait en cas d'erreur dans TRTCPTINT2
 #          ligne 177 "Read [F:TCD]TCD0(2)=GNUMTRT;I_PCE" va fausser le For qui ne renverra qu'une seule ligne
 For [F:TCD]TCD0 Where evalue(LCRITCPT)

  #> Table DEPREC

  If LCAS = GCAS_DEPREC
   KAASREF    = [F:TCD]CPTKEY(0)
   KDPRPLN    = val([F:TCD]CPTKEY(1))
   KFIYENDDAT = evalue([F:TCD]CPTKEY(2))
   KPERENDDAT = evalue([F:TCD]CPTKEY(3))

   Read [F:WCPT]DEP0=KAASREF;KDPRPLN;KFIYENDDAT;KPERENDDAT
   If fstat
    GOK=0
    Break
   Endif
   KPSTDPE    = [F:WCPT]DPEDEV
   KPSTEXC    = [F:WCPT]EXCDEV
   KPSTDER    = [F:WCPT]DERDEV
   KPSTDERRVE = [F:WCPT]DERRVEDEV
   KPSTRVETRF = [F:WCPT]RVETRFDEV
   KPSTRVACRB = [F:WCPT]RVACRBDEV
   If G_ACTCCN=G_OUI
    KPSTCADCRB = [F:WCPT]CADCRBDEV
   Endif

   If LCPTPROV<>G_OUI
    [F:WCPT]FLGDEV     = G_NON
    [F:WCPT]PSTDPE    += [F:WCPT]DPEDEV    : [F:WCPT]DPEDEV    = 0
    [F:WCPT]PSTEXC    += [F:WCPT]EXCDEV    : [F:WCPT]EXCDEV    = 0
    [F:WCPT]PSTDER    += [F:WCPT]DERDEV    : [F:WCPT]DERDEV    = 0
    [F:WCPT]PSTDERRVE += [F:WCPT]DERRVEDEV : [F:WCPT]DERRVEDEV = 0
    [F:WCPT]PSTRVETRF += [F:WCPT]RVETRFDEV : [F:WCPT]RVETRFDEV = 0
    [F:WCPT]PSTRVACRB += [F:WCPT]RVACRBDEV : [F:WCPT]RVACRBDEV = 0
    If G_ACTCCN=G_OUI
     [F:WCPT]PSTCADCRB += [F:WCPT]CADCRBDEV : [F:WCPT]CADCRBDEV = 0
    Endif
    If [F:WCPT]FLGPST <> G_NON
     [F:WCPT]FLGPST = G_OUI
    Endif
    Rewrite [F:WCPT]
    If fstat
     GOK=0
     Break
    Endif
   Endif
   Gosub MAJ_LNKCPTABD
   If GOK=0 : Break : Endif
  Endif

  If LCAS = GCAS_LINK
   KAASREF    = [F:TCD]CPTKEY(0)
   KDPRPLN    = val([F:TCD]CPTKEY(1))
   KFIYENDDAT = evalue([F:TCD]CPTKEY(2))
   KPERENDDAT = evalue([F:TCD]CPTKEY(3))

   Read [F:WCPT]DEP0=KAASREF;KDPRPLN;KFIYENDDAT;KPERENDDAT
   If fstat
    GOK=0
    Break
   Endif
   KPSTLNK    = [F:WCPT]LNKDEV

   If LCPTPROV<>G_OUI
    [F:WCPT]FLGLNKDEV  = G_NON
    [F:WCPT]PSTLNK    += [F:WCPT]LNKDEV    : [F:WCPT]LNKDEV    = 0
    If [F:WCPT]FLGPSTLNK <> G_NON
     [F:WCPT]FLGPSTLNK = G_OUI
    Endif
    Rewrite [F:WCPT]
    If fstat
     GOK=0
     Break
    Endif
   Endif
   Gosub MAJ_LNKCPTABD
   If GOK=0 : Break : Endif
  Endif

  #> Table CCNRPR : Provisions pour renouvellement

  If LCAS = GCAS_CCNRPR
   KAASREF    = [F:TCD]CPTKEY(0)
   KFIYENDDAT = evalue([F:TCD]CPTKEY(1))
   KPERENDDAT = evalue([F:TCD]CPTKEY(2))

   Read [F:WCPT]RPR0=KAASREF;KFIYENDDAT;KPERENDDAT
   If fstat
    GOK=0
    Break
   Endif
   KPSTACGRPR    = [F:WCPT]ACGRPRDEV
   KPSTFISRPR    = [F:WCPT]FISRPRDEV
   If LCPTPROV<>G_OUI
    [F:WCPT]FLGDEV     = G_NON
    [F:WCPT]PSTACGRPR += [F:WCPT]ACGRPRDEV    : [F:WCPT]ACGRPRDEV    = 0
    [F:WCPT]PSTFISRPR += [F:WCPT]FISRPRDEV    : [F:WCPT]FISRPRDEV    = 0
    If [F:WCPT]FLGPST <> G_NON
     [F:WCPT]FLGPST = G_OUI
    Endif
    Rewrite [F:WCPT]
    If fstat
     GOK=0
     Break
    Endif
   Endif
   Gosub MAJ_LNKCPTABD
   If GOK=0 : Break : Endif
  Endif

  #> Evénements

  If LCAS = GCAS_EVENT
   KREF       = [F:TCD]CPTKEY(0)
   KTIMSTP    = [F:TCD]CPTKEY(1)
   KDPRPLN    = val([F:TCD]CPTKEY(2))
   Read [F:WCPT]EVE0=KREF;KTIMSTP
   If fstat
    GOK=0
    Break
   Endif
   [F:WCPT]CPTFLG   = G_OUI
   [F:WCPT]UPDUSR   = GUSER
   [F:WCPT]UPDDAT   = date$
   Rewrite [F:WCPT]
   If fstat
    GOK=0
    Break
   Endif

   # Cas des évènements de sortie en cas de sortie avec amortissement exceptionnel.
   # Recherche du DEPREC de sortie / Mise à jour de l'amortissement exceptionnel comptabilisé

   Gosub MAJ_LNKCPTABD
   If GOK=0 : Break : Endif
  Endif

  #> Autre table

  If LCAS = GCAS_AUTRE
   SACTION = ACTION : ACTION ="MAJ_FLAG_COMPTA" : Gosub ACTION From =LTRTSPE : ACTION = SACTION
   If GOK=0 : Break : Endif
   Gosub MAJ_LNKCPTABD
   If GOK=0 : Break : Endif
  Endif

 Next

 #> Mise à jour de la table LNKCPTABX3 (En-tête)
 Gosub MAJ_LNKCPTABX3

Return

#**
#*=============================================================================
#* Alimentation de la table de liens compta / abelx3 (En-tête)
#*=============================================================================
#*!
$MAJ_LNKCPTABX3
 If NOPIECE : Return : Endif
 If GOK
  Raz [F:LCA]
  [F:LCA]CPY      = PCPY
  [F:LCA]FCY      = PFCY
  [F:LCA]LNKSRC   = LCAS
  [F:LCA]FIY      = LFIY
  [F:LCA]PER      = LPER
  [F:LCA]CAT      = LCAT
  [F:LCA]ACETYP   = [F:TPE]ACETYP
  [F:LCA]TYP      = LPCETYP
  [F:LCA]NUM      = LPCENUM
  [F:LCA]DES      = LPCEDES
  [F:LCA]ACCDAT   = LPCEACCDAT
  [F:LCA]ACCDATRUL= [M:TPE]ACCDATRUL
  [F:LCA]ACCDATFIX= [M:TPE]ACCDATFIX
  [F:LCA]TRACE    = GTRACE
  [F:LCA]CREDAT   = date$
  [F:LCA]CREUSR   = GUSER
  Write [F:LCA]
  If fstat
   GOK=0
   Local Char LIGNE(115)
   LIGNE = "TRTCPTINT1/$MAJ_LNKCPTABX3 : Write [F:LCA] fstat="+num$(fstat)-"Key="+[F:LCA]CPY+";"+[F:LCA]FCY+";"+[F:LCA]TYP+";"+format$(GFMDAT4,[F:LCA]ACCDAT)+[F:LCA]NUM
   Call ECR_TRACE(LIGNE,1) From GESECRAN
  Endif
 Endif
Return

#**
#*=============================================================================
#* Alimentation de la table de liens compta / abelx3 (Détail)
#*=============================================================================
#*!
$MAJ_LNKCPTABD
 If NOPIECE : Return : Endif
 Raz [F:LCD]
 If LPCETYP<>"" : [F:LCD]TYP=LPCETYP : Endif
 If LPCENUM<>"" : [F:LCD]NUM=LPCENUM : Endif
 KNUMENR+=1
 [F:LCD]NUMENR     = KNUMENR
 [F:LCD]LNKDAT     = date$
 [F:LCD]LNKSRC     = LCAS
 If LCAS= GCAS_DEPREC
  [F:LCD]REF       = KAASREF
  [F:LCD]DPRPLN    = KDPRPLN
  [F:LCD]FIYENDDAT = KFIYENDDAT
  [F:LCD]PERENDDAT = KPERENDDAT
  [F:LCD]PSTDPE    = KPSTDPE
  [F:LCD]PSTEXC    = KPSTEXC
  [F:LCD]PSTDER    = KPSTDER
  [F:LCD]PSTDERRVE = KPSTDERRVE
  [F:LCD]PSTRVETRF = KPSTRVETRF
  [F:LCD]PSTRVACRB = KPSTRVACRB
  If G_ACTCCN = G_OUI
   [F:LCD]PSTCADCRB = KPSTCADCRB
  Endif
 Elsif LCAS= GCAS_LINK
  [F:LCD]REF       = KAASREF
  [F:LCD]DPRPLN    = KDPRPLN
  [F:LCD]FIYENDDAT = KFIYENDDAT
  [F:LCD]PERENDDAT = KPERENDDAT
  [F:LCD]PSTLNK    = KPSTLNK
 Elsif LCAS = GCAS_CCNRPR
  [F:LCD]REF       = KAASREF
  [F:LCD]FIYENDDAT = KFIYENDDAT
  [F:LCD]PERENDDAT = KPERENDDAT
  [F:LCD]PSTACGRPR = KPSTACGRPR
  [F:LCD]PSTFISRPR = KPSTFISRPR
 Elsif LCAS = GCAS_EVENT
  [F:LCD]EVT       = [M:TPE]EVTTYP
  [F:LCD]REF       = KREF
  [F:LCD]DPRPLN    = KDPRPLN
  [F:LCD]TIMSTP    = KTIMSTP
 Elsif LCAS = GCAS_AUTRE
  SACTION = ACTION : ACTION ="MAJ_LNKCPTABD" : Gosub ACTION From =LTRTSPE : ACTION = SACTION
 Endif
 Write [F:LCD]
 If fstat
  Local Integer LFSTAT : LFSTAT=fstat
  GOK=0
  Local Char LIGNE(115)
  LIGNE = "TRTCPTINT1/$MAJ_LNKCPTABD : Write [F:LCD] fstat="+num$(fstat)-"Key="+[F:LCD]TYP+";"+[F:LCD]NUM+";"+num$([F:LCD]NUMENR)
  Case LCAS
   When GCAS_DEPREC | GCAS_LINK
    LIGNE-="DEP:key"-[F:LCD]REF+";"+num$([F:LCD]DPRPLN)+";"+format$(GFMDAT4,[F:LCD]FIYENDDAT)+";"+format$(GFMDAT4,[F:LCD]PERENDDAT)
   When GCAS_CCNRPR
    LIGNE-="RPR:key"-[F:LCD]REF+";"+format$(GFMDAT4,[F:LCD]FIYENDDAT)+";"+format$(GFMDAT4,[F:LCD]PERENDDAT)
   When GCAS_EVENT
    LIGNE-="EVT:key"-[F:LCD]EVT+";"+[F:LCD]REF+";"+num$([F:LCD]DPRPLN)+";"+[F:LCD]TIMSTP
  Endcase
  Call ECR_TRACE(LIGNE,1) From GESECRAN
 Endif
Return

#**
#*=============================================================================
#* Vide la table temporaire utilisée pour la comptabilisation
#*=============================================================================
#*!
$VIDE_TABTEMP
 GOK=1
 Trbegin [TCD]
 Delete [TCD] Where TRTNUM=GNUMTRT
 If fstat
  GOK=0
  LIGNE = "TRTCPTINT1-$VIDE_TABTEMP-Delete [F:TCD]"-num$(fstat)
  Call ECR_TRACE(LIGNE,1) From GESECRAN
 Else
  Gosub TRCTECVIDETCD From TRTCPTINT5
 Endif
 If GOK
  Commit
 Else
  Rollback
 Endif
Return

