#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# DLE
# X3-58867 : Set the new field [TCY]GSPFLG to 1 (if it is not already initialized to 2)
# X3-60504 : Set the new field [CPY]ORICERFLG to 1 (if it is not already initialized to 2)
# X3-60505 : Set the new field [FCY]ORICERFLG to 1 (if it is not already initialized to 2)
#----------------------------------------------------------------------------------------#
Call OUVRE_TRACE("[F:TCY]GSPFLG initialization") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#########################################################
$MAJ_GSPFLG
  If DOSSIER=nomap
   Local File TABCOUNTRY [TCY]
   Local File COMPANY    [CPY] :#60504
   Local File FACILITY   [FCY] :#60505
  Else
   Local File =DOSSIER+".TABCOUNTRY" [TCY]
   Local File =DOSSIER+".COMPANY"    [CPY] :#60504
   Local File =DOSSIER+".FACILITY"   [FCY] :#60505
  Endif

  If dim([F:TCY]GSPFLG) >= 0 Then
    Trbegin [TCY]
    Update [TCY] Where GSPFLG = 0 With GSPFLG = 1
    If fstat Then
      Call ERREUR("TABCOUNTRY", 2) From DOSDIC
      Rollback
    Else
      Commit
    Endif
  Endif

  #60504
  If dim([F:CPY]ORICERFLG) >= 0 Then
    Trbegin [CPY]
    Update [CPY] Where ORICERFLG = 0 With ORICERFLG = 1
    If fstat Then
      Call ERREUR("COMPANY", 2) From DOSDIC
      Rollback
    Else
      Commit
    Endif
  Endif
  #end 60504

  #60505
  If dim([F:FCY]ORICERFLG) >= 0 Then
    Trbegin [FCY]
    Update [FCY] Where ORICERFLG = 0 With ORICERFLG = 1
    If fstat Then
      Call ERREUR("FACILITY", 2) From DOSDIC
      Rollback
    Else
      Commit
    Endif
  Endif
  #end 60505

  Close Local File [TCY]
  Close Local File [CPY] :#60504
  Close Local File [FCY] :#60505
Return

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(DOSSIER)
Value Char    DOSSIER
If [L]DOSSIER<>""
  Gosub MAJ_GSPFLG
Endif
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (DOSSIER)
Value Char    DOSSIER
If [L]DOSSIER<>""
  Gosub MAJ_GSPFLG
Endif
End

