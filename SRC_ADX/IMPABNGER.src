#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "IMPORT"        : Gosub IMPORT
  When "IMP_OUVRE"     : Gosub OUVRE
Endcase
Return



$IMPORT
Local Integer NOFORBANK
Local Integer BIDLENGTH
Local Char    BID(5)
Local Char    ID(1)

  [M:ABN1]CRY = "DE"
  If GIMP(1) <> "1" #only banks with marker 1 will be imported
    OK = 0
    NBERR -= 1
  Endif

Return

$OUVRE
Local Integer NBDROP_
# delete all existing DE postcodes
  Filter [F:ABN] Where CRY="DE"
  NBDROP_=rowcount([F:ABN])
  Filter [F:ABN]
  Trbegin [F:ABN]
  Delete [F:ABN] Where CRY="DE"
  If fstat=0
    Call ECR_TRACE(func AFNC.MES1( mess(19,3648,1), num$(NBDROP_)), 0) From GESECRAN
    Commit
  Else
    Call ECR_TRACE(mess(20,3648,1), 1) From GESECRAN
    GOK = -1
    Rollback
  Endif
Return

