#<AdxTL>@(#)0.0.0.0 $Revision$
# Traitement SUBPAS Objet sur la table PARSTOACC
# paramètres d'agrégation des mouvements de stock pour l'interface TB 01/2004

$ACTION
Case ACTION
 When "AFFMASK"  Gosub AFFMASK
 When "RAZCRE"   Gosub RAZCRE
 When "RAZDUP"   Gosub RAZCRE
 When "SETBOUT"  Gosub SETBOUT
 When "EXEBOUT"  Gosub EXEBOUT
 When Default
Endcase
Return

##########################################################################
$AFFMASK
Call FMTLEG From TRTX3
Return

##########################################################################
$RAZCRE
If func AFNC.ACTIV("LEG")=0
    [M:PAS1]LEG = GDOSLEG(1)
Endif
Return

##########################################################################
$SETBOUT
CHAINE += "A"    # Suppression
Return

##########################################################################
$EXEBOUT
Local Integer LRET

Lock STOACC With lockwait=0  # à faire avant la génération du trt (eventuellmt lu par qq'un)
 ## ou locker par société à partir d'un code site saisi MAIS le trt généré ne doit pas être touché !
 # lock identique dans l'objet PAS (paramétrage agrégation) avant de générer le trt
If fstat
    # Afficher un message d'erreur, car quelqu'un est déjà en train de comptabiliser les stocks
    GMESSAGE = mess(270,197,1) 
    GERR = 2
Else
    Call OUVRE_TRACE(mess(147,123,1)) From LECFIC
    LRET = func FUNSTKACC.CTRLPARAM(nomap, "")
    Call FERME_TRACE() From LECFIC
    If LRET
        Call LEC_TRACE From LECFIC
    Endif
    Raz LRET
    
    # générer le traitement qui charge la table temporaire pour l'interface
    Call GENTRT(nomap,LRET) From FUNSTKACC
    Unlock STOACC
Endif


Return

##########################################################################
Subprog AS_TRSTYP(VALEUR)
Variable Integer VALEUR
# ne laisser créer les paramétrages que pour des mouvements effectifs
# bloquer par GMENLOC les types de mvts qui n'ont pas besoin d'être interfacés :

Local Integer LTABTRS(1..len(mess(0,704,1)))
Call TRSTYPACC([M:PAS1]LEG,[M:PAS1]CPY,"",LTABTRS) From STKVALMAJ

For I=1 To len(mess(0,704,1))
    GMENLOC(I) = (LTABTRS(I)=1)
Next

End

