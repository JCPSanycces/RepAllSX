#<AdxTL>@(#)1.0.0.0 $Revision$
#########################################################################
#                                       Module Ventes -  Decembre 2004  #
#     FACTURES A EMETTRE                                                #
#            - à partir des livraisons validées                         #
# --------------------------------------------------------------------- #
#     - Traitement        : FUNAUTFAE                                   #
#     - Action e_commerce : TRTAUTFAE  (Traitement standard)            #
#                                                                       #
#########################################################################
#*X3-39795   MWA  Manage ORIGIN and ORICOD fields in GL Entry
Local Char PARAM(10)(1..3) , VALEUR(250)
Call TRAITE_CHAR(VALEUR,PARAM,"","FUNAUTFAE","DAUTFAE",4,"") From GTRAITE
End

# Variable Char    VALEUR
# Variable Char    PARAM()(1..)
# Value    Char    BOITE      :
# Value    Char    PROG       : # Traitement FUNAUTFAE
# Value    Char    BCRIT      : # Fenêtre de critères DAUTFAE
# Value    Integer TYPPRG     : #
# Value    Char    PROGSPE

#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION

# ----- actions liées au traitement standard
Case ACTION
 When "OUVRE_BATCH" : Gosub INIT_TRTAUTFAE
 When "INIT"        : Gosub INIT_TRTAUTFAE
 #When "DEBUT"       : Affzo [DIA]1-99        : # 71937 : Multilégislation
 When "DEBUT"       : Gosub DEBUT_TRTAUTFAE   : # 71937 : Multilégislation
 When "OK"          : GOK=1
 When "END"         : GOK=0 : FIN=1
 When "CONTROLE"    : Gosub CONTROLE_TRTAUTFAE
 When "EXEC"        : Gosub EXEC_TRTAUTFAE
 When "TERMINE"     : Gosub TERMINE_TRTAUTFAE
 When "SORTIE"      : Gosub SORTIE_TRTAUTFAE
 When Default
Endcase
Return

# ----- action appelée depuis action parametree dans pièce auto SDH
$NUMERO
Global Char GNUMFAE (GLONVCR)
GNUMFAE=[M:HAE0]NUM
Return

#########################################################################
# Détail des actions liées au traitement standard                       #
#########################################################################

#########################################################################
$INIT_TRTAUTFAE

Global Shortint GINVTYP  : GINVTYP = 1  : # Type document        = Facture
Local Integer   STAT
Local Char      SAVGFCYDEF(GLONFCY)     : # 71937

# ----- en batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

Gosub OUVRE

Local Mask SAUTFAE [DIA]

Raz [M:DIA]

# ----- chargement de l'écran en fonction des habilitations
# 71937 : Multilégislation
SAVGFCYDEF=GFCYDEF(0)
GFCYDEF(0)=GFCYDEF(5)
# 71937
[M:DIA]ALLCPY=1
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE : [M:DIA]ALLCPY = 1 : Endif
If [M:DIA]ALLCPY = 1
    Call INICPY([M:DIA]CPY) From CPTSUB
Endif
GFCYDEF(0)=SAVGFCYDEF : : # 71937 : Multilégislation
[M:DIA]ALLFCY=2
If [M:DIA]ALLCPY=1
    Call INIALLFCY([M:DIA]ALLFCY,[M:DIA]CPY) From CPTTRT
Endif
If [M:DIA]ALLFCY = 1
    Call INIFCY([M:DIA]SALFCY,[M:DIA]CPY) From CPTSUB
Endif

[M:DIA]SHIDAT=date$          : # livraisons jusqu'au
[M:DIA]TYP=2                 : # type de generation = simulation
[M:DIA]STA=1 : Grizo STA

Gosub INIT_TYPPCEJOU         : # Init. de la pièce auto, du type de pièce et du code journal

[M:DIA]INVDAT=date$          : # date pièce facture

Effzo EXTOURNE : Grizo EXTOURNE

[M:DIA]TRACE=2

TMP=1               : # Affichage d'un message de temporisation

Call LECMEMO ("STD","[M:DIA]","vf1") From GMEMO

# ----- positionner le flag si lancement batch
If GSERVEUR [M:DIA]BATCH=1 Endif
Return


#------------------------------------------------------------------------
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End


# 71937 : Multilégislation
#########################################################################
$DEBUT_TRTAUTFAE

Call FMTLEG From TRTX3 : # Pour rendre invisible si nécessaire le champ "Législation"
Gosub GRILEG
Affzo [DIA]1-99
Return
# 71937
#########################################################################
$CONTROLE_TRTAUTFAE
If GOK<1  FIN=1 Else TMP=1 : Endif

## Demande de modif 56230 - Lot CE5
If FIN : Return : Endif
Call AVERTDGI([M:DIA]ALLCPY,[M:DIA]CPY,[M:DIA]TYP,FIN) From CPTDIV2
If FIN : Return : Endif
## Fin demande 56230

# ----- suppression enreg. fichier travail si interruption
Gosub DEL_SWI
If GOK < 1 : FIN=1 : Endif

Return

#########################################################################
$EXEC_TRTAUTFAE
Local Char    WPARAM(GLONADP)      : # 40127 : Return status management
Local Decimal WAMTNOTLIN

If !GSERVEUR
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("SAUTFAE","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif

# ----- récupération du numero de compteur
Raz GCPT
# --- Récupération du numéro compteur
Local Integer OK
Call LECTCA(5,OK) From SUBTCA
If fstat | !OK
   GOK=0 : Call ECR_TRACE ("          "+mess(58,105,1)-mess(5,14,1)-mess(250,199,1),0) From GESECRAN : Goto AB_TRT
   If !GSERVEUR Call ERREUR(mess(58,105,1)-mess(5,14,1)-mess(250,199,1)) From GESECRAN : Endif
Endif
GCPT=[F:TCA]CODNUM(3)


If [M:DIA]INVDAT = [0/0/0]
    [M:DIA]INVDAT = date$
    Local Date WINVDAT
    WINVDAT=[M:DIA]INVDAT
    If [M]CPY<>"" Gosub CTL_INVDAT Endif
    If mkstat = 2
        Call ECR_TRACE(mess(468,197,1)-format$(GFMDAT,[M:DIA]INVDAT)-GMESSAGE,1) From GESECRAN :#--CPO 83985 GFMDAT au lieu de GFMD
        Goto EXEC_FIN
    Endif
Endif

# Bornage de la date de prise en compte des livraisons si la requête est abonnée
# Si date expédition/livraison non renseignée, on force la date du jour
If [M:DIA]SHIDAT = [0/0/0] & [M:DIA]ABT=2 [M:DIA]SHIDAT = date$ : Endif

# Issue X3-38251 - 2017-11-10 by CPO : [110949] FUNAUTFAE - calcul date extourne
#--If the check box "All cpy" is checked, we have to control that for a LEG, all companies have the same period dates for a fiscal year
If [M:DIA]ALLCPY=2 and [M:DIA]LEG<>""

  If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif
  If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
  If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif

  Local Date ZPERSTR, ZPEREND : ZPERSTR=[0/0/0] : ZPEREND = [0/0/0]
  Local Integer ZWOK : ZWOK = [V]CST_AOK
  Local Char    ZWCPY(GLONCPY)

  Link [F:PER] With  [F:CPY]CPY0=[F:PER]CPY,
&                    [F:FIY]FIY0=[F:PER]CPY;[F:PER]LEDTYP;[F:PER]FIYNUM
&              As    [PERLNK]
&              Where [F:CPY]LEG = [M:DIA]LEG        and
&                    [F:FIY]FIYSTR <= [M:DIA]INVDAT and
&                    [F:FIY]FIYEND >= [M:DIA]INVDAT and
&                    [F:FIY]FIYSTA  = 2             and
&                    [F:PER]PERSTR <= [M:DIA]INVDAT and
&                    [F:PER]PEREND >= [M:DIA]INVDAT and
&                    [F:PER]CLODAT  = [0/0/0]       and
&                    [F:PER]PERSTA  = 2
  For [PERLNK]
    #--avoiding looping on all ledgers
    If ZWCPY<>[F:PERLNK]CPY
      ZWCPY=[F:PERLNK]CPY
      If ZPERSTR=[0/0/0] : ZPERSTR = [PERLNK]PERSTR : Endif
      If ZPEREND=[0/0/0] : ZPEREND = [PERLNK]PEREND : Endif
      #--if one of this date is different, then the fonction cannot continue
      If ZPERSTR<>[PERLNK]PERSTR or ZPEREND<>[PERLNK]PEREND
        ZWOK = [V]CST_AERROR
        Break
      Endif
    Endif
  Next
  Raz [F:CPY],[F:PER],[F:FIY] #--we don't want to keep values (those are read afterward)
  If ZWOK=[V]CST_AERROR
    Call ECR_TRACE(func AFNC.MES1(mess(681,199,1),[M:DIA]LEG)+"."+mess(682,199,1),1) From GESECRAN
    GOK=0 : Goto EXEC_FIN
  Endif
Endif
# End issue X3-38251

# ----- sélection des livraisons à traiter
Gosub SEL_SDH
If GOK < 1 Goto EXEC_FIN : Endif

# ----- suppression des écritures de simulation
Gosub DEL_SIMULATION
If GOK < 1 Goto EXEC_FIN : Endif

# ----- traitement à partir du fichier de travail
Gosub TRT_SWI

# ----- trace recap par sociétés et sites
Gosub TRACE_RECAP

# ----- fin du traitement -----
$EXEC_FIN

# ----- déverrouillage de toutes les livraisons
For [SWI]
    SYMBOLE = "SDH"+[F:SWI]NUM
    Unlock = SYMBOLE
Next
Filter [SWI]

# ----- suppression enreg. fichier travail
Gosub DEL_SWI

Return

#########################################################################
$TERMINE_TRTAUTFAE

If !GSERVEUR
    If !NBINV
      Call ECR_TRACE(mess(48,192,1),0) From GESECRAN  : # mess = Aucune livraison traitée
    Endif
    Call FERME_TRACE From LECFIC
    # --> Aucune facture effectuee
    If !NBINV
         GERR=2 : GMESSAGE=mess(48,192,1)
    Endif
    TRA=1
Endif
Return

#########################################################################
$SORTIE_TRTAUTFAE
#--CPO 88651 On va utiliser l'écran SFITRFA dont les dimensions sont paramètrables
If func AFNC.ACTIV("SFIAT")>0
  #If clalev([M:SFIT])>0 Close Local Mask [M:SFIT] Endif
  If clalev([M:SFIT])>0 Close Mask [M:SFIT] Endif          # FGR 22/01/2015 : X3SUIVI105626 : pas Local
Endif
#--/
Return

#########################################################################

#-----------------------------------------------------------------------#
#     Ouverture des fichiers et masques                                 #
#-----------------------------------------------------------------------#
$OUVRE

Local Char     LNUM(GLONVCR)
Local Integer  OK, STAT, NBINV, NBPOSTE
Local Char     TIT(50), CRITERE(250), CRITDET(50)
Local Char     WMESS(80), WMESS1(80), WMESS2(80)
Local Integer  WRET, LIN, WSIHLIN, WSDHLIN, WSIHACV, LINFLG
Local Char     WKEY(20), WKEY1(66), WNUM(GLONVCR), WDATA(250)
Local Char     WIME(1)
Local Decimal  MNTCALC
Local Decimal  WNIVDLV
Local Shortint WINVORN
Local Char     WTRANSAC(GLONGAU), WIDENT(GLONGTE), WJOURNAL(GLONJOU)
Local Char     WBPINAM(GLONNAM)
Local Date     WREFDAT

# --- Tables données de base ---
If clalev([F:ADI])=0  : Local File ATABDIV     [ADI] : Endif
If clalev([F:TCA])=0  : Local File TABCOUAFF   [TCA] : Endif
If clalev([F:TSV])=0  : Local File TABSIVTYP   [TSV] : Endif
If clalev([F:TCU])=0  : Local File TABCUR      [TCU] : Endif
If clalev([F:TCH])=0  : Local File TABCHANGE   [TCH] : Endif
If clalev([F:TCO])=0  : Local File TABCOEFF    [TCO] : Endif
If clalev([F:TVT])=0  : Local File TABVAT      [TVT] : Endif
If clalev([F:TRA])=0  : Local File TABRATVAT   [TRA] : Endif
If clalev([F:TUN])=0  : Local File TABUNIT     [TUN] : Endif
If clalev([F:ANM])=0  : Local File ACODNUM     [ANM] : Endif
If clalev([F:AVN])=0  : Local File AVALNUM     [AVN] : Endif
If clalev([F:CPY])=0  : Local File COMPANY     [CPY] : Endif
If clalev([F:FCY])=0  : Local File FACILITY    [FCY] : Endif
If clalev([F:BPR])=0  : Local File BPARTNER    [BPR] : Endif
If clalev([F:BPC])=0  : Local File BPCUSTOMER  [BPC] : Endif
If clalev([F:BPD])=0  : Local File BPDLVCUST   [BPD] : Endif
#FQ 69370 GACTSAD conditionne uniquement le stockage de l'adresse sur le document
#If GACTSAD=2
If clalev([F:BPA])=0  : Local File BPADDRESS   [BPA] : Endif
#Endif
#fin FQ 69370
#If clalev([F:MVC])=0  : Local File BPCUSTMVT   [MVC] : Endif
If clalev([F:ITM])=0  : Local File ITMMASTER   [ITM] : Endif
If clalev([F:ITS])=0  : Local File ITMSALES    [ITS] : Endif
If clalev([F:ITU])=0  : Local File ITMBPC      [ITU] : Endif
If clalev([F:ITF])=0  : Local File ITMFACILIT  [ITF] : Endif
If clalev([F:GCM])=0  : Local File GACM        [GCM] : Endif
If clalev([F:CAL])=0  : Local File CPTANALIN   [CAL] : Endif

# --- Tables ventes ---
If clalev([F:SIH])=0  : Local File SINVOICE    [SIH] : Endif
If clalev([F:SIV])=0  : Local File SINVOICEV   [SIV] : Endif
If clalev([F:SID])=0  : Local File SINVOICED   [SID] : Endif
If clalev([F:SOH])=0  : Local File SORDER      [SOH] : Endif
If clalev([F:SOQ])=0  : Local File SORDERQ     [SOQ] : Endif
If clalev([F:SDH])=0  : Local File SDELIVERY   [SDH] : Endif
If clalev([F:SDD])=0  : Local File SDELIVERYD  [SDD] : Endif
If clalev([F:SVF])=0  : Local File SVCRFOOT    [SVF] : Endif
If clalev([F:SVV])=0  : Local File SVCRVAT     [SVV] : Endif
If clalev([F:SRD])=0  : Local File SRETURND    [SRD] : Endif # X3-59725 (LCC-26/02/18) Invoices to issued: delivery with a return

# --- Tables de travail ---
If clalev([F:SWI])=0  : Local File SWRKINV     [SWI] : Endif
If clalev([F:SWI1])=0 : Local File SWRKINV     [SWI1]: Endif

# --- Tables compta ---
If clalev([F:GTE])=0  : Local File GTYPACCENT  [GTE] : Endif
If clalev([F:CAC])=0  : Local File GACCCODE    [CAC] : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT    [GAC] : Endif
If clalev([F:DUD])=0  : Local File GACCDUDATE  [DUD] : Endif
If clalev([F:GAU])=0  : Local File GAUTACE     [GAU] : Endif
If clalev([F:GAD])=0  : Local File GAUTACED    [GAD] : Endif
If clalev([F:GAG])=0  : Local File GAUTACEF    [GAG] : Endif
If GMODU(2)=2                :  # 105566 : Ajout test présence module compta
    If clalev([F:JOU]) = 0 Local File GJOURNAL [JOU] : Endif
Endif                        :  # 105566
If clalev([F:GDE])=0  : Local File GDIAENTRY   [GDE] : Endif
