If clalev([F:FIY])=0  : Local File FISCALYEAR  [FIY] : Endif
If clalev([F:BAL])=0  : Local File BALANCE     [BAL] : Endif
If clalev([F:BLA])=0  : Local File BALANA      [BLA] : Endif
If clalev([F:TCK])=0  : Local File TABACCLIK   [TCK] : Endif
If clalev([F:PBS])=0  : Local File GAPARBSE    [PBS] : Endif
If clalev([F:JST])=0  : Local File GAJOUSTA    [JST] : Endif
If clalev([F:CCE])=0  : Local File CACCE       [CCE] : Endif
If clalev([F:DSP])=0  : Local File CADSP       [DSP] : Endif
If clalev([F:AUZ])=0  : Local File CAAUZ       [AUZ] : Endif
If clalev([F:CCE2])=0 : Local File CACCE       [CCE2]: Endif
If clalev([F:CMD])=0  : Local File GCOMMITD    [CMD] : Endif
If clalev([F:HAE1])=0 : Local File GACCENTRY   [HAE1] : Endif
If clalev([F:HAE2])=0 : Local File GACCTMP     [HAE2] : Endif

#Call GETDEV(GFCYDEF(5)) From DEVSUB
# --> Chargement globales référenciels, comptes et sections de la société
Raz GSOC_ACTIVE : GFCY=GFCYDEF(5) : Gosub CHARG_PARAM

# ------------------------------------------- #
# Récupération des paramêtres de vente        #
# ------------------------------------------- #
Call GLOBVAR(GFCYDEF(5),"VEN") From TRTX3

#--CPO 88651 On va utiliser l'écran SFITRFA dont les dimensions sont paramètrables
If func AFNC.ACTIV("SFIAT")>0
  #If clalev([M:SFIT])>0 Close Local Mask [M:SFIT] Endif
  If clalev([M:SFIT])>0 Close Mask [M:SFIT] Endif          # FGR 22/01/2015 : X3SUIVI105626 : pas Local
  Local Mask SFITRFA [M:SFIT]
Endif
#--/

Return

#-----------------------------------------------------------------------#
#     Effacement fichier de travail si interruption auparavant          #
#-----------------------------------------------------------------------#
$DEL_SWI
Call DEBTRANS From GLOCK
Trbegin [SWI]
  Delete [SWI] Where PRONUM=adxuid(1)
  If fstat=1  GOK=-1 : GLOCK="$SWRKINV"-num$(adxuid(1))           : Goto AB_TRT
  Elsif fstat GOK= 0 : Call RSTA("SWI",num$(adxuid(1))) From GLOCK : Goto AB_TRT
  Endif
Commit
Return

#-----------------------------------------------------------------------#
#    Sélection des livraisons à traiter                                 #
#-----------------------------------------------------------------------#
$SEL_SDH

# ----- critères de saisie
CRITERE="(SISNUM='' | SISDAT<["+format$(GFMD,[M:DIA]INVDAT)+"])"  : # no de FAE = non
                                                                  : # ou date extourne < date demandee
# 71937 : Multilégislation
If [M:DIA]CPY<> ""
   CRITERE -= '& CPY ="'+[M:DIA]CPY+'"'
Endif
If [M:DIA]LEG<> ""
   CRITERE -= '& [F:CPY]LEG ="'+[M:DIA]LEG+'"'
Endif
# 71937
If [M:DIA]SALFCY<> ""
   CRITERE -= '& SALFCY ="'+[M:DIA]SALFCY+'"'
Endif
If [M:DIA]BPCINVDEB <> ""
   CRITERE -= '& BPCINV >="'+[M:DIA]BPCINVDEB+'"'
Endif
If [M:DIA]BPCINVFIN <> ""
   CRITERE -= '& BPCINV <="'+[M:DIA]BPCINVFIN+'"'
Endif


# ----- critères supplémentaires
CRITERE -= "& (LND=1 | (LND=2 & LNDRTNDAT<[M:DIA]SHIDAT))"  :# Prêt (oui si date retour dépassée)
CRITERE -= "& SCO <> 2"                                  :# Sous-traitance    = non
CRITERE -= "& (BETFCY=1 | (BETFCY=2 & BETCPY=2))"           :# Intra-société     = non
CRITERE -= "& CFMFLG = 2"                                   :# Etat validation   = Validée
#CRITERE -= "& INVFLG = 1"                                   :# Etat facture      = non facturée
#CRITERE -= "& IME <> 6"                                     :# fact manuelle     = oui (on prend)

#---------------------------------------------------------------------#
# Point d'entree ajout filtres supplémentaires                        #
#---------------------------------------------------------------------#
Local Char    FILSUP (250)
Local Integer WSWIKEYD
Local Integer IJL
Local Char    SDH_CPY (GLONCPY)
FILSUP="1=1"
GPOINT="AUTFAEFIL" : Gosub ENTREE From EXEFNC

# 71937 : Multilégislation
Link [SDH] With [CPY]CPY0=[F:SDH]CPY As [KSDH]
# Issue X3-47045 - 2017-09-22 by CPO : No deliveries taken into account because For has to be on [KSDH] link
#For  [SDH] Where (evalue(CRITERE) & evalue (FILSUP)) With Nohint
# X3-99892 (Lcc 19/07/18) Nonbillable deliveries are excluded
#For  [KSDH] Where (evalue(CRITERE) & evalue (FILSUP)) With Nohint
For  [KSDH] Where (evalue(CRITERE) & evalue (FILSUP) & SDHCAT<>4) With Nohint
# End X3-99892 (Lcc 19/07/18) Nonbillable deliveries are excluded
# End issue X3-47045
# 71937
     # 71937 : Multilégislation
     #IJL = find([F:SDH]SALFCY,GSITE(1..GNBSITE))            : # recherche du code societe
     #If IJL  SDH_CPY=GSOCSITE(IJL) Else SDH_CPY="" Endif
     SDH_CPY=[F:SDH]CPY
     # 71937

     # 40127 : Return status management
     Call PARAML([F:SDH]SALFCY,"DLVRTNCNO",WPARAM) From ADOVAL
     GDLVRTNCNO=val(WPARAM)

    # X3-59725 (LCC-26/02/18) Invoices to issued: delivery with a return
    # Now the delivery totally returned could be taken into account if the
    # date of the return is upper to the date of the process [M:DIA]SHIDAT
    # If ([F:SDH]RTNSTA<3&GDLVRTNCNO=1) | GDLVRTNCNO=2
    # End X3-59725
     # 40127

       Gosub SEL_SDHCOMPL
       # --- écriture dans SWRKINV
       If OK = 2
          # --- vérification s'il y a qqch à facturer
          # 40127 : Return status management
          # Unnecessary to check lines, RTNSTA from SDELIVERY is added in the filter
          #OK=1 : Gosub VERIF_SDD
          # 40127
          If OK = 2
              # --> lock fichier entête livraison
              SYMBOLE = "SDH"+[F:SDH]SDHNUM
              Lock = SYMBOLE
              If    fstat
                    # modification en cours sur un autre poste
                    Call ECR_TRACE("$SDELIVERY :"-[F:SDH]SDHNUM-mess(10,100,1),1) From GESECRAN
                    OK=1
              Endif
              If OK=2 : Gosub CHARGESWI : Endif
          Endif
       Endif
    # X3-59725 (LCC-26/02/18) Invoices to issued: delivery with a return
    # Endif      : # 40127 : Return status management
    # End X3-59725
Next
Return

#-----------------------------------------------------------------------#
#     Sélection complémentaires pour les entêtes livraison              #
#-----------------------------------------------------------------------#
$SEL_SDHCOMPL
OK = 2

# 71937 : Multilégislation
#If [M:DIA]CPY<>""
#   If  SDH_CPY<>[M:DIA]CPY : OK=1 : Return : Endif
#Endif

If GINVREFDAT=2
   WREFDAT=[F:SDH]DLVDAT
Else
   WREFDAT=[F:SDH]SHIDAT
Endif

# ----- sélection si date expe/liv <= date saisie
If [M:DIA]SHIDAT <> [0/0/0]
    If WREFDAT > [M:DIA]SHIDAT
        OK=1 : Return
    Endif
Endif

# ACA - 47546
# Sélection si non facturée
# ou facturée sur la période suivant la période considérée
If [F:SDH]INVFLG = 2
    Read [SIH]SIH0 = [F:SDH]SIHNUM
    If fstat : Raz [F:SIH] : Endif
    If [F:SIH]ACCDAT <= [M:DIA]INVDAT
        OK=1
    Endif
Endif


WIME = num$([F:SDH]IME) :
If WIME="0" WIME="1" Endif

Case WIME
     When "1"                 : # 1 fac/bl
     When "2"   : WIME="3"    : # 1 fac/cde soldee   --> 1 fac/cde
     When "3"                 : # 1 fac/cde
     When "4"                 : # 1 fac/client livre
     When "5"                 : # 1 fac/periode      --> regroupement de toutes les livraisons
     When "6"   : WIME="1"    : # 1 fac manuelle     --> 1 fac/bl
Endcase

# ----- pour rajouter des filtres sur les enregistrements à traiter
GPOINT="AUTFAESEL" : Gosub ENTREE From EXEFNC

Return


# 40127 : Return status management
# No more used, RTNSTA from SDELIVERY is added in the filter
##-----------------------------------------------------------------------#
##     Vérification s'il y a des lignes à facturer                       #
##-----------------------------------------------------------------------#
#$VERIF_SDD
#For  [SDD]SDD0 Where SDHNUM = [F:SDH]SDHNUM
##    If (GDLVRTNCNO=1 & [F:SDD]QTYSTU > [F:SDD]RTNQTYSTU) | GDLVRTNCNO=2
#   # Bug 46937
#   # Si livraisons de prêt, on facture ce qui n'est pas retourné
#   # Si livraisons normales et pas de facturation qté retournée (GDLVRTNCNO=1), on ne facture que ce qui n'est pas retourné
#   # Si livraisons normales et facturation qté retournée (GDLVRTNCNO=2), on facture tout
#   If ([F:SDD]QTYSTU>[F:SDD]RTNQTYSTU & ([F:SDH]LND=2 | GDLVRTNCNO=1)) |
#&     ([F:SDH]LND=1 & GDLVRTNCNO=2)
#        OK=2: Break
#    Endif
#Next
#
#Return
# 40127

#-----------------------------------------------------------------------#
#     chargement dans le fichier de travail                             #
#-----------------------------------------------------------------------#
$CHARGESWI
Local Integer WWEEK
Local Date    WDAT

Call DEBTRANS From GLOCK
$CHGFIC
GOK=1
Trbegin [SWI]

# -------------------> lecture entête livraison
Readlock [SDH]SDH0 Curr

If    fstat=1 : GOK=-1 : GLOCK="$SDELIVERY"+[F:SDH]SDHNUM : Goto ROL_CHGFIC
Elsif fstat   : GOK=0  : Call RSTA("SDH",[F:SDH]SDHNUM) From GLOCK : Goto AB_TRT
Endif
# 71937 : Multilégislation
#IJL = find([F:SDH]SALFCY,GSITE(1..GNBSITE))
#If IJL  SDH_CPY=GSOCSITE(IJL) Else SDH_CPY="" Endif
SDH_CPY=[F:SDH]CPY
# 71937

Raz [F:SWI]

[F:SWI]PRONUM  = adxuid(1)

[F:SWI]SWIKEY  = SDH_CPY
[F:SWI]SWIKEY += "~"+[F:SDH]SALFCY
[F:SWI]SWIKEY += "~"+[F:SDH]BPCINV

[F:SWI]SWIKEY1 = WIME

# ----- traitement 1 facture / commande ou 1 facture /commande soldée
If WIME = "2" | WIME = "3"
    [F:SWI]SWIKEY1 += "~"+[F:SDH]SOHNUM
Endif

# ----- traitement 1 facture / client livré
If WIME = "4"
    [F:SWI]SWIKEY1 += "~"+[F:SDH]BPCORD
    [F:SWI]SWIKEY1 += "~"+[F:SDH]BPAADD
Endif

# ----- traitement 1 facture / période
If WIME = "5"
    [F:SWI]SWIKEY1 += "~"+"6"                               : # simule [F:SDH]INVPER = 6 --> 1 fac/mois
Endif

If !find(WIME,"2","3","4","5")
    [F:SWI]SWIKEY1 += [F:SDH]BPCORD
Endif

If !find(WIME,"2","3")
    [F:SWI]SWIKEY1 += "~"+[F:SDH]CUR
    [F:SWI]SWIKEY1 += "~"+num$([F:SDH]PRITYP)
    [F:SWI]SWIKEY1 += "~"+[F:SDH]PJT
    [F:SWI]SWIKEY1 += "~"+[F:SDH]BPCPYR
    [F:SWI]SWIKEY1 += "~"+[F:SDH]VACBPR
    [F:SWI]SWIKEY1 += "~"+[F:SDH]BPIEECNUM
    [F:SWI]SWIKEY1 += "~"+[F:SDH]EECICT
    [F:SWI]SWIKEY1 += "~"+num$([F:SDH]EECLOC)
Endif

[F:SWI]NUM = [F:SDH]SDHNUM
[F:SWI]LIN = 0
[F:SWI]SEQ = 0

If !find(WIME,"2","3")
    [F:SWI]SWIDATA   = [F:SDH]BPCGRU
    [F:SWI]SWIDATA  += "~"+[F:SDH]PTE
    [F:SWI]SWIDATA  += "~"+num$([F:SDH]BETFCY)
    [F:SWI]SWIDATA  += "~"+[F:SDH]ORIFCY
    [F:SWI]SWIDATA  += "~"+toupper(vireblc([F:SDH]BPINAM(0),4))
    [F:SWI]SWIDATA  += toupper(vireblc([F:SDH]BPIADDLIG(0),4))
    [F:SWI]SWIDATA  += toupper(vireblc([F:SDH]BPIPOSCOD,4))
    [F:SWI]SWIDATA  += toupper(vireblc([F:SDH]BPICTY,4))
    [F:SWI]SWIDATA  += toupper(vireblc([F:SDH]BPISAT,4))
    [F:SWI]SWILINNBR = [F:SDH]LINNBR
Else
    [F:SWI]SWILINNBR = [F:SOH]LINNBR
Endif

# ----- pour rajouter des conditions de regroupements
GPOINT="AUTFAEREG" : Gosub ENTREE From EXEFNC

If [F:SWI]SWIDATA<>""
   Filter [SWI1] Where PRONUM=[F:SWI]PRONUM & SWIDATA=[F:SWI]SWIDATA
   Read [SWI1] First
   If fstat
      WSWIKEYD +=1
      [F:SWI]SWIKEYD=WSWIKEYD
     Else
      [F:SWI]SWIKEYD=[F:SWI1]SWIKEYD
   Endif
   Filter [SWI1]
Endif

Write [SWI]
If fstat
   GOK=0 : Call FSTA("SWI") From GLOCK : Goto AB_TRT
Endif

Commit
Return

#-----------------------------------------------------------------------#
#     traitement : lecture du fichier de travail                        #
#-----------------------------------------------------------------------#
$TRT_SWI
Local Integer WFINFAC
Local Char    CPY_CURRENT (GLONCPY)
Local Char    FCY_CURRENT (GLONFCY)
Local Char    CUR_CURRENT (GLONCUR)
Local Char    CPY_NEW     (GLONCPY)
Local Char    FCY_NEW     (GLONFCY)
Local Char    CPY_TRACE   (GLONCPY)
Local Char    BPR_TRACE   (GLONBPR)
Local Integer IJL

# ----- variables locales pour création pièces FAE et extourne FAE -----#
# X3-39795 MWA Start
#If [M:DIA]TYP=1 : # Génération réelle
#  Local Char TZONE (GLONAVA)(1..8)
#  Local Char TVAL  (20)     (1..8)
#Else            : # Génération simulée
#  Local Char TZONE (GLONAVA)(1..7)
#  Local Char TVAL  (20)     (1..7)
#Endif
Local Char    TZONE(10)(1..10)           : # Table of the zones to be forced (Ex: ORICOD)
Local Char    TVAL(30)(1..10)            : # Table of values for zones to be forced
# X3-39795 MWA End

Local Char    WMESSAGE(250)
Local Integer WRETOUR

Local Char    WMSG(250)
Local Char    WMSG_CPY (GLONCPY)
Local Char    WMSG_FCY (GLONFCY)
Local Decimal WMSG_HT  (0..2)
Local Decimal WMSG_TTC (0..2)

# ----- tableaux cumuls pour recap
# Bug 61066 : Dim.tableau :1Poste+1Poste par site+1Poste par société
Local Integer WT_DIM    : WT_DIM=max(3,GNBSITE+GNBSOC+1)
Local Char    WT_CPYFCY (sum(GLONCPY,1,GLONFCY)) (WT_DIM)    : # pour les ruptures et tri
Local Char    WT_CPY    (GLONCPY)                (WT_DIM)    : # ACA - bug 45856 - 100->GNBSITE
Local Char    WT_FCY    (GLONFCY)                (WT_DIM)
Local Char    WT_CUR    (GLONCUR)                (WT_DIM)
Local Decimal WT_HT                              (WT_DIM)
Local Decimal WT_TTC                             (WT_DIM)

Local Decimal WW_HT
Local Decimal WW_TTC

WT_CPYFCY(0)="~" : WT_CUR(0)=GSYSCUR

# ----- récup nb lignes factures autorisées par le code activité
WSIHACV=0
If   !clalev([F:ACV]) : Local File ACTIV [ACV] : Endif
Read [ACV] CODACT = "SIH"
If   !fstat : WSIHACV = [F:ACV]DIME : Endif
If   WSIHACV = 0
#    -- paramêtre non renseigné
     GOK = 0 : Call ECR_TRACE("SIH "+mess(8,176,1),1) From GESECRAN : Return
Endif
Close Local File [ACV]

#-----------------------------------------------------------------------#
# Ouverture de SIH4                                                     #
# Ouverture et chargement de SIHV                                       #
#-----------------------------------------------------------------------#

Local Mask SIH0 [SIH0] : Raz [M:SIH0]
Local Mask SIH1 [SIH1] : Raz [M:SIH1]
Local Mask SIH2 [SIH2] : Raz [M:SIH2]
Local Mask SIH4 [SIH4] : Raz [M:SIH4]
Gosub OUVRE_SIHX From TRTVENFACC

Local Char SFIT_OBJ : SFIT_OBJ="SIH"
Gosub INIT_SFIT From SUBSFIT

Filter [SWI] Where PRONUM=adxuid(1)
&            Order By Key CLE=SWIKEY;SWIKEY1;SWIKEYD;NUM;LIN;SEQ

For [SWI]

    WIME = mid$([F:SWI]SWIKEY1,1,1)

# ------       Traitement des ruptures       ------ #

# ----- 1 facture / bl
    If (WKEY <> [F:SWI]SWIKEY | WNUM <> [F:SWI]NUM |
&      WDATA <> [F:SWI]SWIDATA) & WIME = "1"
        WFINFAC = 2

# ----- 1 facture / commande soldée, 1 facture / commande
# ----- 1 facture / client livré, 1 facture / période
    Elsif (WKEY <> [F:SWI]SWIKEY | WKEY1 <> [F:SWI]SWIKEY1 |
&      WDATA <> [F:SWI]SWIDATA) & find(WIME, "2","3","4","5")
        WFINFAC = 2
    Else
        WFINFAC = 1
    Endif

# ----- ctrl nbre ligne facture
    If WIME <> "2" | (WKEY1 <> [F:SWI]SWIKEY1 & WIME = "2")
        Gosub VERIF_LIN
        If LINFLG = 0
            WMESS="         "+mess(129,197,1)+" "+[F:SWI]NUM
            Call ECR_TRACE(WMESS,1) From GESECRAN
            Call ECR_TRACE(mess(66,192,1),0) From GESECRAN
            Goto NXTSWI
        Elsif LINFLG = 2
            WFINFAC = 2
        Endif
    Endif

# ----- changement de livraison sur la même facture
    If  (WNUM <> [F:SWI]NUM | WFINFAC = 2) & WNUM <> ""
        If GOK=1
           Gosub FIN_LIVRAISON
           If GOK<1 : Goto NXTSWI : Endif
        Endif
    Endif
    If WFINFAC = 2 & find (WIME,"2","3","4","5")
#    ---- changement de facture
        If WKEY1 <> "" & GOK=1
                      Gosub FIN_FACTURE
                      If GOK<1 : Goto NXTSWI : Endif
        Endif
        Gosub DEB_FACTURE
        If GOK<1 : Goto NXTSWI : Endif
    Elsif WFINFAC = 2 & find(WIME, "1")
#    ---- changement de facture
        If WNUM <> "" & GOK=1
                     Gosub FIN_FACTURE
                     If GOK<1 : Goto NXTSWI : Endif
        Endif
        Gosub DEB_FACTURE
        If GOK<1 : Goto NXTSWI : Endif
# ----- changement de livraison sur la même facture
    Elsif WNUM <> [F:SWI]NUM & WNUM <> ""
        If GOK=1
           Gosub DEB_LIVRAISON
           If GOK<1 : Goto NXTSWI : Endif
        Endif
    Endif

# ----- traitement du détail     ------------------------------
    If GOK=1
       Gosub TRT_DETAIL
       If GOK<1 : Goto NXTSWI : Endif
       WKEY  =[F:SWI]SWIKEY
       WKEY1 =[F:SWI]SWIKEY1
       WNUM  =[F:SWI]NUM
       WDATA =[F:SWI]SWIDATA
    Endif

   $NXTSWI
Next
If GOK <> 0 & WNUM <> "" Gosub FIN_LIVRAISON: Gosub FIN_FACTURE : Endif
Return

# ------------------------------------------------------ #
# Traitement d'une entête livraison sur une même facture #
# ------------------------------------------------------ #
$DEB_LIVRAISON
# -------------------> lecture entête livraison
Readlock [SDH]SDH0 = [F:SWI]NUM
If  fstat=1
    GOK=-1 : GLOCK="$SDELIVERY"+[F:SWI]NUM: Goto ROL_TRT
Elsif fstat
    GOK=0 : Call RSTA("SDH",[F:SWI]NUM) From GLOCK : Goto AB_TRT
Endif

# -------------------> alimentation des elements de facturation
NBPOSTE = dim([F:SIV]INVDTA)
# --> Initialisation des montants avec les livraisons
Call ALIMFOOT2 (6,NBPOSTE,[F:SIH]CURTYP,[F:SDH]CUR,[F:SIV]CUR,"NON") From SUBSFIT
[M:SIH2]=[F:SIV]
Raz WNIVDLV

# --> Remise à zéro de la pièce origine car on en a plusieurs
Raz [F:SIV]SIHORINUM, [F:SIV]SIHORIDAT

Return

#-----------------------------------------------------------------------#
# Traitement d'une fin livraison                                        #
#-----------------------------------------------------------------------#
$FIN_LIVRAISON

WINVORN += 1

Raz WNIVDLV
Return


# ----------------------------------------------------- #
# Traitement du détail facture                          #
# ----------------------------------------------------- #
$TRT_DETAIL
# --> boucle de lecture des détails livraison

For  [SDD]SDD0 Where SDHNUM = [F:SDH]SDHNUM
    # Bug 46937
    # Si livraisons de prêt
    # Si livraisons normales et pas de facturation qté retournée (GDLVRTNCNO=1)
    # --> Ne pas prendre en compte les lignes complètement retournée

    # X3-59725 (LCC-26/02/18) Invoices to issued: delivery with a return
    # Now the delivery totally returned could be taken into account if the
    # date of the return is upper to the date of the process [M:DIA]SHIDAT
    # If ([F:SDH]LND=2 | GDLVRTNCNO=1) & [F:SDD]QTYSTU <= [F:SDD]RTNQTYSTU  Goto NEXT_SDD : Endif
    If ([F:SDH]LND=2 | GDLVRTNCNO=1) & [F:SDD]QTYSTU <= [F:SDD]RTNQTYSTU

      # Now we check if the return date if upper to [M:DIA]SHIDAT
      # We will not take into in account the delivery line if at least it has a return
      # with date not upper to [M:DIA]SHIDAT
      Filter [SRD] Where SDHNUM=[F:SDH]SDHNUM & SDDLIN=[F:SDD]SDDLIN and RTNDAT<=[M:DIA]INVDAT
      Look [SRD]SRD1=[F:SDH]SDHNUM;[F:SDD]SDDLIN
      If !fstat: Filter [SRD]: Goto NEXT_SDD Endif
      Filter [SRD]
    Endif
    # End X3-59725 (LCC-26/02/18)

    Local Integer IJUMP
    GPOINT="AUTFAELIG" : Gosub ENTREE From EXEFNC
    If IJUMP : Goto NEXT_SDD : Endif

    Readlock [SDD]SDD0 Curr
    If  fstat
        GOK=0
        Call RSTA("SDD",[F:SDH]SDHNUM-num$([F:SDD]SDDLIN)) From GLOCK
        Gosub AB_TRT : Break
    Endif
#   --> Lecture détail commande
    If  [F:SDD]SOHNUM<>"" & [F:SDD]SOPLIN<>0 & [F:SDD]SOQSEQ<>0
        Readlock [SOQ]SOQ0=[F:SDD]SOHNUM;[F:SDD]SOPLIN;[F:SDD]SOQSEQ
        If  fstat
            GOK=0
            Call RSTA("SOQ",[F:SDD]SOHNUM-num$([F:SDD]SOPLIN)-num$([F:SDD]SOQSEQ)) From GLOCK
            Gosub AB_TRT : Break
        Endif
#       --> Lecture entête commande sauf si cde ouverte
        If [F:SDD]SOHCAT <> 4
            Readlock [SOH]SOH0=[F:SDD]SOHNUM
            If  fstat
                GOK=0
                Call RSTA("SOH",[F:SDD]SOHNUM) From GLOCK
                Gosub AB_TRT : Break
            Endif
        Endif
    Endif

    WSIHLIN = WSIHLIN+1
    LIN     = LIN+1000
#   --> création détail facture
    Call ALISID(3, WSIHLIN, WTRANSAC) From TRTVENFAC
    [M:SIH4]NBLIG += 1

    [F:SID]NUM = [F:SIV]NUM
    [F:SID]SIDLIN = LIN

    WAMTNOTLIN += [F:SID]AMTNOTLIN

    Write [SID]
    If fstat
       GOK=0 : Call FSTA("SID") From GLOCK : Gosub AB_TRT : Break
    Endif

#   --> Ecriture des comptes et sections de la ligne de facture -----#
    Local    Char   TPLAN   (GLONCOA)(10) : # L'indice doit commencer à 0
    Raz GTCOMPTE                          : # C'est une globale et l'indice doit commencer à 0
#   --> Alimentation des comptes par évaluation de la pièce automatique -----#
    Call INIT_ACC(WTRANSAC,"SID",0,TPLAN,GTCOMPTE) From TRTVENFAC
#   --> Ecriture des sections de la ligne de facture
    Call ENREG_ACCCCE(nolign-1,"[V]GTCOMPTE(","","[M:SIH4]CCE","SID",
&                     0,[F:SID]NUM,[F:SID]SIDLIN,0,"","C") From TRTX3CPT
    If GOK<1  Gosub AB_TRT : Break : Endif

# --> nombre de lignes
    [F:SIV]LINNBR += 1

    Local Char SVGGREP(type(GREP)-10)
    SVGGREP=GREP
    GREP="C"
    Gosub SDH_SIH_PLUS From SUBSFIT
    #If GERR <> 0 Then          # FGR 19/08/2014 : X3SUIVI100811
    If GERR = 1 Then            # FGR 22/06/2015 : X3SUIVI109023
      GOK = -1
      Gosub AB_TRT
      Break
    Endif
    # Issue X3-63861 - 2017-12-28 by CPO : Sales invoicing element transfer rule of a Direct invoice order, distribution rule ‘Amount pro rata’, not calculating the invoicing element correctly
    #Call MAJ_SFIT_QTY("F", "SIV", [F:SID]SDHNUM, [F:SID]QTYSTU, [F:SID]AMTNOTLIN * [F:SID]QTY, [F:SID]DSPLINWEI, [F:SID]DSPLINVOL) From SUBSFIT
    Call MAJ_SFIT_QTY("F", "SIV", [F:SID]SDHNUM, [F:SID]QTYSTU, [F:SID]AMTNOTLIN, [F:SID]DSPLINWEI, [F:SID]DSPLINVOL) From SUBSFIT
    # End issue X3-63861
    GREP=SVGGREP

    WMESS="       "+mess(129,197,1)-":"-[F:SDD]SDHNUM-mess(80,197,1)-":"-[F:SDD]ITMREF-[F:SDD]ITMDES1
    Call ECR_TRACE(WMESS, 0) From GESECRAN

$NEXT_SDD
Next

Return

#-----------------------------------------------------------------------#
#     Traitement d'une entête facture                                   #
#-----------------------------------------------------------------------#
$DEB_FACTURE

Call DEBTRANS From GLOCK
$TRTENT
GOK=1
Trbegin [SDH],[SDD],[SIV],[SIH],[SID]
Local Char CODCPT(GLONCAC)
Raz LIN, WSIHLIN
Raz [M:SIH4]

# -------------------> lecture entête livraison
Readlock [SDH]SDH0 = [F:SWI]NUM
If  fstat=1
    GOK=-1 : GLOCK="$SDELIVERY"+[F:SWI]NUM: Goto ROL_TRT
Elsif fstat
    GOK=0 : Call RSTA("SDH",[F:SWI]NUM) From GLOCK : Goto AB_TRT
Endif

# -------------------> test rupture societe site
Raz CPY_NEW, FCY_NEW
IJL=instr(1,[F:SWI]SWIKEY,"~")
If IJL : CPY_NEW=left$([F:SWI]SWIKEY,IJL-1) : Endif
FCY_NEW=right$([F:SWI]SWIKEY,IJL+1)
IJL=instr(1,FCY_NEW,"~")
If IJL : FCY_NEW=left$(FCY_NEW,IJL-1) : Endif

If CPY_CURRENT <> CPY_NEW
   CPY_CURRENT=CPY_NEW
   CPY_TRACE=CPY_NEW : FCY_TRACE=FCY_NEW          : # impression ligne trace societe / site
   #Call GETDEV(FCY_NEW) From DEVSUB               : # Réalimentation GSOCIETE,GFINRSP,GLOCALDEV
   # --> Chargement globales référenciels, comptes et sections de la société
   If GFCY<>FCY_NEW
      GFCY=FCY_NEW : Gosub CHARG_PARAM
      #----- Recherche code pièce auto -----#
      Call PARAML(FCY_NEW,"GAUSDH",[M:DIA]COD) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
      If [M:DIA]COD=""  [M:DIA]COD="SDH" : Endif
   Endif
   If [M:DIA]ALLCPY=2                             : # C est multi societe
      If [M:DIA]EXTOURNE=[0/0/0]
         # on recalcule la date d'extourne
      Endif
   Endif
Endif

If FCY_CURRENT <> FCY_NEW
   FCY_CURRENT=FCY_NEW
   CPY_TRACE=CPY_NEW : FCY_TRACE=FCY_NEW          : # impression ligne trace societe / site
   Call GLOBVAR(FCY_NEW,"VEN") From TRTX3           : # Récupération des paramètres de vente
Endif

# ------------------> lecture client facture
Read [BPC]BPC0 = [F:SDH]BPCINV
If  fstat
    GOK=0 : Call RSTA("BPC",[F:SDH]BPCINV) From GLOCK : Goto AB_TRT
Endif

# ------------------> lecture tiers
Read [BPR]BPR0 = [F:SDH]BPCINV
If  fstat
    GOK=0 : Call RSTA("BPR",[F:SDH]BPCINV) From GLOCK : Goto AB_TRT
Endif

If [F:SDH]BPINAM(0) <> ""
    WBPINAM=[F:SDH]BPINAM(0)
Else
    If [F:BPC]BPCNUM<>[F:SDH]BPCINV
        Read [BPC]BPC0 = [F:SDH]BPCINV
        If fstat Raz [F:BPC] : Endif
    Endif
    WBPINAM=[F:BPC]BPCNAM
Endif

# --> alimentation entête
Call ALISIV(3,[M:DIA]INVDAT) From TRTVENFAC
Call ALISIH(3,[M:DIA]GTE, WRET) From TRTVENFAC

[F:SIV]SIVTYP=GSIVTYP
[F:SIH]SIVTYP=GSIVTYP

If WRET = 1
    GOK=0
    WMESS=mess(129,197,1)-":"-[F:SDH]SDHNUM-mess(99,197,1)-":"-[F:SDH]BPCINV-WBPINAM
    Call ECR_TRACE(WMESS, 0) From GESECRAN
    Call INIT_COMPTE([F:BPC]BPCNUM,[F:SIH]CPY,"C",CODCPT) From CPTSUB
    WMESS=mess(161,197,1)-[L]CODCPT-mess(162,197,1)-[F:SIH]BPRSAC
    Call ECR_TRACE(WMESS, 0) From GESECRAN
    WMESS=mess(112,192,1)         : # mess="Tiers client non autorisé pour le compte collectif"
    Call ECR_TRACE("         "+WMESS, 1) From GESECRAN
    Goto AB_TRT
Endif

Local Char WCODAUTO (GLONGAU)           : # code pièce auto
Local Char WCODGTE  (GLONGTE)           : # type de pièce
Local Char WCODJOU  (GLONJOU)           : # code journal

WCODGTE =[M:DIA]GTE
WCODJOU =[M:DIA]JOU
WCODAUTO =[M:DIA]COD
Read [GAU]GAU0=WCODAUTO
If fstat Raz WCODAUTO Endif

If WCODAUTO="" : WCODAUTO="SDH" : Endif

If WCODGTE=""  : Call EVALAUTO(WCODAUTO,"GTE",WCODGTE) From TRTVENFAC : Endif
# 71937 : Multilégislation
#Read [GTE]GTE0=WCODGTE
#If fstat : Raz [F:GTE] : Endif
Local Integer WRET
Call LEC_GTE_LEG(GCURLEG,WCODGTE,WRET) From TRTLECLEG
If WRET : Raz [F:GTE] : Endif
# 71937

# ----- contrôle sur le type de pièce
#Gosub CONTROLE_GTE From TRTVENFAC
#If GOK=0 : Goto AB_TRT : Endif

[F:SIH]GTE = WCODGTE

# ----- récupération des infos compteur à partir du type de pièce
If [F:GTE]COU<>"" : GCPT=[F:GTE]COU : Endif

If WCODJOU="" : Call EVALAUTO(WCODAUTO,"JOU",WCODJOU) From TRTVENFAC : Endif
If WCODJOU="" : WCODJOU=[F:GTE]DEFJOU : Endif

If GMODU(2)=2                :  # 105566 : Ajout test présence module compta
    # 71937 : Multilégislation
    #Read [JOU]JOU0=WCODJOU
    #If fstat
    Local Integer WRET
    Call LEC_JOU_LEG(GCURLEG,WCODJOU,WRET) From TRTLECLEG
    If WRET
       Raz [F:JOU] : GOK=0 : Call RSTA("JOU",WCODJOU) From GLOCK : Goto AB_TRT
    Endif
    # 71937
Endif                        :  # 105566
[F:SIH]JOU=WCODJOU

# ----- contrôle sur le code journal
#Gosub CONTROLE_JOU From TRTVENFAC
#If GOK=0 : Goto AB_TRT : Endif

LNUM="FAE-000000"                   : # numero bidon (toujours le même)
Delete [SIH] Where NUM=LNUM         : # suppression des enregistrements par precaution
Delete [SIV] Where NUM=LNUM
Delete [SID] Where NUM=LNUM
Delete [CAL] Where ABRFIC="SID" & VCRNUM=LNUM
Delete [CAL] Where ABRFIC="SVF" & VCRTYP=4 & VCRNUM=LNUM
Delete [SVF] Where VCRTYP=4 & VCRNUM=LNUM
Delete [SVV] Where VCRTYP=4 & VCRNUM=LNUM

[F:SIV]NUM=LNUM
[F:SIH]NUM=LNUM

Call NEW_SFIT ( "F","SIV",[F:SIV]CUR,[F:SIV]BPCINV,[F:SIV]BPCORD,[F:SIV]INVDAT ) From SUBSFIT

Call PJT_WRITE_MSG() From TRTPJT  # FGR 14/12/2011 : X3SUIVI71065

Raz WINVORN

Raz WAMTNOTLIN
Call PARAML([F:SIV]SALFCY,"SIVNULL",WPARAM) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
GSIVNULL=val(WPARAM)

Return


#-----------------------------------------------------------------------#
# Ecriture de l'entête facture                                          #
#-----------------------------------------------------------------------#
$FIN_FACTURE

GPOINT="AUTFAEEND" : Gosub ENTREE From EXEFNC

# ----- somme des lignes à 0 interdite
If GSIVNULL=2 & WAMTNOTLIN=0
   Call ECR_TRACE(mess(218,192,1)-":"-mess(91,106,1),1) From GESECRAN
   Goto AB_TRT
Endif

# ----- spécificité USA
# If GLOCUSATAX  # 106867.o
If func AFNC.ACTIV("LTA")  & [F:CPY]SSTTAXACT = 2  # 106867.n
    Local Char WKU_MAJ : WKU_MAJ="2"
    Gosub CHARG_TABLEAUX From TRTVENFACC
Endif

# 101874 : V9 : Taxe code control
#---- Paramètres complementaires contrôle des taxes
# PARAM_T(0) : Flag contrôle des taxes             (1=Non/2=Oui)
# PARAM_T(1) : Lecture de la trace par le sous-pro (1=Non avec msg/2=Oui avec msg/3=Non sans msg/4=Non sans msg)
# PARAM_T(2) : Flag retour                         (1=KO/2=OK)
Local    Char     PARAM_T (25) (0..10)
PARAM_T(0)="2"      : # Contrôle des taxes lors de la création
PARAM_T(1)="3"     : # Pas d'affichage du msg, pas de lecture de la trace
PARAM_T(2)="0"
Gosub CTLVAT From TRTVENFACC1
If PARAM_T(2)="1" GOK=0 : Goto AB_TRT Endif
# 101874

# ----- calcul de la facture
# GO2SUB CAL_FACTURE From TRTVENFACC  # 106867.o
Gosub CAL_FACTURE From TRTVENFACC  # 106867.n

# ----- spécificité USA
# If GLOCUSATAX  # 106867.o
If func AFNC.ACTIV("LTA")  & [F:CPY]SSTTAXACT = 2  # 106867.n
    Call ALISIDTAX ([F:SIH]NUM) From TRTTAXUSA
    If GOK < 1 Goto AB_TRT Endif
Endif

# ----- charger les montants de la facture dans SIH et SIV
Gosub CHARGE_SIH From TRTVENFACC

Raz WINVORN

# ----- ecriture entête facture
Write [SIH]
If fstat GOK=0: Call FSTA("SIH") From GLOCK: Goto AB_TRT
Else
    Write [SIV]
    If fstat
        GOK=0 : Call FSTA("SIV") From GLOCK : Goto AB_TRT
    Else
        NBINV += 1
    Endif
Endif

#----------------------------------------------------------------#
# Création des enregistrements sans SVCRVAT et SVCRFOOT          #
#----------------------------------------------------------------#
Call UPD_VALORISATION ("C","SIH") From TRTVENFACC
If GOK < 1 Goto AB_TRT Endif

#----------------------------------------------------------------#
# Creation des enr. analytiques des elts de facturation          #
#----------------------------------------------------------------#
# ACA (2009-09-17) Lot S03
[M:SIHV]VCRTYP=4 : [M:SIHV]NUM = [F:SIH]NUM
Gosub CREMOD_DIE_FOOT From SUBSIHV
If GOK < 1 Goto AB_TRT Endif

# ----- pour mettre à jour des tables annexes
GPOINT="AUTFAEMAJ" : Gosub ENTREE From EXEFNC
If GOK < 1 Goto AB_TRT Endif

#----------------------------------------------------------------------
# ajustement des montants de taxes à la ligne
# suppression bases de calcul taxes à la ligne (excepté la première pour US)
Raz [M:SIHV]XVPRO       : # calcul par taxe du cumul dans les lignes

Gosub TAXES_LIGNES From TRTVENFACV

# ----- mise à jour des lignes factures
JNOL = 0

For [SID]SID0 Where NUM=[F:SIV]NUM

  Readlock [SID] Curr

  If fstat=1
    GOK=-1 : GLOCK="$SINVOICED"-[F:SIV]NUM          : Break
  Elsif fstat
    GOK=0  : Call RSTA("SID",[F:SIV]NUM) From GLOCK : Break
  Endif
  JNOL += 1
  [F:SID]AMTTAXLIN(0) = [M:SIH4]AMTTAXLIN1(JNOL-1)
  [F:SID]AMTTAXLIN(1) = [M:SIH4]AMTTAXLIN2(JNOL-1)
  [F:SID]AMTTAXLIN(2) = [M:SIH4]AMTTAXLIN3(JNOL-1)

# ----- uniquement bases 0 (principalement pour taxes US), 1 (b21720), 2 (b21720) sont conserves
  [F:SID]BASTAXLIN(3)=0 : [F:SID]BASTAXLIN(4)=0 : [F:SID]BASTAXLIN(5)=0
  Rewrite [SID]
  If fstat
    GOK=0 : Call FSTA("SID") From GLOCK
    Break
  Endif
Next
If GOK<0   : Goto ROL_TRT
Elsif !GOK : Goto AB_TRT
Endif

#----------------------------------------------------------------------
# --- Interface comptable : Creation de la piece

If GMODU(2) = 2                                        : # Présence du module compta
   Raz GNUMPCE
   GFCYDEF=GFCYDEF(2)

   Raz TZONE, TVAL

#---
   TZONE(1)="JOU"       : TVAL(1)=[F:SIH]JOU           : # code journal
   TZONE(2)="ACCDAT"    : TVAL(2)=[F:SIH]ACCDAT        : # date piece
   TZONE(3)="CAT"       : TVAL(3)=num$([M:DIA]TYP)     : # type generation ( 1=réelle / 2 et 3 = simulation )
   TZONE(4)="TYP"       : TVAL(4)=[F:SIH]GTE           : # type de piece
   TZONE(5)="STA"       : TVAL(5)=num$([M:DIA]STA)     : # etat ecritures ( 1=provisoire / 2=definitif )
   ## Demande de modif 56231
   If [M:DIA]TYP = 1 & func AFNC.PARAM("FRADGI",GSOCIETE)="2"
    TZONE(5) = "STA" : TVAL(5) = num$(2)
   Elsif [M:DIA]TYP <> 1
    TZONE(5) = "STA" : TVAL(5) = num$(1)
   Endif
   ## Fin demande 56231
   TZONE(6)="TYPDUD"    : TVAL(6)="2"                  : # facture

   If [M:DIA]TYP=1                                     : # si reelle -->
      TZONE(7)="RVSDAT" : TVAL(7)=num$(val([M:DIA]EXTOURNE))  : # date extourne
      TZONE(8)="RVS"    : TVAL(8)="2"
   Else
      TZONE(7)="REFSIM" : TVAL(7)="FAE-SS"
   Endif
#GTEST=1

   TZONE(9) ="ORIGIN" : TVAL(9) ="2"               : # X3-39795 MWA Automatic loading
   TZONE(10)="ORICOD" : TVAL(10)= WCODAUTO         : # X3-39795 MWA
#---
   Call VALPCE3(WCODAUTO,LNUM,WRETOUR,WMESSAGE,TZONE,TVAL) From CPTAUTO
   #Call VALPCE4(WCODAUTO,'NUM="'+LNUM + '"',WRETOUR,WMESSAGE,TZONE,TVAL) From CPTAUTO

   GFCYDEF=GFCYDEF(5)

   If WRETOUR
      GOK=0
      If GTRACE <> ""
         Call ECR_TRACE(LNUM-WMESSAGE,1) From GESECRAN
      Else
          GERR=1 : GMESSAGE=LNUM-WMESSAGE
      Endif
      Goto AB_TRT
   Endif
   If GNUMPCE="" & [F:SIH]AMTATI<>0
      GOK=0
      If GTRACE <> ""
         Call ECR_TRACE(LNUM-mess(272,199,1),1) From GESECRAN
      Else
          GERR=1 : GMESSAGE=LNUM-mess(272,199,1)
      Endif
      Goto AB_TRT
   Endif
Endif

#----------------------------------------------------------------------
# --- Mise à jour des livraisons ( uniquement si relle )

$MAJ_SDH

If find([M:DIA]TYP,2,3) : Goto LES_TRACES : Endif

Local Char WT_SDH (GLONVCR) (0..dim([M:SIH4]SDHNUM))

# --- creation de la table des enr. livraison à flaguer
For IJL=0 To dim([M:SIH4]ITMREF)-1
    If [M:SIH4]ITMREF(IJL)="" : Break : Endif           : # fin facture
    If [M:SIH4]SDHNUM(IJL)<>""
       If !find([M:SIH4]SDHNUM(IJL),WT_SDH)
          IJL1=find("",WT_SDH)
          If IJL1 : WT_SDH(IJL1-1)=[M:SIH4]SDHNUM(IJL) : Endif
       Endif
    Endif
Next IJL

For IJL=0 To dim(WT_SDH)-1
    If WT_SDH(IJL)="" : Break : Endif
    Readlock [SDH] SDH0=WT_SDH(IJL)
    If fstat=1
       GOK=-1 : GLOCK="$SDELIVERY"-WT_SDH(IJL)          : Break
    Elsif fstat
       GOK=0  : Call RSTA("SDH",WT_SDH(IJL)) From GLOCK : Break
    Endif
    [F:SDH]SISNUM=GNUMFAE
    [F:SDH]SISDAT=[M:DIA]EXTOURNE
    Rewrite [SDH]
    If fstat
       GOK=0 : Call FSTA("SDH") From GLOCK
       Break
    Endif
Next IJL
If GOK<0   : Goto ROL_TRT
Elsif !GOK : Goto AB_TRT
Endif

$LES_TRACES

#----------------------------------------------------------------------
# --- trace facture

Gosub TRACE_FACTURE

#----------------------------------------------------------------------
# --- cumul pour trace recap

Gosub CUMUL_RECAP

#----------------------------------------------------------------------
# --- Delete des enregistrements de la facture

Delete [SIH] Where NUM=LNUM
Delete [SIV] Where NUM=LNUM
Delete [SID] Where NUM=LNUM
Delete [CAL] Where ABRFIC="SID" & VCRNUM=LNUM
Delete [CAL] Where ABRFIC="SVF" & VCRTYP=4 & VCRNUM=LNUM
Delete [SVF] Where VCRTYP=4 & VCRNUM=LNUM
Delete [SVV] Where VCRTYP=4 & VCRNUM=LNUM

Commit

Return

#---------------------------------------------------------------------#
#         Traitement des erreurs                                      #
#---------------------------------------------------------------------#
$ROL_CHGFIC
Rollback
Call ROLL From GLOCK
If   GROLL
     Goto ERR_TRT
Else Goto CHGFIC
Endif
Return

$ROL_TRT
Rollback
Call ROLL From GLOCK
If   GROLL
     Raz WKEY, WKEY1, WNUM, WDATA
     Goto ERR_TRT
Else Goto TRTENT
Endif
Return

$AB_TRT
Rollback
Raz WKEY, WKEY1, WNUM, WDATA

$ERR_TRT
Call PJT_WRITE_MSG() From TRTPJT  # FGR 14/12/2011 : X3SUIVI71065
WMESS =mess(17,107,1)
Call ECR_TRACE("         "+WMESS,0)From GESECRAN
Raz WMESS
Return


#######################################################################
#                     ETIQUETTES                                      #
#######################################################################

#---------------------------------------------------------------------#
#     Verification si création des lignes possible                    #
#---------------------------------------------------------------------#
$VERIF_LIN
Local Char WSOHNUM(GLONVCR)

WSDHLIN = 0
LINFLG = 1

If WIME = "2"
    WSDHLIN = [F:SWI]SWILINNBR
    If WSDHLIN > WSIHACV - WSIHLIN
#   --> Le nb de ligne commande ne tient pas sur la facture : Pas de création possible
        LINFLG = 0
    Endif
Else
    WSDHLIN = [F:SWI]SWILINNBR
    If WSDHLIN > WSIHACV - WSIHLIN
#       --> Le nbre ligne livraison ne tient pas sur la facture en cours de création
        If WIME = "1"
#           Une facture / bl  : Pas de création possible
            LINFLG = 0
        Else
#           Autres cas        :
            If WSDHLIN > WSIHACV
#           --> Le nbre ligne livraison ne tient pas sur une nouvelle facture
                LINFLG = 0
            Else
#           --> Le nbre ligne livraison tient sur une nouvelle facture
                LINFLG = 2
            Endif
        Endif
    Endif
Endif
Return

#---------------------------------------------------------------------#
#     Lecture client                                                  #
#---------------------------------------------------------------------#
$LEC_BPC
If [F:BPC]BPCNUM<>[F:SDH]BPCORD
    Read [BPC]BPC0=[F:SDH]BPCORD
    If fstat Raz [F:BPC] :Endif
Endif
Return

#---------------------------------------------------------------------#
#     Trace facture                                                   #
#---------------------------------------------------------------------#
$TRACE_FACTURE
If [M:DIA]TRACE=2
   # Ini SAM 119686 (JUCON 05/12/16)
   Local Decimal WMTFOOT
   Local Integer WAMTL
   # End SAM 119686 (JUCON 05/12/16)
#  --- ligne societe site si rupture
   If CPY_TRACE<>""
      Raz CPY_TRACE, BPR_TRACE
      Call ECR_TRACE (" ",0)  From GESECRAN
      WMSG ="----- "+mess(2,45,1)-[F:SIH]CPY+space$(16-len([F:SIH]CPY))
      WMSG+=mess(3,45,1)-[F:SIH]FCY
      Call ECR_TRACE (WMSG,0) From GESECRAN
   Endif

#  --- ligne client si rupture
   If [F:SIH]BPR<>BPR_TRACE
      BPR_TRACE=[F:SIH]BPR
      If [F:BPC]BPCNUM<>[F:SIH]BPR
         Read [BPC] BPC0=[F:SIH]BPR
         If fstat Raz [F:BPC] : Endif
      Endif
      WMSG ="----- "+mess(78,117,1)-[F:SIH]BPR+space$((GLONBPR+2)-len([F:SIH]BPR))
      WMSG+=[F:BPC]BPCNAM+space$((GLONNAM+1)-len([F:BPC]BPCNAM))+[F:SIH]CUR
      Call ECR_TRACE (WMSG,0) From GESECRAN
   Endif

#  --- ligne facture a emettre et extourne eventuelle
   WMSG=mess(10,853,1)+"  : "+ctrans(WMESSAGE,"\"," ")
   Call ECR_TRACE(WMSG,0) From GESECRAN

#  --- ligne detail facture
   If [F:TCU]CUR<>[F:SIH]CUR
      Read [TCU] TCU0=[F:SIH]CUR
      If fstat [F:TCU]CURFMT1="9.2" : Endif
   Endif
   For IJL=0 To dim([M:SIH4]ITMREF)-1
       If [M:SIH4]ITMREF(IJL)="" : Break : Endif                    : # plus de ligne facture
       WMSG ="  "+mess(54,198,1)-[M:SIH4]SDHNUM(IJL)+space$((GLONVCR+1)-len([M:SIH4]SDHNUM(IJL)))
       WMSG+=mess(80,197,1)-[M:SIH4]ITMREF(IJL)+space$((GLONITM+1)-len([M:SIH4]ITMREF(IJL)))
       WMSG+=[F:SIH]CUR+space$(4-len([F:SIH]CUR))
       WMT=format$("N3:"+[F:TCU]CURFMT1,[M:SIH4]AMTNOTLIN(IJL)) : WMT=space$(max(1,16-len(WMT)))+WMT
       WMSG+=WMT-mess(1,243,1)
       Call ECR_TRACE(WMSG,0) From GESECRAN
   Next IJL

   # Ini SAM 119686 (JUCON 05/12/16)
   For IJF=0 To [M:SIHV]NBFOOT-1
      WMTFOOT+=[M:SIHV]XFNOT(IJF)
   Next IFF

   WAMTL=len(format$("N3:"+[F:TCU]CURFMT1,WMTFOOT))
   WMSG=space$(20)+ mess(9,2207,1)+space$(41-len(mess(9,2207,1)))+ [F:TCU]CUR+ space$(19-WAMTL) # Sales invoicing elements
   WMSG+=format$("N3:"+[F:TCU]CURFMT1,WMTFOOT)-mess(1,243,1)
   Call ECR_TRACE(WMSG,0) From GESECRAN
   Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
   Call ECR_TRACE (" ",0)  From GESECRAN
   # End SAM 119686 (JUCON 05/12/16)
Endif
Return

#---------------------------------------------------------------------#
#     Cumuls pour trace recap                                         #
#---------------------------------------------------------------------#
#  toutes societes (WT_CPYFCY="~")       --> dev. dossier : GSYSCUR   #
#  societe         (WT_CPYFCY="CPY~")    --> dev. dossier : GLOCALDEV #
#  societe site    (WT_CPYFCY="CPY~FCY") --> dev. dossier : GLOCALDEV #
#---------------------------------------------------------------------#
$CUMUL_RECAP

# --- ligne cumul general
Raz WW_HT, WW_TTC
If [F:SIH]CUR<>GSYSCUR
   Call CONVERT([F:SIH]CUR,GSYSCUR,GLOCALDEV,[F:SIH]CURTYP,[F:SIH]ACCDAT,[F:SIH]AMTNOT,WW_HT,GBIDI3)  From TRTDEV
   Call CONVERT([F:SIH]CUR,GSYSCUR,GLOCALDEV,[F:SIH]CURTYP,[F:SIH]ACCDAT,[F:SIH]AMTATI,WW_TTC,GBIDI3) From TRTDEV
Else
   WW_HT=[F:SIH]AMTNOT : WW_TTC=[F:SIH]AMTATI
Endif
WT_HT(0) +=WW_HT : WT_TTC(0) +=WW_TTC

# --- ligne cumul societe
Raz WW_HT, WW_TTC
IJL=find([F:SIH]CPY+"~",WT_CPYFCY)
If !IJL
   IJL=find("",WT_CPYFCY)
   If IJL WT_CPYFCY(IJL-1)=[F:SIH]CPY+"~" : WT_CPY(IJL-1)=[F:SIH]CPY : WT_CUR(IJL-1)=GLOCALDEV Endif
Endif
If [F:SIH]CUR<>GLOCALDEV
   Call CONVERT([F:SIH]CUR,GLOCALDEV,GLOCALDEV,[F:SIH]CURTYP,[F:SIH]ACCDAT,[F:SIH]AMTNOT,WW_HT,GBIDI3)  From TRTDEV
   Call CONVERT([F:SIH]CUR,GLOCALDEV,GLOCALDEV,[F:SIH]CURTYP,[F:SIH]ACCDAT,[F:SIH]AMTATI,WW_TTC,GBIDI3) From TRTDEV
Else
   WW_HT=[F:SIH]AMTNOT : WW_TTC=[F:SIH]AMTATI
Endif
If IJL WT_HT(IJL-1) +=WW_HT : WT_TTC(IJL-1) +=WW_TTC Endif

# --- ligne cumul societe site
IJL=find([F:SIH]CPY+"~"+[F:SIH]FCY,WT_CPYFCY)
If !IJL
   IJL=find("",WT_CPYFCY)
   If IJL
       WT_CPYFCY(IJL-1)=[F:SIH]CPY+"~"+[F:SIH]FCY : WT_CPY(IJL-1)=[F:SIH]CPY : WT_FCY(IJL-1)=[F:SIH]FCY
       WT_CUR(IJL-1)=GLOCALDEV
   Endif
Endif
If IJL WT_HT(IJL-1) +=WW_HT : WT_TTC(IJL-1) +=WW_TTC Endif
Return

#---------------------------------------------------------------------#
#     Trace recap                                                     #
#---------------------------------------------------------------------#
$TRACE_RECAP
If [M:DIA]TRACE<>2           : Goto FIN_RECAP : Endif
If sum(WT_HT(0),WT_TTC(0))=0 : Goto FIN_RECAP : Endif

Sorta WT_CPYFCY, WT_CPY, WT_FCY, WT_CUR, WT_HT, WT_TTC

# --- cumul general
Call ECR_TRACE (" ",0)  From GESECRAN
Call ECR_TRACE(string$(88,"-"),0)  From GESECRAN
For IJL=0 To dim(WT_CPYFCY)-1
    If sum(WT_CPY(IJL),WT_FCY(IJL))<>""
       If [F:TCU]CUR<>WT_CUR(IJL)
       Read [TCU] TCU0=WT_CUR(IJL)
          If fstat [F:TCU]CURFMT1="9.2" : Endif
       Endif
       If WT_FCY(IJL)=""                                          : # ligne cumul societe
          WMSG =mess(2,45,1)-WT_CPY(IJL)+space$(6)+WT_CUR(IJL)+" "
          WMT=format$("N3*:"+[F:TCU]CURFMT1,WT_HT (IJL)) : WMT=mid$("****************",1,max(1,16-len(WMT)))+WMT
          WMSG+=WMT-mess(1,243,1)+" "
          WMT=format$("N3*:"+[F:TCU]CURFMT1,WT_TTC(IJL)) : WMT=mid$("****************",1,max(1,16-len(WMT)))+WMT
          WMSG+=WMT-mess(2,243,1)
          Call ECR_TRACE (WMSG,0) From GESECRAN
       Else                                                       : # ligne cumul site
          WMSG =space$(1+len(mess(2,45,1)))+mess(3,45,1)+" "
          WMSG+=WT_FCY(IJL)+" "+WT_CUR(IJL)+" "
          WMT=format$("N3:"+[F:TCU]CURFMT1,WT_HT (IJL)) : WMT=space$(max(1,16-len(WMT)))+WMT
          WMSG+=WMT-mess(1,243,1)+" "
          WMT=format$("N3:"+[F:TCU]CURFMT1,WT_TTC(IJL)) : WMT=space$(max(1,16-len(WMT)))+WMT
          WMSG+=WMT-mess(2,243,1)+" "
          Call ECR_TRACE (WMSG,0) From GESECRAN
       Endif
    Endif
Next IJL

Call ECR_TRACE(string$(88,"-"),0)  From GESECRAN

$FIN_RECAP

Return

#---------------------------------------------------------------------#
#     Suppression des ecritures de simulation                         #
#---------------------------------------------------------------------#
$DEL_SIMULATION
GOK=1 : # Le Call DELPCE est une transaction à part entière (Trbegin-Commit)
WFLAG=0 : WMSG=""
If [M:DIA]ALLCPY=2
  Filter [HAE1] Where REFSIM="FAE-SS"
Elsif [M:DIA]ALLFCY=2
  Filter [HAE1] Where REFSIM="FAE-SS" & CPY=[M:DIA]CPY
Else
  If dim([L]WFCY)<1  Local Char WFCY(GLONFCY) : Endif
  #VPO 06/07/09 56248
  #[L]WFCY=[M:DIA]FCY
  [L]WFCY=[M:DIA]SALFCY
  Read [FCY] FCY0=[L]WFCY : If fstat  Raz [F:FCY] : Endif
  If [F:FCY]FINRSPFCY<>""  [L]WFCY=[F:FCY]FINRSPFCY : Endif
  Filter [HAE1] Where REFSIM="FAE-SS" & CPY=[M:DIA]CPY & FCY=[L]WFCY
Endif
For [HAE1] HAE2
  If [M:DIA]TRACE=2 & WFLAG=0
    Call ECR_TRACE(mess(3,107,1),0) From GESECRAN
  Endif
  WFLAG=1
  CLEFIC=num$([F:HAE1]TYP)-[F:HAE1]NUM
  WMSG=mess(12,100,1)-"GACCENTRY"-CLEFIC : # Erreur d'accès sur le fichier ...
  Call DELPCE([F:HAE1]TYP,[F:HAE1]NUM) From CPTBATCH
  If GOK<1  Break : Endif
  If [M:DIA]TRACE=2
    Call ECR_TRACE(mess(41,107,1)-[F:HAE1]TYP-[F:HAE1]NUM,0) From GESECRAN
  Endif
Next
Filter [HAE1]
If GOK<1 Gosub AB_TRANSACTION_MSG : Endif
If [M:DIA]TRACE=2 & WFLAG<>0
  Call ECR_TRACE(string$(88,"-"),0)  From GESECRAN
Endif
Return

#---------------------------------------------------------------------#
# Messages en cas d'abandon de la transaction                         #
#---------------------------------------------------------------------#
$AB_TRANSACTION_MSG
If [M:DIA]TRACE=2
  If WMSG<>"" Call ECR_TRACE(WMSG,1) From GESECRAN : Endif
Endif
Raz WMSG
Return



#######################################################################
#                     ACTIONS CHAMPS                                  #
#######################################################################
$CTL_INVDAT

If GMODU(2) <> 2 Return Endif
Local Decimal    EXERCICE , PERIODE
If clalev([F:PER])=0 : Local File PERIOD [PER] : Endif
For [PER]PER0 Where CPY=[M]CPY & PERSTR<=WINVDAT & PEREND>=WINVDAT & LEDTYP=GTYPGEN
  EXERCICE = [F:PER]FIYNUM
  PERIODE  = [F:PER]PERNUM
Next
If EXERCICE=0 | PERIODE=0
  GMESSAGE = mess(1,104,1) : # MSG=Date incorrecte
  mkstat = 2 : Return
Endif
If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
Read [FIY]FIY0 = [M]CPY;GTYPGEN;EXERCICE
If fstat | [F:FIY]FIYSTA<>2
  GMESSAGE = mess(20,101,1) : # MSG=Exercice non ouvert
  mkstat = 2 : Return
Endif
If [F:PER]PERSTA<2
  GMESSAGE = mess(35,101,1) : # MSG=Periode non ouverte
  mkstat = 2 : Return
Endif
If [F:PER]PERSTA>2
  GMESSAGE = mess(36,101,1) : # MSG=Période fermee
  mkstat = 2 : Return
Endif
Return


#----------------------------------------------------------------------
# Initialisation de la date d'extourne
#----------------------------------------------------------------------
$DATE_EXTOURNE
If dim(SOCIETE) <0 Local  Char    SOCIETE(GLONCPY) : Endif
If dim(DAT)     <0 Local  Date    DAT              : Endif
If dim(EXERCICE)<0 Local  Decimal EXERCICE         : Endif
If dim(PERIODE) <0 Local  Decimal PERIODE          : Endif
If dim(SITE)    <0 Local  Char    SITE(GLONFCY)    : Endif
If dim(VALPAR)  <0 Local  Char    VALPAR(30)       : Endif

# --- si un site saisi --> la societe est garnie
If [M:DIA]ALLFCY=1
  SITE=[M:DIA]SALFCY
  Call GETSOC(SITE) From DEVSUB : SOCIETE=GSOCIETE
# Issue 110744 - 2015-09-10 by CPO : Pb Legislation "Invoices to be issued" function
#--First, we need to see if there is a company
Elsif [M:DIA]CPY<>""
  SOCIETE=[M:DIA]CPY
# End issue 110744
# Issue X3-38251 - 2017-11-10 by CPO : [110949] FUNAUTFAE - calcul date extourne
#--in case of a legislation context, we have to test if GFCYDEF(5)'s company has the right legislation
Elsif [M:DIA]LEG<>"" and [M:DIA]ALLCPY=2 and [M:DIA]ALLFCY=2
  Local Integer WCPODEFFCY : WCPODEFFCY = [V]CST_AYES
  Raz [M:DIA]EXTOURNE
  SOCIETE = ""
  SITE=GFCYDEF(5)
  If SITE<>""
    Read [F:FCY]FCY0=SITE
    If fstat : Raz [F:FCY]
      GERR=2 #--set as warning
      GMESSAGE = mess(77,123,1)-"'"+SITE+"'"-":"-mess(23,100,1)
    Endif
    SOCIETE = [F:FCY]LEGCPY
  Else
    SOCIETE = GDEFSOC
    WCPODEFFCY = [V]CST_ANO
  Endif

  If SOCIETE<>""
    Read [F:CPY]CPY0=SOCIETE
    If fstat : Raz [F:CPY] : Endif
    If [F:CPY]LEG<>"" and [F:CPY]LEG<>[M:DIA]LEG
      mkstat = 2
      GERR=2
      If WCPODEFFCY=[V]CST_AYES
        GMESSAGE = mess(77,123,1)-"'"+SITE+"'"-":"-mess(171,187,1)
      Else
        GMESSAGE = mess(180,124,1)-"'"+SOCIETE+"'"-":"-mess(171,187,1)
      Endif
      Raz SOCIETE
    Endif
  Endif

  #-- ! Keep if and don't use else because of the Raz SOciete further up !
  If SOCIETE=""
    #--if not a default site for the actual leg, read the first company of the current leg
    Filter [F:CPY] Where LEG=[M:DIA]LEG
    Read [F:CPY] First
    If fstat : Raz [F:CPY] : Endif
    SOCIETE = [F:CPY]CPY
    Filter [F:CPY]
  Endif

  GSOCIETE = SOCIETE : GCURLEG = [M:DIA]LEG
  Call SETMAINREF(GSOCIETE,GTYPGEN,GTYPANA) From CPTDIV
  GCURFCY = SITE
# End issue X3-38251
Else
  SITE=GFCYDEF(5)
  Call GETSOC(SITE) From DEVSUB : SOCIETE=GSOCIETE
Endif
DAT=[M:DIA]INVDAT

# Issue X3-38251 - 2017-11-10 by CPO : [110949] FUNAUTFAE - calcul date extourne
Raz [F:PER] #--Raz of [F:PER]
# End issue X3-38251

Call GETPERSOC(SOCIETE,GTYPGEN,DAT,EXERCICE,PERIODE) From CPTSUB
[M:DIA]EXTOURNE=[F:PER]PEREND+1
If [M:DIA]EXTOURNE<=[M:DIA]INVDAT
  [M:DIA]EXTOURNE=addmonth(gdat$(1,month([M:DIA]INVDAT),year([M:DIA]INVDAT)),1)
Endif
Return

# ---------------------------- Toutes sociétés ------------------------
Subprog AS_ALLCPY(VALEUR)
Variable Integer VALEUR

  If [M:DIA]TYP<>1
     Raz [M:DIA]EXTOURNE : Grizo [M:DIA]EXTOURNE
     [M:DIA]STA=1        : Grizo [M:DIA]STA
  Endif
  If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE : mkstat = 1 : End : Endif

# 71937 : Multilégislation
#  # FQ53416 - MABON 29/09/09 - Désactiver la case "Toutes sociétés" si multi-leg
#  # Code activité de multi-législation
#  If func AFNC.ACTIV("LEG") Then
#    Grizo ALLCPY
#    Actzo CPY, ALLFCY
#    mkstat = 1 : End
#  Endif

End
#######################################
Subprog AM_ALLCPY(VALEUR)
Variable Integer VALEUR

If VALEUR=1
  Actzo CPY
  Call INICPY([M:DIA]CPY) From CPTSUB
  Affzo [DIA]CPY : If dim([M:DIA]ZCPY)>0  Affzo [DIA]ZCPY : Endif
  If GNBAUZ=1 Diszo [DIA]CPY : Endif
  Call INIALLFCY([M:DIA]ALLFCY,[M:DIA]CPY) From CPTTRT
  If mkstat
    Grizo [DIA]ALLFCY : Actzo [DIA]SALFCY : Raz mkstat
    Call INIFCY([M:DIA]SALFCY,[M:DIA]CPY) From CPTSUB
    Affzo [DIA]ALLFCY : If dim([M:DIA]ZALLFCY)>0  Affzo [DIA]ZALLFCY : Endif
    If GNBAUZ=1 Diszo [DIA]ALLFCY : Endif
  Else
    Actzo [DIA]ALLFCY
    If [M:DIA]ALLFCY=1
      Call INIFCY([M:DIA]SALFCY,[M:DIA]CPY) From CPTSUB
      Affzo [DIA]SALFCY : If dim([M:DIA]ZSALFCY)>0  Affzo [DIA]ZSALFCY : Endif
    Endif
  Endif
Else
  [M:DIA]ALLFCY=2 : Affzo [DIA]ALLFCY : Grizo [DIA]ALLFCY
  Effzo [DIA]CPY, SALFCY
  Raz GSOCIETE, GCURLEG, GFCY, GCURFCY # Issue 110744 - 2015-09-08 by CPO : Pb Legislation "Invoices to be issued" function
  # 71937 : Multilégislation
  Effzo [M:DIA]LEG
  If dim([M:DIA]ZLEG)>0     Effzo [DIA]ZLEG    : Endif
  # 71937
  If dim([M:DIA]ZCPY)>0     Effzo [DIA]ZCPY    : Endif
  If dim([M:DIA]ZSALFCY)>0  Effzo [DIA]ZSALFCY : Endif
  Diszo [DIA]CPY, SALFCY
  If [M:DIA]TYP=1 : Actzo STA : Endif
Endif
#----- Initialisation type pièce et journal -----#
Gosub INIT_TYPPCEJOU
Affzo [DIA]GTE, JOU
# 71937 : Multilégislation
[M]ALLCPY=VALEUR : Gosub GRILEG
Affzo [M:DIA]LEG
# 71937

End
# ---------------------------- Société --------------------------------
Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
If [M:DIA]ALLCPY = 2 : mkstat = 1 : End : Endif
End
#######################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If [M]ALLCPY<>2 & VALEUR="" mkstat=1 : End : Endif
End
#######################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Call INIALLFCY([M:DIA]ALLFCY,VALEUR) From FUNPTH
If mkstat
  Grizo [DIA]ALLFCY : Actzo [DIA]SALFCY : Raz mkstat
  Call INIFCY([M:DIA]SALFCY,VALEUR) From CPTSUB
  Affzo [DIA]SALFCY : If dim([M:DIA]ZSALFCY)>0  Affzo [DIA]ZSALFCY : Endif
  If GNBAUZ=1 Diszo [DIA]SALFCY : Endif
Else
  Actzo [DIA]ALLFCY
  If [M:DIA]ALLFCY=1
    Raz [M:DIA]SALFCY       : # 71937 : Multilégislation
    Call INIFCY([M:DIA]SALFCY,VALEUR) From CPTSUB
    Affzo [DIA]SALFCY : If dim([M:DIA]ZSALFCY)>0  Affzo [DIA]ZSALFCY : Endif
  Endif
Endif

If  [M:DIA]TYP=1
 If func AFNC.PARAM("FRADGI",VALEUR)="2" : # Paramètre à Oui
  [M:DIA]STA = 2 : Grizo STA
  Affzo STA
 Else
  Actzo STA
 Endif
Endif

#----- Initialisation type pièce et journal -----#
[M:DIA]CPY=VALEUR
Gosub INIT_TYPPCEJOU
Affzo [DIA]GTE, JOU

# 71937 : Multilégislation
Gosub GRILEG
Affzo [M:DIA]LEG
# 71937

# Issue 110744 - 2015-09-08 by CPO : Pb Legislation "Invoices to be issued" function
If [F:FCY]LEGCPY<>VALEUR
  Filter [F:FCY] Where LEGCPY=VALEUR
  Read [F:FCY] First
  If fstat : Raz [F:FCY] : Endif
  Filter [F:FCY]
Endif
If [F:FCY]FCY<>""
  Raz GSOC_ACTIVE : GFCY=[F:FCY]FCY : Gosub CHARG_PARAM
Endif
# End issue 110744

End
# 71937 : Multilégislation
# ---------------------------- Législation -----------------------------
Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG=VALEUR
End
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
[M:DIA]LEG=VALEUR                       : # 71937
Gosub INIT_TYPPCEJOU_SUI
Affzo [DIA]GTE, JOU

End

If [M:DIA]TYP=1
  # Type de génération : Réelle
  #----- Traitement type de pièce -----#
  # Init Type de pièce par évaluation de la pièce auto facture à émettre
  Call EVAL_CHAR([M:DIA]GTE,"GTE",1,0,"",WSTAT) From CPTAUTO
  #----- Traitement du journal -----#
  # Init Journal par évaluation de la pièce auto facture à émettre
  Raz [M:DIA]JOU
  Call EVAL_CHAR([M:DIA]JOU,"JOU",1,0,"",WSTAT) From CPTAUTO
Endif
If [M:DIA]JOU="" & GCURLEG<>"" & [M:DIA]GTE<>""
  # Journal non renseigné : On le récupère du type de pièce
  Call LEC_GTE_LEG(GCURLEG,[M:DIA]GTE,WSTAT) From TRTLECLEG
  If WSTAT Raz [F:GTE] Endif
  [M:DIA]JOU=[F:GTE]DEFJOU
Else
Endif

End
# 71937
# ---------------------------- Tous sites -----------------------------
Subprog AS_ALLFCY(VALEUR)
Variable Integer VALEUR
If [M:DIA]ALLCPY=2 : VALEUR = 2 : End : Endif
Call INIALLFCY(VALEUR,[M:DIA]CPY) From CPTTRT
End
#######################################
Subprog AM_ALLFCY(VALEUR)
Variable Integer VALEUR
If VALEUR=1
  Actzo [DIA]SALFCY
  Call INIFCY([M:DIA]SALFCY,[M:DIA]CPY) From CPTSUB
  Affzo [DIA]SALFCY : If dim([M:DIA]ZSALFCY)>0  Affzo [DIA]ZSALFCY : Endif
  If GNBAUZ=1 Diszo [DIA]SALFCY : Endif
Else
  Effzo [DIA]SALFCY : If dim([M:DIA]ZSALFCY)>0  Effzo [DIA]ZSALFCY : Endif
  Diszo [DIA]SALFCY
Endif
#----- Initialisation type pièce et journal -----#
Gosub INIT_TYPPCEJOU
Affzo [DIA]GTE, JOU
#-----
# 71937 : Multilégislation
Gosub GRILEG
Affzo [M:DIA]LEG
# 71937
End
# ---------------------------- Site -----------------------------------
Subprog AS_SALFCY(VALEUR)
Variable Char    VALEUR()
If [M:DIA]ALLFCY = 2 : mkstat = 1 : End : Endif
End
#######################################
Subprog C_SALFCY(VALEUR)
Variable Char    VALEUR()
If [M]ALLFCY<>2 & VALEUR=""
  mkstat=1 : End : # Obligatoire si flag tous sites non coché
Endif
#If [F:FCY]WRHFLG<>2
#  mkstat=1 : GMESSAGE=mess(58,199,1) : End : # Ce site n'est pas un dépôt
#Endif
End
#######################################
Subprog AM_SALFCY(VALEUR)
Variable Char    VALEUR()
Local Integer ISITE
If [M:DIA]ALLCPY=2
   If VALEUR<>""
      ISITE=find(VALEUR,GSITE(1..GNBSITE))
      If ISITE : [M:DIA]ALLCPY=1 : [M:DIA]CPY=GSOCSITE(ISITE) : Affzo [M:DIA]ALLCPY,CPY : Endif
   Endif
Endif
[M:DIA]SALFCY=VALEUR
#----- Initialisation type pièce et journal -----#
Gosub INIT_TYPPCEJOU
Affzo [M:DIA]ALLCPY, CPY, GTE, JOU
# 71937 : Multilégislation
Gosub GRILEG
Affzo [M:DIA]LEG
# 71937
# Issue 110744 - 2015-09-08 by CPO : Pb Legislation "Invoices to be issued" function
If VALEUR<>""
  Raz GSOC_ACTIVE : GFCY=VALEUR : Gosub CHARG_PARAM
Endif
# End issue 110744
End
# ---------------------------- Client facture début ---------------------
Subprog AM_BPCINVDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]BPCINVFIN = VALEUR : Endif
End

# ---------------------------- Client facture fin ---------------------
Subprog AS_BPCINVFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR="" | VALEUR<[M]BPCINVDEB : VALEUR=[M]BPCINVDEB : Endif
End

Subprog C_BPCINVFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]BPCINVDEB
 GMESSAGE = mess(44,199,1) :# La borne fin est inferieure a la borne debut
 mkstat = 2
Endif
End

# ---------------------------- Type de génération ---------------------
Subprog AM_TYP(VALEUR)
Variable Integer VALEUR
Local    Integer STAT
If VALEUR<>1 Grizo STA Else Actzo STA : Endif

If VALEUR = 1
 If [M]CPY<>""
  If func AFNC.PARAM("FRADGI",[M]CPY)="2" : # Paramètre à Oui
   [M]STA = 2 : Grizo STA
  Else : Actzo STA
  Endif
 Else : Actzo STA
 Endif
Endif

Raz [M:DIA]GTE, [M:DIA]JOU

# --- Traitement du type de pièce ---
If VALEUR<>1                                        : # - Simulation
   Call PARAML("","TYPACC",[M:DIA]GTE) From ADOVAL   : #     Type de pièce (paramètre Tronc commun TYPACC)      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
Else                                                : # - Reelle
   Call LECTURE("GAU",[M:DIA]COD,"") From CONTOBJ   : #     Piece auto : facture a emettre
   If !clalev([F:TB0]) : Local File =[F:GAU]TBL [TB0] : Endif
   Gosub OUVRE From ="WMGAU"+[F:GAU]COD
   Gosub LIENS From ="WMGAU"+[F:GAU]COD
   Call EVAL_CHAR([M:DIA]GTE,"GTE",1,0,"",STAT)  From CPTAUTO
Endif
# --- Traitement du journal ---
If VALEUR=1                                         : # - Reelle
   Call LECTURE("GAU",[M:DIA]COD,"") From CONTOBJ
   Call EVAL_CHAR([M:DIA]JOU,"JOU",1,0,"",STAT) From CPTAUTO
Endif
If [M:DIA]JOU=""
   # 71937 : Multilégislation
   #Call LECTURE("GTE",[M:DIA]GTE,"") From CONTOBJ
   Call LEC_GTE_LEG(GCURLEG,[M:DIA]GTE,STAT) From TRTLECLEG
   If STAT Raz [F:GTE] Endif
   # 71937
   [M:DIA]JOU=[F:GTE]DEFJOU
Endif

Affzo ZGTE : Affzo ZJOU

# --- Traitement date d'extourne ---
If VALEUR<>1
  Effzo EXTOURNE : Grizo EXTOURNE
Else
  Gosub DATE_EXTOURNE
  Actzo EXTOURNE
Endif
# --- Affichage type de pèce et journal et date d'extourne ---
If !GIMPORT  Affzo [DIA]GTE, JOU, EXTOURNE : Endif
End

# ---------------------------- Type de pièce --------------------------
Subprog C_GTE(VALEUR)
Variable Char    VALEUR()
# 71937 : Multilégislation
Local Integer WRET
#Call LECTURE("GTE",VALEUR,"") From CONTOBJ
Call LEC_GTE_LEG(GCURLEG,VALEUR,WRET) From TRTLECLEG
If WRET Raz [F:GTE] Endif
# 71937
Call CONTEXE([F:GTE]ACS)      From CPTSUB
If mkstat  End : Endif
If [M:DIA]TYP=1 & [F:GTE]VCRREA<>2
   GMESSAGE=mess(33,107,1) : mkstat=2 : End         : # Type de pièce interdit en réel
Elsif [M:DIA]TYP>=2 & [F:GTE]VCRSIM<>2
   GMESSAGE=mess(32,107,1) : mkstat=2 : End         : # Type de pièce interdit en simulation
Endif
End

# ---------------------------- Code journal ---------------------------
Subprog C_JOU(VALEUR)
Variable Char    VALEUR()
Call CONTEXE([F:JOU]ACS) From CPTSUB
If mkstat  GMESSAGE=VALEUR-GMESSAGE : Return : Endif
If [M:DIA]CPY<>"" & [M:DIA]SALFCY<>""
   Call VERSOC([F:JOU]FCY,[M:DIA]CPY,[M:DIA]SALFCY,VALEUR) From CFYSUB
   If mkstat  End : Endif
Endif
# 71937 : Multilégislation
Local Integer WRET
#Call LECTURE("GTE",[M:DIA]GTE,"") From CONTOBJ
Call LEC_GTE_LEG(GCURLEG,[M:DIA]GTE,WRET) From TRTLECLEG
If WRET Raz [F:GTE] Endif
# 71937
If [F:GTE]AUZJOU([F:JOU]TYP-1)<>2
   GMESSAGE=[F:JOU]JOU-mess(8,106,1)                : # Journal non autorisé sur ce type de pièce
   mkstat=2 : End
Endif
End

#------------------------#
# Contrôle date de pièce #
#------------------------#
Subprog C_INVDAT(VALEUR)
Variable Date    VALEUR
#-----
If VALEUR<[M:DIA]SHIDAT
  GMESSAGE=mess(564,199,1) : mkstat=1 : End
Endif
#-----
Local    Date    WINVDAT
WINVDAT=VALEUR
If [M:DIA]CPY<>"" & VALEUR <> [0/0/0] Gosub CTL_INVDAT Endif
End

#--------------------------#
# Contrôle date d'extourne #
#--------------------------#
Subprog C_EXTOURNE(VALEUR)
Variable Date    VALEUR
#-----
If VALEUR<=[M:DIA]INVDAT
  GMESSAGE=mess(565,199,1) : mkstat=1 : End
Endif
#-----
Local  Char    SOCIETE(GLONCPY)
Local  Decimal EXERCICE
Local  Decimal PERIODE
Local  Char    SITE(GLONFCY)
#-----
If [M:DIA]ALLFCY=1
  SITE=[M:DIA]SALFCY
  Call GETSOC(SITE) From DEVSUB : SOCIETE=GSOCIETE
Elsif [M:DIA]ALLCPY=1
  Read [CPY] CPY0=[M:DIA]CPY
  SITE=[F:CPY]MAIFCY
  SOCIETE=[M:DIA]CPY
  Call GETSOC(SITE) From DEVSUB
Else
  SITE=GFCYDEF(2)
  Call GETSOC(SITE) From DEVSUB : SOCIETE=GSOCIETE
Endif
#----- Permet d'alimenter la classe [F:PER] -----#
Call GETPERSOC(SOCIETE,GTYPGEN,[M:DIA]INVDAT,EXERCICE,PERIODE) From CPTSUB
#-----
If VALEUR<=[F:PER]PEREND
  GMESSAGE=mess(565,199,1) : mkstat=1 : End
Endif
#-----
End

#######################################################################
#--------------------------------------------------------------------------#
# Chargement des paramètres avec GFCY = Site de la facture                 #
# ------------------------------------------------------------------------ #
# Chargement des globales référenciels, comptes et sections de la société  #
# Chargement des paramètres de localisation                                #
# ------------------------------------------------------------------------ #
$CHARG_PARAM
Local  Char     PARAM2(10)

# --- Chargement GSOCIETE GFINRSP GCURLEG GCURFCY (GETSOC) GLOCALDEV (GETDEV)
# --- Chargement des globales référenciels, comptes et sections de la société
Call GETCPY(GFCY,"",0,"") From TRTX3CPT
# --- Si changement société -----#
If GSOC_UPDFLG
    # --- Chargement des paramètres de localisation
    # --- Numérotation Argentine -----#
    If func AFNC.ACTIV("KAG")
        Call PARAML(GFCY,"ARGNUM",PARAM2) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
        GLOCARGNUM=val(PARAM2)
        If GLOCARGNUM>0  GLOCARGNUM-=1 : Endif
    Else
        Raz GLOCARGNUM
    Endif
    # --- Utilisation systeme de taxe
    Call LEC_CPY(GSOCIETE) From CPTLEC   # 106867.n
#    If func AFNC.ACTIV("KUS") # 106867.so
#        Call PARAM(GFCY,"USATAX",PARAM2) From ADOVAL
#        GLOCUSATAX=val(PARAM2)
#        If GLOCUSATAX>0  GLOCUSATAX-=1 : Endif
#    Else
#      Raz GLOCUSATAX
#    Endif  # 106867.eo
Endif

Return
######################################################################################

#-----------------------------------------------#
# Initialisation du type de pièce et du journal #
#-----------------------------------------------#
$INIT_TYPPCEJOU
#Local Integer WSTAT                                : # 71937
#-----
#----- Chargement du site -----#
If [M:DIA]CPY="" & [M:DIA]SALFCY=""
  [M:DIA]FCY=""
Elsif [M:DIA]SALFCY<>""
  [M:DIA]FCY=[M:DIA]SALFCY
  Call GETSOC([M:DIA]FCY) From DEVSUB               : # 71937
Elsif [M:DIA]CPY<>"" & [M:DIA]SALFCY=""
  Read [CPY] CPY0=[M:DIA]CPY
  If [F:CPY]MAIFCY=""                                 : # 71937
    GCURLEG=[F:CPY]LEG                                : # 71937
  Else                                                : # 71937
    Call GETSOC([F:CPY]MAIFCY) From DEVSUB
    [M:DIA]FCY=GFINRSP
  Endif                                               : # 71937
Endif
Gosub INIT_TYPPCEJOU_SUI                            : # 71937
Return                                              : # 71937

#-----------------------------------------------#        : # 71937
# Initialisation du type de pièce et du journal #        : # 71937
#-----------------------------------------------#        : # 71937
$INIT_TYPPCEJOU_SUI                                      : # 71937
Local Integer WSTAT                                      : # 71937

#----- Recherche code de la pièce auto ----#
If [M]FCY<>""
  Call PARAML([M:DIA]FCY,"GAUSDH",[M:DIA]COD) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
Elsif [M]CPY<>""
  Call PARAML([M:DIA]CPY,"GAUSDH",[M:DIA]COD) From ADOVAL
Elsif [M]LEG<>""                                             : # 71937
  Call PARAML([M:DIA]LEG,"GAUSDH",[M:DIA]COD) From ADOVAL    : # 71937      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
Else
  Call PARAML("","GAUSDH",[M:DIA]COD) From ADOVAL              # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
Endif
If [M:DIA]COD=""  [M:DIA]COD="SDH" : Endif

# 71937 : Multilégislation
If [M:DIA]TYP=1 & [M:DIA]COD<>""
  # Type de génération : Réelle
  #----- Lecture Pièce auto Factures à émettre -----#
  Call LECTURE("GAU",[M:DIA]COD,"") From CONTOBJ
  If !clalev([F:TB0]) : Local File =[F:GAU]TBL [TB0] : Endif
  Gosub OUVRE From ="WMGAU"+[F:GAU]COD
  Gosub LIENS From ="WMGAU"+[F:GAU]COD
Endif
# 71937

#----- Traitement type de pièce -----#
If [M:DIA]TYP<>1
  # Type de génération : Simulation active ou non active
  #----- Paramètre TYPACC : type de pièce utilisé en simulation -----#
  If [M:DIA]FCY<>""
    Call PARAML([M:DIA]FCY,"TYPACC",[M:DIA]GTE) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
  Elsif [M:DIA]CPY<>""
    Call PARAML([M:DIA]CPY,"TYPACC",[M:DIA]GTE) From ADOVAL
  Elsif [M:DIA]LEG<>""                                         : # 71937
    Call PARAML([M:DIA]LEG,"TYPACC",[M:DIA]GTE) From ADOVAL    : # 71937      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
  Else
    Call PARAML("","TYPACC",[M:DIA]GTE) From ADOVAL              # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
  Endif
Else
  # Type de génération : Réelle
  # Init Type de pièce par évaluation de la pièce auto facture à émettre
#  Call LECTURE("GAU",[M:DIA]COD,"") From CONTOBJ               : # 71937
#  If !clalev([F:TB0]) : Local File =[F:GAU]TBL [TB0] : Endif   : # 71937
#  Gosub OUVRE From ="WMGAU"+[F:GAU]COD                         : # 71937
#  Gosub LIENS From ="WMGAU"+[F:GAU]COD                         : # 71937
  Call EVAL_CHAR([M:DIA]GTE,"GTE",1,0,"",WSTAT) From CPTAUTO
Endif
#----- Traitement du journal -----#
Raz [M:DIA]JOU
If [M:DIA]TYP=1
  # Type de génération : Réelle
  # Init Type de pièce par évaluation de la pièce auto facture à émettre
  #Call LECTURE("GAU",[M:DIA]COD,"") From CONTOBJ               : # 71937
  Call EVAL_CHAR([M:DIA]JOU,"JOU",1,0,"",WSTAT) From CPTAUTO
Endif
If [M:DIA]JOU="" & GCURLEG<>"" & [M:DIA]GTE<>""                 : # 71937
  # Journal non renseigné : On le récupère du type de pièce
  # 71937 : Multilégislation
  #Call LECTURE("GTE",[M:DIA]GTE,"") From CONTOBJ
  Call LEC_GTE_LEG(GCURLEG,[M:DIA]GTE,WSTAT) From TRTLECLEG
  If WSTAT Raz [F:GTE] Endif
  # 71937
  [M:DIA]JOU=[F:GTE]DEFJOU
Endif
#----- Recherche du référentiel général principal pour le ctrl de la date
If [M]CPY<>""
    Call SETMAINREF([M]CPY,GTYPGEN,GTYPANA) From CPTDIV
Endif
If [M:DIA]CPY<>"" [M]LEG=GCURLEG Endif :   # 71937 : Multilégislation
Return

# 71937 : Multilégislation
######################################################################
$GRILEG
If func AFNC.ACTIV("LEG")=0 : # Dossier mono-législation
  Diszo [M:DIA]LEG
  [M:DIA]LEG=GDOSLEG(1)
  Affzo [M:DIA]LEG
Elsif [M:DIA]ALLCPY=1
  Diszo [M:DIA]LEG
Else
  Actzo [M:DIA]LEG
Endif
Return
# 71937

