#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion du fichier CONTTEMPL
Call OBJET ("COT", GBIDC1, GBIDC2) From GOBJET
End
##########################################################################################################

##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "LIENS"        : Gosub LIENS
    When "SETBOUT"      : Gosub SETBOUT
    When "RAZCRE"       : Gosub RAZCRE
    When "FERME"        : Gosub FERME
    When "INICRE"       : Gosub INICRE
    When "ABANDON"      : Gosub ABANDON
    When "VERF_ANU"     : Gosub VERF_ANU
    When "GRISE"        : Gosub GRISE
    When "VERIF_MOD"    : Gosub VERIF_MOD
    When "VERIF_CRE"    : Gosub VERIF_CRE
    When "APRES_CRE"    : Gosub APRES_CRE
    When "APRES_MOD"    : Gosub APRES_MOD
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "STATUT"       : Gosub STATUT
    When "FILTRE"       : Gosub FILTRE
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Char GCCOTCPT(GLONANM)    # Code compteur pour modèle de contrat de service

  #------------------------------------------------------------#
  # --> Récupération du code compteur                          #
  #------------------------------------------------------------#
  # ----------------------------------------------------------
  # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
  #  If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
  #  Read [TCA]TCA0=12
  #  If fstat Then
  #    GERR = 1
  #    GMESSAGE = mess(64,199,1)
  #    OK = 0
  #    Return
  #  Endif
  #  GMANCOU = [F:TCA]MANCOU(6)
  #  GCCOTCPT = [F:TCA]CODNUM(6)
  # FGR 20/12/2012 : X3SUIVI71937 (fin)
  GSOCIETE = ""
  GCURLEG = ""
  Call READ_COUNTER("", 12, 6, GSOCIETE, GCURLEG, GCCOTCPT, GMANCOU) From CRM_UTIL
  # ----------------------------------------------------------
Return

##########################################################################################################
$FERME
  Kill GCCOTCPT
Return

##########################################################################################################
$FILTRE
  If GFONCTION = "ADPVAL" Then
    # FGR 25/02/2009 : X3SUIVI26421 Si on vient ici de "Valeur de paramètre" pour DEFCOTCHX on filtre sur CONCAT=4
    If dim([M:ADWP]PARAM) > 0 Then
      If [M:ADWP]PARAM(nolign-1) = "DEFCOTCHX" Then
        FILTSUP = "CONCAT = 4"   # Uniquement les contrat à point
      Endif
    Endif
  Endif
Return

##########################################################################################################
$VERF_ANU
  If [M:COT0]CONNUM = GDEFCOTCHX Then
    #Ce modèle de contrat est utilisé par le paramètre DEFCOTCHX.
    GMESSAGE = mess(191,177,1)
    GERR = 2
    OK = 0
    Return
  Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  Filter [BPC] Where [F:BPC]COTCHX = [M:COT0]CONNUM
  For [BPC]
    #Ce modèle de contrat est utilisé par le client
    GMESSAGE = mess(190,177,1) - ": (" + [F:BPC]BPCNUM + ")" - [F:BPC]BPCNAM
    GERR = 2
    OK = 0
    Break
  Next
  Filter [BPC]
  If OK = 0 Then
    Return
  Endif
Return

##########################################################################################################
$LIENS
Local Integer I
Local Integer INBLIG
Local Char SZGAR

  INBLIG = 0
  SZGAR = ""
  #Gestion de la modification de la devise
  [M:COT0]OLDCUR = [M:COT0]CUR
  # Chargement du tableau des litiges acceptés
  For I = 0 To dim([F:COT]ACPDPTCOD)-1
    If [M:COT3]ACPDPTCOD(INBLIG) = "" Then
      Break
    Endif
    INBLIG += 1
  Next
  [M:COT3]NBDPT = INBLIG
  #Nouveaux champs V140
  If [M:COT2]RVAMET = 0 Then
    [M:COT2]RVAMET = 1
  Endif
  If [M:COT2]RVASSP = 0 Then
    [M:COT2]RVASSP = 1
  Endif
  If [M:COT3]INVMET = 0 Then
    [M:COT3]INVMET = 1
  Endif
  #Effectue le contrôle de grisage des champs
  Call SETGRAY From SUBCOTB
  [M:COT0]OLDCRSCOV = [M:COT1]CRSCOVSAM
  [M:COT0]OLDEVRMAC = [M:COT1]EVRMAC
  [M:COT0]OLDEVRPBL = [M:COT1]EVRPBL
Return

##########################################################################################################
$SETBOUT
  If REP = "" Then
    If [M:COT1]EVRMAC <> 2 Then
      CHMEN += "I"
    Endif
    If [M:COT1]EVRPBL <> 2 Then
      CHMEN += "G"
    Endif
    #Plan d'entretien
    If [M:COT1]CONCAT = 2 Then
      CHMEN += "O"
    Endif
  Endif
  CHMEN += "N"
  #----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
  Gosub SET_BOUT_SPE From GSAISIE
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return

##########################################################################################################
$RAZCRE
  #Initialise les valeurs par défaut de l'enregistrement
  [M:COT3]INVFRYCOE = 1
  [M:COT1]CONCAT = 1
  #Par défaut les modèles procurent des contrats Toutes compétences et tous produits.
  [M:COT1]EVRPBL = 2
  [M:COT1]EVRMAC = 2
  #Initialise la devise par défaut
  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
  [M:COT0]OLDCUR = ""
  Read [TCY]TCY0=GPAYS
  If fstat Then
    [M:COT0]CUR = ""
  Else
    [M:COT0]CUR = [F:TCY]CUR
  Endif
  #Effectue le contrôle de grisage des champs
  Call SETGRAY From SUBCOTB
  [M:COT0]OLDCRSCOV = [M:COT1]CRSCOVSAM
  [M:COT0]OLDEVRMAC = [M:COT1]EVRMAC
  [M:COT0]OLDEVRPBL = [M:COT1]EVRPBL
  Affzo [M:COT0]1-99
  Affzo [M:COT1]1-99
  Affzo [M:COT2]1-99
  Affzo [M:COT3]1-99
Return

##########################################################################################################
$INICRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  # Récupération du compteur de contrat de service.
  If func CRM_UTIL.GET_NUMERO_CHRONO ("HDK", "", GCCOTCPT, date$, "", [M:COT0]CONNUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
    If IBRETOUR = 1 Then
      [F:COT]CONNUM = [M:COT0]CONNUM
      Affzo [M:COT0]CONNUM
    Else
      # problème lors de la récupération du compteur
      GERR = 1
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GOK = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$GRISE
Return

##########################################################################################################
$VERIF_CRE_MOD
  #LSE 05/09/2005 FQ32402
  #Les familles statistiques sont-elles obligatoires
Local Integer ITERSTT

  If GCONTSIOBY = 2 Then
    For ITERSTT = 0 To dim([M:COT1]CONTYP)-1
      If [M:COT1]CONTYP(ITERSTT) = "" Then
        #Les familles statistiques d'un modèle de contrat de service doivent être renseignées.
        GMESSAGE = mess(188,177,1)
        GERR = 2
        OK = 0
        Break
      Endif
    Next
    If OK = 0 Then
      Return
    Endif
  Endif
  #Vérifie si une fréquence de renouvellement a été renseignée
  If [M:COT2]REWFRY < 1 Then
    If ACTION = "VERIF_CRE" Then
      GMESSAGE = mess(452,196,1) #Aucune fréquence de renouvellement n'a été saisie. Création refusée.
    Else
      GMESSAGE = mess(453,196,1) #Aucune fréquence de renouvellement n'a été saisie. Création refusée.
    Endif
    GERR = 2
    OK = 0
    Return
  Endif
  If [M:COT2]REWFRY > 0 Then
    If [M:COT2]REWFRYBAS = 6 Then
      #Aucune base de fréquence de renouvellement n'a été saisie. Création refusée.
      If ACTION = "VERIF_CRE" Then
        GMESSAGE = mess(641,182,1)
      Else
        GMESSAGE = mess(642,182,1)
      Endif
      GERR = 2
      OK = 0
      Return
    Endif
  Endif
  #Vérifie si la durée du contrat est supérieure à une journée
  If [M:COT2]REWFRYBAS = 2 Then
    If [M:COT2]REWFRY <= 1 Then
      #La fréquence de renouvellement du contrat doit être supérieure à une journée.
      GMESSAGE = mess(60,177,1)
      GERR = 2
      OK = 0
      Return
    Endif
  Endif
  #LSE 05/10/2005 FQ32413
  #Vérifie si une fréquence de facturation a été renseignée pour un contart de maintenace
  If [M:COT1]CONCAT = 3 Then
    If [M:COT3]INVFRY < 1 Then
      #Aucune fréquence de facturation n'a été saisie. Création refusée.
      GMESSAGE = mess(639,182,1)
      GERR = 2
      OK = 0
      Return
    Endif
  Endif
  #Vérifie la durée de la fréquence de facturation a été renseignée
  If [M:COT1]CONCAT > 1 Then
    If [M:COT1]CONCAT < 4 Then
      If [M:COT3]INVFRYBAS = 2 Then
        If [M:COT3]INVFRY <= 1 Then
          #La fréquence de facturation du contrat doit être supérieure à une journée.
          GMESSAGE = mess(61,177,1)
          GERR = 2
          OK = 0
          Return
        Endif
      Endif
    Endif
  Endif
  #Vérifie la durée de la fréquence de réévaluation a été renseignée
  If [M:COT1]CONCAT > 1 Then
    If [M:COT1]CONCAT < 4 Then
      If [M:COT2]RVAFRYBAS = 2 Then
        If [M:COT2]RVAFRY <= 1 Then
          #La fréquence de réévaluation du contrat doit être supérieure à une journée.
          GMESSAGE = mess(62,177,1)
          GERR = 2
          OK = 0
          Return
        Endif
      Endif
    Endif
  Endif
  #Vérifie la saisie des réévaluations
  If [M:COT1]CONCAT > 1 Then
    If [M:COT1]CONCAT < 4 Then
      If [M:COT2]RVAFRY > 0 Then
        If [M:COT2]RVAFRYBAS > 1 Then
          If [M:COT2]RVAFRYBAS < 6 Then
            If [M:COT2]RVASSP = 1 Then
              If [M:COT2]CONBASIDX = "" Then
                #Aucun indice n'a été précisé pour la réévaluation du contrat.
                GMESSAGE = mess(63,177,1)
                GERR = 2
                OK = 0
                Return
              Endif
            Endif
            If [M:COT2]RVASSP = 2 Then
              If [M:COT2]CONBASFOR = "" Then
                #Aucune formule n'a été précisée pour la réévaluation du contrat.
                GMESSAGE = mess(64,177,1)
                GERR = 2
                OK = 0
                Return
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
  #Vérifie si des points ont été crédités
  If [M:COT1]CONCAT = 4 Then
    If [M:COT2]PITCDT <= 0 Then
      #Aucun point n'a été crédité sur ce modèle de contrat. Création refusée.
      If ACTION = "VERIF_CRE" Then
        GMESSAGE = mess(193,177,1)
      Else
        GMESSAGE = mess(192,177,1)
      Endif
      GERR = 2
      OK = 0
      Return
    Endif
  Endif
  #Vérifie si la fréquence de facturation n'est pas supérieure à la fréquence de renouvellement.
  Gosub CHECKREWINV From SUBCOTB
  If !OK Then
    Return
  Endif
  #Renseigne la catégorie en clair
  [M:COT1]CONTYPCLA = mess([M:COT1]CONCAT,2976,1)
  #Les contrat à point sont toujours toutes compétences et tous articles
  If [M:COT1]CONCAT = 4 Then
    [M:COT1]EVRPBL = 2
    [M:COT1]EVRMAC = 2
  Endif
Return

##########################################################################################################
$VERIF_CRE
  Gosub VERIF_CRE_MOD
  If !OK Then
    Return
  Endif
Return

##########################################################################################################
$VERIF_MOD
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer IASKCRS

  Gosub VERIF_CRE_MOD
  If !OK Then
    Return
  Endif
  #Gestion de la modification de la couverture parc
  IASKCRS = 0
  If [M:COT0]OLDEVRMAC <> [M:COT1]EVRMAC Then
    If [M:COT1]EVRMAC = 2 Then
      If GIMPORT Then
        IASKCRS = 2
      Else
        #Confirmez-vous la suppression de toutes les descriptions de couverture relatives au parc client.
        Call OUINON(mess(434,182,1), IASKCRS) From GESECRAN
      Endif
      If IASKCRS = 2 Then
        #Vide le tableau de couverture article si le contrat devient de type "Toutes compétences"
        Call RAZPCOV("COT", [M:COT0]CONNUM, IERRINF, ICHAPTER, IBRETOUR) From TRTCONH
        If IBRETOUR = 0 Then
          GMESSAGE = mess(IERRINF,ICHAPTER,1)
          GERR = 1
          Return
        Endif
      Else
        OK = 0
        Return
      Endif
    Endif
  Endif
  #Gestion de la modification de la couverture compétence
  IASKCRS = 0
  If [M:COT0]OLDEVRPBL <> [M:COT1]EVRPBL Then
    If [M:COT1]EVRPBL = 2 Then
      If GIMPORT Then
        IASKCRS = 2
      Else
        #Confirmez-vous la suppression de toutes les descriptions de couverture relatives aux familles de compétence.
        Call OUINON(mess(435,182,1), IASKCRS) From GESECRAN
      Endif
      If IASKCRS = 2 Then
        #Vide le tableau des familles de compétences si le contrat devient de type "Toutes compétences"
        Call RAZPBL("COT", [M:COT0]CONNUM, IERRINF, ICHAPTER, IBRETOUR) From TRTCONH
        If IBRETOUR = 0 Then
          GMESSAGE = mess(IERRINF,ICHAPTER,1)
          GERR = 1
          Return
        Endif
      Else
        OK = 0
        Return
      Endif
    Endif
  Endif
  #Gestion de la couverture croisée identique.
  IASKCRS = 0
  If [M:COT0]OLDCRSCOV <> [M:COT1]CRSCOVSAM Then
    If [M:COT1]EVRMAC <> 2 Then
      If [M:COT1]CRSCOVSAM = 2 Then
        If GIMPORT Then
          IASKCRS = 2
        Else
          #Confirmez-vous la définition de toutes les couvertures croisées sur la base de la couverture du parc.
          Call OUINON(mess(433,182,1), IASKCRS) From GESECRAN
        Endif
        If IASKCRS = 2 Then
          IASKCRS = 0
          Call DOCRSCOVSAM([M:COT0]CONNUM, "", 2, IASKCRS) From TRTCONH
          If IASKCRS Then
            #Erreur lors de l'enregistrement de la couverture croisée à l'identique.
            GMESSAGE = mess(432,182,1)
            GERR = 1
          Endif
        Else
          OK = 0
          Return
        Endif
      Endif
    Endif
  Endif
Return

##########################################################################################################
$APRES_CRE
  [M:COT0]OLDCUR = [M:COT0]CUR
  [M:COT0]OLDCRSCOV = [M:COT1]CRSCOVSAM
  [M:COT0]OLDEVRMAC = [M:COT1]EVRMAC
  [M:COT0]OLDEVRPBL = [M:COT1]EVRPBL
Return

##########################################################################################################
$APRES_MOD
  #Gère la modification de la devise du modèle contrat
  Call MNGCOTCURCHG From SUBCOTB
  [M:COT0]OLDCUR = [M:COT0]CUR
  [M:COT0]OLDCRSCOV = [M:COT1]CRSCOVSAM
  [M:COT0]OLDEVRMAC = [M:COT1]EVRMAC
  [M:COT0]OLDEVRPBL = [M:COT1]EVRPBL
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$STATUT
Return

##########################################################################################################
Subprog AM_REWFRY(VALEUR)
Variable Decimal VALEUR

  #Active ou désactive le champs unité de la fréquence de renouvellement
  If VALEUR > 0 Then
    If [M:COT2]REWFRYBAS = 6 Then
      [M:COT2]REWFRYBAS = 2
    Endif
    Actzo [M:COT2]REWFRYBAS
  Else
    [M:COT2]REWFRYBAS = 6
    Grizo [M:COT2]REWFRYBAS
  Endif
  #Obligatoire pour que ca marche
  [M:COT2]REWFRY = VALEUR
  Affzo [M:COT2]REWFRY, REWFRYBAS
End

##########################################################################################################
Subprog AM_INVFRY(VALEUR)
Variable Decimal VALEUR

  If VALEUR > 0 Then
    If [M:COT3]INVFRYBAS = 6 Then
      [M:COT3]INVFRYBAS = 2
    Endif
    Actzo [M:COT3]INVFRYBAS
  Else
    [M:COT3]INVFRYBAS = 6
    Grizo [M:COT3]INVFRYBAS
  Endif
  [M:COT3]INVFRY = VALEUR
  Affzo [M:COT3]INVFRY, INVFRYBAS
End

##########################################################################################################
Subprog AM_INVLTI(VALEUR)
Variable Decimal VALEUR

  If VALEUR > 0 Then
    If [M:COT3]INVLTIBAS= 6 Then
      [M:COT3]INVLTIBAS = 2
    Endif
    Actzo [M:COT3]INVLTIBAS
  Else
    [M:COT3]INVLTIBAS = 6
    Grizo [M:COT3]INVLTIBAS
  Endif
  [M:COT3]INVLTI = VALEUR
  Affzo [M:COT3]INVLTI, INVLTIBAS
End

##########################################################################################################
Subprog AM_RVAFRY(VALEUR)
Variable Decimal VALEUR

  If VALEUR > 0 Then
    If [M:COT2]RVAFRYBAS = 6 Then
      [M:COT2]RVAFRYBAS = 2
    Endif
    Actzo [M:COT2]RVAFRYBAS
    Actzo [M:COT2]RVAMET
    Actzo [M:COT2]RVASSP
    If [M:COT2]RVASSP = 1 Then
      Actzo [M:COT2]CONBASIDX
      Grizo [M:COT2]CONBASFOR
    Elsif [M:COT2]RVASSP = 1
      Grizo [M:COT2]CONBASIDX
      Actzo [M:COT2]CONBASFOR
    Else
      Grizo [M:COT2]CONBASIDX
      Grizo [M:COT2]CONBASFOR
    Endif
  Else
    [M:COT2]RVAFRYBAS = 6
    [M:COT2]CONBASIDX = ""
    [M:COT2]CONBASFOR = ""
    Grizo [M:COT2]RVAFRYBAS
    Grizo [M:COT2]RVAMET
    Grizo [M:COT2]RVASSP
    Grizo [M:COT2]CONBASIDX
    Grizo [M:COT2]CONBASFOR
  Endif
  [M:COT2]RVAFRY = VALEUR
  Affzo [M:COT2]1-99
End

##########################################################################################################
Subprog AM_RSILTI(VALEUR)
Variable Decimal VALEUR

  If VALEUR > 0 Then
    If [M:COT2]RSILTIBAS = 6 Then
      [M:COT2]RSILTIBAS = 2
    Endif
    Actzo [M:COT2]RSILTIBAS
  Else
    [M:COT2]RSILTIBAS = 6
    Grizo [M:COT2]RSILTIBAS
  Endif
  Affzo [M:COT2]RSILTIBAS
  [M:COT2]RSILTI = VALEUR
  Affzo [M:COT2]RSILTI
End

##########################################################################################################
Subprog AM_EVRMAC(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    [M:COT1]CRSCOVSAM = 2
    Grizo [M:COT1]CRSCOVSAM
  Else
    [M:COT1]CRSCOVSAM = 1
    Actzo [M:COT1]CRSCOVSAM
  Endif
  [M:COT1]EVRMAC = VALEUR
  Affzo [M:COT1]1-99
End

##########################################################################################################
Subprog C_ACPDPTCOD(VALEUR)
Variable Char    VALEUR()

Local Integer I

  If VALEUR = "" Then
    mkstat = 2
    End
  Endif
  #Vérifie si ce code litige n'a pas déjà été préalablement saisi dans ce tableau
  For I = 0 To dim ([M:COT3]ACPDPTCOD)-1
    If I <> nolign-1 Then
      If [M:COT3]ACPDPTCOD(I) = VALEUR and [M:COT3]ACPDPTCOD(I) <> "" Then
        VALEUR = ""
        mkstat = 2
        GMESSAGE = mess(437,196,1) #Ce code litige a déjà été saisi.
        GERR = 2
      Endif
    Endif
  Next
End

##########################################################################################################
Subprog AM_CONCAT(VALEUR)
Variable Integer VALEUR

  [M:COT1]CONCAT = VALEUR
  If VALEUR = 4 Then
    [M:COT1]EVRMAC = 2
    [M:COT1]EVRPBL = 2
    [M:COT1]CRSCOVSAM = 2
  Endif
  #Effectue le contrôle de grisage des champs
  Call SETGRAY From SUBCOTB
End

##########################################################################################################
Subprog C_PITTOL(VALEUR)
Variable Decimal VALEUR

  If VALEUR > 100 Then
    #Ce pourcentage ne peut être supérieur à 100. Saisie refusée
    GMESSAGE = mess(279,182,1)
    GERR = 1
    mkstat = 2
  Endif
  If VALEUR < 0 Then
    #Ce pourcentage ne peut être négatif. Saisie refusée.
    GMESSAGE = mess(344,182,1)
    GERR = 1
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog AM_RVASSP(VALEUR)
Variable Integer VALEUR

  [M:COT2]CONBASIDX = ""
  [M:COT2]CONBASFOR = ""
  If VALEUR = 1 Then
    Actzo [M:COT2]CONBASIDX
    Grizo [M:COT2]CONBASFOR
  Elsif VALEUR = 2 Then
    Grizo [M:COT2]CONBASIDX
    Actzo [M:COT2]CONBASFOR
  Else
    Grizo [M:COT2]CONBASIDX
    Grizo [M:COT2]CONBASFOR
  Endif
  [M:COT2]RVASSP = VALEUR
  Affzo [M:COT2]RVASSP, CONBASIDX, CONBASFOR
End

##########################################################################################################
Subprog AS_CONCAT(VALEUR)
Variable Integer VALEUR

  # FGR 09/07/2009 : X3SUIVI56412 : retiré aussi de la V6
  Raz GMENLOC
  GMENLOC(2) = 1
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") <> 2 Then
    # FGR 29/01/2009 : X3SUIVI41698 : Si code activité "PIT" non positionné on n'a pas le droit à "A points"
    GMENLOC(4) = 1
  Endif
End

##########################################################################################################
Subprog AM_CONREW(VALEUR)
Variable Integer VALEUR

  [M:COT2]CONREW = VALEUR
  Call SETTZN From SUBCOTB
  Affzo [M:COT2]1-99
End

##########################################################################################################
Subprog AS_REWFRYBAS(VALEUR)
Variable Integer VALEUR

  GMENLOC(1) = 1
End

##########################################################################################################
Subprog AS_RVAFRYBAS(VALEUR)
Variable Integer VALEUR

  GMENLOC(1) = 1
End

##########################################################################################################
Subprog AS_INVFRYBAS(VALEUR)
Variable Integer VALEUR

  GMENLOC(1) = 1
End

##########################################################################################################
Subprog AS_INVLTIBAS(VALEUR)
Variable Integer VALEUR

  GMENLOC(1) = 1
End
