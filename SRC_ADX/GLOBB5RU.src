$CAL_DOT_PER_CR
      WDOTPER = 0.
      WEXCPER = 0.
      If ( [M:DIV]DTDBAMTREG < [F:DEPC]PERENDDAT ) Then
        If ( [M:DIV]DATSORREG = [0/0/0] or [M:DIV]DATSORREG >= [F:DEPC]PERENDDAT ) Then
          Local Integer I_P
          I_P = find([F:DEPC]PERENDDAT, [M:DIV2]PERENDDAT)
          WDOTPER = [M:DIV2]DOT1AP(I_P-1) - PCUMP_1
        Endif
      Endif
Return
$CAL_DOT_PER_LR
      Local Decimal WDOTSUP
      If ([M:DIV]BBONUS) Then : WDOTSUP = [M:DIV]DOTSUP : Else : WDOTSUP = 0. : Endif
      WEXCPER = 0.
      WDOTPER = 0.
      WDTDBAMT = [M:DIV]DTDBAMTREG
      Local Char STYPPRODAT : STYPPRODAT = ""
      If ([M:DIV]TYPPRODAT = "T" ) Then
        STYPPRODAT = [M:DIV]TYPPRODAT
        [M:DIV]TYPPRODAT = "M"
      Endif
      Local Integer L_SESFLG
      L_SESFLG = val(mid$([F:WFAS]KSESFLG, [F:DEPC]DPRPLN, 1))
      [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNPER : [M:DIV]PD(2)= [M:DIV]DATNUL
      [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNAMT
      [M:DIV]PD(6)= [M:DIV]DATSORREG : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      [M:DIV]PC(1)= [M:DIV]PSEPLN    : [M:DIV]PE(0)= L_SESFLG
      Gosub GSB_KRU_DUR_DET From   GLOBB4RU
      WDURDET = [M:DIV]RV(1)
      [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNEXE : [M:DIV]PD(2)= [M:DIV]DATNUL
      [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNAMT
      [M:DIV]PD(6)= [M:DIV]DATSORREG : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
      [M:DIV]PC(1)= [M:DIV]PSEPLN    : [M:DIV]PE(0)= L_SESFLG
      Gosub GSB_KRU_DUR_DET From   GLOBB4RU
      WDETEXE = [M:DIV]RV(1)
      If ( STYPPRODAT <> "" ) Then : [M:DIV]TYPPRODAT = STYPPRODAT : Endif
      If (WDETEXE = 0 ) Then
        WDOTPER = 0.
        WDOTPER = PDOTEXE - PCUMP_1
      Else
        If ( abs(PCUMP_1) >= abs(PDOTEXE) ) Then
          WDOTPER    = PDOTEXE - PCUMP_1
        Else
          If ( [M:DIV]PSEPLN <> "" and L_SESFLG = G_OUI) Then
            If ( [F:PSE]ACTFLG(month([F:DEPC]PERSTRDAT)-1) <> G_OUI ) Then
               WDOTPERCUM = PCUMP_1
            Else
              Local Decimal LMNTREF
              LMNTREF = PMNTREF - WDOTSUP
              WDOTPERCUM = [M:DIV]DOTPSE * WDURDET
              [M:DIV]PV(0)= WDOTPERCUM : [M:DIV]PC(0)= [M:DIV]CUR
              Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : WDOTPERCUM = [M:DIV]RV(1)
              If ( [M:DIV]DATSORREG <> [0/0/0] ) Then
                If ( [M:DIV]DATSORREG > [M:DEP]PERENDDAT([M:DIV]DPC-1) ) Then
                  If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DATSORREG,[F:DEPC]PERSTRDAT,[F:DEPC]PERENDDAT,"I") ) Then
                    WDOTPERCUM = WDOTPERCUM + WDOTSUP
                  Endif
                Else
                  If ( [F:DEPC]PERENDDAT = [M:DEP]PERENDDAT([M:DIV]DPC-1) ) Then
                    WDOTPERCUM = WDOTPERCUM + WDOTSUP
                  Endif
                Endif
              Endif
              If ( abs(WDOTPERCUM) > abs(PMNTREF) ) Then : WDOTPERCUM = PMNTREF : Endif
              If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT,[F:DEPC]PERSTRDAT,[F:DEPC]PERENDDAT,"I") ) Then
                WDOTPERCUM = PMNTREF
              Endif
            Endif
          Else
            Local Decimal LMNTREF
            LMNTREF = PMNTREF - WDOTSUP
            WDOTPERCUM = ( [M:DIV]DOTPSE * WDURDET )
            [M:DIV]PV(0)= WDOTPERCUM : [M:DIV]PC(0)= [M:DIV]CUR
            Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : WDOTPERCUM = [M:DIV]RV(1)
            If ( [M:DIV]DATSORREG <> [0/0/0] ) Then
              If ( [M:DIV]DATSORREG > [M:DEP]PERENDDAT([M:DIV]DPC-1) ) Then
                If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DATSORREG,[F:DEPC]PERSTRDAT,[F:DEPC]PERENDDAT,"I") ) Then
                  WDOTPERCUM = WDOTPERCUM + WDOTSUP
                Endif
              Else
                If ( [F:DEPC]PERENDDAT = [M:DEP]PERENDDAT([M:DIV]DPC-1) ) Then
                  WDOTPERCUM = WDOTPERCUM + WDOTSUP
                Endif
              Endif
            Endif
            If ( abs(WDOTPERCUM) > abs(PMNTREF) ) Then : WDOTPERCUM = PMNTREF : Endif
            If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT,[F:DEPC]PERSTRDAT,[F:DEPC]PERENDDAT,"I") ) Then : WDOTPERCUM = PMNTREF : Endif
          Endif
          WDOTPER    = WDOTPERCUM - PCUMP_1
        Endif
      Endif
Return
$CAL_DOT_PER_SR
      Local Date     WDTDB2
      Local Decimal  WDOTPER1, WDOTPER2, WDURDET, WDUREXE, WDURRES
      If ( [M:DIV]CNT = G300CPFI and find([F:DEPC]KSTPDEPSTA, GVML_SSNOSTP, GVML_SSMORST,  GVML_SSCORST) = 0 ) Then
        WDOTPER = PDOTEXE - PCUMP_1
      Else
        WDTDBAMT = [M:DIV]DTDBAMTREG
        [M:DIV]PD(0)= [M:DIV]EXEDATREF : [M:DIV]PD(1)= [M:DIV]DTFNPER : [M:DIV]PD(2)= [M:DIV]DATNUL
        [M:DIV]PD(3)= [M:DIV]DTFN1 : [M:DIV]PD(4)= WDTDBAMT : [M:DIV]PD(5)= [M:DIV]DTFNAMT
        [M:DIV]PD(6)= [M:DIV]DATSORREG : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
        Gosub GSB_KRU_DUR_DET From   GLOBB4RU
        WDURDET = [M:DIV]RV(1)
        Call CAL_DUR_EXE_REF ([M:DIV]DTDBEXE, [M:DIV]DTFNEXE, [M:DIV]TYPPRO, WDUREXE) From   GLOBB8
        WDOTPER1 = ( [M:DIV]VALAMT * [M:DIV]TXAMT1 * (WDURDET / WDUREXE) )
        [M:DIV]PV(0)= WDOTPER1 : [M:DIV]PC(0)= [M:DIV]CUR
        Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : WDOTPER1 = [M:DIV]RV(1)
        WDTDB2 = func GLOBB9.CAL_DAT_PLUS( [M:DIV]DTFN1,  1, "D" )
        [M:DIV]PD(0)= WDTDB2 : [M:DIV]PD(1)= [M:DIV]DTFNPER : [M:DIV]PD(2)= [M:DIV]DATNUL
        [M:DIV]PD(3)= [M:DIV]DATNUL : [M:DIV]PD(4)= [M:DIV]DATNUL: [M:DIV]PD(5)= [M:DIV]DTFNAMT
        [M:DIV]PD(6)= [M:DIV]DATSORREG : [M:DIV]PD(7)= [M:DIV]DETVTEDAT : [M:DIV]PC(0)= [M:DIV]TYPPRODAT
        Gosub GSB_KRU_DUR_DET From   GLOBB4RU
        WDURDET = [M:DIV]RV(1)
        If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT, [M:DIV]DTDBEXE, [M:DIV]DTFNEXE,"I") ) Then
          Call  CAL_DUR_REST_AMT
&              ([M:DIV]DTDBAMTREG, WDTDB2, [M:DIV]DTFNAMT, [M:DIV]TYPPRODAT, WDURRES) From   GLOBB8
          If ( WDURRES <> 0 ) Then
            WDOTPER2 = ( ( PDOTEXE - WDOTPER1)  * (WDURDET / WDURRES) )
          Endif
        Else
          WDOTPER2 = ( [M:DIV]VALAMT * [M:DIV]TXAMT2 *(WDURDET / WDUREXE) )
        Endif
        [M:DIV]PV(0)= WDOTPER2 : [M:DIV]PC(0)= [M:DIV]CUR
        Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : WDOTPER2 = [M:DIV]RV(1)
        If ( abs(WDOTPER1 + WDOTPER2) > abs(PDOTEXE) ) Then
          WDOTPER = PDOTEXE - PCUMP_1
        Else
          WDOTPER = ( WDOTPER1 + WDOTPER2 ) - PCUMP_1
        Endif
        If ( func GLOBB9.CAL_DAT_INSIDE([M:DIV]DTFNAMT,[M:DIV]DTDBPER,[M:DIV]DTFNPER,"I") ) Then
          WDOTPER = PDOTEXE - PCUMP_1
        Endif
      Endif
Return
$CAL_DOT_PER_UR
      If ( [M:DIV]DTFNPPL <> [0/0/0] and [M:DIV]DTFNPPL < [M:DIV]DTDBAMTREG ) Then
        [F:DEPC]PERQTY = 0
        [F:DEPC]RSDQTY = 0
        RDOTPER = 0.
        REXCPER = 0.
        End
      Endif
      Local Integer WIPC
      Local Integer WIPN
      Local Integer WIFNE
      Local Decimal WUOAREP
      Local Decimal WUOPCUM
      WIPC   = find([M:DIV]PERDATREF, [M:PPL]PERSTRDAT)
      WIPN   = find([F:DEPC]PERENDDAT, [M:PPL]PERENDDAT)
      WIFNE  = find([F:DEPC]FIYENDDAT, [M:PPL]PERENDDAT)
      If ([M:PPL]IPSO) Then
        WUOAREP   = sum([M:PPL]PERQTY(WIPC-1..min([M:PPL]IPSO, WIFNE,[M:PPL]IFNA)-1))
      Else
        WUOAREP   = sum([M:PPL]PERQTY(WIPC-1..min(WIFNE,[M:PPL]IFNA)-1))
      Endif
      WUOPCUM    = sum([M:PPL]PERQTY(WIPC-1..WIPN-1))
      [F:DEPC]PERQTY = [M:PPL]PERQTY(WIPN-1)                      : # UO périodes
      [F:DEPC]RSDQTY = sum([M:PPL]PERQTY(WIPN-1..[M:PPL]IFNA-1))  : # UO résiduelle periode n
      If ( WUOAREP = 0 ) Then
        WDOTPER = 0.
        WEXCPER = 0.
        If ( [M:DIV]BSRA ) Then
           If ( abs(PCUMP_1) >= abs(PDOTEXE) ) Then : WDOTPER    = PDOTEXE - PCUMP_1  : Endif
        Else
           WDOTPER = PDOTEXE - PCUMP_1
        Endif
      Else
        If ( abs(PCUMP_1) >= abs(PDOTEXE) ) Then
          WDOTPER    = PDOTEXE - PCUMP_1
        Else
          WDOTPERCUM = ( PMNTREF * (WUOPCUM / WUOAREP) )
          [M:DIV]PV(0)= WDOTPERCUM : [M:DIV]PC(0)= [M:DIV]CUR
          Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : WDOTPERCUM = [M:DIV]RV(1)
          WDOTPER    = WDOTPERCUM - PCUMP_1
        Endif
        If ( PAMTEXC <> 0 ) Then
          If ( abs(PEXCP_1) >= abs(PAMTEXC) ) Then
            WEXCPER = 0
          Else
          WDOTEXCCUM = ( PAMTEXC * (WUOPCUM / WUOAREP) )
          [M:DIV]PV(0)= WDOTEXCCUM : [M:DIV]PC(0)= [M:DIV]CUR
          Gosub GSB_CAL_ARRONDI_MNT From   GLOBB8 : WDOTEXCCUM = [M:DIV]RV(1)
          WEXCPER    = WDOTEXCCUM - PEXCP_1
          Endif
        Endif
      Endif
Return
$CAL_DOT_PER_DR
      WDOTPER = 0.
      WEXCPER = 0.
  If ( [F:DEPC]FIYSTRDAT = [F:DEPC]PERSTRDAT and [F:DEPC]FIYENDDAT = [F:DEPC]PERENDDAT ) Then
    WDOTPER = [M:DIV]DOTEXE
  Else
      If ( [M:DIV]DTDBAMTREG < [F:DEPC]PERENDDAT ) Then
        If ( [M:DIV]DATSORREG = [0/0/0] or [M:DIV]DATSORREG >= [F:DEPC]PERENDDAT ) Then
          Local Integer I_P
          I_P = find([F:DEPC]PERENDDAT, [M:DIV2]PERENDDAT)
          WDOTPER         = [M:DIV2]DOT1AP(I_P-1) - PCUMP_1
          [F:DEPC]KBIRNBV = [M:DIV2]BIRNBV(I_P-1)
        Endif
      Endif
  Endif
Return
