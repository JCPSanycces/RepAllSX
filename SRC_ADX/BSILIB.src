#**
#* Check if facility belongs to company
#*!
$CHECK_FCY_VS_CPY
    If this.CPY = "" or this.FCY = ""
        Return
    Endif

    Local File FACILITY [FCY]

    # Delete errormessages
    If CURPRO = "CPY"
        ASTATUS = fmet this.ADELETEERROR( "FCY" )
    Else
        ASTATUS = fmet this.ADELETEERROR( "CPY" )
    Endif

    # Check if facility belongs to company
    Read [FCY]FCY1 = this.CPY;this.FCY

    # If not....errormessage
    If fstat
        ASTATUS = fmet this.ASETERROR( CURPRO, mess(413,107,1), [V]CST_AERROR ) # 'Site not associated with the company'
    Endif

    LogicClose File [FCY]
Return



#**
#* Check if bank maches company (and in case facility, too)
#*!
$CHECK_BAN_VS_CPY_FCY
    If this.CPY = "" or this.BAN = ""
        Return
    Endif

    Local File BANK [BAN]

    If [F:BAN]BAN <> this.BAN
        Read [F:BAN]BAN0 = this.BAN
        If fstat
            ASTATUS = fmet this.ASETERROR( "BAN", this.BAN - mess(23,100,1), [V]CST_AERROR ) # 'Record does not exist'
            Return
        Endif
    Endif

    If [F:BAN]CPY <> this.CPY
            ASTATUS = fmet this.ASETERROR( "BAN", mess(12,117,1), [V]CST_AERROR ) # 'Bank account not held by company'
        Return
    Endif

    If ( [F:BAN]FCY <> "" )
&      and ( dim( this.FCY ) > 0 )
&      and  ( [F:BAN]FCY <> this.FCY )
        ASTATUS = fmet this.ASETERROR( "BAN", mess(43,121,1) - [F:BAN]FCY, [V]CST_AERROR ) # "This bank belongs to the site"
        Return
    Endif

    LogicClose File [BAN]
Return



#**
#* Evaluate a volume based path and check if this is an existing directory.
#*!
$CHECK_VOLUME_PATH
    Local Char VOLPATH(255)  : VOLPATH = evalue( "this." + [L]CURPRO ) #Assign "this." + [L]CURPRO  With VOLPATH
    Local Char REALPATH(255) : Raz REALPATH
    Local Char ERRMSG(255)   : Raz ERRMSG

    If VOLPATH = ""
        Return
    Endif

    Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
    If func ASYRSTO.CTL_VOLFIL( 2, VOLPATH, REALPATH, E_TYPE_FOLDER, ERRMSG )
        ASTATUS = fmet this.ASETERROR( [L]CURPRO, ERRMSG, [V]CST_AERROR )
    Endif
Return


#**
#* Check if import number definition is set for a company
#*!
$CHECK_INVNUM_DEF
  If this.INVNUM = CST_AYES
    Local File BSIINVDIO    [BSIIND]
    Read [F:BSIIND]BSIIND0(1) = this.CPY
    If fstat
      ASTATUS = fmet this.ASETERROR( CURPRO, mess(65,7703,1), [V]CST_AWARNING ) # 'Definition of BP number not set up yet for this company.'
    Endif
    LogicClose File [BSIIND]
  Endif
Return

#**
#* Check if BP number definition is set for a company
#*!
$CHECK_BPRNUM_DEF
  If this.BPRNUM = CST_AYES
    Local File BSIBPRNUM    [BSIBPN]
    Read [BSIBPN]BSIBPN0(1) = this.CPY
    If fstat
      ASTATUS = fmet this.ASETERROR( CURPRO,mess(64,7703,1), [V]CST_AWARNING ) # 'Definition of Invoice number not set up yet for this company.'
    Endif
    LogicClose File [BSIBPN]
  Endif
Return

############################################################################################################################
# Helpers for import
############################################################################################################################

#**
#* Check amount direction of importfield for SNS
#*!
Funprog CHK_SNS(SNSFIELD)
Value Char SNSFIELD
Local Char CHECKEDSNSFIELD(3)
Local Integer CURRSIGN

For C = 1 To len(SNSFIELD)
  [L]CURRSIGN = ascii(mid$( SNSFIELD,C,1))
  If CURRSIGN>=65 and CURRSIGN<=90 Then
     CHECKEDSNSFIELD = CHECKEDSNSFIELD + mid$( SNSFIELD,C,1)
     If C = 1 & toupper(mid$( SNSFIELD,C,1))<>"R"
        Break
     Endif
  Endif
Next

End CHECKEDSNSFIELD


#**
#* Extraxt amount from string field of import file
#*!
Funprog CONV_MNT(AMOUNTFIELD)
Value Char AMOUNTFIELD
Local Char AMOUNTFIELD1(30),AMOUNTFIELD2(30)
Local Integer CURRSIGN
Dbgaff
If instr(1,AMOUNTFIELD,",") <> 0 Then
   If right$(AMOUNTFIELD,len(AMOUNTFIELD)) = "," or right$(AMOUNTFIELD,len(AMOUNTFIELD)) = "."
      AMOUNTFIELD1 = left$(AMOUNTFIELD, instr(1,AMOUNTFIELD,",")-1)
   Else
      AMOUNTFIELD1 = left$(AMOUNTFIELD, instr(1,AMOUNTFIELD,",")-1)+"."+right$(AMOUNTFIELD,instr(1,AMOUNTFIELD,",")+1 )
   Endif
Else
   AMOUNTFIELD1 = AMOUNTFIELD
Endif

For C = 1 To len(AMOUNTFIELD1)
  CURRSIGN = ascii(mid$( AMOUNTFIELD1,C,1))
  If ((CURRSIGN>=48 and CURRSIGN<=57) or CURRSIGN=44 or CURRSIGN=46 ) Then
      AMOUNTFIELD2 = AMOUNTFIELD2 + mid$( AMOUNTFIELD1,C,1)
  Else
   If C>2
     Break
   Endif
  Endif
Next
#XMNT1 = XMNT2
End AMOUNTFIELD2

