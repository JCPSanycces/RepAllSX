#<AdxTL>@(#)12.0.0.0 $Revision$
######################################################################################
## Xtend:  Gestion champs entité
## Actions
#  Version 0001
######################################################################################
$ACTION
#Infbox "Code Action:"-GACTION-"Etiq:"-ACTION 
Case ACTION
 When "OUVRE"            : Gosub OUVRE
 When "DEBUT"            : Gosub DEBUT
 When "TITRE"            : Gosub TITR
 When "SEL_LISTE"        : Gosub SEL_LISTE
 When "TRT_DIV"          : Gosub TRT_DIV
Endcase
Return

######################################################################################
### Actions
##     Code          Identifiant
#      AYEFIESEL     FIESEL        Sélection d'un champ entité
#      AYEFIECTL     FIECTL        Controle d'un champ entité 
#      AYEFIEINI     FIEINI        Initialisation - Aide pré-remplissage (AYA2)
#      AYEFIEUSG                   Usage d'un champ d'une entité
######################################################################################
$TRT_DIV
Case TRAIT
  When "FIECTL" : Gosub FIE_CTL
  When "FIEINI" : Gosub FIE_INI
Endcase
Return

$SEL_LISTE
Case LISTE
  When "FIESEL" : Gosub FIE_SEL
Endcase
Return

$OUVRE
Case GACTION
  When "AYEFIEUSG" : Gosub FIEUSG_OUV
Endcase
Return

$DEBUT
Case GACTION
  When "AYEFIEUSG" : Gosub FIEUSG_DEB
Endcase
Return

$TITR
Case GACTION
  When "AYEFIEUSG" : Gosub FIEUSG_TIT
Endcase
Return

#    AYEFIESEL  Sélection d'un champ de l'entité Xtend 
######################################################################################
# VALEUR        Adresse       Code champ    Forme composite :  Code, EntiteLiee_Code
# PARAM    1    Valeur        Site Xtend
#          2    Valeur        Code Entité     
#          3    Valeur        Options       "E": Chps entité   "L": Chps liés   "I": Chps avec lien interface
#                                           "S": Champ pour sélection (menu 7931 - pas de 6)
#               
$FIE_SEL
#---------------------------------------------------------------#
Local Char FCYWRK(GLONAYG), ENTCOD(GLONAYE), LNKENTCOD(GLONAYE), LNKFIECOD(GLONAYF)
Local Char OPTION, WSTR
Local Integer WI, FLGINT_NO, FLGHASINT
Local Integer WMAX : WMAX=400
Local Char     WTEXTE2(80)(1..WMAX), WTEXTE3(80)(1..WMAX)
Local Char     TEX(50)(1..WMAX) , TEXTE(80)(1..WMAX,1..3)
If clalev([F:AYN])=0 : Local File AYTLINES [AYN] : Endif
If clalev([F:AYN1])=0 : Local File AYTLINES [AYN1] : Endif
If clalev([F:AYF])=0 : Local File AYTELTFLD [AYF] : Endif
[L]FCYWRK= PARAM(1)  # Site 
[L]ENTCOD= PARAM(2)  # Entité
[L]OPTION= PARAM(3)

If ! ( instr(1,OPTION,"E") | instr(1,OPTION,"L") )
 GERR=1 : GMESSAGE="Xtend - Internal error: Incorrect Option (Action AYEFIESEL)" : Return
Endif

FLGINT_NO = (instr(1,OPTION,"I")=0)

WI = instr(1,VALEUR,"_")
If WI
    LNKFIECOD=right$(VALEUR, WI+1)
    LNKENTCOD=left$(VALEUR, WI-1)
Else
    LNKFIECOD=VALEUR
Endif

TIT=mess(69,7900,1)-[L]ENTCOD
If !FLGINT_NO : TIT = mess(85,7900,1)-[L]ENTCOD: Endif
TIT(1)=mess(37,100,1) : TIT(2)=mess(82,123,1) : TIT(3)=mess(59,100,1)

If instr(0,OPTION,"E")
    For [F:AYN]AYN0 Where FCYCOD=[L]FCYWRK and LINCODTYP = 1
&                     and LINCOD = toupper([L]ENTCOD) and  LINTYP = 10
        If FLGINT_NO | func HASINT()
            Read [AYF]AYF0=[L]FCYWRK;[AYN]FIECOD
            If !fstat 
                If !(instr(1,OPTION,"S") and [AYF]TYP=6)        # Verif. Champ pour sélection 
                    NBTEX+=1
                    TEX(NBTEX)=[AYN]FIECOD
                    Call LECTEXTRA(WSTR,"AYTELTFLD","INTIT",[F:AYF]FCYCOD,[F:AYF]FIECOD) From ATEXTRA
                    If WSTR<>"" : WTEXTE2(NBTEX)= WSTR + space$(20) : Endif
                    WTEXTE3(NBTEX)=mess([AYF]TYP,7931,1)
                Endif
            Endif
        Endif
    Next
Endif

If instr(0,OPTION,"L")
    For [F:AYN]AYN0 Where FCYCOD=[L]FCYWRK and LINCODTYP = 1
&                     and LINCOD = toupper([L]ENTCOD) and  LINTYP = 12
        If FLGINT_NO | func HASINT()
            Read [AYF]AYF0=[L]FCYWRK;[AYN]FIECOD
            If !fstat 
                If !(instr(1,OPTION,"S") and [AYF]TYP=6)        # Verif. Champ pour sélection 
                    NBTEX+=1
                    TEX(NBTEX)=[AYN]FIELNKENT+"_"+[AYN]FIECOD
                    Call LECTEXTRA(WSTR,"AYTELTFLD","INTIT",[F:AYF]FCYCOD,[F:AYF]FIECOD) From ATEXTRA
                    If WSTR<>"" : WTEXTE2(NBTEX)=TEXTE(NBTEX,1)+" -"-WSTR : Endif
                    WTEXTE3(NBTEX)=mess([AYF]TYP,7931,1)
                Endif
            Endif
        Endif
    Next
Endif
DEFPAG=0

If NBTEX=0
    GERR=2 : GMESSAGE =mess(99,100,1) : mkstat=2
Else
    Sorta NBTEX TEX,WTEXTE2,WTEXTE3
    For WI = 1 To NBTEX
        TEXTE(WI,1)=TEX(WI)
        TEXTE(WI,2)=WTEXTE2(WI)
        TEXTE(WI,3)=WTEXTE3(WI)
    Next
Endif
Return


# Chp avec une liaison interface 
Funprog HASINT()
Local Integer WI
WI=0
For [F:AYN1]AYN0 Where FCYCOD=[AYN]FCYCOD and LINCODTYP = 1
&                     and LINCOD = [AYN]LINCOD and  (LINTYP = 20 or LINTYP = 21)
&                     and FIELNKENT=[AYN]FIELNKENT and FIECOD=[AYN]FIECOD
    WI=1
Next
End WI


#    AYEFIEINI  Initialisation champ entité 
######################################################################################
# VALEUR        Adresse       Code champ    Forme composite :  Code, EntiteLiee_Code
# PARAM    1    Valeur        Site Xtend
#          2    Valeur        Code Entité     
#          3    Valeur        Options       
#          4    Valeur        Code champ que l'on souhaiterais proposé     
$FIE_INI
Local Char FCYWRK(GLONAYG), ENTCOD(GLONAYE), FIEWRK(GLONAYF)
Local Char WFILT(200), WSTR(200), OPTION
Local Integer WI
[L]FCYWRK= PARAM(1)  # Site 
[L]ENTCOD= PARAM(2)  # Entité
[L]OPTION= PARAM(3)
[L]FIEWRK= PARAM(4)


WFILT="FIECOD = [L]FIEWRK and FIELNKENT = ''"

WI=0
    For [F:AYN]AYN0 Where FCYCOD=[L]FCYWRK and LINCODTYP = 1
&                     and LINCOD = toupper([L]ENTCOD) 
&                     and evalue(WFILT)
        WI=1 : Break
    Next

If WI
    VALEUR =  [L]FIEWRK
Endif
Return


#    AYEFIECTL  Controle d'un champ entité 
######################################################################################
# VALEUR        Adresse       Code champ    Forme composite :  Code, EntiteLiee_Code
# PARAM    1    Valeur        Site Xtend
#          2    Valeur        Code Entité     
#          3    Valeur        Options       "E": Chps entité   "L": Chps liés   "I": Chps avec lien interface
#                                           "S": Champ pour sélection (menu 7931 - pas de 6)
#               
$FIE_CTL
Local Char FCYWRK(GLONAYG), ENTCOD(GLONAYE), LNKENTCOD(GLONAYE), LNKFIECOD(GLONAYF)
Local Char WFILT(200), WSTR(200), OPTION
Local Integer WI
[L]FCYWRK= PARAM(1)  # Site 
[L]ENTCOD= PARAM(2)  # Entité
[L]OPTION= PARAM(3)

If ! ( instr(1,OPTION,"E") | instr(1,OPTION,"L") )
 mkstat=2 : GMESSAGE="Xtend - Internal error: Incorrect Option (Action AYEFIECTL)" : Return
Endif

WI = instr(1,VALEUR,"_")
If WI
    LNKFIECOD=right$(VALEUR, WI+1)
    LNKENTCOD=left$(VALEUR, WI-1)
    VALEUR=LNKENTCOD+"_"+LNKFIECOD
Else
    LNKFIECOD=VALEUR
Endif


WFILT="FIECOD = [L]LNKFIECOD and FIELNKENT = [L]LNKENTCOD"


#
If instr(0,OPTION,"E") : WSTR += "LINTYP = 10" : Endif
If instr(0,OPTION,"L") : If WSTR<>"" : WSTR+=" or " : Endif : WSTR += "LINTYP = 12" : Endif
WFILT-="and ("-WSTR-")"
#Infbox WFILT

WI=0
    For [F:AYN]AYN0 Where FCYCOD=[L]FCYWRK and LINCODTYP = 1
&                     and LINCOD = toupper([L]ENTCOD) 
&                     and evalue(WFILT)
        WI=1 : Break
    Next

If !WI 
    mkstat=2 
    GMESSAGE=mess(75,7900)
    If (instr(0,OPTION,"E") & instr(0,OPTION,"L"))
        GMESSAGE=mess(75,7900,1)
    Elsif instr(0,OPTION,"E")
        GMESSAGE=mess(75,7900,1)
        If  LNKENTCOD <> "" :  GMESSAGE=mess(76,7900,1) : Endif
    Elsif instr(0,OPTION,"F")
        GMESSAGE=mess(77,7900,1)
    Endif
    Return
Endif

# 
If instr(1,OPTION,"S")                # Champ pour sélection 
    Call CONTROLE("AYF","S" ,[L]LNKFIECOD,[L]FCYWRK,mkstat) From CONTOBJ
    If fstat : Return : Endif
Endif

#
If !instr(0,OPTION,"I") : Return : Endif
WI=0
For [F:AYN]AYN0 Where FCYCOD=[M]FCYCOD and LINCODTYP = 1
&                     and LINCOD = toupper([L]ENTCOD) and  LINTYP = 21
&                     and FIELNKENT=[L]LNKENTCOD and FIECOD=[L]LNKFIECOD
    WI=1
Next
If !WI
    mkstat=2 
    GMESSAGE=mess(78,7900,1)
Endif
#
Return


#    AYEFIEUSG  Usage d'un champ d'une entité
######################################################################################
# PARAM    1    Site Xtend    V
#          2    Code entité   V        
#          3    Code Champ    V
#          4    Retour        A      0:pas d'usage   1:des usages
#          5    Msg origine   V
#               
$FIEUSG_OUV
#---------------------------------------------------------------#
Local Char FCYCOD(GLONAYG), ENTCOD(GLONAYE), FIECOD(GLONAYF)
Local Char MSGORI(120)
[L]FCYCOD= PARAM(1)  
[L]ENTCOD= PARAM(2) 
[L]FIECOD= PARAM(3) 
[L]MSGORI= PARAM(5) 

If [L]FIECOD="" : FIN=1 : Return : Endif   

Local Integer MSGNB
Local Char    MSGTAB(100)(1..30)
Local Integer MSGTABMAX : MSGTABMAX = dim(MSGTAB)

If clalev([F:AYN])=0 : Local File AYTLINES  [AYN] : Endif
If clalev([F:AYB])=0 : Local File AYTELTBLC [AYB] : Endif
If clalev([F:AYL])=0 : Local File AYTELTDLK [AYL] : Endif

# Recherche de l'utilisation du champ
#  -- Utilise le filtre issu de la consultations des usages
Local Clbfile     WFIL(1)        # Filtre
Gosub USG_FIL

Filter [AYN] Where evalue(WFIL) Order By Key AYN0
For [AYN]
    Case [AYN]LINCODTYP
    When 1    # Entité
        If [AYN]LINCOD <> toupper(ENTCOD)    # Ignorer l'entité encours   
            Gosub ANALYSE_AYN 
        Endif
    When Default
        Gosub ANALYSE_AYN
    Endcase
    If MSGNB = MSGTABMAX : Break : Endif
Next
Filter [AYN]
PARAM(4)=num$(MSGNB<>0)
If MSGNB=0 : FIN=1 : Endif
Return

#-- Filtre usage Champs  --
$USG_FIL                           
WFIL=    'FCYCOD = "' +FCYCOD+ '"'
WFIL+=   ' & ( FIECOD = "' +FIECOD+ '"'
WFIL+=   ' | VALFIECOD = "' +FIECOD+ '"'
WFIL+=   ' | VA2FIECOD = "' +FIECOD+ '" )'
Return

#-- Analyse AYN
$ANALYSE_AYN

# Cas FIECOD 
If [AYN]FIECOD = [L]FIECOD 
    If [AYN]FIELNKENT = ENTCOD 
        Gosub USG_ADDMSG
    Elsif [AYN]FIELNKENT = ""
        If [AYN]ENTCOD = ENTCOD  : Gosub USG_ADDMSG : Endif
        # Verif sur fiche entête
        Case [AYN]LINCODTYP
        When 1,3,5,6    # Entete, Bloc caché, Interface, Action  - rien n'est porté par l'entête
        When 2    # Bloc
            Read [AYB]AYB0=[L]FCYCOD;[AYN]LINCOD
            If !fstat
                If [AYB]ENTCOD = ENTCOD  : Gosub USG_ADDMSG : Endif
            Endif
        When 4    # DL
            Read [AYL]AYL0=[L]FCYCOD;[AYN]LINCOD
            If !fstat
                If [AYL]ENTCOD = ENTCOD  : Gosub USG_ADDMSG : Endif
            Endif
        Endcase
    Endif
    If MSGNB = MSGTABMAX : Return : Endif
Endif
    
# Cas VALFIECOD 
If [AYN]VALFIECOD = [L]FIECOD 
    If [AYN]VALFIELNKE = ENTCOD 
        Gosub USG_ADDMSG
    Elsif [AYN]VALFIELNKE = ""
        Read [AYB]AYB0=[L]FCYCOD; [AYN]VALBLCCOD
        If !fstat
            If [AYB]ENTCOD = ENTCOD  : Gosub USG_ADDMSG : Endif
        Endif
    Endif
    If MSGNB = MSGTABMAX : Return : Endif
Endif

# Cas VA2FIECOD 
If [AYN]VA2FIECOD = [L]FIECOD 
    If [AYN]VA2FIELNKE = ENTCOD 
        Gosub USG_ADDMSG
    Elsif [AYN]VA2FIELNKE = ""
        Read [AYB]AYB0=[L]FCYCOD; [AYN]VA2BLCCOD
        If !fstat
            If [AYB]ENTCOD = ENTCOD  : Gosub USG_ADDMSG : Endif
        Endif
    Endif
    If MSGNB = MSGTABMAX : Return : Endif
Endif    
Return

#-- Gestion message
$USG_ADDMSG
    Gosub USGTAB_GETNB : If MSGNB = MSGTABMAX : Return : Endif
    #
    WMSG1=mess(func AYTUTIA.GETAYN_7910([AYN]LINCODTYP),7910,1)-[AYN]LINCOD
    Case [AYN]LINTYP
    When 10             :     WMSG = mess(100,7900,1)
    When 11             :     WMSG = mess(102,7900,1)
    When 12             :     WMSG = mess(101,7900,1)
    When 20             :     WMSG = mess(103,7900,1)
    When 21
        Case [AYN]LINCODTYP
        When 1,3        :     WMSG = mess(104,7900,1)
        When Default    :     WMSG="LINTYP 21-LINCODTYP unknown: "+num$([AYN]LINCODTYP)
        Endcase
    When 30
        Case [AYN]LINCODTYP
        When 1          :     WMSG = mess(98,7900,1)
        When 2,3,4      :     WMSG = mess(99,7900,1)
        When Default    :     WMSG="LINTYP 30-LINCODTYP unknown: "+num$([AYN]LINCODTYP)
        Endcase
    When 31             :     WMSG = mess(105,7900,1)
    When 40             :     WMSG = mess(106,7900,1)
    When 41             :     WMSG = mess(107,7900,1)
    When 50             :     WMSG = mess(108,7900,1)
    When Default        :     WMSG="[AYN]LINTYP unknown: "+num$([AYN]LINTYP)
    Endcase
    #
    MSGTAB(MSGNB)= WMSG1-"-"-WMSG
Return

# Numero de ligne usage suivant
$USGTAB_GETNB
    If MSGNB = MSGTABMAX : Return : Endif
    MSGNB+=1
    # Nb maxi de liens
    If MSGNB = MSGTABMAX 
        MSGTAB(MSGNB)= mess(109,7900,1)
    Endif
Return


$FIEUSG_TIT
#---------------------------------------------------------------#
TIT=mess(100,7900,1)+":"-[L]FIECOD  
Return

$FIEUSG_DEB
#---------------------------------------------------------------#
[M:DIA]MSG1=[L]MSGORI
[M:DIA]MSG2=mess(138,7900,1)
[M:DIA]MSG3=mess(143,7900,1)
[M:DIA]MSGCLB=""
For WI=1 To MSGNB
    [M:DIA]MSGCLB+=MSGTAB(WI)+chr$(13)+chr$(10)
Next
Diszo [M:DIA]MSGCLB  # Permet le copier par rapport à un champ en saisie
Return
