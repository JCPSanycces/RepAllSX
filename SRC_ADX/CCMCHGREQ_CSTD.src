#<AdxTL>@(#)0.0.0.0 $Revision$
# Data Class script: CCMCHGREQ_CSTD, Change Request - Header
# Issue 110863/3 - 2015-12-01 by BAKHA : add method for checking if active Change reqest for a product exists

#####################
# METHODS           #
#####################
$METHODS

  Case CURPTH
    When ""
      Case ACTION
        When "AINIT"                            : Gosub INITIALISE
        When "DUPLICATE_PRODUCT"                : Gosub DUPLICATE_PRODUCT
        When "CHECK_ACTIVE_CHGREQ_EXISTS"       : Gosub CHECK_ACTIVE_CHGREQ_EXISTS   # Issue 110863/3
        When "AUPDATE_AFTER"                    : Gosub EMAIL_NOTIFICATION
        When "AINSERT_AFTER"                    : Gosub NOTIFY_NEW_CHANGE_MANAGER
        When "UPDATE_IMPLEMENT_STATUS"          : Gosub UPDATE_IMPLEMENT_STATUS
       Endcase
  Endcase
Return

# ------------------------------------------------------
# Subroutine: INITIALISE
#
# Called from this Script.
# Set Impact Analysis 'Created' flag = 1 ...
#
$INITIALISE

  this.IMPACTANAL = 0
  this.CLOSEDATE = AVOID.ADATE
  this.ECCVALMAJ = ""
  this.ECCVALMIN = ""
  this.NCSREC = 1
  #setup default Change manager and planner
  Gosub INITIALISE_CHANGE_MANAGER
  Gosub INITIALISE_PLANNER

Return

# --------------------------------------------------
# Initialise change request change manager (CCMUSRID),
# Set to default change manager (error if Default CHANGE MANAGER DOES not EXIST).
$INITIALISE_CHANGE_MANAGER

  Local Char CCMCMDEF(30)

  CCMCMDEF = fmet this.ACTX.APARAM.AGETVALCHAR(CST_ALEVFOLD, this.ACTX.AFOLDER, "CCMCMDEF")
  If (CCMCMDEF <> "")
    this.CCMUSRID = CCMCMDEF
  Else
     ASTATUS = fmet  this.ASETERROR ("", mess(5,2038,1), CST_AERROR)
  Endif

Return

# --------------------------------------------------
# Initialise change request Planner (PLANNER),
# Set to default Planner
$INITIALISE_PLANNER

  Local Char CCMPLADEF(30)

  CCMPLADEF = fmet this.ACTX.APARAM.AGETVALCHAR(CST_ALEVFOLD, this.ACTX.AFOLDER, "CCMPLADEF")
  If (CCMPLADEF <> "")
    this.PLANNER = CCMPLADEF
  Endif

Return

# --------------------------------------------------
# Custom Method
# Check for duplicate product ...
# Return values:
# ARET_VALUE - CST_AERROR, CST_AINFO and 0
# MESSAGE    - corresponding message string.
$DUPLICATE_PRODUCT

  Local File CCMCHGREQ [CCMCR]

  MESSAGE = ""
  ARET_VALUE = 0

  If (this.CRSTATUS = 2 or
&     this.CRSTATUS = 4 or
&     this.CRSTATUS = 5 or
&     this.CRSTATUS = 6)

    Filter [CCMCR] Where PRODUCT = this.PRODUCT and CRID <> this.CRID and CRSTATUS >= 2 and CRSTATUS <= 6
    Read [CCMCR] First
    If (fstat = 0)
      MESSAGE = func ASYRFNC.MES1(mess(51,2038,1), [F:CCMCR]CRID)
      ARET_VALUE = CST_AERROR
    Endif

  Elsif (this.CRSTATUS = 1)

    Filter [CCMCR] Where PRODUCT = this.PRODUCT and CRID <> this.CRID and CRSTATUS <> 7 and (this.PRODUCT <> "")
    Read [CCMCR] First
    If (fstat = 0)
      MESSAGE = mess(50,2038,1)
      ARET_VALUE = CST_AINFO
    Endif

  Endif

  LogicClose File [CCMCR]

Return

# Issue 110863/3
# --------------------------------------------------
# Custom Method
# Check active change request for a product and/or version
# Parameters
#                 PRODUCT       - product code
#                 MAJOR_VERSION - major version
#                 MINOR_VERSION - minor version
# Return values:
#                 ARET_VALUE - CST_AFALSE and CST_ATRUE
#                 CHANGE_REQUEST  - Change request ID if found
#

$CHECK_ACTIVE_CHGREQ_EXISTS

  Local File CCMCHGREQ [CCMCR]
  Local Char CRITERIA(250)

  REQUESTID = ""
  ARET_VALUE = CST_AFALSE

  # Create new sales order lines
  CRITERIA = "PRODUCT ='" + PRODUCT + "' and NCSREC <> 2 "
  If (MAJOR_VERSION <> "")
      CRITERIA += " and (ECCVALMAJ ='" + MAJOR_VERSION +"' or ECCVALMAJ = '')"

    If (MINOR_VERSION <>  "")
      CRITERIA += " and (ECCVALMIN = '" + MINOR_VERSION +"' or ECCVALMIN = '')"
    Endif

  Endif

  Filter [CCMCR] Where evalue(CRITERIA) and CRSTATUS > 1 and CRSTATUS < 7
  Read [CCMCR] First
  If (fstat = 0)
    REQUESTID = [F:CCMCR]CRID
    ARET_VALUE = CST_ATRUE
  Endif
  Filter [CCMCR]
  LogicClose File [CCMCR]

Return

# --------------------------------------------------
# Method: UPDATE_IMPLEMENT_STATUS
#
# Determine the IMPLEMENT the state of the IMPLEMENT flag across all Detail Plans and
# Set the Change Request Status to Implement (from Plan) or Plan (from Implement).
$UPDATE_IMPLEMENT_STATUS

  Local Integer STAT, IMPLEMENT_STATUS, STATUS_CHANGE

  Local Instance CHANGE_REQUEST Using C_CCMCHGREQ
  CHANGE_REQUEST = NewInstance C_CCMCHGREQ AllocGroup null

  STAT = fmet CHANGE_REQUEST.AREAD(CRID)
  If (STAT = CST_AOK)

    STATUS_CHANGE = CST_AFALSE

    IMPLEMENT_STATUS =  fmet CHANGE_REQUEST.DETERMINE_IMPLEMENT_STATUS()

    If (IMPLEMENT_STATUS = 2)
      If (CHANGE_REQUEST.CRSTATUS = 4)
        CHANGE_REQUEST.CRSTATUS = 5
        STATUS_CHANGE = CST_ATRUE
      Endif
    Else
      If (CHANGE_REQUEST.CRSTATUS = 5)
        CHANGE_REQUEST.CRSTATUS = 4
        STATUS_CHANGE = CST_ATRUE
      Endif
    Endif

    If (CYCLE = CST_AFALSE)
      CHANGE_REQUEST.IMPPLANS = 100
    Endif

    If (STATUS_CHANGE)
      STAT =  fmet CHANGE_REQUEST.AUPDATE()
    Endif

  Endif

  FreeGroup CHANGE_REQUEST

Return

# Issue 110863/3
#
# --------------------------------------------------
# FUNCTION NAME:        EMAIL_NOTIFICATION
# FUNCTION DESCRIPTION: Determines the Email Notification functions to execute.
#                       Called from AUPDATE_AFTER.
# FUNCTION TYPE:        Subroutine
# PARAMETERS:           N/A
# RETURN_VALUE:         N/A
#
#
$EMAIL_NOTIFICATION

  Local Integer CM_EMAIL : CM_EMAIL = CST_AFALSE
  Local Integer P_EMAIL  : P_EMAIL  = CST_AFALSE
  Local Integer C_EMAIL  : C_EMAIL  = CST_AFALSE
  Local Integer AP_EMAIL : AP_EMAIL = CST_AFALSE

  # If Change Manager is changed then Notify Change Manager ...
  If (this.snapshot.CCMUSRID <> this.CCMUSRID)
    Gosub NOTIFY_NEW_CHANGE_MANAGER
    Gosub NOTIFY_OLD_CHANGE_MANAGER
  Endif

  # If Status is changed from 'In Review' to 'Plan' or
  #    Status is already 'Plan' and Planner is changed then Notify Planner ...
  If (this.snapshot.CRSTATUS = 2 and this.CRSTATUS = 4)
    Gosub NOTIFY_NEW_PLANNER
  Elsif (this.CRSTATUS = 4 and this.snapshot.PLANNER <> this.PLANNER)
    Gosub NOTIFY_NEW_PLANNER
    Gosub NOTIFY_OLD_PLANNER
  Endif

  # If Status is 'In Review' then NOTIFY_APPROVER ...
  If (this.CRSTATUS = 2)
    Gosub NOTIFY_APPROVER
  Endif

  # If Status is "Reject" or "Complete" then NOTIFY_CREATOR ...
  If ((this.CRSTATUS = 3 and this.snapshot.CRSTATUS <> 3) or
&     (this.CRSTATUS = 6 and this.snapshot.CRSTATUS <> 6))
    Gosub NOTIFY_CREATOR
  Endif

  If (CM_EMAIL = CST_ATRUE)
    ASTATUS = fmet this.ASETERROR("", mess(53,2038,1), CST_AINFO)
  Endif
  If (P_EMAIL  = CST_ATRUE)
    ASTATUS = fmet this.ASETERROR("", mess(54,2038,1), CST_AINFO)
  Endif
  If (C_EMAIL  = CST_ATRUE)
    ASTATUS = fmet this.ASETERROR("", mess(56,2038,1), CST_AINFO)
  Endif
  If (AP_EMAIL = CST_ATRUE)
    ASTATUS = fmet this.ASETERROR("", mess(58,2038,1), CST_AINFO)
  Endif

Return

#
# --------------------------------------------------
# FUNCTION NAME:        NOTIFY_NEW_CHANGE_MANAGER
# FUNCTION DESCRIPTION: Send Email Notification to NEW Change Manager.
# FUNCTION TYPE:        Subroutine
# PARAMETERS:           N/A
# RETURN_VALUE:         N/A
#
#
$NOTIFY_NEW_CHANGE_MANAGER

  Local Integer STAT
  Local Integer EMAIL_TYPE
  Local Char SUBJECT(250)
  Local Clbfile BODY(0)
  Local Integer R_V

  # No Email Notification if you are Change Manager ...
  If (fmet this.ACTX.APARAM.AGETVALNUM(CST_ALEVFOLD, this.ACTX.AFOLDER, "CCMEMAILCM") <> 1 and
&     this.ACTX.USER <> this.CCMUSRID)

    EMAIL_TYPE = 2054  # NEW Change Manager

    STAT = fmet this.BUILD_EMAIL(EMAIL_TYPE, SUBJECT, BODY, AVOID.ACLOB, "CCMCHGREQ")
    STAT = fmet this.SEND_EMAIL(this.ACTX.USER, this.CCMUSRID, "", SUBJECT, BODY)

    If (STAT = CST_AOK)
      CM_EMAIL = CST_ATRUE
    Endif

  Endif

Return

#
# --------------------------------------------------
# FUNCTION NAME:        NOTIFY_OLD_CHANGE_MANAGER
# FUNCTION DESCRIPTION: Send Email Notification to OLD Change Manager.
# FUNCTION TYPE:        Subroutine
# PARAMETERS:           N/A
# RETURN_VALUE:         N/A
#
#
$NOTIFY_OLD_CHANGE_MANAGER

  Local Integer STAT
  Local Integer EMAIL_TYPE
  Local Char SUBJECT(250)
  Local Clbfile BODY(0)

  # No Email Notification if you are Change Manager ...
  If (fmet this.ACTX.APARAM.AGETVALNUM(CST_ALEVFOLD, this.ACTX.AFOLDER, "CCMEMAILCM") <> 1 and
&     this.ACTX.USER <> this.snapshot.CCMUSRID)

    EMAIL_TYPE = 2056  # OLD Change Manager

    STAT = fmet this.BUILD_EMAIL(EMAIL_TYPE, SUBJECT, BODY, AVOID.ACLOB, "CCMCHGREQ")
    STAT = fmet this.SEND_EMAIL(this.ACTX.USER, this.snapshot.CCMUSRID, "", SUBJECT, BODY)

    If (STAT = CST_AOK)
      CM_EMAIL = CST_ATRUE
    Endif

  Endif

Return

Return

