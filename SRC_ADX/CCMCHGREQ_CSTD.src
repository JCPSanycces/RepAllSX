#
# --------------------------------------------------
# FUNCTION NAME:        NOTIFY_CREATOR
# FUNCTION DESCRIPTION: Send Email Notification to the Creator of the Change Request.
# FUNCTION TYPE:        Subroutine
# PARAMETERS:           N/A
# RETURN_VALUE:         N/A
#
#
$NOTIFY_CREATOR

  Local Integer STAT
  Local Integer EMAIL_TYPE
  Local Char SUBJECT(250)
  Local Clbfile BODY(0)
  Local Clbfile BODY_STATUS(0)

  # No Email Notification if you are Creator ...
  If (fmet this.ACTX.APARAM.AGETVALNUM(CST_ALEVFOLD, this.ACTX.AFOLDER, "CCMEMAILCR") <> 1 and
&     this.ACTX.USER <> this.CREUSR)

    EMAIL_TYPE = 2065  # Creator

    Append BODY_STATUS, mess(this.CRSTATUS,2033,1) +chr$(10)

    STAT = fmet this.BUILD_EMAIL(EMAIL_TYPE, SUBJECT, BODY, BODY_STATUS, "CCMCHGREQ")
    STAT = fmet this.SEND_EMAIL(this.ACTX.USER, this.CREUSR, "", SUBJECT, BODY)

    If (STAT = CST_AOK)
      C_EMAIL = CST_ATRUE
    Endif

  Endif

Return

#
# --------------------------------------------------
# FUNCTION NAME:        NOTIFY_APPROVER
# FUNCTION DESCRIPTION: Send Email Notification to Approver(s).
# FUNCTION TYPE:        Subroutine
# PARAMETERS:           N/A
# RETURN_VALUE:         N/A
#
#
$NOTIFY_APPROVER

  Local Instance AUTILIS Using C_AUTILIS
  AUTILIS = NewInstance C_AUTILIS AllocGroup null
  Local Char NEW_APPROVERS(30)(1..)
  Local Char OLD_APPROVERS(30)(1..)
  Local Integer NEW_APPROVERS_ENTITIES(1..,100)
  Local Integer OLD_APPROVERS_ENTITIES(1..,100)
  Local Integer APPROVER_REJECTS(1..)
  Local Clbfile ENTITIES(0)
  Local Clbfile REJECT_ENTITIES(0)
  Local Integer TOTAL_LINE, LINE, I, J
  Local Integer APPRSTAT_CHANGE, APPRSTAT_NOT_PENDING

  Local Integer STAT
  Local Integer EMAIL_TYPE
  Local Char SUBJECT(250)
  Local Clbfile BODY(0)

  APPRSTAT = CST_AFALSE
  APPRSTAT_NOT_PENDING = 0

  NEW_APPROVERS(1) = ""
  OLD_APPROVERS(1) = ""
  APPROVER_REJECTS(1) = 0
  TOTAL_LINE = maxtab(this.CCMAPPROVER)
  For LINE = 1 To TOTAL_LINE
    If (this.CCMAPPROVER(LINE).ASTALIN <> CST_ADEL and
&       this.CCMAPPROVER(LINE).ASTALIN <> CST_ANEWDEL)

      # Email Notification [ to Approver(s) ] if the Approver is changed and you are not the Approver ...
      If (this.CCMAPPROVER(LINE).snapshot.APPRUSER <> this.CCMAPPROVER(LINE).APPRUSER)

        # Email New Approver ...
        If (this.ACTX.USER <> this.CCMAPPROVER(LINE).APPRUSER and
&           this.CCMAPPROVER(LINE).APPRUSER <> "")
          Gosub ADD_TO_NEW_APPROVERS
        Endif

        # Email Old Approver ...
        If (this.ACTX.USER <> this.CCMAPPROVER(LINE).snapshot.APPRUSER and
&           this.CCMAPPROVER(LINE).snapshot.APPRUSER <> "")
          Gosub ADD_TO_OLD_APPROVERS
        Endif

      Endif

      # If Approver status is changed and you are not the Approver ...
      If (this.CCMAPPROVER(LINE).snapshot.APPRSTAT <> this.CCMAPPROVER(LINE).APPRSTAT and
&         this.ACTX.USER <> this.CCMUSRID)

        APPRSTAT_CHANGE = CST_ATRUE

        # Email Notification [ to Change Manager ] if Approver status is "Rejected" ...
        If (this.CCMAPPROVER(LINE).APPRSTAT = 3)
          Gosub ADD_TO_APPROVER_REJECTS
        Endif

      Endif

      # If Approver status is "Approved" or "Rejected" ...
      If (this.CCMAPPROVER(LINE).APPRSTAT = 2 or this.CCMAPPROVER(LINE).APPRSTAT = 3)
        APPRSTAT_NOT_PENDING = APPRSTAT_NOT_PENDING + 1
      Endif

    Endif
  Next LINE

  # Process New Approvers ...
  EMAIL_TYPE = 2060  # New Approver
  I = 1
  While (fmet this.ACTX.APARAM.AGETVALNUM(CST_ALEVFOLD, this.ACTX.AFOLDER, "CCMEMAILAP") <> 1 and
&        NEW_APPROVERS(I) <> "")

    BODY = AVOID.ACLOB
    ENTITIES = AVOID.ACLOB

    J = 1
    While (NEW_APPROVERS_ENTITIES(I,J) <> 0)
      Append ENTITIES, mess(NEW_APPROVERS_ENTITIES(I,J),2039,1) +chr$(10)
      J = J + 1
    Wend

    STAT = fmet this.BUILD_EMAIL(EMAIL_TYPE, SUBJECT, BODY, ENTITIES, "CCMCHGREQ")
    STAT = fmet this.SEND_EMAIL(this.ACTX.USER, NEW_APPROVERS(I), "", SUBJECT, BODY)

    If (STAT = CST_AOK)
      AP_EMAIL = CST_ATRUE
    Endif

    I = I + 1
  Wend

  # Process Old Approvers ...
  EMAIL_TYPE = 2064  # Old Approver
  I = 1
  While (fmet this.ACTX.APARAM.AGETVALNUM(CST_ALEVFOLD, this.ACTX.AFOLDER, "CCMEMAILAP") <> 1 and
&        OLD_APPROVERS(I) <> "")

    BODY = AVOID.ACLOB
    ENTITIES = AVOID.ACLOB

    J = 1
    While (OLD_APPROVERS_ENTITIES(I,J) <> 0)
      Append ENTITIES, mess(OLD_APPROVERS_ENTITIES(I,J),2039,1) +chr$(10)
      J = J + 1
    Wend

    STAT = fmet this.BUILD_EMAIL(EMAIL_TYPE, SUBJECT, BODY, ENTITIES, "CCMCHGREQ")
    STAT = fmet this.SEND_EMAIL(this.ACTX.USER, OLD_APPROVERS(I), "", SUBJECT, BODY)

    If (STAT = CST_AOK)
      AP_EMAIL = CST_ATRUE
    Endif

    I = I + 1
  Wend

  # Process Approver Rejects ...
  If (fmet this.ACTX.APARAM.AGETVALNUM(CST_ALEVFOLD, this.ACTX.AFOLDER, "CCMEMAILCM") <> 1 and
&     APPROVER_REJECTS(1) <> 0)

    BODY = AVOID.ACLOB
    REJECT_ENTITIES = AVOID.ACLOB

    EMAIL_TYPE = 2061 # Approver rejection

    STAT = fmet AUTILIS.AREAD(this.ACTX.USER)
    Append REJECT_ENTITIES, AUTILIS.NOMUSR +chr$(10) +chr$(10)

    J = 1
    While (APPROVER_REJECTS(J) <> 0)
      Append REJECT_ENTITIES, mess(APPROVER_REJECTS(J),2039,1) +chr$(10)
      J = J + 1
    Wend

    STAT = fmet this.BUILD_EMAIL(EMAIL_TYPE, SUBJECT, BODY, REJECT_ENTITIES, "CCMCHGREQ")
    STAT = fmet this.SEND_EMAIL(this.ACTX.USER, this.CCMUSRID, "", SUBJECT, BODY)

    If (STAT = CM_EMAIL)
      CM_EMAIL = CST_ATRUE
    Endif

  Endif

  # Process Approver status (all) ...
  If (fmet this.ACTX.APARAM.AGETVALNUM(CST_ALEVFOLD, this.ACTX.AFOLDER, "CCMEMAILCM") <> 1 and
&     APPRSTAT_CHANGE = CST_ATRUE and
&     APPRSTAT_NOT_PENDING = TOTAL_LINE)

    BODY = AVOID.ACLOB

    EMAIL_TYPE = 2062 # Approver status (all)

    STAT = fmet this.BUILD_EMAIL(EMAIL_TYPE, SUBJECT, BODY, AVOID.ACLOB, "CCMCHGREQ")
    STAT = fmet this.SEND_EMAIL(this.ACTX.USER, this.CCMUSRID, "", SUBJECT, BODY)

    If (STAT = CM_EMAIL)
      CM_EMAIL = CST_ATRUE
    Endif

  Endif

  FreeGroup AUTILIS

Return

#
# --------------------------------------------------
# FUNCTION NAME:        ADD_TO_APPROVERS
# FUNCTION DESCRIPTION: Produce list (array) of unique Approvers.
# FUNCTION TYPE:        Subroutine
# PARAMETERS:           N/A
# RETURN_VALUE:         N/A
#
#
$ADD_TO_NEW_APPROVERS

  Local Integer APPROVER_INDEX, FOUND

  APPROVER_INDEX = 1
  FOUND = CST_AFALSE
  While (NEW_APPROVERS(APPROVER_INDEX) <> "")
    If (this.CCMAPPROVER(LINE).APPRUSER = NEW_APPROVERS(APPROVER_INDEX))
      FOUND = CST_ATRUE
      Break
    Endif
    APPROVER_INDEX = APPROVER_INDEX + 1
  Wend
  If (FOUND = CST_AFALSE)
    NEW_APPROVERS(APPROVER_INDEX) = this.CCMAPPROVER(LINE).APPRUSER
    NEW_APPROVERS(APPROVER_INDEX + 1) = ""

    NEW_APPROVERS_ENTITIES(APPROVER_INDEX,1) = 0
  Endif

  Gosub ADD_TO_NEW_APPROVERS_ENTITIES

Return

#
# --------------------------------------------------
# FUNCTION NAME:        ADD_TO_OLD_APPROVERS
# FUNCTION DESCRIPTION: Produce list (array) of unique Approvers.
# FUNCTION TYPE:        Subroutine
# PARAMETERS:           N/A
# RETURN_VALUE:         N/A
#
#
$ADD_TO_OLD_APPROVERS

  Local Integer APPROVER_INDEX, FOUND

  APPROVER_INDEX = 1
  FOUND = CST_AFALSE
  While (OLD_APPROVERS(APPROVER_INDEX) <> "")
    If (this.CCMAPPROVER(LINE).snapshot.APPRUSER = OLD_APPROVERS(APPROVER_INDEX))
      FOUND = CST_ATRUE
      Break
    Endif
    APPROVER_INDEX = APPROVER_INDEX + 1
  Wend
  If (FOUND = CST_AFALSE)
    OLD_APPROVERS(APPROVER_INDEX) = this.CCMAPPROVER(LINE).snapshot.APPRUSER
    OLD_APPROVERS(APPROVER_INDEX + 1) = ""

    OLD_APPROVERS_ENTITIES(APPROVER_INDEX,1) = 0
  Endif

  Gosub ADD_TO_OLD_APPROVERS_ENTITIES

Return

#
# --------------------------------------------------
# FUNCTION NAME:        ADD_TO_APPROVER_REJECTS
# FUNCTION DESCRIPTION: Produce list (array) of unique Rejects.
# FUNCTION TYPE:        Subroutine
# PARAMETERS:           N/A
# RETURN_VALUE:         N/A
#
#
$ADD_TO_APPROVER_REJECTS

  Local Integer APPROVER_REJECTS_INDEX, FOUND

  APPROVER_REJECTS_INDEX = 1
  FOUND = CST_AFALSE
  While (APPROVER_REJECTS(APPROVER_REJECTS_INDEX) <> 0)
    If (this.CCMAPPROVER(LINE).TRANSTYPE = APPROVER_REJECTS(APPROVER_REJECTS_INDEX))
      FOUND = CST_ATRUE
      Break
    Endif
    APPROVER_REJECTS_INDEX = APPROVER_REJECTS_INDEX + 1
  Wend
  If (FOUND = CST_AFALSE)
    APPROVER_REJECTS(APPROVER_REJECTS_INDEX) = this.CCMAPPROVER(LINE).TRANSTYPE
    APPROVER_REJECTS(APPROVER_REJECTS_INDEX + 1) = 0
  Endif

Return

#
# --------------------------------------------------
# FUNCTION NAME:        ADD_TO_NEW_APPROVERS_ENTITIES
# FUNCTION DESCRIPTION: Produce list (array) of unique Approvers Entities.
# FUNCTION TYPE:        Subroutine
# PARAMETERS:           N/A
# RETURN_VALUE:         N/A
#
#
$ADD_TO_NEW_APPROVERS_ENTITIES

  Local Integer APPROVER_ENTITY_INDEX

  APPROVER_ENTITY_INDEX = 1
  FOUND = CST_AFALSE
  While (NEW_APPROVERS_ENTITIES(APPROVER_INDEX,APPROVER_ENTITY_INDEX) <> 0)
    If (this.CCMAPPROVER(LINE).TRANSTYPE = NEW_APPROVERS_ENTITIES(APPROVER_INDEX,APPROVER_ENTITY_INDEX))
      FOUND = CST_ATRUE
      Break
    Endif
    APPROVER_ENTITY_INDEX = APPROVER_ENTITY_INDEX + 1
  Wend
  If (FOUND = CST_AFALSE)
    NEW_APPROVERS_ENTITIES(APPROVER_INDEX,APPROVER_ENTITY_INDEX) = this.CCMAPPROVER(LINE).TRANSTYPE
    NEW_APPROVERS_ENTITIES(APPROVER_INDEX,APPROVER_ENTITY_INDEX + 1) = 0
  Endif

Return

#
# --------------------------------------------------
# FUNCTION NAME:        ADD_TO_OLD_APPROVERS_ENTITIES
# FUNCTION DESCRIPTION: Produce list (array) of unique Approvers Entities.
# FUNCTION TYPE:        Subroutine
# PARAMETERS:           N/A
# RETURN_VALUE:         N/A
#
#
$ADD_TO_OLD_APPROVERS_ENTITIES

  Local Integer APPROVER_ENTITY_INDEX

  APPROVER_ENTITY_INDEX = 1
  FOUND = CST_AFALSE
  While (OLD_APPROVERS_ENTITIES(APPROVER_INDEX,APPROVER_ENTITY_INDEX) <> 0)
    If (this.CCMAPPROVER(LINE).TRANSTYPE = OLD_APPROVERS_ENTITIES(APPROVER_INDEX,APPROVER_ENTITY_INDEX))
      FOUND = CST_ATRUE
      Break
    Endif
    APPROVER_ENTITY_INDEX = APPROVER_ENTITY_INDEX + 1
  Wend
  If (FOUND = CST_AFALSE)
    OLD_APPROVERS_ENTITIES(APPROVER_INDEX,APPROVER_ENTITY_INDEX) = this.CCMAPPROVER(LINE).TRANSTYPE
    OLD_APPROVERS_ENTITIES(APPROVER_INDEX,APPROVER_ENTITY_INDEX + 1) = 0
  Endif

Return

#####################
# PROPERTIES        #
#####################
$PROPERTIES

  Case CURPRO
    When "CCMUSRID"
      Case ACTION
        When "CONTROL"
          Gosub VALIDATE_CHANGE_MANAGER
      Endcase
    When "PRODUCT"
      Case ACTION
        When "PROPAGATE"
          Gosub CHECK_AUTHORISATION
      Endcase
    When "SITE"
      Case ACTION
        When "CONTROL"
          Gosub CHECK_AUTHORISATION
      Endcase
    When "PLANNER"
      Case ACTION
        When "CONTROL"
          Gosub VALIDATE_PLANNER
      Endcase
  Endcase


Return

# --------------------------------------------------
# Validate change manager (CCMUSRID)
$VALIDATE_CHANGE_MANAGER

  Local Char CCMCHGMAN(30)
  Local Char MESSAGE(100)

  ASTATUS = fmet this.ADELETEERROR("CCMUSRID")

  Call PARAMUTIL("CCMCHGMAN", CCMCHGMAN, this.CCMUSRID, "") From SUBAUS
  If (CCMCHGMAN <> "2")
    MESSAGE = func ASYRFNC.MES1(mess(13,2038,1),this.CCMUSRID)
    ASTATUS = fmet this.ASETERROR("CCMUSRID", MESSAGE, CST_AERROR)
  Endif

  If (ASTATUS = CST_AOK)

    Gosub CHECK_CHANGE_MANAGER_AUTHORISATION

  Endif

Return

# --------------------------------------------------
#
$CHECK_CHANGE_MANAGER_AUTHORISATION

  Local Instance AUTILIS Using C_AUTILIS
  AUTILIS = NewInstance C_AUTILIS AllocGroup null
  Local Instance ITMMASTER Using C_ITMMASTER
  ITMMASTER = NewInstance C_ITMMASTER AllocGroup null
  Local Char MESSAGE(100)
  Local Integer STAT
  Local Integer IS_SOLD, IS_BOUGHT, IS_MANUFACTURED, IS_SUBCONTRACT

  IS_SOLD = IS_BOUGHT = IS_MANUFACTURED = IS_SUBCONTRACT = 2
  If (this.PRODUCT <> "")
    STAT = fmet ITMMASTER.AREAD(this.PRODUCT)
    If (STAT = CST_AOK)
      IS_SOLD         = ITMMASTER.SALFLG
      IS_BOUGHT       = ITMMASTER.PURFLG
      IS_MANUFACTURED = ITMMASTER.MFGFLG
      IS_SUBCONTRACT  = ITMMASTER.SCPFLG
    Endif
  Endif

  For I = 3 To 14 # 3 = BOMs to 14 = Work Orders.

    If ((IS_SOLD = 2 and (I = 4 or I = 5 or I = 8 or I = 10)) or
&       (IS_BOUGHT = 2 and (I = 6 or I = 7 or I = 13)) or
&       (IS_MANUFACTURED = 2 and (I = 3 or I = 9 or I = 14)) or
&       (IS_SUBCONTRACT = 2 and I = 12))

      If (fmet this.CHECK_USER_SITE(this.CCMUSRID, this.SITE, I) = CST_AERROR)

        STAT = fmet AUTILIS.AREAD(this.CCMUSRID)

        MESSAGE = func ASYRFNC.MES4(mess(59,2038,1),
&           this.CCMUSRID,
&           AUTILIS.NOMUSR,
&           mess(I,2039,1),
&           this.SITE)
        ASTATUS = fmet this.ASETERROR("CCMUSRID", MESSAGE, CST_AERROR)

        Break

      Endif

    Endif

  Next I

FreeGroup AUTILIS
FreeGroup ITMMASTER
Return

# --------------------------------------------------
# Validate planner (PLANNER)
$VALIDATE_PLANNER

  Local Char CCMPLANNER(30)
  Local Char MESSAGE(100)

  ASTATUS = fmet this.ADELETEERROR("PLANNER")

  If (this.PLANNER <> "")
    Call PARAMUTIL("CCMPLANNER", CCMPLANNER, this.PLANNER, "") From SUBAUS
    If (CCMPLANNER <> "2")
      MESSAGE = func ASYRFNC.MES1(mess(74,2038,1),this.PLANNER)
      ASTATUS = fmet this.ASETERROR("PLANNER", MESSAGE, CST_AERROR)
    Endif

    If (ASTATUS = CST_AOK)
      Gosub CHECK_PLANNER_AUTHORISATION
    Endif
  Endif

Return

# --------------------------------------------------
#
$CHECK_PLANNER_AUTHORISATION

  Local Instance AUTILIS Using C_AUTILIS
  AUTILIS = NewInstance C_AUTILIS AllocGroup null
  Local Instance ITMMASTER Using C_ITMMASTER
  ITMMASTER = NewInstance C_ITMMASTER AllocGroup null
  Local Char MESSAGE(100)
  Local Integer STAT
  Local Integer IS_SOLD, IS_BOUGHT, IS_MANUFACTURED, IS_SUBCONTRACT

  IS_SOLD = IS_BOUGHT = IS_MANUFACTURED = IS_SUBCONTRACT = 2
  If (this.PRODUCT <> "")
    STAT = fmet ITMMASTER.AREAD(this.PRODUCT)
    If (STAT = CST_AOK)
      IS_SOLD         = ITMMASTER.SALFLG
      IS_BOUGHT       = ITMMASTER.PURFLG
      IS_MANUFACTURED = ITMMASTER.MFGFLG
      IS_SUBCONTRACT  = ITMMASTER.SCPFLG
    Endif
  Endif

  For I = 3 To 14 # 3 = BOMs to 14 = Work Orders.

    If ((IS_SOLD = 2 and (I = 4 or I = 5 or I = 8 or I = 10)) or
&       (IS_BOUGHT = 2 and (I = 6 or I = 7 or  I = 13)) or
&       (IS_MANUFACTURED = 2 and (I = 3 or I = 9 or  I = 14)) or
&       (IS_SUBCONTRACT = 2 and I = 12))

      If (fmet this.CHECK_USER_SITE(this.PLANNER, this.SITE, I) = CST_AERROR)

        STAT = fmet AUTILIS.AREAD(this.PLANNER)

        MESSAGE = func ASYRFNC.MES4(mess(59,2038,1),
&         this.PLANNER,
&         AUTILIS.NOMUSR,
&         mess(I,2039,1),
&         this.SITE)
        ASTATUS = fmet this.ASETERROR("PLANNER", MESSAGE, CST_AERROR)

        Break

      Endif

    Endif

  Next I

FreeGroup AUTILIS
FreeGroup ITMMASTER

Return

# --------------------------------------------------
# Check Approver Site (Change Request) and Transaction Type authorisation [ for all Approvers ].
$CHECK_AUTHORISATION

  Local Char ERROR_MESSAGE(100)
  Local Integer STAT
  Local Instance AUTILIS Using C_AUTILIS
  AUTILIS = NewInstance C_AUTILIS AllocGroup null
  Local Instance PLAN Using C_CCMPLANH
  PLAN = NewInstance C_CCMPLANH AllocGroup null

  # Check Approvers ...
  For I = 1 To maxtab(this.CCMAPPROVER)

    ASTATUS = fmet this.CCMAPPROVER(I).ADELETEERROR("APPRUSER")

    If (fmet this.CHECK_USER_SITE(this.CCMAPPROVER(I).APPRUSER, this.SITE, this.CCMAPPROVER(I).TRANSTYPE) = CST_AERROR)

      STAT = fmet AUTILIS.AREAD(this.CCMAPPROVER(I).APPRUSER)

      ERROR_MESSAGE = func ASYRFNC.MES4(mess(59,2038,1),
&       this.CCMAPPROVER(I).APPRUSER,
&       AUTILIS.NOMUSR,
&       mess(this.CCMAPPROVER(I).TRANSTYPE,2039,1),
&       this.SITE)
      ASTATUS = fmet this.CCMAPPROVER(I).ASETERROR("APPRUSER", ERROR_MESSAGE, CST_AERROR)

    Endif

  Next I

  ASTATUS = fmet this.ADELETEERROR("SITE")

  If (ASTATUS = CST_AOK)

    # Check High Level Plan ...
    If (this.CRSTATUS = 4 or this.CRSTATUS = 5)

      STAT = fmet PLAN.AREAD(this.CRID)
      If (STAT = CST_AOK)

        For I = 1 To maxtab(PLAN.CCMPLAND)

          If (fmet this.CHECK_USER_SITE(PLAN.CCMPLAND(I).ACTIONER, this.SITE, PLAN.CCMPLAND(I).TRANTYPE) = CST_AERROR)

            ERROR_MESSAGE = func ASYRFNC.MES1(mess(61,2038,1), this.SITE)
            ASTATUS = fmet this.ASETERROR("SITE", ERROR_MESSAGE, CST_AERROR)
            Break

          Endif

        Next I

      Endif

    Endif

  Endif

  FreeGroup AUTILIS

  ASTATUS = fmet this.ADELETEERROR("CCMUSRID")

  If (ASTATUS = CST_AOK)

    # Check Change Manager ...
    Gosub CHECK_CHANGE_MANAGER_AUTHORISATION

  Endif

  ASTATUS = fmet this.ADELETEERROR("PLANNER")

  If (ASTATUS = CST_AOK)

    # Check Planner ...
    Gosub CHECK_PLANNER_AUTHORISATION

  Endif

  FreeGroup PLAN

Return


