##########################################################################################################
#CHECK UNUSED_BEGIN
Subprog AM_AMTPLYX(VALEUR)
Variable Decimal VALEUR
If VALEUR > 0
    [M:CON3]BASEXXAMTX = 2
    Actzo [M:CON3]CONCUR2
    Actzo [M:CON3]BASEXXAMTX
Else
    [M:CON3]BASEXXAMTX = 6
    Grizo [M:CON3]CONCUR2
    Grizo [M:CON3]BASEXXAMTX
Endif

GICURCHANGED = 1

Affzo [M:CON3]CONCUR2
Affzo [M:CON3]BASEXXAMTX

End
#CHECK UNUSED_END

##########################################################################################################
Subprog AS_NBGRA
If nolign >= dim([M:CON3]GRACOD)
    End
Endif

If nolign > 0
    If GICON3JSAVED
        Call SAVEMASK(GPRECON3NOL) From TRTCON3
        Call LOADQUAL(GPRECON3NOL) From TRTCON3
        GICON3JSAVED -= 1
    Else
        Call SAVEMASK(GPRECON3NOL) From TRTCON3
        Call LOADQUAL(nolign - 1) From TRTCON3
        If GPRECON3NOL <> nolign - 1
            [M:CON3]NBGRASEL(GPRECON3NOL) = ""
            [M:CON3]NBGRASEL(nolign - 1) = "->"
            GPRECON3NOL = nolign - 1
        Endif
    Endif
Endif
Affzo [M:CON3]1-99
End

##########################################################################################################
Subprog C_NBGRA
If nolign >= dim([M:CON3]GRACOD)
    End
Endif

If nolign > 0
    If GICON3JSAVED
        Call SAVEMASK(GPRECON3NOL) From TRTCON3
        Call LOADQUAL(GPRECON3NOL) From TRTCON3
        GICON3JSAVED -= 1
    Else
        Call SAVEMASK(GPRECON3NOL) From TRTCON3
        Call LOADQUAL(nolign - 1) From TRTCON3
        If GPRECON3NOL <> nolign - 1
            [M:CON3]NBGRASEL(GPRECON3NOL) = ""
            [M:CON3]NBGRASEL(nolign - 1) = "->"
            GPRECON3NOL = nolign - 1
        Endif
    Endif
Endif
Affzo [M:CON3]1-99
End

