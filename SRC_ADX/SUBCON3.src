#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion du masque CON3
##########################################################################################################
Subprog AM_ITTFCY(VALEUR)
Variable Integer VALEUR

If VALEUR = 2
    Actzo [M:CON3]ITTDUR
    Actzo [M:CON3]ITTDURBAS
Else
    [M:CON3]ITTDUR = 0
    [M:CON3]ITTDURBAS = 6
    Grizo [M:CON3]ITTDUR
    Grizo [M:CON3]ITTDURBAS
Endif
Affzo [M:CON3]ITTDUR
Affzo [M:CON3]ITTDURBAS

End

##########################################################################################################
Subprog AM_ITTDUR(VALEUR)
Variable Decimal VALEUR

If VALEUR > 0
    If [M:CON3]ITTDURBAS = 6
        [M:CON3]ITTDURBAS = 2
    Endif
    Actzo [M:CON3]ITTDURBAS
Else
    [M:CON3]ITTDURBAS = 6
    Grizo [M:CON3]ITTDURBAS
Endif
Affzo [M:CON3]ITTDURBAS

End

