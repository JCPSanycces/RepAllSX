#<AdxTL>@(#)0.0.0.0 $Revision$
#
#*********************************************************************
#
#
#
#                    Statut des sociétés - détail
#
#*********************************************************************
#    Modifications
#    GLE 16/09/2014 FQ95754 : Contrôle sur les biens classés pour vente de l'exercice non sortis
#    CBO 02/12/2013 FQ93731 : Contrôle de cohérence des contextes + optimisation dans $CALCUL
#    MDJ 24/10/2013 FQ93596 : Amélioration performances
#    CBO 29/05/2013 FQ88911 : ajout de 2 dates (vides) en paramètre
#    GLE 03/12/2012 FQ84664 : contrôle des événements comptabilisés en prenant en compte la législation
#    GLE 02/03/2011 FQ70465 : Affichage du statut de la période comptable suivante si ACCPERCTL
#    GBO 16/09/2010 FQ67275 : [FASDEP] abréviation trop longue remplacée par [FASD]
#    GLE 11/05/2010 FQ65544 : ajout des contrôles sur la comptabilisation par écart de plan
#    GLE 09/04/2010 FQ61310 : affichage de l'informations nombre de biens gérés dans la société
#    GLE 10/02/2010 FQ54343 : Gestion des concessions
#    GLE 02/10/2009 FQ53001 : Optimisation calcul après clôture - suite
#    GLE 15/07/2009 FQ56486 : utilisation des icones feu rouge/feu vert pour la situation de comptabilisation
#*********************************************************************

$ACTION
  #Infbox (ACTION)
  Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "DEBUT"       : Gosub DEBUT
    When Default
  Endcase
Return

$OUVRE
  If !clalev([F:WCNX]) : Local File CONTEXT   [WCNX] : Endif
  If !clalev([F:WFIS]) : Local File FISCYEAR  [WFIS] : Endif
  If !clalev([F:WFAS]) : Local File FXDASSETS [WFAS] : Endif
  If !clalev([F:WDEP]) : Local File DEPREC    [WDEP] : Endif
  If !clalev([F:CPY])  : Local File COMPANY   [CPY]  : Endif : # FQ84664
Return

$DEBUT
  [M:STC0]CPY       = PARAM(1)
  [M:STC0]CNX       = val(PARAM(2))
  [M:STC0]PERSTRDAT = PARAM(3)
  [M:STC0]PERENDDAT = PARAM(4)

  Call LECTURE("CPY",[M:STC0]CPY,"") From CONTOBJ : # FQ84664

  Read [WFIS]FIY1=[M:STC0]CPY;[M:STC0]CNX;GVML_TECOURA

  Gosub MAJ_FENETRE
Return

$MAJ_FENETRE
  Local Integer I, WCNXERR # FQ93731
  Local Char WSOCERR(10) # FQ93731

  # Lecture du contexte
  Read [WCNX]CNX0=[M:STC0]CPY;[M:STC0]CNX

  Raz [M:STC1]
  Raz [M:STC2]
  Raz [M:STC3]

  Gosub BIENS_GERES : # FQ61310
  Gosub CALCUL
  Gosub COMPTABILISATION
  Gosub CIG
  Gosub BIENS_INACTIFS
  Gosub CONCESSION
  Gosub BIENS_CLASSES_VENTE : # FQ95754
  # FQ93731
  I = func SUBCNX2.CTRL_CNX ([M:STC0]CPY, [M:STC0]CNX, 0, WSOCERR, WCNXERR, [M:STC0]MESSCNX)
  If I = 0
    Chgfmt [M:STC0]MESSCNX With "-LO:1X"
  Endif

  Affzo [M:STC0]
  Affzo [M:STC1]
  Affzo [M:STC2]
  Affzo [M:STC3]

  Gosub COLORISATION
Return

# FQ61310
$BIENS_GERES
  Filter [F:WFAS] Where (ISSTYP<>GVML_TSCIG and ISSTYP<>GVML_TSAPPOR and ISSTYP<>GVML_TSFUSIO and ISSTYP<>GVML_TSSCISS) and CPY=[M:STC0]CPY
  [M:STC0]FASSOC = rowcount([F:WFAS])
  Filter [F:WFAS]
Return

$CALCUL
  # Onglet STACLO2
  Local Integer N_I, N_BCO

  # Contexte
  For N_I=1 To [F:WCNX]UPDWAINBR
    [M:STC1]UPDWAITYP(N_I-1) = [F:WCNX]UPDWAITYP(N_I-1)
    [M:STC1]UPDWAIPAR(N_I-1) = [F:WCNX]UPDWAIPAR(N_I-1)
    [M:STC1]UPDWAIBCO(N_I-1) = [F:WCNX]UPDWAIBCO(N_I-1)
  Next N_I
  [M:STC1]NB_NOCNX = N_I-1

  nolign = 1
  For N_I = 1 To [F:WCNX]NBPLC
    Gosub FILTRE_NB_NOCAL From SAISTACLO

     N_BCO = rowcount([F:FASD])

    If N_BCO > 0
      [M:STC1]DPRPLNC(nolign-1) = [F:WCNX]PLNCAA(N_I-1)
      [M:STC1]NBC(nolign-1)     = N_BCO
      nolign += 1
    Endif
  Next

  [M:STC1]NB_NOCAL = nolign - 1

  # Provisions (CONCESSION)
  If G_ACTCCN = G_OUI
    If [F:WCNX]CCNFLG <> G_OUI
      Chgfmt [M:STC1]RPRNOCAL    With "-N:8"
    Else
      Local Integer NBE
      Chgfmt [M:STC1]RPRNOCAL    With "N:8"
      Call IS_RPR_CALCULATE_NBE([F:WCNX]CPY, NBE) From GLOCCN
      [M:STC1]RPRNOCAL = NBE
    Endif
  Endif
Return

$COMPTABILISATION
  Local Integer TLSTPLN(100)
  Local Integer TLSTNBE(100)
  Local Char    LIBZON(100)

  Read [WFIS]FIY1=[M:STC0]CPY;[M:STC0]CNX;GVML_TECOURA

  # Type de clôture
  If [F:WFIS]DATENDPER([F:WFIS]INDCURPER-1) = [F:WFIS]DATENDFIY
    # Exercice
    [M:STC2]FLGCLOPER = G_NON

    [M:STC2]FLGDEFPER  = "" : Chgtzn [M:STC2]FLGDEFPER  With ""
    [M:STC2]FLGPERCPTP = "" : Chgtzn [M:STC2]FLGPERCPTP With "" : # FQ70465

    [M:STC2]FLGCLOEXE = G_OUI
    If find(GVML_TPSTPRO,[F:WFIS]TYPPST) Then
      [M:STC2]FLGDEFALL = "127"
    Else
      [M:STC2]FLGDEFALL = "128"
    Endif
    Call TEXTE(35384, LIBZON) From OBJDIV : # "Compta. réelle pour toutes les périodes"
    Chgtzn [M:STC2]FLGDEFALL  With LIBZON

    If  func GLOBIENS.IS_CNX_POSTED_ISS_FUTURE([M:STC0]CPY, [M:STC0]CNX) = G_OUI
&   and (G_ACTCCN <> G_OUI or [F:WCNX]CCNFLG <> G_OUI or func GLOCCN.IS_RPR_POSTED_ISS_FUTURE([F:WCNX]CPY) = G_OUI) Then
      [M:STC2]FLGDEFSUIV = "128"
    Else
      [M:STC2]FLGDEFSUIV = "127"
    Endif
    Call TEXTE(35385, LIBZON)  From OBJDIV : # "Extourne sur l'exercice suivant des biens sortis"
    Chgtzn [M:STC2]FLGDEFSUIV  With LIBZON

    # FQ70465
    If func GLOBIENS.ACCPERCTL([M:STC0]CPY)
      Local Shortint N_PLN
      For N_PLN = 0 To [F:WCNX]NBPLC-1
        If func GLOBIENS.PERCPT_STATE([M:STC0]CPY, [F:WCNX]LEDTYP(N_PLN), [F:WFIS]DATENDPER([F:WFIS]INDCURPER-1)+1) = 2
          [M:STC2]FLGPERCPTE  = "128"
        Else
          [M:STC2]FLGPERCPTE  = "127"
          Break
        Endif
      Next
      Call TEXTE(43399, LIBZON)  From OBJDIV : # "Période suivante ouverte en compta"
      Chgtzn [M:STC2]FLGPERCPTE  With LIBZON
    Else
      [M:STC2]FLGPERCPTE = "" : Chgtzn [M:STC2]FLGPERCPTE With ""
    Endif

    Call ACTION_BLOCK(ACB_ACTZO, "STACLO2", "FLGCLOEXE") From GLOBIENS
    Call ACTION_BLOCK(ACB_DISZO, "STACLO2", "FLGCLOPER") From GLOBIENS
  Else
    # Période
    [M:STC2]FLGCLOPER  = G_OUI
    [M:STC2]FLGCLOEXE  = G_NON
    [M:STC2]FLGDEFALL  = "" : Chgtzn [M:STC2]FLGDEFALL  With ""
    [M:STC2]FLGDEFSUIV = "" : Chgtzn [M:STC2]FLGDEFSUIV With ""
    [M:STC2]FLGPERCPTE = "" : Chgtzn [M:STC2]FLGPERCPTE With "" : # FQ70465

    If [F:WFIS]TYPPST([F:WFIS]INDCURPER-1) = GVML_TPSTPRO Then
      [M:STC2]FLGDEFPER = "129"
    Else
      [M:STC2]FLGDEFPER = "128"
    Endif
    Call TEXTE(35382, LIBZON) From OBJDIV : # "Compta. réelle pour la périodes"
    Chgtzn [M:STC2]FLGDEFPER  With LIBZON

    # FQ70465
    If func GLOBIENS.ACCPERCTL([M:STC0]CPY)
      Local Shortint N_PLN
      For N_PLN = 0 To [F:WCNX]NBPLC-1
        If func GLOBIENS.PERCPT_STATE([M:STC0]CPY, [F:WCNX]LEDTYP(N_PLN), [F:WFIS]DATENDPER([F:WFIS]INDCURPER-1)+1) = 2
          [M:STC2]FLGPERCPTP  = "128"
        Else
          [M:STC2]FLGPERCPTP  = "127"
          Break
        Endif
      Next
      Call TEXTE(43399, LIBZON)  From OBJDIV : # "Période suivante ouverte en compta"
      Chgtzn [M:STC2]FLGPERCPTP  With LIBZON
    Else
      [M:STC2]FLGPERCPTP = "" : Chgtzn [M:STC2]FLGPERCPTP With ""
    Endif

    Call ACTION_BLOCK(ACB_ACTZO, "STACLO2", "FLGCLOPER") From GLOBIENS
    Call ACTION_BLOCK(ACB_DISZO, "STACLO2", "FLGCLOEXE") From GLOBIENS
  Endif

  # BLOC EVENEMENTS
  Local Char    TLSTEVTTYP(20)(100)
  Local Integer TYP
  Local Integer RET, RET2 # FQ88911

  Raz TLSTPLN , TLSTNBE

  If [F:WFIS]DATENDPER([F:WFIS]INDCURPER-1) = [F:WFIS]DATENDFIY Then
    TYP = 2 : # contrôle sur l'exercice
  Else
    TYP = 1 : # contrôle sur la période courante
  Endif

  # FQ84664 : ajout de [F:CPY]LEG
  # FQ88911
  RET2 = func GENEVE.CTRL_ALL_EVT_CPT([F:CPY]LEG,
&                       [F:WCNX]CPY,
&                       [F:WCNX]CNX,
&                       TYP,
&                       2,
&                       "",
&                       TLSTEVTTYP,
&                       TLSTPLN ,
&                       TLSTNBE,
&                       RET,
&												[0/0/0], [0/0/0])

  If RET=0
    nolign = 1
    For N_I = 0 To 19
      If TLSTNBE(N_I) > 0
        [M:STC2]EVTP(nolign-1)      = TLSTEVTTYP(N_I)
        [M:STC2]DPRPLNP(nolign-1)   = TLSTPLN(N_I)
        [M:STC2]NBP(nolign-1)       = TLSTNBE(N_I)
        nolign += 1
      Endif
    Next N_I

    [M:STC2]NB_NOPOST = nolign - 1
  Endif

  # BLOC DOTATIONS
  Raz TLSTPLN, TLSTNBE

  If  (func GLOBIENS.IS_CNX_POSTED_FILLTAB([F:WCNX]CPY,
&                                          [F:WCNX]CNX,
&                                          G_OUI,
&                                          [F:WFIS]DATENDFIY,
&                                          [F:WFIS]DATENDPER([F:WFIS]INDCURPER-1),
&                                          TLSTPLN,
&                                          TLSTNBE) = G_NON)
    nolign = 1
    For N_I = 0 To [F:WCNX]NBPLC-1
      If TLSTNBE(N_I) > 0
        [M:STC2]DPRPLND(nolign-1) = TLSTPLN(N_I)
        [M:STC2]NBD(nolign-1)     = TLSTNBE(N_I)
        nolign += 1
      Endif
    Next N_I

    [M:STC2]NB_DOT = nolign - 1
  Endif

  # BLOC DOTATIONS ECART PLAN
  Raz TLSTPLN, TLSTNBE

  If  (func GLOLNK.IS_LNK_POSTED_FILLTAB([F:WCNX]CPY,
&                                        [F:WCNX]CNX,
&                                        2,
&                                        "",
&                                        [F:WFIS]DATENDFIY,
&                                        [F:WFIS]DATENDPER([F:WFIS]INDCURPER-1),
&                                        TLSTPLN,
&                                        TLSTNBE) = G_NON)
    nolign = 1
    For N_I = 0 To [F:WCNX]NBPLC-1
      If TLSTNBE(N_I) > 0
        [M:STC2]DPRPLNL(nolign-1) = TLSTPLN(N_I)
        [M:STC2]NBL(nolign-1)     = TLSTNBE(N_I)
        nolign += 1
      Endif
    Next N_I

    [M:STC2]NB_LNK = nolign - 1
  Endif

  # BLOC CONCESSION
  If G_ACTCCN = G_OUI
    If [F:WCNX]CCNFLG <> G_OUI
      Chgfmt [M:STC2]RPRPST   With "-N:8"
      Return
    Else
      Local Integer NBE
      Chgfmt [M:STC2]RPRPST   With "N:8"
      Call IS_CPY_RPR_POSTED_NBE([F:WCNX]CPY, [F:WFIS]DATENDFIY, [F:WFIS]DATENDPER([F:WFIS]INDCURPER-1), "", NBE) From GLOCCN
      [M:STC2]RPRPST = NBE
    Endif
  Endif
Return

$CONCESSION
  If G_ACTCCN <> G_OUI : Return : Endif

  If [F:WCNX]CCNFLG <> G_OUI
      Chgfmt [M:STC3]RNWBCO    With "-N:8"
      Chgfmt [M:STC3]RNWOP     With "-N:8"
      Chgfmt [M:STC3]CCNEND    With "-N:8"
    Else
      Chgfmt [M:STC3]RNWBCO    With "N:8"
      Chgfmt [M:STC3]RNWOP     With "N:8"
      Chgfmt [M:STC3]CCNEND    With "N:8"

      Local Integer NBE

      Call IS_BCO_NOT_RNW_NBE([F:WCNX]CPY, NBE) From GLOCCN
      [M:STC3]RNWBCO = NBE

      Call IS_RNWOP_NOT_DONE_NBE([F:WCNX]CPY, NBE) From GLOCCN
      [M:STC3]RNWOP = NBE

      Call IS_CCNEND_NOT_DONE_NBE([F:WCNX]CPY, NBE) From GLOCCN
      [M:STC3]CCNEND = NBE
  Endif
Return

$CIG
 Global Char    LISTCIG(10)(1..100)
 Global Char    LISTCIGDES(50)(1..100)
 Global Integer LISTCIGSTA(1..100)
 Global Integer LISTCIGNBBCO(1..100)
 Local  Integer CDRET

 Local  Integer LIMITE : LIMITE = 100

 CDRET = 0
 nolign = 1

 If func GLOBIENS.CTRL_CPY_CIG([M:STC0]CPY, "", LISTCIG, LISTCIGDES, LISTCIGSTA, LISTCIGNBBCO, CDRET)<>0 Then
   For  nolign = 1 To 100
     If nolign > LIMITE or LISTCIG(nolign) = ""
       Break
     Endif
     [M:STC3]CIGCOD(nolign-1)   = LISTCIG(nolign)
     [M:STC3]CIGDES(nolign-1)   = LISTCIGDES(nolign)
     [M:STC3]CIGSTA(nolign-1)   = LISTCIGSTA(nolign)
     [M:STC3]CIGNBBCO(nolign-1) = LISTCIGNBBCO(nolign)
   Next
 Endif

 [M:STC3]NB_CIG = nolign - 1
Return

$BIENS_INACTIFS
  Local Integer LIMITE : LIMITE = 999

  nolign = 1
  #FQ93596 For [F:WFAS]FAS0 Where CPY=[M:STC0]CPY and ENAFAS=G_NON
  For [F:WFAS]FAS7 Where CPY=[M:STC0]CPY and ENAFAS=G_NON
    If nolign > LIMITE
      Break
    Endif

    [M:STC3]AASREFD(nolign-1) = [F:WFAS]AASREF
    nolign += 1
  Next

  [M:STC3]NB_DISAFAS = nolign - 1
Return

# Biens classés pour vente non sortis FQ95754
$BIENS_CLASSES_VENTE
  Local Integer LIMITE : LIMITE = 999
  Local Char    RTLSTFAS(GLONVC9)(LIMITE)

  If func GLOBIENS.HAS_FAS_SALCLS_FILLTAB([M:STC0]CPY, G_OUI, [F:WFIS]DATENDFIY, RTLSTFAS) = G_OUI
    nolign = 1

    While RTLSTFAS(nolign-1) <> "" and not(nolign >= LIMITE)
      [M:STC3]AASREFCLS(nolign-1) = RTLSTFAS(nolign-1)
      nolign += 1
    Wend
  Endif

  [M:STC3]NB_SALCLS = nolign - 1
Return

######################################################################################
# FILTRES
######################################################################################
#*
#* Crée une jointure [FASD] filtrant les amortissements non calculés pour la
#* période courante
#*!
$FILTRE_NB_NOCAL
#    FQ93731 Amélioration requète ~ et sel sur CPY des 2 tables
    If [F:WFIS]DATENDPER([F:WFIS]INDCURPER-1) = [F:WFIS]DATENDFIY
      Link [WFAS] With [WDEP]DEP0 ~= [WFAS]AASREF As [FASD]
&     Where [WFAS]CPY=[M:STC0]CPY and [WDEP]CPY=[M:STC0]CPY and [WDEP]DPRPLN=[F:WCNX]PLNCAA(N_I-1) and [WDEP]PERENDDAT=[M:STC0]PERENDDAT
&       and ([WDEP]DEPSTA=GVML_SCNOCAL or [WFAS]FLGCNXCLC([M:STC0]CNX-1)=GVML_RCCLO)
    Else
      Link [WFAS] With [WDEP]DEP0 ~= [WFAS]AASREF As [FASD]
&     Where [WFAS]CPY=[M:STC0]CPY and [WDEP]CPY=[M:STC0]CPY and [WDEP]DPRPLN=[F:WCNX]PLNCAA(N_I-1) and [WDEP]PERENDDAT=[M:STC0]PERENDDAT
&       and [WDEP]DEPSTA=GVML_SCNOCAL
    Endif
Return

######################################################################################
$COLORISATION
  Local Integer N_I
  Local Char PCHAMP(100)

  # Ecran STC1
  Default Mask [STC1]
  For N_I = 0 To  [M:STC1]NB_NOCNX-1
    Call SET_COLOR_NUM("UPDWAIBCO("+num$(N_I)+")")
  Next
  For N_I = 0 To  [M:STC1]NB_NOCAL-1
    Call SET_COLOR_NUM("NBC("+num$(N_I)+")")
  Next
  Call SET_COLOR_NUM("RPRNOCAL")

  # Ecran STC2
  Default Mask [STC2]
  For N_I = 0 To [M:STC2]NB_NOPOST-1
    If [M:STC2]NBP(N_I) > 0
      If [M:STC2]FLGCLOPER = G_OUI
        Chgstl NBP(N_I) With "BACKYELLOW"
      Else
        Chgstl NBP(N_I) With "BACKRED"
      Endif
    Else
      Chgstl NBP(N_I) With "BACKGREEN"
    Endif
  Next
  For N_I = 0 To [M:STC2]NB_DOT-1
    If [M:STC2]NBD(N_I) > 0
      If [M:STC2]FLGCLOPER = G_OUI and [M:STC2]FLGDEFPER<>"128"
        Chgstl NBD(N_I) With "BACKYELLOW"
      Else
        Chgstl NBD(N_I) With "BACKRED"
      Endif
    Else
      Chgstl NBD(N_I) With "BACKGREEN"
    Endif
  Next
  For N_I = 0 To [M:STC2]NB_LNK-1
    If [M:STC2]NBL(N_I) > 0
      If [M:STC2]FLGCLOPER = G_OUI and [M:STC2]FLGDEFPER<>"128"
        Chgstl NBL(N_I) With "BACKYELLOW"
      Else
        Chgstl NBL(N_I) With "BACKRED"
      Endif
    Else
      Chgstl NBL(N_I) With "BACKGREEN"
    Endif
  Next
  Call SET_COLOR_NUM("RPRPST")

  # Ecran STC3
  Default Mask [STC3]
  For N_I = 0 To [M:STC3]NB_CIG-1
    Call SET_COLOR_NUM("CIGNBBCO("+num$(N_I)+")")
  Next
  For N_I = 0 To [M:STC3]NB_DISAFAS-1
    Chgstl [M:STC3]AASREFD(N_I) With "BACKRED"
  Next
  # FQ95754
  If [M:STC2]FLGCLOPER = G_NON
    For N_I = 0 To [M:STC3]NB_SALCLS-1
      Chgstl [M:STC3]AASREFCLS(N_I) With "BACKRED"
    Next
  Endif
  If G_ACTCCN = G_OUI
    If [M:STC3]RNWBCO > 0
      If [M:STC2]FLGCLOPER = G_OUI
        Chgstl RNWBCO With "BACKYELLOW"
      Else
        Chgstl RNWBCO With "BACKRED"
      Endif
    Else
      Chgstl RNWBCO With "BACKGREEN"
    Endif
    If [M:STC3]RNWOP > 0
      If [M:STC2]FLGCLOPER = G_OUI
        Chgstl RNWOP With "BACKYELLOW"
      Else
        Chgstl RNWOP With "BACKRED"
      Endif
    Else
      Chgstl RNWOP With "BACKGREEN"
    Endif
    If [M:STC3]CCNEND > 0
      Chgstl CCNEND With "BACKYELLOW"
    Else
      Chgstl CCNEND With "BACKGREEN"
    Endif
  Endif
Return

######################################################################################
Subprog SET_COLOR_NUM(PCHAMP)
Value Char PCHAMP
  If evalue("dim("+PCHAMP+")") < 0 : End : Endif

  If evalue(PCHAMP)>0
    Chgstl =PCHAMP With "BACKRED"
  Else
    Chgstl =PCHAMP With "BACKGREEN"
  Endif
End

######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
  [M:STC0]CPY=VALEUR

  Call AM_CNX(G300CPFI)
End

Subprog AS_CNX(VALEUR)
Variable Integer VALEUR
  Local Integer N_I

  For N_I = 0 To G300MAX
    Look [WCNX]CNX0=[M:STC0]CPY;N_I

    If fstat : GMENLOC(N_I) = 1 : Endif
  Next
End

Subprog AM_CNX(VALEUR)
Variable Integer VALEUR
  [M:STC0]CNX=VALEUR

  Read [WFIS]FIY1=[M:STC0]CPY;[M:STC0]CNX;GVML_TECOURA

  [M:STC0]PERSTRDAT = [F:WFIS]DATSTRPER([F:WFIS]INDCURPER-1)
  [M:STC0]PERENDDAT = [F:WFIS]DATENDPER([F:WFIS]INDCURPER-1)

  Gosub MAJ_FENETRE
End

######################################################################################

Subprog AS_FLGCLOPER(VALEUR)
Variable Integer VALEUR
  mkstat=2
End

Subprog AS_FLGCLOEXE(VALEUR)
Variable Integer VALEUR
  mkstat=2
End
