#<AdxTL>@(#)9.0.0.0 $Revision$ 
######################################################################
# BONPREPA          : Impression : Bon de preparation
######################################################################

$ACTION
Case ACTION
 When "EXEC"        : Gosub EXEC
Endcase
Return

############################################################################
# Avant l'impression du document, chargement paramètres si impression auto #
# ------------------------------------------------------------------------ #
# Nota : On force le nombre de copies à 1 car on a écrit dans la table     #
#        AREPORTM, les enregistrements en fonction du nombre de copie.     #
############################################################################
$EXEC

#----- Ne rien faire si pas impression auto, cela se fera par le Call IMPRIME -----#
If dim([V]GWNUMREQ)<1 | dim([V]GWSEQREQ)<1 | dim([V]GWTRTAUTO)<1 | [V]GWTRTAUTO<>1
  Return
Endif
#-----
If dim(I)<1       Local Integer I             : Endif
If dim(J)<1       Local Integer J             : Endif
If dim([L]ETAT)<1 Local Char    ETAT(GLONARP) : Endif
#-----

For I=1 To [L]NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  Case [L]PARAM
   When "X3ETA"          : Call GETPARAM ([L]PARAM,[L]NBPAR,[L]PARAMETRE,[L]ETAT) From ETAT
   When "X3LAN"          : [L]PARAMETRE(I) = "X3LAN="+GLANGUE
   When "__REQUETE"      : [L]PARAMETRE(I) = "__REQUETE="+num$([V]GWNUMREQ)
   When "_PrinterCopies" : [L]PARAMETRE(I) = "_PrinterCopies="+chr$(1)+"1"
   When "numedt"         : [L]PARAMETRE(I) = "numedt="+num$([V]GWNUMREQ)
   When "seqedt"         : [L]PARAMETRE(I) = "seqedt="+num$([V]GWSEQREQ)
   When "usr"            : [L]PARAMETRE(I) = "usr="+GUSER
   When "etat"           : [L]PARAMETRE(I) = "etat="+[L]ETAT
   When "traitauto"      : [L]PARAMETRE(I) = "traitauto=1"
 Endcase
 Endif
Next I
Return

############################################################################
# Appelé par le Call ETAT                                                  #
#   après l'action EXEC                                                    #
#   avant l'impression du document                                         #
############################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

#----- Si impression auto ne rien faire AREPORTM est déjà chargé -----#
If dim([V]GWTRTAUTO)>0 & [V]GWTRTAUTO=1  End : Endif
#----- Ouverture des tables -----#
Local File AREPORTM  [ARM]
Local File STOPREH   [PRH]
Local File STOPRED   [PRE]
Local File SORDER    [SOH]
#----- Déclaration des variables locales -----#
Local Char    CRITERE(255), PARAM(30) , VALEUR(30) , ETAT(GLONARP),CRITERE1(255)
Local Integer NUMREQ, IMPR, I, J
Local Date    DATREF
Local Integer TRAITAUTO

#----- Chargement des paramètres et du filtre -----#
[L]CRITERE="1=1"
[L]CRITERE1="1=1"
#-----
For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  Call GETPARAM ([L]PARAM,[L]NBPAR,[L]PARAMETRE,[L]VALEUR) From ETAT
  Case [L]PARAM
   When "X3ETA"          : [L]ETAT     = [L]VALEUR
   When "__REQUETE"      : [L]NUMREQ   = val([L]VALEUR)
   When "sitedeb"        : [L]CRITERE -= "& STOFCY>='"+[L]VALEUR+"'"
   When "sitefin"        : [L]CRITERE -= "& STOFCY<='"+[L]VALEUR+"'"
   When "preparationdeb" : [L]CRITERE -= "& PRHNUM>='"+[L]VALEUR+"'"
   When "preparationfin" : [L]CRITERE -= "& PRHNUM<='"+[L]VALEUR+"'"
   When "clientdeb"      : [L]CRITERE -= "& BPCORD>='"+[L]VALEUR+"'"
   When "clientfin"      : [L]CRITERE -= "& BPCORD<='"+[L]VALEUR+"'"
   # Issue 59336 - 2013-08-22 by MAE : ajout bornes sur liste de prépa
   When "listedeb"       : If [L]VALEUR<>' ' : [L]CRITERE1 -= "& PRLNUM>='"+[L]VALEUR+"'"  : Endif
   When "listefin"       : If [L]VALEUR<>' ' : [L]CRITERE1 -= "& PRLNUM<='"+[L]VALEUR+"'"  : Endif
   #Fin MAE 59336
   When "etatdeb"        : [L]CRITERE -= "& DLVFLG>=" +[L]VALEUR
   When "etatfin"        : [L]CRITERE -= "& DLVFLG<=" +[L]VALEUR
   When "colisagedeb"    : [L]CRITERE -= "& PACFLG>=" +num$(val([L]VALEUR)+1)
   When "colisagefin"    : [L]CRITERE -= "& PACFLG<=" +num$(val([L]VALEUR)+1)
   When "codimp"         : [L]CRITERE -= "& PRNNPR="  +[L]VALEUR
                           [L]IMPR     = val([L]VALEUR)
   When "X3LAN"          : [L]PARAMETRE(I) = "X3LAN="+GLANGUE
   When "numedt"         : [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
   When "seqedt"         : [L]PARAMETRE(I) = "seqedt=0"
   When "usr"            : [L]PARAMETRE(I) = "usr="+GUSER
   When "etat"           : [L]PARAMETRE(I) = "etat="+[L]ETAT
   When "traitauto"      : If [L]VALEUR="1" [L]TRAITAUTO=1 : Break Endif
 Endcase
 Endif
Next

# les maj tables AREPORTM et STOPRH déjà effectuées si on est dans livraison auto.
If [L]TRAITAUTO = 1 End Endif

#------------------------------------------------------------------#
#  - Création d'un seul enregistrement dans AREPORTM               #
#  - Mise à jour indicateur d'impression sur l'entête de livraison #
#------------------------------------------------------------------#
Call DEBTRANS From GLOCK
Trbegin [ARM], [PRH]
#----- Chargement buffer AREPORTM -----#
Raz [F:ARM]
[F:ARM]USR    = GUSER
[F:ARM]RPTCOD = [F:ARP]RPTCOD
[F:ARM]NUMREQ = [L]NUMREQ
[F:ARM]CREDAT = date$
#-----
# Création du filtre selon les sélections.
For [PRH] PRH0 Where evalue([L]CRITERE +"&"+[L]CRITERE1)
  #----- Création d'un enregistrement dans la table AREPORTM -----#
  [F:ARM]NUMLIG+= 1
  [F:ARM]CLEA1  = [F:PRH]PRHNUM
  #MAE, bg 71162
  #MAE, bg 84725, raz des zones CLEA2, CLEA3 et CLEA4
  Raz [F:ARM]CLEA2, [F:ARM]CLEA3,[F:ARM]CLEA4
  If [F:PRH]ORIPRH <> 3
    Read [PRE]PRE0 = [F:PRH]PRHNUM
        If fstat GOK = 0 : Endif
    If [F:PRE]ORINUM <> ''
        Read [SOH]SOH0 = [F:PRE]ORINUM
            If fstat GOK = 0 : Endif
    Endif
    #si le client livré est sur la commande, on liras l'adresse sur la commande dans l'état
    #sinon, on récupére le client livré dans le BP
    If [F:SOH]BPDNAM <> ''
        [F:ARM]CLEA2 = [F:PRE]ORINUM        #commande origine du BP
    Else
        [F:ARM]CLEA3 = [F:PRH]BPCORD        #nom du client livré
        [F:ARM]CLEA4 = [F:PRH]BPAADD        #adresse du client livré
    Endif
  Else
        [F:ARM]CLEA3 = [F:PRH]BPCORD        #nom du client livré
        [F:ARM]CLEA4 = [F:PRH]BPAADD        #adresse du client livré
  Endif

  Gosub ALIMETAT_PE From ETAT
  Write [ARM]
  If fstat  GOK=0 : Call FSTA("ARM") From GLOCK : Break : Endif
  #----- Mise à jour table entête livraison si demande d'impression -----#
  If [L]IMPR=1
    Update [PRH] Where PRHNUM=[F:ARM]CLEA1 With PRNNPR=2
    If fstat  GOK=0 : Call FSTA("SDH") From GLOCK : Break : Endif
  Endif
  #-----
Next

If !fstat
  Commit
Else
  Rollback
Endif

End


###########################################################################
# Appelé par Gosub depuis le traitement TRTX3ETA                          #
# ----------------------------------------------------------------------- #
#   - Création d'un enregistrement par copie désirée dans AREPORTM        #
#   - Mise à jour indicateur d'impression sur l'entête du document        #
# ----------------------------------------------------------------------- #
# Les variables locales suivantes sont disponibles :                      #
#     WADXLOG  = Indicateur transaction (0 = pas de transaction en cours) #
#     ETAT     = Code de l'état                                           #
#     REQUETE  = Numéro de requête                                        #
#     LIGNE    = Numéro de ligne de AREPORTM                              #
#     SEQUENCE = Numéro de séquence de AREPORTM                           #
# Le buffer [F:SDH] est chargé et l'entête est écrite                     #
###########################################################################
$ALIM_ETAT

#Default File [PRH]
# si plusieurs etats garnir la bonne classe [F]
#If ETAT<>[F:ARP]RPTCOD
#  Read [ARP] ARP0=ETAT
#Endif
#[V]GWNUMREQ = REQUETE

# création dans AREPORTM et maj flag édition dans STOPREH
Call DEBTRANS From GLOCK
#WNUMLIG=LIGNE
Gosub TR1
#LIGNE=WNUMLIG
Return

$TR1
If !adxlog
   Trbegin [PRH] , [ARM]
Endif

   # Mise à jour table entête Bon de Préparation si demande d'impression
   # If [L]IMPR = 1
    Readlock [F:PRH]PRH0=[F:PRH]PRHNUM
    If fstat = 1 : GOK = -1 : GLOCK = "$STOPREH"                             : Goto ROLL_TR1
    Elsif fstat  : GOK = 0  : Call RSTA("PRH","*") From GLOCK                : Goto AB_TR1
    Endif
    [F:PRH]PRNNPR = 2

    Rewrite [F:PRH]
    If fstat=1   : GOK = -1 : GLOCK = "$STOPREH"-[F:PRH]PRHNUM               : Goto ROLL_TR1
    Elsif fstat  : GOK = 0  : Call RSTA("SSTOPREH",[F:PRH]PRHNUM) From GLOCK : Goto AB_TR1
    Endif
    # Création de l'enregistrement dans la table AREPORTM
    #LIGNE      += 1
    Raz [F:ARM]
    [F:ARM]USR     = GUSER
    [F:ARM]RPTCOD  = ETAT
    [F:ARM]NUMREQ  = REQUETE
    [F:ARM]NUMLIG  = LIGNE
    [F:ARM]SEQREQ  = SEQUENCE
    [F:ARM]CLEA1   = [F:PRH]PRHNUM
    [F:ARM]CREDAT  = date$

    #MAE, bg 71162
    If [F:PRH]ORIPRH <> 3
        Read [PRE]PRE0 = [F:PRH]PRHNUM
            If fstat GOK = 0 : Endif
        If [F:PRE]ORINUM <> ''
            Read [SOH]SOH0 = [F:PRE]ORINUM
            If fstat GOK = 0 : Endif
        Endif
        #si le client livré est sur la commande, on liras l'adresse sur la commande dans l'état
        #sinon, on récupére le client livré dans le BP
        If [F:SOH]BPDNAM <> ''
            [F:ARM]CLEA2 = [F:PRE]ORINUM        #commande origine du BP
        Else
            [F:ARM]CLEA3 = [F:PRH]BPCORD        #nom du client livré
            [F:ARM]CLEA4 = [F:PRH]BPAADD        #adresse du client livré
        Endif
    Else
        [F:ARM]CLEA3 = [F:PRH]BPCORD        #nom du client livré
        [F:ARM]CLEA4 = [F:PRH]BPAADD        #adresse du client livré
    Endif

    For I=1 To max(NBRCOPIE,1)
     [F:ARM]NUMLIG+=1
     Gosub ALIMETAT_PE From ETAT
     Write [ARM]
     If fstat  GOK=0 : Call FSTA("ARM") From GLOCK : Break : Endif
    Next I

    If fstat : Goto ROLL_TR1 : Endif

    LIGNE   =[F:ARM]NUMLIG
    SEQUENCE=[F:ARM]SEQREQ

Commit
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$AB_TR1
Rollback
Return

##########################################################################
