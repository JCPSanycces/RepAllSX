#<AdxTL>@(#)0.0.0.0 $Revision$
# Representation ALNKSUB  Subdivision links

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AQUERY_DECODE_CRITERIA_AFTER" : Gosub AQUERY_DECODE_CRITERIA_AFTER
      When "AQUERY_PRIMARYKEYS_AFTER"     : Gosub AQUERY_PRIMARYKEYS_AFTER
      When "AQUERY_OPEN_AFTER"            : Gosub AQUERY_OPEN_AFTER
      When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
      When "AQUERY_CLOSE_AFTER"           : Gosub AQUERY_CLOSE_AFTER
    Endcase
  When "ALNKSUB.COLALB"
    Case [L]AEVENT
      When "AREAD_AFTER"            : Gosub COLALB_AREAD_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "ALNKSUB.TYP"    Gosub ALNKSUB_TYP
  When "ALNKSUB.CRY"    Gosub ALNKSUB_TYP # For changes to CRY during create
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return





############################################################################################################
$AQUERY_DECODE_CRITERIA_AFTER
Raz NBPRO
NBPRO += 1
TBPRO(NBPRO) = "CRY" : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "ALNKSUB.CRY" : TBFIL(NBPRO) = "[LNK_]CRY"
NBPRO += 1
TBPRO(NBPRO) = "TYP" : TBTYP(NBPRO) = 7 : TBPTH(NBPRO) = "ALNKSUB.TYP" : TBFIL(NBPRO) = "[LNK_]TYP"
Return

$AQUERY_PRIMARYKEYS_AFTER
ASTDKEY = "[LNK_]CRY"
Return

$AQUERY_OPEN_AFTER
Local File ALNKSUB [QRY_ALB]
Local Integer I : I=0
Local Char TCRY(12)(1..)
Local Integer TTYP(1..)
For [QRY_ALB]ALB0(2)
 I+=1
 TCRY(I) = [F:QRY_ALB]CRY
 TTYP(I) = [F:QRY_ALB]TYP
Next
If I=0
 Local File ALNKSUB [LNK_]
Else
 Local File (Char CRY(100),Integer TYP) From Variable TCRY,TTYP As [LNK_]
Endif
Return



$AQUERY_TRANS_AFTER
this.ALNKSUB.CRY = [LNK_]CRY
this.ALNKSUB.TYP = [LNK_]TYP
Return

$AQUERY_CLOSE_AFTER
Close Local File [LNK_]
Return


$ALNKSUB_TYP
Case [L]ARULE
  When "PROPAGATE"       Gosub ALNKSUB_DISPLAY
Endcase
Return


$ALNKSUB_DISPLAY
# Hide subdivision entry is possible. GMENLOC alternative would be better
If this.CRY<>AVOID.ACHAR
  If fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"ETATFLG")=[V]CST_AYES &
&   fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"ETATFLG2")=[V]CST_AYES
    [L]ASTATUS = fmet this.ASETATTRIBUTE("TYP","$isDisabled", "false")
  Return
  Else
    [L]ASTATUS = fmet this.ASETATTRIBUTE("TYP","$isDisabled", "true")
  Endif
Endif

Return

$COLALB_AREAD_AFTER

[L]ASTATUS = fmet this.ASETATTRIBUTE("POS", "$isDisabled", "true")

Return

