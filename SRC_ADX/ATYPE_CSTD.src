# Classe ATYPE

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
    Endcase
  When "ACOLACT"
    Case [L]AEVENT
       When "AREAD_AFTER" : Gosub READ_AFTER_ACOLACT
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "TYPTYP"                   : Gosub TYPTYP
  When "LNGTYP"                   : Gosub LNGTYP
  When "FORTYP"                   : Gosub FORTYP
  When "OPTION"                   : Gosub OPTION
  When "OPTTAB"                   : Gosub OPTTAB
  When "PARTAB"                   : Gosub PARTAB
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return





$READ_AFTER_ACOLACT
this.AACTION = [F:ATY]ACTION(this.AORDER-1)
Return


$TYPTYP
Case [L]ARULE
  When "PROPAGATE"                : Gosub TYPTYP_PROPAGATE
Endcase
Return


$LNGTYP
Case [L]ARULE
  When "PROPAGATE"                : Gosub LNGTYP_PROPAGATE
Endcase
Return

$FORTYP
Case [L]ARULE
  When "CONTROL"                  : Gosub FORTYP_CONTROL
Endcase
Return

$OPTION
Case [L]ARULE
  When "CONTROL"                  : Gosub OPTION_CONTROL
Endcase
Return

$OPTTAB
Case [L]ARULE
  When "PROPAGATE"                : Gosub OPTTAB_PROPAGATE
Endcase
Return

$PARTAB
Case [L]ARULE
  When "PROPAGATE"                : Gosub PARTAB_PROPAGATE
Endcase
Return

$OPTTAB_PROPAGATE
#Variable format
If this.OPTTAB = [V]CST_AYES
  this.PARTAB=""
Endif
Return

$PARTAB_PROPAGATE
If this.PARTAB <> ""
  this.VARTAB=""
Endif
Return





$TYPTYP_PROPAGATE
# Enable local menu field
If this.TYPTYP <> 1
  this.NOLIB = 0
Endif
#Gosub CHGT_SYR
Return

$LNGTYP_PROPAGATE
# Enable Adonix format field
If this.LNGTYP <= 0
  this.FORTYP = 0
  Endif
Return

