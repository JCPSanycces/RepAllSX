#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Representation Class EDIFCYPAR                                              #
# Author : RBA + JUCON                                                        #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
         When "AQUERY_TRANS_AFTER"    : Gosub AQUERY_TRANS_AFTER
      Endcase
    When "EFP"
      Case [L]AEVENT
        When "AREAD_AFTER"           : Gosub EFP_AREAD_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#    When "MYOPERATION" : Gosub OPE_MYOPERATION
#  Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  #Init SAM 110811  - Identication ID type
  Case CURPRO
    When "EFP.FCY"      # : Gosub EFP_FCY
      Case [L]ARULE
        When "PROPAGATE" : Gosub EFP_FCY_PROPAGATE
      Endcase
    When "EFP.IDTYPE"  # : Gosub EFP_IDTYPE
      Case [L]ARULE
        When "PROPAGATE" : Gosub EFP_IDTYPE_PROPAGATE
      Endcase
  Endcase
Return

####################################################################

$EFP_FCY_PROPAGATE
  If this.FCY<>""
    Local File FACILITY [FCY]
    Read[FCY]FCY0=this.FCY
    If !fstat
      this.APARENT.LOCODE =[F:FCY]CRN
    Endif
    LogicClose File [FCY]
  Endif
Return

####################################################################

$EFP_IDTYPE_PROPAGATE
  Call EFP_EFP_DISPLAY(this)
Return
#End SAM 110811

####################################################################

#********************************************************************
# Method AQUERY_TRANS_AFTER
#********************************************************************
#*
#*!
$AQUERY_TRANS_AFTER
  this.EFP.FCYNAM = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.EFP.FCY,"FCYNAM")
  this.EFP.PARDES = fmet this.ACTX.ACACHE.EPR.AGETVALCHAR(this.EFP.PARCOD,"PARDES")
Return

#********************************************************************
# Method EFP_AREAD_AFTER
#********************************************************************
#*
#*!
$EFP_AREAD_AFTER
  this.FCYNAM = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.FCY,"FCYNAM")
  this.PARDES = fmet this.ACTX.ACACHE.EPR.AGETVALCHAR(this.PARCOD,"PARDES")

  Local File FACILITY [FCY]
  Read[FCY]FCY0=this.FCY
  If !fstat
    this.APARENT.LOCODE= [F:FCY]CRN
  Endif
  LogicClose File [FCY]

  Call EFP_EFP_DISPLAY(this)      #SAM 110811
Return

#SAM 110811 US6
#********************************************************************
# Subprog EFP_EFP_DISPLAY
#********************************************************************
#
#* @param WOBJECT
#*!
Subprog EFP_EFP_DISPLAY(WOBJECT)
Variable Instance WOBJECT Using OBJECT
  Local Integer WOK
  Local Char WPROP(15)

  WPROP = "$isDisabled"

  Case WOBJECT.IDTYPE
    When 6       :  WOK = fmet WOBJECT.ASETATTRIBUTE('EXCEDICOD', WPROP, 'false')
    When Default :  WOK = fmet WOBJECT.ASETATTRIBUTE('EXCEDICOD', WPROP, 'true')
  Endcase

End
#/ SAM 110811 US6

