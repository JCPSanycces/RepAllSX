########################################################################
Subprog CTLALPV (VALFIN,VALDEB)
#-----------------------------------------------------------------------#
# Contrôle borne fin supérieure ou égale à borne début (alphanumériques)#
#-----------------------------------------------------------------------#
Value Char VALDEB
Value Char VALFIN
If VALFIN<>"" & VALFIN<VALDEB
 # La borne fin est inférieure à la borne début
 GMESSAGE = mess(257,139,1) : mkstat = 2
Endif
End

########################################################################
Subprog CTLNUMV (NUMFIN,NUMDEB)
#-----------------------------------------------------------------------#
# Contrôle borne fin supérieure ou égale à borne début (numériques)     #
#-----------------------------------------------------------------------#
Value Decimal NUMDEB
Value Decimal NUMFIN
If NUMFIN<>0 & NUMFIN<NUMDEB
 # La borne fin est inférieure à la borne début
 GMESSAGE = mess(257,139,1) : mkstat = 2
Endif
End

########################################################################
Subprog CTLDATV (VALFIN,VALDEB)
#-----------------------------------------------------------------------#
# Contrôle borne fin supérieure ou égale à borne début (alphanumériques)#
#-----------------------------------------------------------------------#
Value Date VALDEB
Value Date VALFIN
If VALFIN<>[00/00/00] & VALFIN<VALDEB
 # La borne fin est inférieure à la borne début
 GMESSAGE = mess(257,139,1) : mkstat = 2
Endif
End

########################################################################
Subprog CTLLIBV (NUMFIN,NUMDEB)
#-----------------------------------------------------------------------#
# Contrôle borne fin supérieure ou égale à borne début (numériques)     #
#-----------------------------------------------------------------------#
Value Integer NUMDEB
Value Integer NUMFIN
If NUMFIN<>0 & NUMFIN<NUMDEB
 # La borne fin est inférieure à la borne début
 GMESSAGE = mess(257,139,1) : mkstat = 2
Endif
End

