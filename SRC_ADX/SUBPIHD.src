#<AdxTL>@(#)11.0.0.0 $Revision$
# SUBPIHD : Gestion des factures d'achat                   MBT 15/11/99 #
# --------------------------------------------------------------------- #
# Traitements complémentaires de l'objet "PIH"                          #
# Les traitements sur champ "Call"     se trouvent dans le SUBPIH       #
# Les actions "Gosub" de l'objet "PIH" se trouvent dans le SUBPIHA      #
# Les traitements complémentaires -1-  se trouvent dans le SUBPIHB      #
# Les traitements complémentaires -2-  se trouvent dans le SUBPIHC      #
#########################################################################

$ACTION
#------------------------------------------------------------------#
# Actions sur la saisie de fenêtre des factures d'achats (GSAISIE) #
# SAICRITPIH : Saisie des critères de picking                      #
# SAIFACCPIH : Saisie picking factures complémentaires             #
#------------------------------------------------------------------#
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "OK"          : Gosub OK
 When "ABA"         : Gosub ABA
 When "APRES_MODIF" : REP="M"
 When "SETBOUT"     : Gosub SETBOUT
 When "FINSAI"      : Gosub FINSAI
#------------------------------------------------------------------------#
# Actions sur la sélection dans une table (GACTION)                      #
# SELPIHNUMO : Sélection du numéro origine (cde, récept, retour ou fact) #
#------------------------------------------------------------------------#
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "FIN_TABLE"   : Gosub FIN_TABLE
Endcase
Return

####################################################################
# Actions sur la saisie de fenêtre des factures d'achats (GSAISIE) #
# ---------------------------------------------------------------- #
# SAICRITPIH : Saisie des critères de picking                      #
# SAIFACCPIH : Saisie picking factures complémentaires             #
####################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUVRE
Case GACTION
 When "SAIFACCPIH"  : Gosub OUVRE_SAIFACCPIH
Endcase
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEBUT
Case GACTION
 When "SAICRITPIH"  : Gosub DEBUT_SAICRITPIH
 When "SAIFACCPIH"  : Gosub DEBUT_SAIFACCPIH
Endcase
Return
#--------------------------------#
# Après l'exécution du bouton OK #
#--------------------------------#
$OK
Case GACTION
 When "SAICRITPIH"  : Gosub OK_SAICRITPIH
 When "SAIFACCPIH"  : Gosub OK_SAIFACCPIH
Endcase
Return
#-------------------------------------#
# Après l'exécution du bouton ABANDON #
#-------------------------------------#
$ABA
Case GACTION
 When "SAICRITPIH"  : Gosub ABA_SAICRITPIH
 When "SAIFACCPIH"  : Gosub ABA_SAIFACCPIH
Endcase
Return
#-------------------------------------#
# Avant grisage/dégrisage des boutons #
#-------------------------------------#
$SETBOUT
Case GACTION
 When "SAIFACCPIH"  : Gosub SETB_SAIFACCPIH
Endcase
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI
Case GACTION
 When "SAIFACCPIH" : Gosub FINSAI_SAIFACCPIH
Endcase
Return

##########################################################################
# Actions sur la sélection dans une table (GACTION)                      #
# ---------------------------------------------------------------------- #
# SELPIHNUMO : Sélection du numéro origine (cde, récept, retour ou fact) #
##########################################################################
#--------------------------------------------#
# Avant ouverture de la fenêtre de sélection #
#--------------------------------------------#
$SEL_TABLE
Case GACTION
 When "SELPIHNUMO" : Gosub SEL_SELPIHNUMO
Endcase
Return
#------------------------#
# Sortie de la sélection #
#------------------------#
$FIN_TABLE
Case GACTION
 When "SELPIHNUMO" : Gosub FIN_SELPIHNUMO
Endcase
Return


#########################################################################
# SAISIE_CRIT : S/P de saisie des critères du picking de préchargement  #
#               des lignes de facture                                   #
# --------------------------------------------------------------------- #
# Remplacé par l'action SAICRITPIH sans paramètre          MBT 17/11/00 #
#########################################################################
#---------------------------------------------------------#
# Après l'ouverture de la fenêtre des critères de picking #
#---------------------------------------------------------#
$DEBUT_SAICRITPIH
GBIDI1=1
[M:PCI1]=[M:PCIW]
Case [M:PIH0]PIHTYP
  When 1 : Raz [M:PCI1]WNUMRET, [M:PCI1]WNUMFAC
  When 2 : Raz [M:PCI1]WNUMCDE, [M:PCI1]WNUMRCP, [M:PCI1]WBPSNDE, [M:PCI1]WNUMRET
  When 3 : Raz [M:PCI1]WNUMCDE, [M:PCI1]WNUMRCP, [M:PCI1]WBPSNDE, [M:PCI1]WNUMRET
           [M:PCI1]WNUMFAC=[M:PIH1]INVNUM
  When 4 : Raz [M:PCI1]WNUMCDE, [M:PCI1]WNUMRCP, [M:PCI1]WBPSNDE, [M:PCI1]WNUMFAC
Endcase
[M:PCI1]BPSINV=[M:PIH0]BPR
#----- Affichage foreground -----#
Actzo [PCI1] : Affzo [PCI1]
Case [M:PIH0]PIHTYP
  When 1 : Grizo [PCI1]WNUMRET, WNUMFAC
  When 2 : Grizo [PCI1]WNUMCDE, WNUMRCP, WBPSNDE, WNUMRET
  When 3 : Grizo [PCI1]WNUMCDE, WNUMRCP, WBPSNDE, WNUMRET, WNUMFAC
  When 4 : Grizo [PCI1]WNUMCDE, WNUMRCP, WBPSNDE, WNUMFAC
Endcase
Return
#--------------------------------#
# Après l'exécution du bouton OK #
#--------------------------------#
$OK_SAICRITPIH
Raz GBIDI1
#----- Validation des critères (suppression des espaces parasites) -----#
[M:PCI1]WNUMCDE=vireblc([M:PCI1]WNUMCDE,2)
[M:PCI1]WNUMRCP=vireblc([M:PCI1]WNUMRCP,2)
[M:PCI1]WBPSNDE=vireblc([M:PCI1]WBPSNDE,2)
[M:PCI1]WNUMRET=vireblc([M:PCI1]WNUMRET,2)
[M:PCI1]WNUMFAC=vireblc([M:PCI1]WNUMFAC,2)
[M:PCI1]WITMREF=vireblc([M:PCI1]WITMREF,2)
[M:PCIW]=[M:PCI1]
FIN=1
Return
#-------------------------------------#
# Après l'exécution du bouton ABANDON #
#-------------------------------------#
ABA_SAICRITPIH
[M:PCI1]=[M:PCIW] : Raz REP
Affzo [PCI1]1-99
Return


#########################################################################
# PRECHARGEMENT : S/P de préchargement des lignes de facture            #
#    TRAIT : Code traitement                                            #
#               1 = Préchargement à partir des commandes ou réceptions  #
#               2 = Préchargement à partir des factures                 #
#               3 = Préchargement à partir d'une facture                #
#               4 = Préchargement à partir des retours                  #
#               5 = Préchargement à partir des commandes                #
#               6 = Préchargement à partir des réceptions               #
#    INDIC : Indicateur d'appel  0 = depuis barre de menu               #
#                                1 = depuis tableau des lignes          #
#        à la sortie du S/P -->  9 = pour activation touche enregistrer #
# --------------------------------------------------------------------- #
# Remplacé par les actions PICKE et DEPICK de l'objet PIH  MBT 31/10/00 #
#########################################################################

################################################
# Préchargement facture à partir des commandes #
################################################
#-----------------------------------#
# Sélection d'une ligne de commande #
#-----------------------------------#
$PICKE_CDE
If [M:PIH0]PIHTYP<>1  OK=0 : Return : Endif : # A cause bug superviseur
WNUM=[F:POQ]POHNUM : WPOQLNK=[F:POQ]POQLNK
Read [POQ] POQ3=WNUM;WPOQLNK  : If fstat Raz [F:POQ] : Endif
Read [POH] POH0=[F:POQ]POHNUM : If fstat Raz [F:POH] : Endif
Read [FCY] FCY0=[F:POQ]POHFCY : If fstat Raz [F:FCY] : Endif
If [F:POH]POHNUM="" & [F:FCY]FCY=""
  Call RSTA("XPOQ",WNUM-WPOQLNK) From GLOCK
  OK=0 : Return
Endif
If !evalue(FILGAUSUP) OK=0 : Return : Endif : # A cause bug superviseur
If [F:POQ]LINTYP=2
  Gosub TEST_MAXLIN_SST
Else
  Gosub TEST_MAXLIN
Endif
If mkstat  OK=0 : Return : Endif
#----- Blocage logique de la commande -----#
SYMBOL2="POH"+[F:POQ]POHNUM : Lock=SYMBOL2
If fstat
  GMESSAGE="$PORDER"-[F:POQ]POHNUM-mess(10,100,1) : GERR=1
  WRET=1 : OK=0 : Return
Endif

# Issue 71069 - 2013-08-27 by MUARN : PJT
#Code affaire à la ligne (Partie : rajout paramètre société pour contrôle documents mono-affaire)
#--Contrôles sur le code affaire de la commande à l'origine du bon de préparation
If [M:PIH3]NBLIG<1 & [M:PIH1]PJTH = "" & GPJTSNGDOC = 2
   [M:PIH1]PJTH = [F:POP]PJT
   If func TRTPJT.IS_PJT_AVAILABLE([F:POP]PJT, "[M:PIH1]PJTH", SWPJTMSG) = G_NON Then
      Call PJT_ADD_MSG([F:POP]PJT, SWPJTMSG) From TRTPJT
      OK = 0 : GERR = 1
      GMESSAGE = SWPJTMSG
      Raz [M:PIH1]PJTH
      Return
   Endif
   Affzo [PIH1]PJTH
Else
   If func TRTPJT.IS_PJT_AVAILABLE([F:POP]PJT, "[M:PIH3]PJT", SWPJTMSG) = G_NON Then
      Call PJT_ADD_MSG([F:POP]PJT, SWPJTMSG) From TRTPJT
      OK = 0 : GERR = 1
      GMESSAGE = SWPJTMSG
      Return
   Endif
Endif

#----- Préchargement à partir des commandes -----#
[M:PIH3]TYPORI(NOL)=1
[M:PIH3]NUMORI(NOL)=[F:POQ]POHNUM
[M:PIH3]LINORI(NOL)=[F:POQ]POPLIN
[M:PIH3]SEQORI(NOL)=[F:POQ]POQSEQ
[M:PIH3]ITMREF(NOL)=[F:POQ]ITMREF
#----- Contrôle date dernière FAR inférieure à date comptable de la facture -----#
Gosub CTRL_DATFAR : If mkstat  Unlock=SYMBOL2 : OK=0 : Return : Endif
#----- Contrôle si avoir ou facture non validé sur document d'origine -----#
# Issue 105774 - 2015-04-29 by MUARN : raz numori et linori
Gosub CTRL_VALID  : If mkstat  Unlock=SYMBOL2 : OK=0 : Raz [M:PIH3]NUMORI(NOL),[M:PIH3]LINORI(NOL) : Return : Endif
#----- Three way matching check -----#

#X3-90241.o - Removed below line to clear fields so the validation checks run correctly
#X3-90241.o - Gosub PIH_TWMCHK From TWMLIB : If mkstat  Unlock=SYMBOL2 : OK=0 : Return : Endif

#X3=90241: Added Raz statement below to ensure user can't bypass validation checks
Gosub PIH_TWMCHK From TWMLIB : If mkstat  Unlock=SYMBOL2 : OK=0 : Raz [M:PIH3]TYPORI(NOL),[M:PIH3]NUMORI(NOL),[M:PIH3]LINORI(NOL) : Return : Endif

#----- Particularité pour sous-traitance -----#
If [F:POQ]LINTYP=2
  WVCRTYPORI=[F:POQ]VCRTYPORI
  WVCRNUMORI=[F:POQ]VCRNUMORI
  Raz OK
  For [POQ] POQ3 Where POHNUM   =WNUM
&                    & POQLNK  >=WPOQLNK
&                    & VCRTYPORI=WVCRTYPORI
&                    & VCRNUMORI=WVCRNUMORI
    If [F:POQ]LINTYP<3 & OK  Break : Endif
    If [F:POQ]LINTYP=2
      OK=1
    Else
      Gosub TEST_MAXLIN : If mkstat  Break : Endif
    Endif
    [M:PIH3]TYPORI(NOL)=1
    [M:PIH3]NUMORI(NOL)=[F:POQ]POHNUM
    [M:PIH3]LINORI(NOL)=[F:POQ]POPLIN
    [M:PIH3]SEQORI(NOL)=[F:POQ]POQSEQ
    [M:PIH3]ITMREF(NOL)=[F:POQ]ITMREF
    Call CHARG_LIG(NOL,SAVNBLIG) From SUBPIHB
    status=0 : Call LINNUM("PIDLIN") From TABLEAUX
    [M:PIH3]NBLIG+=1 : Call APRES_NBLIG     From SUBPIH
    If [F:POQ]LINTYP=2  GPIH_QTE=[M:PIH3]QTYUOM(NOL) : Endif
  Next
  OK=1
#----- Lignes classiques (autres que sous-traitance) -----#
Else
  Call CHARG_LIG(NOL,SAVNBLIG) From SUBPIHB
  status=0 : Call LINNUM("PIDLIN") From TABLEAUX
  [M:PIH3]NBLIG+=1 : Call APRES_NBLIG From SUBPIH
Endif
#-----
Return
#-------------------------------------#
# Déselection d'une ligne de commande #
#-------------------------------------#
$DEPICK_CDE
WNUM=[F:POQ]POHNUM : WPOQLNK=[F:POQ]POQLNK
Read [POQ] POQ3=WNUM;WPOQLNK  : If fstat Raz [F:POQ] : Endif
Read [POH] POH0=[F:POQ]POHNUM : If fstat Raz [F:POH] : Endif
Read [FCY] FCY0=[F:POQ]POHFCY : If fstat Raz [F:FCY] : Endif
If [F:POH]POHNUM="" & [F:FCY]FCY=""
  Call RSTA("XPOQ",WNUM-WPOQLNK) From GLOCK
  OK=0 : Return
Endif
#----- Particularité pour sous-traitance -----#
If [F:POQ]LINTYP=2
  WVCRTYPORI=[F:POQ]VCRTYPORI
  WVCRNUMORI=[F:POQ]VCRNUMORI
  Raz OK
  For [POQ] POQ3 Where POHNUM   =WNUM
&                    & POQLNK  >=WPOQLNK
&                    & VCRTYPORI=WVCRTYPORI
&                    & VCRNUMORI=WVCRNUMORI
    If [F:POQ]LINTYP<3 & OK  Break : Endif
    If [F:POQ]LINTYP=2   OK=1      : Endif
    Gosub RECHSUP_LIG_CDE : # Recherche et suppression ligne
  Next
  OK=1
#----- Lignes classiques (autres que sous-traitance) -----#
Else
  Gosub RECHSUP_LIG_CDE   : # Recherche et suppression ligne
Endif
Return


#################################################
# Préchargement facture à partir des réceptions #
#################################################
#------------------------------------#
# Sélection d'une ligne de réception #
#------------------------------------#
$PICKE_RCP
If [M:PIH0]PIHTYP<>1  OK=0 : Return : Endif : # A cause bug superviseur
WNUM=[F:PTD]PTHNUM : WLIN=[F:PTD]PTDLIN
Read [PTD] PTD0=WNUM;WLIN     : If fstat Raz [F:PTD] : Endif
Read [PTH] PTH0=[F:PTD]PTHNUM : If fstat Raz [F:PTH] : Endif
Read [FCY] FCY0=[F:PTD]PRHFCY : If fstat Raz [F:FCY] : Endif

Raz [F:POH] : # Par sécurité à cause du chargement par le tiroir commandes
If [F:PTH]PTHNUM="" & [F:FCY]FCY=""
  Call RSTA("XPTD",WNUM-num$(WLIN)) From GLOCK
Endif
If !evalue(FILGAUSUP) OK=0 : Return : Endif : # A cause bug superviseur
If [F:PTD]LINTYP=2
  Gosub TEST_MAXLIN_SST
Else
  Gosub TEST_MAXLIN
Endif
If mkstat OK=0 : Return : Endif
#----- Blocage logique de la réception -----#
# Issue 86623 - 2013-01-18 by SR : Seulement si pas déjà fait
If NOL = 0 | find([F:PTD]PTHNUM,[M:PIH3]NUMORI(0..NOL-1))=0
   SYMBOL2="PTH"+[F:PTD]PTHNUM : Lock=SYMBOL2
   If fstat
     GMESSAGE="$PRECEIPT"-[F:PTD]PTHNUM-mess(10,100,1) : GERR=1
     WRET=1 : OK=0 : Return
   Endif
Endif
#----- Vérif si commande bloquée logiquement -----#
If [F:PTD]POHNUM<>""
  Lock="POH"+[F:PTD]POHNUM
  If fstat
    GMESSAGE="$PORDER"-[F:PTD]POHNUM-mess(10,100,1) : GERR=1
    WRET=1 : OK=0 : Return
  Endif
  Unlock="POH"+[F:PTD]POHNUM
Endif

# Issue 71069 - 2013-08-27 by MUARN : PJT
#Code affaire à la ligne (Partie : rajout paramètre société pour contrôle documents mono-affaire)
#--Contrôles sur le code affaire de la commande à l'origine du bon de préparation
If [M:PIH3]NBLIG<1 & [M:PIH1]PJTH = "" & GPJTSNGDOC = 2
   [M:PIH1]PJTH = [F:PTD]PJT
   If func TRTPJT.IS_PJT_AVAILABLE([F:PTD]PJT, "[M:PIH1]PJTH", SWPJTMSG) = G_NON Then
      Call PJT_ADD_MSG([F:PTD]PJT, SWPJTMSG) From TRTPJT
      OK = 0 : GERR = 1
      GMESSAGE = SWPJTMSG
      Raz [M:PIH1]PJTH
      Return
   Endif
   Affzo [PIH1]PJTH
Else
   If func TRTPJT.IS_PJT_AVAILABLE([F:PTD]PJT, "[M:PIH3]PJT", SWPJTMSG) = G_NON Then
      Call PJT_ADD_MSG([F:PTD]PJT, SWPJTMSG) From TRTPJT
      OK = 0 : GERR = 1
      GMESSAGE = SWPJTMSG
      Return
   Endif
Endif

#----- Préchargement à partir des réceptions -----#
[M:PIH3]TYPORI(NOL)=2
[M:PIH3]NUMORI(NOL)=[F:PTD]PTHNUM
[M:PIH3]LINORI(NOL)=[F:PTD]PTDLIN
[M:PIH3]SEQORI(NOL)=0
[M:PIH3]ITMREF(NOL)=[F:PTD]ITMREF
#VPO 03/02/11 71185 ajout lecture POHNUMORI ssi TYPORI=2
[M:PIH3]POHNUMORI(NOL)=[F:PTD]POHNUM
#----- Contrôle date dernière FAR inférieure à date comptable de la facture -----#
Gosub CTRL_DATFAR : If mkstat  Unlock=SYMBOL2 : OK=0 : Return : Endif
#----- Contrôle si avoir ou facture non validé sur document d'origine -----#
Gosub CTRL_VALID  : If mkstat  Unlock=SYMBOL2 : OK=0 : Return : Endif
#----- Particularité pour sous-traitance -----#
If [F:PTD]LINTYP=2
  WVCRTYPORI=[F:PTD]VCRTYPORI
  WVCRNUMORI=[F:PTD]VCRNUMORI
  Raz OK
  #VPO 20/01/11 70923 on doit utiliser une autre abrev que PTD pour la boucle
  For [PTD1]PTD0 Where PTHNUM   =WNUM
&                    & PTDLIN  >=WLIN
&                    & VCRTYPORI=WVCRTYPORI
&                    & VCRNUMORI=WVCRNUMORI
    If [F:PTD1]LINTYP<3 & OK  Break : Endif
    If [F:PTD1]LINTYP=2
      OK=1
    Else
      Gosub TEST_MAXLIN : If mkstat  Break : Endif
      [M:PIH3]TYPORI(NOL)=2
      [M:PIH3]NUMORI(NOL)=[F:PTD1]PTHNUM
      [M:PIH3]LINORI(NOL)=[F:PTD1]PTDLIN
      [M:PIH3]SEQORI(NOL)=0
      [M:PIH3]ITMREF(NOL)=[F:PTD1]ITMREF
      #VPO 03/02/11 71185 ajout lecture POHNUMORI ssi TYPORI=2
      [M:PIH3]POHNUMORI(NOL)=[F:PTD1]POHNUM
    Endif
    Call CHARG_LIG(NOL,SAVNBLIG) From SUBPIHB
    status=0 : Call LINNUM("PIDLIN") From TABLEAUX
    [M:PIH3]NBLIG+=1 : Call APRES_NBLIG     From SUBPIH
    If [F:PTD1]LINTYP=2  GPIH_QTE=[M:PIH3]QTYUOM(NOL) : Endif
  Next
  OK=1
#----- Lignes classiques (autres que sous-traitance) -----#
Else
  Call CHARG_LIG(NOL,SAVNBLIG) From SUBPIHB
  status=0 : Call LINNUM("PIDLIN") From TABLEAUX
  [M:PIH3]NBLIG+=1 : Call APRES_NBLIG From SUBPIH
Endif
Return
#--------------------------------------#
# Déselection d'une ligne de réception #
#--------------------------------------#
$DEPICK_RCP
WNUM=[F:PTD]PTHNUM : WLIN=[F:PTD]PTDLIN
Read [PTD] PTD0=WNUM;WLIN     : If fstat Raz [F:PTD] : Endif
Read [PTH] PTH0=[F:PTD]PTHNUM : If fstat Raz [F:PTH] : Endif
Read [FCY] FCY0=[F:POQ]POHFCY : If fstat Raz [F:FCY] : Endif
If [F:PTH]PTHNUM="" & [F:FCY]FCY=""
  Call RSTA("XPTD",WNUM-num$(WLIN)) From GLOCK
  OK=0 : Return
Endif
#----- Particularité pour sous-traitance -----#
If [F:PTD]LINTYP=2
  WVCRTYPORI=[F:PTD]VCRTYPORI
  WVCRNUMORI=[F:PTD]VCRNUMORI
  Raz OK
  #VPO 20/01/11 70923 on doit utiliser une autre abrev que PTD pour la boucle
  For [PTD1]PTD0 Where PTHNUM   =WNUM
&                    & PTDLIN  >=WLIN
&                    & VCRTYPORI=WVCRTYPORI
&                    & VCRNUMORI=WVCRNUMORI
    If [F:PTD1]LINTYP<3 & OK  Break : Endif
    If [F:PTD1]LINTYP=2   OK=1      : Endif
    Gosub RECHSUP_LIG_RCP : # Recherche et suppression ligne
  Next
  OK=1
#----- Lignes classiques (autres que sous-traitance) -----#
Else
  [F:PTD1]=[F:PTD] : #VPO 20/01/11 70923 on doit utiliser une autre abrev que PTD
  Gosub RECHSUP_LIG_RCP   : # Recherche et suppression ligne
Endif
Return


#########################################################
# Préchargement avoir à partir des lignes d'une facture #
#########################################################
#----------------------------------#
# Sélection d'une ligne de facture #
#----------------------------------#
$PICKE_FAC2
If [M:PIH0]PIHTYP<>3  OK=0 : Return : Endif : # A cause bug superviseur
WNUM=[F:PID]NUM : WLIN=[F:PID]PIDLIN
Read [PID] PID0=WNUM;WLIN  : If fstat Raz [F:PID] : Endif
Read [PIH] PIH0=[F:PID]NUM : If fstat Raz [F:PIH] : Endif
If [F:PIH]NUM=""
  Call RSTA("XPID",WNUM-num$(WLIN)) From GLOCK
  OK=0 : Return
Endif
If !evalue(FILGAUSUP) OK=0 : Return : Endif : # A cause bug superviseur
If [F:PID]LINTYP=2
  Gosub TEST_MAXLIN_SST
Else
  Gosub TEST_MAXLIN
Endif
If mkstat OK=0 : Return : Endif
#----- Test si facture d'origine est validée ? -----#
If [F:PIH]STA<>3
  GMESSAGE=[F:PIH]NUM-mess([F:PIH]STA,509,1)-":"-mess(335,194,1) : GERR=1
  WRET=1 : OK=0 : Return
Endif
#----- Si avoir, contrôle date facture d'origine donne le même taux de taxe -----#
# Issue 93187 - 2013-11-15 by MUARN : VATDAT et non ACCDAT
#GBIDA1=[F:PIH]ACCDAT : GBIDC3=[F:PID]VAT(0)
GBIDA1=[F:PIH]VATDAT : GBIDC3=[F:PID]VAT(0)
If WRET=0
  Gosub CTRL_DATE_TAXE From SUBPIHB
  If mkstat  WRET=1 : OK=0 : Return : Endif
Elsif WRET=1
  OK=0 : Return
Endif
#----- Contrôle si ligne facture fait déjà l'objet d'un avoir -----#
Filter [PIDB] Where TYPORI=4
&                 & NUMORI=[F:PID]NUM
&                 & LINORI=[F:PID]PIDLIN
&                 & PIHTYP=3
&                 & NUM<>[M:PIH0]NUM
Look [PIDB] PID1 First
Filter [PIDB]
If !fstat
  If WRET=0
    WRET=2 : Call AVERTIR([F:PID]NUM-num$([F:PID]PIDLIN)-mess(45,191,1),WRET) From GESECRAN
    If WRET<>2  WRET=3 : OK=0 : Return : Endif
  Elsif WRET=3
    OK=0 : Return
  Endif
Endif
#----- Blocage logique de la facture -----#
SYMBOL2="PIH"+[F:PID]NUM : Lock=SYMBOL2
If fstat
  GMESSAGE="$PINVOICE"-[F:PID]NUM-mess(10,100,1) : GERR=1
  WRET=1 : OK=0 : Return
Endif

# Issue 71069 - 2013-08-27 by MUARN : PJT
#Code affaire à la ligne (Partie : rajout paramètre société pour contrôle documents mono-affaire)
#--Contrôles sur le code affaire de la commande à l'origine du bon de préparation
If [M:PIH3]NBLIG<1 & [M:PIH1]PJTH = "" & GPJTSNGDOC = 2
   [M:PIH1]PJTH = [F:PID]PJT
   If func TRTPJT.IS_PJT_AVAILABLE([F:PID]PJT, "[M:PIH1]PJTH", SWPJTMSG) = G_NON Then
      Call PJT_ADD_MSG([F:PID]PJT, SWPJTMSG) From TRTPJT
      OK = 0 : GERR = 1
      GMESSAGE = SWPJTMSG
      Raz [M:PIH1]PJTH
      Return
   Endif
   Affzo [PIH1]PJTH
Else
   If func TRTPJT.IS_PJT_AVAILABLE([F:PID]PJT, "[M:PIH3]PJT", SWPJTMSG) = G_NON Then
      Call PJT_ADD_MSG([F:PID]PJT, SWPJTMSG) From TRTPJT
      OK = 0 : GERR = 1
      GMESSAGE = SWPJTMSG
      Return
   Endif
Endif

#----- Préchargement à partir des lignes de la facture -----#
[M:PIH3]TYPORI(NOL)=4
[M:PIH3]NUMORI(NOL)=[F:PID]NUM
[M:PIH3]LINORI(NOL)=[F:PID]PIDLIN
[M:PIH3]SEQORI(NOL)=0
[M:PIH3]ITMREF(NOL)=[F:PID]ITMREF
#----- Particularité pour sous-traitance -----#
If [F:PID]LINTYP=2
  Raz OK
  For [PID] PID0 Where NUM   =WNUM
&                    & PIDLIN>=WLIN
    If [F:PID]LINTYP<3 & OK  Break : Endif
    If [F:PID]LINTYP=2
      OK=1
    Else
      Gosub TEST_MAXLIN : If mkstat  Break : Endif
      [M:PIH3]TYPORI(NOL)=4
      [M:PIH3]NUMORI(NOL)=[F:PID]NUM
      [M:PIH3]LINORI(NOL)=[F:PID]PIDLIN
      [M:PIH3]SEQORI(NOL)=0
      [M:PIH3]ITMREF(NOL)=[F:PID]ITMREF
    Endif
    Call CHARG_LIG(NOL,SAVNBLIG) From SUBPIHB
    status=0 : Call LINNUM("PIDLIN") From TABLEAUX
    [M:PIH3]NBLIG+=1 : Call APRES_NBLIG     From SUBPIH
    If [F:PID]LINTYP=2  GPIH_QTE=[M:PIH3]QTYUOM(NOL) : Endif
  Next
  OK=1
#----- Lignes classiques (autres que sous-traitance) -----#
Else
  Call CHARG_LIG(NOL,SAVNBLIG) From SUBPIHB
  status=0 : Call LINNUM("PIDLIN") From TABLEAUX
  [M:PIH3]NBLIG+=1 : Call APRES_NBLIG From SUBPIH
Endif
Return
#---------------------------------------#
# Déselection d'une ligne de la facture #
#---------------------------------------#
$DEPICK_FAC2
WNUM=[F:PID]NUM : WLIN=[F:PID]PIDLIN
Read [PID] PID0=WNUM;WLIN  : If fstat Raz [F:PID] : Endif
Read [PIH] PIH0=[F:PID]NUM : If fstat Raz [F:PIH] : Endif
If [F:PIH]NUM=""
  Call RSTA("XPID",WNUM-num$(WLIN)) From GLOCK
  OK=0 : Return
Endif
#----- Particularité pour sous-traitance -----#
If [F:PID]LINTYP=2
  Raz OK
  For [PID] PID0 Where NUM   =WNUM
&                    & PIDLIN>=WLIN
    If [F:PID]LINTYP<3 & OK  Break : Endif
    If [F:PID]LINTYP=2   OK=1      : Endif
    Gosub RECHSUP_LIG_FAC2 : # Recherche et suppression ligne
  Next
  OK=1
#----- Lignes classiques (autres que sous-traitance) -----#
Else
  Gosub RECHSUP_LIG_FAC2     : # Recherche et suppression ligne
Endif
Return


############################################
# Préchargement avoir à partir des retours #
############################################
#---------------------------------#
# Sélection d'une ligne de retour #
#---------------------------------#
$PICKE_RET
If [M:PIH0]PIHTYP<>4  OK=0 : Return : Endif : # A cause bug superviseur
WNUM=[F:PND]PNHNUM : WLIN=[F:PND]PNDLIN
Read [PND] PND0=WNUM;WLIN     : If fstat Raz [F:PND] : Endif
Read [PNH] PNH0=[F:PND]PNHNUM : If fstat Raz [F:PNH] : Endif
Read [FCY] FCY0=[F:PND]PNHFCY : If fstat Raz [F:FCY] : Endif
If [F:PNH]PNHNUM="" & [F:FCY]FCY=""
  Call RSTA("XPND",WNUM-num$(WLIN)) From GLOCK
  OK=0 : Return
Endif
If !evalue(FILGAUSUP) OK=0 : Return : Endif : # A cause bug superviseur
If [F:PND]LINTYP=2
  Gosub TEST_MAXLIN_SST
Else
  Gosub TEST_MAXLIN
Endif
If mkstat OK=0 : Return : Endif
#----- Blocage logique du retour -----#
SYMBOL2="PNH"+[F:PND]PNHNUM : Lock=SYMBOL2
If fstat
  GMESSAGE="$PRETURN"-[F:PND]PNHNUM-mess(10,100,1) : GERR=1
  WRET=1 : OK=0 : Return
Endif

# Issue 71069 - 2013-08-27 by MUARN : PJT
#Code affaire à la ligne (Partie : rajout paramètre société pour contrôle documents mono-affaire)
#--Contrôles sur le code affaire de la commande à l'origine du bon de préparation
If [M:PIH3]NBLIG<1 & [M:PIH1]PJTH = "" & GPJTSNGDOC = 2
   [M:PIH1]PJTH = [F:PND]PJT
   If func TRTPJT.IS_PJT_AVAILABLE([F:PND]PJT, "[M:PIH1]PJTH", SWPJTMSG) = G_NON Then
      Call PJT_ADD_MSG([F:PND]PJT, SWPJTMSG) From TRTPJT
      OK = 0 : GERR = 1
      GMESSAGE = SWPJTMSG
      Raz [M:PIH1]PJTH
      Return
   Endif
   Affzo [PIH1]PJTH
Else
   If func TRTPJT.IS_PJT_AVAILABLE([F:PND]PJT, "[M:PIH3]PJT", SWPJTMSG) = G_NON Then
      Call PJT_ADD_MSG([F:PND]PJT, SWPJTMSG) From TRTPJT
      OK = 0 : GERR = 1
      GMESSAGE = SWPJTMSG
      Return
   Endif
Endif

#----- Préchargement à partir des retours -----#
[M:PIH3]TYPORI(NOL)=3
[M:PIH3]NUMORI(NOL)=[F:PND]PNHNUM
[M:PIH3]LINORI(NOL)=[F:PND]PNDLIN
[M:PIH3]SEQORI(NOL)=0
[M:PIH3]ITMREF(NOL)=[F:PND]ITMREF
#----- Contrôle si avoir ou facture non validé sur document d'origine -----#
Gosub CTRL_VALID : If mkstat  Unlock=SYMBOL2 : OK=0 : Return : Endif
#----- Particularité pour sous-traitance -----#
If [F:PND]LINTYP=2
  Raz OK
  For [PND] PND0 Where PNHNUM =WNUM
&                    & PNDLIN>=WLIN
    If [F:PND]LINTYP<3 & OK  Break : Endif
    If [F:PND]LINTYP=2
      OK=1
    Else
      Gosub TEST_MAXLIN : If mkstat  Break : Endif
      [M:PIH3]TYPORI(NOL)=3
      [M:PIH3]NUMORI(NOL)=[F:PND]PNHNUM
      [M:PIH3]LINORI(NOL)=[F:PND]PNDLIN
      [M:PIH3]SEQORI(NOL)=0
      [M:PIH3]ITMREF(NOL)=[F:PND]ITMREF
    Endif
    Call CHARG_LIG(NOL,SAVNBLIG) From SUBPIHB
    status=0 : Call LINNUM("PIDLIN") From TABLEAUX
    [M:PIH3]NBLIG+=1 : Call APRES_NBLIG     From SUBPIH
    If [F:PND]LINTYP=2  GPIH_QTE=[M:PIH3]QTYUOM(NOL) : Endif
  Next
  OK=1
#----- Lignes classiques (autres que sous-traitance) -----#
Else
  Call CHARG_LIG(NOL,SAVNBLIG) From SUBPIHB
  status=0 : Call LINNUM("PIDLIN") From TABLEAUX
  [M:PIH3]NBLIG+=1 : Call APRES_NBLIG From SUBPIH
Endif
Return
#-----------------------------------#
# Déselection d'une ligne de retour #
#-----------------------------------#
$DEPICK_RET
WNUM=[F:PND]PNHNUM : WLIN=[F:PND]PNDLIN
Read [PND] PND0=WNUM;WLIN     : If fstat Raz [F:PND] : Endif
Read [PNH] PNH0=[F:PND]PNHNUM : If fstat Raz [F:PNH] : Endif
Read [FCY] FCY0=[F:PND]PNHFCY : If fstat Raz [F:FCY] : Endif
If [F:PNH]PNHNUM="" & [F:FCY]FCY=""
  Call RSTA("XPND",WNUM-num$(WLIN)) From GLOCK
  OK=0 : Return
Endif
#----- Particularité pour sous-traitance -----#
# Issue 84642 - 2012-09-20 by SR : Remplacer WPOQLNK par WLIN
If [F:PND]LINTYP=2
  Raz OK
  For [PND] PND0 Where PNHNUM =WNUM
&                    & PNDLIN>=WLIN
    If [F:PND]LINTYP<3 & OK  Break : Endif
    If [F:PND]LINTYP=2   OK=1      : Endif
    Gosub RECHSUP_LIG_RET : # Recherche et suppression ligne
  Next
  OK=1
#----- Lignes classiques (autres que sous-traitance) -----#
Else
  Gosub RECHSUP_LIG_RET    : # Recherche et suppression ligne
Endif
Return


############################################################
# Préchargement facture achat à partir de la facture vente #
############################################################
#----------------------------------#
# Sélection d'une facture de vente #
#----------------------------------#
$PICKE_SIH
If [M:PIH0]BETCPY<>2  OK=0 : Return : Endif : # A cause bug superviseur
#----- On ne peut "picker" qu'une seule facture de vente à la fois ! -----#
If [M:PIH3]NBLIG>0
  GMESSAGE=mess(291,194,1) : OK=0 : Return
Endif
#-----
WNUM=[F:SIH]NUM
Read [SIH] SIH0=WNUM : If fstat Raz [F:SIH] : Endif
Read [SIV] SIV0=WNUM : If fstat Raz [F:SIV] : Endif
If [F:SIH]NUM=""
  Call RSTA("XSIH",WNUM) From GLOCK
  OK=0 : Return
Endif
If !GIMPORT & !evalue(FILGAUSUP) OK=0 : Return : Endif : # A cause bug superviseur
#----- Blocage logique de la facture vente -----#
SYMBOL2="SIV"+[F:SIH]NUM : Lock=SYMBOL2
If fstat
  GMESSAGE="$SINVOICE"-[F:SIH]NUM-mess(10,100,1)
  OK=0 : Return
Endif
#----- Préchargement à partir de la facture de vente -----#
Call CHARG_FACINTSOC(WNUM,WRET) From TRTACHFAC2
If WRET  OK=0 : Gosub DEPICK_SIH : Return : Endif
Affzo [PIH0]1-99
Affzo [PIH1]1-99
Affzo [PIH3]1-99
Affzo [PIH4]1-99
Diszo [PIH1]BPRVCR
If GLOCARGNUM & dim([M:PIH1]TYPVCR)>0
  Diszo [PIH1]TYPVCR, CLSVCR, SCUVCR, SEQVCR
Endif
Return
#------------------------------------#
# Déselection d'une facture de vente #
#------------------------------------#
$DEPICK_SIH
SYMBOL2="SIV"+[M:PIH0]SIHNUM
Unlock=SYMBOL2
Raz [M:PIH0]BPR, [M:PIH0]BPRSAC, [M:PIH0]BPRNAM1, [M:PIH0]LIBPAZ, [M:PIH0]SIHNUM
Raz [M:PIH1], [M:PIH3], [M:PIH4]
Actzo [PIH0]1-99 : Affzo [PIH0]1-99
Actzo [PIH1]1-99 : Affzo [PIH1]1-99
Actzo [PIH3]1-99 : Affzo [PIH3]1-99
Actzo [PIH4]1-99 : Affzo [PIH4]1-99
Return

################################################
# Test si tableau des lignes arrivé au maximum #
################################################
$TEST_MAXLIN
GBIDI2=2 : Gosub TRT_MAXLIN
Return
#----- Prévoir 3 lignes de plus pour la sous-traitance -----#
$TEST_MAXLIN_SST
GBIDI2=5 : Gosub TRT_MAXLIN
Return
#-----
$TRT_MAXLIN
Raz mkstat
If [M:PIH3]NBLIG>dim([M:PIH3]TYPORI)-GBIDI2
  GMESSAGE=mess(26,100,1) : GERR=1
  mkstat=1 : Return
Endif
NOL=[M:PIH3]NBLIG : nolign=NOL+1
status=73 : Call INSERE("PIDLIN") From TABLEAUX
Return


###################################################################
# Préchargement facture complémentaire à partir d'autres factures #
###################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUVRE_SAIFACCPIH
If clalev([F:PIHB])=0 Local File PINVOICE  [PIHB] : Endif
If clalev([F:PIDB])=0 Local File PINVOICED [PIDB] : Endif
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEBUT_SAIFACCPIH
#----- Variables locales -----#
Local Char     NUMERO(GLONPIH), SYMBOL2(30)
Local Shortint SAVNBLIG, I, J, K, L, WMKSTAT, NOL
SAVNBLIG=[M:PIH3]NBLIG
Raz [M:PPI5]
#----- Chargement des zones dans le masque -----#
[M:PPI5]REPART=2
[M:PPI5]TYPORI=4
[M:PPI5]BPSINV=[M:PIH0]BPR
[M:PPI5]DEV=[M:PIH1]CUR
#----- Affichage foreground -----#
If !GIMPORT Affzo [PPI5]1-99 : Endif
Return
#--------------------------------#
# Après l'exécution du bouton OK #
#--------------------------------#
$OK_SAIFACCPIH
If [M:PPI5]NBLIG<>0
  Local Decimal  CUMQTE, CUMMT, CUMMTHT, MT
  Local Integer  STAT
  Default Mask [PIH3]
  Sorta [M:PPI5]NBLIG [M:PPI5]NBLIG Order By [M:PPI5]NUMORI(indice)
  #----- Préchargement des lignes de la facture complémentaire -----#
  Raz CUMQTE, CUMMT
  For I=0 To [M:PPI5]NBLIG-1
    If [M:PPI5]CHX1(I)=2
       If [M:PPI5]REPART=2
          If [M:PPI5]CUR(I)<>[M:PIH1]CUR
             Call CONVERT([M:PPI5]CUR(I),[M:PIH1]CUR,GLOCALDEV,[M:PIH1]CURTYP,
&                         [M:PIH0]ACCDAT,[M:PPI5]AMTNOTLIN(I),MT,STAT) From TRTDEV
             [M:PPI5]AMTNOTLIN(I)=MT : [M:PPI5]CUR(I)=[M:PIH1]CUR
          Endif
          CUMMT +=[M:PPI5]AMTNOTLIN(I)
       Else
          CUMQTE+=[M:PPI5]QTYUOM(I)
       Endif
       J=I
    Endif
  Next I
  Raz CUMMTHT
  For I=0 To [M:PPI5]NBLIG-1
    If [M:PPI5]CHX1(I)=2
      #----- Test si tableau des lignes arrivé au maximum -----#
      Raz mkstat
      If [M:PIH3]NBLIG>dim([M:PIH3]TYPORI)-2
        GMESSAGE=mess(26,100,1) : GERR=1
        #----- Déblocage logique des lignes non chargées si nécessaire -----#
        Raz NUMERO
        For L=I To [M:PPI5]NBLIG-1
          If [M:PPI5]CHX1(L)=2 & [M:PPI5]NUMORI(L)<>NUMERO
            Raz J
            While J<[M:PIH3]NBLIG
              K=find([M:PPI5]NUMORI(L),[M:PIH3]NUMORI(J..[M:PIH3]NBLIG-1))
              If K=0 J=[M:PIH3]NBLIG
                 Elsif [M:PIH3]TYPORI(J+(K-1))=[M:PPI5]TYPORI &
&                      [M:PIH3]CREFLG(J+(K-1))=0  J=[M:PIH3]NBLIG
                 Else  J+=K : K=0
              Endif
            Wend
            If K=0 SYMBOL2="PIH"+[M:PPI5]NUMORI(L) : Unlock=SYMBOL2 : Endif
            NUMERO=[M:PPI5]NUMORI(L)
          Endif
        Next L
        #-----
        mkstat=1
      Else
        NOL=[M:PIH3]NBLIG : nolign=NOL+1
        status=73 : Call INSERE("PIDLIN") From TABLEAUX
      Endif
      #-----
      If mkstat Break : Endif
      [M:PIH3]TYPORI(NOL)=4
      [M:PIH3]NUMORI(NOL)=[M:PPI5]NUM(I)
      [M:PIH3]LINORI(NOL)=[M:PPI5]PIDLIN(I)
      [M:PIH3]SEQORI(NOL)=0
      If [M:PPI5]REFART<>""
        [M:PIH3]ITMREF(NOL)=[M:PPI5]REFART
      Else
        [M:PIH3]ITMREF(NOL)=[M:PPI5]ITMREF(I)
      Endif
      Call CHARG_LIG(NOL,SAVNBLIG) From SUBPIHB
      If I<>J
        If [M:PPI5]REPART=2 & CUMMT<>0 & [M:PIH3]LINTYP(NOL)<>2
          [M:PIH3]GROPRI(NOL)=arr([M:PPI5]MTHT*[M:PPI5]AMTNOTLIN(I)/CUMMT,10^-GDECPRI)
        Elsif [M:PPI5]REPART=1 & CUMQTE<>0 & [M:PIH3]LINTYP(NOL)<>3
          [M:PIH3]GROPRI(NOL)=arr([M:PPI5]MTHT*[M:PPI5]QTYUOM(I)/CUMQTE,10^-GDECPRI)
        Endif
      Else
        [M:PIH3]GROPRI(NOL)=[M:PPI5]MTHT-CUMMTHT
      Endif
      [M:PIH3]AMTNOTLIN(NOL)=[M:PIH3]GROPRI(NOL)
      Call ARRDEV([M:PIH3]AMTNOTLIN(NOL),[M:PIH1]CUR) From TRTDIV
      # Issue 82067 - 2012-07-06 by MUARN : écart arrondi facture/réception après valo stock
      [M:PIH3]AMTNOTLINCAL(NOL)=[M:PIH3]AMTNOTLIN(NOL)
      CUMMTHT+=[M:PIH3]AMTNOTLIN(NOL)
      status=0  : Call LINNUM("PIDLIN") From TABLEAUX
      [M:PIH3]NBLIG+=1 : Call APRES_NBLIG From SUBPIH
    Endif
  Next I
  #-----
  If mkstat & [M:PIH3]NBLIG=SAVNBLIG WMKSTAT=mkstat Else WMKSTAT=4 : Endif
  If !GIMPORT Affzo [PIH3]5 : Endif
Endif
FIN=1
Return
#-------------------------------------#
# Après l'exécution du bouton ABANDON #
#-------------------------------------#
$ABA_SAIFACCPIH
Gosub DEBLOCAGE_PID
Raz [M:PPI5], REP, WMKSTAT
#----- Chargement des zones dans le masque -----#
[M:PPI5]BPSINV=[M:PIH0]BPR
[M:PPI5]DEV=[M:PIH1]CUR
#----- Affichage foreground -----#
If !GIMPORT Affzo [PPI5]1-99 : Endif
Return
#-------------------------------------#
# Avant grisage/dégrisage des boutons #
#-------------------------------------#
$SETB_SAIFACCPIH
Case COUZON
  When "REFART"  : [M:PPI5]REFART=CZ
  When "MTHT"    : [M:PPI5]MTHT=val(CZ)
  When "CHX1"    : [M:PPI5]CHX1(nolign-1)=val(CZ)
Endcase
If [M:PPI5]NBLIG=0
  ETABOU(GVALI)=0
Elsif find(2,[M:PPI5]CHX1(0..[M:PPI5]NBLIG-1))
  ETABOU(GVALI)=1
Else
  ETABOU(GVALI)=0
Endif
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_SAIFACCPIH
If WMKSTAT=0 Gosub DEBLOCAGE_PID : Endif
Close Local File [PIHB]
Close Local File [PIDB]
Default File [PIH]
Gosub TEST_VALID From SUBPIH : # Màj bases taxables et calcul taxes éléments facturation
mkstat=WMKSTAT
Return


####################################################################################
# Déblocage logique des enregistrements lignes factures (factures complémentaires) #
####################################################################################
$DEBLOCAGE_PID
If [M:PPI5]NBLIG<>0
  Sorta [M:PPI5]NBLIG [M:PPI5]NBLIG Order By [M:PPI5]NUMORI(indice)
  Raz NUMERO
  For K=0 To [M:PPI5]NBLIG-1
    If [M:PPI5]CHX1(K)=2 & [M:PPI5]NUMORI(K)<>NUMERO
      If [M:PIH3]NBLIG=0 J=0 : Goto TEST_DEVERROU : Endif
      Raz I
      While I<[M:PIH3]NBLIG
        J=find([M:PPI5]NUMORI(K),[M:PIH3]NUMORI(I..[M:PIH3]NBLIG-1))
        If J=0 I=[M:PIH3]NBLIG
           Elsif [M:PIH3]TYPORI(I+(J-1))=[M:PPI5]TYPORI &
&                [M:PIH3]CREFLG(I+(J-1))=0  I=[M:PIH3]NBLIG
           Else  I+=J : J=0
        Endif
      Wend
$TEST_DEVERROU
      If J=0 SYMBOL2="PIH"+[M:PPI5]NUMORI(K) : Unlock=SYMBOL2 : Endif
      NUMERO=[M:PPI5]NUMORI(K)
    Endif
  Next K
Endif
Return


##########################################################################
# Sélection du numéro d'origine (commande, réception, retour ou facture) #
##########################################################################
#--------------------------------------#
# Avant ouverture fenêtre de sélection #
#--------------------------------------#
$SEL_SELPIHNUMO
Local Shortint OUVFICFLG  : Raz OUVFICFLG
Local Integer  SVG_ADXMXL : Raz SVG_ADXMXL
If [M:PIH3]TYPORI(nolign-1)=1
  OBJET="POH" : OPTIONS="#"
  # Issue 82703 - 2012-10-05 by SR filtrer selon type de facture
  Case [M:PIH0]PIHTYP :
    When 2
      # Issue 102940 - 2014-09-26 by SR : Filtre assoupli
      #CRITERE(1)="CLEFLG = 1 & INVFLG = 1 & RCPFLG = 1 & POHTYP = 1 & APPFLG>2 & CPY=GSOCIETE"
      CRITERE(1)=" POHTYP = 1 & APPFLG>2 & CPY=GSOCIETE"
      If GCTLDATORI=2  CRITERE(1)-="& ORDDAT<=[M:PIH0]ACCDAT" : Endif
    When Default
      # Issue 120453 - 2016-12-16 by SR : Inter soc
      CRITERE(1)="INVFLG<3 & APPFLG>2 & BPSINV=[M:PIH0]BPR & CPY=GSOCIETE & (BETFCY<>2 | (BETCPY=2 & SALFCY=''))"
      If GCTLDATORI=2  CRITERE(1)-="& ORDDAT<=[M:PIH0]ACCDAT" : Endif
  Endcase
Elsif [M:PIH3]TYPORI(nolign-1)=2
  OBJET="PTH" : OPTIONS="#"
  # Issue 85055 - 2012-10-23 by SR : Pas de filtre sur fournisseur en facture complémentaire
  # Issue 102940 - 2014-09-26 by SR : Filtre assoupli
  If [M:PIH0]PIHTYP=2
#      CRITERE(1)="INVFLG<3 & CPY=GSOCIETE & (BETFCY<>2 | BETCPY=2)"
      CRITERE(1)=" CPY=GSOCIETE & (BETFCY<>2 | BETCPY=2)"
  Else
      CRITERE(1)="INVFLG<3 & BPSINV=[M:PIH0]BPR & CPY=GSOCIETE & (BETFCY<>2 | BETCPY=2)"
  Endif
  #VPO 21/04/11 73382 ajout ctl DATORI aussi avec date BL
  #If GCTLDATORI=2  CRITERE(1)-="& RCPDAT<=[M:PIH0]ACCDAT" : Endif
  If GCTLDATORI=2
    CRITERE(1)-="& ((NDEDAT=[0/0/0] & RCPDAT<=[M:PIH0]ACCDAT)|(NDEDAT<>[0/0/0] & min(NDEDAT,RCPDAT)<=[M:PIH0]ACCDAT))" :
  Endif
Elsif [M:PIH3]TYPORI(nolign-1)=3
  OBJET="PNH" : OPTIONS="#A"
  CRITERE(1)="INVFLG<3 & BPSINV=[M:PIH0]BPR & CPY=GSOCIETE & CFMFLG>1 & (BETFCY<>2 | BETCPY=2)"
  If GCTLDATORI=2  CRITERE(1)-="& RTNDAT<=[M:PIH0]ACCDAT" : Endif
Elsif [M:PIH3]TYPORI(nolign-1)=4
  If adxmxl<200  SVG_ADXMXL=adxmxl : adxmxl=200 : Endif
  If clalev([F:AMZ])=0 Local File AMSKZON [AMZ] : OUVFICFLG=1 : Endif
  TIT(0)=mess(36,198,1)
  If [M:PIH0]PIHTYP=3
    CRITERE(1)="PIHTYP<3 & ORIMOD=6 & BPR=[M:PIH0]BPR & CPY=GSOCIETE & STA=3"
  Else
    CRITERE(1)="PIHTYP=1 & ORIMOD=6 & CPY=GSOCIETE & STA=3"
  Endif
  If GCTLDATORI=2  CRITERE(1)-="& ACCDAT<=[M:PIH0]ACCDAT" : Endif
  COL(1)="FCY"    : GBIDC3="FCY"    : Gosub CHARG_LIB : TIT(1)=GBIDC3
  COL(2)="NUM"    : GBIDC3="NUM"    : Gosub CHARG_LIB : TIT(2)=GBIDC3
  COL(3)="BPR"    : GBIDC3="BPR"    : Gosub CHARG_LIB : TIT(3)=GBIDC3
  COL(4)="ACCDAT" : GBIDC3="ACCDAT" : Gosub CHARG_LIB : TIT(4)=GBIDC3
  NBCOL=4
  START="NUM"
  SIZLIG=80 : SIZCOL=240
  If clalev([F:PIHB])=0 Local File PINVOICE [PIHB] : Endif
  Default File [PIHB]
# Issue 110325 - 2016-01-11 by SR : FCC sur expé
Elsif [M:PIH3]TYPORI(nolign-1) = 6
  OBJET="SHIP" : OPTIONS="#"
  CRITERE(1) =  "SHIPTYP <> 2"
  If [F:SHH]LEGCPY <> ""
     CRITERE(1) -=" & LEGCPY=GSOCIETE"
  Endif
  If GCTLDATORI=2
     CRITERE(1)-="& SHIPDAT<=[M:PIH0]ACCDAT"
  Endif
Endif
Return
#------------------------#
# Sortie de la sélection #
#------------------------#
$FIN_SELPIHNUMO
If OUVFICFLG=1        Close Local File [AMZ]  : Raz OUVFICFLG      : Endif
If clalev([F:PIHB])>0 Close Local File [PIHB] : Default File [PIH] : Endif
If SVG_ADXMXL>0 adxmxl=SVG_ADXMXL : Endif
Return
#--------------------------------------------#
# Chargement libellé colonne de la sélection #
#--------------------------------------------#
$CHARG_LIB
Read [AMZ] CODE="PIH0";GBIDC3 : If fstat Raz [F:AMZ] : Endif
Call TEXTE([F:AMZ]INTIT,GBIDC3) From OBJDIV
Return


#----------------------------------------------------------------#
# Contrôle si avoir ou facture non validé sur document d'origine #
#----------------------------------------------------------------#
$CTRL_VALID
# Issue 97613 - 2014-09-09 by SR : Contôle à effectuer en pré chargement ligne FCC
# CTRL_VALID va appeler nouveau sous-pro CONTROL_VALID
Local Char    WITMREF(GLONITM)
Local Char    WNUM(GLONVCR)
Local Integer WTYP,WLIN,WSEQ,WRET
WITMREF = [M:PIH3]ITMREF(NOL)
WTYP    = [M:PIH3]TYPORI(NOL)
WNUM    = [M:PIH3]NUMORI(NOL)
WLIN    = [M:PIH3]LINORI(NOL)
WSEQ    = [M:PIH3]SEQORI(NOL)
Raz WRET
Call CONTROL_VALID(WITMREF,WTYP,WNUM,WLIN,WSEQ,WRET)
If WRET GERR = 1 : Endif
Return

Subprog CONTROL_VALID(LITMREF,LTYP,LNUM,LLIN,LSEQ,LRET)
Variable Char    LITMREF
Value Char       LNUM
Value Integer    LTYP
Variable Integer LLIN,LSEQ,LRET
If GIMPORT  End : Endif : # Ne pas faire ce contrôle en import de factures !

#----- Ne pas faire ce contrôle si l'article n'est pas géré en stock -----#
If [F:ITM]ITMREF<>LITMREF
  Read [ITM] ITM0=LITMREF : If fstat  Raz [F:ITM] : Endif
Endif
# Issue 104732 - 2014-12-22 by MUARN : continuer pour les articles non gérés en stock sinon problème engagements
#If [F:ITM]STOMGTCOD<2  End : Endif
#----- Point d'entrée CTLVALFAC permettant de ne pas faire ce contrôle en interactif -----#
Local Libelle WCONTROLE : [L]WCONTROLE=1
Gosub POINT_CTLVALFAC From SUBPIHB
If [L]WCONTROLE=0  End : Endif
#-----
If !clalev([F:PIHB])  Local File PINVOICE  [PIHB] : Endif
If !clalev([F:PIDB])  Local File PINVOICED [PIDB] : Endif
If !clalev([F:PIX])
  Link [PIDB] With [PIHB] PIH0=[F:PIDB]NUM As [PIX]
Endif
Local Char    WTAB_NUMFAC(GLONPIH)(20)
Local Integer WTAB_LINFAC(20)
Local Integer WTAB_NBFAC, WTAB_I
# Issue 108852 - 2015-06-18 by SR
# si FCC : si sur facture, Contrôle statut de la facture, sinon, rien
If [M:PIH0]PIHTYP = 2
   If  LTYP = 4
     Read [F:PIHB]PIH0 = LNUM
     If fstat : Raz [F:PIHB] : Endif
     If [F:PIHB]STA <> 3
        GMESSAGE=[F:PIDB]NUM-mess([F:PIHB]STA,509,1)-":"
        GMESSAGE-=mess(335,194,1)
        mkstat = 1 : Gosub ERR_CTRL_VALID
     Endif
   Endif
   End
Endif
# End issue 108852

# Issue 108852 - 2015-06-18 by SR : Ajout colonne PIHTYP et exploitation
# pour exclure FCC
Columns [PIX] ([PIDB]TYPORI,[PIDB]NUMORI,[PIDB]LINORI,[PIDB]SEQORI,[PIDB]NUM,
&              [PIDB]PIDLIN,[PIHB]STA, [PIDB]PIHTYP, [PIHB]NUM)
For [PIX] PID1 Where [F:PIDB]TYPORI=LTYP
&                  & [F:PIDB]NUMORI=LNUM
&                  & [F:PIDB]LINORI=LLIN
&                  & [F:PIDB]SEQORI=LSEQ
&                  & [F:PIDB]NUM<>[M:PIH0]NUM
&                  & [F:PIDB]PIHTYP <> 2
  If [F:PIHB]STA<>3
    GMESSAGE=[F:PIDB]NUM-mess([F:PIHB]STA,509,1)-":"
    If LTYP=3
      GMESSAGE-=mess(336,194,1)
    Else
      GMESSAGE-=mess(335,194,1)
    Endif
    mkstat=1 : Break
  Elsif WTAB_NBFAC<dim(WTAB_NUMFAC) & LTYP<3
    If !find([F:PIDB]NUM,WTAB_NUMFAC) | !find([F:PIDB]PIDLIN,WTAB_LINFAC)
      WTAB_NUMFAC(WTAB_NBFAC)=[F:PIDB]NUM
      WTAB_LINFAC(WTAB_NBFAC)=[F:PIDB]PIDLIN
      WTAB_NBFAC+=1
    Endif
  Endif
Next
If mkstat  Gosub ERR_CTRL_VALID : End : Endif
Case LTYP
  When 1
    Columns [PTDB] (POHNUM,POPLIN,POQSEQ,PTHNUM,PTDLIN)
    For [PTDB] PTD2 Where POHNUM=LNUM
&                       & POPLIN=LLIN
&                       & POQSEQ=LSEQ
      # Issue 108852 - 2015-06-18 by SR : Exclure FCC
      For [PIX] PID1 Where  [F:PIDB]TYPORI=2
&                         & [F:PIDB]NUMORI=[F:PTDB]PTHNUM
&                         & [F:PIDB]LINORI=[F:PTDB]PTDLIN
&                         & [F:PIDB]SEQORI=0
&                         & [F:PIDB]NUM<>[M:PIH0]NUM
&                         & [F:PIDB]PIHTYP <> 2
        If [F:PIHB]STA<>3
          GMESSAGE=[F:PIDB]NUM-mess([F:PIHB]STA,509,1)-":"-mess(335,194,1)
          mkstat=1 : Break 2
        Elsif WTAB_NBFAC<dim(WTAB_NUMFAC)
          If !find([F:PIDB]NUM,WTAB_NUMFAC) | !find([F:PIDB]PIDLIN,WTAB_LINFAC)
            WTAB_NUMFAC(WTAB_NBFAC)=[F:PIDB]NUM
            WTAB_LINFAC(WTAB_NBFAC)=[F:PIDB]PIDLIN
            WTAB_NBFAC+=1
          Endif
        Endif
      Next
    Next
    Columns [PTDB]
    If mkstat  Gosub ERR_CTRL_VALID : End : Endif
  When 2
    # Issue 108852 - 2015-06-18 by SR : Exclure FCC
    For [PIX] PID1 Where  [F:PIDB]TYPORI=1
&                       & [F:PIDB]NUMORI=[F:PTD]POHNUM
&                       & [F:PIDB]LINORI=[F:PTD]POPLIN
&                       & [F:PIDB]SEQORI=[F:PTD]POQSEQ
&                       & [F:PIDB]NUM<>[M:PIH0]NUM
&                       & [F:PIDB]PIHTYP <> 2
      If [F:PIHB]STA<>3
        GMESSAGE=[F:PIDB]NUM-mess([F:PIHB]STA,509,1)-":"-mess(335,194,1)
        mkstat=1 : Break
      Elsif WTAB_NBFAC<dim(WTAB_NUMFAC)
        If !find([F:PIDB]NUM,WTAB_NUMFAC) | !find([F:PIDB]PIDLIN,WTAB_LINFAC)
          WTAB_NUMFAC(WTAB_NBFAC)=[F:PIDB]NUM
          WTAB_LINFAC(WTAB_NBFAC)=[F:PIDB]PIDLIN
          WTAB_NBFAC+=1
        Endif
      Endif
    Next
    If mkstat  Gosub ERR_CTRL_VALID : End : Endif
Endcase
#----- Recherche si avoir non validé sur factures validées trouvées -----#
If WTAB_NBFAC>0
  For WTAB_I=0 To WTAB_NBFAC-1
    For [PIX] PID1 Where  [F:PIDB]TYPORI=4
&                       & [F:PIDB]NUMORI=WTAB_NUMFAC(WTAB_I)
&                       & [F:PIDB]LINORI=WTAB_LINFAC(WTAB_I)
&                       & [F:PIDB]SEQORI=0
&                       & [F:PIDB]NUM<>[M:PIH0]NUM
&                       & [F:PIHB]STA<>3
&                       & [F:PIDB]PIHTYP <> 2 # Issue 108852 - 2015-06-18 by SR : Exclure FCC
      GMESSAGE=[F:PIDB]NUM-mess([F:PIHB]STA,509,1)-":"-mess(336,194,1)
      mkstat=1 : Break 2
    Next
  Next WTAB_I
  If mkstat  Gosub ERR_CTRL_VALID : End : Endif
Endif
#-----
Columns [PIX]
End
#----- Message d'erreur, facture/avoir doit être validé ! -----#
$ERR_CTRL_VALID
If dim(WMSG)<1  Local Char WMSG(120) : Endif
Raz LLIN, LSEQ,LITMREF
Columns [PIX]
If GMESSAGE=WMSG
  Raz GMESSAGE, GERR : # Pour ne pas afficher plusieurs fois le même message
Else
  WMSG=GMESSAGE : GERR=1
Endif
LRET = 1
Return
# End issue 97613

#-------------------------------------------------------------#
# Recherche et suppression de la ligne de commande "dépickée" #
#-------------------------------------------------------------#
$RECHSUP_LIG_CDE
Raz J
While J<[M:PIH3]NBLIG
  K=find([F:POQ]POHNUM,[M:PIH3]NUMORI(J..[M:PIH3]NBLIG-1))
  I=J+(K-1)
  If K=0
    J=[M:PIH3]NBLIG
  Elsif [M:PIH3]TYPORI(I)=1 & [M:PIH3]LINORI(I)=[F:POQ]POPLIN
&                           & [M:PIH3]SEQORI(I)=[F:POQ]POQSEQ
&                           & [M:PIH3]CREFLG(I)=0
    WPICK=1 : Gosub MARQUAGE_LIGNE From SUBPIHD
    nolign=I+1 : status=65
    Call AVANT_NBLIG From SUBPIH
    Dela I,1,[M:PIH3]NBLIG-1 [M:PIH3]NBLIG : [M:PIH3]NBLIG-=1 : [M:PIH3]CLCFLG=2
    J+=K : K=0 : status=0
  Else
    J+=K : K=0
  Endif
Wend
Return

#--------------------------------------------------------------#
# Recherche et suppression de la ligne de réception "dépickée" #
#--------------------------------------------------------------#
#VPO 20/01/11 70923 on doit utiliser une autre abrev que PTD pour la boucle
# ici on utilise PTD1
$RECHSUP_LIG_RCP
Raz J
While J<[M:PIH3]NBLIG
  K=find([F:PTD1]PTHNUM,[M:PIH3]NUMORI(J..[M:PIH3]NBLIG-1))
  I=J+(K-1)
  If K=0
    J=[M:PIH3]NBLIG
  Elsif [M:PIH3]TYPORI(I)=2 & [M:PIH3]LINORI(I)=[F:PTD1]PTDLIN
&                           & [M:PIH3]CREFLG(I)=0
    nolign=I+1 : status=65
    Call AVANT_NBLIG From SUBPIH
    Dela I,1,[M:PIH3]NBLIG-1 [M:PIH3]NBLIG : [M:PIH3]NBLIG-=1 : [M:PIH3]CLCFLG=2
    J+=K : K=0 : status=0
  Else
    J+=K : K=0
  Endif
Wend
Return

#-----------------------------------------------------------#
# Recheche et suppression de la ligne de facture "dépickée" #
#-----------------------------------------------------------#
$RECHSUP_LIG_FAC2
Raz J
While J<[M:PIH3]NBLIG
  K=find([F:PID]NUM,[M:PIH3]NUMORI(J..[M:PIH3]NBLIG-1))
  I=J+(K-1)
  If K=0
    J=[M:PIH3]NBLIG
  Elsif [M:PIH3]TYPORI(I)=4 & [M:PIH3]LINORI(I)=[F:PID]PIDLIN
&                           & [M:PIH3]CREFLG(I)=0
    nolign=I+1 : status=65
    Call AVANT_NBLIG From SUBPIH
    Dela I,1,[M:PIH3]NBLIG-1 [M:PIH3]NBLIG : [M:PIH3]NBLIG-=1 : [M:PIH3]CLCFLG=2
    J+=K : K=0 : status=0
  Else
    J+=K : K=0
  Endif
Wend
Return

#-----------------------------------------------------------#
# Recherche et suppression de la ligne de retour "dépickée" #
#-----------------------------------------------------------#
$RECHSUP_LIG_RET
Raz J
While J<[M:PIH3]NBLIG
  K=find([F:PND]PNHNUM,[M:PIH3]NUMORI(J..[M:PIH3]NBLIG-1))
  I=J+(K-1)
  If K=0
    J=[M:PIH3]NBLIG
  Elsif [M:PIH3]TYPORI(I)=3 & [M:PIH3]LINORI(I)=[F:PND]PNDLIN
&                           & [M:PIH3]CREFLG(I)=0
    nolign=I+1 : status=65
    Call AVANT_NBLIG From SUBPIH
    Dela I,1,[M:PIH3]NBLIG-1 [M:PIH3]NBLIG : [M:PIH3]NBLIG-=1 : [M:PIH3]CLCFLG=2
    J+=K : K=0 : status=0
  Else
    J+=K : K=0
  Endif
Wend
Return

#---------------------------------------------------------------------#
# Chargement lignes service et matières fournies par le sous-traitant #
#---------------------------------------------------------------------#
$CHARG_LIG_SUPPLEMENT
Local  Char     WNUM(GLONVCR), WVCRNUMORI(GLONVCR), WPOQLNK(16)
Local  Integer  WLIN, WVCRTYPORI, SAVNOLIGN, SAVNBLIG
#-----
SAVNBLIG =[M:PIH3]NBLIG
SAVNOLIGN=nolign
GPIH_QTE =[M:PIH3]QTYUOM(NOL)
WNUM     =[M:PIH3]NUMORI(NOL)
WLIN     =[M:PIH3]LINORI(NOL)
#-----
Raz [M:PIH3]NBCRELIG
#-----
Case [M:PIH3]TYPORI(NOL)
  When 1
    If [F:POQ]POHNUM<>[M:PIH3]NUMORI(NOL) |
&      [F:POQ]POPLIN<>[M:PIH3]LINORI(NOL) |
&      [F:POQ]POQSEQ<>[M:PIH3]SEQORI(NOL)
      Read [POQ] POQ0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL);[M:PIH3]SEQORI(NOL)
      If fstat  Call ERREUR(mess(384,194,1)) From GESECRAN : Return : Endif
    Endif
    #-----
    WPOQLNK   =[F:POQ]POQLNK
    WVCRTYPORI=[F:POQ]VCRTYPORI
    WVCRNUMORI=[F:POQ]VCRNUMORI
    #-----
    For [POQ] POQ3 Where POHNUM   =WNUM
&                      & POQLNK   >WPOQLNK
&                      & VCRTYPORI=WVCRTYPORI
&                      & VCRNUMORI=WVCRNUMORI
      If [F:POQ]LINTYP<2  Break : Endif
      nolign+=1 : NOL+=1
      status=73 : Call INSERE("PIDLIN") From TABLEAUX  : If mkstat  Break : Endif
      If dim([M:PIH3]ITMREF)<[M:PIH3]NBLIG+2  mkstat=1 : Break : Endif
      Insa NOL,1,[M:PIH3]NBLIG [M:PIH3]NBLIG : [M:PIH3]NBLIG+=1
      [M:PIH3]NBCRELIG+=1
      [M:PIH3]TYPORI(NOL)=1
      [M:PIH3]NUMORI(NOL)=[F:POQ]POHNUM
      [M:PIH3]LINORI(NOL)=[F:POQ]POPLIN
      [M:PIH3]SEQORI(NOL)=[F:POQ]POQSEQ
      [M:PIH3]ITMREF(NOL)=[F:POQ]ITMREF
      Call CHARG_LIG(NOL,SAVNBLIG) From SUBPIHB
      status=0 : Call LINNUM("PIDLIN") From TABLEAUX
      Call APRES_NBLIG From SUBPIH
    Next
  When 2
    If [F:PTD]PTHNUM<>[M:PIH3]NUMORI(NOL) |
&      [F:PTD]PTDLIN<>[M:PIH3]LINORI(NOL)
      Read [PTD] PTD0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL)
      If fstat  Call ERREUR(mess(384,194,1)) From GESECRAN : Return : Endif
    Endif
    WVCRTYPORI=[F:PTD]VCRTYPORI
    WVCRNUMORI=[F:PTD]VCRNUMORI
    #-----
    For [PTD] PTD0 Where PTHNUM=WNUM
&                      & PTDLIN>WLIN
&                      & VCRTYPORI=WVCRTYPORI
&                      & VCRNUMORI=WVCRNUMORI
      If [F:PTD]LINTYP<2  Break : Endif
      nolign+=1 : NOL+=1
      status=73 : Call INSERE("PIDLIN") From TABLEAUX  : If mkstat  Break : Endif
      If dim([M:PIH3]ITMREF)<[M:PIH3]NBLIG+2  mkstat=1 : Break : Endif
      Insa NOL,1,[M:PIH3]NBLIG [M:PIH3]NBLIG : [M:PIH3]NBLIG+=1
      [M:PIH3]NBCRELIG+=1
      [M:PIH3]TYPORI(NOL)=2
      [M:PIH3]NUMORI(NOL)=[F:PTD]PTHNUM
      [M:PIH3]LINORI(NOL)=[F:PTD]PTDLIN
      [M:PIH3]SEQORI(NOL)=0
      [M:PIH3]ITMREF(NOL)=[F:PTD]ITMREF
      #VPO 03/02/11 71185 ajout lecture POHNUMORI ssi TYPORI=2
      [M:PIH3]POHNUMORI(NOL)=[F:PTD]POHNUM
      Call CHARG_LIG(NOL,SAVNBLIG) From SUBPIHB
      status=0 : Call LINNUM("PIDLIN") From TABLEAUX
      Call APRES_NBLIG From SUBPIH
    Next
  When 3
    For [PND] PND0 Where PNHNUM=WNUM
&                      & PNDLIN>WLIN
      If [F:PND]LINTYP<2  Break : Endif
      nolign+=1 : NOL+=1
      status=73 : Call INSERE("PIDLIN") From TABLEAUX  : If mkstat  Break : Endif
      If dim([M:PIH3]ITMREF)<[M:PIH3]NBLIG+2  mkstat=1 : Break : Endif
      Insa NOL,1,[M:PIH3]NBLIG [M:PIH3]NBLIG : [M:PIH3]NBLIG+=1
      [M:PIH3]NBCRELIG+=1
      [M:PIH3]TYPORI(NOL)=3
      [M:PIH3]NUMORI(NOL)=[F:PND]PNHNUM
      [M:PIH3]LINORI(NOL)=[F:PND]PNDLIN
      [M:PIH3]SEQORI(NOL)=0
      [M:PIH3]ITMREF(NOL)=[F:PND]ITMREF
      Call CHARG_LIG(NOL,SAVNBLIG) From SUBPIHB
      status=0 : Call LINNUM("PIDLIN") From TABLEAUX
      Call APRES_NBLIG From SUBPIH
    Next
  When 4
    For [PIDB] PID0 Where NUM=WNUM
&                       & PIDLIN>WLIN
      # Issue 87184 - 2013-01-29 by MUARN : avoir sur facture de sous-traitance fin de nomenclature si LINTYP <=2
      #If [F:PIDB]LINTYP<2  Break : Endif
      If [F:PIDB]LINTYP<=2  Break : Endif
      nolign+=1 : NOL+=1
      status=73 : Call INSERE("PIDLIN") From TABLEAUX  : If mkstat  Break : Endif
      If dim([M:PIH3]ITMREF)<[M:PIH3]NBLIG+2  mkstat=1 : Break : Endif
      Insa NOL,1,[M:PIH3]NBLIG [M:PIH3]NBLIG : [M:PIH3]NBLIG+=1
      [M:PIH3]NBCRELIG+=1
      [M:PIH3]TYPORI(NOL)=4
      [M:PIH3]NUMORI(NOL)=[F:PIDB]NUM
      [M:PIH3]LINORI(NOL)=[F:PIDB]PIDLIN
      [M:PIH3]SEQORI(NOL)=0
      [M:PIH3]ITMREF(NOL)=[F:PIDB]ITMREF
      Call CHARG_LIG(NOL,SAVNBLIG) From SUBPIHB
      status=0 : Call LINNUM("PIDLIN") From TABLEAUX
      Call APRES_NBLIG From SUBPIH
    Next
Endcase
#-----
[M:PIH3]PCLFLG=9 : # Pour marquage ligne cde "pickée" !
[M:PIH3]NBLIG=SAVNBLIG
nolign=SAVNOLIGN
NOL=nolign-1
GMODIF=1
Return

#----------------------------------------#
# Contrôle dates des factures d'origine  #
# -------------------------------------- #
# La date ne doit pas être supérieure    #
# à la date de la facture complémentaire #
# ou de l'avoir                          #
# -------------------------------------- #
# En sortie GMESSAGE est rempli et       #
#           mkstat=1                     #
#----------------------------------------#
Subprog CTLDAT_ORI(WACCDAT)
Value Date WACCDAT
#-----
If !clalev([PIHB])  Local File PINVOICE [PIHB] : Endif
If !clalev([POH])   Local File PORDER   [POH]  : Endif
If !clalev([PTH])   Local File PRECEIPT [PTH]  : Endif
If !clalev([PNH])   Local File PRETURN  [PNH]  : Endif
#-----
Local Integer I
#-----
For I=0 To [M:PIH3]NBLIG-1
  Case [M:PIH3]TYPORI(I)
    When 1
      Read [POH] POH0=[M:PIH3]NUMORI(I) : If fstat Raz [F:POH] : Endif
      If [F:POH]ORDDAT>WACCDAT
        GMESSAGE =mess(18,197,1)-num$(I+1)-":"-mess(98,197,1)-[M:PIH3]NUMORI(I)
        GMESSAGE-="("+format$(GFMD,[F:POH]ORDDAT)+")\"+mess(409,194,1)
        mkstat=1 : Break
      Endif
    When 2
      Read [PTH] PTH0=[M:PIH3]NUMORI(I) : If fstat Raz [F:PTH] : Endif
      #VPO 21/04/11 73382 ajout ctl DATORI aussi avec date BL
      If [F:PTH]NDEDAT=[0/0/0]
        If [F:PTH]RCPDAT>WACCDAT
          GMESSAGE =mess(18,197,1)-num$(I+1)-":"-mess(117,198,1)-[M:PIH3]NUMORI(I)
          GMESSAGE-="("+format$(GFMD,[F:PTH]RCPDAT)+")\"+mess(410,194,1)
          mkstat=1 : Break
        Endif
      Else
        If min([F:PTH]NDEDAT,[F:PTH]RCPDAT)>WACCDAT
          GMESSAGE =mess(18,197,1)-num$(I+1)-":"-mess(117,198,1)-[M:PIH3]NUMORI(I)
          GMESSAGE-="("+format$(GFMD,min([F:PTH]NDEDAT,[F:PTH]RCPDAT))+")\"+mess(420,194,1)
          mkstat=1 : Break
        Endif
      Endif
    When 3
      Read [PNH] PNH0=[M:PIH3]NUMORI(I) : If fstat Raz [F:PNH] : Endif
      If [F:PNH]RTNDAT>WACCDAT
        GMESSAGE =mess(18,197,1)-num$(I+1)-":"-mess(192,198,1)-[M:PIH3]NUMORI(I)
        GMESSAGE-="("+format$(GFMD,[F:PNH]RTNDAT)+")\"+mess(411,194,1)
        mkstat=1 : Break
      Endif
    When 4
      Read [PIHB] PIH0=[M:PIH3]NUMORI(I) : If fstat Raz [F:PIHB] : Endif
      If [F:PIHB]ACCDAT>WACCDAT
        GMESSAGE =mess(18,197,1)-num$(I+1)-":"-mess(55,198,1)-[M:PIH3]NUMORI(I)
        GMESSAGE-="("+format$(GFMD,[F:PIHB]ACCDAT)+")\"
        If [M:PIH0]PIHTYP=2
          GMESSAGE+=mess(408,194,1)
        Else
          GMESSAGE+=mess(407,194,1)
        Endif
        mkstat=1 : Break
      Endif
  Endcase
Next I
#-----
End

#----------------------------------------------------------------------#
# Contrôle date dernière FAR inférieure à date comptable de la facture #
#----------------------------------------------------------------------#
$CTRL_DATFAR
If GIMPORT  Return : Endif : # Ne pas faire ce contrôle en import de factures !
Case [M:PIH3]TYPORI(NOL)
  When 1 : #----- Origine commande
    If [F:POQ]CMMNUM<>""
      Columns [PTDB] (POHNUM,POPLIN,POQSEQ,PTHNUM,PTDLIN,LINPSTFLG,LINPSTDAT)
      For [PTDB] PTD2 Where POHNUM=[F:POQ]POHNUM
&                         & POPLIN=[F:POQ]POPLIN
&                         & POQSEQ=[F:POQ]POQSEQ
        If [F:PTDB]LINPSTFLG=2 & [F:PTDB]LINPSTDAT>[M:PIH0]ACCDAT
          mkstat=1 : Break
        Endif
      Next
      Columns [PTDB]
    Endif
  When 2 : #----- Origine réception
    If [F:PTD]POHNUM<>""
      Read [POQ] POQ0=[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ
      If fstat  Raz [F:POQ] : Endif
      If [F:POQ]CMMNUM<>""
        Columns [PTDB] (POHNUM,POPLIN,POQSEQ,PTHNUM,PTDLIN,LINPSTFLG,LINPSTDAT)
        For [PTDB] PTD2 Where POHNUM=[F:POQ]POHNUM
&                           & POPLIN=[F:POQ]POPLIN
&                           & POQSEQ=[F:POQ]POQSEQ
          If [F:PTDB]LINPSTFLG=2 & [F:PTDB]LINPSTDAT>[M:PIH0]ACCDAT
            mkstat=1 : Break
          Endif
        Next
        Columns [PTDB]
      Endif
    Endif
Endcase
If mkstat
  If dim(WMSG)<1  Local Char WMSG(120) : Endif
  GMESSAGE=mess(415,194,1)-"("+num$([M:PIH0]ACCDAT)-"<"-num$([F:PTDB]LINPSTDAT)+")"
  If GMESSAGE=WMSG
    Raz GMESSAGE, GERR : # Pour ne pas afficher plusieurs fois le même message
  Else
    WMSG=GMESSAGE : GERR=1
  Endif
Endif
Return

$MARQUAGE_LIGNE
#--------------------------------------------------------------#
# Actualisation d'un élément "pické" dans les listes de gauche #
# WPICK : 0 = On ne fait rien                                  #
#         1 = Enlever le marquage de l'élément "pické"         #
#         2 = Marquer l'élément "pické"                        #
#     I : indice de la ligne du tableau à traiter              #
#--------------------------------------------------------------#
#----- Si appel depuis Subprog (C_NBLIG.. etc) les variables locales n'existent pas !
If dim(FILGAUSUP)<1
  #----- Variables locales superviseur -----#
  Local Integer FILTREG : FILTREG=1
  Local Integer INDCUR  : INDCUR=1
  Local Integer ICRITERE, IFILROLE, IFILSUITE, IFILGAUSUP
  Local Char    FILTSUP(240), FILROLE(250)(0..2) , FILSUITE(250)(0..5), CRITERE(250)
  Local Char    FILGAUSUP(240)(0..3)
  Local Char    WINPROG(GLONADC), ACTION(20) : WINPROG="WGOPIH"
  Local Char    HINTLIS(10)(0..8)
  #-----
  HINTLIS(val(right$(GBOXPO1,8)))="POQ1"
  HINTLIS(val(right$(GBOXPT1,8)))="PTD1"
  HINTLIS(val(right$(GBOXPI1,8)))="PID3"
  HINTLIS(val(right$(GBOXPN1,8)))="PND2"
  HINTLIS(val(right$(GBOXSI2,8)))="SIH1"
  #----- Variables locales pour gestion picking liste de gauche -----#
  Local Char     WNUM(GLONVCR), WPOQLNK(16)
  Local Integer  WLIN
  Local Shortint J
Endif
#-----
If [M:PIH3]TYPORI(I)<5 & [M:PIH3]NUMORI(I)<>"" & [M:PIH3]CREFLG(I)=0
  J=WPICK
  WNUM=[M:PIH3]NUMORI(I) : WLIN=[M:PIH3]LINORI(I)
  WPOQLNK=mid$("00000000",1,8-len(num$([M:PIH3]LINORI(I))))+num$([M:PIH3]LINORI(I))
&        +mid$("00000000",1,8-len(num$([M:PIH3]SEQORI(I))))+num$([M:PIH3]SEQORI(I))
  If [M:PIH3]TYPORI(I)=1    : #----- Commandes -----#
    Read [POQ] POQ3=WNUM;WPOQLNK  : If fstat Raz [F:POQ] : Endif
    Read [POH] POH0=[F:POQ]POHNUM : If fstat Raz [F:POH] : Endif
    Read [FCY] FCY0=[F:POQ]POHFCY : If fstat Raz [F:FCY] : Endif
    If [F:POH]POHNUM="" & [F:FCY]FCY="" WPICK=0 : Endif
  Elsif [M:PIH3]TYPORI(I)=2 : #----- Réceptions -----#
    Read [PTD] PTD0=WNUM;WLIN     : If fstat Raz [F:PTD] : Endif
    Read [PTH] PTH0=[F:PTD]PTHNUM : If fstat Raz [F:PTH] : Endif
    Read [FCY] FCY0=[F:PTD]PRHFCY : If fstat Raz [F:FCY] : Endif
    If [F:PTH]PTHNUM="" & [F:FCY]FCY="" WPICK=0 : Endif
  Elsif [M:PIH3]TYPORI(I)=3 : #----- Retours -----#
    Read [PND] PND0=WNUM;WLIN     : If fstat Raz [F:PND] : Endif
    Read [PNH] PNH0=[F:PND]PNHNUM : If fstat Raz [F:PNH] : Endif
    Read [FCY] FCY0=[F:PND]PNHFCY : If fstat Raz [F:FCY] : Endif
    If [F:PNH]PNHNUM="" & [F:FCY]FCY="" WPICK=0 : Endif
  Elsif [M:PIH3]TYPORI(I)=4 : #----- Facture -----#
    Read [PID] PID0=WNUM;WLIN     : If fstat Raz [F:PID] : Endif
    Read [PIH] PIH0=[F:PID]NUM    : If fstat Raz [F:PIH] : Endif
    If [F:PIH]NUM="" WPICK=0 : Endif
  Endif
  If ([M:PIH3]TYPORI(I)=1 & currbox=GBOXPO1) |
&    ([M:PIH3]TYPORI(I)=2 & currbox=GBOXPT1) |
&    ([M:PIH3]TYPORI(I)=3 & currbox=GBOXPN1) |
&    ([M:PIH3]TYPORI(I)=4 & currbox=GBOXPI1)
    Case WPICK
      When 1 : Gosub DEPICK From GOBJSUB
      When 2 : Gosub REPICK From GOBJSUB
    Endcase
  Endif
  WPICK=J
Endif
Return

# Issue 89349 - 2013-10-29 by SR : Déplacé de SUBPIHA vers SUBPIHD
$CHARGENTETE
#------------------------------------------------#
# Chargement entête avant le Write ou le Rewrite #
#------------------------------------------------#
If [M:PIH1]VACTYP=4 [F:PIH]CEEFLG=2 Else [F:PIH]CEEFLG=1 : Endif
[F:PIH]NBRTAX=[M:PIH4]NBTAX
[F:PIH]AMTNOT=[M:PIH4]TOTLINAMT+sum([M:PIH4]INVDTAAMT)
[F:PIH]=[M:PCEZ]
#----- Traitement du nom et de l'adresse du fournisseur facturant -----#
If [M:AD66]ADBFLG<>2
  #----- Stockage systématique de l'adresse (Compatibilité versions précédentes) -----#
  [F:PIH]BPAINV=[M:AD66]BPAADD
  #----- Lecture BPARTNER si nécessaire -----#
  If [F:BPR]BPRNUM<>[F:PIH]BPR
    Read [BPR] BPR0=[F:PIH]BPR
    If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
  Endif
  #----- Lecture de l'adresse si nécessaire -----#
  If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:PIH]BPR | [F:BPA]BPAADD<>[F:PIH]BPAINV
    Read [BPA] BPA0=1;[F:PIH]BPR;[F:PIH]BPAINV
    If fstat  Raz [F:BPA] : Endif
  Endif
  #-----
  [F:PIH]BPRNAM(0)    = [F:BPR]BPRNAM(0)
  [F:PIH]BPRNAM(1)    = [F:BPR]BPRNAM(1)
  [F:PIH]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
  [F:PIH]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
  [F:PIH]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
  [F:PIH]CRY          = [F:BPA]CRY
  [F:PIH]CRYNAM       = [F:BPA]CRYNAM
  [F:PIH]SAT          = [F:BPA]SAT
  [F:PIH]POSCOD       = [F:BPA]POSCOD
  [F:PIH]CTY          = [F:BPA]CTY
Else
  [F:PIH]=[M:AD66]
  [F:PIH]BPAINV=[M:AD66]BPAADD
Endif
#----- Traitement du nom et de l'adresse du fournisseur payé -----#
If [M:AD67]ADBFLG<>2
  [F:PIH]BPAPAY=[M:AD67]BPAADD
  If GACTSAD=2 : # Stockage systématique de l'adresse !
    #----- Lecture BPARTNER si nécessaire -----#
    If [F:BPR]BPRNUM<>[F:PIH]BPRPAY
      Read [BPR] BPR0=[F:PIH]BPRPAY
      If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
    Endif
    #----- Lecture de l'adresse si nécessaire -----#
    If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:PIH]BPRPAY | [F:BPA]BPAADD<>[F:PIH]BPAPAY
      Read [BPA] BPA0=1;[F:PIH]BPRPAY;[F:PIH]BPAPAY
      If fstat  Raz [F:BPA] : Endif
    Endif
    #-----
    [F:PIH]BPYNAM(0)    = [F:BPR]BPRNAM(0)
    [F:PIH]BPYNAM(1)    = [F:BPR]BPRNAM(1)
    [F:PIH]BPYADDLIG(0) = [F:BPA]BPAADDLIG(0)
    [F:PIH]BPYADDLIG(1) = [F:BPA]BPAADDLIG(1)
    [F:PIH]BPYADDLIG(2) = [F:BPA]BPAADDLIG(2)
    [F:PIH]BPYCRY       = [F:BPA]CRY
    [F:PIH]BPYCRYNAM    = [F:BPA]CRYNAM
    [F:PIH]BPYSAT       = [F:BPA]SAT
    [F:PIH]BPYPOSCOD    = [F:BPA]POSCOD
    [F:PIH]BPYCTY       = [F:BPA]CTY
  Else
    Raz [F:PIH]BPYNAM,[F:PIH]BPYADDLIG,[F:PIH]BPYCRY,[F:PIH]BPYCRYNAM,
&       [F:PIH]BPYSAT,[F:PIH]BPYPOSCOD,[F:PIH]BPYCTY
  Endif
Else
  [F:PIH]BPAPAY       = [M:AD67]BPAADD
  [F:PIH]BPYNAM(0)    = [M:AD67]BPRNAM(0)
  [F:PIH]BPYNAM(1)    = [M:AD67]BPRNAM(1)
  [F:PIH]BPYADDLIG(0) = [M:AD67]BPAADDLIG(0)
  [F:PIH]BPYADDLIG(1) = [M:AD67]BPAADDLIG(1)
  [F:PIH]BPYADDLIG(2) = [M:AD67]BPAADDLIG(2)
  [F:PIH]BPYCRY       = [M:AD67]CRY
  [F:PIH]BPYCRYNAM    = [M:AD67]CRYNAM
  [F:PIH]BPYSAT       = [M:AD67]SAT
  [F:PIH]BPYPOSCOD    = [M:AD67]POSCOD
  [F:PIH]BPYCTY       = [M:AD67]CTY
Endif
#----- Chargement HT et TTC facture en devise société -----#
If [M:PIH1]RAT1<>0
  WCOURS=[M:PIH1]RAT2/[M:PIH1]RAT1
Else
  WCOURS=0
Endif
Call COURMNT([F:PIH]CUR,GLOCALDEV,GLOCALDEV,[F:PIH]CURTYP,[F:PIH]RATDAT,1,
&            [F:PIH]AMTNOT,[F:PIH]AMTNOTL,WCOURS,WRET) From TRTDEV
Call COURMNT([F:PIH]CUR,GLOCALDEV,GLOCALDEV,[F:PIH]CURTYP,[F:PIH]RATDAT,1,
&            [F:PIH]AMTATI,[F:PIH]AMTATIL,WCOURS,WRET) From TRTDEV
#-----
Return

# Issue 89349 - 2013-10-29 by SR : Déplacé de SUBPIHA vers SUBPIHD
$CHARGENTBIS
#-----------------------------------------------------------#
# Chargement complément entête avant le Write ou le Rewrite #
#-----------------------------------------------------------#
Local Shortint I
[F:PIV]=[M:PIH0] : [F:PIV]=[M:PIH1] : [F:PIV]=[M:PIH3] : [F:PIV]=[M:PIH4]
[F:PIV]INVTYP=[F:PIH]INVTYP
[F:PIV]LINNBR=[M:PIH3]NBLIG
[F:PIV]CPY   =GSOCIETE
For I=0 To dim([F:PIV]INVDTALIN1)-1 : [F:PIV]INVDTALIN1(I)=GINVDTALIN(I) : Next I
If dim([F:PIV]EXPNUM)>0 [F:PIV]EXPNUM=[C]EXPORT : Endif
Return


# Issue 89349 - 2013-10-29 by SR : Déplacé de SUBPIHA vers SUBPIHD
$CHARGLIGNE
#---------------------------------------------------------------#
# Chargement ligne avant le Write ou le Rewrite :               #
# Site facturation, Date comptable, Codes statistiques article, #
#     codes taxe et écart unitaire de revient.                  #
#---------------------------------------------------------------#
Local Integer  I
Local Shortint SAVXZSNOL, NOL : NOL=nolign-1
[F:PID]FCY=[M:PIH0]FCY : [F:PID]ACCDAT=[M:PIH0]ACCDAT : [F:PID]CPY=GSOCIETE
If dim([M:PIH3]TSICOD1(NOL))>0 [F:PID]TSICOD(0)=[M:PIH3]TSICOD1(NOL) : Endif
If dim([M:PIH3]TSICOD2(NOL))>0 [F:PID]TSICOD(1)=[M:PIH3]TSICOD2(NOL) : Endif
If dim([M:PIH3]TSICOD3(NOL))>0 [F:PID]TSICOD(2)=[M:PIH3]TSICOD3(NOL) : Endif
If dim([M:PIH3]TSICOD4(NOL))>0 [F:PID]TSICOD(3)=[M:PIH3]TSICOD4(NOL) : Endif
If dim([M:PIH3]TSICOD5(NOL))>0 [F:PID]TSICOD(4)=[M:PIH3]TSICOD5(NOL) : Endif
[F:PID]VAT(0)=[M:PIH3]VAT1(NOL)
[F:PID]VAT(1)=[M:PIH3]VAT2(NOL)
[F:PID]VAT(2)=[M:PIH3]VAT3(NOL)
#---------------------------------------------#
# Chargement unité oeuvre pour màj du réalisé #
#      lors de la validation facture.         #
#---------------------------------------------#
If clalev([F:GAC])<>0
  Call RECH_INDACC(2,I) From TRTX3CPT
  If I
    If [F:GAC]COA<>GCOA(I) | [F:GAC]ACC<>evalue("[M:PIH3]LINACC"+num$(I)+"(NOL)")
      Read [GAC] GAC0=GCOA(I);evalue("[M:PIH3]LINACC"+num$(I)+"(NOL)")
      If fstat  Raz [F:GAC] : Endif
    Endif
    If [F:GAC]FLGUOM=2  [F:PID]GLU=[F:GAC]UOM :  Endif
  Endif
Endif
If [F:PID]GLU="" [F:PID]GLU=[F:PID]PUU : Endif
If [F:PID]PUU<>[F:PID]GLU
   #----- Conversion quantité UA en unité d'oeuvre -----#
   Call PCAL_QTY([F:PID]QTYPUU,[F:PID]PUU,[F:PID]QTYGLU,[F:PID]GLU,
&                [F:PID]ITMREF,[F:PID]BPSNUM,1,GBIDD1) From TRTACHQTE1
   If [F:TCO]UOM1="" & GBIDD1=1
      #---- Conversion quantité US en unité d'oeuvre si pas de coef avec l'UA ----#
      Call PCAL_QTY([F:PID]QTYSTU,[F:PID]STU,[F:PID]QTYGLU,[F:PID]GLU,
&                   [F:PID]ITMREF,[F:PID]BPSNUM,1,GBIDD1) From TRTACHQTE1
   Endif
Else
   [F:PID]QTYGLU=[F:PID]QTYPUU
Endif
#----- Chargement prix unitaire brut si nécessaire -----#
If [F:PID]GROPRI=0 [F:PID]GROPRI=[F:PID]NETPRI : Endif
#----- Appel au point d'entrée si facture, avoir sur retour ou avoir en qté -----#
If [F:PIH]PIHTYP=1 |
&  [F:PIH]PIHTYP=4 |
& ([F:PIH]PIHTYP=3 & [F:PID]NETPRI=[F:PID]ORINETPRI & [F:PID]QTYPUU<>0)
  #---------------------------------------------------------#
  # Point d'entrée CPRFAC pour ajuster le prix de revient   #
  # ------------------------------------------------------- #
  # Ce point d'entrée n'est pas appelé pour :               #
  #    - les factures complémentaires et                    #
  #    - les avoirs en valeur                               #
  # ------------------------------------------------------- #
  # Variables utilisables par le point d'entrée :           #
  # Les classes [M:PIH0] à [M:PIH4]                         #
  # Les classes [F:PIH], [F:PIV] et [F:PID]                 #
  # NOL        : indice de la ligne en cours de traitement  #
  # [F:PID]CPR : Prix unitaire de revient calculé           #
  # ------------------------------------------------------- #
  # Variable modifiable par le point d'entrée :             #
  # [F:PID]CPR contient le prix unitaire de revient modifié #
  #---------------------------------------------------------#
  SAVXZSNOL=NOL
  GPOINT="CPRFAC" : Gosub ENTREE From EXEFNC
  NOL=SAVXZSNOL : nolign=SAVXZSNOL+1
  [M:PIH3]CPR(NOL)=[F:PID]CPR
Endif
#--- Pas d'écart unitaire de revient si facture ou avoir/retour ou avoir en qté ---#
Return

# Issue 100651 - 2014-06-06 by MUARN : Déplacement de SUBPIHA à SUBPIHD
# MAJ_FICHIERS_LIGNE et des étiquettes appelées
# subprog MAJ_CDE
# Subprog MAJ_DESENGAGE
# Subprog MAJ_RCP

#--------------------------------------------------------#
# Mise a jour des fichiers commande, reception et retour #
#--------------------------------------------------------#
$MAJ_FICHIERS_LIGNE
If [M:PIH1]STA=3 Return : Endif : # Pas de màj si facture validée (import)
Local Integer WNBRCP
Raz WQTE2
If [F:PID]NUMORI="" | [F:PID]LINORI=0 [F:PID]TYPORI=5 : Endif
Case [F:PID]TYPORI
  When 1 : Gosub MAJ_LIGORICDE
  When 2 : Gosub MAJ_LIGORIRCP
  When 3 : Gosub MAJ_LIGORIRET
  When 4 : Gosub MAJ_LIGORIFAC
  When 5 : Gosub MAJ_LIGDIVERS
Endcase
Return
#--------------------------------------------------------#
# Mise a jour des fichiers si ligne issue d'une commande #
#--------------------------------------------------------#
$MAJ_LIGORICDE
# Issue 82703 - 2012-10-05 by SR
#----- Pas de màj si facture complémentaire -----#
If [M:PIH0]PIHTYP=2
  If [M:PIH3]CREFLG(nolign-1)=0  Unlock="POH"+[F:PID]NUMORI : Endif
  Return
Endif
#----- Récupération de la quantité facturée des autres factures -----#
If SIGN=-1
  Read [POQ] POQ0=[F:PID]NUMORI;[F:PID]LINORI;[F:PID]SEQORI
  If !fstat
    WQTE2=max([F:POQ]INVQTYPUU-[F:PID]QTYPUU,0)
  Endif
Endif
#-----
WQTEUOM=[F:PID]QTYUOM
WQTE=[F:PID]QTYPUU : Raz WNBRCP
If clalev([F:PTDB])<=0 Local File PRECEIPTD [PTDB] : Default File [PID] : Endif
Filter [PTDB] Where POHNUM=[F:PID]NUMORI & POPLIN=[F:PID]LINORI & POQSEQ=[F:PID]SEQORI
&             Order By Key PTD2
For [PTDB]
  # Issue 100651 - 2014-06-06 by MUARN : Déplacement de SUBPIHA à SUBPIHD
  Call MAJ_RCP(SIGN,[F:PTDB]PTHNUM,[F:PTDB]PTDLIN,WQTE,WQTEUOM,WQTE2,WNBRCP) From SUBPIHD
  If GOK<1  Break : Endif
  If WQTE=0 & [F:PID]PRTFLG=2  Break : Endif
Next
Filter [PTDB]
If GOK<1 Return : Endif
# Issue 100651 - 2014-06-06 by MUARN : Déplacement de SUBPIHA à SUBPIHD
Call MAJ_CDE(SIGN,[F:PID]NUMORI,[F:PID]LINORI,[F:PID]SEQORI,WNBRCP) From SUBPIHD
If GOK<1 Return : Endif
If WQTE<>0 & WNBRCP<>0 & [F:POQ]LINCLEFLG=2
# Issue 100651 - 2014-06-06 by MUARN : Déplacement de SUBPIHA à SUBPIHD
  Gosub MAJ_EXTRA_QTE From SUBPIHA : # Màj qtés facturées de la réception si excédent de facturation
  If GOK<1 Return : Endif
Endif
Return
#---------------------------------------------------------#
# Mise a jour des fichiers si ligne issue d'une réception #
#---------------------------------------------------------#
$MAJ_LIGORIRCP
#----- Pas de màj si facture complémentaire -----#
If [M:PIH0]PIHTYP=2
  If [M:PIH3]CREFLG(nolign-1)=0  Unlock="PTH"+[F:PID]NUMORI : Endif
  Return
Endif
#-----
WQTEUOM=[F:PID]QTYUOM
WQTE=[F:PID]QTYPUU : Raz WNBRCP
# Issue 100651 - 2014-06-06 by MUARN : Déplacement de SUBPIHA à SUBPIHD
Call MAJ_RCP(SIGN,[F:PID]NUMORI,[F:PID]LINORI,WQTE,WQTEUOM,WQTE2,WNBRCP) From SUBPIHD
If GOK<1 Return : Endif
If WQTE<>0
  # Issue number - 2011-09-20 by VPO : ajout PE pour permettant de ne pas
  # imputer la quantité sur-facturée sur des réceptions existantes.
  #----------------------------------------------------------------------#
  # Point d'entrée PIHOVEINV : Imputation sur-facturation sur réceptions #
  # -------------------------------------------------------------------- #
  # Variables utilisables par le point d'entrée                          #
  #                                                                      #
  #  SIGN : vaut -1 dans le cas d'une suppression                        #
  #               1 dans le cas d'une création                           #
  #  WQTE : Qté en excédent de facturation                               #
  #  WPIHOVEINV : Indicateur d'imputation sur les autres réceptions      #
  #              (0=Non,1=Oui)                                           #
  # Les classes [F:PIH], [F:PIV] , [F:PID] et [F:PTD] sont disponibles   #
  #----------------------------------------------------------------------#
  WPIHOVEINV=1
  GPOINT="PIHOVEINV" : Gosub ENTREE From EXEFNC
  If WPIHOVEINV
    If [M:PIH0]BETCPY=2
      # Issue 100651 - 2014-06-06 by MUARN : Déplacement de SUBPIHA à SUBPIHD
      Gosub MAJ_EXTRA_INTSOC From SUBPIHA : # Màj qtés facturées réceptions inter-sociétés
    Else
      # Issue 100651 - 2014-06-06 by MUARN : Déplacement de SUBPIHA à SUBPIHD
      Gosub MAJ_EXTRA_QTE From SUBPIHA    : # Màj qtés facturées réception si excédent de facturation
    Endif
    If GOK<1 Return : Endif
  Else
    # Issue 100651 - 2014-06-06 by MUARN : Déplacement de SUBPIHA à SUBPIHD
    Gosub MAJ_EXTRA_QTE_PTD From SUBPIHA    : # Màj qtés facturées sur la reception
    If GOK<1 Return : Endif
  Endif
Endif
If GIMPORT & [F:PTH]PTHNUM="" Return : Endif
If [F:PTD]POHNUM<>""
  # Issue 100651 - 2014-06-06 by MUARN : Déplacement de SUBPIHA à SUBPIHD
  Call MAJ_CDE(SIGN,[F:PTD]POHNUM,[F:PTD]POPLIN,[F:PTD]POQSEQ,WNBRCP) From SUBPIHD
  If GOK<1 Return : Endif
Else
  Raz [F:POQ]
Endif
Return
#-----------------------------------------------------#
# Mise a jour des fichiers si ligne issue d'un retour #
#-----------------------------------------------------#
$MAJ_LIGORIRET
# Issue 84130 - 2013-02-28 by SR : Pavé dévpalcé dans SUBPIHC
Call MAJ_RET(SIGN,[F:PID]NUMORI,[F:PID]LINORI) From SUBPIHC
If GOK<1 Return : Endif
If GIMPORT & [F:PNH]PNHNUM="" Return : Endif
If [F:PND]POHNUM<>"" & [F:PND]ORDFLG=2 : # Réintégration en commande sur même ligne
  # Issue 100651 - 2014-06-06 by MUARN : Déplacement de SUBPIHA à SUBPIHD
  Call MAJ_CDE(SIGN,[F:PND]POHNUM,[F:PND]POPLIN,[F:PND]POQSEQ,0) From SUBPIHD
  If GOK<1 Return : Endif
  If GIMPORT & [F:POH]POHNUM="" Return : Endif
Endif
Return
#-------------------------------------------------------#
# Mise a jour des fichiers si ligne issue d'une facture #
#-------------------------------------------------------#
$MAJ_LIGORIFAC
WQTEUOM=[F:PID]QTYUOM
WQTE=[F:PID]QTYPUU : Raz WNBRCP
If clalev([F:PIDB])<=0 Local File PINVOICED [PIDB] : Default File [PID] : Endif
#----- Avoir sur facture -----#
If [M:PIH0]PIHTYP=3
  Read [PIDB] PID0=[F:PID]NUMORI;[F:PID]LINORI : If fstat Raz [F:PIDB] : Endif
  # Issue 78733 - 2012-01-20 by VPO : ajout PE
  #----------------------------------------------------------------------#
  # Point d'entrée MAJRCPCDE Maj réceptions et commande suite avoir      #
  # -------------------------------------------------------------------- #
  # Variables utilisables par le point d'entrée                          #
  #                                                                      #
  # WMAJRCPCDE  : indicateur de modif à effectuer                        #
  # Les classes [F:PIH], [F:PIV] et [F:PID] sont disponibles             #
  # La  classe  [F:PIDB] est disponible                                  #
  #----------------------------------------------------------------------#
  WMAJRCPCDE=2
  GPOINT="MAJRCPCDE" : Gosub ENTREE From EXEFNC
# #----- Avoir sur ligne de facture issue d'une commande -----#
  #If [F:PIDB]TYPORI=1
  If [F:PIDB]TYPORI=1 & WMAJRCPCDE=2
    # Issue 87790 - 2013-02-08 by MUARN : pour avoir en quantité testé qté et non prix
    #If [F:PID]NETPRI=[F:PID]ORINETPRI : Màj de la réception que si avoir en qté
    # Issue 87781 - 2013-02-18 by MUARN : avoir total
    #If ([F:PID]QTYPUU<>[F:PID]ORIQTYPUU)
    If ([F:PID]QTYPUU<>[F:PID]ORIQTYPUU) | ([F:PID]QTYPUU=[F:PID]ORIQTYPUU & [F:PID]NETPRI=[F:PID]ORINETPRI)
      # Issue 90325 - 2013-06-13 by MUARN : contrôle avant prise en compte de l'avoir sur les réceptions
      # si la quantité réceptionnée est inférieur à (la quantité facturée - la quantité à régulariser)
      # aucune mise à jour de réception n'est à faire
      Read [POQ] POQ0=[F:PIDB]NUMORI;[F:PIDB]LINORI;[F:PIDB]SEQORI
      If [F:POQ]RCPQTYPUU > ([F:POQ]INVQTYPUU - WQTE)
        If clalev([F:PTDB])<=0 Local File PRECEIPTD [PTDB] : Default File [PID] : Endif
        Filter [PTDB] Where POHNUM=[F:PIDB]NUMORI & POPLIN=[F:PIDB]LINORI & POQSEQ=[F:PIDB]SEQORI
&                   Order By Key PTD2
        For [PTDB]
          # Issue 100651 - 2014-06-06 by MUARN : Déplacement de SUBPIHA à SUBPIHD
          Call MAJ_RCP(SIGN,[F:PTDB]PTHNUM,[F:PTDB]PTDLIN,WQTE,WQTEUOM,WQTE2,WNBRCP) From SUBPIHD
          If GOK<1  Break : Endif
          If WQTE=0 Break : Endif
        Next
        Filter [PTDB]
        If GOK<1 Return : Endif
      Endif
    Endif
    # Issue 100651 - 2014-06-06 by MUARN : Déplacement de SUBPIHA à SUBPIHD
    Call MAJ_CDE(SIGN,[F:PIDB]NUMORI,[F:PIDB]LINORI,[F:PIDB]SEQORI,WNBRCP) From SUBPIHD
    If GOK<1 Return : Endif
    If WQTE<>0 & WNBRCP<>0 & [F:POQ]LINCLEFLG=2
      # Issue 100651 - 2014-06-06 by MUARN : Déplacement de SUBPIHA à SUBPIHD
      Gosub MAJ_EXTRA_QTE From SUBPIHA : # Màj qtés facturées réception si excédent de facturation
      If GOK<1 Return : Endif
    Endif
  Endif
# #----- Avoir sur ligne de facture issue d'une réception -----#
  #If [F:PIDB]TYPORI=2
  If [F:PIDB]TYPORI=2 & WMAJRCPCDE=2
    # Issue 87790 - 2013-02-08 by MUARN : pour avoir en quantité testé qté et non prix
    #If [F:PID]NETPRI=[F:PID]ORINETPRI : Màj de la réception que si avoir en qté
    # Issue 87781 - 2013-02-18 by MUARN : avoir total
    #If [F:PID]QTYPUU<>[F:PID]ORIQTYPUU
    If [F:PID]QTYPUU<>[F:PID]ORIQTYPUU | ([F:PID]QTYPUU=[F:PID]ORIQTYPUU & [F:PID]NETPRI=[F:PID]ORINETPRI)
      # Issue 100651 - 2014-06-06 by MUARN : Déplacement de SUBPIHA à SUBPIHD
      Call MAJ_RCP(SIGN,[F:PIDB]NUMORI,[F:PIDB]LINORI,WQTE,WQTEUOM,WQTE2,WNBRCP) From SUBPIHD
      If GOK<1 Return : Endif
      If WQTE<>0
        # Issue 100651 - 2014-06-06 by MUARN : Déplacement de SUBPIHA à SUBPIHD
        Gosub MAJ_EXTRA_QTE From SUBPIHA : # Màj qtés facturées réception si excédent de facturation
        If GOK<1 Return : Endif
      Endif
      If GIMPORT & [F:PTH]PTHNUM="" Return : Endif
    Else
      Read [PTD] PTD0=[F:PIDB]NUMORI;[F:PIDB]LINORI : If fstat Raz [F:PTD] : Endif
    Endif
    If [F:PTD]POHNUM<>""
      # Issue 100651 - 2014-06-06 by MUARN : Déplacement de SUBPIHA à SUBPIHD
      Call MAJ_CDE(SIGN,[F:PTD]POHNUM,[F:PTD]POPLIN,[F:PTD]POQSEQ,WNBRCP) From SUBPIHD
      If GOK<1 Return : Endif
    Else
      Raz [F:POQ]
    Endif
  Endif
#----- Facture complémentaire (Plus de màj de la facture d'origine) -----#
Else
  If [M:PIH3]CREFLG(nolign-1)=0  Unlock="PIH"+[F:PID]NUMORI : Endif
Endif
#-----
Return
#-------------------------------------------#
# Mise a jour des fichiers si ligne diverse #
#-------------------------------------------#
$MAJ_LIGDIVERS
Return


########################################################################
# MAJ_CDE : S/P de mise à jour des fichiers commande entête et ligne   #
#                     (PORDER, PORDERQ et PORDERC)                     #
# -------------------------------------------------------------------- #
# Subprog MAJ_CDE(SIGN,NUMERO,LIGNE,SEQUENCE,WNBRCP)                   #
#   SIGN     : Sens de la mise à jour (+1=Cumul, -1=Soustraction)      #
#   NUMERO   : Numéro   de la commande à mettre à jour                 #
#   LIGNE    : Ligne    de la commande à mettre à jour                 #
#   SEQUENCE : Séquende de la commande à mettre à jour                 #
#   WNBRCP   : Delta du nombre de réceptions entierement facturées     #
########################################################################
Subprog MAJ_CDE(SIGN,NUMERO,LIGNE,SEQUENCE,WNBRCP)
Value    Integer  SIGN
Value    Char     NUMERO
Value    Integer  LIGNE
Value    Integer  SEQUENCE
Value    Integer  WNBRCP
#----- Variables locales -----#
Local    Shortint FLG, FLG2, WPRIREN, WLINCLEFLG, WRCPCLEFLG
Local    Decimal  RELIQUAT, WQTYBUDLIN, WQTY, WORDNOT, WORDATI
Local    Libelle  WANC_LINCLEFLG
Local    Char     SYMBOL2(30), CLEFIC(33)
# Issue 94968/95376 - 2013-12-05 by MUARN : avoir qui désolde la commande
Local    Shortint SAV_FLG, SAV_FLG2
Local    Decimal  SAV_INVQTYPUU

#----- Variables pour le point d'entrée MAJFAC -----#
Local    Char     FICHIER(GLONATB), ABRFIC(3)
#----- Variables pour le point d'entrée POHCLE -----#
Local    Libelle  WPE_POHCLEFLG, WCLEFLG, WTRAIT
#----- Si entête commande bloquée logiquement --> Abandon -----#
CLEFIC=NUMERO : SYMBOL2="POH"+NUMERO : Lock=SYMBOL2
If fstat GMESSAGE="$PORDER"-CLEFIC-mess(10,100,1) : GERR=1
         GOK=0 : End : Endif
#----- Lecture entête et ligne commande avec blocage physique -----#
Readlock [POH] POH0=NUMERO
#----- Pas de màj et pas d'erreur en import si commande n'existe pas -----#
If GIMPORT & fstat Raz [F:POH] : Goto DEBLOC_CDE : Endif
If fstat=1  GOK=-1 : GLOCK="$PORDER"-CLEFIC             : Goto DEBLOC_CDE
Elsif fstat GOK=0  : Call RSTA("POH",CLEFIC) From GLOCK : Goto DEBLOC_CDE
Endif
CLEFIC+=" "+num$(LIGNE)+" "+num$(SEQUENCE)
Readlock [POQ] POQ0=NUMERO;LIGNE;SEQUENCE
#----- Pas de màj et pas d'erreur en import si ligne commande n'existe pas -----#
If GIMPORT & fstat Raz [F:POQ] : Goto DEBLOC_CDE : Endif
If fstat=1  GOK=-1 : GLOCK="$PORDERQ"-CLEFIC            : Goto DEBLOC_CDE
Elsif fstat GOK=0  : Call RSTA("POQ",CLEFIC) From GLOCK : Goto DEBLOC_CDE
Endif
Raz WPE_POHCLEFLG
WANC_LINCLEFLG=[F:POQ]LINCLEFLG
#----- Lecture du fichier ligne commande prix PORDERP [POP] -----#
If [F:POH]POHTYP=1
  Read [POP] POP0=NUMERO;LIGNE;1
  If fstat : Raz [F:POP] : Endif
Else
  Filter [POP] Where POHNUM=NUMERO & POPLIN=LIGNE & POPDAT>=[F:POQ]DEMRCPDAT
  Read [POP] POP1 First
  If fstat : Raz [F:POP] : Endif
  Filter [POP]
# #----- Lecture ligne contrat commande ouverte (PORDERC) avec blocage physique -----#
  CLEFIC=NUMERO+" "+num$(LIGNE)
  Readlock [POC] POC0=NUMERO;LIGNE
  If GIMPORT & fstat Raz [F:POC] : Goto DEBLOC_CDE : Endif
  If fstat=1  GOK=-1 : GLOCK="$PORDERC"-CLEFIC            : Goto DEBLOC_CDE
  Elsif fstat GOK=0  : Call RSTA("POC",CLEFIC) From GLOCK : Goto DEBLOC_CDE
  Endif
Endif
If SIGN=-1
# #----- Mise à jour nbre de facture (si facture ou avoir complet) -----#
  If [F:PIH]INVTYP=1 | ([F:PIH]PIHTYP=3 & [F:PID]PRTFLG=1)
    # Issue 84130 - 2013-04-03 by MUARN : landed-cost-ne pas prendre avoir sur FCC
    Local Shortint MAJ_NBLIG
    MAJ_NBLIG = 2
    If [F:PIH]PIHTYP = 3
      If !clalev([F:PIHD]) Local File PINVOICE [PIHD]  : Endif
      If [F:PIHD]NUM<> [F:PID]NUMORI
        Read [PIHD] PIH0=[F:PID]NUMORI
        If fstat Raz [F:PIH] : Endif
      Endif
      If [F:PIHD]PIHTYP=2 : MAJ_LIG=1 : Endif
    Endif
    If MAJ_NBLIG = 2
      [F:POQ]LININVNBR-=1*(3-(2*[F:PIH]INVTYP))
      [F:POH]INVNBR   -=1*(3-(2*[F:PIH]INVTYP))
    Endif
  Endif
# #----- Mise à jour qtés facturées (si facture, avoir/retour ou avoir en qté -----#
  # Issue 87790 - 2013-02-08 by MUARN : pour avoir en quantité testé qté et non prix
  #If [F:PIH]PIHTYP<>3 | ([F:PIH]PIHTYP=3 & [F:PID]NETPRI=[F:PID]ORINETPRI)
  # Issue 87781 - 2013-02-18 by MUARN : avoir total
  #If [F:PIH]PIHTYP<>3 | ([F:PIH]PIHTYP=3 & [F:PID]QTYPUU<>[F:PID]ORIQTYPUU)
  If [F:PIH]PIHTYP<>3 | ([F:PIH]PIHTYP=3 & [F:PID]QTYPUU<>[F:PID]ORIQTYPUU) |
&    ([F:PIH]PIHTYP=3 & [F:PID]QTYPUU=[F:PID]ORIQTYPUU & [F:PID]NETPRI=[F:PID]ORINETPRI)
    [F:POQ]INVQTYPUU-=[F:PID]QTYPUU*(3-(2*[F:PIH]INVTYP))
    # Issue X3-25003 - 2018-04-05 by SR : Ne pas passer en négatif (avoir en qté supérieure à qté facture)
    If [F:POQ]INVQTYPUU < 0 : Raz [F:POQ]INVQTYPUU : Endif
    If [F:PID]UOM=[F:POQ]STU
      GBIDD1=[F:PID]QTYUOM
    Else
      Call PCAL_QTY([F:PID]QTYPUU,[F:PID]PUU,GBIDD1,[F:POQ]STU,
&                   [F:PID]ITMREF,[F:POQ]BPSNUM,1,GBIDD2) From TRTACHQTE1
    Endif
    [F:POQ]INVQTYSTU-=GBIDD1*(3-(2*[F:PIH]INVTYP))
   # Issue X3-88031 - 2018-04-27 by SR : Ne pas passer en négatif (avoir en qté supérieure à qté facture)
    If [F:POQ]INVQTYSTU < 0 : Raz [F:POQ]INVQTYSTU : Endif
    If [F:POH]POHTYP=2
      [F:POC]INVQTYPUU-=[F:PID]QTYPUU*(3-(2*[F:PIH]INVTYP))
      [F:POC]INVQTYSTU-=GBIDD1*(3-(2*[F:PIH]INVTYP))
      # Issue X3-88031 - 2018-04-27 by SR : Ne pas passer en négatif
      If [F:POC]INVQTYPUU < 0 : Raz [F:POC]INVQTYPUU : Endif
      If [F:POC]INVQTYSTU < 0 : Raz [F:POC]INVQTYSTU : Endif
    Endif
  Endif
# #----- Positionnement indicateur ligne facturée -----#
  FLG=[F:POQ]LININVFLG
  If [F:PIH]INVTYP=1    : # Facture
    If [F:POQ]QTYPUU>[F:POQ]INVQTYPUU       FLG=1 : Endif
  Elsif [F:PIH]PIHTYP=3 : # Avoir
    # Issue 87790 - 2013-02-08 by MUARN : pour avoir en quantité testé qté et non prix
    #If [F:PID]NETPRI=[F:PID]ORINETPRI : Màj de la réception que si avoir en qté
    # Issue 87781 - 2013-02-18 by MUARN : avoir total
    #If [F:PID]QTYPUU<>[F:PID]ORIQTYPUU
    If [F:PID]QTYPUU<>[F:PID]ORIQTYPUU | ([F:PID]QTYPUU=[F:PID]ORIQTYPUU & [F:PID]NETPRI=[F:PID]ORINETPRI)
      If [F:POQ]QTYPUU<=[F:POQ]INVQTYPUU    FLG=2 : Endif
      If [F:PIDB]PRTFLG=1
        If [F:PIDB]TYPORI=1                 FLG=2 : Endif
        # Issue X3-107595 - 2018-09-12 by SR : PEC du delta de rcp facturées
#        If [F:PIDB]TYPORI=2 &
#&          [F:POQ]LINRCPNBR-1=[F:POQ]INVRCPNBR &
#&          [F:POQ]LINCLEFLG=2               FLG=2 : Endif
        # si facture de réception et nbre de réceptions = nbre de réceptions facturées et ligne cde soldée
        If [F:PIDB]TYPORI=2 &
&          [F:POQ]LINRCPNBR=[F:POQ]INVRCPNBR + WNBRCP &
&          [F:POQ]LINCLEFLG=2               FLG=2 : Endif
        # Issue X3-107595
      Endif
    Endif
  Elsif [F:PIH]PIHTYP=4 : # Avoir/retour
    If [F:POQ]QTYPUU<=[F:POQ]INVQTYPUU      FLG=2 : Endif
  Endif
  If [F:POQ]LININVFLG<>FLG
    If FLG=2 [F:POH]INVLINNBR+=1 Else [F:POH]INVLINNBR-=1 : Endif
    [F:POQ]LININVFLG=FLG
  Endif
# #----- Mise à jour nbre de réceptions facturées -----#
  If [F:PIH]INVTYP=1 & [F:POQ]RCPCLEFLG=1 & [F:POQ]LINCLEFLG=2 & [F:PID]PRIREN<0
    [F:POQ]RCPCLEFLG=2
  Elsif [F:PIH]INVTYP=2 & [F:POQ]RCPCLEFLG=2 & [F:POQ]LINCLEFLG=2 & [F:PID]PRIREN<0
    [F:POQ]RCPCLEFLG=1
  Endif
  [F:POQ]INVRCPNBR+=WNBRCP
  WQTYBUDLIN=[F:PID]QTYPUU
# #----- Commande soldée : récupération désengagement avant modif -----#
  If [F:POQ]LINCLEFLG=2 & [F:POQ]RCPCLEFLG=1 & GREP="M"
    [M:PIH3]QTYBUDLIN(nolign-1)=[F:PID]QTYBUDLIN
  Endif
# #--- Positionnement indicateur ligne soldée pour article non réceptionnable ---#
  If [F:ITM]RCPFLG=1 | [F:POQ]ORI=2
    FLG2=[F:POQ]LINCLEFLG
    # Issue 109186 - 2015-06-30 by MUARN : ne pas positionner une commande à facturée pour avoir
    # et facture d'origine partielle
    #If [F:PIH]INVTYP=1 FLG2=1 Elsif [F:PID]PRTFLG=1 & [F:PID]QTYUOM<>0 FLG2=2 : Endif
    If [F:PIH]INVTYP=1
      FLG2=1
    Elsif [F:PID]PRTFLG=1 & [F:PID]QTYUOM<>0 & [F:PIDB]PRTFLG=1
      FLG2=2
    Endif
    If [F:POQ]LINCLEFLG<>FLG2
      If FLG2=2 [F:POH]CLELINNBR+=1  Else  [F:POH]CLELINNBR-=1  : Endif
      [F:POQ]LINCLEFLG=FLG2 : WPE_POHCLEFLG=1
      #----- Si DL de commande ouverte, mettre à jour l'état de la ligne -----#
      If [F:POQ]POHTYP=2
        If [F:POQ]LINCLEFLG=2
          [F:POQ]LINSTA=3
        Elsif [F:POQ]EXTRCPDAT<date$
          [F:POQ]LINSTA=2
        Else
          [F:POQ]LINSTA=1
        Endif
      Endif
      #-----
    Endif
  Endif
Else
# #----- Mise à jour nbre de facture et date (si facture ou avoir complet) -----#
  If [F:PIH]INVTYP=1 | ([F:PIH]PIHTYP=3 & [F:PID]PRTFLG=1)
    # Issue 84130 - 2013-04-03 by MUARN : landed-cost-ne pas prendre avoir sur FCC
    Local Shortint MAJ_NBLIG
    MAJ_NBLIG = 2
    If [F:PIH]PIHTYP = 3
      If !clalev([F:PIHD]) Local File PINVOICE [PIHD]  : Endif
      If [F:PIHD]NUM<> [F:PID]NUMORI
        Read [PIHD] PIH0=[F:PID]NUMORI
        If fstat Raz [F:PIH] : Endif
      Endif
      If [F:PIHD]PIHTYP=2 : MAJ_LIG=1 : Endif
    Endif
    If MAJ_NBLIG = 2
      [F:POQ]LININVNBR+=1*(3-(2*[F:PIH]INVTYP))
      [F:POH]INVNBR   +=1*(3-(2*[F:PIH]INVTYP))
      [F:POQ]LASINVDAT=[F:PIH]ACCDAT
    Endif
  Endif
  # Issue 94968 - 2013-12-05 by MUARN : avoir qui désolde la commande
  SAV_INVQTYPUU= [F:POQ]INVQTYPUU
# #----- Mise à jour qtés facturées (si facture, avoir/retour ou avoir en qté -----#
  # Issue 87790 - 2013-02-08 by MUARN : pour avoir en quantité testé qté et non prix
  #If [F:PIH]PIHTYP<>3 | ([F:PIH]PIHTYP=3 & [F:PID]NETPRI=[F:PID]ORINETPRI)
  # Issue 87781 - 2013-02-18 by MUARN : avoir total
  If [F:PIH]PIHTYP<>3 | ([F:PIH]PIHTYP=3 & [F:PID]QTYPUU<>[F:PID]ORIQTYPUU) |
&    ([F:PIH]PIHTYP=3 & [F:PID]QTYPUU=[F:PID]ORIQTYPUU & [F:PID]NETPRI=[F:PID]ORINETPRI)
    [F:POQ]INVQTYPUU+=[F:PID]QTYPUU*(3-(2*[F:PIH]INVTYP))
    If [F:PID]UOM=[F:POQ]STU
      GBIDD1=[F:PID]QTYUOM
    Else
      Call PCAL_QTY([F:PID]QTYPUU,[F:PID]PUU,GBIDD1,[F:POQ]STU,
&                   [F:PID]ITMREF,[F:POQ]BPSNUM,1,GBIDD2) From TRTACHQTE1
    Endif
    [F:POQ]INVQTYSTU+=GBIDD1*(3-(2*[F:PIH]INVTYP))
    # Issue X3-88031 - 2018-04-27 by SR : Ne pas passer en négatif
    If [F:POQ]INVQTYPUU < 0 : Raz [F:POQ]INVQTYPUU : Endif
    If [F:POQ]INVQTYSTU < 0 : Raz [F:POQ]INVQTYSTU : Endif
    If [F:POH]POHTYP=2
      [F:POC]INVQTYPUU+=[F:PID]QTYPUU*(3-(2*[F:PIH]INVTYP))
      [F:POC]INVQTYSTU+=GBIDD1*(3-(2*[F:PIH]INVTYP))
      # Issue X3-88031 - 2018-04-27 by SR : Ne pas passer en négatif
      If [F:POC]INVQTYPUU < 0 : Raz [F:POC]INVQTYPUU : Endif
      If [F:POC]INVQTYSTU < 0 : Raz [F:POC]INVQTYSTU : Endif
    Endif
  Endif
# #----- Positionnement indicateur ligne facturée -----#
  FLG=[F:POQ]LININVFLG
  # Issue 94968 - 2013-12-05 by MUARN : avoir qui désolde la facture
  SAV_FLG=FLG
  If [F:PIH]INVTYP=1    : # Facture
    If [F:POQ]QTYPUU<=[F:POQ]INVQTYPUU       FLG=2 : Endif
    If [F:PID]PRTFLG=1
      If [F:PID]TYPORI=1                     FLG=2 : Endif
      # Issue X3-107595 - 2018-09-12 by SR : PEC du delta de rcp facturées
#      If [F:PID]TYPORI=2 &
#&        [F:POQ]LINRCPNBR-1=[F:POQ]INVRCPNBR &
#&        [F:POQ]LINCLEFLG=2                  FLG=2 : Endif
      # si facture de réception et nbre de réceptions = nbre de réceptions facturées et ligne cde soldée
      If [F:PID]TYPORI=2 &
&          [F:POQ]LINRCPNBR=[F:POQ]INVRCPNBR + WNBRCP &
&          [F:POQ]LINCLEFLG=2               FLG=2 : Endif
      # Issue X3-107595
    Endif
  Elsif [F:PIH]PIHTYP=3 : # Avoir
    # Issue 87790 - 2013-02-08 by MUARN : pour avoir en quantité testé qté et non prix
    #If [F:PID]NETPRI=[F:PID]ORINETPRI : Màj de la réception que si avoir en qté
    # Issue 87781 - 2013-02-18 by MUARN : avoir total
    #If [F:PID]QTYPUU<>[F:PID]ORIQTYPUU
    If [F:PID]QTYPUU<>[F:PID]ORIQTYPUU | ([F:PID]QTYPUU=[F:PID]ORIQTYPUU & [F:PID]NETPRI=[F:PID]ORINETPRI)
      If [F:POQ]QTYPUU>[F:POQ]INVQTYPUU   FLG=1 : Endif
    Else
      WPRIREN=abs([F:PID]PRIREN)
      Update [PID] Where NUM=[M:PIH0]NUM & PIDLIN=[M:PIH3]PIDLIN(nolign-1)
&                  With PRIREN=WPRIREN
      If fstat
        GOK=0 : Call FSTA("PID") From GLOCK
      Else
        [F:PID]PRIREN=WPRIREN
        [M:PIH3]PRIREN(nolign-1)=WPRIREN
      Endif
    Endif
  Elsif [F:PIH]PIHTYP=4 : # Avoir/retour
    If [F:POQ]QTYPUU>[F:POQ]INVQTYPUU     FLG=1 : Endif
  Endif
  If [F:POQ]LININVFLG<>FLG
    If FLG=2 [F:POH]INVLINNBR+=1 Else [F:POH]INVLINNBR-=1 : Endif
    [F:POQ]LININVFLG=FLG
  Endif
# #----- Mise à jour nbre de réceptions facturées et qté désengagement -----#
  [F:POQ]INVRCPNBR+=WNBRCP
# #----- Plafonnement quantité de désengagement et calcul reliquat -----#
  WQTYBUDLIN=[F:PID]QTYPUU
  If [F:PIH]INVTYP=1 : # Si facture
    If WQTYBUDLIN>[F:POQ]QTYPUU-([F:POQ]INVQTYPUU-([F:PID]QTYPUU*(3-(2*[F:PIH]INVTYP))))
      WQTYBUDLIN=[F:POQ]QTYPUU-([F:POQ]INVQTYPUU-([F:PID]QTYPUU*(3-(2*[F:PIH]INVTYP))))
      If WQTYBUDLIN<0 Raz WQTYBUDLIN : Endif
    Endif
  Else : # Si avoir
    If WQTYBUDLIN>[F:POQ]QTYPUU-[F:POQ]INVQTYPUU
      WQTYBUDLIN=[F:POQ]QTYPUU-[F:POQ]INVQTYPUU
      If WQTYBUDLIN<0 Raz WQTYBUDLIN : Endif
    Endif
    # Issue 95376 - 2013-12-18 by MUARN : plusieurs factures, et avoir non sur la dernière facture
    # PRIREN est positif, mais il faut le même comportement sur les flags de la commande
    #If [F:POQ]RCPCLEFLG=1 & [F:POQ]LINCLEFLG=2 & [F:POQ]LININVFLG<>2 & [F:PID]PRIREN<0
    If [F:POQ]RCPCLEFLG=1 & [F:POQ]LINCLEFLG=2 & [F:POQ]LININVFLG<>2
      [F:POQ]RCPCLEFLG=2
    Endif
  Endif
# #----- Commande soldée et nouvelle ligne facture : pas de désengagement -----#
  If [F:PIH]INVTYP=1 & [F:POQ]LINCLEFLG=2 & [F:POQ]RCPCLEFLG=1 & [M:PIH3]CREFLG(nolign-1)=0
  # #----- Raz uniquement si l'article est réceptionnable -----#
    If [F:ITM]RCPFLG<>1 & [F:POQ]ORI<>2
      Raz WQTYBUDLIN
    Endif
  Endif
# #----- Commande soldée et modif ligne : récupération désengagement avant modif -----#
  If [F:PIH]INVTYP=1 & [F:POQ]LINCLEFLG=2 & [F:POQ]RCPCLEFLG=1 & [M:PIH3]CREFLG(nolign-1)<>0
    WQTYBUDLIN=[F:PID]QTYBUDLIN
  Endif
# #--- Positionnement indicateur ligne soldée pour article non réceptionnable ---#
  If [F:ITM]RCPFLG=1 | [F:POQ]ORI=2
    FLG2=[F:POQ]LINCLEFLG
    # Issue 95376 - 2013-12-11 by MUARN : avoir qui désolde la facture
    SAV_FLG2=FLG2
    # Issue 101828 - 2014-08-14 by MUARN : Avoir en surfacturation mais commande toujours facturée
    #If [F:PIH]INVTYP=1 & [F:PID]PRTFLG=1 FLG2=2 Elsif [F:PIH]INVTYP=2 & [F:PID]QTYUOM<>0 FLG2=1 : Endif
    If [F:PIH]INVTYP=1 & [F:PID]PRTFLG=1
      FLG2=2
    Elsif [F:PIH]INVTYP=2 & [F:PID]QTYUOM<>0 & [F:POQ]QTYPUU > [F:POQ]INVQTYPUU
      FLG2=1
    Endif
    If [F:POQ]LINCLEFLG<>FLG2
      If FLG2=2 [F:POH]CLELINNBR+=1 Else [F:POH]CLELINNBR-=1 : Endif
      [F:POQ]LINCLEFLG=FLG2 : WPE_POHCLEFLG=1
      # Issue 97508 - 2014-03-05 by MUARN : si avoir qui désolde la commande CMMFLG doit repasser à 1
      If FLG2=1 & [F:PIH]PIHTYP=3
        [F:POQ]CMMFLG=1
      Endif
      #----- Si DL de commande ouverte, mettre à jour l'état de la ligne -----#
      If [F:POQ]POHTYP=2
        If [F:POQ]LINCLEFLG=2
          [F:POQ]LINSTA=3
        Elsif [F:POQ]EXTRCPDAT<date$
          [F:POQ]LINSTA=2
        Else
          [F:POQ]LINSTA=1
        Endif
      Endif
      #-----
    Endif
#   #----- Gestion du reliquat si commande non réceptionnable soldée -----#
    If [F:POQ]LINCLEFLG=2
      RELIQUAT=[F:POQ]QTYPUU-[F:POQ]INVQTYPUU
      If RELIQUAT<0 Raz RELIQUAT : Endif
      WQTYBUDLIN+=RELIQUAT
      WPRIREN=[F:PID]PRIREN
      If WPRIREN=0 WPRIREN=-99 Elsif WPRIREN>0 WPRIREN=-WPRIREN : Endif
      Update [PID] Where NUM=[M:PIH0]NUM & PIDLIN=[M:PIH3]PIDLIN(nolign-1)
&                  With PRIREN=WPRIREN
      If fstat
        GOK=0 : Call FSTA("PID") From GLOCK
      Else
        [F:PID]PRIREN=WPRIREN
      Endif
      # Issue 104729 - 2014-12-12 by MUARN : recherche d'autres lignes de cette commande sur la facture
      # il faut aussi passer PRIREN en négatif sur toutes les lignes de la facture portant sur la même POQ
      Update [PID] Where NUM=[M:PIH0]NUM & PRIREN>0 & POHNUM=NUMERO & POPLIN=LIGNE & POQSEQ=SEQUENCE
&                  With PRIREN=-PRIREN
    Endif
  Endif
  # Issue 94968/95376 - 2013-12-04 by MUARN : avoir qui passe la commande de facturée à non-facturée
  # ou de soldée à non soldée
  # Issue 98572 - 2014-03-25 by MUARN : amélioration des cas pour les avoirs
  If [F:PIH]INVTYP=2 & ( ((SAV_FLG2=2 & FLG2=1) & [F:ITM]RCPFLG=1)
&                         | ((SAV_FLG=2 & FLG=1) & [F:ITM]RCPFLG=2 & [F:POQ]LINCLEFLG=2) )
     WQTYBUDLIN=[F:PID]QTYPUU+[F:POQ]QTYPUU-SAV_INVQTYPUU
  Endif
  # si la commande est soldée manuellement ne pas réengager
  If [F:PIH]INVTYP=2 & [F:ITM]RCPFLG=2 & [F:POQ]LINCLEFLG=2 & [F:POQ]QTYPUU>[F:POQ]RCPQTYPUU
    Raz WQTYBUDLIN
  Endif
  # Issue X3-84001 - 2018-05-25 by MUARN : avoir en montant car montant facture trop important
  If [F:PIH]INVTYP=2 & [F:PID]NETPRI < [F:PID]ORINETPRI & [F:PID]QTYPUU = [F:PID]ORIQTYPUU
    Raz WQTYBUDLIN
  Endif

# #----- Gestion du reliquat si commande soldée par réception -----#
  If [F:POQ]RCPCLEFLG=2 & [F:PID]PRTFLG=1
    If [F:PID]TYPORI=2
      Filter [PTDB] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POQSEQ=[F:POQ]POQSEQ & LININVFLG<>2
      Look [PTDB] PTD2 First : If fstat  [F:POQ]LININVFLG=2 : Endif
      Filter [PTDB]
    Endif
    If [F:POQ]LININVFLG=2
      RELIQUAT=[F:POQ]QTYPUU-[F:POQ]INVQTYPUU
      If RELIQUAT<0 Raz RELIQUAT : Endif
      [F:POQ]RCPCLEFLG=1
      WQTYBUDLIN+=RELIQUAT
      WPRIREN=[F:PID]PRIREN
      If WPRIREN=0 WPRIREN=-99 Elsif WPRIREN>0 WPRIREN=-WPRIREN : Endif
      Update [PID] Where NUM=[M:PIH0]NUM & PIDLIN=[M:PIH3]PIDLIN(nolign-1)
&                  With PRIREN=WPRIREN
      If fstat
        GOK=0 : Call FSTA("PID") From GLOCK
      Else
        [F:PID]PRIREN=WPRIREN
      Endif
      # Issue 74946 - 2011-07-18 by VPO : pb désengagement si +sieurs lignes sur même POQ et receptions différentes
      # On passe RCPCLEFLG à 1
      # il faut aussi passer PRIREN en négatif sur toutes les lignes de la facture portant sur la même POQ
      Update [PID] Where NUM=[M:PIH0]NUM & PRIREN>0 & POHNUM=NUMERO & POPLIN=LIGNE & POQSEQ=SEQUENCE
&                  With PRIREN=-PRIREN
      # Issue 84310 - 2012-09-11 by MUARN : pb désengagement, plusieurs factures sur même ligne de commande non validées
      # si facturation complète, la dernière positionne RCPCLEFLG = 1,
      # il faut aussi positionner PRIREN en négatif sur toutes les factures de la même ligne
      # de commande non validées pour effectuer le désengagement
      Local File PINVOICE  [PIH1]
      Local File PINVOICED [PID1]
      Link [PID1] With [PIH1]  PIH0=[F:PID1]NUM As [PIX1]
      For [PIX1] Where [F:PIH1]STA<3 & [F:PID1]PRIREN>0 & [F:PID1]POHNUM=NUMERO & [F:PID1]POPLIN=LIGNE & [F:PID1]POQSEQ=SEQUENCE
        Readlock [PID1] PID0 Curr
        If fstat =1 GOK=-1 : GLOCK="$PINVOICED"-[PID1]NUM-[PID1]PIDLIN : Break
        Elsif fstat GOK=0  : Call RSTA("PID1",[PID1]NUM-[PID1]PIDLIN) From GLOCK : Break : Endif
        [F:PID1]PRIREN=-[F:PID1]PRIREN
        Rewrite [PID1] : If fstat GOK=0 : Call FSTA("PID1") From GLOCK : Break : Endif
      Next

    Endif
  Endif
  # Issue 87781 - 2013-02-11 by MUARN : avoir non réengagé dans le flux commande/facture/réception/avoir
  If [F:PIH]PIHTYP=3 & [F:POQ]RCPCLEFLG=2 & [F:PID]PRIREN>0
    WPRIREN=[F:PID]PRIREN
    If WPRIREN>0 WPRIREN=-WPRIREN : Endif
    Update [PID] Where NUM=[M:PIH0]NUM & PIDLIN=[M:PIH3]PIDLIN(nolign-1)
&                  With PRIREN=WPRIREN
    If fstat
      GOK=0 : Call FSTA("PID") From GLOCK
    Else
      [F:PID]PRIREN=WPRIREN
    Endif
  Endif

Endif
WLINCLEFLG=[F:POQ]LINCLEFLG
WRCPCLEFLG=[F:POQ]RCPCLEFLG
#----------------------------------------------------------------------#
# Point d'entrée MAJFAC pour modif zones std et alim zones spécifiques #
# -------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                          #
#                                                                      #
# FICHIER : Nom de la table qui va être écrite                         #
# ABRFIC  : Abréviation de la table qui va être écrite                 #
# Les classes [F:PIH], [F:PIV] et [F:PID] sont disponibles             #
# La  classe  [F:POQ] est modifiable avant le Rewrite                  #
#----------------------------------------------------------------------#
[L]FICHIER="PORDERQ"
[L]ABRFIC ="POQ"
GPOINT="MAJFAC" : Gosub ENTREE From EXEFNC
If [F:POQ]LINCLEFLG=1  [F:POQ]RCPCLEFLG=1 : Endif
#----- Appel du point d'entrée POHCLE solde/désolde ligne de commande -----#
If WPE_POHCLEFLG & [F:POH]POHTYP<>2
  WTRAIT=4
  If WLINCLEFLG=2  WCLEFLG=1  Else  WCLEFLG=2 : Endif
  Gosub POINT_POHCLE From TRTACHCDE1
Endif
#----- Réécriture ligne commande -----#
Rewrite [POQ]   : If fstat GOK=0 : Call FSTA("POQ") From GLOCK : Goto DEBLOC_CDE : Endif
#----- Réécriture ligne contrat commande ouverte -----#
If [F:POH]POHTYP=2
  #----------------------------------------------------------------------#
  # Point d'entrée MAJFAC pour modif zones std et alim zones spécifiques #
  # -------------------------------------------------------------------- #
  # Variables utilisables par le point d'entrée                          #
  #                                                                      #
  # FICHIER : Nom de la table qui va être écrite                         #
  # ABRFIC  : Abréviation de la table qui va être écrite                 #
  # Les classes [F:PIH], [F:PIV] et [F:PID] sont disponibles             #
  # La  classe  [F:POC] est modifiable avant le Rewrite                  #
  #----------------------------------------------------------------------#
  [L]FICHIER="PORDERC"
  [L]ABRFIC ="POC"
  GPOINT="MAJFAC" : Gosub ENTREE From EXEFNC
  Rewrite [POC] : If fstat GOK=0 : Call FSTA("POC") From GLOCK : Goto DEBLOC_CDE : Endif
Endif
#----- Remise à jour nbre lignes facturées si modif par point d'entrée -----#
If [F:POQ]LININVFLG<>FLG
  If [F:POQ]LININVFLG=2
    [F:POH]INVLINNBR+=1
  Else
    [F:POH]INVLINNBR-=1
  Endif
Endif
#----- Remise à jour nbre lignes soldées si modif par point d'entrée -----#
If ([F:ITM]RCPFLG=1 | [F:POQ]ORI=2) & [F:POQ]LINCLEFLG<>FLG2
  If [F:POQ]LINCLEFLG=2
    [F:POH]CLELINNBR+=1
  Else
    [F:POH]CLELINNBR-=1
  Endif
Endif
#----- Remise à jour qté désengagée et reliquat si modif par point d'entrée -----#
If SIGN=1 & [F:POQ]POHTYP<>2 & [F:POQ]LINCLEFLG<>WLINCLEFLG
  If ([F:ITM]RCPFLG=1 | [F:POQ]ORI=2)
    If WLINCLEFLG=2
      WQTYBUDLIN-=RELIQUAT
    Else
      RELIQUAT=[F:POQ]QTYPUU-[F:POQ]INVQTYPUU
      If RELIQUAT<0 Raz RELIQUAT : Endif
      WQTYBUDLIN+=RELIQUAT
    Endif
  Elsif WRCPCLEFLG=2
    WQTYBUDLIN-=RELIQUAT
    If WPRIREN=-99 WPRIREN=0 Elsif WPRIREN<0 WPRIREN=-WPRIREN : Endif
    Update [PID] Where NUM=[M:PIH0]NUM & PIDLIN=[M:PIH3]PIDLIN(nolign-1)
&                With PRIREN=WPRIREN
    If fstat
      GOK=0 : Call FSTA("PID") From GLOCK
    Else
      [F:PID]PRIREN=WPRIREN
    Endif
  Endif
Endif
#----- Positionnement indicateurs solde, facture -----#
If [F:POH]LINNBR<=[F:POH]CLELINNBR & [F:POH]POHTYP<>2
  [F:POH]CLEFLG=2
Else
  [F:POH]CLEFLG=1
Endif
If [F:POH]LINNBR<=[F:POH]INVLINNBR & [F:POH]POHTYP<>2
  [F:POH]INVFLG=3
Elsif [F:POH]INVNBR<>0
  [F:POH]INVFLG=2
Else
  [F:POH]INVFLG=1
Endif
#----------------------------------------------------------------------#
# Point d'entrée MAJFAC pour modif zones std et alim zones spécifiques #
# -------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                          #
#                                                                      #
# FICHIER : Nom de la table qui va être écrite                         #
# ABRFIC  : Abréviation de la table qui va être écrite                 #
# Les classes [F:PIH], [F:PIV] et [F:PID] sont disponibles             #
# La  classe  [F:POH] est modifiable avant le Rewrite                  #
#----------------------------------------------------------------------#
[L]FICHIER="PORDER"
[L]ABRFIC ="POH"
GPOINT="MAJFAC" : Gosub ENTREE From EXEFNC
#----- Réécriture entête commande -----#
Rewrite [POH] : If fstat GOK=0 : Call FSTA("POH") From GLOCK : Goto DEBLOC_CDE : Endif
#----- Mise à jour quantité à désengager sur ligne facture -----#
If WQTYBUDLIN<>[F:PID]QTYBUDLIN & SIGN=1
   Update [PID] Where NUM=[M:PIH0]NUM & PIDLIN=[M:PIH3]PIDLIN(nolign-1)
&               With QTYBUDLIN=WQTYBUDLIN
   If fstat GOK=0 : Call FSTA("PID") From GLOCK : Endif
   [F:PID]QTYBUDLIN=WQTYBUDLIN : # La classe [F] n'est pas mise à jour par l'Update
   [M:PIH3]QTYBUDLIN(nolign-1)=WQTYBUDLIN
Endif
#----- Màj des mts en commande (Pas de màj si facture validée en import) -----#
If (!GIMPORT | [M:PIH1]STA<>3) &
&  [F:PID]QTYBUDLIN<>0 & [F:POQ]QTYPUU<>0 & (WANC_LINCLEFLG<>2 | [F:POQ]LINCLEFLG<>2)
  WQTY=min(max([F:POQ]INVQTYPUU-[F:POQ]RCPQTYPUU,0),[F:PID]QTYBUDLIN)
  WORDNOT=-([F:POQ]LINAMT*WQTY/[F:POQ]QTYPUU)*SIGN*(3-(2*[F:PIH]INVTYP))
  WORDATI=-([F:POQ]LINATI*WQTY/[F:POQ]QTYPUU)*SIGN*(3-(2*[F:PIH]INVTYP))
  Call MAJENC_BPS([F:POH]BPSNUM,3,[F:POH]POHFCY,[F:POH]CUR,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                 [F:POH]POHNUM,WORDNOT,WORDATI,[F:POH]TTVORD) From TRTBPMVT
Endif
#----- Désengagement si suppression ligne alors que la ligne commande est soldée -----#
If SIGN=-1 & [F:POQ]LINCLEFLG=2 & [F:POQ]RCPCLEFLG=1 & GREP="A" & [F:PID]QTYBUDLIN<>0
  # Issue 100651 - 2014-06-06 by MUARN : Déplacement de SUBPIHA à SUBPIHD
  Call MAJ_DESENGAGE From SUBPIHD
  # Issue 100651 - 2014-06-06 by MUARN : Déplacement de SUBPIHA à SUBPIHD
  If GOK<1 Goto DEBLOC_CDE Else GFCY=[F:PIH]FCY : Gosub CHARG_PARAM From SUBPIHA : Endif
Endif
#-----
$DEBLOC_CDE
Unlock=SYMBOL2
End

########################################################################
# MAJ_DESENGAGE : S/P de mise à jour des désengagements si suppression #
#                 ligne facture alors que la ligne commande est soldée #
# -------------------------------------------------------------------- #
# Subprog MAJ_DESENGAGE                                                #
########################################################################
Subprog MAJ_DESENGAGE
#----- Test présence du module compta -----#
If GMODU(2)<>2 | GOPTCANA<1  End : Endif
#----- Variables locales -----#
Local Char     WTRANSAC(max(GLONGAU,10))
Local Char     WMESSAGE(80)
Local Integer  STAT,       WSIGN
Local Char     WPOHNUM(GLONPOH)
Local Integer  WPOPLIN
Local Integer  WPOQSEQ
Local Integer  WNBPCE
#----- Ouverture des fichiers si nécessaire -----#
If !clalev([F:POH])  Local File PORDER    [POH] : Endif
If !clalev([F:POP])  Local File PORDERP   [POP] : Endif
If !clalev([F:POQ])  Local File PORDERQ   [POQ] : Endif
If !clalev([F:TB0])  Local File PORDER    [TB0] : Endif
If !clalev([F:TB1])  Local File PORDERQ   [TB1] : Endif
If !clalev([F:TB2])  Local File CPTANALIN [TB2] : Endif
#-----
Gosub MAJ_BUDGET From TRTACHFAC1
End

########################################################################
# MAJ_RCP : S/P de mise à jour des fichiers réception entête et ligne  #
#                     (PRECEIPT et PRECEIPTD)                          #
# -------------------------------------------------------------------- #
# Subprog MAJ_RCP(SIGN,NUMERO,LIGNE,QUANTITE,WQTEUOM,WQTEAUTR,WNBRCP)  #
#   SIGN     : Sens de la mise à jour (+1=Cumul, -1=Soustraction)      #
#   NUMERO   : Numéro de la réception à mettre à jour                  #
#   LIGNE    : Ligne  de la réception à mettre à jour                  #
#   QUANTITE : Quantité facturée en UA                                 #
#   WQTEUOM  : Quantité facturée en UOM                                #
#   WQTEAUTR : Quantité restante facturée par d'autres factures        #
#   WNBRCP   : Delta du nombre de réceptions entierement facturées     #
########################################################################
Subprog MAJ_RCP(SIGN,NUMERO,LIGNE,QUANTITE,WQTEUOM,WQTEAUTR,WNBRCP)
Value    Integer  SIGN
Value    Char     NUMERO
Value    Integer  LIGNE
Variable Decimal  QUANTITE
Variable Decimal  WQTEUOM
Variable Decimal  WQTEAUTR
Variable Integer  WNBRCP
#----- Variables locales -----#
Local    Libelle  WANC_LININVFLG
Local    Shortint FLG
Local    Char     SYMBOL2(30), CLEFIC(33)
Local    Decimal  QTE, QTEUOM, RTNQTE, RTNQTEUOM
#----- Variables pour le point d'entrée MAJFAC -----#
Local    Char     FICHIER(GLONATB), ABRFIC(3)
#----- Si entête réception bloquée logiquement --> Abandon -----#
CLEFIC=NUMERO : SYMBOL2="PTH"+NUMERO : Lock=SYMBOL2
If fstat GMESSAGE="$PRECEIPT"-CLEFIC-mess(10,100,1) : GERR=1
         GOK=0 : End : Endif
#----- Lecture entête et ligne réception avec blocage physique -----#
Readlock [PTH] PTH0=NUMERO
#----- Pas de màj et pas d'erreur en import si réception n'existe pas -----#
If GIMPORT & fstat Raz [F:PTH] : Goto DEBLOC_RCP : Endif
If fstat=1  GOK=-1 : GLOCK="$PRECEIPT"-CLEFIC           : Goto DEBLOC_RCP
Elsif fstat GOK=0  : Call RSTA("PTH",CLEFIC) From GLOCK : Goto DEBLOC_RCP
Endif
CLEFIC+=" "+num$(LIGNE)
Readlock [PTD] PTD0=NUMERO;LIGNE
#----- Pas de màj et pas d'erreur en import si ligne réception n'existe pas -----#
If GIMPORT & fstat Raz [F:PTD] : Goto DEBLOC_RCP : Endif
If fstat=1  GOK=-1 : GLOCK="$PRECEIPTD"-CLEFIC          : Goto DEBLOC_RCP
Elsif fstat GOK=0  : Call RSTA("PTD",CLEFIC) From GLOCK : Goto DEBLOC_RCP
Endif
WANC_LININVFLG=[F:PTD]LININVFLG
#----- Calcul qté restant à facturer -----#
If [F:PIH]PIHTYP=3 : # Avoir
  If SIGN=1
    QTE   =min([F:PTD]INVQTYPUU,[F:PTD]QTYPUU)
    QTEUOM=min([F:PTD]INVQTYSTU,[F:PTD]QTYSTU)
  Else
    QTE   =[F:PTD]QTYPUU-[F:PTD]INVQTYPUU
    QTEUOM=[F:PTD]QTYSTU-[F:PTD]INVQTYSTU
  Endif
Else
  If SIGN=1
    If [F:PTD]LININVFLG<>2
      QTE   =[F:PTD]QTYPUU-[F:PTD]INVQTYPUU
      QTEUOM=[F:PTD]QTYSTU-[F:PTD]INVQTYSTU
    Else
      QTE   =0
      QTEUOM=0
    Endif
  Else
    QTE   =[F:PTD]INVQTYPUU
    QTEUOM=[F:PTD]INVQTYSTU
    If WQTEAUTR>0 & QTE>0
      If WQTEAUTR>=QTE
        WQTEAUTR-=QTE
        Raz QTE, QTEUOM
      Else
        QTEUOM=QTEUOM/QTE*(QTE-WQTEAUTR) : Call QTEARR(QTEUOM,[F:PTD]STU) From TRTDIV
        QTE-=WQTEAUTR : Raz WQTEAUTR
      Endif
    Endif
    If QTE=0 & [F:PID]TYPORI<>2  End : Endif : # C'est fini, on passe à la réception suivante !
  Endif
Endif
#----- Recherche retours effectués sur cette réception avec réintégration en cde -----#
If [F:PID]TYPORI=1 & SIGN=1 &
&  [F:PTD]RTNQTYPUU<>0 & QUANTITE>[F:PTD]QTYPUU-[F:PTD]RTNQTYPUU
  RTNQTE=[F:PTD]RTNQTYPUU
  RTNQTEUOM=[F:PTD]RTNQTYSTU
  For [PND] PND1 Where PTHNUM=[F:PTD]PTHNUM & PTDLIN=[F:PTD]PTDLIN & ORDFLG=2
    If [F:PND]QTYPUU>=RTNQTE
      Raz RTNQTE, RTNQTEUOM : Break
    Else
      RTNQTE-=[F:PND]QTYPUU : RTNQTEUOM-=[F:PTD]QTYSTU
    Endif
  Next
  QTE-=([F:PTD]RTNQTYPUU-RTNQTE)
  QTEUOM-=([F:PTD]RTNQTYSTU-RTNQTEUOM)
Endif
#-----
If QTE>QUANTITE
  QTE=QUANTITE : Raz QUANTITE : QTEUOM=WQTEUOM : Raz WQTEUOM
Else
  QUANTITE-=QTE : WQTEUOM-=QTEUOM
Endif
If SIGN=-1
  # Issue X3-70158 - 2018-01-09 by MUARN : TRTLIG à la place de GREP
  # Issue 111124 - 2015-09-21 by MUARN : ajout WOLDQTYPUU <> 0
  # Issue 96640 - 2014-03-04 by SR :si pas de modification de quantité
  If GPIH_TRTLIG="M" & [M:PIH3]NUMORI(nolign-1)=[F:PTD]PTHNUM &[M:PIH3]LINORI(nolign-1)=[F:PTD]PTDLIN &
&    [M:PIH3]QTYPUU(nolign-1) = [M:PIH3]WOLDQTYPUU(nolign-1) & [M:PIH3]WOLDQTYPUU(nolign-1) <> 0
    Raz QUANTITE
    Raz WQTEUOM
  Else
    #----- Mise à jour qtés facturées -----#
    [F:PTD]INVQTYPUU-=QTE*(3-(2*[F:PIH]INVTYP))
    If [F:PID]UOM=[F:PTD]STU
      GBIDD1=QTEUOM
    Else
      Call PCAL_QTY(QTE,[F:PID]PUU,GBIDD1,[F:PTD]STU,
&                 [F:PID]ITMREF,[F:PTH]BPSNUM,1,GBIDD2) From TRTACHQTE1
    Endif
    [F:PTD]INVQTYSTU-=GBIDD1*(3-(2*[F:PIH]INVTYP))
    # Issue X3-88031 - 2018-04-27 by SR : Ne pas passer en négatif
    If [F:PTD]INVQTYPUU < 0 : Raz [F:PTD]INVQTYPUU : Endif
    If [F:PTD]INVQTYSTU < 0 : Raz [F:PTD]INVQTYSTU : Endif
    If ([F:PTD]INVQTYPUU=0 | [F:PTD]INVQTYPUU=QUANTITE) & (QTE<>0 | find([F:PIH]PIHTYP,1,3)<>0)
      [F:PTH]INVLINCTR-=1
    # Issue X3-88031 - 2018-04-27 by SR : Tester <= 0 à cause des avoir en qté > qté facture
    #Elsif [F:PTD]INVQTYPUU+QTE*(3-(2*[F:PIH]INVTYP))=0 & (QTE<>0 | find([F:PIH]PIHTYP,1,3)<>0)
    Elsif [F:PTD]INVQTYPUU+QTE*(3-(2*[F:PIH]INVTYP))<=0 & (QTE<>0 | find([F:PIH]PIHTYP,1,3)<>0)
      [F:PTH]INVLINCTR+=1
    Endif
    #----- Positionnement indicateur ligne facturée -----#
    FLG=[F:PTD]LININVFLG
    If [F:PIH]INVTYP=1    : # Facture
      If [PTD]QTYPUU>[F:PTD]INVQTYPUU | QUANTITE>=[F:PTD]INVQTYPUU  FLG=1 : Endif
    Elsif [F:PIH]PIHTYP=3 : # Avoir
      # Issue 87790 - 2013-02-08 by MUARN : POUR AVOIR EN QUANTITÉ TESTÉ QTÉ ET NON PRIX
      #If [F:PID]NETPRI=[F:PID]ORINETPRI
      # Issue 87781 - 2013-02-18 by MUARN : avoir total
      #If [F:PID]QTYPUU<>[F:PID]ORIQTYPUU
      If [F:PID]QTYPUU<>[F:PID]ORIQTYPUU | ([F:PID]QTYPUU=[F:PID]ORIQTYPUU & [F:PID]NETPRI=[F:PID]ORINETPRI)
        If [F:PTD]QTYPUU<=[F:PTD]INVQTYPUU | [F:PTD]QTYPUU=0 FLG=2 : Endif
        If [F:PIDB]PRTFLG=1 & [F:PIDB]TYPORI<3               FLG=2 : Endif
      Endif
    Endif
    If [F:PTD]LININVFLG<>FLG
       If FLG=2 [F:PTH]INVLINNBR+=1 : WNBRCP+=1
           Else [F:PTH]INVLINNBR-=1 : WNBRCP-=1 : Endif
       [F:PTD]LININVFLG=FLG
    Endif
  Endif
  # End issue 96640
Else
  # Issue X3-70158 - 2018-01-09 by MUARN : TRTLIG à la place de GREP
  # Issue 111124 - 2015-09-21 by MUARN : ajout WOLDQTYPUU <> 0
  # Issue 96640 - 2014-03-04 by SR :si pas de modification de quantité
  If GPIH_TRTLIG="M" & [M:PIH3]NUMORI(nolign-1)=[F:PTD]PTHNUM &[M:PIH3]LINORI(nolign-1)=[F:PTD]PTDLIN &
&    [M:PIH3]QTYPUU(nolign-1) = [M:PIH3]WOLDQTYPUU(nolign-1) & [M:PIH3]WOLDQTYPUU(nolign-1) <> 0
    Raz QUANTITE
    Raz WQTEUOM
  Else
    #--- Mise à jour qtés facturées --#
    # Issue 121633 - 2017-02-17 by MUARN : ne faire quand facture pas avoir
    #If [F:PTD]INVQTYPUU=0 & (QTE<>0 | find([F:PIH]PIHTYP,1,3)<>0)
    If [F:PTD]INVQTYPUU=0 & (QTE<>0 | [F:PIH]PIHTYP=1)
      [F:PTH]INVLINCTR+=1
    # Issue 121633 - 2017-02-17 by MUARN : pour les avoirs il faut une quantité facturée sur la réception
    #Elsif [F:PTD]INVQTYPUU+QTE*(3-(2*[F:PIH]INVTYP))=0 & (QTE<>0 | find([F:PIH]PIHTYP,1,3)<>0)
    # Issue X3-88031 - 2018-04-27 by SR : Tester <=0 à cause des avoirs avec qté > qté facture
    #Elsif [F:PTD]INVQTYPUU+QTE*(3-(2*[F:PIH]INVTYP))=0 & (QTE<>0 | ([F:PIH]PIHTYP=3 & [F:PTD]INVQTYPUU<>0) )
    Elsif [F:PTD]INVQTYPUU+QTE*(3-(2*[F:PIH]INVTYP))<=0 & (QTE<>0 | ([F:PIH]PIHTYP=3 & [F:PTD]INVQTYPUU<>0) )
      [F:PTH]INVLINCTR-=1
    Endif
    [F:PTD]INVQTYPUU+=QTE*(3-(2*[F:PIH]INVTYP))
    # Issue X3-25003 - 2018-04-05 by SR : Ne pas passer en négatif (avoir en qté supérieure à qté facture)
    If [F:PTD]INVQTYPUU <0 : Raz [F:PTD]INVQTYPUU : Endif
    If [F:PID]UOM=[F:PTD]STU
      GBIDD1=QTEUOM
    Else
      Call PCAL_QTY(QTE,[F:PID]PUU,GBIDD1,[F:PTD]STU,
&                 [F:PID]ITMREF,[F:PTH]BPSNUM,1,GBIDD2) From TRTACHQTE1
    Endif
    [F:PTD]INVQTYSTU+=GBIDD1*(3-(2*[F:PIH]INVTYP))
    # Issue X3-88031 - 2018-04-27 by SR : Ne pas passer en négatif
    If [F:PTD]INVQTYSTU < 0 : Raz [F:PTD]INVQTYSTU : Endif
    #----- Positionnement indicateur ligne facturée -----#
    FLG=[F:PTD]LININVFLG
    If [F:PIH]INVTYP=1    : # Facture
      If [F:PTD]QTYPUU<=[F:PTD]INVQTYPUU | [F:PTD]QTYPUU=0     FLG=2 : Endif
      If [F:PID]PRTFLG=1 & [F:PID]TYPORI<3                     FLG=2 : Endif
    Elsif [F:PIH]PIHTYP=3 : # Avoir
      # Issue 87790 - 2013-02-08 by MUARN : POUR AVOIR EN QUANTITÉ TESTÉ QTÉ ET NON PRIX
      #If [F:PID]NETPRI=[F:PID]ORINETPRI
      # Issue 87781 - 2013-02-18 by MUARN : avoir total
      #If [F:PID]QTYPUU<>[F:PID]ORIQTYPUU
      If [F:PID]QTYPUU<>[F:PID]ORIQTYPUU | ([F:PID]QTYPUU=[F:PID]ORIQTYPUU & [F:PID]NETPRI=[F:PID]ORINETPRI)
        If [F:PTD]QTYPUU>[F:PTD]INVQTYPUU | QUANTITE>=[F:PTD]INVQTYPUU  FLG=1 : Endif
      Endif
    Endif
    If [F:PTD]LININVFLG<>FLG
       If FLG=2 [F:PTH]INVLINNBR+=1 : WNBRCP+=1
           Else [F:PTH]INVLINNBR-=1 : WNBRCP-=1 : Endif
       [F:PTD]LININVFLG=FLG
    Endif
  Endif
  # End issue 96640
Endif
#----------------------------------------------------------------------#
# Point d'entrée MAJFAC pour modif zones std et alim zones spécifiques #
# -------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                          #
#                                                                      #
# FICHIER : Nom de la table qui va être écrite                         #
# ABRFIC  : Abréviation de la table qui va être écrite                 #
# Les classes [F:PIH], [F:PIV] et [F:PID] sont disponibles             #
# La  classe  [F:PTD] est modifiable avant le Rewrite                  #
#----------------------------------------------------------------------#
# Issue 114868 - 2016-02-29 by SR : Sauvegarder ININVFLG
FLG = [F:PTD]LININVFLG
# End issue 114868
[L]FICHIER="PRECEIPTD"
[L]ABRFIC ="PTD"
GPOINT="MAJFAC" : Gosub ENTREE From EXEFNC
#----- Réécriture ligne réception -----#
Rewrite [PTD] : If fstat GOK=0 : Call FSTA("PTD") From GLOCK : Goto DEBLOC_RCP : Endif
#----- Remise à jour nbre lignes facturées si modif par point d'entrée -----#
If [F:PTD]LININVFLG<>FLG
  If [F:PTD]LININVFLG=2
    [F:PTH]INVLINNBR+=1 : WNBRCP+=1
  Else
    [F:PTH]INVLINNBR-=1 : WNBRCP-=1
  Endif
Endif
#----- Positionnement indicateur facture -----#
If [F:PTH]LINNBR<=[F:PTH]INVLINNBR
  [F:PTH]INVFLG=3
Elsif [F:PTH]INVLINNBR<>0 | [F:PTH]INVLINCTR<>0
  [F:PTH]INVFLG=2
Else
  [F:PTH]INVFLG=1
Endif
#----------------------------------------------------------------------#
# Point d'entrée MAJFAC pour modif zones std et alim zones spécifiques #
# -------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                          #
#                                                                      #
# FICHIER : Nom de la table qui va être écrite                         #
# ABRFIC  : Abréviation de la table qui va être écrite                 #
# Les classes [F:PIH], [F:PIV] et [F:PID] sont disponibles             #
# La  classe  [F:PTH] est modifiable avant le Rewrite                  #
#----------------------------------------------------------------------#
[L]FICHIER="PRECEIPT"
[L]ABRFIC ="PTH"
GPOINT="MAJFAC" : Gosub ENTREE From EXEFNC
#----- Réécriture entête réception -----#
Rewrite [PTH] : If fstat GOK=0 : Call FSTA("PTH") From GLOCK : Goto DEBLOC_RCP : Endif
#----- Màj des mts réceptionnés non facturés dans mvts fournisseurs -----#
If [F:PTD]QTYPUU<>0
  Local Integer WSTA
  Local Decimal WMT1, WMT2, WRCPNOT, WRCPATI, WQTEFAC
  If SIGN*(3-(2*[F:PIH]INVTYP))=+1
    If [F:PTD]QTYPUU<[F:PTD]INVQTYPUU
      WQTEFAC=max(QTE-([F:PTD]INVQTYPUU-[F:PTD]QTYPUU),0)
    Elsif [F:PTD]LININVFLG=2 & [F:PTD]QTYPUU>[F:PTD]INVQTYPUU
      WQTEFAC=QTE+([F:PTD]QTYPUU-[F:PTD]INVQTYPUU)
    Else
      WQTEFAC=QTE
    Endif
  Else
    If [F:PTD]QTYPUU>[F:PTD]INVQTYPUU
      If WANC_LININVFLG=2
        WQTEFAC=max(QTE,[F:PTD]QTYPUU-[F:PTD]INVQTYPUU)
      Else
        WQTEFAC=min(QTE,[F:PTD]QTYPUU-[F:PTD]INVQTYPUU)
      Endif
    Else
      WQTEFAC=0
    Endif
  Endif
  WMT1=-[F:PTD]LINAMT   *WQTEFAC/[F:PTD]QTYPUU*SIGN*(3-(2*[F:PIH]INVTYP))
  WMT2=-[F:PTD]LINATIAMT*WQTEFAC/[F:PTD]QTYPUU*SIGN*(3-(2*[F:PIH]INVTYP))
  #----- Lecture commande pour récup type de cours et date -----#
  If [F:PTD]POHNUM<>""
    If [F:POH]POHNUM<>[F:PTD]POHNUM
      Read [POH] POH0=[F:PTD]POHNUM
      If fstat
        Raz [F:POH] : [F:POH]CHGTYP=[F:PTH]CHGTYP : [F:POH]ORDDAT=[F:PTH]RCPDAT
      Endif
    Endif
  Else
    Raz [F:POH] : [F:POH]CHGTYP=[F:PTH]CHGTYP : [F:POH]ORDDAT=[F:PTH]RCPDAT
  Endif
  #----- Lecture devise entête réception pour arrondi -----#
  If [F:TCU]CUR<>[F:PTH]CUR
    Read [TCU] TCU0=[F:PTH]CUR : If fstat [F:TCU]CURRND=0.01 : Endif
  Endif
  #----- Conversion si nécessaire du montant en devise entête réception -----#
  If [F:PTH]CUR<>[F:PTD]NETCUR
    Call CONVERT([F:PTD]NETCUR,[F:PTH]CUR,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                WMT1,WRCPNOT,WSTA) From TRTDEV
    #Issue 79995 - 2012-02-13 by VPO : erreur variable STAT
    #If STAT  WRCPNOT=arr(WMT1,[F:TCU]CURRND) : Endif
    If WSTA  WRCPNOT=arr(WMT1,[F:TCU]CURRND) : Endif
    Call CONVERT([F:PTD]NETCUR,[F:PTH]CUR,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                WMT2,WRCPATI,WSTA) From TRTDEV
    #Issue 79995 - 2012-02-13 by VPO : erreur variable STAT
    #If STAT  WRCPATI=arr(WMT2,[F:TCU]CURRND) : Endif
    If WSTA  WRCPATI=arr(WMT2,[F:TCU]CURRND) : Endif
  Else
    WRCPNOT=arr(WMT1,[F:TCU]CURRND)
    WRCPATI=arr(WMT2,[F:TCU]CURRND)
  Endif
  #----- Pas de màj si facture validée en import -----#
  If (!GIMPORT | [M:PIH1]STA<>3)
    Call MAJENC_BPS([F:PTH]BPSNUM,4,[F:PTH]PRHFCY,[F:PTH]CUR,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                   [F:PTH]PTHNUM,WRCPNOT,WRCPATI,[F:PTH]TOTAMTATI) From TRTBPMVT
  Endif
Endif
#-----
$DEBLOC_RCP
Unlock=SYMBOL2
End

$AB1_NBLIG
#-----------------------------------------------------------------------#
# Avant exécution du bouton Tunnel sur commandes, réceptions et retours #
#-----------------------------------------------------------------------#
Local Shortint NOL       : NOL=nolign-1
Local Char     WOBJET(GLONAOB)
Local Char     WCLE1 (GLONVCR) : WCLE1=[M:PIH3]NUMORI(NOL)
Local Char     WCLE2 (GLONVCR) : WCLE2=""
# Issue 110325 - 2016-01-15 by SR : FCC sur expé
Case [M:PIH3]TYPORI(NOL)
  When 1 : If [M:PIH3]SEQORI(NOL)=1
             WOBJET="POH"
           Else
             WOBJET="POD"
             WCLE1=num$([M:PIH3]LINORI(NOL)) : WCLE2=[M:PIH3]NUMORI(NOL)
           Endif
  When 2 : WOBJET="PTH"
  When 3 : WOBJET="PNH"
  When 6 : WOBJET="SHIP"
Endcase
Return

$AB11_NBLIG
#--------------------------------------------------#
# Avant exécution du bouton tunnel sur engagements #
#--------------------------------------------------#
Local Shortint NOL             : NOL=nolign-1
Local Char     WOBJET(GLONAOB) : WOBJET="CMM"
Local Char     WCLE1 (GLONVCR) : WCLE1=[M:PIH3]CMMNUM(NOL)
Local Char     WCLE2 (GLONVCR) : WCLE2=""
If [M:PIH3]NBLIG=0 | [M:PIH3]ITMREF(NOL)="" | [M:PIH3]CMMNUM(NOL)="" |
&  GMODU(2)<>2 | GPURCMM<>2
  WOBJET=""
Endif
Return

$AB1_NUMORI
#-----------------------------------------------------------------------#
# Avant exécution du bouton Tunnel sur commandes, réceptions et retours #
#-----------------------------------------------------------------------#
Local Char     WOBJET(GLONAOB)
# Issue 110325 - 2016-01-11 by SR : FCC sur expé
Case [M:PIH3]TYPORI(nolign-1)
  When 1 : WOBJET="POH"
  When 2 : WOBJET="PTH"
  When 3 : WOBJET="PNH"
  When 6 : WOBJET="SHIP"
Endcase
Return

$AB1_ITMDES
#--------------------------------------#
# Avant exécution du bouton "Articles" #
#--------------------------------------#
Local Shortint NOL : NOL=nolign-1
Return

$BB1_ITMDES
#--------------------------------------#
# Après exécution du bouton "Articles" #
#--------------------------------------#
If [M:PIH3]ITMREF(NOL)="" Return : Endif
#----- Relecture article si celui-ci a été changé par le tunnel -----#
If [F:ITM]ITMREF<>[M:PIH3]ITMREF(NOL)
  Read [ITM] ITM0=[M:PIH3]ITMREF(NOL)
  If fstat Raz [F:ITM] : Endif
Endif
Return
######################################################################################
######################################################################################
Subprog FLD4041DIS(AVAC, APIVTYP)
Value Char AVAC
Value Char APIVTYP

If !func AFNC.ACTIV("KPO") : End : Endif

If [M:PIH1]FLD40REN = "" : Raz [M:PIH1]FLD40REN : Endif
If [M:PIH1]FLD41REN = "" : Raz [M:PIH1]FLD41REN : Endif

Local Char HS(1)

[L]HS = func PORLEGLIB.SHWHID4041(GCURLEG,AVAC,2,APIVTYP,40)
If [L]HS = "-" : Raz [M:PIH1]FLD40REN : Endif
Chgfmt [M:PIH1]FLD40REN With [L]HS+"K:5X"

[L]HS = func PORLEGLIB.SHWHID4041(GCURLEG,AVAC,2,APIVTYP,41)
If [L]HS = "-" : Raz [M:PIH1]FLD41REN : Endif
Chgfmt [M:PIH1]FLD41REN With [L]HS+"K:5X"

If [M:PIH1]STA = 3
  Diszo [M:PIH1]FLD40REN
  Diszo [M:PIH1]FLD41REN
Endif

Affzo [M:PIH1]FLD40REN
Affzo [M:PIH1]FLD41REN

End

# Issue 110325 - 2016-01-11 by SR : FCC sur expé : Code déplacé de SUBPIH vers SUBPIHD + enrichi pour FCC sur expé
######################################################################################
$CTRL_FCSCOD
Case [M:PIH3]TYPORI(NOL)
  When 1 :
      If [F:POQ]POHNUM <>[M:PIH3]NUMORI(NOL) | [F:POQ]POPLIN <>[M:PIH3]LINORI(NOL) | [F:POQ]POQSEQ <>[M:PIH3]SEQORI(NOL)
        Read [F:POQ]POQ0 = [M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL);[M:PIH3]SEQORI(NOL)
        If fstat : Raz [F:POQ] : Endif
      Endif
      If  [F:POQ]STCNUM = ""
          GMESSAGE=mess(466,194,1) #Document d'origine non géré en structure de coût
          mkstat = 1 : Return
      Endif
      Filter [F:STCD] Where VCRTYP = 14 & VCRNUM = [M:PIH3]NUMORI(NOL) & VCRLIN = [M:PIH3]LINORI(NOL)
&                       & VCRSEQ = [M:PIH3]SEQORI(NOL) & FCSCOD = VALEUR
      # la charge est-elle presente
      Read [F:STCD]STCD0 First
      Filter [F:STCD]
      If fstat :
         GMESSAGE=mess(464,194,1) #Charge non prévue sur le document origine
         mkstat = 1 : Return
      Elsif [F:STCD]FCSAMT = 0
        Call OUINON(mess(465,194,1),WOK) From GESECRAN #Montant de charge nul  dans le document origine
        If WOK=1 : mkstat = 1 : Return : Endif
      Endif
      WMESS = func AFNC.MES2(mess(467,194,1),VALEUR,[M:PIH3]NUMORI(NOL)+"/"+num$([M:PIH3]LINORI(NOL))+"/"+num$([M:PIH3]SEQORI(NOL)))
  When 2 :
      If [F:PTD]PTHNUM <>[M:PIH3]NUMORI(NOL) | [F:PTD]PTDLIN <>[M:PIH3]LINORI(NOL)
         Read [F:PTD]PTD0 = [M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL)
         If fstat : Raz [F:PTD] : Endif
      Endif
      If [F:PTD]STCNUM = ""
         GMESSAGE=mess(466,194,1) #Document d'origine non géré en structure de coût
         mkstat = 1 : Return
      Endif
      Filter [F:STCD] Where VCRTYP = 6 & VCRNUM = [M:PIH3]NUMORI(NOL) & VCRLIN = [M:PIH3]LINORI(NOL) & FCSCOD = VALEUR
      # la charge est-elle presente
      Read [F:STCD]STCD0 First
      Filter [F:STCD]
      If fstat :
         GMESSAGE=mess(464,194,1) #Charge non prévue sur le document origine
         mkstat = 1 : Return
      Elsif [F:STCD]FCSAMT = 0
        Call OUINON(mess(465,194,1),WOK) From GESECRAN #Montant de charge nul  dans le document origine
        If WOK=1 : mkstat = 1 : Return : Endif
      Endif
      WMESS = func AFNC.MES2(mess(467,194,1),VALEUR,[M:PIH3]NUMORI(NOL)+"/"+num$([M:PIH3]LINORI(NOL)))
  When 6 :
      If [F:SHD]SHIPNUM <>[M:PIH3]NUMORI(NOL) | [F:SHD]SHIPLIN <>[M:PIH3]LINORI(NOL)
         Read [F:SHD]SHD0 = [M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL)
         If fstat : Raz [F:SHD] : Endif
      Endif
      If [F:SHD]STCNUM = ""
         GMESSAGE=mess(466,194,1) #Document d'origine non géré en structure de coût
         mkstat = 1 : Return
      Endif
      Filter [F:STCD] Where VCRTYP = 38 & VCRNUM = [M:PIH3]NUMORI(NOL) & VCRLIN = [M:PIH3]LINORI(NOL) & FCSCOD = VALEUR
      # la charge est-elle presente
      Read [F:STCD]STCD0 First
      Filter [F:STCD]
      If fstat :
         GMESSAGE=mess(464,194,1) #Charge non prévue sur le document origine
         mkstat = 1 : Return
      Elsif [F:STCD]FCSAMT = 0
        Call OUINON(mess(465,194,1),WOK) From GESECRAN #Montant de charge nul  dans le document origine
        If WOK=1 : mkstat = 1 : Return : Endif
      Endif
      WMESS = func AFNC.MES2(mess(467,194,1),VALEUR,[M:PIH3]NUMORI(NOL)+"/"+num$([M:PIH3]LINORI(NOL)))
  Endcase
# Y-a-t-il déjà un enregistrement pour même charge/même pièce d'origine ?
Filter [F:STCR] Where TYPORI = [M:PIH3]TYPORI(NOL) &  NUMORI = [M:PIH3]NUMORI(NOL) & LINORI = [M:PIH3]LINORI(NOL)
&                   & SEQORI = [M:PIH3]SEQORI(NOL)  & FCSCOD = VALEUR
Look [F:STCR]STCR0 First
Filter [F:STCR]
If !fstat
    Call OUINON(WMESS,WOK) From GESECRAN # La charge $1$ du document $2$  a déjà fait l’objet d’une facture complémentaire
    If WOK=1 : mkstat = 1 : Return : Endif
Endif

Return

######################################################################################
# Issue 117524 - 2016-08-11 by MUARN : législation australienne
Subprog AUSABNWRN(WBPR,WCPY)
Value Char WBPR
Value Char WCPY
Local Integer OK
If !func AFNC.ACTIV("KAU") : End : Endif
If fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY,WCPY,"AUSABNWRN")<>2 : End: Endif
Call LEC_BPR(WBPR) From CPTLEC
If [F:BPR]CRY <> "AU" : End : Endif
If ([F:BPR]CRN="") Then
  OK = 2
  Call AVERTIR(WBPR-mess(106,119,1), OK) From GESECRAN
  If OK=1  : mkstat=1 : Endif
Endif
End

