#<AdxTL>@(#)3.0.0.0 $Revision$
########################################################################################################
# UUTITRS05                                                  Module Tiers                              #
#             Suppression d'enregistrements obsolètes dans les tables TMPFUP0, TMPFUP1, TMPFUP2 et FUP #                     
########################################################################################################

Local Char APPLI(30) : APPLI = nomap
Call SAIDOS(APPLI,"") From SAIDOS
If APPLI <> ""
 If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
 Read [ADS]DOSSIER=[L]APPLI : If fstat Raz [F:ADS] : Endif

 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UTITRS05: stale records deletion") From LECFIC

 Call MAJ_UTITRS05(APPLI)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTITRS05(APPLI)
Value Char APPLI
Local Integer STAT, N


# test du code activité
If func AFNC.ACTIV("FUP")=0 : End : Endif

# test de présence des tables
If filinfo(filpath("FIL","FUP","fde",APPLI),0)<=0 : End : Endif


Call ECR_TRACE("UUTITRS05: Process Start on : "+APPLI,0) From GESECRAN

Local File =APPLI+".FUP"  [FUP]
Local File =APPLI+".FUP"  [FUP2]
Local File =APPLI+".TMPFUP0" [TFP0]
Local File =APPLI+".TMPFUP0" [TF02]
Local File =APPLI+".TMPFUP1" [TFP1]
Local File =APPLI+".TMPFUP1" [TF12]
Local File =APPLI+".TMPFUP2" [TFP2]
Local File =APPLI+".TMPFUP2" [TF22]

Trbegin [FUP]
 If filinfo(filpath("FIL","FUP","fde",APPLI),0)>0
  N = 0
  # enregistrements de FUP dont le numéro de campagne n'existe pas dans TMPFUP0
  Link [FUP] With [TFP0]TFP0=[FUP]NUMEDT As [LNK]
  For [LNK]
   If [TFP0]QURNUM=""
    Delete [FUP2] Where [FUP2]NUMEDT=[F:FUP]NUMEDT
    If fstat=1  : GOK=-1 : Call RSTA("FUP",[F:FUP]NUMEDT) From GLOCK : Break : Endif
    N += adxdlrec
   Endif
  Next
  If GOK=-1 : End : Endif
  Call ECR_TRACE("FUP: Deleted records: "+num$(N),0) From GESECRAN
 Endif

 If filinfo(filpath("FIL","TMPFUP1","fde",APPLI),0)>0
  N = 0
  # enregistrements de TFP1 dont le numéro de campagne n'existe pas dans TMPFUP0
  Link [TFP1] With [TFP0]TFP0=[TFP1]NUMREQ As [LNK]
  For [LNK]
   If [TFP0]QURNUM=""
    Delete [TF12] Where [TF12]NUMREQ=[F:TFP1]NUMREQ
    If fstat=1  : GOK=-1 : Call RSTA("TFP1",[F:TFP1]NUMREQ) From GLOCK : Break : Endif
    N += adxdlrec
   Endif
  Next
  If GOK=-1 : End : Endif
  Call ECR_TRACE("TMPFUP1: Deleted records: "+num$(N),0) From GESECRAN
 Endif

 If filinfo(filpath("FIL","TMPFUP2","fde",APPLI),0)>0
  N = 0
  # enregistrements de TFP2 dont le numéro de campagne n'existe pas dans TMPFUP0
  Link [TFP2] With [TFP0]TFP0=[TFP2]NUMREQ As [LNK]
  For [LNK]
   If [TFP0]QURNUM=""
    Delete [TF22] Where [TF22]NUMREQ=[F:TFP2]NUMREQ
    If fstat=1  : GOK=-1 : Call RSTA("TFP2",[F:TFP2]NUMREQ) From GLOCK : Break : Endif
    N += adxdlrec
   Endif
  Next
  If GOK=-1 : End : Endif
  Call ECR_TRACE("TMPFUP2: Deleted records: "+num$(N),0) From GESECRAN
 Endif

 If filinfo(filpath("FIL","TMPFUP0","fde",APPLI),0)>0
  N = 0
  # enregistrements de TFP0 dont le numéro de campagne n'existe pas dans TMPFUP1
  Link [TFP0] With [TFP1]TFP1(1)=[TFP0]QURNUM As [LNK]
  For [LNK]
   If [TFP1]NUMREQ=""
    Delete [TF02] Where [TF02]QURNUM=[F:TFP0]QURNUM
    If fstat=1  : GOK=-1 : Call RSTA("TFP0",[F:TFP0]QURNUM) From GLOCK : Break : Endif
    N += adxdlrec
   Endif
  Next
  If GOK=-1 : End : Endif
  Call ECR_TRACE("TMPFUP0: Deleted records: "+num$(N),0) From GESECRAN

  N = 0
  # enregistrements de TFP0 dont le numéro de campagne n'existe pas dans TMPFUP2
  Link [TFP0] With [TFP2]TFP1(1)=[TFP0]QURNUM As [LNK]
  For [LNK]
   If [TFP2]NUMREQ=""
    Delete [TF02] Where [TF02]QURNUM=[F:TFP0]QURNUM
    If fstat=1  : GOK=-1 : Call RSTA("TFP0",[F:TFP0]QURNUM) From GLOCK : Break : Endif
    N += adxdlrec
   Endif
  Next
  If GOK=-1 : End : Endif
  Call ECR_TRACE("TMPFUP0: Deleted records: "+num$(N),0) From GESECRAN
 Endif
Commit
Call ECR_TRACE("UUTITRS05: Process End on : "+APPLI,0) From GESECRAN
End

########################################################################
# Pour exécution automatique en gestion de patch                       #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI
# pas de modification dans le dossier mère
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS]DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

# test de présence du module Tiers
If [F:ADS]MODULE(2)<>2 : End : Endif
Call MAJ_UTITRS05(APPLI)
End

########################################################################
# Pour exécution depuis dosmaj (validation dossier)                    #
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI
# pas de modification dans le dossier mère
If APPLI="X3" End : Endif
# test de présence du module Tiers
If [F:ADS]MODULE(2)<>2 : End : Endif
Call MAJ_UTITRS05(APPLI)
End
