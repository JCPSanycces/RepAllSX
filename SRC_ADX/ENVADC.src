####################################################################################
# Program Name: ENVADC
# Description : ADC Standard Routines
# Author      : Standard Development Group
# Date        :
# Type        :
####################################################################################
# * Revision Log *
#-----------------------------------------------------------------------------------
# Rev    Issue Number    Date         User    Description
#-----------------------------------------------------------------------------------
# 001    NA14AD-X01      23-Mar-2006  CED/JRB Initial release v14
####################################################################################

########################################################
# Initialisation du site de stock
########################################################
$INIT_STOFCY

If GXAFCY="" GXAFCY=GFCYDEF(7) Endif
Call GETCPY(GXAFCY,"",0,"") From TRTX3CPT

Return

########################################################
# Miscellaneous Receipt
########################################################
#
# Necessary field in the VT Screen
# --------------------------------
# STOFCY, ITMREF, PCU, QTYPCU, STU , QTYSTU, PCUSTUCOE
# STA, LOC, LOCTYP, LOT, SLO, SLOF, BPSLOT, GESLOT
# PALNUM, CTRNUM, SERNUM, SERNUMF, TCLCOD
# WSTOSEQ, WLOCSEQ
#
# Necessary value in Entry transaction
# ------------------------------------
# Field 'Auto print'     --> No
# Field 'Form'           --> No auto print
# Block 'Lot': all field --> No
#
########################################################

########################################################
$OUVRE_SMR
If clalev([F:SMH]) =0 : Local File SMVTH [SMH]  : Endif
If clalev([M:SMR0])=0 : Local Mask SMR0  [SMR0] : Endif
If clalev([M:SMR1])=0 : Local Mask SMR1  [SMR1] : Endif
Gosub OUVRE From WOSMR
Return

########################################################
$DEBUT_SMR
Global Char     GSERIALADC(GLONSER), GSERIALADCF(GLONSER), GTRAVT(250)
Global Decimal  GQTYPCUADC, GQTYSTUADC, GPCUSTUADC
Global Integer  GNOLIG
Local  Shortint WRET
Local  Integer  I, NOL
GNOLIG=0
Gosub SETTRANS From SUBSMRA
Gosub OUVRE    From SUBSMRA
Return

########################################################
$OK_SMR
Local Char     LECCMAJ(GLONICVVAL), LECCMIN(GLONICVVAL)
# Pour interdire la navigation
GREP="C"
FIN = 0
Raz GSERIALADC, GSERIALADCF
Raz GQTYPCUADC, GQTYSTUADC, GPCUSTUADC
# Si no série
If find([F:ITM]SERMGTCOD,2,3) & [M]SERNUM<>""
   For I=0 To [M:SMR1]NBLIG-1
      If [M]ITMREF=[M:SMR1]ITMREF(I) & [M]STA=[M:SMR1]STA(I) & [M]PCU=[M:SMR1]PCU(I) & [M]PCUSTUCOE=[M:SMR1]PCUSTUCOE(I)
         If dim([M:SMR1]LOT)<=0 | (dim([M:SMR1]LOT)>0 & [M]LOT=[M:SMR1]LOT(I))
            If dim([M:SMR1]SLO)<=0 | (dim([M:SMR1]SLO)>0 & [M]SLO=[M:SMR1]SLO(I))
               If dim([M:SMR1]LOC)<=0 | (dim([M:SMR1]LOC)>0 & [M]LOC=[M:SMR1]LOC(I))
                  If dim([M:SMR1]PALNUM)<=0 | (dim([M:SMR1]PALNUM)>0 & [M]PALNUM=[M:SMR1]PALNUM(I))
                     If dim([M:SMR1]CTRNUM)<=0 | (dim([M:SMR1]CTRNUM)>0 & [M]CTRNUM=[M:SMR1]CTRNUM(I))
                        # Il existe déjà une ligne identique
                        [M:SMR1]QTYSTU(I)+=[M]QTYSTU
                        [M:SMR1]QTYPCU(I)+=[M]QTYPCU
                        GSERIALADC =[M]SERNUM
                        GSERIALADCF=[M]SERNUMF
                        GQTYPCUADC =[M]QTYPCU
                        GQTYSTUADC =[M]QTYSTU
                        GPCUSTUADC =[M]PCUSTUCOE
                        NOL=I
                        Break
                     Endif
                  Endif
               Endif
            Endif
         Endif
      Endif
   Next I
Endif
# Chargement de la nouvelle ligne
If GSERIALADC=""
   GNOLIG +=1
   nolign  =GNOLIG
   NOL     =nolign-1
   [M:SMR0]=[M:XAMR]
   [M:SMR1]=[M:XAMR1]    # hcb 111363

   Default Mask [SMR1]
   Call AM_ITMREF([M:XAMR1]ITMREF) From SUBSMR
#                                                             hcb 119083 deb
   Default Mask [SMR1]
   For I=1 To GNBDIE
      If evalue("dim([M:SMR1]CCE"+num$(I)+")")>0
         Call INISEC (LSEC, "STKENDD", I) From TRTX3CPT
         Assign "[M:SMR1]CCE"+num$(I)+"(nolign-1)" With LSEC
      Else
         Break
      Endif
   Next
#                                                             hcb 119083 fin
   MA=1
   Gosub SETMASK From=WINPROG
   [M:SMR1]NBLIG+=1
   If NOL=0
      [M:SMR1]VCRLIN(NOL)=1000
   Else
      [M:SMR1]VCRLIN(NOL)=[M:SMR1]VCRLIN(NOL-1)+1000
   Endif
Endif
Call OUVENT([M:SMR0]STOFCY,"SMR1",[M:SMR0]TRSTYP,[M:SMR0]TRSCOD,"",
&           [M:SMR0]VCRTYP,[M:SMR0]IPTDAT,NOL,[M:SMR1]NBLIG,"SRT","",WRET)
&    From STKENT

If GOUVENT>1 & GSERIALADC=""
   GNOLIG-=1
   [M:SMR1]NBLIG-=1
Else
    Raz LECCMAJ, LECCMIN
    If dim([M:SMR1]ECCVALMAJ)>0
        [L]LECCMAJ = string$([M:SMR1]ECCVALMAJ(nolign-1)<>"$",[M:SMR1]ECCVALMAJ(nolign-1))
        [L]LECCMIN = string$([M:SMR1]ECCVALMIN(nolign-1)<>"$",[M:SMR1]ECCVALMIN(nolign-1))
    Endif
    If [M:SMR1]PRI(nolign-1)=0
        Call DEFPRI([M:SMR1]ITMREF(nolign-1),LECCMAJ,LECCMIN,[M:SMR0]STOFCY,[M:SMR0]TRSTYP,[M:SMR0]TRSCOD,
&                   "","",[M:SMR0]IPTDAT,[M:SMR1]QTYSTU(nolign-1),[M:SMR1]QTYSTU(nolign-1),0,
&                   GBIDI1,[M:SMR1]PRI(nolign-1),GBIDI2) From STKVAL
    Endif
    If [M:SMR1]PRISAI(nolign-1)=GPRISAIAUT
        Call SETNEWPRIOVE([M:SMR1]ITMREF(nolign-1),LECCMAJ,LECCMIN,[M:SMR0]STOFCY,[M:SMR0]IPTDAT,[M:SMR1]WSTOSEQ(nolign-1),[M:SMR1]PRI(nolign-1),1,[M:SMR1]QTYSTU(nolign-1),"", GBIDI2) From STKVAL
    Else
        Call SETNEWPRI([M:SMR1]ITMREF(nolign-1),LECCMAJ,LECCMIN,[M:SMR0]STOFCY,[M:SMR0]IPTDAT,[M:SMR1]WSTOSEQ(nolign-1),[M:SMR1]PRI(nolign-1),"") From STKVAL
    Endif
Endif
Return

########################################################
Subprog CRE_SMR
Local Char ABREV(10)
ABREV="SMR"
Gosub DEFVAR From GOBJET
GREP="C" : REP="C"
GOBJET     = 1
GORITITCOL = 0
GABREV     = ABREV
GPROGRAMME = "GOBJSUB"
GTRAITE    = "GOBJET"
Call NOMTRTWIN("O"+ABREV,WINPROG) From MSKDIV
Gosub DEFVAR From =WINPROG
Gosub CREATION From GOBJET1
End

########################################################
$FIN_SMR
Call DELSTOENTW(-1,-1,"SMR1",1,1,[M:SMR0]STOFCY,1,"") From STKENT
Kill GSERIALADC, GSERIALADCF, GTRAVT
Kill GQTYPCUADC, GQTYSTUADC, GPCUSTUADC
Return

########################################################
$AM_ITMREF_SMR
#Local    Integer WRET
# Lecture article
#Call LECITM([M]STOFCY,VALEUR,"",3,"",WRET) From STKLIB
#If WRET<>0 : mkstat=2 : Endif
# Lecture de la règle de gestion
#Call LECSRU([M]STOFCY,[F:ITG]TCLCOD,[M:SMR0]TRSTYP,[M:SMR0]TRSCOD,"",WRET) From STKLIB
#If WRET<>0  mkstat=2 : Return : Endif
# Initialisation statut
#Call STKINISTA([M]STA,"",[F:ITM]QUAFLG) From STKACT
# Initialisation emplacement
#If [F:ITF]LOCMGTCOD>1
#   Call STKWLOCSEQ("ZSMR",0,WRET) From STKECR    #NA14AD-X01.o
#   Call STKWLOCSEQ("XAMR",0,WRET) From STKECR    #NA14AD-X01.N
#Endif
#                                                          # hcb 71276 deb
If [F:ITM]ECCSTO > 1 & [F:ITM]LOAECCFLG <> 2
   mkstat = 2
   GMESSAGE = mess(429,184,1) #  En VT un aticle géré en version sans préchargement est interdit !
   Return
Endif
#                                                          # hcb 71276 fin

[M]TCLCOD    = [F:ITM]TCLCOD
[M]STU       = [F:ITM]STU
[M]PCU       = [F:ITM]STU
[M]PCUSTUCOE = 1
If [F:ITM]LOTMGTCOD>1
   Actzo [M]SHLDAT
Else
   Grizo [M]SHLDAT
Endif
Return

########################################################
$AM_PCU_SMR
Local Char    LUSCAV
Local Char    LFMT
Local Integer LMODIF
Call CTLUOM([M]ITMREF,3,"",VALEUR,[M]PCUSTUCOE,LUSCAV,LFMT,LMODIF) From STKACT
If LUSCAV<>"S"
   If LUSCAV<>"C"
      mkstat=2 : Return
   Endif
Endif
Call QTEARR([M]QTYPCU,VALEUR) From TRTDIV
[M]QTYSTU = [M]QTYPCU*[M]PCUSTUCOE
Call QTEARR([M]QTYSTU,[F:ITM]STU) From TRTDIV
Return

########################################################
$AM_QTYPCU_SMR
[M]QTYSTU= VALEUR*[M]PCUSTUCOE
Call QTEARR([M]QTYSTU,[F:ITM]STU) From TRTDIV
Return

########################################################
$C_SLO_SMR
If VALEUR<>""
   Call STKCTRSLO(VALEUR,1,[M]LOT,[M]ITMREF,[M]BPSLOT,[M]GESLOT,"",
&                 0,0,0,[M]STOFCY,[M]SLOF) From STKACT
Endif
Return

########################################################
# Miscellaneous Issue
########################################################
#
# Necessary field in the VT Screen
# --------------------------------
# STOFCY, ITMREF, PCU, QTYPCU, STU , QTYSTU, PCUSTUCOE
# STA, LOC, LOT, SLO, PALNUM, CTRNUM, SERNUM, SERNUMF
# WSTOSEQ
#
# Necessary value in Entry transaction
# ------------------------------------
# Field 'Automatic determination' --> No
#
# ZSMO is the VT screen for the test
#
########################################################

########################################################
$OUVRE_SMO
If clalev([F:SMH]) =0 : Local File SMVTH [SMH]  : Endif
If clalev([M:SMO0])=0 : Local Mask SMO0  [SMO0] : Endif
If clalev([M:SMO1])=0 : Local Mask SMO1  [SMO1] : Endif
Gosub OUVRE From WOSMO
Return

########################################################
$DEBUT_SMO
Global Char     GSERIALADC(GLONSER), GSERIALADCF(GLONSER), GTRAVT(250)
Global Integer  GNOLIG
Local  Integer  WRET
Local  Integer  I, NOL
GNOLIG=0
Gosub SETTRANS From SUBSMOA
Gosub OUVRE    From SUBSMOA
Return

########################################################
$OK_SMO
# Pour interdire la navigation
GREP="C"
FIN = 0
Raz GSERIALADC, GSERIALADCF
# Si no série
If find([F:ITM]SERMGTCOD,2,3) & [M]SERNUM<>""
   For I=0 To [M:SMO1]NBLIG-1
      If [M]ITMREF=[M:SMO1]ITMREF(I) & [M]STA=[M:SMO1]STA(I) & [M]PCU=[M:SMO1]PCU(I) & [M]PCUSTUCOE=[M:SMO1]PCUSTUCOE(I)
         If dim([M:SMO1]LOT)<=0 | (dim([M:SMO1]LOT)>0 & [M]LOT=[M:SMO1]LOT(I))
            If dim([M:SMO1]SLO)<=0 | (dim([M:SMO1]SLO)>0 & [M]SLO=[M:SMO1]SLO(I))
               If dim([M:SMO1]LOC)<=0 | (dim([M:SMO1]LOC)>0 & [M]LOC=[M:SMO1]LOC(I))
                  If dim([M:SMO1]PALNUM)<=0 | (dim([M:SMO1]PALNUM)>0 & [M]PALNUM=[M:SMO1]PALNUM(I))
                     If dim([M:SMO1]CTRNUM)<=0 | (dim([M:SMO1]CTRNUM)>0 & [M]CTRNUM=[M:SMO1]CTRNUM(I))
                        # Il existe déjà une ligne identique
                        [M:SMO1]QTYSTU(I)+=[M]QTYSTU
                        [M:SMO1]QTYPCU(I)+=[M]QTYPCU
                        GSERIALADC =[M]SERNUM
                        GSERIALADCF=[M]SERNUMF
                        NOL=I
                        Break
                     Endif
                  Endif
               Endif
            Endif
         Endif
      Endif
   Next I
Endif
# Chargement de la nouvelle ligne
If GSERIALADC=""
   GNOLIG +=1
   nolign  =GNOLIG
   NOL     =nolign-1
   [M:SMO0]=[M:XAMO]
   [M:SMO1]=[M:XAMO]
   #[M:SMO1]ITMDES1(NOL)=[F:ITM]ITMDES1
   Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:SMO1]ITMDES1(NOL), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
   Default Mask [SMO1]
   For I=1 To GNBDIE
      If evalue("dim([M:SMO1]CCE"+num$(I)+")")>0
         Call INISEC (LSEC, "STKSODD", I) From TRTX3CPT
         Assign "[M:SMO1]CCE"+num$(I)+"(nolign-1)" With LSEC
      Else
         Break
      Endif
   Next
   MA=1
   Gosub SETMASK From=WINPROG
   [M:SMO1]NBLIG+=1
   If NOL=0
      [M:SMO1]VCRLIN(NOL)=1000
   Else
      [M:SMO1]VCRLIN(NOL)=[M:SMO1]VCRLIN(NOL-1)+1000
   Endif
Endif

Gosub ALI_ALP From SUBSMOB
Call OUVSOR("SMO1",NOL,[M:SMO1]NBLIG,[M:SMO1]WSTOSEQ(NOL),[F:SRT]STKFLG,WRET)
&           From STKSOR

If GOUVSOR>=1 & GSERIALADC=""
   GNOLIG-=1
   [M:SMO1]NBLIG-=1
Endif
Return

########################################################
Subprog CRE_SMO
Local Char ABREV(10)
ABREV="SMO"
Gosub DEFVAR From GOBJET
GREP="C" : REP="C"
GOBJET     = 1
GORITITCOL = 0
GABREV     = ABREV
GPROGRAMME = "GOBJSUB"
GTRAITE    = "GOBJET"
Call NOMTRTWIN("O"+ABREV,WINPROG) From MSKDIV
Gosub DEFVAR From =WINPROG
Gosub CREATION From GOBJET1
End

########################################################
$FIN_SMO

If [M:SMO1]NBLIG > 0
    Call DELSTOSORW(-1,-1,"SMO1",[M:SMO0]STOFCY,WRET) From STKSOR
Else
    Call RAZSTOSORW From STKSOR
Endif
Kill GSERIALADC, GSERIALADCF, GTRAVT
Return

########################################################
$AM_ITMREF_SMO

# Old
# Lecture article et règle de gestion
#Call LECFICSOR(VALEUR,[M]STOFCY,[M:SMO0]TRSTYP,[M:SMO0]TRSCOD,0) From STKECR
#If [F:ITM]STOMGTCOD<2 | [F:ITM]ITMSTA=6
#   mkstat=2 : Return
#Endif
#---
# New
# Lecture article et règle de gestion
Call INIZONADC("XAMO",VALEUR,[M:SMO0]STOFCY,0,[M:SMO0]TRSTYP,[M:SMO0]TRSCOD,"") From STKECR
If [F:ITM]STOMGTCOD<2 | [F:ITM]ITMSTA=6
   mkstat=2 : Return
Endif
If clalev ([F:ITF]) <= 0 : Local File ITMFACILIT [ITF] : Endif
If [F:ITF]ITMREF <> VALEUR | [F:ITF]STOFCY <> [M:SMO0]STOFCY
   Read [ITF]ITF0 = VALEUR;[M:SMO0]STOFCY
   If fstat
      mkstat=2 : Return
   Endif
Endif
#---
[M]TCLCOD    = [F:ITM]TCLCOD
[M]PCU       = [F:ITM]STU
[M]STU       = [F:ITM]STU
[M]PCUSTUCOE = 1
If [F:ITF]LOCMGTCOD=2
   Call STKINIEMPS([M]LOC) From STKLOC
Endif
Diszo [M]PCUSTUCOE
# Disable fields that should not be prompted for, based on the product
If [F:ITM]LOTMGTCOD<2
   Grizo [M]LOT
Else
   Actzo [M]LOT
Endif
If [F:ITM]LOTMGTCOD<2 | [F:ITM]LOTMGTCOD<>4
   Grizo [M]SLO
Else
   Actzo [M]SLO
Endif
If [F:ITM]SERMGTCOD<2            # hcb 98605
   Grizo [M]SERNUM
Else
   Actzo [M]SERNUM
Endif
Return

########################################################
$AM_PCU_SMO
Local Integer LMODIF
Call CTLUOM([M]ITMREF,3,"",VALEUR,[M]PCUSTUCOE,GBIDC1,GBIDC2,LMODIF) From STKACT
If mkstat=2 : Return : Endif
Call QTEARR([M]QTYPCU,VALEUR) From TRTDIV
[M]QTYSTU = [M]QTYPCU*[M]PCUSTUCOE
Call QTEARR([M]QTYSTU,[F:ITM]STU) From TRTDIV
# Si UC <> US, le coef est saisissable
If VALEUR<>[F:ITM]STU
   Actzo [M]PCUSTUCOE
Else
   Diszo [M]PCUSTUCOE
Endif
Affzo [M]PCUSTUCOE
Return

########################################################
$AM_PCUSTUCOE_SMO
[M]QTYSTU= [M]QTYPCU*VALEUR
Call QTEARR([M]QTYSTU,[F:ITM]STU) From TRTDIV
Return

########################################################
$AM_QTYPCU_SMO
[M]QTYSTU= VALEUR*[M]PCUSTUCOE
Call QTEARR([M]QTYSTU,[F:ITM]STU) From TRTDIV
Return

########################################################
$AM_SERNUM_SMO
Local    Char    LSERF(GLONSER)
Local    Decimal LQTYF
#--- Issue 116754
Local    Integer J, WRET, WNBSERIE
Local    Char    WNUMDEB(GLONSER), WNUMFIN(GLONSER)
Raz [M]SERNUMF
#If VALEUR<>""
If VALEUR="" : Return : Endif
# Issue 110327 - 2016-07-22 by MAE : ajout des numéros de série en entrée sortie globale
If [F:ITM]SERMGTCOD=3 | [F:ITM]SERMGTCOD=4
#--- End issue 116754
   [M:ALP]TRSTYP     = [M:SMO0]TRSTYP
   [M:ALP]TRSCOD     = [M:SMO0]TRSCOD
   [M:ALP]STOFCY     = [M]STOFCY
   [M:ALP]ITMREF     = [M]ITMREF
   [M:ALP]BESDAT     = [M:SMO0]IPTDAT
   [M:ALP]DLVDAT     = [M:SMO0]IPTDAT
   [M:ALP]PECINTLOC  = 2
   [M:ALP]PECSCOLOC  = 1
   [M:ALP]PECPLFLOC  = 2
   [M:ALP]STA        = "*"
   # Détermination no série fin
   Call CTLSORSER("SMO",0,VALEUR,[M]QTYSTU,LSERF,LQTYF) From STKSOR
   If LQTYF=0
      Raz VALEUR, [M]SERNUMF
   Else
      [M]SERNUMF=LSERF
   Endif
Else
#--- Issue 116754
#   Raz [M]SERNUMF
   Read [STS]STS0=[M]ITMREF;VALEUR
   # Si no série existe, erreur
   If !fstat
      mkstat=2 : GMESSAGE=mess(3,187,1) : Return
   Endif
   If [M]QTYSTU=1
      [M]SERNUMF = VALEUR
   Else
      # Vérification que les no série n'existent pas
      # et alimentation du no série fin
      WNBSERIE = [M]QTYSTU
      WNUMDEB  = VALEUR
      For J=2 To WNBSERIE
         Call PLUS_UN(WNUMDEB,WNUMFIN,WRET) From STKLIB
         If WRET=0
            Read [STS]STS0=[M]ITMREF;WNUMFIN
            If fstat
               WNUMDEB = WNUMFIN
            Else
               mkstat=2 : GMESSAGE=WNUMFIN-":"-mess(3,187,1) : Break
            Endif
         Else
            mkstat=2 : GMESSAGE=WNUMDEB-":"-mess(476,197,1) : Break
         Endif
      Next J
      If mkstat=2 Return Endif
      [M]SERNUMF = WNUMFIN
   Endif
#--- End issue 116754
Endif
Return



########################################################
# Stock change
########################################################
#
# Necessary field in the VT Screen
# --------------------------------
# STOFCY, FCYDES, ITMREF,
# PCU, QTYPCU, STU, QTYSTUDES, PCUSTUCOE
# STA, LOC, LOT, SLO, PALNUM, CTRNUM, SERNUM, SERNUMF
# STADES, LOCDES, LOCTYPDES
# PCUDES, COEDES, QTYPCUDES
# WSTOSEQ, WLOCSEQ
#
# Necessary value in Entry transaction
# ------------------------------------
#
# Field 'Movement type'  --> Internal
# Field 'Form'           --> No print
#
# ZSCS is the VT screen for the test
#
########################################################

########################################################
$OUVRE_SCS
If clalev([F:SGH])  =0 : Local File SCHGH [SGH]  : Endif
If clalev([M:SCS1]) =0 : Local Mask SCS1  [SCS1] : Endif
# Issue 110327 - 2016-09-13 by MAE
If clalev([F:STC]) =0 : Local File STOLOC [STC1]  : Endif
# End issue 110327
Gosub OUVRE From WOSCS
Return

########################################################
$DEBUT_SCS
Global Integer  GNOLIG        : GNOLIG=0
Global Char     GBOXSTO(10)   : GBOXSTO="GAU_CHE1"
Global Char     GTRAVT(250)
Local  Char     LLOT(GLONLOT) : Raz LLOT
Local  Char     LSLO(GLONSLO) : Raz LSLO
Local  Char     LPAL(GLONPAL) : Raz LPAL
Local  Char     LCTR(GLONCTR) : Raz LCTR
Local  Char     LLOC(GLONLOC) : Raz LLOC
Local  Char     LSER(GLONSER) : Raz LSER
Local  Char     LQLY(GLONVCR) : Raz LQLY
Local  Decimal  LSTOCOU
Local  Shortint WRET
Local  Integer  LRET
Local  Integer  I, OK, NOL
GNOLIG=0
Gosub SETTRANS From SUBSCSA
Gosub OUVRE    From SUBSCSA
Return

########################################################
$INIT_SCS
Default Mask [SCS1]
Gosub RAZCRE   From SUBSCSA
MA=1
Gosub SETMASK From=WINPROG
Raz [M]
[M]SRTNUM     = GFLAG
[M]STOFCY     = [M:SCS1]STOFCY
[M]FCYDES     = [M:SCS1]FCYDES
[M:SGW]FCYDES = [M:SCS1]FCYDES
nolign=0
Return

########################################################
$AVANT_OK_SCS
OK=1

WRET=0 : LRET=0
If dim([M]LOT)>0 LLOT=[M]LOT    Endif
If dim([M]SLO)>0 LSLO=[M]SLO    Endif
If dim([M]PALNUM)>0 LPAL=[M]PALNUM    Endif             # hcb 43077
If dim([M]CTRNUM)>0 LCTR=[M]CTRNUM    Endif             # hcb 43077
If dim([M]LOC)>0 LLOC=[M]LOC    Endif
If dim([M]SERNUM)>0    LSER=[M]SERNUM    Endif
If dim([M]QLYCTLDEM)>0 LQLY=[M]QLYCTLDEM Endif
If ([F:ITM]SERMGTCOD = 4 & [F:STS]STOCOU <> AVOID.ADEC) # Issue 110327 - 2016-09-08 by MAE
  LSTOCOU = [F:STS]STOCOU
Endif
Call REC_STO([M]STOFCY,[M]ITMREF,LLOT,LSLO,LPAL,LCTR,[M]STA,LLOC,
&            [M]PCU,[M]PCUSTUCOE,LSER,LQLY,LSTOCOU)
If LSTOCOU=0
   LRET=1 : Return
Endif
If [F:SRT]BETFCYCOD<>2
   If [M]QTYSTUDES>[F:STO]QTYSTU-[F:STO]CUMWIPQTY
      LRET=2 : Return
   Endif
Else
   If [M]QTYSTUDES>[F:STO]QTYSTU-[F:STO]CUMALLQTY-[F:STO]CUMWIPQTY
      LRET=2 : Return
   Endif
Endif
If [M]STADES=""
   [M]STADES=[F:STO]STA
Endif
If [M]LOCDES=""
   [M]LOCDES   =[F:STO]LOC
   [M]LOCTYPDES=[F:STO]LOCTYP
Endif
If [M]PCUDES=""
   [M]PCUDES   =[F:STO]PCU
   [M]COEDES   =[F:STO]PCUSTUCOE
   [M]QTYPCUDES=[F:STO]QTYPCU
Endif

If dim([M]PALNUM)   >0 [M]PALNUM     = [F:STO]PALNUM  Endif   # hcb 74627
If dim([M]CTRNUM)   >0 [M]CTRNUM     = [F:STO]CTRNUM  Endif   # hcb 74627
If dim([M]PALNUMDES)>0 [M]PALNUMDES  = [F:STO]PALNUM  Endif   # hcb 74627
If dim([M]CTRNUMDES)>0 [M]CTRNUMDES  = [F:STO]CTRNUM  Endif   # hcb 74627

GPOINT = "INITSCS"                    # hcb 117786
Gosub  ENTREE From EXEFNC             # hcb 117786


If [F:STO]QLYCTLDEM<>""
   If [F:SRT]BETFCYCOD=1
      If [M]STADES<>[F:STO]STA
         [M]STADES=[F:STO]STA
         If [M]LOCDES=[F:STO]LOC &
&           [M]PCUDES=[F:STO]PCU &
&           [M]COEDES=[F:STO]PCUSTUCOE
            LRET=3 : Return
         Endif
      Endif
   Else
      LRET=3 : Return
   Endif
Endif
#MAE, bg 72981, on ne teste les différences que si on est en intersite
If [F:SRT]BETFCYCOD<>2 &
& [M]STADES=[F:STO]STA & [M]LOCDES=[F:STO]LOC &
&  [M]PCUDES=[F:STO]PCU & [M]COEDES=[F:STO]PCUSTUCOE
   LRET=4 : Return
Endif

Return

########################################################
$OK_SCS
FIN =0
GREP="C" : REP="C"
currbox=GBOXSTO
[F:STO]STOFCY=[M]STOFCY
[F:STO]STOCOU=LSTOCOU
Raz GOUVENT
Gosub PICKE From SUBSCSP
If GOUVENT>0
   Call DELSTOCHGW("SCS1",[M:SCS1]STOFCY,[M:SCS1]NBLIG-1,[M:SCS1]NBLIG-1,1,LRET) From SUBSCSB
   GNOLIG-=1
   [M:SCS1]NBLIG-=1
   LRET=1
Endif
If OK=0 :LRET=1 : Endif
Return

########################################################
Subprog CRE_SCS

Local Char ABREV(10)
ABREV="SCS"
Gosub DEFVAR From GOBJET
GREP="C" : REP="C"
GOBJET     = 1
GORITITCOL = 0
GABREV     = ABREV
GPROGRAMME = "GOBJSUB"
GTRAITE    = "GOBJET"
Call NOMTRTWIN("O"+ABREV,WINPROG) From MSKDIV
Gosub DEFVAR From =WINPROG
Gosub CREATION From GOBJET1
End

########################################################
$FIN_SCS
# Issue 110327 - 2016-09-13 by MAE
If [M:SCS1]NBLIG >0
  Call DELSTOCHGW("SCS1",[M:SCS1]STOFCY,-1,-1,1,LRET) From SUBSCSB
Else
  Call RAZSTOCHGW From SUBSCSB
Endif
# End Issue 110327 - 2016-09-13 by MAE
Kill GTRAVT
Return

########################################################
$AM_ITMREF_SCS
Local  Shortint WRET
Local  Integer  LRET
Local  Integer  WLOCMGTCOD

Raz [M]STA, [M]LOC, [M]PCU, [M]QTYPCU, [M]LOT, [M]SLO
Raz [M]SERNUM, [M]STADES
# Si pas transfert sous-traitant
If [M:SCS1]BETFCYCOD<>4
   Raz[M]LOCDES, [M]LOCTYPDES
Endif
Call LECITM([M:SCS1]FCYDES,VALEUR,"",3,"",LRET) From STKLIB
If LRET<>0  : mkstat=2 : Return : Endif

If [M:SCS1]BETFCYCOD=2 WLOCMGTCOD=[F:ITF]LOCMGTCOD Endif

Read [ITF]ITF0 = VALEUR;[M:SCS1]STOFCY
If fstat
  GMESSAGE=VALEUR-[M:SCS1]STOFCY-":"-mess(139,197,1)
  mkstat=2 : Return
Else
  Read [ITFD]ITF0 = VALEUR;[M:SCS1]FCYDES
  If fstat
    GMESSAGE=VALEUR-[M:SCS1]FCYDES-":"-mess(139,197,1)
    mkstat=2: Return
  Endif
Endif
If [ITF]LOCMGTCOD<>2 & [M:SCS1]BETFCYCOD=4
  GERR=1   : GMESSAGE=mess(149,199,1)
  mkstat=2 : Return
Endif

If [M:SCS1]BETFCYCOD<>2 WLOCMGTCOD=[F:ITF]LOCMGTCOD Endif

# Si transfert inter-site ou tiers, lecture règle de gestion
# pour filtrer la liste de picking et contrôler le picking
If [M:SCS1]BETFCYCOD>1
  Call LECSRU([M:SCS1]STOFCY,[F:ITM]TCLCOD,27,[M:SCS1]TRSCOD,"",LRET)
&             From STKLIB
  If LRET=0
    [F:SRU1] = [F:SRU] : Raz [F:SRU]
  Else
    mkstat=2 : Return
  Endif
Endif

GSCSAUZSST = "A*,Q*,R*"
# Si changement stock, lecture règle de gestion pour flux d'entrée
If [M:SCS1]BETFCYCOD=1
  Call LECSRU([M:SCS1]STOFCY,[F:ITM]TCLCOD,26,[M:SCS1]TRSCOD,"",LRET)
&             From STKLIB
  If LRET<>0 : mkstat=2 : Return : Endif
  GSCSAUZSST = [F:SRU]AUZSST
# Si transfert inter-site, lecture règle de gestion pour flux d'entrée
Elsif [M:SCS1]BETFCYCOD=2
  Call LECSRU([M:SCS1]FCYDES,[F:ITM]TCLCOD,28,[M:SCS1]TRSCOD,"",LRET)
&             From STKLIB
  If LRET<>0 : mkstat=2 : Return : Endif
  GSCSAUZSST = [F:SRU]AUZSST
Endif

# Contrôle emplacement dédié ou mono-article
If [M:SCS1]BETFCYCOD=4
  GBIDD1=-1
  Call STKCTREMP(GBIDD1,[M:SCS1]TRSTYP,[M:SCS1]TRSCOD,[M:SCS1]FCYDES,VALEUR,
&                "",1,"",[M:SCS1]SCOLOCTYP,[M:SCS1]SCOLOC,"",0,WRET,
&                GBIDD2,"UQS","","") From STKLOC
  If WRET : mkstat=2 : Return : Endif
Endif

[M]STU       = [F:ITM]STU
[M]PCU       = [F:ITM]STU
[M]PCUSTUCOE = 1
[M]PCUDES    = [M]PCU
[M]COEDES    = [M]PCUSTUCOE
Diszo [M]PCUSTUCOE
# Disable fields that should not be prompted for, based on the product
If [F:ITM]LOTMGTCOD<2
   Grizo [M]LOT
Else
   Actzo [M]LOT
Endif
If [F:ITM]LOTMGTCOD<2 | [F:ITM]LOTMGTCOD<>4
   Grizo [M]SLO
Else
   Actzo [M]SLO
Endif
If [F:ITM]SERMGTCOD<3
   Grizo [M]SERNUM
Else
   Actzo [M]SERNUM
Endif
If [F:ITF]LOCMGTCOD<2
   Grizo [M]LOC
Else
   Actzo [M]LOC
Endif
If WLOCMGTCOD<2
   Grizo [M]LOCDES
Else
   Actzo [M]LOCDES
Endif

Affzo [M]1-99

Return

########################################################
$APRES_MODIF_SCS

If COUZON="ITMREF"

   Raz WCRIT, WCRITPIC, WCRITSTO4
   # Si transfert inter-site ou tiers
   If [M:SCS1]BETFCYCOD>1
      # Lot et péremption
      If dim([M:SCS1]LOTSTR)>0
         If [F:SRU1]SHLLOT=1
            WCRITPIC = '([F:STL]SHLDAT=[0/0/0]|'                        # hcb v6dlu
            If [M:SCS1]IPTDAT<>[0/0/0]
               WCRITPIC += '[F:STL]SHLDAT>=[M:SCS1]IPTDAT)'             # hcb v6dlu
            Else
               WCRITPIC += '[F:STL]SHLDAT>=date$)'                      # hcb v6dlu
            Endif
         Endif
         If [F:SRU1]SHLLOT=2
            WCRITPIC = '([F:STL]DLUDAT=[0/0/0]|'                        # hcb v6dlu
            If [M:SCS1]IPTDAT<>[0/0/0]
               WCRITPIC += '[F:STL]DLUDAT>=[M:SCS1]IPTDAT)'             # hcb v6dlu
            Else
               WCRITPIC += '[F:STL]DLUDAT>=date$)'                      # hcb v6dlu
            Endif
         Endif
      Endif
      Raz WA, WQ, WR
      # Statuts autorisés par les règles de gestion d'E/S
      If find([F:SRU1]AUZSTA,1,3,5,7) WA=1  Endif
      If find([F:SRU1]AUZSTA,2,3,6,7) WQ=1  Endif
      If find([F:SRU1]AUZSTA,4,5,6,7) WR=1  Endif
      # Prise en compte des sous-statuts autorisés
      Call CREE_FORMULE([F:SRU1]FORSTA,"[F:STO]STA",WCRITSTO4) From TRTCATEG
      # Alimentation des zones de la fenêtre critère et du filtre
      # pour contrôle ligne stock pickée (si non administrateur stock)
      [M:SCS1]AUZSST=[F:SRU1]AUZSST
      [M:SCS1]FORSTA=[F:SRU1]FORSTA
      [M:SCS1]SHLLOT=[F:SRU1]SHLLOT
      Raz WCRIT
      If WA=1
         WCRIT+='pat([F:STO]STA,"A*")<>0'
      Endif
      If WQ=1
         If WCRIT<>"" WCRIT+='|' Endif
         WCRIT+='pat([F:STO]STA,"Q*")<>0'
      Endif
      If WR=1
         If WCRIT<>"" WCRIT+='|' Endif
         WCRIT+='pat([F:STO]STA,"R*")<>0'
      Endif

      If WCRITSTO4<>""
         If WCRITPIC<>""
            WCRITPIC+='&('+WCRITSTO4+')'
         Else
            WCRITPIC+=WCRITSTO4
         Endif
      Elsif WCRITPIC<>""
         If WCRIT<>"" WCRITPIC+='&('+WCRIT+')' Endif
      Else
         If WCRIT<>""
            WCRITPIC+=WCRIT
         Else
            WCRITPIC='1=1'
         Endif
      Endif
   Endif
Endif

Return

########################################################
$AM_PCU_SCS
Local Char    LUSCAV
Local Char    LFMT
Local Integer LMODIF
Call CTLUOM([M]ITMREF,3,"",VALEUR,[M]PCUSTUCOE,LUSCAV,LFMT,LMODIF) From STKACT
If LUSCAV<>"S"
   If LUSCAV<>"C"
      mkstat=2 : Return
   Endif
Endif

[M]COEDES    = [M]PCUSTUCOE

Call QTEARR([M]QTYPCU,VALEUR) From TRTDIV
[M]QTYSTUDES = [M]QTYPCU*[M]PCUSTUCOE
Call QTEARR([M]QTYSTUDES,[F:ITM]STU) From TRTDIV
[M]QTYPCUDES = [M]QTYSTUDES/[M]COEDES
Call QTEARR([M]QTYPCUDES,[M]PCUDES) From TRTDIV
# Si UC <> US, le coef est saisissable
If VALEUR<>[F:ITM]STU
   Actzo [M]PCUSTUCOE
Else
   Diszo [M]PCUSTUCOE
Endif
Affzo [M]PCUSTUCOE
Return


########################################################
$AM_PCUSTUCOE_SCS
[M]COEDES    = VALEUR
[M]QTYSTUDES = [M]QTYPCU*VALEUR
Call QTEARR([M]QTYSTUDES,[F:ITM]STU) From TRTDIV
[M]QTYPCUDES = [M]QTYSTUDES/[M]COEDES
Call QTEARR([M]QTYPCUDES,[M]PCUDES) From TRTDIV
Return

########################################################
$AM_QTYPCU_SCS
If VALEUR<=0 mkstat=2 : Return Endif
[M]QTYSTUDES = VALEUR*[M]PCUSTUCOE
Call QTEARR([M]QTYSTUDES,[F:ITM]STU) From TRTDIV
[M]QTYPCUDES = [M]QTYSTUDES/[M]COEDES
Call QTEARR([M]QTYPCUDES,[M]PCUDES) From TRTDIV
Return

########################################################
$C_STADES_SCS
Case [F:SRT]BETFCYCOD
 When 1   : If VALEUR=[M]STA
               GSCSAUZSST="A*,Q*,R*"
            # Si statut destination <> statut origine, on le contrôle
            Else
               GSCSAUZSST = [F:SRU]AUZSST
               # Changement de stock sans chgt d'emplacement, on restreint
               # les statuts autorisés par la règle par ceux de l'emplacement
               If [F:SRT]CHGEMPCOD<>2 & [F:ITF]LOCMGTCOD=2
                  If [F:STC]LOC<>[M]LOC
                     Read [STC]STC0=[M]STOFCY;[M]LOC
                     If fstat Return Endif
                  Endif
                  Call STKCTRSTA(VALEUR,[F:STC]AUZSST,1,2,0,mkstat) From STKACT
               Endif
            Endif
 When 2   : GSCSAUZSST = [F:SRU]AUZSST : # Trf inter-sites
 When 3,4 : GSCSAUZSST = "A*,Q*,R*"
Endcase
Return

########################################################
# REC_STO    Recherche de la ligne stock correspondantes
#            aux caractéristiques saisies
########################################################
# Paramètres E : LFCY    = Site
#                LITM    = Article
#                LLOT    = Lot
#                LSLO    = Sous-Lot
#                LPAL    = Identifiant 1
#                LCTR    = Identifiant 2
#                LSTA    = Statut
#                LLOC    = Emplacement
#                LPCU    = UC
#                LCOE    = Coef UC/US
#                LSER    = No série
#                LQLY    = No demande analyse
#            S : LSTOCOU = Chrono stock (si 0, rien trouvé)
#
# Prérequis    : Ces tables doivent être ouvertes   STOCK  [STO]
#
########################################################
Subprog REC_STO(LFCY,LITM,LLOT,LSLO,LPAL,LCTR,LSTA,LLOC,LPCU,LCOE,LSER,LQLY,LSTOCOU)
Value    Char    LFCY
Value    Char    LITM
Value    Char    LLOT
Value    Char    LSLO
Value    Char    LPAL
Value    Char    LCTR
Value    Char    LSTA
Value    Char    LLOC
Value    Char    LPCU
Value    Decimal LCOE
Value    Char    LSER
Value    Char    LQLY
Variable Decimal LSTOCOU

Local    Char    WCRITSTO(250)
If LSTOCOU <> 0     # Issue 110327 - 2016-09-08 by MAE : Numéros de série en globale
  Filter [STO] Where  STOFCY    = LFCY
&                   & STOCOU    = LSTOCOU
Elsif LSER<>""
   Filter [STO] Where ITMREF    = LITM
&                   & STOFCY    = LFCY
&                   & SERNUM    = LSER
Else
   WCRITSTO='1=1'
   If LSTA<>"" : WCRITSTO+='&STA=LSTA'       : Endif
   If LPAL<>"" : WCRITSTO+='&PALNUM=LPAL'    : Endif
   If LCTR<>"" : WCRITSTO+='&CTRNUM=LCTR'    : Endif
   If LCOE<>0  : WCRITSTO+='&PCUSTUCOE=LCOE' : Endif
   If LQLY<>"" : WCRITSTO+='&QLYCTLDEM=LQLY' : Endif
   If LLOT="" & LLOC="" & WCRITSTO="1=1"
      Raz LSTOCOU : End
   Endif
   Filter [STO] Where ITMREF    = LITM
&                   & STOFCY    = LFCY
&                   & LOT       = LLOT
&                   & SLO       = LSLO
&                   & LOC       = LLOC
&                   & PCU       = LPCU
&                   & evalue(WCRITSTO)
Endif
If LSTOCOU <> 0    # Issue 110327 - 2016-09-08 by MAE : Numéros de série en globale
  Read [STO]STO0 First
Elsif LSER<>""
  Read [STO] STO5 First
Elsif LLOT="" & LPAL<>""
  Read [STO] STO1 First
Else
  Read [STO] STO3 First
Endif
If !fstat
  LSTOCOU = [F:STO]STOCOU
Else
  Raz LSTOCOU
Endif
Filter [STO]
End

########################################################
# ALI_DOC : Alimente la ligne de document en cours
########################################################
$ALI_DOC
Local Char     LSEC
Local Char     VAT(GLONVAT)(3)
Local Decimal  WQTE

If [F:STO]QTYSTU-[F:STO]CUMWIPQTY-([F:STO]CUMALLQTY*([F:SRT]BETFCYCOD=2))<=0
   OK=0 : GMESSAGE=mess(57,184,1) : Return
Endif
#---- Positionnement sur les tables ------------#
Call POSTABLE([M:SCS1]FCYDES,[F:STO]ITMREF,[F:STO]LOT,[F:STO]SLO,LRET)
&    From SUBSCSB
If LRET
   OK=0 : Return
Endif

Call STKWSTOSEQ ("SCS1",[M:SCS1]NBLIG,[M:SCS1]NBLIG,2,LSEQ,LRET) From STKECR
GNOLIG+=1
nolign =GNOLIG
NOL    =nolign-1
[M:SCS1] = [M]
[M:SCS1] = [F:STO]
# Issue 110327 - 2016-09-12 by MAE : Si numéro de série globaux : remise du num  à partir de l'écran
If [F:ITM]SERMGTCOD = 4
   [M:SCS1]SERNUM(NOL) = [M]SERNUM
Endif
[M:SCS1]QTYPCU(NOL)  = [M]QTYPCU
#[M:SCS1]ITMDES1(NOL) = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:SCS1]ITMDES1(NOL), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:SCS1]WSTOCOU(NOL) = [F:STO]STOCOU
If [M:SCS1]BETCPY=2
   [M:SCS1]INVSGH=2
Else
   [M:SCS1]INVSGH=1
Endif
Default Mask [SCS1]
If [M:SCS1]STOFCY<>[M:SCS1]FCYDES
   For I=1 To GNBDIE
      If [M:SCS1]BETCPY=2
         Call INISEC (LSEC, "ICOD", I) From TRTX3CPT
      Else
         Call INISEC (LSEC, "TRSD", I) From TRTX3CPT
      Endif
      Assign "[M:SCS1]CCE"+num$(I)+"(NOL)" With LSEC
   Next
Endif
MA=1
Gosub SETMASK From=WINPROG
[M:SCS1]NBLIG+=1
If NOL=0
   [M:SCS1]VCRLIN(NOL)=1000
Else
   [M:SCS1]VCRLIN(NOL)=[M:SCS1]VCRLIN(NOL-1)+1000
Endif
Case [M:SCS1]BETFCYCOD
 When 1   : If [F:STO]QLYCTLDEM<>""
              [M:SCS1]QLYCTLFLG(NOL) = 1
            Elsif left$([M]STADES,1)="Q"
              [M:SCS1]QLYCTLFLG(NOL) = [F:SRU]QLYCTLFLG
            Else
              [M:SCS1]QLYCTLFLG(NOL) = 1
            Endif
 When 2   : If left$([M]STADES,1)="Q"
              [M:SCS1]QLYCTLFLG(NOL) = [F:SRU]QLYCTLFLG
            Else
              [M:SCS1]QLYCTLFLG(NOL) = 1
            Endif
 When 3,4 : [M:SCS1]QLYCTLFLG(NOL)=1
Endcase

Case [F:ITM]STOMGTCOD
 When 3       : [M:SCS1]POT(NOL) = [F:STL]POT
 When 4       : [M:SCS1]POT(NOL) = [F:STL]ACT/100
 When Default : [M:SCS1]POT(NOL) = 1
Endcase
Gosub MAJ_STUDIS From SUBSCSB

Default Mask [SCS1]
Call OUVCHG( "SCS1", NOL, [M:SCS1]STOFCY) From SUBSCSB
If [M:SCS1]BETCPY=2
  # En inter-sociétés, alimentation du prix
  If [M:SCS1]PRI(NOL)=0
      Call DEFPRI([M:SCS1]ITMREF(NOL),[F:STL]ECCVALMAJ,[F:STL]ECCVALMIN,[M:SCS1]FCYDES,[M:SCS1]TRSTYP,[M:SCS1]TRSCOD,
&                         "","",[M:SCS1]IPTDAT,[M:SCS1]QTYSTUDES(NOL),[M:SCS1]QTYSTUDES(NOL),0,
&                         GBIDI1,[M:SCS1]PRI(NOL),LRET) From STKVAL
  Endif
  Call SETNEWPRIOVE([M:SCS1]ITMREF(NOL),[F:STL]ECCVALMAJ,[F:STL]ECCVALMIN,[M:SCS1]FCYDES,[M:SCS1]IPTDAT,
&                         [M:SCS1]WSTOSEQ(NOL),[M:SCS1]PRI(NOL),
&                         [M:SCS1]TRSTYP,[M:SCS1]QTYSTUDES(NOL),"",LRET) From STKVAL
Endif
MA=1
Gosub SETMASK From=WINPROG
Return



########################################################
# Purchase Receipt
########################################################
#
# Necessary field in the VT Screen
# --------------------------------
# POHNUM, POPLIN, POQSEQ, ITMREF, UOM, QTYUOM, STU, QTYSTU, UOMSTUCOE,
# STA, LOC, LOCTYP, LOT, SLO, SLOF, BPSLOT, GESLOT, NBSLO
# WSOLDE, PRHFCY, RCPDAT, BPSNUM,
# PALNUM, CTRNUM, SERNUM, SERNUMF, TCLCOD, WSTOSEQ, WLOCSEQ
#
# Necessary value in Entry transaction
# ------------------------------------
# Field 'Auto print'     --> No
# Field 'Form'           --> No auto print
# Block 'Lot': all field --> No
#
########################################################


########################################################
$OUVRE_PTH
If !clalev([F:PTH])   Local File PRECEIPT [PTH] : Endif
If !clalev([F:PTR])   Local File PURTRS   [PTR] : Endif
If !clalev([M:PTH0])  Local Mask PTH0    [PTH0] : Endif
If !clalev([M:PTH1])  Local Mask PTH1    [PTH1] : Endif
If !clalev([M:PTH2])  Local Mask PTH2    [PTH2] : Endif
Gosub OUVRE   From WOPTH
Return


########################################################
$DEBUT_PTH
Global Char     GTRAVT(250)
Global Char     GSERIALADC(GLONSER), GSERIALADCF(GLONSER)
Global Decimal  GQTYPCUADC, GQTYSTUADC, GPCUSTUADC
Global Integer  GNOLIG
Local  Shortint WRET
Local  Integer  NOL
Local  Integer  WOK
Local  Integer  WI
Local  Char     WSECTION(GLONCCE)
GNOLIG=0
Gosub SETTRANS    From SUBPTHA
Gosub OUVRE       From SUBPTHA
Gosub OUVRE_BOITE From SUBPTHA
Return


########################################################
$RAZ_PTH
GREP="C" : REP="C"
Raz [M:PTH0], [M:PTH1], [M:PTH2]
Gosub RAZCRE From SUBPTHA
If [M:PTH0]PRHFCY<>GXAFCY
  GFCY=GXAFCY
  Gosub CHARG_PARAM From SUBPTHB
  [M:PTH0]PRHFCY=GXAFCY
Endif
Return


########################################################
$OK_PTH

# Issue 92137 - 2013-08-29 by MUARN : contrôle si UOM différent entre PTH1 et APR1
Local Decimal  SAV_QTYUOM, SAV_UOMSTUCOE
Local Char     SAV_UOM
Local Decimal  SAV_QTYSTU # Issue 92266 - 2013-09-10 by MUARN : landed cost
Local Decimal  WCPRAMT # Issue 92266 - 2013-09-02 by MUARN : landed cost
Local Char     LECCMAJ(GLONICVVAL), LECCMIN(GLONICVVAL)

GREP="C" : REP="C"
FIN=0
mkstat=0
#----- Si premier fois, chargement site de réception, date et fournisseur -----#
If [M:PTH0]BPSNUM=""
  [M:PTH0]PRHFCY=[M:APR1]PRHFCY
  Call AM_PRHFCY([M:PTH0]PRHFCY) From SUBPTH
  [M:PTH0]RCPDAT=[M:APR1]RCPDAT
  Call AM_RCPDAT([M:PTH0]RCPDAT) From SUBPTH
  [M:PTH0]BPSNUM=[M:APR1]BPSNUM
  Call AM_BPSNUM([M:PTH0]BPSNUM) From SUBPTH
Endif
#----- Need to change UOM if the UOM is not the STU or a pack UOM -----#
If [F:ITM]ITMREF<>[M:APR1]ITMREF
  Read [ITM] ITM0=[M:APR1]ITMREF
  If fstat  Raz [F:ITM] : Endif
Endif

If [F:ITM]STOMGTCOD>1 & !find([M:APR1]UOM,[M:APR1]STU,[F:ITM]PCU)
  [M:APR1]UOM      =[M:APR1]STU
  [M:APR1]QTYUOM   =[M:APR1]QTYSTU
  [M:APR1]UOMSTUCOE=1
Endif

#-----
Raz GSERIALADC, GSERIALADCF
Raz GQTYPCUADC, GQTYSTUADC, GPCUSTUADC
#----- Si no série -----#
If find([F:ITM]SERMGTCOD,2,3) & [M:APR1]SERNUM<>""
  For I=0 To [M:PTH1]NBLIG-1
    If [M:APR0]POHNUM=[M:PTH1]POHNUM(I) & [M:APR1]POPLIN=[M:PTH1]POPLIN(I) & [M:APR1]POQSEQ=[M:PTH1]POQSEQ(I)
      If [M:APR1]ITMREF=[M:PTH1]ITMREF(I) & [M:APR1]STA=[M:PTH1]STA(I) & [M:APR1]UOM=[M:PTH1]UOM(I) & [M:APR1]UOMSTUCOE=[M:PTH1]UOMSTUCOE(I)
        If dim([M:PTH1]LOT)<=0 | (dim([M:PTH1]LOT)>0 & [M:APR1]LOT=[M:PTH1]LOT(I))
          If dim([M:PTH1]SLO)<=0 | (dim([M:PTH1]SLO)>0 & [M:APR1]SLO=[M:PTH1]SLO(I))
            If dim([M:PTH1]LOC)<=0 | (dim([M:PTH1]LOC)>0 & [M:APR1]LOC=[M:PTH1]LOC(I))
              If dim([M:PTH1]PALNUM)<=0 | (dim([M:PTH1]PALNUM)>0 & [M:APR1]PALNUM=[M:PTH1]PALNUM(I))
                If dim([M:PTH1]CTRNUM)<=0 | (dim([M:PTH1]CTRNUM)>0 & [M:APR1]CTRNUM=[M:PTH1]CTRNUM(I))
                  #----- Regroupement lignes identiques -----#
                  [M:PTH1]QTYSTU(I)+=[M:APR1]QTYSTU
                  [M:PTH1]QTYUOM(I)+=[M:APR1]QTYUOM
                  # FGR 15/01/2010 : X3SUIVI60986
                  #[M:PTH1]QTYPUU(I)+=[M:APR1]QTYPUU
                  [M:PTH1]QTYPUU(I)+=[M:APR1]QTYUOM
                  # Issue 118920 - 2016-10-10 by MUARN : flag solde
                  [M:PTH1]WSOLDE(I)=[M:APR1]WSOLDE
                  GSERIALADC =[M:APR1]SERNUM
                  GSERIALADCF=[M:APR1]SERNUMF
                  GQTYPCUADC =[M:APR1]QTYUOM
                  GQTYSTUADC =[M:APR1]QTYSTU
                  GPCUSTUADC =[M:APR1]UOMSTUCOE
                  NOL=I
                  Break
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Next I
Endif
#----- Chargement de la nouvelle ligne -----#
If GSERIALADC=""
  GNOLIG +=1
  nolign  =GNOLIG
  NOL     =nolign-1
  [M:PTH1]=[M:APR1]
  [M:PTH1]=[M:APR0]
  Default Mask [PTH1]
  If [F:ITM]ITMREF<>[M:PTH1]ITMREF(NOL)
    Read [ITM] ITM0=[M:PTH1]ITMREF(NOL)
    If fstat  Raz [F:ITM] : Endif
  Endif
  #----- Chargement de la ligne de réception -----#
  If [M:PTH1]POHNUM(NOL)<>""
    #----- Si réception issue d'une commande -----#
    If [F:POH]POHNUM<>[M:PTH1]POHNUM(NOL)
      Read [POH] POH0=[M:PTH1]POHNUM(NOL)
      If fstat  Raz [F:POH] : Endif
    Endif
    If [F:POQ]POHNUM<>[M:PTH1]POHNUM(NOL) |
&      [F:POQ]POPLIN<>[M:PTH1]POPLIN(NOL) |
&      [F:POQ]POQSEQ<>[M:PTH1]POQSEQ(NOL)
      Read [POQ] POQ0 = [M:PTH1]POHNUM(NOL);[M:PTH1]POPLIN(NOL);[M:PTH1]POQSEQ(NOL)
      If fstat  Raz [F:POQ] : Endif
    Endif
    Gosub DIVPTHLIG From SUBPTHB
    # Issue 92266 - 2013-09-09 by MUARN : landed cost
    If [M:PTH1]STCNUM(NOL)<>""
      [M:PTH1]WSTCUPD(NOL) = 2
    Endif
    If mkstat  GNOLIG-=1 : MA=1 : Gosub SETMASK From=WINPROG : Return : Endif
  Else
    #----- Si réception directe, chargement désignations article et pays d'origine -----#
    If [F:BPR]BPRNUM<>[M:PTH0]BPSNUM
      Read [BPR] BPR0=[M:PTH0]BPSNUM : If fstat  Raz [F:BPR] : [F:BPR]LAN=GLANGUE : Endif
    Endif
    #-----
    #Call CHARGE_ITMDES("DES1AXX",[F:BPR]LAN,[F:ITM]ITMREF,[M:PTH1]ITMDES(NOL)) From TRTX3
    #If [M:PTH1]ITMDES(NOL)="" [M:PTH1]ITMDES(NOL)=[F:ITM]ITMDES1 : Endif
    Call CHARGE_DEFITMDES("DES1AXX",[F:BPR]LAN,[F:ITM]ITMREF,[M:PTH1]ITMDES(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
    #[M:PTH1]ITMDES1(NOL)=[F:ITM]ITMDES1
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PTH1]ITMDES1(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
    #-----
    If [M:PTH1]ORICRY(NOL)=""
      [M:PTH1]ORICRY (NOL) = [F:BPR]CRY
    Endif
    #-----
    # Issue 110327 - 2017-06-02 by SR : Découpage SUBPTH pour permettre Backporting SAM 110327 (Séries)
    # CHARG_RCP_DIR déplacé dans SUBPTHD
    Gosub CHARG_RCP_DIR From SUBPTHD
    # Issue 92266 - 2013-09-09 by MUARN : landed cost
    If [M:PTH1]STCNUM(NOL)<>""
      [M:PTH1]WSTCUPD(NOL) = 2
    Endif
    If mkstat  GNOLIG-=1 : MA=1 : Gosub SETMASK From=WINPROG : Return : Endif
    Call AM_QTYUOM([M:PTH1]QTYUOM(NOL)) From SUBPTH
    If mkstat  GNOLIG-=1 : MA=1 : Gosub SETMASK From=WINPROG : Return : Endif
  Endif
  #-----
  MA=1 : Gosub SETMASK From=WINPROG

  # Issue 92137 - 2013-08-29 by MUARN : contrôle si UOM différent entre PTH1 et APR1
  # si différent faire REAJUST_TARIF
  SAV_QTYUOM = [M:PTH1]QTYUOM(NOL) : SAV_UOM = [M:PTH1]UOM(NOL) : SAV_UOMSTUCOE = [M:PTH1]UOMSTUCOE(NOL)
  SAV_QTYSTU = [M:PTH1]QTYSTU(NOL) # Issue 92266 - 2013-09-10 by MUARN : landed cost
  [M:PTH1]=[M:APR1]
  # Issue 98976 - 2014-04-15 by SR : zones perdues dans le DIVPTHLIG ou CHARG_RCP_DIR
  [M:ENTW]WZONPCU = "UOM"
  [M:ENTW]WZONQUC = "QTYUOM"
  [M:ENTW]WZONCCS = "UOMSTUCOE"
  [M:ENTW]WZONQUS = "QTYSTU"
  Gosub CONT_UNI_RCP From SUBPTHB
  # End issue 98976

  If SAV_UOM <> [M:PTH1]UOM(NOL)
    Call REAJUST_TARIF("PTH1",NOL,SAV_UOM,[M:PTH1]UOM(NOL),SAV_UOMSTUCOE,[M:PTH1]UOMSTUCOE(NOL)) From TRTACHPRI1
  Endif

  Gosub CAL_QTYPUU From SUBPTHB

  # Issue 92266 - 2013-09-10 by MUARN : landed cost - poids volume
  If SAV_QTYSTU <> [M:PTH1]QTYSTU(NOL)
    If !clalev([F:TUN])  Local File TABUNIT [TUN] : Endif
    If [F:TUN]UOM<>[M:PTH1]LINWEU(NOL)
      Read [TUN] TUN0=[M:PTH1]LINWEU(NOL) : If fstat Raz [F:TUN] : Endif
    Endif
    [M:PTH1]QTYWEU(NOL) = arr([M:PTH1]QTYWEU(NOL)*[M:PTH1]QTYSTU(NOL)/SAV_QTYSTU,10^-[F:TUN]UOMDEC)
    If [F:TUN]UOM<>[M:PTH1]LINVOU(NOL)
      Read [TUN] TUN0=[M:PTH1]LINVOU(NOL) : If fstat Raz [F:TUN] : Endif
    Endif
    [M:PTH1]QTYVOU(NOL) = arr([M:PTH1]QTYVOU(NOL)*[M:PTH1]QTYSTU(NOL)/SAV_QTYSTU,10^-[F:TUN]UOMDEC)
  Endif
  If [M:PTH2]DSPWEU <> [M:PTH1]LINWEU(NOL)
    Local Char ORI_WEU : ORI_WEU = [M:PTH1]LINWEU(NOL)
    [M:PTH1]LINWEU(NOL) = [M:PTH2]DSPWEU
    Call PCAL_QTY([M:PTH1]QTYWEU(NOL), ORI_WEU, [M:PTH1]QTYWEU(NOL), [M:PTH1]LINWEU(NOL),
&                   [M:PTH1]ITMREF(NOL), [M:PTH0]BPSNUM, 1,GBIDD2) From TRTACHQTE1
  Endif
  If [M:PTH2]DSPVOU <> [M:PTH1]LINVOU(NOL)
    Local Char ORI_VOU : ORI_VOU = [M:PTH1]LINVOU(NOL)
    [M:PTH1]LINVOU(NOL) = [M:PTH2]DSPVOU
    Call PCAL_QTY([M:PTH1]QTYVOU(NOL), ORI_VOU, [M:PTH1]QTYVOU(NOL), [M:PTH1]LINVOU(NOL),
&                   [M:PTH1]ITMREF(NOL), [M:PTH0]BPSNUM, 1,GBIDD2) From TRTACHQTE1
  Endif
  # Issue 88805 - 2013-03-25 by SR
  #----- Calcul du montant ligne -----#
  [M:PTH1]LINAMT(NOL)=[M:PTH1]NETPRI(NOL)*[M:PTH1]QTYUOM(NOL)
  Call ARRDEV([M:PTH1]LINAMT(NOL),[M:PTH1]NETCUR(NOL)) From TRTDIV
  #-----
  For WI=1 To GNBDIE
    If evalue("[M:PTH1]CCE"+num$(WI)+"(NOL)")=""
      Call INISEC(WSECTION,"PTD",WI) From TRTX3CPT
      Assign "[M:PTH1]CCE"+num$(WI)+"(NOL)" With WSECTION
    Endif
  Next WI
  #-----
  If NOL=0
     [M:PTH1]PTDLIN(NOL)=1000
  Else
     [M:PTH1]PTDLIN(NOL)=[M:PTH1]PTDLIN(NOL-1)+1000
  Endif
 #Call APRES_NBLIG From SUBPTH
Endif
#-----
Raz GOUVENT
If [F:ITM]STOMGTCOD>1
  Call OUVENT([M:PTH0]PRHFCY,"PTH1",3,[M:PTH0]TRSCOD,"",6,
&             [M:PTH0]RCPDAT,NOL,[M:PTH1]NBLIG,"PTR","",WRET) From STKENT
Endif
If GOUVENT>1 & GSERIALADC=""
  GNOLIG-=1
Else
  Raz LECCMAJ, LECCMIN
  If dim([M:PTH1]ECCVALMAJ)>0
      [L]LECCMAJ = string$([M:PTH1]ECCVALMAJ(NOL)<>"$",[M:PTH1]ECCVALMAJ(NOL))
      [L]LECCMIN = string$([M:PTH1]ECCVALMIN(NOL)<>"$",[M:PTH1]ECCVALMIN(NOL))
  Endif
  If [M:PTH1]CPR(NOL)=0
    Call DEFPRI([M:PTH1]ITMREF(NOL),LECCMAJ,LECCMIN,[M:PTH0]PRHFCY,3,[M:PTH0]TRSCOD,
&               "","",[M:PTH0]RCPDAT,[M:PTH1]QTYSTU(NOL),[M:PTH1]QTYSTU(NOL),0,
&               GBIDI1,[M:PTH1]CPR(NOL),GBIDI2) From STKVAL
  Endif
# Issue 114047 - 2016-03-07 by CCC : not necessary because will be done in SUBPTHA
#  Call SETNEWPRIOVE([M:PTH1]ITMREF(NOL),LECCMAJ,LECCMIN,[M:PTH0]PRHFCY,[M:PTH0]RCPDAT,
#&                   [M:PTH1]WSTOSEQ(NOL),[M:PTH1]CPR(NOL),1,[M:PTH1]QTYSTU(NOL),
#&                   "", GBIDI2) From STKVAL
  status=0 : Call APRES_NBLIG From SUBPTH
  If mkstat  GNOLIG-=1 : MA=1 : Gosub SETMASK From=WINPROG : Return : Endif
  # Ne pas incrémenter le nb ligne si le no série est sur une ligne existante
  If GSERIALADC="" [M:PTH1]NBLIG+=1 Endif
Endif
#----- Tenir compte du service et des matières fournies si nécessaire -----#
If [M:PTH1]NBCRELIG>0
  [M:PTH1]NBLIG+=[M:PTH1]NBCRELIG
  Raz [M:PTH1]NBCRELIG
  #----- Recalcul des quantités des composants si nécessaire (réception partielle) -----#
  If [M:PTH1]LINTYP(NOL)=2
    Call CALCUL_COMPOSANTS(NOL) From SUBPTHD
  Endif
  #-----
Endif
#-----
Return


########################################################
Subprog CRE_PTH
Local Char ABREV(10)
ABREV="PTH"
Gosub DEFVAR From GOBJET
GREP       ="C"
REP        ="C"
GOBJET     = 1
GORITITCOL = 0
GABREV     = ABREV
GPROGRAMME = "GOBJSUB"
GTRAITE    = "GOBJET"
Call NOMTRTWIN("O"+ABREV,WINPROG) From MSKDIV
Gosub DEFVAR From =WINPROG
Gosub DECL_VAR_LOCAL From SUBPTHA
Gosub CREATION From GOBJET1
Raz GTRAVT
End


########################################################
$FIN_PTH
Call DELSTOENTW(-1,-1,"PTH1",1,1,[M:PTH0]PRHFCY,1,"") From STKENT
Kill GSERIALADC, GSERIALADCF
Kill GQTYPCUADC, GQTYSTUADC, GPCUSTUADC
Kill GTRAVT
Return


########################################################
$AM_POHNUM_PTH
If VALEUR<>""
  Read [POH] POH0=VALEUR
  If fstat
    #----- Commande introuvable ! -----#
    Call ERREUR(mess(359,197,1)) From GESECRAN : mkstat=1 : Return
  Else
    #----- Ce n'est pas une commande du fournisseur -----#
    If [M:PTH0]BPSNUM<>"" & [F:POH]BPSNUM<>[M:PTH0]BPSNUM
      Call ERREUR(mess(35,7750,1)-[M:PTH0]BPSNUM) From GESECRAN : mkstat=1 : Return
    #----- Commande soldée ! -----#
    Elsif [F:POH]CLEFLG=2
      Call ERREUR(mess(369,194,1))  From GESECRAN : mkstat=1 : Return
    #----- Commande non signée ou déjà réceptionnée. -----#
    # Issue 100084 - 2014-05-16 by MUARN : ajout GPOHCLE
    Elsif [F:POH]APPFLG<3 | ( [F:POH]RCPFLG>2 & GPOHCLE<>3 )
      Call ERREUR(mess(101,194,1)) From GESECRAN : mkstat=1 : Return
    Endif
  Endif
  #-----
  If !clalev([F:POQ2]) Local File PORDERQ   [POQ2] : Endif
  Link [POQ2] With [ITM] ITM0=[POQ2]ITMREF As [POQX]
  Local Char WCRITERE(240)
  WCRITERE ="[F:POQ2]POHNUM=VALEUR&[F:POQ2]PRHFCY=[M:APR1]PRHFCY&[F:POQ2]ORI<>2"
  # Issue 112754 - 2016-11-28 by SR : Services
  #WCRITERE+="&[F:POQ2]WIPSTA<2&[F:POQ2]LINCLEFLG<>2&[F:ITM]ITMSTA=1"
  WCRITERE+="&[F:POQ2]WIPSTA<2&[F:POQ2]LINCLEFLG<>2&[F:POQ2]ITMKND<>2&[F:ITM]ITMSTA=1"
  #--- Bug 74376
  #WCRITERE+="&[F:ITM]MFGFLG<>2&[F:ITM]SCSFLG<>2&[F:ITM]PHAFLG<>2&[F:ITM]RCPFLG=2"
  # Issue 112754 - 2016-11-28 by SR : services
  #WCRITERE+="&[F:ITM]SCSFLG<>2&[F:ITM]PHAFLG<>2&[F:ITM]RCPFLG=2"
  WCRITERE+="&[F:ITM]PHAFLG<>2&[F:ITM]RCPFLG=2"
  #-----
  Filter [POQX] Where evalue (WCRITERE)
  Read [POQX] POQ0 First
  Filter [POQX]
  If fstat
    Call ERREUR(mess(36,7750,1)-[M:APR1]PRHFCY) From GESECRAN : mkstat=1 : Return
  Endif
  #-----
  If [M:PTH0]BPSNUM=""
    #TESTMAE [M]BPSNUM=[F:POH]BPSNUM : Affzo BPSNUM
    [M:APR1]BPSNUM=[F:POH]BPSNUM : Affzo [M:APR1]BPSNUM
  Endif
  Actzo [M:APR1]POPLIN
  Diszo [M:APR1]BPSNUM
Else
  Diszo [M:APR1]POPLIN
  If [M:PTH0]BPSNUM=""
    Actzo [M:APR1]BPSNUM : Effzo [M:APR1]BPSNUM
  Endif
Endif
Effzo [M:APR1]ITMREF,POPLIN,POQSEQ,UOM,QTYUOM,STA,LOC,LOT,SLO,BPSLOT,SERNUM,WSOLDE
# Issue 117340 - 2016-06-27 by SR : Geston des numéros de séries en Inter site
Effzo [M:APR1]SDHNUM,SDDLIN
Return


########################################################
$AS_ITMREF_PTH
Raz [F:POQ]
Return


########################################################
$AM_ITMREF_PTH
If [F:POQ]POHNUM<>""
Affzo [M:APR0]POHNUM
Affzo[M:APR1]POPLIN, BPSNUM : Endif
#-----
If [F:ITM]ITMREF<>VALEUR
  Read [ITM] ITM0=VALEUR
  If fstat
    Call ERREUR(mess(212,199,1)) From GESECRAN : mkstat=1 : Return
  Endif
Endif
#-----
If [F:ITM]ITMSTA<>1
  Call ERREUR([F:ITM]ITMREF-":"-mess(258,199,1)) From GESECRAN : mkstat=1 : Return
# Issue 112754 - 2016-11-28 by SR : Services
#Elsif [F:ITM]SCSFLG=2
#  Call ERREUR([F:ITM]ITMREF-":"-mess(164,199,1)) From GESECRAN : mkstat=1 : Return
Elsif [M:PTH0]BETFCY<>2 & [F:ITM]MFGFLG = 2 & [F:ITM]PHAFLG = 2
  Call ERREUR([F:ITM]ITMREF-":"-mess(70,197,1))  From GESECRAN : mkstat=1 : Return
Elsif [F:ITM]RCPFLG<>2
  Call ERREUR([F:ITM]ITMREF-":"-mess(99,194,1))  From GESECRAN : mkstat=1 : Return
Endif
#-----
Local Char    WCRITERE(100)
Local Integer WCTEUR
Local Decimal WQTYSTUMAX
#-----
If [F:POQ]POHNUM=""
  If [M:APR0]POHNUM<>""
    # Issue 112754 - 2016-11-28 by SR : Services
    WCRITERE="POHNUM=[M:APR0]POHNUM&ITMREF=VALEUR&PRHFCY=[M:APR1]PRHFCY&ORI<>2&WIPSTA<2&LINCLEFLG<>2&ITMKND<>2"
    Filter [POQ] Where evalue (WCRITERE)
    Read [POQ] POQ0 First
    Filter [POQ]
    If fstat
      Call ERREUR(mess(34,7750,1)) From GESECRAN : mkstat=1 : Return
    Endif
    [M:APR1]PRHFCY=[F:POQ]PRHFCY
    [M:APR0]POHNUM=[F:POQ]POHNUM
    [M:APR1]POPLIN=[F:POQ]POPLIN
    [M:APR1]POQSEQ=[F:POQ]POQSEQ
    [M:APR1]BPSNUM=[F:POQ]BPSNUM
#                                                          # hcb 71276 deb
    If dim([M:APR1]ECCVALMAJORI)>0
       [M:APR1]ECCVALMAJORI  = [F:POQ]ECCVALMAJ   # version majeure origine
       [M:APR1]ECCVALMINORI  = [F:POQ]ECCVALMIN   # version mineure origine
    Endif
#                                                          # hcb 71276 fin

    Actzo [M:APR1]POPLIN
    Affzo [M:APR0]POHNUM
    Affzo [M:APR1]POPLIN, BPSNUM
  Else
    Raz [M:APR1]POPLIN, [M:APR1]POQSEQ
    Diszo [M:APR1]POPLIN
    Affzo [M:APR1]POPLIN
  Endif
Endif
#-----
If [M:APR0]POHNUM<>""
  [M:APR1]UOM      =[F:POQ]UOM
  [M:APR1]UOMSTUCOE=arr([F:POQ]QTYSTU/[F:POQ]QTYUOM,0.00000001)
  #----- Calcul de la quantité restante à réceptionner -----#
  Gosub CAL_QTYSTUMAX
  [M:APR1]QTYSTU=WQTYSTUMAX
  [M:APR1]QTYUOM = [M:APR1]QTYSTU/[M:APR1]UOMSTUCOE
  [M:APR1]WSOLDE = 2
  Actzo [M:APR1]WSOLDE
  #----- Si une seule ligne de commande possible, griser le champ ligne -----#
  WCRITERE="POHNUM=[M:APR0]POHNUM & ITMREF=VALEUR & PRHFCY=[M:APR1]PRHFCY & ORI<>2 & WIPSTA<2 & LINCLEFLG<>2"
  Raz WCTEUR
  For [POQ] POQ0 Where evalue (WCRITERE)
    WCTEUR+=1
    If WCTEUR>1  Break : Endif
  Next
    # Issue 102135 - 2014-08-19 by SR : si une seule ligne contrôler ici le type de ligne
  If WCTEUR<2
     If [F:POQ]LINTYP<>1
         Call ERREUR([F:ITM]ITMREF-":"-mess(42,7750,1)) From GESECRAN
         Raz [F:POQ]POHNUM
         mkstat=1
         Return
     Endif
     # Issue 117340 - 2016-06-27 by SR : Gestion des numéros de série en Inter site
     # Issue 119627 - 2016-11-09 by MUARN : que en inter-site
     If [F:POQ]LINOCNNUM <> "" & [F:POH]BETFCY = 2
       Read [F:SOQ]SOQ0 = [F:POQ]LINOCNNUM;[F:POQ]OCNLIN;[F:POQ]OCNSEQ
       If !fstat & [F:SOQ]SDHNUM <> ""
        [M:APR1]SDHNUM = [F:SOQ]SDHNUM
        [M:APR1]SDDLIN = [F:SOQ]SDDLIN
       Else
        GMESSAGE = mess(62,192,1) # Livraison non crée\Il n'y a rien à traiter !
        mkstat = 1
        Return
       Endif
     Endif
     # End issue 117340
     Diszo POPLIN
  Endif
  #-----
  Diszo BPSNUM
Else
  #----- Réception directe interdite -----#
  If GPTHDIR<>2
    Call ERREUR(mess(247,194,1)) From GESECRAN : mkstat=1 : Return
  Endif
  #-----
  [M:APR1]UOM      =[F:ITM]PUU
  [M:APR1]UOMSTUCOE=[F:ITM]PUUSTUCOE
  If [M:APR1]BPSNUM<>""
    If !clalev([F:ITP])  Local File ITMBPS [ITP] : Endif
    Read [ITP] ITP0=VALEUR;[M:APR1]BPSNUM
    If !fstat
      [M:APR1]UOM      =[F:ITP]PUU
      [M:APR1]UOMSTUCOE=[F:ITP]PUUSTUCOE
    Else
      Raz [F:ITP]
    Endif
  Endif
  [M:APR1]QTYSTU=0
  [M:APR1]QTYUOM=0
  [M:APR1]WSOLDE=1
  If [M:PTH0]BPSNUM=""  Actzo [M:APR1]BPSNUM : Endif
  Diszo [M:APR1]WSOLDE
Endif
#-----
[M:APR1]TCLCOD=[F:ITM]TCLCOD
[M:APR1]STU   =[F:ITM]STU
#-----
Call INIZONENT(VALEUR,"APR1",[M:APR1]PRHFCY,[M:APR1]BPSNUM,1,"U",0,3,[F:PTR]TRSCOD,"",3,1) From STKECR
If mkstat  Return : Endif
#-----
Affzo 1-99
Return


########################################################
$AM_POPLIN_PTH
#-----
If [M:APR0]POHNUM="" & VALEUR=0  Return : Endif
#----- Contrôle si no de ligne valide -----#
Filter [POQ] Where POHNUM=[M:APR0]POHNUM
&                & POPLIN=VALEUR
&                & ITMREF=[M:APR1]ITMREF & ORI<>2 & WIPSTA<2 & LINCLEFLG<>2
Read [POQ] POQ0 First
Filter [POQ]
If fstat
  Raz [F:POQ] : GMESSAGE=mess(83,123,1) : mkstat=1 : Return
Endif
# Issue 102135 - 2014-08-19 by SR : Ligne sous-traitance interdite
If [F:POQ]LINTYP<>1
   Call ERREUR([F:ITM]ITMREF-":"-mess(42,7750,1)) From GESECRAN : mkstat=1 : Return
Endif
#-----
[M:APR1]POPLIN   =[F:POQ]POPLIN
[M:APR1]POQSEQ   =[F:POQ]POQSEQ
[M:APR1]UOM      =[F:POQ]UOM
[M:APR1]UOMSTUCOE=arr([F:POQ]QTYSTU/[F:POQ]QTYUOM,0.00000001)
#                                                          # hcb 71276 deb
If dim([M:APR1]ECCVALMAJORI)>0
   [M:APR1]ECCVALMAJORI  = [F:POQ]ECCVALMAJ   # version majeure origine
   [M:APR1]ECCVALMINORI  = [F:POQ]ECCVALMIN   # version mineure origine
Endif
#                                                          # hcb 71276 fin
# Issue 117340 - 2016-06-27 by SR : Gestion des numéros de série en Inter site
# Issue 119627 - 2016-11-09 by MUARN : que en inter-site
If [F:POQ]LINOCNNUM <> "" & [F:POH]BETFCY = 2
 Read [F:SOQ]SOQ0 = [F:POQ]LINOCNNUM;[F:POQ]OCNLIN;[F:POQ]OCNSEQ
 If !fstat & [F:SOQ]SDHNUM <> ""
  [M:APR1]SDHNUM = [F:SOQ]SDHNUM
  [M:APR1]SDDLIN = [F:SOQ]SDDLIN
 Else
  GMESSAGE = mess(62,192,1) # Livraison non crée\Il n'y a rien à traiter !
  mkstat = 1
  Return
 Endif
Endif
 # End issue 117340
#----- Calcul de la quantité restante à réceptionner -----#
Gosub CAL_QTYSTUMAX
[M:APR1]QTYSTU=WQTYSTUMAX
[M:APR1]QTYUOM=[M:APR1]QTYSTU/[M:APR1]UOMSTUCOE
[M:APR1]WSOLDE=2
Affzo [M:APR1]QTYUOM, UOM, WSOLDE
Return


########################################################
$AM_BPSNUM_PTH
If [F:BPS]BPSNUM<>VALEUR
  Read [BPS] BPS0=VALEUR
  If fstat
    Call ERREUR(mess(136,100,1)) From GESECRAN : mkstat=1 : Return
  Endif
Endif
If [M:APR0]POHNUM=""
  If !clalev([F:ITP])  Local File ITMBPS [ITP] : Endif
  Read [ITP] ITP0=[M:APR1]ITMREF;VALEUR
  If !fstat
#                                                          # hcb 71276 deb
     If [F:ITM]ECCSTO > 1 & [F:ITP]LOAECCFLG <> 2
        mkstat = 2
        GMESSAGE = mess(429,184,1) #  En VT un aticle géré en version sans préchargement est interdit !
        Return
     Endif
#                                                          # hcb 71276 fin
    [M:APR1]UOM      =[F:ITP]PUU
    [M:APR1]UOMSTUCOE=[F:ITP]PUUSTUCOE
    Affzo [M:APR1]UOM
  Else
    Raz [F:ITP]
#                                                          # hcb 71276 deb
     If [F:ITM]ECCSTO > 1 & [F:ITM]LOAECCFLG <> 2
         mkstat = 2
         GMESSAGE = mess(429,184,1) #  En VT un aticle géré en version sans préchargement est interdit !
         Return
     Endif
#                                                          # hcb 71276 fin

  Endif
Endif
#-----
Return


########################################################
$AM_UOM_PTH
#-----
Local Char    LUSCAV
Local Char    LFMT
Local Integer LMODIF
#-----
Call CTLUOM([M:APR1]ITMREF,3,[M:APR1]BPSNUM,VALEUR,[M:APR1]UOMSTUCOE,LUSCAV,LFMT,LMODIF) From STKACT
If !find(LUSCAV,"S","C","A","AF","CF")
  mkstat=2 : Return
Endif
#--- Bug 81386
#Call QTEARR([M:APR1]QTYUOM,VALEUR) From TRTDIV
#[M:APR1]QTYSTU = [M:APR1]QTYUOM*[M:APR1]UOMSTUCOE
#Call QTEARR([M:APR1]QTYSTU,[F:ITM]STU) From TRTDIV
If [M:APR1]UOMSTUCOE=0 [M:APR1]UOMSTUCOE=1 Endif
[M:APR1]QTYUOM = [M:APR1]QTYSTU/[M:APR1]UOMSTUCOE
Call QTEARR([M:APR1]QTYUOM,VALEUR) From TRTDIV
#---
Return

########################################################
$AM_QTYUOM_PTH
If VALEUR<0 : mkstat=1 : Return : Endif
If VALEUR=0
   Call ERREUR(mess(472,182,1)) From GESECRAN : mkstat=2 : Return
Endif
#-----
Local Decimal WQTYSTU
Local Integer WOK
#-----
WQTYSTU=VALEUR*[M:APR1]UOMSTUCOE
Call QTEARR(WQTYSTU,[F:ITM]STU) From TRTDIV
#----- Cheik for overreceipt, use the stock UOM as a baseline for all comparisons -----#
If [M:APR0]POHNUM<>""
  Gosub CAL_QTYSTUMAX
  If WQTYSTU>WQTYSTUMAX
    If GRCPORD=2
      Call OUINON(mess(200,194,1),WOK) From GESECRAN
      If WOK<>2  mkstat=1 : Return : Endif
    Else
      Call ERREUR(mess(229,194,1)) From GESECRAN : mkstat=1 : Return
    Endif
  Endif
  #-----
  #If WQTYSTU<WQTYSTUMAX
  #  [M:APR1]WSOLDE=1
  #Else
  #  [M:APR1]WSOLDE=2
  #Endif
  #----------------------------------------------------------#
  # GPOHCLE=1 Si égalité ou supérieur                        #
  # GPOHCLE=2 A la demande                                   #
  # GPOHCLE=3 Jamais                                         #
  # GPOHCLE=4 Suivant tolérance                              #
  # GPOHCLE=5 Tolérance + reste à la demande                 #
  #----------------------------------------------------------#
  [M:APR1]WSOLDE=1 : # GPOHCLE=3 Jamais
  If GPOHCLE=1 | GPOHCLE=2    : # Solde si égalité ou supérieur ou à la demande
    If WQTYSTU>=WQTYSTUMAX  [M:APR1]WSOLDE=2 : Endif
  Elsif GPOHCLE=4 | GPOHCLE=5 : # Solde suivant % tolérance + reste à la demande
    If [F:ITM]ITMREF<>[M:APR1]ITMREF
      Read [ITM] ITM0=[M:APR1]ITMREF : If fstat  Raz [F:ITM] : Endif
    Endif
    GBIDD1=WQTYSTUMAX-WQTYSTU
    If GBIDD1<=0 | abs((GBIDD1/WQTYSTUMAX)*100)<=[F:ITM]MINRMNPRC
      [M:APR1]WSOLDE=2
    Endif
  Endif
  #-----
  Affzo [M:APR1]WSOLDE
Endif
#-----
[M:APR1]QTYSTU=WQTYSTU
#-----
Return


########################################################
$C_SLO_PTH
If VALEUR<>""
  Call STKCTRSLO(VALEUR,1,[M:APR1]LOT,[M:APR1]ITMREF,[M:APR1]BPSLOT,[M:APR1]GESLOT,"",
&                0,0,0,[M:APR1]PRHFCY,[M:APR1]SLOF) From STKACT
Endif
Return


########################################################
$CAL_QTYSTUMAX
If dim(WQTYSTUMAX)<1  Local Decimal WQTYSTUMAX : Endif
#-----
If [F:POQ]POHNUM<>[M:APR0]POHNUM | [F:POQ]POPLIN<>[M:APR1]POPLIN | [F:POQ]POQSEQ<>[M:APR1]POQSEQ
  Read [POQ] POQ0=[M:APR0]POHNUM;[M:APR1]POPLIN;[M:APR1]POQSEQ
  If fstat  Raz [F:POQ] : Endif
Endif
#----- Calcul de la quantité restante à réceptionner -----#
WQTYSTUMAX=[F:POQ]QTYSTU-[F:POQ]RCPQTYSTU
If [M:PTH1]NBLIG>0
  If dim(I)<1  Local Integer I : Endif
  WQTYSTUMAX-=sigma(I=0,[M:PTH1]NBLIG-1,[M:PTH1]QTYSTU(I)*([M:PTH1]POHNUM(I)=[F:POQ]POHNUM &
&                                                          [M:PTH1]POPLIN(I)=[F:POQ]POPLIN &
&                                                          [M:PTH1]POQSEQ(I)=[F:POQ]POQSEQ &
&                                                          [M:PTH1]CREFLG(I)=0))
Endif
If WQTYSTUMAX<0  Raz WQTYSTUMAX : Endif
Return



########################################################
# Production tracking
########################################################
#
# Necessary field in the VT Screen
# --------------------------------
# MFGNUM, MFGLIN, ITMREF, UOM, UOMCPLQTY, STU, CPLQTY, UOMSTUCOE,
# STA, LOC, LOCTYP, LOT, SLO, SLOF, GESLOT, WCLOSE, CLEFLG, FCY,IPTDAT,PALNUM,
# CTRNUM, SERNUM, SERNUMF, TCLCOD, WSTOSEQ, WLOCSEQ
#
# Necessary value in Entry transaction
# ------------------------------------
# Block 'Lot': all field --> No
#
#
########################################################


########################################################
$OUVRE_MBI
If !clalev([M:MBI])  Local Mask MTKBENCHI    [MBI] : Endif

Local Char LORI : LORI=""

Gosub OUVRE_INIT   From FUNBENCHI
Return


########################################################
$DEBUT_MBI
Global Char     GSERIALADC(GLONSER), GSERIALADCF(GLONSER)
Global Decimal  GQTYPCUADC, GQTYSTUADC, GPCUSTUADC
Global Integer  GNOLIG
Local  Shortint WRET
Local  Integer  NOL
GNOLIG=0
Return


########################################################
$RAZ_MBI
Raz [M:MBI]
[M:MBI]FCY = GXAFCY
Call AM_FCY([M:MBI]FCY) From FUNBENCHI
[M:MBI]TRSCOD = [F:BTS]TRSCOD
Return


########################################################
$OK_MBI
Local  Shortint WRET

# Pour interdire la navigation
GREP="C"
FIN = 0
#-----
Raz GSERIALADC, GSERIALADCF
Raz GQTYPCUADC, GQTYSTUADC, GPCUSTUADC
#----- Si no série -----#
If find([F:ITM]SERMGTCOD,2,3) & [M]SERNUM<>""
  For I=0 To [M:MBI]NBLIG-1
    If [M]MFGNUM=[M:MBI]MFGNUM(I) & [M]MFGLIN=[M:MBI]MFGLIN(I)
      If [M]ITMREF=[M:MBI]ITMREF(I) & [M]STA=[M:MBI]STA(I) & [M]UOM=[M:MBI]UOM(I) & [M]UOMSTUCOE=[M:MBI]UOMSTUCOE(I)
        If dim([M:MBI]LOT)<=0 | (dim([M:MBI]LOT)>0 & [M]LOT=[M:MBI]LOT(I))
          If dim([M:MBI]SLO)<=0 | (dim([M:MBI]SLO)>0 & [M]SLO=[M:MBI]SLO(I))
            If dim([M:MBI]LOC)<=0 | (dim([M:MBI]LOC)>0 & [M]LOC=[M:MBI]LOC(I))
              If dim([M:MBI]PALNUM)<=0 | (dim([M:MBI]PALNUM)>0 & [M]PALNUM=[M:MBI]PALNUM(I))
                If dim([M:MBI]CTRNUM)<=0 | (dim([M:MBI]CTRNUM)>0 & [M]CTRNUM=[M:MBI]CTRNUM(I))
                  #----- Regroupement lignes identiques -----#
                  [M:MBI]CPLQTY(I)+=[M]CPLQTY
                  [M:MBI]UOMCPLQTY(I)+=[M]UOMCPLQTY
                  GSERIALADC =[M]SERNUM
                  GSERIALADCF=[M]SERNUMF
                  GQTYPCUADC =[M]UOMCPLQTY
                  GQTYSTUADC =[M]CPLQTY
                  GPCUSTUADC =[M]UOMSTUCOE
                  NOL=I
                  Break
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Next I
Endif
#----- Chargement de la nouvelle ligne -----#
If GSERIALADC=""
  GNOLIG +=1
  nolign  =GNOLIG
  NOL     =nolign-1
  #[M:MBI] = [F:MFI]  # FQ 66476 déplacé après la lecture ?
  [M:MBI]=[M]
  #----- Chargement de la ligne de production -----#
  If [F:MFG]MFGNUM<>[M:MBI]MFGNUM(NOL)
    Read [MFG] MFG0=[M:MBI]MFGNUM(NOL)
    If fstat  Raz [F:MFG] : Endif
  Endif
  If [F:MFI]MFGNUM<>[M:MBI]MFGNUM(NOL) |
&    [F:MFI]MFGLIN<>[M:MBI]MFGLIN(NOL)
     Read [MFI] MFI0 = [M:MBI]MFGNUM(NOL);[M:MBI]MFGLIN(NOL)
     If fstat  Raz [F:MFI] : Endif
  Endif
# FQ 66476 GA 08/2010 Mode VT est-ce que MFGLIN est ok ?
  If [F:MFI]MFGNUM<>[M:MBI]MFGNUM(NOL) |
&    [F:MFI]ITMREF<>[M:MBI]ITMREF(NOL)
     Filter [MFI] Where MFGNUM=[M:MBI]MFGNUM(NOL) and ITMREF=[M:MBI]ITMREF(NOL)
     Read [MFI] First
     If fstat  Raz [F:MFI] : Endif
     Filter [MFI]
  Endif
  If [F:ITM]ITMREF<>[M:MBI]ITMREF(NOL)
    Read [ITM] ITM0=[M:MBI]ITMREF(NOL)
    If fstat  Raz [F:ITM] : Endif
  Endif
  [M:MBI]PRODTYP(NOL) = 1
  [M:MBI] = [F:MFI]  # FQ 66476 déplacé après la lecture
  [M:MBI] = [M]
  Gosub CHARG_ANA_MBI
  [M:MBI]NBLIG+=1
  If NOL=0
     [M:MBI]WLINUM(NOL)=1000
  Else
     [M:MBI]WLINUM(NOL)=[M:MBI]WLINUM(NOL-1)+1000
  Endif
Endif
#-----
Call OUVENT([M:MBI]FCY,"MBI",5,[M:MBI]TRSCOD,"",15,
&           [M:MBI]IPTDAT(NOL),NOL,[M:MBI]NBLIG,"BTS","",WRET) From STKENT
If GOUVENT>1 & GSERIALADC=""
  GNOLIG-=1
  [M:MBI]NBLIG-=1
Endif
GREP=""
Return

########################################################
$CHARG_ANA_MBI
Local Integer I,J
Local Char    WCCE(15)
#Chargement des sections ana
Call CHARG_ACCCCE(nolign-1,"","","[M:MBI]CCE",
&                    "MFI",0,[F:MFI]MFGNUM,[F:MFI]MFGLIN,0,"") From TRTX3CPT
For J = 1 To GNBDIE
    If evalue ("[M:MBI]CCE"+num$(J)+"(nolign-1)")=""
        Call INISEC(WCCE,"MKIB", J) From TRTX3CPT
        Assign "[M:MBI]CCE"+num$(J)+"(nolign-1)" With WCCE
    Endif
Next
Return

########################################################
$CRE_MBI
Local Integer LRETOK
Gosub VALIDATION From FUNBENCHI
GPROGRAMME = "GSAISIE"
GNOLIG = 0
Return


########################################################
$FIN_MBI
Call DELSTOENTW(-1,-1,"MBI",1,1,[M:MBI]FCY,1,"") From STKENT
Kill GSERIALADC, GSERIALADCF
Kill GQTYPCUADC, GQTYSTUADC, GPCUSTUADC
Return


########################################################
$C_MFGNUM_MBI
If VALEUR<>""
  Read [MFG] MFG0=VALEUR
  If fstat | [F:MFG]MFGFCY <> GXAFCY
     GMESSAGE = mess(23,100,1) : mkstat=1 : Return
  Endif
  Call C_MFGNUM(VALEUR) From FUNBENCHI
Endif
Return


########################################################
$AS_ITMREF_MBI
Raz [F:MFI]
Raz [M]MFGLIN
Return


########################################################
$C_ITMREF_MBI
Local Integer I
Read [ITM] ITM0=VALEUR
If fstat
   GMESSAGE = mess(212,199,1) : mkstat=2 : Return : # Article inexistant
Endif

##Si on n' a pas utilise la selection
If [F:MFI]MFGNUM="" : # cnd remise par GH 04/12/2013 bug 90177 : # cnd supprimée par CCC Issue 66849 - 2010-09-06
    Filter [MFI] Where MFGNUM=[M]MFGNUM & ITMREF=VALEUR & ITMSTA<>4
    Read [MFI] MFI0 First
    Filter [MFI]
Else
    Read [MFI]MFI0 = [M]MFGNUM;[M]MFGLIN
Endif
If fstat
   GMESSAGE = mess(23,100,1) : mkstat=1 : Return : # Fiche inexistante
Endif

If [F:MFI]LOT <> "" : [M]LOT = [F:MFI]LOT : Endif
[M]MFGLIN    = [F:MFI]MFGLIN
[M]TCLCOD    = [F:ITM]TCLCOD
[M]STU       = [F:ITM]STU
[M]UOM       = [F:MFI]UOM
[M]UOMSTUCOE = [F:MFI]UOMSTUCOE
#----- Calcul de la quantité restante à produire -----#
[M]CPLQTY=[F:MFI]EXTQTY-[F:MFI]CPLQTY
[M]CPLQTY-=sigma(I=0,[M:MBI]NBLIG-1,[M:MBI]CPLQTY(I)*([M:MBI]MFGNUM(I)=[F:MFI]MFGNUM &
&                                                     [M:MBI]MFGLIN(I)=[F:MFI]MFGLIN))
If [M]CPLQTY<0 : Raz [M]CPLQTY : Endif
[M]UOMCPLQTY = [M]CPLQTY/[M]UOMSTUCOE
[M]CLEFLG = 2
Return


########################################################
$AM_UOM_MBI
Call CTLUOM([M]ITMREF,5,"",VALEUR,[M]UOMSTUCOE,LUSCAV,LFMT,LMODIF) From STKACT
If LUSCAV<>"S"
  If LUSCAV<>"C"
    mkstat=2 : Return
  Endif
Endif
Call QTEARR([M]UOMCPLQTY,VALEUR) From TRTDIV
[M]CPLQTY = [M]UOMCPLQTY*[M]UOMSTUCOE
Call QTEARR([M]CPLQTY,[F:ITM]STU) From TRTDIV
Return


########################################################
$AM_UOMCPLQTY_MBI
If VALEUR<=0 : mkstat=2 : Return : Endif
If VALEUR < [M]CPLQTY : [M]CLEFLG = 1 : Else [M]CLEFLG = 2 : Endif
[M]CPLQTY= VALEUR*[M]UOMSTUCOE
Call QTEARR([M]CPLQTY,[F:ITM]STU) From TRTDIV
Return


########################################################
$C_SLO_MBI
Local Char WBPSLOT
If VALEUR<>""
  Call STKCTRSLO(VALEUR,1,[M]LOT,[M]ITMREF,WBPSLOT,[M]GESLOT,"",
&                0,0,0,[M]FCY,[M]SLOF) From STKACT
Endif
Return



########################################################
# Material consumption tracking
########################################################
#
# Necessary field in the VT Screen
# --------------------------------
# MFGNUM, MFGLIN, BOMSEQ, ITMREF, STU, USEQTY,
# STA, LOC, LOCTYP, LOT, SLO,  WCLOSE, CLEFLG, FCY,IPTDAT,PALNUM,
# CTRNUM, SERNUM, SERNUMF, TCLCOD, WSTOSEQ
#
# Necessary value in Entry transaction
# ------------------------------------
# Field 'Automatic determination' --> No
#
#
########################################################


########################################################
$OUVRE_MBM
If !clalev([M:MBM])  Local Mask MTKBENCHM    [MBM] : Endif

Local Char LORI : LORI=""

Gosub OUVRE_INIT   From FUNBENCHM
Return


########################################################
$DEBUT_MBM
Global Char     GSERIALADC(GLONSER), GSERIALADCF(GLONSER)
Global Decimal  GQTYPCUADC, GQTYSTUADC, GPCUSTUADC
Global Integer  GNOLIG
Local  Integer  NOL, WAUTO, WRET
GNOLIG=0
Return


########################################################
$RAZ_MBM
Raz [M:MBM]
[M:MBM]FCY = GXAFCY
Call AM_FCY([M:MBM]FCY) From FUNBENCHM
[M:MBM]TRSCODS = [F:BTS]TRSCODS
Return


########################################################
$OK_MBM
Local Integer OK
Local Integer WRET
# Pour interdire la navigation
GREP="C"
FIN = 0
#-----
Raz GSERIALADC, GSERIALADCF
Raz GQTYPCUADC, GQTYSTUADC, GPCUSTUADC
#----- Si no série -----#
If find([F:ITM]SERMGTCOD,2,3) & [M]SERNUM<>""
  For I=0 To [M:MBM]NBLIG-1
    If [M]MFGNUM=[M:MBM]MFGNUM(I) & [M]MFGLIN=[M:MBM]MFGLIN(I) & [M]BOMSEQ=[M:MBM]BOMSEQ(I)
      If [M]ITMREF=[M:MBM]ITMREF(I) & [M]STA=[M:MBM]STA(I) & [M]STU=[M:MBM]STU(I)
        If dim([M:MBM]LOT)<=0 | (dim([M:MBM]LOT)>0 & [M]LOT=[M:MBM]LOT(I))
          If dim([M:MBM]SLO)<=0 | (dim([M:MBM]SLO)>0 & [M]SLO=[M:MBM]SLO(I))
            If dim([M:MBM]LOC)<=0 | (dim([M:MBM]LOC)>0 & [M]LOC=[M:MBM]LOC(I))
              If dim([M:MBM]PALNUM)<=0 | (dim([M:MBM]PALNUM)>0 & [M]PALNUM=[M:MBM]PALNUM(I))
                If dim([M:MBM]CTRNUM)<=0 | (dim([M:MBM]CTRNUM)>0 & [M]CTRNUM=[M:MBM]CTRNUM(I))
                  #----- Regroupement lignes identiques -----#
                  [M:MBM]USEQTY(I)+=[M]USEQTY
                  GSERIALADC =[M]SERNUM
                  GSERIALADCF=[M]SERNUMF
                  GQTYPCUADC =[M]USEQTY
                  GQTYSTUADC =[M]USEQTY
                  GPCUSTUADC =1
                  NOL=I
                  Break
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Next I
Endif
#----- Chargement de la nouvelle ligne -----#
If GSERIALADC=""
  GNOLIG +=1
  nolign  =GNOLIG
  NOL     =nolign-1
  [M:MBM] = [F:MFM]
  [M:MBM]=[M]
  [M:MBM]MFMITMREF(NOL) = [M]ITMREF
  #----- Chargement de la ligne de production -----#
  If [F:MFG]MFGNUM<>[M:MBM]MFGNUM(NOL)
    Read [MFG] MFG0=[M:MBM]MFGNUM(NOL)
    If fstat  Raz [F:MFG] : Endif
  Endif
  If [F:MFM]MFGNUM<>[M:MBM]MFGNUM(NOL) | [F:MFM]MFGLIN<>[M:MBM]MFGLIN(NOL)
& |  [F:MFM]BOMSEQ <> [M:MBM]BOMSEQ(NOL) | [F:MFM]ITMREF <> [M:MBM]ITMREF(NOL)
     Read [MFM] MFM0 = [M:MBM]MFGNUM(NOL);[M:MBM]MFGLIN(NOL);[M:MBM]BOMSEQ(NOL);[M:MBM]ITMREF(NOL)
    If fstat  Raz [F:MFI] : Endif
  Endif
  If [F:ITM]ITMREF<>[M:MBM]ITMREF(NOL)
    Read [ITM] ITM0=[M:MBM]ITMREF(NOL)
    If fstat  Raz [F:ITM] : Endif
  Endif
  [M:MBM]MATTYP(NOL) = 1
  Gosub CHARG_ANA_MBM
  #-----
  [M:MBM]=[M]
  [M:MBM]NBLIG+=1
  If NOL=0
     [M:MBM]WLINUM(NOL)=1000
  Else
     [M:MBM]WLINUM(NOL)=[M:MBM]WLINUM(NOL-1)+1000
  Endif
Endif
#-----
Call ALI_ALP("MBM",NOL) From SUBMTKB

If [F:BTS]STKFLG <> 2 : WAUTO = 1
Else
    If [F:BTS]STOCODMAN = 2 & [M:MBM]STOCODL(NOL) = 1 & [M:ALP]QTY <> 0
        WAUTO = 1
    Else
        WAUTO = 2
    Endif
Endif
Call OUVSOR("MBM",NOL,[M:MBM]NBLIG,[M:MBM]WSTOSEQ(NOL),WAUTO,WRET)
&           From STKSOR
If GOUVSOR = 0 & GCTLALL > 1
   If [F:MFM]ALLSTA > 3
      Look [F:STA]STA1 = 10;[F:MFM]MFGNUM;[F:MFM]MFGLIN;[F:MFM]BOMSEQ;[M:SOW]WSTOCOU([M:SOW]NBLIG-1)
      If fstat
         Case GCTLALL
            When 2 : OK=1 : Call AVERTIR(mess(700,197,1), OK) From GESECRAN
                     If OK=1
                        Call DELSTOSORW(NOL,NOL,"MBM",[M:MBM]FCY,WRET) From STKSOR
                        GERR = 1
                     Endif
            When 3 : Call ERREUR(mess(700,197,1)) From GESECRAN
                     Call DELSTOSORW(NOL,NOL,"MBM",[M:MBM]FCY,WRET) From STKSOR
                     GERR = 1
         Endcase
      Endif
   Else
      Case GCTLALL
         When 2 : OK=1 : Call AVERTIR(mess(700,197,1), OK) From GESECRAN
                  If OK=1
                     Call DELSTOSORW(NOL,NOL,"MBM",[M:MBM]FCY,WRET) From STKSOR
                     GERR = 1
                  Endif
         When 3 : Call ERREUR(mess(700,197,1)) From GESECRAN
                  Call DELSTOSORW(NOL,NOL,"MBM",[M:MBM]FCY,WRET) From STKSOR
                  GERR = 1
      Endcase
   Endif
Endif

If (GOUVSOR>=1 & GSERIALADC="") | GERR = 1
  GNOLIG-=1
  [M:MBM]NBLIG-=1
Endif
GREP=""
Return


########################################################
$CHARG_ANA_MBM
Local Integer I,J
Local Char    WCCE(15)
#Chargement des section ana
Call CHARG_ACCCCE(nolign-1,"","","[M:MBM]CCE",
&                    "MFM",0,[F:MFM]MFGNUM,[F:MFM]MFGLIN,[F:MFM]BOMSEQ,[F:MFM]ITMREF) From TRTX3CPT
For J = 1 To GNBDIE
  If evalue ("[M:MBM]CCE"+num$(J)+"(nolign-1)") =""
      Call INISEC(WCCE,"MKMB", J) From TRTX3CPT
      Assign "[M:MBM]CCE"+num$(J)+"(nolign-1)" With WCCE
  Endif
Next
Return

########################################################
$CRE_MBM
Local Integer LRETOK
Gosub VALIDATION From FUNBENCHM
GPROGRAMME = "GSAISIE"
GNOLIG = 0
Return


########################################################
$FIN_MBM
If [M:MBM]NBLIG > 0
    Call DELSTOSORW(-1,0,"MBM",[M:MBM]FCY,WRET) From STKSOR
Else
    Call RAZSTOSORW From STKSOR
Endif
Kill GSERIALADC, GSERIALADCF
Kill GQTYPCUADC, GQTYSTUADC, GPCUSTUADC
Return


########################################################
$C_MFGNUM_MBM
If VALEUR<>""
  Read [MFG] MFG0=VALEUR
  If fstat | [F:MFG]MFGFCY <> GXAFCY
     GMESSAGE = mess(23,100,1) : mkstat=1 : Return
  Endif
  Call C_MFGNUM(VALEUR) From FUNBENCHM
Endif
Return


########################################################
$AS_ITMREF_MBM
Raz [F:MFM]
Return


########################################################
$AM_ITMREF_MBM
Local Integer LRET,I
# Lecture article et règle de gestion
Call INIZONADC("XAMT",VALEUR,[M:XAMT]FCY,0,[M:XAMT]TRSTYP,[M:XAMT]TRSCODS,"") From STKECR
If [F:ITM]STOMGTCOD<2 | [F:ITM]ITMSTA=6
   mkstat=2 : Return
Endif
If clalev ([F:ITF]) <= 0 : Local File ITMFACILIT [ITF] : Endif
If [F:ITF]ITMREF <> VALEUR | [F:ITF]STOFCY <> GXAFCY
   Read [ITF]ITF0 = VALEUR;GXAFCY
   If fstat
      mkstat=2 : Return
   Endif
Endif
# Disable fields that should not be prompted for, based on the product
If [F:ITM]LOTMGTCOD<2
   Grizo [M]LOT
Else
   Actzo [M]LOT
Endif
If [F:ITM]LOTMGTCOD<2 | [F:ITM]LOTMGTCOD<>4
   Grizo [M]SLO
Else
   Actzo [M]SLO
Endif
If [F:ITM]SERMGTCOD<3
   Grizo [M]SERNUM
Else
   Actzo [M]SERNUM
Endif
#Si on n' a pas utilise la selection
If [F:MFM]MFGNUM = ""
    WCRITERE="MFGNUM=[M]MFGNUM"
    WCRITERE-="& ITMREF=VALEUR & MATSTA <> 4"
    Filter [MFM] Where evalue (WCRITERE)
    Read [MFM] MFM0 First
    Filter [MFM]
    If fstat
       GMESSAGE = mess(23,100,1) : mkstat=1 : Return
    Endif
Else
    Read [F:MFM]MFM0 = [M]MFGNUM;[M]MFGLIN;[M]BOMSEQ;VALEUR
Endif
[M]MFGLIN=[F:MFM]MFGLIN
[M]BOMSEQ=[F:MFM]BOMSEQ
[M]TCLCOD= [F:ITM]TCLCOD
If [F:ITF]LOCMGTCOD=2
   [M]LOC =[F:MFM]LOC
   If [M]LOC = ""
       Call STKINIEMPS([M]LOC) From STKLOC
   Endif
Endif
#----- Calcul de la quantité restant à consommer -----#
[M]USEQTY=[F:MFM]RETQTY-[F:MFM]USEQTY
[M]USEQTY-=sigma(I=0,[M:MBM]NBLIG-1,[M:MBM]USEQTY(I)*([M:MBM]MFGNUM(I)  = [F:MFM]MFGNUM &
&                                                       [M:MBM]MFGLIN(I)= [F:MFM]MFGLIN &
&                                                       [M:MBM]BOMSEQ(I)= [F:MFM]BOMSEQ &
&                                                       [M:MBM]ITMREF(I)= VALEUR))
If [M]USEQTY<0 : Raz [M]USEQTY : Endif
[M]WQTY   = [M]USEQTY
Call CONT_SOLDE_MAT([M]FCY,VALEUR,[M]USEQTY,[M]WQTY,LRET) From MFGLIBM
If LRET = 1 : [M]CLEFLG = 2
Else          [M]CLEFLG = 1
Endif
Return


########################################################
$C_SLO_MBM
Local Char WBPSLOT
If VALEUR<>""
   Call STKCTRSLOS(VALEUR,[M]LOT,[M]ITMREF,[M]IPTDAT,"",[M:MBM]FCY) From STKACT
Endif
Return

########################################################
$AM_SERNUM_MBM
Local    Char    LSERF(GLONSER)
Local    Decimal LQTYF

If VALEUR<>""
   [M:ALP]TRSTYP     = [M]TRSTYP
   [M:ALP]TRSCOD     = [M]TRSCODS
   [M:ALP]STOFCY     = [M]FCY
   [M:ALP]ITMREF     = [M]ITMREF
   [M:ALP]BESDAT     = [M]IPTDAT
   [M:ALP]DLVDAT     = [M]IPTDAT
   [M:ALP]PECINTLOC  = 2
   [M:ALP]PECSCOLOC  = 1
   [M:ALP]PECPLFLOC  = 2
   [M:ALP]STA        = "*"

   #--- TS - VXAMT
   [M:ALP]VCRNUMORI  = [M]MFGNUM
   [M:ALP]VCRLINORI  = [M]MFGLIN
   #---

   # Détermination no série fin
   Call CTLSORSER("XAMT",0,VALEUR,[M]USEQTY,LSERF,LQTYF) From STKSOR
   If LQTYF=0
      Raz VALEUR, [M]SERNUMF
   Else
      [M]SERNUMF=LSERF
   Endif
Else
   Raz [M]SERNUMF
Endif
Return

########################################################
# Operation tracking
########################################################
#
# Necessary field in the VT Screen
# --------------------------------
# MFGNUM, OPENUM, OPESPLNUM,CPLQTY, REJCPLQTY,CPLSETTIM,CPLOPETIM,
# CPLUNTTIM , TIMUOMCOD, ROOTIMCOD, OPEUOM, CLEFLG, FCY, IPTDAT
#
# Necessary value in Entry transaction
# ------------------------------------
# Unit can be mosifed : No
#
########################################################


########################################################
$OUVRE_MBO
If !clalev([M:MBO])  Local Mask MTKBENCHO    [MBO] : Endif

Local Char LORI : LORI=""

Gosub OUVRE_INIT   From FUNBENCHO
# Issue 69347 - 2010-11-26 by CCC : Pour contrôle OPENUM
If clalev([F:MFO2])<=0 : Local File MFGOPE     [MFO2] : Endif
Return


########################################################
$DEBUT_MBO
Global Char     GSERIALADC(GLONSER), GSERIALADCF(GLONSER)
Global Decimal  GQTYPCUADC, GQTYSTUADC, GPCUSTUADC
Global Integer  GNOLIG
Local  Shortint WRET
Local  Integer  NOL
GNOLIG=0
Return


########################################################
$RAZ_MBO
Raz [M:MBO]
[M:MBO]FCY = GXAFCY
Call AM_FCY([M:MBO]FCY) From FUNBENCHO
Return


########################################################
$OK_MBO
# Pour interdire la navigation
GREP="C"
FIN = 0
#-----
GNOLIG +=1
nolign  =GNOLIG
NOL     =nolign-1
[M:MBO] = [F:MFO]
# Issue 69817 - 2010-12-10 by CCC : Pour màj de MFO
If [M:MBO]ROUOPENUM(NOL)=0
    [M:MBO]ROUOPENUM(NOL) = [M:MBO]OPENUM(NOL)
Endif
[M:MBO]=[M]

#--------- 11.07 US Feedback
# PE (technique, non documenté) pour désactiver chargement postes si appel depuis module SFC
GPE = 0
GPOINT = "INITSFC"                    #CHECK IGNORE_LINE
Gosub  ENTREE From EXEFNC
#---------
If !GPE
    If [M:MBO]CPLWST(NOL) = ""
      [M:MBO]CPLWST(NOL) = [F:MFO]EXTWST
      [M:MBO]CPLLAB(NOL) = [F:MFO]EXTLAB
    Endif
Endif
#----- Chargement de la ligne de suivi operatoire -----#
If [F:MFG]MFGNUM<>[M:MBO]MFGNUM(NOL)
Read [MFG] MFG0=[M:MBO]MFGNUM(NOL)
If fstat  Raz [F:MFG] : Endif
Endif
If [F:MFO]MFGNUM<>[M:MBO]MFGNUM(NOL) |
&    [F:MFO]OPENUM<>[M:MBO]OPENUM(NOL) |
&    [F:MFO]OPESPLNUM<>[M:MBO]OPESPLNUM(NOL)
     Read [MFO] MFO0 = [M:MBO]MFGNUM(NOL);[M:MBO]OPENUM(NOL);[M:MBO]OPESPLNUM
     If fstat  Raz [F:MFO] : Endif
Endif
If [F:MFI]MFGNUM <> [F:MFO]MFGNUM
   Filter [F:MFI] Where MFGNUM = [F:MFO]MFGNUM
   Read [F:MFI]MFI0 First
   If fstat : Raz [F:MFI] : Endif
   Filter [F:MFI]
Endif
If [M:MBO]EMPNUM(NOL) = 0
   Read [F:TMA] TMA1 = GUSER
   If !fstat : [M:MBO]EMPNUM(NOL) = [F:TMA]EMPNUM : Endif
Endif

[M:MBO]BOMNUM(NOL)  =  [F:MFI]ITMREF
[M:MBO]BOMALT(NOL)  =  [F:MFI]BOMALT
[M:MBO]TIMTYP(NOL) = 1

# Issue 82289 - 2012-07-04 by CCC
[M:MBO]MFOEXTQTY(NOL)  = [F:MFO]EXTQTY
[M:MBO]MFOCPLQTY(NOL)  = [F:MFO]CPLQTY
[M:MBO]MFOREJQTY(NOL)  = [F:MFO]REJCPLQTY
[M:MBO]MFOOKQTY(NOL)   = [M:MBO]MFOCPLQTY(NOL)-[M:MBO]MFOREJQTY(NOL)
[M:MBO]MFOESETTIM(NOL) = [F:MFO]EXTSETTIM
[M:MBO]MFOCSETTIM(NOL) = [F:MFO]CPLSETTIM
[M:MBO]MFOEOPETIM(NOL) = [F:MFO]EXTOPETIM
[M:MBO]MFOCOPETIM(NOL) = [F:MFO]CPLOPETIM

# CCC (09/08/07) Bug 42331 : Alimentation des champs à partir de SCH
If !clalev([F:MWS]) : Local File WORKSTATIO [MWS] : Endif
If !clalev([F:SCH]) : Local File SCHEDULING [SCH] : Endif
Read [F:MWS]WST0 = [F:MFO]EXTWST;[F:MFO]MFGFCY
If !fstat & [F:MWS]WSTTYP <> 3
    Read [F:SCH]SCH0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
    If !fstat
        [M:MBO]DACMST(NOL) = [F:SCH]DACMST
        [M:MBO]SCDCOD(NOL) = [F:SCH]SCDCOD
        [M:MBO]NEXOPENUM(NOL) = [F:SCH]NEXOPENUM
        [M:MBO]INFCAPSTR(NOL)  = [F:SCH]OPESTRDAT
        [M:MBO]INFCAPEND(NOL)  = [F:SCH]OPEENDDAT
        [M:MBO]MFGMST(NOL)     = [F:SCH]MFGMST
        Filter [F:SCH] Where MFGNUM = [M:MBO]MFGNUM(NOL) & NEXOPENUM = [M:MBO]OPENUM(NOL)
        Read [F:SCH]SCH0 First
        If !fstat : [M:MBO]OPEPREC(NOL) = [F:SCH]OPENUM : Endif
        Filter [F:SCH]
    Endif
Endif

Gosub CHARG_ANA_MBO
#-----
[M:MBO]NBLIG+=1
If NOL=0
 [M:MBO]WLINUM(NOL)=1000
Else
 [M:MBO]WLINUM(NOL)=[M:MBO]WLINUM(NOL-1)+1000
Endif
#-----
GREP=""
Return



########################################################
$CHARG_ANA_MBO
Local Integer I,J
Local Char    WCCE(15)
# CCC (2009-11-02) Bug 59387 : Récupération des sections analytiques dans la table CPTANALIN
Call CHARG_ACCCCE(nolign-1,"","","[M:MBO]CCE",
&                    "MFO",0,[F:MFO]MFGNUM,[F:MFO]OPENUM,[F:MFO]OPESPLNUM,"EXTWST") From TRTX3CPT
Call CHARG_ACCCCE(nolign-1,"","","[M:MBO]LABCCE",
&                    "MFO",0,[F:MFO]MFGNUM,[F:MFO]OPENUM,[F:MFO]OPESPLNUM,"EXTLAB") From TRTX3CPT
#Chargement des sections ana
Read [MWS]WST0=[M:MBO]CPLWST(nolign-1);[M:MBO]FCY
If fstat : Raz [F:MWS] : Endif
For J = 1 To GNBDIE
    If evalue ("[M:MBO]CCE"+num$(J)+"(nolign-1)") =""
        Call INISEC(WCCE,"MKOB", J ) From TRTX3CPT
        Assign "[M:MBO]CCE"+num$(J)+"(nolign-1)" With WCCE
    Endif
Next
If [M:MBO]CPLLAB(nolign-1) <> ""
    # lecture poste main d'oeuvre pour section de valo (contenant les CCE)(18/09)
    Read [MWS]WST0=[M:MBO]CPLLAB(nolign-1);[M:MBO]FCY
    If fstat : Raz [F:MWS] : Endif
    For J = 1 To GNBDIE
        If evalue ("[M:MBO]LABCCE"+num$(J)+"(nolign-1)") =""
            Call INISEC(WCCE,"MKOLABB", J ) From TRTX3CPT
            Assign "[M:MBO]LABCCE"+num$(J)+"(nolign-1)" With WCCE
        Endif
    Next
Endif

Return

########################################################
$CRE_MBO
Local Integer LRETOK
Gosub VALIDATION From FUNBENCHO
GPROGRAMME = "GSAISIE"
GNOLIG = 0
Return


########################################################
$FIN_MBO
Kill GSERIALADC, GSERIALADCF
Kill GQTYPCUADC, GQTYSTUADC, GPCUSTUADC

Return


########################################################
$C_MFGNUM_MBO
If VALEUR<>""
  Read [MFG] MFG0=VALEUR
  If fstat | [F:MFG]MFGFCY <> GXAFCY
     GMESSAGE = mess(23,100,1) : mkstat=1 : Return
  Endif
  Call C_MFGNUM(VALEUR) From FUNBENCHO
Endif
Return


########################################################
$AS_OPENUM_MBO
Raz [F:MFO]
Raz [M]OPESPLNUM
Return


########################################################
$AM_OPENUM_MBO
Local Integer LRET,I
#Si on n' a pas utilise la selection
If [F:MFO]MFGNUM = ""
    Filter [MFO] Where MFGNUM=[M]MFGNUM & OPENUM=VALEUR & OPESTA<6
    Read [MFO]MFO0 First
    Filter [MFO]
Else
    Read [MFO]MFO0 = [M]MFGNUM;VALEUR;[M]OPESPLNUM
Endif
If fstat
   GMESSAGE = mess(23,100,1) : mkstat=1 : Return : # Fiche inexistante
Endif

Read [MWS]WST0 = [F:MFO]EXTWST
If fstat | [F:MWS]WSTTYP = 3
   GMESSAGE = mess(30,190,1) : mkstat=1 : Return : # Sous-traitance interdite
Endif

# Issue 69347 - 2010-11-26 by CCC : Contrôle CTLOPEPRE dès la saisie du numéro
If GCTLOPEPRE > 1
    Filter [F:SCH] Where MFGNUM = [M]MFGNUM & NEXOPENUM = VALEUR
    Read [F:SCH]SCH0 First
    Filter [F:SCH]
    If !fstat
        Filter [F:MFO2] Where MFGNUM = [M]MFGNUM & OPENUM = [F:SCH]OPENUM
        Read [F:MFO2]MFO0 First
        Filter [F:MFO2]
        If fstat : Raz [F:MFO2] : Endif
        If [F:MFO2]TRKFIRST=[0/0/0] & [F:MFO2]OPESTA<>6
            Read [F:SCH]SCH0 = [F:MFO2]MFGNUM;[F:MFO2]OPENUM;[F:MFO2]OPESPLNUM
            If fstat : Raz [F:SCH] : Endif
            If [F:SCH]DACMST <> 1
                LRET=0
                For I = 0 To [M:MBO]NBLIG-1
                    If [M:MBO]MFGNUM(I) = [M]MFGNUM & [M:MBO]OPENUM(I) = [F:SCH]OPENUM
&                         &([M:MBO]CPLQTY(I)<>0 | [M:MBO]CPLOPETIM(I)<>0 | [M:MBO]CPLSETTIM(I) <> 0)
                        LRET=1 : Break
                    Endif
                Next I
                If LRET = 0
                    Case GCTLOPEPRE
                        When 2 :
                            LRET=1
                            Call AVERTIR(mess(22,190,1)+num$([F:SCH]OPENUM),LRET) From GESECRAN
                            If LRET <> 2 : mkstat=1 : Return : Endif
                        When 3 :
                            Call ERREUR(mess(22,190,1)-num$([F:SCH]OPENUM)) From GESECRAN
                            mkstat=1
                            Return
                    Endcase
                Endif
            Endif
        Endif
    Endif
Endif

[M]OPENUM    = [F:MFO]OPENUM
[M]OPESPLNUM = [F:MFO]OPESPLNUM
# Issue 65869 - 2010-07-06 by CCC
[M]TIMUOMCODA = mess([F:MFO]TIMUOMCOD,301,1)
[M]TIMUOMCOD  = [F:MFO]TIMUOMCOD
[M]OPEUOM     = [F:MFO]OPEUOM
# CCC (2009-09-04) Bug 55066 : correction du 43250 en V6
[M]OPEWORCOE        = 1
[M]CPLUNTTIM = [F:MFO]EXTUNTTIM
[M]ROOTIMCOD = [F:MFO]ROOTIMCOD
[M]CPLWST = [F:MFO]EXTWST
[M]CPLLAB = [F:MFO]EXTLAB
#----- Calcul de la quantité restante à produire -----#
[M]WQTY=[F:MFO]EXTQTY-[F:MFO]CPLQTY
[M]WQTY-=sigma(I=0,[M:MBO]NBLIG-1,[M:MBO]CPLQTY(I)*([M:MBO]MFGNUM(I)=[F:MFO]MFGNUM &
&                                                   [M:MBO]OPENUM(I) = [F:MFO]OPENUM &
&                                                   [M:MBO]OPESPLNUM(I)=[F:MFO]OPESPLNUM))
If [M]WQTY<0  : Raz [M]WQTY : Endif

[M]CPLQTY = [M]WQTY
If [M]ROOTIMCOD <> 3
   [M]CPLOPETIM = [M]CPLQTY *[M]CPLUNTTIM
Else # GH 28/11/2013 bug 93415
   [M]CPLOPETIM = [F:MFO]EXTOPETIM-[F:MFO]CPLOPETIM
   [M]CPLOPETIM-=sigma(I=0,[M:MBO]NBLIG-1,[M:MBO]CPLOPETIM(I)*([M:MBO]MFGNUM(I)=[F:MFO]MFGNUM &
&                                         [M:MBO]OPENUM(I) = [F:MFO]OPENUM &
&                                         [M:MBO]OPESPLNUM(I)=[F:MFO]OPESPLNUM))
   If [M]CPLOPETIM<0  : Raz [M]CPLOPETIM : Endif
Endif

# GH 28/11/2013 bug 93415
[M]CPLSETTIM = [F:MFO]EXTSETTIM-[F:MFO]CPLSETTIM
[M]CPLSETTIM-=sigma(I=0,[M:MBO]NBLIG-1,[M:MBO]CPLSETTIM(I)*([M:MBO]MFGNUM(I)=[F:MFO]MFGNUM &
&                                                           [M:MBO]OPENUM(I) = [F:MFO]OPENUM &
&                                                           [M:MBO]OPESPLNUM(I)=[F:MFO]OPESPLNUM))
If [M]CPLSETTIM<0  : Raz [M]CPLSETTIM : Endif

Call CONT_SOLDE_OPE([M]FCY,[M]CPLWST,[M]CPLQTY,[M]WQTY,LRET) From MFGLIBO
If LRET = 1 : [M]CLEFLG = 2
Else          [M]CLEFLG = 1
Endif

Affzo [M]1-99
Return


####################################################################################
#
# Subprograms:
#
# SETTRANS            - Use to find a valid ADC transaction code for a
#                       particular transaction
# SETPURTRANS         - Use to find a valid ADC Purchase transaction code for a
#                       particular purchasing transaction
# SETMFGTRANS         - Use to find a valid ADC Purchase transaction code for a
#                       particular tracking transaction
# GETERR_GOUVENT      - Returns error message based on bit status
#
####################################################################################

########################################################################
# Function: SETTRANS
#
# Use to find a valid ADC tranasaction code for a
# particular transaction
#
# For ADC transactions, certain fields cannot be set for
# the transaction to work
########################################################################
# Misc Rec: SRTTYP = 1
# Necessary value in Entry transaction
# ------------------------------------
# Field 'Auto print'     --> No
# Field 'Form'           --> No auto print
# Block 'Lot': all field --> No

# Misc Issue: SRTTYP = 2
# Necessary value in Entry transaction
# ------------------------------------
# Field 'Automatic determination' --> No

# Stock change: SRTTYP = 3
# Necessary value in Entry transaction
# ------------------------------------
# Field 'Movement type'  --> Internal
# Field 'Form'           --> No print
# Field 'Change Units'   --> No

# Intersite Transfer: SRTTYP = 4
# Necessary value in Entry transaction
# ------------------------------------
# Field 'Movement type'  --> Inter-site
# Field 'Form'           --> No print

# Sub-contractor Transfer: SRTTYP = 5
# Necessary value in Entry transaction
# ------------------------------------
# Field 'Movement type'  --> Supplier
# Field 'Form'           --> No print

# Bon de préparation : SRTTYP = 6

########################################################################

Funprog SETTRANS(SRTTYPE)
Value Integer SRTTYPE   # FGR 18/01/2010 : X3SUIVI60986

Local Char CRIT (255)
Local Char TRANS

If clalev([F:SRT])=0 : Local File STKTRS [SRT] : Endif
If clalev([F:ACC])=0 : Local File ACCES  [ACC] : Endif

CRIT="ENAFLG=2"
# hcb 60191 (SPERFLG supprimé)
# --- Lot V01 PRNCOD1 = 1 supprimé et when 7 en +
Case SRTTYPE
    When 1 : CRIT+="&SRTTYP=1&SPOTFLG<>2&SRUB1FLG<>2&SRUB2FLG<>2&SRUB3FLG<>2&SRUB4FLG<>2"
    When 2 : CRIT+="&SRTTYP=2&STKFLG<>2"
    When 3 : CRIT+="&SRTTYP=3&BETFCYCOD=1&CHGPCUCOD=1"
    When 4 : CRIT+="&SRTTYP=3&BETFCYCOD=2"
    When 5 : CRIT+="&SRTTYP=3&BETFCYCOD=4"
    When 6 : CRIT+="&SRTTYP=12"
    When 7 : CRIT+="&SRTTYP=5&SPERFLG<>2&SPOTFLG<>2&SRUB1FLG<>2&SRUB2FLG<>2&SRUB3FLG<>2&SRUB4FLG<>2"
    When 9 : CRIT+="&SRTTYP=9&STKFLG<>2"                                                          # hcb 93103

Endcase

Raz TRANS
For [SRT] Where evalue(CRIT)
   # Contrôle du code accès
   If [F:SRT]ACSCOD<>"" & GUSRACS<>2
      Read [ACC]CODACC = GUSER;[F:SRT]ACSCOD
      If !fstat & [F:ACC]EXEC=2
         TRANS=[F:SRT]SRTNUM
         Break
      Endif
   Else
      TRANS=[F:SRT]SRTNUM
      Break
   Endif
Next

End TRANS


########################################################
# Function: SETPURTRANS
#
# Use to find a valid ADC Purchase tranasaction code for a
# particular purchasing transaction
#
# For ADC transactions, certain fields cannot be set for
# the transaction to work
#
# Standard Order PTRTYP = 3
# Necessary value in Entry transaction
# ------------------------------------
# Field 'Auto print'     --> No
# Field 'Form'           --> No auto print
# Block 'Lot': all field --> No
########################################################

Funprog SETPURTRANS(PTRTYPE)
Value Integer PTRTYPE   # FGR 18/01/2010 : X3SUIVI60986

Local Char CRIT (255)
Local Char TRANS

If clalev([F:PTR])=0 : Local File PURTRS [PTR]  : Endif
If clalev([F:ACC])=0 : Local File ACCES  [ACC] : Endif

CRIT="ENAFLG=2&PTRTYP=PTRTYPE"
#TEST MAE  When 6 : CRIT+="&SPOTFLG<>2&SPERFLG<>2&SRUB1FLG<>2&SRUB2FLG<>2&SRUB3FLG<>2&SRUB4FLG<>2&PRNCOD1=1&DOCFLG=1"
# hcb 60191 (SPERFLG supprimé)
Case PTRTYPE
  When 6 : CRIT+="&SPOTFLG<>2&SRUB1FLG<>2&SRUB2FLG<>2&SRUB3FLG<>2&SRUB4FLG<>2"
Endcase
#  When 6 : CRIT+="&SPOTFLG<>2&SRUB1FLG<>2&SRUB2FLG<>2&SRUB3FLG<>2&SRUB4FLG<>2&DOCFLG=1"   # --- Lot V01

Raz TRANS
For [PTR] Where evalue(CRIT)
   # Contrôle du code accès
   If [F:PTR]ACSCOD<>"" & GUSRACS<>2
      Read [ACC]CODACC = GUSER;[F:PTR]ACSCOD
      If !fstat & [F:ACC]EXEC=2
         TRANS=[F:PTR]PTRNUM
         Break
      Endif
   Else
      TRANS=[F:PTR]PTRNUM
      Break
   Endif
Next

End TRANS


########################################################################

Funprog SETMFGTRANS(BTSTYPE)
Value Integer BTSTYPE   # FGR 18/01/2010 : X3SUIVI60986

Local Char CRIT (255)
Local Char TRANS

If clalev([F:BTS])=0 : Local File BENCHTRS [BTS] : Endif  # FQ 65646
If clalev([F:ACC])=0 : Local File ACCES    [ACC] : Endif

CRIT="ENAFLG=2"
#MAE, impression étiquette autorisée
#--- Lot V01
#When 62 : CRIT+="&BTSTYP=62&SPERFLG=1&SPOTFLG=1&SRUB1FLG=1&SRUB2FLG=1&SRUB3FLG=1&SRUB4FLG = 1&PRNCOD1=1"
Case BTSTYPE
    When 60 : CRIT+="&BTSTYP=60&OPEUOMMOD<>2"
    When 61 : CRIT+="&BTSTYP=61&STKFLG<>2"
    When 62 : # Issue 104865 - 2015-02-11 by CCC
              #CRIT+="&BTSTYP=62&SPOTFLG=1&SRUB1FLG=1&SRUB2FLG=1&SRUB3FLG=1&SRUB4FLG = 1"
              CRIT+="&BTSTYP=62&SPOTFLG<>2&SRUB1FLG<>2&SRUB2FLG<>2&SRUB3FLG<>2&SRUB4FLG<>2"
Endcase

Raz TRANS
For [BTS] Where evalue(CRIT)
   # Contrôle du code accès
   If [F:BTS]ACSCOD<>"" & GUSRACS<>2
      Read [ACC]CODACC = GUSER;[F:BTS]ACSCOD
      If !fstat & [F:ACC]EXEC=2
         TRANS=[F:BTS]BTSNUM
         Break
      Endif
   Else
      TRANS=[F:BTS]BTSNUM
      Break
   Endif
Next

End TRANS

########################################################################
Subprog GETERR_GOUVENT(ERRCOD, ERRMESS)
Value    Integer    ERRCOD
Variable Char       ERRMESS

Case ERRCOD
    When 1        :    ERRMESS = mess( 1,7750,1)
    When 2        :    ERRMESS = mess( 2,7750,1)
    When 4        :    ERRMESS = mess( 3,7750,1)
    When 8        :    ERRMESS = mess( 4,7750,1)
    When 16       :    ERRMESS = mess( 5,7750,1)
    When 32       :    ERRMESS = mess( 6,7750,1)
    When 64       :    ERRMESS = mess( 7,7750,1)
    When 128      :    ERRMESS = mess( 8,7750,1)
    When 256      :    ERRMESS = mess( 9,7750,1)
    When 512      :    ERRMESS = mess(10,7750,1)
    When 16384    :    ERRMESS = mess(11,7750,1)
    When Default       ERRMESS = mess(12,7750,1)
Endcase

End

########################################################################
# PEREMPTION_LOT : Alimentation des données lot dans le bloc lot de
#                  [M:ENTW] suite à saisie de la date de péremption
#
#         Entrée : ABR1 = abréviation de l'écran de saisie    (ex: XAMR)
#                  ABR2 = abréviation de l'écran de maj objet (ex: SMR1)
#
#                  Exemple pour les entrées diverses : ABR1 = "XAMR"
#                                                      ABR2 = "SMR1"
########################################################################
Subprog PEREMPTION_LOT(ABR1,ABR2)
Value Char    ABR1
Value Char    ABR2

Local Integer I,J,K
Local Char    M1,M2
M1 = "[M:"+ABR1+"]"
M2 = "[M:"+ABR2+"]"

K = evalue(M2+"NBLIG-1")
I = find(evalue(M2+"WSTOSEQ(K)"),[M:ENTW]WSTOSEQ(0..[M:ENTW]NBLIG-1))
#--- Bug 74405
If I>0 & [M:ENTW]NUMLIGLOT(I-1)>0 & [M:ENTW]SHLDAT([M:ENTW]NUMLIGLOT(I-1))<>evalue(M1+"SHLDAT")
#If I>0 & [M:ENTW]SHLDAT([M:ENTW]NUMLIGLOT(I-1))<>evalue(M1+"SHLDAT")
#---
   J = [M:ENTW]NUMLIGLOT(I-1)
   Local Integer  WCOD : WCOD = [F:ITM]EXYMGTCOD
   Local Decimal  WDLU : WDLU = [M:ENTW]DLU(J)
   Local Date     WREF : WREF = [M:ENTW]REFPER(J)
   Local Date     WPER
   Local Date     WEXY : WEXY = evalue(M1+"SHLDAT")
   Local Integer  WSHL : WSHL = [M:ENTW]SHL(J)
   Local Integer  WUOM : WUOM = [M:ENTW]SHLUOM(J)
   Local Integer  WLTI



   [M:ENTW]SHLDAT(J) = evalue(M1+"SHLDAT")
   If [F:ITM]EXYMGTCOD = 6
      # recalcul reference date peremption
      Call CALREF(WCOD,WEXY,WSHL,WUOM,"",WPER) From STKLIB
      [M:ENTW]REFPER(J)  = WPER
      WREF               = [M:ENTW]REFPER(J)
   Endif
   # Recalcul date limite utilisation
   Call CALDLU(WCOD,WREF,WEXY,WDLU,"",WPER,WLTI) From STKLIB
   [M:ENTW]DLUDAT(J) = WPER

   If [F:ITM]EXYMGTCOD = 6
      # Recalcul date recontrole
      WUOM = [M:ENTW]SHLLTIUOM(J)
      WSHL = [M:ENTW]SHLLTI(J)
      Call CALLTI(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
      [M:ENTW]NEWLTIDAT(J) = WPER
      # Si date recontrole > date limite utilisation
      If [M:ENTW]NEWLTIDAT(J) <> [31/12/2999]
         If [M:ENTW]NEWLTIDAT(J) > [M:ENTW]DLUDAT(J)
            [M:ENTW]NEWLTIDAT(J) = [M:ENTW]DLUDAT(J)
         Endif
      Endif
   Endif
Endif

End

# Issue 92266 - 2013-09-09 by MUARN : landed cost
Subprog ALIM_STCD(NOL)
Value Integer NOL

Local Integer WRET

If !clalev([M:STCP])  Local Mask STCPAR  [STCP]  : Endif

Raz [M:STCP]
[M:STCP]VCRTYP  = 6
[M:STCP]VCRNUM  = [M:PTH0]PTHNUM
[M:STCP]VCRLIN  = [M:PTH1]PTDLIN(NOL)
[M:STCP]VCRSEQ  = 0
[M:STCP]STOFCY  = [M:PTH0]PRHFCY
[M:STCP]BPSNUM  = [M:PTH0]BPSNUM
[M:STCP]DAT     = [M:PTH0]RCPDAT
[M:STCP]ICT     = [M:PCEX]EECICT
[M:STCP]CHGTYP  = [M:PTH0]CHGTYP
[M:STCP]NETPRI  = [M:PTH1]NETPRI(NOL)
[M:STCP]QTYPUU  = [M:PTH1]QTYPUU(NOL)
[M:STCP]QTYVOU  = [M:PTH1]QTYVOU(NOL)
[M:STCP]QTYWEU  = [M:PTH1]QTYWEU(NOL)
[M:STCP]PUU     = [M:PTH1]PUU(NOL)
[M:STCP]VOU     = [M:PTH1]LINVOU(NOL)
[M:STCP]WEU     = [M:PTH1]LINWEU(NOL)

If [M:PTH1]POHNUM(NOL)<>""  & [M:PTH1]POHTYP(NOL)<>2
  [M:STCP]VCRTYPORI  = 14
  [M:STCP]VCRNUMORI  = [M:PTH1]POHNUM(NOL)
  [M:STCP]VCRLINORI  = [M:PTH1]POPLIN(NOL)
  [M:STCP]VCRSEQORI  = [M:PTH1]POQSEQ(NOL)
  [M:STCP]QTYPUUORI  = [F:POQ]QTYPUU
Endif
[M:STCP]ORIPPK="PTH"

Call GES_STCDW("PTH1",NOL,WRET) From STCCLC

End

