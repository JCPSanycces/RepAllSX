#<AdxTL>@(#)6.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Suppression des doublons PRFCOD+CODACC+USR dans la table ACCES
#----------------------------------------------------------------------------------------#

Subprog GENE
Call OUVRE_TRACE("Updating ACCES...") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER

Call ECR_TRACE("UTIMAJACCES : Updating ACCES on folder"-DOSSIER,0) From GESECRAN

If DOSSIER=nomap
 Local File ACCES [ACC]
 Local File ACCES [ACC1]
 Local File ACCES [ACC2]
 Local File ACCCOD [ACS]
 Local File AUTILIS [AUS]
Else
 Local File =DOSSIER+".ACCES" [ACC]
 Local File =DOSSIER+".ACCES" [ACC1]
 Local File =DOSSIER+".ACCES" [ACC2]
 Local File =DOSSIER+".ACCCOD" [ACS]
 Local File =DOSSIER+".AUTILIS" [AUS]
Endif

Gosub MAJACCES
Gosub MAJACCUSR

Call ECR_TRACE("UTIMAJACCES : End Updating ACCES on folder"-DOSSIER,0) From GESECRAN
Close Local File [ACC],[ACC1],[ACC2],[ACS],[AUS]
End

#-------------------#
$MAJACCUSR
Local Integer WFOUND

Trbegin [ACC],[ACC2]

For [AUS]
 If [F:AUS]ALLACS=2
  For [ACS]ACS0
   WFOUND=0
   For [ACC1] Where [F:ACC1]PRFCOD="" & [F:ACC1]USR=[F:AUS]USR & [F:ACC1]CODACC=[F:ACS]CODACC
    If [F:ACC1]CONSUL = 2 & [F:ACC1]EXEC = 2 & [F:ACC1]MODIF = 2
     WFOUND=1
    Else
     Delete [F:ACC1] Curr
     If fstat
       Call ERREUR("ACCES1 (PRFCOD/USR/CODACC) ("+[F:ACC1]PRFCOD+"/"+[F:ACC1]USR+"/"+[F:ACC1]CODACC+"), Error ="-num$(fstat),3) From DOSDIC
     Endif
    Endif
   Next
   If WFOUND=0
    Raz [F:ACC]
    [F:ACC]CONSUL = 2
    [F:ACC]EXEC   = 2
    [F:ACC]MODIF  = 2
    [F:ACC]USR    = [F:AUS]USR
    [F:ACC]CODACC = [F:ACS]CODACC
    Write [ACC]
    If fstat
      Call ERREUR("ACCES (PRFCOD/USR/CODACC) ("+[F:ACC]PRFCOD+"/"+[F:ACC]USR+"/"+[F:ACC]CODACC+"), Error ="-num$(fstat),1) From DOSDIC
    Endif
   Endif
  Next
 Endif : #[F:AUS]ALLACS=2

 WFOUND=0
 For [ACC1] Where [F:ACC1]PRFCOD="" & [F:ACC1]USR=[F:AUS]USR & [F:ACC1]CODACC=""
  If [F:ACC1]CONSUL = 2 & [F:ACC1]EXEC = 2 & [F:ACC1]MODIF = 2
   WFOUND=1
  Else
   Delete [F:ACC1] Curr
   If fstat
     Call ERREUR("ACCES1 (PRFCOD/USR/CODACC) ("+[F:ACC1]PRFCOD+"/"+[F:ACC1]USR+"/"+[F:ACC1]CODACC+"), Error ="-num$(fstat),3) From DOSDIC
   Endif
  Endif
 Next
 If WFOUND=0
  Raz [F:ACC]
  [F:ACC]CONSUL = 2
  [F:ACC]EXEC   = 2
  [F:ACC]MODIF  = 2
  [F:ACC]USR    = [F:AUS]USR
  [F:ACC]CODACC = ""    : # Code accès vide pour Crystal Report
  [F:ACC]PRFCOD = ""
  Write [ACC]
  If fstat
    Call ERREUR("ACCES (PRFCOD/USR/CODACC) ("+[F:ACC]PRFCOD+"/"+[F:ACC]USR+"/"+[F:ACC]CODACC+"), Error ="-num$(fstat),1) From DOSDIC
  Endif
 Endif
Next
Commit
Return
#-------------------#
$MAJACCES
Local Integer WCOUNT

Trbegin [ACC],[ACC2]
Filter [ACC] Order By Key CLE=[F:ACC]PRFCOD;[F:ACC]USR;[F:ACC]CODACC
For [ACC]CLE(3)
  Raz [F:ACC2]
  [F:ACC2]=[F:ACC]
  WCOUNT=0
  For [ACC1] Where [F:ACC1]PRFCOD=[F:ACC]PRFCOD & [F:ACC1]USR=[F:ACC]USR & [F:ACC1]CODACC=[F:ACC]CODACC
   WCOUNT+=1
  Next
  If WCOUNT>1
   For [ACC]CLE
     [F:ACC2]CONSUL=max([F:ACC2]CONSUL,[F:ACC]CONSUL)
     [F:ACC2]EXEC=max([F:ACC2]EXEC,[F:ACC]EXEC)
     [F:ACC2]MODIF=max([F:ACC2]MODIF,[F:ACC]MODIF)
     Delete [F:ACC] Curr
     If fstat
       Call ERREUR("ACCES (PRFCOD/USR/CODACC) ("+[F:ACC]PRFCOD+"/"+[F:ACC]USR+"/"+[F:ACC]CODACC+"), Error ="-num$(fstat),3) From DOSDIC
     Endif
   Next
   Write [F:ACC2]
   If fstat
     Call ERREUR("ACCES2 (PRFCOD/USR/CODACC) ("+[F:ACC2]PRFCOD+"/"+[F:ACC2]USR+"/"+[F:ACC2]CODACC+"), Error ="-num$(fstat),1) From DOSDIC
   Endif
  Endif
Next ACC
Filter [ACC]
Commit

Return

