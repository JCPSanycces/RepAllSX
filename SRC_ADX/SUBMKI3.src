#<AdxTL>@(#)10.0.0.0 $Revision$
########################################
Subprog AV_NBLIG
Local Integer L : L = nolign - 1

If [M:MKI3]REJCPLQTY(L) <> 0
  pcolor = GCOUL(1)
Else
  pcolor = GCOUL(0)
Endif

End

########################################
Subprog AS_NBLIG
GBOUT1 = ""
If [M:MKI3]NBLIG = 0 : End : Endif
If [M:MKI3]OPENUM(nolign-1) = 0 : End : Endif
If clalev ([M:MTK0]) <= 0 : GBOUT1 = mess(313,198,1) : Endif
End

