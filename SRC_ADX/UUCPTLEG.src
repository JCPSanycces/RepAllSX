#<AdxTL>@(#)1.0.0.0 $Revision$
##############################################################################
## DEMANDE 53111
##
##  Sous un dossier mono-législation... code activité LEG inactif.
##  Les champs LEG doivent être renseignés par la législation courante.
##  
##############################################################################
Call OUVRE_TRACE("") From LECFIC
Call PATCH(nomap)
Call LEC_TRACE From LECFIC
End

Subprog PATCH(DOSSIER)
Value Char DOSSIER()


Local Char LEGREF(30)         # Législation de référence 

#-------------- Est ce un dossier mono ou multi législation ?!
Local File ADOSACT [ADA]
Read [ADA]ADA0=DOSSIER;"LEG"
If !fstat & [F:ADA]FLACT<>2
 Gosub MONO_LEG
Else
 Call ECR_TRACE("LEG"-mess(24,176,1),0) From GESECRAN  # Code activité inactif
Endif
Close Local File
End



##############################################################################
$MONO_LEG
Local File ADOSSIER [ADS]
Read [ADS]DOSSIER = DOSSIER
LEGREF = [F:ADS]DOSLEG(0)

Local Char TABLE(GLONATB)
TABLE="GACM"        : Gosub VERF_LEG   # Modèle comptable
TABLE="GLED"        : Gosub VERF_LEG   # Référentiels
TABLE="GACCCLS"     : Gosub VERF_LEG   # Classes de comptes
TABLE="GCOA"        : Gosub VERF_LEG   # Code plan
TABLE="GCACCOA"     : Gosub VERF_LEG   # Transactions de saisie code compta
TABLE="GDIAENTRY"   : Gosub VERF_LEG   # Transactions de saisie de pièces
TABLE="GJOURNAL"    : Gosub VERF_LEG   # Journaux
TABLE="GTYPACCENT"  : Gosub VERF_LEG   # Types de pièces
TABLE="TABBUDTYP"   : Gosub VERF_LEG   # Transactions budégtaires
TABLE="GACCDENCOD"  : Gosub VERF_LEG   # Destinations comptables
TABLE="TABPAYTYP"   : Gosub VERF_LEG   # Transactions de règlements
TABLE="TXSA"        : Gosub VERF_LEG   # Paramétrage Tableau de bord
TABLE="TABFILBAN"   : Gosub VERF_LEG   # Paramétrage fichiers bancaires
TABLE="TABFILTDS"   : Gosub VERF_LEG   # Paramétrage fichiers TDS
TABLE="FILTDS"      : Gosub VERF_LEG   # Structure fichier DADS-U
TABLE="RITENZIONE"  : Gosub VERF_LEG   # Retenues
Return

$VERF_LEG
If filinfo(filpath("FIL",TABLE,"fde",DOSSIER),0)>0

 Local File =DOSSIER+"."+TABLE [ALEG]
 Trbegin [ALEG]
  GOK = 1 
  Update [ALEG] With LEG=LEGREF
  If fstat
   GOK = 0 : Call ERREUR(TABLE,2) From DOSDIC
  Else
   Call ECR_TIME(mess(81,125,1)-":"-TABLE ) From DOSSUB : # maj table
  Endif

 If GOK
  Commit
 Else
  Rollback
 Endif
 Close Local File [ALEG]

Endif
Return



