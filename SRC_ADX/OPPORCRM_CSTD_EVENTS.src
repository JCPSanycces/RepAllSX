#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
# Classe OPPOR
#######################################################################################
# EVENTS                                                                              #
#######################################################################################
#######################################################################################
$AINSERT_CONTROL_BEFORE
Local Integer IRET

  IRET = fmet this.COMPUTE_OPPREACDA()
  IRET = fmet this.COMPUTE_AMT()
  IRET = fmet this.CURRENT_STEP()
Return

#######################################################################################
$AUPDATE_CONTROL_BEFORE
Local Integer IRET

  IRET = fmet this.COMPUTE_OPPREACDA()
  IRET = fmet this.COMPUTE_AMT()
  IRET = fmet this.CURRENT_STEP()
Return

#######################################################################################
$ACONTROL
Local Integer NI
Local Date DMAXAVVTE
Local Integer ICOD421OUI

  # -------------------------------------
  If this.APARENT = null Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(192,2260,1), [V]CST_AFATAL))
    Return
  Endif
  # -------------------------------------
  If fmet this.COUNT_PRESALE_STEP() = 0 Then
    If fmet this.COUNT_POSTSALE_STEP() = 0 Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(195,177,1), [V]CST_AERROR))
    Endif
  Endif
  # -------------------------------------
  # Vérification cohérence date
  Local File ATABDIV [ADI]
  Raz DMAXAVVTE
  If this.OPPDATOPN <> [00/00/00] and this.OPPCDA <> [00/00/00] Then
    If this.OPPDATOPN > this.OPPCDA Then
      [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(458,177,1), [V]CST_AERROR))
    Endif
  Endif
  #
  For NI = 1 To maxtab(this.STPSTB)
    If this.STPSTB(NI) <> null and find(this.STPSTB(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.STPSTB(NI).ENDDAT <> [00/00/00] Then
        If DMAXAVVTE = [0/0/0] or DMAXAVVTE < this.STPSTB(NI).ENDDAT Then
          DMAXAVVTE = this.STPSTB(NI).ENDDAT
        Endif
        If this.OPPDATOPN <> [00/00/00] Then
          If this.STPSTB(NI).ENDDAT < this.OPPDATOPN Then
            #Erreur : les dates des étapes doivent être supérieurs à la date d'ouverture de l'affaire
            [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(456,177,1) + "." - mess(99,183,1) - num$(NI) - ":" -
&                                                format$(GFMDAT,this.STPSTB(NI).ENDDAT) - "<" - format$(GFMDAT,this.OPPDATOPN), [V]CST_AERROR))
          Endif
        Endif
        If this.OPPCDA <> [00/00/00] Then
          If this.STPSTB(NI).ENDDAT > this.OPPCDA Then
            #Erreur : les dates des étapes doivent être inférieurs à la date de conclusion de l'affaire
            [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(457,177,1) + "." - mess(99,183,1) - num$(NI) - ":" -
&                                                format$(GFMDAT,this.STPSTB(NI).ENDDAT) - ">" - format$(GFMDAT,this.OPPCDA), [V]CST_AERROR))
          Endif
        Endif
      Endif
    Endif
  Next NI
  #
  ICOD421OUI = [V]CST_ANO
  For NI = 1 To maxtab(this.STPSTA)
    If this.STPSTA(NI) <> null and find(this.STPSTA(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.STPSTA(NI).ENDDATX <> [00/00/00] Then
        If DMAXAVVTE <> [0/0/0] Then
          # on regarde le paramètre N1 de la table diverse 421.
          #  N1=1-Non (défaut) => ENDDATX ne peut pas être inférieur à DMAXAVVTE
          #  N1=2-Oui          => ENDDATX peut être inférieur à DMAXAVVTE
          # -------------------------------------
          Read [ADI]CODE=421;this.STPSTA(NI).STEX
          If fstat Then
            Raz [F:ADI]
          Endif
          If [F:ADI]N1 <> [V]CST_AYES Then
            ICOD421OUI = [V]CST_ANO
            If this.STPSTA(NI).ENDDATX < DMAXAVVTE Then
              # Cette étape après-vente ne peut être antérieure aux étapes avant-vente
              [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(652,177,1) - num$(NI) - ":" -
&                                                  format$(GFMDAT,this.STPSTA(NI).ENDDATX) - "<" - format$(GFMDAT,DMAXAVVTE), [V]CST_AERROR))
            Endif
          Else
            ICOD421OUI = [V]CST_AYES
          Endif
        Endif
        If this.OPPDATOPN <> [00/00/00] Then
          If this.STPSTA(NI).ENDDATX < this.OPPDATOPN Then
            # Erreur : les dates des étapes doivent être supérieurs à la date d'ouverture de l'affaire
            [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(456,177,1) + "." - mess(103,183,1) - num$(NI) - ":" -
&                                                format$(GFMDAT,this.STPSTA(NI).ENDDATX) - "<" - format$(GFMDAT,this.OPPDATOPN), [V]CST_AERROR))
          Endif
        Endif
        If this.OPPCDA <> [00/00/00] and ICOD421OUI = [V]CST_ANO Then
          If this.STPSTA(NI).ENDDATX < this.OPPCDA Then
            # Erreur : les dates des étapes doivent être inférieurs à la date de conclusion de l'affaire
            [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(610,177,1) + "." - mess(103,183,1) - num$(NI) - ":" -
&                                                format$(GFMDAT,this.STPSTA(NI).ENDDATX) - "<" - format$(GFMDAT,this.OPPCDA), [V]CST_AERROR))
          Endif
        Endif
      Endif
    Endif
  Next NI
Return

#######################################################################################
$ADELETE_CONTROL_BEFORE
  If this.APARENT = null Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(193,2260,1), [V]CST_AFATAL))
    Return
  Endif
Return

#######################################################################################
$STPSTB_ADELLINE_BEFORE
  If this.STPSTB([L]ALINE).STEORIVCR <> AVOID.ACHAR or this.STPSTB([L]ALINE).STEORIAOB <> AVOID.ACHAR Then
    [L]ASTATUS = max([L]ASTATUS, fmet this.SETERROR("", mess(659,177,1), [V]CST_AERROR))
  Endif
Return

