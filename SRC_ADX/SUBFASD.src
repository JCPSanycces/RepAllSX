#<AdxTL>@(#)0.0.0.0 $Revision$

#  FQ59941  ??.??.????  Gestion des modes russes

# Gestion du masque FASDPE


######################################################################################
Subprog AV_ENDDPE(VALEUR)
Variable Decimal VALEUR
  If ([M:FASD]ENDDPEFLG = G_OUI ) Then
    If ( GBROWS = 0 ) Then
      Chgstl [M:FASD]ENDDPE With "FORCAGE"
    Else
      Chgstl [M:FASD]ENDDPE With "TFORCAGE"
    Endif
  Else
    Chgstl [M:FASD]ENDDPE With ""
  Endif

  # FQ59941 La dotation exercice ne peut pas être forcée pour le mode CR
  If ( [M:FAS3]DPM(G_NOL-1) = G_DPMCR ) Then : Diszo [M:FASD]ENDDPE : Endif

End



######################################################################################
Subprog AS_ENDDPE(VALEUR)
Variable Decimal VALEUR
  If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:FASD]ENDDPE", 0) = G_NON ) Then
    GBOUT1 = ""
    GBOUT2 = ""
  Else
    If ([M:FASD]ENDDPEFLG <> G_OUI ) Then
      GBOUT1 = ""
    Else
      GBOUT2 = ""
    Endif
  Endif
End


##########################################################################
Subprog AM_ENDDPE(VALEUR)
Variable Decimal VALEUR

  # Si la dotation exercice est forcée
  # la nouvelle valeur nette doit toujours être > à la valeur résiduelle
  # X3-42056
  # If ( func ECART_NBV_RSDVAL ( VALEUR )  < 0  ) Then
  If ( ([M:FASD]DPRBAS >= 0 and func ECART_NBV_RSDVAL ( VALEUR )  < 0) or
&      ([M:FASD]DPRBAS <  0 and func ECART_NBV_RSDVAL ( VALEUR )  > 0)    ) Then
    GERR= 1 : GMESSAGE= mess(239 ,7773, 1)
    mkstat = 2 : End
  Endif

  # Gestion du code forçage
  If (G_DEFORCE and evalue("[M]"+zoncou+"("+num$(indice)+") = VALEUR") ) Then
    G_DEFORCE = 0
  Else
    [M:FASD]ENDDPEFLG = G_OUI:  Affzo [M:FASD]ENDDPEFLG
    Affzo [M:FASD]ENDDPE
    If ( GBROWS = 0 ) Then
      Chgstl [M:FASD]ENDDPE With "FORCAGE"
    Else
      Chgstl [M:FASD]ENDDPE With "TFORCAGE"
    Endif

  Endif
End

######################################################################################
Subprog B1_ENDDPE(VALEUR)
Variable Decimal VALEUR
  # Gestion du code forçage
  [M:FASD]ENDDPEFLG = G_NON : Affzo [M:FASD]ENDDPEFLG

  Raz [M:FASD]ENDDPE
  Raz VALEUR

  # Gestion du code forçage
  G_DEFORCE = 1
  Chgstl [M:FASD]ENDDPE  With ""
  Affzo [M:FASD]ENDDPE
  mkstat = 99
End


###########################################
Subprog B2_ENDDPE(VALEUR)
Variable Decimal VALEUR
  # Gestion du code forçage
  [M:FASD]ENDDPEFLG(nolign-1) = G_OUI : Affzo [M:FASD]ENDDPEFLG(nolign-1)
  If ( GBROWS = 0 ) Then
    Chgstl [M:FASD]ENDDPE With "FORCAGE"
  Else
    Chgstl [M:FASD]ENDDPE With "TFORCAGE"
  Endif
End



##########################################################################
Subprog AM_PERENDDPE(VALEUR)
Variable Decimal VALEUR

Local Decimal NEWDPE, LPRIO


  # Si la dotation périodique est forcée
  # Une nouvelle dotation exercice est déterminée en fonction de la dotation périodique saisie
  # la nouvelle valeur nette doit toujours être > à la valeur résiduelle
  NEWDPE = [M:FASD]ENDDPE - [M:FASD]PERENDDPE + VALEUR
  If ( func ECART_NBV_RSDVAL ( NEWDPE )  < 0 ) Then
    GERR= 1 : GMESSAGE= mess(239 ,7773, 1)
    mkstat = 2 : End
  Else
    [M:FASD]ENDDPE = NEWDPE : Affzo [M:FASD]ENDDPE
  Endif

End


##########################################################################
Funprog ECART_NBV_RSDVAL(PDOT)

Value Decimal PDOT
# Contrôle de la valeur amortissable après modification de la dotation exercice
# Elle doit être >= 0.

Local Decimal LVNC

  LVNC   = [M:FAS3]DPRBAS(G_NOL-1)
&        - [M:FAS3]DPRCUM(G_NOL-1)
&        - PDOT
&        - [M:FAS3]EXCDPR(G_NOL-1)
&        - [M:FAS3]IMLBLC(G_NOL-1)
&        - [M:FAS3]IML(G_NOL-1)
&        + [M:FAS3]IMLRVE(G_NOL-1)
&        + [M:FAS3]EXETRFCUM(G_NOL-1)
&        + [M:FAS3]IMLRVETRF(G_NOL-1)
&        + [M:FAS4]IMLRVEISS(G_NOL-1)
&        - [M:FAS3]RSDVAL(G_NOL-1)

End LVNC

