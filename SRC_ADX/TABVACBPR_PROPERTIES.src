###########################################################################################
# TABVACBPR_PROPERTIES : Sous-prog gestion propriétés la classe TABVACBPR : Régime taxe   #
###########################################################################################
End

# ----------------------- LEG --------------------------------------
$LEG
Case [L]ARULE
  When "GET"       : Gosub GET_LEG
  When "PROPAGATE" : Gosub PROPAGATE_LEG
  When Default     : Return
Endcase

Return

$GET_LEG

Return

$PROPAGATE_LEG

Return
# Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
# ----------------------- VAT --------------------------------------
$VAT
Case [L]ARULE
  When "PROPAGATE" : Gosub VAT_PROPAGATE
  When Default     : Return
Endcase

Return
$VAT_PROPAGATE

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_VAT_LEG(this, this.VAT, AVOID.ACHAR, AVOID.ACHAR, this.LEG, this.VAT_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

Return

