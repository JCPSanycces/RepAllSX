#<AdxTL>@(#)2.0.0.0 $Revision$
############################################################################
# UUMGPRESAL05   Pre-migration historique commandes ouvertes Module Ventes #
# Gestion des infos douanières                                             #
############################################################################
# Issue X3-90233 - 20180807 by LD : Error in processes UUMGPRESALxx

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGPRESAL05") From LECFIC
  Endif

  Call MAJ_UUMGPRESAL05(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End


###################################################################################
Subprog MAJ_UUMGPRESAL05(DOSSIER)
Value Char DOSSIER

Local Integer ERR

# Issue 106947 - 20150811 by LD : Migration of historic folder
If func DOSSUB.ISHISTFOLD(DOSSIER) : End : Endif
# Issue 106947 - 20150811 by LD

##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : : # N= no module
  End
Endif

#----- Récupération du n° de version
# Issue X3-90233
#Local Char VERSION
#Call VERSION (DOSSIER,VERSION) From DOSSUB
#If val(VERSION)=0
#  # N° de version incorrecte
#  Call MIGSTKENDFLG (DOSSIER,"UUMGPRESAL02",7,ERR) From TRTMIG : #7=Erreur
#  End
#Endif
Local Char    CVERSION(3)
Local Integer VERSION
Call MIGGETVERSION (DOSSIER,CVERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGPRESAL05",7,ERR) From TRTMIG : #7=Erreur
  End
Else
 VERSION=val(CVERSION)
Endif
# End issue X3-90233

Call ECR_TIME("UUMGPRESAL05 Sales Order Process : Update VSORDERC") From DOSSUB
Call ECR_TRACE("UUMGPRESAL05 : Process Start on : "+DOSSIER,0) From GESECRAN

Gosub MIG_OUVRE From TRTMIG

Local Integer EXE_SQL
#EXE_SQL = 1

# Passage en V6
If VERSION<GMIGX3VER60
  # ----------------------------------------
  # 1- ajouter les colonnes dans la table VOC
  # ----------------------------------------
  Gosub ADDCOL60
  If ERR : Goto FIN_VOC : Endif
Endif

If EXE_SQL

  Gosub TRT_SQL_VOC
Else

  Gosub TRT_X3_VOC
Endif

# Passage en V6
If VERSION<GMIGX3VER60
  #--------------- Suppression index ----------#
  Call MIGINDDEL (DOSSIER,"VSORDERC",ERR) From TRTMIG
  If ERR : Goto FIN_VOC : Endif
Endif

$FIN_VOC
Call ECR_TIME("UUMGPRESAL05 Sales Order Process END.") From DOSSUB
End

##########################################################################
# ----------------------------------------
# Champs à alimenter à partir de la V6
# ----------------------------------------
# 1- ajouter les colonnes dans la table VOC
# 2- ajouter un index unique
# ----------------------------------------
$ADDCOL60

# 1- ajouter les colonnes dans la table VOC
# ----------------------------------------

If GACTDEB=2
  # Ajout du champ EECLOC : Lieu de transport CEE
  Call MIGADDCOL (DOSSIER,"VSORDERC","BPIEECNUM","A",20,1,ERR) From TRTMIG
  If ERR : Return : Endif
  # Ajout du champ EECLOC : Lieu de transport CEE
  If clalev([F:ATZ1])=0 : Local File =DOSSIER+".ATABZON" [ATZ1] : Endif
  If clalev([F:ATZ2])=0 : Local File =DOSSIER+".ATABZON" [ATZ2] : Endif
  # Ajout du champ EECLOC : Lieu de transport CEE
  Read [ATZ2]CODZONE="VSORDERC";"EECLOC"
  If fstat : #il faut ajouter la zone
      Filter [ATZ1] Where CODFIC="VSORDERC"
      Read [ATZ1]NUMLIG Last
      Filter [ATZ1]
      Trbegin [ATZ2]
      Raz [F:ATZ2]
      [F:ATZ2]NUMLIG=[F:ATZ1]NUMLIG+1
      [F:ATZ2]CODFIC="VSORDERC"
      [F:ATZ2]CODZONE="EECLOC"
      [F:ATZ2]CODACT="MIG"
      [F:ATZ2]CODTYP="M"
      [F:ATZ2]LONG=15
      [F:ATZ2]NOLIB=236
      [F:ATZ2]DIME=1
      [F:ATZ2]OBLIG=1
      [F:ATZ2]ZERO=1
      #texte 8713 : Interne X3
      [F:ATZ2]NOCOURT=8713
      [F:ATZ2]NOLONG=8713
      [F:ATZ2]NOABREG=8713
      Write [ATZ2]
      If fstat
        Call ECR_TRACE("File ATABZON"-[F:ATZ2]CODFIC-[F:ATZ2]CODZONE+", Error ="-num$(fstat),1) From GESECRAN
        Rollback
        Return
      Else
        Commit
      Endif
  Endif
Endif

# Ajout du champ EECICT : Incoterm
Call MIGADDCOL (DOSSIER,"VSORDERC","EECICT","A",20,1,ERR) From TRTMIG
If ERR : Return : Endif

#2- ajouter un index unique
#--------------- INDEX ADDITION  ----------#
Call MIGINDCRE (DOSSIER,"VSORDERC","BPCORD+BPAADD+SOHNUM+ITMREVNUM+SOPLIN","","",0,ERR) From TRTMIG
If ERR : Return : Endif

Return

########################################################################
$TRT_X3_VOC

# Passage en V6
If VERSION<GMIGX3VER60
  # Champs à alimenter à partir de la V6
  Gosub TRT_X3_60
Endif

Return

############################################################################
# Migration en V6 :                                                        #
# ---------------                                                          #
# Entête devis : VSORDERC                                                  #
# ---------------------                                                    #
# Gestion des infos douanières                                             #
############################################################################
$TRT_X3_60

# 2- alimenter les nouvelles colonnes si vide
# -------------------------------------------

#----- Ouverture des fichiers -----#
If clalev([F:VOC]) : Close File [VOC] : Endif
If clalev([F:VOH])  = 0 : Local File =DOSSIER+".VSORDER"     [VOH]  : Endif
If clalev([F:VOC])  = 0 : Local File =DOSSIER+".VSORDERC"    [VOC]  : Endif
If clalev([F:BPR])  = 0 : Local File =DOSSIER+".BPARTNER"    [BPR]  : Endif
If clalev([F:BPD])  = 0 : Local File =DOSSIER+".BPDLVCUST"   [BPD]  : Endif

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer COMPTEUR
Local Integer STOP, NB
Local Char    CRITERE(250)
Local Char    ACLE1, ACLE2, ACLE3
Local Integer ACLE4, ACLE5
Raz COMPTEUR, STOP, CRITERE

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_VOC
Raz NB
If STOP=1
 STOP = 2
 CRITERE  = "[F:VOC]BPCORD=ACLE1 & [F:VOC]BPAADD=ACLE2 & [F:VOC]SOHNUM=ACLE3 & [F:VOC]ITMREVNUM=ACLE4 & [F:VOC]SOPLIN>ACLE5"
Elsif STOP=2
 STOP = 3
 CRITERE  = "[F:VOC]BPCORD=ACLE1 & [F:VOC]BPAADD=ACLE2 & [F:VOC]SOHNUM=ACLE3 & [F:VOC]ITMREVNUM>ACLE4"
Elsif STOP=3
 STOP = 4
 CRITERE  = "[F:VOC]BPCORD=ACLE1 & [F:VOC]BPAADD=ACLE2 & [F:VOC]SOHNUM>ACLE3"
Elsif STOP=4
 STOP = 5
 CRITERE  = "[F:VOC]BPCORD=ACLE1 & [F:VOC]BPAADD>ACLE2"
Elsif STOP=5
 STOP = 0
 CRITERE  = "[F:VOC]BPCORD>ACLE1"
Else
 CRITERE  = "1=1"
Endif

Trbegin [VOC]
GOK = 1

For [VOC]MIG Where evalue(CRITERE)

  If (dim([F:VOC]BPIEECNUM)<0 | [F:VOC]BPIEECNUM<>'') & [F:VOC]EECICT<>'' & (dim([F:VOC]EECLOC)<0 | [F:VOC]EECLOC<>0)
      Goto SUITE_LOOP_VOC
  Endif

  # --- alimentation des champs
  Gosub RECUP_BPR_VOC
  # --- alimentation des champs
  Gosub RECUP_BPD_VOC

  Rewrite [F:VOC]
  If fstat
    Call ECR_TRACE("File VSORDERC(SOHNUM/ITMREVNUM/SOPLIN)"-[F:VOC]SOHNUM-num$([F:VOC]ITMREVNUM)-num$([F:VOC]SOPLIN)+", ERROR ="-num$(fstat),1) From GESECRAN
    GOK=0 : Break
  Endif

  COMPTEUR += 1
  NB+=1
  If NB>GMAXUPDTRS
    ACLE1 = [F:VOC]BPCORD
    ACLE2 = [F:VOC]BPAADD
    ACLE3 = [F:VOC]SOHNUM
    ACLE4 = [F:VOC]ITMREVNUM
    ACLE5 = [F:VOC]SOPLIN
    STOP=1
    Break
  Endif

$SUITE_LOOP_VOC
Next

If GOK<1
  Rollback
Else
  Commit
  If STOP
    Goto LOOP_VOC
  Endif
Endif

$FIN_X3_VOC
Gosub UNSET_FIRST From TRTFIRST

Close Local File [VOH], [VOC], [BPR], [BPD]

Call ECR_TIME("UUMGPRESAL05 : "+num$(COMPTEUR)+" records processed.")  From DOSSUB
Return

########################################################################
$RECUP_BPD_VOC

      If [F:VOC]EECICT="" | (GACTDEB=2 & [F:VOC]EECLOC=0)
          # --- Alimentation incoterm, lieu de transport CEE
          If [F:BPD]BPCNUM<>[F:VOC]BPCORD | [F:BPD]BPAADD<>[F:VOC]BPAADD
              Read [F:BPD]BPD0 = [F:VOC]BPCORD;[F:VOC]BPAADD : If fstat Raz [BPD] Endif
          Endif
          If [F:VOC]EECICT="" [F:VOC]EECICT=[F:BPD]EECICT Endif
          If GACTDEB=2 & [F:VOC]EECLOC=0 [F:VOC]EECLOC=[F:BPD]EECLOC Endif
      Endif

Return

########################################################################
$RECUP_BPR_VOC

      If GACTDEB=2 & [F:VOC]BPIEECNUM=""
          # --- Alimentation n° d'identification CEE
          If [F:VOH]SOHNUM<>[F:VOC]SOHNUM
              Read [F:VOH]VOH0 = [F:VOC]SOHNUM : If fstat Raz [VOH] Endif
          Endif
          If [F:VOH]BPCINV<>""
              If [F:BPR]BPRNUM<>[F:VOH]BPCINV
                  Read [F:BPR]BPR0 = [F:VOH]BPCINV : If fstat Raz [BPR] Endif
              Endif
          Endif
          [F:VOC]BPIEECNUM=[F:BPR]EECNUM
      Endif

Return
########################################################################
$TRT_SQL_VOC

#2- alimenter la nouvelle colonne si vide
#----- Ouverture des fichiers -----#
If clalev([F:VOC]) : Close File [VOC] : Endif
If clalev([F:VOH])  = 0 : Local File =DOSSIER+".VSORDER"     [VOH]  : Endif
If clalev([F:VOC])  = 0 : Local File =DOSSIER+".VSORDERC"    [VOC]  : Endif
If clalev([F:BPR])  = 0 : Local File =DOSSIER+".BPARTNER"    [BPR]  : Endif
If clalev([F:BPD])  = 0 : Local File =DOSSIER+".BPDLVCUST"   [BPD]  : Endif

#-----  Déclaration des variables -----#

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

Trbegin [VOC]
GOK = 1

# Passage en V6
If VERSION<GMIGX3VER60
  Gosub TRT_SQL1_60
Endif

If GOK<1
  Rollback
Else
  Commit
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [VOC]
Return
########################################################################
$TRT_SQL1_60
Return
########################################################################

