Subprog C_ORG(VALEUR)
Variable Char    VALEUR()
Call C_ORG(VALEUR) From SUBDCS
End

########################################
Subprog AM_ORG(VALEUR)
Variable Char    VALEUR()
Effzo [M:DIA]TYPFRM,STRDAT,ENDDAT
Call GRISE_PAI([M:DIA]GENPAI, VALEUR)
End

#--------------------------------------------------------------------------------------------------------
#                                           Gestion de [M:DIA] BORDEREAU
#--------------------------------------------------------------------------------------------------------
########################################
Subprog AS_TYPFRM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : End : Endif
Read [F:ORG]ORG0=GCURLEG;[M:DIA]ORG
#Urssaf
If [M:DIA]CAI=1
 VALEUR=[F:ORG]TYPFRM0
Elsif [M:DIA]CAI=2
 VALEUR=[F:ORG]TYPFRM1
#IRC/IP
Else
 VALEUR=[F:ORG]TYPFRM2
Endif
End

########################################
Subprog AM_TYPFRM(VALEUR)
Variable Char    VALEUR()
Effzo [M:DIA]STRDAT,ENDDAT
Call GRISE_REG(VALEUR)
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran GENDCS) 12/02/2008 16:12:29 (DBA)
######################################################################################
Subprog C_TYPFRM(VALEUR)
Variable Char    VALEUR()
Local Integer VOK
Read[F:ADI]CODE=[M:DIA]NUMADI;VALEUR
If [M]ALLFCY=2
 # n sites
 If ([M:DIA]CAI=1 & [F:ADI]A1<>"914" & [F:ADI]A1<>"916") | ([M:DIA]CAI=2 & [F:ADI]A1<>"921" & [F:ADI]A1<>"923")
& | ([M:DIA]CAI>2 & right$([F:ADI]A1,len([F:ADI]A1))<>'G')
  VOK = 1
  #Type de bordereau mono-établissement
  Call AVERTIR(mess(25,10714,1),VOK) From GESECRAN
  If VOK<>2 : mkstat=2 : End : Endif
 Endif
Endif
End


######################################################################################

#--------------------------------------------------------------------------------------------------------
#                                          Gestion de [M:DIA] PERIODE
#--------------------------------------------------------------------------------------------------------
########################################
Subprog AS_STRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] : End : Endif
VALEUR=gdat$(01, month(GMOIPAY), year(GMOIPAY))  :#Mensuel
#Urssaf
If [M:DIA]CAI=1
 Read[F:ADI]CODE=10374;[M:DIA]TYPFRM
 If val([F:ADI]A1)>914
  VALEUR=gdat$(01,01,year(GMOIPAY))    :#Annuel
 Endif
#Assedic
Elsif [M:DIA]CAI=2
 Read[F:ADI]CODE=10375;[M:DIA]TYPFRM
 If val([F:ADI]A1)>921
  VALEUR=gdat$(01,01,year(GMOIPAY))    :#Annuel
 Endif
Endif
End

########################################
Subprog AS_ENDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] : End : Endif
#Urssaf
If [M:DIA]CAI=1
 Read[F:ADI]CODE=10374;[M:DIA]TYPFRM
 If val([F:ADI]A1)>914
  VALEUR=eomonth(addmonth([M:DIA]STRDAT,11))  :#Annuel
 Else
  VALEUR=eomonth([M:DIA]STRDAT)  :#Mensuel
 Endif
#Assedic
Elsif [M:DIA]CAI=2
 Read[F:ADI]CODE=10375;[M:DIA]TYPFRM
 If val([F:ADI]A1)>921
  VALEUR=eomonth(addmonth([M:DIA]STRDAT,11))  :#Annuel
 Else
  VALEUR=eomonth([M:DIA]STRDAT)  :#Mensuel
 Endif
#IRC/IP
Else
 Read[F:ADI]CODE=10376;[M:DIA]TYPFRM
 Case val(left$([F:ADI]A1,3))
  When 930 : VALEUR=eomonth(addmonth([M:DIA]STRDAT,2))  :#Trimestriel
  When 931 : VALEUR=eomonth([M:DIA]STRDAT)              :#Mensuel
  When 932 : VALEUR=eomonth(addmonth([M:DIA]STRDAT,11)) :#Annuel
 Endcase
Endif
End

#--------------------------------------------------------------------------------------------------------
#                                          Gestion de [M:DIA] NEANT
#--------------------------------------------------------------------------------------------------------
########################################
Subprog C_FLGNEA(VALEUR)
Variable Integer VALEUR
If VALEUR=2 & [M:DIA]CAI<3
 Effzo [M:DIA]FLGREG, NUMREG, 12
 [M:DIA]FLGREG=1 : [M:DIA]GENPAI=1
 Grizo [M:DIA]FLGREG, NUMREG,12
Else
 Call GRISE_REG ([M:DIA]TYPFRM)
 Call GRISE_PAI ([M:DIA]GENPAI,[M:DIA]ORG)
Endif
End

#--------------------------------------------------------------------------------------------------------
#                                       Gestion de [M:DIA] PAIEMENT
#--------------------------------------------------------------------------------------------------------
########################################
Subprog AM_GENPAI(VALEUR)
Variable Integer VALEUR
[M:DIA]GENPAI=VALEUR
Call GRISE_PAI(VALEUR,[M:DIA]ORG)
End

########################################
Subprog AS_DATPAYTAX(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0] : VALEUR=[M:DIA]ENDDAT: Endif
End

########################################
Subprog AS_BANFCY(VALEUR)
Variable Char    VALEUR()
Local Integer MODPAY
Local Char    BAN (GLONBAN)(0..1)
If VALEUR=""
 Call ORGBAN([M:DIA]ORG,[M:DIA]CPY,MODPAY,BAN(0),BAN(1)) From SUBORA
 If MODPAY<>3 : mkstat=1 : End : Endif
 VALEUR=BAN(indice)
Endif
End

########################################
Subprog C_BANFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & (indice=0 & VALEUR=[M:DIA]BANFCY(1)) | (indice=1 & VALEUR=[M:DIA]BANFCY(0))
 #Code banque déjà saisi
 GMESSAGE=mess(99,10703,1)
 mkstat=2 : End
Endif
End

########################################
Subprog AM_BANFCY(VALEUR)
Variable Char    VALEUR()
If indice=0
 If VALEUR=""
  Effzo [M:DIA]BANFCY(1),AMTMAX : Grizo [M:DIA]BANFCY(1),AMTMAX
 Else
  Actzo [M:DIA]BANFCY(1)
 Endif
Elsif indice=1 & VALEUR<>""
 Actzo [M:DIA]AMTMAX
Else
 Effzo [M:DIA]AMTMAX : Grizo [M:DIA]AMTMAX
Endif
End

#--------------------------------------------------------------------------------------------------------
#                                       Gestion de [M:DIA] REGUL
#--------------------------------------------------------------------------------------------------------
#NUMREG uniquement pour les DUCS rectificatives Urssaf(régularisation sur période antérieure)
#et non pas pour la déclaration annuelle TR.
########################################
Subprog C_FLGREG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 If [M:DIA]CAI<3
  Actzo [M:DIA]NUMREG
 Else
  Effzo [M:DIA]NUMREG : Grizo [M:DIA]NUMREG
 Endif
Else
 Effzo [M:DIA]NUMREG : Grizo [M:DIA]NUMREG
Endif
End

#--------------------------------------------------------------------------------------------------------
#                                       Gestion de [M:DIA] FICHIER
#--------------------------------------------------------------------------------------------------------


######################################################################################
##60118
######################################################################################
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & [L]VALEUR<2
 GMESSAGE=mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat=2 : End
Endif
#92896 - US2135
If [L]VALEUR=2 : Actzo [DIA] FILNAM
Else             Grizo [DIA] FILNAM
Endif
#If [L]VALEUR=2 : Actzo [DIA] VOLFIL
#Else             Grizo [DIA] VOLFIL
#Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
Local Char FICHIER (GDIMFIC)
If [L]VALEUR<2
 #Composition du nom du fichier
 Call AS_FILNAM(FICHIER)
 Call SET_NAMCLI(FICHIER) From ORDSYS
 [M:DIA]FILNAM=FICHIER+".txt"
 #92896 - US2135
# [M:DIA]VOLFIL=FICHIER+".txt"
#Else
# Call AS_FILNAM(FICHIER)
# [M:DIA]VOLFIL='['+[V]GDIRBQR+']/'+FICHIER+".txt"
Endif
#Affzo VOLFIL
 #
End
##

########################################
Subprog AS_FILNAM(VALEUR)
Variable Char    VALEUR()
Local Char VTYPSND
Local Char VMOIS
If [M:DIA]FLGSND=2 : VTYPSND="R" : Else :  VTYPSND="T" : Endif
If len(num$(month([M:DIA]STRDAT)))<2
 VMOIS="0"+num$(month([M:DIA]STRDAT))
Else
 VMOIS=num$(month([M:DIA]STRDAT))
Endif
VALEUR=[M:DIA]CPY+left$([M:DIA]ORG,3)+VMOIS+VTYPSND
End

########################################
Subprog C_FILNAM(VALEUR)
Variable Char    VALEUR()
Local Char    FICHIER(250)
Local Integer OK
Call C_NOMEXP(VALEUR,"txt") From TRTDUE
If mkstat=2 : End : Endif
#92896 - US2135
#Call EXISTE(filpath([V]GDIRBQE,[L]VALEUR,"txt",0),[L]OK) From ORDSYS
Call EXISTE(filpath([V]GDIRBQR,[L]VALEUR,"txt",0),[L]OK) From ORDSYS
#
If [L]OK
 [V]GMESSAGE=mess(132,133,1) : # Fichier déjà existant
 [V]GERR    =3
 End
Endif
End

########################################
Subprog AS_REFSND(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : End : Endif
#Déclaration DUCS EDI
Local Char NOMFIC (50)
#60118
If [M:DIA]TYPEXP<2
 #On retire l'extention .txt
 NOMFIC=left$([M:DIA]FILNAM,len([M:DIA]FILNAM)-4)
#92896 - US2135
 While instr(1,NOMFIC,"\")
  NOMFIC=right$(NOMFIC,instr(1,NOMFIC,"\")+1)
 Wend
Else
 #NOMFIC=[M:DIA]FILNAM
 NOMFIC=left$([M:DIA]FILNAM,len([M:DIA]FILNAM)-4)
 While instr(1,NOMFIC,"/")
  NOMFIC=right$(NOMFIC,instr(1,NOMFIC,"/")+1)
 Wend
Endif
#While instr(1,NOMFIC,"\")
# NOMFIC=right$(NOMFIC,instr(1,NOMFIC,"\")+1)
#Wend
#
VALEUR=ctrans(toupper(mess(21,10714,1)-NOMFIC))
End

########################################
Subprog AP_REFSND(VALEUR)
Variable Char    VALEUR()
VALEUR=ctrans(toupper(VALEUR))
End

#Ref lot sur 14 caractères (4 pour l'année + 10)
########################################
Subprog AS_REFLOT(VALEUR)
Variable Char    VALEUR()
Local Char NOMFIC (50)
If VALEUR=""
 #60118
 If [M:DIA]TYPEXP<2
 #On retire l'extention .txt
  NOMFIC=left$([M:DIA]FILNAM,len([M:DIA]FILNAM)-4)
  #92896 - US2135
  While instr(1,NOMFIC,"\")
   NOMFIC=right$(NOMFIC,instr(1,NOMFIC,"\")+1)
  Wend
 Else
  #NOMFIC=[M:DIA]FILNAM
  NOMFIC=left$([M:DIA]FILNAM,len([M:DIA]FILNAM)-4)
  While instr(1,NOMFIC,"/")
   NOMFIC=right$(NOMFIC,instr(1,NOMFIC,"/")+1)
  Wend
 Endif
# While instr(1,NOMFIC,"\")
#  NOMFIC=right$(NOMFIC,instr(1,NOMFIC,"\")+1)
# Wend
#
 If len(NOMFIC)>10
  VALEUR=num$(year(date$))+left$(NOMFIC,10)
 Else
  VALEUR=num$(year(date$))+NOMFIC
 Endif
Endif
End

########################################
Subprog AP_REFLOT(VALEUR)
Variable Char    VALEUR()
VALEUR=ctrans(toupper(VALEUR))
End

#--------------------------------------------------------------------------------------------------------
#                                          Gestion de [M:DIA] INIT
#--------------------------------------------------------------------------------------------------------
########################################
Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Call D_INI (VALEUR) From DIVPAYE
Call GRISE_REG ([M:DIA]TYPFRM)
Call GRISE_PAI ([M:DIA]GENPAI,[M:DIA]ORG)
End

#Regul
########################################
Subprog GRISE_REG (BORD)
Value Char BORD()
#Urssaf que pour les TR
If [M:DIA]CAI=1
 Read[F:ADI]CODE=[M:DIA]NUMADI;BORD
 If fstat | [F:ADI]A1="913" | [F:ADI]A1="914"
  Effzo [M:DIA]FLGREG, NUMREG :  Grizo [M:DIA]FLGREG, NUMREG
 Else
  Actzo [M:DIA]FLGREG
  If [M:DIA]FLGREG<>2 : Effzo NUMREG : Grizo NUMREG  : Endif
 Endif
#Assedic : obligatoire pour les DRA
Elsif [M:DIA]CAI=2
 Read[F:ADI]CODE=[M:DIA]NUMADI;BORD
 If !fstat & ([F:ADI]A1="922" | [F:ADI]A1="923" | [F:ADI]A1="928" | [F:ADI]A1="929")
  [M:DIA]FLGREG=2 : [M:DIA]NUMREG=1
  Affzo [M:DIA]FLGREG, NUMREG : Grizo [M:DIA]FLGREG : Actzo [M:DIA]NUMREG
 Else
  Effzo [M:DIA]FLGREG, NUMREG : Grizo [M:DIA]FLGREG, NUMREG
 Endif
Else
 Effzo [M:DIA]FLGREG, NUMREG : Grizo [M:DIA]FLGREG, NUMREG
Endif
End

#Paiement
########################################
Subprog GRISE_PAI (VFLG,VORG)
Value Integer VFLG
Value Char VORG
Local Integer MODPAY
Local Char    BAN (GLONBAN)(0..1)
If VFLG=2
 Actzo DATPAYTAX
 Call ORGBAN(VORG,[M:DIA]CPY,MODPAY,BAN(0),BAN(1)) From SUBORA
 If MODPAY=3
  Actzo [M:DIA]BANFCY
 Else
  Raz [M:DIA]BANFCY,AMTMAX
  Grizo [M:DIA]BANFCY,AMTMAX
 Endif
Else
 Effzo [M:DIA]12 : Grizo [M:DIA]12 : Actzo [M:DIA]GENPAI
Endif
End
