#########################################
Subprog RECUP_ORG (ORG, RESULT,STAT)
Value Char ORG ()
Variable Char RESULT ()
Variable Integer STAT
If clalev([F:ORG2])=0 : Local File ORGANISME  [ORG2] : Endif
Read[F:ORG2]ORG0=GCURLEG;ORG
If fstat=0
 STAT=1
 If [F:ORG2]BID=""
  #RIB Obligatoire
  Call ECRIT_TRACE("PAI",mess(12,10704,1))
  RESULT=RESULT+space$(46)
 Else
  #No compte+ clé rib
  RESULT=RESULT+mid$([F:ORG2]BID,11,13)+space$(22)
  #Code banque
  RESULT=RESULT+mid$([F:ORG2]BID,1,5)+space$(6)
 Endif
 #Qualifiant liste code banque
 RESULT=RESULT+"25"+space$(1)
 #Agence responsable
 RESULT=RESULT+"108"
 #Code guichet
 If [F:ORG2]BID<>""
  #Code guichet
  RESULT=RESULT+mid$([F:ORG2]BID,6,5)+space$(12)
 Else
   RESULT=RESULT+space$(17)
 Endif
 #Qualifiant liste code guichet
 RESULT=RESULT+"25"+space$(1)
 #Agence responsable
 RESULT=RESULT+"108"
Else
 Call ECR_TRACE(mess(4,10707,1)-"ORGANISME [ORG2]",1) From GESECRAN
 STAT=0 : End
Endif
End

#########################################
Subprog RECUP_BANK (BANK, RESULT, STAT)
Value Char BANK ()
Variable Char RESULT ()
Variable Integer STAT
Read[F:BAN]BAN0=BANK
If fstat=0
 STAT=1
 If [F:BAN]BIDNUM=""
  #RIB Obligatoire
  Call ECRIT_TRACE("PAI",mess(12,10704,1))
  RESULT=RESULT+space$(46)
 Else
  #No compte+ clé rib
  RESULT=RESULT+mid$([F:BAN]BIDNUM,11,13)+space$(22)
  #Code banque
  RESULT=RESULT+mid$([F:BAN]BIDNUM,1,5)+space$(6)
 Endif
 #Qualifiant liste code banque
 RESULT=RESULT+"25"+space$(1)
 #Agence responsable
 RESULT=RESULT+"108"
 #Code guichet
 If [F:BAN]BIDNUM<>""
  #Code guichet
  RESULT=RESULT+mid$([F:BAN]BIDNUM,6,5)+space$(12)
 Else
  RESULT=RESULT+space$(17)
 Endif
 #Qualifiant liste code guichet
 RESULT=RESULT+"25"+space$(1)
 #Agence responsable
 RESULT=RESULT+"108"
Else
 Call ECR_TRACE(mess(4,10707,1)-"BANK [BAN]",1) From GESECRAN
 STAT=0 : End
Endif
End

#########################################
Subprog ECRIT_TRACE(ENREG,ZONE)
Value Char ENREG()
Value Char ZONE ()
Call ECR_TRACE("",0) From GESECRAN
# Enregistrement : XXX
Call ECR_TRACE(mess(87,116,1)-":"-ENREG,0) From GESECRAN
# Zone : YYY
Call ECR_TRACE(mess(17,115,1)-":"-ZONE,0) From GESECRAN
# Valeur non renseignée
Call ECR_TRACE(mess(7,10707,1),1) From GESECRAN
End

