#--------------------------------------------------------------------------------------------------------
########################################
Subprog AM_CAI(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 [M:DIA]NUMADI=10374
Elsif VALEUR=2
 [M:DIA]NUMADI=10375
Else
 [M:DIA]NUMADI=10376
 If dim([M:DIA]FLGREG)=0
  Effzo [M:DIA]FLGREG,NUMREG  : Grizo [M:DIA]FLGREG,NUMREG
 Endif
Endif
Effzo [M:DIA]ORG,TYPFRM,STRDAT,ENDDAT
End

