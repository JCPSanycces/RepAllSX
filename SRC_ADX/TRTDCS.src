$DERNIERMOIS
Call PARAM([F:FCY2]FCY,"DMA",VALPAR) From ADOVAL
If VALPAR="" :  LASTMOIS=12 : Else :  LASTMOIS=val(VALPAR) : Endif
Return

#########################################
$REF_SOCIALE
#Référence (clé+type+période+ref+filler)
Call RECUP_DATE ([M:DIA]STRDAT, "AAAATM", WDAT)
RESULTAT+=WDAT
#24=34-10 (Ex : 99S1AAAATM)
If len (INFO)<24
 RESULTAT+=INFO+space$(24-len(INFO))
Else
 RESULTAT+=left$(INFO,24)
Endif
#Filler
RESULTAT+=space$(1)
#Type date
RESULTAT+=space$(3)
#Date associé au paiement
RESULTAT+=space$(8)
#titulaire du compte payeur
###58325
#RESULTAT+=ctrans(toupper([F:CPY]CPYNAM))+space$(27-len([F:CPY]CPYNAM))
If len([F:CPY]CPYNAM)<27
 RESULTAT+=ctrans(toupper([F:CPY]CPYNAM))+space$(27-len([F:CPY]CPYNAM))
Else
 RESULTAT=RESULTAT+ctrans(toupper(left$([F:CPY]CPYNAM,27)))
Endif
###
#qualifiant format date
RESULTAT+=space$(3)
#Filler
RESULTAT+=space$(71)
Return


#########################################
$REF_CPOP
#Ref Cpop (Ident OPS sur 8 caractères + période AATM)
Call RECUP_DATE ([M:DIA]STRDAT, "AATM", WDAT)
RESULTAT+=WDAT
RESULTAT+=space$(23)
#Type date
RESULTAT+="138"
#Date associé au paiement
Call RECUP_DATE ([M:DIA]DATPAYTAX, "AAAAMMJJ", WDAT)
RESULTAT+=WDAT
#Titulaire du compte payeur (Norme CFONB sur 24 carac.) ???
###58325
#RESULTAT+=ctrans(toupper([F:CPY]CPYNAM))+space$(27-len([F:CPY]CPYNAM))
If len([F:CPY]CPYNAM)<27
 RESULTAT+=ctrans(toupper([F:CPY]CPYNAM))+space$(27-len([F:CPY]CPYNAM))
Else
 RESULTAT=RESULTAT+ctrans(toupper(left$([F:CPY]CPYNAM,27)))
Endif
###
#Qualifiant format date
RESULTAT+="102"
Return


#########################################
Subprog RECUP_DATE (VALEUR,FORMAT,DAT)
Value Date VALEUR
Value Char FORMAT ()
Variable Char DAT ()

Case FORMAT

 When "AAAAMMJJ" :
  DAT=num$(year(VALEUR))
  DAT+=string$(2-len(num$(month(VALEUR))),"0")+num$(month(VALEUR))
  DAT+=string$(2-len(num$(day(VALEUR))),"0")+num$(day(VALEUR))
 When "AAAA" :  DAT=num$(year(VALEUR))
 When "AAAAMM" :
    DAT=num$(year(VALEUR))
    DAT+=string$(2-len(num$(month(VALEUR))),"0")+num$(month(VALEUR))
 When "AAAAT" :
    DAT=num$(year(VALEUR))
    If month(VALEUR)<=3
     DAT+="1"
    Elsif month(VALEUR)>=4 & month(VALEUR)<=6
     DAT+="2"
    Elsif month(VALEUR)>=7 & month(VALEUR)<=9
     DAT+="3"
    Else
     DAT+="4"
    Endif
 When "AATM" :
  #Annuelle
  If [M:DIA]ENDDAT-[M:DIA]STRDAT>360
   #période AA62
   DAT=right$(num$(year(VALEUR)),1+len(num$(year(VALEUR)))-2) +"00"
  #Mensuelle
  Elsif [M:DIA]ENDDAT-[M:DIA]STRDAT<31
   #période AATM
   DAT=right$(num$(year(VALEUR)),1+len(num$(year(VALEUR)))-2)
   If month(VALEUR)<=3
    DAT+="1"
    DAT+=num$(month(VALEUR))
   Elsif month(VALEUR)>=4 & month(VALEUR)<=6
    DAT+="2"
    DAT+=num$(month(VALEUR)-3)
   Elsif month(VALEUR)>=7 & month(VALEUR)<=9
    DAT+="3"
    DAT+=num$(month(VALEUR)-6)
   Else
    DAT+="4"
    DAT+=num$(month(VALEUR)-9)
   Endif
  #Trimestrielle
  Else
   #période AAT0
   DAT=right$(num$(year(VALEUR)),1+len(num$(year(VALEUR)))-2)
   If month(VALEUR)<=3
    DAT+="10"
   Elsif month(VALEUR)>=4 & month(VALEUR)<=6
    DAT+="20"
   Elsif month(VALEUR)>=7 & month(VALEUR)<=9
    DAT+="30"
   Else
    DAT+="40"
   Endif
  Endif
 When "AAAATM" :
 #Annuelle
  If [M:DIA]ENDDAT-[M:DIA]STRDAT>360
   #période AAAA00
   DAT=num$(year(VALEUR)) +"00"
  #Mensuelle
  Elsif [M:DIA]ENDDAT-[M:DIA]STRDAT<31
   #période AATM
   DAT=num$(year(VALEUR))
   If month(VALEUR)<=3
    DAT+="1"
    DAT+=num$(month(VALEUR))
   Elsif month(VALEUR)>=4 & month(VALEUR)<=6
    DAT+="2"
    DAT+=num$(month(VALEUR)-3)
   Elsif month(VALEUR)>=7 & month(VALEUR)<=9
    DAT+="3"
    DAT+=num$(month(VALEUR)-6)
   Else
    DAT+="4"
    DAT+=num$(month(VALEUR)-9)
   Endif
  #Trimestrielle
  Else
   #période AAT0
   DAT=num$(year(VALEUR))
   If month(VALEUR)<=3
    DAT+="10"
   Elsif month(VALEUR)>=4 & month(VALEUR)<=6
    DAT+="20"
   Elsif month(VALEUR)>=7 & month(VALEUR)<=9
    DAT+="30"
   Else
    DAT+="40"
   Endif
  Endif
Endcase
End

