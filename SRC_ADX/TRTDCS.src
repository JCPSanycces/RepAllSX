#<AdxTL>@(#)7.0.0.0 $Revision$ Gestion du masque GENDCS
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTDCS","GENDCS",4,"") From GTRAITE
End

#########################################
## Traitement des actions : TRTDCS
#########################################
$ACTION
Case ACTION
 When "INIT"       : Gosub OUVRE
 When "EXEC"       : Gosub EXEC
 When "CONTROLE"   : Gosub CONTROLE
 When "DEBUT"      : Gosub DEBUT
 When "OK"         : FIN = 1 : GOK = 1
 When "END"        : FIN = 1
 When "SORTIE"     : Gosub SORTIE
Endcase
Return

#########################################
$DEBUT
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Affzo [DIA]: Setmok [DIA] With 0
Return

#########################################
$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#########################################
$OUVRE
Gosub OUVFIC

Local Mask GENDCS [DIA]
Raz [DIA]
Call LECMEMO("STD","[M:DIA]","dcs") From GMEMO
Gosub DECLARATION
Return

$OUVFIC
Gosub OUVFIC From INITDCH
If clalev([F:DUC])=0  : Local File PRMDUCS    [DUC] : Endif
If clalev([F:DCS])=0  : Local File DUCS0      [DCS] : Endif
If clalev([F:DCL])=0  : Local File DUCS1      [DCL] : Endif
If clalev([F:DCT])=0  : Local File DUCS2      [DCT] : Endif
If clalev([F:DCX])=0  : Local File DUCS3      [DCX] : Endif
If clalev([F:TDU])=0  : Local File TMPDUCS    [TDU] : Endif
If clalev([F:BPA])=0  : Local File BPADDRESS  [BPA] : Endif
If clalev([F:CNT])=0  : Local File CONTACT    [CNT] : Endif
If clalev([F:AIN])=0  : Local File CONTACTCRM [AIN] : Endif
If clalev([F:ORG])=0  : Local File ORGANISME  [ORG] : Endif
If clalev([F:ADI])=0  : Local File ATABDIV    [ADI] : Endif
If clalev([F:BAN])=0  : Local File BANK       [BAN] : Endif
If clalev([F:FCY2])=0 : Local File FACILITY  [FCY2] : Endif
If clalev([F:FCY3])=0 : Local File FACILITY  [FCY3] : Endif
If clalev([F:CPY2])=0 : Local File COMPANY   [CPY2] : Endif
If clalev([F:ORA])=0  : Local File ORGAFFIL  [ORA] : Endif
If clalev([F:ORB])=0  : Local File ORGBAN    [ORB] : Endif
Return

#########################################
$DECLARATION
Local Char SYMBOLE (100)
Local Char TIT (50)
Local Char CRITERE (50)
Local Char RESULTAT (255)
Local Char FICHIER(250)
Local Char INFO (35)
Local Char SITE (GLONFCY)
Local Char SOCIETE (GLONCPY)
Local Integer NBDEB, NBLIGN
#Mtt par societe et site
Local Decimal AMTTOT, AMTTOTREG, AMTMSS, AMTFCY, AMTFCYREG, MSSFCY, CREDIT, DEBIT, MAXAMT, AMTTRS, AMTTAT, AMTBRT
#Effectif par société et site
Local Integer EFFMRK, EFFPAY, EFFPAYFCY, EFFMRKFCY, EFFMENFCY, EFFWOMFCY
#Effectif apr sexe et par contrat de W
Local Integer EFFMENCDD, EFFWOMCDD, EFFMENCDI, EFFWOMCDI, EFFMENAPP, EFFWOMAPP, EFFMENOLD, EFFWOMOLD
Local Integer EFFMENDIR, EFFWOMDIR, EFFMENCES, EFFWOMCES, EFFMENCNE, EFFWOMCNE, EFFMENINT, EFFWOMINT
Local Integer ITRS
Local Integer COMPTEUR
Local Char CRITFCY (100)
Local Char CRITPAR (100)
Local Integer NUMBANK
Local Char WDAT (8)
Local Char DEVICE (GLONCUR)
Local Char    SAVIFS(5) , SAVIRS(5)
Local Char NUMBORD (5)
Local Date DATVERS    :#Date de versement des salaires

#DBA le 09/11/04
Local Integer LASTMOIS
Local Char VALPAR (20)

#4.2
Local Integer VFLGEDI
Local Integer EXISTE
Local Char OLDCPY (GLONCPY)
Local Char TABSIT (GLONFCY)(0..GNBSITE)
Local Integer NBSIT
Local Char VNUMAFF (50)
Local Char VNUMCTR (50)
Local Integer GRDZE (0..15)
Local Integer IGRD

Local Integer FLGGRP
Local Char CRITCOT (100)

#60118
Local Char    FICHIER (GDIMFIC), FICCLI(GDIMFIC) , URL(GDIMFIC)
Variable Integer STAT

Local Integer MODPAY
Local Char    BAN (GLONBAN)(0..1)

Return

#########################################
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
Return

#########################################
$EXEC

TIT=mess(13,10714,1) : #Génération du fichier DUCS
Call OUVRE_TRACE(TIT) From LECFIC
Call ECR_TRACE(TIT,0) From GESECRAN
#Organisme traité :
Call ECR_TRACE(mess(9,10714,1)-":"-[M:DIA]ORG,0) From GESECRAN

SYMBOLE = "DUCS"+GUSER+format$("D:"+GFMDAT4,date$)+"\"+[M:DIA]FILNAM
Lock =SYMBOLE
#Opération en cours sur un autre poste
If fstat : GMESSAGE=mess(30,100,1): Return : Endif

CRITFCY="1=1"
If [M:DIA]ALLFCY<>2  #site déclarant
 CRITFCY -= '& FCY="'+[M:DIA]FCY+'"'
Endif

OK=1
Gosub OUVRE_FICHIER
If OK
 Gosub TR1
 If !OK
  #Aucune société à traiter
  Call ECR_TRACE(mess(6,10714,1),0) From GESECRAN
 Endif
 Gosub FERME_FICHIER
Endif

Call FERME_TRACE From LECFIC
Return

#########################################
$TR1
NBDEB=0 : EXISTE=0
Raz OLDCPY
Gosub TABLESITE
For [F:FGR]FGR0 Where CPY=[M:DIA]CPY & evalue(CRITFCY)
 Read [F:FCY]FCY0=[F:FGR]FCY
 If !fstat
  Read [F:CPY]CPY0=[F:FCY]LEGCPY
  If !fstat
   GCURLEG=[F:CPY]LEG
   Read[F:DCS]DCS0=[F:FCY]LEGCPY;[F:FCY]FCY;[M:DIA]ORG;[M:DIA]STRDAT;[M:DIA]ENDDAT
   If !fstat
    If OLDCPY<>[F:CPY]CPY
     If OLDCPY<>"" : Gosub TR2 : Endif
     OLDCPY=[F:CPY]CPY
     DEVISE=[F:CPY]ACCCUR
     Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
     Call ECR_TRACE(mess(42,10702,1)-[F:CPY]CPY-[F:CPY]CPYNAM,0) From GESECRAN
     Gosub PARAM_GEN
     If OK
      SITE=[F:FCY]FCY
      Gosub ENREG_DEB
      #On commence toujours par le site déclarant
      If find([F:DUC]FCYDCL, TABSIT(0..NBSIT))
       Read [F:FCY]FCY0=[F:DUC]FCYDCL
       If fstat : OK=0 : Break : Endif
       SOCIETE=[F:CPY]CPY
       SITE=[F:FCY]FCY
       If [M:DIA]FLGNEA=2
        #74772
        #Gosub VERIFSITE
        EXISTE=1
        #
       Else
        Gosub RECUP_BORD
        If NUMBORD="921" | NUMBORD="923" | NUMBORD="926" | NUMBORD="929" | FLGGRP
         Gosub TOTPGSITE
        Else
         Gosub TOTSITE
        Endif
       Endif
       If EXISTE :  Gosub ENREG_EN : Endif
      Endif
     Endif
    Endif
    If [F:FGR]FCY<>[F:DUC]FCYDCL
     Read [F:FCY]FCY0=[F:FGR]FCY
     If !fstat
      Read [F:CPY]CPY0=[F:FCY]LEGCPY
      If !fstat
       SOCIETE=[F:CPY]CPY
       SITE=[F:FCY]FCY
       #74772
       If [M:DIA]FLGNEA=2
        EXISTE=1
        Gosub ENREG_EN
       #
       Else
         If NUMBORD="921" | NUMBORD="923" | NUMBORD="926" | NUMBORD="929" | FLGGRP
          Gosub VIDE_COT
          #En mode IRC/IP regroupé on ne remet pas les entêtes sites secondaires.
          If !FLGGRP : Gosub ENREG_EN : Endif
         Else
          Gosub TOTSITE
          If EXISTE :  Gosub ENREG_EN : Endif
         Endif
       Endif
      Endif
     Endif
    Endif
   Else
    #Aucune donnée DUCS à déclarer
    Call ECR_TRACE(mess(42,10702,1)-[F:CPY]CPY-"-"-mess(43,10702,1)-[F:FCY]FCY-"-"-num$([M:DIA]STRDAT)-"-"-num$([M:DIA]ENDDAT)-mess(23,10714,1),1) From GESECRAN
   Endif
  Endif
 Endif
Next

If !OK : Return : Endif
If EXISTE : Gosub TR2       : Endif
If NBDEB  : Gosub ENREG_FIN : Endif
Return

#########################################
$PARAM_GEN
OK=1
#Recherche du paramètrage exact
Read [F:DUC]DUC0=[M:DIA]CAI;[F:CPY]CPY
If fstat
 CRITPAR="CPY='"+[F:CPY]CPY+"'"
 #Recherche paramètrage exact
 Case [M:DIA]CAI
  When 1   : CRITPAR-='& CAI='+num$(GINDURS)
  When 2   : CRITPAR-='& CAI='+num$(GINDASS)
  When Default  : CRITPAR-='& CAI<>'+num$(GINDURS)-'& CAI<>'+num$(GINDASS)
 Endcase
 Filter [F:DUC] Where evalue (CRITPAR)
 Read [F:DUC]DUC0 First
 Filter [F:DUC]
 If fstat
  #Opération impossible - Paramétrage de la DUCS non défini
  Call ECR_TRACE(mess(4,10714,1)-":"-mess(2,45,1)-[F:CPY]CPY-mess(43,137,1),1) From GESECRAN
  OK=0  : Return
 Endif
Endif
Return

#########################################
$TABLESITE
Raz TABSIT : NBSIT=0
For [F:FGR]FGR0 Where CPY=[M:DIA]CPY & evalue(CRITFCY)
 TABSIT(NBSIT)= [F:FGR]FCY
 NBSIT+=1
Next
Return

#########################################
$TR2
#Une déclaration Néant peut être accompagnée d'un télérèglement pour IRC à cause des Mtt DEBIT & CREDIT
If OK & [M:DIA]GENPAI=2 & ([M:DIA]FLGNEA<>2 | CREDIT | DEBIT )
 #Le montant du paiement doit inclure l'acompte (credit à déduire) et la régul (débit à ajouter)
 AMTTOT+=CREDIT+DEBIT
 #Imposible de faire un paiement négatif !
 If AMTTOT<0 : AMTTOT=0 : Endif

 #Si une régul Urssaf alors le paiment=la régul
 If [M:DIA]CAI=1 & AMTTOTREG>0 : AMTTOT=AMTTOTREG : Endif

 NUMBANK=0 : Gosub ENREG_PAI
 #Deux banques de paiement = deux enreg "PAI"
 If MAXAMT<>0 & MAXAMT<AMTTOT
  NUMBANK=1 : Gosub ENREG_PAI
 Endif
 #Regularisation crédit à déduire
 If CREDIT<>0
  Call ECR_TRACE("",0) From GESECRAN
  Call ECR_TRACE(mess(14,10714,1)-num$(abs(CREDIT))-DEVISE,0) From GESECRAN
 Endif
 #Regularisation debit à ajouter
 If DEBIT<>0
  Call ECR_TRACE("",0) From GESECRAN
  Call ECR_TRACE(mess(15,10714,1)-num$(abs(DEBIT))-DEVISE,0) From GESECRAN
 Endif
Endif
Call ECR_TRACE("",0) From GESECRAN
#Total des cotisations à payer
Call ECR_TRACE(mess(7,10714,1)-num$(AMTTOT)-DEVISE,0) From GESECRAN
If AMTTOTREG<>0
 #Dont une régularisation :
 Call ECR_TRACE("("+mess(22,10714,1)-num$(AMTTOTREG)-DEVISE+")",0) From GESECRAN
Endif
Return

###########################################################################################################################
#                                                    ENREG_DEB
###########################################################################################################################
$ENREG_DEB
#On fait le TOTGENERAL même pour les déclarations Néant à cause des totaux DEBIT et CREDIT pouvant être <>0
Gosub TOTGENERAL
Gosub RECUP_BORD
If !GOK : Return : Endif
Case [M:DIA]CAI
  When 1 : Gosub ENREG_DEB From TURSSAF
  When 2 : Gosub ENREG_DEB From TASSEDIC
  When Default : Gosub ENREG_DEB From TARRCO
Endcase
NBDEB+=1
Return

# Totaux Société (Enreg GEN)
# Total de toutes les cotisations déclarées
#########################################
$TOTGENERAL
Gosub VIDE_COT
AMTTOT=0 : AMTTOTREG=0 : AMTMSS=0 : EFFMRK=0 : EFFPAY=0 : CREDIT=0 : DEBIT=0 : NBLIGN=0
For [FCY]FCY0 Where LEGCPY=[F:CPY]CPY
 If find([F:FCY]FCY, TABSIT(0..NBSIT))
  Read[F:DCS]DCS0=[F:FCY]LEGCPY;[F:FCY]FCY;[M:DIA]ORG;[M:DIA]STRDAT;[M:DIA]ENDDAT
  If !fstat
   For [F:DCL]DCL0 Where CPY=[F:DCS]CPY & FCY=[F:DCS]FCY & CAI=[F:DCS]CAI & ORG=[F:DCS]ORG & STRDAT=[F:DCS]STRDAT & ENDDAT=[F:DCS]ENDDAT
    #On fait bien la sommes des arrondi pour que le cumul des lignes correspondent (arrondi de chaque montant ligne)
    AMTTOT+=arr([F:DCL]AMT3,1)
    AMTTOTREG+=arr([F:DCL]AMT4,1)
    If [F:DCL]AMT4<0
     CREDIT+=arr([F:DCL]AMT4,1) :#crédit à déduire
    Else
     DEBIT+=arr([F:DCL]AMT4,1)  :#débit à ajouter
    Endif
    # Juste pour avoir le nb de lignes exacte déclarées pour les IRC/IP !
    If [M:DIA]CAI>2
     Read[F:TDU]TDU0=GUSER;SITE;[F:DCL]CAI;[F:DCL]CODDCS;[F:DCL]RAT;[F:DCL]RATWAC;[F:DCL]ORGCOD;[F:DCL]PERDEB;[F:DCL]LIBREF1
     If fstat=5
      Raz [F:TDU]
      [F:TDU]=[F:DCL]
      [F:TDU]FCY=SITE
      [F:TDU]USR=GUSER
      [F:TDU]CREDAT=date$
      Write [F:TDU]
      NBLIGN+=1
     Endif
    Endif
   Next
   AMTMSS+=arr([F:DCS]TOTMSS,1)

   #Transport
   For [F:DCT]DCT0 Where CPY=[F:DCS]CPY & FCY=[F:DCS]FCY & CAI=[F:DCS]CAI & ORG=[F:DCS]ORG & STRDAT=[F:DCS]STRDAT & ENDDAT=[F:DCS]ENDDAT
    For ITRS=0 To 2
     AMTTOT+=arr(([F:DCT]TRSBAS(ITRS)*[F:DCT]TRSRAT(ITRS))/100,1)
    Next ITRS
   Next DCT

   #Taxe s/ transport
   For [F:DCX]DCX0 Where CPY=[F:DCS]CPY & FCY=[F:DCS]FCY & CAI=[F:DCS]CAI & ORG=[F:DCS]ORG & STRDAT=[F:DCS]STRDAT & ENDDAT=[F:DCS]ENDDAT
    For ITRS=0 To 2
     AMTTOT+=arr(([F:DCX]TATBAS(ITRS)*[F:DCX]TATRAT(ITRS))/100,1)
    Next ITRS
   Next DCX

   #On ajoute les effectifs de la dernière période déclarée par site...-> Donc en dehors de la boucle !!!
   EFFPAY+=[F:DCS]NBREMPPAY
   EFFMRK+=[F:DCS]NBREMPMRK     #= aussi effectif au 31/12 si déclaration annuelle...
  Endif
 Endif
Next
If [M:DIA]CAI<3 : DEBIT=0 : CREDIT=0 : Endif
MAXAMT = arr([M:DIA]AMTMAX,1)
#Il faut avoir coché la case Régul !!!
If [M:DIA]FLGREG<>2 : AMTTOTREG=0 : Endif
Return

#########################################
$RECUP_BORD
GOK=1
Read[F:ADI]CODE=[M:DIA]NUMADI;[M:DIA]TYPFRM
If !fstat
 NUMBORD=left$([F:ADI]A1,3)
 If right$([F:ADI]A1,len([F:ADI]A1))="G" :  FLGGRP=1 : Else :  FLGGRP=0 : Endif
 ###
Else
 Call ECR_TRACE("DEB"-mess(4,10707,1)-"ATABDIV [ADI]",1) From GESECRAN
 GOK=0 : Return
Endif
Return

#########################################
$VIDE_COT
Trbegin [TDU]
Delete [F:TDU] Where USR=GUSER & CREDAT<=date$ & CAI=[M:DIA]CAI
Commit
Return

###########################################################################################################################
#                                                    ENREG_EN
###########################################################################################################################
$ENREG_EN
Case [M:DIA]CAI
 When 1 : Gosub ENREG_EN From TURSSAF
 When 2 : Gosub ENREG_EN From TASSEDIC
 When Default : Gosub ENREG_EN From TARRCO
Endcase
If NUMBORD="921" | NUMBORD="923" | NUMBORD="926" | NUMBORD="929" | FLGGRP
  #Site XXX : Cotisations déclarées XXX
  Call ECR_TRACE(mess(43,10702,1)-[F:FCY]FCY-":"-mess(8,10714,1),0) From GESECRAN
Else
 #Site XXX : Cotisations déclarées XXX
 Call ECR_TRACE(mess(43,10702,1)-[F:FCY]FCY-":"-mess(8,10714,1)-num$(AMTFCY)-DEVISE,0) From GESECRAN
Endif
If AMTFCYREG<>0
 #Dont une régularisation de :
 Call ECR_TRACE(space$(10)+"("+mess(22,10714,1)-num$(AMTFCYREG)-DEVISE+")",0) From GESECRAN
Endif
Return

#########################################
$VERIFSITE
Raz EXISTE
Filter [F:DCL] Where CPY=SOCIETE & FCY=SITE & CAI=[M:DIA]CAI & ORG=[M:DIA]ORG & STRDAT=[M:DIA]STRDAT & ENDDAT=[M:DIA]ENDDAT
Read [F:DCL]DCL0 First
If fstat<=2 : EXISTE=1 : Endif
Filter [F:DCL]
Return

#Totaux Site (Enreg EN*)
#########################################
$TOTSITE
Raz EFFPAYFCY, EFFMRKFCY, EFFMENFCY, EFFWOMFCY
Raz EFFMENCDD, EFFWOMCDD, EFFMENCDI, EFFWOMCDI, EFFMENAPP, EFFWOMAPP, EFFMENOLD, EFFWOMOLD
Raz EFFMENDIR, EFFWOMDIR, EFFMENCES, EFFWOMCES, EFFMENCNE, EFFWOMCNE, EFFMENINT, EFFWOMINT
Raz AMTFCY, MSSFCY, AMTTRS, AMTTAT, AMTBRT, AMTFCYREG
Raz DATVERS, EXISTE
Raz GRDZE
Gosub VIDE_COT
Read[F:DCS]DCS0=SOCIETE;SITE;[M:DIA]ORG;[M:DIA]STRDAT;[M:DIA]ENDDAT
If !fstat
 For [F:DCL]DCL0 Where CPY=[F:DCS]CPY & FCY=[F:DCS]FCY & CAI=[F:DCS]CAI & ORG=[F:DCS]ORG & STRDAT=[F:DCS]STRDAT & ENDDAT=[F:DCS]ENDDAT
  EXISTE=1
  #70943 : Ajout dans l'index [F:DCL]LIBREF1
  Read[F:TDU]TDU0=GUSER;SITE;[F:DCL]CAI;[F:DCL]CODDCS;[F:DCL]RAT;[F:DCL]RATWAC;[F:DCL]ORGCOD;[F:DCL]PERDEB;[F:DCL]LIBREF1
  If fstat=5
   Raz [F:TDU]
   [F:TDU]=[F:DCL]
   [F:TDU]FCY=SITE
   [F:TDU]USR=GUSER
   [F:TDU]CREDAT=date$
   Write [F:TDU]
  Elsif fstat<=2
   [F:TDU]AMT1+=[F:DCL]AMT1
   #Pour les IRC & IP ici valeur unitaire des forfait donc NE PAS CUMULER !
   If [M:DIA]CAI<3
    [F:TDU]AMT2+=[F:DCL]AMT2
   Else
    [F:TDU]AMT2=max([F:TDU]AMT2,[F:DCL]AMT2)
   Endif
   ###
   #64132 : ajout de l'arrondi ici
   [F:TDU]AMT3+=arr([F:DCL]AMT3,1)
   [F:TDU]NBREMP1=max([F:TDU]NBREMP1,[F:DCL]NBREMP1)
   [F:TDU]NBREMP2=max([F:TDU]NBREMP2,[F:DCL]NBREMP2)
   #On prend les dernieres infos non vides...?
   If [F:DCL]PERDEB<>[0/0/0] : [F:TDU]PERDEB=[F:DCL]PERDEB : Endif
   If [F:DCL]LIBREF1<>"" :   [F:TDU]LIBREF1=[F:DCL]LIBREF1 : Endif
   If [F:DCL]LIBREF2<>"" :   [F:TDU]LIBREF2=[F:DCL]LIBREF2 : Endif
   Rewrite [F:TDU]
  Endif
  #On fait bien la sommes des arrondi pour que le cumul des lignes correspondent (arrondi de chaque montant ligne)
  AMTFCY+=arr([F:DCL]AMT3,1)
  AMTFCYREG+=arr([F:DCL]AMT4,1)
 Next DCL

 #Totaux site
 MSSFCY+=arr([F:DCS]TOTMSS,1)
 AMTBRT+=arr([F:DCS]TOTBRT,1)

 #Transport
 For [F:DCT]DCT0 Where CPY=[F:DCS]CPY & FCY=[F:DCS]FCY & CAI=[F:DCS]CAI & ORG=[F:DCS]ORG & STRDAT=[F:DCS]STRDAT & ENDDAT=[F:DCS]ENDDAT
  For ITRS=0 To 2
   AMTTRS+=arr(([F:DCT]TRSBAS(ITRS)*[F:DCT]TRSRAT(ITRS))/100,1)
  Next ITRS
 Next DCT

 #Une entreprise ne peut cotiser à la TAT sans cotiser à la TRS
 If AMTTRS>0
  #Taxe s/ transport
  For [F:DCX]DCX0 Where CPY=[F:DCS]CPY & FCY=[F:DCS]FCY & CAI=[F:DCS]CAI & ORG=[F:DCS]ORG & STRDAT=[F:DCS]STRDAT & ENDDAT=[F:DCS]ENDDAT
   For ITRS=0 To 2
    AMTTAT+=arr(([F:DCX]TATBAS(ITRS)*[F:DCX]TATRAT(ITRS))/100,1)
   Next ITRS
  Next DCX
 Endif

 #on ajoute les montant des TRS & TAT au total site
 AMTFCY+=AMTTRS+AMTTAT

 #On prend les effectifs de la dernière période déclarée par site...-> Donc en dehors de la boucle !!!
 EFFPAYFCY=[F:DCS]NBREMPPAY
 EFFMRKFCY=[F:DCS]NBREMPMRK     #= aussi effectif au 31/12 si déclaration annuelle...
 EFFMENFCY=[F:DCS]NBRMEN    : EFFWOMFCY=[F:DCS]NBRWOM
 EFFMENCDD=[F:DCS]NBRCDD(0) : EFFWOMCDD=[F:DCS]NBRCDD(1)
 EFFMENCDI=[F:DCS]NBRCDI(0) : EFFWOMCDI=[F:DCS]NBRCDI(1)
 EFFMENAPP=[F:DCS]NBRAPP(0) : EFFWOMAPP=[F:DCS]NBRAPP(1)
 EFFMENOLD=[F:DCS]NBROLD(0) : EFFWOMOLD=[F:DCS]NBROLD(1)
 EFFMENDIR=[F:DCS]NBRDIR(0) : EFFWOMDIR=[F:DCS]NBRDIR(1)
 EFFMENCES=[F:DCS]NBRCES(0) : EFFWOMCES=[F:DCS]NBRCES(1)
 EFFMENCNE=[F:DCS]NBRCNE(0) : EFFWOMCNE=[F:DCS]NBRCNE(1)

 Gosub MOTIF

 #On prend la dernière date de versement des salaires par site...->
 DATVERS=[F:DCS]DATPAYSAL
Endif

#Il faut avoir coché la case Régul !!!
If [M:DIA]FLGREG<>2 : AMTFCYREG=0 : Endif
Return


###04/02/08
#Totaux Société (Principalement pour le PG Assedic & les IRC/IP regroupé)
#########################################
$TOTPGSITE
Raz EFFPAYFCY, EFFMRKFCY, EFFMENFCY, EFFWOMFCY
Raz EFFMENCDD, EFFWOMCDD, EFFMENCDI, EFFWOMCDI, EFFMENAPP, EFFWOMAPP, EFFMENOLD, EFFWOMOLD
Raz EFFMENDIR, EFFWOMDIR, EFFMENCES, EFFWOMCES, EFFMENCNE, EFFWOMCNE, EFFMENINT, EFFWOMINT
Raz AMTFCY, MSSFCY, AMTTRS, AMTTAT, AMTBRT, AMTFCYREG
Raz DATVERS, EXISTE
Raz GRDZE
Gosub VIDE_COT
#On cumule sous le site déclarant la somme des cotisations de tous les sites de la société
For[F:DCS]DCS0 Where CPY=SOCIETE & CAI=[M:DIA]CAI & ORG=[M:DIA]ORG & STRDAT=[M:DIA]STRDAT & ENDDAT=[M:DIA]ENDDAT
 For [F:DCL]DCL0 Where CPY=[F:DCS]CPY & FCY=[F:DCS]FCY & CAI=[F:DCS]CAI & ORG=[F:DCS]ORG & STRDAT=[F:DCS]STRDAT & ENDDAT=[F:DCS]ENDDAT
  EXISTE=1
  #70943 : Ajout dans l'index [F:DCL]LIBREF1
  Read[F:TDU]TDU0=GUSER;SITE;[F:DCL]CAI;[F:DCL]CODDCS;[F:DCL]RAT;[F:DCL]RATWAC;[F:DCL]ORGCOD;[F:DCL]PERDEB;[F:DCL]LIBREF1
  If fstat=5
   Raz [F:TDU]
   [F:TDU]=[F:DCL]
   [F:TDU]FCY=SITE
   [F:TDU]USR=GUSER
   [F:TDU]CREDAT=date$
   Write [F:TDU]
  Elsif fstat<=2
   [F:TDU]AMT1+=[F:DCL]AMT1
   #Pour les IRC & IP ici valeur unitaire des forfait donc NE PAS CUMULER !
   If [M:DIA]CAI<3
    [F:TDU]AMT2+=[F:DCL]AMT2
   Else
    [F:TDU]AMT2=max([F:TDU]AMT2,[F:DCL]AMT2)
   Endif
   ###
   #64132 : ajout de l'arrondi ici
   [F:TDU]AMT3+=arr([F:DCL]AMT3,1)
   [F:TDU]NBREMP1=max([F:TDU]NBREMP1,[F:DCL]NBREMP1)
   [F:TDU]NBREMP2=max([F:TDU]NBREMP2,[F:DCL]NBREMP2)
   #On prend les dernieres infos non vides...?
   If [F:DCL]PERDEB<>[0/0/0] : [F:TDU]PERDEB=[F:DCL]PERDEB : Endif
   If [F:DCL]LIBREF1<>"" :   [F:TDU]LIBREF1=[F:DCL]LIBREF1 : Endif
   If [F:DCL]LIBREF2<>"" :   [F:TDU]LIBREF2=[F:DCL]LIBREF2 : Endif
   Rewrite [F:TDU]
  Endif
  AMTFCY+=arr([F:DCL]AMT3,1)
  AMTFCYREG+=arr([F:DCL]AMT4,1)
 Next DCL

 #Totaux site
 MSSFCY+=arr([F:DCS]TOTMSS,1)
 AMTBRT+=arr([F:DCS]TOTBRT,1)

Next DCS
#On prend les effectifs de la dernière période déclarée par site...-> Donc en dehors de la boucle !!!
EFFPAYFCY=[F:DCS]NBREMPPAY
EFFMRKFCY=[F:DCS]NBREMPMRK     #= aussi effectif au 31/12 si déclaration annuelle...
EFFMENFCY=[F:DCS]NBRMEN    : EFFWOMFCY=[F:DCS]NBRWOM
EFFMENCDD=[F:DCS]NBRCDD(0) : EFFWOMCDD=[F:DCS]NBRCDD(1)
EFFMENCDI=[F:DCS]NBRCDI(0) : EFFWOMCDI=[F:DCS]NBRCDI(1)
EFFMENAPP=[F:DCS]NBRAPP(0) : EFFWOMAPP=[F:DCS]NBRAPP(1)
EFFMENOLD=[F:DCS]NBROLD(0) : EFFWOMOLD=[F:DCS]NBROLD(1)
EFFMENDIR=[F:DCS]NBRDIR(0) : EFFWOMDIR=[F:DCS]NBRDIR(1)
EFFMENCES=[F:DCS]NBRCES(0) : EFFWOMCES=[F:DCS]NBRCES(1)
EFFMENCNE=[F:DCS]NBRCNE(0) : EFFWOMCNE=[F:DCS]NBRCNE(1)

Gosub MOTIF

#On prend la dernière date de versement des salaires par site...->
DATVERS=[F:DCS]DATPAYSAL
#On arrondi les montants
#Il faut avoir coché la case Régul !!!
If [M:DIA]FLGREG<>2 : AMTFCYREG=0 : Endif
Return

######################################
$MOTIF
For IGRD=0 To dim([F:DCS]GRDNBR)-1
  If [F:DCS]GRDNBR (IGRD)="" : Break : Endif
  Read [F:ADI]CODE=10400;[F:DCS]GRDNBR (IGRD)
  If fstat : Break : Return : Endif
  Case [F:ADI]A1
   When "ZE1" :  GRDZE(0)=1
   When "ZE2" :  GRDZE(1)=1
   When "ZE3" :  GRDZE(2)=1
   When "ZE4" :  GRDZE(3)=1
   When "ZE5" :  GRDZE(4)=1
   When "ZE6" :  GRDZE(5)=1
   When "ZE7" :  GRDZE(6)=1
   When "ZE8" :  GRDZE(7)=1
   When "ZE9" :  GRDZE(8)=1
  Endcase
 Next
Return

###########################################################################################################################
#                                                    ENREG_PAI
###########################################################################################################################
$ENREG_PAI
Case [M:DIA]CAI
  When 1 : Gosub ENREG_PAI From TURSSAF
  When 2 : Gosub ENREG_PAI From TASSEDIC
  When Default : Gosub ENREG_PAI From TARRCO
Endcase
Return

###########################################################################################################################
#                                                    ENREG_FIN
###########################################################################################################################
$ENREG_FIN
RESULTAT="FIN"
RESULTAT=RESULTAT+string$(8-len(num$(NBDEB)),"0")+num$(NBDEB)
RESULTAT=RESULTAT+space$(244)
#44415 : pour ne pas avoir le retour charriot
adxirs = ""
Wrseq toupper(ctrans(RESULTAT)) Using [FIC]
adxirs = chr$(13)+chr$(10)
Return

###########################################################################################################################
#                                            Ouverture / Fermeture du fichier txt
###########################################################################################################################
$OUVRE_FICHIER
#60118
#FICHIER = filpath(GDIRBQE,[M:DIA]FILNAM,"txt",0)
[L]FICHIER=[M:DIA]FILNAM
If [M:DIA]TYPEXP=2
# 92896 - US2135
# [L]FICHIER=filpath([V]GDIRBQE,[M:DIA]FILNAM,"txt",0)
[L]FICHIER=filpath([V]GDIRBQR,[M:DIA]FILNAM,"txt",0)
Else
 [L]FICCLI=[L]FICHIER
 Call SET_FICNAM([L]FICCLI,[L]FICHIER,[L]URL) From ORDSYS
Endif
#

Openo FICHIER,0 Using [FIC]
#Séparateur de champs
SAVIFS = adxifs
adxifs = ""
#Caractère de fin de ligne
SAVIRS = adxirs
adxirs = chr$(13)+chr$(10)
Return

#########################################
$FERME_FICHIER
Openo FICHIER Using [FIC]
adxifs = SAVIFS
adxirs = SAVIRS
#60118
If [M:DIA]TYPEXP<2
 Call COPCLI([L]FICHIER,[L]FICCLI,[L]STAT) From ORDSYS
 If [L]STAT<>0 : [L]TRA = 0 : Endif
Endif
Return

##################################################################################################################################
#                                        PARTIE COMMUNE AUX DIVERSES DECLARATIONS
##################################################################################################################################
$COMDEB1
#Date et heure de préparation
Call RECUP_DATE (date$, "AAAAMMJJ", WDAT)
RESULTAT+=WDAT
RESULTAT=RESULTAT+left$(time$,2)+mid$(time$,4,2)
#Fichier test
If [M:DIA]FLGSND=2 : RESULTAT=RESULTAT+"0" : Else : RESULTAT=RESULTAT+"1" : Endif
#Ident message + statut UNSM + No version COPAYM
RESULTAT=RESULTAT+"COPLAT"+"0"+space$(2)+"4.2"
Return

#########################################
$COMDEB2
#Ref déclaration
If len([M:DIA]REFSND)<35
 RESULTAT=RESULTAT+[M:DIA]REFSND+space$(35-len([M:DIA]REFSND))
Else
 RESULTAT=RESULTAT+left$([M:DIA]REFSND,35)
Endif
#Type réponse (non utilisé)
RESULTAT=RESULTAT+space$(3)
Return

#########################################
$COMDEB3
#No version COPLAT
RESULTAT=RESULTAT+"004"
#No edition COPLAT
RESULTAT=RESULTAT+"002"
#Réf lot
If len([M:DIA]REFLOT)<14
 RESULTAT=RESULTAT+[M:DIA]REFLOT+space$(14-len([M:DIA]REFLOT))
Else
 RESULTAT=RESULTAT+left$([M:DIA]REFLOT,14)
Endif
#Nom logiciel + nom editeur + version
RESULTAT=RESULTAT+"Sage HR Management"+space$(2)+"SAGE"+space$(16)+"V6"+space$(8)
#Indicateur de régul
If [M:DIA]FLGREG=2 & [M:DIA]NUMREG>0 :#oui
 RESULTAT=RESULTAT+"4"+space$(2)+num$([M:DIA]NUMREG)
Else
 RESULTAT=RESULTAT+space$(3)+"0"
Endif
#Filler
RESULTAT=RESULTAT+space$(31)
Return

#########################################
$RECUP_INFO
If INFO=""
 #Opération impossible - Paramétrage de la DUCS incomplet
 Call ECR_TRACE(mess(5,10714,1),1) From GESECRAN
 OK=0 : Return
Else
 If len(INFO)<35
  RESULTAT=RESULTAT+INFO+space$(35-len(INFO))
 Else
  RESULTAT=RESULTAT+left$(INFO,35)
 Endif
Endif
Return

