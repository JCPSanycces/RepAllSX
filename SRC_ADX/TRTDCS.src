Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

Call LECTURE('CPY',VALEUR,'') From CONTOBJ
GCURLEG=[F:CPY]LEG

Read[F:CPY]CPY0=VALEUR
If !fstat :
 [M:DIA]CUR=[F:CPY]ACCCUR
 Affzo [M:DIA]CUR
Endif
End

