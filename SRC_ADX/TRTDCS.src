$RECUP_EMAIL
INFO=[AIN]CNTEMA
If len (INFO)<252
 RESULTAT=RESULTAT+INFO+space$(252-len(INFO))
Else
 RESULTAT=RESULTAT+left$(INFO,252)
Endif
