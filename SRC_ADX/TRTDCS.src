$RECUP_CPY
#Nom1
If len([F:CPY2]CPYNAM)<35
 RESULTAT=RESULTAT+[F:CPY2]CPYNAM+space$(35-len([F:CPY2]CPYNAM))
Else
 RESULTAT=RESULTAT+left$([F:CPY2]CPYNAM,35)
Endif
#Nom2
RESULTAT=RESULTAT+space$(35)
#Adresse société
Read [BPA]BPA0=2;[F:CPY2]CPY;[F:CPY2]BPAADD
If fstat= 0
 Gosub RECUP_BPA
Else
 Call ECR_TRACE(mess(4,10707,1)-"BPADDRESS [BPA]",1) From GESECRAN
 OK=0 : Return
Endif
#Filler
RESULTAT=RESULTAT+space$(27)
Return

#########################################
$RECUP_BPA
If len ([F:BPA]BPAADDLIG(0))<35
 RESULTAT=RESULTAT+[F:BPA]BPAADDLIG(0)+space$(35-len([F:BPA]BPAADDLIG(0)))
Else
 RESULTAT=RESULTAT+left$([F:BPA]BPAADDLIG(0),35)
Endif
If len ([F:BPA]BPAADDLIG(1))<35
 RESULTAT=RESULTAT+[F:BPA]BPAADDLIG(1)+space$(35-len([F:BPA]BPAADDLIG(1)))
Else
 RESULTAT=RESULTAT+left$([F:BPA]BPAADDLIG(1),35)
Endif
If len ([F:BPA]CTY)<35
 RESULTAT=RESULTAT+[F:BPA]CTY+space$(35-len([F:BPA]CTY))
Else
 RESULTAT=RESULTAT+left$([F:BPA]CTY,35)
Endif
If len ([F:BPA]POSCOD)<9
 RESULTAT=RESULTAT+[F:BPA]POSCOD+space$(9-len([F:BPA]POSCOD))
Else
 RESULTAT=RESULTAT+left$([F:BPA]POSCOD,9)
Endif
Return

#########################################
$RECUP_CNT
#nom+prénom
INFO=[F:AIN]CNTLNA+space$(1)+[F:AIN]CNTFNA
If len (INFO)<35
