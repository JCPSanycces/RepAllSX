$RECUP_FCY
#Nom1
If len([F:FCY2]FCYNAM)<35
 RESULTAT=RESULTAT+[F:FCY2]FCYNAM+space$(35-len([F:FCY2]FCYNAM))
Else
 RESULTAT=RESULTAT+left$([F:FCY2]FCYNAM,35)
Endif
