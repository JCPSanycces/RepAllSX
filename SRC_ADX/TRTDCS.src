Endif
#fax
If len ([F:CNT]FAX)<25
 RESULTAT=RESULTAT+[F:CNT]FAX+space$(25-len([F:CNT]FAX))
Else
 RESULTAT=RESULTAT+left$([F:CNT]FAX,25)
