#<AdxTL>@(#)10.0.0.0 $Revision$
##########################################################################
# UTIGPA28: Init valeur code activite MWA               Module GPAO      #
##########################################################################
# GH 19/09/11                                           Bug 76248        # 
##########################################################################

Call MAJ_UTIGPA28
End

##################################
Subprog MAJ_UTIGPA28
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER="" : End : Endif
Call OUVRE_TRACE("UTIGPA28: Activity code MWA initialisation") From LECFIC
Call EXE_UTIGPA28(DOSSIER)
Call FERME_TRACE From LECFIC
Call TEMPOFF     From GESECRAN
Call LEC_TRACE From LECFIC
End

##################################
Subprog EXE_UTIGPA28(DOSSIER)
Value Char DOSSIER

Call ECR_TRACE("UTIGPA28 : Process Start on : "+DOSSIER,0) From GESECRAN

Local File =[L]DOSSIER+".ACTIV" [ACV]
If !clalev([ADA]) : Local File ADOSACT [ADA] : Endif
Local Integer I, MAJ

Read [ACV]CODACT = "MWM"
I=(!fstat & [F:ACV]FLACT=2)

If I
 Read [ACV]CODACT = "ADC"
 I=(!fstat & [F:ACV]FLACT=2)
Endif

I=1+(I<>0)
Trbegin [ACV],[ADA]
 Read [ACV]CODACT = "MWA"
 If !fstat & [F:ACV]FLACT<>I
  [F:ACV]FLACT=I
  Rewrite [ACV]
  If fstat
   # Table ... Erreur en écriture
   Call ECR_TRACE(mess(56,123,1)-"ACTIV"-":"-mess(27,125,1)-"(fstat="+num$(fstat)+")",1) From GESECRAN
   MAJ=-1
  Else
   MAJ=1 
  Endif  
 Endif
 
 If MAJ<>-1
  Read [ADA]ADA0 = [L]DOSSIER;[F:ACV]CODACT
  If !fstat & [F:ADA]FLACT<>I
   [F:ADA]FLACT = I
   Rewrite [ADA]
   If fstat
    # Table ... Erreur en écriture
    Call ECR_TRACE(mess(56,123,1)-"ADOSACT"-":"-mess(27,125,1)-"(fstat="+num$(fstat)+")",1) From GESECRAN
    MAJ=-1
   Else
    MAJ=1
   Endif
  Endif
 Endif

If MAJ<0 
 Rollback
Else    
 Commit
 If MAJ 
  # Code activité
  Call ECR_TRACE(mess(14,115,1)-"MWA ->"-mess(I,8,1),0) From GESECRAN
 Endif
Endif

Call ECR_TRACE("UTIGPA28 : Process End on : "+DOSSIER,0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat : Raz [F:ADS] : Endif
Call EXE_UTIGPA28(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
Call EXE_UTIGPA28(APPLI)
End
