#<AdxTL>@(#)1.0.0.0 $Revision$
##       Subprog EXISTE_ADX(MAC,DOS,TRT,OK)
##       Subprog COPIE_ADX(MAC1,DOS1,TRT1,MAC2,DOS2,TRT2,STAT)
##       Subprog EFFACE_ADX(MAC,DOS,TRT,STAT)
##       Subprog INFO_ADX(MAC,DOS,TRT,TYP,INFO)
##       Subprog COPIE(FICHIER1,FICHIER2,STAT)
##       Subprog COMPARE(FICHIER1,FICHIER2,STAT)
##       Subprog MOVE(FICHIER1,FICHIER2,STAT)
##       Subprog EFFACE(FICHIER,STAT)
##       Subprog ABSOLU(FICHIER,STAT)
##       Subprog C_NOMFIC(FICHIER)
##       Subprog EXISTE(FICHIER,EXISTE)
##       Subprog MACHINE(CHEMIN,MACHINE,FICHIER)
##       Subprog VOLUME(MACHINE,DOSSIER,VOLUME)
##       Subprog FICHIER(REP,NOM,EXT,APP,VOL,MAC,FICHIER)
##       Subprog IDENTIQUE(FICHIER1,FICHIER2,STAT)
##       Subprog SYSTEME2(MACHINE,ORDRE,OPT,STAT,RESULT)
##       Subprog SYSTEME(MACHINE,ORDRE,OPT,STAT)
##       Subprog GET_OS(MACHINE,OS)
##       Subprog GETENV(MACHINE,VARIA,RESULT)
##       Subprog SET_NAMCLI(FICCLI)
##       Subprog SET_FICNAM(FICCLI,FICSRV,URL)
##       Subprog MOVCLI(FICSRV,FICCLI,STAT)
##       Subprog COPCLI(FICSRV,FICCLI,STAT)
##       Subprog OPEN_HTTP(URL)
#############################################
# Copie de l'adx d'un traitement
#############################################
Subprog COPIE_ADX(MAC1,DOS1,TRT1,MAC2,DOS2,TRT2,STAT)
Value Char MAC1,DOS1,TRT1,MAC2,DOS2,TRT2
Variable Integer STAT
Local Integer RAC1 , RAC2
Local Char    ORDSYS(250) , OPT(10)
Local Char    FIC1(GDIMFIC) , FIC2(GDIMFIC)
Local Char    SRC1(GDIMFIC) , SRC2(GDIMFIC)
If TRT1="" or TRT2=""
 STAT = 1 : End
Endif
If MAC1="" & DOS1=""
 FIC1 = filpath("TRT",TRT1,"adx")
 SRC1 = filpath("TRT",TRT1,"src")
 RAC1 = (filinfo(filpath("FIL","ADOSSIER","fde",nomap),0)>0)
Elsif MAC1=""
 FIC1 = filpath("TRT",TRT1,"adx",DOS1)
 SRC1 = filpath("TRT",TRT1,"src",DOS1)
 RAC1 = (filinfo(filpath("FIL","ADOSSIER","fde",DOS1),0)>0)
Else
 FIC1 = filpath("TRT",TRT1,"adx",DOS1,"",MAC1)
 SRC1 = filpath("TRT",TRT1,"src",DOS1,"",MAC1)
 RAC1 = (filinfo(filpath("FIL","ADOSSIER","fde",DOS1,"",MAC1),0)>0)
Endif
If MAC2="" & DOS2=""
 FIC2 = filpath("TRT",TRT2,"adx")
 SRC2 = filpath("TRT",TRT2,"src")
 RAC2 = (filinfo(filpath("FIL","ADOSSIER","fde",nomap),0)>0)
Elsif MAC2=""
 FIC2 = filpath("TRT",TRT2,"adx",DOS2)
 SRC2 = filpath("TRT",TRT2,"src",DOS2)
 RAC2 = (filinfo(filpath("FIL","ADOSSIER","fde",DOS2),0)>0)
Else
 FIC2 = filpath("TRT",TRT2,"adx",DOS2,"",MAC2)
 SRC2 = filpath("TRT",TRT2,"src",DOS2,"",MAC2)
 RAC2 = (filinfo(filpath("FIL","ADOSSIER","fde",DOS2,"",MAC2),0)>0)
Endif
# Si la machine origine ou destination est renseignée, il faut par précaution regénérer le .adx
If (MAC1<>"" or MAC2<>"") & filinfo(SRC1,0)>0
 # Copie TRT/adx
 Call COPIE(SRC1,SRC2,STAT)
 If !STAT
  # Avant d'intégrer le traitement dans l'archive, il faut l'effacer s'il existe
  Call EFFACE_ADX(MAC2,DOS2,TRT2,STAT)
  #102739
  ORDSYS='valtrt'
  If func ADS_TOOL.ISTRUSTEDENV=[V]CST_AFALSE & func ADS_TOOL.ISTRUSTEDTRT(TRT2)=[V]CST_AFALSE
    If func VERSRUN(MAC2+string$(MAC2="",adxmac(0)))>="17r.218"
      ORDSYS-='-t'
    Endif
  Endif
  #
  If DOS2=""
   ORDSYS -= nomap-TRT2
  Else
   ORDSYS -= DOS2-TRT2
  Endif
  If MAC2=""
   Call SYSTEME(adxmac(0),ORDSYS,"",STAT)
  Else
   Call SYSTEME(MAC2,ORDSYS,"",STAT)
  Endif
 Endif
Else
 # Avant d'intégrer le traitement dans l'archive, il faut l'effacer s'il existe
 Call EFFACE_ADX(MAC2,DOS2,TRT2,STAT)
 # Copie TRT/adx
 Call COPIE(FIC1,FIC2,STAT)
 # Intégration adx dans le dossier destination
 If DOS2=""
  ORDSYS = 'archive -d'-nomap-'-t'-'-s'-'"'+TRT2+'"'
 Else
  ORDSYS = 'archive -d'-DOS2-'-t'-'-s'-'"'+TRT2+'"'
 Endif
 Call SYSTEME(MAC2,ORDSYS,"",STAT)
Endif
#If DOS2=nomap or DOS2="" : # temporaire et pourri
# adxmpr = adxmpr
#Endif
STAT = pushScript(MAC2,DOS2,TRT2)
End

#############################################
# Invalidation de l'adx d'une structure
#############################################
Subprog INVALID_STC(MAC,DOS,TRT,STAT)
Value Char MAC , DOS , TRT
Variable Integer STAT
Local Char  REP(3) , CODTRT(GLONADC) , OPT(1)
REP = "STC"
OPT = "o"
#CODTRT = "_"+TRT
CODTRT = TRT
Goto INVALID_TRT

#############################################
# Effacement de l'adx d'une structure
#############################################
Subprog EFFACE_STC(MAC,DOS,TRT,STAT)
Value Char MAC , DOS , TRT
Variable Integer STAT
Local Char  REP(3) , CODTRT(GLONADC) , OPT(1)
REP = "STC"
OPT = "o"
#CODTRT = "_"+TRT
CODTRT = TRT
Goto EFFACE_TRT

#############################################
# Effacement de l'adx d'un traitement
#############################################
Subprog EFFACE_ADX(MAC,DOS,TRT,STAT)
Value Char MAC , DOS , TRT
Variable Integer STAT
Local Char  REP(3) , CODTRT(GLONADC) , OPT(1)
REP = "TRT"
OPT = "t"
CODTRT = TRT

$EFFACE_TRT
Local Char    ORDSYS(250) , FIC(GDIMFIC)
If TRT="" : STAT = 1 : End : Endif
If DOS=""
 ORDSYS = 'archive -d'-nomap-'-'+OPT-'-e'-'"'+CODTRT+'"'
Else
 ORDSYS = 'archive -d'-DOS-'-'+OPT-'-e'-'"'+CODTRT+'"'
Endif
If MAC=""
 Call SYSTEME(adxmac(0),ORDSYS,"",STAT)
Else
 Call SYSTEME(MAC,ORDSYS,"",STAT)
Endif
$INVALID_TRT
Local Char    ORDSYS(250) , FIC(GDIMFIC)
If DOS=nomap or DOS="": # temporaire et pourri
# adxmpr = adxmpr
#90822
#STAT = pushScript(MAC,DOS,CODTRT)
STAT = pullScript(MAC,DOS,CODTRT)
Endif
If DOS="" & MAC=""
 FIC = filpath(REP,TRT,"adx",nomap)
Elsif MAC=""
 FIC = filpath(REP,TRT,"adx",DOS)
Else
 FIC = filpath(REP,TRT,"adx",DOS,"",MAC)
Endif
Call EFFACE(FIC,STAT)
End

#############################################
# Existence de l'adx d'une structure
#############################################
Subprog EXISTE_STC(MAC,DOS,TRT,OK)
Value Char MAC , DOS , TRT
Variable Integer OK
If TRT=""
 OK = 0
Else
 OK = objectExist(MAC,DOS,TRT)
Endif
End

#############################################
# Existence de l'adx d'un traitement
#############################################
Subprog EXISTE_ADX(MAC,DOS,TRT,OK)
Value Char MAC , DOS , TRT
Variable Integer OK
If TRT=""
 OK = 0
Else
 OK = filexist(MAC,DOS,TRT)
Endif
End

############################################################
# Infos sur l'adx d'un traitement (~filinfo sur l'archive)
############################################################
Subprog INFO_ADX(MAC,DOS,TRT,TYP,INFO)
Value Char MAC , DOS , TRT
Value Integer TYP
Variable Char INFO
INFO = ""
If TRT<>""
 Case TYP
  When 20
   If DOS="" & MAC=""
    If filinfo(filpath("TRT",TRT,"adx",nomap),0)>0
     INFO = filcom("TRT",TRT,"adx",nomap)
    Endif
   Elsif MAC=""
    If filinfo(filpath("TRT",TRT,"adx",DOS),0)
     INFO = filcom("TRT",TRT,"adx",DOS)
    Endif
   Else
    If filinfo(filpath("TRT",TRT,"adx",DOS,"",MAC),0)
     INFO = filcom("TRT",TRT,"adx",DOS,"",MAC)
    Endif
   Endif
  When Default
   If DOS="" & MAC=""
    INFO = num$(filinfo(filpath("TRT",TRT,"adx",nomap),TYP))
   Elsif MAC=""
    INFO = num$(filinfo(filpath("TRT",TRT,"adx",DOS),TYP))
   Else
    INFO = num$(filinfo(filpath("TRT",TRT,"adx",DOS,"",MAC),TYP))
   Endif
 Endcase
Endif
End

#---------------------------------------------------------------------------#
# Return "17r.218" or etna... or empty
#---------------------------------------------------------------------------#
Funprog VERSRUN(MACHINE)
#---------------------------------------------------------------------------#
Value    Char    MACHINE() : # Où sera exécuté l'ordre système
Local Char WCHTMP(250)
Local Integer RES
If MACHINE="" | MACHINE=adxmac(-1) | MACHINE=adxmac(0)
 WCHTMP=ver$(0)
Else
Call SYSTEME2(MACHINE,"adonix -v","",RES,WCHTMP)
Endif
If pat(WCHTMP,"Version*")>0
 WCHTMP=func AFNC.PARTSEP(WCHTMP,2," ")
Endif
End WCHTMP

#########################################################################
Subprog COPIE_EMPTY(FICHIER1,FICHIER2,STAT)
#########################################################################
Value Char       FICHIER1()
Value Char       FICHIER2()
Variable Integer STAT
Local Integer VIDE
Goto TRT_COPIE

#########################################################################
Subprog COPIE(FICHIER1,FICHIER2,STAT)
#########################################################################
Value Char       FICHIER1()
Value Char       FICHIER2()
Variable Integer STAT

$TRT_COPIE
Local Char MAC1(GDIMFIC), MAC2(GDIMFIC)
Local Char FIC1(GDIMFIC), FIC2(GDIMFIC)
Local Char COMMANDE(30) , FICASK(GDIMFIC)
Local Char RETOUR(250) , REP2(250) , NAM(250)
Local Integer I , OK

If FICHIER1="" | FICHIER2=""
 STAT = 1 : End
Endif

Call IDENTIQUE(FICHIER1,FICHIER2,STAT)
If STAT : End : Endif

Call MACHINE(FICHIER1,MAC1,FIC1)
Call MACHINE(FICHIER2,MAC2,FIC2)

If MAC1<>"#" & MAC2<>"#"
 If MAC1=MAC2
  If filinfo(FICHIER1,0)<0
   STAT = 1
   #101513 : check file before copy
   Call ERREUR(mess(159,141,1)+"\|"+FIC1+"|") From GESECRAN
  Else
   #101513 : delete file before copy
   If filinfo(FICHIER2,0)>=0
    Call EFFACE(FICHIER2,STAT) : STAT=0
   Endif
   If vireblc(FICHIER1,4)<>FICHIER1 or vireblc(FICHIER2,4)<>FICHIER2
    STAT = 0 : Gosub COPIEFIC
   Else
    Call SYSTEME(MAC1,'ae_cp'-'"'+FIC1+'" "'+FIC2+'"','',STAT)
   Endif
   #101513 : check file copy
   If STAT | filinfo(FICHIER2,0)<0 : STAT = 2
    Call ERREUR(mess(33,143,1)+"\"+mess(159,141,1)+"\|"+FICHIER2+"|") From GESECRAN : # Erreur pendant la copie du fichier
   Endif
  Endif
 Else
  STAT = 0 : Gosub COPIEFIC
 Endif
Elsif GSERVEUR
 STAT = 2 : Call ERREUR(mess(127,100,1)) From GESECRAN : # Fonction impossible dans le contexte
Elsif GBROWS & MAC1=MAC2
 STAT = 2 : Call ERREUR(mess(127,100,1)) From GESECRAN : # Fonction impossible dans le contexte
Elsif MAC1="#"
 If GRELCLI>="15c.007" or GBROWS
  STAT = 0 : Gosub COPIE_CS    : # Copie client  vers serveur
 Else
  STAT = 0 : Gosub COPIEFIC
 Endif
Elsif MAC2="#"
 STAT = 0 : Gosub COPIE_SC     : # Copie serveur vers client
Endif
End

###########################################################################
# Copie hors web
###########################################################################
$COPIEFIC
Local Integer NB , COMPTE
NB = 5000
Local Libelle BUFFER(1..NB)

COMPTE = filinfo(FICHIER1,7)
If dim(VIDE)>0
 If COMPTE<0 : STAT = 1 : Return : Endif
Else
 If COMPTE<=0 : STAT = 1 : Return : Endif
Endif
GERREUR = 0
Onerrgo ERREUR From CONTROLE
Openi FICHIER1 Using [AINP]
Openo FICHIER2,0 Using [AOUT]
Onerrgo
If GERREUR : STAT=2 : GERREUR=0 : Return : Endif

Getseq NB , BUFFER Using [AINP]
While fstat=0
 COMPTE -= NB
 Putseq NB , BUFFER Using [AOUT]
 Getseq NB , BUFFER Using [AINP]
Wend
If COMPTE>0 or dim(VIDE)>0
 Putseq COMPTE , BUFFER Using [AOUT]
Endif

Openi Using [AINP]
Openo Using [AOUT]
Return

###########################################################################
# Copie serveur vers client
###########################################################################
$COPIE_SC
Call SETNAM(FICHIER2,NAM)
REP2 = left$(FICHIER2,len(FICHIER2)-len(NAM)-1)
I = instr(1,REP2,"@")
If I : REP2 = right$(REP2,I+1) : Endif
FICASK = func FILE_REMOTE(FICHIER1)
Askui RETOUR="" With  "UIAsk="+chr$(1)+"AskGetFile",
&                     "UIRemotePathFile="+chr$(1)+FICASK,
&                     "UILocalFileName="+chr$(1)+NAM,
&                     "UIOverWrite="+chr$(1)+"1",
&                     "UILocalPath=" + chr$(1)  + REP2
OK = val(RETOUR)
I = instr(1,RETOUR,",")
If    OK=0 : STAT = 1
Elsif OK=1 : STAT = 0 : If I : FICHIER2 = right$(RETOUR,I+1) : Endif
Else       : STAT = 2
Endif
Return

###########################################################################
# Copie Client vers serveur
###########################################################################
$COPIE_CS
Call SETNAM(FICHIER2,NAM)
REP2 = left$(FICHIER2,len(FICHIER2)-len(NAM)-1)
FICASK = func FILE_REMOTE(REP2)
Askui RETOUR="" With  "UIAsk="+chr$(1)+"AskPutFile",
&                     "UILocalFileName="+chr$(1)+FIC1,
&                     "UILocalFileExts="+chr$(1)+"",
&                     "UIRemoteFileName="+chr$(1)+NAM,
&                     "UIRemotePath="+chr$(1)+FICASK,
&                     "UIRemoteOverWrite="+chr$(1)+"1"
OK = val(RETOUR)
I = instr(1,RETOUR,",")
If    OK=0 : STAT = 1
Elsif OK=1 : STAT = 0 : If I : FICHIER1 = right$(RETOUR,I+1) : Endif
Else       : STAT = 2
Endif
Return

#########################################################################
Funprog FILE_REMOTE(CHEMIN)
Value Char CHEMIN
Local Integer I
Local Char    NAM(GDIMFIC) , SRV(GDIMFIC) , FIC(GDIMFIC)
I = instr(1,CHEMIN,"@")
If I
 FIC = right$(CHEMIN,I+1)
 SRV = left$(CHEMIN,I-1)
 If !instr(1,SRV,":")
  SRV += ":"+num$(adxtcp)
 Endif
 NAM = "!"+FIC+",,,,,"+SRV
Else
 NAM = CHEMIN
Endif
End NAM

#################################################################################
Subprog SETNAM(NOMFIC,NAM)
Value    Char NOMFIC : # Nom fichier saisi (avec ou sans chemin)
Variable Char NAM    : # Nom du fichier sans chemin et avec l'extension
Local Integer I
Local Char    CHAINE(250)
CHAINE = NOMFIC
I = max(instr(1,CHAINE,"/"),instr(1,CHAINE,"\"))
While I
 CHAINE = right$(CHAINE,I+1)
 I = max(instr(1,CHAINE,"/"),instr(1,CHAINE,"\"))
Wend
NAM = CHAINE
End

#########################################################################
Subprog COMPARE(FICHIER1,FICHIER2,DIF)
#########################################################################
Value Char       FICHIER1()
Value Char       FICHIER2()
Variable Integer DIF
Local Integer STAT , NB
NB = 5000
DIF = 0

Local Libelle BUFFER1(1..NB) , BUFFER2(1..NB)
Local Char MAC1(GDIMFIC), MAC2(GDIMFIC)
Local Char FIC1(GDIMFIC), FIC2(GDIMFIC)

Call MACHINE(FICHIER1,MAC1,FIC1)
Call MACHINE(FICHIER2,MAC2,FIC2)

If (MAC1="#" or MAC2="#") & ((GBROWS & !GADXLOC) or GSERVEUR)
 STAT = 1 : End
Endif

NB = 5000
DIF = 0

Call IDENTIQUE(FICHIER1,FICHIER2,STAT)
If STAT : End : Endif

If filinfo(FICHIER1,7)<=0 : DIF = 1 : End : Endif
If filinfo(FICHIER2,7)<=0 : DIF = 1 : End : Endif

Onerrgo ERREUR From CONTROLE
Openi FICHIER1 Using [UN_]
Openi FICHIER2 Using [DEU_]
Onerrgo
If GERREUR : DIF = 2 : GERREUR = 0 : End : Endif

Getseq NB , BUFFER1 Using [UN_]
Getseq NB , BUFFER2 Using [DEU_]
While fstat=0
 If sum(BUFFER2)<>sum(BUFFER1)
  DIF = 1 : Break
 Endif
 Getseq NB , BUFFER1 Using [UN_]
 Getseq NB , BUFFER2 Using [DEU_]
Wend
If !DIF & sum(BUFFER2)<>sum(BUFFER1)
 DIF = 1
Endif

Openi Using [UN_]
Openi Using [DEU_]
End

#########################################################################
Subprog MOVE_EMPTY(FICHIER1,FICHIER2,STAT)
#########################################################################
Value Char       FICHIER1()
Value Char       FICHIER2()
Variable Integer STAT
Local Integer VIDE
Goto TRT_MOVE

#########################################################################
Subprog MOVE(FICHIER1,FICHIER2,STAT)
#########################################################################

Value Char       FICHIER1()
Value Char       FICHIER2()
Variable Integer STAT

$TRT_MOVE
Call IDENTIQUE(FICHIER1,FICHIER2,STAT)
If STAT : End : Endif

Local Char MAC1(GDIMFIC), MAC2(GDIMFIC)
Local Char FIC1(GDIMFIC), FIC2(GDIMFIC)

Call MACHINE(FICHIER1,MAC1,FIC1)
Call MACHINE(FICHIER2,MAC2,FIC2)

If (MAC1="#" or MAC2="#") and (GSERVEUR or (GBROWS & !GADXLOC))
 STAT = 2 : Call ERREUR(mess(127,100,1)) From GESECRAN : # Fonction impossible dans le contexte
Else
 If MAC1=MAC2
  #101513 : check file before copy
  If filinfo(FICHIER1,0)<0 : STAT = 1
   Call ERREUR(mess(159,141,1)+"\|"+FIC1+"|") From GESECRAN
   End
  Endif
  #101513 : delete file before copy
  If filinfo(FICHIER2,0)>=0
   Call EFFACE(FICHIER2,STAT) : STAT=0
  Endif
  Call SYSTEME(MAC1,'ae_mv'-'"'+FIC1+'" "'+FIC2+'"',"",STAT)
  #101513 : check file after copy
  If STAT | filinfo(FICHIER2,0)<0 : STAT = 2
   Call ERREUR(mess(33,143,1)+"\"+mess(159,141,1)+"\|"+FIC2+"|") From GESECRAN : # Erreur pendant la copie du fichier
  Endif
 Else
  STAT = 0
  Gosub COPIEFIC
  If !STAT
   Call EFFACE(FICHIER1,STAT)
  Endif
 Endif
Endif
End

#########################################################################
Subprog IDENTIQUE(FICHIER1,FICHIER2,STAT)
#########################################################################

Value    Char FICHIER1()
Value    Char FICHIER2()
Variable Integer STAT
Local Char MAC1(GDIMFIC), MAC2(GDIMFIC)
Local Char FIC1(GDIMFIC), FIC2(GDIMFIC)

Call MACHINE(FICHIER1,MAC1,FIC1) From ORDSYS
Call MACHINE(FICHIER2,MAC2,FIC2) From ORDSYS

##  WIN JP / PP
##  Pour l'instant test sur le numéro d'inode
##  pour savoir si deux chemins pointent
##  sur un seul et même fichier existant

If MAC1="#" or MAC2="#" : STAT = 0 : End : Endif

Local Integer INODE1, INODE2
INODE1 = filinfo(FICHIER1,1)
INODE2 = filinfo(FICHIER2,1)

#109519
#If INODE1>0 & INODE2>0 & INODE1=INODE2
If MAC1=MAC2 & INODE1>0 & INODE2>0 & INODE1=INODE2
 STAT = 1
Else
 STAT = 0
Endif
End

#########################################################################
Subprog EFFACE(FICHIER,STAT)
#########################################################################

Value Char       FICHIER()
Variable Integer STAT

Local Char MAC1(GDIMFIC), FIC1(GDIMFIC)

Call MACHINE(FICHIER,MAC1,FIC1)

If MAC1="#" & ((GBROWS & !GADXLOC) or GSERVEUR)
 Call ERREUR (mess(127,100,1)) From GESECRAN : # Fonction impossible dans le contexte
 STAT = 1 : End
Endif

# Optimisations du delete en version >=16r214     CC - 14/06/2011

If MAC1<>"#" & func AFNC.PARTSEP(ver$(0),2," ")>="16r.214" & instr(1,FIC1,"*")<=0
 STAT = Delfile(FICHIER)
Else
 Call SYSTEME(MAC1,'ae_rm'-'"'+FIC1+'"',"",STAT)
Endif
End

#################################################
Subprog ABSOLU(FICHIER,STAT)
#################################################

Value    Char    FICHIER
Variable Integer STAT

Local Char MAC1(GDIMFIC) , FIC1(GDIMFIC) , OS(10)

Call MACHINE(FICHIER,MAC1,FIC1)
Call GET_OS(MAC1,OS)
STAT = 0
Case OS
 When "unix"
  If left$(FIC1,1)<>"/" : STAT = 1 : Endif
 When "dos"
  If !pat(left$(FIC1,3),"!:\") & left$(FIC1,2)<>"\\" : STAT = 1 : Endif
Endcase
End

#################################################
Subprog EXISTE(FICHIER,EXISTE)
#################################################

Value    Char    FICHIER
Variable Integer EXISTE
Local Char MAC1(GDIMFIC) , FIC1(GDIMFIC)
Local Integer ER

Call MACHINE(FICHIER,MAC1,FIC1)

If MAC1="#" & ((GBROWS & !GADXLOC) or GSERVEUR)
 EXISTE = 0 : End
Endif

Local Integer INFO
INFO = filinfo(FICHIER,0)

If INFO<0
 # Ce n'est pas un fichier, ni un répertoire normal, c'est peut-être un lecteur partagé
 #If MAC1="#"
 # ER = 0
 # Onerrgo ERRACSCLI
 # Openi FICHIER Using [ATST]
 # Openi Using [ATST]
 # Onerrgo
 # If ER=0 or ER=27 : # Problème d'accès sur un fichier
 #  EXISTE = 2
 # Else
 #  EXISTE = 0 : # Il n'existe vraiment pas
 # Endif
 #Else
  EXISTE = 0 : # Inexistant
 #Endif
Elsif find(int(mod(INFO/2^12,16)),0,8)=0
 EXISTE = 2 : # Répertoire
Else
 EXISTE = 1 : # Fichier normal
Endif
End

$ERRACSCLI
ER = errn
Resume

###########################################
Subprog MACHINE(CHEMIN,MACHINE,FICHIER)
###########################################

Value    Char CHEMIN()
Variable Char MACHINE()
Variable Char FICHIER()

Local Integer I

I=instr(1,CHEMIN,"@")

If I=0
 MACHINE = adxmac(0)
 FICHIER = CHEMIN
Else
 MACHINE = left$(CHEMIN,I-1)
 FICHIER = right$(CHEMIN,I+1)
Endif
End

######################################
Subprog VOLUME(MACHINE,DOSSIER,VOLUME)
######################################

Value    Char MACHINE()
Value    Char DOSSIER()
Variable Char VOLUME()

Local Char CHEMIN(GDIMFIC)
Local Char VOL(1)

VOLUME = ""
CHEMIN = filpath("","","",DOSSIER,"",MACHINE)

If CHEMIN<>"" & right$(CHEMIN,len(CHEMIN))<>"@" & filinfo(CHEMIN,0)>0
 For VOL = "0", "A", "B", "C", "D", "E", "F", "G"
  If CHEMIN = filpath("","","",DOSSIER,VOL,MACHINE)
   VOLUME = VOL : Break
  Endif
 Next VOL
Endif
End

################################################
Subprog FICHIER(REP,NOM,EXT,APP,VOL,MAC,FICHIER)
################################################

Value    Char REP()
Value    Char NOM()
Value    Char EXT()
Value    Char APP()
Value    Char VOL()
Value    Char MAC()
Variable Char FICHIER()

Local Char MACHINE(GDIMFIC)

## A-t-on préciser un numéro d'application mère ?
If APP<>"" & VOL="" & MAC=""
& & find(APP,"-1","0","1","2","3","4","5","6","7","8")
 FICHIER = filpath(REP,NOM,EXT,val(APP))
Else
 FICHIER = filpath(REP,NOM,EXT,APP,VOL,MAC)
Endif
Call MACHINE(FICHIER,MACHINE,FICHIER)
End

#################################################
Subprog GET_OS(MACHINE,OS)
#################################################

Value    Char MACHINE()
Variable Char OS()(1..)     : # 1: OS (dos/unix)
                            : # 2: Sous type OS (AIX/ULTRIX/..)
                            : # 3: Répertoire temporaire ($TMPDIR)

Local Integer I , ER
Local Char CHAINE(250) , PARAM(30) , REPDOS(GDIMFIC)

Raz OS , ER

# Histoire d'accepter les deux syntaxes (machine ou machine@)
If right$(MACHINE,len(MACHINE))="@"
 MACHINE = left$(MACHINE,len(MACHINE)-1)
Endif

## Machine où tourne adonix
If MACHINE=""
 OS(1) = GOS(0)
 If dim(OS)>1
  OS(2) = GOS2(0)
  If dim(OS)>2
   OS(3) = GREPTMP(0)
  Endif
 Endif

## Machine locale (PC)
Elsif MACHINE="!" or MACHINE="#"
 REPDOS = "C:\TEMP"
 If GRELCLI>="15c.007"
  OS(1) = "dos"
  If dim(OS)>1
   OS(2) = "w95"
   If dim(OS)>2
    If !GBROWS
     Onerrgo ERRMAC
     For PARAM="X3TempDir","X3UserTempDir","X3UserDir"
      Call PARCLI(PARAM+";",CHAINE) From GLOBVAR
      If CHAINE<>""
       OS(3) = CHAINE : Break
      Endif
     Next PARAM
     Onerrgo
    Endif
    If ER or OS(3)=""
     OS(3) = REPDOS
    Endif
   Endif
  Endif
 Else
  Onerrgo ERRMAC
  System OS = "#@ae_os"
  Onerrgo
  OS(1) = "dos"
  If dim(OS)>1
   OS(2) = "w95"
   If dim(OS)>2
    If ER
     OS(3) = REPDOS
    Elsif OS(3)="" or filinfo(filpath(OS(3),"","","","","#"),0)<0
     Call PARCLI("ClientRootDir",CHAINE) From GLOBVAR
     If filinfo(filpath(CHAINE+"Temp","","","","","#"),0)>0
      OS(3) = filpath(CHAINE+"Temp","","") : # Répertoire d'installation du client X3
     Else
      OS(3) = REPDOS
     Endif
    Endif
   Endif
  Endif
 Endif

## Autres machines
Else
 I = find(MACHINE,adxmac(0),adxmac(1),adxmac(2))
 If I
  OS(1) = GOS(I)
  If dim(OS)>1
   OS(2) = GOS2(I)
   If dim(OS)>2
    OS(3) = GREPTMP(I)
   Endif
  Endif
 Else
  ER = 0
  Onerrgo ERRMAC
  System OS = MACHINE+"@ae_os"
  Onerrgo
  If ER
   Raz OS
  Elsif dim(OS)>2 & OS(3)=""
#   Case OS(1)
#    When "unix"
#     OS(3) = "/tmp"
#    When "dos"
#     OS(3) = "C:\TEMP"
#   Endcase
   OS(3) = filpath("!tmp","","","","",MACHINE)
   OS(3) = right$(OS(3),instr(0,OS(3),"@")+1)
  Endif
 Endif
Endif
End

$ERRMAC
ER=1
Resume

#########################################################################
Subprog SYSTEME2(MACHINE,ORDRE,OPT,STAT,RESULT)
# Ici, on veut récupérer le résultat...
#########################################################################

Value    Char    MACHINE() : # Où sera exécuté l'ordre système
Value    Char    ORDRE()   : # ORDRE(0) = ordre à exécuter ou nom d'un fichier de commande si option "f"
                           : # ORDRE(1) = fichier de trace éventuel
Value    Char    OPT()     : # Options !fs&b (conversationnel/fichier/silence/backround/backround dos)
Variable Integer STAT      : # = fstat1
Variable Char    RESULT()()

Local Integer RES
RES = 1
Goto SYST

############################################################################
Subprog SYSTEME(MACHINE,ORDRE,OPT,STAT)
# Ici, on ne veut pas récupérer le résultat...
#########################################################################

Value    Char    MACHINE() : # Où sera exécuté l'ordre système
Value    Char    ORDRE()   : # ORDRE(0) = ordre à exécuter ou nom d'un fichier de commande si option "f"
                           : # ORDRE(1) = fichier de trace éventuel
Value    Char    OPT()     : # Options !fs&b (conversationnel/fichier/silence/backround/backround dos)
Variable Integer STAT      : # = 0

Local Integer RES
Local Char RESULT(1)
RES = 0

$SYST
Local Integer CMD                         : # 1=fichier (option "f"), 0=commande
Local Integer BACK                        : # 1=background (option"&"), 0=non
Local Integer CONV                        : # 1=conversationnel ("!" ou "!!"), 0=non
Local Integer REDIR                       : # 0=>/dev/null, 1=non, 2=fichier
Local Integer ZERO                        : # 1=raz fichier (option "z"), 0=non
Local Integer SILENCE                     : # 1=silencieux (options "s")
Local Char    OS_ORD(GDIMFIC)(1..3)       : # O.S. machine de l'ordre à exécuter (os/type machine/rep.temp)
Local Char    OS_CMD(10)                  : # O.S. machine du fichier de commande (dos/unix)
Local Char    OS_TRA(10)                  : # O.S. machine du fichier trace intermédiaire (dos/unix)
Local Char    IRS_ORD(5)                  : # Séparateur ligne machine ordre
Local Char    IRS_CMD(5)                  : # Séparateur ligne machine fic commande
Local Char    IRS_TRA(5)                  : # Séparateur ligne machine trace
Local Char    IRS_LEC(5)                  : # Séparateur ligne de la trace généré par l'ordre système
Local Char    SCRIPT(GDIMFIC)             : # Chemin système ordre à exécuter
Local Char    TRACE(GDIMFIC)              : # Chemin système fichier trace
Local Char    FICHIER(GDIMFIC)            : # Chemin système fichier de commande
Local Char    SORTIE(GDIMFIC)             : # Sortie standard & erreurs à l'exécution
Local Char    FICCMD(30)
Local Char    EXT(3)(1..2)
Local Char    CHEMIN(GDIMFIC)(1..2)
Local Clbfile COMMANDE(1)
Local Clbfile BIN(1)
Local Clbfile ARG(1)
Local Char    ORDSYS(250)
Local Char    MAC(GDIMFIC)(0..2)          : #
Local Char    SAVIFS(5)
Local Char    SAVIRS(5)
Local Integer STAT2 , SAVIUM

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

If instr(1,OPT,"!")
 MACHINE = ""
Endif

##  O.S. de la machine sur laquelle doit s'exécuter l'ordre ?

Call GET_OS(MACHINE,OS_ORD)

# Le répertoire temporaire doit exister

STAT = 1
If OS_ORD(3)<>""
 FICHIER = filpath(OS_ORD(3),"","","","",MACHINE)
 If MACHINE<>"#" & filinfo(FICHIER,0)<0
  # Répertoire temporaire pour les ordres systèmes inexistant
  Call ECR_TRACE("|"+FICHIER-":"-mess(138,133,1),1) From GESECRAN
  STAT = 0 : End
 Endif
Endif
If STAT & OS_ORD(3)=""
 Call ECR_TRACE(MACHINE-":"-mess(199,100,1),1) From GESECRAN : # Machine inaccessible
 STAT = 0 : End
Endif

##  Exécution conversationelle ?

If instr(1,OPT,"!")
 CONV = 1
Else
 CONV = 0
Endif

##  Fichier de commande ?

If instr(1,OPT,"f")
 CMD = 1
Else
 CMD = 0
Endif

##  Exécution silencieuse ?

If instr(1,OPT,"s")
 SILENCE = 1
Else
 SILENCE = 0
Endif

##  Exécution en arrière plan ?

If instr(1,OPT,"&")
 BACK = 1 : SILENCE = 1
Else
 BACK = 0
Endif

adxium = GASCII

If BACK
 If OS_ORD(1)="unix"
  Local Clbfile ORDRE_CLB(2)
  ORDRE_CLB = "{ trap 'exit 2' 2 ; trap '' 1 ;"-ORDRE-" & } ; echo $!"
  If GTEST
   adxifs = ""
   adxirs = GIRS(1)
   Openo filpath("",GREPTMP(1)+"/sh"+num$(adxpid),"tra") Using [AOUT]
   Wrseq ORDRE_CLB Using [AOUT]
   Openo Using [AOUT]
   adxifs = ""
   adxirs = chr$(10)
  Endif
  System RESULT = ORDRE_CLB
  End
 Else
  # Exécution en arrière plan impossible sous
  Call ERREUR(mess(137,133,1)-OS_ORD(1)) From GESECRAN
  End
 Endif
Endif

##  Exécution redirigé vers un fichier de trace ?

If dim(ORDRE)>1 & ORDRE(1)<>""
 REDIR = 2 : SILENCE = 1
Elsif !CONV & !RES
 REDIR = 0
Else
 REDIR = 1
Endif

##  Remise à zéro préalable du fichier de trace ?

If REDIR=2 & instr(1,OPT,"z")
 ZERO = 1
Else
 ZERO = 0
Endif

## Il faut fermer la trace avant de faire la commande système

If GTRACE<>"" : Openo : Endif

########################################################
##  Nomenclatures des fichiers propres à chaque O.S.  ##
########################################################

Local Char    WFICCMD(10)
Local Integer WERR
Onerrgo ERREUR
Local File AESPION [AES]
WFICCMD = format$("N0:5#",mod(uniqid([AES]),99999))
Close Local File [AES]
Onerrgo
If WERR
 WFICCMD = format$("N0:5#",time)
Endif

##  1-) Le script intermédiaire

If GTEST
 ##  JP
 ##  En mode "debug", si la machine est rapide, on souhaite tout
 ##  de même distinguer les différents fichiers cmd,
 ##  on temporise donc pour n'en perdre aucun !!
 Sleep 1
 FICCMD = "cmd"+num$(adxuid(1))+"_"+WFICCMD
Elsif GSERVEUR
 FICCMD = "cmd"+num$(adxuid(2))+"_"+WFICCMD
Else
 FICCMD = "cmd"+num$(adxuid(1))+"_"+WFICCMD
Endif
Case OS_ORD(1)
 When "unix"
  EXT(1) = "sh"  : EXT(2) = "tra" : IRS_ORD = chr$(10)
 When "dos"
  EXT(1) = "BAT" : EXT(2) = "TRA" : IRS_ORD = chr$(13)+chr$(10)
Endcase

CHEMIN(1) = filpath(OS_ORD(3),FICCMD,EXT(1),"","",MACHINE)

Call MACHINE(CHEMIN(1),MAC(1),SCRIPT)
If OS_ORD(1)="dos" & !find(left$(SCRIPT,1),'"',"'")
 SCRIPT = '"'+SCRIPT+'"'
Endif

##  2-) Le fichier de commandes

If CMD
 Call MACHINE(ORDRE(0),MAC(0),FICHIER)
 If MAC(0) <> MACHINE
  Call GET_OS(MAC(0),OS_CMD)
 Else
  OS_CMD = OS_ORD(1)
 Endif
 # JP - Le fichier de commandes généré par des programmes
 # indifférents de l'O.S., a pour délimiteur de ligne LF (chr$(10))
 # Ce fichier est passé en entrée d'ORDSYS, il n'est pas
 # directement exécuté par l'interpréteur de commandes.
 Case OS_CMD
  When "unix"
   IRS_CMD = chr$(10)
  When "dos"
   IRS_CMD = chr$(10)
 Endcase
Endif

###########################################################################################################
##  mb 13.3.3
##  En cas de redirection, la trace de l'ordre système est écrit en ascii dans une trace intermédiaire
##  A la fin de l'ordre système, on recopie cette trace en UTF8 dans le bon fichier trace
###########################################################################################################

If REDIR=2
 CHEMIN(2) = filpath(OS_ORD(3),FICCMD,EXT(2),"","",MACHINE)
 ##  On vire la machine pour ne pas avoir d'emmerdes
 Call MACHINE(CHEMIN(2),MAC(2),TRACE)
 If MAC(2) <> MACHINE
  Call GET_OS(MAC(2),OS_TRA)
 Else
  OS_TRA = OS_ORD(1)
 Endif
 IRS_LEC = chr$(10)
 Call GET_OS(MACHINE,OS_TRA)
 Case OS_TRA
  When "unix"
   IRS_TRA = chr$(10)
  When "dos"
   IRS_TRA = chr$(13)+chr$(10)
   If !find(left$(TRACE,1),'"',"'")
    TRACE = '"'+TRACE+'"'
   Endif
 Endcase
 Openo CHEMIN(2), 0 Using [AOUT]
 Openo Using [AOUT]
Endif

############################################
##  Confection d'un script intermédiaire  ##
##  pour l'exécution de l'ordre           ##
############################################

adxifs = ""
Openo CHEMIN(1), 0 Using [AOUT]
adxirs = IRS_ORD
Case OS_ORD(1)
 When "unix"
  Wrseq "trap 'exit 2' 2" Using [AOUT]
 When "dos"
  Wrseq "@ECHO OFF" Using [AOUT]
  Wrseq "BREAK OFF" Using [AOUT]
  Wrseq "chcp 1252 > nul" Using [AOUT] : # CCL 113224
  Case OS_ORD(2)
   When "w95", "dos"
    #If !CONV & !RES : Wrseq "CTTY NUL:" Using [AOUT] : Endif
  Endcase
Endcase

If !CMD
 COMMANDE = ORDRE(0) : Gosub LIGNE
Else
 Openi ORDRE(0) Using [AINP]
 adxirs = IRS_CMD : Rdseq COMMANDE Using [AINP]
 While fstat=0
  Gosub LIGNE
  adxirs = IRS_CMD : Rdseq COMMANDE Using [AINP]
 Wend
 Openi Using [AINP]
Endif

adxirs = IRS_ORD
Case OS_ORD(1)
 When "unix"
  If !CONV
   ORDSYS = "."-SCRIPT-"2>/dev/null"
  Else
   ORDSYS = "."-SCRIPT
  Endif
 When "dos"
  Case OS_ORD(2)
   When "w95", "dos"
    ORDSYS = SCRIPT
    #If !CONV & !RES : Wrseq "CTTY CON:" Using [AOUT] : Endif
   When "NT"
    If !CONV
     ORDSYS = SCRIPT-"2>NUL:"
    Else
     ORDSYS = SCRIPT
    Endif
  Endcase
  Wrseq "BREAK ON" Using [AOUT]
Endcase
Openo Using [AOUT]

If REDIR=2 & ZERO
 Openo ORDRE(1), 0 Using [AOUT]
 Openo Using [AOUT]
Endif

#########################################
##  Sortie standard & sortie d'erreur  ##
##  à l'exécution                      ##
#########################################

Raz SORTIE

Case REDIR
 When 0
  Case OS_ORD(1)
   When "unix"
    SORTIE = ">/dev/null 2>&1"
   When "dos"
    Case OS_ORD(2)
     When "NT"
      SORTIE = ">NUL: 2>&1"
    Endcase
  Endcase
 When 2
  Case OS_ORD(1)
   When "unix"
    SORTIE = ">>"-TRACE-"2>&1"
   When "dos"
    Case OS_ORD(2)
     When "NT"
      SORTIE = ">>"-TRACE-"2>&1"
    Endcase
  Endcase
Endcase

#####################################
##  Enfin, on exécute l'ordre ...  ##
#####################################

If instr(1,OPT,"!!") : # Reparamétrage + sauvegarde
 System "!!"+MACHINE+"@"+ORDSYS+SORTIE
Elsif instr(1,OPT,"!") : # Reparamétrage seulement
 System "!"+MACHINE+"@"+ORDSYS+SORTIE
Elsif RES
 System RESULT = MACHINE+"@"+ORDSYS+SORTIE
Elsif instr(1,OPT,"b") : # Pour les ordres backround sous dos (exemple serveur batch)
 System MACHINE+"@"+ORDSYS+SORTIE
Else
 System COMMANDE = MACHINE+"@"+ORDSYS+SORTIE
Endif

If !RES
 STAT = 0 : # stat1 rend n'importe quoi
Else
 STAT = stat1 : # Dans ce cas là, c'est bon
Endif

###################################
##  On fait le ménage en virant  ##
##  le script intermédiaire      ##
###################################

If !GTEST
 System COMMANDE = MACHINE+'@ae_rm'-SCRIPT
Endif

############################################
##  On réinjecte la trace de l'exécution  ##
##  dans le bon fichier de trace          ##
############################################

Local Integer WERR , ESSAI
ESSAI = 0

$REDIR
WERR = 0
ESSAI += 1
Onerrgo ERREUR
If REDIR=2
 adxifs = ""
 adxirs = IRS_LEC
 If ESSAI=2 : adxium = GASCII : Else : adxium = GUTF8 : Endif
 Openi CHEMIN(2), 0 Using [AINP]
 Openo ORDRE(1) Using [AOUT]
 Rdseq COMMANDE Using [AINP]
 If WERR & ESSAI=1 : Goto REDIR : Endif
 While fstat=0
  adxirs = IRS_TRA
  If ESSAI=2 : adxium = GUTF8 : Endif
  Wrseq COMMANDE Using [AOUT]
  adxirs = IRS_LEC
  If ESSAI=2 : adxium = GASCII : Endif
  Rdseq COMMANDE Using [AINP]
  If WERR & ESSAI=1 : Break : Endif
 Wend
 If WERR & ESSAI=1 : Goto REDIR : Endif
 If COMMANDE<>""
  adxirs = IRS_TRA
  If ESSAI=2 : adxium = GUTF8 : Endif
  Wrseq COMMANDE Using [AOUT]
 Endif
 Openo Using [AOUT]
 Openi Using [AINP]
 If !GTEST
  System COMMANDE = MACHINE+'@ae_rm'-TRACE
 Endif
Endif
Onerrgo

adxirs = SAVIRS
adxifs = SAVIFS
adxium = SAVIUM

If GTRACE<>""
 Openo filpath("TRA",GTRACE,"tra",0) , -1
Endif
End

##################################

$LIGNE
adxirs = IRS_ORD
If COMMANDE = ""
 Wrseq Using [AOUT]
Else
 Case REDIR
  When 0, 1
   Case OS_ORD(1)
    When "unix"
     Wrseq COMMANDE Using [AOUT]
    When "dos"
     Wrseq "CALL"-COMMANDE Using [AOUT]
   Endcase
  When 2
   Case OS_ORD(1)
    When "unix"
     Wrseq COMMANDE Using [AOUT]
    When "dos"
     Case OS_ORD(2)
      When "w95", "dos"
       BIN = vireblc(COMMANDE,3)
       ARG = right$(vireblc(COMMANDE,0),len(BIN)+1)
       If left$(BIN,3) = "ae_"
        Wrseq "CALL"-BIN - "-t" - TRACE - ARG Using [AOUT]
       Else
        Wrseq "CALL"-COMMANDE-">>"-TRACE Using [AOUT]
       Endif
      When "NT"
       Wrseq "CALL"-COMMANDE Using [AOUT]
     Endcase
   Endcase
 Endcase
Endif
Return

$ERREUR
WERR = errn
Resume

#############################################
## Récupère une variable d'environnement
#############################################
Subprog GETENV(MACHINE,VARIA,RESULT)
Value    Char MACHINE
Value    Char VARIA
Variable Char RESULT()
If MACHINE=""
 RESULT = getenv$(VARIA)
Else
 Local Char OS(20)
 Call GET_OS(MACHINE,OS)
 If OS="unix"
  System RESULT = MACHINE+"@ae_echo $"+VARIA
 Else
  System RESULT = MACHINE+"@ae_echo %"+VARIA+"%"
 Endif
Endif
End

#-------------------------------------------------------------------------------------------------#
#
# Sous-programmes permettant la gestion des fichiers sur le poste client
# - Askui (WEB et C/S)
# - Callui (Uniquement C/S)
#
#-------------------------------------------------------------------------------------------------#

####################################################################################
# Détermination du chemin complet d'un fichier sur le poste client (pour askui)
####################################################################################
Subprog SET_NAMCLI(FICCLI)
Variable Char FICCLI
Local Char REP(GDIMFIC) , NAM(250) , OS(GDIMFIC)(1..3)
If !pat(left$(FICCLI,3),"!:\") & left$(FICCLI,1)<>"#"
 REP = vireblc(GDIREXP,2)
 If REP=""
  Call GET_OS("#",OS)
  REP = OS(3)
 Endif
 Call SETNAM(FICCLI,NAM)
 If right$(REP,len(REP))<>"\"
  REP += "\"
 Endif
 FICCLI = REP+NAM
Endif
If left$(FICCLI,2)="#@"
 FICCLI = right$(FICCLI,3)
Endif
End

####################################################################################
# Détermination du nom d'un fichier sur le serveur pour copie sur le poste client
####################################################################################
Subprog SET_FICNAM(FICCLI,FICSRV,URL)
Variable Char FICCLI
Variable Char FICSRV
Variable Char URL
Local Char    NAM(250)
Local Integer K
Local Char MESSAGE(250)
Local Char SRVNAME(250)
Local Integer ASTATUS

FICSRV = "F"+timestamp$ : #SAM 99772 num$(adxuid(1))
If GFUSION & len(URL)>0
  SRVNAME =  '[TMP]/' + FICSRV
  Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
  ASTATUS = func ASYRSTO.CTL_VOLFIL(2, SRVNAME,FICSRV,E_TYPE_FILEOVERWRITE,MESSAGE)
  URL = ""
Else
 Call SET_NAMCLI(FICCLI)
 Call SETNAM(FICCLI,NAM)
 If NAM<>""
  FICSRV += "_"+NAM
 Endif
 FICSRV = filpath(nomap+"/TMP/"+FICSRV,"","","X3_PUB")
 K = instr(1,FICSRV,"X3_PUB")
 URL = GVIRTDIR+right$(FICSRV,K+6)
Endif
End

###########################################################################
# Le fichier existe-t-il sur le client ?
###########################################################################
Subprog EXICLI(FICCLI,STAT)
Variable Char FICCLI
Variable Integer STAT
Local Char    NAM(250) , REPCLI(250) , RETOUR(250) , EXT(1)
Local Integer OK , K
Call SETNAM(FICCLI,NAM)
If len(FICCLI)-len(NAM)<=0
 REPCLI = ""
Else
 REPCLI = left$(FICCLI,len(FICCLI)-len(NAM)-1)
Endif
If NAM<>""
 EXT = "1"
Endif
Askui RETOUR="" With  "UIAsk="+chr$(1)+"AskSelFile",
&                     "UILocalFileName="+chr$(1)+NAM,
&                     "UILocalFileExts="+chr$(1)+EXT,
&                     "UILocalPath="+chr$(1)+REPCLI
OK = val(RETOUR)
K = instr(1,RETOUR,",")
Case OK
 When 0       : STAT = 1                                              : # Non transféré
 When 1       : STAT = 0 : If K : FICCLI = right$(RETOUR,K+1) : Endif : # Ok
 When Default : STAT = val(RETOUR)                                    : # Erreur
Endcase
End

###########################################################################
# Move d'un fichier du serveur vers le poste client
###########################################################################
Subprog MOVCLI(FICSRV,FICCLI,STAT)
Value Char FICSRV
Variable Char FICCLI
Variable Integer STAT
Local Integer SUP
SUP = 1
Goto TRFCLI

###########################################################################
# Copie d'un fichier du serveur vers le poste client
###########################################################################
Subprog COPCLI(FICSRV,FICCLI,STAT)
Value Char FICSRV
Variable Char FICCLI
Variable Integer STAT
Local Integer SUP : SUP = 0

$TRFCLI
Local Char RESULT(250)
Local Blbfile BLOB
Local Integer SIZE
Local Char SRVFILEKEY(GDIMFIC),CLIFILEKEY(GDIMFIC)
Local Integer POS,START
Local Char    RETOUR (250) , NAM(250)
Local Char    REPCLI(GDIMFIC) , FICASK(GDIMFIC)
Local Integer K , OK
Local Char PROTOCOL(10)
If GSERVEUR
 End
Else
 STAT = filinfo(FICSRV,0)
  If STAT <=0
  STAT = 1 : End
 Endif
Endif
If GFUSION=0
 Gosub VERF_FICCLI
 Call SETNAM(FICCLI,NAM)
 If len(FICCLI)-len(NAM)<=0
  REPCLI = ""
 Else
  REPCLI = left$(FICCLI,len(FICCLI)-len(NAM)-1)
 Endif
 FICASK = func FILE_REMOTE(FICSRV)
 Askui RETOUR="" With  "UIAsk="+chr$(1)+"AskGetFile",
&                     "UIRemotePathFile="+chr$(1)+FICASK,
&                     "UILocalFileName="+chr$(1)+NAM,
&                     "UIOverWrite="+chr$(1)+"1",
&                     "UILocalPath="+chr$(1)+REPCLI
 OK = val(RETOUR)
 K = instr(1,RETOUR,",")
 Case OK
  When 0       : STAT = 1                                              : # Non transféré
  When 1       : STAT = 0 : If K : FICCLI = right$(RETOUR,K+1) : Endif : # Ok
  When Default : STAT = val(RETOUR)                                    : # Erreur
 Endcase
 If SUP
  Call EFFACE(FICSRV,K)
 Endif
Else
 #For convergence :
 POS = instr(8+1,baseUrl,"/")
 If  POS>0
  #Get the file's name on the server
  Call SETNAM(FICSRV,SRVFILEKEY) From ORDSYS
  #Read the file in a BLOB
  SIZE = filinfo(FICSRV,7)

  If len(FICCLI) and (!find(right$(FICCLI,len(FICCLI) ),'\','/'))
   Call SETNAM(FICCLI,CLIFILEKEY) From ORDSYS
  Else
   Call SETNAM(FICSRV,CLIFILEKEY) From ORDSYS
  Endif

  If SIZE
   Local Integer ASTATUS
   #FICASK = func ASYRSTO.GETFULLPATH("TMP",SRVFILEKEY)
   FICASK = func ASYRSTO.GETFULLPATH("TMP",CLIFILEKEY)
   If FICASK="" : # 111100 CCL
    Call ERREUR("TMP"-mess(341,139,1)) From GESECRAN #  : #VOLUME INEXISTANT
    STAT=1 : End
   Endif
   If FICSRV<>FICASK
    Call COPIE(FICSRV,FICASK,ASTATUS)
   Endif
   If ASTATUS=0
    STAT=0
   If(left$(toupper(baseUrl),5) = "HTTPS")
    PROTOCOL="HTTPS"
   Else
    PROTOCOL="HTTP"
   Endif
   START = len(PROTOCOL)+4 :# 8 if http, 9 if https

   # CCL 104687 SRVFILEKEY = func  ASYRJSO.ENCODE_URL(SRVFILEKEY)
   #101990:

    Callui RESULT="" With  "UIAction="+chr$(1)+"OpenFile",
&                          "UILocalDir=" + chr$(1) + PROTOCOL,
&                          "UILocalFile="+ chr$(2) +
& left$(right$(baseUrl,START),POS-START)+"/sdata"+right$(baseUrl,POS+6)+"/"
& + "$service/upload?fileName="+CLIFILEKEY
   Endif :#WRITEBLOB
  Elsif SIZE = 0
   Call ERREUR(mess(243,115,1)) From GESECRAN
   STAT = 0
  Endif: #SIZE >0
 Endif
Endif
End

$VERF_FICCLI
Gosub SET_FICDEF
If FICCLI=""
 FICCLI = FICDEF
 Call SET_NAMCLI(FICCLI)
Endif
Call SETNAM(FICCLI,NAM)
If NAM=""
 NAM = FICDEF
 If right$(FICCLI,len(FICCLI))<>"\"
  FICCLI += "\"
 Endif
 FICCLI += NAM
Endif
NAM = ""
Return

$SET_FICDEF
Local Char FICDEF(20)
FICDEF = "file.dat"
GPOINT = "ORDNOMFIC" : Gosub ENTREE From EXEFNC : # mb 13.5.8 demande 47289
Return

###########################################################################
# Copie d'un fichier du poste client vers le serveur
###########################################################################
Subprog COPSRV(FICCLI,FICSRV,STAT)
Variable Char FICCLI
Variable Char FICSRV
Variable Integer STAT
Local Char    RETOUR (250)
Local Char    REPCLI(GDIMFIC) , NAMCLI(250)
Local Char    REPSRV(GDIMFIC) , NAM(250) , FICASK(GDIMFIC)
Local Char    FICHIER1(GDIMFIC) , FICHIER2(GDIMFIC) , REPTMP(GDIMFIC)(1..3)
Local Integer K , OK
Local Char AVOLFIL(250)

If GSERVEUR : End : Endif
If GFUSION
 #upload a file from the client:
 Raz FICCLI :# use the name of the file on the client's machine
 OK = func ASYRSTO.UPLOAD(FICCLI,FICSRV)
 Case OK
  When 0       : STAT = 1 : # upload canceled
  When 1       : STAT = 0 : # upload OK
  #101513 When Default : STAT = OK : # Erreur
  When Default : STAT = 2 : # Erreur
 Endcase
Else
 Gosub VERF_FICCLI
 If FICSRV=""
  Call SET_FICNAM(FICHIER1,FICSRV,FICHIER2)
 Endif
 Call SETNAM(FICSRV,NAM)
 REPSRV = left$(FICSRV,len(FICSRV)-len(NAM)-1)
 Call SETNAM(FICCLI,NAMCLI)
 If len(FICCLI)-len(NAMCLI)<=0
  REPCLI = ""
 Else
  REPCLI = left$(FICCLI,len(FICCLI)-len(NAMCLI)-1)
 Endif
 If GRELCLI>="15c.007" or GBROWS
  FICASK = func FILE_REMOTE(REPSRV)
 Askui RETOUR="" With  "UIAsk="+chr$(1)+"AskPutFile",
&                      "UILocalFileName="+chr$(1)+NAMCLI,
&                      "UILocalPath="+chr$(1)+REPCLI,
&                      "UIRemoteFileName="+chr$(1)+NAM,
&                      "UIRemotePath="+chr$(1)+FICASK,
&                      "UIRemoteOverWrite="+chr$(1)+"1"
  OK = val(RETOUR)
  K = instr(1,RETOUR,",")
  Case OK
   When 0       : STAT = 1                                              : # Non transféré
   When 1       : STAT = 0 : If K : FICCLI = right$(RETOUR,K+1) : Endif : # Ok
   When Default : STAT = val(RETOUR)                                    : # Erreur
  Endcase
 Else
  If left$(FICCLI,1)="#" & left$(FICCLI,2)<>"#@"
   Call GET_OS("#",REPTMP)
   K = instr(1,FICCLI,"\")
   If K
    FICCLI = "#@"+REPTMP(3)+right$(FICCLI,K)
   Else
    FICCLI = "#@"+REPTMP(3)
   Endif
  Elsif left$(FICCLI,1)<>"#"
   FICCLI = "#@"+FICCLI
  Endif
  Call SELFICREP(FICCLI) From SELFICREP
  If GSTATUT=7
   STAT = 1
  Else
   Call EXISTE(FICCLI,STAT)
   If STAT<>1
    STAT = 2
   Else
    FICHIER1 = FICCLI
    FICHIER2 = FICSRV
    STAT = 0
    Gosub COPIEFIC
    If STAT<>0
     STAT = 2
    Else
     STAT = 0
    Endif
   Endif
  Endif
 Endif
Endif
End

#########################################################################
# Exécution d'une commande sur le poste client
#########################################################################
Subprog EXECLI(COMMAND,RETOUR)
Value Char COMMAND
Variable Char RETOUR
Askui RETOUR="" With  "UIAsk="+chr$(1)+"AskExecShell",
&                     "UILocalShell="+chr$(1)+COMMAND
End

#########################################################################
# Ouverture d'un lien http sur un répertoire publié du serveur
#########################################################################
Subprog OPEN_HTTP(URL)
Value Char URL
Local Char RETOUR(250)
#99671 : replace \ characters by / characters
URL = ctrans(URL,"\","/")
#101666
If GFUSION
 Local Integer K
 K = instr(1,URL,GVIRTDIR+"/"+nomap+"/")
 If K
 URL = right$(URL,K+len(GVIRTDIR+"/"+nomap+"/"))
 Endif
 Callui RETOUR="" With "UIAction="+chr$(1)+"OpenFile",
&                     "UILocalDir="+ chr$(1) +"HTTP",
&                     "UILocalFile="+ chr$(1) +URL ,
&                     "UIAdxPubSubFile="+ chr$(1) + "3"
Else
Callui RETOUR="" With "UIAction="+chr$(1)+"OpenFile",
&                     "UILocalDir="+ chr$(1) +"HTTP",
&                     "UILocalFile="+ chr$(1) +URL ,
&                     "UIAdxPubSubFile="+ chr$(1) + "1"
Endif
End

##########################################################################################################
Subprog DEFAULT_FILECLI(FICCLI,REPCLI,DOSSIER,LANG)
##########################################################################################################
# Détermination du chemin complet (sans raccourcis) d'un fichier sur le poste client d'après les
# codes répertoires réservés
#    FICCLI    : Nom complet du fichier (avec extension)
#    REPCLI    : Type de répertoire client : "Temp" - "Report" - "ReportDev" - "UserTemp"
#    DOSSIER   : Facultatif : nom du dossier si différent du dossier de connexion
#    LANG      : Facultatif : code langue si différent de langue de connexion
##########################################################################################################
Variable Char FICCLI
Value Char REPCLI , DOSSIER , LANG
Local Char REPDEV(GDIMFIC) , NAM(250)
Local Char APPKEY(250), DOS(100), LAN(10), HOST(250) , OS(GDIMFIC)(1..3)
Local Char NAMCLI(250), CLIDIR(GDIMFIC)
If !pat(left$(FICCLI,3),"!:\") & left$(FICCLI,1)<>"#"
 Call SETNAM(FICCLI,NAMCLI)
 Call PARCLI("AppHostName", HOST) From GLOBVAR
 If DOSSIER<>""
  DOS = DOSSIER
 Else
  DOS = nomap(0)
 Endif
 If LANG<>""
  LAN = LANG
 Else
  LAN = GLANGUE
 Endif
 If GRELCLI>="15c.007"
  APPKEY= ""
  If DOSSIER<>"" or LAN<>""
   APPKEY = DOS + ";" + HOST + ";" + num$(adxtcp) + ";" + LAN
  Endif
 Else
  APPKEY = DOS + ";" + HOST + ";" + num$(adxtcp) + ";" + LAN
  Call PARCLI("ClientRootDir",CLIDIR) From GLOBVAR
 Endif
 If REPCLI<>""
  If GRELCLI>="15c.007"
   Case REPCLI
    When "ReportDev" : Call PARCLI("ClientRptDevDir;"+APPKEY,REPDEV) From GLOBVAR
    When "RptDev"    : Call PARCLI("ClientRptDir;"+APPKEY,REPDEV) From GLOBVAR
    When "User"      : Call PARCLI("X3UserDir;",REPDEV) From GLOBVAR
    When "UserTemp"  : Call PARCLI("X3UserTempDir;",REPDEV) From GLOBVAR
    When "Temp"      : Call PARCLI("X3TempDir;",REPDEV) From GLOBVAR
   Endcase
   If REPDEV<>""
    FICCLI = REPDEV+"\"+NAMCLI
   Endif
  Else
   Case REPCLI
    When "ReportDev"              : Call PARCLI("ClientRptDevRDir;"+APPKEY,REPDEV) From GLOBVAR
    When "Rptdev"                 : Call PARCLI("ClientRptRDir;"+APPKEY,REPDEV) From GLOBVAR
    When "Temp","User","UserTemp" : REPDEV = "Temp"
    When Default                  : REPDEV = ""
   Endcase
   If REPDEV<>""
    FICCLI = filpath(CLIDIR+REPDEV+"/"+NAMCLI,"","","","","#")
   Else
    FICCLI = filpath(FICCLI,"","","","","#")
   Endif
  Endif
 Else
  If left$(GDIREXP,1)<>"#" & GDIREXP<>""
   REPDEV = vireblc(GDIREXP,2)
   If right$(REPDEV,len(REPDEV))<>"\"
    REPDEV += "\"
   Endif
  Else
   Call GET_OS("#",OS)
   REPDEV = OS(3)+"\"
  Endif
  FICCLI = REPDEV+NAMCLI
 Endif
Endif
If left$(FICCLI,2)="#@"
 FICCLI = right$(FICCLI,3)
Endif
End

##########################################################################################################
Subprog DELETE_FILECLI(FICCLI,REPCLI,DOSSIER,LANG,STAT)
##########################################################################################################
# Suppression d'un fichier sur poste client - compatible Client 15c.006 et < / 15c.007 et >
#    FICCLI    : Nom du fichier (avec extension)
#    REPCLI    : Type de répertoire client : "Temp" - "Report" - "ReportDev" - "UserTemp"
#    DOSSIER   : Facultatif : nom du dossier si différent du dossier de connexion
#    LANG      : Facultatif : code langue si différent de langue de connexion
#    STAT      : Statut de retour : 1 = OK - 0 = KO
##########################################################################################################
Value Char FICCLI(),REPCLI(),DOSSIER(),LANG()
Variable Integer STAT
Local Char CHEMIN(GDIMFIC)
Call FILE_CLIUTIL(1,FICCLI,REPCLI,DOSSIER,LANG,CHEMIN,STAT)
End

##########################################################################################################
Subprog EXIST_FILECLI(FICCLI,REPCLI,DOSSIER,LANG,CHEMIN,STAT)
##########################################################################################################
# Test d'existence d'un fichier sur poste client - compatible Client 15c.006 et < / 15c.007 et >
#    FICCLI    : Nom du fichier (avec extension)
#    REPCLI    : Type de répertoire client : "Temp" - "Report" - "ReportDev" - "UserTemp"
#    DOSSIER   : Facultatif : nom du dossier si différent du dossier de connexion
#    LANG      : Facultatif : code langue si différent de langue de connexion
#    CHEMIN    : Nom complet du fichier client
#    STAT      : Statut de retour : >= 0 Fichier existe - <= 0 = Fichier n'existe pas
##########################################################################################################
Value Char FICCLI(),REPCLI(),DOSSIER(),LANG()
Variable Char CHEMIN()
Variable Integer STAT
Call FILE_CLIUTIL(0,FICCLI,REPCLI,DOSSIER,LANG,CHEMIN,STAT)
End

##########################################################################################################
Subprog COPY_SRVTOCLI(ALWAYS,FICCLI,REPCLI,REMOTEFILE,DOSSIER,LANG,STAT)
##########################################################################################################
# Copie d'un fichier du serveur vers le client - compatible 15c.007 et >
#    ALWAYS    : 1 = Force le transfert - 0 = Le transfert est effectué que si nécessaire
#    FICCLI    : Nom du fichier (avec extension si besoin)
#    REPCLI    : Type de répertoire client : "Temp" - "Report" - "ReportDev" - "UserTemp"
#    REMOTEFILE: Facultatif : nom relatif du fichier serveur si emplacement/nom différent du client
#    DOSSIER   : Facultatif : nom du dossier si différent du dossier de connexion
#    LANG      : Facultatif : code langue si différent de langue de connexion
#    STAT      : Statut de retour : 1 = OK - 0 = KO
##########################################################################################################
Value Integer ALWAYS
Value Char FICCLI(),REPCLI(),REMOTEFILE(),DOSSIER(),LANG()
Variable Integer STAT
Call FILE_CALLUICOPY(1,ALWAYS,FICCLI, REPCLI,REMOTEFILE, DOSSIER,LANG,STAT)
End

##########################################################################################################
Subprog COPY_CLITOSRV(ALWAYS,FICCLI,REPCLI,REMOTEFILE,DOSSIER,LANG,STAT)
##########################################################################################################
# Copie d'un fichier du client vers le serveur - compatible 15c.007 et >
#    ALWAYS    : 1 = Force le transfert - 0 = Le transfert est effectué que si nécessaire
#    FICCLI    : Nom du fichier (avec extension si besoin)
#    REPCLI    : Type de répertoire client : "Temp" - "Report" - "ReportDev" - "UserTemp"
#    REMOTEFILE: Facultatif : nom relatif du fichier serveur si emplacement/nom différent du client
#    DOSSIER   : Facultatif : nom du dossier si différent du dossier de connexion
#    LANG      : Facultatif : code langue si différent de langue de connexion
#    STAT      : Statut de retour : 1 = OK - 0 = KO
##########################################################################################################
Value Integer ALWAYS
Value Char FICCLI(),REPCLI(),REMOTEFILE(),DOSSIER(),LANG()
Variable Integer STAT
Call FILE_CALLUICOPY(0,ALWAYS,FICCLI,REPCLI,REMOTEFILE, DOSSIER,LANG,STAT)
End

##########################################################################################################
Subprog FILE_CLIUTIL(ACCESS,FICCLI,REPCLI,DOSSIER,LANG,CHEMIN,STAT)
##########################################################################################################
# Test d'existence et suppression d'un fichier sur poste client - compatible Client 15c.006 et < 15c.007 et +
#    ACCESS    : 1 = Demande de Suppression d'un fichier - 0 = Demande test d'existence d'un fichier
#    FICCLI    : Nom du fichier (avec extension)
#    REPCLI    : Type de répertoire client : "Temp" - "Report" - "ReportDev" - "UserTemp"
#    DOSSIER   : Facultatif : nom du dossier si différent du dossier de connexion
#    LANG      : Facultatif : code langue si différent de langue de connexion
#    CHEMIN    : Nom complet du fichier client
#    STAT      : Statut de retour : > 0 OK - <= 0 = KO
##########################################################################################################

Value Integer ACCESS
Value Char FICCLI(),REPCLI(),DOSSIER(),LANG()
Variable Char CHEMIN
Variable Integer STAT

Local Char APPKEY(250), DOS(100), LAN(10), HOST(250), REPDEV(GDIMFIC), CALLU(50)
Local Char NAMCLI(250), CLIDIR(GDIMFIC) , REPERT(GDIMFIC)
Local Integer K

# Init des variables pour l'identification de l'application cible
Call PARCLI("AppHostName", HOST) From GLOBVAR
If DOSSIER<>""
 DOS = DOSSIER
Else
 DOS = nomap(0)
Endif
If LANG<>""
 LAN = LANG
Else
 LAN = GLANGUE
Endif

# Traitements
If GRELCLI>="15c.007" & (REPCLI<>"FullPath" or (REPCLI="FullPath" & GRELCLI>="15c.008"))
 # Accès fichier en utilisant les nouvelles fonctionalités du client 15c.007
 APPKEY= ""
 If DOSSIER<>"" or LAN<>""
  APPKEY = DOS + ";" + HOST + ";" + num$(adxtcp) + ";" + LAN
 Endif
 Case ACCESS
  When 1       : CALLU = "FileDelete"
  When Default : CALLU = "FileExist"
 Endcase
 Callui REPDEV="" With "UIAction=" + chr$(1) + CALLU,
&                      "UILocalDir="+ chr$(1) + REPCLI,
&                      "UILocalFile="+ chr$(1) + FICCLI,
&                      "UIAppKey="+ chr$(1) + APPKEY
 K = instr(1,REPDEV,"=")
 If K
  Case ACCESS
   When 1 : # Suppression
    Case right$(REPDEV,K+2)
     When "1"     : STAT = 0
     When Default : STAT = 1 : # Tout s'est bien passé
    Endcase
   When Default : # Existe
    Case right$(REPDEV,K+2)
     When "0"     : STAT = 0
     When Default : STAT = 1 : # Il existe
    Endcase
  Endcase
 Endif
 Case REPCLI
  When "ReportDev" : Call PARCLI("ClientRptDevDir;"+APPKEY,REPERT) From GLOBVAR
  When "RptDev"    : Call PARCLI("ClientRptDir;"+APPKEY,REPERT) From GLOBVAR
  When "User"      : Call PARCLI("X3UserDir;",REPERT) From GLOBVAR
  When "UserTemp"  : Call PARCLI("X3UserTempDir;",REPERT) From GLOBVAR
  When "Temp"      : Call PARCLI("X3TempDir;",REPERT) From GLOBVAR
  When "FullPath"  : REPERT = ""
 Endcase
 If REPERT<>""
  CHEMIN = REPERT+"\"+FICCLI
 Else
  CHEMIN = FICCLI
 Endif
Else
 # Accès "historique" au fichier via routines SADFSQ
 Call SETNAM(FICCLI,NAMCLI)
 APPKEY = DOS + ";" + HOST + ";" + num$(adxtcp) + ";" + LAN
 Call PARCLI("ClientRootDir",CLIDIR) From GLOBVAR
 Case REPCLI
  When "ReportDev"              : Call PARCLI("ClientRptDevRDir;"+APPKEY,REPERT) From GLOBVAR
  When "Rptdev"                 : Call PARCLI("ClientRptRDir;"+APPKEY,REPERT) From GLOBVAR
  When "Temp","User","UserTemp" : REPERT = "Temp"
  When Default                  : REPERT = ""
 Endcase
 If REPERT<>""
  CHEMIN = filpath(CLIDIR+REPERT+"/"+NAMCLI,"","","","","#")
 Else
  CHEMIN = filpath(FICCLI,"","","","","#")
 Endif
 Case ACCESS
  When 1       : Call EFFACE(CHEMIN,STAT)
  When Default : Call EXISTE(CHEMIN,STAT)
 Endcase
Endif
End

##########################################################################################################
Subprog FILE_CALLUICOPY(ACCESS,ALWAYS,FICCLI,REPCLI,REMOTEFILE,DOSSIER,LANG,STAT)
##########################################################################################################
# Copie d'un fichier du serveur vers le client ou du client vers le serveur - compatible 15c.007 et >
#    ACCESS    : Direction : 0 = client-->serveur - 1 = serveur-->client
#    ALWAYS    : 1 = Force le transfert - 0 = Le transfert est effectué que si nécessaire
#    FICCLI    : Nom du fichier (avec extension si besoin)
#    REPCLI    : Type de répertoire client : "Temp" - "Report" - "ReportDev" - "UserTemp"
#    REMOTEFILE: Facultatif : nom relatif du fichier serveur si emplacement/nom différent du client
#    DOSSIER   : Facultatif : nom du dossier si différent du dossier de connexion
#    LANG      : Facultatif : code langue si différent de langue de connexion
#    STAT      : Statut de retour : 1 = OK - 0 = KO
##########################################################################################################
Value Integer ACCESS, ALWAYS
Value Char FICCLI(),REPCLI(),REMOTEFILE(), DOSSIER(),LANG()
Variable Integer STAT

Local Char APPKEY(250), DOS(100), LAN(10), HOST(250), REPDEV(GDIMFIC), CALLU(50)
Local Char CLIDIR(GDIMFIC) , NAMCLI(250), REPSRV(GDIMFIC) , REPERT(GDIMFIC)
Local Integer K

# Init des variables pour l'identification de l'application cible
Call PARCLI("AppHostName", HOST) From GLOBVAR
If DOSSIER<>""
 DOS = DOSSIER
Else
 DOS = nomap(0)
Endif
If LANG<>""
 LAN = LANG
Else
 LAN = GLANGUE
Endif

# Traitements
If GRELCLI>="15c.007" & (REPCLI<>"FullPath" or (REPCLI="FullPath" & GRELCLI>="15c.008"))
 # Accès fichier en utilisant les nouvelles fonctionalités du client 15c.007
 APPKEY= ""
 If DOSSIER<>"" or LANG<>""
  APPKEY = DOS + ";" + HOST + ";" + num$(adxtcp) + ";" + LAN
 Endif
 Case ACCESS
  When 1 : # S->C
   Case ALWAYS
    When 1       : CALLU = "GetFileAlways"
    When Default : CALLU = "GetFile"
   Endcase
  When Default : # C->S
   Case ALWAYS
    When 1       : CALLU = "PutFileAlways"
    When Default : CALLU = "PutFile"
  Endcase
 Endcase
 Callui REPDEV="" With "UIAction=" + chr$(1) + CALLU,
&                      "UILocalDir="+ chr$(1) + REPCLI,
&                      "UILocalFile="+ chr$(1) + FICCLI,
&                      "UIRemoteFile="+ chr$(1) + REMOTEFILE,
&                      "UIAppKey="+ chr$(1) + APPKEY
 # Résultat
 K = instr(1,REPDEV,"=")
 If K
  Case right$(REPDEV,K+2)
   When "0" : STAT = 1
   When "1" : STAT = 0
  Endcase
 Endif
Else
 Call SETNAM(FICCLI,NAMCLI)
 APPKEY = DOS + ";" + HOST + ";" + num$(adxtcp) + ";" + LAN
 Call PARCLI("ClientRootDir",CLIDIR) From GLOBVAR
 Case REPCLI
  When "ReportDev"              : Call PARCLI("ClientRptDevRDir;"+APPKEY,REPERT) From GLOBVAR
  When "Rptdev"                 : Call PARCLI("ClientRptRDir;"+APPKEY,REPERT) From GLOBVAR
  When "Temp","User","UserTemp" : REPERT = "Temp"
  When Default                  : REPERT = ""
 Endcase
 If REPERT<>""
  REPERT = filpath(CLIDIR+REPERT+"/"+NAMCLI,"","","","","#")
 Else
  REPERT = filpath(FICCLI,"","","","","#")
 Endif
 REPSRV = filpath("","","")
 Case GOS(1)
  When "unix"  : REPSRV += "/"
  When Default : REPSRV += "\"
 Endcase
 If find(right$(REMOTEFILE,len(REMOTEFILE)),"/","\")
  REPSRV += left$(REMOTEFILE,len(REMOTEFILE)-1)
 Else
  REPSRV += REMOTEFILE
 Endif
 Case ACCESS
  When 1 : # S->C
   If ALWAYS=1
    Call EFFACE(REPERT,STAT)
   Endif
   Call COPIE(REPSRV,REPERT,STAT)
  When Default : # C->S
   If ALWAYS=1
    Call EFFACE(REPSRV,STAT)
   Endif
   Call COPIE(REPERT,REPSRV,STAT)
 Endcase
Endif
End

