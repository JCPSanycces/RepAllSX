#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion du masque CPV1
$ACTION
Case ACTION
    When "DEBUT" : Gosub DEBUT
    When Default:
Endcase
Return


$DEBUT

Close Local Mask [CPV1]

Local Char TIT(60)
Call TEXTE(14285,TIT) From OBJDIV
Local Char TITLIS(30)
Call TEXTE(14285,TITLIS) From OBJDIV
Local Char TITLIS9(30)
Call TEXTE(14285,TITLIS9) From OBJDIV
Local Char TITSEL(30)(1..5)
Call TEXTE(1344,TITSEL(1)) From OBJDIV
Call TEXTE(5968,TITSEL(2)) From OBJDIV
Call TEXTE(6076,TITSEL(3)) From OBJDIV
Call TEXTE(680,TITSEL(4)) From OBJDIV
Call TEXTE(4064,TITSEL(5)) From OBJDIV
Local Char TITSEL9(30)(1..5)
Call TEXTE(1344,TITSEL9(1)) From OBJDIV
Call TEXTE(5968,TITSEL9(2)) From OBJDIV
Call TEXTE(6076,TITSEL9(3)) From OBJDIV
Call TEXTE(680,TITSEL9(4)) From OBJDIV
Call TEXTE(4064,TITSEL9(5)) From OBJDIV



Local File WORKSTATIO [MWS]

Local Mask CPV1 [CPV1]
Local Inpbox Mask [CPV1]
& Button LISBOUT(1..NBBOUT) With ABRBOUT(1..NBBOUT) Coded CODBOUT(1..NBBOUT)
& Titled TIT
& Treebox [MWS] GAU_CHE
&  [F:MWS]WCRFCY Titled TITSEL(2),
&  [F:MWS]WCR Titled TITSEL(3),
&  [F:MWS]WST+" "+mess([F:MWS]WSTTYP,313,1)+" "+[F:MWS]WSTSHO Titled ""
&  Titled TITLIS
& As [BOI1]
Boxact [BOI1]

Filter [MWS] Where evalue(CRITERE) & evalue(FILTSUP)
Fillbox [BOI1] GAU_CHE
Filter [MWS]

Return



########################################
Subprog C_WST(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog AM_WST(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog S_WST(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog AM_WCRFCY(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog B1_NBLIG
End

########################################
Subprog AS_NBLIG
End

