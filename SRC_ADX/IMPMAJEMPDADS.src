#<AdxTL>@(#)3.0.0.0 $Revision$
######################################################################################
# Modifications :
#     MABOS - 10/06/13 - FQ74502 - US1642- Add new tab "Specialities" before "Specific"
###################################################################################
$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "AP_IMPORT" : Gosub AP_IMPORT
 When "RAZCRE"    : Gosub RAZCRE
 When "VALID"     : Gosub VALID : If GOK=0 : GERREUR=1 : Endif
 When "SAIMSK"    : Gosub SAIMSK
Endcase
Return

###################################################################################

$OUVRE
Local Integer FLGAD, FLGCPT, FLGRIB, FLGHAB, FLGEXM, FLGTRY, FLGCHD
Local Integer INDNOL
Local Decimal PAYPCT

Local Mask MAT0 [EMP0], MAT1 [EMP1], MAT2 [EMP2], MAT3 [EMP3], MAT6 [EMP6], MAT7 [EMP7],
&          MAT9 [EMP9], MAT10 [EMPA], CTR9[CTR9]
Local Mask HRMAT4 [EMP4]  :#MABOS-FQ74502-US1642-10/06/13

Gosub OUVRE From WPDEFTABLE
#Fichier utilisés par les controles
If clalev ([F:CPY])=0  : Local File COMPANY          [CPY] : Endif
If clalev ([F:FCY])=0  : Local File FACILITY         [FCY] : Endif
If clalev ([F:TCY])=0  : Local File TABCOUNTRY       [TCY] : Endif
If clalev ([F:PRF])=0  : Local File PROFIL           [PRF] : Endif
If clalev ([F:SRV])=0  : Local File SERVICE          [SRV] : Endif
If clalev ([F:WAC])=0  : Local File TRVACC           [WAC] : Endif
If clalev ([F:WAR])=0  : Local File TRVACCRAT        [WAR] : Endif
If clalev ([F:CAC])=0  : Local File GACCCODE         [CAC] : Endif
If clalev ([F:BAN])=0  : Local File BANK             [BAN] : Endif
If clalev ([F:TCU])=0  : Local File TABCUR           [TCU] : Endif
If clalev ([F:ADI])=0  : Local File ATABDIV          [ADI] : Endif
If clalev ([F:IDE])=0  : Local File EMPLOID          [IDE] : Endif
If clalev ([F:HRPOA])=0  : Local File POPULA           [HRPOA] : Endif
If clalev ([F:CCE])=0  : Local File =GTABCPT+"CACCE" [CCE] : Endif
If clalev ([F:T1])=0   : Local File EMPLOID          [T1]  : Endif
If clalev ([F:T2])=0   : Local File EMPLOAD          [T2]  : Endif
If clalev ([F:T3])=0   : Local File EMPLOCHD         [T3]  : Endif
If clalev ([F:T4])=0   : Local File EMPLORIB         [T4]  : Endif
If clalev ([F:T5])=0   : Local File EMPLOEXM         [T5]  : Endif
If clalev ([F:T6])=0   : Local File EMPLOTRY         [T6]  : Endif
If clalev ([F:T7])=0   : Local File EMPLOHAB         [T7]  : Endif
If clalev ([F:IDE])=0  : Local File EMPLOID          [IDE] : Endif
If clalev ([F:AOD])=0  : Local File AOBJEXTD         [AOD] : Endif

Filter [AOD] Where EXT=[M:DIA]MODIMP & FIL="EMPLOAD"
Read [AOD]AOD0 First
If !fstat : FLGAD=1 : Endif

Filter [AOD] Where EXT=[M:DIA]MODIMP & FIL="EMPLOCPT"
Read [AOD]AOD0 First
If !fstat : FLGCPT=1 : Endif

Filter [AOD] Where EXT=[M:DIA]MODIMP & FIL="EMPLORIB"
Read [AOD]AOD0 First
If !fstat : FLGRIB=1 : Endif

Filter [AOD] Where EXT=[M:DIA]MODIMP & FIL="EMPLOCHD"
Read [AOD]AOD0 First
If !fstat : FLGCHD=1 : Endif

Filter [AOD] Where EXT=[M:DIA]MODIMP & FIL="EMPLOEXM"
Read [AOD]AOD0 First
If !fstat : FLGEXM=1 : Endif

Filter [AOD] Where EXT=[M:DIA]MODIMP & FIL="EMPLOTRY"
Read [AOD]AOD0 First
If !fstat : FLGTRY=1 : Endif

Filter [AOD] Where EXT=[M:DIA]MODIMP & FIL="EMPLOHAB"
Read [AOD]AOD0 First
If !fstat : FLGHAB=1 : Endif

Filter [AOD]

nolign=0

Return

###################################################################################

$RAZCRE
#Initialisation des masks et des variables
Raz [M:EMP0], [M:EMP1], [M:EMP2], [M:EMP3], [M:EMP6], [M:EMP7], [M:EMP9], [M:EMPA], [M:CTR9]
Raz [M:EMP4] : #MABOS-FQ74502-US1642-10/06/13
nolign=0
Return

###################################################################################

$AP_IMPORT
If [F:ID]REFNUM=""
 If GIMP(1)=""
  # Salarié non importé; N° sécurité sociale incomplet
  Call TRACE(2,mess(63,10711,1)-GIMP(1)) From SUBIMPOBJ
  GOK=0 :  Return
 Endif
 #60944
 #Filter [T1] Where NUMSSC=GIMP(1)
 Filter [T1] Where left$(NUMSSC,13)=left$(GIMP(1),13)
 Read [T1]ID0 First
 Filter [T1]
 If fstat
  # Matricule inexistant
  Call TRACE(2,mess(00083,10702,1)-GIMP(1)) From SUBIMPOBJ
  #60944
  #Raz [F:ID]
  If [M:IMP2]TEST<>2 : Raz [F:ID] : Endif
  GOK = 0
  Return
 Else
  [F:ID]REFNUM   = [F:T1]REFNUM
  #60944
  If len(GIMP(1))>13
   [F:ID]NUMSSC = GIMP(1)
  Endif
 Endif
Endif
Return

###################################################################################

$VALID
If nolign=0 : Return : Endif
Gosub VERIF_ID From IMPORTEMP
If GOK=0 : Filter [AOD] : Return : Endif

If FLGAD
 Gosub VERIF_AD From IMPORTEMP
 If GOK=0 : Return : Endif
Endif

If FLGCPT
 Gosub VERIF_CPT From IMPORTEMP
 If GOK=0 : Return : Endif
Endif

If FLGRIB
 Gosub VERIF_RIB From IMPORTEMP
 If GOK=0 : Return : Endif
Endif

If FLGHAB
 Gosub VERIF_HAB From IMPORTEMP
 If GOK=0 :  Return : Endif
Endif

Call DEBTRANS From GLOCK
Gosub TR1
If GOK<=0 : GERREUR=1 : Goto AB_TR1 : Endif

Return

$AB_TR1
Rollback
Return
###################################################################################

$TR1
GOK=1
Trbegin [ID],[AD],[CPT],[CHD],[RIB],[HREXM],[TRY]

 Readlock[F:ID]ID0=[M:EMP0]REFNUM
 If !fstat & [M:AOE1]OPTUPD=2
  Raz[F:ID]
  [F:ID]=[M:EMP0]
  [F:ID]=[M:EMP1]
  [F:ID]=[M:EMP2]

  If FLGRIB : [F:ID]NBRRIB   = [M:EMP7]NBRRIB : Endif
  If FLGTRY : [F:ID]NBRTRY   = [M:EMP9]NBRTRY : Endif
  If FLGEXM : [F:ID]NBREXM   = [M:EMP9]NBREXM : Endif
  If FLGCHD : [F:ID]NBRCHD   = [M:EMP2]NBRCHD : Endif
  #MABOS-FQ74502-US1642-10/06/13
#  If FLGHAB : [F:ID]NBRHAB   = [M:EMP3]NBRHAB : Endif
    ZONE = "NBRHAB" : Gosub SET_ZONE From SUBEML2
  If MA Then
    If FLGHAB : [F:ID]NBRHAB   = [M]NBRHAB : Endif
  Endif
  #end MABOS-FQ74502-US1642-10/06/13
  If dim([F:ID]UPDDAT)>0 : [F:ID]UPDDAT = date$ : Endif
  If dim([F:ID]UPDUSR)>0 : [F:ID]UPDUSR = GUSER : Endif
  Rewrite [F:ID]
  Call TRACE(1,mess(80,10703,1)-[M:EMP0]REFNUM-[M:EMP0]NAM-[M:EMP0]SRN) From SUBIMPOBJ
 Endif
 If fstat
  GOK=0 : Call FSTA("ID") From GLOCK : Return
 Endif

 Readlock [F:HRPOA]POA0="";[M:EMP0]REFNUM
 If fstat=5
  Raz [F:HRPOA]
  [F:HRPOA]REFNUM = [M:EMP0]REFNUM
  Write [F:HRPOA]
 Elsif !fstat & [M:AOE1]OPTUPD=2
  [F:HRPOA]TYP=0
  Rewrite [F:HRPOA]
 Endif
 If fstat
  GOK=0 : Call FSTA("HRPOA") From GLOCK : Return
 Endif

 If FLGAD
  Readlock[F:AD]AD0=[M:EMP0]REFNUM
  If fstat=5
   Gosub AFFECT_AD From IMPORTEMP
   Write [F:AD]
  Elsif !fstat & [M:AOE1]OPTUPD=2
   Gosub AFFECT_AD From IMPORTEMP
   Rewrite [F:AD]
  Endif
  If fstat
   GOK=0 : Call FSTA("AD") From GLOCK : Return
  Endif
 Endif

 If FLGCPT
  Readlock[F:CPT]CPT0=[M:EMP0]REFNUM
  If fstat=5
   Gosub AFFECT_CPT From IMPORTEMP
   Write [F:CPT]
  Elsif !fstat & [M:AOE1]OPTUPD=2
   Gosub AFFECT_CPT From IMPORTEMP
   Rewrite [F:CPT]
  Endif
  If fstat
   GOK=0 : Call FSTA("CPT") From GLOCK : Return
  Endif
 Endif

 If FLGCHD & [M:EMP2]NBRCHD<>0 : Gosub SAUVE_CHD From IMPORTEMP : Endif
 If GOK<=0 : Return : Endif
 If FLGRIB & [M:EMP7]NBRRIB<>0 : Gosub SAUVE_RIB From IMPORTEMP : Endif
 If GOK<=0 : Return : Endif
  #MABOS-FQ74502-US1642-10/06/13
 # If FLGHAB & [M:EMP3]NBRHAB<>0 : Gosub SAUVE_HAB From IMPORTEMP : Endif
 If FLGHAB : Gosub SAUVE_HAB From IMPORTEMP : Endif

 If GOK<=0 : Return : Endif
 If FLGEXM & [M:EMP9]NBREXM<>0 : Gosub SAUVE_EXM From IMPORTEMP : Endif
 If GOK<=0 : Return : Endif
 If FLGTRY & [M:EMP9]NBRTRY<>0 : Gosub SAUVE_TRY From IMPORTEMP : Endif
 If GOK<=0 : Return : Endif

Commit
Return

###################################################################################

$SAIMSK
#Affectation des masks
Case IMPFIC
 When "ID"
  Gosub CHARGE_MASK
  # 60944
  #Filter [AOD] Where EXT=[M:DIA]MODIMP & FIL="EMPLOID" & FLD<>"/" & left$(FLD,1)<>"*"
  Filter [AOD] Where EXT=[M:DIA]MODIMP & FIL="EMPLOID" & FLD<>"/"
  For [AOD]AOD0
   # 60944
   If left$([F:AOD]FLD,1)="*"
    If [F:AOD]FLD="*1" & len([F:ID]NUMSSC)>13
     If dim([M:EMP0]NUMSSC)>0 : [M:EMP0]NUMSSC = [F:ID]NUMSSC : Endif
     If dim([M:EMP1]NUMSSC)>0 : [M:EMP1]NUMSSC = [F:ID]NUMSSC : Endif
     If dim([M:EMP2]NUMSSC)>0 : [M:EMP2]NUMSSC = [F:ID]NUMSSC : Endif
    Endif
   Else
   # fin 60944
    If evalue("dim([M:EMP0]"+[F:AOD]FLD+")")>0
     Assign "[M:EMP0]"+[F:AOD]FLD With evalue("[F:ID]"+[F:AOD]FLD)
    Endif
    If evalue("dim([M:EMP1]"+[F:AOD]FLD+")")>0
     Assign "[M:EMP1]"+[F:AOD]FLD With evalue("[F:ID]"+[F:AOD]FLD)
    Endif
    If evalue("dim([M:EMP2]"+[F:AOD]FLD+")")>0
     Assign "[M:EMP2]"+[F:AOD]FLD With evalue("[F:ID]"+[F:AOD]FLD)
    Endif
   Endif
  Next
  Filter [AOD]
  #################
  # 70311 : 2 news fiels in EMPLOID (no required)
  # NCKNAM & BDFECOCOD
  # if we have surnam & first name without the nickname, we build it
  If dim([M:EMP2]NCKNAM)>0 & [M:EMP2]NCKNAM=""
   [M:EMP2]NCKNAM=toupper(left$([M:EMP0]SRN,2)+left$([M:EMP2]OLDNAM,3))
  Endif
  # Nothing to do for BDFECOCOD
  #################

 When "CHD"
  [M:EMP2]NBRCHD += 1
  nolign = [M:EMP2]NBRCHD
  [M:EMP2] = [F:CHD]

 When "AD"
   Filter [AOD] Where EXT=[M:DIA]MODIMP & FIL="EMPLOAD" & FLD<>"/"
   For [AOD]AOD0
    If evalue("dim([M:EMP3]"+[F:AOD]FLD+")")>0
     Assign "[M:EMP3]"+[F:AOD]FLD With evalue("[F:AD]"+[F:AOD]FLD)
    Endif
   Next
   Filter [AOD]

 When "CPT"
  [M:EMP7]NBAXE = GOPTCANA
  [M:EMP7] = [F:CPT]
  If [M:EMP7]DSP=""
  If GOPTCANA>=1
   [M:EMP7]SECTION(0) = [F:CPT]CCE1 : [M:EMP7]REINIT(0) = [F:CPT]INICCE1
  Endif
  If GOPTCANA>=2
   [M:EMP7]SECTION(1) = [F:CPT]CCE2 : [M:EMP7]REINIT(1) = [F:CPT]INICCE2
  Endif
  If GOPTCANA>=3
   [M:EMP7]SECTION(2) = [F:CPT]CCE3 : [M:EMP7]REINIT(2) = [F:CPT]INICCE3
  Endif
  If GOPTCANA>=4
   [M:EMP7]SECTION(3) = [F:CPT]CCE4 : [M:EMP7]REINIT(3) = [F:CPT]INICCE4
  Endif
  If GOPTCANA>=5
   [M:EMP7]SECTION(4) = [F:CPT]CCE5 : [M:EMP7]REINIT(4) = [F:CPT]INICCE5
  Endif
  If GOPTCANA>=6
   [M:EMP7]SECTION(5) = [F:CPT]CCE6 : [M:EMP7]REINIT(5) = [F:CPT]INICCE6
  Endif
  If GOPTCANA>=7
   [M:EMP7]SECTION(6) = [F:CPT]CCE7 : [M:EMP7]REINIT(6) = [F:CPT]INICCE7
  Endif
  If GOPTCANA>=8
   [M:EMP7]SECTION(7) = [F:CPT]CCE8 : [M:EMP7]REINIT(7) = [F:CPT]INICCE8
  Endif
  If GOPTCANA>=9
   [M:EMP7]SECTION(8) = [F:CPT]CCE9 : [M:EMP7]REINIT(8) = [F:CPT]INICCE9
  Endif
  Endif

 When "RIB"
  [M:EMP7]NBRRIB += 1
  If [M:EMP7]PAYPCT(nolign)=0
   [M:EMP7]PAYPCT(nolign) = 100
  Endif
  nolign = [M:EMP7]NBRRIB
  #################
  # 70311 : 1 new fiel in EMPLORIB
  # ACCNONREI
  If [M:EMP7]ACCNONREI(nolign-1)=0
   [M:EMP7]ACCNONREI(nolign-1)=1
  Endif
  ################
 [M:EMP7] = [F:RIB]

 When "HREXM"
  [M:EMP9]NBREXM += 1
  nolign = [M:EMP9]NBREXM
  [M:EMP9] = [F:HREXM]

 When "TRY"
  [M:EMP9]NBRTRY += 1
  nolign = [M:EMP9]NBRTRY
  [M:EMP9] = [F:TRY]

 When "HAB"
  #MABOS-FQ74502-US1642-10/06/13
#  [M:EMP3]NBRHAB += 1
#  nolign = [M:EMP3]NBRHAB
#  #################
#  # 70312 : 1 new fiel in EMPLOHAB
#  # HABFLG
#  If [M:EMP3]HABFLG(nolign-1)=0
#   [M:EMP3]HABFLG(nolign-1)=1
#  Endif
#  ################
#  [M:EMP3] = [F:HAB]
  ZONE = "NBRHAB" : Gosub SET_ZONE From SUBEML2
  If MA Then
    [M]NBRHAB += 1
    nolign = [M]NBRHAB
    If [M]HABFLG(nolign-1)=0
     [M]HABFLG(nolign-1)=1
    Endif
    [M] = [F:HAB]
  Endif
  #end MABOS-FQ74502-US1642-10/06/13
Endcase
Return


# Après import DADSu on a rempli EMPLOID et EMPLOAD

$CHARGE_MASK
nolign = 1
Read [T1]ID0=[F:ID]REFNUM
If !fstat
 [M:EMP0] = [F:T1]
 [M:EMP1] = [F:T1]
 [M:EMP2] = [F:T1]
Endif

#Adresse
nolign = 1
Read [T2]AD0=[F:ID]REFNUM
If !fstat
 [M:EMP3] = [F:T2]
Endif
 #MABOS-FQ74502-US1642-10/06/13
#Raz [M:EMP2]NBRCHD, [M:EMP3]NBRHAB, [M:EMP7]NBRRIB, [M:EMP9]NBREXM, [M:EMP9]NBRTRY
Raz [M:EMP2]NBRCHD, [M:EMP7]NBRRIB, [M:EMP9]NBREXM, [M:EMP9]NBRTRY
ZONE = "NBRHAB" : Gosub SET_ZONE From SUBEML2
If MA Then
  Raz [M]NBRHAB
Endif
 #end MABOS-FQ74502-US1642-10/06/13
# On pourrait faire maj au lieu de raz nbr*

