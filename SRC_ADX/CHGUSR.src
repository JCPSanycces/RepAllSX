#<AdxTL>@(#)3.0.0.0 $Revision$
#<AdxTL>@(#)12.0.0.0 $Revision$
#Goto TST_CHGLOGINSD : End
Local Char PARAM(30)(1..2) , VALEUR(10)
#TEST = 2 : Gosub MAJPAR
Call SAISIE_CHAR(VALEUR,PARAM,"FCHGUSR","CHGUSR","") From GSAISIE
#TEST = 1 : Gosub MAJPAR
End

$MAJPAR
Local File ADOVAL [ADW]
Trbegin [ADW]
 Read [ADW]ADW0 = "";"";"PASSWD"
 [F:ADW]VALEUR = num$(TEST)
 Rewrite [ADW]
Commit
Close Local File [ADW]
Return


#-- <Test CHGLOGINSD pour SData>
$TST_CHGLOGINSD
Local Integer OK
Local Char    MESSAGE(200)
Local Char    APPCOD(200)
Local Char    LOGIN
Local Char    PASSWD
Local Char    LANGUE
Local Integer WSOK
Local Integer ISSYNC
Local Char    TYPCTX
Local Char    CTX
Call CHGLOGINWS(OK,MESSAGE,"JPJ2","","FRA",0)
#Infbox GUSER

LOGIN="JPJ2333"   # pwd 'jj'
#LOGIN="BID"
PASSWD="jj"  #"TEST"
LANGUE="FRA"
WSOK=0
TYPCTX="eMail"
CTX="jean-philippe.jullien@sage.com"  # Guser devient JPJ
CTX="jean1@sage.com"    # Guser devient JPJ1
#CTX="TST;jean1sage.com"    #
#CTX="jeanKO@sage.com"   #
#CTX="" : ISSYNC=1
Call CHGLOGINSD(OK,MESSAGE,APPCOD,LOGIN,PASSWD,LANGUE,WSOK,ISSYNC,TYPCTX,CTX)
#Infbox "Fin OK,MESSAGE,APPCOD, LOGIN,PASSWD,LANGUE,WSOK,TYPCTX,CTX" - chr$(13)-num$(OK)-" -" -MESSAGE-" -" -APPCOD-" -"
#& -LOGIN-" -" -PASSWD-" -" -LANGUE-" -" -num$(WSOK)-" -" -TYPCTX-" -" -CTX
#Infbox GUSER
End
#-- </Test CHGLOGINSD pour SData>


########################################
$ACTION
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "BOUTON"       : Gosub BOUTON
 When "OK"           : Gosub ENREG
 When Default
Endcase
Return

$OUVRE
Local File AUTILIS [AUS] , ADOVAL [ADW]
Return

$DEBUT
Local Integer WOK , OBLIG
Local Char    MESSAGE(80)
Raz [M]
Return

$SETBOUT
If OBLIG
 Call VIREBOUT(CHBOU,"O") From GOBJET
Else
 Call VIREBOUT(CHBOU,"A") From GOBJET
Endif
Return

$AVANT_BOUTON
Case BOUT
 When "A"
  If [M]USR="" : FOK = 0 : Return : Endif
  OUSER = GUSER
  GUSER = [M]USR
  GOK = OBLIG-1
  # 0 -> Saisie d'un mot de passe quelconque
  # 1 -> Saisie d'un mot de passe non vide
Endcase
Return

$BOUTON
Case BOUT
 When "A"
  Raz OBLIG
  GUSER = OUSER
Endcase
Return

########################################
$ENREG
Raz OBLIG
Call CHGUSR(OK,MESSAGE,[M]USR,[M]PASSE)
If !OK
 Call ERREUR(MESSAGE) From GESECRAN
 FIN = 0
Else
 FIN = 1
Endif
Return

########################################################
## Sous-programme de changement de login XTEND
########################################################
Subprog CHGLOGINXTEND(OK,MESSAGE,LOGIN,LANGUE)
Variable Integer OK
Variable Char    MESSAGE()
Value    Char    LOGIN
Value    Char    LANGUE

GWEBSERV=1

Local Char APASSWD(250)
Local Integer K , TYPCON

OK = 0
TYPCON = 1
Onerrgo ERRWS1
Local File AUTILIS   [AUS]
If OK<>0 : End : Endif

Read [AUS]LOGIN=toupper(LOGIN)
Onerrgo
If OK<>0 : End : Endif
If fstat
 OK = 0 : MESSAGE = mess(24,100,1)  : # Utilisateur incorrect
 End
Endif

USER       = [F:AUS]USR
APASSWD = [F:AUS]NEWPAS
If APASSWD<>""
 Call VARPSE(APASSWD) From GESUSER
Endif
Call CHGUSR(OK,MESSAGE,USER,APASSWD)
If !OK : End : Endif


If LANGUE<>GLANGUE
 Call CHGLAN(OK,MESSAGE,LANGUE)
 If !OK : End : Endif
Else
 OK=1
Endif

If OK & adxtyp=20
      # 109419  ajout adxtyp=20 web services V9
      Local Char RETOUR(250)
      Callui RETOUR="" With "UIAction="+chr$(1)+"SessionSettings","ChangeUserContext="+chr$(1)
&               +[F:AUS]LOGIN+";"+GLANGUE+";"+"ASK_"
&               +";"+format$("D:YYYY",datesyst)+format$("D:MM",datesyst)+format$("D:DD",datesyst)
Endif

If GBROWS=2
  Global Date GWSTSESSD
  Global Integer GWSTSESST
  Global Char GWSTSESSU(250)
  GWSTSESSD=date$
  GWSTSESST=time
  GWSTSESSU=GUSER
Endif

End


########################################################
## Sous-programme de changement de login
########################################################
Subprog CHGLOGINWS(OK,MESSAGE,LOGIN,PASSWD,LANGUE,WSOK)
Variable Integer OK
Variable Char    MESSAGE()
Value    Char    LOGIN
Value    Char    PASSWD
Value    Char    LANGUE
Value    Integer WSOK

#   Si WSOK=1 on ne controle pas la validité du mot de passe
#   car on utilise le user du pool
Global Integer AWSOK : AWSOK=WSOK
GWEBSERV=1      : #  On force GWEBSERV à 1 (pb rencontré chez Sundis - CC - 02/02/1009)
Goto CHGLOG

########################################################
## Sous-programme de changement de login
########################################################
Subprog CHGLOGIN(OK,MESSAGE,LOGIN,PASSWD,LANGUE)
Variable Integer OK
Variable Char    MESSAGE()
Value    Char    LOGIN
Value    Char    PASSWD
Value    Char    LANGUE

$CHGLOG
Local Char USER(50) , MAIL(50) , CHAINE(250)
Local Integer K , TYPCON

OK = 0
TYPCON = 1

Onerrgo ERRWS1
Local File AUTILIS   [AUS]
If OK<>0 : End : Endif

# Point d'entrée pour la connexion GED (demande 92308 -Bruno Gonzalez-)    CC - 06/01/2014
GPOINT = "AWSSSO" : Gosub ENTREE From EXEFNC

# Connexion mode web via SSO sage (adresse email)

If left$(LOGIN,9)="~SSOSage~"
 MAIL = right$(LOGIN,10)
 K = instr(1,MAIL,"~")
 If K
  MAIL = left$(MAIL,K-1)
 Endif
 K = 0
 For [AUS] Where toupper(ADDEML)=toupper(MAIL)
  K += 1
  CHAINE = [F:AUS]LOGIN
 Next AUS
 If !K
  MESSAGE = MAIL-":"-mess(99,130,1) : # Aucun utilisateur correspond à cette adresse
  OK = 0
  End
 Elsif K>1
  MESSAGE = func AFNC.MES2(mess(98,130,1),num$(K),MAIL) : # Il y a $1$ utilisateurs qui utilisent l'adresse $2$
  OK = 0
  End
 Else
  LOGIN = CHAINE
  TYPCON = 3
 Endif
Endif

Read [AUS]LOGIN=toupper(LOGIN)
Onerrgo
If OK<>0 : End : Endif
If fstat=0
  USER = [F:AUS]USR
Else
  OK = 0 : MESSAGE = mess(24,100,1)  : # Utilisateur incorrect
  End
Endif

#If USER<>GUSER or GBROWS=2
If USER<>GUSER or (USER=GUSER and dim(AWSOK)>0)    :# Bug 85874   CC  16/11/2012
 Local Char APASSWD(250)
 APASSWD = PASSWD                       : #  Bug 73408     CC  06/02/2012
 If dim(AWSOK)>0 and AWSOK=1
   APASSWD = [F:AUS]NEWPAS
   Call VARPSE(APASSWD) From GESUSER
 Endif
 If toupper(left$(APASSWD,6))="CRYX3:"
   APASSWD = right$(APASSWD,7)
   Call VARPSE(APASSWD ) From GESUSER
 Elsif toupper(left$(APASSWD,6))="CRYPT:"
   APASSWD = right$(APASSWD,7)
   Local Char NEWPASSE(24)
   Call DECRYPTO(APASSWD,NEWPASSE) From GESUSER
   APASSWD = NEWPASSE
 Endif
 If USER<>GSUPER : # Pas de contrôle SSO pour l'utilisateur ADMIN
  Call SSO(OK,MESSAGE,TYPCON,LOGIN,PASSWD)
  If !OK : End : Endif
 Endif
 Call CHGUSR(OK,MESSAGE,USER,APASSWD)
 If !OK : End : Endif
Endif
If LANGUE<>GLANGUE
 Call CHGLAN(OK,MESSAGE,LANGUE)
 If !OK : End : Endif
Else
 OK=1
Endif

If GBROWS=2
  Global Date GWSTSESSD
  Global Integer GWSTSESST
  Global Char GWSTSESSU
  GWSTSESSD=date$
  GWSTSESST=time
  GWSTSESSU=GUSER
Endif

End

#   Pour récupérer erreur Oracle
$ERRWS1
  OK=6
Resume

###########################################################
Subprog SSO(OK,MESSAG,TYPCON,LOGIN,APASSWD)
Variable Integer OK
Variable Char    MESSAG
Value Integer    TYPCON : # Type de connexion 1=Standard, 2=Ntlm, 3=SSOsage
Value Char       LOGIN
Value Char       APASSWD
Local Char    SSOCON(10) , AAUSER(30)
Local Integer K , AERR , SSOTYP
SSOCON = ""
SSOTYP = 1
OK = 1
Call PARAM("","SSOCONNECT",SSOCON) From ADOVAL
K = (SSOCON="2" & GWEBSERV=0)   : # Interactif
#K += (SSOCON>="2" & GWEBSERV<>0) : # Interactif + web-service
If K
 Raz AERR , MESSAG , GPE
 AAUSER = LOGIN
#CHECK UNUSED_BEGIN
 GPOINT = "SSOCONNECT" : Gosub ENTREE From EXEFNC
#CHECK UNUSED_END
 If GPE=0
  Call SSO(AAUSER,APASSWD,MESSAG,TYPCON,SSOTYP,AERR) From ASSOCODE
 Endif
 If AERR
  OK = 0
  If MESSAG=""
   MESSAG = mess(231,100,1) : # Connexion refusée (contrôle annuaire)
   If MESSAG="" : MESSAG = "LDAP" : Endif
  Endif
 Endif
Endif
End

########################################################
## Sous-programme de connexion
########################################################
Subprog CHGUSR(OK,MESSAGE,USER,PASSWD)
Variable Integer OK
Variable Char    MESSAGE()
Value    Char    USER
Value    Char    PASSWD

Local Char    PROFIL(10) , NPROFIL(10) , MOTPASSE(24) , PASSVIDE(24)
Local Char    OUSER(GLONAUS) , NUSER(GLONAUS)
Local Integer I , J , K, WT
Local Integer WOK , MAXCON
Local Integer MAXSES , TYPSES , NBSES , NBUSR

Local File ADOVAL [ADW] , ADOVALAUS [ADU] , AUTILIS [AUS] , AMETUTI [AME]

# Existence utilisateur, actif et autorisé à se connecter

Read [AUS]CODUSR = GUSER
If [F:AUS]PRFMEN=""
 Read [AME]AME0 = [F:AUS]CODMET
 PROFIL = [F:AME]PRFMEN
Else
 PROFIL = [F:AUS]PRFMEN
Endif
Read [AUS]CODUSR = toupper(USER)
If fstat or [F:AUS]ENAFLG<>2
 MESSAGE = mess(24,100,1) : # Utilisateur incorrect
 OK = 0 : End
Endif
WT=mod(adxtyp,8)
If   ( [F:AUS]USRCONNECT<>2 and (WT<>4 and WT<>7)  )
& or ( [F:AUS]USRCONXTD<>2 and (WT=4 or WT=7) )
 MESSAGE = mess(279,123,1) :  # Code utilisateur non autorisé pour ce type de connexion
 OK = 0 : End
Endif
If [F:AUS]PRFMEN=""
 Read [AME]AME0 = [F:AUS]CODMET
 NPROFIL = [F:AME]PRFMEN
Else
 NPROFIL = [F:AUS]PRFMEN
Endif

# Même profil que l'utilisateur courant

TYPSES = mod(adxtyp,8)
If TYPSES<>4 & PROFIL<>NPROFIL & GVERSION<="1.4.0"
 MESSAGE = mess(19,130,1) : # Profil menu différent
 OK = 0 : End
Endif

# Nb d'essais de connexion dépassé ?

Read [ADW]ADW0 = "";"";"NBRCON"
MAXCON = val([F:ADW]VALEUR)
If MAXCON<>0 & [F:AUS]NBRCON>=MAXCON
 # Connexion impossible Nombre d'essais dépassés ()
 MESSAGE = mess(153,124,1)+"\"+mess(113,133,1)-"("+num$(MAXCON)+")"
 OK = 0 : End
Endif

# Nombre de sessions maximum

MAXSES = 0
TYPSES = mod(adxtyp,8)
If GUSER<>GSUPER
 Read [ADU]ADU0 = GUSER;"MAXSES"+num$(TYPSES)
 If !fstat
  MAXSES = val([F:ADU]VALEUR)
 Else
  Read [ADW]ADW0 = "";"";"MAXSES"+num$(TYPSES)
  If !fstat
   MAXSES = val([F:ADW]VALEUR)
  Endif
 Endif
Endif
If MAXSES<>0
 #118292
 Local Integer NBSESSUSR25:NBSESSUSR25 = 0
 If TYPSES=1
 Call NBCON_APPNOWEB_USER(tolower([F:AUS]LOGIN),nomap,TYPSES,NBSES) From PSADX
 #Call NBCON_APP_USER_ADXTYP(tolower([F:AUS]LOGIN),nomap,25,NBSESSUSR25) From PSADX
 Else
 Call NBCON_APP_USER(tolower([F:AUS]LOGIN),nomap,TYPSES,NBSES) From PSADX
 Endif
 If NBSES>MAXSES | NBSESSUSR25>MAXSES
  MESSAGE = mess(116,133,1)+"\("+num$(max(0,MAXSES))-mess(117,133,1)-mess(TYPSES,924,1)+")"
  # Nb maximum de sessions dépassé
  OK = 0 : End
 Endif
Endif

# Contrôle du mot de passe

MOTPASSE = PASSWD
Call CTLPAS(MOTPASSE,WOK) From GESUSER
If !WOK
 MESSAGE = mess(25,100,1) : # Mot de passe incorrect
 If MAXCON<>0
  Trbegin [AUS]
   Update [AUS] Where USR=NUSER With NBRCON += 1
  Commit
 Endif
 OK = 0 : End
Endif
If GBROWS=2 or dim(AWSOK)<0 or AWSOK<>1 : # On n'effectue pas ce controle si c'est le serveur de Web service
 If dim(AWSOK)>0 : Kill AWSOK : Endif
 PASSVIDE = ""
 Call CTLPAS(PASSVIDE,WOK) From GESUSER
 If WOK
  Read [ADW]ADW0 = "";"";"PASSWD"
  If !fstat & val([F:ADW]VALEUR)=2
   MESSAGE = mess(100,100,1) : # Vous devez saisir un mot de passe
   OK = 0 : End
  Endif
 Endif
 If dim([F:AUS]PASSDAT)>0 and !WOK
  If func ARECAUO.USRSAG(NUSER)
   If [F:AUS]PASSDAT+7<date$
    MESSAGE = mess(214,100,1) : # Mot de passe périmé
    OK = 0 : End
   Endif
  Else
   GPE = 0
   GPOINT = "CHGPASS" : Gosub ENTREE From EXEFNC : # mb 30.9.13 demande 92865
   If !GPE
    Read [ADW]ADW0 = "";"";"CHGPASS"
    If !fstat & val([F:ADW]VALEUR)>0
     If [F:AUS]PASSDAT+val([F:ADW]VALEUR)<date$
      MESSAGE = mess(214,100,1) : # Mot de passe périmé
      OK = 0 : End
     Endif
    Endif
   Endif
  Endif
 Endif
Endif
If dim(AWSOK)>0 : Kill AWSOK : Endif

# Déconnexion

OUSER  = GUSER
NUSER  = [F:AUS]USR
Call ESPION("",1,"DECONNECT","") From ESPION
Call WORKFLOW(1,"DEC","",GUSER) From AWRK
Call UNLOCK_PROFIL From GESUSER

# Tentative de connexion en utilisateur nommé

#If GUSRNOMME : # mb 9.8.11 bug 74824
If GUSRNOMME and GWEBSERV=0 and mod(adxtyp,8)=1  : #  CC 29/10/2012  Bug 85101
 MESSAGE = ""
 Call CONNECT_NOMME(MESSAGE,NUSER) From GESUSER
 If MESSAGE<>""
  OK = 0 : End
 Endif
 Unlock ="AUO"-OUSER
Endif

# Globales

GUSER = NUSER
GIDENT = format$("K:5X",GUSER)+num$(adxuid(1))
If OUSER=GUSER & GPRODUIT=1 : ## GEODE
 Local Char SAVDEP(GLONDEP), SAVFCY(GLONFCY)
 [L]SAVDEP = [V]GDEP : [L]SAVFCY = [V]GFCY
 Call INIGLOBVAR From GESUSER
 [V]GDEP = [L]SAVDEP : [V]GFCY = [L]SAVFCY
Else
 Call INIGLOBVAR From GESUSER
Endif
GLOGIN = tolower([F:AUS]LOGIN)

# Nb d'utilisateurs pour le profil

Call LCK_PROFIL(WOK,NBUSR) From GESUSER
If !WOK & GUSER<>GSUPER
 MESSAGE = mess(34,130,1)-mess(GTYPPRF,926,1)-"("+num$(NBUSR)+")" : # Trop d'utilisateurs pour le profil
 OK = 0 : End
Endif

# Connexion

Call DEBTRANS From GLOCK
Gosub TR1
If GOK<1
 MESSAGE = GMESSAGE
 OK = 0 : End
Endif
Call ESPION("",1,"CONNECT","") From ESPION
Call WORKFLOW(1,"CON","",GUSER) From AWRK
OK = 1

# Pour le psadx

Call SET_CURFCT(GFONCTION,1,GLOGIN) From PSADX

# Modification portail suite à modif code utilisateur

If GBROWS<>2                                       : #  Inutile si on est en web service
 Local Char RETOUR(250)
 Gosub CHGUSRW From GESUSER
 Call INIPORTAL From INTRUTILA
Endif

End

$TR1
GOK=1
Trbegin [AUS]
 Readlock [AUS]CODUSR = NUSER
 If fstat=1
  GOK = -1 : GLOCK = "$AUTILIS"-NUSER : Goto ROLL_TR1
 Elsif fstat
  GOK = 0 : Call RSTA("AUS",NUSER) From GLOCK : Goto AB_TR1
 Endif
 [F:AUS]DATCONN = date$
 [F:AUS]TIMCONN = time$
 [F:AUS]NBRCON  = 0
 Rewrite [AUS]
 If fstat
  GOK=0 : Call FSTA("AUS") From GLOCK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

########################################################
## Sous-programme de changement de langue
########################################################
Subprog CHGLAN(OK,MESSAGE,LANGUE)
Variable Integer OK
Variable Char    MESSAGE()
Value    Char    LANGUE
If filinfo(filpath("M"+LANGUE,"","",0),0)<0
 MESSAGE = LANGUE-":"-mess(138,124,1) : # Code langue incorrect
 OK = 0 : End
Endif
GLANGUE = LANGUE
adxrob(1)   = "M"+GLANGUE
messname(0) = GLANGUE
adxtms      = nomap+".APLSTD"
adxmbm      = adxmbm
OK = 1
End

########################################################
## Sous-programme de connexion SData (Bridge - adxtyp = 7)
#  Version 0003_S
#   Cinématique wiki: http://ecvmdevprod1/wiki/index.php/SData-CRM_SageCRM#.5BAutorisations_CRM_-_Identit.C3.A9_du_user.5D
#
#
########################################################
Subprog CHGLOGINSD(OK,MESSAGE, MSGAPPCOD, LOGIN,PASSWD,LANGUE,WSOK,ISSYNC,TYPCTX,CTX)
Variable Integer OK        # 1:ok - 6 special oracle ?
Variable Char    MESSAGE()    # Message en clair
Variable Char    MSGAPPCOD()  # Application code SData
Value    Char    LOGIN     # Login
Value    Char    PASSWD
Value    Char    LANGUE
Value    Integer WSOK      # Ctl PWD
Value    Integer ISSYNC    # 1 : Mode synchro
Value    Char    TYPCTX    # Type de contexte "" ou "EMail"
Value    Char    CTX       # Chaine contexte "jpj;test@sage.fr"

#   Si WSOK=1 on ne controle pas la validité du mot de passe
#   car on utilise le user du pool

Local Char USER, APASSWD(250), W_PARSD(1), WEML(GLONMAI)
Local Integer WLOGINPWDOK, WEMLHASUSR,WI
WLOGINPWDOK=0 : WEMLHASUSR=0

OK=0   # 0: KO  6:Erreur base  1:OK
MESSAGE=""


Case toupper(TYPCTX)
When "EMAIL"
    Gosub USER_EXISTSD
    If MSGAPPCOD<>"" : Goto CHGLOGINSD_END : Endif
    Gosub USER_PWD
    If WLOGINPWDOK                            # - Ok sur login
      If ISSYNC                                        # --- en synchro
          Call CHGLOGINWS(OK,MESSAGE,LOGIN,PASSWD,LANGUE,WSOK)      # user banalisé
      Else                                           # -- Avec email
          WEML = CTX
          WI=instr(0,CTX,";")
          If WI : WEML = vireblc(right$(CTX,WI+1),2) : Endif
          If WEML<>""
            For [AUS] Where tolower([F:AUS]ADDEML)=tolower(WEML)
              WEMLHASUSR=1
              Break
            Next
          Endif
          If !WEMLHASUSR                                        # --- Pas de user associé à l'email
                Call PARAM("","ASDAUSFAC",W_PARSD) From ADOVAL
                If W_PARSD <> "2"                                            # ---- Ctl parametre
                    OK=0
                    MSGAPPCOD = func APPCOD("BADEMAIL") :
                    MESSAGE = mess(34,143,1)-LOGIN       # Utilisateur SData non autorisé
                    If vireblc(CTX,2)<>"" : MESSAGE -= "/"-WEML : Endif
                Else
                    Call CHGLOGINWS(OK,MESSAGE,LOGIN,PASSWD,LANGUE,WSOK)  # user banalisé
                Endif
          Else                                                   # --- User associé à l'email
            If ([F:AUS]USRCONXTD=2)     # ---- autorisé à se connecter
                Call CHGLOGINWS(OK,MESSAGE,[F:AUS]LOGIN,"",LANGUE, 1)     # user email sans pwd
            Else
               OK=0
               MSGAPPCOD = func APPCOD("BADUSRORPWD")
               MESSAGE = mess(279,123,1) :  # Code utilisateur non autorisé pour ce type de connexion
#              Call CHGLOGINWS(OK,MESSAGE,LOGIN,PASSWD,LANGUE,WSOK)      # user banalisé - Rappel: le suivi des majs se fera par GUSRSD
            Endif
          Endif
      Endif
    Else                                       # Pwd Ko sur login
      OK=0
      MSGAPPCOD = func APPCOD("BADPWD") : MESSAGE = mess(25,100,1)    # Mot de passe incorrect
    Endif
When Default
   Gosub USER_EXISTSD
   If MSGAPPCOD<>"" : Goto CHGLOGINSD_END : Endif
   Call CHGLOGINWS(OK,MESSAGE,LOGIN,PASSWD,LANGUE,WSOK)
   If OK=0 : MSGAPPCOD = func APPCOD("BADUSRORPWD") : Endif
Endcase

$CHGLOGINSD_END
End

$USER_EXISTSD
# Existence utilisateur, actif
Onerrgo ERRWS1
If clalev([F:AUS])=0 : Local File AUTILIS   [AUS] : Endif
If OK<>0 : MSGAPPCOD = func APPCOD("INTERR") : MESSAGE = mess(1,137,1) : Return : Endif
Read [AUS]LOGIN=toupper(LOGIN)
Onerrgo
If OK<>0 : MSGAPPCOD = func APPCOD("INTERR") : MESSAGE = mess(1,137,1) : Return : Endif
If fstat or [F:AUS]ENAFLG<>2
  MSGAPPCOD = func APPCOD("BADUSR") : MESSAGE = mess(24,100,1)-LOGIN    # Utilisateur incorrect
  Return
Else
  USER = [F:AUS]USR
Endif

# Utilisateur non autorisé pour les WS
If  [F:AUS]USRCONXTD<>2 and (mod(adxtyp,8)=4 or mod(adxtyp,8)=7)
 MSGAPPCOD = func APPCOD("BADUSR") : MESSAGE = mess(279,123,1) :  # Code utilisateur non autorisé pour ce type de connexion
Endif

Return

$USER_PWD
# mot de passe
APASSWD=PASSWD
If toupper(left$(APASSWD,6))="CRYX3:"
   APASSWD = right$(APASSWD,7)
   Call VARPSE(APASSWD ) From GESUSER
Elsif toupper(left$(APASSWD,6))="CRYPT:"
   APASSWD= right$(APASSWD,7)
   Local Char NEWPASSE(24)
   Call DECRYPTO(APASSWD,NEWPASSE) From GESUSER
   APASSWD=NEWPASSE
Endif
Call CTLPAS(APASSWD,WLOGINPWDOK) From GESUSER
Return

# Code SData avec prefixe
Funprog APPCOD(COD)
Value    Char COD()
End "$CHGLOGINSD_"+COD




########################################
Subprog C_USR(VALEUR)
Variable Char    VALEUR()
Local Char OPROFIL(10) , NPROFIL(10)
Local Integer ERFIC
Onerrgo ERFIC
If dim([F:AUS]CODMET)>0
 If clalev([F:AME])=0 : Local File AMETUTI [AME] : Endif
Endif
Onerrgo
Read [AUS]CODUSR = GUSER
If [F:AUS]PRFMEN="" & dim([F:AUS]CODMET) & !ERFIC
 Read [AME]AME0 = [F:AUS]CODMET
 OPROFIL = [F:AME]PRFMEN
Else
 OPROFIL = [F:AUS]PRFMEN
Endif
Read [AUS]CODUSR = toupper(VALEUR)
If [F:AUS]PRFMEN="" & dim([F:AUS]CODMET)>0 & !ERFIC
 Read [AME]AME0 = [F:AUS]CODMET
 NPROFIL = [F:AME]PRFMEN
Else
 NPROFIL = [F:AUS]PRFMEN
Endif
If OPROFIL<>NPROFIL & GVERSION<="1.4.0"
 GMESSAGE = mess(19,130,1) : # Profil menu différent
 mkstat = 2 : End
Endif
End

$ERFIC
ERFIC = errn
Resume

