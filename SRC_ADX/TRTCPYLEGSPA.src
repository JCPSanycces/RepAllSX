#<AdxTL>@(#)6.0.0.0 $Revision$
############################################################
#
#  Legal Spanish datas for table COMPANY
#
# Window AWI=>CPYLEGSPA
# Mask/Screen AMK=>CPYLEGSPA [CLSPA]
#
############################################################


$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "ENR"           : Gosub ENR
 When "ABA"           : Gosub ABA
 When "FIN"           : Gosub FIN
Endcase
Return

$OUVRE
#----- Paramètres de l'action DATALEG -----#
Local Char LEG(GLONADI)
Local Char COD(max(GLONCPY,GLONVAT,5))

[L]LEG = PARAM(1)
[L]COD = PARAM(2)

#----- Tables utilisée -----#
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
If !clalev([F:ALK]) : Local File APLLCK [ALK] : Endif
If !clalev([F:TCU]) : Local File TABCUR [TCU] : Endif

#----- Masque local -----#
Local Mask CPYLEGSPA [CLSPA]

#----- Variables locales pour sauvegarde du masque -----#
Local Decimal SPABPCTSD
Local Decimal SPABPSTSD
Local Decimal SPAYEATSD

Return

$DEBUT
#--- Alimentation des champs de l'écran ---#
Call LEC_CPY([L]COD) From CPTLEC
If !fstat
 [M:CLSPA] = [F:CPY]
 # Devise/currency
 [M:CLSPA]CUR1 = [F:CPY]ACCCUR
 [M:CLSPA]CUR2 = [F:CPY]ACCCUR
 [M:CLSPA]CUR3 = [F:CPY]ACCCUR
 Read [TCU]TCU0 =  [F:CPY]ACCCUR
 If !fstat & [F:TCU]CURFMT1<>""
  [M:CLSPA]FMTCUR = "N+:"+[F:TCU]CURFMT1
 Endif
Endif
#--- Sauvegarde des valeurs initiales du masque ---#
[L]=[M:CLSPA]
Affzo [M:CLSPA]
Return

$ENR
Trbegin [CPY]
Readlock [CPY]CPY0 = [L]COD
If !fstat
 [F:CPY]SPABPCTSD=[M:CLSPA]SPABPCTSD
 [F:CPY]SPABPSTSD=[M:CLSPA]SPABPSTSD
 [F:CPY]SPAYEATSD=[M:CLSPA]SPAYEATSD
 Rewrite [CPY]
 If fstat
  GOK = 0 : Call FSTA("CPY") From GLOCK : Return
 Endif
Endif
Commit
[L]=[M:CLSPA] : REP=""
Return

$ABA
[M:CLSPA]=[L]
REP=""
Gosub ENR
Affzo [M:CLSPA]
Return

$APRES_MODIF
Read [ALK]LCKCLE="CPY"+[L]COD;0
If !fstat & [F:ALK]LCKPID<>adxuid(2)
 GMESSAGE=mess(10,100,1)
 GERR=1
 [M:CLSPA]=[L]
 Affzo [M:CLSPA] :# FIN=1
Else
 REP = "M"
 Local Char SYMB(20)
 SYMB="CPY"+[L]COD
 Lock SYMB With lockwait=0
Endif
Return

$FIN
If dim(SYMB)>0
 Unlock SYMB
Endif
Return
