#<AdxTL>@(#)7.0.0.0 $Revision$
Local Char VALEUR, PARAM(80)(1..2)
PARAM(1)=func RPTBUL
Call S_LIS_CHAR(VALEUR,PARAM,"","PRNBUL","") From GACTION
End

##################################################################################################
# Impression des bulletins de paie : Affichage des reports qui sont rattachés au code impression IMPBUL
##################################################################################################


$ACTION
Case ACTION
 When "SEL_LISTE" : Gosub SEL_LISTE
 When "FIN_LISTE" : Gosub FIN_LISTE
Endcase
Return

$SEL_LISTE
If clalev([F:ARX])=0 : Local File AREPORTX [ARX] : Endif
If clalev([F:ARP])=0 : Local File AREPORT  [ARP] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS  [AUS] : Endif
If clalev([F:AFT])=0 : Local File AFCTFCT  [AFT] : Endif

Local Char    ETAT(GLONARP)
Local Char    AUTSIT(10) , TEXETA(30)
Local Integer MAXTEX , OK , ONBTEX , I
MAXTEX = dim(TEX)
NBTEX = 0

For I=1 To dim(PARAM)
 If PARAM(I)="" : Break : Endif
 ETAT = PARAM(I)
 Gosub LISARX
Next I
ETAT=PARAM(1)
Return

$LISARX
ONBTEX=NBTEX
For [ARX]ARX0 Where INTCOD=ETAT
 If NBTEX>=MAXTEX-1 : Break : Endif
 If [F:ARX]EXTCOD<>"" & !find([F:ARX]EXTCOD,TEX(1..NBTEX))
  Read [ARP]ARP0 = [F:ARX]EXTCOD
  Call VERF_DROIT([F:ARX]EXTCOD,GUSER,OK,AUTSIT) From AIMP1
  If OK & ([F:ARX]LAN="" or [F:ARX]LAN=GLANGUE)
   NBTEX += 1
   TEX(NBTEX)   = [F:ARX]EXTCOD
   Call TEXTE([F:ARP]RPTDES,TEXETA) From OBJDIV
   TEXTE(NBTEX) = format$("K:16X",[F:ARX]EXTCOD)+TEXETA
  Endif
 Endif
Next
If NBTEX=ONBTEX & !find(ETAT,TEX(1..NBTEX))
 Read [ARP]ARP0 = ETAT
 Call VERF_DROIT(ETAT,GUSER,OK,AUTSIT) From AIMP1
 If OK & ([F:ARX]LAN="" or [F:ARX]LAN=GLANGUE)
  NBTEX += 1
  TEX(NBTEX)   = ETAT
  Call TEXTE([F:ARP]RPTDES,TEXETA) From OBJDIV
  TEXTE(NBTEX) = format$("K:16X",ETAT)+TEXETA
 Endif
Endif
Return

$FIN_LISTE
If GSTATUT<>7
 GBIDC1 = VALEUR
Else
 GBIDC1 = ""
 GBIDI1 = 1 : # Pour ne pas exécuter l'action suite AIMP1
Endif
Return

Funprog RPTBUL()
End func AFNC.PARAM("GRURPTBUL",GCURLEG)
