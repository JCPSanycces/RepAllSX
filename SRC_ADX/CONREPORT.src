#<AdxTL>@(#)6.0.0.0 $Revision$
######################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

  Call EXEC(NBPAR,PARAMETRE)
End

######################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value Integer    NBPAR 
Variable Char    PARAMETRE()()

  #----------------------------------------------------------------
  #   When "usr"             : [L]PARAMETRE(I) = "usr="+GUSER
  #   When "etat"            : [L]PARAMETRE(I) = "etat="+[L]ETAT
  #----------------------------------------------------------------
  Gosub OUVRE 
  If GERREUR Then
    GERREUR = 0
    End
  Endif 
  Gosub DECLARE 
  Call TEMPON("R") From GESECRAN
  Raz WNUMLIG 
  [L]CRITERE  = "1=1"
  [L]CRITERE1 = "& 1=1"
  [L]CRITERE2 = "& 1=1"
  [L]CRITERE3 = "& 1=1"
  For I=1 To NBPAR
    J=instr(1,[L]PARAMETRE(I),"=")
    If J Then
      [L]PARAM  = left$([L]PARAMETRE(I),J-1)
      [L]VALEUR = right$([L]PARAMETRE(I),J+1)
      Case [L]PARAM
        When "X3ETA"
          [L]ETAT = [L]VALEUR
        When "__REQUETE"
          [L]NUMREQ = val([L]VALEUR)
        When "numedt"
          [L]PARAMETRE(I) = "numedt=" + num$([L]NUMREQ)
        When "cur"
          [L]SZCURDES = [L]VALEUR
      Endcase
    Endif
  Next
  ###################################################################
  # Conversion de la devise 
  ###################################################################
  Filter [F:CON] Where [F:CON]DSYWND = 2 or [F:CON]DSYWND = 4
  For [F:CON] 
    Call DEBTRANS From GLOCK 
    Trbegin [PPP]
    Readlock [PPP]PPP0=[F:CON]CONNUM;"CON";SZCURDES
    If fstat = 5 Then
      #Création de l'enregistrement dans la table PREREPORT
      [F:PPP]NUM = [F:CON]CONNUM
      [F:PPP]TYPOBJ = "CON"
      [F:PPP]CUR = SZCURDES
      #Conversion des montants dans la devise de l'état
      IT_IS_OK = 1
      IT_IS_NOT_OK = 0
      If [F:CON]CUR <> SZCURDES Then
        Call GETDEVCPY("", [F:CON]SALFCY, CODDEVSOC, IT_IS_OK) From CRM_UTIL
        # Devise d'origine
        # Devise destination
        # Devise de la société
        # Type de cours
        # Date du cours
        # Montant origine
        # Montant destination
        # Status de retour (0 = OK)
        #Base de redevance annuelle
        Call CONVERT([F:CON]CUR,SZCURDES,CODDEVSOC,2,date$,[F:CON]CONAMT,[F:PPP]AMT1,IT_IS_NOT_OK) From TRTDEV
        If IT_IS_NOT_OK Then
          [F:PPP]AMT1 = 0
        Endif
      Else
        [F:PPP]AMT1 = [F:CON]CONAMT
      Endif
      Write [F:PPP]
      If fstat Then
        Rollback
      Else
        Commit
      Endif
    Else
      #Mise à jour de l'enregistrement existant
      [F:PPP]NUM = [F:CON]CONNUM
      [F:PPP]TYPOBJ = "CON"
      [F:PPP]CUR = SZCURDES
      #Conversion des montants dans la devise de l'état
      IT_IS_OK = 1
      IT_IS_NOT_OK = 0
      If [F:CON]CUR <> SZCURDES Then
        Call GETDEVCPY("", [F:CON]SALFCY, CODDEVSOC, IT_IS_OK) From CRM_UTIL
        # Devise d'origine
        # Devise destination
        # Devise de la société
        # Type de cours
        # Date du cours
        # Montant origine
        # Montant destination
        # Status de retour (0 = OK)
        #Base de redevance annuelle
        Call CONVERT([F:CON]CUR,SZCURDES,CODDEVSOC,2,date$,[F:CON]CONAMT,[F:PPP]AMT1,IT_IS_NOT_OK) From TRTDEV
        If IT_IS_NOT_OK Then
          [F:PPP]AMT1 = 0
        Endif
      Else
        [F:PPP]AMT1 = [F:CON]CONAMT
      Endif
      Rewrite [F:PPP]
      If fstat Then
        Rollback
      Else
        Commit
      Endif
    Endif
  Next
  Filter [CON]
  Call TEMPOFF From GESECRAN
End

########################################################################### 
$OUVRE 
  If !clalev([F:PPP]) : Local File PREREPORT [PPP] : Endif
  If !clalev([F:CON]) : Local File CONTSERV [CON] : Endif
Return
 
###########################################################################
$DECLARE 
Local Char CRITERE(255),CRITERE1(50),CRITERE2(50),CRITERE3(50)
Local Char PARAM(30),VALEUR(30),ETAT(GLONARP),WNUM(GLONVCR),WFCY(GLONFCY),WREP(GLONREP),WCLI(GLONBPN),WAFF(GLONVCR),WINT(GLONAIN)
Local Integer WTYP, NUMREQ 
Local Date WDAT
Local Char SZCURDES
Local Char CODDEVSOC
Local Integer WNUMLIG
Local Integer IT_IS_OK
Local Integer IT_IS_NOT_OK

  SZCURDES = ""
  CODDEVSOC = ""
  IT_IS_OK = 1
  IT_IS_NOT_OK = 0
Return
