Subprog AM_FORNAM2(VALEUR)
Variable Char    VALEUR()
I_ESSEMPUKI.FORNAM2 = VALEUR
Call RECOVERS_ERROR_IN_CLASSIC(I_ESSEMPUKI) From ESS_WRKFLOW_FUNC_HYBRID
If GERR = 1 Then
  I_ESSEMPUKI.FORNAM2 = I_ESSEMPUKI.snapshot.FORNAM2
  GERR = 1
  mkstat = 2
  End
Else
  Gosub UPDATE_ESSEMPUKI From ESSEMP

Endif
End


