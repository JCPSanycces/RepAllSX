#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################
# UTISTO10   Alimentation CREMVTDAT, CREMVTTIM et CREMVTSEQ              #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Init CREMVTSEQ") From LECFIC

  Call MAJ_UTISTO10(DOSSIER) 
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTISTO10(DOSSIER)
Value Char     DOSSIER

If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
If [F:ADS]DOSSIER<>[L]DOSSIER
  Read [ADS]DOSSIER=[L]DOSSIER
  If fstat : Raz [F:ADS] : Endif
Endif

# Uniquement si module stock
If [F:ADS]MODULE(6)<>2 : End : Endif

Call ECR_TRACE("UTISTO10: Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:TCM])  =0  Local File =DOSSIER+".TABCOSTMET" [TCM]  : Endif
If clalev([F:ITF])  =0  Local File =DOSSIER+".ITMFACILIT" [ITF]  : Endif
If clalev([F:ITG])  =0  Local File =DOSSIER+".ITMCATEG"   [ITG]  : Endif
If clalev([F:STJ])  =0  Local File =DOSSIER+".STOJOU"     [STJ]  : Endif
If clalev([F:STJ2]) =0  Local File =DOSSIER+".STOJOU"     [STJ2] : Endif
Local Char    LFCY(GLONFCY), LNUM(GLONVCR)
Local Integer LTYP, LLIN
Local Integer STOP,NB, NBTOT, I
Local Char    CRITERE(250)
Local Char    REQ(250)(3)
Local Integer LSEQ

# On vérifie qu'un article ou une catégorie utilise une méthode de valo avec régul de sortie
Link [ITF] With [TCM]TCM0~=[F:ITF]VLTCOD
&          As [LNK]
&          Where [TCM]PRIREGS=2
Look [LNK]reckey First

If fstat
    Link [ITG] With [TCM]TCM0~=[F:ITG]VLTCOD
&              As [LNK2]
&              Where [TCM]PRIREGS=2
    Look [LNK2]reckey First
Endif

If !fstat
  
    Raz STOP

    $LOOP_STJ
    Raz NB
    If STOP = 1
      STOP = 2
      CRITERE = "STOFCY=LFCY & VCRTYP=LTYP & VCRNUM=LNUM & VCRLIN>LLIN"
    Elsif STOP = 2
      STOP = 3
      CRITERE = "STOFCY=LFCY & VCRTYP=LTYP & VCRNUM>LNUM"
    Elsif STOP = 3
      STOP = 4
      CRITERE = "STOFCY=LFCY & VCRTYP>LTYP"
    Elsif STOP = 4
      STOP = 0
      CRITERE = "STOFCY>LFCY"
    Else
      CRITERE = "1=1"
    Endif
    
    Trbegin [STJ2]

    Filter [STJ] Where evalue(CRITERE)
&                Order By Key ZCC=STOFCY;VCRTYP;VCRNUM;VCRLIN;MVTSEQ Desc
    For [STJ]ZCC(4)
            Update [STJ2] Where STOFCY=[F:STJ]STOFCY
&                             & VCRTYP=[F:STJ]VCRTYP
&                             & VCRNUM=[F:STJ]VCRNUM
&                             & VCRLIN=[F:STJ]VCRLIN
&                             & CREMVTDAT = [0/0/0]
&                         With CREMVTDAT = [F:STJ]CREDAT,
&                              CREMVTTIM = [F:STJ]CRETIM+"00"
        NB+=adxuprec
            Update [STJ2] Where STOFCY=[F:STJ]STOFCY
&                             & VCRTYP=[F:STJ]VCRTYP
&                             & VCRNUM=[F:STJ]VCRNUM
&                             & VCRLIN=[F:STJ]VCRLIN
&                             & TRSTYP<>14
&                        With CREMVTSEQ = 99999999-[F:STJ]MVTSEQ+1
        NB+=adxuprec
        NBTOT+=adxuprec
        If NB>GMAXUPDTRS
            LFCY=[F:STJ]STOFCY
            LTYP=[F:STJ]VCRTYP
            LNUM=[F:STJ]VCRNUM
            LLIN=[F:STJ]VCRLIN
            STOP=1
            Break
        Endif
    Next
    [G:STJ]currlen=0
    Filter [STJ]
    Commit
    If STOP
        Goto LOOP_STJ
    Endif
    Call FERME_BOITE From GESECRAN

    Call ECR_TRACE("Init CREMVTSEQ trstyp=14("+num$(nbrecord([STJ]))+")",0) From GESECRAN
    
    Raz STOP
    REQ(0) = "SELECT STJ.F,STJ.T,STJ.N,STJ.L"
    REQ(1) =" FROM "+DOSSIER+".STOJOU, ("
    REQ(1)+=  " SELECT MAX(MVTSEQ_0) S, STOFCY_0 F, VCRTYP_0 T,VCRNUM_0 N,VCRLIN_0 L"
    REQ(1)+=  " FROM "+DOSSIER+".STOJOU"
    REQ(1)+=  " WHERE TRSTYP_0=14"
    REQ(1)+=  " GROUP BY STOFCY_0, VCRTYP_0,VCRNUM_0,VCRLIN_0"
    REQ(1)+= ") STJ"
    REQ(2) =" WHERE STOFCY_0=STJ.F AND VCRTYP_0=STJ.T AND VCRNUM_0=STJ.N AND VCRLIN_0=STJ.L"
    REQ(2)+=  " AND MVTSEQ_0=STJ.S"
    REQ(2)+=" ORDER BY IPTDAT_0,CREMVTDAT_0,CREMVTTIM_0,VCRTYP_0,VCRNUM_0,VCRLIN_0,ACTQTY_0"
    Trbegin [STJ2]
    For (Char FCY, Integer TYP, Char NUM, Integer LIN) From num$(GTYPDBA*2+1) Sql REQ As [XXX]
        LSEQ = uniqid([STJ])
        Update [STJ2] Where STOFCY=[F:XXX]FCY
&                         & VCRTYP=[F:XXX]TYP
&                         & VCRNUM=[F:XXX]NUM
&                         & VCRLIN=[F:XXX]LIN
&                     With CREMVTSEQ = LSEQ
    Next
    Commit
Else
    Call ECR_TRACE("Issue adjustement not used => CREMVTSEQ doesn't need to be initialized",0) From GESECRAN
Endif

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
Call MAJ_UTISTO10(APPLI)        
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
Call MAJ_UTISTO10(APPLI)
End


