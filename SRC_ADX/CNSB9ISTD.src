#<AdxTL>@(#)2.0.0.0 $Revision$
#########################################################################
# CNSB9ISTD :1099 inquiry                                               #
#                                                                       #
# INQUIRY: B9I
# SCREEN 1 (HEADER) : CONSB9I1 [B9I1]                                   #
# SCREEN 2 (LINES)  : CONSB9I2 [B9I2]                                   #
# CRIT SCREEN  : CRITB9I [CB9I]                                         #
# Activity Code: S1099
#
# TABLE 1 (LINES) : BPS1099GEN [B9G] : key = B9G0 ( YR1099+CPY+BPSNUM+FRM1099+BOX1099)
#                                            B9G1 ( YR1099+CPY+BPSNUM   #
# TABLE 2 (Line LINK) : BPSUPPLIER [BPS]                                #
# TABLE 3 (Line LINK) : BPARTNER   [BPR]                                #
# TABLE 4 (Line LINK) : BPADDRESS  [BPA]                                #
# TABLE 5 (Line LINK) : BOX1099    [BX9]                                #
#
# Description: Launched from the "1099 forms [BPS1099GEN]" - View button    #
#   Displays the generated [B9G] 1099 records by supplier, to review or #
#   to support electronic filing.   By exporting the grid to MSExcel and#
#   mapping the data to an external 1099 reporting service.             #
#                                                                       #
# Selection:
#   Company:  Single- Only 1099 Enabled sites are allowed.              #
#   Year :    Single- Current or Next year typically                    #
#   Supplier: Range-                                                    #
#   Form:     Single- Either Misc, Div, Inc.                            #
#
# Detail:
#   Grid populated from combining multiple [B9G] records to display
#   a single line per Supplier, includes Amount, Text and Checkbox values.
#   Also displays the Supplier Address information per line.
#   Ordered by Supplier (for a single Company, Year, Form).
#
#########################################################################

$ACTION

Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "LECTURE"    : Gosub LECTURE
Endcase

Return

############################################
$OUVRE

# Filters and variables using system defined lengths
Local Char FILTB9I(250)(4), FILTPAG(250)
Local Char BPSDEB(GLONBPR), BPSFIN(GLONBPR),DEBNUM(GLONVCR),FINNUM(GLONVCR)
Local Char DEBBOX(4), FINBOX(4)
NAVIG="CONSB9I"

#Driving Table
If clalev ([F:B9G])=0 : Local File BPS1099GEN     [B9G] : Endif

#Auxiliary Tables
If clalev ([F:BPS])=0 : Local File BPSUPPLIER     [BPS] : Endif
If clalev ([F:BPR])=0 : Local File BPARTNER       [BPR] : Endif
If clalev ([F:BPA])=0 : Local File BPADDRESS      [BPA] : Endif
If clalev ([F:BX9])=0 : Local File BOX1099        [BX9] : Endif

If clalev ([F:CPY])=0 : Local File COMPANY        [CPY] : Endif
If clalev ([F:TCY])=0 : Local File TABCOUNTRY     [TCY] : Endif

Gosub DEFCRIT

Return


$DEFCRIT
############################################
#Affectation des zones par les paramètres
# B9I is not called from other screens currently
# DEFCRIT is not used and only added for future support of calls
############################################

#UI Defaults
[M:B9I1]CPY = GDEFSOC  # Company default from user
Call LECTURE("CPY", [M:B9I1]CPY,"") From CONTOBJ
Call LECTURE("TCY", [F:CPY]CRY,"") From CONTOBJ #Set companies' country

[M:B9I1]FRM1099 = 2    # Misc. type
[M:B9I1]YR1099 = year(date$) # Date - Match other 1099 code default
If month(date$) < 6
    [M:B9I1]YR1099 -= 1
Endif

For I=1 To dim(PARAM)
 Case I
  When 1 :
   If PARAM(I)<>""
    [M:B9I1]YR1099 = PARAM(I)
   Endif
  When 2 :
   If PARAM(I)<>""
    [M:B9I1]BPSDEB = PARAM(I)
   Endif
  When 3 :
   If PARAM(I)<>""
    [M:B9I1]BPSFIN = PARAM(I)
   Endif
  When 4 :
   If PARAM(I)<>""
    [M:B9I1]FRM1099 = val(PARAM(I))
   Endif
  When 5 : Break
  Endcase
Next I

#Valeurs par défaut critère
If [M:CB9I]MEMO=""
  [M:CB9I]TRI=1    #sort criterion  A: checkout orig code
Endif

#----- Copy header screen B9I1 to criteria screen CB9I -----#
# Will use WWCNSB9I  criteria in header mask it moves to criteria mask
Gosub CRITENT From =PROGCNS

Return


$LECTURE
# Select 1099 form Generated records from BPS1099GEN [B9G] and
#  link them to Supplier, SupplierAddress, and BoxTypes for details.
# Apply the user Selection and range (for next/prev page) as filters.
# Loop through B9G Supplier/Form/Box and create "one" row per
# Supplier for table/grid display.

Gosub CHANGE_MSK From GCONSULT #support user mask

If CHGPAG<0 : NOL = MAXLIG : Endif

If CHGPAG>0
 SUITE = 1
 If CHGPAG=1 : RETOUR=1 : Elsif CHGPAG=2 : RETOUR=2 : Endif
Else
 RETOUR = 1
 If CHGPAG=-1 : SUITE=1 : Else SUITE=2 : Endif
Endif

# Filtres
Gosub FILTRE
If PROGSPE<>""
 ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

# [BX9]BX90 - will determine by form, the Type of box
Link [B9G] With [BPS]BPS0=[F:B9G]BPSNUM,
&               [BPR]BPR0=[F:B9G]BPSNUM,
&               [BPA]BPA0=1;[F:BPS]BPSNUM;[F:BPS]BPAADD,
&               [BX9]BX90= [F:B9G]FRM1099; [F:B9G]BOX1099
&    As [LNK]

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #
#-- Application des Filtres

# Parcours de page en page
If CHGPAG>0 # Next Page
 SUITE = 1
 If CHGPAG=1 : RETOUR=1 : Elsif CHGPAG=2 : RETOUR=2 : Endif
Else         # Previous Page
 RETOUR = 1
 If CHGPAG=-1 : SUITE=1 : Else SUITE=2 : Endif
Endif

If CHGPAG<>2 & CHGPAG<>-2 : Effzo [M:B9I2]5 : Endif

# Set LNK result set to filter to a unique combination of user selection and page navigation/display.
If  CHGPAG > 0
    #Refresh or Fwd
    Filter [LNK] Where evalue(FILTB9I(0))     & evalue(FILTPAG)
&   Order By  [B9G]BPSNUM Asc
Else
    #Back or Last
    Filter [LNK] Where evalue(FILTB9I(0))    & evalue(FILTPAG)
&   Order By  [B9G]BPSNUM Desc
Endif

# Since we create one Supplier row per many B9G reads, we use
# FINNUM to determine a new line, so reset DEBNUM and FINNUM,
# their values were already used by FILTPAG at this point
Raz DEBNUM, FINNUM

# Loop through all B9G records (driving table of LNK) but only create
# one line per BPS.
For [LNK]
  Gosub CHARGE_B9I
  If CHGPAG > 0 & NOL >= MAXLIG-1 & SUITE=2
      Break
  Elsif CHGPAG <= 0 & NOL <= 0 & RETOUR=2
      Break
  Endif
Next

Return


$CHARGE_B9I
######################################################################################
# Creating the row, many B9G/LNK rows wil make a single row in our inquiry.
# All the Box records for a Supplier will go on the same line.
#
################################

 If NBLU=1
    If CHGPAG=2 or CHGPAG=-2
      Effzo [M:B9I2]5  #In templateClear the grid block, but LAST seems to work fine without.
    Endif
    NBLU=2
 Endif

 If CHGPAG>0
  If NOL>=MAXLIG-1 : SUITE=2 : Return : Endif #Hit Maxline to display so stop
  #FINNUM - When BPS changes, make a new line, also save FINNUM value for paging.
  #When BPS changes, make a new line
   If FINNUM <> [F:B9G]BPSNUM : NOL += 1 : Endif
  If NOL = 0
   DEBNUM = [F:B9G]BPSNUM
  Endif
  FINNUM = [F:B9G]BPSNUM
 Else
  If NOL<=0 : RETOUR=2 : Return : Endif
      #DEBNUM - When BPS changes, going backwards, make a new line, also save DEBNUM value for paging.
    If DEBNUM <> [F:B9G]BPSNUM : NOL -= 1 : Endif

  If NOL = MAXLIG-1
     If CHGPAG=-1
        If [F:B9G]BPSNUM=DEBNUM : NOL+=1 : Return : Endif #Dont re-read if same
     Endif
      FINNUM = [F:B9G]BPSNUM
  Endif
   DEBNUM = [F:B9G]BPSNUM
 Endif

 #Populate the table Row, may be updating the same row for different boxes

 #Copy data once per supplier (nolign<>NOL+1 or 1first line) only, for performance.
 If nolign <> NOL+1 or nolign = 1 #nolign is set to 1 by supervisor on first record
     #New line so move over Supplier stuff
     nolign=NOL+1
     [M:B9I2]=[F:BPS]
     [M:B9I2]=[F:BPA]
     [M:B9I2]=[F:B9G] # Keep B9G last since most important data will not be overridden

     #Note Explicit Fields in comments below
     #[F:BPS]
     #[M:B9I2]BPSNUM(nolign-1)=[F:BPS]BPSNUM
     #[M:B9I2]BPSNAM(nolign-1)=[F:BPS]BPSNAM
     #[F:BPA]
     [M:B9I2]BPAADDLIG1(nolign-1)= [F:BPA]BPAADDLIG(0)
     [M:B9I2]BPAADDLIG2(nolign-1)= [F:BPA]BPAADDLIG(1)
     [M:B9I2]BPAADDLIG3(nolign-1)= [F:BPA]BPAADDLIG(2)
     #[M:B9I2]CTY(nolign-1)=[F:BPA]CTY
     #[M:B9I2]SAT(nolign-1)=[F:BPA]SAT
     #[M:B9I2]POSCOD(nolign-1)=[F:BPA]POSCOD
     #[F:B9G]
     #[M:B9I2]YR1099(nolign-1)=[F:B9G]YR1099
     #[M:B9I2]FRM1099(nolign-1)=[F:B9G]FRM1099
     #[M:B9I2]FRM1099(nolign-1)=[F:B9G]BOX1099
     #[F:BPR]
     [M:B9I2]CRN(nolign-1)= [F:BPR]CRN
     #name fields from BPARTNER (not BSupplier)
     [M:B9I2]BPSNAM1(nolign-1)= [F:BPR]BPRNAM(0)
     [M:B9I2]BPSNAM2(nolign-1)= [F:BPR]BPRNAM(1)
 Endif

 #Copy data for every B9G/LNK  box record
 # Move the Box data into a screen field that has the Box ID
 # Screen M:B9I2 has fields for all the 1099 Forms (Misc, Div, Int)
 # Only populate the fields that match, do not worry about unused/blanks,
 # the grid/table is for user export to Excel then mapped to external 1099 software.
 #
 #For example screen M:B9I2 has a field called "B15A" to represent Box"15a"
 # Dynamically take [F:BX9]BOX1099 value of "15a" and create "[M:B9I2]15A"
 # then depending on the BOXTYP, take the Amount, Text or Checkbox value
 # and move it into the screen field using Assign
 # (ie. Assign [M:B9I2]B15A(nolign-1) With 100.00  )

 #For example  1 Supplier's, Misc. form's, has 3 boxes (in B9G): box 2(Chkbox), 5(Text), 15a(Amt)
 # will create a grid row "SupplierX:  Y, E-94343, 100.00"

 #[BX9]BOXTYP values [-1Amt, 2-Txt, 3-Chbx]
 Case [BX9]BOXTYP
  When 1 :   # amount
    #Assiging to screen fields  is dynamic, but field names will require changes
    # when future 1099 goverment definitions require different boxes.
    Assign "[M:B9I2]B"+toupper([F:BX9]BOX1099)+"VAL("+num$(nolign-1)+")" With format$("N:9.2" , [F:B9G]AMT1099)
  When 2 : # text
    Assign "[M:B9I2]B"+toupper([F:BX9]BOX1099)+"VAL("+num$(nolign-1)+")" With [F:B9G]TXTFLD
  When 3 : # checkbox
    #Text field but 1099BOXMNT saves a "1"-Yes and "2"-No
    If [F:B9G]TXTFLD = "2"
      #Leave blank if "No"
      Assign "[M:B9I2]B"+toupper([F:BX9]BOX1099)+"VAL("+num$(nolign-1)+")" With "Y"
    Endif
 Endcase

Return


$FILTRE
######################################################################################
#Création de critère de selection
#Set base criteria for Link [B9G] As [LNK] using user selections and
# the current records being viewed, in the event of a Page fwd, back, etc.
#
################################
Raz FILTB9I
FILTB9I(0)= "1=1"
FILTPAG = "1=1"


If [M:B9I1]CPY<>""
 FILTB9I(0)+= " & [F:B9G]CPY='"+[M:B9I1]CPY+"'"
Endif

If [M:B9I1]YR1099<>0
 FILTB9I(0)+= " & [F:B9G]YR1099="+num$([M:B9I1]YR1099)+" "
Endif

If [M:B9I1]FRM1099<>0
 FILTB9I(0)+= " & [F:B9G]FRM1099= "+num$([M:B9I1]FRM1099) +" "
Endif

If [M:B9I1]BPSDEB<>""
 FILTB9I(0)+= " & [F:B9G]BPSNUM>='"+[M:B9I1]BPSDEB+"'"
Endif


If [M:B9I1]BPSFIN<>""
 FILTB9I(0)+= " & [F:B9G]BPSNUM<='"+[M:B9I1]BPSFIN+"'"
Endif

FILTPAG = "1=1"

# order descending
Case CHGPAG
  When 3 : # refresh - get records STARTING with the same FIRST Supplier shown (or blank)
    FILTPAG += " & BPSNUM>=DEBNUM"

  When 2 : # Next - get records STARTING with the LAST Supplier shown
    FILTPAG += " & [F:B9G]BPSNUM>FINNUM"

  When -2 : # Previous - get records ENDING with the FIRST Supplier shown
    FILTPAG += " & [F:B9G]BPSNUM<DEBNUM"
Endcase

Return


$DEB_CRIT
#Display the Criteria winows selection fields
Local Integer NBCOL

Affzo [M:CB9I]

Return

Subprog C_CPY(VALEUR)
######################################################################################
# Verify Company selected has 1099 enabled.
# Set Buttons depending on existing records
################################################
Variable Char    VALEUR()

If VALEUR <> "" and func AFNC.PARAM("DCLFEES",VALEUR) <> "3"
    GMESSAGE = mess(77,122,1)  #"Company not defined to process 1099s"
    mkstat = 2
    End
Endif
