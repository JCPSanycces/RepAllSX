Subprog AM_CPY(VALEUR)
######################################################################################
# Called from Inquiry Header and Criteria Screens
# Set the Evaluated titles for a country based on the Company's country.
################################################
Variable Char VALEUR()
  If VALEUR <> ""
    #Set country based on company selection
    Call LECTURE("TCY", [F:CPY] CRY,"") From CONTOBJ
    Affzo [M:B9I2] #Redisplay screen with evaluated titles
  Endif

End


Subprog AP_BPSDEB(VALEUR)
Variable Char    VALEUR()
######################################################################################
# Called from Inquiry Header and Criteria Screens
# Move Start BPR into End BPR as default
# Onto both header and criteria screens
#######################################################

If  VALEUR<>""
  If [M:B9I1]BPSFIN=""
    [M:B9I1]BPSFIN = VALEUR
  Endif
  If [M:CB9I]BPSFIN=""
    [M:CB9I]BPSFIN = VALEUR
  Endif
  [M:CB9I]BPSDEB = VALEUR
Endif
Affzo [M:B9I1]BPSDEB
Affzo [M:B9I1]BPSFIN
Affzo [M:CB9I]BPSFIN

End

Subprog AP_BPSFIN(VALEUR)
Variable Char    VALEUR()
######################################################################################
# Called from Inq header and Criteria Screens, moves value to make both fields equal.
# Do not allow if less than Start value
# Redisplay other fields since setting value thru code
################################

If [M]BPSDEB <> "" & VALEUR <> ""
 If VALEUR < [M]BPSDEB
  GMESSAGE = mess(757,196,1) : mkstat=2 : End
 Endif
Endif

If VALEUR<>""
 [M:B9I1]BPSFIN = VALEUR
 [M:CB9I]BPSFIN = VALEUR
Endif
Affzo [M:B9I1]BPSFIN
Affzo [M:CB9I]BPSFIN

End

Subprog AS_FRM1099(VALEUR)
######################################################################################
# Called from Inq Header and Criteria Screen
# Just display used FRM1099 values, remove 'none' option used in entry.
################################
Variable Integer VALEUR

GMENLOC(1) = 1    # eliminate 1:"None" from the local menu set

End


Subprog PATCH(APPLI)
######################################################################################
## X3 Standard inquiry takes care of validating other objects during patch
#######################################
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(1)<>2 End Endif
Call VALGTC(APPLI,"B9I") From SUBGTC
End

