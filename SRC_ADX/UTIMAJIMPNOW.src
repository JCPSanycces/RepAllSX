#<AdxTL>@(#)7.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour champ IMPNOW dans la table AREPORTX
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update IMPNOW field in AREPORTX file") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub INIFLD
End

#-------------------#
$INIFLD

Local File =DOSSIER+".AREPORTX"   [ARX] 

If dim([F:ARX]IMPNOW)<=0
 Close Local File [ARX]
 Return 
Endif

# Mise à jour de la table AREPORTX
Call ECR_TRACE(mess(81,125,1)-"AREPORTX:"-time$,0) From GESECRAN
Trbegin [ARX]
 For [ARX]ARX0
  If [F:ARX]IMPNOW=0 & [F:ARX]TYPCOD=1 : # Etat
   [F:ARX]IMPNOW = 1
   Rewrite [ARX]
   If fstat
    Call ERREUR("AREPORTX"-[F:ARX]INTCOD-[F:ARX]EXTCOD,2) From DOSDIC
   Endif 
  Endif
 Next
Commit

Close Local File [ARX]

Return
