#################################################################################
# Moulinette Avant mise à jour concernant le module GPAO                        #
#################################################################################
Subprog AMAJ

End

#################################################################################
# Moulinette Après mise à jour concernant le module GPAO                        #
#################################################################################
Subprog MAJ

  Local Integer WOUV_TRACE
  Local Integer NUMPROC
  Raz NUMPROC

  If GTRACE = "" Then
    Call OUVRE_TRACE("GPAMAJ80 : Process for manufacturing") From LECFIC
    WOUV_TRACE = 1
  Endif

  NUMPROC += 1
  Call ECR_TIME("GPAMAJ80 Manufacturing Transactions Process "+ num$(NUMPROC)+": Update TABMAT/SFTTXN/SFTTXNH") From DOSSUB
  Call UPDATE_EMPTYP
  Call UPDATE_SFTTXN

  # Issue X3-7932 - 2017-01-17 by CCC : Control time table schemas
  NUMPROC += 1
  Call ECR_TIME("DOSMAJ80 TC Transactions Process "+num$(NUMPROC)+": control of Time table schemas") From DOSSUB
  Call CTLDIH([F:ADS]DOSSIER)

  #--------------------------------
  #--------------------------------
  If WOUV_TRACE = 1 Then
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif

End

##########################################################################
Subprog UPDATE_EMPTYP

  Local Integer COMPTEUR

  If func DOSVUE.ISVIEW([F:ADS]DOSSIER,"TABMAT") : End : Endif
  #If the table does not exist, then end the process
  If filinfo(filpath("FIL","TABMAT","fde",DOSSIER),0)<=0 : End : Endif

  If !clalev([F:TMA]) : Local File =DOSSIER+".TABMAT" [TMA] : Endif

  # -----------------------------------------------------
  Trbegin [TMA]
  Update [TMA] Where [F:TMA]EMPTYP=0 With EMPTYP=1
  COMPTEUR = adxuprec
  Commit
  # -----------------------------------------------------

  Close Local File [TMA]
  Call ECR_TRACE("Update TABMAT :" - num$(COMPTEUR) - "records updated",0) From GESECRAN

End


##########################################################################
Subprog UPDATE_SFTTXN
  Local Integer COMPTEUR
  Raz COMPTEUR

  If func DOSVUE.ISVIEW([F:ADS]DOSSIER,"SFTTXN") : End : Endif
  If func DOSVUE.ISVIEW([F:ADS]DOSSIER,"SFTTXNH") : End : Endif
  #If the table does not exist, then end the process
  If filinfo(filpath("FIL","SFTTXN","fde",DOSSIER),0)<=0 : End : Endif
  If filinfo(filpath("FIL","SFTTXNH","fde",DOSSIER),0)<=0 : End : Endif

  If !clalev([F:SFTX]) : Local File =DOSSIER+".SFTTXN" [SFTX] : Endif
  If !clalev([F:SFTH]) : Local File =DOSSIER+".SFTTXNH" [SFTH] : Endif
  If !clalev([F:MWS])  : Local File =DOSSIER+".WORKSTATIO" [MWS]: Endif

  # -----------------------------------------------------
  Trbegin [SFTX], [SFTH]

  Update [SFTX] Where [F:SFTX]CLEFLG=0 With CLEFLG=1

  Update [SFTX] With MACFLG=1, NUMMAC=1
  COMPTEUR += adxuprec

  For [F:SFTX] Where [F:SFTX]SFTTYP>3 & [F:SFTX]WCENTER<>""
    Read [MWS]WST0=[F:SFTX]WCENTER;[F:SFTX]FCY
      If !fstat
        If [F:MWS]WSTTYP=1 #Machine
          [F:SFTX]NUMMAC = [V]CST_AYES
          [F:SFTX]MACFLG = [V]CST_AYES
          Rewrite [F:SFTX]
        Endif
    Endif
  Next

  Update [SFTH] Where [F:SFTH]CLEFLG=0 With CLEFLG=1

  Update [SFTH] With MACFLG=1, NUMMAC=1
  COMPTEUR += adxuprec

  For [F:SFTH] Where [F:SFTH]SFTTYP>3 & [F:SFTH]WCENTER<>""
    # Issue 119732 - 2016-12-02 by CCC : FCY doesn't exist => use of MFGFCY
    #Read [MWS]WST0=[F:SFTH]WCENTER;[F:SFTH]FCY
    Read [MWS]WST0=[F:SFTH]WCENTER;[F:SFTH]MFGFCY
      If !fstat
        If [F:MWS]WSTTYP=1 #Machine
          [F:SFTH]NUMMAC = [V]CST_AYES
          [F:SFTH]MACFLG = [V]CST_AYES
          Rewrite [F:SFTH]
        Endif
    Endif
  Next

  Commit
  # -----------------------------------------------------

  Close Local File [SFTX], [SFTH], [MWS]
  Call ECR_TRACE("Update SFTTXN/SFTTXNH :" - num$(COMPTEUR) - "records updated",0) From GESECRAN
End

Subprog CTLDIH(PDOS)
Value Char PDOS

Local File =PDOS+".DIAHOU"  [DIH]

Local Integer IUPPER

For [DIH]
    LERR=0
    For I=0 To dim(STRHOU)-1
        If [F:DIH]STRHOU(I)="" : Break : Endif
        # Is start time > end time ?
        Call ISHOURUPPER([F:DIH]ENDHOU(I), [F:DIH]STRHOU(I), IUPPER) From CRMUTIL140
        If IUPPER=1
            If LERR=0
                Call ECR_TRACE("Time table schema"-[F:DIH]NUM,0) From GESECRAN
            Endif
            LERR=1
            Call ECR_TRACE(func AFNC.MES2("Start time greater than end time : $1$ > $2$",[F:DIH]STRHOU(I),[F:DIH]ENDHOU(I)),1) From GESECRAN
        Elsif I>0
            # Is start time < end time of previous period ?
            Call ISHOURUPPER([F:DIH]STRHOU(I), [F:DIH]ENDHOU(I-1), IUPPER) From CRMUTIL140
            If IUPPER=1
                If LERR=0
                    Call ECR_TRACE("Time table schema"-[F:DIH]NUM,0) From GESECRAN
                Endif
                LERR=1
                Call ECR_TRACE(func AFNC.MES2("Start time can't be before end time of previous period : $1$ < $2$",[F:DIH]STRHOU(I),[F:DIH]ENDHOU(I-1)),1) From GESECRAN
            Endif
        Endif
    Next
Next

End

