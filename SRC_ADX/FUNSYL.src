#<AdxTL>@(#)8.0.0.0 $Revision$
###########################################################################################
# Gestion des transcodification de synchronisation               Créé le 21 février 2006
###########################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "AVANT_MEN"    : Gosub AVANT_MEN
    When "BOUTON"       : Gosub BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "RAF"          : Gosub REFRESH
    When "ABA"          : Gosub ABANDON
    When "ENR"          : Gosub ENREGISTRER
    When Default
Endcase
Return

##########################################################################################################
$REFRESH
Return

##########################################################################################################
$OUVRE
Global Integer GSYLMODIF

  #Ouvre les fichiers utilisés dans l'ffichage des données de synchronisation
  If !clalev([F:SYL]) : Local File SYNCLINK [SYL] : Endif
  If !clalev([F:AUL]) : Local File AUTILIS [AUS] : ENDIF
  GSYLMODIF = 0
Return

##########################################################################################################
$DEBUT
Global Char GSZTSYLKEY(30)(dim([M:SYL0]SYLNUM))
Global Integer GINBSYLKEY
Global Char GTBKCHR(50)(1..50)       # Paramètres caractères
Global Char GTBVCHR(50)(1..50)
Global Char GTBCHRONO(50)(1..50)

  Raz GSZTSYLKEY
  GINBSYLKEY = 0
  Raz GTBKCHR
  Raz GTBVCHR
  Raz GTBCHRONO
  Gosub LOADSYL
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$AVANT_MEN
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "A"
      Gosub RAZSYL
      Gosub LOADSYL
    When Default
  Endcase
Return

##########################################################################################################
$FINSAI
  If clalev([F:SYL]) : Close Local File [SYL] : Endif
Return

##########################################################################################################
$FIN
  Kill GSZTSYLKEY
  Kill GINBSYLKEY
  Kill GTBKCHR
  Kill GTBVCHR
  Kill GTBCHRONO
Return

##########################################################################################################
$ABANDON
  Gosub RAZSYL
  Gosub LOADSYL
Return

##########################################################################################################
$ENREGISTRER
Local Integer ICURLIGNE
Local Integer ILIGNESAVE
Local Integer ILIGNEKEY 
Local Integer LERRCOD
Local Integer IBTRAITE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer IBERROR
Local Char ZSKEYSAVE
Local Char SZTYPESAVE
Local Integer ICHAR

  IBERROR = 0
  ILIGNEKEY = 0
  Raz ZSKEYSAVE
  Raz SZTYPESAVE
  ICHAR = 1
  LERRCOD = 0
  IBTRAITE = 0
  #Traitement des lignes supprimés
  If GINBSYLKEY > 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [SYL]
    For ICURLIGNE = 0 To GINBSYLKEY-1
      If GSZTSYLKEY(ICURLIGNE) <> "" Then
        Delete [SYL] Where [F:SYL]SYLNUM = GSZTSYLKEY(ICURLIGNE)
        If fstat <> 0 Then
          IBERROR = 1
          Break
        Endif
      Endif
    Next ICURLIGNE
    If IBERROR = 0 Then
      Commit
    Else
      Rollback
    Endif
  Endif
  #Traitement des lignes modifiées
  #Traitement des transcodifications
  Call OUVRE_TRACE (mess( 251,177,1)) From LECFIC
  ILIGNEKEY = 0
  ILIGNEDET = 0
  ILIGNESAVE = nolign
  While ILIGNEKEY < [M:SYL0]NBLIGN 
    If [M:SYL0]SYLFLGTRT(ILIGNEKEY) = 2 Then
      IBTRAITE = 1
      #Il faut traiter la ligne
      ICHAR = 1
      Raz GTBCHRONO
      Raz GTBKCHR
      Raz GTBVCHR
      IBERROR = 0
      ZSKEYSAVE = [M:SYL0]SYLKEY(ILIGNEKEY)
      SZTYPESAVE = [M:SYL0]SYLTYP(ILIGNEKEY)
      GTBCHRONO(ICHAR) = [M:SYL0]SYLNUM(ILIGNEKEY)
      GTBKCHR(ICHAR) = [M:SYL0]SYLFIE(ILIGNEKEY)
      GTBVCHR(ICHAR) = [M:SYL0]SYLVALADX(ILIGNEKEY)
      ICHAR += 1
      #On recherche si il y a d'autre ligne sur la même clé
      ICURLIGNE += 1
      While ICURLIGNE < [M:SYL0]NBLIGN
        If [M:SYL0]SYLFLGTRT(ICURLIGNE) = 2 Then
          #Il faut traiter la ligne
          If [M:SYL0]SYLTYP(ICURLIGNE) = SZTYPESAVE and [M:SYL0]SYLKEY(ICURLIGNE) = ZSKEYSAVE Then
            GTBCHRONO(ICHAR) = [M:SYL0]SYLNUM(ICURLIGNE)
            GTBKCHR(ICHAR) = [M:SYL0]SYLFIE(ICURLIGNE)
            GTBVCHR(ICHAR) = [M:SYL0]SYLVALADX(ICURLIGNE)
            ICHAR += 1
            ICURLIGNE += 1
          Else
            ILIGNEKEY = ICURLIGNE  
            Break
          Endif
        Else
          ICURLIGNE += 1
        Endif
      Wend
      If SZTYPESAVE = "TSK" Then
        #Modification de la tâche : +ZSKEYSAVE
        #Rq: transaction géré dans la fonction avec commit ou rollback
        Call UPDTSK("FUNSYL", 1, 0, ZSKEYSAVE, LERRCOD) From SUBTSKCM
        If LERRCOD = 1 Then
          Call ECR_TRACE(mess(239,177,1) - ZSKEYSAVE,1) From GESECRAN
          IBERROR = 1
        Endif        
      Elsif SZTYPESAVE = "CLL" Then
        #Modification de l'appel : +ZSKEYSAVE
        #Rq: transaction géré dans la fonction avec commit ou rollback
        Call UPDCLL("FUNSYL", 1, 0, ZSKEYSAVE, LERRCOD) From SUBCLLCM
        If LERRCOD = 1 Then
          Call ECR_TRACE(mess(239,177,1) - ZSKEYSAVE,1) From GESECRAN
          IBERROR = 1
        Endif        
      Endif
      If IBERROR = 0 Then
        ICURLIGNE = 1
        Call DEBTRANS From GLOCK
        Trbegin [SYL]
        While ICURLIGNE < ICHAR
          Readlock [SYL]SYL0=GTBCHRONO(ICURLIGNE)
          If fstat = 0 Then
            [F:SYL]SYLFLGDPT = 0
            Rewrite [SYL]
          Endif
          ICURLIGNE += 1
        Wend
        Commit
      Endif
      ILIGNEKEY += 1
    Else
      ILIGNEKEY += 1
    Endif
  Wend       
  Call FERME_TRACE From LECFIC
  If IBTRAITE = 1 Then
    Call LEC_TRACE From LECFIC
  Endif
  REP = ""
  Gosub RAZSYL
  Gosub LOADSYL
  Affzo [M:SYL0]1-99
Return

##########################################################################################################
$APRES_MODIF
  If COUZON < >"FILSYLUSR" Then
    REP = "M"
  Endif
Return

##########################################################################################################
# Sous-programmes
#########################################################################################
#
# LOADSYL   : Charge les données de transcodification
#
##########################################################################################################
$LOADSYL
#Charge les données de transcodification
Local Integer ICURLIGNE

  ICURLIGNE = 0
  #Réinitialisation dutableau d'élément à supprimer
  Raz GSZTSYLKEY
  GINBSYLKEY = 0
  #Traitement des filtres
  If FILSYLUSR <> "" Then
    Filter [SYL] Where [F:SYL]SYLUSR=[M:SYL0]FILSYLUSR and [F:SYL]SYLFLGDPT=1 Order By [F:SYL]SYLTYP Asc;[F:SYL]SYLKEY Asc; [F:SYL]SYLFIE Asc
  Else
    Filter [SYL]  Where [F:SYL]SYLFLGDPT=1 Order By [F:SYL]SYLUSR Asc; [F:SYL]SYLTYP Asc;[F:SYL]SYLKEY Asc; [F:SYL]SYLFIE Asc
  Endif
  #Remplit le tableau
  nolign = 0
  For [SYL]
    If ICURLIGNE = dim([M:SYL0]SYLNUM)-1 Then
      Break
    Endif
    #Transclass des données de synchronisation
    nolign += 1
    [M:SYL0] = [F:SYL]
    ICURLIGNE += 1
  Next
  Filter [SYL]
  [M:SYL0]NBLIGN = ICURLIGNE 
  ICURLIGNE = 0
  Affzo [M:SYL0]1-99
  GSYDMODIF = 0
  REP = ""
Return

##########################################################################################################
$RAZSYL
  Raz [M:SYL0]NBLIGN
  Raz [M:SYL0]SYLUSR
  Raz [M:SYL0]SYLTYP
  Raz [M:SYL0]SYLKEY
  Raz [M:SYL0]SYLFIE
  Raz [M:SYL0]SYLVALOTK
  Raz [M:SYL0]SYLVALADX
  Raz [M:SYL0]SYLFLGTRT
  Raz [M:SYL0]SYLFLGDPT
  Raz [M:SYL0]SYLNIV
Return

##########################################################################################################
Subprog C_NBLIGN
Local Integer NOL

  If status = 65 Then
    # Annulation simple
    NOL = nolign-1
    Gosub TRT_ANNULATION
  Elsif status = 68 or status = 83 Then
    # Annulation multiple
    For NOL = nolign-1 To nolign1-1
      Gosub TRT_ANNULATION
    Next NOL
  Endif
End

##########################################################################################################
$TRT_ANNULATION
  GSZTSYLKEY(GINBSYLKEY) = [M:SYL0]SYLNUM (NOL)
  GINBSYLKEY += 1
Return

##########################################################################################################
Subprog AM_SYLVALADX(VALEUR)
Variable Char    VALEUR()

  [M:SYL0]SYLFLGTRT(nolign-1) = 2
  Affzo [M:SYL0]SYLFLGTRT(nolign-1)
End

##########################################################################################################
# Affectation des valeurs pour la création, modification, suppression d'une tache. 
#############################################################################
$TSK_SET_HEA_INFO
Local Integer INDEXE

  Case IMPZON
    When "TSKCMP"
      #Tiers
      INDEXE = find("TSKCMP", GTBKCHR)
      If INDEXE <> 0 Then
        [M:TSK0]TSKCMP = GTBVCHR(INDEXE)      
      Endif
    When "TSKTYP"
      #Catégorie
      INDEXE = find("TSKTYP", GTBKCHR)
      If INDEXE <> 0 Then
        [M:TSK1]TSKTYP = GTBVCHR(INDEXE)
      Endif
  Endcase
Return

##########################################################################################################
# Affectation des valeurs pour la création, modification, suppression d'un appel
#############################################################################
$CLL_SET_HEA_INFO
Local Integer INDEXE

  Case IMPZON
    When "CLLCMP"
      #Tiers
      INDEXE = find("CLLCMP", GTBKCHR)
      If INDEXE <> 0 Then
        [M:CLL0]CLLCMP = GTBVCHR(INDEXE)      
      Endif      
    When "CLLCAT"
      #Catégorie
      INDEXE = find("CLLCAT", GTBKCHR)
      If INDEXE <> 0 Then
        [M:CLL1]CLLCAT = GTBVCHR(INDEXE)
      Endif
  Endcase
Return

##########################################################################################################
# Affectation des valeurs pour la création, modification, suppression d'un rendez vous
#############################################################################
$BAP_SET_HEA_INFO
Local Integer INDEXE

  Case IMPZON
    When "APTCMP"
      #Tiers
      INDEXE = find("APTCMP", GTBKCHR)
      If INDEXE <> 0 Then
        [M:BAP0]APTCMP = GTBVCHR(INDEXE)      
      Endif
    When "APTTYP"
      #Catégorie
      INDEXE = find("APTTYP", GTBKCHR)
      If INDEXE <> 0 Then
        [M:BAP1]APTTYP = GTBVCHR(INDEXE)
      Endif
  Endcase
Return

##########################################################################################################
Subprog B3_NBLIGN
  ## Action GOBJETC1
  Local Char    PARMSK(250)(1..20) , SAVACT(20)

  SAVACT = GACTION
  GACTION = "GOBJETC1"
  Call OBJET_CHAR([M:SYL0]SYLKEY(nolign-1),[M:SYL0]SYLTYP(nolign-1),"") From GOBJET
  GACTION = SAVACT
End
