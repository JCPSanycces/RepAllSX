#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion objet SCSL
######################################################################################
## Etiquette ajoutée par le superviseur (Objet SCSL) 20/03/2018 13:36:58 (TS)
######################################################################################
$ACTION

Case ACTION
 When "DEFTRANS"     : Gosub DEFTRANS
 When "VARIANTE"     : Gosub VARIANTE
 When "SETTRANS"     : Gosub SETTRANS
 When "AVANT_OUVRE"  : Gosub AVANT_OUVRE
 When "OUVRE"        : Gosub OUVRE
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "FILTRE"       : Gosub FILTRE
 When "LIENS"        : Gosub LIENS
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "RAZCRE"       : Gosub RAZCRE
 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "INICRE"       : Gosub INICRE
 When "CREATION"     : Gosub CREATION
 When "APRES_CRE"    : Gosub APRES_CRE
 When "AB_CREATION"  : Gosub AB_CREATION
 When "ABANDON"      : Gosub ABANDON
 When "FIN"          : Gosub ABANDON
 When "FERME"        : Gosub FERME
 When "TIROIR"       : Gosub TIROIR
 When "FILGAUCHE"    : Gosub FILGAUCHE
 When "AP_FILGAUCHE" : Gosub AP_FILGAUCHE
 When "PICKE"        : Gosub PICKE
 When "DEPICK"       : Gosub DEPICK
 When "FIN_PICK"     : Gosub FIN_PICK
 When "FIN_ACTION"   : Gosub FIN_ACTION
When Default
Endcase
Return

######################################################################################
$DEFTRANS
Local Shortint OUVFICFLG
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
If GFONC1<>"GESSCSL" Raz GFLAG Endif
If GFLAG<>""
  Read [F:SRT]SRT0=3;GFLAG
  If fstat | [F:SRT]ENAFLG=1
    Raz GFLAG : Goto FIN_DEFTRANS
  Endif
  If [F:SRT]ACSCOD<>"" & GPROFIL<>GSUPER
    If clalev ([F:ACC])=0
      Local File ACCES  [ACC] : OUVFICFLG=1
    Endif
    Read [ACC] CODACC=GUSER;[F:SRT]ACSCOD
    If fstat | [F:ACC]EXEC<>2
      Raz GFLAG : Goto FIN_DEFTRANS
    Endif
  Endif
Endif
$FIN_DEFTRANS
If OUVFICFLG=1
  Close Local File [ACC] : Raz OUVFICFLG
Endif
Return

######################################################################
$VARIANTE
# La transaction lue est elle utilisable ?
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
Read [SRT]SRT0=3;[F:AWI]TRN
If fstat | [F:SRT]ENAFLG<>2
   OK=0 : Return
Endif
If [F:SRT]BETFCYCOD<>1 | [F:SRT]CHGACC<>2 : OK=0 : Endif
Return

######################################################################
$SETTRANS
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
Read [SRT]SRT0=3;GFLAG
GGRPFCY = [F:SRT]GFY
GSCSNUM = [F:SRT]SRTNUM
Return

######################################################################
$AVANT_OUVRE
#Call AUTORIS From EXEFNC
Return

######################################################################
$OUVRE
Global Integer GSUPLIG
Global Char    GTRUCOD(GLONTRU)
Local Char     SYMBOLE(30)
Local Integer  I, J, NOL
Local Integer  LRET
Local Integer  WA, WQ, WR
Local Char     WMSG(150)
Local Integer  WTRBEGIN
Local Decimal  LQTY, LQTA, LSHT
Local Char     LNUM
Local Integer  LPOT
Local Integer  LNBR, LNBJ, NBSTJ
Local Shortint W_K
Local Char     WSERDEB(GLONSER), WSERFIN(GLONSER), WFIN(GLONSER)
Local Integer  WNBSER
Local Integer  WFIRST

#--- Sauvegarde variables globales
Gosub SAUV_GLOB From TRTX3GLOB

If dim(GSCSAUZSST)<=0    : Global Char    GSCSAUZSST(50) : Endif
GSCSAUZSST = "A*,Q*,R*"

Global Char GFILLOCENT(250)
GFILLOCENT = "[TLO]LOCCAT<=2"

GSRTNUM = GFLAG
# Changement de statut
If [F:SRT]CHGSTACOD=2
  [M:SCSL]TRSTYP=9
# Changement d'emplacement
Else
  [M:SCSL]TRSTYP=7
Endif

GFCY=GFCYDEF(7)
Gosub CHARG_PARAM

# Initialisation des tables nécessaires à la gestion d'emplacements
Gosub STK_INILOC From STKLOC

If clalev([F:STOL])=0 : Local File STOCK     [STOL] : Endif
If clalev([F:STSL])=0 : Local File STOSER    [STSL] : Endif
If clalev([F:STA])=0  : Local File STOALL    [STA]  : Endif

If clalev([M:SGW])=0  : Local Mask STOCHGW   [SGW]  : Endif
If clalev([M:STW])=0  : Local Mask STOWORK   [STW]  : Endif
Raz [M:SGW], [M:STW]

If clalev([M:VALW])=0 : Local Mask STOVALW   [VALW] : Endif
Raz [M:VALW]
[M:VALW]ZONPRI    = "[M:SCSL]PRI"
[M:VALW]ZONPRIORD = "[M:SCSL]PRI"
If !clalev([M:SVW])  : Local Mask STOVALWORK [SVW]  : Endif
If !clalev([M:SVWD]) : Local Mask STOVALWORK [SVWD] : Endif

Return

######################################################################
$OUVRE_BOITE
# Récupération des noms de currbox des tiroirs
Global Char  GBOXLPN(10)
GBOXLPN = "GAU_CHE"+num$(find("LPN1",OBJLIS(1..8)))
Return

######################################################################
$FILTRE
Default File [SGH]
Return

######################################################################
$LIENS
Raz [M:SCSL]
Return

######################################################################
$APRES_MODIF
Gosub SET_NOL

Case COUZON
 When "STOFCY"    : [M]STOFCY=CZ    : Gosub TIROIR
 When "WRHSEL"    : [M]WRHSEL=CZ    : Gosub TIROIR
 When "LOCTYPSEL" : [M]LOCTYPSEL=CZ : Gosub TIROIR
 When "LOCSEL"    : [M]LOCSEL=CZ    : Gosub TIROIR
Endcase

Case GSUPLIG
  When 65     : If [M:SCSL]LPNNUM(NOL)<>""
                  Read [LPN]LPN0=[M:SCSL]LPNNUM(NOL)
                  If !fstat
                    If evalue(FILGAUSUP) Gosub DEPICK From GSAISIE Endif

                    # Si le LPN  dépické est celui dont le détail stock est affiché
                    If [M:SCSL]LPNSEL(0)=[F:LPN]LPNNUM
                      If NOL>0
                        NOL-=1
                        Gosub AFF_STOCK_LPN
                      Else
                        Effzo [M:SCSL]25
                      Endif
                    Endif

                    Gosub DEL_CUMWIPQTY
                    # Unlock logique du LPN
                    SYMBOLE="LPN"+[F:LPN]LPNNUM
                    Unlock =SYMBOLE
                  Endif
                Endif
  When 68, 83 : For I=NOL To nolign1-1
                  If [M:SCSL]LPNNUM(I)<>""
                    Read [LPN]LPN0=[M:SCSL]LPNNUM(I)
                    If !fstat
                      If evalue(FILGAUSUP) Gosub DEPICK From GSAISIE Endif
                      Gosub DEL_CUMWIPQTY
                      # Unlock logique du LPN
                      SYMBOLE="LPN"+[F:LPN]LPNNUM
                      Unlock =SYMBOLE
                    Endif
                  Endif
                Next I

                # Si le LPN  dépické est celui dont le détail stock est affiché
                If [M:SCSL]LPNSEL(0)=[F:LPN]LPNNUM
                  If NOL>0
                    NOL-=1
                    Gosub AFF_STOCK_LPN
                  Else
                    Effzo [M:SCSL]25
                  Endif
                Endif

Endcase
Raz GSUPLIG

Return

######################################################################
$RAZCRE

If [M:SCSL]STOFCY=""
  [M:SCSL]STOFCY=GFCYDEF(7)
  If [F:FCY]FCY<>[M:SCSL]STOFCY
    Read [F:FCY]FCY0=[M:SCSL]STOFCY
  Endif
  If GFCY<>[M:SCSL]STOFCY
    Gosub CHARG_PARAM
  Endif
  If GWRHACT=2
    If [F:FCY]WRHGES=2
      Actzo [M:SCSL]WRHSEL
      If [F:SRT]CHGEMPCOD=2
        Actzo [M:SCSL]WRHDES
      Else
        Diszo [M:SCSL]WRHDES
      Endif
    Else
      Raz   [M:SCSL]WRHSEL
      Raz   [M:SCSL]WRHDES
      Diszo [M:SCSL]WRHSEL
      Diszo [M:SCSL]WRHDES
    Endif
  Endif
Endif

If [M:SCSL]IPTDAT=[0/0/0] [M:SCSL]IPTDAT=date$ Endif

If [F:SRT]CHGSTACOD=2
  Actzo [M:SCSL]STADES
Else
  Diszo [M:SCSL]STADES
Endif
If [F:SRT]CHGEMPCOD=2
  Actzo [M:SCSL]LOCDES
Else
  Diszo [M:SCSL]LOCDES
Endif

Raz [M:SCSL]LOCTYPSEL
Raz [M:SCSL]LOCSEL

# Changement de statut
If [F:SRT]CHGSTACOD=2
  [M:SCSL]TRSTYP=9
# Changement d'emplacement
Else
  [M:SCSL]TRSTYP=7
Endif
[M:SCSL]TRSCOD = [F:SRT]TRSCOD
[M:SCSL]TRSFAM = [F:SRT]TRSFAMDEF

Raz [M:SGW]

Gosub TIROIR

Return

######################################################################
$VERIF_CRE

Raz GMESSAGE
W_K=0

For I=0 To [M:SCSL]NBLIG-1
  If [M:SCSL]LOCDES(I)=[M:SCSL]LOC(I) & [M:SCSL]STADES(I)=""
    GMESSAGE=mess(17,104,1)-num$(I+1)+"\"+mess(542,184,1)
    W_K=1 : Break
  Endif
  # Contrôle des statuts autorisés par emplacements si
  # - emplacement destination sans statut destination ou
  # - statut destination sans emplacement destination
  # le contrôle est déjà fait si les deux sont renseignés
  If ([M:SCSL]LOCDES(I)<>"" & [M:SCSL]STADES(I)="") | ([M:SCSL]LOCDES(I)="" & [M:SCSL]STADES(I)<>"")
    Filter [STO] Where LPNNUM=[M:SCSL]LPNNUM(I) Order By Key STO6
    For [STO]

      If [M:SCSL]LOCDES(I)<>""
        If [F:STC]LOC<>[M:SCSL]LOCDES(I)
          Read [STC]STC0=[F:STO]STOFCY;[M:SCSL]LOCDES(I)
          If fstat : Raz [F:STC]AUZSST : Endif
        Endif
        Call STKCTRSTA([F:STO]STA,[F:STC]AUZSST,0,0,0,W_K) From STKACT
        If W_K<>0
          GMESSAGE=mess(17,104,1)-num$(I+1)+"\"+[F:STO]STA-":"-mess(832,196,1)-[M:SCSL]LOCDES(I)
          Filter [STO] : Break 2
        Endif
      Elsif [M:SCSL]STADES(I)<>""
        If [F:STC]LOC<>[F:STO]LOC
          Read [STC]STC0=[F:STO]STOFCY;[F:STO]LOC
          If fstat : Raz [F:STC]AUZSST : Endif
        Endif
        Call STKCTRSTA([M:SCSL]STADES(I),[F:STC]AUZSST,0,0,0,W_K) From STKACT
        If W_K<>0
          GMESSAGE=mess(17,104,1)-num$(I+1)+"\"+[M:SCSL]STADES(I)-":"-mess(832,196,1)-[F:STO]LOC
          Filter [STO] : Break 2
        Endif
      Endif
    Next
    Filter [STO]
  Endif
Next I

If W_K<>0
  OK=0 : GERR=1 : Return
Endif

Call OUVRE_TRACE(mess(177,198,1)) From LECFIC

#If func AFNC.ACTIV("KPO")>0
#  If func PORLEGLIB.CTLDOCTYP([M:SCSL]SGHTYP,"SGH",GMESSAGE)=1
#    OK=0 : GERR=1 : Return
#  Endif
#Endif

Return

######################################################################
$INICRE

# Création du numéro de document si nécessaire
If GSTKCPTMAN(14)<>2 | [M:SCSL]VCRNUM = ""
  Call NUMERO(GSTKCPT(14), [M:SCSL]STOFCY, [M:SCSL]IPTDAT, "", LNUM, LRET) From SUBANM
  If GOK<0 Return Endif
  If LRET=0
    [M:SCSL]VCRNUM=LNUM
    [F:SGH]VCRNUM =LNUM
  Else
    GERR=1 : GMESSAGE=mess(60,199,1)
    GOK=0
  Endif
Endif

[M:SCSL]VCRTYP=29

[F:SGH]BETFCYCOD=1
[F:SGH]BETCPY=1
[F:SGH]INVSGH=1
[F:SGH]INVFLG=1
[F:SGH]FCYDES=[M:SCSL]STOFCY
[F:SGH]ORISCSLPN=1

### Voir [F:SGH] : zones avec code activité KPO ###

Return

######################################################################
$CREATION

NBSTJ=0

If [F:SRT]SRTNUM<>GSCSNUM
  Read [SRT]SRT0=3;GSCSNUM
Endif

# Boucle sur les LPN pour créer les détails changements de stock
For nolign=1 To [M:SCSL]NBLIG
  J=0
  Filter [STOL] Where LPNNUM=[M:SCSL]LPNNUM(nolign-1) Order By Key STO6
  # Boucle sur le stock du LPN
  For [STOL]
    #--- Pas de chgt d'emplacement et statut ligne stock identique statut destination
    #--- alors pas de changement pour cette ligne de stock
    If [M:SCSL]LOCDES(nolign-1)=[M:SCSL]LOC(nolign-1) & [F:STOL]STA=[M:SCSL]STADES(nolign-1)
      Goto NEXT_STO
    Endif
    # Lecture article, article-site et règle de gestion
    If [F:ITM]ITMREF<>[F:STOL]ITMREF
      Read [ITM]ITM0=[F:STOL]ITMREF
      If fstat : Raz [F:ITM] : Endif
    Endif
    If [F:ITF]STOFCY<>[F:STOL]STOFCY
      Read [ITF]ITF0=[F:STOL]ITMREF;[F:STOL]STOFCY
      If fstat : Raz [F:ITF] : Endif
    Endif
    If [F:ITF]STOMGTCOD=3
      If [F:STL]ITMREF<>[F:STOL]ITMREF | [F:STL]LOT<>[F:STOL]LOT | [F:STL]SLO<>[F:STOL]SLO
        Read [STL]STL0=[F:STOL]ITMREF;[F:STOL]LOT;[F:STOL]SLO
      Endif
      LPOT = [F:STL]POT/100
    Else
      LPOT = 1
    Endif
    Call LECSRU([F:STOL]STOFCY,[F:ITM]TCLCOD,26,[M:SCSL]TRSCOD,"",LRET) From STKLIB

    If [F:ITM]SERMGTCOD<>4
      J+=1
      # Création détail changement de stock
      Gosub CRE_SGD
      If GOK<1 : Break : Endif
      # Maj des stocks
      Gosub MAJ_STOCK
      If GOK<1 : Break : Endif
      NBSTJ+=1
    # Article avec no série géré en E/S globales
    # Il faut traiter les séquences de no séries
    Else
      Filter [STSL] Where ITMREF=[F:STOL]ITMREF & STOCOU=[F:STOL]STOCOU Order By Key STS3
      For [STSL]
        If WSERDEB=""
          WFIRST =1
          WNBSER =1
          WSERDEB=[F:STSL]SERNUM
          WSERFIN=[F:STSL]SERNUM
        Else
          Call PLUS_UN(WSERFIN,WFIN,LRET) From STKLIB
          If LRET<>0 : GOK=0 : Break : Endif
          If WFIN=[F:STSL]SERNUM
            WNBSER+=1
            WSERFIN=[F:STSL]SERNUM
          Else
            J+=1
            # Création détail changement de stock
            Gosub CRE_SGD
            If GOK<1 : Break : Endif
            # Maj des stocks
            Gosub MAJ_STOCK
            If GOK<1 : Break : Endif
            NBSTJ+=1
            WFIRST =0
            WNBSER =1
            WSERDEB=[F:STSL]SERNUM
            WSERFIN=[F:STSL]SERNUM
          Endif
        Endif
      Next
      Filter [STSL]
      If WSERDEB<>""
        J+=1
        # Création détail changement de stock
        Gosub CRE_SGD
        If GOK<1 : Break : Endif
        # Maj des stocks
        Gosub MAJ_STOCK
        If GOK<1 : Break : Endif
        NBSTJ+=1
      Endif
    Endif

    $NEXT_STO
  Next
  Filter [STOL]
  If GOK<1 : Break : Endif
Next

#--- Rien à traiter, aucun changement n'a été effectuée sur les lignes de stock
If NBSTJ=0
  GERR=1 : GMESSAGE=mess(300,139,1) : GOK=0
Endif

Return

######################################################################
$CRE_SGD

Raz [F:SGD]
[F:SGD] = [M:SCSL]
[F:SGD] = [F:STOL]

[F:SGD]VCRLIN    = (1000*nolign)+J
[F:SGD]PCUDES    = [F:STOL]PCU

If [F:ITM]SERMGTCOD = 4
  [F:SGD]COEDES    = 1
  [F:SGD]QTYPCUDES = WNBSER
  [F:SGD]QTYSTUDES = WNBSER
  [F:SGD]SERNUM    = WSERDEB
  [F:SGD]SERNUMF   = WSERFIN
Else
  [F:SGD]COEDES    = [F:STOL]PCUSTUCOE
  [F:SGD]QTYPCUDES = [F:STOL]QTYPCU
  [F:SGD]QTYSTUDES = [F:STOL]QTYSTU
  [F:SGD]SERNUMF=[F:SGD]SERNUM
Endif

[F:SGD]ITMDES1 = [F:ITM]ITMDES1
[F:SGD]STU     = [F:ITM]STU

If [F:SGD]QLYCTLDEM<>"" | left$([M:SCSL]STADES(nolign-1),1)<>"Q"
  [F:SGD]QLYCTLFLG=1
Else
  [F:SGD]QLYCTLFLG=[F:SRU]QLYCTLFLG
Endif

Write [SGD]
If fstat
  GOK=0 : Call FSTA("SGD") From GLOCK
  Return
Endif

Return

######################################################################
$MAJ_STOCK

# Création STOCHGW
Raz [M:SGW]
[M:SGW]TRSTYP = 7
[M:SGW]TRSCOD = ""
[M:SGW]FCYDES = [M:SCSL]STOFCY

[M:SGW]WSTOSEQ(0)    = nolign
[M:SGW]WSTOCOU(0)    = [F:STOL]STOCOU
If [M:SCSL]STADES(nolign-1)<>""
  [M:SGW]WSTADES(0) = [M:SCSL]STADES(nolign-1)
Endif
If dim([M:SCSL]WRH)>0
  [M:SGW]WWRHDES(0) = [M:SCSL]WRHDES(nolign-1)
Endif
[M:SGW]WLOCTYPDES(0) = [M:SCSL]LOCTYPDES(nolign-1)
[M:SGW]WLOCDES(0)    = [M:SCSL]LOCDES(nolign-1)
[M:SGW]WPALNUMDES(0) = [F:STOL]PALNUM
[M:SGW]WCTRNUMDES(0) = [F:STOL]CTRNUM
[M:SGW]WPOT(0)       = LPOT
[M:SGW]WLPNNUMDES(0) = [F:STOL]LPNNUM
[M:SGW]WIPTDAT(0)    = [M:SCSL]IPTDAT
[M:SGW]QLYCTLFLG(0)  = [F:SGD]QLYCTLFLG

If [F:ITM]SERMGTCOD = 4
  [M:SGW]WSERNUM(0)    = [F:SGD]SERNUM
  [M:SGW]WSERNUMF(0)   = [F:SGD]SERNUMF
  [M:SGW]WQTYSTUDES(0) = [F:SGD]QTYSTUDES
  # Il faut déverrouiller la quantité en traitement de la ligne de stock lors
  # du traitement de la première séquence de séries car on ne connait pas la répartition
  If WFIRST=1
    [M:SGW]WWIPQTY(0)    = [F:STOL]CUMWIPQTY
    [M:SGW]WWIPQTA(0)    = [F:STOL]CUMWIPQTA
  Else
    [M:SGW]WWIPQTY(0)    = 0
    [M:SGW]WWIPQTA(0)    = 0
  Endif
Else
  [M:SGW]WQTYSTUDES(0) = [F:STOL]QTYSTU
  [M:SGW]WWIPQTY(0)    = [F:STOL]CUMWIPQTY
  [M:SGW]WWIPQTA(0)    = [F:STOL]CUMWIPQTA
Endif

[M:SGW]NBLIG=1

# Appel à ALISTOWORK
Raz [M:STW]
[M:STW]STOFCY     = [M:SCSL]STOFCY
[M:STW]TRFFCY     = [M:SCSL]STOFCY
[M:STW]TRSTYP     = [M:SCSL]TRSTYP
[M:STW]VCRTYP     = [M:SCSL]VCRTYP
[M:STW]VCRNUM     = [F:SGD]VCRNUM
[M:STW]VCRLIN     = [F:SGD]VCRLIN
[M:STW]ITMREF     = [F:STOL]ITMREF
[M:STW]MVTDES     = [M:SCSL]MVTDES(nolign-1)
[M:STW]TRSFAM     = [M:SCSL]TRSFAM
[M:STW]IPTDAT     = [M:SCSL]IPTDAT
[M:STW]TRSCOD     = [M:SCSL]TRSCOD
[M:STW]PJT        = [M:SCSL]PJT
[M:STW]PIOQTY     = 1

Raz LRET
Call ALISTOWORK(7,nolign,LQTA,LSHT,LNBR,LNBJ,LRET ) From STKINT

# Appel à la maj des stocks
If LRET=0
  Call MAJ_STOCK From STKMAJ
Else
  GOK=0
Endif

Return

######################################################################
$APRES_CRE

Affzo [M:SCSL]VCRNUM

For I=0 To [M:SCSL]NBLIG-1
  Read [LPN]LPN0=[M:SCSL]LPNNUM(I)
  If !fstat
    SYMBOLE = "LPN"+[F:LPN]LPNNUM
    Unlock  = SYMBOLE
  Endif
Next

If GTRACE<>""
  Call ECR_TRACE("***"-mess(554,184,1)-":"-[M:SCSL]VCRNUM,0) From GESECRAN
  Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
  If dim(GTRAVT)>0 : Raz GTRAVT : Endif
Endif

Effzo [M:SCSL]STOFCY
Effzo [M:SCSL]SGHTYP
Effzo [M:SCSL]IPTDAT
Affzo [M:SCSL]VCRNUM
Affzo [M:SCSL]VCRDES
Effzo [M:SCSL]TRSFAM
Effzo [M:SCSL]PJT
Effzo [M:SCSL]15,20,25

Chgtbk [M:SCSL]25 With mess(543,184,1)

Return

######################################################################
$AB_CREATION
If GTRACE<>""
  Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
Endif

Return

######################################################################
$FIN_ACTION
If REPONSE=GSTACRE : Gosub TIROIR : Endif

Return

######################################################################
$ABANDON
Local Integer LRET

For I=0 To [M:SCSL]NBLIG-1
  Read [LPN]LPN0=[M:SCSL]LPNNUM(I)
  If !fstat
    SYMBOLE = "LPN"+[F:LPN]LPNNUM
    Unlock = SYMBOLE
    If evalue(FILGAUSUP) Gosub DEPICK From GSAISIE Endif
    Gosub DEL_CUMWIPQTY
  Endif
Next

Raz [M:SCSL]
ILIS=val(right$(currbox,8))
Gosub REMP_LISGAU From GOBJSUB
WPICK = 1
Gosub RAFFRAICHI

Return

######################################################################
$FERME
#--- Restitution variables globales
Gosub REST_GLOB From TRTX3GLOB

Return

######################################################################
$TIROIR

ILIS=val(right$(currbox,8))

Gosub REMP_LISGAU From GOBJSUB

WPICK=2
Gosub RAFFRAICHI

Return

######################################################################
$FILGAUCHE

Case currbox
 When GBOXLPN  : Gosub FILGAUCHE_LPN
 When Default  : Return
Endcase

Return

######################################################################
$FILGAUCHE_LPN

Raz FILGAUSUP(1)
Raz FILGAUSUP(2)
Raz FILGAUSUP(3)

If GREP<>"C"
  # Rien dans la liste de picking
  FILGAUSUP(0)='[F:LPN]STOFCY=""'
  Return
Endif

FILGAUSUP(0) = '[F:LPN]STOFCY=[M:SCSL]STOFCY & [F:LPN]ENAFLG=2 & [F:LPN]LPNSTAT=2'
If dim([M:SCSL]WRHSEL)>0 & [M:SCSL]WRHSEL<>""
  FILGAUSUP(0)+= '&[F:LPN]WRH=[M:SCSL]WRHSEL'
Endif
If [M:SCSL]LOCSEL<>""
  FILGAUSUP(0)+= '&[F:LPN]LOC=[M:SCSL]LOCSEL'
Elsif [M:SCSL]LOCTYPSEL<>""
  FILGAUSUP(0)+= '&[F:LPN]LOCTYP=[M:SCSL]LOCTYPSEL'
Endif

Return

######################################################################
$AP_FILGAUCHE

Case currbox
 When GBOXLPN  : WPICK=2 : Gosub RAFFRAICHI
 When Default
Endcase

Return

######################################################################
$PICKE

Case currbox
 When GBOXLPN  : Gosub PICKE_LPN
 When Default
Endcase

Return

######################################################################
$PICKE_LPN
Read [LPN]LPN0=[F:LPN]LPNNUM
If fstat
   Call RSTA ("LPN",[F:STO]LPNNUM) From GLOCK
   FOK=0 : Return
Endif

# Lock logique du LPN
SYMBOLE = "LPN"+[F:LPN]LPNNUM
Lock = SYMBOLE
If fstat
  # Modification en cours sur un autre poste
  Call ERREUR ("$LPN"-[F:LPN]LPNNUM-mess(10,100,1)) From GESECRAN
  FOK=0 : Return
Endif

Raz WMSG
#Boucle de contrôle des lignes de stock
Filter [STO] Where LPNNUM=[F:LPN]LPNNUM Order By Key STO6
For [STO]
  If [F:STO]ITMREF<>[F:ITM]ITMREF
    Read [ITM]ITM0=[F:STO]ITMREF
    If fstat
      GMESSAGE=[F:STO]ITMREF-":"-mess(212,199,1)
      FOK=0 : GERR=1 : Break
    Endif
  Endif
  If [F:STO]CUMWIPQTA>0
    WMSG=mess(488,199,1)    : # Ligne de stock en cours de traitement
    FOK=0 : GERR=1 : Break
  Endif
  If [F:STO]QLYCTLDEM<>""
    WMSG=mess(532,184,1)    : # Ligne(s) de stock en controle qualité
    FOK=0 : GERR=1 : Break
  Endif
  If [F:STO]CUNLOKFLG = 2
    WMSG=mess(233,184,1)    : # Ligne(s) de stock en inventaire
    FOK=0 : GERR=1 : Break
  Endif
  Look [F:STA]STA0(3)=[F:STO]STOFCY;[F:STO]ITMREF;[F:STO]STOCOU
  [G:STA]currlen=0
  If !fstat
    # La ligne de stock est-elle en cours de pesée
    Call ALL_WEIGHING([F:STO]STOFCY,[F:STO]ITMREF,[F:STO]STOCOU,LRET) From STKALL
    If LRET<>0
      WMSG=mess(533,184,1)  : # Ligne(s) de stock en cours de pesée
      FOK=0 : GERR=1 : Break
    Endif
  Endif
Next
Filter [STO]

If GERR=1
  If GMESSAGE=""
    GMESSAGE =mess(133,187,1)-":"-[F:STO]ITMREF
    GMESSAGE-=mess(399,198,1)-":"-[F:STO]STA
    If [F:ITM]LOTMGTCOD>1
      GMESSAGE-=mess(43,197,1)-":"-[F:STO]LOT
    Endif
    If [F:ITM]LOTMGTCOD=4
      GMESSAGE-=mess(456,197,1)-":"-[F:STO]SLO
    Endif
    If [F:ITM]SERMGTCOD=3
      GMESSAGE-=mess(453,197,1)-":"-[F:STO]SERNUM
    Endif
    If [F:STO]LOC<>""
      GMESSAGE-=mess(44,197,1)-":"-[F:STO]LOC
    Endif
    GMESSAGE+="\"+WMSG
  Endif
  Unlock=SYMBOLE
  Return
Endif

# Boucle de verrouillage des quantités des lignes de stock
Gosub CRE_CUMWIPQTY
If FOK=0 : Return :  Endif

# Contrôle de l'insertion
If [M:SCSL]NBLIG+1 >= dim([M:SCSL]LPNNUM)-1
  FOK=0 : GERR=1
  GMESSAGE=mess(122,199,1)
  Return
Endif

#--- La sélection est correcte

# Ouverture de la ligne
nolign = [M:SCSL]NBLIG
Insa nolign,1,[M:SCSL]NBLIG [M:SCSL]NBLIG
[M:SCSL]NBLIG += 1
nolign = [M:SCSL]NBLIG
NOL = nolign-1
status = 0

[M:SCSL] = [F:LPN]

Raz [M:SCSL]VCRTYP
Raz [M:SCSL]VCRNUM

If dim([M:SCSL]WRH)>0 : [M:SCSL]WRHDES(NOL)=[M:SCSL]WRH(NOL) : Endif
[M:SCSL]LOCDES(NOL)   =[M:SCSL]LOC(NOL)
[M:SCSL]LOCTYPDES(NOL)=[M:SCSL]LOCTYP(NOL)
Raz [M:SCSL]STADES(NOL)
Raz [M:SCSL]MVTDES(NOL)

Gosub AFF_STOCK_LPN

Return

######################################################################
$DEPICK

Raz I,J
Case currbox
 When GBOXLPN  : Gosub DEPICK_LPN
 When Default
Endcase

Return

######################################################################
$DEPICK_LPN

If [M:SCSL]NBLIG <> 0
  I=find([F:LPN]LPNNUM,[M:SCSL]LPNNUM(J..[M:SCSL]NBLIG-1))
  If I<>0
    NOL=J+I-1
    J=NOL
    Dela NOL,1,[M:SCSL]NBLIG-1 [M:SCSL]NBLIG
    [M:SCSL]NBLIG-=1

    # Si le LPN  dépické est celui dont le détail stock est affiché
    If [M:SCSL]LPNSEL(0)=[F:LPN]LPNNUM
      If NOL>0
        NOL-=1
        Gosub AFF_STOCK_LPN
      Else
        Effzo [M:SCSL]25
      Endif
    Endif

    # Boucle de déverrouillage des quantités des lignes de stock
    Gosub DEL_CUMWIPQTY

    # Unlock logique du LPN
    SYMBOLE="LPN"+[F:LPN]LPNNUM
    Unlock =SYMBOLE
  Endif

Endif

Return

######################################################################
$FIN_PICK

Affzo [M:SCSL]1-99

If [M:SCSL]NBLIG<>0
  # Repositionnement sur la ligne pickée
  zonsui = "[M:SCSL]NBLIG("+num$(NOL)+")"
Endif

Return

Return

#######################################################################
$RAFFRAICHI

If currbox=GBOXLPN
  For I=0 To [M:SCSL]NBLIG-1
    Read [LPN]LPN0=[M:SCSL]LPNNUM(I)
    If fstat : Raz [F:LPN] : Endif
    If    WPICK=1 Gosub DEPICK From GOBJSUB
    Elsif WPICK=2 Gosub REPICK From GOBJSUB
    Endif
  Next I
Endif

Return

#######################################################################
$CRE_CUMWIPQTY

# Si pas de transaction en cours
If adxlog<>1
  FOK=1
  Trbegin [STO]
  WTRBEGIN=1
Endif

# Boucle de verrouillage des quantités des lignes de stock
Filter [STO] Where LPNNUM=[F:LPN]LPNNUM Order By Key STO6
For [STO]
  Readlock [STOL]STO0=[F:STO]STOFCY;[F:STO]STOCOU
  If !fstat
    If [F:STOL]CUMWIPQTA>0
      GMESSAGE=mess(488,199,1)
      FOK=0 : GERR=1 : Break
    Else
      LQTY=[F:STOL]QTYSTU   -[F:STOL]CUMALLQTY
      LQTA=[F:STOL]QTYSTUACT-[F:STOL]CUMALLQTA
      If LQTY>0
        [F:STOL]CUMWIPQTY += LQTY
        [F:STOL]CUMWIPQTA += LQTA
        Rewrite [STOL]
        # Création quantité en cours de traitement
        Call CRE_STOWIPW([F:STOL]STOCOU,LQTY,LQTA) From STKLIB
      Endif
    Endif
  Else
    Call RSTA ("STOL",[F:STO]STOFCY-num$([F:STO]STOCOU)) From GLOCK
    FOK=0 : Break
  Endif
Next
Filter [STO]

# Si on a ouvert une transaction
If WTRBEGIN=1
  Raz WTRBEGIN
  If FOK=0
    Rollback
    Unlock=SYMBOLE
    Return
  Else
    Commit
  Endif
Endif

Return

#######################################################################
$DEL_CUMWIPQTY

# Si pas de transaction en cours
If adxlog<>1
  FOK=1
  Trbegin [STO]
  WTRBEGIN=1
Endif

# Boucle de déverrouillage des quantités des lignes de stock
Filter [STO] Where LPNNUM=[F:LPN]LPNNUM Order By Key STO6
For [STO]
  Readlock [STOL]STO0=[F:STO]STOFCY;[F:STO]STOCOU
  If !fstat
    LQTY=[F:STOL]CUMWIPQTY
    LQTA=[F:STOL]CUMWIPQTA
    If LQTY>0
      [F:STOL]CUMWIPQTY -= LQTY
      [F:STOL]CUMWIPQTA -= LQTA
      Rewrite [STOL]
      # Suppression quantité en cours de traitement
      Call DEL_STOWIPW([F:STOL]STOCOU,LQTY) From STKLIB
    Endif
  Endif
Next
Filter [STO]

# Si on a ouvert une transaction
If WTRBEGIN=1
  Raz WTRBEGIN
  Commit
Endif

Return

######################################################################
$SET_NOL
Local Integer NOL
NOL = nolign-1
Return

######################################################################
Subprog AS_STOFCY(VALEUR)
Variable Char    VALEUR()
# Si ligne déjà saisie, plus d'accés au site de stock
If [M:SCSL]NBLIG<>0 mkstat=2 Endif
End

######################################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()

GFCY=VALEUR : Gosub CHARG_PARAM

If GWRHACT=2
  If [F:FCY]WRHGES=2
    Actzo [M:SCSL]WRHSEL
    If [F:SRT]CHGEMPCOD=2
      Actzo [M:SCSL]WRHDES
    Else
      Diszo [M:SCSL]WRHDES
    Endif
  Else
    Raz   [M:SCSL]WRHSEL
    Raz   [M:SCSL]WRHDES
    Grizo [M:SCSL]WRHSEL
    Grizo [M:SCSL]WRHDES
  Endif
Endif
End

######################################################################
Subprog AS_SGHTYP(VALEUR)
Variable Char    VALEUR()

#85785
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif
If [F:SRT]SRTTYP<>3 | [F:SRT]SRTNUM<>GSCSNUM
  Read [F:SRT]SRT0=3;GSCSNUM : If fstat  Raz [F:SRT] : Endif
Endif

If VALEUR=""
    Local Char WSGHTYP(GLONTSG)
    Gosub SGHTYP From TRTSTKSGH1 : VALEUR=WSGHTYP
Endif
End

######################################################################
Subprog C_SGHTYP(VALEUR)
Variable Char    VALEUR()

#85785
If clalev([F:FCY]) = 0 : Local File FACILITY  [FCY]  : Endif
If clalev([F:TSG]) = 0 : Local File TABSGHTYP [TSG]  : Endif
If clalev([F:SRT]) = 0 : Local File STKTRS    [SRT]  : Endif

Local    Char    LEG
Local    Integer CAS   : [L]CAS = 1 : # 1 - Legislation is empty; 2 - Legislation isn't empty

If [F:FCY]FCY <> GFCY : Read [F:FCY]FCY0 = GFCY : Endif
If fstat > 1 : Raz [F:FCY] : Endif

If [F:SRT]SRTTYP<>3 | [F:SRT]SRTNUM<>GSCSNUM
  Read [F:SRT]SRT0=3;GSCSNUM : If fstat  Raz [F:SRT] : Endif
Endif

If func AFNC.ACTIV("LEG")=0
  [L]LEG = GDOSLEG
Elsif LEG=""
  [L]LEG = [F:FCY]LEG
Endif

If [L]LEG<>""
  Read [TSG]TSG0=VALEUR;[L]LEG
  If fstat
    Read [TSG]TSG0=VALEUR;""
  Else
    [L]CAS = 2 : # Legislation isn't empty
  Endif
Else
  Read [F:TSG]TSG0(1)=[L]VALEUR
  If !fstat
    [L]LEG = [F:TSG]LEG
    [L]CAS = 2 : # Legislation isn't empty
  Endif
Endif

If fstat
  Filter [F:TSG] Where [F:TSG]SGHTYP=VALEUR
  Look [F:TSG]TSG0 First
  If !fstat
    # Fiche inexistante pour la législation courante
    GMESSAGE = VALEUR-":"-mess(232,107,1)-"["+[L]LEG+"]"
  Else
    # Fiche inexistante
    GMESSAGE = VALEUR-":"-mess(23,100,1)
  Endif
  Filter [F:TSG]
  mkstat = 2 : End
Endif

If [F:TSG]GFY<>""
  If clalev([F:AGF])=0 : Local File AGRPFCY    [AGF]  : Endif
  Read [AGF]AGF0=[F:TSG]GFY
  If !fstat
    If [F:AGF]FLGLEG=2
      #--Company
      If [F:TSG]GFY<>[F:FCY]LEGCPY
        GMESSAGE += VALEUR+"\"+mess(63,127,1)-":"-[F:TSG]GFY : # Réservé au groupe de société
        mkstat = 2 : End
      Endif
    Elsif [F:AGF]FLGCPY=2
      If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
      Look [AGC]AGC0 = [F:TSG]GFY;[F:FCY]LEGCPY
      If fstat
        GMESSAGE += VALEUR+"\"+mess(63,127,1)-":"-[F:TSG]GFY : # Réservé au groupe de société
        mkstat = 2 : End
      Endif
    Endif
  Endif
Endif

If [F:TSG]BETFCYCOD <> [F:SRT]BETFCYCOD
  GMESSAGE = VALEUR+":"+ mess(51,139,1) - "("+mess([F:TSG]BETFCYCOD,792,1)+")"
  mkstat = 2 : End
Endif

#If func AFNC.ACTIV("KPO")>0
#  If func PORLEGLIB.CTLDOCTYP(VALEUR,"SGH",GMESSAGE) = 1
#    mkstat = 2 : End
#  Endif
#Endif
End

######################################################################
Subprog AM_SGHTYP(VALEUR)
Variable Char    VALEUR()

#85785
[M:SCSL]SGHTYP=VALEUR
Gosub CHARG_PARAM
If GSTKCPTMAN(14)<>2 & [M:SCSL]VCRNUM <> ""
   Effzo [M:SCSL]VCRNUM
Endif

If GSTKCPTMAN(14)<>2
   Diszo [M:SCSL]VCRNUM
Else
   Actzo [M:SCSL]VCRNUM
Endif
End

######################################################################
Subprog D_VCRNUM(VALEUR)
Variable Char    VALEUR()
[M:SCSL]VCRTYP = 29
End

######################################################################
Subprog C_VCRNUM(VALEUR)
Variable Char    VALEUR()

#-- Il faut une valeur saisie ou retournée par un compteur sinon erreur
If (VALEUR="" &  GSTKCPT(14)="")
  mkstat=2 : End
Endif
#-- Si on est en création , no saisi vide et un compteur est présent on sort
If (VALEUR="" &  GSTKCPT(14)<>"")
  End
Endif

#-- Si dernier lu non chargé, on vérifie l'existence du no saisi
#If [M:SCSL]VCRNUM="" & GREP<>"C"
#  Look [F:SGH]SGH0=VALEUR
#  If fstat
#    GMESSAGE=mess(178,199,1)
#    mkstat=2 : End
#  Endif
#Endif

If VALEUR<>"" & GSTKCPTMAN(14)<>2
#  Look [F:SGH]SGH0=VALEUR
#  If fstat
    Raz VALEUR : End
#  Endif
Endif
End

######################################################################
Subprog C_LOCTYPSEL(VALEUR)
Variable Char    VALEUR()

VALEUR = toupper(VALEUR)
If VALEUR<>[M:SCSL]LOCTYPSEL
  If VALEUR<>""
    Read [TLO]TLO0=[M:SCSL]STOFCY;VALEUR
    If fstat
      GMESSAGE = mess(245,192,1)
      mkstat=2 : End
    Else
      If [F:TLO]LOCCAT>2
        GMESSAGE = mess(399,199,1)
        mkstat=2 : End
      Endif
      If [M:SCSL]LOCSEL<>""
        Raz [M:SCSL]LOCSEL
        Affzo [M:SCSL]LOCSEL
      Endif
    Endif
  Endif
Endif

End

######################################################################
Subprog C_LOCSEL(VALEUR)
Variable Char    VALEUR()

VALEUR = toupper(VALEUR)
If VALEUR<>[M:SCSL]LOCSEL
  If VALEUR<>""
    Read [STC]STC0=[M:SCSL]STOFCY;VALEUR
    If fstat
      GMESSAGE = mess(125,184,1)
      mkstat=2 : End
    Else
      If dim([M:SCSL]WRHSEL)>0 & [M:SCSL]WRHSEL<>"" & [F:STC]WRH<>[M:SCSL]WRHSEL
        GMESSAGE = mess(341,184,1)
        mkstat=2 : End
      Endif
      If [F:STC]LOCCAT>2
        GMESSAGE = mess(399,199,1)
        mkstat=2 : End
      Endif
      If [M:SCSL]LOCTYPSEL<>[F:STC]LOCTYP
        [M:SCSL]LOCTYPSEL=[F:STC]LOCTYP
        Affzo [M:SCSL]LOCTYPSEL
      Endif
    Endif
  Endif
Endif

End

######################################################################
Subprog IB_NBLIG
End

######################################################################
Subprog C_NBLIG
Gosub SET_NOL

If [M:SCSL]LPNSEL(0)<>[M:SCSL]LPNNUM(NOL)
  If [M:SCSL]LPNNUM(NOL)<>""
    Gosub AFF_STOCK_LPN
  Else
    Effzo [M:SCSL]25
  Endif
Endif

# Suppression de lignes
If find(status,65,68,83)
   GSUPLIG = status
Else
   Raz GSUPLIG
Endif

End

######################################################################
Subprog AVANT_NBLIG
End

######################################################################
Subprog APRES_NBLIG
End

######################################################################
Subprog C_WRHDES(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL

# Si dépôt non modifiée ou dépôt = dépôt origine, rien à faire
If VALEUR=[M:SCSL]WRHDES(NOL) | VALEUR=[M:SCSL]WRH(NOL) : End :Endif
# Si article avec gestion de dépôt, dépôt destination obligatoire
If [F:FCY]WRHGES=2 & VALEUR=""
  GMESSAGE=mess(340,184,1)
  mkstat=2 : End
Endif

# Contrôle que les articles du LPN ont bien un article-dépôt
For [STO]STO6(2) Where LPNNUM=[M:SCSL]LPNNUM(NOL)
   Read [ITW]ITW0=[F:STO]ITMREF;VALEUR
   If fstat
      GERR=1 : GMESSAGE=[F:STO]ITMREF-":"-mess(978,196,1)-VALEUR
      mkstat=2 : Break
   Endif
Next

# Si dépôt modifiée et dépôt <> dépôt origine, contrôle du dépôt de l'emplacement destination
If VALEUR<>[M:SCSL]WRHDES(NOL) & VALEUR<>[M:SCSL]WRH(NOL) & [M:SCSL]LOCDES(NOL)<>""
  Read [STC]STC0=[M:SCSL]STOFCY;[M:SCSL]LOCDES(NOL)
  If fstat | [F:STC]WRH<>VALEUR
    Raz [M:SCSL]LOCDES(NOL)
  Endif
Endif

End

######################################################################
Subprog C_LOCTYPDES(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL

VALEUR = toupper(VALEUR)
If VALEUR<>[M:SCSL]LOCTYPDES(NOL)
  If VALEUR<>""
    Read [TLO]TLO0=[M:SCSL]STOFCY;VALEUR
    If fstat
      GMESSAGE = mess(245,192,1)
      mkstat=2 : End
    Else
      If [F:TLO]LOCCAT>2
        GMESSAGE = mess(399,199,1)
        mkstat=2 : End
      Endif
      If [M:SCSL]LOCDES(NOL)<>""
        Raz [M:SCSL]LOCDES(NOL)
        Affzo [M:SCSL]LOCDES(NOL)
      Endif
    Endif
  Endif
Endif

End

######################################################################
Subprog C_LOCDES(VALEUR)
Variable Char    VALEUR()
Local Shortint W_K
Gosub SET_NOL

VALEUR=toupper(VALEUR)

# Si emplacement non modifié ou emplacement = emplacement origine
If VALEUR=[M:SCSL]LOCDES(NOL) | VALEUR=[M:SCSL]LOC(NOL)
  If [M:SCSL]LOCTYPDES(NOL)<>[M:SCSL]LOCTYP(NOL)
    [M:SCSL]LOCTYPDES(NOL) = [M:SCSL]LOCTYP(NOL)
    Affzo [M:SCSL]LOCTYPDES(NOL)
  Endif
  End
Endif

# Emplacement destination obligatoire
If VALEUR=""
  GMESSAGE=mess(379,199,1) : mkstat=2 : End
Endif

If VALEUR=[M:SCSL]LOCSEL
  End
Endif

Read [STC]STC0=[M:SCSL]STOFCY;VALEUR
If fstat
  GMESSAGE=mess(125,184,1)
  mkstat=2 : End
Elsif GWRHACT=2 & [F:FCY]WRHGES=2
  If [F:STC]WRH<>[M:SCSL]WRHDES(NOL)
    GMESSAGE=mess(341,184,1)
    mkstat=2 : End
  Endif
Endif
# Pas de transfert de LPN vers un emplacement externe
If [F:STC]LOCCAT>2
  GMESSAGE = mess(399,199,1)-":"-mess([F:STC]LOCCAT,2710,1)
  mkstat=2 : End
Endif

# Test statut autorisé pour l'emplacement saisi
If [M:SCSL]STADES(NOL)<>""
  Call STKCTRSTA([M:SCSL]STADES(NOL),[F:STC]AUZSST,0,0,0,W_K) From STKACT
  If W_K<>0
    mkstat=2
    If GMESSAGE<>"" : GMESSAGE+=chr$(13) : Endif
    GMESSAGE+=mess(832,196,1)-VALEUR
    End
  Endif
Endif

[M:SCSL]LOCTYPDES(NOL) = [F:STC]LOCTYP
Affzo [M:SCSL]LOCTYPDES(NOL)

End

######################################################################
Subprog AM_STADES(VALEUR)
Variable Char    VALEUR()
Local Shortint W_K : Raz W_K
Gosub SET_NOL

If VALEUR="" : End : Endif

If [F:STC]LOC<>[M:SCSL]LOCDES(NOL)
  Read [STC]STC0=[M:SCSL]STOFCY;[M:SCSL]LOCDES(NOL)
Endif
Call STKCTRSTA(VALEUR,[F:STC]AUZSST,0,0,0,W_K) From STKACT
If W_K<>0 : mkstat=2 : Endif

End

######################################################################
$CHARG_PARAM
Local Integer LRET

# Récupération des codes compteur et effacement fichier de travail
If clalev ([F:TCA])<=0 : Local File TABCOUAFF [TCA] : Endif
# Compteur module stock
Call LECTCA(7,LRET) From SUBTCA
If !LRET
   GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1)
   GERR=1
   Return
Endif

#85785 * RMA
If func AFNC.ACTIV("TRSNE") > 0
  If !clalev([F:TSG]) : Local File TABSGHTYP [TSG] : Endif
  If !clalev([F:FCY]) : Local File FACILITY  [FCY] : Endif
  If [F:FCY]FCY <> GFCY : Read [F:FCY]FCY0 = GFCY : Endif
  Call LEC_TSG_LEG([F:FCY]LEG,[M:SCSL]SGHTYP,LRET) From TRTLECLEG
  If LRET<>0 : Raz [F:TSG] : Endif

  #--Counter definition based on document type
  If [F:TSG]SGHTYP<>""
    GSTKCPTMAN(14) = [F:TSG]MANCOU
    GSTKCPT   (14) = [F:TSG]CODNUM
  Else
    GSTKCPTMAN(14) = [F:TCA]MANCOU(14)
    GSTKCPT   (14) = [F:TCA]CODNUM(14)
  Endif
Else
  GSTKCPTMAN(14) = [F:TCA]MANCOU(14)
  GSTKCPT   (14) = [F:TCA]CODNUM(14)
Endif

#Controle compteur
Call CTRCPT(GSTKCPT(14),type([M:SCSL]VCRNUM), LRET) From STKLIB
If LRET<>0
   GMESSAGE = mess(242,199,1)
   GERR = 1
   GOK  = 0
   Return
Endif
GSTKCPTMAN(0) = [F:TCA]MANCOU(0)
GSTKCPT   (0) = [F:TCA]CODNUM(0)
GSTKCPTMAN(2) = [F:TCA]MANCOU(2)
GSTKCPT   (2) = [F:TCA]CODNUM(2)

Return

######################################################################
$AFF_STOCK_LPN
Local Integer IND, WRET
Local Char    WSERFIN(GLONSER)

Effzo [M:SCSL]25
Raz IND

#Boucle de contrôle des lignes de stock
Filter [STO] Where LPNNUM=[M:SCSL]LPNNUM(NOL) Order By Key STO6
For [STO]
  [M:SCSL]ITMREF(IND)    = [F:STO]ITMREF
  [M:SCSL]LPNSEL(IND)    = [F:STO]LPNNUM
  [M:SCSL]STA(IND)       = [F:STO]STA
  [M:SCSL]PCU(IND)       = [F:STO]PCU
  [M:SCSL]QTYPCU(IND)    = [F:STO]QTYPCU
  [M:SCSL]QLYCTLDEM(IND) = [F:STO]QLYCTLDEM
  If dim([M:SCSL]LOT)>0       : [M:SCSL]LOT(IND)       =[F:STO]LOT       : Endif
  If dim([M:SCSL]SLO)>0       : [M:SCSL]SLO(IND)       =[F:STO]SLO       : Endif
  If dim([M:SCSL]ECCVALMAJ)>0 : [M:SCSL]ECCVALMAJ(IND) =[F:STO]ECCVALMAJ : Endif
  If dim([M:SCSL]PALNUM)>0    : [M:SCSL]PALNUM(IND)    =[F:STO]PALNUM    : Endif
  If dim([M:SCSL]CTRNUM)>0    : [M:SCSL]CTRNUM(IND)    =[F:STO]CTRNUM    : Endif
  If dim([M:SCSL]STOFLD1)>0   : [M:SCSL]STOFLD1(IND)   =[F:STO]STOFLD1   : Endif
  If dim([M:SCSL]STOFLD2)>0   : [M:SCSL]STOFLD2(IND)   =[F:STO]STOFLD2   : Endif
  If dim([M:SCSL]SERNUM)>0
    [M:SCSL]SERNUM(IND) = [F:STO]SERNUM
    [M:SCSL]SERNUMF(IND)= [F:STO]SERNUM
    If [F:ITM]ITMREF<>[F:STO]ITMREF
      Read [ITM]ITM0=[F:STO]ITMREF
      If fstat : Raz [F:ITM] : Endif
    Endif
    If [F:ITM]SERMGTCOD=4
      Filter [STS] Where ITMREF=[F:STO]ITMREF & STOCOU=[F:STO]STOCOU
      Read [STS]STS3 First
      [M:SCSL]SERNUM(IND) = [F:STS]SERNUM
      Read [STS]STS3 Last
      [M:SCSL]SERNUMF(IND)= [F:STS]SERNUM
      Raz WRET
      Call PLUS_NB([M:SCSL]SERNUM(IND),[F:STO]QTYPCU,WSERFIN,WRET) From STKLIB
      If WSERFIN<>[M:SCSL]SERNUMF(IND)
        [M:SCSL]SERNUM(IND) = "$"
        [M:SCSL]SERNUMF(IND)= "$"
      Endif
      Filter [STS]
    Endif
  Endif
  IND+=1
Next
Filter [STO]

Chgtbk [M:SCSL]25 With mess(543,184,1)-[M:SCSL]LPNNUM(NOL)

[M:SCSL]NBSTO=IND
Affzo [M:SCSL]25

Return

######################################################################

