#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
# Etape 6 de la définition d'une campagne d'appels                  Module CRM           2 janvier 2001  #
# Etape 3 de la définition d'une campagne d'appels                  Module CRM          juin 2006  #
##########################################################################################################
# Saisie d'un script d'appel
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer GISCPDEF
Global Integer GICANDEFI

  If clalev ([F:SCP])<=0 Local File SCRIPT [SCP] : Endif
  If clalev ([F:SCQ])<=0 Local File SCPQST [SCQ] : Endif
  If clalev ([F:SQC])<=0 Local File SCPQSTCND [SQC] : Endif
  GISCPDEF = 0
  GICANDEFI = 0
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  #Bouton Confirmer
  If GISCPDEF Then
    If [M:PHO6]SCPNUM = "" Then
      ETABOU(GSPE4) = 0
    Else
      ETABOU(GSPE4) = 1
    Endif
  Else
    ETABOU(GSPE4) = 0
  Endif
  #Bouton Définir
  If GICANDEFI Then
    ETABOU(GSPE2) = 1
  Else
    ETABOU(GSPE2) = 0
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  Read [OMP]OMP0=GSZOPGNUM
  If !fstat Then
    [M:PHO6]SCPNUM = [F:OMP]SCPNUM
    Read [SCP]SCP0=[M:PHO6]SCPNUM
    If !fstat Then
      [M:PHO6]SCPNAM = [F:SCP]SCPNAM
      [M:PHO6]SALFCY = [F:SCP]SALFCY  # FGR 03/09/2008 : X3SUIVI43507
    Endif
  Endif
  Affzo [M:PHO6]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  Raz [M:PHO6]
  Kill GISCPDEF
  Kill GICANDEFI
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$AVANT_BOUTON
  Case BOUT
    When "C"
      Gosub ONNOTHING
    When "D"
      Gosub ONCONFIRM
    When Default
  Endcase
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return


##########################################################################################################
$ONNOTHING
  GISTECPL(GICSTEP - 1) = 1
  FIN = 1
Return

##########################################################################################################
$ONCONFIRM
  If GISCPDEF Then
    Call DEBTRANS From GLOCK
    Trbegin [OMP]
    Readlock [OMP]OMP0=GSZOPGNUM
    If !fstat Then
      [F:OMP]SCPNUM = [M:PHO6]SCPNUM
      Rewrite [OMP]
      If fstat Then
        GMESSAGE = mess(101,141,1)
        GERR = 1
        Unlock [OMP]
        Rollback 
        Return
      Else
        Commit
      Endif
    Endif
    GISTECPL(GICSTEP-1) = 1
    FIN = 1
  Endif
Return

##########################################################################################################
$CANCELSTEP
  If GSZSCRNUM = "" Then
    Return
  Endif
  #
  If !clalev([F:SCP]) : Local File SCRIPT [SCP] : Endif
  If !clalev([F:SCQ]) : Local File SCPQST [SCQ] : Endif
  If !clalev([F:SQC]) : Local File SCPQSTCND [SQC] : Endif
  If !clalev([F:SCA]) : Local File SCPASW [SCA] : Endif
  #
  Call DEBTRANS From GLOCK
  Trbegin [SCP], [SCQ], [SQC], [SCA]
  Delete [SCP] Where [F:SCP]SCPNUM = GSZSCRNUM
  If fstat Then
    Rollback
    Return
  Endif
  #
  Delete [SCQ] Where [F:SCQ]SCPNUM = GSZSCRNUM
  If fstat Then
    Rollback
    Return
  Endif
  #
  Delete [SQC] Where [F:SQC]SCPNUM = GSZSCRNUM
  If fstat Then
    Rollback
    Return
  Endif
  #
  Delete [SCA] Where [F:SCA]SCP = GSZSCRNUM
  If fstat Then
    Rollback
    Return
  Endif
  Commit
Return
