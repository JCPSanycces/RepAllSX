#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion du fichier VALFDR
Local Char PARAM(10)(1..2) , VALEUR(10)
GACTION = "SAIVALPAY"
GFONC1 = "GESVFD"
Call TRAITE_CHAR(VALEUR,PARAM,"","SAIVALPAY","SAIVALPAY",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "AVANT_OUVRE" : Gosub AVANT_OUVRE
 When "OUVRE"       : Gosub OUVRE
 When "RAZCRE"      : Gosub RAZCRE
 When "LIENS"       : Gosub LIENS
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "TITRE"       : Gosub TIT
 When "SETBOUT"     : Gosub SETBOUT
 When "ANNULE"      : Gosub ANNULE
 When "FILTRE"      : Gosub FILTRE
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "FERME"       : Gosub FERME
 When Default
Endcase
Return

########################################
$AVANT_OUVRE
Gosub SAV_GLOB
# Window and screens, can be differents by legislation
# Then their generation needs to be execute everytime when the folder manage several legislation
# Not depending on general parameter like in V6
#Local Integer FLWIN
#Call LECTURE(FLWIN,10334) From SUBVFD
#If FLWIN
#MIPEA - 2018-06-07-  X3-94500- START
Call GENDOSS(nomap) From GENSAI
#If GNBLEG>1
# Call GENDOSS(nomap) From GENSAI
#Endif
#MIPEA - 2018-06-07-  X3-94500- END
# Call RAZFLAG(10334) From SUBVFD
#Endif
Return

$SAV_GLOB
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
If dim(GLEGFIL)>0 : Local Char SAV_GLEGFIL(GLONADI) : SAV_GLEGFIL = GLEGFIL   : Endif
GCURLEG=GDIV : GLEGFIL=GDIV
Return

########################################
$FERME
Gosub GIV_GLOB
Return

########################################
$GIV_GLOB
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
If dim(SAV_GLEGFIL)>0 : GLEGFIL = SAV_GLEGFIL : Endif
Return

