$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"A8") From GOBJET
Endif
Call VIREBOUT(CHAINE,"H") From GOBJET
Return

$OUVRE

If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
If clalev([F:VFD2])=0: Local File VALFDR  [VFD2] : Endif
Gosub CHARGE_TABLE
Local Char    TITFOLD(40)(1..12)
Return

$RAZCRE

If dim ([M:VFD0]LEG)>0 : [M:VFD0]LEG=GCURLEG : Affzo [M:VFD0]LEG : Endif
Gosub CHARGE_TABLE
Return

$FILTRE
FILTSUP = "[F:VFD]LEG='"+GCURLEG+"'"
Return

$FILGAUCHE
FILGAUSUP ="[F:VFD]LEG='"+GCURLEG+"'"
Return


$TIT
For I=1 To NBECRAN
 TITFOLD(I) = [M:VFD0]TABSHO(I-1)
Next I
Return

$CHARGE_TABLE
Local Integer NBECRAN
NBECRAN = 0
For [ADI]CODE Where NUMTAB=10334 & LEG=GCURLEG     #table diverse "DOSSIER"
 NBECRAN += 1
 [M:VFD0]TABCOD(NBECRAN-1) = [F:ADI]CODE
 Call LECTEXTRA([M:VFD0]TABLIB(NBECRAN-1),"ATABDIV","LNGDES","10334",[F:ADI]CODE) From ATEXTRA
 Call LECTEXTRA([M:VFD0]TABSHO(NBECRAN-1),"ATABDIV","SHODES","10334",[F:ADI]CODE) From ATEXTRA
Next

#Initialisation des zones "CODPAG" des différents écrans
For I=1 To NBECRAN
 Gosub SETMASK
 [M]CODPAG = [M:VFD0]TABCOD(I-1)
 [M]LIBPAG = [M:VFD0]TABLIB(I-1)   #Initialisation du libellé de l'onglet
 Affzo CODPAG,LIBPAG
Next I
Return

$SETMASK
Case I
 When 1 : Default Mask [VFD1]
 When 2 : Default Mask [VFD2]
 When 3 : Default Mask [VFD3]
 When 4 : Default Mask [VFD4]
 When 5 : Default Mask [VFD5]
 When 6 : Default Mask [VFD6]
 When 7 : Default Mask [VFD7]
 When 8 : Default Mask [VFD8]
 When 9 : Default Mask [VFD9]
 When 10 : Default Mask [VFDA]
 When 11 : Default Mask [VFDB]
 When 12 : Default Mask [VFDC]
Endcase
Return

$LIENS

Gosub CHARGE_TABLE
For I=1 To NBECRAN
 Gosub SETMASK
 Raz [M]TBL
Next I
For [VLA]VLA0 Where TYP=1 and DAT=[F:VFD]DAT and LEG=GCURLEG
 Read [F:VRA]VRA0=GCURLEG;[F:VLA]VARCOD
 If !fstat
  I = find([F:VRA]PAGFDR,[M:VFD0]TABCOD(0..NBECRAN-1))
  Gosub SETMASK
 Endif
 If I
  nolign = [M]TBL+1
  [M] = [F:VLA]
  [M]VARCOD(nolign-1) = [F:VLA]VARCOD
  [M]VALEUR(nolign-1) = [F:VLA]VARVAL
  [M]RANG(nolign-1)   = [F:VRA]ROWFDR
  [M]TBL += 1
 Endif
Next
For I=1 To NBECRAN
 Gosub SETMASK
 Sorta [M]TBL [M]TBL Order By [M]RANG(indice)
Next I
Return


$CREATION
For I=1 To NBECRAN
 Gosub SETMASK
 For indice=0 To [M]TBL-1
  Raz [F:VLA]
  nolign = indice+1
  [F:VLA] = [M]
  [F:VLA]VARCOD = [M]VARCOD(indice)
  [F:VLA]VARVAL = [M]VALEUR(indice)
  [F:VLA]DAT = [M:VFD0]DAT
  [F:VLA]TYP = 1 : # legislation
  [F:VLA]LEG = GCURLEG
  Write [VLA]
  If fstat : GOK=0 : Call FSTA("VLA") From GLOCK : Break : Endif
 Next indice
 If GOK<1 : Return : Endif
Next I
Return

#############################
$MODIF
Delete [VLA] Where TYP=1 and DAT=[F:VFD]DAT and LEG=GCURLEG
Goto CREATION
Return

########################################
$ANNULE
If clalev([F:VLA])=0 : Local File VALEUR [VLA] : Endif
Delete [VLA] Where TYP=1 & DAT=[F:VFD]DAT & LEG=GCURLEG
If fstat
 GOK = -1 : GLOCK = "$VALEUR" : Return
Endif
Return

########################################
Subprog AS_VARCOD(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Gosub SETNOL
 Gosub VERF_ACCES
Endif
End

Subprog C_VARCOD(VALEUR)
Variable Char    VALEUR()
Local Integer IND
Call LECTURE("VRA",VALEUR,GCURLEG) From CONTOBJ
If [F:VRA]FLGFDR<>2
 #FRLAA - 2016-04-13 - REQUIREMENT 114309 US 111 - START
 Call ERREUR(mess(226,10702,1)) From GESECRAN :  # variable not entered at legislation level
 #Call ERREUR(mess(225,10702,1)) From GESECRAN :  # variable not entered at legislation level
 #FRLAA - 2016-04-13 - REQUIREMENT 114309 US 111 - END
 mkstat = 2 : End
Else
 IND = find([VRA]PAGFDR,[M:VFD0]TABCOD(0..7))
 If IND
  If [M]CODPAG<>[M:VFD0]TABCOD(IND-1)
   Call ERREUR (mess(30,10702,1)-num$([M:VFD0]TABSHO(IND-1))) From GESECRAN
# Variable à saisir dans l'onglet
   mkstat = 2 : End
  Endif
 Endif
Endif
# contrôle d'unicité sur la colonne
Call UNICITE(VALEUR,[M]VARCOD) From OBJDIV
# contrôle code d'accès
If VALEUR<>[M]VARCOD(nolign-1) & [F:VRA]CODACC<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;ACCES
 If fstat or [F:ACC]EXEC<>2
  GMESSAGE = mess(41,10703,1)-[M]VARCOD(nolign-1) : # Accès interdit à cette variable
  mkstat = 2 : End
 Endif
Endif
If [F:VRA]CODACT<>""
 Read [ACV]CODACT = [F:VRA]CODACT
 If fstat or [F:ACV]FLACT<>2
  GMESSAGE = mess(42,10703,1) : # Variable inactive
  mkstat = 2 : End
 Endif
Endif
End

Subprog AS_VALEUR(VALEUR)
Variable Decimal VALEUR()
Gosub SETNOL
Gosub VERF_ACCES
End

Subprog C_DAT(VALEUR)
Variable Date    VALEUR
End

Subprog D_DATF(VALEUR)
Variable Date    VALEUR
Filter [F:VFD] Where [F:VFD]DAT>[M:VFD0]DAT & LEG=GCURLEG
Read [F:VFD]VFD0 First
If fstat<=2 : VALEUR = [F:VFD]DAT-1 : Else : VALEUR = [0/0/0] : Endif
Filter [VFD]
End

Subprog C_TBL
Gosub SETNOL
If status=65
 Gosub VERF_ACCES
Elsif status=68 or status=83
 For NOL=nolign-1 To nolign1-1
  Gosub VERF_ACCES
  If mkstat : Break : Endif
 Next
Endif
If mkstat
 GMESSAGE = mess(41,10703,1)-[M]VARCOD(NOL)
Endif
End

$SETNOL
Local Integer NOL
NOL = nolign-1
Return

$VERF_ACCES
If GUSRACS<>2
 Call LECTURE("VRA",[M]VARCOD(NOL),GCURLEG) From CONTOBJ
 If [F:VRA]CODACC<>""
  Read [ACC]CODACC = GUSER;[F:VRA]CODACC
  If fstat or [F:ACC]EXEC<>2 : mkstat = 2 : Endif
 Endif
Endif
Return

Subprog B1_TBL
Local Integer NBVAR
NBVAR=0
For [VRA]VRA0 Where FLGFDR=2 & PAGFDR=[M]CODPAG & LEG=GCURLEG
 #60421
 OK=1
 If [F:VRA]CODACT<>""
  Read [ACV]CODACT = [F:VRA]CODACT
  If fstat | [F:ACV]FLACT<>2 : OK=0 :   Endif
 Endif
 #
 If OK & !find([F:VRA]COD,[M]VARCOD(0..[M]TBL-1))
  [M]VARCOD([M]TBL) = [F:VRA]COD
  [M]TBL += 1
  NBVAR += 1
 Endif
Next
If NBVAR=0
 # Aucune variable a précharger
 Call MESSAGE(mess(90,10702,1)) From GESECRAN
Else
 Affzo 10
 mkstat = 4
Endif
End

