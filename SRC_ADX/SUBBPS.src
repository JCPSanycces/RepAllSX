Funprog GET_FCY()

Local Char SFCY(GLONFCY)

  # FGR 19/02/2015 : X3SUIVI106383
  If dim([M:BPRS]FCY) >= 0 Then
    SFCY = [M:BPRS]FCY
  Else
    Raz SFCY
  Endif
End SFCY

##############################################################################
Subprog CALCUL(WNOTE)
Variable Decimal WNOTE
#-----------------------------#
# calcul de la note générale  #
#-----------------------------#
  # FGR 20/08/2010 : X3SUIVI66674
  [M:BPS3]CUMCOE = [M:BPS3]LTIMRKCOE + [M:BPS3]PRIMRKCOE + [M:BPS3]QLYMRKCOE + [M:BPS3]QTYMRKCOE + [M:BPS3]RSKMRKCOE
  If [M:BPS3]CUMCOE <> 0 Then
    WNOTE = ([M:BPS3]LTIMRK*[M:BPS3]LTIMRKCOE + [M:BPS3]PRIMRK*[M:BPS3]PRIMRKCOE +
&           [M:BPS3]QLYMRK*[M:BPS3]QLYMRKCOE + [M:BPS3]QTYMRK*[M:BPS3]QTYMRKCOE +
&           [M:BPS3]RSKMRK*[M:BPS3]RSKMRKCOE) / ([M:BPS3]CUMCOE)
  Else
    WNOTE = 0
  Endif
End

##############################################################################
Funprog CALCUL1NOTE(DNOTE, DCOEF)
Value Decimal DNOTE
Value Decimal DCOEF

Local Decimal WNOTE

  # FGR 26/10/2010 : X3SUIVI68595 : Faire une fonction le coef peut valoir 0
  WNOTE = 0
  If DCOEF <> 0 Then
    WNOTE = arr(DNOTE / DCOEF, 10^-6)
  Endif
End WNOTE

########################################
Subprog INI_BSGCATEG(COD)
Variable Char    COD
Local    Integer I,J,SPSTAT

If COD="" End Endif
Read [BSG]BSG0=COD
If fstat  End Endif
#MAE, bg 76255
#si on vient du tiers, on écrase pas les infos
If find(GNAVIG(max(GPILNAV-1,1)),"GESBPR")=0
    [M:BPRS]=[F:BSG]
Endif
[M:BPS0]=[F:BSG]
#[M:BPRS]=[F:BSG]
If GACTFTC=2 [M:BPS1]=[F:BSG] Endif #MAE, bg85873
[M:BPS2]=[F:BSG]
If GACTFTC=2 [M:BPS3]=[F:BSG] Endif #MAE, bg85873
[M:BPS4]=[F:BSG]

#si les axes sont vides après le transclasse depuis la catégorie, on recharge les axes par défaut sur le client
#----- Initialisation tableau des axes -----#
If dim([M:BPS2]NBAXE)>0
  #si le premier axe est vide => la catégorie n'a pas d'axe de renseigné
  If [M:BPS2]DIE(0) = ""
#    If dim([M:BPS0]SOC)>0 & [M:BPS0]SOC<>""
#      Call CHARG_DIE(3,[M:BPS0]SOC,"BPS2","NBAXE") From TRTX3CPT
#    Else
#      Call CHARG_DIE(3,"","BPS2","NBAXE") From TRTX3CPT
#    Endif
     Call CHARG_DIE(3,GSOCIETE,"BPS2","NBAXE") From TRTX3CPT
  Endif
Endif


If [F:BSG]CREMOD=2
   [M:BPS0]ENAFLG=1
Else
   [M:BPS0]ENAFLG=2
Endif

# Conversion montants devise dossier en devise société
Local Decimal WMONTORG (0..2)  # 106430.c - was 0..1
Local Decimal WMONTDES (0..2)
Local Decimal WDECIMAL
Read [TCU]TCU0=GCUR
If !fstat WDECIMAL = [F:TCU]CURRND Endif
WMONTORG(0) = [F:BSG]ORDMINAMT
WMONTORG(1) = [F:BSG]OSTAUZAMT
WMONTORG(2) = [F:BSG]ORDFREFRT  # 106430.n
Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMONTORG(0),WMONTDES(0),SPSTAT) From TRTDEV
Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMONTORG(1),WMONTDES(1),SPSTAT) From TRTDEV
Call CONVERT2(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,WMONTORG(2),WMONTDES(2),SPSTAT) From TRTDEV
If SPSTAT = 0
     #-- on avait un problème suite à la double conversion
     #-- exemple si on saisit un montant de 50 FRF --> conversion EUR
     #-- ensuite reconversion en FRF dans liens pour reaffichage --> 50.03 FRF
     #-- solution aucun arrondi mais uniquement à la fin arrondi
     #-- arrondi de la devise affichage - le stockage est fait avec toute la précision
     If GACTFTC=2
       [M:BPS1]WORDMINAMT = arr(WMONTDES(0),WDECIMAL)
       [M:BPS1]WORDFREFRT = arr(WMONTDES(2),WDECIMAL)  # 106430.n
     Endif
     [M:BPS4]WOSTAUZAMT = arr(WMONTDES(1),WDECIMAL)
Else
     If GACTFTC=2
       [M:BPS1]WORDMINAMT = [F:BSG]ORDMINAMT
       [M:BPS1]WORDFREFRT = [F:BSG]ORDFREFRT  # 106430.n
     Endif
     [M:BPS4]WOSTAUZAMT = [F:BSG]OSTAUZAMT
Endif

If GACTFTC=2
  [M:BPS1]CURWORDMIN = GCUR
  [M:BPS1]CURFREFRT  = GCUR    # 106430.n
Endif
[M:BPS4]ACCCUR = GCUR

# Lecture devise du fournisseur
Read [TCU]TCU0 = [M:BPRS]CUR
If fstat : Raz [F:TCU] : Endif
If GACTFTC=2
   For J=0 To dim([M:BPS1]INVDTA)-1
      If [F:BSG]INVDTA(J) <> 0
         [M:BPS1]INVDTAAMT(I) = [F:BSG]INVDTAAMT(J)
         [M:BPS1]INVDTA   (I) = [F:BSG]INVDTA(J)
         [M:BPS1]AMTCOD   (I) = [F:BSG]AMTCOD(J)
         Read [PFI]PFI0=[F:BSG]INVDTA(J)
         If !fstat
            Call LECTEXTRA([M:BPS1]SHO(I),"PFOOTINV","SHOAXX",num$([F:PFI]PFINUM),"") From ATEXTRA
         Endif
         If [M:BPS1]AMTCOD(I)=2
            [M:BPS1]WWCUR(I) = [M:BPRS]CUR
            [M:BPS1]FORMAT(I)= "NZ:"+[F:TCU]CURFMT1
         Else
            [M:BPS1]FORMAT(I)= "NZ:3.2#[      ]"
         Endif
         I+=1
      Endif
   Next J
   NBPOSTE = I
   [M:BPS1]NBELEMENT = NBPOSTE
Endif

#----------------------------------------------------------------------------
#IRMUE 14.06.12 81574:AP/AR management: initializing of amount type PURPRITYP
#The amount type PURPRITYP is initialized with supplier category. If it’s not defined,
#the value defined on the Parameter PURPRITYP/GPURPRITYP. If Parameter PURPRITYP is not defined,
#the amount type is initialized with Ex tax.The X3 user can change the amount type always.
#-------------------------------------------------------------------------------------
If [M:BPS2]PURPRITYP = 0
 If dim(GPURPRITYP)>0 : [M:BPS2]PURPRITYP = GPURPRITYP : Endif
Endif
If [M:BPS2]PURPRITYP = 0  : [M:BPS2]PURPRITYP = 1 : Endif
#IRMUE 14.06.12 81574:AP/AR management <End>
End

