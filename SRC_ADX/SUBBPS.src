If clalev([F:ADI]) <> 0
    If [F:ADI]N1 = 4 & dim([M:BPRS]EECNUM)>0 & [M:BPRS]EECNUM = ""
        GERR=2:GMESSAGE=mess(157,196,1)
    Endif
Endif
