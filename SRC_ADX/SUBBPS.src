###################################################################
$ABANDON
#-------------------------------------------------#
# il faut deverrouiller BPARTNER                  #
#-------------------------------------------------#
# FGR 15/10/2009 : X3SUIVI58119 : on délocke dans DEVERROU, c'est tout
#SYMBOLE2 = "BPR"+num$([M:BPS0]BPSNUM)
#Unlock = SYMBOLE2
Gosub FIN_GILOCKBPR  # FGR 16/04/2012 : X3SUIVI81335

If GACTFTC=2
   If GREP = "D"
      # Suppression des textes commande et retour
      If [M:BPS1]ORDTEX<>""
         Call SUP_CLOB([M:BPS1]ORDTEX,WRET) From TRTX3TEX
      Endif
      If [M:BPS1]RTNTEX<>""
         Call SUP_CLOB([M:BPS1]RTNTEX,WRET) From TRTX3TEX
      Endif
   Endif
   # Raz des zones mémoire de stockage des textes
   Call RAZ_CLOB From ACLOB
Endif

Return

###################################################################
$VERROU
If [M:BPS0]BPSNUM <> ""
        Read [BPR]BPR0 = [M:BPS0]BPSNUM
        If fstat = 0
            #------------------------------------#
            # il faut verrouiller symbole BPR    #
            #------------------------------------#
            SYMBOLE2 = "BPR"+num$([M:BPS0]BPSNUM)
            Lock = SYMBOLE2 With lockwait = 0
            If fstat
#              Call ERREUR(mess(10,100,1)) From GESECRAN
               #-- on debloque le BPS - modif non autorisée
               #-- sinon on a probleme sur lock reste dans le fichier
               Unlock = SYMBOLE
               OK = 0
            Endif
         Endif
Endif
Return

###################################################################
$INIMOD
#------------------------------------#
# etiquette appellee avant le rewrite#
# dans la transaction de modification#
#------------------------------------#
Gosub CREBPS
If GOK<1 Return Endif

# Création ou mise à jour des textes commande et facture
If GACTFTC=2
  If [M:BPS1]ORDTEX<>""
    Call CRE_CLOB([M:BPS1]ORDTEX,GOK) From TRTX3TEX
    If GOK<1 Return Endif
    [F:BPS]ORDTEX = [M:BPS1]ORDTEX
  Endif
  If [M:BPS1]RTNTEX<>""
    Call CRE_CLOB([M:BPS1]RTNTEX,GOK) From TRTX3TEX
    If GOK<1 Return Endif
    [F:BPS]RTNTEX = [M:BPS1]RTNTEX
  Endif
Endif
#----- Mise à jour adresse par défaut du fournisseur -----#
[F:BPS]BPAADD=[M:BPAS]CODADR(max(find(2,[M:BPAS]BPAADDFLG(0..[M:BPAS]NBADR-1))-1,0))

If func AFNC.ACTIV("SDD") : Call DELBID([M]BPSNUM) From SUBMDT : Endif
Return

######################################################################
$AVANT_MODFIC
Local Integer WMAJNAM : Raz WMAJNAM
If [M:BPRS]BPRNAM <> [F:BPS]BPSNAM | [M:BPRS]BPRSHO <> [F:BPS]BPSSHO WMAJNAM=1 Endif
#----- Ancien tiers risque et indicateur de modif si tiers risque modifié ! -----#
WBPSRSK_OLD=[F:BPS]BPSRSK
WBPSRSK_FLG=0
If [M:BPS2]BPSRSK<>[F:BPS]BPSRSK
  WBPSRSK_FLG=1
Endif
#MAE bg62889
Local Integer WMAJRISK : Raz WMAJRISK
If [M:BPS4]OSTCTL <>[F:BPS]OSTCTL |[M:BPS4]WOSTAUZAMT <>[F:BPS]OSTAUZAMT
WMAJRISK = 1
Endif
#-----
Return

######################################################################
$MODIF
#MAE, bug 101075, modif de l'ordre de création
#Gosub CREBPR : If GOK<1  Return : Endif : # Création/Modification du BPR
#Gosub CREBPA : If GOK<1  Return : Endif : # Création/Modification des adresses
#Gosub CRERIB : If GOK<1  Return : Endif : # Création/Modification des RIB
#Gosub CRECNT : If GOK<1  Return : Endif : # Création/Modification des contacts

Gosub CREBPA : If GOK<1  Return : Endif : # Création/Modification des adresses
Gosub CRERIB : If GOK<1  Return : Endif : # Création/Modification des RIB
Gosub CREBPR : If GOK<1  Return : Endif : # Création/Modification du BPR
Gosub CRECNT : If GOK<1  Return : Endif : # Création/Modification des contacts

#Gosub UPDBPRHCODE From SUBAINCRM
#If GOK < 1 : Return : Endif

#    Si le tiers est un site
#    --> il faut réécrire les adresses les RIB et les contacts du site
If GACTFTC=2 & [M:BPRS]FCY<>""
    Gosub MAJFCY From SUBBPR : If GOK < 1 : Return : Endif
Endif

# MHB 23/10/08
# Mise à jour table ITMBPS
If dim([M:BPS6]NBITP) > 0
  Local Integer WRET
  For [ITP]ITP0 Where BPSNUM = [M:BPS0]BPSNUM
    # Suppression des articles fournisseur supprimés
    If !find([F:ITP]ITMREF,[M:BPS6]ITMREF(0..[M:BPS6]NBITP-1))
      If [F:ITP]TEX <> ""
        Call SUP_CLOB([F:ITP]TEX,WRET) From TRTX3TEX
      Endif
      Delete [ITP]
      #  Vérifier si un enregistrement est locké : si oui : Fin
      If fstat = 1
        GOK = -1
        Call RSTA("ITP",CLE_TO_DEL) From GLOCK : Break
      Endif
    Endif
  Next
  Gosub CREMOD_ITP
Endif

#----- Mise à jour de la raison sociale -----#
If WMAJNAM
  If [M:BPRS]BPCFLG = 2
    Update [BPC] Where [F:BPC]BPCNUM = [M:BPS0]BPSNUM With BPCNAM=[M:BPRS]BPRNAM, BPCSHO=[M:BPRS]BPRSHO
    If fstat GOK=0 : Call FSTA("BPC") From GLOCK : Endif
  Endif
  If dim([M:BPRS]REPFLG)>0 & [M:BPRS]REPFLG=2
    If clalev([F:REP])=0 : Local File SALESREP [REP] : Endif
    Update [REP] Where [F:REP]REPNUM = [M:BPS0]BPSNUM With REPNAM=[M:BPRS]BPRNAM
    If fstat GOK=0 : Call FSTA("REP") From GLOCK : Endif
  Endif
  If dim([M:BPRS]BPTFLG)>0 & [M:BPRS]BPTFLG=2
    If clalev([F:BPT])=0 : Local File BPCARRIER [BPT] : Endif
    Update [BPT] Where [F:BPT]BPTNUM = [M:BPS0]BPSNUM With BPTNAM=[M:BPRS]BPRNAM, BPTSHO=[M:BPRS]BPRSHO
    If fstat GOK=0 : Call FSTA("BPT") From GLOCK : Endif
  Endif
Endif
#----- Modification du tiers risque --> Màj des mouvements fournisseurs -----#
If WBPSRSK_FLG
  If !clalev([F:MVS])  Local File BPSUPPMVT [MVS] : Endif
#  If dim([M:BPS0]SOC)>0 & [M:BPS0]SOC<>""
#    Update [MVS] Where BPSNUM=[M:BPS0]BPSNUM
#&                    & BPSRSK=WBPSRSK_OLD
#&                    & CPY   =[M:BPS0]SOC
#&                 With BPSRSK=[M:BPS2]BPSRSK
  If GSOCIETE<>""
    Update [MVS] Where BPSNUM=[M:BPS0]BPSNUM
&                    & BPSRSK=WBPSRSK_OLD
&                    & CPY   =GSOCIETE
&                 With BPSRSK=[M:BPS2]BPSRSK
  Else
    Update [MVS] Where BPSNUM=[M:BPS0]BPSNUM
&                    & BPSRSK=WBPSRSK_OLD
&                 With BPSRSK=[M:BPS2]BPSRSK
  Endif
  If fstat  GOK=0 : Call FSTA("MVS") From GLOCK : Endif
Endif
#----- CRM -----#
Gosub MODIF_CRM From TRTBPCRM : If GOK<1  Return : Endif
#-----
Return

#######################################################################
$ANNULE
#------------------------------------#
# supression des textes associées    #
#------------------------------------#
Local Integer WRET

# Suppression des textes commande et facture
If GACTFTC=2
   If [M:BPS1]ORDTEX<>""
      Call SUP_CLOB([M:BPS1]ORDTEX,WRET) From TRTX3TEX
   Endif
   If [M:BPS1]RTNTEX<>""
      Call SUP_CLOB([M:BPS1]RTNTEX,WRET) From TRTX3TEX
   Endif
Endif

#------------------------------------------------------#
# lecture bpartner pour depositionner le flag BPSFLG   #
#------------------------------------------------------#
Update [BPR] Where [F:BPR]BPRNUM = [M:BPS0]BPSNUM With BPSFLG = 1
If fstat <> 0
       GOK = 0
Endif
Return

##########################################################################
$AP_ANNULE

