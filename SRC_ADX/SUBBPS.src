Subprog AS_BPAINV(VALEUR)
Variable Char    VALEUR()
# --- En import : les adresses sont chargees après le fournisseur --> controle impossible
#If GIMPORT
#   If [M:BPS2]BPSINV=[M:BPS0]BPSNUM & [M:BPAS]CODADR(0)=""  : # si meme fournisseur et pas adresses saisies
#      mkstat=2 : End                                        : # pas de chargement du code adresse
#   Endif
#Endif

If [M:BPAS]CODADR(0)=""
      mkstat=2 : End
Endif

End

#-------------------------------------------#
# Contrôle adresse du fournisseur facturant #
#-------------------------------------------#
Subprog C_BPAINV(VALEUR)
Variable Char    VALEUR()

If find(GREP,"C","D") & [M:BPS0]REFCOU<>"" & [M:BPS2]BPSINV=""
   End
Endif

If [M:BPS2]BPSINV=[M:BPS0]BPSNUM
  #----- Fournisseur facturant = fournisseur commande -----#
  If !find(VALEUR,[M:BPAS]CODADR(0..[M:BPAS]NBADR-1))
    GMESSAGE=mess(16,199,1) : mkstat=1
  Endif
Else
  #----- Fournisseur facturant <> fournisseur commande -----#
  Look [BPA] BPA0=1;[M:BPS2]BPSINV;VALEUR
  If fstat  GMESSAGE=mess(16,199,1) : mkstat=1 : Endif
Endif
End

#-----------------------------#
# Contrôle fournisseur groupe #
#-----------------------------#
Subprog C_BPSGRU(VALEUR)
Variable Char    VALEUR()
If find(GREP,"C","D") & [M:BPS0]REFCOU<>"" & VALEUR=""
   End
Endif
If VALEUR<>"" & VALEUR<>[M:BPS0]BPSNUM
  Look [BPS]BPS0=VALEUR
  If fstat  GMESSAGE=mess(23,100,1) : mkstat=2 : Endif
