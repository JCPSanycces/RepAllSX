#    Endif
#Endif

Gosub GRIZE_LIENS
#---------------------------------------#
# on initialise le masque contact       #
#---------------------------------------#
# paramètre numéro entité = tiers       #
#           type entité   = 1           #
#---------------------------------------#
#Call CHARG_CNT (GABREV,[M:BPS0]BPSNUM,1,[F:BPR]CNTNAM) From TRTADR
If !GIMPORT Gosub RELIT From GOBJSUB : Endif

#MAE, bg62889 Mise à jour du fournisseur dont l'enregistrement est tiers risque
If WMAJRISK = 1
   If !clalev([F:BPS1]) : Local File BPSUPPLIER [BPS1] : Endif
   # Recherche si le fournisseur est un tiers risque
   Filter [BPS1] Where [F:BPS1]BPSRSK=[M]BPSNUM & [F:BPS1]BPSNUM<>[M]BPSNUM
   For[BPS1]
    Update [BPS] Where [F:BPS]BPSNUM = [F:BPS1]BPSNUM With OSTCTL=[M:BPS4]OSTCTL, OSTAUZAMT = [M:BPS4]WOSTAUZAMT
       If fstat
        GOK = 0 : Call FSTA("BPs") From GLOCK
       Endif
    Next
    Filter [BPS1]
Endif

Gosub FIN_GILOCKBPR  # FGR 16/04/2012 : X3SUIVI81335
Return

