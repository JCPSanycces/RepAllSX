######################################################################################
# MHB 23/10/08 : ajout Articles-fournisseurs
#
# GESTION DE L'ONGLET BPS6
######################################################################################

$CHARGE_ITP
  # Chargement des zones à saisir
  ######If [M:ITP]NBITP > 0 (oté le 22/12/99 : empechait l'effacemt lors des suppressions de lignes)
  [M:BPS6]XITMREFBPS         = [M:BPS6]ITMREFBPS(NOL)
  [M:BPS6]XITMDESBPS         = [M:BPS6]ITMDESBPS(NOL)
  [M:BPS6]XITMREF            = [M:BPS6]ITMREF(NOL)
  [M:BPS6]XDOUFLG            = [M:BPS6]DOUFLG(NOL)
  [M:BPS6]XPURMINQTY         = [M:BPS6]PURMINQTY(NOL)
  [M:BPS6]XCPRCOE            = [M:BPS6]CPRCOE(NOL)
  [M:BPS6]XQLYMRK            = [M:BPS6]QLYMRK(NOL)
  [M:BPS6]XQUAFLG            = [M:BPS6]ITPQUAFLG(NOL)
  [M:BPS6]XQLYCRD            = [M:BPS6]ITPQLYCRD(NOL)
  [M:BPS6]XQUAFRY            = [M:BPS6]ITPQUAFRY(NOL)
  [M:BPS6]XQUANUM            = [M:BPS6]ITPQUANUM(NOL)
  If dim([M:BPS6]XEECINCRAT)>0
    [M:BPS6]XEECINCRAT  = [M:BPS6]EECINCRAT(NOL)
  Endif
  If [M:BPS6]ITPPUU(NOL) = ""
    # Sert d'initialisation
    [M:BPS6]ITPPUU(NOL) = [M:BPS6]PUU(NOL)
  Endif

  [M:BPS6]XPUU               = [M:BPS6]ITPPUU(NOL)
  [M:BPS6]XPUUSTUCOE         = [M:BPS6]IPUUSTUCOE(NOL)
  [M:BPS6]XPCU               = [M:BPS6]ITPPCU(NOL)
  [M:BPS6]XPCUPUUCOE         = [M:BPS6]IPCUPUUCOE(NOL)
  [M:BPS6]XSSTT              = [M:BPS6]SSTT(NOL)
  [M:BPS6]XBOMALT            = [M:BPS6]BOMALT(NOL)
  [M:BPS6]XSCOLTI            = [M:BPS6]SCOLTI(NOL)
  If [M:BPS6]CTMBPSFLG(NOL)=0 : [M:BPS6]CTMBPSFLG(NOL)=1 : Endif
  [M:BPS6]XCTMBPSFLG         = [M:BPS6]CTMBPSFLG(NOL)
  [M:BPS6]XTEX               = [M:BPS6]TEX(NOL)
  [M:BPS6]XPIO               = [M:BPS6]PIO(NOL)
  [M:BPS6]WTEX = 2
  If [M:BPS6]XTEX = "" [M:BPS6]WTEX = 1 Endif

  If !GIMPORT
    Affzo [M:BPS6]10
  Endif
Return


Subprog AV_NBITP
Local Integer NOL

  NOL = nolign-1
  [M]XNUMLIG = nolign-1
  Gosub CHARGE_ITP

  Raz GBOUT1
  # Bouton texte
  If [M:BPS6]ITMREFBPS(NOL) <> ""
    GBOUT1 = mess(38,198,1)
  Endif
End


