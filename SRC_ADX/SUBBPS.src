$GRIZE_LIENS
If dim([M:BPRS]BETFCY)>0
   If [M:BPRS]BETFCY = 2
      Actzo [M:BPRS]FCY
      #  90370 - Cash VAT
      If func AFNC.ACTIV("KSP")
        If dim([M:BPS2]CSHDAT)>0
          Grizo [M:BPS2]CSHDAT
        Endif
        If dim([M:BPS2]CSHVAT)>0
          Grizo [M:BPS2]CSHVAT
        Endif
      Endif
      #  90370 - Cash VAT
   Else
      Grizo [M:BPRS]FCY
      #  90370 - Cash VAT
      If func AFNC.ACTIV("KSP")
        If dim([M:BPS2]CSHDAT)>0
          Actzo [M:BPS2]CSHDAT
        Endif
        If dim([M:BPS2]CSHVAT)>0
          Actzo [M:BPS2]CSHVAT
        Endif
      Endif
      #  90370 - Cash VAT
   Endif
Endif
#-----
#-----
# Exigence 82615 : Législation belge --str
#If dim([M:BPS2]DADFLG)>0
#   If [M:BPS2]DADFLG=2
#      Actzo [M:BPS2]PRVNUM
#   Else
#     Grizo [M:BPS2]PRVNUM
#   Endif
#Endif
If func AFNC.ACTIV("FEE2")
  Local Integer ACTPRVNUM
  Raz ACTPRVNUM
  If dim([M:BPS2]DADFLG)>0
    If [M:BPS2]DADFLG=2
      ACTPRVNUM +=1
    Endif
  Endif
  If dim([M:BPS2]FLG281)>0
    If [M:BPS2]FLG281=2
      ACTPRVNUM +=1
    Endif
  Endif
  If ACTPRVNUM>0
    Actzo [M:BPS2]PRVNUM
  Else
    Grizo [M:BPS2]PRVNUM
  Endif
Endif
# Exigence 82615 : Législation belge --end

Diszo [M:BPS4]TOTAMT

If GS1099 Call SUB_GRIZE_LIENS("BPS2") From TEN99LIB  : Endif #1099.n


Return

