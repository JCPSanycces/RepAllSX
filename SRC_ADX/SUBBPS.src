If dim([M:BPS4]NBTYPDOC) >= 0
 If [M:BPS4]NBTYPDOC = 0
  [M:BPS4]NBTYPDOC = len(mess(0,645,1))
 Endif
 Local Integer VU, X
 Filter [ADI] Where NUMTAB = 362
 nolign = 0
 For [ADI]CODE
  For X=1 To len(mess(0,645,1))
   VU = instr(1,[F:ADI]A1,num$(X))
   If VU
    nolign += 1
    [M:BPS4]TYPDOC(nolign-1) = [F:ADI]CODE
    Break
   Endif
  Next
 Next
 Filter [ADI]
Endif
