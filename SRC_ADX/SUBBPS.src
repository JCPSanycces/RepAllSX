If [M:BPRS]CRY = ""
    [M:BPRS]CRY = GPAYS
    If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
    If [F:TCY]CRY <> GPAYS
        Read [TCY]TCY0 = GPAYS
        If fstat Raz [F:TCY] Endif
    Endif
    [M:BPRS]LAN = [F:TCY]LAN
    [M:BPRS]CUR = [F:TCY]CUR
Endif
##  X3-26017: Support for REX identification ("Registered Export System) for export out of EU/SAL_X3-29158 (LUCUE 04/01/17)
If dim([M:BPRS]REXNUM)
  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
  Read [TCY]TCY0 = [M:BPRS]CRY
  If fstat Raz [F:TCY] Endif
  If [F:TCY]CRY="" or ([F:TCY]EECFLG<>2 & [F:TCY]GSPFLG<>2)
   Grizo [M:BPRS]REXNUM
  Else
   Actzo [M:BPRS]REXNUM
  Endif
Endif
