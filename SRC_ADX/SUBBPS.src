#<AdxTL>@(#)12.0.0.0 $Revision$
########################################################################
#    GESTION DES FOURNISSEURS                                          #
#----------------------------------------------------------------------#
#                                                    cg septembre 1997 #
########################################################################
$ACTION
# Pour gestion multi-société
#Gosub ACTION From GSOCIETE

Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "EXEBOUT"      : Gosub EXEBOUT
 When "AVANTBOUT"    : Gosub AVANTBOUT
 When "STATUT"       : Gosub STATUT
 When "LIENS"        : Gosub LIENS
 When "RAZCRE"       : Gosub RAZCRE
 When "RAZDUP"       : Gosub RAZDUP
 When "VERIF_CRE"    : Gosub VERIFCRE_MOD
 When "INICRE"       : Gosub INICRE
 When "CREATION"     : Gosub CREATION
 When "APRES_CRE"    : Gosub FINMODIF
 When "AB_CREATION"  : Gosub FINMODIF
 When "VERIF_MOD"    : Gosub VERIFCRE_MOD
 When "INIMOD"       : Gosub INIMOD
 When "AVANT_MOD"    : Gosub AVANTMOD
 When "AVANT_MODFIC" : Gosub AVANT_MODFIC
 When "FIN_MOD"      : Gosub FINMODIF
 When "MODIF"        : Gosub MODIF
 When "ABANDON"      : Gosub ABANDON
 When "ANNULE"       : Gosub ANNULE
 When "VERROU"       : Gosub VERROU
 When "DEVERROU"     : Gosub DEVERROU
 When "APRES_MOD"    : Gosub APRES_MOD
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "AP_ANNULE"    : Gosub AP_ANNULE
 When "FERME"        : Gosub FERME
 When "AB_CREATION"  : Gosub AB_CREATION

 When "SEL_TABLE"    : Gosub SEL_TABLE

 When Default
Endcase
Return

#########################################################################
########### ACTIONS STANDARDS ###########################################
#########################################################################


#########################################################################
$OUVRE

Local Char WPARAM(10)
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#----- Chargement du GSOCIETE en fonction du site par défaut "Tronc commun" -----#
GCUR=GLOCALDEV
GFCYDEF(0)=GFCYDEF(9)
If GFONC1="GESBPS"
  If GFCYDEF(0)<>""
    Call GETDEV(GFCYDEF(0)) From DEVSUB : GCUR=GLOCALDEV
    Call PARAML(GFINRSP,"OSTSCTL",WPARAM) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
    GOSTSCTL=val(WPARAM)
  Else
    Raz GSOCIETE : GLOCALDEV=GSYSCUR : GCUR=GSYSCUR
    GOSTSCTL=1
  Endif

  # Si multi-législation, ne pas charger de société et législation par défaut
  #If GNBLEG>1     # FGR 01/09/2016 : X3SUIVI118096 A faire dans tous les cas
     Raz GSOCIETE, GCURLEG
  #Endif

Endif
#-----

If !clalev([F:CPY])   Local File COMPANY    [CPY]   : Endif
If !clalev([F:FCY])   Local File FACILITY   [FCY]   : Endif
If !clalev([F:DIE])   Local File GDIE       [DIE]   : Endif
If !clalev([F:CDI])   Local File CADIEDEF   [CDI]   : Endif
If !clalev([F:BPS2])  Local File BPSUPPLIER [BPS2]  : Endif
If !clalev([F:ADI])   Local File ATABDIV    [ADI]   : Endif
If !clalev([F:BPC])   Local File BPCUSTOMER [BPC]   : Endif
# FGR 05/02/2008 : Table utilisée et pas ouverte
If !clalev([F:REP])   Local File SALESREP   [REP]   : Endif
# MHB 23/10/08 - pour les besoins des articles fournisseurs
If !clalev([F:ITP])   Local File ITMBPS     [ITP]   : Endif
If !clalev([F:ITM])   Local File ITMMASTER  [ITM]   : Endif
If !clalev([F:ITG])   Local File ITMCATEG   [ITG]   : Endif
If !clalev([F:BPR1])  Local File BPARTNER   [BPR1]  : Endif

#-----
If GMODU(7)=2 & !clalev([F:STC])  Local File STOLOC [STC] : Endif
#-----

Global Integer GIBPSEXIST
GIBPSEXIST = 0
Local Libelle WBPSRSK_FLG
Local Char    WBPSRSK_OLD(GLONBPS)
Local Integer WBPATYP : WBPATYP = 1

If clalev([F:ACV])=0  : Local File ACTIV [ACV]  : Endif

If GMODU(2)=2  :# Compta
   Read[ACV]CODACT="FEE2"  # Exigence 82615 : Législation belge (old value : Read[ACV]CODACT="DAS")
   If !fstat & [F:ACV]FLACT=2
   If clalev ([PRV]) = 0 : Local File HONPRV [PRV] : Endif
   Endif
Endif

Local Char SYMBOLE2 (20)

Local Char WLEGCPY (GLONCPY)     : # société juridique
WLEGCPY   =GSOCIETE

#---------------------------------------------------------------#
# recherche cours entre devise dossier et devise site comptable #
#---------------------------------------------------------------#
Local Integer SPSTAT

#-- si pas de cours entre devise dossier et devise affichage
#-- la devise affichage devient la devise de reporting
#-- cg le 14 septembre 99 demande numéro ????

GBIDD1 = 0
GBIDD2 = 0

Call CONVERT(GSYSCUR,GCUR,GCUR,GCHGTYP,datesyst,GBIDD1,GBIDD2,SPSTAT) From TRTDEV
If SPSTAT <> 0
        GCUR = GSYSCUR
Endif

#-----------------------#
# decimal de la devise  #
#-----------------------#
Local Decimal WDECIMAL
WDECIMAL = 0
Read [TCU]TCU0= GCUR
If fstat = 0
    WDECIMAL = [F:TCU]CURRND
Endif

GBIDD1 = 0  : #--- cours devise dossier / devise site comptable ---#
GBIDD2 = 0  : #--- cours devise site comptable / devise dossier ---#
#--- plus besoin le 3 avril 98 double conversion suite à EURO
#Call COURDEV(GSYSCUR,GCUR,GCHGTYP,GHIDATE,GBIDD1,SPSTAT) From TRTDIV
#Call COURDEV(GCUR,GSYSCUR,GCHGTYP,GHIDATE,GBIDD2,SPSTAT) From TRTDIV
#---- Initialisation du code comptable par défaut
#MAE, le 06/01/09, SUP_GACCCOD
#Call INITACCCOD(GACCCOD,3) From TRTX3

If !clalev([F:ADI])  Local File ATABDIV [ADI] : Endif

#Initialisation CRM
Gosub OUVRE_CRM From TRTBPCRM
GSZCRMOBJET="BPS"

Gosub OUVRE From TEN99LIB    #1099.n

Local Integer VII
VII=func AFNC.ACTIV("VII")
Return

#########################################################################
$AVANTBOUT

Case BOUT
 When "2" : # Tarifs
            GBIDC2="T" : Raz GFCY : Gosub AUTORIS_OPT From CONTX3
            If !GBIDI2
               GERR=1 : GMESSAGE=mess(7,104,1) : Return
            Endif
            GFLTBPS = [M:BPS0]BPSNUM
            GVISUTAR = 3
When   "N":  #Création commande
          # Issue 79033 - 2012-01-06 by VPO : ctrl passage en création cde ou fac si fournisseur en litige
          #----- Contrôle fournisseur douteux -----#
          WVALEUR=[M:BPS0]BPSNUM
          mkstat=0
          Call AM_BPSNUM(WVALEUR) From TRTACHCTL1
          If GERR | mkstat : OK=0 : Return : Endif
          GCREFONC=1
When   "P":  #Création facture
          # Issue 79033 - 2012-01-06 by VPO : ctrl passage en création cde ou fac si fournisseur en litige
          #----- Contrôle fournisseur douteux -----#
          WVALEUR=[M:BPS0]BPSNUM
          mkstat=0
          Call AM_BPSNUM(WVALEUR) From TRTACHCTL1
          If GERR | mkstat : OK=0 : Return : Endif
          GCREFONC=1
Endcase
Return

#########################################################################
$STATUT

Case BOUT
 When "E" : If mkstat=4 & GREP=""
               #MAE, bg 50938
                #GREP="M" : REP="M"
                #Gosub SETBOUT From GOBJSUB
                Gosub ENTRE_MODIF From GOBJSUB
            Endif
            If GACTFTC=2
              If [M:BPS1]ORDTEX<>""
                [M:BPS1]WORDTEX=2
              Else
                [M:BPS1]WORDTEX=1
              Endif
            Endif
            Affzo [M:BPS4]15
 When "F" : If mkstat=4 & GREP=""
                #MAE, bg 50938
                #GREP="M" : REP="M"
                #Gosub SETBOUT From GOBJSUB
                Gosub ENTRE_MODIF From GOBJSUB
            Endif
            If GACTFTC=2      : # Issue 106137
              If [M:BPS1]RTNTEX <> ""
                [M:BPS1]WRTNTEX = 2
              Else
                [M:BPS1]WRTNTEX = 1
              Endif
            Endif             : # Issue 106137
            Affzo [M:BPS4]15
 When "H" : Call NYTBIL([M]BPSNUM,WLEGCPY,"",2,1) From TIERSZOOM : # Effet non échu1
 When "J" : Call NYTBIL([M]BPSNUM,WLEGCPY,"",2,2) From TIERSZOOM : # Effet non échu2
 When "K" : Call NYTBIL([M]BPSNUM,WLEGCPY,"",2,3) From TIERSZOOM : # Effet non échu3
 When "L" : Call PROROG([M]BPSNUM,WLEGCPY,"",2)   From TIERSZOOM : # Prorogations
Endcase

Return

#########################################################################
$SETBOUT

Call VIREBOUT (CHAINE,"AH") From GOBJET

#----- Bouton tarif si :
#      presence module achat et une cle active pas en coours de maj
If GMODU(6)<>2 | CLECUR=0 | GACTFTC<>2 | GREP<>""
    Call VIREBOUT (CHAINE,"2") From GOBJET
Endif

#----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
If CLECUR
   If GACTFTC=2 CHMEN+="EF" Endif   : # activation boutons texte
   CHMEN+="HJKL"                     : # activation boutons options
   #MAE, bg 74155, entête commande passe de M à Q
   #If GACTFTC=2 CHMEN+="MRTWX" Endif
   If GACTFTC=2 CHMEN+="QRTBX" Endif  : # activation consultations achats, "X" Demandes DemandesErgonomieX314102008 01/12/08
   CHMEN+="03456"                    : # activation consultations compta
    #MAE, ajout du menu fonction pour la création des commandes et création des factures
    #MAE, bg 76024
    # Issue 79033 - 2012-01-06 by VPO : ctrl passage en création cde ou fac
    # si module achat et PAS en modif/creation
    If GMODU(6)=2 & GREP=""
      If [M:BPS0]ENAFLG = 2
        CHMEN+="NP"
      Endif
    Endif
    #MAE, EVOL_ERGO
    #CHMEN+="ASUV" : MAE, bg 74155 A -> ~
    CHMEN+="~SUV"
     #angre
    If func AFNC.ACTIV("DATEV")
      CHMEN += "Y"
    Endif
    #angre end
Endif

# MHB 03/11/08 : on grise le bouton articles si le fournisseur n'a pas d'article.
If !clalev([F:ITPB])Then Local File ITMBPS [F:ITPB] Endif
Filter [F:ITPB] Where BPSNUM=[M:BPS0]BPSNUM
If rowcount([F:ITPB]) = 0 Then
  Call VIREBOUT(CHAINE,"7") From GOBJET
Endif
If clalev([F:ITPB]) Then Close File [F:ITPB] Endif

Gosub SET_BOUT_SPE From GSAISIE

Return

###################################################################
$EXEBOUT
Local Date WDAT
WDAT = [0/0/0]
Case REP
   When "2" : # Tarifs
              GFLTBPS = ""
              GVISUTAR = 0
Endcase
Return

###################################################################
$LIENS
If GACTFTC=2 [M:BPS1]ANCPLISTC=[M:BPS1]PLISTC Endif     :# Issue 106137
GIBPSEXIST = 0
#-----
#If dim([M:BPS0]SOC)>0 & [M:BPS0]SOC<>""
#  If [M:BPS0]SOC<>GSOCIETE
#    GSOCIETE=[M:BPS0]SOC
#    If [F:CPY]CPY<>GSOCIETE
#     Read [CPY] CPY0=GSOCIETE : If fstat  Raz [F:CPY] : [F:CPY]ACCCUR="EUR" : Endif
#    Endif
#    GLOCALDEV=[F:CPY]ACCCUR
#    GFCY     =[F:CPY]MAIFCY
#    If [F:FCY]FCY<>GFCY
#      Read [FCY] FCY0=GFCY : If fstat  Raz [F:FCY] : [F:FCY]FINRSPFCY=GFCY : Endif
#    Endif
#    GFINRSP=[F:FCY]FINRSPFCY
#    #-----
#    Call PARAM(GFINRSP,"OSTSCTL",WPARAM) From ADOVAL
#    GOSTSCTL=val(WPARAM)   : # Niveau de contrôle d'en-cours
#    #-----
#  Endif
#Else
#  If GFCY<>GFCYDEF(0)
#    GFCY=GFCYDEF(0)
#    Call GETDEV(GFCY) From DEVSUB : If GFINRSP="" GFINRSP=GFCY : Endif
#    #-----
#    Call PARAM(GFINRSP,"OSTSCTL",WPARAM) From ADOVAL
#    GOSTSCTL=val(WPARAM)   : # Niveau de contrôle d'en-cours
#    #-----
#  Endif
#  If dim([M:BPS0]SOC)>0  [M:BPS0]SOC=GSOCIETE : Endif
#Endif

#If func AFNC.ACTIV("MUL")
#  GCUR=GLOCALDEV
#Else
#  GCUR=GSYSCUR
#Endif

# Raz des zones mémoire de stockage des textes
If GFONC1="GESBPS" Call RAZ_CLOB From ACLOB Endif

If [F:BPS]BSGCOD<>""
   Read [BSG]BSG0=[F:BPS]BSGCOD
   [M:BPS0]REFCOU=[F:BSG]REFCOU
Endif

If GACTFTC=2
   If [M:BPS1]ORDTEX <> ""
        [M:BPS1]WORDTEX = 2
   Else [M:BPS1]WORDTEX = 1
   Endif
   If [M:BPS1]RTNTEX <> ""
        [M:BPS1]WRTNTEX = 2
   Else [M:BPS1]WRTNTEX = 1
   Endif
Endif

#------------------------------------------------------------#
# Lecture enregistrement tiers pour récupérer premier masque #
#------------------------------------------------------------#
Read [BPR]BPR0=[M:BPS0]BPSNUM
If !fstat
  [M:BPRS] = [F:BPR]
  [M:BPS0]BPSNAM = [F:BPR]BPRNAM
  [M:BPRS]CUR    = [F:BPS]CUR   : # Récupération devise fournisseur
Else
  Raz [F:BPR], [M:BPRS]
Endif

##  X3-26017: Support for REX identification ("Registered Export System) for export out of EU/SAL_X3-29158 (LUCUE 12/19/17)
If dim([M:BPRS]REXNUM)>0
  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
  Read [TCY]TCY0 = [M:BPRS]CRY
  If fstat Raz [F:TCY] Endif
  If [F:TCY]CRY="" or ([F:TCY]EECFLG<>2 & [F:TCY]GSPFLG<>2)
    If [M:BPRS]REXNUM<>""
      Raz [M:BPRS]REXNUM
      Affzo [M:BPRS]REXNUM
    Endif
    Grizo [M:BPRS]REXNUM
  Else
    Actzo [M:BPRS]REXNUM
  Endif
Endif
## End X3-26017: Support for REX identification ("Registered Export System) for export out of EU/SAL_X3-29158 (LUCUE 12/19/17)



If GACTFTC=2 & [M:BPRS]FCY<>""
   # Lecture du site lié au fournisseur
   If [F:FCY]FCY<>[M:BPRS]FCY
      Read [FCY]FCY0=[M:BPRS]FCY
      If fstat Raz [FCY] Endif
   Endif
   [M:BPS2]LEGCPY = [F:FCY]LEGCPY
Endif

#-----------------------------#
# Chargement tableau des axes #
#-----------------------------#
If dim([M:BPS2]NBAXE)>0
#  If dim([M:BPS0]SOC)>0 & [M:BPS0]SOC<>""
#    Call CHARG_DIE(3,[M:BPS0]SOC,"BPS2","NBAXE") From TRTX3CPT
#  Else
#    Call CHARG_DIE(3,"","BPS2","NBAXE") From TRTX3CPT
#  Endif
   Call CHARG_DIE(3,GSOCIETE,"BPS2","NBAXE") From TRTX3CPT
Endif

#--------------------------------------------------------------------#
# - Chargement du montant mini commande et encours autorisé          #
#   ces deux champs sont affichés et saisis en devise site comptable #
#   mais elles sont stockées dans BPSUPPLIER en devise dossier       #
# - Chargement total en-cours                                        #
#--------------------------------------------------------------------#
If GACTFTC=2
  Call CONVERT2(GSYSCUR,GCUR,GLOCALDEV,GCHGTYP,datesyst,[F:BPS]ORDMINAMT,[M:BPS1]WORDMINAMT,SPSTAT) From TRTDEV
  If !SPSTAT
    [M:BPS1]WORDMINAMT=arr([M:BPS1]WORDMINAMT,WDECIMAL)
  Else
    [M:BPS1]WORDMINAMT=[F:BPS]ORDMINAMT
  Endif

  # 106430.sn - Purchase Planning
  Call CONVERT2(GSYSCUR,GCUR,GLOCALDEV,GCHGTYP,datesyst,[F:BPS]ORDFREFRT,[M:BPS1]WORDFREFRT,SPSTAT) From TRTDEV
  If !SPSTAT
    [M:BPS1]WORDFREFRT=arr([M:BPS1]WORDFREFRT,WDECIMAL)
  Else
    [M:BPS1]WORDFREFRT=[F:BPS]ORDFREFRT
  Endif
  # 106430.en - Purchase Planning
Endif
#----- Chargement Mt mini commande et encours autorisé -----#
Gosub ALIM_OST
#----- Calcul de l'encours fournisseur -----#
Call CALENC_BPS([M:BPS2]BPSRSK,datesyst,[M:BPS4]TOTAMT) From TRTBPMVT

#------------------------------------------------------#
# les elements de facturations sont maintenant stockés #
# dans le fournisseur  et on peut supprimer ou inserer #
#------------------------------------------------------#
Local Integer NBPOSTE (2), I, J
I = 0
J = 0
#----- lecture devise du fournisseur #

If GACTFTC=2
  [M:BPS1]CURWORDMIN=GCUR
  [M:BPS1]CURFREFRT=GCUR    # 106430.n
Endif
[M:BPS4]ACCCUR = GCUR

Read [TCU]TCU0 = [M:BPRS]CUR
If fstat  : Raz [F:TCU] : Endif
If GACTFTC=2
   Raz [M:BPS1]INVDTAAMT
   Raz [M:BPS1]INVDTA
   Raz [M:BPS1]AMTCOD
   Raz [M:BPS1]WWCUR
   Raz [M:BPS1]FORMAT
   For  J = 0 To dim([F:BPS]INVDTA)-1
      If [F:BPS]INVDTA (J) <> 0
         [M:BPS1]INVDTAAMT (I)  = [F:BPS]INVDTAAMT (J)
         [M:BPS1]INVDTA    (I)  = [F:BPS]INVDTA (J)
         [M:BPS1]AMTCOD    (I)  = [F:BPS]AMTCOD (J)
         Read [PFI] PFI0 = [F:BPS]INVDTA (J)
         If !fstat
           Call LECTEXTRA([M:BPS1]SHO(I),"PFOOTINV","SHOAXX",
&                         num$([F:PFI]PFINUM),"") From ATEXTRA
         Endif
         #---------------------------------------#
         #on veut afficher la devise fournisseur #
         #derriere les montants                  #
         #---------------------------------------#
         If [M:BPS1]AMTCOD(I) = 2
            [M:BPS1]WWCUR(I) = [M:BPRS]CUR
            [M:BPS1]FORMAT (I) = "NZ:"+[F:TCU]CURFMT1
         Else
            [M:BPS1]FORMAT (I) = "NZ:3.2#[      ]"
         Endif
         I +=1
      Endif
   Next J
   NBPOSTE = I
   [M:BPS1]NBELEMENT = NBPOSTE
Endif
#-----
Gosub TRAIT_SATTAX : # Traitement du tableau des taxes provinciales
#---------------------------------------#
#        A SUPPRIMER                    #
#---------------------------------------#
# on initialise le masque adresse       #
#---------------------------------------#
# paramètre numéro entité = tiers       #
#           type entité   = 1           #
#---------------------------------------#
#Call CHARG_BPA (GABREV,[M:BPS0]BPSNUM,1,[F:BPR]BPAADD) From TRTADR
#---------------------------------------#
# on initialise le masque contact       #
#---------------------------------------#
# paramètre numéro entité = tiers       #
#           type entité   = 1           #
#---------------------------------------#
#Call CHARG_CNT (GABREV,[M:BPS0]BPSNUM,1,[F:BPR]CNTNAM) From TRTADR
#---------------------------------------#
# on initialise le masque RIB           #
#---------------------------------------#
# paramètre numéro entité = tiers       #
#           type entité   = 1           #
#---------------------------------------#
#Call CHARG_RIB (GABREV,[M:BPS0]BPSNUM,1,"~") From TRTADR
#---------------------------------------#
Default Mask [BPAS]
Call CHARG_BPA(WBPATYP,[M:BPS0]BPSNUM,[F:BPS]BPAADD) From TRTBPA : # Adr.fourn !
Default Mask [BIDS]
Call CHARG_RIB(WBPATYP,[M:BPS0]BPSNUM,"~") From TRTBPA
Default Mask [CNTS]
Call CHARG_CNT(WBPATYP,[M:BPS0]BPSNUM,[F:BPS]CNTNAM) From TRTBPA : # JPGA # Chargement Contact par defaut depuis BPS et pls BPR
Gosub DEFAUT

#LSE 02/03/2007
##---------------------------------------------------#
##Modif CRM 6/02/2002
#If GMODU(13) = 2
#    Call SETPREREP("BPS") From TRTMST4
#Endif
#---------------------------------------------------#

#Initialisation CRM
Gosub LIENS_CRM From TRTBPCRM

If dim([M:BPS4]NBTYPDOC) >= 0
 If [M:BPS4]NBTYPDOC = 0
  [M:BPS4]NBTYPDOC = len(mess(0,645,1))
 Endif
 Local Integer VU, X
 nolign = 0
 For [ADI]CODE Where NUMTAB = 362
  For X=1 To len(mess(0,645,1))
   VU = instr(1,[F:ADI]A1,num$(X))
   If VU
    nolign += 1
    [M:BPS4]TYPDOC(nolign-1) = [F:ADI]CODE
    [M:BPS4]CAI(nolign-1)    = [F:BPS]CAI(nolign-1)
    [M:BPS4]DATVLYCAI(nolign-1) = [F:BPS]DATVLYCAI(nolign-1)
    Break
   Endif
  Next
 Next
Endif

# MHB 23/10/08 : ajout Articles-fournisseurs
If dim([M:BPS6]NBITP) > 0
  Raz [M:BPS6]
  nolign = 0
  For [ITP]ITP0 Where BPSNUM = [M:BPS0]BPSNUM
    If nolign=dim([M:BPS6]ITMREF) Then
      Break
    Endif
    nolign += 1
    [M:BPS6] = [F:ITP]
    [M:BPS6]XQUALIB  = mess(714,197,1)
    [M:BPS6]ITPPCU(nolign-1)     = [F:ITP]PCU
    [M:BPS6]ITPPUU(nolign-1)     = [F:ITP]PUU
    [M:BPS6]ITPQUAFLG(nolign-1)  = [F:ITP]QUAFLG
    [M:BPS6]ITPQLYCRD(nolign-1)  = [F:ITP]QLYCRD
    [M:BPS6]ITPQUAFRY(nolign-1)  = [F:ITP]QUAFRY
    [M:BPS6]ITPQUANUM(nolign-1)  = [F:ITP]QUANUM

    [M:BPS6]IPCUPUUCOE(nolign-1) = [F:ITP]PCUPUUCOE
    [M:BPS6]IPUUSTUCOE(nolign-1) = [F:ITP]PUUSTUCOE

    Read [F:ITM]ITM0=[M:BPS6]ITMREF(nolign-1)
    If !fstat Then
      [M:BPS6]SSTT(nolign-1)      = [F:ITM]SCPFLG
      [M:BPS6]STU(nolign-1)       = [F:ITM]STU
      [M:BPS6]PUU(nolign-1)       = [F:ITM]PUU
      [M:BPS6]PUUSTUCOE(nolign-1) = [F:ITM]PUUSTUCOE
      [M:BPS6]TCLCOD(nolign-1)    = [F:ITM]TCLCOD
    Endif
  Next
  [M:BPS6]NBITP  = nolign
  # Chargement des zones à saisir
  If [M:BPS6]NBITP > 0
     [M:BPS6]XITMREFBPS         = [M:BPS6]ITMREFBPS(0)
     [M:BPS6]XITMDESBPS         = [M:BPS6]ITMDESBPS(0)
     [M:BPS6]XITMREF            = [M:BPS6]ITMREF(0)
     [M:BPS6]XDOUFLG            = [M:BPS6]DOUFLG(0)
     [M:BPS6]XPURMINQTY         = [M:BPS6]PURMINQTY(0)
     [M:BPS6]XCPRCOE            = [M:BPS6]CPRCOE(0)
     [M:BPS6]XQLYMRK            = [M:BPS6]QLYMRK(0)
     [M:BPS6]XQUAFLG            = [M:BPS6]ITPQUAFLG(0)
     [M:BPS6]XQLYCRD            = [M:BPS6]ITPQLYCRD(0)
     [M:BPS6]XQUAFRY            = [M:BPS6]ITPQUAFRY(0)
     [M:BPS6]XQUANUM            = [M:BPS6]ITPQUANUM(0)
     If dim([M:BPS6]XEECINCRAT)>0
       [M:BPS6]XEECINCRAT       = [M:BPS6]EECINCRAT(0)
     Endif
     [M:BPS6]XPUU               = [M:BPS6]ITPPUU(0)
     [M:BPS6]XPUUSTUCOE         = [M:BPS6]IPUUSTUCOE(0)
     [M:BPS6]XPCU               = [M:BPS6]ITPPCU(0)
     [M:BPS6]XPCUPUUCOE         = [M:BPS6]IPCUPUUCOE(0)
     [M:BPS6]XTEX               = [M:BPS6]TEX(0)
     [M:BPS6]XPIO               = [M:BPS6]PIO(0)
     [M:BPS6]XCTMBPSFLG         = [M:BPS6]CTMBPSFLG(0)
     [M:BPS6]XSSTT              = [M:BPS6]SSTT(0)
     [M:BPS6]XBOMALT            = [M:BPS6]BOMALT(0)
     [M:BPS6]XSCOLTI            = [M:BPS6]SCOLTI(0)
     [M:BPS6]WTEX = 2
     If [M:BPS6]XTEX = "" : [M:BPS6]WTEX = 1 Endif
  Endif
Endif

#MAE, lecture du tiers pour les workflows, ne pas écraser, bg 67131
If !GIMPORT
  If !clalev([F:BPRW]) : Local File BPARTNER [BPRW] : Endif
  If [M:BPS0]BPSNUM <> ""
    Read [BPRW]BPR0 = [M:BPS0]BPSNUM
    If fstat Raz [F:BPRW] Endif
  Endif
Endif

