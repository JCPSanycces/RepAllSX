Subprog AV_GENMRK(VALEUR)
Variable Decimal  VALEUR
Local Decimal WNOTE
If GACTFTC=2
   Call CALCUL(WNOTE)
   VALEUR = WNOTE
Endif
End

## <PP ARG>
Subprog AS_CAI(VALEUR)
Variable Char    VALEUR()
If [M]TYPDOC(nolign-1) = "" : mkstat = 2 : End : Endif
End

Subprog AS_DATVLYCAI(VALEUR)
Variable Date    VALEUR
If [M]TYPDOC(nolign-1) = "" : mkstat = 2 : End : Endif
