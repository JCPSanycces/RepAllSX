 [M:BIDS]OBIDBPAADD(nolign-1) = [M:BIDS]BIDBPAADD(nolign-1)
 [M:BIDS]OBIDNUM(nolign-1) = [M:BIDS]BIDNUM(nolign-1)
 If [L]VII : [M:BIDS]OBICCOD(nolign-1) = [M:BIDS]BICCOD(nolign-1) : Endif
Next
Return

