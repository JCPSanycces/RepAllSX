## <Fin PP ARG>

Subprog AM_AGTSATTAX(VALEUR)
Variable Integer VALEUR
Local Integer I
If VALEUR=1
  Grizo [BPS2]NBPRV
  For I=0 To [M:BPS2]NBPRV : [M:BPS2]FLGSATTAX(I)=1 : Next
  Affzo [BPS2]FLGSATTAX
Else
  Actzo [BPS2]NBPRV
  For I=0 To [M:BPS2]NBPRV : [M:BPS2]FLGSATTAX(I)=2 : Next
  Affzo [BPS2]FLGSATTAX
Endif
End

Subprog AS_FLGSATTAX(VALEUR)
Variable Integer VALEUR
If [M:BPS2]SATTAX(nolign-1)=""  mkstat=1 : End : Endif
End

#----------------------------------------------#
# Traitement du tableau des taxes provinciales #
#----------------------------------------------#
$TRAIT_SATTAX
If dim([M:BPS2]SATTAX)>0
  If dim(I)<1  Local Integer I : Endif
  If dim(J)<1  Local Integer J : Endif
  If [M:BPS2]NBPRV=0  [M:BPS2]NBPRV=len(mess(0,8500,1)) : Endif
  I=0
  For [ADI] CODE Where NUMTAB=364
    [M:BPS2]SATTAX(I)=[F:ADI]CODE
    Call LECTEXTRA([M:BPS2]DESSAT(I),"ATABDIV","LNGDES","364",[F:ADI]CODE) From ATEXTRA
    [M:BPS2]XTYPAPL(I)=[F:ADI]N1
    [M:BPS2]TYPAPL(I) =mess([F:ADI]N1,8500,1)
    J=find([F:ADI]CODE,[F:BPS]SATTAX(0..dim([F:BPS]SATTAX)-1))
    If J
      [M:BPS2]FLGSATTAX(I)=[F:BPS]FLGSATTAX(J-1)
    Endif
    I+=1
  Next
  If [F:BPS]AGTSATTAX<>2
    For I=0 To [M:BPS2]NBPRV : [M:BPS2]FLGSATTAX(I)=1 : Next
    Grizo [BPS2]NBPRV
  Else
    For I=0 To [M:BPS2]NBPRV
      If [M:BPS2]FLGSATTAX(I)=0  [M:BPS2]FLGSATTAX(I)=2 : Endif
    Next
    Actzo [BPS2]NBPRV
  Endif
Endif
Return


#--------------------------------------------------------#
# Alimentation et grisage des champs relatif à l'encours #
#--------------------------------------------------------#
$ALIM_OST
#----- Le tiers risque est-il le fournisseur lui-même ? -----#
If [M:BPS2]BPSRSK=[M:BPS0]BPSNUM
  If [F:BPS]BPSNUM<>[M:BPS0]BPSNUM
    Read [BPS] BPS0=[M:BPS0]BPSNUM : If fstat  Raz [F:BPS] : Endif
  Endif
  [M:BPS4]OSTCTL    =[F:BPS]OSTCTL
  Call CONVERT2(GCURSHR,GCUR,GLOCALDEV,GCHGTYP,datesyst,[F:BPS]OSTAUZAMT,[M:BPS4]WOSTAUZAMT,GBIDI2) From TRTDEV
  Call ARRDEV([M:BPS4]WOSTAUZAMT,GCUR) From TRTDIV
  Actzo [BPS4]OSTCTL, WOSTAUZAMT
#----- Le fournisseur est-il le tiers rique d'autres fournisseurs ? -----#
Else
  Filter [BPS2] Where BPSRSK=[M:BPS0]BPSNUM & BPSNUM<>[M:BPS0]BPSNUM
  Look [BPS2] BPS0 First
  Filter [BPS2]
  If fstat
    #----- Récupération des infos à partir du tiers risque ------#
    Read [BPS2] BPS0=[M:BPS2]BPSRSK : If fstat Raz [F:BPS2] : [F:BPS2]OSTCTL=1 : Endif
    [M:BPS4]OSTCTL    =[F:BPS2]OSTCTL
    Call CONVERT2(GCURSHR,GCUR,GLOCALDEV,GCHGTYP,datesyst,[F:BPS2]OSTAUZAMT,[M:BPS4]WOSTAUZAMT,GBIDI2) From TRTDEV
    Call ARRDEV([M:BPS4]WOSTAUZAMT,GCUR) From TRTDIV
    Grizo [BPS4]OSTCTL, WOSTAUZAMT
  Else
    Actzo [BPS4]OSTCTL, WOSTAUZAMT
  Endif
Endif
Return


