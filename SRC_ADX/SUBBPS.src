Subprog AM_XPUU(VALEUR)
Variable Char    VALEUR()

  Call MODUNIT(VALEUR,[M:BPS6]STU([M]XNUMLIG),[M:BPS6]XPUUSTUCOE) From SUBITM
  [M:BPS6]XPUU=VALEUR
  Affzo [M:BPS6]XPUUSTUCOE, XPUU2
  [M]IPUUSTUCOE([M]XNUMLIG)= [M:BPS6]XPUUSTUCOE

  [M]ITPPUU   ([M]XNUMLIG) = VALEUR
  [M]UPDDAT    ([M]XNUMLIG) = date$
  [M]UPDUSR    ([M]XNUMLIG) = GUSER

  GMESSAGE = mess(307,199,1) : GERR=2   # "vérifiez les coeff rattachés"
End

Subprog AS_XPUUSTUCOE(VALEUR)
Variable Decimal VALEUR

  If [M:BPS6]PUU([M]XNUMLIG) = [M]XPUU & VALEUR = 0
    VALEUR = [M:BPS6]PUUSTUCOE([M]XNUMLIG)
  Endif
  Call COEFCNV([M]XPUU,[M:BPS6]STU([M]XNUMLIG),VALEUR) From SUBITM
  If mkstat = 2 [M]IPUUSTUCOE([M]XNUMLIG) = VALEUR : Endif
End

Subprog C_XPUUSTUCOE(VALEUR)
Variable Decimal VALEUR

  If [M]XPUU <> "" & VALEUR = 0
    GMESSAGE = mess(10,123,1) : mkstat=2   # "zone obligatoire"
  Endif
End

