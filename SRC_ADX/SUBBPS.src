############################################################################
# Sous-programme de contrôle de la compatibilité de la structure tarifaire #
# ------------------------------------------------------------------------ #
# WBPSNUM1 : Fournisseur facturant                                         #
# WPLISTC1 : Structure tarifaire du fournisseur facturant                  #
# WBPSNUM2 : Fournisseur lié au facturant                                  #
# WPLISTC2 : Structure tarifaire du fournisseur lié                        #
# ------------------------------------------------------------------------ #
# GERR     : Code erreur (0=OK, 1=Structure incompatible)                  #
# GMESSAGE : Si GERR=1 contient le libellé de l'erreur                     #
############################################################################
Subprog VERIF_STRUCTURE(WBPSNUM1,WPLISTC1,WBPSNUM2,WPLISTC2)
Value Char WBPSNUM1
Value Char WPLISTC1
Value Char WBPSNUM2
Value Char WPLISTC2
##Variable Integer WERR  # FGR 24/07/2012 : N'existe pas.
#-----
Local Integer I
If !clalev([F:PRS])  Local File PRICSTRUCT [PRS]  : Endif
If !clalev([F:PRS2]) Local File PRICSTRUCT [PRS2] : Endif
#-----
Raz GERR, GMESSAGE
If [F:PRS]BPCBPS<>2 | [F:PRS]PLISTC<>WPLISTC1
  Read [PRS] PRS0=2;WPLISTC1  : If fstat  Raz [F:PRS]  : Endif
Endif
If [F:PRS2]BPCBPS<>2 | [F:PRS2]PLISTC<>WPLISTC2
  Read [PRS2] PRS0=2;WPLISTC2 : If fstat  Raz [F:PRS2] : Endif
Endif
For I=0 To 8
  If [F:PRS2]INCDCR(I)=0  Break : Endif
  If [F:PRS2]INCDCR(I)   <>[F:PRS]INCDCR(I)    |
&    [F:PRS2]VALTYP(I)   <>[F:PRS]VALTYP(I)    |
&    [F:PRS2]CLCRUL(I)   <>[F:PRS]CLCRUL(I)    |
&    [F:PRS2]NPRNOTFLG(I)<>[F:PRS]NPRNOTFLG(I) |
&    [F:PRS2]INVDTA(I)   <>[F:PRS]INVDTA(I)
    GERR=1 : GMESSAGE="("+WPLISTC1+")"-mess(390,194,1)-WBPSNUM2-"("+WPLISTC2+")" : Break
  Endif
Next I
End

