Gosub RAZCRE_PURPRITYP
# IRMUE 14.06.12 81574:AP/AR management <End>

Gosub GRIZE_LIENS

#-----
#Affzo [BPRS]CRY, LAN, CUR
#Affzo [BPS2]1-99 : Raz [M:BPS2]BPSRSK
#Affzo [BPS4]1-99

#LSE 06/02/2007
Affzo [M:BPS0]1-99
Affzo [M:BPRS]1-99
Affzo [M:BPAS]1-99
If GACTFTC =2 Affzo [M:BPS1]1-99  Endif #MAE, bg 85873
Affzo [M:BPS4]1-99
Affzo [M:BPS2]1-99
If GACTFTC =2 Affzo [M:BPS3]1-99  Endif #MAE, bg 85873
Affzo [M:BIDS]1-99
Affzo [M:CNTS]1-99

If [M:BPS0]BSGCOD="" zonsui="BSGCOD" Endif

Return

###################################################################
$RAZDUP
Local Integer WRET

# Raz des zones mémoire de stockage des textes
Call RAZ_CLOB From ACLOB

#---------------------------------------------------#
#Modif CRM 6/12/2002
#---------------------------------------------------#
If !GIBPSEXIST
    #Voulez-vous partager les interlocuteurs de la société XXXX ?
    Local Integer IASKBPR
    Local Char SZMESS(250)
    IASKBPR = 0
    If [M:CNTS]NBCNT > 0
        SZMESS = mess(834, 196, 2) + ' ' + [M:BPS0]BPSNUM
        Call OUINON(SZMESS, IASKBPR) From GESECRAN
        If IASKBPR <> 2
            Raz [M:CNTS]
            Raz [M:CNTS]NBCNT
            Affzo [M:CNTS]1-99
        Endif
    Endif
Endif

#En duplication TIERS : On ne duplique pas les informations RIB ! #JPGA:12/06/2006 - BUG140:38475
# Raz + Affzo + Non validation du Mask
If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
Look [BPR] BPR0=CZ
If fstat>0
    # Si le client n'existe pas, on efface les RIB (qui ne doivent pas venir du client dupliqué) # ACA 44754
    Effzo [M:BIDS]
Endif

# A vérifier
If GACTFTC=2
   [M:BPS1]CURWORDMIN = GCUR
   [M:BPS1]CURFREFRT  = GCUR  # 106430.n
   # Dupplication des textes pour le nouveau client
   If [M:BPS1]ORDTEX<>""
      Call DUP_CLOB("BPS",[M:BPS1]ORDTEX,WRET) From TRTX3TEX
      If WRET<1 Raz [M:BPS1]ORDTEX Endif
   Endif
   If [M:BPS1]RTNTEX<>""
      Call DUP_CLOB("BPS",[M:BPS1]RTNTEX,WRET) From TRTX3TEX
      If WRET<1 Raz [M:BPS1]RTNTEX Endif
   Endif
Endif
[M:BPS4]ACCCUR = GCUR

#-----------------#
# flags du tiers  #
#-----------------#
If CLECUR
    If CZ <> [M:BPS0]BPSNUM
        Look  [BPR]BPR0 = CZ
        If fstat
           #-- on remet les indicateurs a zero
           [M:BPRS]BPCFLG    = 1
           # Issue 44629 - 2017-09-12 by MAE : RAZ des indicateurs
           #If GACTFTC=2 & [M:BPRS]BPTFLG=1 Endif
           If GACTFTC=2 & [M:BPRS]BPTFLG<>1
            [M:BPRS]BPTFLG = 1
           Endif
           # Issue 44629 - 2017-09-12 by MAE : RAZ des indicateurs
           #If GACTFTC=2 & [M:BPRS]REPFLG=1 Endif
           If GACTFTC=2 & [M:BPRS]REPFLG<>1
            [M:BPRS]REPFLG=1
           Endif
           [M:BPRS]FCTFLG    = 1
        #-- pas celui de tiers divers
        #  [M:BPRS]BPRACC    = 1
           [M:BPRS]BPSFLG    = 2
        Endif

        #----------------------------------#
        # on init le fournisseur facturant #
        #----------------------------------#
        # Issue 116753 - 2016-05-26 by MAE : Fait plus loin
#        If [M:BPS0]REFCOU=""
#           [M:BPS2]BPSINV = CZ
#           [M:BPS2]BPRPAY = CZ
#           [M:BPS2]BPSGRU = CZ
#        Else
#           [M:BPS2]BPSINV = ""
#           [M:BPS2]BPRPAY = ""
#           [M:BPS2]BPSGRU = ""
#        Endif
#        Raz [M:BPS2]BPSRSK
        # End issue 116753
    Endif
Endif

#---------------------------------------#
# il faut remettre a zéro total encours #
#---------------------------------------#
[M:BPS4]TOTAMT = 0

# Exigence 82615 : Législation belge --str
#If dim([M:BPS2]DADFLG)>0
#   If [M:BPS2]DADFLG=2
#    Actzo [M:BPS2]PRVNUM
#  Else
#    Grizo [M:BPS2]PRVNUM
#  Endif
#Endif
# => Réalisé par $GRIZE_LIENS
# Exigence 82615 : Législation belge --end

# MHB 23/10/08
# Dupplication des textes pour les nouveaux articles fournisseur et client
If dim([M:BPS6]NBITP) > 0
Local Integer WRET
  For nolign=1 To [M:BPS6]NBITP
   If [M:BPS6]TEX(nolign-1)<>""
     Call DUP_CLOB("ITP",[M:BPS6]TEX(nolign-1),WRET) From TRTX3TEX
     If WRET<1 Raz [M:BPS6]TEX(nolign-1) Endif
   Endif
  Next
Endif

# Issue 116753 - 2016-05-26 by MAE : Reinitialisation des parteners dans l'onglet "Financier"
# Réinitialisation du fournisseur groupe avec le nouveau fournisseur s'il était égal au founisseur dupliqué
If [M]BPSGRU = [M:BPS0]BPSNUM
    If [M:BPS0]REFCOU=""
       [M]BPSGRU = CZ
    Else
       [M]BPSGRU = ""
    Endif
    Affzo [M:BPS2]BPSGRU
    If GINIBPRRSK=3 & [M]BPSRSK=[M:BPS0]BPSNUM [M]BPSRSK=CZ : Affzo [M:BPS2]BPSRSK Endif
Endif
Local Integer J
J=find (2,[M:BPAS]BPAADDFLG(0..[M:BPAS]NBADR-1))
# Réinitialisation du tiers facturant avec le nouveau fournisseur s'il était égal au fournisseur dupliqué
If [M]BPSINV = [M:BPS0]BPSNUM
    If [M:BPS0]REFCOU=""
       [M]BPSINV = CZ
    Else
       [M]BPSINV = ""
    Endif
    Affzo [M:BPS2]BPSINV
    If !find (GINIBPRRSK,2,3) & [M]BPSRSK=[M:BPS0]BPSNUM [M]BPSRSK=CZ : Affzo [M:BPS2]BPSRSK Endif
    If J [M:BPS2]BPAINV=[M:BPAS]CODADR(J-1) : Affzo [M:BPS2]BPAINV : Endif
Endif
# Réinitialisation du Tiers payé avec le nouveau fournisseur s'il était égal au fournisseur dupliqué
If [M]BPRPAY = [M:BPS0]BPSNUM
    If [M:BPS0]REFCOU=""
       [M]BPRPAY = CZ
    Else
       [M]BPRPAY = ""
    Endif
    Affzo [M:BPS2]BPRPAY
    If GINIBPRRSK=2 & [M]BPSRSK=[M:BPS0]BPSNUM [M]BPSRSK=CZ : Affzo [M:BPS2]BPSRSK : Endif
    If J [M:BPS2]BPAPAY=[M:BPAS]CODADR(J-1) : Affzo [M:BPS2]BPAPAY : Endif
Endif
# Réinitialisation du tiers risque avec le nouveau fournisseur s'il était égal au fournisseur dupliqué
If [M]BPSRSK = [M:BPS0]BPSNUM
    [M]BPSRSK = CZ : Affzo [M:BPS2]BPSRSK
Endif
# End issue 116753


#CRM

#-------------------------------------------------------------------
#IRMUE 14.06.12 81574:AP/AR management
#-------------------------------------------------------------------
Gosub RAZDUP_PURPRITYP
#IRMUE 14.06.12 81574:AP/AR management <End>

Gosub RAZDUP_CRM From TRTBPCRM

Gosub GRIZE_LIENS

#MAE, bg 50370
If [M:BPS0]BSGCOD <> ""
   Read [BSG]BSG0=[M:BPS0]BSGCOD
   If !fstat
      If [F:BSG]CREMOD=2
         [M:BPS0]ENAFLG=1
      Else
         [M:BPS0]ENAFLG=2
      Endif
   Endif
Endif


Affzo [M:BPRS]1-99
Affzo [M:BPS2]1-99
Affzo [M:BPS4]1-99
#MAE, bg 50370
Affzo [M:BPS0]ENAFLG

Return

###################################################################
$VERIFCRE_MOD
#----------------------------------------------------#
# attention au blanc dans la zone numéro fournisseur #
# option C ne fonctionne pas le 30 juillet 98        #
#----------------------------------------------------#
[M:BPS0]BPSNUM= vireblc ([M:BPS0]BPSNUM,2)
#[M:BPS4]BPSREM= vireblc([M:BPS4]BPSREM,2)  : # hn 08/03/2001   supplier notes
#If [M:BPS4]BPSREM="" Raz[M:BPS4]BPSREM : Endif                 supplier notes 10/10/2012
# MAE 22/07/2008 : La catégorie est obligatoire en V6
  If [M:BPS0]BSGCOD = "" & find(GREP,"C","D") Then
    GERR = 1
    GMESSAGE = mess(535,199,1)
    OK = 0
    zonsui = "BSGCOD"
    Return
  Endif
#----------------------------------#
# avant la creation du fournisseur #
# on verifie qu'une adresse existe #
#----------------------------------#
If [M:BPAS]NBADR=0
  GERR=1 : GMESSAGE=mess(31,199,1) : OK=0 : zonsui="[M:BPAS]NBADR(0)" : Return
Endif
#---------------------------------------------------#
# on verifie qu une adresse est désignée par défaut #
#---------------------------------------------------#
If find (2,[M:BPAS]BPAADDFLG (0..[M:BPAS]NBADR -1)) = 0
        GERR=1:GMESSAGE=mess(110,199,1)
        OK = 0
        Return
Endif
#    Si le tiers est un site
#    --> on va réécrire les adresses les RIB et les contacts du site
If GACTFTC=2 & [M:BPRS]FCY<>""
    GERR=3:GMESSAGE=mess(178,196,1)
Endif

Return

###################################################################
$INICRE
Local Integer STAT, WRET, WNUMOK
Local Char    NUMERO(GLONBPS)

#MAE, bg 100401, si BPSNUM est renseigné et que la catégorie a un compteur et qu'on ne vient pas des tiers
#=> raz de la zone
If [M:BPS0]BPSNUM<>"" &  [F:BSG]REFCOU<>"" & GNAVIG(max(GPILNAV-1,1)) <> "GESBPR"
  If [M:BPS2]BPSINV = [M:BPS0]BPSNUM
    [M:BPS2]BPSINV = ""
    [F:BPS]BPSINV = ""
  Endif
  If [M:BPS2]BPSGRU = [M:BPS0]BPSNUM
    [M:BPS2]BPSGRU = ""
    [F:BPS]BPSGRU = ""
  Endif
  If [M:BPS2]BPRPAY = [M:BPS0]BPSNUM
    [M:BPS2]BPRPAY = ""
    [F:BPS]BPRPAY = ""
  Endif
  If [M:BPS2]BPSRSK = [M:BPS0]BPSNUM
     [M:BPS2]BPSRSK = ""
     [F:BPS]BPSRSK=""
  Endif
  [M:BPS0]BPSNUM = ""
  [F:BPS]BPSNUM = ""
Endif

# Si le numéro fournisseur est déterminée par un compteur
If [F:BPS]BPSNUM = ""
  WNUMOK=0
  While WNUMOK=0
    # FGR 17/12/2009 : X3SUIVI60196
    #--- à activer en 6.20
    #Call NUMERO([M:BPS0]REFCOU,GFCYDEF(9),datesyst,"",NUMERO,STAT) From SUBANM
    Call NUMCLE ([M:BPS0]REFCOU,GFCYDEF(9),datesyst,"","BPS",NUMERO,STAT) From SUBANM
    #---
    If STAT = 0
      Look [BPR]BPR0=NUMERO
      If fstat
        [F:BPS]BPSNUM =NUMERO
        [M:BPS0]BPSNUM=NUMERO
        If [F:BPS]BPSINV=""
          [F:BPS]BPSINV=NUMERO
          [M:BPS2]BPSINV=NUMERO
        Endif
        If [F:BPS]BPSGRU=""
          [F:BPS]BPSGRU=NUMERO
          [M:BPS2]BPSGRU=NUMERO
        Endif
        If [F:BPS]BPRPAY=""
          [F:BPS]BPRPAY=NUMERO
          [M:BPS2]BPRPAY=NUMERO
        Endif
        If [F:BPS]BPSRSK=""
          Case GINIBPRRSK
           When 1       : [M:BPS2]BPSRSK=[M:BPS2]BPSINV
           When 2       : [M:BPS2]BPSRSK=[M:BPS2]BPRPAY
           When 3       : [M:BPS2]BPSRSK=[M:BPS2]BPSGRU
           When Default : [M:BPS2]BPSRSK=[M:BPS2]BPSINV
          Endcase
          [F:BPS]BPSRSK=[M:BPS2]BPSRSK
        Endif
        WNUMOK=1
      Endif
    Else
      GOK=0 : WNUMOK=1
      # FGR 20/07/2011 : X3SUIVI75166
      Local Char MESSA(80)
      GMESSAGE = mess(104,117,1) - "(" + [M:BPS0]REFCOU + ") : "
      Gosub MESSAGE From SUBANMARG
      GMESSAGE -= MESSA
    Endif
  Wend
  If GOK=0 Return Endif
Endif

#------------------------------------#
# etiquette appelee avant le write   #
# dans la transaction de creation    #
#------------------------------------#
Gosub CREBPS
If GOK < 1 : Return : Endif

# Création des textes commande et facture
If GACTFTC=2
  If [M:BPS1]ORDTEX<>""
    Call CRE_CLOB([M:BPS1]ORDTEX,GOK) From TRTX3TEX
    If GOK<1 Return Endif
    [F:BPS]ORDTEX = [M:BPS1]ORDTEX
  Endif
  If [M:BPS1]RTNTEX<>""
    Call CRE_CLOB([M:BPS1]RTNTEX,GOK) From TRTX3TEX
    If GOK<1 Return Endif
    [F:BPS]RTNTEX = [M:BPS1]RTNTEX
  Endif
Endif
#----- Mise à jour adresse par défaut du fournisseur -----#
[F:BPS]BPAADD=[M:BPAS]CODADR(max(find(2,[M:BPAS]BPAADDFLG(0..[M:BPAS]NBADR-1))-1,0))
Return

#  90370 - Cash VAT - Update values of intercompany suppliers
If func AFNC.ACTIV("KSP")
  Local Char SPACSHDAT(8)
  Local Char SPACSHVAT(1)

  Call PARAML([M]FCY,"SPACSHDAT",SPACSHDAT) From ADOVAL
  If val(SPACSHDAT)<>0 and dim([F:BPS]CSHDAT)>0
    [F:BPS]CSHDAT=gdat$(val(mid$(SPACSHDAT,7,2)),val(mid$(SPACSHDAT,5,2)),val(mid$(SPACSHDAT,1,4)))
  Else [F:BPS]CSHDAT=[00/00/00]
  Endif

  Call PARAML([M]FCY,"SPACSHVAT",SPACSHVAT) From ADOVAL
  If dim([F:BPS]CSHVAT)>0
    [F:BPS]CSHVAT=val(SPACSHVAT)
  Endif
Endif
#  90370 - Cash VAT

Return

