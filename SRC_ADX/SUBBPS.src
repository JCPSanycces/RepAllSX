#--------------------------------#
# Après modif fournisseur groupe #
#--------------------------------#
Subprog AM_BPSGRU(VALEUR)
Variable Char    VALEUR()
#----- Alimentation du tiers risque si nécessaire -----#
If GREP="C" & GINIBPRRSK=3
  Call AM_BPSRSK(VALEUR) : [M:BPS2]BPSRSK=VALEUR : Affzo [BPS2]BPSRSK
Endif
End

#--------------------------------#
# Initialisation du tiers risque #
#--------------------------------#
Subprog D_BPSRSK(VALEUR)
Variable Char    VALEUR()
Case GINIBPRRSK
  When 1       : VALEUR=[M:BPS2]BPSINV
  When 2       : VALEUR=[M:BPS2]BPRPAY
  When 3       : VALEUR=[M:BPS2]BPSGRU
  When Default : VALEUR=[M:BPS2]BPSINV
Endcase
End

#-----------------------#
# Contrôle tiers risque #
#-----------------------#
Subprog C_BPSRSK(VALEUR)
Variable Char    VALEUR()

If find(GREP,"C","D") & [M:BPS0]REFCOU<>"" & VALEUR=""
   End
Endif

If VALEUR<>[M:BPS0]BPSNUM
  Read [BPS2] BPS0=VALEUR
  If fstat
    GMESSAGE=mess(23,100,1)  : mkstat=1 : End
  Elsif [F:BPS2]ENAFLG<>2
    GMESSAGE=mess(140,199,1) : mkstat=1 : End
  Endif
Endif
End

#--------------------------#
# Après modif tiers risque #
# ------------------------ #
# Activation/Désactivation #
# des champs de l'encours  #
#--------------------------#
Subprog AM_BPSRSK(VALEUR)
Variable Char    VALEUR()
#----- Le tiers risque est-il le fournisseur lui-même ? -----#
If VALEUR=[M:BPS0]BPSNUM
  Actzo [BPS4]OSTCTL, WOSTAUZAMT
#----- Le fournisseur est-il le tiers rique d'autres fournisseurs ? -----#
Else
  Filter [BPS2] Where BPSRSK=[M:BPS0]BPSNUM & BPSNUM<>[M:BPS0]BPSNUM
  Look [BPS2] BPS0 First
  Filter [BPS2]
  If fstat
   #----- Récupération des infos à partir du tiers risque ------#
   #Read [BPS2] BPS0=VALEUR : If fstat Raz [F:BPS2] : [F:BPS2]OSTCTL=1 : Endif
   #[M:BPS4]OSTCTL    =[F:BPS2]OSTCTL
   #Call CONVERT2(GSYSCUR,GCUR,GLOCALDEV,GCHGTYP,datesyst,[F:BPS2]OSTAUZAMT,[M:BPS4]WOSTAUZAMT,GBIDI2) From TRTDEV
   #Call ARRDEV([M:BPS4]WOSTAUZAMT,GCUR) From TRTDIV
   #Affzo [BPS4]OSTCTL, WOSTAUZAMT
    Grizo [BPS4]OSTCTL, WOSTAUZAMT
  Else
    Actzo [BPS4]OSTCTL, WOSTAUZAMT
  Endif
Endif
End

Subprog AM_DADFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Actzo [M:BPS2]PRVNUM
Else
  # Exigence 82615 : Législation belge --str
  If dim([M:BPS2]FLG281)>0
    If [M:BPS2]FLG281=2
      Actzo [M:BPS2]PRVNUM
    Else
      Grizo [M:BPS2]PRVNUM
    Endif
  Else
    Grizo [M:BPS2]PRVNUM
  Endif
  # Exigence 82615 : Législation belge --end
Endif
End

# Exigence 82615 : Législation belge --str
Subprog AM_FLG281(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Actzo [M:BPS2]PRVNUM
Else
  If dim([M:BPS2]DADFLG)>0
    If [M:BPS2]DADFLG=2
      Actzo [M:BPS2]PRVNUM
    Else
      Grizo [M:BPS2]PRVNUM
    Endif
  Else
    Grizo [M:BPS2]PRVNUM
  Endif
Endif
End
# Exigence 82615 : Législation belge --end

Subprog C_PRVNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Read [PRV]PRV0=VALEUR
 If fstat
  GMESSAGE = mess(5,122,1) : #Prestataire inexistant
  mkstat = 2
 Endif
Endif
End

Subprog AM_VACBPR(VALEUR)
Variable Char    VALEUR()

#If GIMPORT : End : Endif
#-----------------------------------------#
# message avertissement si regime taxe cee#
# et que numéro tva = ""                  #
