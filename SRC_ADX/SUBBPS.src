  [M]UPDUSR   ([M]XNUMLIG) = GUSER
End

Subprog AM_XPCU(VALEUR)
Variable Char    VALEUR()
Local Integer J

  Read [F:ITM]ITM0=[M:BPS6]ITMREF(nolign-1)
  If !fstat Then
    Call MODUNIT(VALEUR,[M:BPS6]XPUU,[M:BPS6]XPCUPUUCOE) From SUBITM

    # si l'UC est parmi les UC de l'article : reprendre le coeff du tableau de PCU
    # et passer par le coeff intermédiaire  (rajouté pour v 140)
    J = find(VALEUR,[F:ITM]PCU)
    If J > 0
      [M:BPS6]XPCUPUUCOE = [F:ITM]PCUSTUCOE(J-1) / [M]XPUUSTUCOE
    Endif

    Affzo [M:BPS6]XPCUPUUCOE
    [M]IPCUPUUCOE([M]XNUMLIG)= [M:BPS6]XPCUPUUCOE

    [M]ITPPCU   ([M]XNUMLIG) = VALEUR
    If VALEUR = ""
      If !GIMPORT
        Effzo XPCUPUUCOE
      Endif
      [M]IPCUPUUCOE([M]XNUMLIG)= 0
    Endif
    [M]UPDDAT    ([M]XNUMLIG) = date$
    [M]UPDUSR    ([M]XNUMLIG) = GUSER
  Endif
End

Subprog AS_XPCUPUUCOE(VALEUR)
Variable Decimal VALEUR
Local Integer J

  Read [F:ITM]ITM0=[M:BPS6]ITMREF([M]XNUMLIG)
  If !fstat Then
    Call COEFCNV([M]XPCU,[M]XPUU,VALEUR) From SUBITM
    # si l'UC est parmi les UC de l'article : voir si elle est modifiable v 140
    If dim([F:ITM]PCU)>0
      J = find([M]XPCU,[F:ITM]PCU(0.. dim([F:ITM]PCU)-1))
      If J > 0
        If [F:ITM]DACPCUCOE(J-1) < 2
          mkstat = 2 # non modifiable
        Endif
      Endif
    Endif

    If mkstat = 2 [M]IPCUPUUCOE([M]XNUMLIG) = VALEUR : Endif
  Endif
End

Subprog C_XPCUPUUCOE(VALEUR)
Variable Decimal VALEUR

  If [M]XPCU <> "" & VALEUR =0
    GMESSAGE = mess(10,123,1) : mkstat=2   # "zone obligatoire"
  Endif
End

