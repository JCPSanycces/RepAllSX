Subprog AS_XQUAFLG(VALEUR)
Variable Integer VALEUR

  # initialisation du menu local
  If [M]ITPQUAFLG([M]XNUMLIG) = 0
    Read [F:ITG]ITG1=[M:BPS6]TCLCOD([M]XNUMLIG);""
    If !fstat Then
      VALEUR = [F:ITG]QUAFLG
    Endif
  Endif
End

Subprog AM_XQUAFLG(VALEUR)
Variable Integer VALEUR

  [M]ITPQUAFLG([M]XNUMLIG) = VALEUR
  [M]UPDDAT   ([M]XNUMLIG) = date$
  [M]UPDUSR   ([M]XNUMLIG) = GUSER
  If VALEUR  < 2
    Effzo [M]XQLYCRD
    Grizo [M]XQLYCRD
  Else
    Actzo [M]XQLYCRD
  Endif
  If VALEUR = 4
    Actzo [M]XQUAFRY
  Else
    Effzo [M]XQUAFRY
    Effzo [M]XQUANUM
    Grizo [M]XQUAFRY
  Endif
End

