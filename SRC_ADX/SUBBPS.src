########################################
Subprog C_BSGCOD(VALEUR)
Variable Char    VALEUR()

# Catégorie obligatoire
If find(GREP,"C","D") & VALEUR=""
   GMESSAGE = mess(10,123,1)
   mkstat=2
Endif
End

########################################
Subprog AM_BSGCOD(VALEUR)
  Variable Char    VALEUR()

  #si le client n'est pas renseigné, la classe BPR1 ne doit pas être remplie,
  #elle sera reseignée quant le client sera saisie
  If [M:BPS0]BPSNUM=""
    Raz [F:BPR1]
  Endif
  #                            hcb 95481  deb
    Local Integer WINI : Raz WINI
    #If GFONC1 = "GESBPS"  # Issue X3-92506 - 2018-07-04 by USA
       If find(GREP,"C","D")
          WINI = 1
       Endif
    # Issue X3-92506 - 2018-07-04 by USA : Begin
      #Else
      #   If find(GREP,"C","D","") : WINI = 1 : Endif
      #Endif
    # Issue X3-92506 - 2018-07-04 by USA : End

  If WINI = 1
  #                            hcb 95481  fin
     Call INI_BSGCATEG(VALEUR)
     If VALEUR <> [F:BPR1]BRGCOD & VALEUR <>"" & [F:BPR1]BRGCOD <> ""
            Call MESSAGE(mess(104,187,1)+" "+[F:BPR1]BRGCOD) From GESECRAN
     Endif
     Affzo [M:BPRS]1-99
     If GACTFTC=2 Affzo [M:BPS1]1-99 Endif #MAE, bg85873
     Affzo [M:BPS2]1-99
     If GACTFTC=2 Affzo [M:BPS3]1-99 Endif #MAE, bg85873
     Affzo [M:BPS4]1-99

     If GS1099 Call SUB_GRIZE_LIENS("BPS2") From TEN99LIB : Endif #Set dependent field properties  #1099.n
  Endif

  ##  X3-26017: Support for REX identification ("Registered Export System) for export out of EU/SAL_X3-29158 (LUCUE 12/19/17)
  If dim([M:BPRS]REXNUM)>0
    If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
    Read [TCY]TCY0 = [M:BPRS]CRY
    If fstat Raz [F:TCY] Endif
    If [F:TCY]CRY="" or ([F:TCY]EECFLG<>2 & [F:TCY]GSPFLG<>2)
      If [M:BPRS]REXNUM<>""
        Raz [M:BPRS]REXNUM
        Affzo [M:BPRS]REXNUM
      Endif
      Grizo [M:BPRS]REXNUM
    Else
      Actzo [M:BPRS]REXNUM
    Endif
  Endif
  ## End X3-26017: Support for REX identification ("Registered Export System) for export out of EU/SAL_X3-29158 (LUCUE 12/19/17)

  # Exigence 82615 : Législation belge --str
  If func AFNC.ACTIV("FEE2")
    Local Integer ACTPRVNUM
    Raz ACTPRVNUM
    If dim([M:BPS2]DADFLG)>0
      If [M:BPS2]DADFLG=2
        ACTPRVNUM +=1
      Endif
    Endif
    If dim([M:BPS2]FLG281)>0
      If [M:BPS2]FLG281=2
        ACTPRVNUM +=1
      Endif
    Endif
    If ACTPRVNUM>0
      Actzo [M:BPS2]PRVNUM
    Else
      Grizo [M:BPS2]PRVNUM
    Endif
  Endif
  # Exigence 82615 : Législation belge --end

End

########################################
Subprog AS_BPSNUM(VALEUR)
Variable Char    VALEUR()

# FGR 19/08/2011 : X3SUIVI75723 :
#                  Si on est en import ça devrait fonctionner comme si on était venu en tunnel.
#                  Reproduire le fonctionnement transactionnel :
#                     Si la référérence n'existe pas on ne peut pas importer le client (parce qu'on est sensé ne pas pouvoir saisir la référence).
#                     Si la référence existe l'import s'applique au tiers existant en conservant sa référence.

  #MAE, le 27/01/09, bg 49572
  #If [M:BPS0]REFCOU<>"" & find(GREP,"C","D")
  If [M:BPS0]REFCOU<>"" & find(GREP,"C","D") & GFONC1 <>"GESBPR" and !GIMPORT Then
    mkstat = 2
  Endif
  If GNAVIG(max(GPILNAV-1,1)) = "GESBPR" & (GREP = "" | GREP="C") and !GIMPORT Then
    If [M:BPR0]BPRNUM <> "" & [M:BPS0]BPSNUM =""
      VALEUR = [M:BPR0]BPRNUM
    Endif
  Endif
End

########################################
Subprog C_BPSNUM(VALEUR)
Variable Char    VALEUR()
If [M:BPS0]REFCOU="" & VALEUR=""
   mkstat=2
Endif
End

########################################
Subprog AM_BPSNUM(VALEUR)
Variable Char    VALEUR()
GIBPSEXIST = 0
Look [BPS] BPS0=VALEUR
If !fstat
    # Si le fournisseur existe, Vérification qu'il est bien autorisé par la gestion des rôles -----#
    # (S'il n'existe pas, il faut autoriser sa création)
    GBIDC2="" : Call FILROLE("BPS",GBIDC2) From SUBARL
    If GBIDC2<>""
        Filter [BPS] Where evalue(GBIDC2)
        Look [BPS] BPS0=VALEUR
        Filter [BPS]
        If fstat  End : Endif
    Endif
Endif

  # FGR 19/08/2011 : X3SUIVI75723 (début)
  If [M:BPS0]REFCOU <> "" & find(GREP,"C","D") and GIMPORT Then
    If !clalev([F:BPR1]) : Local File BPARTNER [BPR1] : Endif
    Read [BPR1]BPR0=VALEUR
    If fstat Then
      GERR = 1
      GMESSAGE = mess(573,199,1)
      mkstat = 2
      End
    Endif
  Endif
  # FGR 19/08/2011 : X3SUIVI75723 (fin)

#MAE, 08/12/08
#[M:BPS0]BPSNUM=VALEUR #MAE, bg 100063
#Gosub INIT_BPS
Call INIT_BPS(VALEUR)

##  X3-26017: Support for REX identification ("Registered Export System) for export out of EU/SAL_X3-29158 (LUCUE 12/19/17)
If dim([M:BPRS]REXNUM)>0
  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
  Read [TCY]TCY0 = [M:BPRS]CRY
  If fstat Raz [F:TCY] Endif
  If [F:TCY]CRY="" or ([F:TCY]EECFLG<>2 & [F:TCY]GSPFLG<>2)
    If [M:BPRS]REXNUM<>""
      Raz [M:BPRS]REXNUM
      Affzo [M:BPRS]REXNUM
    Endif
    Grizo [M:BPRS]REXNUM
  Else
    Actzo [M:BPRS]REXNUM
  Endif
Endif
## End X3-26017: Support for REX identification ("Registered Export System) for export out of EU/SAL_X3-29158 (LUCUE 12/19/17)

End

######################################################################################
Subprog AM_SOC(VALEUR)
Variable Char    VALEUR()
[M:BPS0]SOC = VALEUR
#----- Recharger GCUR avec la devise de la société -----#
GCUR=[F:CPY]ACCCUR
#----- Initialisation tableau des axes -----#
If dim([M:BPS2]NBAXE)>0
  If dim([M:BPS0]SOC)>0 & [M:BPS0]SOC<>""
    Call CHARG_DIE(3,[M:BPS0]SOC,"BPS2","NBAXE") From TRTX3CPT
  Else
    Call CHARG_DIE(3,"","BPS2","NBAXE") From TRTX3CPT
  Endif
Endif
#-----
#MAE, 08/12/08
#Gosub INIT_BPS
Call INIT_BPS([M:BPS0]BPSNUM)
End

#######################################################
# Appelé en AM_BPSNUM et AM_SOC
#MAE, le 08/12/08, passage en sous pro car pb en razdup si init de [M:BPS0]BPSNUM par la valeur saisie
#$INIT_BPS
Subprog INIT_BPS(VALEUR)
Variable Char VALEUR ()

If GACTFTC=2
  Raz [M:BPS1]ORDTEX
  Raz [M:BPS1]RTNTEX
Endif #MAE, bg 85873
#-------------------------------------#
# il faut verrouiller symbole BPR     #
# si pas deja fait dans action verrou #
#-------------------------------------#
# FGR 15/02/2010 : X3SUIVI59669 : Préserver [F:BPR]
# Pb en import
# Il ne faut pas écraser [F:BPR] qui peut être chargé avec des champs à importer (Ex import de la raison sociale)
# ==> Lecture du tiers sous une autre abréviation
If !clalev([F:BPR1]) : Local File BPARTNER [BPR1] : Endif

#MAE,08/12/08
#Read [BPR]BPR0 = [M:BPS0]BPSNUM
#Read [BPR]BPR0 = VALEUR
Read [BPR1]BPR0=VALEUR

If fstat = 0
    If GREP = "C" | GREP = "D" or GREP = ""
        #----------------------------------------------#
        # il faut vérifier si le tiers existe          #
        # lecture BPARTNER et affichage masque         #
        # récupérer aussi les adresses rib et contacts #
        #----------------------------------------------#
        [M:BPRS] = [F:BPR1]
        [M:BPS0]BPSNAM = [F:BPR1]BPRNAM
        Affzo [M:BPS0]BPSNAM
        Affzo [M:BPRS]1-99
        Default Mask [BPAS]
        #MAE,08/12/08
        #Call CHARG_BPA(1,[M:BPS0]BPSNUM,[F:BPR1]BPAADD) From TRTBPA
        Call CHARG_BPA(1,VALEUR,[F:BPR1]BPAADD) From TRTBPA
        Default Mask [BIDS]
        #MAE, 08/12/08
        #Call CHARG_RIB(1,[M:BPS0]BPSNUM,"~") From TRTBPA
        Call CHARG_RIB(1,VALEUR,"~") From TRTBPA
        Default Mask [CNTS]
        #MAE, 08/12/08
        #Call CHARG_CNT(1,[M:BPS0]BPSNUM,[F:BPR1]CNTNAM) From TRTBPA
        Call CHARG_CNT(1,VALEUR,[F:BPR1]CNTNAM) From TRTBPA
        Default Mask [BPS0]
        Affzo [M:BPAS]1-99
        Affzo [M:BIDS]1-99
        Affzo [M:CNTS]1-99

        GIBPSEXIST = 1
    Endif
    If GREP = "C" or GREP = "D" # Issue number 121066 - 2017-01-20 by MAE : déplacé pour ne pas avoir de lock sur BPR en consultation
      If GNAVIG(max(GPILNAV-1,1)) <> "GESBPR" or (GNAVIG(max(GPILNAV-1,1)) = "GESBPR" and [M:BPR0]BPRNUM <> VALEUR) Then # FGR 16/04/2012 : X3SUIVI81335
        #MAE,08/12/08
        #SYMBOLE2 = "BPR"+num$([M:BPS0]BPSNUM)
        SYMBOLE2 = "BPR"+num$(VALEUR)
        Lock = SYMBOLE2 With lockwait = 0
        If fstat
        #If GREP = "C" or GREP = "D"
           GERR=1 : GMESSAGE = mess(10,100,1) : mkstat = 2 : End
        #Endif
        Else
          # FGR 16/04/2012 : X3SUIVI81335
          Global Integer GILOCKBPR
          GILOCKBPR = 1
        Endif
      Endif
   Endif
Else
    # Le tiers n'existe pas
    Raz [F:BPR1]
Endif
# Création d'un fournisseur : alimentation des zones
# --> GREP n'est pas toujours positionné à "C" (RAZCRE peut être executé après)
If [F:BPR1]BPSFLG <> 2 | GREP = "C"
    If GREP =""   #MAE, bg85558
      # Issue 116753 - 2016-05-26 by MAE : on raz uniquement VALEUR et pas le champ écran pour pouvoir le tester et initialisé les données tiers de l'onglet Financier
      #If [M:BPS0]REFCOU<>"" Raz [M:BPS0]BPSNUM :Raz VALEUR: Affzo[M:BPS0]BPSNUM : Endif
      If [M:BPS0]REFCOU<>"" Raz VALEUR : Endif
    Endif
    If [M:BPS2]BPSGRU=""
        #MAE, 08/12/08
        #[M:BPS2]BPSGRU = [M:BPS0]BPSNUM : Affzo [M:BPS2]BPSGRU
        [M:BPS2]BPSGRU = VALEUR : Affzo [M:BPS2]BPSGRU
    Endif
    If GACTFTC=2 & [M:BPRS]BETFCY=2 & [M:BPRS]FCY <> ""
        Local Char WFCY(GLONFCY) : WFCY=[M:BPRS]FCY                            # FGR 11/04/2012 : X3SUIVI81394
        #MAE, 08/12/08
        #Local Char WBPSNUM : WBPSNUM=[M:BPS0]BPSNUM
        Local Char WBPSNUM(GLONBPR) : WBPSNUM=VALEUR                           # FGR 11/04/2012 : X3SUIVI81394
        Gosub ALI_BETFCY
        If mkstat=2 GERR=1 : GMESSAGE-="\"-mess(7,123,1) : End : Endif
    Else
        #MAE, 08/12/08
        #If [M:BPS2]BPRPAY="" [M:BPS2]BPRPAY=[M:BPS0]BPSNUM : [M:BPS2]BPAPAY=[F:BPR1]BPAADD : Endif
        If [M:BPS2]BPRPAY=""
            [M:BPS2]BPRPAY= VALEUR
            #MAE, bg56792 + bg101355
#            If GIMPORT
#                If [F:BPS]BPAPAY<>""
#                    [M:BPS2]BPAPAY = [F:BPS]BPAPAY
#                Endif
            If GIMPORT & [F:BPS]BPAPAY<>""
                    [M:BPS2]BPAPAY = [F:BPS]BPAPAY
            Else
                [M:BPS2]BPAPAY=[F:BPR1]BPAADD
            Endif
        Endif
        #MAE,08/12/08
        #If [M:BPS2]BPSINV="" [M:BPS2]BPSINV=[M:BPS0]BPSNUM : [M:BPS2]BPAINV=[F:BPR1]BPAADD : Endif
        If [M:BPS2]BPSINV=""
            [M:BPS2]BPSINV=VALEUR
            #MAE, bg 56792
            If GIMPORT & [F:BPS]BPAINV <> ""
                [M:BPS2]BPAINV = [F:BPS]BPAINV
            Else
                [M:BPS2]BPAINV=[F:BPR1]BPAADD
            Endif
        Endif
    Endif
    If [M:BPS2]BPSRSK=""
       Case GINIBPRRSK
           When 1       : [M:BPS2]BPSRSK=[M:BPS2]BPSINV
           When 2       : [M:BPS2]BPSRSK=[M:BPS2]BPRPAY
           When 3       : [M:BPS2]BPSRSK=[M:BPS2]BPSGRU
           When Default : [M:BPS2]BPSRSK=[M:BPS2]BPSINV
       Endcase
    Endif

    Affzo [M:BPS2]BPRPAY, BPAPAY, BPSINV, BPAINV, BPSRSK
Endif
End
#MAE, 08/12/08
#Return

$ALI_BETFCY
If find (GREP,"C","D")  #MAE, bg 79523
  Raz [M:BPS2]BPSINV, BPRPAY, BPAINV
Endif
# Si Fournisseur inter-site
If clalev([F:FCY])=0 Local File FACILITY [FCY]  : Endif
#   Lecture du site lié à fournisseur
If  [F:FCY]FCY<>WFCY
    Read [FCY]FCY0=WFCY : If fstat Raz [FCY] Endif
Endif
# FGR 11/04/2012 : X3SUIVI81394 (DÉBUT)
If dim(WBPAADD) < 0 Then
  Local Char WBPAADD(GLONADR) : WBPAADD=[F:FCY]BPAADD
Endif
# FGR 11/04/2012 : X3SUIVI81394 (fin)

[M:BPS2]LEGCPY = [F:FCY]LEGCPY
#   => Init. tiers facturant et tiers payé avec le tiers lié au site financier du site fournisseur
If [F:FCY]FINFLG = 2
    If find (GREP,"C","D")  #MAE, bg 79523
      [M:BPS2]BPSINV=WBPSNUM
      [M:BPS2]BPAINV=WBPAADD  #MAE, bg 79523
      [M:BPS2]BPRPAY=WBPSNUM
      [M:BPS2]BPAPAY=WBPAADD  #MAE, bg 79523
    Endif
Elsif [F:FCY]FINRSPFCY <> ""
    Local File BPARTNER [BPRW]
    Read [BPRW] BPR2(2)=2;[F:FCY]FINRSPFCY
    If !fstat & [F:BPRW]BPSFLG=2
#       Le tiers payé doit être fournisseur ou factor et le tiers facturant doit être fournisseur
#       ==> le tiers doit être fournisseur
        If find (GREP,"C","D")  #MAE, bg 79523
          [M:BPS2]BPRPAY=[F:BPRW]BPRNUM
          [M:BPS2]BPSINV=[F:BPRW]BPRNUM
        Endif
#       Le tiers facturant doit être fournisseur
#        If  [F:BPS]BPSNUM<>[F:BPRW]BPRNUM
#            Look [BPS]BPS0 = [F:BPRW]BPRNUM
#        Endif
#        If fstat=0 | [F:BPRW]BPRNUM=WBPSNUM
#            [M:BPS2]BPSINV=[F:BPRW]BPRNUM
#        Endif
    Else
        GMESSAGE=mess(463,199,1)-"\"-mess(462,199,1) : mkstat=2
    Endif
#    [G:BPRW]currind=1 : [G:BPRW]currlen=0 : # Réinitialisation clé par défaut
Endif
Return

# --------------------------------------------------------------------------------
#                                        Ecran BPS1
# --------------------------------------------------------------------------------


#-----------------------------------------#
# Après modification du mode de livraison #
#-----------------------------------------#
Subprog AM_MDL(VALEUR)
Variable Char    VALEUR()
#----- Chargement et affichage "Incoterm" venant du mode de livraison -----#
[M:BPS1]EECICT=[F:TMD]EECICT : Affzo [BPS1]EECICT
#----- Chargement et affichage "Lieu de transport" (soumis au code activité DEB) -----#
If dim([M:BPS1]EECLOC)>0
  [M:BPS1]EECLOC=[F:TMD]EECLOC : Affzo [BPS1]EECLOC
Endif
#-----
End


#-----------------------------------------#
# Vérification du code structure          #
# --------------------------------------- #
# La modification est possible mais       #
# si des mouvements existent la nouvelle  #
# structure doit commencer par les        #
# mêmes colonnes que l'ancienne structure #
#-----------------------------------------#
Subprog AM_PLISTC(VALEUR)
Variable Char    VALEUR()
#----- Vérification si structure compatible avec fournisseurs liés -----#
For [BPS2] Where BPSNUM<>[M:BPS0]BPSNUM & BPSINV=[M:BPS0]BPSNUM
  Call VERIF_STRUCTURE([M:BPS0]BPSNUM,VALEUR,[F:BPS2]BPSNUM,[F:BPS2]PLISTC)
  If GERR  Break : Endif
Next
If GERR  mkstat=1 : End : Endif
#-----
If GREP="C" | [M:BPS4]TOTAMT=0 End : Endif
Local Shortint OK
#-- S'il y a un encours est-il lié au commande - réception - facture ?
#-- Vérification des factures
If clalev([F:PIH]) =0 Local File PINVOICE [PIH]  : Endif
Filter [PIH] Where BPR=[M:BPS0]BPSNUM & ORIMOD=6
Look [PIH]PIH1 First
Filter [PIH]
If !fstat : OK = 1 : Endif
#-- Vérification des réceptions
If clalev([F:PTH]) =0 Local File PRECEIPT [PTH]  : Endif
Filter [PTH] Where BPSNUM=[M:BPS0]BPSNUM
Look [PTH]PTH2 First
Filter [PTH]
If !fstat : OK = 1 : Endif
#-- Vérification des commandes
If clalev([F:POH]) =0 Local File PORDER [POH]  : Endif
Filter [POH] Where BPSNUM=[M:BPS0]BPSNUM
Look [POH]POH1 First
Filter [POH]
If !fstat : OK = 1 : Endif
#-- Si OK = 0 l'encours ne vient pas des achats
If OK = 0 : End : Endif
Local Shortint I
If clalev([F:PRS]) =0 Local File PRICSTRUCT [PRS]  : Endif
If clalev([F:PRS2])=0 Local File PRICSTRUCT [PRS2] : Endif
If [F:PRS]BPCBPS<>2 | [F:PRS]PLISTC<>VALEUR
  Read [PRS] PRS0=2;VALEUR : If fstat Raz [F:PRS] : Endif
Endif
Read [PRS2] PRS0=2;[M:BPS1]ANCPLISTC : If fstat Raz [F:PRS2] : Endif
For I=0 To 8
  If [F:PRS2]INCDCR(I)=0 Break : Endif
  If [F:PRS2]INCDCR(I)   <>[F:PRS]INCDCR(I)    |
&    [F:PRS2]VALTYP(I)   <>[F:PRS]VALTYP(I)    |
&    [F:PRS2]CLCRUL(I)   <>[F:PRS]CLCRUL(I)    |
&    [F:PRS2]NPRNOTFLG(I)<>[F:PRS]NPRNOTFLG(I) |
&    [F:PRS2]INVDTA(I)   <>[F:PRS]INVDTA(I)    mkstat=2
                                               GMESSAGE=mess(290,199,1)
                                               Break : Endif
Next I
End

Subprog AS_INVDTA (VALEUR)
Variable Decimal VALEUR
If VALEUR<>0 mkstat=2 Endif
End

Subprog C_INVDTA (VALEUR)
Variable Decimal  VALEUR
Local Integer STAT
Local Integer I
I=find(VALEUR,[M:BPS1]INVDTA(0..[M:BPS1]NBELEMENT-1))
If I <> 0 & I <> nolign
  mkstat    = 2
  GMESSAGE  = mess(102,194,1)
Else
  # VPO 08/04/10 V6.2:60763 Settlements Discounts
  If [F:PFI]DISVATFLG=2
    mkstat   = 2
    GMESSAGE = mess(397,194,1)
    End
  Endif
  Call LECTEXTRA([M:BPS1]SHO(nolign-1),"PFOOTINV","SHOAXX",
&                num$([F:PFI]PFINUM),"") From ATEXTRA
  #----------------------------#
  # voir la valeur par defaut  #
  #----------------------------#
  [M:BPS1]AMTCOD (nolign -1) = [F:PFI]AMTCOD
  If [F:PFI]AMTCOD = 2
    [M:BPS1]WWCUR(nolign-1) = [M:BPRS]CUR
    [M:BPS1]FORMAT (nolign-1) = "NZ:"+[F:TCU]CURFMT1
    GBIDD1 = 0
    Call CONVERT(GSYSCUR,[M:BPRS]CUR,GCUR,[M:BPS4]CHGTYP,datesyst,[F:PFI]DEFVAL,GBIDD1,STAT) From TRTDEV
    [M:BPS1]INVDTAAMT (nolign-1) = GBIDD1
  Else
    [M:BPS1]FORMAT (nolign-1) = "NZ:3.2#[      ]"
    [M:BPS1]INVDTAAMT (nolign-1) = [F:PFI]DEFVAL
  Endif
  Affzo [M:BPS1]SHO (nolign-1)
  Affzo [M:BPS1]INVDTAAMT (nolign-1)
  Affzo [M:BPS1]WWCUR (nolign-1)
Endif
End

Subprog C_INVDTAAMT(VALEUR)
Variable Decimal  VALEUR
If [M:BPS1]AMTCOD (nolign -1) <> 2
           If VALEUR > 100.00
                       mkstat = 2
           Endif
Endif
End

#------------------------------------#
# Contrôle emplacement sous-traitant #
#------------------------------------#
Subprog C_LOC(VALEUR)
Variable Char    VALEUR()
If VALEUR=""  End : Endif
Filter [STC] Where LOC=VALEUR & LOCCAT=4
Look [STC] First
Filter [STC]
If fstat  GMESSAGE=mess(244,192,1) : mkstat=1 : End : Endif
End


# --------------------------------------------------------------------------------
#                                        Ecran BPS2
# --------------------------------------------------------------------------------

Subprog C_BPRPAY(VALEUR)
Variable Char     VALEUR

If find(GREP,"C","D") & [M:BPS0]REFCOU<>"" & VALEUR=""
   End
Endif
#----------------------------------------------#
# en creation il faut controler uniquement     #
# si le tiers payé est <> du fournisseur       #
# Ce tiers doit être fournisseur ou factor     #
#----------------------------------------------#
If VALEUR<>""
    If find(GREP, "C", "D")
          If VALEUR <> [M:BPS0]BPSNUM
              # FGR 11/02/2010 : X3SUIVI45621
              #Call CONTROLE("BPR","A",VALEUR,"",mkstat) From CONTOBJ
              Call CONTROLE("BPR","J",VALEUR,"",mkstat) From CONTOBJ
          Endif
    Else
              # FGR 11/02/2010 : X3SUIVI45621
              #Call CONTROLE("BPR","A",VALEUR,"",mkstat) From CONTOBJ
              Call CONTROLE("BPR","J",VALEUR,"",mkstat) From CONTOBJ
    Endif
    If mkstat=2 End : Endif
Endif
# -------------------------------------------------------- #
# Si le fsseur est inter-site : Ctrl lié à l'inter-société #
# -------------------------------------------------------- #
If GACTFTC=2 & [M:BPRS]BETFCY=2 & [M:BPRS]FCY<>""
    Local Char WBPS:WBPS=VALEUR
    Gosub CTRL_BETCPY
Endif

#If GACTFTC=2 & [M:BPRS]BETFCY=2 & [M:BPRS]FCY<>""
#    # Le fournisseur est inter-site
#    Local Char WFCY
#    If VALEUR <> [M:BPS0]BPSNUM
#        # Le tiers payé doit aussi être inter-site
#        If [F:BPR]BETFCY<>2 | [F:BPR]FCY=""
#            GMESSAGE = mess(408,199,1) : mkstat=2 : End
#        Endif
#        WFCY=[F:BPR]FCY
#    Else
#        WFCY=[M:BPRS]FCY
#    Endif
#    Gosub CTRL_BETCPY
#Endif
End

#--------------------------------#
# Après modif du fourniseur payé #
#--------------------------------#
Subprog AM_BPRPAY(VALEUR)
Variable Char    VALEUR()
Local    Integer I
If VALEUR=[M:BPS0]BPSNUM
  #----- Fournisseur payé = fournisseur commande -----#
  For I=0 To [M:BPAS]NBADR-1
    If [M:BPAS]BPAADDFLG(I)=2
      [M:BPS2]BPAPAY=[M:BPAS]CODADR(I) : Break
    Endif
  Next I
Else
  #----- Fournisseur payé <> fournisseur commande -----#
  If [F:BPR]BPRNUM<>VALEUR
    Read [BPR] BPR0=VALEUR : If fstat Raz [F:BPR] : Endif
  Endif
  [M:BPS2]BPAPAY=[F:BPR]BPAADD
Endif
Affzo [BPS2]BPAPAY
#----- Alimentation du tiers risque si nécessaire -----#
If GREP="C" & GINIBPRRSK=2
  Call AM_BPSRSK(VALEUR) : [M:BPS2]BPSRSK=VALEUR : Affzo [BPS2]BPSRSK
Endif
End

#----------------------------------#
# Init bouton Adr fournisseur payé #
#----------------------------------#
Subprog IB_BPAPAY
If [M:BPS2]BPRPAY=[M:BPS0]BPSNUM
  Raz GBOUTS
Else
  Raz GBOUT1
  If [F:BPR]BPRNUM<>[M:BPS2]BPRPAY
    Read [BPR] BPR0=[M:BPS2]BPRPAY : If fstat  Raz [F:BPR] : Endif
  Endif
Endif
End

#-----------------------------------#
# Avant saisie Adr fournisseur payé #
#-----------------------------------#
Subprog AS_BPAPAY(VALEUR)
Variable Char    VALEUR()
# --- En import : les adresses sont chargees après le fournisseur --> controle impossible
#If GIMPORT
#   If [M:BPS2]BPRPAY=[M:BPS0]BPSNUM & [M:BPAS]CODADR(0)=""  : # si meme fournisseur et pas adresses saisies
#      mkstat=2 : End                                        : # pas de chargement du code adresse
#   Endif
#Endif
If [M:BPAS]CODADR(0)=""
      mkstat=2 : End
Endif
End

#--------------------------------------#
# Contrôle adresse du fournisseur payé #
#--------------------------------------#
Subprog C_BPAPAY(VALEUR)
Variable Char    VALEUR()

If find(GREP,"C","D") & [M:BPS0]REFCOU<>"" & [M:BPS2]BPRPAY=""
   End
Endif

If [M:BPS2]BPRPAY=[M:BPS0]BPSNUM
  #----- Fournisseur payé = fournisseur commande -----#
  If !find(VALEUR,[M:BPAS]CODADR(0..[M:BPAS]NBADR-1))
    GMESSAGE=mess(16,199,1) : mkstat=1
  Endif
Else
  #----- Fournisseur payé <> fournisseur commande -----#
  Look [BPA] BPA0=1;[M:BPS2]BPRPAY;VALEUR
  If fstat  GMESSAGE=mess(16,199,1) : mkstat=1 : Endif
Endif
End


Subprog C_BPSINV(VALEUR)
Variable Char     VALEUR

If find(GREP,"C","D") & [M:BPS0]REFCOU<>"" & VALEUR=""
   End
Endif
#------------------------------------------------#
# controle pas sur objet a cause structure tarif #
#------------------------------------------------#
If VALEUR<>""
    #--- Pas de controle si fournisseur facture = fournisseur
    If VALEUR <> [M:BPS0]BPSNUM
        Read [BPS] BPS0 = VALEUR
        If fstat  GMESSAGE = mess(23,100,1) : mkstat = 2 : End : Endif
        If [F:BPS]ENAFLG <> 2
              GMESSAGE = mess(140,199,1) : mkstat = 2 : End
       #Elsif GACTFTC=2 & [F:BPS]PLISTC<>[M:BPS1]PLISTC
       #      GMESSAGE = mess(141,199,1) : mkstat = 2 : End
        Endif
    Endif
Endif
# -------------------------------------------------------- #
# Si le fsseur est inter-site : Ctrl lié à l'inter-société #
# -------------------------------------------------------- #
If GACTFTC=2 & [M:BPRS]BETFCY=2 & [M:BPRS]FCY<>""
    Local Char WBPS:WBPS=VALEUR
    Gosub CTRL_BETCPY
Endif

#If GACTFTC=2 & [M:BPRS]BETFCY=2 & [M:BPRS]FCY<>""
#    # Le fournisseur est inter-site
#    Local Char WFCY
#    If VALEUR <> [M:BPS0]BPSNUM
#        # Le tiers facturant doit aussi être inter-site
#        If [F:BPR]BPRNUM<>VALEUR
#            Read [BPR] BPR0 = VALEUR
#            If fstat  GMESSAGE = mess(23,100,1) : mkstat = 2 : End : Endif
#        Endif
#        If [F:BPR]BETFCY<>2 | [F:BPR]FCY=""
#            GMESSAGE = mess(408,199,1) : mkstat=2 : End
#        Endif
#        WFCY=[F:BPR]FCY
#    Else
#        WFCY=[M:BPRS]FCY
#    Endif
#    Gosub CTRL_BETCPY
#Endif
End

# ------------------------------ #
# Contrôle lié à l'inter-société #
# ------------------------------ #
# fsseur (côté achat)           => site de vente (côté vente)
# tiers payé et tiers facturant => site financier du site de vente (puisqu'on a pas de site de facturation côté vente)
# Par conséquent :
# tiers payé et tiers facturant sont le fsseur lié au site financier du site de vente
# si le site de vente est financier, tiers payé et tiers facturant est le fsseur lui-même
$CTRL_BETCPY
Local Char WLEGCPY

If clalev([F:FCY]) = 0 : Local File FACILITY [FCY] : Endif
# Lecture du site lié au fsseur
If [F:FCY]FCY<>[M:BPRS]FCY
    Read [FCY]FCY0=[M:BPRS]FCY : If fstat Raz [FCY] Endif
Endif
If [F:FCY]FINFLG=2
    # Le site est financier       : le tiers payé et facturant doit être le fsseur lui-même
    If WBPS<>"" & WBPS<>[M:BPS0]BPSNUM GMESSAGE=mess(463,199,1)-"\"-mess(461,199,1) : mkstat=2 : Return : Endif
Else
    # Le site n'est pas financier : le tiers payé et facturant doit être le fsseur lié au site financier
    If [F:BPR]BPRNUM<>WBPS & WBPS<>""
        Read [BPR]BPR0=WBPS
        If fstat
            Raz [BPR]
        Endif
    Endif
    If WBPS="" | [F:BPR]FCY<>[F:FCY]FINRSPFCY GMESSAGE=mess(463,199,1)-"\"-mess(461,199,1) : mkstat=2 : Return : Endif
Endif
Return

# -------------------------------------------------------- #
# Contrôle concernant fournisseur inter-site               #
# Les sites doivent être sur la même société juridique     #
# Les sites doivent être financiers                        #
# -------------------------------------------------------- #
#$CTRL_BETCPY
#Local Char WLEGCPY

#If clalev([F:FCY]) = 0 : Local File FACILITY [FCY] : Endif
#If [F:FCY]FCY<> WFCY
#    Read [FCY]FCY0=WFCY : If fstat Raz [FCY] Endif
#Endif
##   Le site doit être sur la même société juridique que le site rattaché au fournisseur
#If [F:FCY]LEGCPY<>[M:BPS2]LEGCPY GMESSAGE=mess(409,199,1) : mkstat=2 : Return : Endif
##   Le site doit être financier
#If [F:FCY]FINFLG<>2 GMESSAGE=mess(410,199,1) : mkstat=2 : Return : Endif
#Return

#-------------------------------------#
# Après modif du fourniseur facturant #
#-------------------------------------#
Subprog AM_BPSINV(VALEUR)
Variable Char    VALEUR()
#----- Vérification si structure compatible avec fournisseurs liés -----#
If VALEUR<>[M:BPS0]BPSNUM
  Read [BPS2] BPS0=VALEUR : If fstat  Raz [F:BPS2] : Endif
  If GACTFTC=2 Call VERIF_STRUCTURE(VALEUR,[F:BPS2]PLISTC,[M:BPS0]BPSNUM,[M:BPS1]PLISTC) Endif    : # Issue 106137
  If GERR  mkstat=1 : End : Endif
Endif
#-----
Local    Integer I
If VALEUR=[M:BPS0]BPSNUM
  #----- Fournisseur facturant = fournisseur commande -----#
  For I=0 To [M:BPAS]NBADR-1
    If [M:BPAS]BPAADDFLG(I)=2
      [M:BPS2]BPAINV=[M:BPAS]CODADR(I) : Break
    Endif
  Next I
Else
  #----- Fournisseur facturant <> fournisseur commande -----#
  If [F:BPR]BPRNUM<>VALEUR
    Read [BPR] BPR0=VALEUR : If fstat Raz [F:BPR] : Endif
  Endif
  [M:BPS2]BPAINV=[F:BPR]BPAADD
Endif
Affzo [BPS2]BPAINV
#----- Alimentation du tiers risque si nécessaire -----#
If GREP="C" & !find (GINIBPRRSK,2,3)
  Call AM_BPSRSK(VALEUR) : [M:BPS2]BPSRSK=VALEUR : Affzo [BPS2]BPSRSK
Endif
End


#---------------------------------------#
# Init bouton Adr fournisseur facturant #
#---------------------------------------#
Subprog IB_BPAINV
If [M:BPS2]BPSINV=[M:BPS0]BPSNUM
  Raz GBOUTS
Else
  Raz GBOUT1
  If [F:BPR]BPRNUM<>[M:BPS2]BPSINV
       Read [BPR] BPR0=[M:BPS2]BPSINV : If fstat  Raz [F:BPR] : Endif
  Endif
Endif
End

