# MHB 23/10/08 : ajout Articles-fournisseurs
$CREMOD_ITP

  If dim([M:BPS6]NBITP) > 0 Then
    For  nolign = 1 To [M:BPS6]NBITP
      [F:ITP] = [M:BPS6]
      [F:ITP]ITMREF    = [M:BPS6]ITMREF(nolign-1)
      [F:ITP]BPSNUM    = [M:BPS0]BPSNUM
      # Chargement des zones ayant des codes identiques à celles d'ITM
      [F:ITP]PCU       = [M:BPS6]ITPPCU(nolign-1)
      [F:ITP]PUU       = [M:BPS6]ITPPUU(nolign-1)
      [F:ITP]PCUPUUCOE = [M:BPS6]IPCUPUUCOE(nolign-1)
      [F:ITP]PUUSTUCOE = [M:BPS6]IPUUSTUCOE(nolign-1)
      [F:ITP]QUAFLG    = [M:BPS6]ITPQUAFLG(nolign-1)
      [F:ITP]QLYCRD    = [M:BPS6]ITPQLYCRD(nolign-1)
      [F:ITP]QUAFRY    = [M:BPS6]ITPQUAFRY(nolign-1)
      [F:ITP]QUANUM    = [M:BPS6]ITPQUANUM(nolign-1)
      If [F:ITP]CREUSR  = ""
        [F:ITP]CREUSR    = GUSER
        [F:ITP]CREDAT    = date$
        Raz [F:ITP]UPDUSR
        Raz [F:ITP]UPDDAT
      Endif
      Look [ITP]ITP0=[F:ITP]ITMREF;[F:ITP]BPSNUM
      If fstat
        Write [ITP]
      Else
        Rewrite [ITP]
      Endif
      If fstat
        GOK = 0 : Call FSTA("ITP") From GLOCK : Break
      Endif

      # Création ou mise à jour des textes des articles fournisseur
      If [M:BPS6]TEX(nolign-1)<>""
        Call CRE_CLOB([M:BPS6]TEX(nolign-1),GOK) From TRTX3TEX
        If GOK<1 Break Endif
      Endif
    Next nolign
  Endif
Return

