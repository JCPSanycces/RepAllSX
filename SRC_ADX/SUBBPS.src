# Issue 114621 - 2016-10-10 by MAE : si on vient du tiers, avec une catégorie client renseignée=>affectation de la catégorie
If GNAVIG(max(GPILNAV-1,1)) = "GESBPR" & (GREP = "" | GREP="C") and !GIMPORT Then
  If [M:BPR0]BRGCOD<>"" & [M:BPR0]BRGOBJ="BPS"
    [M:BPS0]BSGCOD = [M:BPR0]BRGCOD
  Endif
Endif
