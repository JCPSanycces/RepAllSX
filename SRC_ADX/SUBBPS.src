#------------------------------------------------------------------#
# Ritenzione (KIB) - Controle de validite du code retenue saisi    #
#------------------------------------------------------------------#
Subprog C_RITCOD(VALEUR)
Variable Char    VALEUR()
NOL=nolign-1
If find(VALEUR,[M:BPS2]RITCOD(0..NOL-1)) | find(VALEUR,[M:BPS2]RITCOD(NOL+1..[M:BPS2]RITNBR-1))
   GMESSAGE=mess(22,131,1) # Code retenue déjà spécifié
   mkstat=2
Endif
End

#------------------------------------------------------------------#
# Ritenzione (KIB) - Tri des codes retenues selon type & categorie #
#------------------------------------------------------------------#
Subprog C_RITNBR

## <PP 13/09/04> Demande 24452
#Local Char TABCOD(30)(1..5) # tableau des codes retenues
#Local Integer TABPRIO(1..5) # tableau des priorites
#Local Integer TABSORT(1..5) # tableau des index de retenues tries
Local Char TABCOD(30)(1..dim([F:BPS]RITCOD)) # tableau des codes retenues
Local Integer TABPRIO(1..dim([F:BPS]RITCOD)) # tableau des priorites
Local Integer TABSORT(1..dim([F:BPS]RITCOD)) # tableau des index de retenues tries
## <Fin PP>

Local Integer I,J,AUX       # variables de boucles

If clalev([F:RTZ])=0 : Local File RITENZIONE [RTZ] : Endif

If status>=65 & status<=90 # On reste dans le tableau
Elsif status<>7 & status<1792

   # INIT DES TABLEAUX DE CODES, PRIORITES, INDEX

   For nolign=1 To [M:BPS2]RITNBR
       TABCOD(nolign)=[M:BPS2]RITCOD(nolign-1) # recopie
       Read [F:RTZ]RTZ0=TABCOD(nolign) # lecture fiche retenue
       TABPRIO(nolign)=[F:RTZ]TYP*10+[F:RTZ]CAT
       TABSORT(nolign)=nolign
   Next nolign

   # TRI DU TABLEAU DES INDEX (TABSORT)

   For J=[M:BPS2]RITNBR To 2 Step -1
       For I=1 To J-1
           If TABPRIO(TABSORT(I))>TABPRIO(TABSORT(I+1)) Then # on swap les indexes
              AUX=TABSORT(I)
              TABSORT(I)=TABSORT(I+1)
              TABSORT(I+1)=AUX
           Endif
       Next I
   Next J

   # REORDONNANCEMENT DU TABLEAU DES CODES RETENUES

   For nolign=1 To [M:BPS2]RITNBR
       [M:BPS2]RITCOD(nolign-1)=TABCOD(TABSORT(nolign))
   Next nolign

   Affzo [M:BPS2]1-99 # refresh du masque

Endif
End

#------------------------------------------------------------------#
# Ritenzione (KIB) - Controle de validite du taux d'abattement     #
#------------------------------------------------------------------#
Subprog C_RITRAT(VALEUR)
Variable Decimal VALEUR
If VALEUR<0 | VALEUR>100
   GMESSAGE=mess(17,131,1) # Taux incorrect
   mkstat=2
Endif
End

#------------------------------------------------------------------#
# Ritenzione (KIB) - On controle que Somme des parts = 100%        #
#------------------------------------------------------------------#
Subprog C_RITPARNBR
Local Integer OK
If status>=65 & status<=90 # On reste dans le tableau
Elsif status<>7 & status<1792
   If [M:BPS2]RITPARNBR>0 & sum([M:BPS2]RITPARCOE(0..[M:BPS2]RITPARNBR-1))<>100.0
      GERR=3 : GMESSAGE=mess(14,117,1)
#     Call AVERTIR (mess(14,117,1),OK) From GESECRAN # somme des pourcentages <> 100
#     If OK<>2 mkstat=1 Endif
   Endif
Endif
End

