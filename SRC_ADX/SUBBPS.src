Subprog C_AUTINVCOD(VALEUR)
Variable Char    VALEUR()

#85785 * RMA
If VALEUR <> ""
  If !clalev([F:BPS2]) : Local File BPSUPPLIER [BPS2] : Endif
  Filter [F:BPS2] Where [F:BPS2]AUTINVCOD = VALEUR & [F:BPS2]BPSNUM <> [M:BPS0]BPSNUM
  Read [F:BPS2] First
  If !fstat
    GMESSAGE = mess(61,127,1) + ":"-[F:BPS2]BPSNUM
    mkstat   = 2
  Endif
  Filter [F:BPS2]
Endif

End
