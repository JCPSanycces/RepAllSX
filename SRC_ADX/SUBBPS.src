Variable Decimal VALEUR

  [M]IPCUPUUCOE([M]XNUMLIG) = VALEUR
  [M:BPS6]XPCUPUUCOE=VALEUR : Affzo [M:BPS6]XPCUSTUCOE
  [M]UPDDAT    ([M]XNUMLIG) = date$
  [M]UPDUSR    ([M]XNUMLIG) = GUSER
