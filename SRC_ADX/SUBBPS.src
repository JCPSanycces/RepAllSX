#######################################################################
############# GOSUB ###################################################
#######################################################################

#########################################################################
$CREBPR

#----------------------------------------------#
# il faut récuperer le code adresse par defaut #
# si on ne trouve pas on recupere la premiere  #
#----------------------------------------------#
Local Shortint I
I = find (2,[M:BPAS]BPAADDFLG (0..[M:BPAS]NBADR -1))
If I <> 0     I -= 1 : Endif
If I < 0      I = 0  : Endif

#----------------------------------------------#
# il faut récuperer le code RIB     par defaut #
# et son code pays                             #
# si on ne trouve pas pas de RIB     par defaut#
#----------------------------------------------#
Local Shortint K
# K = find (2,[M:BIDS]BIDNUMFLG (0..[M:BIDS]NBRIB -1))

#--------------------------------#
# creation enregistrement tiers  #
# ou bien modification           #
#--------------------------------#
Look [BPR]BPR0 = [F:BPS]BPSNUM
If fstat <> 0
     Raz [F:BPR]
     [F:BPR]          = [M:BPRS]
     [F:BPR]BPRNUM    = [F:BPS]BPSNUM
     [F:BPR]BPAADD    = [M:BPAS]CODADR (I)
     [F:BPR]CNTNAM    = [F:BPS]CNTNAM     : # JPGA # Le contact par défaut est maintenant sur la fiche Fournisseur

     #--- Le RIB par défaut du tiers vient maintenant
     #--- du RIB par défaut de l'adresse par défaut du tiers
     #If K <> 0
     #    [F:BPR]BIDNUM    = [M:BIDS]BIDNUM (K-1)
     #    [F:BPR]BIDCRY    = [M:BIDS]BIDCRY (K-1)
     #Else
     #    [F:BPR]BIDNUM    = ""
     #    [F:BPR]BIDCRY    = ""
     #Endif
     #MAE, 14/01/09, bg 51610
     Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
     If !fstat
        [F:BPR]BIDNUM=[F:BPA]BPABID
     Else
        [F:BPR]BIDNUM=""
     Endif

     [F:BPR]BPCFLG    = 1
     If GACTFTC=2 & [F:BPR]BPTFLG = 1 Endif
     If GACTFTC=2 & [F:BPR]REPFLG = 1 Endif
     [F:BPR]FCTFLG    = 1
#-- pas celui de tiers divers
#    [F:BPR]BPRACC    = 1
     For I = 0 To 3
              [F:BPR]BPRFLG (I) = 1
     Next I
#MAE, le 25/11/2008, le tiers est actif par défaut
#     [F:BPR]ENAFLG    = [F:BPS]ENAFLG
     [F:BPR]ENAFLG    = 2
     [F:BPR]BPSFLG    = 2
     [F:BPR]CREDAT    = date$
     [F:BPR]CREUSR    = GUSER
     [F:BPR]BRGCOD    = [F:BPS]BSGCOD
     [F:BPR]BRGOBJ    = "BPS"

     Write [BPR]
     If fstat
            GOK = 0 : Call FSTA("BPR") From GLOCK
     Endif
Else
     Readlock [BPR]BPR0 = [F:BPS]BPSNUM
     If fstat = 1
         GOK=-1 : GLOCK = "$BPARTNER"-[F:BPS]BPSNUM
         Call ROLL From GLOCK : Return
     Endif
     Local Char WSAV_CUR(GLONCUR)
     [L]WSAV_CUR   = [F:BPR]CUR        : # Sauvegarde devise tiers
     [F:BPR]       = [M:BPRS]
     [F:BPR]CUR    = [L]WSAV_CUR       : # Restitution devise tiers
     [F:BPR]BPRNUM = [F:BPS]BPSNUM
     #[F:BPR]BPAADD = [M:BPAS]CODADR(I) : # Plus de màj pour le tiers

     # Plus de MAJ de [F:BPR]CNTNAM car maintenant sur la fiche fournisseur

     #--- Le RIB par défaut du tiers vient maintenant
     #--- du RIB par défaut de l'adresse par défaut du tiers
     #If K <> 0
     #    [F:BPR]BIDNUM    = [M:BIDS]BIDNUM (K-1)
     #    [F:BPR]BIDCRY    = [M:BIDS]BIDCRY (K-1)
     #Else
     #    [F:BPR]BIDNUM    = ""
     #    [F:BPR]BIDCRY    = ""
     #Endif
     #MAE, bug 101075, réécriture du rib si il a été modifié

    # X3-107151 (LCC 07/09/18) CNTNAM is not ok in the bpartner's table
    Local Shortint K: K=0
    If [M:CNTS]NBCNT>0
      K = find ([F:BPR]CNTNAM,[M:CNTS]CCNCRM (0..[M:CNTS]NBCNT-1))
    Endif
    ## If the CNTNAM field is an existing contact there is nothing to do
    If K=0
      [F:BPR]CNTNAM    = [F:BPS]CNTNAM
    Endif
    # We check the default contact in Customers Table
    ###
    If [F:BPR]BPCFLG=2 or [F:BPR]PPTFLG=2
      If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
      Readlock [F:BPC]BPC0=[F:BPS]BPSNUM
      If !fstat
        K=0
        If [M:CNTS]NBCNT>0
          K = find ([F:BPC]CNTNAM,[M:CNTS]CCNCRM (0..[M:CNTS]NBCNT-1))
        Endif
      ## If the CNTNAM field is an existing contact there is nothing to do
        If K=0
          [F:BPC]CNTNAM    = [F:BPS]CNTNAM
          Rewrite [F:BPC]
          If fstat GOK=0 : Call FSTA("BPC") From GLOCK : Endif
        Endif
      Endif
    Endif
    ###
    # We check the default contact in Carriers Table
    ###
    If [F:BPR]BPTFLG=2
      If clalev([F:BPT])=0 : Local File BPCARRIER[BPT] : Endif
      Readlock [F:BPT]BPT0=[F:BPS]BPSNUM
      If !fstat
        K=0
        If [M:CNTS]NBCNT>0
          K = find ([F:BPT]CNTNAM,[M:CNTS]CCNCRM (0..[M:CNTS]NBCNT-1))
        Endif
      ## If the CNTNAM field is an existing contact there is nothing to do
        If K=0
          [F:BPT]CNTNAM    = [F:BPS]CNTNAM
          Rewrite [F:BPT]
          If fstat GOK=0 : Call FSTA("BPT") From GLOCK : Endif
        Endif
      Endif
    Endif
    # END X3-107151 (LCC 07/09/18) CNTNAM is not ok in the bpartner's table

     Read [BPA]BPA0=1;[F:BPR]BPRNUM;[F:BPR]BPAADD
     If !fstat
        [F:BPR]BIDNUM=[F:BPA]BPABID
     Else
        [F:BPR]BIDNUM=""
     Endif
     [F:BPR]BPSFLG = 2
     [F:BPR]UPDDAT = date$
     [F:BPR]UPDUSR = GUSER
     Rewrite [BPR]
     #--- pas de test du fstat c est volontaire ----#
Endif

Return

########################################################################
$CREBPA

#-------------------------#
# creation des adresses   #
#-------------------------#

#-------------------------#
#    A SUPPRIMER          #
#-------------------------#
#    Call CREBPA_CPYFCY (GABREV,[M:BPS0]BPSNUM,1) From TRTADR
#-------------------------------------------------------------#
# GOK = 1  Transaction OK                                     #
# GOK = -1 Enregistrement verrouillé on recommence trois fois)#
# GOK = 0  Transaction abandonnée                             #
#-------------------------------------------------------------#
#    If GOK < 1 : Return : Endif
#-------------------------#

Default Mask [BPAS]
Call CREBPA(WBPATYP,[M:BPS0]BPSNUM) From TRTBPA
If GOK < 1 : Return : Endif

Return

########################################################################
$CRECNT

#-------------------------#
# creation des contacts   #
#-------------------------#

#-------------------------#
#    A SUPPRIMER          #
#-------------------------#
#    Call CRECNT_CPYFCY (GABREV,[M:BPS0]BPSNUM,1) From TRTADR
#    If GOK < 1 : Return : Endif
#-------------------------#

Default Mask [CNTS]
Call CRECNT(WBPATYP,[M:BPS0]BPSNUM) From TRTBPA
If GOK < 1 : Return : Endif
  Call MAJ_CNTNAM("[F:BPS]") From SUBBPR  # FGR 10/01/2013 X3SUIVI83886
Return

########################################################################
$CRERIB

#-------------------------#
# creation des RIB        #
#-------------------------#

#-------------------------#
#    A SUPPRIMER          #
#-------------------------#
#    Call CRERIB_CPYFCY ([M:BPS0]BPSNUM,1) From TRTADR
#    If GOK < 1 : RETURN: Endif
#-------------------------#

Default Mask [BIDS]
Call CRERIB(WBPATYP,[M:BPS0]BPSNUM) From TRTBPA
If GOK < 1 : Return : Endif

Return

########################################################################
$CREBPS
#If [M:BPS2]BPSINV="" : [F:BPS]BPSINV = [F:BPS]BPSNUM : Endif
#If [M:BPS2]BPRPAY="" : [F:BPS]BPRPAY = [F:BPS]BPSNUM : Endif
#-------------------------------------#
# chargement des elements facturation #
#-------------------------------------#
Raz [F:BPS]INVDTA
Raz [F:BPS]INVDTAAMT
Raz [F:BPS]AMTCOD

If GACTFTC=2
   For I = 0 To dim([F:BPS]INVDTA)-1
      If [M:BPS1]INVDTA (I) <> 0
         [F:BPS]INVDTA (I)    = [M:BPS1]INVDTA (I)
         [F:BPS]INVDTAAMT (I) = [M:BPS1]INVDTAAMT (I)
         [F:BPS]AMTCOD (I)    = [M:BPS1]AMTCOD (I)
      Endif
   Next I
Endif

#---------------------------------------------------#
# il faut récuperer le nom et intitulé court du BPR #
# et reconvertir les montants en devise dossier     #
#---------------------------------------------------#
[F:BPS]BPSNAM    = [M:BPRS]BPRNAM(0)
[F:BPS]BPSSHO    = [M:BPRS]BPRSHO

Local Decimal WMONTORG (0..2)  # 106430.c - Was 0..1
Local Decimal WMONTDES (0..2)  # 106430.c - Was 0..1
If GACTFTC=2
   WMONTORG(0) = [M:BPS1]WORDMINAMT
   WMONTORG(2) = [M:BPS1]WORDFREFRT		# 106430.n
Endif
WMONTORG(1) = [M:BPS4]WOSTAUZAMT

#-- on avait un problème suite à la double conversion
#-- exemple si on saisit un montant de 50 FRF --> conversion EUR
#-- ensuite reconversion en FRF dans liens pour reaffichage --> 50.03 FRF
#-- solution aucun arrondi mais uniquement à la fin arrondi pour affichage
#-- le stockage est fait avec toute la précision

Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMONTORG (0),WMONTDES (0),SPSTAT) From TRTDEV
Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMONTORG (1),WMONTDES (1),SPSTAT) From TRTDEV
Call CONVERT2(GCUR,GSYSCUR,GCUR,GCHGTYP,datesyst,WMONTORG (2),WMONTDES (2),SPSTAT) From TRTDEV # 106430.n

If SPSTAT = 0
   If GACTFTC=2
     [F:BPS]ORDMINAMT=WMONTDES(0)
     [F:BPS]ORDFREFRT=WMONTDES(2)  # 106430.n
   Endif
   [F:BPS]OSTAUZAMT=WMONTDES(1)
Else
   If GACTFTC=2
     [F:BPS]ORDMINAMT=[M:BPS1]WORDMINAMT
     [F:BPS]ORDFREFRT=[M:BPS1]WORDFREFRT  # 106430.n
   Endif
   [F:BPS]OSTAUZAMT=[M:BPS4]WOSTAUZAMT
Endif

# JPGA # Alimentation du Contact par défaut CNTNAM dans F:BPS (pour $INIMOD et $INICRE)
Local Shortint WI
If [M:CNTS]NBCNT >0
    WI = find (2,[M:CNTS]CNTFLG (0..[M:CNTS]NBCNT -1))
    If WI <> 0
        [F:BPS]CNTNAM  = [M:CNTS]CCNCRM (WI-1)
    Else
        [F:BPS]CNTNAM   =[M:CNTS]CCNCRM (0)
    Endif
Else
    [F:BPS]CNTNAM   =""
Endif

#MAE, bg 56792
If GIMPORT
    If [M:BPS2]BPAPAY = ""
    #----- Fournisseur facturant = fournisseur commande -----#
                    For I=0 To [M:BPAS]NBADR-1
                    If [M:BPAS]BPAADDFLG(I)=2
                      [M:BPS2]BPAPAY=[M:BPAS]CODADR(I) : [F:BPS] BPAPAY = [M:BPS2]BPAPAY : Break
                    Endif
                    Next I
    Endif
    If [M:BPS2]BPAINV = ""
    #----- Fournisseur facturant = fournisseur commande -----#
                    For I=0 To [M:BPAS]NBADR-1
                    If [M:BPAS]BPAADDFLG(I)=2
                      [M:BPS2]BPAINV=[M:BPAS]CODADR(I) : [F:BPS]BPAINV = [M:BPS2]BPAINV : Break
                    Endif
                    Next I
    Endif
Endif

Return


