#<AdxTL>@(#)0.0.0.0 $Revision$Class Degrees
# Supervisor
## CRUD-CLASSE ## EMPLOEXM
# 2018-11-06 07:06:13 626


############################################################################################
### Subprog _ADELETE
############################################################################################
Subprog _ADELETE(EMPLOEXM,ASTATUS)
Variable Instance EMPLOEXM Using C_EMPLOEXM
Variable Integer ASTATUS

If EMPLOEXM = null : End : Endif

Gosub _AVARIABLES From WMC00EMPLOEXM

[L]A_STRSITE = ""
[L]A_STRACC = ""
Local Instance ALNKDELTAB Using C_ALNKDELTAB
Gosub ADELETE_EMPLOEXM

End

############################################################################################
### Subprog ADELETE
############################################################################################
Subprog ADELETE(EMPLOEXM,ASTATUS)
Variable Instance EMPLOEXM Using C_EMPLOEXM
Variable Integer ASTATUS

If EMPLOEXM = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOEXM
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

Local Instance ALNKDELTAB Using C_ALNKDELTAB

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub ADELETE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

If !adxlog
 Gosub ADELETE_TR_EMPLOEXM
Else
 Gosub ADELETE_EMPLOEXM
Endif

$ADELETE_END
End


$ADELETE_CONTROL
Gosub _ADELETE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Verification delete
[L]ASTATUS = max([L]ASTATUS,func ASYRSUB.VERIFY_INSTANCE(EMPLOEXM,ALNKDELTAB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _ADELETE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_BEFORE
If EMPLOEXM.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EMPLOEXM.ASTALIN = [V]CST_ADEL
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOEXM.ACTION("ADELETE_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_AFTER

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOEXM.ACTION("ADELETE_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_TR_EMPLOEXM
Trbegin [F:HREXM]
 Gosub ADELETE_EMPLOEXM
 If [L]ASTATUS>=[V]CST_AERROR : Gosub ADELETE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$ADELETE_EMPLOEXM
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOEXM.ACTION("ADELETE_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = func ASYRSUB.DELETE_LINKS(EMPLOEXM,ALNKDELTAB)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EMPLOEXM._MAJSQL_EMPLOEXM(EMPLOEXM))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOEXM.ACTION("ADELETE_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_ABORT
Rollback
$_ADELETE_ABORT
If EMPLOEXM.snapshotEnabled=1
 [L]A_RETIK = EMPLOEXM.revertUpdTick
Endif
[L]ASTATUS = max(fmet EMPLOEXM.ACTION("ADELETE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#

#-----------------------------------------------------#
$_ADELETE_AFTER
Return



