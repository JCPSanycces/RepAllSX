#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Program Name: VXARI
# Description : ADC Receiving Inquiry
# Author      : NA Development
# Date        : September 8th, 2017
# Type        : NA Core
######################################################################################

#- Handle the various actions we use in this script
$ACTION
   Case ACTION
       When "DEBUT"        : Gosub DEBUT
       When "OUVRE"        : Gosub OUVRE
       When "SETBOUT"      : Gosub SETBOUT
       When "BOUTON"       : Gosub BOUTON
       When "APRES_MODIF"  : Gosub APRES_MODIF
       When "FIN"          : Gosub FIN
   Endcase
Return

######################################################################################

$DEBUT
# Verify the ADC site is set
   If GXAFCY = "" : Call ERREUR(mess(16,7750,1)) From GESECRAN : FIN = 2 : Return : Endif

#- Clear & Refresh the screen (this also displays the Current ADC Site)
   Raz [M:ARI]
   Affzo [M:ARI]
Return

######################################################################################

$OUVRE
#- Define variables used throughout the code
   Local Char LORDNUM(20)
   Local Integer LORDLIN
   Local Char TBL(3)
   Local Char NITMREF(20)
   Global Date TMPDAT

#- Open all the files we'll need
   If !clalev([F:ITM]) : Local File ITMMASTER  [ITM] : Endif
   If !clalev([F:POH]) : Local File PORDER     [POH] : Endif
   If !clalev([F:POQ]) : Local File PORDERQ    [POQ] : Endif
   If !clalev([F:SDD]) : Local File SDELIVERYD [SDD] : Endif
   If !clalev([F:SDH]) : Local File SDELIVERY  [SDH] : Endif

   GVTMOD = 1
   TMPDAT = date$

#- Initalize Stock Site
   Gosub INIT_STOFCY From ENVADC
Return

######################################################################################

#- Enable or disable buttons based on the internal settings
$SETBOUT
   Local Shortint IND

#- See if we need to activate "Page +" or not
   IND = 0

#- If we haven't displayed a full grid; disable the Page+ option, otherwise activate it
   If [M:ARI]NBLIG >= dim([M:ARI]ITMREF)
      If TBL = "POQ"
         Link [F:POQ] With [F:POH]POH0~=[F:POQ]POHNUM
&                       As [ORDS]
&                    Where (([F:POQ]POHNUM = LORDNUM and [F:POQ]POPLIN > LORDLIN) or
&                            [F:POQ]POHNUM > LORDNUM)
&                      and ([M:ARI]FITMREF = "" or ([M:ARI]FITMREF <> "" and [F:POQ]ITMREF = [M:ARI]FITMREF))
&                      and ([M:ARI]FRECDAT = [0/0/0] or ([M:ARI]FRECDAT <> [0/0/0] and [F:POQ]EXTRCPDAT <= [M:ARI]FRECDAT))
&                      and [F:POH]APPFLG > 2
&                      and [F:POQ]PRHFCY = GXAFCY
&                      and [F:POQ]WIPSTA < 2
&                      and [F:POQ]ORI <> 2
&                      and [F:POQ]LINTYP < 3
&                      and [F:POQ]LINSTA <> 3
&                      and [F:POQ]LINCLEFLG = 1
&                      and (([F:POQ]QTYPUU > [F:POQ]RCPQTYPUU) or ([F:POQ]QTYSTU > [F:POQ]RCPQTYSTU)
&                           or (GRCPORD <> 1 and [F:ITM]SCSFLG <> 2))
         Read [ORDS] First
         If fstat = 0
            IND = 1
         Endif
      Endif

      If IND = 0
         Link [F:SDD] With [F:SDH]SDH0~=[F:SDD]SDHNUM
&                       As [ORDS]
&                    Where (([F:SDD]SOHNUM = LORDNUM and [F:SDD]SOPLIN > LORDLIN) or
&                            [F:SDD]SOHNUM > LORDNUM)
&                      and ([M:ARI]FITMREF = "" or ([M:ARI]FITMREF <> "" and [F:SDD]ITMREF = [M:ARI]FITMREF))
&                      and ([M:ARI]FRECDAT = [0/0/0] or ([M:ARI]FRECDAT <> [0/0/0] and [F:SDD]SHIDAT <= [M:ARI]FRECDAT))
&                      and [F:SDD]RCPFLG <> 2
&                      and [F:SDD]LINTYP < 11
&                      and [F:SDH]CFMFLG = 2
&                      and [F:SDH]PRHFCY = GXAFCY
&                      and [F:SDH]LND <> 2
&                      and ([F:SDD]QTYSTU - [F:SDD]RTNQTYSTU - [F:SDD]RCPQTYSTU > 0
&                            or (GRCPORD <> 1 and [F:ITM]SCSFLG <> 2))
         Read [ORDS] First
         If fstat = 0
            IND = 1
         Endif
      Endif
   Endif

   If IND = 0
      Call VIREBOUT(CHMEN, '1') From GOBJET
   Else
      CHMEN += '1'
   Endif

#- Now see if we need to activate the "Product +" button
   IND = 0

   If [M:ARI]FITMREF <> ""
      Link [F:POQ] With [F:POH]POH0~=[F:POQ]POHNUM
&                    As [ORDS]
&                 Where [F:POQ]ITMREF > [M:ARI]FITMREF
&                   and ([M:ARI]FRECDAT = [0/0/0] or ([M:ARI]FRECDAT <> [0/0/0] and [F:POQ]EXTRCPDAT <= [M:ARI]FRECDAT))
&                   and [F:POH]APPFLG > 2
&                   and [F:POQ]PRHFCY = GXAFCY
&                   and [F:POQ]WIPSTA < 2
&                   and [F:POQ]ORI <> 2
&                   and [F:POQ]LINTYP < 3
&                   and [F:POQ]LINSTA <> 3
&                   and [F:POQ]LINCLEFLG = 1
&                   and (([F:POQ]QTYPUU > [F:POQ]RCPQTYPUU) or ([F:POQ]QTYSTU > [F:POQ]RCPQTYSTU)
&                        or (GRCPORD <> 1 and [F:ITM]SCSFLG <> 2))
&                 Order By [F:POQ]ITMREF                          #X3-60309.n
      Read [ORDS] First
      If fstat = 0
         IND = 1
         NITMREF = [F:POQ]ITMREF
      Endif

      If IND = 0
         Link [F:SDD] With [F:SDH]SDH0~=[F:SDD]SDHNUM
&                    As [ORDS]
&                 Where [F:SDD]ITMREF > [M:ARI]FITMREF
&                   and ([M:ARI]FRECDAT = [0/0/0] or ([M:ARI]FRECDAT <> [0/0/0] and [F:SDD]SHIDAT <= [M:ARI]FRECDAT))
&                   and [F:SDD]RCPFLG <> 2
&                   and [F:SDD]LINTYP < 11
&                   and [F:SDH]CFMFLG = 2
&                   and [F:SDH]PRHFCY = GXAFCY
&                   and [F:SDH]LND <> 2
&                   and ([F:SDD]QTYSTU - [F:SDD]RTNQTYSTU - [F:SDD]RCPQTYSTU > 0
&                         or (GRCPORD <> 1 and [F:ITM]SCSFLG <> 2))
&                 Order By [F:SDD]ITMREF                          #X3-60309.n
         Read [ORDS] First
         If fstat = 0
            IND = 1
            NITMREF = [F:SDD]ITMREF
         Endif
      Endif
   Endif

   If IND = 0
      Call VIREBOUT(CHMEN, '2') From GOBJET
   Else
      CHMEN += '2'
   Endif
Return

######################################################################################

#- Process the button pressed by the user
$BOUTON
   If BOUT = "1" : Gosub LOAD_PAGE : Endif
   If BOUT = "2" : LORDNUM = "" : LORDLIN = 0 : TBL = "POQ" : [M:ARI]FITMREF = NITMREF : Gosub LOAD_PAGE : Endif
Return

######################################################################################

Subprog AV_FITMREF(VALEUR)
   Variable Char VALEUR()

   If TMPDAT <> [0/0/0]
      [M:ARI]FRECDAT = TMPDAT
      Affzo [M:ARI]FRECDAT
   Endif
End

######################################################################################

Subprog AS_FRECDAT(VALEUR)
   Variable Date VALEUR()

   If [M:ARI]FITMREF = ""
      Call ERREUR(mess(45,7750,1)) From GESECRAN
      mkstat = 1
      zonsui = "[M:ARI]FITMREF"
   Endif
End

######################################################################################

$APRES_MODIF
   Raz LORDNUM, LORDLIN, [M:ARI]NBLIG, nolign

   Case COUZON
      When "FITMREF"
         [M:ARI]FITMREF = CZ

      When "FRECDAT"
         [M:ARI]FRECDAT = CZ
         TMPDAT = CZ
   Endcase

   Raz [M:ARI]NBLIG
   Affzo [M:ARI]NBLIG

   If [M:ARI]FITMREF <> ""
      Raz LORDNUM, LORDLIN
      TBL = "POQ"
      Gosub LOAD_PAGE
   Endif
Return

######################################################################################

#- Fill the grid - from the POQ table first; then then the delivery tables if not full
$LOAD_PAGE
   Raz [M:ARI]NBLIG, nolign

#- If we are checking POQ' check for any Purchase Order data meeting the requirements
   If TBL = "POQ"
      Link [F:POQ] With [F:POH]POH0~=[F:POQ]POHNUM
&                    As [ORDS]
&                 Where (([F:POQ]POHNUM = LORDNUM and [F:POQ]POPLIN > LORDLIN) or
&                         [F:POQ]POHNUM > LORDNUM)
&                   and ([M:ARI]FITMREF = "" or ([M:ARI]FITMREF <> "" and [F:POQ]ITMREF = [M:ARI]FITMREF))
&                   and ([M:ARI]FRECDAT = [0/0/0] or ([M:ARI]FRECDAT <> [0/0/0] and [F:POQ]EXTRCPDAT <= [M:ARI]FRECDAT))
&                   and [F:POH]APPFLG > 2
&                   and [F:POQ]PRHFCY = GXAFCY
&                   and [F:POQ]WIPSTA < 2
&                   and [F:POQ]ORI <> 2
&                   and [F:POQ]LINTYP < 3
&                   and [F:POQ]LINSTA <> 3
&                   and [F:POQ]LINCLEFLG = 1
&                   and (([F:POQ]QTYPUU > [F:POQ]RCPQTYPUU) or ([F:POQ]QTYSTU > [F:POQ]RCPQTYSTU)
&                        or (GRCPORD <> 1 and [F:ITM]SCSFLG <> 2))

      For [ORDS]
         If nolign < dim([M:ARI]ITMREF)
            [M:ARI]ITMREF(nolign) = [F:POQ]ITMREF
            [M:ARI]VCRNUM(nolign) = [F:POQ]POHNUM
            [M:ARI]VCRLIN(nolign) = [F:POQ]POPLIN
            [M:ARI]RECDAT(nolign) = [F:POQ]EXTRCPDAT
            [M:ARI]QTYSTU(nolign) = [F:POQ]QTYSTU
            [M:ARI]REMQTY(nolign) = [F:POQ]QTYSTU - [F:POQ]RCPQTYSTU
            [M:ARI]STU(nolign)    = [F:POQ]STU
            [M:ARI]BPRNUM(nolign) = [F:POQ]BPSNUM
            [M:ARI]NBLIG+=1
            nolign+=1
            LORDNUM = [F:POQ]POHNUM
            LORDLIN = [F:POQ]POPLIN
          Else
            Break
         Endif
      Next

#- Switch to Delivery table if we can't fill the grid
      If nolign < dim([M:ARI]ITMREF)
         TBL = "SDD"
         Raz LORDNUM, LORDLIN
      Endif
   Endif

#- If we are checking the delivery tables; go see if there is any data meeting the requirements
   If TBL = "SDD"
      Link [F:SDD] With [F:SDH]SDH0~=[F:SDD]SDHNUM
&                    As [ORDS]
&                 Where (([SDD]SDHNUM = LORDNUM and [SDD]SDDLIN > LORDLIN) or
&                         [SDD]SDHNUM > LORDNUM)
&                   and ([M:ARI]FITMREF = "" or ([M:ARI]FITMREF <> "" and [F:SDD]ITMREF = [M:ARI]FITMREF))
&                   and ([M:ARI]FRECDAT = [0/0/0] or ([M:ARI]FRECDAT <> [0/0/0] and [F:SDD]SHIDAT <= [M:ARI]FRECDAT))
&                   and [F:SDD]RCPFLG <> 2
&                   and [F:SDD]LINTYP < 11
&                   and [F:SDH]CFMFLG = 2
&                   and [F:SDH]PRHFCY = GXAFCY
&                   and [F:SDH]LND <> 2
&                   and ([F:SDD]QTYSTU - [F:SDD]RTNQTYSTU - [F:SDD]RCPQTYSTU > 0
&                         or (GRCPORD <> 1 and [F:ITM]SCSFLG <> 2))

      For [ORDS]
         If nolign < dim([M:ARI]ITMREF)
            [M:ARI]ITMREF(nolign) = [F:SDD]ITMREF
            [M:ARI]VCRNUM(nolign) = [F:SDD]SDHNUM
            [M:ARI]VCRLIN(nolign) = [F:SDD]SDDLIN
            [M:ARI]RECDAT(nolign) = [F:SDD]SHIDAT
            [M:ARI]QTYSTU(nolign) = [F:SDD]QTYSTU
            [M:ARI]REMQTY(nolign) = [F:SDD]QTYSTU-[F:SDD]RTNQTYSTU-[F:SDD]RCPQTYSTU
            [M:ARI]STU(nolign)    = [F:SDD]STU
            [M:ARI]BPRNUM(nolign) = [F:SDH]BPCORD
            [M:ARI]NBLIG+=1
            nolign+=1
            LORDNUM = [F:SDD]SDHNUM
            LORDLIN = [F:SDD]SDDLIN
         Else
            Break
         Endif
      Next
   Endif

   Affzo[M:ARI]
Return

######################################################################################

$FIN
   Kill TMPDAT

   GVTMOD = 0

   If clalev([F:ITM]) : Close Local File [F:ITM] : Endif
   If clalev([F:POH]) : Close Local File [F:POH] : Endif
   If clalev([F:POQ]) : Close Local File [F:POQ] : Endif
   If clalev([F:SDD]) : Close Local File [F:SDD] : Endif
   If clalev([F:SDH]) : Close Local File [F:SDH] : Endif
Return

######################################################################################

