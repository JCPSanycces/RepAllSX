#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog AM_FICHIER(VALEUR)
Variable Char VALEUR()
[M]NBLIG = 0
End

$CHARGE_ZON
If [M]NBLIG=0
 nolign = 0
 For [ATZ]NUMLIG Where CODFIC=[M]FICHIER
  nolign += 1
  [M] = [F:ATZ]
  Call TEXTE([F:ATZ]NOCOURT,[M]INTITCOURT(nolign-1)) From OBJDIV
  If find([F:ATZ]CODFIC+[F:ATZ]CODZONE,[M:AOE2]CTL(0..[M:AOE2]NBRLIG-1))
   [M]SELECT(nolign-1) = 1
  Else
   [M]SELECT(nolign-1) = 2
  Endif
 Next
 [M]NBLIG = nolign
 Affzo 10
Endif
Return

Subprog AV_NBLIG
GBOUT2 = mess(2,1,1) : # Oui
GBOUT3 = mess(1,1,1) : # Non
If [M]NBLIG=0
 Gosub CHARGE_ZON
Endif
End

Subprog B2_NBLIG
Local Integer I
For I=1 To [M]NBLIG
 [M]SELECT(I-1) = 2
Next I
Affzo 10
End

Subprog B3_NBLIG
Local Integer I
For I=1 To [M]NBLIG
 [M]SELECT(I-1) = 1
Next I
Affzo 10
End

