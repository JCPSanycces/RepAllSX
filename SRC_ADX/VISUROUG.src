## LBOMALT : alternative de nomenclature
## VALFLG : flag indicateur de validité de la nomenclature. Si VALFGL=1, nomenclature non valide; VALFGL=0,valide
#Value    Date    LDAT
#Value    Char    LITMREF
#Value    Integer LBOMALT
#Value    Integer LBOMALTTYP
#Variable Integer VALFLG
#
#If LDAT=[0/0/0] : VALFLG=0 : End : Endif
#
#Read [BOH1]BOH0 =LITMREF;LBOMALT;LBOMALTTYP
#If ([F:BOH1]BOHSTRDAT<>[0/0/0] & LDAT < [F:BOH1]BOHSTRDAT)
#& |([F:BOH1]BOHENDDAT<>[0/0/0] & LDAT > [F:BOH1]BOHENDDAT)
#    VALFLG = 1
#    GMESSAGE = LITMREF+"/"+num$(LBOMALT)+"/"+num$(LBOMALTTYP)-":"-mess(54,199,1)
#Endif
#
#End

##################################################################
# lecture fichiers
$LEC_FILES

# lecture entete nomenclature
Read [BOH1]BOH0=LITM;LBOMALT;LBOMALTTYP
If fstat : Raz [F:BOH1] : Endif

Return


Subprog GEN_LISTE_RECETTE (L, LEVEL, LIGNE, PLIGNE, LDAT, LITM , LBOMALT, LBOMALTTYP, WFCY,WROU,WROUALT)
Variable Integer L
Variable Integer LEVEL
Variable Integer LIGNE
Variable Integer PLIGNE
Value    Date    LDAT
Value    Char    LITM
Value    Integer LBOMALT
Value    Integer LBOMALTTYP
Value    Char    WFCY
Variable Char    WROU
Variable Integer WROUALT

Local    Integer WMEMPL, WMEMPL2, WMEMPL3
Local Char    LSAV_ROU(GLONITM),LSAV_ROU2(GLONITM)
Local Integer LSAV_ROUALT,LSAV_ROUALT2

  # lecture entête
  Gosub LEC_FILES
  #If [F:ITM]PHAFLG <> 2
    LEVEL  += 1
    PLIGNE = LIGNE
  #Endif
  # selection des articles valides
  If LDAT =[0/0/0]
    Local File BOMD[BOD1] Where ITMREF=LITM & BOMALT=LBOMALT & BOMALTTYP = LBOMALTTYP & CPNTYP<>4
  Else
    Local File BOMD[BOD1] Where ITMREF=LITM & BOMALT=LBOMALT & BOMALTTYP = LBOMALTTYP & CPNTYP<>4 &
&                               (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <> [0/0/0] & BOMSTRDAT <= LDAT)) &
&                               (BOMENDDAT = [0/0/0] | (BOMENDDAT <> [0/0/0] & BOMENDDAT >= LDAT))
  Endif
  # FQ60780 - MABON 10/12/09 - Il peut y avoir des articles avec une nomenclature sans Composants, mais avec des opérations de gammes
  If rowcount([F:BOD1])>0
  # Fin MABON
    # lecture premier enregistrement
    Read [BOD1]BOD0 First
    While !fstat
      # GH 07/02/2014 cnd remonté dans le local file BOMD
      # Si on est sur un composé de type sous produit on ne l'affiche pas
      #If [F:BOD1]CPNTYP=4
      #  WROU ="" : WROUALT=0
      #  Goto NEXT_BOD
      #Endif
      # lecture article
      If [F:ITM]ITMREF <> [F:BOD1]CPNITMREF
        Read [ITM]ITM0=[F:BOD1]CPNITMREF
        If fstat : Raz [F:ITM] : Endif
      Endif
      If [F:ITF]ITMREF <> [F:BOD1]CPNITMREF | [F:ITF]STOFCY <> WFCY
        Read [ITF]ITF0=[F:BOD1]CPNITMREF;WFCY
        If fstat : Raz [F:ITF] : Endif
      Endif
      # si on a la nomenclature du pére on l'affiche
      If GROUFLG
        Gosub ADD_LINE_OP
        GROUFLG = 0
        WROU ="" : WROUALT=0
      Endif
      # On n'affiche pas sa gamme non plus
      LSAV_ROU = WROU
      LSAV_ROUALT=WROUALT
      If !GROUFLG # si l'on a pas une gamme en cours pour le composé
        WROU ="" : WROUALT=0
        If [F:ITM]MFGFLG = 2   # Article fabriqué
          Call SEARCH_ROU([F:BOD1]CPNITMREF,WFCY,[M:VROG]ROUALT,LDAT,WROU,WROUALT)
          If WROU<>"" & WROUALT<>0
            # GH 07/02/2014 controle de validité de gamme inclus dans la recherche de gamme
            # Gamme du sous-produit valide ?
            # Read [ROH1]ROH1 = WFCY;WROU;WROUALT
            # If fstat
            #  Gosub NEXT_ITM
            #Else
              GROUFLG = 1
            # # Controle de validité de l'entête de gamme du sous-produit
            #  If ([F:ROH1]ROUSTRDAT = [0/0/0] | ([F:ROH1]ROUSTRDAT<> [0/0/0] & [F:ROH1]ROUSTRDAT <=LDAT ))&
            #   & ([F:ROH1]ROUENDDAT = [0/0/0] | ([F:ROH1]ROUENDDAT<> [0/0/0] & [F:ROH1]ROUENDDAT>= LDAT))
            #    GROUFLG = 1
            #  Else
            #    GMESSAGE =[F:BOD1]CPNITMREF+"/"+num$(WROUALT)-":"-mess(8,193,1)
            #    GERR = 2
            #    Goto NEXT_BOD
            #  Endif
            #Endif
          Else
            # Nomenclature du sous-produit valide ?
            Read [BOH1]BOH0 =[F:BOD1]CPNITMREF;LBOMALT;2
            If  LDAT <>[0/0/0]
              If ([F:BOH1]BOHSTRDAT <> [0/0/0] & LDAT < [F:BOH1]BOHSTRDAT)
&               |([F:BOH1]BOHENDDAT <> [0/0/0] & LDAT > [F:BOH1]BOHENDDAT)
                Goto NEXT_BOD
              Endif
            Endif
          Endif
        Elsif [F:ITM]SCPFLG = 2   # Article sous-traité
            # Nomenclature du sous-produit valide ?
            Read [BOH1]BOH0 =[F:BOD1]CPNITMREF;LBOMALT;3
            If LDAT <>[0/0/0]
              If ([F:BOH1]BOHSTRDAT <> [0/0/0] & LDAT < [F:BOH1]BOHSTRDAT)
&               |([F:BOH1]BOHENDDAT <> [0/0/0] & LDAT > [F:BOH1]BOHENDDAT)
                Goto NEXT_BOD
              Endif
            Endif
        Else
        # l'article n'est pas fabriqué, donc pas de gamme de fabrication à afficher
          Goto NEXT_ITM
        Endif
      Else
        Gosub ADD_LINE_OP
        WROU ="" : WROUALT=0
        GROUFLG = 0
      Endif
  $NEXT_ITM
    If [F:ITM]PHAFLG <> 2 & !find([F:ITF]REOCOD,1,3,5) : Goto NEXT_BOD : Endif
    # If [F:ITM]PHAFLG <> 2
      WMEMPL  = PLIGNE
      WMEMPL2 = LIGNE
      WMEMPL3 = L
      LSAV_ROU2 = WROU
      LSAV_ROUALT2 = WROUALT
      WROU = LSAV_ROU
      WROUALT = LSAV_ROUALT
      Gosub ADD_LINE
      WROU = LSAV_ROU2
      WROUALT = LSAV_ROUALT2
    # Endif
    Case [F:ITF]REOCOD
        When 3  : LBOMALTTYP=2                  : # Production
        When 5  : LBOMALTTYP=3                  : # Sous-traitance
        When Default : LBOMALTTYP=[M:VROG]BOMALTTYP  : # Pas de suggestion
    Endcase

    # descente récursive
    Call GEN_LISTE_RECETTE (L, LEVEL, LIGNE, PLIGNE, LDAT, [F:BOD1]CPNITMREF , [F:BOD1]BOMALT, LBOMALTTYP, WFCY,WROU,WROUALT)

    # y a t-il une opération dans l'arboresence générée depuis la ligne WEMPL3 ?
    K=0
    For I=WMEMPL3 To [M:VROG]NBLIG-1
       If find([M:VROG]ICO(I),WICO_OPER1,WICO_OPER2,WICO_OPER3)
          K=1 : Break
       Endif
    Next I
    If !K : # Non, on supprime l'arborescence parcourue depuis la ligne WMEMPL3
       L = WMEMPL3
       Dela L,[M:VROG]NBLIG-L [M:VROG]NBLIG
       [M:VROG]NBLIG = L
       LIGNE = WMEMPL2
    Endif

    Gosub LEC_FILES
    #If [F:ITM]PHAFLG <> 2
      LEVEL -= 1
      PLIGNE = WMEMPL
    #Endif

  $NEXT_BOD
      WROU ="" : WROUALT=0
      Read [BOD1] Next
    Wend
  # FQ60780 - MABON 10/12/09 - Il peut y avoir des articles avec une nomenclature sans Composants, mais avec des opérations de gammes
  Elsif LEVEL=1 : # GH 07/02/2014 bug 96664
    Gosub ADD_LINE_OP
  Else
    Call SEARCH_ROU(LITM,WFCY,[M:VROG]ROUALT,LDAT,WROU,WROUALT)
    If WROU<>"" & WROUALT<>0
      Read [ROH1]ROH1 = WFCY;WROU;WROUALT
      If !fstat
        GROUFLG = 1
        Gosub ADD_LINE_OP
      Endif
    Endif
  Endif
  # Fin MABON
  # Affzo [VROG]  # Issue 83450 & 82418 GA 07/2012 Pb Performances idem VISUBOMG
  If LEVEL=1  : # contournement bug 96975 : dela ne raze les varinit des lignes supprimées dans le tableau
     Raz [M:VROG] NIVEAU, NOLIG
  Endif
  Close Local File
End

#----------------------------------------------------------------------
# programme de recherche de gamme d'un semi fini
#----------------------------------------------------------------------
#RECUPERE GAMME+ALTERNATIVE PERMETTANT DE FABRIQUER CHAQUE PRODUIT SEMI-FINI
Subprog SEARCH_ROU(COMPOSANT, FCY, LALT, LDAT, WROU, WROUALT)
# COMPOSANT = article pour lequel on cherche gamme+alt
# FCY       = site de la gamme initiale
# LALT      = gamme initiale
# LDAT      = date de validité à vérifier pour la gamme trouvée
# WROUALT   = gamme à déterminer
# WROU      = alt de gamme à déterminer
Value    Char    COMPOSANT
Value    Char    FCY
Value    Integer LALT
Value    Date    LDAT
Variable Char    WROU
Variable Integer WROUALT

Local Char    WECCMAJ(GLONICVVAL)
Local Char    WECCMIN(GLONICVVAL)
Local Date    WSTRDAT, WENDDAT

# recherche de la gamme mère du composant
Local File ITMFACILIT [ITFT]

Read [ITFT]ITF0 = COMPOSANT;FCY
If !fstat
  WROUALT = [F:ITFT]MFGROUALT
  WROU    = [F:ITFT]MFGROU
Endif
If WROU = "" | WROUALT = 0
  WROU = COMPOSANT
  WROUALT = LALT
Endif
If WROU = "" | WROUALT = 0 : End : Endif

## GH 07/02/2014 bug 96664 controle de validité de la gamme trouvée à LDAT
If !clalev([F:ROHT]) : Local File ROUTING [ROHT] : Endif
If LDAT=[0/0/0]
   Look [ROHT]ROH0 = WROU;WROUALT;FCY
Else
   Read [ROHT]ROH0 = WROU;WROUALT;FCY
Endif
If fstat > 0
&  | (LDAT<>[0/0/0]
&     & (([F:ROHT]ROUSTRDAT <> [0/0/0] & LDAT < [F:ROHT]ROUSTRDAT)
&       |([F:ROHT]ROUENDDAT <> [0/0/0] & LDAT > [F:ROHT]ROUENDDAT))
&    )
     WROU = ""
     WROUALT = 0
Endif

End

############################################################
# alimentation du composé - nomenclature verticale
$ADD_PROD

# FQ 59912
If [M:VROG]NBLIG>=dim([M:VROG]CPNITMREF) : Return : Endif

[M:VROG]LIGNE(L)     = WLIGNE
[M:VROG]PARLIN(L)    = -1
[M:VROG]LEV(L)       = WLEVEL
[M:VROG]ITMREF(L)    = [M:VROG]ROUNUM
[M:VROG]CPNITMREF(L) = [M:VROG]ROUNUM
[M:VROG]GRPITMREF(L) = [M:VROG]ROUNUM
[M:VROG]BOMSEQ(L)    = 0
[M:VROG]LIBSH(L)     = mess(222,184,1)
Read [ITM]ITM0=[M:VROG]ITMREF(L)
If fstat : Raz [F:ITM]  : Endif
Read [ITF]ITF0=[M:VROG]ITMREF(L);[M:VROG]FCY
If fstat : Raz [F:ITF]  : Endif
Read [BOH1]BOH0=[M:VROG]ITMREF(L);[M:VROG]BOMALT;[M:VROG]BOMALTTYP
If fstat : Raz [F:BOH1]  : Endif

## GH 20/03/2013 bug 86834
If [M:VROG]BOMALTTYP=1
   Read [ITS1]ITS0=[M:VROG]ITMREF(L)
   If fstat : Raz [F:ITS1] : Endif
   [M:VROG]ROUTEX(L)     = [F:ITS1]ITSTEX     : # Texte vente
Else
   [M:VROG]ROUTEX(L)     = [F:ITM]MFGTEX     : # Texte production
Endif

#[M:VROG]ITMDES1(L)   = [F:ITM]ITMDES1
# Issue 83628 GA 07/2012
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:VROG]ITMDES1(L), "[F:ITM]") From TRTX3

Gosub ADD_VNOM
GROUFLG = 1

L += 1
[M:VROG]NBLIG = L

Return
#----------------------------------------------------------------------
# alimentation du tableau recette avec les opés de la gamme
$ADD_LINE_OP
Local Integer SUBLVL
Local Decimal PSEQ
Local Integer IND

If LDAT<>[0/0/0]
   Filter [ROO] Where VALSTRDAT <= LDAT & (VALENDDAT = [0/0/0] | VALENDDAT >= LDAT)
Else
   Filter [ROO]
Endif

For [ROO] Where FCY=WFCY & ITMREF = WROU & ROUALT = WROUALT
  If [M:VROG]NBLIG>=dim([M:VROG]CPNITMREF)
    Break
  Endif
  #[M:VROG]CPNITMREF(L) = "OPÉ" - num$([F:ROO]OPENUM) # FQ 74948
  [M:VROG]CPNITMREF(L) = mess(701,197,1) - num$([F:ROO]OPENUM)
  LIGNE += 1
  [M:VROG]LIGNE(L)     = LIGNE
  [M:VROG]PARLIN(L)    = PLIGNE
  [M:VROG]LEV(L)       = LEVEL
  #[M:VROG]GRPITMREF(L) = "OPÉ" - num$([F:ROO]OPENUM) # FQ 74948
  [M:VROG]GRPITMREF(L) = mess(701,197,1) - num$([F:ROO]OPENUM)
  [M:VROG]ITMDES1(L)   = [F:ROO]ROODES
  [M:VROG]ITMREF(L)    = LITM
  [M:VROG]OPENUM(L)    = [F:ROO]OPENUM
  [M:VROG]BOMSEQ(L)    = [F:ROO]OPENUM
  #[M:VROG]ICO(L)       = WICO_OPER : # GH 07/02/2014 bug 96217
  Case [F:ROO]ROOTIMCOD
     When 2       : [M:VROG]ICO(L)       = WICO_OPER2
     When 3       : [M:VROG]ICO(L)       = WICO_OPER3
     When Default : [M:VROG]ICO(L)       = WICO_OPER1
  Endcase
  [M:VROG]PRPTIM(L)    = [F:ROO]PRPTIM
  [M:VROG]WAITIM(L)    = [F:ROO]WAITIM
  [M:VROG]PSPTIM(L)    = [F:ROO]PSPTIM
  [M:VROG]ROOTIMCOD(L) = [F:ROO]ROOTIMCOD
  [M:VROG]TIMCOD(L)    = [F:ROO]TIMCOD
  [M:VROG]OPEUOM(L)    = [F:ROO]OPEUOM
  [M:VROG]RPLIND(L)    = [F:ROO]RPLIND     : # GH 20/03/2013 bug 86834
  [M:VROG]ROUTEX(L)    = [F:ROO]ROOTEX     : # Texte production
  If [F:ROH1]ITMREF<>WROU | [F:ROH1]ROUALT<>WROUALT | [F:ROH1]FCY<>WFCY
   Read [ROH1]ROH0 = WROU;WROUALT;WFCY
   If fstat : Raz [F:ROH1] : Endif
  Endif
  Case [F:ROH1]TIMUOMCOD
   When 1 : [M:VROG]TIMUOM(L) = mess(30,197,1) : # h
   When 2 : [M:VROG]TIMUOM(L) = mess(32,197,1) : # min
  Endcase
  If [F:ROO]ROOTIMCOD = 2  : # GH 07/02/2014 bug 96217 Unité Qté/ Unité Tps pour la cadence
    [M:VROG]TIMUOM2(L) = [M:VROG]OPEUOM(L)+"/"+[M:VROG]TIMUOM(L)
    [M:VROG]OPETIM2(L) = format$("N:6.4#",[F:ROO]CAD)
  Else
    [M:VROG]TIMUOM2(L) = [M:VROG]TIMUOM(L)
  Endif
  If [F:ROO]ROOTIMCOD = 1 & dim([M:VROG]LIKQTY2)>0 & dim([M:VROG]FMTQTY2)>0
     [M:VROG]LIKQTY2(L) = format$([M:VROG]FMTQTY2,[F:ROO]BASQTY)
     [M:VROG]STU(L)     = [F:ROO]OPEUOM
  Endif
  If [M:VROG]BOMSEQ(L) > 0
    PSEQ = [M:VROG]BOMSEQ(L) / 100
  Else
    PSEQ = 1/100
  Endif
  [M:VROG]POIDS(L)     = LEVEL+20+PSEQ
  If dim([M:VROG]LIBSH)>0
    [M:VROG]LIBSH(L) = mess(209,197,1) : # Opération
  Endif
  Gosub ADD_VNOM_OP
  L += 1
  [M:VROG]NBLIG = L
  SUBLVL = LIGNE    #on sauvegarde la ligne de l'opération qui servira de ligne parent pour les postes et l'outillage
  Gosub ADD_WST     #recherche et affichage du poste principal
  Gosub ADD_LABWST  #recherche et affichage du poste de main d'oeuvre
  Gosub ADD_SCOWST  #recherche et affichage du poste de sous traitance
  Gosub ADD_EQUNUM  #recherche et affichage de l'outillage
  ## GH 20/03/2013 bug 86834
  #[M:VROG]SETTIM(SUBLVL)+=sigma(SUBLVL+1,[M:VROG]NBLIG-1,[M:VROG]SETTIM(indcum))
  #[M:VROG]OPETIM(SUBLVL)+=sigma(SUBLVL+1,[M:VROG]NBLIG-1,[M:VROG]OPETIM(indcum))
  [M:VROG]SETTIM(SUBLVL) =max([M:VROG]SETTIM(SUBLVL+1..[M:VROG]NBLIG-1))
  [M:VROG]OPETIM(SUBLVL) =max([M:VROG]OPETIM(SUBLVL+1..[M:VROG]NBLIG-1))
  If dim([M:VROG]SETTIM2)>0 & dim([M:VROG]FMTTIM2)>0
    [M:VROG]SETTIM2(SUBLVL)=format$([M:VROG]FMTTIM2,[M:VROG]SETTIM(SUBLVL))
  Endif
  #If dim([M:VROG]OPETIM2)>0 & dim([M:VROG]FMTTIM2)>0 : # GH 07/02/2014 bug 96217
  If dim([M:VROG]OPETIM2)>0 & dim([M:VROG]FMTTIM2)>0 & [M:VROG]ROOTIMCOD(SUBLVL)<>2
    [M:VROG]OPETIM2(SUBLVL)=format$([M:VROG]FMTTIM2,[M:VROG]OPETIM(SUBLVL))
  Endif
Next
Filter [ROO]
Return

#----------------------------------------------------------------------
# alimentation du tableau - nomenclature verticale
$ADD_LINE
Local Integer PTRI : PTRI = 10
Local Decimal PSEQ
Local Integer IND, IND1, CPT
Local Char    ITMNAME
Local Decimal LQTN, LQTNA, LQTB, LQTBA

# FQ 59912
If [M:VROG]NBLIG>=dim([M:VROG]CPNITMREF) : Return : Endif

# si le composant est une matière liée à l'opération
  ITMNAME =[F:BOD1]CPNITMREF
  If [F:BOD1]CPNOPE > 0
      # on cherche si le pére du composant a une nomenclature
      Call SEARCH_ROU([F:BOD1]ITMREF,WFCY,[M:VROG]ROUALT,LDAT,WROU,WROUALT)
      If WROU <> "" & WROUALT <> 0
          If LDAT<>[0/0/0] : # GH 07/02/2014 bug 96664 vérification de la validité de l'opération de gamme
             Filter [ROO] Where VALSTRDAT <= LDAT & (VALENDDAT = [0/0/0] | VALENDDAT >= LDAT)
          Else
             Filter [ROO]
          Endif
          Read [ROO]ROO0 = WFCY;WROU;WROUALT;[F:BOD1]CPNOPE
          Filter [ROO]
          If !fstat
            If [F:BOD1]CPNITMREF <> ""
              IND = find([F:BOD1]ITMREF,[M]GRPITMREF(0..NBLIG))
              While IND > 1
                CPT +=1
                IND1 = find([F:BOD1]ITMREF,[M]GRPITMREF(IND..NBLIG))
                # Issue 84483 GA 09/2012
                #If IND1 > IND
                #   IND = IND1
                #Else
                #   Break
                #Endif
                If IND1 > 0
                   IND += IND1
                Else
                   ITMNAME += " %"-num$(IND)
                  Break
                Endif
              Wend
              # If CPT > 1
              #   ITMNAME += " %"-num$(IND1)
              # Endif
            Endif
            #GKEYMAT =[M:VROG]KEYC(PLIGNE) +"-"+"OPÉ"-num$([F:BOD1]CPNOPE)+"-"+num$([F:BOD1]CPNOPE) # FQ 74948
            GKEYMAT =[M:VROG]KEYC(PLIGNE) +"-"+mess(701,197,1)-num$([F:BOD1]CPNOPE)+"-"+num$([F:BOD1]CPNOPE)
            If [F:ROO]RPLIND<>0 : GKEYMAT+="."+num$([F:ROO]RPLIND) : Endif : # GH 07/02/2014 bug 96664
          Else
           GKEYMAT = [M:VROG]KEYC(PLIGNE)
         Endif
        Endif
     Endif

# on regarde si le composé à ajouter n'existe pas deja dans le tableau
  If [F:BOD1]CPNITMREF <> "" & GKEYMAT = ""
    IND = find([F:BOD1]CPNITMREF,[M]CPNITMREF(0..NBLIG))
    While IND > 0
      IND1 = find([F:BOD1]CPNITMREF,[M]GRPITMREF(IND..NBLIG))
      If IND1 > 0
        IND += IND1
      Else
        ITMNAME += " %"-num$(IND)
        Break
      Endif
    Wend
  Endif
Case [F:ITF]STOCOD
  When 1 : PTRI = 10
  When 2 : PTRI = 30
Endcase
LIGNE += 1
[M:VROG]LIGNE(L)     = LIGNE
[M:VROG]PARLIN(L)    = PLIGNE
[M:VROG]LEV(L)       = LEVEL
[M:VROG]ITMREF(L)    = [F:BOD1]ITMREF
[M:VROG]BOMSEQ(L)    = [F:BOD1]BOMSEQ
[M:VROG]CPNTYP(L)    = [F:BOD1]CPNTYP
Read [ITM1]ITM0=[F:BOD1]CPNITMREF
[M:VROG]ROUTEX(L)    = [F:ITM1]MFGTEX     : # Texte production

# Gestion du type texte
If [F:BOD1]CPNTYP = 5
  [M:VROG]CPNITMREF(L) = "TEXTE"
  [M:VROG]GRPITMREF(L) = "TEXTE"
  [M:VROG]ITMDES1(L) = [F:BOD1]BOMSHO
  #[M:VROG]BOMSHO(L) = [F:BOD1]BOMSHO : # Issue 76687 selon GH 29/09/11 bug 76687
  PTRI = 50
Else
  [M:VROG]CPNITMREF(L) = ITMNAME
  [M:VROG]GRPITMREF(L) = [F:BOD1]CPNITMREF
 # [M:VROG]ITMDES1(L)   = [F:ITM]ITMDES1
 # Issue 83628 GA 07/2012
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:VROG]ITMDES1(L), "[F:ITM]") From TRTX3
  #[M:VROG]BOMSHO(L) = [F:BOD1]BOMSHO : # Issue 76687 selon GH 29/09/11 bug 76687

  # Issue 104937 - 2015-11-25 by CCC : versioning
  If dim([M:VROG]BOHECCMAJL)>0
      [M:VROG]BOHECCMAJL(L) = [F:BOD1]ECCVALMAJ
      [M:VROG]BOHECCMINL(L) = [F:BOD1]ECCVALMIN
  Endif

Endif

# bulle d'aide en fonction du type de composant
If [F:BOD1]CPNTYP > 1
  [M:VROG]LIBSH(L)  = mess([F:BOD1]CPNTYP,438,1)
Else
  If func VISUBOMG.HAS_NOMP([F:BOD1]CPNITMREF,[M]BOMALT)
    [M:VROG]LIBSH(L)  = mess(222,184,1)
  Else
    [M:VROG]LIBSH(L)  = mess(35,197,1)
  Endif
Endif

If [F:BOD1]CPNTYP = 6 : PTRI= 40 : Endif

If [M:VROG]BOMSEQ(L) > 0
  PSEQ = [M:VROG]BOMSEQ(L) / 100
Else
  PSEQ = 1/100
Endif
[M:VROG]POIDS(L)     =LEVEL + PTRI+PSEQ
Gosub ADD_VNOM
L += 1
[M:VROG]NBLIG = L

Return
#----------------------------------------------------------------------
# GA 02/2008 nomenclature verticale
# NBLIG  : variable <Bas de tableau>
# PARKEY : clé père         (composé)
# KEYC   : clé              (composant)
# LIBL1  : libellé long
# LIBSH  : info-bulle       (facultatif)
# EXPFLG : ouvrir le niveau (facultatif)
# ICO    : icone associée   (facultatif)
#----------------------------------------------------------------------
$ADD_VNOM_OP
[M:VROG]KEYC(L) = [M:VROG]KEYC([M:VROG]PARLIN(L))+"-"+[M:VROG]CPNITMREF(L)+"-"+ num$([M:VROG]OPENUM(L))
If [F:ROO]RPLIND<>0 : [M:VROG]KEYC(L)+="."+num$([F:ROO]RPLIND) : Endif : # GH 07/02/2014 bug 96664
If [M:VROG]PARLIN(L)<>-1
   [M:VROG]PARKEY(L) = [M:VROG]KEYC([M:VROG]PARLIN(L))
Else
   [M:VROG]PARKEY(L) = ""
Endif

# Niveau plié/déplié
If dim([M:VROG]EXPFLG)>0
   If [M:VROG]PARLIN(L) =-1
      [M:VROG]EXPFLG(L) = 2
   Else
      # FQ65148 : le niveau sera présenté Plié avec la valeur 1, et non 0
#       [M:VROG]EXPFLG(L) = 0
      [M:VROG]EXPFLG(L) = 1
   Endif
   [M:VROG]ROUFLG = 0   : # Seul le 1er niveau est déplié
Endif
Return

#----------------------------------------------------------------------
# GA 02/2008 nomenclature verticale
# NBLIG  : variable <Bas de tableau>
# PARKEY : clé père         (composé)
# KEYC   : clé              (composant)
# LIBL1  : libellé long
# LIBSH  : info-bulle       (facultatif)
# EXPFLG : ouvrir le niveau (facultatif)
# ICO    : icone associée   (facultatif)
#----------------------------------------------------------------------
$ADD_VNOM

[M:VROG]KEYC(L)      = [M:VROG]CPNITMREF(L) +"-"+ num$([M:VROG]BOMSEQ(L))
If [M:VROG]PARLIN(L)<>-1
   [M:VROG]PARKEY(L) =[M:VROG]KEYC([M:VROG]PARLIN(L))
Else
   [M:VROG]PARKEY(L) = ""
Endif
If GKEYMAT <> ""
  [M:VROG]PARKEY(L) = GKEYMAT
  GKEYMAT =""
Endif
# icône associée nomenclature verticale
If dim([M:VROG]ICO)>0
       Case [M:VROG]CPNTYP(L)
         When 4           # Sous-produit
           [M:VROG]ICO(L) = WICO_SSPRODR
        When 5            # texte
          [M:VROG]ICO(L)  = WICO_TXTR
        When 6            # valorisation
          [M:VROG]ICO(L)  = WICO_VALR
        When 7            # service
          [M:VROG]ICO(L)  = WICO_SCOWSTR
       Endcase
       If [M:VROG]PARLIN(L)>-1 & [M:VROG]CPNTYP([M:VROG]PARLIN(L))<>4 & [M:VROG]ICO([M:VROG]PARLIN(L))=""
          [M:VROG]ICO([M:VROG]PARLIN(L)) = WICO_PRODR
       Endif
    If [M:VROG]PARLIN(L)<>-1 & find([M:VROG]ICO([M:VROG]PARLIN(L)),"",WICO_ENDR)
       [M:VROG]ICO([M:VROG]PARLIN(L))="Folder.gif"
    Endif
    If [F:ITM]PHAFLG = 2 #fantome
      [M:VROG]ICO(L)= WICO_GHOSTR
    Endif
Endif
# icone par default pour les matière premières
If [M:VROG]ICO(L) = ""
  [M:VROG]ICO(L)=WICO_MATR
Endif

# Niveau plié/déplié
If dim([M:VROG]EXPFLG)>0
   If [M:VROG]PARLIN(L) =-1
      [M:VROG]EXPFLG(L) = 2
   Else
      # FQ65148 : le niveau sera présenté Plié avec la valeur 1, et non 0
#       [M:VROG]EXPFLG(L) = 0
      [M:VROG]EXPFLG(L) = 1
   Endif
   [M:VROG]ROUFLG = 0   : # Seul le 1er niveau est déplié
Endif
Return

#----------------------------------------------------------------------
# alimentation du tableau - nomenclature verticale - Poste principal
$ADD_WST
If [F:ROO]SCOWST = "" | [F:ROO]SCOWST <> [F:ROO]WST
  # FQ 59912
  If [M:VROG]NBLIG>=dim([M:VROG]CPNITMREF) Return Endif

  Read [MWS1]WST0=[F:ROO]WST;WFCY
  If !fstat
    LIGNE += 1
    [M:VROG]LIGNE(L)     = LIGNE
    [M:VROG]PARLIN(L)    = SUBLVL
    [M:VROG]LEV(L)       = LEVEL+1
    [M:VROG]CPNITMREF(L) = [F:ROO]WST
    [M:VROG]GRPITMREF(L) = [F:ROO]WST
    [M:VROG]ITMREF(L)    = LITM
    [M:VROG]OPENUM(L)    = [F:ROO]OPENUM
    [M:VROG]RPLIND(L)    = [F:ROO]RPLIND    : # GH 20/03/2013 bug 86834
    [M:VROG]WST(L)       = [F:ROO]WST
    [M:VROG]WCR(L)       = [F:MWS1]WCR
    [M:VROG]WSTTYP(L)    = [F:MWS1]WSTTYP
    [M:VROG]ROUTEX(L)    = [F:ROO]ROOTEX     : # Texte production
    [M:VROG]ICO(L)       = WICO_WSTR

    [M:VROG]SETTIM(L)    = [F:ROO]SETTIM
    [M:VROG]OPETIM(L)    = [F:ROO]OPETIM
    [M:VROG]ROOTIMCOD(L) = [F:ROO]ROOTIMCOD
    [M:VROG]TIMCOD(L)    = [F:ROO]TIMCOD
    If dim([M:VROG]SETTIM2)>0 & dim([M:VROG]FMTTIM2)>0
      [M:VROG]SETTIM2(L)   = format$([M:VROG]FMTTIM2,[M:VROG]SETTIM(L))
    Endif
    If dim([M:VROG]OPETIM2)>0 & dim([M:VROG]FMTTIM2)>0
      [M:VROG]OPETIM2(L)   = format$([M:VROG]FMTTIM2,[M:VROG]OPETIM(L))
    Endif

    #[M:VROG]ITMDES1(L)   = [F:MWS1]WSTDES bug 68586 26/10/10
    Call LECTEXTRA([M:VROG]ITMDES1(L),"WORKSTATIO","WSTDESAXX",[F:MWS1]WST,[F:MWS1]WCRFCY) From ATEXTRA
    # info bulle
    [M:VROG]BOMSEQ(L)    = 2
    If [M:VROG]BOMSEQ(L) > 0
      PSEQ = [M:VROG]BOMSEQ(L) / 100
    Else
      PSEQ = 1/100
    Endif
    [M:VROG]POIDS(L)     = LEVEL+2+PSEQ
    If dim([M:VROG]LIBSH)>0
       [M:VROG]LIBSH(L) = mess(243,190,1) : # Poste pal
    Endif
    [M:VROG]KEYC(L)      = num$([M:VROG]LEV(L))+"-"+[M:VROG]ITMREF(L) +"-"+ num$([M:VROG]OPENUM(L))+"-"+[M:VROG]WST(L)
    [M:VROG]PARKEY(L) = [M:VROG]KEYC([M:VROG]PARLIN(L))
    L += 1
    [M:VROG]NBLIG = L
  Endif
Endif
Return

#----------------------------------------------------------------------
# alimentation du tableau - nomenclature verticale - Poste main d'oeuvre
$ADD_LABWST
# recherche du type + centre des postes M-O
If [F:ROO]LABWST <> ""

  # FQ 59912
  If [M:VROG]NBLIG>=dim([M:VROG]CPNITMREF) Return Endif

  Read [MWS1]WST0=[F:ROO]LABWST;WFCY
  If !fstat
    LIGNE += 1
    [M:VROG]LIGNE(L)     = LIGNE
    [M:VROG]PARLIN(L)    = SUBLVL
    [M:VROG]LEV(L)       = LEVEL+1
    [M:VROG]CPNITMREF(L) = [F:ROO]LABWST
    [M:VROG]GRPITMREF(L) = [F:ROO]LABWST
    [M:VROG]ITMREF(L)    = LITM
    [M:VROG]OPENUM(L)    = [F:ROO]OPENUM
    [M:VROG]RPLIND(L)    = [F:ROO]RPLIND    : # GH 20/03/2013 bug 86834
    [M:VROG]WST(L)       = [F:ROO]LABWST
    [M:VROG]WCR(L)       = [F:MWS1]WCR
    [M:VROG]WSTTYP(L)    = [F:MWS1]WSTTYP
    [M:VROG]ROUTEX(L)    = [F:ROO]ROOTEX     : # Texte production
    [M:VROG]ICO(L)       = WICO_LABWSTR

    [M:VROG]SETTIM(L)    = [F:ROO]SETTIM * [F:ROO]SETLABCOE
    [M:VROG]OPETIM(L)    = [F:ROO]OPETIM * [F:ROO]OPELABCOE
    [M:VROG]ROOTIMCOD(L) = [F:ROO]ROOTIMCOD
    [M:VROG]TIMCOD(L)    = [F:ROO]TIMCOD
    If dim([M:VROG]SETTIM2)>0 & dim([M:VROG]FMTTIM2)>0
      [M:VROG]SETTIM2(L)   = format$([M:VROG]FMTTIM2,[M:VROG]SETTIM(L))
    Endif
    If dim([M:VROG]OPETIM2)>0 & dim([M:VROG]FMTTIM2)>0
      [M:VROG]OPETIM2(L)   = format$([M:VROG]FMTTIM2,[M:VROG]OPETIM(L))
    Endif

    #[M:VROG]ITMDES1(L)   = [F:MWS1]WSTDES bug 68586 26/10/10
    Call LECTEXTRA([M:VROG]ITMDES1(L),"WORKSTATIO","WSTDESAXX",[F:MWS1]WST,[F:MWS1]WCRFCY) From ATEXTRA
    [M:VROG]BOMSEQ(L)    = 3
    If [M:VROG]BOMSEQ(L) > 0
      PSEQ = [M:VROG]BOMSEQ(L) / 100
    Else
      PSEQ = 1/100
    Endif
    [M:VROG]POIDS(L)     = LEVEL+2+PSEQ
    # info bulle
    If dim([M:VROG]LIBSH)>0
       [M:VROG]LIBSH(L) = mess(244,190,1) : # Poste Mo
    Endif
    [M:VROG]KEYC(L)      = num$([M:VROG]LEV(L))+"-"+[M:VROG]ITMREF(L) +"-"+ num$([M:VROG]OPENUM(L))+"-"+[M:VROG]WST(L)
    [M:VROG]PARKEY(L) = [M:VROG]KEYC([M:VROG]PARLIN(L))
  Endif
  L += 1
  [M:VROG]NBLIG = L
Endif
Return
#----------------------------------------------------------------------
# alimentation du tableau - nomenclature verticale - Sous-traitance
$ADD_SCOWST

# recherche du type + centre des postes SST
If [F:ROO]SCOCOD=2 & [F:ROO]SCOWST<>""

  # FQ 59912
  If [M:VROG]NBLIG>=dim([M:VROG]CPNITMREF) Return Endif

   Read [MWS1]WST0=[F:ROO]SCOWST;WFCY
   If !fstat
      LIGNE += 1
      [M:VROG]LIGNE(L)     = LIGNE
      [M:VROG]PARLIN(L)    = SUBLVL
      [M:VROG]LEV(L)       = LEVEL+1
      [M:VROG]ITMREF(L)    = LITM
      [M:VROG]OPENUM(L)    = [F:ROO]OPENUM
      [M:VROG]RPLIND(L)    = [F:ROO]RPLIND    : # GH 20/03/2013 bug 86834
      [M:VROG]ITMSST(L)    = [F:ROO]SCOITMREF
      [M:VROG]WST(L)       = [F:ROO]SCOWST
      [M:VROG]WCR(L)       = [F:MWS1]WCR
      [M:VROG]WSTTYP(L)    = [F:MWS1]WSTTYP
      [M:VROG]ROUTEX(L)    = [F:ROO]ROOTEX     : # Texte production
      [M:VROG]ICO(L)       = WICO_SCOWSTR
      [M:VROG]CPNITMREF(L) = [F:ROO]SCOWST
      [M:VROG]GRPITMREF(L) = [F:ROO]SCOWST

      [M:VROG]SETTIM(L)    = [F:ROO]SETTIM
      [M:VROG]OPETIM(L)    = [F:ROO]OPETIM
      [M:VROG]ROOTIMCOD(L) = [F:ROO]ROOTIMCOD
      [M:VROG]TIMCOD(L)    = [F:ROO]TIMCOD
      If dim([M:VROG]SETTIM2)>0 & dim([M:VROG]FMTTIM2)>0
        [M:VROG]SETTIM2(L)   = format$([M:VROG]FMTTIM2,[M:VROG]SETTIM(L))
      Endif
      If dim([M:VROG]OPETIM2)>0 & dim([M:VROG]FMTTIM2)>0
        [M:VROG]OPETIM2(L)   = format$([M:VROG]FMTTIM2,[M:VROG]OPETIM(L))
      Endif

      #[M:VROG]ITMDES1(L)   = [F:MWS1]WSTDES  bug 68586 26/10/10
      Call LECTEXTRA([M:VROG]ITMDES1(L),"WORKSTATIO","WSTDESAXX",[F:MWS1]WST,[F:MWS1]WCRFCY) From ATEXTRA
      [M:VROG]BOMSEQ(L)    = 4
      If [M:VROG]BOMSEQ(L) > 0
        PSEQ = [M:VROG]BOMSEQ(L) / 100
      Else
        PSEQ = 1/100
      Endif
      [M:VROG]POIDS(L)     = LEVEL+2+PSEQ
      # info bulle
      If dim([M:VROG]LIBSH)>0
         [M:VROG]LIBSH(L) = mess(245,190,1) : # Poste SST
      Endif
   Endif
   [M:VROG]KEYC(L)      = num$([M:VROG]LEV(L))+"-"+[M:VROG]ITMREF(L) +"-"+ num$([M:VROG]OPENUM(L))+"-"+[M:VROG]WST(L)
   [M:VROG]PARKEY(L) = [M:VROG]KEYC([M:VROG]PARLIN(L))

   L += 1
  [M:VROG]NBLIG = L
Endif
Return

#----------------------------------------------------------------------
# alimentation du tableau - nomenclature verticale - Outillage
$ADD_EQUNUM

If [F:ROO]EQUNUM<>""

  # FQ 59912
  If [M:VROG]NBLIG>=dim([M:VROG]CPNITMREF) Return Endif

   Read [ITM1]ITM0=[F:ROO]EQUNUM
   If !fstat
      LIGNE += 1
      [M:VROG]LIGNE(L)     = LIGNE
      [M:VROG]PARLIN(L)    = SUBLVL
      [M:VROG]LEV(L)       = LEVEL+1
      [M:VROG]ITMREF(L)    = LITM
      #[M:VROG]OPENUM(L)    = [F:ROO]OPENUM
      [M:VROG]CPNITMREF(L) = [F:ROO]EQUNUM
      [M:VROG]GRPITMREF(L) = [F:ROO]EQUNUM
      [M:VROG]ROUTEX(L)    = [F:ROO]ROOTEX     : # Texte production
      #[M:VROG]ITMDES1(L)   = [F:ITM1]ITMDES1
      # Issue 83628 GA 07/2012
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM1]ITMREF,[M:VROG]ITMDES1(L), "[F:ITM1]") From TRTX3
      [M:VROG]BOMSEQ(L)    = 5
      [M:VROG]ICO(L)       = WICO_EQUNR
      If [M:VROG]BOMSEQ(L) > 0
        PSEQ = [M:VROG]BOMSEQ(L) / 100
      Else
        PSEQ = 1/100
      Endif
      [M:VROG]POIDS(L)     = LEVEL+2+PSEQ
      # info bulle
      If dim([M:VROG]LIBSH)>0
         [M:VROG]LIBSH(L) = mess(78,198,1) : # Outillage
      Endif
   Endif
   [M:VROG]KEYC(L)      = num$([M:VROG]LEV(L))+"-"+[M:VROG]ITMREF(L) +"-"+ num$([M:VROG]OPENUM(L))+"-"+[M:VROG]WST(L)
   [M:VROG]PARKEY(L) = [M:VROG]KEYC([M:VROG]PARLIN(L))

  L += 1
  [M:VROG]NBLIG = L
Endif
Return


######################################################################################
# NOL doit être préalablement chargée - appelé par SUBVROUG en AS_NBLIG
$CHARGE_ROO
Effzo [VROG]35
# Affichage élément courant
[M:VROG]XNUMLIG = NOL
[M:VROG]XLIB    = [M:VROG]LIBSH(NOL)
[M:VROG]XLIBL1  = [M:VROG]GRPITMREF(NOL)
[M:VROG]XLIBL2  = [M:VROG]ITMDES1(NOL)

If dim([M:VROG]BOHECCMAJL)>0
    [M:VROG]XBOHECCMAJ = [M:VROG]BOHECCMAJL(NOL)
    [M:VROG]XBOHECCMIN = [M:VROG]BOHECCMINL(NOL)
Endif

Read [ITM1]ITM0=[M:VROG]ITMREF(NOL)
If fstat : Raz [F:ITM1]  : Endif
Read [ITF1]ITF0=[M:VROG]ITMREF(NOL);[M:VROG]FCY
If fstat : Raz [F:ITF1]  : Endif

If [M:VROG]WST(NOL)<>""
  # Infos relatives au poste de charge courant  - bloc [M:VROG]45
  Read [MWS1]WST0=[M:VROG]WST(NOL);[M:VROG]FCY
  If fstat : Raz [F:MWS1] : Endif

  [M:VROG]XWST    = [M:VROG]WST(NOL)
  [M:VROG]XWSTTYP = [M:VROG]WSTTYP(NOL)
  [M:VROG]XWCR    = [M:VROG]WCR(NOL)
Else
  Effzo [VROG]45
  [M:VROG]XWSTTYP = 0
Endif

If dim([M:VROG]XITMREF)>0
  #CHECK UNUSED_BEGIN
  # FGR 14/01/2010 : le champ [M:VROG]XITMREF n'existe pas. on ne peut jamais passer ici !
  If [M:VROG]EQUNUM(NOL)<>""
    # Outillage  - bloc [M:VROG]35
    [M:VROG]XLIBITM    = mess(78,198,1)        : # Outillage
    [M:VROG]XITMREF    = [M:VROG]EQUNUM(NOL)
    [M:VROG]XBOMALTTYP = 2
  Elsif [M:VROG]ITMSST(NOL)<>""
    # Service sous-traitance  - bloc [M:VROG]35
    [M:VROG]XLIBITM    = mess(79,198,1)        : # Article sous-traitance
    [M:VROG]XITMREF    = [M:VROG]ITMSST(NOL)
    [M:VROG]XBOMALTTYP = 2
  Elsif [M:VROG]ITMREF(NOL)<>""
    # Composé nomenclature  - bloc [M:VROG]35
    [M:VROG]XLIBITM    = mess(222,184,1)       : # Composé
    [M:VROG]XITMREF    = [M:VROG]ITMREF(NOL)
    [M:VROG]XBOMALT    = [M:VROG]BOMALT(NOL)
    [M:VROG]XBOMALTTYP = [M:VROG]BOMALTTYP(NOL)
    [M:VROG]XBODSTRDAT = [M:VROG]BODSTRDAT(NOL)
    [M:VROG]XBODENDDAT = [M:VROG]BODENDDAT(NOL)
  Endif
  #CHECK UNUSED_END
Else
  Effzo [VROG]35
Endif

If [M:VROG]ITMSST(NOL)<>""
  # Service sous-traitance  - bloc [M:VROG]65
  [M:VROG]SCOITMREF = [M:VROG]ITMSST(NOL)
  [M:VROG]BPRNUM    = [M:VROG]BPRNUM2(NOL)
  If clalev ([MWS])=0 : Local File WORKSTATIO [MWS] : Endif
  If [M:VROG]WST(NOL) <> ""
    Read [MWS]WST0=[M:VROG]WST(NOL);[M:VROG]FCY
    If !fstat
      If [F:MWS]WSTTYP=3
        [M:VROG]SCOCOD = 2
      Endif
      If [F:MWS]WSTTYP <> 3 & [M:VROG]SCOCOD=2
        [M:VROG]SCOCOD=3
      Endif
    Endif
  Endif
Else
  Effzo [VROG]65
Endif

If dim([M:VROG]XVALSTRDAT)>0 & [M:VROG]OPENUM(NOL)<>0
  # Infos relatives à l'opération courante - bloc [M:VROG]40
  Read [ROO1]ROO0=[M:VROG]FCY;[M:VROG]ITMREF(NOL);[M:VROG]ROUALT;[M:VROG]OPENUM(NOL);[M:VROG]RPLIND(NOL)
  If fstat : Raz [F:ROO1] : Endif

  [M:VROG]XOPENUM    = [M:VROG]OPENUM(NOL)
  [M:VROG]XRPLIND    = [M:VROG]RPLIND(NOL)
  [M:VROG]XVALSTRDAT = [F:ROO1]VALSTRDAT
  [M:VROG]XVALENDDAT = [F:ROO1]VALENDDAT
  If [M:VROG]XWST    = [F:ROO1]LABWST
     [M:VROG]XWSTNBR = [F:ROO1]LABNBR : # Nb postes M/O
  Else
     [M:VROG]XWSTNBR = [F:ROO1]WSTNBR : # Nb postes
  Endif
  [M:VROG]XSETTIM    = [M:VROG]SETTIM(NOL)   : [M:VROG]XTIMUOM1    = [M:VROG]TIMUOM(NOL)
  If [M:VROG]XTIMUOM1="" & [M:VROG]PARLIN(NOL)>=0 : [M:VROG]XTIMUOM1 = [M:VROG]TIMUOM([M:VROG]PARLIN(NOL)) : Endif
  [M:VROG]XPRPTIM    = [M:VROG]PRPTIM(NOL)   : [M:VROG]XTIMUOM2    = mess(30,197,1) : # h
  [M:VROG]XOPETIM    = [M:VROG]OPETIM(NOL)   : [M:VROG]XTIMUOM3    = [M:VROG]XTIMUOM1
  [M:VROG]XWAITIM    = [M:VROG]WAITIM(NOL)   : [M:VROG]XTIMUOM4    = [M:VROG]XTIMUOM2
  If dim([M:VROG]XPSPTIM)>0
     [M:VROG]XPSPTIM   = [M:VROG]PSPTIM(NOL) : [M:VROG]XTIMUOM5    = [M:VROG]XTIMUOM2
  Endif
  ## GH 20/03/2013 bug 86834
  Case [F:ROO1]ROOTIMCOD
       When 1       : [M:VROG]XTIMCOD = mess([F:ROO1]TIMCOD,303,1) : # GH 07/01/2014 mess([F:ROO1]ROOTIMCOD,303,1)
       When 2       : [M:VROG]XTIMCOD = num$([F:ROO1]CAD)-"/"-[M:VROG]XTIMUOM1
       When Default : [M:VROG]XTIMCOD = ""
  Endcase
  If dim([M:VROG]XROOTIMCOD)>0
     [M:VROG]XROOTIMCOD = [F:ROO1]ROOTIMCOD
  Endif
  If dim([M:VROG]XOPEUOM)>0
    [M:VROG]XOPEUOM    = [F:ROO1]OPEUOM
  Endif
  [M:VROG]XBASQTY = [F:ROO1]BASQTY
Else
  Effzo [VROG]40
  [M:VROG]XOPENUM    = [M:VROG]OPENUM([M:VROG]PARLIN(NOL))
  [M:VROG]XRPLIND    = [M:VROG]RPLIND([M:VROG]PARLIN(NOL))
  Read [ROO1]ROO0=[M:VROG]FCY;[M:VROG]ITMREF([M:VROG]PARLIN(NOL));[M:VROG]ROUALT;[M:VROG]XOPENUM;[M:VROG]XRPLIND
  If !fstat
      [M:VROG]XVALSTRDAT = [F:ROO1]VALSTRDAT
      [M:VROG]XVALENDDAT = [F:ROO1]VALENDDAT
  Endif
  If dim([M:VROG]XROOTIMCOD)>0
     [M:VROG]XROOTIMCOD = 0
  Endif
Endif

Gosub CHARGE_TEX    : # Texte
Gosub CHARGE_IMG    : # CLOB Image

Affzo [VROG]

Return

######################################################################################
# NOL doit être préalablement chargée - appelé par SUBVROUG en AS_NBLIG
$CHARGE_ROH
# Affichage du composé
[M:VROG]XNUMLIG     = NOL
[M:VROG]XLIB    = [M:VROG]LIBSH(NOL)
[M:VROG]XLIBL1  = [M:VROG]GRPITMREF(NOL)
[M:VROG]XLIBL2  = [M:VROG]ITMDES1(NOL)

Read [ITM1]ITM0=[M:VROG]ITMREF(NOL)
If fstat : Raz [F:ITM1]  : Endif
Read [ITF1]ITF0=[M:VROG]ITMREF(NOL);[M:VROG]FCY
If fstat : Raz [F:ITF1]  : Endif

If dim([M:VROG]XITMREF)>0 & [M:VROG]ITMREF(NOL)<>""
  # Composé nomenclature  - bloc [M:VROG]35
  #CHECK UNUSED_BEGIN
  # FGR 14/01/2010 : le champ [M:VROG]XITMREF n'existe pas. on ne peut jamais passer ici !
  [M:VROG]XLIBITM    = mess(222,184,1)       : # Composé
  [M:VROG]XITMREF    = [M:VROG]ITMREF(NOL)
  [M:VROG]XBOMALT    = [M:VROG]BOMALT(NOL)
  [M:VROG]XBOMALTTYP = [M:VROG]BOMALTTYP(NOL)
  #CHECK UNUSED_END
Else
  Effzo [VROG]35
  If dim([M:VROG]XBOMALTTYP)>0
    [M:VROG]XBOMALTTYP = 2
  Endif
Endif
Gosub CHARGE_TEX    : # Texte
Gosub CHARGE_IMG    : # CLOB Image

Effzo [VROG]40
Effzo [VROG]45
[M:VROG]XWSTTYP = 0
If dim([M:VROG]XROOTIMCOD)>0
  [M:VROG]XROOTIMCOD = 0
Endif
Affzo [VROG]

Return

############################################################
$CHARGE_TEX
Raz [M:VROG]TEXTE
If [M:VROG]ROUTEX(NOL)<>""
   Read [TXC1]TXC0=[M:VROG]ROUTEX(NOL)
   If !fstat   [M:VROG]TEXTE = [F:TXC1]TEXTE Endif
Endif

Return
############################################################
$CHARGE_IMG
Read [CBB1]CBB0="ITM";[F:ITM1]ITMREF;""
If !fstat
   [M:VROG]IMG=[F:CBB1]BLOB
Else
   Raz [M:VROG]IMG
Endif

Return

############################################################
$AVANT_BOUTON_ROUG
Local Char     WCLE1(15)
Local Char     WCLE2(15) (2)

Case BOUT
  When "1" :
    Global Date    GDATREF : GDATREF = [M:VROG]DATREF
    Global Decimal GQTYREF : GQTYREF = 0
    If GDATREF = [0/0/0] : GDATREF = date$ : Endif
    # Quantité de base = qté réappro ou 1
    Read [ITF]ITF0=[M:VROG]ITMREF;[M:VROG]FCY
    If fstat = 0
      GQTYREF = [F:ITF]REOMINQTY
    Endif
    If GQTYREF = 0
      GQTYREF = 1
    Endif
    If clalev ([F:PJA]) = 0 : Local File PARJAL      [PJA]  : Endif
Endcase
Return

############################################################
$BOUTON_ROUG
#Local Char WCLE1(15)
#Local Char WCLE2(15) (2)
Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)

Case BOUT
  When "a" :
    Gosub FIRST_LEV_ROUG
  When "b" :
    Gosub ALL_LEV_ROUG
  When "c" :
    # MHB 24/10/08 : l'état ROUTING est dorénavant appelé, plutôt qu'une impression écran
    # Les paramètres sont fournis par les valeurs par défaut de Paramétrage/ Destinations sur la fonction VISUROUG
    # Call PRTSCR("VISUROUG","VROG","",0,0) From ATRTX3
    Local Char FONCTION_SAV
    FONCTION_SAV=GFONCTION
    GFONCTION="VISUROUG"
    # FQ61726 - MABON 19/01/09 - la langue FRA ne doit pas être passée en dur
#    Call ETAT("ROUTING","VISU","FRA",0,"Impression des gammes", TBPAR, TBVAL) From AIMP3
    Call ETAT("ROUTING",GFONCTION,TBPAR, TBVAL) From ETAT
    GFONCTION=FONCTION_SAV
  When "2" :
    # Cas d'emploi de gammes - Objet ROW - Index ROH1
    Local Char     WCLE1(30)
    Local Char     WCLE2(30) (2)
    WCLE1    = [M:VROG]FCY
    WCLE2(0) = [M:VROG]ITMREF
    WCLE2(1) = num$([M:VROG]ROUALT)
    Global Char GFLTROW (250)
    GFLTROW = 'ITMREF="'+[M:VROG]ITMREF+'"& ROUALT='+num$([M:VROG]ROUALT)+' & FCY="'+[M:VROG]FCY+'"'
    If [F:ROH]ITMREF<>[M:VROG]ITMREF | [F:ROH]FCY<>[M:VROG]FCY | [F:ROH]ROUALT<>[M:VROG]ROUALT
       Read [ROH]ROH1=[M:VROG]FCY;[M:VROG]ITMREF;[M:VROG]ROUALT
       If fstat Raz [F:ROH] : Return : Endif
    Endif
    Call OBJET_CHAR(WCLE1,"ROW",WCLE2(0)+"~"+WCLE2(1)) From GOBJET
    If dim([V]GFLTROW)>0 : Kill [V]GFLTROW : Endif
Endcase
Return

############################################################
$FIRST_LEV_ROUG
# Replier tout, sauf 1er niveau
Local Integer K
If dim([M:VROG]EXPFLG)>0
For K=0 To [M:VROG]NBLIG-1
  If [M:VROG]PARLIN(K)=-1
     [M:VROG]EXPFLG(K) = 2
  Else
      # FQ65148 : le niveau sera présenté Plié avec la valeur 1, et non 0
#     [M:VROG]EXPFLG(K) = 0
     [M:VROG]EXPFLG(K) = 1
  Endif
Next
Endif
[M:VROG]ROUFLG = 0   : # Seul le 1er niveau est déplié
Affzo [VROG]
Return
############################################################
$ALL_LEV_ROUG
# Deplier toute l'arborescence
Local Integer K
If dim([M:VROG]EXPFLG)>0
  For K=0 To [M:VROG]NBLIG-1
    [M:VROG]EXPFLG(K) = 2
  Next
Endif
[M:VROG]ROUFLG = 1   : # Toute l'arborescence est dépliée
Affzo [VROG]
Return

