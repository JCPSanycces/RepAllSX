#<AdxTL>@(#)8.0.0.0 $Revision$
# Action de visualisation nomenclatures et gammes - Mode graphique
# Action VISUROHG   : Visualisation gamme multiniveaux
#     nb VISUROUG déjà utilisé pour Visu charge graphique :-(
############################################################
$ACTION
  Case GACTION
    When "VISUROHG"
      Case ACTION
        When "OUVRE"            : Gosub OUVRE_ROUG
        When "DEBUT"            : Gosub DEBUT_ROUG
        When "FIN"              : Gosub FIN_ROUG
        When "SETBOUT"          : Gosub SETBOUT_ROUG
        When "AVANT_BOUTON"     : Gosub AVANT_BOUTON_ROUG
        When "BOUTON"           : Gosub BOUTON_ROUG
        When "APRES_MODIF"      : Gosub APRES_MODIF_ROUG
        When "FIR"              : Gosub FIR_ROUG
        When "AVANT_PRE"        : Gosub SET_ROH1
        When "PRE"              : Gosub PRE_ROUG
        When "SUI"              : Gosub SUI_ROUG
        When "AVANT_SUI"        : Gosub SET_ROH1
        When "LAS"              : Gosub LAS_ROUG
      Endcase
  Endcase
Return

############################################################
# Visualisation nomenclatures
############################################################
$OUVRE_ROUG
Local Integer IITM, IITF, IITS, IROH, IROO, ITRO, IMWS, IBOH, IBOD, ITBO, ICBB, ITXC
If clalev([F:ITF])  = 0 : Local File ITMFACILIT    [ITF]   : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER     [ITM]   : Endif
If clalev([F:ROH])  = 0 : Local File ROUTING       [ROH]   : Endif
If clalev([F:ROO])  = 0 : Local File ROUOPE        [ROO]   : Endif
If clalev([F:TRO])  = 0 : Local File TABROUALT     [TRO]   : Endif

If clalev([F:ITM1]) = 0 : Local File ITMMASTER     [ITM1]  : IITM = 1 : Endif
If clalev([F:ITF1]) = 0 : Local File ITMFACILIT    [ITF1]  : IITF = 1 : Endif
If clalev([F:ITS1]) = 0 : Local File ITMSALES      [ITS1]  : IITS = 1 : Endif

If clalev([F:ROH1]) = 0 : Local File ROUTING       [ROH1]  : IROH = 1 : Endif
If clalev([F:ROO1]) = 0 : Local File ROUOPE        [ROO1]  : IROO = 1 : Endif
If clalev([F:TRO1]) = 0 : Local File TABROUALT     [TRO1]  : ITRO = 1 : Endif
If clalev([F:MWS1]) = 0 : Local File WORKSTATIO    [MWS1]  : IMWS = 1 : Endif

If clalev([F:BOH1]) = 0 : Local File BOM           [BOH1]  : IBOH = 1 : Endif
If clalev([F:BOD1]) = 0 : Local File BOMD          [BOD1]  : IBOD = 1 : Endif
If clalev([F:TBO1]) = 0 : Local File TABBOMALT     [TBO1]  : ITBO = 1 : Endif

If clalev([F:CBB1]) = 0 : Local File CBLOB         [CBB1]  : ICBB = 1 : Endif
If clalev([F:TXC1]) = 0 : Local File TEXCLOB       [TXC1]  : ITXC = 1 : Endif

# Issue 104937 - 2015-11-25 by CCC : versioning in routes
If clalev([F:EVL])  = 0 : Local File ECCVAL        [EVL]   : Endif
If clalev([F:RVV])  = 0 : Local File RVMVAL        [RVV]   : Endif

Local Integer OK, L, WLEVEL, WLIGNE, WPLIGNE
Global Char WICO_PRODR(30),WICO_SSPRODR(30),WICO_SCPR(30),WICO_SCSR(30),WICO_ENDR(30)
Global Char WICO_OPER1(30), WICO_OPER2(30), WICO_OPER3(30) : # WICO_OPER(30) : # GH 07/02/2014 bug 96217
Global Char WICO_WSTR(30),WICO_LABWSTR(30),WICO_EQUNR(30), WICO_TXTR(30),WICO_VALR(30),WICO_SCOWSTR(30)
Global Char WICO_MATR(30),WICO_GHOSTR(30)
Global Integer GROUFLG
# Global Char GKEYMAT : # GH 10/09/2014 bug 102531

Gosub LISTE_ICONES

# GH 07/02/2014 bug 96664
Local Char SAVFONCTION(GLONAFC)
SAVFONCTION = GFONCTION
GFONCTION = "VISUROUG" : # pour l'aide sur fonction
If GNBAUZ=0
   GERR=1 : GMESSAGE = GFONCTION-":"-mess(1,123,1) : # Fonction non autorisée
   FIN=1 : Return
Endif
# appel en tunnel avec un site précis
If [L]PARAM(2)<>"" & [L]PARAM(1)<>"" & GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE & !find([L]PARAM(1),GUSRFCY(1..GNBAUZ))
   GERR=1 : GMESSAGE = mess(175,123,1)-[L]PARAM(1) : # Fonction non autorisée pour ce site
   FIN=1 : Return
Endif
Return

############################################################
$FIN_ROUG
If IITM = 1
  IITM = 0
  Close Local File [ITM1]
Endif
If IITF = 1
  IITF = 0
  Close Local File [ITF1]
Endif
If IITS = 1
  IITS = 0
  Close Local File [ITS1]
Endif

If IROH = 1
  IROH = 0
  Close Local File [ROH1]
Endif
If IROO = 1
  IROO = 0
  Close Local File [ROO1]
Endif
If ITRO = 1
  ITRO = 0
  Close Local File [TRO1]
Endif
If IMWS = 1
  IMWS = 0
  Close Local File [MWS1]
Endif

If IBOH = 1
  IBOH = 0
  Close Local File [BOH1]
Endif
If IBOD = 1
  IBOD = 0
  Close Local File [BOD1]
Endif
If ITBO = 1
  ITBO = 0
  Close Local File [TBO1]
Endif

If ICBB = 1
  ICBB = 0
  Close Local File [CBB1]
Endif
If ITXC = 1
  ITXC = 0
  Close Local File [TXC1]
Endif

Call IMPSCR From ATRTX3
If dim([V]WICO_PRODR) > 0   : Kill [V]WICO_PRODR   : Endif
If dim([V]WICO_SSPRODR) > 0 : Kill [V]WICO_SSPRODR : Endif
If dim([V]WICO_SCPR) > 0    : Kill [V]WICO_SCPR    : Endif
If dim([V]WICO_SCSR) > 0    : Kill [V]WICO_SCSR    : Endif
If dim([V]WICO_ENDR) > 0    : Kill [V]WICO_ENDR    : Endif
If dim([V]WICO_WSTR) > 0    : Kill [V]WICO_WSTR    : Endif
If dim([V]WICO_LABWSTR) > 0 : Kill [V]WICO_LABWSTR : Endif
If dim([V]WICO_EQUNR) > 0   : Kill [V]WICO_EQUNR   : Endif
If dim([V]WICO_SCOWSTR) > 0 : Kill [V]WICO_SCOWSTR : Endif
If dim([V]WICO_TXTR) > 0    : Kill [V]WICO_TXTR    : Endif
If dim([V]WICO_VALR) > 0    : Kill [V]WICO_VALR    : Endif
If dim([V]WICO_MATR) > 0    : Kill [V]WICO_MATR    : Endif
If dim([V]WICO_GHOSTR) > 0  : Kill [V]WICO_GHOSTR  : Endif
If dim([V]WICO_OPER1) > 0   : Kill [V]WICO_OPER1   : Endif
If dim([V]WICO_OPER2) > 0   : Kill [V]WICO_OPER2   : Endif
If dim([V]WICO_OPER3) > 0   : Kill [V]WICO_OPER3   : Endif
If dim([V]GKEYMAT) > 0      : Kill [V]GKEYMAT      : Endif
If dim([V]GROUFLG) > 0      : Kill [V]GROUFLG      : Endif
If dim([V]SEL_NUM) > 0      : Kill [V]SEL_NUM      : Endif

# GH 07/02/2014 bug 96664
If SAVFONCTION<>GFONCTION
   GFONCTION=SAVFONCTION
Endif
Return

############################################################
$SETBOUT_ROUG
If [M:VROG]ROUFLG = 0
  ETABOU(GSPE1) = 0
  ETABOU(GSPE2) = 1
Else
  ETABOU(GSPE1) = 1
  ETABOU(GSPE2) = 0
Endif
If [M:VROG]ROUNUM='' or [M:VROG]ROUALT=0
  ETABOU(GSPE1) = 0
  ETABOU(GSPE2) = 0
  ETABOU(GSPE3) = 0
  ETABOU(GSPE4) = 0
  ETABOU(GSPE5) = 0
Else
  ETABOU(GSPE3) = 1
  ETABOU(GSPE4) = 1
  ETABOU(GSPE5) = 1
Endif
If [M:VROG]ROUNUM=''
  Call VIREBOUT(CHBOU,"<") From GOBJET
  Call VIREBOUT(CHBOU,">") From GOBJET
Endif
# le bouton Cas d'emploi n'est valide que si on ne vient pas des cas d'emloi
If find("GESROW",GNAVIG(1..GPILNAV-1))
  ETABOU(GSPE4) = 0
Endif
Return

############################################################
$DEBUT_ROUG
Global Char GKEYMAT(type([M:VROG]KEYC)-10) : # GH 10/09/2014  bug 102531

Local Date LSTRDAT, LENDDAT
Local Integer LALT

Raz [M:VROG]
# If PARAM(1)=""
#    Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
#    [M:VROG]FCY = GFCY              : # Site GP par défaut
# Else
   [M:VROG]FCY = PARAM(1)
# Endif
[M:VROG]ROUNUM = PARAM(2)
[M:VROG]ROUALT = val(PARAM(3))
If PARAM(4)<>""
   [M:VROG]DATREF = PARAM(4)    # !!! peut être 0/0/0 !!!
Endif
If PARAM(2) <> ""
   Call AM_ROUNUM(PARAM(2)) From SUBVROUG
Endif

# Issue 104937 - 2015-11-25 by CCC : versioning in routes
If dim([M:VROG]ROUECCMAJ)>0
    [M:VROG]ROUECCMAJ = PARAM(5)
    [M:VROG]ROUECCMIN = PARAM(6)
    # If the version number is in parameters, it is a higher priority than the reference date
    If [M:VROG]ROUECCMAJ<>""
        Call GETECCDAT([M:VROG]ROUNUM, [M:VROG]FCY, [M:VROG]ROUECCMAJ, [M:VROG]ROUECCMIN, LSTRDAT, LENDDAT) From SUBVROUG
        [M:VROG]ROUECCSTR = LSTRDAT
        [M:VROG]ROUECCEND = LENDDAT
        If [M:VROG]DATREF<LSTRDAT | [M:VROG]DATREF>LENDDAT
            [M:VROG]DATREF=LSTRDAT
        Endif
    # else if version number is missing, we can initialize it
    Elsif [M:VROG]ROUNUM<>"" & [M:VROG]FCY<>"" & [M:VROG]DATREF<>[0/0/0] & func RVMLIB.NBRCPNROU([M:VROG]ROUNUM)>0
        LALT = [M:VROG]ROUALT
        Call GETECCVAL([M:VROG]ROUNUM, [M:VROG]FCY, [M:VROG]DATREF, LALT, [M:VROG]ROUECCMAJ, [M:VROG]ROUECCMIN, [M:VROG]ROUECCSTR, [M:VROG]ROUECCEND) From SUBVROUG
    Endif

Endif

# GH 07/02/2014 bug 96217
If dim([M:VROG]LIKQTY2)>0 & dim([M:VROG]FMTQTY2)>0
  # détermination de FMTQTY2 selon le type de donnée du champ LIKQTY de l'écran
  Local Decimal LNG

  If clalev([F:AMZ])=0 : Local File AMSKZON [AMZ] : Endif
  If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif

  Read [AMZ]CODE = "VISUBOMROU";"LIKQTY"
  If !fstat
    If [F:ATY]CODTYP<>[F:AMZ]CODTYP
      Read [ATY]CODTYP = [F:AMZ]CODTYP
    Endif
    LNG=[F:AMZ]LONG
  Endif
  If fstat
    Read [ATY]CODTYP = ""
    If fstat : Raz [F:ATY] : Endif
  Endif
  If [F:ATY]LNGTYP<>0 : LNG = [F:ATY]LNGTYP : Endif

  If LNG=0
    [M:VROG]FMTQTY2 = "N:"+num$(type([M:VROG]LIKQTY2)-10)+"F"
  Elsif int(LNG)=LNG
    [M:VROG]FMTQTY2 = "N:"+num$(LNG)+"F"
  Else
    [M:VROG]FMTQTY2 = "N:"+num$(LNG)+"#"
  Endif
Endif

## GH 20/03/2013 bug 86834
If (dim([M:VROG]SETTIM2)>0 | dim([M:VROG]OPETIM2)>0) & dim([M:VROG]FMTTIM2)>0
  # détermination de FMTTIM2 selon le type de donnée du champ OPETIM de l'écran
  Local Decimal LNG

  If clalev([F:AMZ])=0 : Local File AMSKZON [AMZ] : Endif
  If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif

  Read [AMZ]CODE = "VISUROUG";"OPETIM"
  If !fstat
    If [F:ATY]CODTYP<>[F:AMZ]CODTYP
      Read [ATY]CODTYP = [F:AMZ]CODTYP
    Endif
    LNG=[F:AMZ]LONG
  Endif
  If fstat
    Read [ATY]CODTYP = ""
    If fstat : Raz [F:ATY] : Endif
  Endif
  If [F:ATY]LNGTYP<>0 : LNG = [F:ATY]LNGTYP : Endif

  If LNG=0
    [M:VROG]FMTTIM2 = "N:"+num$(type([M:VROG]OPETIM2)-10)+"F"
  Elsif int(LNG)=LNG
    [M:VROG]FMTTIM2 = "N:"+num$(LNG)+"F"
  Else
    [M:VROG]FMTTIM2 = "N:"+num$(LNG)+"#"
  Endif
Endif

# RECHERCHE DES NOMENCLATURES ASSOCIEES AU COUPLE GAMME+ALT
[M:VROG]BOMALTTYP=2
[M:VROG]BOMALT = func SUBVROUG.INIBOMALT([M:VROG]ROUNUM,[M:VROG]ROUALT,[M:VROG]BOMALTTYP)

# Issue 104937 - 2015-11-25 by CCC : versioning in routes
If [M:VROG]BOMALT<>0 & func ECCLIB.NBRCPN([M:VROG]ROUNUM)>0
    Filter [EVL] Where [F:EVL]ITMREF=[M:VROG]ROUNUM
&                    & [F:EVL]ECCTYP=2
&                    & [F:EVL]BOMALT=[M:VROG]BOMALT
&                    & [F:EVL]STRDAT<=[M:VROG]DATREF
&                    & ([F:EVL]ENDDAT>=[M:VROG]DATREF | [F:EVL]ENDDAT=[0/0/0])
    Read [EVL] First
    Filter [EVL]
    If fstat
        Filter [EVL] Where [F:EVL]ITMREF=[M:VROG]ROUNUM
&                        & [F:EVL]ECCTYP=2
&                        & [F:EVL]BOMALT=[M:VROG]BOMALT
&                        & ([F:EVL]STRDAT<=[M:VROG]ROUENDDAT | [M:VROG]ROUENDDAT=[0/0/0])
&                        & ([F:EVL]ENDDAT>=[M:VROG]ROUSTRDAT | [M:VROG]ROUSTRDAT=[0/0/0] | [F:EVL]ENDDAT=[0/0/0])
        Read [EVL] First
        Filter [EVL]
    Endif
    If !fstat
        [M:VROG]BOMECCMAJ = [F:EVL]ECCVALMAJ
        [M:VROG]BOMECCMIN = [F:EVL]ECCVALMIN
    Else    # No correct BOM version found
        [M:VROG]BOMALT = 0
    Endif
Endif

If [M:VROG]ROUALT <> 0 & [M:VROG]ROUNUM <> "" & [M:VROG]FCY<>""
  Grizo [VROG]ROUALT,ROUNUM,FCY        # FQ 63457 GA 03/2010
  # Issue 104937 - 2015-11-25 by CCC : versioning in routes
  If dim([M:VROG]ROUECCMAJ)>0
    Call AFFECC([M:VROG]ROUNUM,[M:VROG]FCY,[M:VROG]ROUALT,[M:VROG]BOMALT) From SUBVROUG
  Endif

  Gosub TRT_AFFROU
Else
  Affzo [VROG]
Endif
Return

############################################################
$APRES_MODIF_ROUG
#Case COUZON
#  When "FCY"       : [M:VROG]FCY    = CZ
#  When "ROUALT"    : [M:VROG]ROUALT = val(CZ)
#  When "ROUNUM"    : [M:VROG]ROUNUM = CZ
#  When "DATREF"    : [M:VROG]DATREF = CZ
#Endcase
If COUZON="DATREF" & [M:VROG]ROUALT <> 0 & [M:VROG]ROUNUM <> "" & [M:VROG]FCY<>""
    [M:VROG]DATREF = CZ
    Gosub TRT_AFFROU
Endif
Return

############################################################
$TRT_AFFROU
Local Integer LECCFLG, LRVMFLG

# Lecture alternative
Read [TRO1]TRO0=[M:VROG]ROUALT
If fstat
  FIN = 1
  Return
Endif
#
Read [ROH1]ROH1= [M:VROG]FCY;[M:VROG]ROUNUM;[M:VROG]ROUALT
If fstat :
 GMESSAGE = [M:VROG]ROUNUM-"("+[M:VROG]FCY+")"-mess(153,196,1)
 GERR =1 : FIN=1 : Return
Endif

[M:VROG] = [F:ROH1]
Affzo [VROG]5-20

# Issue 104937 - 2015-11-25 by CCC : versioning in routes
LECCFLG = func ECCLIB.NBRCPN([M:VROG]ROUNUM)
LRVMFLG = func RVMLIB.NBRCPNROU([M:VROG]ROUNUM)
If LRVMFLG>0
    # If the route is managed by version, we take the validity period of the version instead of header
    Call GETECCDAT([M:VROG]ROUNUM, [M:VROG]FCY, [M:VROG]ROUECCMAJ, [M:VROG]ROUECCMIN, [F:ROH1]ROUSTRDAT, [F:ROH1]ROUENDDAT) From SUBVROUG
Endif
# Control validity period in the header or in the version.
# If at least the product is managed by version => the reference date has to be known (in fact this control has to be done before, here it's just a safety control)
If  [M:VROG]DATREF=[0/0/0] & LECCFLG=0
& | ( ([M:VROG]DATREF >= [F:ROH1]ROUSTRDAT | [F:ROH1]ROUSTRDAT=[0/0/0])
&   & ([M:VROG]DATREF <= [F:ROH1]ROUENDDAT | [F:ROH1]ROUENDDAT=[0/0/0]))
  Gosub DISPLAY_ROUG
Else
  Gosub DISPLAY_ROUG
  If GERR=0
     GMESSAGE = mess(8,193,1) : # Gamme non valide à la date indiquée
     GERR     = 2
  Endif
Endif
[M:VROG]ROUFLG = 0   : # Seul le 1er niveau est déplié
Return

############################################################
$DISPLAY_ROUG   : # selon ancien traitement VISUGAM
Local Char    TEMPITM(GLONITM)
Local Integer TEMPALT
Local Char    WFCY(GLONFCY)
Local Char    WROU(GLONITM)
Local Integer WROUALT

# FGR 02/10/2009 : X3SUIVI58337
#[M:VROG]ROUDES    = [F:ROH1]ROUDES
Call LECTEXTRA([M:VROG]ROUDES,"ROUTING", "ROUDESAXX", [M:VROG]ROUNUM+"~"+num$([M:VROG]ROUALT),[M:VROG]FCY) From ATEXTRA
Affzo [VROG]ROUDES

If dim(L)<0
  Local Integer L, WLEVEL, WLIGNE, WPLIGNE
Endif

# génération de la liste
nolign  = 1
L       = nolign -1
WLEVEL  = 0
WLIGNE  = 0
WPLIGNE = 0

# Vider le XSL des composants
Effzo [VROG]25

# GH 07/02/2014 bug 96664
If [M:VROG]FCY<>"" &  GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE & !find([M:VROG]FCY,GUSRFCY(1..GNBAUZ))
   GERR=1 : GMESSAGE = mess(48,193,1) : # Alternative non valide sur ce site !
   Return
Endif

# sauvegarde des valeurs (on les perd sinon)
TEMPITM = [M:VROG]ROUNUM
TEMPALT = [M:VROG]ROUALT

WROUALT=[M:VROG]ROUALT
WROU   =[M:VROG]ROUNUM
WFCY   =[M:VROG]FCY

Gosub ADD_PROD
Call GEN_LISTE_RECETTE(L, WLEVEL,WLIGNE, WPLIGNE, [M:VROG]DATREF, [M:VROG]ITMREF, [M:VROG]BOMALT, 2, WFCY, WROU , WROUALT)

[M:VROG]ROUNUM = TEMPITM
[M:VROG]ROUALT = TEMPALT
Affzo [VROG]25

nolign  = 1
Call AS_NBLIG From SUBVROUG

Return

# Issue 104937 - 2015-11-25 by CCC : route versioning : this subprog is not used => don't update it
###################################################################
## Nomenclature valide ?
#Subprog VERIF_BOM (LDAT , LITMREF , LBOMALT , LBOMALTTYP, VALFLG )
## LDAT : date référence
