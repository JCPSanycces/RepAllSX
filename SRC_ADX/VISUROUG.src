############################################################
Funprog CTL_FIC_ICONE (LNOMICON)
Value Char LNOMICON
Local Integer WOK : WOK=2

Local Char WREPERT(200),WDIRSEP
Case GOS(1)
 When "dos"  : WDIRSEP="\"
 When Default : WDIRSEP="/"
Endcase

WREPERT=filpath("X3_ROOT"+WDIRSEP+"RESSTD"+WDIRSEP+"IMG","","","X3_PUB")
If LNOMICON<>"" & filinfo(WREPERT+WDIRSEP+LNOMICON,0)<0
   WOK = 1
Endif
End WOK

##############################################################
# Gestion des boutons Premier, Précédent, Suivant et Dernier #
##############################################################
$CHARGE_DATA
# Raz [M:VROG]
[M:VROG]ROUFLG = 0
[M:VROG] = [F:ROH1]
[M:VROG]ROUNUM = [F:ROH1]ITMREF
Affzo [VROG] 5-20
# Contrôle validité entête
If [F:ROH1]ROUENDDAT = [0/0/0]
   [F:ROH1]ROUENDDAT = [31/12/2999]
Endif
Gosub DISPLAY_ROUG
If clalev([F:ROH]) : Close Local File [ROH] : Local File ROUTING [ROH] : Endif
Read [ROH]ROH0=[F:ROH1]ITMREF;[F:ROH1]ROUALT;[F:ROH1]FCY
Return

$SET_ROH1
Read [ROH1]ROH0= [M:VROG]ROUNUM;[M:VROG]ROUALT;[M:VROG]FCY
Return

$DROIT
OK = ([F:ROH1]FCY="" |  GUSRFCY(1)="\"  | GNBAUZ=GNBSITE | find([F:ROH1]FCY,GUSRFCY(1..GNBAUZ)))
Return

$FIR_ROUG
  Read [ROH1]ROH0 First
  If fstat > 2
    Call MESSAGE(mess(11,100,1)) From GESECRAN
    Return
  Endif
  Gosub DROIT
  If !OK : Goto SUI_ROUG : Endif
  Gosub CHARGE_DATA
Return

$PRE_ROUG
  Read [ROH1]ROH0 Prev
  If fstat > 2
    Call MESSAGE(mess(11,100,1)) From GESECRAN
    Return
  Endif
  Gosub DROIT
  If !OK : Goto PRE_ROUG : Endif
  Gosub CHARGE_DATA
Return

$SUI_ROUG
  Read [ROH1]ROH0 Next
  If fstat > 2
    Call MESSAGE(mess(11,100,1)) From GESECRAN
    Return
  Endif
  Gosub DROIT
  If !OK : Goto SUI_ROUG : Endif
  Gosub CHARGE_DATA
Return

$LAS_ROUG
  Read [ROH1]ROH0 Last
  If fstat > 2
    Call MESSAGE(mess(11,100,1)) From GESECRAN
    Return
  Endif
  Gosub DROIT
  If !OK : Goto PRE_ROUG : Endif
  Gosub CHARGE_DATA
Return

