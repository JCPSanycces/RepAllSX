#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
  Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "DEBUT"        : Gosub DEBUT
  When "OK"           : Gosub OK
  Endcase
Return

$OUVRE
  If clalev([F:CPYNA])=0 : Local File HRCOMPANYNA [CPYNA]  : Endif

Return

$DEBUT
  Raz [M:CPYNA]
  [M]CPY = [M:CPY0]CPY
  Read [F:CPYNA]CPYNA0 = [M:CPY0]CPY
  If !fstat
    [M:CPYNA] = [F:CPYNA]
  Else
    Return
  Endif

  Affzo [M:CPYNA]

Return

$OK
  Trbegin [F:CPYNA]
  Read [F:CPYNA]CPYNA0 = [M:CPY0]CPY
  If fstat
    [F:CPYNA]    = [M:CPYNA]
    [F:CPYNA]CPY = [M:CPY0]CPY
    Write [F:CPYNA]
    Commit
  Else
    [F:CPYNA] = [M:CPYNA]
    Rewrite [F:CPYNA]
    Commit
  Endif
  If fstat
    GOK=0 : Call FSTA("CPYNA") From GLOCK
  Endif

  If !GOK : Goto AB_TR1 : Return : Endif

Return

$AB_TR1
  Rollback
  Call ERREUR(mess (17,107,1)) From GESECRAN :#Rollback suite à une erreur dans la transaction

Return

