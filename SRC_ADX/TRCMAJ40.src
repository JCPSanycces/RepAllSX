#CHECK MIGRATE_SOURCE
# ----------------------------------------------------------------------------- #
# TRCMAJ40 : M.a.j à effectuer lors du passage à version 7  Module Tronc commun #
# ----------------------------------------------------------------------------- #
#                                                                               #
# Avant mise à jour : ATRCMAJ40                                                 #
#                                                                               #
#   - TABVACBPR : Nouvelle table régime de taxe initialisée à partir de ATABDIV #
#   - TABVACITM : Nouvelle table niveau de taxe initialisée à partir de ATABDIV #

#                                                                               #
#################################################################################
#                                                                               #
#                                                                               #
# Après mise à jour : TRCMAJ40                                                  #
#                                                                               #
#   - UPDICT   : Met à jour les tables INCOTERM/INCOTERMD(Incoterms)            #
#   - UPDITG   : Met à jour la table ITMCATEG                                   #
#                                                                               #
#################################################################################


#################################################################################
# Moulinette : Structure tables avec anciens et nouveaux champs                 #
#################################################################################

Subprog ATRCMAJ40

Local Integer WOUV_TRACE
If GTRACE = ""
    Call OUVRE_TRACE("DOSMAJ40 : Process for common data") From LECFIC
    WOUV_TRACE=1
Endif

# 71937 : Multilégislation
# Passage en V7
#Table TABVACBPR - Transformation ADI ==> Table
Call RAZ_TABVACBPR([F:ADS]DOSSIER) From UTITRC7
Call MAJ_TABVACBPR([F:ADS]DOSSIER) From UTITRC7

#Table TABVACITM - Transformation ADI ==> Table
Call RAZ_TABVACITM([F:ADS]DOSSIER) From UTITRC7
Call MAJ_TABVACITM([F:ADS]DOSSIER) From UTITRC7

#Table TABVAC - LEG déjà présente ==> Traitement de ATEXTRA
Call MAJ_TABVAC([F:ADS]DOSSIER) From UTITRC7

#Table TABVAT - LEG déjà présente ==> Traitement de ATEXTRA + Alimentation LEG de TABRATVAT
Call MAJ_TABVAT([F:ADS]DOSSIER) From UTITRC7

#Table TABEECNAT
Call MAJ_TABEECNAT([F:ADS]DOSSIER) From UTITRC7

#Table TABEECSCH
Call MAJ_TABEECSCH([F:ADS]DOSSIER) From UTITRC7

#Table TABPIVTYP
Call MAJ_TABPIVTYP([F:ADS]DOSSIER) From UTITRC7

#Table TABSIVTYP
Call MAJ_TABSIVTYP([F:ADS]DOSSIER) From UTITRC7

#Table TABPAYTERM
Call MAJ_TABPAYTERM([F:ADS]DOSSIER) From UTITRC7

# 71937 : Multilégislation

# FGR 18/04/2014 : X3SUIVI97632/X3SUIVI99189 (début)
Call MAJ_UTITC44([F:ADS]DOSSIER) From UTITC44
# FGR 18/04/2014 : X3SUIVI97632/X3SUIVI99189 (fin)

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End


#################################################################################
# Moulinette : Structure définitive des tables                                  #
#################################################################################

Subprog TRCMAJ40

Local Integer WOUV_TRACE
If GTRACE = ""
    Call OUVRE_TRACE("DOSMAJ40 : Process for common data") From LECFIC
    Call ECR_TRACE( ' ', 0) From GESECRAN
    WOUV_TRACE=1
Endif

Local Integer NUMPROC
Raz NUMPROC

Onerrgo TRT_ERR

#---- Récupération table diverse 5 dans nouvelle table INCOTERM ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ40 TC Transactions Process "+num$(NUMPROC)+": Creation INCOTERMS") From DOSSUB
#Gbn-106947
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
  Call UPDICT([F:ADS]DOSSIER)
  If GOK<>1 : Onerrgo : End : Endif
Else
  Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
Endif

#---- Init nouveaux champs TABUNAVAIL ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ40 TC Transactions Process "+num$(NUMPROC)+": Update TABUNAVAIL") From DOSSUB
#Gbn-106947
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
  Call UPDTUV([F:ADS]DOSSIER)
  If GOK<>1 : Onerrgo : End : Endif
Else
  Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
Endif

#---- Init nouveaux champs ITMCATEG ------#
NUMPROC += 1
Call ECR_TIME("DOSMAJ40 TC Transactions Process "+num$(NUMPROC)+": Update ITMCATEG") From DOSSUB
#Gbn-106947
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
  Call UPDITG([F:ADS]DOSSIER)
  If GOK<>1 : Onerrgo : End : Endif
Else
  Call ECR_TRACE("Historic folder migration => Migration process not executed",0) From GESECRAN
Endif

If WOUV_TRACE=1
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
Endif

End

#################################################################################
$TRT_ERR
    Call ECR_TRACE( "ligne"-num$(errl)-":"-errm-errmes$(errn), 1) From GESECRAN
Resume

#################################################################################
# Récupération des codes Incoterms de la table diverse 5
#################################################################################
Subprog UPDICT(PDOS)
Value Char PDOS
Local Integer WI
Local Char    WINTDES(80)
Local File =PDOS+".INCOTERM"    [ICTH]
Local File =PDOS+".INCOTERMD"   [ICTD]
Local File =PDOS+".ATABDIV"     [ADI]
Local File =PDOS+".APLSTD"      [AST]
Local File =PDOS+".ATEXTRA"     [AXX]

Call DEBTRANS From GLOCK
Trbegin [ICTH]
Filter [F:ADI] Where NUMTAB = 5
For [F:ADI]
  Case [F:ADI]CODE
    When "EXW","FCA","CPT","CIP","DAP","DAT","DDP","FAS","FOB","CFR","CIF"  :
    When Default :
      Look [F:ICTH]ICT0 = [F:ADI]CODE
      If fstat
          WI+=1
          [F:ICTH]ICTCOD = [F:ADI]CODE
          Call DUPTEXTRA("ATABDIV","LNGDES",num$(5),[F:ADI]CODE,"INCOTERM","DES",[F:ICTH]ICTCOD,"") From ATEXTRA
          If find([F:ICTH]ICTCOD,"DES","DDU","DAF","DEQ")
            [F:ICTH]ENAFLG = 1
          Else
            [F:ICTH]ENAFLG = 2
          Endif
          Write [ICTH]
          If fstat
              Call FSTA("ICTH") From GLOCK
              Break 2
          Endif
          Raz [F:ICTD]
          [F:ICTD]ICTCOD = [F:ICTH]ICTCOD
          Filter [AST] Where LANCHP=2276 and LAN=GLANGUE and LANNUM <> 0
          For [AST] CLE
            [F:ICTD]CSTNAT = [F:AST]LANNUM
            [F:ICTD]CSTPYR = 1
            Write [F:ICTD]
            If fstat
              Call FSTA("ICTD") From GLOCK
              Break
            Endif
          Next
      Endif
  Endcase
Next
Filter [F:ADI]
Call ECR_TIME("DOSMAJ40 INCOTERM :"-num$(WI)-"record(s) created") From DOSSUB
Commit
End

#################################################################################
# Met à jour la table TABUNAVAIL
#################################################################################
# Le champ UVYPER est nouveau et doit être initialisé à 1
#################################################################################
Subprog UPDTUV(PDOS)
Value Char PDOS

Local Integer WI
Local File =PDOS+".TABUNAVAIL"    [TUV]

Call DEBTRANS From GLOCK
Trbegin [TUV]
For [TUV]
    [F:TUV]UVYPER = 1
    Rewrite [TUV]
    If fstat
        Call FSTA("TUV") From GLOCK
        Break
    Endif
Next
Commit

End

#################################################################################
# Met à jour la table ITMCATEG
#################################################################################
# Le CPRCOE : initialisé à 1 (Exi 70985 : landed cost)
# Le BASPRIORI : initialisé à 1 (Exi 86585 )
# Le ITMSFTTYP : initialisé à 1 (Exi portugaise )
#################################################################################
Subprog UPDITG(PDOS)
Value Char PDOS

Local File =PDOS+".ITMCATEG"    [ITG]

Call DEBTRANS From GLOCK
Trbegin [ITG]
For [ITG]
    [F:ITG]CPRCOE = 1
    [F:ITG]BASPRIORI = 1
    [F:ITG]ITMSFTTYP = 1
    Rewrite [ITG]
    If fstat
        Call FSTA("ITG") From GLOCK
        Break
    Endif
Next
Commit

End

