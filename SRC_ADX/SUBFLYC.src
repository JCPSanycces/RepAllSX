#<AdxTL>@(#)12.0.0.0 $Revision$
#############################################################################################
#   Composants technique de gestion de coupon de garantie  Module CRM       19 Septembre 2003
# CREFLY     : Sous-programme de création d'un coupon de garantie
# DELFLY     : Sous-programme de suppression d'un coupon de garantie
#############################################################################################
##########################################################
# Sous-programme de création d'un coupon de garantie
##########################################################
Subprog CREFLY(SZFLYNUM, IERRINF)
Variable Char SZFLYNUM
Variable Integer IERRINF

Local Char SZCOUNTER(GLONANM)
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer IBDEBTRANSFLG             # FGR 04/01/2011 : X3SUIVI70100
Local Integer IMANUAL                   # FGR 27/11/2014 : X3SUIVI104350

  # FGR 04/01/2011 : X3SUIVI70100 : ouverture des table au début
  ##############################################
  # Etape 1
  # Ouverture des tables nécessaires
  ##############################################
  If !clalev([F:FLYV]) : Local File WARFLYER [FLYV] : Endif
  If !clalev([F:TCA]) : Local File TABCOUAFF [TCA] : Endif
  If !clalev([F:ITM]) : Local File ITMMASTER [ITM] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
  If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  ##############################################
  IERRINF = 0
  SZMACNUM = ""
  # FGR 04/01/2011 : X3SUIVI70100 (début)
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [FLYV]
  Endif
  # FGR 04/01/2011 : X3SUIVI70100 (fin)
  # Suppression périodique des coupons de garantie.
  Call CLEANFLY(IERRINF)
  If IERRINF Then
    If IBDEBTRANSFLG = 0 Then           # FGR 04/01/2011 : X3SUIVI70100
      Rollback
    Endif
    End
  Endif
  ##############################################
  # Etape 2
  # Contrôle des informations obligatoires
  ##############################################
  #Site
  If [M:FLY0]FCY = "" Then
    #Le champ obligatoire SITE n'est pas qualifié.
    IERRINF = 448
    If IBDEBTRANSFLG = 0 Then           # FGR 04/01/2011 : X3SUIVI70100
      Rollback
    Endif
    End
  Endif
  #Code article
  If [M:FLY0]ITMREF = "" Then
    #Le champ obligatoire CODE ARTICLE n'est pas qualifié.
    IERRINF = 58
    If IBDEBTRANSFLG = 0 Then           # FGR 04/01/2011 : X3SUIVI70100
      Rollback
    Endif
    End
  Else
    Read [ITM]ITM0=[M:FLY0]ITMREF
    If fstat Then
      #Le code article indiqué sur le coupon de garantie est incorrect.
      IERRINF = 445
      If IBDEBTRANSFLG = 0 Then         # FGR 04/01/2011 : X3SUIVI70100
        Rollback
      Endif
      End
    Endif
  Endif
  #Origine
  If [M:FLY0]FLYORI < 1 Then
    #L'origine du coupon de garantie n'est pas précisée.
    IERRINF = 446
    If IBDEBTRANSFLG = 0 Then           # FGR 04/01/2011 : X3SUIVI70100
      Rollback
    Endif
    End
  Else
    If [M:FLY0]FLYORI > 3 Then
      #L'origine du coupon de garantie est incorrecte.
      IERRINF = 447
      If IBDEBTRANSFLG = 0 Then         # FGR 04/01/2011 : X3SUIVI70100
        Rollback
      Endif
      End
    Endif
  Endif
  If [M:FLY0]FLYORIVCR = "" Then
    #Le numéro de pièce origine n'est pas précisé.
    IERRINF = 64
    If IBDEBTRANSFLG = 0 Then           # FGR 04/01/2011 : X3SUIVI70100
      Rollback
    Endif
    End
  Endif
  ##############################################
  # Etape 3
  # Contrôle des informations facultatives
  ##############################################
  #Catégorie
  If [M:FLY0]FLYCAT <> "" Then
    Read [ADI]CODE=450;[M:FLY0]FLYCAT
    If fstat Then
      #La catégorie indiquée est incorrecte.
      IERRINF = 449
      If IBDEBTRANSFLG = 0 Then         # FGR 04/01/2011 : X3SUIVI70100
        Rollback
      Endif
      End
    Endif
  Endif
  #Site de vente
  If [M:FLY0]FCY <> "" Then
    Read [FCY]FCY0=[M:FLY0]FCY
    If fstat Then
      #Le site indiqué est incorrect.
      IERRINF = 450
      If IBDEBTRANSFLG = 0 Then         # FGR 04/01/2011 : X3SUIVI70100
        Rollback
      Endif
      End
    Endif
  Endif
  ##############################################
  # Etape 4
  # Calcul d'une clé primaire
  ##############################################
  #------------------------------------------------------------#
  # --> Récupération du code compteur                          #
  #------------------------------------------------------------#
  # ----------------------------------------------------------
  # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
  #  Read [TCA]TCA0=12
  #  If fstat Then
  #    #Aucun compteur n'a pu être identifié pour la création du coupon de garantie.
  #    IERRINF = 451
  #    If IBDEBTRANSFLG = 0 Then           # FGR 04/01/2011 : X3SUIVI70100
  #      Rollback
  #    Endif
  #    End
  #  Endif
  #  SZCOUNTER = [F:TCA]CODNUM(12)
  Read [F:FCY]FCY0=[M:FLY0]FCY
  Read [F:CPY]CPY0=[F:FCY]LEGCPY
  GSOCIETE = [F:CPY]CPY
  GCURLEG = [F:CPY]LEG
  Call READ_COUNTER([M:FLY0]FCY, 12, 12, GSOCIETE, GCURLEG, SZCOUNTER, IMANUAL) From CRM_UTIL
  GMANCOU = 1
  # FGR 20/12/2012 : X3SUIVI71937 (fin)
  # ----------------------------------------------------------
  #------------------------------------------------------------#
  # --> Calcul du code compteur                                #
  #------------------------------------------------------------#
  If func CRM_UTIL.GET_NUMERO_CHRONO ("HDK1", [M:FLY0]FCY, SZCOUNTER, date$, "", [M:FLY0]NUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
    If IBRETOUR = 0 Then
      # problème lors de la récupération du compteur
      #GMESSAGE = mess(IERRINF,ICHAPTER,1)
      IERRINF = 452
      If IBDEBTRANSFLG = 0 Then         # FGR 04/01/2011 : X3SUIVI70100
        Rollback
      Endif
      End
    Endif
  Endif
  ##############################################
  # Etape 5
  # On traite les cas particuliers
  ##############################################
  #Alimentation de BPANAM
  Case [M:FLY1]BPATYP
    When 1
      Read [BPR]BPR0=[M:FLY1]BPANUM
      If fstat Then
        [M:FLY1]BPANAM = [M:FLY1]BPANUM
      Else
        [M:FLY1]BPANAM = [F:BPR]BPRNAM
      Endif
    When 2
      Read [CPY]CPY0=[M:FLY1]BPANUM
      If fstat Then
        [M:FLY1]BPANAM = [M:FLY1]BPANUM
      Else
        [M:FLY1]BPANAM = [F:CPY]CPYNAM
      Endif
    When 3
      Read [FCY]FCY0=[M:FLY1]BPANUM
      If fstat Then
        [M:FLY1]BPANAM = [M:FLY1]BPANUM
      Else
        [M:FLY1]BPANAM = [F:FCY]FCYNAM
      Endif
    When 4
      Read [AUS]CODUSR=[M:FLY1]BPANUM
      If fstat Then
        [M:FLY1]BPANAM = [M:FLY1]BPANUM
      Else
        [M:FLY1]BPANAM = [F:AUS]NOMUSR
      Endif
    When Default
      [M:FLY1]BPANAM = [M:FLY1]BPANUM
  Endcase
  ##############################################
  # Dernière étape
  # On crée
  ##############################################
  #Trbegin [FLYV]                       # FGR 04/01/2011 : X3SUIVI70100
  Raz [F:FLYV]
  [F:FLYV] = [M:FLY0]
  [F:FLYV] = [M:FLY1]
  [F:FLYV] = [M:FLY2]
  [F:FLYV] = [M:FLY3]
  [F:FLYV]CREUSR = GUSER
  [F:FLYV]CREDAT = date$
  [F:FLYV]CREHOU = left$(time$, 2) + mid$(time$, 4, 2)
  Write [FLYV]
  If fstat Then
    #Echec de la transaction de création du coupon de garantie.
    IERRINF = 453
    If IBDEBTRANSFLG = 0 Then           # FGR 04/01/2011 : X3SUIVI70100
      Rollback
    Endif
    End
  Else
    If IBDEBTRANSFLG = 0 Then           # FGR 04/01/2011 : X3SUIVI70100
      Commit
    Endif
  Endif
  SZFLYNUM = [M:FLY0]NUM
End

###############################################################################
# Nettoyage automatique des coupons de garanties.
###############################################################################
Subprog CLEANFLY(IERRINF)
Variable Integer IERRINF

Local Integer ICANDEL
Local Date DDATE
Local Integer IBDEBTRANSFLG             # FGR 04/01/2011 : X3SUIVI70100

  If !clalev([F:FLY]) : Local File WARFLYER [FLY] : Endif
  If !clalev([F:DVA]) : Local File DEFVAL [DVA] : Endif
  # FGR 04/01/2011 : X3SUIVI70100 (début)
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [DVA]
  Endif
  # FGR 04/01/2011 : X3SUIVI70100 (fin)
  ICANDEL = 0
  #Avant tout, on teste si cela n'a pas déjà été fait pour cette journée.
  #Enregistre le nouveau ciblage
  Read [DVA]DVA0="FLY";"FLYER"
  If fstat Then
    #Call DEBTRANS From GLOCK           # FGR 04/01/2011 : X3SUIVI70100
    #Trbegin [DVA]                      # FGR 04/01/2011 : X3SUIVI70100
    [F:DVA]OBC = "FLY"
    [F:DVA]PARAM = "FLYER"
    [F:DVA]DATX(0) = date$
    Write [DVA]
    If fstat Then
      #La suppression périodique des coupons de garantie a échoué.
      IERRINF = 459
      #Rollback                         # FGR 04/01/2011 : X3SUIVI70100
    Else
      #Commit                           # FGR 04/01/2011 : X3SUIVI70100
      ICANDEL = 1
    Endif
  Else
    If [F:DVA]DATX(0) < date$ Then
      #Call DEBTRANS From GLOCK         # FGR 04/01/2011 : X3SUIVI70100
      #Trbegin [DVA]                    # FGR 04/01/2011 : X3SUIVI70100
      Readlock [DVA]DVA0="FLY";"FLYER"
      If fstat Then
        #La suppression périodique des coupons de garantie a échoué.
        IERRINF = 459
        #Rollback                       # FGR 04/01/2011 : X3SUIVI70100
      Else
        [F:DVA]OBC = "FLY"
        [F:DVA]PARAM = "FLYER"
        [F:DVA]DATX(0) = date$
        Rewrite [DVA]
        If fstat Then
          #La suppression périodique des coupons de garantie a échoué.
          IERRINF = 459
          #Rollback                     # FGR 04/01/2011 : X3SUIVI70100
          Unlock [DVA]
        Else
          #Commit                       # FGR 04/01/2011 : X3SUIVI70100
          Unlock [DVA]
          ICANDEL = 1
        Endif
      Endif
    Endif
  Endif
  If ICANDEL = 0 Then
    If IBDEBTRANSFLG = 0 Then           # FGR 04/01/2011 : X3SUIVI70100
      Commit
    Endif
    End
  Endif
  If IERRINF Then
    If IBDEBTRANSFLG = 0 Then           # FGR 04/01/2011 : X3SUIVI70100
      Rollback
    Endif
    End
  Endif
  #Suppression
  If GWARFLYLTI < 1 Then
    GWARFLYLTI = 30
  Endif
  DDATE = date$ - GWARFLYLTI
  #Call DEBTRANS From GLOCK             # FGR 04/01/2011 : X3SUIVI70100
  #Trbegin [FLY]                        # FGR 04/01/2011 : X3SUIVI70100
  Delete [FLY] Where [F:FLY]CREDAT < DDATE
  If fstat Then
    #La suppression périodique des coupons de garantie a échoué.
    IERRINF = 459
    #Rollback                           # FGR 04/01/2011 : X3SUIVI70100
  Else
    #Commit                             # FGR 04/01/2011 : X3SUIVI70100
  Endif
  # FGR 04/01/2011 : X3SUIVI70100 (début)
  If IERRINF Then
    If IBDEBTRANSFLG = 0 Then
      Rollback
    Endif
  Else
    If IBDEBTRANSFLG = 0 Then
      Commit
    Endif
  Endif
  # FGR 04/01/2011 : X3SUIVI70100 (fin)
End

##########################################################
# Sous-programme de suppression d'un coupon de garantie
##########################################################
Subprog DELFLY(SZFLYNUM, IERRINF)
Variable Char SZFLYNUM
Variable Integer IERRINF

Local Integer IBDEBTRANSFLG             # FGR 04/01/2011 : X3SUIVI70100

  IERRINF = 0
  If !clalev([F:FLY]) : Local File WARFLYER [FLY] : Endif
  # FGR 04/01/2011 : X3SUIVI70100 (début)
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  If IBDEBTRANSFLG = 0 Then
    Call DEBTRANS From GLOCK
    Trbegin [DVA]
  Endif
  # FGR 04/01/2011 : X3SUIVI70100 (fin)
  #Call DEBTRANS From GLOCK             # FGR 04/01/2011 : X3SUIVI70100
  #Trbegin [FLY]                        # FGR 04/01/2011 : X3SUIVI70100
  Delete [FLY] Where [F:FLY]NUM = SZFLYNUM
  If fstat Then
    #La suppression du coupon de garantie a échoué. Suppression interrompue.
    IERRINF = 464
    If IBDEBTRANSFLG = 0 Then           # FGR 04/01/2011 : X3SUIVI70100
      Rollback
    Endif
    End
  Endif
  If IBDEBTRANSFLG = 0 Then             # FGR 04/01/2011 : X3SUIVI70100
    Commit
  Endif
End
