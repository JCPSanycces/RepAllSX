End
##########################################################################################################
# Etape 5 de la définition d'un mailing                             Module CRM          16 janvier 2000  #
##########################################################################################################
# Définition du modèle de mailing
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "SETBOUT"      : Gosub SETBOUT
    When "DEBUT"        : Gosub DEBUT
    When "FINSAI"       : Gosub FINSAI
    When "BOUTON"       : Gosub BOUTON
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  If clalev ([F:OMR]) <= 0 : Local File OMMRPT [OMR] : Endif
  If clalev ([F:MXL]) <= 0 : Local File MAILXML [MXL] : Endif
Return

##########################################################################################################
$SETBOUT
  # -------------------------
  # Boutons :
  #          C-Confirmer
  # -------------------------
  # SHIMOD(ML936) : 1=Courrier 2=E-mail 3=Télécopie 4=XML
  If [M:MAY5]TYPMRGX <> 2 and [M:MAY5]MAGTPL = "" Then
    Call VIREBOUT(CHMEN, "C") From GOBJET
  Endif
  # -----------------------------
  Gosub SET_BOUT_SPE From GSAISIE
Return

##########################################################################################################
$BOUTON
  If BOUT = "C" Then
    # Confirmer
    If [M:MAI5]SHIMOD = 4 Then
      Local Char SZMAY5MAGTPL(type([M:MAY5]MAGTPL)-10)

      SZMAY5MAGTPL = toupper([M:MAY5]MAGTPL)
      If SZMAY5MAGTPL = "" Then
        #Un publipostage XML doit être indiqué.
        GMESSAGE = mess(663,182,1)
        GERR = 2
        Return
      Endif
      #Vérifie que le publipostage XML demandé existe
      Read [MXL]MXL0=SZMAY5MAGTPL
      If fstat Then
        #Le publipostage XML indiqué est incorrect.
        GMESSAGE = mess(664,182,1)
        GERR = 2
        Return
      Else
        [M:MAI5]TPL = toupper([M:MAY5]MAGTPL)
        [M:MAI5]TYPMRG = [M:MAY5]TYPMRGX
        GITPLSEL = 1
        FIN = 1
      Endif
    Else
      Gosub ONCONFIRM
    Endif
  Endif
Return

##########################################################################################################
$DEBUT
  [M:MAY5]MAGTPL = [M:MAI5]TPL
  [M:MAY5]TYPMRGX = [M:MAI5]TYPMRG
  Actzo [M:MAY5]TYPMRGX
  Affzo [M:MAY5]1-99
Return

##########################################################################################################
$FINSAI
  Raz [M:MAY5]
Return

##########################################################################################################
# Sous-programmes
##########################################################################################################
##########################################################################################################
$ONCONFIRM
Local Integer I2EXISTOK
Local Char SZ2TPLEND(30)
Local Char SZ2PROPERTPL(type([M:MAY5]MAGTPL)-10)
Local Char SZ2TPLSUFIX(3)
Local Integer IDLOADOK
Local Char SZACHEMIN(250)
Local Char SZAREPREP(250)
Local Integer IOMMTPL
Local Integer IMORETHREE

  I2EXISTOK = 0
  SZ2TPLEND = ""
  SZ2PROPERTPL = ""
  IDLOADOK = 0
  IOMMTPL = 0
  IMORETHREE = 1
  If len([M:MAY5]MAGTPL) < 4 Then
    IMORETHREE = 0
  Endif
  #
  #On détermine l'extension du modèle
  SZ2TPLSUFIX = "rpt"
  #Contrôle de l'extension .rpt
  If IMORETHREE Then
    SZ2TPLEND = right$([M:MAY5]MAGTPL, len([M:MAY5]MAGTPL)-3)
    If SZ2TPLEND = ".rpt" or SZ2TPLEND = ".RPT" Then
      Call REMTPLEXT([M:MAY5]MAGTPL, SZ2PROPERTPL) From CRM_UTIL
      [M:MAY5]MAGTPL = SZ2PROPERTPL
    Endif
  Endif
  Call ADDTPLEXT2(SZ2TPLSUFIX, [M:MAY5]MAGTPL, GSZNEWTPL) From CRM_UTIL
  [M:MAI5]TPL = toupper([M:MAY5]MAGTPL)
  [M:MAI5]TYPMRG = [M:MAY5]TYPMRGX
  GITPLSEL = 1
  FIN = 1
Return

##########################################################################################################
# Création d'une imprimante messagerie électronique
########################################################
Subprog GETEMAILIMP(SZCSVIMP, IERR)
Variable Char SZCSVIMP
Variable Integer IERR

Local Integer ICSVSUFFIX

  SZCSVIMP = ""
  IERR = 0
  ICSVSUFFIX = 1
  Local File APRINTER [AIM]
  Filter [AIM] Where [F:AIM]ENAFLG = 2 and [F:AIM]ACS = "" and [F:AIM]PRT = 3
  For [AIM]
    SZCSVIMP = [F:AIM]COD
    Break
  Next
  Filter [AIM]
  If SZCSVIMP <> "" : End : Endif
  SZCSVIMP = "EMAIL" + num$(ICSVSUFFIX)
  While 1
    Read [AIM]AIM0=SZCSVIMP
    If fstat Then
      #Création de l'imprimante CSV
      Trbegin [AIM]
      Raz [F:AIM]
      [F:AIM]COD = SZCSVIMP
      [F:AIM]ENAFLG = 2
      [F:AIM]PRT = 3
      [F:AIM]PRTFMT = 1
      [F:AIM]CREDAT = date$
      [F:AIM]CREUSR = GUSER
      Write [AIM]
      If fstat Then
        Rollback
        IERR = 1
      Else
        Commit
      Endif
      Break
    Else
      ICSVSUFFIX += 1
      SZCSVIMP = "EMAIL" + num$(ICSVSUFFIX)
    Endif
  Wend
End

##########################################################################################################
# Création d'une imprimante ActiveFax
########################################################
Subprog GETFAXIMP(SZCSVIMP, IERR)
Variable Char SZCSVIMP
Variable Integer IERR

Local Integer ICSVSUFFIX

  SZCSVIMP = ""
  IERR = 0
  ICSVSUFFIX = 1
  Local File APRINTER [AIM]
  Filter [AIM] Where [F:AIM]ENAFLG = 2
&                and [F:AIM]ACS = ""
&                and [F:AIM]PRT = 2
&                and [F:AIM]PRTSRV = ""
&                and [F:AIM]PRTNAM = "ActiveFax"
&                and [F:AIM]PRTTYP = 1
&                and [F:AIM]NBRCPY = 1
  For [AIM]
    SZCSVIMP = [F:AIM]COD
    Break
  Next
  Filter [AIM]
  If SZCSVIMP <> "" Then
    End
  Endif
  SZCSVIMP = "ACTFAX" + num$(ICSVSUFFIX)
  While 1
    Read [AIM]AIM0=SZCSVIMP
    If fstat Then
      #Création de l'imprimante CSV
      Trbegin [AIM]
      Raz [F:AIM]
      [F:AIM]COD = SZCSVIMP
      [F:AIM]ENAFLG = 2
      [F:AIM]PRT = 2
      [F:AIM]PRTSRV = ""
      [F:AIM]PRTNAM = "ActiveFax"
      [F:AIM]PRTTYP = 1
      [F:AIM]NBRCPY = 1
      [F:AIM]CREDAT = date$
      [F:AIM]CREUSR = GUSER
      Write [AIM]
      If fstat Then
        Rollback
        IERR = 1
      Else
        Commit
      Endif
      Break
    Else
      ICSVSUFFIX += 1
      SZCSVIMP = "ACTFAX" + num$(ICSVSUFFIX)
    Endif
  Wend
End

##########################################################################################################
# Création d'une imprimante de Prévisualisation
########################################################
Subprog GETPREVISUIMP(SZCSVIMP, IERR)
Variable Char SZCSVIMP
Variable Integer IERR

Local Integer ICSVSUFFIX

  SZCSVIMP = ""
  IERR = 0
  ICSVSUFFIX = 1
  Local File APRINTER [AIM]
  Filter [AIM] Where [F:AIM]ENAFLG = 2 and [F:AIM]ACS = "" and [F:AIM]PRT = 1 and [F:AIM]PRTSRV = ""
  For [AIM]
    SZCSVIMP = [F:AIM]COD
    Break
  Next
  Filter [AIM]
  If SZCSVIMP <> "" Then
    End
  Endif
  SZCSVIMP = "PREVISU" + num$(ICSVSUFFIX)
  While 1
    Read [AIM]AIM0=SZCSVIMP
    If fstat Then
      #Création de l'imprimante CSV
      Trbegin [AIM]
      Raz [F:AIM]
      [F:AIM]COD = SZCSVIMP
      [F:AIM]ENAFLG = 2
      [F:AIM]PRT = 1
      [F:AIM]CREDAT = date$
      [F:AIM]CREUSR = GUSER
      Write [AIM]
      If fstat Then
        Rollback
        IERR = 1
      Else
        Commit
      Endif
      Break
    Else
      ICSVSUFFIX += 1
      SZCSVIMP = "PREVISU" + num$(ICSVSUFFIX)
    Endif
  Wend
End
