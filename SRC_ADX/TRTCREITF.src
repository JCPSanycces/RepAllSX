#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################
# Traitement TRTCREITF - Creation article site                         #
########################################################################
# Action SAICREITF
########################################################################
$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "DEBUT"     : Gosub DEBUT
 When "SETBOUT"   : Gosub SETBOUT
 When "FINSAI"    : Gosub FINSAI
 When "BOUTON"   :
    Case BOUT :
        When "C" : Gosub CREATION_ITF
        When "I" : Call SELECT_ALL(2)
        When "E" : Call SELECT_ALL(1)
    Endcase
Endcase

Return

##########################################################################
$OUVRE

If clalev([F:FCY])=0 Local File FACILITY     [FCY]  Endif
If clalev([F:ITF])=0 Local File ITMFACILIT   [ITF]  Endif

Return

##########################################################################
$DEBUT
# chargement des droits pour la fonction GESITF
Local Char OFONCTION(20)
OFONCTION=GFONCTION
GFONCTION="GESITF" : Call AUTORIS From EXEFNC

Local Integer I
I = 0
If !instr(1,GUSRAUZ,"C")                           # hcb 90189
   Call ERREUR (mess(99,9009,1)) From GESECRAN     # hcb 90189 
   FIN  = 1                                        # hcb 90189
   Return                                          # hcb 90189
Endif     
Raz [M:ITF]
[M:ITF]TCLCOD  = [M:ITM0]TCLCOD
[M:ITF]ITMREF  = [M:ITM0]ITMREF
# Remplissage tableau avec  les sites donc l article n a pas ete créé
Local Char LFCY(GLONFCY)
Raz LFCY
Filter [FCY] Where WRHFLG=2
&            Order By Key FCY1
For [FCY]
    Call CONTFCY([F:FCY]FCY) From CPTSUB # controle habilitation
    If !mkstat
       Look [ITF]ITF0 = [M:ITM0]ITMREF;[F:FCY]FCY
       If fstat
          If I > dim([M:ITF]FCY) - 1
                 Call ERREUR (mess(26,100,1)-mess(50,139,1)-" : "-" CREITF") From GESECRAN
                 Break
          Endif
          [M:ITF]LEGCPY  (I) = [F:FCY]LEGCPY
          [M:ITF]FCY     (I) = [F:FCY]FCY
          [M:ITF]FCYNAM  (I) = [F:FCY]FCYNAM
          I += 1
       Endif
    Endif
Next
Filter [FCY]
[M:ITF]NBLIG = I

Affzo [M:ITF]1-99

# chargement des droits initiaux
GFONCTION=OFONCTION : Call AUTORIS From EXEFNC

Return

#########################################################################
$SETBOUT
# Pas de bouton  Creation   si pas de cochage

If !find( 2, [M:ITF]FLG(0..[M:ITF]NBLIG-1))
   Call VIREBOUT(CHMEN,"C") From GOBJET
Endif

Return
##########################################################################
$FINSAI

mkstat = 4

Return


######################################################################################
#--------------------------------------------#
# Paramètre E : PON = 1: Désélectionne tout
#                     2: Sélectionne tout
#--------------------------------------------#
Subprog SELECT_ALL(PON)
Value Integer PON  # FGR 01/02/2010 : X3SUIVI60986

Local Integer I
For I=0 To [M:ITF]NBLIG-1
    If PON=2
       [M:ITF]FLG(I) = 2
    Else
       [M:ITF]FLG(I) = 1
    Endif
Next I
Affzo [M:ITF]FLG
End

#--------------------------------------------#
# creation ITMFACILIT
#--------------------------------------------#
$CREATION_ITF

Local Char LFCY(GLONFCY)
Raz LFCY

#MAE, bg 68556, ajout de trace
If [M:ITF]TRACE=2             #MAE, bg 85175
  Call OUVRE_TRACE("CREITF") From LECFIC
  Call ECR_TRACE(mess(85,151,1)+" "+mess(14,752,1)+" "+mess(213,154,1)+" : "+[M:ITF]ITMREF,0) From GESECRAN
Endif

#MAE, bg76914
#Affectation du role
Local Char ABROL(GLONAOB)
ABROL = "ITF"
Gosub FILROLE From GOBJACT
#Fin bg76914

#--- Bug 80980
If [M:ITF]ITMREF<>[F:ITM]ITMREF
   Read [ITM]ITM0=[M:ITF]ITMREF
   If fstat
      Call RSTA("ITM",[M:ITF]ITMREF) From GLOCK
      GOK=0 : Return
   Endif
Endif
#---

Call DEBTRANS From GLOCK
Trbegin [ITF]
Local Integer Y
For Y=0 To [M:ITF]NBLIG-1
    If [M:ITF]FLG(Y) = 2
       LFCY = [M:ITF]FCY(Y)
       Gosub CRE_ITMFACILIT From SUBITM
       If GOK = 0
          Break
       Endif
    Endif
Next Y
Commit
#MAE, bg 68556
If [M:ITF]TRACE=2             #MAE, bg 85175
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
Gosub DEBUT
Return

######################################################################################
## Action ecran
######################################################################################
Subprog AM_FLG(VALEUR)
Variable Integer VALEUR
If !clalev([F:ITG1]) : Local File ITMCATEG [ITG1] : Endif
If !clalev([F:FCYS]) : Local File FACILITY [FCYS] : Endif
If !clalev([F:FCYR]) : Local File FACILITY [FCYR] : Endif

# obligé sinon le setbout ne marche pas pour le bouton "C"
[M:ITF]FLG(nolign-1) = VALEUR
#MAE, le 30/09/2010, bg67766, le site ne peut pas être choisi si le site de réapro de la catégorie article est sur une sté différente
If VALEUR = 2
    If [M:ITF]TCLCOD<>""
        Read [ITG1]ITG1=[F:ITM]TCLCOD;[M:ITF]FCY(nolign-1)
        If fstat
          Read [ITG1]ITG1=[F:ITM]TCLCOD;""
        Endif
        If [F:ITG1]REOFCY<>""
            Read [FCYR]FCY0=[F:ITG1]REOFCY
            If fstat : End : Endif
                Read [FCYS]FCY0=[M:ITF]FCY(nolign-1)
            If fstat : End : Endif
            If [F:FCYR]LEGCPY <> [F:FCYS]LEGCPY
                Call MESSAGE (mess(560,199,1)) From GESECRAN
                [M:ITF]FLG(nolign-1) = 1
                Affzo [M:ITF]FLG(nolign-1)
            Endif
        Endif
    Endif
Endif
End
