#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
##    SEGAY - 23/04/13 - FQ88082 - US1515 test ACS de TIM
######################################################################################

Call OBJET("CNE",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "SETBOUT"   : Gosub SETBOUT
 When "ANNULE"    : Gosub ANNULE
 When "FILTRE"    : Gosub FILTRE
 When "RAZDUP"    : Gosub RAZDUP
 When "LIENS"     : Gosub LIENS
 When "VERIF_CRE" : Gosub VERIF_CRE
 When "OUVRE"     : Gosub OUVRE
 When "FERME"     : Gosub FERME
 When "STYLE"     : Gosub STYLE
 When "RAZCRE"    : Gosub RAZCRE
Endcase
Return

###################################
$RAZDUP
For I=0 To [M]NBLIG-1
 [M]NBRPRI(I)=0
 [M]NBRCLE(I)=[M]NBRDAY(I)
Next
Affzo 20
Return

$RAZCRE
GCURLEG = ""
Return

$STYLE

  #LIPET - 31-10-2016 - X3PEOP-3635 - START
  Gosub DISPLAY_HIDE From SUBCNELEG
  Affzo [M:CNE1]
  #LIPET - 31-10-2016 - X3PEOP-3635 - END
Return

############################################################################################################
#La création manuelle d'une nouvelle fiche CNE est délicate si le module PAYE est présent,
#car c'est le calcul des bulletins qui doit créer ces fiches le moment venu (Mois de juin).
#Si il y a des reports de soldes négatifs à faire, de N-1 vers N, c'est à la création de ces fiches CNE que
#ces reports seront gérés.
#Si ces fiches CNE sont créées manuellement trop tôt, la gestion des reports de solde négatifs sera fausse !
#On demande donc CONFIRMATION de création !!!
# Exemple : On est en Février 2005 (Bulletin de Fev. 2005 calculé).
#           Fiche CNE de MAT1, entré en janv. 2005)
# Fiche CNE : 2005
# CP Acquis : 4
# CP Pris : 15            # Pose de CP sur Août 2005
# Solde CP : -11
#################
# Si l'utilisateur ne crée pas de fiche CNE manuellement sur 2006, le calcul du bulletin le fera
# correctement en juin et on obtiendra le résultat suivant :
#################
# Fiche CNE : 2005
# CP Acquis : 10          # 4(janv+fev)+2(mars)+2(avril)+2(mai)
# CP Pris : 15
# Solde CP : -5
##################
# Fiche CNE : 2006
# CP Acquis : 2    2(juin)
# CP Pris :  5            # Solde négatif de 2005
# Solde CP : -3
#################
# Si l'utilisateur crée une fiche CNE manuellement sur 2006 avant le mois de juin, en mars par ex,
# on obtiendra le résultat erroné suivant :
#################
# Fiche CNE : 2005
# CP Acquis : 6          # 4(janv+fev)+2(mars)
# CP Pris : 15
# Solde CP : -9
##################
# Fiche CNE : 2006
# CP Acquis : 0
# CP Pris :  9            # Solde négatif de 2005
# Solde CP : -9
############################################################################################################

##################################
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return
##################################
$OUVRE
  Call MANAGE_LOCALISATION("OCNE") From DIVPAYE
  If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return
###################################
$VERIF_CRE
If GPAYE
 OK = 1
 #Le module paie est présent : Etes-vous sûr de vouloir continuer ?
 Call OUINON(mess(129,10709,1),OK) From GESECRAN
 If OK<>2 : OK = 0 : Return : Endif
Endif
Return

###################################
$ANNULE
CRITERE -= '& REFNUM="'+[M:CNE1]REFNUM+'"'
Return

###################################
$SETBOUT
#Objet à 4 éléments de clé : Ajout du bouton suppression après que GOBJET l'ait viré !
#39925
#If CLECUR : CHAINE += "A" : Endif
#If CLECUR : CHAINE += "B" : Endif
If CLECUR & VERROU : CHAINE += "A" : Endif
If GREP<>"" | GHISTO=1
 Call VIREBOUT (CHAINE,"B") From GOBJET    :#Bouton extraction
Endif
Return

###################################
$FILTRE
If GUSRACS<>2
 FILTSUP = '([F:ID]CODACS="" or [F:ACC]CONSUL=2)'
 FILTSUP -= "& find([F:ECT]SRV,GAUTSRV(1..GNBSERV))"
Else
 FILTSUP ="1=1"
Endif
# FQ88082 - SEGAY 23/04/13 test ACS de TIM
# On ne filtre pas les listes car coté Back on doit voir toutes les lignes.
# On teste uniqument en saisie au contrôle de la nature d'évènement
#If GUSRACS<>2
#  If FILTSUP<>"" : FILTSUP += " & " : Endif
#  FILTSUP -= '([F:TIM]ACS="" or [F:ACCT]CONSUL=2)'
#Else
#  FILTSUP ="1=1"
#Endif
# END FQ88082
Return

###################################
$LIENS
  [M]NBRCLE(nolign-1)=[M]NBRDAY(nolign-1)-[M]NBRPRI(nolign-1)
  Gosub GRISE_CTR
  #GCURLEG = [F:TIM]LEG
  #LIPET - 2017-06-08 - X3PEOP-3635 - START
  If GLEGFIL <> ""
   GCURLEG = GLEGFIL
  Endif
  #LIPET - 2017-06-08 - X3PEOP-3635 - START

  #LIPET - 31-10-2016 - X3PEOP-3635 - START
  Call GET_LEG([M]CTRNUM)
  #LIPET - 31-10-2016 - X3PEOP-3635 - END

  #JASMI - 2016-11-01 - START
    Gosub STYLE
  #JASMI - 2016-11-01 - END
    Affzo [M:CNE1]
Return


$GRISE_CTR
# FQ86518 - MABON 17/12/12 - Si intermittent, on n'a pas FLGMULCTR coché, mais on peut quand même avoir plusieurs contrats
# D'où l'ajout du test sur FLGINT
If [F:ID]FLGMULCTR=2
#If [F:ID]FLGMULCTR=2 | [F:ID]FLGINT=2
 Actzo CTRNUM
Else
 Diszo CTRNUM
Endif
Affzo CTRNUM

#FLNEL - need to get company number from contract, to get the right dates for leave event
 Read [ECT]ECT0=[M]REFNUM;[M]CTRNUM
 If !fstat
  Call LECTURE("FCY",[F:ECT]FCY,"") From CONTOBJ
 Endif

Return

########################################
Subprog C_YEA(VALEUR)
Variable Decimal VALEUR
If VALEUR<1900
 GMESSAGE = mess(106,10709,1) : # Année incorrecte
 mkstat = 2 : End
Endif
End

########################################
Subprog AS_NBLIG
Local Integer WACS
Local Char WCPA(GLONTPS),WCPE(GLONTPS) : # FQ76178 US1931 - SEGAY 18/09/13
#If GUSER="FLNEL" : Dbgaff : Endif
If clalev([F:ECT])=0 : Local File EMPCTR [ECT] : Endif

If [M]NBLIG=0 & GREP="C"
 Read [ECT]ECT0=[M]REFNUM;[M]CTRNUM
 If !fstat
  Call LECTURE("FCY",[F:ECT]FCY,"") From CONTOBJ
  nolign = 0
  For [CNG] Where YEA=[M]YEA & CPY=[F:FCY]LEGCPY
# FQ74044 - SEGAY 02/03/12 - Ajout vérification du nouveau champ FILTRE
#   nolign += 1
#   [M]TIM(nolign-1) = [F:CNG]TIM
   # FQ88082 - SEGAY 23/04/13 test ACS de TIM
   WACS = 1
   #ADNGO - 22-02-2017 - X3PEOP-3635 - START
   #Call LECTURE("HRTIM",[F:CNG]TIM,"") From CONTOBJ
   Call LECTURE("HRTIM",[F:CNG]TIM,GCURLEG) From CONTOBJ
   #ADNGO - 22-02-2017 - X3PEOP-3635 - END
   If [F:TIM]ACS<>"" & GUSRACS<>2
      Read [ACC]CODACC = GUSER;[F:TIM]ACS
      If (fstat or [F:ACC]EXEC<>2) Then
        WACS = 0
      Endif
   Endif
   # FQ76178 US1931 - SEGAY 18/09/13
   If [L]WACS Then
     Call PARAM("","CPA",WCPA) From ADOVAL
     Call PARAM("","CPE",WCPE) From ADOVAL
     # FQ76178 US1931 - SEGAY 18/09/13 - On fait le test sur TYPCP pour CPE et CPA idem dans CNSCNGSTD, CNSCCSTD et GETLSTCCG de PORTPS
     Call VERIF_TYPCP([F:ECT]FCY,[L]WCPA,[L]WCPE,[F:CNG]TIM,[L]WACS) From CNSCNGSTD
   Endif
  # END FQ76178
   If WACS Then
   # END FQ88082
     If [F:TIM]FILTRE<>"" | [F:TIM]POP<>"" Then
        Local Integer RET
        Call VERIF_FILTRE_TIM([F:TIM]FILTRE,[F:TIM]POP,[M]REFNUM,[M]CTRNUM,RET) From DIVPAYE
        If RET<1 Then
           nolign += 1
           [M]TIM(nolign-1) = [F:CNG]TIM
#FLNEL 7 Apr 2014 - populate start and end dates in leave line
           Call AM_TIM([M]TIM(nolign-1))
        Endif
     Else
       nolign += 1
       [M]TIM(nolign-1) = [F:CNG]TIM
#FLNEL 7 Apr 2014 - populate start and end dates in leave line
       Call AM_TIM([M]TIM(nolign-1))

     Endif
   Endif
   # Fin FQ74044
  Next
  [M]NBLIG = nolign
  Affzo 20
 Endif

Endif
End

########################################
Subprog C_TIM(VALEUR)
Variable Char    VALEUR()
# FQ76178 US1931 2006 - SEGAY 18/09/13
Local Char WCPA(GLONTPS),WCPE(GLONTPS)
Local Integer WOK
If clalev([F:ECT])=0 : Local File EMPCTR [ECT] : Endif
# END FQ76178
#JASMI - 2016-10-31 - START
#Call LECTURE("HRTIM",VALEUR,"") From CONTOBJ
  Read [F:TIM]TIM0 = GCURLEG;VALEUR
  If !fstat
    If [F:TIM]LEG<>"" & [F:TIM]LEG<>GCURLEG
      GMESSAGE = VALEUR-":"-mess(62,127,1)-":"-[F:TIM]LEG
      mkstat = 2 : End
    Endif
  Endif
#JASMI - 2016-10-31 - END
If [F:TIM]CATTIM<>3
 GMESSAGE = mess(105,10709,1) : # Type d'événement incorrect
 mkstat = 2 : End
Endif
# FQ88082 - SEGAY 23/04/13 test ACS de TIM
If [F:TIM]ACS<>"" & GUSRACS<>2
 Read [ACC]CODACC = GUSER;[F:TIM]ACS
 Call CONTEXE([F:TIM]ACS) From CPTSUB
 If mkstat : End : Endif
Endif
# END FQ88082

# FQ74044 - MABON 13/02/12 - Ajout vérification du nouveau champ FILTRE
If [F:TIM]FILTRE<>"" | [F:TIM]POP<>"" Then
  Local Integer RET
  Call VERIF_FILTRE_TIM([F:TIM]FILTRE,[F:TIM]POP,[M:CNE1]REFNUM,[M:CNE1]CTRNUM,RET) From DIVPAYE
  If RET>0 Then
    GMESSAGE=VALEUR-":"-mess(320,199,1) : # Nature d'événement incompatible avec ce salarié
    mkstat=2 : End
  Endif
Endif
# Fin MABON
# FQ76178 US1931 2006 - SEGAY 18/09/13
Call PARAM("","CPA",WCPA) From ADOVAL
Call PARAM("","CPE",WCPE) From ADOVAL
# FQ76178 US1931 2006 - SEGAY 18/09/13 - On fait le test sur TYPCP pour CPE et CPA idem dans CNSCNGSTD, CNSCCSTD et GETLSTCCG de PORTPS
[L]WOK = 1


Case VALEUR
  When WCPA,WCPE
    Read [ECT]ECT0=[M]REFNUM;[M]CTRNUM
    If !fstat
       Call VERIF_TYPCP([F:ECT]FCY,[L]WCPA,[L]WCPE,VALEUR,[L]WOK) From CNSCNGSTD
    Endif
Endcase
If ![L]WOK
    GMESSAGE = mess(105,10709,1) : # Type d'événement incorrect
    mkstat = 2 : End
Endif
# END FQ76178
Call UNICITE(VALEUR,[M]TIM) From OBJDIV
End

########################################
Subprog AM_NBRDAY(VALEUR)
Variable Decimal VALEUR
[M]NBRCLE(nolign-1)=VALEUR-[M]NBRPRI(nolign-1)
Affzo [M]NBRCLE(nolign-1)
End

#En création et duplication, on reporte les soldes négatifs...
########################################
Subprog AS_NBRPRI(VALEUR)
Variable Decimal VALEUR
If clalev([F:CNE2])=0 : Local File CNGEMP    [CNE2] : Endif
If VALEUR=0 & (GREP="C" |GREP="D")
 Filter [F:CNE2] Where YEA<[M]YEA & REFNUM=[M]REFNUM & TIM=[M]TIM (nolign-1)
 Read [F:CNE2]CNE0 Last
 Filter [F:CNE2]
 If ! fstat & [F:CNE2]NBRDAY-[F:CNE2]NBRPRI<0
  VALEUR=abs([F:CNE2]NBRDAY- [F:CNE2]NBRPRI)
  [M]NBRCLE(nolign-1)=[M]NBRDAY(nolign-1)-VALEUR
 Endif
Endif
End

########################################
Subprog AM_NBRPRI(VALEUR)
Variable Decimal VALEUR
[M]NBRCLE(nolign-1)=[M]NBRDAY(nolign-1)-VALEUR
Affzo [M]NBRCLE(nolign-1)
End

########################################
Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
# FQ86518 - MABON 17/12/12 - Si intermittent, on n'a pas FLGMULCTR coché, mais on peut quand même avoir plusieurs contrats
# D'où l'ajout du test sur FLGINT
If [F:ID]FLGMULCTR<>2
#If [F:ID]FLGMULCTR<>2 & [F:ID]FLGINT<>2
 Filter [HRCTR] Where REFNUM=VALEUR
 Read [HRCTR]CTR1 Last
 Filter [HRCTR]
 If !fstat
  [M]CTRNUM = [F:HRCTR]CTRNUM
  Call GET_LEG([M]CTRNUM)
 Else
  #Pas de contrat de travail pour ce salarié
  GMESSAGE = mess(150,10702,1)
  mkstat = 2 : End
 Endif
Endif
Gosub GRISE_CTR
End

######################################################################################
## Section automatically added (screen CNE1) 03/12/2014 12:18:33 (FLNEL)
## 19/05/2014 FLNEL - changes subprogram to call a common subprogram in SUBCNEKSA
######################################################################################
#JASMI - 2014-09-04 - START
Subprog AM_TIM(VALEUR)
Variable Char    VALEUR()
#JASMI - 2016-12-01 - START
#If func AFNC.ACTIV("KSA")>0 Then
If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
#JASMI - 2016-12-01 - END
#JASMI - 2014-10-29 - 2999 - START
#  Call CALC_LVE_DATES_KSA(VALEUR,[F:FCY]LEGCPY,[M]YEA,[M]REFNUM,[M]CTRNUM,
#&                         [M]EMPLEASTR(nolign-1),[M]EMPLEAEND(nolign-1),
#&                         [M]EMPCYCSTR(nolign-1),[M]EMPCYCEND(nolign-1)) From SUBCNEKSA
  Local Integer NEWYEA : [L]NEWYEA = 0
  Call CALC_LVE_DATES_KSA(VALEUR,[F:FCY]LEGCPY,[M]YEA,[M]REFNUM,[M]CTRNUM,
&                         [M]EMPLEASTR(nolign-1),[M]EMPLEAEND(nolign-1),
&                         [M]EMPCYCSTR(nolign-1),[M]EMPCYCEND(nolign-1),
&                         [0/0/0],[L]NEWYEA) From SUBCNEKSA
#JASMI - 2014-10-29 - 2999 - END
  Affzo  [M]EMPLEASTR(nolign-1)
  Affzo  [M]EMPLEAEND(nolign-1)

#JASMI - 2014-09-04 - START
  Affzo  [M]EMPCYCSTR(nolign-1)
  Affzo  [M]EMPCYCEND(nolign-1)
#JASMI - 2014-09-04 - END
Endif
End
#JASMI - 2014-09-04 - END


Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()

#LIPET - 31-10-2016 - X3PEOP-3635 - START
Call GET_LEG(VALEUR)
#LIPET - 31-10-2016 - X3PEOP-3635 - END
#JASMI - 2016-11-01 - START
  Gosub STYLE
#JASMI - 2016-11-01 - END
  Affzo [M:CNE1]

End
######################################################################################
Subprog GET_LEG(VALEUR)
Variable Char    VALEUR()

#LIPET - 31-10-2016 - X3PEOP-3635 - START
If clalev([F:HRCTR2])=0 : Local File EMPLOCTR [HRCTR2] : Endif
If clalev([F:FCY2])=0 : Local File FACILITY [FCY2]  : Endif

If VALEUR<>""
  Filter  [HRCTR2] Where CTRNUM=VALEUR
   Read [HRCTR2] Last
   Filter [HRCTR2]
   Read [FCY2]FCY0 = [F:HRCTR2]ETRFCY
   If !fstat
    GCURLEG = [F:FCY2]LEG
    [M]LEG = GCURLEG
    Affzo [M]LEG
   Endif
#LIPET - 31-10-2016 - X3PEOP-3635 - END
Endif
######################################################################################

