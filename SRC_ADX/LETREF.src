#<AdxTL>@(#)0.0.0.0 $Revision$
Call IMPRIME("LETREF","") From ETAT
End

####################################################
## Initialisation lettre de refus
####################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

Call TEMPON("O") From GESECRAN

Local Char    PARAM(20), ETAT(GLONARP), CRITERE(250), CRITERE1(250) , CRITERE2(250), CRITERE3(250)
Local Char    DEMDEB(GLONDEM), DEMFIN(GLONDEM)
Local Char    STGDEB(GLONSTG), STGFIN(GLONSTG)
Local Char    SESDEB(GLONSES), SESFIN(GLONSES)

Local Char    CPYDEB(GLONCPY), CPYFIN(GLONCPY), FCYDEB(GLONFCY), FCYFIN(GLONFCY)
Local Char    PRFDEB(GLONPRF), PRFFIN(GLONPRF), SRVDEB(GLONSRV), SRVFIN(GLONSRV)
Local Char    MAT(GLONEML),REF(GLONEML)
Local Decimal NUMREQ
Local Integer I,NBMAT,ININUMLIG

If clalev([F:ARM])=0  : Local File AREPORTM  [ARM]  : Endif
If clalev([F:DEM])=0  : Local File DEMANDE   [DEM]  : Endif
If clalev([F:DML])=0  : Local File DEMLIG    [DML]  : Endif
If clalev([F:DML1])=0 : Local File DEMLIG    [DML1] : Endif

If clalev([F:ECT])=0  : Local File EMPCTR    [ECT]  : Endif
If clalev([F:CPE])=0  : Local File CPCEMP    [CPE]  : Endif
If clalev([F:CPE1])=0 : Local File CPCEMP    [CPE1] : Endif
If clalev([F:FGR])=0  : Local File FACGROUP  [FGR]  : Endif
If clalev([F:HRPOA])=0  : Local File POPULA    [POA]  : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR  [HRCTR]  : Endif
If clalev([F:ID])=0    : Local File EMPLOID   [ID]   : Endif
If clalev([F:FCY])=0   : Local File FACILITY   [FCY]   : Endif

Call GETPARAM("X3ETA",NBPAR,PARAMETRE,ETAT)
Call GETPARAM("demdeb",NBPAR,PARAMETRE,DEMDEB)
Call GETPARAM("demfin",NBPAR,PARAMETRE,DEMFIN)
Call GETPARAM("stgdeb",NBPAR,PARAMETRE,STGDEB)
Call GETPARAM("stgfin",NBPAR,PARAMETRE,STGFIN)
Call GETPARAM("sesdeb",NBPAR,PARAMETRE,SESDEB)
Call GETPARAM("sesfin",NBPAR,PARAMETRE,SESFIN)

Call GETPARAM("cpydeb",NBPAR,PARAMETRE,CPYDEB)
Call GETPARAM("cpyfin",NBPAR,PARAMETRE,CPYFIN)
Call GETPARAM("fcydeb",NBPAR,PARAMETRE,FCYDEB)
Call GETPARAM("fcyfin",NBPAR,PARAMETRE,FCYFIN)
Call GETPARAM("prfdeb",NBPAR,PARAMETRE,PRFDEB)
Call GETPARAM("prffin",NBPAR,PARAMETRE,PRFFIN)
Call GETPARAM("srvdeb",NBPAR,PARAMETRE,SRVDEB)
Call GETPARAM("srvfin",NBPAR,PARAMETRE,SRVFIN)
Call GETPARAM("mat",NBPAR,PARAMETRE,MAT)
Call GETPARAM("ref",NBPAR,PARAMETRE,REF)

Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) : [L]NUMREQ = val(PARAM)

PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

CRITERE1="1=1"
CRITERE2="1=1"
CRITERE3="1=1"

#CRITERE1 = "[F:ID]ENAFLG=2"
#CRITERE2 = "([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=date$)"

If DEMDEB<>"" : CRITERE1 -= "& [F:DEM]DEMNUM>='"+DEMDEB+"'"    : Endif
If DEMFIN<>"" : CRITERE1 -= "& [F:DEM]DEMNUM<='"+DEMFIN+"'"    : Endif
If STGDEB<>"" : CRITERE1 -= "& [F:DEM]STG>='"+STGDEB+"'"    : Endif
If STGFIN<>"" : CRITERE1 -= "& [F:DEM]STG<='"+STGFIN+"'"    : Endif
If SESDEB<>"" : CRITERE1 -= "& [F:DEM]SES>='"+SESDEB+"'"    : Endif
If SESFIN<>"" : CRITERE1 -= "& [F:DEM]SES<='"+SESFIN+"'"    : Endif
If REF<>""    : CRITERE1 -= "& [F:DEM]REFNUM='"+REF+"'" : Endif

If MAT<>"" : CRITERE2 -= "& [F:DML]EMP='"+MAT+"'"    : Endif

If CPYDEB<>"" : CRITERE2 -= "& [F:DML]CPY>='"+CPYDEB+"'"    : Endif
If CPYFIN<>"" : CRITERE2 -= "& [F:DML]CPY<='"+CPYFIN+"'"    : Endif
If FCYDEB<>"" : CRITERE2 -= "& [F:DML]FCY>='"+FCYDEB+"'"    : Endif
If FCYFIN<>"" : CRITERE2 -= "& [F:DML]FCY<='"+FCYFIN+"'"    : Endif
If SRVDEB<>"" : CRITERE2 -= "& [F:DML]SRV>='"+SRVDEB+"'"    : Endif
If SRVFIN<>"" : CRITERE2 -= "& [F:DML]SRV<='"+SRVFIN+"'"    : Endif

If MAT<>""    : CRITERE3 -= "& [F:DML1]EMP='"+MAT+"'"    : Endif
If CPYDEB<>"" : CRITERE3 -= "& [F:DML1]CPY>='"+CPYDEB+"'"    : Endif
If CPYFIN<>"" : CRITERE3 -= "& [F:DML1]CPY<='"+CPYFIN+"'"    : Endif
If FCYDEB<>"" : CRITERE3 -= "& [F:DML1]FCY>='"+FCYDEB+"'"    : Endif
If FCYFIN<>"" : CRITERE3 -= "& [F:DML1]FCY<='"+FCYFIN+"'"    : Endif
If SRVDEB<>"" : CRITERE3 -= "& [F:DML1]SRV>='"+SRVDEB+"'"    : Endif
If SRVFIN<>"" : CRITERE3 -= "& [F:DML1]SRV<='"+SRVFIN+"'"    : Endif

#Link [DML] With
#&   [DEM]DEM0=[F:DML]DEMNUM
#& , [ECT]ECT0=[DEM]REFNUM;[DEM]CTR
#& , [ID]ID0=[F:ECT]REFNUM
#& , [HRCTR]CTR2=[F:ECT]REFNUM;[F:ECT]CTRNUM;[F:ECT]NBRCTR
#& , [FGR]FGR1(1)=[F:ECT]FCY
#& As [LDML]
#& Where evalue(CRITERE1) & evalue(CRITERE2)

Link [DML] With
&   [DEM]DEM0=[F:DML]DEMNUM
& As [LDML]
& Where evalue(CRITERE1) & evalue(CRITERE2)

Call DEBTRANS From GLOCK
Gosub TR1
Call DEBTRANS From GLOCK
Gosub TR2
Call TEMPOFF From GESECRAN
End

$TR1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=[L]ETAT & USR=GUSER
Commit
Return

$TR2
Local Integer NUMTAB,NUMTAB_PAR,OKPAR
Local Char TMP_LEG(GLONADI)

 Trbegin [ARM]
 I=1
 NBMAT=0
 For [LDML]DML0(1)
   Read [F:ECT]ECT0=[F:DEM]REFNUM;[F:DEM]CTR
   Filter [F:HRCTR] Where [F:HRCTR]REFNUM=[F:DEM]REFNUM & [F:HRCTR]CTRNUM=[F:DEM]CTR & [F:HRCTR]NUMLIG=[F:ECT]NBRCTR
   Read [F:HRCTR]CTR0 Last
   Filter [HRCTR]
   NUMTAB=0
   If !fstat
     Call VERIF_AML_EML([F:ECT]FCY,[F:HRCTR]CIVCTR,0,"CIVIL",NUMTAB,TMP_LEG,TMP_LEG,OKPAR) From SUBEML2
   Endif
   Filter [DML1] Where [F:DML1]DEMNUM=[F:DML]DEMNUM & [F:DML1]STA=3
   If rowcount ([DML1]) > 0
     Filter [DML1] Where [F:DML1]DEMNUM=[F:DML]DEMNUM
     [L]ININUMLIG=0
     Read [DML1] First
     If !fstat
        [L]ININUMLIG=[F:DML1]NUMLIG
     Endif
     For [DML1]DML0
       NBMAT += [F:DML1]NBREMP
     Next
     Filter [DML1] Where [F:DML1]DEMNUM=[F:DML]DEMNUM & [F:DML1]STA=3 & evalue(CRITERE3)
     For [DML1]DML0
      NUMTAB_PAR=0
      If [F:DML1]EMP <> ""
       Read [F:ECT]ECT0=[F:DML1]EMP;[F:DML1]CTRNUM
       Filter [F:HRCTR] Where [F:HRCTR]REFNUM=[F:DML1]EMP & [F:HRCTR]CTRNUM=[F:DML1]CTRNUM & [F:HRCTR]NUMLIG=[F:ECT]NBRCTR
       Read [F:HRCTR]CTR0 Last
       Filter [HRCTR]
       If !fstat
         Call VERIF_AML_EML([F:ECT]FCY,[F:HRCTR]CIVCTR,0,"CIVIL",NUMTAB_PAR,TMP_LEG,TMP_LEG,OKPAR) From SUBEML2
       Endif
      Endif

      Raz [F:ARM]
      [F:ARM]USR    = GUSER
      [F:ARM]RPTCOD = [L]ETAT
      [F:ARM]NUMREQ = [L]NUMREQ
      [F:ARM]NUMLIG = I
      [F:ARM]CLEA1  = [F:DML1]DEMNUM
      [F:ARM]CLEN1  = [F:DML1]NUMLIG
      [F:ARM]CLEN3  = [L]ININUMLIG
      [F:ARM]CLEA2  = [F:DEM]REFNUM
      [F:ARM]CLEA3  = [F:DEM]CTR
      [F:ARM]CLEA4  = [F:DML1]EMP
      [F:ARM]CLEA5  = [F:DML1]CTRNUM
      [F:ARM]CLEA6  = num$(NUMTAB)
      [F:ARM]CLEA7  = num$(NUMTAB_PAR)
      [F:ARM]CLEN2  = NBMAT
      Write [ARM]
      If fstat
       GOK = 0 : Call FSTA("ARM") From GLOCK : Break 2
      Endif
      I+=1
     Next
   Endif
 Next
 Filter [DML1]
 If GOK=0
  Goto AB_TR2
 Elsif GOK=-1
  Goto ROLL_TR2
 Endif
Commit
Return


$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif
Return

$AB_TR2
Rollback
Return

Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End
