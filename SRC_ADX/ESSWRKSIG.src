#<AdxTL>@(#)0.0.0.0 $Revision$ 

##################################################
Subprog WRKFLOWSIGN(CHRONO,DEST,EVT,ACTION)
Value    Char    CHRONO
Value    Char    DEST
Value    Char    EVT
Value    Char    ACTION
End


##################################################
Subprog WRKFLOWVIS(CHRONO,DEST,EVT,ACTION)
Value    Char    CHRONO
Value    Char    DEST
Value    Char    EVT
Value    Char    ACTION
ACTION="VIS"
Gosub TRIGGER_WORKFLOW
End


##################################################
Subprog WRKFLOWREF(CHRONO,DEST,EVT,ACTION)
Value    Char    CHRONO
Value    Char    DEST
Value    Char    EVT
Value    Char    ACTION
ACTION="REF"
Gosub TRIGGER_WORKFLOW

End



$TRIGGER_WORKFLOW

#Iniate the record - instantiating the class
Local Integer INIT_STATUS, MY_STATUS
Local Char VCHRONO(100)
Local Char VDEST(100)
VCHRONO = CHRONO
VDEST = DEST

Local Instance  I_ESSWRKHISSUI Using C_ESSWRKHISSUI
I_ESSWRKHISSUI         = NewInstance C_ESSWRKHISSUI AllocGroup null
[L]INIT_STATUS  = fmet I_ESSWRKHISSUI.AINIT()
If [L]INIT_STATUS <> [V]CST_AOK
   Call RECOVERS_ERROR_IN_CLASSIC(I_ESSWRKHISSUI)
  If GMESSAGE = AVOID.ACHAR Then
    GMESSAGE = mess(10,10727,1)
  Endif
  If [L]INIT_STATUS <> [V]CST_AWARNING and [L]MY_STATUS <> [V]CST_AINFO Then
    Return
  Endif
Endif

#Invoke workflow method and handle
[L]MY_STATUS  = fmet I_ESSWRKHISSUI.ESSWRKSIGHYBRID(VCHRONO,VDEST,ACTION,EVT)
If [L]MY_STATUS <> [V]CST_AOK Then
  Call RECOVERS_ERROR_IN_CLASSIC(I_ESSWRKHISSUI)
  If GMESSAGE = AVOID.ACHAR Then
    GMESSAGE = mess(9,10727,1)
  Endif
  If [L]MY_STATUS <> [V]CST_AWARNING and [L]MY_STATUS <> [V]CST_AINFO Then
    Return
  Endif
Endif


Gosub UPDATE_APPROVAL_SCREEN

FreeGroup I_ESSWRKHISSUI
Return

$UPDATE_APPROVAL_SCREEN
If GOK
  #Leave
  If dim([M:ESWDG]REFNUM)>0
    #Set the status of the line
    [M:ESWDG]WWRK(nolign-1) = "S"
    Gosub REFRESH_ESSWRKDCG From ESSWRKDCG
  Endif

  #Expenses
   If dim([M:ESWXS]REFNUM)>0
    #Set the status of the line
    [M:ESWXS]WWRK(nolign-1) = "S"
    Gosub REFRESH_ESSWRKEXS From ESSWRKEXS
  Endif

  #Employee
   If dim([M:ESWEMP]CHRONO)>0
    #Set the status of the line
    [M:ESWEMP]WWRK(nolign-1) = "S"
    Gosub REFRESH_ESSWRKEMP From ESSWRKEMP
  Endif

Endif
Return



Subprog RECOVERS_ERROR_IN_CLASSIC(I_ESSWRKHISSUI)
Variable Instance I_ESSWRKHISSUI Using C_ESSWRKHISSUI

Local Integer NI
Local Char SMESSAGE(type(GMESSAGE)-10)
Local Integer MY_STATUS
Local Integer IMESSAGE
Local Integer IOPEN_TRACE

#----------Hybrid----------------------#
IMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_UPPER_MESSAGE(I_ESSWRKHISSUI, SMESSAGE)
If IMESSAGE = [V]CST_AWARNING or IMESSAGE = [V]CST_AINFO Then
  GMESSAGE = SMESSAGE
  GERR = 2
Elsif IMESSAGE = [V]CST_AERROR or IMESSAGE = [V]CST_AFATAL Then
  GMESSAGE = SMESSAGE
  GOK = 0
  GERR = 1
Endif
#----------Hybrid----------------------#
# To help debug process : write a classic log file with all errors in class.
If GERR <> 0 Then
  If GTRACE = AVOID.ACHAR Then
    Call OUVRE_TRACE("MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG" + GUSER) From LECFIC
    IOPEN_TRACE = [V]CST_AYES
  Endif
  Call ECR_TRACE("->", 0) From GESECRAN
  Call MSGSTACK_DUMP_MESSAGES_INTO_CLASSIC_LOG(I_ESSWRKHISSUI) From SYRSTACKTOOLS
  If IOPEN_TRACE = [V]CST_AYES Then
    Call FERME_TRACE From LECFIC
  Endif
Endif
# ----------------------------------------------------------

[L]MY_STATUS = fmet I_ESSWRKHISSUI.ADELETERRORALL()
End

