#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
# UTIGPA23   Modification de la LISTE des gammes                         #
##########################################################################
# Bug 66361  par GBE le 27/09/10
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    Call MAJ_UTIGPA23(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIGPA23(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Char WOBJET(GLONAOB)
Local Integer WNBR
Local Integer B_OK

  Call ECR_TRACE("UTIGPA23: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".AOBJET"  [AOB]
  Trbegin [AOB]
  Read [F:AOB]NOMFIC="ROUTING";"ROW"
  If fstat=0
      If [F:AOB]RPT2="ROUUSE"
        [F:AOB]RPT2 = "ROUTING"
        [F:AOB]UPDDAT = date$
        [F:AOB]UPDUSR = GUSER
        Rewrite [F:AOB]
        If fstat
            Call ECR_TRACE("RPT2: can't update object ROW",1) From GESECRAN
        Endif
      Endif
  Else
      Call ECR_TRACE("RPT2: can't find object ROW",1) From GESECRAN
  Endif
  Commit
  Close Local File [AOB]
  Call ECR_TRACE("UTIGPA23 : finish",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  Call MAJ_UTIGPA23(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = GDOSX3 Then
    End
  Endif
  Call MAJ_UTIGPA23(APPLI)
End




