#<AdxTL>@(#)4.0.0.0 $Revision$
##########################################################################################################
# Etape 6 de la définition d'une campagne d'appels                  Module CRM           2 janvier 2001  #
##########################################################################################################
# Récupération d'un script d'appel
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "FIR"          : Gosub PREMIER
    When "PRE"          : Gosub PRECEDENT
    When "SUI"          : Gosub SUIVANT
    When "LAS"          : Gosub DERNIER
    When Default
  Endcase
Return

##########################################################################################################
$PREMIER
  Call LOADSCP(1, 1) From TRTSCP8
Return

##########################################################################################################
$PRECEDENT
  Call LOADSCP(2, 1) From TRTSCP8
Return

##########################################################################################################
$SUIVANT
  Call LOADSCP(3, 1) From TRTSCP8
Return

##########################################################################################################
$DERNIER
  Call LOADSCP(4, 1) From TRTSCP8
Return

##########################################################################################################
$OUVRE
#Global Char GSZSCPNUM
#GSZSCPNUM = ""
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
  Call LOADSCP(1, 1) From TRTSCP8
  #GSZSCPNUM = [M:PHZ6]SCPNUMY(0)
  Grizo [M:PHZ6]SCPFLG
  Affzo [M:PHZ6]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$FINSAI
  #Nettoie l'écran avant de partir.
  Raz [M:PHZ6]
  #Kill GSZSCPNUM
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "A"
      Gosub ONSELECT
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
$ONSELECT
  #LSE 21/10/2005
  #[M:PHO6]SCPNUM = GSZSCPNUM
  #Read [SCP] SCP0 = GSZSCPNUM
  [M:PHO6]SCPNUM = [M:PHZ6]SCPNUMY(nolign - 1)
  Read [SCP] SCP0 = [M:PHZ6]SCPNUMY(nolign - 1)
  If !fstat
    [M:PHO6]SCPNAM = [F:SCP]SCPNAM
    [M:PHO6]SALFCY = [F:SCP]SALFCY  # FGR 03/09/2008 : X3SUIVI43507
    GISCPDEF = 1
    GICANDEFI = 1
  Endif
  Affzo [M:PHO6]1-99
  FIN = 1
Return

