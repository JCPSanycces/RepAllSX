#<AdxTL>@(#)3.0.0.0 $Revision$
# Gestion du masque CONSSTCITG1


# Gestion du masque CONSSTCITM1
#############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : Raz [M:CSTG] : Transmask [M:STG1] To [M:CSTG]  # Issue 25606_Transmask [M:CSTG] = [M:STG1]
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AP_MAGNETO" : Gosub AP_MAGNETO
  When Default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$OUVRE
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITG]) = 0 : Local File ITMCATEG   [ITG] : Endif
If clalev([F:ACV]) = 0 : Local File ACTIV      [ACV] : Endif

#
Local Char    WFIL(250), WFILS(250), WFILSPE(250)
Local Integer WFSTAT, WREAD, WSKIP, WLIG
Local Integer WGCONSULT : WGCONSULT = GCONSULT
Local Integer I

#
Gosub LOAD_SCREEN
#
NAVIG="CONSSTCITP"
SUITE  = 1
RETOUR = 1
Return
############################################################
$FIN_CRIT
[M:STG1]    = [M:CSTG]
Return
############################################################
$AP_MAGNETO
Return
############################################################
$FERME
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return





############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> "" & PARAM(I) <> "***"
        Call LECTURE("STC",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:STG1]STCNUM = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) <> ""
        Call LECTURE("ITG",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:STG1]TCLCODSTR = [F:ITG]TCLCOD
        Endif
      Endif
    When 4 :
      If PARAM(I) <> ""
        Call LECTURE("ITG",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:STG1]TCLCODEND = [F:ITG]TCLCOD
        Endif
      Endif
  Endcase
Next I
If clalev([M:CSTG]) <> 0 & [M:CSTG]MEMO = "STD"
  [M:STG1] = [M:CSTG]
Endif
Return
############################################################
$LECTURE
Gosub TRT_FILTER
SUITE  = 0
RETOUR = 0
NBLU   = 1
Case CHGPAG
  When 1 :
    Raz [M:STG2]
    nolign = 1
    WPAGE  = 0
    For [ITG]
      If nolign <= MAXLIG
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    += 1
        Else
          Break
        Endif
    Next
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    # Bug 38845 - 12/12/2006 - Début
    Effzo [M:STG2]
    # Bug 38845 - 12/12/2006 - fin
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0
    For [ITG]
        If WLIG >= WSKIP
          If nolign <= MAXLIG
            Gosub LOA_LIGNE
            NBLU    = 2
            nolign += 1
            NOL    += 1
          Else
            Break
          Endif
        Else
          WLIG += 1
        Endif
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :

    Effzo [M:STG2]
    WLIG = 0
    For [ITG]

        WLIG += 1
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [ITG]
        If WLIG >= WSKIP
          If nolign <= MAXLIG
            Gosub LOA_LIGNE
            NBLU    = 2
            nolign += 1
            NOL    -= 1
          Else
            Break
          Endif
        Else
          WLIG += 1
        Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 :
    Effzo [M:STG2]
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0
    For [ITG]
        If WLIG >= WSKIP
          If nolign <= MAXLIG
            Gosub LOA_LIGNE
            NBLU    = 2
            nolign += 1
          Else
            Break
          Endif
        Else
          WLIG += 1
        Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
Endcase
$LECTURE_FIN
Filter [F:ITG]
Return
############################################################
$TRT_FILTER
  Raz [M:STG2]
  Gosub LOAD_FILTER
  WFILSPE="1=1"
  If PROGSPE<>""
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif

  Filter [F:ITG] Where evalue(WFIL)&
&                      evalue(WFILSPE)
&                Order By Key ITG0


[M:STG1]NBRITG = rowcount([F:ITG])

Return

############################################################
$LOAD_FILTER
WFIL="1=1"

# Filtre structure de couts
If [M:STG1]STCNUM <> ""
    WFIL = "[F:ITG]STCNUM=[M:STG1]STCNUM"
Endif

# Filtre catégorie article
If [M:STG1]TCLCODSTR <> "" | [M:STG1]TCLCODEND <> ""
  If [M:STG1]TCLCODSTR = [M:STG1]TCLCODEND
    WFIL += "&[F:ITG]TCLCOD=[M:STG1]TCLCODSTR"
  Else
    WFIL += "&[F:ITG]TCLCOD>=[M:STG1]TCLCODSTR&[F:ITG]TCLCOD<=[M:STG1]TCLCODEND"
  Endif
Endif

# filtre catégorie article
#If [M:STP1]BPSNUMSTR <> "" | [M:STP1]BPSNUMEND <> ""
#  If [M:STP1]BPSNUMSTR = [M:STP1]BPSNUMEND
#    WFIL += " & [F:ITP]BPSNUM=[M:STP1]BPSNUMSTR"
#  Else
#    WFIL += " & [F:ITP]BPSNUM>=[M:STP1]BPSNUMSTR & [F:ITP]BPSNUM<=[M:STP1]BPSNUMEND"
#  Endif
#Endif

Return
############################################################
$LOA_LIGNE
[M:STG2] = [F:ITG]
Call LECTEXTRA([M:STG2]TCLAXX(nolign-1),"ITMCATEG","TCLAXX",[M:STG2]TCLCOD(nolign-1),"") From ATEXTRA
Call LECTEXTRA([M:STG2]TCLSHOAXX(nolign-1),"ITMCATEG","TCLSHOAXX",[M:STG2]TCLCOD(nolign-1),"") From ATEXTRA

Return
############################################################
$SETBOUT
Return
############################################################
$EXEBOUT
Return

##########################################################################
#MAE, bg 57749
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch             #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(6)<>2 End Endif

Call VALGTC(APPLI,"STG") From SUBGTC

End



######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSSTCITG1) 25/03/2013 10:13:00 (MAE)
######################################################################################
Subprog AM_TCLCODSTR(VALEUR)
Variable Char    VALEUR()
  If [M]TCLCODEND = "" [M]TCLCODEND = VALEUR : Affzo [M]TCLCODEND : Endif
  If [M]TCLCODEND < VALEUR [M]TCLCODEND = VALEUR : Affzo [M]TCLCODEND : Endif
End

Subprog C_TCLCODEND(VALEUR)
Variable Char    VALEUR()
If VALEUR < [M]TCLCODSTR
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End

######################################################################################

