#<AdxTL>@(#)0.0.0.0 $Revision$
#STCAH - 2017-04-13 - REQUIREMENT nnnnnn - US nnnn
#Handling all properties for EXPENSESESS_RSTD
############################################################################################################
$PROPERTIES

 #ASTATUS = fmet this.ASETERROR(CURPRO,"Now here",CST_AINFO)

Case [L]CURPRO
  When "EXSH.REFNUM"                   : Gosub EXSH_REFNUM
  When "EXHS.HREXPENSES.CUR"           : Gosub EXHS_EXPENSES_CUR
  When "EXHS.HREXPENSES.VATCUR"        : Gosub EXHS_EXPENSES_VATCUR
Endcase

Return
############################################################################################################
$EXSH_REFNUM
Case [L]ARULE
  When "PROPAGATE"
   Gosub EXSH_REFNUM_PROPAGATE
Endcase

Return
############################################################################################################
$EXHS_EXPENSES_CUR
Case [L]ARULE
  When "PROPAGATE"
   Gosub EXHS_EXPENSES_CUR_PROPAGATE
Endcase

Return
############################################################################################################
$EXHS_EXPENSES_VATCUR
Case [L]ARULE
  When "PROPAGATE"
   Gosub EXHS_EXPENSES_VATCUR_PROPAGATE
Endcase

Return
############################################################################################################
$EXSH_REFNUM_PROPAGATE

#Local File EMPLOID [ID]
If clalev ([F:ID]) = 0 : Local File EMPLOID [ID] Endif
Read [ID]ID0=this.REFNUM
If fstat = [V]CST_AOK
  If [F:ID]FLGMULCTR=2
    ASTATUS = fmet this.ASETATTRIBUTE("CTRNUM","$isDisabled","false")
  Else
    ASTATUS = fmet this.ASETATTRIBUTE("CTRNUM","$isDisabled","true")
  Endif
Endif

Return
############################################################################################################
$EXHS_EXPENSES_CUR_PROPAGATE

Local File HRTABEXPENS[F:HRTES]
Read [F:HRTES]HRTES0 = this.APARENT.LEG;this.CODEXP
If fstat = [V]CST_AOK
  Case [F:HRTES]TYPVLT
    When 1,3      :  ASTATUS = fmet this.ASETATTRIBUTE("CUR","$isDisabled","true")
    When Default  :  ASTATUS = fmet this.ASETATTRIBUTE("CUR","$isDisabled","false")
  Endcase
Endif

Return
############################################################################################################
$EXHS_EXPENSES_VATCUR_PROPAGATE

ASTATUS = fmet this.ASETATTRIBUTE("VATCUR","$isDisabled","false")
If this.PAYCUR <> 0
  ASTATUS = fmet this.ASETATTRIBUTE("VATCUR","$isDisabled","true")
  Return
Endif

Local File HRTABEXPENS[F:HRTES]
Read [F:HRTES]HRTES0 = this.APARENT.LEG;this.CODEXP
If fstat = [V]CST_AOK
  Case [F:HRTES]TYPVLT
    When 3      :  ASTATUS = fmet this.ASETATTRIBUTE("VATCUR","$isDisabled","true")
  Endcase
Endif

Return
############################################################################################################

