$LIENS
# FQ81085 - MABON 16/07/12 - To manage legislation in employee selection
If GNBLEG=1 : GCURLEG = GDOSLEG : Endif
# End MABON
# JML 13/08/10 LOT P02 [F:EVE]EVACPC & EVALEV are now on EVAEMPCPC !
nolign=0
#ANMCL - 2017-02-05 - X3-29417 - START
