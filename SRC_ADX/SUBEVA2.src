###   If [M:EVA2]NBRGRA<func AFNC.ACTIV("HRCPC")
##    If [M:EVA2]NBRGRA<dim([M:EVA2]CPCGRA)
##     [M:EVA2]CPCGRA([M:EVA2]NBRGRA)   = [F:EVC]EVACPC
##     [M:EVA2]ACQUIS([M:EVA2]NBRGRA)   = [M:EVA2]LEVREFEVA(nolign-1)
##     [M:EVA2]NBRGRA += 1
##    Else
##     # Tableau plein
##     Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
##     Break
##    Endif
##   Endif
##  Endif
##
##  # JML 10/09/10 CG Tunnel Echelle
##  Call LECTURE("CPC",[F:EVC]EVACPC,"") From CONTOBJ
##  [M:EVA2]CODSCAVAL(nolign-1) = [F:CPC]CODSCA
##Next : # [EVC]EVC0
##[M:EVA2]NBRVAL = nolign

If func AFNC.ACTIV("EVAEN")>0
  Filter [EVC] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & EVADATSTR=[M]EVADATSTR & EVADATEND=[M]EVADATEND
&                 & EVATYP=[M]EVATYP & EVATYPCPC=2 & EVAMAT = [F:EVE]EVAMAT
Else
  Filter [EVC] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & EVADATSTR=[M]EVADATSTR & EVADATEND=[M]EVADATEND
&                 & EVATYP=[M]EVATYP & EVATYPCPC=2
Endif

For [EVC]EVC0

    If nolign>=dim([M:EVA2]CPCVAL)
      # Tableau plein
      Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
      Break
    Endif
    nolign+=1
    # Watchout here, don't make a 'transclass' !
    [M:EVA2]CPCVAL(nolign-1)       = [F:EVC]EVACPC
    [M:EVA2]LEVCPCVAL(nolign-1)    = [F:EVC]EVALEV
    [M:EVA2]LEVCPCEVA(nolign-1)    = [F:EVC]LEVCPCEVA
    If [F:EVC]LEVREFVAL<>0
      [M:EVA2]LEVREFVAL(nolign-1)    = [F:EVC]LEVREFVAL
    Else
      [M:EVA2]LEVREFVAL(nolign-1)    = func SUBECP.CPC_LEVREF([F:EVC]EVACPC,[F:EVC]EVALEV)
    Endif
    If [F:EVC]LEVREFEVA<>0
      [M:EVA2]LEVREFEVA(nolign-1)    = [F:EVC]LEVREFEVA
    Else
      [M:EVA2]LEVREFEVA(nolign-1)    = func SUBECP.CPC_LEVREF([F:EVC]EVACPC,[F:EVC]LEVCPCEVA)
    Endif
    [M:EVA2]EVACPCDATVAL(nolign-1) = [F:EVC]EVACPCDAT
    [M:EVA2]ORICPCVAL(nolign-1)    = [F:EVC]ORICPC
    [M:EVA2]ACTDEV(nolign-1)       = [F:EVC]ACTDEV
    [M:EVA2]FLGMODVAL(nolign-1)    = 1
    [M:EVA2]FLGOLDVAL(nolign-1)    = 2
    # Issue 11472 - 2017-09-20 by BRBAN : new field STGCOD
    If func AFNC.ACTIV("FRT")>0
      [M:EVA2]STGCOD(nolign-1)       = [F:EVC]STGCOD
    Endif
    # -

    # Now some graphicals, Learned
    L_IJ = find([F:EVC]EVACPC,[M:EVA2]CPCGRA(0..[M:EVA2]NBRGRA-1))
    If [M:EVA2]LEVREFEVA(nolign-1)=0
       If L_IJ
          [M:EVA2]ACQUIS(L_IJ-1)   = [M:EVA2]LEVREFEVA(nolign-1)
       Else
          If [M:EVA2]NBRGRA<dim([M:EVA2]CPCGRA)
             [M:EVA2]CPCGRA([M:EVA2]NBRGRA)   = [F:EVC]EVACPC
             [M:EVA2]ACQUIS([M:EVA2]NBRGRA)   = [M:EVA2]LEVREFEVA(nolign-1)
             [M:EVA2]NBRGRA += 1
          Else
             # Tableau plein
             Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
             Break
          Endif
       Endif
    Else
       If L_IJ
          [M:EVA2]ACQUIS(L_IJ-1)   = [M:EVA2]LEVREFEVA(nolign-1)
       Else
          If [M:EVA2]NBRGRA<dim([M:EVA2]CPCGRA)
             [M:EVA2]CPCGRA([M:EVA2]NBRGRA)   = [F:EVC]EVACPC
             [M:EVA2]ACQUIS([M:EVA2]NBRGRA)   = [M:EVA2]LEVREFEVA(nolign-1)
             [M:EVA2]NBRGRA += 1
          Else
             # Tableau plein
             Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
             Break
          Endif
       Endif
    Endif

    Call LECTURE("CPC",[F:EVC]EVACPC,"") From CONTOBJ
    [M:EVA2]CODSCAVAL(nolign-1) = [F:CPC]CODSCA
Next : # [EVC]EVC0
[M:EVA2]NBRVAL = nolign

Filter [EVC]
#ANMCL - 2017-02-05 - X3-29417 - END

#43885
If dim([M:EVA3]EVASTG)>0
 For nolign=1 To dim([F:EVE]EVASTG)
#     SEGAY - 12/12/12 BUG 86600 On n'a besoin de tester que Soit le STG , soit le DOM , soit le THM est renseigné
#  If [F:EVE]EVASTG(nolign-1)="" & [F:EVE]DOM(nolign-1)="" : Break : Endif
  If [F:EVE]EVASTG(nolign-1)="" & [F:EVE]DOM(nolign-1)="" & [F:EVE]THM(nolign-1)="": Break : Endif
  [M:EVA3] = [F:EVE]
  [M:EVA3]NBRSTG = nolign
 Next nolign
Endif
#ADNGO - 2017-11-06 - START
Call AM_FLGMOB([M:EVA8]FLGMOB) From SUBEVA
#ADNGO - 2017-11-06 - END

# FQ81085 - SEGAY 12/09/12 - US740 To allow a domain, theme or organism in a different legislation than the contract
# we had to change the datatype of these fields. So we have to get the title
#ADNGO - 2017-11-06 - START
#Call LECTEXTRA([M:EVA3]WJOBGRPDES,"ATABDIV","LNGDES","10460",[M:EVA3]EVAJOBGRP) From ATEXTRA
Call LECTEXTRA([M:EVA8]WJOBGRPDES,"ATABDIV","LNGDES","10460",[M:EVA8]EVAJOBGRP) From ATEXTRA
#ADNGO - 2017-11-06 - END

Read [ID]ID0=[F:EVE]REFNUM
If !fstat
 Call GRISE_CTRNUM([F:ID]FLGMULCTR)
 [M]SRN = [F:ID]NAM-[F:ID]SRN        : # JML 31/08/10 CG
Endif
# FQ81085 - MABON 16/07/12 - Get contract legislation
Read [HRCTR]CTR0=[M:EVA0]REFNUM;[M:EVA0]CTRNUM;[M:EVA0]CTRDAT
If fstat : Raz [F:HRCTR] : Endif
Read [F:FCY]FCY0=[F:HRCTR]ETRFCY
If !fstat Then
  GCURLEG     = [F:FCY]LEG
  [M:EVA0]EVALEG = GCURLEG
  Affzo [M:EVA0]EVALEG
Endif
# End MABON
# FQ82920 - MABON 15/06/12 - Le poste et/ou l'emploi-type sont initialisés par la carrière, et si aucune donnée
# exploitable n'est trouvée dans les carrières, on les cherche dans le contrat
Filter [F:EPO] Where [EPO]REFNUM=[M:EVA0]REFNUM & [EPO]CTRNUM=[M:EVA0]CTRNUM & [EPO]DATPOT<=[M:EVA0]EVADATEND Order By DATPOT
Read [F:EPO] Last
Filter [F:EPO]
If !fstat & ([F:EPO]POT<>"" | [F:EPO]JOBPOT<>"") Then
  [M:EVA0]POT    = [F:EPO]POT
  [M:EVA0]JOBPOT = [F:EPO]JOBPOT
Else
# Fin MABON
  # JML 09/08/10 LOT P02
#  Read [HRCTR]CTR0=[M:EVA0]REFNUM;[M:EVA0]CTRNUM;[M:EVA0]CTRDAT
#  If fstat : Raz [F:HRCTR] : Endif
  [M:EVA0]POT    = [F:HRCTR]POT
  [M:EVA0]JOBPOT = [F:HRCTR]JOBPOT
Endif
Affzo [EVA0]POT,ZPOT,JOBPOT,ZJOBPOT
# 71140 - SYMEU - 28/01/2011
Call SET_CPY([F:HRCTR]ETRFCY)
#GSOCIETE=[M:EVA0]CPY

# JML 12/08/10 LOT P02 Could be useful...
Actzo [EVA6]EVALIB, EVAMAT, EVALIB2, EVAMAT2
If [M:EVA6]EVAMAT<>""
 Grizo [EVA6]EVALIB
Endif
If [M:EVA6]EVALIB<>""
 Grizo [EVA6]EVAMAT
Endif
If [M:EVA6]EVAMAT2<>""
 Grizo [EVA6]EVALIB2
Endif
If [M:EVA6]EVALIB2<>""
 Grizo [EVA6]EVAMAT2
Endif
# JML 13/08/10 LOT P02
nolign = 0
#     SEGAY - 08/08/12 - EXI 81491 83397 US606
#ANMCL - 2017-02-05 - X3-29417 - START
#For [EVD]EVD0 Where [F:EVD]REFNUM=[M]REFNUM & [F:EVD]CTRNUM=[M]CTRNUM & [F:EVD]EVADAT=[M]EVADAT & [F:EVD]TYPOBJ=1
##For [EVD]EVD0 Where [F:EVD]REFNUM=[M]REFNUM & [F:EVD]CTRNUM=[M]CTRNUM
##& & [F:EVD]EVADATSTR=[M]EVADATSTR & [F:EVD]EVADATEND=[M]EVADATEND & [F:EVD]TYPOBJ=1
##& & [F:EVD]EVATYP=[M]EVATYP
###     SEGAY - 11/09/12 - EXI 84448
## If nolign<=dim([M:EVA1]EVAOBJ)-1
##  nolign += 1
##  [M:EVA1] = [F:EVD]
##  [M:EVA1]NBRCMT = nolign
## Endif
##Next : # [EVD]EVD0
If func AFNC.ACTIV("EVAEN")>0
  Filter [EVD] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & EVADATSTR=[M]EVADATSTR & EVADATEND=[M]EVADATEND & TYPOBJ=1
&                    & EVATYP=[M]EVATYP & EVAMAT = [F:EVE]EVAMAT
Else
  Filter [EVD] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & EVADATSTR=[M]EVADATSTR & EVADATEND=[M]EVADATEND & TYPOBJ=1
&                    & EVATYP=[M]EVATYP
Endif
For [EVD]EVD0
   If nolign<=dim([M:EVA1]EVAOBJ)-1
       nolign += 1
       [M:EVA1] = [F:EVD]
       If [M:EVA1]ORIDET(nolign-1)=0 Then [M:EVA1]ORIDET(nolign-1)=1 : Endif : # Manuel
       [M:EVA1]NBRCMT = nolign
   Endif
Next : # [EVD]EVD0
#ANMCL - 2017-02-05 - X3-29417 - END
# JML 16/08/10 LOT P02
nolign = 0
#     SEGAY - 08/08/12 - EXI 81491 83397 US606
#For [EVD]EVD0 Where [F:EVD]REFNUM=[M]REFNUM & [F:EVD]CTRNUM=[M]CTRNUM & [F:EVD]EVADAT=[M]EVADAT & [F:EVD]TYPOBJ=2
#ANMCL - 2017-02-05 - X3-29417 - START
#For [EVD]EVD0 Where [F:EVD]REFNUM=[M]REFNUM & [F:EVD]CTRNUM=[M]CTRNUM
#&  & [F:EVD]EVADATSTR=[M]EVADATSTR & [F:EVD]EVADATEND=[M]EVADATEND & [F:EVD]TYPOBJ=2
