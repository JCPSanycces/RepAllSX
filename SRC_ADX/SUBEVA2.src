##    [M:EVA2]NBRGRA += 1
##   Else
##    # Tableau plein
##    Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
##    Break
##   Endif
##  Endif
##  # JML 10/09/10 CG Tunnel Echelle
##  Call LECTURE("CPC",[F:EVC]EVACPC,"") From CONTOBJ
##  [M:EVA2]CODSCACPC(nolign-1) = [F:CPC]CODSCA
##Next : # [EVC]EVC0
##[M:EVA2]NBRCPC = nolign

If func AFNC.ACTIV("EVAEN")>0
  Filter [EVC] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & EVADATSTR=[M]EVADATSTR & EVADATEND=[M]EVADATEND
&                 & EVATYP=[M]EVATYP & EVATYPCPC=1 & EVACPCDAT=[0/0/0] & EVAMAT = [M]EVAMAT
Else
  Filter [EVC] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & EVADATSTR=[M]EVADATSTR & EVADATEND=[M]EVADATEND
&                 &  EVATYP=[M]EVATYP & EVATYPCPC=1 & EVACPCDAT=[0/0/0]
Endif

For [EVC]EVC0
  # ACTIV CODE CPC
  If nolign>=dim([M:EVA2]EVACPC)
    # Tableau plein
    Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
    Break
  Endif
  nolign+=1
  [M:EVA2] = [F:EVC]
  [M:EVA2]EVACPC(nolign-1)    = [F:EVC]EVACPC
  [M:EVA2]EVALEV(nolign-1)    = [F:EVC]EVALEV
  If [F:EVC]LEVREFVAL<>0
    [M:EVA2]LEVREF(nolign-1) = [F:EVC]LEVREFVAL
  Else
    [M:EVA2]LEVREF(nolign-1) = func SUBECP.CPC_LEVREF([F:EVC]EVACPC,[F:EVC]EVALEV)
  Endif
  [M:EVA2]EVACPCDAT(nolign-1) = [F:EVC]EVACPCDAT
  [M:EVA2]ORICPC(nolign-1)    = [F:EVC]ORICPC
  [M:EVA2]FLGMOD(nolign-1)    = 1
  [M:EVA2]FLGOLD(nolign-1)    = 2

  # Now some graphicals, required
  If !find([F:EVC]EVACPC,[M:EVA2]CPCGRA(0..[M:EVA2]NBRGRA-1))
     If [M:EVA2]NBRGRA<dim([M:EVA2]CPCGRA)
        [M:EVA2]CPCGRA([M:EVA2]NBRGRA)   = [F:EVC]EVACPC
        [M:EVA2]REQUIS([M:EVA2]NBRGRA)   = [M:EVA2]LEVREF(nolign-1)
        [M:EVA2]NBRGRA += 1
     Else
        # Tableau plein
        Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
        Break
     Endif
  Endif
  Call LECTURE("CPC",[F:EVC]EVACPC,"") From CONTOBJ
  [M:EVA2]CODSCACPC(nolign-1) = [F:CPC]CODSCA
Next
[M:EVA2]NBRCPC = nolign

#nolign=0
Filter [EVC]
#ANMCL - 2017-02-05 - X3-29417 - END

nolign=0
#ANMCL - 2017-02-05 - X3-29417 - START

