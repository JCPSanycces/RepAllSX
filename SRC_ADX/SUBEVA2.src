# If nolign<=dim([M:EVA4]EVAOBJ)-1
#  nolign += 1
#  [M:EVA4] = [F:EVD]
#  [M:EVA4]NBROBJ = nolign
# Endif
#Next : # [EVD]EVD0

If func AFNC.ACTIV("EVAEN")>0
  Filter [EVD] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & EVADATSTR=[M]EVADATSTR & EVADATEND=[M]EVADATEND & TYPOBJ=2
&                    & EVATYP=[M]EVATYP & EVAMAT = [F:EVE]EVAMAT
Else
  Filter [EVD] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & EVADATSTR=[M]EVADATSTR & EVADATEND=[M]EVADATEND & TYPOBJ=2
&                    & EVATYP=[M]EVATYP
Endif
For [EVD]
   If nolign<=dim([M:EVA4]EVAOBJ)-1
       nolign += 1
       [M:EVA4] = [F:EVD]
       [M:EVA4]NBROBJ = nolign
   Endif
Next : # [EVD]EVD0
Filter [EVD]
#ANMCL - 2017-02-05 - X3-29417 - END

#ANMCL - 2017-02-05 - X3-29417 - START
# 13/02/14 - EXI 96649 US2420 Mission
#nolign = 0
##For [EVM]EVM0 Where [F:EVM]REFNUM=[M]REFNUM & [F:EVM]CTRNUM=[M]CTRNUM
##& & [F:EVM]EVADATSTR=[M]EVADATSTR & [F:EVM]EVADATEND=[M]EVADATEND
##& & [F:EVM]EVATYP=[M]EVATYP
##   If nolign<=dim([M:EVA7]CODMIS)-1
##       nolign += 1
##       [M:EVA7] = [F:EVM]
##       [M:EVA7]NBRMIS = nolign
##   Endif
##Next : # [EVM]EVM0
###END 96649
# Mission
If func AFNC.ACTIV("EVAEN")>0
  Local Integer FIRSTMIS, X
  nolign = 0
  For [EVM]EVM0 Where [F:EVM]REFNUM=[M]REFNUM & [F:EVM]CTRNUM=[M]CTRNUM
&   & [F:EVM]EVADATSTR=[M]EVADATSTR & [F:EVM]EVADATEND=[M]EVADATEND
&   & [F:EVM]EVATYP=[M]EVATYP & [F:EVM]EVAMAT = [F:EVE]EVAMAT
    If nolign<=dim([M:EVA7]CODMIS)-1
      FIRSTMIS = 1
      nolign += 1
      #[M:EVA7]                = [F:EVM]
      [M:EVA7]EVALEVMIS(nolign-1)     = [F:EVM]EVALEVMIS
      [M:EVA7]WMIS(nolign-1)          = [F:EVM]CODMIS
      [M:EVA7]CODMIS(nolign-1)        = [F:EVM]CODMIS
      [M:EVA7]EVAMISREF(nolign-1)     = [F:EVM]EVAMISREF
      [M:EVA7]CMTMIS(nolign-1)        = [F:EVM]CMTMIS
      [M:EVA7]MISWEI(nolign-1)        = [F:EVM]MISWEI
      [M:EVA7]MISSCO(nolign-1)        = [F:EVM]MISSCO

      #Created a table just for the indicators
      For [EVIN]EVIN0 Where [F:EVIN]REFNUM=[M]REFNUM & [F:EVIN]CTRNUM=[M]CTRNUM
&       & [F:EVIN]EVADATSTR=[M]EVADATSTR & [F:EVIN]EVADATEND=[M]EVADATEND
&       & [F:EVIN]EVATYP=[M]EVATYP & [F:EVIN]EVAMAT = [F:EVE]EVAMAT & [F:EVIN]CODMIS = [F:EVM]CODMIS
        If FIRSTMIS = 1 : FIRSTMIS = 2 : Else nolign += 1  :Endif
        [M:EVA7]WMIS(nolign-1)    = [F:EVIN]CODMIS
        [M:EVA7]IND(nolign-1)     = [F:EVIN]IND
        [M:EVA7]INDWEI(nolign-1)  = [F:EVIN]INDWEI
        [M:EVA7]INDLEV(nolign-1)  = [F:EVIN]INDLEV
        [M:EVA7]INDSCO(nolign-1)  = [F:EVIN]INDSCO
        [M:EVA7]CMTIND(nolign-1)  = [F:EVIN]CMTIND
      Next
    Endif
  Next
  [M:EVA7]NBRMIS = nolign
Else
  nolign = 0
  For [EVM]EVM0 Where [F:EVM]REFNUM=[M]REFNUM & [F:EVM]CTRNUM=[M]CTRNUM
&   & [F:EVM]EVADATSTR=[M]EVADATSTR & [F:EVM]EVADATEND=[M]EVADATEND
&   & [F:EVM]EVATYP=[M]EVATYP
    If nolign<=dim([M:EVA7]CODMIS)-1
      nolign += 1
      [M:EVA7] = [F:EVM]
      [M:EVA7]NBRMIS = nolign
   Endif
  Next : # [EVM]EVM0
Endif
#ANMCL - 2017-02-05 - X3-29417 - END

###################################################################################
Read [ACV]CODACT="FRT"
If !fstat & [F:ACV]FLACT=2 #Active Flag is Yes
#Infbox "in LIENS, Active Flag is Yes,Gosub STG_REA"
 Gosub STG_REA
Endif
# JML 16/08/10 LOT P02 Read previous comments
#     SEGAY - 08/08/12 - EXI 81491 83397 US606
#Filter [EVE1] Where [F:EVE1]REFNUM=[M]REFNUM & [F:EVE1]CTRNUM=[M]CTRNUM & [F:EVE1]EVADAT<[M]EVADAT
#ANMCL start 2017-02-05 - X3-29417 - START
If func AFNC.ACTIV("EVAEN")>0
  Filter [EVE1] Where [F:EVE1]REFNUM=[M]REFNUM & [F:EVE1]CTRNUM=[M]CTRNUM
& & [F:EVE1]EVADATSTR<[M]EVADATSTR & [F:EVE1]EVATYP=[M]EVATYP
& & [F:EVE1]EVAMAT = [F:EVE]EVAMAT
Else
  Filter [EVE1] Where [F:EVE1]REFNUM=[M]REFNUM & [F:EVE1]CTRNUM=[M]CTRNUM
& & [F:EVE1]EVADATSTR<[M]EVADATSTR & [F:EVE1]EVATYP=[M]EVATYP
Endif
#ANMCL - 2017-02-05 - X3-29417 - END

Read [EVE1]EVE0 Last
If fstat<4
 # Don't do a transclass !!
 [M:EVA5]EVACMT1 = [F:EVE1]EVACMTNEW
 [M:EVA5]CMTMAT1 = [F:EVE1]CMTMATNEW
Endif
Filter [EVE1]
Read [ID]ID0=[M:EVA6]EVAMAT
If !fstat
 [M]SRN1 = [F:ID]NAM-[F:ID]SRN        : # JML 13/09/10 CG
Endif
Read [ID]ID0=[M:EVA6]EVAMAT2
If !fstat
 [M]SRN2 = [F:ID]NAM-[F:ID]SRN        : # JML 13/09/10 CG
Endif

#ANMCL - 2017-02-05 - X3-29417 - START
#  If [M:EVA0]CEV<>"" Then
#    Grizo [M:EVA0]EVADATSTR, EVADATEND, EVATYP
#  Else
#    Actzo [M:EVA0]EVADATSTR, EVADATEND, EVATYP
#  Endif
If [M:EVA0]CEV<>"" Then
 If GREP="C" & ([M:EVA0]FLGPRO=2 | [M:EVA0]FLGBIL=2 )
   Actzo [M:EVA0]EVADATSTR, EVADATEND
 Else
   Grizo [M:EVA0]EVADATSTR, EVADATEND, EVATYP
 Endif
Else
 Actzo [M:EVA0]EVADATSTR, EVADATEND, EVATYP
Endif
#ANMCL - 2017-02-05 - X3-29417 - END

#ANMCL - 2017-02-05 - X3-29417 - START
#Infbox"Filter [EVI] Actions"
#US4120_11239 : add tab actions
nolign = 0
#FRLAA - 2016-08-01 - REQUIREMENT 117178 US 3 - START
Filter [EVI]
If func AFNC.ACTIV("EVAEN")>0
  Filter [EVI] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & EVADATSTR=[M]EVADATSTR & EVADATEND=[M]EVADATEND & EVATYP=[M]EVATYP & EVAMAT = [F:EVE]EVAMAT
Else
  Filter [EVI] Where REFNUM=[M]REFNUM & CTRNUM=[M]CTRNUM & EVADATSTR=[M]EVADATSTR & EVADATEND=[M]EVADATEND & EVATYP=[M]EVATYP
Endif
#For [EVI]EVI0 Where [F:EVI]REFNUM=[M]REFNUM & [F:EVI]CTRNUM=[M]CTRNUM
#& & [F:EVI]EVADATSTR=[M]EVADATSTR & [F:EVI]EVADATEND=[M]EVADATEND & [F:EVI]EVATYP=[M]EVATYP
For [EVI]EVI0
#FRLAA - 2016-08-01 - REQUIREMENT 117178 US 3 - END
   #ADNGO - 2017-11-06 - START
   #If nolign<dim([M:EVA3]ACTACT)
   If nolign<dim([M:EVA8]ACTACT)
   #ADNGO - 2017-11-06 - END
       nolign += 1
       #ADNGO - 2017-11-06 - START
       #[M:EVA3] = [F:EVI]
       #[M:EVA3]NBRACT = nolign
       [M:EVA8] = [F:EVI]
       [M:EVA8]NBRACT = nolign
       #ADNGO - 2017-11-06 - END
   Endif
Next
Filter [EVI]

If func AFNC.ACTIV("EVAEN")>0
#Infbox"[F:EVE1]DETFNLFLG =" # - [F:EVE1]DETFNLFLG
  STA_EVASTA = [F:EVE]DETFNLFLG #FRLAA - X3PEOP-2053 - 2016-11-02
  #AM STA_EVASTA = [F:EVE1]DETFNLFLG
Endif

#ANMCL - 2017-02-05 - X3-29417 - END
Return

######################################################################################

Subprog GRISE_CTRNUM(VALEUR)
Value Integer VALEUR
If VALEUR=2
 Actzo [M:EVA0]CTRNUM
Else
 Diszo [M:EVA0]CTRNUM
Endif
Affzo [M:EVA0]CTRNUM
End

#####################################################################################################

Subprog SET_CPY(P_FCY)
Value Char P_FCY
  Raz [M:EVA0]CPY
  Read [F:FCY2]FCY0=P_FCY
  If !fstat
    [M:EVA0]CPY = [F:FCY2]LEGCPY
  Endif
  [M:EVA0]FCY=P_FCY
  Affzo [M:EVA0]CPY, FCY
End

####################################################################################################
# JML 16/08/10 LOT P02
$STG_REA
# JML 14/09/10 CG Stages réalisés durant la période d'évaluation (c'est pas gagné avec les structures INJ/INS)
Effzo [EVA3]5
# SEGAY - 08/08/12 - EXI 81491 83397 US606
#If [M:EVA6]EVADATSTR=[0/0/0] | [M:EVA6]EVADATEND=[0/0/0] : Return : Endif
If [M:EVA0]EVADATSTR=[0/0/0] | [M:EVA0]EVADATEND=[0/0/0] : Return : Endif

nolign = 0
# SEGAY - 08/08/12 - EXI 81491 83397 US606
#For [INJ]INJ1(2) Where [INJ]REFNUM=[M:EVA0]REFNUM
#&                    & [INJ]DAT>=[M:EVA6]EVADATSTR
#&                    & [INJ]DAT<=[M:EVA6]EVADATEND
#gets registration days within range of the interview
For [INJ]INJ1(2) Where [INJ]REFNUM=[M:EVA0]REFNUM
&                    & [INJ]DAT>=[M:EVA0]EVADATSTR
&                    & [INJ]DAT<=[M:EVA0]EVADATEND
#AM incorrect for index INJ1, should be session not start date [INJ]DAT>=[M:EVA0]EVADATSTR
#Infbox "link[INJ] rowcount before read = "-num$(rowcount([INJ]))

 # INJ1 * REFNUM+SES+DAT
 Read [INS]INS1=[F:INJ]SES;[F:INJ]REFNUM
 If fstat : Raz [F:INS] : Endif
#Infbox "link[INS] rowcount before read = "-num$(rowcount([INS]))
 Read [HRSES]SES0=[F:INJ]SES
 If fstat : Raz [F:HRSES] : Endif
#Infbox "link[HRSES] rowcount before read = "-num$(rowcount([HRSES]))
 Read [STG]STG0=[F:INJ]STG
 If fstat : Raz [F:STG] : Endif
#Infbox "link[STG] rowcount before read = "-num$(rowcount([STG]))
# SEGAY 01/03/11 Bug 72009 dépassement capacité
 If nolign>= dim([M:EVA3]STG)
     # Tableau plein
    Call ERREUR("Ecarts : "-mess(26,100,1)) From GESECRAN
    Break
 Endif
 nolign += 1

 # Pas de transclasse à cause du 2ème tableau identique
 [M:EVA3]STG(nolign-1)       = [F:INJ]STG
 [M:EVA3]DOMSTG(nolign-1)    = [F:STG]DOM
 [M:EVA3]THMSTG(nolign-1)    = [F:STG]THM
 [M:EVA3]STA(nolign-1)       = [F:INS]STA
 [M:EVA3]SES(nolign-1)       = [F:INJ]SES
 [M:EVA3]STRDAT(nolign-1)    = [F:HRSES]STRDAT
 [M:EVA3]ENDDAT(nolign-1)    = [F:HRSES]ENDDAT
 [M:EVA3]NBRDAY(nolign-1)    = [F:INS]NBRDAY
 [M:EVA3]NBRHOUIPT(nolign-1) = [F:INS]NBRHOUIPT

#[M:EVA3]ACTACT(nolign-1) = "ANMCL Test"

Next : # [INJ]INJ1
[M:EVA3]NBRREA = nolign
Return
#####################################################################################################
#ANMCL - 2017-05-08 -  X3-29417 - START
Subprog C_MISWEI(VALEUR)
Variable Decimal VALEUR
If VALEUR < 0
  mkstat = 1 : GMESSAGE = mess(00180,00141,1)
Endif
If [M:EVA7]MISWEIFLG = 2 and [M:EVA7]CODMIS(nolign-1) <> ""
  If VALEUR = 0
    mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
Endif
End

Subprog C_IND(VALEUR)
Variable Char    VALEUR()
If [M:EVA7]INDFLG = 2
  If VALEUR = ""
    mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
Endif
End

Subprog C_INDWEI(VALEUR)
Variable Decimal VALEUR
If VALEUR < 0
  mkstat = 1 : GMESSAGE = GMESSAGE = mess(00180,00141,1)
Endif
If [M:EVA7]INDFLG = 2 and [M:EVA7]INDWEIFLG = 2
  If VALEUR = 0
    mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
Endif
End

Subprog AM_INDLEV(VALEUR)
Variable Char    VALEUR()
#FRLAA - 2016-06-20 - REQUIREMENT 108587 US 1 - START
#Only using the score of the Indicator level selected
#The field should not be active but just a check
Local Integer L_NOL : L_NOL = nolign-1

If [M:EVA7]INDFLG = 2
  Call NIVREF([M:EVA7]EVAMIS,VALEUR, [M:EVA7]INDSCO(L_NOL)) From SUBEVA
Else
    [EVA7]INDSCO(L_NOL) = 0
Endif
Affzo [EVA7]INDSCO(L_NOL)

End

Subprog C_MISCALSCO(VALEUR)
Variable Decimal VALEUR
If VALEUR < 0
  mkstat = 1 : GMESSAGE = mess(00180,00141,1)
Endif
End

Subprog AP_EVAOBJ(VALEUR)
Variable Char    VALEUR()
If func AFNC.ACTIV("EVAEN")>0
  [M:EVA1]MAIREC(nolign-1) = [M:EVA0]EVAMAIREC
  #Affzo [M:EVA1]
Endif
End

Subprog C_STGCOD(VALEUR)
Variable Char    VALEUR()
If VALEUR<>''
  If !clalev([F:STG]) : Local File STAGE  [STG] : Endif
  Read [F:STG]STG0=VALEUR
#  If fstat | !(find([M:EVA2]CPCVAL(nolign-1),[F:STG]CPCAFT) & [F:STG]FICTI=1 & (([F:STG]STRVLY<=[M:EVA0]EVADATSTR & [F:STG]ENDVLY>=[M:EVA0]EVADATEND) | ([F:STG]STRVLY=[0/0/0] |
# [F:STG]ENDVLY=[0/0/0]))
#& )
If fstat | !(find([M:EVA2]CPCVAL(nolign-1),[F:STG]CPCAFT) & [F:STG]FICTI=1 & (([F:STG]STRVLY<=[M:EVA0]EVADATEND & ([F:STG]ENDVLY=[0/0/0] | [F:STG]ENDVLY>=[M:EVA0]EVADATSTR))))
    GMESSAGE = mess(33,10717,1)-mess(105,10723,1)
    mkstat = 1
  Endif
Endif
End

Subprog C_LEVCPCEVA(VALEUR)
Variable Char    VALEUR()
If func AFNC.ACTIV("FRT")>0
  If VALEUR<>''
    Actzo [M:EVA2]STGCOD(nolign-1)
  Else
    Raz   [M:EVA2]STGCOD(nolign-1)
    Diszo [M:EVA2]STGCOD(nolign-1)
    Affzo [M:EVA2]STGCOD(nolign-1)
  Endif
Endif
End
#ANMCL - 2017-05-08 -  X3-29417 - END

