#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTITC63   Création des paramètres WOMMVTWAI & EOMMVTWAI                #
##########################################################################
# DM 99496 + 83332 - 10.2014 by CCC
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Initialization of WOMMVTWAI & EOMMVTWAI parameters") From LECFIC
    Call MAJ_UTITC63(DOSSIER)
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog MAJ_UTITC63(DOSSIER)
Value Char DOSSIER

 Call ECR_TRACE("UTITC63: Process Start on : "+DOSSIER,0) From GESECRAN

  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".ADOVAL"  [ADW]
  Trbegin [ADW]
  Look [F:ADW]ADW0="";"";"WOMMVTWAI"
  If fstat
      Raz [F:ADW]
      [F:ADW]PARAM = "WOMMVTWAI"
      [F:ADW]CREDAT = date$
      [F:ADW]CREUSR = GUSER
      [F:ADW]VALEUR = "1"
      Write [F:ADW]
      If fstat
          Call ECR_TRACE("WOMMVTWAI can't be initialized",1) From GESECRAN
      Endif
  Endif
  Commit

  Trbegin [ADW]
  Look [F:ADW]ADW0="";"";"EOMMVTWAI"
  If fstat
      Raz [F:ADW]
      [F:ADW]PARAM = "EOMMVTWAI"
      [F:ADW]CREDAT = date$
      [F:ADW]CREUSR = GUSER
      [F:ADW]VALEUR = "1"
      Write [F:ADW]
      If fstat
          Call ECR_TRACE("EOMMVTWAI can't be initialized",1) From GESECRAN
      Endif
  Endif
  Commit
  Close Local File [ADW]
  Call ECR_TRACE("UTITC63 : finish",0) From GESECRAN

End
########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  Call MAJ_UTITC63(APPLI)

End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  Call MAJ_UTITC63(APPLI)
End
