#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Class PJMSALITMD
###################################################################################################
# METHODS
###################################################################################################
$SETERROR
#Value Char PRO ()
#Value Char MES ()
#Value Integer STA
#Local Integer ARET_VALUE

Local Char SLEVEL(250)

  If this.PBUCOD = AVOID.ACHAR and this.TASCOD = AVOID.ACHAR Then
    SLEVEL = func AFNC.MES2(mess(947,2260,1), this.OPPNUM, num$(this.SEQNUM))
  Elsif this.PBUCOD <> AVOID.ACHAR Then
    SLEVEL = func AFNC.MES3(mess(948,2260,1), this.OPPNUM, this.PBUCOD, num$(this.SEQNUM))
  Elsif this.TASCOD <> AVOID.ACHAR Then
    SLEVEL = func AFNC.MES3(mess(949,2260,1), this.OPPNUM, this.TASCOD, num$(this.SEQNUM))
  Endif
  #[L]ARET_VALUE = fmet this.ASETERROR (PRO, SLEVEL + "\" + MES, STA)                                                    # Issue X3-85933 - 2018-06-19 by FGR
  [L]ARET_VALUE = fmet this.ASETERROR (func OPPOR_CSTD_PROGS_COM.GET_PROPERTY_TITLE(this, PRO), SLEVEL + "\" + MES, STA) # Issue X3-85933 - 2018-06-19 by FGR
Return

###################################################################################################
$SALES_DOC_EXIST
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_ANO
  If this.ASTALIN = [V]CST_AUPD Then
    If this.PSONUM <> AVOID.ACHAR Then
      [L]ARET_VALUE = [V]CST_AYES
    Endif
  Endif
Return

###################################################################################################
$UOM_CONTROL
#Local Integer ARET_VALUE

Local Integer ISBPC
Local Integer IFOUND
Local Integer NI

  [L]ARET_VALUE = [V]CST_AOK
  If this.OPPCMP = AVOID.ACHAR Then
    ISBPC = [V]CST_ANO
  Else
    ISBPC = [V]CST_AYES
  Endif
  #--------------------------
  Local File ITMMASTER [ITM]
  Local File ITMBPC    [ITU]
  #--------------------------
  Read [ITM]ITM0=this.ITMREF
  If ISBPC = [V]CST_AYES Then
    Read [F:ITU]ITU0=this.ITMREF;this.OPPCMP
    If !fstat Then
      ISBPC = [V]CST_ANO
      Raz [F:ITU]
    Endif
  Endif
  #--------------------------
  IFOUND = [V]CST_ANO
  #--------------------------
  If ISBPC = [V]CST_AYES Then
    If [F:ITU]SAU = this.SAU Then
      IFOUND = [V]CST_AYES
    Endif
  Endif
  #--------------------------
  If IFOUND = [V]CST_ANO Then
    If [F:ITM]SAU = this.SAU Then
      IFOUND = [V]CST_AYES
    Endif
  Endif
  #--------------------------
  If IFOUND = [V]CST_ANO Then
    If [F:ITM]STU = this.SAU Then
      IFOUND = [V]CST_AYES
    Endif
  Endif
  #--------------------------
  If IFOUND = [V]CST_ANO Then
    For NI = 0 To dim([F:ITM]PCU)-1
      If [F:ITM]PCU(NI) = AVOID.ACHAR Then
        Break
      Else
        If [F:ITM]PCU(NI) = this.SAU Then
          IFOUND = [V]CST_AYES
          Break
        Endif
      Endif
    Next NI
  Endif
  #--------------------------
  If IFOUND = [V]CST_ANO Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("SAU", func AFNC.MES1(mess(391,2260,1), this.SAU), [V]CST_AERROR))
  Endif
  #--------------------------
Return

###################################################################################################
$QTY_CONVERT
#Local Integer ARET_VALUE

Local Decimal WCOEF

  [L]ARET_VALUE = [V]CST_AOK
  Call SCAL_QDST(this.snapshot.QTY, this.ITMREF, this.OPPCMP, this.snapshot.SAU, this.SAU, this.QTY, WCOEF) From TRTVENQTE_SYRA
Return

###################################################################################################
$GET_SPLD_KEYCONCAT
  [L]ARET_VALUE = func PJMSALITMD_CSTD_PROGS.GET_SPLD_KEYCONCAT(this.ACTX, this.OPPNUM, this.PBUCOD, this.TASCOD, this.SEQNUM)
Return

