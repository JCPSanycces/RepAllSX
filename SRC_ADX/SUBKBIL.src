#<AdxTL>@(#)11.0.0.0 $Revision$
###########################################################################
## SPECALBIL   Calcul des indicateurs bilan social
###########################################################################
$ACTION
Case ACTION
 When "DEBUT"     : Gosub DEBUT
 When "LECTURE"   : Gosub LECTURE
 When "CALCUL"    : Gosub CALCUL
 When "MOYENNE"   : Gosub MOYENNE
 When "FIN"
Endcase
Return
 
###########################################################################
## Principales variables utilisables
###########################################################################
##  A) Au niveau de chaque salarié (Action CALCUL)
###########################################################################
##  A1) Variables initialisées d'après la fiche personnel (E/S, Contrat, ...)
###########################################################################
##  NBENT        Nombre d'entrées-sorties sur la période
##  DATENT()     Date d'entrée
##  DATSOR()     Date de sortie
##  TYPENT()     Motif entrée (ADI 386)
##  CATENT()     Motif entrée (code TDS)                  
##  TYPSOR()     Motif sortie (ADI 359)
##  CATSOR()     Motif sortie (code TDS)
##  DEPART()     Départ définitif (N/O)
##  CONTRAT()    Nature contrat (ADI 354)
##  CATCONT()    Nature contrat (code TDS)
##  TYPCONT()    Type de contrat (Menu 312)
##  STATUT()     Statut professionnel (ADI 357)
##  CATSTA()     Statut professionnel (code TDS)
##  [F:XXX]      Tables employés en ligne à la date de fin
###########################################################################
##  PRESENT      Présent en fin de période (31/12)
##  PERMANENT    Présent sur toute la période
##  NOMBRE       Nombre de présence en fin de mois
###########################################################################
##  A2) Variables initialisées d'après les feuilles de paye
###########################################################################
##  PAYE         Présence d'une paye le dernier mois (décembre)
##  SALAIRE      Salaire du dernier mois (décembre)
##  MASSE        Salaire total de la période
##  HTRAV        Heures travaillées
##  HSTAGE       Heures travaillées avec un contrat "stagiaire"
##  RENDEMENT    Indicateur de prime de rendement
###########################################################################
##  A3) Variables initialisées d'après les temps saisis
###########################################################################
##  ABSENCE      Nb de jours d'absence
##  MALADIE      Nb de jours de maladie
##  MATERNITE    Nb de jours de maternité
##  PATERNITE    Nb de jours de paternité
##  ACCIDENT     Nb de jours d'AT
##  NBACC        Nb d'accidents du travail
##  ABSAUTOR     Nb de jours d'absence autorisée
##  AUTABS       Nb de jours d'autres absences
##  FORM1        Nb de jours de formation rémunérée
##  FORM2        Nb de jours de formation non rémunérée
##  REPOS1       Nb de jours de repos compensateur (légal)
##  REPOS2       Nb de jours de repos compensateur (conventionnel)
##  CHOMAGE      Nb d'heures de chômage partiel
##  INTEMP       Nb d'heures de chômage intempéries
###########################################################################
##  A4) Variables initialisées d'après le planning
###########################################################################
##  NUIT         Indicateur travail de nuit
##  ALTERNE      Indicateur alternance de semaines
##  FLCONGE      Indicateur 2 jours de repos consécutifs
##  PERSO        Indicateur planning individuel
###########################################################################
##  A5) Variables initialisées d'après le module participation
###########################################################################
##  PARTICIPE    Montant participation individuelle
###########################################################################
###########################################################################
##  B) Au niveau global (Actions LECTURE et MOYENNE)
###########################################################################
##  B1) Variables générales
###########################################################################
##  SOCIETE      Société
##  SITE         Site
##  DATDEB       Date début de période
##  DATFIN       Date fin de période
##  NBMOIS       Nb de mois de la période
##  FERIE        Nb de jours fériés de la période (d'aprsç gestion des temps)
##  TAUXAT       Taux AT du site (fiche AT)
###########################################################################
##  VALEUR       Valeur de retour (si ventilaton auto)
##  TABLEAU(1..) Valeur de retour (si ventilaton manuelle)
##  OKVAL        (Action CALCUL)  : 1=Valeur valide, 0=non
##  OKIND        (Action LECTURE) : 1=Calculer, 0=non
###########################################################################
##  B2) Tableau des indicateurs
###########################################################################
##  NBINDIC      Nb d'indicateurs
##  INDIC(I)     Tableau des indicateurs
##  FLINDIC(I)   Flag "à calculer" (1) ou non (0)
##  MLIG(I)      Nb de lignes
##  MCOL(I)      Nb de colonnes
##  TOTAL(I,J,K) Résultats i=indicateur, j=ligne, k=colonne
###########################################################################
##  B3) D'après les feuilles de paye
###########################################################################
##  NBPAYE       Nombre de salaires (permanent, temps plein, en décembre)
##  TBSAL(1..)   Tableau des salaires
###########################################################################
##  B4) D'après le module participation
###########################################################################
##  RESERVE      Réserve de participation (société)
###########################################################################

###########################################################################
# Ouverture tables, déclarations, ...
###########################################################################

$DEBUT
Return

###########################################################################
# Lecture des indicateurs
###########################################################################

$LECTURE
OKIND = 1
Case INDICATEUR
 When Default
Endcase
Return

###########################################################################
# Calcul pour chaque salarié
###########################################################################

$CALCUL
Case INDICATEUR
 When Default
  VALEUR = VALEUR
Endcase
Return

###########################################################################
# Moyennes pour certains indicateurs
###########################################################################

$MOYENNE
Case INDICATEUR
 When Default
  For J=1 To MLIG(I)
   For K=1 To MCOL(I)
    TOTAL(I,J,K) = TOTAL(I,J,K)
   Next K
  Next J
Endcase
Return

