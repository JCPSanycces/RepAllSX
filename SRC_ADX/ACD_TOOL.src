#<AdxTL>@(#)0.0.0.0 $Revision$

#**
#* PLAGE  Reserved ranges (screens, processes, tables, statuses, menus, messages)
#*
#* @param CODE - Code to be checked (char value, if message use num$(message number) )
#* @param TYP - value from local menu 7865
#* @param MESSAGE - Returned error or warning message returned
#* @param Status of Plage - [V]CST_AWARNING, [V]CST_AERROR, [V]CST_AOK
#*!
Funprog PLAGE(CODE,TYP,MESSAGE)
Value Char CODE
Value Integer TYP
Variable Char MESSAGE

Local Integer MY_STATUS, RESERVED_WORD, RANGE
[L]MY_STATUS=[V]CST_AOK

If [L]CODE<>AVOID.ACHAR & [L]TYP<>0
  #Object
  If TYP=1
    RESERVED_WORD = find(CODE,"COM1","COM2","COM3","COM4","COM5","COM6","COM7","COM8","COM9")
    RESERVED_WORD += find(CODE,"AUX","LPT1","LPT2","LPT3","PRN","NUL")
    If RESERVED_WORD>0
      # Reserved code
      MESSAGE = CODE-":"-mess(205,133,1) : # Code réservé
      [L]MY_STATUS = [V]CST_AERROR
    Endif
  Endif
  If [L]MY_STATUS = [V]CST_AOK
    Gosub PLAGE_CTL
  Endif
Endif
End [L]MY_STATUS

#----------------------------#
$PLAGE_CTL
Local Instance MY_ACTLDEV Using C_ACTLDEV
Local Integer OKPLG , OKENV , IDX, TYPDOS, ER, PRODUIT
Local Char    DEB(30) , FIN(30)

Local File ACTLDEV [ACD]

# Define/initialize global variables used in calculations
If dim(GADONIX)<1
  Global Integer GADONIX : GADONIX=[V]CST_AFALSE
Endif

If dim(GSOPHIA)<1
  Global Integer GSOPHIA : GSOPHIA=[V]CST_AFALSE
Endif

# Contrôle
For [ACD]
  MY_ACTLDEV = NewInstance C_ACTLDEV AllocGroup null
  [L]MY_STATUS = fmet MY_ACTLDEV.AREAD([F:ACD]COD)
  If [L]MY_STATUS = [V]CST_AOK
    # Fields (properties)
    If TYP=4
      [L]OKENV = [V]CST_ATRUE
      If [L]ENVCUR=1 & [L]ENVOBJ=1 & ACTLDEV.DEV<>1
        [L]OKENV = [V]CST_AERROR : # En développement std, sur un écran std, on ne peut pas utiliser des champs spé
      Elsif [L]ENVCUR<>1 & [L]ENVOBJ=1 & ACTLDEV.DEV=1
        [L]OKENV = [V]CST_AERROR : # En développement spé, sur un écran std, on ne peut pas utiliser des champs std
      Endif
    Else
      ER = [V]CST_AOK
      [L]OKENV=[V]CST_ATRUE
      Onerrgo ER
        [L]OKENV = evalue(MY_ACTLDEV.ENV)
      Onerrgo
      If ER<>[V]CST_AOK
        [L]OKENV = [V]CST_AFALSE
      Endif
    Endif

    [L]TYPDOS = fmet MY_ACTLDEV.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD,MY_ACTLDEV.ACTX.AFOLDER,"TYPDOS")
     Case MY_ACTLDEV.PRO
       When 2 : [L]OKENV *= ([L]TYPDOS=0)  : # Superviseur
       When 3 : [L]OKENV *= ([L]TYPDOS=1)  : # X3
       When 4 : [L]OKENV *= ([L]TYPDOS=2)  : # Géode
       When 5 : [L]OKENV *= ([L]TYPDOS=3)  : # Paye
     Endcase

     For IDX=1 To MY_ACTLDEV.NBLIG
       If MY_ACTLDEV.COLACD(IDX).TYP=[L]TYP
         RANGE = instr(1,MY_ACTLDEV.COLACD(IDX).RAN,"-")
         If RANGE
           [L]DEB = left$(MY_ACTLDEV.COLACD(IDX).RAN,RANGE-1)
           [L]FIN = right$(MY_ACTLDEV.COLACD(IDX).RAN,RANGE+1)
           Case [L]TYP
             When 1,4  : [L]OKPLG = (CODE>=[L]DEB & CODE<=[L]FIN)   # Objects/fields
             When 2,3  : [L]OKPLG = (val(CODE)>=val([L]DEB) & val(CODE)<=val([L]FIN)) # local menus-messages
           Endcase
           If [L]OKPLG = [V]CST_ATRUE
             If [L]OKENV = [V]CST_AFALSE
               # Code réservé
               MESSAGE = mess(205,133,1)-func ASYRFNC.TEXTRA("ACTLDEV","INTCOD",MY_ACTLDEV.COD,"")-"("+MY_ACTLDEV.COD+")"
               [L]MY_STATUS = [V]CST_AWARNING
               Break 1
             Endif
           Endif
         Endif
       Endif
     Next IDX
   Endif

  FreeGroup MY_ACTLDEV
  If [L]MY_STATUS <> [V]CST_AOK         # Freegroup then break
    Break 1
  Endif
Next ACD
Return

$ER
ER = errn
Resume

#-----------------------------------------------------------------------------------------------------#
#  Reserved ranges for fields (screens, tables, views)
#-----------------------------------------------------------------------------------------------------#
#**
#* PLAGE_ZON Reserved fields (screens, processes, tables, statuses, menus, messages)
#*
#* @param OBJET - Object as type 1 from local menu 7865
#* @param ZONE - Field name to check
#* @param MESSAGE - Returned error or warning message returned
#* @param Status of Plage - [V]CST_AWARNING, [V]CST_AERROR, [V]CST_AOK
#*!
Funprog PLAGE_ZON(OBJET,ZONE,MESSAGE)
Value Char OBJET,ZONE,MESSAGE

Local Instance MY_ACTLDEV Using C_ACTLDEV
Local File ACTLDEV [ACD]
Local Integer ER , IDX , RANGE, MY_STATUS, TYPDOS, PRODUIT
Local Char    CODE(GLONAVA)
Local Integer ENVOBJ , ENVCUR , TYP, OKENV

# Load allowable field names
Gosub ZONRES

# Check if field name is allowed and object is not blank
If OBJET<>AVOID.ACHAR & find(ZONE,"",ZONRES(1..NBRES))=0
  # Search current level of development
  [L]ENVCUR = 0
  For [ACD]
    MY_ACTLDEV = NewInstance C_ACTLDEV AllocGroup null
    [L]MY_STATUS = fmet MY_ACTLDEV.AREAD([F:ACD]COD)
    If [L]MY_STATUS = [V]CST_AOK
      ER = [V]CST_AFALSE
      Onerrgo ER
      [L]OKENV = evalue(MY_ACTLDEV.ENV)
      Onerrgo
      If ER<>[V]CST_AFALSE
        [L]OKENV = [V]CST_AFALSE
      Endif
      [L]TYPDOS = fmet MY_ACTLDEV.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD,MY_ACTLDEV.ACTX.AFOLDER,"TYPDOS")
      Case [F:ACD]PRO
        When 2 : [L]OKENV *= ([L]TYPDOS=0)      : # Superviseur
        When 3 : [L]OKENV *= ([L]TYPDOS=1)      : # X3
        When 4 : [L]OKENV *= ([L]TYPDOS=2)      : # Géode
        When 5 : [L]OKENV *= ([L]TYPDOS=3)      : # Paye
      Endcase
      If [L]OKENV
        [L]ENVCUR = max(ENVCUR,MY_ACTLDEV.DEV) : # Level of development
      Endif
    Endif
    FreeGroup MY_ACTLDEV
  Next ACD

  # Search current level of development
  [L]ENVOBJ = -1
  For [ACD]
    MY_ACTLDEV = NewInstance C_ACTLDEV AllocGroup null
    [L]MY_STATUS = fmet MY_ACTLDEV.AREAD([F:ACD]COD)
    If [L]MY_STATUS = [V]CST_AOK
      For IDX=1 To  MY_ACTLDEV.NBLIG
        If MY_ACTLDEV.COLACD(IDX).TYP=1 : # Objet
          RANGE = instr(1,MY_ACTLDEV.COLACD(IDX).RAN,"-")
          If RANGE
            If OBJET>=left$(MY_ACTLDEV.COLACD(IDX).RAN,RANGE-1) & OBJET<=right$(MY_ACTLDEV.COLACD(IDX).RAN,RANGE+1)
              ENVOBJ = MY_ACTLDEV.DEV
              Break 1
            Endif
          Endif
        Endif
      Next IDX
    Endif
    FreeGroup ACTLDEV
    If [L]ENVOBJ>=0
      Break
    Endif
  Next ACD

  # Field control
  CODE = ZONE
  TYP  = 4
  Gosub PLAGE_CTL
Endif
End [L]MY_STATUS


#**
#* Fields that are allowed without warning regardless of envirnonment
#*!
$ZONRES
Local Char ZONRES(GLONAVA)(1..30)
Local Integer NBRES
NBRES = 0
NBRES += 1 : ZONRES(NBRES) = "CREUSR"
NBRES += 1 : ZONRES(NBRES) = "CREDAT"
NBRES += 1 : ZONRES(NBRES) = "CRETIM"
NBRES += 1 : ZONRES(NBRES) = "UPDUSR"
NBRES += 1 : ZONRES(NBRES) = "UPDDAT"
NBRES += 1 : ZONRES(NBRES) = "UPDTIM"
NBRES += 1 : ZONRES(NBRES) = "EXPNUM"
NBRES += 1 : ZONRES(NBRES) = "MODULE"
NBRES += 1 : ZONRES(NBRES) = "CREDATTIM"
NBRES += 1 : ZONRES(NBRES) = "UPDDATTIM"
NBRES += 1 : ZONRES(NBRES) = "AUUID"
NBRES += 1 : ZONRES(NBRES) = "ENAFLG"
Return

