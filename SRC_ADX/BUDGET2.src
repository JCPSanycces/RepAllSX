#<AdxTL>@(#)2.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"FBUD","BUDGET","DBUDCRI",4,"") From GTRAITE
End

##########################################################################################
## Chargement Lecture Enregistrement Abandon Suiv/Prev/Prem/Dern
## Toutes les fonctions de base du GSAISIE spécifiques à chaque type de budget
##
##########################################################################################
# CLECUR1    = CPY
# CLECUR2(1) = FIY
# CLECUR2(2) = ACC
# CLECUR2(3) = CCE1
# CLECUR2(4) = CCE2
# CLECUR2(5) = CCE3
# CLECUR2(6)  = CCE4
# CLECUR2(7)  = CCE5
# CLECUR2(8)  = CCE6
# CLECUR2(9)  = CCE7
# CLECUR2(10) = CCE8
# CLECUR2(11) = CCE9
# CLECUR2(12) = FCY

# TYPDEF=1 : Défilement sur compte
# TYPDEF=2 : Défilement sur section
# TYPDEF=3 : Défilement sur pyramide de comptes
# TYPDEF=4 : Défilement sur pyramide de sections

# Pour les budgets par période et par compte
#   defile=1 si défilement par compte / defile=2 si défilement sur axe1
#   defile=3 si défilement sur axe2   / defile=4 si défilement sur axe3 ...
# Pour les budgets par section
#   defile=1 si défilement sur axe1 / defile=2 si défilement sur axe2
#   defile=3 si défilement sur axe3

##########################################################################################
#                                 BUDGET PAR PERIODE                                     #
##########################################################################################

$DISPLAYPER
# Affichage des périodes : On prend les periodes de la 1ère société saisie dans les critères
# budgets, car tous les budgets doivent être sur la même société (mais site ou niveau <>)
nolign = 0
Filter [PER]
For [PER]PER0 Where CPY=[M:BCR]CPY & PERSTR>=[M:BCR]DATD & PEREND<=[M:BCR]DATF & LEDTYP = [M:BCR]LEDTYP
 [M:BUD]PERSTR(nolign) = [F:PER]PERSTR
 [M:BUD]PEREND(nolign) = [F:PER]PEREND
 [M:BUD]FIYNUM(nolign) = [F:PER]FIYNUM
 [M:BUD]PERNUM(nolign) = [F:PER]PERNUM
 nolign +=1
 If nolign>= dim([M:BUD]PERSTR)
  Call MESSAGE(mess(26,100,1)) From GESECRAN : # Tableau plein
  Break
 Endif
Next
[M:BUD]NBLIG = nolign
Return

#################################################################
$DEFCRITPER
Gosub INDDIE From BUDGET3
CRITERE  = "1=1"
If DEFILE=1 : # Défilement sur le compte
 If [F:BUP]PYMACC<>""
  CRITERE += " & PYM='"+[F:BUP]PYMACC+"'"
  CRITERE += " & LEV="+num$([F:BUP]PYMACCLEV)
  CRITERE += " & BUDTRK=2"
 Else
  Gosub CRITERE
 Endif
Else        : # Défilement sur Section
 IND = DEFILE-1
 If [F:BUP]PYMCCE(IND-1)<>""
  CRITERE += " & PYM='"+[F:BUP]PYMCCE(IND-1)+"'"
  CRITERE += " & LEV="+num$([F:BUP]PYMCCELEV(IND-1))
  CRITERE += " & BUDTRK=2"
 Else
  CRITERE += " & DIE='"+[F:BUP]DIE(IND-1)+"'"
  Gosub CRITERE
 Endif
Endif
If DEFILE<>1 & [F:BUP]PYMCCE(DEFILE-2)=""
 TYPDEF = 2
Elsif (DEFILE=1 & [F:BUP]PYMACC<>"")
 TYPDEF = 3
Elsif (DEFILE<>1 & [F:BUP]PYMCCE(DEFILE-2)<>"")
 TYPDEF = 4
Else
 TYPDEF = 1
Endif
Return

#################################################################
## Load the budget
$LOAD_BUDPER
OK = 1
For I=0 To [M:BCR]NBCRI-1
 Call LECTURE("BUP",[M:BCR]BUD(I),"") From CONTOBJ
 NEWCLE1    = [M:BCR]CPY(I)
 # si budget défini au niveau société
 If [F:BUP]LEV=1
  NEWCLE2(12) = ""
 Else
  NEWCLE2(12) = [M:BCR]FCY(I)
 Endif
 NOL = 1
 For J=[M:BCR]FIYSTR(I) To [M:BCR]FIYEND(I)
  NEWCLE2(1) = num$(J)
  Case COUZON
   When "ACC"  : Gosub FILL_NEWCLEPER : NEWCLE2(2) = CZ
   When "CCE1" : Gosub FILL_NEWCLEPER : NEWCLE2(3) = CZ
   When "CCE2" : Gosub FILL_NEWCLEPER : NEWCLE2(4) = CZ
   When "CCE3" : Gosub FILL_NEWCLEPER : NEWCLE2(5) = CZ
   When "CCE4" : Gosub FILL_NEWCLEPER : NEWCLE2(6) = CZ
   When "CCE5" : Gosub FILL_NEWCLEPER : NEWCLE2(7) = CZ
   When "CCE6" : Gosub FILL_NEWCLEPER : NEWCLE2(8) = CZ
   When "CCE7" : Gosub FILL_NEWCLEPER : NEWCLE2(9) = CZ
   When "CCE8" : Gosub FILL_NEWCLEPER : NEWCLE2(10) = CZ
   When "CCE9" : Gosub FILL_NEWCLEPER : NEWCLE2(11) = CZ
  Endcase

  # Search the index of the dimension of the budget in the dimension of the ledger
  # Recherche de l'indice de l'axe budget par rapport à l'axe du référentiel
  Gosub INIVAR_BUDCCE
  Read [F:BUD]BUD0=[M:BCR]LEDTYP(I);[M:BCR]BUD(I);NEWCLE1;NEWCLE2(12);val(NEWCLE2(1));[M:BCR]VER(I);NEWCLE2(2);
&                  BUDCCE(0);BUDCCE(1);BUDCCE(2);BUDCCE(3);BUDCCE(4);BUDCCE(5);BUDCCE(6);BUDCCE(7);BUDCCE(8)

  If fstat : Raz [F:BUD] : Endif
  Gosub INDDIE From BUDGET3
  If NEWCLE2(2)<>"" & (NEWCLE2(3)<>"" | INDDIE<1) & (NEWCLE2(4)<>"" | INDDIE<2) & (NEWCLE2(5)<>"" | INDDIE<3)
&                   & (NEWCLE2(6)<>"" | INDDIE<4) & (NEWCLE2(7)<>"" | INDDIE<5) & (NEWCLE2(8)<>"" | INDDIE<6)
&                   & (NEWCLE2(9)<>"" | INDDIE<7) & (NEWCLE2(10)<>"" | INDDIE<8) & (NEWCLE2(11)<>"" | INDDIE<9)
   # Toutes les clés ont été saisies
   REP = "" : GREP = ""
   CLECUR = 1
   nolign = NOL
   CLECUR1 = NEWCLE1       : CLECUR2(1) = NEWCLE2(1) : CLECUR2(2) = NEWCLE2(2)
   CLECUR2(3) = NEWCLE2(3) : CLECUR2(4) = NEWCLE2(4) : CLECUR2(5) = NEWCLE2(5)
   CLECUR2(6) = NEWCLE2(6)
   CLECUR2(7) = NEWCLE2(7) : CLECUR2(8) = NEWCLE2(8) : CLECUR2(9) = NEWCLE2(9)
   CLECUR2(10) = NEWCLE2(10) : CLECUR2(11) = NEWCLE2(11): CLECUR2(12) = NEWCLE2(12)
   Gosub READ_BUDPER
   If GOK=0 : OK = 0 : Break 2 : Endif
   If nolign>[M:BUD]NBLIG : Break : Endif
  Else OK = 0 : Break 2 : # Toutes les clés n'ont pas été saisies
  Endif
 Next J
Next I
If OK : Affzo [M:BUD]20-40 : Endif : # Pour ne pas afficher inutilement et perdre du temps
Return

#################################################################
$FILL_NEWCLEPER
NEWCLE2(2) = [M:BUD]ACC
NEWCLE2(3) = [M:BUD]CCE1
NEWCLE2(4) = [M:BUD]CCE2
NEWCLE2(5) = [M:BUD]CCE3
NEWCLE2(6) = [M:BUD]CCE4
NEWCLE2(7) = [M:BUD]CCE5
NEWCLE2(8) = [M:BUD]CCE6
NEWCLE2(9) = [M:BUD]CCE7
NEWCLE2(10) = [M:BUD]CCE8
NEWCLE2(11) = [M:BUD]CCE9
Return

#################################################################
$INIVAR_BUDCCE
Call GET_LEDCUR(GACTX,[M:BCR]CPY(I),[M:BCR]LEDTYP,CODLED,DEVLED,GMESSAGE) From FINACM_SYRA
Call LEC_LED(CODLED) From CPTLEC
Raz BUDCCE, BUDDIE
For L=0 To [F:LED]DIENBR-1
 If [F:LED]DIE(L)=[F:BUP]DIE(0)
  If [M:BCR]BUDCAT=1 : BUDCCE(L) = NEWCLE2(3) : Else BUDCCE(L) = CLECUR2(3) : Endif
  BUDDIE(L) = [F:BUP]DIE(0)
 Elsif [F:LED]DIE(L)=[F:BUP]DIE(1)
  If [M:BCR]BUDCAT=1 : BUDCCE(L) = NEWCLE2(4) : Else BUDCCE(L) = CLECUR2(4) : Endif
  BUDDIE(L) = [F:BUP]DIE(1)
 Elsif [F:LED]DIE(L)=[F:BUP]DIE(2)
  If [M:BCR]BUDCAT=1 : BUDCCE(L) = NEWCLE2(5) : Else BUDCCE(L) = CLECUR2(5) : Endif
  BUDDIE(L) = [F:BUP]DIE(2)
 Elsif [F:LED]DIE(L)=[F:BUP]DIE(3)
  If [M:BCR]BUDCAT=1 : BUDCCE(L) = NEWCLE2(6) : Else BUDCCE(L) = CLECUR2(6) : Endif
  BUDDIE(L) = [F:BUP]DIE(3)
 Elsif [F:LED]DIE(L)=[F:BUP]DIE(4)
  If [M:BCR]BUDCAT=1 : BUDCCE(L) = NEWCLE2(7) : Else BUDCCE(L) = CLECUR2(7) : Endif
  BUDDIE(L) = [F:BUP]DIE(4)
 Elsif [F:LED]DIE(L)=[F:BUP]DIE(5)
  If [M:BCR]BUDCAT=1 : BUDCCE(L) = NEWCLE2(8) : Else BUDCCE(L) = CLECUR2(8) : Endif
  BUDDIE(L) = [F:BUP]DIE(5)
 Elsif [F:LED]DIE(L)=[F:BUP]DIE(6)
  If [M:BCR]BUDCAT=1 : BUDCCE(L) = NEWCLE2(9) : Else BUDCCE(L) = CLECUR2(9) : Endif
  BUDDIE(L) = [F:BUP]DIE(6)
 Elsif [F:LED]DIE(L)=[F:BUP]DIE(7)
  If [M:BCR]BUDCAT=1 : BUDCCE(L) = NEWCLE2(10) : Else BUDCCE(L) = CLECUR2(10) : Endif
  BUDDIE(L) = [F:BUP]DIE(7)
 Elsif [F:LED]DIE(L)=[F:BUP]DIE(8)
  If [M:BCR]BUDCAT=1 : BUDCCE(L) = NEWCLE2(11) : Else BUDCCE(L) = CLECUR2(11) : Endif
  BUDDIE(L) = [F:BUP]DIE(8)
 Endif
Next
Return

#################################################################
## Read the balance
$READ_BUDPER
# On recherche AMTREA,QTYREA,AMTCMM,QTYCMM,AMTPRP,QTYPRP par budget/exo/compte/sections
If [F:BUP]PYMACC="" & [F:BUP]PYMCCE(0)="" & [F:BUP]PYMCCE(1)="" & [F:BUP]PYMCCE(2)="" & [F:BUP]PYMCCE(3)=""
&& [F:BUP]PYMCCE(4)="" & [F:BUP]PYMCCE(5)="" & [F:BUP]PYMCCE(6)="" & [F:BUP]PYMCCE(7)="" & [F:BUP]PYMCCE(8)=""
 Gosub LDIE From BUDGET3
 Call LEC_BLA([M:BCR]LED,[M:BCR]LEDTYP,[M:BCR]CPY(I),[M:BCR]FCY(I),CLECUR2(2),
&             LDIE1,LDIE2,LDIE3,LDIE4,LDIE5,LDIE6,LDIE7,LDIE8,LDIE9,
&             CLECUR2(3),CLECUR2(4),CLECUR2(5),CLECUR2(6),CLECUR2(7),CLECUR2(8),CLECUR2(9),
&             CLECUR2(10),CLECUR2(11),J,AMTREA,QTYREA,AMTCMM,QTYCMM,AMTPRP,QTYPRP) From BUDGET3

 Call CONVERT([M:BCR]LEDTYP,[M:BCR]CPY(I),[M:BCR]FCY(I),[M:BUD]NBLIG,AMTREA,QTYREA,AMTCMM,QTYCMM,
&             AMTPRP,QTYPRP) From BUDGET3
If GOK=0 : Return : Endif
Endif
# On charge dans le tableau les textes et les valeurs des quantités et montants du budget
For [TBU]TBU1 Where BUDTYP=[M:BCR]BUDTYP & LINSELCRI=I+1
 NOMCOL = [F:TBU]NOMZON+num$([F:TBU]COLNUM)
 nolign = NOL
 Case [F:TBU]COLTYP
  When 1  : # QTY - Quantité
   While nolign<=[M:BUD]NBLIG and [M:BUD]FIYNUM(nolign-1)=J
    Assign "[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")" With [F:BUD]QTY([M:BUD]PERNUM(nolign-1)-1)
    nolign +=1
   Wend
  When 2  : # AMT - Montant
   While nolign<=[M:BUD]NBLIG and [M:BUD]FIYNUM(nolign-1)=J
    Assign "[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")" With [F:BUD]AMT([M:BUD]PERNUM(nolign-1)-1)/[F:BUP]DIVAMT
    nolign +=1
   Wend
  When 10 : # TEX
   While nolign<=[M:BUD]NBLIG and [M:BUD]FIYNUM(nolign-1)=J
    Assign "[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")" With [F:BUD]TEXPER([M:BUD]PERNUM(nolign-1)-1)
    nolign +=1
   Wend
 Endcase

 If [F:BUP]PYMACC="" & [F:BUP]PYMCCE(0)="" & [F:BUP]PYMCCE(1)="" & [F:BUP]PYMCCE(2)="" & [F:BUP]PYMCCE(3)=""
&& [F:BUP]PYMCCE(4)="" & [F:BUP]PYMCCE(5)="" & [F:BUP]PYMCCE(6)="" & [F:BUP]PYMCCE(7)="" & [F:BUP]PYMCCE(8)=""
  Case [F:TBU]COLTYP
   When 3 : # QTYREA - Qté réelle
    While nolign<=[M:BUD]NBLIG and [M:BUD]FIYNUM(nolign-1)=J
     Assign "[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")" With QTYREA([M:BUD]PERNUM(nolign-1))
     nolign +=1
    Wend
   When 4 : # AMTREA - Montant réel
    While nolign<=[M:BUD]NBLIG and [M:BUD]FIYNUM(nolign-1)=J
     Assign "[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")" With AMTREA([M:BUD]PERNUM(nolign-1))
     nolign +=1
    Wend
   When 5 :# QTYCMM - Qté engagée
    While nolign<=[M:BUD]NBLIG and [M:BUD]FIYNUM(nolign-1)=J
     Assign "[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")" With QTYCMM([M:BUD]PERNUM(nolign-1))
     nolign +=1
    Wend
   When 6 : # AMTCMM - Montant engagé
    While nolign<=[M:BUD]NBLIG and [M:BUD]FIYNUM(nolign-1)=J
     Assign "[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")" With AMTCMM([M:BUD]PERNUM(nolign-1))
     nolign +=1
    Wend
   When 7 : # QTYPRP - Qté pré-engagée
    While nolign<=[M:BUD]NBLIG and [M:BUD]FIYNUM(nolign-1)=J
     Assign "[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")" With QTYPRP([M:BUD]PERNUM(nolign-1))
     nolign +=1
    Wend
   When 8 : # AMTPRP - Montant pré-engagé
    While nolign<=[M:BUD]NBLIG and [M:BUD]FIYNUM(nolign-1)=J
     Assign "[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")" With AMTPRP([M:BUD]PERNUM(nolign-1))
     nolign +=1
    Wend
  Endcase
 Endif
Next
NOL = nolign
Return

#################################################################
$DEFILEPER
If DEFILE = 1
 If [F:BUP]PYMACC=""
  NEWCLE2(2) = [F:GAC]ACC
  [M:BUD]ACC = [F:GAC]ACC
  Read [GAC]GAC0 = [M:BUD]COA;[M:BUD]ACC
  Call LECTEXTRA([M:BUD]DESACC,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
  [M:BUD]DTP      = [F:GAC]TIMDSP
  [M:BUD]UOMACC   = [F:GAC]UOM
 Else
  NEWCLE2(2) = [F:GRY]GRU
  [M:BUD]ACC = [F:GRY]GRU
  Filter [GRY] Where PYM = [F:BUP]PYMACC and GRU = [M:BUD]ACC and LIN=1
  Read [GRY] First
  Filter [GRY]
  Call LECTEXTRA([M:BUD]DESACC,"GACCGRUPYM","DESTRA",[F:GRY]PYM,[F:GRY]GRU) From ATEXTRA
  [M:BUD]DTP    = [F:GRY]TIMDSP
  [M:BUD]UOMACC = [F:GRY]UOM
 Endif
Elsif DEFILE = 2
 If [F:BUP]PYMCCE(0)=""
  NEWCLE2(3)  = [F:CCE]CCE
  [M:BUD]CCE1 = [F:CCE]CCE
  Call LECTURE("CCE",[M:BUD]CCE1,[M:BUD]DIE1) From CONTOBJ
  [M:BUD]DESCCE1 = [F:CCE]DES
 Else
  NEWCLE2(3)  = [F:CRY]GRU
  [M:BUD]CCE1 = [F:CRY]GRU
  Filter [CRY] Where PYM = [F:BUP]PYMCCE(0) and GRU = [M:BUD]CCE1 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE1,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Endif
Elsif DEFILE = 3
 If [F:BUP]PYMCCE(1)=""
  NEWCLE2(4)  = [F:CCE]CCE
  [M:BUD]CCE2 = [F:CCE]CCE
  Call LECTURE("CCE",[M:BUD]CCE2,[M:BUD]DIE2) From CONTOBJ
  [M:BUD]DESCCE2 = [F:CCE]DES
 Else
  NEWCLE2(4)  = [F:CRY]GRU
  [M:BUD]CCE2 = [F:CRY]GRU
  Filter [CRY] Where PYM = [F:BUP]PYMCCE(1) and GRU = [M:BUD]CCE2 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE2,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Endif
Elsif DEFILE = 4
 If [F:BUP]PYMCCE(2)=""
  NEWCLE2(5)  = [F:CCE]CCE
  [M:BUD]CCE3 = [F:CCE]CCE
  Call LECTURE("CCE",[M:BUD]CCE3,[M:BUD]DIE3) From CONTOBJ
  [M:BUD]DESCCE3 = [F:CCE]DES
 Else
  NEWCLE2(5)  = [F:CRY]GRU
  [M:BUD]CCE3 = [F:CRY]GRU
  Filter [CRY] Where PYM = [F:BUP]PYMCCE(2) and GRU = [M:BUD]CCE3 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE3,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Endif
Elsif DEFILE = 5
 If [F:BUP]PYMCCE(3)=""
  NEWCLE2(6)  = [F:CCE]CCE
  [M:BUD]CCE4 = [F:CCE]CCE
  Call LECTURE("CCE",[M:BUD]CCE4,[M:BUD]DIE4) From CONTOBJ
  [M:BUD]DESCCE4 = [F:CCE]DES
 Else
  NEWCLE2(6)  = [F:CRY]GRU
  [M:BUD]CCE4 = [F:CRY]GRU
  Filter [CRY] Where PYM = [F:BUP]PYMCCE(3) and GRU = [M:BUD]CCE4 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE4,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Endif
Elsif DEFILE = 6
 If [F:BUP]PYMCCE(4)=""
  NEWCLE2(7)  = [F:CCE]CCE
  [M:BUD]CCE5 = [F:CCE]CCE
  Call LECTURE("CCE",[M:BUD]CCE5,[M:BUD]DIE5) From CONTOBJ
  [M:BUD]DESCCE5 = [F:CCE]DES
 Else
  NEWCLE2(7)  = [F:CRY]GRU
  [M:BUD]CCE5 = [F:CRY]GRU
  Filter [CRY] Where PYM = [F:BUP]PYMCCE(4) and GRU = [M:BUD]CCE5 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE5,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Endif
Elsif DEFILE = 7
 If [F:BUP]PYMCCE(5)=""
  NEWCLE2(8)  = [F:CCE]CCE
  [M:BUD]CCE6 = [F:CCE]CCE
  Call LECTURE("CCE",[M:BUD]CCE6,[M:BUD]DIE6) From CONTOBJ
  [M:BUD]DESCCE6 = [F:CCE]DES
 Else
  NEWCLE2(8)  = [F:CRY]GRU
  [M:BUD]CCE6 = [F:CRY]GRU
  Filter [CRY] Where PYM = [F:BUP]PYMCCE(5) and GRU = [M:BUD]CCE6 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE6,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Endif
Elsif DEFILE = 8
 If [F:BUP]PYMCCE(6)=""
  NEWCLE2(9)  = [F:CCE]CCE
  [M:BUD]CCE7 = [F:CCE]CCE
  Call LECTURE("CCE",[M:BUD]CCE7,[M:BUD]DIE7) From CONTOBJ
  [M:BUD]DESCCE7 = [F:CCE]DES
 Else
  NEWCLE2(9)  = [F:CRY]GRU
  [M:BUD]CCE7 = [F:CRY]GRU
  Filter [CRY] Where PYM = [F:BUP]PYMCCE(6) and GRU = [M:BUD]CCE7 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE7,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
Endif
Elsif DEFILE = 9
 If [F:BUP]PYMCCE(7)=""
  NEWCLE2(10)  = [F:CCE]CCE
  [M:BUD]CCE8 = [F:CCE]CCE
  Call LECTURE("CCE",[M:BUD]CCE8,[M:BUD]DIE8) From CONTOBJ
  [M:BUD]DESCCE8 = [F:CCE]DES
 Else
  NEWCLE2(10)  = [F:CRY]GRU
  [M:BUD]CCE8 = [F:CRY]GRU
  Filter [CRY] Where PYM = [F:BUP]PYMCCE(7) and GRU = [M:BUD]CCE8 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE8,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Endif
Elsif DEFILE = 10
 If [F:BUP]PYMCCE(8)=""
  NEWCLE2(11)  = [F:CCE]CCE
  [M:BUD]CCE9 = [F:CCE]CCE
  Call LECTURE("CCE",[M:BUD]CCE9,[M:BUD]DIE9) From CONTOBJ
  [M:BUD]DESCCE9 = [F:CCE]DES
 Else
  NEWCLE2(11)  = [F:CRY]GRU
  [M:BUD]CCE9 = [F:CRY]GRU
  Filter [CRY] Where PYM = [F:BUP]PYMCCE(8) and GRU = [M:BUD]CCE9 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE9,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Endif
Endif
Return

#################################################################
## Enregistrement du budget par période
$TR_BUDPER
GOK = 1
Trbegin [BUD]
 # Parcours s/ budgets
 For I=0 To [M:BCR]NBCRI-1
  # Recherche du nom des zones Quantité budget, Montant budget, Texte de la ligne critère
  Raz QTYZON,MTZON,TXZON
  Filter [TBU] Where BUDTYP=[M:BCR]BUDTYP & LINSELCRI=I+1 & (COLTYP=1 | COLTYP=2 | COLTYP=10)
   For [TBU]TBU1
    Case [F:TBU]COLTYP
     When 1  : QTYZON = [F:TBU]NOMZON+num$([F:TBU]COLNUM)
     When 2  : MTZON  = [F:TBU]NOMZON+num$([F:TBU]COLNUM)
     When 10 : TXZON  = [F:TBU]NOMZON+num$([F:TBU]COLNUM)
    Endcase
   Next
  Filter [TBU]

  Call LECTURE("BUP",[M:BCR]BUD(I),"") From CONTOBJ
  [L]CPY = [M:BCR]CPY(I)
  # si budget défini au niveau société
  If [F:BUP]LEV = 1
     [L]FCY = ""
  Else
     [L]FCY = [M:BCR]FCY(I)
  Endif
  If [F:BUP]DIVAMT<>0 : DIV = [F:BUP]DIVAMT : Else : DIV = 1 : Endif

  If [F:BUP]BUPODS=3      : # Création auto autorisée
   [L]NUMCPT = ""
   [L]NBRLIG  = 0
  Endif

  # Parcours s/ exercices du budget
  For J=[M:BCR]FIYSTR(I) To [M:BCR]FIYEND(I)
   ### Avoir le budget avant modif pour OD budgétaire
   Raz [F:BUD9]
   Gosub INIVAR_BUDCCE
   Read [BUD9]BUD0=[M:BCR]LEDTYP(I);[M:BCR]BUD(I);[L]CPY;[L]FCY;J;[M:BCR]VER(I);[M:BUD]ACC;BUDCCE(0);BUDCCE(1);
&                  BUDCCE(2);BUDCCE(3);BUDCCE(4);BUDCCE(5);BUDCCE(6);BUDCCE(7);BUDCCE(8)
   Readlock [BUD]BUD0=[M:BCR]LEDTYP(I);[M:BCR]BUD(I);[L]CPY;[L]FCY;J;[M:BCR]VER(I);[M:BUD]ACC;BUDCCE(0);BUDCCE(1);
&                  BUDCCE(2);BUDCCE(3);BUDCCE(4);BUDCCE(5);BUDCCE(6);BUDCCE(7);BUDCCE(8)
   If fstat=1
    GOK=-1 : GLOCK="$BUD"-[M:BCR]BUD(I) : Break 2
   Elsif fstat
    #Création du budget
    Raz [F:BUD]
    [F:BUD]CPY    = [L]CPY
    [F:BUD]BUD    = [M:BCR]BUD(I)
    [F:BUD]FCY    = FCY
    [F:BUD]LEDTYP = [M:BCR]LEDTYP(I)
    [F:BUD]LED    = [M:BCR]LED
    [F:BUD]VER    = [M:BCR]VER(I)
    [F:BUD]FIY    = J
    [F:BUD]COA    = [M:BUD]COA
    [F:BUD]ACC    = [M:BUD]ACC
    [F:BUD]UOM    = [M:BUD]UOMACC
    [F:BUD]DIE1   = BUDDIE(0)
    [F:BUD]DIE2   = BUDDIE(1)
    [F:BUD]DIE3   = BUDDIE(2)
    [F:BUD]DIE4   = BUDDIE(3)
    [F:BUD]DIE5   = BUDDIE(4)
    [F:BUD]DIE6   = BUDDIE(5)
    [F:BUD]DIE7   = BUDDIE(6)
    [F:BUD]DIE8   = BUDDIE(7)
    [F:BUD]DIE9   = BUDDIE(8)
    [F:BUD]CCE1   = BUDCCE(0)
    [F:BUD]CCE2   = BUDCCE(1)
    [F:BUD]CCE3   = BUDCCE(2)
    [F:BUD]CCE4   = BUDCCE(3)
    [F:BUD]CCE5   = BUDCCE(4)
    [F:BUD]CCE6   = BUDCCE(5)
    [F:BUD]CCE7   = BUDCCE(6)
    [F:BUD]CCE8   = BUDCCE(7)
    [F:BUD]CCE9   = BUDCCE(8)
    [F:BUD]CREDAT = date$
    [F:BUD]CREUSR = GUSER
    [F:BUD]ACCNUM = uniqid([F:BUD])
    [F:BUD]CUR = [M:BCR]CUR(I)

    If QTYZON<>"" | MTZON<>"" | TXZON<>""
     For K=0 To [M:BUD]NBLIG-1
      If [M:BUD]FIYNUM(K)=J & MTZON<>""
       [F:BUD]AMT([M:BUD]PERNUM(K)-1) = evalue("[M:BUD]"+MTZON+"("+num$(K)+")") * DIV
      Endif
      If [M:BUD]FIYNUM(K)=J & QTYZON<>""
       [F:BUD]QTY([M:BUD]PERNUM(K)-1) = evalue("[M:BUD]"+QTYZON+"("+num$(K)+")")
      Endif
      If [M:BUD]FIYNUM(K)=J & TXZON<>""
       [F:BUD]TEXPER([M:BUD]PERNUM(K)-1) = evalue("[M:BUD]"+TXZON+"("+num$(K)+")")
      Endif
     Next K
    Endif
    Write [BUD]
    If fstat
     GOK=0 : Call FSTA("BUD") From GLOCK : Break 2
    Endif
   Else
    # Mise à jour du budget
    [F:BUD]UPDDAT = date$
    [F:BUD]UPDUSR = GUSER
    If QTYZON<>"" | MTZON<>"" | TXZON<>""
     For K=0 To [M:BUD]NBLIG-1
      If [M:BUD]FIYNUM(K)=J & MTZON<>""
       [F:BUD]AMT([M:BUD]PERNUM(K)-1) = evalue("[M:BUD]"+MTZON+"("+num$(K)+")") * DIV
      Endif
      If [M:BUD]FIYNUM(K)=J & QTYZON<>""
       [F:BUD]QTY([M:BUD]PERNUM(K)-1) = evalue("[M:BUD]"+QTYZON+"("+num$(K)+")")
      Endif
      If [M:BUD]FIYNUM(K)=J & TXZON<>""
       [F:BUD]TEXPER([M:BUD]PERNUM(K)-1) = evalue("[M:BUD]"+TXZON+"("+num$(K)+")")
      Endif
     Next K
    Endif
    Rewrite [BUD]
    If fstat
     GOK=0 : Call FSTA("BUD") From GLOCK : Break 2
    Endif
   Endif
   If [F:BUP]BUPODS=3      : # Création auto autorisée
    Gosub CREEBDO From MAJBDO
   Endif
  Next J
 Next I
 If GOK<0 : Goto ROLL_TR_BUDPER
 Elsif !GOK : Goto AB_TR
 Endif
Commit
Return

$AB_TR
Rollback
Return

$ROLL_TR_BUDPER
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_BUDPER : Endif
Return


##########################################################################################
#                                 BUDGET PAR COMPTE                                      #
##########################################################################################

$INIT_BUDACC
## Saisie avec écran vierge
Gosub INDDIE From BUDGET3
[M]NBRLIN = 0
Gosub LOAD_KEYS_BUDACC
Effzo [BUD]25-35 : Effzo [BUD]TEX
Return

#################################################################
$LOAD_KEYS_BUDACC
Case COUZON
 When "ACC" :
  Raz NEWCLE2(3), NEWCLE2(4), NEWCLE2(5), NEWCLE2(6), NEWCLE2(7), NEWCLE2(8), NEWCLE2(9), NEWCLE2(10)
  Gosub FILL_NEWCLEACC :  NEWCLE2(2) = CZ
 When "CCE1"
  Raz NEWCLE2(4), NEWCLE2(5), NEWCLE2(6), NEWCLE2(7), NEWCLE2(8), NEWCLE2(9), NEWCLE2(10)
  Gosub FILL_NEWCLEACC :  NEWCLE2(3) = CZ
 When "CCE2"
  Raz NEWCLE2(5), NEWCLE2(6), NEWCLE2(7), NEWCLE2(8), NEWCLE2(9), NEWCLE2(10)
  Gosub FILL_NEWCLEACC :  NEWCLE2(4) = CZ
 When "CCE3"
  Raz NEWCLE2(6), NEWCLE2(7), NEWCLE2(8), NEWCLE2(9), NEWCLE2(10)
  Gosub FILL_NEWCLEACC :  NEWCLE2(5) = CZ
 When "CCE4"
  Raz NEWCLE2(7), NEWCLE2(8), NEWCLE2(9), NEWCLE2(10)
  Gosub FILL_NEWCLEACC :  NEWCLE2(6) = CZ
 When "CCE5"
  Raz NEWCLE2(8), NEWCLE2(9), NEWCLE2(10)
  Gosub FILL_NEWCLEACC :  NEWCLE2(7) = CZ
 When "CCE6"
  Raz NEWCLE2(9), NEWCLE2(10)
  Gosub FILL_NEWCLEACC :  NEWCLE2(8) = CZ
 When "CCE7"
  Raz NEWCLE2(10)
  Gosub FILL_NEWCLEACC :  NEWCLE2(9) = CZ
 When "CCE8"
  Gosub FILL_NEWCLEACC :  NEWCLE2(10) = CZ
Endcase

If NEWCLE2(2)<>"" & (NEWCLE2(3)<>"" | INDDIE<2) & (NEWCLE2(4)<>"" | INDDIE<3) & (NEWCLE2(5)<>"" | INDDIE<4)
&                 & (NEWCLE2(6)<>"" | INDDIE<5) & (NEWCLE2(7)<>"" | INDDIE<6) & (NEWCLE2(8)<>"" | INDDIE<7)
&                 & (NEWCLE2(9)<>"" | INDDIE<8) & (NEWCLE2(10)<>"" | INDDIE<9)
 # Toutes les clés ont été saisies
 REP = "" : GREP = "" : CLECUR = 1
 CLECUR1     = NEWCLE1     :# Company
 CLECUR2(2)  = NEWCLE2(2)  :# Account
 CLECUR2(12) = NEWCLE2(12) :# Site
 If INDDIE=1
  Raz CLECUR2(3), CLECUR2(4), CLECUR2(5), CLECUR2(6), CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
 Elsif INDDIE=2
  CLECUR2(3) = NEWCLE2(3)
  Raz CLECUR2(4), CLECUR2(5), CLECUR2(6), CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
 Elsif INDDIE=3
  CLECUR2(3) = NEWCLE2(3) : CLECUR2(4) = NEWCLE2(4)
  Raz CLECUR2(5), CLECUR2(6), CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
 Elsif INDDIE=4
  CLECUR2(3) = NEWCLE2(3) : CLECUR2(4) = NEWCLE2(4) : CLECUR2(5) = NEWCLE2(5)
  Raz CLECUR2(6), CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
 Elsif INDDIE=5
  CLECUR2(3) = NEWCLE2(3) : CLECUR2(4) = NEWCLE2(4) : CLECUR2(5) = NEWCLE2(5) : CLECUR2(6) = NEWCLE2(6)
  Raz CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
 Elsif INDDIE=6
  CLECUR2(3) = NEWCLE2(3) : CLECUR2(4) = NEWCLE2(4) : CLECUR2(5) = NEWCLE2(5) : CLECUR2(6) = NEWCLE2(6)
  CLECUR2(7) = NEWCLE2(7)
  Raz CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
 Elsif INDDIE=7
  CLECUR2(3) = NEWCLE2(3) : CLECUR2(4) = NEWCLE2(4) : CLECUR2(5) = NEWCLE2(5) : CLECUR2(6) = NEWCLE2(6)
  CLECUR2(7) = NEWCLE2(7) : CLECUR2(8) = NEWCLE2(8)
  Raz CLECUR2(9), CLECUR2(10), CLECUR2(11)
 Elsif INDDIE=8
  CLECUR2(3) = NEWCLE2(3) : CLECUR2(4) = NEWCLE2(4) : CLECUR2(5) = NEWCLE2(5) : CLECUR2(6) = NEWCLE2(6)
  CLECUR2(7) = NEWCLE2(7) : CLECUR2(8) = NEWCLE2(8) : CLECUR2(9) = NEWCLE2(9)
  Raz CLECUR2(10), CLECUR2(11)
 Elsif INDDIE=9
  CLECUR2(3) = NEWCLE2(3) : CLECUR2(4) = NEWCLE2(4) : CLECUR2(5) = NEWCLE2(5) : CLECUR2(6) = NEWCLE2(6)
  CLECUR2(7) = NEWCLE2(7) : CLECUR2(8) = NEWCLE2(8) : CLECUR2(9) = NEWCLE2(9) : CLECUR2(10) = NEWCLE2(10)
  Raz CLECUR2(11)
 Endif
Endif
Return

#################################################################
$FILL_NEWCLEACC
If INDDIE>=1 : NEWCLE2(2) = [M:BUD]ACC : Endif
If INDDIE>=2 : NEWCLE2(3) = [M:BUD]CCE1 : Endif
If INDDIE>=3 : NEWCLE2(4) = [M:BUD]CCE2 : Endif
If INDDIE>=4 : NEWCLE2(5) = [M:BUD]CCE3 : Endif
If INDDIE>=5 : NEWCLE2(6) = [M:BUD]CCE4 : Endif
If INDDIE>=6 : NEWCLE2(7) = [M:BUD]CCE5 : Endif
If INDDIE>=7 : NEWCLE2(8) = [M:BUD]CCE6 : Endif
If INDDIE>=8 : NEWCLE2(9) = [M:BUD]CCE7 : Endif
If INDDIE>=9 : NEWCLE2(10) = [M:BUD]CCE8 : Endif
Return
## Fin YYFIN_104036_US5

#################################################################
$LOAD_BUDACC
## Ecran pré chargé avec les sections
Gosub INDDIE From BUDGET3
AEFF=1
For I=0 To [M:BCR]NBCRI-1
 Call LECTURE("BUP",[M:BCR]BUD(I),"") From CONTOBJ
 NEWCLE1 = [M:BCR]CPY(I)
 # si budget défini au niveau société
 If [F:BUP]LEV=1
  NEWCLE2(12) = ""
 Else
  NEWCLE2(12) = [M:BCR]FCY(I)
  Endif

 Gosub LOAD_KEYS_BUDACC

 If NEWCLE2(2)<>"" & (NEWCLE2(3)<>"" | INDDIE<2) & (NEWCLE2(4)<>"" | INDDIE<3) & (NEWCLE2(5)<>"" | INDDIE<4)
&                  & (NEWCLE2(6)<>"" | INDDIE<5) & (NEWCLE2(7)<>"" | INDDIE<6) & (NEWCLE2(8)<>"" | INDDIE<7)
&                  & (NEWCLE2(9)<>"" | INDDIE<8) & (NEWCLE2(10)<>"" | INDDIE<9)

  nolign = 0
  If AEFF = 1
   Effzo [BUD]25-35 : Effzo [BUD]TEX
   AEFF = 0
  Endif
  Gosub READ_BUDACC
  If GOK=0 | GOK=2 : Break : Endif
 Endif
Next I
If GOK=0 : Return : Endif
If GOK=2 : GOK = 1 : Endif
Sorta NBLIG NBLIG Order By CODCCE3([S]indice)

Affzo [M:BUD]25-40 : Affzo [M:BUD]TEX
Return

#################################################################
# saisie budgétaire par compte
#################################################################
$READ_BUDACC
# On charge en colonne les sections du dernier axe
DEFILE = 10
Gosub DEFCRITACC
Gosub FILTACC

If [F:BUP]PYMCCE(INDDIE-1)=""
 For [CCE]CCE0
  Gosub VERF_DEFILE
  If OK
   TROUVE = find([F:CCE]CCE,[M:BUD]CODCCE3(0..[M:BUD]NBLIG-1))
   If !TROUVE
    # On ne peut plus rajouter de sections, mais pour celles chargées dans le tableau
    # il faut compléter les lignes avec tous les budgets de BUDCRI
    If nolign>=dim([M:BUD]CODCCE3)
     Call MESSAGE (mess(26,100,1)) From GESECRAN : # Tableau plein
     GOK = 2 : Break
    Endif
    [M:BUD]NBLIG +=1
    nolign = [M:BUD]NBLIG
    [M:BUD]CODCCE3(nolign-1) = [F:CCE]CCE
   Else
    nolign = TROUVE
   Endif
   If INDDIE=1
    CLECUR2(3) = [M:BUD]CODCCE3(nolign-1)
    Raz CLECUR2(4), CLECUR2(5), CLECUR2(6), CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
   Elsif INDDIE=2
    CLECUR2(4) = [M:BUD]CODCCE3(nolign-1)
    Raz CLECUR2(5), CLECUR2(6), CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
   Elsif INDDIE=3
    CLECUR2(5) = [M:BUD]CODCCE3(nolign-1)
    Raz CLECUR2(6), CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
   Elsif INDDIE=4
    CLECUR2(6) = [M:BUD]CODCCE3(nolign-1)
    Raz CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
   Elsif INDDIE=5
    CLECUR2(7) = [M:BUD]CODCCE3(nolign-1)
    Raz CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
   Elsif INDDIE=5
    CLECUR2(8) = [M:BUD]CODCCE3(nolign-1)
    Raz CLECUR2(9), CLECUR2(10), CLECUR2(11)
   Elsif INDDIE=7
    CLECUR2(9) = [M:BUD]CODCCE3(nolign-1)
    Raz CLECUR2(10), CLECUR2(11)
   Elsif INDDIE=8
    CLECUR2(10) = [M:BUD]CODCCE3(nolign-1)
    Raz CLECUR2(11)
   Elsif INDDIE=9
    CLECUR2(11) = [M:BUD]CODCCE3(nolign-1)
   Endif
   Gosub READ_AMT_QTY
   If GOK=0 : Break : Endif
  Else Raz mkstat,GMESSAGE
  Endif
 Next
Else
 For [CRY]CLE Where LIN=1
  TROUVE = find([F:CRY]GRU,[M:BUD]CODCCE3(0..[M:BUD]NBLIG-1))
  If !TROUVE
   # On ne peut plus rajouter de sections, mais pour celles chargées dans le tableau
   # il faut compléter les lignes avec tous les budgets de BUDCRI
   If nolign>=dim([M:BUD]CODCCE3)
    Call MESSAGE (mess(26,100,1)) From GESECRAN : # Tableau plein
    GOK = 2 : Break
   Endif
   [M:BUD]NBLIG +=1
   nolign = [M:BUD]NBLIG
   [M:BUD]CODCCE3(nolign-1) = [F:CRY]GRU
  Else
   nolign = TROUVE
  Endif
  If INDDIE=1
   CLECUR2(3) = [M:BUD]CODCCE3(nolign-1)
   Raz CLECUR2(4), CLECUR2(5), CLECUR2(6), CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
  Elsif INDDIE=2
   CLECUR2(4) = [M:BUD]CODCCE3(nolign-1)
   Raz CLECUR2(5), CLECUR2(6), CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
  Elsif INDDIE=3
   CLECUR2(5) = [M:BUD]CODCCE3(nolign-1)
   Raz CLECUR2(6), CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
  Elsif INDDIE=4
   CLECUR2(6) = [M:BUD]CODCCE3(nolign-1)
   Raz CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
  Elsif INDDIE=5
   CLECUR2(7) = [M:BUD]CODCCE3(nolign-1)
   Raz CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
  Elsif INDDIE=6
   CLECUR2(8) = [M:BUD]CODCCE3(nolign-1)
   Raz CLECUR2(9), CLECUR2(10), CLECUR2(11)
  Elsif INDDIE=7
   CLECUR2(9) = [M:BUD]CODCCE3(nolign-1)
   Raz CLECUR2(10), CLECUR2(11)
  Elsif INDDIE=8
   CLECUR2(10) = [M:BUD]CODCCE3(nolign-1)
   Raz CLECUR2(11)
  Elsif INDDIE=9
   CLECUR2(11) = [M:BUD]CODCCE3(nolign-1)
  Endif
  Gosub READ_AMT_QTY
  If GOK=0 : Break : Endif
 Next
Endif
Filter [CCE]
Filter [CRY]
[M:BUD]NBLIG  = nolign
[M:BUD]NBRLIN = [M:BUD]NBLIG
If [M:BUD]NBLIG>0 : CLECUR = 1 : Endif
Return

#################################################################
$DEFCRITACC
Gosub INDDIE From BUDGET3
CRITERE  = "1=1"
If DEFILE=1 : # Défilement sur Compte
 If [F:BUP]PYMACC<>""
  CRITERE += " & PYM='"+[F:BUP]PYMACC+"'"
  CRITERE += " & LEV="+num$([F:BUP]PYMACCLEV)
  CRITERE += " & BUDTRK=2"
 Else
  Gosub CRITERE
 Endif
Else        : # Défilement sur Section
 IND = DEFILE-1
 If DEFILE=10
  If [F:BUP]PYMCCE(INDDIE-1)<>""
   CRITERE += " & PYM='"+[F:BUP]PYMCCE(INDDIE-1)+"'"
   CRITERE += " & LEV="+num$([F:BUP]PYMCCELEV(INDDIE-1))
   CRITERE += " & BUDTRK=2"
  Else
   CRITERE += " & DIE='"+[F:BUP]DIE(INDDIE-1)+"'"
   Gosub CRITERE
  Endif
 Else
  If [F:BUP]PYMCCE(IND-1)<>""
   CRITERE += " & PYM='"+[F:BUP]PYMCCE(IND-1)+"'"
   CRITERE += " & LEV="+num$([F:BUP]PYMCCELEV(IND-1))
   CRITERE += " & BUDTRK=2"
 Else
   CRITERE += " & DIE='"+[F:BUP]DIE(IND-1)+"'"
   Gosub CRITERE
  Endif
 Endif
Endif
If DEFILE=10
 If [F:BUP]PYMCCE(INDDIE-1)<>""
  If [M:BCR]CCED<>"" : CRITERE -= '& GRU>="'+[M:BCR]CCED+'"' : Endif
  If [M:BCR]CCEF<>"" : CRITERE -= '& GRU<="'+[M:BCR]CCEF+'"' : Endif
 Else
  If [M:BCR]CCED<>"" : CRITERE -= '& CCE>="'+[M:BCR]CCED+'"' : Endif
  If [M:BCR]CCEF<>"" : CRITERE -= '& CCE<="'+[M:BCR]CCEF+'"' : Endif
 Endif
Endif
If DEFILE<>1 & [F:BUP]PYMCCE(DEFILE-2)=""
 TYPDEF = 2
Elsif (DEFILE=1 & [F:BUP]PYMACC<>"")
 TYPDEF = 3
Elsif  (DEFILE<>1 & [F:BUP]PYMCCE(DEFILE-2)<>"")
 TYPDEF = 4
Else
 TYPDEF = 1
Endif
Return

#################################################################
$FILTACC
If DEFILE=1 & [F:BUP]PYMACC=""
 Filter [GAC] Where evalue(CRITERE)
Elsif (DEFILE=2 & [F:BUP]PYMCCE(0)="")
& |   (DEFILE=3 & [F:BUP]PYMCCE(1)="")
& |   (DEFILE=4 & [F:BUP]PYMCCE(2)="")
& |   (DEFILE=5 & [F:BUP]PYMCCE(3)="")
& |   (DEFILE=6 & [F:BUP]PYMCCE(4)="")
& |   (DEFILE=7 & [F:BUP]PYMCCE(5)="")
& |   (DEFILE=8 & [F:BUP]PYMCCE(6)="")
& |   (DEFILE=9 & [F:BUP]PYMCCE(7)="")
& |   (DEFILE=10 & [F:BUP]PYMCCE(INDDIE-1)="")
 Filter [CCE] Where evalue(CRITERE)
Else
 # Suite à une demande faite par Jean-Marc LAVAL pour avoir les pyramides sections
 # qui sont affichées en colonnes triées par rang d'impression
 Filter [CRY] Where evalue(CRITERE) Order By Key CLE = PRNROW ; PYM ; GRU ; LIN
Endif
Return

#################################################################
$READ_AMT_QTY
# On charge toutes les valeurs des quantités et montants dans le tableau
For [TBU]TBU1 Where BUDTYP=[M:BCR]BUDTYP & LINSELCRI=I+1
 NOMCOL = [F:TBU]NOMZON+num$([F:TBU]COLNUM)
 If [F:TBU]COLTYP<=8 : Assign "[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")" With 0 : Endif
 Call LEC_BUP([M:BCR]BUD) From CPTLEC
 For J=[M:BCR]FIYSTR(I) To [M:BCR]FIYEND(I)
  NEWCLE2(1) = num$(J)
  CLECUR2(1) = NEWCLE2(1)
  Raz PDEB,PFIN
  If J=[M:BCR]FIYSTR(I) : PDEB = [M:BCR]PERDEB(I) : Endif
  If J=[M:BCR]FIYEND(I) : PFIN = [M:BCR]PERFIN(I) : Endif
  If PDEB=0 : PDEB=1 : Endif
  If PFIN=0 : Call NBPER([M:BCR]CPY(I),[M:BCR]LEDTYP,J,PFIN) From CPTSUB : Endif
  If PFIN=0 : Break : Endif

  #Lecture des montants et quantités réels engagés pré-engagés
  If [F:TBU]COLTYP>=1 & [F:TBU]COLTYP<=8
   #Lecture des montants et quantités budget
   If [F:TBU]COLTYP=2 | [F:TBU]COLTYP=1
    Gosub INIVAR_BUDCCE
    Read [BUD]BUD0=[M:BCR]LEDTYP(I);[M:BCR]BUD(I);CLECUR1;CLECUR2(12);val(CLECUR2(1));[M:BCR]VER(I);CLECUR2(2);
&                  BUDCCE(0);BUDCCE(1);BUDCCE(2);BUDCCE(3);BUDCCE(4);BUDCCE(5);BUDCCE(6);BUDCCE(7);BUDCCE(8)
    If fstat: Raz [F:BUD] : Endif

    If [F:BUD]TEX<>"" : [M:BUD]TEX = [F:BUD]TEX : Endif

    If [F:TBU]COLTYP=2 # AMT
     Assign "[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")" With
&    (sum([F:BUD]AMT(PDEB-1..PFIN-1))/[F:BUP]DIVAMT) + evalue("[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")")
    Endif
    If [F:TBU]COLTYP=1 # QTY
     Assign "[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")" With
&    sum([F:BUD]QTY(PDEB-1..PFIN-1)) + evalue("[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")")
    Endif
   Endif

   # bug 59809 - utilisation du paramétrage [F:BUP]DIE* au lieu de LDIE*

   Call LEC_BLA([M:BUD]LED,[M:BCR]LEDTYP,[M:BCR]CPY(I),[M:BCR]FCY(I),CLECUR2(2),[F:BUP]DIE(0),[F:BUP]DIE(1),
&   [F:BUP]DIE(2),[F:BUP]DIE(3),[F:BUP]DIE(4),[F:BUP]DIE(5),[F:BUP]DIE(6),[F:BUP]DIE(7),[F:BUP]DIE(8),
&   CLECUR2(3),CLECUR2(4),CLECUR2(5),CLECUR2(6),CLECUR2(7),CLECUR2(8),CLECUR2(9),CLECUR2(10),CLECUR2(11),
&             J,AMTREA,QTYREA,AMTCMM,QTYCMM,AMTPRP,QTYPRP) From BUDGET3

   Case left$(NOMCOL,6)
    When "AMTREA"
      Assign "[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")" With
&     sum(AMTREA(PDEB..PFIN))+evalue("[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")")
    When "AMTPRP"
      Assign "[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")" With
&     sum(AMTPRP(PDEB..PFIN)) + evalue("[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")")
    When "AMTCMM"
      Assign "[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")" With
&     sum(AMTCMM(PDEB..PFIN)) + evalue("[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")")
    When "QTYREA"
      Assign "[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")" With
&     sum(QTYREA(PDEB..PFIN))  + evalue("[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")")
    When "QTYPRP"
      Assign "[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")" With
&     sum(QTYPRP(PDEB..PFIN)) + evalue("[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")")
    When "QTYCMM"
      Assign "[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")" With
&     sum(QTYCMM(PDEB..PFIN)) + evalue("[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")")
   Endcase
  Endif
 Next J

 # On convertit dans la devise du budget les données issues de BALANA
 If [F:BUP]PYMACC="" & [F:BUP]PYMCCE(0)="" & [F:BUP]PYMCCE(1)="" & [F:BUP]PYMCCE(2)=""
& & [F:BUP]PYMCCE(3)="" & [F:BUP]PYMCCE(4)="" & [F:BUP]PYMCCE(5)="" & [F:BUP]PYMCCE(6)=""
& & [F:BUP]PYMCCE(7)="" & [F:BUP]PYMCCE(8)="" & [F:TBU]COLTYP>=3 & [F:TBU]COLTYP<=8
&   & (left$(NOMCOL,6)="AMTREA"| left$(NOMCOL,6)="AMTCMM" | left$(NOMCOL,6)="AMTPRP")
  CONVMT = evalue("[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")")
  Call CONVERT_ZON([M:BCR]LEDTYP(I),[M:BCR]CPY(I),[M:BCR]FCY(I),CONVMT) From BUDGET3
  If GOK=0 : Break : Endif
  Assign ("[M:BUD]"+NOMCOL+"("+num$(nolign-1)+")") With CONVMT
 Endif
 # Si saisie d'une nouvelle section ou compte, on affiche quantités et montants
 If AFFIC : Affzo ="[M:BUD]"+NOMCOL+"(nolign-1)" : Endif

Next
Return

#################################################################
$CRITERE
CRITERE  -= "& COA='"+[M]COA+"'"
CRITERE  -= "& BUDTRK=2"
# Dans les budgets par période on a les mêmes dates pour toutes les lignes de critères
If [M:BCR]BUDCAT=1
 CRITERE  -= "& (VLYEND=[0/0/0] | VLYEND>=[M:BCR]DATDEB(0))"
 CRITERE  -= "& (VLYSTR=[0/0/0] | VLYSTR<=[M:BCR]DATFIN(0))"
Endif
Return

#################################################################
$VERF_DEFILE
mkstat = 0
OK = 1

Local Char CCEACC(max(GLONGAC,GLONCCE)) : # Valeur du compte ou section
Case TYPDEF
 When 2 : # Vérification de la section
  CCEACC = [F:CCE]CCE
  ## Code d'accès
  Call CONTEXE([F:CCE]ACS) From CPTSUB
  If mkstat : OK = 0 : Return : Endif
  ## Société / site
  Call BUDSITE([F:CCE]FCY,[F:BUP]LEV,[M:BCR]FCY(I),[M:BCR]CPY(I),[F:CCE]CCE) From CFYSUB
  If mkstat : OK = 0 : Return : Endif
  ## Dates de validité
  If [F:CCE]VLYEND<>[0/0/0] & [F:CCE]VLYEND<[M:BCR]DATDEB(I)
&  | [F:CCE]VLYSTR<>[0/0/0] & [F:CCE]VLYSTR>[M:BCR]DATFIN(I)
   OK = 0 : Return  : # Section inactive
  Endif
  ## Autorisations compte
  IND = DEFILE-1
  Gosub AUTCCEACC From BUDGET3
  If !OK : Return : Endif
  ## Autorisations sections
  Gosub AUTSECSEC From BUDGET3
  If !OK : Return : Endif

 When 1 : # Vérification du compte
  CCEACC = [F:GAC]ACC
  ## Vérif code d'accès
  Call CONTEXE([F:GAC]ACS) From CPTSUB : # Vérif code d'accès
  If mkstat : OK = 0 : Return : Endif
  ## Vérif site/société
  Call BUDSITE([F:GAC]FCY,[F:BUP]LEV,[M:BCR]FCY(I),[M:BCR]CPY(I),[F:GAC]ACC) From CFYSUB
  If mkstat : OK = 0 : Return : Endif
  ## Dates de validité
  If [F:GAC]VLYEND<>[0/0/0] & [F:GAC]VLYEND<[M:BCR]DATDEB(I)
&  | [F:GAC]VLYSTR<>[0/0/0] & [F:GAC]VLYSTR>[M:BCR]DATFIN(I)
   OK = 0 : Return : # Compte inactive
  Endif
  ## Autorisations avec les sections
  IND = 0
  Gosub AUTCCEACC From BUDGET3
  If !OK : Return : Endif
Endcase
Return

#################################################################
$DEFILEACC
If DEFILE = 1 # Groupes de compte / compte
 If [F:BUP]PYMACC=""
  CLECUR2(2) = [F:GAC]ACC
  [M:BUD]ACC = [F:GAC]ACC
#  Call LECTURE("GAC",[M:BUD]ACC,[M:BUD]COA) From CONTOBJ
#  Read [GAC]GAC0=[M:BUD]COA;[M:BUD]ACC
  Call LECTEXTRA([M:BUD]DESACC,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
  [M:BUD]DTP      = [F:GAC]TIMDSP
  [M:BUD]UOMACC   = [F:GAC]UOM
 Else
  CLECUR2(2) = [F:GRY]GRU
  [M:BUD]ACC = [F:GRY]GRU
  Filter [GRY] Where PYM = [F:BUP]PYMACC and GRU = [M:BUD]ACC and LIN=1
  Read [GRY] First
  Filter [GRY]
  Call LECTEXTRA([M:BUD]DESACC,"GACCGRUPYM","DESTRA",[F:GRY]PYM,[F:GRY]GRU) From ATEXTRA
  [M:BUD]DTP    = [F:GRY]TIMDSP
  [M:BUD]UOMACC = [F:GRY]UOM
 Endif
Elsif DEFILE = 2 #Groupes de section / section: pyramide = PYMCCE(0)
 If [F:BUP]PYMCCE(0)=""
  CLECUR2(3)  = [F:CCE]CCE
  [M:BUD]CCE1 = [F:CCE]CCE
   Call LECTEXTRA([M:BUD]DESCCE1,"CACCE","DESTRA",[M:BUD]DIE1,[M:BUD]CCE1) From ATEXTRA
 Else
  CLECUR2(3)  = [F:CRY]GRU
  [M:BUD]CCE1 = [F:CRY]GRU
  Filter [CRY] Where PYM = [F:BUP]PYMCCE(0) and GRU = [M:BUD]CCE1 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE1,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Endif
Elsif DEFILE = 3 #Groupes de section / section: pyramide = PYMCCE(1)
 If [F:BUP]PYMCCE(1)=""
  CLECUR2(4)  = [F:CCE]CCE
  [M:BUD]CCE2 = [F:CCE]CCE
  Call LECTEXTRA([M:BUD]DESCCE2,"CACCE","DESTRA",[M:BUD]DIE2,[M:BUD]CCE2) From ATEXTRA
 Else
  CLECUR2(4)  = [F:CRY]GRU
  [M:BUD]CCE2 = [F:CRY]GRU
  Filter [CRY] Where PYM = [F:BUP]PYMCCE(1) and GRU = [M:BUD]CCE2 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE2,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Endif
Elsif DEFILE=4    #Groupes de section / section: pyramide = PYMCCE(2)
 If [F:BUP]PYMCCE(2)=""
  CLECUR2(5)  = [F:CCE]CCE
  [M:BUD]CCE3 = [F:CCE]CCE
  Call LECTEXTRA([M:BUD]DESCCE3,"CACCE","DESTRA",[M:BUD]DIE3,[M:BUD]CCE3) From ATEXTRA
 Else
  CLECUR2(5)  = [F:CRY]GRU
  [M:BUD]CCE3 = [F:CRY]GRU
  Filter [CRY] Where PYM=[F:BUP]PYMCCE(2) and GRU=[M:BUD]CCE3 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE3,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Endif
Elsif DEFILE=5    #Groupes de section / section: pyramide = PYMCCE(3)
 If [F:BUP]PYMCCE(3)=""
  CLECUR2(6)  = [F:CCE]CCE
  [M:BUD]CCE4 = [F:CCE]CCE
  Call LECTEXTRA([M:BUD]DESCCE4,"CACCE","DESTRA",[M:BUD]DIE4,[M:BUD]CCE4) From ATEXTRA
 Else
  CLECUR2(6)  = [F:CRY]GRU
  [M:BUD]CCE4 = [F:CRY]GRU
  Filter [CRY] Where PYM=[F:BUP]PYMCCE(3) and GRU=[M:BUD]CCE4 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE4,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Endif
Elsif DEFILE=6    #Groupes de section / section: pyramide = PYMCCE(4)
 If [F:BUP]PYMCCE(4)=""
  CLECUR2(7)  = [F:CCE]CCE
  [M:BUD]CCE5 = [F:CCE]CCE
  Call LECTEXTRA([M:BUD]DESCCE5,"CACCE","DESTRA",[M:BUD]DIE5,[M:BUD]CCE5) From ATEXTRA
 Else
  CLECUR2(7)  = [F:CRY]GRU
  [M:BUD]CCE5 = [F:CRY]GRU
  Filter [CRY] Where PYM=[F:BUP]PYMCCE(4) and GRU=[M:BUD]CCE5 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE5,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Endif
Elsif DEFILE=7    #Groupes de section / section: pyramide = PYMCCE(5)
 If [F:BUP]PYMCCE(5)=""
  CLECUR2(8)  = [F:CCE]CCE
  [M:BUD]CCE6 = [F:CCE]CCE
  Call LECTEXTRA([M:BUD]DESCCE6,"CACCE","DESTRA",[M:BUD]DIE6,[M:BUD]CCE6) From ATEXTRA
 Else
  CLECUR2(8)  = [F:CRY]GRU
  [M:BUD]CCE6 = [F:CRY]GRU
  Filter [CRY] Where PYM=[F:BUP]PYMCCE(5) and GRU=[M:BUD]CCE5 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE6,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Endif
Elsif DEFILE=8    #Groupes de section / section: pyramide = PYMCCE(6)
 If [F:BUP]PYMCCE(6)=""
  CLECUR2(9)  = [F:CCE]CCE
  [M:BUD]CCE7 = [F:CCE]CCE
  Call LECTEXTRA([M:BUD]DESCCE7,"CACCE","DESTRA",[M:BUD]DIE7,[M:BUD]CCE7) From ATEXTRA
 Else
  CLECUR2(9)  = [F:CRY]GRU
  [M:BUD]CCE7 = [F:CRY]GRU
  Filter [CRY] Where PYM=[F:BUP]PYMCCE(6) and GRU=[M:BUD]CCE6 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE7,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
Endif
Elsif DEFILE=9    #Groupes de section / section: pyramide = PYMCCE(7)
 If [F:BUP]PYMCCE(7)=""
  CLECUR2(10) = [F:CCE]CCE
  [M:BUD]CCE8 = [F:CCE]CCE
  Call LECTEXTRA([M:BUD]DESCCE8,"CACCE","DESTRA",[M:BUD]DIE8,[M:BUD]CCE8) From ATEXTRA
 Else
  CLECUR2(10) = [F:CRY]GRU
  [M:BUD]CCE8 = [F:CRY]GRU
  Filter [CRY] Where PYM=[F:BUP]PYMCCE(7) and GRU=[M:BUD]CCE7 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE8,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Endif
Endif
Return

#################################################################
## Enregistrement du budget par compte
$TR_BUDACC
Gosub INDDIE From BUDGET3
GOK = 1

If [F:BUP]PYMACC=""
 Call LECTURE("GAC",[M:BUD]ACC,[M:BUD]COA) From CONTOBJ
Else
 Filter [GRY] Where PYM = [F:BUP]PYMACC and GRU = [M:BUD]ACC and LIN=1
 Read [GRY] First
 Filter [GRY]
Endif

Trbegin[BUD]

 #Parcours s/ budgets
 For I=0 To [M:BCR]NBCRI-1

  # Recherche du nom des zones Quantité budget et Montant budget dans le tableau
  Raz QTYZON,MTZON
  Filter [TBU] Where BUDTYP=[M:BCR]BUDTYP & LINSELCRI=I+1 & (COLTYP=1 | COLTYP=2)
   For [TBU]TBU1
    If [F:TBU]COLTYP=1
     QTYZON=[F:TBU]NOMZON+num$([F:TBU]COLNUM)
    Else
     MTZON=[F:TBU]NOMZON+num$([F:TBU]COLNUM)
    Endif
   Next
  Filter [TBU]
  If QTYZON<>"" | MTZON<>""
   Call LECTURE("BUP",[M:BCR]BUD(I),"") From CONTOBJ
   [L]CPY = [M:BCR]CPY(I)
   # si budget défini au niveau société
   If [F:BUP]LEV=1
      [L]FCY = ""
   Else
      [L]FCY = [M:BCR]FCY(I)
   Endif
   If [F:BUP]DIVAMT<>0 : DIV = [F:BUP]DIVAMT : Else : DIV = 1 : Endif

   If [F:BUP]BUPODS=3      : # Création auto autorisée
    [L]NUMCPT = ""
    [L]NBRLIG  = 0
   Endif

   Gosub CAL_COEF
   # Parcours s/ les sections
   For K=0 To [M:BUD]NBLIG-1
    If [M:BUD]FLGMOD(K)=2 : # La ligne a été modifiée
     If INDDIE=1
      CLECUR2(3) = [M:BUD]CODCCE3(K)
      Raz CLECUR2(4), CLECUR2(5), CLECUR2(6), CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
     Elsif INDDIE=2
      CLECUR2(4) = [M:BUD]CODCCE3(K)
      Raz CLECUR2(5), CLECUR2(6), CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
     Elsif INDDIE=3
      CLECUR2(5) = [M:BUD]CODCCE3(K)
      Raz CLECUR2(6), CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
     Elsif INDDIE=4
      CLECUR2(6) = [M:BUD]CODCCE3(K)
      Raz CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
     Elsif INDDIE=5
      CLECUR2(7) = [M:BUD]CODCCE3(K)
      Raz CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
     Elsif INDDIE=6
      CLECUR2(8) = [M:BUD]CODCCE3(K)
      Raz CLECUR2(9), CLECUR2(10), CLECUR2(11)
     Elsif INDDIE=7
      CLECUR2(9) = [M:BUD]CODCCE3(K)
      Raz CLECUR2(10), CLECUR2(11)
     Elsif INDDIE=8
      CLECUR2(10) = [M:BUD]CODCCE3(K)
      Raz CLECUR2(11)
     Elsif INDDIE=9
      CLECUR2(11) = [M:BUD]CODCCE3(K)
     Endif

     # Parcours s/ exercices du budget
     For J=[M:BCR]FIYSTR(I) To [M:BCR]FIYEND(I)
      Raz [F:BUD9]
      Gosub INIVAR_BUDCCE
      Read [BUD9]BUD0=[M:BCR]LEDTYP(I);[M:BCR]BUD(I);[L]CPY;[L]FCY;J;[M:BCR]VER(I);[M:BUD]ACC;
&                     BUDCCE(0);BUDCCE(1);BUDCCE(2);BUDCCE(3);BUDCCE(4);BUDCCE(5);BUDCCE(6);BUDCCE(7);BUDCCE(8)
      Readlock [BUD]BUD0=[M:BCR]LEDTYP(I);[M:BCR]BUD(I);[L]CPY;[L]FCY;J;[M:BCR]VER(I);[M:BUD]ACC;
&                     BUDCCE(0);BUDCCE(1);BUDCCE(2);BUDCCE(3);BUDCCE(4);BUDCCE(5);BUDCCE(6);BUDCCE(7);BUDCCE(8)
      If fstat=1
       GOK=-1 : GLOCK="$BUD"-[M:BCR]BUD(I): Break 3
      Elsif fstat : # Le budget n'existe pas, c'est une création...
       Raz [F:BUD]
       [F:BUD]ACCNUM = uniqid([F:BUD])
       [F:BUD]CPY    = [L]CPY
       [F:BUD]BUD    = [M:BCR]BUD(I)
       [F:BUD]FCY    = [L]FCY
       [F:BUD]LEDTYP = [M:BCR]LEDTYP(I)
       [F:BUD]LED    = [M:BCR]LED
       [F:BUD]VER    = [M:BCR]VER(I)
       [F:BUD]FIY    = J
       [F:BUD]ACC    = [M:BUD]ACC
       [F:BUD]COA    = [M:BUD]COA
       [F:BUD]UOM    = [M:BUD]UOMACC
       [F:BUD]DIE1   = BUDDIE(0)
       [F:BUD]DIE2   = BUDDIE(1)
       [F:BUD]DIE3   = BUDDIE(2)
       [F:BUD]DIE4   = BUDDIE(3)
       [F:BUD]DIE5   = BUDDIE(4)
       [F:BUD]DIE6   = BUDDIE(5)
       [F:BUD]DIE7   = BUDDIE(6)
       [F:BUD]DIE8   = BUDDIE(7)
       [F:BUD]DIE9   = BUDDIE(8)
       [F:BUD]CCE1   = BUDCCE(0)
       [F:BUD]CCE2   = BUDCCE(1)
       [F:BUD]CCE3   = BUDCCE(2)
       [F:BUD]CCE4   = BUDCCE(3)
       [F:BUD]CCE5   = BUDCCE(4)
       [F:BUD]CCE6   = BUDCCE(5)
       [F:BUD]CCE7   = BUDCCE(6)
       [F:BUD]CCE8   = BUDCCE(7)
       [F:BUD]CCE9   = BUDCCE(8)
       [F:BUD]TEX    = [M:BUD]TEX
       [F:BUD]CREDAT = date$
       [F:BUD]CREUSR = GUSER
       [F:BUD]CUR    = [M:BCR]CUR(I)
       Gosub CAL_BUDACC
       Write [BUD]
       If fstat
        GOK = 0 : Call FSTA("BUD") From GLOCK : Break 3
       Endif
      Else
       [F:BUD]DIE1   = BUDDIE(0)
       [F:BUD]DIE2   = BUDDIE(1)
       [F:BUD]DIE3   = BUDDIE(2)
       [F:BUD]DIE4   = BUDDIE(3)
       [F:BUD]DIE5   = BUDDIE(4)
       [F:BUD]DIE6   = BUDDIE(5)
       [F:BUD]DIE7   = BUDDIE(6)
       [F:BUD]DIE8   = BUDDIE(7)
       [F:BUD]DIE9   = BUDDIE(8)
       [F:BUD]TEX    = [M:BUD]TEX
       Gosub CAL_BUDACC
       [F:BUD]UPDDAT = date$
       [F:BUD]UPDUSR = GUSER
       Rewrite [BUD]
       If fstat
        GOK = 0 : Call FSTA("BUD") From GLOCK : Break 3
       Endif
      Endif
      [M:BUD]NBRLIN = [M:BUD]NBLIG
      ### Création d'une OD bugetaire
      If [F:BUP]BUPODS=3      :#Création auto autorisée
       Gosub CREEBDO From MAJBDO
      Endif
      If GOK<1 : Break 2 : Endif
     Next J
    Endif
   Next K
  Endif
 Next I
 If GOK<0 : Goto ROLL_TR_BUDACC
 Elsif !GOK : Goto AB_TR
 Endif
Commit
Return

$ROLL_TR_BUDACC
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_BUDACC : Endif
Return

#################################################################
$CAL_COEF
# Récupération des coeff pour la période du budget
Raz COEDTP, SUMCOE
If [F:BUP]PYMACC=""
 Read [DTP]DTP0 = [F:GAC]TIMDSP
Else
 Read [DTP]DTP0 = [F:GRY]TIMDSP
Endif
If fstat
 For INAT=0 To dim([F:DTP]COE)-1
  [F:DTP]COE(INAT) = 1
 Next
Endif
For EXO=[M:BCR]FIYSTR(I) To [M:BCR]FIYEND(I)
 # Recherche de la période début et de la période fin de chaque exercice
 Raz PDEB,PFIN
 If EXO=[M:BCR]FIYSTR(I) : PDEB = [M:BCR]PERDEB(I) : Endif
 If EXO=[M:BCR]FIYEND(I) : PFIN = [M:BCR]PERFIN(I) : Endif
 If PDEB=0 : PDEB=1 : Endif
 If PFIN=0 : Call NBPER([M:BCR]CPY(I),[M:BCR]LEDTYP,EXO,PFIN) From CPTSUB : Endif
 If PFIN=0 : Return : Endif
 # Recherche du coefficient
 For INAT=PDEB To PFIN
  Call DATPER([M:BCR]CPY(I),[M:BCR]LEDTYP,EXO,INAT,DATDEB,DATFIN) From CPTSUB
  # Renvoie la date début et la date fin de la période INAT de l'exo EXO pour la sté CPY
  While DATDEB<>[0/0/0]
   M = month(DATDEB)        : # M contient le no du mois de DATDEB
   N = day(eomonth(DATDEB)) : # N contient le dernier jour de DATDEB
   If M=month(DATFIN)       : # J contient le nb de jours de la période I
    J = DATFIN-DATDEB+1
    DATDEB = [0/0/0]
   Else
    J = eomonth(DATDEB)-DATDEB+1
    DATDEB = eomonth(DATDEB)+1
   Endif
   COEDTP(EXO,INAT) += [F:DTP]COE(M-1)*J/N
  Wend
  SUMCOE += COEDTP(EXO,INAT)
 Next
Next
Return

#################################################################
$CAL_BUDACC
Raz SUMAMT, SUMQTY
# Recherche de la période début et de la période fin de l'exercice J
Raz PDEB,PFIN
If J=[M:BCR]FIYSTR(I) : PDEB = [M:BCR]PERDEB(I) : Endif
If J=[M:BCR]FIYEND(I) : PFIN = [M:BCR]PERFIN(I) : Endif
If PDEB=0 : PDEB=1 : Endif
If PFIN=0 : Call NBPER([M:BCR]CPY(I),[M:BCR]LEDTYP,J,PFIN) From CPTSUB : Endif
If PFIN=0 : Return : Endif
# Mise à jour des budgets
For INAT=PDEB To PFIN
 If MTZON<>""
  MTREP   = evalue("[M:BUD]"+MTZON+"("+num$(K)+")")*[F:BUP]DIVAMT*COEDTP(J,INAT)/SUMCOE
  Call LECTURE("TCU",[F:BUP]CUR,"") From CONTOBJ
  [F:BUD]AMT(INAT-1) = arr(SUMAMT+MTREP,[F:TCU]CURRND)-arr(SUMAMT,[F:TCU]CURRND)
  SUMAMT += MTREP
 Endif
 If QTYZON<>""
  QTREP   = evalue("[M:BUD]"+QTYZON+"("+num$(K)+")")*COEDTP(J,INAT)/SUMCOE
  Call LECTURE("TCU",[F:BUP]CUR,"") From CONTOBJ
  [F:BUD]QTY(INAT-1) = arr(SUMQTY+QTREP,[F:TCU]CURRND)-arr(SUMQTY,[F:TCU]CURRND)
  SUMQTY += QTREP
 Endif
Next
Return


##########################################################################################
#                                 BUDGET PAR SECTION                                     #
##########################################################################################
$INIT_BUDCCE
## Saisie avec écran vierge
Gosub INDDIE From BUDGET3
[M]NBRLIN = 0
Gosub LOAD_KEYS_BUDCCE
Effzo [BUD]25-35 : Effzo [BUD]TEX
Return

#################################################################
$LOAD_KEYS_BUDCCE
Case COUZON
 When "CCE1"
  Raz NEWCLE2(4), NEWCLE2(5), NEWCLE2(6), NEWCLE2(7), NEWCLE2(8), NEWCLE2(9), NEWCLE2(10), NEWCLE2(11)
  Gosub FILL_NEWCLECCE :  NEWCLE2(3) = CZ
 When "CCE2"
  Raz NEWCLE2(5), NEWCLE2(6), NEWCLE2(7), NEWCLE2(8), NEWCLE2(9), NEWCLE2(10), NEWCLE2(11)
  Gosub FILL_NEWCLECCE :  NEWCLE2(4) = CZ
 When "CCE3"
  Raz NEWCLE2(6), NEWCLE2(7), NEWCLE2(8), NEWCLE2(9), NEWCLE2(10), NEWCLE2(11)
  Gosub FILL_NEWCLECCE :  NEWCLE2(5) = CZ
 When "CCE4"
  Raz NEWCLE2(7), NEWCLE2(8), NEWCLE2(9), NEWCLE2(10), NEWCLE2(11)
  Gosub FILL_NEWCLECCE :  NEWCLE2(6) = CZ
 When "CCE5"
  Raz NEWCLE2(8), NEWCLE2(9), NEWCLE2(10), NEWCLE2(11)
  Gosub FILL_NEWCLECCE :  NEWCLE2(7) = CZ
 When "CCE6"
  Raz NEWCLE2(9), NEWCLE2(10), NEWCLE2(11)
  Gosub FILL_NEWCLECCE :  NEWCLE2(8) = CZ
 When "CCE7"
  Raz NEWCLE2(10), NEWCLE2(11)
  Gosub FILL_NEWCLECCE :  NEWCLE2(9) = CZ
 When "CCE8"
  Raz NEWCLE2(11)
  Gosub FILL_NEWCLECCE :  NEWCLE2(10) = CZ
 When "CCE9"
  Gosub FILL_NEWCLECCE :  NEWCLE2(11) = CZ
Endcase

If (NEWCLE2(3)<>"" | INDDIE<1) & (NEWCLE2(4)<>"" | INDDIE<2) & (NEWCLE2(5)<>"" | INDDIE<3)
&& (NEWCLE2(6)<>"" | INDDIE<4) & (NEWCLE2(7)<>"" | INDDIE<5) & (NEWCLE2(8)<>"" | INDDIE<6)
&& (NEWCLE2(9)<>"" | INDDIE<7) & (NEWCLE2(10)<>"" | INDDIE<8) & (NEWCLE2(11)<>"" | INDDIE<9)
 # Toutes les clés ont été saisies
 REP = "" : GREP = "" : CLECUR = 1
 CLECUR1     = NEWCLE1     :# Company
 CLECUR2(2)  = NEWCLE2(2)  :# Account
 CLECUR2(12) = NEWCLE2(12) :# Site
 If INDDIE=1
  CLECUR2(3) = NEWCLE2(3)
  Raz CLECUR2(4), CLECUR2(5), CLECUR2(6), CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
 Elsif INDDIE=2
  CLECUR2(3) = NEWCLE2(3) : CLECUR2(4) = NEWCLE2(4)
  Raz CLECUR2(5), CLECUR2(6), CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
 Elsif INDDIE=3
  CLECUR2(3) = NEWCLE2(3) : CLECUR2(4) = NEWCLE2(4) : CLECUR2(5) = NEWCLE2(5)
  Raz CLECUR2(6), CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
 Elsif INDDIE=4
  CLECUR2(3) = NEWCLE2(3) : CLECUR2(4) = NEWCLE2(4) : CLECUR2(5) = NEWCLE2(5) : CLECUR2(6) = NEWCLE2(6)
  Raz CLECUR2(7), CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
 Elsif INDDIE=5
  CLECUR2(3) = NEWCLE2(3) : CLECUR2(4) = NEWCLE2(4) : CLECUR2(5) = NEWCLE2(5) : CLECUR2(6) = NEWCLE2(6)
  CLECUR2(7) = NEWCLE2(7)
  Raz CLECUR2(8), CLECUR2(9), CLECUR2(10), CLECUR2(11)
 Elsif INDDIE=6
  CLECUR2(3) = NEWCLE2(3) : CLECUR2(4) = NEWCLE2(4) : CLECUR2(5) = NEWCLE2(5) : CLECUR2(6) = NEWCLE2(6)
  CLECUR2(7) = NEWCLE2(7) : CLECUR2(8) = NEWCLE2(8)
  Raz CLECUR2(9), CLECUR2(10), CLECUR2(11)
 Elsif INDDIE=7
  CLECUR2(3) = NEWCLE2(3) : CLECUR2(4) = NEWCLE2(4) : CLECUR2(5) = NEWCLE2(5) : CLECUR2(6) = NEWCLE2(6)
  CLECUR2(7) = NEWCLE2(7) : CLECUR2(8) = NEWCLE2(8) : CLECUR2(9) = NEWCLE2(9)
  Raz CLECUR2(10), CLECUR2(11)
 Elsif INDDIE=8
  CLECUR2(3) = NEWCLE2(3) : CLECUR2(4) = NEWCLE2(4) : CLECUR2(5) = NEWCLE2(5) : CLECUR2(6) = NEWCLE2(6)
  CLECUR2(7) = NEWCLE2(7) : CLECUR2(8) = NEWCLE2(8) : CLECUR2(9) = NEWCLE2(9) : CLECUR2(10) = NEWCLE2(10)
  Raz CLECUR2(11)
 Elsif INDDIE=9
  CLECUR2(3) = NEWCLE2(3) : CLECUR2(4) = NEWCLE2(4) : CLECUR2(5) = NEWCLE2(5) : CLECUR2(6) = NEWCLE2(6)
  CLECUR2(7) = NEWCLE2(7) : CLECUR2(8) = NEWCLE2(8) : CLECUR2(9) = NEWCLE2(9) : CLECUR2(10) = NEWCLE2(10)
  CLECUR2(11) = NEWCLE2(11)
 Endif
Endif
Return

#################################################################
$FILL_NEWCLECCE
If INDDIE>=1 : NEWCLE2(3)  = [M:BUD]CCE1 : Endif
If INDDIE>=2 : NEWCLE2(4)  = [M:BUD]CCE2 : Endif
If INDDIE>=3 : NEWCLE2(5)  = [M:BUD]CCE3 : Endif
If INDDIE>=4 : NEWCLE2(6)  = [M:BUD]CCE4 : Endif
If INDDIE>=5 : NEWCLE2(7)  = [M:BUD]CCE5 : Endif
If INDDIE>=6 : NEWCLE2(8)  = [M:BUD]CCE6 : Endif
If INDDIE>=7 : NEWCLE2(9)  = [M:BUD]CCE7 : Endif
If INDDIE>=8 : NEWCLE2(10) = [M:BUD]CCE8 : Endif
If INDDIE>=9 : NEWCLE2(11) = [M:BUD]CCE9 : Endif
Return

#################################################################
$LOAD_BUDCCE
Gosub INDDIE From BUDGET3
## Ecran pré chargé avec les comptes
AEFF = 1
For I=0 To [M:BCR]NBCRI-1
 Call LECTURE("BUP",[M:BCR]BUD(I),"") From CONTOBJ
 NEWCLE1    = [M:BCR]CPY(I)
 # si budget défini au niveau société
 If [F:BUP]LEV=1
  CLECUR2(12) = ""
 Else
  CLECUR2(12) = [M:BCR]FCY(I)
 Endif

 Gosub LOAD_KEYS_BUDCCE

 If (NEWCLE2(3)<>"" | INDDIE<1) & (NEWCLE2(4)<>"" | INDDIE<2) & (NEWCLE2(5)<>"" | INDDIE<3)
&&   (NEWCLE2(6)<>"" | INDDIE<4) & (NEWCLE2(7)<>"" | INDDIE<5) & (NEWCLE2(8)<>"" | INDDIE<6)
&&   (NEWCLE2(9)<>"" | INDDIE<7) & (NEWCLE2(10)<>"" | INDDIE<8) & (NEWCLE2(11)<>"" | INDDIE<9)
  nolign = 0
  If AEFF = 1
   Effzo [BUD]25-35 : Effzo [BUD]TEX
   AEFF = 0
  Endif
  Gosub READ_BUDCCE
  If GOK=0 | GOK=2 : Break : Endif
 Endif
Next I
If GOK=0 : Return : Endif
If GOK=2 : GOK = 1 : Endif
Sorta NBLIG NBLIG Order By CODACC([S]indice)
Affzo [M:BUD]25-40 : Affzo [M:BUD]TEX
Return

#################################################################
# saisie budgétaire par section
#################################################################
$READ_BUDCCE
DEFILE=10

Gosub DEFCRITCCE
Gosub FILTCCE
Raz TPVAL
If [F:BUP]PYMACC=""
 For [GAC]GAC0
  Gosub VERF_DEFILE
  If OK
   TROUVE = find([F:GAC]ACC,[M:BUD]CODACC(0..[M:BUD]NBLIG-1))
   If !TROUVE
    # On ne peut plus rajouter de comptes, mais pour celles chargées dans le tableau
    # il faut compléter les lignes avec tous les budgets de BUDCRI
    If nolign>=dim([M:BUD]CODACC)
     Call MESSAGE (mess(26,100,1)) From GESECRAN : # Tableau plein
     GOK = 2 : Break
    Endif
    [M:BUD]NBLIG +=1
    nolign = [M:BUD]NBLIG
    [M:BUD]CODACC(nolign-1)  = [F:GAC]ACC
    If [F:COA]COA<>[F:GAC]COA
     Read [COA]COA0 = [F:GAC]COA
    Endif
    Read [CLS]CLS0 = [F:COA]LEGCLS;[F:GAC]CLSCOD
    [M:BUD]SENS(nolign-1) = [F:CLS]SNSANA
    If dim([M:BUD]UOM)>0
     [M:BUD]UOM(nolign-1) = [F:GAC]UOM
    Endif
    If dim([M:BUD]CODDTP)>0
     [M:BUD]CODDTP(nolign-1) = [F:GAC]TIMDSP
    Endif
   Else
    nolign = TROUVE
   Endif
   NEWCLE2(2) = [M:BUD]CODACC(nolign-1)
   CLECUR2(2) = [M:BUD]CODACC(nolign-1)
   Gosub READ_AMT_QTY
   If GOK=0 : Break : Endif
  Else Raz mkstat,GMESSAGE
  Endif
 Next
Else
 For [GRY]CLE Where LIN=1 and BUDTRK=2
  TROUVE = find([F:GRY]GRU,[M:BUD]CODACC(0..[M:BUD]NBLIG-1))
  If !TROUVE
   # On ne peut plus rajouter de comptes, mais pour celles chargées dans le tableau
   # il faut compléter les lignes avec tous les budgets de BUDCRI
   If nolign>=dim([M:BUD]CODACC)
    Call MESSAGE (mess(26,100,1)) From GESECRAN : # Tableau plein
    GOK = 2 : Break
    Break
   Endif
   [M:BUD]NBLIG +=1
   nolign = [M:BUD]NBLIG
  Else
   nolign = TROUVE
  Endif
  [M:BUD]CODACC(nolign-1)  = [F:GRY]GRU
  If [F:COA]COA<>[F:GRY]COA
   Read [COA]COA0 = [F:GRY]COA
  Endif
  Read [CLS]CLS0 = [F:COA]LEGCLS;[F:GRY]CLSCOD
  [M:BUD]SENS(nolign-1) = [F:CLS]SNSANA
  If [F:GRY]UOMDAC=2 & dim([M:BUD]UOM)>0
   [M:BUD]UOM(nolign-1) = [F:GRY]UOM
  Endif
  If dim([M:BUD]CODDTP)>0
   [M:BUD]CODDTP(nolign-1) = [F:GRY]TIMDSP
  Endif
  NEWCLE2(2) = [M:BUD]CODACC(nolign-1)
  CLECUR2(2) = [M:BUD]CODACC(nolign-1)
  Gosub READ_AMT_QTY
  If GOK=0 : Break : Endif
 Next
Endif
Filter [GAC]
Filter [GRY]
Filter [CCE]
[M:BUD]NBRLIN = [M:BUD]NBLIG
If [M:BUD]NBLIG>0 : CLECUR = 1 : Endif
Return

#################################################################
$FILTCCE
If DEFILE=10 & [F:BUP]PYMACC=""
 Filter [GAC] Where evalue(CRITERE)
Elsif find(DEFILE,1,2,3,4,5,6,7,8,9) & [F:BUP]PYMCCE(DEFILE-1)=""
 Filter [CCE] Where evalue(CRITERE)
Else
 Filter [GRY] Where evalue(CRITERE) Order By Key CLE = PRNROW ; PYM ; GRU ; LIN
Endif
Return

#################################################################
$DEFCRITCCE
Gosub INDDIE From BUDGET3
CRITERE  = "1=1"
If DEFILE=10 : # Défilement sur compte
 If [F:BUP]PYMACC<>""
  CRITERE += " & PYM='"+[F:BUP]PYMACC+"'"
  CRITERE += " & LEV="+num$([F:BUP]PYMACCLEV)
  If [M:BCR]ACCD<>"" : CRITERE -= '& GRU>="'+[M:BCR]ACCD+'"' : Endif
  If [M:BCR]ACCF<>"" : CRITERE -= '& GRU<="'+[M:BCR]ACCF+'"' : Endif
 Else
  Gosub CRITERE
  If [M:BCR]ACCD<>"" : CRITERE -= '& ACC>="'+[M:BCR]ACCD+'"' : Endif
  If [M:BCR]ACCF<>"" : CRITERE -= '& ACC<="'+[M:BCR]ACCF+'"' : Endif
 Endif
Else        : # Défilement sur section
 IND = DEFILE
 If [F:BUP]PYMCCE(IND-1)<>""
  CRITERE += " & PYM='"+[F:BUP]PYMCCE(IND-1)+"'"
  CRITERE += " & LEV="+num$([F:BUP]PYMCCELEV(IND-1))
  CRITERE += " & BUDTRK=2"
 Else
  CRITERE += " & DIE='"+[F:BUP]DIE(IND-1)+"'"
  Gosub CRITERE
 Endif
Endif

If DEFILE<>10 & [F:BUP]PYMCCE(IND-1)=""
 TYPDEF = 2
Elsif (DEFILE=10 & [F:BUP]PYMACC<>"")
 TYPDEF = 3
Elsif  (DEFILE<>10 & [F:BUP]PYMCCE(IND-1)<>"")
 TYPDEF = 4
Else
 TYPDEF = 1
Endif
Return

#################################################################
$DEFILECCE
If DEFILE = 1
 If [F:BUP]PYMCCE(0)=""
  CLECUR2(3)  = [F:CCE]CCE
  [M:BUD]CCE1 = [F:CCE]CCE
  Call LECTEXTRA([M:BUD]DESCCE1,"CACCE","DESTRA",[M:BUD]DIE1,[M:BUD]CCE1) From ATEXTRA
 Else
  CLECUR2(3)  = [F:CRY]GRU
  [M:BUD]CCE1 = [F:CRY]GRU
  Filter [CRY] Where PYM = [F:BUP]PYMCCE(0) and GRU = [M:BUD]CCE1 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE1,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Endif
Elsif DEFILE = 2
 If [F:BUP]PYMCCE(1)=""
  CLECUR2(4)  = [F:CCE]CCE
  [M:BUD]CCE2 = [F:CCE]CCE
  Call LECTEXTRA([M:BUD]DESCCE2,"CACCE","DESTRA",[M:BUD]DIE2,[M:BUD]CCE2) From ATEXTRA
 Else
  CLECUR2(4)  = [F:CRY]GRU
  [M:BUD]CCE2 = [F:CRY]GRU
  Filter [CRY] Where PYM = [F:BUP]PYMCCE(1) and GRU = [M:BUD]CCE2 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE2,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Endif
Elsif DEFILE = 3
 If [F:BUP]PYMCCE(2)=""
  CLECUR2(5)  = [F:CCE]CCE
  [M:BUD]CCE3 = [F:CCE]CCE
  Call LECTEXTRA([M:BUD]DESCCE3,"CACCE","DESTRA",[M:BUD]DIE3,[M:BUD]CCE3) From ATEXTRA
 Else
  CLECUR2(5)  = [F:CRY]GRU
  [M:BUD]CCE3 = [F:CRY]GRU
  Filter [CRY] Where PYM = [F:BUP]PYMCCE(2) and GRU = [M:BUD]CCE3 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE3,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Endif
Elsif DEFILE = 4
 If [F:BUP]PYMCCE(3)=""
  CLECUR2(6)  = [F:CCE]CCE
  [M:BUD]CCE4 = [F:CCE]CCE
  Call LECTEXTRA([M:BUD]DESCCE4,"CACCE","DESTRA",[M:BUD]DIE4,[M:BUD]CCE4) From ATEXTRA
 Else
  CLECUR2(6)  = [F:CRY]GRU
  [M:BUD]CCE4 = [F:CRY]GRU
  Filter [CRY] Where PYM=[F:BUP]PYMCCE(3) and GRU=[M:BUD]CCE4 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE4,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Endif
Elsif DEFILE = 5
 If [F:BUP]PYMCCE(4)=""
  CLECUR2(7)  = [F:CCE]CCE
  [M:BUD]CCE5 = [F:CCE]CCE
  Call LECTEXTRA([M:BUD]DESCCE5,"CACCE","DESTRA",[M:BUD]DIE5,[M:BUD]CCE5) From ATEXTRA
 Else
  CLECUR2(7)  = [F:CRY]GRU
  [M:BUD]CCE5 = [F:CRY]GRU
  Filter [CRY] Where PYM=[F:BUP]PYMCCE(4) and GRU=[M:BUD]CCE5 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE5,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Endif
Elsif DEFILE = 6
 If [F:BUP]PYMCCE(5)=""
  CLECUR2(8)  = [F:CCE]CCE
  [M:BUD]CCE6 = [F:CCE]CCE
  Call LECTEXTRA([M:BUD]DESCCE6,"CACCE","DESTRA",[M:BUD]DIE6,[M:BUD]CCE6) From ATEXTRA
 Else
  CLECUR2(8)  = [F:CRY]GRU
  [M:BUD]CCE6 = [F:CRY]GRU
  Filter [CRY] Where PYM=[F:BUP]PYMCCE(5) and GRU=[M:BUD]CCE6 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE6,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Endif
Elsif DEFILE = 7
 If [F:BUP]PYMCCE(6)=""
  CLECUR2(9)  = [F:CCE]CCE
  [M:BUD]CCE7 = [F:CCE]CCE
  Call LECTEXTRA([M:BUD]DESCCE7,"CACCE","DESTRA",[M:BUD]DIE7,[M:BUD]CCE7) From ATEXTRA
 Else
  CLECUR2(9)  = [F:CRY]GRU
  [M:BUD]CCE7 = [F:CRY]GRU
  Filter [CRY] Where PYM=[F:BUP]PYMCCE(6) and GRU=[M:BUD]CCE7 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE7,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Endif
Elsif DEFILE = 8
 If [F:BUP]PYMCCE(7)=""
  CLECUR2(10) = [F:CCE]CCE
  [M:BUD]CCE8 = [F:CCE]CCE
  Call LECTEXTRA([M:BUD]DESCCE8,"CACCE","DESTRA",[M:BUD]DIE8,[M:BUD]CCE8) From ATEXTRA
 Else
  CLECUR2(10)  = [F:CRY]GRU
  [M:BUD]CCE8 = [F:CRY]GRU
  Filter [CRY] Where PYM=[F:BUP]PYMCCE(7) and GRU=[M:BUD]CCE8 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE8,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Endif
Elsif DEFILE = 9
 If [F:BUP]PYMCCE(8)=""
  CLECUR2(11) = [F:CCE]CCE
  [M:BUD]CCE9 = [F:CCE]CCE
  Call LECTEXTRA([M:BUD]DESCCE9,"CACCE","DESTRA",[M:BUD]DIE9,[M:BUD]CCE9) From ATEXTRA
 Else
  CLECUR2(11) = [F:CRY]GRU
  [M:BUD]CCE9 = [F:CRY]GRU
  Filter [CRY] Where PYM=[F:BUP]PYMCCE(8) and GRU=[M:BUD]CCE9 and LIN=1
  Read [CRY] First
  Filter [CRY]
  Call LECTEXTRA([M:BUD]DESCCE9,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
 Endif
Endif
Return

#################################################################
## Enregistrement du budget par section
$TR_BUDCCE

GOK = 1

Trbegin[BUD]
 # Parcours des comptes
 For K=0 To [M:BUD]NBLIG-1
  If [M:BUD]FLGMOD(K)=2 : # La ligne a été modifiée

   If [F:BUP]PYMACC=""
    Call LEC_GAC([M:BUD]CODACC(K),[M:BUD]COA) From CPTLEC
   Else
    Filter [GRY] Where PYM = [F:BUP]PYMACC and GRU = [M:BUD]CODACC(K) and LIN=1
    Read [GRY] First
    Filter [GRY]
   Endif

   #Parcours s/ budgets
   For I=0 To [M:BCR]NBCRI-1

    # Recherche du nom des zones Quantité budget et Montant budget dans le tableau
    Raz QTYZON,MTZON
    Filter [TBU] Where BUDTYP=[M:BCR]BUDTYP & LINSELCRI=I+1 & (COLTYP=1 | COLTYP=2)
     For [TBU]TBU1
      If [F:TBU]COLTYP=1
       QTYZON=[F:TBU]NOMZON+num$([F:TBU]COLNUM)
      Else
       MTZON=[F:TBU]NOMZON+num$([F:TBU]COLNUM)
      Endif
     Next
    Filter [TBU]
    If QTYZON<>"" | MTZON<>""
     Call LEC_BUP([M:BCR]BUD(I)) From CPTLEC
     [L]CPY = [M:BCR]CPY(I)
     # si budget défini au niveau société
     If [F:BUP]LEV = 1
      [L]FCY = ""
     Else
      [L]FCY = [M:BCR]FCY(I)
     Endif
     If [F:BUP]DIVAMT<>0 : DIV = [F:BUP]DIVAMT : Else : DIV = 1             : Endif
     Gosub CAL_COEF

     If [F:BUP]BUPODS=3      : # Création auto autorisée
      [L]NUMCPT = ""
      [L]NBRLIG  = 0
     Endif

     # Parcours s/ exercices du budget
     For J=[M:BCR]FIYSTR(I) To [M:BCR]FIYEND(I)
      Raz [F:BUD9]
      Gosub INIVAR_BUDCCE
      Read [BUD9]BUD0=[M:BCR]LEDTYP(I);[M:BCR]BUD(I);[L]CPY;[L]FCY;J;[M:BCR]VER(I);[M:BUD]CODACC(K);
&                     BUDCCE(0);BUDCCE(1);BUDCCE(2);BUDCCE(3);BUDCCE(4);BUDCCE(5);BUDCCE(6);BUDCCE(7);BUDCCE(8)
      Readlock [BUD]BUD0=[M:BCR]LEDTYP(I);[M:BCR]BUD(I);[L]CPY;[L]FCY;J;[M:BCR]VER(I);[M:BUD]CODACC(K);
&                     BUDCCE(0);BUDCCE(1);BUDCCE(2);BUDCCE(3);BUDCCE(4);BUDCCE(5);BUDCCE(6);BUDCCE(7);BUDCCE(8)
      If fstat=1
       GOK=-1 : GLOCK="$BUD"-[M:BCR]BUD(I): Break 3
      Elsif fstat : # Le budget n'existe pas, c'est une création...
       Raz [F:BUD]
       [F:BUD]CPY    = [L]CPY
       [F:BUD]BUD    = [M:BCR]BUD(I)
       [F:BUD]FCY    = FCY
       [F:BUD]LEDTYP = [M:BCR]LEDTYP(I)
       [F:BUD]LED    = [M:BCR]LED
       [F:BUD]VER    = [M:BCR]VER(I)
       [F:BUD]FIY    = J
       [F:BUD]COA    = [M:BUD]COA
       [F:BUD]ACC    = [M:BUD]CODACC(K)
       [F:BUD]UOM    = [M:BUD]UOM(K)
       [F:BUD]DIE1   = BUDDIE(0)
       [F:BUD]DIE2   = BUDDIE(1)
       [F:BUD]DIE3   = BUDDIE(2)
       [F:BUD]DIE4   = BUDDIE(3)
       [F:BUD]DIE5   = BUDDIE(4)
       [F:BUD]DIE6   = BUDDIE(5)
       [F:BUD]DIE7   = BUDDIE(6)
       [F:BUD]DIE8   = BUDDIE(7)
       [F:BUD]DIE9   = BUDDIE(8)
       [F:BUD]CCE1   = BUDCCE(0)
       [F:BUD]CCE2   = BUDCCE(1)
       [F:BUD]CCE3   = BUDCCE(2)
       [F:BUD]CCE4   = BUDCCE(3)
       [F:BUD]CCE5   = BUDCCE(4)
       [F:BUD]CCE6   = BUDCCE(5)
       [F:BUD]CCE7   = BUDCCE(6)
       [F:BUD]CCE8   = BUDCCE(7)
       [F:BUD]CCE9   = BUDCCE(8)
       [F:BUD]CUR    = [M:BCR]CUR(I)
       [F:BUD]TEX    = [M:BUD]TEX
       [F:BUD]CREDAT = date$
       [F:BUD]CREUSR = GUSER
       [F:BUD]ACCNUM = uniqid([F:BUD])
       Gosub CAL_BUDACC
       Write [BUD]
       If fstat
        GOK = 0 : Call FSTA("BUD") From GLOCK : Break 3
       Endif
      Else
       [F:BUD]DIE1   = BUDDIE(0)
       [F:BUD]DIE2   = BUDDIE(1)
       [F:BUD]DIE3   = BUDDIE(2)
       [F:BUD]DIE4   = BUDDIE(3)
       [F:BUD]DIE5   = BUDDIE(4)
       [F:BUD]DIE6   = BUDDIE(5)
       [F:BUD]DIE7   = BUDDIE(6)
       [F:BUD]DIE8   = BUDDIE(7)
       [F:BUD]DIE9   = BUDDIE(8)
       [F:BUD]TEX    = [M:BUD]TEX
       Gosub CAL_BUDACC
       [F:BUD]UPDDAT = date$
       [F:BUD]UPDUSR = GUSER
       Rewrite [BUD]
       If fstat
        GOK = 0 : Call FSTA("BUD") From GLOCK : Break 3
       Endif
      Endif
      [M:BUD]NBRLIN = [M:BUD]NBLIG
      ### Création d'une OD bugetaire
      If [F:BUP]BUPODS=3      # Création auto autorisée
       Gosub CREEBDO From MAJBDO
      Endif
      If GOK<1 : Break 3 : Endif
     Next J
    Endif
   Next I
  Endif
 Next K
 If GOK<0 : Goto ROLL_TR_BUDCCE
 Elsif !GOK : Goto AB_TR
 Endif
Commit
Return

$ROLL_TR_BUDCCE
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_BUDCCE : Endif
Return

