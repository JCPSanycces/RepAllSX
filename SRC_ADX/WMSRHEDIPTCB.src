$_GET_RES_STRING
Local Char RES(250)
Case _LAN
 When "FRA":
  Case _ID
   When 1294: RES='Protocole'
   When 1294: RES='Protocole'
   When 250: RES='Utilisateur'
   When 250: RES='Utilisateur'
  Endcase
 When "ENG":
  Case _ID
   When 1294: RES='Protocol'
   When 1294: RES='Protocol'
   When 250: RES='User'
   When 250: RES='User'
  Endcase
 When "ITA":
  Case _ID
   When 1294: RES='Protocollo'
   When 1294: RES='Protocollo'
   When 250: RES='Utente'
   When 250: RES='Utente'
  Endcase
 When "POR":
  Case _ID
   When 1294: RES='Protocolo'
   When 1294: RES='Protocolo'
   When 250: RES='Utilizador'
   When 250: RES='Utilizador'
  Endcase
 When "SPA":
  Case _ID
   When 1294: RES='Protocolo'
   When 1294: RES='Protocolo'
   When 250: RES='Usuario'
   When 250: RES='Usuario'
  Endcase
 When "BRI":
  Case _ID
   When 1294: RES='Protocol'
   When 1294: RES='Protocol'
   When 250: RES='User'
   When 250: RES='User'
  Endcase
 When "GER":
  Case _ID
   When 1294: RES='Protokoll'
   When 1294: RES='Protokoll'
   When 250: RES='Benutzer'
   When 250: RES='Benutzer'
  Endcase
 When "POL":
  Case _ID
   When 1294: RES='Protokół'
   When 1294: RES='Protokół'
   When 250: RES='Użytkownik'
   When 250: RES='Użytkownik'
  Endcase
 When "CHI":
  Case _ID
   When 1294: RES='协议'
   When 1294: RES='协议'
   When 250: RES='用户'
   When 250: RES='用户'
  Endcase
 When "ARB":
  Case _ID
   When 1294: RES='البروتوكول'
   When 1294: RES='البروتوكول'
   When 250: RES='المستخدم'
   When 250: RES='المستخدم'
  Endcase
Endcase
Return
#---------------------------------------------------------------------------------------------------#
