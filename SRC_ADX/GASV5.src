#<AdxTL>@(#)2.0.0.0 $Revision$
#GIMP(4) # Secteur IAS
#GIMP(5) # Secteur IAS
#GIMP(6) # Nature analytique
#GIMP(7) # Montant devise société
#GIMP(8) # Montant devise reporting

Call IMPORTATION("GASHRM") From GIMPOBJ
End
###################################################################################
$ACTION
Case ACTION
 When Default
Endcase
Return

###################################################################################
$RAZCRE
Raz [M:HAE0]
Raz [M:HAE1]
Raz [M:HAE2]
Raz [M:HAEF]
Raz [M:VTL]
Raz [M:VT2]
Return

###################################################################################
$OUVRE
# The last mask opened is the default mask. This mask is very important
# in SUBCDEB to find dimensions with the default dimension
If clalev([M:HAE0])=0 : Local Mask GACCENT0   [HAE0] : Endif
If clalev([M:HAE1])=0 : Local Mask GACCENT1   [HAE1] : Endif
If clalev([M:HAE2])=0 : Local Mask GACCENT2   [HAE2] : Endif
If clalev([M:HAEW])=0 : Local Mask GACCENTW   [HAEW] : Endif
If clalev([M:VTL]) =0 : Local Mask VENTILE    [VTL]  : Endif
If clalev([M:VT2]) =0 : Local Mask VENTILE2   [VT2]  : Endif
If clalev([M:HAEF])=0 : Local Mask GACCENTFMT [HAEF] : Endif

Raz [M:HAE0],[M:HAE1],[M:HAE2],[M:HAEW],[M:VTL],[M:VT2],[M:HAEF]

If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif
If clalev([F:GDE])=0  : Local File GDIAENTRY  [GDE]  : Endif
If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif
If clalev([F:LED])=0  : Local File GLED       [LED]  : Endif
If clalev([F:AODA])=0 : Local File AOBJEXTD   [AODA] : Endif

Local Integer STAT, I, J, K, L, AXE, AX, OPTTV, OPTF, NBANA, OBY, VU
Local Integer SOCLED, ANALED, IASLED

# TACC contains the accounts of each ledger. The array index matches with the index of [M:HAEF]LEDTYP
Local Char    TACC(GLONGAC)(0..8)

Local Char    CRIBLE(15), ACCORG(GLONGAC), ACCDES(GLONGAC), SECTION(GLONCCE)

# Dimensions types contained in the import template. They won't be initialized with the default dimension
Local Char    TDIE(GLONDIE)(0..19)

# Ledger types are sorted in the order of the journal entry transaction
Local Integer TLEDTYP(1..len(mess(0,2644,1)))

Local Integer NBLEDTYP, NBANACCE, NBIASCCE

Local Integer LASTLIN : # LASTLIN=0 If a DAA record has been sent for the previous line Else LASTLIN=number of the previous line
Local Integer IDTLIN  : # Used when the type of the journal entry transaction is Line. Allow to initialize [F:DAE]IDTLIN
Local Integer STRLIN  : # First line of the DAE record in the mask HAE2
Local Decimal LASTAMT : # Amount of the last DAE record

## Number of dimensions imported from IAS ledger and from analytic ledger
Filter [AODA] Where EXT=[F:AOD]EXT & FIL="GACCENTRY" & (FLD="*4" or FLD="*5")
NBIASCCE = rowcount([AODA])
Filter [AODA] Where EXT=[F:AOD]EXT & FIL="GACCENTRYA" & left$(FLD,3)="CCE"
NBANACCE = rowcount([AODA])
Filter [AODA]
Return

###################################################################################
$SAIMSK
Case IMPFIC

 When "HAE"
  nolign = 1
  Raz [L]IDTLIN
  [M:HAE0] = [F:HAE]
  [M:HAE1] = [F:HAE]
  ## We don't use GSCHDEF's value(Parameter SCHSAISIE) to update DACDIA
  ## We use the parameter SCHIMPV5
  If [F:HAE]DACDIA<>""
   GFLAG = [F:HAE]DACDIA
   [M:HAE0]DACDIA = GFLAG
  Else
   GFLAG = func AFNC.PARAM("SCHIMPV5",[F:HAE]FCY)
   If GFLAG<>""
    [M:HAE0]DACDIA = GFLAG
   Else
    # Paramètre non renseigné
    Call ECR_TRACE("SCHIMPV5"-mess(171,133,1),1) From GESECRAN
    FIN = 1 : Return
   Endif
  Endif

  Gosub READING

  # Scan the ledgers to charge all the dimension views
  For I=0 To dim([F:GCM]LED)-1
   If [F:GCM]LED(I)<>""
    ## Even if the ledger isn't authorised with the document type, the currency rate is updated
    [F:HAE]LED(I)    = [F:GCM]LED(I)
    [F:HAE]CURLED(I) = [F:GCM]CUR(I)
    [F:HAE]RATDIV(I) = 1
    If [F:GCM]CUR(I) = GIMP(1)                                        # Reporting currency in the V5
     [F:HAE]RATMLT(I) = val(GIMP(3))
    Elsif [F:GCM]CUR(I)<>[F:HAE]CUR & [F:GCM]CUR(I)=[F:CPY]ACCCUR     # Company currency in the V5
     [F:HAE]RATMLT(I) = val(GIMP(2))
    Else
     [F:HAE]RATMLT(I) = 1
    Endif
   Endif
  Next

  [M:HAE1]LED    = [F:HAE]LED
  [M:HAE1]CURLED = [F:HAE]CURLED
  [M:HAE1]RATMLT = [F:HAE]RATMLT
  [M:HAE1]RATDIV = [F:HAE]RATDIV

  ## Initialization in the mask [HAEF].
  ## We call INIMSKFMT3 to initialize the rates RATDIV and RATMLT if they are imported
  Call INIMSKFMT3([F:HAE]FCY,[F:GDE]TYPENT,GFLAG,[F:HAE]TYP,[F:HAE]ACCDAT,STAT) From SUBGASA

  If STAT
   GMESSAGE=""
   Call TITOBJ("GDE","!",GMESSAGE) From CONTOBJ
   Gosub MESSAGE From CPTAUTO
   GMESSAGE -= ":"-[F:GDE]DIA+"\"+mess(86,105,1)+"\"+MESSA : # Paramétrage à revoir
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
   Raz GMESSAGE
   FIN = 1 : Return
  Endif

  For I=1 To [M:HAEF]NBRLED
   Assign "[M:HAE1]COA("+num$(I-1)+")" With [M:HAEF]COA(I-1)
   Assign "[M:HAE2]COA("+num$(I-1)+")" With [M:HAEF]COA(I-1)
  Next

  For I=1 To dim([M:HAEF]DIE)
   Assign "[M:HAE2]DIE("+num$(I-1)+")" With [M:HAEF]DIE(I-1)
  Next

  Raz TLEDTYP, NBLEDTYP
  For I=1 To [F:GDE]NBRLED
   If find([F:GDE]LEDTYP(I-1),[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
    NBLEDTYP += 1
    TLEDTYP(NBLEDTYP) = [F:GDE]LEDTYP(I-1)
   Endif
  Next

 When "DAE"
  # No DAA record imported matching with the last DAE (LASTLIN<>0). DAA record import analytic data.
  # => We must initialize
  # 1) IAS dimension with the imported IAS data
  # 2)the other dimensions with the default dimension GASIMPV5
  If LASTLIN<>0
   If STRLIN<>0
    For nolign=STRLIN To [M:HAE2]NBLIG
     Gosub IMPORT_IAS
     Gosub INI_OTHERDIE
    Next
   Endif
   Raz LASTLIN : # Even if the dimensions aren't initialized, LASTLIN must be erased
  Endif

  [L]IDTLIN +=1

  # Initialize accounts with data imported : Only social account or analytic account
  Raz TACC
  For I=0 To [M:HAEF]NBRLED-1
   Case [M:HAEF]LEDTYP(I)
    When SOCLED :   # The first ledger imported is the first ledger of the journal entry transaction
     Call LEC_GAC([F:DAE]ACC,[M:HAEF]COA(I)) From CPTLEC : # Reading of the account
     If fstat
      ## Non défini dans le plan de comptes
      Call ECR_TRACE([F:DAE]ACC-mess(176,105,1)-[M:HAEF]COA(I),1) From GESECRAN
      FIN = 1 : Break
     Endif
     Gosub ADDLIN
     If [M:HAEF]TYPENT=2 : # Saisie en lignes
      Assign "[M:HAE2]SAC1"+"("+num$(nolign-1)+")" With [F:DAE]SAC
      Assign "[M:HAE2]ACC1"+"("+num$(nolign-1)+")" With [F:DAE]ACC
      Assign "[M:HAE2]COA1"+"("+num$(nolign-1)+")" With [M:HAEF]COA(I)
     Else
      Assign "[M:HAE2]SAC"+num$(I+1)+"("+num$(nolign-1)+")" With [F:DAE]SAC
      Assign "[M:HAE2]ACC"+num$(I+1)+"("+num$(nolign-1)+")" With [F:DAE]ACC
     Endif
     TACC(I) = [F:DAE]ACC

    When ANALED :   # Analytical ledger
     If SOCLED<>ANALED
      If GIMP(6)<>"" : # Nature analytique saisie
       Call LEC_GAC(GIMP(6),[M:HAEF]COA(I)) From CPTLEC : # Reading of the account
       If !fstat
        TACC(I) = GIMP(6)
        If [M:HAEF]TYPENT=2 : # Saisie en lignes
         Gosub ADDLIN
         If [F:GAC]SAC=2
          Assign "[M:HAE2]SAC1"+"("+num$(nolign-1)+")" With [F:GAC]ACCSHO
         Endif
         Assign "[M:HAE2]ACC1"+"("+num$(nolign-1)+")" With TACC(I)
         Assign "[M:HAE2]COA1"+"("+num$(nolign-1)+")" With [M:HAEF]COA(I)
        Else
         Call MAJ_AMT(ANALED)
         If [F:GAC]SAC=2
          Assign "[M:HAE2]SAC"+num$([M:HAEF]LEDTYP(I))+"("+num$(nolign-1)+")" With [F:GAC]ACCSHO
         Endif
         Assign "[M:HAE2]ACC"+num$([M:HAEF]LEDTYP(I))+"("+num$(nolign-1)+")" With TACC(I)
        Endif
       Else
        ## Non défini dans le plan de comptes
        Call ECR_TRACE(GIMP(6)-mess(176,105,1)-[M:HAEF]COA(I),1) From GESECRAN
        FIN = 1 : Break
       Endif
      Endif
     Endif
    Endcase
   Next

   If FIN=1 : Return : Endif

   ## On cherche à initialiser le compte du type référentiel destination ssi les comptes des types
   ## référentiels précédemment initialisés peuvent avoir une imputation sur le plan de compte associé
   ## au type référentiel destination
   ## Pour chaque type de référentiel, on initialise le compte du réferentiel
   ## 1°)on essaye d'initialiser le compte du référentiel destination par rapport aux comptes
   ##     des référentiels précédemment initialisés en appliquant les comptes par défaut. Sauf pour Social et Analytique
   ##     car les comptes ont été importés.
   ##     EX : on a renseigné les types référentiels suivants sur la transaction de saisie: social, ias, analytique
   ##     => lorsqu'on cherchera à initialiser le compte IAS, on va chercher à l'initialiser en prenant :
   ##        a) le compte par défaut type 'IAS' du compte social
   ##        b) si pas de compte IAS trouvé, le compte par défaut type 'IAS' du compte analytique
   ## 2°) si pas de compte trouvé, on prend le compte par défaut du code plan du référentiel destination
   ## 3°) si pas de compte trouvé, on renvoie un message d'erreur compte inexistant
   For K=1 To NBLEDTYP  : # Destination
    I = find(TLEDTYP(K),[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
    # Compte destination vide, on l'initialise si ce n'est pas le référentiel analytique ou social
    If I & !find([M:HAEF]LEDTYP(I-1),SOCLED,ANALED) & TACC(I-1)=""
     I -=1
     Raz [L]ACCDES,[L]CRIBLE
     OBY = 0
     For L=1 To NBLEDTYP : # Origine
      If K<>L
       # Search the account
       J = find(TLEDTYP(L),[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
       If J & TACC(J-1)<>""
        J-= 1
        ACCORG = TACC(J)
        If !OBY
         # A voir avec Pascale
         #Call CNTIPTACC([M:HAEF]COA(J),[L]ACCORG,[M:HAEF]COA(I),OBY) From TRTPCE
         Call LECTURE("GAC",ACCORG,[M:HAEF]COA(J)) From CONTOBJ
         VU = find([M:HAEF]COA(I),[F:GAC]OTHCOA(0..[F:GAC]COANBR-1))
         If VU & [F:GAC]OBYIPT(VU-1)=2
          OBY = 1
         Endif
        Endif
        Call INIACC([M:HAEF]COA(J),[L]ACCORG,[M:HAEF]COA(I),[L]ACCDES,[L]CRIBLE) From CPTINI
        If [L]ACCDES<>""
         Call LECTURE("GAC",ACCDES,[M:HAEF]COA(I)) From CONTOBJ
         If fstat
          ## Compte inexistant
          Call ECR_TRACE([M:HAEF]COA(I)-ACCDES-":"-mess(38,106,1),1) From GESECRAN
          FIN = 1 : Break
         Else
          ## Le compte du type référentiel destination a été initialisé par le type référentiel origine -> On sort
          Break
         Endif
        Endif
       Endif
      Endif
     Next
     If  FIN=1 : Break : Endif
     If ACCDES<>""
      TACC(I)=ACCDES
     Elsif !OBY
      ## Dernier recours : le compte par défaut : si aucun compte des autres référentiels n'est paramétré
      ## "Imputation obligatoire" sur le plan de compte du type référentiel courant (OBLIG=0) , on initialise
      ## le compte du référentiel courant par le compte par défaut
      Call LEC_COA([M:HAEF]COA(I)) From CPTLEC
      ACCDES = [F:COA]ACCMIS(1)
      Read [GAC]GAC0 = [M:HAEF]COA(I);ACCDES
      If !fstat
       TACC(I)=ACCDES
      Endif
     Elsif OBY & ACCDES=""
      ## Si tjs pas de compte trouvé, on bloque mais toujours ssi au moins un compte des référentiels
      ## précédemment initialisés est flagué "Imputation obligatoire" à 'Oui' sur le plan de compte du
      ## référentiel courant
      FIN = 1
      # Pas de compte trouvé
      Call ECR_TRACE([M:HAEF]LED(I)-mess(107,106,1),1) From GESECRAN
      Break
     Endif
     If TACC(I)<>""
      If [M:HAEF]TYPENT=2 : # Saisie en lignes
       Gosub ADDLIN
       Assign "[M:HAE2]ACC1"+"("+num$(nolign-1)+")" With TACC(I)
      Else
       Assign "[M:HAE2]ACC"+num$(I+1)+"("+num$(nolign-1)+")" With TACC(I)
       Call MAJ_AMT([M:HAEF]LEDTYP(I))
      Endif
     Endif
    Endif
   Next
   If FIN=1 : Return : Endif

   If [M:HAEF]TYPENT=2 : # Saisie en lignes
    LASTLIN = [L]IDTLIN
    # To process all the lines having the same idtlin, we find the first line of the group
    STRLIN = find(num$(LASTLIN),[M:HAE2]IDTLIN)
   Else
    LASTLIN = [M:HAE2]NBLIG
    # The only line to process is the current line
    STRLIN = [M:HAE2]NBLIG
   Endif

   LASTAMT = [F:DAE]AMTCUR

 When "DAA"
  ## Initialize [F:DAA]DIE with the IAS dimension
  If (GIMP(4)<>"" | GIMP(5)<>"") & IASLED=0
   # Référentiel IAS principal
   # Type de référentiel non défini pour la société
   Call ECR_TRACE(mess(145,104,1)-"\"-mess(105,104,1),1) From GESECRAN
   FIN = 1 : Return
  Endif

  # Saisie en lignes sur un réf ana<>réf général. On a donc déjà ajouté la ligne du réf ana dans [M:HAE2] (Cf When "DAE" ADDLINE)
  # C'est cette ligne qu'il faut traiter => On incrémente STRLIN pour pointer dans HAE2 sur la ligne ana
  # et ne pas imputer de l'analytique sur les lignes DAE
  # L'incrémentation se fait à la réception du premier enreg DAA
  If [M:HAEF]TYPENT=2 & SOCLED<>ANALED & LASTLIN<>0
   STRLIN += 1
  Endif

  # We import a DAA record matching with the last DAE => Erase LASTLIN because the initialization of the dimensions
  # (IAS & analytical & others) is done here
  Raz LASTLIN

  For nolign=STRLIN To [M:HAE2]NBLIG
   Gosub INIT_PTVPTF
   Gosub IMPORT_IAS
   Gosub IMPORT_ANA
   Gosub INI_OTHERDIE
   [M:HAE2]DSP(nolign-1)       = "$"
   [M:VT2]TBAMT([M:VT2]PTVENT) = [F:DAA]AMTCUR
   [M:VT2]TBQTY([M:VT2]PTVENT) = [F:DAA]QTY
   [M:HAE2]QTY(nolign-1)       = sum([M:VT2]TBQTY([M:HAE2]PTV(nolign-1)..[M:HAE2]PTF(nolign-1)))
  Next
Endcase
Return


###################################################################################
Subprog MAJ_AMT(LEDTYP)
Value Integer  LEDTYP
Local Char    CURLED(GLONCUR)
Local Integer K
CURLED = [F:GCM]CUR(LEDTYP-1)
If CURLED=[F:CPY]ACCCUR         # Company currency
 [F:DAE]AMTLED =  val(GIMP(7))
Elsif CURLED=GIMP(1)            # Reporting currency
 [F:DAE]AMTLED =  val(GIMP(8))
Elsif CURLED=[F:HAE]CUR         # Transaction currency
 [F:DAE]AMTLED =  [F:DAE]AMTCUR
Endif

If [M:HAEF]TYPENT = 2  # Saisie Ligne
 If [F:DAE]SNS<=0 & [M:HAE2]CDT(nolign-1)=0
  Assign "[M:HAE2]AMT"+num$(LEDTYP)+"("+num$(nolign-1)+")" With -[F:DAE]AMTLED
 Else
  Assign "[M:HAE2]AMT"+num$(LEDTYP)+"("+num$(nolign-1)+")" With [F:DAE]AMTLED
 Endif
Else
 K=find(LEDTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
 If [F:DAE]SNS<=0 & [M:HAE2]CDT(nolign-1)=0
  Assign "[M:HAE2]AMT"+num$(K)+"("+num$(nolign-1)+")" With -[F:DAE]AMTLED
 Else
  Assign "[M:HAE2]AMT"+num$(K)+"("+num$(nolign-1)+")" With [F:DAE]AMTLED
 Endif
Endif
End

###################################################################################
## Add a line in the mask [HAE2] :
## 1 line for a DAE record if the entry type of the journal entry transaction=column
## As many lines as ledgers if the entry type of the journal entry transaction=line

$ADDLIN
[M:HAE2]NBLIG += 1
nolign = [M:HAE2]NBLIG
[F:DAE]IDTLIN = num$([L]IDTLIN)
[F:DAE]LEDTYP = [M:HAEF]LEDTYP(I)

[M:HAE2] = [F:DAE]
[F:DAE]LIN = nolign
If [F:DAE]SNS>0
 [M:HAE2]DEB(nolign-1) = [F:DAE]AMTCUR
Else
 [M:HAE2]CDT(nolign-1) = [F:DAE]AMTCUR
Endif

Call MAJ_AMT([M:HAEF]LEDTYP(I))
Return

###################################################################################
## Initialize the others dimensions not imported with the default dimension "GASIMPV5"

$INI_OTHERDIE
For I=0 To [M:HAEF]NBRLED-1
 # When the journal entry transaction type=Line => add the control of the line
 If [M:HAEF]LEDTYP(I)<>0 & ([M:HAEF]TYPENT<>2 | [M:HAE2]LEDTYP(nolign-1)=[M:HAEF]LEDTYP(I))
  ## Don't initialiaze the dimensions that have been imported
  For J=1 To dim([F:DAA]DIE)
   If evalue("[M:HAEF]DIE"+num$(J)+"("+num$(I)+")")<>"" & !find(evalue("[M:HAEF]DIE"+num$(J)+"("+num$(I)+")"),TDIE)
    Raz SECTION
    GIMPORT = 0
    Call INICCE(SECTION,evalue("[M:HAEF]DIE"+num$(J)+"("+num$(I)+")"),[M:HAEF]COA(I),TACC(I),"GASIMPV5") From CPTINI
    GIMPORT=1
    If SECTION<>""
     AXE = find(evalue("[M:HAEF]DIE"+num$(J)+"("+num$(I)+")"),[M:HAEF]DIE(0..[M:HAEF]NBRAXI-1))
     If AXE>0
      # LASTLIN<>0 if called from DAE
      If LASTLIN<>0
       If evalue("[M:HAE2]CCE"+num$(AXE)+"("+num$(nolign-1)+")")=""
        Assign "[M:HAE2]CCE"+num$(AXE)+"("+num$(nolign-1)+")" With SECTION
       Endif
      Else
       If evalue("[M:VT2]TBCCE"+num$(AXE)+"("+num$([M:VT2]PTVENT)+")")=""
        Assign "[M:VT2]TBCCE"+num$(AXE)+"("+num$([M:VT2]PTVENT)+")" With SECTION
       Endif
      Endif
     Endif
    Endif
   Endif
  Next
 Endif
Next
Return

###################################################################################
## Update the pointers in the mask [HAE2] to identify the values of the dimensions

$INIT_PTVPTF
If [M:HAE2]PTV(nolign-1)=0                          # A garbage line is generated
 [M:HAE2]PTV(nolign-1) = [M:VT2]PTVENT
 K = [M:VT2]PTVENT+1
 [M:VT2]PTVENT = K
 [M:HAE2]PTV(nolign-1) = K
 [M:HAE2]PTF(nolign-1) = K
Else
 NBANA = [M:HAE2]PTF(nolign-1)-[M:HAE2]PTV(nolign-1)+1
 If [F:DAA]ANALIN>=1 & [F:DAA]ANALIN<=NBANA         # Update of an existing line
  K = [M:HAE2]PTV(nolign-1)+[F:DAA]ANALIN-1
 Elsif [M:VT2]PTVENT=[M:HAE2]PTF(nolign-1)          # ok there is the place
  If [M:VT2]PTVENT+1>=dim([M:VT2]TBAMT)
   #  Trop ventilations analytiques
   Call ECR_TRACE([M:HAE0]TYP-[M:HAE0]NUM-num$(nolign)-mess(79,117,1),1) From GESECRAN
   GOK = 0 : Return
  Endif
  K = [M:VT2]PTVENT+1
  [M:VT2]PTVENT    = K
  [M:HAE2]PTF(nolign-1) = K
 Else                                               # put far away
  OPTV = [M:HAE2]PTV(nolign-1)
  OPTF = [M:HAE2]PTF(nolign-1)
  If [M:VT2]PTVENT+OPTF-OPTV+1>=dim([M:VT2]TBAMT)
   Call ECR_TRACE([M:HAE0]TYP-[M:HAE0]NUM-num$(nolign)-mess(79,117,1),1) From GESECRAN
   GOK = 0 : Return
  Endif
  K = [M:VT2]PTVENT+1
  [M:HAE2]PTV(nolign-1) = K
  For I=0 To OPTF-OPTV
   [M:VT2]TBAMT(K+I) = [M:VT2]TBAMT(OPTV+I)
   [M:VT2]TBQTY(K+I) = [M:VT2]TBQTY(OPTV+I)
   For L=0 To [M:HAEF]NBRLED-1
    # When the journal entry transaction type=Line => add the control of the line
    If [M:HAEF]LEDTYP(L)<>0 & ([M:HAEF]TYPENT<>2 | [M:HAE2]LEDTYP(nolign-1)=[M:HAEF]LEDTYP(L))
     For AX=1 To dim([F:DAA]CCE)
      AXE = find(evalue("[M:HAEF]DIE"+num$(AX)+"("+num$(L)+")"),[M:HAEF]DIE(0..[M:HAEF]NBRAXI-1))
      If AXE>0
       Assign"[M:VT2]TBCCE"+num$(AXE)+"("+num$(K+I)+")" With  evalue("[M:VT2]TBCCE"+num$(AXE)+"("+num$(OPTV+I)+")")
      Endif
     Next AX
    Endif
   Next L
  Next I
  K += OPTF-OPTV+1
  [M:VT2]PTVENT = K
  [M:HAE2]PTF(nolign-1) = K
  Call ANUVENTIL([M:HAE2]PTV,[M:HAE2]PTF,[M:HAE2]NBLIG,OPTV,OPTF-OPTV+1) From VENTILE
  K -= OPTF-OPTV+1
 Endif
Endif
Return

###################################################################################
## Transfer of IAS informations (CCE of IAS's DIE). Only 2 sectors (CCE) were used in the V5
## Required : The 2 imported sectors match with the first 2 dimensions views of the IAS ledger

$IMPORT_IAS
If [M:HAEF]TYPENT=2 : # Saisie en lignes
 I = find(IASLED,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
 J = find([M:HAE2]LEDTYP(nolign-1),[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
 If I & J & [M:HAEF]DIE1(I-1)<>"" & GIMP(4)<>""
  For L=1 To 9
   If [M:HAEF]DIE1(I-1)= evalue("[M:HAEF]DIE"+num$(L)+"("+num$(J-1)+")")
    AXE = find([M:HAEF]DIE1(I-1),[M:HAEF]DIE(0..[M:HAEF]NBRAXI-1))
    If AXE>0
     # LASTLIN<>0 if called from DAE
     If LASTLIN<>0
      Assign "[M:HAE2]CCE"+num$(AXE)+"("+num$(nolign-1)+")" With GIMP(4)
     Else
      Assign "[M:VT2]TBCCE"+num$(AXE)+"("+num$([M:VT2]PTVENT)+")" With GIMP(4)
     Endif
    Endif
    Break
   Endif
  Next
 Endif
 If I & J & [M:HAEF]DIE2(I-1)<>"" & GIMP(5)<>""
  For L=1 To dim([F:DAA]DIE)
   If [M:HAEF]DIE2(I-1)= evalue("[M:HAEF]DIE"+num$(L)+"(J-1)")
    AXE = find([M:HAEF]DIE2(I-1),[M:HAEF]DIE(0..[M:HAEF]NBRAXI-1))
    If AXE>0
     # LASTLIN<>0 if called from DAE
     If LASTLIN<>0
      Assign "[M:HAE2]CCE"+num$(AXE)+"("+num$(nolign-1)+")" With GIMP(5)
     Else
      Assign "[M:VT2]TBCCE"+num$(AXE)+"("+num$([M:VT2]PTVENT)+")" With GIMP(5)
     Endif
    Endif
    Break
   Endif
  Next
 Endif
Else  : # Saisie en colonnes
 I = find(IASLED,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
 If I
  If [M:HAEF]DIE1(I-1)<>"" & GIMP(4)<>""
   AXE = find([M:HAEF]DIE1(I-1),[M:HAEF]DIE(0..[M:HAEF]NBRAXI-1))
   If AXE>0
    # LASTLIN<>0 if called from DAE
    If LASTLIN<>0
     Assign "[M:HAE2]CCE"+num$(AXE)+"("+num$(nolign-1)+")" With GIMP(4)
    Else
     Assign "[M:VT2]TBCCE"+num$(AXE)+"("+num$([M:VT2]PTVENT)+")" With GIMP(4)
    Endif
   Endif
  Endif
  If [M:HAEF]DIE2(I-1)<>"" & GIMP(5)<>""
   AXE = find([M:HAEF]DIE2(I-1),[M:HAEF]DIE(0..[M:HAEF]NBRAXI-1))
   If AXE
    # LASTLIN<>0 if called from DAE
    If LASTLIN<>0
     Assign "[M:HAE2]CCE"+num$(AXE)+"("+num$(nolign-1)+")" With GIMP(5)
    Else
     Assign "[M:VT2]TBCCE"+num$(AXE)+"("+num$([M:VT2]PTVENT)+")" With GIMP(5)
    Endif
   Endif
  Endif
 Endif
Endif
Return

###################################################################################
## Transfer of analytical informations

$IMPORT_ANA
If [M:HAEF]TYPENT=2 : # Saisie en lignes
 I = find(ANALED,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
 J = find([M:HAE2]LEDTYP(nolign-1),[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
 If I & J
  For AX=1 To dim([F:DAA]DIE)
   For L=1 To dim([F:DAA]DIE)
    If evalue("[M:HAEF]DIE"+num$(AX)+"("+num$(I-1)+")")= evalue("[M:HAEF]DIE"+num$(L)+"("+num$(J-1)+")")
     AXE = find(evalue("[M:HAEF]DIE"+num$(AX)+"("+num$(I-1)+")"),[M:HAEF]DIE(0..[M:HAEF]NBRAXI-1))
     If AXE>0
      Assign "[M:VT2]TBCCE"+num$(AXE)+"("+num$([M:VT2]PTVENT)+")" With [F:DAA]CCE(AX-1)
     Endif
    Endif
   Next
  Next
 Endif
Else  : # Saisie en colonnes
 I = find(ANALED,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
 If I
  For AX=1 To dim([F:DAA]DIE)
   AXE = find(evalue("[M:HAEF]DIE"+num$(AX)+"("+num$(I-1)+")"),[M:HAEF]DIE(0..[M:HAEF]NBRAXI-1))
   If AXE>0
    Assign "[M:VT2]TBCCE"+num$(AXE)+"("+num$([M:VT2]PTVENT)+")" With [F:DAA]CCE(AX-1)
   Endif
  Next
 Endif
Endif
Return

###################################################################################
$VALID
If [M:HAE2]NBLIG=0 : Return : Endif

# No DAA record imported for the last DAE (LASTLIN<>0)
# => Initialize IAS dimension with the imported data and the other dimensions with the default dimension GASIMPV5
If LASTLIN<>0
 If STRLIN<>0
  For nolign=STRLIN To [M:HAE2]NBLIG
   ## Si IAS importé sans enreg DAA alors l'IAS n'est pas pris en compte sur la ligne
   Gosub IMPORT_IAS
   Gosub INI_OTHERDIE
  Next
 Endif
 Raz LASTLIN : # Even if the dimensions aren't initialized, LASTLIN must be erased
Endif

Raz STAT, MESSA, GSCHEMA
Default Mask [HAE0]
Default Mask [HAE1]
Default Mask [HAE2]

Call CONTROLE(STAT,MESSA) From CPTBATCH

GCLE = [M:HAE0]TYP-[M:HAE0]NUM
If STAT
 Gosub MESSAGE From CPTAUTO
 Call TRACE2(2,"<"+GCLE+">"-MESSA-"("+num$(STAT)+")",-1) From SUBIMPOBJ
 STAT = 0 : # mb 10.10.01 Conflit avec le STAT de l'import
 GOK = 0
 Return
Endif

GOK=1
Call DEBTRANS From GLOCK
Gosub TR1
GCLE = [F:HAE]TYP-[F:HAE]NUM
If STAT
 Call TRACE2(2,"<"+GCLE+">"-MESSA-"("+num$(STAT)+")",-1) From SUBIMPOBJ
 STAT = 0
 GOK = 0
Else
 Call TRACE(0,GCLE) From SUBIMPOBJ
 NBCRE += 1
 GOK = 1
Endif

Return

###################################################################################
$TR1
Trbegin [HAE]
 Default Mask [HAE0]
 Default Mask [HAE1]
 Default Mask [HAE2]
 Call VALPIECER(STAT,MESSA) From CPTBATCH
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
If STAT=0
 STAT = 20 : Gosub MESSAGE From CPTAUTO
Endif
Return

###########################################################################################################
## Reading tables

$READING
# Reading of the site
Call LEC_FCY([F:HAE]FCY) From CPTLEC

# Reading of the legal company
Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
GSOCIETE    = [F:CPY]CPY                            # GSOCIETE is used to initialize dimensions with a default dimension
[M:HAE0]CPY = [F:CPY]CPY

# Reading of the journal entry transaction
Call LEC_GDE(GFLAG) From CPTLEC

# Reading of the account core model
Call LEC_GCM([F:CPY]ACM) From CPTLEC
SOCLED = [F:GCM]GENLEDTYP
ANALED = [F:GCM]ANALEDTYP
IASLED = [F:GCM]IASLEDTYP

# Reading of the analytic ledger
If ANALED<>0
 Call LEC_LED([F:GCM]LED(ANALED-1)) From CPTLEC
 For I=0 To min([L]NBANACCE,dim(TDIE))-1
  TDIE(I) = [F:LED]DIE(I)
 Next
Endif

# Reading of the ias ledger
If IASLED<>0
 Call LEC_LED([F:GCM]LED(IASLED-1)) From CPTLEC
 For J=0 To min([L]NBIASCCE,dim(TDIE))-1
  TDIE(J+I) = [F:LED]DIE(J)
 Next
Endif
Return

