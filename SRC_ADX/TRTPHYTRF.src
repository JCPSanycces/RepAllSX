#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################
#
# TRTPHYTRF - Transfert analytique et géographique des éléments physiques
#
######################################################################
# MODIF :
#    MDJ 09.02.15 FQ100398 : Suppression site géographique
#    MDJ 14.05.14 FQ98687 : Transfert massif éléments physiques : décochage d'une sélection de site
#    CBO 28.03.13 FQ88833 : Erreur en trf massif par batch (du à 88137)
#    CBO 28.02.13 FQ88137 : Erreur en validation des relevés validés (Inventaire)
#    CBO 21.03.12 FQ10941 : pb message d'erreur
#    CBO 12.14.2011 FQ69691 : ajout pour import des mvts
#    GLE 08/09/10 FQ62267 : La localisation du bien n'est pas mise à jour lors d'un transfert de localisation par inventaire
#    GLE 19/05/10 FQ64478 : Correction appels à AP_NBFCY, AP_NBCPY, AM_FLGCPY
#    GLE 05/02/10 FQ56093 : Possibilité de gérer le site d'inventaire au niveau société
#    GLE 22/06/09 FQ55485 : Un bien composant n'a plus obligatoirement la même localisation que son bien principal
#  STANT 08/05/09 FQ49517 : Ouverture du transfert géographique au site financier
#    GLE 04/12/08 FQ50829 : En massif, le champs TRFDAT était mis à jour à tort lors de la mise en attente d'un transfert
#
######################################################################
 Local Char MASUNI : MASUNI="M"
 Call LAUNCH_ACT(MASUNI)
End

######################################################################
# Etiquettes modèle Traitement standard / saisie fenêtre / gobjet
######################################################################
$ACTION

  If dim(ORIACT)>0 & ORIACT<>"" Then
    Case ORIACT
      When "TRTOBJ"
        Case ACTION
          When "LIENS2"       : Gosub MPY_LIENS2
          When Default
        Endcase
        When Default
    Endcase
  Else
    Case ACTION
      When "INIT_DIA"         : Gosub INIT_DIA
      When "INIT"             : Gosub INIT
      When "AVANT_PAR"        : Gosub AVANT_PAR

      When "OUVRE"            : Gosub OUVRE
      When "DEBUT"            : Gosub DEBUT
      When "AP_CHOIX"         : Gosub APPEL_MODELE
      When "BOUTON"           : Gosub BOUTON
      When "APRES_MODIF"      : Gosub APRES_MODIF
      When "SETBOUT"          : Gosub APPEL_MODELE

      When "END"              : Gosub APPEL_MODELE
      When "OK"               : Gosub OK
      When "FIN"              : Gosub FIN
      When "ABA"              : Gosub ABA
      When "EXEC"             : Gosub APPEL_MODELE
      When "TERMINE"          : Gosub APPEL_MODELE
      When "SORTIE"           : Gosub APPEL_MODELE
      # CBO 20110907 exigence 69691 ajout pour import des mvts
      When "CONTROLE"         : Gosub CONTROLE
      # CBO 20120208 exigence 69691 ajout pour import des mvts
      When "IMP_MVT"      : Gosub IMP_MVT
      When Default
    Endcase
  Endif
Return


######################################################################################
$MPY_LIENS2
  Sorta [M:MPY0]NBOBJ [M:MPY0]NBOBJ
Return


######################################################################################
$INIT_DIA                    # (Massif - Saisie des paramètres)
  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT
  Gosub INIT_WIN_PHYTRF    #-> Initialisation de la fenêtre
Return


######################################################################################
$INIT                    # (Unitaire et Massif - interactif et exécution batch)

  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT
Return


######################################################################################
$AVANT_PAR               # (Massif uniquement - Interactif et soumission batch)

  If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Gosub ACTION From =TRTMODACT

##### Ouverture des masques de la fenêtre de l'action massive pour pouvoir les garder jusqu'à
##### EXEC - Ouverture manuelle des masques de la fenêtre.
##### Nécessaire jusqu'à ce qu'une modif permette de lancer une action massive avec plus
##### d'un écran de critère.
  Local Char WINACT : WINACT=ACTMETNAM+"M"
  Local Integer I_MSK
  If !clalev([F:AWI]) : Local File AWINDOW : Endif
  If !clalev([F:AMK]) : Local File AMSK    : Endif
  Read [AWI]AWI0=WINACT
  If !fstat Then
    Local Mask =[F:AWI]MSKENT
    For I_MSK=0 To [F:AWI]NBMSK
      Read [AMK]CODMSK=[F:AWI]NOMMSK(I_MSK)
      Local Mask =[F:AMK]CODMSK
    Next I_MSK
  Endif

##### Préparation et lancement de l'action en mode silencieux
  If ACTSILENCE=G_OUI & TRTFILMSK<>"" Then
    TYPPRG=0
    Gosub INIT_WIN  From TRMPROACT
    Gosub ALIM_MASK From =TRTFILMSK
  Endif

Return


######################################################################################
$OUVRE                   # (Massif interactif et Unitaire)
Global Char    SAUFCYO # 49517
Global Char    SAUFCYD # 49517
Global Char    SAULOCO
Global Char    SAULOCD
Global Date    SAUTRFDAT
Global Integer IND_MVT_ATT
# Global Integer G_EXISTS_TRANS

  If dim(TRTMODACT)<0 Then
    Global Char TRTMODACT
    TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
  Endif
  If dim(TRFSELLOC)<0 Then
    Global Char TRFSELLOC(255)
  Endif
  Gosub ACTION From =TRTMODACT

  # CBO 20110907 exigence 69691 ajout pour import des mvts
  # ajout de or dim(GFXDINT) > 0
  If ACTTYPGES=GTAMUNI or dim(GFXDINT) > 0 Then
    # FQ55485
    #If GBCO_STATU = GVML_SBCOMPO Then        # si le bien rattaché est un composant on interdit les transfert
    #  GERR=1
    #  GMESSAGE=mess(74,7775,1)                # Lélément physique est rattaché à un bien composant, vous devez faire le transfert sur le bien principal.
    #  FIN=1
    #  Return
    #Endif
    IND_MVT_ATT = -1
    If [F:PHY]AASREF <> "" Then
      For I= 0 To dim([F:PHY]MVT)-1
        If [F:PHY]MVT(I) > 1 Then  # il y a un mvt en ettente
          IND_MVT_ATT = I
        Endif
      Next
    Endif

    If IND_MVT_ATT < 0 Then
      SAUFCYO    = [F:PHY]FCY    # FQ49517
      SAULOCO    = [F:PHY]LOC
      SAUFCYD    = [F:PHY]FCY   # FQ49517
      SAULOCD    = [F:PHY]LOC
      SAUTRFDAT  = [F:PHY]TRFDAT
    Else
      SAUFCYO    = [F:PHY]MVTFCY(IND_MVT_ATT) # FQ49517
      SAULOCO    = [F:PHY]MVTLOC(IND_MVT_ATT)
      SAUFCYD    = [F:PHY]MVTFCY(IND_MVT_ATT) # FQ49517
      SAULOCD    = [F:PHY]MVTLOC(IND_MVT_ATT)
      SAUTRFDAT  = [F:PHY]MVTDAT(IND_MVT_ATT)
    Endif
  Endif
Return


######################################################################################
$DEBUT                   # (Massif interactif et Unitaire)

  Gosub ACTION From =TRTMODACT
  If !GBATCH Then
 # CBO 20111012 exigence 69691 ajout pour import des mvts
# on va venir initialiser ici l'action
$DEB_ITFMVT
    Gosub INIT_WIN_PHYTRF    #-> Initialisation de la fenêtre
  Endif
  Setmok [M:PHYM] With 0

  If ACTSILENCE=G_OUI & TRTFILMSK<>"" Then
    TYPPRG=0
    Gosub ALIM_MASK From =TRTFILMSK
  Endif
  If GREP='M' Then
    ACTSTATUS=STA_TEMP
  Else
    Raz ACTSTATUS
  Endif
  If dim(GBCO_STATU) > 0 Then
    # FQ55485
    #If GBCO_STATU = GVML_SBPRINC or GBCO_STATU = GVML_SBCOMPO Then
    #  Grizo [M:PHYM]LOCD
    #Endif
    # FIN FQ55485
  Endif
Return


######################################################################################
$BOUTON             # (Massif interactif et Unitaire)

  If [M:PHYM]CCLTRF=G_OUI Then
    CRITACT="TRFDAT=[M:PHYM]DATTRANS"
  Endif
  Gosub APPEL_MODELE

  If mkstat=4 Then
    REP="M"
    Affzo [M:PHYM]
  Endif
Return


######################################################################################
$APRES_MODIF

  Case COUZON
    When "FLGCPY"
      Local Integer VALCPYFLG
      Case val(CZ)
        When G_OUI
          VALCPYFLG=1
          [M:PHYM]CPYP=func TRMPROACT.GET_SOCSEL(nolign,G_OUI)
        When G_NON
          VALCPYFLG=0
          [M:PHYM]CPYP=func TRMPROACT.GET_SOCSEL(nolign,G_NON)
      Endcase
      Setmok [M:PHYM] With 0
    When "FLGFCY"
      # FQ58040 - On ne compare pas les mêmes tableaux !!
#      [M:PHYM]CPYP=func TRMPROACT.GET_SOCSEL(nolign,G_NON)
      [M:PHYM]CPYP=func TRMPROACT.GET_SOCSEL(0,G_NON)
      Setmok [M:PHYM] With 0
    When Default
  Endcase

  Gosub APPEL_MODELE
Return
######################################################################################
$ABA

  Gosub INIT_WIN_PHYTRF    #-> Ré-initialisation de la fenêtre
  Gosub ACTION From =TRTMODACT
Return


######################################################################################
$OK

  Gosub APPEL_MODELE
  # On ne dégrise le bouton OK de la fenêtre des éléments physiques que si le site géo ou la localisation a changé
  Gosub CONTROLE_VALIDATION
  If VALID=G_OUI Then
    mkstat=4
    IS_TRANSFERT = G_OUI
    If dim(IND_MVT_ATT)>0    Then Kill IND_MVT_ATT    Endif
    If dim(SAUFCYO)>0        Then Kill SAUFCYO        Endif  # FQ49517
    If dim(SAULOCO)>0        Then Kill SAULOCO        Endif
    If dim(SAUFCYD)>0        Then Kill SAUFCYD        Endif  # FQ49517
    If dim(SAULOCD)>0        Then Kill SAULOCD        Endif
    If ACTTYPGES = GTAMUNI Then
      If dim(SAUTRFDAT)>0      Then Kill SAUTRFDAT      Endif
    Endif
  Endif
  Kill VALID
Return


######################################################################################
$FIN

  If dim(IND_MVT_ATT)>0 Then Kill IND_MVT_ATT Endif
  Gosub APPEL_MODELE
Return

$CONTROLE

    # CBO 20110907 exigence 69691 ajout pour import des mvts
    If dim(GFXDNBERR) > 0

        # ne pas continuer si erreur lors de l'alim des champs
        If GFXDERRALCHP
            FIN = 1
            GERR = 1
            Setmode
            Return
        Endif

        Local Integer SV_ERR_TRACE
        Default Mask [M:PHYM]

        GIMPORT = 1 # permet de ne pas afficher à l'écran les messages d'erreur
        SV_ERR_TRACE = GERRTRACE
        Call SAIMSK("", "IMP_MVT", "TRTPHYTRF") From W0PHYTRFP
        If SV_ERR_TRACE = GERRTRACE
            Call CTLVARMODE(GFXDNBERR) From FXDINT
        Endif
        GIMPORT = 0
        # setmode final
        Setmode

        If GFXDERRALCHP or SV_ERR_TRACE <> GERRTRACE
            FIN = 1
            GERR = 1
            # CBO 20120321 FQ10941
            If [F:FXM]DESRJTMVT = ""
                [F:FXM]DESRJTMVT = GMESSAGE
                If [F:FXM]DESRJTMVT = ""
                    [F:FXM]DESRJTMVT = right$(GMESSIMP, 2)
                Endif
            Endif
            Return
        Endif
    Endif
Return

######################################################################################
#--------------------------------------------------------------#
# Appel du modèle de traitement action métier                  #
#--------------------------------------------------------------#
$APPEL_MODELE
  Gosub ACTION From =TRTMODACT
Return


######################################################################################
$ACTMET

  Case ACTMET
    When "CRITMEN"            :   Gosub CRITMEN              # U  - Activation menu ou bouton
    When "AP_NBFCY"           :   Call  AP_NBFCY()           # M  - Chargement du site financier selon critère FQ64478
    When "AP_NBCPY"           :   Call  AP_NBCPY()           # M  - Raz du site financier, site géo et loc si société non sélectionnée FQ64478
    When "AM_FLGCPY"          :   Call  AM_FLGCPY(VALEUR)    # M  - Raz des sites sélectionnés FQ64478
    When "MAS1_CONTROLE"      :   Gosub MAS1_CONTROLE        # M  - Exclusion élément de la population à sélectionner


    When "MAS1_ALIM_TMP1"     :   Gosub MAS1_ALIM_TMP1       # UM - Transfert zones tables de données -> tables tempo

    When "OUVR_APPL_TMP1"     :   Gosub OUVR_APPL_TMP1       # UM - Traitement commun avant application des paramètres de l'action aux enr de la table
    When "TMP1_APPL_TMP1"     :   Gosub TMP1_APPL_TMP1       # UM - Application des paramètres de l'action aux enr de la table temporaire principale

    When "TMP1_ALIM_MASK"     :   Gosub TMP1_ALIM_MASK       # U  - Tansfert table temporaire principale -> masques de l'écran
    When "REAF_ALIM_MASK"     :   Gosub REAF_ALIM_MASK       # U  - Tansfert tables temporaires -> masques de l'écran (pour réaffichage)

    When "OUVR_ALIM_TABLE"    :   Gosub OUVR_ALIM_TABLE      # UM - Ouverture de table annexes pour le report tmp -> données
    When "TMP1_ALIM_TABLE"    :   Gosub TMP1_ALIM_TABLE      # UM - Report table temporaire principale -> table de données
    When "CLOS_ALIM_TABLE"    :   Gosub CLOS_ALIM_TABLE      # UM - Traitement de fin de report

    When "OUVR_APPL_DIRT"     :   Gosub OUVR_APPL_DIRT       # M  - Ouverture de tables annexes pour la maj directe en massif
    When "MAS1_APPL_DIRT"     :   Gosub MAS1_APPL_DIRT       # M  - Mise à jour directe des tables de données avec les paramètres de l'action
    When "CLOS_APPL_DIRT"     :   Gosub CLOS_APPL_DIRT       # M  - Fin mise à jour directe # 49517 (SYMEU)

    When Default
  Endcase
Return


######################################################################################
# Unitaire : critère désactivation / activation menu CRITMEN                         #
######################################################################################
$CRITMEN
# Permet d'alimenter la variable CRITMEN, condition d'activation du menu
Local Integer AUTORISE : AUTORISE=1
Local Integer AUZGEO
Local Integer AUZANA

  Call GET_AUZ_GEOANA(nomap,GUSER,[M:PHY0]CPY,[M:PHY0]FCY,AUZGEO,AUZANA) From TRTFASTRF
  If AUZGEO=G_NON & AUZANA=G_NON Then
    AUTORISE=0
  Endif

  If !AUTORISE
    CRITMEN="1=0"
  Else
    CRITMEN="1=1"
  Endif
Return


######################################################################################
# Unitaire / massif : Chargement de la population en table temporaire                #
#                     Etiquette appelée par le s/p CHARGER                           #
#                     Si une erreur se produit dans cette étiquette                  #
#                     Alimenter RMES avec le message qui doit apparaître             #
#                     dans une boîte en unitaire ou en massif                        #
######################################################################################
$MAS1_ALIM_TMP1

  #=> Alimentation table temporaire par objet
  Raz [F:TMP1] : TABORI="[F:MAS1]" : Gosub ALIM_ENR From TRTPHYTRF
  Write [TMP1]
  Gosub TRT_RET_ALIM_TMP1
Return


######################################################################################
# Unitaire / massif : Traitements communs avant applications des paramètres sur la   #
# table temporaire                                                                   #
# Déclaration des variables nécessaires au s/p d'application des paramètres aux      #
# éléments de la table temporaire                                                    #
######################################################################################
$OUVR_APPL_TMP1
Local Integer CCLTRF
Local Date    TRFDAT
Local Char    CLASORI
Local Char    CLASDES
Local Char    SUFFORI
Local Char    SUFFDES
Local Char    SUFFIX_ZONE
Local Integer RETOUR
Local Char    FCYORI
Local Char    LOCORI
Local Date    TRFDATORI
Local Integer RETOUR
Local Integer USE_PAR_VIDE
Local Integer IMPUT_INCH              # Indicateur d'imputations inchangée # Bug n°26442
Local Char    RMVTTRORI

  #=> INITIALISATION DES VARIABLES
  CCLTRF=[M:PHYM]CCLTRF
  TRFDAT=[M:PHYM]DATTRANS
Return


#######################################################################################
# Unitaire / massif : Application paramètres action au contenu de la table temporaire #
# principale                                                                          #
# Alimentation du type d'opération (transfert ou annulation de transfert) dans la     #
# table temporaire                                                                    #
#######################################################################################
$TMP1_APPL_TMP1

  [F:TMP1]CCLTRF=CCLTRF

  #=> Transfert
  If CCLTRF=G_NON Then
    # Alimentation de la date de transfert
    [F:TMP1]MVTDAT=[M:PHYM]DATTRANS

    # Initialisation de l'enregistrement (Pour le cas où on passe plusieurs fois par contrôler - ex modif de paramétres)
    If [F:TMP1]LOC<>[F:TMP1]LOCO       : [F:TMP1]LOC=[F:TMP1]LOCO       : Endif

    # Transfert
    CLASORI="[M:PHYM]"
    CLASDES="[F:TMP1]"
    SUFFIX_ZONE="D"
    If ACTTYPGES=GTAMMAS Then
      USE_PAR_VIDE=G_NON
    Elsif ACTTYPGES=GTAMUNI
      USE_PAR_VIDE=G_OUI
    Endif
    Gosub TRF_CLASORI_TO_CLASDES

    [F:TMP1]RENTRF=[M:PHYM]REN

    # En unitaire, les param non obligatoires vides sont pris en compte (ex site géo vide)
    # Contrôle imputations inchangée ?
    CLASORI="[F:TMP1]" : SUFFORI="O"
    CLASDES="[M:PHYM]" : SUFFDES="D"
    #Gbn-180705-Fq 31225
    If ACTTYPGES=GTAMMAS Then
      USE_PAR_VIDE=G_NON
    Elsif ACTTYPGES=GTAMUNI
      USE_PAR_VIDE=G_OUI
    Endif

   Gosub CONTROLE_PHY_IMPUTATIONS_INCHANGEE
    If IMPUT_INCH=G_OUI Then
      [F:TMP1]FLGERR=G_OUI
      [F:TMP1]MSGERR=mess(3,7775,1) # "Imputations inchangées pour cet élément physique"
      Return
    Else
      [F:TMP1]FLGERR=G_NON
      [F:TMP1]MSGERR=""
    Endif

    # Vérification de la cohérence de l'élément physique en cours
    # de traitement : reprend ce qui est fait si on clique directement sur le
    # bouton OK sans passer par le bouton Contrôler (étiquette CONTROLE_ELT_IMPUTATIONS_DIRT)
    If !clalev([F:WFCY]) : Local File FACILITY [WFCY] : Endif
    If !clalev([F:WPHY]) : Local File PHYELT   [WPHY] : Endif
    Read [F:WPHY]PHY0=[F:TMP1]OBJREF
    CLASORI="[M:PHYM]" : CLASDES="[F:TMP1]"
  Endif

  #=> Annulation de Transfert
  If CCLTRF=G_OUI Then
    [F:TMP1]MVTDAT=[M:PHYM]DATTRANS

    # Récupération des imputations d'origine du bien
    Call GET_IMPUT_ORI([F:TMP1]CPY,[F:TMP1]FCY,[F:TMP1]OBJREF,[F:TMP1]MVTDAT,
&                      FCYORI,LOCORI,TRFDATORI,RMVTTRORI,RETOUR) From TRTPHYTRFHIS
    # Report des imputations d'origine du bien dans l'enr. de la table temporaire.
    [F:TMP1]RENTRF      = RMVTTRORI
    [F:TMP1]MVTDAT      = [0/0/0]
    [F:TMP1]FCY         = FCYORI
    [F:TMP1]LOC         = LOCORI
    [F:TMP1]MVTDAT      = TRFDATORI
  Endif
Return


######################################################################################
# Unitaire : Permet de reporter les infos de TMP1 dans les masques de l'objet métier #
#            Positionner ACTMODIF à 1 si des infos de l'objet métier sont modifiées  #
######################################################################################
$TMP1_ALIM_MASK
Local Integer RETOUR

  If [F:TMP1]FLGERR=G_NON
    #> PHY0
    Call APPL_ZONE("[M:PHY0]","FCY","[F:TMP1]","FCY", G_OUI, RETOUR) From TRTPHYTRF

    #> PHY1
    [M:PHY1]LOCO    = SAULOCO
    [M:PHY1]LOC     = [F:TMP1]LOC
    [M:PHY1]MVTTR   = [M:PHYM]REN
    [M:PHY1]CCLMVT  = [M:PHYM]CCLTRF
    [M:PHY1]TRFDAT  = [F:TMP1]MVTDAT
    [M:PHY1]ANNDAT  = [M:PHYM]DATTRANS
    #> Mise à jour du témoin de modification
    ACTMODIF=1
  Endif
Return


######################################################################################
# Unitaire : Permet de réafficher les masques de l'objet métier si des modifs y ont  #
#            été reportées.                                                          #
######################################################################################
$REAF_ALIM_MASK

  Affzo [M:PHY1]
Return


######################################################################################
# Alimentation d'un enregistrement de TMP1                                           #
######################################################################################
$ALIM_ENR
Local Integer CPT

  [F:TMP1]TRTNUM  = NUMACT
  [F:TMP1]FLGERR  = G_NON

  If [M:PHYM]CCLTRF = G_NON Then
    If TABORI="[F:MAS1]" Then
      [F:TMP1]FLGMOD = G_OUI
    Endif
  Else
    [F:TMP1]FLGMOD = G_NON
  Endif

  [F:TMP1]OBJREF  = evalue (TABORI+"PHYREF")
  [F:TMP1]PHYDES1 = evalue (TABORI+"PHYDES1")
  [F:TMP1]CPY     = evalue (TABORI+"CPY")
  [F:TMP1]FCYO    = evalue (TABORI+"FCY")    : [F:TMP1]FCY     = evalue (TABORI+"FCY")
  [F:TMP1]LOCO    = evalue (TABORI+"LOC")    : [F:TMP1]LOC     = evalue (TABORI+"LOC")
  [F:TMP1]AASREF  = evalue (TABORI+"AASREF")
  For CPT= 0 To evalue("dim("+TABORI+"MVT)")-1
    [F:TMP1]MVTFCY(CPT) = evalue(TABORI+"MVTFCY("+num$(CPT)+")")  # FQ49517
    [F:TMP1]MVTLOC(CPT) = evalue(TABORI+"MVTLOC("+num$(CPT)+")")
  Next CPT
Return


######################################################################################
# Traitement de l'erreur d'écriture dans la table temporaire                         #
######################################################################################
$TRT_RET_ALIM_TMP1

  If fstat Then
    Case fstat
      When 1
        RMES="TMPMASPHY"-mess(5,7775,1)  # "TMPMASPHY table verrouillée"
        GOK=-1
      When 3
        RMES=mess(5,7775,1)-num$([F:TMP1]TRTNUM)+"/"+[F:TMP1]OBJREF # "Tentative d'écriture en double de la clé"
        GOK=0
      When Default
    Endcase
  Else
    NBTMP+=1
  Endif
Return


######################################################################################
# Transfert des imputations et affectations d'une classe origine vers une classe     #
# destination                                                                        #
#     CLASORI     - Classe contenant les informations à reporter                     #
#     CLASDES     - Classe à mettre à jour à partir de CLASORI                       #
#     SUFFIX_ZONE - Suffixe éventuel des noms de champ à transférer                  #
######################################################################################
$TRF_CLASORI_TO_CLASDES

 Call APPL_ZONE(CLASDES,"FCY",   CLASORI,"FCY"+SUFFIX_ZONE,   USE_PAR_VIDE,RETOUR) From TRTPHYTRF
 Call APPL_ZONE(CLASDES,"LOC",   CLASORI,"LOC"+SUFFIX_ZONE,   USE_PAR_VIDE,RETOUR) From TRTPHYTRF
Return


######################################################################################
# Déclaration de variables diverses                                                  #
######################################################################################
$OUVR_ALIM_TABLE

  # Ouverture des classes de travail pour la génération des événements
  If !clalev([F:PHYO]) : Local File PHYELT [PHYO] : Endif
  If !clalev([F:PHYD]) : Local File PHYELT [PHYD] : Endif

  # Société courante : rupture société pour émission en-tête trace
  Local Char TRC_CPY   : Raz TRC_CPY

  # Zone contenant la nature et la date du transfert
  If dim([V]RENTRF)<0    : Global Char    RENTRF    : Endif
  If dim([V]MVTDAT)<0    : Global Date    MVTDAT    : Endif

  # Variables diverses
  Local Char    CLASDES          # Classe de la classe destination des mises à jour
  Local Char    CLASORI          # Classe de la classe origine des modifications
  Local Char    SUFFIX_ZONE      # Suffixe éventuel de la zone origine
  Local Integer RETOUR
  Local Integer USE_PAR_VIDE

  # Variables pour la génération des événements
  Local Char    WK_CPY           # Société du bien pour lequel on veut traiter l'événement
  Local Char    WK_FCY
  Local Char    WK_PHYREF
  Local Date    WK_TRFDAT
Return


######################################################################################
# Chargement des imputations actuelles de l'élément physique dans le masque          #
# de paramètre de la fonction de transfert - utilisée en unitaire                    #
# Est appelée quand on décoche la case "Annulation"                                  #
######################################################################################
$LOAD_IMPUTATION_PHY

  If IND_MVT_ATT >= 0 Then
    [M:PHYM]FCYD     = [M:PHY1]MVTFCY(IND_MVT_ATT)   # FQ49517
    [M:PHYM]LOCD     = [M:PHY1]MVTLOC(IND_MVT_ATT)
    [M:PHYM]DATTRANS = date$
    [M:PHYM]TRFDAT   = [M:PHY1]TRFDAT
  Else
    [M:PHYM]FCYD     = [M:PHY0]FCY
    [M:PHYM]LOCD     = SAULOCD
    [M:PHYM]DATTRANS = date$
    [M:PHYM]TRFDAT   = [M:PHY1]TRFDAT
  Endif

  Affzo [M:PHYM]
Return


######################################################################################
# Chargement des imputations de l'élément physique avant le dernier transfert        #
# géographique. Les infos sont récupérées sur l'événement de transfert.              #
# Est appelée quand on coche la case "Annulation"                                    #
######################################################################################
$LOAD_IMPUTATION_ORIGINE
Local Char    FCYORI
Local Char    LOCORI
Local Integer RETOUR
Local Date    RTRFDATORI
Local Char    RMVTTRORI

  # Récupération des imputations d'origine du bien
  Call GET_IMPUT_ORI([M:PHY0]CPY,[M:PHY0]FCY,[M:PHY0]PHYREF,[M:PHYM]TRFDAT,
&                    FCYORI,LOCORI,RTRFDATORI,RMVTTRORI,RETOUR) From TRTPHYTRFHIS
  [M:PHYM]FCYD     = FCYORI
  [M:PHYM]LOCD     = LOCORI
  [M:PHYM]DATTRANS = [M:PHYM]TRFDAT
  [M:PHYM]TRFDAT   = RTRFDATORI
  [M:PHYM]REN      = RMVTTRORI

  Affzo [M:PHYM]
Return


######################################################################################
# Initialisation des variables contenant les dates de période et d'exercice des      #
# contextes gérés par la société                                                     #
######################################################################################
$SET_CPY_DAT

  If dim(GCPYSTRFIY)<0 : Local Date    GCPYSTRFIY(1..G300MAX) : Endif
  If dim(GCPYENDFIY)<0 : Local Date    GCPYENDFIY(1..G300MAX) : Endif
  If dim(GCPYSTRPER)<0 : Local Date    GCPYSTRPER(1..G300MAX) : Endif
  If dim(GCPYENDPER)<0 : Local Date    GCPYENDPER(1..G300MAX) : Endif
  Local Integer RETOUR
  # Appel du sous-pro d'alimentation des dates
  Call GET_CPY_DAT(TRC_CPY,GCPYSTRFIY,GCPYENDFIY,GCPYSTRPER,GCPYENDPER,RETOUR) From GLOBIENS
Return


######################################################################################
# Unitaire / massif : Report du contenu de la table temporaire principale dans la    #
# table de données principale                                                        #
######################################################################################
$TMP1_ALIM_TABLE
Local Date ANNDAT
Local Integer HAS_BCO : HAS_BCO = G_NON

  #=> En massif, à rupture société on émet un en-tête dans la trace
  If [F:TMP1]CPY<>TRC_CPY Then
    If ACTTYPGES=GTAMMAS Then
      Call ET_COMPTE_RENDU([F:TMP1]CPY) From TRTPHYTRF
    Endif
    TRC_CPY=[F:TMP1]CPY
    Gosub SET_CPY_DAT
  Endif

  #=> Transfert
  If [F:TMP1]CCLTRF=G_NON Then
   #-> Report de l'enregistrement de TMP1 dans MAS1
    [F:PHYO] = [F:MAS1]  # Sauvegarde des valeurs d'origine de l'élément physique
    CLASDES      = "[F:MAS1]"
    CLASORI      = "[F:TMP1]"
    SUFFIX_ZONE  = ""
    USE_PAR_VIDE = G_OUI
    #> Report des zones relative au transfert géographique
    Gosub TRF_CLASORI_TO_CLASDES

    #> Report de zones diverses
    [F:MAS1]TRFDAT=[F:TMP1]MVTDAT
    [F:PHYD] = [F:MAS1]  # Sauvegarde des nouvelles valeurs de l'élément physique

    #-> En massif emission de message dans le compte-rendu
    If ACTTYPGES=GTAMMAS Then
      # 49517 - MABON - 25/05/09 - Ajout test sur [F:TMP1]FLGERR, car sinon, même si erreur,
      # l'élément physique est quand même mis à jour !!
      If [F:MAS1]AASREF <> "" and [F:TMP1]FLGERR<>G_OUI Then   # si un bien est rattaché on met le mouvement en attente
        # début 49517 (SYMEU) : transfert de site financier
        If [F:PHYO]FCY = [F:MAS1]FCY and [F:PHYO]LOC <> [F:MAS1]LOC
&       and [F:PHYO]MVT(0) < 2 Then
          # c'est un changement de localisation et il n'y a pas d'en attente, on le fait immédiatement, on ne le met pas en attente
          # mise à jour de la localisation du bien quand on fait seulement un transfert de localisation sur l'élément
          #Call MAJ_LOC_BIEN : # FQ62267
          Call MAJ_LOC_BIEN ([F:MAS1]PHYREF, [F:MAS1]AASREF, [F:MAS1]LOC)
        Else
        # fin 49517 (SYMEU) : transfert de site financier
          I=0
          While (I<=dim([F:MAS1]MVT)-1) and ([F:MAS1]MVT(I)>1) # on cherche la premiere ligne de libre
            I += 1
          Wend
          If I < dim([F:MAS1]MVT) Then # 49517 (SYMEU) : transfert de site financier
            [F:MAS1]MVT(I)       = GVMLPMVGEO  :  # transfert
            [F:MAS1]MVTDAT(I)    = [F:TMP1]MVTDAT
            [F:MAS1]MVTTRANS(I)  = [M:PHYM]REN
            [F:MAS1]MVTFCY(I)    = [F:TMP1]FCY
            [F:MAS1]MVTLOC(I)    = [F:TMP1]LOC
            HAS_BCO = G_OUI
            # on restaure les valeurs d'origine pour l'élément physique en cours.
            # MABON - 20/05/09 - Ajout ligne sur FCY
            [F:MAS1]FCY    = [F:PHYO]FCY
            [F:MAS1]LOC    = [F:PHYO]LOC
            [F:MAS1]TRFDAT = [F:PHYO]TRFDAT : # FQ50829
          # début 49517 (SYMEU) : transfert de site financier
          Else
            [F:TMP1]FLGERR=G_OUI
            [F:TMP1]MSGERR=mess(139,7775,1) # Impossible d'ajouter un transfert un attente, il y a déjà 4 mouvements en attente
            GOK=0
          Endif
          # fin 49517 (SYMEU) : transfert de site financier
        Endif # 49517 (SYMEU) : transfert de site financier
      Endif

      If [F:TMP1]FLGERR=G_OUI Then
        Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]PHYREF,0,G_OUI,[F:TMP1]MSGERR) From TRCPROCOM
      Elsif [F:TMP1]FLGERR=G_NON
        Call PHY_COMPTE_RENDU([F:MAS1]CPY,[F:MAS1]PHYREF,[F:MAS1]PHYDES1,"",[F:PHYO]LOC) # 49517 modif compte-rendu
        NBCPYMAJ+=1
      Endif
      ANNDAT = [0/0/0]
    Endif
  Endif
   #=> Annulation de transfert
  If [F:TMP1]CCLTRF=G_OUI Then
    #-> Report de l'enregistrement de TMP1 dans MAS1
    [F:PHYO] = [F:MAS1]  # Sauvegarde des valeurs d'origine de l'élément physique
    CLASDES      = "[F:MAS1]"
    CLASORI      = "[F:TMP1]"
    SUFFIX_ZONE  = ""
    USE_PAR_VIDE = G_OUI
    Gosub TRF_CLASORI_TO_CLASDES

    [F:MAS1]TRFDAT     = [F:TMP1]MVTDAT
    [F:PHYD] = [F:MAS1]  # Sauvegarde des nouvelles valeurs de l'élément physique

    #-> En massif emission de message dans le compte-rendu
    If ACTTYPGES=GTAMMAS Then
      If [F:MAS1]AASREF <> "" Then
        # début 49517 (SYMEU) : transfert de site financier
        If [F:PHYO]FCY = [F:MAS1]FCY and [F:PHYO]LOC <> [F:MAS1]LOC
&       and [F:PHYO]MVT(0) < 2 Then
          # c'est un changement de localisation et il n'y a pas d'en attente, on le fait immédiatement, on ne le met pas en attente
          # mise à jour de la localisation du bien quand on fait seulement un transfert de localisation sur l'élément
          #Call MAJ_LOC_BIEN : # FQ62267
          Call MAJ_LOC_BIEN ([F:MAS1]PHYREF, [F:MAS1]AASREF, [F:MAS1]LOC)
        Else
          # Récupération des informations d'origine
          [F:MAS1]=[F:PHYO]
        # fin 49517 (SYMEU) : transfert de site financier
          If [F:MAS1]MVT(0)>1 Then
            # on ne peut pas faire d'annulation s'il y a des mouvements en attente
            [F:TMP1]FLGERR=G_OUI
            [F:TMP1]MSGERR=mess(140,7775,1) # Impossible d'ajouter une annulation de transfert en attente, il y a déjà des mouvements en attente
            GOK=0
          Else
            [F:MAS1]MVT(0)     = GVMLPMVAGEO  : # Annulation transfert
            [F:MAS1]MVTDAT(0)  = [F:MAS1]TRFDAT
            HAS_BCO = G_OUI
            [F:MAS1]MVTFCY(0)   = [F:PHYD]FCY
            [F:MAS1]MVTLOC(0)   = [F:PHYD]LOC
          Endif
          # fin 49517 (SYMEU) : transfert de site financier
        Endif # 49517 (SYMEU) : transfert de site financier
      Endif

      If [F:TMP1]FLGERR=G_OUI Then
        Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]PHYREF,0,G_OUI,[F:TMP1]MSGERR) From TRCPROCOM
      Elsif [F:TMP1]FLGERR=G_NON
        Call PHY_COMPTE_RENDU([F:MAS1]CPY,[F:MAS1]PHYREF,[F:MAS1]PHYDES1,"",[F:PHYD]LOC) # 49517 modif compte-rendu
        NBCPYMAJ+=1
      Endif
      ANNDAT = [M:PHYM]DATTRANS
    Endif

  Endif

  If ACTTYPGES=GTAMMAS Then
    # 49517 (SYMEU) : transfert site financier (on ne transfère pas s'il y a des erreurs (lock notamment))
    # If FLGSIM = G_NON and HAS_BCO = G_NON Then
    If FLGSIM = G_NON and HAS_BCO = G_NON and [F:TMP1]FLGERR <> G_OUI Then
      # FQ49517 :Modification des paramètres, rajout du site financier d'origine.
      Call TRANS_ELT( [M:PHYM]CCLTRF, [F:MAS1]PHYREF,[F:PHYO]FCY,[F:MAS1]FCY,[F:PHYO]LOC,[F:MAS1]LOC,[F:MAS1]TRFDAT,ANNDAT, G_OUI)
    Endif
  Endif
Return


######################################################################################
# Unitaire / massif : Après report du contenu de la table temporaire principale dans #
# la table de données principale                                                     #
######################################################################################
$CLOS_ALIM_TABLE
  If dim([V]RENTRF)>0      : Kill [V]RENTRF      : Endif
  If dim([V]MVTDAT)>0      : Kill [V]MVTDAT      : Endif
Return


######################################################################################
# Massif : Déclaration et initialisation avant traitement de la population
#          en mise à jour directe. Valable uniquement en massif.
######################################################################################
$OUVR_APPL_DIRT
  # Classe pour traiter les composants
  If !clalev([F:MAS2]) : Local File PHYELT [MAS2] : Endif

  # Ouverture des classes de travail pour la génération des événements
  If !clalev([F:PHYO]) : Local File PHYELT [PHYO] : Endif
  If !clalev([F:PHYD]) : Local File PHYELT [PHYD] : Endif

  # Société courante : rupture société pour émission en-tête trace
  Local Char TRC_CPY

  # Zone contenant la nature et la date du transfert
  If dim([V]RENTRF)<0 : Global Char RENTRF : Endif
  If dim([V]MVTDAT)<0 : Global Date MVTDAT : Endif

  # Variables diverses :
Local Char    CLASDES                 # Classe de la classe destination des mises à jour
Local Char    CLASORI                 # Classe de la classe origine des modifications
Local Char    SUFFORI
Local Char    SUFFDES
Local Char    SUFFIX_ZONE             # Suffixe éventuel de la zone origine
Local Integer RETOUR                  # Code retour sous-programme
Local Char    FCYORI                  # Site financier origine
Local Char    LOCORI                  # Localisation origine
Local Date    TRFDATORI               # Date de transfert origine
Local Integer CCLTRF                  # Transfert ou annulation de transfert
Local Date    TRFDAT                  # Date de transfert
Local Integer USE_PAR_VIDE            # Indique si un paramétre de valeur null doit être appliqué à la zone
Local Integer IMPUT_INCH              # Indicateur d'imputations inchangée

  # Variables de travail pour la génération des événements et la récupération des imputations d'origine
Local Char    WK_CPY                  # Société
Local Char    WK_FCY                  # Site
Local Char    WK_PHYREF               # Référence Elt
Local Date    WK_TRFDAT               # Date de transfert
Local Char    WK_NOMZON               # Nom de zone pour assign
Local Decimal WK_MONTANT              # Montant de travail pour assign

  # Initialisations diverses
  CCLTRF=[M:PHYM]CCLTRF
Return


######################################################################################
# Massif : Application paramètres action aux tables de données : mise à jour directe #
######################################################################################
$MAS1_APPL_DIRT

  #=> A rupture société : en-tête société dans la trace et chargement des dates des contextes
  If [F:MAS1]CPY<>TRC_CPY Then
    Call ET_COMPTE_RENDU([F:MAS1]CPY) From TRTPHYTRF
    TRC_CPY=[F:MAS1]CPY
    Gosub SET_CPY_DAT
  Endif

   #-> Traitement de l'élément physique
  Gosub TRANSFERT_DIRT

  #-> Si une erreur s'est produit on sort
  Raz RMES
  If GOK<1 : Return : Endif
Return


######################################################################################
$CLOS_APPL_DIRT
  If dim([V]RENTRF)>0      : Kill [V]RENTRF      : Endif
  If dim([V]MVTDAT)>0      : Kill [V]MVTDAT      : Endif
Return


######################################################################################
$TRANSFERT_DIRT
Local Date ANNDAT
Local Integer HAS_BCO

  [F:PHYO] = [F:MAS1]                                           # Sauvegarde des valeurs d'origine de l'élément physique

  # Le contrôle des imputations inchangées ne doit pas se faire en annulation
  If CCLTRF=G_NON Then
    # Contrôle imputations inchangée ?
    CLASORI="[F:PHYO]" : SUFFORI=""
    CLASDES="[M:PHYM]" : SUFFDES="D"
    USE_PAR_VIDE=G_NON
    Gosub CONTROLE_PHY_IMPUTATIONS_INCHANGEE
    If IMPUT_INCH=G_OUI
      Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]PHYREF,0,G_OUI,mess(3,7775,1)) From TRCPROCOM #"Imputations inchangées pour cet élément""
      Return
    Endif
  Endif
  CLASDES  ="[F:MAS1]"                                          # Classe à mettre à jour
  If CCLTRF=G_NON : Gosub REPORT_PHYM_MAS_DIRT          : Endif #      Application des paramètres de transfert à l'élément
  If CCLTRF=G_OUI : Gosub LOAD_INPUT_ORI                : Endif # ou   Restauration des imputations d'origine
  [F:PHYD] = [F:MAS1]                                           # Sauvegarde des nouvelles valeurs du bien comptable
  If CCLTRF=G_NON : Gosub CONTROLE_ELT_IMPUTATIONS_DIRT : Endif # Contrôle des nouvelles imputations et localisations
  If dim(NBR_ERREUR)>0 & NBR_ERREUR>0 Then
    If ACTSILENCE=G_OUI Then
      Local Integer I_ERREUR
      G_MAJOK=G_NON
      GT_OBJ_REF(I_OBJ)=[F:MAS1]PHYREF
      GT_OBJ_DES(I_OBJ)=[F:MAS1]PHYDES1
      I_OBJ+=1
      For I_ERREUR=1 To dim(GT_LIS_ERR)
        If TAB_ERREUR(I_ERREUR-1)="" : Break : Endif
        GT_LIS_ERR(I_ERREUR-1)=TAB_ERREUR(I_ERREUR-1)
      Next I_ERREUR
    Else
      Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]PHYREF,0,G_OUI,mess(67,7775,1)) From TRCPROCOM #"Erreur d'imputation ou de localisation sur cet élément"
    Endif
  Else


    [F:PHYD]=[F:MAS1]
    If FLGSIM = G_NON Then
      If CCLTRF=G_OUI Then
        ANNDAT = [M:PHYM]DATTRANS
      Else
        ANNDAT = [0/0/0]
      Endif
      # début 49517 (SYMEU) : transfert de site financier
      # If [F:MAS1]AASREF = "" Then
      If [F:MAS1]AASREF = ""
&     or ([F:MAS1]AASREF <> "" and [F:PHYO]FCY=[F:MAS1]FCY and [F:PHYO]LOC<>[F:MAS1]LOC and [F:PHYO]MVT(0) < 2) Then
      # fin 49517 (SYMEU) : transfert de site financier
          # FQ49517 :passage du site financier d'origine à TRANS_ELT
          Call TRANS_ELT( [M:PHYM]CCLTRF, [F:MAS1]PHYREF,[F:PHYO]FCY,[F:MAS1]FCY,[F:PHYO]LOC,[F:MAS1]LOC,[F:MAS1]TRFDAT,ANNDAT, G_OUI)
          # transfert de site financier
          # mise à jour de la localisation du bien quand on fait seulement un transfert de localisation sur l'élément
          If [F:MAS1]AASREF <> "" and GOK <> 0 Then
            #Call MAJ_LOC_BIEN : # FQ62267
            Call MAJ_LOC_BIEN ([F:MAS1]PHYREF, [F:MAS1]AASREF, [F:MAS1]LOC)
          Endif
          # fin transfert de site financier
      # transfert de site financier
      Elsif CCLTRF=G_OUI # annulation d'un transfert de site géographique ou financier
          # Récupération des informations d'origine et mise à jour de l'en-attente s'il n'y a rien en attente
          [F:MAS1]=[F:PHYO]
          If [F:MAS1]MVT(0)>1 Then # s'il y a des mouvements en attente, on ne peut pas faire d'annulation de transfert
            OK = -1 : GERR=1 : GOK = 0
            Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]PHYREF,0,G_OUI,mess(140,7775,1)) From TRCPROCOM # "Impossible d'ajouter une annulation de transfert un attente, il y a déjà des mouvements en
# attente"
          Else
            [F:MAS1]MVT(0)      = GVMLPMVAGEO : # Annulation de transfert géographique
            [F:MAS1]MVTDAT(0)   = [F:PHYD]TRFDAT
            [F:MAS1]MVTFCY(0)   = [F:PHYD]FCY
            [F:MAS1]MVTLOC(0)   = [F:PHYD]LOC
          Endif
      # fin 49517 (SYMEU) : transfert de site financier
      Endif
      If GOK <> 0 Then # 49517 (SYMEU) : transfert site financier : ne pas mettre à jour si erreur ci-dessus
        Rewrite [MAS1]                                               # Réecriture de l'élément
        Gosub TRT_RET_DIRT                                           # Traitement du résultat de la réécriture
        If ACTSILENCE=G_OUI Then
          G_MAJOK=G_OUI
          GT_OBJ_REF(I_OBJ)=evalue(CLASDES+"PHYREF")
          GT_OBJ_DES(I_OBJ)=evalue(CLASDES+"PHYDES1")
          I_OBJ+=1
        Else
          # début 49517 modif compte-rendu
          # Call PHY_COMPTE_RENDU(evalue(CLASDES+"CPY"),evalue(CLASDES+"PHYREF"),evalue(CLASDES+"PHYDES1"),"")
          If CCLTRF=G_OUI Then
            # on annule le transfert donc on affiche le site et la localisation de destination
            Call PHY_COMPTE_RENDU(evalue(CLASDES+"CPY"),evalue(CLASDES+"PHYREF"),evalue(CLASDES+"PHYDES1"),"",evalue(CLASDES+"LOC"))
          Else
            # on transfère donc on affiche le site et la localisation d'origine
            Call PHY_COMPTE_RENDU(evalue(CLASDES+"CPY"),evalue(CLASDES+"PHYREF"),evalue(CLASDES+"PHYDES1"),"",[F:PHYO]LOC)
          Endif
          # fin 49517 modif compte-rendu
        Endif
        # Emission des infos du BCO dans le compte-rendu ou dans une globale si traitement silencieux
        # Incrémentation du compteur de mises à jour
        NBCPYMAJ+=1
      Endif # 49517 (SYMEU) : transfert site financier : ne pas mettre à jour si erreur ci-dessus
      # début 49517 (SYMEU) : transfert de site financier : alimentation du CR même en simulation
    Else # alimentation du compte-rendu en simulation
      # début 49517 modif compte-rendu
      # Call PHY_COMPTE_RENDU(evalue(CLASDES+"CPY"),evalue(CLASDES+"PHYREF"),evalue(CLASDES+"PHYDES1"),"")
      If CCLTRF=G_OUI Then
        # on annule le transfert donc on affiche le site et la localisation de destination
        Call PHY_COMPTE_RENDU(evalue(CLASDES+"CPY"),evalue(CLASDES+"PHYREF"),evalue(CLASDES+"PHYDES1"),"",evalue(CLASDES+"LOC"))
      Else
        # on transfère donc on affiche le site et la localisation d'origine
        Call PHY_COMPTE_RENDU(evalue(CLASDES+"CPY"),evalue(CLASDES+"PHYREF"),evalue(CLASDES+"PHYDES1"),"",[F:PHYO]LOC)
      Endif
      # fin 49517 modif compte-rendu
    # fin 49517 (SYMEU) : transfert de site financier
    # Emission des infos du BCO dans le compte-rendu ou dans une globale si traitement silencieux
    # Incrémentation du compteur de mises à jour
    NBCPYMAJ+=1
    Endif
  Endif
  If CCLTRF=G_NON : Kill TAB_ZONERR, TAB_ERREUR, NBR_ERREUR : Endif
Return


######################################################################################
$REPORT_PHYM_MAS_DIRT

  CLASORI      = "[M:PHYM]"          # Classe Origine
  SUFFIX_ZONE  = "D"                 # Suffixe des zones à reporter
  USE_PAR_VIDE = G_NON               # Prise en compte des paramètres sans valeur ?
  Gosub TRF_CLASORI_TO_CLASDES
  NOMZON=CLASDES+"TRFDAT" : Assign NOMZON With evalue(CLASORI+"DATTRANS")
  If [F:MAS1]AASREF <> "" Then   # si un bien est rattaché on met le mouvement en attente
    # début 49517 (SYMEU) : transfert de site financier
    If [F:PHYO]FCY = [F:MAS1]FCY  and [F:PHYO]LOC <> [F:MAS1]LOC and [F:PHYO]MVT(0) < 2 Then
       # c'est un changement de localisation alors qu'il n'y a pas d'en attente, on le fait immédiatement, on ne le met pas en attente
    Else
    # fin 49517 (SYMEU) : transfert de site financier
      I=0
      While (I<=dim([F:MAS1]MVT)-1) and ([F:MAS1]MVT(I)>1) # on cherche la premiere ligne de libre
        I += 1
      Wend
      If I < dim([F:MAS1]MVT) Then # 49517 (SYMEU) : transfert de site financier
        If [M:PHYM]CCLTRF = G_OUI Then
          [F:MAS1]MVT(I)     = GVMLPMVAGEO  : # Annulation transfert
          [F:MAS1]MVTDAT(I)  = [F:MAS1]TRFDAT
        Else
          [F:MAS1]MVT(I)       = GVMLPMVGEO  :  # transfert
          [F:MAS1]MVTDAT(I)    = [M:PHYM]DATTRANS
          [F:MAS1]MVTTRANS(I)  = [M:PHYM]REN
          [F:MAS1]MVTFCY(I)    = [M:PHYM]FCYD    : # FQ49517
          [F:MAS1]MVTLOC(I)    = [M:PHYM]LOCD
          [F:MAS1]FCY          = [F:PHYO]FCY
          [F:MAS1]LOC          = [F:PHYO]LOC
          [F:MAS1]TRFDAT       = [F:PHYO]TRFDAT  : # FQ50829
        Endif
      # début 49517 (SYMEU) : transfert de site financier
      Else
        OK = -1 : GERR=1 : GOK = 0
        Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]PHYREF,0,G_OUI,mess(139,7775,1)) From TRCPROCOM # "Impossible d'ajouter un transfert un attente, il y a déjà 4 mouvements en attente"
      Endif
      # fin 49517 (SYMEU) : transfert de site financier
    Endif # 49517 (SYMEU) : transfert de site financier
  Endif
Return


######################################################################################
$LOAD_INPUT_ORI
Local Char    RMVTTRORI

  WK_CPY    = evalue(CLASDES+"CPY")
  WK_FCY    = evalue(CLASDES+"FCY")
  WK_PHYREF = evalue(CLASDES+"PHYREF")
  WK_TRFDAT = evalue(CLASDES+"TRFDAT")

  Call GET_IMPUT_ORI(WK_CPY,WK_FCY,WK_PHYREF,WK_TRFDAT,
&                    FCYORI,LOCORI,TRFDATORI,RMVTTRORI,RETOUR) From TRTPHYTRFHIS
  #-> Si erreur
  If RETOUR Then
    Call ECR_TRACE_ERREUR(WK_CPY,WK_AASREF,0,G_OUI,mess(68,7775,1)) From TRCPROCOM #"Annulation de transfert impossible, pas d'événement"
    Return
  Endif

  #-> Si pas d'erreur, report des imputations d'origine
  If !RETOUR Then
    WK_NOMZON=CLASDES+"FCY"    : Assign WK_NOMZON With FCYORI
    WK_NOMZON=CLASDES+"LOC"    : Assign WK_NOMZON With LOCORI
    WK_NOMZON=CLASDES+"TRFDAT" : Assign WK_NOMZON With TRFDATORI
  Endif
Return


######################################################################################
$CONTROLE_ELT_IMPUTATIONS_DIRT

  Gosub DECLARE_VAR_CONTROLE

  TRFDAT = evalue (CLASDES+"TRFDAT")
  CPY    = evalue (CLASDES+"CPY")
  FCY    = evalue (CLASDES+"FCY")
  LOC    = evalue (CLASDES+"LOC")
  Gosub APPEL_SP_CONTROLE
Return


######################################################################################
# Appel du sous-programme de contrôle                                                #
######################################################################################
$APPEL_SP_CONTROLE

  Call CONT_IMPUTATION(TRFDAT,CPY,FCY,LOC,TAB_ZONERR,TAB_ERREUR,NBR_ERREUR,RETOUR) From TRTPHYTRF
Return


######################################################################################
# Contrôle des imputations et affectations d'un élément                              #
######################################################################################
Subprog CONT_IMPUTATION(PTRFDAT,PCPY,PFCY,PLOC,RTABZON,RTABERR,RNBERR,RET)
Value    Date    PTRFDAT
Value    Char    PCPY
Value    Char    PFCY
Value    Char    PLOC
Variable Char    RTABZON()()
Variable Char    RTABERR()()
Variable Integer RNBERR
Variable Integer RET

  If !clalev([F:WFCY]) : Local File FACILITY  [WFCY] : Endif
  If !clalev([F:WLOC]) : Local File LOCALIZAT [WLOC] : Endif
  If !clalev([F:WCPY]) : Local File COMPANY   [WCPY] : Endif
  If !clalev([F:WFGR]) : Local File FACGROUP  [WFGR] : Endif

Local Integer  I_ERR

  Raz RNBERR
  Raz RTABZON
  Raz RTABERR
  Raz RET
  Raz I_ERR

  #-> Contrôle de la cohérence des niveaux géographiques
  #> Contrôle site financier par rapport à la société
  Read [WFCY]FCY0=PFCY
  If fstat Then
    RET=10+fstat
    End
  Else
    If [F:WFCY]LEGCPY<>PCPY Then
      RET=1
      RTABZON(I_ERR)=mess(65,7775,1) #"Site financier"
      # 49517 (SYMEU) : remplacé message en dur
      # RTABERR(I_ERR)=PFCY-"ce site financier a pour société"-[F:WFCY]LEGCPY
      RTABERR(I_ERR)=PFCY-mess(136,7775,1)-[F:WFCY]LEGCPY
      I_ERR+=1
    Endif
  Endif

  #> Contrôle localisation par rapport au site géographique (site d'inventaire)
  If PLOC<>"" Then
    Read [WLOC]LOC0=PLOC
    If fstat Then
      If fstat=5 Then
        RET=1
        RTABZON(I_ERR)=mess(122,7776,1) # "Localisation"
        RTABERR(I_ERR)=PLOC-mess(122,7776,1)-mess(85,7776,1) #  "localisation inconnue"
        I_ERR+=1
      Else
        RET=20+fstat
        End
      Endif
    Else
    Endif
  Endif

  RNBERR=I_ERR
End


######################################################################################
$TRT_RET_DIRT

  If fstat Then
    Case fstat
      When 1
        RMES=mess(69,7775,1)-evalue(CLASDES+"PHYREF")+"/"+evalue(CLASDES+"PHYDES1") # "ENREGISTREMENT en cours d'utilisation"
        GOK=-1
      When 3
        RMES=mess(70,7775,1)-evalue(CLASDES+"PHYREF") # "Tentative d'écriture en double de la clé"
        GOK=0
      When Default
    Endcase
    If ACTSILENCE=G_OUI Then
      G_MAJOK=G_NON
      GT_OBJ_REF(I_OBJ)=evalue(CLASDES+"PHYREF")
      GT_OBJ_DES(I_OBJ)=evalue(CLASDES+"PHYDES1")
      I_OBJ+=1
    Else
      # début 49517 modif compte-rendu
      # Call PHY_COMPTE_RENDU(evalue(CLASDES+"CPY"),evalue(CLASDES+"PHYREF"),evalue(CLASDES+"PHYDES1"),"")
      If CCLTRF=G_OUI Then
        # on annule le transfert donc on affiche le site et la localisation de destination
        Call PHY_COMPTE_RENDU(evalue(CLASDES+"CPY"),evalue(CLASDES+"PHYREF"),evalue(CLASDES+"PHYDES1"),"",evalue(CLASDES+"LOC"))
      Else
        # on transfère donc on affiche le site et la localisation d'origine
        Call PHY_COMPTE_RENDU(evalue(CLASDES+"CPY"),evalue(CLASDES+"PHYREF"),evalue(CLASDES+"PHYDES1"),"",[F:PHYO]LOC)
      Endif
      # fin 49517 modif compte-rendu
    Endif
  Else
    # Gestion événements si on est en traitement réél
    If FLGSIM=G_NON Then
      #-> Evénement de transfert
      If [M:PHYM]CCLTRF=G_NON Then
        If RENTRF=""         : RENTRF=[M:PHYM]REN         : Endif
        If [V]MVTDAT=[0/0/0] : [V]MVTDAT=[M:PHYM]DATTRANS : Endif
        WK_TRFDAT=[M:PHYM]DATTRANS
      Endif
      #-> Annulation d'événement de transfert
      If [M:PHYM]CCLTRF=G_OUI Then
        WK_CPY    = [F:PHYO]CPY
        WK_FCY    = [F:PHYO]FCY
        WK_PHYREF = [F:PHYO]AASREF
        WK_TRFDAT = [F:PHYO]TRFDAT
      Endif
    Endif
  Endif
Return


######################################################################################
# Contrôle si les imputations de l'élément sont inchangées                           #
# Dans ce cas la variable IMP_INCH est positionnée à G_OUI sinon elle a la valeur    #
# G_NON. Les imputation de l'élément sont à prendre dans CLASORI et les nouvelles    #
# imputations dans CLASDES.                                                          #
# La variable USE_PAR_VIDE permet de prendre ou pas en compte des paramétres de      #
# valeur null                                                                        #
######################################################################################
$CONTROLE_VALIDATION
Global Integer VALID

  VALID=G_OUI
  If ACTTYPGES=GTAMUNI Then
    If IND_MVT_ATT =-1 Then
      If  ( SAULOCO=[M:PHYM]LOCD) or (SAULOCO='') Then
        VALID=G_NON
        GMESSAGE = mess(3,7775,1)
        GERR = 1
        FIN = 0   # pour rester dans la fenêtre
        Return
      Endif
    Else
      If  ([M:PHY1]MVTLOC(IND_MVT_ATT)=[M:PHYM]LOCD) Then
        VALID=G_NON
        GMESSAGE = mess(3,7775,1)
        GERR = 1
        FIN = 0   # pour rester dans la fenêtre
        # FQ49517 on se positionne sur le site financier au lieu du site géographique.
        zonsui="[M:PHYM]FCYD"
        Return
      Endif
    Endif
  Endif
Return

######################################################################################
# Contrôle Si les imputations de l'élément sont inchangées                           #
# Dans ce cas la variable IMP_INCH est positionnée à G_OUI sinon elle a la valeur    #
# G_NON. Les imputation de l'élément sont à prendre dans CLASORI et les nouvelles    #
# imputations dans CLASDES.                                                          #
# La variable USE_PAR_VIDE permet de prendre ou pas en compte des paramétres de      #
# valeur null                                                                        #
######################################################################################
$CONTROLE_PHY_IMPUTATIONS_INCHANGEE

  If dim(IMPUT_INCH)<0 : Return : Endif

Local Char    EXPR_COND1(255)
Local Char    EXPR_COND2(255)
Local Integer IND_MVT_ATT_M
  IMPUT_INCH=G_NON

  If ACTTYPGES=GTAMUNI Then

    # Si on a des mvts en attente, on compare les données saisies avec celles du mvt en attente
    If IND_MVT_ATT >= 0 Then

      If  [M:PHYM]LOCD <>'' and [F:PHY]MVTLOC(IND_MVT_ATT)=[M:PHYM]LOCD Then
        IMPUT_INCH=G_OUI
      Endif
    # Sinon, on compare les données saisies avec celles de l'élément physique
    Elsif  [M:PHYM]LOCD <>'' and [F:TMP1]LOCO=[M:PHYM]LOCD Then
        IMPUT_INCH=G_OUI
    Endif
  Else
    IND_MVT_ATT_M = -1 # 49517 (SYMEU) : transfert site financier
    If evalue(CLASORI+"AASREF") <> "" Then
      For CPT = evalue("dim("+CLASORI+"MVT)")-1 To 0 Step -1
        If evalue(CLASORI+"MVT("+num$(CPT)+")") > 1 Then
          IND_MVT_ATT_M = CPT
          Break
        Endif
      Next CPT
      If IND_MVT_ATT_M >= 0 Then # 49517 (SYMEU) : transfert site financier
        EXPR_COND1 = CLASORI+"MVTGEO("+num$(IND_MVT_ATT_M)+") <>''"
        EXPR_COND1 +=" and "+CLASORI+"MVTLOC("+num$(IND_MVT_ATT_M)+") <> ''"
        EXPR_COND2 =" and "+CLASDES+"LOC"+SUFFDES+"="+CLASORI+"MVTLOC("+num$(IND_MVT_ATT_M)+")"
        Gosub CONT_INCH
        If IMPUT_INCH=G_OUI Then Return Endif
      Endif # 49517 (SYMEU) : transfert site financier
    Endif

    If IND_MVT_ATT_M < 0 Then # 49517 (SYMEU) : transfert site financier
      EXPR_COND1 = CLASDES+"LOC"+SUFFDES+"<>"+"''"    : EXPR_COND2 = CLASORI+"LOC"+SUFFORI+"="+CLASDES+"LOC"+SUFFDES
      Gosub CONT_INCH
      If IMPUT_INCH=G_OUI Then Return Endif
    Endif # 49517 (SYMEU) : transfert site financier
   Endif
Return


######################################################################################
$CONT_INCH

  If ((USE_PAR_VIDE=G_NON & evalue(EXPR_COND1)) | (USE_PAR_VIDE=G_OUI)) Then
    If evalue(EXPR_COND2) Then
      IMPUT_INCH=G_OUI
      Return
    Endif
  Endif
Return


######################################################################################
$AFFICHE_LIGNE

  Affzo [M:MPY0]CPY(nolign-1)
  Affzo [M:MPY0]OBJREF(nolign-1)
  Affzo [M:MPY0]PHYDES1(nolign-1)
Return


######################################################################################
# Contrôles pour savoir si les imputations d'un élément sont modifiées dans la       #
# fenêtre de contrôle                                                                #
######################################################################################
$CONTROLE_PHY_IMPUTATIONS_INCHANGEE_MPY
Local Integer IMPUTINCH
Local Char WFCY
Local Char WLOC
Local Char NOMZON

  WFCY    = [M:MPY0]FCY(nolign-1)
  WLOC    = [M:MPY0]LOC(nolign-1)

  If COUR<>"" Then
    NOMZON="W"+COUR : Assign NOMZON With VALEUR # On alimente la zone courante COUR - Wxxx avec Valeur
  Endif

  IMPUTINCH=G_OUI

  If WFCY<>[M:MPY0]FCYO(nolign-1) Then
    IMPUTINCH=G_NON
  Endif
  If IMPUTINCH=G_OUI Then
    If WLOC<>[M:MPY0]LOCO(nolign-1)       : IMPUTINCH=G_NON : Endif
  Endif

  # Imputations inchangées :

  # On arrive par le bouton "Erreur", on alimente TAB_ERR et NB_ERR
  If dim(BOUT_ERREUR)>0 Then
    If IMPUTINCH=G_OUI Then
      NBR_ERREUR+=1
      TAB_ZONERR(NBR_ERREUR-1)=""
      TAB_ERREUR(NBR_ERREUR-1)=mess(3,7775,1) # "Imputations inchangées pour ce bien"
    Endif
  Else
    If IMPUTINCH=G_OUI Then
      [M:MPY0]FLGERR(nolign-1)=G_OUI         : Affzo [M:MPY0]FLGERR(nolign-1)
      [M:MPY0]MSGERR(nolign-1)=mess(3,7775,1) : Affzo [M:MPY0]MSGERR(nolign-1)
    Else
      [M:MPY0]FLGERR(nolign-1)=G_NON         : Affzo [M:MPY0]FLGERR(nolign-1)
      [M:MPY0]MSGERR(nolign-1)=""            : Affzo [M:MPY0]MSGERR(nolign-1)
    Endif
    Gosub AFFICHE_LIGNE
  Endif
Return


######################################################################################
#-> Déclaration des variables nécessaires à l'appel du sous-programme de contrôle    #
# des imputations.                                                                   #
######################################################################################
$DECLARE_VAR_CONTROLE
Local  Date    TRFDAT
Local  Char    CPY
Local  Char    PHYREF
Local  Char    FCY
Local  Char    LOC(50)
Local  Integer RETOUR
Local  Integer I_ERREUR
Global Char    TAB_ZONERR(20)(30)
Global Char    TAB_ERREUR(100)(30)
Global Integer NBR_ERREUR

Return


######################################################################################
# Contrôle de la cohérence de la localisation géographique d'un élément physique.    #
# Les éléments de localisation sont passés en paramétre et le s/p renvoie un tableau #
# d'erreur, chaque occurrence du tableau correspondant à une erreur detectée.        #
#------------------------------------------------------------------------------------#
#-> Contrôles dans l'objet de visu / correction                                      #
######################################################################################
$CONTROLE_PHY_IMPUTATIONS_MPY

  Gosub DECLARE_VAR_CONTROLE

  TRFDAT = [M:MPY0]MVTDAT(nolign-1)
  CPY    = [M:MPY0]CPY(nolign-1)
  If COUR="FCY"    : FCY=VALEUR    : Else : FCY    = [M:MPY0]FCY(nolign-1)    : Endif
  If COUR="LOC"    : LOC=VALEUR    : Else : LOC    = [M:MPY0]LOC(nolign-1)    : Endif
  PHYREF=[M:MPY0]OBJREF(nolign-1)

  If dim(BOUT_ERREUR)>0 Then
    Gosub CONTROLE_PHY_IMPUTATIONS_INCHANGEE_MPY
  Endif

  If NBR_ERREUR>0 Then
    # Si on arrive ici par le choix erreur sur clique droit (Par CONTROLER), on affiche la liste des erreurs
    If dim (BOUT_ERREUR)>0 Then
      Local Char PARAM(30)(1..2)
      Local Char VALEUR
      PARAM(1)=[M:MPY0]OBJREF(nolign-1)
      Call TRAITE_CHAR(VALEUR,PARAM,"","TRTPHYTRFERR","PHYTRFERR",4,"") From GTRAITE
    Endif
    If [M:MPY0]FLGERR(nolign-1)=G_NON Then
      [M:MPY0]FLGERR(nolign-1)=G_OUI
      [M:MPY0]MSGERR=mess(6,7775,1) # "Erreur de localisation sur cet élément physique"
      Affzo [M:MPY0]CPY(nolign-1)
      Affzo [M:MPY0]OBJREF(nolign-1)
      Affzo [M:MPY0]PHYDES1(nolign-1)
    Endif
  Else
    If [M:MPY0]FLGERR(nolign-1)=G_OUI Then
      Raz [M:MPY0]MSGERR(nolign-1)
      [M:MPY0]FLGERR(nolign-1)=G_NON
      Affzo [M:MPY0]CPY(nolign-1)
      Affzo [M:MPY0]OBJREF(nolign-1)
      Affzo [M:MPY0]PHYDES1(nolign-1)
    Endif
  Endif
  Kill TAB_ZONERR, TAB_ERREUR, NBR_ERREUR
Return


# CBO 20110907 exigence 69691 ajout pour import des mvts
$IMP_MVT
Local Char WWIMPZON

    WWIMPZON = IMPZON

    Case IMPZON
        When "CCLTRF"
            If WNUM = G_OUI
                IMPMOD = 1
            Endif
#        When "DATTRANS"
#            If WDATE <> [M:FAS4]ISSDAT
#                IMPMOD = 1
#            Endif
        When "REN"
            If WCHAR <> ""
                IMPMOD = 1
            Endif
        When "FCYD"
            If  WCHAR <> "" and WCHAR <> [M:PHY0]FCY
                IMPMOD = 1
            Endif
        When "LOCD"
            If WCHAR <> "" and WCHAR <> [M:PHY1]LOC
                IMPMOD = 1
            Endif
        When Default
    Endcase

    # si champ ds la liste (et valorisé) : il a forcément été paramétré : donc modifié
    If IMPMOD <> 1
        If find(WWIMPZON, GRUBALIM(1..GNBRUBALIM))
            IMPMOD = 1
        Endif
    Endif

Return
######################################################################################
## Etiquettes ajoutées par le superviseur (écran PHYTRFP) 23/05/2008 12:34:29 (MABON)#
######################################################################################

######################################################################################
# Gestion de la case à cocher Annulation :                                           #
#    - Si on coche la case, on positionne les valeurs du transfert qu'on peut annuler#
#    - Si on décoche la case, on réinitialise les valeurs                            #
######################################################################################
Subprog AM_CCLTRF(VALEUR)
Variable Integer VALEUR

  Case VALEUR
    When G_OUI
      [M:PHYM]REN="" : Grizo [M:PHYM]REN
      # CBO 20120208 FQ69691B
      If ACTTYPGES=GTAMUNI or dim(GFXDINT) > 0
        Gosub LOAD_IMPUTATION_ORIGINE
        Grizo [M:PHYM]DATTRANS
        Grizo [M:PHYM]15
      Endif
    When G_NON
      # CBO 20110909 exigence 69691 ajout test pour import des mvts
      If GIMPORT <> 1

        [M:PHYM]REN="" : Actzo [M:PHYM]REN
        If ACTTYPGES=GTAMUNI
          Gosub LOAD_IMPUTATION_PHY
          Actzo [M:PHYM]DATTRANS
          Actzo [M:PHYM]15
        Endif
      Endif
  Endcase

  # Action CHGACTCRIT ne doit être exécutée qu'en massif. Pas d'impact sur la population en unitaire
  If ACTTYPGES=GTAMMAS
    Call ACTCHGCRIT() From TRCPROCOM
  Endif
End

################################################################################################################

Funprog SEARCH_TRANS(DATTR,EXIST_ONE_TRANS,TABLE)
Variable Integer EXIST_ONE_TRANS
Variable Date DATTR
Value Char TABLE
Local Date    DAT_ATT

  EXIST_ONE_TRANS=G_NON

  DAT_ATT=[0/0/0]
  # si l'elt physique est rattaché à un bco, on contrôle que la date de transfert est supérieure à la date
  # du dernier transfert en attente.
  If evalue(TABLE+"AASREF") <> "" Then
    For I= evalue("dim("+TABLE+"MVT)")-1  To 0 Step -1
      If evalue (TABLE+"MVT("+num$(I)+")") = GVMLPMVGEO Then : # Si on a un transfert en attente
        If DATTR <= evalue(TABLE+"MVTDAT("+num$(I)+")") Then
          DAT_ATT = evalue(TABLE+"MVTDAT("+num$(I)+")")
          If I>0  Then
            If evalue(TABLE+"MVTGEO("+num$(I)+")") <> evalue(TABLE+"MVTGEO("+num$(I-1)+")") Then
              EXIST_ONE_TRANS=G_OUI
              Break
            Endif
          Endif
        Endif
      Endif
    Next I
  Endif
  # On peut transférer à la même date que la date de réception que si un transfert n'existe pas déjà à cette date
  If SAUTRFDAT<>[0/0/0] or DAT_ATT<>[0/0/0] Then
    If SAUTRFDAT=evalue(TABLE+"DNUMRECEP") or DAT_ATT=evalue(TABLE+"DNUMRECEP") Then
      # on verifie qu'il s'agit d'un transfert de site
      If !clalev([F:EVT0]) : Local File EPHYAFFGEO [EVT0] : Endif
      Filter [F:EVT0] Where (CPY=evalue(TABLE+"CPY") & EVTINT="PHYAFFGEO" & REF=evalue(TABLE+"PHYREF") & EVTDAT=SAUTRFDAT & SNSEVE<>GVML_TEAACT &
&                     EVEANN=G_NON ) Order By Key EVE0 Desc
    Endif
    If clalev([F:EVT0]) : Close File [EVT0] : Endif
  Endif
End DAT_ATT


################################################################################################################
# Il faut que la date de transfert saisie soit strictement supérieure à la date du                             #
# dernier transfert validé pour l'élément ou à la date de reception ou à la plus grande date de mvt en attente #
################################################################################################################
Subprog AP_DATTRANS(VALEUR)
Variable Date    VALEUR
Local Date DAT_ATT
Local Integer EXIST_ONE_TRANS
Local Integer RETOUR

  If ACTTYPGES=GTAMUNI Then
    DAT_ATT=func TRTPHYTRF.SEARCH_TRANS(VALEUR,EXIST_ONE_TRANS,"[F:PHY]")

    # On prend la date max entre la date de dernier transfert effectif TRFDAT, la date du dernier transfert en attente MVTDAT
    # et la date de réception DNUMRECEP
    If DAT_ATT < [F:PHY]DNUMRECEP Then
      DAT_ATT = [F:PHY]DNUMRECEP
    Endif
    If DAT_ATT < SAUTRFDAT Then
      DAT_ATT = SAUTRFDAT
    Endif

    Actzo [M:PHYM]FCYD        # FQ 49517

    # On peut transférer un élt à la date de sa réception. Par contre, on ne peut pas avoir deux transferts à la même date
    If DAT_ATT=[F:PHY]DNUMRECEP and EXIST_ONE_TRANS=G_NON Then
      If VALEUR < DAT_ATT Then
        GMESSAGE = mess(42,7775,1)- num$(DAT_ATT)
        mkstat = 2
        GERR = 1
      Endif
    # On peut transférer en localisation un élt à la date de son dernier transfert.
    Elsif (DAT_ATT=SAUTRFDAT) and (VALEUR = DAT_ATT) and EXIST_ONE_TRANS = G_OUI Then
      # FQ55485
      #If GBCO_STATU = GVML_SBPRINC or GBCO_STATU = GVML_SBCOMPO Then
      #  GMESSAGE = mess(87,7775,1)-mess(88,7775,1)
      #  GERR = 1
      #  mkstat = 2
      #  End
      #Endif
      # FIN FQ55485
      If [M:PHYM]REN='' Then
        GMESSAGE = mess(40,7775,1)- num$(DAT_ATT)
        GERR = 1
      Endif
      Grizo [M:PHYM]FCYD      #FQ 49517
    Elsif VALEUR < DAT_ATT Then
      GMESSAGE = mess(42,7775,1)- num$(DAT_ATT)
      mkstat = 2
      GERR = 1
    Endif
  Endif
End


######################################################################################
# Emission de l'en-tête société dans la trace                                        #
######################################################################################
Subprog ET_COMPTE_RENDU(PCPY)
Value Char PCPY
Local Char LIGNE(130) # 49517 modif compte-rendu ancien 100

  If FLGDET=G_OUI & ACTSILENCE<>G_OUI Then
    Call ECR_TRACE(PCPY,GTRC_CRACTIO,"",0,1) From TRACEABX3
    # début 49517 modif compte-rendu
    # LIGNE="=================================================================================================" :  Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
    # LIGNE="  "+mess(6,3141,1)+"         "+mess(251,7773,1)+""                                                   :  Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
    # LIGNE="=================================================================================================" :  Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
    LIGNE=string$(114,"=") :  Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
    LIGNE=space$(2)+mess(6,3141,1)+space$(5)+mess(251,7773,1)+space$(34)+mess(143,7775,1) : Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
    LIGNE=string$(114,"=") :  Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
    # fin 49517 modif compte-rendu
  Endif
End


######################################################################################
# Emission des infos de mise à jour de l'élt physique dans la trace                  #
######################################################################################
Subprog PHY_COMPTE_RENDU(PCPY,PREF,PDES,PMES,PSITE,PLOC) # 49517 modif compte-rendu
Value Char PCPY
Value Char PREF
Value Char PDES
Value Char PMES
Value Char PSITE # 49517 modif compte-rendu
Value Char PLOC  # 49517 modif compte-rendu

  If FLGDET=G_OUI & ACTSILENCE<>G_OUI Then
    Local Char LIGNE(130)
    LIGNE =space$(2)
    # début 49517 modif compte-rendu
    # LIGNE+=left$(PREF+space$(23),23)
    # LIGNE+=left$(PDES+space$(70),70)
    LIGNE+=left$(PREF+space$(21),21)
    LIGNE+=left$(PDES+space$(46),46)
    LIGNE+=left$(PSITE+space$(6),6)
    LIGNE+=left$(PLOC+space$(38),38)
    # fin 49517 modif compte-rendu
    Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
  Endif
  If ACTSILENCE=G_OUI
    GT_OBJ_REF(I_OBJ)=PREF
    GT_OBJ_DES(I_OBJ)=PDES
    I_OBJ+=1
  Endif
End


######################################################################################
# S/p de lancement de l'action à partir du traitement                                #
# Réservé développement                                                              #
######################################################################################
Subprog LAUNCH_ACT(PACTTYP)
Value Char PACTTYP

  Case PACTTYP
    When "U"
      Raz GPILOBJ
      Call DEFVAR From GLOBIMM
      Call INIVAR From GLOBIMM
      Call OBJET("PHY",GBIDC1,GBIDC2) From GOBJET
    When "M"
      Local Char PARAM(30)(1..5)
      Local Char VALEUR
      PARAM(1)="M"              # Massif / unitaire
      PARAM(2)="PHYTRF"         # Nom de l'action métier
      PARAM(3)="6"              # Objet métier de référence PHY
      PARAM(4)=num$(1)          # Mono société              Non
      PARAM(5)=num$(1)          # Plan d'amortissement géré Non
      Call TRAITE_CHAR(VALEUR,PARAM,"","TRTPHYTRF","PHYTRFM",4,"") From GTRAITE
    When Default
  Endcase
End


######################################################################################
# Initialisation de la fenêtre paramètre des transferts                              #
######################################################################################
$INIT_WIN_PHYTRF
Local Integer EXIST_ONE_TRANS
Local Date    DAT_ATT

  Effzo [M:PHYM]

  #-> Initialisation de la société servant au filtrage de la liste des sites financiers
  #-> Initialisation du site géographique et de la localisation
  # Si l'élt a des mvts en attente, on charge les infos du dernier transfert, sinon, on charge les infos de l'élt

  # CBO 20110907 exigence 69691 ajout pour import des mvts
  # ajout de or dim(GFXDINT) > 0
  If ACTTYPGES=GTAMUNI or dim(GFXDINT) > 0 Then
    [M:PHYM]CPYP    = [F:PHY]CPY
    # [M:PHYM]FCYD    = [F:PHY]FCY # FQ49517

    [M:PHYM]FCYO    = [F:PHY]FCY
    [M:PHYM]LOCO    = SAULOCO
    If GREP='M' and [M:PHY1]MVTTR<>""
      [M:PHYM]FCYD    = [M:PHY0]FCY   # FQ49517
      [M:PHYM]LOCD    = [M:PHY1]LOC
      [M:PHYM]TRFDAT  = [M:PHY1]TRFDAT
    Else
      [M:PHYM]FCYD    = SAUFCYD       # FQ49517
      [M:PHYM]LOCD    = SAULOCD
      [M:PHYM]TRFDAT  = SAUTRFDAT
    Endif
    #-> Initialisation de la date de transfert et du motif de transfert et du témoin d'annulation
    [M:PHYM]CCLTRF=G_NON

    # début 49517 (SYMEU) : quand on abandonne après avoir coché Annulation, les zones restaient grisées
    Actzo [M:PHYM]DATTRANS
    Actzo [M:PHYM]REN
    Actzo [M:PHYM]FCYD
    Actzo [M:PHYM]LOCD
    # fin 49517 (SYMEU) : quand on abandonne après avoir coché Annulation, les zones restaient grisées

    If GREP='M' and [M:PHY1]MVTTR<>"" Then
      If [M:PHY1]TRFDAT<>[0/0/0] Then
        [M:PHYM]DATTRANS=[M:PHY1]TRFDAT
      Else
        [M:PHYM]DATTRANS=date$
      Endif
      [M:PHYM]REN = [M:PHY1]MVTTR
      DAT_ATT=func TRTPHYTRF.SEARCH_TRANS([M:PHYM]DATTRANS,EXIST_ONE_TRANS,"[F:PHY]")
      If EXIST_ONE_TRANS=G_OUI and [M:PHYM]DATTRANS=DAT_ATT Then
      Endif
      [M:PHYM]CCLTRF = [M:PHY1]CCLMVT
      If [M:PHYM]CCLTRF=G_OUI Then
        Grizo [M:PHYM]DATTRANS
        Grizo [M:PHYM]REN
        Grizo [M:PHYM]15
        [M:PHYM]TRFDAT  = [F:PHY]TRFDAT
      Endif
    Else
      [M:PHYM]DATTRANS=date$
      Raz [M:PHYM]REN
    Endif

    [M:PHY1]LOCO    = [F:PHY]LOC
    [M:PHY1]LOC     = [F:PHY]LOC
    [M:PHY1]MVTTR   = ''
    [M:PHY1]CCLMVT  = 0
    [M:PHY1]TRFDAT  = [F:PHY]TRFDAT
    [M:PHY1]ANNDAT  = [0/0/0]

    #-> Activation / désactivation du flag d'annulation en unitaire (toujours modifiable en massif)
    Local Integer IS_CANCELABLE : IS_CANCELABLE=1

    # Annulation impossible s'il n'y a pas eu de transfert
    If [M:PHYM]TRFDAT=[0/0/0] Then
      If GREP='M' and [M:PHYM]CCLTRF=G_OUI Then
      Else
        IS_CANCELABLE=0
      Endif
    Endif

    # Annulation impossible si le dernier transfert a été réalisé dans un exercice antérieur à l'exercice courant
    # pour tous les contextes gérés dans la société de l'élément
    If IS_CANCELABLE Then
      Local Date    CPYSTRFIY(1..G300MAX)
      Local Date    CPYENDFIY(1..G300MAX)
      Local Date    CPYSTRPER(1..G300MAX)
      Local Date    CPYENDPER(1..G300MAX)
      Local Integer RETOUR
      Local Integer I_CPY
      Local Integer I_CNX
      Local Integer NBR_CPY

      Call GET_CPY_DAT([M:PHY0]CPY,CPYSTRFIY,CPYENDFIY,CPYSTRPER,CPYENDPER,RETOUR) From GLOBIENS
      For I_CNX=1 To G300MAX
        If CPYSTRFIY(I_CNX)<>[0/0/0] & [M:PHYM]TRFDAT<CPYSTRFIY(I_CNX) Then
          IS_CANCELABLE=0
          Break
        Endif
      Next I_CNX
    Endif

    # Annulation impossible si pas d'événement permettant de retrouver la situation antérieure
    If IS_CANCELABLE Then
      If func TRTPHYTRFHIS.GET_PLN_EVE_TRF([M:PHY0]CPY,[M:PHY0]FCY,[M:PHY0]PHYREF,[M:PHYM]TRFDAT) Then
        IS_CANCELABLE=1
      Else
       IS_CANCELABLE=0
      Endif
    Endif

    # Activation ou grisage de CCLTRF
    If IS_CANCELABLE Then
      Actzo [M:PHYM]CCLTRF
    Else
      Grizo [M:PHYM]CCLTRF
    Endif
  Endif

  #--> Grisage des zones non saisissables en fonction du code option G(éographique)
  Local Integer AUZGEO
  Local Char    CPY
  Local Char    FCY

  If ACTTYPGES=GTAMUNI Then
    CPY=[M:PHY0]CPY
    FCY=[M:PHY0]FCY
    Call GET_AUZ_GEO(nomap,GUSER,CPY,FCY,AUZGEO)
  Elsif ACTTYPGES=GTAMMAS
    # En massif, seules les sociétés cochées figurent dans le tableau
    AUZGEO=G_OUI
  Endif
  If AUZGEO=G_NON Then
    Grizo [M:PHYM]FCYD
    Grizo [M:PHYM]LOCD
  Endif
  If [M:PHYM]LOCD = mess(44,7775,1) Then  #si loc = "ATTENTE" on vide la zone
    [M:PHYM]LOCD=""
    Affzo [M:PHYM]LOCD
  Endif

  #--> Réaffichage du masque paramètre et positionnement à non valide pour forcer tous les contrôles
  Affzo  [M:PHYM]
  Setmok [M:PHYM] With 0
Return


######################################################################################
# Récupération des autorisations par type de transfert géo                           #
######################################################################################
Subprog GET_AUZ_GEO(PAPPLI,PUSER,PCPY,PFCY,RAUZGEO)
Value    Char    PAPPLI    # Dossier pour lequel on souhaite connaitre les habilitations
Value    Char    PUSER     # Code utilisateur pour lequel on souhaite connaître la valeur des codes options A et G
Value    Char    PCPY      # Société pour laquelle on souhaite connaitre la valeur des codes options A et G
Value    Char    PFCY      # Site pour lequel on souhaite connaitre la valeur des codes options A et G
Variable Integer RAUZGEO   # Valeur du code option G (G_OUI ou G_NON) pour l'utilisateur PUSER dans le dossier PAPPLI

  If clalev([F:AUS])=0  : Local File =PAPPLI+".AUTILIS"    [AUS]  : Endif : # Utilisateurs
  If clalev([F:AFT])=0  : Local File =PAPPLI+".AFCTFCT"    [AFT]  : Endif : # Habilitations fonctionnelles
  If clalev([F:AFP])=0  : Local File =PAPPLI+".AFCTPRF"    [AFP]  : Endif : # Habilitations fonctionnelles
  If clalev([F:CPY])=0  : Local File =PAPPLI+".COMPANY"    [CPY]  : Endif : # Sociétés
  If clalev([F:AWI])=0  : Local File =PAPPLI+".AWINDOW"    [AWI]  : Endif : # fenêtre
  If clalev([F:AMK])=0  : Local File =PAPPLI+".AMSK"       [AMK]  : Endif : # masques
  If clalev([F:AMZ])=0  : Local File =PAPPLI+".AMSKZON"    [AMZ]  : Endif : # champs des masques
  If clalev([F:FGR])=0  : Local File =PAPPLI+".FACGROUP"   [FGR]  : Endif : # Groupe de société

  Local Char PRFFCT                    # Profil fonction associé à l'utilisateur
  Local Char SEAFCT : SEAFCT="GESPHY"  # Fonction pour laquelle on charche les valeurs de code option
  Local Char OPTANA : OPTANA="A"       # Code de l'option transfert analytique
  # FQ55556 - MABON - 04/05/09 - Déclaration de OPTGEO utilisé dans GET_AUZ_GEO
  Local Char OPTGEO : OPTGEO="G"       # Code de l'option transfert géographique

  # Initialisation des valeurs de retour
  RAUZGEO = G_OUI
  PRFFCT  = GPROFIL

  # Recherche si la transaction de saisie bien comptable fait apparaître ou non toutes les zones
  Read [AWI]AWI0=G_TRSSAV
  If !fstat Then
    Local Integer I_MSK
    For I_MSK=0 To [F:AWI]NBMSK-1
      Read [AMK] =[F:AWI]NOMMSK(I_MSK)
    Next I_MSK
    If dim(NOMMSKFAS2)>0 & NOMMSKFAS2<>"" Then
      Read [AMZ]CODE=NOMMSKFAS2;"LOC"    : If !fstat & [F:AMZ]SAIAFF>2 : RAUZGEO=G_NON : Endif
      Read [AMZ]CODE=NOMMSKFAS2;"AASBUS" : If !fstat & [F:AMZ]SAIAFF>2 : RAUZANA=G_NON : Endif
      Read [AMZ]CODE=NOMMSKFAS2;"IASCGU" : If !fstat & [F:AMZ]SAIAFF>2 : RAUZANA=G_NON : Endif
      Read [AMZ]CODE=NOMMSKFAS2;"SCT1"   : If !fstat & [F:AMZ]SAIAFF>2 : RAUZANA=G_NON : Endif
      Read [AMZ]CODE=NOMMSKFAS2;"SCT2"   : If !fstat & [F:AMZ]SAIAFF>2 : RAUZANA=G_NON : Endif
      Read [AMZ]CODE=NOMMSKFAS2;"DSP"    : If !fstat & [F:AMZ]SAIAFF>2 : RAUZANA=G_NON : Endif
      Read [AMZ]CODE=NOMMSKFAS2;"CCE"    : If !fstat & [F:AMZ]SAIAFF>2 : RAUZANA=G_NON : Endif
    Endif
  Endif

  If RAUZGEO=G_NON
    End
  Endif

  # Recherche si le profil autorise toutes fonctions
  Read [AFT]AFT0=PRFFCT
  If !fstat Then
    If [F:AFT]ALLFCT=G_OUI : End : Endif
  Else
    RAUZGEO=G_NON
  Endif

  # Accès à AFP car le profil n'autorise pas toutes les fonctions.
  # Premier essai en utilisant la société passée en paramétre
  Read [AFP]AFP0=PRFFCT;SEAFCT;PCPY
  If !fstat Then
    If pat([F:AFP]OPT,"*"+OPTGEO+"*")=0 : RAUZGEO=G_NON : Endif
    End
  Endif

  # Deuxième essai en utilisant le site passé en paramétre
  Read [AFP]AFP0=PRFFCT;SEAFCT;PFCY
  If !fstat Then
    If !pat([F:AFP]OPT,"*"+OPTGEO+"*") : RAUZGEO=G_NON : Endif
    End
  Endif

  # Dernier essai en utilisant blanc dans le regroupement
  Read [AFP]AFP0=PRFFCT;SEAFCT;""
  If !fstat Then
    If !pat([F:AFP]OPT,"*"+OPTGEO+"*") : RAUZGEO=G_NON : Endif
    End
  Endif

  # Recherche si la société fait partie d'un groupe de société pour lequel l'habilitation est positionné
  Filter [FGR] Where FCY=PFCY
  For [FGR]
    Read [AFP]AFP0=PRFFCT;SEAFCT;[F:FGR]CPY
    If !fstat Then
      If !pat([F:AFP]OPT,"*"+OPTGEO+"*") : RAUZGEO=G_NON : Endif
      End #CHECK IGNORE_LINE
    Endif
  Next
  Filter [FGR]

  # Recherche infructueuse, on renvoie G_NON
  RAUZGEO=G_NON
End


######################################################################################
# Application des paramétres à une zone passée en paramètre                          #
######################################################################################
Subprog APPL_ZONE(PCLASSE,PZONE,PCLASSEP,PZONEP,PPARVIDE,RET)
Value    Char    PCLASSE      # Classe à mettre à jour
Value    Char    PZONE        # Zone à modifier
Value    Char    PCLASSEP     # Classe paramètre
Value    Char    PZONEP       # Zone paramètre
Value    Integer PPARVIDE     # Indique si un paramétre vide doit être pris en compte
Variable Integer RET          # Code retour

Local    Char    NOMZONE

  If ((PPARVIDE=G_NON & evalue(PCLASSEP+PZONEP+"<>''")) | (PPARVIDE=G_OUI)) Then
    If evalue(PCLASSE+PZONE+"<>"+PCLASSEP+PZONEP) Then
      NOMZONE=PCLASSE+PZONE
      Assign NOMZONE With evalue(PCLASSEP+PZONEP)
    Endif
  Endif
End


