######################################################################################
## Etiquette ajoutée par le superviseur (écran PHYTRFP) 02/06/2008 10:00:27 (STANT)
######################################################################################
Subprog AS_LOCD(VALEUR)
Variable Char    VALEUR()

  # on filtre la table des localisations pour enlever la valeur déjà saisie
  # pour cela on court circuite la gestion auto en enlevant les paramètre du type BCL
  # et on gère le site géographique à la main.
  TRFSELLOC = " LOCCOD <>'"+ VALEUR +"'"
End

######################################################################################



######################################################################################
# Sous pro permettant d'annuler l'événement de transfert : cela revient à créer un   #
# événement PHYAFFGEO, avec le champ SNSEVE à 2 (annulation)                         #
######################################################################################
Subprog ANNULE_EVE_TRANS(ANNDAT,ORIPHY)
Value Date    ANNDAT
Value Integer ORIPHY
Local Integer RETOUR
Local Char    TIMSTP_A

  # On ferme EVT0 car si on vient d'un transfert de biens, la table EVT0 contient la table des évts de transfert des biens
  If clalev([F:EVT0]) : Close File [EVT0] : Endif
  If !clalev([F:EVT0]) : Local File EPHYAFFGEO [EVT0] : Endif

  If clalev([F:EVT1]) : Close File [EVT1] : Endif
  If !clalev([F:EVT1]) : Local File EPHYAFFGEO [EVT1] : Endif
  If !clalev([F:EVT2]) : Local File EPHYAFFGEO [EVT2] : Endif

  If ORIPHY <> G_OUI Then
    # MABON - FQ49517 - 18/05/09 - Transfert de site financier
    # Si on vient du transfert des biens, en sélectionnant uniquement les evts
    # dont EVTDAT=ANNDAT, on ne va pas annuler un transfert de localisation
    # si celui-ci a eu lieu après le transfert de site : il faut donc faire
    # une modif de façon à sélectionner aussi les évts réalisés après ANNDAT.
    # On exécute donc la requête en sélectionnant tous les evts >= à ANNDAT
    Filter [F:EVT0] Where (CPY=[F:PHY]CPY & EVTINT="PHYAFFGEO" & REF=[F:PHY]PHYREF & EVTDAT>=ANNDAT & SNSEVE<>GVML_TEAACT) Order By Key EVE0 Desc
    For [F:EVT0]EVE0
      If func GENEVE.EXISTE_EXTOURNE_EVE(RETOUR)=G_NON Then
        Update [F:EVT2] Where REF=[F:PHY]PHYREF and TIMSTP=[EVT0]TIMSTP With EVEANN=G_OUI
#        Call EXTOURNE_EVE(GVMLOMPHY,[F:PHY]CPY,[F:PHY]FCY,[F:PHY]PHYREF,0,"PHYAFFGEO",ANNDAT,RETOUR) From GENEVE # 49517
        Call EXTOURNE_EVE(GVMLOMPHY,[F:PHY]CPY,[F:PHY]FCY,[F:PHY]PHYREF,0,"PHYAFFGEO",[F:EVT0]EVTDAT,RETOUR) From GENEVE
      Endif
    Next
    Filter [EVT0]
  Else
    TIMSTP_A = func TRTPHYTRFHIS.GET_EVE([F:PHY]CPY,"",[F:PHY]PHYREF,ANNDAT,RETOUR)
    Read [F:EVT0]EVE0=[F:PHY]PHYREF;TIMSTP_A
    # début 49517
    If [F:EVT0]FCY <> [F:EVT0]FCYD and [F:EVT0]FCYD <> "" Then
      Filter [F:EVT0] Where (CPY=[F:PHY]CPY & EVTINT="PHYAFFGEO" & REF=[F:PHY]PHYREF & EVTDAT=ANNDAT & SNSEVE<>GVML_TEAACT) Order By Key EVE0 Desc
      For [F:EVT0]EVE0
        If func GENEVE.EXISTE_EXTOURNE_EVE(RETOUR)=G_NON Then
          Update [F:EVT2] Where REF=[F:PHY]PHYREF and TIMSTP=[EVT0]TIMSTP With EVEANN=G_OUI
         Call EXTOURNE_EVE(GVMLOMPHY,[F:PHY]CPY,[F:PHY]FCY,[F:PHY]PHYREF,0,"PHYAFFGEO",ANNDAT,RETOUR) From GENEVE
        Endif
      Next
      Filter [EVT0]
    Else
    # fin 49517
      # On met à jour l'évt à annuler, en positionnant le flag EVEANN à G_OUI => on sait ainsi que cet évt est annulé,
      # et on n'essaiera plus de l'annuler (problème des évts à la même date)
      Update [F:EVT0] Where REF=[F:PHY]PHYREF and TIMSTP=TIMSTP_A With EVEANN=G_OUI
      # Puisqu'on gère le champ EVEANN, on n'a plus besoin d'appeler EXISTE_EXTOURNE_EXE
      Call EXTOURNE_EVE(GVMLOMPHY,[F:PHY]CPY,[F:PHY]FCY,[F:PHY]PHYREF,0,"PHYAFFGEO",ANNDAT,RETOUR) From GENEVE
    Endif # 49517
  Endif
End


######################################################################################
# Sous pro mettant à jour les tableaux de mouvements en attente dans la table,       #
# lorsqu'on ajoute un mouvement de transfert
# 49517 (SYMEU) : transfert de site financier : ajout du paramètre FCYD              #
######################################################################################
Subprog MAJ_MVT_TRANS_ATT_FILE(CCLTRF,TRFDAT,FCYD,LOCD,REN) # 49517
Value Integer CCLTRF
Value Date    TRFDAT
Value Char    FCYD      # 49517
Value Char    LOCD
Value Char    REN
Local Integer I

  I=0
  While (I<=dim([F:PHY]MVT)-1) and ([F:PHY]MVT(I)>1)
    I += 1
  Wend
  If CCLTRF = G_OUI Then
    [F:PHY]MVT(I)      = GVMLPMVAGEO : # Annulation de transfert géographique
    [F:PHY]MVTDAT(I)   = TRFDAT
    [F:PHY]MVTFCY(I)   = FCYD # 49517
    [F:PHY]MVTLOC(I)   = LOCD
  Else
    [F:PHY]MVT(I)      = GVMLPMVGEO  : # Transfert géographique
    [F:PHY]MVTDAT(I)   = TRFDAT
    [F:PHY]MVTFCY(I)   = FCYD # 49517
    [F:PHY]MVTLOC(I)   = LOCD
    [F:PHY]MVTTRANS(I) = REN
  Endif
End


###########################################################################################
# Sous pro effectuant le transfert d'un élément physique                                  #
# Crée également l'événement de transfert, ou d'annulation de transfert                   #
# PARAMETRES :                                                                            #
#   - CCLMVT : indicateur d'annulation, égal à G_OUI ou G_NON                             #
#   - PHYREF : référence de l'élément à transférer                                        #
#   - FCYO   : Site financier d'origine  # 49517 (SYMEU) : transfert site financier       #
#   - FCYD   : Site financier de destination                                              #
#   - LOCO   : localisation d'origine de l'élément à transférer                           #
#   - LOCD   : localisation de destination de l'élément à transférer                      #
#   - TRFDAT : date de transfert de l'élément, renseignée si CCLMVT=G_NON (pas annul)     #
#   - ANNDAT : date de transfert annulée de l'élément, renseignée si CCLMVT=G_OUI         #
#   - ORIPHY : indique si l'on vient des élément physique ou des biens                    #
#  (1,3= BIEN, 2= ELTPHY) lorsqu'on vient des biens il faut mettre à jour la table eltphy #
###########################################################################################
Subprog TRANS_ELT(CCLMVT, PHYREF,FCYO, FCYD, LOCO, LOCD, TRFDAT, ANNDAT, ORIPHY) # 49517
Value Integer CCLMVT
Value Char PHYREF
Value Char FCYO  # 49517 (SYMEU) : transfert site financier
Value Char FCYD
Value Char LOCO
Value Char LOCD
Value Date TRFDAT
Value Date ANNDAT
Value Integer ORIPHY
Global Char   WFCY(GLONFCY) # 49517
Local Integer LCDRET
Local Char    FCYORI
Local Char    LOCORI
Local Date    TRFDATORI
Local Char    RMVTTRORI
Local Integer RETOUR
Local Integer I, WDIM_ELT_PHY, OK
Local Integer CONTINUE
Local Integer WTRANSFERT_OK  # flag pour dire si le transfert a été effectué
Local Integer WB_REWRITE # Boolean réécriture

  WB_REWRITE = 0
  If !clalev([F:PHY]) : Local File PHYELT    [PHY] : Endif

  Readlock [PHY]PHY0=PHYREF
  If !fstat Then
    # Pour interdire toute modification sur l'objet
    LLOCK = func GLOBIENS.GET_KEY_PHYELT (PHYREF)
    If ( func GLOBIENS.IS_SYMBOLE_LOCKED ("PHY", [F:PHY]CPY, LLOCK) = 0 ) Then
      # Test si la société est verrouillée sur cette table pour en empêcher la modification
      OK = -1 : GERR=1 : GMESSAGE = mess(60,100,1)-":"-[F:PHY]PHYREF
      GOK=0
      End
    Elsif !fstat Then
      # Cas d'une demande de transfert
      If CCLMVT=G_NON Then
        If !clalev([F:PHYO]) : Local File PHYELT [PHYO] : Endif
        If !clalev([F:PHYD]) : Local File PHYELT [PHYD] : Endif

        # Ces 4 lignes suivantes servent pour renseigner les sites et loc d'origine dans l'evt de transfert PHYAFFGEO
        [F:PHYO]LOC    = LOCO
        [F:PHYD]LOC    = LOCD
        [F:PHYD]FCY    = FCYD # 49517 (SYMEU) : transfert site financier
        [F:PHYO]FCY    = FCYO # 49517 (SYMEU) : transfert site financier

        # début 49517 : transfert site financier
        # Lorsqu'il n'y a pas de tranfert entre sites financiers, le champ FCYD est vide, sinon il contient le
        # site de destination, ce qui permet de distinguer les différents cas de figure.
        If [F:PHYO]FCY <> [F:PHYD]FCY
          WFCY = [F:PHYD]FCY
        Else
          WFCY = ""
        Endif
        # fin 49517 : transfert site financier

        # Si la localisation actuelle de l'élément est différente de la nouvelle localisation, on crée l'événement de transfert
        If [F:PHY]LOC <> LOCD Then
           # Création des événement sur le site financier destination
           Call GENER_EVE (GVMLOMPHY, [F:PHY]CPY, [F:PHYD]FCY, PHYREF, 0, "PHYAFFGEO", TRFDAT, [0/0/0], LCDRET ) From GENEVE
           If (LCDRET > 20) Then
             GOK = 0
             Call FSTA("EPHYAFFGEO") From GLOCK
             End
           Endif
           WTRANSFERT_OK = G_OUI

           # début FQ 49517 --------------------------------------------------------
           # S'il y a transfert de site financier, on va créer un deuxième jeu d'événement
           If [F:PHYO]FCY <> [F:PHYD]FCY Then
             Call GENER_EVE(GVMLOMPHY,[F:PHY]CPY,[F:PHYO]FCY,PHYREF,0,"PHYAFFGEO",TRFDAT,[0/0/0],LCDRET) From GENEVE
             If (LCDRET > 20)
               GOK = 0
               Call FSTA("EPHYAFFGEO") From GLOCK
               End
             Endif
           Endif
           # fin FQ 49517 --------------------------------------------------------
        Else
           WTRANSFERT_OK = G_NON
        Endif

        # Si oriphy <> G_OUI on fait la mise à jour dans la table PHY
        # Si oriphy =3 on ne fait que le 1er transfert en attente et on supprime les attentes de transfert ou annulation de transfert suivantes
        # car on a changé les paramètres de transfert par rapport à l'élément en attente de transfert

        # FQ88137 en relevé d'inventaire ACTTYPGES n'existe pas
        # et la partie du test le concernant ne peut jamais être vraie (ORIPHY = 1)
        # donc déclaration si n'existe pas
        # FQ88833 ne pas créer la var ACTTYPGES : fait planter en batch
        # test fait avec la var CONTINUE qui adapte le test en fct de l'existence de ACTTYPGES
        CONTINUE = G_NON
        If dim(ACTTYPGES) < 0
#          Global Char ACTTYPGES
          If ORIPHY <> G_OUI and WTRANSFERT_OK = G_OUI Then
            CONTINUE = G_OUI
          Endif
        Else
          If ORIPHY <> G_OUI and (WTRANSFERT_OK = G_OUI or (ACTTYPGES=GTAMUNI and WTRANSFERT_OK = G_NON and ORIPHY = 3)) Then
            CONTINUE = G_OUI
          Endif
        Endif
        If CONTINUE = G_OUI
          GOK=1
          If WTRANSFERT_OK = G_OUI Then
              [F:PHY]FCY = FCYD
              [F:PHY]LOC    = LOCD
              [F:PHY]TRFDAT = TRFDAT
              WB_REWRITE = 1
          Endif
          WDIM_ELT_PHY = dim([F:PHY]MVTDAT)
          If WDIM_ELT_PHY <> 0  and ([F:PHY]MVT(0) = GVMLPMVGEO or [F:PHY]MVT(0) = GVMLPMVAGEO) Then
             CONTINUE = G_OUI
             While CONTINUE = G_OUI
               If [F:PHY]MVT(0) = GVMLPMVGEO or [F:PHY]MVT(0) = GVMLPMVAGEO Then
                 For I = 0 To WDIM_ELT_PHY-1
                 # On tasse les éléments qui suivent
                   If I = WDIM_ELT_PHY-1 Then
                     [F:PHY]MVTDAT(I)   = [0/0/0]
                     [F:PHY]MVT(I)      = GVMLPMVNONE
                     [F:PHY]MVTTRANS(I) = ""
                     [F:PHY]MVTFCY(I)   = "" # 49517
                     [F:PHY]MVTLOC(I)   = ""
                   Else
                     # Si oriphy =3 on ne fait que le 1er transfert en attente et on supprime les attentes de
                     # transfert ou annulation de transfert suivantes
                     [F:PHY]MVTDAT(I)   = [F:PHY]MVTDAT(I+1)
                     [F:PHY]MVT(I)      = [F:PHY]MVT(I+1)
                     [F:PHY]MVTTRANS(I) = [F:PHY]MVTTRANS(I+1)
                     [F:PHY]MVTFCY(I)   = [F:PHY]MVTFCY(I+1) # 49517
                     [F:PHY]MVTLOC(I)   = [F:PHY]MVTLOC(I+1)

                     If ORIPHY <> 3 Then
                        CONTINUE = G_NON
                     Endif
                   Endif
                   WB_REWRITE = 1
                 Next I
               Else
                 CONTINUE = G_NON
               Endif
             Wend
          Endif
          If WB_REWRITE Then
             Rewrite [F:PHY]
             If fstat Then
                GOK=0
             Endif

             Call MAJ_LOC_BIEN ([F:PHY]PHYREF, [F:PHY]AASREF, [F:PHY]LOC) : # FQ62267
          Endif
        Endif
      Endif

      # Cas d'une demande d'annulation de transfert : on annule l'événement PHYAFFGEO

      If CCLMVT=G_OUI Then
        Call ANNULE_EVE_TRANS(ANNDAT,ORIPHY)
        If ORIPHY <> G_OUI  Then
          # Récupération des imputations d'origine du bien
          # début 49517 (SYMEU) : transfert site financier
         Call GET_IMPUT_ORI_FAS([F:PHY]CPY,[F:PHY]FCY,[F:PHY]PHYREF,ANNDAT,
&                           FCYORI,LOCORI,TRFDATORI,RMVTTRORI,RETOUR) From TRTPHYTRFHIS
          If FCYD <> FCYO Then
            Call GET_IMPUT_ORI_FAS_ANNUL([F:PHY]CPY,[F:PHY]FCY,[F:PHY]PHYREF,ANNDAT,
&                            FCYORI,LOCORI,TRFDATORI,RMVTTRORI,RETOUR) From TRTPHYTRFHIS
          Else
            Call GET_IMPUT_ORI_FAS([F:PHY]CPY,[F:PHY]FCY,[F:PHY]PHYREF,ANNDAT,
&                            FCYORI,LOCORI,TRFDATORI,RMVTTRORI,RETOUR) From TRTPHYTRFHIS
          Endif
          # fin 49517 (SYMEU) : transfert site financier

          # Si on n'a pas retrouvé l'imputation d'origine on sort sans mettre à jour l'élément physique
          If RETOUR = G_NON Then
             End
          Endif
          # Report de l'imputation d'origine du bien dans l'élément physique
          [F:PHY]TRFDAT = TRFDATORI
          [F:PHY]FCY = FCYORI
          [F:PHY]LOC    = LOCORI

          # Si on a annulé un transfert et s'il y a des mouvements de transfert en attente qui suivent, il faut
          # annuler ces transferts en attente
          WDIM_ELT_PHY = dim([F:PHY]MVTDAT)
          If WDIM_ELT_PHY <> 0  and ([F:PHY]MVT(0) = GVMLPMVAGEO or [F:PHY]MVT(0) = GVMLPMVGEO) Then
             OK = G_OUI
             While OK = G_OUI
                If [F:PHY]MVT(0) = GVMLPMVAGEO or [F:PHY]MVT(0) = GVMLPMVGEO Then
                   For I = 0 To WDIM_ELT_PHY-1
                      # On tasse les éléments qui suivent
                      If I = WDIM_ELT_PHY-1 Then
                         [F:PHY]MVTDAT(I)   = [0/0/0]
                         [F:PHY]MVT(I)      = GVMLPMVNONE
                         [F:PHY]MVTTRANS(I) = ""
                         [F:PHY]MVTFCY(I)   = "" # 49517
                         [F:PHY]MVTGEO(I)   = ""
                         [F:PHY]MVTLOC(I)   = ""
                      Else
                         [F:PHY]MVTDAT(I)   = [F:PHY]MVTDAT(I+1)
                         [F:PHY]MVT(I)      = [F:PHY]MVT(I+1)
                         [F:PHY]MVTTRANS(I) = [F:PHY]MVTTRANS(I+1)
                         [F:PHY]MVTFCY(I)   = [F:PHY]MVTFCY(I+1) # 49517
                         [F:PHY]MVTGEO(I)   = [F:PHY]MVTGEO(I+1)
                         [F:PHY]MVTLOC(I)   = [F:PHY]MVTLOC(I+1)
                      Endif
                   Next I
                Else
                   OK = G_NON
                Endif
             Wend
          Endif
          Rewrite [F:PHY]
          If fstat Then
            GOK = 0
          Endif

          Call MAJ_LOC_BIEN ([F:PHY]PHYREF, [F:PHY]AASREF, [F:PHY]LOC) : # FQ62267
        Endif
      Endif
    Endif
  Endif
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran PHYTRFM) 03/07/2008 17:05:33 (MABON)
######################################################################################
Subprog AV_FCYD(VALEUR)
Variable Char    VALEUR()

  If varmode([M:PHYM]DATTRANS)=0
    If ACTTYPGES=GTAMMAS Then
      Call GER_GEO("FCYD",0,0)
    Endif
  Endif
End
######################################################################################

Subprog GER_GEO(PZONE,PINIT,PINDICE)
Value Char    PZONE
Value Integer PINIT
Value Integer PINDICE

Local Integer I_CPY
Local Integer NB_CPY : NBR_CPY=PINIT

  For I_CPY=1 To [M:MHC]NBCPY
    If [M:MHC]FLGCPY(I_CPY-1)=G_OUI & I_CPY<>PINDICE Then
      NBR_CPY+=1
    Endif
  Next I_CPY

  If NBR_CPY=1 Then
    Actzo [M:PHYM]=PZONE
    If evalue("dim([M:PHYM]Z"+PZONE+")>0") Then
      Actzo [M:PHYM]="Z"+PZONE
    Endif
  Else
    Effzo [M:PHYM]=PZONE
    Grizo [M:PHYM]=PZONE
    If evalue("dim([M:PHYM]Z"+PZONE+")>0") Then
      Effzo [M:PHYM]="Z"+PZONE
      Actzo [M:PHYM]="Z"+PZONE
    Endif
  Endif
End

######################################################################################

Subprog C_FCYD(VALEUR)
Variable Char    VALEUR()

  # En unitaire, le site financier ne peut être vide
  If ACTTYPGES=GTAMUNI & VALEUR="" Then
    GERR=1
    GMESSAGE=mess(10,123,1)
    mkstat=2
  Endif

  # En massif et en unitaire, le site financier doit toujours être cohérent avec la société sélectionnée s'il y en a une.
  If ACTTYPGES=GTAMMAS | ACTTYPGES=GTAMUNI Then
    If VALEUR<>"" Then
      If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
      Read [FCY]FCY0=VALEUR
      If !fstat Then
        If [M:PHYM]CPYP<>[F:FCY]LEGCPY Then
          GERR=1
          If ACTTYPGES=GTAMMAS Then
            GMESSAGE=mess(353,7773,1)-" :"-[M:PHYM]CPYP # "Site incompatible avec la société sélectionnée"
          Elsif ACTTYPGES=GTAMUNI Then
            GMESSAGE=mess(354,7773,1)-" :"-[M:PHYM]CPYP # Site financier incompatible avec la société du bien
          Endif
          mkstat=2
          End
        Endif
      Endif
    Endif
  Endif
End
######################################################################################

Subprog AM_FCYD(VALEUR)
Variable Char    VALEUR()

  #> Critère de sélection si annulation
  If [M:PHYM]CCLTRF=G_OUI Then Call ACTCHGCRIT() From TRCPROCOM : Endif

  #> Affectation du site par défaut dès qu'une société est saisie
  If VALEUR<>"" Then
    If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
    Read [FCY]FCY0=VALEUR
    If !fstat Then
      [M:PHYM]CPYP=[F:FCY]LEGCPY
    Endif
  Endif


End

######################################################################################
# Il faut sélectionner au maximum un site financier (pas de transfert de site        #
# financier possible pour les éléments physiques)                                    #
######################################################################################
Subprog AP_NBFCY
Local Integer I_FCY
Local Integer IND_FCY
Local Integer NB_SEL_FCY

  NB_SEL_FCY=0
  If ACTTYPGES=GTAMMAS Then
    For I_FCY=1 To [M:MHC]NBFCY
      If [M:MHC]FLGFCY(I_FCY-1)=G_OUI Then
        NB_SEL_FCY += 1
        IND_FCY     = I_FCY
      Endif
    Next I_FCY
  Endif

  If NB_SEL_FCY=0 Then
    # MABON - 01/07/09 - Un site doit être sélectionné
    # Gosub AP_NBCPY
    Call ERREUR ("Sélectionnez un site") From GESECRAN
    mkstat=2
  Elsif NB_SEL_FCY>1 Then
    Call ERREUR ("Sélectionnez au plus un site") From GESECRAN
    mkstat=2
  Else
    If [M:PHYM]FCYD="" Then # FQ49517
      [M:PHYM]FCYD  = [M:MHC]FCY(IND_FCY-1)
      [M:PHYM]ZFCYD = [M:MHC]ZFCY(IND_FCY-1)
      Affzo [M:PHYM]FCYD, ZFCYD
    Endif
  Endif
End


######################################################################################
# Si aucune société sélectionnée, on vide les sites et la localosation               #
######################################################################################
Subprog AP_NBCPY
Local Integer I_CPY
Local Integer SELCPY

  If ACTTYPGES=GTAMMAS Then
    For I_CPY=1 To [M:MHC]NBCPY
      If [M:MHC]FLGCPY(I_CPY-1)=G_OUI : SELCPY = 1 : Break : Endif
    Next I_CPY

    If !SELCPY Then
      [M:PHYM]FCYD  = ""
      [M:PHYM]ZFCYD = ""
      Affzo [M:PHYM]FCYD, ZFCYD

      [M:PHYM]LOCD  = ""
      Affzo [M:PHYM]LOCD
    Endif
  Endif
End


######################################################################################
# MABON - 01/07/09
# On décoche tous les sites correspondants à la société qui vient d'être cochée, car au plus un site doit être sélectionné
######################################################################################
Subprog AM_FLGCPY(VALEUR)
Variable Integer VALEUR()
Local    Integer I_FCY

#FQ98687  If VALEUR=2 Then
#FQ98687    For I_FCY=1 To [M:MHC]NBFCY
#FQ98687     If [M:MHC]FCYCPY(I_FCY-1)=[M:MHC]CPY(nolign-1) & [M:MHC]FLGFCY(I_FCY-1)=G_OUI
#FQ98687      [M:MHC]FLGFCY(I_FCY-1)=G_NON
#FQ98687     Endif
#FQ98687    Next I_FCY
#FQ98687    Affzo [M:MHC]FLGFCY
#FQ98687  Endif

End

################################################################################
# Traitement de gestion de la trace - informations particulières à l'action    #
################################################################################
$GESTRACE
  Case TRTYP
    When 1         # Ouverture de la trace
      If ACTSILENCE=G_NON
        If !clalev([F:XTRA]) : Local File TRCABX3 [XTRA] : Endif
        Call OUVRE_TRACE(mess(344,7773,1),1) From TRACEABX3 # "Transfert analytique et / ou géographique"
      Endif
    When 20        # Paramètres de l'action
      If [M:PHYM]CCLTRF=G_NON : Call ECR_TRACE("",GTRC_PARAM,left$(mess(062,7775,1)+space$(27),27)+":"-format$("D:DD[ ]MMMMMMMMMM4Y",[M:PHYM]DATTRANS),0,1) From TRACEABX3 : Endif  # Date de transfert
      If [M:PHYM]CCLTRF=G_OUI : Call ECR_TRACE("",GTRC_PARAM,left$(mess(063,7775,1)+space$(27),27)+":"-format$("D:DD[ ]MMMMMMMMMM4Y",[M:PHYM]DATTRANS),0,1) From TRACEABX3 : Endif  # Date du transfert
# à annuler
      If [M:PHYM]CCLTRF=G_NON : Call ECR_TRACE("",GTRC_PARAM,left$(mess(064,7775,1)+space$(27),27)+":"-[M:PHYM]REN-"/"-[M:PHYM]ZREN,0,1) From TRACEABX3 : Endif                   # Motif du transfert
      Call ECR_TRACE("",GTRC_PARAM,"",0,1) From TRACEABX3
      If [M:PHYM]CCLTRF=G_OUI : Call ECR_TRACE("",GTRC_PARAM,"Affectations et/ou imputations destinations du transfert à annuler",0,1) From TRACEABX3 : Endif                    # Affectations et/ou
# imputations destinations du transfert à annuler
      If [M:PHYM]FCYD   <>""  : Call ECR_TRACE("",GTRC_PARAM,left$(mess(065,7775,1)+space$(27),27) +":"-[M:PHYM]FCYD-"/"-[M:PHYM]ZFCYD,0,1) From TRACEABX3 : Endif                # Site financier
      If [M:PHYM]LOCD<>""     : Call ECR_TRACE("",GTRC_PARAM,left$(mess(122,7776,1)+space$(27),27) +":"-[M:PHYM]LOCD,0,1) From TRACEABX3 : Endif                                  # Localisation
    When Default
  Endcase
Return


######################################################################################
#  Massif : contrôle élément pour retrait de la population                           #
######################################################################################
$MAS1_CONTROLE
Local Date DAT_ATT
Local Integer I
Local Integer OUVFIC
Local Integer EXIST_ONE_TRANS

  If ACTTYPGES=GTAMMAS & [M:PHYM]CCLTRF=G_NON Then
    # On ne peut pas transférer un élément physique qui est sorti
    If [F:MAS1]ISSDAT<>[0/0/0] Then
      GOK =0
      Return
    Endif
    SAUTRFDAT  = [F:MAS1]TRFDAT
    DAT_ATT=func TRTPHYTRF.SEARCH_TRANS([M:PHYM]DATTRANS,EXIST_ONE_TRANS,"[F:MAS1]")
    # si l'elt physique est rattaché à un bco, on contrôle si le bien est actif
    # On contrôle aussi que la date de transfert est supérieure à la date du dernier transfert en attente.
    If [F:MAS1]AASREF <> "" Then
      OUVFIC=G_NON
      If !clalev([FAS]) Then
        OUVFIC=G_OUI
        Local File FXDASSETS [FAS]
      Endif
      Read [FAS]FAS0=[F:MAS1]AASREF
      If !fstat Then
        If [F:FAS]ENAFAS=G_NON Then
          GOK = 0
          Return
        Endif
      Endif
      If OUVFIC=G_OUI Then
        Close Local File [FAS]
      Endif

      For I= dim([F:MAS1]MVT)-1  To 0 Step -1
        If [F:MAS1]MVT(I) = GVMLPMVGEO Then : # Si on a un transfert en attente
          If [M:PHYM]DATTRANS <= [F:MAS1]MVTDAT(I) Then
            DAT_ATT = [F:MAS1]MVTDAT(I)
            Break
          Endif
        Elsif [F:MAS1]MVT(I) = GVMLPMVISS Then #Si on a un mvt de sortie en attente on quitte.
          GOK = 0
          Break
        Endif
      Next I
    Endif

    If GOK= 0 Then Return Endif

    # On prend la date max entre la date de dernier transfert effectif TRFDAT, la date du dernier transfert
    # en attente MVTDAT et la date de réception DNUMRECEP
    If DAT_ATT < [F:MAS1]DNUMRECEP Then
      DAT_ATT = [F:MAS1]DNUMRECEP
    Endif

    If DAT_ATT < [F:MAS1]TRFDAT & EXIST_ONE_TRANS = G_OUI Then
      DAT_ATT = [F:MAS1]TRFDAT
    Endif

    If [M:PHYM]DATTRANS <= DAT_ATT Then
      GOK =0
      Return
    Endif
  Endif
  # CBO 20120208 FQ69691B : test complété par and dim(GFXDINT) <= 0
  If ACTTYPGES=GTAMMAS & [M:PHYM]CCLTRF=G_OUI and dim(GFXDINT) <= 0 Then
   #> Est-ce que les imputations destinations fournies par l'utilisateur correspondent aux imputations actuelles de l'élément ?
   If [M:PHYM]FCYD   <>"" & [F:MAS1]FCY   <>[M:PHYM]FCYD    : GOK=0 : Return : Endif
   If [M:PHYM]LOCD   <>"" & [F:MAS1]LOC   <>[M:PHYM]LOCD    : GOK=0 : Return : Endif

    If GOK=0
      Return
    Endif
  Endif

Return




######################################################################################
## Etiquette ajoutée par le superviseur (écran PHYTRFP) 25/07/2008 15:43:41 (STANT)
######################################################################################
Subprog B10_LOCD(VALEUR)
Variable Char    VALEUR()

Local Char LOCDEF(GLONLCT), WMESS(250)
Local Integer LCDRET

  LOCDEF = func PHYLCT_CSTD.GET_DEFAULT_LOCATION([M:PHYM]FCYD, LCDRET, WMESS)
  If LOCDEF <> "" Then
    [M:PHYM]LOCD = LOCDEF
    Affzo [M:PHYM]LOCD
  Endif
End

######################################################################################
# 49517 (SYMEU) : transfert de site financier
# Mise à jour de la localisation du bien quand on fait un transfert de localisation
# sur un élément physique rattaché à un bien, en traitement massif uniquement
# FQ62267 : ajout des paramètres PPHYREF, PAASREF et PLOC
######################################################################################
Subprog MAJ_LOC_BIEN(PPHYREF, PAASREF, PLOC)
Value Char       PPHYREF
Value Char       PAASREF
Value Char       PLOC

Local Integer DIFFLOC
Local Char LLOCK(200)
Local Integer L_OUVBCO, L_OUVPHY

  L_OUVBCO = G_NON : L_OUVPHY = G_NON
  If !clalev([F:FASW]) Then
    Local File FXDASSETS [FASW]
    L_OUVBCO = G_OUI
  Endif

  #Readlock [FASW]FAS0=[F:MAS1]AASREF : # FQ62267
  Readlock [FASW]FAS0=PAASREF
  # Pour interdire toute modification sur l'objet
  #LLOCK = func GLOBIENS.GET_KEY_FXDASSETS ([F:MAS1]AASREF) : # FQ62267
  LLOCK = func GLOBIENS.GET_KEY_FXDASSETS (PAASREF)
  #If ( func GLOBIENS.IS_SYMBOLE_LOCKED ("FAS", [F:MAS1]CPY, LLOCK) = 0 ) Then : # FQ62267
  If ( func GLOBIENS.IS_SYMBOLE_LOCKED ("FAS", [F:FASW]CPY, LLOCK) = 0 ) Then
    # Test si la société est verrouillée sur cette table pour en empêcher la modification
    #If ACTMET = "MAS1_APPL_DIRT" Then  : # FQ62267
    If (dim(ACTMET)=-1) or (ACTMET = "MAS1_APPL_DIRT") Then
      #OK = -1 : GERR=1 : GMESSAGE = mess(60,100,1)-":"-mess(144,7773,1)-[F:MAS1]AASREF : # FQ62267
      OK = -1 : GERR=1 : GMESSAGE = mess(60,100,1)-":"-mess(144,7773,1)-PAASREF
    Else
      [F:TMP1]FLGERR=G_OUI : # FQ62267
      #[F:TMP1]MSGERR=mess(60,100,1)-":"-mess(144,7773,1)-[F:MAS1]AASREF # Enregistrement verrouillé : Bien XXX : # FQ62267
      [F:TMP1]MSGERR=mess(60,100,1)-":"-mess(144,7773,1)-PAASREF # Enregistrement verrouillé : Bien XXX
    Endif
    GOK=0
  Elsif !fstat Then
    # Recherche des éléments physiques rattachés à ce bien, et différents de l'élément physique en cours
    If !clalev([F:PY1]) Then
      Local File PHYELT [PY1]
      L_OUVPHY = G_OUI
    Endif
    #Filter [PY1] Where AASREF=[F:MAS1]AASREF and PHYREF<>[F:MAS1]PHYREF : # FQ62267
    Filter [PY1] Where AASREF=PAASREF and PHYREF<>PPHYREF
    DIFFLOC=G_NON
    For [PY1]
      #If [PY1]LOC<>[F:MAS1]LOC Then : # FQ62267
      If [PY1]LOC<>PLOC Then
        DIFFLOC=G_OUI
        Break
      Endif
    Next
    Filter [PY1]
    If L_OUVPHY = G_OUI Then
      Close Local File [PY1]
    Endif

    If DIFFLOC=G_OUI Then
      # Si plusieurs éléments avec localisations différentes, on vide la localisation du BCO
      [F:FASW]LOC = ''
    Else
      # sinon, on fait remonter la localisation de l'élément dans celle du BCO
      #[F:FASW]LOC = [F:MAS1]LOC : # FQ62267
      [F:FASW]LOC = PLOC
    Endif

    Rewrite [FASW]
    If fstat Then
      GOK=0
      Call FSTA("FAS") From GLOCK
    Endif
  Endif
  Unlock [FASW]

  If L_OUVBCO = G_OUI Then
    Close Local File [F:FASW]
  Endif

End
