#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("MLR",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
## Actions objets
######################################################################################
$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "LIENS"      : Gosub LIENS
  When "FERME"      : Gosub FERME
  When Default
Endcase
Return

$OUVRE
  If !clalev([F:RUB]) : Local File RUBRIQUE [RUB] : Endif
  If !clalev([F:MSR]) : Local File MSRUB    [MSR] : Endif
  If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
  GCURLEG = 'FRA' #Total Payroll is FRA only
Return

$LIENS
  Call MAJ_TABLE([F:MLR]CODRUB)
Return

Subprog MAJ_TABLE(CODRUB)
  Variable Char CODRUB

  Read [F:MSR]MSR0 = CODRUB
  If !fstat
    [M:MLR1]DESRUB(nolign-1)  = [F:MSR]DES
    [M:MLR1]ROW(nolign-1)     = [F:MSR]ROW
    [M:MLR1]CODGRP(nolign-1)  = [F:MSR]CODGRP
    [M:MLR1]TYPMAS(nolign-1)  = [F:MSR]TYPMAS
    [M:MLR1]NOSUMMS(nolign-1) = [F:MSR]NOSUMMS
    [M:MLR1]EFF1MS(nolign-1)  = [F:MSR]EFF1MS
    [M:MLR1]EFF2MS(nolign-1)  = [F:MSR]EFF2MS
    [M:MLR1]OBJRUB(nolign-1)  = "MSR"
  Else
    Read [F:RUB]RUB0 = GCURLEG;CODRUB
    If !fstat
      Call LECTEXTRA([M:MLR1]DESRUB(nolign-1),"RUBRIQUE","DES",GCURLEG,CODRUB) From ATEXTRA
      [M:MLR1]ROW(nolign-1)     = [F:RUB]ROW
      [M:MLR1]CODGRP(nolign-1)  = [F:RUB]CODGRP
      [M:MLR1]TYPMAS(nolign-1)  = [F:RUB]TYPMAS
      [M:MLR1]NOSUMMS(nolign-1) = [F:RUB]NOSUMMS
      [M:MLR1]EFF1MS(nolign-1)  = [F:RUB]EFF1MS
      [M:MLR1]EFF2MS(nolign-1)  = [F:RUB]EFF2MS
      [M:MLR1]OBJRUB(nolign-1)  = "RUB"
    Endif
  Endif
  If [M:MLR1]NOSUMMS(nolign-1) = 0 : [M:MLR1]NOSUMMS(nolign-1)=1 : Endif
  If [M:MLR1]EFF1MS(nolign-1) = 0  : [M:MLR1]EFF1MS(nolign-1)=1 : Endif
  If [M:MLR1]EFF2MS(nolign-1) = 0  : [M:MLR1]EFF2MS(nolign-1)=1 : Endif
End

$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

######################################################################################
## Actions sur champs
######################################################################################
Subprog C_CODRUB(VALEUR)
  Variable Char    VALEUR()
  Local Char LCODACC(GLONACS)
  #contrôle rubrique existante...
  Read [F:MSR]MSR0 = VALEUR
  If fstat
    Read [F:RUB]RUB0 = GCURLEG;VALEUR
    If fstat
      GMESSAGE = mess(11,10702,1) #"Rubrique inexistante"
      mkstat=2 : End
    Elsif [F:RUB]CODGRP=""
      GMESSAGE =  mess(35,10722,1) : # Code groupe MS non renseigné dans la rubrique
      mkstat=2 : End
    Else
      LCODACC=[F:RUB]CODACC
    Endif
  Elsif [F:MSR]CODGRP=""
    GMESSAGE =  mess(35,10722,1) : # Code groupe MS non renseigné dans la rubrique
    mkstat=2  : End
  Else
    LCODACC=[F:MSR]CODACC
  Endif

  Call CONTEXE(LCODACC) From CPTSUB
End

Subprog AM_CODRUB(VALEUR)
  Variable Char    VALEUR()

  Call MAJ_TABLE(VALEUR)
End
######################################################################################
