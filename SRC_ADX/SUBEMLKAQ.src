 #MAPAD - 2016-05-03 - Req 114309 - END

If TABLE="EMPLOCTRAFR"
  Filter [F:ETA] Where REFNUM=[F:ID]REFNUM Order By [F:ETA]TAXSTRDAT
  nolign = 0
  For [F:ETA]
    nolign += 1
    Gosub CHARGE
  Next
  Filter [F:ETA]
  Assign "[M:EMP"+MSKTAB(I)+"]"+BASTAB(I) With nolign
Endif
Return

$CHARGE
  MA=15
  Gosub SETMASK From =WINPROG
  [M] = [F:ETA]
  [M]CTRNUMAFR(nolign-1) = [F:ETA]CTRNUM
  [M]CTRDATAFR(nolign-1) = [F:ETA]CTRDAT
  [M]XITDATAFR(nolign-1) = [F:ETA]XITDAT
  [M]TAXYEAAFR(nolign-1) = num$([F:ETA]TAXYEA)

Return

$STYLE
