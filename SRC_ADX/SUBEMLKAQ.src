#FRLAA and JASMI - 2015-02-17 - Requirement 104592 US 3261 - START
$ACTION
Case ACTION
  When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
  When "STYLE"        : Gosub STYLE
  When "OUVRE"        : Gosub OUVRE
Endcase
Return

$OUVRE
  Read [ACV]CODACT="KAFR"
  If !fstat & [F:ACV]FLACT=2
    NBTBL += 1  : TBTABLE(NBTBL) = "EMPLOIDAFR"  : TYPTABLE(NBTBL) = 1
    MSKTAB(NBTBL) = "5" : TBABREV(NBTBL) = "EAF" :
    If clalev([F:EAF])=0 : Local File EMPLOIDAFR    [EAF]         : Endif

    NBTBL += 1  : TBTABLE(NBTBL) = "EMPLOCTRAFR" : TYPTABLE(NBTBL) = 0
    MSKTAB(NBTBL) = "5" : BASTAB(NBTBL) = "NBRCTRAFR"
    If clalev([F:CTRAFR])=0 : Local File EMPLOCTRAFR    [CTRAFR]         : Endif
    If clalev([F:ETA])=0   : Local File EMPLOTAXAFR   [ETA]   : Endif

  Endif
Return

$OUVRE_BOITE
