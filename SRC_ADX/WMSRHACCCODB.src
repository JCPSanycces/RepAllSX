$_GET_RES_STRING
Local Char RES(250)
Case _LAN
 When "FRA":
  Case _ID
   When 189: RES='Codes d'+"'"+'accès'
   When 71: RES='Code d'+"'"+'accès'
   When 1320: RES='Opérateur création'
   When 1324: RES='Opérateur modif'
  Endcase
 When "ENG":
  Case _ID
   When 189: RES='Access codes'
   When 71: RES='Access code'
   When 1320: RES='Creation user'
   When 1324: RES='Change user'
  Endcase
 When "ITA":
  Case _ID
   When 189: RES='Codici d'+"'"+'accesso'
   When 71: RES='Codice accesso'
   When 1320: RES='Utente creazione'
   When 1324: RES='Utente modifica'
  Endcase
 When "POR":
  Case _ID
   When 189: RES='Códigos acesso'
   When 71: RES='Código acesso'
   When 1320: RES='Operador criação'
   When 1324: RES='Operador modif.'
  Endcase
 When "SPA":
  Case _ID
   When 189: RES='Códigos de acceso'
   When 71: RES='Cód. de acceso'
   When 1320: RES='Operador creación'
   When 1324: RES='Operador modif.'
  Endcase
 When "BRI":
  Case _ID
   When 189: RES='Access codes'
   When 71: RES='Access code'
   When 1320: RES='Creation User'
   When 1324: RES='Change User'
  Endcase
 When "GER":
  Case _ID
   When 189: RES='Zugriffscodes'
   When 71: RES='Zugriffscode'
   When 1320: RES='Benutzer Anlage'
   When 1324: RES='Benutzer Änderung'
  Endcase
 When "POL":
  Case _ID
   When 189: RES='Kody dostępu'
   When 71: RES='Kod dostępu'
   When 1320: RES='Autor'
   When 1324: RES='Autor zmiany'
  Endcase
 When "CHI":
  Case _ID
   When 189: RES='访问代码'
   When 71: RES='访问代码'
   When 1320: RES='创建用户'
   When 1324: RES='修改用户'
  Endcase
 When "ARB":
  Case _ID
   When 189: RES='رموز الدخول'
   When 71: RES='رمز الدخول'
   When 1320: RES='إنشاء المستخدم'
   When 1324: RES='تعديل المستخدم'
  Endcase
Endcase
Return
#---------------------------------------------------------------------------------------------------#
