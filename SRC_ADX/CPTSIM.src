#<AdxTL>@(#)7.0.0.0 $Revision$
GSCHEMA=""
Local Char PARAM(10)(1..2) , VALEUR(10)
PARAM(1) = "V"
Call TRAITE_CHAR(VALEUR,PARAM,"","CPTSIM","CPTSIM",4,"") From GTRAITE
End
#X3-39795  MDJ   Manage ORIGIN and ORICOD fields in GL Entry
#######################################################
## Traitement des actions
#######################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub FIN
 When "TITRE"       : Gosub TIT
 When "OUVRE_BATCH" : Gosub OUVFIC
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 : GOK = 0
 When "DEBUT"       : Gosub DEBUT
 When "SORTIE"      : Gosub SORTIE
 When "INIT_DIA"    : Gosub INIT_DIA
Endcase
Return

$DEBUT
Raz [M:DIA]INI : Affzo [DIA]
Setmok [DIA] With 0
Return

$CONTROLE
If GOK<1
 FIN = 1
Else
 TMP = 1
Endif
If FIN : Return : Endif

If [M]ACTION1="V" & [M:DIA]ALLCPY=2
 Call AVERTDGI([M:DIA]ALLCPY,[M:DIA]CPY,1,SAI) From CPTDIV2
 If SAI : Return : Endif
Endif

Local Integer OK
If [M:DIA]ALLCPY=2 # toutes sociétés
 SOC=""
Else
 SOC=[M:DIA]CPY
Endif
Call LOCKCPY(SOC, OK) From AX3MONO
If !OK : FIN=1 : Endif
Return

$SORTIE
Call UNLOCKCPY() From AX3MONO
Return

$INIT
Gosub OUVRE
OPTSIM = PARAM(1)
Local Mask CPTSIM [DIA]
Raz [M:DIA]
[M]ACTION1 = OPTSIM
Call LECMEMO("STD","[M:DIA]","cs"+num$(instr(1,"+-AV",[M]ACTION1))) From GMEMO
Gosub TIT
Return

$INIT_DIA
[M]ACTION1 = PARAM(1)
Return

$TIT
Case [M]ACTION1
 When '+'
  TIT = mess(1,107,1) : # Activation des écritures de simulation
 When '-'
  TIT = mess(2,107,1) : # Désactivation des écritures de simulation
 When 'A'
  TIT = mess(3,107,1) : # Annulation des écritures de simulation
 When 'V'
  TIT = mess(4,107,1) : # Validation des écritures de simulation
 When Default
  GERR = 1 : GMESSAGE = mess(92,116,1) : # Argument incorrect
Endcase
Return

$OUVRE
Gosub OUVFIC
Local Mask GACCENT0 [HAE0], GACCENT1 [HAE1], GACCENT2 [HAE2], VENTILE  [VTL], VENTILE2 [VT2]
Local Mask SAICURLED [SCL], GACCENTFMT  [HAEF], GACCENTW  [HAEW]

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
# Dossier mono-leg on force GCURLEG à GDOSLEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif

Local Char    CRITERE(250), CRITEREJ(250), MESSA(250), OPTSIM(1), SYMBOLE(50), CRITSPE(250)
Local Integer I, J, K, OK, NOL, NOLI, SIGN, NBPCE, STAT, MAXLIG , MAXVTL
Local Integer FLECHE
Local Integer OKMESS
MAXLIG = dim([M:HAE2]SAC1)
MAXVTL = dim([M:VTL]AMT)
Local Decimal DEBLOC(MAXLIG) , CDTLOC(MAXLIG)
Local Decimal DEBRPT(MAXLIG) , CDTRPT(MAXLIG)
Local Decimal TMPLOC(MAXVTL) , TMPRPT(MAXVTL)
Local Decimal AROLOC , ARORPT
Local Integer PCEMAX : PCEMAX = 1000
Local Integer NB_PCE, STOP
Local Char    FILPCE(250)
Local Char    TYPDEB(GLONGTE)
Local Char    NUMDEB(GLONVCR)
Local Date    DATDEB
Local Decimal EXE, PER
Local Char    OLDCOU(GLONANM)
Local Char    VLEG(GLONADI)
Local Char    TZONE(10)(1..10)    : # Table of the zones to be forced (Ex: ORICOD)   #*X3-39795
Local Char    TVAL(30)(1..10)     : # Table of values for zones to be forced         #*X3-39795

Local Integer EP_CPTSIM : Raz EP_CPTSIM
If dim(GNBENTREE)>0 & GNBENTREE>0 & find("CPTSIM",GENTSTD(1..GNBENTREE))
 EP_CPTSIM=1
Endif
Return

$OUVFIC
If !clalev([F:GAC])  : Local File GACCOUNT   [GAC]  : Endif
If !clalev([F:JST])  : Local File GAJOUSTA   [JST]  : Endif
If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif
If !clalev([F:CPY2]) : Local File COMPANY    [CPY2] : Endif
If !clalev([F:FCY])  : Local File FACILITY   [FCY]  : Endif
If !clalev([F:FGR])  : Local File FACGROUP   [FGR]  : Endif
If !clalev([F:TCU])  : Local File TABCUR     [TCU]  : Endif
If !clalev([F:TCH])  : Local File TABCHANGE  [TCH]  : Endif
If !clalev([F:GDE])  : Local File GDIAENTRY  [GDE]  : Endif
If !clalev([F:GDD])  : Local File GDIAENTRYD [GDD]  : Endif
If !clalev([F:TCK])  : Local File TABACCLIK  [TCK]  : Endif
If !clalev([F:GTE])  : Local File GTYPACCENT [GTE]  : Endif
If !clalev([F:DSP])  : Local File CADSP      [DSP]  : Endif
If !clalev([F:HAE])  : Local File GACCENTRY  [HAE]  : Endif
If !clalev([F:DAE])  : Local File GACCENTRYD [DAE]  : Endif
If !clalev([F:DAA])  : Local File GACCENTRYA [DAA]  : Endif
If !clalev([F:BAL])  : Local File BALANCE    [BAL]  : Endif
If !clalev([F:BLA])  : Local File BALANA     [BLA]  : Endif
If !clalev([F:BLQ])  : Local File BLAQTY     [BLQ]  : Endif
If !clalev([F:AVN])  : Local File AVALNUM    [AVN]  : Endif
If !clalev([F:ANM])  : Local File ACODNUM    [ANM]  : Endif
If !clalev([F:FIY])  : Local File FISCALYEAR [FIY]  : Endif
If !clalev([F:PER])  : Local File PERIOD     [PER]  : Endif
If !clalev([F:JOU])  : Local File GJOURNAL   [JOU]  : Endif
If !clalev([F:JOU2]) : Local File GJOURNAL   [JOU2] : Endif
If !clalev([F:JOU3]) : Local File GJOURNAL   [JOU3] : Endif
If !clalev([F:TUN])  : Local File TABUNIT    [TUN]  : Endif
If !clalev([F:HA2])  : Local File GACCENTRY  [HA2]  : Endif
If !clalev([F:DUD])  : Local File GACCDUDATE [DUD]  : Endif
If !clalev([F:BPR])  : Local File BPARTNER   [BPR]  : Endif
If !clalev([F:GCM])  : Local File GACM       [GCM]  : Endif
If !clalev([F:DA2])  : Local File GACCENTRYD [DA2]  : Endif
Gosub OUVRE2
Return


$OUVRE2
If clalev([F:GAU])=0 : Local File GAUTACE     [GAU] : Endif
If clalev([F:GAD])=0 : Local File GAUTACED    [GAD] : Endif
If clalev([F:GAG])=0 : Local File GAUTACEF    [GAG] : Endif
If clalev([F:CAC])=0 : Local File GACCCODE    [CAC] : Endif
If clalev([F:TCK])=0 : Local File TABACCLIK   [TCK] : Endif
If clalev([F:DUD])=0 : Local File GACCDUDATE  [DUD] : Endif
If clalev([F:GCF])=0 : Local File GACCDEF     [GCF] : Endif
If clalev([F:GAC])=0 : Local File GACCOUNT    [GAC] : Endif
If clalev([F:CCE])=0 : Local File CACCE       [CCE] : Endif
If clalev([F:AUZ])=0 : Local File CAAUZ       [AUZ] : Endif
If clalev([F:ANM])=0 : Local File ACODNUM     [ANM] : Endif
If clalev([F:AVN])=0 : Local File AVALNUM     [AVN] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV     [ADI] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON     [ATZ] : Endif
If clalev([F:ATI])=0 : Local File ATABIND     [ATI] : Endif
If clalev([F:CCE2])=0 : Local File CACCE      [CCE2] : Endif
If clalev([F:ATB])=0  : Local File ATABLE     [ATB]  : Endif
If clalev([F:HAE2])=0 : Local File GACCTMP    [HAE2] : Endif
If GMODU(2)=2  :# Compta
 If clalev([F:GDE])=0 : Local File GDIAENTRY   [GDE] : Endif
 If clalev([F:GDD])=0 : Local File GDIAENTRYD  [GDD] : Endif
 If clalev([F:PBS])=0 : Local File GAPARBSE    [PBS] : Endif
 If clalev([F:JST])=0 : Local File GAJOUSTA    [JST] : Endif
 If clalev([F:HAE1])=0 : Local File GACCENTRY  [HAE1] : Endif
Endif
Return

#######################################################
$EXEC
If GSERVEUR : [M:DIA]TRC = 2 : Endif
Gosub TIT
If !GSERVEUR & [M:DIA]TRC=2
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
If [M:DIA]TRC=2
 Call ECR_TRACE(TIT,0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

# Reinit de GCURLEG car qd on lance la validation on passe de GSAISE à GTRAITE et
# on perd le GCURLEG initialisé par CPTTRT
# Dossier mono-leg on force GCURLEG à GDOSLEG
If GNBLEG=1
 GCURLEG = GDOSLEG(1)
Else
 GCURLEG=[M:DIA]LEG
Endif

Raz GSOCIETE
CRITERE = "1=1"
If [M:DIA]ALLCPY<>2
 CRITERE -= '& CPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2
 CRITERE -= '& FCY = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]ALLTYP<>2
 CRITERE -= '& TYP = "'+[M:DIA]TYP+'"'
 If [M:DIA]VCRDEB<>""
  CRITERE -= '& NUM>="'+[M:DIA]VCRDEB+'"'
 Endif
 If [M:DIA]VCRFIN<>""
  CRITERE -= '& NUM<="'+[M:DIA]VCRFIN+'"'
 Endif
Endif
If [M:DIA]ALLUSR<>2
 CRITERE -= '& (UPDUSR = "'+[M:DIA]USR+'"'
 CRITERE -= '| (UPDUSR = "" & CREUSR = "'+[M:DIA]USR+'"))'
Endif
Case [L]OPTSIM
 When "+"
  CRITERE -= "& CAT=3"  : # LA 618 Simulation inactive
  If [M:DIA]AUTACC=1 : CRITERE -= "& REFSIM=''" : Endif
 When "-"
  CRITERE -= "& CAT=2"  : # LA 618 Simulation active
  If [M:DIA]AUTACC=1 : CRITERE -= "& REFSIM=''" : Endif
 When "A"
  If [M:DIA]SIM=2       : # On prend les simulations inactives
   CRITERE -= "& (CAT=2 | CAT=3)"
  Else
   CRITERE -= "& CAT=2" : # LA 618 Simulation active
  Endif
  If [M:DIA]AUTACC=1 : CRITERE -= "& REFSIM=''" : Endif
 When "V"
  If [M:DIA]SIM=2       : # On prend les simulations inactives
   CRITERE -= "& (CAT=2 | CAT=3)"
  Else
   CRITERE -= "& CAT=2" : # LA 618 Simulation active
  Endif
  CRITERE -= "& REFSIM=''"  : # On ne prend pas les écritures de simulations automatiques
Endcase
If [M:DIA]STRDAT<>[0/0/0]
 CRITERE -= '& ACCDAT>=['+format$(GFMD,[M:DIA]STRDAT)+']'
Endif
If [M:DIA]ENDDAT<>[0/0/0]
 CRITERE -= '& ACCDAT<=['+format$(GFMD,[M:DIA]ENDDAT)+']'
Endif

Raz [L]CRITSPE
GPOINT = "FILTRE" : Gosub ENTREE From EXEFNC
If [L]CRITSPE="" : [L]CRITSPE = "1=1" : Endif

CRITEREJ = "1=1"
If [M:DIA]ALLTYPJOU<>2
 CRITEREJ -= "& TYP ="-num$([M:DIA]TYPJOU)
Endif
If [M:DIA]ALLJOU<>2
 CRITEREJ -= '& JOU = "'+[M:DIA]JOU+'"'
Endif
Filter [JOU2] Where evalue(CRITEREJ)

#Boucle sur les sociétés
If [M:DIA]ALLCPY=2
 For [CPY2] Where CPYLEGFLG=2 & LEG=GCURLEG
  Filter [HA2] Where evalue(CRITERE) & evalue([L]CRITSPE) & [F:HA2]CPY=[F:CPY2]CPY
  Gosub TRTSOC
 Next
Else
 If [F:CPY2]CPY<>[M:DIA]CPY
  Read [CPY2]CPY0 = [M:DIA]CPY
 Endif
 Filter [HA2] Where evalue(CRITERE) & evalue([L]CRITSPE)
 Gosub TRTSOC
Endif

Filter [JOU2]
Filter [HA2]

If !NBPCE
 Call ECR_TRACE(mess(8,107,1),0) From GESECRAN : # Aucune pièce à traiter
Endif

If !GSERVEUR & [M:DIA]TRC=2
 Call FERME_TRACE From LECFIC
Endif
Return


#######################################################
$FIN
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
If !GSERVEUR & [M:DIA]TRC=2
 TRA = 1
Else
 TRA = 0
Endif
Return


#######################################################
$TRTSOC
For [JOU2]JOU0(1)
 VLEG = [F:CPY2]LEG
 Look [JOU3]JOU0=[F:JOU2]JOU;VLEG
 If fstat
  Raz VLEG
 Endif
 For [JOU2]JOU0(2)
  If [F:JOU2]LEG=VLEG
   GOK=1
   Gosub TRTSIM
   If GOK<1 & GTRACE<>""
    Call ECR_TRACE(mess(17,107,1),1) From GESECRAN : # Rollback
   Endif
  Endif
 Next
Next
Return

#######################################################
$TRTSIM
Call CONTEXE([F:JOU2]ACS) From CPTSUB
If mkstat
 If GTRACE<>""
  Call ECR_TRACE([F:JOU2]JOU-GMESSAGE,1) From GESECRAN
 Endif
 Return
Endif

Raz NUMDEB

$BOUCLE_PCE
NB_PCE  = 0
STOP    = 0
FILPCE  = "1=1"

If NUMDEB<>""
 FILPCE -= ' & ( ACCDAT=['+format$(GFMD,DATDEB)+'] & TYP="'+TYPDEB+'" & NUM>="'+NUMDEB+'")'
 FILPCE -= ' | ( ACCDAT=['+format$(GFMD,DATDEB)+'] & TYP>"'+TYPDEB+'")'
 FILPCE -= ' | ( ACCDAT>['+format$(GFMD,DATDEB)+'])'
Endif

For [HA2]HAE1 Where JOU=[F:JOU2]JOU & evalue(FILPCE)
 If NB_PCE>=PCEMAX
  STOP = 1 : DATDEB = [F:HA2]ACCDAT : TYPDEB = [F:HA2]TYP : NUMDEB = [F:HA2]NUM : Break
 Endif
 NB_PCE += 1
 OK = 1
 Call CONTFCY([F:HA2]FCY) From CPTSUB
 If mkstat : OK=0 : Endif
 Filter [DA2] Where TYP=[F:HA2]TYP and NUM=[F:HA2]NUM
 For [DA2]DAE3(1)
  If [F:DA2]PER=0
   Call GETPERSOC([F:HA2]CPY,[F:DA2]LEDTYP,[F:HA2]ACCDAT,[L]EXE,[L]PER) From CPTSUB
   If [F:HA2]CPY<>[F:PER]CPY |[L]EXE<>[F:PER]FIYNUM | [L]PER<>[F:PER]PERNUM | [F:DA2]LEDTYP<>[F:PER]LEDTYP
    Read [PER]PER0 = [F:HA2]CPY ; [F:DA2]LEDTYP ; [L]EXE ; [L]PER
   Endif
  Elsif [F:HA2]CPY<>[F:PER]CPY | [F:HA2]FIY<>[F:PER]FIYNUM | [F:HA2]PER<>[F:PER]PERNUM | [F:DA2]LEDTYP<>[F:PER]LEDTYP
   Read [PER]PER0 = [F:HA2]CPY ; [F:DA2]LEDTYP ; [F:HA2]FIY ; [F:HA2]PER
  Endif
  If [F:PER]PERSTA<>2 : OK = 0 : Break : Endif
 Next
 Filter [DA2]

  #Issue X3-76846 by MRDAB
  Filter [F:DA2] Where [F:DA2]TYP = [F:HA2]TYP and [F:DA2]NUM = [F:HA2]NUM
  For [F:DA2]DAE3
    If (func AFNC.ACTIV("FIFRC") & [F:HA2]NUM <> '')
      If (func AFNC.PARAM("FIFRC", [F:HA2]FCY) = "2")
        If (func FIFOCONVAR_CSTD.DOES_FIFO_EXIST_FOR_HAE([F:DA2]NUM, [F:DA2]CPY) = 0)
          Call ECR_TRACE([F:HA2]TYP - [F:HA2]NUM + ":", 0) From GESECRAN
          Call ECR_TRACE(mess(12,7708,1), 1) From GESECRAN
          OK = 0 : Break
        Endif
      Endif
    Endif
  Next
  Filter [F:DA2]
  #Issue end

 If [M:DIA]ALLTYP=2
  Call LEC_GTE_LEG(GCURLEG,[F:HA2]TYP) From CPTLEC
  Call CONTEXE([F:GTE]ACS) From CPTSUB
  If OPTSIM="V" & [F:GTE]VCRREA<>2 & [M:DIA]TYPDES="" : OK = 0 : Endif
 Endif
 If OK
  NBPCE += 1
  SYMBOLE = "HAE"+[F:HA2]NUM+"\"+[F:HA2]TYP
  Lock =SYMBOLE With lockwait=0
  If fstat=1
   If GTRACE<>""
    Call ECR_TRACE([F:HA2]TYP-[F:HA2]NUM-mess(10,100,1),1) From GESECRAN
   Endif
  Else
   OKMESS = 1
   Call DEBTRANS From GLOCK
   Gosub TR1
   If GOK=1 & !STAT & OKMESS
    If GTRACE<>""
     Case OPTSIM
      When "+", "-", "A"
       Call ECR_TRACE(mess(12,107,1)-[F:HA2]TYP-[F:HA2]NUM-[F:HA2]JOU-[F:HA2]CREUSR
&           -format$("D:"+GFMDAT,[F:HA2]ACCDAT),0) From GESECRAN : # Pièce
      When "V"
       If [M:HAE0]CAT=1 & [M:HAE0]STA<>[M:DIA]SIMSTA
        Call ECR_TRACE([F:HA2]TYP-[F:HA2]NUM-[F:HA2]JOU-format$("D:"+GFMDAT,[F:HA2]ACCDAT)
&           -mess(11,107,1)-[F:HAE]TYP-[F:HAE]NUM-"("+tolower(mess(192,107,1))+")",0) From GESECRAN : # Pièce validée

       Else
        Call ECR_TRACE([F:HA2]TYP-[F:HA2]NUM-[F:HA2]JOU-format$("D:"+GFMDAT,[F:HA2]ACCDAT)
&           -mess(11,107,1)-[F:HAE]TYP-[F:HAE]NUM,0) From GESECRAN : # Pièce validée
       Endif
     Endcase
    Endif
    Case OPTSIM
     When "A"
      Call ESPION("GACCENTRY",3,[F:HA2]TYP,[F:HA2]NUM) From ESPION
     When "V"
      Call ESPION("GACCENTRY",3,[F:HA2]TYP,[F:HA2]NUM) From ESPION
      Call ESPION("GACCENTRY",1,[F:HAE]TYP,[F:HAE]NUM) From ESPION
    Endcase
   Endif
   Unlock =SYMBOLE
  Endif
 Endif
Next
If STOP : Goto BOUCLE_PCE : Endif
Return

$TR1
GOK=1
Trbegin  [HAE], [HA2], [DAE], [DAA], [AVN], [BAL], [BLA], [DUD]
 Readlock [HAE]HAE0 = [F:HA2]TYP ; [F:HA2]NUM
 If fstat=1
  GOK=-1 : GLOCK="$GACCENTRY"+[F:HA2]TYP-[F:HA2]NUM : Goto ROL_TR1
 Elsif fstat
  OKMESS = 0 : Goto AB_TR1
 Else
  Case OPTSIM
   When "+"
    ## le traitement pouvant être lancé sur deux postes différents et sur la même société, on conditionne l'activation en retestant la
    ## valeur de CAT (car a pu être activé entre temps...)
    If [F:HAE]CAT=3
     SIGN=-1 : Gosub MAJSTA
     If GOK>=0
      [F:HAE]CAT = 2 : # Simulation active
      Rewrite [HAE]
      If fstat
       GOK=0 : Call FSTA("HAE") From GLOCK : Goto AB_TR1
      Endif
      Call VALPCE(1,[F:HAE]TYP,[F:HAE]NUM) From CPTBAL
      If GOK>=0
       SIGN=+1 : Gosub MAJSTA
      Endif
     Endif
    Else
     OKMESS = 0
    Endif
   When "-"
    If [F:HAE]CAT=2
     Call VALPCE(-1,[F:HAE]TYP,[F:HAE]NUM) From CPTBAL
     If GOK>=0
      SIGN=-1 : Gosub MAJSTA
      If GOK>=0
       [F:HAE]CAT = 3 : # Simulation inactive
       Rewrite [HAE]
       If fstat
        GOK=0 : Call FSTA("HAE") From GLOCK : Goto AB_TR1
       Endif
       SIGN=+1 : Gosub MAJSTA
      Endif
     Endif
    Else
     OKMESS = 0
    Endif
   When "A"
    Gosub ANNUL
   When "V"
    Gosub GENECR
  Endcase
  If    GOK<0 : Goto ROL_TR1
  Elsif GOK=0 : Goto AB_TR1
  Endif
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$MAJSTA
For [DAE]DAE0 Where TYP=[F:HAE]TYP & NUM=[F:HAE]NUM
 Call VALSTA("GAS",SIGN) From SUBPS2
 If GOK<1 : Break : Endif
Next : # [DAE]
Return

$ANNUL
GTRANS = 1
Call DELPCE([F:HA2]TYP,[F:HA2]NUM) From CPTBATCH
GTRANS = 0
If GOK<1 : Return : Endif
Return

$GENECR
# Chargement des écrans de saisie écritures
Raz [M:HAE0], [M:HAE1], [M:HAE2]
[M:HAE0] = [F:HAE]
[M:HAE1] = [F:HAE]
Default Mask [HAE2]
Default Mask [HAE1]
Default Mask [HAE0]
GFLAG = [F:HAE]DACDIA

Gosub LIENS From SUBGAS
[M:HAE0]NUM = ""
[M:HAE0]CAT = 1 : # Réel
[M:HAE0]STA = [M:DIA]SIMSTA

If [M:DIA]ALLCPY=2
 If func AFNC.PARAM("FRADGI",[M:HAE0]CPY)="2"
  [M:HAE0]STA = 2
 Endif
Endif

If [M:DIA]TYPDES<>""
 [M:HAE0]TYP=[M:DIA]TYPDES
Endif
If [M:DIA]JOUDES<>""
 [M:HAE0]JOU=[M:DIA]JOUDES
Endif

[M:HAE1]REFSIM = ""
For NOL=0 To [M:HAE2]NBLIG-1
 [M:HAE2]ACCNUM(NOL) = 0
Next NOL

# Contrôles écran
Call CONTROLE(STAT,MESSA) From CPTBATCH
If STAT
 Gosub MESSAGE From CPTAUTO
 If GTRACE<>""
  Call ECR_TRACE([F:HAE]TYP-[F:HAE]NUM-MESSA,1) From GESECRAN
 Endif
 Return
Endif

# Annulation écriture de simulation
Gosub ANNUL
If GOK<1 : Return : Endif
#[M:HAE0]NUM=[F:HAE]NUM
Call LEC_GTE_LEG(GCURLEG,[F:HAE]TYP) From CPTLEC
OLDCOU = [F:GTE]COU
Call LEC_GTE_LEG(GCURLEG,[M:HAE0]TYP) From CPTLEC
If [F:GTE]COU<>"" & [F:GTE]COU<>OLDCOU
 Raz [M:HAE0]NUM
Else
 [M:HAE0]NUM=[F:HAE]NUM
Endif

# Ecriture de la pièce
Default Mask [HAE0]
 TZONE(5)= "ORIGIN" : TVAL(5)= "2"        :#Automatic loading  #*X3-39795
 TZONE(6)= "ORICOD" : TVAL(6)= "CPTVALSIM"                     #*X3-39795 MWA
 #*X3-39795 Call VALPIECE(STAT,MESSA) From CPTBATCH
 Call VALPIECE2(STAT,MESSA,TZONE,TVAL) From CPTBATCH
 If STAT
  If GTRACE<>""
   Call ECR_TRACE([F:HAE]TYP-[F:HAE]NUM-MESSA,1) From GESECRAN
  Endif
  Return
 Endif

For [DAE]DAE0 Where TYP=[F:HAE]TYP & NUM=[F:HAE]NUM & SAC<>"" & [F:DAE]LEDTYP=[M:HAEF]GENLED
 FLECHE = 1 : Gosub VALECHE From SUBGAS
 If dim(EP_CPTSIM)>0 & EP_CPTSIM
  GPOINT = "GNRDUD" : Gosub ENTREE From EXEFNC
 Endif
 If GOK<1 : Break : Endif
Next
If GOK<1 : Return : Endif

Call VALPCE(1,[F:HAE]TYP,[F:HAE]NUM) From CPTBAL
Return

