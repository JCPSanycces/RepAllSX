# Classe AFCTFCT

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AREAD_BEFORE"  : Gosub AREAD_BEFORE
      When "AREAD_AFTER"   : Gosub AREAD_AFTER
      When "AINSERT_AFTER" : Gosub WRTACC
      When "AUPDATE_AFTER" : Gosub WRTACC
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return



$AREAD_BEFORE
Return

$AREAD_AFTER
Local Integer I,NUMLIN,STAT
I=0

#Acces
If this.ALLACS<>2
Local File ACCES [ACC1]
For [ACC1]CODACC Where PRFCOD=this.PRFCOD & CODACC<>"" & USR=""
 NUMLIN = fmet this.ADDLINE("AACS",[V]CST_ALASTPOS)
 this.AACS(NUMLIN).CODACC = [F:ACC1]CODACC
 this.AACS(NUMLIN).MODIF  = [F:ACC1]MODIF
 this.AACS(NUMLIN).CONSUL = [F:ACC1]CONSUL
 this.AACS(NUMLIN).EXEC   = [F:ACC1]EXEC
Next
Endif

# Groupe état
#For I=1 To 15:# len(mess(0,97,1))
For I=1 To maxtab(this.ASTA)
 If I<=15
  this.ASTA(I).GRPETX = I
# Else
#  STAT = fmet this.ADELLINE("ASTA",I)
 Endif
Next
#essai par asetattribut
#ASTAT = fmet this.ASETATTRIBUTE("AFTSTA","$maxItems","15")

#Site
Read [AFT]AFT0 = this.PRFCOD
For I=1 To len(mess(0,14,1))
 If left$(mess(I,14,1),1)="#"
  Break
 Else
  NUMLIN = fmet this.ADDLINE("AFCYD",[V]CST_ALASTPOS)
  this.AFCYD(NUMLIN).MODULE = I
  this.AFCYD(NUMLIN).DEFFCY = [AFT]FCYDEF(I-1)
 Endif
Next I
Return



$WRTACC
#Tous codes d'accès
If this.ALLACS = 2
Else

Endif
Return

