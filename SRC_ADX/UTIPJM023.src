#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIPJM023
# Issue X3-63434 - 2017-11-09 by FGR
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM023(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM023(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer IUPDATE
Local Char SVIEW(30)

  Call ECR_TRACE("UTIPJM023: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File ADOSSIER [ADS]
  Local File =DOSSIER + ".AVIEW"   [AVW]
  Local File =DOSSIER + ".AVIEWB"  [AVB]
  Local File =DOSSIER + ".AVIEWC"  [AVC]
  Local File =DOSSIER + ".AVIEWD"  [AVD]
  # -----------------
  Read [ADS]DOSSIER=DOSSIER
  Raz COMPTEUR
  # -----------------
  Trbegin [AVW]
  For SVIEW = "PJMOPER", "PJMTSKTRFUL", "PJMTSKTRFULU"
    # --------------------------
    Filter [AVW] Where [F:AVW]CODVUE = SVIEW
    For [AVW]
      COMPTEUR += 1
      Delete [AVW]
      If fstat Then
        Call ECR_TRACE("File AVIEW" - [F:AVW]CODVUE + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [AVW]
    # --------------------------
    Filter [AVB] Where [F:AVB]CODVUE = SVIEW
    For [AVB]
      COMPTEUR += 1
      Delete [AVB]
      If fstat Then
        Call ECR_TRACE("File AVIEWB" - [F:AVB]CODVUE + "~" + num$([F:AVB]TYPDBA) + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [AVB]
    # --------------------------
    Filter [AVC] Where [F:AVC]CODVUE = SVIEW
    For [AVC]
      COMPTEUR += 1
      Delete [AVC]
      If fstat Then
        Call ECR_TRACE("File AVIEWB" - [F:AVC]CODVUE + "~" + num$([F:AVC]CODCLE) + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [AVC]
    # --------------------------
    Filter [AVD] Where [F:AVD]CODVUE = SVIEW
    For [AVD]
      COMPTEUR += 1
      Delete [AVD]
      If fstat Then
        Call ECR_TRACE("File AVIEWB" - [F:AVD]CODVUE + "~" + num$([F:AVD]NUMLIG) + "~" + num$([F:AVD]FLDVUE) + ", Error =" - num$(fstat), 1) From GESECRAN
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
    Next
    Filter [AVD]
    # --------------------------
    Call SUPVUE(SVIEW, DOSSIER, [F:ADS]TYPDBA) From DOSVUE
    # --------------------------
  Next
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM023 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM023 : records processed with error(s).", 0) From GESECRAN
  Endif
  Close Local File [AVW]
  Close Local File [AVB]
  Close Local File [AVC]
  Close Local File [AVD]
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  # Issue X3-68134 - 2017-12-12 by FGR : BEGIN : in all cases
  #If APPLI = GDOSX3 and GADONIX <> 2 Then
  #  End
  #Endif
  # Issue X3-68134 - 2017-12-12 by FGR : END
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","AVIEW","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AVIEW") : End : Endif
  If filinfo(filpath("FIL","AVIEWD","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AVIEWD") : End : Endif
  If filinfo(filpath("FIL","AVIEWC","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AVIEWC") : End : Endif
  If filinfo(filpath("FIL","AVIEWB","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AVIEWB") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM023(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  # Issue X3-68134 - 2017-12-12 by FGR : BEGIN : in all cases
  #If APPLI = GDOSX3 and GADONIX <> 2 Then
  #  End
  #Endif
  # Issue X3-68134 - 2017-12-12 by FGR : END
  # -------------------------
  If filinfo(filpath("FIL","AVIEW","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AVIEW") : End : Endif
  If filinfo(filpath("FIL","AVIEWD","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AVIEWD") : End : Endif
  If filinfo(filpath("FIL","AVIEWC","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AVIEWC") : End : Endif
  If filinfo(filpath("FIL","AVIEWB","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "AVIEWB") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM023(APPLI)
End

