####################################################################
Gosub DECLARE_VAR
[L]AEVENT = "ACONTROL" : [L]ACTION = "ACONTROL" : [L]CURPRO = "" : Gosub ACTION From ASYRSUB
Return

####################################################################
# ADELLINE
####################################################################
$ADELLINE
Case _ACOLLECTION
 When "EXFD"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"EXFD",this)
 When "EXFF"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"EXFF",this)
 When "EXFN"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"EXFN",this)
 When "EXSD"
  [L]_ALINE =  func ASYRSUBTAB.ADELLINE([L]ALINE,"EXSD",this)
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# ADDLINE
####################################################################
$ADDLINE
Case _ACOLLECTION
 When "EXFD"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"EXFD","C_EDIXMLFILD",this)
 When "EXFF"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"EXFF","C_EDIXMLFILF",this)
 When "EXFN"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"EXFN","C_EDIXMLFIL_EXFN",this)
 When "EXSD"
  [L]_ALINE = func ASYRSUBTAB.ADDLINE([L]ALINE,"EXSD","C_EDIXMLFILXSD",this)
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# AGETDIM
####################################################################
$AGETDIM
Case _ACOLLECTION
 When "EXFD"
  [L]_ALINE = 0
 When "EXFF"
  [L]_ALINE = 0
 When "EXFN"
  [L]_ALINE = 20
 When "EXSD"
  [L]_ALINE = 0
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

####################################################################
# AGETMIN
####################################################################
$AGETMIN
Case _ACOLLECTION
 When "EXFD"
  [L]_ALINE = 1
 When "EXFF"
  [L]_ALINE = 1
 When "EXFN"
  [L]_ALINE = 1
 When "EXSD"
  [L]_ALINE = 1
 When Default :
  [L]_ALINE = [V]CST_ANOTDEFINED
Endcase
Return

