####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 91 : INTFLG Integration ( Field Local menu number 1)
####################################################################

$SET_INTFLG
If [L]_AOLDVAL<>this.INTFLG
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_INTFLG
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.INTFLG
 Gosub PROPAGATE_INTFLG
Endif
Return

$INIT_INTFLG
Gosub DECLARE_VAR From WMC0EMPLOID
[L]CURPRO = "INTFLG"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.INTFLG=0 and fmet this.AGETATTRIBUTE("INTFLG","$isMandatory")="true"
 this.INTFLG = 1
Endif
Return
 
$CONTROL_INTFLG
Gosub DECLARE_VAR From WMC0EMPLOID
[L]CURPRO = "INTFLG"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_INTFLG                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_INTFLG                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_INTFLG
[L]CURPRO = "INTFLG"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.INTFLG=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_INTFLG
[L]CURPRO = "INTFLG"
If this.INTFLG<0 or this.INTFLG>len(mess(0,1,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"1 ->"-num$(this.INTFLG)-mess(99,123,1)):  Return : # Local menu "1 -> Invalid option
Endif
Return

$_AOTHERS_INTFLG
[L]CURPRO = "INTFLG"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_INTFLG
[L]CURPRO = "INTFLG"
Return

$PROPAGATE_INTFLG
this.isReadonly = 0
[L]CURPRO = "INTFLG"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_INTFLG
Gosub DECLARE_VAR From WMC0EMPLOID
[L]CURPRO = "INTFLG"
$_LNKPRO_INTFLG
Return


