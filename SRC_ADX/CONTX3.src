#<AdxTL>@(#)8.0.0.0 $Revision$
#########################################################################
#                CONTX3 : contrôles communs de X3                       #
#-----------------------------------------------------------------------#
# Traitements e_commerce                                                #
#-----------------------------------------------------------------------#
# Actions liés au type traitement et affichage divers (GACTION)         #
#   CTLUSRACC : Contrôle droit accès en saisie du site                  #
#                                                                       #
#########################################################################
$ACTION
#--- Actions liés au type traitement et affichage divers
Case ACTION
 When "TRT_DIV"       : Gosub TRT_DIV
Endcase

#########################################################################
# Actions liés au type traitement et affichage divers (GACTION)         #
#########################################################################
$TRT_DIV
Case TRAIT
    When "CTLFCYAUZ"  : Gosub C_FCYAUZ
    When "CTLALPVAL"  : Gosub C_ALPVAL
    When "CTLNUMVAL"  : Gosub C_NUMVAL
    When "CTLDATVAL"  : Gosub C_DATVAL
Endcase
Return

########################################################################
# A supprimer : ancienne action droit acces sur le site                #
# CTLUSRACC : Contrôle droit accès en saisie du site                   #
#             (GUSRACC n'existe plus en version 150 !!)                #
########################################################################
$C_USRACC
Local Integer OBJTYP   :   OBJTYP=val(PARAM(1))
Return

########################################################################
# CTLFCYAUZ : Contrôle autorisation de la fonction pour un site        #
########################################################################
$C_FCYAUZ

If VALEUR="" : Return : Endif
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
 If !find(VALEUR,GUSRFCY(1..GNBAUZ))
   GMESSAGE = VALEUR-":"-mess(2,104,1) : # Vous n'avez pas les droits pour ce site
   mkstat = 2
 Endif
Endif
Return
########################################################################
# CTLBPRCPY : Contrôle autorisation d'un tiers sur la société du site  #
########################################################################
Subprog CTLBPRCPY(VALEUR,SITE)
Value    Char    VALEUR
Value    Char    SITE

Local    Integer ISITE
Local    Char    SOC(GLONCPY)

If !clalev([F:ACV]) Local File ACTIV      [ACV] : Endif

# Contrôle uniquement si on est en multi-site
Read[ACV]CODACT="MUL"
If !fstat & [F:ACV]FLACT = 2
   ISITE=find(SITE,GSITE(1..GNBSITE))
   If ISITE SOC=GSOCSITE(ISITE) Endif

   If SOC<>""
      If !clalev([F:BPE]) : Local File BPEXCEPT [BPE] : Endif
      Read[BPE]BPE0=VALEUR;SOC
      If !fstat
         If [F:BPE]ACEAUZ=1
            # Tiers non autorisé pour cette société
            GMESSAGE=VALEUR-mess(29,104,1) : mkstat=2 : End
         Endif
      Endif
   Endif
Endif

End

########################################################################
# A supprimer (ne plus utiliser sur GX3APP)
########################################################################
# Contrôle borne fin supérieure ou égale à borne début (alphanumérique)#
########################################################################
$C_ALPVAL
Local Char VALDEB  : VALDEB=PARAM(1)
If VALEUR < VALDEB
   GMESSAGE=mess(44,199,1) : mkstat = 2
Endif
Return

########################################################################
# A supprimer (ne plus utiliser sur GX3APP)
########################################################################
# Contrôle borne fin supérieure ou égale à borne début (numérique)     #
########################################################################
$C_NUMVAL
Local Decimal NUMDEB  : NUMDEB=val(PARAM(1))
If VALEUR < NUMDEB
   GMESSAGE=mess(44,199,1) : mkstat=2
Endif
Return

########################################################################
# A supprimer (ne plus utiliser sur GX3APP)
########################################################################
# Contrôle borne fin supérieure ou égale à borne début (date)          #
########################################################################
$C_DATVAL
Local Date VALDEB  : VALDEB=PARAM(1)
If VALEUR < VALDEB
   GMESSAGE=mess(44,199,1) : mkstat = 2
Endif
Return

#########################################################################
#                CONTX3 : contrôles communs de X3                       #
#-----------------------------------------------------------------------#
# Traitements non e_commerce                                            #
#-----------------------------------------------------------------------#
# VERFCY     : Contrôle droit acces en saisie  du  site                 #
# VERIFCY    : Contrôle droit acces en saisie  du  site                 #
# TRTSAIFCY  : Contrôle si un seul site est permis (action avant saisie)#
# CTL_PER    : Contrôle présence d'une date dans les périodes d'indispo #
# CTL_JOU    : Contrôle présence d'une date dans les jours d'indispo    #
# CTL_JOU2   : Contrôle jours d'indispo et décalage avec date mini      #
# CTLALPV    : Contrôle borne fin >= borne début (alphanumériques)      #
# CTLNUMV    : Contrôle borne fin >= borne début (numériques)           #
# CTLDATV    : Contrôle borne fin >= borne début (date)                 #
# AUTORIS_OPT: Contrôle si option autorisée pour le site et la fonction #
# CTLDEVISEIN: Contrôle qu'une devise "in" est valide                   #
#########################################################################


#########################################################################
###################### SOUS PROGRAMME ###################################
#########################################################################


Subprog VERFCY(LFCY)
#-----------------------------------------------#
# controle des droits d'acces sur la zone site  #
#  (GUSRACC n'existe plus en version 150 !!)    #
#-----------------------------------------------#
Value    Char LFCY
End

#########################################################################
Subprog VERIFCY(OBJTYP)
#----------------------------------------------#
# Ancienne gestion des autorisations  (v120)   #
# -------------------------------------------- #
# Action a utiliser en avant saisie            #
# Contrôle des droits d'acces sur la zone site #
#  (GUSRACC n'existe plus en version 150 !!)   #
#----------------------------------------------#
Value    Integer OBJTYP
# gestion objet -> OBJTYP : 1 simple / 2 tableau / 3 combiné
# fonction      -> OBJTYP : 1 multi-masque / 2 total.consult / 4 oui.non
End


#########################################################################
Subprog TRTSAIFCY(SITE)
#---------------------------------------------#
# Nouvelle gestion des autorisations   (v130) #
# ------------------------------------------- #
# Action a utiliser en avant saisie           #
# Contrôle si plusieurs sites sont autorisés  #
# Chargement si nécessaire du site par défaut #
#                 ou du premier site autorisé #
#---------------------------------------------#
Variable    Char SITE
If SITE=""
  SITE=GFCYDEF(0)   : # Si le site n'est pas renseigné on prend le site par défaut
Endif
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
  If !find(SITE,GUSRFCY(1..GNBAUZ))
    SITE=GUSRFCY(1) : # On prend le premier site autorisé
  Endif
  If GNBAUZ=1 & SITE<>""
    mkstat=2        : # Saisie inutile si un seul site permis
  Endif
Endif
End


#########################################################################
Subprog TCOFCY(OBJTYP)
#-----------------------------------------------#
# action a utiliser en controle                 #
# controle des droits d'acces sur la zone site  #
#   (GUSRACC n'existe plus en version 150 !!)   #
#-----------------------------------------------#
Value    Integer OBJTYP
# gestion objet -> OBJTYP : 1 simple / 2 tableau / 3 combiné
# fonction      -> OBJTYP : 1 multi-masque / 2 total.consult / 4 oui.non
End


########################################################################
Subprog CTL_PER(DATCTL,UVYCOD)
Variable Date DATCTL
Value Char UVYCOD
#-----------------------------------------------------------#
# Controle presence d'une date dans les periodes d'indispo. #
#-----------------------------------------------------------#
Local Char LIBMES(80), DATE1(10), DATE2(10)
Local Integer I

mkstat=0
If clalev([F:TUV])=0 : Local File TABUNAVAIL [TUV] : Endif
Read [F:TUV]UVY0=UVYCOD
#If fstat <> 0:mkstat=2:End:Endif
If fstat <> 0: End : Endif
For I=0 To dim([F:TUV]UVYSTRDAT)-1
#   If (VALEUR >= UVYSTRDAT (I) & VALEUR <= UVYENDDAT (I))
    If (DATCTL >= [F:TUV]UVYSTRDAT (I) & DATCTL <= [F:TUV]UVYENDDAT (I))
        If !GIMPORT and !GWEBSERV Then  # FGR 30/01/2014 : X3SUIVI105683 manquait !GWEBSERV
          mkstat = 2
        Else
          GERR = 2
        Endif
        DATE1 = format$("DD2", [F:TUV]UVYSTRDAT(I))
        DATE2 = format$("DD2", [F:TUV]UVYENDDAT(I))
        LIBMES = sum (mess(1,192,1),mess(1,191,1),DATE1,mess(2,191,1),DATE2)
        GMESSAGE = LIBMES
        End
    Endif
Next
End

########################################################################
Subprog CTL_JOU(DATCTL,UVYDAY,UVYCOD,SENS)
Variable Date    DATCTL
Value    Libelle UVYDAY(0..)
Value    Char    UVYCOD
Value    Integer SENS
#--------------------------------------------------------#
# Controle presence d'une date dans les jours d'indispo. #
#--------------------------------------------------------#
Local Integer JCOUR, I
Local Integer JOUR
If mkstat=2 End : Endif
mkstat=0
JCOUR=dayn(DATCTL)
I=0

$TR1
JOUR = UVYDAY(JCOUR-1)
If JOUR <> 1 : Goto TR2 : Endif
I+=1
If I > 7:Goto TR2:Endif
If SENS=0:JCOUR+=1:Else:JCOUR-=1:Endif
If JCOUR=8:JCOUR=1:Endif
If JCOUR=0:JCOUR=7:Endif
Goto TR1

$TR2
If I <> 0
   If SENS=0 : DATCTL+=I : Else : DATCTL-=I : Endif
Endif
Call CTL_PER(DATCTL,UVYCOD)
End


##########################################################################
# CTL_JOU2 : S/P de contrôle d'une date avec jours ouverts de la semaine #
#            et décalage avant ou arrière de cette date.                 #
#            Le décalage arrière se fait jusqu'à une date mini et si     #
#            celle-ci est dépassée, le décalage repart en avant jusqu'au #
#            1er jour de la semaine ouvert.                              #
# ---------------------------------------------------------------------- #
# Subprog CTL_JOU2(DATCTL,DATMIN,UVYDAY,UVYCOD,SENS)                     #
#   DATCTL  : Date à controler                                           #
#   DATMIN  : Date minimum du décalage arrière                           #
#   UVYDAY  : Jours de la semaine ouverts ou fermés                      #
#   UVYCOD  : Code périodes d'indisponibilité                            #
#   SENS    : Sens du décalage (0=Avant, 1=Arrière)                      #
# -----------------------------------------------------------------------#
# En sortie du sous-programme :                                          #
#   DATCTL  : Date réajustée à un jour de la semaine ouvert              #
##########################################################################
Subprog CTL_JOU2(DATCTL,DATMIN,UVYDAY,UVYCOD,SENS)
Variable Date    DATCTL
Value    Date    DATMIN
Value    Libelle UVYDAY(0..)
Value    Char    UVYCOD
Value    Integer SENS
#----- Variables locales -----#
Local Integer JCOUR, I
#-----
If mkstat=2 End : Endif
mkstat=0
#----------------------------------------------------------------#
# Point d'entrée CTLJOU2 pour court-circuiter ou modifier le     #
#     contrôle servant au calcul de la date prévue de réception  #
# -------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                    #
#    DATCTL   : Date à contrôler                                 #
#    UVYDAY   : Jours de la semaine ouverts ou fermés            #
#    UVYCOD   : Code période d'indisponibilité                   #
#                                                                #
# Variable modifiable par le point d'entrée :                    #
#    DATMIN   : Date minimum de réception                        #
#    SENS     : Sens du décalage (0=Avant, 1=Arrière)            #
#    WCTLFLAG : Indicateur permettant d'agir sur le contrôle     #
#               0 = Contrôle classique                           #
#               1 = Contrôle périodes indisponibilité uniquement #
#               2 = Pas de contrôle du tout                      #
#----------------------------------------------------------------#
Local    Integer WCTLFLAG : [L]WCTLFLAG=0
GPOINT="CTLJOU2" : Gosub ENTREE From EXEFNC
If [L]WCTLFLAG=2  End               : Endif
If [L]WCTLFLAG=1  Goto CTL_JOU2_TR3 : Endif
#-----
$CTL_JOU2_TR0
JCOUR=dayn(DATCTL) : I=0
#----- Contrôle si jour de la semaine est ouvert -----#
$CTL_JOU2_TR1
If UVYDAY(JCOUR-1)<>1 Goto CTL_JOU2_TR2 : Endif
I+=1
If I>7 Goto CTL_JOU2_TR2 : Endif
If SENS=0  JCOUR+=1   Else  JCOUR-=1 : Endif
If JCOUR=8 JCOUR=1  : Endif
If JCOUR=0 JCOUR=7  : Endif
Goto CTL_JOU2_TR1
#----- Réajustement de la date -----#
$CTL_JOU2_TR2
If I<>0
  If SENS=0 DATCTL+=I Else DATCTL-=I : Endif
Endif
#----- Contrôle date minimum -----#
If DATCTL<DATMIN & DATMIN<>[0/0/0]
  SENS=0 : DATCTL=DATMIN : Goto CTL_JOU2_TR0
Endif
#----- Contrôle par rapport aux périodes d'indisponibilité -----#
$CTL_JOU2_TR3
Call CTL_PER(DATCTL,UVYCOD)
End

