########################################################################
# Contrôle que le code d'accès est autorisé     cg JUIN 98             #
# code accés autre que /xxxxxxx                                        #
########################################################################
Subprog CTLACC(WACCES,WCTLTYP)
#--------------------------------------------------------#
# Contrôle que le code d'accès est autorisé              #
# WACCES  = Code accés à controler                       #
# WCTLTYP = Type de contrôle                             #
#                 "": pas de contrôle particulier        #
#                 C : consultation                       #
#                 M : modification                       #
#                 E : execution                          #
#--------------------------------------------------------#
Value    Char     WACCES
Value    Char     WCTLTYP
If WACCES="" : End : Endif
WCTLTYP = toupper (WCTLTYP)

#-----------------------------------------------------------#
# on interdit les codes d'accés avec / en premier caractère #
#-----------------------------------------------------------#
If left$(WACCES,1) = "/"
      GMESSAGE = mess(3,104,1) : mkstat = 2
      End
Endif

If GUSRACS=2 : End : Endif : # Accès à tous les codes accès

If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
Read [ACC]CODACC = GUSER;WACCES
If fstat : GMESSAGE = mess(3,104,1) : mkstat = 2
           End
Endif
#------------------------------------------------------#
#    mess :   Vous n'avez pas les droits pour ce code  #
#------------------------------------------------------#
If WCTLTYP = "C"
        If [F:ACC]CONSUL <> 2
               GMESSAGE = mess(4,104,1) : mkstat = 2
        Endif
Elsif WCTLTYP = "M"
        If [F:ACC]MODIF <> 2
               GMESSAGE = mess(4,104,1) : mkstat = 2
        Endif
Elsif WCTLTYP = "E"
        If [F:ACC]EXEC  <> 2
               GMESSAGE = mess(4,104,1) : mkstat = 2
        Endif
Endif
End


########################################################################
# Selection des codes accés autorisés           cg JUIN 98             #
# code accés autre que /xxxxxxx                                        #
########################################################################
Subprog SELX3ACC(WACCES,WCTLTYP)
#--------------------------------------------------#
# Selection des codes accés autorisés              #
# WACCES  = Code accés                             #
# WCTLTYP = Type de selection                      #
#                 "": pas de selection particuliere#
#                 C : consultation                 #
#                 M : modification                 #
#                 E : execution                    #
#--------------------------------------------------#
Variable Char WACCES()
Value    Char WCTLTYP

WCTLTYP = toupper (WCTLTYP)

If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif

If WCTLTYP="C"
   Choose [ACC] Where USR=GUSER & CONSUL=2 & left$(CODACC,1)<>"/"
&               Using USR Titled mess(79,123,1), CODACC Titled mess(73,123,1)
&               Sized (112,80) Titled mess(5,104,1)
Elsif WCTLTYP="M"
   Choose [ACC] Where USR=GUSER & MODIF=2  & left$(CODACC,1)<>"/"
&               Using USR Titled mess(79,123,1), CODACC Titled mess(73,123,1)
&               Sized (112,80) Titled mess(5,104,1)
Elsif WCTLTYP="E"
   Choose [ACC] Where USR=GUSER & EXEC=2   & left$(CODACC,1)<>"/"
&               Using USR Titled mess(79,123,1), CODACC Titled mess(73,123,1)
&               Sized (112,80) Titled mess(5,104,1)
Endif
Case status
    When 0       : Call MESSAGE(mess(99,100,1)) From GESECRAN
    When 7
    When Default : WACCES = [F:ACC]CODACC
Endcase
End


##########################################################################
# Contrôle si l'option est autorisé pour le site et la fonction courante #
#                                                                        #
# GFCY   : Site à contrôler                                              #
# GBIDC2 : Option à contrôler "M" = Modification                         #
#                             "T" = Solde                                #
#                             "V" = Validation ...etc...                 #
# GBIDI2 : Résultat du contrôle (0 = Non autorisé,  1 = Autorisé)        #
##########################################################################
$AUTORIS_OPT
Raz GBIDI2
If GUSRFCY(1)="\"
  If GFCY=""
    If instr(1,GUSRAUZ(1),GBIDC2)
      GBIDI2=1
    Endif
  Else
    GBIDI2=1
  Endif
Elsif find(GFCY,GUSRFCY(1..GNBAUZ))
  If instr(1,GUSRAUZ(find(GFCY,GUSRFCY(1..GNBAUZ))),GBIDC2)
    GBIDI2=1
  Endif
Endif
Return


########################################################################
# Contrôle que le code d'accès est autorisé                            #
# code accés autre que /xxxxxxx                                        #
########################################################################
Subprog CTLACS(WACCES,WCTLTYP)
#--------------------------------------------------------#
# Contrôle que le code d'accès est autorisé              #
# WACCES  = Code accés à controler                       #
# WCTLTYP = Type de contrôle                             #
#                 "": pas de contrôle particulier        #
#                 C : consultation                       #
#                 M : modification                       #
#                 E : execution                          #
#--------------------------------------------------------#
Value    Char     WACCES
Value    Char     WCTLTYP
If WACCES="" : End : Endif
WCTLTYP = toupper (WCTLTYP)

#-----------------------------------------------------------#
# on interdit les codes d'accés avec / en premier caractère #
#-----------------------------------------------------------#
If left$(WACCES,1) = "/"
      GMESSAGE = mess(3,104,1) : mkstat = 2
      End
Endif

If GUSRACS=2 : End : Endif : # Accès à tous les codes accès

If clalev([F:ACC])=0 : Local File ACCES [ACC] : Endif
Read [ACC]CODACC = GUSER;WACCES
If fstat : GMESSAGE = mess(3,104,1) : mkstat = 2
           End
Endif
#------------------------------------------------------#
#    mess :   Vous n'avez pas les droits pour ce code  #
#------------------------------------------------------#
If WCTLTYP = "C"
        If [F:ACC]CONSUL <> 2
               GMESSAGE = mess(4,104,1) : mkstat = 2
        Endif
Elsif WCTLTYP = "M"
        If [F:ACC]MODIF <> 2
               GMESSAGE = mess(4,104,1) : mkstat = 2
        Endif
Elsif WCTLTYP = "E"
        If [F:ACC]EXEC  <> 2
               GMESSAGE = mess(4,104,1) : mkstat = 2
        Endif
Endif
End

##########################################################################
# Contrôle de la validité d'une devise "in"                              #
#                                                                        #
# WDEVISE : Devise à contrôler                                           #
# WDAT    : Date de référence pour le contrôle                           #
# WOK     : Résultat du contrôle                                         #
#         : 0 ok                                                         #
#         : 1 Ctrl devise "in" activé et saisie devise "in" autorisée    #
#         : 2 Ctrl devise "in" activé et saisie devise "in" interdite    #
#         : 3 Devise non valide à la date donnée                         #
##########################################################################
$CTLDEVISEIN
WOK=0
If WDEVISE = GEURO Return Endif
If clalev([F:TCU])=0 : Local File TABCUR  [TCU] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif

If [F:TCU]CUR <> WDEVISE Read [TCU]TCU0=WDEVISE
                         If fstat Raz [F:TCU] : Endif
                         Endif
If [F:AUS]USR <> GUSER   Read [AUS]CODUSR=GUSER
                         If fstat Raz [F:AUS] : Endif
                         Endif

If [F:TCU]EURFLG <> 2 Return Endif

# Contrôle validité de la devise à la date donnée
If [F:TCU]CURENDDAT <> [0/0/0] & WDAT >= [F:TCU]CURENDDAT WOK=3 : Return  : Endif
# Contrôle utilisateur
Local Char LEURDAT(10), LEURDAC(3)
Local Date DEURDAT
Call PARAMUTIL("DATDEBCTR",LEURDAT,"","") From SUBAUS
Call PARAMUTIL("SAIDEVISE",LEURDAC,"","") From SUBAUS
DEURDAT = LEURDAT
If DEURDAT<>[0/0/0] & datesyst>DEURDAT
    If val(LEURDAC)<>2
        WOK=2 : Return : # Saisie en devise in interdite
    Else
        WOK=1 : Return
    Endif
Endif
Return


##########################################################################
# CTLDAT_CNF : S/P de contrôle d'une date pour la certification NF       #
#         - Contrôle que la date est comprise dans la période autorisée  #
#         - Contrôle que la nouvelle date ne donne pas un élément du     #
#           compteur sur une autre période ou exercice                   #
# ---------------------------------------------------------------------- #
# Subprog CTLDAT_CNF(WMODULE,WSITE,WOLDDAT,WNEWDAT,WCODNUM,WNUM)         #
#   WMODULE  : Module concerné (5=Ventes, 6=Achats)                      #
#   WSITE    : Site du document concerné                                 #
#   WOLDDAT  : Ancienne date (si modification document existant)         #
#   WNEWDAT  : Nouvelle date (création ou modification)                  #
#   WCODNUM  : Code compteur utilisé pour le document                    #
#   WNUM     : Numéro du document (si modification document existant)    #
# -----------------------------------------------------------------------#
# En sortie du sous-programme :                                          #
#   mkstat   : Positionné à 1 si date interdite                          #
#   GMESSAGE : Contient le message d'anomalie si mkstat=1                #
##########################################################################
Subprog CTLDAT_CNF(WMODULE,WSITE,WOLDDAT,WNEWDAT,WCODNUM,WNUM)
Value Integer WMODULE
Value Char    WSITE()
Value Date    WOLDDAT
Value Date    WNEWDAT
Value Char    WCODNUM()
Value Char    WNUM()
#-----
Local Char    WPARAM1(10), WPARAM2(10), WVALPAR(10)
Local Date    WSTRDAT,     WENDDAT
Local Decimal WEXERCICE1,  WPERIODE1
Local Decimal WEXERCICE2,  WPERIODE2
#----- Contrôle que la date est comprise dans la période autorisée -----#
Case WMODULE
  When 2 : WPARAM1="CPTSTRDAT" : WPARAM2="CPTENDDAT"
  When 3 : WPARAM1="TRSSTRDAT" : WPARAM2="TRSENDDAT"
  When 5 : WPARAM1="VENSTRDAT" : WPARAM2="VENENDDAT"
  When 6 : WPARAM1="ACHSTRDAT" : WPARAM2="ACHENDDAT"
  When Default : End
Endcase
Call PARAMUTIL(WPARAM1,WVALPAR,"",WSITE) From SUBAUS
If WVALPAR<>""  WSTRDAT=WVALPAR  Else  Raz WSTRDAT : Endif
Call PARAMUTIL(WPARAM2,WVALPAR,"",WSITE) From SUBAUS
If WVALPAR<>""  WENDDAT=WVALPAR  Else  Raz WENDDAT : Endif
If (WSTRDAT<>[0/0/0] & WNEWDAT<WSTRDAT) | (WENDDAT<>[0/0/0] & WNEWDAT>WENDDAT)
  GMESSAGE=mess(140,104,1)-mess(WMODULE,14,1) : mkstat=1 : End
Endif
# Dde 71552 : Ctrl existence fac/avoir/note débit/crédit sur une période/exercice supérieur
Call CTLPERINV (WMODULE-4, WNEWDAT) From CPTSUB
If mkstat=2 End Endif
#----- Si création document, pas d'ancienne date, pas de numéro attribué, c'est fini ! -----#
If WOLDDAT=[0/0/0] | WCODNUM="" | WNUM=""  End : Endif
#----- Contrôle nouvelle date et éléments compteur sur même période -----#
If func AFNC.PARAM("FRADGI",WSITE)="2"
  If !clalev([F:ANM])  Local File ACODNUM [ANM] : Endif
  If [F:ANM]CODNUM<>WCODNUM
    Read [ANM] ANM0=WCODNUM
    If fstat  Raz [F:ANM] : Endif
  Endif
  #----- Elément exercice ou période dans la structure compteur -----#
  If find(10,[F:ANM]POSTYP) | find(11,[F:ANM]POSTYP)
    Call GETPERSOC(GSOCIETE,GTYPGEN,WOLDDAT,WEXERCICE1,WPERIODE1) From CPTSUB
    Call GETPERSOC(GSOCIETE,GTYPGEN,WNEWDAT,WEXERCICE2,WPERIODE2) From CPTSUB
    If WEXERCICE1<>WEXERCICE2 | WPERIODE1<>WPERIODE2
      GMESSAGE=mess(81,119,1) : mkstat=1 : End
    Endif
  Endif
Endif
#-----
End

##################################################
Subprog TCAIMDEF(AZC,ETAT,PARAM,VALEUR)
Variable Char    AZC()
Value    Char    ETAT
Variable Char    PARAM()
Variable Char    VALEUR()

  # FGR 09/02/2015 : X3SUIVI106015
  If AZC = "" Then
    Call AIMDEF(AZC, ETAT, PARAM, VALEUR) From IMPRIME
  Endif
End
