#<AdxTL>@(#)2.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
###########################################################################
# TRTMFGS  : Situation OF                             LLC - MAR      1999 #
#
# Version modelisée                                   MM - Septembre  2003 
#
# - modèle : traitement standard (GTRAITE) avec liste de gauche
# - Ecrans : MFS0,MFS1,MFS2,MFS3,MFS4                
# - Fenêtre : IMFS 
# - Objet : MFG  
# - Action TRTMFGS                                   
###########################################################################

$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "INIT"          :  Gosub INIT
 When Default
Endcase

#--- Actions liées à la fenêtre de saisie
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "FILGAUCHE"     : Gosub FILGAUCHE
 When "GAU"           : Gosub GAU
 When "SETBOUT"       : Gosub SETBOUT
 When "BOUTON"        : Gosub BOUTON
 When Default
Endcase

Return

#########################################################################
# Actions du traitement standard (traitement GTRAITE)                   #
#########################################################################

#########################################################################
$INIT
#
Global Integer GTITRE
# récupération de la valeur du code activité titre
Call LECACT("TIT",GTITRE) From TRTX3

Call FIND_GFCYDEF(8) From TRTX3  # FQ 54218
Gosub CHARG_PARAM 

Return

#########################################################################
# Actions de la saisie fenêtre (traitement GSAISIE)                     #
#########################################################################

#########################################################################
$OUVRE
#
Local Integer  L,I 
Local Integer  REPONSE 
Local Char     WMSG(80)
#
If clalev ([F:MFG]) <= 0 : Local File MFGHEAD    [MFG] : Endif 
If clalev ([F:MFI]) <= 0 : Local File MFGITM     [MFI] : Endif 
If clalev ([F:MFM]) <= 0 : Local File MFGMAT     [MFM] : Endif 
If clalev ([F:MFO]) <= 0 : Local File MFGOPE     [MFO] : Endif 
If clalev ([F:MFP]) <= 0 : Local File MFGPRN     [MFP] : Endif 
If clalev ([F:MTS]) <= 0 : Local File MFGTRS     [MTS] : Endif 
If clalev ([F:FCY]) <= 0 : Local File FACILITY   [FCY] : Endif
If clalev ([F:ITM]) <= 0 : Local File ITMMASTER  [ITM] : Endif 
If clalev ([F:ITF]) <= 0 : Local File ITMFACILIT [ITF] : Endif 
If clalev ([F:ITV]) <= 0 : Local File ITMMVT     [ITV] : Endif 
If clalev ([F:ITG]) <= 0 : Local File ITMCATEG   [ITG] : Endif 
If clalev ([F:MWS]) <= 0 : Local File WORKSTATIO [MWS] : Endif 
If clalev ([F:SCH]) <= 0 : Local File SCHEDULING [SCH] : Endif 
If clalev ([F:TUN]) <= 0 : Local File TABUNIT    [TUN] : Endif 
If clalev ([F:ORD]) <= 0 : Local File ORDERS     [ORD] : Endif
If clalev ([F:OPS]) <= 0 : Local File OPERATIONS [OPS] : Endif
If clalev ([F:POQ]) <= 0 : Local File PORDERQ    [POQ] : Endif
If clalev ([F:SRU]) <= 0 : Local File TABSTORUL  [SRU] : Endif
If clalev ([M:OPSK])<= 0 : Local Mask OPSK       [OPSK]: Endif
If clalev ([M:ORDK])<= 0 : Local Mask ORDK       [ORDK]: Endif 
If clalev ([F:STJ]) <= 0 : Local File STOJOU     [STJ] : Endif    # llc 08.02 14548

# sr 08.02 demande 15029
Local Mask JALK   [JALK]                                             # ecran pour jalonnement
If clalev([F:PJA])<=0 : Local File PARJAL     [PJA] : Endif          # Paramètres jalonnement
#

Read [F:MTS]MTS0 = 2;GCLEMTSNUM
If fstat : Raz [F:MTS] : [F:MTS]OPEUOMMOD = 1 : Endif


Return

######################################################################### 
$DEBUT
Raz [M:MFS0]
Raz [M:MFS1]
Raz [M:MFS2]
Raz [M:MFS3]
Raz [M:MFS4]
Return

######################################################################### 
$FILGAUCHE
# sr 05.03 filtre sur WGGFLG
Case GMFGCLOSE
     When "3":     If dim([F:MFG]WGGFLG) > 0
                      FILGAUSUP(0)="MFGSTA=1 & find(MFGTRKFLG,4,5) & !find([F:MFG]WGGFLG,3,4)"
                   Else
                      FILGAUSUP(0)="MFGSTA=1 & find(MFGTRKFLG,4,5)"
                   Endif  
     When "4":     FILGAUSUP(0)="MFGSTA=4 & MFGTRKFLG < 6"
     When Default: FILGAUSUP(0)="MFGSTA=1"
Endcase

Return

######################################################################### 
$GAU

[M:MFS0]MFGFCY = [F:MFG]MFGFCY
Grizo [M:MFS0]MFGFCY
[M:MFS0]MFGNUM = [F:MFG]MFGNUM
Gosub LOAD_SITU

Return

###########################################################################
# chargement masques
$LOAD_SITU
Local Integer I, WRET
Local Decimal WDIS
#
Read [MFG]MFG0=[M:MFS0]MFGNUM
If fstat : Return : Endif

#
If [F:MFG]MFGFCY <> [M:MFS0]MFGFCY 
    [M:MFS0]MFGFCY = [F:MFG]MFGFCY
Endif
#
[M:MFS0]MFGSTA = [F:MFG]MFGSTA
[M:MFS1] = [F:MFG]

[M:MFS1]OKCPLQTY = [F:MFG]CPLQTY - [F:MFG]REJCPLQTY - [F:MFG]QUACPLQTY
[M:MFS0]XMFGSTA = mess([M:MFS0]MFGSTA,317,1)
[M:MFS1]XMFGMOD = mess([M:MFS1]MFGMOD,333,1)
[M:MFS1]XSCDMOD = mess([M:MFS1]SCDMOD,334,1)
[M:MFS1]XALLSTA = mess([M:MFS1]ALLSTA,336,1)
If [F:MFG]OPTFLG <> 2
    [M:MFS1]XMFGTRKFLG = mess([M:MFS1]MFGTRKFLG,339,1)
Else
    [M:MFS1]XMFGTRKFLG = mess(2,339,1)
Endif
[M:MFS1]XSCDFLG = mess([M:MFS1]SCDFLG,335,1)
#
I = 0
For [MFI]MFI0 Where MFGNUM=[M:MFS0]MFGNUM
    # llc 02.02    12772
    nolign = I + 1
    [M:MFS2] = [F:MFI]

    [M:MFS2]BOMALT(I)     = [F:MFI]BOMALT
    [M:MFS2]BPCNUM(I)     = [F:MFI]BPCNUM
    [M:MFS2]BPCTYPDEN(I)  = [F:MFI]BPCTYPDEN
    [M:MFS2]CPLQTY(I)     = [F:MFI]CPLQTY
    [M:MFS2]EXTQTY(I)     = [F:MFI]EXTQTY
    [M:MFS2]ITMREF(I)     = [F:MFI]ITMREF
    [M:MFS2]ITMTYP(I)     = [F:MFI]ITMTYP # llc 04.00 (sous-produit)
    [M:MFS2]ITMSTA(I)     = [F:MFI]ITMSTA
    [M:MFS2]LOT(I)        = [F:MFI]LOT
    [M:MFS2]MFGDES(I)     = [F:MFI]MFGDES
    [M:MFS2]PJT(I)        = [F:MFI]PJT
    [M:MFS2]QUACPLQTY(I)  = [F:MFI]QUACPLQTY
    [M:MFS2]REJCPLQTY(I)  = [F:MFI]REJCPLQTY
    [M:MFS2]RMNEXTQTY(I)  = [F:MFI]RMNEXTQTY
    [M:MFS2]STU(I)        = [F:MFI]STU
    [M:MFS2]UOM(I)        = [F:MFI]UOM
    [M:MFS2]UOMEXTQTY(I)  = [F:MFI]UOMEXTQTY
    [M:MFS2]UOMSTUCOE(I)  = [F:MFI]UOMSTUCOE
    Read [ITM]ITM0 = [F:MFI]ITMREF
    #If !fstat : [M:MFS2]ITMDES1(I) = [F:ITM]ITMDES1 : Endif
    If !fstat
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MFS2]ITMDES1(I), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    Endif
    I += 1
Next
[M:MFS2]NBLIG = I

#
I=0
For [MFM]MFM0 Where MFGNUM=[M:MFS0]MFGNUM
    # llc 02.02    12772
    nolign = I + 1
    [M:MFS3] = [F:MFM]

    [M:MFS3]ALLQTY(I)     = [F:MFM]ALLQTY
    [M:MFS3]BOMOPE(I)     = [F:MFM]BOMOPE
    [M:MFS3]BOMSEQ(I)     = [F:MFM]BOMSEQ
    [M:MFS3]CUMFLG(I)     = [F:MFM]CUMFLG
    [M:MFS3]ITMREF(I)     = [F:MFM]ITMREF
    [M:MFS3]MATSTA(I)     = [F:MFM]MATSTA
    [M:MFS3]MFGLIN(I)     = [F:MFM]MFGLIN
    [M:MFS3]PICPRN(I)     = [F:MFM]PICPRN
    [M:MFS3]PLANNER(I)    = [F:MFM]PLANNER
    [M:MFS3]RETDAT(I)     = [F:MFM]RETDAT
    [M:MFS3]RETQTY(I)     = [F:MFM]RETQTY
    [M:MFS3]SCA(I)        = [F:MFM]SCA
    [M:MFS3]SCOFLG(I)     = [F:MFM]SCOFLG
    [M:MFS3]SHTQTY(I)     = [F:MFM]SHTQTY
    [M:MFS3]STU(I)        = [F:MFM]STU
    [M:MFS3]USEQTY(I)     = [F:MFM]USEQTY
    Read [ITM]ITM0 = [F:MFM]ITMREF
    #If !fstat : [M:MFS3]ITMDES1(I) = [F:ITM]ITMDES1 : Endif
    If !fstat
      Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MFS3]ITMDES1(I), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    Endif
    # lecture cumuls stocks 
    Call LECITV2([M:MFS0]MFGFCY,[F:MFM]ITMREF,WRET) From MFGLIB
    Call LECSRU([M:MFS0]MFGFCY,[F:ITM]TCLCOD,6,"","",WRET) From STKLIB
    If WRET = 1 : WDIS = 0
       # recherche stock disponible
       Call STODISTOT("",0,[F:SRU]AUZSTA,"",WDIS) From STKLIB
    Endif
    [M:MFS3]AVAQTY(I)    = WDIS + [F:MFM]ALLQTY                    # llc 09.02 15756 + 18847

    # (titres llc 130)
    If [F:ITM]STOMGTCOD <> 3
        If dim([M:MFS3]TYPQTY(I)) > 0 : [M:MFS3]TYPQTY(I) = 2 : Endif
    Else
        If dim([M:MFS3]TYPQTY(I)) > 0 : [M:MFS3]TYPQTY(I) = 1 : Endif
    Endif

    I += 1
Next
[M:MFS3]NBLIG = I
#
I=0
For [MFO]MFO0 Where MFGNUM=[M:MFS0]MFGNUM
    # llc 02.02    12772
    nolign = I + 1
    [M:MFS4] = [F:MFM]

    [M:MFS4]BPSNUM(I)     = [F:MFO]BPRNUM
    [M:MFS4]CPLLAB(I)     = [F:MFO]CPLLAB
    [M:MFS4]CPLOPETIM(I)  = [F:MFO]CPLOPETIM
    [M:MFS4]CPLQTY(I)     = [F:MFO]CPLQTY
    [M:MFS4]CPLSETTIM(I)  = [F:MFO]CPLSETTIM
    [M:MFS4]CPLWST(I)     = [F:MFO]CPLWST
    [M:MFS4]CPLWSTNBR(I)  = [F:MFO]CPLWSTNBR
    [M:MFS4]CPLLABNBR(I)  = [F:MFO]CPLLABNBR
    [M:MFS4]EXTLAB(I)     = [F:MFO]EXTLAB
    [M:MFS4]EXTOPETIM(I)  = [F:MFO]EXTOPETIM
    [M:MFS4]EXTQTY(I)     = [F:MFO]EXTQTY
    [M:MFS4]EXTSETTIM(I)  = [F:MFO]EXTSETTIM
    [M:MFS4]EXTWST(I)     = [F:MFO]EXTWST
    [M:MFS4]EXTWSTNBR(I)  = [F:MFO]EXTWSTNBR
    [M:MFS4]EXTLABNBR(I)  = [F:MFO]EXTLABNBR
    [M:MFS4]OPEEND(I)     = [F:MFO]OPEEND
    [M:MFS4]OPENUM(I)     = [F:MFO]OPENUM
    [M:MFS4]OPESPLNUM(I)  = [F:MFO]OPESPLNUM
    [M:MFS4]OPESTA(I)     = [F:MFO]OPESTA
    [M:MFS4]OPESTR(I)     = [F:MFO]OPESTR
    [M:MFS4]OPEUOM(I)     = [F:MFO]OPEUOM
    [M:MFS4]POHNUM(I)     = [F:MFO]POHNUM
    [M:MFS4]POPLIN(I)     = [F:MFO]POPLIN
    [M:MFS4]POPSEQ(I)     = [F:MFO]POPSEQ
    [M:MFS4]REJCPLQTY(I)  = [F:MFO]REJCPLQTY
    [M:MFS4]TIMUOMCOD(I)  = [F:MFO]TIMUOMCOD
    Read [MWS]WST0=[F:MFO]EXTWST;[F:MFO]MFGFCY
    If !fstat
        [M:MFS4]WCR(I)    = [F:MWS]WCR
        [M:MFS4]WSTTYP(I) = [F:MWS]WSTTYP
    Endif  
    Read [MWS]WST0=[F:MFO]EXTLAB;[F:MFO]MFGFCY
    If !fstat
        [M:MFS4]LABWCR(I) = [F:MWS]WCR
    Endif  
    Read [F:SCH]SCH0 = [F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM  
    If fstat : Raz [F:SCH] : Endif 
    [M:MFS4]DACMST(I) = [F:SCH]DACMST
    I += 1
Next
[M:MFS4]NBLIG = I
#
Read [F:MFP]MFP0 = [F:MFG]MFGNUM
If !fstat [M:MFS0]WPRN = [F:MFP]MFGFDRFLG : Endif

Affzo [M:MFS0]
Affzo [M:MFS1]
Affzo [M:MFS2] 
Affzo [M:MFS3]
Affzo [M:MFS4]

Return

######################################################################## 
$SETBOUT
# inactivation bouton détail suivi
If [M:MFS1]MFGTRKFLG <= 3 
 Call VIREBOUT(CHMEN,"A") From GOBJET
Endif
Case GMFGCLOSE
        When "3":    If ([M:MFS1]MFGTRKFLG >=5 | [M:MFS1]MFGTRKFLG =0) # inactivation bouton solde
                         Call VIREBOUT(CHMEN,"B") From GOBJET
                     Endif
                     If ([M:MFS0]MFGSTA >=4 | [M:MFS0]MFGSTA =0) # inactivation bouton clôture
                         Call VIREBOUT(CHMEN,"C") From GOBJET
                     Endif
        When "4":    If ([M:MFS0]MFGSTA <> 4 | [M:MFS1]MFGTRKFLG = 6)  # inactivation bouton réactivation
                        Call VIREBOUT(CHMEN,"D") From GOBJET
                     Endif

Endcase
Return


######################################################################## 
$BOUTON
Case BOUT
    When "B" : Gosub SOLDE_OF From FUNMFGS_OLD    # solde
  #  When "C" : Gosub CLOTURE_OF From FUNMFGS_OLD    # cloture
  #  When "D" : Gosub ACTIVE_OF From FUNMFGS_OLD    # reactivation

Endcase
Return
######################################################################## 
$CHARG_PARAM 
#----- Variables globales stock 
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return 
