#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion du masque FASISR
########################################
Subprog AM_ISRTYP(VALEUR)
Variable Integer VALEUR
If ( VALEUR = GVML_TAASSUR ) Then
    # conditionnement et affichage.
    Diszo [M]1-99
    Effzo [M]1-99
    [M:FASI]ISRTYP = GVML_TAASSUR : Affzo [M:FASI]ISRTYP :   Actzo [M:FASI]ISRTYP
Else
    # conditionnement et affichage.
    [M:FASI]RPLVALCOE = 1 : Affzo [M:FASI]RPLVALCOE
    [M:FASI]ISRVALCOE = 1 : Affzo [M:FASI]ISRVALCOE
    Actzo [M]1-99
Endif
End

########################################
Subprog AM_ISRCLCBAS(VALEUR)
Variable Integer VALEUR

  [M:FASI]ISRCLCBAS = VALEUR
  Gosub RPLVAL_CALCUL
  Gosub ISRVAL_CALCUL


End

########################################
Subprog AM_RPLVALCOE(VALEUR)
Variable Decimal VALEUR

  [M:FASI]RPLVALCOE = VALEUR
  Gosub RPLVAL_CALCUL
  Gosub ISRVAL_CALCUL

End

########################################
Subprog AM_ISRVALCOE(VALEUR)
Variable Decimal VALEUR

  [M:FASI]ISRVALCOE = VALEUR
  Gosub ISRVAL_CALCUL

End

#
#*************************************
#*         ISRVAL_CALCUL             *         
#*   Calcul valeur d'assurance       *         
#*************************************
#

$ISRVAL_CALCUL

  Gosub DETERM_VALREF 

  If ([M:FASI]ISRVALFLG <> G_OUI ) Then : # Non forcé
    [M:FASI]ISRVAL = [M:FASI]RPLVAL * [M:FASI]ISRVALCOE
    Call GET_MNT_ARRONDI ([M:FASI]ISRVAL, GCOUDEV, [M:FASI]ISRVAL) From GLOBIENS
  Endif
  Affzo [M:FASI]ISRVAL

Return

#
#*************************************
#*         RPLVAL_CALCUL             *         
#*   Calcul valeur de remplacement   *         
#*************************************
#

$RPLVAL_CALCUL

  Gosub DETERM_VALREF 

  If ([M:FASI]RPLVALFLG <> G_OUI ) Then : # Non forcé
    [M:FASI]RPLVAL = LVALREF  * [M:FASI]RPLVALCOE
    Call GET_MNT_ARRONDI ([M:FASI]RPLVAL, GCOUDEV, [M:FASI]RPLVAL) From GLOBIENS
  Endif
  Affzo [M:FASI]RPLVAL

Return

#
#*************************************
#*         DETRM_VALREF              *         
#*   Calcul valeur de référence      *         
#*************************************
#

$DETERM_VALREF
Local Decimal LVALREF
  LVALREF = 0
  Case [M:FASI]ISRCLCBAS
    When GVML_BAVTAXE  : LVALREF = [M:FAS2]TAXBAS     
    When GVML_BAVRPMV  : LVALREF = [M:FAS4]GALREFBAS
    When GVML_BAACHAT  : LVALREF = [M:FAS1]ACGETRNOT      
    When GVML_BABILAN  : LVALREF = [M:FAS1]ACGBSEVAL      
  Endcase
Return


######################################################################################


########################################
Subprog AM_RPLVALFLG(VALEUR)
Variable Integer VALEUR

######  [M:FASI]RPLVALFLG = VALEUR
######  Gosub RPLVAL_CALCUL
######  Gosub ISRVAL_CALCUL

End

Subprog AV_RPLVAL(VALEUR)
Variable Decimal VALEUR
  If ([M:FASI]RPLVALFLG = G_OUI ) Then
    If ( GBROWS = 0 ) Then
      Chgstl [M:FASI]RPLVAL With "FORCAGE"
    Else
      Chgstl [M:FASI]RPLVAL With "TFORCAGE"
    Endif
  Else
    Chgstl [M:FASI]RPLVAL With ""
  Endif
End

Subprog AS_RPLVAL(VALEUR)
Variable Decimal VALEUR
  # Gestion du code forçage
  If ( func GLOBIENS.IS_CHAMP_ENABLE ("[M:FASI]RPLVAL", 0) = G_NON ) Then
    GBOUT1 = ""
    GBOUT2 = "" 
  Else  
    If ( [M:FASI]RPLVALFLG <> G_OUI ) Then
      GBOUT1 = ""
    Else
      GBOUT2 = ""
    Endif
  Endif
End

Subprog AM_RPLVAL(VALEUR)
Variable Decimal VALEUR

  # Gestion du code forçage
  If (G_DEFORCE and evalue("[M]"+zoncou+"("+num$(indice)+") = VALEUR") ) Then
    G_DEFORCE = 0
  Else
    [M:FASI]RPLVALFLG = G_OUI : Affzo [M:FASI]RPLVALFLG
    Affzo [M:FASI]RPLVAL
    If ( GBROWS = 0 ) Then
      Chgstl [M:FASI]RPLVAL With "FORCAGE"
    Else
      Chgstl [M:FASI]RPLVAL With "TFORCAGE"
    Endif
  Endif 

  [M:FASI]RPLVAL = VALEUR
  Gosub ISRVAL_CALCUL

End

Subprog B1_RPLVAL(VALEUR)
Variable Decimal VALEUR

  # Gestion du code forçage
  [M:FASI]RPLVALFLG = G_NON : Affzo [M:FASI]RPLVALFLG
 
  Gosub RPLVAL_CALCUL
  Gosub ISRVAL_CALCUL
  VALEUR = [M:FASI]RPLVAL

  # Gestion du code forçage
  G_DEFORCE = 1 
  Chgstl [M:FASI]RPLVAL With ""
  Affzo [M:FASI]RPLVAL 
  mkstat = 99
End


