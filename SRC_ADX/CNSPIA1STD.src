#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################
## Trt CNSPIA1STD                                     ######
############################################################
End
############################################################
############################################################
$FILL_PIH
  If !clalev([F:TPV]) Then Local File TABPIVTYP [TPV] : Endif
  #
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T     = [F:PIH]NUM
  #
  #-- X3suivi 71937 - T249 : Multi-Leg--#
  #Read [F:TPV]TPV0=[F:PIH]PIVTYP
  Local Integer WRET
  Local Char    WLEG (20)
  Call GETLEG([F:PIH]CPY,"G",WLEG) From TRTLECLEG
  Call LEC_TPV_LEG(WLEG,[F:PIH]PIVTYP,WRET) From TRTLECLEG
  #
  If [F:PIH]ORIMOD = 6 Then
    If [F:TPV]PIHTYP = 2 Then : #-- Fac. Complément.
      VCRTYP_T   = NUM_PIHC
    Else
      VCRTYP_T   = NUM_PIH
    Endif
  Else
    # FGR 24/10/2012 : X3SUIVI81498
    VCRTYP_T   = NUM_BIS
  Endif
  #
  If dim(PIH_L) >= 0 Then
    VCRLIN_T = PIH_L
  Endif
  VCRNUMCALC_T = [F:PIH]INVNUM
  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T = [F:PKW]VCRNUM
    VCRLINORI_T = [F:PKW]VCRLIN
    VCRTYPORI_T = [F:PKW]VCRTYP
  Endif
  IPTDAT_T     = [F:PIH]ACCDAT

  # Faire apparaître le statut de la pièce
  If [M:PIV1]VCRTYPSEL = NUM_PIH or [M:PIV1]VCRTYPSEL = NUM_PIHC Then
    # -------------------------------------------
    If VCRTYP_T = NUM_PIHC and [M:PIV1]VCRTYPSEL = NUM_PIH Then
      [M:PIV1]VCRTYPSEL = NUM_PIHC
      Affzo [M:PIV1]VCRTYPSEL
    Elsif VCRTYP_T = NUM_PIH and [M:PIV1]VCRTYPSEL = NUM_PIHC Then
      [M:PIV1]VCRTYPSEL = NUM_PIH
      Affzo [M:PIV1]VCRTYPSEL
    Endif
    # -------------------------------------------
    [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(509, [F:PIH]STA)
  Endif

  # FGR 06/02/2012 : X3SUIVI71269 (début)
  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(509, [F:PIH]STA)
  # FGR 06/02/2012 : X3SUIVI71269 (fin)

  SALFCY_T     = [F:PIH]FCY
  STOFCY_T     = ""
  BPRNUM_T     = [F:PIH]BPR
  JOU_T        = ""
  REP1_T       = ""
  REP2_T       = ""

  ACCNUM_T     = [F:PIH]ACCNUM
  DUDLIG_T     = 0

  CURS         = [F:PIH]CUR
  WCHGTYP      = [F:PIH]CURTYP
  ORDNOT_T     = [F:PIH]AMTNOT
  ORDATI_T     = [F:PIH]AMTATI
  SCURVCR_T    = [F:PIH]CUR
  WMNTORG(0)   = [F:PIH]AMTNOTL
  WMNTORG(1)   = [F:PIH]AMTATIL
  # Issue 83475 - 2012-07-19 by MUARN : conversion devise
  # CALC_MNT_FOLDER au lieu de CALC_MNT
  #Gosub CALC_MNT From CONSPITOOLS
  Call GETDEV(GFCY)  From DEVSUB
  ORDNOTL_T   = [F:PIH]AMTNOTL
  ORDATIL_T   = [F:PIH]AMTATIL
  Gosub CALC_MNT_FOLDER From CONSPITOOLS
  # fin Issue 83475 - 2012-07-19 by MUARN : conversion devise
Return

############################################################
$FILL_PIV
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T     = [F:PIH]NUM
  VCRTYP_T     = NUM_PIV
  If dim(PIV_L) >= 0 Then
    VCRLIN_T = PIV_L
  Endif
  VCRNUMCALC_T = [F:PIV]NUM
  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T = [F:PKW]VCRNUM
    VCRLINORI_T = [F:PKW]VCRLIN
    VCRTYPORI_T = [F:PKW]VCRTYP
  Endif
  IPTDAT_T     = [F:PIH]ACCDAT
  # FQ55971 - MABON 29/06/09 - Faire apparaître le statut de la pièce
  If [M:PIV1]VCRTYPSEL = NUM_PIV Then
    [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(509, [F:PIH]STA)
  Endif

  # FGR 06/02/2012 : X3SUIVI71269 (début)
  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(509, [F:PIH]STA)
  # FGR 06/02/2012 : X3SUIVI71269 (fin)

  SALFCY_T     = [F:PIH]FCY
  STOFCY_T     = ""
  BPRNUM_T     = [F:PIH]BPR
  JOU_T        = ""
  REP1_T       = ""
  REP2_T       = ""

  ACCNUM_T     = [F:PIH]ACCNUM
  DUDLIG_T     = 0

  CURS         = [F:PIH]CUR
  WCHGTYP      = [F:PIH]CURTYP
  ORDNOT_T     = [F:PIH]AMTNOT
  SCURVCR_T    = [F:PIH]CUR
  ORDATI_T     = [F:PIH]AMTATI
  WMNTORG(0)   = [F:PIH]AMTNOTL
  WMNTORG(1)   = [F:PIH]AMTATIL
  # Issue 83475 - 2012-07-19 by MUARN : conversion devise
  # CALC_MNT_FOLDER au lieu de CALC_MNT
  #Gosub CALC_MNT From CONSPITOOLS
  Call GETDEV(GFCY)  From DEVSUB
  ORDNOTL_T   = [F:PIH]AMTNOTL
  ORDATIL_T   = [F:PIH]AMTATIL
  Gosub CALC_MNT_FOLDER From CONSPITOOLS
  # fin Issue 83475 - 2012-07-19 by MUARN : conversion devise
Return

############################################################
$FILL_PNH
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T     = [F:PNH]PNHNUM
  VCRTYP_T     = NUM_PNH
  If dim(PNH_L) >= 0 Then VCRLIN_T = PNH_L Endif
  VCRNUMCALC_T = [F:PNH]PNHNUM
  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T = [F:PKW]VCRNUM
    VCRLINORI_T = [F:PKW]VCRLIN
    VCRTYPORI_T = [F:PKW]VCRTYP
  Endif
  IPTDAT_T     = [F:PNH]RTNDAT
  If [M:PIV1]VCRTYPSEL = NUM_PNH Then
    [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(280, [F:PNH]INVFLG)
  Endif

  # FGR 06/02/2012 : X3SUIVI71269 (début)
  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(280, [F:PNH]INVFLG)
  # FGR 06/02/2012 : X3SUIVI71269 (fin)

  SALFCY_T     = [F:PNH]PNHFCY
  STOFCY_T     = ""
  BPRNUM_T     = [F:PNH]BPSNUM
  JOU_T        = ""
  REP1_T       = ""
  REP2_T       = ""

  ORDNOT_T     = 0
  ORDATI_T     = 0
  SCURVCR_T    = ""
  ORDNOTL_T    = 0
  ORDATIL_T    = 0
  ORDNOTD_T    = 0
  ORDATID_T    = 0
Return

############################################################
$FILL_PTH
# Issue 84972 - 2012-10-08 by SR
Local Integer   WCLEFLG

  # sr 08.12 issue 79772
  If !clalev([F:PTD]) Then Local File PRECEIPTD [PTD] : Endif
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T     = [F:PTH]PTHNUM
  VCRTYP_T     = NUM_PTH
  If dim(PTH_L) >= 0 Then
    VCRLIN_T = PTH_L
  Endif
  VCRNUMCALC_T = [F:PTH]PTHNUM
  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T = [F:PKW]VCRNUM
    VCRLINORI_T = [F:PKW]VCRLIN
    VCRTYPORI_T = [F:PKW]VCRTYP
  Endif
  IPTDAT_T     = [F:PTH]RCPDAT
  # sr 08.12 issue 79772
  #----- Réajustement indicateur "facturée" si nécessaire -----#
  # FQ55971 - MABON 29/06/09 - Faire apparaître le statut de la pièce
  If [M:PIV1]VCRTYPSEL = NUM_PTH Then
      # Issue 84972 - 2012-10-08 by SR
      WCLEFLG=1
      If [F:PTH]INVFLG=3
           WCLEFLG=2
           Filter [F:PTD] Where (PTHNUM = [F:PTH]PTHNUM) & (INVQTYSTU < QTYSTU)
           If rowcount([F:PTD]) > 0
              [F:PTH]INVFLG=2
           Endif
           Filter [F:PTD]
     Endif
    [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(280, [F:PTH]INVFLG)
    [M:PIV1]VCRSTA_L = func CONSPITOOLS.GET_MESSAGE(1, [F:PTH]PSTFLG)
       # Issue 84972 - 2012-10-08 by SR
    [M:PIV1]VCRSTA_S = func CONSPITOOLS.GET_MESSAGE(1, WCLEFLG)
  Endif

  # FGR 06/02/2012 : X3SUIVI71269 (début)
  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(280, [F:PTH]INVFLG)
  STBVCRSTAT(2) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(1, [F:PTH]PSTFLG)
  # FGR 06/02/2012 : X3SUIVI71269 (fin)
  # Issue 84972 - 2012-10-08 by SR : ajouter le flag Solde
  STBVCRSTAT(3) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(1, WCLEFLG)

  SALFCY_T     = [F:PTH]PRHFCY
  STOFCY_T     = ""
  BPRNUM_T     = [F:PTH]BPSNUM
  JOU_T        = ""
  REP1_T       = ""
  REP2_T       = ""

  CURS         = [F:PTH]CUR
  WCHGTYP      = [F:PTH]CHGTYP
  ORDNOT_T     = [F:PTH]TOTAMTNOT
  ORDATI_T     = [F:PTH]TOTAMTATI
  SCURVCR_T    = [F:PTH]CUR
  WMNTORG(0)   = [F:PTH]TOTAMTNOTL
  WMNTORG(1)   = [F:PTH]TOTAMTATIL
  # Issue 83475 - 2012-07-19 by MUARN : conversion devise
  # CALC_MNT_FOLDER au lieu de CALC_MNT
  #Gosub CALC_MNT From CONSPITOOLS
  Call GETDEV(GFCY)  From DEVSUB
  ORDNOTL_T   = [F:PIH]AMTNOTL
  ORDATIL_T   = [F:PIH]AMTATIL
  Gosub CALC_MNT_FOLDER From CONSPITOOLS
  # fin Issue 83475 - 2012-07-19 by MUARN : conversion devise
Return

############################################################
$FILL_POC
  If !clalev([F:POHF]) Then Local File PORDER [POHF] : Endif
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T     = [F:POC]POHNUM
  VCRTYP_T     = NUM_POC
  If dim(POC_L) >= 0 Then
    VCRLIN_T = POC_L
  Endif
  VCRNUMCALC_T = [F:POC]POHNUM
  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T = [F:PKW]VCRNUM
    VCRLINORI_T = [F:PKW]VCRLIN
    VCRTYPORI_T = [F:PKW]VCRTYP
  Endif
  IPTDAT_T     = [F:POC]EARDAT

  # FQ55971 - MABON 29/06/09 - Faire apparaître le statut de la pièce
  If [M:PIV1]VCRTYPSEL = NUM_POC Then
    Read [F:POHF]POH0=[F:POC]POHNUM
    If !fstat Then
      [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(280, [F:POH]INVFLG)
      [M:PIV1]VCRSTA_L = func CONSPITOOLS.GET_MESSAGE(280, [F:POH]APPFLG)
      If [F:POH]ENDDAT < date$ Then
        [M:PIV1]VCRSTA_C = func CONSPITOOLS.GET_MESSAGE(1, G_OUI)
      Else
        [M:PIV1]VCRSTA_C = func CONSPITOOLS.GET_MESSAGE(1, G_NON)
      Endif
    Endif
  Endif

  # FGR 06/02/2012 : X3SUIVI71269 (début)
  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  Read [F:POHF]POH0=[F:POC]POHNUM
  If !fstat Then
    STBVCRSTAT(1) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(280, [F:POH]INVFLG)
    STBVCRSTAT(2) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(280, [F:POH]APPFLG)
    If [F:POH]ENDDAT < date$ Then
      STBVCRSTAT(3) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(1, G_OUI)
    Else
      STBVCRSTAT(3) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(1, G_NON)
    Endif
  Endif
  # FGR 06/02/2012 : X3SUIVI71269 (fin)

  SALFCY_T     = [F:POC]POHFCY
  STOFCY_T     = [F:POC]STOFCY
  BPRNUM_T     = [F:POC]BPSNUM
  JOU_T        = ""
  REP1_T       = ""
  REP2_T       = ""
  ORDNOT_T     = 0
  ORDATI_T     = 0
  SCURVCR_T    = ""
  ORDNOTL_T    = 0
  ORDATIL_T    = 0
  ORDNOTD_T    = 0
  ORDATID_T    = 0
Return

############################################################
$FILL_POH
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T     = [F:POH]POHNUM
  VCRTYP_T     = NUM_POH
  If dim(POH_L) >= 0 Then
    VCRLIN_T = POH_L
  Endif
  VCRNUMCALC_T = [F:POH]POHNUM
  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T = [F:PKW]VCRNUM
    VCRLINORI_T = [F:PKW]VCRLIN
    VCRTYPORI_T = [F:PKW]VCRTYP
  Endif
  IPTDAT_T     = [F:POH]ORDDAT
  # FQ55971 - MABON 29/06/09 - Faire apparaître le statut de la pièce
  If [M:PIV1]VCRTYPSEL = NUM_POH Then
    [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(280, [F:POH]INVFLG)
    [M:PIV1]VCRSTA_L = func CONSPITOOLS.GET_MESSAGE(280, [F:POH]APPFLG)
    [M:PIV1]VCRSTA_C = func CONSPITOOLS.GET_MESSAGE(1, [F:POH]CLEFLG)
    [M:PIV1]VCRSTA_S = func CONSPITOOLS.GET_MESSAGE(280, [F:POH]RCPFLG)
  Endif

  # FGR 06/02/2012 : X3SUIVI71269 (début)
  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(280, [F:POH]INVFLG)
  STBVCRSTAT(2) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(280, [F:POH]APPFLG)
  STBVCRSTAT(3) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(1, [F:POH]CLEFLG)
  STBVCRSTAT(4) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(280, [F:POH]RCPFLG)
  # FGR 06/02/2012 : X3SUIVI71269 (fin)

  SALFCY_T     = [F:POH]POHFCY
  STOFCY_T     = [F:POH]STOFCY
  BPRNUM_T     = [F:POH]BPSNUM
  JOU_T        = ""
  REP1_T       = ""
  REP2_T       = ""

  CURS         = [F:POH]CUR
  WCHGTYP      = [F:POH]CHGTYP
  ORDNOT_T     = [F:POH]TOTORD
  ORDATI_T     = [F:POH]TTVORD
  SCURVCR_T    = [F:POH]CUR
  WMNTORG(0)   = [F:POH]TOTORDL
  WMNTORG(1)   = [F:POH]TTVORDL
  # Issue 83475 - 2012-07-19 by MUARN : conversion devise
  # CALC_MNT_FOLDER au lieu de CALC_MNT
  #Gosub CALC_MNT From CONSPITOOLS
  Call GETDEV(GFCY)  From DEVSUB
  ORDNOTL_T   = [F:PIH]AMTNOTL
  ORDATIL_T   = [F:PIH]AMTATIL
  Gosub CALC_MNT_FOLDER From CONSPITOOLS
  # fin Issue 83475 - 2012-07-19 by MUARN : conversion devise
Return

############################################################
$FILL_DUD
  # FGR 09/02/2012 : X3SUIVI71269 : Même schéma que CNSPIV1STD.$FILL_DUD. Mais petites variantes
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T     = [F:DUD]NUMDUD
  If [F:DUD]TYP = "*PO" Then
    VCRTYP_T    = NUM_DUDA
  Else
    VCRTYP_T    = NUM_DUD
  Endif
  If dim(NUM_L) >= 0 Then
    VCRLIN_T = NUM_L
  Endif
  If [M:PIV1]TRKSEL = 1 Then
    # Amont
    #If dim(SIV_F) >= 0 Then
    If [F:PKW]VCRTYPORI = NUM_PIH Then
      # Facture
      VCRNUMCALC_T = [F:DUD]NUM
    Else
      VCRNUMCALC_T = [F:DUD]NUM
    Endif
  Else
    # Aval
    VCRNUMCALC_T = [F:DUD]NUM
  Endif
  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T = [F:PKW]VCRNUM
    VCRLINORI_T = [F:PKW]VCRLIN
    VCRTYPORI_T = [F:PKW]VCRTYP
  Endif
  IPTDAT_T     = [F:DUD]DUDDAT

  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(1, [F:DUD]FLGFUP)
  If [F:DUD]PAYCUR + [F:DUD]TMPCUR = 0 Then
    STBVCRSTAT(2) = func CONSPITOOLS.GET_MESSAGE(196, 1062)
  Elsif [F:DUD]PAYCUR + [F:DUD]TMPCUR < [F:DUD]AMTCUR Then
    STBVCRSTAT(2) = func CONSPITOOLS.GET_MESSAGE(196, 1063)
  Elsif [F:DUD]PAYCUR + [F:DUD]TMPCUR >= [F:DUD]AMTCUR Then
    STBVCRSTAT(2) = func CONSPITOOLS.GET_MESSAGE(196, 1064)
  Endif
  If [M:PIV1]VCRTYPSEL = NUM_DUD Then
    [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(1, [F:DUD]FLGFUP)
    If [F:DUD]PAYCUR + [F:DUD]TMPCUR = 0 Then
      [M:PIV1]VCRSTA_C = func CONSPITOOLS.GET_MESSAGE(196, 1062)
    Elsif [F:DUD]PAYCUR + [F:DUD]TMPCUR < [F:DUD]AMTCUR Then
      [M:PIV1]VCRSTA_C = func CONSPITOOLS.GET_MESSAGE(196, 1063)
    Elsif [F:DUD]PAYCUR + [F:DUD]TMPCUR >= [F:DUD]AMTCUR Then
      [M:PIV1]VCRSTA_C= func CONSPITOOLS.GET_MESSAGE(196, 1064)
    Endif
  Endif

  SALFCY_T     = [F:DUD]FCY
  STOFCY_T     = ""
  BPRNUM_T     = [F:DUD]BPR
  JOU_T        = ""
  REP1_T       = ""
  REP2_T       = ""

  ACCNUM_T     = [F:DUD]ACCNUM
  DUDLIG_T     = [F:DUD]DUDLIG

  # Issue 83475 - 2012-07-23 by MUARN : tracabilité piece achat conversion devise
  #CURS         = GLOCALDEV
  CURS         = [F:DUD]CUR

  If VCRTYP_T = NUM_DUDA Then
    # Commande
    Read [F:POH]POH0=[F:DUD]NUM
    WCHGTYP    = [F:POH]CHGTYP
  Else
    # Facture
    Read [F:PIH]PIH0=[F:DUD]NUM
    WCHGTYP    = [F:PIH]CURTYP
  Endif
  ORDNOT_T     = 0
  ORDATI_T     = [F:DUD]AMTCUR
  SCURVCR_T    = [F:DUD]CUR
  WMNTORG(0)   = 0
  WMNTORG(1)   = [F:DUD]AMTLOC
  # Issue 83475 - 2012-07-23 by MUARN : tracabilité piece achat conversion devise
  # CALC_MNT_FOLDER au lieu de CALC_MNT
  #Gosub CALC_MNT From CONSPITOOLS
  Call GETDEV(GFCY)  From DEVSUB
  ORDNOTL_T    = 0
  ORDATIL_T    = [F:DUD]AMTLOC
  Gosub CALC_MNT_FOLDER From CONSPITOOLS
  # fin Issue 83475 - 2012-07-23 by MUARN : tracabilité piece achat conversion devise
Return

############################################################
$FILL_PYH
  # FGR 09/02/2012 : X3SUIVI71269 : Identique à CNSPIV1STD.$FILL_PYH
  Gosub FILL_PYH From CNSPIV1STD
Return

############################################################
$FILL_HAE
  # FGR 09/02/2012 : X3SUIVI71269 : Identique à CNSPIV1STD.$FILL_HAE
  Gosub FILL_HAE From CNSPIV1STD
Return

############################################################
$FILL_PSH
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T     = [F:PSH]PSHNUM
  VCRTYP_T     = NUM_PSH
  If dim(PSH_L) >= 0 Then
    VCRLIN_T = PSH_L
  Endif
  VCRNUMCALC_T = [F:PSH]PSHNUM
  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T = [F:PKW]VCRNUM
    VCRLINORI_T = [F:PKW]VCRLIN
    VCRTYPORI_T = [F:PKW]VCRTYP
  Endif
  IPTDAT_T     = [F:PSH]PRQDAT
  # FQ55971 - MABON 29/06/09 - Faire apparaître le statut de la pièce
  If [M:PIV1]VCRTYPSEL = NUM_PSH Then
    [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(1, [F:PSH]CLEFLG)
    [M:PIV1]VCRSTA_L = func CONSPITOOLS.GET_MESSAGE(1, [F:PSH]ORDFLG)
    [M:PIV1]VCRSTA_C = func CONSPITOOLS.GET_MESSAGE(280, [F:PSH]APPFLG)
  Endif

  # FGR 06/02/2012 : X3SUIVI71269 (début)
  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(1, [F:PSH]CLEFLG)
  STBVCRSTAT(2) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(1, [F:PSH]ORDFLG)
  STBVCRSTAT(3) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(280, [F:PSH]APPFLG)
  # FGR 06/02/2012 : X3SUIVI71269 (fin)

  SALFCY_T     = [F:PSH]PSHFCY
  STOFCY_T     = ""
  JOU_T        = ""
  BPRNUM_T     = ""
  REP1_T       = ""
  REP2_T       = ""
  ORDNOT_T     = 0
  ORDATI_T     = 0
  SCURVCR_T    = ""
  ORDNOTL_T    = 0
  ORDATIL_T    = 0
  ORDNOTD_T    = 0
  ORDATID_T    = 0
Return

############################################################
$FILL_PQH
  If !clalev([F:PQF]) Then Local File PQUOTATF [PQF] : Endif
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T     = [F:PQH]PQHNUM
  VCRTYP_T     = NUM_PQH
  If dim(PQH_L) >= 0 Then
    VCRLIN_T = PQH_L
  Endif
  VCRNUMCALC_T = [F:PQH]PQHNUM
  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T = [F:PKW]VCRNUM
    VCRLINORI_T = [F:PKW]VCRLIN
    VCRTYPORI_T = [F:PKW]VCRTYP
  Endif
  IPTDAT_T     = [F:PQH]PQHDAT
  # FQ55971 - MABON 29/06/09 - Faire apparaître le statut de la pièce
  If [M:PIV1]VCRTYPSEL = NUM_PQH Then
    If [F:PQH]RSPDEA < date$ Then
      [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(1, G_OUI)
    Else
      [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(1, G_NON)
    Endif
  Endif

  # FGR 06/02/2012 : X3SUIVI71269 (début)
  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  If [F:PQH]RSPDEA < date$ Then
    STBVCRSTAT(1) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(1, G_OUI)
  Else
    STBVCRSTAT(1) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(1, G_NON)
  Endif
  # FGR 06/02/2012 : X3SUIVI71269 (fin)

  SALFCY_T     = [F:PQH]PQHFCY
  STOFCY_T     = ""
  JOU_T        = ""
  BPRNUM_T     = ""
  # MABON - FQ55623 - Récupération du fournisseur
  Filter [F:PQF] Where PQHNUM=VCRNUM_T
  Read [F:PQF]First
  If !fstat Then
    BPRNUM_T     = [F:PQF]BPSNUM
  Endif
  Filter [F:PQF]
  REP1_T       = ""
  REP2_T       = ""
  ORDNOT_T     = 0
  ORDATI_T     = 0
  SCURVCR_T    = ""
  ORDNOTL_T    = 0
  ORDATIL_T    = 0
  ORDNOTD_T    = 0
  ORDATID_T    = 0
Return

############################################################
$FILL_SCO
  If !clalev([F:SCI]) Then Local File SCOITM [SCI] : Endif
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T     = [F:SCO]SCONUM
  VCRTYP_T     = NUM_SCO
  If dim(SCO_L) >= 0 Then
    VCRLIN_T = SCO_L
  Endif
  VCRNUMCALC_T = [F:SCO]SCONUM
  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T = [F:PKW]VCRNUM
    VCRLINORI_T = [F:PKW]VCRLIN
    VCRTYPORI_T = [F:PKW]VCRTYP
  Endif
  IPTDAT_T     = [F:SCO]ORDDAT
  # FQ55971 - MABON 29/06/09 - Faire apparaître le statut de la pièce
  If [M:PIV1]VCRTYPSEL = NUM_SCO Then
    Filter [F:SCI] Where SCONUM=[F:SCO]SCONUM
    Read [F:SCI]First
    If !fstat Then
      [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(2238, [F:SCI]SCITRKFLG)
      [M:PIV1]VCRSTA_L = func CONSPITOOLS.GET_MESSAGE(2221, [F:SCI]ITMSTA)
      [M:PIV1]VCRSTA_C = func CONSPITOOLS.GET_MESSAGE(336, [F:SCO]ALLSTA)
    Endif
    Filter [F:SCI]
  Endif

  # FGR 06/02/2012 : X3SUIVI71269 (début)
  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  Filter [F:SCI] Where SCONUM=[F:SCO]SCONUM
  Read [F:SCI]First
  If !fstat Then
    STBVCRSTAT(1) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(2238, [F:SCI]SCITRKFLG)
    STBVCRSTAT(2) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(2221, [F:SCI]ITMSTA)
    STBVCRSTAT(3) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(336, [F:SCO]ALLSTA)
  Endif
  Filter [F:SCI]
  # FGR 06/02/2012 : X3SUIVI71269 (fin)

  SALFCY_T     = [F:SCO]POHFCY
  STOFCY_T     = ""
  BPRNUM_T     = [F:SCO]BPRNUM
  JOU_T        = ""
  REP1_T       = ""
  REP2_T       = ""
  ORDNOT_T     = 0
  ORDATI_T     = 0
  SCURVCR_T    = ""
  ORDNOTL_T    = 0
  ORDATIL_T    = 0
  ORDNOTD_T    = 0
  ORDATID_T    = 0
Return

############################################################
$FILL_CTRH
  # FGR 29/05/2015 : X3SUIVI104697   FLORENT ICI : voir pour les montants
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T     = [F:CTRH]CTRNUM
  VCRTYP_T     = NUM_CTRH
  VCRLIN_T     = 0

  VCRNUMCALC_T = [F:CTRH]CTRNUM

  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T = [F:PKW]VCRNUM
    VCRLINORI_T = [F:PKW]VCRLIN
    VCRTYPORI_T = [F:PKW]VCRTYP
  Endif
  IPTDAT_T     = [0/0/0]
  #
  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(1, [F:CTRH]FULFLG)
  STBVCRSTAT(2) += STBVCRSTAT(0) + [F:CTRH]SEANUM1
  If [M:PIV1]VCRTYPSEL = NUM_CTRH Then
    [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(1, [F:CTRH]FULFLG)
    [M:PIV1]VCRSTA_S = [F:CTRH]SEANUM1
  Endif
  #
  SALFCY_T     = [F:CTRH]FCY
  STOFCY_T     = ""
  BPRNUM_T     = [F:CTRH]BPSNUM
  JOU_T        = ""
  REP1_T       = ""
  REP2_T       = ""
  ORDNOT_T     = 0
  ORDATI_T     = 0
  SCURVCR_T    = ""
  ORDNOTL_T    = 0
  ORDATIL_T    = 0
  ORDNOTD_T    = 0
  ORDATID_T    = 0
Return

############################################################
$FILL_SHH
  # FGR 29/05/2015 : X3SUIVI104697   FLORENT ICI : voir pour les montants
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T     = [F:SHH]SHIPNUM
  VCRTYP_T     = NUM_SHH
  VCRLIN_T     = 0

  VCRNUMCALC_T = [F:SHH]SHIPNUM

  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T = [F:PKW]VCRNUM
    VCRLINORI_T = [F:PKW]VCRLIN
    VCRTYPORI_T = [F:PKW]VCRTYP
  Endif

  #IPTDAT_T     = [F:SHH]ARVEXPDAT
  IPTDAT_T     =  [F:SHH]SHIPDAT  #[F:SHH]ARVEXPDAT
  #
  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1) += STBVCRSTAT(0) + [F:SHH]DPECRY
  STBVCRSTAT(2) += STBVCRSTAT(0) + [F:SHH]DPECRY
  STBVCRSTAT(3) += STBVCRSTAT(0) + [F:SHH]ARVCRY
  If [M:PIV1]VCRTYPSEL = NUM_SHH Then
    [M:PIV1]VCRSTA = [F:SHH]DPECRY
    [M:PIV1]VCRSTA_S = [F:SHH]DPECRY
    [M:PIV1]VCRSTA_C = [F:SHH]ARVCRY
  Endif
  #
  SALFCY_T     = [F:SHH]FCY
  STOFCY_T     = ""
  BPRNUM_T     = [F:SHH]BPRNUM
  JOU_T        = ""
  REP1_T       = ""
  REP2_T       = ""
  ORDNOT_T     = 0
  ORDATI_T     = 0
  SCURVCR_T    = ""
  ORDNOTL_T    = 0
  ORDATIL_T    = 0
  ORDNOTD_T    = 0
  ORDATID_T    = 0
Return

############################################################
$FILL_TRNP
  # FGR 29/05/2015 : X3SUIVI104697   FLORENT ICI : voir pour les montants
  Gosub DECLARE_VAR From CNSPIVSTD
  VCRNUM_T     = [F:TRNP]TRNNUM
  VCRTYP_T     = NUM_TRNP
  VCRLIN_T     = 0

  VCRNUMCALC_T = [F:TRNP]TRNNUM

  If [F:PKW]VCRNUM <> "" Then
    VCRNUMORI_T = [F:PKW]VCRNUM
    VCRLINORI_T = [F:PKW]VCRLIN
    VCRTYPORI_T = [F:PKW]VCRTYP
  Endif
  IPTDAT_T     = [F:SHH]ARVEXPDAT
  #
  Call GET_TXT_STA_FROM_NUM(VCRTYP_T, STBVCRSTAT) From CNSPIVSTD
  STBVCRSTAT(1) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(2027, [F:TRNP]TRNMOD)
  STBVCRSTAT(2) += STBVCRSTAT(0) + func CONSPITOOLS.GET_MESSAGE(591, [F:TRNP]TRNSTA)
  STBVCRSTAT(3) += STBVCRSTAT(0) + format$("D:"+GFMDAT4,[F:TRNP]DPEDAT)
  STBVCRSTAT(4) += STBVCRSTAT(0) + format$("D:"+GFMDAT4,[F:TRNP]ARVEXPDAT)
  If [M:PIV1]VCRTYPSEL = NUM_TRNP Then
    [M:PIV1]VCRSTA = func CONSPITOOLS.GET_MESSAGE(2027, [F:TRNP]TRNMOD)
    [M:PIV1]VCRSTA_S = func CONSPITOOLS.GET_MESSAGE(591, [F:TRNP]TRNSTA)
    [M:PIV1]VCRSTA_C = format$("D:"+GFMDAT4,[F:TRNP]DPEDAT)
    [M:PIV1]VCRSTA_L = format$("D:"+GFMDAT4,[F:TRNP]ARVEXPDAT)
  Endif
  #
  SALFCY_T     = ""
  STOFCY_T     = ""
  BPRNUM_T     = [F:TRNP]BPTNUM
  JOU_T        = ""
  REP1_T       = ""
  REP2_T       = ""
  ORDNOT_T     = 0
  ORDATI_T     = 0
  SCURVCR_T    = ""
  ORDNOTL_T    = 0
  ORDATIL_T    = 0
  ORDNOTD_T    = 0
  ORDATID_T    = 0
Return

