#<AdxTL>@(#)0.0.0.0 $Revision$

###########################################################
## Génération de l'écran de feuille des temps
###########################################################
Subprog GENECR(APPLI,COD)
Value Char APPLI
Value Char COD
If clalev([F:AMK])=0  : Local File =APPLI+".AMSK"       [AMK]  : Endif
If clalev([F:AMZ])=0  : Local File =APPLI+".AMSKZON"    [AMZ]  : Endif
If clalev([F:AMA])=0  : Local File =APPLI+".AMSKACT"    [AMA]  : Endif
If clalev([F:AMP])=0  : Local File =APPLI+".AMSKPAR"    [AMP]  : Endif
Local File =APPLI+".AWINDOW"    [AWI]
If clalev([F:AWP])=0  : Local File =APPLI+".AWINPAR"    [AWP]  : Endif
If clalev([F:AWT])=0  : Local File =APPLI+".AWINBOUT"   [AWT]  : Endif
If clalev([F:AMK2])=0 : Local File =APPLI+".AMSK"       [AMK2] : Endif
If clalev([F:AMZ2])=0 : Local File =APPLI+".AMSKZON"    [AMZ2] : Endif
If clalev([F:AMA2])=0 : Local File =APPLI+".AMSKACT"    [AMA2] : Endif
If clalev([F:AMP2])=0 : Local File =APPLI+".AMSKPAR"    [AMP2] : Endif
If clalev([F:AWI2])=0 : Local File =APPLI+".AWINDOW"    [AWI2] : Endif
If clalev([F:AWP2])=0 : Local File =APPLI+".AWINPAR"    [AWP2] : Endif
If clalev([F:AWT2])=0 : Local File =APPLI+".AWINBOUT"   [AWT2] : Endif

If clalev([F:STH])=0  : Local File =APPLI+".SCRTPSH"    [STH]  : Endif
If clalev([F:STD])=0  : Local File =APPLI+".SCRTPSD"    [STD]  : Endif

If clalev([F:ADS])=0  : Local File ADOSSIER   [ADS]  : Endif

Local Char    MASKDES(GLONAMK) , MASKREF(GLONAMK)
Local Char    WINREF(GLONFEN) , WINDES(GLONFEN)
Local Integer NBRFLD, DIMFLD, OLDBLOC, NOLIG, NBRLIB, I, OK
MAXLIB = 24
Local Integer FLDOPT(1..50)
Local Char    FLDCOD(10)(1..50) : # Zones de la transaction à afficher dans l'écran de saisie
Local Decimal COL
#Si on valide la transaction à partir d'un autre dossier les globales ne sont pas correctes
Local Integer INBHOR
Read [ACV]CODACT = "HOR"
If !fstat & [F:ACV]FLACT=2
 INBHOR = max(0,[F:ACV]DIME)
Else
 INBHOR=0
Endif

MASKREF = "TPSJOU"
MASKDES = "WMJOU"+COD
WINREF  = "OTPSJOU"
WINDES  = "WFJOU"+COD

NBRFLD = 0
NBRLIB = 0 : # Nombre de libellé des zones

# FQ102773 -04/12/14 - Dorénavant, c'est le champ NBRHOU qui est sur la même ligne que le champ NBRDAY, de façon à ce que le champ
# Nature d'événement soit tout seul sur sa ligne. En revanche, si le champ NBRDAY est invisible, on met le champ NBRHOU tout seul
# sur la ligne
If clalev([F:STD2])=0 : Local File SCRTPSD [STD2] : Endif
Local Integer DECAL_NBRHOU : DECAL_NBRHOU=0
For [STD]STD0 Where COD=[L]COD & FLD<>"STRDAT" & FLD<>"ENDDAT" & OPT<>3 : # Champs non invisibles
 NBRFLD +=1
 FLDCOD(NBRFLD) = [F:STD]FLD
 FLDOPT(NBRFLD) = [F:STD]OPT
 If [F:STD]FLD="STRTIM" & INBHOR>1
  NBRLIB += INBHOR
  # FQ102773 -04/12/14 - Gestion du champ NBRHOU
# Elsif [F:STD]FLD<>"ENDTIM" & [F:STD]FLD<>"TYPPGN" : # Car ces 2 champs sont sur la même qu'un autre champ
# Elsif [F:STD]FLD<>"ENDTIM" & [F:STD]FLD<>"NBRHOU" : # Car ces 2 champs sont sur la même qu'un autre champ
 Elsif [F:STD]FLD<>"ENDTIM"  : # Car ces 2 champs sont sur la même qu'un autre champ
   If [F:STD]FLD="NBRHOU" Then
    Read [F:STD2]STD1=[L]COD;"NBRDAY"
    If [F:STD2]OPT=3 Then
      NBRLIB += 1
      DECAL_NBRHOU=1
    Endif
   Else
    NBRLIB += 1
   Endif
 Endif
Next

If NBRLIB>MAXLIB
#ADNGO - 2016-12-20 - X3-11636 - START
 # Ecran non généré pour la transaction YYY Nombre de zones limité à xxx lignes dans la feuille des temps
 #Call ECR_TRACE (mess(90,117,1)-[L]COD-"\"-mess(130,709,1)-num$(MAXLIB)-mess(184,709,1),1) From GESECRAN
 Call ECR_TRACE (mess(90,117,1)-[L]COD-"\"-mess(130,10709,1)-num$(MAXLIB)-mess(184,10709,1),1) From GESECRAN
#ADNGO - 2016-12-20 - X3-11636 - END
 GOK = 0 : End
Endif

Call TR_DELMSK(MASKDES,APPLI) From MSKDIV
If GOK=0 : End : Endif
Call TR_DELWIN(WINDES,APPLI) From MSKDIV
If GOK=0 : End : Endif
Call DEBTRANS From GLOCK
Gosub TR1
If GOK=0 : End : Endif

## Validation des écrans
Read [ADS]DOSSIER = APPLI
Call VALID(MASKDES,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,1,OK) From VALMSK
If !OK : GOK = 0 : End : Endif

## Validation fenêtre
Call VALID(WINDES,APPLI,0,OK) From VALWIN
If !OK : GOK = 0 : End : Endif

End


$TR1
GOK = 1
Trbegin [AMK]
# Création de l'écran de saisie
 Read [AMK2]CODMSK = MASKREF
 [F:AMK] = [F:AMK2]
 [F:AMK]CODMSK = MASKDES
 [F:AMK]MDL    = 1
 Write [AMK]
 If fstat : GOK=0 : Call FSTA("AMK") From GLOCK : Goto AB_TR1 : Endif
 I = 0
 NOLIG = 0
 For [AMZ2]CODZON Where CODMSK=MASKREF
  If [F:AMZ2]NUMBLOC=1 | [F:AMZ2]NUMBLOC=2 | [F:AMZ2]NUMBLOC=11
   NOLIG += 1
   [F:AMZ] = [F:AMZ2]
   [F:AMZ]CODMSK = MASKDES
   [F:AMZ]NUMLIG = NOLIG
   Write [AMZ]
   If fstat : GOK=0 : Call FSTA("AMZ") From GLOCK : Goto AB_TR1 : Endif
   Gosub COPIE_ACTION
   If GOK<1 : Break : Endif
  Elsif [F:AMZ2]NUMBLOC=3
   If val(right$([F:AMZ2]CODZON,4))<=NBRLIB
    NOLIG +=1
    [F:AMZ] = [F:AMZ2]
    [F:AMZ]CODMSK = MASKDES
    [F:AMZ]NUMLIG = NOLIG
    Write [AMZ]
    If fstat : GOK=0 : Call FSTA("AMZ") From GLOCK : Goto AB_TR1 : Endif
    Gosub COPIE_ACTION
    If GOK<1 : Break : Endif
   Endif
  Elsif [F:AMZ2]NUMBLOC>=4 & [F:AMZ2]NUMBLOC<=10
   If left$([F:AMZ2]CODZON,6)="STRTIM" | left$([F:AMZ2]CODZON,6)="ENDTIM"
    # Zone affichée ou saisissable
    I = find(left$([F:AMZ2]CODZON,6),FLDCOD(1..NBRFLD))
    J = val(right$([F:AMZ2]CODZON,len([F:AMZ2]CODZON)))
    If J<>1 & J>INBHOR
     I = 0
    Endif
   Else
    I = find(left$([F:AMZ2]CODZON,len([F:AMZ2]CODZON)-1),FLDCOD(1..NBRFLD))
   Endif
   If I
    If OLDBLOC<>[F:AMZ2]NUMBLOC
     OLDBLOC = [F:AMZ2]NUMBLOC
     COL     = 1.1
    Else
     # FQ102773 -04/12/14 - Le champ NBRHOU est sur la même ligne que le champ NBRDAY, sauf si celui-ci est invisible
     # Dans ce cas, NBRHOU est seul sur sa ligne
#      When "ENDTIM","TYPPGN" : COL = COL+0.1
     Case left$([F:AMZ2]CODZON,6)
      When "STRTIM"          : COL = fix(COL)+1+0.1
      When "ENDTIM"          : COL = COL+0.1
      When "NBRHOU"          : If !DECAL_NBRHOU Then COL = COL+0.1 : Else COL = fix(COL)+1+0.1 : Endif
      When Default           : COL = fix(COL)+1+0.1
     Endcase
    Endif
    NOLIG += 1
    [F:AMZ] = [F:AMZ2]
    [F:AMZ]CODMSK = MASKDES
    [F:AMZ]SAIAFF = FLDOPT(I)
    [F:AMZ]NOZONE = COL
    [F:AMZ]NUMLIG = NOLIG
    Write [AMZ]
    If fstat : GOK=0 : Call FSTA("AMZ") From GLOCK : Goto AB_TR1 : Endif
    Gosub COPIE_ACTION
    If GOK<1 : Break : Endif
   Endif
  Endif
 Next
 If GOK<1 : Goto AB_TR1 : Endif
# Création de la fenêtre de saisie
 Read [AWI2]AWI0 = WINREF
 [F:AWI] = [F:AWI2]
 [F:AWI]WIN       = WINDES
 [F:AWI]NOMMSK(0) = MASKDES
 [F:AWI]ENAFLG    = 2
 [F:AWI]MDL       = 1
 [F:AWI]TRN       = COD
 Read [STH]STH0=COD
 If !fstat
  [F:AWI]LIBEL    = [F:STH]DES
 Endif
 Write [AWI]
 If fstat
  GOK = 0 : Call FSTA("AWI") From GLOCK : Goto AB_TR1
 Endif
 For [AWP2]AWP0 Where WIN=WINREF
  [F:AWP] = [F:AWP2]
  [F:AWP]WIN = WINDES
  Write [AWP]
  If fstat
   GOK = 0 : Call FSTA("AWP") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR1 : Endif
 For [AWT2]AWT0 Where WIN=WINREF
  [F:AWT] = [F:AWT2]
  [F:AWT]WIN = WINDES
  Write [AWT]
  If fstat
   GOK = 0 : Call FSTA("AWT") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return


$COPIE_ACTION
For [AMA2] Where TYPAFF=1 & CODAFF=MASKREF & CODZON=[F:AMZ]CODZON
 [F:AMA] = [F:AMA2]
 [F:AMA]CODAFF = MASKDES
 Write [AMA]
 If fstat
  GOK=0 : Call FSTA("AMA") From GLOCK : Break
 Endif
Next
If GOK<1 : Return : Endif
For [AMP2] Where TYPAFF=1 & CODAFF=MASKREF & CODZON=[F:AMZ]CODZON
 [F:AMP] = [F:AMP2]
 [F:AMP]CODAFF = MASKDES
 Write [AMP]
 If fstat
  GOK=0 : Call FSTA("AMP") From GLOCK : Break
 Endif
Next
If   GOK<1 : Return : Endif
Return

$AB_TR1
Rollback
Return

