#<AdxTL>@(#)0.0.0.0 $Revision$Class Project  
# Supervisor
## CRUD-CLASSE ## PROJET
# 2018-11-06 07:13:51 203

Gosub TEST From WMCR_PROJET : End

############################################################################################
## R : Subprog AREAD(INSTANCE,PRJ)
############################################################################################
# PROJET : PROJET
# PRJLOT : PROJET PRJLOT
# PRJFAS : PROJET PRJFAS
############################################################################################

############################################################################################
### AVARIABLES
############################################################################################
$AVARIABLES
[L]ASTATUS =max([L]ASTATUS,fmet PROJET._ADELERRORS([V]CST_ALLERRORS))
$_AVARIABLES
Local    Integer     A_LEVEL,A_I,A_NEWCOL,A_N1,A_N2,A_S2,A_N3,A_S3
Local    Integer    ASTATUS,A_RETIK,A_TYPMAJ,A_ASTALIN
Local    Char        A_STRSITE(GLONFCY),A_STRACC(GLONACS),CURPRO(50),A_PARENT(50),A_PATH(200),A_ABR(GLONABR),A_ERROR(250)
Local    Uuident    A_UUID

[L]A_LEVEL    = PROJET.ACTX.LEVWML
[L]ASTATUS  = 0

Onerrgo ERR_OPENTAB
If find(PROJET.ACTX.AFOLDER,nomap,"")>0
 Local File PROJET [PRJ]
 Local File PRJLOT [PJL]
 Local File PRJFAS [PJF]
 Local File ATEXTRA [AXX]
Else
 Local File =PROJET.ACTX.AFOLDER+".PROJET" [PRJ]
 Local File =PROJET.ACTX.AFOLDER+".PRJLOT" [PJL]
 Local File =PROJET.ACTX.AFOLDER+".PRJFAS" [PJF]
 Local File =PROJET.ACTX.AFOLDER+".ATEXTRA" [AXX]
Endif
Onerrgo
Return

$ERR_OPENTAB
[L]ASTATUS = max([L]ASTATUS,fmet PROJET.ASETERROR("",errp+"("+num$(errl)+")"-mess(6,123,1)-num$(errn)-errmes$(errn)-errm,[V]CST_AERROR))
Resume

############################################################################################
### Link
############################################################################################
$AOPEN_LINK
Gosub AVARIABLES
Link [PRJ] With
& [PJL]PJL0 = [F:PRJ]PRJ,
& [PJF]PJF0 = [F:PRJ]PRJ
& As [LNK_]
Return



