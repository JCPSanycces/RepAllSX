#<AdxTL>@(#)0.0.0.0 $Revision$ Object management GSTGRP
######################################################################################
# Handling of screens GSTGRPH / GSTGRPD : GST groups (for Australian GST reporting)
# Caution, this screen is managed with hybrid code
# If you change something, be sure that you don't have to change the class
# Classes : GSTGRP and GSTGRPD
# Treatments : GSTGRP_CSTD, GSTGRPD_CSTD
# Author : Bader
# History:
# 2018-01-17 Bader X3-71755 LIENS: disable filed "Reporting period" if at least one reporting period exists for group
######################################################################################

$ACTION
    Case ACTION
        When "OUVRE"        : Gosub OUVRE
        When "RAZCRE"       : Gosub RAZCRE
        When "RAZDUP"       : Gosub RAZDUP
        When "LIENS"        : Gosub LIENS
        When "APRES_MOD"    : Gosub APRES_MOD
        When "APRES_CRE"    : Gosub APRES_CRE
        When "DEFLIG"       : Gosub DEFLIG
        When "AV_ANNULE"    : Gosub AV_ANNULE
        When "ANNULE"       : Gosub ANNULE
        When "CREATION"     : Gosub CREATION
        When "MODIF"        : Gosub MODIF
        When "INICRE_LIG"   : Gosub INICRE_LIG
        When "LIENS_LIG"    : Gosub LIENS_LIG
        When "VALLIG"       : Gosub VALLIG
        When "FERME"        : Gosub FERME
        When Default
    Endcase
Return

$DECL_VAR_LOCAL
#----------------------------------#
# Local variable declaration       #
#----------------------------------#
Local  Integer  I
Local  Shortint NOL
Local  Integer MY_STATUS, WRET
Return

#-------------------------------------------------------------#
$DEFLIG
#----------------------------------#
# Lines file definition            #
#----------------------------------#
Default Mask [GSTGD]
Default File [GSTGD]
CRIT   = 'CODGSTGRP="'+[M:GSTGH]CODGSTGRP+'"'
FICLIG = "GSTGRPD"
ABLIG  = "GSTGD"
ZONLIG = "LIN"
Return

#-------------------------------------------------------------#
$VALLIG
#---------------------------------------------------------------#
# After each creation, modification or deletion lines           #
#---------------------------------------------------------------#
Case TRTLIG
  When  "C"   Gosub VALLIG_CRE
  When  "M"   Gosub VALLIG_UPD
  When  "A"   Gosub VALLIG_DEL
Endcase
Return

#-------------------------------------------------------------#
$VALLIG_CRE
#--------------------------------#
# After creation lines           #
#--------------------------------#
Gosub INS_LIG
Return
#-------------------------------------------------------------#

$VALLIG_UPD
#--------------------------------#
# After modification lines       #
#--------------------------------#
If SIGN = -1 Gosub UPD_LIG Endif
Return

#-------------------------------------------------------------#
$VALLIG_DEL
#--------------------------------#
# After deletion lines           #
#--------------------------------#
If GREP <> "A" Gosub DEL_LIG : Endif
Return

#-------------------------------------------------------------#
$INS_LIG
#---------------------------------------#
# Insert one line in container class    #
#---------------------------------------#
Local Integer WPOS
WPOS = fmet WGSTGRP.ADDLINE("LINES",[V]CST_ALASTPOS)
If WPOS = [V]CST_ANOTDEFINED
  #--The insertion was not possible
  GMESSAGE = func ASYRFNC.MES2(mess(266,133,1),'LINES','CODGSTGRP')
  GOK=0 : GERR=1
  Return
Endif
WGSTGRP.LINES(WPOS).CODGSTGRP = [M:GSTGH]CODGSTGRP
WGSTGRP.LINES(WPOS).LIN       = [M:GSTGD]LIN(nolign-1)
WGSTGRP.LINES(WPOS).CPY       = [M:GSTGD]CPY(nolign-1)
WGSTGRP.LINES(WPOS).GSTHEA    = [M:GSTGD]GSTHEA(nolign-1)
WGSTGRP.LINES(WPOS).ABN       = [M:GSTGD]ABN(nolign-1)
WGSTGRP.LINES(WPOS).DATFOR    = [M:GSTGD]DATFOR(nolign-1)
WGSTGRP.LINES(WPOS).DATCES    = [M:GSTGD]DATCES(nolign-1)
Return

#-------------------------------------------------------------#
$DEL_LIG
#---------------------------------------#
# Delete one line in container class    #
#---------------------------------------#
Local Integer WPOS, WRET
Raz WRET
#--- Find the AUUID of the del line
WPOS = find([F:GSTGD]AUUID, WGSTGRP.LINES(1..maxtab(WGSTGRP.LINES)).AUUID)
If WPOS <> 0
  WRET=fmet WGSTGRP.ADELLINE ("LINES", WGSTGRP.LINES(WPOS).AORDER)
  If WRET>=[V]CST_AERROR
    GMESSAGE = func ASYRFNC.MES2(mess(273,133,1),'LINES','CODGSTGRP')
    GOK=0 : GERR=1
    Return
  Endif
Endif
Return

#-------------------------------------------------------------#
$UPD_LIG
#---------------------------------------#
# Update one line in container class    #
#---------------------------------------#
Local Integer WPOS
#--- Find the AUUID of the update line
WPOS = find([F:GSTGD]AUUID, WGSTGRP.LINES(1..maxtab(WGSTGRP.LINES)).AUUID)
  If WPOS <> 0
    #--- Affect new values(M class) in the container class
    WGSTGRP.LINES(WPOS).CODGSTGRP = [M:GSTGH]CODGSTGRP
    WGSTGRP.LINES(WPOS).LIN       = [M:GSTGD]LIN(nolign-1)
    WGSTGRP.LINES(WPOS).CPY       = [M:GSTGD]CPY(nolign-1)
    WGSTGRP.LINES(WPOS).GSTHEA    = [M:GSTGD]GSTHEA(nolign-1)
    WGSTGRP.LINES(WPOS).ABN       = [M:GSTGD]ABN(nolign-1)
    WGSTGRP.LINES(WPOS).DATFOR    = [M:GSTGD]DATFOR(nolign-1)
    WGSTGRP.LINES(WPOS).DATCES    = [M:GSTGD]DATCES(nolign-1)
  Endif
Return

#-------------------------------------------------------------#
$INICRE_LIG
#----------------------------#
# Before line write          #
#----------------------------#
Return

#-------------------------------------------------------------#
$OUVRE
#-------------------------------#
# before the Window opening     #
#-------------------------------#
#--- To use the class CRUD instead of the object CRUD
ANOWRITE = 1
#---
Local File GSTGRPD  [GSTGD1]
#---- Local variables
Gosub DECL_VAR_LOCAL
#--- Array variables
Gosub DECLARE From TABLEAUX
#--- Container class : global for sub prog ANUCOD
Global Instance WGSTGRP Using C_GSTGRP
Return

#-------------------------------------------------------------#
$RAZCRE
If WGSTGRP<> null : FreeGroup WGSTGRP :Endif
#--- Class instanciation
WGSTGRP = NewInstance C_GSTGRP AllocGroup null
[L]MY_STATUS = fmet WGSTGRP.AINIT()
If [L]MY_STATUS >= [V]CST_AERROR
  #--- Header errors
  GMESSAGE = func LCCLIB.MAXMSG(WGSTGRP)
  If GMESSAGE <> AVOID.ACHAR :  GOK=0 : GERR=1: Return
  Endif
Endif
SetInstance [F:GSTGH] With WGSTGRP
[M:GSTGH] = [F:GSTGH]
Actzo [M:GSTGH]CODGSTGRP              # enable field "GST group" in creation mode
Affzo [M:GSTGH]1-99
Return

#-------------------------------------------------------------#
$RAZDUP
If WGSTGRP<> null : FreeGroup WGSTGRP :Endif
#--- Class instanciation
WGSTGRP = NewInstance C_GSTGRP AllocGroup null
[L]MY_STATUS = fmet WGSTGRP.AINIT()
If [L]MY_STATUS >= [V]CST_AERROR
  #--- Header errors
  GMESSAGE = func LCCLIB.MAXMSG(WGSTGRP)
  If GMESSAGE <> AVOID.ACHAR :  GOK=0 : GERR=1: Return
  Endif
Endif
SetInstance [F:GSTGH] With WGSTGRP
[M:GSTGH] = [F:GSTGH]
Affzo [M:GSTGH]1-99
Return

#-------------------------------------------------------------#
$CREATION
#----------------------------------#
# Container creation               #
#----------------------------------#
Local Integer I
# Collection reinit in case of modification after a first creation with error
For I=1 To maxtab(WGSTGRP.LINES)
  If (WGSTGRP.LINES(I) <> null and find(WGSTGRP.LINES(I).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL) = 0)
    WRET=fmet WGSTGRP.ADELLINE ("LINES", WGSTGRP.LINES(I).AORDER)
    If WRET<>[V]CST_AOK
      GMESSAGE = func ASYRFNC.MES2(mess(273,133,1),'LINES','CODGSTGRP')
      GOK=0 : GERR=1
      Return
    Endif
  Endif
Next
Gosub CREATION From TABLEAUX
If GOK<1 : Return : Endif
#--- Assign the class properties
SetInstance WGSTGRP With [F:GSTGH]
WGSTGRP.CODGSTGRP = [M:GSTGH]CODGSTGRP
WGSTGRP.DES = [M:GSTGH]DES
#--- AINSERT method
MY_STATUS = fmet WGSTGRP.AINSERT()
If [L]MY_STATUS >= [V]CST_AERROR
  Call GET_ERRORS(WGSTGRP)
  If GOK=0 : Return : Endif
Endif
SetInstance [F:GSTGH] With WGSTGRP
Gosub LIENS
Return

#-------------------------------------------------------------#
$MODIF
#--------------------------------------#
# Modification container               #
#--------------------------------------#
Local Integer I
# Collection reinit in case of modification after a first creation with error
For I=1 To maxtab(WGSTGRP.LINES)
  If (WGSTGRP.LINES(I) <> null and find(WGSTGRP.LINES(I).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL, [V]CST_ALL) = 0)
    WRET=fmet WGSTGRP.ADELLINE ("LINES", WGSTGRP.LINES(I).AORDER)
    If WRET<>[V]CST_AOK
      GMESSAGE = func ASYRFNC.MES2(mess(273,133,1),'LINES','CODGSTGRP')
      GOK=0 : GERR=1
      Return
    Endif
    Endif
Next
Gosub MODIF From TABLEAUX : If GOK<1  Return : Endif

#--- Assign the Syracuse class with [M]class
SetInstance WGSTGRP With [F:GSTGH]
WGSTGRP.CODGSTGRP = [M:GSTGH]CODGSTGRP
WGSTGRP.DES = [M:GSTGH]DES
#--- AUPDATE method
MY_STATUS = fmet WGSTGRP.AUPDATE()
If [L]MY_STATUS >= [V]CST_AERROR
  Call GET_ERRORS(WGSTGRP)
  If GOK=0 : Return : Endif
Endif
Return

#-------------------------------------------------------------#
$AV_ANNULE
#--- Must define again ANOWRITE because of subprog ANUCOD
ANOWRITE = 1
Return

#-------------------------------------------------------------#
$ANNULE
#--------------------------------------#
# Deletion container                   #
#--------------------------------------#
# NOTE (DNE): Data writing is disabled because ANOWRITE = 1!
Gosub ANNULE From TABLEAUX
#--- ADELETE method
MY_STATUS = fmet WGSTGRP.ADELETE()
If [L]MY_STATUS >= [V]CST_AERROR
  Call GET_ERRORS(WGSTGRP)
  If GOK=0 : Return : Endif
Endif
Return

#-------------------------------------------------------------#
$FERME
#--- Free instance
If WGSTGRP<> null
  FreeGroup WGSTGRP
Endif
Kill WGSTGRP
Return

#-------------------------------------------------------------#
$APRES_CRE
Gosub LIENS From TABLEAUX
Return

#-------------------------------------------------------------#
$APRES_MOD
Gosub LIENS From TABLEAUX
Return

#------------------------------------#
$LIENS
#------------------------------------#
#--- Free instance
If WGSTGRP<> null  : FreeGroup WGSTGRP :Endif
#--- class instantiation
WGSTGRP = NewInstance C_GSTGRP AllocGroup null
#--- Read method
WRET = fmet WGSTGRP.AREAD([M:GSTGH]CODGSTGRP)
If WRET >= [V]CST_AERROR
  Call GET_ERRORS(WGSTGRP)
  If GOK=0 : Return : Endif
Endif
Gosub LIENS From TABLEAUX

If !clalev([F:GSTPH]) Local File GSTPER [GSTPH] Endif
Filter [F:GSTPH] Where CODGSTGRP = [M:GSTGH]CODGSTGRP  # check if at least one period exists for group
If rowcount([F:GSTPH]) > 0                             # period exists > disable "Reporting period" field
    Diszo [M:GSTGH]GSTPER
Else
    Actzo [M:GSTGH]GSTPER
Endif
Filter [F:GSTPH]
Diszo [M:GSTGH]CODGSTGRP              # disable field "GST group" if not in creation mode
Return

#------------------------------------#
$LIENS_LIG
#------------------------------------#
Return

#------------------------------------#
#--- Get the errors                  #
#------------------------------------#
Subprog GET_ERRORS(WGSTGRP)
Variable Instance WGSTGRP Using C_GSTGRP
Local Integer I
Local Char WTEXTE(50)

 GMESSAGE = func LCCLIB.MAXMSG(WGSTGRP)
 If GMESSAGE = AVOID.ACHAR
   #--- Lines errors
  For I=1 To maxtab(WGSTGRP.LINES)
    GMESSAGE = func LCCLIB.MAXMSG(WGSTGRP.LINES(I))
    If GMESSAGE <> AVOID.ACHAR
      Call TEXTE(53658, WTEXTE) From OBJDIV
      GMESSAGE = WTEXTE + " : " + GMESSAGE
      Break:  Endif
  Next I
Endif
GOK=0 : GERR=1
End




######################################################################################

# 2018-01-09 DNE INSERT BEGIN
Subprog AP_CPY(VALEUR)
Variable Char    VALEUR()

    # Note: The "Classic" way is easier than to use the class instance's LINES collection
    #       for you have to find the correct index.
    Local File COMPANY [CPY]

    # Optimization for we use the company's database record in CONTROL and PROPAGATE.
    Call LEC_CPY( VALEUR ) From CPTLEC
    If !fstat
        [M:GSTGD]ABN( nolign - 1 ) = [F:CPY]CRN
        Affzo [M:GSTGD]ABN( nolign - 1 )
    Endif
End
# 2018-01-09 DNE INSERT END

