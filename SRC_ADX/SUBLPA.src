#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion du fichier LIVREPAYE
Raz GPILOBJ
Call OBJET("LPA",GBIDC1,GBIDC1) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "FERME"       : Gosub FERME
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEACT"      : Gosub EXEACT
 When "LIENS"       : Gosub LIENS
 When "CREATION"   : Gosub CREATION
 When "MODIF"      : Gosub MODIF
 When "ANNULE"     : Gosub ANNULE
 When "AP_CHANGE"  : Gosub AP_CHANGE
 When "AS_COD"      : Gosub AS_COD
 When "BS_COD"      : Gosub BS_COD
Endcase
Return

$OUVRE
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#Before selection on field COD
#############
$AS_COD
Raz GCURLEG
Return

#After selection on field COD
############
$BS_COD
# To do nothing if the user doesn't select a record
If [F:LPA]COD<>"" :
 mkstat=4                     # mkstat=4 to load again the record after selection
 If dim([M:LPA1]LEG)>=0 : [M:LPA1]LEG=[F:LPA]LEG: Endif
 GCURLEG=[F:LPA]LEG
Else
 # Else we need to update GCURLEG becaude we erased it in $AS_COD
 If dim([M:LPA1]LEG)>=0
  GCURLEG=[M:LPA1]LEG
 Elsif GLEFIL<>""
  GCURLEG=GLEGFIL
 Else
  GCURLEG=GDOSLEG
 Endif
Endif
Return

$LIENS
GCURLEG=[F:LPA]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
Call LECTEXTRA([M]DES,"LIVREPAYE","DES",GCURLEG,[M]COD) From ATEXTRA
Return

$SETBOUT
# 39925
# If !CLECUR or REP<>""
If !CLECUR or REP<>"" or GHISTO=1
 Call VIREBOUT(CHAINE,"8") From GOBJET
Else
 CHAINE += "E"
Endif
Return

$EXEACT
Case BOUT
 When "I"
  Local Char TBPAR(20)(1..10) , TBVAL(20)(1..10)
  TBPAR(1) = "livre"
  TBVAL(1) = CLECUR1
  TBPAR(2) = "leg"
  TBVAL(2) = CLECUR2
  Call ETAT("LIVREPAYE",GFONCTION,TBPAR,TBVAL) From ETAT
Endcase
Return


########################################
$CREATION
$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

########################################
# To manage translated texts (data type AX3 & AX1) in cretion and duplication
$TEXTRA
If GREP="D"
 ## In duplication mode we want to keep all translated texts
 Call DUPTEXTRA("LIVREPAYE","DES",CLECUR1,"","LIVREPAYE","DES",GCURLEG,[F:LPA]COD) From ATEXTRA
Endif
Call MAJTEXTRA([M]DES,"LIVREPAYE","DES",GCURLEG,[F:LPA]COD) From ATEXTRA
Return

########################################
$AP_CHANGE
# To change translated texts (data type AX3 & AX1) when you change the main code
Call CHGTEXTRA("LIVREPAYE","DES",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Return

########################################
# To delete translated texts (data type AX3 & AX1)
$ANNULE
Call SUPTEXTRA("LIVREPAYE","DES",SUPP,[L]CODE) From ATEXTRA
Return

########################################
$SEL_TABLE
#Tax band
Local Char    PARMSK(250)(1..20) , SAVACT(20)
Case TABLE
 When "SELLPA"
 #JOJAC - 2016-07-06 - REQ114309 US74 - START
  #Case [M:LPA1]TYPAMT(nolign-1)
   #When 1,2,3,4,5,13,14,15,16,17,18
    Case [M]TYPAMT(nolign-1)
    When 1,2,3,4,5,13,14,15,16,17,18,10,11,12
    #JOJAC - 2016-07-06 - REQ114309 US74 - END
    OBJET = "RUB"
    If [M:LPA1]TYPAMT(nolign-1)=2
     Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'(([F:RUB]TYPRUB=6)|([F:RUB]TYPRUB=2 & RAT2<>"")|([F:RUB]TYPRUB=3 & RAT2<>""))',"&") From GOBJSUB
    Elsif [M:LPA1]TYPAMT(nolign-1)<>1
     Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:RUB]TYPRUB=5)',"&") From GOBJSUB
    Endif
   When 6
    OBJET = "CUM"
     Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:CUM]CUMTMP<>2)',"&") From GOBJSUB
   When 7
    OBJET = "VRA"
   Endcase
  VALEUR = toupper(VALEUR)
Endcase
Return

########################################
Subprog C_CRI(VALEUR)
Variable Char    VALEUR()
Local Char CHAMP(20) , ABREV(10)
CHAMP = toupper(VALEUR)
K = instr(1,CHAMP,"]")
If K
 ABREV = seg$(CHAMP,2,K-1)
 CHAMP = right$(CHAMP,K+1)
 If left$(ABREV,2)="F:"
  ABREV = right$(ABREV,3)
 Endif
 If toupper(ABREV)="VEP"
  Read [ATZ]CODZONE = "VALEMP";CHAMP
  If !fstat
   VALEUR = "[F:VEP]"+CHAMP
   End
  Endif
 Endif
Endif
Read [DIC]DIC0 = CHAMP
#JOJAC - 2016-07-06 - REQ114309 US74 - START
#If fstat
If fstat | left$([F:DIC]TBL,5)<>"EMPLO"
#JOJAC - 2016-07-06 - REQ114309 US74 - END
 GMESSAGE = mess(41,100,1) : # Champ inexistant
 mkstat = 2 : End
Endif
Read [ATB]CODFIC = [F:DIC]TBL
VALEUR = "[F:"+[F:ATB]ABRFIC+"]"+CHAMP
End

Subprog AS_BASE(VALEUR)
Variable Integer VALEUR
# Pas de base pour cumul, variable et Aucun
If find([M]TYPAMT(nolign-1),6,7,8,9)
 mkstat = 2
Endif
End

Subprog AS_RUBCOD(VALEUR)
Variable Char    VALEUR()
If [M]TYPAMT(nolign-1)=8 : mkstat = 1 : End : Endif
If [M]TYPAMT(nolign-1)<>9
 Raz GBOUT1,GBOUT2,GBOUT3,GBOUT4,GBOUT5,GBOUT6
Endif
End

Subprog C_RUBCOD(VALEUR)
Variable Char    VALEUR()
If [M]TYPAMT(nolign-1)=9
 VALEUR = vireblc(format$("KT:250X",VALEUR),2)
Else
 VALEUR = toupper(VALEUR)
Endif
#Tax band
Case [M]TYPAMT(nolign-1)
 When 1,2,3,4,5,13,14,15,16,17,18
  VALEUR = left$(VALEUR,GLONRUB)
  Call CONTROLE("RUB","",VALEUR,GCURLEG,mkstat) From CONTOBJ
 When 6
  VALEUR = left$(VALEUR,GLONCUM)
  Call CONTROLE("CUM","",VALEUR,GCURLEG,mkstat) From CONTOBJ
 When 7
  VALEUR = left$(VALEUR,GLONVRA)
  Call CONTROLE("VRA","",VALEUR,GCURLEG,mkstat) From CONTOBJ
 When 9
  Call CONTFRM(VALEUR) From SUBRUB
  If !mkstat
   Call CONTVAL(VALEUR)
  Endif
Endcase
If mkstat : End : Endif
#Tax band
Case [M]TYPAMT(nolign-1)
 When 2
  Read [F:RUB]RUB0=GCURLEG;VALEUR
   If [F:RUB]TYPRUB<>6 & [F:RUB]TYPRUB<>10 & [F:RUB]TYPRUB<>2 & [F:RUB]TYPRUB<>3 :#Cotisation et Régularisation et Montant=Base*taux (/100)
   GMESSAGE = mess(47,10703,1) : # Ce n'est pas une cotisation
   mkstat = 2 : End
  Endif
 When 3,4,5,13,14,15,16,17,18
  Read [F:RUB]RUB0=GCURLEG;VALEUR
  If [F:RUB]TYPRUB<>5
   GMESSAGE = mess(46,10703,1) : # Ce n'est pas une assiette de cotisation
   mkstat = 2 : End
  Endif
 When 6
  Read [F:CUM]CUM0=GCURLEG;VALEUR
  If [F:CUM]CUMTMP=2
   GMESSAGE = mess(48,10703,1) : # Cumul intermédiaire
   mkstat = 2 : End
  Endif
Endcase
End

Subprog AS_DESCOL(VALEUR)
Variable Char    VALEUR()
If [M]TYPAMT(nolign-1)=8 : mkstat = 1 : End : Endif
End

Subprog APRES_NBRCOL
Local Integer I , J , K , L , NOL
NOL = nolign-1
If find(status,65,68,83)
 For I=0 To [M]NBRCOL-1
  L = 0
  If [M]TYPAMT(I)=9
   For J=NOL+1 To 99
    K = 0
    Repeat
     K = instr(K+1,[M]RUBCOD(I),"F0"+num$(J))
     If K
      [M]RUBCOD(I) = left$([M]RUBCOD(I),K-1)+"F0"+num$(J-1)+right$([M]RUBCOD(I),K+3)
      L = 1
     Endif
    Until K=0
   Next J
  Endif
  If L
   Affzo RUBCOD(I)
  Endif
 Next I
Elsif [M]STA(NOL)=73
 For I=0 To [M]NBRCOL-1
  L = 0
  If [M]TYPAMT(I)=9
   For J=99 To NOL+1 Step -1
    K = 0
    Repeat
     K = instr(K+1,[M]RUBCOD(I),"F0"+num$(J))
     If K
      [M]RUBCOD(I) = left$([M]RUBCOD(I),K-1)+"F0"+num$(J+1)+right$([M]RUBCOD(I),K+3)
      L = 1
     Endif
    Until K=0
   Next J
  Endif
  If L
   Affzo RUBCOD(I)
  Endif
 Next I
Endif
[M]STA(NOL) = 0
End

Subprog AVANT_NBRCOL
[M]STA(nolign-1) = status
End


#Tax band
Subprog CONTVAL(FORMULE)
Variable Char FORMULE
Local Integer I , J , T , OK, K
Local Char    OP2(2) , OP3(3) , OP(3) , CODE(80)
I = 0
While I<=len(FORMULE)-1
 OP2 = mid$(FORMULE,I,2)
 OP3 = mid$(FORMULE,I,3)
 T = 0
 #65041
 If find(OP2,"R_","V_","C_","B_")
  T = 1 : J = I+2 : I += 2 : OP = OP2
 Endif
 If find(OP3,"TA_","TB_","TC_","EA_","EB_","EC_","[F]","TD_","TE_","TF_","TG_","TH_","TI_","ED_","EE_","EF_","EG_","EH_","EI_")
  T = 1 : J = I+3 : I += 3 : OP = OP3
 Endif
 If find(OP3,"[F:")
  # Expression incorrecte Remplacer par : [F]
  GMESSAGE = mid$(FORMULE,I,7)-mess(37,124,1)-"\"-mess(28,9802,1)-"[F]"
  mkstat = 2 : Break
 Endif
 If T
  While I<len(FORMULE) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_",mid$(FORMULE,I+1,1))
   I += 1
  Wend
  CODE = seg$(FORMULE,J,I)
  Case OP
   When "R_","TA_","TB_","TC_","EA_","EB_","EC_","B_","TD_","TE_","TF_","TG_","TH_","TI_","ED_","EE_","EF_","EG_","EH_","EI_" : #65041
    Read [RUB]RUB0 = GCURLEG;CODE
    If fstat
     Read [RUB]RUB1 = GCURLEG;val(CODE)
     If !fstat
      FORMULE = left$(FORMULE,J-1)+[F:RUB]COD+right$(FORMULE,I+1)
      I += len([F:RUB]COD)-len(CODE)
      CODE = [F:RUB]COD
     Endif
    Endif
   When "[F]"
    OK = 1
    For [ATZ]DICO Where CODZONE=CODE
     If [F:ATZ]CODFIC="TIMEMPDAT"
      If clalev([F:TID])=0 : Local File TIMEMPDAT [TID] : Endif
      If evalue("type([F:TID]"+CODE+")")>=10
       OK = 0 : Break
      Endif
     Elsif [F:ATZ]CODFIC="TIMRECAP"
      If clalev([F:TIR])=0 : Local File TIMRECAP [TIR] : Endif
      If evalue("type([F:TIR]"+CODE+")")>=10
       OK = 0 : Break
      Endif
     Else
      K = find([F:ATZ]CODFIC,GEMPTAB(1..GNBEMPTAB))
      If K>0
       If clalev([F:F_E])<>0 : Close Local File [F_E] Endif
       Local File =GEMPTAB(K) [F_E]
       If evalue("type([F:F_E]"+CODE+")")>=10 | evalue("type([F:F_E]"+CODE+")")=3
        OK = 0 : Break
       Endif
      Endif
     Endif
    Next
    If !OK
     # Donnée non numérique
     mkstat = 2 : GMESSAGE = CODE-":"-mess(127,123,1) : Break
    Endif
  Endcase
  I += 1
 Else
  I += 1
 Endif
Wend
End
# fin 39614

Subprog AS_TYPAMT(VALEUR)
Variable Integer VALEUR
GMENLOC (10)=1
GMENLOC (11)=1
GMENLOC (12)=1
#Tax band (D to I)
For I=func AFNC.ACTIV("TXB")+10 To len(mess(0,10355,1))
 GMENLOC(I)=1
Next
End

