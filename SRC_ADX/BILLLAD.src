#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################
# Program Name: BILLLAD
# Description : Bill of Lading Report
# Author      : Carlos R Tuason
# Date        : Nov 05, 2014
####################################################################################

####################################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)

End


####################################################################################
Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Gosub OUVRE
If GERREUR : GERREUR=0 : End : Endif
Gosub DECLARE

For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)

  Case [L]PARAM
   When "__REQUETE"       : [L]REQNUM = val([L]VALEUR)
   When "usr"             : [L]PARAMETRE(I) = "usr="+GUSER
   When "sitedeb"         : [L]SSITE = [L]VALEUR
   When "sitefin"         : [L]ESITE = [L]VALEUR
   When "boltyp"          : [L]BOLTYP = val([L]VALEUR)
   When "bolnumdeb"       : [L]SBOLNUM = [L]VALEUR
   When "bolnumfin"       : [L]EBOLNUM = [L]VALEUR
   When "bpr"             : [L]BPR = [L]VALEUR
   When "codimp"          : [L]CODIMP = val([L]VALEUR)
   When "numedt"          : [L]PARAMETRE(I) = "numedt="+num$([L]REQNUM)
   When "boldatdeb"         :
    [L]SDATE=gdat$(val(right$([L]VALEUR,7)),val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
   When "boldatfin"         :
    [L]EDATE=gdat$(val(right$([L]VALEUR,7)),val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
 Endcase
 Endif
Next

# Initialize the BOLW table to prepare to load it with new information.
Lock [BOLW]
Delete[BOLW] Where (REQNUM=[L]REQNUM) | CREDATTIM <date$-1
Unlock [BOLW]

Gosub WRITE_BILLLADWRK

End


####################################################################################
$OUVRE
If !clalev([F:BOLH]) : Local File BILLLADH [BOLH] : Endif
If !clalev([F:BOLH2]): Local File BILLLADH [BOLH2]: Endif
If !clalev([F:BOLD]) : Local File BILLLADD [BOLD] : Endif
If !clalev([F:BOLW]) : Local File BILLLADWRK [BOLW]: Endif
If !clalev([F:BOLW2]): Local File BILLLADWRK [BOLW2]: Endif
If !clalev([F:AXX])  : Local File ATEXTRA [AXX] : Endif
Return




####################################################################################
$DECLARE

Local Char    PARAM(30), VALEUR(30), FRTCLS(5), NMFC(9), COMMENT(50), NMFCDES(80)
Local Integer REQNUM,  BOLTYP, CODIMP, COUNT, OVRFLOW, KUSFLG, BOLLIN
Local Char    SSITE(GLONFCY), ESITE(GLONFCY), BOLNUM(20), SBOLNUM(20), EBOLNUM(20), BPR(15), LAN(3)
Local Decimal NBRPCK, GROWEI, WEU
Local Date    SDATE, EDATE

Return

####################################################################################
$WRITE_BILLLADWRK

Filter [BOLH] Where FCY>=[L]SSITE & FCY<=[L]ESITE & BOLNUM>=[L]SBOLNUM & BOLNUM<=[L]EBOLNUM & BOLDAT>=[L]SDATE & BOLDAT<=[L]EDATE
&   & BOLTYP=[L]BOLTYP & PRNFLG=[L]CODIMP & (BPR=[L]BPR | [L]BPR = "")
&   Order By BOLNUM

#Default to English
[L]LAN = "ENG"

If find(GLANGUE,"FRA","GER","SPA") : [L]LAN = GLANGUE : Endif

For [BOLH]
    Raz [L]BOLNUM
    Raz [L]COUNT
    Raz [L]OVRFLOW
    Raz [L]KUSFLG

    [L]BOLNUM = [BOLH]BOLNUM

    If [L]BOLNUM<>""

        If func AFNC.ACTIV("KUS")
            If func AFNC.PARAM("USABOL",[BOLH]FCY)="2"
                KUSFLG = 1
            Endif
        Endif

        #Update print flag
        Read [BOLH2]BOLH0 = [L]BOLNUM

        If !fstat
            # Rec found
            If [BOLH2]PRNFLG = 1

                Trbegin [BOLH2]

                [BOLH2]PRNFLG = 2

                Rewrite [BOLH2]
                If fstat
                    Rollback
                Else
                    Commit
                Endif
            Endif
        Endif

        Filter [BOLD] Where BOLNUM = [L]BOLNUM

        For [BOLD]
            Raz [L]NMFCDES

            #Determine whether or not BOL document contains overflow
            [L]COUNT = [L]COUNT + 1
            [L]BOLLIN = [BOLD]BOLLIN

            If [BOLD]NMFC<>""
                Read [AXX]AXX0 = "FRTCOMCOD";"DESAXX";GLANGUE;[BOLD]NMFC;"1"
                If !fstat
                    # Rec found
                    [L]NMFCDES = [AXX]TEXTE
                Endif
            Endif

            Look [BOLW]BOLW0=[L]REQNUM;GUSER;[L]BOLNUM;[L]BOLLIN
            If !fstat : Return : Endif

            Trbegin [BOLW]

            # Create new record
            Raz [BOLW]
            [BOLW]REQNUM    = [L]REQNUM
            [BOLW]USER      = GUSER
            [BOLW]BOLNUM    = [L]BOLNUM
            [BOLW]BOLLIN    = [L]BOLLIN
            [BOLW]LAN       = [L]LAN #117709.n
            [BOLW]FRTCLS    = [BOLD]FRTCLS
            [BOLW]PCK       = [BOLD]PCK
            [BOLW]NMFC      = [BOLD]NMFC
            [BOLW]NBRPCK    = [BOLD]NBRPCK
#           [BOLW]GROWEI    = GROWEI  # 105206.o
            [BOLW]GROWEI    = arr([BOLD]GROWEI,1)  # 105206.n
            [BOLW]WEU       = [BOLD]WEU
            [BOLW]COMMENT   = [BOLD]COMMENT
            [BOLW]TEXTE     = [L]NMFCDES
            [BOLW]OVRFLOW   = 0
            [BOLW]KUSFLG    = [L]KUSFLG
            #117709.sn
            [BOLW]TXTNUM1   = 1
            [BOLW]TXTNUM2   = 2
            [BOLW]TXTNUM3   = 3
            [BOLW]TXTNUM4   = 4
            [BOLW]TXTNUM5   = 5
            #117709.en


            Write [BOLW]
            If fstat
                Rollback
            Else
                Commit
            Endif

            If [L]COUNT>5
                [L]OVRFLOW = 1
            Endif
        Next
        Filter [BOLD]

        If [L]OVRFLOW = 1

            Trbegin [BOLW2]

            Update [BOLW2] Where BOLNUM = [L]BOLNUM With OVRFLOW = [L]OVRFLOW

            If fstat
                Rollback
            Else
                Commit
            Endif
        Endif
    Endif
Next
Filter [BOLH]

Return

