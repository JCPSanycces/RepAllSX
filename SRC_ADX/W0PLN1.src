#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PLN1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone COD
mkstat = 0
zoncou = "COD"
indice = 0
If varmode([M]COD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "COD" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]COD,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTPLN"
  Call CONTPLN([M]COD) From SUBPLN
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Local Char    VALEUR(250)
   VALEUR = [M]COD
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
   [M]COD = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "CONTOBJW"
    PARAM(1) = "PLN"
    Local Char    VALEUR(250)
    VALEUR = [M]COD
    Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJW","CONTOBJ","") From GACTION
    [M]COD = VALEUR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "COD" : GZNUM = 5296 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone FIRDAY
mkstat = 0
zoncou = "FIRDAY"
indice = 0
IMPENT = [M]FIRDAY
WNUM = IMPENT
If varinit([M]FIRDAY,indice)=0
 IMPENT = 1
Endif
If varmode([M]FIRDAY,indice)=0
 [M]FIRDAY(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FIRDAY" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FIRDAY(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "FIRDAY" : GZNUM = 45280 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>IMPENT or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_FIRDAY(IMPENT) From SUBPLN
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "FIRDAY" : GZNUM = 45280 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif
[M]FIRDAY = IMPENT

## Zone YEA
mkstat = 0
zoncou = "YEA"
indice = 0
WNUM = [M]YEA
If varinit([M]YEA,indice)=0
 [M]YEA = year(date$)
Endif
If varmode([M]YEA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "YEA" : Gosub ACTION From =IMPTRT
 Endif
 If WNUM<>[M]YEA or IMPMOD
  SAVACT = GACTION : GACTION = "STD"
  Call AM_YEA([M]YEA) From SUBPLN
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "YEA" : GZNUM = 1879 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone DES
mkstat = 0
zoncou = "DES"
indice = 0
If varmode([M]DES,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "DES" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone SHO
mkstat = 0
zoncou = "SHO"
indice = 0
If varmode([M]SHO,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SHO" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
WCHAR = [M]LEG
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"909","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]LEG,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "LEG" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]LEG,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]LEG,"909","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]LEG,"909",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]LEG or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_LEG([M]LEG) From SUBPLN
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBRWEK
mkstat = 0
zoncou = "NBRWEK"
indice = 0
status = 1
zoncou = "NBRWEK"
If varmode([M]NBRWEK,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRWEK" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRWEK
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRWEK = nolign
   status = 75
   Call SAI_NBRWEK(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBRWEK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRWEK
mkstat = 0
zoncou = "NBRWEK"

## Zone WEKTYP
mkstat = 0
zoncou = "WEKTYP"
If varmode([M]WEKTYP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "WEKTYP" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTOBJN"
 Local Char    VALEUR(250)
 VALEUR = [M]WEKTYP(indice)
 Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
 [M]WEKTYP(indice) = VALEUR
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "WEKTYP" : GZNUM = 55957 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTSTY"
  Call CONTSTY([M]WEKTYP(indice)) From SUBSTY
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "WEKTYP" : GZNUM = 55957 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_WEKTYP([M]WEKTYP(indice)) From SUBPLN
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "WEKTYP" : GZNUM = 55957 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone NBRWEK
mkstat = 0
zoncou = "NBRWEK"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "PLN1"
Return

