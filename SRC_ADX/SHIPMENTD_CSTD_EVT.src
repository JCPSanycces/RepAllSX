#<AdxTL>@(#)0.0.0.0 $Revision$
$AINSERT_CONTROL_AFTER
Gosub CTR_DATE
Return


$AUPDATE_CONTROL_AFTER
Gosub CTR_DATE
Return

$CTR_DATE
Local Char WTEXTE(100)
 # 1- Date de réception prévue obligatoire
  # Cette zone n'est pas obligatoire dans la classe car le message renvoyé par le superviseur
  # ne donne pas le nom de la zone si il n'y a pas de représentation
  If this.EXTRCPDAT = AVOID.ADATE
    Call TEXTE(2758, WTEXTE) From OBJDIV
    [L]ASTATUS = fmet this.ASETERROR(WTEXTE, mess(10,123,1), [V]CST_AERROR)
  Endif
Return

