#<AdxTL>@(#)0.0.0.0 $Revision$


#**
#* Check if the given LOGIN exists in the given folder, fill informations
#*
#* @param DOSSIER
#* @param ELOGIN
#* @return RES_OK   0-OK, other-Error code
#*
#* # Error 2: "Incorrect user / password"
#* # Error 12: "User code not authorized for this type of connection"
#*!
Funprog _CHECK_LOGIN(DOSSIER,ELOGIN,LOGIN,USER,PRFCOD,ALLACS)
Value Char DOSSIER, ELOGIN
Variable Char LOGIN,USER,PRFCOD
Variable Tinyint ALLACS
Local Integer RES_OK
RES_OK=2
 If DOSSIER <> "" and ELOGIN <> ""
  If DOSSIER=nomap
   Local File AUTILIS [AUS]
   Local File AMETUTI [AME]
  Else
   Local File =[L]DOSSIER+".AUTILIS" [AUS]
   Local File =[L]DOSSIER+".AMETUTI" [AME]
  Endif
  Read [AUS]LOGIN = toupper([L]ELOGIN)
  If fstat
   RES_OK=2
   End RES_OK
  Elsif [F:AUS]ENAFLG<>2
   RES_OK=2
   End RES_OK
  Elsif ([F:AUS]USRCONNECT<>2 and mod(adxtyp,8)<>4) or ([F:AUS]USRCONXTD<>2 and (mod(adxtyp,8)=4 or mod(adxtyp,8)=7))
   RES_OK=12
   End RES_OK
  Else
   RES_OK = 0
   LOGIN=[L]ELOGIN
   USER = [F:AUS]USR
   ALLACS = [F:AUS]ALLACS
   If [F:AUS]PRFFCT=""
    Read [AME]AME0 = [F:AUS]CODMET
    If !fstat
     PRFCOD  = [F:AME]PRFFCT
    Endif
   Else
    PRFCOD  = [F:AUS]PRFFCT
   Endif
  Endif
 Endif
End RES_OK

#**
#* Fill informations for a given USER, already controlled by _CHECK_LOGIN
#*
#* @param DOSSIER
#* @param USER
#* @return RES_OK   1-OK, 0-Error
#*!
Funprog _FILL_ACTX_USER(DOSSIER,USER,PRFCOD,ALLACS)
Value Char DOSSIER,USER
Variable Char PRFCOD
Variable Tinyint ALLACS
Local Integer RES_OK
 If DOSSIER <> "" and USER <> ""
  If DOSSIER=nomap
   Local File AUTILIS [AUS]
   Local File AMETUTI [AME]
  Else
   Local File =[L]DOSSIER+".AUTILIS" [AUS]
   Local File =[L]DOSSIER+".AMETUTI" [AME]
  Endif
  Read [AUS]CODUSR = USER
  If !fstat
   RES_OK = 1
   ALLACS = [F:AUS]ALLACS
   If [F:AUS]PRFFCT=""
    Read [AME]AME0 = [F:AUS]CODMET
    If !fstat
     PRFCOD  = [F:AME]PRFFCT
    Endif
   Else
    PRFCOD  = [F:AUS]PRFFCT
   Endif
  Endif
 Endif
End RES_OK

