#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################################################
# IMPFXM : Import des mouvements de biens
# --------------------------------------------------------------------- #
# dans les tables FXDMVT et FXDMVTD                                     #
#########################################################################

#
# CBO 2013.10.28 FQxxxxx contrôle sur changement de méthode (non implémenté)
# CBO 2013.07.31 FQ91070 ajout pour éclatement d'un bien
#

$ACTION

  Case ACTION
    When "IMP_OUVRE"     : Gosub OUVRE
    When "AP_IMPORT"     : Gosub AP_IMPORT

    When "IMP_VERIF_CRE" : Gosub IMP_VERIF_CRE
    When "IMP_CREATION"  : Gosub IMP_CREATION
    When "IMP_VERIF_MOD" : Gosub IMP_VERIF_MOD
    When "IMP_MODIF"     : Gosub IMP_MODIF

    When "IMP_FERME"     : Gosub FERME
  Endcase
Return

##########################################################################################################
#                                  IMPORT                                #
##########################################################################
$OUVRE

Local Integer WMAXIDMVT, WCURIDMVT, WBMODIF, I, WERRENTETE, WNDIME, WTYPDIMEAL
Local Char WSSUFFIXE(20), WSCODESUFF(20), WCLE(100), WLIBSEQMVT(20)

    If !clalev([F:FXMX])
        Local File FXDMVT [FXMX]
    Endif

    If !clalev([F:FXD])
        Local File FXDMVTD [FXD]
    Endif

    If !clalev([F:LOF])
        Local File LAYOUTFAS [LOF]
    Endif
    If !clalev([F:FAS])
        Local File FXDASSETS [FAS]
    Endif
    If !clalev([F:PHY])
        Local File PHYELT [PHY]
    Endif

    # paramètres de l'import des mouvements
    Gosub GLOBFXM From SUBFXM

    # récup du lib de SEQMVT pour le c.r.
    # récup du type de DIME (num en V5 et alpha ensuite)
    If !clalev([F:AMZ])
        Local File AMSKZON [AMZ]
    Endif
    If !clalev([F:ATX])
        Local File ATEXTE [ATX]
    Endif
    Read [AMZ]CODE = "FXDMVT0"; "SEQMVT"
    Read [ATX]NUMERO = GLANGUE ; [F:AMZ]INTIT
    WLIBSEQMVT = [F:ATX]TEXTE
    Read [AMZ]CODE = "FXDMVT1"; "DIME"
    If [F:AMZ]CODTYP = "A"
        WTYPDIMEAL = 1
    Else
        WTYPDIMEAL = 0
    Endif

    # ruse pour palier la mauvaise gestion entête/ligne sans objet
    [M:AOE1]OPTUPD=2
Return


$AP_IMPORT

    GMESSAGE = ""
    GERR = 0
    WBMODIF = 0
    If SEPNUM = 1 # entête
        WERRENTETE = 0
        If [F:FXM]SEQMVT
            # lecture pour définir si l'objet existe : que la création autorisée
            Look [FXMX]FXM1 = [F:FXM]OBJMVT ; [F:FXM]REF1MVT ; [F:FXM]REF2MVT ; [F:FXM]TYPMVT ; [F:FXM]SEQMVT
            If fstat = 0
                WERRENTETE = 1
                Return
            Endif
        Endif

        #lock du cptr
        Lock FXD With lockwait = 5
        [C]FXD   += 1
        WMAXIDMVT = [C]FXD
        Unlock FXD

        [F:FXM]IDMVT = WMAXIDMVT

    Else # détail
        [F:FXD]IDMVT = WMAXIDMVT
    Endif

    # entête : alimentation forcée de certains champs
    If SEPNUM = 1
        [F:FXM]STATMVT = GFXM_ATRAITER
        [F:FXM]ORIMVT  = 1
        [F:FXM]DESRJTMVT = ""

#       recherche de la soc et du site
        If [F:FXM]CPY = "" or [F:FXM]FCY = ""
            If [F:FXM]OBJMVT = GFXM_DEPENSE
                Read [LOF]LOF0 = [F:FXM]REF1MVT ; val([F:FXM]REF2MVT)
                If fstat = 0
                    [F:FXM]CPY = [F:LOF]CPY
                    [F:FXM]FCY = [F:LOF]FCY
                Endif
            Elsif [F:FXM]OBJMVT = GFXM_IMMOS
                Read [FAS]FAS0 = [F:FXM]REF1MVT
                If fstat = 0
                    [F:FXM]CPY = [F:FAS]CPY
                    [F:FXM]FCY = [F:FAS]FCY
                Endif
            Elsif [F:FXM]OBJMVT = GFXM_PHY
                Read [PHY]PHY0 = [F:FXM]REF1MVT
                If fstat = 0
                    [F:FXM]CPY = [F:PHY]CPY
                    [F:FXM]FCY = [F:PHY]FCY
                Endif
            Endif
        Endif
    Endif

Return

$IMP_VERIF_CRE
    If SEPNUM = 1
        # Détermination du numéro de séquence si celui-ci n'est pas donné par le fichier d'import
        If [F:FXM]SEQMVT = 0
            # On utilise le compteur [C]FXD comme un sémaphore pour ne pas créer deux enregistrement avec
            # le même numéro de séquence
            Lock FXD With lockwait = 5
            # on recherche le + grand n° de seq de cet objet
            Filter [FXMX] Where OBJMVT = [F:FXM]OBJMVT and
&                               REF1MVT = [F:FXM]REF1MVT and
&                               REF2MVT = [F:FXM]REF2MVT
            Read [FXMX]FXM1 Last
            If fstat
                [F:FXM]SEQMVT = 1
            Else
                [F:FXM]SEQMVT = [F:FXMX]SEQMVT + 1
            Endif
            Filter [FXMX]
        Endif
    Else
        Unlock FXD
        # FQxxxxx
        If WERRENTETE = 1
            OK = 0
            Return
        Endif
    Endif
Return

######################################################################

$IMP_CREATION
    If SEPNUM = 1
        WCLE = [F:FXM]REF1MVT
        If [F:FXM]OBJMVT = GFXM_DEPENSE
            WCLE -= "/" - [F:FXM]REF2MVT
        Endif
        WCLE -= WLIBSEQMVT - num$([F:FXM]SEQMVT)
        WCLE -= "(" + mess([F:FXM]OBJMVT, GML_MSGOBJ, 1) - "/" - mess([F:FXM]TYPMVT, GML_MSGTYP, 1) + ")"
        Call ECR_TRACE("-->" - WCLE, 0) From GESECRAN
    Endif
Return

    ######################################################################

$IMP_APRES_CRE
  # Libère le compteur FXD qui sert de sémaphore lors de la création d'un nouveau numéro de séquence
  # Le lock est posé dans $IMP_CREATION
  Unlock FXD
Return

    ######################################################################

$IMP_VERIF_MOD

    Gosub IMP_VERIF_CRE
    [F:FXD]IDMVT = WMAXIDMVT

Return

$IMP_MODIF
Local Decimal WDIMEMAX # FQ91070
WDIMEMAX = -1
    If SEPNUM = 2
        WCODZONE = [F:FXD]CODZONE
        If WTYPDIMEAL
            I = func SUBFXM.TRTDIME(WTYPDIMEAL, [F:FXD]DIME, [F:FXD]CODZONE, WDIMEMAX, WNDIME, WSSUFFIXE, WSCODESUFF)
        Else
            I = func SUBFXM.TRTDIME(WTYPDIMEAL, num$([F:FXD]DIME), [F:FXD]CODZONE, WDIMEMAX, WNDIME, WSSUFFIXE, WSCODESUFF)
        Endif

        If [F:FXD]DPRPLN  > 0
            WSCODESUFF -= "(" + num$(mess([F:FXD]DPRPLN, GML_NPLAN, 1)) + ")"
        Endif

        Call ECR_TRACE("-->" - WSCODESUFF - "=" - [F:FXD]VALZONE, 0) From GESECRAN

        [F:FXD]IDMVT = WMAXIDMVT
        Write [FXD]
    Endif

Return


##########################################################################
#------------------------#
# Fin de l'import/export #
#------------------------#
$FERME
    Close File [FXMX], [FXD], [LOF], [FAS], [PHY]

    # sécurité
    Unlock FXD

Return
