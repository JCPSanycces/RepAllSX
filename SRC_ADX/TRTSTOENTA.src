#<AdxTL>@(#)8.0.0.0 $Revision$
########################################################################
#
# TRTSTOENTA   Traitement complémentaire du TRTSTOENT à disposition
#              des fonctions appellant la fenêtre de saisie des entrées
#              Il permet de gérer l'interaction avec la fonction origine
#
#              La mise à jour de ce traitement est à la charge du développeur
#              de la fonction origine , en fonction des deux parametres passés
#              à l action SAISTOENT  (type de piece , masque ecran)
#########################################################################

#########################################################################
# Chargement du masque STOENT [ENT] Bloc 1 entete
#                      STOENT [ENT] Bloc 2 premiere ligne
#                      STOENT [ENT] Bloc 3 parametrage
#
#   bloc entete         : STOFCY        Site stockage
#                         ITMREF        Article
#                         QTYTOENT      Quantite à entrée
#                         PCUTOENT      Unité stock de la quantite à entrée
#                         VCRNUM        Numéro du document
#                         VCRLIN        Numéro ligne document
#                         VCRTYP        Type du document (M701)
#   bloc parametrage    : TRSTYP        Type transaction (M704)
#                         TRSCOD        Code mouvement
#                         STOFCYORI     Numéro pièce origine
#                         VCRNUMORI     Numéro pièce origine
#                         VCRTYPORI     Type   pièce origine
#                         VCRTLINORI    Ligne  pièce origine
#                         IPTDAT        Date imputation
#                         TABLE1        Abréviation table transaction
#                         ITP           Article fournisseur  1 = non 2 = oui
#                         BPRNUM        Tiers
#                         CUR           Devise pièce
#########################################################################
# Chargement Ecran STOENT (partie parametrage) creations des entrées
#########################################################################
$CHARG_PARAM_STOENT

Case  LBOI
     When  "ISTOENTS"
               Case LTYP
                 When 6  :                             # reception
                 When 12 :                             # reintegration stock
                 When 13 :                             # retour client / retour pret
                 When 15 :                             # declaration production
                 When 18 :                             # Avoir
                 When 19 :                             # entree diverse
                 When Default :
              Endcase

     When   Default
#           [M:ENT]ORIDOC = LORI
#            [M:ENT]QUAFLG = [F:ITF]QUAFLG             # hcb V6CQ
               Case LTYP
                 When 6  : Call CHARG_PARAM_STOENT(LLIGDOC) From SUBPTHB    # receptions
                 When 12 : Call CHARG_PARAM_STOENT(LLIGDOC) From MTKLIB     # réintégration
                 When 13 : If LABR="SRH1"
                             Call CHARG_PARAM_STOENT(LLIGDOC) From SUBSRH   # retour client
                           Elsif LABR="SRS1"
                             Call CHARG_PARAM_STOENT(LLIGDOC) From SUBSRS   # retour matière pour sous traitance
                           Else
                             Call CHARG_PARAM_STOENT(LLIGDOC) From SUBSRL   # retour pret
                           Endif
                 When 15 : If clalev([M:PTH1])>0 & clalev([M:PSTT])>0 & [M:PSTT]MFGNUM<>""
                             Call CHARG_PARAM_STOENT(LLIGDOC) From SUBPTHC  # réception de sous-traitance OF
                           Else
                             Call CHARG_PARAM_STOENT(LLIGDOC) From MTKLIB   # declaration production
                           Endif
                 When 18 : Call CHARG_PARAM_STOENT(LLIGDOC) From SUBSIHB    # Avoir
                 When 19 : Call CHARG_PARAM_STOENT(LLIGDOC) From SUBSMRB    # entrées diverses
                 When 27 : Call CHARG_PARAM_STOENT(LLIGDOC) From TRTSSLA    # changement emplacement/plan de rangement
                 When 31 : Call CHARG_PARAM_STOENT(LLIGDOC) From SUBBBYA    # Assemblage
                 When 32 : Call CHARG_PARAM_STOENT(LLIGDOC) From SUBDBYA    # Désassemblage
                 When Default :
               Endcase
Endcase

# Chargement de paramètres dans l'écran STOENT
GPOINT="CHG_STOENT" : Gosub ENTREE From EXEFNC

Return


#########################################################################
# Chargement ecran STOENT à partir de STOENTW  (mvt entree)
#########################################################################
$LIGNE_STOENTW

Local Integer LNUMLIGLOT
Local Integer WMAX
Local Integer LLIG
Local Integer CPTRET
Local Integer I,J
Local Integer LECC
WMAX = dim([M:ENTW]PCU)-1     # mémorisation nombre de ligne maxi

Local Integer I,J
Local Integer LLIGCCE
Local Char    LCCEDEF

I = 0
LLIG = 0
#--- Issue 117545
Call ADDLOTBLANC( "ENT" ) From STKENTA
#Call ADDLOTBLANC( "ENT" ) From STKENT
#---
If [M:ENT]WSTOSEQ<=0
    Return
Endif


I=find([M:ENT]WSTOSEQ,[M:ENTW]WSTOSEQ)-1
If I<0 : Return : Endif

#---- Récupération des sections analytiques ----#
LLIGCCE = find([M:ENT]WSTOSEQ,[M:ENTW]WSTOSEQ2)-1
If LLIGCCE>=0
    For J=1 To GNBDIE
        If evalue("dim([M:ENTW]CCE"+num$(I)+")")>0
            [M:ENT]CCE(J-1) = evalue("[M:ENTW]CCE"+num$(J)+"(LLIGCCE)")
        Else
            Break
        Endif
    Next
Endif

While [M:ENTW]WSTOSEQ(I)=[M:ENT]WSTOSEQ

    If LLIG = WMAX
        Call ERREUR(mess(11,184,1)) From GESECRAN
        Break
    Endif
    [M:ENT]ORILIG    (LLIG)        = [M:ENTW]ORILIG (I)

    [M:ENT]PCU       (LLIG)        = [M:ENTW]PCU(I)
    [M:ENT]QTYPCU    (LLIG)        = [M:ENTW]QTYPCU   (I)
    [M:ENT]QTYPCUO   (LLIG)        = [M:ENTW]QTYPCU   (I)
    [M:ENT]QTYSTU    (LLIG)        = [M:ENTW]QTYSTU(I)
    [M:ENT]PCUSTUCOE (LLIG)        = [M:ENTW]PCUSTUCOE(I)
    If [M:ENTW]NUMLIGLOT(I)>=0
        [M:ENT]BPSLOTO   (LLIG)         = [M:ENTW]BPSLOT([M:ENTW]NUMLIGLOT(I))
        If dim([M:ENT]BPSLOTAFF) > 0
            [M:ENT]BPSLOTAFF (LLIG)     = [M:ENTW]BPSLOT([M:ENTW]NUMLIGLOT(I))
        Endif
        If dim([M:ENT]LOTAFF) > 0
            [M:ENT]LOTAFF    (LLIG)     = [M:ENTW]LOT([M:ENTW]NUMLIGLOT(I))
        Endif
        If dim([M:ENT]ECCVALMAJAFF) > 0
            [M:ENT]ECCVALMAJAFF (LLIG)     = [M:ENTW]ECCVALMAJ([M:ENTW]NUMLIGLOT(I))
        Endif
        If dim([M:ENT]ECCSAIFLG) > 0
            [M:ENT]ECCSAIFLG (LLIG)        = [M:ENTW]ECCSAIFLG([M:ENTW]NUMLIGLOT(I))
        Endif
        If dim([M:ENT]ECCVALMINAFF) > 0
            [M:ENT]ECCVALMINAFF (LLIG)     = [M:ENTW]ECCVALMIN([M:ENTW]NUMLIGLOT(I))
        Endif

        If dim([M:ENT]SLOAFF) > 0
            [M:ENT]SLOAFF    (LLIG)     = [M:ENTW]SLO([M:ENTW]NUMLIGLOT(I))
        Endif
        [M:ENT]GESLOTAFF    (LLIG)         = [M:ENTW]GESLOT   ([M:ENTW]NUMLIGLOT(I))
    Endif

    LECC = 0

    Call SETCPTLOTAUTO( [M:ENT]ITMREF, "ENT", LLIG, string$(dim([M:ENT]LOTAFF)>0,sigma(1,dim([M:ENT]LOTAFF)>0,[M:ENT]LOTAFF(LLIG))),
&                       string$(dim([M:ENT]SLOAFF)>0,sigma(1,dim([M:ENT]SLOAFF)>0,[M:ENT]SLOAFF(LLIG))),
&                       string$(dim([M:ENT]BPSLOTAFF)>0,sigma(1,dim([M:ENT]BPSLOTAFF)>0,[M:ENT]BPSLOTAFF(LLIG))),
&                       [M:ENT]GESLOTAFF(LLIG),
&                       string$(dim([M:ENT]ECCVALMAJAFF)>0,sigma(1,dim([M:ENT]ECCVALMAJAFF)>0,[M:ENT]ECCVALMAJAFF(LLIG))),
&                       string$(dim([M:ENT]ECCVALMINAFF)>0,sigma(1,dim([M:ENT]ECCVALMINAFF)>0,[M:ENT]ECCVALMINAFF(LLIG))),
&                       LECC,
&                       CPTRET ) From STKENT


    [M:ENT]STOCOU    (LLIG)        = [M:ENTW]STOCOU   (I)
    If dim([M:ENT]SERNUM) > 0
        [M:ENT]SERNUM    (LLIG)    = [M:ENTW]SERNUM   (I)
    Endif
    If dim([M:ENT]SERNUMF) > 0
        [M:ENT]SERNUMF   (LLIG)    = [M:ENTW]SERNUMF  (I)
    Endif
    If dim([M:ENT]STUDIS) > 0
        [M:ENT]STUDIS(LLIG)        = [M:ENTW]STUDIS   (I)
    Endif
    [M:ENT]STA       (LLIG)        = [M:ENTW]STA      (I)
    If dim([M:ENT]LOCTYP)>0
        [M:ENT]LOCTYP    (LLIG)    = [M:ENTW]LOCTYP   (I)
    Endif
    If dim([M:ENT]LOC)>0
        [M:ENT]LOC       (LLIG)    = [M:ENTW]LOC      (I)
    Endif
    If dim([M:ENT]WRH)>0
        [M:ENT]WRH       (LLIG)    = [M:ENTW]WRH      (I)
    Endif
    #--- Issue X3-53322
    If dim([M:ENT]LPNNUM)>0
        [M:ENT]LPNNUM    (LLIG)    = [M:ENTW]LPNNUM   (I)
    Endif
    If dim([M:ENT]TCTRNUM)>0
        [M:ENT]TCTRNUM   (LLIG)    = [M:ENTW]TCTRNUM  (I)
    Endif
    If dim([M:ENT]NBLPN)>0
        [M:ENT]NBLPN     (LLIG)    = [M:ENTW]NBLPN    (I)
    Endif
    #---
    [M:ENT]WLOCSEQ   (LLIG)        = [M:ENTW]WLOCSEQ  (I)
    [M:ENT]LBEFMT    (LLIG)        = [M:ENTW]LBEFMT   (I)
    [M:ENT]LBENBR    (LLIG)        = [M:ENTW]LBENBR   (I)
    If dim([M:ENT]PALNUM)>0
        [M:ENT]PALNUM    (LLIG)    = [M:ENTW]PALNUM   (I)
    Endif
    If dim([M:ENT]CTRNUM)>0
        [M:ENT]CTRNUM    (LLIG)    = [M:ENTW]CTRNUM   (I)
    Endif
    If dim([M:ENT]STOFLD1)>0
        [M:ENT]STOFLD1   (LLIG)    = [M:ENTW]STOFLD1  (I)
    Endif
    If dim([M:ENT]STOFLD2)>0
        [M:ENT]STOFLD2   (LLIG)    = [M:ENTW]STOFLD2  (I)
    Endif

   [M:ENT]LBEFMT    (LLIG)        = [M:ENTW]LBEFMT   (I)
    [M:ENT]STOCOU    (LLIG)        = [M:ENTW]STOCOU   (I)
    [M:ENT]STOCOUALL (LLIG)        = [M:ENTW]STOCOUALL(I)

    If dim([M:ENT]SAIACTFLG)>0
        [M:ENT]SAIACTFLG           = [M:ENTW]SAIACTFLG(I)
    Endif

    [M:ENT]WFLG      (LLIG)        = 2

    # Transfert zones de l'écran STOENTW vers l'écran STOENT
    GPOINT="ENTW_ENT" : Gosub ENTREE From EXEFNC

    [M:ENT]NBLIG        = LLIG+1
    LLIG += 1
    I+=1
Wend

#----- Alimentation des sections analytiques avec les valeurs par défaut ----#
Case LTYP
    When 6      : LCCEDEF = "STKREC"    # Réception
    When 12     : LCCEDEF = "STKSOF"    # Réintégration
    When 13     : LCCEDEF = "STKSRT"    # Retour client
    When 15     : LCCEDEF = "STKEOF"    # Déclaration fab
    When 18     : LCCEDEF = "STKAVO"    # Avoir vente
    When 19     : LCCEDEF = "STJEND"    # Entrée div
    When 31     : LCCEDEF = "STJEND"    # Assemblage
    When 32     : LCCEDEF = "STJEND"    # Désassemblage
    When 27                             # Plan de rangement   # hcb 61972
         Case [M:ENT]VCRTYP
              When 6      : LCCEDEF = "STKREC"    # Réception
              When 9      : LCCEDEF = "STJINV"    # Inventaire
              When 12     : LCCEDEF = "STKSOF"    # Réintégration
              When 13     : LCCEDEF = "STKSRT"    # Retour client
              When 15     : LCCEDEF = "STKEOF"    # Déclaration fab
              When 18     : LCCEDEF = "STKAVO"    # Avoir vente
              When 19     : LCCEDEF = "STJEND"    # Entrée div
              When 31     : LCCEDEF = "STJEND"    # Assemblage
              When 32     : LCCEDEF = "STJEND"    # Désassemblage
          Endcase
Endcase
Call STKINISEC ([M:ENT]WSTOSEQ,LCCEDEF,"ENTW") From STKECR

If LCCEDEF<>"" & [M:ENTW]NBLIG2>0
    I=find([M:ENT]WSTOSEQ, [M:ENTW]WSTOSEQ2)-1
    If I>=0
        For J=1 To GNBDIE
            [M:ENT]CCE(J-1) = evalue("[M:ENTW]CCE"+num$(J)+"(I)")
        Next J
    Endif
Endif

Return


#########################################################################
# Desactivation des rubriques STOENT
#    origine = document origine  => desactivation de la ligne
#########################################################################
$DESACTIV_RUB

# Cas où on visualise une entrée après tunnel (à partir du plan de rangement)
If GCONSULT
    Diszo [M:ENT]
    Return
Endif

Default Mask [ENT]
For I=1 To 11
    If GCHPSTO(I)<>""
&    & evalue("dim([M:ENT]"+GCHPSTO(I)+")") > 0
        If mid$(GSAIFLG,I,1)<>"0"
            Diszo =GCHPSTO(I)
        Else
            Actzo =GCHPSTO(I)
        Endif
    Endif
Next
If dim([M:ENT]ECCVALMAJAFF) > 0
   Diszo [M:ENT]ECCVALMAJAFF
Endif
If dim([M:ENT]ECCVALMINAFF) > 0
   Diszo [M:ENT]ECCVALMINAFF
Endif
Gosub VERIF_UOM

Return

#########################################################################
# verification UOM soit US ou UC sinon convertie en US
#########################################################################
$VERIF_UOM

Local Char    LUSCAV(5)
Local Integer LMODIF
Local Decimal LCOE
Local Char    LLBEFMT(GLONARP)
Local Integer WRET
Local Integer NOL
WRET = 0
PCOE = 0

For NOL = 0 To [M:ENT]NBLIG-1
     If [M:ENT]PCU(NOL) = ""
        If [M:ENT]PCUTOENT <> ""
           [M:ENT]PCU(NOL) = [M:ENT]PCUTOENT
        Else
           [M:ENT]PCU(NOL) = [F:ITM]STU
        Endif
    Endif

    If [M:ENT]PCU(NOL) <>  "" & [M:ENT]WPCU (NOL) = ""
       Call CTLUOM ([M:ENT]ITMREF,3,[M:ENT]BPRNUM, [M:ENT]PCU(NOL),LCOE, LUSCAV, LLBEFMT, LMODIF) From STKACT
       If LUSCAV <> "S"
          If LUSCAV <> "C"
             LMODIF = 0
             [M:ENT]PCU      (NOL) = [M:ENT]STU
             [M:ENT]PCUSTUCOE(NOL) = 1
             [M:ENT]QTYPCU   (NOL) = [M:ENT]QTYSTU(NOL)
             [M:ENT]QTYPCUO  (NOL) = [M:ENT]QTYSTU(NOL)
             LLBEFMT               = [F:ITM]STULBEFMT

          Endif
       Endif
       If LMODIF = 2 & mid$(GSAIFLG,3,1)="0"
          Actzo [M:ENT]PCUSTUCOE(NOL)
       Else
          Diszo [M:ENT]PCUSTUCOE(NOL)
       Endif
       [M:ENT]WPCU (NOL) = [M:ENT]PCU(NOL)

       If dim([M:ENT]LBENBR(NOL)) > 0
          If [M:ENT]LBENBR(NOL) = 0
             Diszo [M:ENT]LBEFMT(NOL)
          Endif
       Endif
  Endif
Next NOL
Return



#########################################################################
# MAJ_LIGNE_DOCUMENT : Donne la main aux documents pour la mise à jour
#                      de la ligne du document, et grise les champs stock
#------------------------------------------------------------------------
# LLIGDOC = Indice de la ligne du document
# LQTYSTU = quantité en US totale du détail
# LPCU    = Unité de conditionnement si UC identique sur toutes les lignes de détail
#            sinon = ""
# LCOE    = Coefficient UC/US si identique sur toutes les lignes de détai
#            sinon = 0
#------------------------------------------------------------------------
# ATTENTION : Ce traitement est appelé aussi sans que le masque STOENT [ENT]
#             soit complètement chargé => il ne faut pas utiliser ce masque
#########################################################################
$MAJ_LIGNE_DOCUMENT
    Case LTYP
         When 6  :    Gosub MAJ_LIG_PTH From SUBPTHB      : # reception
         When 12 :    Gosub MAJ_LIG_MTK From MTKLIB          : # réintégration
         When 13 :    If LABR="SRH1"
                        Gosub MAJ_LIG_SRH From SUBSRH        : # retour client
                      Elsif LABR="SRS1"
                        Gosub MAJ_LIG_SRS From SUBSRS        : # retour matière sous traitant
                      Else
                        Gosub MAJ_LIG_SRL From SUBSRL        : # retour pret
                      Endif
         When 15 :    If clalev([M:PTH1])>0 & clalev([M:PSTT])>0 & [M:PSTT]MFGNUM<>""
                        Gosub MAJ_LIGD_STT From SUBPTHC      : # réception de sous-traitance OF
                      Else
                        Gosub MAJ_LIG_MTK From MTKLIB        : # Declaration production
                      Endif
         When 18 :    Gosub MAJ_LIG_SIH From SUBSIHB         : # avoir
         When 19 :    Gosub MAJ_LIGNE_DOCUMENT From SUBSMRB  : # entrées diverses
         When 27 :    Gosub MAJ_LIGNE_DOCUMENT From TRTSSLA  : # plan de rangement
         When 31 :    Gosub MAJ_LIGNE_DOCUMENT From SUBBBYA  : # Assemblage
         When 32 :    Gosub MAJ_LIGNE_DOCUMENT From SUBDBYA  : # Desassemblage

         When Default :
    Endcase

#    Default Mask "["+LABR+"]"
#    Call STKDISLIG( LLIGDOC ) From STKECR
#    Default Mask [ENT]

Return



#########################################################################
# STOCKAGE_LIGNE    Chargement ecran STOENTW à partir de STOENT
#########################################################################
$STOCKAGE_LIGNE

Local Integer LBID
Local Integer LRET
Local Integer LLIGLOT
Local Char    LSLO(GLONSLO)
Local Integer LSETCPT
Local Integer LLIGCCE

If [M:ENT]ORILIG = 4
   Return
Endif

# Suppression des valeurs précédentes
Call DELSTOENTW (LLIGDOC,LLIGDOC,LABR,0,0,"",0,"") From STKENT
Local Integer I
Local Integer LLIG
LLIG = [M:ENTW]NBLIG
If dim (GTOTQTY) >= 0
   Raz GTOTQTY
Endif
If dim (GQQQQTY) >= 0
   Raz GQQQQTY
Endif
If dim (GRRRQTY) >= 0
   Raz GRRRQTY
Endif

#---- Récupération des sections analytiques ----#
LLIGCCE = find([M:ENT]WSTOSEQ,[M:ENTW]WSTOSEQ2)-1
If LLIGCCE>=0
    For I=1 To GNBDIE
        If evalue("dim([M:ENTW]CCE"+num$(I)+")")>0
            Assign "[M:ENTW]CCE"+num$(I)+"(LLIGCCE)" With [M:ENT]CCE(I-1)
        Else
            Break
        Endif
    Next
Endif

For I = 0 To [M:ENT]NBLIG-1

    [M:ENTW]WSTOSEQ   (LLIG)        = [M:ENT]WSTOSEQ
#    [M:ENTW]ORIDOC    (LLIG)        = [M:ENT]ORIDOC
#    If [M:ENTW]ORIDOC    (LLIG) = 1
#        [M:ENTW]ORIDOC    (LLIG) = 3
#    Endif
    [M:ENTW]ITMREF    (LLIG)        = [M:ENT]ITMREF

    [M:ENTW]PCU       (LLIG)        = [M:ENT]PCU(I)
    [M:ENTW]QTYPCU    (LLIG)        = [M:ENT]QTYPCU(I)
    [M:ENTW]QTYSTU    (LLIG)        = [M:ENT]QTYSTU(I)
    [M:ENTW]PCUSTUCOE (LLIG)        = [M:ENT]PCUSTUCOE(I)

    If dim([M:ENT]LOTAFF)>0
        If [M:ENT]GESLOTAFF(I)="B"
            [M:ENTW]NUMLIGLOT(LLIG) = 0
        Elsif !([M:ENT]GESLOTAFF(I)="" & [M:ENT]LOTAFF(I)="")
            LLIGLOT = -1
            If dim([M:ENT]SLOAFF)>0
                LSLO = [M:ENT]SLOAFF(I)
            Else
#                LSLO = "00001"
                Raz LSLO
            Endif
            Raz LSETCPT
            If [M:ENT]GESLOTAFF(I)="C"
                Call SEARCHGESLOTW( "C", [M:ENT]BPSLOTAFF(I), LSLO, [M:ENT]WSTOSEQ, LLIGLOT ) From STKENTA
                [M:ENTW]NUMLIGLOT(LLIG) = LLIGLOT
                If LLIGLOT=-1
                    LLIGLOT = [M:ENTW]NBLIGLOT
                    [M:ENTW]NBLIGLOT += 1
                    LSETCPT = 1
                Endif
            Else
                Call ADDLOTENTW( [M:ENT]ITMREF, [M:ENT]LOTAFF(I), LSLO, [M:ENT]BPSLOTAFF(I), [M:ENT]GESLOTAFF(I), LLIGLOT ) From STKENTA
                LSETCPT = 1
            Endif
            If LSETCPT=1
                [M:ENTW]NUMLIGLOT(LLIG) = LLIGLOT
                Call SETCPTLOT( "ENTW", LLIGLOT,
&                               [M:ENT]LOTAFF(I), LSLO, [M:ENT]BPSLOTAFF(I),[M:ENT]GESLOTAFF(I),
&                               [M:ENT]POT       ([M:ENT]NUMLIGLOT(I)),
&                               [M:ENT]ACT       ([M:ENT]NUMLIGLOT(I)),
&                               [M:ENT]REFPER    ([M:ENT]NUMLIGLOT(I)),
&                               [M:ENT]SHL       ([M:ENT]NUMLIGLOT(I)),
&                               [M:ENT]SHLDAT    ([M:ENT]NUMLIGLOT(I)),
&                               [M:ENT]SHLUOM    ([M:ENT]NUMLIGLOT(I)),
&                               [M:ENT]SHLLTI    ([M:ENT]NUMLIGLOT(I)),
&                               [M:ENT]SHLLTIUOM ([M:ENT]NUMLIGLOT(I)),
&                               [M:ENT]NEWLTIDAT ([M:ENT]NUMLIGLOT(I)),
&                               [M:ENT]DLU       ([M:ENT]NUMLIGLOT(I)),
&                               [M:ENT]DLUDAT    ([M:ENT]NUMLIGLOT(I)),
&                               [M:ENT]USRFLD1   ([M:ENT]NUMLIGLOT(I)),
&                               [M:ENT]USRFLD2   ([M:ENT]NUMLIGLOT(I)),
&                               [M:ENT]USRFLD3   ([M:ENT]NUMLIGLOT(I)),
&                               [M:ENT]USRFLD4   ([M:ENT]NUMLIGLOT(I)),
&                               [M:ENT]MODIF     ([M:ENT]NUMLIGLOT(I)),
&                               [M:ENT]ECCVALMAJ ([M:ENT]NUMLIGLOT(I)),
&                               [M:ENT]ECCVALMIN ([M:ENT]NUMLIGLOT(I)),
&                               [M:ENT]ECCSAIFLG ([M:ENT]NUMLIGLOT(I)),
&                               [M:ENT]VALIDE    ([M:ENT]NUMLIGLOT(I))) From STKENT
            Endif
        Endif
    Endif
    [M:ENTW]STOCOU    (LLIG)        = [M:ENT]STOCOU   (I)
    If dim([M:ENT]SERNUM(LLIG)) > 0
       [M:ENTW]SERNUM    (LLIG)     = [M:ENT]SERNUM   (I)
    Endif
    If dim([M:ENTW]SERNUMF(LLIG)) > 0
       [M:ENTW]SERNUMF   (LLIG)     = [M:ENT]SERNUMF  (I)
    Endif
    [M:ENTW]STA       (LLIG)        = [M:ENT]STA      (I)
    If dim([M:ENT]LOCTYP)>0
        [M:ENTW]LOCTYP    (LLIG)    = [M:ENT]LOCTYP   (I)
    Endif
    If dim([M:ENT]LOC)>0
        [M:ENTW]LOC       (LLIG)    = [M:ENT]LOC      (I)
    Endif
    If dim([M:ENT]WRH)>0
        [M:ENTW]WRH       (LLIG)    = [M:ENT]WRH      (I)
    Endif
    #--- Issue X3-53322
    If dim([M:ENT]LPNNUM)>0
        [M:ENTW]LPNNUM    (LLIG)    = [M:ENT]LPNNUM   (I)
    Endif
    If dim([M:ENT]TCTRNUM)>0
        [M:ENTW]TCTRNUM   (LLIG)    = [M:ENT]TCTRNUM  (I)
    Endif
    If dim([M:ENT]NBLPN)>0
        [M:ENTW]NBLPN     (LLIG)    = [M:ENT]NBLPN    (I)
    Endif
    #---
    [M:ENTW]WLOCSEQ   (LLIG)        = [M:ENT]WLOCSEQ  (I)
    If [M:ENT]PRNNBFLG1<>2
        #--- Bug 59444
        #[M:ENTW]LBENBR(LLIG) = [M:ENT]QTYPCU(I)
        If int([M:ENT]QTYPCU(I))= [M:ENT]QTYPCU(I)
           [M:ENTW]LBENBR(LLIG) = [M:ENT]QTYPCU(I)
        Else
           [M:ENTW]LBENBR(LLIG) = int([M:ENT]QTYPCU(I))+1
        Endif
        #---
    Else
        [M:ENTW]LBENBR(LLIG)    = [M:ENT]LBENBR(I)
    Endif
    [M:ENTW]LBEFMT    (LLIG)        = [M:ENT]LBEFMT   (I)
    If dim([M:ENT]PALNUM)>0
        [M:ENTW]PALNUM    (LLIG)    = [M:ENT]PALNUM   (I)
    Endif
    If dim([M:ENT]CTRNUM)>0
        [M:ENTW]CTRNUM    (LLIG)    = [M:ENT]CTRNUM   (I)
    Endif
    If dim([M:ENT]STOFLD1)>0
        [M:ENTW]STOFLD1   (LLIG)    = [M:ENT]STOFLD1  (I)
    Endif
    If dim([M:ENT]STOFLD2)>0
        [M:ENTW]STOFLD2   (LLIG)    = [M:ENT]STOFLD2  (I)
    Endif

    [M:ENTW]STOCOU    (LLIG)        = [M:ENT]STOCOU   (I)
    [M:ENTW]STOCOUALL (LLIG)        = [M:ENT]STOCOUALL(I)
    [M:ENTW]SEQALL    (LLIG)        = [M:ENT]SEQALL   (I)
    [M:ENTW]SAIACTFLG (LLIG)        = [M:ENT]SAIACTFLG

#recuperation demande analyse du fichier SRU
    If left$([M:ENTW]STA(LLIG),1)="Q"
        [M:ENTW]QLYCTLFLG (LLIG)        = [F:SRU]QLYCTLFLG
    Else
        [M:ENTW]QLYCTLFLG (LLIG)        = 1
    Endif

# calcul  qtés saisies et total Q et R ----#
    If dim (GTOTQTY) >= 0
       GTOTQTY +=[M:ENT]QTYSTU(I)
    Endif
    If dim (GQQQQTY) >=0
       If left$([M:ENT]STA(I),1)= "Q"
          GQQQQTY += [M:ENT]QTYSTU(I)
       Else
          If left$([M:ENT]STA(I),1)= "R"
             GRRRQTY += [M:ENT]QTYSTU(I)
          Endif
       Endif
    Endif

    # Transfert zones de l'écran STOENT vers l'écran STOENTW
    GPOINT="ENT_ENTW" : Gosub ENTREE From EXEFNC

    [M:ENTW]NBLIG += 1
    LLIG += 1
Next I

Return

