#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque POT4 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBRLIG
mkstat = 0
zoncou = "NBRLIG"
indice = 0
status = 1
zoncou = "NBRLIG"
If varmode([M]NBRLIG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRLIG = nolign
   status = 75
   Call SAI_NBRLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBRLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRLIG
mkstat = 0
zoncou = "NBRLIG"

## Zone CPC
mkstat = 0
zoncou = "CPC"
WCHAR = [M]CPC(indice)
If varmode([M]CPC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CPC" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CPC(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CPC" : GZNUM = 15622 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_CPC([M]CPC(indice)) From SUBPOT
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CPC" : GZNUM = 15622 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Local Char    VALEUR(250)
   VALEUR = [M]CPC(indice)
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
   [M]CPC(indice) = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CPC" : GZNUM = 15622 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]CPC(indice) or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_CPC([M]CPC(indice)) From SUBPOT
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "CPC" : GZNUM = 15622 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone NIV
mkstat = 0
zoncou = "NIV"
WCHAR = [M]NIV(indice)
If varmode([M]NIV,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NIV([M]NIV(indice)) From SUBPOT
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NIV(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NIV" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]NIV(indice),2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "NIV" : GZNUM = 5230 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CTLNIV"
   Call CTLNIV([M]NIV(indice),[M]CPC(nolign-1)) From SUBCPC
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NIV" : GZNUM = 5230 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]NIV(indice) or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_NIV([M]NIV(indice)) From SUBPOT
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "NIV" : GZNUM = 5230 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone ORI
mkstat = 0
zoncou = "ORI"
IMPENT = [M]ORI(indice)
If varinit([M]ORI,indice)=0
 IMPENT = 6
Endif
[M]ORI(indice) = IMPENT

## Zone WEI
mkstat = 0
zoncou = "WEI"
If varinit([M]WEI,indice)=0
 [M]WEI(indice) = 1
Endif
If varmode([M]WEI,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_WEI([M]WEI(indice)) From SUBPOT
 GACTION = SAVACT
 If mkstat=1 : Raz [M]WEI(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "WEI" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If [M]WEI(indice)=0
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "WEI" : GZNUM = 25982 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If [M]WEI(indice)<0
    mkstat = 1 : GMESSAGE = mess(180,141,1)
   Endif
   If mkstat : GERR = 1 : GZONE = "WEI" : GZNUM = 25982 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone CODORI
mkstat = 0
zoncou = "CODORI"
If varinit([M]CODORI,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]CODORI(indice),"10461","") From SUBADI
 GACTION = SAVACT
Endif

## Zone FLGKEY
mkstat = 0
zoncou = "FLGKEY"
IMPENT = [M]FLGKEY(indice)
If varinit([M]FLGKEY,indice)=0
 IMPENT = 1
Endif
[M]FLGKEY(indice) = IMPENT

## Zone CRSFLG
mkstat = 0
zoncou = "CRSFLG"
IMPENT = [M]CRSFLG(indice)
If varinit([M]CRSFLG,indice)=0
 IMPENT = 1
Endif
[M]CRSFLG(indice) = IMPENT

## Zone NBRLIG
mkstat = 0
zoncou = "NBRLIG"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "POT4"
Return

