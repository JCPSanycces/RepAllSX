#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMACOPY0A 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone TSALFCY
mkstat = 0
zoncou = "TSALFCY"
indice = 0
WCHAR = [M]TSALFCY
If varmode([M]TSALFCY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TSALFCY" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]TSALFCY,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "TSALFCY" : GZNUM = 5060 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "ACONTFCY"
  Call CONTSITE([M]TSALFCY) From SUBAGF
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "TSALFCY" : GZNUM = 5060 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("FCY","F",[M]TSALFCY,"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "TSALFCY" : GZNUM = 5060 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]TSALFCY or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_TSALFCY([M]TSALFCY) From SUBPJMACOPY
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "TSALFCY" : GZNUM = 5060 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

