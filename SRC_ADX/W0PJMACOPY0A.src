## Zone TACALL
mkstat = 0
zoncou = "TACALL"
indice = 0
IMPENT = [M]TACALL
WNUM = IMPENT
If varinit([M]TACALL,indice)=0
 IMPENT = 1
Endif
If varmode([M]TACALL,indice)=0
 If !([M:PJMAC2]NBLIGT>0)
  mkstat = 2
 Endif
