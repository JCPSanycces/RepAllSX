#<AdxTL>@(#)7.0.0.0 $Revision$
####################################################
##       Validation Code Déversement
#
# Issue X3-38378 - 2017-12-12 by MDJ : Balance transfert
#
#######################################################
# Issue X3-38378 - 2017-09-06 by BEFOU/MDJ : Balance transfert
#*      X3-39795   MDJ  Manage ORIGIN and ORICOD fields in GL Entry
#
#######################################################
Local Char PARAM(10)(1..2) , VALEUR(10)
GERR = 0
Call TRAITE_CHAR(VALEUR,PARAM,"","CPTDUM","CPTDUM",4,"") From GTRAITE
End
#######################################################
##    Traitement des actions
#######################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub FIN
 When "OUVRE_BATCH" : Gosub OUVFIC
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 : GOK = 0
 When "DEBUT"       : Gosub DEBUT
 When "SORTIE"      : Gosub SORTIE
Endcase
Return

$OUVRE
Local Char    SVGTIT(100)
Local Char    SITE(GLONFCY)
Local Char    SOCIETE(GLONCPY)
Local Char    JOURNAL(GLONJOU)
Local Char    TYPEPCE(GLONGTE)
Local Char    DEVISE(GLONCUR)
Local Char    MESSA(80)
Local Char    SYMBOLE(30)
Local Char    REF_SIM(10), COMPTE(GLONGAC)
Local Char    TABRAC(10)(0..300)       : # Table des racines plus longues
Local Char    CRITERE(250)
Local Char    SECTION(GLONCCE)
Local Integer TABLNGRAC(0..300)        : # Table des longueurs des racines plus longues
Local Integer NBRAC                    : # Nombre de racines plus longues
Local Integer I, OK, STAT              : # Variables diverses

Local Integer TYPLED                   : # Type de référentiel
Local Integer TYPLEDVLDAUT(1..10)      : # Liste des types de référentiel rpt en valid auto
Local Integer NBRVLDAUT
Local Char    DACDIA(GLONGDE)          : # transaction de saisie
Local Char    LEDCUR(GLONLED)          : # Référentiel courant
Local Char    DEVLED(GLONCUR)
Local Integer INDEX, INDMSK
Local Integer STAECT

Local Integer AXE
Local Date    DAT
Local Decimal EXER, PERIOD, PERIOF
Local Decimal LASTPERIOD               : # JML/DUFOUR 19/08/99 pour 13ème période
Local Decimal EXERCICE, PERIODE
Local Decimal EXE, PER


Local Decimal SOLCPTD, SOLCPTC, SOLCPT    : # Soldes d'un compte (et un seul) dans la devise de mouvements
Local Decimal SOLLEDD, SOLLEDC, SOLLED    : # Soldes d'un compte (et un seul) dans la devise de référentiels

Local Decimal SOLRPT1D, SOLRPT1C, SOLRPT1 : # Soldes d'un compte (et un seul) dans la devise de référentiels auto.
Local Decimal SOLRPT2D, SOLRPT2C, SOLRPT2 : # Soldes d'un compte (et un seul) dans la devise de référentiels auto.
Local Decimal SOLRPT3D, SOLRPT3C, SOLRPT3 : # Soldes d'un compte (et un seul) dans la devise de référentiels auto.
Local Decimal SOLRPT4D, SOLRPT4C, SOLRPT4 : # Soldes d'un compte (et un seul) dans la devise de référentiels auto.
Local Decimal SOLRPT5D, SOLRPT5C, SOLRPT5 : # Soldes d'un compte (et un seul) dans la devise de référentiels auto.
Local Decimal SOLRPT6D, SOLRPT6C, SOLRPT6 : # Soldes d'un compte (et un seul) dans la devise de référentiels auto.
Local Decimal SOLRPT7D, SOLRPT7C, SOLRPT7 : # Soldes d'un compte (et un seul) dans la devise de référentiels auto.
Local Decimal SOLRPT8D, SOLRPT8C, SOLRPT8 : # Soldes d'un compte (et un seul) dans la devise de référentiels auto.
Local Decimal SOLRPT9D, SOLRPT9C, SOLRPT9 : # Soldes d'un compte (et un seul) dans la devise de référentiels auto.

Local Decimal SOLDEB, SOLCRE              : # Soldes des comptes ayant même Racine dans la devise de mouvements
Local Decimal SOLDEBLED, SOLCRELED        : # Soldes des comptes ayant même Racine dans la devise de référentiels
Local Decimal SOLDEBRPT1, SOLCRERPT1      : # Soldes des comptes ayant même Racine dans la devise de référentiels auto.
Local Decimal SOLDEBRPT2, SOLCRERPT2      : # Soldes des comptes ayant même Racine dans la devise de référentiels auto.
Local Decimal SOLDEBRPT3, SOLCRERPT3      : # Soldes des comptes ayant même Racine dans la devise de référentiels auto.
Local Decimal SOLDEBRPT4, SOLCRERPT4      : # Soldes des comptes ayant même Racine dans la devise de référentiels auto.
Local Decimal SOLDEBRPT5, SOLCRERPT5      : # Soldes des comptes ayant même Racine dans la devise de référentiels auto.
Local Decimal SOLDEBRPT6, SOLCRERPT6      : # Soldes des comptes ayant même Racine dans la devise de référentiels auto.
Local Decimal SOLDEBRPT7, SOLCRERPT7      : # Soldes des comptes ayant même Racine dans la devise de référentiels auto.
Local Decimal SOLDEBRPT8, SOLCRERPT8      : # Soldes des comptes ayant même Racine dans la devise de référentiels auto.
Local Decimal SOLDEBRPT9, SOLCRERPT9      : # Soldes des comptes ayant même Racine dans la devise de référentiels auto.

Local Integer SOLRPTFLG      : # Flag d'un montant forcé
Local Integer SOLDEBRPTFLG   : # Flag d'un montant forcé
Local Integer SOLCRERPTFLG   : # Flag d'un montant forcé

Local Decimal SOLCPTDEF      : # Cas de génération de X pièces => solde pièce dans la devise de mouvements
Local Decimal SOLCPTLED      : # Cas de génération de X pièces => solde pièce dans la devise de référentiels
Local Decimal SOLCPTRPT1     : # Cas de génération de X pièces => solde pièce dans la devise de référentiels auto.
Local Decimal SOLCPTRPT2     : # Cas de génération de X pièces => solde pièce dans la devise de référentiels auto.
Local Decimal SOLCPTRPT3     : # Cas de génération de X pièces => solde pièce dans la devise de référentiels auto.
Local Decimal SOLCPTRPT4     : # Cas de génération de X pièces => solde pièce dans la devise de référentiels auto.
Local Decimal SOLCPTRPT5     : # Cas de génération de X pièces => solde pièce dans la devise de référentiels auto.
Local Decimal SOLCPTRPT6     : # Cas de génération de X pièces => solde pièce dans la devise de référentiels auto.
Local Decimal SOLCPTRPT7     : # Cas de génération de X pièces => solde pièce dans la devise de référentiels auto.
Local Decimal SOLCPTRPT8     : # Cas de génération de X pièces => solde pièce dans la devise de référentiels auto.
Local Decimal SOLCPTRPT9     : # Cas de génération de X pièces => solde pièce dans la devise de référentiels auto.
Local Decimal SOLCPTRPT10    : # Cas de génération de X pièces => solde pièce dans la devise de référentiels auto.

Local Integer INDEXTYPLED

Local Decimal MAXECT
Local Char    CODTAX(GLONVAT), VAC(3), TIERS(GLONBPR), TYPTIERS(1)
Local Char    VALPAR(GLONADW)

Local Char    TZONE(10)(1..10) : # Table of the zones to be forced (Ex: ORICOD)   #*X3-39795
Local Char    TVAL(30)(1..10)  : # Table of values for zones to be forced         #*X3-39795

Local Decimal WSOL

Gosub OUVFIC

Local Mask CPTDUM [DIA]

Local Mask GACCENT0 [HAE0], GACCENT1 [HAE1], GACCENT2 [HAE2],  VENTILE [VTL], VENTILE2 [VT2],
&          GACCENTFMT [HAEF], GACCENTW [HAEW], SAICURLED [SCL]

MAXECT = dim([M:HAE2]SAC1)

TIT = mess(61,107,1) : # Validation code déversement
SVGTIT = TIT
Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","cp8") From GMEMO
Return

$OUVFIC
If clalev([F:PDM])=0  : Local File GAPARDUM   [PDM]  : Endif : # Déversements
If clalev([F:PDM2])=0 : Local File GAPARDUM   [PDM2] : Endif : # Déversements
If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif : # Société
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif : # Site
If clalev([F:FIY])=0  : Local File FISCALYEAR [FIY]  : Endif : # Exercices
If clalev([F:FGR])=0  : Local File FACGROUP   [FGR]  : Endif : # Groupe de sites
If clalev([F:LED])=0  : Local File GLED       [LED]  : Endif : # Référentiels
If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif : # Modèles comptable
If clalev([F:COA])=0  : Local File GCOA       [COA]  : Endif : # Code Plan

If clalev([F:BAL])=0  : Local File BALANCE    [BAL]  : Endif : # Balance
If clalev([F:BAL1])=0 : Local File BALANCE    [BAL1] : Endif : # Balance
If clalev([F:BAL2])=0 : Local File BALANCE    [BAL2] : Endif : # Balance
If clalev([F:BAL3])=0 : Local File BALANCE    [BAL3] : Endif : # Balance
If clalev([F:BAL4])=0 : Local File BALANCE    [BAL4] : Endif : # Balance
If clalev([F:BAL5])=0 : Local File BALANCE    [BAL5] : Endif : # Balance

If clalev([F:GAC])=0  : Local File GACCOUNT   [GAC]  : Endif : # Comptes
If clalev([F:GAC2])=0 : Local File GACCOUNT   [GAC2] : Endif : # Comptes
If clalev([F:HAE])=0  : Local File GACCTMP    [HAE]  : Endif : # Pièces comptables
If clalev([F:HAE1])=0 : Local File GACCENTRY  [HAE1] : Endif : # Pièces comptables
If clalev([F:DAE])=0  : Local File GACCTMPD   [DAE]  : Endif : # Lignes pièces comptables
If clalev([F:DAA])=0  : Local File GACCTMPA   [DAA]  : Endif : # Lignes pièces comptables
If clalev([F:TCU])=0  : Local File TABCUR     [TCU]  : Endif : # Devises
If clalev([F:ANM])=0  : Local File ACODNUM    [ANM]  : Endif : # Compteurs document
If clalev([F:AVN])=0  : Local File AVALNUM    [AVN]  : Endif : # Valeurs des compteurs
If clalev([F:GTE])=0  : Local File GTYPACCENT [GTE]  : Endif : # Type de pièces
If clalev([F:PER])=0  : Local File PERIOD     [PER]  : Endif : # Périodes
If clalev([F:JOU])=0  : Local File GJOURNAL   [JOU]  : Endif : # Journaux
If clalev([F:JST])=0  : Local File GAJOUSTA   [JST]  : Endif : # Etats de journaux
If clalev([F:BPR])=0  : Local File BPARTNER   [BPR]  : Endif : # Business Partner
If clalev([F:TVB])=0  : Local File TABVACBPR  [TVB]  : Endif
If clalev([F:TVT])=0  : Local File TABVAT     [TVT]  : Endif
If clalev([F:DUD])=0  : Local File GACCDUDATE [DUD]  : Endif : # Echéances

If clalev([F:GDE])=0  : Local File GDIAENTRY  [GDE]  : Endif : # Schéma de transaction
Return

$DEBUT
Raz [M]COA
Raz [M:DIA]INI : Affzo [DIA]
Setmok [DIA] With 0
Return

##############################################################################
$CONTROLE
If GOK<1
 FIN = 1 : Return
Else
 TMP = 1
Endif

If FIN : Return : Endif
Call AVERTDGI2([M:DIA]NBSOC,[M:DIA]SOC,[M:DIA]SITE,[M:DIA]TYPGEN,SAI) From CPTDIV2
If SAI : Return : Endif

Filter [PDM] Where COD = [M:DIA]DUM
Read [PDM]PDM0 Last
Filter [PDM]
SYMBOLE = "PDM"+[M:DIA]DUM+"\"+num$([F:PDM]NUMLIN)
Lock =SYMBOLE With lockwait=0
If fstat
 GMESSAGE = mess(30,100,1)
 GERR = 1 : Return
Endif
Return

##############################################################################
$FIN
If !GSERVEUR & [M:DIA]TRACE=2
 TRA = 1
Else
 TRA = 0
Endif
Return

$SORTIE
Return

##############################################################################
$EXEC
If GSERVEUR
 [M:DIA]TRACE = 2
Endif
TIT = SVGTIT
If !GSERVEUR & [M:DIA]TRACE=2
 Call OUVRE_TRACE(TIT-[M:DIA]DUM) From LECFIC
Endif
If [M:DIA]TRACE=2
 Call ECR_TRACE(TIT,0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

JOURNAL = [M:DIA]VCRJOU
DAT     = [M:DIA]VCRDAT
TYPEPCE = [M:DIA]VCRTYP
TYPLED  = [M:DIA]LEDTYP
DACDIA  = [M:DIA]DACDIA

Local Integer NBSOC , OKSOC
For [L]NBSOC=0 To [M:DIA]NBSOC-1
 # Reinit du site car valeur modifiée ds $PIECE
 SITE    = [M:DIA]SITE
 SOCIETE = [M:DIA]SOC([L]NBSOC)
 #--- Code taxe obligatoire
 If dim(GSAITAX)>0
  Call PARAM(SOCIETE,"SAITAX",VALPAR) From ADOVAL
  GSAITAX  = val(VALPAR)
 Endif
 #--- Code taxe exonéré
 If dim(GEXETAX)>0
  Call PARAM(SOCIETE,"EXETAX",VALPAR) From ADOVAL
  GEXETAX  = VALPAR
 Endif
 Call LOCKCPY(SOCIETE, OKSOC) From AX3MONO
 If OKSOC
  Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
  If [M:DIA]TYPGEN=1 & func AFNC.PARAM("FRADGI",SOCIETE)="2"
   STAECT = 2
  Else
   STAECT = [M:DIA]SIM
  Endif
  Call LECLED(SOCIETE,TYPLED,LEDCUR,DEVLED) From CPTDIV
  ILED = find(LEDCUR,GLED(1..GLEDNBR))
  If !ILED : Break : Endif
  Gosub ANUPCE
  If GOK<1 : Break : Endif
  Gosub CONTDAT
  If OK
   If SITE<>""
    NOL=0 : Gosub DEVISE
   Else
    For [FCY]FCY1 Where LEGCPY=SOCIETE & FINFLG=2
     SITE = [F:FCY]FCY
     NOL=0 : Gosub DEVISE
    Next
   Endif
  Endif
 Endif
 Call UNLOCKCPY() From AX3MONO
Next

$F_EXEC
If !GSERVEUR & GTRACE<>""
 Call FERME_TRACE From LECFIC
Endif
Unlock =SYMBOLE
Return

##############################################################################
$CONTDAT
OK = 1
Call GETPERSOC(SOCIETE,TYPLED,[M:DIA]STRDAT,EXE,PER) From CPTSUB
EXERCICE = EXE : PERIODE = PER
Call GETPERSOC(SOCIETE,TYPLED,[M:DIA]ENDDAT,EXE,PER) From CPTSUB
If EXERCICE<>EXE
 If GTRACE<>""
  Call ECR_TRACE(mess(2,45,1)-SOCIETE-":"-"("+tolower(mess(20,107,1))+")",1) From GESECRAN
 Endif
 OK = 0 : Return
Endif
Call GETPERSOC(SOCIETE,TYPLED,[M:DIA]VCRDAT,EXE,PER) From CPTSUB
If !PER | [F:PER]PERSTA<2
 If GTRACE<>""
  Call ECR_TRACE(mess(2,45,1)-SOCIETE-":"-tolower(mess(35,101,1)),1) From GESECRAN
 Endif
 OK = 0 : Return
Endif
Return

$DEVISE
Call GETPER(SITE,TYPLED,[M:DIA]STRDAT,EXER,PERIOD) From CPTSUB
Call GETPER(SITE,TYPLED,[M:DIA]ENDDAT,EXER,PERIOF) From CPTSUB
Read [FIY]FIY0 = SOCIETE;TYPLED;EXER
Call GETPER(SITE,TYPLED,[F:FIY]FIYEND,EXER,LASTPERIOD) From CPTSUB

For [BAL1]BAL2(2) Where CPY=SOCIETE & FCY=SITE & LEDTYP=[L]TYPLED & COA=GLEDCOA(ILED)
&                      & BPR="" & FIY=EXER
 DEVISE = [F:BAL1]CUR
 Gosub PIECE
Next
Return


$PIECE
GOK=1
Gosub RAZPCE

## Initialisation masque de référence [HAEF]
Call INIMSKFMT3(SITE,1,DACDIA,TYPEPCE,DAT,STAT) From SUBGASA

For [PDM]PDM0 Where COD=[M:DIA]DUM & COA=GLEDCOA(ILED)

 NBCHIFFRE = len(num$([F:PDM]ACCSTR))
 Gosub FILTRE

 Raz SOLCRE, SOLDEB
 Raz SOLCRELED, SOLDEBLED
 Raz SOLDEBRPT1, SOLCRERPT1
 Raz SOLDEBRPT2, SOLCRERPT2
 Raz SOLDEBRPT3, SOLCRERPT3
 Raz SOLDEBRPT4, SOLCRERPT4
 Raz SOLDEBRPT5, SOLCRERPT5
 Raz SOLDEBRPT6, SOLCRERPT6
 Raz SOLDEBRPT7, SOLCRERPT7
 Raz SOLDEBRPT8, SOLCRERPT8
 Raz SOLDEBRPT9, SOLCRERPT9
 Raz SOLDEBRPTFLG, SOLCRERPTFLG

 For [BAL2] Where CPY=SOCIETE & FCY=SITE & LEDTYP=[L]TYPLED & COA=GLEDCOA(ILED) & CUR=DEVISE
&          & left$([F:BAL2]ACC,NBCHIFFRE)=[F:PDM]ACCSTR
&          & BPR="" & FIY=EXER
  Gosub FILT2
  If OK
   Read [GAC2]GAC0 = GLEDCOA(ILED);[F:BAL2]ACC
   If !fstat
    Gosub RAZ_SOLD  #*X3-38378
    #    Raz SOLCPTD, SOLCPTC, SOLCPT
    #    Raz SOLLEDD, SOLLEDC, SOLLED
    #    Raz SOLRPT1D, SOLRPT1C, SOLRPT1
    #    Raz SOLRPT2D, SOLRPT2C, SOLRPT2
    #    Raz SOLRPT3D, SOLRPT3C, SOLRPT3
    #    Raz SOLRPT4D, SOLRPT4C, SOLRPT4
    #    Raz SOLRPT5D, SOLRPT5C, SOLRPT5
    #    Raz SOLRPT6D, SOLRPT6C, SOLRPT6
    #    Raz SOLRPT7D, SOLRPT7C, SOLRPT7
    #    Raz SOLRPT8D, SOLRPT8C, SOLRPT8
    #    Raz SOLRPT9D, SOLRPT9C, SOLRPT9
    #    Raz SOLRPTFLG
    Gosub LIGNE
   Endif
  Endif
 Next

 If SOLDEB<>0 | SOLCRE<>0 | SOLDEBRPTFLG=1 | SOLCRERPTFLG=1
  Gosub CONTREPART
  If GOK<1 : Break : Endif
 Endif

Next

If GOK<1 : Return : Endif
If [M:HAE2]NBLIG > 0
 Gosub VALPCE
 Gosub RAZPCE
Endif
Return

$FILTRE
# On met dans un tableau les racines du paramétrage qui commencent par la racine
#  que l'on est en train de traiter mais qui est plus longue que celle-ci
I=0 : Raz TABRAC

For [PDM2]PDM0 Where COD=[F:PDM]COD & COA=[F:PDM]COA
&                  & left$([F:PDM2]ACCSTR,NBCHIFFRE) = [F:PDM]ACCSTR
&                  & len([F:PDM2]ACCSTR) > NBCHIFFRE
 TABRAC(I)    = [F:PDM2]ACCSTR
 TABLNGRAC(I) = len([F:PDM2]ACCSTR)
 I+=1
Next
NBRAC = I
Return

$FILT2
# On regarde si le compte contenu dans [F:BAL2]ACC ne doit pas être traité par une autre racine
OK = 1
For I=0 To NBRAC-1
 If left$([F:BAL2]ACC,TABLNGRAC(I)) = TABRAC(I)
  OK = 0 : Break
 Endif
Next
Return

$LIGNE
If [F:GAC2]SAC=1

 ## Boucle sur référentiel renseigné

 For [BAL3]BAL0 Where LEDTYP=[L]TYPLED & COA=GLEDCOA(ILED) & ACC=[F:GAC2]ACC & CPY=SOCIETE & FCY=SITE & FIY=EXER
&                   & BPR="" & CUR=DEVISE
  SOLCPTD += sum([F:BAL3]DEB(PERIOD..PERIOF))
  SOLCPTC += sum([F:BAL3]CDT(PERIOD..PERIOF))
  SOLLEDD += sum([F:BAL3]DEBLED(PERIOD..PERIOF))
  SOLLEDC += sum([F:BAL3]CDTLED(PERIOD..PERIOF))
  If PERIOD=1 : # Gestion des A-nouveaux
   SOLCPTD += [F:BAL3]DEB(0)
   SOLCPTC += [F:BAL3]CDT(0)
   SOLLEDD += [F:BAL3]DEBLED(0)
   SOLLEDC += [F:BAL3]CDTLED(0)
  Endif
  # Gestion des clôtures (ajout 13ieme periode, si dernière période déversement=dernière période de l'exercice)
  If PERIOF=LASTPERIOD & dim([F:BAL2]DEB)>PERIOF+1
   SOLCPTD += [F:BAL3]DEB(PERIOF+1)
   SOLCPTC += [F:BAL3]CDT(PERIOF+1)
   SOLLEDD += [F:BAL3]DEBLED(PERIOF+1)
   SOLLEDC += [F:BAL3]CDTLED(PERIOF+1)
  Endif
 Next
 # Calcul du solde - Devise de mouvements
 SOLCPT = SOLCPTD - SOLCPTC
 If SOLCPT>0
  SOLDEB    += SOLCPT
 Elsif SOLCPT<0
  SOLCRE    -= SOLCPT
 Endif
 # Calcul du solde - Devise de référentiel
 SOLLED = SOLLEDD - SOLLEDC
 If SOLLED<>0
   SOLRPTFLG=1
 Endif
 If SOLLED>0
  SOLDEBLED +=  SOLLED
 Elsif SOLLED<0
  SOLCRELED -= SOLLED
 Endif
 If SOLDEBLED<>0 : SOLDEBRPTFLG=1 : Endif
 If SOLCRELED<>0 : SOLCRERPTFLG=1 : Endif

 ## Boucles sur les référentiels Automatiques du référentiel renseigné
 ##  Liste des types de référentiel x en valid auto
 ##  + Parcourt la balance pour chacun d'entre et calculer le SOLRPTx

 Call GETTYPLEDVLDAUT(SOCIETE,TYPLED,TYPLEDVLDAUT,NBRVLDAUT) From CPTDIV
 For I=1 To NBRVLDAUT
  INDEXTYPLED=TYPLEDVLDAUT(I)
  For [BAL4]BAL0 Where LEDTYP=INDEXTYPLED & COA=GLEDCOA(ILED) & ACC=[F:GAC2]ACC & CPY=SOCIETE & FCY=SITE & FIY=EXER
&                   & BPR="" & CUR=DEVISE

   Assign "SOLRPT"+num$(INDEXTYPLED)+"D" With sum([F:BAL4]DEBLED(PERIOD..PERIOF))+evalue("SOLRPT"+num$(INDEXTYPLED)+"D")
   Assign "SOLRPT"+num$(INDEXTYPLED)+"C" With sum([F:BAL4]CDTLED(PERIOD..PERIOF))+evalue("SOLRPT"+num$(INDEXTYPLED)+"C")

   If PERIOD=1 : # Gestion des A-nouveaux
    Assign "SOLRPT"+num$(INDEXTYPLED)+"D" With sum([F:BAL4]DEBLED(0))+evalue("SOLRPT"+num$(INDEXTYPLED)+"D")
    Assign "SOLRPT"+num$(INDEXTYPLED)+"C" With sum([F:BAL4]CDTLED(0))+evalue("SOLRPT"+num$(INDEXTYPLED)+"C")
   Endif
   # Gestion des clôtures (ajout 13ieme periode, si dernière période déversement=dernière période de l'exercice)
   If PERIOF=LASTPERIOD & dim([F:BAL2]DEB)>PERIOF+1
    Assign "SOLRPT"+num$(INDEXTYPLED)+"D" With sum([F:BAL4]DEBLED(PERIOF+1))+evalue("SOLRPT"+num$(INDEXTYPLED)+"D")
    Assign "SOLRPT"+num$(INDEXTYPLED)+"C" With sum([F:BAL4]CDTLED(PERIOF+1))+evalue("SOLRPT"+num$(INDEXTYPLED)+"C")
   Endif
  Next : #[BAL4]

  # Calcul du solde - Devise des référentiels automatiques
  Assign "SOLRPT"+num$(INDEXTYPLED) With evalue("SOLRPT"+num$(INDEXTYPLED)+"D")-evalue("SOLRPT"+num$(INDEXTYPLED)+"C")
  If evalue("SOLRPT"+num$(INDEXTYPLED))<>0
   SOLRPTFLG=1
  Endif
  If evalue("SOLRPT"+num$(INDEXTYPLED))>0
   Assign "SOLDEBRPT"+num$(INDEXTYPLED) With evalue("SOLDEBRPT"+num$(INDEXTYPLED))+evalue("SOLRPT"+num$(INDEXTYPLED))
  Elsif evalue("SOLRPT"+num$(INDEXTYPLED))<0
   Assign "SOLCRERPT"+num$(INDEXTYPLED) With evalue("SOLCRERPT"+num$(INDEXTYPLED))-evalue("SOLRPT"+num$(INDEXTYPLED))
  Endif
  If evalue("SOLDEBRPT"+num$(INDEXTYPLED))<>0 : SOLDEBRPTFLG=1 : Endif
  If evalue("SOLCRERPT"+num$(INDEXTYPLED))<>0 : SOLCRERPTFLG=1 : Endif
 Next I

 If SOLCPT<>0 | SOLRPTFLG
  NOL = [M:HAE2]NBLIG
  [M:HAE2]BPR(NOL) = ""
  [M:HAE2]SAC1(NOL) = ""
  [M:HAE2]ACC1(NOL) = [F:GAC2]ACC
  [M:HAE2]LEDTYP(NOL) = TYPLED
  [M:HAE2]DES(NOL) = mess(53,106,1)-[F:GAC2]ACC : # Solde compte [F:GAC2]ACC
  [M:HAE2]FCYLIN(NOL) = SITE
  Gosub INITAX
  [M:HAE2]TAX(NOL) = CODTAX

  If SOLCPT<0
   [M:HAE2]DEB(NOL) = -SOLCPT
  Elsif SOLCPT>0
   [M:HAE2]CDT(NOL) = SOLCPT
  Endif

  If sgn(SOLCPT)=sgn(SOLLED)
   Assign "[M:HAE2]AMTFRC"+num$([L]TYPLED)+"("+num$(NOL)+")" With abs(SOLLED)
  Else
   If SOLCPT<=0
    Assign "[M:HAE2]AMTFRC"+num$([L]TYPLED)+"("+num$(NOL)+")" With -SOLLED
   Else
    Assign "[M:HAE2]AMTFRC"+num$([L]TYPLED)+"("+num$(NOL)+")" With SOLLED
   Endif
  Endif
  Assign "[M:HAE2]AMTFLG"+num$([L]TYPLED)+"("+num$(NOL)+")" With 1

  For I=1 To NBRVLDAUT
   WSOL = evalue("SOLRPT"+num$(TYPLEDVLDAUT(I)))
   If sgn(SOLCPT)=sgn(WSOL)
    Assign "[M:HAE2]AMTFRC"+num$(TYPLEDVLDAUT(I))+"("+num$(NOL)+")" With abs(WSOL)
   Else
    If SOLCPT<=0
     Assign "[M:HAE2]AMTFRC"+num$(TYPLEDVLDAUT(I))+"("+num$(NOL)+")" With -WSOL
    Else
     Assign "[M:HAE2]AMTFRC"+num$(TYPLEDVLDAUT(I))+"("+num$(NOL)+")" With WSOL
    Endif
   Endif
   Assign "[M:HAE2]AMTFLG"+num$(TYPLEDVLDAUT(I))+"("+num$(NOL)+")" With 1
  Next

  Gosub INICCE

  [M:HAE2]NBLIG += 1
  If [M:HAE2]NBLIG+1 = MAXECT
   Gosub NVPCE
  Endif
 Endif

Elsif [GAC2]SAC=2
 # Compte de type Collectif, donc parcourt pour tous les tiers
 #X3-38378
 Link [BAL3] With [BPR]BPR0~=[F:BAL3]BPR
&     As [BLNK]
&     Where LEDTYP=[L]TYPLED & COA=GLEDCOA(ILED) & ACC=[F:GAC2]ACC & CPY=SOCIETE & FCY=SITE & FIY=EXER
&                   & BPR<>"" & CUR=DEVISE
&     Order By Key BLNK0= [BAL3]BPR

  For[BLNK]BLNK0
    #X3-38378 For [BAL3]BAL0 Where LEDTYP=[L]TYPLED & COA=GLEDCOA(ILED) & ACC=[F:GAC2]ACC & CPY=SOCIETE & FCY=SITE & FIY=EXER
    #&                   & BPR<>"" & CUR=DEVISE
    Gosub RAZ_SOLD  #*X3-38378
    #X3-38378 [F:BAL3] replaced by [F:BLNK]
    SOLCPTD += sum([F:BLNK]DEB(PERIOD..PERIOF))
    SOLCPTC += sum([F:BLNK]CDT(PERIOD..PERIOF))
    SOLLEDD += sum([F:BLNK]DEBLED(PERIOD..PERIOF))
    SOLLEDC += sum([F:BLNK]CDTLED(PERIOD..PERIOF))
    If PERIOD=1 : # Gestion des A-nouveaux
     SOLCPTD += [F:BLNK]DEB(0)
     SOLCPTC += [F:BLNK]CDT(0)
     SOLLEDD += [F:BLNK]DEBLED(0)
     SOLLEDC += [F:BLNK]CDTLED(0)
    Endif
    # Gestion des clôtures (ajout 13ieme periode, si dernière période déversement=dernière période de l'exercice)
    If PERIOF=LASTPERIOD & dim([F:BAL2]DEB)>PERIOF+1
     SOLCPTD += [F:BLNK]DEB(PERIOF+1)
     SOLCPTC += [F:BLNK]CDT(PERIOF+1)
     SOLLEDD += [F:BLNK]DEBLED(PERIOF+1)
     SOLLEDC += [F:BLNK]CDTLED(PERIOF+1)
    Endif
  # #X3-38378 Next #[BAL3]

 # Calcul du solde - Devise de mouvements
 SOLCPT = SOLCPTD - SOLCPTC
 If SOLCPT>0
  SOLDEB    += SOLCPT
 Elsif SOLCPT<0
  SOLCRE    -= SOLCPT
 Endif

 # Calcul du solde - Devise de référentiel
 SOLLED = SOLLEDD - SOLLEDC
 If SOLLED<>0
   SOLRPTFLG=1
 Endif
 If SOLLED>0
  SOLDEBLED + = SOLLED
 Elsif SOLLED<0
  SOLCRELED -= SOLLED
 Endif
 If SOLDEBLED<>0 : SOLDEBRPTFLG=1 : Endif
 If SOLCRELED<>0 : SOLCRERPTFLG=1 : Endif

 Call GETTYPLEDVLDAUT(SOCIETE,TYPLED,TYPLEDVLDAUT,NBRVLDAUT) From CPTDIV
 For I=1 To NBRVLDAUT
  INDEXTYPLED=evalue("TYPLEDVLDAUT("+num$(I)+")")

  For [BAL4]BAL0 Where LEDTYP=INDEXTYPLED & COA=GLEDCOA(ILED) & ACC=[F:GAC2]ACC & CPY=SOCIETE &  FCY=SITE  & FIY=EXER
&                   & BPR=[F:BLNK]BPR & CUR=DEVISE
#X3-38378 &         & BPR<>"" & CUR=DEVISE

   Assign "SOLRPT"+num$(INDEXTYPLED)+"D" With sum([F:BAL4]DEBLED(PERIOD..PERIOF))+evalue("SOLRPT"+num$(INDEXTYPLED)+"D")
   Assign "SOLRPT"+num$(INDEXTYPLED)+"C" With sum([F:BAL4]CDTLED(PERIOD..PERIOF))+evalue("SOLRPT"+num$(INDEXTYPLED)+"C")

   If PERIOD=1 : # Gestion des A-nouveaux
    Assign "SOLRPT"+num$(INDEXTYPLED)+"D" With sum([F:BAL4]DEBLED(0))+evalue("SOLRPT"+num$(INDEXTYPLED)+"D")
    Assign "SOLRPT"+num$(INDEXTYPLED)+"C" With sum([F:BAL4]CDTLED(0))+evalue("SOLRPT"+num$(INDEXTYPLED)+"C")
   Endif
   # Gestion des clôtures (ajout 13ieme periode, si dernière période déversement=dernière période de l'exercice)
   If PERIOF=LASTPERIOD & dim([F:BAL2]DEB)>PERIOF+1
    Assign "SOLRPT"+num$(INDEXTYPLED)+"D" With sum([F:BAL4]DEBLED(PERIOF+1))+evalue("SOLRPT"+num$(INDEXTYPLED)+"D")
    Assign "SOLRPT"+num$(INDEXTYPLED)+"C" With sum([F:BAL4]CDTLED(PERIOF+1))+evalue("SOLRPT"+num$(INDEXTYPLED)+"C")
   Endif
  Next : #[BAL4]

  # Calcul du solde - Devise des référentiels automatiques
  Assign "SOLRPT"+num$(INDEXTYPLED) With evalue("SOLRPT"+num$(INDEXTYPLED)+"D")-evalue("SOLRPT"+num$(INDEXTYPLED)+"C")
  If evalue("SOLRPT"+num$(INDEXTYPLED))<>0
   SOLRPTFLG=1
  Endif
  If evalue("SOLRPT"+num$(INDEXTYPLED))>0
   Assign "SOLDEBRPT"+num$(INDEXTYPLED) With evalue("SOLDEBRPT"+num$(INDEXTYPLED))+evalue("SOLRPT"+num$(INDEXTYPLED))
  Elsif evalue("SOLRPT"+num$(INDEXTYPLED))<0
   Assign "SOLCRERPT"+num$(INDEXTYPLED) With evalue("SOLCRERPT"+num$(INDEXTYPLED))-evalue("SOLRPT"+num$(INDEXTYPLED))
  Endif
  If evalue("SOLDEBRPT"+num$(INDEXTYPLED))<>0 : SOLDEBRPTFLG=1 : Endif
  If evalue("SOLCRERPT"+num$(INDEXTYPLED))<>0 : SOLCRERPTFLG=1 : Endif
 Next I

 If SOLCPT<>0 | SOLRPTFLG
  NOL = [M:HAE2]NBLIG
  [M:HAE2]SAC1(NOL)   = [F:GAC2]ACCSHO
  [M:HAE2]ACC1(NOL)   = [F:GAC2]ACC
  [M:HAE2]LEDTYP(NOL) = TYPLED
  ##X3-38378  [M:HAE2]BPR(NOL)  = [F:BAL3]BPR
  ##X3-38378  [M:HAE2]DES(NOL)  = mess(53,106,1)-[F:BAL3]BPR : # Solde compte
  [M:HAE2]BPR(NOL)    = [F:BLNK]BPR
  [M:HAE2]DES(NOL)    = mess(53,106,1)-[F:BLNK]BPR : # Solde compte
  [M:HAE2]FCYLIN(NOL) = SITE
  Gosub INITAX
  [M:HAE2]TAX(NOL)    = CODTAX

  If SOLCPT<0
   [M:HAE2]DEB(NOL) = -SOLCPT
  Elsif SOLCPT>0
   [M:HAE2]CDT(NOL) = SOLCPT
  Endif

  If sgn(SOLCPT)=sgn(SOLLED)
   Assign "[M:HAE2]AMTFRC"+num$([L]TYPLED)+"("+num$(NOL)+")" With abs(SOLLED)
  Else
   If SOLCPT<=0
    Assign "[M:HAE2]AMTFRC"+num$([L]TYPLED)+"("+num$(NOL)+")" With -SOLLED
   Else
    Assign "[M:HAE2]AMTFRC"+num$([L]TYPLED)+"("+num$(NOL)+")" With SOLLED
   Endif
  Endif
  Assign "[M:HAE2]AMTFLG"+num$([L]TYPLED)+"("+num$(NOL)+")" With 1

  For I=1 To NBRVLDAUT
   WSOL = evalue("SOLRPT"+num$(TYPLEDVLDAUT(I)))
   If sgn(SOLCPT)=sgn(WSOL)
    Assign "[M:HAE2]AMTFRC"+num$(TYPLEDVLDAUT(I))+"("+num$(NOL)+")" With abs(WSOL)
   Else
    If SOLCPT<=0
     Assign "[M:HAE2]AMTFRC"+num$(TYPLEDVLDAUT(I))+"("+num$(NOL)+")" With -WSOL
    Else
     Assign "[M:HAE2]AMTFRC"+num$(TYPLEDVLDAUT(I))+"("+num$(NOL)+")" With WSOL
    Endif
   Endif
   Assign "[M:HAE2]AMTFLG"+num$(TYPLEDVLDAUT(I))+"("+num$(NOL)+")" With 1
  Next

  Gosub INICCE

  [M:HAE2]NBLIG += 1
  If [M:HAE2]NBLIG+1 = MAXECT
   Gosub NVPCE
  Endif
 Endif

 Next # [F:BLNK] X3-38378

Endif
Return


$CONTREPART
If SOLDEB<>0 or (SOLDEB=0 & SOLDEBRPTFLG=1)
 NOL += 1
 [M:HAE2]ACC1(NOL) = [F:PDM]ACCDEB
 [M:HAE2]SAC1(NOL) = ""
 [M:HAE2]LEDTYP(NOL) = TYPLED
 [M:HAE2]DES(NOL) = mess(1,106,1)-tolower(mess(45,102,1))-[F:PDM]ACCSTR
 [M:HAE2]FCYLIN(NOL) = SITE
 Gosub INITAX
 [M:HAE2]TAX(NOL) = CODTAX

 If ([F:PDM]ACCCDT=[F:PDM]ACCDEB) & (SOLCRE<>0 or SOLCRERPTFLG=1)

  # Montant en devise de mouvements
  If SOLCRE<SOLDEB
   [M:HAE2]CDT(NOL) = 0
   [M:HAE2]DEB(NOL) = SOLDEB-SOLCRE
  Elsif SOLCRE>=SOLDEB
   [M:HAE2]DEB(NOL) = 0
   [M:HAE2]CDT(NOL) = SOLCRE-SOLDEB
  Endif

  # Montant en devise de référentiel
  WSOL = SOLDEBLED-SOLCRELED
  If sgn(SOLDEB-SOLCRE)=sgn(WSOL)
   Assign "[M:HAE2]AMTFRC"+num$([L]TYPLED)+"("+num$(NOL)+")" With abs(WSOL)
  Else
   If SOLDEB-SOLCRE>=0
    Assign "[M:HAE2]AMTFRC"+num$([L]TYPLED)+"("+num$(NOL)+")" With WSOL
   Else
    Assign "[M:HAE2]AMTFRC"+num$([L]TYPLED)+"("+num$(NOL)+")" With -WSOL
   Endif
  Endif
  Assign "[M:HAE2]AMTFLG"+num$([L]TYPLED)+"("+num$(NOL)+")" With 1

  # Montant en devise de référentiel auto.
  For I=1 To 9
   If I<>[L]TYPLED
    WSOL = evalue("SOLDEBRPT"+num$(I))-evalue("SOLCRERPT"+num$(I))
    If sgn(SOLDEB-SOLCRE)=sgn(WSOL)
     Assign "[M:HAE2]AMTFRC"+num$(I)+"("+num$(NOL)+")" With abs(WSOL)
    Else
     If SOLDEB-SOLCRE>=0
      Assign "[M:HAE2]AMTFRC"+num$(I)+"("+num$(NOL)+")" With WSOL
     Else
      Assign "[M:HAE2]AMTFRC"+num$(I)+"("+num$(NOL)+")" With -WSOL
     Endif
    Endif
    Assign "[M:HAE2]AMTFLG"+num$(I)+"("+num$(NOL)+")" With 1
   Endif
  Next I

 Else
  [M:HAE2]DEB(NOL) = SOLDEB

  If sgn(SOLDEB)=sgn(SOLDEBLED)
   Assign "[M:HAE2]AMTFRC"+num$([L]TYPLED)+"("+num$(NOL)+")" With abs(SOLDEBLED)
  Else
   Assign "[M:HAE2]AMTFRC"+num$([L]TYPLED)+"("+num$(NOL)+")" With SOLDEBLED
  Endif
  Assign "[M:HAE2]AMTFLG"+num$([L]TYPLED)+"("+num$(NOL)+")" With 1

  For I=1 To 9
   WSOL =  evalue("SOLDEBRPT"+num$(I))
   If I<>[L]TYPLED & WSOL<>0
    If sgn(SOLDEB)=sgn(WSOL)
     Assign "[M:HAE2]AMTFRC"+num$(I)+"("+num$(NOL)+")" With abs(WSOL)
    Else
     Assign "[M:HAE2]AMTFRC"+num$(I)+"("+num$(NOL)+")" With WSOL
    Endif
   Endif
   Assign "[M:HAE2]AMTFLG"+num$(I)+"("+num$(NOL)+")" With 1
  Next I

 Endif

 Gosub INICCE

 [M:HAE2]NBLIG += 1
 If [M:HAE2]NBLIG+1>=MAXECT & (SOLCRE<>0 or (SOLCRE=0 & SOLCRELED<>0)) & ([F:PDM]ACCCDT<>([F:PDM]ACCDEB))
  # Il va avoir une ligne supplémentaire car SOLCRE<>0 et on n'a plus de
  # place : il faur passer par le compte de report pour équilibrer la
  # pièce et la valider...
  Gosub NVPCE
  If GOK<1 : Return : Endif
 Elsif [M:HAE2]NBLIG+1>=MAXECT
  # La pièce est ici équilibrée mais on n'aura plus de place pour la
  # prochaine écriture... (NB : il faut prévoir 2 lignes pour la
  # prochaine écriture : 1 pour la nouvelle écriture et l'autre pour le
  # compte de report...)
  Gosub VALPCE
  If GOK<1 : Return : Endif
  Gosub RAZPCE
  NOL=0 : [M:HAE2]NBLIG=0
 Endif
Endif

#######

If (SOLCRE<>0 or (SOLCRE=0 & SOLCRERPTFLG=1)) & ([F:PDM]ACCCDT<>[F:PDM]ACCDEB | (SOLDEB=0 & SOLDEBRPTFLG=0))
 NOL+=1
 [M:HAE2]ACC1(NOL) = [F:PDM]ACCCDT
 [M:HAE2]SAC1(NOL) = ""
 [M:HAE2]LEDTYP(NOL) = TYPLED
 [M:HAE2]DES(NOL) = mess(1,106,1)-tolower(mess(45,102,1))-[F:PDM]ACCSTR
 [M:HAE2]FCYLIN(NOL) = SITE
 Gosub INITAX
 [M:HAE2]TAX(NOL)  = CODTAX

 [M:HAE2]CDT(NOL) = SOLCRE
 If sgn(SOLCRE)=sgn(SOLCRELED)
  Assign "[M:HAE2]AMTFRC"+num$([L]TYPLED)+"("+num$(NOL)+")" With abs(SOLCRELED)
 Else
  Assign "[M:HAE2]AMTFRC"+num$([L]TYPLED)+"("+num$(NOL)+")" With -SOLCRELED
 Endif
 Assign "[M:HAE2]AMTFLG"+num$([L]TYPLED)+"("+num$(NOL)+")" With 1

 For I=1 To 9
  WSOL=evalue("SOLCRERPT"+num$(I))
  If I<>[L]TYPLED & WSOL<>0
   If sgn(SOLCRE)=sgn(WSOL)
    Assign "[M:HAE2]AMTFRC"+num$(I)+"("+num$(NOL)+")" With abs(WSOL)
   Else
    Assign "[M:HAE2]AMTFRC"+num$(I)+"("+num$(NOL)+")" With -WSOL
   Endif
  Endif
  Assign "[M:HAE2]AMTFLG"+num$(I)+"("+num$(NOL)+")" With 1
 Next I

 Gosub INICCE

 [M:HAE2]NBLIG += 1
 If [M:HAE2]NBLIG+1>=MAXECT
  # La pièce est ici équilibrée mais on n'aura plus de place pour la
  # prochaine écriture... (NB : il faut prévoir 2 lignes pour la
  # prochaine écriture : 1 pour la nouvelle écriture et l'autre pour le
  # compte d'attente...)
  Gosub VALPCE
  If GOK<1 : Return : Endif
  Gosub RAZPCE
  NOL=0 : [M:HAE2]NBLIG=0
 Endif
Endif
Return

$NVPCE
# On n'a plus de place dans le tableau, on crée une nouvelle pièce en
# passant par un compte d'attente...
NOL = MAXECT-1
[M:HAE2]SAC1(NOL)    = ""
Call LECTURE("COA",GLEDCOA(ILED),"") From CONTOBJ
COMPTE=[F:COA]ACCMIS(1)
If COMPTE=""
 # Paramètre non renseigné
 Call ECR_TRACE("ACCTMP :"-mess(136,199,1),1) From GESECRAN
 GOK=0 : Return
Endif

[M:HAE2]ACC1(NOL)   = COMPTE
[M:HAE2]LEDTYP(NOL) = TYPLED

[M:HAE2]DES(NOL)    = mess(50,107,1)
[M:HAE2]FCYLIN(NOL) = SITE

Raz SOLCPTDEF
Raz SOLCPTLED
Raz SOLCPTRPT1
Raz SOLCPTRPT2
Raz SOLCPTRPT3
Raz SOLCPTRPT4
Raz SOLCPTRPT5
Raz SOLCPTRPT6
Raz SOLCPTRPT7
Raz SOLCPTRPT8
Raz SOLCPTRPT9
Raz SOLCPTRPT10

For II=0 To [M:HAE2]NBLIG-1
 If [M]DEB(II)>0
  SOLCPTDEF += [M:HAE2]DEB(II)
 Else
  SOLCPTDEF -= [M:HAE2]CDT(II)
 Endif

 If evalue("[M]AMT"+num$([L]TYPLED)+"("+num$(II)+")") > 0 or ([M]DEB(II)=0 and [M]CDT(II)=0)
  SOLCPTLED += evalue("[M]AMT"+num$([L]TYPLED)+"("+num$(II)+")")
 Else
  SOLCPTLED -= evalue("[M]AMT"+num$([L]TYPLED)+"("+num$(II)+")")
 Endif

 For JJ=1 To 10
  If II<>[L]TYPLED
   If evalue("[M]AMTFRC"+num$(JJ)+"("+num$(II)+")") > 0 or ([M]DEB(II)=0 and [M]CDT(II)=0)
    Assign "SOLCPTRPT"+num$(JJ) With evalue("SOLCPTRPT"+num$(JJ)) + evalue("[M]AMTFRC"+num$(JJ)+"("+num$(II)+")")
   Else
    Assign "SOLCPTRPT"+num$(JJ) With evalue("SOLCPTRPT"+num$(JJ)) - evalue("[M]AMTFRC"+num$(JJ)+"("+num$(II)+")")
   Endif
  Endif
 Next JJ
Next II

If SOLCPTDEF<0
 [M:HAE2]DEB(NOL) = -SOLCPTDEF
Else
 [M:HAE2]CDT(NOL) = SOLCPTDEF
Endif

If sgn(SOLCPTDEF)=sgn(SOLCPTLED)
 Assign "[M:HAE2]AMT"+num$([L]TYPLED)+"("+num$(NOL)+")" With abs(SOLCPTLED)
Else
 Assign "[M:HAE2]AMT"+num$([L]TYPLED)+"("+num$(NOL)+")" With SOLCPTLED
Endif

For KK=1 To 10
 WSOL = evalue("SOLCPTRPT"+num$(KK))
 If  sgn(SOLCPTDEF)=sgn(WSOL)
  Assign "[M:HAE2]AMTFRC"+num$(KK)+"("+num$(NOL)+")" With abs(WSOL)
 Else
  Assign "[M:HAE2]AMTFRC"+num$(KK)+"("+num$(NOL)+")" With WSOL
 Endif
 Assign "[M:HAE2]AMTFLG"+num$(KK)+"("+num$(NOL)+")" With 1
Next

Gosub INICCE

[M:HAE2]NBLIG += 1
Gosub VALPCE
If GOK<1 : Return : Endif
Gosub RAZPCE

NOL=0 : [M:HAE2]NBLIG=0

[M:HAE2]SAC1(NOL) = ""
[M:HAE2]ACC1(NOL)   = COMPTE
[M:HAE2]LEDTYP(NOL) = TYPLED

[M:HAE2]DES(NOL)    = mess(50,107,1)
[M:HAE2]FCYLIN(NOL) = SITE


If SOLCPTDEF<0
 [M:HAE2]CDT(NOL) = -SOLCPTDEF
Else
 [M:HAE2]DEB(NOL) = SOLCPTDEF
Endif

If sgn(SOLCPTDEF)=sgn(SOLCPTLED)
 Assign "[M:HAE2]AMT"+num$([L]TYPLED)+"("+num$(NOL)+")" With abs(SOLCPTLED)
Else
 Assign "[M:HAE2]AMT"+num$([L]TYPLED)+"("+num$(NOL)+")" With -SOLCPTLED
Endif

For KK=1 To 10
 WSOL = evalue("SOLCPTRPT"+num$(KK))
 If  sgn(SOLCPTDEF)=sgn(WSOL)
  Assign "[M:HAE2]AMTFRC"+num$(KK)+"("+num$(NOL)+")" With abs(WSOL)
 Else
  Assign "[M:HAE2]AMTFRC"+num$(KK)+"("+num$(NOL)+")" With -WSOL
 Endif
 Assign "[M:HAE2]AMTFLG"+num$(KK)+"("+num$(NOL)+")" With 1
Next

Gosub INICCE

[M:HAE2]NBLIG += 1
Return

$VALPCE
Call DEBTRANS From GLOCK
Gosub TR1
If GTRACE<>""
 If !STAT
  If [M:DIA]TYPGEN=1 & STAECT=2 & [M:DIA]SIM<>STAECT
   ## La pièce a été générée en définitif alors qu'on avait sélectionné 'Provisoire' : possible dans le cas où
   ## le traitement est lancé pour toutes sociétés et que la pièce a été créée sur une société avec le paramètre
   ## FRADGI à "Oui".
   Call ECR_TRACE(mess(40,107,1)-[M:HAE0]TYP-[M:HAE0]NUM-format$("D:"+GFMDAT4,[M:HAE0]ACCDAT)-"("+tolower(mess(192,107,1))+")",0) From GESECRAN
  Else
   Call ECR_TRACE(mess(40,107,1)-[M:HAE0]TYP-[M:HAE0]NUM-format$("D:"+GFMDAT4,[M:HAE0]ACCDAT),0) From GESECRAN
  Endif
 Else
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 Endif
Endif
Return

$TR1
GOK=1
Trbegin [HAE], [DAE], [DAA]
 Raz [M:HAE0]NUM
 mkstat = 0
 Gosub VERFDAT
 If mkstat
  STAT=1
  If GTRACE<>""
   Call ECR_TRACE(SOCIETE-JOURNAL-format$("D:"+GFMDAT4,DAT)-GMESSAGE,1) From GESECRAN
  Endif
  GOK = 0 : Goto AB_TR1
 Endif

 [M:HAE0]FCY    = SITE
 [M:HAE0]CPY    = [F:CPY]CPY
 [M:HAE0]TYP    = [M:DIA]VCRTYP
 [M:HAE0]ACCDAT = [M:DIA]VCRDAT
 [M:HAE0]JOU    = [M:DIA]VCRJOU
 [M:HAE0]CAT    = [M:DIA]TYPGEN
 [M:HAE0]STA    = STAECT

 [M:HAE0]DACDIA = DACDIA
 [M:HAEF]DACDIA = DACDIA
 [M:HAEF]TYPENT = 1

 Call GETPERSOC([M:HAE0]CPY,TYPLED,[M:HAE0]ACCDAT,EXERCICE,PERIODE) From CPTSUB

 [M:HAE0]FIY = EXERCICE
 [M:HAE0]PER = PERIODE

 [M:HAE1]ENTDAT = [M:DIA]VCRDAT
 [M:HAE1]DUDDAT = [M:DIA]VCRDAT
 [M:HAE1]VALDAT = [M:DIA]VCRDAT
 [M:HAE1]CUR    = [L]DEVISE
 [M:HAE1]ORIMOD = 2
 [M:HAE1]DESVCR = mess(62,107,1)-[M:DIA]DUM : # Déversement de comptes
 If [M:DIA]TYPGEN>=2 : # Simulation
  [M:HAE1]REFSIM = REF_SIM
 Endif
 [M:HAE1]REFINT = "DUM" : # A cause du contrôle euro
 # La propagation sera effectuée via le VALPCE
 #  => Propagation automatique des référentiels via les règles de saisie de pièces comptables.
 [M:HAE1]FLGGEN = 3

 Call CONTROLE(STAT,MESSA) From CPTBATCH
 If STAT
  Gosub MESSAGE From CPTAUTO
  Call ECR_TRACE(MESSA,1) From GESECRAN
  STAT = 1 : GOK=0 : Goto AB_TR1
 Endif
 TZONE(5)= "ORIGIN" : TVAL(5)= "2"        :#Automatic loading  #*X3-39795
 TZONE(6)= "ORICOD" : TVAL(6)= "CPTDUM"                        #*X3-39795
 #*X3-39795 Call VALPIECE(STAT,MESSA) From CPTBATCH
 Call VALPIECE2(STAT,MESSA,TZONE,TVAL) From CPTBATCH
 If STAT
  Call ECR_TRACE(MESSA,1) From GESECRAN
 Endif
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 [M:HAE0]NUM = [F:HAE]NUM

Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

$ANUPCE
CRITERE = '1=1'
CRITERE -='& CPY = "'+SOCIETE+'"'
If [M:DIA]SITE<>""
 CRITERE -= '& FCY = "'+[M:DIA]SITE+'"'
Endif

REF_SIM = "DU"+[M:DIA]DUM
GOK = 1
For [HAE1] Where evalue(CRITERE) & REFSIM=REF_SIM & CAT>1
 # Annulation pièce
 If [M:DIA]TRACE=2
  Call ECR_TRACE(mess(41,107,1)-[F:HAE1]TYP-[F:HAE1]NUM,0) From GESECRAN
 Endif
 Call DELPCE([F:HAE1]TYP,[F:HAE1]NUM) From CPTBATCH
Next
Return

$INICCE
If GLEDFLGANA(ILED)=2
 Call LEC_GDE([M:DIA]DACDIA) From CPTLEC
 For INDEX=1 To GLEDDIENBR(ILED)
  SECTION = ""
  Call INICCE(SECTION,evalue("GDIE"+num$(INDEX)+"("+num$(ILED)+")"),LEDCUR,[M:HAE2]ACC1(NOL),[F:GDE]CDE) From CPTINI
  INDMSK=find(evalue("GDIE"+num$(INDEX)+"("+num$(ILED)+")"),[M:HAEF]DIE(0..dim([M:HAEF]DIE)-1))
  If SECTION<>""
   Assign "[M:HAE2]CCE"+num$(INDMSK)+"("+num$(NOL)+")" With SECTION
  Endif
 Next
Endif
Return

$RAZPCE
Raz [M:HAE0]
Raz [M:HAE1]
Raz [M:HAE2]
Return



#########################################################################
## Etiquettes du masque CPTDUM [CDU] (Validation d'un code déversement)
#########################################################################
Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Integer OPTION
If [M:DIA]SOC(0)=""
 [M]NBSOC = 1
 [M]SOC(0)=GDEFSOC
 Affzo 10
Endif
OPTION=7
Call LEDTYP_CHOICE([M:DIA]SOC(0),OPTION) From CPTDIV
End

Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
If [M:DIA]SOC(0)<>"" & VALEUR<>[M]LEDTYP
 Raz [M]NBSOC, [M]SITE
 Call C_GRPSOC([M]GRPSOC)
Endif
Call C_LEDTYP(VALEUR) From CPTTRT
End

Subprog C_GRPSOC(VALEUR)
Variable Char    VALEUR()
Local Integer OKSOC
Local Char    SOCIETE(GLONCPY)
If VALEUR<>"" & VALEUR<>[M]GRPSOC
 If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
 [M]NBSOC = 0
 For [AGC] Where GRP=VALEUR
  SOCIETE = [F:AGC]CPY
  Gosub OKSOC
  If OKSOC
   Gosub CONTSOC
  Endif
  If OKSOC
   [M]SOC([M]NBSOC) = SOCIETE
   [M]NBSOC += 1
  Endif
 Next
 Affzo 10
Elsif VALEUR="" & dim([M]NBSOC)>0 & [M]NBSOC=0 & dim([M]SITE)>0 & [M]SITE=""
 Raz [M]SOC
 [M]NBSOC = 1
 [M]SOC(0)=GDEFSOC
 Affzo 10
Endif
End

$OKSOC
#Vérification de la compatibilité avec le code plan du déversement
Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
Call LEC_GCM([F:CPY]ACM) From CPTLEC
Call LEC_LED([F:GCM]LED([M]LEDTYP-1)) From CPTLEC

# Initialisation du COA
If [M]NBSOC=0 & [F:LED]COA<>""
 [M]COA = [F:LED]COA
 OKSOC = 1
# En modification de la 1ère société, ré-initialise le COA
Elsif [M]NBSOC=1 & nolign=1 & [F:LED]COA<>""
 [M]COA = [F:LED]COA
 OKSOC = 1
# En contrôle de compatibilité.
Else
 OKSOC = ([F:LED]COA=[M]COA)
Endif
Return

Subprog C_NBSOC
Call C_NBSOC From CPTTRT
End

Subprog AS_SOC(VALEUR)
Variable Char    VALEUR()
If nolign=1 & VALEUR=""
 VALEUR = GDEFSOC
Endif
End

Subprog C_SOC(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]SOC) From OBJDIV
If mkstat : End : Endif
Local Integer OKSOC
Local Char    SOCIETE(GLONCPY)
SOCIETE = VALEUR
GSOCIETE = VALEUR
Gosub OKSOC
If !OKSOC
 GMESSAGE = mess(93,102,1)
 mkstat = 2 : End
Endif
Gosub CONTSOC
If !OKSOC
 GMESSAGE = mess(32,104,1)
 mkstat = 2 : End
Endif
If GCURFCY=""
 I = find(GSOCIETE,GSOCSITE(1..GNBSITE))
 GCURFCY = GSITE(I)
Endif
End

$CONTSOC
If GUSRFCY(1)<>"\"
 Local Integer I
 Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
 For I=1 To GNBSITE
  If SOCIETE=GSOCSITE(I) & !find(GSITE(I),GUSRFCY(1..GNBAUZ))
   OKSOC = 0 : Break
  Endif
 Next I
Endif
Return

Subprog C_DUM(VALEUR)
Variable Char VALEUR()
Read [PDM]PDM0 = [M]COA;VALEUR
If fstat
 GMESSAGE = VALEUR-":"-mess(23,100,1)-"\("+mess(134,107,1)-":"-[M]COA+")"
 mkstat = 2 : End
Endif
Call LEC_COA([M]COA) From CPTLEC
If [F:COA]GENTRK<>2 :
 GMESSAGE = VALEUR-":"-mess(83,123,1)-"\("+mess(134,107,1)-":"-[M]COA+")"
 mkstat = 2 : End
Endif
End

Subprog AS_SITE(VALEUR)
Variable Char    VALEUR()
If [M]NBSOC>1 : mkstat = 1 : End : Endif
End

Subprog C_SITE(VALEUR)
Variable Char    VALEUR()
Local Integer OKSOC
Local Char    SOCIETE(GLONCPY)
If VALEUR=""
 If [M]NBSOC=0
  GMESSAGE = mess(9,109,1)
  mkstat = 2
 Endif
 End
Endif
Call LECTURE("FCY",VALEUR,"") From CONTOBJ
SOCIETE = [F:FCY]LEGCPY
GSOCIETE = SOCIETE
If [M]NBSOC>0 & SOCIETE<>[M]SOC(0)
 GMESSAGE = mess(30,106,1)-SOCIETE
 mkstat = 2 : End
Endif
GCURFCY=VALEUR
Gosub OKSOC
End

Subprog AS_STRDAT(VALEUR)
Variable Date    VALEUR
Call AS_STRDAT(VALEUR) From CPTTRT
End

Subprog AS_VCRTYP(VALEUR)
Variable Char    VALEUR()
If (VALEUR="" & [M:DIA]TYPGEN<>1) # Génération Simulation
 If [M]SITE<>""
  Call PARAML([M]SITE,"TYPACC",VALEUR) From ADOVAL
 Elsif [M]SOC(0)<>""
  Call PARAML([M]SOC(0),"TYPACC",VALEUR) From ADOVAL
 Elsif GCURLEG<>""
  Call PARAM(GCURLEG,"TYPACC",VALEUR) From CPTLEC
 Endif
Elsif (VALEUR="" & [M:DIA]TYPGEN=1)
 If [M]SITE<>""
  Call PARAML([M]SITE,"VCRTYPDUM",VALEUR) From ADOVAL
 Elsif [M]SOC(0)<>""
  Call PARAML([M]SOC(0),"VCRTYPDUM",VALEUR) From ADOVAL
 Elsif GCURLEG<>""
  Call PARAM(GCURLEG,"VCRTYPDUM",VALEUR) From CPTLEC
 Endif
Endif
End

Subprog C_VCRTYP(VALEUR)
Variable Char VALEUR
# No control if all the companies have a different legislation (GCURLEG="")
If GCURLEG<>""
 Call CONTEXE([F:GTE]ACS) From CPTSUB
 If mkstat : End : Endif
 If [M]TYPGEN=1 & [F:GTE]VCRREA<>2
  GMESSAGE = mess(33,107,1) : mkstat = 2 : End
 Elsif [M]TYPGEN>=2 & [F:GTE]VCRSIM<>2
  GMESSAGE = mess(32,107,1) : mkstat = 2 : End
 Endif
Endif
End


Subprog AS_VCRJOU(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 VALEUR = [F:GTE]DEFJOU
Endif
End

Subprog C_VCRJOU(VALEUR)
Variable Char VALEUR
Local Decimal OFIY, OPER
# No control if all the companies have a different legislation (GCURLEG="")
If GCURLEG<>""
 Call CONTEXE([F:JOU]ACS) From CPTSUB
 If mkstat : GMESSAGE = VALEUR-GMESSAGE : End : Endif
 If [F:GTE]AUZJOU([F:JOU]TYP-1)<>2
  GMESSAGE = [F:JOU]JOU-mess(8,106,1)
  mkstat = 2 : End
 Endif
 Call VERSOC([F:JOU]FCY,[M]CPY,[M]FCY,[F:JOU]JOU) From CFYSUB
 If mkstat : End : Endif
Endif
End

Subprog AS_VCRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
 VALEUR = datesyst
Endif
End

Subprog C_VCRDAT(VALEUR)
Variable Date    VALEUR
Local Char TYPEPCE(GLONGTE)
Local Date DAT
TYPEPCE = [M]VCRTYP
DAT = VALEUR
# GCURLEG="" if there are many companies in the array
If GCURLEG<>""
 Gosub VERFDAT
Endif
End

$VERFDAT
mkstat = 0
Call LEC_GTE_LEG(GCURLEG,TYPEPCE) From CPTLEC
Call CTLVLYDAT(DAT,[F:GTE]VLYSTR,[F:GTE]VLYEND) From CPTSUB
If mkstat=2 : Return : Endif
Return

Subprog AS_SIM(VALEUR)
Variable Integer VALEUR
Local Char SOCIETE(GLONCPY)
If [M]TYPGEN<>1 : mkstat = 1 : End : Endif
If [M]NBSOC=0
 Call LECTURE("FCY",[M]SITE,"") From CONTOBJ
 [L]SOCIETE = [F:FCY]LEGCPY
Elsif [M]NBSOC=1
 [L]SOCIETE = [M]SOC(0)
Endif
If [L]SOCIETE<>""
 If func AFNC.PARAM("FRADGI",[L]SOCIETE)="2" : # Paramètre à Oui
  VALEUR = 2 : mkstat = 2 : End
 Endif
Endif
End

Subprog C_TYPGEN(VALEUR)
Variable Integer VALEUR
If VALEUR<>1 : Grizo SIM : Else : Actzo SIM : Endif
End

Subprog AM_TYPGEN(VALEUR)
Variable Integer VALEUR
[M:DIA]VCRTYP = ""
[M:DIA]VCRJOU = ""
End

Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Call D_INI(VALEUR) From CPTTRT
If [M]TYPGEN<>1 : Grizo SIM : Else : Actzo SIM : Endif
End

$INITAX
Raz CODTAX
Call LEC_GAC([M:HAE2]ACC1(NOL),GLEDCOA(ILED)) From CPTLEC
If [F:GAC]FLGVAT=1 : Return : Endif
# Code taxe pas obligatoire au niveau du compte
If GSAITAX=1 & [F:GAC]VAT(0)=""
 TIERS=""
 For I=NOL To 0 Step -1
  If [M:HAE2]BPR(I)<>"" : TIERS=[M:HAE2]BPR(I) : Break : Endif
 Next I
 If TIERS<>""
  TYPTIERS = " "
  Read [BPR]BPR0 = TIERS
  If !fstat
   If [F:BPR]BPCFLG=2 : TYPTIERS="C"
   Elsif [F:BPR]BPSFLG=2 : TYPTIERS="F"
   Endif
  Endif
  Call INIT_REGIME(TIERS,[M:HAE2]FCYLIN(I),TYPTIERS,[L]VAC) From CPTSUB
  Call LEC_TVB(GCURLEG,[L]VAC) From CPTLEC
  If !fstat & [F:TVB]ENAFLG=2 : CODTAX = [F:TVB]VAT : Endif
 Endif
Endif
# Code taxe renseigné au niveau du compte général
If CODTAX=""
 CODTAX = [F:GAC]VAT(0)
Endif
# Paramètre EXETAX (Tronc commun)
If CODTAX="" : CODTAX = GEXETAX : Endif
Return

Subprog C_DACDIA(VALEUR)
Variable Char    VALEUR()
Call LECTURE("GDE",VALEUR,"") From CONTOBJ
If !find([M]LEDTYP,[F:GDE]LEDTYP(0..[F:GDE]NBRLED-1))
 GMESSAGE = mess(82,103,1)
 mkstat   = 2 : End
Endif
End
#*X3-38378 ===============================
$RAZ_SOLD
    Raz SOLCPTD, SOLCPTC, SOLCPT
    Raz SOLLEDD, SOLLEDC, SOLLED
    Raz SOLRPT1D, SOLRPT1C, SOLRPT1
    Raz SOLRPT2D, SOLRPT2C, SOLRPT2
    Raz SOLRPT3D, SOLRPT3C, SOLRPT3
    Raz SOLRPT4D, SOLRPT4C, SOLRPT4
    Raz SOLRPT5D, SOLRPT5C, SOLRPT5
    Raz SOLRPT6D, SOLRPT6C, SOLRPT6
    Raz SOLRPT7D, SOLRPT7C, SOLRPT7
    Raz SOLRPT8D, SOLRPT8C, SOLRPT8
    Raz SOLRPT9D, SOLRPT9C, SOLRPT9
    Raz SOLRPTFLG
Return
#================================
