#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIHRM001 - Set activity codes (PAPI and HRNOF) values to OFF          #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Delete activity codes (HISCT,NTPS,NCA,PCOM,HRCOM)") From LECFIC

  Call MAJ_UTIHRM011(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTIHRM011(DOSSIER)
Value Char DOSSIER
Local Char CODE (GLONACV)

If clalev([F:ACV])=0  : Local File =DOSSIER+".ACTIV"   [ACV]  : Endif

Call ECR_TRACE("Delete activity codes (HISCT,NTPS,NCA,PCOM,HRCOM) : "+DOSSIER,0) From GESECRAN

For [ACV]CODACT = "HISCT","NTPS","NCA","HRCOM","PCOM"

  [L]CODE = [F:ACV]CODACT
  Read [ACV]CODACT = [L]CODE
  If !fstat
    Call ANNULATION(DOSSIER,"ACV",[L]CODE,"") From ANUCOD
    Call ECR_TRACE("Deleted activity code : "+[L]CODE+" from "+DOSSIER,0) From GESECRAN
  Else
    Call ECR_TRACE("Deletion of activity code : "+[L]CODE+" cancelled from "+DOSSIER+" -Activity code does not exist",0) From GESECRAN
  Endif
Next

Call ECR_TRACE("UTIHRM011: Process completed on : "+DOSSIER,0) From GESECRAN

Close Local File [ACV]

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If filinfo(filpath("FIL","ACTIV","fde",APPLI),0)<=0 : End : Endif
If func DOSVUE.ISVIEW(APPLI,"ACTIV") : End : Endif
Call MAJ_UTIHRM011(APPLI)

End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If filinfo(filpath("FIL","ACTIV","fde",APPLI),0)<=0 : End : Endif
If func DOSVUE.ISVIEW(APPLI,"ACTIV") : End : Endif
Call MAJ_UTIHRM011(APPLI)

End

