#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################################
# Programme : PREPFASLIST                                                               #
#                                                                                       #
# Fonction  :                                                                           #
#      1- Managment of the table TMPFASLIST                                             #
#    Modification :
# UUUUU jj.mm.aaaa nnnnnn_nn Cccccccccccccccccccccccccccccccccccccccccccccccccccccccc
# MWA   11.01.2017 120796    La sélection sur le type de détention ne fonctionne pas.
# CBO   30.11.2016 120112    Paramètre actif pris en compte (ENAFLG)
# MDJ   03.02.2016 114161    Intitulés Code comptable absents (en sqlserver)
# MDJ   09/02/2015 FQ100398  Suppression site géographique
# CBO   29/04/2014 FQ-69690  Objet FAM
# MDJ   15/01/2014 FQ-XXXXX  Creation of the standard processing for the report FASLIST
#########################################################################################

######################################################################################
$ACTION

    Case ACTION
        When "OUVRE" :   Gosub OUVRE
        When "EXEC"  :   Gosub EXEC
        When "FIN"   :   Gosub FIN
    Endcase
Return
######################################################################################
$OUVRE
#=============================================================================
# traitement PREPFASLIST : alimentation de la table TMPFASLIST
#=============================================================================
If clalev([F:TFL])=0    : Local File TMPFASLIST [TFL] : Endif
If clalev([F:TFLM])=0   : Local File TMPFASLIST [TFLM] : Endif

If clalev([F:FAS])=0   : Local File FXDASSETS   [FAS]  : Endif
If clalev([F:CCE])=0   : Local File CACCE       [CCE]  : Endif
If clalev([F:DSP])=0   : Local File CADSP       [DSP]  : Endif

If clalev([F:CPY])=0   : Local File COMPANY     [CPY] : Endif
If clalev([F:GCM])=0   : Local File GACM        [GCM] : Endif
If clalev([F:LED])=0   : Local File GLED        [LED] : Endif
If clalev([F:DIE])=0   : Local File GDIE        [DIE] : Endif

If clalev([F:CNX])=0   : Local File CONTEXT     [CNX]  : Endif
If clalev([F:CNXI])=0  : Local File CONTEXT     [CNXI] : Endif  # Context IAS/IFRS plan

If clalev([F:FIY])=0   : Local File FISCYEAR    [FIY]  : Endif
If clalev([F:DEP])=0   : Local File DEPREC      [DEP]  : Endif  # Current FIY DEPREC of Accounts plan

If clalev([F:FCY])=0   : Local File FACILITY    [FCY]  : Endif  # Financial sites

If clalev([F:CAC])=0   : Local File GACCCODE    [CAC]  : Endif  # Accounting code
If clalev([F:GACC])=0  : Local File GACCOUNT    [GACC] : Endif  # CoA account
If clalev([F:GACI])=0  : Local File GACCOUNT    [GACI] : Endif  # IAS account

If clalev([F:BPR])=0  : Local File BPARTNER     [BPR] : Endif   # Supplier

If clalev([F:ADI])=0  : Local File ATABDIV      [ADI] : Endif   # Miscellaneous table  (Family, Activity, UGT... )
If clalev([F:AFF])=0  : Local File AFCTFCY      [AFF] : Endif   # Site profile function

If clalev([FAM])=0 : Local File FASFAM [FAM] : Endif

Return
######################################################################################
$FIN

Unlock PREPFASLIST

Return
######################################################################################
$EXEC

Lock PREPFASLIST With lockwait = 3
If fstat
   Return
Endif

Gosub MAJ_TMPFASLIST

Return
###################################################
$MAJ_TMPFASLIST
#------------------------------------------------------------------------------------#
#--- Création table temporaire TMPFASLIST pour l'état FASLIST                     ---#
#------------------------------------------------------------------------------------#

   Gosub OUVRE

    Local Integer I, I_COA      # Compteur paramètres / Indices
    Local Integer RCNX, WCNX
    Local Char LCPY             # Company deb
    Local Char LCPYDEB          # Company deb
    Local Char LCPYFIN          # Company fin
    Local Char LFCYDEB          # Company site deb
    Local Char LFCYFIN
    Local Char LCCPTDEB         # Accounting code deb
    Local Char LCCPTFIN         #                fin
    Local Char LACCDEB          # CoA account deb
    Local Char LACCFIN          #            fin
    Local Char LIASACDEB        # IAS account deb
    Local Char LIASACFIN        #            fin
    Local Char LDIE             # Axe
    Local Char LCCEDEB          #  Section déb
    Local Char LCCEFIN          #  Section fin
    Local Char LACGGRPDEB       # Family  deb
    Local Char LACGGRPFIN       #         fin
    Local Char LBPRDEB          # Supplier  deb
    Local Char LBPRFIN          #       fin

    Local Integer LTYPDETDEB    # Holding type deb
    Local Integer LTYPDETFIN    #          fin

    Local Char LACTDEB       # Activity  deb
    Local Char LACTFIN       #           fin

    Local Char LUGTDEB       #  UGT  deb
    Local Char LUGTFIN       #           fin
    Local Char LPLNDEB       #  Invest Project  deb
    Local Char LPLNFIN       #           fin
    Local Char LBUDDEB       #  Invest Budget  deb
    Local Char LBUDFIN       #           fin

    Local Date   LDATCPTDEB     # Posting date début
    Local Date   LDATCPTFIN     # Date fin
    Local Date   LDATMESDEB     # Date put into service début
    Local Date   LDATMESFIN     # Date fin
    Local Date   LDATSORDEB     # Issue date début
    Local Date   LDATSORFIN     # Date fin
    Local Char   LREFDEB          # réf deb
    Local Char   LREFFIN          # réf fin

    Local Integer LACTIF        # Active ?


    Local Integer LDET          # Detail ?

    Local Integer LEDTNUM       # Identifiant session
    Local Char    LCRITERE  (250) # Critère de sélection
    Local Char    LCRITERE2 (250) # Critère de sélection
    Local Char    LCRITERE3 (250) # Critère de sélection
    Local Char    LCRITANA  (250) # Critère de sélection
    Local Decimal WENDDPET
    Local Char    SCPY         #  Company
    Local Char    SFCY         #* Financial site
    Local Char    X3PRF        #* Code profil user
    Local Char    X3FCT        #* Fonction
    Global Char   GWCOA        #* Plan de compte
    Local Integer NBAXE
    Local Char    AXE(GLONDIE)(1..3)


    If clalev([TFL])=0 : Local File TMPFASLIST [TFL] : Endif
    Trbegin [TFL]
    Delete [TFL] Where CREUSR = GUSER
    If fstat = 1
      #  "Problème à l'effacement du fichier temporaire"
      Call MESSAGE (mess(155,197,1)) From GESECRAN
      Rollback
      Return
    Else
       Commit
    Endif

   Call GETPARAM("cpydeb",NBPAR,PARAMETRE,LCPYDEB)
   Call GETPARAM("cpyfin",NBPAR,PARAMETRE,LCPYFIN)

   Call GETPARAM("fcydeb",NBPAR,PARAMETRE,LFCYDEB)
   Call GETPARAM("fcyfin",NBPAR,PARAMETRE,LFCYFIN)

   Call GETPARAM("typdetdeb",NBPAR,PARAMETRE,PARAM)    : LTYPDETDEB = val(PARAM)
   Call GETPARAM("typdetfin",NBPAR,PARAMETRE,PARAM)    : LTYPDETFIN = val(PARAM)

   Call GETPARAM("ccptdeb",NBPAR,PARAMETRE,LCCPTDEB)
   Call GETPARAM("ccptfin",NBPAR,PARAMETRE,LCCPTFIN)

   Call GETPARAM("accdeb",NBPAR,PARAMETRE,LACCDEB)
   Call GETPARAM("accfin",NBPAR,PARAMETRE,LACCFIN)

   Call GETPARAM("accifrsdeb",NBPAR,PARAMETRE,LIASACDEB)
   Call GETPARAM("accifrsfin",NBPAR,PARAMETRE,LIASACFIN)

   Call GETPARAM("axe",NBPAR,PARAMETRE,LDIE)
   Call GETPARAM("secdeb",NBPAR,PARAMETRE,LCCEDEB)
   Call GETPARAM("secfin",NBPAR,PARAMETRE,LCCEFIN)

   Call GETPARAM("acggrpdeb",NBPAR,PARAMETRE,LACGGRPDEB)
   Call GETPARAM("acggrpfin",NBPAR,PARAMETRE,LACGGRPFIN)

   Call GETPARAM("bprdeb",NBPAR,PARAMETRE,LBPRDEB)
   Call GETPARAM("bprfin",NBPAR,PARAMETRE,LBPRFIN)

   Call GETPARAM("actdeb",NBPAR,PARAMETRE,LACTDEB)
   Call GETPARAM("actfin",NBPAR,PARAMETRE,LACTFIN)

  Call GETPARAM("ugtdeb",NBPAR,PARAMETRE,LUGTDEB)
  Call GETPARAM("ugtfin",NBPAR,PARAMETRE,LUGTFIN)

   Call GETPARAM("plndeb",NBPAR,PARAMETRE,LPLNDEB)
   Call GETPARAM("plnfin",NBPAR,PARAMETRE,LPLNFIN)

  Call GETPARAM("buddeb",NBPAR,PARAMETRE,LBUDDEB)
  Call GETPARAM("budfin",NBPAR,PARAMETRE,LBUDFIN)

   Call GETPARAM("datcptdeb",NBPAR,PARAMETRE,PARAM)    : LDATCPTDEB  =  PARAM
   Call GETPARAM("datcptfin",NBPAR,PARAMETRE,PARAM)    : LDATCPTFIN  =  PARAM
   Call GETPARAM("datmesdeb",NBPAR,PARAMETRE,PARAM)    : LDATMESDEB  =  PARAM
   Call GETPARAM("datmesfin",NBPAR,PARAMETRE,PARAM)    : LDATMESFIN  =  PARAM
   Call GETPARAM("datsordeb",NBPAR,PARAMETRE,PARAM)    : LDATSORDEB  =  PARAM
   Call GETPARAM("datsorfin",NBPAR,PARAMETRE,PARAM)    : LDATSORFIN  =  PARAM

   Call GETPARAM("refdeb",NBPAR,PARAMETRE,LREFDEB)
   Call GETPARAM("reffin",NBPAR,PARAMETRE,LREFFIN)


   Call GETPARAM("actif",NBPAR,PARAMETRE,PARAM)     : LACTIF     = val(PARAM)
   Call GETPARAM("detail",NBPAR,PARAMETRE,PARAM)    : LDET       = val(PARAM)
   Call GETPARAM("edtnum",NBPAR,PARAMETRE,PARAM)    : LEDTNUM    = val(PARAM)

   Call GETPARAM("X3PRF",NBPAR,PARAMETRE,X3PRF)
   Call GETPARAM("X3FCT",NBPAR,PARAMETRE,X3FCT)

   LCRITERE = "1=1"
   LCRITERE2 = "1=1"
   LCRITERE3 = "1=1"
   LCRITANA = "1=1"

   For I=1 To NBPAR
      J=instr(1,[L]PARAMETRE(I),"=")
      If J
         [L]PARAM  = left$([L]PARAMETRE(I),J-1)
         [L]VALEUR = right$([L]PARAMETRE(I),J+1)
         Case [L]PARAM

            When "cpydeb"     :     LCRITERE += "& CPY >='"+LCPYDEB+"'"
            When "cpyfin"     :     LCRITERE += "& CPY <='"+LCPYFIN+"'"

            When "fcydeb"     :     LCRITERE += "& FCY >='"+LFCYDEB+"'"
            When "fcyfin"     :     LCRITERE += "& FCY <='"+LFCYFIN+"'"

            # FQ120796
            #When "typdetdeb"  :     LCRITERE += "& OWNTYP >='"+LTYPDETDEB+"'"
            #When "typdetfin"  :     LCRITERE += "& OWNTYP <='"+LTYPDETFIN+"'"
            When "typdetdeb"  :     LCRITERE += "& OWNTYP >="+num$(LTYPDETDEB)
            When "typdetfin"  :     LCRITERE += "& OWNTYP <="+num$(LTYPDETFIN)

            When "ccptdeb"    :     LCRITERE += "& ACCCOD >='"+LCCPTDEB+"'"
            When "ccptfin"    :     LCRITERE += "& ACCCOD <='"+LCCPTFIN+"'"

            When "accdeb"     :     LCRITERE += "& GAC >='"+LACCDEB+"'"
            When "accfin"     :     LCRITERE += "& GAC <='"+LACCFIN+"'"

            When "accifrsdeb" :     LCRITERE += "& IASACC >='"+LIASACDEB+"'"
            When "accifrsfin" :     LCRITERE += "& IASACC <='"+LIASACFIN+"'"

            When "refdeb"     :     LCRITERE += "& AASREF >='"+LREFDEB+"'"
            When "reffin"     :     LCRITERE += "& AASREF <='"+LREFFIN+"'"

            When "acggrpdeb"  :     LCRITERE2 += "& ACGGRP >='"+LACGGRPDEB+"'"
            When "acggrpfin"  :     LCRITERE2 += "& ACGGRP <='"+LACGGRPFIN+"'"

            When "bprdeb"     :     LCRITERE2 += "& BPR >='"+LBPRDEB+"'"
            When "bprfin"     :     LCRITERE2 += "& BPR <='"+LBPRFIN+"'"

            When "ugtdeb"     :     LCRITERE2 += "& IASCGU >='"+LUGTDEB+"'"
            When "ugtfin"     :     LCRITERE2 += "& IASCGU <='"+LUGTFIN+"'"

            When "plndeb"     :     LCRITERE2 += "& INVPLN >='"+LPLNDEB+"'"
            When "plnfin"     :     LCRITERE2 += "& INVPLN <='"+LPLNFIN+"'"

            When "buddeb"     :     LCRITERE2 += "& BUDREF >='"+LBUDDEB+"'"
            When "budfin"     :     LCRITERE2 += "& BUDREF <='"+LBUDFIN+"'"

            When "datcptdeb"  :
            If LDATCPTDEB  > [01/01/1900]
               LCRITERE3 +=  "& AASIPTDAT >= ["+format$(GFMD,LDATCPTDEB)+"]"
               LCRITERE3 +=  "& AASIPTDAT <= ["+format$(GFMD,LDATCPTFIN)+"]"
            Else
               LCRITERE3 +=  "& AASIPTDAT <= ["+format$(GFMD,LDATCPTFIN)+"]"
            Endif
            When "datmesdeb"  :
            If LDATMESDEB  > [01/01/1900]
               LCRITERE3 +=  "& ITSDAT >= ["+format$(GFMD,LDATMESDEB)+"]"
               LCRITERE3 +=  "& ITSDAT <= ["+format$(GFMD,LDATMESFIN)+"]"
            Else
               LCRITERE3 +=  "& ITSDAT <= ["+format$(GFMD,LDATMESFIN)+"]"
            Endif
            When "datsordeb"  :
            If LDATSORDEB > [01/01/1900]
               LCRITERE3 +=  "& ISSDAT >= ["+format$(GFMD,LDATSORDEB)+"]"
               LCRITERE3 +=  "& ISSDAT <= ["+format$(GFMD,LDATSORFIN)+"]"
            Else
               If LDATSORFIN > [01/01/1900]
                  LCRITERE3 +=  "& ISSDAT <= ["+format$(GFMD,LDATSORFIN)+"]"
               Endif
            Endif

         Endcase
      Endif
   Next

 Read [CPY]CPY0 = LCPYDEB

 Read [GCM]GCM0 = [F:CPY]ACM

 If LDIE <> ""
    If (LCPYDEB = "") or (LCPYDEB <> LCPYFIN)
       # Axe non pris en compte si état multi-sociétés
       Call MESSAGE ( mess(64,7784,1)) From GESECRAN
       GOK = 0 : Goto ENDFASLIST
    Else

       Local Mask FASPARCPY [FPC]
       Local Integer ERROR
       Raz [M:FPC]

       Call LOAD_FASPARCPY(LCPYDEB,"FPC",G_NON,ERROR) From GLOFCYCPY
       Local Integer IDX_AXE
       IDX_AXE=find(LDIE,[M:FPC]DIE)

       LCRITANA += "& [F:FAS]DIE(" + num$(IDX_AXE-1) + ") = '" + LDIE + "'"

       If (LCCEDEB <> "") & (LCCEDEB = LCCEFIN)
          LCRITANA += "&  [F:FAS]CCE(" + num$(IDX_AXE-1) + ") = '" + LCCEDEB + "'"
       Else
          If LCCEDEB <>""
             LCRITANA += "& [F:FAS]CCE(" + num$(IDX_AXE-1) + ") >= '" + LCCEDEB + "'"
             LCRITANA += "& [F:FAS]CCE(" + num$(IDX_AXE-1) + ") <= '" + LCCEFIN + "'"
          Endif
       Endif
     Endif
  Else
    If LCCEDEB <> ""
       # Section interdite si axe non saisi
       Call MESSAGE ( mess(65,7784,1)) From GESECRAN
       GOK = 0 :  Goto ENDFASLIST
     Endif
  Endif
#--------------------------------
   If clalev([TFL])=0 : Local File TMPFASLIST [TFL] : Endif
   Trbegin [TFL]
   Delete [TFL] Where CREUSR = GUSER
   If fstat=1 | fstat>5
      Rollback
    Else
        Commit
   Endif

   If GOK=0
      Rollback
      Unlock[TFL]
      Return
   Endif
   #
   Trbegin [TFL]
   SFCY= ""
   GWCOA= ""
   If LACTIF = 1 # Issue 120112
     Filter [FAS] Where  (evalue(LCRITERE) ) & (evalue (LCRITERE2)) & (evalue (LCRITERE3)) & (evalue (LCRITANA) ) and
&                     ( ENAFAS=2 )
   Else
     Filter [FAS] Where  (evalue(LCRITERE) ) & (evalue (LCRITERE2)) & (evalue (LCRITERE3)) & (evalue (LCRITANA) ) and
&                     ( ENAFAS<>2 )
   Endif # End Issue 120112
   For [FAS]FAS1
      # Lecture contexte du plan
      Call GET_CNX_FROM_PLAN ([F:FAS]CPY, G301CPT, RCNX) From GLOBIENS
      WCNX=RCNX
      Read[CNX]CNX0= [F:FAS]CPY;RCNX
      If fstat=0
         I_COA = find(G301CPT,[F:CNX]PLNCAA(0..[F:CNX]NBPLC-1))
         If I_COA > 0
            GWCOA= [F:CNX]COA(I_COA-1)
         Endif
      Endif
      If [F:FAS]FCY <> SFCY
         Read[FCY]FCY0=[F:FAS]FCY
         If [F:FCY]LEGCPY <> [F:FAS]CPY
             SFCY= [F:FAS]FCY
            Goto NEXTFAS
         Endif
         Read [AFF]AFF0 = [F:FAS]FCY;X3PRF;X3FCT
         If fstat <> 0
            SFCY= [F:FAS]FCY
            Goto NEXTFAS
         Endif
         SFCY= [F:FAS]FCY
      Endif
      #1------------
      Raz[TFLM]
      [F:TFLM] = [F:FAS]
      [F:TFLM]COA = GWCOA
      #=========================================================
      # Récupération des intitulés des champs
      #=========================================================
      Read [CPY]CPY0    = [F:FAS]CPY
      If fstat=0 :     [F:TFLM]CPYNAM    = [F:CPY]CPYNAM  : Endif
      Read [FCY]FCY0    = [F:FAS]FCY
      If fstat=0 :     [F:TFLM]FCYNAM    = [F:FCY]FCYNAM : Endif
      [F:TFLM]AASDES1   = [F:FAS]AASDES1
      # Issue 114161 Read[CAC]CAC0="15";[F:FAS]ACCCOD;GWCOA
      Read[CAC]CAC0=15;[F:FAS]ACCCOD;GWCOA
      If fstat=0
         Call LECTEXTRA([F:TFLM]ACCDES,"GACCCODE","DESTRA","15",[F:FAS]ACCCOD) From ATEXTRA
         # Issue 114161 [F:TFLM]ACCDES=[F:CAC]DESTRA
          Endif
      Read[GACC]GAC0=GWCOA;[F:FAS]GAC
      If fstat=0
         Call LECTEXTRA([F:TFLM]GACDES,"GACCOUNT","DESTRA",GWCOA,[F:FAS]GAC) From ATEXTRA
      Endif
      Read[GACI]GAC0=GWCOA;[F:FAS]IASACC :
      If fstat=0
         Call LECTEXTRA([F:TFLM]IASACCDES,"GACCOUNT","DESTRA",GWCOA,[F:FAS]IASACC) From ATEXTRA
      Endif

      Read[DSP]DSP0=[F:FAS]DSP;1
      If fstat=0
       [F:TFLM]DSPDES = [F:DSP]DESTRA
      Endif

      [F:TFLM]OWNTYPDEB=mess(LTYPDETDEB,3171,1)
      [F:TFLM]OWNTYPFIN=mess(LTYPDETFIN,3171,1)

      #* Récupération des intitulés de l'axe
      [F:TFLM]DIE=LDIE

      Read [F:FAM]FAM0 = [F:FAS]ACGGRP
#      Read [ADI]CODE = GTD_FAMCPT;[F:FAS]ACGGRP
      If fstat=0
#         Call LECTEXTRA ([F:TFLM]ACGGRPDES, "ATABDIV", "LNGDES", num$(GTD_FAMCPT), [F:ADI]CODE) From ATEXTRA
         Call LECTEXTRA ([F:TFLM]ACGGRPDES, "FASFAM", "FAMDES", [F:FAS]ACGGRP, "") From ATEXTRA
      Endif

      Read [ADI]CODE = 613;[F:FAS]IASCGU
      If fstat=0
         Call LECTEXTRA ([F:TFLM]IASCGUDES, "ATABDIV", "LNGDES", "613", [F:ADI]CODE) From ATEXTRA
      Endif
      #=========================================================
       [F:TFLM]DPRBASPCG = [F:FAS]ACGETRNOT+[F:FAS]IVCVATAMT-[F:FAS]DEDVATAMT
       [F:TFLM]DPRBASIAS = [F:FAS]IASETRNOT+[F:FAS]IVCVATAMTI-[F:FAS]DEDVATAMTI
       [F:TFL]=[F:TFLM]
       [F:TFL]EDTNUM = LEDTNUM
       [F:TFL]CREUSR = GUSER
       [F:TFL]CREDAT = date$
       Write [F:TFL]
       If fstat <> 0
          GOK=0
          Rollback
          Unlock[TFL]
          Break
       Else
          Commit
          Unlock[TFL]
       Endif
      #1------------
      $NEXTFAS
   Next # [FAS]
   Filter[FAS]

 $ENDFASLIST

 If GOK : Commit : Else Rollback : Endif

Unlock PREPFASLIST

Return
######################################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
End
####################################################
#================================================================
Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L

   Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
   L = len(PARAM)
   If right$(PARAM,L-2)="deb"
      If VALEUR=string$(len(VALEUR)," ")
          VALEUR = ""
      Endif
   Endif

End
####################################################

