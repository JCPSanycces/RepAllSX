# Supervisor
## CRUD-CLASSE ## CACCE
# 2018-11-06 07:03:59 428


############################################################################################
### Subprog _ADELETE
############################################################################################
Subprog _ADELETE(CACCE,ASTATUS)
Variable Instance CACCE Using C_CACCE
Variable Integer ASTATUS

If CACCE = null : End : Endif

Gosub _AVARIABLES From WMC00CACCE

[L]A_STRSITE = ""
[L]A_STRACC = CACCE.ACS
Local Instance ALNKDELTAB Using C_ALNKDELTAB
Gosub ADELETE_CACCE

End

############################################################################################
### Subprog ADELETE
############################################################################################
Subprog ADELETE(CACCE,ASTATUS)
Variable Instance CACCE Using C_CACCE
Variable Integer ASTATUS

If CACCE = null : End : Endif

Gosub AVARIABLES From WMC00CACCE
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

Local Instance ALNKDELTAB Using C_ALNKDELTAB

[L]A_STRSITE = ""
[L]A_STRACC = CACCE.ACS
Gosub ADELETE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

If !adxlog
 Gosub ADELETE_TR_CACCE
Else
 Gosub ADELETE_CACCE
Endif

$ADELETE_END
End


$ADELETE_CONTROL
Gosub _ADELETE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Verification delete
[L]ASTATUS = max([L]ASTATUS,func ASYRSUB.VERIFY_INSTANCE(CACCE,ALNKDELTAB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _ADELETE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_BEFORE
If CACCE.ASTALIN = [V]CST_ANEWDEL : Return : Endif
CACCE.ASTALIN = [V]CST_ADEL
[L]ASTATUS = max([L]ASTATUS,fmet CACCE.ACTION("ADELETE_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For [L]A_I=1 To maxtab(CACCE.DIEOTH)
 If CACCE.DIEOTH([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet CACCE.DIEOTH([L]A_I).ACTION("ADELETE_CONTROL_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For [L]A_I=1 To maxtab(CACCE.DISUOM)
 If CACCE.DISUOM([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet CACCE.DISUOM([L]A_I).ACTION("ADELETE_CONTROL_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_AFTER

For [L]A_I=1 To maxtab(CACCE.DIEOTH)
 If CACCE.DIEOTH([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet CACCE.DIEOTH([L]A_I).ACTION("ADELETE_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For [L]A_I=1 To maxtab(CACCE.DISUOM)
 If CACCE.DISUOM([L]A_I)<>null
  [L]ASTATUS = max([L]ASTATUS,fmet CACCE.DISUOM([L]A_I).ACTION("ADELETE_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
[L]ASTATUS = max([L]ASTATUS,fmet CACCE.ACTION("ADELETE_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_TR_CACCE
Trbegin [F:CCE]
 Gosub ADELETE_CACCE
 If [L]ASTATUS>=[V]CST_AERROR : Gosub ADELETE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$ADELETE_CACCE
[L]ASTATUS = max([L]ASTATUS,fmet CACCE.ACTION("ADELETE_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = func ASYRSUB.DELETE_LINKS(CACCE,ALNKDELTAB)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00CACCE._MAJSQL_CACCE(CACCE))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet CACCE.ACTION("ADELETE_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_ABORT
Rollback
$_ADELETE_ABORT
If CACCE.snapshotEnabled=1
 [L]A_RETIK = CACCE.revertUpdTick
Endif
[L]ASTATUS = max(fmet CACCE.ACTION("ADELETE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#

#-----------------------------------------------------#
$_ADELETE_AFTER
Return



