################################################################################
# Mon petit bazar jusqu'à ce que je le connaisse par coeur
#     Infbox "ligne = "-num$(nolign)
################################################################################
################################################################################
$ACTION
  #Infbox "ACTION="-num$(ACTION)
  Gosub ACTION From ASELOBJ : # Pour faire tout ce qui va bien en standard
  Case ACTION
    When "OK" 
      GLDAPCRIT = PARAM(2)
      GLDAPSTAR = val(PARAM(3))
      Gosub REMPLI_SOURCE From FUNLOFLDAB
      Call AS_NBSRCE From W1LOFLDAB
      Affzo [M:LOF6]15 
  Endcase
Return

