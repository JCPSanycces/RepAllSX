#<AdxTL>@(#)1.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Copy data from table ACLASSE to ACLACOL, ACLAOPT
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("Copy data from table ACLASSE to ACLACOL and ACLAOPT") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJTAB
End

#----------------------------------------------------------------------------------------#

#----------------------------------------------------------------------------------------#

$MAJTAB

If DOSSIER=nomap
 Local File ACLASSE [ACLA]
 Local File ACLACOL [ACLAC]
 Local File ACLAOPT [ACLAO]
Else
 Local File =DOSSIER+".ACLASSE" [ACLA]
 Local File =DOSSIER+".ACLACOL" [ACLAC]
 Local File =DOSSIER+".ACLAOPT" [ACLAO]
Endif

If dim([F:ACLA]CODGRP)<0
 Return
Endif

Local Integer I

Trbegin [ACLA]
 For [ACLA]

  #Options
  For I=1 To 20
   If [F:ACLA]OPTCOD(I-1)<>""
    Read [ACLAO]ACLAO0=[F:ACLA]CODCLA;[F:ACLA]OPTCOD(I-1)
    If fstat
      Raz [F:ACLAO]
      [F:ACLAO]=[F:ACLA]

      [F:ACLAO]OPTCOD=[F:ACLA]OPTCOD(I-1)
      [F:ACLAO]OPTLIB=[F:ACLA]OPTLIB(I-1)
      [F:ACLAO]OPTCND=[F:ACLA]OPTCND(I-1)
      [F:ACLAO]OPTERR=[F:ACLA]OPTERR(I-1)
      Write [ACLAO]
      If fstat
       Call ERREUR("ACLAOPT"-[F:ACLA]CODCLA-[F:ACLAO]OPTCOD,1) From DOSDIC
      Endif
    Endif
   Endif
  Next I

  #Collections
  For I=1 To 20
   If [F:ACLA]CODGRP(I-1)<>""
    Read [ACLAC]ACLAC0=[F:ACLA]CODCLA;[F:ACLA]CODGRP(I-1)
    If fstat
      Raz [F:ACLAC]
      [F:ACLAC]=[F:ACLA]

      [F:ACLAC]CODCOL=[F:ACLA]CODGRP(I-1)
      [F:ACLAC]ACTCOL=[F:ACLA]ACTGRP(I-1)
      [F:ACLAC]MINCOL=[F:ACLA]MINGRP(I-1)
      [F:ACLAC]MAXCOL=[F:ACLA]MAXGRP(I-1)
      [F:ACLAC]PROCOL=[F:ACLA]PROGRP(I-1)
      [F:ACLAC]INTCOL=[F:ACLA]INTGRP(I-1)
      [F:ACLAC]FLGINSCOL=[F:ACLA]FLGINSGRP(I-1)
      [F:ACLAC]FLGSUPCOL=[F:ACLA]FLGSUPGRP(I-1)
      [F:ACLAC]FLGTRICOL=[F:ACLA]FLGTRIGRP(I-1)
      [F:ACLAC]FLGAPDCOL=[F:ACLA]FLGAPDGRP(I-1)

      Write [ACLAC]
      If fstat
       Call ERREUR("ACLACOL"-[F:ACLA]CODCLA-[F:ACLAC]CODCOL,1) From DOSDIC
      Endif
    Endif
   Endif
  Next I

 Next
Commit

Close Local File [ACLA],[ACLAO],[ACLAC]

Return
