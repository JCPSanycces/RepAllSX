# Here, the PARAM(1..NBPAR), VALEUR(1..NBPAR), TYPVAL(1..NBPAR) are filled and can be transcoded
$TRANSCODE_LINK

  If SIMUL=2 : Return : Endif : # No transcodification done, because a test of consistency will be done on what would be rewritten

Local Integer IDTYP, IDCOD, IDPA1, IDPA2

    IDTYP=find("xtype",PARAM(1..NBPAR)) : If IDTYP=0 : Return : Endif
    IDCOD=find("xcode",PARAM(1..NBPAR))
    IDPA1=find("xparam1",PARAM(1..NBPAR))
    IDPA2=find("xparam2",PARAM(1..NBPAR))

    Case VALEUR(IDTYP)
      When "url"     : Gosub TRANSCODE_URL
      When "report"  : Gosub TRANSCODE_REPORT
      When "request" : Gosub TRANSCODE_REQUEST
      When "erpfunc" : Gosub TRANSCODE_ERPFUNC
      When "stat"    : Gosub TRANSCODE_STAT
      When "page"    : Gosub TRANSCODE_PAGE
      When "consult" : Gosub TRANSCODE_CONSULT
      When "reportbo": Gosub TRANSCODE_REPORTBO
      When "x3help"  : Gosub TRANSCODE_X3HELP
      When Default   : Gosub TRANSCODE_DEFAULT
    Endcase
Return

$TRANSCODE_URL : # Nothing to do ! -- except a 'main' target (Dominique, 16th of October)
  Gosub ADD_MAIN
Return

$TRANSCODE_REPORT : # must be a convergence URL
  If IDCOD=0 : Return : Endif
  VALEUR(IDTYP)="url"
  CHAINE=VALEUR(IDCOD)

# Fix for classic pages links: a dedicated variable is necessary Dom Sept 18, 2014
  VALEUR(IDCOD)="{$baseTrans}/$sessions?f=AIMP~"+CHAINE
  VALEUR(IDCOD)+="/2/" : # return to the menu

  Gosub ADD_MAIN
Return

$TRANSCODE_REQUEST : # Modified the 19th of June, graphical requests can also be transcoded as Syrapedia links
  If IDCOD=0 : Return : Endif

  If VALEUR(IDCOD)<>""
    Read [ALH]ALH0=VALEUR(IDCOD)
    If fstat : Raz [ALH] : Endif : # If request not found, call the convergence request execution (Sept 20, 2013)
  Else
    Raz [ALH]
  Endif

  # Classical and graphical requests will be managed in Syrapedia
  # - cube mode set no no by default Oct 8th)
  # - level set to 1: SAM 119105
  If [ALH]TYP=1 or [ALH]TYP=3
    VALEUR(IDCOD)="{$baseUrl}/QUERY('"+VALEUR(IDCOD)+"')?representation=QUERY~"+VALEUR(IDCOD)+"~1.$query&level=1&cube=false&forcedExecution=true" :#SAM 117732
    Gosub ADD_MAIN
  Else

# Fix for classic pages links: a dedicated variable is necessary Dom Sept 18, 2014
    VALEUR(IDCOD)="{$baseTrans}/$sessions?f=EXEALH"+string$([ALH]COD<>"","~"+[ALH]COD)
    VALEUR(IDCOD)+="/2/" : # return to the menu
    Gosub ADD_MAIN
  Endif

  VALEUR(IDTYP)="url"
Return

$TRANSCODE_ERPFUNC : # Depending on the case, will be a convergence URL or a Syrapedia URL

# Let's first manage the rotten cases
  If IDCOD=0 : Return : Endif
  If VALEUR(IDCOD)="" : Return : Endif

# Is the function an object with a class and a representation associated to it ?
# If yes IFSYRA is set to 1
  IFSYRA=0
  OBJCOD=""
  #{SAM 118129
   If left$(VALEUR(IDCOD),3)="GES"
    Read [AFC]CODINT=VALEUR(IDCOD)
    CHAINE=vireblc([AFC]VALPAR(0),2)
    If pat(CHAINE,'"*"')
     Read [AOB]ABREV=seg$(CHAINE,2,len(CHAINE)-1)
     If fstat=0
      OBJCOD=[AOB]ABREV
      If CONVONLY<>2
       # Is it a link to syracuse ?
       For [ACLA] Where TYPCLA=2 and TABREF=[AOB]NOMFIC
         For [ASW] Where CODCLA=[ACLA]CODCLA
           IFSYRA=1
           Break 2 :#Break ASW and ACLA loops
         Next ASW
       Next ACLA
      Endif
     Endif
    Endif
  Endif
  #SAM 118129}

  # Link for Syracuse link
  If IFSYRA=1
    VALEUR(IDTYP)="url"
    VALEUR(IDCOD)="{$baseUrl}/"+[ACLA]CODCLA
    If IDPA2<>0 and VALEUR(IDPA2)<>""
      VALEUR(IDCOD)+="('"+VALEUR(IDPA2)+"')?representation="+[ASW]CODREP+".$details"
    Else
      VALEUR(IDCOD)+="?representation="+[ASW]CODREP+".$query"
    Endif

  Else
  # Workflow style link for convergence
    VALEUR(IDTYP)="url"
    CHAINE=VALEUR(IDCOD)

  # Fix for classic pages links: a dedicated variable is necessary Dom Sept 18, 2014
    VALEUR(IDCOD)="{$baseTrans}/$sessions?f="+CHAINE
    If IDPA1>0 and VALEUR(IDPA1)<>""
      VALEUR(IDCOD)+="~"+VALEUR(IDPA1)
    Endif
    VALEUR(IDCOD)+="/2/" : # return to the menu
    # Manage the second parameter for objects and some other functions
    If OBJCOD<>"" or find(CHAINE,"ADPVAL")<>0
      If IDPA2>0 and VALEUR(IDPA2)<>""
        VALEUR(IDCOD)+="OBJ"+OBJCOD+"/M/"+VALEUR(IDPA2)
      Endif
    Endif
  Endif

  # Manage xlabel and suppress the unused parameter for the URL
  I=find("xlabel",PARAM(1..NBPAR))
  If I
    J=find("xparam1label",PARAM(1..NBPAR))
    If J and VALEUR(J)<>""
      VALEUR(I)-="/"-VALEUR(J)
    Endif
    J=find("xparam2",PARAM(1..NBPAR))
    If J and VALEUR(J)<>""
      VALEUR(I)-="/"-VALEUR(J)
    Endif
  Endif

  For CHAINE="xparam1","xparam1label","xparam2"
    Gosub SUPPRESS_PARAM
  Next CHAINE
  If IFSYRA=1
    Gosub ADD_MAIN
  Else
    Gosub ADD_MAIN
  Endif
Return

$TRANSCODE_STAT
  If IDCOD=0 : Return : Endif

# Syrapedia link
  VALEUR(IDTYP)="url"
  VALEUR(IDCOD)="{$baseUrl}/STATS('"+VALEUR(IDCOD)+"')?representation=STATS~"+VALEUR(IDCOD)+".$cube"
  Gosub ADD_MAIN
Return

$TRANSCODE_PAGE
  If IDCOD=0 : Return : Endif

# Syrapedia link
  VALEUR(IDTYP)="url"
  VALEUR(IDCOD)="{$baseUrl}/PROCESS('"+VALEUR(IDCOD)+"')?representation=PROCESS~"+VALEUR(IDCOD)+".$details"
  Gosub ADD_MAIN
Return

$TRANSCODE_CONSULT
  If IDCOD=0 : Return : Endif

# In a first step, find the function associated to the inquiry
  CHAINE=""
  For [ACT] Where TYP=2 and PARAM1=VALEUR(IDCOD)
    CHAINE=[ACT]ACTION : Break
  Next
  If CHAINE="" : Return : Endif
  CHAINE1=""
  For [AFC] Where ACTION=CHAINE
    CHAINE1=[AFC]CODINT : Break
  Next
  If CHAINE1="" : Return : Endif

# Now set up the convergence link
  VALEUR(IDTYP)="url"

# Fix for classic pages links: a dedicated variable is necessary Dom Sept 18, 2014
  VALEUR(IDCOD)="{$baseTrans}/$sessions?f="+CHAINE1
  If IDPA1>0 and VALEUR(IDPA1)<>""
    VALEUR(IDCOD)+="~"+VALEUR(IDPA1)
  Endif
  VALEUR(IDCOD)+="/2/" : # return to the menu

  # Manage xlabel and suppress the unused parameter for the URL
  I=find("xlabel",PARAM(1..NBPAR))
  If I
    J=find("xparam1label",PARAM(1..NBPAR))
    If J and VALEUR(J)<>""
      VALEUR(I)-="/"-VALEUR(J)
    Endif
    J=find("xparam2",PARAM(1..NBPAR))
    If J and VALEUR(J)<>""
      VALEUR(I)-="/"-VALEUR(J)
    Endif
  Endif

  For CHAINE="xparam1","xparam1label","xparam2"
    Gosub SUPPRESS_PARAM
  Next CHAINE
  Gosub ADD_MAIN

Return

# BO execution by convergence link
$TRANSCODE_REPORTBO
  If IDCOD=0 : Return : Endif

  VALEUR(IDTYP)="url"
  CHAINE=VALEUR(IDCOD)

# Fix for classic pages links: a dedicated variable is necessary Dom Sept 18, 2014
# VALEUR(IDCOD)="{$baseTrans}/$sessions?f=ABIIMP"+string$(CHAINE<>"","~"+CHAINE)
# VALEUR(IDCOD)+="/2/" : # return to the menu
  VALEUR(IDCOD)="{$baseTrans}/$sessions?f=ABIIMP"
  VALEUR(IDCOD)+="/2//M//params~ETAT~"+CHAINE: # return to the menu
  Gosub ADD_MAIN
Return


$TRANSCODE_X3HELP
  If IDCOD=0 : Return : Endif

  I=find("xhelptype",PARAM(1..NBPAR))
  If I=0 : Return : Endif

  CHAINE=VALEUR(IDCOD)
  If VALEUR(I) ="xhfunc"
    VALEUR(IDCOD)="{$funcHelpUrl}/"+CHAINE+".htm"
  Elsif VALEUR(I) ="xhfield"
    VALEUR(IDCOD)="{$fieldHelpUrl}/"+CHAINE+".htm"
  Else
    Return
  Endif

  VALEUR(IDTYP)="url"

  # Suppress the unused parameter for the URL
  For CHAINE="xhelptype"
    Gosub SUPPRESS_PARAM
  Next CHAINE
  Gosub ADD_MAIN

Return

$TRANSCODE_DEFAULT
Return

# Suppress a parameter from the list
$SUPPRESS_PARAM
 I=find(CHAINE,PARAM(1..NBPAR))
 If I
  For J=I To NBPAR-1
    PARAM(J)=PARAM(J+1)
    VALEUR(J)=VALEUR(J+1)
    TYPVAL(J)=TYPVAL(J+1)
  Next J
  NBPAR-=1
 Endif
Return

# Add the _self xtarget parameter value
# No more used
$ADD_SELF
  I=find("xtarget",PARAM(1..NBPAR))
  If I=0 : NBPAR+=1 : I=NBPAR : Endif
  PARAM(I)="xtarget"
  VALEUR(I)="_self"
  TYPVAL(I)=2
Return

# Add the blank xtarget parameter value
# No more used
$ADD_BLANK
  I=find("xtarget",PARAM(1..NBPAR))
  If I=0 : NBPAR+=1 : I=NBPAR : Endif
  PARAM(I)="xtarget"
  VALEUR(I)="blank"
  TYPVAL(I)=2
Return

# Add the main xtarget parameter value
$ADD_MAIN
  I=find("xtarget",PARAM(1..NBPAR))
  If I=0 : NBPAR+=1 : I=NBPAR : Endif
  PARAM(I)="xtarget"
  VALEUR(I)="main"
# VALEUR(I)="blank" : # To be suppressed when Daniel will be ready
  TYPVAL(I)=2
Return

# Dump the parameter (for debug reasons only)
$LISTEPAR
  Call ECR_TRACE("  Initial parameter values",0) From GESECRAN
  For I=1 To NBPAR
    Call ECR_TRACE("  "+num$(I)-'"'+PARAM(I)+'" '+string$(TYPVAL(I)=2,'"')+VALEUR(I)+string$(TYPVAL(I)=2,'"'),0) From GESECRAN
  Next I
  Call ECR_TRACE("  ------------------------",0) From GESECRAN
Return

Funprog ESCAPE(A)
Value Clbfile A()
Local Char BUFFER(250)
BUFFER=""
Local Integer I,J
For I=1 To len(A)
  J=ascii(mid$(A,I,1))
  If J<32 or J>=127 or J=92
    BUFFER+="{{"+format$("N0:3",J)+"}}"
  Else
    BUFFER+=mid$(A,I,1)
  Endif
Next I
End BUFFER

