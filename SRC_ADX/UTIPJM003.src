#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIPJM003
# Issue X3-4848/119127 - 2016-10-14 by FGR
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM003(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM003(SZAPPLI)
Value Char SZAPPLI

Local Integer IERR
Local Integer IUPDATE
Local Integer NI
Local Integer NE
Local Integer NCOUNTOK
Local Integer NCOUNTERROR
Local Char WOBJET(GLONAOB)
Local Char WCHAINE(250)
Local Char STBDIE(250)(0..)
Local Char STBCCE(250)(0..)
Local Integer STBCHX(0..)

Local Integer I_DIE
Local Integer I_FCY
Local Char    L_CPY(GLONCPY)
Local Integer RNBRDIE
Local Char    RDIE(GLONDIE)(1..max(1,GOPTCANA))
Local Char    RDIEFMT(15)(1..max(1,GOPTCANA))
Local Char    RDIECOLHEA(15)(1..max(1,GOPTCANA))
Local Integer RDIEOBYFLG(1..max(1,GOPTCANA))
Local Char    RERRMES(250)
Local Integer BFND # Issue X3-7591/120520 - 2016-12-20 by FGR

  IERR = 0
  Call ECR_TRACE("UTIPJM003: Process Start on : "+SZAPPLI, 0) From GESECRAN
  # Traitement table PJMTIMEMP
  #
  If filinfo(filpath("FIL", "PJMCOSTCTR", "fde", SZAPPLI), 0) <= 0 Then
    End
  Endif
  Local File =SZAPPLI + ".PJMCOSTCTR" [PJCC]
  Local File =SZAPPLI + ".GDIE" [DIE]
  Local File =SZAPPLI + ".GLED" [LED]  # Issue X3-7591/120520 - 2016-12-20 by FGR
  Local File =SZAPPLI + ".FACILITY" [FCY]
  Local File =SZAPPLI + ".COMPANY" [CPY]
  # -------------------------
  If dim([F:PJCC]CHX) > 0 Then
    Trbegin [PJCC]
    NCOUNT = 0
    NCOUNTERROR = 0
    Call ECR_TRACE("UTIPJM003: Updating PJMCOSTCTR", 0) From GESECRAN
    Filter [PJCC] #Where [F:PJCC]PCCCOD = "202"
    For [PJCC]
      NCOUNT += 1
      # -----------------------------
      NE = 0
      Raz STBDIE
      Raz STBCCE
      Raz STBCHX
      For NI = 0 To dim([F:PJCC]CHX)-1
        If [F:PJCC]DIE(NI) <> "" Then
          Call LEC_DIE([F:PJCC]DIE(NI)) From CPTLEC
          # -----------------------------
          # Issue X3-7591/120520 - 2016-12-20 by FGR : BEGIN
          BFND = [V]CST_AFALSE
          Filter [LED] Where PJMFLG = [V]CST_AYES and find([F:DIE]DIE, [F:LED]DIE(0..dim([F:LED]DIE)-1))
          For [LED]
            BFND = [V]CST_ATRUE
            Break
          Next
          Filter [LED]
          # Issue X3-7591/120520 - 2016-12-20 by FGR : END
          # -----------------------------
          #If [F:DIE]PCCFLG = [V]CST_AYES Then                            # Issue X3-7591/120520 - 2016-12-20 by FGR
          If BFND = [V]CST_ATRUE and [F:DIE]PCCFLG = [V]CST_AYES Then     # Issue X3-7591/120520 - 2016-12-20 by FGR
            If [F:PJCC]CHX(NI) <> 1 and [F:PJCC]CHX(NI) <> 2 Then
              [F:PJCC]CHX(NI) = 1
            Endif
            If [F:PJCC]CHX(NI) = 2 and [F:PJCC]CCE(NI) = "" Then
              [F:PJCC]CHX(NI) = 1
            Endif
            If [F:PJCC]CHX(NI) <> 2 and [F:PJCC]CCE(NI) <> "" Then
              [F:PJCC]CHX(NI) = 2
            Endif
            # -----------------------------
            STBDIE(NE) = [F:PJCC]DIE(NI)
            STBCCE(NE) = [F:PJCC]CCE(NI)
            STBCHX(NE) = [F:PJCC]CHX(NI)
            NE += 1
            # -----------------------------
          Else
            Raz [F:PJCC]DIE(NI)
            Raz [F:PJCC]CCE(NI)
          Endif
        Endif
      Next NI
      # -----------------------------
      If NE = 0 Then
        If [F:PJCC]PCCFCY <> "" Then
          Read [FCY]FCY0=[F:PJCC]PCCFCY
          L_CPY = [F:FCY]LEGCPY
          # ---------------------------------------
          #IRET = func FINACM_SYRA.GET_ANASTC(GACTX, L_CPY, 2, RNBRDIE, RDIE, RDIEFMT, RDIECOLHEA, RDIEOBYFLG, RERRMES)
          #If IRET < [V]CST_AERROR Then
          #  # Récupération des axes de la société
          #  For I_DIE = 1 To RNBRDIE
          #    Call LEC_DIE(RDIE(I_DIE)) From CPTLEC
          #    If [F:DIE]PCCFLG = 2 Then
          #      STBDIE(NE) = RDIE(I_DIE)
          #      STBCCE(NE) = ""
          #      STBCHX(NE) = 1
          #      NE += 1
          #    Endif
          #    # ---------------------------------------
          #  Next I_DIE
          #Endif
          #If IRET > [V]CST_AOK Then
          #  #Call ECR_TRACE("File PJMCOSTCTR" - [F:PJCC]PCCCOD - [F:PJCC]DIE(NI) + ", Error =" - RERRMES, 1) From GESECRAN # Issue X3-8324/120099 - 2016-11-30 by FGR
          #  Call ECR_TRACE("File PJMCOSTCTR" - [F:PJCC]PCCCOD + ", Error =" - RERRMES, 1) From GESECRAN                    # Issue X3-8324/120099 - 2016-11-30 by FGR
          #Endif
          Read [CPY]CPY0=L_CPY
          For I_DIE = 0 To dim([F:CPY]DIE)-1
            If [F:CPY]DIE(I_DIE) <> "" Then
              Call LEC_DIE([F:CPY]DIE(I_DIE)) From CPTLEC
              # -----------------------------
              # Issue X3-7591/120520 - 2016-12-20 by FGR : BEGIN
              BFND = [V]CST_AFALSE
              Filter [LED] Where PJMFLG = [V]CST_AYES and find([F:DIE]DIE, [F:LED]DIE(0..dim([F:LED]DIE)-1))
              For [LED]
                BFND = [V]CST_ATRUE
                Break
              Next
              Filter [LED]
              # Issue X3-7591/120520 - 2016-12-20 by FGR : END
              # -----------------------------
              #If [F:DIE]PCCFLG = 2 Then                             # Issue X3-7591/120520 - 2016-12-20 by FGR
              If BFND = [V]CST_ATRUE and [F:DIE]PCCFLG = 2 Then      # Issue X3-7591/120520 - 2016-12-20 by FGR
                STBDIE(NE) = RDIE(I_DIE)
                STBCCE(NE) = ""
                STBCHX(NE) = 1
                NE += 1
              Endif
            Endif
          Next I_DIE
          # ---------------------------------------
        Else
          Raz STBDIE
          Raz STBCCE
          Raz STBCHX
          Filter [DIE] Where PCCFLG = 2
          For [DIE]
            # -----------------------------
            # Issue X3-7591/120520 - 2016-12-20 by FGR : BEGIN
            BFND = [V]CST_AFALSE
            Filter [LED] Where PJMFLG = [V]CST_AYES and find([F:DIE]DIE, [F:LED]DIE(0..dim([F:LED]DIE)-1))
            For [LED]
              BFND = [V]CST_ATRUE
              Break
            Next
            Filter [LED]
            # Issue X3-7591/120520 - 2016-12-20 by FGR : END
            # -----------------------------
            If BFND = [V]CST_ATRUE Then     # Issue X3-7591/120520 - 2016-12-20 by FGR
              If NE < dim([F:PJCC]CHX) Then
                STBDIE(NE) = [F:DIE]DIE
                STBCCE(NE) = ""
                STBCHX(NE) = 1
                NE += 1
              Endif
            Endif
            # ---------------------------------------
          Next
          Filter [DIE]
        Endif
      Endif
      # -----------------------------
      Raz [F:PJCC]DIE
      Raz [F:PJCC]CCE
      Raz [F:PJCC]CHX
      For NI = 0 To NE-1
        [F:PJCC]DIE(NI) = STBDIE(NI)
        [F:PJCC]CCE(NI) = STBCCE(NI)
        [F:PJCC]CHX(NI) = STBCHX(NI)
      Next NI
      # -----------------------------
      Rewrite [PJCC]
      If fstat Then
        #Call ECR_TRACE("File PJMCOSTCTR" - [F:PJCC]PCCCOD - [F:PJCC]DIE(NI) + ", Error =" - num$(fstat), 1) From GESECRAN # Issue X3-8324/120099 - 2016-11-30 by FGR
        Call ECR_TRACE("File PJMCOSTCTR" - [F:PJCC]PCCCOD + ", Error =" - num$(fstat), 1) From GESECRAN                    # Issue X3-8324/120099 - 2016-11-30 by FGR
        GOK = 1
        IERR = 1
        NCOUNTERROR += 1
      Endif
      # -----------------------------
    Next
    Filter [PJCC]
    # -------------------------
    If NCOUNTERROR = 0 Then
      Call ECR_TRACE("UTIPJM003: PJMCOSTCTR" - num$(NCOUNT) - "updated.", 0) From GESECRAN
    Else
      Call ECR_TRACE("UTIPJM003: PJMCOSTCTR" - num$(NCOUNT) - "updated." - num$(NCOUNTERROR) - "error(s)", 1) From GESECRAN
    Endif
    # -----------
    If IERR = 0 Then
      Commit
      Call ECR_TRACE("UTIPJM003 : records processed without error.", 0) From GESECRAN
    Else
      Rollback
      Call ECR_TRACE("UTIPJM003 : records processed with error(s).", 0) From GESECRAN
    Endif
  Endif
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------------
  # Issue X3-8278/120038 - 2016-11-30 by FGR : BEGIN
  If filinfo(filpath("FIL","PJMCOSTCTR","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMCOSTCTR") : End : Endif
  # Issue X3-8278/120038 - 2016-11-30 by FGR : END
  # -------------------------------
  Call MAJ_UTIPJM003(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then        # Issue X3-47712 - 2017-07-06 by FGR
    End
  Endif
  # -------------------------------
  # Issue X3-8278/120038 - 2016-11-30 by FGR : BEGIN
  If filinfo(filpath("FIL","PJMCOSTCTR","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMCOSTCTR") : End : Endif
  # Issue X3-8278/120038 - 2016-11-30 by FGR : END
  # -------------------------------
  Call MAJ_UTIPJM003(APPLI)
End

