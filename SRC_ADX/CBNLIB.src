#<AdxTL>@(#)1.0.0.0 $Revision$
############################################################
# Routines diverse de traitement calcul besoins
# Subprog LOA_LOCAL
# Subprog DIS_PARAM
# Subprog CORBUC(LCOR,LDAT,LJOU,LDAY,LWEE,LMON,LFIN)
# Subprog CALDAT(LSIG,LCOR,LDAT,LCOD,LDUR,LCAP,LDATD,LRES)
# Subprog DELSUG
# Subprog QTESUG(LBES,LSUG,LNBR,LSUGR,LRET)
# Subprog CORDEL(LDEL,LQTE,LCOE,LLOT)
# Subprog FORTXT(LTXT,LLON,LCHA)
# Subprog DATMOIS(LDAT,LDATD,LDATF,LWEED,LWEEF,LYEA,LMON,LWEE)
############################################################
# Chargement zones de travail selon MRP ou MPS (appel & définition des variables dans FUNCBN)
$LOA_LOCAL
Call PARAM(WFCY,"FIRWRKDAY",WPAR) From ADOVAL
If val(WPAR) < 1 | val(WPAR) > 7
  WSEM = 1
Else
  WSEM = val(WPAR)
Endif
Case WPRO
  When 1 :
    [M:PCB1]     = [F:PCB]
    [M:PCB3]     = [F:PCB]
    WTWD         = [F:PCB]MPSTWD
    WALTTYP      = [F:PCB]MPSALTTYP   : # GA 08/2007 pour la V6
    WBOMALT      = [F:PCB]MPSBOMALT
    WCAPFCT      = [F:PCB]MPSCAPFCT
    WANYLTI      = [F:PCB]MPSANYLTI
    WCAPLTI      = [F:PCB]MPSCAPLTI
    WDAYNBR      = [F:PCB]MPSDAYNBR
    WWEENBR      = [F:PCB]MPSWEENBR
    WMONNBR      = [F:PCB]MPSMONNBR
    WBUCCOR      = [F:PCB]MPSBUCCOR
    WPHYSTO      = [F:PCB]MPSPHYSTO
    WCTLSTO      = [F:PCB]MPSCTLSTO
    WREJSTO      = [F:PCB]MPSREJSTO
    WTRFSTO      = [F:PCB]MPSTRFSTO
    WSOSFLG      = [F:PCB]MPSSOSFLG
    WSOPFLG      = [F:PCB]MPSSOPFLG
    WSOFFLG      = [F:PCB]MPSSOFFLG
    WTPSFLG      = [F:PCB]MPSTPSFLG
    WTPPFLG      = [F:PCB]MPSTPPFLG
    WTPFFLG      = [F:PCB]MPSTPFFLG
    WTRPFLG      = [F:PCB]MPSTRPFLG
    WTRFFLG      = [F:PCB]MPSTRFFLG
    WWOPFLG      = [F:PCB]MPSWOPFLG
    WWOFFLG      = [F:PCB]MPSWOFFLG
    WPOPFLG      = [F:PCB]MPSPOPFLG
    WPOFFLG      = [F:PCB]MPSPOFFLG
    WEOPFLG      = [F:PCB]MPSEOPFLG
    WEOFFLG      = [F:PCB]MPSEOFFLG
    WMTPFLG      = [F:PCB]MPSMTPFLG # Issue 107498/102 - 2016-04-19 by ALSHE : MTP demand
    WMTFFLG      = [F:PCB]MPSMTFFLG # Issue number 107498/9 - 2016-03-03 by LLC
    WWOSFCY      = [F:PCB]MPSWOSFCY
    WWOSFCYI     = [F:PCB]MPSWOSFCYI
    WPOSFCY      = [F:PCB]MPSPOSFCY
    WEOSFCY      = [F:PCB]MPSEOSFCY
    WHORDEM      = [F:PCB]MPSHORDEM
    #--------
    # chargement règles replanification
    For I = 0 To 7
        WRPLTYP(I)     = [F:PCB]RPLTYPS(I)
        WRPLMOD(I)     = [F:PCB]RPLMODS(I)
        WRPLBWDLTI(I)  = [F:PCB]RPLBWDLTIS(I)
        WRPLFRWLTI(I)  = [F:PCB]RPLFRWLTIS(I)
        WRPLUPDQTY(I)  = [F:PCB]RPLUPDQTYS(I)
        WRPLUPDDAT(I)  = [F:PCB]RPLUPDDATS(I)
        If WRPLTYP(I) = 0 : WRPLTYP(I) = I + 1 : Endif
        If WRPLMOD(I) = 0 : WRPLTYP(I) = 1     : Endif
    Next I
    WWIPPRO      = [F:PCB]WIPPROS
    WRESBLWLOT   = [F:PCB]RESBLWLOTS
    WREOPOLDIS   = [F:PCB]REOPOLDISS
    WSAFCOV      = [F:PCB]MPSSAFCOV                # (02.04)
    #--------
    WMAXANY      = [F:PCB]MPSMAXANY
    WPRNFLG      = [F:PCB]MPSPRNFLG
    WITM         = [F:PCB]MPSITM
    WFABLTI      = [F:PCB]MPSMFGLTI
    WGHOSTO      = [F:PCB]MPSGHOSTO
    WSAFSTO      = [F:PCB]MPSSAFSTO
    WCOVFLG      = [F:PCB]MPSCOV
    WWAISTO      = [F:PCB]MPSWAISTO
    WITMCOD      = [F:PCB]MPSITMCOD
    WSPEPAR      = [F:PCB]MPSSPEPAR
    WSHRFLG      = [F:PCB]MPSSHRPRC
    WPLHDAT      = [F:PCB]MPSPLHDAT
    WCOVRES      = [F:PCB]MPSCOVRES
  # V6 Maj selon V5 GA 05/2009
    Call PARAM(WFCY,"MPSPJTSOF",WPAR) From ADOVAL
    WPJTSOF      = val(WPAR)
    Call PARAM(WFCY,"MPSPJTSOP",WPAR) From ADOVAL
    WPJTSOP      = val(WPAR)
    Call PARAM(WFCY,"MPSPJTSOS",WPAR) From ADOVAL
    WPJTSOS      = val(WPAR)
  # Fin - V6 Maj selon V5 GA 05/2009
    Call PARAM(WFCY,"MPSDYNCOV",WPAR) From ADOVAL
    WDYNCOV      = val(WPAR)
    Call PARAM(WFCY,"MPSDYNSAF",WPAR) From ADOVAL
    WDYNSAF      = val(WPAR)
   # Issue 94363 GA 02/2014 Couverture du stock de sécurité ?
    Call PARAM(WFCY,"MPSSECCOV",WPAR) From ADOVAL
    WSECCOV      = val(WPAR)
   # Issue 102933 GA 01/2015 # Tenir compte qté allouée
    Call PARAM(WFCY,"MAXALLQTY",WPAR) From ADOVAL
    WMAXALLQTY   = val(WPAR):
    # Issue 108013 - 2015-06-19 by GA : ECC for MRP
    WECCFLG      = func AFNC.ACTIV("ECC")    # Is ECC activated ?
    WECCNBR      = func AFNC.ACTIV("ECCMX")  # Max version nr for a product
    # Issue 48236 GH 05/06/2018 - Deletion useless parameters MPSECCSO*
#    Call PARAM(WFCY,"MPSECCSOF",WPAR) From ADOVAL
#    WECCSOF      = val(WPAR)
#    Call PARAM(WFCY,"MPSECCSOP",WPAR) From ADOVAL
#    WECCSOP      = val(WPAR)
#    Call PARAM(WFCY,"MPSECCSOS",WPAR) From ADOVAL
#    WECCSOS      = val(WPAR)

    # Issue 122220 - 2017-05-25 by STLIG : Switch (parameter) coverage mode:
    #                                      Reduce stock (Yes=2), maintain stock (No<2)..
    Call PARAM(WFCY,"MPSRECOVST",WPAR) From ADOVAL
    WRECOVST = val(WPAR)

  When 2 :
    [M:PCB2]     = [F:PCB]
    [M:PCB4]     = [F:PCB]
    WTWD         = [F:PCB]MRPTWD            # (llc 08.00 v130)
    WALTTYP      = [F:PCB]MRPALTTYP   : # GA 08/2007 pour la V6
    WBOMALT      = [F:PCB]MRPBOMALT
    WCAPFCT      = [F:PCB]MRPCAPFCT
    WANYLTI      = [F:PCB]MRPANYLTI
    WCAPLTI      = [F:PCB]MRPCAPLTI
    WDAYNBR      = [F:PCB]MRPDAYNBR
    WWEENBR      = [F:PCB]MRPWEENBR
    WMONNBR      = [F:PCB]MRPMONNBR
    WBUCCOR      = [F:PCB]MRPBUCCOR
    WPHYSTO      = [F:PCB]MRPPHYSTO
    WCTLSTO      = [F:PCB]MRPCTLSTO
    WREJSTO      = [F:PCB]MRPREJSTO
    WTRFSTO      = [F:PCB]MRPTRFSTO
    WSOSFLG      = [F:PCB]MRPSOSFLG
    WSOPFLG      = [F:PCB]MRPSOPFLG
    WSOFFLG      = [F:PCB]MRPSOFFLG
    WTPSFLG      = [F:PCB]MRPTPSFLG
    WTPPFLG      = [F:PCB]MRPTPPFLG
    WTPFFLG      = [F:PCB]MRPTPFFLG
    WTRPFLG      = [F:PCB]MRPTRPFLG
    WTRFFLG      = [F:PCB]MRPTRFFLG
    WWOPFLG      = [F:PCB]MRPWOPFLG
    WWOFFLG      = [F:PCB]MRPWOFFLG
    WPOPFLG      = [F:PCB]MRPPOPFLG
    WPOFFLG      = [F:PCB]MRPPOFFLG
    WEOPFLG      = [F:PCB]MRPEOPFLG
    WEOFFLG      = [F:PCB]MRPEOFFLG
    WMTPFLG      = [F:PCB]MRPMTPFLG # Issue 107498/102 - 2016-04-19 by ALSHE : MTP demand
    WMTFFLG      = [F:PCB]MRPMTFFLG # Issue number 107498/9 - 2016-03-03 by LLC
    WWOSFCY      = [F:PCB]MRPWOSFCY
    WWOSFCYI     = [F:PCB]MRPWOSFCYI
    WPOSFCY      = [F:PCB]MRPPOSFCY
    WEOSFCY      = [F:PCB]MRPEOSFCY
    WHORDEM      = [F:PCB]MRPHORDEM
    #--------
    # chargement règles replanification
    For I = 0 To 7
        WRPLTYP(I)     = [F:PCB]RPLTYP(I)
        WRPLMOD(I)     = [F:PCB]RPLMOD(I)
        WRPLBWDLTI(I)  = [F:PCB]RPLBWDLTI(I)
        WRPLFRWLTI(I)  = [F:PCB]RPLFRWLTI(I)
        WRPLUPDQTY(I)  = [F:PCB]RPLUPDQTY(I)
        WRPLUPDDAT(I)  = [F:PCB]RPLUPDDAT(I)
        If WRPLTYP(I) = 0 : WRPLTYP(I) = I + 1 : Endif
        If WRPLMOD(I) = 0 : WRPLTYP(I) = 1     : Endif
    Next I
    WWIPPRO      = [F:PCB]WIPPRO
    WRESBLWLOT   = [F:PCB]RESBLWLOT
    WREOPOLDIS   = [F:PCB]REOPOLDIS
    WSAFCOV      = [F:PCB]MRPSAFCOV                    # (02.04)
    #--------
    WMAXANY      = [F:PCB]MRPMAXANY
    WPRNFLG      = [F:PCB]MRPPRNFLG
    WITM         = [F:PCB]MRPITM
    WFABLTI      = [F:PCB]MRPMFGLTI
    WGHOSTO      = [F:PCB]MRPGHOSTO
    WSAFSTO      = [F:PCB]MRPSAFSTO
    WCOVFLG      = [F:PCB]MRPCOV
    WWAISTO      = [F:PCB]MRPWAISTO
    WITMCOD      = [F:PCB]MRPITMCOD
    WSPEPAR      = [F:PCB]MRPSPEPAR
    WSHRFLG      = [F:PCB]MRPSHRPRC
    WPLHDAT      = [F:PCB]MRPPLHDAT
    WCOVRES      = [F:PCB]MRPCOVRES
  # Issue 78714 V6 Maj selon V5 GA 10/2012
    Call PARAM(WFCY,"MRPPJTSOF",WPAR) From ADOVAL
    WPJTSOF      = val(WPAR)
    Call PARAM(WFCY,"MRPPJTSOP",WPAR) From ADOVAL
    WPJTSOP      = val(WPAR)
    Call PARAM(WFCY,"MRPPJTSOS",WPAR) From ADOVAL
    WPJTSOS      = val(WPAR)
  # Fin - V6 Maj selon V5 GA 05/2009
    Call PARAM(WFCY,"MRPDYNCOV",WPAR) From ADOVAL
    WDYNCOV      = val(WPAR)
    Call PARAM(WFCY,"MRPDYNSAF",WPAR) From ADOVAL
    WDYNSAF      = val(WPAR)
   # Issue 94363 GA 02/2014 Couverture du stock de sécurité ?
    Call PARAM(WFCY,"MRPSECCOV",WPAR) From ADOVAL
    WSECCOV      = val(WPAR)
   # Issue 102933 GA 01/2015 # Tenir compte qté allouée
    Call PARAM(WFCY,"MAXALLQTY",WPAR) From ADOVAL
    WMAXALLQTY   = val(WPAR):
    # Issue 108013 - 2015-06-19 by GA : ECC for MRP
    WECCFLG      = func AFNC.ACTIV("ECC")    # Is ECC activated ?
    WECCNBR      = func AFNC.ACTIV("ECCMX")  # Max version nr for a product
    # Issue 48236 GH 05/06/2018 - Deletion useless parameters MRPECCSO*
#    Call PARAM(WFCY,"MRPECCSOF",WPAR) From ADOVAL
#    WECCSOF      = val(WPAR)
#    Call PARAM(WFCY,"MRPECCSOP",WPAR) From ADOVAL
#    WECCSOP      = val(WPAR)
#    Call PARAM(WFCY,"MRPECCSOS",WPAR) From ADOVAL
#    WECCSOS      = val(WPAR)

    # Issue 122220 - 2017-05-25 by STLIG : Switch (parameter) coverage mode:
    #                                      Reduce stock (Yes=2), maintain stock (No<2)..
    Call PARAM(WFCY,"MRPRECOVST",WPAR) From ADOVAL
    WRECOVST = val(WPAR)

Endcase
Return
############################################################
#Affichage paramètres principaux dans fichier trace
$DIS_PARAM
Local Char    WPRE(3)
Case WPRO
  When 1 : WPRE = "MPS"
           [M:PCB1]MPSDAYNBR = WDAYNBR
           [M:PCB1]MPSWEENBR = WWEENBR
           [M:PCB1]MPSMONNBR = WMONNBR
           Call PRTSCR("PCB1","","",0,1) From ATRTX3
           Call ECR_TRACE(" ",0) From GESECRAN
           Call PRTSCR("PCB3","","",0,1) From ATRTX3
  When 2 : WPRE = "MRP"
           [M:PCB2]MRPDAYNBR = WDAYNBR
           [M:PCB2]MRPWEENBR = WWEENBR
           [M:PCB2]MRPMONNBR = WMONNBR
           Call PRTSCR("PCB2","","",0,1) From ATRTX3
           Call ECR_TRACE(" ",0) From GESECRAN
           Call PRTSCR("PCB4","","",0,1) From ATRTX3
Endcase
Call ECR_TRACE(" ",0) From GESECRAN
#
If WDAYNBR <> 0
  Call TEXTFIC("PARMRP",WPRE+"DAYNBR",2,WINT0) From OBJDIV
  Call FORTXT(WINT0,30,".")
  I = 0
  J = WDAYNBR-1
  WMSG = WINT0+" : "+num$(WDAYNBR)+"  ("+format$("D:",WBUCDEB(I))+" - "+
&        format$("D:",WBUCFIN(J))+")"
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
#
If WWEENBR <> 0
  Call TEXTFIC("PARMRP",WPRE+"WEENBR",2,WINT0) From OBJDIV
  Call FORTXT(WINT0,30,".")
  I =  WDAYNBR
  J = (WDAYNBR+WWEENBR)-1
  WMSG = WINT0+" : "+num$(WWEENBR)+"  ("+format$("D:",WBUCDEB(I))+" - "+
&        format$("D:",WBUCFIN(J))+")"
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
#
If WMONNBR <> 0
  Call TEXTFIC("PARMRP",WPRE+"MONNBR",2,WINT0) From OBJDIV
  Call FORTXT(WINT0,30,".")
  I =  WDAYNBR+ WWEENBR
  J = (WDAYNBR+WWEENBR+WMONNBR)-1
  WMSG = WINT0+" : "+num$(WMONNBR)+"  ("+format$("D:",WBUCDEB(I))+" - "+
&        format$("D:",WBUCFIN(J))+")"
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
#
Call ECR_TRACE(" ",0) From GESECRAN
#
Call TEXTPAR("FIRWRKDAY",WINT0) From TRTX3
Call FORTXT(WINT0,30,".")
WMSG = WINT0+" : "+mess(WSEM,742,1)+" ("+mess(81,123,1)-"FIRWRKDAY"+")"
Call ECR_TRACE(WMSG,0) From GESECRAN
#
Call TEXTPAR(WPRE+"DYNCOV",WINT0) From TRTX3
Call FORTXT(WINT0,30,".")
WMSG = WINT0+" : "+mess(WDYNCOV,1,1)+" ("+mess(81,123,1)-WPRE+"DYNCOV"+")"
Call ECR_TRACE(WMSG,0) From GESECRAN
#
Call TEXTPAR(WPRE+"DYNSAF",WINT0) From TRTX3
Call FORTXT(WINT0,30,".")
WMSG = WINT0+" : "+mess(WDYNSAF,1,1)+" ("+mess(81,123,1)-WPRE+"DYNSAF"+")"
Call ECR_TRACE(WMSG,0) From GESECRAN
#
# Issue 94363 GA 02/2014 Couverture du stock de sécurité ?
Call TEXTPAR(WPRE+"SECCOV",WINT0) From TRTX3
Call FORTXT(WINT0,30,".")
WMSG = WINT0+" : "+mess(WSECCOV,1,1)+" ("+mess(81,123,1)-WPRE+"SECCOV"+")"
Call ECR_TRACE(WMSG,0) From GESECRAN
#
If GMODU(8) = 2
  Call TEXTPAR("GPERCOMP",WINT0) From TRTX3
  Call FORTXT(WINT0,30,".")
  WMSG = WINT0+" : "+num$(GPERCOMP)+"   ("+mess(81,123,1)-"GPERCOMP"+")"
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif

# Issue 122220 - 2017-05-25 by STLIG : Switch (parameter) coverage mode:
#                                      Reduce stock (Yes=2), maintain stock (No<2)..
Call TEXTPAR(WPRE+"RECOVST",WINT0) From TRTX3
Call FORTXT(WINT0,30,".")
WMSG = WINT0+" : "+mess(WRECOVST,1,1)+" ("+mess(81,123,1)-WPRE+"RECOVST"+")"
Call ECR_TRACE(WMSG,0) From GESECRAN

#
Return
############################################################
#Correction nombre de buckets (alignements début semaine / mois)
# LDAT = Date début traitement
# LJOU = Jour début semaine (1=lundi / 7= dimanche)
# LDAY = Nombre buckets en jours
# LWEE = Nombre buckets en semaines
# LMON = Nombre buckets en mois
# LFIN = Date fin traitement
Subprog CORBUC(LCOR,LDAT,LJOU,LDAY,LWEE,LMON,LFIN)
Variable Integer LCOR
Variable Date    LDAT
Variable Integer LJOU
Variable Integer LDAY
Variable Integer LWEE
Variable Integer LMON
Variable Date    LFIN
#
Local    Integer WSEMD, WSEMF, WSEM, WYEA, WMON
Local    Date    WDAT : WDAT = LDAT
Local    Date    WDATD
Local    Date    WDATF
Local    Integer WMON
Local    Integer WCASE
Local    Integer WJOU
If LJOU < 1 | LJOU > 7
  LJOU = 1
Endif
WCASE = 0
If LCOR = 2
  If LDAY <> 0 : WCASE += 1 : Endif
  If LWEE <> 0 : WCASE += 2 : Endif
  If LMON <> 0 : WCASE += 4 : Endif
Else
  LFIN  = LDAT + LDAY
  If LWEE <> 0
    WSEM = LWEE
    While WSEM <> 0
      LFIN += 1
      If dayn(LFIN) = LJOU
        WSEM -= 1
      Endif
    Wend
    LFIN -= 1
  Endif
  If LMON <> 0
    If LFIN = eomonth(LFIN)
      LFIN = addmonth(LFIN,LMON)
      LFIN = eomonth(LFIN)
    Else
      LFIN = addmonth(LFIN,LMON-1)
      LFIN = eomonth(LFIN)
    Endif
  Endif
  End
Endif
#
Case WCASE
  When 3 :
    WDAT = LDAT+LDAY
    While dayn(WDAT) <> LJOU
      LDAY += 1
      WDAT += 1
    Wend
  When 5:
    WDAT = LDAT + LDAY
    Call DATMOIS(WDAT,WDATD,WDATF,WSEMD,WSEMF,WYEA,WMON,WSEM)
    LDAY = WDATF - LDAT
  When 6 :
    WDAT = LDAT + (LWEE*7)
    Call DATMOIS(WDAT,WDATD,WDATF,WSEMD,WSEMF,WYEA,WMON,WSEM)
    WJOU = WDATF - LDAT
    If mod(WJOU,7) = 0
      LWEE = int(WJOU/7)
    Else
      LWEE = int(WJOU/7)+1
    Endif
  When 7 :
    WDAT = LDAT+LDAY
    While dayn(WDAT) <> LJOU
      LDAY += 1
      WDAT += 1
    Wend
    WDAT = LDAT + LDAY +(LWEE*7)
    Call DATMOIS(WDAT,WDATD,WDATF,WSEMD,WSEMF,WYEA,WMON,WSEM)
    WJOU = WDATF - (LDAT+LDAY)
    If mod(WJOU,7) = 0
      LWEE = int(WJOU/7)
    Else
      LWEE = int(WJOU/7)+1
    Endif
Endcase
#Calcul date fin traitement
WDAT = LDAT + LDAY + (LWEE*7)
If LMON <> 0
  WDAT = addmonth(WDAT,LMON)
  Call DATMOIS(WDAT,WDATD,WDATF,WSEMD,WSEMF,WYEA,WMON,WSEM)
  WDAT = WDATF+1
Endif
LFIN = WDAT-1
End
############################################################
#Calcul des numéros de bucket
# LDAT = Date début traitement
# LCAP = Tableau capacités calendrier
# LBUN = tableau des numéros de bucket
# LBUC = tableau des capcités buckets
# LBUD = Tableau dates début bucket
# LBUF = Tableau dates fin   buckets
# LTYP = Tableau des types de buckets                    # 11.05 33236
# LDAY = Nombre de buckets jours
# LWEE = Nombre de buckets semaines ( 7 jours)
# LMON = Nombre de buckets mois     (30 jours)
Subprog LOABUC(LDAT,LCAP,LBUN,LBUC,LBUD,LBUF,LTYP,LJOU,LDAY,LWEE,LMON)
Variable Date    LDAT
Variable Decimal LCAP()
Variable Integer LBUN()
Variable Integer LBUC()
Variable Date    LBUD()
Variable Date    LBUF()
Variable Integer LTYP()                                # 11.05 33236
Variable Integer LJOU
Variable Integer LDAY
Variable Integer LWEE
Variable Integer LMON
#
Local    Date    WDAT
Local    Integer WJOU, WDAY, WWEE ,WMON
Local    Integer I, J, K, L
#
Raz LBUN, LBUC, LBUD, LBUF
WDAT = LDAT
WJOU = LJOU
WDAY = LDAY
WWEE = LWEE
WMON = LMON
If WJOU < 1 | WJOU > 7
  WJOU = 1
Endif
#
J = 0
K = 0
While WDAY > 0
  LBUN(J)  = K
  LBUC(K) += LCAP(J)
  LBUD(K)  = WDAT
  LBUF(K)  = WDAT
  LTYP(K)  = 1                                        # 11.05 33236
  WDAT    += 1
  K       += 1
  J       += 1
  WDAY    -= 1
Wend
While WWEE > 0
  LBUD(K) = WDAT
  LBUN(J)  = K
  LBUC(K) += LCAP(J)
  WDAT    += 1
  J       += 1
  L = dayn(WDAT)
  While L <> WJOU
    LBUN(J)  = K
    LBUC(K) += LCAP(J)
    WDAT    += 1
    L = dayn(WDAT)
    J += 1
  Wend
  LBUF(K) = WDAT-1
  LTYP(K)  = 2                                        # 11.05 33236
  K    += 1
  WWEE -= 1
Wend
While WMON > 0
  LBUD(K) = WDAT
  For L = day(WDAT) To day(eomonth(WDAT))
    LBUN(J)  = K
    LBUC(K) += LCAP(J)
    WDAT    += 1
    J       += 1
  Next L
  LBUF(K) = WDAT-1
  LTYP(K)  = 3                                        # 11.05 33236
  K    += 1
  WMON -= 1
Wend
End
############################################################
# Calcul date début / fin
# LSIG  = "+" ou "-"
# LCOR  = Correction  0      = pas de correction
#                     1 à  7 = lundi à dimanche suivant
#                    -1 à -7 = lundi à dimanche précédent
#                     8      = correction calendrier
#                     9      = fin mois
#                    10      = fin mois suivant
#                    11      = fin mois précédent
#                    12      = début mois
#                    13      = début mois suivant
#                    14      = début mois précedent
# LDAT  = Date de référence
# LCOD  = Unité temps 1 jours calendaires
#                     2 jours ouvrés (avec correction calendrier)
#                     3 semaines
#                     4 quinzaines
#                     5 mois
# LDUR  = Durée selon LCOD
# LCAP  = Table calendier (pour correction jours ouvrés)
# LDATD = date début table calendrier
# LRES  = Date résultat
#!
Subprog CALDAT(LSIG,LCOR,LDAT,LCOD,LDUR,LCAP,LDATD,LRES)
Value    Char     LSIG()
Variable Integer  LCOR
Variable Date     LDAT
Variable Integer  LCOD
Variable Decimal  LDUR
Variable Decimal  LCAP()
Variable Date     LDATD
Variable Date     LRES
#
Local    Integer  ICAP, IERR
Local    Integer  WINC
Local    Decimal  WDEL
Local    Integer  WJOU
Local    Date     WDAT
#
LRES = LDAT
ICAP = LDAT - LDATD
IERR = 0
#Choix incrément de date
If LSIG = "+"
  WINC = 1
Else
  WINC = -1
Endif
WDEL = LDUR
Onerrgo CALDAT_ERR
Case LCOD
  When 1 :
    LRES = LDAT+(WDEL*WINC)
  When 2 :
    While WDEL > 0 & ICAP < dim(LCAP)-1 & ICAP >= 0
      If LCAP(ICAP) <> 0
        WDEL -= (LCAP(ICAP))
      Endif
      LRES += WINC
      ICAP += WINC
    Wend
  When 3 :
    LRES = LDAT+(WDEL*7*WINC)
  When 4 :
    LRES = LDAT+(WDEL*14*WINC)
  When 5 :
    LRES = addmonth(LDAT,(WDEL*WINC))
Endcase
Case LCOR
  When 1, 2, 3, 4, 5, 6, 7 :
    WJOU = LCOR
    While dayn(LRES) <> WJOU
      LRES += 1
    Wend
  When -1, -2, -3, -4, -5, -6, -7 :
    WJOU = 0-LCOR
    While dayn(LRES) <> WJOU
      LRES -= 1
    Wend
  When 8 :
    While ICAP < dim(LCAP)-1 & ICAP >= 0 & LCAP(ICAP) = 0
      LRES += WINC
      ICAP += WINC
    Wend
  When 9 :
    LRES = eomonth(LRES)
  When 10 :
    LRES = addmonth(LRES,1)
    LRES = eomonth(LRES)
  When 11 :
    LRES = addmonth(LRES,-1)
    LRES = eomonth(LRES)
  When 12 :
    LRES = gdat$(1,month(LRES),year(LRES))
  When 13 :
    LRES = gdat$(1,month(LRES),year(LRES))
    LRES = addmonth(LRES,1)
  When 14 :
    LRES = gdat$(1,month(LRES),year(LRES))
    LRES = addmonth(LRES,-1)
Endcase
Onerrgo
# Si erreur sur calcul de date
If IERR <> 0
  LRES = LDATD-1
Endif
End
$CALDAT_ERR
IERR = 1
Resume
############################################################
# Effacement WOS POS et leurs traces
# Effacement charge des WOS si module GPAO
# La classe [ORD] contient la suggestion à effacer
Subprog DELSUG
Local Integer WFSTAT
WFSTAT = fstat
If clalev([F:ORD1]) = 0 : Local File ORDERS   [ORD1] : Endif
# Effacement MWS et SCS
If ([F:ORD]WIPTYP = 2  & [F:ORD]WIPSTA = 3) |
&  ([F:ORD]WIPTYP = 5  & [F:ORD]WIPSTA = 3) |
&  ([F:ORD]WIPTYP = 13 & [F:ORD]WIPSTA = 3)
  Filter[ORD1] Where STOFCY  = [F:ORD]STOFCY   &
&                    VCRTYP  = 11              &
&                    VCRNUM  = [F:ORD]WIPNUM   &
&                    (WIPTYP = 3 | WIPTYP = 4 | WIPTYP = 6 | WIPTYP = 9) &
&                    WIPSTA  = 3
&              Order By Key ORD3
  For [ORD1]
    Readlock [ORD1] Curr
    Case fstat
      When 1 :
        GOK = -1
        Break
      When 0 :
        Delete [ORD1]
        If fstat
          GOK = 0
          Call FSTA("ORD1") From GLOCK
          Break
        Endif
      When Default :
        If fstat
          GOK = 0
          Call FSTA("ORD1") From GLOCK
          Break
        Endif
    Endcase
  Next
  Filter [ORD1]
Endif
# Effacement demandes transferts
If GOK = 1
  If ([F:ORD]WIPTYP = 7 & [F:ORD]WIPSTA = 3)
    Readlock [ORD1]ORD0=8;[F:ORD]WIPNUM;[F:ORD]ITMREF
    Case fstat
      When 1 :
        GOK = -1
      When 0 :
        Delete [ORD1]
        If fstat
          GOK = 0
          Call FSTA("ORD") From GLOCK
        Endif
      When 4,5 :
      When Default :
        GOK = 0
        Call FSTA("ORD") From GLOCK
    Endcase
  Endif
Endif
# Effacement WOS / POS / TRS / EOS
# Effacement charge WOS
If GOK = 1
  Delete [ORD]
  If fstat
    GOK = 0
    Call FSTA("ORD") From GLOCK
  Endif
  If [F:ORD]WIPTYP = 5 & GMODU(8) = 2
    Call PUR_LOA_SUG([F:ORD]STOFCY,[F:ORD]WIPNUM) From CBNLIBO    # llc 03.02 13344
  Endif
Endif
fstat = WFSTAT
End
############################################################
# Calcul quantités suggestions
# Buffer [CBH] en ligne (Données politique de réappro)
# Buffer [ITF] en ligne (Données de réappro)
# LBES  = Besoin en US
# LSUG  = Quantité de la suggestion
# LNBR  = Nombre de suggestions
# LSUGR = Quantité dernière suggestion (Si différente en quantité)
# LRET  = Code retour
# LTOS  = Total suggestions corrigé  perte
Subprog QTESUG(LBES,LSUG,LNBR,LSUGR,LRET,LTOS)
Variable Decimal  LBES
Variable Decimal  LSUG
Variable Integer  LNBR
Variable Decimal  LSUGR
Variable Integer  LRET
Variable Decimal  LTOS
#
Local    Decimal WBES
Local    Decimal WSUG
Local    Decimal WLOTT
Local    Decimal WLOTE
Local    Integer WNBR
#
Raz LSUG, LNBR, LSUGR, LRET
#Calcul besoin avec ou sans stock securité
WBES = LBES
WSUG = 0
WLOTT = [F:ITF]MFGLOTQTY
WLOTE = [F:ITF]REOMINQTY

#--- PE Spécifique FQ 42659 - GA 09/2007
GPOINT = "BEFQTESUG" : Gosub ENTREE From EXEFNC
#--- PE Spécifique

If WLOTE = 0
  WLOTE = WLOTT
Endif
If WLOTT = 0
  WLOTT = WLOTE
Endif
#Calcul quantité totale suggestion
Case [F:CBH]REOQTYCOD
  When 1 :
    WSUG = WBES
  When 2
    If WBES <= WLOTE
      WSUG = WLOTE
    Else
      WSUG = WBES
    Endif
  When 3 :
    If WBES <= WLOTE
      WSUG = WLOTE
    Else
      WSUG = WBES
    Endif
    If WLOTT <> 0 & mod(WSUG,WLOTT) <> 0
      WNBR = int(WSUG/WLOTT)+1
      WSUG = WNBR*WLOTT
    Endif
Endcase
#Calcul du fractionnement
If [F:CBH]SPLCOD = 1 | WLOTT = 0 | WSUG <= WLOTT
  LNBR = 1
  LSUG = WSUG
Else
  While WSUG >= WLOTT
    LNBR += 1
    LSUG  = WLOTT
    WSUG -= WLOTT
  Wend
  LSUGR = WSUG
Endif
LTOS = (LSUG*LNBR)+LSUGR
End
############################################################
# Correction du délai en fonction quantité
Subprog CORDEL(LDEL,LQTE,LCOE,LLOT)
Variable Decimal LDEL
Variable Decimal LQTE
Variable Decimal LCOE
Variable Decimal LLOT
#
Local Integer WDEL
Local Decimal WFIX
Local Decimal WVAR
If LQTE <> LLOT & LLOT <> 0
  WFIX = (((100-LCOE)/100)*LDEL)
  WVAR = (LCOE/100)*LDEL
  LDEL = WFIX+(WVAR*(LQTE/LLOT))
  LDEL = arr(LDEL,0.1)
Endif
End
############################################################
# Complementation d'une zone à droite par un caractère qcq
# LTXT = zone à complémenter
# LLON = Longueur zone
# LCHA = caractère
Subprog FORTXT(LTXT,LLON,LCHA)
Variable Char    LTXT
Value    Integer LLON
Value    Char    LCHA
Local    Char    WFOR(LLON) : WFOR = string$(LLON,LCHA)
Local    Char    WTXT(LLON)
Local    Integer WLON
WTXT = left$(LTXT,LLON)
WLON = LLON - len(WTXT)
LTXT = WTXT+left$(WFOR,WLON)
End
############################################################
Subprog DATMOIS(LDAT,LDATD,LDATF,LWEED,LWEEF,LYEA,LMON,LWEE)
Variable Date    LDAT
Variable Date    LDATD
Variable Date    LDATF
Variable Integer LWEED
Variable Integer LWEEF
Variable Integer LYEA
Variable Integer LMON
Variable Integer LWEE
#
Local    Date WDAT : WDAT = LDAT
$DATMOIS1
# Calcul dates et semaine début
LDATD = gdat$(1,month(WDAT),year(WDAT))
LDATF = eomonth(LDATD)
Case dayn(LDATD)
  When 2 : LDATD -= 1
  When 3 : LDATD -= 2
  When 4 : LDATD -= 3
  When 5 : LDATD += 3
  When 6 : LDATD += 2
  When 7 : LDATD += 1
Endcase
Case dayn(LDATF)
  When 1 : LDATF -= 1
  When 2 : LDATF -= 2
  When 3 : LDATF -= 3
  When 4 : LDATF += 3
  When 5 : LDATF += 2
  When 6 : LDATF += 1
Endcase
LWEED = week(LDATD)
LWEEF = week(LDATF)
If LWEEF = 0
  LWEEF= week(LDATF-7)
Endif
If LDAT < LDATD
  WDAT = addmonth(WDAT,-1)
  Goto DATMOIS1
Endif
If LDAT > LDATF
  WDAT = addmonth(WDAT,1)
  Goto DATMOIS1
Endif
# Calcul année et mois de la date de référence
LYEA = year(LDATD+7)
LMON = month(LDATD+7)
# Calcul numero semaine dans le mois (de 1 à 5)
LWEE = 1
WDAT = LDATD
While !(LDAT >= WDAT & LDAT <= WDAT+6)
  WDAT += 7
  LWEE += 1
Wend
End

########################################################################
Funprog MAPRPL( LTYP, LSTA )
Value    Integer LTYP
Value    Integer LSTA

Local Integer LMAP
Case LTYP
    When 2:    Case LSTA
                   When 1:    LMAP = 2
                   When 2:    LMAP = 3
               Endcase
    When 5:    Case LSTA
                   When 1:    LMAP = 0
                   When 2:    LMAP = 1
               Endcase
    When 7:    Case LSTA
                   When 1:    LMAP = 4
                   When 2:    LMAP = 5
               Endcase
    When 13:    Case LSTA
                   When 1:    LMAP = 6
                   When 2:    LMAP = 7
               Endcase
Endcase
End LMAP

########################################################################
# A partir du type d'encours, renvoit si il s'agit d'une ressource
Funprog ISRESS( LTYP)
Value    Integer LTYP
Local Integer LRESS

# GH 29/02/12 ajout de 4 par cohérence avec ISDEM
# Issue number 107498/9 - 2016-03-01 by LLC : new demand type 14 = MT
Case LTYP
    When 1,3,4,6,8,10,14:  # demandes
                        LRESS = 0
    When 2,5,7,9,13:    # ressources
                        LRESS = 1
Endcase
End LRESS

########################################################################
# A partir du type d'encours, renvoit si il s'agit d'une demande
Funprog ISDEM( LTYP)
Value    Integer LTYP
Local Integer LDEM

# Issue number 107498/9 - 2016-03-01 by LLC : new demand type 14 = MT
Case LTYP
    When 1,3,4,6,8,10,14:  # demandes
                        LDEM = 1
    When 2,5,7,9,13:    # ressources
                        LDEM = 0
Endcase
End LDEM

# Issue 108013 - 2015-06-24 by GA : ECC for MRP
########################################################################
# Conversion from WIPTYP to TRSTYP to check stock rule used by MRP
# WIPTYP local menu 306 codes 1 to 13
# TRSTYP local menu 704 codes 1 to 35
Funprog WIP2TRS( LWIPTYP)
Value    Integer LWIPTYP

Local Integer LTRSTYP
Case LWIPTYP
    When 6  :  LTRSTYP = 6  # MWx => WO issue
    When 3  :  LTRSTYP = 29 # MSx => EO issue
    When 5  :  LTRSTYP = 5  # WOx => WO receipt
    When 13 :  LTRSTYP = 3  # EOx => EO receipt (normal)
    When Default : LTRSTYP = 0
Endcase
End LTRSTYP

# X3-69678 - STWIL
#**----------------------------------------------------------------<br/>
#* VCR2WIPTYP : Convert ORDERS VCRTYP to WIPTYP
#**<br/>----------------------------------------------------------------<br/>
#* @param VCRTYP  = Source document
#* @return WIPTYP = Demand type
#**<br/>----------------------------------------------------------------
#*!
Funprog VCR2WIPTYP (VCRTYP)
Value Integer VCRTYP

Local Integer LWIPTYP
    Case VCRTYP
        When 2 : LWIPTYP = 1      # Sales order to Customer order
        When 14 : LWIPTYP = 2     # Purchase order to supplier order
        When 10 : LWIPTYP = 5     # Work order to work order
        When 20 : LWIPTYP = 10    # Miscellaneous issue to Miscellaneous request
        When 19 : LWIPTYP = 11    # Miscellaneous receipt to Miscellaneous resources
        When 36 : LWIPTYP = 13    # Subcontract order to subcontract order
        When 40 : LWIPTYP = 14    # Project to project demand
        When Default : LWIPTYP = 0
    Endcase
End LWIPTYP

# Issue 108013 - 2015-06-22 by GA : ECC for MRP
########################################################################
# STOECCVAL      Calcul stock article site d'une version
########################################################################
# Paramètres E : LITM       = Article
#                LFCY       = Site
#                LMAJ       = Version majeure
#                LMIN       = Version mineure
#            S : LSTUACT    = Stock en US active
########################################################################
Subprog STOECCVAL(LITM,LFCY,LMAJ,LMIN,LSTUACT)
Value    Char     LITM
Value    Char     LFCY
Value    Char     LMAJ
Value    Char     LMIN
Variable Decimal  LSTUACT

Local    Char     CRITERE(100)

Local File ITMMVT     [ITV]
Local File STOLOT     [STL]
Local File STOLOTFCY  [SLF]

LSTUACT=0

If LITM="" | LFCY="" : End : Endif

Read [ITV]ITV0=LITM;LFCY
If fstat : End : Endif

If LMAJ=""
  LSTUACT = [F:ITV]PHYSTO+[F:ITV]CTLSTO+[F:ITV]REJSTO
&          +[F:ITV]PLFPHYSTO+[F:ITV]PLFCTLSTO+[F:ITV]PLFREJSTO
&          +[F:ITV]BPRPHYSTO+[F:ITV]BPRCTLSTO+[F:ITV]BPRREJSTO
&          +[F:ITV]SCOPHYSTO+[F:ITV]SCOCTLSTO+[F:ITV]SCOREJSTO
Else
  CRITERE = '[F:SLF]ITMREF=LITM&[F:SLF]STOFCY=LFCY&[F:STL]ECCVALMAJ=LMAJ'
  If LMIN<>""
    CRITERE += '&[F:STL]ECCVALMIN=LMIN'
  Endif

  Link [SLF] With [STL]STL0=[F:SLF]ITMREF;[F:SLF]LOT;[F:SLF]SLO As [LNK]
&            Where evalue(CRITERE)
  For [LNK]
    LSTUACT += [F:SLF]AAACUMQTY+[F:SLF]QQQCUMQTY+[F:SLF]RRRCUMQTY
  Next
Endif

End

