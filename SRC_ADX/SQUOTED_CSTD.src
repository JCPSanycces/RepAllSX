#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe SQUOTED
#######################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS

  Case CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"              : Gosub AREAD_AFTER              From SQUOTED_METHODS
        When "AINSERT_BEFORE"           : Gosub AINSERT_BEFORE
        When "AUPDATE_BEFORE"           : Gosub AUPDATE_BEFORE

        When Default
      Endcase
    When "C_VACITM"
      Case [L]AEVENT
        When "AREAD_AFTER"              : Gosub AREAD_AFTER_C_VACITM From SQUOTED_METHODS
        When Default
      Endcase
    When Default
  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
        When "LOADVATPARAMFROMDOC"      : #--Nothing done if already existing errors !!!
                                          #If fmet this.AGETMAXERROR("")>=[V]CST_AERROR : Return : Endif
                                          Gosub LOADVATPARAMFROMDOC      From SQUOTED_METHODS
                                          Return
        When "LOADVATRESULTFROMFINDVAT" : #--Nothing done if already existing errors !!!
                                          #If fmet this.AGETMAXERROR("")>=[V]CST_AERROR : Return : Endif
                                          Gosub LOADVATRESULTFROMFINDVAT From SQUOTED_METHODS
                                          Return
  Endcase
Return
#--------------------------------------
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class - removed all _LEG properties related calls
  Case CURPTH
    When ""
      Case CURPRO
        When "LINQUONOT"                 :  Gosub LINQUONOT     From SQUOTED_PROPERTIES
        When "LINQUOATI"                 :  Gosub LINQUOATI     From SQUOTED_PROPERTIES
        When "LINPFM"                    :  Gosub LINPFM        From SQUOTED_PROPERTIES
        When Default
      Endcase
    When Default
  Endcase
Return

#######################################################################################
#######################################################################################
#######################################################################################
# METHODS                                                                             #
#######################################################################################
#######################################################################################
#######################################################################################
$NEW_TEXT_MANAGE
Local Integer IRET

  If this.CLASQDTEX <> null Then
    If this.SQDTEX = "" Then
      IRET = fmet this.CLASQDTEX.COMPUTE_CODE("SQD", this.SQDTEX)
    Endif
    IRET = fmet this.CLASQDTEX.SET_IDENT(this.SQHNUM, num$(this.SQDLIN), "")
  Endif

Return
#######################################################################################
$AINSERT_BEFORE
  # Note : A faire après le calcul de SQHNUM
  Gosub NEW_TEXT_MANAGE

Return
#######################################################################################
$AUPDATE_BEFORE

  Gosub NEW_TEXT_MANAGE

Return
#######################################################################################

