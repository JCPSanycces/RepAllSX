#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################
# UUMGTRTGPA03   Squelette pour Moulinette de Migration      Module GPAO #
#                                                                        #
#          Update of field CCE stored in [F:CAL]                         #
#                                                                        #
##########################################################################
# Extrait de GPAMAJ30                                                    #
#   - $MFG   : Update of MFG tables  Insert rows into CPTANALIN          #
#              MFGHEAD [F:MFG]                                           #
#              MFGITM  [F:MFI]                                           #
#              MFGMAT  [F:MFM]                                           #
#              MFGOPE  [F:MFO]                                           #
##########################################################################
# Issues 80101 & 80102 & get VERSION number - GA 02/2012
##########################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
If !GSERVEUR
  Call SAIDOS(WDOSSIER,"") From SAIDOS
Endif
If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=[L]WDOSSIER : If fstat Raz [F:ADS] : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTGPA03") From LECFIC
  Endif

  #Call RAZ_UUMGTRTGPA03(WDOSSIER)
  Call MAJ_UUMGTRTGPA03(WDOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End



########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(WDOSSIER)
Value Char    WDOSSIER
If WDOSSIER=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS]DOSSIER=WDOSSIER : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(7)<>2 : End : Endif                                  : # N= no module - 1    7=>GPAO
Call MAJ_UUMGTRTGPA03(WDOSSIER)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (WDOSSIER)
Value Char    WDOSSIER
If WDOSSIER=GDOSX3 End : Endif
Call MAJ_UUMGTRTGPA03(WDOSSIER)
End

##########################################################################
Subprog MAJ_UUMGTRTGPA03(WDOSSIER)
Value Char WDOSSIER

GOK=1
Gosub UPDMFG
If GOK<=0
    Call ECR_TRACE("UUMGTRTGPA03 table MFGHEAD Incorrectly Processed : Update MFG"-WDOSSIER,1) From GESECRAN
Endif

End
##########################################################################
Subprog RAZ_UUMGTRTGPA03(WDOSSIER)
Value Char WDOSSIER

#Local Integer ERR
  Call RAZ_UUMGTRTGPA03_FIC(WDOSSIER,"MFGITM" ,"MFI")
  Call RAZ_UUMGTRTGPA03_FIC(WDOSSIER,"MFGMAT" ,"MFM")
  Call RAZ_UUMGTRTGPA03_FIC(WDOSSIER,"MFGOPE" ,"MFO")

  Call RAZ_UUMGTRTGPA03_FIC(WDOSSIER,"MFGHEAD","MFG")
End

##########################################################################
$UPDMFG
Local Integer ERR

GOK=1

##1 - verifications
####################

If [F:ADS]MODULE(7)<>2    # N= no module - 1    7=>GPAO
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTGPA03",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

#----- Is new file ok ? ...  -----#
If  filinfo(filpath("FIL","MFGHEAD"   ,"fde",WDOSSIER),0) <=0
& | filinfo(filpath("FIL","MFGITM"    ,"fde",WDOSSIER),0) <=0
& | filinfo(filpath("FIL","MFGMAT"    ,"fde",WDOSSIER),0) <=0
& | filinfo(filpath("FIL","MFGOPE"    ,"fde",WDOSSIER),0) <=0
& | filinfo(filpath("FIL","CPTANALIN" ,"fde",WDOSSIER),0) <=0
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTGPA03",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

Local Char WNAMFICM,WNAMFICM_I,WNAMFICM_M,WNAMFICM_O
Call MIGTABNAME (WDOSSIER,"MFGHEAD",WNAMFICM  ,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTGPA03",7,ERR) From TRTMIG : #7=Erreur
  Return
Endif
Call MIGTABNAME (WDOSSIER,"MFGITM" ,WNAMFICM_I,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTGPA03",7,ERR) From TRTMIG : #7=Erreur
  Return
Endif
Call MIGTABNAME (WDOSSIER,"MFGMAT" ,WNAMFICM_M,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTGPA03",7,ERR) From TRTMIG : #7=Erreur
  Return
Endif
Call MIGTABNAME (WDOSSIER,"MFGOPE" ,WNAMFICM_O,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTGPA03",7,ERR) From TRTMIG : #7=Erreur
  Return
Endif

#----- Is old renamed file ok ?...  -----#
If  filinfo(filpath("FIL",WNAMFICM  ,"fde",WDOSSIER),0) < 0
& | filinfo(filpath("FIL",WNAMFICM_I,"fde",WDOSSIER),0) < 0
& | filinfo(filpath("FIL",WNAMFICM_M,"fde",WDOSSIER),0) < 0
& | filinfo(filpath("FIL",WNAMFICM_O,"fde",WDOSSIER),0) < 0
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTGPA03",3,ERR) From TRTMIG : #3=Terminée
  Return
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTGPA03",2,ERR) From TRTMIG : #2=En cours

#----- Récupération du n° de version
Local Char VERSION
Call MIGGETVERSION (WDOSSIER,VERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTGPA03",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

###################

Call ECR_TIME("UUMGTRTGPA03 table MFGHEAD Process : Update MFG") From DOSSUB
Call ECR_TRACE("UUMGTRTGPA03 : Process Start on : "+WDOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (WDOSSIER,"MFGHEAD"   ,ERR) From TRTMIG
Call MIGTABINIT (WDOSSIER,"MFGITM"    ,ERR) From TRTMIG
Call MIGTABINIT (WDOSSIER,"MFGMAT"    ,ERR) From TRTMIG
Call MIGTABINIT (WDOSSIER,"MFGOPE"    ,ERR) From TRTMIG
##Ne pas faire INIT et END sur CPTANALIN
#Call MIGTABINIT (WDOSSIER,"CPTANALIN" ,ERR) From TRTMIG

#----- Ouverture des fichiers -----#
If clalev([F:MFG])  = 0 : Local File =WDOSSIER+".MFGHEAD"    [MFG]  : Endif   # Fichier X3 "Vide"
If clalev([F:MFI])  = 0 : Local File =WDOSSIER+".MFGITM"     [MFI]  : Endif   # Fichier X3 "Vide"
If clalev([F:MFM])  = 0 : Local File =WDOSSIER+".MFGMAT"     [MFM]  : Endif   # Fichier X3 "Vide"
If clalev([F:MFO])  = 0 : Local File =WDOSSIER+".MFGOPE"     [MFO]  : Endif   # Fichier X3 "Vide"
If clalev([F:CAL])  = 0 : Local File =WDOSSIER+".CPTANALIN"  [CAL]  : Endif   # Fichier X3 V6 à compléter

If clalev([F:MFGM]) = 0 : Local File =WDOSSIER+"."+WNAMFICM   [MFGM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:MFIM]) = 0 : Local File =WDOSSIER+"."+WNAMFICM_I [MFIM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:MFMM]) = 0 : Local File =WDOSSIER+"."+WNAMFICM_M [MFMM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:MFOM]) = 0 : Local File =WDOSSIER+"."+WNAMFICM_O [MFOM] : Endif   # Fichier X3 renommé Avant Migration
Local Char WMFGFCY(GLONFCY) : WMFGFCY=""

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer STOP, NB, NBCOMMIT, ISVALID, NBLUS, NBTOT
Local Char CRITERE(250),CRITERESPE(250), HINTSPE(30) # Issue 80101 ajout HINTSPE
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, NBTOT, STOP, CRITERE

# Déclaration des variables communes de travail
Local Integer I, J
Local Integer NB_MFI,NB_MFM,NB_MFO
Local Char WCRIT_MFI(250) : WCRIT_MFI="1=1"
Local Char WCRIT_MFM(250) : WCRIT_MFM="1=1"
Local Char WCRIT_MFO(250) : WCRIT_MFO="1=1"
# pour les WriteB des tables détails
Local Char WTAB_MFG (100) (adxwrb)
Local Shortint WCPT_MFG
Local Char WTAB_MFI (100) (adxwrb)
Local Char WTAB_MFM (100) (adxwrb)
Local Char WTAB_MFO (100) (adxwrb)
Local Char WTAB_CAL (100) (adxwrb)
Local Shortint WCPT_MFI, WCPT_MFM, WCPT_MFO, WCPT_CAL



#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (WDOSSIER,"UUMGTRTGPA03",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(NBMIGKEY))

# PE pour ajout clause where
# ATTENTION: en dernier la clause sur MFG réutilisée juste après
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTGPA03" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

# Issue 80145 Key=MFGFCY+MFGNUM
Filter [F:MFGM] Order By Key CLE=[F:MFGM]MFGFCY;[F:MFGM]MFGNUM

$LOOP_MFG00
Raz NB
# Clé optimisée migration: MFGFCY/MFGNUM
If STOP = 1
 STOP = 2
 CRITERE = "[F:MFGM]MFGFCY=TABMIGKEY(1) & [F:MFGM]MFGNUM>TABMIGKEY(2)"
Elsif STOP=2
 STOP = 0
 CRITERE = "[F:MFGM]MFGFCY>TABMIGKEY(1)"
Else
 CRITERE = "1=1"
Endif


Trbegin [MFG],[MFI],[MFO],[MFM],[CAL]
GOK = 1

# Issue 80145 Key=MFGFCY+MFGNUM instead of MFG0
For [MFGM]CLE Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)
  NBLUS += 1

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTGPA03" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto NEXT_MFG : Endif
  Endif
  If [F:MFGM]MFGFCY<>WMFGFCY
     WMFGFCY=[F:MFGM]MFGFCY
     Gosub CHARGE_PARAM
  Endif
  Raz NB_MFI,NB_MFM,NB_MFO

  #Raz [F:MFG]
  # version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_MFG
  Endif
  # version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
      Gosub RAZV7_MFG
  Endif

  [F:MFG] = [F:MFGM]

  If val(VERSION)<GMIGX3VER60
      #Appel proc de migration sur entete
      Gosub MAJV6_MFG
      If GOK<1 : Break : Endif
  Endif

  If val(VERSION)<GMIGX3VER60 | val(VERSION)<GMIGX3VER70  #Appel proc de migration V6 et V7 sur tables détails
    # 1er détail: MFI+CAL
      Gosub UPDMFG_MFI
      If GOK<1 : Break : Endif

    # 2eme détail: MFM+CAL
      Gosub UPDMFG_MFM
      If GOK<1 : Break : Endif

    # 3eme détail: MFO+CAL
      Gosub UPDMFG_MFO
      If GOK<1 : Break : Endif
  Endif

  # --- alimentation des champs et écriture enreg
  Gosub MFG_STK : # pour stocker ref
  WriteB [F:MFG]
  If fstat
      Call ECR_TRACE("File MFGHEAD, Error ="-num$(fstat),1) From GESECRAN
      Gosub MFG_ERRTRA : # pour afficher les ref
      GOK=0 : Break
  Endif

  NB+=1
  NBTOT+=(1+NB_MFI+NB_MFM+NB_MFO)    # Comptage des lignes détail
  If NB>GMAXUPDTRS
    TABMIGKEY(1) = [F:MFGM]MFGFCY
    TABMIGKEY(2) = [F:MFGM]MFGNUM
    STOP=1
    Break
  Endif
$NEXT_MFG
Next

$END_MFG
If GOK<1
  Rollback
  Call MIGSTKENDFLG (WDOSSIER,"UUMGTRTGPA03",7,ERR) From TRTMIG : #7=Erreur
Else
    Flush [F:MFG]
    If fstat
        Call ECR_TRACE("File MFGHEAD, Error ="-num$(fstat),1) From GESECRAN
        Gosub MFG_ERRTRA : # pour afficher les ref
        GOK=0 : Goto END_MFG : #on part sur rollback
    Endif
    Flush [F:MFI]
    If fstat
        Call ECR_TRACE("File MFGITM, Error ="-num$(fstat),1) From GESECRAN
        Gosub MFI_ERRTRA : # pour afficher les ref
        GOK=0 : Goto END_MFG : #on part sur rollback
    Endif
    Flush [F:MFM]
    If fstat
        Call ECR_TRACE("File MFGMAT, Error ="-num$(fstat),1) From GESECRAN
        Gosub MFM_ERRTRA : # pour afficher les ref
        GOK=0 : Goto END_MFG : #on part sur rollback
    Endif
    Flush [F:MFO]
    If fstat
        Call ECR_TRACE("File MFGOPE, Error ="-num$(fstat),1) From GESECRAN
        Gosub MFO_ERRTRA : # pour afficher les ref
        GOK=0 : Goto END_MFG : #on part sur rollback
    Endif
    Flush [F:CAL]
    If fstat
        Call ECR_TRACE("File CPTANALIN, Error ="-num$(fstat),1) From GESECRAN
        Gosub CAL_ERRTRA From UUMGTRTGPA00: # pour afficher les ref
        GOK=0 : Goto END_MFG : #on part sur rollback
    Endif
    If STOP
      TABMIGKEY(NBMIGKEY)=num$(STOP)
    Else
      Raz TABMIGKEY
    Endif
    # Stocker les valeurs de ACLE1/ACLE2/ACLE3/STOP dans la table AMIGKEY.
    Call MIGSTKKEY (WDOSSIER,"UUMGTRTGPA03",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
    If ERR
     GOK=-1 : Goto END_MFG
    Endif
    Commit
    NBCOMMIT+=NB
    Call MIGSTKPROGRESS (WDOSSIER,"UUMGTRTGPA03",STOP,ERR) From TRTMIG
    If STOP
      Goto LOOP_MFG00
    Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [MFG]
Close Local File [MFI]
Close Local File [MFM]
Close Local File [MFO]
Close Local File [MFGM]
Close Local File [MFIM]
Close Local File [MFMM]
Close Local File [MFOM]
Close Local File [CAL]
#----- Remise en état des fichiers où on a inseré -----#
Call MIGTABEND (WDOSSIER,"MFGHEAD"  ,ERR) From TRTMIG
Call MIGTABEND (WDOSSIER,"MFGITM"   ,ERR) From TRTMIG
Call MIGTABEND (WDOSSIER,"MFGMAT"   ,ERR) From TRTMIG
Call MIGTABEND (WDOSSIER,"MFGOPE"   ,ERR) From TRTMIG
##Ne pas faire INIT et END sur CPTANALIN
#Call MIGTABEND (WDOSSIER,"CPTANALIN",ERR) From TRTMIG
Call MIGTRTEND (WDOSSIER,"UUMGTRTGPA03") From TRTMIG
Call ECR_TIME("UUMGTRTGPA03:"+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

##########################################################################
$RAZV6_MFG
Return
$RAZV6_MFI
Return
$RAZV6_MFM
Return
$RAZV6_MFO
Return

##########################################################################
$RAZV7_MFG
Return
$RAZV7_MFI
Return
$RAZV7_MFM
Return
$RAZV7_MFO
Return

##########################################################################
$UPDMFG_MFI

# Transaction déjà démarrée
GOK = 1
For [MFIM]MFI0 Where MFGFCY=[F:MFG]MFGFCY & MFGNUM=[F:MFG]MFGNUM
&                    & evalue(WCRIT_MFI)

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTGPA03/MFI" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto NEXT_MFI : Endif
  Endif

  #Raz [F:MFI]
  # version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_MFI
  Endif
  # version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
      Gosub RAZV7_MFI
  Endif

  [F:MFI] = [F:MFIM]

  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_MFI
    If GOK<1 : Break : Endif

    Gosub MAJV6_MFI_CAL
    If GOK<1 : Break : Endif
  Endif

  NB_MFI+=2

$NEXT_MFI
Next

Return

##########################################################################
$UPDMFG_MFM

# Transaction déjà démarrée
GOK = 1
For [MFMM]MFM0 Where MFGFCY=[F:MFG]MFGFCY & MFGNUM=[F:MFG]MFGNUM
&                    & evalue(WCRIT_MFM)

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTGPA03/MFM" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto NEXT_MFM : Endif
  Endif
  #Raz [F:MFM]
  # version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_MFM
  Endif
  # version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
      Gosub RAZV7_MFM
  Endif

  [F:MFM] = [F:MFMM]

  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_MFM
    If GOK<1 : Break : Endif

    Gosub MAJV6_MFM_CAL
    If GOK<1 : Break : Endif
  Endif

  NB_MFM+=2

$NEXT_MFM
Next

Return

##########################################################################
$UPDMFG_MFO

# Transaction déjà démarrée
GOK = 1
For [MFOM]MFO0 Where MFGFCY=[F:MFG]MFGFCY & MFGNUM=[F:MFG]MFGNUM
&                    & evalue(WCRIT_MFO)

  # PE pour exclure ligne
  If FILTRELIN
      FLUX="UUMGTRTGPA03/MFO" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
      If ISVALID=0 : Goto NEXT_MFO : Endif
  Endif
  #Raz [F:MFO]
  # version < V6, raz des champs v6
  If val(VERSION)<GMIGX3VER60
      Gosub RAZV6_MFO
  Endif
  # version < V7, raz des champs v7
  If val(VERSION)<GMIGX3VER70
      Gosub RAZV7_MFO
  Endif

  [F:MFO] = [F:MFOM]

  If val(VERSION)<GMIGX3VER60
    Gosub MAJV6_MFO
    If GOK<1 : Break : Endif

    Gosub MAJV6_MFO_CAL
    If GOK<1 : Break : Endif
  Endif

  NB_MFO+=2

$NEXT_MFO
Next

Return


#######################################################################
# Code extrait de GPAMAJ30 - table MFGHEAD
#######################################################################
$MAJV6_MFG
[F:MFG]UPDUSR=GUSER
[F:MFG]UPDDAT=date$
Return
#######################################################################
$MFG_STK
Call STK (WTAB_MFG,WCPT_MFG,[F:MFG]MFGNUM) From TRTMIG
Return
#######################################################################
$MFG_ERRTRA
Call ERRTRA (WTAB_MFG,WCPT_MFG,"File MFGHEAD(MFGNUM)=") From TRTMIG
Return


#######################################################################
# Code extrait de GPAMAJ30 - table MFGITM
#######################################################################
$MAJV6_MFI
  [F:MFI]UPDUSR=GUSER
  [F:MFI]UPDDAT=date$
  # --- alimentation des champs et écriture enreg
  Gosub MFI_STK : # pour stocker ref MFI
  WriteB [F:MFI]
  If fstat
      Call ECR_TRACE("MAJ_UUMGTRTGPA03: File MFGITM MFI, Error ="-num$(fstat),1) From GESECRAN
      Gosub MFG_ERRTRA : # pour afficher les ref
      GOK=0 : Return
  Else
    Call ECR_DEBUG("File MFGITM(MFGFCY/MFGNUM/MFGLIN)"-[F:MFI]MFGFCY+"/"+[F:MFI]MFGNUM+"/"+num$([F:MFI]MFGLIN))
  Endif
Return
#######################################################################
$MAJV6_MFI_CAL
  #Raz [F:CAL]
  [F:CAL]ABRFIC="MFI"
  [F:CAL]VCRNUM=[F:MFI]MFGNUM
  [F:CAL]VCRLIN=[F:MFI]MFGLIN
  [F:CAL]VCRSEQ=0
  [F:CAL]CPLCLE=""
  [F:CAL]ANALIG=1
  For J=1 To max(GNBCOA,2)
    [F:CAL]LED(J-1)=GLEDSOC(J)
    [F:CAL]COA(J-1)=GCOA(J)
  Next J
  For J=1 To max(GNBDIE,GOPTCANA)
    [F:CAL]DIE(J-1)=GDIE(J)
    If evalue("dim([F:MFIM]CCE"+num$(J)+")")>0    # Issue 80466 GA 03/2012 error [F:MFI]
        [F:CAL]CCE(J-1)=evalue("[F:MFIM]CCE"+num$(J))
    Endif
  Next J
  # --- alimentation des champs et écriture enreg
  Gosub CAL_STK From UUMGTRTGPA00 # pour stocker ref CAL
  WriteB [F:CAL]
  If fstat
       Call ECR_TRACE("MAJ_UUMGTRTGPA03: File CPTANALIN MFI, Error ="-num$(fstat),1) From GESECRAN
       Gosub CAL_ERRTRA From UUMGTRTGPA00: # pour afficher les ref
      GOK=0 : Return
  Endif
Return
#######################################################################
$MFI_STK
Call STK (WTAB_MFI,WCPT_MFI,[F:MFI]MFGNUM) From TRTMIG
Return
#######################################################################
$MFI_ERRTRA
Call ERRTRA (WTAB_MFI,WCPT_MFI,"File MFGITM(MFGNUM)=") From TRTMIG
Return


#######################################################################
# Code extrait de GPAMAJ30 - table MFGMAT
#######################################################################
$MAJV6_MFM
  [F:MFM]CPNTYP = 1   # V6 new Field
  [F:MFM]UPDUSR=GUSER
  [F:MFM]UPDDAT=date$
  # --- alimentation des champs et écriture enreg
  Gosub MFM_STK : # pour stocker ref MFM
  WriteB [F:MFM]
  If fstat
      Call ECR_TRACE("MAJ_UUMGTRTGPA03: File MFGMAT MFM, Error ="-num$(fstat),1) From GESECRAN
      Gosub MFG_ERRTRA : # pour afficher les ref
      GOK=0 : Return
  Else
    Call ECR_DEBUG("File MFGITM(MFGFCY/MFGNUM/MFGLIN/BOMSEQ/ITMREF)"-[F:MFM]MFGFCY+"/"+[F:MFM]MFGNUM
&                  +"/"+num$([F:MFM]MFGLIN)+"/"+num$([F:MFM]BOMSEQ)+[F:MFM]ITMREF)
  Endif
Return
#######################################################################
$MAJV6_MFM_CAL
  #Raz [F:CAL]
  [F:CAL]ABRFIC="MFM"
  [F:CAL]VCRNUM=[F:MFM]MFGNUM
  [F:CAL]VCRLIN=[F:MFM]MFGLIN
  [F:CAL]VCRSEQ=[F:MFM]BOMSEQ
  [F:CAL]CPLCLE=[F:MFM]ITMREF
  [F:CAL]ANALIG=1
  For J=1 To max(GNBCOA,2)
    [F:CAL]LED(J-1)=GLEDSOC(J)
    [F:CAL]COA(J-1)=GCOA(J)
  Next J
  For J=1 To max(GNBDIE,GOPTCANA)
    [F:CAL]DIE(J-1)=GDIE(J)
    If evalue("dim([F:MFMM]CCE"+num$(J)+")")>0    # Issue 80466 GA 03/2012 error [F:MFM]
        [F:CAL]CCE(J-1)=evalue("[F:MFMM]CCE"+num$(J))
    Endif
  Next J
  # --- alimentation des champs et écriture enreg
      Gosub CAL_STK From UUMGTRTGPA00 # pour stocker ref CAL
      WriteB [F:CAL]
  If fstat
       Call ECR_TRACE("MAJ_UUMGTRTGPA03: File CPTANALIN MFM, Error ="-num$(fstat),1) From GESECRAN
       Gosub CAL_ERRTRA From UUMGTRTGPA00: # pour afficher les ref
       GOK=0 : Return
  Endif
Return
#######################################################################
$MFM_STK
Call STK (WTAB_MFM,WCPT_MFM,[F:MFM]MFGNUM) From TRTMIG
Return
#######################################################################
$MFM_ERRTRA
Call ERRTRA (WTAB_MFM,WCPT_MFM,"File MFGMAT(MFGNUM)=") From TRTMIG
Return

#######################################################################
# Code extrait de GPAMAJ30 - table MFGOPE
#######################################################################
$MAJV6_MFO
  [F:MFO]UPDUSR=GUSER
  [F:MFO]UPDDAT=date$
  # --- alimentation des champs et écriture enreg
      Gosub MFO_STK : # pour stocker ref MFO
      WriteB [F:MFO]
  If fstat
      Call ECR_TRACE("MAJ_UUMGTRTGPA03: File MFGOPE MFO, Error ="-num$(fstat),1) From GESECRAN
      Gosub MFG_ERRTRA : # pour afficher les ref
      GOK=0 : Return
  Else
    Call ECR_DEBUG("File MFGITM(MFGFCY/MFGNUM/OPENUM/OPESPLNUM)"-[F:MFO]MFGFCY+"/"+[F:MFO]MFGNUM
&                  +"/"+num$([F:MFO]OPENUM)+"/"+num$([F:MFO]OPESPLNUM) )
  Endif
Return
#######################################################################
$MAJV6_MFO_CAL
   #Raz [F:CAL]
   [F:CAL]ABRFIC="MFO"
   [F:CAL]VCRNUM=[F:MFOM]MFGNUM
   [F:CAL]VCRLIN=[F:MFOM]OPENUM
   [F:CAL]VCRSEQ=[F:MFOM]OPESPLNUM
   [F:CAL]CPLCLE="EXTWST"
   [F:CAL]ANALIG=1
   For J=1 To max(GNBCOA,2)
     [F:CAL]LED(J-1)=GLEDSOC(J)
     [F:CAL]COA(J-1)=GCOA(J)
   Next J
   For J=1 To max(GNBDIE,GOPTCANA)
     [F:CAL]DIE(J-1)=GDIE(J)
     If evalue("dim([F:MFOM]CCE"+num$(J)+")")>0    # Issue 80466 GA 03/2012 error [F:MFO]
         [F:CAL]CCE(J-1)=evalue("[F:MFOM]CCE"+num$(J))
     Endif
   Next J
   # --- alimentation des champs et écriture enreg
   Gosub CAL_STK From UUMGTRTGPA00 # pour stocker ref CAL
   WriteB [F:CAL]
   If fstat
       Call ECR_TRACE("MAJ_UUMGTRTGPA03: File CPTANALIN MFOM EXTWST, Error ="-num$(fstat),1) From GESECRAN
       Gosub CAL_ERRTRA From UUMGTRTGPA00: # pour afficher les ref
       GOK=0 : Return
   Endif
   If [F:MFOM]EXTLAB <> ""
       #Raz [F:CAL]
       [F:CAL]ABRFIC="MFO"
       [F:CAL]VCRNUM=[F:MFOM]MFGNUM
       [F:CAL]VCRLIN=[F:MFOM]OPENUM
       [F:CAL]VCRSEQ=[F:MFOM]OPESPLNUM
       [F:CAL]CPLCLE="EXTLAB"
       [F:CAL]ANALIG=1
       #For J=1 To max(GNBCOA,2)
       #  [F:CAL]LED(J-1)=GLEDSOC(J)
       #  [F:CAL]COA(J-1)=GCOA(J)
       #Next J
       For J=1 To max(GNBDIE,GOPTCANA)
         #[F:CAL]DIE(J-1)=GDIE(J)
         If evalue("dim([F:MFOM]LABCCE"+num$(J)+")")>0
             [F:CAL]CCE(J-1)=evalue("[F:MFOM]LABCCE"+num$(J))
         Endif
       Next J
       # --- alimentation des champs et écriture enreg
       Gosub CAL_STK From UUMGTRTGPA00 # pour stocker ref CAL
       WriteB [F:CAL]
       If fstat
           Call ECR_TRACE("MAJ_UUMGTRTGPA03: File CPTANALIN MFOM EXTLAB, Error ="-num$(fstat),1) From GESECRAN
           Gosub CAL_ERRTRA From UUMGTRTGPA00: # pour afficher les ref
           GOK=0 : Return
       Endif
  Endif
Return
#######################################################################
$MFO_STK
Call STK (WTAB_MFO,WCPT_MFO,[F:MFO]MFGNUM) From TRTMIG
Return
#######################################################################
$MFO_ERRTRA
Call ERRTRA (WTAB_MFO,WCPT_MFO,"File MFGOPE(MFGNUM)=") From TRTMIG
Return

#######################################################################
$CHARGE_PARAM
#----- Alimentation champs pour le multi-référenciels comptabilité -----#
Call RECUP_GLOBAL_CPT([F:ADS]DOSSIER,WMFGFCY) From TRTX3CPT
Return

######################################################################
Subprog ECR_DEBUG(LMESS)
Value Char LMESS
If GUSER="ZGA" & 1=2
   Call ECR_TRACE(LMESS,0) From GESECRAN
Endif

End

#######################################################################
Subprog RAZ_UUMGTRTGPA03_FIC(WDOSSIER,LNOMFIC,LABRFIC)
Value Char WDOSSIER
Value Char LNOMFIC
Value Char LABRFIC

Local Integer ERR

If filinfo(filpath("FIL",LNOMFIC,"fde",WDOSSIER),0)<=0 : GOK=0 : End :  Endif

# Issue 80145 Vérifier là aussi que le fichier renommé soit dispo
Local Char WNAMFICM
Call MIGTABNAME (WDOSSIER,LNOMFIC,WNAMFICM,ERR) From TRTMIG
If ERR : End : Endif
#----- Présence des fichiers renommés...  -----#
If filinfo(filpath("FIL",WNAMFICM,"fde",WDOSSIER),0) < 0 :  End : Endif

#Call ECR_TRACE("RAZ_UUMGTRTGPA03 Raz table"-WDOSSIER-LNOMFIC,0) From GESECRAN
Call MIGTABRAZ (WDOSSIER,LNOMFIC,ERR) From TRTMIG
If LABRFIC="MFG"
   Call MIGRAZKEY (WDOSSIER,"UUMGTRTGPA03",ERR) From TRTMIG
Endif

Local File =WDOSSIER+".CPTANALIN"  [CALW]
Trbegin [CALW]
Delete [CALW] Where ABRFIC=LABRFIC
Commit
Close Local File [CALW]

End

