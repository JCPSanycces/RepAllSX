#<AdxTL>@(#)7.0.0.0 $Revision$
# Representation class PBDBPGRP
# Update: ANGRE - SAM # 111399 2015-12-21
# 2018-08-28 Bader X3-103717 ENABLE_FIELDS_BY_PAYBALDCL: check activity code PBDCL before reading parameter
##############################################################################################################

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
    Case [L]CURPTH
       When "PBDBPG.PBDBPGRPD"
          Case [L]AEVENT
              When "AREAD_AFTER" : Gosub AREAD_AFTER_LINES   # A line has been read
          Endcase
    Endcase
Return

# SAM # 111399 $METHODS outcommented ADDLINE_AFTER is now implemented in $EVENT
$METHODS
#    Case [L]CURPTH
#       When "PBDBPG.PBDBPGRPD"
#          Case [L]ACTION
#              When "AREAD_AFTER" : Gosub AREAD_AFTER_LINES   # A line has been read
#          Endcase
#    Endcase
Return

$AREAD_AFTER_LINES
    Gosub ENABLE_TYP_BY_FLGALL
    Gosub ENABLE_FIELDS_BY_PAYBALDCL
Return


##############################################################################################################

$PROPERTIES
    Case [L]CURPRO
        When "PBDBPG.PBDBPGRPD.FLGALL" : Gosub PROP_FLGALL
        When "PBDBPG.PBDBPGRPD.LEG"    : Gosub PROP_LEG
    Endcase
Return

# SAM # 111399 changed ACTION to ARULE
$PROP_FLGALL
    Case [L]ARULE
        When "INIT"
            this.FLGALL = CST_AYES
        When "PROPAGATE"
            Gosub ENABLE_TYP_BY_FLGALL
    Endcase
Return

# SAM # 111399 changed ACTION to ARULE
$PROP_LEG
    Case [L]ARULE
        When "PROPAGATE"
            Gosub ENABLE_FIELDS_BY_PAYBALDCL
    Endcase
Return


##############################################################################################################

$ENABLE_TYP_BY_FLGALL
    If this.FLGALL = CST_AYES Then
        this.TYP = 0
        ASTATUS = fmet this.ASETATTRIBUTE( "TYP", "$isDisabled", "true" )
    Else
        ASTATUS = fmet this.ASETATTRIBUTE( "TYP", "$isDisabled", "false" )
    Endif
Return


$ENABLE_FIELDS_BY_PAYBALDCL
    If func AFNC.ACTIV("PBDCL") and fmet this.ACTX.APARAM.AGETVALNUM( [V]CST_ALEVLEG, this.LEG, "PAYBALDCL" ) = 2
        ASTATUS = fmet this.ASETATTRIBUTE( "FLGALL",    "$isDisabled", "false" )
        ASTATUS = fmet this.ASETATTRIBUTE( "TYP",       "$isDisabled", "false" )
        ASTATUS = fmet this.ASETATTRIBUTE( "CRYADDCOD", "$isDisabled", "false" )
        ASTATUS = fmet this.ASETATTRIBUTE( "FLGBPNINC", "$isDisabled", "false" )
    Else
        ASTATUS = fmet this.ASETATTRIBUTE( "FLGALL",    "$isDisabled", "true" )
        ASTATUS = fmet this.ASETATTRIBUTE( "TYP",       "$isDisabled", "true" )
        ASTATUS = fmet this.ASETATTRIBUTE( "CRYADDCOD", "$isDisabled", "true" )
        ASTATUS = fmet this.ASETATTRIBUTE( "FLGBPNINC", "$isDisabled", "true" )
    Endif
Return

