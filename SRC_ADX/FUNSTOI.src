#<AdxTL>@(#)83.0.0.0 $Revision$
$FUNSTOI
Call TRT_INTSTO
End
###########################################################
Subprog TRT_INTSTO 
#Vérification habilitations 
Local Char    WFCY(GLONFCY)  : WFCY = GFCYDEF(0)
Local Char    WITM(GLONITM)  : WITM = ""
Local Char    WLOT(GLONLOT)  : WLOT = ""
Local Char    WLOC(GLONLOC)  : WLOC = ""
Local Char    WPAL(GLONPAL)  : WPAL = ""
Local Char    WCTR(GLONCTR)  : WCTR = ""
Local Char    WSER(GLONSER)  : WSER = ""
Local Date    WDAT           : WDAT = date$
Local Integer WOPT           
If GNBGAUCHE = 0
  WOPT = 0
Else
  WOPT = 99
Endif
If clalev([F:ITM]) = 0 Local File ITMMASTER [ITM] : Endif
Call INTSTOOLD(WFCY,WITM,WLOT,WLOC,WPAL,WCTR,WSER,WDAT,WOPT) From SUBSTOI
Call IMPSCR From ATRTX3
End
