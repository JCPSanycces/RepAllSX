#<AdxTL>@(#)0.0.0.0 $Revision$
# ANLLIB                                             
# Constitution table analyse postes d'un Site               
# Constitution table analyse des OF d'un Site
#
#   séquence introduite pour test
#
Local Date PERSTRDAT      : PERSTRDAT = "991201"
Local Date PERENDDAT      : PERENDDAT = "991231"
Call WSTANL("GAL",PERSTRDAT,PERENDDAT)
End
#########################################################################
# Subprog WSTANL(LWCRFCY,LPERSTRD,LPERENDD)                             #
# Subprog MFGANL(LMFGFCY,LPERSTRD,LPERENDD)                             #
# Subprog SAI_BATCH(OK,OPT)                                             #
#########################################################################
#########################################################################
# Constitution table analyse postes d'un Site   
#   LWCRFCY  : Site
#   LPERSTRD : Date début période
#   LPERENDD : Date fin période
# 
Subprog WSTANL(LWCRFCY,LPERSTRD,LPERENDD)
#
Value Char       LWCRFCY()
Variable Date    LPERSTRD
Variable Date    LPERENDD
#
Local Char    WWCR
Local Char    WWST
Local Char    WLAB
Local Char    WTAB
Local Char    WCLE
Local Date    WDATD,WDATF
Local Integer I,J,WCOR,WRET
Local Integer WNBJOP,WNBJPER
Local Decimal WPERDISTH,WPERDIS
#
Local Integer WWSTTYP
Local Integer WCPLOPENBR,XCPLOPENBR
Local Decimal WTIM,WEFF,WSCA,WRATIO
Local Decimal WSTDSETLOD
Local Decimal WSTDOPELOD
Local Decimal WEXTSETLOD
Local Decimal WEXTOPELOD
Local Decimal WCPLSETLOD
Local Decimal WCPLOPELOD
Local Decimal WCPLTOTLOD
Local Decimal WEXTQTYSUM
Local Decimal WREJQTYSUM
Local Decimal WCPLQTYSUM
Local Decimal WAVEQTYEFF,XAVEQTYEFF
Local Decimal WAVEQTYSCA,XAVEQTYSCA
Local Decimal WEXTCPLTIM
#
Local Integer NBJMX : NBJMX = 2000   : # dimension tables calendrier
#
Local Decimal WCAP1(NBJMX)           : # capacités journalières théoriques
Local Decimal WCAP2(NBJMX)           : # capacités journalières corrigées
#
#   création WSTANL du site
# 
Trbegin ADOVAL
#
If clalev([F:TWD])  = 0 : Local File TABWEEDIA  [TWD]  : Endif
If clalev([F:MWS])  = 0 : Local File WORKSTATIO [MWS]  : Endif
If clalev([F:TWC])  = 0 : Local File TABWRKCTR  [TWC]  : Endif
If clalev([F:MFO])  = 0 : Local File MFGOPE     [MFO]  : Endif
If clalev([F:WSA])  = 0 : Local File WSTANL     [WSA]  : Endif
If clalev([F:FCY])  = 0 : Local File FACILITY   [FCY]  : Endif
If clalev([F:TUV]) = 0  : Local File TABUNAVAIL [TUV]  : Endif
If clalev([F:CPV]) = 0  : Local File CAPVAR     [CPV]  : Endif
#

# lecture site
Call LECTURE ("FCY", LWCRFCY, "") From CONTOBJ   

# lecture indisponibilités
Read [F:TUV]UVY0=[F:FCY]UVYCOD  
If fstat : Raz [F:TUV] : Endif

#
#   positionne les bornes du calendrier
#
WDATD = LPERSTRD
WDATF = LPERENDD
WNBJPER = WDATF - WDATD + 1
#
#   positionne le filtre général des opérations
#
# llc 02.02 13044
Filter [MFO] Where MFGFCY = LWCRFCY
&               &  CPLQTY <> 0
&               & (TRKFIRST >= LPERSTRD)
&               & (TRKFIRST <= LPERENDD)    
&               & (TRKLAST = [0/0/0] | TRKLAST <= LPERENDD)
&               &  CPLWST <> ""
&            Order By Key NEW = CPLWST    # llc 03.02 13699


#Filter [MFO] Where MFGFCY = LWCRFCY
#&               &  CPLQTY <> 0
#&               & (TRKLAST = [0/0/0] | TRKLAST >= LPERSTRD)
#&               &  CPLWST <> ""
#&            Order By Key NEW = CPLWST
#
#   prospecte l'ensemble des postes du site
Filter [F:MWS] Where WCRFCY = LWCRFCY & WSTTYP <> 3
For [F:MWS]WST4                                            # llc 10.02 Performances
  WWCR    = [F:MWS]WCR                 
  WWST    = [F:MWS]WST      
  WWSTTYP = [F:MWS]WSTTYP    

#  (llc 08.00 v130) nouvelle gestion des capacités
  Call LOACAP (WDATD,WDATF,WCAP1,WRET) From JALLIBB
  
#
#   calcul capacité période
#
  WPERDISTH = 0
  WPERDIS   = 0
  WNBJOP = 0
#
  For J = 0 To WNBJPER-1
    WPERDISTH += WCAP1(J)
    WPERDIS   += WCAP1(J)
    If WCAP1(J) > 0 
      WNBJOP += 1
    Endif
  Next J
#
#   traite les opérations concernées du poste
#
  WCPLOPENBR = 0
  WSTDSETLOD = 0
  WSTDOPELOD = 0
  WEXTSETLOD = 0
  WEXTOPELOD = 0
  WCPLSETLOD = 0
  WCPLOPELOD = 0
  WCPLTOTLOD = 0
  WEXTQTYSUM = 0
  WREJQTYSUM = 0
  WCPLQTYSUM = 0
  WAVEQTYEFF = 0
  WAVEQTYSCA = 0
  WEXTCPLTIM = 0
#
  Read [MFO]NEW = WWST
  If fstat : Goto WR_WSTANL : Endif
#
$MFO_NEXT
    If [F:MFO]EXTQTY = 0 : Goto MFO_NEXT2 : Endif        # llc 10.02 16250

    WCPLOPENBR += 1
    WTIM = [F:MFO]STDSETTIM
#      convertit en H si nécessaire
    If [F:MFO]TIMUOMCOD = 2
      WTIM /= 60
    Endif
    WSTDSETLOD += WTIM 
#
    WTIM = [F:MFO]STDOPETIM
    If [F:MFO]TIMUOMCOD = 2
      WTIM /= 60
    Endif
    WSTDOPELOD += WTIM 
#
    WTIM = [F:MFO]EXTSETTIM
    If [F:MFO]TIMUOMCOD = 2
      WTIM /= 60
    Endif
    WEXTSETLOD += WTIM 
#
    WTIM = [F:MFO]EXTOPETIM
    If [F:MFO]TIMUOMCOD = 2
      WTIM /= 60
    Endif
    WEXTOPELOD += WTIM 
#
    WTIM = [F:MFO]CPLSETTIM
    If [F:MFO]TIMUOMCOD = 2
      WTIM /= 60
    Endif
    WCPLSETLOD += WTIM 
    WCPLTOTLOD += WTIM
#
    WTIM = [F:MFO]CPLOPETIM
    If [F:MFO]TIMUOMCOD = 2
      WTIM /= 60
    Endif
    WCPLOPELOD += WTIM
    WCPLTOTLOD += WTIM 
#
    WEXTQTYSUM += [F:MFO]EXTQTY
    WREJQTYSUM += [F:MFO]REJCPLQTY
    WCPLQTYSUM += [F:MFO]CPLQTY
#   actualisation somme temps effectifs 
    # llc 10.03 19840 
    If [F:MFO]EXTQTY <> 0
    WRATIO      = [F:MFO]CPLQTY / [F:MFO]EXTQTY
    Else
        WRATIO      = 1
    Endif
#
    WTIM = [F:MFO]EXTSETTIM + ([F:MFO]EXTOPETIM * WRATIO)
    If [F:MFO]TIMUOMCOD = 2
      WTIM /= 60
    Endif
    WEXTCPLTIM += WTIM
#   actualisation rendement moyen (qté) et perte moyenne
    # llc 10.03 19840
    If [F:MFO]EXTQTY <> 0
    WEFF        = ([F:MFO]CPLQTY    * 100) / [F:MFO]EXTQTY
    Else
        WEFF        = 100
    Endif
    WSCA        = 100
    If [F:MFO]CPLQTY > 0 
      WSCA        = ([F:MFO]REJCPLQTY * 100) / [F:MFO]CPLQTY
    Endif
    WAVEQTYEFF += WEFF
    WAVEQTYSCA += WSCA        
#
$MFO_NEXT2                        # llc 10.02 16250
  Read [MFO] Next
  If fstat : Goto WR_WSTANL : Endif
  If [F:MFO]CPLWST = WWST : Goto MFO_NEXT : Endif
#
#  écriture ou réécriture enregistrement
#
$WR_WSTANL
#
  If WCPLOPENBR > 0
    WAVEQTYEFF /= WCPLOPENBR
    WAVEQTYSCA /= WCPLOPENBR
  Endif
#
  Readlock [WSA]WSA0 = LWCRFCY;WWST;WDATF
  WRET = fstat
  If WRET = 0
    [F:WSA]WCR       = WWCR
    [F:WSA]WSTTYP    = WWSTTYP
    [F:WSA]PERSTR    = WDATD
    [F:WSA]PERDAYNBR = WNBJPER
    [F:WSA]PERWRKNBR = WNBJOP
    [F:WSA]PERTHEAVA = WPERDISTH
    [F:WSA]PERAVA    = WPERDIS
    [F:WSA]CPLOPENBR = WCPLOPENBR
    [F:WSA]STDSETLOD = WSTDSETLOD
    [F:WSA]STDOPELOD = WSTDOPELOD
    [F:WSA]EXTSETLOD = WEXTSETLOD
    [F:WSA]EXTOPELOD = WEXTOPELOD
    [F:WSA]CPLSETLOD = WCPLSETLOD
    [F:WSA]CPLOPELOD = WCPLOPELOD
    [F:WSA]CPLTOTLOD = WCPLTOTLOD
    [F:WSA]EXTQTYSUM = WEXTQTYSUM
    [F:WSA]REJQTYSUM = WREJQTYSUM
    [F:WSA]CPLQTYSUM = WCPLQTYSUM
    [F:WSA]AVEQTYEFF = WAVEQTYEFF
    [F:WSA]AVEQTYSCA = WAVEQTYSCA
    [F:WSA]EXTCPLTIM = WEXTCPLTIM
    [F:WSA]UPDDAT    = date$
    [F:WSA]UPDUSR    = GUSER
#
    Rewrite [WSA]
    Unlock [WSA]
    If fstat
      WTAB="WSA"
      WCLE=LWCRFCY-WWST-WDATF
      Goto AB_WSTANL
    Endif
  Elsif WRET = 5
    [F:WSA]WCRFCY    = LWCRFCY
    [F:WSA]WCR       = WWCR
    [F:WSA]WSTTYP    = WWSTTYP
    [F:WSA]WST       = WWST
    [F:WSA]PERSTR    = WDATD
    [F:WSA]PEREND    = WDATF
    [F:WSA]PERDAYNBR = WNBJPER
    [F:WSA]PERWRKNBR = WNBJOP
    [F:WSA]PERTHEAVA = WPERDISTH
    [F:WSA]PERAVA    = WPERDIS
    [F:WSA]CPLOPENBR = WCPLOPENBR
    [F:WSA]STDSETLOD = WSTDSETLOD
    [F:WSA]STDOPELOD = WSTDOPELOD
    [F:WSA]EXTSETLOD = WEXTSETLOD
    [F:WSA]EXTOPELOD = WEXTOPELOD
    [F:WSA]CPLSETLOD = WCPLSETLOD
    [F:WSA]CPLOPELOD = WCPLOPELOD
    [F:WSA]CPLTOTLOD = WCPLTOTLOD
    [F:WSA]EXTQTYSUM = WEXTQTYSUM
    [F:WSA]REJQTYSUM = WREJQTYSUM
    [F:WSA]CPLQTYSUM = WCPLQTYSUM
    [F:WSA]AVEQTYEFF = WAVEQTYEFF
    [F:WSA]AVEQTYSCA = WAVEQTYSCA
    [F:WSA]EXTCPLTIM = WEXTCPLTIM
    [F:WSA]CREDAT    = date$
    [F:WSA]CREUSR    = GUSER
    [F:WSA]UPDDAT    = date$
    [F:WSA]UPDUSR    = GUSER
#
    Write [WSA]
    If fstat
      WTAB="WSA"
      WCLE=LWCRFCY-WWST-WDATF
      Goto AB_WSTANL
    Endif
  Else
    WTAB="WSA"
    WCLE=LWCRFCY-WWST-WDATF
    Goto AB_WSTANL
  Endif
#
Next
Filter [F:MWS]
#
Commit
#
#   modification WSTANL du site pour prise en compte main d'oeuvre complémentaire
# 
Trbegin ADOVAL
#
If clalev([F:MWS])  = 0 : Local File WORKSTATIO [MWS]  : Endif
If clalev([F:TWC])  = 0 : Local File TABWRKCTR  [TWC]  : Endif
If clalev([F:MFO])  = 0 : Local File MFGOPE     [MFO]  : Endif
If clalev([F:WSA])  = 0 : Local File WSTANL     [WSA]  : Endif
#
#   positionne le filtre général des opérations
#
# llc 02.02 13044
Filter [MFO] Where MFGFCY = LWCRFCY
&                            &  CPLQTY <> 0
&                            & (TRKFIRST >= LPERSTRD)
&                            & (TRKFIRST <= LPERENDD)    
&                            & (TRKLAST = [0/0/0] | TRKLAST <= LPERENDD)
&                  & CPLLAB <> ""
&            Order By Key NEW = CPLLAB

#Filter [MFO] Where MFGFCY = LWCRFCY
#&                            &  CPLQTY <> 0
#&                  & (TRKLAST = [0/0/0] | TRKLAST >= LPERSTRD)
#&                  & CPLLAB <> ""
#&            Order By Key NEW = CPLLAB
#
#   prospecte l'ensemble des postes M/O du site
#
#Link [MWS] With [TWC]TWC0=[F:MWS]WCR
#&          As   [WSTCR]
#&          Order By Key WST3
#
#For [WSTCR] Where [F:TWC]WCRFCY=LWCRFCY
#&                 & [F:MWS]WSTTYP = 2
Filter [F:MWS] Where WCRFCY = LWCRFCY & WSTTYP = 2
For [F:MWS]WST4                                            # llc 10.02 Performances
  WLAB = [F:MWS]WST                 
#
#   traite les opérations concernées du poste M/O
#
  WCPLOPENBR = 0
  WSTDSETLOD = 0
  WSTDOPELOD = 0
  WEXTSETLOD = 0
  WEXTOPELOD = 0
  WCPLSETLOD = 0
  WCPLOPELOD = 0
  WCPLTOTLOD = 0
  WEXTQTYSUM = 0
  WREJQTYSUM = 0
  WCPLQTYSUM = 0
  WAVEQTYEFF = 0
  WAVEQTYSCA = 0
  WEXTCPLTIM = 0
#
  Read [MFO]NEW = WLAB
  If fstat : Goto LAB_NEXT : Endif
#
$MFO_NEXT_LAB
    If [F:MFO]EXTQTY = 0 : Goto MFO_NEXT_LAB2 : Endif        # llc 10.02 16250
    WCPLOPENBR += 1
    WTIM = [F:MFO]STDSETTIM * [F:MFO]SETLABCOE
#      convertit en H si nécessaire
    If [F:MFO]TIMUOMCOD = 2
      WTIM /= 60
    Endif
    WSTDSETLOD += WTIM 
#
    WTIM = [F:MFO]STDOPETIM * [F:MFO]OPELABCOE
    If [F:MFO]TIMUOMCOD = 2
      WTIM /= 60
    Endif
    WSTDOPELOD += WTIM 
#
    WTIM = [F:MFO]EXTSETTIM * [F:MFO]SETLABCOE
    If [F:MFO]TIMUOMCOD = 2
      WTIM /= 60
    Endif
    WEXTSETLOD += WTIM 
#
    WTIM = [F:MFO]EXTOPETIM * [F:MFO]OPELABCOE
    If [F:MFO]TIMUOMCOD = 2
      WTIM /= 60
    Endif
    WEXTOPELOD += WTIM 
#
    WTIM = [F:MFO]CPLSETTIM * [F:MFO]SETLABCOE
    If [F:MFO]TIMUOMCOD = 2
      WTIM /= 60
    Endif
    WCPLSETLOD += WTIM 
    WCPLTOTLOD += WTIM 
#
    WTIM = [F:MFO]CPLOPETIM * [F:MFO]OPELABCOE
    If [F:MFO]TIMUOMCOD = 2
      WTIM /= 60
    Endif
    WCPLOPELOD += WTIM 
    WCPLTOTLOD += WTIM 
#
    WEXTQTYSUM += [F:MFO]EXTQTY
    WREJQTYSUM += [F:MFO]REJCPLQTY
    WCPLQTYSUM += [F:MFO]CPLQTY
#   actualisation somme temps effectifs 
    # llc 10.03 19840
    If [F:MFO]EXTQTY <> 0
    WRATIO      = [F:MFO]CPLQTY / [F:MFO]EXTQTY
    Else
        WRATIO      = 1
    Endif
#
    WTIM = ([F:MFO]EXTSETTIM * [F:MFO]SETLABCOE) + 
&          ([F:MFO]EXTOPETIM * [F:MFO]OPELABCOE * WRATIO)
    If [F:MFO]TIMUOMCOD = 2
      WTIM /= 60
    Endif
    WEXTCPLTIM += WTIM 
#   actualisation rendement moyen (qté) et perte moyenne
    # llc 10.03 19840
    If [F:MFO]EXTQTY <> 0
    WEFF        = ([F:MFO]CPLQTY    * 100) / [F:MFO]EXTQTY 
    Else
        WEFF        = 100
    Endif
    WSCA        = 100
    If [F:MFO]CPLQTY > 0 
      WSCA        = ([F:MFO]REJCPLQTY * 100) / [F:MFO]CPLQTY
    Endif
    WAVEQTYEFF += WEFF
    WAVEQTYSCA += WSCA        
#
$MFO_NEXT_LAB2            # llc 10.02 16250
  Read [MFO] Next
  If fstat : Goto RW_WSTANL : Endif
  If [F:MFO]CPLLAB = WLAB : Goto MFO_NEXT_LAB : Endif
#
$RW_WSTANL
  If WCPLOPENBR > 0
#
    WAVEQTYEFF /= WCPLOPENBR
    WAVEQTYSCA /= WCPLOPENBR
#
    Readlock [WSA]WSA0=LWCRFCY;WLAB;WDATF
    If fstat
      WTAB="WSA"
      WCLE=LWCRFCY-WLAB-WDATF
      Goto AB_WSTANL
    Endif
#
    XCPLOPENBR = [F:WSA]CPLOPENBR  
    XAVEQTYEFF = [F:WSA]AVEQTYEFF  
    XAVEQTYSCA = [F:WSA]AVEQTYSCA
#  
#   actualisation rendement moyen (qté) et perte moyenne
#
    WAVEQTYEFF = ((XAVEQTYEFF * XCPLOPENBR) + (WAVEQTYEFF * WCPLOPENBR)) / 
&                (XCPLOPENBR + WCPLOPENBR)
    WAVEQTYSCA = ((XAVEQTYSCA * XCPLOPENBR) + (WAVEQTYSCA * WCPLOPENBR)) / 
&                (XCPLOPENBR + WCPLOPENBR)
#
    [F:WSA]CPLOPENBR += WCPLOPENBR
    [F:WSA]STDSETLOD += WSTDSETLOD
    [F:WSA]STDOPELOD += WSTDOPELOD
    [F:WSA]EXTSETLOD += WEXTSETLOD
    [F:WSA]EXTOPELOD += WEXTOPELOD
    [F:WSA]CPLSETLOD += WCPLSETLOD
    [F:WSA]CPLOPELOD += WCPLOPELOD
    [F:WSA]CPLTOTLOD += WCPLTOTLOD
    [F:WSA]EXTQTYSUM += WEXTQTYSUM
    [F:WSA]REJQTYSUM += WREJQTYSUM
    [F:WSA]CPLQTYSUM += WCPLQTYSUM
    [F:WSA]AVEQTYEFF  = WAVEQTYEFF
    [F:WSA]AVEQTYSCA  = WAVEQTYSCA
    [F:WSA]EXTCPLTIM += WEXTCPLTIM
#
    Rewrite [WSA]
    Unlock [WSA]
    If fstat
      WTAB="WSA"
      WCLE=LWCRFCY-WLAB-WDATF
      Goto AB_WSTANL
    Endif
#
  Endif
#
$LAB_NEXT
Next
Filter [F:MWS]
#
Commit
#
End
#########################################################################
# Constitution table analyse des OF d'un Site   
#   LMFGFCY  : Site
#   LPERSTRD : Date début période
#   LPERENDD : Date fin période
# 
Subprog MFGANL(LMFGFCY,LPERSTRD,LPERENDD)
#
Value Char       LMFGFCY()
Variable Date    LPERSTRD
Variable Date    LPERENDD
#
Local Char    WTAB
Local Char    WCLE
Local Date    WDATD,WDATF
Local Integer I,J,WRET
Local Integer WNBJPER
#
Local Decimal WTIM,WEFF,WSCA,WRATIO
#
Local Integer WOPENBR
Local Integer WMATNBR
Local Decimal WDELDAYNBR
Local Decimal WMFGCPLLTI
Local Decimal WMFGSCDLTI
Local Decimal WMFGLTI
Local Decimal WSTDTIMSUM
Local Decimal WEXTTIMSUM
Local Decimal WCPLTIMSUM
Local Decimal WCPLSHR
Local Decimal WOPEQTYEFF
Local Decimal WOPETIMEFF
Local Decimal WMATQTYEFF
#
#   création MFGANL du site
# 
Trbegin ADOVAL
#
If clalev([F:ITM])  = 0 : Local File ITMMASTER  [ITM]  : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT [ITF]  : Endif
If clalev([F:MFG])  = 0 : Local File MFGHEAD    [MFG]  : Endif
If clalev([F:MFM])  = 0 : Local File MFGMAT     [MFM]  : Endif
If clalev([F:MFO])  = 0 : Local File MFGOPE     [MFO]  : Endif
If clalev([F:MFI])  = 0 : Local File MFGITM     [MFI]  : Endif
If clalev([F:MFA])  = 0 : Local File MFGANL     [MFA]  : Endif
If clalev([F:MWS])  = 0 : Local File WORKSTATIO [MWS]  : Endif            # llc 10.02 Performances
#
#   positionne les bornes du calendrier
#
WDATD = LPERSTRD
WDATF = LPERENDD
WNBJPER = WDATF - WDATD + 1
#
#   positionne le filtre général des OF du site
#     (terminés dans la période)
#
Filter [MFG] Where MFGFCY = LMFGFCY
&                  & (MFGTRKFLG > 4 & MFGTRKFLG <= 6)
&                  & (CPLQTY <> 0)
&                  & (TRKLAST >= LPERSTRD & TRKLAST <= LPERENDD)

#
#   établit un lien entre MFGITM et ITMFACILIT
#
Link [MFI] With [ITF]ITF0=[F:MFI]ITMREF;[F:MFI]MFGFCY
&          As   [MFIT]
&          Order By Key MFI0
#
#   traitement des OF sélectionnés
#
Read [MFG]MFG1 First                                    # llc 10.02 Performances
If fstat : Goto END_MFGANL : Endif
#
$MFG_NEXT
#
  WMFGCPLLTI = [F:MFG]TRKLAST - [F:MFG]TRKFIRST + 1
#
#     traitement des matières de l'OF
#
  WMATNBR = 0
  WMATQTYEFF = 0
#
#       lecture des composants matière
#
  For [MFM]MFM0 Where MFGNUM = [F:MFG]MFGNUM                            # llc 10.02 Performances
    WMATNBR += 1
    # llc 10.03 19840
    If [F:MFM]RETQTY <> 0
    WMATQTYEFF += ([F:MFM]USEQTY * 100) / [F:MFM]RETQTY
    Else
        WMATQTYEFF += 100
    Endif
#
  Next
#
  If WMATNBR <> 0    # (llc 08.00)
      WMATQTYEFF /= WMATNBR
  Endif
#
#     traitement des opérations de l'OF
#
  WOPENBR = 0
  WSTDTIMSUM = 0
  WEXTTIMSUM = 0
  WCPLTIMSUM = 0
  WOPEQTYEFF = 0
  WOPETIMEFF = 0
#
#       lecture des opérations
#
  For [MFO]MFO0 Where MFGNUM = [F:MFG]MFGNUM                        # llc 10.02 Performances

    # llc 02.02 
    Read [MWS]WST0 = [F:MFO]EXTWST
    If fstat : Raz [MWS] : Endif
    If !find([F:MWS]WSTTYP , 1, 2) : Goto NEXT_OPE : Endif

    WOPENBR += 1
    WTIM = [F:MFO]STDSETTIM
#      convertit en H si nécessaire
    If [F:MFO]TIMUOMCOD = 2
      WTIM /= 60
    Endif
    WSTDTIMSUM += WTIM
#
    WTIM = [F:MFO]STDOPETIM
    If [F:MFO]TIMUOMCOD = 2
      WTIM /= 60
    Endif
    WSTDTIMSUM += WTIM 
#
    WTIM = [F:MFO]EXTSETTIM
    If [F:MFO]TIMUOMCOD = 2
      WTIM /= 60
    Endif
    WEXTTIMSUM += WTIM 
#
    WTIM = [F:MFO]EXTOPETIM
    If [F:MFO]TIMUOMCOD = 2
      WTIM /= 60
    Endif
    WEXTTIMSUM += WTIM 
#
    WTIM = [F:MFO]CPLSETTIM
    If [F:MFO]TIMUOMCOD = 2
      WTIM /= 60
    Endif
    WCPLTIMSUM += WTIM 
#
    WTIM = [F:MFO]CPLOPETIM
    If [F:MFO]TIMUOMCOD = 2
      WTIM /= 60
    Endif
    WCPLTIMSUM += WTIM 
#
#        ajoute main d'oeuvre complémentaire
#
    If [F:MFO]CPLLAB <> ""
#
      WTIM = [F:MFO]STDSETTIM * [F:MFO]SETLABCOE
#      convertit en H si nécessaire
      If [F:MFO]TIMUOMCOD = 2
        WTIM /= 60
      Endif
      WSTDTIMSUM += WTIM
#
      WTIM = [F:MFO]STDOPETIM * [F:MFO]OPELABCOE
      If [F:MFO]TIMUOMCOD = 2
        WTIM /= 60
      Endif
      WSTDTIMSUM += WTIM 
#
      WTIM = [F:MFO]EXTSETTIM * [F:MFO]SETLABCOE
      If [F:MFO]TIMUOMCOD = 2
        WTIM /= 60
      Endif
      WEXTTIMSUM += WTIM 
#
      WTIM = [F:MFO]EXTOPETIM * [F:MFO]OPELABCOE
      If [F:MFO]TIMUOMCOD = 2
        WTIM /= 60
      Endif
      WEXTTIMSUM += WTIM 
#
      WTIM = [F:MFO]CPLSETTIM * [F:MFO]SETLABCOE
      If [F:MFO]TIMUOMCOD = 2
        WTIM /= 60
      Endif
      WCPLTIMSUM += WTIM 
#
      WTIM = [F:MFO]CPLOPETIM * [F:MFO]OPELABCOE
      If [F:MFO]TIMUOMCOD = 2
        WTIM /= 60
      Endif
      WCPLTIMSUM += WTIM 
#
    Endif
#
    WRATIO = 1
    If [F:MFO]CPLQTY > 0
      WRATIO      = [F:MFO]EXTQTY / [F:MFO]CPLQTY
    Endif
#
    If [F:MFO]EXTSETTIM=0 & [F:MFO]EXTOPETIM=0
        WEFF = 100
    Else
        WEFF = (([F:MFO]CPLSETTIM + [F:MFO]CPLOPETIM * WRATIO) * 100)  
&                     / ([F:MFO]EXTSETTIM + [F:MFO]EXTOPETIM)
    Endif
#
    WSCA = 100
    If [F:MFO]CPLQTY > 0
      WSCA = (([F:MFO]CPLQTY - [F:MFO]REJCPLQTY) * 100) / [F:MFO]CPLQTY
    Endif
#
    WOPETIMEFF += WEFF
    WOPEQTYEFF += WSCA
#
$NEXT_OPE            # llc 02.02
  Next
#
  If WOPENBR <> 0        # (llc 08.00)
      WOPETIMEFF /= WOPENBR
      WOPEQTYEFF /= WOPENBR
  Endif
#
#     traitement des composés de l'OF
#
#       lecture des composés 
#
  For [MFIT] Where MFGNUM = [F:MFG]MFGNUM
    WDELDAYNBR = [F:MFI]ENDDAT - [F:MFI]TRKFIRST
    WCPLSHR = 0
    If [F:MFI]CPLQTY <> 0                                        # llc 07.01
        WCPLSHR = ([F:MFI]REJCPLQTY * 100) / [F:MFI]CPLQTY 
    Endif
#
#       écriture ou réécriture enregistrement
#
$WR_MFGANL
    Readlock [MFA]MFA0 = LMFGFCY;[F:MFG]MFGNUM;WDATF
    WRET = fstat
    If WRET = 0
      [F:MFA]MFGLIN    = [F:MFI]MFGLIN
      [F:MFA]ITMREF    = [F:MFI]ITMREF
      [F:MFA]PERSTR    = WDATD
      [F:MFA]PERDAYNBR = WNBJPER
      [F:MFA]OPENBR    = WOPENBR
      [F:MFA]MATNBR    = WMATNBR
      [F:MFA]DELDAYNBR = WDELDAYNBR
      [F:MFA]MFGCPLLTI = WMFGCPLLTI
      If [F:MFG]CLCSCDLTI <> 0
          [F:MFA]MFGSCDLTI = [F:MFG]CLCSCDLTI
      Else
          [F:MFA]MFGSCDLTI = [F:MFG]ENDDAT - [F:MFG]STRDAT
      Endif
      If [F:ITF]MFGLTI <> 0  
          [F:MFA]MFGLTI    = [F:ITF]MFGLTI
      Else
          [F:MFA]MFGLTI    = [F:MFG]ENDDAT - [F:MFG]STRDAT
      Endif
      If [F:MFA]MFGSCDLTI = 0 : [F:MFA]MFGSCDLTI = 1 : Endif
      If [F:MFA]MFGLTI    = 0 : [F:MFA]MFGLTI = 1    : Endif
      [F:MFA]STDTIMSUM = WSTDTIMSUM
      [F:MFA]EXTTIMSUM = WEXTTIMSUM
      [F:MFA]CPLTIMSUM = WCPLTIMSUM
      [F:MFA]SHR       = [F:ITF]SHR
      [F:MFA]CPLSHR    = WCPLSHR
      [F:MFA]OPEQTYEFF = WOPEQTYEFF
      [F:MFA]OPETIMEFF = WOPETIMEFF
      [F:MFA]MATQTYEFF = WMATQTYEFF
      [F:MFA]UPDDAT    = date$
      [F:MFA]UPDUSR    = GUSER
#
      Rewrite [MFA]
      Unlock [MFA]
      If fstat
        WTAB="MFA"
        WCLE=LMFGFCY-[F:MFG]MFGNUM-WDATF
        Goto AB_MFGANL
      Endif
    Elsif WRET = 5
      [F:MFA]MFGFCY    = LMFGFCY
      [F:MFA]ITMREF    = [F:MFI]ITMREF
      [F:MFA]MFGNUM    = [F:MFG]MFGNUM
      [F:MFA]MFGLIN    = [F:MFI]MFGLIN
      [F:MFA]PERSTR    = WDATD
      [F:MFA]PEREND    = WDATF
      [F:MFA]PERDAYNBR = WNBJPER
      [F:MFA]OPENBR    = WOPENBR
      [F:MFA]MATNBR    = WMATNBR
      [F:MFA]DELDAYNBR = WDELDAYNBR
      [F:MFA]MFGCPLLTI = WMFGCPLLTI
      If [F:MFG]CLCSCDLTI <> 0
          [F:MFA]MFGSCDLTI = [F:MFG]CLCSCDLTI
      Else
          [F:MFA]MFGSCDLTI = [F:MFG]ENDDAT - [F:MFG]STRDAT
      Endif
      If [F:ITF]MFGLTI <> 0  
          [F:MFA]MFGLTI    = [F:ITF]MFGLTI
      Else
          [F:MFA]MFGLTI    = [F:MFG]ENDDAT - [F:MFG]STRDAT
      Endif
      If [F:MFA]MFGSCDLTI = 0 : [F:MFA]MFGSCDLTI = 1 : Endif
      If [F:MFA]MFGLTI    = 0 : [F:MFA]MFGLTI = 1    : Endif
      [F:MFA]STDTIMSUM = WSTDTIMSUM
      [F:MFA]EXTTIMSUM = WEXTTIMSUM
      [F:MFA]CPLTIMSUM = WCPLTIMSUM
      [F:MFA]SHR       = [F:ITF]SHR
      [F:MFA]CPLSHR    = WCPLSHR
      [F:MFA]OPEQTYEFF = WOPEQTYEFF
      [F:MFA]OPETIMEFF = WOPETIMEFF
      [F:MFA]MATQTYEFF = WMATQTYEFF
      [F:MFA]CREDAT    = date$
      [F:MFA]CREUSR    = GUSER
      [F:MFA]UPDDAT    = date$
      [F:MFA]UPDUSR    = GUSER
#
      Write [MFA]
      If fstat
        WTAB="MFA"
        WCLE=LMFGFCY-[F:MFG]MFGNUM-WDATF
        Goto AB_MFGANL
      Endif
    Else
      WTAB="MFA"
      WCLE=LMFGFCY-[F:MFG]MFGNUM-WDATF
      Goto AB_MFGANL
    Endif
#  
#
  Next
#
Read [MFG]MFG1 Next                                    # llc 10.02 Performances
If fstat : Goto END_MFGANL : Endif
Goto MFG_NEXT
#
$END_MFGANL
#
Commit
#
End
############################################################
# Saisie des paramètres en batch 
#   OPT : 1 = WSA, 2 = MFA
#
Subprog SAI_BATCH(OK,OPT)
Variable Integer OK
Value    Integer OPT
#
Local Integer REPONSE
Local Integer WBOU(1..GNBBOU)
Local Integer SAVGOBJET
#
Local Dlgbox Mask [ANL4]
&   Button mess(64,123,1),mess(65,123,1)
&   With   left$(mess(64,123,1),1) , left$(mess(65,123,1),1)
&   Coded GSTAOK , GSTAFIN
&   Titled mess(OPT,386,1)
&   As [ANL4]
#
SAVGOBJET = GOBJET
Call SAVBOUT From GESECRAN
GOBJET = 0
#
Boxact [ANL4] 
[M:ANL4]PRO = OPT
Affzo  [ANL4] 
Grizo  [ANL4]PRO
WBOU(GVALI) = 1 
WBOU(GABAN) = 1 
Call SETBOUT(WBOU) From GESECRAN
Boxinp [ANL4] Using REPONSE 
Case REPONSE
  When GSTAOK  , GSTARET :
    OK = 2
  When GSTAESC , GSTAFIN :
    OK = 1
  When Default :  
    OK = 1
Endcase 
Boxclr [ANL4]
Call RESTBOUT From GESECRAN
GOBJET = SAVGOBJET
End 
#
#########################################################################
#
# fin anormale :
#   rollback     
#   écriture d'un message
#
$AB_WSTANL
#
If !GSERVEUR : GOK=0 : Call RSTA(WTAB,WCLE) From GLOCK : Rollback : Endif
End
#
#########################################################################
#
# fin anormale :
#   rollback     
#   écriture d'un message
#
$AB_MFGANL
#
If !GSERVEUR : GOK=0 : Call RSTA(WTAB,WCLE) From GLOCK : Rollback : Endif
End
