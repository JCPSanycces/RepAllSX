#<AdxTL>@(#)7.0.0.0 $Revision$ Consultation LLC
# CNSLLCSTD   Consultation des codes de plus bas niveau pour v 130
# remplace la visualisation SYNCLLC de la v 120        (TB  Déc 2000)

$ACTION
Case ACTION
 When "OUVRE"   Gosub OUVRE
 When "LECTURE" Gosub LECTURE
 When default
Endcase
Return

$OUVRE
Local Char  CRITERE(30), CRITERE2(255), WFILSPE(250)
Local Char  DEBITM(GLONITM), FINITM(GLONITM)
Local Integer DEBALT, FINALT, DEBLLC, FINLLC # pour conserver les bornes

# Mail TS du 18/03/08
NAVIG="CONSLLC"
Return

$LECTURE
########################################################################
# Préparation du filtre sur la table ITMBOM (ITB)                      #
########################################################################
Raz CRITERE
Raz CRITERE2

CRITERE = "LLCTYP = [M:IBS]LLCTYP"
Gosub LOAD_CRITERE2   

If [M:IBS]ITMREFDEB <> ""                   # borne début article
   CRITERE = "ITMREF >= [M:IBS]ITMREFDEB"
   Gosub LOAD_CRITERE2   
Endif
If [M:IBS]ITMREFFIN <> ""                   # borne fin article
   CRITERE = "ITMREF <= [M:IBS]ITMREFFIN"
   Gosub LOAD_CRITERE2   
Endif

If [M:IBS]BOMALTDEB <> 0                   # borne début alternative
   CRITERE = "BOMALT >= [M:IBS]BOMALTDEB"
   Gosub LOAD_CRITERE2   
Endif
If [M:IBS]BOMALTFIN <> 0                   # borne fin   alternative
   CRITERE = "BOMALT <= [M:IBS]BOMALTFIN"
   Gosub LOAD_CRITERE2   
Endif
If CRITERE2 = "" CRITERE2= "1=1" Endif  :# pour evalue()
Case CHGPAG
   When 3 : # rafraichissement
     Case [M:IBS]TRI
       When 1 : # tri par article
           CRITERE2 += "&[F]ITMREF>=DEBITM"
       When 2 : # tri par alternative
           CRITERE2 += "&[F]BOMALT>=DEBALT"
     Endcase
   When 2 : # suite
     Case [M:IBS]TRI
       When 1 : # tri par article
           CRITERE2 += "&[F]ITMREF>FINITM"
       When 2 : # tri par alternative
           CRITERE2 += "&([F]BOMALT>FINALT |([F]BOMALT=FINALT & [F]LLC>FINLLC))"
     Endcase
   When -2 : # retour
     Case [M:IBS]TRI
       When 1 : # tri par article
           CRITERE2 += "&[F]ITMREF<DEBITM"
       When 2 : # tri par alternative
           CRITERE2 += "&([F]BOMALT<DEBALT |([F]BOMALT=DEBALT & [F]LLC<DEBLLC))"
     Endcase
Endcase
WFILSPE="1=1"
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif
SUITE  = 1
RETOUR = 1
NBLU   = 2
# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #

#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:IBS]TRI
      When 1 : # tri par article
        Filter [ITB] Where evalue(CRITERE2) & evalue(WFILSPE) Order By Key ITB0
      When 2 : # tri par alternative/LLC
        Filter [ITB] Where evalue(CRITERE2) & evalue(WFILSPE) Order By Key ITB1
    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:IBS]TRI
      When 1 : # tri par article
        Filter [ITB] Where evalue(CRITERE2) & evalue(WFILSPE) Order By Key ITB0 Desc
      When 2 : # tri par alt
        Filter [ITB] Where evalue(CRITERE2) & evalue(WFILSPE) Order By Key ITB1 Desc
    Endcase
Endif

#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:LLC1] : Endif

nolign = 0

For [ITB]
  If mkstat = 0
    
      If NBLU = 1
         If CHGPAG=2 | CHGPAG=-2 : Raz [M:LLC1] : Endif
         NBLU = 2
      Endif
      If CHGPAG > 0
         If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
         NOL    += 1 
         nolign += 1
         If NOL=0 
             DEBITM = [F:ITB]ITMREF 
             DEBALT = [F:ITB]BOMALT
             DEBLLC = [F:ITB]LLC
         Endif
         FINITM = [F:ITB]ITMREF 
         FINALT = [F:ITB]BOMALT
         FINLLC = [F:ITB]LLC
      Else
         If NOL <= 0 : RETOUR=2 : Break : Endif
         NOL    -= 1 
         If NOL=MAXLIG-1 
             FINITM = [F:ITB]ITMREF 
             FINALT = [F:ITB]BOMALT
             FINLLC = [F:ITB]LLC
         Endif
         DEBITM = [F:ITB]ITMREF 
         DEBALT = [F:ITB]BOMALT
         DEBLLC = [F:ITB]LLC
      Endif
    
      [M:LLC1] = [F:ITB]
  Endif
Next
[M:LLC1]NBLIG = nolign

Filter [ITB]

Return

$LOAD_CRITERE2
If CRITERE2 <> ""
     CRITERE2 += "&"
Endif
CRITERE2 += CRITERE
Return

############################################################

# FQ 57754 Module Tronc commun GA 10/2009
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(9)<>2 End Endif

Call VALGTC(APPLI,"LLC") From SUBGTC

End

