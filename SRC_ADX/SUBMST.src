#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion du fichier MARSCT
##########################################################################################################
# Gestion des secteurs de marché                 Module CRM aout 2006
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEBUT"        : Gosub DEBUT
    When "SETBOUT"      : Gosub SETBOUT
    When "STATUT"       : Gosub STATUT
    When "FERME"        : Gosub FERME
    When "LIENS"        : Gosub LIENS
    When "RAZCRE"       : Gosub RAZCRE
    When "RAZDUP"       : Gosub RAZDUP
    When "INICRE"       : Gosub INICRE
    When "VERIF_CRE"    : Gosub VERIF_CRE
    When "CREATION"     : Gosub CREATION
    When "APRES_CRE"    : Gosub APRES_CRE
    When "VERIF_MOD"    : Gosub VERIF_MOD
    When "INIMOD"       : Gosub INIMOD
    When "MODIF"        : Gosub MODIF
    When "APRES_MOD"    : Gosub APRES_MOD
    When "AV_ANNULE"    : Gosub AV_ANNULE
    When "ANNULE"       : Gosub ANNULE
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER[BPR] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER[BPC] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS[BPA] : Endif
  If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
  If !clalev([F:ATB]) : Local File ATABLE [ATB] : Endif
  #
  Gosub INITFORMULE From SUBMSTB
  #
  # FGR 20/02/2008 : CREABTMST a été supprimé, mais l'appel ne l'avait pas été
  #Crée la tache batch de régénération des secteurs s'il est n'existe pas.
  #Call CREABTMST From SUBMSTB
Return

##########################################################################################################
$DEBUT
  Diszo [M:MST2]MSTSYN
Return

##########################################################################################################
$FERME
Return

##########################################################################################################
$SETBOUT
  # FGR 09/04/2010 : X3SUIVI63627 ajout du menu "2"
  If GUSRAUZ(1) = "" Then
    If REP = "" Then
      CHMEN += "GIN2"
    Endif
  Else
    If REP = "" Then
      CHMEN += "2"
      If instr(1, GUSRAUZ(1), 'G') Then
        CHMEN += "G"
      Endif
      If instr(1, GUSRAUZ(1), 'H') Then
        CHMEN += "IN"
      Endif
    Endif
  Endif
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return

##########################################################################################################
$STATUT
Local Integer IERROR

  If BOUT = "2" Then
    Call GENTRT_TEST_SECTEUR(IERROR) From SUBMSTB1
    If IERROR Then
      GMESSAGE = mess(648,177,1)
      GERR = 1     # Issue X3-61585 - 2018-04-19 by FGR : not 2
    Else
      GMESSAGE = mess(647,177,1)
      GERR = 2     # Issue X3-61585 - 2018-04-19 by FGR : not 1
    Endif
  Endif
Return

##########################################################################################################
$LIENS
  #---------------------------------------------------#
  #Lecture des clobs
  #---------------------------------------------------#
  Gosub LOADCLOB From SUBMSTB
  #Chargement du tableau des critère de définition d'un secteur.
  Gosub INITFORMULE From SUBMSTB
  Gosub LOAD_MDF From SUBMSTB
  #Chargement du tableau des affectations de représentants.
  Gosub LOAD_REP From SUBMSTB
  #
  Gosub REGROUPEMENT From SUBMSTB
  #
  Affzo [M:MST1]1-99
  Affzo [M:MST2]1-99
  Affzo [M:MST3]1-99
  Diszo [M:MST2]MSTSYN
Return

##########################################################################################################
$RAZCRE
  [M:MST1]TYPFULDES = "MST"
  Gosub INITFORMULE From SUBMSTB
Return

##########################################################################################################
$RAZDUP
Return

##########################################################################################################
$VERIF_CRE_MOD
  GOK=1
  Gosub VERIF_MDF From SUBMSTB
  If GOK < 1 Then
    OK = 0
    GERR = 2
    Return
  Endif
  Gosub REGROUPEMENT From SUBMSTB
Return

##########################################################################################################
$VERIF_CRE
  Gosub VERIF_CRE_MOD
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$INICRE
  [F:MST]NUMFULDES = [M:MST0]MARSCTNUM
  [M:MST1]NUMFULDES = [M:MST0]MARSCTNUM
Return

##########################################################################################################
$CREATION_MODIF
  # FGR 06/03/2009 : X3SUIVI52963 Texte traduisible
  # FGR 13/04/2010 : X3SUIVI63967 : SELSSP au lieu de MARSCT
  Call MAJTEXTRA([M:MST0]MARSCTAXX, "MARSCT", "MARSCTAXX", [M:MST0]MARSCTNUM, "") From ATEXTRA
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBMSTB
  If GOK < 1 Then
    Return
  Endif
  Gosub SAVE_MDF From SUBMSTB
  If GOK < 1 Then
    Return
  Endif
  Gosub SAVE_REP From SUBMSTB
  If GOK < 1 Then
    Return
  Endif
  Call GENTRT_DELTRT(0) From SUBMSTB1  # FGR 09/04/2010 : X3SUIVI63627
Return

##########################################################################################################
$CREATION
  Gosub CREATION_MODIF
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$APRES_CRE
  Affzo [M:MST2]1-99
Return

##########################################################################################################
$VERIF_MOD
  Gosub VERIF_CRE_MOD
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$INIMOD
Return

##########################################################################################################
$MODIF
  Gosub CREATION_MODIF
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$APRES_MOD
  Affzo [M:MST2]1-99
Return

##########################################################################################
$AV_ANNULE
  #Suppression des clobs
  Gosub DELCLOB From SUBMSTB
  If GOK < 1 Then
    Return
  Endif
  #Supprime tous les enregistrements associés au secteur de marché.
  Delete [MDF] Where [F:MDF]MARSCTNUM = [M:MST0]MARSCTNUM
  Delete [MRS] Where [F:MRS]MARSCTNUM = [M:MST0]MARSCTNUM
Return

##########################################################################################################
$ANNULE
  # FGR 03/03/2009 : X3SUIVI52963 Texte traduisible
  # FGR 13/04/2010 : X3SUIVI63967 : SELSSP au lieu de MARSCT
  Call SUPTEXTRA("MARSCT", "MARSCTAXX", [M:MST0]MARSCTNUM, "") From ATEXTRA
  Call GENTRT_DELTRT(0) From SUBMSTB1  # FGR 09/04/2010 : X3SUIVI63627
Return

##########################################################################################################
Subprog C_SCTREPITM(VALEUR)
Variable Char    VALEUR()

Local Integer IADINUM

  If VALEUR = "" Then
    End
  Endif
  IADINUM = 19 + GFAMCIA
  Read [ADI]CODE=IADINUM;VALEUR
  If fstat Then
    GMESSAGE = mess(83,123,1) #Valeur incorrect.
    GERR = 1
    mkstat = 2
    End
  Endif
End

##########################################################################################################
Subprog AM_SCTREPITM(VALEUR)
Variable Char    VALEUR()

Local Integer IADINUM

  IADINUM = 19 + GFAMCIA
  #Ecrit la famille commerciale de produit en clair dans le champs SCTITMCLA
  [M:MST3]SCTREPITM(nolign-1) = VALEUR
  If VALEUR = "" Then
    [M:MST3]SCTITMCLA(nolign-1) = ""
  Else
    Call GET_LIB(IADINUM, [M:MST3]SCTREPITM(nolign-1), [M:MST3]SCTITMCLA(nolign-1)) From CRM_UTIL
  Endif
  Affzo [M:MST3]SCTREPITM(nolign-1), SCTITMCLA(nolign-1)
End

##########################################################################################################
Subprog AS_MARSCTOPD(VALEUR)
Variable Integer VALEUR

Local Integer INOLIGN

  INOLIGN = nolign
  If INOLIGN-1 = 0 Then
    [M:MST2]MARSCTOPD(0)=1
    # FGR 17/09/2008 : MSTDEF apparaît "comme ça" ! Je garde ces lignes en cmt pour le moment, mais ne vois pas à quoi ça sert !
    #If [M:MST2]MSTSYN = "" Then
    #  [M:MST2]MSTDEF = "1"
    #  Affzo [M:MST2]MSTDEF
    #Endif
    mkstat = 2
  Else
    GMENLOC(1)=1
  Endif
End

##########################################################################################################
Subprog AM_MARSCTOPD(VALEUR)
Variable Integer VALEUR

  [M:MST2]MARSCTOPD(nolign-1) = VALEUR
  Gosub REGROUPEMENT From SUBMSTB
  Affzo [M:MST2]MSTSYN
End

##########################################################################################################
Subprog C_PARDEB(VALEUR)
Variable Char    VALEUR()

Local Char SZMESSAGE(250)
Local Integer IBRETOUR

  Raz SZMESSAGE
  IBRETOUR = 1
  Call CTRLPARENTHESE (VALEUR, 0, SZMESSAGE, IBRETOUR) From CRMUTIL150
  If IBRETOUR = 0 Then
    GMESSAGE = SZMESSAGE
    mkstat = 2
    End
  Endif
End

##########################################################################################################
Subprog AM_PARDEB(VALEUR)
Variable Char    VALEUR()

Local Char SZMESSAGE(250)
Local Integer IBRETOUR
Local Integer INBPARENTHESE
Local Char SZRESULT

  Raz SZMESSAGE
  IBRETOUR = 1
  INBPARENTHESE = 0
  Raz SZRESULT
  Call GETNBPARENTHESE (VALEUR, 0, INBPARENTHESE, SZRESULT, SZMESSAGE, IBRETOUR) From CRMUTIL150
  If IBRETOUR = 0 Then
    GMESSAGE = SZMESSAGE
    mkstat = 2
    End
  Endif
  [M:MST2]NBPARDEB(nolign-1) = INBPARENTHESE
  [M:MST2]PARDEB(nolign-1) = SZRESULT
  Gosub REGROUPEMENT From SUBMSTB
  Affzo [M:MST2]MSTSYN
End

##########################################################################################################
Subprog AM_MDFTAB(VALEUR)
Variable Char    VALEUR()

  [M:MST2]MARSCTFIE(nolign-1) = ""
  [M:MST2]MDFINDOK(nolign-1) = 0
  If VALEUR <> "" Then
    Read [ATB]CODFIC=VALEUR
    If fstat = 0 Then
      [M:MST2]MDFABRFIC(nolign-1) = [F:ATB]ABRFIC
    Else
      #Erreur lecture table des tables
      GMESSAGE = mess(558,177,1)
      mkstat = 2
    Endif
  Endif
  Affzo [M:MST2]MDFABRFIC
End

##########################################################################################################
Subprog AV_MARSCTFIE(VALEUR)
Variable Char    VALEUR()

  # FGR 18/04/2012 : X3SUIVI79830
  Raz GFMT
End

##########################################################################################################
Subprog AM_MARSCTFIE(VALEUR)
Variable Char    VALEUR()

Local Char SZVALEUR
Local Integer IVALEUR
Local Integer INOLIGN

  INOLIGN = nolign
  [M:MST2]MDFINDNUM(INOLIGN-1) = 0
  [M:MST2]MDFFIETYP(INOLIGN-1) = 0
  If VALEUR <> "" Then
    If [M:MST2]MDFTAB(INOLIGN-1) <> "" Then
      Read [ATB]CODFIC=[M:MST2]MDFTAB(INOLIGN-1)
      If fstat = 0 Then
        [M:MST2]MDFABRFIC(INOLIGN-1) = [F:ATB]ABRFIC
      Else
        [M:MST2]MDFABRFIC(INOLIGN-1) = ""
      Endif
    Endif
  Endif

  If VALEUR = "" or [M:MST2]MDFTAB(INOLIGN-1) = "" Then
    [M:MST2]MDFINDOK(INOLIGN-1) = 0
  Else
    Local File =[M:MST2]MDFTAB(INOLIGN-1) [XXX0]
    #
    If evalue("dim([F:XXX0]" + VALEUR + ")") > 1 Then
      [M:MST2]MDFINDOK(INOLIGN-1) = 1
    Else
      [M:MST2]MDFINDOK(INOLIGN-1) = 0
    Endif
    #
    SZVALEUR = "type([F:XXX0]" + VALEUR + ")"
    IVALEUR = evalue(SZVALEUR )
    Case IVALEUR
       When 1, 2, 4, 5, 6, 7, 9
         #Numerique
         [M:MST2]MDFFIETYP(INOLIGN-1) = 2
         [M:MST2]VALCODTYP(INOLIGN-1) = "DBC"
       When 3
         #date
         [M:MST2]MDFFIETYP(INOLIGN-1) = 3
         [M:MST2]VALCODTYP(INOLIGN-1) = "D"
       When Default
         #Alphanumerique
         [M:MST2]MDFFIETYP(INOLIGN-1) = 1
         [M:MST2]VALCODTYP(INOLIGN-1) = "A"
    Endcase
    Close Local File  [XXX0]
    #
    Read [ATZ]CODZONE=[M:MST2]MDFTAB(INOLIGN-1);VALEUR
    If fstat = 0 Then
      [M:MST2]VALCODTYP(INOLIGN-1) = [F:ATZ]CODTYP
      [M:MST2]VALLONG(INOLIGN-1) = [F:ATZ]LONG
      [M:MST2]VALNOLIB(INOLIGN-1) = [F:ATZ]NOLIB
      [M:MST2]VALTCT(INOLIGN-1) = ""
      [M:MST2]VALNOLIB(INOLIGN-1) = [F:ATZ]NOLIB
      [M:MST2]VALSUPP(INOLIGN-1) = ""
      [M:MST2]VALOPTION(INOLIGN-1) = ""
    Endif
  Endif
End

##########################################################################################################
Subprog AS_MDFINDNUM(VALEUR)
Variable Decimal VALEUR

  If [M:MST2]MDFINDOK(nolign-1) <> 1 Then
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog AS_MARSCTCND(VALEUR)
Variable Integer VALEUR

  GMENLOC(10) = 1
  # FGR 02/11/2009 : XUSUIVI59445
  If [M:MST2]MDFFIETYP(nolign-1) = 1 Then
    # Alphanumérique
    # Tous les types de conditions sont autorisés
  Elsif [M:MST2]MDFFIETYP(nolign-1) = 2 Then
    # Numérique
    # Les types :
    #      3 - Commence par
    #      4 - Contient
    #      5 - Se termine par
    # N'ont pas de sens pour un nombre
    GMENLOC(3) = 1
    GMENLOC(4) = 1
    GMENLOC(5) = 1
  Elsif [M:MST2]MDFFIETYP(nolign-1) = 3 Then
    # Date
    # Les types :
    #      3 - Commence par
    #      4 - Contient
    #      5 - Se termine par
    # N'ont pas de sens pour une date
    GMENLOC(3) = 1
    GMENLOC(4) = 1
    GMENLOC(5) = 1
  Endif
End

