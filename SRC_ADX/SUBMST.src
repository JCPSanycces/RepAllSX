###########################################################################################################
Subprog IB_MSTENA
End

##########################################################################################################
$TRTCOP
  #-----------------------------------------------------------#
  # Etiquette appelée depuis le traitement superviseur ACOPIE #
  # --------------------------------------------------------- #
  # Traitement de la copie d'une cible                        #
  #-----------------------------------------------------------#
  If [M]DOSORG = nomap Then
    Local File MARSCT [MST1]
    Local File MARDEF  [MDF1]
    Local File MARREPSEC [MRS1]
    Local File HD6CLOB [HD61]
  Else
    Local File =[M]DOSORG+".MARSCT" [MST1]
    Local File =[M]DOSORG+".MARDEF"  [MDF1]
    Local File =[M]DOSORG+".MARREPSEC" [MRS1]
    Local File =[M]DOSORG+".HD6CLOB" [HD61]
  Endif
  If [M]DOSDES = nomap Then
    Local File MARSCT [MST2]
    Local File MARDEF  [MDF2]
    Local File MARREPSEC  [MRS2]
    Local File HD6CLOB  [HD62]
  Else
    Local File =[M]DOSDES+".MARSCT" [MST2]
    Local File =[M]DOSDES+".MARDEF" [MDF2]
    Local File =[M]DOSDES+".MARREPSEC" [MRS2]
    Local File =[M]DOSDES+".HD6CLOB" [HD62]
  Endif
  OK = 1
  Look [MST2] MST0= TABLE
  If !fstat Then
    OK = 2
    Call AVERTIR([M]DOSDES-TABLE-mess(148,196,1),OK) From GESECRAN
    If OK <> 2 Then
     OK = 0
    Endif
  Endif
  If OK Then
    Call DEBTRANS From GLOCK
    Gosub TRT_COPIE
  Endif
  Close Local File [MST1], [MDF1], [MRS1], [HD61],[MST2], [MDF2], [MRS2], [HD62]
Return

##########################################################################################################
$TRT_COPIE
  #--------------------------------------------------#
  # Transaction de copie d'une cible                 #
  #--------------------------------------------------#
  GOK = 1
  Trbegin [MST2]
  #
  Delete [MDF2] Where MARSCTNUM=TABLE
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$"+[M]DOSDES+".MARDEF"-TABLE
    Goto ROLL_COPIE
  Elsif fstat Then
    GOK = 0
    Call RSTA("MDF2",TABLE) From GLOCK
    Goto AB_COPIE
  Endif
  #
  Delete [MRS2] Where MARSCTNUM=TABLE
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$"+[M]DOSDES+".MARREPSEC"-TABLE
    Goto ROLL_COPIE
  Elsif fstat Then
    GOK = 0
    Call RSTA("MRS2",TABLE) From GLOCK
    Goto AB_COPIE
  Endif
  #
  Delete [HD62] Where TYP="MST" and NUM=TABLE
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$"+[M]DOSDES+".HD6CLOB"-TABLE
    Goto ROLL_COPIE
  Elsif fstat
    GOK = 0
    Call RSTA("HD62",TABLE) From GLOCK
    Goto AB_COPIE
  Endif
  #
  Delete [MST2] Where MARSCTNUM=TABLE
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$"+[M]DOSDES+".MARSCT"-TABLE
    Goto ROLL_COPIE
  Elsif fstat Then
    GOK = 0
    Call RSTA("MST2",TABLE) From GLOCK
    Goto AB_COPIE
  Endif
  #
  If GOK = 1 Then
    Read [MST1]MST0=TABLE
    If !fstat Then
      [F:MST2] = [F:MST1]
      Write [MST2]
      If fstat Then
        GOK = 0
        Call FSTA("MST2") From GLOCK
        Goto AB_COPIE
      Endif
    Endif
  Endif
  If GOK = 1 Then
    Filter [MDF1] Where [F:MDF1]MARSCTNUM = TABLE
    For [MDF1]
      [F:MDF2] = [F:MDF1]
      Write [MDF2]
      If fstat Then
        GOK = 0
        Call FSTA("MDF2") From GLOCK
        Goto AB_COPIE
      Endif
    Next
    Filter [MDF1]
  Endif
  If GOK Then
    Filter [MRS1] Where [F:MRS1]MARSCTNUM = TABLE
    For [MRS1]
      [F:MRS2] = [F:MRS1]
      Write [MRS2]
      If fstat Then
        GOK = 0
        Call FSTA("MRS2") From GLOCK
        Goto AB_COPIE
      Endif
    Next
    Filter [MRS1]
  Endif
  If GOK Then
    Look [HD61]HD60=[M:MST1]NUMFULDES;[M:MST1]TYPFULDES
    If fstat Then
      Read [HD61]HD60=[M:MST1]NUMFULDES;[M:MST1]TYPFULDES
      [F:HD62] = [F:HD61]  # FGR 02/07/2013 : X3SUIVI90864 et pas [F:HD1]
      Write [HD62]
      If fstat Then
        GOK = 0
        Call FSTA("HD62") From GLOCK
        Goto AB_COPIE
      Endif
    Endif
  Endif
  Commit
Return

##########################################################################################################
#----- Abandon de la copie -----#
$AB_COPIE
  Rollback
Return

##########################################################################################################
#----- Nouvel essai si nécessaire -----#
$ROLL_COPIE
  Rollback
  Call ROLL From GLOCK
  If !GROLL Then
    Goto TRT_COPIE
  Endif
Return

