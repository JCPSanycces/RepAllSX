#<AdxTL>@(#)9.0.0.0 $Revision$     Gestion R觬es Workflow
# Appel du workflow avec envoi immédiat hors transaction trbegin/commit
Subprog MESSAGE(EVEN,OPER,CLE)
Value Char     EVEN
Value Char     OPER
Value Char     CLE 
Gosub MES
End

# Appel du workflow avec envoi immédiat à partir d'une transaction trbegin/commit
Subprog MESSTRANS(EVEN,OPER,CLE)
Value Char     EVEN
Value Char     OPER
Value Char     CLE 
Gosub MES
End

$MES
If left$(EVEN,3)="OBJ" & len(EVEN)=6
 TYPEVT = 2 : CODEVT = right$(EVEN,4)
Elsif left$(EVEN,2)="F_"
 TYPEVT = 3: CODEVT = right$(EVEN,3)
Elsif left$(EVEN,2)="R_"
 TYPEVT = 4: CODEVT = right$(EVEN,3)
Elsif left$(EVEN,2)="B_"
 TYPEVT = 5: CODEVT = right$(EVEN,3)
Elsif left$(EVEN,2)="A_"
 TYPEVT = 6: CODEVT = right$(EVEN,3)
Elsif left$(EVEN,2)="T_"
 TYPEVT = 7: CODEVT = right$(EVEN,3)
Elsif left$(EVEN,2)="I_"
 TYPEVT = 8: CODEVT = right$(EVEN,3)
Else
 TYPEVT = 1 : CODEVT = EVEN
Endif
Call WORKFLOW(TYPEVT,CODEVT,OPER,CLE) From AWRK
Return

# En 150, il faut utiliser le Subprog WORKFLOW() From AWRK
