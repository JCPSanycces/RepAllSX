#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque SIPAR6 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBPFI
mkstat = 0
zoncou = "NBPFI"
indice = 0
status = 1
zoncou = "NBPFI"
[M]NBPFI = 8
If varmode([M]NBPFI,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBPFI" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBPFI
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBPFI = nolign
   status = 75
   Call SAI_NBPFI(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone PFINUM1
mkstat = 0
zoncou = "PFINUM1"
indice = 0
If varmode([M]PFINUM1,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PFINUM1" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTNUM("PFI","!AB",[M]PFINUM1,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "PFINUM1" : GZNUM = 23268 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_PFINUM1([M]PFINUM1) From SUBSIP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PFINUM1" : GZNUM = 23268 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone PFINUM2
mkstat = 0
zoncou = "PFINUM2"
indice = 0
If varmode([M]PFINUM2,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PFINUM2" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTNUM("PFI","!AB",[M]PFINUM2,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "PFINUM2" : GZNUM = 23269 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_PFINUM2([M]PFINUM2) From SUBSIP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PFINUM2" : GZNUM = 23269 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

####################################
## Bloc liste 3
####################################
IMPTBL = 0

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBPFI(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBPFI
mkstat = 0
zoncou = "NBPFI"

## Zone INVDTALIB
mkstat = 0
zoncou = "INVDTALIB"
[M]INVDTALIB(indice) = SI_MES(97+nolign)

## Zone PFINUM
mkstat = 0
zoncou = "PFINUM"
If varmode([M]PFINUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "PFINUM" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTNUM("PFI","!ABC",[M]PFINUM(indice),"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "PFINUM" : GZNUM = 3660 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_PFINUM([M]PFINUM(indice)) From SUBSIP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "PFINUM" : GZNUM = 3660 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone NBPFI
mkstat = 0
zoncou = "NBPFI"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "SIPAR6"
Return

