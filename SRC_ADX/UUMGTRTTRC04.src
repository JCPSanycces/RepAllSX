#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################
# UUMGTRTTRC04         Migration Process            Module Common Data   #
#                                                                        #
#    Flow for Open item                                                  #
#                                                                        #
#            GACCDUDATE                                                  #
#                                                                        #
##########################################################################
#                                                                        #
#  Optimized Index for Migration                                         #
#                                                                        #
#   GACCDUDATE : CPY;ACCNUM;DUDLIG                                       #
#                                                                        #
#  Index to keep for Migration                                           #
#                                                                        #
#   GACCDUDATE : TYP;NUM;LIG;DUDLIG                                      #
#                                                                        #
#  Miscellaneous Informations :                                          #
#                                                                        #
#  - New V6 fields : BPAPAY/FIY/PER/CREDAT/CREUSR                        #
#  - Old V5 fields : AMTRPT/PAYRPT/TMPRPT                                #
#                                                                        #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTTRC04") From LECFIC
  Endif

  #Call RAZ_UUMGTRTTRC04(DOSSIER)
  Call MAJ_UUMGTRTTRC04(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

########################################################################
Subprog RAZ_UUMGTRTTRC04(DOSSIER)
Value Char DOSSIER

Local Integer ERR
If [F:ADS]MODULE(8)<>2 : End : Endif

#----- File naming...  -----#
Local Char WNAMDUDM
Call MIGTABNAME (DOSSIER,"GACCDUDATE",WNAMDUDM,ERR) From TRTMIG
If ERR : End : Endif

#----- Existence of renamed File...  -----#
If filinfo(filpath("FIL",WNAMDUDM,"fde",[F:ADS]DOSSIER),0) < 0 : End : Endif

#----- Deleting of records...  -----#
Call MIGTABRAZ (DOSSIER,"GACCDUDATE",ERR) From TRTMIG

Call MIGRAZKEY (DOSSIER,"UUMGTRTTRC04",ERR) From TRTMIG
End

########################################################################
Subprog MAJ_UUMGTRTTRC04(DOSSIER)
Value Char DOSSIER
Local Integer ERR

If [F:ADS]MODULE(8)<>2 :
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC04",3,ERR) From TRTMIG : End
Endif

#----- File naming...  -----#
Local Char WNAMDUDM
Call MIGTABNAME (DOSSIER,"GACCDUDATE",WNAMDUDM,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC04",7,ERR) From TRTMIG : End : Endif

#----- Existence of renamed File...  -----#
If filinfo(filpath("FIL",WNAMDUDM,"fde",[F:ADS]DOSSIER),0) < 0
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC04",3,ERR) From TRTMIG : End
Endif

#----- Starting process  -----#
Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC04",2,ERR) From TRTMIG

#-----  n°version
Local Char VERSION
Call MIGGETVERSION (DOSSIER,VERSION,ERR) From TRTMIG
If ERR : Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC04",7,ERR) From TRTMIG : End : Endif
If val(VERSION)>=GMIGX3VER60
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC04",3,ERR) From TRTMIG : End
Endif

Call ECR_TIME("UUMGTRTTRC04 Open items Process : Update GACCDUDATE") From DOSSUB
Call ECR_TRACE("UUMGTRTTRC04 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Files Updating where we will insert -----#
Gosub MIG_OUVRE From TRTMIG
Call MIGTABINIT (DOSSIER,"GACCDUDATE",ERR) From TRTMIG

#--------------- Opening of files  -----#
# X3 Files
If clalev([F:DUD]) = 0 :  Local File =DOSSIER+".GACCDUDATE"    [DUD]   : Endif    # Open item

# X3 Renamed File
If clalev([F:DUDM]) = 0 :  Local File =DOSSIER+"."+WNAMDUDM   [DUDM]  : Endif     # Open item

# X3 Commun File
If clalev([F:BPR])  = 0 : Local File =DOSSIER+".BPARTNER"    [BPR]   : Endif      # Business Partner

#-----  Declaration of Variables

# Variables to manage Fush intrcution
Local Char WTAB_DUD (100) (adxwrb)
Local Shortint WCPT_DUD

# Variables to Handle Loops Ruptures
Local Integer STOP, NB, ISVALID, NBCOMMIT, NBLUS
Local Char CRITERE(250),CRITERESPE(250),HINTSPE(30)
Local Integer NBMIGKEY : NBMIGKEY=2
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, STOP, CRITERE, NBCOMMIT

# Variables linked to the migration process
Local Integer PREMIG

#-----  Keys's reading  -----#
# Table's AMIGKEY reading to initialize ACLEx/STOP
Call MIGGETKEY (DOSSIER,"UUMGTRTTRC04",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
STOP=val(TABMIGKEY(2))

#-----  Link of BP's Table to delete "Read" Instruction
#-----  We don't have the line number in the key !
If dim([F:DUDM]BPAPAY)<=0 or func DOSSUB.ISHISTFOLD(DOSSIER)=1
 PREMIG = 0
# JHA Modif du 19/07:supp jointure fixe pour prendre tous les enregs
# Link [DUDM] With [BPR]BPR0~=[F:DUDM]BPRPAY
 Link [DUDM] With [BPR]BPR0=[F:DUDM]BPRPAY
&    As [LNK]
&    Order By Key CLE = [F:DUDM]ACCNUM
Else
 PREMIG = 1
# If clalev([F:LNK]) : Close File [LNK] : Endif
# If clalev([F:LNK]) = 0 :  Local File =DOSSIER+"."+WNAMDUDM   [LNK]  : Endif     # Open item
# Filter [LNK] Order By Key CLE=[F:DUDM]CPY;[F:DUDM]ACCNUM
 Filter [DUDM] Order By Key CLE=[F:DUDM]ACCNUM
Endif

# EP to add a criteria in the "where"
#----- Warning ! if it exist a filter on DUDDAT's field, the open items may be incomplete.
Local Char FLUX
Local Integer FILTRELIN
FLUX="UUMGTRTTRC04" : FILTRELIN=0 : Raz HINTSPE : Raz CRITERESPE : Gosub PE_CRITSEL From TRTMIG
If CRITERESPE="" : CRITERESPE="1=1" : Endif

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

$LOOP_TRC04
Raz NB
If STOP = 1
 STOP = 0
 CRITERE = "[F:DUDM]ACCNUM>"+TABMIGKEY(1)
Else
 CRITERE = "1=1"
Endif

Trbegin [DUD]
GOK = 1

If !PREMIG

 For [LNK]CLE(1) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)

  NBLUS+=1

  # EP to delete line
  If FILTRELIN
   FLUX="UUMGTRTTRC04" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
   If ISVALID=0 : Goto SUITE_BOUCLE : Endif
  Endif

  For [LNK]CLE
   # To Update GACCDUDATE table
   Gosub MAJ30_DUD
   If GOK<1 : Break 2 : Endif
  Next

  NB+=1
  If NB>GMAXUPDTRS
   TABMIGKEY(1) = num$([F:DUDM]ACCNUM)
   STOP=1
   Break
  Endif

 $SUITE_BOUCLE
 Next

Else

 For [DUDM]CLE(1) Hint Key=HINTSPE Where evalue(CRITERE) & evalue(CRITERESPE)

  NBLUS+=1

  # EP to delete line
  If FILTRELIN
   FLUX="UUMGTRTTRC04" : ISVALID=1 : Gosub PE_VERIFSEL From TRTMIG
   If ISVALID=0 : Goto SUITE_BOUCLE2 : Endif
  Endif

  For [DUDM]CLE
   # To Update GACCDUDATE table
   Gosub MAJ30_DUD
   If GOK<1 : Break 2 : Endif
  Next

  NB+=1
  If NB>GMAXUPDTRS
   TABMIGKEY(1) = num$([F:DUDM]ACCNUM)
   STOP=1
   Break
  Endif

 $SUITE_BOUCLE2
 Next
Endif

$FIN_BOUCLE
If GOK<1
 Rollback
 Call MIGSTKENDFLG (DOSSIER,"UUMGTRTTRC04",7,ERR) From TRTMIG : #7=Erreur
Else
 Flush [F:DUD]
 If fstat
  Call ECR_TRACE("File GACCDUDATE, Error ="-num$(fstat),1) From GESECRAN
  # To Display reference
  Gosub DUD_ERRTRA
  GOK=0 : Goto FIN_BOUCLE
 Endif
 # To Save values of key ACLEx/STOP in AMIGKEY table
 If STOP
   TABMIGKEY(2)=num$(STOP)
 Else
   Raz TABMIGKEY
 Endif
 Call MIGSTKKEY (DOSSIER,"UUMGTRTTRC04",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT+NB,ERR) From TRTMIG
 If ERR
  GOK=-1 : Goto FIN_BOUCLE
 Endif
 Commit
 NBCOMMIT+=NB
 Call MIGSTKPROGRESS (DOSSIER,"UUMGTRTTRC04",STOP,ERR) From TRTMIG
 If STOP
  Goto LOOP_TRC04
 Endif
Endif

Gosub UNSET_FIRST From TRTFIRST

Close Local File [DUD]
Close Local File [DUDM]
Close Local File [BPR]

#----- To Re-Update files where we will insert
Call MIGTABEND (DOSSIER,"GACCDUDATE",ERR) From TRTMIG

$FIN
Call MIGTRTEND (DOSSIER,"UUMGTRTTRC04") From TRTMIG
Call ECR_TIME("UUMGTRTTRC04 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB
End

#############################################################################################################
$MAJ30_DUD
#--- Transclass
[DUD] = [DUDM]

#-- Update FIY/PER Fields
#       Update FIY/PER Fields on Post-Migration UPOSMIGTRC04 Process

#-- Update new filed : BPAPAY (BP's Adress)
If !PREMIG
 [F:DUD]BPAPAY=[F:BPR]BPAADD
Elsif [F:DUD]BPAPAY=""
 If [BPR]BPRNUM<>[F:DUD]BPRPAY
  Read [BPR]BPR0=[F:DUD]BPRPAY : If fstat Raz [F:BPR] Endif
 Endif
 [F:DUD]BPAPAY=[F:BPR]BPAADD
Endif

Gosub WRI_DUD
Return

# Write Instruction
$WRI_DUD
# To Save reference
Gosub DUD_STK
WriteB [F:DUD]
If fstat
 Call ECR_TRACE("File GACCDUDATE, Error ="-num$(fstat),1) From GESECRAN
 # To Display reference
 Gosub DUD_ERRTRA
 GOK=0 : Return
Endif
Return

################################################
$DUD_STK
Call STK (WTAB_DUD,WCPT_DUD,[F:DUD]TYP-'/'-[F:DUD]NUM-'/'-num$([F:DUD]ACCNUM)) From TRTMIG
Return
##############################################################################################
$DUD_ERRTRA
Call ERRTRA (WTAB_DUD,WCPT_DUD,"File GACCDUDATE(TYP/NUM/ACCNUM)=")  From TRTMIG
Return


########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
Call MAJ_UUMGTRTTRC04(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
Call MAJ_UUMGTRTTRC04(APPLI)
End

