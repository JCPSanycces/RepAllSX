#<AdxTL>@(#)4.0.0.0 $Revision$
###################################################################################
# SUBSQHC    Gestion des devis.     Fonctionnalités CRM           6 juillet 2000
###################################################################################
# Issue 122156 - 20170322 by LD : bad adress of delivery

$SQHFROMOPP
Local Char SZPBY
Local Char SZISBPCBPP
Local Integer INBPOSTE
SZPBY = ""
ISBPCBPP = 0

[M:SQH0]QUODAT = date$                #Date du devis

If [M:SQH0]BPCORD <> ""
    Read [BPC] BPC0 = [M:SQH0]BPCORD
    If !fstat
        [M:SQH0]BPCNAM = [F:BPC]BPCNAM    #Nom complet client
        [M:SQH0]CHGTYP = [F:BPC]CHGTYP
        [M:SQH1]PRITYP = [F:BPC]PRITYP    #Type de prix
        # Issue 122156
#        # Initialisation du régime de taxe
#        Call INIT_REGIME([F:BPC]BPCINV, GSOCIETE, "C", [M:SQH1]VACBPR) From CPTSUB
        # End issue 122156
        # Initialisation des escomptes et agios
        Call INIT_ESCOMPTE([F:BPC]BPCNUM, GSOCIETE, "C", [M:SQH3]DEP) From CPTSUB
        # Initialisation du code condition de paiement
        Call INIPTE ([F:BPC]BPCPYR, [F:BPC]BPCINV, "C", [M:SQH3]PTE) From TRTX3

        If [F:BPC]BPCTYP = 4              #Il s'agit d'un prospect ou d'un client.
            SZISBPCBPP = "BPP"
        Else
            SZISBPCBPP = "BPC"
        Endif

        # Observation du prospect/client
        If !GIMPORT
           If len(vireblc([F:BPC]BPCREM,2)) & GERR=0
                GMESSAGE = [F:BPC]BPCREM
                GERR=2
            Endif
        Endif

#        #Eléments de facturation
#        INBPOSTE=10
#        Raz [M:SQH3]INVDTAAMT
#        Call SAISFOOT (3,"SQH3",INBPOSTE,[M:SQH0]CHGTYP,[M:SQH0]CUR, [M:SQH0]CUR, "OUI") From TRTVENELT
#        [M:SQH3]NBFAC = INBPOSTE

        If [M:SQH1]CUR = "" : [M:SQH1]CUR = GLOCALDEV : Endif
        [M:SQH0]CUR = [F:BPC]CUR          #Devise
        [M:SQH1]CUR = [F:BPC]CUR          #Devise

        Read [BPR]BPR0=[M:SQH0]BPCORD
        #LSE 27/01/2006 FQ 34352
        If fstat=0 [M:SQH0]LAN = [F:BPR]LAN Endif         #langue

        If SZISBPCBPP = "BPC"
            # FGR 06/02/2014 : X3SUIVI96513 (début) on prend l'adresse de livraison par défaut s'il y en a sinon, l'adresse par défaut
            #[M:SQH1]BPAADD = [F:BPC]BPAADD    #Adresse de livraison
            If [F:BPC]BPDADD <> "" Then
              [M:SQH1]BPAADD = [F:BPC]BPDADD
              # FGR 10/02/2014 : X3SUIVI96675 (début)
              Read [F:BPD]BPD0=[M:SQH0]BPCORD;[M:SQH1]BPAADD
              If fstat Then
                Raz [BPD]
                [M:SQH1]BPAADD = [F:BPC]BPAADD
              Else
                # Alimentation des champs relatifs au infos douanières
                [M:SQH0]EECICT = [F:BPD]EECICT
                If dim([M:SQH1]EECICT) > 0 Then
                  [M:SQH1]EECICT = [F:BPD]EECICT
                Endif
                [M:SQH0]ICTCTY = [F:BPD]ICTCTY
                If dim([M:SQH1]ICTCTY) > 0 Then
                  [M:SQH1]ICTCTY = [F:BPD]ICTCTY
                Endif
                [M:SQH0]FFWNUM = [F:BPD]FFWNUM
                [M:SQH0]FFWADD = [F:BPD]FFWADD
                If dim([M:SQH0]BPIEECNUM) > 0 Then
                  Call INIEECNUM([M:SQH0]BPCORD, [F:BPD]BPAADD, [F:BPC]BPCINV, [M:SQH0]BPIEECNUM, [M:SQH0]EECNUMCRY) From TRTVENDIV
                  [M:SQH0]EECLOC = [F:BPD]EECLOC
                Endif
              Endif
              # FGR 10/02/2014 : X3SUIVI96675 (fin)
            Else
              [M:SQH1]BPAADD = [F:BPC]BPAADD
            Endif
            # FGR 06/02/2014 : X3SUIVI96513 (fin)
        Endif
        If SZISBPCBPP = "BPP"
            # Issue 122156
            #[M:SQH1]BPAADD = ""               #Adresse de livraison
            [M:SQH1]BPAADD = [F:BPC]BPAADD    #Adresse de livraison
            # End issue 122156
        Endif

        # Issue 122156
        # Initialisation du régime de taxe
        Call INIT_REGIME([F:BPC]BPCINV, GSOCIETE, "C", [M:SQH1]VACBPR) From CPTSUB
        # End issue 122156

    Endif

    # -- Alimentation depuis le client facture
    # -- Lecture client facture lié au client pour alimentation
    # -- Si aucun client facture (prospect) on gardera les valeurs du client commande
    If [F:BPC]BPCINV <> [M:SQH0]BPCORD & [F:BPC]BPCINV <> ""
        Read [BPC]BPC0 = [F:BPC]BPCINV
        If !fstat
            [M:SQH0]CHGTYP = [F:BPC]CHGTYP
            [M:SQH1]PRITYP = [F:BPC]PRITYP
            # Initialisation des escomptes et agios
            Call INIT_ESCOMPTE([F:BPC]BPCNUM, GSOCIETE, "C", [M:SQH3]DEP) From CPTSUB
            If [M:SQH1]CUR = "" : [M:SQH1]CUR = GLOCALDEV : Endif
            [M:SQH0]CUR = [F:BPC]CUR          #Devise
            [M:SQH1]CUR = [F:BPC]CUR          #Devise
        Endif
    Endif

    #--> init. du tableau des éléments de facturation (à la fin, une fois que ttes les zones st garnies)
    INBPOSTE=dim([M:SQH3]INVDTA)
    Raz [M:SQH3]INVDTAAMT
    Call STRUFOOT (3,"SQH3",INBPOSTE,[M:SQH0]CHGTYP,[M:SQH0]CUR, [M:SQH0]CUR, "OUI") From SUBSFIT
    [M:SQH3]NBFAC = INBPOSTE
    #--CPO 93221 Création de devis depuis une affaire
    #--Comme on ne passe pas par l'AM_BPCORD
    #--(l'appel est fait dans RAZCRE mais la condition de début n'est pas remplie => on sort)
    #--Il faut appeler le sous-pro d'init des valeurs depuis les valeurs par défaut client etc
    Call NEW_SFIT ("M","SQH3",[M:SQH0]CUR,[F:BPC]BPCINV,[M:SQH0]BPCORD,[M:SQH0]QUODAT) From SUBSFIT
    #--/

Endif

Read [OPP] OPP0 = [M:SQH1]PJT
If !fstat
    GSZSQHFROMOPPRAZCRE = [F:OPP]OPPNUM
    [M:SQH0]SALFCY = [F:OPP]SALFCY            #Site
    # 71065 : PJT
    #[M:SQH1]PJTCLA = left$([F:OPP]OPPDES, 45) #Nom complet affaire.
    # 71065 : PJT
    SZPBY = num$([F:OPP]OPPSUC)
    [M:SQH1]PBYPRC = val(SZPBY)       #Taux de probabilité
Endif

If SZISBPCBPP = "BPP"
    [M:SQH1]STOFCY = GFCYDEF(7)       #Site d'expédition
    [M:SQH1]BPDNAM = ""                         #Nom complet adresse de livraison
Endif

# FGR 02/02/2012 X3SUIVI79420 (début) Fait au début de SUBSQHA.$RAZCRE
#LSE 24/05/2005 initialisation société
#If [M:SQH0]SALFCY <> ""
#    #Call GETDEV([M:SQH0]SALFCY) From DEVSUB
#    Call GETCPY([M:SQH0]SALFCY,"SLT",1,GFLAG) From TRTX3CPT
#Endif
  # FGR 02/02/2012 X3SUIVI79420 (fin)

If SZISBPCBPP = "BPC"
    #-------------------------------------------------------#
    # Lecture Client livré   : Alimentation du nom client   #
    #-------------------------------------------------------#
    Filter [BPD] Where [F:BPD]BPCNUM = [M:SQH0]BPCORD & [F:BPD]ENAFLG=2
    Read [BPD]BPD0 = [M:SQH0]BPCORD;[M:SQH1]BPAADD
    If fstat = 0
        [M:SQH1]BPDNAM = [F:BPD]BPDNAM       #Nom complet adresse de livraison

        If [F:BPD]STOFCY <> ""
            Read [FCY]FCY0=[F:BPD]STOFCY     #Site d'expédition
            If !fstat & [F:FCY]LEGCPY=GSOCIETE
                [M:SQH1]STOFCY = [F:BPD]STOFCY
            Endif
        Endif

        [M:SQH1]DAYLTI = [F:BPD]DAYLTI       #Délai de livraison
        If [F:BPD]VACBPR<>"" [M:SQH1]VACBPR = [F:BPD]VACBPR Endif
    Else
         Read [BPD]BPD0 First
         If fstat = 0
            [M:SQH1]BPAADD = [F:BPD]BPAADD       #Adresse de livraison
            [M:SQH1]BPDNAM = [F:BPD]BPDNAM       #Nom complet adresse de livraison

            If [F:BPD]STOFCY <> ""               #Site d'expédition
                Read [FCY]FCY0=[F:BPD]STOFCY
                If !fstat & [F:FCY]LEGCPY=GSOCIETE
                    [M:SQH1]STOFCY = [F:BPD]STOFCY
                Endif
            Endif

            [M:SQH1]DAYLTI = [F:BPD]DAYLTI       #Délai de livraison
            If [F:BPD]VACBPR<>"" [M:SQH1]VACBPR = [F:BPD]VACBPR Endif
         Else
            [M:SQH1]BPAADD = ""                  #Adresse de livraison
         Endif
    Endif
    Filter [F:BPD]
Endif

  # ------------------------------------
  # FGR 14/02/2012 : X3SUIVI79621 (début)
  If clalev([M:ADB1]) Then
    [M:ADB1]CNTNAM = [F:OPP]OPPMCN
  Endif
  # FGR 14/02/2012 : X3SUIVI79621 (fin)
  # ------------------------------------

#LSE 30/05/2006 FQ36317 Pas d'initialisation adresse livrée
# Alimentation code adresse (client livré) dans [M:ADB2] pour saisie adresse libre
If dim([M:ADB2]BPAADD) > 0
    [M:ADB2]BPAADD    = [M:SQH1]BPAADD
    #LSE 04/12/2006 Erreur d'affectation
    #LSE 15/01/2007 FQ39259
    #[M:ADB2]CNTNAM =[M:SQH1]BPDNAM
    [M:ADB2]BPRNAM=[M:SQH1]BPDNAM
    If [M:ADB2]BPAADD<>""
        # Recherche s'il y a un contact pour l'adresse de livraison
        Call RECH_CNTNAM([M:SQH0]BPCORD, [M:ADB2]BPAADD, [M:ADB2]CNTNAM) From TRTVENDIV
    Endif

Endif


GBPCNUM=[M:SQH0]BPCORD

If [M:SQH1]PRITYP = 0
    [M:SQH1]PRITYP = 1
Endif

Affzo [M:SQH0]1-99
Affzo [M:SQH1]1-99
Affzo [M:SQH3]1-99
Return

############################################################
# Raffraichissement de l'affaire
############################################################
$COMEBACKTOOPP

If type(GSZSQHFROMOPPRAZCRE) > 0
    If GSZSQHFROMOPPRAZCRE = "" : Return : Endif
Else
    Return
Endif

Read [OPP] OPP0 = GSZSQHFROMOPPRAZCRE
If fstat : Return : Endif

[M:OPP0] = [F:OPP]
[M:OPP1] = [F:OPP]
[M:OPP2] = [F:OPP]
[M:OPP3] = [F:OPP]
[M:OPP4] = [F:OPP]
[M:OPP5] = [F:OPP]

# Issue 122156
#Gosub LIENS From SUBOPP
Gosub LIENS From SUBOPPA
# End issue 122156

Affzo [M:OPP0]1-99
Affzo [M:OPP1]1-99
Affzo [M:OPP2]1-99
Affzo [M:OPP3]1-99
Affzo [M:OPP4]1-99
Affzo [M:OPP5]1-99
Return

