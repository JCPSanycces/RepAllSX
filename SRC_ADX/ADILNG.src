#<AdxTL>@(#)11.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Raz GNBMASKOUV
Call TRAITE_CHAR(VALEUR,PARAM,"","ADILNG","ADILNG",4,"") From GTRAITE
End

#-----------------------------#
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "EXEC"        : Gosub EXEC
 When "DEBUT"       : Gosub DEBUT
 When "FIN"         : Gosub FIN
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "SETBOUT"     : Gosub SETBOUT
 When "AP_CHOIX"    : Gosub AP_CHOIX
 When "CONTROLE"    : Gosub CONTROLE
Endcase
Return

#-----------------------------#
$INIT
If clalev([F:ADV])=0 : Local File ATABTAB [ADV] : Endif
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
If clalev([F:ACC])=0 : Local File ACCES   [ACC] : Endif
Local File AMSKZON [AMZ9]
Local Mask ADILNG [ADI]
Link [ADV] With
& [ACC]CODACC=GUSER;ACS,
& [AXX]AXX0="ATABTAB";"LNGDES";GLANGUE;NUMCAR;""
& As [ADV_]
Local Libelle TBTAB(1..5000)
Local Integer NUMADI , OKMSK , RW
Local Char    PARADI(80) , MASQUE(GLONAMK) , TYPADI(GLONATY)
Local Char    APPLI(GLONADS)
TYPADI = "ADI"
Return

#-----------------------------#
$DEBUT
Local Integer STAT
Call EXISTE_ADX("","","SUBADVB",STAT) From ORDSYS
Gosub CHARGE
REP = ""
Gosub VERROU
Return

#-----------------------------#
$FIN
If VERROU
 Unlock =SYMBOLE
Endif
Return
    
#-----------------------------#
$CHARGE
Raz [M]
nolign = 0
For [ADV_]CODE Where [F:ACC]MODIF=2
 nolign += 1
 [M] = [F:ADV]
 [M]LIBEL(nolign-1) = [F:AXX]TEXTE
 [M]OLIB (nolign-1) = [F:AXX]TEXTE
Next
[M]NBLIG = nolign
[M]SPECIF = STAT
Affzo
If dim([M]LNGFLG)>0
 For I=1 To [M]NBLIG
  If [M]LNGFLG(I-1)<>2
   Grizo LNG(I-1)
  Else
   Actzo LNG(I-1)
  Endif
 Next I
Endif
Return

#-----------------------------#
$SETBOUT
If REP<>"M"
 Call VIREBOUT(CHBOU,"O") From GOBJET
Endif
If !VERROU
 IMGFLG(3) = 1 : # Cadenas
Else
 IMGFLG(3) = 0
Endif
Return

#-------------------------------#
$AP_CHOIX
Case REPONSE
 When GSTACLK+3
  Gosub VERROU
  If VERROU
   Gosub CHARGE
  Endif
Endcase
Return

#-----------------------------#
$APRES_MODIF
If !VERROU
 Call ERREUR(mess(10,100,1)) From GESECRAN : # Modification en cours sur un autre poste
 mkstat = 2 : Return 
Endif
REP = "M"
Return

#-----------------------------#
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Endif
Return

#-----------------------------#
$VERROU
SYMBOLE = "ADILNG"
Lock =SYMBOLE With lockwait=0
If fstat  
 VERROU = 0
Else 
 VERROU = 1
Endif
Return

#-----------------------------#
$EXEC
Call DEBTRANS From GLOCK
Gosub TR1
If sum(TBTAB)
 OK = 2 : Call OUINON(mess(144,133,1),OK) From GESECRAN
 If OK=2
  Gosub VALMSK
  FIN = 1
  TRA = 1
 Endif
Endif
Return

#-----------------------------#
$TR1
GOK = 1
Raz TBTAB
Trbegin [ADV]
 For nolign=1 To [M]NBLIG
  Readlock [ADV]CODE = [M]NUMTAB(nolign-1)
  If fstat=1
   GOK = -1 : GLOCK = "ATABTAB"-num$([M]NUMTAB(nolign-1))
   Break
  Endif
  RW = 0
  If [F:ADV]ACS   <>[M]ACS(nolign-1)    : RW = 1 : Endif
  If [F:ADV]CODACT<>[M]CODACT(nolign-1) : RW = 1 : Endif
  If [F:ADV]DEPNUM<>[M]DEPNUM(nolign-1) : RW = 1 : Endif
  If [M]LIBEL(nolign-1)<>[M]OLIB(nolign-1)
   Readlock [AXX]AXX0 = "ATABTAB";"LNGDES";GLANGUE;num$([F:ADV]NUMTAB);""
   If fstat=1
    GOK = -1 : GLOCK = "$ATEXTRA ATABTAB LNGDES"-GLANGUE-num$([F:ADV]NUMTAB) : Break
   Endif
   [F:AXX]TEXTE = [M]LIBEL(nolign-1)
   Rewrite [AXX]
   If fstat
    GOK = 0 : Call FSTA("AXX") From GLOCK : Break
   Endif
  Endif
  If [F:ADV]LNG<>[M]LNG(nolign-1)
   TBTAB([F:ADV]NUMTAB) = 1
   RW = 1
  Endif
  If RW
   [F:ADV] = [M]
   Rewrite [ADV]
   If fstat
    GOK = 0 : Call FSTA("ADV") From GLOCK : Break
   Endif
  Endif
 Next nolign
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

#-----------------------------#
$VALMSK
Call OUVRE_TRACE(mess(144,133,1)) From LECFIC : # Revalidation des écrans
APPLI = nomap
Gosub OUVFIC From VALMSKLEC
For [AMZ9]CODTYP(2) Where CODTYP=TYPADI
 MASQUE = [F:AMZ9]CODMSK
 OKMSK  = 0
 For [AMZ9]CODTYP
  Read [AMP]CODPAR = 1;MASQUE;[F:AMZ9]CODZON;TYPADI
  If !fstat
   PARADI = [F:AMP]VALPAR
   If find(left$(PARADI,1),'"',"'")
    PARADI = seg$(PARADI,2,len(PARADI)-1)
   Endif
   NUMADI = val(PARADI)
   If NUMADI<>0 & TBTAB(NUMADI)
    OKMSK = 1 : Break
   Endif
  Endif
 Next
 If OKMSK
  Call VALID(MASQUE,APPLI,1,GLANGUE,1,OK) From VALMSK
 Endif
Next
Call FERME_TRACE From LECFIC
Return

#-----------------------------#
Subprog AS_LIBEL(VALEUR)
Variable Char    VALEUR()
If [M]SPECIF
 Local Char    ACTION(20)
 Local Integer NUMTAB , OK
 NUMTAB = [M]NUMTAB(nolign-1)
 OK     = 1
 ACTION = "AS_LIBEL"
 Gosub ACTION From SUBADVB
 If !OK
  mkstat = 2
 Endif
Endif
End

Subprog AS_LNG(VALEUR)
Variable Decimal VALEUR
If [M]LNGFLG(nolign-1)<>2
 mkstat = 2 : End
Endif
End

Subprog C_LNG(VALEUR)
Variable Decimal VALEUR
If VALEUR>GLONADI
 GMESSAGE = mess(122,123,1)-"("+num$(GLONADI)+")" : # Longueur trop grande
 mkstat = 2 : End
Endif
If VALEUR<[M]LNG(nolign-1)
 Local Integer LNGMAX
 LNGMAX = 0
 For [ADI]CODE Where NUMTAB=[M]NUMTAB(nolign-1)
  LNGMAX = max(LNGMAX,len([F:ADI]CODE))
 Next
 If LNGMAX>VALEUR
  GMESSAGE = mess(146,133,1)-num$(LNGMAX) : # La table contient des codes de longueur
  mkstat = 2 : End
 Endif
Endif
End


