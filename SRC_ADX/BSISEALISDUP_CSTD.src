######################################################################################################
# Module        : Finance
# Description   : Manages duplicate class for search term list (Class BSISEALIS)
######################################################################################################
# Updates       :
# Date          |Author |Version| Description
######################################################################################################

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case CURPRO
    When "CPYNEW"
      Case [L]ARULE
        When "CONTROL"   : Gosub NEW_CONTROL
      Endcase
    When "BANNEW"
      Case [L]ARULE
        When "CONTROL"   : Gosub NEW_CONTROL
      Endcase
    When "FILFMTNEW"
      Case [L]ARULE
        When "CONTROL"   : Gosub NEW_CONTROL
      Endcase
    When Default
  Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_DUPLICATE"  : Gosub MET_DUPLICATE
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return


####################################################################

$NEW_CONTROL
  If this.CPYNEW <> ""
    If func CTRL_EXIST_SEALIS(this.CPYNEW,this.BANNEW,this.FILFMTNEW) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("SEALIS",mess(45,7779,1)-":"-this.CPYNEW+"/"+this.BANNEW+"/"+this.FILFMTNEW,[V]CST_AERROR)
    Endif
  Endif
Return


####################################################################

$MET_DUPLICATE
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Char WERR(250)

  ASTATUS = fmet this.ADELETEERROR("")
  If this.CPYNEW <> ""
    ASTATUS = fmet this.ASETERROR("",mess(9,7983,1),[V]CST_AINFO)
    If func CTRL_EXIST_SEALIS(this.CPYNEW,this.BANNEW,this.FILFMTNEW) = [V]CST_ATRUE
      ASTATUS = fmet this.ASETERROR("BSISEALISNEW",mess(45,7779,1)-":"-this.CPYNEW+"/"+this.BANNEW+"/"+this.FILFMTNEW,[V]CST_AERROR)
      WRET_VALUE = [V]CST_AERROR
    Else
      If func COPY_SEALIS(this.CPY,this.BAN,this.FILFMT,this.CPYNEW,this.BANNEW,this.FILFMTNEW,WERR) = [V]CST_AERROR
        ASTATUS = fmet this.ASETERROR("",mess(9,7983,1)-":"-mess(9,2007,1)-this.CPYNEW+"/"+this.BANNEW+"/"+this.FILFMTNEW-WERR,[V]CST_AERROR)
        WRET_VALUE = [V]CST_AERROR
      Else
        ASTATUS = fmet this.ASETERROR("",mess(9,7983,1)-":"-mess(7,2007,1)-this.CPYNEW+"/"+this.BANNEW+"/"+this.FILFMTNEW,[V]CST_AINFO)
        WRET_VALUE = [V]CST_AOK
      Endif
    Endif
  Else
    ASTATUS = fmet this.ASETERROR("",mess(141,105,1),[V]CST_AERROR)
    WRET_VALUE = [V]CST_AERROR
  Endif
  ARET_VALUE = WRET_VALUE
Return

Funprog CTRL_EXIST_SEALIS(WCPY,WBAN,WFILFMT)
Value Char WCPY
Value Char WBAN
Value Char WFILFMT

  Local Integer WOK : WOK = [V]CST_AFALSE
  If WCPY <> ""
    Local File BSISEALIS [BSILIS]
    Read [BSILIS]BSILIS0 = WCPY;WBAN;WFILFMT
    If !fstat
      WOK = [V]CST_ATRUE
    Endif
    LogicClose File [BSILIS]
  Else
    WOK = [V]CST_AFALSE
  Endif
End WOK

Funprog COPY_SEALIS(WCPY,WBAN,WFILFMT,WCPY_NEW,WBAN_NEW,WFILFMT_NEW, WERR)
Value Char WCPY
Value Char WBAN
Value Char WFILFMT
Value Char WCPY_NEW
Value Char WBAN_NEW
Value Char WFILFMT_NEW
Variable Char WERR
  Local Integer WOK : WOK = [V]CST_AOK
  Local File BSISEALIS [BSILIS]
  Local File BSISEALIS [BSILIS2]
  Local File BSISEALISD [BSILISD]
  Local File BSISEALISD [BSILISD2]
  WERR = ""

  Trbegin [BSILIS2], [BSILISD2]

  Read [BSILIS]BSILIS0 = WCPY;WBAN;WFILFMT
  If !fstat
    [BSILIS2]       = [BSILIS]
    [BSILIS2]CPY    = WCPY_NEW
    [BSILIS2]BAN    = WBAN_NEW
    [BSILIS2]FILFMT = WFILFMT_NEW
    Write [BSILIS2]
    If fstat
      WOK = [V]CST_AERROR
      WERR = "BSISEALIS ("+mess(1,7983,1)+")"
    Endif
  Else
    WOK = [V]CST_AERROR
    WERR = "BSISEALIS ("+mess(7,7983,1)+")"
  Endif

  If WOK = [V]CST_AOK
    Filter [BSILISD] Where CPY = WCPY and BAN = WBAN and FILFMT = WFILFMT
    For [BSILISD]
      [BSILISD2]       = [BSILISD]
      [BSILISD2]CPY    = WCPY_NEW
      [BSILISD2]BAN    = WBAN_NEW
      [BSILISD2]FILFMT = WFILFMT_NEW
      Write [BSILISD2]
      If fstat
          WOK = [V]CST_AERROR
          Break
      Endif
    Next
    Filter [BSILISD]
  Endif

  If WOK = [V]CST_AERROR
    If WERR = "" : WERR = "BSISEALISD ("+mess(3,40,1)-num$([BSILISD2]LIN)+")" : Endif
    Rollback
  Else
    Commit
  Endif

  LogicClose File [BSILISD2]
  LogicClose File [BSILISD]
  LogicClose File [BSILIS2]
  LogicClose File [BSILIS]
End WOK

