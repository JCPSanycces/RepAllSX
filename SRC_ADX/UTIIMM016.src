#<AdxTL>@(#)4.0.0.0 $Revision$
###########################################################################################
# MODIFIE PAR : GBO
# LE          : 09 Septembre 2010 11:48:59
# Moulinette pour mettre û  jour la liste gauche des types d'ûˋcriture
# FQ66710
# FQ68628
###########################################################################################
 Local Char DOSSIER(30)
 DOSSIER = nomap
 Call SAIDOS(DOSSIER,"") From SAIDOS
 If DOSSIER<>""
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTIIMM016: Modification de la liste gauche des types d'ûˋcriture") From LECFIC
  Call EXE_UTIIMM016(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
End

 Subprog EXE_UTIIMM016(APPLI)
 Value Char APPLI
 If clalev([F:ZAOL]) : Close Local File [ZAOL] : Endif
 Local File =APPLI+".AOBJLST" [ZAOL]
  Call ECR_TRACE("UTIIMM016: Process Start on : "+APPLI,0) From GESECRAN

  Call DEBTRANS From GLOCK
  Gosub TR_UTIIMM016

  Call ECR_TRACE("UTIIMM016: Process End on : "+APPLI,0) From GESECRAN

 End

########################################
#### Corps de la moulinette - dûˋbut ####
########################################
$TR_UTIIMM016
  Trbegin [ZAOL]
  
  Read [F:ZAOL]AOL0="TPE"
  If fstat
   Call ECR_TRACE("Error : The TPE object doesn't exist.",-1) From GESECRAN
   GOK=0 : Goto AB_UTIIMM016
  Endif 
  Raz [F:ZAOL]
  [F:ZAOL]ABREV     = "TPE"
  [F:ZAOL]DELDEF    = 1
  [F:ZAOL]NBSEL     = 5

  [F:ZAOL]SELEXP(0) = "string$([F:TPE]CPY='',mess(36,7770,1))+string$([F:TPE]CPY<>'',[F:CPY]CPY)"
  [F:ZAOL]SELEXP(1) = "string$([F:TPE]DPRPLN=0,mess(16,3101,1))+string$([F:TPE]DPRPLN>0,mess([F:TPE]DPRPLN,3101,1))"
  [F:ZAOL]SELEXP(2) = "string$([F:TPE]ACEGRP='',mess(103,7778,1))+string$([F:TPE]ACEGRP<>'',[F:TPE]ACEGRP)"
  [F:ZAOL]SELEXP(3) = ""
  [F:ZAOL]SELEXP(4) = ""

  [F:ZAOL]SELFIC(0) = ""
  [F:ZAOL]SELFIC(1) = ""
  [F:ZAOL]SELFIC(2) = ""
  [F:ZAOL]SELFIC(3) = "TYPACE"
  [F:ZAOL]SELFIC(4) = "ATEXTRA"

  [F:ZAOL]SELINT(0) = 1343 
  [F:ZAOL]SELINT(1) = 33972
  [F:ZAOL]SELINT(2) = 616
  [F:ZAOL]SELINT(3) = 34014
  [F:ZAOL]SELINT(4) = 8

  [F:ZAOL]SELTYP(0) = "A"
  [F:ZAOL]SELTYP(1) = "A"
  [F:ZAOL]SELTYP(2) = "A"
  [F:ZAOL]SELTYP(3) = ""

  [F:ZAOL]SELZON(0) = ""
  [F:ZAOL]SELZON(1) = ""
  [F:ZAOL]SELZON(2) = ""
  [F:ZAOL]SELZON(3) = "ACETYP"
  [F:ZAOL]SELZON(4) = "TEXTE"
  
  Rewrite [F:ZAOL]
  
  If fstat
   GOK=0
   Call ECR_TRACE("   Error Rewrite [F:ZAOL] fstat="+num$(fstat),1) From GESECRAN
  Else
   Call ECR_TRACE("   Left list of the TPE object modified",0) From GESECRAN
  Endif
  
  If !GOK Then
    Goto AB_UTIIMM016
  Else
    Commit
  Endif

  Call VALFEN(APPLI,"TPE") From SUBAOB  

Return

$AB_UTIIMM016
 Rollback
Return
########################################
#### Corps de la moulinette - fin ######
########################################

#######################################################################
# Pour exûˋcution depuis passage de patch
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI


 If filinfo(filpath("FIL","AOBJLST","fde",APPLI),0) < 0 : End : Endif

  Call EXE_UTIIMM016(APPLI)
End

#######################################################################
# Pour exûˋcution depuis dosmajx (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI


 If filinfo(filpath("FIL","AOBJLST","fde",APPLI),0) < 0 : End : Endif

  Call EXE_UTIIMM016(APPLI)
End
