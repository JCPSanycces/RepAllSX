######################################################################################
Subprog D_VCRNUM(VALEUR)
Variable Char    VALEUR()
End


######################################################################################
Subprog IB_VCRNUM
#----------------------------------#
# Initialisation des boutons       #
# -------------------------------- #
# B2  Saisie ordre de ss-traitance #
# -------------------------------- #
Raz GBOUT2,GBOUT3
# GBOUT1 réservé au type de données VCR
GBOUT2=mess(643,197,1)-[M:PWI0]VCRNUM
End


