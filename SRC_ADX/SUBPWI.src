#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion objet PWI
# SUBPWI : Consultation des en cours d'EO WIPCOST
# Gestion des masque PWI0 - PWI8 (PWI5 et PWI6 n'existent pas)
# l'objet porte sur la table MFGWIP [MWH]
######################################################################################
## Etiquette ajoutée par le superviseur (Objet PWI) 22/11/2010 16:06:30 (CCC)
######################################################################################
$ACTION
Case ACTION
 When "FILTRE"   Gosub FILTRE
 When "FILGAUCHE"   Gosub FILGAUCHE
 When "LIENS"    Gosub LIENS
 When "OUVRE"    Gosub OUVRE
 When "SETBOUT"  Gosub SETBOUT
 When Default
Endcase
Return

# JFL - 11/09/06 - correction bug 37598
$GESTUN
# si je viens de la consultation des pièces comptables (via tunnel)
If GTUNCPT(4)=1
 N=0
# modif JFL 26/09/08 suite à une demande de Gilles LEFEBVRE
# For [MWI] Where [F:MWI]JOUNUM=[M:PCE2]NUM(NOLIGN2-1) and [F:MWI]JOUTYP=[M:PCE2]TYP(NOLIGN2-1) and [F:MWI]MFGFCY=[M:PCE2]FCYLIN(NOLIGN2-1)
 For [MWI] Where [F:MWI]JOUNUM=[M:PCE2]NUM(NOLIGN2-1) and [F:MWI]JOUTYP=[M:PCE2]TYP(NOLIGN2-1)
  If(!find([F:MWI]VCRNUM, TABNUM(1..N)))
   N=N+1
   TABNUM(N) = [F:MWI]VCRNUM
  Endif
  If N>=dim(TABNUM) : Call AVERTIR(mess(26,100,1), R) From GESECRAN : Break : Endif
 Next
 NBNUM=N
Elsif GTUNCPT(1)=1 # consultation de comptes
 N=0
# modif JFL 26/09/08 suite à une demande de Gilles LEFEBVRE
# For [MWI] Where [F:MWI]JOUNUM=[M:CPT2]NUM(NOLIGN2-1) and [F:MWI]JOUTYP=[M:CPT2]TYP(NOLIGN2-1) and [F:MWI]MFGFCY=[M:CPT2]FCYLIN(NOLIGN2-1)
 For [MWI] Where [F:MWI]JOUNUM=[M:CPT2]NUM(NOLIGN2-1) and [F:MWI]JOUTYP=[M:CPT2]TYP(NOLIGN2-1)
  If(!find([F:MWI]VCRNUM, TABNUM(1..N)))
   N=N+1
   TABNUM(N) = [F:MWI]VCRNUM
  Endif
  If N>=dim(TABNUM) : Call AVERTIR(mess(26,100,1), R) From GESECRAN : Break : Endif
 Next
 NBNUM=N
Endif
Return

# JFL - 11/09/06 - correction bug 37598
$FILTRE
If GTUNCPT(4)=1
 FILTSUP = "find([F:MWH]VCRNUM, [L]TABNUM(1..nbnum))" # bug 37598 - 08/09/06
Elsif GTUNCPT(1)=1 # consultation de comptes
 FILTSUP = "find([F:MWH]VCRNUM, [L]TABNUM(1..nbnum))" # bug 37598 - 08/09/06
Endif
Return

$FILGAUCHE
Raz GBIDI1
Call ADDCRIT(FILGAUCHE,GBIDI1,"","VCRTYP=36","&") From GOBJSUB
Return

$OUVRE
#If GMODU(8)=2 : # Module GP actif
#   Gosub OPEN_FILES_MFG From MFGLIB
#Endif
If clalev([F:ITF])=0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:TCM])=0 : Local File TABCOSTMET [TCM] : Endif
If clalev([F:MFC])=0 : Local File MFGCOST    [MFC] : Endif
If clalev([F:ITC])=0 : Local File ITMCOST    [ITC] : Endif
If clalev([F:MCN])=0 : Local File MFCNAT     [MCN] : Endif
If clalev([F:ICN])=0 : Local File ITCNAT     [ICN] : Endif

If GMODU(6)=2 : # Module Achats actif
   Gosub OPEN_FILES_SCO From SCOLIB
Endif

# JFL - 11/09/06 - correction bug 37598
# on doit récupérer la valeur de nolign dans l'écran d'où on arrive en tunnel
Local Integer NOLIGN2, N, R, NBNUM
Local Char TABNUM(250)(1..500)

If GTUNCPT(1)=1 or GTUNCPT(4)=1 # tunnel à partir des consultations de pièces ou consultations de comptes
 # on sauvegarde la valeur nolign de l'écran d'où l'on vient
 NOLIGN2 = nolign
Endif
Gosub GESTUN
Return

$LIENS

# > attention MWH n'a pas forcément toutes ses zones renseignées (dates, CPLQTY...)
# l'objet porte sur MFGWIP ; lire l'OF s'il existe
[M:PWI0]=[F:MWH]
If GMODU(6)=2 : # Module Achats actif
    [M:PWI0]VCRTYP=36
    Read [SCI]SCI0 = [F:MWH]VCRNUM ## << mono-article !!
    If !fstat
      [M:PWI0]EXTQTY = [F:SCI]EXTQTY
      [M:PWI0]CPLQTY = [F:SCI]CPLQTY     # qté totale réalisée
      [M:PWI0]SCRAP  = [F:SCI]REJCPLQTY  # qté totale rejetée
    Endif
Endif
# seulement pour les suivis sur OF
If [F:MWH]TRKTYP = 1
 If [M:PWI0]EXTQTY >= [M:PWI0]CPLQTY + [M:PWI0]SCRAP
   [M:PWI0]RMNEXTQTY = [M:PWI0]EXTQTY - [M:PWI0]CPLQTY - [M:PWI0]SCRAP
 Endif
Else
 [M:PWI0]RMNEXTQTY = 0
Endif

Affzo [M:PWI0]SCRAP
Affzo [M:PWI0]RMNEXTQTY
Affzo [M:PWI0]RCPVLTCOD
Affzo [M:PWI0]ISSVLTCOD
Affzo [M:PWI0]PRIREG
If dim([M:PWI0]PROPER)>0
  Affzo [M:PWI0]PROPER
Endif

Diszo [PWI0]10,15,20

Call GETDEV([M:PWI0]MFGFCY) From DEVSUB  # charge GLOCALDEV
[M:PWI0]CUR = GLOCALDEV

Call LOAD_SCRNS([M:PWI0]VCRTYP,[M:PWI0]VCRNUM)          # fait ici plutôt qu'en action s/champ
Return

$SETBOUT
Call VIREBOUT(CHAINE,"CMDH") From GOBJET # aucune écriture en table !
Gosub GESTUN
Return

Subprog C_VCRNUM(VALEUR)
Variable Char    VALEUR()
[M:PWI0]VCRTYP=36
End



###########################################################################
#  LOAD_SCRNS : Call the individual tab functions to load their screen values
###########################################################################
Subprog LOAD_SCRNS(I_VCRTYP, I_VCRNUM)
Value Integer I_VCRTYP
Value Char I_VCRNUM  # FGR 25/01/2010 : X3SUIVI60986

# Open tables
If clalev([F:MWI])=0 : Local File WIPCOST    [MWI] : Endif
If clalev([F:ITM])=0 : Local File ITMMASTER  [ITM] : Endif
Gosub OPEN_FILES_SCO From SCOLIB


# Initialize Screens
Raz [M:PWI1], [M:PWI2], [M:PWI3], [M:PWI4], [M:PWI7], [M:PWI8]

# Place calls to load screens
Call LOAD_SUM(I_VCRTYP, I_VCRNUM)
Call LOAD_ITM(I_VCRTYP, I_VCRNUM)
Call LOAD_MAT(I_VCRTYP, I_VCRNUM)
Call LOAD_SUB(I_VCRTYP, I_VCRNUM)
Call LOAD_OVE(I_VCRTYP, I_VCRNUM)
Call LOAD_REAL_THEO_COST

# Display screens
Affzo [M:PWI1]
Affzo [M:PWI2]
Affzo [M:PWI3]
Affzo [M:PWI4]
Affzo [M:PWI7]
Affzo [M:PWI8]

End

###########################################################################
#  LOAD_SUM  : Load the variables to display the Summary tab
###########################################################################
Subprog LOAD_SUM(I_VCRTYP, I_VCRNUM)
Value Integer I_VCRTYP
Value Char I_VCRNUM

  #MJH temporary measure to change fields into a table to work with new UI changes
  [M:PWI1]NBLIG = 7
  [M:PWI2]NBLIG = 7
  For I=0 To 6
    [M:PWI1]LINE(I) = mess(I+1,2361,1)
    [M:PWI2]LINE(I) = mess(I+1,2361,1)
  Next

Local Integer    I
If [F:MWH]TRKTYP = 1
    Read [SCO]SCO0 = I_VCRNUM
    If fstat : End : Endif
    Read [SCI]SCI0 = I_VCRNUM  # le premier !
    If fstat : End : Endif
    Read [ITM]ITM0 = [F:SCI]ITMREF
    If fstat : End : Endif
Else
    Read [ITM]ITM0 = [F:MWH]ITMREF # article produit (depuis plan de suivi)
Endif
Read [ITF]ITF0 = [F:ITM]ITMREF;[M:PWI0]MFGFCY
If !fstat
  Call GETTCM([F:ITM]ITMREF,[M:PWI0]MFGFCY,[M:PWI0]VLTCOD,GBIDI1) From STKVAL    #GETTCM se positionne sur [F:TCM]
  # selon la valorisation principale, afficher le solde
Endif

# Read all of WIPCOST records for the Work Order
For [MWI]MWI5 Where VCRTYP = I_VCRTYP & VCRNUM = I_VCRNUM

    # Process the WIPCOST records based on the Transaction Type
    Case [F:MWI]TXNTYP
    When 1                # Material
        [M:PWI1]ACTUALS(0) += [F:MWI]AMOUNT
        If [F:MWI]GLPSTA = 2 : [M:PWI2]ACTUALS(0) += [F:MWI]AMOUNT : Endif

    When 2                # Labor
        [M:PWI1]ACTUALS(1) += [F:MWI]AMOUNT
        If [F:MWI]GLPSTA = 2 : [M:PWI2]ACTUALS(1) += [F:MWI]AMOUNT : Endif

    When 3                # Machine
        [M:PWI1]ACTUALS(2) += [F:MWI]AMOUNT
        If [F:MWI]GLPSTA = 2 : [M:PWI2]ACTUALS(2) += [F:MWI]AMOUNT : Endif

    When 4                # Subcontracting
        [M:PWI1]ACTUALS(3) += [F:MWI]AMOUNT
        If [F:MWI]GLPSTA = 2 : [M:PWI2]ACTUALS(3) += [F:MWI]AMOUNT : Endif

    When 5,6,7,8          # Overhead
        [M:PWI1]ACTUALS(4) += [F:MWI]AMOUNT
        If [F:MWI]GLPSTA = 2 : [M:PWI2]ACTUALS(4) += [F:MWI]AMOUNT : Endif

    When 9                # Material Variance
        If [F:SCO]SCOTRKFLG = 6  # Costed
            [M:PWI1]BALANCE(0) += [F:MWI]AMOUNT
            If [F:MWI]GLPSTA = 2 : [M:PWI2]BALANCE(0) += [F:MWI]AMOUNT : Endif
        Endif

    When 10                # Labor Variance
        If [F:SCO]SCOTRKFLG = 6  # Costed
            [M:PWI1]BALANCE(1) += [F:MWI]AMOUNT
            If [F:MWI]GLPSTA = 2 : [M:PWI2]BALANCE(1) += [F:MWI]AMOUNT : Endif
        Endif

    When 11                # Machine Variance
        If [F:SCO]SCOTRKFLG = 6  # Costed
            [M:PWI1]BALANCE(2) += [F:MWI]AMOUNT
            If [F:MWI]GLPSTA = 2 : [M:PWI2]BALANCE(2) += [F:MWI]AMOUNT : Endif
        Endif

    When 12                # Subcontracting Variance
        If [F:SCO]SCOTRKFLG = 6  # Costed
            [M:PWI1]BALANCE(3) += [F:MWI]AMOUNT
            If [F:MWI]GLPSTA = 2 : [M:PWI2]BALANCE(3) += [F:MWI]AMOUNT : Endif
        Endif

    When 13                # Overhead Variance
        If [F:SCO]SCOTRKFLG = 6  # Costed
            [M:PWI1]BALANCE(4) += [F:MWI]AMOUNT
            If [F:MWI]GLPSTA = 2 : [M:PWI2]BALANCE(4) += [F:MWI]AMOUNT : Endif
        Endif

    When 14               # Production Receipt  # distinguer le cas du sous-produit
        If [F:MWI]ITMTYP = 1
          If [F:MWI]OVENAT=""
              For I = 0 To 3
                [M:PWI1]STANDARDS(I) -= [F:MWI]CSTELM(I)
                If [F:MWI]GLPSTA = 2 : [M:PWI2]STANDARDS(I) -= [F:MWI]CSTELM(I) : Endif
              Next I
              # CCC (2009-12-08) Bug 60252 : Depuis la modif 46145 les CSTELM(4..7) sont nuls mais il faut toujours pourvoir consulter les anciens enreg
              [M:PWI1]STANDARDS(4) += sum([F:MWI]CSTELM(4..7))
              If [F:MWI]GLPSTA = 2 : [M:PWI2]STANDARDS(4) += sum([F:MWI]CSTELM(4..7)) : Endif
          Else
              [M:PWI1]STANDARDS(4) -= [F:MWI]AMOUNT
              If [F:MWI]GLPSTA = 2 : [M:PWI2]STANDARDS(4) -= [F:MWI]AMOUNT : Endif
          Endif
          [M:PWI1]STANDARDS(5) -= [F:MWI]AMOUNT
          If [F:MWI]GLPSTA = 2 : [M:PWI2]STANDARDS(5) -= [F:MWI]AMOUNT : Endif
        Elsif [F:MWI]ITMTYP = 2
          [M:PWI1]ACTUALS(0) += [F:MWI]AMOUNT # sous-pdt en déduction de la matière dépensée
          If [F:MWI]GLPSTA = 2 : [M:PWI2]ACTUALS(0) += [F:MWI]AMOUNT : Endif
        Endif
    When 15                # Balance Adjustment
        [M:PWI1]BALANCE(6) += [F:MWI]AMOUNT
        If [F:MWI]GLPSTA = 2 : [M:PWI2]BALANCE(6) += [F:MWI]AMOUNT : Endif
    When 16                # WIP Scrap
        If [F:MWI]OVENAT=""
            For I = 0 To 3
                [M:PWI1]SCRAP(I) += [F:MWI]CSTELM(I)
                If [F:MWI]GLPSTA = 2 : [M:PWI2]SCRAP(I) += [F:MWI]CSTELM(I) : Endif
            Next I
            # CCC (2009-12-08) Bug 60252 : Depuis la modif 46145 les CSTELM(4..7) sont nuls mais il faut toujours pourvoir consulter les anciens enreg
            [M:PWI1]SCRAP(4) += sum([F:MWI]CSTELM(4..7))
            If [F:MWI]GLPSTA = 2 : [M:PWI2]SCRAP(4) += sum([F:MWI]CSTELM(4..7)) : Endif
        Else
            [M:PWI1]SCRAP(4) += [F:MWI]AMOUNT
            If [F:MWI]GLPSTA = 2 : [M:PWI2]SCRAP(4) += [F:MWI]AMOUNT : Endif
        Endif
        [M:PWI1]SCRAP(5) += [F:MWI]AMOUNT
        If [F:MWI]GLPSTA = 2 : [M:PWI2]SCRAP(5) += [F:MWI]AMOUNT : Endif

    When 17                # Actual Cost
        If [F:MWI]OVENAT=""
            [M:PWI1]BALANCE(5) += [F:MWI]AMOUNT
            If [F:MWI]GLPSTA = 2 : [M:PWI2]BALANCE(5) += [F:MWI]AMOUNT : Endif
        Endif

    Endcase
Next

# Calculate the Totals
[M:PWI1]ACTUALS(5)   += sum([M:PWI1]ACTUALS(0..4))
[M:PWI2]ACTUALS(5)   += sum([M:PWI2]ACTUALS(0..4))

If [F:SCO]SCOTRKFLG = 6  & [F:TCM]RCPVLTCOD < 3  # Standard Costed (:il y a eu des enreg écarts 9-13)
    For I = 0 To 4
       [M:PWI1]BALANCE(5)  += [M:PWI1]BALANCE(I)
       [M:PWI2]BALANCE(5)  += [M:PWI2]BALANCE(I)
    Next I
Endif

# Calculate the Balances if the Work Order is Actual Costed
If [F:SCO]SCOTRKFLG = 6  & [F:TCM]RCPVLTCOD > 2  # Actual Costed ("réel" : pas d'enreg d'écart)
    For I = 0 To 4
        [M:PWI1]BALANCE(I) = ([M:PWI1]ACTUALS(I) - [M:PWI1]STANDARDS(I) + [M:PWI1]SCRAP(I)) * (-1)
        [M:PWI2]BALANCE(I) = ([M:PWI2]ACTUALS(I) - [M:PWI2]STANDARDS(I) + [M:PWI2]SCRAP(I)) * (-1)
    Next I
Endif

# Calculate the Balances if the Work Order is not costed
If [F:SCO]SCOTRKFLG < 6 & [F:MWH]TRKTYP = 1 # que pour les suivis sur OF
    For I = 0 To 5
        [M:PWI1]BALANCE(I) = ([M:PWI1]ACTUALS(I) - [M:PWI1]STANDARDS(I) + [M:PWI1]SCRAP(I)) * (-1)
        [M:PWI2]BALANCE(I) = ([M:PWI2]ACTUALS(I) - [M:PWI2]STANDARDS(I) + [M:PWI2]SCRAP(I)) * (-1)
    Next I
Endif
# Calculate the percent if the Work Order is costed
If [F:SCO]SCOTRKFLG = 6
    Actzo [M:PWI1]PERCENT
    For I = 0 To 5
        If [M:PWI1]STANDARDS(I) <> 0
            [M:PWI1]PERCENT(I) = [M:PWI1]BALANCE(I) / [M:PWI1]STANDARDS(I) * 100
        Endif
    Next
    Affzo [M:PWI1]PERCENT
Else
    Grizo [M:PWI1]PERCENT
    Effzo [M:PWI1]PERCENT
Endif

#MJH temporary measure to change fields into a table to work with new UI changes
Gosub FILL_GRID

End

$FILL_GRID

  For I=0 To 5
    [M:PWI1]ACTCST(I) = [M:PWI1]ACTUALS(I)
    [M:PWI1]STDCST(I) = [M:PWI1]STANDARDS(I)
    [M:PWI1]REJCST(I) = [M:PWI1]SCRAP(I)
    [M:PWI1]VARCST(I) = [M:PWI1]BALANCE(I)
    [M:PWI1]VARPCT(I) = [M:PWI1]PERCENT(I)

    [M:PWI2]ACTCST(I) = [M:PWI2]ACTUALS(I)
    [M:PWI2]STDCST(I) = [M:PWI2]STANDARDS(I)
    [M:PWI2]REJCST(I) = [M:PWI2]SCRAP(I)
    [M:PWI2]VARCST(I) = [M:PWI2]BALANCE(I)
  Next
  [M:PWI1]VARCST(6) = [M:PWI1]BALANCE(6)
  [M:PWI2]VARCST(6) = [M:PWI2]BALANCE(6)
  Affzo [M:PWI1]
  Affzo [M:PWI2]

Return


###########################################################################
#  LOAD_REAL_THEO_COST : Load the variables to display the Real Costs and Theoritical Costs
#  Equipe de Bordeaux le 16/10/2008
###########################################################################
Subprog LOAD_REAL_THEO_COST()
# Camembert pour le coût réel
For I = 0 To 4
  [M:PWI1]DESCST(I)=mess(I+1,2361,1)
  [M:PWI1]AMTCSTREL(I)=max(0,[M:PWI1]ACTUALS(I))
  [M:PWI1]AMTCSTTHE(I)=max(0,[M:PWI1]STANDARDS(I))
Next I
[M:PWI1]NBLIGCST = 5

# Diagrammes pour la comparaison coût réel / coût théorique par type de répartition
# Coût réel
[M:PWI1]DESCSTCMP(0)=mess(8,2361,1)
[M:PWI1]AMTCSTMAT(0)=[M:PWI1]ACTUALS(0)
[M:PWI1]AMTCSTLAB(0)=[M:PWI1]ACTUALS(1)
[M:PWI1]AMTCSTMAC(0)=[M:PWI1]ACTUALS(2)
[M:PWI1]AMTCSTSCO(0)=[M:PWI1]ACTUALS(3)
[M:PWI1]AMTCSTOVE(0)=[M:PWI1]ACTUALS(4)
[M:PWI1]AMTCSTTOT(0)=[M:PWI1]ACTUALS(5)

# Coût théorique
[M:PWI1]DESCSTCMP(1)=mess(9,2361,1)
[M:PWI1]AMTCSTMAT(1)=[M:PWI1]STANDARDS(0)
[M:PWI1]AMTCSTLAB(1)=[M:PWI1]STANDARDS(1)
[M:PWI1]AMTCSTMAC(1)=[M:PWI1]STANDARDS(2)
[M:PWI1]AMTCSTSCO(1)=[M:PWI1]STANDARDS(3)
[M:PWI1]AMTCSTOVE(1)=[M:PWI1]STANDARDS(4)
[M:PWI1]AMTCSTTOT(1)=[M:PWI1]STANDARDS(5)

[M:PWI1]NBLIGCMP = 2

End
###########################################################################
#  LOAD_ITM : Load the variables to display the Products tab
###########################################################################
Subprog LOAD_ITM(I_VCRTYP, I_VCRNUM)
Value Integer I_VCRTYP
Value Char I_VCRNUM

# CCC (2009-07-28) Bug 56811 : le cumul se fait par mfglin/article
Local Char TMP_KEY(8+1+GLONITM)  : TMP_KEY = ""
Local Integer I     : I = -1

Filter [MWI] Where VCRTYP = I_VCRTYP & VCRNUM = I_VCRNUM & (TXNTYP = 14 | (TXNTYP = 5 & MATOVETYP = 1) | TXNTYP = 17)
&            Order By VCRLIN;ITMREF
For [MWI]
    If TMP_KEY <> num$([F:MWI]VCRLIN) + "~" + [F:MWI]ITMREF
        I += 1
        TMP_KEY = num$([F:MWI]VCRLIN) + "~" + [F:MWI]ITMREF
        [M:PWI3]VCRLIN(I)        = [F:MWI]VCRLIN
        [M:PWI3]ITMREF(I)        = [F:MWI]ITMREF
        [M:PWI3]ITMTYP(I)        = [F:MWI]ITMTYP # type : Normal / Sous-produit
        [M:PWI3]STU(I)           = [F:MWI]STU
        # 104939
        If dim([M:PWI3]ECCVALMAJ)>0
            [M:PWI3]ECCVALMAJ(I) = [F:MWI]ECCVALMAJ
            [M:PWI3]ECCVALMIN(I) = [F:MWI]ECCVALMIN
        Endif
    Endif

    If [F:MWI]TXNTYP = 14
        [M:PWI3]QUANTITY(I)  += [F:MWI]QTY
        [M:PWI3]AMOUNT(I)    += [F:MWI]AMOUNT
        If [F:MWI]GLPSTA = 2
            [M:PWI3]AMTPOST(I)  += [F:MWI]AMOUNT
        Endif
    Elsif ([F:MWI]TXNTYP = 5 & [F:MWI]MATOVETYP = 1)
       [M:PWI3]OVERHEAD(I)    += [F:MWI]AMOUNT
       If [F:MWI]GLPSTA = 2
            [M:PWI3]OVEPOST(I)  += [F:MWI]AMOUNT
       Endif
    Elsif [F:MWI]TXNTYP = 17
        [M:PWI3]CSTADJ(I)    += [F:MWI]AMOUNT
    Endif
Next
Filter [MWI]
nolign = I + 1
[M:PWI3]NBLIG = I + 1

End

###########################################################################
#  LOAD_MAT  : Load the variables to display the Material tab
###########################################################################
Subprog LOAD_MAT(I_VCRTYP, I_VCRNUM)
Value Integer I_VCRTYP
Value Char I_VCRNUM

Local Char TMP_KEY(250)  : TMP_KEY = ""
Local Integer I     : I = -1

Filter [MWI] Where VCRTYP = I_VCRTYP & VCRNUM = I_VCRNUM & (TXNTYP = 1 | (TXNTYP = 5 & MATOVETYP = 2))
&            Order By VCRTYP;VCRNUM;VCRLIN;BOMSEQ;ITMREF;ECCVALMAJ;ECCVALMIN
For [MWI]
    If TMP_KEY <> num$([F:MWI]VCRLIN) + num$([F:MWI]BOMSEQ) + [F:MWI]ITMREF + [F:MWI]ECCVALMAJ +"~"+ [F:MWI]ECCVALMIN
        I += 1
        TMP_KEY = num$([F:MWI]VCRLIN) + num$([F:MWI]BOMSEQ) + [F:MWI]ITMREF + [F:MWI]ECCVALMAJ +"~"+ [F:MWI]ECCVALMIN
        [M:PWI4]VCRLIN(I)        = [F:MWI]VCRLIN
        [M:PWI4]BOMSEQ(I)        = [F:MWI]BOMSEQ
        [M:PWI4]ITMREF(I)        = [F:MWI]ITMREF
        Read [ITM]ITM0 = [F:MWI]ITMREF
   ##      # récupérer la désignation traduisible si le lien auto ne se fait pas
   ##     [M:PWI4]ITMDES(I)        = [F:ITM]ITMDES1
        [M:PWI4]STU(I)           = [F:MWI]STU
        # 104939
        If dim([M:PWI4]ECCVALMAJ)>0
            [M:PWI4]ECCVALMAJ(I) = [F:MWI]ECCVALMAJ
            [M:PWI4]ECCVALMIN(I) = [F:MWI]ECCVALMIN
        Endif
    Endif

   If [F:MWI]TXNTYP = 1
       [M:PWI4]QUANTITY(I)  += [F:MWI]QTYACT    # CCC (08/11/04) Bug 26297
       [M:PWI4]AMOUNT(I)    += [F:MWI]AMOUNT
       If [F:MWI]GLPSTA = 2
            [M:PWI4]AMTPOST(I)  += [F:MWI]AMOUNT
       Endif
    Elsif ([F:MWI]TXNTYP = 5 & [F:MWI]MATOVETYP = 2)
       [M:PWI4]OVERHEAD(I)    += [F:MWI]AMOUNT
       If [F:MWI]GLPSTA = 2
            [M:PWI4]OVEPOST(I)  += [F:MWI]AMOUNT
       Endif
    Endif
Next
Filter [MWI]
nolign = I + 1
[M:PWI4]NBLIG = I + 1

End


###########################################################################
#  LOAD_SUB  : Load the variables to display the Subcontracting tab
###########################################################################
Subprog LOAD_SUB(I_VCRTYP, I_VCRNUM)
Value Integer I_VCRTYP
Value Char I_VCRNUM

Local Char TMP_KEY  : TMP_KEY = ""
Local Integer I     : I = -1

For [MWI]MWI4 Where VCRTYP = I_VCRTYP & VCRNUM = I_VCRNUM & (TXNTYP = 4 | TXNTYP = 8)
    If TMP_KEY <> [F:MWI]ITMREF
        I += 1
        TMP_KEY = [F:MWI]ITMREF
        [M:PWI7]SCOITMREF(I)     = [F:MWI]ITMREF
        [M:PWI7]STU(I)           = [F:MWI]STU
        [M:PWI7]VCRLIN(I)        = [F:MWI]VCRLIN
        Raz [F:SCS]
        Filter [SCS] Where SCONUM=[M:PWI0]VCRNUM & SCILIN=[F:MWI]VCRLIN & BOMSEQ=[F:MWI]BOMSEQ
        Read [SCS] First
        [M:PWI7]SCSLIN(I) = [F:SCS]SCSLIN
        Filter [SCS]
    Endif

    If [F:MWI]TXNTYP = 4

       # CCC (31/08/05) Bug 31709
       # Les enregistrements de type 4 qui proviennent d'une régul de prix sont repérés par CSTTYP=0
       [M:PWI7]QUANTITY(I)  += [F:MWI]QTY * ([F:MWI]CSTTYP<>0 | [F:MWI]VCRTYP<>10)
       [M:PWI7]REJECTED(I)  += [F:MWI]REJQTY * ([F:MWI]CSTTYP<>0 | [F:MWI]VCRTYP<>10)
       [M:PWI7]AMOUNT(I)    += [F:MWI]AMOUNT
       If [F:MWI]GLPSTA = 2
            [M:PWI7]AMTPOST(I)  += [F:MWI]AMOUNT
       Endif
    Elsif [F:MWI]TXNTYP = 8
       [M:PWI7]OVERHEAD(I)    += [F:MWI]AMOUNT
       If [F:MWI]GLPSTA = 2
            [M:PWI7]OVEPOST(I)  += [F:MWI]AMOUNT
       Endif
    Endif
Next
nolign = I + 1
[M:PWI7]NBLIG = I + 1

End

###########################################################################
#  LOAD_OVE  : Load the variables to display the Overhead tab
###########################################################################
Subprog LOAD_OVE(I_VCRTYP, I_VCRNUM)
Value Integer I_VCRTYP
Value Char I_VCRNUM
Local Integer OH_POS, I, J
Local Decimal LPRI
Local Integer LRET

# Read all of WIPCOST records for the Work Order
For [MWI]MWI5 Where VCRTYP = I_VCRTYP & VCRNUM = I_VCRNUM & (TXNTYP > 4 & TXNTYP <= 17) & OVENAT<>""
    # Process the WIPCOST records based on the Transaction Type
    Case [F:MWI]TXNTYP
    When 5                # Material Overhead
       # trouver la nature dans le tableau pour y cumuler le mnt ou rajouter une ligne
       OH_POS = find([F:MWI]OVENAT,[M:PWI8]OVENAT)
       If OH_POS > 0
         [M:PWI8]MATERIAL(OH_POS-1) += [F:MWI]AMOUNT
       Else
         # rajouter en fin de tableau 1 ligne avec cette nature
         [M:PWI8]NBLIG += 1
         [M:PWI8]OVENAT([M:PWI8]NBLIG-1)   = [F:MWI]OVENAT
         [M:PWI8]MATERIAL([M:PWI8]NBLIG-1) = [F:MWI]AMOUNT
       Endif

    When 6                # Labor Overhead
       OH_POS = find([F:MWI]OVENAT,[M:PWI8]OVENAT)
       If OH_POS > 0
         [M:PWI8]LABOR(OH_POS-1) += [F:MWI]AMOUNT
       Else
         # rajouter en fin de tableau 1 ligne avec cette nature
         [M:PWI8]NBLIG += 1
         [M:PWI8]OVENAT([M:PWI8]NBLIG-1)   = [F:MWI]OVENAT
         [M:PWI8]LABOR([M:PWI8]NBLIG-1)    = [F:MWI]AMOUNT
       Endif

    When 7                # Machine  Overhead
       OH_POS = find([F:MWI]OVENAT,[M:PWI8]OVENAT)
       If OH_POS > 0
         [M:PWI8]MACHINE(OH_POS-1) += [F:MWI]AMOUNT
       Else
         # rajouter en fin de tableau 1 ligne avec cette nature
         [M:PWI8]NBLIG += 1
         [M:PWI8]OVENAT([M:PWI8]NBLIG-1)   = [F:MWI]OVENAT
         [M:PWI8]MACHINE([M:PWI8]NBLIG-1) = [F:MWI]AMOUNT
       Endif

    When 8                # Subcontracting Overhead
       OH_POS = find([F:MWI]OVENAT,[M:PWI8]OVENAT)
       If OH_POS > 0
         [M:PWI8]SUBCONT(OH_POS-1) += [F:MWI]AMOUNT
       Else
         # rajouter en fin de tableau 1 ligne avec cette nature
         [M:PWI8]NBLIG += 1
         [M:PWI8]OVENAT([M:PWI8]NBLIG-1)   = [F:MWI]OVENAT
         [M:PWI8]SUBCONT([M:PWI8]NBLIG-1) = [F:MWI]AMOUNT
       Endif

    When 14                # Production Receipt
       OH_POS = find([F:MWI]OVENAT,[M:PWI8]OVENAT)
       If OH_POS > 0
         [M:PWI8]STANDARD(OH_POS-1) += [F:MWI]AMOUNT
       Else
         # rajouter en fin de tableau 1 ligne avec cette nature
         [M:PWI8]NBLIG += 1
         [M:PWI8]OVENAT([M:PWI8]NBLIG-1)   = [F:MWI]OVENAT
         [M:PWI8]STANDARD([M:PWI8]NBLIG-1) = [F:MWI]AMOUNT
       Endif

    When 9,10,11,12,13     # Variance
       OH_POS = find([F:MWI]OVENAT,[M:PWI8]OVENAT)
       If OH_POS > 0
         [M:PWI8]VARIANCE(OH_POS-1) += [F:MWI]AMOUNT
       Else
         # rajouter en fin de tableau 1 ligne avec cette nature
         [M:PWI8]NBLIG += 1
         [M:PWI8]OVENAT([M:PWI8]NBLIG-1)   = [F:MWI]OVENAT
         [M:PWI8]VARIANCE([M:PWI8]NBLIG-1) = [F:MWI]AMOUNT
       Endif

    When 16                # Rebut
       OH_POS = find([F:MWI]OVENAT,[M:PWI8]OVENAT)
       If OH_POS > 0
         [M:PWI8]SCRAP(OH_POS-1) += [F:MWI]AMOUNT
       Else
         # rajouter en fin de tableau 1 ligne avec cette nature
         [M:PWI8]NBLIG += 1
         [M:PWI8]OVENAT([M:PWI8]NBLIG-1)   = [F:MWI]OVENAT
         [M:PWI8]SCRAP([M:PWI8]NBLIG-1)    = [F:MWI]AMOUNT
       Endif

    When 17     # Variance
       OH_POS = find([F:MWI]OVENAT,[M:PWI8]OVENAT)
       If OH_POS > 0
         [M:PWI8]VARIANCE(OH_POS-1) += sum([F:MWI]CSTELM(4..7))
       Else
         # rajouter en fin de tableau 1 ligne avec cette nature
         [M:PWI8]NBLIG += 1
         [M:PWI8]OVENAT([M:PWI8]NBLIG-1)   = [F:MWI]OVENAT
         [M:PWI8]VARIANCE([M:PWI8]NBLIG-1) = sum([F:MWI]CSTELM(4..7))
       Endif


    Endcase
Next

[M:PWI8]OVENAT([M:PWI8]NBLIG) = mess(200,197,1) #"Totaux". Ligne supplémentaire pour totaux :
For I = 0 To [M:PWI8]NBLIG - 1
    [M:PWI8]TOTAL(I) = [M:PWI8]MATERIAL(I) + [M:PWI8]LABOR(I) + [M:PWI8]MACHINE(I) + [M:PWI8]SUBCONT(I)
    #[M:PWI8]VARIANCE(I) = [M:PWI8]TOTAL(I) - [M:PWI8]STANDARD(I)
Next
[M:PWI8]MATERIAL([M:PWI8]NBLIG) = sum([M:PWI8]MATERIAL(0..[M:PWI8]NBLIG - 1))
[M:PWI8]LABOR([M:PWI8]NBLIG)    = sum([M:PWI8]LABOR(0..[M:PWI8]NBLIG - 1))
[M:PWI8]MACHINE([M:PWI8]NBLIG)  = sum([M:PWI8]MACHINE(0..[M:PWI8]NBLIG - 1))
[M:PWI8]SUBCONT([M:PWI8]NBLIG)  = sum([M:PWI8]SUBCONT(0..[M:PWI8]NBLIG - 1))
[M:PWI8]TOTAL([M:PWI8]NBLIG)    = sum([M:PWI8]TOTAL(0..[M:PWI8]NBLIG - 1))
[M:PWI8]STANDARD([M:PWI8]NBLIG) = sum([M:PWI8]STANDARD(0..[M:PWI8]NBLIG - 1))
[M:PWI8]SCRAP([M:PWI8]NBLIG)    = sum([M:PWI8]SCRAP(0..[M:PWI8]NBLIG - 1))
[M:PWI8]VARIANCE([M:PWI8]NBLIG) = sum([M:PWI8]VARIANCE(0..[M:PWI8]NBLIG - 1))

[M:PWI8]NBLIG += 1

End

