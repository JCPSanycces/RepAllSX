#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################
#                                                    #
#  ANNULATION DE QUITTANCES SUBROGATIVES             #
#                                                    #
######################################################

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","DELQUIT","FDELQUIT",3,"") From GTRAITE
End


$ACTION
Case ACTION
 When "INIT"       : Gosub INIT
 When "INIT_DIA"   : Gosub INIT_DIA
 When "CONTROLE"   : Gosub CONTROLE
 When "EXEC"       : Gosub EXEC
 When "TERMINE"    : Gosub TERMINE
Endcase
Return


$INIT
Local Char FACTOR(GLONFCT), NUMQUIT(GLONVCR)
Gosub OUVRE
Return

$INIT_DIA
Gosub TIT
Return

$TIT
TIT = mess(65,121,1)    # Annulation de quittance
Return

$CONTROLE
TMP = 1  :# Pour afficher des tempon/tempoff
Return

$TERMINE
If !GSERVEUR & [M:DIA]TRACE=2
 TRA = 1
Else
 TRA = 0
Endif
Return

$EXEC
If GSERVEUR
### batch
 [M:DIA]TRACE = 2
Endif

Gosub TIT
If !GSERVEUR & [M:DIA]TRACE=2
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
If [M:DIA]TRACE=2
 Call ECR_TRACE(TIT-[M:DIA]FCTVCR,0) From GESECRAN
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Endif

#### Traitement d'annulation
FACTOR = [M:DIA]BPRFCT
NUMQUIT = [M:DIA]FCTVCR
# Annulation des pieces de simulation
Filter [SIH1] Where BPRFCT=FACTOR & FCTVCR=NUMQUIT & FCTVCRFLG=0
&             Order By Key CLE = CUR
For [F:SIH1]CLE(1)
 REF_SIM = "QT" + FACTOR + [F:SIH1]CUR
 GOK=1
 For [F:HAE1] Where REFSIM = REF_SIM & CAT>1
  If GTRACE<>""
   # Annulation pièce
   Call ECR_TRACE(mess(41,107,1)-[F:HAE1]TYP-[F:HAE1]NUM,0) From GESECRAN
  Endif
  Call DELPCE([F:HAE1]TYP,[F:HAE1]NUM) From CPTBATCH
  If GOK < 1: Break : Endif
 Next
Next
Filter [SIH1]
If GOK<1 : GERR=1 : Return : Endif

# Remise à blanc de la zone Numéro de quittance sur SIH et DUD
Call DEBTRANS From GLOCK
Gosub TR1

If !GSERVEUR & [M:DIA]TRACE=2
 Call FERME_TRACE From LECFIC
Endif

Return


####################################################
$OUVRE
If clalev([F:SIH])=0  : Local File SINVOICE   [SIH]  : Endif
If clalev([F:SIH1])=0 : Local File SINVOICE   [SIH1] : Endif
If clalev([F:DUD])=0  : Local File GACCDUDATE [DUD]  : Endif
If clalev([F:HAE1])=0 : Local File GACCENTRY  [HAE1] : Endif
Return

#####################################################
## Remise à blanc du numéro de quittance sélectionné
#####################################################
$TR1
GOK = 1
Trbegin [SIH], [DUD]
For [SIH]SIH4 Where BPRFCT=FACTOR & FCTVCR=NUMQUIT & FCTVCRFLG=0
 Readlock
 If fstat=1 : GOK = -1 : GLOCK = "$SINVOICE"-[F:SIH]NUM : Break
 Elsif fstat : GOK = 0 : Call RSTA("SIH",[F:SIH]NUM) From GLOCK
 Endif
 [F:SIH]FCTVCR = ""
 Rewrite [SIH]
 If fstat : GOK = 0 : Call FSTA("SIH") From GLOCK : Break : Endif
 Update [DUD] Where ACCNUM=[F:SIH]ACCNUM With FCTVCR=""
 If fstat : GOK = 0 : Call FSTA("DUD") From GLOCK : Break : Endif
 If GTRACE <> ""
  Call ECR_TRACE(mess(16,122,1)-[F:SIH]NUM,0) From GESECRAN   # Facture/Avoir
 Endif
Next
If GOK<0    : Goto ROLL
Elsif GOK=0 : Goto ABORT
Endif
Commit
Return

$ROLL
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return

$ABORT
Rollback
Return

###############################################
## Etiquettes du masque DELQUIT
###############################################

Subprog AM_BPRFCT(VALEUR)
Variable Char    VALEUR()
Local Char CRIT(150)
Raz [M]FCTVCR
CRIT = "BPRFCT='"+VALEUR+"' & FCTVCR<>'' & FCTVCRFLG=0"
If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
 CRIT -= "& find(FCY, GUSRFCY(1..GNBAUZ))"
Endif
# On propose par défaut la quittance non comptabilisée la plus récente
Filter [SIH] Where evalue(CRIT) Order By Key CLE = FCTVCR
Read [SIH] Last
If !fstat : [M]FCTVCR = [F:SIH]FCTVCR : Endif
Filter [SIH]
End

Subprog C_FCTVCR(VALEUR)
Variable Char    VALEUR()
Local Integer NB, CPT
Raz NB, CPT
For [SIH] Where BPRFCT=[M]BPRFCT & FCTVCR=VALEUR
 NB += 1
 If GUSRFCY(1)<>"\" & !find([F:SIH]FCY, GUSRFCY(1..GNBAUZ))
   GMESSAGE = [F:SIH]FCY-":"-mess(2,104,1)  : # Vous n'avez pas les droits pour ce site
   mkstat = 2 : Break
 Endif
 If [F:SIH]FCTVCRFLG=1 : CPT = 1 : Break : Endif
Next
If !NB
 GMESSAGE = mess(79,121,1)   # Quittance inexistante
 mkstat = 2
Else
 If CPT
   GMESSAGE = mess(80,121,1) # Quittance comptabilisée
   mkstat = 2
 Endif
Endif
End

