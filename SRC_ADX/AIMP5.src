#<AdxTL>@(#)7.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
Local Mask AIMP5
Call SAISIE_CHAR(VALEUR,PARAM,"AIMP5","AIMP5","") From GSAISIE
End

#----------------------------#
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "ABA"         : Gosub ABA
 When "OK"          : Gosub OK
Endcase
Return

#----------------------------#
$OUVRE
If clalev([M:AIM5])=0 : FIN = 1 : Return : Endif
Return

#----------------------------#
$DEBUT
Affzo
Return

#----------------------------#
$APRES_MODIF
REP = "M"
Return

#----------------------------#
$ABA
Raz [M:AIM5]
Affzo
REP = ""
Return

#----------------------------#
$OK
FIN = 1
Return

#----------------------------------------------------------------#
# Etiquettes écran AIMP5
#----------------------------------------------------------------#

Subprog C_NBDEST
If adxgtb=2 & [M]NBDEST=0
 Call ERREUR(mess(3,75,1)) From GESECRAN : # Un destinataire principal , au moins, est nécessaire !
 mkstat = 2 : End
Endif
End

Subprog IB_DEST
If GBROWS
 GBOUT1 = ""
Endif
End

Subprog C_DEST(VALEUR)
Variable Char    VALEUR()
Local Char    CHAINE(250) , EMAIL(GLONMAI)
Local Integer NOL , I , K
Local Char    SAVUSR(GLONAUS)
If clalev([F:AUS])=0
 Local File AUTILIS [AUS]
Else
 SAVUSR = [F:AUS]USR
Endif
CHAINE = VALEUR
NOL = nolign
I = 0
While CHAINE<>""
 I += 1
 K = instr(1,CHAINE,";")
 If K
  EMAIL = left$(CHAINE,K-1)
  CHAINE = right$(CHAINE,K+1)
 Else
  EMAIL = CHAINE
  CHAINE = ""
 Endif
 If left$(EMAIL,1)='"' : EMAIL = right$(EMAIL,2) : Endif
 If right$(EMAIL,len(EMAIL))='"' : EMAIL = left$(EMAIL,len(EMAIL)-1) : Endif
 Read [AUS]CODUSR = EMAIL
 If !fstat & [F:AUS]ADDEML<>""
  EMAIL = [F:AUS]ADDEML
 Endif
 If I=1
  VALEUR = EMAIL
  [M]DEST(NOL-1) = EMAIL
 Elsif [M]NBDEST<dim([M]DEST)
  Insa NOL+I-2,1 [M]NBDEST
  [M]NBDEST += 1
  [M]DEST(NOL+I-2) = EMAIL
 Endif
Wend
Affzo 5
If SAVUSR<>"" & SAVUSR<>[F:AUS]USR
 Read [AUS]CODUSR = SAVUSR
Endif
End

