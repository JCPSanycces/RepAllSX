#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################
# UTITRC6      Utilitaire de réajustement des tables           Module TC #
#               tronc commun en v6 suite à la non exécution              #
#               des AP_ de la migration v130 -> v140/v5       21/09/2010 #
# ---------------------------------------------------------------------- #
#                                                                        #
##########################################################################


Call MAJ_UTITRC6
End


Subprog MAJ_UTITRC6
Local Char WDOSSIER(30)
Local Libelle WTRACE  : WTRACE=2     : # WTRACE=2 --> Trace détaillée
Local Libelle WSIMUL  : WSIMUL=1     : # 0=normale, 1=simulation (pas de màj)
WDOSSIER=nomap
Call SAIDOS(WDOSSIER,"UTITRC6 - Réajustement tables tronc commun en v6") From SAIDOS
If WDOSSIER<>""
  #-----
  Call TEMPON("O") From GESECRAN
  If WTRACE
    Call OUVRE_TRACE("UTITRC6 : Réjustement tables tronc commun en v6") From LECFIC
    Call ECR_TIME("UTITRC6 : Starting process on folder "+WDOSSIER) From DOSSUB
  Endif
  Call EXE_UTITRC6(WDOSSIER,WTRACE,WSIMUL)
  Call TEMPOFF From GESECRAN
  If WTRACE
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif
Endif
End


Subprog EXE_UTITRC6(WDOSSIER,WTRACE,WSIMUL)
Value Char     WDOSSIER
Value Libelle  WTRACE
Value Libelle  WSIMUL
#----- Variables locales -----#
Local Char     WMSG(90)
Local Integer  NBENR, NBCOR, WNBR
Local Char     CLE1(max(20,GLONVCR,GLONBPR))
Local Char     CLE2(20)
Local Integer  CLE3
Local Char     CRITERE(150)
Local Integer COMPTEUR, STOP
Local Libelle  WFLAG1, WFLAG2
Local Char     WCRIITM_A(5)
Local Char     WCRIBPR_A(5)
Local Char     WPLICRI (GLONSPX)
Local Char     WPLICRI1(GLONSPU)
Local Char     WPLICRI2(GLONSPU)
Local Char     WPLICRI3(GLONSPU)
Local Char     WPLICRI4(GLONSPU)
Local Char     WPLICRI5(GLONSPU)
Local Integer  I, J
#-----
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=WDOSSIER : If fstat  Raz [F:ADS] : Endif
#-----
If dim(GMAXUPDTRS)<1  Global Integer GMAXUPDTRS : Endif
Local File =[F:ADS]DOSSIER+".ADOVAL" [ADW] 
Read [ADW] ADW0="";"";"MAXUPDTRS" : If fstat  Raz [F:ADW] : Endif
If val([F:ADW]VALEUR)>0
  GMAXUPDTRS=val([F:ADW]VALEUR)
Else
  GMAXUPDTRS=1000
Endif
Close Local File [ADW]
#-----
Gosub TRT_BPC
Gosub TRT_SPC
Gosub TRT_SPL
Gosub TRT_PPC
Gosub TRT_PPL
Gosub TRT_OVE
#Gosub TRT_BPA
#-----
$FIN_UTITRC6
If WSIMUL
 Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
Else
 Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
Endif
#-----
End


#----------------------------------------------------------#
#    ---> Concerne les clients BPCUSTOMER                  #
#----------------------------------------------------------#
# Remplacement du type client "intra-société" par "normal" #
#----------------------------------------------------------#
$TRT_BPC  
Local File =[F:ADS]DOSSIER+".BPCUSTOMER" [BPC]
#-----
If WTRACE
  If WSIMUL
   Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
  Else
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
  Call ECR_TIME("UTITRC6 : Customer Process : Update BPCUSTOMER") From DOSSUB
Endif
Raz CLE1, STOP, NBENR, NBCOR
#-----
$BOUCLE_BPC
If STOP=1
  STOP=0 : CRITERE='BPCTYP=3 & BPCNUM>"'+CLE1+'"'
Else
  CRITERE="BPCTYP=3"
Endif
Raz COMPTEUR
Trbegin [BPC]
For [BPC] BPC0 Where evalue(CRITERE)
  Raz WFLAG1
  NBENR+=1
  If [F:BPC]BPCTYP=3
    If WTRACE=2
      WMSG=[F:BPC]BPCNUM-"- BPCTYP    : 3 --> 1"
      Call ECR_TRACE(WMSG,0) From GESECRAN
    Endif
    [F:BPC]BPCTYP=1 : WFLAG1=1
  Endif
  If WFLAG1
    COMPTEUR+=1 : NBCOR+=1
    Rewrite [BPC]
    If fstat & WTRACE
      Call ECR_TRACE("File BPCUSTOMER, Error ="-num$(fstat),1) From GESECRAN
    Endif
  Endif      
  If COMPTEUR>GMAXUPDTRS  CLE1=[F:BPC]BPCNUM : STOP=1 : Break : Endif
Next
If WSIMUL  Rollback  Else  Commit : Endif
If STOP : Goto BOUCLE_BPC : Endif
Close Local File [BPC]
#-----
If WTRACE
  WMSG ="UTITRC6 : Number of processed records :"-num$(NBENR)
  WMSG+=" corrected :"-num$(NBCOR)
  Call ECR_TIME(WMSG) From DOSSUB
Endif
Return


#----------------------------------------------------------------#
#    ---> Concerne le parametrage tarifs ventes SPRICCONF        #
#----------------------------------------------------------------#
# CRIITM = concatenation des no de criteres concernant l'article #
# CRIBPR = concatenation des no de criteres concernant le client #
#----------------------------------------------------------------#
$TRT_SPC  
Local File =[F:ADS]DOSSIER+".SPRICCONF" [SPC]
#-----
If WTRACE
  If WSIMUL
   Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
  Else
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
  #-----
  Call ECR_TIME("UTITRC6 : Customer Prices Process 1 : Update SPRICCONF") From DOSSUB
Endif
#-----
Raz COMPTEUR, NBENR, NBCOR
Trbegin [SPC]
  For [SPC] SPC0
    Raz WFLAG1
    NBENR+=1
    Raz WCRIITM_A, WCRIBPR_A
    #----- Les champs de la table ITMBPC sont des critères articles et clients -----#
    For I=0 To dim([F:SPC]FIL)-1
      If find([F:SPC]FIL(I),"ITMMASTER","ITMSALES","ITMBPC") 
        WCRIITM_A+=num$(I+1) 
      Endif
      If find([F:SPC]FIL(I),"BPARTNER","BPCUSTOMER","BPCUSTMVT","BPDLVCUST","ITMBPC") 
        WCRIBPR_A+=num$(I+1) 
      Endif
    Next I
    #-----
    If [F:SPC]CRIITM<>val(WCRIITM_A)
      If WTRACE=2
        WMSG=[F:SPC]PLI-"- CRIITM    :"-num$([F:SPC]CRIITM)-"-->"-num$(val(WCRIITM_A))
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:SPC]CRIITM=val(WCRIITM_A) : WFLAG1=1
    Endif
    If [F:SPC]CRIBPR<>val(WCRIBPR_A)
      If WTRACE=2
        WMSG=[F:SPC]PLI-"- CRIBPR    :"-num$([F:SPC]CRIBPR)-"-->"-num$(val(WCRIBPR_A))
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:SPC]CRIBPR=val(WCRIBPR_A) : WFLAG1=1
    Endif
    #-----
    If WFLAG1
      NBCOR+=1 
      Rewrite [SPC]
      If fstat & WTRACE
        Call ECR_TRACE("File SPRICCONF, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
  Next
If WSIMUL  Rollback  Else  Commit : Endif
Close Local File [SPC]
#-----
If WTRACE
  WMSG ="UTITRC6 : Number of processed records :"-num$(NBENR)
  WMSG+=" corrected :"-num$(NBCOR)
  Call ECR_TIME(WMSG) From DOSSUB
Endif
Return


#---------------------------------------------------------------#
#    ---> Concerne les lignes tarifs ventes SPRICLIST           #
#---------------------------------------------------------------#
# Chargement des 5 critères dans les champs PLICRI1 --> PLICRI5 #
#---------------------------------------------------------------#
$TRT_SPL  
Local File =[F:ADS]DOSSIER+".SPRICLIST" [SPL]
#-----
If WTRACE
  If WSIMUL
   Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
  Else
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
  #-----
  Call ECR_TIME("UTITRC6 : Customer Prices Process 2 : Update SPRICLIST") From DOSSUB
Endif
#-----
Raz CLE1, CLE2, CLE3, STOP, NBENR, NBCOR
#-----
$BOUCLE_SPL 
If STOP=1
  CRITERE='PLI="'+CLE1+'" & PLICRD="'+CLE2+'" & PLILIN>'+num$(CLE3)
  STOP=2
Elsif STOP=2
  CRITERE='PLI="'+CLE1+'" & PLICRD>"'+CLE2+'"'
  STOP=3
Elsif STOP=3
CRITERE='PLI>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif
Raz COMPTEUR
Trbegin [SPL]
  For [SPL] SPL0 Where evalue(CRITERE)
    Raz WFLAG1
    NBENR+=1
    #----- Eclatement des critères -----#
    WPLICRI=[F:SPL]PLICRI
    Raz J
    While instr(1,WPLICRI,"~")
      I=instr(1,WPLICRI,"~")
      J+=1
      Case J
        When 1 : WPLICRI1=left$(WPLICRI,I-1)
        When 2 : WPLICRI2=left$(WPLICRI,I-1)
        When 3 : WPLICRI3=left$(WPLICRI,I-1)
        When 4 : WPLICRI4=left$(WPLICRI,I-1)
        When 5 : WPLICRI5=left$(WPLICRI,I-1)
      Endcase
      WPLICRI=right$(WPLICRI,I+1)
    Wend
    If [F:SPL]PLICRI1<>WPLICRI1
      If WTRACE=2
        WMSG=[F:SPL]PLI-[F:SPL]PLICRD-num$([F:SPL]PLILIN)-"- PLICRI1   :"-[F:SPL]PLICRI1-"-->"-WPLICRI1
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:SPL]PLICRI1=WPLICRI1 : WFLAG1=1
    Endif
    If [F:SPL]PLICRI2<>WPLICRI2
      If WTRACE=2
        WMSG=[F:SPL]PLI-[F:SPL]PLICRD-num$([F:SPL]PLILIN)-"- PLICRI2   :"-[F:SPL]PLICRI2-"-->"-WPLICRI2
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:SPL]PLICRI2=WPLICRI2 : WFLAG1=1
    Endif
    If [F:SPL]PLICRI3<>WPLICRI3
      If WTRACE=2
        WMSG=[F:SPL]PLI-[F:SPL]PLICRD-num$([F:SPL]PLILIN)-"- PLICRI3   :"-[F:SPL]PLICRI3-"-->"-WPLICRI3
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:SPL]PLICRI3=WPLICRI3 : WFLAG1=1
    Endif
    If [F:SPL]PLICRI4<>WPLICRI4
      If WTRACE=2
        WMSG=[F:SPL]PLI-[F:SPL]PLICRD-num$([F:SPL]PLILIN)-"- PLICRI4   :"-[F:SPL]PLICRI4-"-->"-WPLICRI4
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:SPL]PLICRI4=WPLICRI4 : WFLAG1=1
    Endif
    If [F:SPL]PLICRI5<>WPLICRI5
      If WTRACE=2
        WMSG=[F:SPL]PLI-[F:SPL]PLICRD-num$([F:SPL]PLILIN)-"- PLICRI5   :"-[F:SPL]PLICRI5-"-->"-WPLICRI5
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:SPL]PLICRI5=WPLICRI5 : WFLAG1=1
    Endif
    #-----
    If WFLAG1
      COMPTEUR+=1 : NBCOR+=1
      [F:SPL]UPDDAT=date$ : [F:SPL]UPDUSR=GUSER
      Rewrite [SPL]
      If fstat & WTRACE
        Call ECR_TRACE("File SPRICLIST"-[F:SPL]PLI-[F:SPL]PLICRD-num$([F:SPL]PLILIN)+", Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
    If COMPTEUR>GMAXUPDTRS
      CLE1=[F:SPL]PLI : CLE2=[F:SPL]PLICRD : CLE3=[F:SPL]PLILIN : STOP=1 : Break
    Endif
  Next
If WSIMUL  Rollback  Else  Commit : Endif
If STOP Goto BOUCLE_SPL : Endif
#-----
Close Local File [SPL]
#-----
If WTRACE
  WMSG ="UTITRC6 : Number of processed records :"-num$(NBENR)
  WMSG+=" corrected :"-num$(NBCOR)
  Call ECR_TIME(WMSG) From DOSSUB
Endif
Return


#---------------------------------------------------------------------#
#    ---> Concerne le parametrage tarifs achats PPRICCONF             #
#---------------------------------------------------------------------#
# CRIITM = concatenation des no de criteres concernant l'article      #
# CRIBPR = concatenation des no de criteres concernant le fournisseur #
#---------------------------------------------------------------------#
$TRT_PPC  
Local File =[F:ADS]DOSSIER+".PPRICCONF" [PPC]
#-----
If WTRACE
  If WSIMUL
   Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
  Else
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
  #-----
  Call ECR_TIME("UTITRC6 : Supplier Prices Process 1 : Update PPRICCONF") From DOSSUB
Endif
#-----
Raz COMPTEUR, NBENR, NBCOR
Trbegin [PPC]
  For [PPC] PPC0
    Raz WFLAG1
    NBENR+=1 
    Raz WCRIITM_A, WCRIBPR_A
    #----- Les champs de la table ITMBPS sont des critères articles et fournisseurs -----#
    #----- Recherche des champs des tables ITMSALES, ITMBPC, BPCUSTOMER pour intersociété
    For I=0 To dim([F:PPC]FIL)-1
      If find([F:PPC]FIL(I),"ITMMASTER","ITMBPS","ITMSALES","ITMBPC") 
        WCRIITM_A+=num$(I+1) 
      Endif
      If find([F:PPC]FIL(I),"BPARTNER","BPSUPPLIER","ITMBPS","BPCUSTOMER","ITMBPC") 
        WCRIBPR_A+=num$(I+1) 
      Endif
    Next I
    #-----
    If [F:PPC]CRIITM<>val(WCRIITM_A)
      If WTRACE=2
        WMSG=[F:PPC]PLI-"- CRIITM    :"-num$([F:PPC]CRIITM)-"-->"-num$(val(WCRIITM_A))
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:PPC]CRIITM=val(CRIITM_A) : WFLAG1=1
    Endif

    If [F:PPC]CRIBPR<>val(WCRIBPR_A)
      If WTRACE=2
        WMSG=[F:PPC]PLI-"- CRIBPR    :"-num$([F:PPC]CRIBPR)-"-->"-num$(val(WCRIBPR_A))
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:PPC]CRIBPR=val(WCRIBPR_A) : WFLAG1=1
    Endif
    #-----
    If WFLAG1
      NBCOR+=1
      Rewrite [PPC]
      If fstat & WTRACE
         Call ECR_TRACE("File PPRICCONF, Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
  Next
If WSIMUL  Rollback  Else  Commit : Endif
Close Local File [PPC]
#-----
If WTRACE
  WMSG ="UTITRC6 : Number of processed records :"-num$(NBENR)
  WMSG+=" corrected :"-num$(NBCOR)
  Call ECR_TIME(WMSG) From DOSSUB
Endif
Return


#---------------------------------------------------------------#
#    ---> Concerne les lignes tarifs achats PPRICLIST           #
#---------------------------------------------------------------#
# Chargement des 5 critères dans les champs PLICRI1 --> PLICRI5 #
#----------------------------------------------------------------#
$TRT_PPL  
Local File =[F:ADS]DOSSIER+".PPRICLIST" [PPL]
#-----
If WTRACE
  If WSIMUL
   Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
  Else
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
  #-----
  Call ECR_TIME("UTITRC6 : Supplier Prices Process 2 : Update PPRICLIST") From DOSSUB
Endif
#-----
Raz CLE1, CLE2, CLE3, STOP, NBENR, NBCOR
#-----
$BOUCLE_PPL 
If STOP=1
  CRITERE='PLI="'+CLE1+'" & PLICRD="'+CLE2+'" & PLILIN>'+num$(CLE3)
  STOP=2
Elsif STOP=2
  CRITERE='PLI="'+CLE1+'" & PLICRD>"'+CLE2+'"'
   STOP=3
Elsif STOP=3
  CRITERE='PLI>"'+CLE1+'"'
  STOP=0
Else
  CRITERE="1=1"
Endif
Raz COMPTEUR
Trbegin [PPL]
  For [PPL] PPL0 Where evalue(CRITERE)
    Raz WFLAG1
    NBENR+=1
    #----- Eclatement des critères -----#
    WPLICRI=[F:PPL]PLICRI
    Raz J
    While instr(1,WPLICRI,"~")
      I=instr(1,WPLICRI,"~")
      J+=1
      Case J
        When 1 : WPLICRI1=left$(WPLICRI,I-1)
        When 2 : WPLICRI2=left$(WPLICRI,I-1)
        When 3 : WPLICRI3=left$(WPLICRI,I-1)
        When 4 : WPLICRI4=left$(WPLICRI,I-1)
        When 5 : WPLICRI5=left$(WPLICRI,I-1)
      Endcase
      WPLICRI=(right$(WPLICRI,I+1))
    Wend
    If [F:PPL]PLICRI1<>WPLICRI1
      If WTRACE=2
        WMSG=[F:PPL]PLI-[F:PPL]PLICRD-num$([F:PPL]PLILIN)-"- PLICRI1   :"-[F:PPL]PLICRI1-"-->"-WPLICRI1
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:PPL]PLICRI1=WPLICRI1 : WFLAG1=1
    Endif
    If [F:PPL]PLICRI2<>WPLICRI2
      If WTRACE=2
        WMSG=[F:PPL]PLI-[F:PPL]PLICRD-num$([F:PPL]PLILIN)-"- PLICRI2   :"-[F:PPL]PLICRI2-"-->"-WPLICRI2
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:PPL]PLICRI2=WPLICRI2 : WFLAG1=1
    Endif
    If [F:PPL]PLICRI3<>WPLICRI3
      If WTRACE=2
        WMSG=[F:PPL]PLI-[F:PPL]PLICRD-num$([F:PPL]PLILIN)-"- PLICRI3   :"-[F:PPL]PLICRI3-"-->"-WPLICRI3
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:PPL]PLICRI3=WPLICRI3 : WFLAG1=1
    Endif
    If [F:PPL]PLICRI4<>WPLICRI4
      If WTRACE=2
        WMSG=[F:PPL]PLI-[F:PPL]PLICRD-num$([F:PPL]PLILIN)-"- PLICRI4   :"-[F:PPL]PLICRI4-"-->"-WPLICRI4
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:PPL]PLICRI4=WPLICRI4 : WFLAG1=1
    Endif
    If [F:PPL]PLICRI5<>WPLICRI5
      If WTRACE=2
        WMSG=[F:PPL]PLI-[F:PPL]PLICRD-num$([F:PPL]PLILIN)-"- PLICRI5   :"-[F:PPL]PLICRI5-"-->"-WPLICRI5
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
      [F:PPL]PLICRI5=WPLICRI5 : WFLAG1=1
    Endif
    #-----
    If WFLAG1
      COMPTEUR+=1 : NBCOR+=1
      [F:PPL]UPDDAT=date$ : [F:PPL]UPDUSR=GUSER
      Rewrite [PPL]
      If fstat & WTRACE
        Call ECR_TRACE("File PPRICLIST"-[F:PPL]PLI-[F:PPL]PLICRD-num$([F:PPL]PLILIN)+", Error ="-num$(fstat),1) From GESECRAN
      Endif
    Endif
    If COMPTEUR>GMAXUPDTRS
      CLE1=[F:PPL]PLI : CLE2=[F:PPL]PLICRD : CLE3=[F:PPL]PLILIN : STOP=1 : Break
    Endif
  Next
If WSIMUL  Rollback  Else  Commit : Endif
If STOP Goto BOUCLE_PPL : Endif
#-----
Close Local File [PPL]
If WTRACE
  WMSG ="UTITRC6 : Number of processed records :"-num$(NBENR)
  WMSG+=" corrected :"-num$(NBCOR)
  Call ECR_TIME(WMSG) From DOSSUB
Endif
Return


#---------------------------------------------------------------#
#    ---> Concerne les descriptions de frais généraux  OVERHEAD #
#---------------------------------------------------------------#
# Initialisation de la base pour formule (champ FORBASIS)       #
#---------------------------------------------------------------#
$TRT_OVE
Local File =[F:ADS]DOSSIER+".OVERHEAD"  [OVE]
#-----
If WTRACE
  If WSIMUL
   Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
  Else
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
  #-----
  Call ECR_TIME("UTITRC6 : Overhead Formula basis Process : Update FORBASIS") From DOSSUB
Endif
#-----
Raz COMPTEUR, NBENR, NBCOR
Trbegin [OVE]
For [OVE]
  Raz WFLAG1
  NBENR+=1
  If [F:OVE]FORBASIS=0
    If WTRACE=2
      WMSG=[F:OVE]OVECOD-"- FORBASIS  : 0 --> 1"
      Call ECR_TRACE(WMSG,0) From GESECRAN
    Endif
    [F:OVE]FORBASIS=1 : WFLAG1=1
  Endif
  If WFLAG1
    NBCOR+=1
    Rewrite [OVE]
    If fstat & WTRACE
      Call ECR_TRACE("File OVERHEAD"-[F:OVE]OVECOD +", Error ="-num$(fstat),1) From GESECRAN
    Endif
  Endif
Next
If WSIMUL  Rollback  Else  Commit : Endif
Close Local File [OVE]
#-----
If WTRACE
  WMSG ="UTITRC6 : Number of processed records :"-num$(NBENR)
  WMSG+=" corrected :"-num$(NBCOR)
  Call ECR_TIME(WMSG) From DOSSUB
Endif
Return


#-------------------------------------------------------------#
#    ---> Concerne les adresses BPADDRESS                     #
#-------------------------------------------------------------#
# Initialisation de l'indicateur adresse par défaut BPAADDFLG #
#-------------------------------------------------------------#
$TRT_BPA
#-----
WSIMUL=1 : # On force la simulation car cette moulinette semble faire plus de mal que de bien
#-----
Local File =[F:ADS]DOSSIER+".BPADDRESS"   [BPA]
Local File =[F:ADS]DOSSIER+".BPARTNER"    [BPR]
Local File =[F:ADS]DOSSIER+".COMPANY"     [CPY]
Local File =[F:ADS]DOSSIER+".FACILITY"    [FCY]
Local File =[F:ADS]DOSSIER+".AUTILIS"     [AUS]
Local File =[F:ADS]DOSSIER+".GACCOUNT"    [GAC]
#-----
If WTRACE
  If WSIMUL
   Call ECR_TRACE("***** Simulation"-string$(63,"-"),0) From GESECRAN
  Else
   Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
  #-----
  Call ECR_TIME("UTITRC6 : Address Process : Update BPADDRESS") From DOSSUB
Endif
#-----
Local Char     CLE2(15), CLE3(3), CRITERE(60), WADR(3), WNUM(21)
Local Integer  CLE1,    WFLAG
#-----
Raz CLE1, CLE2, CLE3, STOP, NBENR, NBCOR
#-----
$BOUCLE_BPA
If  STOP=1
  CRITERE = 'BPATYP='+num$(CLE1)+' & BPANUM="'+CLE2+'" & BPAADD>"'+CLE3+'"'
  STOP = 2
Elsif STOP=2
  CRITERE = 'BPATYP='+num$(CLE1)+' & BPANUM>"'+CLE2+'"'
  STOP = 3
Elsif STOP=3
  CRITERE = 'BPATYP>'+num$(CLE1)
  STOP = 0
Else
  CRITERE = "1=1" 
Endif
Raz COMPTEUR
#-----
Trbegin [BPA]
  For [BPA] BPA0 Where evalue(CRITERE)
    WNUM=num$([F:BPA]BPATYP)-[F:BPA]BPANUM-[F:BPA]BPAADD
    NBENR+=1
    Raz WADR
    Case [F:BPA]BPATYP
      When 1 : #----- Tiers -----#
        If [F:BPR]BPRNUM<>[F:BPA]BPANUM
          Read [BPR] BPR0=[F:BPA]BPANUM   : If fstat  Raz [F:BPR] : Endif
        Endif
        WADR=[F:BPR]BPAADD
      When 2 : #----- Société -----#
        If [F:CPY]CPY<>[F:BPA]BPANUM
          Read [CPY] CPY0=[F:BPA]BPANUM   : If fstat  Raz [F:CPY] : Endif
        Endif
        WADR=[F:CPY]BPAADD
      When 3 : #----- Site -----#
        If [F:FCY]FCY<>[F:BPA]BPANUM
          Read [FCY] FCY0=[F:BPA]BPANUM   : If fstat  Raz [F:BPR] : Endif
        Endif
        WADR=[F:FCY]BPAADD
      When 4 : #----- Utilisateur -----#
        If [F:AUS]USR<>[F:BPA]BPANUM
          Read [AUS] CODUSR=[F:BPA]BPANUM : If fstat  Raz [F:AUS] : Endif
        Endif
        WADR=[F:AUS]BPAADD
      When 5 : #----- Compte -----#
        If [F:GAC]ACC<>[F:BPA]BPANUM
          Read [GAC] GAC0=[F:BPA]BPANUM   : If fstat  Raz [F:GAC] : Endif
        Endif
        WADR=[F:GAC]BPAADD
    Endcase
    If [F:BPA]BPAADD=WADR  WFLAG=2  Else  WFLAG=1 : Endif
    #----- Mise à jour de l'indicateur "Adresse par défaut" -----#
    If [F:BPA]BPAADDFLG<>WFLAG
      COMPTEUR+=1 : NBCOR+=1
      [F:BPA]BPAADDFLG=WFLAG
      Rewrite [BPA]
      If WTRACE
        If fstat
          Call ECR_TRACE("File BPADDRESS, Error ="-num$(fstat),1) From GESECRAN
        Else
          Call ECR_TRACE(WNUM-"BPAADDFLG set to"-num$(WFLAG),0) From GESECRAN
        Endif
      Endif
      COMPTEUR+=1
    Endif
    If COMPTEUR>GMAXUPDTRS
      CLE1=[F:BPA]BPATYP : CLE2=[F:BPA]BPANUM : CLE3=[F:BPA]BPAADD : STOP=1 : Break
    Endif
  Next
If WSIMUL  Rollback  Else  Commit : Endif
#-----
If STOP  Goto BOUCLE_BPA : Endif
Close Local File [BPA], [BPR], [CPY], [FCY],[AUS], [GAC]
#-----
If WTRACE
  WMSG ="UTITRC6 : Number of processed records :"-num$(NBENR)
  WMSG+=" corrected :"-num$(NBCOR)
  Call ECR_TIME(WMSG) From DOSSUB
Endif
Return


###################################################
# Pour exécution automatique  en gestion de patch #
###################################################
Subprog PATCH(DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
If !clalev([F:ADS])  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=DOSSIER : If fstat  Raz [F:ADS] : Endif
#-----
Call ECR_TRACE("UTITRC6 - Réajustement tables tronc commun en v6",0) From GESECRAN
Call EXE_UTITRC6(DOSSIER,1,0)
#-----       
End


#########################################################
# Pour exécution depuis DOSMAJ au changement de version #
#########################################################
Subprog UTI_MOUL(DOSSIER)
Value Char DOSSIER
#-----
If DOSSIER=GDOSX3  End : Endif
#-----
Call ECR_TRACE("UTITRC6 - Réajustement tables tronc commun en v6",0) From GESECRAN
Call EXE_UTITRC6(DOSSIER,1,0)
#-----
End
