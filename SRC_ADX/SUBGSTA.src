#<AdxTL>@(#)0.0.0.0 $Revision$ 


$ACTION

  Case ACTION
    When 'BOUTON' : Gosub BOUTON
    When 'FIN'  : Gosub FIN
    When 'OUVRE'  : Gosub OUVRE
    When 'OK' : Gosub OK
  Endcase
Return

#-----------------------------------------------------------------------------#
$FIN

Return

#-----------------------------------------------------------------------------#
$OUVRE
  Infbox mess(51,7704,1)-mess(52,7704,1) Titled mess(66,123,1)
Return
#-----------------------------------------------------------------------------#
$OK


Return
#-----------------------------------------------------------------------------#

$BOUTON
  Case BOUT
    When 'R' : Gosub GENREPORT
    When 'S' : Gosub SEARCH
  Endcase
Return
#-----------------------------------------------------------------------------#

$SEARCH
Local Char FSTRING(255)
If clalev([F:GHR]) = 0 Local File GSTHDR[GHR] : Endif

#clear grid
Raz [M:GSTA]NBLIG
Affzo [M:GSTA]

FSTRING = 'RPTTYP = 1 '

#if company is selected
If [M:GSTA]SCPY <> ''
  #FSTRING += 'and (FCPY >= [M:GSTA]CPY and TCPY <= [M:GSTA]CPY)'
  FSTRING += 'and (CPY = [M:GSTA]SCPY)'#  and [M:GSTA]CPY <= CPY)'
Endif

#if site is selected
If [M:GSTA]SFCY <> ''
  FSTRING += 'and (FCY = [M:GSTA]SFCY)'# and [M:GSTA]FCY <= FCY)'
Endif

#if report number is selected
If [M:GSTA]SRPTNUM <> ''
  FSTRING += ' and (RPTNUM = [M:GSTA]SRPTNUM)'
Endif

#if date is selected
If num$([M:GSTA]DAT) <> '00/00/0000'
  FSTRING += ' and (RUNDAT = [M:GSTA]DAT)'
Endif

#If FSTRING <> ''
  Filter[F:GHR] Where evalue(FSTRING)
#Else
#  Filter[F:GHR] Where RPTTYP = 1
#Endif

nolign = 0
For [F:GHR]
  nolign +=1
  [M:GSTA] = [F:GHR]
Next

#Filter[F:GHR]

[M:GSTA]NBLIG = nolign

Affzo [M:GSTA]

Return


$GENREPORT

Local Integer RPT
Local Integer NBPAR_MAX : NBPAR_MAX=10
Local Char XTBPAR(20)(1..NBPAR_MAX)
Local Char XTBVAL(250)(1..NBPAR_MAX)
Local Char XREPNUM : XREPNUM = 'AUSGST'
Local Char XDESTINATION : XDESTINATION = 'PREVIEW' #3 PREVISU / MESSPDF
#find the selected report.
RPT = find(2,[M:GSTA]SELECT)

If RPT > 0
  #Infbox [M:GSTA]RPTNUM(RPT-1)
  XTBPAR(1)="RPTNUM" : XTBVAL(1) = [M:GSTA]RPTNUM(RPT-1)
  Call ETAT(XREPNUM,"",XTBPAR,XTBVAL) From ETAT
 #Call ETAT(XREPNUM, XDESTINATION,"",0,"",XTBPAR,XTBVAL) From AIMP3

Call GENLOG([M:GSTA]RPTNUM(RPT-1))

Endif

Return

#-----------------------------------------------------------------------------#
Subprog AM_SELECT(VALEUR)
Variable Integer VALEUR

Local Integer RPT
If VALEUR = 2
  RPT = find(2,[M:GSTA]SELECT) - 1
    If RPT > 0
     GMESSAGE  = mess(13,7704,1)
     GERR = 1
     VALEUR = 1
   Endif
Endif


End

#-----------------------------------------------------------------------------#
Subprog AS_SELECT(VALEUR)
Variable Integer VALEUR

End
#-----------------------------------------------------------------------------#

Subprog GENLOG(L_RPTNUM)
Value Char L_RPTNUM

Local Char     SFCY(GLONFCY)
Local Char     SCPY(GLONCPY)
Local Char     RPTTYP
Local Char     DETAIL(250)

If clalev([F:GHR]) = 0 Local File GSTHDR[GHR] : Endif
If clalev([F:GDL]) = 0 Local File GSTDTL[GDL] : Endif

Read[F:GHR]GHR0 = L_RPTNUM

If fstat <> 0
  End
Endif

#open log file
 If !GSERVEUR :
    Call OUVRE_TRACE (time$ + "GST Archive Report Log file") From LECFIC
Else
     Call ECR_TRACE (time$ + "GST Archive Report Log file",0) From GESECRAN
Endif

If [F:GHR]ALLCPY= 2
  SCPY = 'ALL'
Else
  SCPY = [F:GHR]CPY
Endif

If [F:GHR]ALLFCY = 2
  SFCY = 'ALL'
Else
  SFCY = [F:GHR]FCY
Endif

If [F:GHR]RPTTYP = 1
  RPTTYP = 'ACTUAL'
Else
  RPTTYP = 'SIMULATION'
Endif


Call ECR_TRACE('#########################################################################',0) From GESECRAN
Call ECR_TRACE('# Description       : GST Report Log file'+ space$(50-len('GST Report Log file'))+'#',0) From GESECRAN
Call ECR_TRACE('# Creation date     : ' + date$ + space$(52-len(num$(date$)))+'#',0) From GESECRAN
Call ECR_TRACE('# ----------------------------------------------------------------------#',0) From GESECRAN
Call ECR_TRACE('#                     ' + space$(50)+'#',0) From GESECRAN
Call ECR_TRACE('# Criteria          : '+ space$(50)+'#',0) From GESECRAN
Call ECR_TRACE('# Companies         : '+ SCPY + space$(50-len(SCPY))+'#',0) From GESECRAN
Call ECR_TRACE('# Sites             : '+ SFCY + space$(50-len(SFCY))+'#',0) From GESECRAN
Call ECR_TRACE('# Date From         : '+ [F:GHR]STRDAT + space$(52-len(num$([F:GHR]STRDAT)))+'#',0) From GESECRAN
Call ECR_TRACE('# Date To           : '+ [F:GHR]ENDDAT + space$(52-len(num$([F:GHR]ENDDAT)))+'#',0) From GESECRAN
Call ECR_TRACE('# Report Type       : '+ RPTTYP + space$(50-len(RPTTYP))+'#',0) From GESECRAN
Call ECR_TRACE('#                     ' + space$(50)+'#',0) From GESECRAN
Call ECR_TRACE('#                     ' + space$(50)+'#',0) From GESECRAN
Call ECR_TRACE('#-----------------------------------------------------------------------# ',0) From GESECRAN
Call ECR_TRACE('##########################################################################',0) From GESECRAN
Call ECR_TRACE('',0) From GESECRAN
Call ECR_TRACE('',0) From GESECRAN
#Call ECR_TRACE('#Detail             : '+ space$(50)+'#',0) From GESECRAN
#Call ECR_TRACE('#                     '+ space$(50)+'#',0) From GESECRAN

Filter [F:GDL] Where [F:GDL]RPTNUM = L_RPTNUM
For[F:GDL]

Raz DETAIL

DETAIL = + '# ' + [F:GDL]BPR
DETAIL += '   ' + [F:GDL]NUM
DETAIL += '   ' + num$([F:GDL]AMTATI * [F:GDL]SNS)
DETAIL += '   ' + num$([F:GDL]NETPRINOT * [F:GDL]SNS) #num$([F:GDL]NETPRINOT)
DETAIL += '   ' + num$([F:GDL]AMTVAT * [F:GDL]SNS) #num$([F:GDL]AMTVAT)
DETAIL += '   ' + [F:GDL]VAT #[F:GDL]VAT

If [F:GDL]AUS1AGSTSAL = '' and [F:GDL]AUS1BGSTPUR = '' and [F:GDL]AUSG10CAPPUR = '' and [F:GDL]AUSG11NCAPPU = '' and [F:GDL]AUSG1TOTSA = '' and [F:GDL]AUSG2EXPSAL = '' and [F:GDL]AUSG3GSTFRES = ''
  DETAIL += ' : No BAS label assigned'

  Call ECR_TRACE(' '+ DETAIL + space$(100-len(DETAIL))+'#',1) From GESECRAN
Else

  If [F:GDL]AUS1AGSTSAL <> ''
    DETAIL +=  ' : ' + [F:GDL]AUS1AGSTSAL
  Endif

  If [F:GDL]AUS1BGSTPUR <> ''
    DETAIL +=  ' : ' + [F:GDL]AUS1BGSTPUR
  Endif

  If [F:GDL]AUSG10CAPPUR <> ''
    DETAIL +=  ' : ' + [F:GDL]AUSG10CAPPUR
  Endif

  If [F:GDL]AUSG11NCAPPU <> ''
    DETAIL +=  ' : ' + [F:GDL]AUSG11NCAPPU
  Endif

  If [F:GDL]AUSG1TOTSA <> ''
    DETAIL +=  ' : ' + [F:GDL]AUSG1TOTSA
  Endif

  If [F:GDL]AUSG2EXPSAL <> ''
    DETAIL +=  ' : ' + [F:GDL]AUSG2EXPSAL
  Endif

  If [F:GDL]AUSG3GSTFRES <> ''
    DETAIL +=  ' : ' + [F:GDL]AUSG3GSTFRES
  Endif

  Call ECR_TRACE(' '+ DETAIL + space$(100-len(DETAIL))+'#',0) From GESECRAN

Endif

Next

Call ECR_TRACE('###########################################################################',0) From GESECRAN


#close log file
If !GSERVEUR : Call FERME_TRACE From LECFIC : Endif

#display log file
Call LEC_TRACE() From LECFIC

End

