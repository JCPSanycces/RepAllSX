###########################################################################################
# TRTX3BIVEN  Fonctions pour la Business Intelligence    Module Ventes                    #
# --------------------------------------------------------------------------------------- #
# GETLEG_SDHTYP  : Détermination de la législation retenue pour un type de livraison      #
# GETLEG_SOHTYP  : Détermination de la législation retenue pour un type de commande       #
# GETLEG_SRHTYP  : Détermination de la législation retenue pour un type de retour         #
# GETLEG_SIVTYP  : Détermination de la législation retenue pour un type de facture achat  #
# GETLEG_INVCND  : Détermination de la législation retenue pour une condition de fact.    # Issue 107888 - 2016-05-30 by CPO : Scheduled invoices object management
# --------------------------------------------------------------------------------------- #
###########################################################################################
Funprog GETLEG_SDHTYP(PSDHTYP,PLEG)
Value Char PSDHTYP
Value Char PLEG

Local Char WLEG(GLONADI)

  Raz WLEG
  If PSDHTYP <> "" Then
    If clalev([TSD])<=0 Then
      #--CPO 92324 V7.1: BI modification for data by legislation
      If GDOSSIER<>"" Then
        Local File =GDOSSIER+".TABSDHTYP" [TSD]
      Else
        Local File TABSDHTYP [TSD]
      Endif
    Endif
    #--Si dossier mono-lég, on retourne la
    Gosub INIT_WLEG From TRTX3BITC  # FGR 16/06/2014 : X3SUIVI98503
    fstat = 0 #--CPO 92324 V7.1: BI modification for data by legislation
    If func TRTX3BITC.GET_CPY_LEG(GDOSSIER, "TABSDHTYP", PLEG, PSDHTYP, WLEG) = [V]CST_AYES Then
      If WLEG <> "" Then
        If [F:TSD]SDHTYP <> PSDHTYP and [F:TSD]LEG <> WLEG Then
          #--CPO 92324 V7.1: BI modification for data by legislation
          Read [TSD]TSD0=PSDHTYP;WLEG
          If fstat
            Read [TSD]TSD0=PSDHTYP;""
          Endif
        Endif
      Else
        If [F:TSD]SDHTYP<>PSDHTYP Then
          #--CPO 92324 V7.1: BI modification for data by legislation
          Read [TSD]TSD0(1)=PSDHTYP
        Endif
      Endif
      If !fstat Then
        WLEG = [F:TSD]LEG
      Else
        Raz WLEG
      Endif
      Call ADD_CPY_LEG(GDOSSIER, "TABSDHTYP", PLEG, PSDHTYP, WLEG) From TRTX3BITC
    Endif
  Endif
End WLEG

