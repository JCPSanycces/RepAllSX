Subprog C_VATVAC(VALEUR)
Variable Char    VALEUR()
#--71937 CPO Contrôle de cohérence fait par le type de donnée TVB
#If VALEUR <> ''
# #-- 71937 Coherence de groupe & Multi-lég
# Local Integer WRET
# If !clalev([F:TVB])  Local File TABVACBPR [TVB] : Endif
#
# Call LEC_TVB_LEG([M:TVT1]LEG,VALEUR ,WRET)        From TRTLECLEG
# If WRET
