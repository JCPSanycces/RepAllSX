######################################################################################
Subprog AM_VATVAC(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  #-- X3Suivi 71937 : Données par législation pour la détermination de la taxe
  #Filter [TVC] Where VAT=[M]VAT & VACBPR<>"" & VACBPR<>VALEUR & ENAFLG=2
  #--CPO 71937 TVT Il faut chercher la même LEG
  #Filter [TVC] Where VAT=[M]VAT & VACBPR<>"" & VACBPR<>VALEUR & ( LEG="" or LEG=[M]LEG) & ENAFLG=2
  Filter [TVC] Where VAT=[M]VAT & VACBPR<>"" & VACBPR<>VALEUR & ( LEG=[M]LEG) & ENAFLG=2
  #Read [TVC] TVC0 First
  Read [TVC] TVC0 Last
  Filter [TVC]
  If !fstat
  #--CPO 71937 TVT et multi-lèg
  #GMESSAGE=VALEUR-mess(544,199,1)-[F:TVC]COD : GERR=1 : mkstat=1 : End
  If [F:TVC]LEG<>""
    GMESSAGE=VALEUR-mess(544,199,1)-[F:TVC]COD-mess(238,133,1)-[F:TVC]LEG : GERR=1 : mkstat=1 : End
    Else
      GMESSAGE=VALEUR-mess(544,199,1)-[F:TVC]COD-'"'+mess(91,187,1)+'"' : GERR=1 : mkstat=1 : End
Endif
#--/CPO
  Endif
Endif
End

########################################
Subprog AM_GRP(VALEUR)
Variable Char    VALEUR()
Local Integer I
GGRPFCY = VALEUR
If VALEUR<>""
#-- X3Suivi 71937 : Données par législation pour la détermination de la taxe
  #Filter [TVC] Where VAT=[M]VAT & GRP<>"" & GRP<>VALEUR & ENAFLG=2
  #--CPO 71937 TVT Il faut chercher la même LEG
  #Filter [TVC] Where VAT=[M]VAT & GRP<>"" & GRP<>VALEUR & ( LEG="" or LEG=[M]LEG) & ENAFLG=2
  Filter [TVC] Where VAT=[M]VAT & GRP<>"" & GRP<>VALEUR & ( LEG=[M]LEG) & ENAFLG=2
  #Read [TVC] TVC0 First
  Read [TVC] TVC0 Last
  Filter [TVC]
  If !fstat
  #--CPO 71937 TVT et multi-lèg
    #GMESSAGE=VALEUR-mess(549,199,1)-[F:TVC]COD : GERR=1 : mkstat=1 : End
  If [F:TVC]LEG<>""
    GMESSAGE=VALEUR-mess(549,199,1)-[F:TVC]COD-mess(238,133,1)-[F:TVC]LEG : GERR=1 : mkstat=1 : End
    Else
      GMESSAGE=VALEUR-mess(549,199,1)-[F:TVC]COD-'"'+mess(91,187,1)+'"' : GERR=1 : mkstat=1 : End
Endif
#--/CPO
  Endif
  #--Afin de relancer les contrôles sur les sociétés saisies pour les taux de taxe
For I=0 To [M:TVT1]NBRRAT-1
If [M:TVT1]CPY(I)<>""
Call CONTSOC ([M:TVT1]CPY(I)) From SUBAGF
  If mkstat : GERR=1 : End Endif
Endif
Next I
Endif
End

########################################
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
Local Integer NOL , I
NOL = nolign-1
For I=0 To [M]NBRRAT-1
 If I<>NOL & VALEUR=[M]STRDAT(I) & [M]CPY(I)=[M]CPY(NOL)
  GERR=1
  GMESSAGE = mess(29,100,1)-num$(I+1) : # Code déjà saisi en ligne
  mkstat = 2 : Break
 Endif
Next I
End

#####################################################
## Calcul des taxes                                ##
#####################################################
## X3BY sera a compléter pour les pays étrangers....
#####################################################
Subprog CALTAXE(SOCIETE,DAT,REGIME,DEVISE
& ,NBTAXE,TAXES,TYPBASE,BASE,MONTANT,MONTDED,TYPREG,STAT)
Value    Char    SOCIETE          : # Société
Value    Date    DAT              : # Date de pièce
Value    Char    REGIME           : # Code régime (non utilisé)
Value    Char    DEVISE           : # Devise de facturation à cause de l'EURO
Value    Integer NBTAXE           : # Nb de taxes
Value    Char    TAXES()(1..)     : # Codes des taxes
Value    Integer TYPBASE          : # Base HT ou TTC
Value    Decimal BASE             : # Base
Variable Decimal MONTANT(1..)     : # Montant des taxes
Variable Decimal MONTDED(1..)     : # Montant déductible
Variable Integer TYPREG           : # Type de régime
Variable Integer STAT             : # Statut de retour
Local Integer CAS
CAS = 1 : Gosub CAL_TAXE
End

#####################################################
## Calcul des taxes : utilisé pour les achats      ##
#####################################################
## X3BY sera a compléter pour les pays étrangers....
#####################################################
Subprog CALTAXE2(SOCIETE,DAT,REGIME,DEVISE
& ,NBTAXE,TAXES,TYPBASE,BASE,OTHBASE,MONTANT,MONTDED,TYPREG,STAT)
Value    Char    SOCIETE          : # Société
Value    Date    DAT              : # Date de pièce
Value    Char    REGIME           : # Code régime (non utilisé)
Value    Char    DEVISE           : # Devise de facturation à cause de l'EURO
Value    Integer NBTAXE           : # Nb de taxes
Value    Char    TAXES()(1..)     : # Codes des taxes
Value    Integer TYPBASE          : # Base HT ou TTC
Value    Decimal BASE             : # Base
Value    Decimal OTHBASE(1..)     : # Autres bases 1 à 7 (parafiscale, spéciale ..etc)
Variable Decimal MONTANT(1..)     : # Montant des taxes
Variable Decimal MONTDED(1..)     : # Montant déductible
Variable Integer TYPREG           : # Type de régime
Variable Integer STAT             : # Statut de retour
Local Integer CAS
CAS = 2 : Gosub CAL_TAXE
End

#####################################################
## Calcul des taxes avec gestion des exonérations  ##
#####################################################
## X3BY sera a compléter pour les pays étrangers....
#####################################################
Subprog CALTAXE3(SOCIETE,CLIENT,DAT,REGIME,DEVISE
& ,NBTAXE,TAXES,TYPBASE,BASE,MONTANT,MONTDED,EXEAMTTAX,TYPREG,STAT)
Value    Char    SOCIETE          : # Société
Value    Char    CLIENT           : # Code client
Value    Date    DAT              : # Date de pièce
Value    Char    REGIME           : # Code régime (non utilisé)
Value    Char    DEVISE           : # Devise de facturation à cause de l'EURO
Value    Integer NBTAXE           : # Nb de taxes
Value    Char    TAXES()(1..)     : # Codes des taxes
Value    Integer TYPBASE          : # Base HT ou TTC
Value    Decimal BASE             : # Base
Variable Decimal MONTANT(1..)     : # Montant des taxes
Variable Decimal MONTDED(1..)     : # Montant déductible
Variable Decimal EXEAMTTAX(1..)   : # Montant exonération
Variable Integer TYPREG           : # Type de régime
Variable Integer STAT             : # Statut de retour
Local Integer CAS
CAS = 3 : Gosub CAL_TAXE
End

$CAL_TAXE
## TYPBASE = 1 : Base HT
## TYPBASE = 2 : Base TTC

## TYPREG = 1 : Normal, il faut appliquer les taxes
## TYPREG = 2 : Export, il ne faut pas appliquer les taxes
## TYPREG = 3 : Suspension de taxes, il ne faut pas appliquer les taxes
## TYPREG = 4 : CEE, cas spécial selon achat/vente

## STAT = 0 : RAS TVB
## STAT = 1 : Un code taxe n'existe pas
## STAT = 2 : Y'a pas de taux applicable
## STAT = 3 : Type de base incorrect
## STAT = 4 : Il y a 2 taxes de type TVA
## STAT = 5 : Code régime inexistant
## STAT = 6 : Société ou site inexistant
## STAT = 7 : Taxes de régime différents

If clalev([F:TVT])=0 : Local File TABVAT    [TVT] : Endif
If clalev([F:TRA])=0 : Local File TABRATVAT [TRA] : Endif
If clalev([F:TCU])=0 : Local File TABCUR    [TCU] : Endif
#If clalev([F:ADI])=0 : Local File ATABDIV   [ADI] : Endif : # 71937 : Multilégislation
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
If clalev([F:TVB])=0 : Local File TABVACBPR [TVB] : Endif  : # 71937 : Multilégislation


Local Libelle TYPTAX(1..NBTAXE)
Local Libelle SOUMIS(1..NBTAXE)
Local Libelle BASVAT(1..NBTAXE) : # MBT 22/07/2003
Local Char    TAX(GLONVAT) , COMPANY(GLONCPY) , DEVLED(GLONCUR)
Local Decimal TAUX1 , TAUX2 , MONTANT1 , MONTANT2 , BASTVA , BASTAX
Local Integer NTVA , I , TABNUM
Local Integer WRET:#--CPO 71937 TVT et multi-lég

TABNUM = 1 : # Table diverse des codes régime de taxe
Raz MONTANT , MONTDED , TYPREG , STAT
# Issue 74556 - 2011-06-30 by VPO : lecture ssi besoin
#Call LECTURE("TCU",DEVISE,"") From CONTOBJ
If [F:TCU]CUR<>DEVISE
    Read [TCU]TCU0=DEVISE : If fstat  Raz [F:TCU] : Endif
Endif

# La société est-elle une société ou un site ??
I = find(SOCIETE,GSOC(1..GNBSOC))
If I
 COMPANY = SOCIETE
Else
 I = find(SOCIETE,GSITE(1..GNBSITE))
 If I
  COMPANY = GSOCSITE(I)
 Else
  STAT = 6 : Return : # Perdu!!
 Endif
Endif

# Issue 74556 - 2011-06-30 by VPO : lecture ssi besoin
#Call LECTURE("CPY",[L]COMPANY,"") From CONTOBJ
If [F:CPY]CPY<>[L]COMPANY
  Read [CPY] CPY0=[L]COMPANY : If fstat  Raz [F:CPY] : Endif
Endif
Call SETCUR(1,[F:CPY]CPY,DEVLED) From CPTDIV

# Lecture des taxes
REGIME = ""
For I=1 To NBTAXE
 If TAXES(I)<>""
  # Issue 74556 - 2011-07-05 by VPO : lecture ssi besoin
  #If [F:TVT]VAT<>TAXES(I)
  #  Read [TVT]TVT0 = TAXES(I)
  #  If fstat : STAT = 1 : Break : Endif
  #Endif
  #--CPO 71937 TVT et multi-lég
  #Call LEC_TVT_LEG([F:CPY]LEG,TAXES(I)) From CPTLEC
  Raz WRET
  Call LEC_TVT_LEG([F:CPY]LEG,TAXES(I),WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : STAT = 1 : Break : Endif
  #--/CPO
  TYPTAX(I) = [F:TVT]VATTYP
  SOUMIS(I) = [F:TVT]VATCHA
  BASVAT(I) = [F:TVT]VATBAS : # MBT 22/07/2003
  If REGIME=""
   REGIME = [F:TVT]VATVAC
  #Elsif REGIME<>[F:TVT]VATVAC                             : # MBT 04/06/2010
  Elsif REGIME<>[F:TVT]VATVAC & [F:TVT]VATVAC<>"" & CAS<>2 : # MBT 04/06/2010
   STAT = 7 : Break
  Endif
 Endif
Next I
If STAT : Return : Endif

# Type de régime applicable
If REGIME=""
 TYPREG = 1 : # Par défaut "normal"
Else
 # 71937 : Multilégislation
 # Issue 74556 - 2011-07-05 by VPO : lecture ssi besoin
 #If [F:ADI]NUMTAB<>TABNUM | [F:ADI]CODE<>REGIME
 #  Read [ADI]CODE = TABNUM;REGIME
 #  If fstat : STAT = 5 : Return : Endif
 #Endif
 #TYPREG = [F:ADI]N1
 Local Integer WRET
 Call LEC_TVB_LEG(GCURLEG,REGIME,WRET) From TRTLECLEG
 If WRET Raz [F:TVB] : Endif
 TYPREG = [F:TVB]REGVAC
 # 71937 : Multilégislation
Endif

Case TYPBASE
 When 1       : Gosub CALNORM
 When 2       : Gosub CALINV :#Gosub CALINV2 #--CPO 84846 CALINV2 est le nouveau sous-pro (pas encore qualifié par l'équipe finance)
 When Default : STAT = 3 : Return
Endcase

Return

$CALNORM
# Calcul à partir d'un montant HT
# On commence par les taxes parafiscales
BASTVA = BASE
For I=1 To NBTAXE
 If TYPTAX(I)>1
  TAX    = TAXES(I)
  If CAS = 1 | CAS = 3
   BASTAX = BASE
  Elsif CAS = 2
   If BASVAT(I) > 1     : # MBT 09/02/2010
    BASTAX = OTHBASE(I) : # MBT 09/02/2010
   Else                 : # MBT 22/07/2003
    BASTAX = BASE       : # MBT 22/07/2003
   Endif
  Endif
  Gosub CALCUL
  If STAT : Break : Endif
  MONTANT(I) = MONTANT1
  MONTDED(I) = MONTANT2
  If SOUMIS(I)=2
   BASTVA += MONTANT(I)
  Endif
 Endif
Next I
If STAT : Return : Endif

# On peut maintenant calculer la TVA
NTVA = 0
For I=1 To NBTAXE
 If TYPTAX(I)=1
  If NTVA : STAT = 4 : Break : Endif
  TAX    = TAXES(I)
  BASTAX = BASTVA
  Gosub CALCUL
  If STAT : Break : Endif
  MONTANT(I) = MONTANT1
  MONTDED(I) = MONTANT2
 Endif
Next I
If STAT : Return : Endif
Return


$CALINV
# Calcul à partir d'un montant TTC
# On commence par les taxes parafiscales non soumises
BASTVA = BASE
For I=1 To NBTAXE
 If TYPTAX(I)>1 & SOUMIS(I)<>2
  TAX    = TAXES(I)
  If CAS = 1
   BASTAX = BASTVA
  Elsif CAS = 2
   If BASVAT(I) > 1     : # MBT 09/02/2010
    BASTAX = OTHBASE(I) : # MBT 09/02/2010
   Else                 : # MBT 22/07/2003
    BASTAX = BASTVA     : # MBT 22/07/2003
   Endif
  Endif
  Gosub CALCUL2
  If STAT : Break : Endif
  MONTANT(I) = MONTANT1
  MONTDED(I) = MONTANT2
  BASTVA -= MONTANT1
 Endif
Next I
# Ensuite la TVA
NTVA = 0
For I=1 To NBTAXE
 If TYPTAX(I)=1
  If NTVA : STAT = 4 : Break : Endif
  TAX    = TAXES(I)
  BASTAX = BASTVA
  Gosub CALCUL2
  If STAT : Break : Endif
  MONTANT(I) = MONTANT1
  MONTDED(I) = MONTANT2
  BASTVA -= MONTANT1
 Endif
Next I
If STAT : Return : Endif
# Puis enfin les taxes soumises
For I=NBTAXE To 1 Step -1
 If TYPTAX(I)>1 & SOUMIS(I)=2
  TAX    = TAXES(I)
  If CAS = 1
   BASTAX = BASTVA
  Elsif CAS = 2
   If BASVAT(I) > 1     : # MBT 09/02/2010
    BASTAX = OTHBASE(I) : # MBT 09/02/2010
   Else                 : # MBT 22/07/2003
    BASTAX = BASTVA     : # MBT 22/07/2003
   Endif
  Endif
  Gosub CALCUL2
  If STAT : Break : Endif
  MONTANT(I) = MONTANT1
  MONTDED(I) = MONTANT2
  BASTVA -= MONTANT1
 Endif
Next I
Return


$CALCUL
Gosub LECTAX
If STAT = 2 : Return : Endif
Call RNDTVA(BASTAX,TAUX1,[F:TCU]CURRND,MONTANT1)
Gosub EXONERATION
# Pour le montant déductible, quelle option ?
MONTANT2 = arr(MONTANT1*TAUX2/100,[F:TCU]CURRND)
Return

$CALCUL2
Gosub LECTAX
If STAT = 2 : Return : Endif
Call RNDTVA2(BASTAX,TAUX1,[F:TCU]CURRND,MONTANT1)
Gosub EXONERATION
# Pour le montant déductible, quelle option ?
MONTANT2 = arr(MONTANT1*TAUX2/100,[F:TCU]CURRND)
Return

$LECTAX
#--CPO 71937 TVT et multi-lèg
If [F:CPY]CPY<>COMPANY
Read [F:CPY]CPY0=COMPANY
If fstat : Raz [F:CPY] : Endif
Endif
#--/CPO
# Cas particulier société ??
Call LEC_TVT_LEG([F:CPY]LEG,TAX) From CPTLEC
Filter [TRA] Where CPY=COMPANY & VAT=TAX & STRDAT<=DAT & LEG=[F:TVT]LEG
Read [TRA]TRA0 Last
If fstat>2
# sinon on se rabat sur le code dossier
 Filter [TRA] Where CPY="" & VAT=TAX & STRDAT<=DAT & LEG=[F:TVT]LEG
 Read [TRA]TRA0 Last
 If fstat>2 : STAT = 2 : Return : Endif
Endif
TAUX1 = [F:TRA]VATRAT
TAUX2 = [F:TRA]DEDRAT

# Issue 102218  - 2014-10-02 by MUARN : PE pour le pourcentage déductible
#--------------------------------------------------------------#
# Point d'entrée MAJ_TAUX pour modif le pourcentage déductible #
# ------------------------------------------------------------ #
# Variable modifiable par le point d'entrée :                  #
# TAUX2 contient le pourcentage déductible                     #
GPOINT="MAJ_TAUX" : Gosub ENTREE From EXEFNC

Return

$EXONERATION
If CAS<>3 : Return : Endif
If MONTANT1=0 : EXEAMTTAX(I) = 0 : Endif
## En gestion des exonérations, on accepte par exemple d'avoir pour un client, une société et un code taxe de type TVA
## un taux éxonération de 10% et d'avoir pour tous les autres codes taxes de type TVA un taux d'éxonération de 20%. Dans
## ce cas, on pourra réaliser ce paramétrage en ne spécifiant pas de code taxe pour le second cas.
## Par conséquent, on tient compte de la priorité à donner pour la recherche de l'exonération :
## 1 °) On regarde d'abord s'il y a une exonération pour le client qui est spécifique à la société et au code taxe
If clalev([F:TEX])=0 : Local File TABVATEXE [TEX] : Endif
Local Decimal TSDMINFAC, TSDMAXFAC
Filter [TEX] Where BPCNUM = [L]CLIENT
&                & CPY = [L]SOCIETE & VAT=[L]TAX
&                & (STRDAT=[0/0/0] | STRDAT<=[L]DAT) & (ENDDAT=[0/0/0] | ENDDAT>=[L]DAT)
Read [TEX]TEX0 First
If fstat
 ## 2°) On regarde alors s'il y a une exonération pour le client qui est spécifique à la société (=pour un client,
 ## et une société une éxonération s'applique pour toute une catégorie de taxe)
 Filter [TEX] Where BPCNUM = [L]CLIENT
&              &    CPY = [L]SOCIETE & VAT="" & VATTYP = TYPTAX(I)
&                 & (STRDAT=[0/0/0] | STRDAT<=[L]DAT) & (ENDDAT=[0/0/0] | ENDDAT>=[L]DAT)
 Read [TEX]TEX0 First
 If fstat
  ## 3°) On regarde alors s'il y a une exonération pour le client qui est spécifique au code taxe mais valable pour toutes
  ## les sociétés
  If func AFNC.ACTIV("KAG") and func AFNC.PARAM("ARGEXO",[L]SOCIETE)="2" # Issue X3-107197
   Filter [TEX] Where BPCNUM = [L]CLIENT
&                   & CPY = "" & VAT=[L]TAX
&                   & (STRDAT=[0/0/0] | STRDAT<=[L]DAT) & (ENDDAT=[0/0/0] | ENDDAT>=[L]DAT)
   Read [TEX]TEX0 First
   If fstat
    ## 4°) On regarde alors s'il y a une exonération pour le client qui est spécifique qui est s'applique pour toute une
    ## catégorie de taxes et pour toutes les sociétés
    Filter [TEX] Where BPCNUM = [L]CLIENT
&                    & CPY = "" & VAT="" & VATTYP = TYPTAX(I)
&                    & (STRDAT=[0/0/0] | STRDAT<=[L]DAT) & (ENDDAT=[0/0/0] | ENDDAT>=[L]DAT)
    Read [TEX]TEX0 First
   Endif
  Endif
 Endif
Endif
Call CONVERT(GCURSHR,DEVISE,[L]DEVLED,GCHGTYP,[L]DAT,[F:TEX]TSDMIN,TSDMINFAC,STAT) From TRTDEV
If STAT
 Call ECR_TRACE(mess(4,109,1)-GCURSHR-"=>"-DEVISE,1) From GESECRAN
Endif
Call CONVERT(GCURSHR,DEVISE,[L]DEVLED,GCHGTYP,[L]DAT,[F:TEX]TSDMAX,TSDMAXFAC,STAT) From TRTDEV
If STAT
 Call ECR_TRACE(mess(4,109,1)-GCURSHR-"=>"-DEVISE,1) From GESECRAN
Endif
If BASTAX>=TSDMINFAC & ([F:TEX]TSDMAX=0 | BASTAX<=TSDMAXFAC)
 EXEAMTTAX(I) = arr(MONTANT1*[F:TEX]EXERAT/100,[F:TCU]CURRND)
 MONTANT1 = MONTANT1 - EXEAMTTAX(I)
Endif
Return


Subprog ERR_CALTAXE(STAT,MESSA)
Value Integer STAT
Variable Char MESSA()
Case STAT
 When 1 : MESSA = mess(37,119,1) : # Un code taxe n'existe pas
 When 2 : MESSA = mess(38,119,1) : # Il n'y a aucun taux applicable
 When 3 : MESSA = mess(39,119,1) : # Type de base incorrecte
 When 4 : MESSA = mess(40,119,1) : # Il y a deux taxes de type TVA
 When 5 : MESSA = mess(41,119,1) : # Code régime inexistant
 When 6 : MESSA = mess(21,104,1) : # Société ou site inexistant
 When 7 : MESSA = mess(42,119,1) : # Taxes de régimes différents
Endcase
End

##########################################
## Calcul du montant d'une taxe
##########################################
## 1) A partir du HT
##
Subprog RNDTVA(BASE,TAUX,ARROND,MONTANT)
Value    Decimal BASE
Value    Decimal TAUX
Value    Decimal ARROND
Variable Decimal MONTANT
Local Integer TYP
If dim([V]GVATRND)>0
 TYP = [V]GVATRND
Else
 TYP = 3
Endif

# Issue 117554 - 2016-08-12 by MUARN : gestion montant négatif
Local Integer SIGN
If BASE < 0
  SIGN =-1
  BASE = BASE * SIGN
Else
  SIGN = 1
Endif

Case TYP
 When 1       : # Supérieur
  MONTANT = -ARROND*int(-(BASE*TAUX)/(100*ARROND))
 When 2       : # Inférieur
  MONTANT = ARROND*int((BASE*TAUX)/(100*ARROND))
 When Default : # 5/4
  MONTANT = arr(BASE*TAUX/100,ARROND)
Endcase

# Issue 117554 - 2016-08-12 by MUARN : gestion montant négatif
If SIGN = -1
  MONTANT = MONTANT * SIGN
Endif
End
## 2) A partir du TTC
##
Subprog RNDTVA2(BASE,TAUX,ARROND,MONTANT)
Value    Decimal BASE
Value    Decimal TAUX
Value    Decimal ARROND
Variable Decimal MONTANT
Local Integer TYP
If dim([V]GVATRND)>0
 TYP = [V]GVATRND
Else
 TYP = 3
Endif
Case TYP
 When 1       : # Supérieur
  MONTANT = -ARROND*int(-(BASE-BASE/(1+TAUX/100))/ARROND)
 When 2       : # Inférieur
  MONTANT = ARROND*int((BASE-BASE/(1+TAUX/100))/ARROND)
 When Default : # 5/4
  MONTANT = arr(BASE-BASE/(1+TAUX/100),ARROND)
Endcase
End

