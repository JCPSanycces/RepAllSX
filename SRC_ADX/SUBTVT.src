Subprog AS_VATTYP(VALEUR)
Variable Integer VALEUR
#----- Si taxes Argentines ou taxes provinciales -----#
If func AFNC.ACTIV("KAG")=1 | func AFNC.ACTIV("PTX")=1
 GMENLOC(4) = 0
Else
 GMENLOC(4) = 1
Endif
End

Subprog AS_SAT(VALEUR)
Variable Char    VALEUR()
End

Subprog AM_SAT(VALEUR)
Variable Char    VALEUR()
If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
Read [ADI]CODE = 364 ; VALEUR
If !fstat
 [M]APLTAX = mess([F:ADI]N1,8500,1)
 Affzo APLTAX
Endif
End
#######################################################################
$SETBOUT
#------------------------------#
# Désactivation bouton "Copie" #
#------------------------------#
If GREP<>"" | !CLECUR
  Call VIREBOUT(CHAINE,"1") From GOBJET
Endif
#------------------------------#
#  Données légales/Législation #
#** Legal datas/Legislation    #
#------------------------------#
LEGOK=0
If [M:TVT1]LEG<>""
 fstat = 0
 If [F:ADI]NUMTAB<>959 or [F:ADI]CODE<>[M:TVT1]LEG
  Read [ADI]CODE = 959;[M:TVT1]LEG
 Endif
 If !fstat & [F:ADI]A3<>""
  If [F:AWI]WIN<>[F:ADI]A3
   Read [AWI]AWI0 = [F:ADI]A3
  Endif
  If !fstat
   LEGOK=1
  Endif
 Endif
Else
 ##  Si le code legislation est vide alors on lit la table diverse sur une
 #   législation (du dossier X3) pour laquelle une fenêtre est définie pour
 #   TVT dans la table diverse 959.
 ##
 #** If the legislation code is empty then we will use another legislation
 #*  (of the current X3 Folder) which present a window in the miscelleanous
 #*  table 959 for TVT.
 #*!
 fstat = 0
 If [F:ADS]DOSSIER<>nomap
  Read [ADS]DOSSIER = nomap
 Endif
 If !fstat
  Filter [ADI] Where NUMTAB=959 & find([F:ADI]CODE,[F:ADS]DOSLEG(0..dim([F:ADS]DOSLEG)-1)) & [F:ADI]A3<>""
  For [ADI]
   If [F:AWI]WIN<>[F:ADI]A3
    Read [AWI]AWI0 = [F:ADI]A3
   Endif
   If !fstat
    LEGOK=1 : Break
   Endif
  Next
  Filter [ADI]
 Endif
Endif
If REP="C" | REP="D" | !LEGOK
 Call VIREBOUT(CHAINE,"2") From GOBJET
Endif
Return

$FERME
#--CPO 71937
#If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
#If dim(SAV_GGRPFCY)>0 : GGRPFCY = SAV_GGRPFCY : Endif :#--CPO 71937
#------------------------------------#
# Restitution des variables globales #
#------------------------------------#
Gosub REST_GLOB From TRTX3GLOB
#--/CPO

# To manage the button Tunnel
#If TUNNEL<>1 | dim(VCOD)<1 : Return : Endif
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONVAT) : Endif

VCOD = CLE2

Return


#######################################################################
$TRTCOP
#-----------------------------------------------------------#
# Etiquette appelée depuis le traitement superviseur ACOPIE #
# --------------------------------------------------------- #
# Traitement de la copie d'un taux de taxe                  #
#-----------------------------------------------------------#
If [M]DOSORG=nomap
  Local File TABVAT    [TVT1]
  Local File TABRATVAT [TRA1]
  Local File ATEXTRA   [AXX1]
Else
  Local File =[M]DOSORG+".TABVAT"    [TVT1]
  Local File =[M]DOSORG+".TABRATVAT" [TRA1]
  Local File =[M]DOSORG+".ATEXTRA"   [AXX1]
Endif
If [M]DOSDES=nomap
  Local File TABVAT    [TVT2]
  Local File TABRATVAT [TRA2]
  Local File ATEXTRA   [AXX2]
  Local File ACTIV     [ACV2]
Else
  Local File =[M]DOSDES+".TABVAT"    [TVT2]
  Local File =[M]DOSDES+".TABRATVAT" [TRA2]
  Local File =[M]DOSDES+".ATEXTRA"   [AXX2]
  Local File =[M]DOSDES+".ATABDIV"   [ADI2]
  Local File =[M]DOSDES+".ACTIV"     [ACV2]
  Local File =func DOSCONT.DOSX3([M]DOSDES)+".ADOSSIER"  [ADS2]
Endif
Gosub OUVDOS  From ATEXTRA
## Multi-Lég... Vérifier que la législation existe dans le dossier destination
## Sous OUVDOS, le fichier ADOSSIER ADS2 du dossier destination est déjà en ligne
#If TABLE2<>"" & clalev([F:ADS2])>0 & !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1))
# Call MESSAGE(TABLE2 - ':' - mess(249,133,1) ) From GESECRAN  #:--CPO 71937 -- Législation non gérée par ce dossier --#
#   Return
#Endif

Call DEBTRANS From GLOCK
Gosub TRT_COPIE

Close Local File [TVT1], [TRA1], [AXX1], [TVT2], [TRA2], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
If clalev([F:ADI2])>0 : Close Local File [ADI2] : Endif
If clalev([F:ACV2])>0 : Close Local File [ACV2] : Endif

Return

$TRT_COPIE
#--------------------------------------------------#
# Transaction de copie d'un taux de taxe           #
#--------------------------------------------------#
Local Char    LEGDES
Local Integer WMONOLEGDES
# Par défaut : Leg destination=leg de l'enregistrement à copier
LEGDES=TABLE2
GOK=1
#--Quelques vérifications...
#If TABLE2<>''
# If [M]DOSDES<>nomap
#  Local Char SZDOSSIER(GLONADS)
#  Local Integer LG
#  Read [ADI2]CODE=909; TABLE2
#  If fstat
#   Call MESSAGE (TABLE2 - ':'- mess(173,187,1)  ) From GESECRAN : #-- Législation inexistante sur ce dossier --#
#   Return
#  Endif
# Endif
#Endif

If [M]DOSDES<>nomap
    # Le dossier destination est-il mono-leg ?
    If [F:ACV2]CODACT<>"LEG"
     Read [ACV2]CODACT = "LEG"
     If fstat Raz [F:ACV2] : Endif
    Endif
    If [F:ACV2]FLACT<>2
     WMONOLEGDES=0
    Else
     WMONOLEGDES=1
    Endif

    If WMONOLEGDES =0
        # Dossier destination mono-leg
        LG = instr(1, [M]DOSDES, "@")
        If LG = 0 Then
          SZDOSSIER = [M]DOSDES
        Else
          SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
        Endif
        Read [ADS2]DOSSIER=SZDOSSIER
        If fstat
            # Pb lecture dossier
            Call MESSAGE(SZDOSSIER-":"-mess(78,133,1) ) From GESECRAN  #-- Dossier inexistant --#
            Return
        Endif
        If [F:ADS2]DOSLEG(0)=""
            # Pas de législation pour le dossier
            Call MESSAGE(SZDOSSIER-":"-mess(241,133,1) ) From GESECRAN  #-- Il doit y avoir au moins une législation  --#
            Return
        Endif
        If TABLE2<>[F:ADS2]DOSLEG(0) & TABLE2<>''
            # La leg de l'enreg. à copier n'est pas tte leg et elle est <> Leg dossier mono-leg
            # Pas de copie
            Call MESSAGE(mess(617,199,1)-"("-[F:ADS2]DOSLEG(0)-") :"-mess(618,199,1)) From GESECRAN
            Return
        Elsif TABLE2=''
            # La leg de l'enreg. à copier est toute leg
            # On peut copier l'enreg : Leg destination=leg du dossier mono-leg
            LEGDES=[F:ADS2]DOSLEG(0)
        Endif
    Else
        # Dossier destination multi-leg
        If TABLE2<>''
          # Enregistrement à copier avec leg<>""
          Local Char SZDOSSIER(GLONADS)
          Local Integer LG
          Read [ADI2]CODE=909; TABLE2
          If fstat
           Call MESSAGE (TABLE2 - ':'- mess(173,187,1)  ) From GESECRAN : #-- Législation inexistante sur ce dossier --#
           Return
          Endif

          LG = instr(1, [M]DOSDES, "@")
          If LG = 0 Then
            SZDOSSIER = [M]DOSDES
          Else
            SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
          Endif
          Read [ADS2]DOSSIER=SZDOSSIER
          If !fstat Then
              If !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
                Call MESSAGE(TABLE2 - ':' - mess(249,133,1) ) From GESECRAN  #-- Législation non gérée par ce dossier --#
                Return
              Endif
          Endif
        Endif
    Endif
Endif

Read [TVT2]TVT0=TABLE ;LEGDES
If !fstat
    Local Integer WOK : WOK=1
    Call AVERTIR (mess(197,133,1), WOK) From GESECRAN : #-- enregistrement existe déjà --#
    If WOK=1 Return : Endif
Endif

Local Integer ILIG
#--/vérifications
Trbegin [TVT2], [TRA2]
  Delete [TVT2] Where VAT=(TABLE) & LEG=LEGDES
  If fstat=1 GOK=-1 : GLOCK="$"+[M]DOSDES+".TABVAT"-TABLE-LEGDES   : Goto ROLL_COPIE :#--CPO 71937
  Elsif fstat GOK=0 : Call RSTA("TVT2",TABLE) From GLOCK    : Goto AB_COPIE
  Endif
  Delete [TRA2] Where VAT=(TABLE)& LEG=LEGDES
  If fstat=1 GOK=-1 : GLOCK="$"+[M]DOSDES+".TABRATVAT"-TABLE : Goto ROLL_COPIE
  Elsif fstat GOK=0 : Call RSTA("TRA2",TABLE) From GLOCK     : Goto AB_COPIE
  Endif
  If !fstat
     #For [TVT1]VAT=TABLE & LEG = TABLE2
     For [TVT1]TVT0 Where VAT=TABLE & LEG = TABLE2 :#--CPO 71937 TVT
         [F:TVT2]=[F:TVT1]
         [F:TVT2]LEG = LEGDES
         If TABLE2=LEGDES
             Call COPTEXTRA("TABVAT","DESAXX",TABLE,TABLE2) From ATEXTRA
             If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
             Call COPTEXTRA("TABVAT","SHOAXX",TABLE,TABLE2) From ATEXTRA
             If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
             Call COPTEXTRA("TABVAT","TEXAXX",TABLE,TABLE2) From ATEXTRA  #MAE, multiLEG
             If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
         Else
             Call COPTEXTRA1("TABVAT","DESAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
             If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
             Call COPTEXTRA1("TABVAT","SHOAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
             If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
             Call COPTEXTRA1("TABVAT","TEXAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX #MAE, multiLEG
             If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
         Endif
         If dim([F:TVT2]UPDUSR)>0 : [F:TVT2]UPDUSR = GUSER : Endif :#--CPO 71937
         If dim([F:TVT2]UPDDAT)>0 : [F:TVT2]UPDDAT = date$ : Endif :#--CPO 71937
         Write [TVT2]
         If fstat GOK=0 : Call FSTA("TVT2") From GLOCK : Goto AB_COPIE : Endif
     Next
  Endif
  For [TRA1]TRA0 Where VAT=(TABLE) & LEG = TABLE2
    Raz [F:TRA2]
    [F:TRA2]=[F:TRA1]
    [F:TRA2]LEG = LEGDES
    Write [TRA2]
    If fstat GOK=0 : Call FSTA("TRA2") From GLOCK : Goto AB_COPIE : Endif
  Next

Commit
Return
#----- Abandon de la copie -----#
$AB_COPIE
Rollback : Return
#----- Nouvel essai si nécessaire -----#
$ROLL_COPIE
Rollback : Call ROLL From GLOCK : If !GROLL Goto TRT_COPIE : Endif : Return
#################################################################################
$CHGCOD
Call CHGCOD(ABREV,CLECUR1,CLECUR2,OK) From CHGCLELEG
Return
