######################################################################################


##################################################
## Actions of the data type TVT
##################################################

# Control
Subprog CONTTVT(VAT,LEG,CODMSK,CHAMPCOD,FCY,GROUPE,CPY)
Variable Char    VAT()
Value    Char    LEG()
Value    Char    CODMSK()
Value    Char    CHAMPCOD()
Value    Char    FCY
Value    Char    GROUPE
Value    Char    CPY

Local Integer    WRET

Local    Integer CAS
Local    Char    OPTIONS(30)

If GFONCTION = "GESTVT" | VAT="" : End : Endif

If clalev([F:TVT]) =0 : Local File TABVAT [TVT]  : Endif
If clalev([F:AMZZ])=0 : Local File AMSKZON  [AMZZ] : Endif :#Pour déterminer les options de sélection
If clalev([F:CPY])=0  : Local File COMPANY  [CPY]  : Endif :#--CPO 71937
If clalev([F:FCY])=0  : Local File FACILITY [FCY]  : Endif :#--CPO 71937

If func AFNC.ACTIV("LEG")=0
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Endif
CAS = 1 : # Legislation is empty

#--CPO 71937
#--Cas particulier : pas de GCURLEG mais société ou site en ligne
If [L]LEG="" and ([L]CPY<>"" | [L]FCY<>"")
If [L]FCY<>""
If [F:FCY]FCY<>[L]FCY
Read [F:FCY]FCY0=[L]FCY
If fstat : Raz [F:FCY] Endif
Endif
If [L]CPY="" : [L]CPY=[F:FCY]LEGCPY : Endif
Endif
If [L]CPY<>""
If [F:CPY]CPY<>[L]CPY
Read [F:CPY]CPY0=[L]CPY
If fstat : Raz [F:CPY] Endif
Endif
[L]LEG=[F:CPY]LEG
Endif
Endif
#--/CPO

If LEG<>""
 Read [TVT]TVT0=VAT;LEG
 If fstat
  Read [TVT]TVT0=VAT;""
 Else
  CAS = 2 : # Legislation isn't empty
 Endif
Else
 Read [TVT]TVT0(1)=VAT
 If !fstat
  LEG = [F:TVT]LEG
  CAS = 2
 Endif
Endif
If fstat
 Filter [TVT] Where VAT=[L]VAT
 Look [TVT]TVT0 First
 If !fstat
  # Fiche inexistante pour la législation courante
  GMESSAGE = [L]VAT-":"-mess(232,107,1)-"["+[L]LEG+"]"
 Else
  # Fiche inexistante
  GMESSAGE = [L]VAT-":"-mess(23,100,1)
 Endif
 Filter [TVT]
 mkstat = 2 : End
Endif

#--Filtrage par groupe de société
#--Dans ce cas particulier ou nous pouvons avoir que le CPY de renseigné (paramètrage pour une société)
#--Du fait du type de donné AGF sur le champ GRP de TABVAT, il n'y aura que le filtrage sur site ! (en fonction de GCURFCY)
#If [L]CPY<>""
If [L]CPY<>"" and [L]FCY="" :#--CPO 71937
  If [F:TVT]GRP<>""
  #--CPO 71937
  If clalev([F:AGF])=0 : Local File AGRPFCY    [AGF]  : Endif
Read [AGF]AGF0=[F:TVT]GRP
If !fstat
  If [F:AGF]FLGLEG=2
    #--Société
If [F:TVT]GRP<>[L]CPY
          GMESSAGE += VAT+"\"+mess(63,127,1)-":"-[F:TVT]GRP : # Réservé au groupe de société
          mkstat = 2 : End
Endif
  Elsif [F:AGF]FLGCPY=2
  #--CPO
        If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
        Look [AGC]AGC0 = [F:TVT]GRP;[L]CPY
        If fstat
          GMESSAGE += VAT+"\"+mess(63,127,1)-":"-[F:TVT]GRP : # Réservé au groupe de société
          mkstat = 2 : End
        Endif
      Endif :#--CPO 71937
    Endif
  Endif
Endif
#--

#--Contrôle de cohérence entre le groupe de la taxe et la législation
If [F:TVT]GRP<>"" and LEG<>""
Call CTLGFYLEG([F:TVT]GRP,LEG,"","") From TRTVENCTL
If mkstat : End : Endif
Endif
#--Contrôle de cohérence entre le groupe passé en paramètre et la législation de l'enregistrement retenu
If GROUPE<>"" and [F:TVT]LEG<>""
Call CTLGFYLEG(GROUPE,[F:TVT]LEG,"","") From TRTVENCTL
If mkstat : End : Endif
Endif
#--Contrôle de la cohérence entre le groupe passé en param et celui de la taxe à contrôler
#--uniquement si le groupe passé est renseigné
#--uniquement si pas de contexte site ou société !
If GROUPE<>""
  If CPY="" & FCY="" & [F:TVT]GRP<>"" & [F:TVT]GRP<>GROUPE
  #--Les groupes doivent avoir au moins une société en commun
  Gosub CTLGFYGRP
If mkstat : End : Endif
  Endif
Endif

#--On charge les options définies sur le type de données du champ du masque
OPTIONS=""
If CODMSK<>"" & CHAMPCOD<>""
  Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
  If fstat=0 : OPTIONS=[F:AMZZ]OPTOBJ : Endif
Endif

If CAS=2
 Call CONTROLE("TVT",OPTIONS,LEG,VAT,mkstat) From CONTOBJ
Else
 Call CONTROLE("TVT",OPTIONS,"",VAT,mkstat) From CONTOBJ
Endif

End
#-------------------------------
$CTLGFYGRP
Local Integer ERR
Local Char    SZVIEW(GLONAVW)
If [F:TVT]LEG=""
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTVTZGRP"
    Local File =SZVIEW [TVTZ]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, pas de contrôle
    Return
  Endif

  Read [F:TVTZ]TVTZ0 = [L]GROUPE;[F:TVT]VAT;[F:TVT]GRP;[F:TVT]LEG
  If fstat
  GMESSAGE = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:TVT]GRP-":"-mess(178,187,1)
  mkstat=1
  Return
  Endif
Else
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTVTYGRP"
    Local File =SZVIEW [TVTY]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, pas de contrôle
    Return
  Endif

  Read [F:TVTY]TVTZ0 = [L]GROUPE;[F:TVT]VAT;[F:TVT]GRP;[F:TVT]LEG
  If fstat
  GMESSAGE = mess(177,187,1)-":"-[L]GROUPE-"-"-[F:TVT]GRP-":"-mess(178,187,1)
  mkstat=1
  Return
  Endif
Endif
Return
## Tunnel régime de taxe
Subprog TUNTVT(COD,LEG)
Variable Char    COD()
Value    Char    LEG()
Local Integer TOKILL

TOKILL = 0
If dim(VCOD)<1
  Global Char VCOD(GLONVAT)
  TOKILL = 1
Endif

If clalev([F:TVT])=0 : Local File TABVAT [TVT] : Endif

VCOD = COD

If GNBLEG=1
  LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>""
  LEG = GCURLEG
#--If LEG="" then firstly we search a TVT record with LEG="" secondly a TVT record with TVT<>""
Elsif LEG=""
  Read [TVT]TVT0 = VCOD;LEG
  If fstat
    Read [TVT]TVT0(1)=VCOD
    If !fstat
      LEG = [F:TVT]LEG
    Endif
  Endif
Endif

Read [TVT]TVT0 = COD;LEG
If fstat : LEG = "" : Endif

Call OBJET("TVT",LEG,VCOD) From GOBJET

COD = VCOD
If TOKILL : Kill VCOD : Endif

End
#--------------------------------------------------------------------------------
#--Called from ADPVAL fonction "Parameter values"
#--Also called from the SELTVT selection action (Throughout the SELTVTA subprog)
#--------------------------------------------------------------------------------
$SELTVT
If clalev([F:TVT])=0 : Local File TABVAT [TVT] : Endif

If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP   [FGR] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA    [AXX] : Endif
If clalev([F:AGF])=0 : Local File AGRPFCY  [AGF] : Endif
If clalev([F:AMZZ])=0 : Local File AMSKZON  [AMZZ] : Endif :#--CPO 71937 Pour déterminer les options de sélection

Local Char    FCY(GLONFCY)
Local Char    CPY(GLONCPY)
Local Char    LEG(GLONADI)
Local Char    GRP(GLONAGC)
Local Integer WNOL
Local Integer ERR
Local Char    AUTRE_CRIT(250)
Local Char    SZVIEW(GLONAVW)

If dim(OPTIONS)<0 : Local Char OPTIONS(30) Endif #--CPO 71937 Pour déterminer les options de sélection
Local Char CODMSK   (GLONAMK)  #--CPO 71937 Pour déterminer les options de sélection
Local Char CHAMPCOD (GLONAVA)  #--CPO 71937 Pour déterminer les options de sélection

#--------------------------------------------------------------------------------------------------
# Identifying the parameters
#--------------------------------------------------------------------------------------------------
AUTRE_CRIT = '1=1'

If GFONCTION="ADPVAL"     :#--"Parameter values". Data type = ???
  FCY  = [M:ADWP]FCY
  CPY  = [M:ADWP]CMP
  If dim([M:ADWP]LEG)>0
    LEG = [M:ADWP]LEG
  Endif
Else
  LEG   = PARAM(1)
  FCY   = PARAM(2)
  GRP   = PARAM(3)
  CPY      = PARAM(4)
  If dim(PARAM(5))>0 & PARAM(5)<>"" : AUTRE_CRIT -= '& '+PARAM(5) Endif
  CODMSK   = PARAM(6)
  CHAMPCOD = PARAM(7)
  #--CPO 98053 et 98275 Sélection depuis "ADPVAL" et prise en compte des OPTIONS
  #--On charge les options définies sur le type de données du champ du masque
  OPTIONS=""
  If CODMSK<>"" & CHAMPCOD<>""
    Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
    If fstat=0 : OPTIONS =[F:AMZZ]OPTOBJ : Endif
  Endif
  #--/CPO
Endif

If func AFNC.ACTIV("LEG")=0
 LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>"" : # GCURLEG positionné par programme
 LEG = GCURLEG
Endif
#--CPO 98053 Sélection depuis "ADPVAL" et prise en compte des OPTIONS
#--On charge les options définies sur le type de données du champ du masque
#OPTIONS=""
#If CODMSK<>"" & CHAMPCOD<>""
#  Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
#  If fstat=0 : OPTIONS =[F:AMZZ]OPTOBJ : Endif
#Endif
#--/CPO
#--------------------------------------------------------------------------------------------------
If GFONCTION = "GESTVT" Then
  # Si on est sur l'objet de paramétrage, pas de filtre on part sur la sélection standard
  OBJET = "TVT"
  Return
Endif

#--Init. of legislation
If [L]LEG=""
 If [L]FCY<>""
  Call LEC_FCY([L]FCY) From CPTLEC
  Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
  [L]LEG = [F:CPY]LEG
 Elsif [L]CPY<>""
  Call LEC_CPY([L]CPY) From CPTLEC
  [L]LEG = [F:CPY]LEG
 Endif
Endif

If [L]LEG=""
 [L]LEG = GCURLEG
Endif
#--------------------------------------------------------------------------------------------------
## Position and dimension of the window
#--------------------------------------------------------------------------------------------------
Gosub OUVRE_LISTE From WOTVT
For I=1 To NBSEL
 If SELEXP(I)<>""
  COL(I) = SELEXP(I)
 Else
  COL(I) = SELZON(I)
 Endif
 TIT(I)  = SELLIB(I)
 If left$(SELFMT(I),2)="LA"
  COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
 Endif
Next I
NBCOL   = NBSEL
SIZCOL  = 240
SIZLIG  = 100
TIT(0)  = mess(12,123,1)
Call TITOBJ("TVT","",TIT(1)) From CONTOBJ
TIT(0) -= TIT(1)
START   = "[F:TVT]VAT"
ORDRE   = "[F:TVT]VAT;[F:TVT]LEG"
OBJET   = ""

#--------------------------------------------------------------------------------------------------
## Standard selection criteria
#--------------------------------------------------------------------------------------------------
ICRITERE = 0
ICRITERE += 1
CRITERE(ICRITERE) = '1=1'
#--Groupe de soc/sites
If FCY="" & CPY="" & GRP<>""
 Read [F:AGF]AGF0=[L]GRP
 If !fstat
 If [F:AGF]FLGLEG=2 : [L]CPY=[L]GRP : Endif
Endif
Endif
#--Facility
If    [L]FCY<>""
  CRITERE(ICRITERE) -= '& ([F:TVT]GRP="" | ([F:TVT]GRP<>"" & [F:FGR]FCY="'+[L]FCY+'"))'
#--Company
Elsif [L]CPY<>""
  CRITERE(ICRITERE) -= '& ([F:TVT]GRP="" | ([F:TVT]GRP<>"" & [F:TVTC]LEGCPY="'+[L]CPY+'"))'
Endif
#--Legislation
ICRITERE += 1
If LEG<>""
  CRITERE(ICRITERE) -= '& ([F:TVT]LEG="'+[L]LEG+'" | [F:TVT]LEG="")'
Endif
#--First selection character

If dim(SELCAR)>0 & SELCAR<>0
  CRITERE(ICRITERE) -= '& left$([F:TVT]VAT,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
Endif

CRITERE(ICRITERE) -= '&'-[L]AUTRE_CRIT

ICRITERE += 1
Call FILROLE(OBJET,FILROLE) From SUBARL
If FILROLE<>"" & FILROLE<>"1=1"
 For I=0 To dim(FILROLE)-1
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILROLE(I),"&") From GOBJSUB
 Next I
Endif

#--------------------------------------------------------------------------------------------------
#--Views calls
#--------------------------------------------------------------------------------------------------
If ([L]CPY="" and [L]FCY="" and [L]GRP<>"")
If [L]LEG<>""
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTVTYGRP"
      Local File =SZVIEW [TVTY]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "TVT"
      Return
    Endif
Else
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTVTZGRP"
      Local File =SZVIEW [TVTZ]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "TVT"
      Return
    Endif
Endif
Endif
If 1=1
  ERR = 0
  Repeat
    # -----------------------------------------------------------------------------------------------
    # ERR=0  : Pas d'erreur, on sort
    # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
    # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
    # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
    # -----------------------------------------------------------------------------------------------
    Onerrgo ERRVUE
    SZVIEW = "LEGTVTCPY"
    Local File =SZVIEW [TVTC]
    Onerrgo
  Until ERR <> -1
  If ERR Then
    # Si problème, on se déroute sur le select standard
    OBJET = "TVT"
    Return
  Endif
  If [L]LEG<>""
    #--View throughout GCURLEG
    #--------------------------------------------------------------------------------------------------
    ## Appel à la vue
    #--------------------------------------------------------------------------------------------------
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTVTSEL"
      Local File =SZVIEW [TVTS]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "TVT"
      Return
    Endif
    If ([L]CPY="" and [L]FCY="" and [L]GRP<>"")
  Link [TVT] With [F:AXX]AXX0    = "TABVAT";"DESAXX";GLANGUE;[F:TVT]VAT;[F:TVT]LEG,
&                 [F:TVTY]TVTZ0 ~= [L]GRP;[F:TVT]VAT;[F:TVT]GRP;[F:TVT]LEG,
&                [F:TVTS]TVT0  ~= [F:TVT]VAT;[F:TVT]LEG;[L]LEG
&              As [LTVT]
Else
    Link [TVT] With [F:AXX]AXX0   = "TABVAT";"DESAXX";GLANGUE;[F:TVT]VAT;[F:TVT]LEG,
&                [F:FGR]FGR1    = [L]FCY;[F:TVT]GRP,
&                [F:TVTC]TVT0   = [F:TVT]VAT;[F:TVT]LEG;[F:TVT]GRP;[L]CPY,
&                [F:TVTS]TVT0  ~= [F:TVT]VAT;[F:TVT]LEG;[L]LEG
&     As [LTVT]
Endif
  Else
   #--View without legislation
   ERR = 0
   Repeat
     # -----------------------------------------------------------------------------------------------
     # ERR=0  : Pas d'erreur, on sort
     # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
     # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
     # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
     # -----------------------------------------------------------------------------------------------
     Onerrgo ERRVUE
     SZVIEW = "LEGTVTPAR"
     Local File =SZVIEW [TVTP]
     Onerrgo
   Until ERR <> -1
   If ERR Then
    # Si problème, on se déroute sur le select standard
     OBJET = "TVT"
     Return
   Endif
   If ([L]CPY="" and [L]FCY="" and [L]GRP<>"")
  Link [TVT] With [F:AXX]AXX0    = "TABVAT";"DESAXX";GLANGUE;[F:TVT]VAT;[F:TVT]LEG,
&                 [F:TVTZ]TVTZ0 ~= [L]GRP;[F:TVT]VAT;[F:TVT]GRP;[F:TVT]LEG
&              As [LTVT]
 Else
   Link [TVT] With [F:AXX]AXX0    = "TABVAT";"DESAXX";GLANGUE;[F:TVT]VAT;[F:TVT]LEG,
&                [F:FGR]FGR1    = [L]FCY;[F:TVT]GRP,
&                 [F:TVTC]TVT0   = [F:TVT]VAT;[F:TVT]LEG;[F:TVT]GRP;[L]CPY,
&                 [F:TVTP]TVT0  ~= [F:TVT]VAT;[F:TVT]LEG
&      As [LTVT]
Endif
  Endif
Endif

# Options de sélection
If OPTIONS<>""
  Gosub OPTIONS From WOTVT
  ICRITERE=2
  For I=1 To NBCOND
   If instr(1,OPTIONS,OPT(I))
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","("+CONDIT(I)+")","&") From GOBJSUB
   Endif
  Next I
Endif

Default File [LTVT]
DEFPAG = 1

Return

$ERRVUE
  If ERR = 0 Then
    ERR = -1
    Call MAJVUE(SZVIEW, nomap) From DOSVUE
  Else
    ERR = errn
  Endif
Resume
#--------------------------------------------------------------------------------
#--Call from SELTVT Action
#--------------------------------------------------------------------------------
Subprog SELTVTA(VAT,LEG,FCY,GROUPE,CPY)
Variable Char    VAT()
Value    Char    LEG
Value    Char    FCY
Value    Char    GROUPE
Value    Char    CPY
Local Char PARMSK(30)(1..10)
PARMSK(1)=[L]LEG
PARMSK(2)=[L]FCY
PARMSK(3)=[L]GROUPE
PARMSK(4)=[L]CPY

If clalev([F:TVT])=0 : Local File TABVAT [TVT] : Endif
Call S_TAB_CHAR(VAT,PARMSK,"SELTVT","SUBTVT","") From GACTION

End
######################################################################################
## Etiquette ajoutée par le superviseur (écran TVT1) 15/10/2012 10:09:51 (LD)
######################################################################################
Subprog IB_DESAXX
End


######################################################################################
#--CPO 84846 Nouveau sous-pro de calcul de taxe TTC vers HT
#######################################################################################
$CALINV2
Local Decimal  MONTCALC
Local Decimal  WRAT    (1..NBTAXE)   : # les 3 taux de taxe
Local Decimal  WRATDED (1..NBTAXE)  : # les taux déductibles
Local Decimal  WBASTAX (1..NBTAXE)   : # les bases de taxe

#--Pour passage des bases soumises des taxes
Raz STAT
For I=1 To NBTAXE
  If TAXES(I)<>""
    Raz TAUX1,TAUX2
    TAX = TAXES(I) : Gosub LECTAX
    If STAT=2 : Return Endif
WRAT(I)=TAUX1
    #If CAS=3 : WRATDED(I)=TAUX2 Endif :#--CPO Suite conversation tél PR
    WRATDED(I)=TAUX2
    If CAS=2 and TYPTAX(I)<>1 and BASVAT(I)>1
      WBASTAX(I)=OTHBASE(I)
    Else
    WBASTAX(I)=BASE
    Endif
  Endif
Next

Call CALCULTAXE(CAS,SOCIETE,DEVISE,DAT,TYPBASE,NBTAXE,TAXES,TYPTAX,SOUMIS,BASVAT,WRAT,WBASTAX,MONTANT,MONTCALC,BASE)
#--Calcul des montants déductibles
#If CAS=3 :#--CPO Suite conversation tél PR
  For I=1 To NBTAXE
   If TAXES(I)<>""
  MONTANT1=MONTANT(I)
  Gosub EXONERATION From SUBTVT
  # Pour le montant déductible, quelle option ?
  MONTDED(I) = arr(MONTANT1*WRATDED(I)/100,[F:TCU]CURRND)
   Endif
  Next
#Endif

Return
#########################################################################
# CALCULTAXE calcule les montants des taxes
#------------------------------------------------------------------------
# appel (garnir) :
#   CPY    CUR  DAT  PRITYP  VAT
#   RAT    si le taux n'est pas garni (=999.99) il est recherche en table
#   BASTAX montants soumis aux taxes
#     lignes produit  : (0) soumis à TVA  (1) soumis à TS1  (2) soumis à TS2
#     frais           : (3) soumis à TVA
#     taxe secondaire : (4) soumis à TVA
# retour
#   RAT    si non garnis à l'appel
#   BASTAX les montants sont mis à jour (ex: (4) si TS1 TS2 soumis à TVA)
#          mis à jour dans le cas du calcul à partir du TTC
#      nota un montant exonéré reste garni (pour les répartitions prorata)
#   AMTNOT montant HT
#   AMTATI montant TTC
#
#########################################################################
Subprog CALCULTAXE (CAS,CPY,CUR,DAT,PRITYP,NBVAT,VAT,TYPVAT,SOUMIS,BASVAT,RAT,BASTAX,AMTTAX,AMTNOT,AMTATI)
Value    Integer  CAS
Value    Char     CPY            : # société (nécessaire à table des taux de taxe
Value    Char     CUR            : # devise
Value    Date     DAT            : # date (nécessaire à table des taux de taxe)
Value    Integer  PRITYP         : # 1=HT 2=TTC
Value  Integer  NBVAT
Value    Char     VAT () (0..)   : # les 3 codes de taxe
Value    Libelle  TYPVAT(0..)
Value    Libelle  SOUMIS(0..)
Value    Libelle  BASVAT(0..)
Variable Decimal  RAT (0..)      : # les 3 taux de taxe
Variable Decimal  BASTAX (0..)   : # les bases de taxe
Variable Decimal  AMTTAX (0..)   : # les montants
Variable Decimal  AMTNOT         : # montant HT  (si ligne=celui de la ligne)
Variable Decimal  AMTATI         : # montant TTC (si ligne=celui de la ligne)

Local    Shortint I,J
Local    Decimal  MTSOUMIS (0..)
Local    Decimal  TAXE1          : # si calcul sur autre que le ht
Local    Decimal  TAXE2          : # si calcul sur autre que le ht
Local    Decimal  TVATAXE1       : # si calcul sur autre que le ht et taxe soumise à tva : # Bug 65799
Local    Decimal  TVATAXE2       : # si calcul sur autre que le ht et taxe soumise à tva : # Bug 65799
Local    Decimal  TXTOT          : # taux total de la ligne si prix TTC
Local    Decimal  MTSOUMISTVA
Local    Decimal  RATTVA
Local    Integer  INDTVA
Local    Decimal  BASTAX4,BASTAX5
Local  Decimal  TOT_BASTAXSEC,TOT_AMTTAXSEC,TOT_BASTAXFORMT
Local    Decimal  TOT_TVATAXE1,TOT_TVATAXE2
Local    Decimal  TOT_TAXE1,TOT_TAXE2

#--CPO
If clalev([F:TCU])=0 : Local File TABCUR    [TCU] : Endif
If [F:TCU]CUR<>CUR
    Read [TCU]TCU0=CUR : If fstat  Raz [F:TCU] : Endif
Endif
#--/
For I=0 To NBVAT-1
  If TYPVAT(I)=1
   MTSOUMISTVA=BASTAX(I)
   RATTVA=RAT(I)
   INDTVA=I
  Endif
  MTSOUMIS(I)=BASTAX(I)
Next
# Taxes secondaires :
# - Calcul de la taxe UNIQUEMENT si la base n est pas le HT
Raz TVATAXE1, TVATAXE2 : # Bug 65799
Raz TOT_TVATAXE1, TOT_TVATAXE2
Raz TAXE1, TAXE2       : # Issue 74556 - Optimisation
#--Uniquement pour appels depuis les achats
If CAS=2
  For I=0 To NBVAT-1
   If VAT(I)<>"" and TYPVAT(I)<>1
     # Bug 73097
     # Si Document HT,  calcul des taxes secondaires
     # Si Document TTC, calcul des taxes secondaires sf si mnt TTC ligne taxe principale à 0 (Dans ce cas, pas de taxe donc pas de calcul des taxes)
    If (PRITYP=1 | MTSOUMISTVA<>0)  : # Bug 73097
      If BASVAT(I)=2   : # si base de taxe est montant1
        If MTSOUMIS(I)<>0   : # Issue 74556 - Optimisation
          Call RNDTVA(MTSOUMIS(I),RAT(I),[F:TCU]CURRND,TAXE1) From SUBTVT
        Endif
        AMTTAX(I)=TAXE1
        TOT_TAXE1 += TAXE1
        If SOUMIS(I)=2      : # la taxe est soumise à taxe principale
         If TAXE1<>0        :  # Issue 74556 - Optimisation
            Call RNDTVA(TAXE1,RATTVA,[F:TCU]CURRND,TVATAXE1) From SUBTVT : # calcul de la taxe principale : # Bug 65799
            TOT_TVATAXE1 += TVATAXE1
            If TYPVAT(I)=2 : BASTAX4 += TAXE1 : Endif : # c'EST UNE TAXE PARAFISCALE
            If TYPVAT(I)=3 : BASTAX5 += TAXE1 : Endif : # c'est une taxe spéciale
          Endif
        Endif
      Endif
      If BASVAT(I)=3    : # si base de taxe est montant2
        If MTSOUMIS(I)<>0   : # Issue 74556 - Optimisation
          Call RNDTVA(MTSOUMIS(I),RAT(I),[F:TCU]CURRND,TAXE2) From SUBTVT
        Endif
        AMTTAX(I)=TAXE2
        TOT_TAXE2 += TAXE2
        If SOUMIS(I)=2  : # la taxe est soumise à taxe principale
          If TAXE2<>0       : # Issue 74556 - Optimisation
            Call RNDTVA(TAXE2,RATTVA,[F:TCU]CURRND,TVATAXE2) From SUBTVT : # calcul de la taxe principale : # Bug 65799
            TOT_TVATAXE2 += TVATAXE2
            If TYPVAT(I)=2 : BASTAX4 += TAXE2 : Endif : # c'est une taxe parafiscale
            If TYPVAT(I)=3 : BASTAX5 += TAXE2 : Endif : # c'est une taxe spéciale
          Endif
        Endif
      Endif
    Endif
   Endif
  Next I
Endif
# Document saisi avec type de prix TTC
# - cumul des % pour determiner la base HT de chaque taxe
# - Attention : il faut enlever du TTC ligne les taxes TAXE1 et TAXE2 calculees sur autre que HT
If PRITYP=2
  Raz TXTOT                        : # taux cumule
  For I=0 To NBVAT-1
    #If VAT(I)<>"" and BASVAT(I)<2  : # uniquement si taxe sur HT
    If VAT(I)<>"" and (CAS<>2 | (CAS=2 and BASVAT(I)<2))  : # uniquement si taxe sur HT
      TXTOT += RAT(I)/100
      If SOUMIS(I)=2 and I<>INDTVA    : # si taxe principale sur taxe secondaire
        TXTOT += (RAT(I)/100)*(RATTVA/100)
      Endif
    Endif
  Next I
  For I=0 To NBVAT-1
    #If VAT(I)<>"" and BASVAT(I)<2  : # uniquement si taxe sur HT
    If VAT(I)<>"" and (CAS<>2 | (CAS=2 and BASVAT(I)<2))  : # uniquement si taxe sur HT
      If TXTOT<>0
          Raz GBIDD3     : # Issue 74556 - Optimisation
          If MTSOUMIS(I)-TOT_TAXE1-TOT_TAXE2-TOT_TVATAXE1-TOT_TVATAXE2<>0   : # Issue 74556 - Optimisation
            Call RNDTVA2(MTSOUMIS(I)-TOT_TAXE1-TOT_TAXE2-TOT_TVATAXE1-TOT_TVATAXE2,TXTOT*100,[F:TCU]CURRND,GBIDD3) From SUBTVT
          Endif
          BASTAX(I)=MTSOUMIS(I)-TOT_TAXE1-TOT_TAXE2-TOT_TVATAXE1-TOT_TVATAXE2-GBIDD3
# Bug 65799
      Endif
    Endif
  Next I
Endif

# Calcul des taxes secondaires sur HT
For I=0 To NBVAT-1
 If VAT(I)<>"" and TYPVAT(I)<>1
  #If BASVAT(I)<2
  If (CAS<>2 | (CAS=2 and BASVAT(I)<2))
    Raz AMTTAX(I)     : # Issue 74556 - Optimisation
    If BASTAX(I)<>0   : # Issue 74556 - Optimisation
      Call RNDTVA(BASTAX(I),RAT(I),[F:TCU]CURRND,AMTTAX(I)) From SUBTVT
      If SOUMIS(I)=2      : # la taxe est soumise à taxe principale
        If TYPVAT(I)=2 : BASTAX4 += AMTTAX(I) : Endif : # c'est une taxe parafiscale
        If TYPVAT(I)=3 : BASTAX5 += AMTTAX(I) : Endif : # c'est une taxe spéciale
      Endif
    Endif
  Endif
 Endif
Next I

#--Calcul de la taxe principale
For I=0 To NBVAT-1
  If VAT(I)<>"" and TYPVAT(I)<>1
  TOT_BASTAXSEC += BASTAX(I)
  TOT_AMTTAXSEC += AMTTAX(I)
Endif
Next
[L]TOT_BASTAXFORMT = BASTAX4+BASTAX5
If PRITYP=1
  GBIDD3=BASTAX(INDTVA)+ TOT_BASTAXFORMT
  Raz AMTTAX(INDTVA)  : # Issue 74556 - Optimisation
  If GBIDD3<>0   : # Issue 74556 - Optimisation
    Call RNDTVA(GBIDD3,RAT(INDTVA),[F:TCU]CURRND,AMTTAX(INDTVA)) From SUBTVT
  Endif
  # Calcul du HT et TTC ligne
AMTNOT=MTSOUMISTVA
AMTATI=AMTNOT+AMTTAX(INDTVA)+ [L]TOT_AMTTAXSEC
Endif
If PRITYP=2
  #AMTTAX(INDTVA)=max(0,MTSOUMIS(INDTVA)-BASTAX(INDTVA)-[L]TOT_AMTTAXSEC) :#--CPO 85189
#-CPO 85189
If [F:TCU]CUR<>""
AMTTAX(INDTVA) = arr(max(0,MTSOUMIS(INDTVA)-BASTAX(INDTVA)-[L]TOT_AMTTAXSEC),[F:TCU]CURRND)
Else
  AMTTAX(INDTVA)=max(0,MTSOUMIS(INDTVA)-BASTAX(INDTVA)-[L]TOT_AMTTAXSEC)
Endif
#--/
  # Calcul du HT et TTC ligne
  AMTATI=MTSOUMIS(INDTVA)
  AMTNOT=AMTATI-AMTTAX(INDTVA)-[L]TOT_AMTTAXSEC
Endif

End
######################################################################################
Subprog VERF_PARAM(PPARAM,PVALEUR,POK)
Value Char PPARAM     # Nom du paramètre en cours de saisie
Value Char PVALEUR    # Valeur saisie à contrôler
Variable Integer POK  # 1 si contrôle satisfait, 0 si saisie incorrecte

If PVALEUR="" End Endif

If clalev([F:TVT])=0 : Local File TABVAT [TVT] : Endif

Local Char    FCY(GLONFCY),SAVE_GCURFCY( GLONFCY)
Local Char    CPY(GLONCPY),SAVE_GSOCIETE(GLONCPY)
Local Char    LEG(GLONADI)
Local Integer CAT
Local Integer WNOL
Local Integer ERR

[L]SAVE_GCURFCY = GCURFCY
[L]SAVE_GSOCIETE= GSOCIETE

If GFONCTION="ADPVAL" : # Saisie valeurs paramètres. Type de données = PGT
  FCY  = [M:ADWP]FCY : GCURFCY = FCY
  CPY  = [M:ADWP]CMP : GSOCIETE= CPY
  If dim([M:ADWP]LEG)>0
    LEG = [M:ADWP]LEG
  Else
    LEG = GDOSLEG
  Endif
  #--Initialisation de législation
  If [L]LEG=""
    If [L]FCY<>""
      Call LEC_FCY([L]FCY) From CPTLEC
      Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
      GSOCIETE = [F:FCY]LEGCPY
      [L]LEG = [F:CPY]LEG
    Elsif [L]CPY<>""
      Call LEC_CPY([L]CPY) From CPTLEC
      [L]LEG = [F:CPY]LEG
    Endif
  Endif
  If [L]LEG=""
    [L]LEG = GCURLEG
  Endif
  #--CPO 98053 Sélection depuis "ADPVAL" et prise en compte des OPTIONS
  #Call CONTTVT(PVALEUR,LEG,"","",FCY,"",CPY)
  Call CONTTVT(PVALEUR,LEG,"MULTILEGADP",PPARAM,FCY,"",CPY)
  If mkstat : POK=0 : Endif
Endif

GCURFCY = [L]SAVE_GCURFCY
GSOCIETE= [L]SAVE_GSOCIETE

End
