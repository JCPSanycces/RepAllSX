#<AdxTL>@(#)9.0.0.0 $Revision$
#####################################################################################
# SUBTVT : Gestion de la Table des codes taxes
#####################################################################################
#
# Issue X3-107197 - 2018-09-12 by CBO : PARAMETER AND ACTIVITY CODE
#Gosub TEST : End
Call OBJET("TVT",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"                  : Gosub OUVRE
 When "AFFMASK"                : Gosub AFFMASK
 When "RAZCRE"                 : Gosub RAZCRE
 When "INICRE"                 : Gosub MAJ_ATEXTRA
 When "CREATION"               : Gosub CREATION
 When "LIENS"                  : Gosub LIENS
 When "INIMOD"                 : Gosub INIMOD
 When "MODIF"                  : Gosub MODIF
 When "APRES_CRE", "APRES_MOD" : Gosub APRES_CRE
 When "ANNULE"                 : Gosub ANNULE
 When "SETBOUT"                : Gosub SETBOUT
 When "FERME"                  : Gosub FERME
 When "CHGCOD"       : Gosub CHGCOD
 When "AP_CHANGE"    : Gosub AP_CHANGE
 When "VERIF_CRE" : Gosub VERIF_CRE :#--CPO 71937 TABVAT
 When "VERIF_MOD" : Gosub VERIF_MOD #85803 RICAR - Legal Requirements
 When "SEL_TABLE"
   Case TABLE
     When "SELTVT"     : Gosub SELTVT
   Endcase
Endcase
Return

$OUVRE
If !clalev([F:ADI]) : Local File ATABDIV   [ADI] : Endif
If !clalev([F:TVC]) : Local File TABVAC    [TVC] : Endif
If !clalev([F:CAC]) : Local File GACCCODE  [CAC] : Endif
If !clalev([F:ADI]) : Local File ATABDIV   [ADI] : Endif
If !clalev([F:AWI]) : Local File AWINDOW   [AWI] : Endif
If !clalev([F:ADS]) : Local File ADOSSIER  [ADS] : Endif
If !clalev([F:CDI]) : Local File CADIEDEF  [CDI] : Endif

Local Integer LEGOK
Local Integer NUMDIE
NUMDIE = 9 : # Rang dans le menu 2230
Read [CDI]CDI0 = NUMDIE
#--CPO 71937
#If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#If dim(GGRPFCY)>0 : Local Char SAV_GGRPFCY(GLONADI) : SAV_GGRPFCY = GGRPFCY   : Endif :#--CPO 71937 TVT
#-----------------------------------#
# Sauvegarde des variables globales #
#-----------------------------------#
Gosub SAUV_GLOB From TRTX3GLOB

#--Lors d'un tunnel depuis un document (exemple : livraison)
Raz GCURFCY  :#--Ici pas de contexte et on veut éviter le filtrage des groupes de sites
Raz GSOCIETE :#--Ici pas de contexte et on veut éviter le filtrage des groupes de societes
#--/CPO

Return

$AFFMASK
Call FMTLEG From TRTX3 : # Pour rendre invisible si nécessaire le champ "Législation"
Gosub GRILEG
Return

$GRILEG
If func AFNC.ACTIV("LEG")=0 : # Dossier mono-législation
  Diszo [TVT1]LEG
  [M:TVT1]LEG=GDOSLEG(1)
  Affzo [TVT1]LEG : If dim([M:TVT1]ZLEG)>0  Affzo [TVT1]ZLEG : Endif
Endif
Return

$RAZCRE
[M]VATTYP=1 : [M]VATCHA=1 : [M]VATPAY=1 : [M]VATBAS=1 : # init menus locaux pour Web
Grizo [M]VATCHA
Gosub INIDIE
Gosub GRILEG
Affzo [TVT1]30
Raz GCURLEG #gbn-102846
Return

$INIMOD
Gosub MAJ_ATEXTRA
If dim([F:TVT]SPAVAT)>0 & [F:TVT]SPAVAT<>"" & [F:TVT]VATTYP<>2 : [F:TVT]SPAVAT = "" : Endif
Return

######################################################################
$AP_CHANGE
Call CHGTEXTRA("TABVAT","DESAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Call CHGTEXTRA("TABVAT","SHOAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Call CHGTEXTRA("TABVAT","TEXAXX",[L]OCODE,SUPP,[L]NCODE,SUPP) From ATEXTRA
Return

$MAJ_ATEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("TABVAT","DESAXX",CLECUR1,"","TABVAT","DESAXX",[F:TVT]VAT,[F:TVT]LEG)  From ATEXTRA
 Call DUPTEXTRA("TABVAT","SHOAXX",CLECUR1,"","TABVAT","DESAXX",[F:TVT]VAT,[F:TVT]LEG)  From ATEXTRA
 Call DUPTEXTRA("TABVAT","TEXAXX",CLECUR1,"","TABVAT","TEXAXX",[F:TVT]VAT,[F:TVT]LEG)  From ATEXTRA
Endif
#----- Création/Modification des textes traduisibles (ATEXTRA) -----#
Call MAJTEXTRA ([M:TVT1]DESAXX,"TABVAT","DESAXX",[M:TVT1]VAT,[M:TVT1]LEG) From ATEXTRA  #MAE, multiLEG
Call MAJTEXTRA ([M:TVT1]SHOAXX,"TABVAT","SHOAXX",[M:TVT1]VAT,[M:TVT1]LEG) From ATEXTRA  #MAE, multiLEG
Call MAJTEXTRA ([M:TVT1]TEXAXX,"TABVAT","TEXAXX",[M:TVT1]VAT,[M:TVT1]LEG) From ATEXTRA  #MAE, multiLEG
#----- SOS libellés -----#
If dim([F:TVT]LANDESSHO)>0
  [F:TVT]LANDESSHO=GLANGUE+"~"+[M:TVT1]DESAXX+"~"+[M:TVT1]SHOAXX
Endif
#-----
Return

$VERIF_CRE

#--Afin de relancer les contrôles sur les sociétés saisies pour les taux de taxe
For I=0 To [M:TVT1]NBRRAT-1
If [M:TVT1]CPY(I)<>""
  ## Action CONTCPYLEG
Call CONTCPYLEG([M:TVT1]CPY(I),[M:TVT1]LEG) From TRTX3
  If mkstat : GERR=1 : OK=0 : Return :  Endif
Endif
Next I

#85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
Gosub VERIF_SUBTVT_POR From PORLEGLIB
#85803 RICAR 2014/05/20 - Portuguese legal requirements - END

Return

$VERIF_MOD

#85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
Gosub VERIF_SUBTVT_POR From PORLEGLIB
#85803 RICAR 2014/05/20 - Portuguese legal requirements - END

Return

$CREATION
For nolign=1 To [M]NBRRAT
 If [M]CPY(nolign-1)<>"" | [M]STRDAT(nolign-1)<>[00/00/00] | [M]VATRAT(nolign-1)<>0
  Raz [F:TRA]
  [F:TRA]    = [M]
  [F:TRA]LEG = [TVT1]LEG   # leg
  Write [TRA]
  If fstat
   GOK = 0 : Call FSTA("TRA") From GLOCK : Break
  Endif
 Endif
Next I
Return

$MODIF
Delete [TRA] Where VAT=[F:TVT]VAT & LEG=[F:TVT]LEG
If fstat=1
 GOK = -1 : GLOCK="$TABRATVAT"-[F:TVT]VAT : Return
Endif
Gosub CREATION
Return

$ANNULE
Delete [AXX] Where CODFIC="TABVAT" & IDENT1=[F:TVT]VAT & IDENT2=[F:TVT]LEG
Return

$APRES_CRE
Gosub RELIT From GOBJSUB
Return

$LIENS
GCURLEG = [F:TVT]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
GGRPFCY = [M:TVT1]GRP :#--CPO 71937

nolign=0
For [TRA]TRA0 Where VAT=[F:TVT]VAT & LEG=[F:TVT]LEG
 nolign += 1
 [M] = [F:TRA]
Next
[M]NBRRAT = nolign
If dim([M]BASTAB) > 0
    [M]BASTAB = GOPTCANA
Endif

If [M]VATFOR="" Grizo [M]VATBAS Else Actzo [M]VATBAS Endif
If [M]VATTYP=1 | [M]VATTYP>3  Grizo [M]VATCHA Else Actzo [M]VATCHA Endif
If func AFNC.ACTIV("KAG") = 1
 If [M]VATTYP<>4
  Raz [M]SAT, [M]APLTAX
  Grizo [M]SAT : Grizo [M]APLTAX
 Else
  Actzo [M]SAT : Actzo [M]APLTAX
  Read [ADI]CODE = 364 ; [M]SAT
  If !fstat
   [M]APLTAX = mess([F:ADI]N1,8500,1)
  Endif
 Endif
Endif
Gosub INIDIE

# FGR 09/01/2015 : X3SUIVI105330 (début)
##85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
#If !find([M:TVT1]LEG,"POR")
#  Chgfmt [M:TVT1]TEXAXX  With "K:40X"
#Else
#  Chgfmt [M:TVT1]TEXAXX  With "-K:40X"
#Endif
##85803 RICAR 2014/05/20 - Portuguese legal requirements - END
If !find([M:TVT1]LEG,"POR")
  Chgfmt [M:TVT1]TEXAXX  With "K:" + num$(type([M:TVT1]TEXAXX)-10) + "X"
Else
  Chgfmt [M:TVT1]TEXAXX  With "-K:" + num$(type([M:TVT1]TEXAXX)-10) + "X"
Endif
# FGR 09/01/2015 : X3SUIVI105330 (fin)
Return

$INIDIE
If dim([M]DIE)<=0 : Return : Endif
Raz [M]DIE
Raz [M]CCE
[M]BASTAB = [F:CDI]NBRDIE
For I=0 To [F:CDI]NBRDIE-1
 [M]DIE(I) = [F:CDI]DIE(I)
 For J=0 To dim([F:TVT]DIE)-1
  If [F:TVT]DIE(J)=[F:CDI]DIE(I)
   [M]CCE(I) = [F:TVT]CCE(J)
   Break
  Endif
 Next J
Next I
Return

########################################
Subprog AM_VATTYP(VALEUR)
Variable Integer VALEUR
#-----
#-- X3Suivi 71937 : Données par législation pour la détermination de la taxe
#--CPO 71937 TVT Il faut chercher la même LEG
#Filter [TVC] Where VATTYP<>VALEUR & ENAFLG=2 & VAT=[M]VAT & ( LEG="" or LEG=[M]LEG)
Filter [TVC] Where VATTYP<>VALEUR & ENAFLG=2 & VAT=[M]VAT & ( LEG=[M]LEG) & ENAFLG=2
#Read [TVC] TVC0 First
Read [TVC] TVC0 Last
Filter [TVC]
If !fstat
  #--CPO 71937 TVT et multi-lèg
  #GMESSAGE=mess(VALEUR,232,1)-mess(542,199,1)-[F:TVC]COD : GERR=1 : mkstat=1 : End
  If [F:TVC]LEG<>""
   GMESSAGE=mess(VALEUR,232,1)-mess(542,199,1)-[F:TVC]COD-mess(238,133,1)-[F:TVC]LEG : GERR=1 : mkstat=1 : End
  Else
    GMESSAGE=mess(VALEUR,232,1)-mess(542,199,1)-[F:TVC]COD-'"'+mess(91,187,1)+'"' : GERR=1 : mkstat=1 : End
Endif
#--/CPO
Endif
#-----
If VALEUR=1 | VALEUR>3
  [M]VATCHA=1 : Grizo [M]VATCHA
Else
  Actzo [M]VATCHA
Endif
Affzo [M]VATCHA
If dim([M]SAT)>0
 If VALEUR<>4
  [M]SAT = "" : [M]APLTAX = "" : Grizo [M]SAT : Grizo [M]APLTAX
 Else
  Actzo [M]SAT : Actzo [M]APLTAX
 Endif
Endif

End

########################################
Subprog AM_VATFOR(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : [M]VATBAS=1 : Grizo [M]VATBAS
  Else                       Actzo [M]VATBAS
Endif
Affzo [M]VATBAS
End

########################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
#--CPO 71937 TVT et multi-lèg
#--Comme la LEG fait partie de la clé, un changement de LEG va soit créer un nouvel enreg
#--soit nous porter sur un autre...du coup plus besoin de contrôle !
#If VALEUR<>""
#  #-- X3Suivi 71937 : Données par législation pour la détermination de la taxe
#  #Filter [TVC] Where VAT=[M]VAT & LEG<>"" & LEG<>VALEUR & ENAFLG=2
#  Filter [TVC] Where VAT=[M]VAT & ( LEG="" or LEG=[M]LEG) & ENAFLG=2
#  #Read [TVC] TVC0 First
#  Read [TVC] TVC0 Last
#  Filter [TVC]
#  If !fstat
#    GMESSAGE=VALEUR-mess(543,199,1)-[F:TVC]COD : GERR=1 : mkstat=1 : End
#  Endif
#Endif
#--/CPO

GCURLEG=VALEUR : # 71937

#85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
If find(VALEUR,"POR")
  Chgfmt [M:TVT1]TEXAXX  With "K:40X"
Else
  Chgfmt [M:TVT1]TEXAXX  With "-K:40X"
Endif
#85803 RICAR 2014/05/20 - Portuguese legal requirements - END

End
