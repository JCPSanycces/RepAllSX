#<AdxTL>@(#)9.0.0.0 $Revision$
Local Char DOSVAL(GLONADS) , DOSREF(GLONADS) , DOSCOP(GLONADS)
#X3-76171
If dim(GMAXSPEACV)>=0 & GMAXSPEACV>0
  Global Char    GSPE(GLONACV)(1..GMAXSPEACV)
Else
  Global Char    GSPE(GLONACV)(1..300)
Endif
#X3-76171
Global Integer GNBSPE
Local File ADOSSIER [ADS]
Read [ADS]DOSSIER = "TEST2"
If fstat : End : Endif
#GCOEF = 0.5
DOSVAL = [F:ADS]DOSSIER
DOSREF  = [F:ADS]DOSREF
DOSCOP  = [F:ADS]DOSCOP
Local File ADOSACT [ADA]
GNBSPE = 0
For [ADA]ADA0 Where [F]DOSSIER=[L]DOSVAL & CODACT>="X"
 GNBSPE += 1
 GSPE(GNBSPE) = [F:ADA]CODACT
Next ADA
Close Local File [ADA]
Call OUVRE_TRACE("") From LECFIC
Gosub AMAJSUP
Gosub MAJSUP
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

################################################################################################
#
#  Moulinettes superviseur pour la v9=V7.3=AMBASSADOR=Release 60 ...
#
#  Ces moulinettes sont réexécutables :
#  si elles sont été déjà lancées elles sont effet si on les lance une deuxième fois
#
################################################################################################


######################################################################
Subprog MAJDIC
Local Integer I , J , K , OK , OKCOP , DETAIL , OUVFIC , EXISTE
Local Char    X3(20) , OBJET(15), APPLI(15) , MESSA(80)
Local Char    TABSPE(GLONATB)(1..100), TABACTS(GLONACV)(1..300)
Local Integer NBSPE , NBACTS , NBFLD , DIME , VERCUR

VERCUR = 190
DETAIL = 0
APPLI = [F:ADS]DOSSIER

If val(DOSVERS)<50 : End : Endif : # C'est que la mise à jour 50 a déjà été faite

#107271
If func DOSVUE.ISVIEW(APPLI,"ATYPE")=0
 MESSA = "Update Data Types"
 Call ECR_TRACE(MESSA,0) From GESECRAN
 If GINFO
  Call AFF_VLC("Previsional Dictionary",MESSA) From GESECRAN
 Endif
 Gosub DOSMAJATY From DOSMAJATY
Endif

#107271
If func DOSVUE.ISVIEW(APPLI,"ACTIV")=0
 MESSA = "Update Activity Codes"
 If GINFO
  Call AFF_VLC("Previsional Dictionary",MESSA) From GESECRAN
 Endif
 Call ECR_TRACE(MESSA,0) From GESECRAN
 Gosub DOSMAJACV From DOSMAJACV
Endif

#107271
If func DOSVUE.ISVIEW(APPLI,"ATABLE")=0
 MESSA = "Update tables"
 If GINFO
  Call AFF_VLC("Previsional Dictionary",MESSA) From GESECRAN
 Endif
 Call ECR_TRACE(MESSA,0) From GESECRAN
 If func DOSSUB.ISHISTFOLD(APPLI)=0
  Gosub DOSMAJATB From DOSMAJATB
 Else
  Gosub DOSMAJATBHIS From DOSMAJATB
 Endif
Endif

# Pour forcer la validation des vues parce que l'intégration d'une sauvegarde
# d'un dossier d'une version différente de la version courante ne revalide pas les vues

MESSA = "Update views"
If GINFO
 Call AFF_VLC("Dictionnary",MESSA) From GESECRAN
Endif
Call ECR_TRACE(MESSA,0) From GESECRAN
If dim(GVALIDE)>=11
 GVALIDE(11) = 1
Endif

End

######################################################################
Subprog AMAJ
#107271
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER) : End : Endif

Local Char DOSVAL(GLONADS) , DOSREF(GLONADS) , DOSCOP(GLONADS)
DOSVAL = [F:ADS]DOSSIER
DOSREF = [F:ADS]DOSREF
DOSCOP = [F:ADS]DOSCOP
Gosub AMAJSUP
#107271
#Read [ADS]DOSSIER=DOSVAL
STAT=func DOSSUB.FILL_ADS([L]DOSVAL)
End

##################################
$AMAJSUP
If GINFO
 Call AFF_VLC(mess(93,125,1),"Update Supervisor") From GESECRAN
Endif
Call UTIAPL(DOSVAL)                      : # Modif APL.ini
Call PATCH([L]DOSVAL) From UTIDELDEMSRV  :#deletion of DEMSRV parameter 107748
Call PATCH([L]DOSVAL) From UTIMAJACCES      : # maj table ACCES
Call PATCH([L]DOSVAL) From UTIDELAP2FNC      : # maj table AFCTFCY , del GESAP2
Call PATCH([L]DOSVAL) From UTIINIMAXSPEACV    : #X3-76171 Initialize the parameter MAXSPEACV
If GINFO
 Call AFF_VLC("","") From GESECRAN
Endif
Return

######################################################################
Subprog MAJ
#107271
If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER) : End : Endif

Local Char DOSVAL(GLONADS) , DOSREF(GLONADS) , DOSCOP(GLONADS)
DOSVAL = [F:ADS]DOSSIER
DOSREF = [F:ADS]DOSREF
DOSCOP = [F:ADS]DOSCOP
Gosub MAJSUP
End

$MAJSUP
If GINFO
 Call AFF_VLC(mess(93,125,1),"Update Supervisor") From GESECRAN
Endif
Call PATCH(DOSSIER) From UTIDELADOASEAR     : # delete ASEAR
Call PATCH([L]DOSVAL) From UTIMAJADINUMTAB  :#Update ACLAPARFLD and ASHWPAR FOR DATA TYPE ADI
Call PATCH([L]DOSVAL) From UTIMAJTCYDUE : #110921 Initialisation champ FLGDUE dans TABCOUNTRY
If GINFO
 Call AFF_VLC("","") From GESECRAN
Endif
Return

######################################################################


####################################################################################
##  Mise a jour APL.ini
####################################################################################

Subprog UTIAPL(DOSSIER)
Value Char DOSSIER
Call PATCH(DOSSIER) From UTIAPLMAXHEAP24
Call PATCH(DOSSIER) From UTIAPLMAXMEM30
End

