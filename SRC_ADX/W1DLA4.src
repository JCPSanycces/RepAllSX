$ON_CTTINS
Onevent INIT_AREA Call D_CTTINS(zc) From W1DLA4
Onevent AFTER_CHANGE Gosub AMM_CTTINS From W1DLA4
Onevent BEFORE_INPUT Call AS_CTTINS(zc) From W1DLA4
Return

Subprog D_CTTINS(VALEUR)
Variable Integer VALEUR
If varinit([M]CTTINS,indice)=0
 VALEUR = 1
 ## Action STD
 Call D_CTTINS(VALEUR) From SUBDLA
Endif
Gosub _AFF
End

Subprog AS_CTTINS(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_CTTINS
Call AM_CTTINS(zc)
If !mkstat & GOBJET
 zoncou = "CTTINS" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CTTINS(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_CTTINS(VALEUR) From SUBDLA
If mkstat : GERR = 1 : GZONE = "CTTINS" : GZNUM = 47441 : Endif
Gosub _AFF
End

