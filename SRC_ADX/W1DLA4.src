#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque DLA4 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:59"
A_USER  = "DOC"
A_STAMP = "20181109230359"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask DLA4 [DLA4]
Gosub HORODAT
Local Inpbox "DLA4" From GFONCTION At A_STAMP With A_WINDPREV Mask [DLA4] As [SIM_]
Grizo [DLA4]5
Grizo [DLA4]25
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [DLA4]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=85 : Y1(0)=1 : Y2(0)=10
X1(1)=1 : X2(1)=85 : Y1(1)=11 : Y2(1)=21
Return

$ON_CTTTYP
Onevent INIT_AREA Call D_CTTTYP(zc) From W1DLA4
Onevent BEFORE_INPUT Call AS_CTTTYP(zc) From W1DLA4
Return

Subprog D_CTTTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]CTTTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_CTTTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_CTTDAT
Onevent CONTROL Call C_CTTDAT(zc) From W1DLA4
Onevent BEFORE_AREA Gosub AV_CTTDAT From W1DLA4
Return

$AV_CTTDAT
Chgfmt [M]CTTDAT(indice) With "DZ:"+GFMDAT4
Gosub _AFF
Return

Subprog C_CTTDAT(VALEUR)
Variable Date    VALEUR
## Action DATDEBFIN
Call DATDEBFIN(VALEUR,[M:DLA0]DAT) From EXEFNC
If mkstat : GERR = 1 : GZONE = "CTTDAT" : GZNUM = 46360 : Endif
Gosub _AFF
End

$ON_CTTHOU
Onevent CONTROL Call C_CTTHOU(zc) From W1DLA4
Onevent AFTER_AREA Call AP_CTTHOU(zc) From W1DLA4
Return

Subprog C_CTTHOU(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CONTHMM
 Call CONTHM(VALEUR) From TPSDIV
 If mkstat : GERR = 1 : GZONE = "CTTHOU" : GZNUM = 847 : Endif
Endif
Gosub _AFF
End

Subprog AP_CTTHOU(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action INIHMM
 Call INIHM(VALEUR) From TPSDIV
 If mkstat : GERR = 1 : GZONE = "CTTHOU" : GZNUM = 847 : Endif
Endif
Gosub _AFF
End

