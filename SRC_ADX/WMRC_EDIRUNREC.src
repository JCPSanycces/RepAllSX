#<AdxTL>@(#)0.0.0.0 $Revision$Class EDI inbound msg. generation
# Supervisor
## CRUD-CLASSE ## EDIRUNREC
# 2018-10-17 07:54:26 758


############################################################################################
### Subprog AINSERT
############################################################################################
Subprog AINSERT(EDIRUNREC,ASTATUS)
Variable Instance EDIRUNREC Using R_EDIRUNREC
Variable Integer ASTATUS

If EDIRUNREC = null : End : Endif

Gosub AVARIABLES From WMR00EDIRUNREC
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

If fmet EDIRUNREC.ACTX.AGETAFCRIGHT(EDIRUNREC,"EDIRUNREC",[V]CST_ATRUE)>=[V]CST_AERROR : [L]ASTATUS=[V]CST_AERROR : Goto AINSERT_END : Endif
If fmet EDIRUNREC.ACTX.AGETAFCRIGHTC(EDIRUNREC,"EDIRUNREC",[L]A_STRSITE,[V]CST_ATRUE)>=[V]CST_AERROR
 [L]ASTATUS=[V]CST_AERROR : Goto AINSERT_END
Endif

Gosub AREPCONTROL_AINSERT
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

If !adxlog
 Gosub AINSERT_TR_EDIRUNREC
Else
 Gosub AINSERT_EDIRUNREC
Endif
If [L]ASTATUS>=[V]CST_AERROR : Gosub AINSERT_END : Return : Endif

Gosub _AINSERT_AFTER
$AINSERT_END
[L]A_I = EDIRUNREC.freeSnapshot
EDIRUNREC.snapshotEnabled = 1
End

#-----------------------------------------------------#
$AREPCONTROL_AINSERT
EDIRUNREC.ASTALIN = [V]CST_ANEW
EDIRUNREC.EDR.ASTALIN = [V]CST_ANEW
[L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.ACTION("AINSERT_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Gosub AINSERT_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.ACTION("AINSERT_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return


$AINSERT_CONTROL
Gosub _AINSERT_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet EDIRUNREC._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet EDIRUNREC._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet EDIRUNREC._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AINSERT_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_BEFORE
If EDIRUNREC.EDR.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EDIRUNREC.EDR.ASTALIN = [V]CST_ANEW
[L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.EDR.ACTION("AINSERT_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIRUNREC.EDR.EDRD) : # EDIRUND -- 2
 If EDIRUNREC.EDR.EDRD(A_N2) <> null
& and !find(EDIRUNREC.EDR.EDRD(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.EDR.EDRD(A_N2).ACTION("AINSERT_CONTROL_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_AFTER
For A_N2=1 To maxtab(EDIRUNREC.EDR.EDRD) : # EDIRUND -- 2
 If EDIRUNREC.EDR.EDRD(A_N2) <> null
& and !find(EDIRUNREC.EDR.EDRD(A_N2).ASTALIN,[V]CST_ANEWDEL,[V]CST_ADEL)
  [L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.EDR.EDRD(A_N2).ACTION("AINSERT_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.EDR.ACTION("AINSERT_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_TR_EDIRUNREC
Trbegin [F:EDR]
 Gosub AINSERT_EDIRUNREC
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AINSERT_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
$_AINSERT_AFTER
If find(EDIRUNREC.EDR.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 EDIRUNREC.EDR.ASTALIN = [V]CST_ALL
Endif
Local Integer ASTATUS2
For A_N2=1 To maxtab(EDIRUNREC.EDR.EDRD)
 If EDIRUNREC.EDR.EDRD(A_N2) <> null
  If EDIRUNREC.EDR.EDRD(A_N2).ASTALIN=[V]CST_ADEL or EDIRUNREC.EDR.EDRD(A_N2).ASTALIN=[V]CST_ANEWDEL
   FreeInstance EDIRUNREC.EDR.EDRD(A_N2)
   EDIRUNREC.EDR.EDRD(A_N2) = null
  Elsif EDIRUNREC.EDR.EDRD(A_N2).ASTALIN <> [V]CST_ALL
   EDIRUNREC.EDR.EDRD(A_N2).ASTALIN = [V]CST_ALL
  Endif
  [L]ASTATUS = max([L]ASTATUS2,[L]ASTATUS)
 Endif
Next A_N2
Return

#-----------------------------------------------------#
$AINSERT_EDIRUNREC
[L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.ACTION("AINSERT_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.EDR._AINSERT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EDIRUNREC.ACTION("AINSERT_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_ABORT
Rollback
$_AINSERT_ABORT
If EDIRUNREC.snapshotEnabled=1
 [L]A_RETIK = EDIRUNREC.revertUpdTick
Endif
[L]ASTATUS = max(fmet EDIRUNREC.ACTION("AINSERT_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#



