   [M:TRS2]SUGLOCCOD2 = 1
   [M:TRS1]MVTDESCOD  = 3
   [M:TRS1]PJTCOD     = 3
   [M:TRS1]BPSLOTCOD  = 3
   [M:TRS2]QTYPUUFLG  = 3
#   [M:TRS2]UOMDACFLG  = 1
Endcase
GPOINT = "VALDEF"         #CHECK IGNORE_LINE
Gosub  ENTREE From EXEFNC 
Gosub DEF_CODACT
End
###########################################################
$DEF_CODACT
If [M:TRS0]LOTFLG = 0
  [M:TRS1]LOTCOD      = 3
  [M:TRS1]LOTMGTCOD   = 1
  [M:TRS1]BPSLOTCOD   = 3
  [M:TRS1]USRFLDCOD1  = 3
  [M:TRS1]USRFLDCOD2  = 3
  [M:TRS1]USRFLDCOD3  = 3
  [M:TRS1]USRFLDCOD4  = 3
#  
  [F:STT]LOTCOD       = 3
  [F:STT]LOTMGTCOD    = 1
  [F:STT]BPSLOTCOD    = 3
  [F:STT]USRFLDCOD1   = 3
  [F:STT]USRFLDCOD2   = 3
  [F:STT]USRFLDCOD3   = 3
  [F:STT]USRFLDCOD4   = 3
Endif
If [M:TRS0]TITFLG = 0
  [M:TRS1]POTACTCOD   = 3
  [F:STT]POTACTCOD    = 3
Endif
If [M:TRS0]EXYFLG = 0
  [M:TRS1]SHLCOD      = 3
  [F:STT]SHLCOD       = 3
Endif
If [M:TRS0]EMPFLG = 0
  [M:TRS2]LOCMGTCOD1  = 1
  [M:TRS2]SUGLOCCOD1  = 1
  [M:TRS2]LOCMGTCOD2  = 1
  [M:TRS2]SUGLOCCOD2  = 1
  [F:STT]LOCMGTCOD1   = 1
  [F:STT]SUGLOCCOD1   = 1
  [F:STT]LOCMGTCOD2   = 1
  [F:STT]SUGLOCCOD2   = 1
Endif
If [M:TRS0]TRAFLG = 0
  [M:TRS1]TRKCOD      = 1
  [F:STT]TRKCOD       = 1 
Endif
Return
###########################################################
#Génération masques de type ENTREE
Subprog TRT_ENTREE(TBLOC,TZONE,TMOD,TINT,IBLO,IZON)
Variable Integer TBLOC
Variable Char    TZONE
Variable Integer TMOD
Variable Char    TINT
Variable Integer IBLO
Variable Integer IZON
Local    Integer ACTLOT 
Local    Integer ACTEMP
Local    Integer ACTEXY
Local    Integer ACTTIT 
Local    Integer I
# Numéro de lot ###########################################
# si activite LOT absente
If [M:TRS0]LOTFLG = 0
  ACTLOT      = 1
  TZONE(IZON) = "LOT"
  TMOD(IZON)  = 3
  IZON += 1
Else
  If [M:TRS1]LOTCOD <>1 
    TZONE(IZON) = "LOT"
    TMOD(IZON)  = [M:TRS1]LOTCOD
    IZON += 1
  Endif  
Endif
# Titre ###################################################
#si activite "TIT" absente
If [M:TRS0]TITFLG = 0 
  TZONE(IZON) = "POTACT"
  TMOD(IZON)  = 3
  IZON += 1
Else  
# si activite "TIT" presente
  If [M:TRS1]POTACTCOD <> 1
    TZONE(IZON) = "POTACT"
    TMOD(IZON)  = [M:TRS1]POTACTCOD
    IZON += 1
  Endif  
Endif
# Péremption ##############################################
#si activite "EXY" absente
If [M:TRS0]EXYFLG = 0 
  TZONE(IZON) = "SHL"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "SHLDAT"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "REFPER"
  TMOD(IZON)  = 3
  IZON += 1
Else  
#Activité "EXY" presente
  If [M:TRS1]SHLCOD <>1 
    TZONE(IZON) = "SHL"
    TMOD(IZON)  = [M:TRS1]SHLCOD
    IZON += 1
    TZONE(IZON) = "SHLDAT"
    TMOD(IZON)  = [M:TRS1]SHLCOD
    IZON += 1
    TZONE(IZON) = "REFPER"
    TMOD(IZON)  = [M:TRS1]SHLCOD
    IZON += 1
  Endif
Endif
###########################################################
#Si pas saisie unité
If [M:TRS2]UOMDACFLG = 1
#  TZONE(IZON) = "WPCU"
#  TMOD(IZON)  = 3
#  IZON += 1
  TZONE(IZON) = "WPCUSTUCOE"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "WQTYSTU"
  TMOD(IZON)  = 3
  IZON += 1
Endif
###########################################################
#si nouveau lot en entrée ou sortie pas de quantité totale
#If [M:TRS1]LOTMGTCOD = 2
#  TZONE(IZON) = "WQTYSTUNEW"
#  TMOD(IZON)  = 3
#  IZON += 1
#  TZONE(IZON) = "WCUMALLQTY"
#  TMOD(IZON)  = 3
#  IZON += 1
#Endif
# si pas reception suppression UA
If [M:TRS2]QTYPUUFLG = 1 
  TZONE(IZON) = "WQTYPUU"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "WPUU"
  TMOD(IZON)  = 3
  IZON += 1
Endif
###########################################################
#Gestion d'emplacement
If [M:TRS0]EMPFLG = 0
  TZONE(IZON) = "WLOCTYP"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "WLOC"
  TMOD(IZON)  = 3
  IZON += 1
Else
#Activité "EMP présente
  Case [M:TRS2]LOCMGTCOD1  
    When 1 :  TZONE(IZON) = "WLOCTYP"
              TMOD(IZON)  = 3
              IZON += 1
              TZONE(IZON) = "WLOC"
              TMOD(IZON)  = 3
              IZON += 1
  Endcase
Endif  

# Traitement des statuts ##################################
#Pas de statut si un seul statut autorisé et pas de table sous statuts
If ([M:TRS2]STACOD=2|[M:TRS2]STACOD=3|[M:TRS2]STACOD=5) &
&   [M:TRS3]SSTCODNBR=0 
  TZONE(IZON) = "WSTA"
  TMOD(IZON)  = 3
  IZON += 1
Endif
###########################################################
#Prix
If [M:TRS1]PRICOD   <> 1
  TZONE(IZON) = "PRI"
  TMOD(IZON)  = [M:TRS1]PRICOD
  IZON += 1
  TZONE(IZON) = "CUR"
  TMOD(IZON)  = [M:TRS1]PRICOD
  IZON += 1
Endif
###########################################################
# Flag stock existant
If [M:TRS1]LOTMGTCOD = 2 
  TZONE(IZON) = "WFLG"
  TMOD(IZON)  = 3
  IZON += 1
Endif
############################################################
# Mouvements combinés
If [M:TRS2]COBMVTCOD = 1 | ([M:TRS2]COBMVTCOD <> 1 & [M:TRS2]COBBOMALT <> 0) 
  TZONE(IZON) = "BOMALT"
  TMOD(IZON)  = 3
  IZON += 1
Endif
###########################################################
# rajout des sections analytiques           (TB  26/10/99)
# dans une dlgbox supplémentaire plutôt que dans l'écran généré !
#For I=0 To dim([M:TRS3]CCECOD)-1
#      If [M:TRS3]CCECOD(I) <> 3
#                TZONE(IZON)="CCE"+num$(I+1)
#                TMOD(IZON) =[M:TRS3]CCECOD(I)
#                IZON+=1
#      Endif
#Next I
End
###########################################################
#Génération masques de type SORTIE
Subprog TRT_SORTIE(TBLOC,TZONE,TMOD,TINT,IBLO,IZON)
Variable Integer TBLOC
Variable Char    TZONE
Variable Integer TMOD
Variable Char    TINT
Variable Integer IBLO
Variable Integer IZON
Local    Integer I
# Numéro de lot ###########################################
If [M:TRS0]LOTFLG = 0
  TZONE(IZON) = "LOT"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "WLOT"
  TMOD(IZON)  = 3
  IZON += 1
Else
  If [M:TRS1]LOTCOD <>1
    TZONE(IZON) = "LOT"
    TMOD(IZON)  = [M:TRS1]LOTCOD
    IZON += 1
    TZONE(IZON) = "WLOT"
    TMOD(IZON)  = [M:TRS1]LOTCOD
    IZON += 1
  Endif
Endif
# Titre ###################################################
#si activite "TIT" absente
If [M:TRS0]TITFLG = 0
  TZONE(IZON) = "POTACT"
  TMOD(IZON)  = 3
  IZON += 1
Else
# si activite "TIT" presente
 If [M:TRS1]POTACTCOD <> 1
   TZONE(IZON) = "POTACT"
   TMOD(IZON)  = [M:TRS1]POTACTCOD
   IZON += 1
 Endif  
Endif
# Péremption ##############################################
#si activite "EXY" absente
If [M:TRS0]EXYFLG = 0
  TZONE(IZON) = "SHLDAT"
  TMOD(IZON)  = 3
  IZON += 1
Else
#Activité "EXY" presente
  If [M:TRS1]SHLCOD <>1 
    TZONE(IZON) = "SHLDAT"
    TMOD(IZON)  = [M:TRS1]SHLCOD
    IZON += 1
  Endif  
Endif
###########################################################
#Si pas saisie unité
If [M:TRS2]UOMDACFLG = 1
  TZONE(IZON) = "YPCU"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "YPCUSTUCOE"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "YQTYSTU"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "WPCU"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "WQTYPCU"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "WQTYPCUISS"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "WPCUSTUCOE"
  TMOD(IZON)  = 3
  IZON += 1
Endif
###########################################################
#Gestion d'emplacement
If [M:TRS0]EMPFLG = 0
  TZONE(IZON) = "WLOCTYP"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "WLOC"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "YLOC"
  TMOD(IZON)  = 3
  IZON += 1
Else
#Activité "EMP présente
  Case [M:TRS2]LOCMGTCOD2 
    When 1 : TZONE(IZON) = "WLOCTYP"
             TMOD(IZON)  = 3
             IZON += 1
             TZONE(IZON) = "WLOC"
             TMOD(IZON)  = 3
             IZON += 1
             TZONE(IZON) = "YLOC"
             TMOD(IZON)  = 3
             IZON += 1
#si saisie non contrôlée
    When 2 : TZONE(IZON) = "WLOCTYP"
             TMOD(IZON)  = 3
             IZON += 1
  Endcase           
Endif
# Traitement des statuts ##################################
#Pas de statut si un seul statut autorisé et pas de table sous statuts
If ([M:TRS2]STACOD=2|[M:TRS2]STACOD=3|[M:TRS2]STACOD=5) & 
&    [M:TRS3]SSTCODNBR=0 
  TZONE(IZON) = "WSTA"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "YSTA"
  TMOD(IZON)  = 3
  IZON += 1
Endif
###########################################################
# rajout des sections analytiques           (TB  26/10/99)
# dans une dlgbox supplémentaire plutôt que dans l'écran généré !
#For I=0 To dim([M:TRS3]CCECOD)-1
#      If [M:TRS3]CCECOD(I) <> 3
#                TZONE(IZON)="CCE"+num$(I+1)
#                TMOD(IZON) =[M:TRS3]CCECOD(I)
#                IZON+=1
#      Endif
#Next I
End
###########################################################
#Génération masques de type changement emplacement
Subprog TRT_EMPLAC(TBLOC,TZONE,TMOD,TINT,IBLO,IZON)
Variable Integer TBLOC
Variable Char    TZONE
Variable Integer TMOD
Variable Char    TINT
Variable Integer IBLO
Variable Integer IZON
# Numéro de lot ###########################################
If [M:TRS0]LOTFLG = 0
  TZONE(IZON) = "LOT"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "WLOT"
  TMOD(IZON)  = 3
  IZON += 1
Else
  If [M:TRS1]LOTCOD <>1 
    TZONE(IZON) = "LOT"
    TMOD(IZON)  = [M:TRS1]LOTCOD
    IZON += 1
    TZONE(IZON) = "WLOT"
    TMOD(IZON)  = [M:TRS1]LOTCOD
    IZON += 1
  Endif  
Endif
# Titre ###################################################
#si activite "TIT" absente
If [M:TRS0]TITFLG = 0
  TZONE(IZON) = "POTACT"
  TMOD(IZON)  = 3
  IZON += 1
Else  
# si activite "TIT" presente
  If [M:TRS1]POTACTCOD <> 1
    TZONE(IZON) = "POTACT"
    TMOD(IZON)  = [M:TRS1]POTACTCOD
    IZON += 1
  Endif  
Endif
# Péremption ##############################################
#si activite "EXY" absente
If [M:TRS0]EXYFLG = 0
  TZONE(IZON) = "SHLDAT"
  TMOD(IZON)  = 3
  IZON += 1
Else  
#Activité "EXY" presente
  If [M:TRS1]SHLCOD <>1 
    TZONE(IZON) = "SHLDAT"
    TMOD(IZON)  = [M:TRS1]SHLCOD
    IZON += 1
  Endif
Endif
###########################################################
#Si pas saisie unité
If [M:TRS2]UOMDACFLG = 1
  TZONE(IZON) = "YPCU"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "YPCUSTUCOE"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "YQTYSTU"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "WPCU"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "WQTYPCU"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "WQTYPCUISS"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "WPCUSTUCOE"
  TMOD(IZON)  = 3
  IZON += 1
Endif
###########################################################
#Gestion d'emplacement
If [M:TRS0]EMPFLG = 0
  TZONE(IZON) = "WLOCTYP"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "WLOC"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "YLOC"
  TMOD(IZON)  = 3
  IZON += 1
Else
#Activité "EMP présente
  Case [M:TRS2]LOCMGTCOD1 
    When 1 :  TZONE(IZON) = "YLOC"
              TMOD(IZON)  = 3
              IZON += 1
#si saisie non contrôlée
#    When 2 :  TZONE(IZON) = "WLOCTYP"
#              TMOD(IZON)  = 3
#              IZON += 1
  Endcase            
Endif
# Traitement des statuts ##################################
#Pas de statut si un seul statut autorisé et pas de table sous statuts
If ([M:TRS2]STACOD=2|[M:TRS2]STACOD=3|[M:TRS2]STACOD=5) &
&   [M:TRS3]SSTCODNBR=0 
  TZONE(IZON) = "WSTA"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "YSTA"
  TMOD(IZON)  = 3
  IZON += 1
Endif
End
###########################################################
Subprog TRT_CTRQUA(TBLOC,TZONE,TMOD,TINT,IBLO,IZON)
Variable Integer TBLOC
Variable Char    TZONE
Variable Integer TMOD
Variable Char    TINT
Variable Integer IBLO
Variable Integer IZON
# Numéro de lot ###########################################
# si activite LOT absente
If [M:TRS0]LOTFLG = 0
  TZONE(IZON) = "LOT"
  TMOD(IZON)  = 3
  IZON += 1
Else
  If [M:TRS1]LOTCOD <>1 
    TZONE(IZON) = "LOT"
    TMOD(IZON)  = [M:TRS1]LOTCOD
    IZON += 1
  Endif  
  If [M:TRS1]BPSLOTCOD <>1 
    TZONE(IZON) = "BPSLOT"
    TMOD(IZON)  = [M:TRS1]BPSLOTCOD
    IZON += 1
  Endif  
Endif
# Titre ###################################################
#si activite "TIT" absente
If [M:TRS0]TITFLG = 0
  TZONE(IZON) = "POTACT"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "POT"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "ACT"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "DEFPOT"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "DEFACT"
  TMOD(IZON)  = 3
  IZON += 1
Else  
# si activite "TIT" presente
  If [M:TRS1]POTACTCOD <> 1
    TZONE(IZON) = "POTACT"
    TMOD(IZON)  = [M:TRS1]POTACTCOD
    IZON += 1
    TZONE(IZON) = "POT"
    TMOD(IZON)  = [M:TRS1]POTACTCOD
    IZON += 1
    TZONE(IZON) = "ACT"
    TMOD(IZON)  = [M:TRS1]POTACTCOD
    IZON += 1
    TZONE(IZON) = "DEFPOT"
    TMOD(IZON)  = [M:TRS1]POTACTCOD
    IZON += 1
    TZONE(IZON) = "DEFACT"
    TMOD(IZON)  = [M:TRS1]POTACTCOD
    IZON += 1
  Endif  
Endif
# Péremption ##############################################
#si activite "EXY" absente
If [M:TRS0]EXYFLG = 0
  TZONE(IZON) = "SHL"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "SHLDAT"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "REFPER"
  TMOD(IZON)  = 3
  IZON += 1
Else  
#Activité "EXY" presente
  If [M:TRS1]SHLCOD <>1 
    TZONE(IZON) = "SHL"
    TMOD(IZON)  = [M:TRS1]SHLCOD
    IZON += 1
    TZONE(IZON) = "SHLDAT"
    TMOD(IZON)  = [M:TRS1]SHLCOD
    IZON += 1
    TZONE(IZON) = "REFPER"
    TMOD(IZON)  = [M:TRS1]SHLCOD
    IZON += 1
  Endif
Endif
#Gestion d'emplacement
If [M:TRS0]EMPFLG = 0
  TZONE(IZON) = "WLOC"
  TMOD(IZON)  = 3
  IZON += 1
Endif
End
###########################################################
Subprog TRT_MODSTA(TBLOC,TZONE,TMOD,TINT,IBLO,IZON)
Variable Integer TBLOC
Variable Char    TZONE
Variable Integer TMOD
Variable Char    TINT
Variable Integer IBLO
Variable Integer IZON
# Titre ###################################################
#si activite "TIT" absente
If [M:TRS0]TITFLG = 0
  TZONE(IZON) = "POTACT"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "POT"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "ACT"
  TMOD(IZON)  = 3
  IZON += 1
Else  
# si activite "TIT" presente
  If [M:TRS1]POTACTCOD <> 1
    TZONE(IZON) = "POTACT"
    TMOD(IZON)  = [M:TRS1]POTACTCOD
    IZON += 1
    TZONE(IZON) = "POT"
    TMOD(IZON)  = [M:TRS1]POTACTCOD
    IZON += 1
    TZONE(IZON) = "ACT"
    TMOD(IZON)  = [M:TRS1]POTACTCOD
    IZON += 1
  Endif  
Endif
# Péremption ##############################################
#si activite "EXY" absente
If [M:TRS0]EXYFLG = 0
  TZONE(IZON) = "SHLDAT"
  TMOD(IZON)  = 3
  IZON += 1
Else  
#Activité "EXY" presente
  If [M:TRS1]SHLCOD <>1 
    TZONE(IZON) = "SHLDAT"
    TMOD(IZON)  = [M:TRS1]SHLCOD
    IZON += 1
  Endif
Endif
#Gestion d'emplacement
If [M:TRS0]EMPFLG = 0
  TZONE(IZON) = "WLOCTYP"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "WLOC"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "WLOCTYPNEW"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "WLOCNEW"
  TMOD(IZON)  = 3
  IZON += 1
Else
#Activité "EMP présente
  Case [M:TRS2]LOCMGTCOD1  
    When 1 :  TZONE(IZON) = "WLOCTYP"
              TMOD(IZON)  = 3
              IZON += 1
              TZONE(IZON) = "WLOC"
              TMOD(IZON)  = 3
              IZON += 1
              TZONE(IZON) = "WLOCTYPNEW"
              TMOD(IZON)  = 3
              IZON += 1
              TZONE(IZON) = "WLOCNEW"
              TMOD(IZON)  = 3
              IZON += 1
#si saisie non contrôlée
    When 2 :  TZONE(IZON) = "WLOCTYP"
              TMOD(IZON)  = 3
              IZON += 1
#              TZONE(IZON) = "WLOCTYPNEW"
#              TMOD(IZON)  = 3
#              IZON += 1
  Endcase
Endif
End
###########################################################
#Traitementcommuns 
Subprog TRT_COMMUN(TBLOC,TZONE,TMOD,TINT,IBLO,IZON)
Variable Integer TBLOC
Variable Char    TZONE
Variable Integer TMOD
Variable Char    TINT
Variable Integer IBLO
Variable Integer IZON
# Bloc article
If find([M:TRS0]TRSTYP,1,2,3,4,5,6,7,10,11,12)
  Case [M:TRS1]ITMCOD
    When 2 : TBLOC(0) = 2
    When 3 : TBLOC(0) = 1
  Endcase
Endif
# Numéro lot fournisseur ##################################
#If [M:TRS0]LOTFLG = 0                       <MG> 11/05/00
#                    TZONE(IZON) = "BPSLOT"  <MG> 11/05/00
#                    TMOD(IZON)  = 3         <MG> 11/05/00
#                    IZON += 1               <MG> 11/05/00
#Else                                        <MG> 11/05/00
  If [M:TRS1]BPSLOTCOD <>1
                    TZONE(IZON) = "BPSLOT"
                    TMOD(IZON)  = [M:TRS1]BPSLOTCOD
                    IZON += 1
  Endif
#Endif                                       <MG> 11/05/00
# Désignation mouvement ###################################
If [M:TRS1]MVTDESCOD <>1
  TZONE(IZON) = "MVTDES"
  TMOD(IZON)  = [M:TRS1]MVTDESCOD
  IZON += 1
Endif
# Numéro d'affaire ########################################
If [M:TRS1]PJTCOD    <>1
  TZONE(IZON) = "PJT"
  TMOD(IZON)  = [M:TRS1]PJTCOD
  IZON += 1
Endif
# Numéro de tiers #########################################
If [M:TRS1]BPRNUMCOD <>1
  TZONE(IZON) = "BPRNUM"
  TMOD(IZON)  = [M:TRS1]BPRNUMCOD
  IZON += 1
Endif
# Numéro d'ordre ou commande ##############################
If [M:TRS1]ORDNUMCOD <>1
  TZONE(IZON) = "ORDNUM"
  TMOD(IZON)  = [M:TRS1]ORDNUMCOD
  IZON += 1
  TZONE(IZON) = "ORDLIN"
  TMOD(IZON)  = [M:TRS1]ORDNUMCOD
  IZON += 1
Endif
# Numéro de pièce #########################################
If [M:TRS1]VCRNUMCOD <>1
  TZONE(IZON) = "VCRTYP"
  TMOD(IZON)  = [M:TRS1]VCRNUMCOD
  IZON += 1
  TZONE(IZON) = "VCRNUM"
  TMOD(IZON)  = [M:TRS1]VCRNUMCOD
  IZON += 1
  TZONE(IZON) = "VCRLIN"
  TMOD(IZON)  = [M:TRS1]VCRNUMCOD
  IZON += 1
Endif
#Zones utilisateurs #######################################
If [M:TRS1]USRFLDCOD1 <>1
  TZONE(IZON) = "USRFLD1"
  TMOD(IZON)  = [M:TRS1]USRFLDCOD1
  IZON += 1
Endif
If [M:TRS1]USRFLDCOD1 <>3
  TZONE(IZON) = "USRFLD1"
  TMOD(IZON)  = 7
  TINT(IZON)  = "mess(1,726,1)"
  IZON += 1
Endif
If [M:TRS1]USRFLDCOD2 <>1
  TZONE(IZON) = "USRFLD2"
  TMOD(IZON)  = [M:TRS1]USRFLDCOD2
  IZON += 1
Endif
If [M:TRS1]USRFLDCOD2 <>3
  TZONE(IZON) = "USRFLD2"
  TMOD(IZON)  = 7
  TINT(IZON)  = "mess(2,726,1)"
  IZON += 1
Endif
If [M:TRS1]USRFLDCOD3 <>1
  TZONE(IZON) = "USRFLD3"
  TMOD(IZON)  = [M:TRS1]USRFLDCOD3
  IZON += 1
Endif
If [M:TRS1]USRFLDCOD3 <>3
  TZONE(IZON) = "USRFLD3"
  TMOD(IZON)  = 7
  TINT(IZON)  = "mess(3,726,1)"
  IZON += 1
Endif
If [M:TRS1]USRFLDCOD4 <>1
  TZONE(IZON) = "USRFLD4"
  TMOD(IZON)  = [M:TRS1]USRFLDCOD4
  IZON += 1
Endif
If [M:TRS1]USRFLDCOD4 <>3
  TZONE(IZON) = "USRFLD4"
  TMOD(IZON)  = 7
  TINT(IZON)  = "mess(4,726,1)"
  IZON += 1
Endif
###########################################################
# Identifiant 1 & 2
If [M:TRS0]PALFLG = 0
  TZONE(IZON) = "WPALNUM"
  TMOD(IZON)  = 3
  IZON += 1
  TZONE(IZON) = "WCTRNUM"
  TMOD(IZON)  = 3
  IZON += 1
Else
  If [M:TRS1]PALNUMCOD <> 1
    TZONE(IZON) = "WPALNUM"
    TMOD(IZON)  = [M:TRS1]PALNUMCOD
    IZON += 1
  Endif
  If [M:TRS1]CTRNUMCOD <> 1
    TZONE(IZON) = "WCTRNUM"
    TMOD(IZON)  = [M:TRS1]CTRNUMCOD
    IZON += 1
  Endif
Endif
###########################################################
#Etiquettes
If [M:TRS2]LBEPRNCOD = 1 TZONE(IZON) = "WLBEFMT"
                    TMOD(IZON)  = 3
                    IZON += 1
Endif
If [M:TRS2]LBENBRFLG = 1 TZONE(IZON) = "WLBENBR"
                    TMOD(IZON)  = 3
                    IZON += 1
Endif
End
