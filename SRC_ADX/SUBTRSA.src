   [M:TRS1]LOTMGTCOD  = 1
   [M:TRS1]POTACTCOD  = 2
   [M:TRS1]SHLCOD     = 2
   [M:TRS1]PRICOD     = 3
   [M:TRS2]STACOD     = 8
   [M:TRS2]LOCMGTCOD1 = 1
   [M:TRS2]SUGLOCCOD1 = 1
   [M:TRS2]LOCMGTCOD2 = 1
   [M:TRS2]SUGLOCCOD2 = 1
   [M:TRS1]MVTDESCOD  = 1
   [M:TRS1]PJTCOD     = 1   
   [M:TRS1]MVTDESCOD  = 1
   [M:TRS1]VCRNUMCOD  = 3
   [M:TRS1]ORDNUMCOD  = 3
   [M:TRS2]QLYCTLFLG  = 1
 When 10 :
   [M:TRS0]SNS        = "+"
   [M:TRS1]ITMCOD     = 3
   [M:TRS1]LOTCOD     = 2
   [M:TRS1]LOTMGTCOD  = 1
   [M:TRS1]POTACTCOD  = 3
   [M:TRS1]SHLCOD     = 2
   [M:TRS1]PRICOD     = 3
   [M:TRS2]STACOD     = 1
   [M:TRS2]LOCMGTCOD1 = 1
   [M:TRS2]SUGLOCCOD1 = 1
   [M:TRS2]LOCMGTCOD2 = 1
   [M:TRS2]SUGLOCCOD2 = 1
   [M:TRS1]MVTDESCOD  = 3
   [M:TRS1]PJTCOD     = 3
   [M:TRS1]BPSLOTCOD  = 2
   [M:TRS2]QTYPUUFLG  = 1
   [M:TRS2]UOMDACFLG  = 2
  When 11 :
   [M:TRS0]SNS        = "-"
   [M:TRS1]ITMCOD     = 3
   [M:TRS1]LOTCOD     = 2
   [M:TRS1]LOTMGTCOD  = 11
   [M:TRS1]POTACTCOD  = 3
   [M:TRS1]SHLCOD     = 2
   [M:TRS1]PRICOD     = 3
   [M:TRS2]STACOD     = 2
   [M:TRS2]LOCMGTCOD1 = 1
   [M:TRS2]SUGLOCCOD1 = 1
   [M:TRS2]LOCMGTCOD2 = 1
   [M:TRS2]SUGLOCCOD2 = 1
   [M:TRS1]MVTDESCOD  = 3
   [M:TRS1]PJTCOD     = 3  
 When 12 :
   [M:TRS0]SNS        = "+"
   [M:TRS1]ITMCOD     = 2
   [M:TRS1]LOTCOD     = 1
   [M:TRS1]LOTMGTCOD  = 1
   [M:TRS1]POTACTCOD  = 3
   [M:TRS1]SHLCOD     = 1
   [M:TRS1]PRICOD     = 3
