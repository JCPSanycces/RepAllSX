#<AdxTL>@(#)193.0.0.0 $Revision$
#Lecture des codes activité
Subprog LEC_ACTIVITES
If [M:TRS0]ACTFLG <> 0
  End
Endif
###########################################################
[M:TRS0]ACTFLG = 1
Read [ACV]CODACT="LOT"
If fstat = 0 & [F:ACV]FLACT = 1
  [M:TRS0]LOTFLG = 0
Else
  [M:TRS0]LOTFLG = 1
Endif
###########################################################
Read [ACV]CODACT="TIT"
If fstat = 0 & [F:ACV]FLACT = 1
  [M:TRS0]TITFLG = 0
Else
  [M:TRS0]TITFLG = 1
Endif 
###########################################################
Read [ACV]CODACT="EMP"
If fstat = 0 & [F:ACV]FLACT = 1
  [M:TRS0]EMPFLG = 0
Else
  [M:TRS0]EMPFLG = 1
Endif 
###########################################################
Read [ACV]CODACT="EXY"
If fstat = 0 & [F:ACV]FLACT = 1
  [M:TRS0]EXYFLG = 0
Else
  [M:TRS0]EXYFLG = 1
Endif 
###########################################################
Read [ACV]CODACT="PAL"
If fstat = 0 & [F:ACV]FLACT = 1
  [M:TRS0]PALFLG = 0
Else
  [M:TRS0]PALFLG = 1
Endif 
###########################################################
Read [ACV]CODACT="TRA"
If fstat = 0 & [F:ACV]FLACT = 1
  [M:TRS0]TRAFLG = 0
Else
  [M:TRS0]TRAFLG = 1
Endif 
###########################################################
#Si pas de lots pas de titres pas d'UI pas de péremptions
If [M:TRS0]LOTFLG = 0
  [M:TRS0]TITFLG = 0
  [M:TRS0]EXYFLG = 0
Endif
End 
########################################################### 
Subprog GRISAGE(LTYP,LCOD)
Variable Integer LTYP
Variable Integer LCOD 
#  
If LTYP = 0 | GIMPORT
  End 
Endif 
If GCONSULT <> 0
  Grizo [M:TRS0]
  Grizo [M:TRS1]  
  Grizo [M:TRS2]  
  Grizo [M:TRS3]35 
  End
Endif
#
Actzo [M:TRS0]1-99
Actzo [M:TRS1]1-99  
Actzo [M:TRS2]1-99  
Actzo [M:TRS3]1-99 
If find(LTYP,1,2,7,8,9,11,12)  
  Grizo [M:TRS1]ITMCOD  
Endif 
If !find(LTYP,1,2,7,8,9) 
  Grizo [M:TRS1]MVTDESTXT 
Endif  
If find(LTYP,1,2,9)  
  Grizo [M:TRS1]ORDNUMCOD   
Endif
If find(LTYP,9)  
  Grizo [M:TRS1]VCRNUMCOD  
Endif  
If [M:TRS0]LOTFLG = 0  
  Grizo [M:TRS1]USRFLDCOD1  
  Grizo [M:TRS1]USRFLDCOD2  
  Grizo [M:TRS1]USRFLDCOD3  
  Grizo [M:TRS1]USRFLDCOD4 
#  Grizo [M:TRS1]BPSLOTCOD  <MG> 11/05/00
Endif  
If [M:TRS0]PALFLG = 0
  Grizo [M:TRS1]PALNUMCOD
  Grizo [M:TRS1]CTRNUMCOD
Endif
If find(LTYP,12)  
  Grizo [M:TRS1]BPSLOTCOD  
Endif  
If find(LTYP,8,9) | [M:TRS0]LOTFLG = 0  
  Grizo [M:TRS1]LOTCOD   
Endif  
If find(LTYP,8,9,10) | [M:TRS0]LOTFLG = 0  
  Grizo [M:TRS1]LOTMGTCOD  
Endif  
If ([M:TRS0]SNS = "-" | find(LTYP,10,12))
  Grizo [M:TRS1]PRICOD  
Endif  
If [M:TRS0]EXYFLG = 0  
  Grizo [M:TRS1]SHLCOD  
Endif  
If [M:TRS0]TITFLG = 0  
  Grizo [M:TRS1]POTACTCOD  
Endif  
If [M:TRS0]TRAFLG = 0
  Grizo [M:TRS1]TRKCOD
Endif
# sr 07.02 demande 14931
If !find(LTYP,1,3,5,7,8,9)
  Grizo [M:TRS1]AGRCOD
Endif
#
If find(LTYP,8,9,10,12)  
  Grizo [M:TRS2]UOMDACFLG  
Endif  
If find(LTYP,3,8,9,10,12)   
  Grizo [M:TRS2]DEFUOMCOD  
Endif  
If LTYP <> 3   
  Grizo [M:TRS2]QTYPUUFLG  
Endif  
If find(LTYP,1,3,5,8,9,10,12)  
  Grizo [M:TRS2]LOCMGTCOD2  
Endif  
If find(LTYP,1,3,5,8,9,10,12)  
  Grizo [M:TRS2]SUGLOCCOD2  
Endif  
If find(LTYP,2,4,6,11)  
  Grizo [M:TRS2]LOCMGTCOD1  
Endif  
If find(LTYP,2,4,6,11)  
 Grizo [M:TRS2]SUGLOCCOD1  
Endif  
If find(LTYP,3,4,5,12)  
  Grizo [M:TRS2]STACOD  
Endif  
If !find(LTYP,1,3,5,10)
  Grizo [M:TRS2]VCRFLTCOD
  Grizo [M:TRS2]ZERSTOFLG
Endif
If find(LTYP,1,5) 
  If [M:TRS2]COBMVTCOD = 1 
    Grizo [M:TRS2]COBTRSNUM   
    Grizo [M:TRS2]COBBOMALT 
  Endif 
Else 
  Grizo [M:TRS2]COBMVTCOD   
  Grizo [M:TRS2]COBTRSNUM   
  Grizo [M:TRS2]COBBOMALT  
Endif  
#  
If [M:TRS0]EMPFLG = 0
  Grizo [M:TRS2]LOCMGTCOD1
  Grizo [M:TRS2]SUGLOCCOD1
  Grizo [M:TRS2]LOCMGTCOD2
  Grizo [M:TRS2]SUGLOCCOD2
Endif
If !find(LTYP,1,3,5,7)
  Grizo [M:TRS2]WAISTOFLG
Endif
If !find(LTYP,3,5)
  Grizo [M:TRS2]SHTCOD
Endif
If find(LTYP,2,4)
  Grizo [M:TRS2]LBEPRNCOD
  Grizo [M:TRS2]LBENBRFLG
Endif
If !find(LTYP,2,4,6,8,9,11)  
  Grizo [M:TRS2]PCUCHGFLG  
Endif  
End
###########################################################
#Valeurs par défaut selon type de transaction
Subprog VAL_DEFAUT(LTYP,LCOD)
Variable Integer LTYP
Variable Integer LCOD 
If LTYP = 0 
  End 
Endif 
[M:TRS1]MVTDESTXT  = ""
[M:TRS1]USRFLDCOD1 = 3
[M:TRS1]USRFLDCOD2 = 3
