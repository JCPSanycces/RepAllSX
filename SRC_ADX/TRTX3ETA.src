#<AdxTL>@(#)4.0.0.0 $Revision$
#############################################################################
# TRTX3ETA  Traitement impressions automatiques d'état  Module Tronc commun #
# ------------------------------------------------------------------------- #
# INIT_ETAT : Ouverture tables, déclaration et initialisation des variables #
# ALIM_ETAT : Ecriture dans AREPORTM pour chaque document généré            #
# PRINT_ETAT: Impression de tous les documents en fin de génération         #
#############################################################################


##############################################################
# Initialisation appelé en début de traitement (action INIT) #
# ---------------------------------------------------------- #
#    - Ouverture des tables                                  #
#    - Déclaration des variables                             #
#                                                            #
# Nota : 9 documents différents peuvent être traités         #
#        simultanément (indices 1 à 9).                      #
#        L'indice 0 est réservé pour le document en cours de #
#        traitement WARP_RPTCOD(0).                          #
##############################################################
$INIT_ETAT
#----- Ouverture des tables si nécessaire -----#
If !clalev([F:ARP])  Local File AREPORT   [ARP] : Endif
If !clalev([F:ARM])  Local File AREPORTM  [ARM] : Endif
If !clalev([F:TPM])  Local File TABPRTMOD [TPM] : Endif
#----- Déclaration des variables locales -----#
Local Char    WARP_RPTCOD(GLONARP)(0..9) : # Codes état
Local Integer WARP_NUMREQ(1..9)          : # Numéros des requêtes pour AREPORTM
Local Integer WARP_NUMLIG(1..9)          : # Numéros de ligne pour AREPORTM
Local Integer WARP_SEQREQ(1..9)          : # Séquences des requêtes pour AREPORTM
Local Char    WARP_PRT(GLONAIM)          : # Destination (nom de l'imprimante)
Local Integer WARP_NBRCPY                : # Nombre de copies
Return


###################################################################################
# Ecriture d'un ou plusieurs enregistrements dans AREPORTM suivant nbre de copies #
# ------------------------------------------------------------------------------- #
# Paramètres E                                                                    #
#    IDOC        = Indice du document à traiter (1 à 9)                           #
#    NBRCOPIE    = Nombre de copies                                               #
# Paramètre E/S                                                                   #
#    WARP_RPTCOD = Codes état (Code état à traiter dans l'indice 0)               #
#    WARP_NUMREQ = Numéros des requêtes (récupérés si 1ère fois)                  #
#    WARP_NUMLIG = Derniers numéros de ligne utilisé dans AREPORTM                #
#    WARP_SEQREQ = Dernières séquences utilisées dans AREPORTM                    #
###################################################################################
Subprog ALIM_ETAT(IDOC,NBRCOPIE,WARP_RPTCOD,WARP_NUMREQ,WARP_NUMLIG,WARP_SEQREQ)
Value    Integer IDOC
Value    Integer NBRCOPIE
Variable Char    WARP_RPTCOD()(0..)
Variable Integer WARP_NUMREQ  (1..)
Variable Integer WARP_NUMLIG  (1..)
Variable Integer WARP_SEQREQ  (1..)
#----- Variables locales -----#
Local    Char    ETAT(GLONARP) : ETAT    =WARP_RPTCOD(0)
Local    Integer REQUETE       : REQUETE =WARP_NUMREQ(max(IDOC,1))
Local    Integer LIGNE         : LIGNE   =WARP_NUMLIG(max(IDOC,1))
Local    Integer SEQUENCE      : SEQUENCE=WARP_SEQREQ(max(IDOC,1))
Local    Integer I
Local    Integer OK
Local    Libelle WADXLOG
#----- Récupération du numéro de la requête si 1ère fois -----#
If REQUETE=0  REQUETE=uniqid([ARP]) : Endif
#----- Faire progresser la séquence si nécessaire -----#
If ETAT<>WARP_RPTCOD(max(IDOC,1))  SEQUENCE+=1 : Endif
#----- Récupération du traitement d'init correspondant à l'état -----#
If [F:ARP]RPTCOD<>ETAT
  Read [ARP] ARP0=ETAT : If fstat  Raz [F:ARP] : Endif
Endif
#-----
If [F:ARP]TRTINI<>""
  #----- Vérification existence du traitement -----#
  Call EXISTE_ADX("","",[F:ARP]TRTINI,[L]OK) From ORDSYS
  If [L]OK=1
    #----- Test si transaction en cours -----#
    If !adxlog
      [L]WADXLOG=0
      Call DEBTRANS From GLOCK
    Else
      [L]WADXLOG=1
    Endif
    #----- Màj indicateur d'impression et chargement AREPORTM -----#
    Gosub ALIM_ETAT From =[F:ARP]TRTINI
    #----- Actualisation des paramètres de l'état -----#
    WARP_RPTCOD(max(IDOC,1))=ETAT
    WARP_NUMREQ(max(IDOC,1))=REQUETE
    WARP_NUMLIG(max(IDOC,1))=LIGNE
    WARP_SEQREQ(max(IDOC,1))=SEQUENCE
    #-----
  Endif
Endif
#-----
End


###########################################################
# Impression de tous les documents créés (action TERMINE) #
# ------------------------------------------------------- #
# Paramètres E                                            #
#    IDOC        = Indice du document à traiter (1 à 9)   #
#    WARP_NUMREQ = Numéros des requêtes                   #
#    DESTINATION = Destination (nom de l'imprimante)      #
###########################################################
Subprog PRINT_ETAT(IDOC,WARP_NUMREQ,DESTINATION)
Value    Integer IDOC
Value    Integer WARP_NUMREQ(1..)
Value    Char    DESTINATION
#----- Déclaration des variables locales -----#
Local    Integer REQUETE : REQUETE=WARP_NUMREQ(max(IDOC,1))
Local    Char    TBPAR(15)(1..50)
Local    Char    TBVAL(30)(1..50)
Local    Char    WMSG(100)
#----- Déclaration variables globales -----#
Global   Integer GWNUMREQ
Global   Integer GWSEQREQ
Global   Libelle GWTRTAUTO
#----- Transmission du numéro de la requête suite au Call ETAT -----#
[V]GWNUMREQ =REQUETE
[V]GWTRTAUTO=1
#----- Impression par code document -----#
For [ARM] ARM2(4) Where NUMREQ=REQUETE & USR=GUSER
  [V]GWSEQREQ=[F:ARM]SEQREQ
  Call ETAT([F:ARM]RPTCOD,DESTINATION,"",1,"",TBPAR,TBVAL) From AIMP3
  #----- Impression dans la trace du no requête, séquence, opérateur et code état -----#
  If GTRACE<>""
    WMSG =mess(18,134,1)-"="-num$([V]GWNUMREQ)
    WMSG+=","-mess(215,188,1)-"="-num$([V]GWSEQREQ)
    WMSG+=","-mess(2,72,1)-"="-GUSER
    WMSG+=","-mess(36,135,1)-"="-[F:ARM]RPTCOD
    Call ECR_TRACE(WMSG,0) From GESECRAN
  Endif
Next
#-----
Kill GWNUMREQ, GWSEQREQ, GWTRTAUTO
End
