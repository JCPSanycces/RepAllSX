#<AdxTL>@(#)11.0.0.0 $Revision$
############################################################################
# TRTSLMCRI    Saisie des filtres pour la liste de picking des modifs lot  #
############################################################################

$ACTION
#--- Actions liés au type fenêtre de saisie
Case ACTION
 When "OUVRE_BOITE" : Gosub OUVRE_BOITE
 When "DEBUT"       : Gosub DEBUT
 When "SETBOUT"     : Gosub SETBOUT
 When "ENR"         : Gosub ENR
 When "ABA"         : Gosub ABA
Endcase
Return

#########################################################################
$OUVRE_BOITE

Gosub FORMAT_INV From STKLIB

Return

#########################################################################
$DEBUT

Local Char    WABMSK 
Local Integer I,J

Raz [M:SLR]
WABMSK           = PARAM(1)
[M:SLR]STOFCY    = evalue("[M:"+WABMSK+"]STOFCY")
[M:SLR]ITMREF    = evalue("[M:"+WABMSK+"]ITMREF")
[M:SLR]AUZSST    = evalue("[M:"+WABMSK+"]AUZSST")
[M:SLR]FORSTA    = evalue("[M:"+WABMSK+"]FORSTA")
[M:SLR]AAASTA    = evalue("[M:"+WABMSK+"]AAASTA")
[M:SLR]QQQSTA    = evalue("[M:"+WABMSK+"]QQQSTA")
[M:SLR]RRRSTA    = evalue("[M:"+WABMSK+"]RRRSTA")

# Chargement des filtres avec le filtre issu du détail stock 
If dim([M:SLR]LOC)>0
   [M:SLR]LOC = evalue("[M:"+WABMSK+"]XLOC")
Endif
[M:SLR]STA = evalue("[M:"+WABMSK+"]XSTA")

Affzo [M:SLR]

If find([M:SLR]STA,"","*")
   Actzo [M:SLR]AUZSST
Else
   Diszo [M:SLR]AUZSST
Endif
Return

#########################################################################
$SETBOUT

ETABOU(GENRE)=1
ETABOU(GABAN)=1

Return

#########################################################################
$ENR
Assign "[M:"+WABMSK+"]AUZSST" With [M:SLR]AUZSST
Assign "[M:"+WABMSK+"]FORSTA" With [M:SLR]FORSTA
Assign "[M:"+WABMSK+"]AAASTA" With [M:SLR]AAASTA
Assign "[M:"+WABMSK+"]QQQSTA" With [M:SLR]QQQSTA
Assign "[M:"+WABMSK+"]RRRSTA" With [M:SLR]RRRSTA

If dim([M:SLR]LOC)>0 Assign "[M:"+WABMSK+"]XLOC" With [M:SLR]LOC Endif
Assign "[M:"+WABMSK+"]XSTA" With [M:SLR]STA 

GOK = 1
FIN = 1

Return

#########################################################################
$ABA

# Réalimentation avec les valeurs initiales
Gosub DEBUT

Return



# Gestion du masque SLMCRI

##########################################################################
## Etiquette ajoutée par le superviseur 09/01/2004 08:52:48 (LLC)
##########################################################################
Subprog C_AUZSST(VALEUR)
Variable Char    VALEUR()
Local    Integer I,J
Local    Char    WWSTA(30)
Local    Char    WSTA(3)(20)

If VALEUR = "" : mkstat=2 : End Endif 

VALEUR = toupper(VALEUR)
WWSTA  = VALEUR
J      = instr(J,WWSTA,",")
While J <> 0
   WSTA(I) = left$ (WWSTA,J-1)
   WWSTA   = right$(WWSTA,J+1)
   J       = instr(J,WWSTA,",")
   I += 1
Wend
J = I
WSTA(I) = WWSTA
For I = 0 To J
   If !find(left$(WSTA(I),1),"A","Q","R")
      mkstat = 2 : GMESSAGE = mess(21,199,1)
      Break 
   Elsif len(WSTA(I)) > GLONSTA
      mkstat = 2 : GMESSAGE = mess(456,199,1)-num$(GLONSTA)
      Break
   Endif
Next I

# Construction de la formule :
Call DECODE_STAT(VALEUR,[M:SLR]FORSTA(nolign-1)) From TRTCATEG

End

##########################################################################
Subprog B1_AUZSST(VALEUR)
Variable Char    VALEUR()
VALEUR = [M:SLM1]AUZSST
End

##########################################################################
Subprog C_STA(VALEUR)
Variable Char    VALEUR()
Local    Integer I,J,K,L
Local    Char    WWSTA(12),  WWSRU(12)
Local    Char    WSTA(3)(6), WSRU(3)(6)
Local    Char    WSTA2(3)
Local    Char    WCRITSTA(200)

If VALEUR = "" : End : Endif

# Contrôle par rapport à la règle de gestion
VALEUR = toupper(VALEUR)
WWSTA = VALEUR
J = instr(J,WWSTA,",")
While J <> 0
   WSTA(I) = left$ (WWSTA,J-1)
   WWSTA   = right$(WWSTA,J+1)
   J       = instr(J,WWSTA,",")
   I += 1
Wend
J = I
WSTA(I) = WWSTA
For I = 0 To J
   Raz WCRITSTA
   Call CREE_FORMULE([M:SLR]FORSTA,"WSTA(I)",WCRITSTA) From TRTCATEG
   If !evalue(WCRITSTA)
      mkstat = 2 : GMESSAGE = mess(456,199,1)
      Break 
   # Le pat ne sait pas contrôler les jokers entre eux 
   Elsif right$(WSTA(I),len(WSTA(I))) = "*"
      # Dépack des sous-statuts autorisés
      WWSRU = [M:SLR]AUZSST
      L = instr(L,WWSRU,",")
      While L <> 0
         WSRU(K) = left$ (WWSRU,L-1)
         WWSRU   = right$(WWSRU,L+1)
         L = instr(L,WWSRU,",")
         K += 1
      Wend
      L = K
      WSRU(K) = WWSRU
      Case len(WSTA(I))
       When 2 : If !find(WSTA(I),WSRU(0..L)) 
                   mkstat = 2 : GMESSAGE = mess(456,199,1)
                   Break 
                Endif
       When 3 : If !find(WSTA(I),WSRU(0..L))
                   WSTA2 = left$(WSTA(I),1)+right$(WSTA(I),len(WSTA(I)))  
                   If !find(WSTA2,WSRU(0..L)) 
                      mkstat = 2 : GMESSAGE=mess(456,199,1)
                      Break 
                   Endif
                Endif
      Endcase 
   Endif
Next I
End

##########################################################################
Subprog AM_STA(VALEUR)
Variable Char    VALEUR()
If find(VALEUR,"","*")
   Actzo [M:SLR]AUZSST
Else
   Diszo [M:SLR]AUZSST
Endif
Affzo [M:SLR]AUZSST
End

##########################################################################
Subprog B1_STA(VALEUR)
Variable Char    VALEUR()
VALEUR = [M:SLM1]AUZSTA
End


##########################################################################

