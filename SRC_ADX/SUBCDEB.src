#<AdxTL>@(#)3.0.0.0 $Revision$
Local Integer  TOTO

GBIDC1="" : GBIDC2="" : GFLAG="TV04"
Call OBJET("GAS",GBIDC1,GBIDC2) From GOBJET
End


############################################################
## Sections par défaut (propre à chaque produit)
############################################################
$IDENT

#JOJAC - X3-11234 - 2017-02-28 - START
#test if finance module inactive and HR module active - run function HR_IDENT
If GMODU(2)<>2
  If GMODU(15)=2
    Gosub HR_IDENT
    Return
  Endif
Endif
#JOJAC - X3-11234 - 2017-02-28 - END

If TAB=6 or TAB=20 : # Pièce / document d'origine  => cas particulier
 Onerrgo ERREUR
 If instr(1,[F:CDE]FLD(TAB-1),"func") | instr(1,[F:CDE]FLD(TAB-1),"evalue")
  #VALEUR = evalue([F:CDE]FLD(TAB-1)) #F64268
  If [F:CDE]FLD(TAB-1)<>"" : VALEUR = evalue([F:CDE]FLD(TAB-1)) : Endif
 Else

  # Récupération de l'abréviation
  Call ABREV([F:CDE]FLD(TAB-1),ABREV)
  If instr(1,[F:CDE]FLD(TAB-1),"[F")
   If ABREV<>""
     WABREV = "[F:"+ABREV+"]"
   Else
     WABREV  = "[F]"
   Endif
  Elsif instr(1,[F:CDE]FLD(TAB-1),"[M")
   If ABREV<>""
    WABREV = "[M:"+ABREV+"]"
   Else
    WABREV = "[M]"
   Endif
  Endif

  Raz INDAXE2
  For XX=1 To GOPTCANA
   If AXE = evalue(WABREV+"DIE("+num$(XX-1)+")") : INDAXE2=XX : Break :  Endif
  Next
  If INDAXE2>0 : VALEUR = evalue([F:CDE]FLD(TAB-1)+"("+num$(INDAXE2-1)+")") : Endif
 Endif
 Onerrgo

Elsif TAB=21 # Sections précédentes => cas particulier
 # A la différence des "Pièces" ou "Document d'origne", l'utilitaire boucle sur le tableau jusqu'à trouver une valeur.
 # L’identifiant sera le nom du champ section et non sa valeur et pourra être saisi sous forme « CCE# ».

 Onerrgo ERREUR
 OLDID = [F:CCE]CCE   : OLDID2 = [F:CCE]DIE

 # Récupération de l'abréviation
 Call ABREV([F:CDE]FLD(TAB-1),ABREV)
 If instr(1,[F:CDE]FLD(TAB-1),"[F")
  If ABREV<>""
    WABREV = "[F:"+ABREV+"]"
  Else
    WABREV  = "[F]"
  Endif
 Elsif instr(1,[F:CDE]FLD(TAB-1),"[M")
  If ABREV<>""
   WABREV = "[M:"+ABREV+"]"
  Else
   WABREV = "[M]"
  Endif
 Endif

 # Recherche des axes/sections précédentes
 ABREV = "CCE"
 For XX=1 To GOPTCANA
  If evalue("dim("+WABREV+"DIE)")>0
   WAXE = evalue(WABREV+"DIE("+num$(XX-1)+")")
  Else
   WAXE = GDIE(XX)
  Endif
  WCCE = ""
  If WAXE <> ""
   FLDCCE="CCE"
   K =  instr(1,[F:CDE]FLD(TAB-1),"]")
   If K : FLDCCE = right$([F:CDE]FLD(TAB-1),K+1) : Endif
   K = instr(1,FLDCCE,"#")
   If K
    FLDCCE = left$(FLDCCE,K-1)
    WCCE = evalue(WABREV+FLDCCE+num$(XX)+"("+num$(nolign-1)+")")
   Else
    WCCE = evalue(WABREV+FLDCCE+"("+num$(XX-1)+")")
   Endif
  Endif
  If WCCE<>""
   Call LECTURE(ABREV,WCCE,WAXE) From CONTOBJ
   If fstat=0
    Raz INDAXE2
    For XY=1 To GOPTCANA
     If AXE=evalue("[F:CCE]OTHDIE("+num$(XY-1)+")") : INDAXE2=XY : Break : Endif
    Next
    If INDAXE2>0 : VALEUR = evalue("[F:CCE]DEFCCE("+num$(INDAXE2-1)+")") : Endif
   Endif
  Endif
  If VALEUR<>"" : Break : Endif
 Next
 Call LECTURE(ABREV,OLDID,OLDID2) From CONTOBJ
 Onerrgo
Else
 If TAB>0 & TAB<>D & [F:CDE]FLD(TAB-1)<>"" : # D=aucune
  Onerrgo ERREUR
  IDENT = evalue([F:CDE]FLD(TAB-1))
  Onerrgo
 Endif
 If IDENT="" & TAB=7
  Gosub SETSOC
 Endif
 If IDENT<>""
  ABREV  = ""
  ZONE   = "CCE"
  IDENT2 = ""
  IND    = 0
  Case TAB
   When 1  : ABREV = "ITM" : TABLE = "ITMMASTER"
   When 2  : ABREV = "BPC" : TABLE = "BPCUSTOMER"
   When 3  : ABREV = "BPS" : TABLE = "BPSUPPLIER"
   When 4  : ABREV = "REP" : TABLE = "SALESREP"
   When 5  : ABREV = "AUS" : TABLE = "AUTILIS"
   When 6  : # Pièce, déjà traité
   When 7  : ABREV = "CPY" : TABLE = "COMPANY"
   When 8  : ABREV = "FCY" : TABLE = "FACILITY"
   When 9  : ABREV = "TCU" : TABLE = "TABCUR"
   When 10 : ABREV = "TVT" : TABLE = "TABVAT"
   When 11 : ABREV = "SFI" : TABLE = "SFOOTINV"
   When 12 : ABREV = "TDA" : TABLE = "TABDEPAGIO"
   When 13 : ABREV = "BAN" : TABLE = "BANK"
   When 14 : ABREV = "GAC" : TABLE = "GACCOUNT"  : ZONE = "CCEDEF" : IDENT2 = [F:GAC]COA
   When 15 : ABREV = "FAS" : TABLE = "FIXASSET"
   When 16 : ABREV = "PFI" : TABLE = "PFOOTINV"
   When 17 : ABREV = "BPR" : TABLE = "BPARTNER"
   When 18 : ABREV = "MWC" : TABLE = "WORKCOST" : Onerrgo ERREUR  # zones de clé inversées ! (18/12/01)
                                                  IDENT  = evalue([F:CDE]FLD(7)) # (TB 21/02/01)
                                                  IDENT2 = evalue([F:CDE]FLD(TAB-1))
                                                  Onerrgo
   When 19 : ABREV = "ONA" : TABLE = "OVENAT" :# nouvelle table# ZONE = "CCE"+num$(AXE)+"("+num$(IND)+")"
   When 20 : # Pièce bis, déjà traité
   When 21 : # Pièce ter, déjà traité
   When 22 : ABREV = "AUS" : TABLE = "AUTILIS"
   When 23 : ABREV = "FCS" : TABLE = "FRECST" # Issue 84130 - 2013-02-25 by MAE : Ajout des charges achat
   When 24 : ABREV = "OPPPJM" : TABLE = "OPPORPJM"    : # 71065 : PJT : Gbn-PJM
   When 25 : ABREV = "PJCC"   : TABLE = "PJMCOSTCTR"  : # 71065 : PJT : Gbn-PJM
  Endcase
  If ABREV<>""
   If evalue("clalev([F:"+ABREV+"])")=0
    RELIT = 0
    Local File =TABLE
   Else
    RELIT = 1 : Raz OLDID, OLDID2
    Case TAB
     When 1  : OLDID = [F:ITM]ITMREF
     When 2  : OLDID = [F:BPC]BPCNUM
     When 3  : OLDID = [F:BPS]BPSNUM
     When 4  : OLDID = [F:REP]REPNUM
     When 5  : OLDID = [F:AUS]USR
     When 7  : OLDID = [F:CPY]CPY
     When 8  : OLDID = [F:FCY]FCY
     When 9  : OLDID = [F:TCU]CUR
     When 10 : OLDID = [F:TVT]VAT
     When 11 : OLDID = num$([F:SFI]SFINUM)
     When 12 : OLDID = [F:TDA]DEP
     When 13 : OLDID = [F:BAN]BAN
     When 14 : OLDID = [F:GAC]ACC       : OLDID2 = [F:GAC]COA
     When 15 : OLDID = [F:FAS]FASNUM    : OLDID2 = [F:FAS]FASCOD  #CHECK IGNORE_LINE (Ligne 15 n'est plus accessible sous les identifiants)
     When 16 : OLDID = num$([F:PFI]PFINUM)
     When 17 : OLDID = [F:BPR]BPRNUM
     When 18 : OLDID = [F:MWC]VLTFCY    : OLDID2 = [F:MWC]VLTCCE
     When 19 : OLDID = [F:ONA]OVENAT
     When 22 : OLDID = [F:AUS]USR
     When 23 : OLDID = [F:FCS]FCSCOD # Issue 84130 - 2013-02-25 by MAE : Ajout des charges achat
     When 24 : OLDID = [F:OPPPJM]OPPNUM : # 71065 : PJT : # Gbn-PJM
     When 25 : OLDID = [F:PJCC]PCCCOD   : # 71065 : PJT : # Gbn-PJM
    Endcase
   Endif

   If ABREV="TVT"
    Call LEC_TVT_LEG(GCURLEG,IDENT) From CPTLEC
    If fstat=0 :  Gosub INI_SEC : Endif #US223
   Elsif ABREV="TDA"
    Call LEC_TDA(GCURLEG,IDENT) From CPTLEC
    If fstat=0 :  Gosub INI_SEC : Endif #US223
   Elsif ABREV<>"GAC"
    Call LECTURE(ABREV,IDENT,IDENT2) From CONTOBJ
    If fstat=0 : Gosub INI_SEC : Endif
   Elsif ABREV="GAC"
    If clalev([F:COA])=0 : Local File GCOA [COA] : Endif
    Local Integer OKINI : OKINI = 0
    If IDENT2<>""
     Call LECTURE("COA",IDENT2,"") From CONTOBJ
     If [F:COA]ANATRK = 2
      Call LECTURE(ABREV,IDENT,IDENT2) From CONTOBJ
      If fstat = 0
       Gosub INI_SEC
       OKINI=1
      Endif
     Endif
    Endif
    If !OKINI
     Local Char    MODELE(GLONGCM), PLAN(GLONCOA)(1..10)
     Local Integer NBPLAN, REFTYP(1..10), NPLAN
     Local Char    XIDENT2(20)
     XIDENT2 = IDENT2
     Call SETPLAN3(GSOCIETE,NBPLAN,PLAN,REFTYP) From CPTDIV
     For NPLAN=1 To NBPLAN
      If XIDENT2<>PLAN(NPLAN)
       Call LECTURE("COA",PLAN(NPLAN),"") From CONTOBJ
       If [F:COA]ANATRK = 2
        Call LECTURE(ABREV,IDENT,PLAN(NPLAN)) From CONTOBJ
        If fstat=0
         IDENT2 = PLAN(NPLAN)
         Call LECTURE(ABREV,IDENT,IDENT2) From CONTOBJ
         If fstat = 0
          Gosub INI_SEC
          Break
         Endif
        Endif
       Endif
      Endif
     Next
    Endif
   Endif
   If RELIT
    If ABREV="TVT"
     Call LEC_TVT_LEG(GCURLEG,OLDID) From CPTLEC
    Elsif ABREV="TDA"
     Call LEC_TDA(GCURLEG,OLDID) From CPTLEC
    Else
     Call LECTURE(ABREV,OLDID,OLDID2) From CONTOBJ
    Endif
   Endif
  Endif
 Endif
Endif
Return

$INI_SEC
Onerrgo ERREUR
Raz INDAXE2
For XX=1 To GOPTCANA
 If AXE=evalue("[F:"+ABREV+"]DIE("+num$(XX-1)+")") : INDAXE2=XX : Break : Endif
Next
If INDAXE2>0 : VALEUR = evalue("[F:"+ABREV+"]"+ZONE+"("+num$(INDAXE2-1)+")") : Endif

Onerrgo
Return

$SETSOC
If [F:CDE]FLD(TAB)<>""
 Onerrgo ERREUR
 SITE = evalue([F:CDE]FLD(TAB))
 Onerrgo
 If SITE<>""
  ISOC = find(SITE,GSITE(1..GNBSITE))
  If ISOC
   IDENT = GSOCSITE(ISOC)
  Endif
 Endif
Endif
Return


Subprog ABREV(CHAINE,ABREV)
Value    Char CHAINE
Variable Char ABREV
Local Integer K1, K2
ABREV  = ""
CHAINE = toupper(CHAINE)
K1 = instr(1,CHAINE,":")
If !K1 : End : Endif
K2 = instr(1,CHAINE,"]")
ABREV = mid$(CHAINE,K1+1,K2-(K1+1))
End

$ERREUR
Resume

#JOJAC - X3-11234 - 2017-02-28 - START
$HR_IDENT
Local Char IDENT(100), OLDID(100)
If TAB>0 & TAB<>D & [F:CDE]FLD(TAB-1)<>""
 Onerrgo ERREUR
 IDENT = evalue([F:CDE]FLD(TAB-1))
 Onerrgo
Endif
If IDENT="" & TAB=4
 Gosub SETSOC
Endif
If IDENT<>""
 ABREV  = ""
 ZONE   = "CCE"
 IDENT2 = ""
 IND    = 0

# JOJAC - 2017-02-28 - START
#  When 1   : ABREV = "CPT" : TABLE = "EMPLOCPT"
#  When 2   : ABREV = "SRV" : TABLE = "SERVICE"
#  When 3   : ABREV = "PRF" : TABLE = "PROFIL"
#  When 4   : ABREV = "CPY" : TABLE = "COMPANY"
#  When 5   : ABREV = "FCY" : TABLE = "FACILITY"
#  When 6   : ABREV = "TCU" : TABLE = "TABCUR"
#  When 7   : ABREV = "AUS" : TABLE = "AUTILIS"
#  When 8   : ABREV = "TIM" : TABLE = "TIMCOD"
#  When 9   : ABREV = "NAT" : TABLE = "NATACTIV"
#  When 10  : ABREV = "TES" : TABLE = "TABEXPENS"
#  When 11  : ABREV = "CPR" : TABLE = "EMPLOCTRCPT"
 Case TAB
  When 7   : ABREV = "CPY" : TABLE = "COMPANY"
  When 8   : ABREV = "FCY" : TABLE = "FACILITY"
  When 9   : ABREV = "TCU" : TABLE = "TABCUR"
  When 26   : ABREV = "CPT" : TABLE = "EMPLOCPT"
  When 27   : ABREV = "SRV" : TABLE = "SERVICE"
  When 28   : ABREV = "PRF" : TABLE = "PROFIL"
  When 29   : ABREV = "AUS" : TABLE = "AUTILIS"
  When 30   : ABREV = "TIM" : TABLE = "TIMCOD"
  When 31   : ABREV = "NAT" : TABLE = "NATACTIV"
#JASMI - 2017-06-07 - X3-42325 - START
  When 32   : ABREV = "HRTES" : TABLE = "HRTABEXPENS"
#JASMI - 2017-06-07 - X3-42325 - END
  When 33   : ABREV = "CPR" : TABLE = "EMPLOCTRCPT"
 Endcase
#JOJAC - 2017-02-28 - END

 If ABREV<>""
  If evalue("clalev([F:"+ABREV+"])")=0
   RELIT = 0
   Local File =TABLE
  Else
   RELIT = 1 : Raz OLDID, OLDID2

#    JOJAC - X3-11234 - 2017-02-28 - START
#Local menu 693 combined for Finance and HR - index number changed
#    When 1  : OLDID = [F:CPT]REFNUM
#    When 2  : OLDID = [F:SRV]COD
#    When 3  : OLDID = [F:PRF]PRFCOD
#    When 4  : OLDID = [F:CPY]CPY
#    When 5  : OLDID = [F:FCY]FCY
#    When 6  : OLDID = [F:TCU]CUR
#    When 7  : OLDID = [F:AUS]USR
#    When 8  : OLDID = [F:TIM]COD
#    When 9  : OLDID = [F:NAT]COD
#    When 10 : OLDID = [F:TES]CODEXP
#    When 11 : [L]OLDID = func TRTCTRCPT.CRYPTE_IDCTR([F:CPR]REFNUM, [F:CPR]CTRNUM, [F:CPR]CTRDAT, 1)
   Case TAB
    When 7   : OLDID = [F:CPY]CPY
    When 8   : OLDID = [F:FCY]FCY
    When 9   : OLDID = [F:TCU]CUR
    When 26  : OLDID = [F:CPT]REFNUM
    When 27  : OLDID = [F:SRV]COD
    When 28  : OLDID = [F:PRF]PRFCOD
    When 29  : OLDID = [F:AUS]USR
    When 30  : OLDID = [F:TIM]COD
    When 31  : OLDID = [F:NAT]COD
    When 32  : OLDID = [F:TES]CODEXP
#DIRAS - 31-05-2017 - JIRA X3-11781 - START
    If GPRODUIT = 2 : OLDID = [F:HRTES]CODEXP : Endif
#DIRAS - 31-05-2017 - JIRA X3-11781 - END
    When 33  : [L]OLDID = func TRTCTRCPT.CRYPTE_IDCTR([F:CPR]REFNUM, [F:CPR]CTRNUM, [F:CPR]CTRDAT, 1) #11
   Endcase
#   JOJAC - X3-11234 - 2017-02-28 - END
  Endif
  # (C) PROSPER 22/07/10 - Prise en compte des infos compta contrat
  # If TAB=1
  # Read [CPT]CPT0=IDENT
  # Else
  # Call LECTURE(ABREV,IDENT,IDENT2) From CONTOBJ
  # Endif
  Case [L]TAB
    When 26
        Read [CPT]CPT0=IDENT
    #JOJAC - 2017-03-27 - START
    When 28,30,31
        Local Char WLEG(3), WCOD([V]GLONPRF)
        Local Integer WERREUR
        Call DECRYPTE_IDCOD([L]IDENT, [L]WLEG, [L]WCOD, [L]WERREUR) From TRTCTRCPT
        If not [L]WERREUR
            If [L]TAB = 28
              Read [PRF]PRF0= [L]WLEG;WCOD
            Elsif [L]TAB = 30
              Read [TIM]TIM0= [L]WLEG;WCOD
            Elsif  [L]TAB = 30
              Read [NAT]NAT0= [L]WLEG;WCOD
            Endif
        Endif
    #JOJAC - 2017-03-27 - END
      When 33
        # Pas très propre mais on ne va pas déclarer en INISEC / SUBCDE des infos "spécifiques"
        # à un produit (HRM) donné
        Local Char WREFNUM([V]GLONEML), WCTRNUM([V]GLONHRCTR)
        Local Date WCTRDAT
        Local Integer WERREUR
        Call DECRYPTE_IDCTR([L]IDENT, [L]WREFNUM, [L]WCTRNUM, [L]WCTRDAT, [L]WERREUR) From TRTCTRCPT
        If not [L]WERREUR
            Read [F:CPR]CPR0 = [L]WREFNUM ; [L]WCTRNUM ; [L]WCTRDAT
        Endif
    When Default
        Call LECTURE(ABREV,IDENT,IDENT2) From CONTOBJ
  Endcase

  If fstat=0
   Onerrgo ERREUR

   # (C) PROSPER 23/07/10 - Prise en compte des infos comptables au contrat
   #                        la table EMPLOCTRCPT est du même formalisme que
   #                        EMPLOCPT
   # If TAB=1
   # VALEUR = evalue("[F:"+ABREV+"]"+ZONE+num$(AXE))
   # Else
   # VALEUR = evalue("[F:"+ABREV+"]"+ZONE+"("+num$(AXE-1)+")")
   # Endif

   #  SBA : 92876-2580
   Gosub HR_INI_SEC
#   Case [L]TAB
#        When 1, 11
#            VALEUR = evalue("[F:"+ABREV+"]"+ZONE+num$(AXE))
#        When Default
#            VALEUR = evalue("[F:"+ABREV+"]"+ZONE+"("+num$(AXE-1)+")")
#   Endcase
    #  SBA : 92876-2580 fin
   Onerrgo
  Endif
  If RELIT
   # (C) PROSPER 22/07/10 - Prise en compte des infos compta contrat
   # If TAB=1
   # Read [CPT]CPT0=OLDID
   # Else
   # Call LECTURE(ABREV,OLDID,OLDID2) From CONTOBJ
   # Endif

   Case [L]TAB
        When 26
            Read [CPT]CPT0=OLDID
        When 33
            Call DECRYPTE_IDCTR([L]OLDID, [L]WREFNUM, [L]WCTRNUM, [L]WCTRDAT, [L]WERREUR) From TRTCTRCPT
            If not [L]WERREUR
                Read [F:CPR]CPR0 = [L]WREFNUM ; [L]WCTRNUM ; [L]WCTRDAT
            Endif
            Kill [L]WREFNUM, [L]WCTRNUM, [L]WCTRDAT, [L]WERREUR
        When Default
            Call LECTURE(ABREV,OLDID,OLDID2) From CONTOBJ
   Endcase
  Endif
 Endif
Endif
Return

$HR_INI_SEC
Onerrgo ERREUR
If(evalue('dim([F:'+ABREV+']DIE)')>0)
  Raz INDAXE2
  For XX=1 To GOPTCANA
    If AXE=evalue("[F:"+ABREV+"]DIE("+num$(XX-1)+")") : INDAXE2=XX : Break : Endif
  Next
  If INDAXE2>0 : VALEUR = evalue("[F:"+ABREV+"]"+ZONE+"("+num$(INDAXE2-1)+")") : Endif

Else
     Case [L]TAB
          When 26, 33
             VALEUR = evalue("[F:"+ABREV+"]"+ZONE+num$(AXE))
          When Default
             VALEUR = evalue("[F:"+ABREV+"]"+ZONE+"("+num$(AXE-1)+")")
     Endcase
Endif
Onerrgo
Return
#JOJAC - X3-11234 - 2017-02-28 - END

