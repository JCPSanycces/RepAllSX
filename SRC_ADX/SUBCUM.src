Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()

#delete all lists from screens if we change the legislation
If VALEUR<>GCURLEG
  Look [CUM]CUM0=VALEUR;[M]CUMCOD
#MIPEA - 2016-11-10 - X3PEOP-773- START
  If func AFNC.ACTIV("MAS")
    If fstat>1
      Effzo [M]CUMTHM,CUMNUMADI,CUMINI,CUMREP,CODGRP
    Endif
  Else
    If fstat>1
      Effzo [M]CUMTHM,CUMNUMADI,CUMINI,CUMREP
    Endif
Endif
#  If fstat>1
#    Effzo [M]CUMTHM,CUMNUMADI,CUMINI,CUMREP,CODGRP
#  Endif
Endif
#MIPEA - 2016-11-10 - X3PEOP-773- END
GCURLEG = VALEUR
End


##################################################
#ADNGO - 2016-11-25 START
#Subprog TUNCUM(COD,LEG)
Subprog TUNCUM(COD)
Variable Char    COD()
#Variable Char    LEG()
#ADNGO - 2016-11-25 END


Local Integer TOKILL
TOKILL = 0
If dim(VCOD)<1
 Global Char VCOD(GLONCUM)
 TOKILL = 1
Endif

If clalev([F:CUM])=0 : Local File CUMUL [CUM] : Endif
# To update the CUM code after the tunnel order
VCOD = COD
If VCOD="" & GLECOBJ=2
#  If no code is specified, it's better to select one of the curent legislation
  Filter [CUM] Where LEG=GCURLEG
  Read [F:CUM] First
  Filter [CUM]
  If !fstat : VCOD=[F:CUM]CUMCOD : Endif
Else
  Read [CUM]CUM0 = GCURLEG;VCOD
  #Infbox [CUM]CUMCOD
Endif

#Infbox VCOD
Call OBJET("CUM",GCURLEG,VCOD) From GOBJET
#Infbox VCOD
COD = VCOD

If TOKILL : Kill VCOD : Endif
End

