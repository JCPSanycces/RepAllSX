#<AdxTL>@(#)1.0.0.0 $Revision$  Gestion du fichier CUMULS
Raz GPILOBJ
Call OBJET("CUM",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "SETBOUT"    : Gosub SETBOUT
 When "CREATION"   : Gosub CREATION
 When "INICRE"     : Gosub INICRE
 When "INIMOD"     : Gosub INIMOD
 When "LIENS"      : Gosub LIENS
 When "APRES_CRE"  : Gosub APRES_CRE
 When "APRES_MOD"  : Gosub APRES_MOD
 When "VERF_ANU"   : Gosub VERF_ANU
 When "AP_ANNULE"  : Gosub AP_ANNULE
 When "AP_CHANGE"  : Gosub AP_CHANGE
 When "FERME"      : Gosub FERME
 When "AS_CUMCOD"  : Gosub AS_CUMCOD
 When "BS_CUMCOD"  : Gosub BS_CUMCOD
 When "ANNULE"     : Gosub ANNULE
 When "MODIF"      : Gosub MODIF
 #JOJAC - START
 When "SEL_TABLE"  : Gosub SEL_TABLE
 #JOJAC - END
Endcase
Return

$OUVRE
If clalev([F:CUM1])=0 : Local File CUMUL [CUM1] : Endif
# JOJAC - 2016-02-24 - Req 114309 US 27 - START
Default File [CUM]
# JOJAC - 2016-02-24 - Req 114309 US 27 - END
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
  If TUNNEL<>1 : VCOD = "": VCODLEG="": Return : Endif
    If dim(VCOD)<1 : Global Char VCOD(GLONCUM) : Endif
    If dim(VCODLEG)<1 : Global Char VCODLEG(GLONCUM) : Endif
#JOJAC - 2016-10-31 - START
#      VCOD = CLE2
#      VCODLEG = CLE1
      VCOD = CLE1
      VCODLEG = CLE2
#JOJAC - 2016-10-31 - END
Return


#Before selection on field COD
#############
$AS_CUMCOD
Raz GCURLEG
Return

#After selection on field COD
############
$BS_CUMCOD
# To do nothing if the user doesn't select a record
If [F:CUM]CUMCOD<>"" :
 mkstat=4                     # mkstat=4 to load again the record after selection
 If dim([M:CUM0]LEG)>=0 : [M:CUM0]LEG=[F:CUM]LEG: Endif
 GCURLEG=[F:CUM]LEG
Else
 # Else we need to update GCURLEG becaude we erased it in $AS_COD
 If dim([M:CUM0]LEG)>=0
  GCURLEG=[M:CUM0]LEG
 Elsif GLEFIL<>""
  GCURLEG=GLEGFIL
 Else
  GCURLEG=GDOSLEG
 Endif
Endif
Return

$LIENS
GCURLEG=[F:CUM]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif

# To manage translated texts (data type AX3 & AX1)
Call LECTEXTRA([M]CUMDES,"CUMUL","CUMDES",GCURLEG,[M]CUMCOD) From ATEXTRA
Call LECTEXTRA([M]CUMSHO,"CUMUL","CUMSHO",GCURLEG,[M]CUMCOD) From ATEXTRA

Call C_CUMTMP([F:CUM]CUMTMP)
[M]PRNFLG1 = [F:CUM]PRNFLG(0)
[M]PRNFLG2 = [F:CUM]PRNFLG(1)
If dim([M]CUMTYP)>0 & [M]CUMTYP>1 : Grizo RAZCUM : Else Actzo RAZCUM : Endif
Return

$SETBOUT
If REP="" & !GHISTO
 CHMEN = "1"
Else
 CHMEN = ""
Endif
If REP<>"" | !CLECUR | GHISTO=1
 Call VIREBOUT(CHAINE,"8") From GOBJET
Endif
Gosub SET_BOUT_SPE From GSAISIE
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
[M]CUMROW = [F:CUM]CUMROW
Affzo CUMROW
Return


$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$INICRE
Filter [F:CUM1] Where LEG=GCURLEG
Read [F:CUM1]CUM1 Last
Filter [F:CUM1]
If fstat>2
 [F:CUM]CUMROW = 1
Else
 [F:CUM]CUMROW = [F:CUM1]CUMROW+1
Endif

$INIMOD
[F:CUM]PRNFLG(0) = [M]PRNFLG1
[F:CUM]PRNFLG(1) = [M]PRNFLG2
If [F:CUM]CUMTYP=0 : [F:CUM]CUMTYP=1 : Endif
Return

$VERF_ANU
If clalev([F:HSP])=0 : Local File HISTOPAYE [HSP] : Endif
If clalev([F:LPA])=0 : Local File LIVREPAYE [LPA] : Endif
Local Integer K1
Filter [HSP] Where LEG=GCURLEG & RUB=CODE & TYP=6 & (AMT<>0 | BAS<>0)
Read [HSP] First
Filter [HSP]
If !fstat
 GMESSAGE = mess(22,115,1)-"HISTOPAYE\"+mess(55,123,1)-":"-[F:HSP]EMP+"\"+mess(1,115,1)
 OK = 0 : Return
Endif
For [LPA]LPA0 Where LEG=GCURLEG
 K1 = find(CODE,[F:LPA]RUBCOD(0..[F:LPA]NBRCOL-1))
 If K1 & [F:LPA]TYPAMT(K1-1)=6
  GMESSAGE = mess(22,115,1)-"LIVREPAYE\"+mess(55,123,1)-":"-[F:LPA]COD+"\"+mess(1,115,1)
  OK = 0 : Break
 Endif
Next
Return

#JOJAC - START
$SEL_TABLE
Case TABLE
  When "SELCUM"
    If clalev ([F:CUM])=0 : Local File CUMUL [CUM] : Endif
    Filter [F:CUM]
    OBJET     = "CUM"
    #ADNGO - 2016-11-25 - START
      #If PARAM(1)<>""
      #Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:CUM]LEG="'+PARAM(1)+'" | [F:CUM]LEG="")',"&") From GOBJSUB
       If GCURLEG<>""
          Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",'([F:CUM]LEG="'+GCURLEG+'" | [F:CUM]LEG="")',"&") From GOBJSUB
     #ADNGO - 2016-11-25 - END
    Endif
Endcase
Return
#JOJAC - END


$AP_CHANGE
Call CHGTEXTRA("CUMUL","CUMDES",SUPP,[L]OCODE,SUPP,[L]NCODE) From ATEXTRA
Call CHGTEXTRA("CUMUL","CUMSHO",SUPP,[L]OCODE,SUPP,[L]NCODE) From ATEXTRA

If clalev([F:HSP])=0 : Local File HISTOPAYE [HSP] : Endif
If clalev([F:LPA])=0 : Local File LIVREPAYE [LPA] : Endif
Local Integer K1 , RW
Call DEBTRANS From GLOCK
Gosub CHG_HSP
If GOK<1 : Return : Endif
Call DEBTRANS From GLOCK
Gosub CHG_LPA
If GOK<1 : Return : Endif
Call CHANGE(3,OCODE,NCODE) From CHGPLAN
Call SETPAR From GENPLAN
Return

$CHG_HSP
GOK = 1
Trbegin [HSP]
For [HSP]HSP0 Where LEG=GCURLEG & RUB=OCODE & TYP=6 With Stability
 [F:HSP]RUB=NCODE
 Rewrite [HSP]
 If fstat
  GOK = 0 : Call FSTA("HSP") From GLOCK : Break
 Endif
Next
If GOK<1 : Goto AB_HSP : Endif
Commit
Return

$ANNULE
Call SUPTEXTRA("CUMUL","CUMDES",SUPP,[L]CODE) From ATEXTRA
Call SUPTEXTRA("CUMUL","CUMSHO",SUPP,[L]CODE) From ATEXTRA
Return

$AB_HSP
Rollback
Return

$CHG_LPA
GOK = 1
Trbegin [LPA]
 For [LPA]LPA0 Where LEG=GCURLEG
  RW = 0
  For K1=1 To [F:LPA]NBRCOL
   If [F:LPA]TYPAMT(K1-1)=6 & [F:LPA]RUBCOD(K1-1)=OCODE
    [F:LPA]RUBCOD(K1-1) = NCODE
    RW = 1
   Endif
  Next K1
  If RW
   Rewrite [LPA]
   If fstat
    GOK = 0 : Call FSTA("LPA") From GLOCK : Break
   Endif
  Endif
 Next
 If GOK<1 : Goto AB_LPA : Endif
Commit
Return

$AB_LPA
Rollback
Return

$APRES_CRE
$APRES_MOD
$AP_ANNULE
Call SETPAR From GENPLAN
Return

########################################
# To manage translated texts (data type AX3 & AX1) in cretion and duplication
########################################
$TEXTRA
If GREP="D"
 ## In duplication mode we want to keep all translated texts
 Call DUPTEXTRA("CUMUL","CUMDES",CLECUR1,"","CUMUL","CUMDES",GCURLEG,[F:CUM]CUMCOD)  From ATEXTRA
 Call DUPTEXTRA("CUMUL","CUMSHO",CLECUR1,"","CUMUL","CUMSHO",GCURLEG,[F:CUM]CUMCOD)  From ATEXTRA
Endif
Call MAJTEXTRA([M]CUMDES,"CUMUL","CUMDES",GCURLEG,[F:CUM]CUMCOD) From ATEXTRA
Call MAJTEXTRA([M]CUMSHO,"CUMUL","CUMSHO",GCURLEG,[F:CUM]CUMCOD) From ATEXTRA
Return

Subprog C_CUMTMP(VALEUR)
Value Integer VALEUR
If VALEUR=2
 Effzo CUMPER,CUMINI,CUMREP
 Grizo CUMPER,CUMINI,CUMREP
Else
 Actzo CUMPER,CUMINI,CUMREP
 If [M]CUMPER=0 : [M]CUMPER = 1 : Endif
Endif
End

Subprog AS_CUMPER(VALEUR)
Variable Integer VALEUR
If [M]CUMTMP=2 : mkstat = 1 : End : Endif

# JOJAC - 2016-02-24 - Req 114309 US 27 - START
  # JASMI - 2014/03/19 - Requirement 95019 US 2547
  # Adding items to Local Menu 334 and show only items for RSA
  Call DISPLAY_ML10334() From DIVPAYE
  # JASMI - 2014/03/19 - Requirement 95019 US 2547
  # End
# JOJAC - 2016-02-24 - Req 114309 US 27 - END
End

Subprog AS_CUMINI(VALEUR)
Variable Char    VALEUR()
If [M]CUMTMP=2 : mkstat = 1 : End : Endif
End

Subprog C_CUMINI(VALEUR)
Variable Char    VALEUR()
Call CONTFRM(VALEUR) From SUBRUB
End

Subprog AS_CUMREP(VALEUR)
Variable Char    VALEUR()
If [M]CUMTMP=2 : mkstat = 1 : End : Endif
End

Subprog C_CUMREP(VALEUR)
Variable Char    VALEUR()
Call CONTFRM(VALEUR) From SUBRUB
End
##ADNGO - 2016-11-25 - START
# JOJAC - 2016-02-24 - Req 114309 US 27 - START
#Subprog CONTCUM(CODE, LEG)
Subprog CONTCUM(CODE)
Variable Char CODE()
#Value Char LEG()
#ADNGO - 2016-11-25 - END
#48648
#If instr(1,CODE,"-")
# # Caractère interdit
# GMESSAGE = "- :"-mess(94,123,1)
# mkstat=2 : End
#Endif
#If instr(1,CODE,"/")
# # Caractère interdit
# GMESSAGE = "/ :"-mess(94,123,1)
# mkstat=2 : End
#Endif
#If num$(val(CODE))=CODE
# If clalev([F:CUM])=0 : Local File CUMUL [CUM] : Endif
# Look [CUM]CUM0 = CODE
# If fstat
#  Read [CUM]CUM1 = num$(val(CODE))
#  If !fstat
#   CODE = [F:CUM]CUMCOD
#  Endif
# Endif
#Endif
# JOJAC - 2016-02-24 - Req 114309 US 27 - END
#ADNGO - 2016-11-21 - START
If GFONCTION = "GESCUM" | CODE="" : End : Endif
If clalev([F:CUM])=0 : Local File CUMUL [CUM] : Endif

If CODE <> ""
  Filter [F:CUM] Where CUMCOD=[L]CODE
  Read [F:CUM] First
  If fstat
      GMESSAGE = CODE-":"-mess(23,100,1)
      mkstat = 2 : End
  Else
      Filter [F:CUM]
      Read [F:CUM]CUM0 = GCURLEG;[L]CODE
      If fstat
        Filter [F:CUM] Where CUMCOD=[L]CODE
        Read [F:CUM] First
        GMESSAGE = CODE-":"-mess(62,127,1)-":"-[F:CUM]LEG
        mkstat = 2 : End
      Endif
  Endif
Endif
Filter [F:CUM]
End
#ADNGO - 2016-11-21 - END


Subprog D_CUMPRN(VALEUR)
Variable Char VALEUR()
Local Char CUMTITLE(GLONAX3)
Call LECTEXTRA(CUMTITLE,"CUMUL","CUMDES",GCURLEG,[M]CUMCOD) From ATEXTRA
VALEUR=left$(CUMTITLE,15)
End

Subprog AM_CUMTYP(VALEUR)
Variable Integer VALEUR
If [L]VALEUR>1 : Effzo RAZCUM : Grizo RAZCUM : Else Actzo RAZCUM : Endif
End

