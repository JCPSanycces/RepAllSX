#<AdxTL>@(#)10.0.0.0 $Revision$
###########################################################################
# FUNACHPPV : Visualisation des tarifs achats appelée                     #
#             depuis les gestions articles, fournisseurs et commandes.    #
# ----------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Traitement standard GTRAITE)                  #
#   - VISUPPVD   : Action associée au bouton détail tarif                 #
# ACTIONS modélisation WEB (Saisie de fenêtre GSAISIE)                    #
#   - VISUPPV    : Action associée au bouton visu tarif                   #
#   - VISUPPVD   : Action associée au bouton détail tarif                 #
###########################################################################

$ACTION
#######################################################
# Actions sur le traitement standard (GTRAITE)        #
# --------------------------------------------------- #
# VISUPPVD   : Action associée au bouton détail tarif #
#######################################################
Case ACTION
 When "INIT"
  #-----------------------------------------------#
  # Initialisations avant exécution du traitement #
  #-----------------------------------------------#
  Case GACTION
   When "VISUPPVD"     : Gosub INIT_VISUPPVD
  Endcase
#######################################################
# Actions sur la saisie de fenêtre (GSAISIE)          #
# --------------------------------------------------- #
# VISUPPV    : Action associée au bouton visu tarif   #
# VISUPPVD   : Action associée au bouton détail tarif #
#######################################################
 When "OUVRE"
  #--------------------------------------------------------------#
  # Avant la définition des boutons et l'ouverture de la fenêtre #
  #--------------------------------------------------------------#
  Case GACTION
   When "VISUPPV"      : Gosub OUVRE_VISUPPV
   When "VISUPPVD"     : Gosub OUVRE_VISUPPVD
  Endcase
 When "TITRE"
  #-------------------------------------#
  # Modification du titre de la fenêtre #
  #-------------------------------------#
  Case GACTION
   When "VISUPPVD"     : Gosub TITRE_VISUPPVD
  Endcase
 When "SETBOUT"
  #----------------------------#
  # Positionnement des boutons #
  #----------------------------#
  Case GACTION
   When "VISUPPV"      : Gosub SETBOUT_VISUPPV
   When "VISUPPVD"     : Gosub SETBOUT_VISUPPVD
  Endcase
 When "DEBUT"
  #---------------------------------#
  # Après l'ouverture de la fenêtre #
  #---------------------------------#
  Case GACTION
   When "VISUPPV"      : Gosub DEBUT_VISUPPV
   When "VISUPPVD"     : Gosub DEBUT_VISUPPVD
  Endcase
 When "APRES_MODIF"
  #------------------------------------#
  # Après chaque modification de champ #
  #------------------------------------#
  Case GACTION
   When "VISUPPV"      : Gosub APRES_MODIF
   When "VISUPPVD"     : Gosub APRES_MODIF
  Endcase
 When "AVANT_BOUTON"
  #--------------#
  # Avant bouton #
  #--------------#
  Case GACTION
   When "VISUPPV"      : Gosub AVBOUTON_VISUPPV
   When "VISUPPVD"     : Gosub AVBOUTON_VISUPPVD
  Endcase
 When "BOUTON"
  #--------#
  # Bouton #
  #--------#
  Case GACTION
   When "VISUPPVD"     : Gosub BOUTON_VISUPPVD
  Endcase
 When "FIN"
  #--------------------------#
  # Avant de fermer la boite #
  #--------------------------#
  Case GACTION
   When "VISUPPV"      : Gosub FIN_VISUPPV
  Endcase
 When Default
Endcase
Return


#########################################################################
#    TRAITEMENT DE L'ECRAN DE VISUALISATION DES TARIFS                  #
#########################################################################
#########################################################################
$OUVRE_VISUPPV
Local    Date     WDAT      :    WDAT=PARAM(1)
Local    Char     ITMREF    :    ITMREF=PARAM(2)
Local    Char     BPSNUM    :    BPSNUM=PARAM(3)

If dim(GWNOL)<1  Global Integer  GWNOL : Endif
GWNOL=max(nolign-1,0)

#----- Test pour savoir l'origine de l'appel -----#
If ITMREF<>"" & BPSNUM<>""
  GVISUTAR=1  : # Origine commande
Elsif ITMREF<>""
  GVISUTAR=2  : # Origine article
Elsif BPSNUM<>""
  GVISUTAR=3  : # Origine fournisseur
Else
  GVISUTAR=0  : # Origine inconnue ?
Endif
#----- Chargement des filtres article et fournisseur -----#
GFLTITM = ITMREF
GFLTBPS = BPSNUM
#-----
Local Integer NBTEX, REPONSE
Local Char    CHAINE(10) , REP(1)
Local Char    TEXTE(15)(10)
Local Char    WABB(3)           : # abb table   du critere
Local Char    WFLD(12)          : # champ table du critere
Local Integer WCRIIND
Local Char    WCRIPPC(50)
Local Char    WWCRI1(200)
Local Char    WWCRI2(110)
Local Char    WCRITOT(250)
Local Integer WNBR
Local Integer WNONSEL           : # flag de non selection sur le critere

Onerrgo ERREUR From CONTROLE
If clalev([F:PRS]) = 0 : Local File PRICSTRUCT [PRS] : Endif
If clalev([F:PPC]) = 0 : Local File PPRICCONF  [PPC] : Endif
If clalev([F:PPL]) = 0 : Local File PPRICLIST  [PPL] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITP]) = 0 : Local File ITMBPS     [ITP] : Endif
If clalev([F:BPS]) = 0 : Local File BPSUPPLIER [BPS] : Endif
If clalev([F:BPR]) = 0 : Local File BPARTNER   [BPR] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif

If GMODU(5)=2            : # si presence module vente (pour tarifs inter-societes)
   If clalev([F:SPL]) = 0 : Local File SPRICLIST  [SPL]  : Endif
   If clalev([F:BPC]) = 0 : Local File BPCUSTOMER [BPC]  : Endif
   If clalev([F:ITS]) = 0 : Local File ITMSALES   [ITS]  : Endif
   Raz [F:SPL], [F:BPC], [F:ITS]
Endif

If GFLTBPS <> ""
   If [F:BPR]BPRNUM<>GFLTBPS
      Read [BPR]BPR0=GFLTBPS
      If fstat : Raz [F:BPS] : Endif
   Endif
   If [F:BPS]BPSNUM<>GFLTBPS
      Read [BPS]BPS0=GFLTBPS
      If fstat : Raz [F:BPS] : Endif
   Endif
Endif

If GFLTITM <> ""
   If [F:ITM]ITMREF<>GFLTITM
      Read [ITM]ITM0=GFLTITM
      If fstat : Raz [F:ITM] : Endif
   Endif
Endif

Return

#########################################################################
$DEBUT_VISUPPV

Raz [M:PPV1]
[M:PPV1]ITMREF    = GFLTITM
[M:PPV1]BPSNUM    = GFLTBPS
[M:PPV1]DAT       = WDAT
Gosub LIRE

Return
#########################################################################
$SETBOUT_VISUPPV

REP = ""
If nolign = 0 | [M:PPV1]NBTAR = 0
  ETABOU(GSPE1) = 0
Else
  ETABOU(GSPE1) = 1
Endif
ETABOU(GABAN) = 1

Return
#########################################################################
$AVBOUTON_VISUPPV

WWCRI2 = [M:PPV1]WCRI2(nolign-1)
GBIDC3 = [M:PPV1]WBPC(nolign-1)

Return
###############################################################################
$FIN_VISUPPV

GFLTITM = ""
GFLTBPS = ""
GVISUTAR = 0
Return
#########################################################################
#    TRAITEMENT DE L'ECRAN DETAIL DES TARIFS                            #
#########################################################################
$INIT_VISUPPVD
Local    Char     WPLI(6)       :    WPLI=PARAM(1)
Local    Integer  WNBR
BOITE = "WA2"+WPLI
Return
#########################################################################
$OUVRE_VISUPPVD
Local    Char     WPLI(6)        :    WPLI=PARAM(1)
Local    Char     WWCRI1(200)    :    WWCRI1=PARAM(2)
Local    Char     WWCRI2(110)    :    WWCRI2=PARAM(3)

Local Char    WCRITOT(250)

WCRITOT = WWCRI1
If    WWCRI2 <> "" : WCRITOT += " & "+WWCRI2 : Endif

Onerrgo ERREUR From CONTROLE
If clalev ([TUN]) = 0 : Local File TABUNIT [TUN] : Endif
If clalev ([TCU]) = 0 : Local File TABCUR  [TCU] : Endif

Call LECTURE("PPC",WPLI,"")      From CONTOBJ
Call COLREM("C",2,[F:PPC]PLISTC) From TRTPRICE

Return

#########################################################################
$TITRE_VISUPPVD
Local Char TIT1(60)

Call TEXTE(7958,TIT) From OBJDIV
Call LECTEXTRA(TIT1,"PPRICCONF","DESAXX",[F:PPC]PLI,"") From ATEXTRA
TIT -= "-"-[F:PPC]PLI-":"-TIT1

Return
#########################################################################
$SETBOUT_VISUPPVD

REP = ""
ETABOU(GABAN)=1
If [F:PPC]PLIBPRCNR=2             # si tarif inter-societes (pas de saisie depuis les achats)
   ETABOU(GSPE1)=0
Else
   ETABOU(GSPE1)=1
Endif
If [M]PLIDAT = [0/0/0]
  ETABOU(GSPE2)=0
  ETABOU(GSPE3)=0
Else
  ETABOU(GSPE2)=1
  ETABOU(GSPE3)=1
Endif
Grizo PLI, ITMREF, BPSNUM

Return

#########################################################################
$DEBUT_VISUPPVD

Raz [M]
#[M]PLIDES = [F:PPC]PLIDES
Call LECTEXTRA ([M]PLIDES,"PPRICCONF","DESAXX",[F:PPC]PLI,"") From ATEXTRA
[M]PLITYP = [F:PPC]PLITYP
[M]ITMREF = [M:PPV1]ITMREF
[M]BPSNUM = [M:PPV1]BPSNUM
[M]PLIDAT = [M:PPV1]DAT
Gosub LIREDET
Grizo PLI, ITMREF, BPSNUM

Return

#########################################################################
$AVBOUTON_VISUPPVD

Case BOUT
  When "A" : GFLTPLI=[M]PLI
Endcase

Return

#########################################################################
$BOUTON_VISUPPVD
Case BOUT
  When "A" : GFLTPLI = ""

             If [M:PPV1]ITMREF<>""
                If [F:ITM]ITMREF<>[M:PPV1]ITMREF
                   Read [ITM]ITM0=[M:PPV1]ITMREF
                   If fstat : Raz [F:ITM] : Endif
                Endif
             Endif

             If [M:PPV1]BPSNUM<> ""
                If [F:BPR]BPRNUM<>[M:PPV1]BPSNUM
                   Read [BPR]BPR0=[M:PPV1]BPSNUM
                   If fstat : Raz [F:BPS] : Endif
                Endif
                If [F:BPS]BPSNUM<>[M:PPV1]BPSNUM
                   Read [BPS]BPS0=[M:PPV1]BPSNUM
                   If fstat : Raz [F:BPS] : Endif
                Endif
             Endif

             If [F:PPC]PLIBPRCNR=2
                Default File [SPL]
              Else
                Default File [PPL]
             Endif

             Gosub LIREDET
  When "B" : Gosub DATINF : Gosub LIREDET
  When "C" : Gosub DATSUP : Gosub LIREDET
Endcase

Return

#########################################################################
#    ETIQUETTE APRES_MODIF
#########################################################################
# Attention : Cette étiquette doit s'appeler APRES_MODIF
#             car elle est appelée depuis les AUT.!
#########################################################################
$APRES_MODIF

# Cette modif a été faite pour la version Web (le test du dbgstrt(1) est pas terrible)
# remplace le test du maskcou
Case dbgstr(1)
    When " [PPV1]" :
# Ecran de visu de tous les tarifs
        Case COUZON
             When "ITMREF"
                  [M:PPV1]ITMREF = CZ
                  Gosub LIRE
             When "BPSNUM"
                  [M:PPV1]BPSNUM = CZ
                  Gosub LIRE
             When "DAT" :
                  [M:PPV1]DAT = CZ
                  Gosub LIRE
        Endcase
    When Default :
# Ecran de visu détail d'un tarif
        Case COUZON
             When "PLIDAT"
                  [M:PPLV]PLIDAT = CZ
                  If [M:PPLV]PLIDAT = [0/0/0]
                     Disable GSTABOU+2
                     Disable GSTABOU+3
                  Else
                     Enable  GSTABOU+2
                     Enable  GSTABOU+3
                  Endif
                  Gosub DATDET
                  Gosub LIREDET
        Endcase
Endcase
Return

#########################################################################
$LIRE
Call TEMPON("L") From GESECRAN
Enable GSTABOU+1

nolign=0

WCRIPPC="1=1"

If GVISUTAR=3
  WCRIPPC +=" & [F:PPC]CRIBPR<>0"
Elsif GVISUTAR=2
  WCRIPPC +=" & [F:PPC]CRIITM<>0"
Endif

If [M:PPV1]ITMREF<>""
   If [F:ITM]ITMREF<>[M:PPV1]ITMREF
      Read [ITM]ITM0=[M:PPV1]ITMREF
      If fstat : Raz [F:ITM] : Endif
   Endif
Endif

If [M:PPV1]BPSNUM<> ""
   If [F:BPR]BPRNUM<>[M:PPV1]BPSNUM
      Read [BPR]BPR0=[M:PPV1]BPSNUM
      If fstat : Raz [F:BPR] : Endif
   Endif
   If [F:BPS]BPSNUM<>[M:PPV1]BPSNUM
      Read [BPS]BPS0=[M:PPV1]BPSNUM
      If fstat : Raz [F:BPS] : Endif
   Endif
Endif
If GMODU(5)=2
  Gosub TRT_INTER_SOC
Endif
For [PPC]PPC1 Where PLIENAFLG=2 & evalue (WCRIPPC)
  Gosub PREPFILT
  Raz GBIDC3
  If [F:PPC]PLIBPRCNR<>2
    Filter [PPL] Where evalue("PLI=[F:PPC]PLI"+WCRITOT)
     # Issue 108396 - 2015-05-29 by SR : Laisser la base déterminer la meilleure stratégie
#    Look [PPL] First
    Look [PPL] First With Nohint
    Filter [PPL]
  Else                                                     : # si tarifs inter-societes
    If dim([L]WNBR)>0 & [L]WNBR>1
      Raz J
$BOUCLE_BPC
      Read [BPC] BPC0=[L]WBPCNUM(J)
      If fstat  Raz [F:BPC] : Endif
      Filter [SPL] Where evalue("PLI=[F:PPC]PLI"+WCRITOT)
      # Issue 108396 - 2015-05-29 by SR : Laisser la base déterminer la meilleure stratégie
      #Look [SPL] First
      Look [SPL] First With Nohint
      If fstat
        J+=1
        If J<[L]WNBR  Goto BOUCLE_BPC : Endif
      Else
        GBIDC3=[F:BPC]BPCNUM
      Endif
      Filter [SPL]
    Else
      Filter [SPL] Where evalue("PLI=[F:PPC]PLI"+WCRITOT)
      # Issue 108396 - 2015-05-29 by SR : Laisser la base déterminer la meilleure stratégie
      #Look [SPL] First
      Look [SPL] First With Nohint
      Filter [SPL]
    Endif
  Endif

  If fstat<=2
#   But du test CRIBPR et CRIITM :
#       ne pas exclure de la consultation un tarif sans données classe [F] de référence dans les critères
#       ( Exemple : présence uniquement du critère [F:SPK]SALFCY )
    If [M:PPV1]BPSNUM<>"" & !find("BPR",[F:PPC]ABB) & !find("BPS",[F:PPC]ABB)
&                         & !find("BPC",[F:PPC]ABB)
&                         & [F:PPC]CRIBPR<>0
      Goto NOSELECT
    Endif
    If [M:PPV1]ITMREF<>"" & !find("ITM",[F:PPC]ABB) & !find("ITP",[F:PPC]ABB)
&                         & !find("ITS",[F:PPC]ABB)
&                         & [F:PPC]CRIITM<>0
      Goto NOSELECT
    Endif
    nolign += 1
    [M:PPV1] = [F:PPC]
    Call LECTEXTRA ([M:PPV1]PLIDES(nolign-1),"PPRICCONF","DESAXX",[F:PPC]PLI,"") From ATEXTRA
    [M:PPV1]WCRI1(nolign-1) = WWCRI1
    [M:PPV1]WCRI2(nolign-1) = WWCRI2
    [M:PPV1]WBPC(nolign-1)  = GBIDC3
    If nolign>dim([M:PPV1]PLI)-1 GERR=2 : GMESSAGE=mess(26,100,1) : Break : Endif
    $NOSELECT
  Endif
Next
[M:PPV1]NBTAR = nolign
nolign=1

Call TEMPOFF From GESECRAN
Affzo [PPV1]1-99
If [M:PPV1]NBTAR=0
   Infbox mess(99,100,1)
   Disable GSTABOU+1
Endif

Return

#########################################################################
$PREPFILT

WCRI    = ""
WWCRI1  = ""
WWCRI2  = ""
WCRITOT = ""

If [M:PPV1]ITMREF<>"" & [F:PPC]CRIITM <> 0
   ALPHA=num$([F:PPC]CRIITM)
   While ALPHA<>""
         I=val(left$(ALPHA,1)) : ALPHA=right$(ALPHA,2)
         Gosub CRITERE
   Wend
Endif

If [M:PPV1]BPSNUM <> "" & [F:PPC]CRIBPR <> 0
   ALPHA=num$([F:PPC]CRIBPR)
   While ALPHA<>""
         I=val(left$(ALPHA,1)) : ALPHA=right$(ALPHA,2)
         Gosub CRITERE
   Wend
Endif

WWCRI1 = WCRITOT
If [M:PPV1]DAT <> [0/0/0]
   If [F:PPC]PLIBPRCNR<>2
      WWCRI2 = '[M:PPV1]DAT >= [F:PPL]PLISTRDAT & [M:PPV1]DAT <= [F:PPL]PLIENDDAT'
   Else
      WWCRI2 = '[M:PPV1]DAT >= [F:SPL]PLISTRDAT & [M:PPV1]DAT <= [F:SPL]PLIENDDAT'
   Endif
   WCRITOT += " & " + WWCRI2
Endif
Return

#########################################################################
$CRITERE
Raz WNONSEL
WABB = [F:PPC]ABB(I-1)
If evalue("clalev([F:"+WABB+"])")=1
#     si critere sur table article/fourn ITMBPS, enr. doit etre garni
   If WABB="ITP"
      If [F:ITP]ITMREF<>ITMREF | [F:ITP]BPSNUM<>BPSNUM : WNONSEL=1 : Endif
   Endif
#     si critere sur table article/client ITMBPC, enr. doit etre garni
   If WABB="ITU"
      If [F:ITU]ITMREF<>ITMREF | [F:ITU]BPCNUM<>BPCNUM : WNONSEL=1 : Endif
   Endif
   If !WNONSEL
      WFLD     = [F:PPC]FLD(I-1)
      WCRIIND  = [F:PPC]CRIIND(I-1)
      WVAL     = "num$([F:"+WABB+"]"+WFLD+"("+num$(WCRIIND)+"))"
      WCRI     = 'PLICRI'+num$(I)+'='+WVAL
      WCRITOT += " & "+ WCRI
   Endif
Endif
Return

#########################################################################
$DATDET
WCRITOT = WWCRI1
If [M:PPLV]PLIDAT <> [0/0/0]
   If [F:PPC]PLIBPRCNR<>2
      WWCRI2 = '[M:PPLV]PLIDAT >= [F:PPL]PLISTRDAT & [M:PPLV]PLIDAT <= [F:PPL]PLIENDDAT'
   Else
      WWCRI2 = '[M:PPLV]PLIDAT >= [F:SPL]PLISTRDAT & [M:PPLV]PLIDAT <= [F:SPL]PLIENDDAT'
   Endif
   WCRITOT += " & "+WWCRI2
Endif
Return

#########################################################################
$DATSUP
# supérieur à date = Tarifs valides + Anciens tarifs
If [M:PPLV]PLIDAT <> [0/0/0]
   WCRITOT = WWCRI1
   If [F:PPC]PLIBPRCNR<>2
      WWCRI2 = '[M:PPLV]PLIDAT >= [F:PPL]PLISTRDAT'
   Else
      WWCRI2 = '[M:PPLV]PLIDAT >= [F:SPL]PLISTRDAT'
   Endif
   WCRITOT += " & "+WWCRI2
Endif
Return

#########################################################################
$DATINF
# inférieur à date = Tarifs valides + Futurs tarifs
If [M:PPLV]PLIDAT <> [0/0/0]
   WCRITOT = WWCRI1
   If [F:PPC]PLIBPRCNR<>2
      WWCRI2 = '[M:PPLV]PLIDAT <= [F:PPL]PLIENDDAT'
   Else
      WWCRI2 = '[M:PPLV]PLIDAT <= [F:SPL]PLIENDDAT'
   Endif
   WCRITOT += " & "+WWCRI2
Endif
Return

#########################################################################
$LIREDET
Call TEMPON("L") From GESECRAN
If [M:PPV1]ITMREF<>""
   If [F:ITM]ITMREF<>[M:PPV1]ITMREF
      Read [ITM]ITM0=[M:PPV1]ITMREF
      If fstat : Raz [F:ITM] : Endif
   Endif
Endif

If [M:PPV1]BPSNUM<> ""
   If [F:BPR]BPRNUM<>[M:PPV1]BPSNUM
      Read [BPR]BPR0=[M:PPV1]BPSNUM
      If fstat : Raz [F:BPS] : Endif
   Endif
   If [F:BPS]BPSNUM<>[M:PPV1]BPSNUM
      Read [BPS]BPS0=[M:PPV1]BPSNUM
      If fstat : Raz [F:BPS] : Endif
   Endif
Endif

If GMODU(5)=2
  Gosub TRT_INTER_SOC
Endif
If dim([L]WNBR)>0 & [L]WNBR>1 & GBIDC3<>""
  Read [BPC] BPC0=GBIDC3
  If fstat  Raz [F:BPC] : Endif
Endif

nolign=0

If [F:PPC]PLIBPRCNR<>2
   Filter [PPL] Where evalue("PLI=[F:PPC]PLI"+WCRITOT)
   For [PPL]PPL0
     nolign += 1
     [M:PPLV] = [F:PPL]
     Gosub LIENS_LIG
     If nolign>dim([M:PPLV]CRIT1)-1 GERR=2 : GMESSAGE=mess(26,100,1) : Break : Endif
   Next
   [M:PPLV]NBLIG = nolign
   Filter [PPL]
Else                                                         # si tarifs inter-societes
   Filter [SPL] Where evalue("PLI=[F:PPC]PLI"+WCRITOT)
   For [SPL]SPL0
       nolign += 1
       [M:PPLV] = [F:SPL]
       Gosub LIENS_LIG
       If nolign>dim([M:PPLV]CRIT1)-1 GERR=2 : GMESSAGE=mess(26,100,1) : Break : Endif
   Next
   [M:PPLV]NBLIG = nolign
   Filter [SPL]
Endif
Call TEMPOFF From GESECRAN
Affzo [PPLV]1-99
# Issue 104553 - 2014-12-11 by SR : Format GFORREM fait perdre le type "affiché" des frais/remises
Diszo [M:PPLV]10
# End issue 104553
Return


#------------------------------------------------------------------#
# Traitement particulier dans le contexte d'un tarif inter-société #
# ---------------------------------------------------------------- #
#    [F:BPS]BPSNUM Fournisseur    -->   Site de vente WSALFCY      #
#    WPURFCY       Site d'achat   -->   Client        WBPCNUM      #
#------------------------------------------------------------------#
$TRT_INTER_SOC
If [F:BPR]BETFCY<>2
  If dim([L]WNBR)>0  Raz [L]WNBR : Endif
  Raz [F:SPL], [F:BPC], [F:ITS] : Return
Endif
#----
If dim(J)<0        Local Integer J                     : Endif
If dim(WNBR)<0     Local Integer WNBR                  : Endif
If dim(WPURFCY)<0  Local Char    WPURFCY(GLONFCY)(100) : Endif
If dim(WSALFCY)<0  Local Char    WSALFCY(GLONFCY)      : Endif
If dim(WSALCPY)<0  Local Char    WSALCPY(GLONCPY)      : Endif
If dim(WBPCNUM)<0  Local Char    WBPCNUM(GLONBPC)(100) : Endif
If dim(WBETCPY)<0  Local Integer WBETCPY               : Endif
Raz [L]WNBR, [L]WPURFCY, [L]WSALFCY, [L]WSALCPY, [L]WBPCNUM, [L]WBETCPY
If !clalev([M:BPS0]) & !clalev([M:ITM0])
  If clalev([M:POH0])
    [L]WPURFCY(0)=[M:POH0]POHFCY
    [L]WSALFCY   =[M:POH0]SALFCY
    [L]WBPCNUM(0)=[M:POH0]BPCORD
    [L]WBETCPY   =[M:POH0]BETCPY
  Elsif clalev([M:POI1])
    [L]WPURFCY(0)=[M:POI1]POHFCY
    [L]WSALFCY   =[M:POI1]SALFCY(GWNOL)
    [L]WBPCNUM(0)=[M:POI1]BPCORD(GWNOL)
    [L]WBETCPY   =[M:POI1]BETCPY(GWNOL)
  Elsif clalev([M:POC0])
    [L]WPURFCY(0)=[M:POC0]POHFCY
    [L]WSALFCY   =[M:POC0]SALFCY
    [L]WBPCNUM(0)=[M:POC0]BPCORD
    [L]WBETCPY   =[M:POC0]BETCPY
  Elsif clalev([M:PTH1])
    [L]WPURFCY(0)=[M:PTH1]POHFCY(GWNOL)
    [L]WSALFCY   =[M:PTH0]SALFCY
    #----- Recherche du client car le champ n'est pas présent dans l'écran -----#
    Filter [BPR] Where BPCFLG=2
    Read [BPR] BPR2(2)=2;[L]WPURFCY(0)
    If fstat  Raz [F:BPR] : Endif
    [G:BPR]currind=1 : [G:BPR]currlen=0  : # Réinitialisation clé par défaut
    Filter [BPR]
    [L]WBPCNUM(0)=[F:BPR]BPRNUM
    #-----
    [L]WBETCPY   =[M:PTH0]BETCPY
  Elsif clalev([M:PNH1])
    [L]WPURFCY(0)=[M:PNH1]POHFCY(GWNOL)
    [L]WSALFCY   =[F:BPR]FCY
    #----- Recherche du client car le champ n'est pas présent dans l'écran -----#
    Filter [BPR] Where BPCFLG=2
    Read [BPR] BPR2(2)=2;[L]WPURFCY(0)
    If fstat  Raz [F:BPR] : Endif
    [G:BPR]currind=1 : [G:BPR]currlen=0  : # Réinitialisation clé par défaut
    Filter [BPR]
    [L]WBPCNUM(0)=[F:BPR]BPRNUM
    #-----
    [L]WBETCPY   =[M:PNH1]BETCPY
  Else
    [L]WSALFCY   =[F:BPR]FCY
  Endif
Else
  [L]WSALFCY   =[F:BPR]FCY
Endif
#-----
Read [FCY] FCY0=[L]WSALFCY
If fstat  Raz [F:FCY] : Endif
[L]WSALCPY=[F:FCY]LEGCPY
If [L]WPURFCY(0)=""
  Filter [BPR] Where BETFCY=2 & FCY<>"" & FCY<>[L]WSALFCY
  For [BPR] BPR2
    Read [FCY] FCY0=[F:BPR]FCY
    If fstat
      Raz [F:FCY]
    Else
      If [L]WSALCPY<>[F:FCY]LEGCPY
        [L]WPURFCY([L]WNBR)=[F:BPR]FCY
        [L]WNBR+=1
        If [L]WNBR>99  Break : Endif
      Endif
    Endif
  Next
  Filter [BPR]
  If [L]WPURFCY(0)=""
    Raz [F:BPR] : [L]WPURFCY(0)=GFCYDEF(6)
  Else
    [L]WBETCPY=2
  Endif
Else
  [L]WNBR=1
Endif
#-----
If [L]WBETCPY=1 | [L]WNBR<1
  Raz [F:SPL], [F:BPC], [F:ITS] : Return
Endif
If [L]WBPCNUM(0)<>""
  Read [BPC] BPC0=[L]WBPCNUM(0)
  If fstat  Raz [F:BPC] : Endif
Else
  Filter [BPR] Where BPCFLG=2
  For J=0 To [L]WNBR-1
    Read [BPR] BPR2(2)=2;[L]WPURFCY(J)
    If !fstat  [L]WBPCNUM(J)=[F:BPR]BPRNUM : Endif
  Next J
  [G:BPR]currind=1 : [G:BPR]currlen=0
  Filter [BPR]
  If WNBR=1
    Read [BPC] BPC0=[L]WBPCNUM(0)
    If fstat  Raz [F:BPC] : Endif
  Else
    Raz [F:BPR], [F:BPC]
  Endif
Endif
If [F:ITM]ITMREF<>""
  Read [ITS] ITS0=[F:ITM]ITMREF : If fstat  Raz [F:ITS] : Endif
Endif
Return


#########################################################################
$LIENS_LIG

# éclatement des critères
If [F:PPC]PLIBPRCNR<>2
   MANIP=[F:PPL]PLICRI
Else
   MANIP=[F:SPL]PLICRI
Endif
For RG=1 To dim([F:PPC]FLD)
 JK=instr(1,MANIP,"~")
 If JK
  Case [F:PPC]FLDTYP(RG-1)
   When "C","L","DCB","M","SFI","RAT","COE","WEI","OPE"
    Assign "[M]CRIT"+num$(RG)+"(nolign-1)" With val(left$(MANIP,JK-1))
   When Default
    Assign "[M]CRIT"+num$(RG)+"(nolign-1)" With left$(MANIP,JK-1)
  Endcase
  MANIP=(right$(MANIP,JK+1))
 Endif
Next RG
For RG=1 To 9
  If [F:PPC]PLIBPRCNR<>2
     Assign "[M]XFRAREM"+num$(RG)+"(nolign-1)" With [F:PPL]DCGVAL(RG-1)
  Else
     Assign "[M]XFRAREM"+num$(RG)+"(nolign-1)" With [F:SPL]DCGVAL(RG-1)
  Endif

Next RG
Return

#########################################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
If GVISUTAR=2 & VALEUR=""
  mkstat=2 : End
Endif
Call LECTURE("ITM",VALEUR,"") From CONTOBJ
End

#########################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
End

#########################################################################
Subprog C_BPSNUM(VALEUR)
Variable Char    VALEUR()
If GVISUTAR=3 & VALEUR=""
  mkstat=2 : End
Endif
Call LECTURE("BPS",VALEUR,"") From CONTOBJ
Call LECTURE("BPR",VALEUR,"") From CONTOBJ
End

#########################################################################
Subprog AV_NBLIG
# --- Visu du libellé dans cadre du bas
[M]AFFLIB=""
If    [F:PPC]CRIITMNUM <> 0 & nolign > 0
      Call LECTURE("ITM",evalue("[M]CRIT"+num$([F:PPC]CRIITMNUM)+"(nolign-1)"),"") From CONTOBJ
      #If !fstat : [M]AFFLIB  = mess(14,195,1) + " : " + [F:ITM]ITMDES1 : Endif              # FGR 30/06/2009 : X3SUIVI56189
      If !fstat
        Local Char WITMDES(GLONDES)                                                          # FGR 30/06/2009 : X3SUIVI56189

        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,WITMDES, "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
        [M]AFFLIB  = mess(14,195,1) + " : " + WITMDES                                        # FGR 30/06/2009 : X3SUIVI56189
      Endif
Endif
If    [F:PPC]CRIBPSNUM <> 0 & nolign > 0
      Call LECTURE("BPR",evalue("[M]CRIT"+num$([F:PPC]CRIBPSNUM)+"(nolign-1)"),"") From CONTOBJ
      If !fstat
         If [M]AFFLIB <> "" : [M]AFFLIB += " / " : Endif
         [M]AFFLIB += mess(73,198,1) + " : " + [F:BPR]BPRNAM
      Endif
Endif
Affzo [M]AFFLIB
End

