#<AdxTL>@(#)3.0.0.0 $Revision$
End

#----------------------------------------------------------------------------------------------------------#
# This operation is used for create a file .lka for sign a workflow
#
#
# use this url
# http://sosyrsuperv:8124/sdata/x3/erp/SUPERV/$service/sign?chrono=ccc-aaa&key=kkk&directory=ddd
#
# use GET for create this file on the server
#
# The file "ccc-aaa.lka" is created in the directory "ddd"
# This file contains "K=yyy"
#----------------------------------------------------------------------------------------------------------#

#**
#* Funprog HANDLER_GET()
#*!
Funprog HANDLER_GET(ACTX,ASWK,ARCV,PSYR,ASND)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND

Local Integer   ERROR : ERROR = [V]CST_AOK

ERROR = func NEW(ACTX,ASND,PSYR,ARCV,PSYR.SELREP)
End ERROR

#--------------------------------------------------------------------------------#
Funprog NEW(ACTX,ASND,PSYR,PARCV,KEYS)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASND  Using C_ASYRSND
Variable Instance PSYR  Using C_ASYR
Variable Instance PARCV Using C_ASYRRCV
Value    Char     KEYS

Local Integer ERROR

Local Integer I , J , K , ERR , EXIST , ASTATUS
Local Char    CHRONO(80) , KEYS(200) , DIRECT(80) , CHAINE(250) , MESSAGE(250)
Local Char    FILE_LKA(250) , FILE_PATH(250) , ERRTIT(80) , DIR(250)
Local Char    COMMAND(50) , ORDSYS(250) , MAC(250) , RAC(250)
Local Char    LANGUE(10) , OLDLAN(10)

#{SAM 120589
CHRONO = func ASYRMAIN.PARVAL(PARCV,"chrono")
If !len(CHRONO)
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,func AFNC.MES1(mess(59,149,1),"chrono"))
 Goto ERR_DETAIL
Endif
KEYS = func ASYRMAIN.PARVAL(PARCV,"key")
DIRECT = func ASYRMAIN.PARVAL(PARCV,"directory")
LANGUE = func ASYRMAIN.PARVAL(PARCV,"language")
#SAM 120589}

Gosub SET_LAN

RAC = vireblc(fmet GACTX.APARAM.AGETVALCHAR(CST_ALEVFOLD,"","WRKRMTDIR"),2)
MAC = fmet GACTX.APARAM.AGETVALCHAR(CST_ALEVFOLD,"","WRKRMTMAC")

Onerrgo ERRORS
CHAINE = filpath("","","","","",MAC)
Onerrgo
If ERR
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,MAC-":"-mess(199,100,1))
 Goto ERR_DETAIL
Endif

K = instr(1,RAC,"]")
If K
 Gosub ENUM_VOLFIL_TYPE  From ASYRSTO

 ASTATUS = func ASYRSTO.CTL_VOLFIL(2,RAC,CHAINE,E_TYPE_FILEWRITE,MESSAGE)
 If ASTATUS<>CST_AOK
  ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,MESSAGE)
  Goto ERR_DETAIL
 Else
  RAC = CHAINE
 Endif
Endif

Onerrgo ERRORS
CHAINE = filpath(RAC,"","","","",MAC)
Onerrgo
If ERR
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,RAC-":"-mess(147,141,1))
 Goto ERR_DETAIL
Endif

DIR = RAC
If DIRECT<>""
 If DIR<>"" & !find(right$(DIR,len(DIR)),"/","\") : DIR += "/" : Endif
 DIR += DIRECT
Endif

CHAINE = filpath(DIR,"","","","",MAC)
Call EXIST(CHAINE,EXIST) From ASYRSYS
Case EXIST
 When 2 : # ok
 When 1 : # this file is not a folder
  ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,func AFNC.MES1(mess(52,149,1),CHAINE))
  Goto ERR_DETAIL
 When 0 : # this folder don't exist -> create this folder
  K = instr(1,CHAINE,"@")
  If K
   ORDSYS = left$(CHAINE,K)+'ae_mkdir'-'"'+right$(CHAINE,K+1)+'"'
  Else
   ORDSYS = 'ae_mkdir'-'"'+CHAINE+'"'
  Endif
  System COMMAND=ORDSYS
  Call EXIST(CHAINE,EXIST) From ASYRSYS
  If EXIST<>2
   ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,func AFNC.MES1(mess(53,149,1),CHAINE))
   Goto ERR_DETAIL
  Endif
Endcase

FILE_LKA  = CHRONO
FILE_PATH = filpath(DIR,FILE_LKA,"lka","","",MAC)
Onerrgo ERRORS
Openo FILE_PATH,0      Using [FIC_]
Iomode adxirs chr$(10) Using [FIC_]
Iomode adxifs ''       Using [FIC_]
Iomode adxium GUTF8    Using [FIC_]
Wrseq "K="+KEYS        Using [FIC_]
Openo                  Using [FIC_]
Onerrgo

If ERR or filinfo(FILE_PATH,0)<=0
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,func AFNC.MES1(mess(54,149,1),FILE_LKA))
 Goto ERR_DETAIL
Endif

If instr(1,CHRONO,"-VAL")
 # Votre demande de validation a bien été prise en compte
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AINFO,[V]CST_AHTTP_OK,mess(201,75,1))
Elsif instr(1,CHRONO,"-REJ")
 # Votre demande de rejet a bien été prise en compte
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AINFO,[V]CST_AHTTP_OK,mess(202,75,1))
Else
 ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AINFO,[V]CST_AHTTP_OK,'The creation of file'-FILE_LKA-'is completed')
Endif
ASND.URL      = PSYR.PREFIX+'/sign'
ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+".sign"

Gosub RESET_LAN

End ERROR

#------------------------------------------#
# Error response
#------------------------------------------#

$ERR_DETAIL
Gosub RESET_LAN
End ERROR

#--------------------------------------#
# Errors management
#--------------------------------------#

$ERRORS
ERR = errn
ERRTIT = errmes$(errn)
Resume

#--------------------------------------------------------------------------#
# Miscellaneous programs
#--------------------------------------------------------------------------#

$SET_LAN
OLDLAN = ""
If LANGUE<>"" & LANGUE<>messname(0)
 OLDLAN = messname(0)
 messname(0) = LANGUE
 adxmbm = adxmbm
Endif
Return

#-----------------#
$RESET_LAN
If OLDLAN<>""
 messname(0) = OLDLAN
 adxmbm = adxmbm
Endif
Return

