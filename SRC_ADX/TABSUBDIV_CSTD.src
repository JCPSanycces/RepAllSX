#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$
# Class TABSUBDIV   Geographic subdivisions

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AREAD"                      : Gosub AREAD
      When "AINSERT_CONTROL_BEFORE"     : Gosub AINSERT_CONTROL_BEFORE
      When "AINSERT_CONTROL_AFTER"      : Gosub AINSERT_CONTROL_AFTER
      When "AINSERT"                    : Gosub AINSERT
      When "AUPDATE_CONTROL_AFTER"      : Gosub AUPDATE_CONTROL_AFTER
      When "AUPDATE"                    : Gosub AUPDATE
      When "ADELETE"                    : Gosub ADELETE
    Endcase
  When "COLATU"
    Case [L]AEVENT
      When "AREAD_AFTER"            : Gosub COLATU_AREAD_AFTER
      When "ADDLINE_AFTER"          : Gosub COLATU_ADDLINE_AFTER
      When "ADDLINE_BEFORE"          : Gosub COLATU_ADDLINE_BEFORE
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "TYP"                : Gosub TYP
  When "CRY"                : Gosub CRY
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return



############################################################################################################
$AREAD
Local Integer ILINE
ILINE=0
Local File TABSUBDIV [ATU]
For [ATU] Where [ATU]CRY=this.CRY & [ATU]TYP=this.TYP
  ILINE = fmet this.ADDLINE("COLATU",[V]CST_ALASTPOS)
    If ILINE <> CST_ANOTDEFINED
      [L]ASTATUS = fmet this.COLATU(ILINE).AREAD([F:ATU]CRY,[F:ATU]TYP,[F:ATU]COD)
      Break ([L]ASTATUS>=[V]CST_AERROR)
    Else
      [L]ASTATUS=[V]CST_AERROR
      Break
    Endif
    If [L]ASTATUS= CST_AOK
      this.COLATU(ILINE).ASTALIN=[V]CST_ALL
    Endif
Next
# Not found
If ILINE=0
  [L]ASTATUS = fmet this.ASETERROR("",mess(81,75,1),[V]CST_AERROR)
Endif
Return

######################################################################################################
$AINSERT_CONTROL_BEFORE
Local File TABSUBDIV [ATU]
For [ATU] Where [F:ATU]CRY= this.CRY and [F:ATU]TYP=this.TYP
  [L]ASTATUS = fmet this.ASETERROR("TYP",mess(22,100,1),[V]CST_AERROR)
  Break
Next
Return

######################################################################################################
$AINSERT_CONTROL_AFTER
Gosub CTL_CONSISTENCY
Return

############################################################################################################
$AINSERT
Local Integer ILINE
For ILINE=1 To maxtab(this.COLATU)
  If this.COLATU(ILINE)<> null
    If this.COLATU(ILINE).ASTALIN = [V]CST_ANEW
      [L]ASTATUS = fmet this.COLATU(ILINE).AINSERT()
      If ([L]ASTATUS>=[V]CST_AERROR)
        Break
      Endif
    Endif
  Endif
Next
Return


###################################################################################################
$AUPDATE_CONTROL_AFTER
Gosub CTL_CONSISTENCY
Return


###################################################################################################
$CTL_CONSISTENCY
Local Shortint LINE_FOUND
Local Integer ILINE, ILINE_SEARCH
  For ILINE=1 To maxtab(this.COLATU)
    If this.COLATU(ILINE)<>null
      If find(this.COLATU(ILINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
        LINE_FOUND=1
        For ILINE_SEARCH= ILINE+1 To maxtab(this.COLATU)
          If this.COLATU(ILINE_SEARCH)<>null
            If find(this.COLATU(ILINE_SEARCH).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
              If this.COLATU(ILINE).COD= this.COLATU(ILINE_SEARCH).COD
                [L]ASTATUS = fmet this.ASETERROR("", this.COLATU(ILINE).COD -":"-mess(94,139,1),[V]CST_AERROR)
                Break 2
              Endif
            Endif
          Endif
        Next ILINE_SEARCH
      Endif
    Endif
  Next ILINE
  If LINE_FOUND=0
    [L]ASTATUS = fmet this.ASETERROR("",mess(178,123,1),[V]CST_AERROR)
  Endif
Return

############################################################################################################
$AUPDATE
# First - Delete the lines that have been removed from the collection
For ILINE= 1 To maxtab(this.COLATU)
  If this.COLATU(ILINE)<> null
    If this.COLATU(ILINE).ASTALIN = [V]CST_ADEL
      [L]ASTATUS = fmet this.COLATU(ILINE).ADELETE()
      If [L]ASTATUS>=[V]CST_AERROR
        Break
      Endif
    Endif
  Endif
Next


If [L]ASTATUS>=[V]CST_AERROR
  Return
Endif

  # Second - Update existing and changed lines
 For ILINE= 1 To maxtab(this.COLATU)
  If this.COLATU(ILINE)<> null
    If this.COLATU(ILINE).ASTALIN = [V]CST_AUPD
      [L]ASTATUS = fmet this.COLATU(ILINE).AUPDATE()
      If [L]ASTATUS>=[V]CST_AERROR
        Break
      Endif
    Endif
  Endif
Next

If [L]ASTATUS>=[V]CST_AERROR
  Return
Endif

  # Finally - Insert new lines
For ILINE= 1 To maxtab(this.COLATU)
  If this.COLATU(ILINE)<> null
    If this.COLATU(ILINE).ASTALIN = [V]CST_ANEW
      [L]ASTATUS = fmet this.COLATU(ILINE).AINSERT()
      If [L]ASTATUS>=[V]CST_AERROR
        Break
      Endif
    Endif
  Endif
Next

Return

############################################################################################################
$ADELETE
Local Integer ILINE
For ILINE= 1 To maxtab(this.COLATU)
  If this.COLATU(ILINE)<> null
    [L]ASTATUS = fmet this.COLATU(ILINE).ADELETE()
    Break  ([L]ASTATUS>=[V]CST_AERROR)
  Endif
Next
Return


############################################################################################################
$COLATU_AREAD_AFTER
# Assign ASTALIN to CST_ALL (they have CST_NEW as value after AREAD method)
this.ASTALIN = [V]CST_ALL
Return

############################################################################################################
$COLATU_ADDLINE_AFTER
#** To initialize properties of the header
this.CRY = this.APARENT.CRY
this.TYP = this.APARENT.TYP
Return

############################################################################################################
$COLATU_ADDLINE_BEFORE
Gosub CONTROL_IF_SUBDIV_ALLOW
Return

############################################################################################################
$CONTROL_IF_SUBDIV_ALLOW
If this.CRY<>AVOID.ACHAR
  Local Integer ETATFLG
  Local Integer ETATFLG2
  ETATFLG = fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"ETATFLG")
  ETATFLG2 = fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"ETATFLG2")
  If ETATFLG<>[V]CST_AYES and ETATFLG2<>[V]CST_AYES
    [L]ASTATUS = fmet this.ASETERROR("CRY",this.CRY - ":"-mess(213,139,1),[V]CST_AERROR)
  Endif
Endif
Return


#######################################################################################################
$CRY
Case [L]ARULE
    When "PROPAGATE"     : Gosub CRY_PROP
  When Default
Endcase
Return

$TYP
Case [L]ARULE
  When "CONTROL"      : Gosub TYP_CONTROL
  When "PROPAGATE"    : Gosub TYP_PROPAGATE
Endcase
Return




#######################################################################################################
$CRY_PROP
If this.CRY<>AVOID.ACHAR
  Local Integer ETATFLG
  Local Integer ETATFLG2
  ETATFLG = fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"ETATFLG")
  ETATFLG2 = fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"ETATFLG2")
  If ETATFLG<>[V]CST_AYES and ETATFLG2<>[V]CST_AYES
    [L]ASTATUS = fmet this.ASETERROR("CRY",this.CRY - ":"-mess(213,139,1),[V]CST_AERROR)
    Return
  Endif

  # Initialize type according to subdivision value country
  # Subdivision 1
  If ETATFLG=[V]CST_AYES
    this.TYP = 2
  Else
    If ETATFLG2=[V]CST_AYES
      this.TYP = 3
    Endif
  Endif
Endif

Local Integer ILINE
For ILINE=1 To maxtab(this.COLATU)
  If this.COLATU(ILINE)<> null
    this.COLATU(ILINE).CRY = this.CRY
  Endif
Next
Return

#######################################################################################################
#**
#* TYP - Allow TYP menu selection based on country setup
#*!
$TYP_CONTROL
If this.CRY<>AVOID.ACHAR
  If this.TYP=1
    [L]ASTATUS = fmet this.ASETERROR("TYP",mess(126,143,1),[V]CST_AERROR)
    Return
   Endif

  # Subdivision 1
  If this.TYP = 2 & fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"ETATFLG")<>[V]CST_AYES
    [L]ASTATUS = fmet this.ASETERROR("TYP",mess(83,123,1),[V]CST_AERROR)
    Return
  Endif

  # Subdivision 2
  If this.TYP = 3 & fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"ETATFLG2")<>[V]CST_AYES
    [L]ASTATUS = fmet this.ASETERROR("TYP",mess(83,123,1),[V]CST_AERROR)
    Return
  Endif
Endif
Return


$TYP_PROPAGATE
Local Integer ILINE
For ILINE=1 To maxtab(this.COLATU)
  If this.COLATU(ILINE)<> null
    this.COLATU(ILINE).TYP = this.TYP
  Endif
Next
Return

