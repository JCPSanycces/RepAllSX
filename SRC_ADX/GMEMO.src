#<AdxTL>@(#)12.0.0.0 $Revision$ Action MEMO
#-------------------------------------------------------------------------------------------------#
#   Gestion des mémos
#-------------------------------------------------------------------------------------------------#
#   Un nom de fichier mémo se présente sous la forme UUU_RRR.XXX
#
#     * UUU code utilisateur  : GUSER (mémos utilisateurs) ou GSUPER (mémos globaux)
#     * RRR référence du mémo : nom de la table _ (cas de la gestion d'objet) + code mémo
#     * XXX code extension    : sel(glo) , gle , rpt , etc.
#
#   Paramètres de l'action MEMO à utiliser sur les boutons Mémo Rappel et Efface
#
#     * Abréviation des écrans en dur ([M:DIA],[M:XXX]) ou dans une variable dimensionnée
#     * Table~Extension : les codes extensions sont gérés dans la table AMEMO
#     * Type évènement : 1 Mémo , 2 Rappel , 3 Efface
#
#   Remarques
#
#     * Subprog LECMEMO : user = GUSER
#     * Subprog LECMEMOPT : user = GSUPER
#     * La sélection avancée (gestion d'objet) permet de gérer des mémos accessibles à tous (.glo)
#       ou des mémos personnalisés (.sel) suivant la valeur de la case à cocher "Global".
#       Les mémos globaux sont rattachés à l'utilisateur GSUPER.
#     * Les mémos UUU_STD.sel(glo) sont appelés automatiquement au début de la gestion d'un objet.
#     * La table AOBJSEL permet de sauvegarder les intitulés des mémos .sel et .glo
#       Ces intitulés apparaissent dans le menu "Sélection" de la gestion d'objet.
#
#-------------------------------------------------------------------------------------------------#

Local Mask AMK0 [AMK0]
Local Char VALBOUT(30) , PARBOUT(30)(1..30)
PARBOUT(1) = "[M:AMK0]"
PARBOUT(2) = "sel"
PARBOUT(3) = "1"
Call SAISIE_CHAR(VALBOUT,PARBOUT,"GMEMO","GMEMO","") From GSAISIE
End

#-----------------------------------------------------------#
# Action MEMO
#-----------------------------------------------------------#

$ACTION
Case ACTION
 When "TITRE"       : Gosub TIT
 When "OUVRE"       : Gosub OUVRE
 When "DEBUT"       : Gosub DEBUT
 When "OK"          : Gosub OK
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "FINSAI"      : Gosub FINSAI
Endcase
Return

#-----------------------------------------------------------#
$OUVRE
If clalev([F:AOS])=0  : Local File AOBJSEL  [AOS]  : Endif
If clalev([F:AUS1])=0 : Local File AUTILIS  [AUS1] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA  [AXX] : Endif
# Contrôle performance mémos sélection sur table de grosse importance
If PARAM(3)="1" & clalev([M:ASL])>0
 Call VERIF_MEMO("[ASL]",OK)
 If !OK : FIN = 1 : Return : Endif
Endif
Return

#-----------------------------------------------------------#
$TIT
Case PARAM(3)
 When "1" : TIT = mess(110,126,1) : # Enregistrement mémo
 When "2" : TIT = mess(111,126,1) : # Rappel mémo
 When "3" : TIT = mess(112,126,1) : # Effacement mémo
Endcase
Return

#-----------------------------------------------------------#
$DEBUT
Local Integer I , J , K , DIME , NBVAR , ERR , STAT , ERR2
Local Char    MEMO(30) , VARIA(GLONAVA) , ABRMASK(GLONABR+4)(0..15) , EXT(30) , CHAINE(250)
Local Char    FICMEM(250) , SAVIFS(5) , SAVIRS(5)
Local Integer SAVIUM
ERR = 0
Onerrgo ERREUR
K = evalue("dim("+PARAM(1)+")") : # abréviations des écrans sous la forme [M:xxx]
Onerrgo
If ERR or instr(1,PARAM(1),",")>0
 CHAINE = PARAM(1)
 K = instr(1,CHAINE,",")
 I = 0
 While K<>0
  ABRMASK(I) = left$(CHAINE,K-1)
  If instr(1,ABRMASK(I),"[M")<=0
   ABRMASK(I) = "[M:"+ABRMASK(I)+"]"
  Endif
  CHAINE = right$(CHAINE,K+1)
  K = instr(1,CHAINE,",")
  I += 1
 Wend
 ABRMASK(I) = CHAINE
 If instr(1,ABRMASK(I),"[M")<=0
  ABRMASK(I) = "[M:"+ABRMASK(I)+"]"
 Endif
Else
 For I=0 To K-1
  ERR = 0
  Onerrgo ERREUR
  CHAINE = evalue(PARAM(1)+"("+num$(I)+")")
  Onerrgo
  If !ERR & CHAINE<>""
   ABRMASK(I) = CHAINE
  Endif
 Next I
Endif
EXT  = PARAM(2)
MEMO = [M:MEM]CODE

K = instr(0,EXT,"~")
If !K
 [M:MEM]TYP = EXT
 [M:MEM]OBJECT = ""
Else
 [M:MEM]TYP = right$(EXT,K+1)
 [M:MEM]OBJECT = left$(EXT,K-1)
Endif

# Initialisation
If dim([M:MEM]MODE)>=0  : [M:MEM]MODE = val(PARAM(3)) : Endif
If dim([M:MEM]GLOB)>=0  : [M:MEM]GLOB = 1             : Endif
If dim([M:MEM]DESAX)>=0 : [M:MEM]DESAX  = ""          : Endif

# Affiche mémo dans la fenetre GMEMO pour les programmes qui passe par la boite de critères
For I=0 To dim(ABRMASK)-1
 If ABRMASK(I)<>""
  If evalue("dim("+ABRMASK(I)+"MEMO)")>0
   [M:MEM]CODE = evalue(ABRMASK(I)+"MEMO")
  Else
   [M:MEM]CODE = ""
  Endif
 Endif
Next I

# Affiche mémo "STD" ou le dernier créé dans la fenetre GMEMO pour les SELECTION
If dim([M:MEM]GLOB)>=0
 Read [F:AOS]AOS0 = [M:MEM]OBJECT;"STD";1;GUSER
 If !fstat
  [M:MEM]CODE = [F:AOS]MEMO
  Call LECTEXTRA([M:MEM]DESAX,"AOBJSEL","DES",[F:AOS]CODE+"~"+[F:AOS]MEMO,num$([F:AOS]ALL)+"~"+[F:AOS]USR)
& From ATEXTRA
 Else
  Filter [AOS] Where [F:AOS]CODE = [M:MEM]OBJECT
&                  & [F:AOS]ALL  = 1
&                  & [F:AOS]USR  = GUSER
  Read [F:AOS]AOS1 Last
  If !fstat
   [M:MEM]CODE = [F:AOS]MEMO
   Call LECTEXTRA([M:MEM]DESAX,"AOBJSEL","DES",[F:AOS]CODE+"~"+[F:AOS]MEMO,num$([F:AOS]ALL)+"~"+[F:AOS]USR)
&  From ATEXTRA
  Endif
  Filter [AOS]
 Endif
 Affzo [M:MEM]DESAX
Endif
If dim([M:MEM]USR2) > 0
 [M:MEM]USR2 = [F:AOS]USR
Endif
Affzo [M:MEM]CODE
Return

#-------------------------#
$ERREUR
ERR = errn
Resume

#-------------------------#
$ERREUR2
ERR2 = errn
Resume

#-----------------------------------------------------------#
$OK
If [M:MEM]CODE<>""
 Case PARAM(3)
  When "1" : If GSTATUT<>GSTAEND : Gosub MEMO : Endif
  When "2" : If GSTATUT<>GSTAEND : Gosub RAPPEL : Endif
  When "3" : Gosub EFFACE
 Endcase
Endif
FIN = 1
Return

#-------------------------#
$MEMO

SAVIFS  = adxifs
SAVIRS  = adxirs
SAVIUM  = adxium

## Détermine le nom complet du fichier mémo

## différenciation des mémos "objet" & "global"
If dim([M:MEM]GLOB)>=0
 If [M:MEM]GLOB=2
  FICMEM = filpath("ETM",GSUPER+"_"+[M:MEM]OBJECT+"_"+[M:MEM]CODE,"glo",0)
  Call MAJAOBJSEL(2)
 Else
  FICMEM = filpath("ETM",GUSER+"_"+[M:MEM]OBJECT+"_"+[M:MEM]CODE,[M:MEM]TYP,0)
  Call MAJAOBJSEL(1)
 Endif
Elsif [M:MEM]OBJECT = ""
 FICMEM = filpath("ETM",GUSER+"_"+[M:MEM]CODE,[M:MEM]TYP,0)
Else
 FICMEM = filpath("ETM",GUSER+"_"+[M:MEM]OBJECT+"_"+[M:MEM]CODE,[M:MEM]TYP,0)
Endif

ER = 0
Onerrgo ERREUR
## Enregistrement du fichier mémo
Openo FICMEM , 0 Using [MEM_]

adxifs = tab$
adxirs = chr$(10)
adxium = GUTF8

For K=0 To dim(ABRMASK)-1
 If ABRMASK(K)<>""
  NBVAR = evalue("clanbs("+ABRMASK(K)+",1)")
  For I=1 To NBVAR
   VARIA = evalue("clavar("+ABRMASK(K)+","+num$(I)+")")
   DIME  = evalue("dim("+ABRMASK(K)+VARIA+")")
   If VARIA = "MEMO"
    Assign ABRMASK(K)+VARIA With [M:MEM]CODE
   Endif
   For J=1 To DIME
    ERR2 = 0
    If DIME=1
     Onerrgo ERREUR2 : GBIDC1 = num$(evalue(ABRMASK(K)+VARIA)) : Onerrgo
     If !ERR2
      Wrseq VARIA , evalue(ABRMASK(K)+VARIA) Using [MEM_]
     Endif
    Else
     Onerrgo ERREUR2 : GBIDC1 = num$(evalue(ABRMASK(K)+VARIA+"("+num$(J-1)+")")) : Onerrgo
     If !ERR2
      Wrseq VARIA+"("+num$(J-1)+")" , evalue(ABRMASK(K)+VARIA+"("+num$(J-1)+")") Using [MEM_]
     Endif
    Endif
   Next J
  Next I
 Endif
Next K

If clalev([M:R1])>0
 For I=0 To [M:R1]NBLIG-1
  Wrseq "R1/"+num$(I)+"/"+[M:R1]ZONE(I)+"/"+num$([M:R1]OPER(I)),[M:R1]VALRECH(I) Using [MEM_]
 Next I
Endif
If clalev([M:R2])>0
 For I=0 To [M:R2]NBLIG-1
  Wrseq "R2/"+num$(I)+"/"+[M:R2]ZONE(I)+"/"+num$([M:R2]OPER(I)),[M:R2]VALRECH(I) Using [MEM_]
 Next I
Endif

Openo Using [MEM_]

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

Onerrgo

If ER
 Call ERREUR(mess(13,100,1)+"\|"+FICMEM) From GESECRAN : # Erreur d'écriture sur le fichier
Else
 Call MESSAGE(mess(1,139,1)) From GESECRAN : # Paramètres enregistrés
Endif
Return

#-------------------------#
$RAPPEL
If dim([M:MEM]GLOB)>=0 & [M:MEM]GLOB=2
 Call LECMEMOPT([M:MEM]CODE,PARAM(1),PARAM(2))
Else
 Call LECMEMO([M:MEM]CODE,PARAM(1),PARAM(2))
Endif
Return

#-------------------------#
$EFFACE
If dim([M:MEM]GLOB)>=0
 If [M:MEM]GLOB=2
  FICMEM = filpath("ETM",GSUPER+"_"+[M:MEM]OBJECT+"_"+[M:MEM]CODE,"glo",0)
  Call EFFAOBJSEL(2)
 Else
  FICMEM = filpath("ETM",GUSER+"_"+[M:MEM]OBJECT+"_"+[M:MEM]CODE,[M:MEM]TYP,0)
  Call EFFAOBJSEL(1)
 Endif
Elsif [M:MEM]OBJECT=""
 FICMEM = filpath("ETM",GUSER+"_"+[M:MEM]CODE,[M:MEM]TYP,0)
Else
 FICMEM = filpath("ETM",GUSER+"_"+[M:MEM]OBJECT+"_"+[M:MEM]CODE,[M:MEM]TYP,0)
Endif

If filinfo(FICMEM,0)>=0
 Call EFFACE(FICMEM,STAT) From ORDSYS
 For I=0 To dim(ABRMASK)-1
  If ABRMASK(I)<>""
   If evalue("dim("+ABRMASK(I)+"MEMO)")>0
    If evalue(ABRMASK(I)+"MEMO")=[M:MEM]CODE
     Assign ABRMASK(I)+"MEMO" With ""
    Endif
   Endif
  Endif
 Next I
 Call MESSAGE(mess(2,139,1)) From GESECRAN : # Mémo effacé
Endif
Return

#-----------------------------------------------------------#
$FINSAI
If PARAM(3)="2" & GSTATUT=GSTAOK
 NBAFF = 2 : # Pour raffraîchir la fenêtre du dessous
Endif
Return

#-----------------------------------------------------------#
$SEL_TABLE
Local Char    WMEMOS(GLONAMM)(1..GNBSEL)
Local Char    WDES(GLONDES)(1..GNBSEL)
Local Integer NBTEX
Local File   (Char MEMOS(GLONAMM) , Char DES(GLONDES))
&             From Variable WMEMOS , WDES  As [FIC]
Default File [FIC]
ORDRE = "MEMOS"
NBCOL  = 1 : COL(NBCOL) = "[F:FIC]MEMOS" : COLTYP(NBCOL) = type([F:FIC]MEMOS)  : TIT(NBCOL) = mess(191,125,1) : # Codes mémos
NBCOL += 1 : COL(NBCOL) = "[F:FIC]DES"  : COLTYP(NBCOL)  = type([F:FIC]DES)    : TIT(NBCOL) = mess(30,109,1) : # Intitulé
FILTRE = '1=1  '
START = "MEMOS"
CRITERE ='MEMOS <> ""  '
TIT = mess(109,126,1) : # Selection fichier memos
Gosub LISTE_MEMO
For I=1 To GNBSEL-1
 If TEXTE(I) <> ""
  WMEMOS(I) = vireblc(left$(TEXTE(I),instr(1,TEXTE(I),"~")-1),2)
  WDES(I) = vireblc(right$(TEXTE(I),instr(1,TEXTE(I),"~")+1),2)
 Else
  WMEMOS(I) = ""
 Endif
Next I
#X3-39092
If sum(WDES)=""
 NBCOL -= 1
Endif
ORDRE = ""
adxmxl = I
Return

$LISTE_MEMO
Local Integer TAIL
Local Char ORDRE(250),DESAX2(30)
# Code utilisateur + Code objet + code mémo (15) + extension (10) + séparateurs
TAIL = GLONAUS+GLONAOB+GLONAMM+20
Local Char    TEX(TAIL)(0..GNBSEL) , TEXTE(TAIL)(0..GNBSEL)
If dim([M:MEM]GLOB)>0
 If [M:MEM]GLOB=2
  ORDRE = 'lsadx -a'-nomap(0)-'ETM "'+GSUPER+"_"+[M:MEM]OBJECT+"_"+'*.'+"glo"+'"'
  Call SYSTEME2(adxmac(0),ORDRE,"",NBTEX,TEX) From ORDSYS
  NBTEX = min(NBTEX,dim(TEX)-1)
  For I=NBTEX To 1 Step-1
   TEX(I) = TEX(I-1)
   If TEX(I)<>""
    TEX(I) = right$(TEX(I),len(GSUPER)+len([M:MEM]OBJECT)+3)
    TEX(I) = left$(TEX(I),len(TEX(I))-1-len([M:MEM]TYP))
    Read [F:AOS]AOS0 = [M:MEM]OBJECT;TEX(I);2;GSUPER
    If !fstat
     Call LECTEXTRA([L]DESAX2,"AOBJSEL","DES",[M:MEM]OBJECT+"~"+TEX(I),"2"+"~"+GSUPER) From ATEXTRA
     TEXTE(I) = TEX(I)+"~"+[L]DESAX2
    Endif
   Endif
  Next I
 Else
  ORDRE = 'lsadx -a'-nomap(0)-'ETM "'+GUSER+"_"+[M:MEM]OBJECT+"_"+'*.'+[M:MEM]TYP+'"'
  Call SYSTEME2(adxmac(0),ORDRE,"",NBTEX,TEX) From ORDSYS
  NBTEX = min(NBTEX,dim(TEX)-1)
  For I=NBTEX To 1 Step-1
   TEX(I) = TEX(I-1)
   If TEX(I)<>""
    TEX(I) = right$(TEX(I),len(GUSER)+len([M:MEM]OBJECT)+3)
    TEX(I) = left$(TEX(I),len(TEX(I))-1-len([M:MEM]TYP))
    Read [F:AOS]AOS0 = [M:MEM]OBJECT;TEX(I);1;GUSER
    If !fstat
     Call LECTEXTRA([L]DESAX2,"AOBJSEL","DES",[M:MEM]OBJECT+"~"+TEX(I),"1"+"~"+GUSER) From ATEXTRA
     TEXTE(I) = TEX(I)+"~"+[L]DESAX2
    Endif
   Endif
  Next I
 Endif
Elsif dim([M:MEM]OBJECT)>0
 If [M:MEM]OBJECT=""
  ORDRE = 'lsadx -a'-nomap(0)-'ETM "'+GUSER+"_"+'*.'+[M:MEM]TYP+'"'
  Call SYSTEME2(adxmac(0),ORDRE,"",NBTEX,TEX) From ORDSYS
  NBTEX = min(NBTEX,dim(TEX)-1)
  For I=NBTEX To 1 Step-1
   TEX(I) = TEX(I-1)
   If TEX(I)<>""
    TEX(I) = right$(TEX(I),len(GUSER)+2)
    TEX(I) = left$(TEX(I),len(TEX(I))-1-len([M:MEM]TYP))
    TEXTE(I) = TEX(I)+"~"+""
   Endif
  Next I
 Else
  ORDRE = 'lsadx -a'-nomap(0)-'ETM "'+GUSER+"_"+[M:MEM]OBJECT+"_"+'*.'+[M:MEM]TYP+'"'
  Call SYSTEME2(adxmac(0),ORDRE,"",NBTEX,TEX) From ORDSYS
  NBTEX = min(NBTEX,dim(TEX)-1)
  For I=NBTEX To 1 Step-1
   TEX(I) = TEX(I-1)
   If TEX(I)<>""
    TEX(I) = right$(TEX(I),len(GUSER)+len([M:MEM]OBJECT)+3)
    TEX(I) = left$(TEX(I),len(TEX(I))-1-len([M:MEM]TYP))
    Read [F:AOS]AOS0 = [M:MEM]OBJECT;TEX(I);1;GUSER
    If !fstat
     Call LECTEXTRA([L]DESAX2,"AOBJSEL","DES",[M:MEM]OBJECT+"~"+TEX(I),"1"+"~"+GUSER) From ATEXTRA
     TEXTE(I) = TEX(I)+"~"+[L]DESAX2
    Else
     TEXTE(I) = TEX(I)+"~"+TEX(I)
    Endif
   Endif
  Next I
 Endif
Endif
If NBTEX=0 : mkstat = 2 : Endif
TIT = mess(109,126,1) : # Sélection fichier mémo
Return

#-------------------------------------------------------#
Subprog LECMEMORET(MEMO,ECRAN,EXT,OPT,STAT)
Value Char    MEMO()
Value Char    ECRAN()
Value Char    EXT()
Value Integer OPT
Variable Integer STAT
Goto LECMEMO1

#-------------------------------------------------------#
Subprog LECMEMOPT(MEMO,ECRAN,EXT)
Value Char    MEMO()
Value Char    ECRAN()
Value Char    EXT()
Local Integer OPT , STAT
OPT = 0 : # La gestion des mémos se fera avec GSUPER
Goto LECMEMO1

#-------------------------------------------------------#
Subprog LECMEMO(MEMO,ECRAN,EXT)
Value Char    MEMO()
Value Char    ECRAN()
Value Char    EXT()
Local Integer OPT , STAT
OPT = 1 : # La gestion des mémos se fera avec GUSER

#----------------------#
$LECMEMO1
Local Integer I , J , K , L , NBVAR , IND , OPER , ERR
Local Char    FICMEM(250) , ZONE(20) , ABRMASK(GLONABR+4)(0..15)
Local Char    MEMCOD(50) , MEMVAL(250) , MEMVAR(30) , MEMZON(250) , CHAINE(250)
Local Char    SAVIFS(5) , SAVIRS(5)
Local Char    TYP , OBJ
Local Integer SAVIUM

SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium

# Ce sous-programme est appelé par GCONSULT et GOBJET

ERR = 0

Onerrgo ERREUR
K = evalue("dim("+[L]ECRAN+")") : # abréviations des écrans sous la forme [M:xxx]
Onerrgo
If ERR or instr(1,[L]ECRAN,",")>0
 CHAINE = [L]ECRAN
 K = instr(1,CHAINE,",")
 I = 0
 While K<>0
  ABRMASK(I) = left$(CHAINE,K-1)
  If instr(1,ABRMASK(I),"[M")<=0
   ABRMASK(I) = "[M:"+ABRMASK(I)+"]"
  Endif
  CHAINE = right$(CHAINE,K+1)
  K = instr(1,CHAINE,",")
  I += 1
 Wend
 ABRMASK(I) = CHAINE
 If instr(1,ABRMASK(I),"[M")<=0
  ABRMASK(I) = "[M:"+ABRMASK(I)+"]"
 Endif
Else
 For I=0 To K-1
  ERR = 0
  Onerrgo ERREUR
  CHAINE = evalue([L]ECRAN+"("+num$(I)+")")
  Onerrgo
  If !ERR & CHAINE<>""
   ABRMASK(I) = CHAINE
  Endif
 Next I
Endif

K = instr(0,[L]EXT,"~")
If !K
 [L]TYP = [L]EXT
 [L]OBJ = ""
Else
 [L]TYP = right$([L]EXT,K+1)
 [L]OBJ = left$([L]EXT,K-1)
Endif

## Recherche du nom complet du fichier mémo
If [L]OBJ=""
 FICMEM = filpath("ETM",GUSER+"_"+[L]MEMO,[L]TYP,0)
Elsif OPT=0
 FICMEM = filpath("ETM",GSUPER+"_"+[L]OBJ+"_"+[L]MEMO,"glo",0)
Else
 FICMEM = filpath("ETM",GUSER+"_"+[L]OBJ+"_"+[L]MEMO,[L]TYP,0)
Endif

If filinfo(FICMEM,0)<=0 : STAT = 1 : End : Endif

Openi FICMEM Using [MEM_]

adxifs = tab$
adxirs = chr$(10)
adxium = GUTF8

Rdseq MEMCOD , MEMVAL Using [MEM_]
While fstat=0
 If clalev([M:R1]) > 0 & left$(MEMCOD,2) = "R1"
  Gosub DECODE
  [M:R1]ZONE(IND)    = ZONE
  [M:R1]OPER(IND)    = OPER
  [M:R1]VALRECH(IND) = MEMVAL
  [M:R1]NBLIG = max([M:R1]NBLIG,IND+1)
 Elsif clalev([M:R2])>0 & left$(MEMCOD,2) = "R2"
  Gosub DECODE
  [M:R2]ZONE(IND)    = ZONE
  [M:R2]OPER(IND)    = OPER
  [M:R2]VALRECH(IND) = MEMVAL
  [M:R2]NBLIG = max([M:R2]NBLIG,IND+1)
 Endif
 I = instr(1,MEMCOD,"(")
 If I
  MEMVAR = left$(MEMCOD,I-1)
 Else
  MEMVAR = MEMCOD
 Endif
 For L=0 To dim(ABRMASK)-1
  If ABRMASK(L)<>""
   ERR = 0
   Onerrgo ERREUR
   NBVAR = evalue("clanbs("+ABRMASK(L)+",1)")
   Onerrgo
   If !ERR
    For I=1 To NBVAR
     ERR = 0
     Onerrgo ERREUR
     MEMZON = evalue("clavar("+ABRMASK(L)+","+num$(I)+")")
     Onerrgo
     If !ERR & MEMVAR=MEMZON
      Onerrgo ERREUR
      Case evalue("type("+ABRMASK(L)+MEMVAR+")")
       When 1,2,4,5,6,7,8,9 : Assign ABRMASK(L)+MEMCOD With val(MEMVAL)
       When 3               : Assign ABRMASK(L)+MEMCOD With gdat$(MEMVAL)
       When Default         : Assign ABRMASK(L)+MEMCOD With MEMVAL
      Endcase
      Onerrgo
      Break
     Endif
    Next I
   Endif
  Endif
 Next L
 Rdseq MEMCOD , MEMVAL Using [MEM_]
Wend
Openi Using [MEM_]

For L=0 To dim(ABRMASK)-1
 If ABRMASK(L)<>""
  If evalue("dim("+ABRMASK(L)+"MEMO)")>0
   Assign ABRMASK(L)+"MEMO" With [L]MEMO
  Endif
  If ABRMASK(L)="[M:DIA]" & dim([M:DIA]INI)>0
   Raz [M:DIA]INI : # Pour les trt de compta
  Endif
 Endif
Next L
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
End

#--------------------------------#
$DECODE
I = instr(1,MEMCOD,"/")
J = instr(I+1,MEMCOD,"/")
K = instr(J+1,MEMCOD,"/")
IND  = val(seg$(MEMCOD,I+1,J-1))
ZONE = seg$(MEMCOD,J+1,K-1)
OPER = val(right$(MEMCOD,K+1))
Return

#-------------------------------------------------------#
Subprog MAJAOBJSEL(ALL)
Value Integer ALL
Local Char USR
Local Integer SAVNUMORD

If [L]ALL = 2
 [L]USR = GSUPER
Else
 [L]USR = GUSER
Endif

Trbegin [AOS]

 # Calcul du numéro d'ordre (cpteur automatique par objet)
 Filter [AOS] Where [F:AOS]CODE = [M:MEM]OBJECT & [F:AOS]ALL  = [L]ALL
 Read [F:AOS]AOS1 Last
 If !fstat
  SAVNUMORD = [F:AOS]NUMORD+1
 Else
  SAVNUMORD = 1
 Endif
 Filter [AOS]

 # Affectation & ecriture

 Read [F:AOS]AOS0 = [M:MEM]OBJECT;[M:MEM]CODE;[L]ALL;[L]USR
 If fstat = 0
  Raz [AOS]
  [F:AOS]CODE   = [M:MEM]OBJECT
  [F:AOS]MEMO   = [M:MEM]CODE
  Call MAJTEXTRA([M:MEM]DESAX,"AOBJSEL","DES",[M:MEM]OBJECT+"~"+[M:MEM]CODE,num$([L]ALL)+"~"+[L]USR)
& From ATEXTRA
  [F:AOS]NUMORD = SAVNUMORD
  [F:AOS]ALL    = [L]ALL
  [F:AOS]USR    = [L]USR
  Rewrite [AOS]
  If fstat = 1
   GOK = -1 : Call RSTA("AOS","") From GLOCK
  Elsif fstat
   GOK = 0  : Call FSTA("AOS") From GLOCK
  Endif
 Else
  Raz [AOS]
  [F:AOS]CODE   = [M:MEM]OBJECT
  [F:AOS]MEMO   = [M:MEM]CODE
  Call MAJTEXTRA([M:MEM]DESAX,"AOBJSEL","DES",[M:MEM]OBJECT+"~"+[M:MEM]CODE,num$([L]ALL)+"~"+[L]USR)
& From ATEXTRA
  [F:AOS]NUMORD = SAVNUMORD
  [F:AOS]ALL    = [L]ALL
  [F:AOS]USR    = [L]USR
  Write [AOS]
  If fstat
   GOK = 0  : Call FSTA("AOS") From GLOCK
  Endif
 Endif

Commit
End

#-------------------------------------------------------#
Subprog EFFAOBJSEL(ALL)
Value Integer ALL
Local Char USR

If [L]ALL = 2
 [L]USR = GSUPER
Else
 [L]USR = GUSER
Endif

Trbegin [AOS],[AXX]
 Delete [F:AOS] Where [F:AOS]CODE = [M:MEM]OBJECT
&                   & [F:AOS]MEMO = [M:MEM]CODE
&                   & [F:AOS]ALL  = [L]ALL
&                   & [F:AOS]USR  = [L]USR
 If fstat = 1
  GOK = -1 : Call RSTA("AOS","") From GLOCK
 Elsif fstat
  GOK = 0  : Call FSTA("AOS") From GLOCK
 Endif

 Delete [AXX] Where CODFIC="AOBJSEL" & ZONE="DES"
&                 & IDENT1=[M:MEM]OBJECT+"~"+[M:MEM]CODE & IDENT2=num$([L]ALL)+"~"+[L]USR
 If fstat=1 | fstat>5
  GOK=0 : Call RSTA("AXX",[M:MEM]OBJECT+"~"+[M:MEM]CODE) From GLOCK
 Endif

Commit
End

#-----------------------------------------------------------------------------------------------#
# Contrôle des mémos
# Fonctionne à partir du mémo courant supposé être en ligne
# Ecrit par Dominique BOPP
# On renvoie ici OK=1 si OK (AUZMEMO autorise l'utilisateur à créer un mémo non performant)
# (C) ADONIX 2002
#------------------------------------------------------------------------------------------------#

Subprog VERIF_MEMO(MSKMEM,OK)
Value    Char    MSKMEM
Variable Integer OK
Local    Char    FIC_COUR(20), OBJ_COUR(5), MESSAGE(250), MESSENT(250)
Local    Integer I, NBCOND, TROUVE, NBRENR
Local    Char    FIC_SEL(20)(1..5),CHAMP_SEL(20)(1..5)
Local    Char    SELWARN(20) , AUZMEMO(10)

OK=1
# Contrôle uniquement en gestion d'objet
If GOBJET=0 : End : Endif

# Pour gérer le message Trop de tables ouvertes
Onerrgo TROFICOUV
If clalev ([F:ATB])=0 : Local File ATABLE : Endif
If clalev ([F:ATI])=0 : Local File ATABIND : Endif
If clalev ([F:AOB])=0 : Local File AOBJET : Endif
If clalev ([F:ANX])=0 : Local File AINDEX : Endif
Onerrgo

Default Mask MSKMEM

# Recherche table courante
OBJ_COUR = [M]OBJ
Read [AOB]ABREV=OBJ_COUR
If fstat
    End : # On traite les erreurs par le mépris
Endif
FIC_COUR=[AOB]NOMFIC
Read [ATB]CODFIC=FIC_COUR
If fstat
    End : # On traite les erreurs par le mépris
Endif

# Est-on au dessus du seuil d'alerte ?
Call PARAM("","SELWARN",SELWARN) From ADOVAL
If val(SELWARN)=0 : SELWARN = "100000" : Endif : # mb 26.9.2 vu avec DOM
NBRENR = evalue("nbrecord(["+[ATB]ABRFIC+"])")
If NBRENR<val(SELWARN)
    End
Endif

# Alerte : Pb de performance de la table XXXXXX  (NNNNN lignes)
MESSENT = mess(142,115,1)-FIC_COUR-"("+num$(NBRENR)-mess(7,105,1)+")"

# Y a-t-il une expression ? Si oui, on alerte
If [M]EXP1<>""
    # sélection sur expression
    MESSAGE = MESSENT-"\"-mess(128,115,1)
    Goto ERR_VERIF
Endif

# Y a-t-il un opérateur "comme" ou "différent" ? Si oui, on alerte
If find(3,[M]OPE1,[M]OPE2,[M]OPE3,[M]OPE4,[M]OPE5)
    # Utilisation de l'opérateur comme
    MESSAGE = MESSENT-"\"-mess(143,115,1)-mess(3,55,1)
    Goto ERR_VERIF
Endif
If  find(8,[M]OPE1,[M]OPE2,[M]OPE3,[M]OPE4,[M]OPE5)
    # Utilisation de l'opérateur comme
    MESSAGE = MESSENT-"\"-mess(143,115,1)-mess(8,55,1)
    Goto ERR_VERIF
Endif

# Y a-t-il plusieurs tables dans la sélection ? Si oui, on alerte...
FIC_SEL(1)=[M]TBL1
FIC_SEL(2)=[M]TBL2+string$([M]TBL2="",[M]TBL1)
FIC_SEL(3)=[M]TBL3+string$([M]TBL3="",[M]TBL1)
FIC_SEL(4)=[M]TBL4+string$([M]TBL4="",[M]TBL1)
FIC_SEL(5)=[M]TBL5+string$([M]TBL5="",[M]TBL1)
If min(FIC_SEL,FIC_COUR)<>max(FIC_SEL,FIC_COUR)
    # sélection sur jointure
    MESSAGE = MESSENT-"\"-mess(144,115,1)
    Goto ERR_VERIF
Endif

# Y a-t-il des 'ou' la sélection ? Si oui, on alerte...
If [M]FLD2<>"" & ([M]ANDOR2=2 or
&  [M]FLD3<>"" & ([M]ANDOR3=2 or
&  [M]FLD4<>"" & ([M]ANDOR4=2 or
&  [M]FLD5<>"" & ([M]ANDOR5=2
&  ))))
    # sélection avec des 'ou'
    MESSAGE = MESSENT-"\"-mess(145,115,1)
    Goto ERR_VERIF
Endif

# Recherche de pertinence de clés
# On regarde si au moins une des clés de la table commence par un des champs de la sélection
# On se fiche de la clé utilisée dans la liste gauche, puisqu'en principe oracle fait bien le boulot
# (on est maintenant en Nohint)

TROUVE = 0
For [ATI] Where CODFIC=FIC_COUR
    If find(vireblc(ctrans([ATI]DESCRIPT,"+-","  "),3),
&           [M]FLD1,[M]FLD2,[M]FLD3,[M]FLD4,[M]FLD5)
        TROUVE=1
        Break
    Endif
Next
If !TROUVE
  For [ANX]ANX1 Where TABLE=FIC_COUR & FLACT=2
    If find(vireblc(ctrans([ANX]DESCRIPT,"+-","  "),3),
&           [M]FLD1,[M]FLD2,[M]FLD3,[M]FLD4,[M]FLD5)
        TROUVE=1
        Break
    Endif
  Next
Endif

If !TROUVE
    # pas de clé utilisable pour la sélection sur champ
    MESSAGE = MESSENT-"\"-mess(146,115,1)
    Goto ERR_VERIF
Endif
End

$ERR_VERIF
If GPROFIL=GSUPER
 Call MESSAGE(MESSAGE) From GESECRAN
Else
 Call PARAMUTIL("AUZMEMO",AUZMEMO,"","") From SUBAUS
 If AUZMEMO="2"
  Call MESSAGE(MESSAGE) From GESECRAN
 Else
  Call ERREUR(MESSAGE) From GESECRAN
  OK = 0
 Endif
Endif
End

$TROFICOUV
End

#-------------------------------------------------------#
#  Etiquettes du masque MEMO2
#-------------------------------------------------------#

Subprog AS_TIT(VALEUR)
Variable Char    VALEUR()
# Intitulé saisissable uniquement dans le cas d'un enregistrement de mémos (mode=1)
# et si un code mémo a été saisi (code<>"")
If find([M:MEM]MODE,2,3)
 mkstat = 2 : End
Endif
If [M:MEM]CODE=""
 mkstat = 1 : End
Endif
End

Subprog C_CODE(VALEUR)
Variable Char    VALEUR()
Local    Integer OK
If VALEUR = "" : End : Endif
If find([M:MEM]MODE,2,3) : # Rappel, Effacement
 OK = 1
 If dim([M:MEM]GLOB)>0
  If [M:MEM]GLOB=2
   Read [F:AOS]AOS0 = [M:MEM]OBJECT;VALEUR;2;GSUPER
   If fstat & filinfo(filpath("ETM",GSUPER+"_"+[M:MEM]OBJECT+"_"+VALEUR,"glo",0),0)<0
    OK = 0
   Endif
  Else
   Read [F:AOS]AOS0 = [M:MEM]OBJECT;VALEUR;1;GUSER
   If fstat & filinfo(filpath("ETM",GUSER+"_"+[M:MEM]OBJECT+"_"+VALEUR,[M:MEM]TYP,0),0)<0
    OK = 0
   Endif
  Endif
 Elsif [M:MEM]OBJECT=""
  If filinfo(filpath("ETM",GUSER+"_"+VALEUR,[M:MEM]TYP,0),0)<0
   OK = 0
  Endif
 Else
  Read [F:AOS]AOS0 = [M:MEM]OBJECT;VALEUR;1;GUSER
  If fstat & filinfo(filpath("ETM",GUSER+"_"+[M:MEM]OBJECT+"_"+VALEUR,[M:MEM]TYP,0),0)<0
   OK = 0
  Endif
 Endif
 If !OK
  GMESSAGE = mess(113,126,1) : # Fichier mémo inexistant
  mkstat = 1 : End
 Endif
Endif
End

Subprog AM_CODE(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 [M:MEM]DESAX = "" : End
Endif
[M:MEM]DESAX = ""
Case [M:MEM]GLOB
 When 2
  Read [F:AOS]AOS0 = [M:MEM]OBJECT;VALEUR;2;GSUPER
  Call LECTEXTRA([M:MEM]DESAX,"AOBJSEL","DES",[M:MEM]OBJECT+"~"+VALEUR,"2"+"~"+GSUPER) From ATEXTRA
 When Default
  Read [F:AOS]AOS0 = [M:MEM]OBJECT;VALEUR;1;GUSER
  Call LECTEXTRA([M:MEM]DESAX,"AOBJSEL","DES",[M:MEM]OBJECT+"~"+VALEUR,"1"+"~"+GUSER) From ATEXTRA
Endcase
End

Subprog AV_GLOB(VALEUR)
Variable Integer VALEUR
Local Char SELGLO(10)
If find([M:MEM]MODE,1,3)
 Call PARAMUTIL("SELGLO",SELGLO,"","") From SUBAUS
 If SELGLO<>"2"
  Grizo GLOB
 Else
  Actzo GLOB
 Endif
Endif
End

Subprog AM_GLOB(VALEUR)
Variable Integer VALEUR
If VALEUR= 2
 [M:MEM]USR2 = GSUPER
Else
 [M:MEM]USR2 = GUSER
Endif
End

