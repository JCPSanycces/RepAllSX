#######################################################################################
$SEL_TABLE
  #---------------------#
  # Sélection sur champ #
  #---------------------#
  Case COUZON
    When "COD"   : # Pièce auto Achat
      OBJET = "GAU"
      CRITERE = "TBL='PINVOICEV'"
    When "COD2"  : # Pièce auto Tiers
      OBJET = "GAU"
      CRITERE = "TBL='PINVOICE'"
  Endcase
Return

######################################################################################
$FERME
  # FGR 11/12/2012 : X3SUIVI71937 (début)
  If dim(SAV_GCURLEG) > 0 Then
    GCURLEG = SAV_GCURLEG
  Endif
  # FGR 11/12/2012 : X3SUIVI71937 (fin)
  #------------------------------------#
  # Restitution des variables globales #
  #------------------------------------#
  Raz GBIDI1
  Gosub REST_GLOB From TRTX3GLOB
  # ----------------------------
  If GFONC1 = "GESTPV" Then
    Raz GFONC1
  Endif
  # To manage the button Tunnel
  If TUNNEL<>1 : Return : Endif
  If dim(VCOD)<1 : Global Char VCOD(GLONTPV) : Endif
  VCOD = CLE2
Return

######################################################################################
#---------------------------------------------------------------------
$INICRE
  #--- Creation / Modif de ATEXTRA
  #--CPO 71937 Prise en compte de LEG, ajout de [M:TPV1]LEG
  Call MAJTEXTRA ([M:TPV1]DESAXX,"TABPIVTYP","DESAXX",[M:TPV1]PIVTYP,[M:TPV1]LEG) From ATEXTRA
  Call MAJTEXTRA ([M:TPV1]SHOAXX,"TABPIVTYP","SHOAXX",[M:TPV1]PIVTYP,[M:TPV1]LEG) From ATEXTRA
  # SOS libellés
  If dim([F:TPV]LANDESSHO) > 0 Then
    [F:TPV]LANDESSHO = GLANGUE + "~" + [M:TPV1]DESAXX + "~" + [M:TPV1]SHOAXX
  Endif

  #--CPO 71937 Contrôle global de cohérence avant enregistrement
  Gosub CONTROLE_COHERENCE

Return

######################################################################################
#---------------------------------------------------------------------
$ANNULE
  #--CPO 71937 Prise en compte de LEG, ajout de [F:TPV]LEG
  Delete [AXX] Where CODFIC="TABPIVTYP" & IDENT1=[F:TPV]PIVTYP & IDENT2=[F:TPV]LEG
Return

######################################################################################
######################################################################################
Subprog AM_INVTYP(VALEUR)
#--------------------------------------------#
# Après modification de la catégorie facture #
# Chargement si nécessaire de catégorie pour #
#          les factures d'achat              #
#--------------------------------------------#
Variable Integer VALEUR

  If VALEUR=2 | VALEUR=4
    If [M:TPV1]PIHTYP<3 [M:TPV1]PIHTYP=3 : Affzo [TPV1]PIHTYP : Endif
  Else
    If [M:TPV1]PIHTYP>2 [M:TPV1]PIHTYP=1 : Affzo [TPV1]PIHTYP : Endif
  Endif
  If VALEUR=5 : # Test Proforma
    Effzo [TPV1]COD2, JOU, GTE
    If dim([M:TPV1]ZCOD2)>0  Effzo [TPV1]ZCOD2 : Endif
    If dim([M:TPV1]ZGTE)>0   Effzo [TPV1]ZGTE  : Endif
    Grizo [TPV1]COD2, JOU, GTE
  Else
    Actzo [TPV1]COD2, JOU, GTE
  Endif
  If VALEUR>2 : # Test type facture non achat
    Effzo [TPV1]COD : If dim([M:TPV1]ZCOD)>0  Effzo [TPV1]ZCOD : Endif
    Grizo [TPV1]PIHTYP, COD
  Else
    Actzo [TPV1]PIHTYP, COD
  Endif
  Gosub GRIJOU
End

######################################################################################
Subprog AS_PIHTYP(VALEUR)
#--------------------------------------------#
# Avant saisie de la catégorie facture achat #
# Désactivation des options non valides      #
#--------------------------------------------#
Variable Integer VALEUR

  If [M:TPV1]INVTYP=2  | [M:TPV1]INVTYP=4
    GMENLOC(1)=1 : GMENLOC(2)=1
  Else
    GMENLOC(3)=1 : GMENLOC(4)=1
  Endif
End

######################################################################################
Subprog C_COD(VALEUR)
#--------------------------------#
# Contrôle code pièce auto achat #
#--------------------------------#
Variable Char    VALEUR()

  If VALEUR="" : End : Endif
  Call CONTROLE("GAU","A!",VALEUR,"",mkstat) From CONTOBJ
  If mkstat : End : Endif
  If [F:GAU]MODULE<>6 : GMESSAGE=VALEUR-mess(180,194,1) : mkstat=1 : Endif
  If [F:GAU]TBL<>"PINVOICEV"
    GMESSAGE=mess(61,119,1)-"PINVOICEV"   : # La table déclenchante n'est pas PINVOICEV
    mkstat=2
  Endif
End

######################################################################################
Subprog C_COD2(VALEUR)
#--------------------------------#
# Contrôle code pièce auto tiers #
#--------------------------------#
Variable Char    VALEUR()

  If VALEUR<>""
   Read [GAU]GAU0=VALEUR
   If !fstat
    If [F:GAU]TBL<>"PINVOICE"
     GMESSAGE = mess(61,119,1)-"PINVOICE" : # La table déclenchante n'est pas PINVOICE
     mkstat=2 : End
    Endif
   Endif
  Endif
End

