#    GMESSAGE = mess(23,100,1) : # Fiche inexistante
#    mkstat = 2
#    End
#  Else
#    If [F:TPV]LEG <> ''
#      Call CONTROLE("TPV","",[F:TPV]LEG,COD,mkstat) From CONTOBJ
#    Else
#      Call CONTROLE("TPV","","",COD,mkstat) From CONTOBJ
#    Endif
#  Endif
End

######################################################################################
## Tunnel Type de facture
# FGR 13/11/2012 : X3SUIVI71937
Subprog TUNTPV(COD,LEG)
Variable Char    COD()
Value    Char    LEG()

Local Integer TOKILL

  # FGR 11/12/2012 : X3SUIVI71937
  TOKILL = 0
  If dim(VCOD) < 1 Then
    Global Char VCOD(GLONTPV)

    TOKILL = 1
  Endif
  If clalev([F:TPV])=0 : Local File TABPIVTYP [TPV] : Endif
  VCOD = COD
  If GNBLEG = 1 Then
    LEG = GDOSLEG
  Elsif LEG = "" & GCURLEG <> "" Then
    LEG = GCURLEG
  Elsif LEG = "" Then
    #--If LEG="" then firstly we search a TRE record with LEG="" secondly a TRE record with TRE<>""
    Read [TPV]TPV0=VCOD;[L]LEG
    If fstat Then
      Read [TPV]TPV0(1)=VCOD
      If !fstat Then
        LEG = [F:TPV]LEG
      Endif
    Endif
  Endif
  Read [TPV]TPV0=[L]COD;[L]LEG
  If fstat Then
    LEG = ""
  Endif
  Call OBJET("TPV",[L]LEG,VCOD) From GOBJET
  COD = VCOD
  If TOKILL Then
    Kill VCOD
  Endif
End

#Subprog TUNTPV(COD,LEG)
