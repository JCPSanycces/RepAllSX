## To update the TSV code after the tunnel order
#VCOD = COD
#VLEG = LEG
#If clalev([F:TPV])=0 : Local File TABPIVTYP [TPV] : Endif
#If func AFNC.ACTIV("LEG")=0 : VLEG = GDOSLEG : Endif
#
##-- X3suivi 71937 - T249 : Multi-Leg--#
#Read [TPV]TPV0 = VCOD;VLEG : #-- Lecture sans héritage Multi-Leg
#If fstat : VLEG = "" : Endif
#Call OBJET("TPV",VLEG,VCOD) From GOBJET
#COD = VCOD
#Kill VCOD
#End

############################################################
# FGR 11/12/2012 : X3SUIVI71937
$SELTPVLEG
Local Char FCY(GLONFCY)
Local Char CPY(GLONCPY)
Local Char LEG(GLONADI)
Local Char GRP(GLONAGC)
Local Char STYPSEL(250)
Local Integer WNOL
Local Integer ERR
Local Integer I
Local Char SZVIEW(GLONAVW)
Local Char CODMSK(GLONAMK)
Local Char CHAMPCOD(GLONAVA)

  If dim(OPTIONS) < 0 Then
    Local Char OPTIONS(30)
  Endif
  #--------------------------------------------------------------------------------------------------
  If clalev([F:TPV])=0 : Local File TABPIVTYP [TPV] : Endif
  If clalev([F:FCY])=0 : Local File FACILITY  [FCY] : Endif
  If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif
  If clalev([F:FGR])=0 : Local File FACGROUP  [FGR] : Endif
  If clalev([F:AXX])=0 : Local File ATEXTRA   [AXX] : Endif
  If clalev([F:AGF])=0 : Local File AGRPFCY   [AGF] : Endif
  If clalev([F:AMZZ])=0 : Local File AMSKZON   [AMZZ] : Endif :#--CPO 71937 Pour déterminer les options de sélection
  #--------------------------------------------------------------------------------------------------
  #--CPO 98053 Sélection depuis "ADPVAL" et prise en compte des OPTIONS
  #--On charge les options définies sur le type de données du champ du masque
  #  OPTIONS = ""
  #  If CODMSK <> "" and CHAMPCOD <> "" Then
  #    Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
  #    If fstat = 0 Then
  #      OPTIONS = [F:AMZZ]OPTOBJ
  #    Endif
  #  Endif
  #--------------------------------------------------------------------------------------------------

  If left$(GFONCTION,6) = "GESTPV" Then
    # Si on est sur l'objet de paramétrage,
    # Où s'il n'y a qu'une seule législation
    #        => pas de filtre on part sur la sélection standard
    OBJET = "TPV"
    Return
  Endif

  #--------------------------------------------------------------------------------------------------
  # Récupération des paramètres
  #--------------------------------------------------------------------------------------------------
  #--CPO 98053 Sélection depuis "ADPVAL" et prise en compte des OPTIONS
  #--------------------------------------------------------------------------------------------------
  # Récupération des paramètres
  #--------------------------------------------------------------------------------------------------
  If GFONCTION="ADPVAL" : # Saisie valeurs paramètres. Type de données = PST2
    If dim([M:ADWP]LEG)>0
      LEG = [M:ADWP]LEG
    Endif
    FCY      = [M:ADWP]FCY
    CPY      = [M:ADWP]CMP
  Else
  #--/
    LEG      = PARAM(1)
    FCY      = PARAM(2)
    GRP      = PARAM(3)
    CPY      = PARAM(4)
    STYPSEL  = PARAM(5)  # Prévu, mais rien ne semble nécessaire pour le moment.
    CODMSK   = PARAM(6)
    CHAMPCOD = PARAM(7)
    #--CPO 98053 Sélection depuis "ADPVAL" et prise en compte des OPTIONS
    #--On charge les options définies sur le type de données du champ du masque
    OPTIONS = ""
    If CODMSK <> "" and CHAMPCOD <> "" Then
      Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
      If fstat = 0 Then
        OPTIONS = [F:AMZZ]OPTOBJ
      Endif
    Endif
  Endif
  #--------------------------------------------------------------------------------------------------
  # Initialisation de législation
  If func AFNC.ACTIV("LEG")=0
    [L]LEG = GDOSLEG
  Endif
  If [L]LEG = "" Then
    If [L]FCY <> "" Then
      Call LEC_FCY([L]FCY) From CPTLEC
      Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
      [L]LEG = [F:CPY]LEG
    Elsif [L]CPY <> "" Then
      Call LEC_CPY([L]CPY) From CPTLEC
      [L]LEG = [F:CPY]LEG
    Endif
  Endif
  If [L]LEG = "" Then
    [L]LEG = GCURLEG
  Endif
  #--------------------------------------------------------------------------------------------------
  ## Position et taille de la fenêtre
  #--------------------------------------------------------------------------------------------------
  Gosub OUVRE_LISTE From WOTPV
  For I = 1 To NBSEL
    If SELEXP(I) <> "" Then
      COL(I) = SELEXP(I)
    Else
      COL(I) = SELZON(I)
    Endif
    TIT(I) = SELLIB(I)
    If left$(SELFMT(I),2)="LA"
      COL(I) = "mess("+COL(I)+","+num$(val(right$(SELFMT(I),3)))+",1)"
    Endif
  Next I
  NBCOL   = NBSEL
  SIZCOL  = 290
  SIZLIG  = 100
  TIT(0)  = mess(12,123,1)  # Choix
  Call TITOBJ("TPV", "", TIT(1)) From CONTOBJ
  TIT(0) -= TIT(1)
  START   = "[F:TPV]PIVTYP"
  ORDRE   = "[F:TPV]PIVTYP;[F:TPV]LEG"
  OBJET   = ""
  #--------------------------------------------------------------------------------------------------
  ## Critères pour la sélection standard
  #--------------------------------------------------------------------------------------------------
  # --------------------------------------
  ICRITERE = 1
  CRITERE(ICRITERE) = '1=1'
  #--CPO 71937 Ca c'est le bon !
  #--Groupe de soc/sites
  If [L]FCY="" & [L]CPY="" & [L]GRP<>""
  	#--Cas du groupe étant une société
   	Read [F:AGF]AGF0=[L]GRP
   	If !fstat
   		If [F:AGF]FLGLEG=2 : [L]CPY=[L]GRP : Endif
   	Endif
   	#--Le filtrage sur les groupes sites/sociétés est fait dans le link directement
  Endif
  #--/CPO
  # --------------------------------------
  If [L]FCY <> "" Then
    # --Site
    CRITERE(ICRITERE) -= '& ([F:TPV]GFY="" | ([F:TPV]GFY<>"" & [F:FGR]FCY="' + [L]FCY + '"))'
  Elsif [L]CPY <> "" Then
    # --Société
    CRITERE(ICRITERE) -= '& ([F:TPV]GFY="" | ([F:TPV]GFY<>"" & [F:TPVC]LEGCPY="' + [L]CPY + '"))'
  Endif
  # --------------------------------------
  #--CPO 71937 NOK (voir plus haut)
  #  # --Groupe de soc/sites
  #  If [L]FCY = "" & [L]CPY = "" & [L]GRP <> "" Then
  #    CRITERE(ICRITERE) -= '& ([F:TPV]GFY="" | [F:TPV]GFY="' + [L]GRP + '")'
  #  Endif
  # --------------------------------------
  # --Législation
  ICRITERE += 1
  If LEG <> "" Then
    CRITERE(ICRITERE) -= '& ([F:TPV]LEG="' + [L]LEG + '" | [F:TPV]LEG="")'
  Endif
  # --------------------------------------
  If dim(SELCAR) > 0 & SELCAR <> 0 Then
    CRITERE(ICRITERE) -= '& left$([F:TPV]PIVTYP,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
  Endif
  # --------------------------------------
  # Paramètres de sélection (STYPSEL) : Prévu, mais rien ne semble nécessaire pour le moment.
  # ICRITERE += 1
  # CRITERE(ICRITERE) -= '& SOHCAT = ' + mid$(STYPSEL,2,1)
  # --------------------------------------
  ICRITERE += 1

   ##MGG X3-38593 Row level permission
   #Call FILROLE(OBJET, FILROLE) From SUBARL
   Call FILROLE("TPV", FILROLE) From SUBARL
   ##MGG X3-38593 Row level permission

  If FILROLE <> "" & FILROLE <> "1=1" Then
    For I = 0 To dim(FILROLE)-1
      Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", FILROLE(I), "&") From GOBJSUB
    Next I
  Endif
  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  If [L]CPY = "" and [L]FCY = "" and [L]GRP <> "" Then
    If [L]LEG <> "" Then
      ERR = 0
      Repeat
        # -----------------------------------------------------------------------------------------------
        # ERR=0  : Pas d'erreur, on sort
        # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
        # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
        # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
        # -----------------------------------------------------------------------------------------------
        Onerrgo ERRVUE
        SZVIEW = "LEGTPVYGRP"
        Local File =SZVIEW [TPVY]
        Onerrgo
      Until ERR <> -1
      If ERR Then
        # Si problème, on se déroute sur le select standard
        OBJET = "TPV"
        Return
      Endif
    Else
      ERR = 0
      Repeat
        # -----------------------------------------------------------------------------------------------
        # ERR=0  : Pas d'erreur, on sort
        # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
        # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
        # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
        # -----------------------------------------------------------------------------------------------
        Onerrgo ERRVUE
        SZVIEW = "LEGTPVZGRP"
        Local File =SZVIEW [TPVZ]
        Onerrgo
      Until ERR <> -1
      If ERR Then
        # Si problème, on se déroute sur le select standard
        OBJET = "TPV"
        Return
      Endif
    Endif
  Endif
  If 1=1 Then
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTPVCPY"
      Local File =SZVIEW [TPVC]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, on se déroute sur le select standard
      OBJET = "TPV"
      Return
    Endif
    #--------------------------------------------------------------------------------------------------
    ## Appel à la vue
    #--------------------------------------------------------------------------------------------------
    If [L]LEG <> "" Then
      # Vue via GCURLEG
      ERR = 0
      Repeat
        # -----------------------------------------------------------------------------------------------
        # ERR=0  : Pas d'erreur, on sort
        # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
        # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
        # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
        # -----------------------------------------------------------------------------------------------
        Onerrgo ERRVUE
        SZVIEW = "LEGTPVSEL"
        Local File =SZVIEW [TPVS]
        Onerrgo
      Until ERR <> -1
      If ERR Then
        # Si problème, on se déroute sur le select standard
        OBJET = "TPV"
        Return
      Endif
      If [L]CPY = "" and [L]FCY = "" and [L]GRP <> "" Then
        Link [TPV] With [F:AXX]AXX0    = "TABPIVTYP";"DESAXX";GLANGUE;[F:TPV]PIVTYP;[F:TPV]LEG,
&                       [F:TPVY]TPVY0 ~= [L]GRP;[F:TPV]PIVTYP;[F:TPV]GFY;[F:TPV]LEG,
&                       [F:TPVS]TPV0  ~= [F:TPV]PIVTYP;[F:TPV]LEG;[L]LEG
&                    As [LTPV]
      Else
        Link [TPV] With [F:AXX]AXX0   = "TABPIVTYP";"DESAXX";GLANGUE;[F:TPV]PIVTYP;[F:TPV]LEG,
&                       [F:FGR]FGR1   = [L]FCY;[F:TPV]GFY,
&                       [F:TPVC]TPV0  = [F:TPV]PIVTYP;[F:TPV]LEG;[F:TPV]GFY;[L]CPY,
&                       [F:TPVS]TPV0 ~= [F:TPV]PIVTYP;[F:TPV]LEG;[L]LEG
&                    As [LTPV]
      Endif
    Else
      # Vue LEG vide
      ERR = 0
      Repeat
        # -----------------------------------------------------------------------------------------------
        # ERR=0  : Pas d'erreur, on sort
        # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
        # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
        # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
        # -----------------------------------------------------------------------------------------------
        Onerrgo ERRVUE
        SZVIEW = "LEGTPVPAR"
        Local File =SZVIEW [TPVP]
        Onerrgo
      Until ERR <> -1
      If ERR Then
        # Si problème, on se déroute sur le select standard
        OBJET = "TPV"
        Return
      Endif
      If [L]CPY = "" and [L]FCY = "" and [L]GRP <> "" Then
        Link [TPV] With [F:AXX]AXX0    = "TABPIVTYP";"DESAXX";GLANGUE;[F:TPV]PIVTYP;[F:TPV]LEG,
&                       [F:TPVZ]TPVZ0 ~= [L]GRP;[F:TPV]PIVTYP;[F:TPV]GFY;[F:TPV]LEG
&                    As [LTPV]
      Else
        Link [TPV] With [F:AXX]AXX0   = "TABPIVTYP";"DESAXX";GLANGUE;[F:TPV]PIVTYP;[F:TPV]LEG,
&                       [F:FGR]FGR1   = [L]FCY;[F:TPV]GFY,
&                       [F:TPVC]TPV0  = [F:TPV]PIVTYP;[F:TPV]LEG;[F:TPV]GFY;[L]CPY,
&                       [F:TPVP]TPV0 ~= [F:TPV]PIVTYP;[F:TPV]LEG
&                    As [LTPV]
      Endif
    Endif
  Endif
  # --------------------------------
  # Options de sélection
  If OPTIONS <> "" Then
    Gosub OPTIONS From WOTPV
    ICRITERE += 1
    For I = 1 To NBCOND
      If instr(1,OPTIONS,OPT(I)) Then
        Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", "("+CONDIT(I)+")", "&") From GOBJSUB
      Endif
    Next I
  Endif
  # --------------------------------
  Default File [LTPV]
  DEFPAG = 1
Return

#-------------------------------------
$ERRVUE
  If ERR = 0 Then
    ERR = -1
    Call MAJVUE(SZVIEW, nomap) From DOSVUE
  Else
    ERR = errn
  Endif
Resume

###########################################################################
$TRTCOP
  #-----------------------------------------------------------#
  # Etiquette appelée depuis le traitement superviseur ACOPIE #
  # --------------------------------------------------------- #
  # Traitement de la copie d'un régime de taxe                #
  #-----------------------------------------------------------#
  If [M]DOSORG = nomap Then
    Local File TABPIVTYP [TPV1]
    Local File ATEXTRA   [AXX1]
  Else
    Local File =[M]DOSORG+".TABPIVTYP" [TPV1]
    Local File =[M]DOSORG+".ATEXTRA"   [AXX1]
  Endif
  If [M]DOSDES = nomap Then
    Local File TABPIVTYP [TPV2]
    Local File ATEXTRA   [AXX2]
    Local File ACTIV     [ACV2]
Else
    Local File =[M]DOSDES+".TABPIVTYP" [TPV2]
    Local File =[M]DOSDES+".ATEXTRA"   [AXX2]
    Local File =[M]DOSDES+".ATABDIV"   [ADI2]
    Local File =[M]DOSDES+".ACTIV"     [ACV2]
    Local File =func DOSCONT.DOSX3([M]DOSDES)+".ADOSSIER"  [ADS2]
  Endif
  Gosub OUVDOS From ATEXTRA
  # Multi-Lég... Vérifier que la législation existe dans le dossier destination
  # Sous OUVDOS, le fichier ADOSSIER ADS2 du dossier destination est déjà en ligne
  # Note FGR : c'est pas top ici. Déjà y a pas de message
  #  If TABLE2 <> "" & clalev([F:ADS2]) > 0 & !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
  #    Return
  #  Endif
  #
  Call DEBTRANS From GLOCK
  Gosub TRT_COPIE
  Close Local File [TPV1], [TPV2]
  Close Local File [AXX1], [AXX2]
  If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
  If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
  If clalev([F:ADI2])>0 : Close Local File [ADI2] : Endif
  If clalev([F:ACV2])>0 : Close Local File [ACV2] : Endif
Return

###########################################################################
$TRT_COPIE
Local Integer ILIG

  #--------------------------------------------------#
  # Transaction de copie d'un type de facture        #
  #--------------------------------------------------#
  Local Char    LEGDES
  Local Integer WMONOLEGDES
  # Par défaut : Leg destination=leg de l'enregistrement à copier
  LEGDES=TABLE2
  GOK = 1
  # -------------------------------------------------
  # Contrôles
#  If TABLE2 <> "" Then
#    If [M]DOSDES <> nomap Then
#      Local Char SZDOSSIER(GLONADS)
#      Local Integer LG
#
#      Read [ADI2]CODE=909;TABLE2
#      If fstat Then
#        Call MESSAGE([M:TPV1]LEG - ':' - mess(173,187,1)) From GESECRAN        #-- Législation non gérée par ce dossier --#
#        Return
#      Endif
#      LG = instr(1, [M]DOSDES, "@")
#      If LG = 0 Then
#        SZDOSSIER = [M]DOSDES
#      Else
#        SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
#      Endif
#      Read [ADS2]DOSSIER=SZDOSSIER
#      If !fstat Then
#        If !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
#          Call MESSAGE([M:TPV1]LEG - ':' - mess(249,133,1)) From GESECRAN      #-- Législation non gérée par ce dossier --#
#          Return
#        Endif
#      Endif
#    Endif
#  Endif
  #

  If [M]DOSDES<>nomap
      # Le dossier destination est-il mono-leg ?
      If [F:ACV2]CODACT<>"LEG"
       Read [ACV2]CODACT = "LEG"
       If fstat Raz [F:ACV2] : Endif
      Endif
      If [F:ACV2]FLACT<>2
       WMONOLEGDES=0
      Else
       WMONOLEGDES=1
      Endif

      If WMONOLEGDES =0
          # Dossier destination mono-leg
          LG = instr(1, [M]DOSDES, "@")
          If LG = 0 Then
            SZDOSSIER = [M]DOSDES
          Else
            SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
          Endif
          Read [ADS2]DOSSIER=SZDOSSIER
          If fstat
              # Pb lecture dossier
              Call MESSAGE(SZDOSSIER-":"-mess(78,133,1) ) From GESECRAN  #-- Dossier inexistant --#
              Return
          Endif
          If [F:ADS2]DOSLEG(0)=""
              # Pas de législation pour le dossier
              Call MESSAGE(SZDOSSIER-":"-mess(241,133,1) ) From GESECRAN  #-- Il doit y avoir au moins une législation  --#
              Return
          Endif
          If TABLE2<>[F:ADS2]DOSLEG(0) & TABLE2<>''
              # La leg de l'enreg. à copier n'est pas tte leg et elle est <> Leg dossier mono-leg
              # Pas de copie
              Call MESSAGE(mess(617,199,1)-"("-[F:ADS2]DOSLEG(0)-") :"-mess(618,199,1)) From GESECRAN
              Return
          Elsif TABLE2=''
              # La leg de l'enreg. à copier est toute leg
              # On peut copier l'enreg : Leg destination=leg du dossier mono-leg
              LEGDES=[F:ADS2]DOSLEG(0)
          Endif
      Else
          # Dossier destination multi-leg
          If TABLE2<>''
            # Enregistrement à copier avec leg<>""
            Local Char SZDOSSIER(GLONADS)
            Local Integer LG
            Read [ADI2]CODE=909; TABLE2
            If fstat
             Call MESSAGE (TABLE2 - ':'- mess(173,187,1)  ) From GESECRAN : #-- Législation inexistante sur ce dossier --#
             Return
            Endif

            LG = instr(1, [M]DOSDES, "@")
            If LG = 0 Then
              SZDOSSIER = [M]DOSDES
            Else
              SZDOSSIER = mid$([M]DOSDES,LG+1,len([M]DOSDES))
            Endif
            Read [ADS2]DOSSIER=SZDOSSIER
            If !fstat Then
                If !find(TABLE2,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1)) Then
                  Call MESSAGE(TABLE2 - ':' - mess(249,133,1) ) From GESECRAN  #-- Législation non gérée par ce dossier --#
                  Return
                Endif
            Endif
          Endif
      Endif
  Endif

  Read [TPV2]TPV0=TABLE;LEGDES
  If !fstat Then
    Local Integer WOK

    WOK = 1
    Call AVERTIR (mess(197,133,1), WOK) From GESECRAN :                        #-- enregistrement existe déjà --#
    If WOK = 1 Then
      Return
    Endif
  Endif
  # -----------------------------------------------
  Trbegin [TPV2]
  Delete [TPV2] Where PIVTYP = TABLE & LEG = LEGDES
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$" + [M]DOSDES + ".TABPIVTYP"
    Goto ROLL_COPIE
  Elsif fstat Then
    GOK=0
    Call RSTA("TPV2", "") From GLOCK
    Goto AB_COPIE
  Endif
  If !fstat Then
    #-- copie des données
    For [TPV1] Where PIVTYP = TABLE & LEG = TABLE2
      [F:TPV2] = [F:TPV1]
      [F:TPV2]LEG = LEGDES
      If TABLE2=LEGDES
         Call COPTEXTRA("TABPIVTYP","DESAXX",TABLE,TABLE2) From ATEXTRA
         Call COPTEXTRA("TABPIVTYP","SHOAXX",TABLE,TABLE2) From ATEXTRA
      Else
         Call COPTEXTRA1("TABPIVTYP","DESAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
         Call COPTEXTRA1("TABPIVTYP","SHOAXX",TABLE,TABLE2,LEGDES) From TRTX3TEX
      Endif
      If GOK=0 Goto AB_COPIE Elsif GOK<0 Goto ROLL_COPIE : Endif
      If dim([F:TPV2]UPDUSR) > 0 Then
        [F:TPV2]UPDUSR = GUSER
      Endif
      If dim([F:TPV2]UPDDAT) > 0 Then
        [F:TPV2]UPDDAT = date$
      Endif
      If fstat Then
        GOK = 0
        Call FSTA("TPV2") From GLOCK
      Endif
      Write [TPV2]
      If fstat Then
        GOK = 0
        Call FSTA("TPV2") From GLOCK
        Break
      Endif
    Next
  Endif
  If GOK < 0 Then
    Goto ROLL_COPIE
  Elsif !GOK Then
    Goto AB_COPIE
  Endif
  Commit
Return

#----- Abandon de la copie -----#
$AB_COPIE
  Rollback
Return

#----- Nouvel essai si nécessaire -----#
$ROLL_COPIE
  Rollback
  Call ROLL From GLOCK
  If !GROLL Then
    Goto TRT_COPIE
  Endif
Return

######################################################################################
Subprog SELTPVA(PIVTYP,LEG,FCY,GROUPE,CPY,TYPSEL,CODMSK,CHAMPCOD)
Variable Char    PIVTYP()
Value    Char    LEG
Value    Char    FCY
Value    Char    GROUPE
Value    Char    CPY
Value    Char    TYPSEL
Value    Char    CODMSK
Value    Char    CHAMPCOD

Local Char PARMSK(30)(1..10)

  # FGR 02/01/2013 :X3SUIVI71937
  PARMSK(1)=[L]LEG
  PARMSK(2)=[L]FCY
  PARMSK(3)=[L]GROUPE
  PARMSK(4)=[L]CPY
  PARMSK(5)=[L]TYPSEL
  PARMSK(6)=[L]CODMSK
  PARMSK(7)=[L]CHAMPCOD
  #
  If clalev([F:TPV])=0 : Local File TABPIVTYP [TPV] : Endif
  Call S_TAB_CHAR(PIVTYP, PARMSK, "SELTPVLEG", "SUBTPV", "") From GACTION
End

######################################################################################
Subprog VERF_PARAM(PPARAM, PVALEUR, POK)
Value Char PPARAM     # Nom du paramètre en cours de saisie
Value Char PVALEUR    # Valeur saisie à contrôler
Variable Integer POK  # 1 si contrôle satisfait, 0 si saisie incorrecte

Local Char    FCY(GLONFCY),SAVE_GCURFCY( GLONFCY)
Local Char    CPY(GLONCPY),SAVE_GSOCIETE(GLONCPY)
Local Char    LEG(GLONADI)
Local Integer WNOL
Local Integer ERR

  # FGR 02/01/2013 :X3SUIVI71937
  If PVALEUR = "" Then
    End
  Endif
  If clalev([F:TPV])=0 : Local File TABPIVTYP [TPV] : Endif
  [L]SAVE_GCURFCY = GCURFCY
  [L]SAVE_GSOCIETE= GSOCIETE
  If GFONCTION = "ADPVAL" Then
    # Saisie valeurs paramètres. Type de données = TPVB
    FCY  = [M:ADWP]FCY : GCURFCY  = FCY
    CPY  = [M:ADWP]CMP : GSOCIETE = CPY
    If dim([M:ADWP]LEG)>0
      LEG = [M:ADWP]LEG
    Else
      LEG = GDOSLEG
    Endif

    WNOL = nolign-1
    #--Initialisation de législation
    If [L]LEG = "" Then
      If [L]FCY <> "" Then
        Call LEC_FCY([L]FCY) From CPTLEC
        Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
        GSOCIETE = [F:FCY]LEGCPY
        [L]LEG = [F:CPY]LEG
      Elsif [L]CPY <> "" Then
        Call LEC_CPY([L]CPY) From CPTLEC
        [L]LEG = [F:CPY]LEG
      Endif
    Endif
    If [L]LEG = "" Then
      [L]LEG = GCURLEG
    Endif
    #--CPO 98053 Sélection depuis "ADPVAL" et prise en compte des OPTIONS
    #Call CONTTPV(PVALEUR,LEG,"","",FCY,"",CPY)
    Call CONTTPV(PVALEUR,LEG,"MULTILEGADP",PPARAM,FCY,"",CPY)
    If mkstat Then
      POK = 0
    Endif
  Endif
  GCURFCY = [L]SAVE_GCURFCY
  GSOCIETE= [L]SAVE_GSOCIETE
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran TPV1) 28/01/2013 17:39:07 (CPO)
######################################################################################
#--CPO 71937
Subprog C_LEG(VALEUR)
