######################################################################################
Subprog C_GFY(VALEUR)
Variable Char    VALEUR()

  GGRPFCY = VALEUR :#--CPO 71937
End

######################################################################################
Subprog AM_GFY(VALEUR)
#------------------------------------------------#
# Après modification du groupe de sociétés/sites #
# ---------------------------------------------- #
# Il faut vérifier si le type de pièce est bien  #
# sur le même groupe                             #
# Nota: On ne peut pas contrôler le code journal #
# Car la notion de groupe est différente         #
#------------------------------------------------#
Variable Char    VALEUR()
GGRPFCY = VALEUR :#--CPO 71937
  If [M:TPV1]GTE<>""
    If [F:GTE]TYP<>[M:TPV1]GTE
      #--CPO 71937 Déclinaison par législation
      #Read [GTE] GTE0=[M:TPV1]GTE;[M:TPV1]LEG : If fstat  Raz [F:GTE] : Endif
      Local Integer WRET
      Call LEC_GTE_LEG([M:TPV1]LEG, [M:TPV1]GTE, WRET) From TRTLECLEG
      If WRET  Raz [F:GTE] : Endif
    Endif
    If ([F:GTE]GFY<>"" | VALEUR="") & [F:GTE]GFY<>VALEUR
      GMESSAGE=mess(10,105,1)-[M:TPV1]GTE-mess(92,187,1)-"("
      If VALEUR<>""
        GMESSAGE+=VALEUR-"<>"-[F:GTE]GFY+")"
      Else
        GMESSAGE+=mess(220,117,1)-"<>"-[F:GTE]GFY+")"
      Endif
      mkstat=1
      End
    Endif
  Endif
End

