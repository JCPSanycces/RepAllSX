######################################################################################
###################################################################################################
##--CPO 71937 Contrôle global de cohérence avant enregistrement
$CONTROLE_COHERENCE

  Local Integer WSTAT
  Local Char    WMESSA(250)
  Local Char  	WCODE
  Local Char    WLEG
  Local Char    WCTX_CPY
  Local Char    WCTX_FCY
  Local Char    WCTX_LEG

	WCODE=[M:TPV1]PIVTYP
	WLEG =[M:TPV1]LEG

  Call CTL_ML_CONSISTENCY("TPV", "NON", WCODE, WLEG , WCTX_CPY, WCTX_FCY, WCTX_LEG, WSTAT, WMESSA) From TRTVENCTL
  If WSTAT>0 or WMESSA<>""
  	GMESSAGE = WMESSA : GOK=0 : GERR=1 #--Si on ne veux pas bloquer..GERR=2
  Endif

Return
#--------------------------------------------------------------------------------------------------
$CHECK_CONSISTENCY
	Local Integer WRET

	If clalev([F:TPV])=0 : Local File TABPIVTYP [TPV] : Endif

  #--Vérification de la compatibilité des sous-données déclinées elles aussi

	#--  P_CODE<>"" and (PACTUAL_CPY<>"" or PACTUAL_FCY<>"" or PACTUAL_LEG<>"")

  #--Est-ce que la lég du code retenu est-elle compatible avec la lég en paramètre ?
  If P_LEG<>"" and PACTUAL_LEG<>"" and P_LEG<>PACTUAL_LEG
		VSTATUS=99 : VMESSAGE=mess(74,127,1)-":"-P_LEG-"<>"-PACTUAL_LEG :# "Législations différentes"
		Return
	Endif

	#--Lecture du [F]
	#--Seulement si besoin
	#--De plus si on est dans GESTPV il ne faut pas relire car
	#--Si Création => pas dans la BD (mais comme appel depuis ACTION="INICRE" [F] est chargé
	#--Si Modification => idem
	If left$(GFONCTION,6) <>"GESTPV"
    #--Cohérence [TPV] et paramètres
    Call CONTTPV(P_CODE,PACTUAL_LEG,"","",PACTUAL_FCY,"",PACTUAL_CPY) From SUBTPV
    If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Return : Endif
  #--CPO 96248 Lors du ttt de cette fiche => il ne faut plus appeler le sous-contrôles car appelés lors du CONT principal
  Else #Endif
    #--Cohérence [TPV]JOU et paramètres
    If PACTUAL_FCY<>""
    	Call CONTJOU([TPV]JOU, PACTUAL_LEG, PACTUAL_FCY) From SUBJOU
    Else
    	Call CONTJOU([TPV]JOU, PACTUAL_LEG, PACTUAL_CPY) From SUBJOU
  	Endif
    If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Return : Endif

    #--Cohérence [TPV]GTE et paramètres
    If PACTUAL_FCY<>""
    	Call CONTGTE([TPV]GTE, PACTUAL_LEG, PACTUAL_FCY) From SUBGTE
    Else
    	Call CONTGTE([TPV]GTE, PACTUAL_LEG, PACTUAL_CPY) From SUBGTE
  	Endif
    If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Return : Endif
  Endif

Return
#-----------------------------------------------------------------------------------------
$FIND_CONTEXT
	Local Integer I,IJ
	Local Integer RET,I
	Local Integer CAS
	Local Char LEGS(GLONADI)(1..)
	Local Integer COHERENCE_OK

	If clalev([F:TPV])=0 : Local File TABPIVTYP  [TPV] : Endif
	If clalev([F:JOU])=0 : Local File GJOURNAL   [JOU] : Endif
	If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif

  Local Instance GROUPES Using C_GRPCOLL

	#--On connait la détermination
	#--On cherche un contexte compatible
	#--Si pas de contexte compatible, alors la donnée multi-lég est mal paramétrée

	#-- P_CODE<>"" and (PACTUAL_CPY="" and PACTUAL_FCY=""and PACTUAL_LEG="")

	#--Lecture du [F]
	#--Seulement si besoin
	#--De plus si on est dans GESTPV il ne faut pas relire car
	#--Si Création => pas dans la BD (mais comme appel depuis ACTION="INICRE" [F] est chargé
	#--Si Modification => idem
	If left$(GFONCTION,6) <>"GESTPV" and ( [F:TPV]PIVTYP<>P_CODE | find([F:TPV]LEG,P_LEG,"")=0 )
    If P_LEG<>""
     Read [TPV]TPV0=P_CODE;P_LEG
     If fstat
      Read [TPV]TPV0=P_CODE;""
     Else
      CAS = 2 : # P_LEGislation isn't empty
     Endif
    Else
     Read [TPV]TPV0(1)=P_CODE
     If !fstat
      P_LEG = [F:TPV]LEG
      CAS = 2
     Endif
    Endif
    If fstat
     Filter [TPV] Where PIVTYP=P_CODE
     Look [TPV]TPV0 First
     If !fstat
      # Fiche inexistante pour la législation courante
      VMESSAGE = P_CODE-":"-mess(232,107,1)-"["+P_LEG+"]"
     Else
      # Fiche inexistante
      VMESSAGE = P_CODE-":"-mess(23,100,1)
     Endif
     Filter [TPV]
     VSTATUS=99 : Return
    Endif
  Endif

  #--Est-ce que la lég du code retenu est-elle compatible avec la lég en paramètre ?
  If P_LEG<>"" and [F:TPV]LEG<>"" and P_LEG<>[F:TPV]LEG
		VSTATUS=99 : VMESSAGE=mess(74,127,1)-":"-P_LEG-"<>"-[F:TPV]LEG :# "Législations différentes"
		Return
	Endif

  P_LEG=[F:TPV]LEG
  LEGS(1)=P_LEG

  If P_LEG=""
		#--Le code retenu est toutes législations
		#--Il faut d'abord trouver une législation commune
		#--Puis pour cette législation, il faut déterminer une société commune aux groupes, sinon on renvoye ""
		I = 2

		If [F:TPV]JOU<>""
  		For [JOU] Where JOU=[F:TPV]JOU
  			If [F:JOU]LEG<>"" and find([F:JOU]LEG,LEGS)=0
  				LEGS(I) = [F:JOU]LEG
  				I += 1
  			Endif
  		Next
  	Endif

		If [F:TPV]GTE<>""
  		For [GTE] Where TYP=[F:TPV]GTE
  			If [F:GTE]LEG<>"" and find([F:GTE]LEG,LEGS)=0
  				LEGS(I) = [F:GTE]LEG
  				I += 1
  			Endif
  		Next
  	Endif

	Endif

	For I=1 To maxtab(LEGS)

  	#--Le code retenu contient une législation en particulier
  	#--Cette législation sera renvoyée
  	#--Reste à déterminer une société commune aux groupes, sinon on renvoye ""

  	#--On commence par lire les sous-données déclinées

  	#--Lecture du Régime de taxes
  	If [F:TPV]JOU<>""
    	Call LEC_JOU_LEG(LEGS(I),[F:TPV]JOU,RET) From TRTLECLEG
    	If RET
    		#--On passe à la lég suivante
  			Goto NEXT_LEGS
    	Endif
    Else
    	Raz [F:JOU]
    Endif

  	#--Lecture de la Nature de taxes
  	If [F:TPV]GTE<>""
    	Call LEC_GTE_LEG(LEGS(I),[F:TPV]GTE,RET) From TRTLECLEG
    	If RET
    		#--On passe à la lég suivante
  			Goto NEXT_LEGS
    	Endif
    Else
    	Raz [F:GTE]
    Endif

  	#--Il reste à trouver une société commune aux différents groupes
  	#--La société doit être de la législation retenue

		If [F:TPV]GFY<>"" or [F:JOU]FCY <>"" or [F:GTE]GFY<>""

      GROUPES = NewInstance [GRPTPV] With C_GRPCOLL


      RET= fmet GROUPES.GROUPADD([F:TPV]GFY)
      RET= fmet GROUPES.GROUPADD([F:JOU]FCY)
      RET= fmet GROUPES.GROUPADD([F:GTE]GFY)

    	For IJ = 1 To maxtab(GROUPES.L_FCY)
      	If GROUPES.L_FCY(IJ)<>null and find(GROUPES.L_FCY(IJ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      	  If LEGS(I)="" | GROUPES.L_FCY(IJ).FCYCPYLEG = LEGS(I)

        		PACTUAL_FCY = GROUPES.L_FCY(IJ).FCY
        		PACTUAL_CPY = GROUPES.L_FCY(IJ).FCYCPY
        		PACTUAL_LEG = GROUPES.L_FCY(IJ).FCYCPYLEG

        		FreeInstance =GROUPES.AllocGrp

        		COHERENCE_OK = 1
        		Break 2

      		Endif
      	Endif
    	Next IJ

      #--On libère proprement...
      FreeInstance =GROUPES.AllocGrp

		Else
			#--On a trouvé une lég, et il n'y a pas de groupes
			#--C'est bon...
    	#--Les lectures ont abouti
    	#--On peut renvoyer le legs(i) comme législation du contexte
    	PACTUAL_LEG = LEGS(I)
    	COHERENCE_OK = 1
    	Break

		Endif

   	$NEXT_LEGS
	Next I

	#--On positionne le VSTATUS si rien trouvé
  If COHERENCE_OK <>1
  	VMESSAGE = mess(799,197,1)
  	VSTATUS  = 1 : Return
  Endif

Return
#-----------------------------------------------------------------------------------------
$FIND_CODE
	If clalev([F:TPV])=0 : Local File TABPIVTYP [TPV] : Endif
  #--On connait le contexte
  #--On cherche une détermination compatible

  #--  P_CODE=""  and (PACTUAL_CPY<>"" or PACTUAL_FCY<>"" or PACTUAL_LEG<>"")

	#--Filtre sur la législation ou "toutes législations"
  Filter [F:TPV] Where find(LEG,"",PACTUAL_LEG)>0

	For [F:TPV]

		Raz VSTATUS : Raz VMESSAGE

    #--Cohérence [TPV] et paramètres
    Call CONTTPV([F:TPV]PIVTYP, PACTUAL_LEG, "","", PACTUAL_FCY, "", PACTUAL_CPY) From SUBTPV
    If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Endif
    #--CPO 96248 Lors du ttt de cette fiche => il ne faut plus appeler le sous-contrôles car appelés lors du CONT principal
    #  	If VSTATUS=0
    #      #--Cohérence [TPV]JOU et paramètres
    #      If PACTUAL_FCY<>""
    #      	Call CONTJOU([TPV]JOU, PACTUAL_LEG, PACTUAL_FCY) From SUBJOU
    #      Else
    #      	Call CONTJOU([TPV]JOU, PACTUAL_LEG, PACTUAL_CPY) From SUBJOU
    #			Endif
    #      If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Endif
    #  	Endif
    #
    #  	If VSTATUS=0
    #      #--Cohérence [TPV]GTE et paramètres
    #      If PACTUAL_FCY<>""
    #      	Call CONTGTE([TPV]GTE, PACTUAL_LEG, PACTUAL_FCY) From SUBGTE
    #      Else
    #      	Call CONTGTE([TPV]GTE, PACTUAL_LEG, PACTUAL_CPY) From SUBGTE
    #			Endif
    #      If mkstat : Raz mkstat : VSTATUS=1 : VMESSAGE=GMESSAGE : Raz GMESSAGE : Endif
    #  	Endif

    If VSTATUS=0
    	#--Le code trouvé est cohérent avec le contexte
    	P_CODE=[F:TPV]PIVTYP
			P_LEG =[F:TPV]LEG
			Break
		Endif

	Next

	Filter [F:TPV]

	If VSTATUS>0 | P_CODE=""
		VMESSAGE = mess(798,197,1)-":"-mess(218,107,1)-PACTUAL_LEG+","-mess(2,45,1)-PACTUAL_CPY
	Endif

Return

End
