######################################################################################
# Control
Subprog CONTTPV(COD,LEG,CODMSK,CHAMPCOD,FCY,GROUPE,CPY)
Variable Char    COD()
Value    Char    LEG()
Value    Char    CODMSK()
Value    Char    CHAMPCOD()
Value    Char    FCY
Value    Char    GROUPE
Value    Char    CPY

Local    Integer CAS
Local    Char    OPTIONS(30)

  # FGR 11/12/2012 : X3SUIVI71937
  If left$(GFONCTION,6) = "GESTPV" or [L]COD = "" Then
    End
  Endif
  # --------------------------------------------------------------------------
  If clalev([F:TPV])= 0  : Local File TABPIVTYP  [TPV] : Endif
  If clalev([F:TPVZ])= 0 : Local File LEGTPVZGRP [TPVZ] : Endif
  If clalev([F:AMZZ])= 0 : Local File AMSKZON    [AMZZ] : Endif :#--for the selection options of the object
  # --------------------------------------------------------------------------
  If func AFNC.ACTIV("LEG") = 0 Then
    [L]LEG = GDOSLEG
  Elsif LEG = "" & GCURLEG <> "" Then : # GCURLEG positionné par programme
    [L]LEG = GCURLEG
  Endif
  # --------------------------------------------------------------------------
  CAS = 1  #--Legislation is empty

  #--CPO 71937
  #--Cas particulier : pas de GCURLEG mais société ou site en ligne
  If clalev([F:CPY])=0  : Local File COMPANY    [CPY] : Endif :#--CPO 71937
  If clalev([F:FCY])=0  : Local File FACILITY   [FCY] : Endif :#--CPO 71937
  If [L]LEG="" and ([L]CPY<>"" | [L]FCY<>"")
  	If [L]FCY<>""
  		If [F:FCY]FCY<>[L]FCY
  			Read [F:FCY]FCY0=[L]FCY
  			If fstat : Raz [F:FCY] Endif
  		Endif
  		If [L]CPY="" : [L]CPY=[F:FCY]LEGCPY : Endif
  	Endif
  	If [L]CPY<>""
  		If [F:CPY]CPY<>[L]CPY
  			Read [F:CPY]CPY0=[L]CPY
  			If fstat : Raz [F:CPY] Endif
  		Endif
  		[L]LEG=[F:CPY]LEG
  	Endif
  Endif
  #--/CPO

  If [L]LEG <> "" Then
    Read [TPV]TPV0=[L]COD;[L]LEG
    If fstat Then
      Read [TPV]TPV0=[L]COD;""
    Else
      CAS = 2  #--Legislation isn't empty
    Endif
  Else
    Read [TPV]TPV0(1)=[L]COD
    If !fstat Then
      [L]LEG = [F:TPV]LEG
      CAS = 2
    Endif
  Endif
  If fstat Then
    Filter [TPV] Where PIVTYP=[L]COD
    Look [TPV]TPV0 First
    If !fstat Then
      # "Fiche inexistante pour la législation courante"
      # "No existing record for the curent legislation"
      GMESSAGE = [L]COD - ":" - mess(232,107,1) - "[" + [L]LEG + "]"
    Else
      # "Fiche inexistante"
      # "Record does not exist"
      GMESSAGE = [L]COD - ":" - mess(23,100,1)
    Endif
    Filter [TPV]
    mkstat = 2
    End
  Endif
  # --------------------------------------------------------------------------
  #--Filtrage par groupe de société
  #--Dans ce cas particulier ou nous pouvons avoir que le CPY de renseigné (paramètrage pour une société)
  #--Du fait du type de donné AGF sur le champ GRP de TABVAT, il n'y aura que le filtrage sur site ! (en fonction de GCURFCY)
#If [L]CPY<>""
If [L]CPY<>"" and [L]FCY="" :#--CPO 71937
  If [F:TPV]GFY<>""
  	#--CPO 71937
  	If clalev([F:AGF])=0 : Local File AGRPFCY    [AGF]  : Endif
		Read [AGF]AGF0=[F:TPV]GFY
		If !fstat
  		If [F:AGF]FLGLEG=2
    		#--Société
				If [F:TPV]GFY<>[L]CPY
          GMESSAGE += [L]COD+"\"+mess(63,127,1)-":"-[F:TPV]GFY : # Réservé au groupe de société
          mkstat = 2 : End
				Endif
  		Elsif [F:AGF]FLGCPY=2
  	#--CPO
        If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
        Look [AGC]AGC0 = [F:TPV]GFY;[L]CPY
        If fstat
          GMESSAGE += [L]COD+"\"+mess(63,127,1)-":"-[F:TPV]GFY : # Réservé au groupe de société
          mkstat = 2 : End
        Endif
      Endif :#--CPO 71937
    Endif
  Endif
Endif
#--

  #--Contrôle de cohérence entre le groupe de la taxe et la législation
  If [F:TPV]GFY <> "" and [L]LEG <> "" Then
    Call CTLGFYLEG([F:TPV]GFY, [L]LEG, "", "") From TRTVENCTL
    If mkstat Then
      End
    Endif
  Endif
  #--Contrôle de cohérence entre le groupe passé en paramètre et la législation de l'entrée retenue
  If [L]GROUPE <> "" and [F:TPV]LEG <> "" Then
    Call CTLGFYLEG([L]GROUPE, [F:TPV]LEG, "", "") From TRTVENCTL
    If mkstat Then
      End
    Endif
  Endif
  # --Contrôle de la cohérence entre le groupe passé en param et celui de la taxe à contrôler
  # --uniquement si le groupe passé est renseigné
  # --uniquement si pas de contexte site ou société !
  If [L]GROUPE <> "" Then
    If [L]CPY = "" and [L]FCY = "" and [F:TPV]GFY <> "" and [F:TPV]GFY <> [L]GROUPE Then
      #--Les groupes doivent avoir au moins une société en commun
      Gosub CTLGFYGRP
      If mkstat Then
        End
      Endif
    Endif
  Endif
  # --------------------------------------------------------------------------
  # --On charge les options définies sur le type de données du champ du masque
  # --Findig Object options defined on the data type of the field in the screen
  OPTIONS = ""
  If CODMSK <> "" & CHAMPCOD <> "" Then
    Read [F:AMZZ]CODE=[L]CODMSK;[L]CHAMPCOD
    If fstat = 0 Then
      OPTIONS = [F:AMZZ]OPTOBJ
    Endif
  Endif
  If CAS = 2 Then
   Call CONTROLE("TPV", OPTIONS, [L]LEG, [L]COD, mkstat) From CONTOBJ
  Else
   Call CONTROLE("TPV", OPTIONS, "", [L]COD, mkstat) From CONTOBJ
  Endif

	#--CPO 71937 Contrôle global de cohérence avant enregistrement
  If mkstat > 0 End Endif

	#--Cohérence [TSV]JOU et paramètres
	If [F:TPV]JOU<>""
  	If clalev([F:JOU])=0 : Local File GJOURNAL   [JOU] : Endif

    If [L]FCY<>""
    	Call CONTJOU([TPV]JOU, [L]LEG, [L]FCY) From SUBJOU
    Elsif [L]CPY<>""
    	Call CONTJOU([TPV]JOU, [L]LEG, [L]CPY) From SUBJOU
    Elsif [L]GROUPE<>""
    	Call CONTJOU([TPV]JOU, [L]LEG, [L]GROUPE) From SUBJOU
  	Endif
  	If mkstat
  		If [L]LEG=""
  			GMESSAGE = [L]COD-":"-GMESSAGE
  		Else
  			GMESSAGE = [L]COD-"["+[L]LEG+"]"-":"-GMESSAGE
  		Endif
  		End
  	Endif
	Endif


	#--Cohérence [TSV]GTE et paramètres
	If [F:TPV]GTE<>""
  	If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif
    If [L]FCY<>""
    	Call CONTGTE([TPV]GTE, LEG, [L]FCY) From SUBGTE
    Elsif [L]CPY<>""
    	Call CONTGTE([TPV]GTE, LEG, [L]CPY) From SUBGTE
    Elsif [L]GROUPE<>""
    	Call CONTGTE([TPV]GTE, LEG, [L]GROUPE) From SUBGTE
  	Endif
  	If mkstat
  		If [L]LEG=""
  			GMESSAGE = [L]COD-":"-GMESSAGE
  		Else
  			GMESSAGE = [L]COD-"["+[L]LEG+"]"-":"-GMESSAGE
  		Endif
  		End
  	Endif
	Endif

End

#-------------------------------
$CTLGFYGRP
Local Integer ERR
Local Char    SZVIEW(GLONAVW)

  #--------------------------------------------------------------------------------------------------
  ## Appel à la vue
  #--------------------------------------------------------------------------------------------------
  If [F:TPV]LEG = "" Then
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTPVZGRP"
      Local File =SZVIEW [TPVZ]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, pas de contrôle
      Return
    Endif
    Read [F:TPVZ]TPVZ0=[L]GROUPE;[F:TPV]PIVTYP;[F:TPV]GFY;[F:TPV]LEG
    If fstat Then
      GMESSAGE = mess(177,187,1) - ":" - [L]GROUPE - "-" - [F:TPV]GFY - ":" - mess(178,187,1)
      mkstat = 1
      Return
    Endif
  Else
    ERR = 0
    Repeat
      # -----------------------------------------------------------------------------------------------
      # ERR=0  : Pas d'erreur, on sort
      # ERR=-1 : Erreur à l'ouverture de la vue on l'a revalidée. On tente de réouvrir
      # ERR>0  : Erreur relative à l'ouverture de la vue. Comme on l'a revalidée c'est qu'elle est pas bonne on sort quand même
      # Note : obligé de faire ça parce que l'abrégé d'ouverture d'un local file ne peut être évalué.
      # -----------------------------------------------------------------------------------------------
      Onerrgo ERRVUE
      SZVIEW = "LEGTPVYGRP"
      Local File =SZVIEW [TPVY]
      Onerrgo
    Until ERR <> -1
    If ERR Then
      # Si problème, pas de contrôle
      Return
    Endif
    Read [F:TPVY]TPVY0=[L]GROUPE;[F:TPV]PIVTYP;[F:TPV]GFY;[F:TPV]LEG
    If fstat Then
      GMESSAGE = mess(177,187,1) - ":" - [L]GROUPE - "-" - [F:TPV]GFY - ":" - mess(178,187,1)
      mkstat = 1
      Return
    Endif
  Endif
Return

#Subprog CONTTPV(COD,LEG)
#Variable Char    COD()
#Value    Char    LEG()
