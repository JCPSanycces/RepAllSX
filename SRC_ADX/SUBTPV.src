#<AdxTL>@(#)10.0.0.0 $Revision$ Gestion du fichier TABPIVTYP
#########################################################################
# SUBTPV : Gestion des types facture utilisateur achats    MBT 28/09/99 #
# --------------------------------------------------------------------- #
# Traitements sur champ "Call" de l'objet "PTV"                         #
# Table mise à jour  : [F:TPV]TABPIVTYP                                 #
#########################################################################
  Call OBJET("TPV",GBIDC1,GBIDC2) From GOBJET
End
######################################################################################
$ACTION
  Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "AFFMASK"     : Gosub AFFMASK
    When "RAZCRE"      : Gosub RAZCRE
    When "RAZDUP"      : Gosub RAZDUP
    When "LIENS"       : Gosub LIENS
    When "SETBOUT"     : Gosub SETBOUT           # FGR 11/12/2012 : X3SUIVI71937
    When "SEL_TABLE"   :                         # FGR 11/12/2012 : X3SUIVI71937
      Case TABLE
        When "SELTPVLEG"
          Gosub SELTPVLEG
        When Default
          Gosub SEL_TABLE
      Endcase
    When "CHGCOD"      : Gosub CHGCOD            # FGR 11/12/2012 : X3SUIVI71937
    When "VERIF_CRE"   : Gosub VERIF             # FGR 11/12/2012 : X3SUIVI71937
    When "VERIF_MOD"   : Gosub VERIF             # FGR 11/12/2012 : X3SUIVI71937
    When "FERME"       : Gosub FERME
    When "INICRE"      : Gosub INICRE
    When "INIMOD"      : Gosub INICRE
    When "ANNULE"      : Gosub ANNULE
    When "CHANGE"      :                         # FGR 11/12/2012 : X3SUIVI71937 # --CPO 71937 Prise en compte de LEG, ajout de SUPP
                         #Call CHANGE_AXX ("TABPIVTYP", [L]SUPP(0), [L]OCODE, [L]SUPP(0), [L]NCODE) From TRTX3TEX
                         Call CHANGE_AXX ("TABPIVTYP", [L]OCODE, [L]SUPP(0), [L]NCODE, [L]SUPP(0)) From TRTX3TEX
    When Default
  Endcase
Return

######################################################################################
$OUVRE
  If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif # FGR 11/12/2012 : X3SUIVI71937
  #------------------------------------#
  # Sauvegarder des variables globales #
  #------------------------------------#
  Gosub SAUV_GLOB From TRTX3GLOB
  #-----
  GBIDI1=1 : # Valeur testée dans l'objet GAU pour sélection du type de pièce auto
  #--Lors d'un tunnel depuis un document (exemple : livraison)
  Raz GCURFCY  :#--Ici pas de contexte et on veut éviter le filtrage des groupes de sites
  Raz GSOCIETE :#--Ici pas de contexte et on veut éviter le filtrage des groupes de societes
  #--/CPO

  #BRBAN 08/10/2014 - Document types control
  If !clalev([F:TPV3]) : Local File TABPIVTYP [TPV3] : Endif

Return

######################################################################
$SETBOUT
  # FGR 11/12/2012 : X3SUIVI71937
  #------------------------------#
  # Désactivation bouton "Copie" #
  #------------------------------#
  If GREP <> "" | !CLECUR Then
    Call VIREBOUT(CHAINE, "2") From GOBJET
  Endif
Return

#################################################################################
$CHGCOD
  # FGR 11/12/2012 : X3SUIVI71937
  Call CHGCOD(ABREV, CLECUR1, CLECUR2, OK) From CHGCLELEG
Return

######################################################################################
$AFFMASK
  Call FMTLEG From TRTX3 : # Pour rendre invisible si nécessaire le champ "Législation"
  Gosub GRILEG                                   # FGR 11/12/2012 : X3SUIVI71937
  Gosub GRIJOU
Return

######################################################################################
$GRILEG
  # FGR 11/12/2012 : X3SUIVI71937
  If func AFNC.ACTIV("LEG") = 0 Then : # Dossier mono-législation
    Diszo [TPV1]LEG
    [M:TPV1]LEG = GDOSLEG(1)
    Affzo [TPV1]LEG : If dim([M:TPV1]ZLEG)>0  Affzo [TPV1]ZLEG : Endif
  Endif
Return

######################################################################################
$GRIJOU
  If GMODU(2)<>2
    Grizo JOU
  Endif
Return

######################################################################################
$RAZCRE
  #-------------------------------------------------------#
  # Traitement zones dépendant de la catégorie "Proforma" #
  #-------------------------------------------------------#
  Actzo [TPV1]COD, COD2, JOU, GTE
  Gosub GRILEG                                   # FGR 11/12/2012 : X3SUIVI71937
  Gosub GRIJOU

  #RMA * 85785
  If func AFNC.ACTIV("KPO") > 0
    Call SHOW_HIDE_TPV([M:TPV1]LEG) From PORLEGLIB
  Endif

Return
######################################################################################
######################################################################################
$RAZDUP

#RMA * 85785
If func AFNC.ACTIV("KPO") > 0
  Call SHOW_HIDE_TPV([M:TPV1]LEG) From PORLEGLIB
Endif

Return
######################################################################################
$LIENS
  # FGR 11/12/2012 : X3SUIVI71937 (début)
  GCURLEG = [F:TPV]LEG
  If GNBLEG = 1 Then
    GCURLEG = GDOSLEG
  Endif
  # FGR 11/12/2012 : X3SUIVI71937 (fin)
  #--------------------------------------------------------------#
  # Grisage dégrisage zones dépendant de la catégorie "Proforma" #
  #              "Note de débit" et "Note de crédit"             #
  #--------------------------------------------------------------#
  If [M:TPV1]INVTYP=5 : # Test Proforma
    Grizo [TPV1]COD2, JOU, GTE
  Else
    Actzo [TPV1]COD2, JOU, GTE
  Endif
  If [M:TPV1]INVTYP>2 : # Test type facture non achat
    Grizo [TPV1]PIHTYP, COD
  Else
    Actzo [TPV1]PIHTYP, COD
  Endif
  Gosub GRIJOU

  #RMA * 85785
  If func AFNC.ACTIV("KPO") > 0
    Call SHOW_HIDE_TPV([M:TPV1]LEG) From PORLEGLIB
  Endif

# Issue X3-143 - 2016-10-03 by RICAR : 107966 - Change the field actions on RECTYP, SAFTTRNTYP and COMAT
# Issue X3-143
If func AFNC.ACTIV("KPO") > 0
  Gosub DISABLE_TPV_FIELDS From PORLEGLIB
Endif
# End issue X3-143

Return

######################################################################
$VERIF

#BRBAN 08/10/2014 - Document types control
If func AFNC.ACTIV("KPO") > 0
  Case [M:TPV1]LEG
    When ""
      Read [F:TPV3]TPV0=[M:TPV1]PIVTYP;"POR"
      If !fstat
        If [M:TPV1]RECTYP <> [F:TPV3]RECTYP
          Call ECR_TRACE(func AFNC.MES2(mess(136,7711,1),[F:TPV3]PIVTYP,[F:TPV3]LEG),2) From GESECRAN
          OK = 0 : Return
        Endif
        If [M:TPV1]SAFTINVTYP <> [F:TPV3]SAFTINVTYP
          Call ECR_TRACE(func AFNC.MES2(mess(137,7711,1),[F:TPV3]PIVTYP,[F:TPV3]LEG),2) From GESECRAN
          OK = 0 : Return
        Endif
        If [M:TPV1]AUTINV <> [F:TPV3]AUTINV
          Call ECR_TRACE(func AFNC.MES2(mess(138,7711,1),[F:TPV3]PIVTYP,[F:TPV3]LEG),2) From GESECRAN
          OK = 0 : Return
        Endif
      Endif
    When "POR"
      Read [F:TPV3]TPV0=[M:TPV1]PIVTYP;""
      If !fstat
        If [M:TPV1]RECTYP <> [F:TPV3]RECTYP
          Call ECR_TRACE(func AFNC.MES2(mess(136,7711,1),[F:TPV3]PIVTYP,mess(59,151,1)),2) From GESECRAN
          OK = 0 : Return
        Endif
        If [M:TPV1]SAFTINVTYP <> [F:TPV3]SAFTINVTYP
          Call ECR_TRACE(func AFNC.MES2(mess(137,7711,1),[F:TPV3]PIVTYP,mess(59,151,1)),2) From GESECRAN
          OK = 0 : Return
        Endif
        If [M:TPV1]AUTINV <> [F:TPV3]AUTINV
          Call ECR_TRACE(func AFNC.MES2(mess(138,7711,1),[F:TPV3]PIVTYP,mess(59,151,1)),2) From GESECRAN
          OK = 0 : Return
        Endif
      Endif
  Endcase
Endif
