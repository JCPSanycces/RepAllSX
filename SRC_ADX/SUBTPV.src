#      #--CPO 71937 Déclinaison par législation
#      #Read [GTE] GTE0=[M:TPV1]GTE;[M:TPV1]LEG : If fstat  Raz [F:GTE] : Endif
#      Local Integer WRET
#      Call LEC_GTE_LEG([M:TPV1]LEG, [M:TPV1]GTE, WRET) From TRTLECLEG
#      If WRET  Raz [F:GTE] : Endif
#    Endif
#    If ([F:GTE]LEG<>"" | VALEUR="") & [F:GTE]LEG<>VALEUR
