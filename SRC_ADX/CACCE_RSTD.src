# Représentation CACCE

###########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
        When "AREAD_AFTER" : Gosub AREAD_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


##########################################################################################################
$AREAD_AFTER

# Title of Company/site/group
If this.CCE.FCY<>""
 Local File FACILITY [FCY]
 Call LEC_FCY(this.CCE.FCY) From CPTLEC
 If !fstat
  this.FCYDES=[F:FCY]FCYNAM
 Else
  Local File COMPANY [CPY]
  Call LEC_CPY(this.CCE.FCY) From CPTLEC
  If !fstat
   this.FCYDES=[F:CPY]CPYNAM
  Endif
 Endif
Endif

# Load the pyramids tab
Local File GCCEGRUPYM [CRY]
Local File GCCEPYM [CYM]
Local File ATEXTRA [AXX]
Local Integer NUMCUR
For [CRY] Where pat(this.CCE.CCE,[F:CRY]CCE)<>0
 fstat = 0
 If [F:CRY]PYM<>[F:CYM]PYM
  Read [CYM]CYM0=[F:CRY]PYM
 Endif
 If !fstat & [F:CYM]DIE = this.CCE.DIE
  NUMCUR = fmet this.ADDLINE("DISPYM",[V]CST_ALASTPOS)
  this.DISPYM(NUMCUR).PYM    = [F:CRY]PYM
  this.DISPYM(NUMCUR).GRU    = [F:CRY]GRU
  this.DISPYM(NUMCUR).LEV    = [F:CRY]LEV
  this.DISPYM(NUMCUR).PRNROW = [F:CRY]PRNROW
  Read [AXX]AXX0 = "GCCEPYM";"DESTRA";this.ACTX.LAN;[F:CRY]PYM;""
  If fstat=0
   this.DISPYM(NUMCUR).DESPYM = [F:AXX]TEXTE
  Endif
  Read [AXX]AXX0 = "GCCEGRUPYM";"DESTRA";this.ACTX.LAN;[F:CRY]PYM;[F:CRY]GRU
  If fstat=0
   this.DISPYM(NUMCUR).DESGRU = [F:AXX]TEXTE
  Endif
  If this.CCE.CCE<>[F:CRY]CCE
   this.DISPYM(NUMCUR).CRI   = [F:CRY]CCE
  Endif
 Endif
Next
Return

