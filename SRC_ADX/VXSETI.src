#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################
# Program Name: VXSETI
# Description : ADC Setup Start
# Author      : NA Development
# Date        : Mar 7, 2016
# Type        : ADCs Manufacturing
####################################################################################
$ACTION

Case ACTION
  When "OUVRE"         : Gosub OUVRE
  When "DEBUT"         : Gosub DEBUT
  When "OK"            : Gosub OK
Endcase

Return
####################################################################################
$OUVRE

  Global Char    GMTSNUM(GLONTRS) : GMTSNUM = GFLAG

  If !clalev([SFTX])  : Local File SFTTXN     [SFTX]  : Endif
  If !clalev([SFTH])  : Local File SFTTXNH    [SFTH]  : Endif
  If !clalev([F:MFG]) : Local File MFGHEAD    [MFG]   : Endif
  If !clalev([F:MFO]) : Local File MFGOPE     [MFO]   : Endif
  If !clalev([F:TMA]) : Local File TABMAT     [TMA]   : Endif
  If !clalev([SCH])   : Local File SCHEDULING [SCH]   : Endif
  If !clalev([MWS])   : Local File WORKSTATIO [MWS]   : Endif

Return
####################################################################################
$DEBUT

  Raz [M:VXSETI]
  Affzo [M:VXSETI]

Return
####################################################################################
Subprog C_EMPNUM(VALEUR)
Variable Decimal  VALEUR

  # Check if employee exist
  Read [TMA]TMA0=VALEUR
  If fstat
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(23,100,1)
    mkstat = 2
    End
  Endif

  EMPTYP =  [TMA]EMPTYP

  # Check if employee is active
  If func SFTLIB.EMPLOYEEACTIVE(VALEUR) = [V]CST_ANO
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(2,126,1)
    mkstat = 2
    End
  Endif

  Local Integer EMPLIST(1..)
  EMPLIST(1) = VALEUR
  Call TEAM_LIST (VALEUR, "A", EMPLIST) From SFTLIB
  [M:VXSETI]EMPLST = EMPLIST(1) #CT-1992

  #Check if an employee or team is on a break or on an exclusive indirect
  If func SFTLIB.EMPLOYEE_ON_BREAK(EMPLIST(1)) = [V]CST_AYES
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV

    #X3-1801 sn
    Case EMPTYP
      When 0,1 #Employee
        GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(18,2422,1)
      When 2 #Detail Team
        GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(122,2422,1)
      When 3 #Summary Team
        GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(121,2422,1)
    Endcase
    #X3-1801 en

    mkstat = 2
    End
  Endif

End
######################################################################################
Subprog AM_EMPNUM(VALEUR)
Variable Decimal VALEUR

  Raz [M:VXSETI]VCRNUM
  Call CLEAR_FIELDS

  #Get the employee default site (if it exists)
  Read [TMA]TMA0=VALEUR
  If !fstat
    # Default employee description and the site if populated
    [M:VXSETI]EMPDES = [F:TMA]EMPDES
    [M:VXSETI]FCY = [F:TMA]DEFFCY
    [M:VXSETI]EMPTYP = [F:TMA]EMPTYP
    Affzo [M:VXSETI]FCY, EMPDES
  Else    # Employee not found
    Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
    GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(23,100,1)
    mkstat = 2
    End
  Endif
End
######################################################################################
Subprog C_FCY(VALEUR)
Variable Char   VALEUR()

  Local Integer   EMP_LIST(1..)

  # Make sure the global variables and parameters are updated
  GFCY=VALEUR : Gosub CHARG_PARAM From SUBMTKA

  Local Char PARAMRET(4)
  Raz PARAMRET

  # check if clock in is needed for this site
  Call PARAM(VALEUR,"SFTEMPCLK",PARAMRET) From ADOVAL
  If val([L]PARAMRET) = [V]CST_AYES
    If [M:VXSETI]EMPTYP = 2
      #X3-1717 sn
      # Check if team members are clocked in or not on any individual activities
      Call TEAM_LIST ([M:VXSETI]EMPNUM, 'A', EMP_LIST) From SFTLIB
      If maxtab(EMP_LIST) = 0   # No team member found
        Call ERREUR(func AFNC.MES1(mess(110,2422,1), num$([M:VXSETI]EMPNUM))) From GESECRAN
        mkstat = 1
        End
      Endif
      #X3-1717 en
    Else #Detailed teams dont clock in
      If func SFTLIB.EMPLOYEE_CLOCKED_IN([M:VXSETI]EMPNUM) = [V]CST_ANO
        Call ERREUR(func AFNC.MES1(mess(12,2422,1), num$([M:VXSETI]EMPNUM))) From GESECRAN #CT-1797
        mkstat = 1
        End
      Endif
    Endif
  Elsif [M:VXSETI]EMPTYP = 2 #Detailed teams must be on sites that require clock-in
    GMESSAGE = func AFNC.MES1(mess(111,2422,1), "SFTEMPCLK")
    mkstat = 1
    End
  Endif

End
######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  Raz [M:VXSETI]VCRNUM
  Call CLEAR_FIELDS

End
######################################################################################
Subprog C_VCRNUM(VALEUR)
Variable Char    VALEUR()

  Call CLEAR_FIELDS

  Read [F:MFG]MFG0=VALEUR
  If !fstat
      #Work order does not exist at the site
      If [F:MFG]MFGFCY<>[M:VXSETI]FCY : Call ERREUR(mess(51,2422,1)) From GESECRAN  :  mkstat = 2 : End : Endif

      #This WO Status cannot be tracked
      If [F:MFG]MFGSTA<>1 : Call ERREUR(mess(19,190,1)) From GESECRAN  :  mkstat = 2 : End : Endif

      #This WO is suspended: tracking is not possible
      If [F:MFG]SUSFLG=2  : Call ERREUR(mess(180,190,1)) From GESECRAN :  mkstat = 2 : End : Endif

      #Allocation incomplete. Tracking not possible
      If GMTKALLMGT = [V]CST_AYES & !find([F:MFG]ALLSTA,3,5)  # Alloc status: 3-Complete; 5-Complete/Shortage
          Call ERREUR(mess(18,190,1)) From GESECRAN
          mkstat = 2
          End
      Endif

      #The WO is not printed: tracking not possible
      If [F:MFG]MFGTRKFLG < 3 & GDOSFAB = 2 : Call ERREUR(mess(20,190,1)) From GESECRAN : mkstat = 2 : End : Endif
  Else
      #Record does not exist
      Call ERREUR(mess(23,100,1)) From GESECRAN
      mkstat = 2
      End
  Endif

End
######################################################################################
Subprog C_OPENUM(VALEUR)
Variable Decimal VALEUR
  Local Integer OPERPREC, ALLOW_IT

  # Verify the operation is running
  Filter [F:SFTX] Where EMPNUM = [M:VXSETI]EMPLST &
&                       find(SFTTYP, 4, 5) &
&                       VCRNUM = [M:VXSETI]VCRNUM &
&                       OPENUM = VALEUR &
&                       UTCENDDATTIM = AVOID.ADATTIM #CT-1992
  Read [F:SFTX] First
  Filter [F:SFTX]
  If fstat = 0     # Record found
    GERR=1
    If [F:SFTX]SFTTYP = 4         # Setup
      GMESSAGE = mess(83,2422,1)
    Else                          # Run
      GMESSAGE = mess(85,2422,1)
    Endif
    mkstat = 2
    End
  Endif

  # Verify the operation complete
  Filter [F:SFTX] Where [F:SFTX]VCRNUM = [M:VXSETI]VCRNUM &
&                       [F:SFTX]OPENUM = VALEUR &
&                       [F:SFTX]CLEFLG = [V]CST_AYES
  Look [F:SFTX] First
  Filter [F:SFTX]
  If fstat = 0  # Found
    GERR=1 : GMESSAGE = mess(84,2422,1)   # Operation closed
    mkstat = 2
    End
  Endif



  # Valid operation?
  If [M:VXSETI]VCRNUM <> AVOID.ACHAR
    Filter [MFO] Where MFGNUM = [M:VXSETI]VCRNUM & OPENUM = VALEUR
    Read [MFO]MFO0 First
    Filter [MFO]
    If !fstat
      #Operation status cannot be closed, excluded, or ordered
      If [F:MFO]OPESTA >= 5 : Call ERREUR(mess(50,2422,1)) From GESECRAN  :  mkstat = 2 : End : Endif

      #Work center type cannot be subcontract
      If [F:MFO]EXTWST <> AVOID.ACHAR
        Read [MWS]WST0 = [F:MFO]EXTWST;[M:VXSETI]FCY
        If !fstat
          If [F:MWS]WSTTYP = 3
            Call ERREUR(mess(52,2422,1)) From GESECRAN
            mkstat = 2
            End
          Endif
        Endif
      Endif

      #Labor center type cannot be subcontract
      If [F:MFO]EXTLAB <> AVOID.ACHAR
        Read [MWS]WST0=[F:MFO]EXTLAB;[M:VXSETI]FCY
        If !fstat
          If [F:MWS]WSTTYP=3
            Call ERREUR(mess(55,2422,1)) From GESECRAN
            mkstat = 2
            End
          Endif
        Endif
      Endif

      # 53701 - JOBRO
      # See if they can start this based on the type of employee and
      # if someone already started it
      If func SFTLIB.CAN_START_OPERATION([M:VXSETI]EMPTYP, [M:VXSETI]EMPNUM, 4, [M:VXSETI]VCRNUM, VALEUR) = [V]CST_ANO
        GERR=1
        If [M:VXSETI]EMPTYP = 1
          GMESSAGE = mess(1,7727,1) # Employee cannot join an operation already started by a team
        Else
          GMESSAGE = mess(2,7727,1) # Team cannot join an operation already started
        Endif
        mkstat = 2 : End
      Endif
      # 53701 - JOBRO

      #Invalid if GCTLOPEPRE = 3 and prior operation has not been run.
      If GCTLOPEPRE > 1
        OPERPREC = 0
        # Find the prior operation number
        Filter [SCH] Where MFGNUM = [M:VXSETI]VCRNUM & NEXOPENUM = VALEUR
        Read [SCH]SCH0 First
        Filter [SCH]
        If !fstat : OPERPREC = [F:SCH]OPENUM : Endif
        If OPERPREC<>0
          # Check if prior marked complete in MFG Operations table
           Filter [MFO] Where MFGNUM = [M:VXSETI]VCRNUM & OPENUM = OPERPREC
           Read [MFO]MFO0 First
           Filter [MFO]
           If !fstat & [F:MFO]OPESTA < 5
             # This operation is not closed in the MFG tables - see if closed in SFTTXN tables
             Filter [F:SFTX] Where [F:SFTX]VCRNUM = [M:VXSETI]VCRNUM &
&                                      [F:SFTX]OPENUM = OPERPREC &
&                                      [F:SFTX]CLEFLG = [V]CST_AYES
             Read [F:SFTX]SFT0 First
             Filter [F:SFTX]
             If fstat <> 0
               ALLOW_IT = [V]CST_ANO
               If GCTLOPEPRE=2
                 Call AVERTIR(mess(22,190,1)-num$([L]OPERPREC),ALLOW_IT) From GESECRAN
               Else
                 Call ERREUR(mess(22,190,1)-num$([L]OPERPREC)) From GESECRAN
               Endif
               If ALLOW_IT=[V]CST_ANO : mkstat = 2 : End : Endif
             Endif
           Endif
         Endif
      Endif
    Else
       #Invalid Operation
      Call ERREUR(mess(58,123,1)) From GESECRAN
      mkstat = 2
      End
    Endif
  Endif
End
######################################################################################
Subprog AM_OPENUM(VALEUR)
Variable Decimal VALEUR

  #Default work center and labor center from the work order
  If [M:VXSETI]VCRNUM <> AVOID.ACHAR & VALEUR <> 0
    Filter [MFO] Where MFGNUM = [M:VXSETI]VCRNUM & OPENUM = VALEUR
    Read [MFO]MFO0 First
    Filter [MFO]
    If !fstat
      [M:VXSETI]WCENTER   = [F:MFO]EXTWST
      If [F:MFO]EXTLAB <> AVOID.ACHAR
        Actzo [M:VXSETI]LCENTER
        [M:VXSETI]LCENTER   = [F:MFO]EXTLAB
      Else
        Raz [M:VXSETI]LCENTER
        Grizo [M:VXSETI]LCENTER
      Endif
#      [M:VXSETI]NUMMAC    = [F:MFO]EXTWSTNBR  # Expected machines    # TODAN-119090
      [M:VXSETI]OPEUOM    = [F:MFO]OPEUOM     # Operation unit
    Endif
  Endif

  # Read Work centers table to get the work center type
  Read [F:MWS]WST0 = [F:MFO]EXTWST;[M:VXSETI]FCY

  # Get the changed WC & LC from the SFT transaction table
  Call GET_SFT_WC_LC([M:VXSETI]VCRNUM, VALEUR, [F:MWS]WSTTYP, [F:MFO]EXTWST,
&                    [F:MFO]EXTLAB, [M:VXSETI]WCENTER, [M:VXSETI]LCENTER) From SFTLIB

  #---------------------------------------------------------------
  # If someone else has this operation running at the same
  # workstation default NUMMAC to unchecked...
  #---------------------------------------------------------------
  # TODAN-119090.so
  # Assign Work center type
  [M:VXSETI]WSTTYP = [F:MWS]WSTTYP

  # Machine type...check if the operation already run
  If [F:MWS]WSTTYP = 1
    [M:VXSETI]NUMMAC = [V]CST_AYES  #53701.n - JOBRO
# 53701
#    If func SFTLIB.OPERATION_RUN([M:VXSETI]VCRNUM, VALEUR, [M:VXSETI]WCENTER) = [V]CST_ANO
#      [M:VXSETI]NUMMAC = [V]CST_AYES
#    Else    # Yes, this operation already running...
#      If [M:VXSETI]LCENTER = AVOID.ACHAR    # If this is Machine only, default to Yes
#        [M:VXSETI]NUMMAC = [V]CST_AYES
#      Else
#        [M:VXSETI]NUMMAC = [V]CST_ANO
#      Endif
#    Endif
#    Actzo [M:VXSETI]NUMMAC
# 53701
  Else    # Labor type
    [M:VXSETI]NUMMAC = [V]CST_ANO
#    Grizo [M:VXSETI]NUMMAC           #53701
  Endif
  # TODAN-119090.eo

  Affzo [M:VXSETI]WCENTER, LCENTER, NUMMAC, OPEUOM, WSTTYP
End
######################################################################################
# TODAN-119090.so
Subprog C_NUMMAC(VALEUR)
Variable Integer VALEUR

  # Get out if the Machine included is checked.
  # The only time the Machine included is manually checked when the machine/labor operation
  # already been run so the the Machine included option is unchecked when loaded
  If VALEUR = [V]CST_AYES : End : Endif

  # Get out if the work center is not machine type.
  If [M:VXSETI]WSTTYP <> 1 : End : Endif

  # If it come to here that mean the Machine included option is unchecked and
  # the work center is machine type.

  # Machine only operation require Machine included and for the machine/labor operation
  # that has not been run yet the Machine included also require.
  If [M:VXSETI]LCENTER = AVOID.ACHAR |
&     func SFTLIB.OPERATION_RUN([M:VXSETI]VCRNUM, [M:VXSETI]OPENUM, [M:VXSETI]WCENTER) = [V]CST_ANO

    Call ERREUR(mess(30,2422,1)) From GESECRAN
    mkstat = 2
    End

  Endif

End
# TODAN-119090.eo
######################################################################################
Subprog C_WCENTER(VALEUR)
Variable Char    VALEUR()

  Read [MWS]WST0 = VALEUR; [M:VXSETI]FCY
  If fstat
    GERR=1 : GMESSAGE = VALEUR - tolower(mess(196,193,1))
    mkstat = 2
    End
  Else
    If [F:MWS]WSTTYP <> [M:VXSETI]WSTTYP
      #CT-1797.sn
      #GERR=1 : GMESSAGE = VALEUR - mess(47,2422,1) : mkstat=2 : End
      Call ERREUR(func AFNC.MES1(mess(47,2422,1), VALEUR)) From GESECRAN
      mkstat = 2
      End
      #CT-1797.en
    Endif
  Endif

End
######################################################################################
Subprog C_LCENTER(VALEUR)
Variable Char    VALEUR()

  If VALEUR = AVOID.ACHAR & [M:VXSETI]LCENTER <> AVOID.ACHAR
    GERR=1 : GMESSAGE = mess(48,2422,1) : mkstat = 2 : End
  Endif

  If VALEUR <> AVOID.ACHAR & [M:VXSETI]LCENTER <> AVOID.ACHAR
    If VALEUR = [M:VXSETI]WCENTER : GERR=1 : GMESSAGE=mess(26,193,1) : mkstat=2 : End : Endif
    Read [MWS]WST0 = VALEUR; [M:VXSETI]FCY
    If fstat
      GERR=1 : GMESSAGE = VALEUR - tolower(mess(44,2422,1))
      mkstat=2
      End
    Else
      If [F:MWS]WSTTYP <> 2
         GERR=1 : GMESSAGE = VALEUR - mess(4,193,1) : mkstat = 2 : End
      Endif
    Endif
  Endif
End
######################################################################################
Subprog CLEAR_FIELDS

  Raz [M:VXSETI]OPENUM, NUMMAC, WCENTER, LCENTER
  Affzo [M:VXSETI]OPENUM, NUMMAC, WCENTER, LCENTER
End
######################################################################################
$OK

  Local Char      START_WONUM(20)(1..1), START_WCENTER(8)(1..1), START_LCENTER(8)(1..1), START_OPEUOM(3)(1..1)
  Local Integer   START_OPENUM(1..1), START_NUMMAC(1..1)
  Local Integer   START_COUNT, OPTYPE, ISTOP, RESTART_COUNT
  Local Datetime  STARTTIME
  Local Integer   MY_STATUS
  Local Char      STRYEAR(4), STRMONTH(2), STRDAY(2), STRHOUR(2), STRMIN(2)
  Local Integer   EMPTEAMNUM
  Local Char      ERRMSG(125)
  Local Integer   ERRNUM
  Local Integer   YESNO : YESNO = [V]CST_AYES
  Local Date ODATE
  Local Char OTIME(5)

  # Variables to pass to class method that we don't need
  Local Integer   ISTOP : ISTOP   = [V]CST_ANO

  # Initialization
  OPTYPE = 4              # Setup start operation
  START_COUNT = 0
  STARTTIME    = datetime$

  # Add the record to a collection
  START_COUNT += 1
  START_WONUM(START_COUNT)          = [M:VXSETI]VCRNUM
  START_OPENUM(START_COUNT)         = [M:VXSETI]OPENUM
  START_NUMMAC(START_COUNT)         = [M:VXSETI]NUMMAC
  START_WCENTER(START_COUNT)        = [M:VXSETI]WCENTER
  START_LCENTER(START_COUNT)        = [M:VXSETI]LCENTER
  START_OPEUOM(START_COUNT)         = [M:VXSETI]OPEUOM

  # Skip machine only operation but include machine/labor, labor only and labor and labor operations to increase # of activities.
  If [M:VXSETI]LCENTER <> AVOID.ACHAR or [M:VXSETI]NUMMAC = [V]CST_ANO    # TODAN-119090
#  If [M:VXSETI]LCENTER <> "" or [M:VXSETI]NUMMAC = 0
    RESTART_COUNT += 1
  Endif

  If !clalev([SFTXNS]) : Local File SFTTXN [SFTXNS] : Endif

  # Check if employee is in a team and if he has any team activities running
  Call EMP_TEAM_NUM ([M:VXSETI]EMPNUM, EMPTEAMNUM) From SFTLIB
  If EMPTEAMNUM <> 0   # Employee is part of the team
    Filter [F:SFTXNS] Where (EMPNUM = [M:VXSETI]EMPNUM & TEAMNUM = EMPTEAMNUM) &
&                            SFTTYP <> 1 & UTCENDDATTIM = AVOID.ADATTIM
    Look [F:SFTXNS] First
    If fstat = 0    # Found open team activities...
      Call OUINON(mess(107,2422,1), YESNO) From GESECRAN    # Employee has open activities on a team. Do you want to stop all of the employee’s activities?
      If YESNO <> [V]CST_AYES    # No
        mkstat = 2
        Return
      Endif

      # Stop open activities...
      Call STOP_OPEN_ACTIVITIES(EMPTEAMNUM, [M:VXSETI]EMPNUM, ERRNUM, ERRMSG) From SFTLIB
      If ERRNUM
        GERR=1 : GMESSAGE = ERRMSG
        mkstat = 2
        Return
      Endif
    Endif
  Endif

  # 53701 - JOBRO - determine what the true value for NUMMAC should be
  START_NUMMAC(START_COUNT) = func SFTLIB.START_MACHINE([M:VXSETI]EMPTYP,
&   [M:VXSETI]EMPNUM,OPTYPE,START_WONUM(START_COUNT),START_OPENUM(START_COUNT),
&   START_WCENTER(START_COUNT),START_LCENTER(START_COUNT),[M:VXSETI]FCY)
  # 53701 - JOBRO

  Local Instance SFTTXN Using C_SFTTXN
  SFTTXN = NewInstance C_SFTTXN AllocGroup null

  # Start the setup operation(s)
  If fmet SFTTXN.OPERATION_START([M:VXSETI]EMPNUM, [M:VXSETI]FCY, [M:VXSETI]EMPTYP, OPTYPE, STARTTIME,
&                                          START_WONUM, START_OPENUM, START_NUMMAC, START_WCENTER, START_LCENTER,
&                                          START_OPEUOM, ISTOP, START_COUNT, RESTART_COUNT)  <> [V]CST_AOK
    Call ERREUR(func AFNC.MES1(mess(10,2422,1),tolower(mess(4,2416,1)))) From GESECRAN
    Return
  Endif

  FreeGroup SFTTXN

  # display confirmation message
  Call TIMESTAMP([M:VXSETI]FCY, ODATE, OTIME) From SFTLIB
  Call MESSAGE(func AFNC.MES2(mess(77,2422,1), [M:VXSETI]VCRNUM+" "+num$([M:VXSETI]OPENUM), left$(OTIME,2) + ":" + right$(OTIME,3))) From GESECRAN

  LogicClose File [SFTXNS]

Return
####################################################################################

