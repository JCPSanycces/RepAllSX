#<AdxTL>@(#)7.0.0.0 $Revision$
GBIDC1 = ""
Call IMPORTATION(GBIDC1)
End

#######################################################
Subprog IMPORTATION(MODL)
Value Char MODL
Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = MODL
Call TRAITE_CHAR(VALEUR,PARAM,"","GIMPOBJ","DIMPOBJ",4,"XYGIMPOBJ") From GTRAITE
End

#######################################################
$ACTION
Case ACTION
 When "INIT"         : Gosub INIT
 When "DEBUT"        : Gosub DEBUT
 When "CONTROLE"     : Gosub CONTROLE
 When "EXEC"         : Gosub EXEC
 When "TERMINE"      : Gosub TERMINE
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON_SAI
 When "SETBOUT"      : Gosub SETBOUT_SAI
 When "BOUTON"       : Gosub BOUTON_SAI
 When "OK"           : Gosub OK_SAI
 When "OUVRE_BATCH"  : Gosub OUVRE
 When Default
Endcase
Return

#######################################################
$AVANT_BOUTON_SAI
[M:IMP2] = [M:DIA]
Return

#######################################################
$SETBOUT_SAI
Local Char AUZ(23)
Call DROITSITE("",AUZ,OK) From EXEFNC
If !OK | !instr(1,AUZ,"T")
 Call VIREBOUT(CHMEN,"1") From GOBJET
Endif
Return

#######################################################
$BOUTON_SAI
Case BOUT
 When "1" : # Traitement
  FIN = 1
 When "2" : # Test
Endcase
Return

#######################################################
$OK_SAI
[M:IMP2]OKIMP = 1
Return

#######################################################
$INIT
Local Char TIT(50)
If PARAM(1)="***"
 FIN = 1 : Return
Endif
TIT  = mess(52,141,1) : # Importation
Gosub OUVRE
Local Mask IMPOBJ [DIA]
Raz [M:DIA]
Raz [M:IMP2]
Return

#######################################################
$DEBUT
[M:DIA]MODIMP = PARAM(1)
If [M:DIA]MODIMP<>""
 Call C_MODIMP([M:DIA]MODIMP)
 If mkstat
  GERR = 1 : FIN = 1 : Return
 Else
  Call AM_MODIMP([M:DIA]MODIMP)
  If mkstat : FIN = 1 : Return : Endif
 Endif
 Grizo [M:DIA]MODIMP
Else
 Call GET_DERLU([M:DIA]MODIMP,"AOE","ENAFLG=2 & IMPORT=2") From GOBJACT
 If [M:DIA]MODIMP<>""
  Call C_MODIMP([M:DIA]MODIMP)
  If mkstat
   [M:DIA]MODIMP = "" : Return
  Else
   Call CHARGE([M:DIA]MODIMP,K)
   If K : [M:DIA]MODIMP = "" : Return : Endif
  Endif
 Endif
Endif
Return

#######################################################
$OUVRE
If clalev([F:AOE])=0  : Local File AOBJEXT    [AOE]  : Endif
If clalev([F:AOD])=0  : Local File AOBJEXTD   [AOD]  : Endif
If clalev([F:APX])=0  : Local File APARIMPEXP [APX]  : Endif
If clalev([F:AOR])=0  : Local File AOBJEXTR   [AOR]  : Endif

If clalev([F:ACC_])=0 : Local File ACCES      [ACC_] : Endif
If clalev([F:AOB_])=0 : Local File AOBJET     [AOB_] : Endif
If clalev([F:AWI_])=0 : Local File AWINDOW    [AWI_] : Endif
If clalev([F:ATY_])=0 : Local File ATYPE      [ATY_] : Endif
If clalev([F:AMK_])=0 : Local File AMSK       [AMK_] : Endif
If clalev([F:AMZ_])=0 : Local File AMSKZON    [AMZ_] : Endif
If clalev([F:ATB_])=0 : Local File ATABLE     [ATB_] : Endif
If clalev([F:ATZ_])=0 : Local File ATABZON    [ATZ_] : Endif
If clalev([F:ATI_])=0 : Local File ATABIND    [ATI_] : Endif
If clalev([F:AMP_])=0 : Local File AMSKPAR    [AMP_] : Endif
If clalev([F:AFC_])=0 : Local File AFONCTION  [AFC_] : Endif
If clalev([F:ACV_])=0 : Local File ACTIV      [ACV_] : Endif
If clalev([F:ANM_])=0 : Local File ACODNUM    [ANM_] : Endif

If clalev([M:AOE0])=0 : Local Mask AOE0       [AOE0] : Endif
If clalev([M:AOE1])=0 : Local Mask AOE1       [AOE1] : Endif
If clalev([M:AOE2])=0 : Local Mask AOE2       [AOE2] : Endif
If clalev([M:IEX])=0  : Local Mask IMPTEST    [IEX]  : Endif
If clalev([M:IMP2])=0 : Local Mask IMPOBJ2    [IMP2] : Endif
Return

#######################################################
$CONTROLE
TIT -= [M:DIA]MODIMP
If GSERVEUR
 [M:IMP2] = [M:DIA]
Elsif [M:IMP2]OKIMP
 [M:IMP2] = [M:DIA]
 TMP = 1
Else
 FIN = 1
Endif
Call SET_DERLU("AOE",[M:DIA]MODIMP+'~') From GOBJACT
Return

#######################################################
$EXEC
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call IMPORTSIL([M:IMP2]MODIMP,[M:IMP2]NOMIMP)

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

###############################################################
$TERMINE
If !GSERVEUR
 TRA = 1
Else
 TRA = 0
Endif
Return

##############################################################################
## Import "silencieux"                                                      ##
## Les paramètres MODELE et FICHIER sont conservés à cause de l'historique  ##
## de ce sous-programme                                                     ##
##############################################################################

Subprog IMPORTSIL(MODELE,FICHIER)
Value Char MODELE, FICHIER
#Start X3-88439 - may need to be declared larger for misc tables
If dim(GLONADI)>0 and GLONADI>15
  Local    Char    PARAM(GLONADI)(1..4) , VALEUR(GLONADI)
Else
  Local    Char    PARAM(15)(1..4) , VALEUR(15)
Endif
#End X3-88439
If clalev([M:IMP2])=0 : Local Mask IMPOBJ2 [IMP2] : Endif
[M:IMP2]MODIMP = MODELE
If [M:IMP2]TYPEXP=0
 If left$(FICHIER,2)="#@"
  [M:IMP2]TYPEXP = 1
  [M:IMP2]NOMIMP = right$(FICHIER,3)
 Else
  [M:IMP2]TYPEXP = 2
  [M:IMP2]NOMIMP = FICHIER
 Endif
Else
 [M:IMP2]NOMIMP = FICHIER
Endif
Call WORKFLOW(8,MODELE,"ID","") From AWRK
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTIMPOBJ","",4,"XYTRTIMPOBJ") From GTRAITE
Call WORKFLOW(8,MODELE,"IF","") From AWRK
End

###########################################################
Subprog ERR_IMPORT(IMPSTA,MESSAGE)
Value Integer IMPSTA
Variable Char MESSAGE()
Case IMPSTA
 When 1  : MESSAGE = GBIDC3+"\"+mess(30,141,1)                     : # Modèle inexistant
 When 2  : MESSAGE = "|"+GBIDC3+"|\"+mess(101,100,1)               : # Fichier inexistant
 When 3  : MESSAGE = mess(12,141,1)                                : # Importation impossible sur fichier
 When 5  : MESSAGE = "|"+GBIDC3+"|\"+mess(9,141,1)                 : # Répertoire inexistant
 When 6  : MESSAGE = mess(30,100,1)                                : # En cours autre poste
 When 7  : MESSAGE = mess(62,141,1)                                : # Erreur système (valtrt)
 When 8  : MESSAGE = mess(63,141,1)-num$(GERREUR)                  : # Erreur système (prog exp/imp)
 When 9  : MESSAGE = GBIDC3+"\"+mess(41,100,1)                     : # Champ inexistant
 When 10 : MESSAGE = mess(65,141,1)                                : # Import impossible (lien)
 When 13 : MESSAGE = mess(72,141,1)-":"+GMESSAGE                   : # Modèle incorrect
 When 14 : MESSAGE = mess(97,141,1)+"\|"+GBIDC3+"|\"+mess(2,126,1) : # Modèle export-import, Fiche inactive
 When 15 : MESSAGE = "|"+GBIDC3+"|\"+mess(1,123,1)                 : # Fonction non autorisée
 When 16 : MESSAGE = "|"+GBIDC3+"|\"+mess(123,141,1)               : # Pas les droits pour créer ou modifier
 When 17 : MESSAGE = "|"+GBIDC3+"|\"+mess(49,125,1)                : # Erreur de lecture
 When 18 : MESSAGE = GBIDC3+"\"+mess(109,141,1)                    : # Import impossible sur ce modèle
 When 19 : MESSAGE = "|"+GBIDC3+"|\"+mess(167,141,1)               : # Fichier non copié sur le serveur
 When 20 : MESSAGE = "|"+GBIDC3+"|\"+mess(35,126,1)                : # Nom de fichier incorrect
 When 21 : MESSAGE = mess(178,141,1)                               : # Traitement inexistant (obligatoire pour un import spécial)
 When 100 : MESSAGE = GMESSAGE                                     : # X3-43015 : Keep GMESSAGE which can be set by a function
Endcase
End

#################################################################
Subprog CHARGE_MODELE(MODELE,IMPSTA)
Variable Char    MODELE()
Variable Integer IMPSTA
Local Integer    OK , I, J
IMPSTA = 0
Read [AOE]AOE0 = MODELE
If fstat               : IMPSTA = 1  : GBIDC3 = MODELE : End
Elsif [F:AOE]ENAFLG<>2 : IMPSTA = 14 : GBIDC3 = MODELE : End
Elsif [F:AOE]IMPORT<>2 : IMPSTA = 18 : GBIDC3 = MODELE : End
Endif
Raz [M:AOE0], [AOE1], [AOE2]
[M:AOE0] = [F:AOE]
[M:AOE1] = [F:AOE]
[M:AOE2] = [F:AOE]
[M:IMP2]MODIMP = [F:AOE]EXT
If [F:AOE]AOWSTA = 2
 [M:IMP2]AOWSTA = 2
Else
 [M:IMP2]AOWSTA = 0
Endif
Raz [M:IMP2]FICHIER, [M:IMP2]NBFIC
nolign = 0
For [AOD]AOD0 Where EXT=[M:AOE0]EXT
 nolign += 1
 [M:AOE2] = [F:AOD]
 If [F:ATB_]CODFIC<>[F:AOD]FIL
  Read [ATB_]CODFIC = [F:AOD]FIL
 Endif
 [M:AOE2]ZONE(nolign-1) = [F:ATB_]ABRFIC-[M:AOE2]FLD(nolign-1)
 If find([F:AOD]FIL,[M:IMP2]FICHIER(0..[M:IMP2]NBFIC-1))=0
  [M:IMP2]FICHIER([M:IMP2]NBFIC) = [F:AOD]FIL
  [M:IMP2]ABREV([M:IMP2]NBFIC)   = [F:ATB_]ABRFIC
  [M:IMP2]FLG([M:IMP2]NBFIC)     = [F:AOD]TYP
  [M:IMP2]NBFIC += 1
 Endif
Next
Raz [M:IMP2]SEPNBZ, [M:IMP2]SEPREC, [M:IMP2]SEPLOC
For J=0 To dim([M:AOE1]FLGREC)-1
 [M:IMP2]SEPREC(J) = [M:AOE1]FLGREC(J)
 If [M:IMP2]SEPREC(J)<>"" | J=0
  K = find([M:IMP2]SEPREC(J),[M:AOE2]TYP(0..[M:AOE2]NBRLIG-1))-1
  For I=0 To [M:AOE2]NBRLIG-1
   If [M:AOE2]TYP(I)=[M:IMP2]SEPREC(J)
    If [M:IMP2]SEPREC(0)=""
     [M:IMP2]SEPLOC(0) = 1
    Elsif [M:AOE2]FLD(I)="/"
     [M:IMP2]SEPLOC(J) = I+1-K
    Endif
    If [M:AOE2]SEL(I)<>3
     [M:IMP2]SEPNBZ(J) += 1
    Endif
   Endif
  Next I
 Endif
Next J
Default Mask [AOE2]
mkstat = 0
Call CONTROLE From SUBAOE
If mkstat
 GMESSAGE = MODELE+"\"+GMESSAGE : IMPSTA = 13
Endif
End

####################################################
## Etiquettes de l'écran IMPOBJ                   ##
####################################################
Subprog IB_MODIMP
If GADONIX<>2
 GBOUT2 = ""
Endif
End

Subprog C_MODIMP(VALEUR)
Variable Char VALEUR()
Call CONTROLE("AOE","",VALEUR,"",mkstat) From CONTOBJ
If mkstat : End : Endif
Call CONTEXE([F:AOE]ACS) From SUBACS
If mkstat : End : Endif
If [F:AOE]IMPORT<>2
 GMESSAGE = mess(109,141,1) : # Import impossible sur ce modèle
 mkstat = 1 : End
Endif
End

Subprog AM_MODIMP(VALEUR)
Variable Char VALEUR()
Local Integer IMPSTA
Local Char    MESSAGE(250)
Call CHARGE(VALEUR,IMPSTA)
If IMPSTA
 Call ERR_IMPORT(IMPSTA,MESSAGE)
 Call ERREUR(MESSAGE) From GESECRAN
 GMESSAGE = "" : mkstat=2 : End
Endif
End

Subprog CHARGE(MODELE,IMPSTA)
Value Char MODELE
Variable Integer IMPSTA

Local Integer TYPEXP
TYPEXP = [M:IMP2]TYPEXP

Call CHARGE_MODELE(MODELE,IMPSTA) From GIMPOBJ
If IMPSTA : End : Endif

If GBATCH
 [M:IMP2]TYPEXP = 2
Else
 [M:IMP2]TYPEXP = [F:AOE]TYPEXP
Endif
If GOS(1)="unix" & !GBATCH
 If left$([F:AOE]FILEXT,2)="#@"
  [M:IMP2]TYPEXP = 1
  [M:IMP2]NOMIMP = right$([M:IMP2]NOMIMP,3)
 Elsif left$([M:IMP2]NOMIMP,2)="#" or pat(left$([M:IMP2]NOMIMP,3),"!:\")
  [M:IMP2]TYPEXP = 1
 Endif
Endif
Call SET_NOMFIC([F:AOE]FILEXT,[M:IMP2]NOMIMP,[M:IMP2]TYPEXP)
[M:DIA] = [M:IMP2]
# 121621-Import default path not proposed automatically - start
If [F:AOE]TYPEXP=2            # Server import
  [M:DIA]VOLFIL=[M:IMP2]NOMIMP
Endif
# 121621-Import default path not proposed automatically - end
Affzo
If [M:DIA]TYPEXP=1
 Grizo NOMIMP
Else
 Actzo NOMIMP
Endif
If [M:IMP2]AOWSTA = 2
 [M:DIA]AOWSTA = 2
 Actzo [M:DIA]AOWSTA
Else
 [M:DIA]AOWSTA = 0
 Grizo [M:DIA]AOWSTA
Endif

If TYPEXP <> [M:IMP2]TYPEXP :  Call AM_TYPEXP([M:IMP2]TYPEXP) : Endif

End

Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat = 2 : End
Endif
End

Subprog AM_AOWSTA(VALEUR)
Variable Integer VALEUR
[M:IMP2]AOWSTA = VALEUR
End


Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR

Local Integer ASTATUS

If VALEUR=1
 Raz [M]VOLFIL    # 121621-Import default path not proposed automatically
 Grizo [M]VOLFIL
Else
 # 121621-Import default path not proposed automatically - start
 If [M]VOLFIL="" & [M:IMP2]NOMIMP<>""
  [M]VOLFIL = [M:IMP2]NOMIMP
 Endif
 # 121621-Import default path not proposed automatically - end
 Actzo [M]VOLFIL
Endif
Affzo [M]VOLFIL
End

Subprog AS_NOMIMP(VALEUR)
Variable Char VALEUR()
End

Subprog SET_NOMFIC(FICHIER,NOMIMP,TYPEXP)
Value Char FICHIER
Variable Char NOMIMP
Value Integer TYPEXP
Local Char    FICSRV(GDIMFIC) , URL(GDIMFIC)
Local Char    REPERT(GDIMFIC) , MACHINE(GDIMFIC)
Local Char    SREPERT(GDIMFIC)
NOMIMP = FICHIER

If TYPEXP=1
 Call SET_NAMCLI(NOMIMP) From ORDSYS
# Issue X3-58598 - 2018-07-24 by ALSHE : Don't determine default path from GIMPEXPPAR if NOMIMP conatains already path
Elsif !instr(1,NOMIMP,"@") & !find(left$(NOMIMP,1),"/") & !pat(left$(NOMIMP,3),"!:\") & !find(left$(NOMIMP,1),"[")
 Call GETREP("REPIMPDEF",REPERT) From SUBEXPOBJ
 If REPERT<>""
  SREPERT = REPERT
  Call MACHINE(REPERT,MACHINE,REPERT) From ORDSYS
  If FICHIER <>""
    Call SETFIC(REPERT,FICHIER,MACHINE,NOMIMP) From SUBEXPOBJ
    # Issue X3-58598 - 2018-07-24 by ALSHE : Set NOMIMP back from full path to X3 path even if no value returned from SETFIC
    NOMIMP = SREPERT + '/' + FICHIER
  Else
    NOMIMP = SREPERT
  Endif
 Endif
 # End issue X3-58598
Endif
End

Subprog C_NOMIMP(VALEUR)
Variable Char VALEUR()
Local Char NOMFIC(GDIMFIC)
NOMFIC = VALEUR
Gosub CONTFIC
End

$CONTFIC
Local Char    NAM(GDIMFIC) , SUF(30)
Local Integer ER, I
Local Char    REPERT(GDIMFIC)
Local Char    MACHINE(GDIMFIC) , OS(GDIMFIC)
If NOMFIC=""
 GMESSAGE = mess(35,126,1) : # Nom de fichier incorrect
 mkstat=1 : Return
Elsif left$(NOMFIC,1)="#"
 GMESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
 mkstat = 2 : Return
Elsif instr(1,NOMFIC,"#")
 Return
Endif
Call MACHINE(NOMFIC,MACHINE,REPERT) From ORDSYS
Call GET_OS(MACHINE,OS) From ORDSYS
If OS=""
 GMESSAGE = MACHINE-mess(90,141,1) : # Machine inexistante
 mkstat = 2 : Return
Elsif OS="unix"
 If pat(left$(REPERT,3),"!:\")
  GMESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
  mkstat = 2 : Return
 Elsif left$(REPERT,1)="\"
  GMESSAGE = mess(147,141,1) : # Répertoire inaccessible
  mkstat = 2 : Return
 Endif
Else
 If left$(REPERT,1)="/"
  GMESSAGE = mess(147,141,1) : # Répertoire inaccessible
  mkstat = 2 : Return
 Endif
Endif
Call EXISTE(NOMFIC,ER) From ORDSYS
Case ER
 When 2
  GMESSAGE = mess(55,141,1) : # Ce fichier est un répertoire
  mkstat = 2 : Return
 When 0
  GMESSAGE = mess(03,141,1) : # Fichier à importer inexistant
  mkstat = 2 : Return
Endcase
Return


######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran IMPOBJ) 17/09/2013 13:25:04 (ERB)
######################################################################################
Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()

#control de la valeur [espace]chemin relatif
#calcul du chemin absolu
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
# Issue X3-43015 - 2017-06-20 by CCC : when entering parameters for batch process, just check that path is a file
If GBATCH
    mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP, VALEUR,[M]NOMIMP,E_TYPE_FILEOVERWRITE,GMESSAGE)
Else
    mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP, VALEUR,[M]NOMIMP,E_TYPE_FILEREAD,GMESSAGE)
Endif

End



