$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EMPLORIB
Gosub _ALOADATTRIBUTE_REFNUM From WMC1EMPLORIB : Gosub TESTALLSTAT
Gosub _ALOADATTRIBUTE_NUMLIG From WMC1EMPLORIB : Gosub TESTALLSTAT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EMPLORIB
Gosub LNKPRO_REFNUM From WMC1EMPLORIB : Gosub TESTALLSTAT
Gosub LNKPRO_BIDNUM From WMC1EMPLORIB : Gosub TESTALLSTAT
