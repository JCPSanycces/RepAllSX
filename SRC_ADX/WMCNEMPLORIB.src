####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0EMPLORIB
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_REFNUM From WMC1EMPLORIB : Gosub TESTALLSTAT
Gosub INIT_NUMLIG From WMC1EMPLORIB : Gosub TESTALLSTAT
Gosub INIT_BIDNUM From WMC1EMPLORIB : Gosub TESTALLSTAT
Gosub INIT_PAB1 From WMC1EMPLORIB : Gosub TESTALLSTAT
