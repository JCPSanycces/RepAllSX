#<AdxTL>@(#)1.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
PARAM(1) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","SUBRPAINT","RPAINT",4,"SPERPAINT") From GTRAITE
End

# Gestion du masque RPAINT
$ACTION
#Infbox "ACTION="+ACTION
Case ACTION
 When "OUVRE_BATCH"  : Gosub OUVRE : #entrée en Batch
 When "INIT"         : Gosub OUVRE : #entrée en Interactif
 When "DEBUT"        : Gosub DEBUT
 When "CONTROLE"     : Gosub CONTROLE
 When "EXEC"         : Gosub EXEC
 When "TERMINE"      : Gosub TERMINE
 When Default
Endcase
Return

######################################################################################
$OUVRE
Local Integer NBERR : NBERR=0
Local Integer OK , STAT
Local Char   FICREF(GDIMFIC),FICREJ(GDIMFIC), WFICHIER (GDIMFIC) , WFICCLI(GDIMFIC) , URL(GDIMFIC)

Local Mask RPAINT [DIA] : # Saisie paramètres
Raz [M:DIA]
If clalev ([F:RPA]) = 0 : Local File REACHPAR [RPA] : Endif
If clalev ([F:TFO]) = 0 : Local File TABFOR [TFO] : Endif
Call GET_DERLU([M:DIA]ID,"RPA","")
If [M:DIA]ID<>""
    Call AP_ID([M:DIA]ID)
Endif
[M:DIA]TRACE=2
Return

$DEBUT
Affzo [M:DIA]
# Issue 99586 - 2014-25-04 by RBA : Volumes managment evolution
If [M:DIA]ID<>""
 Call AM_TYPEXP([M:DIA]TYPEXP)
Endif
#/ Issue 99586 - 2014-25-04 by RBA : Volumes managment evolution
Return

#######################################################
$CONTROLE
If GSTATUT=7
 FIN = 1 : # Sortie du GSAISIE par la touche FIN
 Return
Endif
If !GSERVEUR
 TMP = 1
Endif
If [M:DIA]FLGITMPIT<>2 &
&     [M:DIA]FLGBPSPIT<>2
    ##Il faut demander au moins le traitement d'un fichier
    GERR=1
    SAI=1
    GMESSAGE=mess(36,7710,1)
    Return
Endif
Return

###############################################################
$TERMINE
  If !GSERVEUR & ( [M:DIA]TRACE=2 | NBERR>0)
    TRA = 1
  Else
    TRA = 0
  Endif
  #Gosub SUP_VAR
Return

######################################################################################
$EXEC
Local Char     WMESS(150)
Local Char     CRITERE(255),WCRITSTJ(255)
Local Char     CRITERE1(255)
Local Char     CRITERE2(255)

TIT  = mess(88,7710,1) # interface REACH

If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif

Call TRACE_MASQUE("RPAINT","DIA",nomap) From GTRAITE
Call ECR_TRACE(string$(100,"="),0) From GESECRAN


# lecture en cours
Call TEMPON(mess(3,100,1)) From GESECRAN
If [M:DIA]FLGITMPIT=2 | [M:DIA]FLGBPSPIT=2
    WITMPIT=""
    If [M:DIA]FLGITMPIT=2
        WITMPIT=[M:DIA]ITMPIT
    Endif
    WBPSPIT=""
    If [M:DIA]FLGBPSPIT=2
        WBPSPIT=[M:DIA]BPSPIT
    Endif
    Call TRT_ITM('RPA',[M:DIA]ID,WITMPIT,[M:DIA]ITMFOR,[M:DIA]ITMSRT,WBPSPIT,[M:DIA]BPSFOR,OK) From PITREACH
Endif

Gosub TRF_FILES
Call TEMPOFF From GESECRAN

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

########################################################################
# transfert fichiers serveur vers client
$TRF_FILES
Local Char PATH (GDIMFIC)
Local Char WFICHIER (GDIMFIC)
Local Integer STAT

Local Char MACHINE(GDIMFIC) , MACFIC(GDIMFIC)
Call MACHINE([M:DIA]DRTWRK,MACHINE,MACFIC) From ORDSYS

#on doit basculer le fichier dans le repertoire des fichiers destination

# articles
PATH = filpath("tmp",tolower([M:DIA]ID)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pititm")
WFICHIER = filpath([M:DIA]DRTWRK,"ITEMS","csv","","",MACHINE)
If [M:DIA]TYPEXP=1
# Issue 99586 - 2014-25-04 by RBA : Volumes managment evolution
  Call COPCLI(PATH,WFICHIER,STAT) From ORDSYS
#    Call MOVCLI(PATH ,WFICHIER ,STAT) From ORDSYS
#/ Issue 99586 - 2014-25-04 by RBA : Volumes managment evolution
Elsif [M:DIA]TYPEXP=2
    Call MOVE_EMPTY(PATH,WFICHIER ,STAT) From ORDSYS
Endif

# fournisseurs
PATH = filpath("tmp",tolower([M:DIA]ID)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitbps")
WFICHIER = filpath([M:DIA]DRTWRK,"SUPPLIERS","csv","","",MACHINE)
If [M:DIA]TYPEXP=1
# Issue 99586 - 2014-25-04 by RBA : Volumes managment evolution
  Call COPCLI(PATH,WFICHIER,STAT) From ORDSYS
#    Call MOVCLI(PATH ,WFICHIER ,STAT) From ORDSYS
#/ Issue 99586 - 2014-25-04 by RBA : Volumes managment evolution
Elsif [M:DIA]TYPEXP=2
    Call MOVE_EMPTY(PATH,WFICHIER ,STAT) From ORDSYS
Endif
Return
######################################################################################
## Etiquette ajoutée par le superviseur (écran RPAINT) 28/11/2011 16:50:03 (VPO)
######################################################################################
Subprog AP_ID(VALEUR)
Variable Char    VALEUR()
Read [RPA]RPA0=VALEUR
If !fstat
    [M:DIA]=[F:RPA]

# Issue 99586 - 2014-25-04 by RBA : Volumes managment evolution
#    If (GOS(1)="unix" & pat(left$([M:DIA]DRTRCP,3),"!:\")) or left$([M:DIA]DRTRCP,1)="#"
#     [M:DIA]TYPEXP = 1
#    Elsif GOS(1)<>"unix" & pat(left$([M:DIA]DRTRCP,3),"!:\") & filinfo([M:DIA]DRTRCP,0)<=0
#     [M:DIA]TYPEXP = 1
#    Else
#     [M:DIA]TYPEXP = 2
#    Endif
If [M:DIA]VOLFILWRK<>"" & left$([M:DIA]VOLFILWRK,1)="["
  [M:DIA]TYPEXP = 2 : # Server
 Else
  If GBATCH
   [M:DIA]TYPEXP = 2
  Else
   [M:DIA]TYPEXP = 1
  Endif
 Endif
#/ Issue 99586 - 2014-25-04 by RBA : Volumes managment evolution

    Call AM_TYPEXP([M:DIA]TYPEXP)
    Affzo [M:DIA]
    Call SET_DERLU("RPA",VALEUR)
Endif
End


#----------------------------------------------#
Subprog GET_DERLU(VALEUR,ABREV,CRITERE)
Variable Char VALEUR
Value Char ABREV,CRITERE
Onerrgo RIEN
Local File ALSTRD [ALS]
Local Char CLE(GLONID1) , PROGOBJ(GLONADC)
PROGOBJ = "WO"+ABREV
Gosub NOMFIC From =PROGOBJ
Local File =NOMFIC [A__]
If CRITERE="" : CRITERE = "1=1" : Endif
Filter [ALS] Where USR=GUSER & OBJ=ABREV Order By Key ALS0 Desc
For [ALS]ALS0
 CLE = [F:ALS]CLES
 K = instr(1,CLE,"~")
 If K
  CLE = left$(CLE,K-1)
 Endif
 Read [A__] = CLE
 If !fstat & evalue(CRITERE)
  VALEUR = CLE : Break
 Endif
Next ALS
Close Local File [ALS] , [A__]
End

#----------------------------------------------#
Subprog SET_DERLU(ABREV,CLE)
Value Char ABREV,CLE
Local File ALSTRD [ALS]
Local Integer I , K , OK
Trbegin [ALS]
 Gosub ECR_DERLU
Commit
Close Local File [ALS]
End


#----------------------------------------------#
$ECR_DERLU
Filter [ALS] Where USR=GUSER & OBJ=ABREV
Read [ALS]ALS0 Last
If fstat<=2
 If [F:ALS]LIG>=32000
  Delete [ALS] Where USR=GUSER & OBJ=ABREV
  K = 1
 Else
  K = [F:ALS]LIG+1
 Endif
Else
 K = 1
Endif
Raz I, OK
For [ALS]ALS0
 If [F:ALS]CLES=CLE : OK = 1 : Break : Endif
 If dim(CLEVALEUR)<0
  I+=1
 Else : ## GEODE
  OK=1
  Local Integer I1, I2, I3
  If CLEFCY<>""
   I2=0
   J=find(CLEFCY,CLEPRIM,CLESEC)
   For I3=1 To J
    I1 = I2+1
    I2 = instr(I1,[F:ALS]CLES,"~")
   Next I3
   If I2 & GFCY<>seg$([F:ALS]CLES,I1,I2-1) : OK=0 : Endif
  Endif
  If CLEDEP<>""
   I2=0
   J=find(CLEDEP,CLEPRIM,CLESEC)
   For I3=1 To J
    I1 = I2+1
    I2 = instr(I1,[F:ALS]CLES,"~")
   Next I3
   If GDEP<>seg$([F:ALS]CLES,I1,I2-1) : OK=0 : Endif
  Endif
  If OK : I+=1 : OK=0 : Endif
 Endif
Next
Filter [ALS]
If OK
 [F:ALS]LIG = K
 Rewrite [ALS]
Else
 If I>=GNBDERNIER
  Read [ALS]ALS0(2) = GUSER ; ABREV
  If fstat<=2 : OK = 1 : Endif
 Endif
 Raz [F:ALS]
 [F:ALS]USR  = GUSER
 [F:ALS]OBJ  = ABREV
 [F:ALS]LIG  = K
 [F:ALS]CLES = CLE
 If !OK
  Write [ALS]
 Else
  Rewrite [ALS]
 Endif
Endif
Return

$RIEN
Resume

######################################################################################
######################################################################################
Subprog C_ID(VALEUR)
Variable Char    VALEUR()
Read [RPA]RPA0=VALEUR
If fstat
    GERR=1
    GMESSAGE=mess(13,7710,1)-"("+VALEUR+")"
    mkstat=2
Endif
End

Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
# Issue 99586 - 2014-25-04 by RBA : Volumes managment evolution
#If GBATCH & VALEUR=1
# GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
# mkstat = 2 : End
#Endif
If VALEUR=1
 If GBATCH : GMESSAGE = mess(163,141,1) : mkstat = 2 : End
 Else
   Raz [M]VOLFILWRK : Grizo [M]VOLFILWRK
 Endif
Endif
#/ Issue 99586 - 2014-25-04 by RBA : Volumes managment evolution

End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
# Issue 99586 - 2014-25-04 by RBA : Volumes managment evolution
#  Call SET_NOMFIC("DRTWRK",[M:DIA]DRTWRK,VALEUR)
#  Affzo [M:DIA]DRTWRK
#  If VALEUR=1
#     Grizo [M:DIA]DRTWRK
#  Else
#     Actzo [M:DIA]DRTWRK
#  Endif
  If VALEUR=1
    Raz [M:DIA]VOLFILWRK
    Grizo [M:DIA]VOLFILWRK
  Else
    Actzo [M:DIA]VOLFILWRK
  Endif
  Affzo [M:DIA]VOLFILWRK
#/ Issue 99586 - 2014-25-04 by by RBA : Volumes managment evolution
End


Subprog SET_NOMFIC(COLREP,NOMIMP,TYPEXP)
Value Char COLREP()
Variable Char NOMIMP()
Value Integer TYPEXP
Local Char    FICSRV(GDIMFIC) , URL(GDIMFIC)
Local Char    REPERT(GDIMFIC) , MACHINE(GDIMFIC)

Read [RPA]RPA0=[M:DIA]ID
If !fstat
    If (GOS(1)="unix" & pat(left$([F:RPA]DRTWRK,3),"!:\")) or left$([F:RPA]DRTWRK,1)="#"
     If TYPEXP=1
        NOMIMP=evalue("[F:RPA]"+COLREP)
     Endif
    Elsif GOS(1)<>"unix" & pat(left$([F:RPA]DRTWRK,3),"!:\") & filinfo([F:RPA]DRTWRK,0)<=0
     If TYPEXP=1
        NOMIMP=evalue("[F:RPA]"+COLREP)
     Endif
    Else
     If TYPEXP=2
        NOMIMP=evalue("[F:RPA]"+COLREP)
     Else
        Call SET_NAMCLI(NOMIMP) From ORDSYS
     Endif
    Endif
Else
  If TYPEXP=1
    Call SET_NAMCLI(NOMIMP) From ORDSYS
  Endif
Endif

End

Subprog AS_DRTWRK(VALEUR)
Variable Char    VALEUR()
If [M:DIA]TYPEXP = 1
    Grizo [M:DIA]DRTWRK
    [S]mkstat=2
Endif
End

Subprog C_DRTWRK(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
# contrôle du répertoire
Call CONTREP(VALEUR)
If mkstat : End : Endif
End

######################################################################################

Subprog CONTREP(NAMEREP)
Variable Char NAMEREP()
Local Integer ER
Local Char    REPERT(GDIMFIC)
Local Char    MACHINE(GDIMFIC) , OS(10)
  If left$(NAMEREP,1)="#"
   GMESSAGE = mess(162,141,1) : # Le répertoire doit être indiqué sur un serveur
   mkstat   = 2
   End
  Endif
  Call MACHINE(NAMEREP,MACHINE,REPERT) From ORDSYS
  Call GET_OS(MACHINE,OS) From ORDSYS
  If OS="" Then
    GMESSAGE = MACHINE-mess(90,141,1) : # Machine inexistante
    mkstat=2 : End
  Endif
  Call EXISTE(NAMEREP,ER) From ORDSYS
  If ER<>2 Then
    GERR=1
    GMESSAGE = mess(9,141,1) :  # Répertoire inexistant
    mkstat = 2 : End
  Endif
End

Subprog AS_FLGITMPIT(VALEUR)
Variable Integer VALEUR
If [M:DIA]ITMPIT=""
    [S]mkstat=1
Endif
End

Subprog AS_FLGBPSPIT(VALEUR)
Variable Integer VALEUR
If [M:DIA]BPSPIT=""
    [S]mkstat=1
Endif
End

# Issue 98927 - 2014-07-04 by RBA : Volumes managment evolution
Subprog C_VOLFILWRK(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]DRTWRK,E_TYPE_FOLDER,GMESSAGE)
End
#/ Issue 98927 - 2014-07-04 by RBA : Volumes managment evolution
