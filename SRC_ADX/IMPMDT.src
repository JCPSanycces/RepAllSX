#<AdxTL>@(#)3.0.0.0 $Revision$
Return

$ACTION
Case ACTION
 When "IMP_ZONE"      : Gosub IMP_ZONE
 When "IMPORT"        : Gosub IMPORT
Endcase
Return

$IMP_ZONE
If GREP<>"M" : Return : Endif
If [M:MDT1]STA=2
 Case IMPZON
  When "BPCNUM"
   If [M:MDT1]BPCNUM<>[F:MDT]BPCNUM
    Call ECR_TRACE(func AFNC.MES1(mess(278,117,1), "BPCNUM"), 1) From GESECRAN
    OK=0
   Endif
  When "SIGCTY"
   If [M:MDT1]SIGCTY<>[F:MDT]SIGCTY
    Call ECR_TRACE(func AFNC.MES1(mess(278,117,1), "SIGCTY"), 1) From GESECRAN
    OK=0
   Endif
  When "SIGDAT"
   If [M:MDT1]SIGDAT<>[F:MDT]SIGDAT
    Call ECR_TRACE(func AFNC.MES1(mess(278,117,1), "SIGDAT"), 1) From GESECRAN
    OK=0
   Endif
  When "TYP"
   If [M:MDT1]TYP<>[F:MDT]TYP
    Call ECR_TRACE(func AFNC.MES1(mess(278,117,1), "TYP"), 1) From GESECRAN
    OK=0
   Endif
  When "PAYTYP"
   If [M:MDT1]PAYTYP<>[F:MDT]PAYTYP
    Call ECR_TRACE(func AFNC.MES1(mess(278,117,1), "PAYTYP"), 1) From GESECRAN
    OK=0
   Endif
  When "MIGFLG"
   If [M:MDT1]MIGFLG<>[F:MDT]MIGFLG
    Call ECR_TRACE(func AFNC.MES1(mess(278,117,1), "MIGFLG"), 1) From GESECRAN
    OK=0
   Endif
  When "NTLMIGIDT"
   If [M:MDT1]NTLMIGIDT<>[F:MDT]NTLMIGIDT
    Call ECR_TRACE(func AFNC.MES1(mess(278,117,1), "NTLMIGIDT"), 1) From GESECRAN
    OK=0
   Endif
  When "SITNAM"
   If [M:MDT1]SITNAM<>[F:MDT]SITNAM
    Call ECR_TRACE(func AFNC.MES1(mess(278,117,1), "SITNAM"), 1) From GESECRAN
    OK=0
   Endif
  When "SITFNC"
   If [M:MDT1]SITFNC<>[F:MDT]SITFNC
    Call ECR_TRACE(func AFNC.MES1(mess(278,117,1), "SITFNC"), 1) From GESECRAN
     OK=0
   Endif
 Endcase
Endif
Return

$IMPORT
# [F:MDT] : record to be imported
# [M:MDT1] : existing record (in case of import of an existing mandate)

Local Integer UPDBICONLY
UPDBICONLY = 0

# Expired, revoked or closed mandates are all rejected
If find([F:MDT]STA,4,5,6)
 Call ECR_TRACE(mess(273,117,1), 1) From GESECRAN
 OK=0 : Return
Endif

# $LIENS has already been called to update OPTBICSTR
If dim([M:MDT1]BANUPD)>0
 [M:MDT1]BANUPD = 0
 If OPTBICSTR=1 & ([F:MDT]STA=2 | [F:MDT]STA=3) & [F:MDT]NDAIMPFLG>0
  If [F:MDT]IBACOD<>[M:MDT1]IBACOD
   [M:MDT1]BANUPD = [F:MDT]NDAIMPFLG
  Else
   Local File MANDATE [MDTY]
   Read [F:MDTY]MDT0=[F:MDT]CPY;[F:MDT]UMRNUM
   If !fstat
    UPDBICONLY = 1
    [M:MDT1]BICCOD = [F:MDTY]BICCOD
    [M:MDT1]BANUPD = [F:MDT]NDAIMPFLG
   Endif
  Endif
 Endif
Endif

If clalev([F:BID])=0 : Local File BID [BID] : Endif

[F:MDT]IBAN   = left$([F:MDT]IBACOD, 4)
[F:MDT]BIDNUM = right$([F:MDT]IBACOD, 5)
Filter [BID] Where BPATYP=1 and BPANUM=[F:MDT]BPCNUM and BIDNUM=[F:MDT]BIDNUM and BPAADD=[F:MDT]BPCADD
Read [BID] First
[F:MDT]BIDCRY = [F:BID]CRY
[F:MDT]BICCOD = [F:BID]BICCOD
Filter [BID]

If [F:MDT]FNLFLG<>2 : Raz [F:MDT]PAYNBR : Endif
If [F:MDT]MIGFLG<>2 : Raz [F:MDT]NTLMIGIDT : Endif

# "Display" fields need to be set explicitly
[M:MDT1]IBAN   = [F:MDT]IBAN
[M:MDT1]BIDNUM = [F:MDT]BIDNUM
[M:MDT1]BIDCRY = [F:MDT]BIDCRY
If !UPDBICONLY
 [M:MDT1]BICCOD = [F:MDT]BICCOD
Endif
[M:MDT1]STA    = [F:MDT]STA

Call PARAML([F:MDT]CPY, "OPTBICSTR", VALPAR) From ADOVAL
DATBICSTR = VALPAR
If date$>=DATBICSTR & DATBICSTR<>[0/0/0]
 OPTBICSTR = 1
Else
 OPTBICSTR = 0
Endif

If find([F:MDT]STA,2,3)
 If [F:MDT]SIGCTY="" or [F:MDT]SIGDAT=[0/0/0] or [F:MDT]CPYADD="" or [F:MDT]BPCADD="" or [F:MDT]IBACOD="" or OPTBICSTR=0 and [F:MDT]BICCOD=""
  Call ECR_TRACE(mess(274,117,1), 1) From GESECRAN
  OK=0 : Return
 Endif
Endif

If [F:MDT]STA=3 : # Ajourné
 [F:MDT]MAIMDTFLG = 1
 [M:MDT1]MAIMDTFLG = [F:MDT]MAIMDTFLG
Endif
Return

