#<AdxTL>@(#)1.0.0.0 $Revision$
##################################################################################################
# SUBSSPB    Gestion des support de sélection           Module CRM                13 mars 2002   #
#                                                                                                #
# Sous-programmes utilitaires                                                                    #
##################################################################################################
#                                                                                                #
# LOADSSPL  : Charge une description des composants.                                             #
# SAVESSPL  : Enregistre une description des composants.                                         #
# SETTRT    : Assure la gestion d'un traitement associé à un support de type Traitement          #
# REACHTGR  : Vérifie si toutes les tables saisies mènent à la cible.                            #
# CHECKSSC  : Vérifie si les composants du support sont bien renseignés.                         #
#                                                                                                #
##################################################################################################

##########################################################################################################
# Charge une description des composants.
##################################################################################################
Subprog LOADSSPL(SZSPTNUM)
Value Char SZSPTNUM

Local Integer INBCPN

  INBCPN = 0
  #On charge une description existante.
  Filter [SSC] Where [F:SSC]SPTNUM = SZSPTNUM Order By [F:SSC]SPTLEV Asc; [F:SSC]SPTTAB Asc
  For [SSC] Hint Key SSC0
    If INBCPN >= dim([M:SSP2]SPTTAB) Then
      Break
    Endif
    [M:SSP2]SPTLEV(INBCPN) = [F:SSC]SPTLEV
    [M:SSP2]SPTTAB(INBCPN) = [F:SSC]SPTTAB
    [M:SSP2]SPTKEY(INBCPN) = [F:SSC]SPTKEY
    [M:SSP2]SPTTABPAE(INBCPN) = [F:SSC]SPTTABPAE
    [M:SSP2]SPTKEYPAE(INBCPN) = [F:SSC]SPTKEYPAE
    [M:SSP2]SPTFLT(INBCPN) = [F:SSC]SPTFLT
    [M:SSP2]SPTIDX(INBCPN) = [F:SSC]SPTIDX
    INBCPN += 1
  Next
  Filter [SSC]
  [M:SSP2]NBCPN = INBCPN
End

##########################################################################################################
# Enregistre une description des composants.
##################################################################################################
$SAVESSPL
Local Integer ISSPITER
Local Integer ISSPPBL

  ISSPPBL = 0
  #On efface tout et on recommence
  Delete [SSC] Where [F:SSC]SPTNUM = [M:SSP0]SPTNUM
  If fstat Then
    ISSPPBL = 1
    GOK=0
    Call FSTA("SSC") From GLOCK
  Endif
  If ISSPPBL Then
    Return
  Endif
  #Enregistre le tableau 1
  For ISSPITER = 0 To [M:SSP2]NBCPN-1
    If [M:SSP2]SPTTAB(ISSPITER) <> "" Then
      [F:SSC]SPTNUM = [M:SSP0]SPTNUM
      [F:SSC]SPTLEV = [M:SSP2]SPTLEV(ISSPITER)
      [F:SSC]SPTTAB = [M:SSP2]SPTTAB(ISSPITER)
      [F:SSC]SPTKEY = [M:SSP2]SPTKEY(ISSPITER)
      [F:SSC]SPTTABPAE = [M:SSP2]SPTTABPAE(ISSPITER)
      [F:SSC]SPTKEYPAE = [M:SSP2]SPTKEYPAE(ISSPITER)
      [F:SSC]SPTFLT = [M:SSP2]SPTFLT(ISSPITER)
      [F:SSC]SPTIDX = [M:SSP2]SPTIDX(ISSPITER)
      [F:SSC]SPTCPNSTD = 0
      Write [SSC]
      If fstat Then
        ISSPPBL = 1
        GOK = 0
        Call FSTA("SSC") From GLOCK
      Endif
    Endif
    If ISSPPBL Then
      Break
    Endif
  Next
Return

##########################################################################################################
# Assure la gestion d'un traitement associé à un support de type Traitement
###############################################################################################
Subprog SETTRT(SZTRT)
Value Char SZTRT

Local Char SZTGR
Local Char SZABRTGR
Local Char SZTGRMAIKEY
Local Char SZADXIFS
Local Char SZADXIRS
Local Char SZTRTNAME
Local Char SZTPLNAME
Local Char SZPRGSRC(250)
Local Char SZNEWPRG(250)
Local Char SZQUITMASK(3)
Local Integer IPRGSUFIX
Local Integer IEXIST
Local Integer ISTAT
Local Integer ISSPTAB
Local Integer IFIRCRICTL
Local Integer ILOOPSECURE

  ILOOPSECURE = 0
  ISTAT = 0
  SZQUITMASK = "000"
  ISSPTAB = 0
  IFIRCRICTL = 0
  If SZTRT = "" Then
    Gosub GENNEWTRT
  Else
    SZNEWPRG = filpath("TRT",SZTRT,"src",nomap)
    IEXIST = 0
    Call EXISTE(SZNEWPRG,IEXIST) From ORDSYS
    If !IEXIST Then
      #Génération d'un nouveau traitement
      Gosub GENNEWTRT
    Endif
  Endif
  If GERR Then
    End
  Endif
  Edi = SZTRT
End

##########################################################################################################
# Génération d'un nouveau traitement
##########################################################################
$GENNEWTRT
  IPRGSUFIX = 1
  While 1
    SZTRTNAME = "ZSSP" + num$(IPRGSUFIX)
    SZNEWPRG = filpath("TRT",SZTRTNAME,"src",nomap)
    #Contrôle de l'existence du src
    IEXIST = 0
    Call EXISTE(SZNEWPRG,IEXIST) From ORDSYS
    If IEXIST Then
      #Calcul un nouveau suffixe pour le traitement
      IPRGSUFIX += 1
    Else
      Break
    Endif
    ILOOPSECURE += 1
    If ILOOPSECURE > 100000 Then
      Break
    Endif
  Wend
  If ILOOPSECURE > 100000 Then
    #Erreur lors de la génération du modèle de traitement.
    GMESSAGE = mess(720,196,1)
    GERR = 1
    Return
  Endif
  SZTRT = SZTRTNAME
  Gosub GENSSPTRT
  If GERR Then
    SZTPLNAME = "SUBSSPC"
    SZPRGSRC = filpath("TRT",SZTPLNAME,"src",nomap)
    ISTAT = 1
    Call COPIE(SZPRGSRC, SZNEWPRG, ISTAT) From ORDSYS
    If ISTAT Then
      #Erreur lors de la génération du modèle de traitement.
      GMESSAGE = mess(720,196,1)
      GERR = 1
      Return
    Endif
  Endif
  #On enregistre le nom du traitement sur le support de sélection
  Call DEBTRANS From GLOCK
  Trbegin [SSP]
  Readlock [SSP]SSP0=[M:SSP0]SPTNUM
  If fstat Then
    Rollback
    #Erreur lors de la génération du modèle de traitement.
    GMESSAGE = mess(720,196,1)
    GERR = 1
    Return
  Else
    [F:SSP]SPTPRO = SZTRTNAME
    Rewrite [SSP]
    If fstat Then
      Rollback
      #Erreur lors de la génération du modèle de traitement.
      GMESSAGE = mess(720,196,1)
      GERR = 1
      Return
    Else
      Commit
      Unlock [SSP]
    Endif
  Endif
  [M:SSP1]SPTPRO = SZTRTNAME
  Affzo [M:SSP1]SPTPRO
Return

##########################################################################################################
#Génération du modèle de traitement
###############################################################
$GENSSPTRT
  #On sauvegarde les variables adxifs et adxirs
  SZADXIFS = adxifs
  SZADXIRS = adxirs
  adxifs = ""
  adxirs = chr$(10)
  #Ouverture du traitement à générer
  Openo SZNEWPRG, 0 Using [CRM6]
  #Génération du traitement
  Wrseq "#<AdxT"+GADOVERS+">@(#)%I%" Using [CRM6]

  Wrseq "#####################################################################################################" Using [CRM6]
  #Traitement de génération de requête complexe pour le support de sélection : XXXX
  Wrseq "#" + mess(725,196,1) + ' ' + [M:SSP0]SPTNUM Using [CRM6] 
  Wrseq "#####################################################################################################" Using [CRM6]

  Wrseq "Subprog LOOKUPTARGET(SZQURNUM, IPPLORD)" Using [CRM6]
  Wrseq "Value Char SZQURNUM    #" + mess(726,196,1) Using [CRM6]
  Wrseq "Value Integer IPPLORD  #" + mess(727,196,1) Using [CRM6]

  Wrseq "Gosub BEGIN" Using [CRM6]
  Wrseq "If GERR : End : Endif" Using [CRM6]

  Wrseq " " Using [CRM6]

  #Section destinée à ouvrir la table cible, et les autres tables nécessaires à la recherche.
  Wrseq "#" + mess(728,196,1) Using [CRM6]

  #Ouverture de la table cible
  Read [ATB] CODFIC = [M:SSP0]SPTTGR
  If fstat Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "111"
    Gosub QGENSSPTRT
    Return
  Else
    SZTGR = [M:SSP0]SPTTGR
    If SZTGR = "" Then
      #Erreur. Il faut nettoyer les ressources avant de dépiler.
      SZQUITMASK = "111"
      Gosub QGENSSPTRT
      Return
    Else
      SZABRTGR = [F:ATB]ABRFIC
      Read [TGL]TGL0=SZTGR
      If fstat Then
        #Erreur. Il faut nettoyer les ressources avant de dépiler.
        SZQUITMASK = "111"
        Gosub QGENSSPTRT
        Return
      Else
        If [F:TGL]TGRMAIKEY = "" Then
          #Erreur. Il faut nettoyer les ressources avant de dépiler.
          SZQUITMASK = "111"
          Gosub QGENSSPTRT
          Return
        Else
           SZTGRMAIKEY = [F:TGL]TGRMAIKEY
        Endif
      Endif
    Endif
    Wrseq "If !clalev([F:" + SZABRTGR + "]) : Local file " + [M:SSP0]SPTTGR + ' [' + SZABRTGR + '] : Endif' Using [CRM6]
  Endif
  #Ouvre les éventuelles autres tables précisées dans l'onglet Composants
  ISSPTAB = 0
  Filter [SSC] Where [F:SSC]SPTNUM = [M:SSP0]SPTNUM
  For [SSC] SSC1
    Read [ATB]CODFIC=[F:SSC]SPTTAB
    If fstat Then
      GERR = 1
      Break
    Else
      Wrseq "If !clalev([F:" + [F:ATB]ABRFIC + "]) : Local file " + [F:SSC]SPTTAB + ' [' + [F:ATB]ABRFIC + '] : Endif' Using [CRM6]
    Endif
    ISSPTAB += 1
  Next
  Filter [SSC]
  If GERR Then
    #Erreur. Il faut nettoyer les ressources avant de dépiler.
    SZQUITMASK = "111"
    Gosub QGENSSPTRT
    Return
  Endif
  Wrseq " " Using [CRM6]
  Wrseq " " Using [CRM6]
  Wrseq " " Using [CRM6]
  Wrseq " " Using [CRM6]
  #Section destinée à définir tous les différents types de filtres, relations et contrôles avec les tables ouvertes.
  #Le filtre présent ici inclus la totalité de la cible.
  Wrseq "#" + mess(729,196,1) Using [CRM6]
  Wrseq "#" + mess(730,196,1) Using [CRM6]

  If ISSPTAB Then
    #On va créer un link avec les tables liées
    Wrseq "Link [" + SZABRTGR + "] With" Using [CRM6]

    #Génération des expressions de lien
    Filter [SSC] Where [F:SSC]SPTNUM = [M:SSP0]SPTNUM
    IFIRCRICTL = 0
    For [SSC] SSC1
      If [F:SSC]SPTTAB <> "" Then
        #Vérifie si la table n'a pas déjà été liée
        If [F:SSC]SPTKEY <> "" Then
          If [F:SSC]SPTIDX <> "" Then
            If [F:SSC]SPTFLT <> "" Then
              Read [ATB]CODFIC=[F:SSC]SPTTAB
              If fstat Then
                #Erreur. Il faut nettoyer les ressources avant de dépiler.
                SZQUITMASK = "111"
                Gosub QGENSSPTRT
                Break
              Else
                If IFIRCRICTL Then
                  Wrseq "& ,[" + [F:ATB]ABRFIC + ']' + [F:SSC]SPTIDX + ' = ' + [F:SSC]SPTFLT Using [CRM6]
                Else
                  Wrseq "& [" + [F:ATB]ABRFIC + ']' + [F:SSC]SPTIDX + ' = ' + [F:SSC]SPTFLT Using [CRM6]
                  IFIRCRICTL += 1
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Next
    Filter [SSC]
    If GERR Then
      Return
    Endif

    Wrseq "& As [LNK]" Using [CRM6]

    #Définit l'ordre de tri pour la boucle de For de recherche
    Wrseq "& Order By Key KBID = [F:" + SZABRTGR + ']' + SZTGRMAIKEY + " Asc" Using [CRM6]

    #On pose un filtre total sur la cible
    Wrseq "Filter [LNK] Where 1=1" Using [CRM6]
  Else
    #On pose un filtre total sur la cible
    Wrseq "Filter [" + SZABRTGR + "] Where 1=1" Using [CRM6]
  Endif
  Wrseq " " Using [CRM6]
  Wrseq " " Using [CRM6]
  Wrseq " " Using [CRM6]
  Wrseq " " Using [CRM6]

  #Boucle destinée à stocker les enregistrements cible trouvés pour la population traitée.
  Wrseq "#" + mess(731,196,1) Using [CRM6]
  If ISSPTAB Then
    Wrseq "For [LNK]" Using [CRM6]
  Else
    Wrseq "For [" + SZABRTGR + ']' Using [CRM6]
  Endif

  Wrseq "Read [QTP] QTP1 = SZQURNUM;IPPLORD;[F:" + SZABRTGR + "]" + SZTGRMAIKEY Using [CRM6]
  Wrseq "If fstat" Using [CRM6]
  #Renseigne les champs non modifiables.
  Wrseq " " Using [CRM6]
  Wrseq "#" + mess(732,196,1) Using [CRM6]
  Wrseq "Gosub SETDATA" Using [CRM6]

  #Section destinée à intervenir sur le contenu des informations en général non modifiables.
  Wrseq " " Using [CRM6]
  Wrseq "#" + mess(733,196,1) Using [CRM6]
  Wrseq "[F:QTP]CRINUM = 0" Using [CRM6]
  Wrseq "[F:QTP]CRIVALNUM = 0" Using [CRM6]
  Wrseq "[F:QTP]WKGTAB = " + '"' + '"' Using [CRM6]
  Wrseq "[F:QTP]SPTLEV = 0" Using [CRM6]
  Wrseq "[F:QTP]KEYREC = " + '"' + '"' Using [CRM6]

  #Section destinée à préciser la clé primaire de la cible à utiliser pour l'enregistrement.
  Wrseq " " Using [CRM6]
  Wrseq "#" + mess(734,196,1) Using [CRM6]
  Wrseq "[F:QTP]KEYTGR = [F:" + SZABRTGR + ']' + SZTGRMAIKEY Using [CRM6]

  #Ecrit les informations dans la base.
  Wrseq " " Using [CRM6]
  Wrseq "#" + mess(735,196,1) Using [CRM6]
  Wrseq "Gosub WRITEDATA" Using [CRM6]
  Wrseq "Endif"  Using [CRM6]
  Wrseq " " Using [CRM6]
  Wrseq "If GERR : Break : Endif" Using [CRM6]
  Wrseq "Next" Using [CRM6]
  Wrseq " " Using [CRM6]
  Wrseq "Gosub TRANSACT" Using [CRM6]
  Wrseq " " Using [CRM6]

  #Réinitialise le ou les filtres sur la ou les tables utilisées.
  Wrseq "#" + mess(736,196,1) Using [CRM6]
  If ISSPTAB Then
    Wrseq "Filter [LNK]" Using [CRM6]
  Else
    Wrseq "Filter [" + SZABRTGR + ']' Using [CRM6]
  Endif

  Wrseq "End" Using [CRM6]

  Wrseq " " Using [CRM6]
  Wrseq " " Using [CRM6]
  Wrseq " " Using [CRM6]
  Wrseq " " Using [CRM6]

  Wrseq "######################################################" Using [CRM6]
  Wrseq "$BEGIN" Using [CRM6]
  Wrseq "Local Integer IPERF" Using [CRM6]
  Wrseq "Local Integer INTR" Using [CRM6]
  Wrseq "IPERF = 0" Using [CRM6]
  Wrseq "INTR = 0" Using [CRM6]
  Wrseq "If !clalev([F:QTP]) : Local File QURTMP [QTP] : Endif" Using [CRM6]
  Wrseq "Call DEBTRANS From GLOCK" Using [CRM6]
  Wrseq "Trbegin [QTP]" Using [CRM6]
  Wrseq "Delete [QTP] Where [F:QTP]QURNUM = SZQURNUM and [F:QTP]PPLORD = IPPLORD" Using [CRM6]
  Wrseq "If fstat" Using [CRM6]
  Wrseq "Rollback" Using [CRM6]
  Wrseq "GERR = 1" Using [CRM6]
  Wrseq "Else" Using [CRM6]
  Wrseq "Commit" Using [CRM6]
  Wrseq "Endif" Using [CRM6]

  Wrseq "Return" Using [CRM6]
  Wrseq " " Using [CRM6]
  Wrseq " " Using [CRM6]

  Wrseq "#########################################################" Using [CRM6]
  Wrseq "$TRANSACT" Using [CRM6]
  Wrseq "If INTR" Using [CRM6]
  Wrseq "If !GERR" Using [CRM6]
  Wrseq "Commit" Using [CRM6]
  Wrseq "Endif" Using [CRM6]
  Wrseq "Endif" Using [CRM6]
  Wrseq "Return" Using [CRM6]

  Wrseq " " Using [CRM6]
  Wrseq " " Using [CRM6]

  Wrseq "#######################################################" Using [CRM6]
  Wrseq "$SETDATA" Using [CRM6]
  Wrseq "If IPERF = 0" Using [CRM6]
  Wrseq "Call DEBTRANS From GLOCK" Using [CRM6]
  Wrseq "Trbegin [QTP]" Using [CRM6]
  Wrseq "INTR = 1" Using [CRM6]
  Wrseq "Endif" Using [CRM6]
  Wrseq "[F:QTP]QURNUM = SZQURNUM" Using [CRM6]
  Wrseq "[F:QTP]PPLORD = IPPLORD" Using [CRM6]
  Wrseq "[F:QTP]SPTTYP = 2" Using [CRM6]
  Wrseq "Return" Using [CRM6]

  Wrseq " " Using [CRM6]
  Wrseq " " Using [CRM6]

  Wrseq "########################################################" Using [CRM6]
  Wrseq "$WRITEDATA" Using [CRM6]
  Wrseq "Write [QTP]" Using [CRM6]
  Wrseq "If fstat" Using [CRM6]
  Wrseq "Rollback" Using [CRM6]
  Wrseq "GERR = 1" Using [CRM6]
  Wrseq "INTR = 0" Using [CRM6]
  Wrseq "Else" Using [CRM6]
  Wrseq "If IPERF >= 500" Using [CRM6]
  Wrseq "Commit" Using [CRM6]
  Wrseq "IPERF = 0" Using [CRM6]
  Wrseq "INTR = 0" Using [CRM6]
  Wrseq "Else" Using [CRM6]
  Wrseq "IPERF += 1" Using [CRM6]
  Wrseq "Endif" Using [CRM6]
  Wrseq "Endif" Using [CRM6]
  Wrseq "Return" Using [CRM6]

  #Fermeture du traitement généré
  Openo Using [CRM6]
  #On restaure les variables adxifs et adxirs
  adxifs = SZADXIFS
  adxirs = SZADXIRS
Return

##########################################################################################################
# Programme de remise en état des ressources suite à une arrêt sur erreur dans GENSSPTRT
##################################################################
$QGENSSPTRT
  #---------------------------------------------------#
  #Table des tâches de nettoyage :
  #
  # 0 : On restaure les variables adxifs et adxirs
  # 1 : On ferme le fichier ZSSPXXX
  # 2 : Suppression physique du fichier ZSSPXXX.src
  #---------------------------------------------------#
  #On signale toujours l'erreur
  GERR = 1
  #On restaure les variables adxifs et adxirs
  If val(mid$(SZQUITMASK, 1, 1)) Then
    adxifs = SZADXIFS
    adxirs = SZADXIRS
  Endif
  #On ferme le fichier ZSSPXXX
  If val(mid$(SZQUITMASK, 2, 1)) Then
    Openo Using [CRM6]
  Endif
  #Suppression physique du fichier ZSSPXXX.src
  If val(mid$(SZQUITMASK, 3, 1)) Then
    IEXIST = 1
    Call EFFACE(SZNEWPRG, IEXIST) From ORDSYS
  Endif
Return

##########################################################################################################
#Vérifie si toutes les tables saisies mènent à la cible.
###################################################################################
Subprog REACHTGR(ISOK)
Variable Integer ISOK

Local File SELSSPCPN [SSC2]
Local Integer ILEVEL
Local Integer ILOOPSECURE
Local Char SZPAE

  ILOOPSECURE = 0
  Filter [SSC] Where [F:SSC]SPTNUM = [M:SSP0]SPTNUM Order By [F:SSC]SPTLEV Asc; [F:SSC]SPTTAB Asc
  For [SSC] Hint Key SSC0
    ILEVEL = [F:SSC]SPTLEV
    SZPAE = [F:SSC]SPTTABPAE
    If ILEVEL = 1 Then
      If [F:SSC]SPTTABPAE <> [M:SSP0]SPTTGR Then
        #Certaines tables ne permettent pas d'accéder à la cible.
        GMESSAGE = mess(748,196,1)
        GERR = 1
        ISOK = 0
        Break
      Endif
    Else
      While 1
        Read [SSC2]SSC1=[M:SSP0]SPTNUM;SZPAE
        If fstat Then
          #Certaines tables ne permettent pas d'accéder à la cible.
          GMESSAGE = mess(748,196,1)
          GERR = 1
          ISOK = 0
          Break
        Else
          If [F:SSC2]SPTLEV = 1 Then
            If [F:SSC2]SPTTABPAE <> [M:SSP0]SPTTGR Then
              #Certaines tables ne permettent pas d'accéder à la cible.
              GMESSAGE = mess(748,196,1)
              GERR = 1
              ISOK = 0
              Break
            Else
              Break
            Endif
          Else
            SZPAE = [F:SSC2]SPTTABPAE
          Endif
        Endif
        ILOOPSECURE += 1
        If ILOOPSECURE > 50000 Then
          Break
        Endif
      Wend
    Endif
    If GERR Then
      Break
    Endif
  Next
  Filter [SSC]
  Close Local File [SSC2]
End

##########################################################################################################
#Vérifie si les composants du support sont bien renseignés
###################################################################################
Subprog CHECKSSC(ISOK)
Variable Integer ISOK

Local Integer ITERSSP

  #Regroupement de tables
  If [M:SSP1]SPTTYP = 1 Then
    For ITERSSP = 0 To [M:SSP2]NBCPN-1
      If [M:SSP2]SPTTAB(ITERSSP) <> "" Then
        If [M:SSP2]SPTKEY(ITERSSP) = "" Then
          #La définition des composants du support est incomplète.
          GMESSAGE = mess(110,177,1)
          GERR = 1
          ISOK = 0
          Break
        Endif
        If [M:SSP2]SPTKEYPAE(ITERSSP) = "" Then
          #La définition des composants du support est incomplète.
          GMESSAGE = mess(110,177,1)
          GERR = 1
          ISOK = 0
          Break
        Endif
      Endif
    Next
  Endif
  If ISOK = 0 Then
    End
  Endif
  #Premier niveau
  If [M:SSP1]SPTTYP = 4 Then
    For ITERSSP = 0 To [M:SSP2]NBCPN-1
      If [M:SSP2]SPTTAB(ITERSSP) <> "" Then
        If [M:SSP2]SPTKEY(ITERSSP) = "" Then
          #La définition des composants du support est incomplète.
          GMESSAGE = mess(110,177,1)
          GERR = 1
          ISOK = 0
          Break
        Endif
        If [M:SSP2]SPTKEYPAE(ITERSSP) = "" Then
          #La définition des composants du support est incomplète.
          GMESSAGE = mess(110,177,1)
          GERR = 1
          ISOK = 0
          Break
        Endif
        If [M:SSP2]SPTIDX(ITERSSP) = "" Then
          #La définition des composants du support est incomplète.
          GMESSAGE = mess(110,177,1)
          GERR = 1
          ISOK = 0
          Break
        Endif
        If [M:SSP2]SPTFLT(ITERSSP) = "" Then
          #La définition des composants du support est incomplète.
          GMESSAGE = mess(110,177,1)
          GERR = 1
          ISOK = 0
          Break
        Endif
      Endif
    Next
  Endif
  If ISOK = 0 Then
    End
  Endif
End
