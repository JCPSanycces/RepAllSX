#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIVEN201808002
# Issue X3-86343 - 2018-04-12 by FGR
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIVEN201808002(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIVEN201808002(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer NCOUNTERROR
Local Integer ISALREVQ
Local Integer IFOUND # Issue X3-113667 - 2018-10-24 by USA

  Call ECR_TRACE("UTIVEN201808002: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".FACILITY" [FCY]
  Local File =DOSSIER + ".VSQUOTE"  [VQH]
  Local File =DOSSIER + ".SQUOTE"   [SQH]
  # -----------------
  Raz COMPTEUR
  Raz NCOUNTERROR
  Raz IERR
  # -----------------
  If dim([F:VQH]CURREVFLG) > 0 Then
    Trbegin [VQH]
    # -----------------
    # I explained that an UTI must be executable many times, without corrupt existing data.
    # This is the case here, by the where condition : we are going to do something only if line with "[F:VQH]CURREVFLG = 0" are existing
    Update [VQH] Where [F:VQH]CURREVFLG = 0 With [F:VQH]CURREVFLG = 1
    If fstat Then
      # Error
      Call ECR_TRACE("File VSQUOTE error during [F:VQH]CURREVFLG initialization" + ", Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
      NCOUNTERROR += 1
    Else
      # Success
      COMPTEUR = adxuprec    # adxuprec return number of line updated by "Update"
    Endif
    # -----------------
    If IERR = 0 Then
      Delete [VQH] Where [F:VQH]CURREVFLG = 2
      Filter [FCY] Where [F:FCY]SALFLG = [V]CST_AYES
      For [FCY]
        ISALREVQ = val(func ADP_TOOL.GET_PARAM([L]DOSSIER, 3, [F:FCY]FCY, "SALREVQ"))  # To get a parameter value in an UTI
        If ISALREVQ = 2 or ISALREVQ = 3 Then
          For [SQH] Where [F:SQH]SALFCY = [F:FCY]FCY
            # Issue X3-113667 - 2018-10-24 by USA: Begin
              Repeat
                IFOUND = 1
                Filter [VQH] Where [F:VQH]SQHNUM = [F:SQH]SQHNUM and [F:VQH]REVNUM = [F:SQH]REVNUM
                For [VQH]
                  IFOUND = 2
                  Break
                Next
                Filter [VQH]
                If IFOUND = 2 Then
                  Filter [VQH] Where [F:VQH]SQHNUM = [F:SQH]SQHNUM Order By Key KEY1=[F:VQH]REVNUM Desc
                  For [VQH]KEY1
                    [F:VQH]REVNUM = [F:VQH]REVNUM + 1
                    Rewrite [VQH]
                    If fstat Then
                      Call ECR_TRACE("File VSQUOTE(rewrite)" - [F:VQH]SQHNUM - num$([F:VQH]REVNUM) + ", Error =" - num$(fstat), 1) From GESECRAN
                      GOK = 1
                      IERR = 1
                      NCOUNTERROR += 1
                      Break
                    Endif
                  Next
                  Filter [VQH]
                  If IERR = 1 Then
                    Break
                  Endif
                Endif
              Until IFOUND = 1
            # Issue X3-113667 - 2018-10-24 by USA: End

            If IERR = 0 Then   # Issue X3-113667 - 2018-10-24 by USA
              Raz [F:VQH]
              [F:VQH]SQHNUM = [F:SQH]SQHNUM
              [F:VQH]REVNUM = [F:SQH]REVNUM
              [F:VQH]SALFCY = [F:SQH]SALFCY
              [F:VQH]CURREVFLG = 2
              Write [VQH]
              COMPTEUR += 1
              If fstat Then
                Call ECR_TRACE("File VSQUOTE" - [F:VQH]SQHNUM - num$([F:VQH]REVNUM) + ", Error =" - num$(fstat), 1) From GESECRAN
                GOK = 1
                IERR = 1
                NCOUNTERROR += 1
              Endif
            Endif

          Next
        Endif
      Next
      Filter [FCY]
    Endif
    # -----------------
    If IERR = 0 Then
      Commit
      Call ECR_TRACE("UTIVEN201808002 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
    Else
      Rollback
      Call ECR_TRACE("UTIVEN201808002 : records processed with error(s).", 0) From GESECRAN
    Endif
  Endif
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","VSQUOTE","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "VSQUOTE") : End : Endif
  If filinfo(filpath("FIL","SQUOTE","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "SQUOTE") : End : Endif
  # -------------------------
  Call MAJ_UTIVEN201808002(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If filinfo(filpath("FIL","VSQUOTE","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "VSQUOTE") : End : Endif
  If filinfo(filpath("FIL","SQUOTE","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "SQUOTE") : End : Endif
  # -------------------------
  Call MAJ_UTIVEN201808002(APPLI)
End

