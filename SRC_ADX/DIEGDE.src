#<AdxTL>@(#)7.0.0.0 $Revision$
Call OBJET("GDE",GBIDC1,"") From GOBJET
End


#################################################################################
## Transaction de saisie
##  Bouton Pré-chargement automatique des axes du dossier avec Choix d'un groupe de site
#################################################################################

$ACTION
Case ACTION
 When "OUVRE" : Gosub OUVRE
 When "DEBUT" : Gosub DEBUT
 When "OK"    : Gosub OK
Endcase
Return

$OUVRE
If clalev([F:AGC]) = 0 : Local File AGRPCPY  [AGC] : Endif    # Groupe de sociétés
If clalev([F:AGF]) = 0 : Local File AGRPFCY  [AGF] : Endif    # Groupe de sites
If clalev([F:FGR]) = 0 : Local File FACGROUP [FGR] : Endif    # Regroupement de sites

If clalev([F:CPY]) = 0 : Local File COMPANY  [CPY] : Endif    # Sociétés
If clalev([F:FCY]) = 0 : Local File FACILITY [FCY] : Endif    # Sites

If clalev([F:DIE]) = 0 : Local File GDIE [DIE]     : Endif    # Axes
Return

$DEBUT
If [M:GDE1]GFY<>""  : [M:DIA]DIEAGF=[M:GDE1]GFY : Endif
Return

$OK

Local Integer I,LASTSAI
Local Char CRITERE(250)

If [M:DIA]DIEAGF=""  # Pré-charge tous les axes
 LASTSAI = [M:GDE4]NBRFLD
 For [DIE]DIE0
  If !find([F:DIE]DIE,[M:GDE4]DIE(0..LASTSAI-1))
   [M:GDE4]DIE([M:GDE4]NBRFLD) = [F:DIE]DIE
   [M:GDE4]FLD([M:GDE4]NBRFLD) = "CCE."+[F:DIE]DIE
   [M:GDE4]NBRFLD += 1
  Endif
  If [M:GDE4]NBRFLD>=dim([M:GDE4]DIE) : Break : Endif
 Next

Else
 If [F:AGF]FLGCPY=2
  #  Groupe de Société
  Filter [AGC] Where GRP=[M:DIA]DIEAGF
  For [AGC] 
   LASTSAI = [M:GDE4]NBRFLD
   Call LECTURE("CPY",[F:AGC]CPY,"") From CONTOBJ
   For I=0 To dim([F:CPY]DIE)
    If [F:CPY]DIE(I)="" : Break : Endif
    If !find([F:CPY]DIE(I),[M:GDE4]DIE(0..LASTSAI-1))
     [M:GDE4]DIE([M:GDE4]NBRFLD) = [F:CPY]DIE(I)
     [M:GDE4]FLD([M:GDE4]NBRFLD) = "CCE."+[F:CPY]DIE(I)
     [M:GDE4]NBRFLD += 1
    Endif
   Next
   If [M:GDE4]NBRFLD>=dim([M:GDE4]DIE) : Break : Endif
  Next
 Else
  #  Groupe de Sites
  Filter [FGR] Where CPY=[M:DIA]DIEAGF
  For [FGR] 
   LASTSAI = [M:GDE4]NBRFLD
   Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
   For I=0 To dim([F:FCY]DIE)
    If [F:FCY]DIE(I)="" : Break : Endif
    If !find([F:FCY]DIE(I),[M:GDE4]DIE(0..LASTSAI-1))
     [M:GDE4]DIE([M:GDE4]NBRFLD) = [F:FCY]DIE(I)
     [M:GDE4]FLD([M:GDE4]NBRFLD) = "CCE."+[F:FCY]DIE(I)
     [M:GDE4]NBRFLD += 1
    Endif
   Next
   If [M:GDE4]NBRFLD>=dim([M:GDE4]DIE) : Break : Endif
  Next
  Filter [FGR]
 Endif
Endif
Affzo [M:GDE4]
mkstat = 4 
Return

