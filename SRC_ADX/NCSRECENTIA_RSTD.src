#<AdxTL>@(#)0.0.0.0 $Revision$
# Class CCMCHGREQIA
###############################################################################
# Issue 110210/8 - 2015-12-15 by JUSYN : New labels for supervisor update
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AREAD_AFTER"
          Gosub IS_IMPACT_AVAILABLE
          Gosub FILL_IMPACT_ANALYSIS_ID
        When "AQUERY_TRANS_AFTER"
          Gosub FILL_IMPACT_ANALYSIS_ID
      Endcase
  Endcase
Return

$METHODS
  Case [L]AMETHOD
  Endcase
Return

$PROPERTIES
  Case [L]CURPRO
  Endcase
Return
###############################################################################

# ------------------------------------------------------
# Subroutine: IS_IMPACT_AVAILABLE
#
# Called from this Script.
# Is Impact Analysis available?
#
$IS_IMPACT_AVAILABLE

  If (this.NCSREC.IMPACTANAL = 0)
    ASTATUS = fmet this.ASETERROR("", mess(69,2038,1), CST_AWARNING)
  Elsif (this.NCSREC.IMPACTANAL = 1)
    ASTATUS = fmet this.ASETERROR("", mess(70,2038,1), CST_AWARNING)
  Endif

Return

$FILL_IMPACT_ANALYSIS_ID
    this.NCSID     = this.NCSREC.CRID
Return

