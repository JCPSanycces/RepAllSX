#######################################################################################
$_BUD_COMPUTE_MNTREMBUD
#Value Char BUDGET ()
#Local Decimal ARET_VALUE

Local Integer ILINE
Local Integer IISPARENT
Local Integer NI
Local Integer NI1

  [L]ARET_VALUE = 0
  # -------------------
  ILINE = fmet this.BUD_GET_INDEX(BUDGET)
  If ILINE > 0 Then
    IISPARENT = fmet this.BUD_IS_PARENT(BUDGET)
    If IISPARENT = [V]CST_AYES Then
      NI = find(BUDGET, this.BUD(1..maxtab(this.BUD)).PBUPAE)
      While NI > 0
        If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          [L]ARET_VALUE += fmet this._BUD_COMPUTE_MNTREMBUD(this.BUD(NI).PBUCOD)
        Endif
        NI1 = NI
        NI = find(BUDGET, this.BUD(NI+1..maxtab(this.BUD)).PBUPAE)
        If NI > 0 Then
          NI += NI1
        Endif
      Wend
    Endif
    [L]ARET_VALUE += fmet this.BUD(ILINE).BUDLIG_COMPUTE_MNTREMBUD()
  Endif
Return

#######################################################################################
$BUD_BUDLIG_DEL_ALL_LINES
#Value Char BUDGET ()
#Value Shortint LEVEL
#Local Decimal ARET_VALUE

Local Integer ILINE

  [L]ARET_VALUE = [V]CST_AOK
  ILINE = fmet this.BUD_GET_INDEX(BUDGET)
  If ILINE < 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(239,2260,1), BUDGET), [V]CST_AERROR))
    Return
  Endif
  If this.OPPSTATE <> 3 or this.OPPSTATE <> 4 or this.OPPSTATE <> 9 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(242,2260,1), mess(this.BUD(ILINE).PBUSTATE,2251,1)), [V]CST_AERROR))
    Return
  Endif
  If ILINE > 0 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._BUD_BUDLIG_DEL_ALL_LINES(BUDGET, LEVEL))
  Endif
Return

#######################################################################################
$_BUD_BUDLIG_DEL_ALL_LINES
#Value Char BUDGET ()
#Value Shortint LEVEL
#Local Decimal ARET_VALUE

Local Integer ILINE
Local Integer IISPARENT
Local Integer NI
Local Integer NI1
Local Integer IRET

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------
  ILINE = fmet this.BUD_GET_INDEX(BUDGET)
  If ILINE > 0 Then
    IISPARENT = fmet this.BUD_IS_PARENT(BUDGET)
    If IISPARENT = [V]CST_AYES Then
      NI = find(BUDGET, this.BUD(1..maxtab(this.BUD)).PBUPAE)
      While NI > 0
        If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          IRET = fmet this._BUD_BUDLIG_DEL_ALL_LINES(this.BUD(NI).PBUCOD, LEVEL)
          [L]ARET_VALUE = max([L]ARET_VALUE, IRET)
        Endif
        NI1 = NI
        NI = find(BUDGET, this.BUD(NI+1..maxtab(this.BUD)).PBUPAE)
        If NI > 0 Then
          NI += NI1
        Endif
      Wend
    Endif
    IRET = fmet this.BUD(ILINE).BUDLIG_DEL_ALL_LINES(LEVEL)
    [L]ARET_VALUE = max([L]ARET_VALUE, IRET)
  Endif
Return

#######################################################################################
$BUD_GET_PARENTS
#Value Char CODE ()
#Variable Char STBCODE ()(1..)
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer INBTAB

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------
  Raz STBCODE
  INBTAB = 0
  ILINE = fmet this.BUD_GET_INDEX(CODE)
  If ILINE < 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(239,2260,1), CODE), [V]CST_AERROR))
  Endif
  If ILINE > 0 Then
    INBTAB += 1
    STBCODE(INBTAB) = this.BUD(ILINE).PBUCOD
    If this.BUD(ILINE).PBUPAE <> AVOID.ACHAR Then
      Repeat
        ILINE = fmet this.BUD_GET_INDEX(this.BUD(ILINE).PBUPAE)
        If ILINE > 0 Then
          INBTAB += 1
          STBCODE(INBTAB) = this.BUD(ILINE).PBUCOD
        Endif
      Until ILINE = 0
    Endif
  Endif
Return

#######################################################################################
$BUD_GET_FAMILY
#Value Char CODE ()
#Variable Char STBCODE ()(1..)
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer INBTAB

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------
  Raz STBCODE
  INBTAB = 0
  ILINE = fmet this.BUD_GET_INDEX(CODE)
  If ILINE < 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(239,2260,1), CODE), [V]CST_AERROR))
  Endif
  If ILINE > 0 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._BUD_GET_FAMILY(CODE, INBTAB, STBCODE))
  Endif
Return

#######################################################################################
$_BUD_GET_FAMILY
#Value Char CODE ()
#Variable Integer INBTAB
#Variable Char STBCODE ()(1..)
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer IISPARENT
Local Integer NI
Local Integer NI1

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------
  ILINE = fmet this.BUD_GET_INDEX(CODE)
  If ILINE > 0 Then
    IISPARENT = fmet this.BUD_IS_PARENT(CODE)
    If IISPARENT = [V]CST_AYES Then
      NI = find(CODE, this.BUD(1..maxtab(this.BUD)).PBUPAE)
      While NI > 0
        If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          [L]ARET_VALUE += fmet this._BUD_GET_FAMILY(this.BUD(NI).PBUCOD, INBTAB, STBCODE)
        Endif
        NI1 = NI
        NI = find(CODE, this.BUD(NI+1..maxtab(this.BUD)).PBUPAE)
        If NI > 0 Then
          NI += NI1
        Endif
      Wend
    Endif
    INBTAB += 1
    STBCODE(INBTAB) = CODE
  Endif
Return

#########################################################################
$BUD_GET_PRJQTY
#Variable Char UOM

Local Integer BUDSUB
Local Integer LIGSUB
Local Decimal CONQTY

  [L]ARET_VALUE = 0
  # -------------------
  For BUDSUB = 1 To maxtab(this.BUD)
    For LIGSUB = 1 To maxtab(this.BUD(BUDSUB).BUDLIG)
      If this.BUD(BUDSUB).BUDLIG(LIGSUB) <> null and find(this.BUD(BUDSUB).BUDLIG(LIGSUB).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
         CONQTY = this.BUD(BUDSUB).BUDLIG(LIGSUB).PLBQTY
         If this.BUD(BUDSUB).BUDLIG(LIGSUB).PLBU <> UOM Then
          Call CONVERT_QTY(this.ACTX, this.BUD(BUDSUB).BUDLIG(LIGSUB).PLBU, UOM, CONQTY) From TRTX3_SYRA
         Endif
         [L]ARET_VALUE += CONQTY
      Endif
    Next LIGSUB
  Next BUDSUB
Return

###################################################################################################
$BUD_GET_PRJAMT
#Local Decimal ARET_VALUE

Local Integer BUDSUB
Local Integer LIGSUB

  [L]ARET_VALUE = 0
  For BUDSUB = 1 To maxtab(this.BUD)
    For LIGSUB = 1 To maxtab(this.BUD(BUDSUB).BUDLIG)
      If this.BUD(BUDSUB).BUDLIG(LIGSUB) <> null and find(this.BUD(BUDSUB).BUDLIG(LIGSUB).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        [L]ARET_VALUE += this.BUD(BUDSUB).BUDLIG(LIGSUB).PLBAMT
      Endif
    Next LIGSUB
  Next BUDSUB
Return

###################################################################################################
$BUD_GET_PIMDESAXX
#Value Char BUDCOD ()
#Local Char ARET_VALUE(250)

Local Integer NI

  Raz [L]ARET_VALUE
  # -------------------
  NI = fmet this.BUD_GET_INDEX(BUDCOD)
  If NI > 0 Then
    [L]ARET_VALUE = this.BUD(NI).PIMPL.PIMDESAXX
  Endif
Return

########################################################################################
$BUD_GET_ITMMASTER
#Value    Char PARITM
#Variable Char PARDES1
#Variable Char PARPUU
#Variable Decimal PARPRI
#Variable Char PARSTU
#Variable Char PARPCC

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------
  Local File ITMMASTER [ITM]
  # -------------------
  PARDES1 = AVOID.ACHAR
  PARPUU = AVOID.ACHAR
  PARPRI = 0
  PARSTU = AVOID.ACHAR
  PARPCC = AVOID.ACHAR
  Read [ITM]ITM0=PARITM
  If !fstat Then
    PARPUU = [F:ITM]PUU
    PARPCC = [F:ITM]PCCCOD
    PARSTU = [F:ITM]STU
    PARDES1 = [F:ITM]ITMDES1
    PARPRI = [F:ITM]PURBASPRI
  Endif
Return

#######################################################################################
$BUD_GET_ITMCOST
#Value    Char    PARFCY
#Value    Char    PARITM
#Value    Char    PARCTYP
#Value    Char    PARDTE
#Variable Decimal PARPRI
#Variable Char    PARCUR
#Variable Char    PARUOM

Local Date BUDDATE
Local Char SCPY(GLONCPY)

  [L]ARET_VALUE = [V]CST_AOK
  # -------------------
  Local File ITMCOST [ITC]
  # -------------------
  PARPRI = 0
  PARCUR = AVOID.ACHAR
  Filter [ITC] Where [F:ITC]STOFCY = PARFCY and [F:ITC]ITMREF = PARITM and [F:ITC]CSTTYP = PARCTYP and [F:ITC]ITCSTRDAT <= PARDTE and [F:ITC]ITCENDDAT >= PARDTE
  Read [ITC]First
  If fstat Then
    Filter [ITC] Where [F:ITC]STOFCY = PARFCY and [F:ITC]ITMREF = PARITM and [F:ITC]CSTTYP = PARCTYP and [F:ITC]ITCENDDAT < PARDTE Order By [F:ITC]ITCENDDAT Desc
    Read [ITC]First
  Endif
  If !fstat Then
    PARPRI = [F:ITC]VLTTOT
    If PARPRI <> 0 Then
      SCPY = fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(PARFCY, "LEGCPY")
      PARCUR = fmet this.ACTX.ACACHE.ACPY.AGETVALCHAR(SCPY, "ACCCUR")
    Endif
  Endif
  Filter [ITC]
Return

#######################################################################################
$BUD_PROGRESS
#Value Char BUD ()
#Local Decimal ARET_VALUE

Local Decimal NCSMTOT
Local Decimal NRMNTOT
Local Decimal DCSMTOT
Local Decimal DRMNTOT
Local Decimal IRET
Local Integer NI

  [L]ARET_VALUE = 0
  # -------------------
  If BUD <> AVOID.ACHAR Then
    NCSMTOT = 0
    NRMNTOT = 0
    IRET = fmet this._BUD_PROGRESS(BUD, NCSMTOT, NRMNTOT)
    DCSMTOT += NCSMTOT
    DRMNTOT += NRMNTOT
    If DCSMTOT <> 0 Then
      [L]ARET_VALUE = ar2(DCSMTOT / (DCSMTOT + DRMNTOT) * 100)
    Endif
  Endif
Return

#######################################################################################
$_BUD_PROGRESS
#Value Char BUD ()
#Variable Decimal CSMTOT
#Variable Decimal RMNTOT
#Local Decimal ARET_VALUE

Local Integer ILINE
Local Integer IISPARENT
Local Decimal NCSMTOT
Local Decimal NRMNTOT
Local Decimal IRET
Local Integer ILINE
Local Integer NI
Local Integer NI1
Local Integer NE
Local Integer NE1

  [L]ARET_VALUE = 0
  # -------------------
  ILINE = fmet this.BUD_GET_INDEX(BUD)
  If ILINE > 0 Then
    IISPARENT = fmet this.BUD_IS_PARENT(BUD)
    If IISPARENT = [V]CST_AYES Then
      NI = find(BUD, this.BUD(1..maxtab(this.BUD)).PBUPAE)
      While NI > 0
        If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          [L]ARET_VALUE += fmet this._BUD_PROGRESS(this.BUD(NI).PBUCOD, CSMTOT, RMNTOT)
        Endif
        NI1 = NI
        NI = find(BUD, this.BUD(NI+1..maxtab(this.BUD)).PBUPAE)
        If NI > 0 Then
          NI += NI1
        Endif
      Wend
    Endif
    If fmet this.TAS_IS_BUDGET_USED(BUD) = [V]CST_AYES Then
      NE = find(BUD, this.TAS(1..maxtab(this.TAS)).PBUCOD)
      While NE > 0
        If this.TAS(NE) <> null and find(this.TAS(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          NCSMTOT = 0
          NRMNTOT = 0
          IRET = fmet this._TAS_PROGRESS(this.TAS(NE).TASCOD, NCSMTOT, NRMNTOT)
          CSMTOT += NCSMTOT
          RMNTOT += NRMNTOT
        Endif
        NE1 = NE
        NE = find(BUD, this.TAS(NE+1..maxtab(this.TAS)).PBUCOD)
        If NE > 0 Then
          NE += NE1
        Endif
      Wend
    Endif
  Endif
Return

