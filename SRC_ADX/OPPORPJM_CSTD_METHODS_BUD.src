  [L]ARET_VALUE = 0
  If BUD <> AVOID.ACHAR Then
    [L]ARET_VALUE = fmet this._BUD_COMPUTE_QTYBUD(BUD, UOM)
  Endif
Return

#######################################################################################
$_BUD_COMPUTE_QTYBUD
#Value Char BUD ()
#Value Char UOM ()
#Local Decimal ARET_VALUE

Local Integer ILINE
Local Integer IISPARENT
Local Integer NI
Local Integer NI1

  [L]ARET_VALUE = 0
  # -------------------
  ILINE = fmet this.BUD_GET_INDEX(BUD)
  If ILINE > 0 Then
    IISPARENT = fmet this.BUD_IS_PARENT(BUD)
    # -------------------
    If IISPARENT = [V]CST_AYES Then
      NI = find(BUD, this.BUD(1..maxtab(this.BUD)).PBUPAE)
      While NI > 0
        If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          [L]ARET_VALUE += fmet this._BUD_COMPUTE_QTYBUD(this.BUD(NI).PBUCOD, UOM)
        Endif
        NI1 = NI
        NI = find(BUD, this.BUD(NI+1..maxtab(this.BUD)).PBUPAE)
        If NI > 0 Then
          NI += NI1
        Endif
      Wend
    Endif
    # -------------------
    [L]ARET_VALUE += fmet this.BUD(ILINE).BUDLIG_COMPUTE_QTYBUD(UOM)
    # -------------------
  Endif
Return

#######################################################################################
$BUD_COMPUTE_MNTBUD_ALL_BUDGETS
