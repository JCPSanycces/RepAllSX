#######################################################################################
$_BUD_COMPUTE_MNTBUD
#Value Char BUDGET ()
#Local Decimal ARET_VALUE

Local Integer ILINE
Local Integer IISPARENT
Local Integer NI
Local Integer NI1

  [L]ARET_VALUE = 0
  # -------------------
  ILINE = fmet this.BUD_GET_INDEX(BUDGET)
  If ILINE > 0 Then
    IISPARENT = fmet this.BUD_IS_PARENT(BUDGET)
    If IISPARENT = [V]CST_AYES Then
      NI = find(BUDGET, this.BUD(1..maxtab(this.BUD)).PBUPAE)
      While NI > 0
        If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          [L]ARET_VALUE += fmet this._BUD_COMPUTE_MNTBUD(this.BUD(NI).PBUCOD)
        Endif
        NI1 = NI
        NI = find(BUDGET, this.BUD(NI+1..maxtab(this.BUD)).PBUPAE)
        If NI > 0 Then
          NI += NI1
        Endif
      Wend
