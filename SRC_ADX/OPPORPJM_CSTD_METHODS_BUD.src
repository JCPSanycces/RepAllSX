#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################################
# Classe OPPORPJM
########################################################################################
# METHODS linked to BUD collection
########################################################################################
$BUD_INIT_TECH_PROP
#Value Integer LIN

  [L]ARET_VALUE = [V]CST_AOK
  If this.BUD(LIN) <> null Then
    this.BUD(LIN).CUR = this.CUR
    this.BUD(LIN).OPPCMP = this.OPPCMP
    this.BUD(LIN).TCHCHGTYP = this.TCHCHGTYP
    this.BUD(LIN).TCHOPPIMPT = this.OPPIMPT
    this.BUD(LIN).TCHOPPSTATE = this.OPPSTATE
  Endif
Return

#######################################################################################
$BUD_GET_INDEX
#Value char COD

  [L]ARET_VALUE = 0
  If COD <> AVOID.ACHAR Then
    [L]ARET_VALUE = find(COD,this.BUD(1..maxtab(this.BUD)).PBUCOD)
  Endif
Return

#######################################################################################
$BUD_DISABLE_ALL
Local Integer NI

  [L]ARET_VALUE = [V]CST_AOK
  For NI = 1 To maxtab(this.BUD)
    If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.BUD(NI).PIMPL.PIMSTA = [V]CST_AYES Then
        this.BUD(NI).PIMPL.TCHACTION = "STATUS"
        this.BUD(NI).PIMPL.PIMSTA = [V]CST_ANO
      Endif
    Endif
  Next NI
Return

#######################################################################################
$BUD_ENABLE_ALL
Local Integer NI

  [L]ARET_VALUE = [V]CST_AOK
  For NI = 1 To maxtab(this.BUD)
    If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.BUD(NI).PIMPL.PIMSTA = [V]CST_ANO Then
        If this.BUD(NI).PBUSTATE <> 4 and this.BUD(NI).PBUSTATE <> 9 and (this.OPPSTATE = 2 or this.OPPSTATE = 3) Then
          If this.BUD(NI).PBUSTATE = 1 Then
            this.BUD(NI).TCHACTION = "OPEN"
            this.BUD(NI).PBUSTATE = 2
          Endif
          If this.BUD(NI).PBUIMP = [V]CST_AYES Then
            this.BUD(NI).PIMPL.TCHACTION = "STATUS"
            this.BUD(NI).PIMPL.PIMSTA = [V]CST_AYES
          Endif
        Endif
      Endif
    Endif
  Next NI
Return

#######################################################################################
$BUD_AUTOMATION
#Variable Instance TECBUDAUT Using C_TECBUDAUT : #
#Variable Instance BUDLOG Using C_ALOG : #
#Local Integer ARET_VALUE

Local Integer ILINE
Local Date RTEEFD
Local Char PCCCOD(GLONPJCC)
Local Integer NI
Local Integer NE, STNE
Local Integer NZ
Local Integer B1
Local Integer LOK
Local Char LOGNAME (40)
Local Char SMESSAGE(250)
Local Integer UPDCLS
Local Integer OPPSUB
Local Integer TSKSUB
Local Integer OPESUB
Local Integer RTESUB
Local Integer BUDSUB
Local Integer BUDLVL
Local Char STPAE (GLONPBU) (1..)
Local Integer LVLNI(1..)
Local Char STPBUCOD (GLONPBU) (1..)
Local Integer IRETLOG

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------
  # 1°) Preliminary checks
  If this.OPPSTATE = 4 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(204,2260,1), mess(this.OPPSTATE,2249,1)), [V]CST_AERROR))
    Return
  Endif
  If TECBUDAUT.PBUCOD <> AVOID.ACHAR Then
    ILINE = fmet this.BUD_GET_INDEX(TECBUDAUT.PBUCOD)
    If ILINE < 1 Then
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(207,2260,1), TECBUDAUT.PBUCOD), [V]CST_AERROR))
      If TECBUDAUT.INCLOG = [V]CST_AYES
        IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES1(mess(207,2260,1), TECBUDAUT.PBUCOD),[V]CST_AWARNING)
      Endif
      Return
    Endif
  Endif
  # -------------------------------- Testing Parent/Child Processing [ALMON]
  If TECBUDAUT.PBUCOD <> AVOID.ACHAR
    If TECBUDAUT.INCALL = [V]CST_AYES
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.BUD_GET_FAMILY(TECBUDAUT.PBUCOD,STPBUCOD))
      If [L]ARET_VALUE < [V]CST_AERROR and maxtab(STPBUCOD) > 0 Then
        For B1 = 1 To maxtab(STPBUCOD)
          NI = find(STPBUCOD(B1), this.BUD(1..maxtab(this.BUD)).PBUCOD)
          If NI > 0
            [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.BUD_CODE_AUTOPROC(NI,TECBUDAUT,BUDLOG))
          Else
            If TECBUDAUT.INCLOG = [V]CST_AYES
              IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES1(mess(316,2260,1), TECBUDAUT.PBUCOD),[V]CST_AWARNING)
            Endif
          Endif
        Next B1
      Endif
    Else
      If this.BUD <> null
        NI = find(TECBUDAUT.PBUCOD, this.BUD(1..maxtab(this.BUD)).PBUCOD)
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.BUD_CODE_AUTOPROC(NI,TECBUDAUT,BUDLOG))
      Endif
    Endif
  Else
    For NI = 1 To maxtab(this.BUD)
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.BUD_CODE_AUTOPROC(NI,TECBUDAUT,BUDLOG))
    Next NI
  Endif
Return

#######################################################################################
$BUD_CODE_AUTOPROC
#Variable Integer NI : PJMBUD Collection Subscript
#Variable Instance TECBUDAUT Using C_TECBUDAUT : #
#Variable Instance BUDLOG Using C_ALOG #

Local Instance STKVAL Using C_STKVAL
Local Integer ORILVL
Local Char SBUDCOD(GLONPBU)
Local Integer ILINE
Local Integer IRETLOG

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------
  Local File PJMTSKCAT [PTC]
  If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
    If this.BUD(NI).PBUSTATE <> 3 and this.BUD(NI).PBUSTATE <> 4 and this.BUD(NI).PBUSTATE <> 9 Then
      # [ALMON] Bypass Deleteing
      If TECBUDAUT.INCDAL = [V]CST_AYES Then
        # delete related BUDLIGS
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.BUD(NI).BUDLIG_DEL_ALL_LINES(2))
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.BUD(NI).BUDLIG_DEL_ALL_LINES(3))
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.BUD(NI).BUDLIG_DEL_ALL_LINES(6))
      Endif #[ALMON] END
      If [L]ARET_VALUE < [V]CST_AERROR Then
        If TECBUDAUT.INCLOG = [V]CST_AYES
          IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES1(mess(282,2260,1), this.BUD(NI).PBUCOD),[V]CST_AWARNING)
        Endif
        NE = find(this.BUD(NI).PBUCOD, this.TAS(1..maxtab(this.TAS)).PBUCOD)
        While NE > 0
          If this.TAS(NE) <> null and find(this.TAS(NE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            Read [F:PTC]CTA0=this.TAS(NE).TCACOD # [ALMON] Start use Category Type not Task Type
            If !fstat Then
              If TECBUDAUT.INCLOG = [V]CST_AYES Then
                IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES1(mess(283,2260,1), this.TAS(NE).TASCOD),[V]CST_AWARNING)
              Endif
              If TECBUDAUT.INCOPE = [V]CST_AYES Then
                If maxtab(this.TAS(NE).RTKO) > 0 Then
                  If [F:PTC]TASTYP = 2 or [F:PTC]TASTYP = 3 Then
                    # ----- PROCESS OPERATIONS
                    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.BUD_AUTOMATION_OPE(NI, NE, TECBUDAUT, BUDLOG))
                  Else
                    If TECBUDAUT.INCLOG = [V]CST_AYES
                      IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES1(mess(256,2260,1), mess([F:PTC]TASTYP,2252,1)) ,0)
                    Endif
                  Endif
                Endif
              Else
                If TECBUDAUT.INCLOG = [V]CST_AYES
                  IRETLOG = fmet BUDLOG.APUTLINE(mess(257,2260,1),0)
                Endif
              Endif
              # ----- PROCESS TASK PRODUCS
              If TECBUDAUT.INCITM = [V]CST_AYES Then
                If [F:PTC]TASTYP = 1 or [F:PTC]TASTYP = 3 Then
                  [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.BUD_AUTOMATION_ITM(NI, NE, TECBUDAUT, BUDLOG, STKVAL))
                Else
                  If maxtab(this.TAS(NE).RITT) > 0 Then
                    If TECBUDAUT.INCLOG = [V]CST_AYES Then
                      IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES1(mess(1007,2260,1), mess([F:PTC]TASTYP,2252,1)),0)
                    Endif
                  Endif
                Endif
              Else
                If TECBUDAUT.INCLOG = [V]CST_AYES Then
                  IRETLOG = fmet BUDLOG.APUTLINE(mess(1008,2260,1),0)
                Endif
              Endif
            Else
              If TECBUDAUT.INCLOG = [V]CST_AYES Then
                IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES1(mess(255,2260,1), this.TAS(NE).TCACOD), [V]CST_AWARNING)
              Endif
            Endif
          Else
            If TECBUDAUT.INCLOG = [V]CST_AYES Then
              IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES1(mess(254,2260,1), this.BUD(NI).PBUCOD), [V]CST_AWARNING)
            Endif
          Endif
          # --------------------------------
          STNE = NE #ALMON without STNE logic iteration remains in a loop
          NE = find(this.BUD(NI).PBUCOD, this.TAS(NE+1..maxtab(this.TAS)).PBUCOD)
          If NE > 0 Then
            NE = STNE + NE
          Endif
        Wend
      Endif
    Else
      If TECBUDAUT.INCLOG = [V]CST_AYES Then
        IRETLOG = fmet BUDLOG.APUTLINE(this.BUD(NI).PBUCOD - mess(208,2260,1), [V]CST_AWARNING)
      Endif
    Endif
  Endif
  # --------------------------------
  If STKVAL <> null Then
    FreeGroup STKVAL
  Endif
Return

###############################################################################
$BUD_AUTOMATION_OPE
#Variable Integer NI - Budget code subscript
#Variable Integer NE - Task Subscript
#Variable Instance TECBUDAUT Using C_TECBUDAUT : #
#Variable Instance BUDLOG Using C_ALOG #

Local Decimal DRATE
Local Integer ISTAT
Local Decimal WRKRATE
Local Decimal OPEQTY
Local Char WRKPCCCOD(GLONPJCC)
Local Char WRKCUR(GLONCUR)
Local Char WRKUOM(GLONUOM)
Local Char CUR(GLONCUR)
Local Char UOM(GLONUOM)
Local Char OPEITM(1)
Local Char PCCCOD(GLONPJCC)
Local Date RTEEFD
Local Integer NZ
Local Integer IRETLOG

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------
  For NZ = 1 To maxtab(this.TAS(NE).RTKO)
    If this.TAS(NE).RTKO(NZ) <> null and find(this.TAS(NE).RTKO(NZ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If TECBUDAUT.INCLOG = [V]CST_AYES Then
        IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES2(mess(284,2260,1), num$(this.TAS(NE).RTKO(NZ).OPENUM), num$(this.TAS(NE).RTKO(NZ).OPESPLNUM)),[V]CST_AWARNING)
      Endif
      #--------------
      # Get Task Oper Rate Effective Date - now incorporated into this.TAS_GET_COST_EFFECTIVE_RATE()
      OPEQTY = this.TAS(NE).RTKO(NZ).EXTQTY
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.TAS_GET_COST_TYPE(this.TAS(NE).TASCOD, this.TAS(NE).RTKO(NZ).OPENUM, this.TAS(NE).RTKO(NZ).OPESPLNUM, 0,CUR, UOM, PCCCOD))
      If [L]ARET_VALUE < [V]CST_AERROR  and PCCCOD <> AVOID.ACHAR Then
        If TECBUDAUT.INCLOG = [V]CST_AYES Then
          IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES1(mess(285,2260,1), PCCCOD),[V]CST_AWARNING)
        Endif
        WRKPCCCOD = PCCCOD
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.TAS_GET_COST_EFFECTIVE_RATE(this.TAS(NE).TASCOD,this.TAS(NE).RTKO(NZ).OPENUM,this.TAS(NE).RTKO(NZ).OPESPLNUM,0,WRKCUR,WRKUOM,WRKRATE))
        If TECBUDAUT.INCLOG = [V]CST_AYES Then
           IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES1(mess(286,2260,1), num$(WRKRATE)) ,0)
        Endif
      Else
        If TECBUDAUT.INCLOG = [V]CST_AYES
          IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES1(mess(258,2260,1), this.TAS(NE).TASCOD+":"+num$(this.TAS(NE).RTKO(NZ).OPENUM)) ,[V]CST_AERROR)
          Break
        Endif
      Endif
      If [L]ARET_VALUE < [V]CST_AERROR Then
        If WRKUOM = AVOID.ACHAR
          WRKUOM = this.TAS(NE).RTKO(NZ).OPEUOM2
        Endif
        If WRKUOM <> this.TAS(NE).RTKO(NZ).OPEUOM2 Then
          # conversion from OPERATION UOM to COST TYPE UOM
          Call CONVERT_QTY(this.ACTX, this.TAS(NE).RTKO(NZ).OPEUOM2, WRKUOM, OPEQTY) From TRTX3_SYRA
          If TECBUDAUT.INCLOG = [V]CST_AYES Then
            IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES1(mess(260,2260,1), num$(this.TAS(NE).RTKO(NZ).EXTQTY)), 0)
          Endif
        Endif
       [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.TAS_GET_EFFECTIVE_DATE(this.TAS(NE).TASCOD,this.TAS(NE).RTKO(NZ).OPENUM,this.TAS(NE).RTKO(NZ).OPESPLNUM,0,RTEEFD))
       If [L]ARET_VALUE < [V]CST_AERROR Then
         If CUR = AVOID.ACHAR Then
           If TECBUDAUT.INCLOG = [V]CST_AYES Then
             IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES2(mess(293,2260,1), CUR, this.CUR), [V]CST_AERROR)
           Endif
           CUR = this.CUR
         Endif
         Call CONVERT(this.ACTX, CUR, this.CUR, CUR, this.TCHCHGTYP, RTEEFD, WRKRATE, DRATE, ISTAT) From TRTDEV_SYRA
         If ISTAT = [V]CST_AOK Then
           WRKRATE = DRATE
           If TECBUDAUT.INCLOG = [V]CST_AYES Then
             IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES1(mess(295,2260,1), num$(WRKRATE)), 0)
           Endif
           [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._BUD_UPD_LINES(NI, WRKPCCCOD,[V]CST_ANO,OPEQTY,WRKRATE,WRKUOM,RTEEFD,TECBUDAUT,BUDLOG))
         Else
           If TECBUDAUT.INCLOG = [V]CST_AYES Then
             IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES2(mess(293,2260,1), CUR, this.CUR), [V]CST_AERROR)
           Endif
         Endif
       Else
         If TECBUDAUT.INCLOG = [V]CST_AYES Then
           IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES2(mess(292,2260,1), this.TAS(NE), num$(this.TAS(NE).RTKO(NZ).OPENUM)) ,[V]CST_AERROR)
         Endif
       Endif
      Else
        If TECBUDAUT.INCLOG = [V]CST_AYES Then
          IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES1(mess(259,2260,1), WRKPCCOD), [V]CST_AERROR)
        Endif
      Endif
    Endif
  Next NZ
Return

#######################################################################################
$BUD_AUTOMATION_ITM
#Variable Integer NI - Budget code subscript
#Variable Integer NE - Task Subscript
#Variable Instance TECBUDAUT Using C_TECBUDAUT : #
#Variable Instance BUDLOG Using C_ALOG #
#Variable Instance STKVAL Using C_STKVAL # X3-63079 Changed to param declaration

Local Decimal DRATE
Local Integer ISTAT
Local Decimal WRKRATE
Local Decimal OPEQTY
Local Char WRKPCCCOD(GLONPJCC)
Local Char WRKCUR(GLONCUR)
Local Char WRKUOM(GLONUOM)
Local Char CUR(GLONCUR)
Local Char UOM(GLONUOM)
Local Char OPEITM(1)
Local Char PCCCOD(GLONPJCC)
Local Date RTEEFD
Local Integer NZ
Local Char PARPUU(GLONUOM)
Local Char PARFCY(GLONFCY)
Local Char PARCUR(GLONCUR)
Local Char ITMREF(GLONITM)
Local Char ITMDES1(GLONDES)
Local Char EXTUOM(GLONUOM)
Local Char PARSTU(GLONUOM)
Local Decimal EXTQTY
Local Decimal QTYSTU
Local Integer CI               # Cost componenet Index
Local Integer CSTIDX           # Cost componenet
Local Decimal CSTVAL           # Cost componenet Value
Local Integer IRETLOG

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------
  For NZ = 1 To maxtab(this.TAS(NE).RITT)
    If this.TAS(NE).RITT(NZ) <> null and find(this.TAS(NE).RITT(NZ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If TECBUDAUT.INCLOG = [V]CST_AYES Then
        IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES2(mess(522,2260,1), this.TAS(NE).RITT(NZ).ITMREF,num$(this.TAS(NE).RITT(NZ).ITTSEQ)),[V]CST_AWARNING)
      Endif
      OPEQTY = this.TAS(NE).RITT(NZ).ITTQTY
      ITMREF = this.TAS(NE).RITT(NZ).ITMREF
      If STKVAL <> null Then
        FreeGroup STKVAL
      Endif
      STKVAL = NewInstance C_STKVAL AllocGroup null
      [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.BUD_GET_ITMMASTER(ITMREF, ITMDES1, PARPUU, WRKRATE, PARSTU, PCCCOD))
      If [L]ARET_VALUE < [V]CST_AERROR Then
        If TECBUDAUT.INCLOG = [V]CST_AYES Then
          IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES1(mess(285,2260,1), PCCCOD), [V]CST_AWARNING)
        Endif
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.TAS_GET_EFFECTIVE_DATE(this.TAS(NE).TASCOD,0,0,this.TAS(NE).RITT(NZ).ITTSEQ, RTEEFD))
        If [L]ARET_VALUE = [V]CST_AERROR or RTEEFD = [0/0/0] Then
          RTEEFD = date$
        Endif
        If this.TAS(NE).RITT(NZ).MANUALBUD = 0 Then
          PARFCY = this.TAS(NE).TASFCY
          If this.TAS(NE).RITT(NZ).BUDVLTCOD > 1 Then
            WRKRATE = fmet this.BUD_GET_STKVAL(this.TAS(NE).RITT(NZ).BUDVLTCOD,NE,NZ,RTEEFD,STKVAL)
          Endif
          If WRKRATE = 0 and this.TAS(NE).RITT(NZ).BUDVLT2 > 1 Then
            WRKRATE = fmet this.BUD_GET_STKVAL(this.TAS(NE).RITT(NZ).BUDVLT2,NE,NZ,RTEEFD,STKVAL)
          Endif
          CUR    = PARCUR
          WRKUOM = PARPUU
          If WRKRATE <> 0 Then
            If STKVAL.CUR = AVOID.ACHAR Then
              If TECBUDAUT.INCLOG = [V]CST_AYES Then
               IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES2(mess(293,2260,1), STKVAL.CUR, this.CUR), [V]CST_AERROR)
              Endif
              CUR = this.CUR
            Else
              CUR = STKVAL.CUR
            Endif
            [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.BUD_MAT_BRKDWN(NI, NE, NZ, OPEQTY, WRKUOM, RTEEFD, CUR, TECBUDAUT, BUDLOG, STKVAL))
            [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.BUD_LAB_BRKDWN(NI, NE, NZ, OPEQTY, WRKUOM, RTEEFD, CUR, TECBUDAUT, BUDLOG, STKVAL))
            [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.BUD_MAC_BRKDWN(NI, NE, NZ, OPEQTY, WRKUOM, RTEEFD, CUR, TECBUDAUT, BUDLOG, STKVAL))
          Else
            If TECBUDAUT.INCLOG = [V]CST_AYES Then
             IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES1(mess(1015,2260,1), ITMREF), [V]CST_AERROR)
            Endif
          Endif
        Else
          If PCCCOD <> AVOID.ACHAR Then
            WRKRATE = this.TAS(NE).RITT(NZ).MANUALBUD
            PARCUR  = this.TAS(NE).RITT(NZ).CUR
            WRKUOM  = this.TAS(NE).RITT(NZ).UOM
            WRKPCCCOD = PCCCOD
            If RTEEFD <> [0/0/0] Then
              CUR = this.CUR
              [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._BUD_UPD_LINES(NI,WRKPCCCOD,[V]CST_AYES,OPEQTY,WRKRATE,WRKUOM,RTEEFD,TECBUDAUT,BUDLOG))
            Endif
          Else
            If TECBUDAUT.INCLOG = [V]CST_AYES Then
              IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES1(mess(523,2260,1), this.TAS(NE).TASCOD+":"+this.TAS(NE).RITT(NZ).ITMREF), [V]CST_AERROR)
            Endif
          Endif
        Endif
      Else
        If TECBUDAUT.INCLOG = [V]CST_AYES Then
          IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES1(mess(523,2260,1), this.TAS(NE).TASCOD+":"+this.TAS(NE).RITT(NZ).ITMREF), [V]CST_AERROR)
        Endif
      Endif
    Endif
  Next NZ
Return

#######################################################################################
$BUD_MAT_BRKDWN
#Variable integer BUDIDX
#Variable integer TASIDX
#Variable integer ITMIDX
#Variable integer ITMQTY
#Variable Char    ITMUOM
#Variable Date    ITMEFD
#Variable Char    OPPCUR
#Variable Instance TECBUDAUT Using C_TECBUDAUT : #
#Variable Instance BUDLOG Using C_ALOG #
#Variable Instance STKVAL Using C_STKVAL

Local Integer ISTAT
Local Decimal WRKRATE
Local Decimal DRATE
Local Char ITMPCCCOD(GLONPJCC)
Local Integer IRETLOG
Local Integer CSTIDX           # Cost componenet
Local Decimal CSTVAL           # Cost componenet Value
Local Integer CI

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------
  For CI = 1 To maxtab(STKVAL.MATERIAL)
    If STKVAL.MATERIAL(CI) <> null and find(STKVAL.MATERIAL(CI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      CSTIDX = STKVAL.MATERIAL(CI).MATIDX + 1
      CSTVAL = STKVAL.MATERIAL(CI).MATCST
      If CSTVAL <> 0 Then
        Raz ITMPCCCOD
        ITMPCCCOD = fmet this.BUD_GET_COSTTYPE(1, CSTIDX)
        If ITMPCCCOD <> AVOID.ACHAR Then
          WRKRATE = CSTVAL * this.TAS(TASIDX).RITT(ITMIDX).ITTQTY
          Call CONVERT(this.ACTX, OPPCUR, this.CUR, OPPCUR, this.TCHCHGTYP, ITMEFD, WRKRATE, DRATE, ISTAT) From TRTDEV_SYRA
          If ISTAT = [V]CST_AOK Then
            WRKRATE = DRATE
            If TECBUDAUT.INCLOG = [V]CST_AYES Then
              IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES1(mess(295,2260,1), num$(WRKRATE)), 0)
            Endif
            [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._BUD_UPD_LINES(BUDIDX,ITMPCCCOD,[V]CST_AYES,ITMQTY,WRKRATE,ITMUOM,date$,TECBUDAUT,BUDLOG))
          Else
            If TECBUDAUT.INCLOG = [V]CST_AYES Then
              IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES2(mess(293,2260,1), OPPCUR, this.CUR), [V]CST_AERROR)
            Endif
          Endif
        Else
          IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES2(mess(964,2260,1),mess(1,7722,1), mess(CSTIDX,325,1)), [V]CST_AERROR)
        Endif
      Endif
    Endif
  Next CI
Return

#######################################################################################
$BUD_LAB_BRKDWN
#Variable integer BUDIDX
#Variable integer TASIDX
#Variable integer ITMIDX
#Variable integer ITMQTY
#Variable Char    ITMUOM
#Variable Date    ITMEFD
#Variable Char    OPPCUR
#Variable Instance TECBUDAUT Using C_TECBUDAUT : #
#Variable Instance BUDLOG Using C_ALOG #
#Variable Instance STKVAL Using C_STKVAL

Local Integer ISTAT
Local Decimal WRKRATE
Local Decimal DRATE
Local Char ITMPCCCOD(GLONPJCC)
Local Integer IRETLOG
Local Integer CSTIDX           # Cost componenet
Local Decimal CSTVAL           # Cost componenet Value
Local Integer CI

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------
  For CI = 1 To maxtab(STKVAL.LABOR)
    If STKVAL.LABOR(CI) <> null and find(STKVAL.LABOR(CI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      CSTIDX = STKVAL.LABOR(CI).LABIDX+1
      CSTVAL = STKVAL.LABOR(CI).LABCST
      If CSTVAL <> 0 Then
        Raz ITMPCCCOD
        ITMPCCCOD = fmet this.BUD_GET_COSTTYPE(2, CSTIDX)
        If ITMPCCCOD <> AVOID.ACHAR Then
          WRKRATE = CSTVAL * this.TAS(TASIDX).RITT(ITMIDX).ITTQTY
          Call CONVERT(this.ACTX, OPPCUR, this.CUR, OPPCUR, this.TCHCHGTYP, ITMEFD, WRKRATE, DRATE, ISTAT) From TRTDEV_SYRA
          If ISTAT = [V]CST_AOK Then
           WRKRATE = DRATE
           If TECBUDAUT.INCLOG = [V]CST_AYES Then
             IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES1(mess(295,2260,1), num$(WRKRATE)) ,0)
           Endif
           [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._BUD_UPD_LINES(BUDIDX, ITMPCCCOD, [V]CST_AYES, ITMQTY, WRKRATE, ITMUOM, date$, TECBUDAUT, BUDLOG))
          Else
           	If TECBUDAUT.INCLOG = [V]CST_AYES Then
							IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES2(mess(293,2260,1), OPPCUR, this.CUR) ,[V]CST_AERROR)
						Endif
          Endif
        Else
          IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES2(mess(964,2260,1),mess(2,7722,1) ,mess(CSTIDX,316,1)),[V]CST_AERROR)
        Endif
      Endif
    Endif
  Next CI
Return

#######################################################################################
$BUD_MAC_BRKDWN
#Variable integer BUDIDX
#Variable integer TASIDX
#Variable integer ITMIDX
#Variable integer ITMQTY
#Variable Char    ITMUOM
#Variable Date    ITMEFD
#Variable Char    OPPCUR
#Variable Instance TECBUDAUT Using C_TECBUDAUT : #
#Variable Instance BUDLOG Using C_ALOG #
#Variable Instance STKVAL Using C_STKVAL

Local Integer ISTAT
Local Decimal WRKRATE
Local Decimal DRATE
Local Char    ITMPCCCOD(GLONPJCC)
Local Integer IRETLOG
Local Integer  CSTIDX           # Cost componenet
Local Decimal  CSTVAL           # Cost componenet Value
Local Integer CI

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------
  For CI = 1 To maxtab(STKVAL.MACHINE)
    If STKVAL.MACHINE(CI) <> null and find(STKVAL.MACHINE(CI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      CSTIDX = STKVAL.MACHINE(CI).MACIDX + 1
      CSTVAL = STKVAL.MACHINE(CI).MACCST
      If CSTVAL <> 0 Then
        Raz ITMPCCCOD
        ITMPCCCOD = fmet this.BUD_GET_COSTTYPE(3, CSTIDX)
        If ITMPCCCOD <> AVOID.ACHAR Then
          WRKRATE = CSTVAL * this.TAS(TASIDX).RITT(ITMIDX).ITTQTY
          Call CONVERT(this.ACTX, OPPCUR, this.CUR, OPPCUR, this.TCHCHGTYP, ITMEFD, WRKRATE, DRATE, ISTAT) From TRTDEV_SYRA
          If ISTAT = [V]CST_AOK Then
           WRKRATE = DRATE
           If TECBUDAUT.INCLOG = [V]CST_AYES Then
              IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES1(mess(295,2260,1), num$(WRKRATE)), 0)
           Endif
           [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._BUD_UPD_LINES(BUDIDX, ITMPCCCOD, [V]CST_AYES, ITMQTY, WRKRATE, ITMUOM, date$, TECBUDAUT, BUDLOG))
          Else
           If TECBUDAUT.INCLOG = [V]CST_AYES Then
             IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES2(mess(293,2260,1), OPPCUR, this.CUR), [V]CST_AERROR)
           Endif
          Endif
        Else
          IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES2(mess(964,2260,1),mess(3,7722,1) ,mess(CSTIDX,316,1)),[V]CST_AERROR)
        Endif
      Endif
    Endif
  Next CI
Return

#######################################################################################
$BUD_GET_STKVAL
#Value Integer  BUDMTHD  # Budget Method
#Value Integer  TSKIDX   # Task Index
#Value Integer  ITMIDX   # Item Index
#Value Date     EFFDTE   # Effective Date of Valuation
#Variable Instance STKVAL Using C_STKVAL

Local Decimal RETCOST
Local Tinyint PARDETVAL         # Detail Value
Local Char SECCVALMAJ(GLONVCR)
Local Char SECCVALMIN(GLONVCR)

  [L]ARET_VALUE = 0
  # --------------------------------
  PARUID = 0
  PARDETVAL = 0
  If dim(this.TAS(TSKIDX).RITT(ITMIDX).ECCVALMAJ) > 0 Then
    SECCVALMAJ = this.TAS(TSKIDX).RITT(ITMIDX).ECCVALMAJ
  Endif
  If dim(this.TAS(TSKIDX).RITT(ITMIDX).SECCVALMIN) > 0 Then
    SECCVALMIN = this.TAS(TSKIDX).RITT(ITMIDX).SECCVALMIN
  Endif

  Case BUDMTHD
    When 2
      # Standard Cost
      [L]ARET_VALUE = fmet STKVAL.GET_STD(this.TAS(TSKIDX).RITT(ITMIDX).ITMREF, this.OPEDEFFCY, SECCVALMAJ, this.TAS(TSKIDX).RITT(ITMIDX).ECCVALMIN, EFFDTE, PARUID, PARDETVAL)
    When 3
      # Revised standard
      [L]ARET_VALUE =  fmet STKVAL.GET_STD_REV(this.TAS(TSKIDX).RITT(ITMIDX).ITMREF, this.OPEDEFFCY, SECCVALMAJ, SECCVALMIN, EFFDTE, PARUID, PARDETVAL)
    When 4
      # Budget cost
      [L]ARET_VALUE =  fmet STKVAL.GET_STD_BUD(this.TAS(TSKIDX).RITT(ITMIDX).ITMREF, this.OPEDEFFCY, SECCVALMAJ, SECCVALMIN, EFFDTE, PARUID, PARDETVAL)
    When 5
      # Simulated cost
      [L]ARET_VALUE =  fmet STKVAL.GET_STD_SIM(this.TAS(TSKIDX).RITT(ITMIDX).ITMREF, this.OPEDEFFCY, SECCVALMAJ, SECCVALMIN, EFFDTE,PARUID, PARDETVAL)
  Endcase
Return

#######################################################################################
$BUD_GET_COSTTYPE
#Value Integer PARTYP   #PCGTYP Material, Lavour or Machine
#Value Integer PARIDX   #Cost Group Indexed component

  Raz [L]ARET_VALUE
  # --------------------------------
  Local File PJMCOSTGRP [PJGC]
  Case PARTYP
    When 1
      #Material
      Filter [PJGC] Where [F:PJGC]PCGTYP = PARTYP and [F:PJGC]PCGGRPMAT = PARIDX
      Read [PJGC]First
      If fstat = 0 Then
        [L]ARET_VALUE = [F:PJGC]PCCCOD
      Endif
    When 2
      #Labour
      Filter [PJGC] Where [F:PJGC]PCGTYP = PARTYP and [F:PJGC]PCGGRPLAB = PARIDX
      Read [PJGC]First
      If fstat = 0 Then
        [L]ARET_VALUE = [F:PJGC]PCCCOD
      Endif
    When 3
      #Machine
      Filter [PJGC] Where [F:PJGC]PCGTYP = PARTYP and [F:PJGC]PCGGRPMAC = PARIDX
      Read [PJGC]First
      If fstat = 0 Then
        [L]ARET_VALUE = [F:PJGC]PCCCOD
      Endif
  Endcase
  Filter [PJGC]
Return

#######################################################################################
$_BUD_UPD_LINES
#Value Integer NI
#Value Char WRKPCCCOD Using C_TECBUDAUT
#Value Integer PROCITM
#Value Decimal OPEQTY
#Value Decimal WRKRATE
#Value Char WRKUOM
#Value Date BUDDTE
#Variable Instance TECBUDAUT Using C_TECBUDAUT : #
#Variable Instance BUDLOG Using C_ALOG #

Local Integer BUDSUB
Local Integer BUDSUB1
Local Integer BUDSUB2
Local Integer BYPASS
Local Integer CURORI
Local Integer IRETLOG

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------
  # --------------------------------------------------------------------------------------------
  # Begin Simplify and Add only if not exist or update if from Automation
  ##############################################################################################
  CURORI = 2
  If PROCITM = [V]CST_AYES Then
    CURORI = 3
  Endif
  BUDSUB = 0
  BYPASS = [V]CST_ANO
  If maxtab(this.BUD(NI).BUDLIG) > 0 Then
    For BUDSUB1 = 1 To maxtab(this.BUD(NI).BUDLIG)
      If this.BUD(NI).BUDLIG(BUDSUB1) <> null and this.BUD(NI).BUDLIG(BUDSUB1).ASTALIN <> [V]CST_ADEL and this.BUD(NI).BUDLIG(BUDSUB1).ASTALIN <> [V]CST_ANEWDEL Then
        If this.BUD(NI).BUDLIG(BUDSUB1).PCCCOD = WRKPCCCOD Then
          If this.BUD(NI).BUDLIG(BUDSUB1).ORI = 2 or this.BUD(NI).BUDLIG(BUDSUB1).ORI = 3 or this.BUD(NI).BUDLIG(BUDSUB1).ORI = 6 Then
            If TECBUDAUT.INCOWRT = [V]CST_AYES Then
              BUDSUB = BUDSUB1
            Else
              If this.BUD(NI).BUDLIG(BUDSUB1).ASTALIN <> [V]CST_ANEW Then
                BYPASS = [V]CST_AYES
              Else
                BUDSUB = BUDSUB1
              Endif
            Endif
          Else
            BYPASS = [V]CST_AYES
            If TECBUDAUT.INCLOG = [V]CST_AYES Then
              IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES2(mess(1014,2260,1), this.BUD(NI).PBUCOD,WRKPCCCOD), [V]CST_AERROR)
            Endif
          Endif
        Endif
      Endif
    Next BUDSUB1
  Endif
  # -----------------------------------
  If BYPASS = [V]CST_ANO Then
    If BUDSUB = 0 Then
      BUDSUB = fmet this.BUD(NI).ADDLINE("BUDLIG",[V]CST_ALASTPOS)
      If BUDSUB = [V]CST_ANOTDEFINED Then
        If TECBUDAUT.INCLOG = [V]CST_AYES Then
          IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES2(mess(336,2260,1), this.BUD(NI).PBUCOD,WRKPCCCOD), [V]CST_AERROR)
        Endif
      Else
        this.BUD(NI).BUDLIG(BUDSUB).ORI = CURORI
      Endif
    Else
      If this.BUD(NI).BUDLIG(BUDSUB).PLBFLGREM = [V]CST_AYES or this.BUD(NI).BUDLIG(BUDSUB).ORI = 1 or this.BUD(NI).BUDLIG(BUDSUB).PLBAMTREM <> 0 Then
        BYPASS = [V]CST_AYES
      Endif
      If this.BUD(NI).BUDLIG(BUDSUB).ASTALIN = [V]CST_ALL Then
        If this.BUD(NI).BUDLIG(BUDSUB).ORI = CURORI or this.BUD(NI).BUDLIG(BUDSUB).ORI = 6 Then
          Raz this.BUD(NI).BUDLIG(BUDSUB).PLBQTY
          Raz this.BUD(NI).BUDLIG(BUDSUB).PLBAMT
        Endif
      Endif
    Endif
    If BYPASS = [V]CST_ANO Then
      this.BUD(NI).BUDLIG(BUDSUB).TCHACTION = "BUD_AUTOMATION"
      # -----------------------------------
      #Send AMT rather than unit price
      this.BUD(NI).BUDLIG(BUDSUB).PCCCOD = WRKPCCCOD
      If CURORI <> this.BUD(NI).BUDLIG(BUDSUB).ORI Then
        this.BUD(NI).BUDLIG(BUDSUB).ORI = 6
      Else
        this.BUD(NI).BUDLIG(BUDSUB).ORI = CURORI
      Endif
      # If Task Product
      If PROCITM = [V]CST_AYES Then
        this.BUD(NI).BUDLIG(BUDSUB).PLBPRI = 0
        If this.BUD(NI).BUDLIG(BUDSUB).ORI = 3 Then
          this.BUD(NI).BUDLIG(BUDSUB).PLBQTY = 0
          this.BUD(NI).BUDLIG(BUDSUB).PLBU   = AVOID.ACHAR
        Endif
        this.BUD(NI).BUDLIG(BUDSUB).PLBAMT = this.BUD(NI).BUDLIG(BUDSUB).PLBAMT + arr(WRKRATE, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(this.CUR,"CURRND"))
      Else
        # If Task Operation
        this.BUD(NI).BUDLIG(BUDSUB).PLBQTY = this.BUD(NI).BUDLIG(BUDSUB).PLBQTY + OPEQTY #send 0 on qty for product
        # Set to correct Decimal places for currency
        this.BUD(NI).BUDLIG(BUDSUB).PLBPRI = arr(WRKRATE, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(this.CUR,"CURRND"))
        this.BUD(NI).BUDLIG(BUDSUB).PLBU   = WRKUOM #send blank when Product
        If this.BUD(NI).BUDLIG(BUDSUB).ORI = 2 Then
          this.BUD(NI).BUDLIG(BUDSUB).PLBDATBUD = BUDDTE
          this.BUD(NI).BUDLIG(BUDSUB).PLBAMT = this.BUD(NI).BUDLIG(BUDSUB).PLBAMT + (arr(WRKRATE, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(this.CUR,"CURRND"))*OPEQTY)
          # Start Aggregate and derive weighted unit price when multiple rates apply
          If OPEQTY <> this.BUD(NI).BUDLIG(BUDSUB).PLBQTY and this.BUD(NI).BUDLIG(BUDSUB).PLBQTY <> 0 Then
            WRKRATE = this.BUD(NI).BUDLIG(BUDSUB).PLBAMT / this.BUD(NI).BUDLIG(BUDSUB).PLBQTY
            this.BUD(NI).BUDLIG(BUDSUB).PLBPRI = arr(WRKRATE, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(this.CUR,"CURRND"))
            this.BUD(NI).BUDLIG(BUDSUB).PLBAMT = this.BUD(NI).BUDLIG(BUDSUB).PLBPRI * this.BUD(NI).BUDLIG(BUDSUB).PLBQTY
          Endif
        Endif
        If this.BUD(NI).BUDLIG(BUDSUB).ORI = 6 Then
          this.BUD(NI).BUDLIG(BUDSUB).PLBAMT = this.BUD(NI).BUDLIG(BUDSUB).PLBAMT + (arr(WRKRATE, fmet this.ACTX.ACACHE.ACUR.AGETVALDEC(this.CUR,"CURRND"))*OPEQTY)
          this.BUD(NI).BUDLIG(BUDSUB).PLBPRI = 0
        Endif
      Endif
      this.BUD(NI).BUDLIG(BUDSUB).PLBDATBUD = date$
      this.BUD(NI).BUDLIG(BUDSUB).PLBPRIFRC = [V]CST_AYES
      If TECBUDAUT.INCLOG = [V]CST_AYES
        IRETLOG = fmet BUDLOG.APUTLINE(func AFNC.MES1(mess(261,2260,1), this.BUD(NI).PBUCOD+" "+num$(this.BUD(NI).BUDLIG(BUDSUB).PLBSEQ)+" "+WRKPCCCOD) ,[V]CST_AWARNING)
      Endif
    Endif
  Endif
Return

#######################################################################################
$BUD_IS_PARENT
#Value Char COD ()
#Local Integer ARET_VALUE

Local Integer NI
Local Integer NI1

  [L]ARET_VALUE = [V]CST_ANO
  If COD <> AVOID.ACHAR Then
    NI = find(COD, this.BUD(1..maxtab(this.BUD)).PBUPAE)
    While NI > 0
      If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        [L]ARET_VALUE = [V]CST_AYES
        Break
      Else
        NI1 = NI
        NI = find(COD, this.BUD(NI+1..maxtab(this.BUD)).PBUPAE)
        If NI > 0 Then
          NI += NI1
        Endif
      Endif
    Wend
  Endif
Return

#######################################################################################
$BUD_COUNT
Local Integer NI

  [L]ARET_VALUE = 0
  For NI = 1 To maxtab(this.BUD)
    If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      [L]ARET_VALUE += 1
    Endif
  Next NI
Return

#######################################################################################
$BUD_CHECK_PBUPAE_VALID
#Value Char COD ()
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer IINDEX
Local Integer ISTATUS
Local Integer NI
Local Integer NI1
Local Integer IRET

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------
  If COD = AVOID.ACHAR Then
    # If COD is empty nothing to do
    Return
  Endif
  # --------------------------------
  ILINE = fmet this.BUD_GET_INDEX(COD)
  If ILINE < 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("PBUPAE", func AFNC.MES1(mess(239,2260,1), COD), [V]CST_AERROR))
    Return
  Endif
  # --------------------------------
  If this.OPPIMPT = [V]CST_ANO Then
    If fmet this.TAS_IS_BUDGET_USED(COD) = [V]CST_AYES Then
      NI = find(COD, this.TAS(1..maxtab(this.TAS)).PBUCOD)
      While NI > 0
        If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If this.TAS(NI).TASTYP = 2 or fmet this.TAS_IS_PARENT(this.TAS(NI).TASCOD) = [V]CST_ANO Then
            [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("PBUPAE", func AFNC.MES1(mess(438,2260,1), COD), [V]CST_AERROR))
            Break
          Endif
          NI1 = NI
          NI = find(COD, this.TAS(NI+1..maxtab(this.TAS)).PBUCOD)
          If NI > 0 Then
            NI += NI1
          Endif
        Else
          NI1 = NI
          NI = find(COD, this.TAS(NI+1..maxtab(this.TAS)).PBUCOD)
          If NI > 0 Then
            NI += NI1
          Endif
        Endif
      Wend
    Endif
  Endif
  # --------------------------------
  If this.BUD(ILINE).PBUIMP = [V]CST_ANO and this.BUD(ILINE).snapshot.PBUIMP = [V]CST_AYES Then
    # If the parent budget is not chargeable, and was chargeable before
    IRET = fmet this.BUD(ILINE).PIMPL.IS_USED_IN_ERP()
    If IRET = [V]CST_AYES Then
      ISTATUS = fmet this.SETERROR("PBUPAE", func AFNC.MES1(mess(439,2260,1), COD), [V]CST_AERROR)
    Endif
    [L]ARET_VALUE = max([L]ARET_VALUE,ISTATUS)
  Endif
  # --------------------------------
  If this.BUD(ILINE).PBUPAE = AVOID.ACHAR Then
    # If the budget line haven't a parent code, there is nothing to do
    Return
  Endif
  # --------------------------------
  If this.BUD(ILINE).PBUCOD = this.BUD(ILINE).PBUPAE Then
    # the parent code must be different of the budget code
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("PBUPAE", func AFNC.MES2(mess(238,2260,1), this.BUD(ILINE).PBUPAE, this.BUD(ILINE).PBUCOD), [V]CST_AERROR))
    Return
  Endif
  # --------------------------------
  IINDEX = fmet this.BUD_GET_INDEX(this.BUD(ILINE).PBUPAE)
  If IINDEX < 0 Then
    # the parent budget code must exist as a budget
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("PBUPAE", func AFNC.MES1(mess(239,2260,1), this.BUD(ILINE).PBUPAE), [V]CST_AERROR))
    Return
  Endif
  # --------------------------------
  # Recursive method which check that the curent parent is not parent of a lower level
  ISTATUS = fmet this._BUD_CHECK_PBUPAE_VALID(this.BUD(ILINE).PBUCOD, this.BUD(ILINE).PBUPAE)
  [L]ARET_VALUE = max([L]ARET_VALUE,ISTATUS)
  # --------------------------------
Return

#######################################################################################
# Recursive method which check that the PARENT budget code given is not a parent on a lower level
$_BUD_CHECK_PBUPAE_VALID
#Value Char COD ()
#Value Char PARENT ()
#Local Integer ARET_VALUE

Local Integer NI
Local Integer NI1

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------
  If COD = AVOID.ACHAR Then
    # If COD is empty nothing to do
    Return
  Endif
  NI = find(COD, this.BUD(1..maxtab(this.BUD)).PBUPAE)
  While NI > 0
    If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If fmet this.BUD_IS_PARENT(this.BUD(NI).PBUCOD) = [V]CST_AYES Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._BUD_CHECK_PBUPAE_VALID(this.BUD(NI).PBUCOD, PARENT))
        If [L]ARET_VALUE >= [V]CST_AERROR Then
          Break
        Endif
      Endif
      If this.BUD(NI).PBUPAE = PARENT Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("PBUPAE", func AFNC.MES1(mess(240,2260,1), PARENT), [V]CST_AERROR))
        Break
      Endif
    Endif
    NI1 = NI
    NI = find(COD, this.BUD(NI+1..maxtab(this.BUD)).PBUPAE)
    If NI > 0 Then
      NI += NI1
    Endif
  Wend
Return

#######################################################################################
$BUD_DELIVERY
#Value Char BUDGET ()
#Variable Instance LOGFILE Using C_ALOG
#Variable Instance TECOPPACT Using C_TECOPPACT
#Local Integer ARET_VALUE

Local Integer ILINE

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------
  # Preliminary checkes
  If this.TCHACTION <> "BUDGET_DELIVERY" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  If this.OPPSTATE <> 2 and this.OPPSTATE <> 3 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(204,2260,1), mess(this.OPPSTATE,2249,1)), [V]CST_AERROR))
    Return
  Endif
  ILINE = fmet this.BUD_GET_INDEX(BUDGET)
  If ILINE < 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(239,2260,1), BUDGET), [V]CST_AERROR))
    Return
  Endif
  If this.BUD(ILINE).PBUSTATE <> 2 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(242,2260,1), mess(this.BUD(ILINE).PBUSTATE,2251,1)), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._BUD_DELIVERY(BUDGET, LOGFILE, TECOPPACT))
  # -------------------
Return

#######################################################################################
$_BUD_DELIVERY
#Value Char BUDGET ()
#Variable Instance LOGFILE Using C_ALOG : #
#Variable Instance TECOPPACT Using C_TECOPPACT
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer IISPARENT
Local Integer NI
Local Integer NI1

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------
  # Preliminary checkes
  If this.TCHACTION <> "BUDGET_DELIVERY" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  ILINE = fmet this.BUD_GET_INDEX(BUDGET)
  IISPARENT = fmet this.BUD_IS_PARENT(BUDGET)
  # -------------------
  If IISPARENT = [V]CST_AYES Then
    NI = find(BUDGET, this.BUD(1..maxtab(this.BUD)).PBUPAE)
    While NI > 0
      If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._BUD_DELIVERY(this.BUD(NI).PBUCOD, LOGFILE, TECOPPACT))
        If [L]ARET_VALUE >= [V]CST_AERROR Then
          Break
        Endif
      Endif
      NI1 = NI
      NI = find(BUDGET, this.BUD(NI+1..maxtab(this.BUD)).PBUPAE)
      If NI > 0 Then
        NI += NI1
      Endif
    Wend
  Endif
  # -------------------
  If [L]ARET_VALUE < [V]CST_AERROR Then
    this.BUD(ILINE).PBUCOMTEX = TECOPPACT.COMTEX
    If this.BUD(ILINE).PBUSTATE = 2 Then
      # -------------------
      this.BUD(ILINE).TCHACTION = "DELIVERY"
      this.BUD(ILINE).PBUSTATE = 3
      If TECOPPACT.EVTDAT = [0/0/0] Then
        this.BUD(ILINE).PBUDATO = date$
      Else
        this.BUD(ILINE).PBUDATO = TECOPPACT.EVTDAT
      Endif
      this.BUD(ILINE).PBUCOMTEX = TECOPPACT.COMTEX
      # -------------------
      If this.BUD(ILINE).PBUIMP = [V]CST_AYES Then
        # Only imputable budgets become enable
        this.BUD(ILINE).PIMPL.TCHACTION = "STATUS"
        this.BUD(ILINE).PIMPL.PIMSTA = [V]CST_AYES
      Else
        # To be sure they're not enable
        this.BUD(ILINE).PIMPL.TCHACTION = "STATUS"
        this.BUD(ILINE).PIMPL.PIMSTA = [V]CST_ANO
      Endif
      # -------------------
    Endif
  Endif
  # -------------------
Return

#######################################################################################
$BUD_CLOSING
#Value Char BUDGET ()
#Variable Instance LOGFILE Using C_ALOG
#Variable Instance TECOPPACT Using C_TECOPPACT
#Local Integer ARET_VALUE

Local Integer ILINE

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------
  # Preliminary checkes
  If this.TCHACTION <> "BUDGET_CLOSING" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  ILINE = fmet this.BUD_GET_INDEX(BUDGET)
  If ILINE < 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(239,2260,1), BUDGET), [V]CST_AERROR))
    Return
  Endif
  If this.BUD(ILINE).PBUSTATE = 4 or this.BUD(ILINE).PBUSTATE = 9 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(242,2260,1), mess(this.BUD(ILINE).PBUSTATE,2251,1)), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  # Issue X3-101833 - 2018-08-02 by FGR : BEGIN
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.TAS_RITT_CLOSE_RELEASE_UNDER(AVOID.ACHAR, BUDGET))
  # Issue X3-101833 - 2018-08-02 by FGR : END
  # -------------------
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._BUD_CLOSING(BUDGET, LOGFILE, TECOPPACT))
  # -------------------
Return

#######################################################################################
$_BUD_CLOSING
#Value Char BUDGET ()
#Variable Instance LOGFILE Using C_ALOG
#Variable Instance TECOPPACT Using C_TECOPPACT
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer IISPARENT
Local Integer NI
Local Integer NI1

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------
  # Preliminary checkes
  If this.TCHACTION <> "BUDGET_CLOSING" and this.TCHACTION <> "CLOSING" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  ILINE = fmet this.BUD_GET_INDEX(BUDGET)
  IISPARENT = fmet this.BUD_IS_PARENT(BUDGET)
  If this.TCHACTION = "BUDGET_CLOSING" Then
    # -------------------
    If IISPARENT = [V]CST_AYES Then
      NI = find(BUDGET, this.BUD(1..maxtab(this.BUD)).PBUPAE)
      While NI > 0
        If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._BUD_CLOSING(this.BUD(NI).PBUCOD, LOGFILE, TECOPPACT))
          If [L]ARET_VALUE >= [V]CST_AERROR Then
            Break
          Endif
        Endif
        NI1 = NI
        NI = find(BUDGET, this.BUD(NI+1..maxtab(this.BUD)).PBUPAE)
        If NI > 0 Then
          NI += NI1
        Endif
      Wend
    Endif
  Endif
  # -------------------
  If [L]ARET_VALUE < [V]CST_AERROR Then
    If this.BUD(ILINE).PBUSTATE <> 4 and
&     ((this.TCHACTION = "BUDGET_CLOSING" and this.BUD(ILINE).PBUSTATE <> 9) or (this.TCHACTION = "CLOSING"))
&   Then
      this.BUD(ILINE).PBUCOMTEX = TECOPPACT.COMTEX
      # -------------------
      this.BUD(ILINE).TCHACTION = "CLOSING"
      this.BUD(ILINE).PBUSTATE = 4
      # -------------------
      If TECOPPACT.EVTDAT = [0/0/0] Then
        this.BUD(ILINE).PBUDATS = date$
      Else
        this.BUD(ILINE).PBUDATS = TECOPPACT.EVTDAT
      Endif
      this.BUD(ILINE).PBUCOMTEX = TECOPPACT.COMTEX
      # -------------------
      If this.BUD(ILINE).PBUIMP = [V]CST_AYES Then
        If this.BUD(ILINE).PIMPL.PIMSTA = [V]CST_AYES Then
          this.BUD(ILINE).PIMPL.TCHACTION = "STATUS"
          this.BUD(ILINE).PIMPL.PIMSTA = [V]CST_ANO
        Endif
      Endif
      # -------------------
      If this.TCHACTION = "BUDGET_CLOSING" Then
        NI = find(BUDGET, this.TAS(1..maxtab(this.TAS)).PBUCOD)
        While NI > 0
          If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
            If this.TAS(NI).TASSTATE <> 4 Then
              IRET = fmet this._TAS_CLOSING(this.TAS(NI).TASCOD, LOGFILE, TECOPPACT)
              [L]ARET_VALUE = max([L]ARET_VALUE, IRET)
            Endif
          Endif
          NI1 = NI
          NI = find(BUDGET, this.TAS(NI+1..maxtab(this.TAS)).PBUCOD)
          If NI > 0 Then
            NI += NI1
          Endif
        Wend
      Endif
    Endif
  Endif
Return

#######################################################################################
$BUD_SUSPENSION
#Value Char BUDGET ()
#Variable Instance LOGFILE Using C_ALOG
#Variable Instance TECOPPACT Using C_TECOPPACT
#Local Integer ARET_VALUE

Local Integer ILINE

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------
  # Preliminary checkes
  If this.TCHACTION <> "BUDGET_SUSPENSION" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  ILINE = fmet this.BUD_GET_INDEX(BUDGET)
  If ILINE < 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(239,2260,1), BUDGET), [V]CST_AERROR))
    Return
  Endif
  If this.BUD(ILINE).PBUSTATE = 4 or this.BUD(ILINE).PBUSTATE = 9 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(242,2260,1), mess(this.BUD(ILINE).PBUSTATE,2251,1)), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._BUD_SUSPENSION(BUDGET, LOGFILE, TECOPPACT))
  # -------------------
Return

#######################################################################################
$_BUD_SUSPENSION
#Value Char BUDGET ()
#Variable Instance LOGFILE Using C_ALOG
#Variable Instance TECOPPACT Using C_TECOPPACT
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer IISPARENT
Local Integer NI
Local Integer NI1

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------
  # Preliminary checkes
  If this.TCHACTION <> "SUSPENSION" and this.TCHACTION <> "BUDGET_SUSPENSION" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  ILINE = fmet this.BUD_GET_INDEX(BUDGET)
  IISPARENT = fmet this.BUD_IS_PARENT(BUDGET)
  If this.TCHACTION = "BUDGET_SUSPENSION" Then
    # -------------------
    If IISPARENT = [V]CST_AYES Then
      NI = find(BUDGET, this.BUD(1..maxtab(this.BUD)).PBUPAE)
      While NI > 0
        If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._BUD_SUSPENSION(this.BUD(NI).PBUCOD, LOGFILE, TECOPPACT))
          If [L]ARET_VALUE >= [V]CST_AERROR Then
            Break
          Endif
        Endif
        NI1 = NI
        NI = find(BUDGET, this.BUD(NI+1..maxtab(this.BUD)).PBUPAE)
        If NI > 0 Then
          NI += NI1
        Endif
      Wend
    Endif
  Endif
  # -------------------
  If [L]ARET_VALUE < [V]CST_AERROR Then
    If this.BUD(ILINE).PBUSTATE <> 4 and this.BUD(ILINE).PBUSTATE <> 9 Then
      this.BUD(ILINE).PBUCOMTEX = TECOPPACT.COMTEX
      # -------------------
      this.BUD(ILINE).TCHACTION = "SUSPENSION"
      this.BUD(ILINE).PBUSTATE = 9
      # -------------------
      If TECOPPACT.EVTDAT = [0/0/0] Then
        this.BUD(ILINE).PBUDATH = date$
      Else
        this.BUD(ILINE).PBUDATH = TECOPPACT.EVTDAT
      Endif
      this.BUD(ILINE).PBUCOMTEX = TECOPPACT.COMTEX
      # -------------------
      If this.BUD(ILINE).PBUIMP = [V]CST_AYES Then
        If this.BUD(ILINE).PIMPL.PIMSTA = [V]CST_AYES Then
          this.BUD(ILINE).PIMPL.TCHACTION = "STATUS"
          this.BUD(ILINE).PIMPL.PIMSTA = [V]CST_ANO
        Endif
      Endif
      # -------------------
      # linked tasks status not changed, but linked tasks become disable
      NI = find(BUDGET, this.TAS(1..maxtab(this.TAS)).PBUCOD)
      While NI > 0
        If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If this.TAS(NI).TASSTATE <> 4 and this.TAS(NI).TASSTATE <> 9 Then
            IRET = fmet this._TAS_SUSPENSION(this.TAS(NI).TASCOD, LOGFILE, TECOPPACT)
            [L]ARET_VALUE = max([L]ARET_VALUE, IRET)
          Endif
        Endif
        NI1 = NI
        NI = find(BUDGET, this.TAS(NI+1..maxtab(this.TAS)).PBUCOD)
        If NI > 0 Then
          NI += NI1
        Endif
      Wend
    Endif
  Endif
Return

#######################################################################################
$BUD_REACTIVATE
#Value Char BUDGET ()
#Variable Instance LOGFILE Using C_ALOG
#Variable Instance TECOPPACT Using C_TECOPPACT
#Local Integer ARET_VALUE

Local Integer ILINE

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------
  # Preliminary checkes
  If this.TCHACTION <> "BUDGET_REACTIVATE" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  ILINE = fmet this.BUD_GET_INDEX(BUDGET)
  If ILINE < 1 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(239,2260,1), BUDGET), [V]CST_AERROR))
    Return
  Endif
  If this.BUD(ILINE).PBUSTATE <> 3 and this.BUD(ILINE).PBUSTATE <> 4 and this.BUD(ILINE).PBUSTATE <> 9 Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", func AFNC.MES1(mess(242,2260,1), mess(this.BUD(ILINE).PBUSTATE,2251,1)), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._BUD_REACTIVATE(BUDGET, LOGFILE, TECOPPACT))
  # -------------------
Return

#######################################################################################
$_BUD_REACTIVATE
#Value Char BUDGET ()
#Variable Instance LOGFILE Using C_ALOG
#Variable Instance TECOPPACT Using C_TECOPPACT
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer IISPARENT
Local Integer NI
Local Integer NI1
Local Integer IRET

  [L]ARET_VALUE = [V]CST_AOK
  # --------------------------------
  # Preliminary checkes
  If this.TCHACTION <> "BUDGET_REACTIVATE" and this.TCHACTION <> "REACTIVATE" Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.SETERROR("", mess(196,2260,1), [V]CST_AERROR))
    Return
  Endif
  # -------------------
  ILINE = fmet this.BUD_GET_INDEX(BUDGET)
  IISPARENT = fmet this.BUD_IS_PARENT(BUDGET)
  If this.TCHACTION = "BUDGET_REACTIVATE" Then
    # -------------------
    If IISPARENT = [V]CST_AYES Then
      NI = find(BUDGET, this.BUD(1..maxtab(this.BUD)).PBUPAE)
      While NI > 0
        If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          [L]ARET_VALUE = max([L]ARET_VALUE, fmet this._BUD_REACTIVATE(this.BUD(NI).PBUCOD, LOGFILE, TECOPPACT))
          If [L]ARET_VALUE <= [V]CST_AERROR Then
            Break
          Endif
        Endif
        NI1 = NI
        NI = find(BUDGET, this.BUD(NI+1..maxtab(this.BUD)).PBUPAE)
        If NI > 0 Then
          NI += NI1
        Endif
      Wend
    Endif
  Endif
  # -------------------
  If [L]ARET_VALUE < [V]CST_AERROR Then
    If this.BUD(ILINE).PBUSTATE = 3 or this.BUD(ILINE).PBUSTATE = 4 or this.BUD(ILINE).PBUSTATE = 9 Then
      this.BUD(ILINE).PBUCOMTEX = TECOPPACT.COMTEX
      # -------------------
      this.BUD(ILINE).TCHACTION = "REACTIVATE"
      # -------------------
      If this.BUD(ILINE).PBUDATH <> [0/0/0] and this.BUD(ILINE).PBUDATS <> [0/0/0] and this.TCHACTION = "REACTIVATE" Then
        this.BUD(ILINE).PBUSTATE = 9
      Elsif this.BUD(ILINE).PBUDATO <> [0/0/0] Then
        this.BUD(ILINE).PBUSTATE = 3
      Elsif this.OPPSTATE = 1 Then
        this.BUD(ILINE).PBUSTATE = 1
      Else
        this.BUD(ILINE).PBUSTATE = 2
      Endif
      this.BUD(ILINE).PBUCOMTEX = TECOPPACT.COMTEX
      # -------------------
      If this.BUD(ILINE).PBUIMP = [V]CST_AYES Then
        If this.BUD(ILINE).PIMPL.PIMSTA = [V]CST_ANO and this.BUD(ILINE).PBUSTATE = 2 Then
          this.BUD(ILINE).PIMPL.TCHACTION = "STATUS"
          this.BUD(ILINE).PIMPL.PIMSTA = [V]CST_AYES
        Endif
      Endif
      # -------------------
      NI = find(BUDGET, this.TAS(1..maxtab(this.TAS)).PBUCOD)
      While NI > 0
        If this.TAS(NI) <> null and find(this.TAS(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If this.BUD(ILINE).snapshot.PBUSTATE = 9 Then
            # If budget was suspended
            If this.TAS(NI).TASSTATE = 9 and this.TAS(NI).TASDATH = this.BUD(ILINE).snapshot.PBUDATH Then
              # If task suspended on the same date than the budget : task is reactived
              IRET = fmet this._TAS_REACTIVATE(this.TAS(NI).TASCOD, LOGFILE, TECOPPACT)
              [L]ARET_VALUE = max([L]ARET_VALUE, IRET)
            Endif
          Elsif this.BUD(ILINE).snapshot.PBUSTATE = 4 Then
            # If budget was closed
            If this.TAS(NI).TASSTATE = 4 and this.TAS(NI).TASDATS = this.BUD(ILINE).snapshot.PBUDATS Then
              # If task suspended on the same date than the budget : task is reactived
              IRET = fmet this._TAS_REACTIVATE(this.TAS(NI).TASCOD, LOGFILE, TECOPPACT)
              [L]ARET_VALUE = max([L]ARET_VALUE, IRET)
            Endif
          Endif
        Endif
        NI1 = NI
        NI = find(BUDGET, this.TAS(NI+1..maxtab(this.TAS)).PBUCOD)
        If NI > 0 Then
          NI += NI1
        Endif
      Wend
    Endif
  Endif
Return

#######################################################################################
$BUD_COMPUTE_QTYBUD_ALL_BUDGETS
#Value Char UOM ()
#Local Decimal ARET_VALUE

Local Integer NI

  [L]ARET_VALUE = 0
  For NI = 1 To maxtab(this.BUD)
    If this.BUD(NI) <> null and find(this.BUD(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If this.BUD(NI).PBUPAE = AVOID.ACHAR Then
        [L]ARET_VALUE += fmet this.BUD_COMPUTE_QTYBUD(this.BUD(NI).PBUCOD, UOM)
      Endif
    Endif
  Next NI
Return

#######################################################################################
$BUD_COMPUTE_QTYBUD
#Value Char BUD ()
#Value Char UOM ()
