      If this.BUD(NI).PBUPAE = AVOID.ACHAR Then
        [L]ARET_VALUE += fmet this.BUD_COMPUTE_MNTBUD(this.BUD(NI).PBUCOD)
      Endif
    Endif
  Next NI
Return

