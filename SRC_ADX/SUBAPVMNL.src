#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion objet APV
#
#    Action SELMENU - Aide choix ligne de menu
#
$ACTION
Case ACTION
 When "SEL_LISTE"   : Gosub SEL_LISTE
 When "FIN_LISTE"   : Gosub FIN_LISTE
Endcase
Return

# - = - = - = - = - = - = - = - = - = - = - = - = - = - = - = - = - = - = - = - = -
#    Action SELMENU - Aide choix ligne de menu
$SEL_LISTE
Local Integer NOLIB
NOLIB = val(PARAM(1))
If NOLIB=0
    OK=0
Elsif NOLIB<100
 TIT = mess(NOLIB,0,1)
Else
 TIT = mess(NOLIB-200,200,1)
Endif
NBTEX = len(mess(0,NOLIB,1))
For I=1 To NBTEX
 TEX(I) = num$(I)
 TEXTE(I) = mess(I,NOLIB,1)
Next I
Return

$FIN_LISTE
Return

