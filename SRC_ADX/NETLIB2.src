#<AdxTL>@(#)0.0.0.0 $Revision$
#############################################################################################################################
## This library contains the subprograms called by the Generate/Post button in the BPOINET function
## Called from the GENNET action that opens the DGENNET window required to enter the post date
#############################################################################################################################
#*X3-39795   MDJ  Manage ORIGIN and ORICOD fields in GL Entry
#########################################################
$ACTION
Case ACTION
 When "CONTROLE" : Gosub CONTROLE
 When "EXEC"     : Gosub EXEC
 When Default
Endcase
Return

#########################################################
$CONTROLE
TMP=1  : TIT="T" : # Operation in progress
Return

#########################################################
$EXEC
Local Integer I, J
Local Char    VTYP(GLONGTE)
Local Char    VNUM(GLONVCR)
Local Integer VLIN, VIND
Local Char    PCEAUTO(GLONGAU)
Local Integer STAT
Local Char    MESSA(100)
Local Char    CRIT(255)                    : # General ledger of the company
Local Char    FLD1(30), FLD2(30), FLD3(30) : # Contain each key value of the NETAUTO table
Local Integer VLED
Local Integer NBLET , TBLET(1..2) , DUDLIG(1..2)
Local Decimal AMTIPT(1..2)
#*X3-39795 Local Char    TZONE(10)(1..1)   : # Table des zones à forcer (Ex:réference interne)
#*X3-39795 Local Char    TVAL(20)(1..1)    : # Table des valeurs des zones à forcer
Local Char    TZONE(10)(1..10) : # Table of the zones to be forced (Ex: ORICOD)   #*X3-39795
Local Char    TVAL(30)(1..10)  : # Table of values for zones to be forced         #*X3-39795

If clalev([F:NTO])=0  : Local File NETAUTO    [NTO] : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY] : Endif
If clalev([F:DAE])=0  : Local File GACCENTRYD [DAE] : Endif

If !GSERVEUR
 Call OUVRE_TRACE(mess(322,117,1))From LECFIC
Endif
Call ECR_TRACE(mess(322,117,1),0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(2,45,1)-":"-[M:BPOI]CPYSEL,0) From GESECRAN
If [M:BPOI]ALLFCY = 2
 Call ECR_TRACE(mess(3,45,1)-":"-mess(20,197,1),0) From GESECRAN
Else
 Call ECR_TRACE(mess(3,45,1)-":"-[M:BPOI]FCYSEL,0) From GESECRAN
Endif
If [M:BPOI]ALLSAC = 2
 Call ECR_TRACE(mess(27,102,1)-":"-mess(20,197,1),0) From GESECRAN
Else
 Call ECR_TRACE(mess(27,102,1)-":"-[M:BPOI]GRPSAC-[M:BPOI]SACSEL,0) From GESECRAN
Endif
Call ECR_TRACE(mess(31,105,1)-":"-[M:BPOI]BPRSEL,0) From GESECRAN
Call ECR_TRACE(mess(18,105,1)-":"-[M:BPOI]CURSEL,0) From GESECRAN
If [M:BPOI]DUDDATDEB<>[0/0/0] | [M:BPOI]DUDDATFIN<>[0/0/0]
 Call ECR_TRACE(mess(188,107,1)-":"-mess(94,100,1)-string$([M:BPOI]DUDDATDEB<>[0/0/0],format$(GFMDAT,[M:BPOI]DUDDATDEB))
&             -mess(95,100,1)-string$([M:BPOI]DUDDATFIN<>[0/0/0],format$(GFMDAT,[M:BPOI]DUDDATFIN)),0) From GESECRAN
Else
 Call ECR_TRACE(mess(188,107,1)-":",0) From GESECRAN
Endif
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

Call PARAML([M:BPOI]CPYSEL,"GAUNET",[L]PCEAUTO) From ADOVAL
If [L]PCEAUTO="" : [L]PCEAUTO="NETLI" : Endif

Call LECLEDMAIN(1,[M:BPOI]CPYSEL,VLED) From CPTDIV

Call DEBTRANS From GLOCK
Gosub VALID_NETAUTO

If !GSERVEUR
 Call FERME_TRACE From LECFIC
 TRA=1
Endif
Return


#########################################################
$VALID_NETAUTO
GOK=1
Trbegin [NTO]
 ## Load table
 Gosub WRI_NETAUTO
 If GOK=0
  Call ECR_TRACE(mess(67,121,1),1) From GESECRAN
  Goto AB_VALID_NETAUTO
 Endif

 If clalev([M:HAEW])=0 : Local Mask GACCENTW   [HAEW] : Endif
 If clalev([M:HAEF])=0 : Local Mask GACCENTFMT [HAEF] : Endif
 CRIT = "UIDUSR="+num$(adxuid(1))-" & ACCNUMVCR="+num$(0)
 TZONE(1)= "REFINT" :  TVAL(1)= "NETLI"-[M:BPOI]BPRSEL
 TZONE(5)= "ORIGIN"  :  TVAL(5)= "2"         #Automatic loading  #*X3-39795
 TZONE(6)= "ORICOD"  :  TVAL(6)= [L]PCEAUTO                      #*X3-39795
 ## Posting
 Call VALPCE4([L]PCEAUTO,CRIT,STAT,MESSA,TZONE,TVAL) From CPTAUTO
 If STAT
  Call ECR_TRACE(mess(67,121,1),1) From GESECRAN
  Call ECR_TRACE(MESSA,1) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN
  Goto AB_VALID_NETAUTO
 Endif

 Call DELOCK("HAE") From GLOCK

 ## Updating + Matching
 For I=0 To [M:HAEW]NB-1
  If [M:HAEW]LEDTYP(I)=VLED
   Raz VTYP, VNUM, VLIN
   CRIT   = [M:HAEW]CRITGRPIMP(I)
   J = instr(1,CRIT,'/')
   If J   # account to match
    FLD1 = left$(CRIT,J-1)
    CRIT = right$(CRIT,J+1)
    J = instr(1,CRIT,'/')
    If J
     FLD2 = left$(CRIT,J-1)
     FLD3 = right$(CRIT,J+1)
     Gosub UPD_NETAUTO
     If GOK=0 : Break : Endif
     Read [DAE]DAE2=[F:NTO]ACCNUM
     If !fstat
      VTYP = [F:DAE]TYP
      VNUM = [F:DAE]NUM
      VLIN = [F:DAE]LIN
      Gosub LETTRAGE
     Endif
     If GOK=0 : Break : Endif
    Endif
   Endif
  Endif
 Next
 If GOK=0
  Call ECR_TRACE(mess(67,121,1),1) From GESECRAN
  Goto AB_VALID_NETAUTO
 Endif
 Call ECR_TRACE(mess(40,107,1)-GTYPPCE-MESSA,0) From GESECRAN
 Call ECR_TRACE("",0) From GESECRAN

 FIN = 1
Commit
Return

#########################################################
## Load the NETAUTO table
$WRI_NETAUTO
For I=0 To [M:BPOI]NB-1
 If [M:BPOI]MRK(I)=2
  Filter [NTO] Where ACCNUM=[M:BPOI]ACCNUM(I) & DUDLIG=[M:BPOI]DUDLIG(I)
  Read [NTO]NTO0 Last
  Filter [NTO]
  If !fstat
   VIND = [F:NTO]IND+1
  Else
   VIND = 1
  Endif
  Raz [F:NTO]
  Raz VTYP,VNUM,VLIN
  [F:NTO]CPY       = [M:BPOI]CPYSEL
  [F:NTO]ACCNUM    = [M:BPOI]ACCNUM(I)
  [F:NTO]DUDLIG    = [M:BPOI]DUDLIG(I)
  [F:NTO]IND       = VIND
  [F:NTO]CUR       = [M:BPOI]CURSEL
  [F:NTO]UIDUSR    = adxuid(1)
  [F:NTO]NUM       = [M:BPOI]NUM(I)
  Case [M:BPOI]SNS(I)
   When 1  # Debit
    [F:NTO]AMTCURNET = [M:BPOI]AMTTONET(I)
   When -1 # Credit
    [F:NTO]AMTCURNET = [M:BPOI]AMTTONET(I)*-1
  Endcase
  [F:NTO]SNS       = [M:BPOI]SNS(I)*-1
  Read [DAE]DAE2=[M:BPOI]ACCNUM(I)
  If !fstat
   VTYP = [F:DAE]TYP
   VNUM = [F:DAE]NUM
   VLIN = [F:DAE]LIN
   [F:NTO]FCYLIN = [F:DAE]FCYLIN
   [F:NTO]BPR    = [F:DAE]BPR
   Filter [DAE] Where TYP=VTYP & NUM=VNUM & LIN=VLIN
   For [DAE]DAE0
    [F:NTO]COA([F:DAE]LEDTYP-1) = [F:DAE]COA
    [F:NTO]ACC([F:DAE]LEDTYP-1) = [F:DAE]ACC
   Next
   Filter [DAE]
  Endif
  Write [NTO]
  If fstat
   GOK=0 : Call FSTA("NTO") From GLOCK
   Break
  Endif
 Endif
Next
Return

#########################################################
## Update the NETAUTO table
$UPD_NETAUTO
Readlock [NTO]NTO0=val(FLD1);val(FLD2);val(FLD3)
If fstat
 GOK=0 : Call FSTA("NTO") From GLOCK : Return
Endif
[F:NTO]ACCNUMVCR = [M:HAEW]ACCNUM(I)
Rewrite [NTO]
If fstat
 GOK=0 : Call FSTA("NTO") From GLOCK : Return
Endif
Return

#########################################################
$AB_VALID_NETAUTO
Rollback
Return

#########################################################
## Matching with the original entry
$LETTRAGE
# The ledger isn't an automatic ledger and is ticked "Matching"
If [M:HAEF]GENC(VLED-1)=2 & [M:HAEF]MTC(VLED-1)=2
 Call LEC_GAC([M:HAEW]ACC(I),[M:HAEW]COA(I)) From CPTLEC
 If !fstat & [F:GAC]MTC=2
  Raz TBLET, DUDLIG, AMTIPT, NBLET
  Read [DAE]DAE0 = VTYP;VNUM;VLIN;VLED
  If !fstat
   TBLET(1)  = [F:DAE]ACCNUM
   DUDLIG(1) = val(FLD2)
   AMTIPT(1) = [M:HAEW]DEB(I)+[M:HAEW]CDT(I)
   NBLET     = 2
  Endif
  TBLET(2)  = [M:HAEW]ACCNUM(I)
  DUDLIG(2) = 1
  AMTIPT(2) = [M:HAEW]DEB(I)+[M:HAEW]CDT(I)
  Call LETDIF2(NBLET,TBLET,DUDLIG,AMTIPT,-2) From CPTLET
 Endif
Endif
Return

##################################################################################################################
## Funprog called in the site field of the NETLI journal automatic code

Funprog FCY(COD)
Value Char COD
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If [F:CPY]CPY<>COD
 Read [CPY]CPY0 = COD
Endif
If !fstat : End [F:CPY]MAIFCY : Endif
End ""


####################################################################################################################
## Funprog called in the FCYLIN field of the NETLI automatic journal lines

Funprog FCYLIN(LACCNUM,LDUDLIG)
Value Integer LACCNUM
Value Integer LDUDLIG
If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
If LACCNUM<>[F:DUD]ACCNUM | LDUDLIG<>[F:DUD]DUDLIG
 Read [DUD]DUD1=LACCNUM;LDUDLIG
Endif
If !fstat : End [F:DUD]FCY : Endif
End ""

####################################################################################################################
## Funprog called in the BPR field of the NETLI automatic journal lines

Funprog BPR(LACCNUM,LDUDLIG)
Value Integer LACCNUM
Value Integer LDUDLIG
If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
If LACCNUM<>[F:DUD]ACCNUM | LDUDLIG<>[F:DUD]DUDLIG
 Read [DUD]DUD1=LACCNUM;LDUDLIG
Endif
If !fstat : End [F:DUD]BPR : Endif
End ""

####################################################################################################################
## Action before line creation in the NETLI automatic journal
$INICRITIMP
[L]CRITIMP = num$([F:TB0]ACCNUM)+"/"+num$([F:TB0]DUDLIG)+"/"+num$([F:TB0]IND)
Return

######################################################################################
## Labels  (mask DATNET)
######################################################################################
Subprog C_DAT(VALEUR)
Variable Date    VALEUR
If !clalev([F:FIY]) : Local File FISCALYEAR [FIY] : Endif
If !clalev([F:PER]) : Local File PERIOD     [PER] : Endif
Local Integer VLED
Local Decimal EXE, PER
Call LECLEDMAIN(1,[M:BPOI]CPYSEL,VLED) From CPTDIV
Call GETEXE([M:BPOI]CPYSEL,VLED,VALEUR,EXE) From CPTSUB
If !EXE | [F:FIY]FIYSTA<>2
 # Exercice non ouvert
 GMESSAGE=mess(20,101,1) : mkstat=2 : End
Elsif [F:FIY]FIYSTA=3
 # Exercice fermé
 GMESSAGE=mess(42,101,1) : mkstat=2 : End
Endif
Call GETPERSOC([M:BPOI]CPYSEL,VLED,VALEUR,EXE,PER) From CPTSUB
If !PER | [F:PER]PERSTA<>2
 # Période non ouverte
 GMESSAGE=mess(35,101,1) : mkstat=2 : End
Elsif [F:PER]PERSTA=3
 # Période fermée
 GMESSAGE=mess(36,101,1) : mkstat=2 : End
Endif
End

