#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "IMPORT"        : Gosub IMPORT
  When "IMP_OUVRE"     : Gosub OUVRE
Endcase
Return



$IMPORT
Local Integer NOFORBANK
Local Integer BIDLENGTH
Local Char    BID(5)

  If GIMP(2) <> "0000"
    OK = 0                # to avoid the insertion
    NBERR -= 1            # to avoid error trace
  Else
    [M:ABN1]CRY = "CH"
    BID = GIMP(1)
    #set leading zeros
    For BIDLENGTH = len(BID) + 1 To 5
      BID = "0"+BID
    Next

    [M:ABN1]BAN = BID
    #For banks from Liechtenstein set country to "LI"
    If vireblc(GIMP(3),2) = "LI"
     [M:ABN1]CRY = "LI"
    Endif
  Endif
Return

$OUVRE
Local Integer NBDROP_
# delete all existing CH postcodes
  Filter [F:ABN] Where CRY="CH" or CRY = "LI"
  NBDROP_=rowcount([F:ABN])
  Filter [F:ABN]
  Trbegin [F:ABN]
  Delete [F:ABN] Where CRY="CH" or CRY="LI"
  If fstat=0
    Call ECR_TRACE(func AFNC.MES1( mess(19,3648,1), num$(NBDROP_)), 0) From GESECRAN
    Commit
  Else
    Call ECR_TRACE(mess(20,3648,1), 1) From GESECRAN
    GOK = -1
    Rollback
  Endif
Return

