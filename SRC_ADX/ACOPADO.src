#<AdxTL>@(#)5.0.0.0 $Revision$
Call EXECUTE()
End

######################################################################################
Subprog EXECUTE()
Local Char PARAM(10)(1..1) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ACOPADO","ACOPADO",3,"") From GTRAITE
End
######################################################################################

$ACTION
Case ACTION
 When "CONTROLE"    : Gosub CONTROLE
 When "AVANT_PAR"   : Gosub AVANT_PAR
 When "EXEC"        : Gosub EXEC
 When "AB1_ORI"     : Gosub AVANT_SELECTION2
 When "AB1_DEST11"  : Gosub AVANT_SELECTION
 When "AB1_DEST12"  : Gosub AVANT_SELECTION
 When "AB1_DEST21"  : Gosub AVANT_SELECTION
 When "AB1_DEST31"  : Gosub AVANT_SELECTION
 When "SORTIE"      : Gosub SORTIE
 When Default
Endcase
Return

$AVANT_PAR
TIT = mess(151,139,1) : # "Copie valeurs paramètres"
TMP = 1
TRA = 1
Return

$SORTIE
Raz [M]
Return

$AVANT_SELECTION2
Raz GBIDC1,GBIDC2,GBIDC3
Case [M]NIV
 When 1
  If [M]DOSORG<>nomap
   Local File =[M]DOSORG+".COMPANY" [CPY]
  Endif
  GBIDC1 = "CPY"
 When 2
  If [M]DOSORG<>nomap
   Local File =[M]DOSORG+".FACILITY" [FCY]
  Endif
  GBIDC1 = "FCY"
 When 3
  If [M]DOSORG<>nomap
   Local File =[M]DOSORG+".ACCES"   [ACC]
   Local file =[M]DOSORG+".AFCTFCT" [AFT]
   Local File =[M]DOSORG+".AUTILIS" [AUS]
  Endif
  GBIDC1 = "AUS"
 When 4
  If [M]DOSORG<>nomap
   Local File =[M]DOSORG+".ATEXTRA" [AXX]
   Local File =[M]DOSORG+".ATABDIV" [ADI]
  Endif    
  GBIDC1 = "ADI"
  GBIDC3 = "909"
Endcase
Return

$AVANT_SELECTION
Raz GBIDC1,GBIDC2,GBIDC3
Case [M]NIV
 When 1
  If [M]DOSDES<>nomap
   Local File =[M]DOSDES+".COMPANY" [CPY]
  Endif
  GBIDC1 = "CPY"
 When 2
  If [M]DOSDES<>nomap
   Local File =[M]DOSDES+".FACILITY" [FCY]
  Endif
  GBIDC1 = "FCY"
 When 3
  If [M]DOSDES<>nomap
   Local File =[M]DOSDES+".ACCES"   [ACC]
   Local file =[M]DOSDES+".AFCTFCT" [AFT]
   Local File =[M]DOSDES+".AUTILIS" [AUS]
  Endif
  GBIDC1 = "AUS"
 When 4
  If [M]DOSDES<>nomap
   Local File =[M]DOSDES+".ATEXTRA" [AXX]
   Local File =[M]DOSDES+".ATABDIV" [ADI]
  Endif    
  GBIDC1 = "ADI"
  GBIDC3 = "909"
Endcase
Return


$EXEC
Local Char CRIT(250),CRIT2(250),CRIT3(250),VARIA(30), CLES(20)(1..250),TRACE_MOD(250)(1..250)
Local Integer NBR,NBR2,NBMOD,OKSUPP
If !GSERVEUR
 Call OUVRE_TRACE([L]TIT) From LECFIC
Endif
Gosub TABLES
Call ECR_TRACE(mess([M]NIV,7809,1)-mess(128,124,1)-":"-[M]ORI,0) From GESECRAN
Call DEBTRANS From GLOCK
Gosub TR1
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return


$TR1
Trbegin [ADW],[ADU]
Case [M]NIV
 When 1
  Gosub COP_CMP
 When 2
  Gosub COP_FCY
 When 3
  Gosub COP_AUS
 When 4
  Gosub COP_LEG
Endcase
If GOK=0 : Goto AB_TR1
Elsif GOK<0 : Goto ROLL_TR1
Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$TABLES
If [M]DOSORG=nomap 
 Local File ADOVAL     [ADW]
 Local File ADOVALAUS  [ADU]
Else 
 Local File =[M]DOSORG+".ADOVAL"     [ADW]  
 Local File =[M]DOSORG+".ADOVALAUS"  [ADU]
Endif 
If [M]DOSDES=nomap
 Local File ADOPAR     [ADP]
 Local File ADOVAL     [ADW2]
 Local File ADOVAL     [ADW3]
 Local File ADOVALAUS  [ADU2]
 Local File ADOVALAUS  [ADU3]
 Local File ATABDIV    [ADI]
 Local File COMPANY    [CPY]  
 Local File FACILITY   [FCY] 
 Local File AUTILIS    [AUS]  
Else 
 Local File =[M]DOSDES+".ADOPAR"     [ADP]
 Local File =[M]DOSDES+".ADOVAL"     [ADW2]
 Local File =[M]DOSDES+".ADOVAL"     [ADW3]
 Local File =[M]DOSDES+".ADOVALAUS"  [ADU2]
 Local File =[M]DOSDES+".ADOVALAUS"  [ADU3]
 Local File =[M]DOSDES+".ATABDIV"    [ADI]
 Local File =[M]DOSDES+".COMPANY"    [CPY]  
 Local File =[M]DOSDES+".FACILITY"   [FCY] 
 Local File =[M]DOSDES+".AUTILIS"    [AUS] 
Endif
Local File ADOSACT [ADA]
Return

$COP_CMP
CRIT  = 'CMP = "'+[M]ORI+'" & FCY = ""'
Case [M]TYP
 When 1,2
  If [M]TYP =1
   CRIT2 = 'CPY>= "'+[M]DEST11+'" & CPY <= "'+[M]DEST12+'"'
  Else
   CRIT2 = 'pat(CPY,"'+[M]DEST21+'") = 1'
  Endif
  CRIT3 = 'CMP=[F:CPY]CPY & FCY =""'
  VARIA = '[F:CPY]CPY'
  If [M]DOSORG=[M]DOSDES
   CRIT2 += ' & CPY <> "'+[M]ORI+'"'
   CRIT3 += ' & CMP <> [M]ORI'
  Endif
  Gosub DEB_ADW
  Filter [CPY] Where evalue([L]CRIT2)
  For [CPY]CPY0
   Gosub ROUTINE_ADW
  Next
  Filter [CPY]
  If GOK<1 : Return : Endif
 When 3
  CRIT3 =  'CMP = [M]DEST31(I)  & FCY =""'
  VARIA = '[M]DEST31(I)'
  Gosub DEB_ADW
  For I=0 To [M]NBLIG-1
   Gosub ROUTINE_ADW
  Next 
  If GOK<1 : Return : Endif
Endcase
Return

$COP_FCY
CRIT  = 'FCY = "'+[M]ORI+'" & CMP = ""'
Case [M]TYP
 When 1,2
  If [M]TYP = 1
   CRIT2 = 'FCY>= "'+[M]DEST11+'" & FCY <= "'+[M]DEST12+'"'
  Else
   CRIT2 = 'pat(FCY,"'+[M]DEST21+'") = 1 & FCY <> "'+[M]ORI+'"'
  Endif
  CRIT3 = 'FCY=[FCY]FCY & CMP =""'
  VARIA = '[F:FCY]FCY'
  If [M]DOSORG=[M]DOSDES
   CRIT2 += ' & FCY <> [M]ORI'
   CRIT3 += ' & FCY <> [M]ORI'
  Endif
  Gosub DEB_ADW
  Filter [FCY] Where evalue([L]CRIT2)
  For [FCY]FCY0 
   Gosub ROUTINE_ADW
  Next
  Filter [FCY]
  If GOK<1 : Return : Endif
 When 3
  CRIT3 =  'FCY = [M]DEST31(I) & CMP =""'
  VARIA =  '[M]DEST31(I)'
  Gosub DEB_ADW
  For I=0 To [M]NBLIG-1
   Gosub ROUTINE_ADW
  Next 
  If GOK<1 : Return : Endif
Endcase
Return

$COP_LEG
CRIT  = 'FCY = "'+[M]ORI+'" & CMP = "*"'
Case [M]TYP
 When 1,2
  If [M]TYP = 1
   CRIT2 = 'NUMTAB = 909 & CODE>= "'+[M]DEST11+'" & CODE <= "'+[M]DEST12+'"'
  Else
   CRIT2 = 'NUMTAB = 909 & pat(CODE,"'+[M]DEST21+'") = 1'
  Endif
  CRIT3 = 'FCY>=[FCY]FCY & CMP ="*"'
  VARIA = '[ADI]CODE'
  If [M]DOSORG=[M]DOSDES
   CRIT2 += ' & CODE <> "'+[M]ORI+'"'
   CRIT3 += ' & FCY <> [M]ORI '
  Endif
  Gosub DEB_ADW
  Filter [ADI]  Where evalue([L]CRIT2)
  For [ADI]CODE   
   Gosub ROUTINE_ADW
  Next
  Filter [ADI]
  If GOK<1 : Return : Endif
 When 3
  CRIT3 =  'FCY = [M]DEST31(I)  & CMP ="*"'
  VARIA = '[M]DEST31(I)'
  Gosub DEB_ADW
  For I=0 To [M]NBLIG-1
   Gosub ROUTINE_ADW
  Next 
  If GOK<1 : Return : Endif
Endcase
Return

$COP_AUS
CRIT = 'CODUSR = "'+[M]ORI+'"'
Case [M]TYP
 When 1,2
  If [M]TYP = 1
   CRIT2 = 'USR>="'+[M]DEST11+'" & USR<="'+[M]DEST12+'"'
  Else
   CRIT2 = 'pat(USR,"'+[M]DEST21+'") = 1'
  Endif
  CRIT3 = 'pat(CODUSR,[AUS]USR)<>0'
  VARIA = '[AUS]USR'
  If [M]DOSORG=[M]DOSDES
   CRIT2 += ' & USR <> "'+[M]ORI+'"'
   CRIT3 += ' & CODUSR <> [M]ORI'
  Endif
  Gosub DEB_ADU
  Filter [AUS]  Where evalue([L]CRIT2)
  For [AUS]CODUSR   
   Gosub ROUTINE_ADU
  Next
  Filter [AUS]
  If GOK<1 : Return : Endif
 When 3
  CRIT3 =  'CODUSR = [M]DEST31(I)'
  VARIA = '[M]DEST31(I)'
  Gosub DEB_ADU
  For I=0 To [M]NBLIG-1
   Gosub ROUTINE_ADU
  Next 
  If GOK<1 : Return : Endif
 Endcase
Return

$CONTROLE
If !GSERVEUR
 If [M]TYP = 3 & [M]NBLIG = 0 
  SAI = 1 : Call ERREUR(mess(20,124,1)) From GESECRAN
  Return
 Endif
 Call OUINON (mess(152,139,1)-mess([M]NIV,7809,1)-"("+[M]ORI+")",OK) From GESECRAN
 If OK <> 2
  FIN =1
  Return
 Endif
Endif
Return

$WRITE_ADW2
If [M]SIMU <> 2
 Write [ADW2]
 If fstat
  GOK=0 : Call FSTA("ADW2") From GLOCK : Return
 Endif
Endif
Return

$WRITE_ADU2
If [M]SIMU <> 2
 Write [ADU2]
 If fstat
  GOK=0 : Call FSTA("ADU2") From GLOCK : Return
 Endif
Endif
Return

$TRACE_DEL
OKSUPP = 1
If [M]NIV <> 3
 Read [ADP]ADP1 = [ADW3]PARAM
 If !fstat 
  If !find([ADW3]PARAM,CLES(1..NBR))  & [M]SUPP <> 2
   OKSUPP =0
   NBR2  -=1
  Elsif !find([ADW3]PARAM,CLES(1..NBR))
   If [M]DETAIL = 2
    Call ECR_TRACE("    -"-mess(143,105,1)-[ADW3]PARAM-":"-[ADW3]VALEUR-"("-func AFNC.TEXTE([ADP]NAM)-")",0) From GESECRAN
   Endif
  Else
   NBMOD += 1
   NBR2  -= 1
   TRACE_MOD(NBMOD) = "    -"-mess(143,105,1)-[ADW3]PARAM-":"-[ADW3]VALEUR-"("-func AFNC.TEXTE([ADP]NAM)-")"
  Endif 
 Endif
Else
 Read [ADP]ADP1 = [ADU3]PARAM
 If !fstat
  If !find([ADU3]PARAM,CLES(1..NBR))  & [M]SUPP <> 2
   OKSUPP =0
   NBR2  -=1
  Elsif !find([ADU3]PARAM,CLES(1..NBR)) 
   If [M]DETAIL = 2
    Call ECR_TRACE("    -"-mess(143,105,1)-[ADU3]PARAM-":"-[ADU3]VALEUR-"("-func AFNC.TEXTE([ADP]NAM)-")",0) From GESECRAN
   Endif
  Else
   NBMOD += 1
   NBR2  -= 1
   TRACE_MOD(NBMOD) = "    -"-mess(143,105,1)-[ADU3]PARAM-":"-[ADU3]VALEUR-"("-func AFNC.TEXTE([ADP]NAM)-")"
  Endif    
 Endif
Endif
Return

$TRACE_MODIF
For J=1 To NBMOD
 Call ECR_TRACE(TRACE_MOD(J),0) From GESECRAN
Next 
Return

############################################################
$DEB_ADW
NBR = 0
If [M]DETAIL = 2 : Call ECR_TRACE("  -"-mess(59,127,1),0) From GESECRAN : Endif
For [ADW] Where evalue([L]CRIT)
 NBR +=1
 CLES(NBR) = [ADW]PARAM
 If [M]DETAIL =2
  Read [ADP]ADP1 = [ADW]PARAM
  If !fstat
   Call ECR_TRACE("    -"-mess(143,105,1)-[ADW]PARAM-":"-[ADW]VALEUR-"("-func AFNC.TEXTE([ADP]NAM)-")",0) From GESECRAN
  Endif
 Endif
Next
Call ECR_TRACE("    -"-num$(NBR)-mess(59,127,1),0) From GESECRAN : # mess(174,139,1)
Return

$ROUTINE_ADW
NBR2 = 0  : NBMOD = 0
Call ECR_TRACE(" "-mess([M]NIV,7809,1)-mess(129,124,1)-":"-evalue(VARIA),0) From GESECRAN 
If [M]DETAIL =2 : Call ECR_TRACE("  -"-mess(175,139,1)-":",0) From GESECRAN  : Endif
For [ADW3] Where evalue([L]CRIT3)
 NBR2 += 1
 Gosub TRACE_DEL 
 If [M]SIMU <> 2 & OKSUPP
  Delete [ADW3]Curr
  If fstat=1 : GOK=-1 : GLOCK="$ADOVAL" : Break
  Elsif fstat>5 : GOK=0 : Call FSTA("ADW") From GLOCK : Break
  Endif
 Endif
Next
If GOK<1 : Return : Endif
Call ECR_TRACE("    -"-num$(NBR2)-mess(175,139,1),0) From GESECRAN
If [M]DETAIL =2 
 Call ECR_TRACE("  -"-mess(176,139,1)-":",0) From GESECRAN 
 Gosub TRACE_MODIF
Endif 
Call ECR_TRACE("    -"-num$(NBMOD)-mess(176,139,1),0) From GESECRAN
######  ecriture 
For [ADW] Where evalue([L]CRIT)
 Raz [ADW2]
 [F:ADW2]    = [F:ADW]
 Case[M]NIV
  When 1   : [F:ADW2]CMP = evalue(VARIA)
  When 2,4 : [F:ADW2]FCY = evalue(VARIA)
 Endcase 
 Gosub WRITE_ADW2
 If GOK<1 : Break  : Endif
Next
Return

########################################################
$DEB_ADU
NBR = 0
If [M]DETAIL = 2 : Call ECR_TRACE("  -"-mess(59,127,1),0) From GESECRAN : Endif
For [ADU] Where evalue([L]CRIT)
 NBR +=1
 CLES(NBR) = [ADU]PARAM
 If [M]DETAIL =2
  Read [ADP]ADP1 = [ADU]PARAM
  If !fstat
   Call ECR_TRACE("    -"-mess(143,105,1)-[ADU]PARAM-":"-[ADU]VALEUR-"("-func AFNC.TEXTE([ADP]NAM)-")",0) From GESECRAN
  Endif
 Endif
Next
Call ECR_TRACE("    -"-num$(NBR)-mess(59,127,1),0) From GESECRAN
Return

$ROUTINE_ADU
NBR2 = 0 : NBMOD = 0
Call ECR_TRACE(" "-mess([M]NIV,7809,1)-mess(129,124,1)-":"-evalue(VARIA),0) From GESECRAN 
If [M]DETAIL =2 : Call ECR_TRACE("  -"-mess(175,139,1)-":",0) From GESECRAN  : Endif
For [ADU3] Where evalue([L]CRIT3)
 NBR2 += 1
 Gosub TRACE_DEL 
 If [M]SIMU <> 2 & [L]OKSUPP
  Delete [ADU3]Curr
  If fstat=1 : GOK=-1 : GLOCK="$ADOVAL" : Break
  Elsif fstat>5 : GOK=0 : Call FSTA("ADU") From GLOCK : Break
  Endif
 Endif
Next
If GOK<1 : Return : Endif
Call ECR_TRACE("    -"-num$(NBR2)-mess(175,139,1),0) From GESECRAN
If [M]DETAIL =2 
 Call ECR_TRACE("  -"-mess(176,139,1)-":",0) From GESECRAN 
 Gosub TRACE_MODIF
Endif 
Call ECR_TRACE("    -"-num$(NBMOD)-mess(176,139,1),0) From GESECRAN
#####  ecriture
For [ADU] Where evalue([L]CRIT)
 Raz [ADU2]
 [F:ADU2]       = [F:ADU]     
 [F:ADU2]CODUSR = evalue(VARIA)
 Gosub WRITE_ADU2
 If GOK<1 : Break  : Endif
Next
Return

#############################################################################################
#############################################################################################
#############################################################################################
Subprog C_NIV(VALEUR)
Variable Integer VALEUR
If VALEUR=4
 Local Integer OKLEG
 Local File ADOSACT [ADA]
 Read [ADA]ADA0=[M]DOSORG;"LEG"
 If !fstat & [F:ADA]FLACT=2
  Read [ADA]ADA0=[M]DOSDES;"LEG"
  If !fstat & [F:ADA]FLACT=2
   OKLEG = 1
  Endif
 Endif
 If !OKLEG : GMESSAGE = mess(100,127,1) : mkstat =2 : Endif
Endif
End


Subprog AM_TYP(VALEUR)
Variable Integer VALEUR
Raz [M]DEST21   : Raz [M]DEST31  : Raz [M]DEST12 : Raz [M]DEST11 : Raz [M]DESTLIB
Affzo [M]
Case VALEUR
 When 1 :
  Actzo [M]DEST11 
  Grizo [M]DEST21 : Grizo [M]DEST31  
 When 2 :
  Actzo [M]DEST21
  Grizo [M]DEST11 : Grizo [M]DEST12 : Grizo [M]DEST31 
 When 3 :
  Actzo [M]NBLIG  : Actzo [M]DEST31
  Grizo [M]DEST11 : Grizo [M]DEST12 : Grizo [M]DEST21 
Endcase
End

Subprog D_DEST11(VALEUR)
Variable Char    VALEUR()
If [M]TYP <> 1
 Grizo [M]DEST11
Endif
End

Subprog D_DEST12(VALEUR)
Variable Char    VALEUR()
Grizo [M]DEST12
End

Subprog D_DEST21(VALEUR)
Variable Char    VALEUR()
Grizo[M]DEST21
End

Subprog AM_ORI(VALEUR)
Variable Char    VALEUR()
End

Subprog AM_DEST11(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
 Actzo [M]DEST12
Else
 Grizo [M]DEST12
Endif
End

Subprog C_DEST11(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
End

Subprog C_DEST12(VALEUR)
Variable Char    VALEUR()
If [M]DEST11 > toupper(VALEUR)
 GMESSAGE = mess(8,133,1) : # Valeur trop petite
 mkstat =1 : End
Endif
VALEUR = toupper(VALEUR)
End

Subprog C_DEST21(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
If VALEUR = [M]ORI & [M]DOSORG = [M]DOSDES
 Call ERREUR(VALEUR-"="-mess(153,139,1)) From GESECRAN # Valeur D'origine
 mkstat = 1 : End
Endif
End

Subprog C_ORI(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
Case [M]NIV 
 When 1
  If !clalev([F:CPY]) : Local File =[M]DOSORG+".COMPANY"    [CPY] : Endif
  Read [CPY]CPY0=VALEUR
  If fstat : GMESSAGE = mess(16,104,1)  : mkstat = 1 : Endif : # Societe inexistante
  [M]ORILIB = [CPY]CPYNAM
 When 2  
  If !clalev([F:FCY]) : Local File =[M]DOSORG+".FACILITY"   [FCY] : Endif
  Read [FCY]FCY0=VALEUR
  If fstat : GMESSAGE = mess(15,104,1) : mkstat = 1 : Endif : # Site inexistante
  [M]ORILIB = [FCY]FCYNAM
 When 3
  If !clalev([F:AUS]) : Local File =[M]DOSORG+".AUTILIS"    [AUS] : Endif
  Read [AUS]CODUSR=VALEUR
  If fstat : GMESSAGE = mess(141,100,1) : mkstat = 1 : Endif : # Utilisateur inexistante
  [M]ORILIB = [AUS]NOMUSR
 When 4
  If !clalev([F:ADI]) : Local File =[M]DOSORG+".ATABDIV"    [ADI] : Endif
  Read [ADI]CODE=909;VALEUR
  If fstat : GMESSAGE = mess(154,139,1) : mkstat = 1 : Endif : # Legislation inexistante
  Local Char DOSLEG(30)(1..30)
  Local Integer NBLEG
  Call SETLEG([M]DOSDES,DOSLEG,NBLEG) From DOSCONT
  If !find(VALEUR,DOSLEG) 
   GMESSAGE = VALEUR-":"-mess(67,127,1)-[M]DOSDES  : mkstat = 1 : End : # : Législation non gérée par le dossier
  Endif
  Call LECTEXTRA([M]ORILIB,"ATABDIV","LNGDES",num$([ADI]NUMTAB),[ADI]CODE) From ATEXTRA
Endcase
Grizo [M]NBLIG
End

Subprog C_DEST31(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
Call UNICITE(VALEUR,[M]DEST31) From OBJDIV
If VALEUR = [M]ORI & [M]DOSORG = [M]DOSDES
 Call ERREUR(VALEUR-"="-mess(153,139,1)) From GESECRAN : # Valeur D'origine
 mkstat = 1 : End
Endif
Case [M]NIV 
 When 1
  If !clalev([F:CPY]) : Local File =[M]DOSDES+".COMPANY"    [CPY] : Endif
  Read [CPY]CPY0=VALEUR
  If fstat GMESSAGE = mess(16,104,1) : mkstat = 1 : End : Endif : # societe inexistante
  [M]DESTLIB(nolign-1) = [CPY]CPYNAM
 When 2  
  If !clalev([F:FCY]) : Local File =[M]DOSDES+".FACILITY"   [FCY] : Endif
  Read [FCY]FCY0=VALEUR
  If fstat GMESSAGE = mess(15,104,1) : mkstat = 1 : End : Endif : # site inexistante
  [M]DESTLIB(nolign-1) = [FCY]FCYNAM
 When 3
  If !clalev([F:AUS]) : Local File =[M]DOSDES+".AUTILIS"    [AUS] : Endif
  Read [AUS]CODUSR=VALEUR
  If fstat GMESSAGE = mess(141,100,1) : mkstat = 1 : End : Endif : # utilisateur inexistante
  [M]DESTLIB(nolign-1) = [AUS]NOMUSR
 When 4
  If !clalev([F:ADI]) : Local File =[M]DOSDES+".ATABDIV"    [ADI] : Endif
  Read [ADI]CODE=909;VALEUR
  If fstat GMESSAGE = mess(154,139,1) : mkstat = 1 : End : Endif : # Legislation inexistante
  Call LECTEXTRA([M]DESTLIB(nolign-1),"ATABDIV","LNGDES",num$([ADI]NUMTAB),[ADI]CODE) From ATEXTRA
Endcase
End

Subprog AM_NIV(VALEUR)
Variable Integer VALEUR
Raz [M]ORI,[M]ORILIB,[M]DETAIL,[M]SIMU,[M]SUPP
Raz [M]DEST11,[M]NBLIG,[M]DEST12,[M]DEST21,[M]DEST31,[M]DESTLIB  
[M]TYP = 1
[M]NIV = VALEUR
Actzo [M]DEST11
Grizo [M]DEST12 : Grizo [M]DEST21 : Grizo [M]DEST31
Affzo [M]
Setmok [M] With "0"
End
