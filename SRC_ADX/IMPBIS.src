#<AdxTL>@(#)10.0.0.0 $Revision$
#**********************************************************************#
#    Modification                                                      #
# Issue X3-99385 - 2018-07-12 by CBO : Import large number of Supplier BP invoices failed on 2018 R4 cloud site
# SMO   30.01.2018 X3-72953 : Ability to import currency rate in AP/AR #
#                             invoices                                 #
# FPE     23.08.2018 X3-75263 : If CURTYP field is deleted from the    #
#                               import template, initilize it as in    #
#                               GESBIS function (SUBBIS script).       #
########################################################################

$ACTION
Case ACTION
 When "IMP_OUVRE"     : Gosub OUVRE
 When "IMPORT"        : Gosub IMPORT
 When "IMP_LIENS"     : Gosub LIENS
 When "IMP_CREATION"  : Gosub CREATION
 When "IMP_MODIF"     : Gosub MODIF
 When "IMP_ZONE"      : Gosub IMP_ZONE
 When "IMP_TAB"       : Gosub IMP_ZONE
 When "IMP_VERIF_CRE" : Gosub VERIF_CRE
 When "AP_IMPORT"     : #Gosub AP_IMPORT
Endcase
Return

### Ouverture du masque des échéances
$OUVRE
If clalev([M:DUD1])=0 : Local Mask BPSDUD [DUD1] : Endif

If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif
If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif
If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif
If clalev([F:AUS])=0 : Local File AUTILIS    [AUS] : Endif
If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
If clalev([F:TAM])=0 : Local File TABPAM     [TAM] : Endif
Call LECTURE("AUS",GUSER,"") From CONTOBJ
Local Integer USRPAZ
Local Char LLEVPAZ(3)
Call PARAMUTIL("DEFBONPAY",LLEVPAZ,"","") From SUBAUS
[L]USRPAZ = val(LLEVPAZ)
Local Integer AX , OPTV , OPTF , NBANA , OKCHAMP, STAT
Local Char MESSA
Local Char CRITSUPPR (250)
Local Integer  TAX_PIL
Global Integer GAMTVAT_PIL
##
Local Char    COMPTE(GLONGAC)
Local Integer NLED, TLED, VU

Gosub OUVRE_ACT_CODE From SUBBIS2 # Issue X3-99385

Return

### Chargement des échéances en modif
$LIENS
Call LECTURE("FCY",[F:PIH]FCY,"") From CONTOBJ
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ

## Initialisations globales plans/axes
GSOCIETE = [M:BIS0]CPY
Call INI_GLOBAL(2,[M:BIS0]CPY,STAT,MESSA) From SUBBICS
If STAT : OK=0 : Endif

Raz [M:DUD1]
[M:DUD1]AMTTOT = [F:PIH]AMTATI
nolign = 0
For [DUD]DUD1 Where ACCNUM=[F:PIH]ACCNUM
 nolign += 1
 [M:DUD1] = [F:DUD]
 If nolign=1
  [M:DUD1]DUDCUR = [F:DUD]CUR
 Endif
Next
[M:DUD1]NBECH = nolign
Return

### Lecture d'un enregistrement
$IMPORT
Case IMPFIC

 When "PIH" : # En-tête
  If GREP="C" :  Raz [M:DUD1] : Endif
  Call LEC_CPY([F:PIH]CPY) From CPTLEC
  For AX=0 To dim([F:PIH]DIE)-1
   If [F:PIH]DIE(AX)<>""
    VU = find([F:PIH]DIE(AX),[F:CPY]DIE(0..dim([F:CPY]DIE)-1))
    If VU<>0
     [M]SAIAXE(AX) = [F:CPY]DACDIE(VU-1)
    Else
     [M]SAIAXE(AX) = 2
    Endif
   Endif
  Next

 When "PIL" : # Lignes de factures

  If GREP="M" & [M]STA=3 : OK = -1 : Return : Endif

  ## Recherche du numéro de ligne en modif
  If GREP="M" & [F:PIL]LIG>=1 & [F:PIL]LIG<=[M]NBLIG : # Modif ligne existante
   nolign = [F:PIL]LIG
  Else                                               : # Ajout d'une ligne
   [M]NBLIG += 1
   nolign = [M]NBLIG
  Endif

  [F:PIL]LIG = nolign : # Mémo pour ligne ana

  For NLED=1 To GNBTYPLED
   Assign "[M]ACC"+num$(NLED)+"("+num$(nolign-1)+")" With [F:PIL]ACC(GTYPLED(NLED)-1)
  Next

  ## <Dem 53100, 61421> Pour importer les codes taxes du fichier de données (et non initialiser les taxe1 et taxe2
  ## par les codes taxes par défaut du compte), les champs VAT, TAX1 et TAX2 doivent être définis dans le modèle d'import.
  TAX_PIL=1
  Call TST_CHAMP("PIL","VAT",OKCHAMP) From SUBIMPOBJ
  If !OKCHAMP : TAX_PIL=0 : Endif
  Call TST_CHAMP("PIL","TAX1",OKCHAMP) From SUBIMPOBJ
  If !OKCHAMP : TAX_PIL=0 : Endif
  Call TST_CHAMP("PIL","TAX2",OKCHAMP) From SUBIMPOBJ
  If !OKCHAMP : TAX_PIL=0 : Endif
  If TAX_PIL
   [M:BIS3]VAT(nolign-1)  = [F:PIL]VAT
   [M:BIS3]TAX1(nolign-1) = [F:PIL]TAX1
   [M:BIS3]TAX2(nolign-1) = [F:PIL]TAX2
  Endif

  ## <Dem 61421> Pour importer les factures avec les montants de taxes (AMTVAT, AMTTAX1, AMTTAX2) du fichier de données (non
  ## recalcul des montants de taxes), les 6 trois champs AMTVAT, AMTTAX1, AMTTAX2, DEDVAT, DEDTAX1, DEDTAX2
  ## doivent être définis dans le modèle d'import.
  GAMTVAT_PIL=1
  Call TST_CHAMP("PIL","AMTVAT",OKCHAMP) From SUBIMPOBJ
  If !OKCHAMP : GAMTVAT_PIL=0 : Endif
  Call TST_CHAMP("PIL","AMTTAX1",OKCHAMP) From SUBIMPOBJ
  If !OKCHAMP : GAMTVAT_PIL=0 : Endif
  Call TST_CHAMP("PIL","AMTTAX2",OKCHAMP) From SUBIMPOBJ
  If !OKCHAMP : GAMTVAT_PIL=0 : Endif
  Call TST_CHAMP("PIL","DEDVAT",OKCHAMP) From SUBIMPOBJ
  If !OKCHAMP : GAMTVAT_PIL=0 : Endif
  Call TST_CHAMP("PIL","DEDTAX1",OKCHAMP) From SUBIMPOBJ
  If !OKCHAMP : GAMTVAT_PIL=0 : Endif
  Call TST_CHAMP("PIL","DEDTAX2",OKCHAMP) From SUBIMPOBJ
  If !OKCHAMP : GAMTVAT_PIL=0 : Endif
  If GAMTVAT_PIL
   [M:BIS3]AMTVAT(nolign-1)  = [F:PIL]AMTVAT
   [M:BIS3]AMTTAX1(nolign-1) = [F:PIL]AMTTAX1
   [M:BIS3]AMTTAX2(nolign-1) = [F:PIL]AMTTAX2
   [M:BIS3]DEDVAT(nolign-1)  = [F:PIL]DEDVAT
   [M:BIS3]DEDTAX1(nolign-1) = [F:PIL]DEDTAX1
   [M:BIS3]DEDTAX2(nolign-1) = [F:PIL]DEDTAX2
  Endif

  ## Management of periodicity
  Call TST_CHAMP("PIL","STRDAT",OKCHAMP) From SUBIMPOBJ
  If OKCHAMP : [M:BIS3]STRDAT(nolign-1)  = [F:PIL]STRDAT : Endif
  Call TST_CHAMP("PIL","ENDDAT",OKCHAMP) From SUBIMPOBJ
  If OKCHAMP : [M:BIS3]ENDDAT(nolign-1)  = [F:PIL]ENDDAT : Endif
  Call TST_CHAMP("PIL","PERNBR",OKCHAMP) From SUBIMPOBJ
  If OKCHAMP : [M:BIS3]PERNBR(nolign-1)  = [F:PIL]PERNBR : Endif
  Call TST_CHAMP("PIL","PERTYP",OKCHAMP) From SUBIMPOBJ
  If OKCHAMP : [M:BIS3]PERTYP(nolign-1)  = [F:PIL]PERTYP : Endif
  #

 When "PIA" : # Lignes analytiques

  If GREP="M" & [M]STA=3 : OK = -1 : Return : Endif

  ## Recherche no de ligne géné
  If GREP="M" & [F:PIA]LIG>=1 & [F:PIA]LIG<=[M]NBLIG : # Si ligne OK
   nolign = [F:PIA]LIG
  Else                                               : # Sinon dernière ligne lue
   nolign = [F:PIL]LIG
  Endif

  ## Recherche no de ligne ana
  If [M:BIS3]PTV(nolign-1)=0 : # On génére une ligne "bidon"
   K = [M:VT2]PTVENT+1
   [M:VT2]PTVENT = K
   [M:BIS3]PTV(nolign-1) = K
   [M:BIS3]PTF(nolign-1) = K
  Else
   NBANA = [M:BIS3]PTF(nolign-1)-[M:BIS3]PTV(nolign-1)+1
   If [F:PIA]ANALIG>=1 & [F:PIA]ANALIG<=NBANA : # Modif ligne existante
    K = [M:BIS3]PTV(nolign-1)+[F:PIA]ANALIG-1
   Elsif [M:VT2]PTVENT=[M:BIS3]PTF(nolign-1)    : # Y'a la place
    K = [M:VT2]PTVENT+1
    [M:VT2]PTVENT         = K
    [M:BIS3]PTF(nolign-1) = K
   Else                                      : # On met plus loin
    OPTV = [M:BIS3]PTV(nolign-1)
    OPTF = [M:BIS3]PTF(nolign-1)
    K = [M:VT2]PTVENT+1
    [M:BIS3]PTV(nolign-1) = K
    For I=0 To OPTF-OPTV
     [M:VT2]TBAMT(K+I) = [M:VT2]TBAMT(OPTV+I)
     [M:VT2]TBQTY(K+I) = [M:VT2]TBQTY(OPTV+I)
     For AX=1 To GOPTCANA
      Assign "[M:VT2]TBCCE"+num$(AX)+"("+num$(K+I)+")" With
&     evalue("[M:VT2]TBCCE"+num$(AX)+"("+num$(OPTV+I)+")")
     Next AX
    Next I
    K += OPTF-OPTV+1
    [M:VT2]PTVENT = K
    [M:BIS3]PTF(nolign-1) = K
    Call ANUVENTIL([M:BIS3]PTV,[M:BIS3]PTF,[M:BIS3]NBLIG,OPTV,OPTF-OPTV+1) From VENTILE
    K -= OPTF-OPTV+1
   Endif
  Endif
  [M:BIS3]DSP(nolign-1) = "$"

  ## Transfert des infos
  For AX=1 To dim([F:PIA]CCE)
   Call TST_CHAMP("PIA","CCE("+num$(AX-1)+")",OKCHAMP) From SUBIMPOBJ
   If OKCHAMP
    INDAX = find(GAXE(AX),[F:PIA]DIE(0..dim([F:PIA]DIE)-1))
    If INDAX
     mkstat = 0
     For NLED=1 To GNBTYPLED
      COMPTE = evalue("[M]ACC"+num$(NLED)+"("+num$(nolign-1)+")")
      If COMPTE<>""
       [L]TLED = GTYPLED(NLED) : Gosub LECLED From SUBBICS
       Call CONTCCE([F:PIA]CCE(AX-1),[L]LED,GAXE(AX),[M]FCYLIN(nolign-1),[M]ACCDAT,COMPTE,GAXE,"[M:VT2]TBCCE#",K) From CPTCNT
       If mkstat : Break : Endif
      Endif
     Next
     If mkstat
      Call ECR_TRACE(GMESSAGE-":"-mess(8,104,1)-COMPTE-mess(208,111,1)-[L]LED-mess(17,103,1)-[F:PIA]CCE(AX-1),1) From GESECRAN
      Raz GMESSAGE
      OK = 0 : Break
     Endif
     Assign "[M:VT2]TBCCE"+num$(AX)+"("+num$(K)+")" With [F:PIA]CCE(INDAX-1)
    Endif
   Endif
  Next AX
  If !OK : Return : Endif

  Call TST_CHAMP("PIA","AMT",OKCHAMP) From SUBIMPOBJ
  If OKCHAMP : [M:VT2]TBAMT(K) = [F:PIA]AMT : Endif
  Call TST_CHAMP("PIA","QTY",OKCHAMP) From SUBIMPOBJ
  If OKCHAMP : [M:VT2]TBQTY(K) = [F:PIA]QTY : Endif

  [M:BIS3]QTY(nolign-1) = sum([M:VT2]TBQTY([M:BIS3]PTV(nolign-1)..[M:BIS3]PTF(nolign-1)))

 When "DUD" : # Echéances
  ## Recherche no de ligne
  If GREP="M" & [F:DUD]DUDLIG>=1 & [F:DUD]DUDLIG<=[M:DUD1]NBECH : # Modif ligne existante
   nolign = [F:DUD]DUDLIG
  Else                                                     : # Ajout d'une ligne
   [M:DUD1]NBECH += 1
   nolign = [M:DUD1]NBECH
  Endif

Endcase
Return


## Création des échéances
$CREATION
If [M:DUD1]NBECH=0 : # Pas d'échéances importées
 Call CREECHE(2,2,0,[L]USRPAZ) From SUBBIH
Else
 Gosub MODECHE
Endif
# Issue X3-99385 : the 'Call CALRTZ' was already in comment
#If dim([M:BIS3]RITCODSRC)>0 : # test l'existence de la zone "Retenue Source"
# If func AFNC.PARAM("ARGRTZ",[M:BIS0]FCY)="2"
#  Call CALRTZ(1,[M:BIS0]BPR,GPLAN(1),[M:BIS3]ACC1,[M:BIS3]FCYLIN,[M:BIS1]CUR,[M:BIS0]ACCDAT,[M:BIS3]AMTNOTLIN,[M:BIS3]AMTVAT,[M:BIS3]NBLIG,0) From CALRTZARG
# Endif
#Endif
# End Issue X3-99385

Return


## Modif des échéances
$MODIF
Gosub MODECHE
Return


$MODECHE
Local Decimal TOTAL , RESIDU , RESTE
Local Integer EXERCICE, PERIODE
Local Integer ASTATUS
Local Libelle TYPGEN,TYPANA

## Rééquilibrage des échéances
TOTAL = sum([M:DUD1]AMTCUR(0..[M:DUD1]NBECH-1))
If TOTAL<[F:PIH]AMTATI : # Correction sur dernière échéance
 [M:DUD1]AMTCUR([M:DUD1]NBECH-1) += [F:PIH]AMTATI-TOTAL
Elsif TOTAL>[F:PIH]AMTATI
 RESIDU = TOTAL-[F:PIH]AMTATI
 For NOL=0 To [M:DUD1]NBECH-1
  RESTE = [M:DUD1]AMTCUR(NOL)-[M:DUD1]PAYCUR(NOL)-[M:DUD1]TMPCUR(NOL)
  If RESTE>0
   If RESTE>RESIDU
    [M:DUD1]AMTCUR(NOL) -= RESIDU : Break
   Else
    [M:DUD1]AMTCUR(NOL) -= RESTE
    RESIDU -= RESTE
   Endif
  Endif
 Next NOL
Endif

# Effacement
CRITSUPPR="ACCNUM="+num$([F:PIH]ACCNUM)
Call HISTOSUPPR (CRITSUPPR) From MODECHE
Delete [DUD] Where ACCNUM=[F:PIH]ACCNUM
If fstat=1
 GOK = -1 : GLOCK="$GACCDUDATE"-num$([F:DUD]ACCNUM) : Return
Endif
# Recalcul des montants société et reporting
Call LECTURE("FCY",[F:PIH]FCY,"") From CONTOBJ
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
If [M:DUD1]NBECH>0
 Call CONVERT_TAB([F:PIH]CUR,[F:CPY]ACCCUR,[F:CPY]ACCCUR
&  ,[F:PIH]CURTYP,[F:PIH]ACCDAT,[M:DUD1]AMTCUR(0..[M:DUD1]NBECH-1)
&  ,[M:DUD1]AMTLOC,GBIDI1) From TRTDEV
Endif

# Création des nouvelles échéances
For nolign=1 To [M:DUD1]NBECH
 If [M:DUD1]AMTTOT=0 | [M:DUD1]AMTCUR(nolign-1)<>0
   Raz [F:DUD]
   [F:DUD]BPRTYP = 2
   [F:DUD] = [F:PIH]
   [F:DUD]SAC = [F:PIH]BPRSAC
   Case [F:PIH]INVTYP
    When 1,3
     [F:DUD]SNS = -1
    When 2,4
     [F:DUD]SNS = +1
   Endcase
   [F:DUD]TYP    = [F:PIH]GTE
   [F:DUD]       = [M:DUD1]
   [F:DUD]LIG    = 1
   [F:DUD]PAMTYP = 1 : # Type échéance
   If [F:PIH]STA = 3
    [F:DUD]DUDSTA = 2
   Else
    [F:DUD]DUDSTA = 1
   Endif
   [F:DUD]DUDLIG = nolign
   [F:DUD]TYPDUD = 2  : #Facture
   # Point d'entrée mise à jour des échéances
   Gosub IMPECHE From SUBBIH
   Call KEYDUD("DUD") From MODECHE
   Call SLDECH("DUD")From MODECHE
   Call SETMAINREF([F:DUD]CPY,TYPGEN,TYPANA) From CPTDIV
   [L]ASTATUS = func FINPER_SYRA.GET_PER(GACTX, [F:DUD]CPY, TYPGEN, [F:DUD]DUDDAT, EXERCICE, PERIODE, GMESSAGE)
   [F:DUD]FIY = EXERCICE
   [F:DUD]PER = PERIODE
   If dim([F:DUD]CREDAT)>0 : [F:DUD]CREDAT = datesyst : Endif
   If dim([F:DUD]CREUSR)>0 : [F:DUD]CREUSR = GUSER : Endif
   Write [DUD]
   If fstat
    GOK=0 : Call FSTA("DUD") From GLOCK : Break
   Endif
   Call HISTOECH("DUD",1,[F:PIH]ACCDAT)From MODECHE
 Endif
Next nolign
Return


$IMP_ZONE
Case IMPZON
 When "DSP"
  If dim([M]DSP)>0 & [M]DSP(nolign-1)="" : [M]DSP(nolign-1) = "$" : Endif
 When "CUR"
  #-- Initialisation du masque commun SAICURLED (sans les cours enregistrés)
  # Issue X3-75263
  If [F:PIH]CURTYP = 0
    If dim([F:BPS]CHGTYP) > 0
      [F:PIH]CURTYP = [F:BPS]CHGTYP
    Else
      [F:PIH]CURTYP = 1
    Endif
  Endif
  # End issue X3-75263
  Call CHARG_ZONES_DEV("BIS1",[F:PIH]CPY,[F:PIH]CUR,[F:PIH]RATDAT,[F:PIH]CURTYP,0) From SUBBICS
  Call INIT_COURS("BIS1") From SUBBICS
  Call IMP_CUR_RAT_APAR_INVOICES("BIS1") From SUBBICS #X3-72953
 When "BPAPAY"
  If [F:DUD]BPAPAY = "" & [M]BPAPAY = ""
   Call LECTURE("BPR",[M:BIS1]BPRPAY,"") From CONTOBJ
   [M]BPAPAY = [F:BPR]BPAADD
  Endif
Endcase
Return

$VERIF_CRE
For I=0 To [M]NBLIG-1
 If dim([M]DSP)>0 & [M]DSP(I)="$"
  If  [M]AMTNOTLIN(I)<>sum([M:VT2]TBAMT([M]PTV(I)..[M]PTF(I)))
&  or [M]QTY(I)<>sum([M:VT2]TBQTY([M]PTV(I)..[M]PTF(I)))
   Call ECR_TRACE(mess(28,106,1)-mess(61,100,1)-num$(I+1),1) From GESECRAN
# Répartition déséquilibrée - ligne no ...
   OK = 0 : Break
  Endif
 Endif
Next I
Return


####################################################################
# Après l'import d'une ligne du fichier en entrée
#
$AP_IMPORT

Return

  Case SEPNUM
    When 4 :
     Gosub ALI_DUD
     OK = 0
    When Default
  Endcase
Return


$ALI_DUD
Local Integer FINDCODE, ICODE

  FINDCODE=G_NON
  For I=0 To [M:DUD1]NBECH-1
    # If [M:DUD1]DUDDAT(I)=[F:DUD]DUDDAT & [M:DUD1]PAM(I)=[F:DUD]PAM
    If [M:DUD1]DUDLIG(I)=[F:DUD]DUDLIG
      FINDCODE=G_OUI
      ICODE=I
      Break
    Endif
  Next I
  If FINDCODE=G_OUI Then
    nolign = ICODE+1
  Else
    nolign = [M:DUD1]NBECH+1
  Endif
  [M:DUD1]DUDDAT(nolign-1) = [F:DUD]DUDDAT
  [M:DUD1]PAM(nolign-1)    = [F:DUD]PAM
  [M:DUD1]AMTCUR(nolign-1) = [F:DUD]AMTCUR
  If FINDCODE=G_NON Then
   [M:DUD1]NBECH+=1
  Endif
Return

