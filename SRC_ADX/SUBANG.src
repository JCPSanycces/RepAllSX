#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion objet ANG
Raz GPILOBJ , GNBMASKOUV
Call OBJET("ANG",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
Endcase
Return

$OUVRE
If clalev([F:ANG3])=0 : Local File ANAVIG [ANG3] : Endif
Return

$LIENS
nolign = 0
For [ANH]ANH0 Where COD=[F:ANG]COD
 nolign += 1
 [M:ANG1] = [F:ANH]
Next
[M:ANG1]NBFIL = nolign
nolign = 0
For [ANI]ANI0 Where COD=[F:ANG]COD
 nolign += 1
 [M:ANG2] = [F:ANI]
Next
[M:ANG2]NBCRE = nolign
Call C_OBJ([F:ANG]OBJ)
Call TEXTE([F:ANG]DES,[M]ZDES) From OBJDIV
Call LECTURE("AOB",[F:ANG]OBJ,"") From CONTOBJ
[M:ANG0]NOMFIC = [F:AOB]NOMFIC
Return

$MODIF
Delete [ANH] Where COD=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ANAVFIL"-CLECUR1 : Return
Endif
Delete [ANI] Where COD=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ANAVCRE"-CLECUR1 : Return
Endif
Gosub CREATION
Return

$CREATION
For nolign=1 To [M:ANG1]NBFIL
 [F:ANH] = [M:ANG0]
 [F:ANH] = [M:ANG1]
 [F:ANH]LIG = nolign
 Write [ANH]
 If fstat
  GOK = 0 : Call FSTA("ANH") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : Return : Endif
For nolign=1 To [M:ANG2]NBCRE
 [F:ANI] = [M:ANG0]
 [F:ANI] = [M:ANG2]
 [F:ANI]LIG = nolign
 Write [ANI]
 If fstat
  GOK = 0 : Call FSTA("ANI") From GLOCK : Break
 Endif
Next nolign
If GOK<1 : Return : Endif
Return

##########################################################################
$TRTCOP
If [M]DOSORG=nomap 
 Local File ANAVIG  [ANG1] 
 Local File ANAVCRE [ANI1] 
 Local File ANAVFIL [ANH1] 
 Local File ATEXTE  [ATX1] 
Else 
 Local File =[M]DOSORG+".ANAVIG"  [ANG1]
 Local File =[M]DOSORG+".ANAVCRE" [ANI1] 
 Local File =[M]DOSORG+".ANAVFIL" [ANH1] 
 Local File =[M]DOSORG+".ATEXTE"  [ATX1] 
Endif 
If [M]DOSDES=nomap 
 Local File ANAVIG  [ANG2] 
 Local File ANAVCRE [ANI2] 
 Local File ANAVFIL [ANH2] 
 Local File ATEXTE  [ATX2] 
Else 
 Local File =[M]DOSDES+".ANAVIG"  [ANG2]
 Local File =[M]DOSDES+".ANAVCRE" [ANI2]
 Local File =[M]DOSDES+".ANAVFIL" [ANH2]
 Local File =[M]DOSDES+".ATEXTE"  [ATX2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ANG1], [ANI1], [ANH1], [ATX1]
&              , [ANG2], [ANI2], [ANH2], [ATX2]
Return

$TR_COP
GOK = 1
Trbegin [ANG2] , [ANI2] , [ANH2] , [ATX2]
 Delete [ANG2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ANAVIG" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ANG2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ANI2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ANAVCRE" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ANI2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ANH2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ANAVFIL" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ANH2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ANG1]ANG0 Where COD=TABLE
  [F:ANG2] = [F:ANG1]
  Call COPTEXTE([F:ANG1]DES,[F:ANG2]DES) From OBJDIV
  If GOK<1 : Break : Endif
  If dim([F:ANG2]UPDUSR)>0 : [F:ANG2]UPDUSR = GUSER : Endif
  If dim([F:ANG2]UPDDAT)>0 : [F:ANG2]UPDDAT = date$ : Endif
  If dim([F:ANG2]UPDTIM)>0 : [F:ANG2]UPDTIM = time  : Endif
  Write [ANG2]
  If fstat
   GOK=0 : Call FSTA("ANG2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [ANI1]ANI0 Where COD=TABLE
  [F:ANI2] = [F:ANI1]
  Write [ANI2]
  If fstat
   GOK=0 : Call FSTA("ANI2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [ANH1]ANH0 Where COD=TABLE
  [F:ANH2] = [F:ANH1]
  Write [ANH2]
  If fstat
   GOK=0 : Call FSTA("ANH2") From GLOCK : Break
  Endif
 Next
 If GOK<1 : Goto AB_TR_COP : Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

##########################################################################
## Ecrans
##########################################################################
Subprog C_FLD(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
End

Subprog C_OBJ(VALEUR)
Variable Char    VALEUR()
Read [ANG3]ANG1 = [M]FNC;VALEUR
If !fstat & [F:ANG3]COD<>[M]COD
 GMESSAGE = mess(212,126,1)-[F:ANG3]COD : # Couple fonction/objet déjà défini sur
 mkstat = 2 : End
Endif
Call LECTURE("AOB",VALEUR,"") From CONTOBJ
If !find([F:AOB]TYPGES,1,3)
 GMESSAGE = mess(42,115,1) : # Type d'objet incorrect
 mkstat = 2 : End
Endif
[M]NOMFIC = [F:AOB]NOMFIC
End
