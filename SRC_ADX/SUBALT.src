#<AdxTL>@(#)8.0.0.0 $Revision$
Close Local File
Raz GPILOBJ , GNBMASKOUV
GCONSULT = 0
Call OBJET("ALT",GBIDC1,GBIDC2) From GOBJET
End

#-------------------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "APRES_CHOI"  : Gosub APRES_CHOI
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When "LIENS"       : Gosub LIENS
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "RAZCRE"      : Gosub RAZCRE
 When "VERIF_CRE"   : Gosub VERIF_CRE
 When "VERIF_MOD"   : Gosub VERIF_MOD
 When "APRES_CRE"   : Gosub APRES_CRE
 When "APRES_MOD"   : Gosub APRES_MOD
 When "ANNULE"      : Gosub ANNULE
 When "AP_ANNULE"   : Gosub AP_ANNULE
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "FILTRE"      : Gosub FILTRE
 When "STYLE"       : Gosub STYLE
 When "DEGRISE"     : Gosub DEGRISE
 When "FIN_ACTION"  : Gosub FIN_ACTION
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "CHANGE"      : Gosub CHANGE
 When "ABANDON"     : Gosub ABANDON
Endcase
Return

#----------------------#
$OUVRE
If filinfo(filpath("FIL","AVIEWTAB","fde"),0)<0
& or filinfo(filpath("FIL","AVIEWFLD","fde"),0)<0
& or filinfo(filpath("FIL","AVIEWIND","fde"),0)<0
 Local File ATABLE   [AVWT]
 Local File ATABZON  [AVWF]
 Local File ATABIND  [AVWI]
Else
 Local File AVIEWTAB [AVWT]
 Local File AVIEWFLD [AVWF]
 Local File AVIEWIND [AVWI]
Endif
Local File ADOSSIER [ADS] #Bug 78943
If !clalev([M:ALH1]) : Local Mask ALH1 [ALH1] : Endif
Local Integer NUMERO , OKTRT , DIME , OLDNUM
Local Integer VERIF_INTIT , VERIF_VALEUR , MODIF_CLOB
Local Integer R , D , ERF , L , M , MAXCOL , NOL , CPT
MAXCOL  = max(16,dim([M:ALH1]FLD)-1)
Local Char    TBORG(GLONABR+2)(1..20) , TBDES(GLONABR+2)(1..20)
Local Integer M1 , M2 , M3
Local Integer N1 , N2 , N3
Local Char    MESSA(250) , CHAINE(255) , CH2(50) , CH3(50) , CH4(50) , OLDREP(1)
Local Integer TR(1..MAXCOL) , TI(1..MAXCOL) , TN(1..MAXCOL) , NB , NIVMAX
Local Char T_VALEUR #Bug 78943
Local Char L_LIST_LANG(3)(1..20) #Bug 78943
Local Integer T_INT #Bug 78943
Return

#----------------------#
$APRES_CHOI
Case REPONSE
 When GSTARAF : OLDREP = REP : REP = ""
Endcase
Return

#----------------------#
$DEGRISE
$STYLE
Setmok [ALT1] With 0
Return

#----------------------#
$RAZCRE
Call CREFLUX([M:ALT5]CLOB)
[M:ALT1]CLBFL = [M:ALT5]CLOB
Raz [M:ALT5]
Affzo [M:ALT1]CLBFL
Return

#----------------------#
$FILTRE
FILTSUP = "TYP=3"
Return

#----------------------#
$INICRE
$INIMOD
[F:ALH]TYP = 3
Return

#----------------------#
$FIN_ACTION
Case REPONSE
 When GSTAANU
  If CLECUR1="" & CLECUR2=""
   Call CREFLUX([M:ALT5]CLOB)
   [M:ALT1]CLBFL = [M:ALT5]CLOB
   Raz [M:ALT5]
   Affzo [M:ALT1]CLBFL
  Endif
 When GSTACRE
  Setmok [ALT1] With 0
 When GSTARAF
  REP = OLDREP
Endcase
Return

#----------------------#
$CHANGE
Update [AXX] Where CODFIC="ALISTED" & ZONE = "INTITLIG" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA ALISTED"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Update [AXX] Where CODFIC="ALISTEH" & ZONE = "INTIT"  & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA ALISTEH"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Update [AXX] Where CODFIC="ALISTEH" & ZONE = "INTITSHO"  & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA ALISTEH"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

#----------------------#
$LIENS
[M:ALT5]NBLIG = 0
OK = 1
# Chargement des tables
nolign = 0
For [ALT] Where COD=[M]COD
 If nolign>=dim([M:ALT5]TABLE)
  OK = 0 : Break
 Endif
 nolign += 1
 [M:ALT5]TYPLIG(nolign-1) = 1 : # Tables
 [M:ALT5]TABLE(nolign-1)  = [F:ALT]TBL
 [M:ALT5]X(nolign-1)      = [F:ALT]X
 [M:ALT5]Y(nolign-1)      = [F:ALT]Y
 [M:ALT5]LARGE(nolign-1)  = [F:ALT]LRG
 [M:ALT5]HAUT(nolign-1)   = [F:ALT]HIG
 Read [AVWT]CODFIC=[F:ALT]TBL
 [M:ALT5]ABREV(nolign-1)  = [AVWT]ABRFIC
 [M:ALT5]VISFLG(nolign-1) = 2
 Call TEXTE([F:AVWT]INTITFIC,[M:ALT5]LIBTAB(nolign-1)) From OBJDIV
Next ALT
[M:ALT5]NBLIG = nolign

# Chargement des champs
For I=1 To [M:ALT5]NBLIG
 If [M:ALT5]TYPLIG(I-1)=1
  For [AVWF]NUMLIG Where CODFIC=[M:ALT5]TABLE(I-1)
   Read [ATY]CODTYP=[F:AVWF]CODTYP
   If find([F:ATY]TYPTYP,9,10) : # Clob/Blob
    R = 0
   Else
    R = [F:AVWF]DIME
    If [F:AVWF]CODACT<>""
     Read [ACV]CODACT = [F:AVWF]CODACT
     If fstat or [F:ACV]FLACT<>2
      R = 0
     Else
      If [F:ACV]DIMFIL<>0 or [F:ACV]DIME<>0
       R = max([F:ACV]DIMFIL,[F:ACV]DIME)
      Endif
      R = max(R,1)
     Endif
    Endif
   Endif
   For D=0 To R-1
    If nolign>=dim([M:ALT5]TABLE)
     OK = 0 : Break 3
    Endif
    nolign += 1
    indice = D
    [M:ALT5]TYPLIG(nolign-1) = 2 : # Champs des tables
    [M:ALT5]CHAMP(nolign-1)  = "["+[M:ALT5]ABREV(I-1)+"]"+[F:AVWF]CODZONE
    If D>0
     [M:ALT5]CHAMP(nolign-1) += "("+num$(D)+")"
    Endif
    [M:ALT5]VISFLG(nolign-1) = 2
    Call TEXTE([F:AVWF]NOCOURT,[M:ALT5]LIBCHP(nolign-1)) From OBJDIV
    [M:ALT5]CODTYP(nolign-1) = [F:AVWF]CODTYP
    If [F:AVWF]LONG<>0
     [M:ALT5]LONG(nolign-1)  = [F:AVWF]LONG
    Else
     Read [ATY]CODTYP=[F:AVWF]CODTYP
     If [F:ATY]LNGTYP<>0
      #[M:ALT5]LONG(nolign-1) = [F:ATY]LNGTYP : # ccl
     Endif
    Endif
    If [F:AVWF]CODTYP="ADI"
     Read [AMP]CODPAR=2;[F:AVWF]CODFIC;[F:AVWF]CODZONE;"ADI"
     ERF = 0
     Onerrgo ERF
     [M:ALT5]NOLIB(nolign-1) = val(num$(evalue([F:AMP]VALPAR)))
     If ERF
      [M:ALT5]NOLIB(nolign-1) = val([F:AMP]VALPAR)
     Endif
     Onerrgo
    Else
     [M:ALT5]NOLIB(nolign-1) = [F:AVWF]NOLIB
    Endif
   Next D
  Next ATZ
 Endif
Next I
# Chargement des index
For I=1 To [M:ALT5]NBLIG
 If [M:ALT5]TYPLIG(I-1)=1
  For [AVWI]NUMLIG Where CODFIC=[M:ALT5]TABLE(I-1)
   If nolign>=dim([M:ALT5]TABLE)
    OK = 0 : Break 2
   Endif
   nolign += 1
   [M:ALT5]TYPLIG(nolign-1) = 5 : # Index
   [M:ALT5]TABLE(nolign-1)  = [F:AVWI]CODFIC
   [M:ALT5]ABREV(nolign-1)  = [F:AVWI]CODIND
   [M:ALT5]IDENT(nolign-1)  = [F:AVWI]NUMLIG
   [M:ALT5]EXPR(nolign-1)   = ctrans([F:AVWI]DESCRIPT,"+-",";;")
  Next ATI
 Endif
Next I
# Chargement des liens
NUMERO = 0
For [ALL] Where COD=[M]COD
 K = 0
 For CHAINE=[F:ALL]LNKORG,[F:ALL]LNKDES
  K = 0
  For L=0 To nolign-1
   If [M:ALT5]TYPLIG(L)=2 & [M:ALT5]CHAMP(L)=CHAINE
    K = 1 : Break
   Endif
  Next L
  If !K : Break : Endif
 Next CHAINE
 If K
  If nolign>=dim([M:ALT5]TABLE)
   OK = 0 : Break
  Endif
  NUMERO += 1
  nolign += 1
  [M:ALT5]TYPLIG(nolign-1) = 3 : # Liens
  [M:ALT5]LNKORG(nolign-1) = [F:ALL]LNKORG
  [M:ALT5]LNKDES(nolign-1) = [F:ALL]LNKDES
  [M:ALT5]LNKTYP(nolign-1) = [F:ALL]LNKTYP
  [M:ALT5]IDENT(nolign-1)  = NUMERO
  [M:ALT5]VISFLG(nolign-1) = 2
 Endif
Next ALL
# Chargement des colonnes
NUMERO = 0
OLDNUM = 0
For [ALD] Where COD=[M]COD
 OLDNUM += 1
 If [F:ALD]CLC<>""
  K = 1
 Else
  K = 0
  Read [AVWT]CODFIC=[F:ALD]TBL
  CHAINE = "["+[F:AVWT]ABRFIC+"]"+[F:ALD]FLD
  For L=0 To nolign-1
   If [M:ALT5]TYPLIG(L)=2 & [M:ALT5]CHAMP(L)=CHAINE
    K = 1 : Break
   Endif
  Next L
 Endif
 If K
  If nolign>=dim([M:ALT5]TABLE)
   OK = 0 : Break
  Endif
  NUMERO += 1
  nolign += 1
  [M:ALT5]TYPLIG(nolign-1) = 4 : # Champs sélectionnés
  If [F:ALD]CLC<>""
   [M:ALT5]EXPR(nolign-1)   = [F:ALD]CLC
   [M:ALT5]FORMU(nolign-1)  = 2
  Else
   [M:ALT5]EXPR(nolign-1)   = CHAINE
   [M:ALT5]FORMU(nolign-1)  = 1
  Endif
  # Bug 78943
  If [F:ALD]NUMTEX>0
    [M:ALT5]NUMTEX(nolign-1) = [F:ALD]NUMTEX
  Else
    [M:ALT5]NUMTEX(nolign-1) = NUMERO
  Endif
  If [M:ALT5]NUMTEX(nolign-1)>[M:ALT5]MAXNUMTEX
    [M:ALT5]MAXNUMTEX = [M:ALT5]NUMTEX(nolign-1)
  Endif
  # End Bug 78943

  [M:ALT5]CODTYP(nolign-1) = [F:ALD]CODTYP
  [M:ALT5]LONG(nolign-1)   = [F:ALD]LNG
  [M:ALT5]NOLIB(nolign-1)  = [F:ALD]NOLIB
  Call LECTEXTRA([M:ALT5]LIBCHP(nolign-1),"ALISTED","INTITLIG",[M]COD,num$([M:ALT5]NUMTEX(nolign-1))) From ATEXTRA
  If [M:ALT5]LIBCHP(nolign-1)=""
   Read [AVWF]CODZONE=[F:ALD]TBL;[F:ALD]FLD
   If !fstat
    Call TEXTE([F:AVWF]NOCOURT,[M:ALT5]LIBCHP(nolign-1)) From OBJDIV
   Endif
  Endif
  [M:ALT5]VISFLG(nolign-1) = ([F:ALD]STREND<=2)+1
  [M:ALT5]BORNE(nolign-1)  = (find([F:ALD]STREND,2,3)<>0)+1
  [M:ALT5]CUMUL(nolign-1)  = [F:ALD]CUM
  [M:ALT5]TRI(nolign-1)    = [F:ALD]SRT
  [M:ALT5]GROUPE(nolign-1) = [F:ALD]GRP
  [M:ALT5]NIV(nolign-1)    = [F:ALD]NIV
  [M:ALT5]IDENT(nolign-1)  = NUMERO
  [M:ALT5]GRA(nolign-1)    = [F:ALD]GRA
  [M:ALT5]REP(nolign-1)    = [F:ALD]REP
  [M:ALT5]VALDEB(nolign-1) = [F:ALD]VALDEB
  [M:ALT5]VALFIN(nolign-1) = [F:ALD]VALFIN
 Endif
Next ALD
[M:ALT5]NBLIG = nolign
Read [ALC]ALC0=[M]COD
If !fstat
 [M:ALT5]CLBCNF = [F:ALC]CLBCNF
Endif
Call CREFLUX([M:ALT5]CLOB)
[M:ALT1]CLBFL = [M:ALT5]CLOB
Gosub GRISE_REPGRA
Gosub GRISE_TYPGRA
If !OK
 Call ERREUR(mess(161,115,1)-"(>"+num$(dim([M:ALT5]TABLE))+")") From GESECRAN : # Trop de lignes
Endif
Return

$ERF
ERF = errn
Resume

#----------------------#
$VERIF_CRE
$VERIF_MOD
Local Integer NBPAR5
For nolign=1 To [M:ALT5]NBLIG
 If [M:ALT5]TYPLIG(nolign-1)=4
  NBPAR5 +=1
  Break
 Endif
Next
If !NBPAR5
 Call ERREUR(mess(178,123,1) ) From GESECRAN : # : Il doit y avoir au moins une ligne
 OK = 0 : Return
Endif
Gosub VERIF_EXPR
If OK=0 : Return  : Endif
[M:ALT5]CLBREC = [M:ALT1]CLBFL : # Pour voir ce qu'on reçoit
Call AINTERFL([M:ALT1]CLBFL,TBORG,TR,K)
MODIF_CLOB = 0
Gosub VERIF
Return

#----------------------#
$APRES_CRE
$APRES_MOD
If MODIF_CLOB
 Call CREFLUX([M:ALT1]CLBFL)
 Affzo [M:ALT1]
Endif
Return

#--------------------------------------------------------------------------------------------#
# Les champs invisibles sont repoussés sur les dernières colonnes (cause export Excel)
#--------------------------------------------------------------------------------------------#

$TRI_STREND
Local Integer XNBLIG
For NOL=1 To [M:ALT5]NBLIG
 If [M:ALT5]TYPLIG(NOL-1) = 4
  If [M:ALT5]BORNE(NOL-1)=2
   If [M:ALT5]VISFLG(NOL-1)<>2
    XNBLIG = 1
    Break
   Endif
  Elsif [M:ALT5]VISFLG(NOL-1)<>2
   XNBLIG = 1
   Break
  Endif
 Endif
Next

If !XNBLIG : Return : Endif

Local Integer XBORNE(0..dim([M:ALT5]IDENT)-1),XVISFLG(0..dim([M:ALT5]IDENT)-1),XIDENT(0..dim([M:ALT5]IDENT)-1)
Local Integer XNIV(0..dim([M:ALT5]IDENT)-1),XLIG(0..dim([M:ALT5]IDENT)-1)
XNBLIG = 0 : CPT = 0

For NOL=1 To [M:ALT5]NBLIG
 If [M:ALT5]TYPLIG(NOL-1) = 4
  XNBLIG+=1
  XBORNE(XNBLIG)  = [M:ALT5]BORNE(NOL-1)
  XVISFLG(XNBLIG) = [M:ALT5]VISFLG(NOL-1)
  XIDENT(XNBLIG)  = [M:ALT5]IDENT(NOL-1)
  XNIV(XNBLIG)    = [M:ALT5]NIV(NOL-1)
  XLIG(XNBLIG)    = NOL
 Endif
Next

Sorta XBORNE, XVISFLG, XIDENT , XNIV ,XLIG Order By XIDENT(indice)

For NOL=1 To dim([M:ALT5]IDENT)-1
 If XIDENT(NOL)>0
  If XBORNE(NOL)=2
   If XVISFLG(NOL)=2
    CPT +=1
    XIDENT(NOL) = CPT
   Else
    #
   Endif
  Elsif XVISFLG(NOL)=2
   CPT +=1
   XIDENT(NOL) = CPT
  Else
   #
  Endif
 Endif
Next

For NOL=1 To dim([M:ALT5]IDENT)-1
 If XIDENT(NOL)>0
  If XBORNE(NOL)=2
   If XVISFLG(NOL)=2
    #
   Else
    CPT +=1
    XIDENT(NOL) = CPT
    XNIV(NOL) = max(XNIV(0..dim([M:ALT5]IDENT)-1))
   Endif
  Elsif XVISFLG(NOL)=2
   #
  Else
   CPT +=1
   XIDENT(NOL) = CPT
   XNIV(NOL) = max(XNIV(0..dim([M:ALT5]IDENT)-1))
  Endif
 Endif
Next

For NOL=1 To dim([M:ALT5]IDENT)-1
 If XIDENT(NOL)>0
  [M:ALT5]BORNE(XLIG(NOL)-1)  =   XBORNE(NOL)
  [M:ALT5]VISFLG(XLIG(NOL)-1) =   XVISFLG(NOL)
  [M:ALT5]IDENT(XLIG(NOL)-1)  =   XIDENT(NOL)
  [M:ALT5]NIV(XLIG(NOL)-1)    =   XNIV(NOL)
 Endif
Next

Return

#----------------------#

# remove the titles that are no longer in use from ATEXTRA  (Bug 78943)
$L_REMOVE_TITLE
Local Char WCRITERE(250)(1..10)
Local Integer WICRITERE
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
If clalev([F:ALD])=0 : Local File ALISTED [ALD] : Endif

# build the filter criterias
Call ADDCRIT(WCRITERE,WICRITERE,"CRITERE",'CODFIC="ALISTED"',"") From GOBJSUB
Call ADDCRIT(WCRITERE,WICRITERE,"CRITERE",'ZONE="INTITLIG"',"&") From GOBJSUB
Call ADDCRIT(WCRITERE,WICRITERE,"CRITERE",'IDENT1="'+[M]COD+'"',"&") From GOBJSUB
For [ALD] Where COD = [M]COD
 If [ALD]NUMTEX > 0 # Champs sélectionnés
   Call ADDCRIT(WCRITERE,WICRITERE,"CRITERE",'IDENT2<>"'+num$([ALD]NUMTEX)+'"',"&") From GOBJSUB
 Endif
Next

# extract titles that are no longer in use
Filter [AXX] Where evalue(WCRITERE)
For[AXX]
 # remove
 Call SUPTEXLAN([AXX]CODFIC,[AXX]ZONE,[AXX]LANGUE,[AXX]IDENT1,[AXX]IDENT2) From ATEXTRA #
Next
Filter [AXX]
Return


#----------------------#
$CREATION
Gosub TRI_STREND
Call MAJTEXTRA([M]INTIT,"ALISTEH","INTIT",[M]COD,"") From ATEXTRA
Call MAJTEXTRA([M]INTITSHO,"ALISTEH","INTITSHO",[M]COD,"") From ATEXTRA
# Bug 78943
Read [ADS]DOSSIER = nomap
If !fstat
 For I = 0 To (dim([F:ADS]LAN)-1)
  If [F:ADS]LAN(I)<>""
   # build a local list of languages
   L_LIST_LANG(I+1)=[F:ADS]LAN(I)
  Endif
 Next
Endif
# End Bug 78943

For nolign=1 To [M:ALT5]NBLIG
 Case [M:ALT5]TYPLIG(nolign-1)
  When 1 : # Tables
   Raz [F:ALT]
   [F:ALT]COD    = [M]COD
   [F:ALT]TBL    = [M:ALT5]TABLE(nolign-1)
   [F:ALT]X      = [M:ALT5]X(nolign-1)
   [F:ALT]Y      = [M:ALT5]Y(nolign-1)
   [F:ALT]LRG    = [M:ALT5]LARGE(nolign-1)
   [F:ALT]HIG    = [M:ALT5]HAUT(nolign-1)
   Write [ALT]
   If fstat
    GOK = 0 : Call FSTA("ALT") From GLOCK : Break
   Endif
  When 3 : # Liens
   Raz [F:ALL]
   [F:ALL]COD    = [M]COD
   [F:ALL]LNKORG = toupper([M:ALT5]LNKORG(nolign-1))
   [F:ALL]LNKDES = toupper([M:ALT5]LNKDES(nolign-1))
   [F:ALL]LNKTYP = [M:ALT5]LNKTYP(nolign-1)
   Write [ALL]
   If fstat
    GOK = 0 : Call FSTA("ALL") From GLOCK : Break
   Endif
  When 4 : # Champs sélectionnés
   Raz [F:ALD]
   K = instr(1,[M:ALT5]EXPR(nolign-1),"]")
   If K or [M:ALT5]FORMU(nolign-1)=2
    [F:ALD]        = [M:ALT5]
    [F:ALD]ORD     = [M:ALT5]IDENT(nolign-1)
    [F:ALD]COD     = [M]COD
    [F:ALD]LIG     = [M:ALT5]IDENT(nolign-1)
    If [M:ALT5]FORMU(nolign-1)=2
     [F:ALD]CLC    = [M:ALT5]EXPR(nolign-1)
    Else
     [F:ALD]FLD    = toupper(right$([M:ALT5]EXPR(nolign-1),K+1))
     [F:ALD]TBL    = ""
     For J=0 To [M:ALT5]NBLIG-1
      If [M:ALT5]TYPLIG(J) = 1 & [M:ALT5]ABREV(J) = toupper(seg$([M:ALT5]EXPR(nolign-1),2,K-1))
       [F:ALD]TBL    = [M:ALT5]TABLE(J)
       Break
      Endif
     Next
     If [F:ALD]TBL=""
      Read [AVWT]ABRFIC=toupper(seg$([M:ALT5]EXPR(nolign-1),2,K-1))
      [F:ALD]TBL    = [F:AVWT]CODFIC
     Endif
    Endif
    [F:ALD]CODTYP  = [M:ALT5]CODTYP(nolign-1)
    Read [ATY]CODTYP=[F:ALD]CODTYP
    If !fstat & [F:ATY]LNGTYP<>0
     #[F:ALD]LNG    = [F:ATY]LNGTYP : # ccl
    Else
     [F:ALD]LNG    = [M:ALT5]LONG(nolign-1)
    Endif
    If !fstat & [F:ALD]CODTYP<>"ADI" & [F:ATY]NOLIB<>0
     [F:ALD]NOLIB   = [F:ATY]NOLIB
    Else
     [F:ALD]NOLIB   = [M:ALT5]NOLIB(nolign-1)
    Endif

    # Bug 78943
     #### update title for all languages
     For I = 1 To dim(L_LIST_LANG)
      If L_LIST_LANG(I)<>""

      ### in case it's GLANGUE
      If L_LIST_LANG(I) = GLANGUE
       # take the title from [M:ALT5]LIBCHP
       T_VALEUR = [M:ALT5]LIBCHP(nolign-1)
       # in case it's a table field, try to get the title defined in the resource table
       If [M:ALT5]FORMU(nolign-1)=1 and T_VALEUR = ""
        Read [AVWF]CODZONE=[F:ALD]TBL;[F:ALD]FLD
        If !fstat :
         Call TEXTE([F:AVWF]NOCOURT,T_VALEUR) From OBJDIV
        Endif
       Endif
       If T_VALEUR = ""
         Call SUPTEXTRA("ALISTED","INTITLIG",[M]COD,num$([M:ALT5]NUMTEX(nolign-1))) From ATEXTRA
       Else
         Call MAJTEXTRA(T_VALEUR,"ALISTED","INTITLIG",[M]COD,num$([M:ALT5]NUMTEX(nolign-1))) From ATEXTRA
       Endif

       ### in case it's not GLANGUE
       Else
        # 1: get the title from ATEXTRA
        T_VALEUR = func AFNC.TEXTRALAN(L_LIST_LANG(I),"ALISTED","INTITLIG",[M]COD,num$([M:ALT5]NUMTEX(nolign-1)))
        If T_VALEUR = ""
          # in case of "free expression"
          If [M:ALT5]FORMU(nolign-1)=2
           # 2: set title to "Expression" by default
           T_VALEUR = mess(2,89,1)
          # in case of "table field"
          Else
           Read [AVWF]CODZONE=[F:ALD]TBL;[F:ALD]FLD
           If !fstat
            # 2: get title from the resource table
            T_VALEUR = func AFNC.LANTEXTE(L_LIST_LANG(I),[F:AVWF]NOCOURT)
           Endif
          Endif
          If T_VALEUR <> ""
           Call TEXTRALANMAJ(L_LIST_LANG(I),T_VALEUR,"ALISTED","INTITLIG",[M]COD,num$([M:ALT5]NUMTEX(nolign-1))) From AFNC
          Endif
        Endif

       Endif
      Endif
     Next
    # End Bug 78943

    If [M:ALT5]BORNE(nolign-1)=2
     If [M:ALT5]VISFLG(nolign-1)=2
      [F:ALD]STREND = 2 : # Colonne visible + saisie borne
     Else
      [F:ALD]STREND = 3 : # Colonne non visible + saisie borne
     Endif
    Elsif [M:ALT5]VISFLG(nolign-1)=2
     [F:ALD]STREND = 1 : # Colonne visible + pas de saisie borne
    Else
     [F:ALD]STREND = 4 : # Colonne non visible + pas de borne
    Endif
    [F:ALD]CUM     = [M:ALT5]CUMUL(nolign-1)
    [F:ALD]SRT     = [M:ALT5]TRI(nolign-1)
    [F:ALD]GRP     = [M:ALT5]GROUPE(nolign-1)
    [F:ALD]NIV     = [M:ALT5]NIV(nolign-1)
    [F:ALD]GRA     = [M:ALT5]GRA(nolign-1)
    [F:ALD]REP     = [M:ALT5]REP(nolign-1)
    [F:ALD]VALDEB  = [M:ALT5]VALDEB(nolign-1)
    [F:ALD]VALFIN  = [M:ALT5]VALFIN(nolign-1)
    Write [ALD]
    If fstat
     GOK = 0 : Call FSTA("ALD") From GLOCK : Break
    Endif
   Endif
 Endcase
Next nolign
If GOK<1 : Return : Endif
Raz [F:ALC]
[F:ALC]COD    = [M]COD
[F:ALC]CLBCNF = [M:ALT5]CLBCNF
Write [ALC]
If fstat
 GOK = 0 : Call FSTA("ALC") From GLOCK : Return
Endif
# BUG 78943
Gosub L_REMOVE_TITLE
# End Bug 78943
Return

#----------------------#
$MODIF
Delete [ALD] Where COD=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ALISTED"-CLECUR1 : Return
Endif
Delete [ALT] Where COD=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ALISTET"-CLECUR1 : Return
Endif
Delete [ALL] Where COD=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ALISTEL"-CLECUR1 : Return
Endif
Delete [ALC] Where COD=CLECUR1
If fstat=1
 GOK = -1 : GLOCK = "$ALISTEC"-CLECUR1 : Return
Endif
Gosub CREATION
Return

#----------------------#
$ANNULE
Delete [AXX] Where (CODFIC="ALISTEH" or CODFIC="ALISTED") & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK  : Return
Endif
Delete [ALR] Where COD=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("ALR",[L]CODE) From GLOCK  : Return
Endif
If dim([F:ALH]TYPENV)>0 & dim([F:ALV]COD)>0
 Delete [ALV] Where COD=[L]CODE
 If fstat=1 | fstat>5
  GOK=0 : Call RSTA("ALR",[L]CODE) From GLOCK  : Return
 Endif
Endif
Return

#----------------------#
$AP_ANNULE
Gosub SETPRG From SUBALH
Gosub SETMSK From SUBALH
Call DELMSK(PREFMSK+[L]CODE,APPLI) From MSKDIV
Call DELWIN(PREFMSK+[L]CODE,APPLI) From MSKDIV
Call EFFACE_ADX("",APPLI,PREFPRG+[L]CODE,OK) From ORDSYS
Call EFFACE(filpath("TRT",PREFPRG+[L]CODE,"src",APPLI),OK) From ORDSYS
Return

#----------------------#
$SETBOUT
If CLECUR=0 | REP<>"" | !VERROU
 Call VIREBOUT(CHAINE,"VB2") From GOBJET
 CHMEN = ""
Else
 CHMEN = "1"
 Gosub SETPRG From SUBALH
 Gosub SETMSK From SUBALH
 Call EXISTE_ADX("","",PREFPRG+CLECUR1,OKTRT) From ORDSYS
 If !OKTRT or filinfo(filpath(adxrob(0),PREFMSK+CLECUR1,"msk",nomap),0)<0
  Call VIREBOUT(CHAINE,"B") From GOBJET
 Endif
 If [M]ENAFLG<>2
  Call VIREBOUT(CHAINE,"VB") From GOBJET
 Endif
Endif
Return

#----------------------#
$EXEBOUT
Case REP
 When "V"
  Call VALIDE(CLECUR1,nomap,0,0) From SUBALT1
  If GERR & dim([M:ALT1]ENAFLG)>0
   Read [ALH]ALH0 = CLECUR1
   [M]ENAFLG = [F:ALH]ENAFLG
   Affzo [ALT1]ENAFLG
   If dim([L]AUPDTICK)>0 & dim([F]updTick)>0
    [L]AUPDTICK = [F]updTick
   Endif
  Endif

#  Syracuse validation has been included in VALID program so the validation utilities will work as well (Sep 11,2013)
#  Call VALIDE(CLECUR1,nomap,0,0) From SUBALT11
#  If GERR & dim([M:ALT1]ENAFLG)>0
#   Read [ALH]ALH0 = CLECUR1
#   [M]ENAFLG = [F:ALH]ENAFLG
#   Affzo [ALT1]ENAFLG
#   If dim([L]AUPDTICK)>0 & dim([F]updTick)>0
#    [L]AUPDTICK = [F]updTick
#   Endif
#  Endif

Endcase
Return

#----------------------#
$SEL_TABLE
Case TABLE
 When "SELTAB" : OBJET ="ATB"
Endcase
Return

#----------------------#
$GRISE_REPGRA
Case [M:ALT4]REPGRA
 When 0,1 : # Caractère
  [M:ALT4]OPTGRA = ""
  [M:ALT4]TYPGRA = 0
  [M:ALT4]DEFGRA = 0
  Raz [M:ALT4]IMAG
  Affzo [ALT4]OPTGRA
  Affzo [ALT4]TYPGRA, DEFGRA, IMAG
  Grizo [ALT4]OPTGRA
  Grizo [ALT4]TYPGRA, DEFGRA, IMAG
 When 2 : # Caractère ou graphique
  Actzo [ALT4]OPTGRA
  Actzo [ALT4]DEFGRA, IMAG
  [M:ALT4]TYPGRA = 2
  Affzo [ALT4]TYPGRA
  Diszo [ALT4]TYPGRA
 When 3 : # Caractère et graphique
  Actzo [ALT4]OPTGRA
  Actzo [ALT4]DEFGRA, IMAG
  [M:ALT4]TYPGRA = 2
  Affzo [ALT4]TYPGRA
  Diszo [ALT4]TYPGRA
 When 4 : # Graphique
  [M:ALT4]OPTGRA = ""
  Affzo [ALT4]OPTGRA
  Grizo [ALT4]OPTGRA
  Actzo [ALT4]DEFGRA, IMAG
  [M:ALT4]TYPGRA = 2
  Affzo [ALT4]TYPGRA
  Diszo [ALT4]TYPGRA
Endcase
Gosub AFF_OPTIONS
Return

$AFF_OPTIONS
Case [M]REPGRA
 When 2
  [M:ALT4]INTREPGRA = mess(164,139,1) : # Affichage par défaut
  [M:ALT4]TYPREPGRA = "M"
  [M:ALT4]LIBREPGRA = 2936
  [M:ALT4]LNGREPGRA = 20
  [M:ALT4]VALREPGRA = num$([M:ALT4]AFFGRA)
  [M:ALT4]OPTGRA = [M:ALT4]VALREPGRA
  Call CHARGE([M:ALT4]OPTGRA,[M:ALT4]TYPREPGRA,[M:ALT4]LIBREPGRA,[M:ALT4]LNGREPGRA,[M:ALT4]VALREPGRA)
& From FMTVAR
 When 3
  [M:ALT4]INTREPGRA = mess(163,139,1) : # Position
  [M:ALT4]TYPREPGRA = "M"
  [M:ALT4]LIBREPGRA = 2931
  [M:ALT4]LNGREPGRA = 20
  [M:ALT4]VALREPGRA = num$([M:ALT4]POSGRA)
  [M:ALT4]OPTGRA = [M:ALT4]VALREPGRA
  Call CHARGE([M:ALT4]OPTGRA,[M:ALT4]TYPREPGRA,[M:ALT4]LIBREPGRA,[M:ALT4]LNGREPGRA,[M:ALT4]VALREPGRA)
& From FMTVAR
 When Default
  [M:ALT4]INTREPGRA = ""
Endcase
Chgtzn [M:ALT4]OPTGRA With [M:ALT4]INTREPGRA
Return

$GRISE_TYPGRA
Case [M:ALT4]REPGRA
 When 0,1 : # Graphique
  [M:ALT4]FSHGRA = 0
  Affzo [ALT4]FSHGRA
  Grizo [ALT4]FSHGRA
 When Default : # Caractère ou graphique/Caractère ou graphique/Graphique
  Case [M:ALT4]TYPGRA
   When 1  : # Graphe Flash
    [M:ALT4]FSHGRA = 0 : Affzo [ALT4]FSHGRA : Grizo [ALT4]FSHGRA
   When 2 : # Graphe multi Flash
    Actzo [ALT4]FSHGRA
   When 4 : # XSL
    [M:ALT4]FSHGRA = 0 : Affzo [ALT4]FSHGRA : Grizo [ALT4]FSHGRA
  Endcase
Endcase
Gosub AFF_IMAGE
Return

$AFF_IMAGE
Local Char NOMIMAG(200) , IMAG1(20)
Case [M:ALT4]TYPGRA
 When 1,2
  Case [M:ALT4]DEFGRA
   When 1 : IMAG1="xbar"
   When 2 : IMAG1="xline"
   When 3 : IMAG1="xarea"
   When 4 : IMAG1="xpie"
   When 5 : IMAG1="xradar"
  Endcase
  If IMAG1<>""
   Case [M:ALT4]FSHGRA
    When 1 : IMAG1+="m"
    When 2 : IMAG1+="cu"
    When 3 : IMAG1+="co"
   Endcase
  Endif
 When 3
  Case [M:ALT4]FSHGRA
   When 4 : IMAG1="calmonth"
   When 5 : IMAG1="calweek"
   When 6 : IMAG1="calday"
  Endcase
 When 5
  IMAG1="gantt"
Endcase
Read [ASB]ASB0="SCR";toupper(IMAG1)
If !fstat
 [M:ALT4]IMAG=[F:ASB]BLOB
Else
 Raz [M:ALT4]IMAG
Endif
Return

#-----------------------------------------------------#
# Verification qu'il y est pas un champ expr sur un sous niveau seul
$VERIF_EXPR
Local Integer I , J  , K , RUPTURE , OKEXPR
OKEXPR  = 1
RUPTURE = 1
For I=1 To [M:ALT5]NBLIG
 If [M:ALT5]TYPLIG(I-1)=4
  K = 0
  If RUPTURE=2
   K = 1
  Elsif [M:ALT5]NIV(I-1)<>RUPTURE
   K = 1
  Endif
  If K
   RUPTURE = [M:ALT5]NIV(I-1)
   ## Verif si expression
   If !find ([M:ALT5]EXPR(I-1),[M:ALT5]CHAMP(0..[M:ALT5]NBLIG-1))
    ## Verif qu'il y est au moins un vrai champ sur ce niveau
    Raz OKEXPR
    For J=1 To [M:ALT5]NBLIG
     If [M:ALT5]NIV(I-1)=[M:ALT5]NIV(J-1)  & find ([M:ALT5]EXPR(J-1),[M:ALT5]CHAMP(0..[M:ALT5]NBLIG-1))
      OKEXPR  += 1
     Endif
    Next
    If !OKEXPR : Break : Endif
   Endif
  Endif
 Endif
Next
If !OKEXPR
 Call ERREUR([M:ALT5]LIBCHP(I-1)-":"-mess(104,127,1)) From GESECRAN : # Un champ expression ne peut être seul dans un sous-niveau
 OK = 0 : Return
Endif
Return

#-----------------------------------------------------#
$VERIF

# Vérification paramètrage graphisme

Raz VERIF_INTIT , VERIF_VALEUR
If [M]REPGRA>=2 & [M]ENAFLG=2
 Raz TI , TN , R
 For I=1 To [M:ALT5]NBLIG
  If [M:ALT5]TYPLIG(I-1)=4 & [M:ALT5]VISFLG(I-1)=2 : # Champs sélectionnés visibles
   R += 1
   TI(R) = I-1
   TN(R) = [M:ALT5]IDENT(I-1)
  Endif
 Next I
 Sorta R TN,TI Order By TN(indice+1)
 # On vérifie s'il n'y qu'un libellé et 1 ou +sieurs valeurs    ... et si les types sont corrects
 For I=1 To R
   Read [ATY]CODTYP=[M:ALT5]CODTYP(TI(I))
   If fstat=0
    If (find([F:ATY]TYPTYP,7) or find([M:ALT5]CODTYP(TI(I)),"ATX","AXX","AX1","AX2","AX3"))
     If VERIF_INTIT=0
      [M:ALT5]GRA(TI(I)) = 3 : # Libellé
      VERIF_INTIT=1
      If [M:ALT5]REP(TI(I))=0 : [M:ALT5]REP(TI(I))=1 : Endif
     Else
      [M:ALT5]GRA(TI(I)) = 4 : # Aucun
      [M:ALT5]REP(TI(I)) = 0
     Endif
    Elsif find([F:ATY]TYPTYP,2,3,4)
      VERIF_VALEUR+=1
      If [M:ALT5]GRA(TI(I))<>1 and [M:ALT5]GRA(TI(I))<>2 : [M:ALT5]GRA(TI(I)) = 1 : Endif # Valeur
      If [M:ALT5]REP(TI(I))=0 : [M:ALT5]REP(TI(I))=1 : Endif
    Else
      [M:ALT5]GRA(TI(I)) = 4 : # Aucun
      [M:ALT5]REP(TI(I)) = 0
    Endif
   Endif
 Next I
 # On renseigne les champs non définis
# J = (VERIF_INTIT>=1)
# For I=1 To R
#  If [M:ALT5]GRA(TI(I))=0
#   [M:ALT5]GRA(TI(I)) = 4 : # Aucun
#   [M:ALT5]REP(TI(I)) = 1
#   Read [ATY]CODTYP=[M:ALT5]CODTYP(TI(I))
#   If !fstat
#    If (find([F:ATY]TYPTYP,7) or find([M:ALT5]CODTYP(TI(I)),"ATX","AXX","AX1","AX2","AX3")) & !J
#     [M:ALT5]GRA(TI(I)) = 3 : # Libellé
#     VERIF_INTIT += 1
#     J = 1
#    Elsif find([F:ATY]TYPTYP,2,3,4)
#     [M:ALT5]GRA(TI(I)) = 1 : # Valeur
#     VERIF_VALEUR += 1
#    Endif
#   Endif
#  Endif
# Next I
 # Si c'est pas bon, on redistribue les cartes
 If !VERIF_VALEUR or VERIF_INTIT<>1
  Raz VERIF_INTIT , VERIF_VALEUR , J
  For I=1 To R
   [M:ALT5]GRA(TI(I)) = 4 : # Aucun
   [M:ALT5]REP(TI(I)) = 1
   Read [ATY]CODTYP=[M:ALT5]CODTYP(TI(I))
   If !fstat
    If (find([F:ATY]TYPTYP,7) or find([M:ALT5]CODTYP(TI(I)),"ATX","AXX","AX1","AX2","AX3")) & !J
     [M:ALT5]GRA(TI(I)) = 3 : # Libellé
     VERIF_INTIT += 1
     J = 1
    Elsif find([F:ATY]TYPTYP,2,3,4)
     [M:ALT5]GRA(TI(I)) = 1 : # Valeur
     VERIF_VALEUR += 1
    Endif
   Endif
  Next I
  If !VERIF_VALEUR or VERIF_INTIT<>1
   # Il faut au moins un champ de type libellé et de type valeur pour utiliser le graphisme
   GMESSAGE = mess(128,139,1)
   OK = 0 : Return
  Endif
 Endif
Endif

## Vérif du contenu des formules

For I=1 To [M:ALT5]NBLIG
 If [M:ALT5]TYPLIG(I-1)=4 & [M:ALT5]FORMU(I-1)=2 & [M:ALT5]EXPR(I-1)<>""
  CHAINE = [M:ALT5]EXPR(I-1)
  Gosub VERF_FRM
  If !OK
   GERR = 1 : GMESSAGE = MESSA : Break
  Endif
 Endif
Next I
If !OK : Return : Endif

## Petites vérifs pour ne pas exploser les limites

M1 = 16 : # Tri
M2 = 16 : # Bornes
M3 = 16 : # Cumuls
N1 = 0 : N2 = 0 : N3 = 0
For I=1 To [M:ALT5]NBLIG
 If [M:ALT5]TYPLIG(I-1)=4
  If [M:ALT5]TRI(I-1)>1
   N1 += 1
  Endif
  If [M:ALT5]BORNE(I-1)=2
   N2 += 1
  Endif
  If [M:ALT5]CUMUL(I-1)=2
   N3 += 1
  Endif
 Endif
Next I
If N1>M1
 # Trop de critères de tri
 GERR = 1 : GMESSAGE = mess(22,135,1)-"("+mess(74,124,1)-num$(M1)+")"
 OK = 0 : Return
Endif
If N2>M2 & GPRODUIT<>1 : ## GEODE
 # Trop de bornes
 GERR = 1 : GMESSAGE = mess(23,135,1)-"("+mess(74,124,1)-num$(M2)+")"
 OK = 0 : Return
Endif
If N3>M3
 # Trop de cumuls
 GERR = 1 : GMESSAGE = mess(24,135,1)-"("+mess(74,124,1)-num$(M3)+")"
 OK = 0 : Return
Endif

# On force les jointures internes si l'expression de lien contient des champs de tables différentes

Raz I , TBORG , TBDES
For nolign=1 To [M:ALT5]NBLIG
 If [M:ALT5]TYPLIG(nolign-1)=3
  K = instr(1,[M:ALT5]LNKDES(nolign-1),"]")
  If K
   I += 1
   TBDES(I) = seg$([M:ALT5]LNKDES(nolign-1),2,K-1)
   K = instr(1,[M:ALT5]LNKORG(nolign-1),"]")
   If K
    TBORG(I) = seg$([M:ALT5]LNKORG(nolign-1),2,K-1)
   Endif
  Endif
 Endif
Next nolign
Sorta I TBORG,TBDES Order By TBORG(indice+1)
For J=1 To I
 If J>1 & TBDES(J)=TBDES(J-1)
  If TBORG(J)<>TBORG(J-1)
   For nolign=1 To [M:ALT5]NBLIG
    If [M:ALT5]TYPLIG(nolign-1)=3
     K = instr(1,[M:ALT5]LNKDES(nolign-1),"]")
     If K<>0 & TBDES(J)=seg$([M:ALT5]LNKDES(nolign-1),2,K-1)
      [M:ALT5]LNKTYP(nolign-1) = 1 : # Jointure Interne
     Endif
    Endif
   Next nolign
  Endif
 Endif
Next J

# Positionnement du flag "Groupe"

Raz NB , NIVMAX
For I=1 To [M:ALT5]NBLIG
 If [M:ALT5]TYPLIG(I-1)=4
  If [M:ALT5]FORMU(I-1)<>2
   NB += 1
   TR(NB) = [M:ALT5]IDENT(I-1)
   TI(NB) = I
   TN(NB) = [M:ALT5]NIV(I-1)
   NIVMAX = max(NIVMAX,[M:ALT5]NIV(I-1))
  Endif
  [M:ALT5]GROUPE(I-1) = 1
 Endif
Next I
Sorta NB TN,TR,TI Order By TN(indice+1),TR(indice+1)
K = 0
For I=1 To NB
 If K<>TN(I) & TN(I)<NIVMAX
  [M:ALT5]GROUPE(TI(I)-1) = 2
  If [M:ALT5]TRI(TI(I)-1)=1
   [M:ALT5]TRI(TI(I)-1) = 2
  Endif
 Endif
 K = TN(I)
Next I
Return

#--------------------------------#
$VERF_FRM
OK = 1
CHAINE = vireblc(format$("KT:255X",CHAINE),2)
J = 0
Repeat
 J = instr(J+1,CHAINE,"[")
 If J
  K = instr(J+1,CHAINE,"]")
  If K & !instr(1,seg$(CHAINE,J+1,K-1),"/")
   Repeat
    K += 1
   Until K>len(CHAINE) or !instr(1,sigma(0,25,chr$(65+indcum))+sigma(0,9,chr$(48+indcum))+"_",mid$(CHAINE,K,1))
   CH2 = seg$(CHAINE,J,K-1)
   K = instr(1,CH2,"]")
   CH3 = seg$(CH2,2,K-1)
   CH4 = right$(CH2,K+1)
   If left$(CH3,2)="F:" : CH3 = right$(CH3,3) : Endif
   Read [AVWT]ABRFIC = CH3
   If fstat
    MESSA = CHAINE+"\"+CH3-":"-mess(124,124,1) : # Table inexistante
    OK = 0 : Break
   Endif
   M = 0
   For L=1 To [M:ALT5]NBLIG
    If [M:ALT5]TYPLIG(L-1)=1 & [F:AVWT]CODFIC=[M:ALT5]TABLE(L-1)
     M = 1 : Break
    Endif
   Next L
   If !M
    MESSA = CHAINE+"\"+CH3-[F:AVWT]CODFIC-":"-mess(17,123,1) : # Table non définie
    OK = 0 : Break
   Endif
   Read [AVWF]CODZONE = [F:AVWT]CODFIC;CH4
   If fstat
    MESSA = CHAINE+"\"+CH2-":"-mess(41,100,1) : # Champ inexistant
    OK = 0 : Break
   Else
    Read [ATY]CODTYP=[F:AVWF]CODTYP
    If !fstat & find([F:ATY]TYPTYP,9,10)
     MESSA = CHAINE+"\"+mess([F:ATY]TYPTYP,30,1)-":"-mess(30,139,1)-"("+CH2+")" : # Type de donnée non géré
     OK = 0 : Break
    Endif
   Endif
  Endif
 Endif
Until J=0
Return

#-------------------------------------------------------#
Subprog AINTERFL(CLOB,MES,GRAV,OK)
Variable Clbfile CLOB()
Variable Char    MES()(1..)
Variable Integer GRAV(1..)
Variable Integer OK

#   CLOB  : contient le clob de description des paramètres (spécifique à chaque interaction flash)
#   MES   : contient le texte des messages à afficher (0 à 5)
#   GRAV  : contient la gravité des messages 1=info, 2=avertissement, 3=bloquant
#   OK    : =1 si pas de pb, 0 sinon

Local Integer D , R , K , L , M , I , J , ER , ERF , ERT , OK , EX
Local Integer CUR , DEB , FIN , ATD , ATC , TEST , NIVMAX , LIG
Local Integer NBA , NBE , NBB , NB
Local Clbfile ATB(2)(1..5)
If !clalev([M:ALH1]) : Local Mask ALH1 [ALH1] : Endif
Local Char    ATT(30)(1..5) , NOD(2) , INTACT(2) , BALISE(3)(1..2)
Local Char    TABORG(GLONATB) , ABRORG(GLONABR+2) , ZONORG(20)
Local Char    TABDES(GLONATB) , ABRDES(GLONABR+2) , ZONDES(20)
Local Integer DIMORG , DIMDES
Local Char    FLD(GLONAVA)
Local Integer OKIND , PART , DOUB
Local Char    MESSA(250) , CHAINE(255)
Local Char    TABLE(GLONATB) , PARSEL(50)(1..20)
Local Decimal TB(1..60) , TT(1..60)
Local Integer M1 , M2 , M3
Local Integer N1 , N2 , N3
Local Char    CH2(50) , CH3(50) , CH4(50)
Local Integer MAXCOL

Onerrgo ERT

Raz NBE , MES , GRAV
BALISE(1) = "ACT"
BALISE(2) = "AT"
MAXCOL    = max(16,dim([M:ALH1]FLD)-1)

[M:ALT5]CLBREC = [L]CLOB : # Pour voir ce qu'on reçoit

# Traitement des actions
#-------------------------------------------------------------------------------------
# TP : # Déplacement/Modif du bloc d'une table
# DT : # Suppression d'une table
# AT : # Ajout d'une table
# CL : # Création d'un lien
# DL : # Suppression d'un lien
# AF : # Ajout d'un champ sélectionné
# MF : # Déplacement d'un champ sélectionné
# DF : # Suppression d'un champ sélectionné
# LT : # Modification d'un lien
# CF : # Changement de propriétés (tri, borne, cumul, niveau) d'un champ sélectionné
# LF : # Modification du niveau d'un champ sélectionné
# EE : # Ajout d'une expression
# ME : # Modification d'une expression
# FC : # Appel d'une fonction
# SC : # Sauvegarde de la configuration
# CQ : # Effacement du clob
#-------------------------------------------------------------------------------------

CUR = 1
While CUR
 DEB = instr(CUR+1,CLOB,"<"+BALISE(1)+">")
 CUR = DEB
 If DEB
  FIN = instr(DEB,CLOB,"</"+BALISE(1)+">")
  ATC = DEB
  While ATC
   ATD = instr(ATC+1,CLOB,"<"+BALISE(2)+">")
   If ATD>=DEB & ATD<=FIN
    ATC = ATD
   Else
    ATC = 0
   Endif
   If ATC
    Raz NBA , ATT , ER , NBB
    INTACT = right$(CLOB,ATC+len(BALISE(2))+2)
    Case INTACT

     When "TP" : # Déplacement/Modif du bloc d'une table
      For NOD="SK","P1","P2","P3","P4"
       Gosub ATTRIBUTS
      Next NOD
      For I=1 To [M:ALT5]NBLIG
       If [M:ALT5]TYPLIG(I-1)=1 & [M:ALT5]ABREV(I-1)=ATT(1)
        If val(ATT(2))<>0 : [M:ALT5]X(I-1)     = val(ATT(2)) : Endif
        If val(ATT(3))<>0 : [M:ALT5]Y(I-1)     = val(ATT(3)) : Endif
        If val(ATT(4))<>0 : [M:ALT5]LARGE(I-1) = val(ATT(4)) : Endif
        If val(ATT(5))<>0 : [M:ALT5]HAUT(I-1)  = val(ATT(5)) : Endif
        Break
       Endif
      Next I

     When "DT" : # Suppression d'une table
      For NOD="SK"
       Gosub ATTRIBUTS
      Next NOD
      Raz I , TABLE
      While I<[M:ALT5]NBLIG
       I += 1
       K = 0
       Case [M:ALT5]TYPLIG(I-1)
        When 1 : # Table
         If [M:ALT5]ABREV(I-1)=ATT(1) : TABLE = [M:ALT5]TABLE(I-1) : K = 1 : Endif
        When 2 : # Champs
         J = instr(1,[M:ALT5]CHAMP(I-1),"]")
         If J & seg$([M:ALT5]CHAMP(I-1),2,J-1)=ATT(1) : K = 1 : Endif
        When 3 : # Liens
         J = instr(1,[M:ALT5]LNKORG(I-1),"]")
         If J & seg$([M:ALT5]LNKORG(I-1),2,J-1)=ATT(1)
          K = 1
         Else
          J = instr(1,[M:ALT5]LNKDES(I-1),"]")
          If J & seg$([M:ALT5]LNKDES(I-1),2,J-1)=ATT(1) : K = 1 : Endif
         Endif
        When 4 : # Sélection
         If [M:ALT5]FORMU(I-1)<>2
          J = instr(1,[M:ALT5]EXPR(I-1),"]")
          If J & seg$([M:ALT5]EXPR(I-1),2,J-1)=ATT(1) : K = 1 : Endif
         Endif
        When 5 : # Index
         If TABLE<>"" & [M:ALT5]TABLE(I-1)=TABLE : K = 1 : Endif
       Endcase
       If K
        Dela I-1,1 [M:ALT5]NBLIG
        [M:ALT5]NBLIG -= 1
        I -= 1
       Endif
      Wend

     When "AT" : # Ajout d'une table
      Call S_TAB_CHAR(TABLE,PARSEL,"ASELVTAB","SUBAVW","") From GACTION
      If TABLE<>""
       ER = 0
       For I=1 To [M:ALT5]NBLIG
        If [M:ALT5]TYPLIG(I-1)=1 & [M:ALT5]TABLE(I-1)=TABLE
         ER = 3 : Break
        Endif
       Next I
       If ER
        MESSA  = TABLE-":"-mess(250,139,1) : # Cette table a déjà été sélectionnée
        Gosub ADDERR
       Else
        LIG = [M:ALT5]NBLIG
        Gosub CHARGE_TAB
        If !ER
         Call REPFLUX("AT",num$(LIG+1)+"/"+num$([M:ALT5]NBLIG),CLOB)
        Endif
        Break
       Endif
      Endif

     When "CL" : # Création d'un lien
      For NOD="SK","TK","P1","P2"
       Gosub ATTRIBUTS
      Next NOD
      Gosub VERF_LIEN
      If !ER
       Gosub ADDLIG
       If !ER
        [M:ALT5]TYPLIG([M:ALT5]NBLIG-1) = 3 : # Liens
        [M:ALT5]LNKORG([M:ALT5]NBLIG-1) = ATT(1)
        [M:ALT5]LNKDES([M:ALT5]NBLIG-1) = ATT(2)
        [M:ALT5]LNKTYP([M:ALT5]NBLIG-1) = 2 : # Jointure gauche
        [M:ALT5]IDENT([M:ALT5]NBLIG-1)  = val(ATT(3))
        [M:ALT5]VISFLG([M:ALT5]NBLIG-1) = 2
       Endif
      Endif

     When "DL" : # Suppression d'un lien
      For NOD="SK"
       Gosub ATTRIBUTS
      Next NOD
      For I=1 To [M:ALT5]NBLIG
       If [M:ALT5]TYPLIG(I-1)=3 & [M:ALT5]IDENT(I-1)=val(ATT(1))
        Dela I-1,1 [M:ALT5]NBLIG
        [M:ALT5]NBLIG -= 1
        Break
       Endif
      Next I

     When "AF" : # Ajout d'un champ sélectionné
      For NOD="SK","P1","P2"
       Gosub ATTRIBUTS
      Next NOD
      NB = 0
      For I=1 To [M:ALT5]NBLIG
       If [M:ALT5]TYPLIG(I-1)=4
        NB += 1
        If [M:ALT5]EXPR(I-1)=ATT(2)
         ER = 3  : Break
        Endif
       Endif
      Next I
      If ER
       MESSA  = ATT(2)-mess(248,139,1) : # Ce champ a déjà été sélectionné
       Gosub ADDERR
      Elsif NB>=MAXCOL
       ER = 3
       MESSA  = func AFNC.MES(mess(256,139,1),num$(MAXCOL)) : # Trop de champs (maxi #)
       Gosub ADDERR
      Else
       Gosub ADDLIG
       If !ER
        # new field is added as last element
        [M:ALT5]TYPLIG([M:ALT5]NBLIG-1) = 4 : # Champs
        [M:ALT5]EXPR([M:ALT5]NBLIG-1)   = ATT(2)
        [M:ALT5]FORMU([M:ALT5]NBLIG-1)  = 1
        [M:ALT5]BORNE([M:ALT5]NBLIG-1)  = 1
        [M:ALT5]CUMUL([M:ALT5]NBLIG-1)  = 1
        [M:ALT5]TRI([M:ALT5]NBLIG-1)    = 1
        [M:ALT5]VISFLG([M:ALT5]NBLIG-1) = 2
        [M:ALT5]NIV([M:ALT5]NBLIG-1)    = val(ATT(3))
        [M:ALT5]GROUPE([M:ALT5]NBLIG-1) = 1
        [M:ALT5]IDENT([M:ALT5]NBLIG-1)  = val(ATT(1))
        [M:ALT5]MAXNUMTEX += 1
        [M:ALT5]NUMTEX([M:ALT5]NBLIG-1) = [M:ALT5]MAXNUMTEX # Bug 78943
        # for those fields befind the new added field, need to increment its IDENT by 1
        For I=1 To [M:ALT5]NBLIG
         If [M:ALT5]TYPLIG(I-1)=4 & [M:ALT5]IDENT(I-1)>=val(ATT(1)) & [M:ALT5]EXPR(I-1)<>ATT(2)
          [M:ALT5]IDENT(I-1) += 1
         Endif
        Next I
        For I=1 To [M:ALT5]NBLIG
         If [M:ALT5]TYPLIG(I-1)=2 & [M:ALT5]CHAMP(I-1)=ATT(2)
          [M:ALT5]CODTYP([M:ALT5]NBLIG-1) = [M:ALT5]CODTYP(I-1)
          [M:ALT5]LONG([M:ALT5]NBLIG-1)   = [M:ALT5]LONG(I-1)
          [M:ALT5]NOLIB([M:ALT5]NBLIG-1)  = [M:ALT5]NOLIB(I-1)
          [M:ALT5]LIBCHP([M:ALT5]NBLIG-1) = [M:ALT5]LIBCHP(I-1)
          Break
         Endif
        Next I
        Call REPFLUX("AF",num$([M:ALT5]NBLIG),[M:ALT5]CLOB)
        Break
       Endif
      Endif

     When "MF" : # Déplacement d'un champ sélectionné
      For NOD="SK","TK"
       Gosub ATTRIBUTS
      Next NOD
      NB = 0
      For I=1 To [M:ALT5]NBLIG
       If [M:ALT5]TYPLIG(I-1)=4
        NB += 1
        TB(NB) = I
        If [M:ALT5]IDENT(I-1)=val(ATT(1))
         TT(NB) = val(ATT(2))
        Elsif [M:ALT5]IDENT(I-1)=val(ATT(2))
         If val(ATT(2))>val(ATT(1))
          TT(NB) = val(ATT(2))-0.5
         Else
          TT(NB) = val(ATT(2))+0.5
         Endif
        Else
         TT(NB) = [M:ALT5]IDENT(I-1)
        Endif
       Endif
      Next I
      Sorta NB TT,TB Order By TT(indice+1)
      # reset the IDENT with new order
      For I=1 To NB
       [M:ALT5]IDENT(TB(I)-1) = I
      Next I

     When "DF" : # Suppression d'un champ sélectionné
      For NOD="SK"
       Gosub ATTRIBUTS
      Next NOD
      Raz I , K
      While I<[M:ALT5]NBLIG
       I += 1
       If [M:ALT5]TYPLIG(I-1)=4 & [M:ALT5]IDENT(I-1)=val(ATT(1))
        K = [M:ALT5]IDENT(I-1)
        Dela I-1,1 [M:ALT5]NBLIG
        [M:ALT5]NBLIG -= 1
        Break
       Endif
      Wend
      If K
       For I=1 To [M:ALT5]NBLIG
        # for those fields behind the removed field, need to decrement its IDENT by 1
        If [M:ALT5]TYPLIG(I-1)=4 & [M:ALT5]IDENT(I-1)>=K & [M:ALT5]EXPR(I-1)<>ATT(2)
         [M:ALT5]IDENT(I-1) -= 1
        Endif
       Next I
      Endif

     When "LT" : # Modification d'un lien
      For NOD="SK","P1"
       Gosub ATTRIBUTS
      Next NOD
      For I=1 To [M:ALT5]NBLIG
       If [M:ALT5]TYPLIG(I-1)=3 & [M:ALT5]IDENT(I-1)=val(ATT(1))
        Case ATT(2)
         When "I" : [M:ALT5]LNKTYP(I-1) = 1
         When "L" : [M:ALT5]LNKTYP(I-1) = 2
         When "R" : [M:ALT5]LNKTYP(I-1) = 3
        Endcase
       Endif
      Next I

     When "CF" : # Changement de propriétés (tri, borne, cumul, niveau) d'un champ sélectionné
      For NOD="SK","P1","P2"
       Gosub ATTRIBUTS
      Next NOD
      K = 0
      For I=1 To [M:ALT5]NBLIG
       If [M:ALT5]TYPLIG(I-1)=4 & [M:ALT5]IDENT(I-1)=val(ATT(1))
        Case ATT(2)
         When "Visible" : K = I : [M:ALT5]VISFLG(I-1) = find(ATT(3),"N","Y")
         When "Bounds"  : K = 0 : [M:ALT5]BORNE(I-1)  = find(ATT(3),"N","Y")
         When "Sort"    : K = I : [M:ALT5]TRI(I-1)    = find(ATT(3),"A","D")+1
         When "Sum"     : K = 0 : [M:ALT5]CUMUL(I-1)  = find(ATT(3),"N","Y")
         When "Level"   : K = 0 : [M:ALT5]NIV(I-1)    = val(ATT(3))
        Endcase
        Break
       Endif
      Next I
      If K
       Call REPFLUX("CF",num$(K),CLOB)
       Break
      Endif

     When "LF" : # Modification du niveau d'un champ sélectionné
      For NOD="SK","P1"
       Gosub ATTRIBUTS
      Next NOD
      K = 0
      For I=1 To [M:ALT5]NBLIG
       If [M:ALT5]TYPLIG(I-1)=4 & [M:ALT5]IDENT(I-1)=val(ATT(1))
        [M:ALT5]NIV(I-1) = val(ATT(2))
        Break
       Endif
      Next I

     When "EE" : # Ajout d'une expression
      For NOD="SK"
       Gosub ATTRIBUTS
      Next NOD
      Raz J , PARSEL , NIVMAX
      For I=1 To [M:ALT5]NBLIG
       If [M:ALT5]TYPLIG(I-1)=1 & J<5
        J += 1
        PARSEL(J) = "[F:"+[M:ALT5]ABREV(I-1)+"]"+[M:ALT5]TABLE(I-1)
       Endif
       If [M:ALT5]TYPLIG(I-1)=4
        NIVMAX = max(NIVMAX,[M:ALT5]NIV(I-1))
       Endif
      Next I
      CHAINE = ""
      Call B1_FORMULE(CHAINE,PARSEL(1),PARSEL(2),PARSEL(3),PARSEL(4),PARSEL(5)) From AFORMULE
      If GSTATUT<>7
       Gosub VERF_FRM
       If !OK
        ER = 3
        Gosub ADDERR
       Else
        Gosub ADDLIG
        If !ER
         [M:ALT5]TYPLIG([M:ALT5]NBLIG-1) = 4 : # Champs
         [M:ALT5]EXPR([M:ALT5]NBLIG-1)   = CHAINE
         [M:ALT5]FORMU([M:ALT5]NBLIG-1)  = 2
         [M:ALT5]BORNE([M:ALT5]NBLIG-1)  = 1
         [M:ALT5]CUMUL([M:ALT5]NBLIG-1)  = 1
         [M:ALT5]TRI([M:ALT5]NBLIG-1)    = 1
         [M:ALT5]VISFLG([M:ALT5]NBLIG-1) = 2
         [M:ALT5]NIV([M:ALT5]NBLIG-1)    = NIVMAX
         [M:ALT5]GROUPE([M:ALT5]NBLIG-1) = 1
         [M:ALT5]IDENT([M:ALT5]NBLIG-1)  = val(ATT(1))+1
         [M:ALT5]CODTYP([M:ALT5]NBLIG-1) = "A"
         [M:ALT5]LONG([M:ALT5]NBLIG-1)   = 20
         [M:ALT5]NOLIB([M:ALT5]NBLIG-1)  = 0
         [M:ALT5]LIBCHP([M:ALT5]NBLIG-1) = mess(2,89,1) : # Expression
         [M:ALT5]MAXNUMTEX += 1
         [M:ALT5]NUMTEX([M:ALT5]NBLIG-1) = [M:ALT5]MAXNUMTEX # Bug 78943
         Call REPFLUX("EE",num$([M:ALT5]NBLIG),CLOB)
        Endif
       Endif
       Break
      Endif

     When "ME" : # Modification d'une expression
      For NOD="SK"
       Gosub ATTRIBUTS
      Next NOD
      Raz PARSEL
      Raz J , NB , EX
      For I=1 To [M:ALT5]NBLIG
       If [M:ALT5]TYPLIG(I-1)=1 & J<5
        J += 1
        PARSEL(J) = "[F:"+[M:ALT5]ABREV(I-1)+"]"+[M:ALT5]TABLE(I-1)
       Endif
       If [M:ALT5]TYPLIG(I-1)=4 & [M:ALT5]IDENT(I-1)=val(ATT(1))
        If [M:ALT5]FORMU(I-1) = 2
         EX = 1
        Endif
        NB = I
       Endif
      Next I
      If NB
       CHAINE     = [M:ALT5]EXPR(NB-1)
       PARSEL(6)  = [M:ALT5]LIBCHP(NB-1)
       PARSEL(7)  = [M:ALT5]CODTYP(NB-1)
       PARSEL(8)  = num$([M:ALT5]NOLIB(NB-1))
       PARSEL(9)  = num$([M:ALT5]LONG(NB-1))
       PARSEL(10) = [M]COD
       PARSEL(11) = num$([M:ALT5]IDENT(NB-1))
       PARSEL(12) = num$(EX)
       PARSEL(13) = num$([M:ALT5]BORNE(NB-1))
       PARSEL(14) = [M:ALT5]VALDEB(NB-1)
       PARSEL(15) = [M:ALT5]VALFIN(NB-1)
       PARSEL(16) = num$([M:ALT5]NUMTEX(NB-1)) # Bug 78943
       Call SAISIE_CHAR(CHAINE,PARSEL,"ALT9","SUBALT9","") From GSAISIE
       If GSTATUT<>7
        Gosub VERF_FRM
        If !OK
         ER = 3
         Gosub ADDERR
        Else
         [M:ALT5]EXPR(NB-1)   = CHAINE
         [M:ALT5]LIBCHP(NB-1) = PARSEL(6)
         [M:ALT5]CODTYP(NB-1) = PARSEL(7)
         [M:ALT5]NOLIB(NB-1)  = val(PARSEL(8))
         [M:ALT5]LONG(NB-1)   = val(PARSEL(9))
         [M:ALT5]VALDEB(NB-1) = PARSEL(14)
         [M:ALT5]VALFIN(NB-1) = PARSEL(15)
         [M:ALT5]NUMTEX(NB-1) = val(PARSEL(16)) # Bug 78943
         Call REPFLUX("ME",num$(NB),CLOB)
        Endif
        Break
       Endif
      Endif

     When "FC" : # Appel d'une fonction
      For NOD="P1"
       Gosub ATTRIBUTS
      Next NOD
      Case ATT(1)
       When Default
        ER = 3
        MESSA  = ATT(1)-mess(4,9014,1) : # Fonction inconnue
        Gosub ADDERR
      Endcase

     When "SC" : # Sauvegarde de la configuration
      For NOD="P1"
       Gosub ATTRIBUTS
      Next NOD
      If left$(ATT(1),4)="Clob"
       [M:ALT5]CLBCNF = ATB(val(right$(ATT(1),5)))
      Else
       [M:ALT5]CLBCNF = ATT(1)
      Endif

     When "CQ" : # Effacement du clob
      Raz [M:ALT5]
      Effzo [M:ALT5]

     When Default
      ER = 3
      MESSA  = INTACT-mess(5,137,1) : # Action inconnue
      Gosub ADDERR

    Endcase
   Endif
  Wend
 Endif
Wend

OK = 1
For I=1 To NBE
 If GRAV(I)>=3
  OK = 0
  Break
 Endif
Next I
[M:ALT5]CLOB = [L]CLOB : # Pour vérifier ce qu'on a envoyé
#mkstat = 4

Onerrgo
End

#--------------#
$ERT
MESSA = errm-errmes$(errn)+"\"+errp+"("+num$(errl)+")"
Call ECR_TRACE(MESSA,0) From GESECRAN
End

#--------------#
$ADDERR
NBE += 1
MES(NBE)  = func AFNC.TRANSF(MESSA,"\",'&#10;')
GRAV(NBE) = ER
Return

#--------------#
$ADDLIG
If [M:ALT5]NBLIG<dim([M:ALT5]TABLE)
 [M:ALT5]NBLIG += 1
Else
 ER = 3
 MESSA = mess(161,115,1)-"(>"+num$(dim([M:ALT5]TABLE))+")" : # Trop de lignes
 Gosub ADDERR
Endif
Return

#--------------#
$ATTRIBUTS
NBA += 1
K = instr(ATD,CLOB,"<"+NOD+">")
L = instr(K,CLOB,"</"+NOD+">")
If K & L
 K += len(NOD)+2
 L -= 1
 If L-K>type(ATT)-10
  NBB += 1
  ATB(NBB) = seg$(CLOB,K,L)
  ATT(NBA) = "Clob"+num$(NBB)
 Else
  ATT(NBA) = seg$(CLOB,K,L)
 Endif
Endif
Return

#--------------#
$VERF_LIEN
I = instr(1,ATT(1),"]")
If I
 ABRORG = seg$(ATT(1),2,I-1)
 Read [AVWT]ABRFIC = ABRORG
 TABORG = [F:AVWT]CODFIC
 ZONORG = right$(ATT(1),I+1)
 J = instr(1,ZONORG,"(")
 If J
  DIMORG = val(right$(ZONORG,J+1))
  ZONORG = left$(ZONORG,J-1)
 Endif
Endif
I = instr(1,ATT(2),"]")
If I
 ABRDES = seg$(ATT(2),2,I-1)
 Read [AVWT]ABRFIC = ABRDES
 TABDES = [F:AVWT]CODFIC
 ZONDES = right$(ATT(2),I+1)
 J = instr(1,ZONDES,"(")
 If J
  DIMDES = val(right$(ZONDES,J+1))
  ZONDES = left$(ZONDES,J-1)
 Endif
Endif
If ZONDES="" or ZONORG=""
 ER = 3
 # Lien impossible/Erreur de syntaxe
 MESSA  = ATT(1)-"->"-ATT(2)-mess(45,105,1)+"\"+mess(134,141,1)
 Gosub ADDERR
 Return
Endif
Read [AVWF]CODZONE=TABORG;ZONORG
Read [ATY]CODTYP=[F:AVWF]CODTYP
I = [F:ATY]TYPTYP
Read [AVWF]CODZONE=TABDES;ZONDES
Read [ATY]CODTYP=[F:AVWF]CODTYP
J = [F:ATY]TYPTYP
K = 0
If I<=6 & J<=6 : # Numérique
 K = 1
Elsif I=J : # Alpha ou date
 K = 1
Endif
If !K
 ER = 3
 # Lien impossible/Les zones doivent être de même type
 MESSA  = ATT(1)-"->"-ATT(2)-mess(45,105,1)+"\"+mess(195,117,1)
 Gosub ADDERR
 Return
Endif
# Le champ a-t-il déjà été utilisé par les autres liens définis sur cette table
DOUB = 0
For I=1 To [M:ALT5]NBLIG
 J = ([M:ALT5]TYPLIG(I-1)=3)
 J *= (left$([M:ALT5]LNKDES(I-1),len(ABRDES)+2)="["+ABRDES+"]")
 If J
  J = instr(1,[M:ALT5]LNKDES(I-1),"]")
  If J
   K = instr(J,[M:ALT5]LNKDES(I-1),"(")
   If K=0 : K = len([M:ALT5]LNKDES(I-1))+1 : Endif
   FLD = seg$([M:ALT5]LNKDES(I-1),J+1,K-1)
   If FLD=ZONDES
    DOUB = 1 : Break
   Endif
  Endif
 Endif
Next I
If DOUB
 ER = 3
 # Lien impossible/Composante de Clé déjà saisie
 MESSA  = ATT(1)-"->"-ATT(2)-mess(45,105,1)+"\"+mess(249,139,1)
 Gosub ADDERR
Else
 # Recherche de la clé de lecture d'après les liens déjà définis sur la table
 Raz OKIND , PART
 For [AVWI] Where CODFIC=TABDES
  CHAINE = [F:AVWI]DESCRIPT
  Gosub SETCLE
  If find(ZONDES,CLE)
   OKIND = 1
   For I=1 To [M:ALT5]NBLIG
    J = ([M:ALT5]TYPLIG(I-1)=3)
    J *= (left$([M:ALT5]LNKDES(I-1),len(ABRDES)+2)="["+ABRDES+"]")
    If J
     J = instr(1,[M:ALT5]LNKDES(I-1),"]")
     If J
      PART += 1
      OKIND = 0
      K = instr(J,[M:ALT5]LNKDES(I-1),"(")
      If K=0 : K = len([M:ALT5]LNKDES(I-1))+1 : Endif
      FLD = seg$([M:ALT5]LNKDES(I-1),J+1,K-1)
      If find(FLD,CLE)
       OKIND = 1 : Break
      Endif
     Endif
    Endif
   Next I
   If OKIND : Break : Endif
  Endif
 Next ATI
 If !OKIND
  If PART=1
   ER = 3
   # Lien impossible - Clé existante incomplète
   MESSA  = ATT(1)-"->"-ATT(2)-mess(45,105,1)+"\"+mess(247,139,1)
  Else
   ER = 3
   # Lien impossible - Clé inexistante
   MESSA  = ATT(1)-"->"-ATT(2)-mess(45,105,1)+"\"+mess(6,114,1)
  Endif
  Gosub ADDERR
 Endif
Endif
Return

#--------------#
$SETCLE
Local Char    CLE(GLONAVA)(1..16)
Local Integer AI , AJ , NBCLE
Raz CLE, NBCLE
While CHAINE<>""
 AI = instr(1,CHAINE,"+")
 AJ = instr(1,CHAINE,"-")
 If AI & AJ
  AI = min(AI,AJ)
 Elsif AJ & !AI
  AI = AJ
 Endif
 NBCLE += 1
 If AI
  CLE(NBCLE) = left$(CHAINE,AI-1)
  CHAINE = right$(CHAINE,AI+1)
 Else
  CLE(NBCLE) = CHAINE
  CHAINE = ""
 Endif
Wend
Return

#--------------#
$SETLNK
Local Char    LNK(20)(1..16)
Local Integer AK , NBLNK
Raz LNK , NBLNK
CHAINE = format$("KTv2:200X",[F:AVWF]EXPLIEN)
If CHAINE=""
 CHAINE = [F:AVWF]CODZONE
Endif
While CHAINE<>""
 NBLNK += 1
 AK = instr(1,CHAINE,";")
 If AK
  LNK(NBLNK) = left$(CHAINE,AK-1)
  CHAINE = right$(CHAINE,AK+1)
 Else
  LNK(NBLNK) = CHAINE
  CHAINE = ""
 Endif
 If left$(LNK(NBLNK),1)<"A" or left$(LNK(NBLNK),1)>"Z"
  LNK(NBLNK) = ""
 Else
  AK = instr(1,LNK(NBLNK),"(indice)")
  If AK
   LNK(NBLNK) = left$(LNK(NBLNK),AK-1)+right$(LNK(NBLNK),AK+8)
  Endif
 Endif
Wend
Return

#--------------#
$CHARGE_TAB
# Insertion de la nouvelle table
Read [AVWT]CODFIC = TABLE
Gosub ADDLIG
If ER : Goto SUP_TAB : Endif
[M:ALT5]TYPLIG([M:ALT5]NBLIG-1) = 1 : # Tables
[M:ALT5]TABLE([M:ALT5]NBLIG-1)  = TABLE
[M:ALT5]X([M:ALT5]NBLIG-1)      = 7
[M:ALT5]Y([M:ALT5]NBLIG-1)      = 154
[M:ALT5]LARGE([M:ALT5]NBLIG-1)  = 141
[M:ALT5]HAUT([M:ALT5]NBLIG-1)   = 135
[M:ALT5]ABREV([M:ALT5]NBLIG-1)  = [F:AVWT]ABRFIC
[M:ALT5]VISFLG([M:ALT5]NBLIG-1) = 2
Call TEXTE([F:AVWT]INTITFIC,[M:ALT5]LIBTAB([M:ALT5]NBLIG-1)) From OBJDIV

# Insertion des champs
For [AVWF]NUMLIG Where CODFIC=TABLE
 Read [ATY]CODTYP=[F:AVWF]CODTYP
 If find([F:ATY]TYPTYP,9,10) : # Clob/Blob
  R = 0
 Else
  R = [F:AVWF]DIME
  If [F:AVWF]CODACT<>""
   Read [ACV]CODACT = [F:AVWF]CODACT
   If !fstat & ([F:ACV]DIMFIL<>0 | [F:ACV]DIME<>0)
    R = max([F:ACV]DIMFIL,[F:ACV]DIME)
   Endif
   R = max(R,1)
  Endif
 Endif
 OINDICE = indice
 For D=0 To R-1
  Gosub ADDLIG
  If ER : Break 2 : Endif
  indice = D
  [M:ALT5]TYPLIG([M:ALT5]NBLIG-1) = 2 : # Champs des tables
  [M:ALT5]CHAMP([M:ALT5]NBLIG-1)  = "["+[F:AVWT]ABRFIC+"]"+[F:AVWF]CODZONE
  If D>0
   [M:ALT5]CHAMP([M:ALT5]NBLIG-1) += "("+num$(D)+")"
  Endif
  Call TEXTE([F:AVWF]NOCOURT,[M:ALT5]LIBCHP([M:ALT5]NBLIG-1)) From OBJDIV
  [M:ALT5]VISFLG([M:ALT5]NBLIG-1) = 2
  [M:ALT5]CODTYP([M:ALT5]NBLIG-1) = [F:AVWF]CODTYP
  If [F:AVWF]LONG<>0
   [M:ALT5]LONG([M:ALT5]NBLIG-1)  = [F:AVWF]LONG
  Else
   Read [ATY]CODTYP=[F:AVWF]CODTYP
   If [F:ATY]LNGTYP<>0
    #[M:ALT5]LONG([M:ALT5]NBLIG-1) = [F:ATY]LNGTYP : # CCL
   Endif
  Endif
  If [F:AVWF]CODTYP="ADI"
   Read [AMP]CODPAR=2;[F:AVWF]CODFIC;[F:AVWF]CODZONE;"ADI"
   ERF = 0
   Onerrgo ERF
   [M:ALT5]NOLIB([M:ALT5]NBLIG-1) = val(num$(evalue([F:AMP]VALPAR)))
   If ERF
    [M:ALT5]NOLIB([M:ALT5]NBLIG-1) = val([F:AMP]VALPAR)
   Endif
   Onerrgo ERT
  Else
   [M:ALT5]NOLIB([M:ALT5]NBLIG-1) = [F:AVWF]NOLIB
  Endif
 Next D
 indice = OINDICE
Next ATZ
If ER : Goto SUP_TAB : Endif
# Insertion des index
For [AVWI]NUMLIG Where CODFIC=TABLE
 Gosub ADDLIG
 If ER : Break : Endif
 [M:ALT5]TYPLIG([M:ALT5]NBLIG-1) = 5 : # Index
 [M:ALT5]TABLE([M:ALT5]NBLIG-1)  = [F:AVWI]CODFIC
 [M:ALT5]ABREV([M:ALT5]NBLIG-1)  = [F:AVWI]CODIND
 [M:ALT5]IDENT([M:ALT5]NBLIG-1)  = [F:AVWI]NUMLIG
 [M:ALT5]EXPR([M:ALT5]NBLIG-1)   = ctrans([F:AVWI]DESCRIPT,"+-",";;")
Next ATI
If ER : Goto SUP_TAB : Endif
# Recherche d'un lien possible vers la nouvelle table
NUMERO = 0
For I=1 To [M:ALT5]NBLIG
 If [M:ALT5]TYPLIG(I-1)=3 & [M:ALT5]IDENT(I-1)>NUMERO
  NUMERO = [M:ALT5]IDENT(I-1)
 Endif
Next I
L = 0
For I=1 To [M:ALT5]NBLIG
 If [M:ALT5]TYPLIG(I-1)=1 and [M:ALT5]TABLE(I-1)<>TABLE
  For [AVWF]LIEN Where CODFIC=[M:ALT5]TABLE(I-1) & LIEN=TABLE
   Read [AVWI]NUMLIG(2)=TABLE;1
   CHAINE = [F:AVWI]DESCRIPT
   Gosub SETCLE
   Gosub SETLNK
   # Ce champ est-il déjà lié ?
   K = 1
   Read [AVWT]CODFIC=TABLE
   For J=1 To NBCLE
    If LNK(J)<>""
     For M=1 To [M:ALT5]NBLIG
      If [M:ALT5]TYPLIG(M-1)=3 & [M:ALT5]LNKDES(M-1)="["+[F:AVWT]ABRFIC+"]"+CLE(J)
       K = 0 : Break 2
      Endif
     Next M
    Endif
   Next J
   If K
    For J=1 To NBCLE
     If LNK(J)<>""
      Gosub ADDLIG
      If ER : Break 3 : Endif
      NUMERO += 1
      Read [AVWT]CODFIC=[F:AVWF]CODFIC
      [M:ALT5]LNKORG([M:ALT5]NBLIG-1) = "["+[F:AVWT]ABRFIC+"]"+LNK(J)
      Read [AVWT]CODFIC=TABLE
      [M:ALT5]LNKDES([M:ALT5]NBLIG-1) = "["+[F:AVWT]ABRFIC+"]"+CLE(J)
      [M:ALT5]TYPLIG([M:ALT5]NBLIG-1) = 3 : # Liens
      [M:ALT5]LNKTYP([M:ALT5]NBLIG-1) = 2 : # Gauche
      [M:ALT5]IDENT([M:ALT5]NBLIG-1)  = NUMERO
      [M:ALT5]VISFLG([M:ALT5]NBLIG-1) = 2
     Endif
    Next J
    L = 1
    Break 2
   Endif
  Next ATZ
 Endif
Next I
If ER : Goto SUP_TAB : Endif
# Si pas de lien vers la nouvelle table, alors on cherche un lien depuis cette table
If !L
 For I=1 To [M:ALT5]NBLIG
  If [M:ALT5]TYPLIG(I-1)=1 and [M:ALT5]TABLE(I-1)<>TABLE
   For [AVWF]LIEN Where CODFIC=TABLE & LIEN=[M:ALT5]TABLE(I-1)
    Read [AVWI]NUMLIG(2)=[M:ALT5]TABLE(I-1);1
    CHAINE = [F:AVWI]DESCRIPT
    Gosub SETCLE
    Gosub SETLNK
    # Ce champ est-il déjà lié ?
    K = 1
    Read [AVWT]CODFIC=[M:ALT5]TABLE(I-1)
    For J=1 To NBCLE
     If LNK(J)<>""
      For M=1 To [M:ALT5]NBLIG
       If [M:ALT5]TYPLIG(M-1)=3 & [M:ALT5]LNKDES(M-1)="["+[F:AVWT]ABRFIC+"]"+CLE(J)
        K = 0 : Break 2
       Endif
      Next M
     Endif
    Next J
    If K
     For J=1 To NBCLE
      If LNK(J)<>""
       Gosub ADDLIG
       If ER : Break 3 : Endif
       NUMERO += 1
       Read [AVWT]CODFIC=[F:AVWF]CODFIC
       [M:ALT5]LNKORG([M:ALT5]NBLIG-1) = "["+[F:AVWT]ABRFIC+"]"+LNK(J)
       Read [AVWT]CODFIC=[M:ALT5]TABLE(I-1)
       [M:ALT5]LNKDES([M:ALT5]NBLIG-1) = "["+[F:AVWT]ABRFIC+"]"+CLE(J)
       [M:ALT5]TYPLIG([M:ALT5]NBLIG-1) = 3 : # Liens
       [M:ALT5]LNKTYP([M:ALT5]NBLIG-1) = 2 : # Gauche
       [M:ALT5]IDENT([M:ALT5]NBLIG-1)  = NUMERO
       [M:ALT5]VISFLG([M:ALT5]NBLIG-1) = 2
      Endif
     Next J
     Break 2
    Endif
   Next ATZ
  Endif
 Next I
Endif
If ER : Goto SUP_TAB : Endif
Return

#--------------#
$SUP_TAB
I = 0
Read [AVWT]CODFIC = TABLE
While I<[M:ALT5]NBLIG
 I += 1
 K = 0
 Case [M:ALT5]TYPLIG(I-1)
  When 1 : # Table
   If [M:ALT5]ABREV(I-1)=[F:AVWT]ABRFIC : K = 1 : Endif
  When 2 : # Champs
   J = instr(1,[M:ALT5]CHAMP(I-1),"]")
   If J & seg$([M:ALT5]CHAMP(I-1),2,J-1)=[F:AVWT]ABRFIC : K = 1 : Endif
  When 3 : # Liens
   J = instr(1,[M:ALT5]LNKORG(I-1),"]")
   If J & seg$([M:ALT5]LNKORG(I-1),2,J-1)=[F:AVWT]ABRFIC
    K = 1
   Else
    J = instr(1,[M:ALT5]LNKDES(I-1),"]")
    If J & seg$([M:ALT5]LNKDES(I-1),2,J-1)=[F:AVWT]ABRFIC : K = 1 : Endif
   Endif
  When 4 : # Sélection
   If [M:ALT5]FORMU(I-1)<>2
    J = instr(1,[M:ALT5]EXPR(I-1),"]")
    If J & seg$([M:ALT5]EXPR(I-1),2,J-1)=[F:AVWT]ABRFIC : K = 1 : Endif
   Endif
  When 5 : # Index
   If [M:ALT5]TABLE(I-1) = TABLE : K = 1 : Endif
 Endcase
 If K
  Dela I-1,1 [M:ALT5]NBLIG
  [M:ALT5]NBLIG -= 1
  I -= 1
 Endif
Wend
Return

#-----------------------------------------------------------------------------------#
# Flux de données réponse XML au requêteur flash
#-----------------------------------------------------------------------------------#

Subprog REPFLUX(INTACT,MES,CLOBF)
Value    Char    INTACT
Value    Char    MES()
Variable Clbfile CLOBF
Local Char    CARF(1)
Local Char    TYPCOU(30) , SAVTYP(30)
Local Integer X , Y , K , I , J
CARF = chr$(10)
Raz CLOBF
CLOBF  = '<X3PORTAL>'+CARF
Append CLOBF,'<Data>'+CARF
Append CLOBF,'<Result>'+CARF
Case INTACT
 When "AT" : # Ajout table
  K = instr(1,MES,"/")
  X = val(left$(MES,K-1))
  Y = val(right$(MES,K+1))
  For I=X To Y
   If [M:ALT5]TYPLIG(I-1)=1
    Gosub ADDTAB
   Endif
  Next I
  For I=X To Y
   If [M:ALT5]TYPLIG(I-1)=3
    Gosub ADDLINK
   Endif
  Next I
 When "EE","ME" : # Ajout/Modif Expression
  I = val(MES)
  If I>0
   Gosub ADDSEL
  Endif
 When "AF","CF" : # Ajout/Modif Champ
  I = val(MES)
  If I>0
   Gosub GRANT
  Endif
Endcase
If SAVTYP<>""
 Append CLOBF,'</'+SAVTYP+'>'+CARF
Endif
Append CLOBF,'</Result>'+CARF
Append CLOBF,'</Data>'+CARF
Append CLOBF,'</X3PORTAL>'
End

#-----------------------------------------------------------------------------------#
# Création du flux de données initial XML du requêteur flash
#-----------------------------------------------------------------------------------#

Subprog CREFLUX(CLOBF)
Variable Clbfile CLOBF
Local    Integer I , J , K , X , Y
Local    Char    TYPCOU(30) , SAVTYP(30)
Local    Char    CARF(1)
CARF = chr$(10)
X = 1
Y = [M:ALT5]NBLIG
Raz CLOBF
CLOBF  = '<X3PORTAL>'+CARF
Append CLOBF,'<Data>'+CARF
Append CLOBF,'<Lines>'+CARF
Append CLOBF,'<Config>'+[M:ALT5]CLBCNF+'</Config>'+CARF
For I=X To Y
 Case [M:ALT5]TYPLIG(I-1)
  When 1 : Gosub ADDTAB
  When 3 : Gosub ADDLINK
  When 4 : Gosub ADDSELECT
 Endcase
Next I
If SAVTYP<>""
 Append CLOBF,'</'+SAVTYP+'>'+CARF
Endif
Append CLOBF,'</Lines>'+CARF
Append CLOBF,'</Data>'+CARF
Append CLOBF,'<Technical>'+CARF
Append CLOBF,'<VisCmp Type="FQD"/>'+CARF
Append CLOBF,'<UserLang>'+GLANGUE+'</UserLang>'+CARF
Append CLOBF,'</Technical>'+CARF
Append CLOBF,'<Messages/>'+CARF
Append CLOBF,'</X3PORTAL>'
End

#--------------#
$ADDTAB
TYPCOU = "Tables"
If TYPCOU<>SAVTYP
 If SAVTYP<>""
  Append CLOBF,'</'+SAVTYP+'>'+CARF
 Endif
 SAVTYP = TYPCOU
 Append CLOBF,'<'+TYPCOU+'>'+CARF
Endif
Append CLOBF,'<Table '
Append CLOBF,' Id="'+[M:ALT5]ABREV(I-1)+'" '
Append CLOBF,' Name="'+[M:ALT5]TABLE(I-1)+'" '
Append CLOBF,' Lbl="'+func CARSPEXML([M:ALT5]LIBTAB(I-1))+'" '
Append CLOBF,' Vis="'+func YESNO([M:ALT5]VISFLG(I-1))+'" '
Append CLOBF,' X="'+num$([M:ALT5]X(I-1))+'" '
Append CLOBF,' Y="'+num$([M:ALT5]Y(I-1))+'" '
Append CLOBF,' W="'+num$([M:ALT5]LARGE(I-1))+'" '
Append CLOBF,' H="'+num$([M:ALT5]HAUT(I-1))+'"'
Append CLOBF,' >'+CARF
Append CLOBF,'<Fields> '+CARF
For J=X To Y
 If [M:ALT5]TYPLIG(J-1)=2
  K = instr(1,[M:ALT5]CHAMP(J-1),"]")
  If seg$([M:ALT5]CHAMP(J-1),2,K-1)=[M:ALT5]ABREV(I-1)
   Append CLOBF,'<Field '
   Append CLOBF,' Id="'+right$([M:ALT5]CHAMP(J-1),K+1)+'" '
   Append CLOBF,' Vis="'+func YESNO([M:ALT5]VISFLG(J-1))+'" '
   Append CLOBF,' Lbl="'+func CARSPEXML([M:ALT5]LIBCHP(J-1))+'"'
   Append CLOBF,' />'+CARF
  Endif
 Endif
Next J
Append CLOBF,'</Fields> '+CARF
Append CLOBF,'<Indexes> '+CARF
For J=X To Y
 If [M:ALT5]TYPLIG(J-1)=5 & [M:ALT5]TABLE(J-1)=[M:ALT5]TABLE(I-1)
  Append CLOBF,'<Field '
  Append CLOBF,' Id="'+[M:ALT5]ABREV(J-1)+'" '
  Append CLOBF,' Def="'+[M:ALT5]EXPR(J-1)+'" '
  Append CLOBF,' />'+CARF
 Endif
Next J
Append CLOBF,'</Indexes> '+CARF
Append CLOBF,'</Table> '+CARF
Return

#--------------#
$ADDLINK
TYPCOU = "Links"
If TYPCOU<>SAVTYP
 If SAVTYP<>""
  Append CLOBF,'</'+SAVTYP+'>'+CARF
 Endif
 SAVTYP = TYPCOU
 Append CLOBF,'<'+TYPCOU+'>'+CARF
Endif
Append CLOBF,'<Link '
Append CLOBF,' Id="'+num$([M:ALT5]IDENT(I-1))+'" '
Append CLOBF,' Sid="'+func ZERO([M:ALT5]LNKORG(I-1))+'" '
Append CLOBF,' Tid="'+func ZERO([M:ALT5]LNKDES(I-1))+'" '
Append CLOBF,' Vis="'+func YESNO([M:ALT5]VISFLG(I-1))+'" '
Append CLOBF,' Join="'+func JOIN([M:ALT5]LNKTYP(I-1))+'"'
Append CLOBF,' />'+CARF
Return

#--------------#
$ADDSELECT
TYPCOU = "DroppedFields"

#--------------#
$ADDSEL
If TYPCOU<>"" & TYPCOU<>SAVTYP
 If SAVTYP<>""
  Append CLOBF,'</'+SAVTYP+'>'+CARF
 Endif
 SAVTYP = TYPCOU
 Append CLOBF,'<'+TYPCOU+'>'+CARF
Endif
# Champs sélectionnés
Append CLOBF,'<DroppedField '
Append CLOBF,' Expr="'+string$([M:ALT5]FORMU(I-1)=2,"=")+func CARSPEXML([M:ALT5]EXPR(I-1))+'" '
Append CLOBF,' Lbl="'+func CARSPEXML([M:ALT5]LIBCHP(I-1))+'" '
Append CLOBF,' Vis="'+func YESNO([M:ALT5]VISFLG(I-1))+'" '
Append CLOBF,' Bounds="'+func YESNO([M:ALT5]BORNE(I-1))+'" '
Append CLOBF,' Sum="'+func YESNO([M:ALT5]CUMUL(I-1))+'" '
Append CLOBF,' Sort="'+func TRI([M:ALT5]TRI(I-1))+'" '
Append CLOBF,' Level="'+num$([M:ALT5]NIV(I-1))+'"'
Append CLOBF,' >'+CARF
Gosub GRANT
Append CLOBF,'</DroppedField>'+CARF
Return

#--------------#
$GRANT
Local Integer SRT , BOR , SOM , NIV
Local Char    CHAINE(250)
SRT = 2
BOR = 2
SOM = 2
NIV = 2
If [M:ALT5]VISFLG(I-1)=1
 SRT = 1
 SOM = 1
 NIV = 1
Endif
If [M:ALT5]FORMU(I-1)=2
 SRT = 1
 BOR = 1
Endif
Read [ATY]CODTYP=[M:ALT5]CODTYP(I-1)
If !find([F:ATY]TYPTYP,2,3,4,5,6) or [M:ALT5]CODTYP(I-1)="ATX"
 SOM = 1
Endif
If find([M:ALT5]CODTYP(I-1),"AXX","AX1","AX2","AX3")
 K = instr(1,[M:ALT5]EXPR(I-1),"]")
 If K
  Read [AVWT]ABRFIC=seg$([M:ALT5]EXPR(I-1),2,K-1)
  Read [AVWI]NUMLIG(2) = [F:AVWT]CODFIC;1
  CHAINE = [F:AVWI]DESCRIPT
  Gosub SETCLE
  For K=1 To NBCLE
   Read [AVWF]CODZONE = [F:AVWT]CODFIC;CLE(K)
   Read [ATY]CODTYP = [F:AVWF]CODTYP
   If [F:ATY]TYPTYP<>7
    K = 0 : Break
   Endif
  Next K
  # Si une partie de clé est non alpha ou si le nb de parties de clé > 2, le lien ATEXTRA est impossible
  If !K or NBCLE>2
   SRT = 1
  Endif
 Endif
Endif
# Propriétés des champs sélectionnés
Append CLOBF,'<Grants>'+CARF
Append CLOBF,' <Grant Prop="Sort" Val="'+func YESNO(SRT)+'" />'+CARF
Append CLOBF,' <Grant Prop="Bounds" Val="'+func YESNO(BOR)+'" />'+CARF
Append CLOBF,' <Grant Prop="Sum" Val="'+func YESNO(SOM)+'" />'+CARF
Append CLOBF,' <Grant Prop="Level" Val="'+func YESNO(NIV)+'" />'+CARF
Append CLOBF,'</Grants>'+CARF
Return

#------------------#
Funprog YESNO(COD)
Value Integer COD
Case COD
 When 2       : End 'Y'
 When Default : End 'N'
Endcase
End

#------------------#
Funprog TRI(COD)
Value Integer COD
Case COD
 When 2       : End 'A' : # Ascendant
 When 3       : End 'D' : # Descendant
 When Default : End 'N' : # Aucun
Endcase
End

#------------------#
Funprog JOIN(COD)
Value Integer COD
Case COD
 When 1       : End 'I' : # Interne
 When Default : End 'L' : # Externe gauche
Endcase
End

#--------------------------------#
Funprog CARSPEXML(CHAINE)
Value Char CHAINE
Local Char CHAINE2(255)
CHAINE2 = CHAINE
Call MODVAL(CHAINE2) From INTRUTILA : # Transformation des caractères <>"& pour le script XML
End CHAINE2

#--------------------------------#
Funprog ZERO(CHAINE)
Value Char CHAINE
Local Char CHAINE2(255)
Local Integer I
CHAINE2 = CHAINE
I = instr(1,CHAINE2,"(0)")
While I
 CHAINE2 = left$(CHAINE2,I-1)+right$(CHAINE2,I+3)
 I = instr(1,CHAINE2,"(0)")
Wend
End CHAINE2

#-------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File ALISTEL  [ALL1]
 Local File ALISTEC  [ALC1]
 Local File ALISTET  [ALT1]
 Local File ALISTEH  [ALH1]
 Local File ALISTED  [ALD1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".ALISTEL" [ALL1]
 Local File =[M]DOSORG+".ALISTEC" [ALC1]
 Local File =[M]DOSORG+".ALISTET" [ALT1]
 Local File =[M]DOSORG+".ALISTEH" [ALH1]
 Local File =[M]DOSORG+".ALISTED" [ALD1]
 Local File =[M]DOSORG+".ATEXTRA" [AXX1]
Endif
If [M]DOSDES=nomap
 Local File ALISTEL [ALL2]
 Local File ALISTEC [ALC2]
 Local File ALISTET [ALT2]
 Local File ALISTEH [ALH2]
 Local File ALISTED [ALD2]
 Local File ATEXTRA [AXX2]
Else
 Local File =[M]DOSDES+".ALISTEL" [ALL2]
 Local File =[M]DOSDES+".ALISTEC" [ALC2]
 Local File =[M]DOSDES+".ALISTET" [ALT2]
 Local File =[M]DOSDES+".ALISTEH" [ALH2]
 Local File =[M]DOSDES+".ALISTED" [ALD2]
 Local File =[M]DOSDES+".ATEXTRA" [AXX2]
Endif
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [ALH1] , [ALD1] , [ALH2] , [ALD2] , [AXX1] , [AXX2]
Close Local File [ALT1] , [ALL1] , [ALC1] , [ALT2] , [ALL2] , [ALC2]
Return

$TR_COP
GOK = 1
Trbegin [ALH2] , [ALD2]
 Delete [ALH2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ALISTEH" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ALH2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ALD2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ALISTED" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ALD2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ALT2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ALISTET" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ALT2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ALL2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ALISTEL" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ALL2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [ALC2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ALISTEC" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("ALC2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [AXX2] Where (CODFIC="ALISTEH" | CODFIC="ALISTED")   & IDENT1=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ATEXTRA" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AXX2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [ALD1] Where COD=TABLE
  [F:ALD2] = [F:ALD1]
  Call COPTEXTRA("ALISTED","INTITLIG",[F:ALD2]COD,num$([F:ALD2]NUMTEX)) From ATEXTRA
  Write [ALD2]
  If fstat
   GOK = 0 : Call FSTA("ALD2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [ALH1] Where COD=TABLE
  [F:ALH2] = [F:ALH1]
  Call COPTEXTRA("ALISTEH","INTIT",[F:ALH2]COD,"") From ATEXTRA
  Call COPTEXTRA("ALISTEH","INTITSHO",[F:ALH2]COD,"") From ATEXTRA
  If dim([F:ALH2]UPDUSR)>0 : [F:ALH2]UPDUSR = GUSER : Endif
  If dim([F:ALH2]UPDDAT)>0 : [F:ALH2]UPDDAT = date$ : Endif
  Write [ALH2]
  If fstat
   GOK = 0 : Call FSTA("ALH2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [ALT1] Where COD=TABLE
  [F:ALT2] = [F:ALT1]
  Write [ALT2]
  If fstat
   GOK = 0 : Call FSTA("ALT2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [ALL1] Where COD=TABLE
  [F:ALL2] = [F:ALL1]
  Write [ALL2]
  If fstat
   GOK = 0 : Call FSTA("ALL2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [ALC1] Where COD=TABLE
  [F:ALC2] = [F:ALC1]
  Write [ALC2]
  If fstat
   GOK = 0 : Call FSTA("ALC2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

$ABANDON
Gosub L_REMOVE_TITLE # BUG 78943
Return

#-------------------------------------------------------#
Subprog AP_REPGRA(VALEUR)
Variable Integer VALEUR
End

Subprog AM_REPGRA(VALEUR)
Variable Integer VALEUR
Local Integer I , K , LIB
Case VALEUR
 When 1
  [M:ALT5]REP = 0
  [M:ALT5]GRA = 0
  Effzo [ALT5]GRA : Effzo [ALT5]REP
 When 2,3,4
  If [M]REPGRA<=1
   LIB = 0
   For I=1 To [M:ALT5]NBLIG
    If [M:ALT5]TYPLIG(I-1)=4
     [M:ALT5]REP(I-1) = 1
     [M:ALT5]GRA(I-1) = 4
     K = find([M:ALT5]EXPR(I-1),[M:ALT5]CHAMP)
     If K
      Read [ATY]CODTYP=[M:ALT5]CODTYP(K)
      If !fstat
       If ([F:ATY]TYPTYP=7 or find([M:ALT5]CODTYP(K),"ATX","AXX","AX1","AX2","AX3")) & !LIB
        [M:ALT5]GRA(I-1) = 3
        LIB = 1
       Elsif [F:ATY]TYPTYP>=1 and [F:ATY]TYPTYP<=4
        [M:ALT5]GRA(I-1) = 1
       Endif
      Endif
     Endif
    Endif
   Next I
  Endif
Endcase
[M]REPGRA = VALEUR
Gosub GRISE_REPGRA
Gosub GRISE_TYPGRA
End

Subprog AP_OPTGRA(VALEUR)
Variable Char    VALEUR()
Case [M]REPGRA
 When 2 : [M]AFFGRA = val([M]VALREPGRA)
 When 3 : [M]POSGRA = val([M]VALREPGRA)
Endcase
End

Subprog AS_SEL(VALEUR)
Variable Char    VALEUR()
If indice>0 & [M]SEL(indice-1)="" : mkstat = 1 : End : Endif
Gosub CHARGE_AIDE
End

$CHARGE_AIDE
Local Integer I
If dim([M]TABL)>0
 Raz [M]TABL , NBTABL
 For I=1 To [M:ALT5]NBLIG
  If [M:ALT5]TYPLIG(I-1)=1
   If [M]NBTABL<dim([M]TABL)
    [M]NBTABL += 1
    [M]TABL([M]NBTABL-1) = [M:ALT5]TABLE(I-1)
   Endif
  Endif
 Next I
Endif
Return

Subprog AS_LNK(VALEUR)
Variable Char    VALEUR()
If indice>0 & [M]LNK(indice-1)="" : mkstat = 1 : End : Endif
Gosub CHARGE_AIDE
End

Subprog AS_TYPGRA(VALEUR)
Variable Integer VALEUR
GMENLOC(3) = 1
GMENLOC(4) = 1
GMENLOC(5) = 1
End

Subprog AP_TYPGRA(VALEUR)
Variable Integer VALEUR
[M]TYPGRA = VALEUR
Gosub GRISE_TYPGRA
End

Subprog AS_FSHGRA(VALEUR)
Variable Integer VALEUR
Case [M]TYPGRA
 When 2
  GMENLOC(1)=0 : GMENLOC(2)=0 : GMENLOC(3)=0
  GMENLOC(4)=1 : GMENLOC(5)=1 : GMENLOC(6)=1
  If [M]DEFGRA=4 or  [M]DEFGRA=5
    GMENLOC(2)=1 : GMENLOC(3)=1
  Endif
 When 3
  GMENLOC(1)=1 : GMENLOC(2)=1 : GMENLOC(3)=1
  GMENLOC(4)=0 : GMENLOC(5)=0 : GMENLOC(6)=0
 When Default  : mkstat=1
Endcase
End

Subprog AP_FSHGRA(VALEUR)
Variable Integer VALEUR
[M]FSHGRA = VALEUR
Gosub AFF_IMAGE
End

Subprog AS_DEFGRA(VALEUR)
Variable Integer VALEUR
If [M]TYPGRA<>1 and [M]TYPGRA<>2 : mkstat=1 : Endif
End

Subprog AP_DEFGRA(VALEUR)
Variable Integer VALEUR
[M]DEFGRA = VALEUR
Gosub AFF_IMAGE
End

Subprog AP_ENAFLG(VALEUR)
Variable Integer VALEUR
mkstat = 4
End

Subprog AS_NBLIG
Affzo [ALT5]
End

Subprog IB_VISFLG
End


