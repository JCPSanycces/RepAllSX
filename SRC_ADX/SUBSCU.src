#<AdxTL>@(#)4.0.0.0 $Revision$ Gestion objet SCU
Raz GBIDC1, GBIDC2 , GPILOBJ
Call OBJET("SCU",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "LIENS2"        : Gosub LIENS
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "APRES_CHOI"    : Gosub APRES_CHOI
 When "SETBOUT"       : Gosub SETBOUT
 When "AP_FILGAUCHE"  : Gosub AP_FILGAUCHE
 When Default
Endcase
Return

$OUVRE
If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:ADI])=0  : Local File ATABDIV    [ADI]  : Endif
If clalev([F:ADI2])=0 : Local File ATABDIV    [ADI2] : Endif
Return 

$LIENS
If CLE2 = "" : CLE2 = GFCYDEF : Endif
[M]FCY = CLE2
Gosub CHARGE
Return

$APRES_MODIF
If COUZON="FCY"
 Local Char OLDFCY(GLONFCY), NEWFCY(GLONFCY)
 OLDFCY = [M]FCY
 NEWFCY = CZ
 If OLDFCY<>NEWFCY
  Read [FCY]FCY0 = NEWFCY
  If fstat
   GMESSAGE = mess(15,104,1) : # Site inexistant
   mkstat = 2
  Else
   If VERROU : Gosub DEVERROU From GOBJET : Endif
   CLE2 = NEWFCY
   Gosub SETBOX From =WINPROG
   Gosub RELIT From GOBJSUB
   [M]FCY = NEWFCY : Affzo FCY
  Endif
  If [M]NBLIG = 0
    Gosub CHARGE
   Endif
  OK = -1
  SUIZON = "NBLIG(0)"
 Endif
 Gosub SETBOUT From GOBJSUB
Endif
Return

$SETBOUT
CHAINE += "><09"
Return

$APRES_CHOI
Case REPONSE
 When GSTALFT : Gosub GAUCHE    : REPONSE = 0
 When GSTASUI : Gosub SUIVANT   : REPONSE = 0
 When GSTAPRE : Gosub PRECEDENT : REPONSE = 0
 When GSTAFIR : Gosub PREMIER   : REPONSE = 0
 When GSTALAS : Gosub DERNIER   : REPONSE = 0
Endcase
Return

$GAUCHE
If VERROU : Gosub DEVERROU From GOBJET : Endif
Goto SUIVPREC

$SUIVANT
If VERROU : Gosub DEVERROU From GOBJET : Endif
Read [FCY]FCY0 > [M]FCY
Goto SUIVPREC

$PRECEDENT
If VERROU : Gosub DEVERROU From GOBJET : Endif
Read [FCY]FCY0 < [M]FCY
Goto SUIVPREC

$PREMIER
If VERROU : Gosub DEVERROU From GOBJET : Endif
Read [FCY]FCY0 First
Goto SUIVPREC

$DERNIER
If VERROU : Gosub DEVERROU From GOBJET : Endif 
Read [FCY]FCY0 Last
Goto SUIVPREC

$SUIVPREC
CLE2 = [F:FCY]FCY
Gosub SETBOX From =WINPROG
Gosub RELIT From GOBJSUB
REP = "" : GREP = ""
CRITERE = "1=1"
[M]FCY = [F:FCY]FCY
Affzo FCY
Gosub CHARGE
Return

$CHARGE
If [M]NBLIG=0
 Filter [ADI] Where NUMTAB = 362
 Filter [ADI2] Where NUMTAB = 363
 For [ADI]CODE
  For [ADI2]CODE
   nolign += 1
   [M]TYP(nolign-1) = [F:ADI]CODE
   If dim([M]ZTYP)>0
    Call LECTEXTRA([M]ZTYP(nolign-1),"ATABDIV","LNGDES","362",num$([M]TYP(indice))) From ATEXTRA
   Endif
   [M]CLS(nolign-1) = [F:ADI2]CODE
   If dim([M]ZCLS)>0
    Call LECTEXTRA([M]ZCLS(nolign-1),"ATABDIV","LNGDES","363",num$([M]CLS(indice))) From ATEXTRA
   Endif
  Next
 Next
 [M]NBLIG = nolign
 Filter [ADI]
 Filter [ADI2]
 Affzo TYP, CLS, FCY, SCU
 If dim([M]ZTYP)>0
  Affzo ZTYP
 Endif
 If dim([M]ZCLS)>0
  Affzo ZCLS
 Endif
Endif
Return

$AP_FILGAUCHE
If [M]FCY = ""
 [M]FCY = [F:FCY]FCY
Else
 Read [FCY]FCY0 = [M]FCY
Endif
Return

Subprog C_NBLIG
End

Subprog AM_SCU(VALEUR)
Variable Char VALEUR()
Local Char CHAINE(4)
CHAINE = "0"
While len(VALEUR)<4
 VALEUR = CHAINE+VALEUR
Wend
End




