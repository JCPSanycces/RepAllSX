#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case GACTION
 When "VISUCP"
  Case ACTION
   When "DEBUT"     : Gosub DEBUT_CP
  Endcase
 When "DETCP"
  Case ACTION
   When "DEBUT"     : Gosub DEBUT_DETAIL
  Endcase
Endcase
Return

$DEBUT_CP
Gosub DECLARE
Gosub OUVFIC

MATRI = PARAM(1)
CTR   = PARAM(2)
Raz [M]

Call PARAM("","CNGYEASTR",PARTPS) From ADOVAL
ANNDEB = val(PARTPS)
Call PARAM("","CNGYEAEND",PARTPS) From ADOVAL
ANNFIN = val(PARTPS)

Call LECTURE("EML",MATRI,"") From CONTOBJ
Filter [CTR] Where REFNUM=MATRI & CTRNUM=CTR
Read [CTR]CTR0 Last
Filter [CTR]
Call LECTURE("FCY",[F:CTR]ETRFCY,"") From CONTOBJ

[M]REFNUM = MATRI
[M]CTRNUM = CTR

nolign = 0
For [TIM]TIM0 Where CATTIM=3
 CODTPS = [F:TIM]COD
# Chargement des droits
 NBDROIT = 0
 For [CNE]CNE1 Where REFNUM=MATRI & CTRNUM=CTR & TIM=CODTPS
  NBDROIT += 1
  TBANNEE(NBDROIT) = [F:CNE]YEA
  TBJOURS(NBDROIT) = [F:CNE]NBRDAY
  TBACQUI(NBDROIT) = [F:CNE]NBRDAY
  TBPRIS(NBDROIT)  = [F:CNE]NBRPRI
  Read [CNG]CNG0 = [F:FCY]LEGCPY;[F:CNE]YEA;CODTPS
  TBDEB(NBDROIT)   = [F:CNG]STRDAT
  TBFIN(NBDROIT)   = [F:CNG]ENDDAT
 Next
 For I=1 To NBDROIT
  If TBANNEE(I)>=ANNDEB & TBANNEE(I)<=ANNFIN
   If dim([M]TIM)<nolign+1
    # Tableau plein
    # Paramétrage à revoir
    Call ERREUR(mess(26,100,1)-"\"-mess(86,105,1)-":"-"CNGYEASTR"-"CNGYEAEND") From GESECRAN
    Break 2
   Endif
   nolign += 1
   [M]TIM(nolign-1)    = CODTPS
   [M]YEA(nolign-1)    = TBANNEE(I)
   [M]ACQ(nolign-1)    = TBACQUI(I)
   [M]PRI(nolign-1)    = TBPRIS (I)
   [M]SOL(nolign-1)    = TBACQUI(I)-TBPRIS(I)
   [M]DATDEB(nolign-1) = TBDEB(I)
   [M]DATFIN(nolign-1) = TBFIN(I)
   #ADNGO - 2017-01-13 - X3-11765 - START
   #Read [TIM]TIM0 = CODTPS
   Read [TIM]TIM0 = GCURLEG;CODTPS
   #ADNGO - 2017-01-13 - X3-11765 - END
   [M]LIBEL(nolign-1)  = [F:TIM]DES
  Endif
 Next I
Next
[M]NBLIG = nolign
Sorta [M]NBLIG [M]NBLIG Order By [M]YEA(indice),[M]TIM(indice)
[M]TOT = sum([M]SOL(0..[M]NBLIG-1))
Affzo
Return

$OUVFIC
If clalev([F:ADW])=0 : Local File ADOVAL    [ADW] : Endif
If clalev([F:ID])=0  : Local File EMPLOID   [ID]  : Endif
If clalev([F:CNG])=0 : Local File CNGCPY    [CNG] : Endif
If clalev([F:CNE])=0 : Local File CNGEMP    [CNE] : Endif
If clalev([F:TIM])=0 : Local File TIMCOD    [TIM] : Endif
If clalev([F:TIP])=0 : Local File TIMEMP    [TIP] : Endif
If clalev([F:TIG])=0 : Local File TIMREGUL  [TIG] : Endif
If clalev([F:FCY])=0 : Local File FACILITY  [FCY] : Endif
If clalev([F:CTR])=0 : Local File EMPLOCTR  [CTR] : Endif
Return

$DECLARE
Local Integer MAXJOUR , MAXANNEE
MAXJOUR  = 50
MAXANNEE = 50
Local Char    MATRI(GLONMAT) , PARTPS(30) , CTR(GLONCTR)
Local Char    CODTPS(GLONTPS)
Local Integer ANNEE , I
Local Integer NBDROIT
Local Decimal JOUR(1..MAXJOUR) , HEURE(1..MAXJOUR)
Local Integer TBANNEE(1..MAXANNEE)
Local Date    TBDEB(1..MAXANNEE) , TBFIN(1..MAXANNEE)
Local Decimal TBJOURS(1..MAXANNEE) , TBACQUI(1..MAXANNEE), TBPRIS(1..MAXANNEE)
Local Date    DAT
Local Decimal JRESTE , JIMPUT , TOTIMPUT
Local Integer ANNDEB , ANNFIN
Return

$DEBUT_DETAIL
Gosub DECLARE
Gosub OUVFIC

MATRI  = PARAM(1)
CODTPS = PARAM(2)
ANNEE  = val(PARAM(3))
CTR    = PARAM(4)

Raz [M]
Call LECTURE("EML",MATRI,"") From CONTOBJ
Filter [CTR] Where REFNUM=MATRI & CTRNUM=CTR
Read [CTR]CTR0 Last
Filter [CTR]
Call LECTURE("FCY",[F:CTR]ETRFCY,"") From CONTOBJ

# Chargement des droits
NBDROIT = 0
For [CNE]CNE1 Where REFNUM=MATRI & CTRNUM=CTR & TIM=CODTPS
 NBDROIT += 1
 TBANNEE(NBDROIT) = [F:CNE]YEA
 TBJOURS(NBDROIT) = [F:CNE]NBRDAY
 Read [CNG]CNG0 = [F:FCY]LEGCPY;[F:CNE]YEA;CODTPS
 TBDEB(NBDROIT)   = [F:CNG]STRDAT
 TBFIN(NBDROIT)   = [F:CNG]ENDDAT
 If [F:CNE]YEA=ANNEE
  [M]ACQ = [F:CNE]NBRDAY
 Endif
Next
# Parcours des temps
nolign = 0
For [TIP]TIP1 Where REFNUM=MATRI & CTRNUM=CTR & TIM=CODTPS
 If [F:TIP]STRDAT=[F:TIP]ENDDAT
  JOUR(1) = [F:TIP]NBRDAY
 Else
  #DBA le 25/11/04
  Call VALORDET([F:TIP]STRDAT,[F:TIP]ENDDAT,MATRI,CODTPS,JOUR,HEURE,[F:TIP]FCY,[F:TIP]CTRNUM) From SUBPLN
 Endif
 TOTIMPUT = 0
 For K=1 To [F:TIP]ENDDAT-[F:TIP]STRDAT+1
  DAT = [F:TIP]STRDAT+K-1
  If JOUR(K)
   JRESTE = JOUR(K)
   For I=1 To NBDROIT
    If DAT>=TBDEB(I) & DAT<=TBFIN(I) & TBJOURS(I)>0
# ou If DAT<=TBFIN(I) & TBJOURS(I)>0 : # si on peut les prendre d'avance...
     If TBJOURS(I)>JOUR(K)
      JIMPUT = JRESTE
     Else
      JIMPUT = TBJOURS(I)
     Endif
     TBJOURS(I) -= JIMPUT
     JRESTE     -= JIMPUT
     If TBANNEE(I)=ANNEE
      TOTIMPUT   += JIMPUT
     Endif
     If JRESTE<=0 : Break : Endif
    Endif
   Next I
  Endif
 Next K
 If TOTIMPUT
  nolign += 1
  [M] = [F:TIP]
  [M]NBRDAY(nolign-1) = TOTIMPUT
 Endif
Next
For [TIG] Where REFNUM=MATRI & CTRNUM=CTR & TIM=CODTPS
 DAT = [F:TIG]STRDAT
 TOTIMPUT = 0
 If [F:TIG]NBRDAY
  JRESTE = [F:TIG]NBRDAY
  For I=1 To NBDROIT
   If DAT>=TBDEB(I) & DAT<=TBFIN(I) & TBJOURS(I)>0
#61817
#    If TBJOURS(I)>JOUR(K)
    If TBJOURS(I)>JRESTE
#
     JIMPUT = JRESTE
    Else
     JIMPUT = TBJOURS(I)
    Endif
    TBJOURS(I) -= JIMPUT
    JRESTE     -= JIMPUT
    If TBANNEE(I)=ANNEE
     TOTIMPUT += JIMPUT
    Endif
    If JRESTE<=0 : Break : Endif
   Endif
  Next I
 Endif
 If TOTIMPUT
  nolign += 1
  [M] = [F:TIG]
  [M]NBRDAY(nolign-1) = TOTIMPUT
 Endif
Next
[M]NBRLIG = nolign
Sorta [M]NBRLIG [M]NBRLIG Order By [M]STRDAT(indice)
[M]CUMDAY(0) = [M]NBRDAY(0)
For nolign=2 To [M]NBRLIG
 [M]CUMDAY(nolign-1) = [M]CUMDAY(nolign-2)+[M]NBRDAY(nolign-1)
Next nolign
[M]PRI = sum([M]NBRDAY(0..[M]NBRLIG-1))
[M]SOL = [M]ACQ-[M]PRI
Affzo
Return

