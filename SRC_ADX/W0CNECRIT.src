 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CALLFCY"
  Call C_ALLFCY(IMPENT) From DIVPAYE
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "ALLFCY" : GZNUM = 6053 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WNUM<>IMPENT or IMPMOD
    SAVACT = GACTION : GACTION = "BMALLFCY"
    Call AM_ALLFCY(IMPENT) From DIVPAYE
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "ALLFCY" : GZNUM = 6053 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif
[M]ALLFCY = IMPENT

## Zone FCY
mkstat = 0
zoncou = "FCY"
indice = 0
WCHAR = [M]FCY
If varmode([M]FCY,indice)=0
 SAVACT = GACTION : GACTION = "BSFCY"
 Call AS_FCY([M]FCY) From DIVPAYE
 GACTION = SAVACT
 If mkstat=1 : Raz [M]FCY : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "INIFCY"
  Call INIFCY([M]FCY,[M]CPY) From EXEFNC
  GACTION = SAVACT
  If mkstat=1 : Raz [M]FCY : Endif
  If !mkstat
   IMPMOD = 0 : IMPZON = "FCY" : Gosub ACTION From =IMPTRT
  Endif
  If !mkstat
   If vireblc([M]FCY,2)=""
    mkstat = 1 : GMESSAGE = mess(10,123,1)
   Endif
   If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "ACONTFCY"
    Call CONTSITE([M]FCY) From SUBAGF
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     Call CONTROLE("FCY","",[M]FCY,"",mkstat) From CONTOBJ
     If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      SAVACT = GACTION : GACTION = "CONTFCY"
      Call CONTFCY([M]FCY) From EXEFNC
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
      If !mkstat
       SAVACT = GACTION : GACTION = "CONTFCYCPY"
       Call CONTFCYCPY([M]FCY,[M]CPY) From EXEFNC
       GACTION = SAVACT
       If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
       Gosub AFF From GSAISIE
       If mkstat : End : Endif
       If !mkstat
        If WCHAR<>[M]FCY or IMPMOD
         SAVACT = GACTION : GACTION = "BMFCY"
         Call AM_FCY([M]FCY) From DIVPAYE
         GACTION = SAVACT
         If mkstat : GERR = 1 : GZONE = "FCY" : GZNUM = 1344 : Endif
         Gosub AFF From GSAISIE
         If mkstat : End : Endif
        Endif
       Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
WCHAR = [M]LEG
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"909","") From SUBADI
 GACTION = SAVACT
Endif
If !mkstat
 If varmode([M]LEG,indice)=0
  If !mkstat
   IMPMOD = 0 : IMPZON = "LEG" : Gosub ACTION From =IMPTRT
  Endif
  If vireblc([M]LEG,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTADI"
   Call CONTADI([M]LEG,"909","") From SUBADI
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("ADI","",[M]LEG,"909",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "CLEG"
     Call C_LEG([M]LEG) From DIVPAYE
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      If WCHAR<>[M]LEG or IMPMOD
       SAVACT = GACTION : GACTION = "BMLEG"
       Call AM_LEG([M]LEG) From DIVPAYE
       GACTION = SAVACT
       If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
       Gosub AFF From GSAISIE
       If mkstat : End : Endif
       If !mkstat
        SAVACT = GACTION : GACTION = "STD"
        Call AM_LEG([M]LEG) From SUBHRCNECRI
        GACTION = SAVACT
        If mkstat : GERR = 1 : GZONE = "LEG" : GZNUM = 26213 : Endif
        Gosub AFF From GSAISIE
        If mkstat : End : Endif
       Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone ALLSRV
mkstat = 0
zoncou = "ALLSRV"
indice = 0
IMPENT = [M]ALLSRV
If varinit([M]ALLSRV,indice)=0
 IMPENT = 2
Endif
If varmode([M]ALLSRV,indice)=0
 [M]ALLSRV(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ALLSRV" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ALLSRV(indice)
 Endif
 SAVACT = GACTION : GACTION = "CALLSRV"
 Call C_ALLSRV(IMPENT) From DIVPAYE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ALLSRV" : GZNUM = 46945 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]ALLSRV = IMPENT

## Zone SRV
mkstat = 0
zoncou = "SRV"
indice = 0
If varmode([M]SRV,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SRV" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]SRV,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "SRV" : GZNUM = 18735 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("SRV","",[M]SRV,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "SRV" : GZNUM = 18735 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone ALLPRF
mkstat = 0
zoncou = "ALLPRF"
indice = 0
IMPENT = [M]ALLPRF
If varinit([M]ALLPRF,indice)=0
 IMPENT = 2
Endif
If varmode([M]ALLPRF,indice)=0
 [M]ALLPRF(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "ALLPRF" : Gosub ACTION From =IMPTRT
  IMPENT = [M]ALLPRF(indice)
 Endif
 SAVACT = GACTION : GACTION = "CALLPRF"
 Call C_ALLPRF(IMPENT) From DIVPAYE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "ALLPRF" : GZNUM = 13625 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]ALLPRF = IMPENT

## Zone PRF
mkstat = 0
zoncou = "PRF"
indice = 0
If varmode([M]PRF,indice)=0
 SAVACT = GACTION : GACTION = "BSPRF"
 Call AS_PRF([M]PRF) From DIVPAYE
 GACTION = SAVACT
 If mkstat=1 : Raz [M]PRF : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "PRF" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]PRF,2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "PRF" : GZNUM = 8750 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTPRF"
   Call CONTPRF([M]PRF) From SUBPRF
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "PRF" : GZNUM = 8750 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "CONTOBJN"
    Local Char    VALEUR(250)
    VALEUR = [M]PRF
    Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
    [M]PRF = VALEUR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "PRF" : GZNUM = 8750 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone MATDEB
mkstat = 0
zoncou = "MATDEB"
indice = 0
If varmode([M]MATDEB,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "MATDEB" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "DROITEMP"
 Call DROIT([M]MATDEB,"","","") From DIVPAYE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "MATDEB" : GZNUM = 45742 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("EML","!",[M]MATDEB,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "MATDEB" : GZNUM = 45742 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone MATFIN
mkstat = 0
zoncou = "MATFIN"
indice = 0
If varmode([M]MATFIN,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "MATFIN" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "DROITEMP"
 Call DROIT([M]MATFIN,"","","") From DIVPAYE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "MATFIN" : GZNUM = 45743 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("EML","!",[M]MATFIN,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "MATFIN" : GZNUM = 45743 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CTLALPV"
   Call CTLALPV([M]MATFIN,[M]MATDEB) From CONTDIV
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "MATFIN" : GZNUM = 45743 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone POP
mkstat = 0
zoncou = "POP"
indice = 0
If varmode([M]POP,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "POP" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "CONTPOP"
 Call CONTPOP([M]POP,"") From SUBPOP
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("POP","!",[M]POP,"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 19073 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone INI
mkstat = 0
zoncou = "INI"
For indice=0 To 29
 If varinit([M]INI,indice)=0
  SAVACT = GACTION : GACTION = "STD"
  Call D_INI([M]INI(indice)) From SUBHRCNECRI
  GACTION = SAVACT
 Endif
 mkstat = 0
Next indice
If mkstat : End : Endif

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
indice = 0
status = 1
zoncou = "NBLIG"
If varmode([M]NBLIG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG = nolign
   status = 75
   Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 3
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

## Zone TIM
mkstat = 0
zoncou = "TIM"
If varmode([M]TIM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TIM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]TIM(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "TIM" : GZNUM = 5296 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTHRTIM"
  Call CONTHRTIM([M]TIM(indice)) From SUBHRTIM
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "TIM" : GZNUM = 5296 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Local Char    VALEUR(250)
   VALEUR = [M]TIM(indice)
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
   [M]TIM(indice) = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "TIM" : GZNUM = 5296 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_TIM([M]TIM(indice)) From SUBHRCNECRI
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "TIM" : GZNUM = 5296 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone NBRDAY
mkstat = 0
zoncou = "NBRDAY"
If varmode([M]NBRDAY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRDAY" : Gosub ACTION From =IMPTRT
 Endif
 If [M]NBRDAY(indice)<0
  mkstat = 1 : GMESSAGE = mess(180,141,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "NBRDAY" : GZNUM = 3599 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CNECRIT"
Return

