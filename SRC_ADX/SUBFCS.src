#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion objet FCS
########################################################################
# SUBFCS : Gestion des charges                        MUARN 06/05/2013 #
# Issue 70985 - 2012-02-15 by MUARN : Landed cost                      #
########################################################################

$ACTION
#Infbox "ACTION = " + ACTION
Case ACTION
  When "OUVRE"     : Gosub OUVRE
  When "RAZCRE"    : Gosub RAZCRE
  When "RAZDUP"    : Gosub RAZDUP
#  When "SETBOUT"  : Gosub SETBOUT
  When "LIENS"     : Gosub LIENS
  When "INICRE"    : Gosub INICRE
  When "CREATION"  : Gosub CREAMOD
  When "APRES_CRE" : Gosub LIENS
  When "MODIF"     : Gosub CREAMOD
  When "ANNULE"    : Gosub ANNULE
  When "AVANT_MOD" : Gosub AVANT_MOD
  When Default
Endcase
Return

#########################################################################
$OUVRE
If !clalev([F:TCA])    Local File TABCOUAFF   [TCA]  : Endif
GFCYDEF(0)=GFCYDEF(6)
GFCY      =GFCYDEF(6)
#----- Chargement des globales référentiels, comptes et sections de la société -----#
Call GETCPY(GFCY,"",0,"") From TRTX3CPT
#----- Compteur des charges -----#
Call LECTCA(9,OK) From SUBTCA
  If fstat | !OK
    GMESSAGE=mess(58,105,1)-mess(9,14,1)-mess(250,199,1) : Return
  Endif
  GMANCOU=[F:TCA]MANCOU(6) : GCODNUM=[F:TCA]CODNUM(6)
Return

#########################################################################
$RAZCRE
Call INIT_DIE(17,"","FCS1","NBAXE") From TRTX3CPT
Actzo [FCS1]1-99
[M:FCS1]ENAFLG    = 2
[M:FCS1]DIRFLG    = 2
[M:FCS1]INVFLG    = 1
[M:FCS1]DOCCHGTYP = 2
Grizo [M:FCS1]INVFLG, CHGTYP, HGHBKT
Affzo [M:FCS1]
Return

#########################################################################
$RAZDUP
Actzo [M:FCS1]DIRFLG, FCSNAT
Affzo [M:FCS1]DIRFLG, FCSNAT
Return

#########################################################################
$SETBOUT
# si charge utilisée dans un structure, pas de modification ni suppression
If CLECUR
  Filter [F:STCL] Where FCSCOD = [M:FCS1]FCSCOD
  Look [F:STCL]STCL0 First
  If !fstat
      Call VIREBOUT(CHAINE,"MA") From GOBJET
  Endif
  Filter [F:STCL]
  Filter [F:STCD] Where FCSCOD = [M:FCS1]FCSCOD
  Look [F:STCD]STCD0 First
  If !fstat
      Call VIREBOUT(CHAINE,"MA") From GOBJET
  Endif
  Filter [F:STCL]
Endif
Return

#########################################################################
$LIENS
Local Integer WRET
Call CHARG_DIE(17,"","FCS1","NBAXE") From TRTX3CPT
Actzo [M:FCS1]DIRFLG, FCSNAT

Call  CONTROL_USEFCS([M:FCS1]FCSCOD,WRET, "LIENS") From STCCTL


# Une charge directe n'est jamais facturable
# Activer ou désactiver le mode de calcul selon charge directe ou indirecte
If [M:FCS1]DIRFLG    = 2
   Grizo [M:FCS1]INVFLG  : Actzo [M:FCS1]10
   # Si par Tranche activation tranche supérieure
   If [M:FCS1]DIRCLCMOD = 4 : Actzo [M:FCS1]HGHBKT    : Else Grizo [M:FCS1]HGHBKT : Endif
Else
   Actzo [M:FCS1]INVFLG  : Grizo [M:FCS1]10
Endif
If [M:FCS1]DIRCLCMOD    <> 5
   Grizo [M:FCS1]LIMTYP
Else
   Actzo [M:FCS1]LIMTYP
Endif
If [M:FCS1]DOCCHGTYP = 2 : Grizo [M:FCS1]CHGTYP    : Else Actzo [M:FCS1]CHGTYP : Endif
Read [AXX] AXX0="FRECST";"";GLANGUE;[M:FCS1]FCSCOD;""
If !fstat  [M:FCS1]DESAXX=[F:AXX]TEXTE : Endif
Return

#########################################################################
$INICRE
Local Integer STAT
If GMANCOU<>2 | (GMANCOU=2 & vireblc([M:FCS1]FCSCOD,2)="")
  Call NUMERO(GCODNUM,GFCY,date$,"",[M:FCS1]FCSCOD,STAT) From SUBANM
  If GOK<0
    Return
  Elsif GOK<1 | STAT<>0
    Local Char MESSA(80)
    GMESSAGE=mess(60,199,1)-"("+GCODNUM+") : "
    Gosub MESSAGE From SUBANM
    GMESSAGE-=MESSA : GOK=0 : GERR=1
    Return
  Endif
  [F:FCS]FCSCOD=[M:FCS1]FCSCOD
Endif
Return

#########################################################################
$AVANT_MOD
Local Integer WRET
If zoncou <> "DESAXX"
  Call  CONTROL_USEFCS([M:FCS1]FCSCOD,WRET,"AVANT_MOD") From STCCTL
Endif
If WRET : GOK = 0 : Endif
Return

#########################################################################
$CREAMOD
Call MAJTEXTRA ([M:FCS1]DESAXX,"FRECST","DESAXX",[F:FCS]FCSCOD,"") From ATEXTRA
Return

#########################################################################
$ANNULE
# suppression des textes traduisibles (v 140)
Delete [AXX] Where CODFIC="FRECST" & IDENT1=[M:FCS1]FCSCOD
Return

######################################################################################
## Actions sur champs écran FCS1
######################################################################################
Subprog AS_FCSCOD(VALEUR)
Variable Char    VALEUR()
If (GREP = "C" | GREP = "D") & GMANCOU <> 2 : mkstat = 2 : Endif
End

# Une charge directe n'est jamais facturable
# Activer ou désactiver le mode de calcul selon charge directe ou indirecte
Subprog AM_DIRFLG(VALEUR)
Variable Integer VALEUR
Case VALEUR :
  When 1 : Actzo [M:FCS1]INVFLG : : Grizo [M:FCS1]10
  When 2 : [M:FCS1]INVFLG = 1 : Grizo [M:FCS1]INVFLG :  Actzo [M:FCS1]10
Endcase
End

######################################################################################
Subprog C_FCSCOD(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" : End : Endif
# Si saisie manuelle = non, on ne peut pas saisir un code inexistant
If GMANCOU <> 2
    Look [F:FCS]FCS0 = VALEUR
    If fstat
      GMESSAGE = mess(178,199,1) # Ce document n'existe pas
      mkstat = 2
      End
    Endif
Endif
End

