######################################################################################
# Si pas type de cours du doument, saisir le type de cours
Subprog AM_DOCCHGTYP(VALEUR)
Variable Integer VALEUR
Case VALEUR :
  When 1 : Actzo [M:FCS1]CHGTYP
  When 2 : [M:FCS1]CHGTYP = 1 : Grizo [M:FCS1]CHGTYP
Endcase

End


#############################
# Affichage de la désignation du code comptable (lien long ne marche pas)
Subprog AM_ACC(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  Raz [M:FCS1]ACCDES
Else
  Call LECTEXTRA([M:FCS1]ACCDES,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
Endif
Affzo [M:FCS1]ACCDES
End


######################################################################################
# si mode de calcul pas "Par tranche" , pas de saisie de "Tranche supérieure"
Subprog AM_DIRCLCMOD(VALEUR)
Variable Integer VALEUR
If VALEUR = 4 : Actzo [M:FCS1]HGHBKT : Else [M:FCS1]HGHBKT = 1 : Grizo [M:FCS1]HGHBKT : Endif
Affzo [M:FCS1]HGHBKT
If VALEUR = 5 : Actzo [M:FCS1]LIMTYP : Else Grizo [M:FCS1]LIMTYP : Endif
Affzo [M:FCS1]LIMTYP
End

######################################################################################
