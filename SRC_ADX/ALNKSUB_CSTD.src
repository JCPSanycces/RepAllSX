#<AdxTL>@(#)0.0.0.0 $Revision$
# Class ALNKSUB

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AREAD"                  : Gosub AREAD
      When "AINSERT_CONTROL_BEFORE" : Gosub AINSERT_CONTROL_BEFORE
      When "AINSERT"                : Gosub AINSERT
      When "AINSERT_CONTROL_AFTER"  : Gosub AINSERT_CONTROL_AFTER
      When "AUPDATE"                : Gosub AUPDATE
      When "AUPDATE_CONTROL_AFTER"  : Gosub AUPDATE_CONTROL_AFTER
      When "ADELETE"                : Gosub ADELETE
    Endcase
  When "COLALB"
    Case [L]AEVENT
      When "AREAD_AFTER"            : Gosub ALNKSUB_AREAD_AFTER
      When "ADDLINE_AFTER"          : Gosub ALNKSUB_ADDLINE_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "CRY"                : Gosub CRY
  When "TYP"                : Gosub TYP
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return




############################################################################################################
$AREAD
Local Integer ILINE:ILINE=0
Local File ALNKSUB [ALB]

  For [ALB] Where [F:ALB]CRY=this.CRY & [F:ALB]TYP=this.TYP
    ILINE = fmet this.ADDLINE("COLALB",[V]CST_ALASTPOS)
    [L]ASTATUS = fmet this.COLALB(ILINE).AREAD([F:ALB]CRY,[F:ALB]TYP,[F:ALB]POS)
    If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
  Next
  # Not found
  If ILINE=0
    [L]ASTATUS = fmet this.ASETERROR("ALNKSUB",mess(81,75,1),[V]CST_AERROR)
  Endif

Return

######################################################################################################
$AINSERT_CONTROL_BEFORE
Local File ALNKSUB [ALB]
For [ALB] Where [F:ALB]CRY= this.CRY and [F:ALB]TYP=this.TYP
  [L]ASTATUS = fmet this.ASETERROR("TYP",mess(22,100,1),[V]CST_AERROR)
  Break
Next
Return

############################################################################################################
$AINSERT
Local Integer ILINE
For ILINE=1 To maxtab(this.COLALB)
  If this.COLALB(ILINE)<>null
    If this.COLALB(ILINE).ASTALIN = CST_ANEW
      [L]ASTATUS = fmet this.COLALB(ILINE).AINSERT()
      Break ([L]ASTATUS>=[V]CST_AERROR)
    Endif
  Endif
Next
Return

###############################################################################################
$AINSERT_CONTROL_AFTER
Gosub CONTROL
Return


############################################################################################################
$AUPDATE
Local Integer ILINE
# First - Delete the lines that have been removed from the collection
For ILINE= 1 To maxtab(this.COLALB)
  If this.COLALB(ILINE)<>null
    If this.COLALB(ILINE).ASTALIN = [V]CST_ADEL
      [L]ASTATUS = fmet this.COLALB(ILINE).ADELETE()
      If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
    Endif
  Endif
Next
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

  # Second - Update existing and changed lines
For ILINE= 1 To maxtab(this.COLALB)
  If this.COLALB(ILINE)<>null
    If this.COLALB(ILINE).ASTALIN = [V]CST_AUPD
      [L]ASTATUS = fmet this.COLALB(ILINE).AUPDATE()
      If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
    Endif
  Endif
Next

If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Finally - Insert new lines
For ILINE= 1 To maxtab(this.COLALB)
  If this.COLALB(ILINE)<>null
    If this.COLALB(ILINE).ASTALIN = [V]CST_ANEW
      [L]ASTATUS = fmet this.COLALB(ILINE).AINSERT()
      If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
    Endif
  Endif
Next

Return

###############################################################################################
$AUPDATE_CONTROL_AFTER
Gosub CONTROL
Return


############################################################################################################
$ADELETE
Local Integer ILINE
For ILINE= 1 To maxtab(this.COLALB)
  If this.COLALB(ILINE)<>null
    [L]ASTATUS = fmet this.COLALB(ILINE).ADELETE()
    If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
  Endif
Next
Return


############################################################################################################
$ALNKSUB_AREAD_AFTER
# Assign ASTALIN to CST_ALL (they have CST_NEW as value just after AREAD method)
this.ASTALIN = [V]CST_ALL

Return

############################################################################################################
$ALNKSUB_ADDLINE_AFTER
# To initialize properties of the header
this.CRY = this.APARENT.CRY
this.TYP = this.APARENT.TYP

Return

#######################################################################################################
$CONTROL
Gosub TYP_CONTROL
If [L]ASTATUS >= CST_AERROR
  Return
Endif
Gosub  CTL_CONSISTENCY
Return

###################################################################################################
$CTL_CONSISTENCY
Local Shortint LINE_FOUND
Local Integer ILINE, ILINE_SEARCH
  For ILINE=1 To maxtab(this.COLALB)
    If this.COLALB(ILINE)<>null
      If find(this.COLALB(ILINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
        LINE_FOUND=1
        For ILINE_SEARCH= ILINE+1 To maxtab(this.COLALB)
          If this.COLALB(ILINE_SEARCH)<>null
            If find(this.COLALB(ILINE_SEARCH).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
              If this.COLALB(ILINE).POS= this.COLALB(ILINE_SEARCH).POS
                [L]ASTATUS = fmet this.ASETERROR("", this.COLALB(ILINE).POS -":"-mess(94,139,1),[V]CST_AERROR)
                Break 2
              Endif
            Endif
          Endif
        Next ILINE_SEARCH
      Endif
    Endif
  Next ILINE
  If LINE_FOUND=0
    [L]ASTATUS = fmet this.ASETERROR("",mess(178,123,1),[V]CST_AERROR)
  Endif
Return


#######################################################################################################
$CRY
Case  [L]ARULE
  When "PROPAGATE"    : Gosub CRY_PROPAGATE
  When "CONTROL"      : Gosub CRY_CONTROL
Endcase
Return

#######################################################################################################
# Initialize type according to subdivision value country
$CRY_CONTROL
If this.CRY<>AVOID.ACHAR
  # Subdivision 1
  If fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"ETATFLG")<>[V]CST_AYES &
&   fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"ETATFLG2")<>[V]CST_AYES
      [L]ASTATUS = fmet this.ASETERROR("CRY",mess(213,139,1),[V]CST_AERROR)
  Endif
Endif
Return

#######################################################################################################
$CRY_PROPAGATE
Gosub TYP_INIT
Return

#######################################################################################################
$TYP
Case [L]ARULE
  When "INIT"         : Gosub TYP_INIT
  When "CONTROL"      : Gosub TYP_CONTROL
Endcase
Return

#######################################################################################################
# Initialize type according to subdivision value country
$TYP_INIT
If this.CRY<>AVOID.ACHAR
  # Subdivision 14
  If fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"ETATFLG")=[V]CST_AYES
    this.TYP = 2
  Elsif fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"ETATFLG2")=[V]CST_AYES
    this.TYP = 3
  Endif
Endif
Return

#######################################################################################################
#**
#* TYP - Allow TYP menu selection based on country setup
#*!
$TYP_CONTROL
# Subdivision None
If this.CRY<>AVOID.ACHAR
  If this.TYP = 1
    [L]ASTATUS = fmet this.ASETERROR("TYP",mess(83,123,1),[V]CST_AERROR)
    # Subdivision 1
  Elsif this.TYP = 2
    If fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"ETATFLG")<>[V]CST_AYES
      [L]ASTATUS = fmet this.ASETERROR("TYP",mess(83,123,1),[V]CST_AERROR)
    Endif
  # Subdivision 2
  Elsif this.TYP = 3
    If  fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"ETATFLG2")<>[V]CST_AYES
      [L]ASTATUS = fmet this.ASETERROR("TYP",mess(83,123,1),[V]CST_AERROR)
    Endif
  Endif
Endif
Return

