#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIFIN001GEN   UTI process                                    Module CPT  #
# called by UTI2018R08 -> UTIFIN001   Yes   No
# called by CPTMAJ90   -> UTIFIN002   No    No
# called by VALDOS                    No    Yes
##########################################################################

# Issue X3-115384 - 2018-11-05 by CBO : Error when histo folder
# Issue X3-113104 - 2018-10-30 by CBO : Error in UTIBASE when X3 folder
# Issue X3-113885 - 2018-10-23 by CBO : manage n folders
# Issue X3-111845 - 2018-10-05 by CBO : manage n folders
# Issue X3-111553 - 2018-10-04 by CBO : good folder in ABA
# Issue X3-110660 - 2018-09-28 by CBO : error in system tables
Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

Local Char WCODOPE(100)(1..5)
Local Shortint WACTIV, WCRT

  WCODOPE(1) = mess(1,1,1)
  WCODOPE(2) = mess(2,1,1)
  WACTIV = 1
  Selbox WCODOPE(1..2) Titled "active recurring task " Using WACTIV
  If WACTIV <> 2
    WACTIV = 1
  Endif

#  WCODOPE(1) = mess(1,1,1)
#  WCODOPE(2) = mess(2,1,1)
#  WCRT = 1
#  Selbox WCODOPE(1..2) Titled "force create recurring task " Using WCRT
#  If WCRT <> 2
#    WCRT = 1
#  Endif

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("BTC -> ABA Accounting recurring task migration.") From LECFIC
  Call MAJ_UTIFIN001(WDOSSIER, WACTIV, 1)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
#**
#*
#*
#* @param DOSSIER               folder
#* @param PACTIV_REC_TASK       [F:ABA]ENAFLG local menu 1
#* @param PFORCE_CRT_REC_TASK   force the recurring task
#*!
Subprog MAJ_UTIFIN001(DOSSIER, PACTIV_REC_TASK, PFORCE_CRT_REC_TASK)
Value Char DOSSIER()
Value Shortint PACTIV_REC_TASK, PFORCE_CRT_REC_TASK

Local Char WCODTASK(30)
Local Char WCODABT(GLONABA)
Local Integer WMULBATCH

  If func DOSSUB.ISHISTFOLD(DOSSIER) # X3-115384
    End
  Endif

  If PACTIV_REC_TASK <> [V]CST_AYES
    PACTIV_REC_TASK = [V]CST_ANO
  Endif

  Local File =[L]DOSSIER+".ADOVAL" [ADW12]
  Read [ADW12]ADW0 = "";"";"MULBATCH"

  If fstat = 0 and [F:ADW12]VALEUR = "2"
    WMULBATCH = [V]CST_AYES
  Else
    WMULBATCH = [V]CST_ANO
  Endif
  Call ECR_TRACE("UTIFIN001GEN : Recurring task is created active : " + mess(PACTIV_REC_TASK,1,1), 0) From GESECRAN
  Call ECR_TRACE("", 0) From GESECRAN

  Local File =DOSSIER + ".BATCH"   [BTC]

  Local File ABATABT   [ABA]
  Local File ABATGRP   [ABG]
  Local File ABATABTD  [ABD]
  Local File ABATABTD2 [A22]
  Local File ABATRQT2  [A11]
  Local File ABATRQT   [ABR]
  Local File ABATTAC   [ABT]
  Local File ADICTRT   [ADC]

  Local Integer CPT_BTC
  Raz CPT_BTC

  Call DEBTRANS From GLOCK

  Trbegin [BTC]

  Local Char W_TEMPLATE_REC(GLONABA)
  W_TEMPLATE_REC = func SUBBTC.GET_TEMPLATE_ACCTASK_ABA()

  Delete [ABA] Where CODABT = "ACCBATRECT" # delete an old name template
  #Delete [ABA] Where CODABT = W_TEMPLATE_REC # delete the current template

  Read [ABA]CODABT = W_TEMPLATE_REC
  If fstat
    Call CRT_TEMPLATE_ACC_REC_TASK(W_TEMPLATE_REC) From SUBBTC # Issue X3-111553
  Endif

  # Issue X3-113104
  # CODABT is mandatory : we put the template on root folder
  If DOSSIER = GDOSX3 and GADONIX <> 2
    Read [BTC] First
    If fstat = 0 and [F:BTC]CODABT = ""
      [F:BTC]CODABT = W_TEMPLATE_REC
      Rewrite [BTC]
    Endif
    Commit
    End
  Endif
  # End Issue X3-113104

  GOK = 1
  For [BTC]

    # Verify if ABA exists with old name = [F:BTC]COD and delete it
    WCODABT = [F:BTC]COD
    If WCODABT <> ""
      Gosub DELETE_ABA_OLD
    Endif

    If [F:BTC]CODABT <> ""
      Read [ABA]CODABT = [F:BTC]CODABT

      # Issue X3-113885
      # control if recurring task is on the same folder
      If fstat = 0
        If [F:ABA]DOSSIER <> DOSSIER
          [F:BTC]CODABT = ""
        Endif
      Endif
    Endif


    # create the Recurring task management
    If fstat or [F:BTC]CODABT = ""
      Call ECR_TRACE("ABA: Creation of batch job parameter record" - [F:BTC]CODABT - "in folder" - DOSSIER, 0) From GESECRAN
      Call CRT_ACC_REC_TASK([F:BTC]CODABT, [F:BTC]COD, DOSSIER, PACTIV_REC_TASK) From SUBBTC # Issue X3-111553
      If GMESSAGE <> ""
        GOK = 0
        Break
      Endif
    Else
      Call ECR_TRACE("ABA :" - [F:BTC]CODABT - " already exists" - DOSSIER, 0) From GESECRAN
    Endif

    Read [ABA]CODABT = [F:BTC]CODABT
    If fstat = 0
      [F:ABA]FRQ    = 1
      [F:ABA]CNTERR = 2 # Issue X3-111845
      If PACTIV_REC_TASK = [V]CST_AYES # Issue X3-113885
        If WMULBATCH = [V]CST_AYES
          If [F:BTC]COD = "ACCENTRY"
            [F:ABA]ENAFLG = [V]CST_ANO
          Else
            [F:ABA]ENAFLG = [V]CST_AYES
          Endif
        Else
          If [F:BTC]COD = "ACCENTRY"
            [F:ABA]ENAFLG = [V]CST_AYES
          Else
            [F:ABA]ENAFLG = [V]CST_ANO
          Endif
        Endif
      Else
        [F:ABA]ENAFLG = PACTIV_REC_TASK
      Endif
      [F:ABA]DREL   = 2
      [F:ABA]NOMABT = func SUBBTC.GET_DESCRIPTION_ACC_TASK(DOSSIER, [F:BTC]COD)

      Rewrite [ABA]
      If fstat
        Call ECR_TRACE("ABA :" - [F:BTC]CODABT - "modification failed." - DOSSIER, 1) From GESECRAN
        GOK = 0
        Break
      Else
        Call ECR_TRACE("ABA :" - [F:BTC]CODABT - "successfully created." - DOSSIER, 0) From GESECRAN
      Endif
    Else
      Call ECR_TRACE("ABA :" - [F:BTC]CODABT - "reading failed." - DOSSIER, 1) From GESECRAN
      GOK = 0
      Break
    Endif

    [F:BTC]NBRREC = max(1, [F:BTC]TIMOUT(2), [F:BTC]NBRREC)

    [F:BTC]TIMOUT(0) = 0
    [F:BTC]TIMOUT(1) = 0
    [F:BTC]TIMOUT(2) = 0
    [F:BTC]TIMOUT(3) = 0

    Rewrite [BTC]
    If fstat = 0
      CPT_BTC += 1
      Call ECR_TRACE("BTC:" - [F:BTC]COD - "successfully modified." - DOSSIER, 0) From GESECRAN
    Else
      Call ECR_TRACE("BTC:" - [F:BTC]COD - "modification failed." - DOSSIER, 1) From GESECRAN
      GOK = 0
      Break
    Endif
  Next

#
# Tables concernées :
# ABG : ABATGRP Champ CODTAC Code tâche
# ABD : ABATABTD Champ CODTAC Code tâche
# A22 : ABATABTD2 Champ CODTAC Code tâche
# A11 : ABATRQT2 Champ TACHE Code tâche
# ABR : ABATRQT Champ TACHE Code tâche
# ABA : ABATABT Champ TACHE Code tâche
# ABT : ABATTAC Champ CODTAC Code tâche

  # Old recurring tasks : no more used
  WCODTASK = "ACCBATCH"
  Gosub DELETE_ABA

  WCODTASK = "ACCSTOP"
  Gosub DELETE_ABA

  Delete [ADC] Where CODTRT = "ACCBATCH"
  Delete [ADC] Where CODTRT = "ACCSTOP"


  Commit

  Close Local File [BTC]
  Close Local File [ABA]

  Close Local File [ABG]
  Close Local File [ABD]
  Close Local File [A22]
  Close Local File [A11]
  Close Local File [ABR]
  Close Local File [ABT]

  Close Local File [ADC]

  Call ECR_TRACE("UTIFIN001GEN :" - DOSSIER - ":" - num$(CPT_BTC) - "records migrated from BTC into ABA", 0) From GESECRAN

End

$DELETE_ABA

  Delete [ABD] Where CODTAC = WCODTASK
  If fstat
   Call ECR_TRACE("Error when deleting" - WCODTASK - "task from ABATABTD table fstat ="-num$(fstat),-1) From GESECRAN
  Endif

  Delete [A22] Where CODTAC = WCODTASK
  If fstat
   Call ECR_TRACE("Error when deleting" - WCODTASK - "task from ABATABTD2 table fstat ="-num$(fstat),-1) From GESECRAN
  Endif

  Delete [A11] Where TACHE = WCODTASK
  If fstat
   Call ECR_TRACE("Error when deleting" - WCODTASK - "task from ABATRQT2 table fstat ="-num$(fstat),-1) From GESECRAN
  Endif

  Delete [ABR] Where TACHE = WCODTASK
  If fstat
   Call ECR_TRACE("Error when deleting" - WCODTASK - "task from ABATRQT table fstat ="-num$(fstat),-1) From GESECRAN
  Endif

  Delete [ABA] Where TACHE = WCODTASK
  If fstat
   Call ECR_TRACE("Error when deleting" - WCODTASK - "task from ABATABT table fstat ="-num$(fstat),-1) From GESECRAN
  Endif


  Delete [ABT] Where CODTAC = WCODTASK
  If fstat
   Call ECR_TRACE("Error when deleting" - WCODTASK - "task from ABATRQT2 table fstat ="-num$(fstat),-1) From GESECRAN
  Endif

  Delete [ABG] Where CODTAC = WCODTASK
  If fstat
   Call ECR_TRACE("Error when deleting" - WCODTASK - "task from ABATGRP table fstat ="-num$(fstat),-1) From GESECRAN
  Endif

Return

$DELETE_ABA_OLD

  Delete [ABD] Where CODABT = WCODABT
  If fstat
   Call ECR_TRACE("Error when deleting" - WCODABT - "task from ABATABTD table fstat ="-num$(fstat),-1) From GESECRAN
  Endif

  Delete [A22] Where CODABT = WCODABT
  If fstat
   Call ECR_TRACE("Error when deleting" - WCODABT - "task from ABATABTD2 table fstat ="-num$(fstat),-1) From GESECRAN
  Endif

  Delete [A11] Where CODABT = WCODABT
  If fstat
   Call ECR_TRACE("Error when deleting" - WCODABT - "task from ABATRQT2 table fstat ="-num$(fstat),-1) From GESECRAN
  Endif

  Delete [ABR] Where CODABT = WCODABT
  If fstat
   Call ECR_TRACE("Error when deleting" - WCODABT - "task from ABATRQT table fstat ="-num$(fstat),-1) From GESECRAN
  Endif

  Delete [ABA] Where CODABT = WCODABT
  If fstat
   Call ECR_TRACE("Error when deleting" - WCODABT - "task from ABATABT table fstat ="-num$(fstat),-1) From GESECRAN
  Endif

Return

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI()

If APPLI = GDOSX3
  End
Endif

If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI) = 0
  End
Endif

If [F:ADS]MODULE(1) <> 2  # module compta
  End
Endif

Call MAJ_UTIFIN001(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI()

If APPLI = GDOSX3
  End
Endif

If [F:ADS]MODULE(1) <> 2
  End
Endif                                 : # module compta

Call MAJ_UTIFIN001(APPLI)
End

