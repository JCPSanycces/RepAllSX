#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion objet AGF
Raz GPILOBJ
Call OBJET("AGF",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 Call EXISTE_ADX("","","SUBAGFB",PSUBB) From ORDSYS
Endif
Case ACTION
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "LIENS"        : Gosub LIENS
 When "RAZCRE"       : Gosub RAZCRE
 When "RAZDUP"       : Gosub RAZDUP
 When "INICRE"       : Gosub INICRE
 When "CREATION"     : Gosub CREATION
 When "APRES_CRE"    : Gosub APRES_CRE
 When "MODIF"        : Gosub MODIF
 When "APRES_MOD"    : Gosub APRES_MOD
 When "ANNULE"       : Gosub ANNULE
 When "APRES_ANNULE" : Gosub APRES_ANNULE
 When "FIN"          : Gosub FIN
 When "GAUCHE"       : Gosub GAUCHE
 When "SETBOUT"      : Gosub SETBOUT
 When "SEL_TABLE"    : Gosub SEL_TABLE
 When "CHX_TABLE"    : Gosub CHX_TABLE
Endcase
If PSUBB
 Gosub ACTION From SUBAGFB
Endif
Return

$OUVRE_BOITE
Local Integer FLMODIF : FLMODIF = 1 :  # flag de mode (modification ou création)
Local Integer FLCOMPA : FLCOMPA = 1 :  # flag de compatibilité des droits
Local Integer BROWFCY , BROWCPY
Local Char    BOXFCY(10) , BOXCPY(10)
BROWFCY = find("FCY",OBJLIS(1..8)) : BOXFCY = "GAU_CHE"+num$(BROWFCY)
BROWCPY = find("CPY",OBJLIS(1..8)) : BOXCPY = "GAU_CHE"+num$(BROWCPY)
Return

$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET
If [M:FGR0]FLGLEG=2
 Call VIREBOUT(CHAINE,"MA") From GOBJET
Endif
Return

$LIENS
[M:FGR1]NBRCPY = 0
[M:FGR1]NBRFCY = 0
For [AGC]AGC0 Where GRP=[F:AGF]GRP
 [M:FGR1]CPY([M:FGR1]NBRCPY)    = [F:AGC]CPY
 Call SETSITES([F:AGC]CPY,[M:FGR1]FCYCPY([M:FGR1]NBRCPY))
 [M:FGR1]NBRCPY += 1
Next
Read [CPY]CPY0 = [F:AGF]GRP
If !fstat
 [M:FGR0]FLGLEG = [F:CPY]CPYLEGFLG
 If [M:FGR0]FLGLEG=2
  [M:FGR0]FLGCPY = 2
 Endif
Endif
If [M:FGR0]FLGCPY<>2
 For [FGR]FGR0 Where CPY=[F:AGF]GRP
  Read [FCY]FCY0 = [F:FGR]FCY
  If !find([F:FCY]LEGCPY,[M:FGR1]CPY(0..[M:FGR1]NBRCPY-1))
   [M:FGR1]FCY([M:FGR1]NBRFCY)    = [F:FGR]FCY
   [M:FGR1]LEGCPY([M:FGR1]NBRFCY) = [F:FCY]LEGCPY
   [M:FGR1]NBRFCY += 1
  Endif
 Next
Endif
Gosub GRISE
Return

$GRISE
If [M:FGR0]FLGLEG=2
 Grizo [M:FGR0]DES,SHO,FLGCPY
 Grizo [M:FGR1]NBRCPY,NBRFCY
Else
 Actzo [M:FGR0]DES,SHO,FLGCPY
 Actzo [M:FGR1]NBRCPY
 If [M:FGR0]FLGCPY=2
  Effzo [M:FGR1]NBRFCY
  Grizo [M:FGR1]NBRFCY
 Else
  Actzo [M:FGR1]NBRFCY
 Endif
Endif
Return

$RAZCRE
$RAZDUP
[M:FGR0]FLGLEG=1
Affzo [M:FGR0]FLGLEG
Gosub GRISE
Return

$MODIF
Delete [AGC] Where GRP=[F:AGF]GRP
If fstat=1
 GOK=-1 : Call RSTA("AGC",[F:AGF]GRP) From GLOCK : Return
Endif
Delete [FGR] Where CPY=[F:AGF]GRP
If fstat=1
 GOK=-1 : Call RSTA("FGR",[F:AGF]GRP) From GLOCK : Return
Endif
Gosub CREATION
If !GSERVEUR & !GIMPORT
 Call OUVRE_TRACE(mess(54,133,1)) From LECFIC : # Vérifications
Endif
Call TEMPON("F") From GESECRAN
FLCOMPA = 1
Call COMPATIBILITE(FLCOMPA) From SUBAFP1
GOK = FLCOMPA
Call TEMPOFF From GESECRAN
If !GSERVEUR & !GIMPORT
 Call FERME_TRACE From LECFIC
Endif
If !FLCOMPA
 Call ERREUR(mess(9,123,1)-":"-mess(135,126,1)) From GESECRAN
 # Modification impossible : consulter le ficher de trace
Endif
Return

$CREATION
For I=0 To [M:FGR1]NBRCPY-1
 Raz [F:AGC]
 [F:AGC]GRP = [F:AGF]GRP
 [F:AGC]CPY = [M:FGR1]CPY(I)
 Write [AGC]
 If fstat
  GOK = 0 : Call FSTA("AGC") From GLOCK : Break
 Endif
 For [FCY]FCY1 Where LEGCPY=[M:FGR1]CPY(I)
  [F:FGR]CPY = [F:AGF]GRP
  [F:FGR]FCY = [F:FCY]FCY
  Write [FGR]
  If fstat
   GOK = 0 : Call FSTA("FGR") From GLOCK : Break 2
  Endif
 Next
Next I
If GOK<1 : Return : Endif
For I=0 To [M:FGR1]NBRFCY-1
 [F:FGR]CPY = [F:AGF]GRP
 [F:FGR]FCY = [M:FGR1]FCY(I)
 Write [FGR]
 If fstat
  GOK = 0 : Call FSTA("FGR") From GLOCK : Break
 Endif
Next I
If GOK<1 : Return : Endif
Read [CPY]CPY0 = [F:AGF]GRP
If fstat
 Raz [F:CPY]
 [F:CPY]CPY = [F:AGF]GRP
 [F:CPY]CPYLEGFLG = 1
 [F:CPY]CPYNAM    = [F:AGF]DES
 [F:CPY]CPYSHO    = [F:AGF]SHO
 Write [CPY]
Else
 [F:CPY]CPYNAM    = [F:AGF]DES
 [F:CPY]CPYSHO    = [F:AGF]SHO
 Rewrite [CPY]
Endif
If fstat
 GOK = 0 : Call FSTA("CPY") From GLOCK : Return
Endif
Return

$INICRE
If [M:FGR1]NBRFCY=0
 K = 1
 For I=1 To [M:FGR1]NBRCPY
  Read [CPY]CPY0=[M:FGR1]CPY(I-1)
  If fstat or [F:CPY]CPYLEGFLG<>2
   K = 0 : Break
  Endif
 Next I
 If K
  [F]FLGCPY = 2
 Endif
Endif
Return

$APRES_CRE
If dim([M:FGR0]FLGCPY)>0 & [M:FGR0]FLGCPY<>[F:AGF]FLGCPY
 [M:FGR0]FLGCPY = [F:AGF]FLGCPY
 Affzo [FGR0]FLGCPY
Endif
$APRES_MOD
$APRES_ANNULE
FLMODIF = 0
Call INISOC From GLOBSUP  : # Réinit de la tables des sociétés
Return

$ANNULE
FLMODIF = 1
# Bug 19880 : Ajour d'un message de confirmation
If clalev([F:AFP2])=0 : Local File AFCTPRF   [AFP2] : Endif
Filter [F:AFP2] Where [F:AFP2]FCYGRU = [M:FGR0]GRP
Read [F:AFP2] First
Filter [F:AFP2]
If !fstat
 # Les habilitations pour cette société vont être supprimées.
 OK = 2  : Call AVERTIR(mess(214,126,1),OK) From GESECRAN
 If OK<>2
  GOK=0 : OK=0 : Return
 Else
  #mise à jour de la table AFCTPRF (Habilitation fonctionnelle)
  Call SUPPRGMT([M:FGR0]GRP) From SUBAFP1
  FLMODIF = 0
 Endif
Endif
Delete [CPY] Where CPY=[L]CODE
Return

$FIN
#mise à jour de la table AFCTFCY (Droit profil fonction) par rapport AFCTPRF (Habilitation fonctionnelle)
If FLMODIF=0
 OK = 2
 Call OUINON(mess(88,127,1),OK) From GESECRAN : # Mise à jour des droits d'accès aux fonctions (table AFCTFCY)
 If OK=2
  Call MAJAFF("") From SUBAFP1
  Default Mask [M:FGR1]
 Endif
Endif
Return

$GAUCHE
Case currbox
 When BOXFCY
  If [F:FCY]FCY<>"" & !find([F:FCY]FCY,[M:FGR1]FCY(0..[M:FGR1]NBRFCY-1)) & [M:FGR1]NBRFCY<dim([M:FGR1]FCY)
& & [M:FGR0]FLGCPY<>2
   OK = 0
   Case REP
    When "C","M","D"
     OK = 1
    When ""
     If CLECUR & VERROU & ACTMOD & !GCONSULT
      OK = 1
     Endif
   Endcase
   If OK
    Read [FCY]FCY0 = [F:FCY]FCY
    [M:FGR1]FCY([M:FGR1]NBRFCY)    = [F:FCY]FCY
    [M:FGR1]LEGCPY([M:FGR1]NBRFCY) = [F:FCY]LEGCPY
    [M:FGR1]NBRFCY += 1
    Affzo [M:FGR1]FCY([M:FGR1]NBRFCY-1),ZFCY([M:FGR1]NBRFCY-1)
    If REP=""
     Gosub ENTRE_MODIF From GOBJSUB
    Endif
   Endif
  Endif
 When BOXCPY
  If [F:CPY]CPY<>"" & !find([F:CPY]CPY,[M:FGR1]CPY(0..[M:FGR1]NBRCPY-1)) & [M:FGR1]NBRCPY<dim([M:FGR1]CPY)
& & [M:FGR0]FLGLEG<>2
   OK = 0
   Case REP
    When "C","M","D"
     OK = 1
    When ""
     If CLECUR & VERROU & ACTMOD & !GCONSULT
      OK = 1
     Endif
   Endcase
   If OK
    Read [CPY]CPY0 = [F:CPY]CPY
    [M:FGR1]CPY([M:FGR1]NBRCPY) = [F:CPY]CPY
    Call SETSITES([F:CPY]CPY,[M:FGR1]FCYCPY([M:FGR1]NBRCPY))
    [M:FGR1]NBRCPY += 1
    Affzo [M:FGR1]CPY([M:FGR1]NBRCPY-1),ZCPY([M:FGR1]NBRCPY-1),FCYCPY([M:FGR1]NBRCPY-1)
    Call VIRESITE([F:CPY]CPY)
    If REP=""
     Gosub ENTRE_MODIF From GOBJSUB
    Endif
   Endif
  Endif
Endcase
Return

Subprog VIRESITE(SOC)
Value Char    SOC
Local Integer J , K
J = 0
K = 0
While J<[M:FGR1]NBRFCY
 Read [FCY]FCY0 = [M:FGR1]FCY(J)
 If [F:FCY]LEGCPY=SOC
  Dela J,1,[M:FGR1]NBRFCY [M:FGR1]NBRFCY
  [M:FGR1]NBRFCY -= 1
  K = 1
 Else
  J += 1
 Endif
Wend
If K
 Affzo [M:FGR1]NBRFCY,FCY,LEGCPY
Endif
End

Subprog SETSITES(SOC,SITES)
Value    Char SOC
Variable Char SITES
SITES = ""
For [FCY]FCY1 Where LEGCPY=SOC
 SITES -= [F:FCY]FCY
Next
End

######################################################################################
## Ecran FGR1
######################################################################################

Subprog C_GRP(VALEUR)
Variable Char    VALEUR()
If GREP="C" or GREP="D" or GREP = ""
 Look [FCY]FCY0 = VALEUR
 If fstat=0
  # Ce code existe déjà comme site
  GMESSAGE = mess(39,133,1) : mkstat = 2 : End
 Endif
Endif
End

Subprog C_FLGCPY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo [M:FGR1]NBRFCY
 Grizo [M:FGR1]NBRFCY
Else
 Actzo [M:FGR1]NBRFCY
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:FGR1]CPY) From OBJDIV
If mkstat : End : Endif
Call VIRESITE(VALEUR)
Call SETSITES(VALEUR,[M:FGR1]FCYCPY(nolign-1))
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:FGR1]FCY) From OBJDIV
If mkstat : End : Endif
Call LECTURE("FCY",VALEUR,"") From CONTOBJ
If find([F:FCY]LEGCPY,[M:FGR1]CPY(0..[M:FGR1]NBRCPY-1))
 GMESSAGE = mess(228,133,1)-[F:FCY]LEGCPY : # Site déjà défini par la société
 mkstat = 2 : End
Endif
[M:FGR1]LEGCPY(nolign-1) = [F:FCY]LEGCPY
End

##################################################
## Contrôle du site / transaction
##################################################
Subprog CONTSITE(VALEUR)
Value    Char    VALEUR
If dim([V]GGRPFCY)>0 & [V]GGRPFCY<>"" & VALEUR<>""
 If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif
 Look [FGR]FGR0 = GGRPFCY;VALEUR
 If fstat
  GMESSAGE = VALEUR-":"-mess(24,127,1)-GGRPFCY : # Site non inclus dans le groupe
  mkstat = 2 : End
 Endif
Endif
# Pour mettre à jour les variables globales site et société en cas de création d'un nouveau site sur une autre session
If VALEUR<>"" & GFONCTION<>"GESFCY" & !find(VALEUR,GSITE(1..GNBSITE))
 Call INISOC From GLOBSUP
Endif
End

##################################################
## Contrôle société / transaction
##################################################
Subprog CONTSOC(VALEUR)
Value    Char    VALEUR
If dim([V]GGRPFCY)>0 & [V]GGRPFCY<>"" & VALEUR<>""
 If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
 Look [AGC]AGC0 = GGRPFCY;VALEUR
 If fstat
  # Société non incluse dans le groupe
  GMESSAGE = VALEUR-":"-mess(64,127,1)-GGRPFCY
  mkstat = 2 : End
 Endif
Endif
# Pour mettre à jour les variables globales site et société en cas de création d'une nouvelle société sur une autre session
If VALEUR<>"" & GFONCTION<>"GESCPY" & !find(VALEUR,GSOC(1..GNBSOC))
 Call INISOC From GLOBSUP
Endif
End

##################################################
## Sélection du site / transaction
##################################################
$SEL_TABLE
Case TABLE
 When "ASELAGC" : Gosub SELAGC
Endcase
Return

$SELAGC
OBJET = "AGF"
OPTIONS = "C"
Return

$CHX_TABLE
Case TABLE
 When "ASELAGC" : Gosub CHXAGC
Endcase
Return

$CHXAGC
TIT(0) = mess(12,123,1)-mess(237,133,1) : # Choix/Groupe société
Return
