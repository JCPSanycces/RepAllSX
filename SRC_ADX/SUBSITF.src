#<AdxTL>@(#)5.0.0.0 $Revision$
#CHECK IGNORE_BEGIN
Local File XISOUFMCLT [XIS]
Trbegin [XIS]
Update [XIS] With  FLGREP=1
Update [XIS] Where CODSOUFAM="INF"
&            With  X3CLE=""
Commit
End
#CHECK IGNORE_END

# Gestion du masque SITRAFIL

$ACTION
#Infbox ACTION
Case ACTION
    When "DEBUT"  : Gosub DEBUT
    When "BOUTON" : Gosub BOUTON
    When "END"    : Gosub ACT_END
    When "FIN"    : Gosub FIN
    When "SUI" : Call LOADSIW(+1,1)
    When "PRE" : Call LOADSIW(-1,1)
    When "FIR" : Call LOADSIW(-2,1)
    When "LAS" : Call LOADSIW(+2,1)
Endcase
Return

######################################################################################
$DEBUT
Global Integer GCURPAG, GNBPAG
Global Integer GNBTOTSIW    # Nombre d'enreg SIW pour le fichier en cours
Global Char GSITF_CARO(250), GSITF_CARD(250)
Local Integer LERR

[M:SITF] = [M:SITC]
[M:SITF]ERRONLY = 1
If [M:SITF]INTZONE=""
    Chgfmt [M:SITF]INTITULE With "-K:30"
Endif


Local File =[M]CODFIC [XSMI]
If nbrecord([XSMI])>1000
    Call OUINON("Ne traiter que les erreurs ?",[M:SITF]ERRONLY) From GESECRAN
Endif
Read [F:SIR]SIT1=[M:SITF]CODFIC;[M:SITF]CODZONE;[M:SITF]SEQ

Effzo [M:SITF]15
Grizo [M:SITF]HAUT,BAS
If [M:SITF]MODIF <> 2
    Diszo [M:SITF]INTCND,CND,LNG,FMTCLE,MAJ,ACCENT,SPC
Endif

Call RPCCAR(GSITF_CARO,GSITF_CARD) From SUBSIT

[M:SITF]TRTERR = 1
Call TRTFIC(2,0,GSITF_CARO,GSITF_CARD,[M:SITF]ERRONLY,LERR) From SUBSIT
[M:SITF]NBERR  = LERR

Lock ="SIT~"+[M]CODFIC+"~"+[M]CODZONE+"~"+num$([M]SEQ) With lockwait = 0

If fstat | LERR=-1
    Call ERREUR(mess(234,188,1)) From GESECRAN
    FIN=1
    Return
Endif

Call LOADSIW(-2,0)

[M:SITF]TRTERR = 2

Call FMT_X3CLE

Affzo [M:SITF]
Return

######################################################################################
$BOUTON
    Case BOUT
        When "1" : # Exécuter
            Call SIT_SIMUF
        When "2" : # Enregistrer
            Gosub ENR
        When "3" : # Erreur suivante
            Call NXTERR
    Endcase

If find(BOUT,"1","2") & GTRACE<>""
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
Endif

Return

######################################################################################
$ENR
    Local Integer LX3CLE, STOP
    Local Char REQ(250)(2)
    # Pour les codes tournées, le transcodage est forcé pour avoir une suite de n° à partir de 1
    If [M:SITF]CODFIC="XINUMTNCLT"
        LX3CLE=0
        $LOOP_SIW
        Raz REQ, STOP
        REQ(0)+="Select CODFIC_0,CODZONE_0,SEQ_0,COD_0,COD2_0,X3CLE_0"
        REQ(0)+=" From SITRAWRK"
        REQ(0)+=" Where CODFIC_0='"+[M:SITF]CODFIC+"'"
        REQ(0)+="   and CODZONE_0='"+[M:SITF]CODZONE+"'"
        REQ(1)+="   and SEQ_0="+num$([M:SITF]SEQ)
        REQ(1)+="   and X3CLE_0<>''"
        REQ(1)+="   and cast(X3CLE_0 as integer)>"+num$(LX3CLE)
        REQ(1)+=" ORDER BY cast(X3CLE_0 as integer)"

        Trbegin [SIW]
        For (Char F, Char Z, Integer S, Char C1, Char C2, Char X) From num$(GTYPDBA*2+1) Sql REQ As [XXX]
            LX3CLE += 1
            Read [SIW]SIW2=[F:XXX]F;[F:XXX]Z;[F:XXX]S;[F:XXX]C1;[F:XXX]C2;[F:XXX]X
            [F:SIW]X3CLE=num$(LX3CLE)
            Rewrite [SIW]
            STOP=1
            Break
        Next
        Commit
        If STOP
            Goto LOOP_SIW
        Endif
    Endif

    Local Integer LERR
    Call TRTFIC(3,0,"","",[M:SITF]ERRONLY,LERR) From SUBSIT
    Readlock [F:SIR]SIT1=[M:SITF]CODFIC;[M:SITF]CODZONE;[M:SITF]SEQ
    [F:SIR]NBERR=LERR
    Rewrite [SIR]
    [M:SITC]NBERR(val(PARAM(1))) = LERR
    Affzo [M:SITC]NBERR(val(PARAM(1)))
    [M:SITF]NBERR = LERR
    Affzo [M:SITF]NBERR

    If [M:SITF]CODFIC="XINUMTNCLT"
        Call LOADSIW(-2,1)
    Endif
Return

######################################################################################
$ACT_END
Local Integer LCPTERR
    LCPTERR = func SUBSIT.CPTERR([M:SITF]CODFIC,0)
    If LCPTERR>0
        # X enregistrements ne sont pas transcodés correctement.
        # Quitter la saisie ?
        Call OUINON(num$(LCPTERR)-SI_MES(43)+chr$(13)+mess(890,196,1),FIN) From GESECRAN
        FIN-=1
        Return
    Endif
    [M:SITC]NBERR(val(PARAM(1))) = LCPTERR
    Affzo [M:SITC]NBERR(val(PARAM(1)))
Return

######################################################################################
$FIN
    Unlock ="SIT~"+[M]CODFIC+"~"+[M]CODZONE+"~"+num$([M]SEQ)
Return

######################################################################################
Subprog C_LNG(VALEUR)
Variable Char    VALEUR()
Onerrgo LNG_ERR
GBIDI1 = evalue(VALEUR)
Onerrgo
End

$LNG_ERR
    GMESSAGE = mess(83,123,1)
    mkstat=2
Resume

######################################################################################
Subprog AM_FMTCLE(VALEUR)
Variable Integer VALEUR
    If VALEUR=2
        Diszo [M:SITF]SPC,MAJ,ACCENT
        [M:SITF]SPC=2
        [M:SITF]MAJ=2
        [M:SITF]ACCENT=2
        Affzo [M:SITF]SPC,MAJ,ACCENT
    Else
        Actzo [M:SITF]SPC,MAJ,ACCENT
        Affzo [M:SITF]SPC,MAJ,ACCENT
    Endif

    [M:SITF]FMTCLE = VALEUR
    Call FMT_X3CLE
End

######################################################################################
Subprog AV_CODE(VALEUR)
Variable Char    VALEUR()
If [M:SITF]ERR(nolign-1)=2
    pcolor = GCOUL(1)
Elsif [M:SITF]DBL(nolign-1)=2
    pcolor = GCOUL(2)
Elsif [M:SITF]MDF(nolign-1)=2
    pcolor = GCOUL(3)
Else
    pcolor = GCOUL(0)
Endif
End

######################################################################################
Subprog AV_X3CLE(VALEUR)
Variable Char    VALEUR()
If [M:SITF]ERR(nolign-1)=2
    pcolor = GCOUL(1)
Elsif [M:SITF]DBL(nolign-1)=2
    pcolor = GCOUL(2)
Elsif [M:SITF]MDF(nolign-1)=2
    pcolor = GCOUL(3)
Else
    pcolor = GCOUL(0)
Endif
End


######################################################################################
Subprog C_X3CLE(VALEUR)
Variable Char    VALEUR()

Local Integer I, LNUMTAB

    If VALEUR=""
# La gfestion de l'erreur se fait en AM
#        [M:SITF]ERR(nolign-1) = 2
        End
    Endif

    If VALEUR <> func SUBSIT.TRACOD(VALEUR,
&                                   evalue([M:SITF]LNG),
&                                   [M:SITF]FMTCLE,
&                                   [M:SITF]ACCENT,
&                                   [M:SITF]MAJ,
&                                   [M:SITF]SPC,
&                                   [M:SITF]NUM,
&                                   GSITF_CARO,GSITF_CARD)
        GMESSAGE=mess(83,123,1)
        mkstat=2
        End
    Endif
    If [M:SITF]CODFIC="XINMC"
        Filter [SIW2] Where CODFIC=[M:SITF]CODFIC
&                         & CODZONE=[M:SITF]CODZONE
&                         & SEQ=[M:SITF]SEQ
&                         & COD<>[M:SITF]COD(nolign-1)
&                         & COD2=[M:SITF]COD2(nolign-1)
&                         & X3CLE=VALEUR
    Else
        Filter [SIW2] Where CODFIC=[M:SITF]CODFIC
&                         & CODZONE=[M:SITF]CODZONE
&                         & SEQ=[M:SITF]SEQ
&                         & ( COD<>[M:SITF]COD(nolign-1)
&                           | COD2<>[M:SITF]COD2(nolign-1) )
&                         & X3CLE=VALEUR
    Endif
    [M:SITF]DBL(nolign-1) = 1
    For [SIW2]
        [M:SITF]DBL(nolign-1)=2
        GMESSAGE = SI_MES(40)+chr$(13)+SI_MES(39)+[F:SIW2]COD
        If [M:SITF]AUZDBL<>2
            mkstat=2 # Erreur
        Else
            GERR=1 # Avertissement
        Endif
        Break
    Next
    Filter [SIW2]
    If mkstat=2 : End : Endif

    If [M:SITF]ERRONLY=2
        # On cherche les enreg de XSMI qui ont X3CLE=VALEUR et qui ne sont pas dans SIW (car n'étaient pas en erreur lors du chargement)

        # Si on trouve VALEUR dans X3CLE d'un enreg se trouvant lui-même dans SIW,
        # c'est qu'il n'existe pas d'autre enreg dans XSMI dont X3CLE=VALEUR et qui n'a pas été mis dans SIW
        # car c'étaient des doublons
        Link [XSMI] With [SIW2]SIW0(3)~=[M]CODFIC;[M]CODZONE;[M]SEQ
&                   As [LNK]
&                   Where [XSMI]X3CLE = VALEUR
&                       & [F:SIW]COD  = evalue("[XSMI]"+[M]CODZONE)
&                       & ([M]CODZONE2="" | [F:SIW]COD2 = evalue("[XSMI]"+[M]CODZONE2))
        Raz I
        For [LNK]
            I=1    # --> OK
            Break
        Next
        If I=0
            # On n'a pas trouvé d'enreg dans XSMI qui soit aussi dans SIW
            # Il faut donc maintenant vérifier qu'il existe un enregistrement dans XSMI avec X3CLE=VALEUR
            # Si c'est le cas => on est en train de créer un doublon : KO
            If [M]CODFIC="XINMC"
                For [XSMI] Where [XSMI]X3CLE=VALEUR
&                              & [XSMI]NUMNMC<>[M]COD(nolign-1)
&                              & [XSMI]CODARTCSE=[M]COD2(nolign-1)
                    GMESSAGE = SI_MES(40)+chr$(13)+SI_MES(39)+evalue("[F:XSMI]"+[M]CODZONE)
                    mkstat=2
                    Break
                Next
            Else
                For [XSMI] Where [XSMI]X3CLE=VALEUR
                    GMESSAGE = SI_MES(40)+chr$(13)+SI_MES(39)+evalue("[F:XSMI]"+[M]CODZONE)
                    mkstat=2
                    Break
                Next
            Endif
        Endif
        If mkstat=2 : End : Endif

    Endif


    I = func SUBSIT.CTLTRACOD([M]OBJ,[M]CODFIC,[M]LNG,VALEUR)
    If I
        mkstat=2
        If I=2
            # Compte ... (...) Format du compte incorrect
            Call ECR_TRACE(mess(45,102,1)-VALEUR-mess(4,113,1),1) From GESECRAN
        Elsif I=3
            # Journal ... (...) valeur incorrecte
            Call ECR_TRACE(mess(13,105,1)-VALEUR-":"-mess(83,123,1),1) From GESECRAN
        Endif
        End
    Endif 
End

######################################################################################
Subprog AM_X3CLE(VALEUR)
Variable Char    VALEUR()

Local Integer LNBDBL, LERRDBL, I, LDBL
Local Char LOLDX3CLE(type([M]X3CLE)-10)

    If VALEUR=""
        If [M:SITF]ERR(nolign-1)<>2
            [M:SITF]NBERR+=1
            [M:SITF]ERR(nolign-1) = 2
        Endif
        [M:SITF]DBL(nolign-1) = 1
        [M:SITF]MDF(nolign-1) = 1
        Affzo [M:SITF]CODE(nolign-1), NBERR
    Else
        If [M:SITF]ERR(nolign-1)=2
            [M:SITF]NBERR-=1
            [M:SITF]ERR(nolign-1) = 1
        Endif
        [M:SITF]MDF(nolign-1) = 1
    Endif

    Readlock [SIW]SIW0=[M:SITF]CODFIC;[M:SITF]CODZONE;[M:SITF]SEQ;[M:SITF]COD(nolign-1);[M:SITF]COD2(nolign-1)
    LDBL=[F:SIW]DBL
    Trbegin [SIW]
    [F:SIW]X3CLE   = VALEUR
    [F:SIW]ERR     = [M:SITF]ERR(nolign-1)
    [F:SIW]DBL     = [M:SITF]DBL(nolign-1)
    [F:SIW]MDF     = [M:SITF]MDF(nolign-1)
    Rewrite [SIW]
    
        If LDBL=2    # C'était en doublon => l'autre n'est plus en doublon (s'il est seul!)
            Filter [SIW] Where CODFIC=[M:SITF]CODFIC
&                            & CODZONE=[M:SITF]CODZONE
&                            & CODZONE2=[M:SITF]CODZONE2
&                            & SEQ=[M:SITF]SEQ
&                            & ( COD<>[M:SITF]COD(nolign-1)
&                              | COD2<>[M:SITF]COD2(nolign-1))
&                            & X3CLE=[M:SITF]X3CLE(nolign-1)
            Raz LNBDBL
            For [SIW]
                LNBDBL+=1
                If LNBDBL>1
                    Break
                Endif
            Next
            Filter [SIW]
            If LNBDBL<=1
                Update [SIW] Where CODFIC=[M:SITF]CODFIC
&                                & CODZONE=[M:SITF]CODZONE
&                                & CODZONE2=[M:SITF]CODZONE2
&                                & SEQ=[M:SITF]SEQ
&                                & ( COD<>[M:SITF]COD(nolign-1)
&                                  | COD2<>[M:SITF]COD2(nolign-1))
&                                & X3CLE=[M:SITF]X3CLE(nolign-1)
&                            With DBL=1, ERR=1
            Endif
        Endif

    LERRDBL=1+([M:SITF]AUZDBL<>2)

    # Rafraichissement des doublons (potentiels)
    If [M:SITF]CODFIC="XINMC"
        Update [SIW] Where CODFIC=[M:SITF]CODFIC
&                        & CODZONE=[M:SITF]CODZONE
&                        & CODZONE2=[M:SITF]CODZONE2
&                        & SEQ=[M:SITF]SEQ
&                        & COD<>[M:SITF]COD(nolign-1)
&                        & COD2=[M:SITF]COD2(nolign-1)
&                        & X3CLE=VALEUR
&                    With DBL=2, ERR=2
    Else
        Update [SIW] Where CODFIC=[M:SITF]CODFIC
&                        & CODZONE=[M:SITF]CODZONE
&                        & CODZONE2=[M:SITF]CODZONE2
&                        & SEQ=[M:SITF]SEQ
&                        & ( COD<>[M:SITF]COD(nolign-1)
&                          | COD2<>[M:SITF]COD2(nolign-1))
&                        & X3CLE=VALEUR
&                    With DBL=2, ERR=LERRDBL
    Endif
    Commit

    LOLDX3CLE = [M:SITF]X3CLE(nolign-1)
    [M:SITF]X3CLE(nolign-1) = VALEUR
    For I=0 To [M:SITF]NBCOD-1
        If [M:SITF]X3CLE(I)<>""
&        & find([M:SITF]X3CLE(I),VALEUR,LOLDX3CLE)
            Read [SIW]SIW0=[M:SITF]CODFIC;[M:SITF]CODZONE;[M:SITF]SEQ;[M:SITF]COD(I);[M:SITF]COD2(I)
            [M:SITF]DBL(I) = [F:SIW]DBL
            If [M:SITF]X3CLE(I) = LOLDX3CLE
&            & [M:SITF]X3CLE(I) = func SUBSIT.TRACOD([M:SITF]X3CLE(I),
&                                                   evalue([M:SITF]LNG),
&                                                   [M:SITF]FMTCLE,
&                                                   [M:SITF]ACCENT,
&                                                   [M:SITF]MAJ,
&                                                   [M:SITF]SPC,
&                                                   [M:SITF]NUM,
&                                                   GSITF_CARO,GSITF_CARD)
&            & [M:SITF]ERR(I)=2
&            & [F:SIW]ERR=1
                [M:SITF]ERR(I)=1
                [M:SITF]NBERR-=1
            Endif
            Affzo [M:SITF]X3CLE(I),CODE(I)
        Endif
    Next
    Affzo [M:SITF]NBERR
End


######################################################################################
Subprog SIT_SIMUF
Local Integer LERR

SI_SIMU=2

Call TRTFIC(1,0,GSITF_CARO,GSITF_CARD,[M:SITF]ERRONLY,LERR) From SUBSIT

[M:SITF]NBERR = LERR

Gosub CAL_NB_PAGE

Call LOADSIW(-2,1)

End

######################################################################################
Subprog CL_HAUT(VALEUR)
Variable Char    VALEUR()
    Call LOADSIW(-1,1)
End

######################################################################################
Subprog CL_BAS(VALEUR)
Variable Char    VALEUR()
    Call LOADSIW(1,1)
End


######################################################################################
# Paramètres E : PNXT : -2=Premier
#                       -1=Précédent
#                        1=Suivant
#                        2=Dernier
#                PAFF : 1=Rafraichit l'écran [M:SITF]
######################################################################################
Subprog LOADSIW(PNXT,PAFF)
Value Integer PNXT
Value Integer PAFF

If !find (PNXT,-2,-1,1,2)
    End
Endif

Local Char LCRIT(250)
Local Integer LNXT
Local Char LTIT(50), LINT(30)
Local Char LCRIT(250)
Local Integer ICRIT

If [M:SITF]AFFERR=2    # Affichage de toutes les erreurs dont les doublons
    Call ADDCRIT(LCRIT,ICRIT,"","ERR=2","&") From GOBJSUB
Elsif [M:SITF]AFFDBL=2    # Affichage que des doublons
    Call ADDCRIT(LCRIT,ICRIT,"","DBL=2","&") From GOBJSUB
Endif
If [M:SITF]AFFMDF=2    # Affichage des X3CLE calculés
    Call ADDCRIT(LCRIT,ICRIT,"","MDF=2","|") From GOBJSUB
Endif
If LCRIT=""
    LCRIT="1=1"
Else
    LCRIT="("+LCRIT+")"
Endif


Case PNXT
    When -2:    # Premier
        Gosub CAL_NB_PAGE
        LNXT = +1
        If [M:SITF]AFFDBL=2
            Filter [SIW] Where CODFIC=[M:SITF]CODFIC
&                            & CODZONE=[M:SITF]CODZONE
&                            & SEQ=[M:SITF]SEQ
&                            & evalue(LCRIT)
&                        Order By Key SIW1 Asc
        Else
            Filter [SIW] Where CODFIC=[M:SITF]CODFIC
&                            & CODZONE=[M:SITF]CODZONE
&                            & SEQ=[M:SITF]SEQ
&                            & evalue(LCRIT)
&                        Order By Key SIW0 Asc
        Endif
        Effzo [M:SITF]15
        Raz GCURPAG, nolign
        Raz [M:SITF]NBCOD

    When -1:    # Précédent
        If GCURPAG=1
            End
        Endif
        LNXT = -1
        If [M:SITF]AFFDBL=2
            Filter [SIW] Where CODFIC=[M:SITF]CODFIC
&                            & CODZONE=[M:SITF]CODZONE
&                            & SEQ=[M:SITF]SEQ
&                            & COD<[M:SITF]COD(0)
&                            & evalue(LCRIT)
&                        Order By Key SIW1 Desc
        Else
            Filter [SIW] Where CODFIC=[M:SITF]CODFIC
&                            & CODZONE=[M:SITF]CODZONE
&                            & SEQ=[M:SITF]SEQ
&                            & COD<[M:SITF]COD(0)
&                            & evalue(LCRIT)
&                        Order By Key SIW0 Desc
        Endif
        Effzo [M:SITF]15
        [M:SITF]NBCOD = dim([M:SITF]COD)
        nolign=[M:SITF]NBCOD+1

    When 1 :    # Suivant
        If GCURPAG>=GNBPAG
            End
        Endif
        LNXT = +1
        If [M:SITF]AFFDBL=2
            Filter [SIW] Where CODFIC=[M:SITF]CODFIC
&                            & CODZONE=[M:SITF]CODZONE
&                            & SEQ=[M:SITF]SEQ
&                            & COD>[M:SITF]COD([M:SITF]NBCOD-1)
&                            & evalue(LCRIT)
&                        Order By Key SIW1 Asc
        Else
            Filter [SIW] Where CODFIC=[M:SITF]CODFIC
&                            & CODZONE=[M:SITF]CODZONE
&                            & SEQ=[M:SITF]SEQ
&                            & COD>[M:SITF]COD([M:SITF]NBCOD-1)
&                            & evalue(LCRIT)
&                        Order By Key SIW0 Asc
        Endif
        Effzo [M:SITF]15
        Raz nolign
        Raz [M:SITF]NBCOD

    When 2 :    # dernier
        LNXT = -1
        If [M:SITF]AFFDBL=2
            Filter [SIW] Where CODFIC=[M:SITF]CODFIC
&                            & CODZONE=[M:SITF]CODZONE
&                            & SEQ=[M:SITF]SEQ
&                            & evalue(LCRIT)
&                        Order By Key SIW1 Desc
        Else
            Filter [SIW] Where CODFIC=[M:SITF]CODFIC
&                            & CODZONE=[M:SITF]CODZONE
&                            & SEQ=[M:SITF]SEQ
&                            & evalue(LCRIT)
&                        Order By Key SIW0 Desc
        Endif
        Effzo [M:SITF]15
        [M:SITF]NBCOD=mod(GNBTOTSIW,dim([M:SITF]COD))
        If [M:SITF]NBCOD=0
            [M:SITF]NBCOD = dim([M:SITF]COD)
        Endif
        nolign=[M:SITF]NBCOD+1

Endcase

For [SIW]
    nolign+=LNXT
    [M:SITF] = [F:SIW]
    If LNXT=1
        [M:SITF]NBCOD += 1
    Endif
    If nolign>=dim([M:SITF]COD) & LNXT=1
        Break
    Elsif nolign<=0 & LNXT=-1
        Break
    Endif
Next
Filter [SIW]
Case PNXT
    When -2 :
        GCURPAG=1
    When -1 :
        GCURPAG+=LNXT
    When 1 :
        GCURPAG+=LNXT
    When 2 :
        GCURPAG=GNBPAG
Endcase

If [M:SITF]NBCOD>0
    Actzo [M:SITF]HAUT,BAS
Else
    Grizo [M:SITF]HAUT,BAS
Endif

If GCURPAG>=GNBPAG
    Grizo [M:SITF]BAS
Endif

If GCURPAG=1
    Grizo [M:SITF]HAUT
Endif

Call TEXTE(7161,LTIT) From OBJDIV
LTIT -= num$(GCURPAG)-"/"-num$(GNBPAG)
Chgtbk [M:SITF]15 With LTIT

If PAFF=1
    Affzo [M:SITF]
Endif

End


######################################################################################
Subprog NXTERR

Local Integer I,J,K

    Filter [SIW] Where CODFIC=[M:SITF]CODFIC
&                    & CODZONE=[M:SITF]CODZONE
&                    & SEQ=[M:SITF]SEQ
&                    & COD>[M:SITF]COD(max(0,nolign-1))
&                    & ERR=2
    Look [SIW] First
    Filter [SIW]

    If !fstat
        J = nolign
        Raz K
        Repeat
            I = sigma(J,[M:SITF]NBCOD-1,(indcum+1)*([M:SITF]ERR(indcum)=2 & I=0 & sigma(I=1,1,1)))
            If I<=0
                Call LOADSIW(1,0)
                Raz J
            Endif
            K+=1
            If K>GCURPAG : Call LOADSIW(-2,1) : End : Endif    # Sécurité pour éviter boucle sans fin
        Until I>0
        Affzo [M:SITF]
        zonsui="NBCOD("+num$(I-1)+")"
    Else
        Call MESSAGE(mess(55,139,1)) From GESECRAN
    Endif
End


######################################################################################
Subprog AM_AFFERR(VALEUR)
Variable Integer VALEUR

[M:SITF]AFFERR=VALEUR
Call LOADSIW(-2,1)

End

######################################################################################
Subprog AM_AFFDBL(VALEUR)
Variable Integer VALEUR
[M:SITF]AFFDBL=VALEUR
Call LOADSIW(-2,1)

End

######################################################################################
Subprog AM_AFFMDF(VALEUR)
Variable Integer VALEUR
[M:SITF]AFFMDF=VALEUR
Call LOADSIW(-2,1)

End


######################################################################################
Subprog FMT_X3CLE

Local Char LFMT(20)
LFMT = "Kc"
If [M:SITF]SPC=2
    LFMT+="v4"
Endif
LFMT+=":"+num$(evalue([M:SITF]LNG))
If [M:SITF]NUM=2
    LFMT+="#"
Else
    If [M:SITF]FMTCLE=2
        LFMT+="c"
    Else
        LFMT+="X"
    Endif
Endif

# Le contrôle en V6 ne peut plus se faire <=> multi-plan.
# Demande de Fabienne, dans le cas "SI ET SEULEMENT SI un seul modèle comptable est présent dans le dossier"
If [M:SITF]CODFIC="XIPLACBGNR"
 If GGCMNBR=1
  LFMT="K:"+num$(GLONGAC)+'c'
 Endif
Endif

Chgfmt [M:SITF]X3CLE With LFMT

End

######################################################################################
Subprog AM_LNG(VALEUR)
Variable Char    VALEUR()
    [M:SITF]LNG = VALEUR
    Call FMT_X3CLE
End

Subprog AM_SPC(VALEUR)
Variable Integer VALEUR
    [M:SITF]SPC = VALEUR
    Call FMT_X3CLE
End

Subprog AM_MAJ(VALEUR)
Variable Integer VALEUR
    [M:SITF]MAJ = VALEUR
    Call FMT_X3CLE
End


######################################################################################
$CAL_NB_PAGE
#--- Calcul du nombre de lignes et de pages ---#
If [M:SITF]AFFERR=2
    Filter [SIW] Where CODFIC=[M:SITF]CODFIC
&                    & CODZONE=[M:SITF]CODZONE
&                    & SEQ=[M:SITF]SEQ
&                    & ERR=2
Elsif [M:SITF]AFFDBL=2
    Filter [SIW] Where CODFIC=[M:SITF]CODFIC
&                    & CODZONE=[M:SITF]CODZONE
&                    & SEQ=[M:SITF]SEQ
&                    & DBL=2
Else
    Filter [SIW] Where CODFIC=[M:SITF]CODFIC
&                    & CODZONE=[M:SITF]CODZONE
&                    & SEQ=[M:SITF]SEQ
Endif
GNBTOTSIW = rowcount([SIW])
GNBPAG = fix(GNBTOTSIW/dim([M:SITF]COD))+(mod(GNBTOTSIW,dim([M:SITF]COD))>0)
Filter [SIW]
Return



######################################################################################

######################################################################################
Subprog B2_NBCOD
Local Integer I
I=nolign
For nolign=1 To [M:SITF]NBCOD
    If [M:SITF]X3CLE(nolign-1)=""
        [M:SITF]X3CLE(nolign-1) = func INIX3CLE(nolign-1)
        Call AM_X3CLE([M:SITF]X3CLE(nolign-1))
        [M:SITF]MDF(nolign-1) = 2
        Affzo [M:SITF]X3CLE(nolign-1)
    Endif
Next
nolign=I
End

Subprog AS_X3CLE(VALEUR)
Variable Char    VALEUR()
    If [M:SITF]X3CLE(nolign-1)=""
        VALEUR = func INIX3CLE(nolign-1)
    Endif
End

######################################################################################
Funprog INIX3CLE(PIND)
Value Integer PIND
Local Char LX3CLE

    LX3CLE = [M:SITF]COD(PIND)
    LX3CLE = func SUBSIT.TRACOD(LX3CLE,
&                               100,
&                               [M]FMTCLE,
&                               [M]ACCENT,
&                               [M]MAJ,
&                               [M]SPC,
&                               [M]NUM,
&                               GSITF_CARO, GSITF_CARD)
    LX3CLE=left$(LX3CLE,evalue([M]LNG))

    If func SUBSIT.CTLTRACOD([M]OBJ,[M]CODFIC,[M]LNG,LX3CLE)
        Raz LX3CLE
    Endif

    If [M:SITF]CODFIC="XIPLACBGNR"
        # Le contrôle en V6 ne peut plus se faire <=> multi-plan.
        #If format$("K:"+GACCFMT,LX3CLE)<>LX3CLE
        #  Raz LX3CLE
        #Endif
        # Demande de Fabienne, dans le cas "SI ET SEULEMENT SI un seul modèle comptable est présent dans le dossier"
        If GGCMNBR=1
         Local Char    FMTACC(10)
         FMTACC =  num$(GLONGAC)+'c'
         If format$("K:"+FMTACC,LX3CLE)<>LX3CLE
          Raz LX3CLE
         Endif
        Endif
    Endif

End LX3CLE

######################################################################################

######################################################################################
Subprog IB_X3CLE
If [M]SEL=""
    GBOUTS=""
Endif
Case [M:SITF]CODFIC
    When "XIMODRGL" :
        # N° de table diverse    GBIDC1 est utilisé dans le paramètre SUPP1 de l'action de sélection
        If [M:SITF]CODZONE2<>"" : Raz GBIDC1 Else GBIDC1 = "3" : Endif
    When Default :
        Raz GBIDC1
Endcase
End


