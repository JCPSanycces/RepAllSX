########################################################################
# STKSELLOT : Sélection lot
########################################################################
# Paramètres E : LITM = article
#                LLOT = lot
#
########################################################################
$STKSELLOT
Local Char    LFIC(10)        : LFIC = "STOLOT"
Local Char    LITM(GLONITM)   : LITM = PARAM(1)
Local Char    LFCY(GLONFCY)   : LFCY = PARAM(2)
Local Char    LABR            : LABR = PARAM(3)
Local Integer LLIG            : LLIG = val(PARAM(4))
Local Integer LQTYFLG         : If dim(PARAM)>5 : LQTYFLG = val(PARAM(5)) : Endif
Local Char    LLOT(GLONLOT)   : LLOT = VALEUR
Local Integer ISTL
Raz ISTL

#--- Bug 65496
# Si le niveau des caractéristiques est le lot, alors la sélection
# est limitée à 30 lots (au delà, il y a un problème mémoire).
# De plus on ne sait pas filtrer sur, et afficher les cumuls quantités.
If GFEALOTLEV<>1
   #--- Issue 114228
   Local Integer NBLOT : NBLOT=30
   GPOINT="DIM_TABLOT" : Gosub ENTREE From EXEFNC
   #---
   LQTYFLG=2
   Local  Integer I
   #--- Issue 114228 Remplacement de 30 par NBLOT
   Global Char    GTABLOT(GLONLOT)(NBLOT)
   Global Char    GTABSLO(GLONSLO)(NBLOT)
   #---
Endif
#---
If clalev([F:STL1]) = 0 : Local File STOLOT    [STL1] : ISTL = 1 : Endif
If clalev([F:SLF1]) = 0 : Local File STOLOTFCY [SLF1] : ISLF = 1 : Endif
If clalev([F:ATZ])  = 0 : Local File ATABZON   [ATZ]  : Endif

#                                                     # hcb 71276 deb
If LITM <> ""
   If [F:ITM]ITMREF<>LITM
      Read [ITM]ITM0=LITM
      If fstat
         Raz [F:ITM]
      Endif
   Endif
Else
  Raz [F:ITM]
Endif
#                                                     # hcb 71276 fin

TIT(0) = mess(2,723,1)
NBCOL=0
If GVTMOD=0
  NBCOL =1 : COL(NBCOL)="[F:SLF1]ITMREF"    : Call TEXTFIC(LFIC,"ITMREF",2,TIT(NBCOL)) From OBJDIV
Endif
NBCOL+=1   : COL(NBCOL)="[F:SLF1]LOT"       : Call TEXTFIC(LFIC,"LOT",2,TIT(NBCOL)) From OBJDIV
#--- Bug 65496
If GFEALOTLEV = 1
  NBCOL+=1 : COL(NBCOL)="[F:SLF1]SLO"       : Call TEXTFIC(LFIC,"SLO",2,TIT(NBCOL)) From OBJDIV
Endif
#                                                     # hcb 71276 deb
If dim([F:ITM]ECCSTO) > 0
   Case [F:ITM]ECCSTO
        When  2
          NBCOL+=1 : COL(NBCOL)="[F:STL1]ECCVALMAJ" : Call TEXTFIC("STOLOT","ECCVALMAJ",2,TIT(NBCOL)) From OBJDIV
        When  3
          NBCOL+=1 : COL(NBCOL)="[F:STL1]ECCVALMAJ" : Call TEXTFIC("STOLOT","ECCVALMAJ",2,TIT(NBCOL)) From OBJDIV
          NBCOL+=1 : COL(NBCOL)="[F:STL1]ECCVALMIN" : Call TEXTFIC("STOLOT","ECCVALMIN",2,TIT(NBCOL)) From OBJDIV
        When Default
   Endcase
Endif
#                                                     # hcb 71276 fin

If LFCY=""
  NBCOL+=1 : COL(NBCOL)="[F:SLF1]STOFCY"    : Call TEXTFIC(LFIC,"STOFCY",2,TIT(NBCOL)) From OBJDIV
Endif
#--- Bug 65496
If GFEALOTLEV = 1
  NBCOL+=1 : COL(NBCOL)="[F:SLF1]AAACUMQTY" : Call TEXTFIC("STOLOTFCY","AAACUMQTY",2,TIT(NBCOL)) From OBJDIV
  NBCOL+=1 : COL(NBCOL)="[F:SLF1]QQQCUMQTY" : Call TEXTFIC("STOLOTFCY","QQQCUMQTY",2,TIT(NBCOL)) From OBJDIV
  NBCOL+=1 : COL(NBCOL)="[F:SLF1]RRRCUMQTY" : Call TEXTFIC("STOLOTFCY","RRRCUMQTY",2,TIT(NBCOL)) From OBJDIV
Endif

NBCOL+=1 : COL(NBCOL)="[F:STL1]SHLDAT"      : Call TEXTFIC("STOLOT","SHLDAT",2,TIT(NBCOL)) From OBJDIV
NBCOL+=1 : COL(NBCOL)="[F:STL1]DLUDAT"      : Call TEXTFIC("STOLOT","DLUDAT",2,TIT(NBCOL)) From OBJDIV
NBCOL+=1 : COL(NBCOL)="[F:STL1]POT"         : Call TEXTFIC("STOLOT","POT",2,TIT(NBCOL)) From OBJDIV

#--- Bug 77117
CRITERE  = "[F:SLF1]ITMREF='"+LITM+"'"
If LFCY<>""
  CRITERE +="&[F:SLF1]STOFCY='"+LFCY+"'"
Endif
#---

If dim(GFONCTION)>0 & GFONCTION= "CONSSTK"
  Goto S_SELLOT1
Endif
Case LQTYFLG
  When 0 : CRITERE += "&([F:SLF1]AAACUMQTY = 0 & [F:SLF1]QQQCUMQTY = 0 & [F:SLF1]RRRCUMQTY = 0)"
  When 1 : CRITERE += "&([F:SLF1]AAACUMQTY <> 0 | [F:SLF1]QQQCUMQTY <> 0 | [F:SLF1]RRRCUMQTY <> 0)"
  When 2 : # Pas de critère sur la quantité
Endcase

#--- Bug 65496
If GFEALOTLEV<>1
  I=0
  Filter [SLF1] Where evalue(CRITERE) Order By Key SLF0(2)
  For [SLF1]
    GTABLOT(I)=[F:SLF1]LOT
    GTABSLO(I)=[F:SLF1]SLO
    I+=1
    #--- Issue 114228 Remplacement de 30 par NBLOT
    If I>=NBLOT Break Endif
  Next
  Filter [SLF1]
  #--- Issue 114228 Remplacement de 29 par NBLOT-1
  CRITERE += "&find([F:SLF1]LOT,GTABLOT(0..NBLOT-1))<>0"
  CRITERE += "&find([F:SLF1]SLO,GTABSLO(0..NBLOT-1))<>0"
  #---
Endif
#---

Link [SLF1] With [STL1]STL0=[F:SLF1]ITMREF;[F:SLF1]LOT;[F:SLF1]SLO As [LNK]

$S_SELLOT1

ORDRE   = "ITMREF;LOT;SLO"
START   = "LOT"
VALEUR  = LLOT
SIZLIG  = 150
SIZCOL  = 280

#--- Bug 77117
If GFEALOTLEV=1 DEFPAG=1 Endif

Default File [LNK]
Return


#--- TS 106217
########################################################################
# STKSELMAJS Sélection version majeure en sortie
########################################################################
# Paramètres E : LECCVAL = Version majeure
#                LFCY    = Site stock
#                LITM    = Article
#                LTRSTYP = Type mouvement (ML 704)
#                          Si devis, commande ou préparation,
#                          mettre comme pour une livraison
#                LTRSCOD = Code mouvement
#                LABR    = Masque
#                LLIG    = Ligne si selection depuis un tableau
########################################################################
$STKSELMAJS

Local Char    LFIC(10)          : LFIC    = "ECCSTA"
Local Char    LECCVAL(GLONECS)  : LECCVAL = VALEUR
Local Char    LFCY(GLONFCY)     : LFCY    = PARAM(1)
Local Char    LITM(GLONITM)     : LITM    = PARAM(2)
Local Integer LTRSTYP           : LTRSTYP = val(PARAM(3))
Local Char    LTRSCOD           : LTRSCOD = PARAM(4)
Local Char    LABR              : LABR    = PARAM(5)
Local Integer LLIG              : LLIG    = val(PARAM(6))
Local Integer LRET

If clalev([F:ECS1]) = 0 : Local File ECCSTA    [ECS1] : Endif
If clalev([F:ATZ])  = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:AXX])  = 0 : Local File ATEXTRA   [AXX]  : Endif
If clalev([F:SRU])  = 0 : Local File TABSTORUL [SRU]  : Endif

TIT(0) = mess(20,723,1)

If LITM="" : OK=0 : Return : Endif

If [F:ITM]ITMREF<>LITM
  Read [ITM]ITM0=LITM
  If fstat
    Call RSTA("ITM",LITM) From GLOCK
    OK=0 : Return
  Endif
Endif

# Lecture de la règle de gestion à utiliser
Call LECSRU(LFCY,[F:ITM]TCLCOD,LTRSTYP,LTRSCOD,"",LRET) From STKLIB
If LRET<>0
  OK=0 : Return
Endif

Link [ECS1] With [AXX]AXX0="ECCSTA";"ECCDESAXX";GLANGUE;[F:ECS1]ITMREF;[F:ECS1]ECCVALMAJ
&           As [SRT_]

If [F:AXX]CODFIC<>"ECCSTA"
  Raz [F:AXX]TEXTE
Endif
NBCOL=0
NBCOL+=1 : COL(NBCOL)="[F:ECS1]ECCVALMAJ"           : Call TEXTFIC(LFIC,"ECCVALMAJ",2,TIT(NBCOL)) From OBJDIV
NBCOL+=1 : COL(NBCOL)="[F:AXX]TEXTE"                : Call TEXTFIC(LFIC,"ECCDESAXX",2,TIT(NBCOL)) From OBJDIV
NBCOL+=1 : COL(NBCOL)="mess([F:ECS1]ECCSTA,2776,1)" : Call TEXTFIC(LFIC,"ECCSTA",2,TIT(NBCOL))    From OBJDIV
NBCOL+=1 : COL(NBCOL)="[F:ECS1]EXNDAT"              : Call TEXTFIC(LFIC,"EXNDAT",2,TIT(NBCOL))    From OBJDIV
NBCOL+=1 : COL(NBCOL)="mess([F:ECS1]SPSFLG,1,1)"    : Call TEXTFIC(LFIC,"SPSFLG",2,TIT(NBCOL))    From OBJDIV

CRITERE(1) ="[F:ECS1]ITMREF='"+LITM+"'"
# FGR 21/07/2015 : X3SUIVI105605 : vu avec TS : ne pas faire ça (début)
#If LECCVAL <> ""
#  CRITERE(1) +="&[F:ECS1]ECCVALMAJ>='"+LECCVAL+"'"
#Endif
# FGR 21/07/2015 : X3SUIVI105605 : vu avec TS : ne pas faire ça (fin)

CRITERE(2)  ="&([F:ECS1]ECCSTA<4)"

#--- La sélection n'est volontairement pas filtrée selon la règle de gestion
#CRITERE(2) +="([F:ECS1]ECCSTA=1&([F:SRU]AUZPRO=3|[F:SRU]AUZPRO=2&[F:ECS1]SPSFLG=1))"
#CRITERE(2) +="|"
#CRITERE(2) +="([F:ECS1]ECCSTA=2&([F:SRU]AUZACT=3|[F:SRU]AUZACT=2&[F:ECS1]SPSFLG=1))"
#CRITERE(2) +="|"
#CRITERE(2) +="([F:ECS1]ECCSTA=3&([F:SRU]AUZSTP=3|[F:SRU]AUZSTP=2&[F:ECS1]EXNFLG=2))"
#CRITERE(2) +=")"

ORDRE  = "ITMREF;ECCVALMAJ desc"
START  = "ECCVALMAJ"
EXPSTART = "[F:ECS1]ECCVALMAJ" + ">''"  # FGR 21/07/2015 : X3SUIVI105605 : vu avec TS
VALEUR = LECCVAL
SIZLIG = 150
SIZCOL = 280
DEFPAG = 1
Default File [SRT_]
Return

$VERF_STKSELMAJS
If LABR<>""
  Local     Char    LABRMSK
  LABRMSK  = "[M:"+LABR+"]"
  If evalue("dim("+LABRMSK+"ECCVALMAJ)")>0
    If LLIG <> 0
      Assign LABRMSK+"ECCVALMAJ(LLIG)"  With [F:ECS1]ECCVALMAJ
      #Default Mask "["+LABR+"]"
      #Affzo [M]ECCVALMAJ(LLIG)
    Else
      Assign LABRMSK+"ECCVALMAJ"  With [F:ECS1]ECCVALMAJ
      #Default Mask "["+LABR+"]"
      #Affzo [M]ECCVALMAJ
    Endif
  Endif
Endif
Return
#--- End TS 106217

########################################################################
# STKSELMAJ Sélection version majeure
########################################################################
# Paramètres E : LITM = article
#                LFCY = site
#                LMAJ = version majeure
#                LACT = statut : "" tout statut; "1" = prototype; "23" = active + fermée   etc etc .....
#                LABR = masque
#                LLIG = ligne si selection depuis un tableau
########################################################################
$STKSELMAJ

Local Char    LFIC(10)        : LFIC = "ECCSTA"
Local Char    LMAJ(GLONECS)   : LMAJ = VALEUR
Local Char    LITM(GLONITM)   : LITM = PARAM(1)
Local Char    LSTA            : LSTA = PARAM(2)
Local Char    LABR            : LABR = PARAM(3)
Local Integer LLIG            : LLIG = val(PARAM(4))

#---
If clalev([F:ECS1]) = 0 : Local File ECCSTA    [ECS1] : Endif
If clalev([F:ATZ])  = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:AXX])  = 0 : Local File ATEXTRA   [AXX]  : Endif

TIT(0) = mess(20,723,1)


Link [ECS1] With
& [AXX]AXX0="ECCSTA";"ECCDESAXX";GLANGUE;[F:ECS1]ITMREF;[F:ECS1]ECCVALMAJ
& As [SRT_]

If [F:AXX]CODFIC <> "ECCSTA"
   Raz [F:AXX]TEXTE
Endif
NBCOL=0
NBCOL+=1 : COL(NBCOL)="[F:ECS1]ECCVALMAJ"           : Call TEXTFIC(LFIC,"ECCVALMAJ",2,TIT(NBCOL)) From OBJDIV
NBCOL+=1 : COL(NBCOL)="[F:AXX]TEXTE"                : Call TEXTFIC(LFIC,"ECCDESAXX",2,TIT(NBCOL)) From OBJDIV
NBCOL+=1 : COL(NBCOL)="mess([F:ECS1]ECCSTA,2776,1)" : Call TEXTFIC(LFIC,"ECCSTA",2,TIT(NBCOL))    From OBJDIV
NBCOL+=1 : COL(NBCOL)="[F:ECS1]EXNDAT"              : Call TEXTFIC(LFIC,"EXNDAT",2,TIT(NBCOL))    From OBJDIV
NBCOL+=1 : COL(NBCOL)="mess([F:ECS1]SPSFLG,1,1)"    : Call TEXTFIC(LFIC,"SPSFLG",2,TIT(NBCOL))    From OBJDIV

CRITERE = "1=1"
CRITERE +="&[F:ECS1]ITMREF='"+LITM+"'"
If LMAJ <> ""
   CRITERE +="&[F:ECS1]ECCVALMAJ>='"+LMAJ+"'"
Endif

CRITERE +="&([F:ECS1]ECCSTA<4)"

If LSTA <> ""
   CRITERE += "&find([F:ECS1]ECCSTA"
   For I = 1 To len(LSTA)
       CRITERE += ","+num$(mid$(LSTA,I,1))
   Next I
   CRITERE += ")"
Endif

#---
ORDRE  = "ITMREF;ECCVALMAJ desc"
START  = "ECCVALMAJ"

VALEUR = LMAJ
SIZLIG = 150
SIZCOL = 280
DEFPAG = 1
Default File [SRT_]

Return

########################################################################
# STKSELMIN Sélection version mineure
########################################################################
# Paramètres E : LITM = article
#                LMAJ = version majeure
#                LMIN = version mineure
#                LABR = masque
#                LLIG = ligne si sélection depuis un tableau
#                LTYP = type de flux  (ECCTYP de la table ECCVAL)
########################################################################
$STKSELMIN
Local Char    LFIC(10)         : LFIC = "ECCVAL"
Local Char    LMIN(GLONICVVAL) : LMIN = VALEUR
Local Char    LITM(GLONITM)    : LITM = PARAM(1)
Local Char    LMAJ(GLONECS)    : LMAJ = PARAM(2)
Local Char    LABR             : LABR = PARAM(3)
Local Integer LLIG             : LLIG = val(PARAM(4))
Global Integer LTYP             : LTYP = val(PARAM(5))

#---
If clalev([F:EVL1]) = 0 : Local File ECCVAL    [EVL1] : Endif
If clalev([F:ATZ])  = 0 : Local File ATABZON   [ATZ]  : Endif

TIT(0) = mess(21,723,1)
If LTYP = 0
   Return
Endif
NBCOL=0
NBCOL+=1 : COL(NBCOL)="[F:EVL1]ECCVALMIN" : Call TEXTFIC(LFIC,"ECCVALMIN",2,TIT(NBCOL)) From OBJDIV
CRITERE = "1=1"
CRITERE +="&[F:EVL1]ECCTYP=LTYP"
CRITERE +="&[F:EVL1]ITMREF='"+LITM+"'"
CRITERE +="&[F:EVL1]ECCVALMAJ='"+LMAJ+"'"
# FGR 21/07/2015 : X3SUIVI105605 : vu avec TS : ne pas faire ça (début)
#If LMIN <> ""
#   CRITERE +="&[F:EVL1]ECCVALMIN>='"+LMIN+"'"
#Endif
# FGR 21/07/2015 : X3SUIVI105605 : vu avec TS : ne pas faire ça (fin)

#---
ORDRE  = "ITMREF;ECCVALMAJ desc;ECCVALMIN desc"
START = "ECCVALMIN"
EXPSTART = "[F:EVL1]ECCVALMIN" + ">''"  # FGR 21/07/2015 : X3SUIVI105605 : vu avec TS

VALEUR = LMIN
SIZLIG = 150
SIZCOL = 280
DEFPAG = 1
Default File [EVL1]

Return

#                                                                                                   # hcb 71276  fin


########################################################################
# STKSELLOTO : Sélection lot d'une pièce origine
########################################################################
# Paramètres E : LITM = article
#                LLOT = lot
#
########################################################################
$STKSELLOTO
Local Char    LITM(GLONITM)       : LITM = PARAM(1)
Local Char    LABR                : LABR = PARAM(2)
Local Integer LLIG                : LLIG = val(PARAM(3))
Local Char    LFCY(GLONFCY)       : LFCY = PARAM(4)
Local Integer LVCRTYPORI          : LVCRTYPORI = val(PARAM(5))
Local Char    LVCRNUMORI(GLONVCR) : LVCRNUMORI = PARAM(6)
Local Integer LVCRLINORI          : LVCRLINORI = val(PARAM(7))

Global Char   GTABLOTORI(GLONLOT)(50)

Local Char    LLOT(GLONLOT)   : LLOT = VALEUR

Local Integer ISTL, I, ISLF
Raz ISTL, I
If clalev([F:STL]) = 0 : Local File STOLOT   [STL] : ISTL = 1 : Endif
If clalev([F:SLF]) = 0 : Local File STOLOTFCY[SLF] : ISLF = 1 : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON  [ATZ] : Endif
If clalev([F:STJ]) = 0 : Local File STOJOU   [STJ] : Endif
#
Raz GTABLOTORI
If LVCRNUMORI<>""
   For [STJ]STJ1 Where STOFCY=LFCY & VCRTYP=LVCRTYPORI &
&                      VCRNUM=LVCRNUMORI & VCRLIN=LVCRLINORI & ITMREF = LITM
      If [F:STJ]LOT<>""
         If I=0
            GTABLOTORI(0)=[F:STJ]LOT
            I+=1
         Elsif !find([F:STJ]LOT,GTABLOTORI(0..I-1))
            GTABLOTORI(I)=[F:STJ]LOT
            I+=1
         Endif
      Endif
   Next
Endif
#
TIT(0) = mess(2,723,1)
NBCOL  = 1 : COL(NBCOL) = "[F:SLF]ITMREF" : Call TEXTFIC("STOLOTFCY","ITMREF",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:SLF]LOT"    : Call TEXTFIC("STOLOTFCY","LOT",2,TIT(NBCOL)) From OBJDIV
If [F:ITM]LOTMGTCOD = 4
   NBCOL += 1 : COL(NBCOL) = "[F:SLF]SLO" : Call TEXTFIC("STOLOTFCY","SLO",2,TIT(NBCOL)) From OBJDIV
Endif
If LFCY=""
    NBCOL += 1 : COL(NBCOL) = "[F:SLF]STOFCY" :  Call TEXTFIC("STOLOTFCY","STOFCY",2,TIT(NBCOL)) From OBJDIV
Endif
NBCOL += 1 : COL(NBCOL) = "[F:SLF]AAACUMQTY"  : Call TEXTFIC("STOLOTFCY","AAACUMQTY",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:SLF]QQQCUMQTY"  : Call TEXTFIC("STOLOTFCY","QQQCUMQTY",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:SLF]RRRCUMQTY"  : Call TEXTFIC("STOLOTFCY","RRRCUMQTY",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:STL]SHLDAT"     : Call TEXTFIC("STOLOT","SHLDAT",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:STL]DLUDAT"     : Call TEXTFIC("STOLOT","DLUDAT",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:STL]POT"        : Call TEXTFIC("STOLOT","POT",2,TIT(NBCOL)) From OBJDIV
#
If GTABLOTORI(0)=""
   CRITERE  = "[F:STL]ITMREF=LITM"
Else
   CRITERE  = "[F:STL]ITMREF=LITM&find([F:STL]LOT,GTABLOTORI(0..49))<>0"
Endif
CRITERE+="&[F:SLF]STOFCY=LFCY"

Link [SLF] With [STL]STL0=[F:SLF]ITMREF;[F:SLF]LOT;[F:SLF]SLO
&          As [LNK]

ORDRE    = "[F:STL]ITMREF;LOT;SLO"
START    = "LOT"
VALEUR   = LLOT
SIZLIG   = 150
SIZCOL   = 280
Default File [LNK]

Return

########################################################################
# STKSELLOTS : Sélection lot    + statut
########################################################################
# Paramètres E : LITM = article
#                LLOT = lot
#
########################################################################
$STKSELLOTS
Local Char    LITM(GLONITM)   : LITM = PARAM(1)
Local Char    LFCY(GLONFCY)   : LFCY = PARAM(2)
Local Char    LABR            : LABR = PARAM(3)
Local Integer LLIG            : LLIG = val(PARAM(4))
Local Integer LASTA           : LASTA = val(PARAM(5))
Local Integer LQSTA           : LQSTA = val(PARAM(6))
Local Integer LRSTA           : LRSTA = val(PARAM(7))
Local Char    LLOT(GLONLOT)   : LLOT = VALEUR
Local Integer XSTA
#
Local Integer ISTL, ISLF
Raz ISTL
If clalev([F:STL]) = 0 : Local File STOLOT     [STL] : ISTL = 1 : Endif
If clalev([F:SLF]) = 0 : Local File STOLOTFCY  [SLF] : ISLF = 1 : Endif
If clalev([F:ATZ])  = 0 : Local File ATABZON   [ATZ]  : Endif
#
TIT(0) = mess(2,723,1)
NBCOL  = 1 : COL(NBCOL) = "[F:SLF]ITMREF"    : Call TEXTFIC("STOLOTFCY","ITMREF",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:SLF]LOT"       : Call TEXTFIC("STOLOTFCY","LOT",2,TIT(NBCOL)) From OBJDIV
If [F:ITM]LOTMGTCOD = 4
   NBCOL += 1 : COL(NBCOL) = "[F:SLF]SLO"    : Call TEXTFIC("STOLOTFCY","SLO",2,TIT(NBCOL)) From OBJDIV
Endif
NBCOL += 1 : COL(NBCOL) = "[F:SLF]STOFCY"    : Call TEXTFIC("STOLOTFCY","STOFCY",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:SLF]AAACUMQTY" : Call TEXTFIC("STOLOTFCY","AAACUMQTY",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:SLF]QQQCUMQTY" : Call TEXTFIC("STOLOTFCY","QQQCUMQTY",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:SLF]RRRCUMQTY" : Call TEXTFIC("STOLOTFCY","RRRCUMQTY",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:STL]SHLDAT"    : Call TEXTFIC("STOLOT","SHLDAT",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:STL]DLUDAT"    : Call TEXTFIC("STOLOT","DLUDAT",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:STL]POT"       : Call TEXTFIC("STOLOT","POT",2,TIT(NBCOL)) From OBJDIV
#
CRITERE  = "[F:SLF]ITMREF=LITM&[F:SLF]STOFCY=LFCY"
XSTA = 0
If LASTA = 2 : XSTA += 1 : Endif
If LQSTA = 2 : XSTA += 2 : Endif
If LRSTA = 2 : XSTA += 4 : Endif
Case XSTA
    When 1: CRITERE += "&[F:SLF]AAACUMQTY<>0&[F:SLF]QQQCUMQTY=0&[F:SLF]RRRCUMQTY=0"
    When 2: CRITERE += "&[F:SLF]QQQCUMQTY<>0&[F:SLF]AAACUMQTY=0&[F:SLF]RRRCUMQTY=0"
    When 3: CRITERE += "&([F:SLF]AAACUMQTY<>0|[F:SLF]QQQCUMQTY<>0)&[F:SLF]RRRCUMQTY=0"
    When 4: CRITERE += "&[F:SLF]RRRCUMQTY<>0&[F:SLF]AAACUMQTY=0&[F:SLF]QQQCUMQTY=0"
    When 5: CRITERE += "&([F:SLF]AAACUMQTY<>0|[F:SLF]RRRCUMQTY<>0)&[F:SLF]QQQCUMQTY=0"
    When 6: CRITERE += "&([F:SLF]QQQCUMQTY<>0|[F:SLF]RRRCUMQTY<>0)&[F:SLF]AAACUMQTY=0"
    When 7: CRITERE += "&([F:SLF]AAACUMQTY<>0|[F:SLF]QQQCUMQTY<>0|[F:SLF]RRRCUMQTY<>0)"
Endcase

Link [SLF] With [STL]STL0=[F:SLF]ITMREF;[F:SLF]LOT;[F:SLF]SLO
&          As [LNK]

ORDRE   = "[F:SLF]ITMREF;LOT;SLO"
START   = "LOT"
VALEUR  = LLOT
SIZLIG  = 150
SIZCOL  = 280
Default File [LNK]
Return

#########################################################################
# STKSELLOTM : Sélection lot sur des bornes articles
# Paramètres E :
#                LITMSTR = article début
#                LITMEND = article fin
#########################################################################
$STKSELLOTM
Local Char    LITMSTR(GLONITM): LITMSTR   =     PARAM(1)
Local Char    LITMEND(GLONITM): LITMEND   =     PARAM(2)
Local Char    LFCY   (GLONFCY): LFCY      =     PARAM(3)
Local Integer LQTYFLG         : LQTYFLG   = val(PARAM(4))
Local Char    LLOT(GLONLOT)   : LOT = VALEUR

If clalev([F:STL])        = 0 : Local File STOLOT      [STL] : Endif
If clalev([F:SLF])        = 0 : Local File STOLOTFCY   [SLF] : Endif
If clalev([F:ATZ])        = 0 : Local File ATABZON     [ATZ] : Endif

TIT(0) = mess(2,723,1)
NBCOL  = 1 : COL(NBCOL) = "[F:SLF]ITMREF"     : Call TEXTFIC("STOLOTFCY","ITMREF",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:SLF]LOT"        : Call TEXTFIC("STOLOTFCY","LOT",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:SLF]SLO"        : Call TEXTFIC("STOLOTFCY","SLO",2,TIT(NBCOL)) From OBJDIV
If LFCY=""
    NBCOL += 1 : COL(NBCOL) = "[F:SLF]STOFCY" :  Call TEXTFIC("STOLOTFCY","STOFCY",2,TIT(NBCOL)) From OBJDIV
Endif
NBCOL += 1 : COL(NBCOL) = "[F:SLF]AAACUMQTY"  : Call TEXTFIC("STOLOTFCY","AAACUMQTY",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:SLF]QQQCUMQTY"  : Call TEXTFIC("STOLOTFCY","QQQCUMQTY",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:SLF]RRRCUMQTY"  : Call TEXTFIC("STOLOTFCY","RRRCUMQTY",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:STL]SHLDAT"     : Call TEXTFIC("STOLOT","SHLDAT",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:STL]DLUDAT"     : Call TEXTFIC("STOLOT","DLUDAT",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:STL]POT"        : Call TEXTFIC("STOLOT","POT",2,TIT(NBCOL)) From OBJDIV
CRITERE = "1=1"
If LITMSTR <> ""  : CRITERE += "&[F:SLF]ITMREF>=LITMSTR"    : Endif
If LITMEND <> ""  : CRITERE += "&[F:SLF]ITMREF<=LITMEND"    : Endif
If LFCY <> ""  : CRITERE += "&[F:SLF]STOFCY=LFCY"    : Endif
Case LQTYFLG
    When 0 : CRITERE += "&([F:SLF]AAACUMQTY = 0 & [F:SLF]QQQCUMQTY = 0 & [F:SLF]RRRCUMQTY = 0)"
    When 1 : CRITERE += "&([F:SLF]AAACUMQTY <> 0 | [F:SLF]QQQCUMQTY <> 0 | [F:SLF]RRRCUMQTY <> 0)"
    When 2 : # Pas de critère sur la quantité
Endcase

Link [SLF] With [STL]STL0=[F:SLF]ITMREF;[F:SLF]LOT;[F:SLF]SLO
&          As [LNK]

ORDRE   = "[F:SLF]ITMREF;LOT;SLO;STOFCY"
START   = "LOT"
VALEUR  = LLOT
SIZLIG  = 150
SIZCOL  = 280
Default File [LNK]

Return


$VERF_STKSELLOT
If LABR<>""
    Local     Char    LABRMSK
    LABRMSK  = "[M:"+LABR+"]"
    If evalue("dim("+LABRMSK+"SLO)")>0
       Assign LABRMSK+"SLO(LLIG)"  With [F:STL1]SLO    # hcb 65496
       Default Mask "["+LABR+"]"
       Affzo [M]SLO(LLIG)
    Endif
Endif

Return

#                                                                   # hcb 71276 deb
$VERF_STKSELMAJ
If LABR<>""
  Local     Char    LABRMSK
  LABRMSK  = "[M:"+LABR+"]"
  If evalue("dim("+LABRMSK+"ECCVALMAJ)")>0
     If LLIG <> 0
        Assign LABRMSK+"ECCVALMAJ(LLIG)"  With [F:ECS1]ECCVALMAJ
        Default Mask "["+LABR+"]"
        Affzo [M]ECCVALMAJ(LLIG)
     Else
        Assign LABRMSK+"ECCVALMAJ"  With [F:ECS1]ECCVALMAJ
        Default Mask "["+LABR+"]"
        Affzo [M]ECCVALMAJ
     Endif
  Endif
Endif

Return

$VERF_STKSELMIN

If LABR<>""
  Local     Char    LABRMSK
  LABRMSK  = "[M:"+LABR+"]"
  If evalue("dim("+LABRMSK+"ECCVALMIN)")>0
     If LLIG <> 0
        Assign LABRMSK+"ECCVALMIN(LLIG)"  With [F:EVL1]ECCVALMIN
        Default Mask "["+LABR+"]"
        Affzo [M]ECCVALMIN(LLIG)
     Else
        Assign LABRMSK+"ECCVALMIN"  With [F:EVL1]ECCVALMIN
        Default Mask "["+LABR+"]"
        Affzo [M]ECCVALMIN
     Endif
  Endif
Endif
Return
#                                                                   # hcb 71276 fin



#                                                        hcb 65496 deb
$VERF_STKSELLOTO
If LABR<>""
    Local     Char    LABRMSK
    LABRMSK  = "[M:"+LABR+"]"
    If evalue("dim("+LABRMSK+"SLO)")>0
       Assign LABRMSK+"SLO(LLIG)"  With [F:STL]SLO
       Default Mask "["+LABR+"]"
       Affzo [M]SLO(LLIG)
    Endif
Endif

Return
#                                                         hcb 65496 fin
$VERF_STKSELLOTD
If LABR<>""
    Local     Char    LABRMSK
    LABRMSK  = "[M:"+LABR+"]"
    If evalue("dim("+LABRMSK+"SLODES)")>0
       Assign LABRMSK+"SLODES(LLIG)"  With [F:STL]SLO
       Default Mask "["+LABR+"]"
       Affzo [M]SLODES(LLIG)
    Endif
Endif

Return

#########################################################################
# STKSELSLOM : Sélection s/lot sur des bornes articles/lot
# Paramètres E :
#                LITMSTR = article début
#                LITMEND = article fin
#                LLOTSTR = lot début
#                LLOTEND = lot fin
#########################################################################
$STKSELSLOM
Local Char    LITMSTR(GLONITM): LITMSTR   =     PARAM(1)
Local Char    LITMEND(GLONITM): LITMEND   =     PARAM(2)
Local Char    LLOTSTR(GLONLOT): LLOTSTR   =     PARAM(3)
Local Char    LLOTEND(GLONLOT): LLOTEND   =     PARAM(4)
Local Char    LFCY   (GLONFCY): LFCY      =     PARAM(5)
Local Char    LSLO(GLONSLO)   : LSLO = VALEUR
Local Char    LFIC(10)        : LFIC = "STOLOT"

If clalev([F:STL])        = 0 : Local File STOLOT      [STL] : Endif
If clalev([F:SLF])        = 0 : Local File STOLOTFCY   [SLF] : Endif
If clalev([F:ATZ])        = 0 : Local File ATABZON     [ATZ] : Endif

TIT(0) = mess(2,723,1)
NBCOL=0
If GVTMOD=0
   NBCOL  = 1 : COL(NBCOL) = "[F:SLF]ITMREF"  : Call TEXTFIC("STOLOTFCY","ITMREF",2,TIT(NBCOL)) From OBJDIV
Endif
NBCOL += 1 : COL(NBCOL) = "[F:SLF]LOT"        : Call TEXTFIC("STOLOTFCY","LOT",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:SLF]SLO"        : Call TEXTFIC("STOLOTFCY","SLO",2,TIT(NBCOL)) From OBJDIV
If LFCY=""
    NBCOL += 1 : COL(NBCOL) = "[F:SLF]STOFCY" : Call TEXTFIC("STOLOTFCY","STOFCY",2,TIT(NBCOL)) From OBJDIV
Endif
NBCOL += 1 : COL(NBCOL) = "[F:SLF]AAACUMQTY"  : Call TEXTFIC("STOLOTFCY","AAACUMQTY",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:SLF]QQQCUMQTY"  : Call TEXTFIC("STOLOTFCY","QQQCUMQTY",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:SLF]RRRCUMQTY"  : Call TEXTFIC("STOLOTFCY","RRRCUMQTY",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:STL]SHLDAT"     : Call TEXTFIC("STOLOT","SHLDAT",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:STL]DLUDAT"     : Call TEXTFIC("STOLOT","DLUDAT",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:STL]POT"        : Call TEXTFIC("STOLOT","POT",2,TIT(NBCOL)) From OBJDIV
CRITERE = "1=1"
If LITMSTR <> ""  : CRITERE += "&[F:STL]ITMREF>=LITMSTR"    : Endif
If LITMEND <> ""  : CRITERE += "&[F:STL]ITMREF<=LITMEND"    : Endif
If LLOTSTR <> ""  : CRITERE += "&[F:STL]LOT>=LLOTSTR"       : Endif
If LLOTEND <> ""  : CRITERE += "&[F:STL]LOT<=LLOTEND"       : Endif
If LFCY<>""
    CRITERE+="&[F:SLF]STOFCY=LFCY"
Endif

Link [SLF] With [STL]STL0=[F:SLF]ITMREF;[F:SLF]LOT;[F:SLF]SLO
&          As [LNK]

ORDRE   = "[F:SLF]ITMREF;LOT;SLO;STOFCY"
START   = "SLO"
VALEUR  = LSLO
SIZLIG  = 150
SIZCOL  = 280
Default File [LNK]

Return

########################################################################
# STKSELBPLN : Sélection lot FOURNISSEUR
########################################################################
# Paramètres E : LITM = article
#                LLOT = lot
#
########################################################################
$STKSELBPLN
Local Char    LFIC(10)        : LFIC = "STOCK"
Local Char    LFCY(GLONFCY)   : LFCY = PARAM(1)
Local Char    LITM(GLONITM)   : LITM = PARAM(2)
#
If clalev([F:STO0]) = 0 : Local File STOCK     [STO0] : Endif
If clalev([F:ATZ])  = 0 : Local File ATABZON   [ATZ]  : Endif
#
TIT(0) = mess(3,706,1)-LITM-LFCY
NBCOL  = 1 : COL(NBCOL) = "BPSLOT"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "LOT"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
If [F:ITM]LOTMGTCOD = 4
   NBCOL += 1 : COL(NBCOL) = "SLO"
   Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
Endif
NBCOL += 1 : COL(NBCOL) = "STA"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "LOC"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "QTYSTU"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
#
CRITERE = "[F:STO0]STOFCY=LFCY&[F:STO0]ITMREF=LITM&[F:STO0]BPSLOT<>''"
ORDRE   = ""
START   = ""
VALEUR  = ""
SIZLIG  = 100
SIZCOL  = 200
Default File [STO0]
Return

#########################################################################
# STKSELSTA : Sélection statut stock
#########################################################################
$STKSELSTA
Local Char    WFIC(10)        : WFIC = "TABSTASTO"
Local Integer I, J, K
# Modifie la liste des sous statuts autorisés suivant la valeur de PARAM(2)
Call STKAUZSTA(PARAM(1),val(PARAM(2))) From STKACT

If clalev([F:TST]) = 0 : Local File TABSTASTO [TST] : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA   [AXX] : Endif
#
TIT(0) = mess(138,198,1)
NBCOL  = 1 : COL(NBCOL) = "STASTO"
Call TEXTFIC(WFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"
Call TEXTE(8,TIT(NBCOL)) From OBJDIV
#
If PARAM(1) = ""
  CRITERE += "[F:TST]STASTO=''"
Else
  I = 1
  J = instr(I,PARAM(1),",")
  K = 0
  CRITERE = "1=1 &("
  While J <> 0
    If K <> 0
      CRITERE += "|"
    Endif
    CRITERE += "pat([F:TST]STASTO,'"+seg$(PARAM(1),I,J-1)+"')"
    I = J + 1
    J = instr(I,PARAM(1),",")
    K = 1
  Wend
  If K <> 0
    CRITERE += "|"
  Endif
  CRITERE += "pat([F:TST]STASTO,'"+seg$(PARAM(1),I,len(PARAM(1)))+"'))"
Endif
Link [TST] With [AXX]AXX0="TABSTASTO";"STAAXX";GLANGUE;[F:TST]STASTO;""
&          As [LNK]
ORDRE   = "STASTO"
START   = ""
#VALEUR  = ""
SIZLIG  = 100
SIZCOL  = 140
Default File [LNK]
Return

############################################################
# Sélection numéro de série
############################################################
$STKSELSER
Local Char    WFCY(GLONFCY)       : WFCY       = PARAM(1)
Local Char    WITM(GLONITM)       : WITM       = PARAM(2)
#Local Date    WISSDAT             : WISSDAT    = PARAM(3)
Local Integer WVCRTYPORI          : WVCRTYPORI = val(PARAM(4))
Local Char    WVCRNUMORI(GLONVCR) : WVCRNUMORI = PARAM(5)
Local Integer WVCRLINORI          : WVCRLINORI = val(PARAM(6))
#
Local Integer LSENS
LSENS = func STKLIB.SENSVCR(WVCRTYPORI)
#
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:STS]) = 0 : Local File STOSER    [STS] : Endif
#

CRITERE = "[F:STS]ITMREF=WITM & [F:STS]STOFCY=WFCY"
#
TIT(0) = mess(47,197,1)-WITM
NBCOL  = 1 : COL(NBCOL) = "SERNUM"
Call TEXTFIC("STOSER","SERNUM",2,TIT(NBCOL)) From OBJDIV
If find(LSENS,-1,2)
    NBCOL += 1 : COL(NBCOL) = "ISSDAT"
    Call TEXTFIC("STOSER","ISSDAT",2,TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "SDHTYP"
    Call TEXTFIC("STOSER","SDHTYP",2,TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "SDHNUM"
    Call TEXTFIC("STOSER","SDHNUM",2,TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "SDDLIN"
    Call TEXTFIC("STOSER","SDDLIN",2,TIT(NBCOL)) From OBJDIV

#    CRITERE += "&[F:STS]ISSDAT=WISSDAT"
    If WVCRNUMORI<>""
        CRITERE += "&[F:STS]SDHTYP=WVCRTYPORI"
        CRITERE += "&[F:STS]SDHNUM=WVCRNUMORI"
        CRITERE += "&[F:STS]SDDLIN=WVCRLINORI"
    Else
        CRITERE += "&[F:STS]SDHNUM<>WVCRNUMORI"
    Endif
Else
    NBCOL += 1 : COL(NBCOL) = "RCPVCRTYP"
    Call TEXTFIC("STOSER","RCPVCRTYP",2,TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "RCPVCRNUM"
    Call TEXTFIC("STOSER","RCPVCRNUM",2,TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "RCPVCRLIN"
    Call TEXTFIC("STOSER","RCPVCRLIN",2,TIT(NBCOL)) From OBJDIV
    If WVCRNUMORI<>""
        CRITERE += "&[F:STS]RCPVCRTYP=WVCRTYPORI"
        CRITERE += "&[F:STS]RCPVCRNUM=WVCRNUMORI"
        CRITERE += "&[F:STS]RCPVCRLIN=WVCRLINORI"
    Endif
    #-- On ne sélectionne que les n° pas encore sortis
    CRITERE += "&[F:STS]SDHNUM=''"
Endif
ORDRE   = "ITMREF;SERNUM"
START   = ""
VALEUR  = ""
SIZLIG  = 100
SIZCOL  = 200
Default File [STS]
Return

############################################################
# Sélection numéro de série
############################################################
$STKSELSERN
Global Char    WITM(GLONITM)       : WITM       = PARAM(1)           # hcb 110327
Global Char    WFCY(GLONFCY)       : WFCY       = PARAM(2)           # hcb 110327
Local Integer  WSERSOR             : WSERSOR    = val(PARAM(3))
Local Char     WCTLORI(1)          : WCTLORI    = PARAM(4)
Global Integer WVCRTYPORI          : WVCRTYPORI = val(PARAM(5))      # hcb 110327
Global Char    WVCRNUMORI(GLONVCR) : WVCRNUMORI = PARAM(6)           # hcb 110327
Global Integer WVCRLINORI          : WVCRLINORI = val(PARAM(7))      # hcb 110327
Local Char     WFILTRE             : WFILTRE    = PARAM(8)

If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:STS]) = 0 : Local File STOSER    [STS] : Endif
Filter [STS]                                                         # hcb 110327

CRITERE = "[F:STS]ITMREF=WITM"
If WFCY<>"" CRITERE+="&[F:STS]STOFCY=WFCY" Endif
TIT(0) = mess(47,197,1)-WITM
NBCOL  = 1 : COL(NBCOL) = "SERNUM"
Call TEXTFIC("STOSER","SERNUM",2,TIT(NBCOL)) From OBJDIV

If WCTLORI="E"
    NBCOL += 1 : COL(NBCOL) = "RCPVCRTYP"
    Call TEXTFIC("STOSER","RCPVCRTYP",2,TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "RCPVCRNUM"
    Call TEXTFIC("STOSER","RCPVCRNUM",2,TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "RCPVCRLIN"
    Call TEXTFIC("STOSER","RCPVCRLIN",2,TIT(NBCOL)) From OBJDIV
Else
    NBCOL += 1 : COL(NBCOL) = "ISSDAT"
    Call TEXTFIC("STOSER","ISSDAT",2,TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "SDHTYP"
    Call TEXTFIC("STOSER","SDHTYP",2,TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "SDHNUM"
    Call TEXTFIC("STOSER","SDHNUM",2,TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "SDDLIN"
    Call TEXTFIC("STOSER","SDDLIN",2,TIT(NBCOL)) From OBJDIV
Endif

# No série sortis
If WSERSOR=1
   CRITERE+="&[F:STS]ISSDAT<>[0/0/0]"
# No série non sortis
Else
   CRITERE+="&[F:STS]ISSDAT=[0/0/0]"
Endif

If WVCRNUMORI<>""
   # No série entrés avec la pièce origine renseignée
   If WCTLORI="E"
      CRITERE += "&[F:STS]RCPVCRTYP=WVCRTYPORI"
      CRITERE += "&[F:STS]RCPVCRNUM=WVCRNUMORI"
      CRITERE += "&[F:STS]RCPVCRLIN=WVCRLINORI"
   # No série sortis avec la pièce origine renseignée
   Else
      CRITERE += "&[F:STS]SDHTYP=WVCRTYPORI"
      CRITERE += "&[F:STS]SDHNUM=WVCRNUMORI"
      CRITERE += "&[F:STS]SDDLIN=WVCRLINORI"
   Endif
Endif

# Prise ne compte du filtre renseigné
If WFILTRE<>"" CRITERE+="&"+WFILTRE Endif

ORDRE   = "ITMREF;SERNUM"
START   = "SERNUM"                 # hcb 110327
DEFPAG  = 1                        # hcb 110327
EXPSTART = ""
VALEUR  = ""
SIZLIG  = 100
SIZCOL  = 200
Default File [STS]
Return

#--- Issue 110327
############################################################
# Sélection numéro de série géré en E/S globale en flux de sortie
############################################################
$STKSELSERG
Global Char    WITM(GLONITM)       : WITM       = PARAM(1)
Global Char    WFCY(GLONFCY)       : WFCY       = PARAM(2)
Global Decimal WSTOCOU: WSTOCOU = val(PARAM(3))
Local Integer WSERSOR             : WSERSOR    = val(PARAM(4))
Global Integer WVCRTYP             : WVCRTYP    = val(PARAM(5))
Global Char    WVCRNUM(GLONVCR)    : WVCRNUM    = PARAM(6)
Global Integer WVCRLIN             : WVCRLIN    = val(PARAM(7))
Global Integer WVCRTYPORI          : WVCRTYPORI = val(PARAM(8))
Global Char    WVCRNUMORI(GLONVCR) : WVCRNUMORI = PARAM(9)
Global Integer WVCRLINORI          : WVCRLINORI = val(PARAM(10))
Local Char    WFILTRE             : WFILTRE    = PARAM(11)

If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:STS]) = 0 : Local File STOSER    [STS] : Endif
Filter [STS]

CRITERE = "[F:STS]ITMREF=WITM"
If WFCY<>"" CRITERE+="&[F:STS]STOFCY=WFCY" Endif
If WSTOCOU<>0 CRITERE+="&[F:STS]STOCOU=WSTOCOU" Endif
TIT(0) = mess(47,197,1)-WITM
NBCOL  = 1 : COL(NBCOL) = "SERNUM"
Call TEXTFIC("STOSER","SERNUM",2,TIT(NBCOL)) From OBJDIV

NBCOL += 1 : COL(NBCOL) = "ISSDAT"
Call TEXTFIC("STOSER","ISSDAT",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "SDHTYP"
Call TEXTFIC("STOSER","SDHTYP",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "SDHNUM"
Call TEXTFIC("STOSER","SDHNUM",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "SDDLIN"
Call TEXTFIC("STOSER","SDDLIN",2,TIT(NBCOL)) From OBJDIV
If WVCRNUMORI<>""
   NBCOL += 1 : COL(NBCOL) = "RCPVCRTYP"
   Call TEXTFIC("STOSER","RCPVCRTYP",2,TIT(NBCOL)) From OBJDIV
   NBCOL += 1 : COL(NBCOL) = "RCPVCRNUM"
   Call TEXTFIC("STOSER","RCPVCRNUM",2,TIT(NBCOL)) From OBJDIV
   NBCOL += 1 : COL(NBCOL) = "RCPVCRLIN"
   Call TEXTFIC("STOSER","RCPVCRLIN",2,TIT(NBCOL)) From OBJDIV
Endif
#--- Si pièce origine renseignée
If WVCRNUMORI<>""
   CRITERE += "&(([F:STS]ISSDAT=[0/0/0]"
   CRITERE += "&[F:STS]RCPVCRTYP=WVCRTYPORI"
   CRITERE += "&[F:STS]RCPVCRNUM=WVCRNUMORI"
   CRITERE += "&[F:STS]RCPVCRLIN=WVCRLINORI)"
Else
   CRITERE += "&(([F:STS]ISSDAT=[0/0/0]"
   CRITERE += "&[F:STS]SDHNUM='')"
Endif
#---  Si no série sortis
If WSERSOR=1
   CRITERE += "|([F:STS]ISSDAT<>[0/0/0]"
   CRITERE += "&[F:STS]SDHTYP=WVCRTYP"
   CRITERE += "&[F:STS]SDHNUM=WVCRNUM"
   CRITERE += "&[F:STS]SDDLIN=WVCRLIN)"
Endif
CRITERE += ")"

# Prise ne compte du filtre renseigné
If WFILTRE<>"" CRITERE+="&"+WFILTRE Endif
ORDRE   = "ITMREF;SERNUM"
START   = ""
EXPSTART = ""
VALEUR  = ""
SIZLIG  = 100
SIZCOL  = 200
DEFPAG  = 1
Default File [STS]
Return
#--- End issue 110327
#                                                                         # hcb 110327-pck deb
############################################################
# Sélection numéro de série
############################################################
$STKSELSERI
Local Char    WFCY(GLONFCY)       : WFCY       = PARAM(1)
Local Char    WITM(GLONITM)       : WITM       = PARAM(2)
#
If clalev([F:ATZ]) = 0 : Local File ATABZON   [ATZ]  : Endif
If clalev([F:STS]) = 0 : Local File STOSER    [STS] : Endif
#

CRITERE = "[F:STS]ITMREF=WITM & [F:STS]STOFCY=WFCY"
#
TIT(0) = mess(47,197,1)-WITM
NBCOL  = 1 : COL(NBCOL) = "SERNUM"
Call TEXTFIC("STOSER","SERNUM",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "ISSDAT"
Call TEXTFIC("STOSER","ISSDAT",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "SDHTYP"
Call TEXTFIC("STOSER","SDHTYP",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "SDHNUM"
Call TEXTFIC("STOSER","SDHNUM",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "SDDLIN"
Call TEXTFIC("STOSER","SDDLIN",2,TIT(NBCOL)) From OBJDIV

ORDRE   = "ITMREF;SERNUM"
START   = ""
VALEUR  = ""
SIZLIG  = 100
SIZCOL  = 200
Default File [STS]
Return
#                                                                         # hcb 110327-pck fin
############################################################
# Sélection analyse qualité
############################################################
$STKSELQLY
Local Char    WFCY(GLONFCY)   : WFCY = PARAM(1)
Local Char    WITM(GLONITM)   : WITM = PARAM(2)
Local Char    WFILTRE(100)    : WFILTRE=PARAM(3)

CRITERE(1)="1=1"
If WFCY<>""
# Issue 112726 - 2015-11-24 by MAE
    #CRITERE(1)+=" & [F:QLH]STOFCY=[L]WFCY"
    CRITERE(1)+=" & [F:QLH]STOFCY='"+[L]WFCY+"'"
Endif
If WITM<>""
    # Issue 112726 - 2015-11-24 by MAE
    #CRITERE(1)+=" & [F:QLH]ITMREF=[L]WITM"
    CRITERE(1)+=" & [F:QLH]ITMREF='"+[L]WITM+"'"
Endif
If WFILTRE<>""
    CRITERE(1)+=" & "+WFILTRE
Endif
If dim([M]VALFLGO)>0 & dim([M]VALFLGN)>0
    If [M]VALFLGO=1
        CRITERE(1)+=" & [F:QLH]VALFLG<>2"
    If [M]VALFLGN=1
        CRITERE(1)+=" & [F:QLH]VALFLG<>1"
    Endif
Endif
Endif
START="VCRNUM"
OBJET ="STQ"
OPTIONS="#"
Return

$VERF_STKSELQLY
Return

#########################################################################
# STKSELBOML : Sélection entete nomenclature
#              Avec restitution et affichage de l alternative
# Paramètres E : LITM = Compose
#                LALT = Alternative
#                LALTT= Type Alternative
#                LABR = Abreviation de l ecran
#                LZON = Zone ecran qui contient le numéro d alternative
#                LLIG = Numero de ligne du tableau ecran
#
#########################################################################
$STKSELBOML
Local Char    LITM(GLONITM)   : LITM  =     PARAM(1)
Local Integer LALT            : LALT  = val(PARAM(2))
Local Integer LALTT           : LALTT = val(PARAM(3))
Local Char    LABR            : LABR  =     PARAM(4)
Local Char    LZON            : LZON  =     PARAM(5)
Local Integer LLIG            : LLIG  = val(PARAM(6))
Local Char    LFCY            : LFCY  =     PARAM(7)
Local Char    WFCY
Raz WFCY
#
If clalev([F:BOH]) = 0 : Local File BOM         [BOH] : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON     [ATZ] : Endif
If clalev([F:TBO]) = 0 : Local File TABBOMALT   [TBO] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT  [ITF] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER   [ITM] : Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA     [AXX] : Endif  # FGR 02/10/2009 : X3SUIVI57935

If clalev([M:SMO1])
# FGR 02/10/2009 : X3SUIVI57935
#    Link [BOH] With [TBO]TBO0 = [F:BOH]BOMALTTYP;[BOH]BOMALT,
#&                   [ITF]ITF0 = [BOH]ITMREF;LFCY,
#&                   [ITM]ITM0 = GSOCIETE;[BOH]ITMREF
#&              As [NEW]
#&              Where ([TBO]FCY = LFCY | [TBO]FCY = WFCY) &
#&                    [ITF]STOFCY = LFCY &
#&                    [ITM]PHAFLG <> 2
# FGR 16/12/2009 X3SUIVI60964 manquait GLANGUE
    Link [BOH] With [TBO]TBO0 = [F:BOH]BOMALTTYP;[BOH]BOMALT,
&                   [ITF]ITF0 = [BOH]ITMREF;LFCY,
&                   [ITM]ITM0 = GSOCIETE;[BOH]ITMREF,
&                   [AXX]AXX0="BOM";"BOMDESAXX";GLANGUE;[F:BOH]IDENT1;num$([F:BOH]BOMALTTYP)
&              As [NEW]
&              Where ([TBO]FCY = LFCY | [TBO]FCY = WFCY) &
&                    [ITF]STOFCY = LFCY
#&                    [ITM]PHAFLG <> 2 #MAE, bg 85393
Else
# FGR 02/10/2009 : X3SUIVI57935
#    Link [BOH] With [TBO]TBO0 = [F:BOH]BOMALTTYP;[BOH]BOMALT ,
#&                   [ITF]ITF0 = [BOH]ITMREF;LFCY ,
#&                   [ITM]ITM0 = [BOH]ITMREF
#&              As [NEW]
#&              Where ([TBO]FCY = LFCY | [TBO]FCY = WFCY) &
#&                    [ITF]STOFCY = LFCY &
#&                    [ITM]PHAFLG <> 2
# FGR 16/12/2009 X3SUIVI60964 manquait GLANGUE
    Link [BOH] With [TBO]TBO0 = [F:BOH]BOMALTTYP;[BOH]BOMALT ,
&                   [ITF]ITF0 = [BOH]ITMREF;LFCY ,
&                   [ITM]ITM0 = [BOH]ITMREF,
&                   [AXX]AXX0="BOM";"BOMDESAXX";GLANGUE;[F:BOH]IDENT1;num$([F:BOH]BOMALTTYP)
&              As [NEW]
&              Where ([TBO]FCY = LFCY | [TBO]FCY = WFCY) &
&                    [ITF]STOFCY = LFCY
#&                    [ITM]PHAFLG <> 2 #MAE, bg 85393
Endif

Default File [NEW]

TIT(0) = mess(414,198,1) # Sélection entête nomenclature

NBCOL  += 1 : COL(NBCOL) = "ITMREF"
Call TEXTFIC("BOM",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL  += 1 : COL(NBCOL) = "BOMALT"
Call TEXTFIC("BOM",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
# FGR 02/10/2009 : X3SUIVI57935
#NBCOL += 1 : COL(NBCOL) = "BOMDES"
#Call TEXTFIC("BOM",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "BOMDESAXX"
Call TEXTFIC("BOM",COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
COL(NBCOL) = "[F:AXX]TEXTE"

SIZLIG  = 140
SIZCOL  = 180
If LITM <> ""
   CRITERE = "ITMREF >= LITM"
Endif

If LALT <> 0
   If CRITERE <> ""
      CRITERE = CRITERE + "& BOMALT >= LALT"
   Else
      CRITERE = "BOMALT >= LALT"
   Endif
Endif
If LALTT  <> 0
   If CRITERE <> ""
      CRITERE = CRITERE + "& BOMALTTYP=LALTT"
   Else
      CRITERE = "BOMALTTYP=LALTT"
   Endif
Endif

ORDRE   = "ITMREF;BOMALT"
START  = "ITMREF"
EXPSTART = "ITMREF=LITM"
VALEUR = LITM

Default File [NEW]
# Issue 56194 - 2017-10-10 by MAE : ajout de la pagination
DEFPAG = 1
Return

$VERF_STKSELBOML

If evalue("dim([M:"+LABR+"]"+LZON+")")>0
   Assign " [M:"+LABR+"]"+LZON+"("+num$(LLIG)+")"  With [F:BOH]BOMALT
Endif
# ligne rajoutée car bug moteur
If LABR = "BBY0" | LABR = "DBY0"
   If evalue("dim([M:"+LABR+"]ITMREF)")>0
      Assign " [M:"+LABR+"]ITMREF("+num$(LLIG)+")"    With [F:BOH]ITMREF
   Endif
Endif
Default Mask "["+LABR+"]"
Affzo [M]

Return

#########################################################################
# STKSELPRP                       Selection paramétrage code préparation
#########################################################################
$STKSELPRP

Local Char LFIC(10)
LFIC = "TABPRECOD"

If clalev([F:PRC])  = 0 : Local File TABPRECOD [PRC] : Endif
If clalev([F:FCY])  = 0 : Local File FACILITY  [FCY] : Endif

TIT(0) = mess(349,184,1)

NBCOL = 1 : COL(NBCOL) = "[F:PRC]STOFCY"
Call TEXTFIC(LFIC,"STOFCY",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:FCY]FCYNAM"
Call TEXTFIC("FACILITY","FCYNAM",2,TIT(NBCOL)) From OBJDIV

Link [PRC] With [FCY]FCY0=[F:PRC]STOFCY
&          As [LNK]

ORDRE   = "STOFCY"
CRITERE = "[F:PRC]NUMCRIT=0&[F:PRC]PRECOD=''"
START   = "STOFCY"
SIZLIG  = 100
SIZCOL  = 200
Default File [LNK]
Return

#########################################################################
# STKSELSPH                                               Sélection Colis
#########################################################################
$STKSELSPH
Local Integer LTYP         : LTYP  =  val(PARAM(1))
Local Char    LNUM         : LNUM  =      PARAM(2)
Local Char    LNUME        : LNUME =      PARAM(3)
Local Char    LFCY         : LFCY  =      PARAM(4)
Local Char LFIC(10)
LFIC = "SPACK"
If clalev([F:SPH])  = 0 : Local File SPACK     [SPH]  : Endif
If clalev([F:ATZ])  = 0 : Local File ATABZON   [ATZ]  : Endif

TIT(0) = mess(294,195,1)

NBCOL = 1  : COL(NBCOL) = "PACNUM"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "PCK"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "BPCORD"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "PREUSR"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "SCCCOD"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "VCRTYP"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "VCRNUM"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV

Local Char WLISTE(15)
WLISTE = ""

ORDRE   = "VCRNUM;PACNUM"
CRITERE = "[F:SPH]STOFCY=LFCY"
If LTYP <> 0
   CRITERE = CRITERE+"&[F:SPH]VCRTYP=LTYP"
Endif
If LNUM <> ""
   CRITERE = CRITERE+"&[F:SPH]VCRNUM>=LNUM"
Endif
If LNUME <> ""
   CRITERE = CRITERE+"&[F:SPH]VCRNUM<=LNUME"
Endif
START   = "PACNUM"
SIZLIG  = 100
SIZCOL  = 200
Default File [SPH]
Return

$VERF_STKSELSPH
Return

############################################################
# STKSELADD                        Sélection adresses tiers
############################################################
# - AZC      = Code adresse
# - PARAM(1) = Tiers
# - PARAM(2) = Type adresse
############################################################
$STKSELADD
Local Char    LADD(GLONADR)
LADD = VALEUR

If !clalev([F:ATZ])  Local File ATABZON  [ATZ] : Endif

CRITERE="BPATYP="+PARAM(2)+"&BPANUM=PARAM(1)"
OBJET=""
TIT(0) = mess(10,195,1)
NBCOL  = 0
NBCOL += 1 : COL(NBCOL) = "BPANUM"
Call TEXTFIC("BPSUPPLIER","BPSNUM",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "BPAADD"
Call TEXTFIC("BPADDRESS","BPAADD",1,TIT(NBCOL)) From OBJDIV
START   = "BPAADD"
VALEUR  = LADD
Default File [BPA]

Return

# Issue 67963 - 2017-12-20 by MAE : selection sur les identifiants de contenant interne
#########################################################################
# STKSELLPN                                               Sélection LPN
#########################################################################
$STKSELLPN
Local Char    LFCY(GLONFCY)      : LFCY   =      PARAM(1)
Local Char    LTCTR(GLONTCTR)    : LTCTR  =      PARAM(2)
Local Char    LLOC(GLONLOC)      : LLOC   =      PARAM(3)

Local Char LFIC(10)
Local Char CRITERE(250)

Local Integer WSTOCK



LFIC = "LPN"
If clalev([F:LPN])  = 0 : Local File LPN     [LPN]  : Endif
If clalev([F:STO])  = 0 : Local File STOCK     [STO]  : Endif


Default File [LPN]

TIT(0) = mess(306,195,1)

NBCOL = 1  : COL(NBCOL) = "LPNNUM"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "TCTRNUM"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "LOC"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "LOCTYP"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:LPN]MONITMFLG,1,1)"
Call TEXTFIC(LFIC,"MONITMFLG",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:LPN]MONLOTFLG,1,1)"
Call TEXTFIC(LFIC,"MONLOTFLG",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:LPN]LPNSTAT,2787,1)"
Call TEXTFIC(LFIC,"LPNSTAT",3,TIT(NBCOL)) From OBJDIV

ORDRE   = "LPNNUM"
CRITERE = "[F:LPN]STOFCY='"+LFCY+"' & [F:LPN]ENAFLG = 2"
If LTCTR <> ""
   CRITERE = CRITERE+"&[F:LPN]TCTRNUM='"+LTCTR+"'"
Endif
If LLOC <> ""
   CRITERE = CRITERE+"&([F:LPN]LOC='' or [F:LPN]LOC='"+LLOC+"')"
Endif
START   = "LPNNUM"
SIZLIG  = 100
SIZCOL  = 200
DEFPAG = 1
Default File [LPN]
Return

$VERF_STKSELLPN
Return

