#<AdxTL>@(#)8.0.0.0 $Revision$
#########################################################################
# Traitement STKSEL - Librairie d'actions de sélection stock            #
#########################################################################

#########################################################################
# Actions de type sélection liste
#------------------------------------------------------------------------
# STKSELUOMN  : Sélection unite de mesure
# STKSELLOCT  : Sélection emplacement pour terminaux portables
# STKSELDBY   : Sélection d'un désassemblage
# STKSELPRC   : Sélection code préparation
# STKSELSTOL  : Sélection ligne de stock pour resynchronisation no série   : # Issue 110327
# STKSELSTSL  : Sélection no série pour resynchronisation no série         : # Issue 110327
#########################################################################

#########################################################################
# Actions de type sélection table
#------------------------------------------------------------------------
# STKSELTRS   : Sélection transaction stock
# SELITMF     : Sélection article + filtres
# SELITF      : Sélection article site avec filtres divers
# SELITFITW   : Sélection article site article depot avec filtres divers
# SELITP      : Sélection article fournisseur
# STKSELSTO   : Sélection ligne de stock
# STKSELSTOT  : Sélection ligne de stock pour terminaux portables
# STKSELSTOS  : Sélection ligne de stock pour resynchronisation no séries  : # Issue 110327
# STKSELLOT   : Sélection lot
# STKSELMAJS  : Sélection versions majeures pour sortie  : # TS 106217
# STKSELMAJ   : Sélection historiques versions majeures
# STKSELMIN   : Sélection historiques versions mineures
# STKSELLOTO  : Sélection lot d'une pièce origine
# STKSELLOTD  : Sélection lot destinataire
# STKSELLOTS  : Sélection lot + filtre statut
# STKSELLOTM  : Sélection lot sur bornes article
# STKSELSLOM  : Sélection s/lot sur bornes article et bornes lot
# STKSELBPLN  : Sélection lot fournisseur
# STKSELSTA   : Sélection statut
# STKSELSER   : Sélection numéros de série
# STKSELSERN  : Sélection numéros de série
# STKSELSERG  : Sélection numéros de série en E/S globale flux de sortie   : # Issue 110327
# STKSELQLY   : Sélection demande d'analyse
# STKSELBOML  : Sélection entête nomenclature avec restitution alternative
# STKSELPRP   : Sélection paramétrage code préparation
# STKSELSPH   : Sélection colis
# STKSELADD   : Sélection adresse tiers pour terminaux portables
# STKSELLPN   : Sélection identifiant contenant interne
#########################################################################

$ACTION
Case ACTION
  When "SEL_LISTE"      : Gosub SEL_LISTE
  When "VERF_LISTE"     : Gosub VERF_LISTE
  When "SEL_TABLE"      : Gosub SEL_TABLE
  When "BOUT_TABLE"     : Gosub BOUT_TABLE
  When "VERF_TABLE"     : Gosub VERF_TABLE
  When "FIN_TABLE"      : Gosub FIN_TABLE
Endcase
Return

#########################################################################
$SEL_LISTE
Case LISTE
  When "STKSELUOMN"    : Gosub STKSELUOMN
  When "STKSELLOCT"    : Gosub STKSELLOCT
  When "STKSELDBY"     : Gosub STKSELDBY
  When "STKSELPRC"     : Gosub STKSELPRC
  When "STKSELSTOL"    : Gosub STKSELSTOL   : # Issue 110327
  When "STKSELSTSL"    : Gosub STKSELSTSL   : # Issue 110327
Endcase
Return

#########################################################################
$VERF_LISTE
Case LISTE
  When "STKSELDBY"     : Gosub VERF_STKSELDBY
Endcase
Return

#########################################################################
$SEL_TABLE
Case TABLE
  When "STKSELTRS"     : Gosub STKSELTRS
  When "SELITMF"       : Gosub S_SELITMF
  When "SELITF"        : Gosub S_SELITF
  When "SELITFITW"     : Gosub S_SELITFITW
  When "SELITP"        : Gosub S_SELITP
  When "STKSELSTO"     : Gosub STKSELSTO
  When "STKSELSTOT"    : Gosub STKSELSTOT
  When "STKSELSTOS"    : Gosub STKSELSTOS   : # Issue 110327
  When "STKSELLOT"     : Gosub STKSELLOT
  When "STKSELMAJS"    : Gosub STKSELMAJS   : # TS 106217
  When "STKSELMAJ"     : Gosub STKSELMAJ      # hcb 71276
  When "STKSELMIN"     : Gosub STKSELMIN      # hcb 71276
  When "STKSELLOTO"    : Gosub STKSELLOTO
  When "STKSELLOTS"    : Gosub STKSELLOTS
  When "STKSELLOTD"    : Gosub STKSELLOTS
  When "STKSELLOTM"    : Gosub STKSELLOTM
  When "STKSELSLOM"    : Gosub STKSELSLOM
  When "STKSELBPLN"    : Gosub STKSELBPLN
  When "STKSELSTA"     : Gosub STKSELSTA
  When "STKSELSER"     : Gosub STKSELSER
  When "STKSELSERN"    : Gosub STKSELSERN
  When "STKSELSERG"    : Gosub STKSELSERG   : # Issue 110327
  When "STKSELSERI"    : Gosub STKSELSERI   : # hcb 110327-pck
  When "STKSELQLY"     : Gosub STKSELQLY
  When "STKSELBOML"    : Gosub STKSELBOML
  When "STKSELPRP"     : Gosub STKSELPRP
  When "STKSELSPH"     : Gosub STKSELSPH
  When "STKSELADD"     : Gosub STKSELADD
  When "STKSELLPN"     : Gosub STKSELLPN
Endcase
Return

#########################################################################
$BOUT_TABLE
Case TABLE
  When "SELITMF"       : Gosub B_SELITMF
  When "SELITF"        : Gosub B_SELITF
  When "SELITFITW"     : Gosub B_SELITFITW
  When "SELITP"        : Gosub B_SELITP
Endcase
Return

#########################################################################
$VERF_TABLE
Case TABLE
  When "STKSELSTO"     : Gosub VERF_STKSELSTO
  When "STKSELSTOT"    : Gosub VERF_STKSELSTOT
  When "STKSELSTOS"    : Gosub VERF_STKSELSTOS        : # Issue 110327
  When "STKSELLOT"     : Gosub VERF_STKSELLOT
  When "STKSELSTOS"    : Gosub VERF_STKSELSTOS        : # Issue 110327
  When "STKSELMIN"     : Gosub VERF_STKSELMIN
  When "STKSELMAJ"     : Gosub VERF_STKSELMAJ
  When "STKSELMAJS"    : Gosub VERF_STKSELMAJS        : # TS 106217
  When "STKSELLOTO"    : Gosub VERF_STKSELLOTO          # hcb 65496
  When "STKSELLOTS"    : Gosub VERF_STKSELLOTO          # hcb 65496
  When "STKSELLOTD"    : Gosub VERF_STKSELLOTD
  When "STKSELQLY"     : Gosub VERF_STKSELQLY
  When "STKSELBOML"    : Gosub VERF_STKSELBOML
  When "STKSELSPH"     : Gosub VERF_STKSELSPH
Endcase
Return

#########################################################################
$FIN_TABLE
Return

#########################################################################

#########################################################################
# STKSELUOMN : Sélection unite de mesure
#########################################################################
# Paramètres E : LTYP = Type unite (2=vente, 3=achat )
#                LITM = 1 : en complement de  l'US et des UC de l'article
#
# Prérequis    : Ces tables doivent être ouvertes   ITMMASTER
#                                                   ITMBPC
#                                                   ITMBPS
#########################################################################
$STKSELUOMN
Local Integer  LTYP : LTYP = val(PARAM(1))
Local Integer  LITM : LITM = val(PARAM(2))

#
Local Char     WUNI(GLONUOM)
Local Decimal  WCOE
Local Char     WUCV(GLONUOM)
Local Integer  I, J, K, L
#
Local Char    W_PCU1(GLONUOM)(1..20)
Local Char    W_COE (20)(1..20)
Local Char    W_PCU2(GLONUOM)(1..20)
#

# Chargement unités article maitre
If LITM = 1 & clalev([F:ITM]) <> 0
  WUNI  = [F:ITM]STU     : WCOE  = 0                  : WUCV = ""
  Gosub LOA_UNI
     For I = 0 To dim([F:ITM]PCU)-1
         WUNI = [F:ITM]PCU(I) : WCOE = [F:ITM]PCUSTUCOE(I) : WUCV = [F:ITM]STU
         Gosub LOA_UNI
     Next I
Endif
# Chargement unités ventes
If LTYP = 2 & clalev([F:ITU]) <> 0
  WUNI = [F:ITU]PCU1 : WCOE = [F:ITM]SAUSTUCOE*[F:ITU]PCUSAUCOE1 : WUCV = [F:ITM]STU
  Gosub LOA_UNI
  WUNI = [F:ITU]PCU2 : WCOE = [F:ITM]SAUSTUCOE*[F:ITU]PCUSAUCOE2 : WUCV = [F:ITM]STU
  Gosub LOA_UNI
Endif
# Chargement unités achats
If LTYP = 3 & clalev([F:ITP]) <> 0
  WUNI = [F:ITP]PCU  : WCOE = arr([F:ITP]PCUPUUCOE*[F:ITP]PUUSTUCOE,10^-6) : WUCV = [F:ITM]STU
  Gosub LOA_UNI
  WUNI = [F:ITP]PUU  : WCOE = [F:ITP]PUUSTUCOE : WUCV = [F:ITM]STU
  Gosub LOA_UNI
Endif
# Chargement unités achats article et article fournisseur
If LTYP = 3 & clalev([F:ITP]) <> 0
  WUNI = [F:ITM]PUU  : WCOE = [F:ITM]PUUSTUCOE : WUCV = [F:ITM]STU
  Gosub LOA_UNI
  If [F:ITM]PUU <> [F:ITP]PUU
       WUNI = [F:ITP]PUU  : WCOE = [F:ITP]PUUSTUCOE : WUCV = [F:ITM]STU
       Gosub LOA_UNI
   Endif
Endif

TIT(0) = mess(43,195,1)
Return

#########################################################################
$LOA_UNI
If WUNI <> ""
  If J < dim(W_PCU1)
    L = 0
    For K = 1 To J
      If W_PCU1(K) = WUNI & W_COE(K) = num$(WCOE)
        L = 1
        Break
      Elsif WUNI = WUCV
        L = 1
        Break
      Endif
    Next K
    If L = 0
      J += 1
      W_PCU1(J) = WUNI
      If WCOE = 0
        W_COE(J) = ""
      Else
        W_COE (J) = num$(WCOE)
      Endif
      W_PCU2(J) = WUCV
      NBTEX +=1
      TEX(NBTEX) = [L]WUNI
      If WUCV<>""  TEXTE(NBTEX) = TEX(NBTEX)-"="-W_COE(J)-WUCV : Endif
    Endif
  Endif
Endif
Return

#########################################################################
# STKSELLOCT : Sélection emplacement pour terminaux portables
#########################################################################
# Paramètres E : LFCY = Site
#                LITM = Article
#                PARAM(3) = Catégories emplacement autorisées
#
# Prérequis    : Ces tables doivent être ouvertes   STOCK
#
#########################################################################
$STKSELLOCT
Local Char  LFCY : LFCY = PARAM(1)
Local Char  LITM : LITM = PARAM(2)

Local Char     CRITERE(240)
Local Char     WLOC(GLONLOC)
Local Char     WTABLOC(GLONLOC)(1..50)
Local Integer  I,J,WCAT

If !clalev([F:STC]) Local File STOLOC [STC] Endif

If PARAM(3)="" PARAM(3)="1234" Endif

CRITERE  = "[F:STO]ITMREF=LITM&[F:STO]STOFCY=LFCY"
CRITERE += "&[F:STO]CUNLOKFLG<>2"
CRITERE += "&([F:STO]QTYSTU-[F:STO]CUMALLQTY-[F:STO]CUMWIPQTY)>0"
If len(PARAM(3)) > 0
  CRITERE += "&find([F:STO]LOCCAT"
  For WCAT = 1 To len(PARAM(3))
    CRITERE += ","
    CRITERE += mid$(PARAM(3),WCAT,1)
  Next WCAT
  CRITERE += ")"
Endif

For [STO]STO4 Hint Key STO3 Where evalue(CRITERE)
   WLOC = [F:STO]LOC
   Gosub LOA_LOC
Next

TIT(0) = mess(22,123,1)

Return

#########################################################################
$LOA_LOC

If WLOC<>"" & J<dim(WTABLOC)
   If J=0 | !find(WLOC,WTABLOC(1..J))
      Read [STC]STC0=[F:STO]STOFCY;[F:STO]LOC
      If !fstat
         J += 1
         WTABLOC(J) = WLOC
         NBTEX +=1
         TEX(NBTEX) = WLOC
         TEXTE(NBTEX) = format$("K:10X",TEX(NBTEX))-format$("K:3X",[F:STC]LOCTYP)-mess([F:STC]LOCCAT,2710,1)
      Endif
   Endif
Endif

Return

#########################################################################
# STKSELDBY       Selection sur fichier SMVTH   numero de desassemblage
#########################################################################
$STKSELDBY
Local Char    LFCY(GLONFCY)   : LFCY =      PARAM(1)
Local Integer LTYP            : LTYP =      val(PARAM(2))
Local Char    LVCR            : LVCR =      PARAM(3)
Local Integer Z
Local Char SZTIT
Z = 0
SZTIT = ""
If clalev ([F:SMH1])=0 Local File SMVTH [SMH1] Endif

Filter [SMH1] Where [F:SMH1]STOFCY = LFCY & [F:SMH1]VCRTYPORI = LTYP & [F:SMH1]VCRNUMORI = LVCR Order By [F:SMH1]VCRNUM Asc

For [SMH1] With Nohint
    If Z >= dim(TEX) - 1 : Break : Endif
    Z += 1
    TEX(Z)   = [F:SMH1]VCRNUM
    TEXTE(Z) = [F:SMH1]VCRNUM
$NEXTLIS
Next

Filter [SMH1]
ORDRE   = "STOFCY;VCRNUM"

NBTEX = Z
SZTIT = mess(33,725,1) #desassemblage
TIT = left$(SZTIT, 30)

Return

$VERF_STKSELDBY
Local Char WVCRNUM
GCONSULT = 2
#WVCRNUM = VALEUR
WVCRNUM = TEX(CHOIX)
Call OBJET("DBY",WVCRNUM,"32") From GOBJET
GCONSULT = 0

Return

#########################################################################
# STKSELPRC                                   Selection Code préparation
#########################################################################
$STKSELPRC

Local Char    LFCY   : LFCY=PARAM(1)
Local Integer Z      : Z=0

If clalev([F:PRC])  = 0 : Local File TABPRECOD [PRC] : Endif
If clalev([F:ATZ])  = 0 : Local File ATABZON   [ATZ] : Endif

For [PRC] Where STOFCY=LFCY & find(NUMCRIT,1,2,3,4,5)
   If Z >= dim(TEX)-1 : Break : Endif
   If !find([F:PRC]PRECOD,TEX(0..dim(TEX)-1))
      Z += 1
      TEX(Z)   = [F:PRC]PRECOD
      TEXTE(Z) = format$("K:5X",TEX(Z))-[F:PRC]PREDES
   Endif
Next
NBTEX  = Z
ORDRE  = "PRECOD;PREDES"
TIT(0) = mess(226,184,1)-LFCY
Return

#--- Issue 110327
#########################################################################
# STKSELSTOL : Sélection ligne de stock pour resynchronisation no séries
#########################################################################
# Paramètres E : LFCY    = Site
#                LITM    = Article
#                LSTOCOU = Chrono stock exclu
#
#########################################################################
$STKSELSTOL
Local Char    LFIC(10)        : LFIC = "STOCK"
Local Char    LFCY(GLONFCY)   : LFCY = PARAM(1)
Local Char    LITM(GLONITM)   : LITM = PARAM(2)
Local Decimal LSTOCOU         : LSTOCOU = val(PARAM(3))
Local Integer I, NBT
Local Char     CRITERE(240)

If clalev([F:STO]) = 0 : Local File STOCK      [STO] : Endif
If clalev([F:SER]) = 0 : Local File STOSER     [SER] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON    [ATZ] : Endif

If [F:ITM]ITMREF<>LITM
    Read [ITM]ITM0=LITM
Endif
If [F:ITF]ITMREF<>LITM | [F:ITF]STOFCY<>LFCY
    Read [ITF]ITF0=LITM;LFCY
Endif

NBTEX=1
TIT(0) = mess(145,198,1)-mess(498,197,1)-LFCY-mess(80,197,1)-LITM

CRITERE = "[F:STO]STOFCY=LFCY&[F:STO]ITMREF=LITM&[F:STO]STOCOU<>LSTOCOU"

# Chargement des chronos stock pour lesquels il manque des no série
For [STO] Where evalue(CRITERE)
  Filter [STS] Where ITMREF=[F:STO]ITMREF & STOCOU=[F:STO]STOCOU & ISSDAT=[0/0/0]
  NBSER = rowcount([F:STS])
  Filter [STS]
  If NBSER < [F:STO]QTYSTU
    TEX(NBTEX)   = num$([F:STO]STOCOU)
    TEXTE(NBTEX) = format$("K:10X",TEX(NBTEX))-":"-mess(677,197,1)-format$("N:5.0",[F:STO]QTYSTU)-mess(458,197,1)-mess(453,197,1)-format$("N:5.0",NBSER)
    If [F:ITM]LOTMGTCOD > 1
      TEXTE(NBTEX) -= mess(43,197,1)-format$("K:15X",[F:STO]LOT)
      If [F:ITM]LOTMGTCOD = 4
        TEXTE(NBTEX) -= format$("K:5X",[F:STO]SLO)
      Endif
    Endif
    TEXTE(NBTEX) -= mess(702,197,1)-format$("K:3X",[F:STO]STA)
    If [F:ITF]LOCMGTCOD > 1
      TEXTE(NBTEX) -= mess(672,197,1)-format$("K:10X",[F:STO]LOC)
    Endif
    NBTEX +=1
    If NBTEX>=dim(TEX)-1 : Break : Endif
  Endif
Next

Return

#########################################################################
# STKSELSTSL : Sélection no série pour resynchronisation no séries
#########################################################################
# Paramètres E : LFCY    = Site
#                LITM    = Article
#                LSTOCOU = Chrono stock exclu
#
#########################################################################
$STKSELSTSL
Local Char    LFIC(10)        : LFIC = "STOCK"
Local Char    LFCY(GLONFCY)   : LFCY = PARAM(1)
Local Char    LITM(GLONITM)   : LITM = PARAM(2)
Local Decimal LSTOCOU         : LSTOCOU = val(PARAM(3))
Local Integer I, NBT
Local Char     CRITERE(240)

If clalev([F:STO]) = 0 : Local File STOCK      [STO] : Endif
If clalev([F:SER]) = 0 : Local File STOSER     [SER] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON    [ATZ] : Endif

If [F:ITM]ITMREF<>LITM
    Read [ITM]ITM0=LITM
Endif
If [F:ITF]ITMREF<>LITM | [F:ITF]STOFCY<>LFCY
    Read [ITF]ITF0=LITM;LFCY
Endif

NBTEX=1
TIT(0) = mess(578,200,1)-mess(498,197,1)-LFCY-mess(80,197,1)-LITM

CRITERE = "[F:STO]STOFCY=LFCY&[F:STO]ITMREF=LITM&[F:STO]STOCOU<>LSTOCOU"

# Chargement des no séries liés à des chronos stock pour lesquels il y en a trop
For [STO] Where evalue(CRITERE)
  Filter [STS] Where ITMREF=[F:STO]ITMREF & STOCOU=[F:STO]STOCOU & ISSDAT=[0/0/0]
  NBSER = rowcount([F:STS])
  If NBSER > [F:STO]QTYSTU
    For [STS]
      TEX(NBTEX)   = [F:STS]SERNUM
      TEXTE(NBTEX) = format$("K:20X",TEX(NBTEX))-":"
      If [F:ITM]LOTMGTCOD > 1
        TEXTE(NBTEX) -= mess(43,197,1)-format$("K:15X",[F:STO]LOT)
        If [F:ITM]LOTMGTCOD = 4
          TEXTE(NBTEX) -= format$("K:5X",[F:STO]SLO)
        Endif
      Endif
      TEXTE(NBTEX) -= mess(702,197,1)-format$("K:3X",[F:STO]STA)
      If [F:ITF]LOCMGTCOD > 1
        TEXTE(NBTEX) -= mess(672,197,1)-format$("K:10X",[F:STO]LOC)
      Endif
      TEXTE(NBTEX) -= mess(50,196,1)-format$("K:10X",num$([F:STO]STOCOU))
      NBTEX +=1
      If NBTEX>=dim(TEX)-1 : Break : Endif
    Next
  Endif
  Filter [STS]
Next

Return
#--- End issue 110327

#########################################################################
# STKSELTRS                                  Selection Transaction Stock
#########################################################################
$STKSELTRS

Local Integer LTYP
Local Char    LFIC(10)
LTYP = val(PARAM(1))
LFIC = "STKTRS"

If clalev([F:SRT])  = 0 : Local File STKTRS    [SRT] : Endif
If clalev([F:ATZ])  = 0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:AXX])  = 0 : Local File ATEXTRA   [AXX] : Endif

Link [SRT] With
& [AXX]AXX0="STKTRS";"DESAXX";GLANGUE;[F:SRT]SRTTYPCAR;[F:SRT]SRTNUM
& As [SRT_]

TIT(0) = mess(209,184,1)+"  "+mess(LTYP,2721,1)

NBCOL = 1 : COL(NBCOL) = "SRTNUM"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"
Call TEXTFIC(LFIC,"DESAXX",2,TIT(NBCOL)) From OBJDIV

ORDRE   = "SRTNUM;[F:AXX]TEXTE"
CRITERE = "[F:SRT]SRTTYP=LTYP"
START   = "SRTNUM"
SIZLIG  = 100
SIZCOL  = 200
Default File [SRT_]
Return

##########################################################################
# Action SELITMF : Sélection des articles avec filtres et options        #
# ---------------------------------------------------------------------- #
#   zone courante AZC  : Référence article                               #
#   PARAM(1) = FILTRE  : Critères pour le filtre                         #
#   PARAM(2) = OPTIONA : Options de l'objet ITM                          #
##########################################################################
$S_SELITMF
If PARAM(1)="" PARAM(1)="1=1" : Endif
CRITERE(1)=PARAM(1)
OPTIONS=PARAM(2)
OBJET="ITM"

$B_SELITMF
Return

#########################################################################
# SELITF : Sélection article site
#          Particularité pour le parametre TCLCOD
#             alimentation possible en associant les valeurs uivantes :
#             les valeurs associées sont interpretrées avec
#             l’opérateur logique « ou »)
#          ex : valeur "12" -->  liste des articles Acheté ou Fabriqué
#          Acheté         = 1
#          Fabriqué       = 2
#          Sous-traité    = 3
#          Sous-traitance = 4
#          Phantome       = 5
#          Générique      = 6
#          Outillage      = 7
#          Livrable       = 8
#          Vendu          = 9
#          Intermédiaire  = I
#########################################################################
$S_SELITF
Local Char    WFIC(10)
Local Char    WITM(GLONITM) : WITM = VALEUR
Local Char    WFCY(GLONFCY) : WFCY = PARAM(1)
Local Char    WCAT(10)      : WCAT = PARAM(2)
Local Char    WACT(10)      : WACT = PARAM(3)
Local Char    WMGT(10)      : WMGT = PARAM(4)
Local Char    WLOT(GLONLOT) : WLOT = PARAM(5)
Local Date    WDAT          :
Local Integer ICRITERE        :ICRITERE = 0
If PARAM(6) = ""
  WDAT = date$
Else
  WDAT = num$(PARAM(6) )
Endif
Local Char    WFILM(250), WFILF(250), WFILX(250)
If PARAM(7) <> ""
  WFILX = PARAM(7)
Else
  WFILX = "1=1"
Endif
#
Local Char WI
Local Char W_TYP(20)
Local Char WTYPE(250)
Raz W_TYP
Raz WTYPE

If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON    [ATZ] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
# FQ 53562 libellé traduisible
If clalev([F:AXX]) = 0 : Local File ATEXTRA    [AXX] : Endif
#
TIT(0) = mess(4,198,1)
If WFCY = ""
    NBCOL += 1 : COL(NBCOL) = "[F:ITF]STOFCY"
    Call TEXTFIC("ITMFACILIT","STOFCY",2,TIT(NBCOL)) From OBJDIV
Endif
NBCOL += 1 : COL(NBCOL) = "[F:ITF]ITMREF"
Call TEXTFIC("ITMFACILIT","ITMREF",2,TIT(NBCOL)) From OBJDIV

# FQ 53562 libellé traduisible
#NBCOL += 1 : COL(NBCOL) = "[F:ITM]ITMDES1"
#Call TEXTFIC("ITMMASTER","ITMDES1",2,TIT(NBCOL)) From OBJDIV
# FGR 05/10/2009 : X3SUIVI58372
#NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"
NBCOL += 1 : COL(NBCOL) = "string$(1,[F:AXX]TEXTE)+string$(len([F:AXX]TEXTE)=0,[F:ITM]ITMDES1)"
Call TEXTFIC("ITMMASTER","DES1AXX",2,TIT(NBCOL)) From OBJDIV
COLTYP(NBCOL) = 30                        # hcb 62036

#
NBCOL += 1 : COL(NBCOL) = "[F:ITM]TCLCOD"
Call TEXTFIC("ITMMASTER","TCLCOD",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ITM]ITMSTA,246,1)"
Call TEXTFIC("ITMMASTER","ITMSTA",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ITF]STOMGTCOD,215,1)"
Call TEXTFIC("ITMFACILIT","STOMGTCOD",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ITM]LOTMGTCOD,209,1)"
Call TEXTFIC("ITMMASTER","LOTMGTCOD",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ITM]SERMGTCOD,210,1)"
Call TEXTFIC("ITMMASTER","SERMGTCOD",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:ITF]BUY"
Call TEXTFIC("ITMFACILIT","BUY",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ITF]CUNFLG,1,1)"
Call TEXTFIC("ITMFACILIT","CUNFLG",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ITF]CUNCOD,216,1)"
Call TEXTFIC("ITMFACILIT","CUNCOD",2,TIT(NBCOL)) From OBJDIV
#
#filtre Article maitre [ITM]
# MAE 17/10/08 WFILM = "[F:ITF]ITMREF >= WITM"
If WITM <> ""
    CRITCAR = "[F:ITF]ITMREF >= '"+WITM + "'"
Endif
#filtre Article site [ITF]
If WFCY <> ""
  #WFILF = "&[F:ITF]STOFCY=WFCY"
  Call ADDCRIT (WFILF,ICRITERE, "CRITERE","[F:ITF]STOFCY= '"+WFCY+"'", "&") From GOBJSUB
Endif
If WACT <> ""
  #Call ADDCRIT(WFILM,ICRITERE,"CRITERE","find([F:ITM]ITMSTA", "&") From GOBJSUB
  WFILM += "find([F:ITM]ITMSTA"
  For I = 1 To len(WACT)
    WFILM += ","+num$(mid$(WACT,I,1))
  Next I
  WFILM += ")"
Endif
If WMGT <> ""
    If WFILM <> ""
        WFILM +="&"
    Endif
  WFILM += "find([F:ITF]STOMGTCOD"
  For I = 1 To len(WMGT)
    WFILM += ","+num$(mid$(WMGT,I,1))
  Next I
  WFILM += ")"
Endif
If WLOT <> ""
    If WFILM <> ""
        WFILM +="&"
    Endif
  WFILM += "find([F:ITM]LOTMGTCOD"
  For I = 1 To len(WLOT)
    WFILM += ","+num$(mid$(WLOT,I,1))
  Next I
  WFILM += ")"
Endif
If WCAT <> ""
      For I = 1 To len(WCAT)
          WI =  num$(mid$(WCAT,I,1))
          Case WI
               When "1" :
                W_TYP   = "[F:ITM]PURFLG = 2"
                Gosub LOAD_WTYPE
               When "2" :
                W_TYP   = "[F:ITM]MFGFLG = 2"
                Gosub LOAD_WTYPE
               When "3" :
                W_TYP   = "[F:ITM]SCPFLG = 2"
                Gosub LOAD_WTYPE
               When "4" :
                W_TYP   = "[F:ITM]SCSFLG = 2"
                Gosub LOAD_WTYPE
               When "5" :
                W_TYP   = "[F:ITM]PHAFLG = 2"
                Gosub LOAD_WTYPE
               When "6" :
                W_TYP   = "[F:ITM]GENFLG = 2"
                Gosub LOAD_WTYPE
               When "7" :
                W_TYP   = "[F:ITM]TOOFLG = 2"
                Gosub LOAD_WTYPE
               When "8" :
                W_TYP   = "[F:ITM]DLVFLG = 2"
                Gosub LOAD_WTYPE
               When "9" :
                W_TYP   = "[F:ITM]SALFLG = 2"
                Gosub LOAD_WTYPE
               When "I" :
                W_TYP   = "[F:ITM]INTFLG = 2"
                Gosub LOAD_WTYPE
          Endcase
      Next I
Endif
#
If WTYPE = ""
   WTYPE = "1=1"
Endif
If WFILM = ""
   WFILM = "1=1"
Endif
If WFILF = ""
   # FQ 53562 libellé traduisible
   # Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF As [LNK]
    Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF, [AXX]AXX0="ITMMASTER";"DES1AXX";GLANGUE;[F:ITF]ITMREF;"" As [LNK]
&              Where evalue(WFILM) & evalue(WFILX)
&              Order By Key ITF1
Else
   # FQ 53562 libellé traduisible
   # Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF As [LNK]
    Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF, [AXX]AXX0="ITMMASTER";"DES1AXX";GLANGUE;[F:ITF]ITMREF;"" As [LNK]
&              Where evalue(WFILF) & evalue(WFILM) & evalue(WFILX)& evalue(WTYPE)
&              Order By Key ITF1
Endif
#
#CRITERE = ""
START   = "ITMREF"
ORDRE   = "ITMREF"   # FQ 56558
VALEUR  = WITM
#SIZLIG  = 120
#SIZCOL  = 340
Default File [LNK]
DEFPAG=1
Return

$B_SELITF
Return

###########
#########################################################################
# SELITFITW : Sélection article site article depot
#          Particularité pour le parametre TCLCOD
#             alimentation possible en associant les valeurs uivantes :
#             les valeurs associées sont interpretrées avec
#             l’opérateur logique « ou »)
#          ex : valeur "12" -->  liste des articles Acheté ou Fabriqué
#          Acheté         = 1
#          Fabriqué       = 2
#          Sous-traité    = 3
#          Sous-traitance = 4
#          Phantome       = 5
#          Générique      = 6
#          Outillage      = 7
#          Livrable       = 8
#          Vendu          = 9
#          Intermédiaire  = I
#########################################################################
$S_SELITFITW
Local Char    WFIC(10)
Local Char    WITM(GLONITM) : WITM     = VALEUR
Local Char    WFCY(GLONFCY) : WFCY     = PARAM(1)
Local Char    WCAT(10)      : WCAT     = PARAM(2)
Local Char    WACT(10)      : WACT     = PARAM(3)
Local Char    WMGT(10)      : WMGT     = PARAM(4)
Local Char    WLOT(GLONLOT) : WLOT     = PARAM(5)
Local Date    WDAT          :
Local Integer ICRITERE      : ICRITERE = 0
Local Integer WITMWRH       : WITMWRH  = val(PARAM(8))

If WITMWRH <> 2 | !GWRHACT
   Gosub S_SELITF
   Return
Endif


If PARAM(6) = ""
  WDAT = date$
Else
  WDAT = num$(PARAM(6) )
Endif
Local Char    WFILM(250), WFILF(250), WFILX(250)
If PARAM(7) <> ""
  WFILX = PARAM(7)
Else
  WFILX = "1=1"
Endif
#
Local Char WI
Local Char W_TYP(20)
Local Char WTYPE(250)
Raz W_TYP
Raz WTYPE

If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON    [ATZ] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITW]) = 0 : Local File ITMWRH     [ITW] : Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA    [AXX] : Endif
#
TIT(0) = mess(346,184,1)
If WFCY = ""
    NBCOL += 1 : COL(NBCOL) = "[F:ITF]STOFCY"
    Call TEXTFIC("ITMFACILIT","STOFCY",2,TIT(NBCOL)) From OBJDIV
Endif
NBCOL += 1 : COL(NBCOL) = "[F:ITF]ITMREF"
Call TEXTFIC("ITMFACILIT","ITMREF",2,TIT(NBCOL)) From OBJDIV
# FGR 05/10/2009 : X3SUIVI58372
#NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"
NBCOL += 1 : COL(NBCOL) = "string$(1,[F:AXX]TEXTE)+string$(len([F:AXX]TEXTE)=0,[F:ITM]ITMDES1)"
Call TEXTFIC("ITMMASTER","DES1AXX",2,TIT(NBCOL)) From OBJDIV
COLTYP(NBCOL) = 30                        # hcb 62036

#
NBCOL += 1 : COL(NBCOL) = "[F:ITM]TCLCOD"
Call TEXTFIC("ITMMASTER","TCLCOD",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ITM]ITMSTA,246,1)"
Call TEXTFIC("ITMMASTER","ITMSTA",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ITF]STOMGTCOD,215,1)"
Call TEXTFIC("ITMFACILIT","STOMGTCOD",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ITM]LOTMGTCOD,209,1)"
Call TEXTFIC("ITMMASTER","LOTMGTCOD",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ITM]SERMGTCOD,210,1)"
Call TEXTFIC("ITMMASTER","SERMGTCOD",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:ITF]BUY"
Call TEXTFIC("ITMFACILIT","BUY",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ITF]CUNFLG,1,1)"
Call TEXTFIC("ITMFACILIT","CUNFLG",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ITF]CUNCOD,216,1)"
Call TEXTFIC("ITMFACILIT","CUNCOD",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:ITW]WRH"
Call TEXTFIC("ITMWRH","WRH",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ITW]CUNWRHFLG,1,1)"
Call TEXTFIC("ITMWRH","CUNWRHFLG",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ITW]CUNCOD,216,1)"
Call TEXTFIC("ITMWRH","CUNCOD",2,TIT(NBCOL)) From OBJDIV

#
If WITM <> ""
    CRITCAR = "[F:ITF]ITMREF >= '"+WITM + "'"
Endif
#filtre Article site [ITF]
If WFCY <> ""
   Call ADDCRIT (WFILF,ICRITERE, "CRITERE","[F:ITF]STOFCY= '"+WFCY+"'", "&") From GOBJSUB
Endif
If WACT <> ""
   WFILM += "find([F:ITM]ITMSTA"
   For I = 1 To len(WACT)
       WFILM += ","+num$(mid$(WACT,I,1))
   Next I
   WFILM += ")"
Endif
If WMGT <> ""
    If WFILM <> ""
        WFILM +="&"
    Endif
    WFILM += "find([F:ITF]STOMGTCOD"
    For I = 1 To len(WMGT)
        WFILM += ","+num$(mid$(WMGT,I,1))
    Next I
    WFILM += ")"
Endif
If WLOT <> ""
    If WFILM <> ""
        WFILM +="&"
    Endif
    WFILM += "find([F:ITM]LOTMGTCOD"
    For I = 1 To len(WLOT)
        WFILM += ","+num$(mid$(WLOT,I,1))
    Next I
    WFILM += ")"
Endif
If WCAT <> ""
      For I = 1 To len(WCAT)
          WI =  num$(mid$(WCAT,I,1))
          Case WI
               When "1" :
                W_TYP   = "[F:ITM]PURFLG = 2"
                Gosub LOAD_WTYPE
               When "2" :
                W_TYP   = "[F:ITM]MFGFLG = 2"
                Gosub LOAD_WTYPE
               When "3" :
                W_TYP   = "[F:ITM]SCPFLG = 2"
                Gosub LOAD_WTYPE
               When "4" :
                W_TYP   = "[F:ITM]SCSFLG = 2"
                Gosub LOAD_WTYPE
               When "5" :
                W_TYP   = "[F:ITM]PHAFLG = 2"
                Gosub LOAD_WTYPE
               When "6" :
                W_TYP   = "[F:ITM]GENFLG = 2"
                Gosub LOAD_WTYPE
               When "7" :
                W_TYP   = "[F:ITM]TOOFLG = 2"
                Gosub LOAD_WTYPE
               When "8" :
                W_TYP   = "[F:ITM]DLVFLG = 2"
                Gosub LOAD_WTYPE
               When "9" :
                W_TYP   = "[F:ITM]SALFLG = 2"
                Gosub LOAD_WTYPE
               When "I" :
                W_TYP   = "[F:ITM]INTFLG = 2"
                Gosub LOAD_WTYPE
          Endcase
      Next I
Endif
#
If WTYPE = ""
   WTYPE = "1=1"
Endif
If WFILM = ""
   WFILM = "1=1"
Endif
If WFILF = ""
   Link [ITW] With [ITM]ITM0=[F:ITW]ITMREF,[ITF]ITF0=[F:ITW]ITMREF;[F:ITW]STOFCY,[AXX]AXX0="ITMMASTER";"DES1AXX";GLANGUE;[F:ITW]ITMREF;""
&              As [LNK]
&              Where evalue(WFILM) & evalue(WFILX)
&              Order By Key ITW1
Else
   Link [ITW] With [ITM]ITM0=[F:ITW]ITMREF,[ITF]ITF0=[F:ITW]ITMREF;[F:ITW]STOFCY,[AXX]AXX0="ITMMASTER";"DES1AXX";GLANGUE;[F:ITW]ITMREF;""
&              As [LNK]
&              Where evalue(WFILF) & evalue(WFILM) & evalue(WFILX)& evalue(WTYPE)
&              Order By Key ITW1
Endif
#
START   = "ITMREF"
ORDRE   = "ITMREF"
VALEUR  = WITM
Default File [LNK]
DEFPAG=1
Return



$B_SELITFITW
Return

########################################################################
# LOAD_WTYPE                                   Concaténation W_TYP
########################################################################
$LOAD_WTYPE
If WTYPE <> ""
   WTYPE += "|"
Endif
WTYPE += W_TYP
Return

#########################################################################
# SELITP : Sélection article fournisseur
#########################################################################
$S_SELITP
Local Char    WFIC(10)
Local Char    WITM(GLONITM) : WITM = VALEUR
Local Char    WBPS(GLONBPS) : WBPS = PARAM(1)
Local Char    WCAT(10)      : WCAT = PARAM(2)
Local Char    WACT(10)      : WACT = PARAM(3)
Local Char    WMGT(10)      : WMGT = PARAM(4)
Local Char    WLOT(GLONLOT) : WLOT = PARAM(5)

Local Char    WFILM(250), WFILF(250), WFILX(250)
If PARAM(6) <> ""
  WFILX = PARAM(6)
Else
  WFILX = "1=1"
Endif

Local Char WI
Local Char W_TYP(20)
Local Char WTYPE(250)
Raz W_TYP
Raz WTYPE

If clalev([F:ATZ]) = 0 : Local File ATABZON    [ATZ] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITP]) = 0 : Local File ITMBPS     [ITP] : Endif
# FQ 53562 libellé traduisible
If clalev([F:AXX]) = 0 : Local File ATEXTRA    [AXX] : Endif

TIT(0) = mess(23,198,1)
If WBPS = ""
    NBCOL += 1 : COL(NBCOL) = "[F:ITP]BPSNUM"
    Call TEXTFIC("ITMBPS","BPSNUM",2,TIT(NBCOL)) From OBJDIV
Endif
NBCOL += 1 : COL(NBCOL) = "[F:ITP]ITMREF"
Call TEXTFIC("ITMBPS","ITMREF",2,TIT(NBCOL)) From OBJDIV
# FQ 53562 libellé traduisible
#NBCOL += 1 : COL(NBCOL) = "[F:ITM]ITMDES1"
#Call TEXTFIC("ITMMASTER","ITMDES1",2,TIT(NBCOL)) From OBJDIV
# FGR 05/10/2009 : X3SUIVI58372
#NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"
NBCOL += 1 : COL(NBCOL) = "string$(1,[F:AXX]TEXTE)+string$(len([F:AXX]TEXTE)=0,[F:ITM]ITMDES1)"
Call TEXTFIC("ITMMASTER","DES1AXX",2,TIT(NBCOL)) From OBJDIV
COLTYP(NBCOL) = 30                        # hcb 62036

#
NBCOL += 1 : COL(NBCOL) = "[F:ITM]TCLCOD"
Call TEXTFIC("ITMMASTER","TCLCOD",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ITM]ITMSTA,246,1)"
Call TEXTFIC("ITMMASTER","ITMSTA",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ITM]STOMGTCOD,215,1)"
Call TEXTFIC("ITMFACILIT","STOMGTCOD",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ITM]LOTMGTCOD,209,1)"
Call TEXTFIC("ITMMASTER","LOTMGTCOD",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess([F:ITM]SERMGTCOD,210,1)"
Call TEXTFIC("ITMMASTER","SERMGTCOD",2,TIT(NBCOL)) From OBJDIV
#
#filtre Article site [ITP]
If WBPS <> ""
  WFILF = "[F:ITP]BPSNUM=WBPS"
Endif
#filtre Article maitre [ITM]
WFILM = "[F:ITM]ITMREF >= WITM"
If WACT <> ""
  WFILM += "&find([F:ITM]ITMSTA"
  For I = 1 To len(WACT)
    WFILM += ","+num$(mid$(WACT,I,1))
  Next I
  WFILM += ")"
Endif
If WMGT <> ""
  WFILM += "&find([F:ITF]STOMGTCOD"
  For I = 1 To len(WMGT)
    WFILM += ","+num$(mid$(WMGT,I,1))
  Next I
  WFILM += ")"
Endif
If WLOT <> ""
  WFILM += "&find([F:ITM]LOTMGTCOD"
  For I = 1 To len(WLOT)
    WFILM += ","+num$(mid$(WLOT,I,1))
  Next I
  WFILM += ")"
Endif
If WCAT <> ""
      For I = 1 To len(WCAT)
          WI =  num$(mid$(WCAT,I,1))
          Case WI
               When "1" :
                W_TYP   = "[F:ITM]PURFLG = 2"
                Gosub LOAD_WTYPE
               When "2" :
                W_TYP   = "[F:ITM]MFGFLG = 2"
                Gosub LOAD_WTYPE
               When "3" :
                W_TYP   = "[F:ITM]SCPFLG = 2"
                Gosub LOAD_WTYPE
               When "4" :
                W_TYP   = "[F:ITM]SCSFLG = 2"
                Gosub LOAD_WTYPE
               When "5" :
                W_TYP   = "[F:ITM]PHAFLG = 2"
                Gosub LOAD_WTYPE
               When "6" :
                W_TYP   = "[F:ITM]GENFLG = 2"
                Gosub LOAD_WTYPE
               When "7" :
                W_TYP   = "[F:ITM]TOOFLG = 2"
                Gosub LOAD_WTYPE
               When "8" :
                W_TYP   = "[F:ITM]DLVFLG = 2"
                Gosub LOAD_WTYPE
               When "9" :
                W_TYP   = "[F:ITM]SALFLG = 2"
                Gosub LOAD_WTYPE
               When "I" :
                W_TYP   = "[F:ITM]INTFLG = 2"
                Gosub LOAD_WTYPE
          Endcase
      Next I
Endif

If WTYPE = ""
   WTYPE = "1=1"
Endif

If clalev([M:SMO1])
    If WFILF = ""
      # FQ 53562 libellé traduisible
      # Link [ITP] With [ITM]ITM0~=GSOCIETE;[F:ITP]ITMREF,
        Link [ITP] With [ITM]ITM0~=GSOCIETE;[F:ITP]ITMREF,
&                       [AXX]AXX0="ITMMASTER";"DES1AXX";GLANGUE;[F:ITP]ITMREF;"",
&                       [FCY]FCY1~=GSOCIETE;[F:ITF]STOFCY As [LNK]
&                  Where evalue(WFILM) & evalue(WFILX)
&                  Order By Key ITP2
       ORDRE   = "ITMREF;BPSNUM"
    Else
      # FQ 53562 libellé traduisible
      # Link [ITP] With [ITM]ITM0~=GSOCIETE;[F:ITP]ITMREF,
        Link [ITP] With [ITM]ITM0~=GSOCIETE;[F:ITP]ITMREF,
&                       [AXX]AXX0="ITMMASTER";"DES1AXX";GLANGUE;[F:ITP]ITMREF;"",
&                       [FCY]FCY1~=GSOCIETE;[F:ITF]STOFCY As [LNK]
&                  Where evalue(WFILF) & evalue(WFILM) & evalue(WFILX)& evalue(WTYPE)
&                  Order By Key ITP2
        ORDRE   = "ITMREF;BPSNUM"
    Endif
Else
    If WFILF = ""
      Link [ITP] With [ITM]ITM0=[F:ITP]ITMREF As [LNK]
&                Where evalue(WFILM) & evalue(WFILX)
&                Order By Key ITP2
       ORDRE   = "ITMREF;BPSNUM"
    Else
      Link [ITP] With [ITM]ITM0=[F:ITP]ITMREF As [LNK]
&                Where evalue(WFILF) & evalue(WFILM) & evalue(WFILX)& evalue(WTYPE)
&                Order By Key ITP2
       ORDRE   = "ITMREF;BPSNUM"
    Endif
Endif
#
CRITERE = ""
START   = "ITMREF"
VALEUR  = WITM
SIZLIG  = 120
SIZCOL  = 340
Default File [LNK]
DEFPAG=1
Return

$B_SELITP
Return

#########################################################################
# STKSELSTO : Sélection ligne de stock
#########################################################################
$STKSELSTO
Local Char    LFIC(10)        : LFIC = "STOCK"
Local Char    LFCY(GLONFCY)   : LFCY = PARAM(1)
Local Char    LITM(GLONITM)   : LITM = PARAM(2)
Local Char    LLOT(GLONLOT)   : LLOT = PARAM(3)
Local Char    LABR            : LABR = PARAM(4)
Local Integer LLIG            : LLIG = val(PARAM(5))

If clalev([F:STO]) = 0 : Local File STOCK      [STO] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON    [ATZ] : Endif
If [F:ITM]ITMREF<>LITM
    Read [ITM]ITM0=LITM
Endif
If [F:ITF]ITMREF<>LITM | [F:ITF]STOFCY<>LFCY
    Read [ITF]ITF0=LITM;LFCY
Endif

TIT(0) = mess(145,198,1)-LITM-LLOT

#NBCOL = 1 : COL(NBCOL) = "STOFCY"
#Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "PCU"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
If [F:ITM]LOTMGTCOD > 1
    NBCOL += 1 : COL(NBCOL) = "BPSLOT"
    Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
    NBCOL += 1 : COL(NBCOL) = "LOT"
    Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
    If [F:ITM]LOTMGTCOD = 4
       NBCOL += 1 : COL(NBCOL) = "SLO"
       Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
    Endif
Endif
NBCOL += 1 : COL(NBCOL) = "STA"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
#--- Issue X3-53322
If [F:ITF]LPNMGTCOD=2
   NBCOL += 1 : COL(NBCOL) = "LPNNUM"
   Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
Endif
#---
NBCOL += 1 : COL(NBCOL) = "LOCTYP"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "LOC"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
#NBCOL += 1 : COL(NBCOL) = "QTYSTU"
#Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
#NBCOL += 1 : COL(NBCOL) = "STOCOU"
#Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV

If LLOT <> ""
   CRITERE = "[F:STO]STOFCY=LFCY&[F:STO]ITMREF=LITM&[F:STO]LOT=LLOT&[F:STO]CUNLOKFLG<>2&[F:STO]QTYSTU>0"
Else
   CRITERE = "[F:STO]STOFCY=LFCY&[F:STO]ITMREF=LITM&[F:STO]CUNLOKFLG<>2&[F:STO]QTYSTU>0"
Endif

ORDRE   = "STOCOU"
START   = "PCU"
EXPSTART = "ITMREF=LITM"
#VALEUR  = ""
SIZLIG  = 100
SIZCOL  = 200
Default File [STO]

Return

$VERF_STKSELSTO
Local     Char    LABRMSK
LABRMSK  = "[M:"+LABR+"]"

Read [STO]STO0=LFCY;[F:STO]STOCOU
If fstat
   Return
Endif
If evalue("dim([M:"+LABR+"]STA)")>0
   Assign " [M:"+LABR+"]STA("+num$(LLIG)+")"  With [F:STO]STA
Endif
#--- Issue X3-53322
If [F:ITF]LPNMGTCOD=2
    If evalue("dim([M:"+LABR+"]LPNNUM)")>0
       Assign " [M:"+LABR+"]LPNNUM("+num$(LLIG)+")"  With [F:STO]LPNNUM
    Endif
Endif
#---
If [F:ITF]LOCMGTCOD=2
    If evalue("dim([M:"+LABR+"]LOCTYP)")>0
       Assign " [M:"+LABR+"]LOCTYP("+num$(LLIG)+")"  With [F:STO]LOCTYP
    Endif
    If evalue("dim([M:"+LABR+"]LOC)")>0
       Assign " [M:"+LABR+"]LOC("+num$(LLIG)+")"  With [F:STO]LOC
    Endif
Endif
If evalue("dim([M:"+LABR+"]PALNUM)")>0
   Assign " [M:"+LABR+"]PALNUM("+num$(LLIG)+")"  With [F:STO]PALNUM
Endif
If evalue("dim([M:"+LABR+"]CTRNUM)")>0
   Assign " [M:"+LABR+"]CTRNUM("+num$(LLIG)+")"  With [F:STO]CTRNUM
Endif
If evalue("dim([M:"+LABR+"]PCU)")>0
   Assign " [M:"+LABR+"]PCU("+num$(LLIG)+")"  With [F:STO]PCU
Endif
If evalue("dim([M:"+LABR+"]PCUSTUCOE)")>0
   Assign " [M:"+LABR+"]PCUSTUCOE("+num$(LLIG)+")"  With [F:STO]PCUSTUCOE
Endif

If evalue("dim([M:"+LABR+"]STOFLD1)")>0
   Assign " [M:"+LABR+"]STOFLD1("+num$(LLIG)+")"  With [F:STO]STOFLD1
Endif
If evalue("dim([M:"+LABR+"]STOFLD2)")>0
   Assign " [M:"+LABR+"]STOFLD2("+num$(LLIG)+")"  With [F:STO]STOFLD2
Endif

If [F:ITM]LOTMGTCOD>1
    If evalue("dim([M:"+LABR+"]BPSLOTAFF)")>0
       Assign " [M:"+LABR+"]BPSLOTAFF("+num$(LLIG)+")"  With [F:STO]BPSLOT
    Endif
    If evalue("dim([M:"+LABR+"]LOTAFF)")>0
       Assign " [M:"+LABR+"]LOTAFF("+num$(LLIG)+")"     With [F:STO]LOT
    Endif
    If [F:ITM]LOTMGTCOD=4 & evalue("dim([M:"+LABR+"]SLOAFF)")>0
       If [F:STO]SLO <> ""
          Assign " [M:"+LABR+"]SLOAFF("+num$(LLIG)+")"  With [F:STO]SLO
       Endif
    Endif
Endif

Default Mask "["+LABR+"]"
Affzo [M]

Return

#########################################################################
# STKSELSTOT : Sélection ligne de stock pour terminaux portables
#########################################################################
$STKSELSTOT
Local Char    LFIC(10)        : LFIC = "STOCK"
Local Char    LFCY(GLONFCY)   : LFCY = PARAM(1)
Local Char    LITM(GLONITM)   : LITM = PARAM(2)
Local Char    LLOT(GLONLOT)   : LLOT = PARAM(3)
Local Char    LSLO(GLONSLO)   : LSLO = PARAM(4)
Local Char    LLOC(GLONLOC)   : LLOC = PARAM(5)
Local Char    LSTA(GLONSTA)   : LSTA = PARAM(6)
Local Char    LABR            : LABR = PARAM(7)

If clalev([F:STO]) = 0 : Local File STOCK      [STO] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON    [ATZ] : Endif

If [F:ITM]ITMREF<>LITM
   Read [ITM]ITM0=LITM
Endif
If [F:ITF]ITMREF<>LITM | [F:ITF]STOFCY<>LFCY
   Read [ITF]ITF0=LITM;LFCY
Endif

TIT(0) = mess(145,198,1)

CRITERE = "[F:STO]STOFCY=LFCY&[F:STO]ITMREF=LITM"

Case zoncou
 When "LOT"       : If [F:ITM]SERMGTCOD=3
                       NBCOL += 1 : COL(NBCOL) = "SERNUM"
                       Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
                    Endif
                   NBCOL += 1 : COL(NBCOL) = "LOT"
                    Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
                    If [F:ITM]LOTMGTCOD = 4
                       NBCOL += 1 : COL(NBCOL) = "SLO"
                       Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
                    Endif
 When "SLO"       : If LLOT<>""
                       CRITERE += "&[F:STO]LOT=LLOT"
                    Endif
                    If [F:ITM]SERMGTCOD=3
                       NBCOL += 1 : COL(NBCOL) = "SERNUM"
                       Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
                    Endif
                    NBCOL += 1 : COL(NBCOL) = "LOT"
                    Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
                    NBCOL += 1 : COL(NBCOL) = "SLO"
                    Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
 When "SERNUM"    : NBCOL += 1 : COL(NBCOL) = "SERNUM"
                    Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
                    If LLOT<>""
                       CRITERE += "&[F:STO]LOT=LLOT"
                       If [F:ITM]LOTMGTCOD=4 & LSLO<>""
                          CRITERE += "&[F:STO]SLO=LSLO"
                       Endif
                    Else
                       NBCOL += 1 : COL(NBCOL) = "LOT"
                       Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
                       If [F:ITM]LOTMGTCOD = 4
                          NBCOL += 1 : COL(NBCOL) = "SLO"
                          Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
                       Endif
                    Endif
Endcase

If LSTA<>""
   CRITERE += "&[F:STO]STA=LSTA"
Else
   NBCOL += 1 : COL(NBCOL) = "STA"
   Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
Endif

If [F:ITF]LOCMGTCOD=2
   If LLOC<>""
      CRITERE += "&[F:STO]LOC=LLOC"
   Else
      NBCOL += 1 : COL(NBCOL) = "LOC"
      Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
   Endif
Endif

CRITERE += "&[F:STO]CUNLOKFLG<>2&([F:STO]QTYSTU-[F:STO]CUMALLQTY-[F:STO]CUMWIPQTY)>0"

START  = zoncou
ORDRE  = "STOCOU"
SIZLIG = 100
SIZCOL = 100
Default File [STO]
Return

$VERF_STKSELSTOT
Local     Char    LABRMSK
LABRMSK  = "[M:"+LABR+"]"

Read [STO]STO0=LFCY;[F:STO]STOCOU
If fstat
   Return
Endif
If evalue("dim([M:"+LABR+"]STA)")>0
   Assign "[M:"+LABR+"]STA" With [F:STO]STA
Endif
If [F:ITF]LOCMGTCOD=2
   If evalue("dim([M:"+LABR+"]LOC)")>0
      Assign "[M:"+LABR+"]LOC" With [F:STO]LOC
   Endif
Endif
If [F:ITM]LOTMGTCOD>1
   If evalue("dim([M:"+LABR+"]LOT)")>0
      Assign "[M:"+LABR+"]LOT" With [F:STO]LOT
   Endif
   If [F:ITM]LOTMGTCOD=4 & evalue("dim([M:"+LABR+"]SLO)")>0
      If [F:STO]SLO <> ""
         Assign "[M:"+LABR+"]SLO" With [F:STO]SLO
      Endif
   Endif
Endif
If [F:ITM]SERMGTCOD=3
   If evalue("dim([M:"+LABR+"]SERNUM)")>0
      Assign "[M:"+LABR+"]SERNUM" With [F:STO]SERNUM
   Endif
Endif

Default Mask "["+LABR+"]"
Affzo [M]

Return

#--- Issue 110327
#########################################################################
# STKSELSTOS : Sélection ligne de stock pour resynchronisation no séries
#########################################################################
$STKSELSTOS
Local Char    LFIC(10)        : LFIC = "STOCK"
Local Char    LFCY(GLONFCY)   : LFCY = PARAM(1)
Local Char    LITM(GLONITM)   : LITM = PARAM(2)
Local Decimal LSTOCOU         : LSTOCOU = val(PARAM(3))
Local Decimal TSTOCOU(255)
Local Decimal TNBSER(255)
Local Integer I, NBT

If clalev([F:STO]) = 0 : Local File STOCK      [STO] : Endif
If clalev([F:SER]) = 0 : Local File STOSER     [SER] : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON    [ATZ] : Endif

TIT(0) = mess(145,198,1)-LITM-LFCY

CRITERE = "[F:STO]STOFCY=LFCY&[F:STO]ITMREF=LITM&[F:STO]STOCOU<>LSTOCOU"

# Chargement des nombre de séries par chronos stock (limité à 255)
I=0
For [STO] Where evalue(CRITERE)
  Filter [STS] Where ITMREF=[F:STO]ITMREF & STOCOU=[F:STO]STOCOU & ISSDAT=[0/0/0]
  TNBSER(I)  = rowcount([F:STS])
  TSTOCOU(I) = [F:STO]STOCOU
  Filter [STS]
  I+=1
  If I>=255 : Break : Endif
Next
NBT = I

NBCOL += 1 : COL(NBCOL) = "STOCOU"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "QTYSTU"
#Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
#NBCOL += 1 : COL(NBCOL) = "TNBSER(find([F]STOCOU,TSTOCOU(0..NBT-1))-1)"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV

If [F:ITM]LOTMGTCOD > 1
  NBCOL += 1 : COL(NBCOL) = "LOT"
  Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
  If [F:ITM]LOTMGTCOD = 4
    NBCOL += 1 : COL(NBCOL) = "SLO"
    Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
  Endif
Endif
NBCOL += 1 : COL(NBCOL) = "STA"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "LOCTYP"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "LOC"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV

ORDRE   = "STOCOU"
START   = "STOCOU"
EXPSTART = "ITMREF=LITM"
#VALEUR  = ""
SIZLIG  = 100
SIZCOL  = 200
Default File [STO]

Return

$VERF_STKSELSTOS
#Local     Char    LABRMSK
#LABRMSK  = "[M:"+LABR+"]"
