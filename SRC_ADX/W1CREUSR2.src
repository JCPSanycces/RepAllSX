#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CREUSR2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:35"
A_USER  = "DOC"
A_STAMP = "20181109230335"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRUSR"
  If [M]NBRUSR=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CREUSR2 [USR2]
Gosub HORODAT
Local Inpbox "CREUSR2" From GFONCTION At A_STAMP With A_WINDPREV Mask [USR2] As [SIM_]
Grizo [USR2]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [USR2]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=112 : Y1(0)=4 : Y2(0)=25
Return

$ON_FLGVAL
Onevent INIT_AREA Call D_FLGVAL(zc) From W1CREUSR2
Onevent BEFORE_INPUT Call AS_FLGVAL(zc) From W1CREUSR2
Return

Subprog D_FLGVAL(VALEUR)
Variable Integer VALEUR
If varinit([M]FLGVAL,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_FLGVAL(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_REFNUM
Return

$ON_CPY
Return

$ON_ZCPY
Onevent BEFORE_AREA Gosub AV_ZCPY From W1CREUSR2
Return

$AV_ZCPY
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
Call LECTURE("CPY",num$([M]CPY(indice)),"") From CONTOBJ
zc = [F:CPY]CPYSHO
Gosub _AFF
Return

$ON_FCY
Return

$ON_ZFCY
Onevent BEFORE_AREA Gosub AV_ZFCY From W1CREUSR2
Return

$AV_ZFCY
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
Call LECTURE("FCY",num$([M]FCY(indice)),"") From CONTOBJ
zc = [F:FCY]FCYSHO
Gosub _AFF
Return

$ON_LEG
Onevent INIT_AREA Call D_LEG(zc) From W1CREUSR2
Return

Subprog D_LEG(VALEUR)
Variable Char    VALEUR()
If varinit([M]LEG,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"909","") From SUBADI
Endif
Gosub _AFF
End

$ON_ZLEG
Onevent BEFORE_AREA Gosub AV_ZLEG From W1CREUSR2
Return

$AV_ZLEG
Call LECTEXTRA(zc,"ATABDIV","SHODES","909",num$([M]LEG(indice))) From ATEXTRA
Gosub _AFF
Return

$ON_CTRNUM
Return

$CHG_STY
Return


