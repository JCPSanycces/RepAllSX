#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion du fichier SOLUTION
Call OBJET ("SOL", GBIDC1, GBIDC2) From GOBJET
End
##########################################################################################################

##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"     : Gosub OUVRE
    When "FERME"     : Gosub FERME
    When "INICRE"    : Gosub INICRE
    When "LIENS"     : Gosub LIENS
    When "RAZCRE"    : Gosub RAZCRE
    When "SETBOUT"   : Gosub SETBOUT
    When "VERIF_CRE" : Gosub VERIF_CRE
    When "VERIF_MOD" : Gosub VERIF_MOD
    When "CREATION"  : Gosub CREATION
    When "MODIF"     : Gosub MODIF
    When "AV_ANNULE" : Gosub AV_ANNULE
    When "ANNULE"    : Gosub ANNULE
    When "AP_ANNULE" : Gosub AP_ANNULE
    When "APRES_CRE" : Gosub APRES_CRE
    When "APRES_MOD" : Gosub APRES_MOD
    When "FILTRE"    : Gosub FILTRE
    When "FILGAUCHE" : Gosub FILGAUCHE
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Char GCSOLCPT(GLONANM)   # Code compteur pour solution

  #------------------------------------------------------------#
  # --> Récupération du code compteur                          #
  #------------------------------------------------------------#
  # ----------------------------------------------------------
  # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
  #  If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
  #  Read [TCA]TCA0=12
  #  If fstat Then
  #    GERR = 1
  #    GMESSAGE = mess(64,199,1)
  #    OK=0
  #    Return
  #  Endif
  #  GMANCOU = [F:TCA]MANCOU(3)
  #  GCSOLCPT = [F:TCA]CODNUM(3)
  GSOCIETE = ""
  GCURLEG = ""
  Call READ_COUNTER("", 12, 3, GSOCIETE, GCURLEG, GCSOLCPT, GMANCOU) From CRM_UTIL
  # FGR 20/12/2012 : X3SUIVI71937 (fin)
  # ----------------------------------------------------------
Return

##########################################################################################################
$FERME
  #Nettoie tous les écrans.
  Raz [M:SOL0]
  Raz [M:SOL1]
  Raz [M:SOL2]
  Raz [M:SOL3]
  Raz [M:SOL4]
  Kill GCSOLCPT
Return

##########################################################################################################
$INICRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  # Récupération du compteur de contrat de service.
  If func CRM_UTIL.GET_NUMERO_CHRONO ("HDK", "", GCSOLCPT, date$, "", [M:SOL0]NUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
    If IBRETOUR = 1 Then
      [F:SOL]NUM = [M:SOL0]NUM
      Affzo [M:SOL0]NUM
    Else
      # problème lors de la récupération du compteur
      GERR = 1
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GOK = 0
      Return
    Endif
  Endif
  [F:SOL]TYPPBLDES = "PBL"
  [F:SOL]NUMPBLDES = [M:SOL0]NUM
  [M:SOL1]TYPPBLDES = "PBL"
  [M:SOL1]NUMPBLDES = [M:SOL0]NUM
  [F:SOL]TYPSOLDES = "SOL"
  [F:SOL]NUMSOLDES = [M:SOL0]NUM
  [M:SOL2]TYPSOLDES = "SOL"
  [M:SOL2]NUMSOLDES = [M:SOL0]NUM
  [F:SOL]CREHOU = left$(time$, 2) + mid$(time$, 4, 2)
Return

##########################################################################################################
$VERIF_CRE_MOD
  If [M:SOL2]SOLFULDES = "" Then
    #Une solution ne peut pas être enregistrée sans sa description. Création refusée.
    If ACTION = "VERIF_CRE" Then
      GMESSAGE = mess(854,182,1)
    Else
      GMESSAGE = mess(855,182,1)
    Endif
    GERR = 2
    OK = 0
    Return
  Endif
  # FGR 06/08/2014 : X3SUIVI95250 (début)
  #  #Synthèse description demande de service
  #  If [M:SOL1]PBLFULDES = "" Then
  #    [M:SOL1]PBLDES = ""
  #  Else
  #    [M:SOL1]PBLDES = left$([M:SOL1]PBLFULDES,250)
  #  Endif
  #  #Synthèse solution
  #  If [M:SOL2]SOLFULDES = "" Then
  #    [M:SOL2]SOLDES = ""
  #  Else
  #    [M:SOL2]SOLDES = left$([M:SOL2]SOLFULDES,250)
  #  Endif
  # FGR 06/08/2014 : X3SUIVI95250 (fin)
Return

##########################################################################################################
$VERIF_CRE
  Gosub VERIF_CRE_MOD
  If OK = 0 Then
    Return
  Endif
Return

##########################################################################################################
$VERIF_MOD
  Gosub VERIF_CRE_MOD
  If OK = 0 Then
    Return
  Endif
Return

##########################################################################################################
$CREATION
  #Enregistrement des CLOBs
  Gosub SAVEHD3 From SUBSOLB
  If GOK < 1 Then
    Return
  Endif
  # Maj des statistiques
  Call VALSTA("SOL",1) From SUBPS2
Return

##########################################################################################################
$MODIF
  #Enregistrement des CLOBs
  Gosub SAVEHD3 From SUBSOLB
  If GOK < 1 Then
    Return
  Endif
  # Maj des statistiques
  Call VALSTA("SOL",-1) From SUBPS2
  Call VALSTA("SOL",1) From SUBPS2
Return

##########################################################################################################
$AV_ANNULE
  #Suppression des clobs
  Gosub DELHD3 From SUBSOLB
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$ANNULE
  # Maj des statistiques
  Call VALSTA("SOL",-1) From SUBPS2
Return

##########################################################################################################
$AP_ANNULE
Return

##########################################################################################################
$APRES_CRE
  [M:SOL1]CREHOU = [F:SOL]CREHOU
  [M:SOL0]CXTSYNSRE = "SOLSRE"
  [M:SOL0]CXTSYNSOL = "SOL"
  Gosub DISPICON From SUBSOLB
  Affzo [M:SOL1]1-99
  Affzo [M:SOL2]1-99
Return

##########################################################################################################
$APRES_MOD
  [M:SOL0]CXTSYNSRE = "SOLSRE"
  [M:SOL0]CXTSYNSOL = "SOL"
  Gosub DISPICON From SUBSOLB
  Affzo [M:SOL1]1-99
  Affzo [M:SOL2]1-99
Return

##########################################################################################################
$RAZCRE
  [M:SOL2]SOLDESUPDF = 0
  Raz [M:SOL1]PBLFULDES
  [M:SOL0]CXTSYNSRE = "SOLSRE"
  [M:SOL0]CXTSYNSOL = "SOL"
  #Initialise les valeurs par défaut de l'enregistrement
  #Nom du créateur de la solution
  [M:SOL1]CREDAT = date$
  [M:SOL1]CREUSR = GUSER
  Read [AUS] CODUSR = [M:SOL1]CREUSR
  If !fstat Then
    [M:SOL1]FULNAMUSR = [F:AUS]NOMUSR
  Endif
  Call GET_LIBFC(409, [M:SOL1]CAT) From CRM_UTIL
  Gosub DISPICON From SUBSOLB
  Affzo [M:SOL1]1-99
  Affzo [M:SOL2]1-99
Return

##########################################################################################################
$LIENS
Local Integer TESTNBLIG
Local Integer I

  [M:SOL0]CXTSYNSRE = "SOLSRE"
  [M:SOL0]CXTSYNSOL = "SOL"
  #Affiche la famille de compétence
  If [M:SOL1]PBLGRP = "" Then
    [M:SOL1]PBLCLA = ""
  Else
    Read [PBL]PBL0=[M:SOL1]PBLGRP
    If fstat Then
      [M:SOL1]PBLCLA = ""
    Else
      # FGR 23/09/2009 : X3SUIVI58024
      #[M:SOL1]PBLCLA = [F:PBL]GRPPBLDES
      Call LECTEXTRA([M:SOL1]PBLCLA,"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
    Endif
  Endif
  #---------------------------------------------------#
  #  Affiche le nom du créateur de la solution en clair
  #---------------------------------------------------#
  If [M:SOL1]CREUSR <> "" Then
    If !clalev([F:AUS]) Local File AUTILIS [AUS] : Endif
    Read [AUS]CODUSR=[M:SOL1]CREUSR
    If !fstat Then
      [M:SOL1]FULNAMUSR = [F:AUS]NOMUSR
    Endif
    Affzo [M:SOL1]FULNAMUSR
  Endif
  #---------------------------------------------------#
  #  Affiche les clobs
  #---------------------------------------------------#
  #Lecture des clobs
  Gosub LOADHD3 From SUBSOLB
  #---------------------------------------------------#
  #  Remplit les tableaux
  #---------------------------------------------------#
  # Chargement du tableau des mots clés
  TESTNBLIG = 0
  For I = 0 To dim([F:SOL]KEYWRD)-1
    If [M:SOL3]KEYWRD(I) = "" Then
      Break
    Endif
    TESTNBLIG += 1
  Next
  [M:SOL3]NBWRD = TESTNBLIG
  # Chargement du tableau des solutions associées
  TESTNBLIG = 0
  For I = 0 To dim([F:SOL]CODSOL)-1
    If [M:SOL4]CODSOL(I) = "" Then
      Break
    Endif
    TESTNBLIG += 1
  Next
  For I = 0 To TESTNBLIG-1
    Read [SOL]SOL0=[M:SOL4]CODSOL(I)
    [M:SOL4]SOLCREDAT(I) = [F:SOL]CREDAT
  Next
  [M:SOL4]NBLIG = TESTNBLIG
  Gosub DISPICON From SUBSOLB
  Affzo [M:SOL1]1-99
  Affzo [M:SOL2]1-99
Return

##########################################################################################################
$SETBOUT
Local Integer IFUNOPEN

  IFUNOPEN = 0
  If REP = "" Then
    CHMEN += "D"   # FGR 17/10/2012 : X3SUIVI71278 Traçabilité des pièces "D"
    #Visualiser la demande
    If [M:SOL0]SRENUM <> "" Then
      Call ISFUNOPEN("GESSRE", IFUNOPEN) From CRMUTIL140
      If !IFUNOPEN Then
        CHMEN += "G"
      Endif
    Endif
    #Recherche de solution
    IFUNOPEN = 0
    Call ISFUNOPEN("GESSRE", IFUNOPEN) From CRMUTIL140
    If !IFUNOPEN Then
      CHMEN += "I"
    Endif
  Endif
  #----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
  Gosub SET_BOUT_SPE From GSAISIE
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return

##########################################################################################################
$FILTRE_GSZSOLKEY
Local Integer ITERG

  If type(GSZSOLKEY) > 0 Then
    Call ADDCRIT(FILGAUCHE, IFILGAUCHE, "FILGAUCHE", "NUM=G8", "&") From GOBJSUB
    For ITERG = 0 To dim(G9)-1
      If G9(ITERG) = "" Then
        Break
      Endif
      If ITERG >= 22 Then
        Break
      Endif
      Call ADDCRIT(FILGAUCHE, IFILGAUCHE, "FILGAUCHE", "NUM=G9(" + num$(ITERG) + ")", "|") From GOBJSUB
    Next
  Endif
Return

##########################################################################################################
$FILGAUCHE
  Default File [SOL]
  Gosub FILTRE_GSZSOLKEY
Return

##########################################################################################################
$FILTRE
  Default File [SOL]
  Gosub FILTRE_GSZSOLKEY
Return

##########################################################################################################
Subprog C_CODSOL(VALEUR)
Variable Char    VALEUR()
Local Integer IERR
Local Integer I

  IERR = 0
  If VALEUR = "" Then
    mkstat = 2
    End
  Endif
  #Vérifie si ce code solution n'a pas déjà été préalablement saisi dans ce tableau
  For I = 0 To dim ([M:SOL4]CODSOL)-1
    If I <> nolign-1 Then
      If [M:SOL4]CODSOL(I) = VALEUR and [M:SOL4]CODSOL(I) <> "" Then
        VALEUR = ""
        mkstat = 2
        GMESSAGE = mess(282,196,1) #Cette fiche solution a déjà été saisie.
        GERR = 2
        IERR = 1
      Endif
    Endif
  Next
  #Vérifie si l'on associe la fiche solution à elle-même.
  If !IERR Then
    If VALEUR = [M:SOL0]NUM Then
      VALEUR = ""
      mkstat = 2
      GMESSAGE = mess(281,196,1) #Vous ne pouvez pas associer une solution à elle-même.
      GERR = 2
    Else
      Read [SOL] SOL0 = VALEUR
      [M:SOL4]SOLCREDAT(nolign-1) = [F:SOL]CREDAT
    Endif
  Endif
  If !IERR Then
    [M:SOL4]CODSOL(nolign-1) = VALEUR
    Affzo [M:SOL4]CODSOL(nolign-1)
    Affzo [M:SOL4]SOLCREDAT(nolign-1)
  Endif
End

##########################################################################################################
Subprog C_NBWRD
Local Char SZMESSAGE(250)
Local Integer IBRETOUR
Local Integer NUMLIGNE
Local Char SZVIDE

  Raz SZMESSAGE
  IBRETOUR = 1
  NUMLIGNE = 0
  SZVIDE = ""
  If status = 65 Then
    #Effacement d'une seule ligne
    Call CRE_KWD([M:SOL3]KEYWRD(nolign-1), SZVIDE) From SUBSOLB
  Elsif status = 68 or status = 83 Then
    #Effacement d'un groupe de lignes
    For NUMLIGNE = nolign-1 To nolign1-1
      Call CRE_KWD([M:SOL3]KEYWRD(NUMLIGNE), SZVIDE) From SUBSOLB
    Next
  Endif
End

##########################################################################################################
Subprog C_KEYWRD(VALEUR)
Variable Char    VALEUR()

Local Integer I
Local Integer IERR
Local Char SZUPPWRD
Local Char SZUPPVAL

  IERR = 0
  SZUPPWRD = ""
  If VALEUR = "" Then
    mkstat = 2
    End
  Endif
  SZUPPVAL = toupper(VALEUR)
  VALEUR = SZUPPVAL
  Call CRE_KWD([M:SOL3]KEYWRD(nolign-1), VALEUR) From SUBSOLB
  #Vérifie qu'un même mot clé n'est pas saisi deux fois
  For I = 0 To dim ([M:SOL3]KEYWRD)-1
    If I <> nolign-1 Then
      SZUPPWRD = toupper([M:SOL3]KEYWRD(I))
      If SZUPPWRD = SZUPPVAL and [M:SOL3]KEYWRD(I) <> "" Then
        VALEUR = ""
        mkstat = 2
        IERR = 1
        GMESSAGE = mess(284,196,1) #Ce mot-clé a déjà été saisi pour cette fiche solution.
        GERR = 2
        Break
      Endif
    Endif
  Next
  If !IERR Then
    [M:SOL3]KEYWRD(nolign-1) = VALEUR
    Affzo [M:SOL3]KEYWRD(nolign-1)
  Endif
End

##########################################################################################################
Subprog AM_KEYWRD(VALEUR)
Variable Char    VALEUR()

End

##########################################################################################################
Subprog C_PBLGRP(VALEUR)
Variable Char    VALEUR()

  Gosub CTLSHORTCUT From SUBPBLB
End

##########################################################################################################
Subprog AM_PBLGRP(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    [M:SOL1]PBLCLA = ""
  Else
    Read [PBL]PBL0=VALEUR
    If fstat Then
      [M:SOL1]PBLCLA = ""
    Else
      # FGR 23/09/2009 : X3SUIVI58024
      #[M:SOL1]PBLCLA = [F:PBL]GRPPBLDES
      Call LECTEXTRA([M:SOL1]PBLCLA,"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
    Endif
  Endif
End

##########################################################################################################
Subprog AM_SOLDESX(VALEUR)
Variable Char    VALEUR()

Local Char SZMESSAGE(250)
Local Integer IBRETOUR
Local Char SZVIDE
Local Integer IMESSREP
Local Integer ITER
Local Integer INBWRDADDED
Local Char SZTEXT(250)
Local Char SZWORDS(230)(250)
Local Integer I
Local Char SZUPPWRD
Local Integer ICANADD

  Raz SZMESSAGE
  IBRETOUR = 1
  #Renseigne les nouveaux mots clés pertinents
  SZVIDE = ""
  If VALEUR = "" Then
    If [M:SOL3]NBWRD > 0 Then
      IMESSREP = 0
      #Souhaitez-vous supprimer les mots-clés associés à cette solution.
      Call OUINON(mess(711,182,1), IMESSREP) From GESECRAN
      If IMESSREP = 2 Then
        For ITER = 0 To [M:SOL3]NBWRD-1
          Call CRE_KWD([M:SOL3]KEYWRD(ITER), SZVIDE) From SUBSOLB
        Next
        Raz [M:SOL3]NBWRD
        Raz [M:SOL3]KEYWRD
      Endif
    Endif
  Else
    ICANADD = 1
    SZUPPWRD = ""
    INBWRDADDED = 0
    SZTEXT = VALEUR
    Call EXTWORD(451, SZTEXT, SZWORDS) From CRMUTIL140
    For ITER = 0 To dim(SZWORDS)-1
      If SZWORDS(ITER) = "" Then
        Break
      Endif
      Gosub ADDKEYWRD
    Next
    If INBWRDADDED Then
      If INBWRDADDED > 1 Then
        #NNN mots-clés définis comme pertinents ont été associés à cette solution.
        GMESSAGE = num$(INBWRDADDED) - mess(710,182,1)
      Else
        #NNN mot-clé défini comme pertinent a été associé à cette solution.
        GMESSAGE = num$(INBWRDADDED) - mess(712,182,1)
      Endif
      GERR = 2
    Endif
  Endif
  [M:SOL2]SOLDES = VALEUR
  Affzo [M:SOL2]SOLDES
  Affzo [M:SOL3]1-99
End

##########################################################################################################
Subprog IB_PBLFULDES
Raz GBOUT1
  If [M:SOL1]PBLFULDES <> "" Then
    If len([M:SOL1]PBLFULDES) > GLONCLE Then
      Call TEXTE(23819, GBOUT1) From OBJDIV      #Synthèse
    Endif
  Endif
End

##########################################################################################################
Subprog AM_PBLFULDES (VALEUR)
Variable Clbfile VALEUR

  Call GERE_TEXTE_SYNTHESE([M:SOL1]PBLFULDES, VALEUR, [M:SOL1]PBLDES) From CRMUTIL150  # FGR 06/08/2014 : X3SUIVI95250
  [M:SOL1]PBLFULDES = VALEUR
  Gosub DISPICON From SUBSOLB
  Affzo [M:SOL1]1-99
  Affzo [M:SOL2]1-99
End

##########################################################################################################
Subprog IB_SOLFULDES

  Raz GBOUT1
  If [M:SOL2]SOLFULDES<> "" Then
    If len([M:SOL2]SOLFULDES) > GLONCLE Then
      Call TEXTE(23819, GBOUT1) From OBJDIV      #Synthèse
    Endif
  Endif
End

##########################################################################################################
Subprog AM_SOLFULDES (VALEUR)
Variable Clbfile VALEUR

Local Integer ILNGCLOB
Local Integer INBBYTES
Local Integer IBUFFSIZE
Local Integer ITER
Local Integer ITER2
Local Char SZMESSAGE(250)
Local Integer IBRETOUR
Local Char SZVIDE
Local Integer IMESSREP
Local Integer INBWRDADDED
Local Char SZWORDS(230)(250)
Local Integer I
Local Char SZUPPWRD
Local Integer ICANADD

  Call GERE_TEXTE_SYNTHESE([M:SOL2]SOLFULDES, VALEUR, [M:SOL2]SOLDES) From CRMUTIL150  # FGR 06/08/2014 : X3SUIVI95250
  [M:SOL2]SOLFULDES = VALEUR
  Gosub DISPICON From SUBSOLB
  #On transfère le clob dans un tableau de chaines
  Read [ATY]CODTYP="HD3"
  If fstat Then
    ILNGCLOB = 6
  Else
    ILNGCLOB = [F:ATY]LNGTYP
  Endif
  If ILNGCLOB = 0 Then
    ILNGCLOB = 6
  Endif
  INBBYTES = 1024 * (2^ILNGCLOB)
  IBUFFSIZE = INBBYTES / 200
  IBUFFSIZE += 5

Local Char SZBUFFER(250)(IBUFFSIZE)
Local Char SZBUFFER2(250)(IBUFFSIZE)
Local Char SZBUFFER3(250)(IBUFFSIZE)

  Raz SZBUFFER
  Raz SZBUFFER2
  Raz SZBUFFER3
  Setlob SZBUFFER With [M:SOL2]SOLFULDES
  #Renseigne les nouveaux mots clés pertinents
  Raz SZMESSAGE
  IBRETOUR = 1
  SZVIDE = ""
  If SZBUFFER(0) = "" Then
    If [M:SOL3]NBWRD > 0 Then
      IMESSREP = 0
      #Souhaitez-vous supprimer les mots-clés associés à cette solution.
      Call OUINON(mess(711,182,1), IMESSREP) From GESECRAN
      If IMESSREP = 2 Then
        Raz [M:SOL3]NBWRD
        Raz [M:SOL3]KEYWRD
      Endif
    Endif
  Else
    ICANADD = 1
    SZUPPWRD = ""
    I = 0
    INBWRDADDED = 0
    Call SPLITBUFFER(SZBUFFER, SZBUFFER2, SZBUFFER3) From CRMUTIL140
    For ITER2 = 0 To dim(SZBUFFER2)-1
      If SZBUFFER2(ITER2) <> "" Then
        Raz SZWORDS
        Call EXTWORD(451, SZBUFFER2(ITER2), SZWORDS) From CRMUTIL140
        For ITER = 0 To dim(SZWORDS)-1
          If SZWORDS(ITER) = "" Then
            Break
          Endif
          Gosub ADDKEYWRD
        Next
      Endif
    Next
    For ITER2 = 0 To dim(SZBUFFER3)-1
      If SZBUFFER3(ITER2) <> "" Then
        Raz SZWORDS
        Call EXTWORD(451, SZBUFFER3(ITER2), SZWORDS) From CRMUTIL140
        For ITER = 0 To dim(SZWORDS)-1
          If SZWORDS(ITER) = "" Then
            Break
          Endif
          Gosub ADDKEYWRD
        Next
      Endif
    Next
    If INBWRDADDED Then
      If INBWRDADDED > 1 Then
        #NNN mots-clés définis comme pertinents ont été associés à cette solution.
        GMESSAGE = num$(INBWRDADDED) - mess(710,182,1)
      Else
        #NNN mot-clé défini comme pertinent a été associé à cette solution.
        GMESSAGE = num$(INBWRDADDED) - mess(712,182,1)
      Endif
      GERR = 2
    Endif
  Endif
  [M:SOL2]SOLDESUPDF = 1
  Affzo [M:SOL1]1-99
  Affzo [M:SOL2]1-99
  Affzo [M:SOL3]1-99
End

##########################################################################################################
$ADDKEYWRD
  ICANADD = 1
  #Vérifie qu'un même mot clé n'est pas saisi deux fois
  For I = 0 To dim([M:SOL3]KEYWRD)-1
    If [M:SOL3]KEYWRD(I) <> "" Then
      SZUPPWRD = toupper([M:SOL3]KEYWRD(I))
      If SZUPPWRD = SZWORDS(ITER) Then
        ICANADD = 0
        Break
      Endif
    Endif
  Next
  If ICANADD Then
    Call CRE_KWD(SZVIDE, SZWORDS(ITER)) From SUBSOLB
    #Ajoute le mot-clé dans l'écran
    [M:SOL3]KEYWRD([M:SOL3]NBWRD) = SZWORDS(ITER)
    [M:SOL3]NBWRD += 1
    INBWRDADDED += 1
  Endif
Return
