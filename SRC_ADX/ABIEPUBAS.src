#<AdxTL>@(#)9.0.0.0 $Revision$
Local Char VALBOUT(250) , PARBOUT(250)(1..20) # #
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","ABIEPUBAS","ABIEPUBAS",3,"") From GTRAITE
End

#------------------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "OUVRE_BATCH" : Gosub OUVRE_BATCH
 When "EXEC"        : Gosub EXEC
Endcase
Return
#------------------------------------------------------------#

$OUVRE_BATCH
$INIT
Local Integer   SILENCE
TIT = mess(145,148,1) : # Epuration Datawarehouse
Return

$EXEC 
# Affichage boîte d'info ??
If GSERVEUR
 SILENCE = 1
Else
 SILENCE = 0
 TRA = 1
Endif

If TRA
 Call OUVRE_TRACE(TIT) From LECFIC
Endif 

If !SILENCE
  Call OUVRE_VLC(TIT-[M]DATAW-"("-[M]DATAM-")","","") From GESECRAN
Endif
 
Call EPUBAS(nomap,[M]DATAW,[M]DATAM,SILENCE,[M]DET,[M]SIMU)
 
Call ECR_TRACE("",0) From GESECRAN
 
If !SILENCE
 Call FERME_VLC From GESECRAN 
Endif

If TRA
 Call FERME_TRACE From LECFIC
Endif
Return


Subprog EPUBAS(APPLI,DATAW,DATAM,SILENCE,DET,SIMU)
Value Char    APPLI
Value Char    DATAW
Value Char    DATAM
Value Integer SILENCE
Value Integer DET
Value Integer SIMU

If clalev([F:ABW])=0 : Local File =APPLI+".ABIDATWRH" [ABW] : Endif
If clalev([F:ABF])=0 : Local File =APPLI+".ABITABDAT" [ABF] : Endif
If clalev([F:ABM])=0 : Local File =APPLI+".ABIDATMRT" [ABM] : Endif
If clalev([F:AC2])=0 : Local File =APPLI+".ACTIV"     [AC2] : Endif

Local Integer  MAXFIC, MAXDOS , NBFIC 

Local Integer  I , J , K , N , NUM , OK , D , W , R , STAT , ERFIC , NBENREG , ERFOR

MAXFIC = 500
MAXDOS = 20

Local Char     MACHINE(GDIMFIC) , DOSSIER(GDIMFIC) , ORDSYS(250)
Local Char     LISFIC(30)(1..MAXFIC) , TBADX(250)(1..MAXDOS)
Local Char     CHAINE(255),INFO(100),CRITERE(250)

Read [ABW]ABW0=DATAW
If fstat
 Call ECR_TRACE(DATAW-":"-mess(1,148,1),1) From GESECRAN : # Datawarehouse inexistante
 End
Else
 Call MACHINE_BO([F:ABW]SOLBI,MACHINE) From ABICREBAS
 If MACHINE=""
  Call ECR_TRACE([F:ABW]COD-":"-mess(78,148,1),1) From GESECRAN : # Impossible de déterminer la machine BO
  End
 Elsif filinfo(filpath("FIL","","",[F:ABW]COD,"",MACHINE),0)<0
  Call ECR_TRACE([F:ABW]COD-":"-mess(1,148,1),1) From GESECRAN : # Datawarehouse inexistante
  End
 Elsif filinfo(filpath("FIL","ADOVAL","fde",[F:ABW]COD,"",MACHINE),0)>0
  Call TYPDOS(MACHINE+"@"+[F:ABW]COD,K,CHAINE) From DOSCONT
  # Ce dossier correspond à une application
  Call ECR_TRACE([F:ABW]COD-":"-mess(208,139,1)-CHAINE,1) From GESECRAN
  End
 Elsif filinfo(filpath("","synchro","",[F:ABW]COD,"",MACHINE),0)>0
  # Resynchronisation en cours
  Call ECR_TRACE([F:ABW]COD-":"-mess(148,124,1),1) From GESECRAN
  End
 Elsif filinfo(filpath("","valid","",[F:ABW]COD,"",MACHINE),0)>0
  # En cours de validation
  Call ECR_TRACE([F:ABW]COD-":"-mess(128,117,1),1) From GESECRAN
  End
 Elsif filinfo(filpath("","epuration","",[F:ABW]COD,"",MACHINE),0)>0
  # En cours de validation
  Call ECR_TRACE([F:ABW]COD-":"-mess(146,148,1),1) From GESECRAN
  End
 Else
  Call VERF_REFBO(MACHINE,[F:ABW]COD,CHAINE,OK) From SUBABW
  If !OK
   # Ce datawarehouse est utilisé par le dossier #
   Call ECR_TRACE(func AFNC.MES(mess(98,148,1),CHAINE),-1) From GESECRAN
   End
  Endif
 Endif
Endif

Call ECR_TRACE(mess(145,148,1)-[F:ABW]COD,0) From GESECRAN : # Synchronisation Datawarehouse

ORDSYS = "lsadx -a"-[F:ABW]COD-"FIL fde"
Call SYSTEME2(MACHINE,ORDSYS,"",NBFIC,LISFIC) From ORDSYS
If NBFIC<=0 : End : Endif

# Création du lock de synchronisation

Openo filpath("","epuration","",[F:ABW]COD,"",MACHINE),0 Using [LOK_]
Wrseq adxmac(-2)-adxusr-format$(GFMD,date$)-"-"-time$ Using [LOK_]
Openo Using [LOK_]

# Droits sur le dossier

Call SET_DROITS From TRTGRANT

# Epuration / simulation
Read [F:ABM]ABM0 = DATAM
If !fstat
 For I=0 To [F:ABM]NBRABF
  If func AFNC.ACTIV([ABM]ACTABF(I))=1
   Read [F:ABF]ABF0 = [F:ABM]CODABF(I)
   If  !fstat & [F:ABF]FLDDAT<>""  & [F:ABF]NBEPU>0
    INFO = [F:ABM]CODABF(I)-"("-mess(149,148,1)-":"-num$([F:ABF]NBEPU)-mess(38,104,1)-")"
    Gosub INFO
    DOSSIER  = MACHINE+"@"+[F:ABW]COD
    Onerrgo ERFIC
    OUVTAB = DOSSIER+".F_"+[F:ABM]CODABF(I): Local File =OUVTAB [AAA_]
    Onerrgo
    If !ERFIC
     Onerrgo ERR
     Gosub NBENREG
     If !ERFOR
      If SIMU<>2
       Gosub EPU_FAT
      Else
       Call ECR_TRACE("***  "+num$(NBENREG)-mess(148,148,1),0) From GESECRAN
      Endif
     Endif
      Onerrgo RIEN
      Close Local File [AAA_]
      Onerrgo ERR
    Endif
   Endif
  Endif
 Next
Endif

# Suppresion lock
Call EFFACE(filpath("","epuration","",[F:ABW]COD,"",MACHINE),STAT) From ORDSYS
End
##------------------------------------------------------------------------------------------##
##------------------------------------------------------------------------------------------##

#-----------------#
$EPU_FAT
Call DEBTRANS From GLOCK
Gosub TR_EPUFAT
Return

#-----------------#
$TR_EPUFAT
Trbegin [ABM]
 Delete [F:AAA_] Where evalue(CRITERE)
 If fstat=1 | fstat>5
  GOK = -1 : Call RSTA(INFO,CRITERE) From GLOCK
 Elsif !fstat
  Call ECR_TRACE("***  "+num$(NBENREG)-mess(148,148,1),0) From GESECRAN
 Endif
Commit
Return

#-----------------#
$NBENREG
Onerrgo ERFOR
CRITERE = [F:ABF]FLDDAT+"<=gdat$(date$-[F:ABF]NBEPU)"
Filter [F:AAA_] Where evalue(CRITERE)
For [F:AAA_]
 If [L]DET=2
  Call ECR_TRACE("**   "+mess(53,123,1)-[F:AAA_]ADOS-[F:AAA_]AREG-num$([F:AAA_]AIND)-[F:AAA_]ACLE,0) From GESECRAN
 Endif
 NBENREG+=1
Next
Filter
Return

#-----------------#
$ERFIC
ERFIC = errn
Call ECR_TRACE(mess(196,133,1)-":|"-OUVTAB+"|"-errmes$(ERFIC)-"|"-errm,1) From GESECRAN
Resume

#-----------------#
$ERR
ER = errn
Call ECR_TRACE(errp+"("+num$(errl)+")"-mess(6,123,1)-num$(ER)-errmes$(ER)-errm,1) From GESECRAN
Resume

#-------#
$ERFOR
ERFOR = errn
Call ECR_TRACE(FLD-":"-mess(65,106,1)-CRITERE+"\"+errmes$(ERFOR)-errm,1) From GESECRAN
Resume

#-----------------#
$RIEN
Resume

#-----------------#
$INFO
Call ECR_TIME(mess(147,148,1)-INFO) From DOSSUB : # Epuration de la table
If !SILENCE
 K = instr(1,INFO,"-")
 If K : INFO = left$(INFO,K-1) : Endif
 Call AFF_VLC(mess(147,148,1),INFO) From GESECRAN : # Epuration de la table
Endif
Return




