#<AdxTL>@(#)2.0.0.0 $Revision$
#     Mise à jour planning à partir de tableau piloté
#     par l'XSL standard de mise à jour planning
#
#     Les champs suivants doivent etre présents dans le tableau :
#     NBDAY  : Variable bas de tableau
#     TYPDAY : Type de jour (1 : Ouvré, 2 : WE, 3 : Férié)
#     PLAG1à n : Plages journées (n vaut 4 au maximum) 
#                Selon valeur du menu 9837 ou du menu personnalisé
#
#     Les paramètres :
#
#     période à mettre à jour identifiée par (LDEB-PLAGED-LFIN-PLAGEF)
#     LDEB    : ligne de début
#     PLAGED  : Plage de début
#     LFIN    : ligne de fin
#     PLAGEF  : Plage de fin
#     ETAT    : activité à affecter
#     MESSAGE : Message 
#     CODRET  : 1 Si OK
#
#     Seuls les jours ouvrés (TYPDAY=1) peuvent ête modifiés.
#
#     Les totaux sont mis à jour selon le principe suivant 
#     TOTTYPn est la somme des jours de type d'activité n (menu 9837 par défaut)
#

Subprog MAJPLAN(LDEB,PLAGED,LFIN,PLAGEF,ETAT,MESSAGE,CODRET)
Value Integer LDEB
Value Integer PLAGED
Value Integer LFIN
Value Integer PLAGEF
Value Integer ETAT
Variable Char MESSAGE()
Variable Integer CODRET
Local Integer I,NBPLAG,ITOT
Local Decimal INC

If dim([M]PLAG1)>0 : NBPLAG+=1 : Endif
If dim([M]PLAG2)>0 : NBPLAG+=1 : Endif
If dim([M]PLAG3)>0 : NBPLAG+=1 : Endif
If dim([M]PLAG4)>0 : NBPLAG+=1 : Endif


#  Mise à jour du tableau
For I=LDEB-1 To LFIN-1
  For J=1 To NBPLAG
    If [M]TYPDAY(I)>1 : Break 1 : Endif
    If (I=LDEB-1 and J<PLAGED) or (I=LFIN-1 and J>PLAGEF) : Goto SUITPLAG : Endif
    Case J
      When 1 : [M]PLAG1(I)=ETAT : Affzo [M]PLAG1(I)
      When 2 : [M]PLAG2(I)=ETAT : Affzo [M]PLAG2(I) 
      When 3 : [M]PLAG3(I)=ETAT : Affzo [M]PLAG3(I)
      When 4 : [M]PLAG4(I)=ETAT : Affzo [M]PLAG4(I)
    Endcase
$SUITPLAG
  Next J
Next I

#  Mise à jour des totaux

If dim([M]TOTTYP1)>0 : Raz [M]TOTTYP1 : Endif
If dim([M]TOTTYP2)>0 : Raz [M]TOTTYP2 : Endif
If dim([M]TOTTYP3)>0 : Raz [M]TOTTYP3 : Endif
If dim([M]TOTTYP4)>0 : Raz [M]TOTTYP4 : Endif
If dim([M]TOTTYP5)>0 : Raz [M]TOTTYP5 : Endif
If dim([M]TOTTYP6)>0 : Raz [M]TOTTYP6 : Endif
If dim([M]TOTTYP7)>0 : Raz [M]TOTTYP7 : Endif
If dim([M]TOTTYP8)>0 : Raz [M]TOTTYP8 : Endif
INC=1/NBPLAG

For I=0 To [M]NBDAY-1
  If dim([M]PLAG1)>0
   ITOT=[M]PLAG1(I) 
   Gosub CHARGTOT
  Endif
  If dim([M]PLAG2)>0
   ITOT=[M]PLAG2(I) 
   Gosub CHARGTOT
  Endif
  If dim([M]PLAG3)>0
   ITOT=[M]PLAG3(I) 
   Gosub CHARGTOT
  Endif
  If dim([M]PLAG4)>0
   ITOT=[M]PLAG4(I) 
   Gosub CHARGTOT
  Endif
Next I

If dim([M]TOTTYP1)>0 : Affzo [M]TOTTYP1 : Endif
If dim([M]TOTTYP2)>0 : Affzo [M]TOTTYP2 : Endif
If dim([M]TOTTYP3)>0 : Affzo [M]TOTTYP3 : Endif
If dim([M]TOTTYP4)>0 : Affzo [M]TOTTYP4 : Endif
If dim([M]TOTTYP5)>0 : Affzo [M]TOTTYP5 : Endif
If dim([M]TOTTYP6)>0 : Affzo [M]TOTTYP6 : Endif
If dim([M]TOTTYP7)>0 : Affzo [M]TOTTYP7 : Endif
If dim([M]TOTTYP8)>0 : Affzo [M]TOTTYP8 : Endif
CODRET=1
End

$CHARGTOT
   Case ITOT
    When 1 : If dim([M]TOTTYP1)>0 : [M]TOTTYP1+=INC : Endif
    When 2 : If dim([M]TOTTYP2)>0 : [M]TOTTYP2+=INC : Endif
    When 3 : If dim([M]TOTTYP3)>0 : [M]TOTTYP3+=INC : Endif
    When 4 : If dim([M]TOTTYP4)>0 : [M]TOTTYP4+=INC : Endif
    When 5 : If dim([M]TOTTYP5)>0 : [M]TOTTYP5+=INC : Endif
    When 6 : If dim([M]TOTTYP6)>0 : [M]TOTTYP6+=INC : Endif
    When 7 : If dim([M]TOTTYP7)>0 : [M]TOTTYP7+=INC : Endif
    When 8 : If dim([M]TOTTYP8)>0 : [M]TOTTYP8+=INC : Endif
    When Default
   Endcase
Return
