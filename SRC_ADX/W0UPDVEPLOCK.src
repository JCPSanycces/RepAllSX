#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque UPDVEPLOCK 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
indice = 0
status = 1
zoncou = "NBLIG"
If varmode([M]NBLIG,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG = nolign
   status = 75
   Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

## Zone FLGLOCK
mkstat = 0
zoncou = "FLGLOCK"
IMPENT = [M]FLGLOCK(indice)
If varinit([M]FLGLOCK,indice)=0
 IMPENT = 1
Endif
If varmode([M]FLGLOCK,indice)=0
 [M]FLGLOCK(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "FLGLOCK" : Gosub ACTION From =IMPTRT
  IMPENT = [M]FLGLOCK(indice)
 Endif
 If IMPENT=0
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "FLGLOCK" : GZNUM = 51786 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif
[M]FLGLOCK(indice) = IMPENT

## Zone STA
mkstat = 0
zoncou = "STA"
IMPENT = [M]STA(indice)
If varinit([M]STA,indice)=0
 IMPENT = 1
Endif
[M]STA(indice) = IMPENT

## Zone FLGGEN
mkstat = 0
zoncou = "FLGGEN"
IMPENT = [M]FLGGEN(indice)
If varinit([M]FLGGEN,indice)=0
 IMPENT = 1
Endif
[M]FLGGEN(indice) = IMPENT

## Zone FLGSYN
mkstat = 0
zoncou = "FLGSYN"
IMPENT = [M]FLGSYN(indice)
If varinit([M]FLGSYN,indice)=0
 IMPENT = 1
Endif
[M]FLGSYN(indice) = IMPENT

## Zone FLGVRA
mkstat = 0
zoncou = "FLGVRA"
IMPENT = [M]FLGVRA(indice)
If varinit([M]FLGVRA,indice)=0
 IMPENT = 1
Endif
[M]FLGVRA(indice) = IMPENT

## Zone FLGANA
mkstat = 0
zoncou = "FLGANA"
IMPENT = [M]FLGANA(indice)
If varinit([M]FLGANA,indice)=0
 IMPENT = 1
Endif
[M]FLGANA(indice) = IMPENT

## Zone SELFLG
mkstat = 0
zoncou = "SELFLG"
IMPENT = [M]SELFLG(indice)
If varinit([M]SELFLG,indice)=0
 IMPENT = 1
Endif
[M]SELFLG(indice) = IMPENT

## Zone OLDLOCK
mkstat = 0
zoncou = "OLDLOCK"
IMPENT = [M]OLDLOCK(indice)
If varinit([M]OLDLOCK,indice)=0
 IMPENT = 1
Endif
[M]OLDLOCK(indice) = IMPENT

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "UPDVEPLOCK"
Return

