######################################################################################################
# Module        : Accounting
# Description   : Swiss specific initializations for payments
######################################################################################################
 # Updates :
 # Date     |Author|Version|Description
 # 24.06.15 |Bader |U9     |add AM_FCY to init GSWIPAYBVR for new company
######################################################################################################


Subprog AM_BPR(BPR)
Variable Char BPR
Local Char CPY(GLONCPY)
Local Char XSLEG(GLONADI)

If dim(GSWIPAYBVR) > 0 and GSWIPAYBVR = 2 : # parameter "Swiss checks in payments" = yes?
  If clalev([F:TPY])=0 : Local File TABPAYTYP [TPY] : Endif
  Call LEC_TPY_LEG(GCURLEG,[M]PAYTYP) From CPTLEC  # read payment entry type
  # X3-29237
  If find([F:TPY]SWIPAYTYP,2,3,4)    # DTA/EZAG/ISO payment?
    Read [BPSX]BPS0 = BPR
    If fstat = 0
      If dim([M:PAY2]CPY) > 0
        CPY = [M:PAY2]CPY
      Else
        If !clalev([F:XFCY]) : Local File FACILITY [XFCY] : Endif
        Read [F:XFCY]FCY0=[M:PAY1]FCY
        If fstat = 0  #lecture ok
          CPY = [F:XFCY]LEGCPY
        Endif
      Endif
      Raz [L]XSLEG
      Call GET_LEG(CPY,[L]XSLEG) From SWILIB0
      Read [TPTX]TPT0 = [BPSX]PTE;[L]XSLEG;1
      If fstat = 0
         [M:PAY1]PAM = [TPTX]PAM
         If !GIMPORT Affzo [M:PAY1]PAM : Endif
      Else                  # not found -> try without LEG
         Read [TPTX]TPT0 = [BPSX]PTE;"";1
         If fstat = 0
            [M:PAY1]PAM = [TPTX]PAM
            If !GIMPORT Affzo [M:PAY1]PAM : Endif
         Else
            GERR=1 : GMESSAGE=func AFNC.MES1(mess(48,3648,1),[BPSX]PTE) # Error reading the payment term $1$.
         Endif
      Endif
    Else
      GERR=1 : GMESSAGE=func AFNC.MES1(mess(36,3648,1),BPR) # Error reading the business partner $1$.
    Endif
  Endif
Endif
End


Subprog AM_VCRNUM(VCR)
Variable Char VCR
Local Char XSVCRTYP(20)

Call PARAM([M:PAY1]FCY,"TYPINVSUP",XSVCRTYP) From ADOVAL

If nolign-1 = 0 : #->> On est sur la première ligne
   If [M]VCRTYP(nolign-1) = XSVCRTYP
      #***MAJ jour du mode de règlement
      Read [DUDX]DUD0 = VCRTYP;VCR;1;1
      If fstat = 0
         [M:PAY1]PAM = [DUDX]PAM
         If !GIMPORT Affzo [M:PAY1]PAM : Endif
      Endif
   Endif
Endif
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
   If dim(GSWIPAYBVR) > 0 : GSWIPAYBVR = int(val(func AFNC.PARAM("SWIPAYBVR", VALEUR))) : Endif
End

