#<AdxTL>@(#)3.0.0.0 $Revision$
############################################################################
# UUMGINISAL07   Moulinette de Migration des retours         Module Ventes #
#                                                                          #
# Pour toutes les versions                                                 #
# ------------------------                                                 #
# Détail devis : SRETURND                                                  #
# --------------------------                                               #
# Alim. STOFCY à partir de l'entête si différence                          #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGINISAL07") From LECFIC
  Endif

  #Call RAZ_UUMGINISAL07(DOSSIER)
  Call MAJ_UUMGINISAL07(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End


##########################################################################
Subprog MAJ_UUMGINISAL07(DOSSIER)
Value Char DOSSIER

# Issue 106947 - 20150811 by LD : Migration of historic folder
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1
# Issue 106947 - 20150811 by LD

Local Integer TOTNBR
Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : : # N = no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL07",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

#----- Récupération du n° de version
Local Char    CVERSION(3)
Local Integer VERSION
Call MIGGETVERSION (DOSSIER,CVERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL06",7,ERR) From TRTMIG : #7=Erreur
  End
Else
 VERSION=val(CVERSION)
Endif

Local Char WNAMSRHM,WNAMSRDM
Call MIGTABNAME (DOSSIER,"SRETURN", WNAMSRHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SRETURND",WNAMSRDM,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL07",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMSRHM, "fde",DOSSIER),0)<0
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL07",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMSRDM, "fde",DOSSIER),0)<0
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL07",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL07",2,ERR) From TRTMIG : #2=En cours

###################

Call ECR_TIME("UUMGINISAL07 Sales Return Process : Update SRETURN-D") From DOSSUB
Call ECR_TRACE("UUMGINISAL07 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG

#----- SRETURN => TOTNBR= Number of lines  -----#
Call MIGGETTOTNBR (DOSSIER,"SRETURN",TOTNBR,ERR) From TRTMIG
Trbegin [AMY]
Call MIGSTKTOTNBR (DOSSIER,"UUMGINISAL07",TOTNBR,ERR) From TRTMIG
Commit

#----- Ouverture des fichiers -----#
If clalev([F:SRHM]) = 0 : Local File =DOSSIER+"."+WNAMSRHM   [SRHM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:SRDM]) = 0 : Local File =DOSSIER+"."+WNAMSRDM   [SRDM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer NBLUS, NBCOMMIT
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, NBCOMMIT

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGINISAL07",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG

If NBCOMMIT=0
  #----- Suppression des incohérences entre tables avant migration -----#
  Gosub TRT_SQL
  If GOK<1 : Goto FIN : Endif
  Trbegin [AMY]
  NBLUS=TOTNBR
  NBCOMMIT=TOTNBR
  Call MIGSTKKEY (DOSSIER,"UUMGINISAL07",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
  Commit
Endif

$FIN
Close Local File [SRDM], [SRHM]

Call ECR_TIME("UUMGINISAL07 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB

Call MIGTRTEND (DOSSIER,"UUMGINISAL07") From TRTMIG
End
##########################################################################
Subprog RAZ_UUMGINISAL07(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : # N= no module
  End
Endif

Local Char WNAMSRHM,WNAMSRDM
Call MIGTABNAME (DOSSIER,"SRETURN", WNAMSRHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SRETURND",WNAMSRDM,ERR) From TRTMIG
If ERR : End : Endif

If filinfo(filpath("FIL",WNAMSRHM, "fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table
If filinfo(filpath("FIL",WNAMSRDM, "fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table

##2 - On vide les fichiers selon le cas
#######################################

##3 - On vide AMIGKEY pour le flux
####################
Call MIGRAZKEY (DOSSIER,"UUMGINISAL07",ERR) From TRTMIG

End
########################################################################
#----- Suppression des incohérences entre tables avant migration -----#
########################################################################
$TRT_SQL

 #-----  Déclaration des variables -----#

 Call DEBTRANS From GLOCK
 Gosub SET_FIRST From TRTFIRST

 Trbegin [SRDM]
 GOK = 1

 Gosub TRT_SQL1

 If GOK<1
  Rollback
 Else
  Commit
 Endif

Gosub UNSET_FIRST From TRTFIRST

Return

########################################################################
# Mise à jour STOFCY SRETURND à partir de STOFCY SRETURN
########################################################################
$TRT_SQL1
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL

REQSQL(0)="UPDATE"-DOSSIER+"."+WNAMSRDM+" SET STOFCY_0="
REQSQL(1)="(SELECT SRH.STOFCY_0 FROM"-DOSSIER+"."+WNAMSRHM+" SRH Where SRH.SRHNUM_0="+WNAMSRDM+".SRHNUM_0)"
REQSQL(2)=" WHERE "+WNAMSRDM+".STOFCY_0<>(SELECT SRH.STOFCY_0 From"-DOSSIER+"."+WNAMSRHM+" SRH Where SRH.SRHNUM_0="+WNAMSRDM+".SRHNUM_0) "
Execsql From num$(GTYPDBA*2+1) Sql REQSQL

Onerrgo
Return
###################################################################################################
$ERR_SQL
 GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
 Call ECR_TRACE(GMESSAGE,1) From GESECRAN
 GOK=0
Resume
########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 106947 - 20150811 by LD : Migration of historic folder
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
# Issue 106947 - 20150811 by LD
Call MAJ_UUMGINISAL07(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGINISAL07(APPLI)
End

