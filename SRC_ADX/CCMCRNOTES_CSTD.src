#<AdxTL>@(#)0.0.0.0 $Revision$
# Data Class script: CCMCRNOTES_CSTD, Change Request - Attachments Collection

#####################
# METHODS           #
#####################
$METHODS

  Case CURPTH
    When ""
      Case ACTION
        When "ADDLINE_AFTER"
          Gosub INCREMENT_LINE_NUMBER
      Endcase
  Endcase

Return

# --------------------------------------------------
# Increment collection row's line number (NOTELINE)
# for subsequent database update.
$INCREMENT_LINE_NUMBER

  this.NOTELINE = 1 + max (this.APARENT.CCMCRNOTES(1..maxtab(this.APARENT.CCMCRNOTES)).NOTELINE)

Return


#####################
# PROPERTIES        #
#####################
$PROPERTIES

  Case CURPRO
        When "CRNOTES"
         Case ACTION
          When "PROPAGATE" : Gosub CRNOTES_PROPAGATE
         Endcase
  Endcase

Return

# --------------------------------------------------
# File name is added to the property CRNOTES when file is uploaded
$CRNOTES_PROPAGATE
  this.FILENAM = fmet this.AGETATTRIBUTE("CRNOTES", "$filename")
Return


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

