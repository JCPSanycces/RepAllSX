Subprog DELOCKE_FAS (PCPY, RLOCK_FAS)
Value Char PCPY
Variable Integer RLOCK_FAS

Local Char LLOCK(200)

  # -----------------------
  Call UNLOCK_SYMBOLE ("FAS", PCPY, "") From GLOBIENS
  RLOCK_FAS = G_NON

End
#====================================================================
# Initialisation des zones Initiales, Théoriques et Réelles lors
# du passage d'un plan de standard à normé IAS ou CRC2002-10
#====================================================================
Funprog ACTIVATION_NORME(PCPY, PCNX, PPLN)
Value Char    PCPY       # Société
Value Integer PCNX       # Contexte
Value Integer PPLN       # Plan pour lequel la norme est activée

If !clalev([F:WFIS]) : Local File FISCYEAR  [WFIS] : Endif
If !clalev([F:WDEP]) : Local File DEPREC    [WDEP] : Endif

Local Integer RCOD           : RCOD      = 0
Local Char    L_REQUETE(255) : L_REQUETE = "1=1"
Local Date    L_DATDEB
Local Date    L_DATFIN
Local Integer L_NBTOTBCO
Local Integer L_NBTRTBCO
Local Integer ROK

#> Récupération des dates du contexte

Read [F:WFIS]FIY1=PCPY;PCNX;GVML_TECOURA
If fstat
 GOK = 0
 Call RSTA("WFIY",CPY+"~"+num$(PCNX)+"~"+num$(GVML_TECOURA)) From GLOCK
 RCOD = 10+fstat
 End RCOD
Endif

L_DATDEB = [F:WFIS]DATSTRPER(0)
L_DATFIN = [F:WFIS]DATENDPER(0)

#> Construction du critère de sélection
L_REQUETE = "CPY=PCPY & DPRPLN=PPLN & PERSTRDAT=L_DATDEB & PERENDDAT=L_DATFIN"

#> Sélection / Lecture des biens à traiter
Filter [WDEP] Where evalue(L_REQUETE)
L_NBTOTBCO = rowcount([WDEP])
If L_NBTOTBCO=0
 RCOD = 0
 End RCOD
Endif

Call OUVRE_BOITE(mess(192,GML_MSGFASPR,1),L_NBTOTBCO) From GESECRAN #"Initialisation des informations IAS ou CRC du plan"
For [WDEP]
 #> Pour chaque bien, on initialise les informations nécessaires au calcul pour un plan normé à partir
 #  du cumul d'amortissement des exercices antérieurs et du cumul d'amortissement des périodes closes
 #  de l'exercice.
 [F:WDEP]EXECLOCUMI = [F:WDEP]DPRCUM
 [F:WDEP]EXECLOCUMT = [F:WDEP]DPRCUM
 [F:WDEP]DEPSTA     = GVML_SCNOCAL
 Rewrite [WDEP] Curr
 If fstat
  GOK= 0
  Call RSTA("WDEP",[F:WDEP]AASREF+"~"+num$([F:WDEP]DPRPLN)+"~"+format$("DD2",[F:WDEP]FIYENDDAT)+"~"+format$("DD2",[F:WDEP]PERENDDAT)) From GLOCK
  RCOD = 20+fstat
  Break
 Endif
 L_NBTRTBCO+=1

 Call AFF_BOITE  ([F:WDEP]AASREF,L_NBTRTBCO,ROK) From GESECRAN
Next
Filter [WDEP]

Call FERME_BOITE From GESECRAN

End RCOD
#====================================================================
# Initialisation des plans du contexte
#====================================================================
Subprog INIT_PLAN (P_CONTEXT)
Value Integer P_CONTEXT

Local Integer N_I
Local Char RLED, RDEVLED, RCOA

  Local Integer ERR
  Call LOAD_FASPARCPY([M:CNX0]CPY,"",G_NON,ERR) From GLOFCYCPY

  Read[CPY]CPY0=[M:CNX0]CPY
  If fstat=0
     G_PAYS = [F:CPY]CRY
  Endif
  Call ACTION_BLOCK (ACB_EFFZO, "CNX1", "PLNCAA") From GLOBIENS
  N_I= 1
  If P_CONTEXT = G300CPFI
    [M:CNX1]NBPLC = 1
    # Comptable et fiscal
    [M:CNX1]PLNCAA(N_I-1)     = G301CPT
    [M:CNX1]LEDTYP(N_I-1)     = [M:FPC]GENLEDTYP
    Call  LECLED([M:CNX0]CPY,[M:CNX1]LEDTYP(N_I-1),RLED,RDEVLED) From CPTDIV
    [M:CNX1]LED(N_I-1)= RLED
    Call LECPLAN([M:CNX0]CPY,[M:CNX1]LEDTYP(N_I-1),RCOA) From CPTDIV
    [M:CNX1]COA(N_I-1)= RCOA
    If   [M:FPC]LEG = "FRA"
       [M:CNX1]PLNSTD(N_I-1)     = GVML_NPCRC
    Else
       [M:CNX1]PLNSTD(N_I-1)     = GVML_NPSTD
    Endif
    [M:CNX1]PLNMGT(N_I-1)     = G_OUI
    [M:CNX1]PLNMGTSV(N_I-1)   = G_OUI
    [M:CNX1]FLUTRATXS(N_I-1) = [F:CPY]CRY
    If [F:CPY]CRY = 'FR'
         [M:CNX1]FLUTRATXS(N_I-1) = [F:CPY]CRY
    Else
         [M:CNX1]FLUTRATXS(N_I-1) = ""
    Endif
    [M:CNX1]FLUTRAACC(N_I-1) = G_NON

    If GFRADGI=G_OUI : # FQ73079
      Gosub CRE_EXE_PER From SUBCNX2
    Endif
  Else
      [M:CNX1]PLNCAA(N_I-1)    = 0
      [M:CNX1]PLNMGT(N_I-1)    = G_OUI
      [M:CNX1]PLNMGTSV(N_I-1)  = G_NON
      [M:CNX1]FLUTRATXS(N_I-1) = ""
      [M:CNX1]FLUTRAACC(N_I-1) = G_NON
      [M:CNX1]ORIBASDPR(N_I-1) = 0
 Endif

 Call ACTION_BLOCK (ACB_AFFZO, "CNX1", "PLNCAA") From GLOBIENS

 If N_I & [M:CNX1]LEDTYP(N_I-1)=GVML_TLSOC
  Grizo [M:CNX1]LEDTYP(N_I-1)
  Grizo [M:CNX1]LED(N_I-1)
 Endif

End
########################################
Subprog PERIODE_SAISISSABLE ()
Local Date DATE_DEB_EXE
Local Integer N_I

  If STAFIY([M:CNX3]YEACLICK-1) = GVML_TEPREC
    # Si l'exercice est clos on ne peut plus rien faire sur les périodes
    Disable 65 : # status Suppression ligne
    Disable 73 : # status insertion ligne
    GBOUT1 = ""
    GBOUT2 = ""
    GBOUT3 = ""
    GBOUT4 = ""
    GBOUT5 = ""
    GBOUT6 = ""
    GBOUT7 = ""
  Else
    DATE_DEB_EXE = [M:CNX2]DATSTRFIY([M:CNX3]YEACLICK-1)
    If DATE_DEB_EXE = [0/0/0]
      # si aucun exercice n'est défini on ne peut pas définir de période
      Disable 65 : # status Suppression ligne
      Disable 73 : # status insertion ligne
      GBOUT1 = ""
      GBOUT2 = ""
      GBOUT3 = ""
      GBOUT4 = ""
      GBOUT5 = ""
      GBOUT6 = ""
      GBOUT7 = ""
    Else
      #
      For N_I = 1 To [M:CNX2]NBPER2
        If [M:CNX2]STAPER(nolign-1) = GVML_SPCLOSE  or
&                [M:CNX2]DATENDPER(N_I) <> [0/0/0]  #or [M:CNX2]DATENDPERS(N_I-1) <> [0/0/0]
          # Si au moins une période est close ou que la date de fin de la période suivante est alimentée
          # => ON NE PEUT PAS UTILISER LES BOUTONS
          GBOUT1 = ""
          GBOUT2 = ""
          GBOUT3 = ""
          GBOUT4 = ""
          GBOUT5 = ""
          Break
        Endif
        # --------------------------
        # Suite de la boucle
      Next N_I
    Endif
  Endif
End
########################################
Subprog VAL_DEFAUT_PER3()

  If varinit([M:CNX2]STAPER, nolign-1) = 0  & GREP <> "M"
    [M:CNX2]STAPER(nolign-1) = GVML_SPFERME
    [M:CNX2]TYPPST(nolign-1) = 0
  Endif

End
########################################
Subprog SEND_PERIODE_EN_GLOBAL(P_LIGNE)
Value Integer P_LIGNE

Local Integer N_E

  N_E = [M:CNX2]INDCNX3(P_LIGNE-1)
  If N_E = 0
     [M:CNX3]NBPERC            += 1
     N_E                        = [M:CNX3]NBPERC
    [M:CNX2]INDCNX3(P_LIGNE-1) = N_E
    Affzo [M:CNX2]INDCNX3(P_LIGNE-1)
  Endif
  [M:CNX3]INDFISYEA(N_E-1)  = [M:CNX3]YEACLICK
  [M:CNX3]DATSTRPER(N_E-1)  = [M:CNX2]DATSTRPER(P_LIGNE-1)
  [M:CNX3]DATENDPER(N_E-1)  = [M:CNX2]DATENDPER(P_LIGNE-1)
  [M:CNX3]DATENDPERS(N_E-1) = [M:CNX2]DATENDPERS(P_LIGNE-1)
  [M:CNX3]NBRMONPER(N_E-1)  = [M:CNX2]NBRMONPER(P_LIGNE-1)
  [M:CNX3]NBRWEKPER(N_E-1)  = [M:CNX2]NBRWEKPER(P_LIGNE-1)
  [M:CNX3]NBRDAYPER(N_E-1)  = [M:CNX2]NBRDAYPER(P_LIGNE-1)
  If GREP <> "M"
     If P_LIGNE=1
        If  STAFIY([M:CNX3]YEACLICK-1) = GVML_TECOURA
           If [M:CNX2]STAPER(P_LIGNE-1) = 0
              [M:CNX2]STAPER(P_LIGNE-1) = GVML_SPCOURA
           Endif
           If [M:CNX2]TYPPST(P_LIGNE-1) = 0 # FQ93002
              [M:CNX2]TYPPST(P_LIGNE-1) = GVML_TPSTPRO
           Endif
        Else
# FQ93002
           If [M:CNX2]TYPPST(P_LIGNE-1)= 0
              [M:CNX2]TYPPST(P_LIGNE-1) = GVML_TPSTPRO
           Endif
        Endif
        If [M:CNX2]INDCURPER(P_LIGNE-1)< 1
           [M:CNX2]INDCURPER(P_LIGNE-1)= 1
        Endif
     Else
# FQ93002
#         [M:CNX2]STAPER(P_LIGNE-1)= GVML_SPFERME
#         [M:CNX2]TYPPST(P_LIGNE-1)= 0
         If [M:CNX2]STAPER(P_LIGNE-1) = 0
             [M:CNX2]STAPER(P_LIGNE-1)= GVML_SPFERME
         Endif
         If [M:CNX2]TYPPST(P_LIGNE-1) = 0
            [M:CNX2]TYPPST(P_LIGNE-1) = GVML_TPSTPRO
         Endif
     Endif
  Endif
  [M:CNX3]STAPER(N_E-1)        = [M:CNX2]STAPER(P_LIGNE-1)
  [M:CNX3]TYPPST(N_E-1)        = [M:CNX2]TYPPST(P_LIGNE-1)
  [M:CNX3]LSTTYPPRO(N_E-1)     = [M:CNX2]LSTTYPPRO(P_LIGNE-1)
  [M:CNX3]NBPERC+=1
End
########################################
Subprog CALCUL_TOTAUX2 (P_SIGNE, P_LIGNE)
# Calcul les totaux des tableaux de périodes
# P_SIGNE = 1 soustrait, P_SIGNE = 2 ajoute, P_SIGNE = 3 RAZ
Value Integer P_SIGNE
Value Integer P_LIGNE
  If P_SIGNE = 2
    [M:CNX2]TOTMON += [M:CNX2]NBRMONPER(P_LIGNE-1)
    [M:CNX2]TOTWEK += [M:CNX2]NBRWEKPER(P_LIGNE-1)
    [M:CNX2]TOTDAY += [M:CNX2]NBRDAYPER(P_LIGNE-1)
  Elsif P_SIGNE = 1
    [M:CNX2]TOTMON -= [M:CNX2]NBRMONPER(P_LIGNE-1)
    [M:CNX2]TOTWEK -= [M:CNX2]NBRWEKPER(P_LIGNE-1)
    [M:CNX2]TOTDAY -= [M:CNX2]NBRDAYPER(P_LIGNE-1)
  Else
    [M:CNX2]TOTMON = 0
    [M:CNX2]TOTWEK = 0
    [M:CNX2]TOTDAY = 0
  Endif
End

########################################
Subprog RAZ_TAB_PER_CUMULE
Local Integer N_I

  For N_I = 1 To [M:CNX2]NBPER2-1
    [M:CNX3]INDFISYEA([M:CNX2]INDCNX3(N_I-1)-1) = 9999
    # ------------------
    # Suite de la boucle
  Next N_I
  Sorta [M:CNX3]NBPERC [M:CNX3]NBPERC Order By [M:CNX3]INDFISYEA(indice), [M:CNX3]DATSTRPER(indice)
  Call ACTION_BLOCK (ACB_AFFZO, "CNX2", "DATSTRFIY") From GLOBIENS
  Call ACTION_BLOCK (ACB_AFFZO, "CNX3", "NBPERC") From GLOBIENS
End

########################################
Subprog AFFICHE_TOTAUX3 ()
# Calcul les totaux des tableaux de périodes
  Affzo [M:CNX2]TOTMON
  Affzo [M:CNX2]TOTWEK
  Affzo [M:CNX2]TOTDAY
End
########################################
Subprog PER_CALCUL_POIDS(P_LIGNE, P_BAFFICHE)
Value Integer P_LIGNE
Value Integer P_BAFFICHE

Local Integer NB_JOURS
Local Integer NB_MOIS
Local Integer NB_WEEK
Local Decimal NB_YEAR

  Call CALCUL_NB_D_M_W_Y ([M]DATSTRPER(P_LIGNE-1), [M]DATENDPER(P_LIGNE-1), NB_JOURS, NB_MOIS, NB_WEEK, NB_YEAR) From GLOBIENS
  [M]NBRMONPER(P_LIGNE-1) = NB_MOIS
  [M]NBRDAYPER(P_LIGNE-1) = NB_JOURS
  [M]NBRWEKPER(P_LIGNE-1) = NB_WEEK

  If P_BAFFICHE = G_OUI
    Affzo [M]NBRMONPER(P_LIGNE-1)
    Affzo [M]NBRWEKPER(P_LIGNE-1)
    Affzo [M]NBRDAYPER(P_LIGNE-1)
  Endif
End

########################################
Subprog DISABLE_POIDS

  If [M]STAPER(nolign-1) = GVML_SPCLOSE
     Diszo [M]DATENDPER(nolign-1)
     Diszo [M]NBRMONPER(nolign-1)
     Diszo [M]NBRWEKPER(nolign-1)
     Diszo [M]NBRDAYPER(nolign-1)
  Else
     Actzo [M]DATENDPER(nolign-1)
     Actzo [M]NBRMONPER(nolign-1)
     Actzo [M]NBRWEKPER(nolign-1)
     Actzo [M]NBRDAYPER(nolign-1)
  Endif

End
################################################################################
# Fonctions locales
################################################################################
Subprog GET_DATE_DEBUT_EXERCICE (P_TYPE_EXE, R_DATE)
# Rend la date de début d'exercice courant ou suivant
Value Integer P_TYPE_EXE
Variable Date R_DATE

Local Integer N_I

  R_DATE = [0/0/0]
  N_I = find(P_TYPE_EXE, [M:CNX2]STAFIY(0..[M:CNX2]NBFIY-1))
  If N_I <> 0
    R_DATE = [M:CNX2]DATSTRFIY(N_I-1)
  Endif
End

########################################
Subprog GET_DATE_FIN_EXERCICE (P_TYPE_EXE, R_DATE)
# Rend la date de début d'exercice courant ou suivant
Value Integer P_TYPE_EXE
Variable Date R_DATE

Local Integer N_I

  R_DATE = [0/0/0]
  N_I = find(P_TYPE_EXE, [M:CNX2]STAFIY(0..[M:CNX2]NBFIY-1))
  If N_I <> 0
    R_DATE = [M:CNX2]DATENDFIY(N_I-1)
  Endif
End


#=============================================
# Fonction pour déterminer si la norme est modifiable ou pas
#Fq-63496 en fonction de la période dans laquelle on se trouve
# --> IS_MODIFIABLE=G_OUI si 1ère période de l'exercice.
#=============================================
Funprog IS_PLNSTD_MODIFIABLE(PCPY,PCNX)
Value Char    PCPY
Value Integer PCNX

Local Integer ISMODIFIABLE

If !clalev([F:FIS]) : Local File FISCYEAR  [FIS] : Endif

Read [FIS]FIY1=[M]CPY;[M]CNX;GVML_TECOURA
If fstat
 ISMODIFIABLE = -1
 End ISMODIFIABLE
Endif

#Fq-63496
 If [F:FIS]INDCURPER=1
   ISMODIFIABLE=G_OUI
 Endif    #Fq-63496

End ISMODIFIABLE
##########################################################################
##          CONTROLE UNICITE (pas de lignes en double)
##########################################################################
Subprog UNICITE(VALEUR,TABLO)
Value Char VALEUR
Value Integer TABLO
Local Integer I, NOL

NOL = nolign-1
I = find(VALEUR,TABLO(0..NOL-1),TABLO(NOL+1..dim(TABLO)-1))
If I
  If I>NOL
    I += 1
  Endif
  # Code déjà existant en ligne
  GERR=1   :  GMESSAGE = mess(159,GML_MSGFASPR,1)-num$(I)
  mkstat=2 :  End
Endif

End
######################################################################################
######################################################################################
#                 F O N C T I O N S      D I V E R S E S
######################################################################################
#=====================================================================
# Mise à jour des indicateurs de recalcul sur les biens comptables
#=====================================================================
# FQ88911 ajout LRET en param
Subprog UPD_FAS_FLGCLC (PCNX, LRET)
# ----------------------------
Value Integer PCNX
Variable Integer LRET

Local Integer N_I

N_I = find(GVML_TECOURA,[M:CNX2]STAFIY)

If !N_I : LRET=1 : End : Endif

LRET=0

 Update [FAS] Where CPY=[M:CNX0]CPY and (ISSDAT>=[M:CNX2]DATSTRFIY(N_I-1) or ISSDAT=[0/0/0])
&                    With   FLGCLC            = G_OUI,
&                           FLGCNXCLC(PCNX-1) = G_OUI
  If fstat
    LRET=1
  Endif

If G_ACTCCN = G_OUI          #<<<<<<<<<Fq-70181
     #FQ-75362   Update [FAS] Where CPY=[M:CNX0]CPY
     Update [FAS] Where CPY=[M:CNX0]CPY and (ISSDAT>=[M:CNX2]DATSTRFIY(N_I-1) or ISSDAT=[0/0/0])
&                 With   FLGRPRCLC            = G_OUI
   If fstat
      LRET=1
   Endif
Endif

End

# ------------------------------------------------------------------------------ FQ66894
#**
#* Mise à jour des indicateurs de génération des flux pour les biens comptables
#* à partir des informations de la transaction Contextes
#*
#* @param PCNX : Contexte concerné
#* @param PRET : code retour 0-OK, 1-Erreur
#*!
Subprog UPD_FAS_FLGFLX (PCNX, PRET)
Value Integer  PCNX
Value Integer  PRET

Local Shortint N_I, N_PLN
Local Shortint STATUT     : # Statut à mettre à jour sur les biens pour le contexte

 N_I = find(GVML_TECOURA,[M:CNX2]STAFIY)

 If !N_I : PRET=1 : End : Endif

 PRET=0

 STATUT     = GVML_FLXNO

 Case GREP
   When "C", "D"
     If func SUBCNX2.CNXFLX("[M:CNX1]")
       STATUT  = GVML_FLXNOTG
     Endif
   When "M"
     If func SUBCNX2.CNXFLX("[M:CNX1]")
       STATUT  = GVML_FLXNOTG
     Else
       STATUT  = GVML_FLXNO
     Endif
   When "A"
     If func SUBCNX2.CNXFLX("[M:CNX1]")
       STATUT  = GVML_FLXNO
     Endif
 Endcase

 Call ADD_UPD_WAI_CNX([M:CNX0]CPY, [M:CNX0]CNX, "CNX", "FLUX", num$(STATUT), "", PRET) From UPDWAICNX
End

# ------------------------------------------------------------------------------ FQ66894
#**
#* Cette fonction permet de savoir si la classe passée en paramètre correspondant à un contexte
#* gère ou non des flux pour au moins un de ses plans.
#*
#* Retourne 0 si le contexte ne gère pas les flux, 1 si le contexte gère les flux
#*
#* @param PCLAS1 : classe de la forme "[M:CNX1]" ou "[F:CNX]"
#*!
Funprog CNXFLX(PCLAS1)
Value Char PCLAS1
Local Shortint RVAL, N_PLN
  RVAL=0
  For N_PLN = 0 To evalue(PCLAS1+"NBPLC-1")
    If evalue(PCLAS1+"FLUTRATXS(N_PLN)<>''") or evalue(PCLAS1+"FLUTRAACC(N_PLN)=G_OUI")
      RVAL=1
    Endif
  Next
End RVAL

#=====================================================================
# Mise à jour des indicateurs de recalcul du plan de provision pour
# renouvellement sur les biens comptables
#=====================================================================
Subprog UPD_FAS_FLGRPRCLC (PCNX)
# ------------------------------
Value Integer PCNX
Local Integer LRET

Local Integer N_I

N_I = find(GVML_TECOURA,[M:CNX2]STAFIY)

If !N_I : LRET=1 : End : Endif

LRET=0

 Update [FAS] Where CPY=[M:CNX0]CPY and (ISSDAT>=[M:CNX2]DATSTRFIY(N_I-1) or ISSDAT=[0/0/0])
&                    With   FLGRPRCLC            = G_OUI
     If fstat
       LRET=1
     Endif

End
#=====================================================================
Subprog COLOR_EXERCICE(PLIGNE)
# -----------------------------
Value Integer PLIGNE

   #*FQ82871
   #* - on garde les pcolor pour l'appli. C/S
   #* - on ajoute un chgstl pour Convergence
  If [M:CNX2]STAFIY(PLIGNE-1) = GVML_TECOURA
    Chgstl NBFIY(PLIGNE-1)  With "AWARNLOW"
    pcolor = GCOUL(3) : # Bleu
  Else
     Chgstl NBFIY(PLIGNE-1)  With ""
    pcolor = GCOUL(0) : # Normal
    Affzo  [M:CNX2]NBFIY
  Endif

End
#=====================================================================
Subprog COLOR_PERIODE(PLIGNE)
# ---------------------------

Value Integer PLIGNE

   #*FQ82871
   #* - on garde les pcolor pour l'appli. C/S
   #* - on ajoute un chgstl pour Convergence
  If [M:CNX2]STAPER(PLIGNE-1) = GVML_SPCOURA
    Chgstl NBPER2(PLIGNE-1)  With "AWARNLOW"
    pcolor = GCOUL(3) : # Bleu
  Else
    Chgstl NBPER2(PLIGNE-1)  With ""
    pcolor = GCOUL(0) : # Normal
    Affzo  [M:CNX2]NBPER2
  Endif

End

#=====================================================================
#----------------------------------------------------------------------------------------
# Filtre des plans utilisables pour les concessions
#----------------------------------------------------------------------------------------
$FILTRE_PLAN_CCN
 Local Integer I_PLN

 For I_PLN=1 To G301MAX

  # FQ106989
#  If I_PLN=G301IAS | I_PLN=G301SUB | !find(I_PLN,[M:CNX1]PLNCAA)
#   GMENLOC(I_PLN)=1
#  Endif
  If I_PLN=G301IAS | !find(I_PLN,[M:CNX1]PLNCAA)
   GMENLOC(I_PLN)=1
  Endif

  If dim(LCCNPLN)>0

   # FQ106989
   If ( LCCNPLN <> "GRT" and I_PLN=G301SUB )
     GMENLOC(I_PLN)=1
   Endif

   Case LCCNPLN
    When "IND"
     # Le plan ne doit pas avoir été utilisé pour la caducité
     If [M:CNX1]CCNCADPLN<>0 & [M:CNX1]CCNCADPLN=I_PLN
      GMENLOC(I_PLN)=1
     Endif
     # Le plan ne doit pas avoir comme origine base d'amortissement : "Saisie"
     Local Integer IDX_PLN : IDX_PLN=find(I_PLN,[M:CNX1]PLNCAA)
     If IDX_PLN
      If [M:CNX1]ORIBASDPR(IDX_PLN-1)=GVML_OBSAI
       GMENLOC(I_PLN)=1
      Endif
     Endif
     # Si la gestion des subventions est active, le plan ne doit pas avoir été utilisé pour le plan de subvention
     If [M:CNX1]CCNGRTFLG=G_OUI
      If [M:CNX1]CCNGRTPLN<>0 & [M:CNX1]CCNGRTPLN=I_PLN
       GMENLOC(I_PLN)=1
      Endif
     Endif
    When "GRT"
     # Le plan doit avoir comme origine base d'amortissement : "Saisie"
     If [M:CNX1]CCNGRTFLG=G_OUI
      Local Integer IDX_PLN : IDX_PLN=find(I_PLN,[M:CNX1]PLNCAA)
      If IDX_PLN
 #     FQ106989 If [M:CNX1]ORIBASDPR(IDX_PLN-1)<>GVML_OBSAI
       If [M:CNX1]ORIBASDPR(IDX_PLN-1)<>GVML_OBSAI and [M:CNX1]ORIBASDPR(IDX_PLN-1)<>GVML_OBSUB
        GMENLOC(I_PLN)=1
       Endif
      Endif
     Endif
    When "CAD"
     #FQ-54343 Le plan de caducité ne peut pas être le plan fiscal
     GMENLOC(G301FIS)=1
     # Le plan ne doit pas avoir été utilisé pour le plan industriel
     If [M:CNX1]CCNINDPLN<>0 & [M:CNX1]CCNINDPLN=I_PLN
      GMENLOC(I_PLN)=1
     Endif
     # Le plan ne doit pas avoir comme origine base d'amortissement : "Saisie"
     Local Integer IDX_PLN : IDX_PLN=find(I_PLN,[M:CNX1]PLNCAA)
     If IDX_PLN
      If [M:CNX1]ORIBASDPR(IDX_PLN-1)=GVML_OBSAI
       GMENLOC(I_PLN)=1
      Endif
     Endif
     # Si la gestion des subventions est active, le plan ne doit pas avoir été utilisé pour le plan de subvention
     If [M:CNX1]CCNGRTFLG=G_OUI
      If [M:CNX1]CCNGRTPLN<>0 & [M:CNX1]CCNGRTPLN=I_PLN
       GMENLOC(I_PLN)=1
      Endif
     Endif
   Endcase
  Endif
 Next I

Return

#----------------------------------------------------------------------------------------
# Vérifications effectuées à la création ou à la modification du contexte
#----------------------------------------------------------------------------------------
$VERIF_CCN
  If [M:CNX1]CCNINDPLN=[M:CNX1]CCNCADPLN
   GERR     = 2
   GMESSAGE = mess(248,GML_MSGFASPR,1) # "Le plan industriel et le plan de subvention doivent être différents"
   GOK      = 0
  Endif

  If [M:CNX1]CCNGRTFLG=G_OUI & ([M:CNX1]CCNGRTPLN=[M:CNX1]CCNINDPLN | [M:CNX1]CCNGRTPLN=[M:CNX1]CCNCADPLN)
   GERR     = 2
   GMESSAGE = mess(249,GML_MSGFASPR,1) # "Le plan de subvention (concessions) doit être différent du plan industriel et du plan de caducité"
   GOK      = 0
  Endif
Return

#========================================================================
$CHARGE_ENVIRONNEMENT

  If [M:CNX0]CNX = G300CPFI   # on recharge si on a touché au contexte Comptable & Fiscal
    Raz GCOUSOC
    Call ACTION_CPY([M:CNX0]CPY) From GLOFCYCPY
  Endif

  If find (G301IAS, [M:CNX1]PLNCAA(0..[M:CNX1]NBPLC-1)) > 0  # on recharge si on a touché au contexte contenant le plan IAS
    Raz GCOUSOC
    Call ACTION_CPY([M:CNX0]CPY) From GLOFCYCPY
  Endif

Return
#--#*FQ-64247 déplacé depuis le SUBCNX -----------------------------------------------------------------------------
$GERE_SUIVI_FLUX
Local Integer LNCNX, N_E, LERROR

  For N_E = 1 To [M:CNX1]NBPLC
   If ACTION = "ANNULE"
      Call DESINIT_CONTEXTE ([M:CNX0]CPY, GML_TFPLIASS, [M:CNX1]PLNCAA(N_E-1), [M:CNX1]FLUTRATSV(N_E-1), LERROR) From TRTFLUX
      If LERROR < 0
        Call GERE_MSG_ERREUR_FLUX(LERROR, GMESSAGE) From TRTFLUX
        GOK = 0
        Break
      Endif
      Call DESINIT_CONTEXTE ([M:CNX0]CPY, GML_TFCOMPTE, [M:CNX1]PLNCAA(N_E-1), "", LERROR) From TRTFLUX
      If LERROR < 0
        # Y a une erreur, on arrête
        Call GERE_MSG_ERREUR_FLUX(LERROR, GMESSAGE) From TRTFLUX
        GOK = 0
        Break
      Endif
   Else
    If [M:CNX1]FLUTRATXS(N_E-1) = "" and [M:CNX1]FLUTRATSV(N_E-1) <> ""
      # Là on ne gère plus, faudrait purger
      Call DESINIT_EXERCICE ([M:CNX0]CPY, GML_TFPLIASS, [M:CNX1]PLNCAA(N_E-1), [M:CNX1]FLUTRATSV(N_E-1), LERROR) From TRTFLUX
      If LERROR < 0
        Call GERE_MSG_ERREUR_FLUX(LERROR, GMESSAGE) From TRTFLUX
        GOK = 0
        Break
      Endif
    Endif

    If [M:CNX1]FLUTRAACC(N_E-1) <> G_OUI and [M:CNX1]FLUTRAASV(N_E-1) = G_OUI
      # Là on ne gère plus, faudrait purger
      Call DESINIT_EXERCICE ([M:CNX0]CPY, GML_TFCOMPTE, [M:CNX1]PLNCAA(N_E-1), "", LERROR) From TRTFLUX
      If LERROR < 0
        # Y a une erreur, on arrête
        Call GERE_MSG_ERREUR_FLUX(LERROR, GMESSAGE) From TRTFLUX
        GOK = 0
        Break
      Endif
    Endif
   Endif
   # ----------------------------------
   # Suite de la boucle
  Next N_E

Return

#**
#* Contrôle s'il existe des lignes vides en début de masque CNX3
#*!
Subprog CONTROLE_LIGNE_VIDE()
 Local Integer I_PER
 If [M:CNX3]DATENDPER(0)=[0/0/0] & [M:CNX3]NBPERC<>0
   For I_PER=0 To [M:CNX3]NBPERC-1
   If [M:CNX3]DATENDPER(I_PER)<>[0/0/0]
    Break
   Endif
  Next I_PER
  Dela 0, I_PER [M:CNX3]NBPERC
 Endif
End
#-------------------------------------------------------------------------------
$GERE_ACTIVATION_NORME

Local Integer LNCNX, N_E, LERROR
  For N_E = 1 To [M:CNX1]NBPLC
   If ([M:CNX1]PLNSTD(N_E-1)=GVML_NPIAS | [M:CNX1]PLNSTD(N_E-1)=GVML_NPCRC)
&    &([M:CNX1]PLNSTDSV(N_E-1)=GVML_NPSTD)
    LERROR=func SUBCNX2.ACTIVATION_NORME([M:CNX0]CPY, [M:CNX0]CNX, [M:CNX1]PLNCAA(N_E-1))
    If LERROR
     GOK=0
    Endif
   Endif
  Next N_E

Return
#-------------------------------------------------------------------------------
$AFFICHE_EXO_PER
Local Integer N_I, N_DEBUT

  LAST_CPY         = [M:CNX0]CPY
  LAST_CUR         = [M:CNX1]CUR
  LAST_CURTYP      = [M:CNX1]CURTYP
  N_DEBUT          = 1

  # Lecture des exercices
  EXE_COUR = 0
  nolign           = 1
  For [FIS]FIY0 Where CPY=[M:CNX0]CPY and CNX=[M:CNX0]CNX
      [M:CNX2]DATSTRFIY(nolign-1)  = [F:FIS]DATSTRFIY
      [M:CNX2]DATENDFIY(nolign-1)  = [F:FIS]DATENDFIY
      [M:CNX2]RAT39BIS(nolign-1)   = [F:FIS]RAT39BIS
      [M:CNX2]STAFIY(nolign-1)     = [F:FIS]STAFIY
      [M:CNX2]INDCURPER(nolign-1)  = [F:FIS]INDCURPER
      [M:CNX2]NBRPER(nolign-1)     = [F:FIS]NBRPER
      [M:CNX2]EVTCREFLG(nolign-1)  = [F:FIS]EVTCREFLG
      [M:CNX2]DFDCOD(nolign-1)     = [F:FIS]DFDCOD
      [M:CNX2]DFDRAT(nolign-1)     = [F:FIS]DFDRAT
      [M:CNX2]DFDTYP(nolign-1)     = [F:FIS]DFDTYP
      If [M:CNX2]STAFIY(nolign-1) = GVML_TECOURA
        EXE_COUR = nolign
        # Période courante/exercice courant
        GCURSTRPER = [F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
      Endif
      # ------------------------------
      If [F:FIS]STAFIY = GVML_TECOURA
        [M:CNX3]YEACLICK = nolign
      Endif

      # FQ67615
      [M:CNX2]LVATYP(nolign-1)   = [F:FIS]LVATYP
      [M:CNX2]LVALIM(nolign-1)  = [F:FIS]LVALIM

      # ------------------------------
      # Chargement des périodes si besoin
      If [F:FIS]NBRPER > 0
        For N_I = 0 To [F:FIS]NBRPER-1
          [M:CNX3]INDFISYEA(N_DEBUT-1)  = nolign
          [M:CNX3]DATSTRPER(N_DEBUT-1)  = [F:FIS]DATSTRPER(N_I)
          [M:CNX3]DATENDPER(N_DEBUT-1)  = [F:FIS]DATENDPER(N_I)
          [M:CNX3]DATENDPERS(N_DEBUT-1) = [F:FIS]DATENDPER(N_I)
          [M:CNX3]NBRMONPER(N_DEBUT-1)  = [F:FIS]NBRMONPER(N_I)
          [M:CNX3]NBRWEKPER(N_DEBUT-1)  = [F:FIS]NBRWEKPER(N_I)
          [M:CNX3]NBRDAYPER(N_DEBUT-1)  = [F:FIS]NBRDAYPER(N_I)
          [M:CNX3]STAPER(N_DEBUT-1)     = [F:FIS]STAPER(N_I)
          [M:CNX3]TYPPST(N_DEBUT-1)     = [F:FIS]TYPPST(N_I)
          [M:CNX3]TYPPSTS(N_DEBUT-1)    = [F:FIS]TYPPST(N_I) #Fq67417
          [M:CNX3]LSTTYPPRO(N_DEBUT-1)  = [F:FIS]LSTTYPPRO(N_I)
          #---------------
          N_DEBUT += 1
          # Suite de la boucle
        Next N_I
      Endif
      nolign += 1
    # ------------------------------
    # Suite de la boucle
  Next FIY0
  # ------------------------------
  [M:CNX2]NBFIY  = nolign-1
  [M:CNX3]NBPERC = N_DEBUT-1

 Call AFFICHE_PERIODE() From SUBCNX

Return
#-------------------------------------------------------------------------------
$DECLENCHE_ASSOCIATION
Local Integer PLAN, LALW, LFLGRAT, RERROR, LERROR
Local Char    LDPM, LVEH, FAM, ACCCOD
Local Decimal LDUR
Local Decimal LRAT
Local Decimal LRAT2
Local Integer LTYPD
Local Integer LPRA
Local Decimal LACL
Local Char    LPROPLN
Local Integer LFLGBCO

  PLAN       =  [F:DEPZ]DPRPLN
  ACCCOD     =  [F:FAS]ACCCOD
  FAM        =  [F:FAS]ACGGRP
  LPROPLN    =  [F:FAS]PROPLN
  LFLGBCO    =  G_OUI

  RERROR = 0
  LERROR = 0
  Call DETER_VAL_NEW_PLAN(FAM, ACCCOD, PLAN, LDPM, LDUR, LRAT, LRAT2, LALW, LVEH, RERROR) From TRTASSO
  If RERROR = 0
    If LRAT > 0
      LFLGRAT=G_OUI
    Else
      LFLGRAT=G_NON
    Endif
    [M:METH]           = [F:FAS]
    [M:METH]           = [F:DEPZ]
    [M:METH]FLGBCO     = G_OUI
    [M:METH]DPRRATFLG  = LFLGRAT
     # Controle de la méthode pour chaque plan d'amortissement
     Call CONTROLE_METHODE () From TRTFAS
     If ( [M:METH]MSGERR)
      Return
    Endif

    If LDPM <> ""
     [F:DEPZ]DPM = LDPM
    Endif
    If LDUR > 0
     [F:DEPZ]DPRDUR = LDUR
    Endif
    If LRAT > 0
     [F:DEPZ]DPRRAT = LRAT
    Endif

    If LRAT2 > 0
     [F:DEPZ]DPRRAT2 = LRAT2
    Endif

    If LALW > 0
      [F:DEPZ]ALWCOD = LALW
    Endif
    If LVEH <> ""
      [F:DEPZ]CRBVEHCOD = LVEH
    Endif
  Endif

Return
#-------------------------------------------------------------------------------
$MENAGE_ASSOCIATION
# Destruction du/des plan(s) supprimé(s) dans les associations
# la liste des plan est dans TBPLNDEL de (0..N_NBPLNDEL)

Local Integer I

  # ------------------
  If clalev([F:RVP])  = 0 : Local File RUBASSVALP    [RVP]  : Endif : # Association-valeurs
  If clalev([F:RDP])  = 0 : Local File RUBASSDEFP    [RDP]  : Endif : # Association-définitions
  # ------------------
  For I = 0 To N_NBPLNDEL
    Delete [RVP] Where CPY=[M:CNX0]CPY & DPRPLN = TBPLNDEL(I)
    If fstat <> 0
      GOK = 0
      Call RSTA("RVP",CLECUR1-CLECUR2-num$(CLECUR2(1))) From GLOCK
      Break
    Endif
    # ------------------
    Delete [RDP] Where CPY=[M:CNX0]CPY & DPRPLN = TBPLNDEL(I)
    If fstat <> 0
      GOK = 0
      Call RSTA("RDP",CLECUR1-CLECUR2-num$(CLECUR2(1))) From GLOCK
      Break
    Endif
  Next I
  If GOK = 0
    Return
  Endif
Return
#--------------------------------------------------------
##Fq-79487 : transféré depuis le SUBCNX2  ################
#######################################
Subprog REPORTE_PERIODES_CNX3()
Local Integer N_I

  If (nolign < [M:CNX2]NBPER2)
    If [M]DATSTRPER(nolign) <> [M]DATENDPER(nolign-1)+1
      If [M]DATENDPER(nolign) < [M]DATENDPER(nolign-1)+1
        # Si la fin de la période suivante est avant son nouveau début on détruit les lignes
        # jusqu'à trouver un période où ça n'est pas le cas !
        N_I = nolign
        While N_I <= [M:CNX2]NBPER2
          If [M]DATENDPER(N_I) = [0/0/0]
            Call ACTION_BLOCK (ACB_AFFZO, "CNX2", "NBPER2") From GLOBIENS
            Break
          Endif
          If [M]DATENDPER(N_I) < [M]DATENDPER(N_I-1)+1
            # On vire la ligne de la liste globale
            [M:CNX3]INDFISYEA([M:CNX2]INDCNX3(N_I)-1) = 9999
            Dela N_I, 1  [M:CNX2]NBPER2
            [M:CNX2]NBPER2 -= 1
          Else
            [M]DATSTRPER(N_I) = [M]DATENDPER(N_I-1)+1
            Affzo [M]DATSTRPER(N_I)
            Call SEND_PERIODE_EN_GLOBAL (N_I+1) From SUBCNX2
            Call ACTION_BLOCK (ACB_AFFZO, "CNX2", "NBPER2") From GLOBIENS
            nolign = N_I+1
            Call AM_DATENDPER([M]DATENDPER(N_I)) From SUBCNX
            Break
          Endif
          # ----------------------
          # Suite de la boucle
        Wend
      Else
        [M]DATSTRPER(nolign) = [M]DATENDPER(nolign-1)+1
        Affzo [M]DATSTRPER(nolign)
        nolign += 1
        Call AM_DATENDPER([M]DATENDPER(nolign-1))  From SUBCNX
        nolign -= 1
      Endif
    Endif
  Endif
  Call VAL_DEFAUT_PER3 ()              From SUBCNX2
  Call SEND_PERIODE_EN_GLOBAL (nolign) From SUBCNX2
End
######################################################################################
## 70465- Alimentation auto des exercices/périodes
######################################################################################
#-------------------------------------------------------------------------------
#**
#*  Alimentation auto des exercices/périodes
#*!
$CRE_EXE_PER

Local Integer NBPER       : NBPER    = 1
Local Integer NBPERFAY
Local Decimal NB_YEAR
Local Integer NB_MONTH
Local Integer NB_WEEK
Local Integer NB_DAY
Local Integer EXE_COUR, PER_COUR
  If !clalev([F:PER]) : Local File PERIOD     [PER] : Endif
  If !clalev([F:FAY]) : Local File FISCALYEAR [FAY] : Endif

  If ( [M:CNX1]PLNMOD <> 0 )  & ( [M:CNX1]PLNMODFLG = G_OUI )
    GERR=1   :  GMESSAGE = mess(242,GML_MSGFASPR,1)-num$(mess([M:CNX1]PLNMOD,3101,1) )
     mkstat=2 :  Return
  Endif

  Raz [M:CNX2], [M:CNX3]

  # Lecture des exercices
  EXE_COUR = 0
  nolign   = 1
  #Fq-73079
  Filter [FAY] Where FIYSTA = 2
  Look [FAY]FIY0(2)=[M:CNX0]CPY;[M:CNX1]LEDTYP(0)
  Filter [FAY]
  If fstat
    GERR=1   :  GMESSAGE = mess(273,GML_MSGFASPR,1)
    mkstat=2 :  Disable GSTACRE
    Diszo[M:CNX1]
    Diszo[M:CNX2]
    GBOUT1=""  : GBOUT2="" : GBOUT3=""  : GBOUT4="" :GBOUT5=""  : GBOUT6=""
   Return
  Endif #Fq-73079

  For [FAY]FIY0 Where CPY=[M:CNX0]CPY and LEDTYP=[M:CNX1]LEDTYP(0) and FIYSTA < 3
     [M:CNX2]DATSTRFIY(nolign-1)  = [F:FAY]FIYSTR
     [M:CNX2]DATENDFIY(nolign-1)  = [F:FAY]FIYEND
     If EXE_COUR = 0 and [F:FAY]FIYSTA=2
        EXE_COUR = 1
        [M:CNX2]STAFIY(nolign-1)  = GVML_TECOURA
     Else
        EXE_COUR = 9
        [M:CNX2]STAFIY(nolign-1)  = 0
     Endif
     # ------------------------------
     [M:CNX3]YEACLICK = nolign
     NBPERFAY = 0
     # Chargement des périodes si besoin
     PER_COUR=0
     Filter[PER] Where  CPY=[M:CNX0]CPY and LEDTYP=[M:CNX1]LEDTYP(0) and FIYNUM = [F:FAY]FIYNUM and PERSTA = 2
      Read [PER]First
       If fstat and [M:CNX2]STAFIY(nolign-1)  = GVML_TECOURA
           #270-Aucune période ouverte en Compta pour cette Société et ce Référentiel : la création du contexte est impossible.
           GERR=1   :  GMESSAGE = mess(270,GML_MSGFASPR,1)
           mkstat=2 :  Disable GSTACRE :      GBOUT2="" : Return #CHECK IGNORE_LINE
       Endif
     Filter[PER]
     For[PER]PER0 Where  CPY=[M:CNX0]CPY and LEDTYP=[M:CNX1]LEDTYP(0) and FIYNUM = [F:FAY]FIYNUM
        [M:CNX3]INDFISYEA(NBPER-1)     = nolign
        [M:CNX3]DATSTRPER(NBPER-1)     = [F:PER]PERSTR
        [M:CNX3]DATENDPER(NBPER-1)     = [F:PER]PEREND
        [M:CNX3]DATENDPERS(NBPER-1)    = [F:PER]PEREND
        Call CALCUL_NB_D_M_W_Y ([M:CNX3]DATSTRPER(NBPER-1), [M:CNX3]DATENDPER(NBPER-1), NB_DAY, NB_MONTH, NB_WEEK, NB_YEAR) From GLOBIENS
        [M:CNX3]NBRMONPER  (NBPER-1)   = NB_MONTH
        [M:CNX3]NBRWEKPER  (NBPER-1)   = NB_WEEK
        [M:CNX3]NBRDAYPER  (NBPER-1)   = NB_DAY
        Case  [F:PER]PERSTA
           When 2 # ==> période ouverte
              If PER_COUR=0
               PER_COUR=1
              Else
               PER_COUR=9
             Endif
              [M:CNX3]STAPER     (NBPER-1)  = GVML_SPOUVER
              [M:CNX3]TYPPST     (NBPER-1)  = GVML_TPSTPRO
              If [M:CNX2]STAFIY  (nolign-1)= GVML_TECOURA and PER_COUR=1
                [M:CNX3]STAPER     (NBPER-1)  = 2
                [M:CNX2]INDCURPER  (nolign-1)  = NBPER
              Else
                 [M:CNX3]STAPER     (NBPER-1)  = 3
              Endif
           When 1 # ==> période non-ouverte
             [M:CNX3]STAPER     (NBPER-1)  = 1
             [M:CNX3]TYPPST     (NBPER-1)  = 0
           When 3 # ==> période fermée
             [M:CNX3]STAPER     (NBPER-1)  = 4
             [M:CNX3]TYPPST     (NBPER-1)  = 0
        Endcase
       #---------------
        NBPER    += 1
        NBPERFAY += 1
        # Suite de la boucle
     Next
     [M:CNX2]NBRPER(nolign-1) =  NBPERFAY
     nolign += 1
    #  ------------------------------
    # Suite de la boucle
  Next
  # ------------------------------
  GDECAUTO=G_OUI   #*FQ-64247
  [M:CNX2]NBFIY  = nolign-1
  [M:CNX3]NBPERC = NBPER-1
  [M:CNX3]YEACLICK = 1
  Call AFFICHE_PERIODE() From SUBCNX
  #*FQ-93055  Test existence exercice suivant en Compta
  If [M:CNX2]DATENDFIY(1) <> [0/0/0]
     [M:CNX2]STAFIY(1)   = GVML_TESUIV    : # Suivant
  Else
     # "Pas d'exercice suivant en Compta : impossible de créer le contexte."
     GERR=1   :  GMESSAGE = mess(301,GML_MSGFASPR,1)
     mkstat=2 :  Disable GSTACRE :      GBOUT2="" : Return
  Endif
  If [M:CNX2]DATENDFIY(2) <> [0/0/0]
     [M:CNX2]STAFIY(2)   = GVML_TESUIV2   : # Suivant2
  Endif
  #*FQ-93055 Fin test existence exercice suivant en Compta
  #------------------------------
  [M:CNX2]STAFIY(1)   = GVML_TESUIV    : # Suivant
  [M:CNX2]STAFIY(2)   = GVML_TESUIV2   : #

   Affzo [M:CNX2] : Diszo [M:CNX2]
   Actzo  [M:CNX2]TYPPST
    Disable 65 : # status Suppression ligne
    Disable 73 : # status insertion ligne
    GBOUT1=""
    GBOUT2=""
    #Fq-93019 Affzo [M:CNX1] pb adffichage sur infos Concessions
    Disable 65 : # status Suppression ligne
    Disable 73 : # status insertion ligne
    GBOUT1=""
    GBOUT2=""
    GBOUT3=""
    GBOUT4=""
    GBOUT5=""
    GBOUT6=""
    GBOUT7=""
    Affzo [M:CNX2]TYPPST #FQ93002  : Actzo  [M:CNX2]TYPPST   #Fq-73079

Return
#-------------------------------------------------------------------------------
#**70465
#* Compare le découpage exercices/périodes de 2 référentiels d'une société passés en paramètre
#* Si des exercices ou périodes ne sont pas identiques (date début, date fin et statut)
#* le champ RERROR prend la valeur 1
#* @param PCPY    : Société
#* @param PLED1   : Référentiel 1
#* @param PLED2   : Référentiel 2
#* @param RERROR  : Code retour : 1  si incohérence dans les dates
#*!
Subprog COMP_DECOUP_CPTA (PCPY, PLED1, PLED2, RERROR)
Value  Char        PCPY
Value Integer      PLED1
Value Integer      PLED2
Variable Integer   RERROR

 RERROR = 0

If !clalev([F:FAY1]) : Local File FISCALYEAR [FAY1] : Endif
If !clalev([F:PER1]) : Local File PERIOD     [PER1] : Endif
If !clalev([F:FAY2]) : Local File FISCALYEAR [FAY2] : Endif
If !clalev([F:PER2]) : Local File PERIOD     [PER2] : Endif

Filter [FAY1] Where CPY=PCPY and LEDTYP = PLED2 and FIYSTA < 3
  For [FAY1]FIY0
    Read[F:FAY2]FIY0 = PCPY;PLED1;[F:FAY1]FIYNUM
    If fstat =0
      If [F:FAY2]FIYSTR <> [F:FAY1]FIYSTR or
&        [F:FAY2]FIYEND <> [F:FAY1]FIYEND or
&        [F:FAY2]FIYSTA <> [F:FAY1]FIYSTA
        RERROR = 1 : Break
      Endif
    Endif
  Next
Filter [FAY1]

If RERROR = 1 : End : Endif

Filter [PER1] Where CPY=PCPY and LEDTYP=PLED2 and PERSTA < 3
  For [PER1]PER0
    Read[F:PER2]PER0 = PCPY;PLED1;[F:PER1]FIYNUM;[F:PER1]PERNUM
    If fstat =0
      If [F:PER2]PERSTR <> [F:PER1]PERSTR or
&        [F:PER2]PEREND <> [F:PER1]PEREND or
&        [F:PER2]PERSTA <> [F:PER1]PERSTA
        RERROR = 1 : Break
      Endif
    Endif
  Next
Filter [FAY1]

End

# FQ67615
$MODIF

  # Maj ici des infos LVA si le ctx n'est pas modifié par ailleurs (G_MODCNX = G_OUI)
  If G_MODCNX <> G_OUI and GOK = 1 and
&   [M:CNX0]CNX = G300CPFI and ([M:FPC]LEG = "GER" or [M:FPC]LEG = "AUT")

    For nolign = 1 To [M]NBFIY

      Read [FIS]FIY0 = [M:CNX0]CPY ; [M:CNX0]CNX ; [M:CNX2]DATSTRFIY(nolign-1)
      [F:FIS]LVATYP  = [M:CNX2]LVATYP(nolign-1)
      [F:FIS]LVALIM = [M:CNX2]LVALIM(nolign-1)

      Rewrite [FIS]
      If fstat
        GOK = 0
        Break
      Endif
    Next nolign
  Endif
Return

$AFFICH_LVA
  If [M:CNX0]CNX = G300CPFI and ([M:FPC]LEG = "GER" or [M:FPC]LEG = "AUT")
    Actzo [M:CNX2]LVATYP, LVALIM
    Chgfmt [M:CNX2]LVATYP With "+LO:1X"
    Chgfmt [M:CNX2]LVALIM With "+KC:3"
  Else
    Diszo [M:CNX2]LVATYP, LVALIM
    Chgfmt [M:CNX2]LVATYP With "-LO:1X"
    Chgfmt [M:CNX2]LVALIM With "-KC:3"

  Endif
Return

$AM_LVATYP

  # initialisation de la limite LVA (si non renseignée)
#  If VALEUR > GVML_GLVAAUC and [M:CNX2]LVATYP(nolign - 1) <= GVML_GLVAAUC and
#&   and [M:CNX2]LVALIM(nolign - 1) = 0
  If VALEUR > GVML_GLVAAUC and VALEUR <> [M:CNX2]LVATYP(nolign - 1)
    Local Char WCH

    Local Integer LFAS : # X3-104535
    LFAS = func AFNC.ACTIV("FAS")

    WCH = ""
    If VALEUR = GVML_GLVALVA
      If LFAS = G_OUI : # X3-104535
        Call PARAM([M:FPC]LEG, "LVALIM", WCH) From ADOVAL
      Endif : # X3-104535
    Elsif VALEUR = GVML_GLVAPOOL
      If LFAS = G_OUI : # X3-104535
        Call PARAM([M:FPC]LEG, "POOLIM", WCH) From ADOVAL
      Endif : # X3-104535
    Endif
    If WCH = ""
      [M:CNX2]LVALIM(nolign - 1) = 0
    Else
      [M:CNX2]LVALIM(nolign - 1) = val(WCH)
    Endif
    Affzo [M:CNX2]LVALIM
  Elsif VALEUR <= GVML_GLVAAUC
    [M:CNX2]LVALIM(nolign - 1) = 0
    Diszo [M:CNX2]LVALIM
    Affzo [M:CNX2]LVALIM
  Endif
Return

$AS_LVATYP
  Local Integer WNCMPSTA

  If ([M:CNX2]STAFIY(nolign - 1) < GVML_TECOURA and GREP <> "C") or
&    [M:CNX0]CNX <> G300CPFI or
&    ([M:FPC]LEG <> "GER" and [M:FPC]LEG <> "AUT")

    Diszo [M:CNX2]LVATYP(nolign - 1), LVALIM(nolign - 1)
  Else

    If GREP = "C"
      VALEUR = GVML_GLVALVA
      Gosub AM_LVATYP
    Endif
    If [M:FPC]LEG = "AUT"
      GMENLOC(GVML_GLVAPOOL) = 1
    Else
      GMENLOC(GVML_GLVAPOOL) = 0
    Endif

    # recherche si il existe 1 bien de LVATYP ds l'exercice concerné
    If VALEUR = GVML_GLVAPOOL
      WNCMPSTA = GVML_SBPOOL
    Elsif VALEUR = GVML_GLVALVA
      WNCMPSTA = GVML_SBLVA
    Else
      WNCMPSTA = 0
    Endif
    If func GLOBIENS.EXISTEBIENLVA(WNCMPSTA, [M:CNX2]DATSTRFIY(nolign - 1), [M:CNX2]DATENDFIY(nolign - 1), [M:CNX0]CPY)
      Diszo [M:CNX2]LVATYP(nolign - 1)
    Else
      Actzo [M:CNX2]LVATYP(nolign - 1), LVALIM(nolign - 1)
    Endif
  Endif
  Affzo [M:CNX2]LVATYP(nolign - 1), LVALIM(nolign - 1)

Return

#FQ88911
# les changements des périodes sont repris
$REPORT_CHGT_PERIODES

Local Integer I_PLN, I_PLNMSK
Local Integer NBFAS
Local Integer ROK
Local Integer NBBCO #Fq-81074

  GOK=1

  If !clalev([F:FAS])  : Local File FXDASSETS  [FAS]   : Endif : # Biens comptables
  If !clalev([F:WDEP]) : Local File DEPREC     [WDEP]  : Endif : # Plans d'amortissements
  If !clalev([F:WFLU]) : Local File FXDLIFL    [WFLU]  : Endif : # flux
  If !clalev([F:WLCD]) : Local File LNKCPTABD  [WLCD]  : Endif : # Lien compta/immo détail

  #Fq-81074
   If EXISTBCO
     Filter [FAS] Where CPY=[M:CNX0]CPY
        NBBCO = rowcount([F:FAS])
     Filter [FAS]
   Endif
   #Fq-81074


  Call OUVRE_BOITE(mess(201,GML_MSGFASPR,1),NBBCO) From GESECRAN    #"Mise à jour des biens"
  Call SET_BOITE  (mess(201,GML_MSGFASPR,1),NBBCO) From GESECRAN    #"Mise à jour des biens"

    #> Mise à jour des DEPREC FLU RPR et PROPLN
    For [FAS]FAS1 Where CPY=[M:CNX0]CPY
      # FQ-56630 ajout test s/date sortie du bien
      If  ([F:FAS]ISSDAT = [0/0/0] or [F:FAS]ISSDAT >= GTO_DEBEXE(GVML_TECOURA) or [F:FAS]FLGUPDISS <> G_OUI)

        Gosub MAJ_PER_DEPREC
        If GOK = 0
          Break
        Endif
      Endif
    Next
    Call FERME_BOITE From GESECRAN

Return


# les périodes sont redécoupées : maj de DEPREC and FXDLIFL et CCNRPR
# Boucle sur les plans d'un bien
$MAJ_PER_DEPREC

  NBFAS+=1
  If mod(NBFAS, 10) = 0
    Call AFF_BOITE  ([F:FAS]AASREF, NBFAS, ROK) From GESECRAN
  Endif

  For I_PLNMSK = 1 To [M:CNX1]NBPLC

    I_PLN = [M:CNX1]PLNCAA(I_PLNMSK - 1) # n° du plan M 3101
    If [M:CNX1]PLNMGT(I_PLNMSK - 1) = G_OUI

#      Call AFF_BOITE  ([F:FAS]AASREF - "/" - mess(I_PLN, 3101, 1), NBFAS, ROK) From GESECRAN


      # 1° Suppression des DEPREC des périodes modifiées et futures
      # si on est dans exercice suivant + 1 alors, on supprime tout cet exercice et >
      # Si la 1° période modifiée est la courante :
      # on ne la supprime pas.
      # -> indexe DEPA

      # Si la première modif est >= au début d'exercice statut suivant + 1
      # on détruit tout à partir de cet exercice
      If  GTO_DEBEXE(GVML_TESUIV2) <> [0/0/0] and WFDSC_PER >= GTO_DEBEXE(GVML_TESUIV2)
        Delete [WDEP] Where (AASREF    =  [F:FAS]AASREF and
&                            DPRPLN    =  I_PLN and
&                            PERSTRDAT >=  GTO_DEBEXE(GVML_TESUIV2) )
      Elsif WFDEC_PER = WODE_PER_COU
        Delete [WDEP] Where (AASREF    =  [F:FAS]AASREF and
&                            DPRPLN    =  I_PLN and
&                            PERSTRDAT >  WFDSC_PER )
      Else
        Delete [WDEP] Where (AASREF    =  [F:FAS]AASREF and
&                            DPRPLN    =  I_PLN and
&                            PERSTRDAT >= WFDSC_PER )
      Endif
      If fstat
        GOK=0
        Break
      Endif


      # 2° Maj des DEPREC clos si on a changé la date de fin d'exercice
      # -> indexe DEP0

      If G_CMENDFIY
        Update [WDEP] Where AASREF    = [F:FAS]AASREF and
&                           DPRPLN    = I_PLN and
&                           FIYENDDAT = GTO_FINEXE(GVML_TECOURA) and
&                           PERENDDAT < GTO_FINPERCUR
&                     With FIYENDDAT = N_COUENDFIY
        If fstat
          GOK=0
          Break
        Endif
      Endif


      # 3° Maj des LNKCPTABD si on a changé la date de fin d'exercice
      # -> indexe LCA2

      # Les pièces comptabilisées peuvent donc avoir leur date de fin d'exe maj
      # Les autres n'auront pas les périodes maj : elles seront regénérées
      # à la prochaine interface

      If G_CMENDFIY
        Update [WLCD] Where REF    = [F:FAS]AASREF and
&                           DPRPLN    = I_PLN and
&                           FIYENDDAT = GTO_FINEXE(GVML_TECOURA)
&                     With FIYENDDAT = N_COUENDFIY
        If fstat
          GOK=0
          Break
        Endif
      Endif

      # 4° Maj de la période courante (si elle a changé)

      If WFDEC_PER = WODE_PER_COU
        If G_CMENDFIY
          Update [WDEP] Where AASREF    =  [F:FAS]AASREF and
&                           DPRPLN    =  I_PLN and
&                           FIYENDDAT =  GTO_FINEXE(GVML_TECOURA) and
&                           PERENDDAT = WODE_PER_COU
&                     With PERENDDAT = WNDE_PER_COU,
&                          FIYENDDAT = N_COUENDFIY,
&                          DEPSTA = GVML_SCNOCAL
        Else
          Update [WDEP] Where AASREF    =  [F:FAS]AASREF and
&                           DPRPLN    =  I_PLN and
&                           FIYENDDAT =  GTO_FINEXE(GVML_TECOURA) and
&                           PERENDDAT = WODE_PER_COU
&                     With PERENDDAT = WNDE_PER_COU,
&                          DEPSTA = GVML_SCNOCAL
        Endif
      Elsif  G_CMENDFIY
          Update [WDEP] Where AASREF    =  [F:FAS]AASREF and
&                           DPRPLN    =  I_PLN and
&                           FIYENDDAT =  GTO_FINEXE(GVML_TECOURA) and
&                           PERENDDAT = WODE_PER_COU
&                     With FIYENDDAT = N_COUENDFIY,
&                          DEPSTA = GVML_SCNOCAL

      Endif


      # 5° Maj des DEPREC de l'exercice courant : periodes > celle de statut courant
      # -> indexe DEP0

      If G_CMENDFIY
        Update [WDEP] Where AASREF    =  [F:FAS]AASREF and
&                           DPRPLN    =  I_PLN and
&                           FIYENDDAT =  GTO_FINEXE(GVML_TECOURA) and
&                           PERENDDAT > GTO_FINPERCUR
&                     With FIYENDDAT = N_COUENDFIY,
&                          DEPSTA = GVML_SCNOCAL
      Else
        Update [WDEP] Where AASREF    =  [F:FAS]AASREF and
&                           DPRPLN    =  I_PLN and
&                           FIYENDDAT =  GTO_FINEXE(GVML_TECOURA) and
&                           PERENDDAT > GTO_FINPERCUR
&                     With DEPSTA = GVML_SCNOCAL
      Endif
      If fstat
        GOK=0
        Break
      Endif


      # 6° Maj des DEPREC de l'exercice suivant si la 1° période modifiée
      # est dans cet exercice (et que c'est la 2° parceque si c'est la première,
      # on a supprimé tous les DEPREC de cet exercice
      # -> indexe DEP0

      If WFDSC_PER > GTO_DEBEXE(GVML_TESUIV) and
&        WFDSC_PER < GTO_FINEXE(GVML_TESUIV)

        If G_SMENDFIY
          Update [WDEP] Where AASREF    =  [F:FAS]AASREF and
&                             DPRPLN    =  I_PLN and
&                             FIYENDDAT =  GTO_FINEXE(GVML_TESUIV)
&                       With FIYENDDAT = N_SUIENDFIY,
&                            DEPSTA = GVML_SCNOCAL
        Else
          Update [WDEP] Where AASREF    =  [F:FAS]AASREF and
&                             DPRPLN    =  I_PLN and
&                             FIYENDDAT =  GTO_FINEXE(GVML_TESUIV)
&                       With DEPSTA = GVML_SCNOCAL
        Endif
        If fstat
          GOK=0
          Break
        Endif
      Endif


      # 7° Maj des LNKCPTABD si on a changé la date de fin d'exercice suivant
      # -> indexe LCA2

      If G_SMENDFIY
        Update [WLCD] Where  REF    = [F:FAS]AASREF and
&                           DPRPLN    = I_PLN and
&                           FIYENDDAT = GTO_FINEXE(GVML_TESUIV)
&                     With FIYENDDAT = N_SUIENDFIY
        If fstat
          GOK=0
          Break
        Endif
      Endif
      # x° Pas de Maj des DEPREC de l'exercice suivant + 1 et autres : tous supprimés


      # 8° flux
      If G_CMENDFIY or G_CMPER or G_NEWPOIDS  or G_SMENDFIY or G_SMPER or G_CFUTUR

        #> Suppression des FLUX provisoires
        Delete [WFLU] Where AASREF    =  [F:FAS]AASREF and
&                           DPRPLN    =  I_PLN and
&                           FLGSTATXS =  GVML_TXSPRO
        If fstat
          GOK=0
          Break
        Endif

        If N_COUENDFIY <> [0/0/0]

          # Traitement des flux période
          # FQ66894 : On ne traite que les périodes closes
          # car les flux provisoires périodes et exercices sont supprimés plus bas

          Update [WFLU] Where
&                  AASREF    = [F:FAS]AASREF and
&                  DPRPLN    = I_PLN and
&                  FIYENDDAT = GTO_FINEXE(GVML_TECOURA) and
&                  FLGSTATXS = GVML_TXSDEF
&         With FIYENDDAT = N_COUENDFIY
          If fstat
            GOK=0
            Break
          Endif
        Endif
      Endif
    Endif

  Next I_PLN
  If GOK = 0
    Return
  Endif

  If G_ACTCCN = G_OUI #Fq-70181
    #--------------------------------------------------
    #> Suppression des périodes futures du Plan de provisions  en fonction de WFDSC_PER
    # (On ne supprime pas la per courante)

    If WFDSC_PER < WODE_PER_COU

      # Suppression des suivantes
      Delete [RPR] Where (AASREF    =  [F:FAS]AASREF and
&                       PERSTRDAT >  WFDSC_PER )

      If G_CMENDFIY
        # Maj des per < courante
        Update [RPR] Where AASREF    =  [F:FAS]AASREF and
&                         FIYENDDAT = GTO_FINEXE(GVML_TECOURA) and
&                         PERENDDAT <  WODE_PER_COU
&                   With FIYENDDAT = N_COUENDFIY

        # Maj de la per courante
        Update [RPR] Where AASREF    =  [F:FAS]AASREF and
&                         FIYENDDAT = GTO_FINEXE(GVML_TECOURA) and
&                         PERENDDAT =  WODE_PER_COU
&                   With PERENDDAT =  WNDE_PER_COU,
&                        FIYENDDAT = N_COUENDFIY
      Else

        # Maj de la per courante
        Update [RPR] Where AASREF    =  [F:FAS]AASREF and
&                         FIYENDDAT = GTO_FINEXE(GVML_TECOURA) and
&                         PERENDDAT =  WODE_PER_COU
&                   With PERENDDAT =  WNDE_PER_COU
      Endif

    Elsif  GTO_DEBEXE(GVML_TESUIV2) <> [0/0/0] and WFDSC_PER >= GTO_DEBEXE(GVML_TESUIV2)
        Delete [RPR] Where (AASREF    =  [F:FAS]AASREF and
&                           FIYENDDAT >=  GTO_FINEXE(GVML_TESUIV2) )

    Else
      #

      Delete [RPR] Where (AASREF    =  [F:FAS]AASREF and
&                       PERSTRDAT >=  WFDSC_PER )

      # Maj des per <= courante
      If G_CMENDFIY

        Update [RPR] Where AASREF    =  [F:FAS]AASREF and
&                         FIYENDDAT = GTO_FINEXE(GVML_TECOURA) and
&                         PERENDDAT <  WFDSC_PER
&                   With FIYENDDAT = N_COUENDFIY

      Elsif G_SMENDFIY and WFDSC_PER > GTO_DEBEXE(GVML_TESUIV)
        Update [RPR] Where AASREF    =  [F:FAS]AASREF and
&                         FIYENDDAT = GTO_FINEXE(GVML_TESUIV) and
&                         PERENDDAT <  WFDSC_PER
&                   With FIYENDDAT = N_SUIENDFIY

      Elsif G_S2MENDFIY and WFDSC_PER > GTO_DEBEXE(GVML_TESUIV2)
        Read [FIS]FIY1 = [M:CNX0]CPY; [M:CNX0]CNX; GVML_TESUIV2 With Stability

        Update [RPR] Where AASREF    =  [F:FAS]AASREF and
&                         FIYENDDAT = GTO_FINEXE(GVML_TESUIV2) and
&                         PERENDDAT <  WFDSC_PER
&                   With FIYENDDAT = [F:FIS]DATENDFIY
      Endif
    Endif
    If fstat
      GOK = 0
      Return
    Endif
    [F:FAS]FLGRPRCLC = G_OUI
  Endif

Return


#-------------------------------------------------------------------------------
$MAJ_PLANPROD


  If clalev([F:PPH])  = 0 : Local File PROPLNH    [PPH]  : Endif : # Plan de production #FQ-70141
  If clalev([F:PPL])  = 0 : Local File PROPLN     [PPL]  : Endif                        #FQ-70141

  Local Decimal WPLNQTY, WRSDQTY
  Local Decimal WFIY_CUR_EXE, WEXT_CUR_EXE, WCPL_CUR_PER
  Local Decimal WFIY_NEW_EXE

  Local Char SWHERE(250)
  Local Integer PR_PER_TRTEE, WPLPMODIF

  Filter [PPH] Where CPY = [M:CNX0]CPY and
&                    CNX = [M:CNX0]CNX and
&                   (PPLENDDAT0 = [0/0/0] or
&                    PPLENDDAT0 >= WFDSC_PER)
  For [PPH]PPH3

    PR_PER_TRTEE = 0

    WPLNQTY = 0
    # Mémoriser le dernier résiduel gardé pour repartir de celui là
    WRSDQTY = 0

    WFIY_CUR_EXE = 0
    WEXT_CUR_EXE = 0
    WCPL_CUR_PER = 0

    WFIY_NEW_EXE = 0

    # Exercice courant
    If WFDEC_FIY = GTO_FINEXE(GVML_TECOURA)

      For [PPL] Where PROPLN = [F:PPH]PROPLN and
&                     FIYENDDAT = GTO_FINEXE(GVML_TECOURA) With Stability

        If PR_PER_TRTEE = 0

          WRSDQTY  =   [F:PPL]RSDQTY
          WPLNQTY  =   [F:PPL]PLNQTY
          WFIY_CUR_EXE = [F:PPL]FIYQTY
          PR_PER_TRTEE = 1
        Endif

        If [F:PPL]PERENDDAT = WODE_PER_COU
          WCPL_CUR_PER = [F:PPL]CPLQTY
        Endif

        # Suppression des lignes du plan de Production >= 1° période modifiée
        # (mais pas la période courante)
        If [F:PPL]PERSTRDAT >= WFDSC_PER and [F:PPL]PERENDDAT > WODE_PER_COU

          # cumul du prévu : que les périodes supprimées
          WEXT_CUR_EXE += [F:PPL]EXTQTY

          Delete [PPL] Curr
          If fstat
            GOK = 0
            Call RSTA ("PPL", CLECUR1 - CLECUR2 - num$(CLECUR2(1))) From GLOCK
            Break 2    #Fq-70141
          Endif
        Endif
      Next
    Endif


    # Exercices suivants (modifiés) : on détruit tout l'exercice
    If WLDEC_FIY  > GTO_FINEXE(GVML_TECOURA)

      SWHERE = "PROPLN = [F:PPH]PROPLN and"
      If WFDEC_FIY > GTO_FINEXE(GVML_TESUIV)
          SWHERE -= "FIYENDDAT > GTO_FINEXE(GVML_TESUIV) and"
      Else
          SWHERE -= "FIYENDDAT > GTO_FINEXE(GVML_TECOURA) and"
      Endif
      SWHERE -= "PERSTRDAT < WLDEC_FIY"

      For [PPL] Where evalue(SWHERE) With Stability

        If PR_PER_TRTEE = 0
          PR_PER_TRTEE = 1

          WPLNQTY  =   [F:PPL]PLNQTY
          # Mémoriser le 1° résiduel pour repartir de celui là
          WRSDQTY  =   [F:PPL]RSDQTY

        Endif

        # Cumul du prévu pour report
        WFIY_NEW_EXE  +=   [F:PPL]EXTQTY

        Delete [PPL] Curr
        If fstat
          GOK = 0
          Call RSTA ("PPL", CLECUR1 - CLECUR2 - num$(CLECUR2(1))) From GLOCK
          Break 2    #Fq-70141
        Endif
      Next
    Endif

    # (re)Création des lignes du plan de production (PROPLN)
    Gosub RECHARGEMENT_PLANPROD From SUBCNX2

  Next
  Filter [PPH]
Return

#-FQ-56630------------------------------------------------------------------------------
$RECHARGEMENT_PLANPROD

Local Integer I, WSUM_FIY

  Raz [F:PPL]
  [F:PPL]= [F:PPH]

  PR_PER_TRTEE = 0
  WSUM_FIY = 0
  GOK = 1
  WPLPMODIF = 0

  # Exercice courant modifié : (on va tout reporter dessus)
  If WFDEC_FIY = GTO_FINEXE(GVML_TECOURA)
    WPLPMODIF = 1

  # 1° Maj des périodes non supprimées sur l'exercice courant (si modif)
  # la date de fin d'exe et/ou le montant exercice ont pu changer
  # ainsi que la date de fin de période courante

    Read [FIS]FIY1 = [M:CNX0]CPY; [M:CNX0]CNX; GVML_TECOURA With Stability

    For I = 1 To GTO_NB_PER(GVML_TECOURA)
      # cela correspond aux enregistrements supprimés : fin de boucle
      If GTO_DEBPER(GVML_TECOURA, I - 1) >= WFDSC_PER and GTO_FINPER(GVML_TECOURA, I - 1) > WODE_PER_COU
        Break
      Endif

      Read [PPL]PPL0 = [F:PPH]PROPLN; GTO_FINEXE(GVML_TECOURA); GTO_FINPER(GVML_TECOURA, I - 1)
      # test pour si le contrat commence en cours de cet exercice
      If fstat = 0

        # mémo du résiduel de la PER SUIVANTE qui pourra changer après la 1° per modifiée
        If [F:PPL]CPLQTY
          WRSDQTY  = [F:PPL]RSDQTY - [F:PPL]CPLQTY
          WSUM_FIY += [F:PPL]CPLQTY
        Else
          WRSDQTY  = [F:PPL]RSDQTY - [F:PPL]EXTQTY
          WSUM_FIY += [F:PPL]EXTQTY
        Endif

        If G_CMENDFIY
          [F:PPL]FIYENDDAT = [F:FIS]DATENDFIY
        Endif
        If [F:PPL]PERENDDAT = GTO_FINPERCUR and WODE_PER_COU <> WNDE_PER_COU
            [F:PPL]PERENDDAT = WNDE_PER_COU
        Endif

        Rewrite [PPL]
        If fstat
          GOK = 0
          Break
        Endif
      Endif
    Next
    If GOK = 0
      Return
    Endif

  # 2° recréation des périodes (supprimées) dans l'exercice courant
  # mais pas la période courante

    # i = 1° per supprimée
    For IPER = I To [F:FIS]NBRPER

      Gosub ENREG_PPL
      If GOK = 0
        Break
      Endif
      #----------------
    Next IPER

    If GOK = 0
      Return
    Endif

    # 3a° pas de modif dans les exercices suivant et/ou suivant + 1
    # pas de période maj en 2°) : ie on a supprimé des périodes

    # il faut mettre le prévu sur la dernière période (qui doit être la période ouverte)

    If (GTO_FINEXE(GVML_TECOURA) <> [0/0/0] and WLDEC_FIY = GTO_FINEXE(GVML_TECOURA)) and
&      PR_PER_TRTEE = 0

      # On ne (re)Maj pas les per closes (elles gardent l'ancien montant exercice)

      # (re)Maj de la per courante
      Update [PPL] Where PROPLN    =  [F:PPH]PROPLN and
&                        FIYENDDAT = [F:FIS]DATENDFIY and
&                        PERENDDAT = [F:FIS]DATENDFIY
&                   With EXTQTY = EXTQTY + WEXT_CUR_EXE

      If func UO_MAJ_FIY ([F:PPH]PROPLN, WNDE_PER_COU) = 0
        Return
      Endif
      Return
    Endif

  Endif # Fin exercice courant

  WEXT_CUR_EXE = 0
  WFIY_CUR_EXE = 0
  # on a reporté le prévu donc les prochains exercices seront à 0 :
  If PR_PER_TRTEE
    WFIY_NEW_EXE = 0
  Endif

  # 3b° recréation des périodes dans les exercices suivant et/ou suivant + 1 (on recrée tout)

  If GTO_FINEXE(GVML_TECOURA) <> [0/0/0] and WLDEC_FIY > GTO_FINEXE(GVML_TECOURA)
    WPLPMODIF = 1
    SWHERE = "CPY = [M:CNX0]CPY and CNX = [M:CNX0]CNX"

    If WFDEC_FIY <= GTO_FINEXE(GVML_TESUIV)
      SWHERE -= "and (STAFIY = GVML_TESUIV"
      If WLDEC_FIY > GTO_FINEXE(GVML_TESUIV)
        SWHERE -= "or STAFIY = GVML_TESUIV2)"
      Else
        SWHERE -= ")"
      Endif
    Else
      SWHERE -= "and STAFIY = GVML_TESUIV2"
    Endif

    For [FIS]FIY1 Where evalue(SWHERE)

      For IPER = 1 To [F:FIS]NBRPER

        Gosub ENREG_PPL
        If fstat
          Break
        Endif
      #----------------
      Next IPER
      # on a reporté le prévu donc les prochains exercices seront à 0 :
      WEXT_CUR_EXE = 0
      WFIY_CUR_EXE = 0
      If PR_PER_TRTEE
        WFIY_NEW_EXE = 0
      Endif

    Next
  Endif


  # 4° recréation des périodes dans les exercices > (suivant + 1)

  If GTO_FINEXE(GVML_TESUIV2) <> [0/0/0] and WLDEC_FIY > GTO_FINEXE(GVML_TESUIV2)
    WPLPMODIF = 1

    SWHERE = "CPY = [M:CNX0]CPY and CNX = [M:CNX0]CNX"
    SWHERE -= "and DATENDFIY > GTO_FINEXE(GVML_TESUIV2)"
    SWHERE -= "and DATENDFIY <= WLDEC_FIY"

    For [FIS]FIY2 Where evalue(SWHERE)

      For IPER = 1 To [F:FIS]NBRPER

        If [F:PPH]PPLENDDAT0 <> [0/0/0] and [F:PPH]PPLENDDAT0 < [F:FIS]DATSTRPER(IPER - 1)
          Break(2)
        Endif

        Gosub ENREG_PPL
        If fstat
          Break
        Endif
      #----------------
      Next IPER
      # on a reporté le prévu donc les prochains exercices seront à 0 :
      WEXT_CUR_EXE = 0
      WFIY_CUR_EXE = 0
      WFIY_NEW_EXE = 0
    Next
  Endif

  If WPLPMODIF = 1
    If func UO_MAJ_FIY ([F:PPH]PROPLN, WNDE_PER_COU) = 0
      Return
    Endif
  Endif
Return


$ENREG_PPL

  If PR_PER_TRTEE = 0
    PR_PER_TRTEE = 1
    [F:PPL]RSDQTY = WRSDQTY
#    WCPLQTY = 0
    [F:PPL]EXTQTY = WEXT_CUR_EXE + WFIY_NEW_EXE
  Else
    [F:PPL]RSDQTY -= [F:PPL]EXTQTY
#    WEXTQTY = 0
    [F:PPL]EXTQTY = 0
  Endif

  [F:PPL]CPLQTY = 0
  [F:PPL]PLNQTY = WPLNQTY

  [F:PPL]FIYSTRDAT  = [F:FIS]DATSTRFIY
  [F:PPL]FIYENDDAT  = [F:FIS]DATENDFIY
  [F:PPL]PERSTRDAT  = [F:FIS]DATSTRPER(IPER-1)
  [F:PPL]PERENDDAT  = [F:FIS]DATENDPER(IPER-1)
  [F:PPL]PPLENDDAT  = [F:PPH]PPLENDDAT0

  Write [F:PPL]
  If ( fstat )
    GOK = 0
    Call FSTA("PPL") From GLOCK
  Endif

Return
#**
#* recalcul du cumul exercice, du résiduel pour les exercices >= exe courant (et période >= per courante)
#*
#* @param PPROPLN           plan de production
#* @param PNEWFINPERCOUR    (nouvelle) fin de pérode courante
#*!
Funprog UO_MAJ_FIY (PPROPLN, PNEWFINPERCOUR)
Value Char PPROPLN()
Value Date PNEWFINPERCOUR

Local Integer LUOEXE, WLU
Local Date WDTFINEXE

    WDTFINEXE = [0/0/0]
    LUOEXE = 0
    WLU = 0
    For [PPL] Where PROPLN = PPROPLN and FIYENDDAT >= PNEWFINPERCOUR

      WLU = 1
      # on change d'exercice
      If WDTFINEXE <> [0/0/0] and WDTFINEXE <> [F:PPL]FIYENDDAT
        # on maj si on est >= à l'exercice courant
        If WDTFINEXE >= PNEWFINPERCOUR
          If func UO_MAJ_FIY2 (PPROPLN, PNEWFINPERCOUR, WDTFINEXE, LUOEXE) = 0
            WLU = -1
            Break
          Endif
        Endif
        LUOEXE = 0
      Endif
      WDTFINEXE = [F:PPL]FIYENDDAT

      If [F:PPL]CPLQTY
        LUOEXE += [F:PPL]CPLQTY
      Else
        LUOEXE += [F:PPL]EXTQTY
      Endif

    Next
    If WLU = -1
      End 0
    Endif

    # on a fini la boucle mais il faut maj le dernier exercice lu
    # on maj si on est >= à l'exercice courant
    If WDTFINEXE <> [0/0/0] and WDTFINEXE >= PNEWFINPERCOUR and WLU
      End func UO_MAJ_FIY2 (PPROPLN, PNEWFINPERCOUR, WDTFINEXE, LUOEXE)
    Endif
End 1



Funprog UO_MAJ_FIY2(PPROPLN, PNEWFINPERCOUR, PDTFINEXE, PUOEXE)
Value Char PPROPLN()
Value Date PNEWFINPERCOUR, PDTFINEXE
Value Decimal PUOEXE

    If clalev([F:PPL2]) = 0
      Local File PROPLN [PPL2]
    Endif

    Update [PPL2] Where PROPLN = PPROPLN and FIYENDDAT = PDTFINEXE and PERENDDAT >= PNEWFINPERCOUR
&                 With FIYQTY = PUOEXE
    If fstat
      End 0
    Endif
End 1

# FQ88911 : réindentation et test sur > periode en cours
#** Recherche de la 1° période modifiée et mémorisation de
#*  la date de fin d'exercice correspondant à la dernière période modifiée
#*
#* @param PCPY
#* @param PCNX
#* @param RFIRSTDTSTR_CHG_PER RFDSC_PER début de la 1° période modifiée
#* @param RFIRSTDTEND_CHG_PER RFDEC_PER fin de la 1° période modifiée
#* @param RFIRSTDTEND_CHG_FIY RFDEC_FIY fin d'exercice de la 1° période modifiée
#* @param RLASTDTEND_CHG_FIY  RLDEC_FIY fin d'exercice de la dernière période modifiée
#* @param ROLD_DTEND_PER_COUR RODE_PER_COU ancienne fin de période courante
#* @param RNEW_DTEND_PER_COUR RNDE_PER_COU nouvelle fin de période courante
#*!
Subprog CHANGED_PER_DATES(PCPY, PCNX,
&       RFDSC_PER, RFDEC_PER, RFDEC_FIY,
&       RLDEC_FIY,
&       RODE_PER_COU, RNDE_PER_COU)
Value Char PCPY()
Value Integer PCNX
Variable Date RFDSC_PER, RFDEC_PER, RFDEC_FIY
Variable Date RLDEC_FIY
Variable Date RODE_PER_COU, RNDE_PER_COU

Local Integer I, IEXE

    RFDSC_PER = [0/0/0]
    RFDEC_PER = [0/0/0]
    RFDEC_FIY = [0/0/0]
    RLDEC_FIY  = [0/0/0]
    RODE_PER_COU = [0/0/0]
    RNDE_PER_COU = [0/0/0]

    # la lecture de l'exe courant avant modif est déjà faite avec [F:CFIS]
    # la lecture de l'exe suivant avant modif est déjà faite avec [F:SFIS]

    If !clalev([F:WFIS])
        Local File FISCYEAR  [WFIS]
    Endif

    IEXE = GVML_TECOURA - 1 # comme ça : on aura le courant  = GVML_TECOURA dans le for
    For [WFIS]FIY0 Where CPY = PCPY and CNX = PCNX and
&                   (STAFIY = GVML_TECOURA or
&                    STAFIY = GVML_TESUIV  or
&                    STAFIY = GVML_TESUIV2 or
&                    STAFIY = 0)

        IEXE += 1
        If IEXE > GNBEXE
            Break
        Endif

        For I = 1 To GTO_NB_PER(IEXE) # on boucle bien sur 'l'ancien' nombre de périodes

            # mémo de la période courante -> plans de prod
            If IEXE = GVML_TECOURA # exercice courant
                If [F:WFIS]STAPER(I - 1) = GVML_SPCOURA
                    RODE_PER_COU = GTO_FINPER(IEXE, I - 1)
                    RNDE_PER_COU = [F:WFIS]DATENDPER(I - 1)
                Endif
            Endif

            If GTO_DEBPER(IEXE, I - 1) <> [F:WFIS]DATSTRPER(I - 1) or
&              GTO_FINPER(IEXE, I - 1) <> [F:WFIS]DATENDPER(I - 1)
                If RFDSC_PER = [0/0/0]
                    RFDSC_PER = GTO_DEBPER(IEXE, I - 1)
                    RFDEC_PER = GTO_FINPER(IEXE, I - 1)
                    RFDEC_FIY = GTO_FINEXE(IEXE)
                Endif
                RLDEC_FIY  = GTO_FINEXE(IEXE)
                If IEXE > GVML_TESUIV2
                    G_CFUTUR = 1
                Endif
                Break
            Endif
        Next I

        # si il y a maintenant plus de périodes dans cet exe
        If RFDSC_PER = [0/0/0] and [F:WFIS]NBRPER > GTO_NB_PER(IEXE)
            RFDSC_PER = [F:WFIS]DATSTRPER(GTO_NB_PER(IEXE))
            RFDEC_PER = [F:WFIS]DATENDPER(GTO_NB_PER(IEXE))
            RFDEC_FIY = [F:WFIS]DATENDFIY
            RLDEC_FIY  = [F:WFIS]DATENDFIY
            If IEXE > GVML_TESUIV2
                G_CFUTUR = 1
            Endif

        Endif

    Next

End

Funprog PER_EXIST_POSTED(PLEG, PCPY, PCNX, PDATENDFIY, PDATSTRPER, PDATENDPER)
Value Char PLEG, PCPY
Value Integer PCNX
Value Date PDATENDFIY, PDATSTRPER, PDATENDPER

Local Integer WRETOUR
    #--------------------------------
    # Contrôle que les comptabilisations de dotations sont correctes dans l'exercice ou la période
    #--------------------------------
#    If func GLOBIENS.IS_CNX_POSTED(PCPY, PCNX, PDATENDFIY, PDATENDPER) = G_NON
#        End 1
#    Endif
    If func GLOBIENS.IS_DEJA_COMPTABILISE(PCPY, PCNX, PDATSTRPER, PDATENDPER) = G_OUI
        End 1
    Endif


    #--------------------------------
    # Contrôle que les comptabilisations par écart sont correctes dans l'exercice ou la période
    #--------------------------------
#    If func GLOLNK.IS_LNK_POSTED(PCPY,
#&                                PCNX,
#&                                       PDATENDFIY,
#&                                       PDATENDPER) = G_NON
    If G_ACTLNK = G_OUI
        If func GLOLNK.IS_LNK_POSTED_PLNS_CNX(PCPY, PCNX, PDATENDFIY, PDATENDPER) = G_OUI
            End 1
        Endif
    Endif

    #--------------------------------
    # Contrôle que les comptabilisations d'événements sont correctes dans l'exercice ou la période
    #--------------------------------

    Local Integer RETOUR, LDIM

    LDIM = 0
    If dim(LISTEVT) < 0
      LDIM = 1
      Global Char    LISTEVT(10)(1..100)
      Global Integer LISTPLN(1..100)
      Global Integer LISTNBE(1..100)
    Endif
#
#    Call CONTROLE_EVENEMENTS(PCPY, PCNX, LTYPCTRL, 1, WRETOUR) From GENEVE
    # Type de contrôle : (1) Période ou (2) exercice ou (3) dates indiquées
    If func GENEVE.CTRL_ALL_EVT_CPT([F:CPY]LEG, PCPY, PCNX, 3, G_NON, "",
&          LISTEVT, LISTPLN, LISTNBE, WRETOUR, PDATSTRPER, PDATENDPER) = G_NON

      If LDIM
        Kill LISTEVT, LISTPLN, LISTNBE
      Endif
      End 1
    Endif
    If LDIM
      Kill LISTEVT, LISTPLN, LISTNBE
    Endif

# provision pour renouvellement
    If G_ACTCCN = G_OUI and PCNX = G300CPFI
        If func GLOCCN.IS_RPR_DEJA_COMPTABILISE(PCPY, PDATSTRPER, PDATENDPER) = G_OUI
            End 1
        Endif
    Endif
End 0


# CBO   02.07.2013 FQ-89970 : ctrle si trf de site futur (evt)

#** Recherche si il existe un evt de transfert supérieur à une date donnée (pour un contexte)
#*
#* Par soucis de performance, on ne gère pas les cas d'annulation : cela pourrait nous emener loin...
#*
#* @param PCPY
#* @param PDATE
#*!
Funprog FUTURTRFSITE_EXIST(PCPY, PDATE)
Value Char PCPY()
Value Date PDATE

Local Char WSELECT(200)
Local Integer I, WTROUVE

    If !clalev([F:E22])
        Local File EFASAFFAGE [E22]
    Endif

    WTROUVE = 0
    For I = 0 To [M:CNX1]NBPLC - 1

        # CPTFLG permet d'utiliser l'indexe EVE2
        WSELECT  = "CPTFLG = 1 and DPRPLN = [M:CNX1]PLNCAA(I) and CPY = PCPY and"
        WSELECT -= "EVTDAT >= PDATE"

        Filter [E22] Where evalue(WSELECT)
        Look [E22]EVE2 First

        Filter [E22]
        If fstat = 0
            WTROUVE = 1
            Break
        Endif

        # CPTFLG permet d'utiliser l'indexe EVE2
        WSELECT  = "CPTFLG = 2 and DPRPLN = [M:CNX1]PLNCAA(I) and CPY = PCPY and"
        WSELECT -= "EVTDAT >= PDATE"

        Filter [E22] Where evalue(WSELECT)
        Look [E22]EVE2 First

        Filter [E22]
        If fstat = 0
            WTROUVE = 1
            Break
        Endif
    Next

    Close File [E22]

End WTROUVE




#** Fonction indépendante de contrôle des exercices d'un contexte FQ93731
#*
#*
#* @param PSOCIETE    société (ou vide pour toutes)
#* @param PCONTEXTE   contexte (ou 0 pour tous)
#* @param PBTRACE     trace (1 ou 0)
#* @param RSOCERR     société  où l'erreur est trouvée
#* @param RCNXERR     contexte où l'erreur est trouvée
#* @param RMESS       message d'erreur
#*        01  CPY NOT FOUNT
#*        02  CONTEXT NOT FOUND
#*        05  OLD EXERCICE NOT CLOSED                             + deb_exe
#*        10  CURRENT EXERCICE NOT FOUND
#*        11  OPENED PERIOD OF CURRENT EXERCICE NOT FOUND         + deb_exe
#*        20  NEXT EXERCICE NOT FOUND
#*        40  EXERCICE WITHOUT statut BEFORE AN EXERCICE WITH     + deb_exe
#*        50  EXERCICE'S START DIFFERENT OF FIRST PERIOD'S START  + deb_exe
#*        51  EXERCICE'S END DIFFERENT OF LAST PERIOD'S END       + deb_exe
#*        52  PERIOD'S START SUPERIOR OF PERIOD'S END             + deb_exe deb_per
#*        53  PERIOD'S START NOT FOLLOWING END OF PRECEDENT       + deb_exe deb_per
#*        54  PERIOD MUST BE ENDED                                + deb_exe deb_per
#*        55  PERIOD MUST BE OPENED OR CLOSED                     + deb_exe deb_per
#*        56  AN OPENED PERIOD CAN'T FOLLOW A CLOSED ONE          + deb_exe deb_per
#*        57  PERIOD MUST BE OPENED                               + deb_exe deb_per
#*        58  EXERCICE'S START NOT FOLLOWING END OF PRECEDENT     + deb_exe fin_exe_prec
#* Code retour de la fonction :  0 Ok
#*                             < 0 anomalie non bloquante
#*                             > 0 erreur grave
#*!
Funprog CTRL_CNX (PSOCIETE, PCONTEXTE, PBTRACE, RSOCERR, RCNXERR, RMESS)
Value    Char    PSOCIETE()
Value    Integer PCONTEXTE, PBTRACE
Variable Char RSOCERR()
Variable Integer RCNXERR
Variable Char RMESS()

Local Char SREQSOC(250), SREQCNX(250)
Local Integer RERROR, I, WTROUVE, WSTAT_DERN, WCPTR
Local Date WDATSTRFIY, WDATENDFIY
Local Integer WSV_LEDTYP, J #FQ105514

    Raz RERROR, RSOCERR, RCNXERR, WTROUVE, RMESS, WCPTR
    WDATENDFIY = [0/0/0]

    If clalev([F:CPYC]) = 0
        Local File COMPANY    [CPYC]
    Endif
    If clalev([F:CNXC]) = 0
        Local File CONTEXT    [CNXC]
    Endif
    If clalev([F:FISC])=0
        Local File FISCYEAR   [FISC]
    Endif

    If PBTRACE
        Call OUVRE_TRACE("CONTEXT CONTROL") From LECFIC
    Endif


#Global Char WTMPMES(250)(100)
#WTMPMES(05) = "Exercice (debut = $1$) antérieur à l'exercice courant non clos"
#WTMPMES(10) = "Exercice courant non trouvé"
#WTMPMES(11) = "Exercice (debut = $1$) courant sans période courante"
#WTMPMES(20) = "Exercice suivant non trouvé"
#WTMPMES(40) = "Exercice (debut = $1$) sans statut antérieur à un exercice statué"
##@MDJ ne faut-il pas plutôt dire : La date de début  de la première période n'est pas égale à la date de début d'exercice
## pour MES=50 (==> mess existant =239) ?? chap 7770 GML_MSGFASPR
#WTMPMES(50) = "Date de début d'exercice ($1$) différente du début de la première période ($2$)"
##@MDJ ne faut-il pas plutôt dire : La date de fin  de la dernière période n'est pas égale à la date de fin d'exercice
## pour MES=51 (==> mess existant =85) ?
#WTMPMES(51) = "Date de fin d'exercice ($1$) différente de la fin de la dernière période ($2$)"
#WTMPMES(52) = "Date de début de période ($1$) postérieure à celle de fin ($2$)"
#WTMPMES(53) = "Date de début de période ($1$) ne suivant pas celle de fin de la période précédente ($2$)"
#WTMPMES(54) = "Exercice ($1$), période ($2$) : Le statut doit être fermé"
#WTMPMES(55) = "Exercice ($1$), période ($2$) : Le statut doit être ouvert ou fermé"
#WTMPMES(56) = "Exercice ($1$), période ($2$) : Le statut est ouvert et devrait être fermé"
#WTMPMES(57) = "Exercice ($1$), période ($2$) : Le statut doit être courant"
#WTMPMES(58) = "Date de début d'exercice ($1$) ne suivant pas celle de fin du précédent ($2$)"


    If PSOCIETE = ""
        SREQSOC = "CPY <> ''"
    Else
        SREQSOC = "CPY = PSOCIETE"
    Endif

    SREQCNX = "CPY = [F:CPYC]CPY"
    If PCONTEXTE
        SREQCNX -= "and CNX = PCONTEXTE"
    Endif


    For [CPYC]CPY0 Where evalue(SREQSOC)

        WTROUVE = 1
        RSOCERR = [F:CPYC]CPY
        RCNXERR = 0
        RERROR = 0
        For [CNXC]CNX0 Where evalue(SREQCNX)
            WDATENDFIY = [0/0/0]
            WTROUVE = 2
            RCNXERR = [F:CNXC]CNX

            # existence exercice courant
            Read [FISC]FIY1 = [F:CNXC]CPY; [F:CNXC]CNX; GVML_TECOURA
            If fstat
                RERROR = 10
                WCPTR += 1
                RMESS = mess(310, GML_MSGFASPR, 1)
                If PBTRACE
                    Call ECR_TRACE("Error" - num$(RERROR) - "Company" - RSOCERR - "Context" - num$(RCNXERR) - RMESS, 0) From GESECRAN
                    Break
                Else
                    Break 2
                Endif
            Endif
            WDATSTRFIY = [F:FISC]DATSTRFIY

            # exercice(s) de date < à l'exercice courant et non clos
            Filter [FISC] Where CPY = [F:CNXC]CPY and
&                              CNX = [F:CNXC]CNX and
&                              DATSTRFIY < WDATSTRFIY and
&                              STAFIY <> GVML_TEPREC
            Read [FISC]FIY0 First
            If fstat = 0
                RERROR = 5
                WCPTR += 1
                # Exercice (debut = $1$) antérieur à l'exercice courant non clos
                RMESS  = func AFNC.MES5(mess(305, GML_MSGFASPR, 1), format$("D:"+GFMDAT, [F:FISC]DATSTRFIY), "", "", "", "")
                Filter [FISC]
                If PBTRACE
                    Call ECR_TRACE("Error" - num$(RERROR) - "Company" - RSOCERR - "Context" - num$(RCNXERR) - RMESS, 0) From GESECRAN
                    Break
                Else
                    Break 2
                Endif
            Endif
            Filter [FISC]

            # relecture exercice courant
            Read [FISC]FIY1 = [F:CNXC]CPY; [F:CNXC]CNX; GVML_TECOURA

            # Exercice courant sans période courante
            I = find(GVML_SPCOURA, [F:FISC]STAPER(0..[F:FISC]NBRPER-1))
            If I = 0
                RERROR = 11
                WCPTR += 1
                RMESS  = func AFNC.MES5(mess(311, GML_MSGFASPR, 1), format$("D:"+GFMDAT, [F:FISC]DATSTRFIY), "", "", "", "")
                If PBTRACE
                    Call ECR_TRACE("Error" - num$(RERROR) - "Company" - RSOCERR - "Context" - num$(RCNXERR) - RMESS, 0) From GESECRAN
                    Break
                Else
                    Break 2
                Endif
            Endif

            WSTAT_DERN = 0
            Call CNX_EXE(I, WSTAT_DERN, WDATENDFIY, RMESS, RERROR)
            If RERROR
                WCPTR += 1
                If PBTRACE
                    Call ECR_TRACE("Error" - num$(RERROR) - "Company" - RSOCERR - "Context" - num$(RCNXERR) - RMESS, 0) From GESECRAN
                    Break
                Else
                    Break 2
                Endif
            Endif


            # existence exercice suivant
            Read [FISC]FIY1 = [F:CNXC]CPY; [F:CNXC]CNX; GVML_TESUIV
            If fstat
                RERROR = 20
                WCPTR += 1
                RMESS  = func AFNC.MES5(mess(320, GML_MSGFASPR, 1), "", "", "", "", "")
                If PBTRACE
                    Call ECR_TRACE("Error" - num$(RERROR) - "Company" - RSOCERR - "Context" - num$(RCNXERR) - RMESS, 0) From GESECRAN
                    Break
                Else
                    Break 2
                Endif
            Endif
            WDATSTRFIY = [F:FISC]DATSTRFIY

            Call CNX_EXE(0, WSTAT_DERN, WDATENDFIY, RMESS, RERROR)
            If RERROR
                WCPTR += 1
                If PBTRACE
                    Call ECR_TRACE("Error" - num$(RERROR) - "Company" - RSOCERR - "Context" - num$(RCNXERR) - RMESS, 0) From GESECRAN
                    Break
                Else
                    Break 2
                Endif
            Endif

# A partir d'ici (exercices sans statut), les n° d'erreur deviennent négatives :
# Ce sont des anomalies (a traiter comme non bloquant)

            # existence exercice suivant + 1
            Read [FISC]FIY1 = [F:CNXC]CPY; [F:CNXC]CNX; GVML_TESUIV2
            If fstat = 0
                WDATSTRFIY = [F:FISC]DATSTRFIY

                Call CNX_EXE(0, WSTAT_DERN, WDATENDFIY, RMESS, RERROR)
                If RERROR
                    WCPTR += 1
                    RERROR = -RERROR
                    If PBTRACE
                        Call ECR_TRACE("Error" - num$(RERROR) - "Company" - RSOCERR - "Context" - num$(RCNXERR) - RMESS, 0) From GESECRAN
                        Break
                    Else
                        Break 2
                    Endif
                Endif
            Endif
#        If fstat
#            RERROR = 30
#            Break
#        Endif

            # exercices futur sans statut

            # FQ106257 : tri par exercice ajouté
            Filter [FISC] Where (CPY = [F:CPYC]CPY and CNX = [F:CNXC]CNX and STAFIY = 0)
&           Order By [F:FISC]DATENDFIY Asc
            For [FISC]
#            For [FISC]FIY1 Where (CPY = [F:CPYC]CPY and CNX = [F:CNXC]CNX and STAFIY = 0)

                #  Date < au dernier exercice statué
                If [F:FISC]DATSTRFIY < WDATSTRFIY
                    RERROR = 40
                    WCPTR += 1
                    RMESS  = func AFNC.MES5(mess(340, GML_MSGFASPR, 1), format$("D:"+GFMDAT, [F:FISC]DATSTRFIY), "", "", "", "")
                    If PBTRACE
                        Call ECR_TRACE("Error" - num$(RERROR) - "Company" - RSOCERR - "Context" - num$(RCNXERR) - RMESS, 0) From GESECRAN
                        Break 2
                    Else
                        Break 3
                    Endif
                Endif

                Call CNX_EXE(0, WSTAT_DERN, WDATENDFIY, RMESS, RERROR)
                If RERROR
                    WCPTR += 1
                    RERROR = -RERROR
                    If PBTRACE
                        Call ECR_TRACE("Error" - num$(RERROR) - "Company" - RSOCERR - "Context" - num$(RCNXERR) - RMESS, 0) From GESECRAN
                        Break 2
                    Else
                        Break 3
                    Endif
                Endif
            Next
            Filter [FISC] # FQ106257
        Next
        Filter [FISC] # FQ106257 (utile si on sort par 1 break 2 ou 3)

        If WTROUVE = 1 and PSOCIETE <> "" # pas de contexte trouvé pour la société testée
            RERROR = -2
            WCPTR += 1
            RCNXERR = 0
            RMESS = mess(121, GML_MSGFASPR, 1) # Contexte inexistant
            If PBTRACE
                Call ECR_TRACE("Error" - num$(RERROR) - "Company" - RSOCERR - "Context" - num$(RCNXERR) - RMESS, 0) From GESECRAN
            Else
                Break
            Endif
        Endif

        #FQ105514
        If func GLOBIENS.ACCPERCTL([F:CPYC]CPY) #FRADGI

          For [CNXC]CNX0 Where CPY = [F:CPYC]CPY
            WSV_LEDTYP = 0
            For J = 0 To [F:CNXC]NBPLC- 1
              If WSV_LEDTYP = 0
                WSV_LEDTYP = [F:CNXC]LEDTYP(J)
              Else
                If [F:CNXC]LEDTYP(J) <> WSV_LEDTYP
                  RERROR = -3
                  WCPTR += 1
                  RCNXERR = [F:CNXC]CNX
                  RMESS = mess(383,GML_MSGFASPR,1) : # Les plans du contexte ne peuvent pas être associés à des référentiels différents en législation française
                  If PBTRACE
                      Call ECR_TRACE("Error" - num$(RERROR) - "Company" - RSOCERR - "Context" - num$(RCNXERR) - RMESS, 0) From GESECRAN
                  Else
                      Break
                  Endif
                Endif
              Endif
            Next I
          Next
        Endif

    Next

    If WTROUVE = 0 # pas de société trouvée
        RERROR = -1
        WCPTR += 1
        RSOCERR = PSOCIETE
        RCNXERR = 0
        RMESS = mess(16, 104, 1) # Société inexistante
        If PBTRACE
            Call ECR_TRACE("Error" - num$(RERROR) - "Company" - RSOCERR - "Context" - num$(RCNXERR) - RMESS, 0) From GESECRAN
        Endif
#    Elsif RERROR > 0 or RERROR < 0
    Elsif RERROR = 0
        Raz RMESS, RSOCERR, RCNXERR
    Endif

    If PBTRACE
        Call ECR_TRACE("", 0) From GESECRAN
        If WCPTR
            Call ECR_TRACE(num$(WCPTR) - "companies in error", 0) From GESECRAN
        Else
            Call ECR_TRACE("no company in error", 0) From GESECRAN
        Endif
        Call FERME_TRACE() From LECFIC
    Endif
End RERROR


#** contrôle un exercice
#*
#*
#* @param PPER_COUR     N° de la période courante (de 1 à n) si exercice courant 0 sinon
#* @param RSTAT_DERN    statut de la dernière période de l'exercice précédent si exe sup à l'exe courrant 0 sinon
#* @param RDATENDFIY    date de fin de l'exercice précédent
#* @param RMESS
#* @param RERROR
#*!
Subprog CNX_EXE(PPER_COUR, RSTAT_DERN, RDATENDFIY, RMESS, RERROR)
Value Integer PPER_COUR
Variable Integer RSTAT_DERN
Variable Date RDATENDFIY
Variable Char RMESS
Variable Integer RERROR

Local Integer I

    # Date de début d'exercice ($1$) ne suivant pas celle de fin du précédent ($2$)
    If RDATENDFIY <> [0/0/0] and RDATENDFIY + 1 <> [F:FISC]DATSTRFIY
        RERROR = 58
        RMESS  = func AFNC.MES5(mess(358, GML_MSGFASPR, 1), format$("D:"+GFMDAT, [F:FISC]DATSTRFIY), format$("D:"+GFMDAT, RDATENDFIY), "", "", "")

        End
    Endif

    # Date de début d'exercice ($1$) différente du début de la première période ($2$)
    If [F:FISC]DATSTRPER(0) <> [F:FISC]DATSTRFIY
        RERROR = 50
        RMESS  = func AFNC.MES5(mess(350, GML_MSGFASPR, 1), format$("D:"+GFMDAT, [F:FISC]DATSTRFIY), format$("D:"+GFMDAT, [F:FISC]DATSTRPER(0)), "", "", "")
        End
    Endif

    # Date de fin d'exercice ($1$) différente de la fin de la dernière période ($2$)
    If [F:FISC]DATENDPER([F:FISC]NBRPER - 1) <> [F:FISC]DATENDFIY
        RMESS -= "DATSTRFIY =" - format$("D:"+GFMDAT, [F:FISC]DATSTRFIY )
        RERROR = 51
        RMESS  = func AFNC.MES5(mess(351, GML_MSGFASPR, 1), format$("D:"+GFMDAT, [F:FISC]DATENDFIY), format$("D:"+GFMDAT, [F:FISC]DATENDPER([F:FISC]NBRPER - 1)), "", "", "")
        End
    Endif

    For I = 0 To [F:FISC]NBRPER - 1

        # Date de début de période ($1$) postérieure à celle de fin ($2$)
        If [F:FISC]DATSTRPER(I) > [F:FISC]DATENDPER(I)
            RERROR = 52
            RMESS  = func AFNC.MES5(mess(352, GML_MSGFASPR, 1), format$("D:"+GFMDAT, [F:FISC]DATSTRPER(I)), format$("D:"+GFMDAT, [F:FISC]DATENDPER(I)), "", "", "")
            Break
        Endif
        If I
            # Date de début de période ($1$) ne suivant pas celle de fin de la période précédente ($2$)
            If [F:FISC]DATSTRPER(I) <> [F:FISC]DATENDPER(I - 1) + 1
                RERROR = 53
                RMESS  = func AFNC.MES5(mess(353, GML_MSGFASPR, 1), format$("D:"+GFMDAT, [F:FISC]DATSTRPER(I)), format$("D:"+GFMDAT, [F:FISC]DATENDPER(I - 1)), "", "", "")
                Break
            Endif
        Endif

        If PPER_COUR # on est sur l'exercice courant (on a 1 période courante)
            If I < PPER_COUR - 1  # Les périodes précédentes doivent être closes
                If [F:FISC]STAPER(I) <> GVML_SPCLOSE
                    RERROR = 54
                    RMESS  = func AFNC.MES5(mess(354, GML_MSGFASPR, 1), format$("D:"+GFMDAT, [F:FISC]DATSTRFIY), format$("D:"+GFMDAT, [F:FISC]DATSTRPER(I)), "", "", "")
                    Break
                Endif
            Elsif I = PPER_COUR - 1  # La période courante
                If [F:FISC]STAPER(I) <> GVML_SPCOURA
                    RERROR = 57
                    RMESS  = func AFNC.MES5(mess(357, GML_MSGFASPR, 1), format$("D:"+GFMDAT, [F:FISC]DATSTRFIY), format$("D:"+GFMDAT, [F:FISC]DATSTRPER(I)), "", "", "")
                    Break
                Endif
            Elsif I = PPER_COUR  # La première période suivante est soit fermée, soit ouverte
                If [F:FISC]STAPER(I) <> GVML_SPFERME and [F:FISC]STAPER(I) <> GVML_SPOUVER
                    RERROR = 55
                    RMESS  = func AFNC.MES5(mess(355, GML_MSGFASPR, 1), format$("D:"+GFMDAT, [F:FISC]DATSTRFIY), format$("D:"+GFMDAT, [F:FISC]DATSTRPER(I)), "", "", "")
                    Break
                Endif
            Elsif I > PPER_COUR
                 # Les périodes suivantes doivent être ouvertes ou fermées
                If [F:FISC]STAPER(I) <> GVML_SPFERME and [F:FISC]STAPER(I) <> GVML_SPOUVER
                    RERROR = 55
                    RMESS  = func AFNC.MES5(mess(355, GML_MSGFASPR, 1), format$("D:"+GFMDAT, [F:FISC]DATSTRFIY), format$("D:"+GFMDAT, [F:FISC]DATSTRPER(I)), "", "", "")
                    Break
                Endif
                 # une période ouverte ne peut suivre une fermée
                 If [F:FISC]STAPER(I) = GVML_SPOUVER and [F:FISC]STAPER(I - 1) = GVML_SPFERME
                    RERROR = 56
                    RMESS  = func AFNC.MES5(mess(356, GML_MSGFASPR, 1), format$("D:"+GFMDAT, [F:FISC]DATSTRFIY), format$("D:"+GFMDAT, [F:FISC]DATSTRPER(I)), "", "", "")
                    Break
                Endif
            Endif

        Else # on est sur les exercices suivants

             # Les périodes doivent être ouvertes ou fermées
             # ou 0 si on est sur un exercice suivant + 1 ou avec statut = 0
            If [F:FISC]STAPER(I) <> GVML_SPFERME and [F:FISC]STAPER(I) <> GVML_SPOUVER
                If ([F:FISC]STAFIY = GVML_TESUIV2 or [F:FISC]STAFIY = 0) and [F:FISC]STAPER(I) = 0
                Else
                    RERROR = 55
                    RMESS  = func AFNC.MES5(mess(355, GML_MSGFASPR, 1), format$("D:"+GFMDAT, [F:FISC]DATSTRFIY), format$("D:"+GFMDAT, [F:FISC]DATSTRPER(I)), "", "", "")
                    Break
                Endif
            Endif
            If I = 0
                # la première période ne peut être ouverte si la dernière de l'exercice précédent est fermée
                If RSTAT_DERN = GVML_SPFERME and [F:FISC]STAPER(I) = GVML_SPOUVER
                    RERROR = 56
                    RMESS  = func AFNC.MES5(mess(356, GML_MSGFASPR, 1), format$("D:"+GFMDAT, [F:FISC]DATSTRFIY), format$("D:"+GFMDAT, [F:FISC]DATSTRPER(I)), "", "", "")
                    Break
                Endif
            Else
                # une période ouverte ne peut suivre une fermée
                If [F:FISC]STAPER(I) = GVML_SPOUVER and [F:FISC]STAPER(I - 1) = GVML_SPFERME
                    RERROR = 56
                    RMESS  = func AFNC.MES5(mess(356, GML_MSGFASPR, 1), format$("D:"+GFMDAT, [F:FISC]DATSTRFIY), format$("D:"+GFMDAT, [F:FISC]DATSTRPER(I)), "", "", "")
                    Break
                Endif
            Endif
        Endif


        # Le type de compta réel ne peut suivre un type de compta simulé pour les exe courant et suivant
# voir plus tard (phase 2)
If I = -1
        If I and ([F:FISC]STAFIY = GVML_TECOURA or [F:FISC]STAFIY = GVML_TESUIV)
            If ([F:FISC]STAPER(I - 1) = GVML_SPCOURA or [F:FISC]STAPER(I - 1) = GVML_SPOUVER) and
&              ([F:FISC]STAPER(I) = GVML_SPCOURA     or [F:FISC]STAPER(I) = GVML_SPOUVER)
                If [F:FISC]TYPPST(I - 1) = GVML_TPSTPRO and [F:FISC]TYPPST(I) = GVML_TPSTDEF
                    RMESS -= "DATSTRFIY =" - format$("D:"+GFMDAT, [F:FISC]DATSTRFIY )
                    RMESS -= "DATSTRPER =" - format$("D:"+GFMDAT, [F:FISC]DATSTRPER(I) )
                    RERROR = 58
                    Break
                Endif
            Endif
        Endif
Endif
    Next I

    # infos pour la continuité avec le prochain exercice qui sera contrôlé
    If RERROR = 0
        RSTAT_DERN = [F:FISC]STAPER([F:FISC]NBRPER - 1)
        RDATENDFIY = [F:FISC]DATENDFIY
    Endif
End

Subprog CTR_CNX_GEN()

Local Char RSOCERR(10)
Local Integer RCNXERR
Local Char RMESS(100)
#Infbox "dedans"

If func CTRL_CNX ("", 0, 1, RSOCERR, RCNXERR, RMESS)
Endif

End

