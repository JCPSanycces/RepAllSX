# Classe PPRICLINKH_CSTD from SPRICLINKH_C_TSCCOD  12/11/2013

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
     Case [L]AEVENT
       When "LOAD_TO_PPK_FILE" : Gosub LOAD_TO_PPK_FILE
     Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#  Case [L]CURPRO
#     Case [L]ARULE
#     Endcase
#  Endcase
Return

#-------------------------------------------------------
#--Method used to load properties from class PPRICLINKH to [F:PPK]
$LOAD_TO_PPK_FILE
Local Integer IJ

  If dim([F:PPK]CPY)<1
    [L]ASTATUS = fmet this.ASETERROR ("", "Data Class PPRICLINKH : Method call LOAD_TO_PPK_FILE no [F:PPK] file opened", [V]CST_AERROR)
    [L]ARET_VALUE = [L]ASTATUS
    Return
  Endif

  SetInstance [F:PPK] With this
  #--Parcours des collections
  #--TSCCOD
  For IJ=1 To maxtab(this.C_TSCCOD)
    If dim([F:PPK]TSCCOD(IJ-1))<1 : Break : Endif

    [F:PPK]TSCCOD(IJ-1) = "" #AVOID.ACHAR

    If this.C_TSCCOD(IJ)<>null
      [F:PPK]TSCCOD(IJ-1) = this.C_TSCCOD(IJ).TSCCOD
    Endif

  Next IJ
Return

