#<AdxTL>@(#)0.0.0.0 $Revision$ Object Management MAT
#####################################################################################
# SUBMAT 07/27/2011 22:40:24 (EWI)
#####################################################################################
$ACTION

Case ACTION
 When "LIENS"         : Gosub LIENS
 When "RAZCRE"        : Gosub RAZCRE
 When "VERIF_CRE"     : Gosub VERIF_CRE
 When "VERIF_MOD"     : Gosub VERIF_MOD
 When "ANNULE"        : Gosub ANNULE
 When "INICRE"        : Gosub INICRE
 When "INIMOD"        : Gosub INIMOD
 When Default
Endcase

Return

######################################################################################
$INICRE
  #CATUA X3-97326.sn
  #New matching tolerance description AX3 field
  Call MAJTEXTRA([M:MAT0]TOLDESAXX,"MATCHTOL","TOLDESAXX",[M]MATTOL,"") From ATEXTRA
  [F:MAT]TOLDES = [M:MAT0]TOLDESAXX
  #CATUA X3-97326.en
Return

######################################################################################
$INIMOD
  #CATUA X3-97326.sn
  #New matching tolerance description AX3 field
  Call MAJTEXTRA([M:MAT0]TOLDESAXX,"MATCHTOL","TOLDESAXX",[M]MATTOL,"") From ATEXTRA
  [F:MAT]TOLDES = [M:MAT0]TOLDESAXX
  #CATUA X3-97326.en
Return

######################################################################################
$LIENS
  #CATUA X3-97326.sn
  #New matching tolerance description AX3 field
  Read [AXX]AXX0="MATCHTOL";"TOLDESAXX";GLANGUE;[M]MATTOL;""
  If !fstat
    [M:MAT0]TOLDESAXX=[F:AXX]TEXTE
  Endif

  If [M:MAT0]TOLDESAXX="" and [F:MAT]TOLDES<>"" Then
    [M:MAT0]TOLDESAXX=[F:MAT]TOLDES
    Chgstl [M:MAT0]TOLDESAXX With "NTRANSLATE"
  Else
    Chgstl [M:MAT0]TOLDESAXX With ""
  Endif
  #CATUA X3-97326.en

  Gosub M_GRIZO
Return

######################################################################################
$RAZCRE
  Gosub M_GRIZO
Return

######################################################################################
$M_GRIZO

# Receipt qty short
If [M:MAT1]QSCTL<>2
  Grizo [M:MAT1]QSPER,QSQTY,QSACT
Else
  [M:MAT1]QSUOM = [M:MAT0]TOLUOM
  Actzo [M:MAT1]5
Endif

# Receipt qty exceed
If [M:MAT1]QECTL<>2
  Grizo [M:MAT1]QEPER,QEQTY,QEACT
Else
  [M:MAT1]QEUOM = [M:MAT0]TOLUOM
  Actzo [M:MAT1]10
Endif

# Early receipt
If [M:MAT1]ERCTL<>2
  Grizo [M:MAT1]ERDAYS,ERACT
Else
  Actzo [M:MAT1]15
Endif

# Late receipt
If [M:MAT1]LRCTL<>2
  Grizo [M:MAT1]LRDAYS,LRACT
Else
  Actzo [M:MAT1]20
Endif

# Invoice qty short
If [M:MAT2]IQSCTL<>2
  Grizo [M:MAT2]IQSPER,IQSQTY,IQSACT
Else
  [M:MAT2]IQSUOM = [M:MAT0]TOLUOM
  Actzo [M:MAT2]5
Endif

# Invoice qty exceed
If [M:MAT2]IQECTL<>2
  Grizo [M:MAT2]IQEPER,IQEQTY,IQEACT
Else
  [M:MAT2]IQEUOM = [M:MAT0]TOLUOM
  Actzo [M:MAT2]10
Endif

# Under inv unit
If [M:MAT2]UIUCTL<>2
  Grizo [M:MAT2]UIUPER,UIUAMT,UIUACT
Else
  [M:MAT2]UIUCUR = [M:MAT0]TOLCUR
  Actzo [M:MAT2]25
Endif

# Over inv unit
If [M:MAT2]OIUCTL<>2
  Grizo [M:MAT2]OIUPER,OIUAMT,OIUACT
Else
  [M:MAT2]OIUCUR = [M:MAT0]TOLCUR
  Actzo [M:MAT2]30
Endif

# Under inv ext line
If [M:MAT2]UILCTL<>2
  Grizo [M:MAT2]UILPER,UILAMT,UILACT
Else
  [M:MAT2]UILCUR = [M:MAT0]TOLCUR
  Actzo [M:MAT2]35
Endif

# Over inv ext line
If [M:MAT2]OILCTL<>2
  Grizo [M:MAT2]OILPER,OILAMT,OILACT
Else
  [M:MAT2]OILCUR = [M:MAT0]TOLCUR
  Actzo [M:MAT2]40
Endif

Return

######################################################################################
$VERIF_CRE
Gosub VERIF
Gosub SET_CTLFLGS
Return

######################################################################################
$VERIF_MOD
Gosub VERIF
Gosub DOC_CHECK
Gosub SET_CTLFLGS
Return

######################################################################################
$VERIF
  If sum([M:MAT2]UIUAMT,[M:MAT2]OIUAMT,[M:MAT2]UILAMT,[M:MAT2]OILAMT)>0 & [M:MAT0]TOLCUR=""
    GMESSAGE = mess(425,194,1) : GERR=1
    OK=0 : SUIZON="TOLCUR" : Return
  Endif

  If sum([M:MAT1]QSQTY,[M:MAT1]QEQTY,[M:MAT2]IQSQTY,[M:MAT2]IQEQTY)>0 & [M:MAT0]TOLUOM=""
    GMESSAGE = mess(421,194,1) : GERR=1
    OK=0 : SUIZON="TOLUOM" : Return
  Endif

Return

######################################################################################
$DOC_CHECK # To warn user on changes to tolerance codes in active use on POs, Receipts or Invoices

If  !clalev([F:POH]) : Local File PORDER    : Endif
If  !clalev([F:POP]) : Local File PORDERP   : Endif
If  !clalev([F:PTH]) : Local File PRECEIPT  : Endif
If  !clalev([F:PTD]) : Local File PRECEIPTD : Endif
If  !clalev([F:PIH]) : Local File PINVOICE  : Endif
If  !clalev([F:PID]) : Local File PINVOICED : Endif

Link [F:POP] With [F:POH]POH0=[F:POP]POHNUM As [LNK] Where [POP]MATTOL=[M]MATTOL and
&    ([POH]CLEFLG=1 |  [POH]RCPFLG < 3 | [POH]INVFLG < 3)

Read [LNK] First
  If  !fstat
   Call OUINON(mess(24,584,1),XOK) From GESECRAN # Warning message prompt
    If XOK<>2
     Goto DOC_MESS
    Else
     Goto DOC_FIN
    Endif
  Endif
Filter [LNK]

Link [F:PTD] With [F:PTH]PTH0=[F:PTD]PTHNUM As [LNK] Where [PTD]MATTOL=[M]MATTOL and [PTH]INVFLG < 3

Read [LNK] First
  If  !fstat
    Call OUINON(mess(24,584,1),XOK) From GESECRAN # Warning message prompt
     If XOK<>2
      Goto DOC_MESS
     Else
      Goto DOC_FIN
     Endif
  Endif
Filter [LNK]

Link [F:PID] With [F:PIH]PIH0=[F:PID]NUM As [LNK] Where [PID]MATTOL=[M]MATTOL and [F:PIH]STA<3

Read [LNK] First
  If  !fstat
    Call OUINON(mess(24,584,1),XOK) From GESECRAN # Warning message prompt
     If XOK<>2
      Goto DOC_MESS
     Endif
  Endif
Filter [LNK]

Return
######################################################################################
$DOC_MESS
GERR=1 : OK=0
SUIZON="MATTOL"
Filter [LNK]

Return
######################################################################################
$DOC_FIN
 Filter [LNK]

Return
######################################################################################
$ANNULE
  #CATUA X3-97326.sn
  Delete [AXX] Where CODFIC="MATCHTOL" & IDENT1=[M]MATTOL
  #CATUA X3-97326.en

