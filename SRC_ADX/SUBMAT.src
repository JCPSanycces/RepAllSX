Else
  Raz [M:MAT1]QEPER,QEQTY,QEUOM
  [M:MAT1]QEACT=2
  Grizo [M:MAT1]QEPER,QEQTY,QEACT
Endif
Affzo [M:MAT1]10

End

######################################################################################
Subprog AM_ERCTL(VALEUR)
Variable Integer VALEUR

If VALEUR=2
  Actzo [M:MAT1]15
Else
  Raz [M:MAT1]ERDAYS
  [M:MAT1]ERACT=2
  Grizo [M:MAT1]ERDAYS,ERACT
Endif
Affzo [M:MAT1]15

End

