#  If  !fstat
#   GMESSAGE = mess(25,584,1) : mkstat=2
#     Goto DOC_FIN
#  Endif
#Filter [LNK]
#
#Link [F:PTD] With [F:PTH]PTH0=[F:PTD]PTHNUM As [LNK] Where [PTD]MATTOL=[M]MATTOL and [PTH]INVFLG < 3
#
#Read [LNK] First
#  If  !fstat
#    GMESSAGE = mess(25,584,1) : mkstat=2
#      Goto DOC_FIN
#  Endif
#Filter [LNK]
#
#Link [F:PID] With [F:PIH]PIH0=[F:PID]NUM As [LNK] Where [PID]MATTOL=[M]MATTOL and [F:PIH]STA<3
#
#Read [LNK] First
#  If  !fstat
#   GMESSAGE = mess(25,584,1) : mkstat=2
#     Goto DOC_FIN
#  Endif
#Filter [LNK]
Return
######################################################################################
$SET_CTLFLGS

#Set hidden control flags per section
Raz [M:MAT1]QSCTLP,QSCTLQ,QECTLP,QECTLQ
Raz [M:MAT2]IQSCTLP,IQSCTLQ,IQECTLP,IQECTLQ
Raz [M:MAT2]UIUCTLP,UIUCTLA,OIUCTLP,OIUCTLA,UILCTLP,UILCTLA,OILCTLP,OILCTLA

If [M:MAT1]QSCTL=2
 If [M:MAT1]QSPER<>0 | ([M:MAT1]QSPER=0 & [M:MAT1]QSQTY=0)
  [M:MAT1]QSCTLP=2
 Endif
 If [M:MAT1]QSQTY<>0
  [M:MAT1]QSCTLQ=2
 Endif
Endif

If [M:MAT1]QECTL=2
 If [M:MAT1]QEPER<>0 |([M:MAT1]QEPER=0 & [M:MAT1]QEQTY=0)
  [M:MAT1]QECTLP=2
 Endif
 If [M:MAT1]QEQTY<>0
  [M:MAT1]QECTLQ=2
 Endif
Endif

If [M:MAT2]IQSCTL=2
 If [M:MAT2]IQSPER<>0 | ([M:MAT2]IQSPER=0 & [M:MAT2]IQSQTY=0)
  [M:MAT2]IQSCTLP=2
 Endif
 If [M:MAT2]IQSQTY<>0
  [M:MAT2]IQSCTLQ=2
 Endif
Endif

If [M:MAT2]IQECTL=2
 If [M:MAT2]IQEPER<>0 | ([M:MAT2]IQEPER=0 & [M:MAT2]IQEQTY=0)
  [M:MAT2]IQECTLP=2
 Endif
 If [M:MAT2]IQEQTY<>0
  [M:MAT2]IQECTLQ=2
 Endif
Endif

If [M:MAT2]UIUCTL=2
 If [M:MAT2]UIUPER<>0 | ([M:MAT2]UIUPER=0 & [M:MAT2]UIUAMT=0)
  [M:MAT2]UIUCTLP=2
 Endif
 If [M:MAT2]UIUAMT<>0
  [M:MAT2]UIUCTLA=2
 Endif
Endif

If [M:MAT2]OIUCTL=2
 If [M:MAT2]OIUPER<>0 | ([M:MAT2]OIUPER=0 & [M:MAT2]OIUAMT=0)
  [M:MAT2]OIUCTLP=2
 Endif
 If [M:MAT2]OIUAMT<>0
  [M:MAT2]OIUCTLA=2
 Endif
Endif

If [M:MAT2]UILCTL=2
 If [M:MAT2]UILPER<>0 | ([M:MAT2]UILPER=0 & [M:MAT2]UILAMT=0)
  [M:MAT2]UILCTLP=2
 Endif
 If [M:MAT2]UILAMT<>0
  [M:MAT2]UILCTLA=2
 Endif
Endif

If [M:MAT2]OILCTL=2
 If [M:MAT2]OILPER<>0 | ([M:MAT2]OILPER=0 & [M:MAT2]OILAMT=0)
  [M:MAT2]OILCTLP=2
 Endif
 If [M:MAT2]OILAMT<>0
  [M:MAT2]OILCTLA=2
 Endif
Endif

Return

######################################################################################
Subprog C_TOLCUR(VALEUR)
Variable Char    VALEUR()

If sum([M:MAT2]UIUAMT,[M:MAT2]OIUAMT,[M:MAT2]UILAMT,[M:MAT2]OILAMT)>0 & VALEUR=""
  GMESSAGE = mess(425,194,1)
  GERR=1 : mkstat=2 : End
Endif

End

######################################################################################
Subprog AM_TOLCUR(VALEUR)
Variable Char    VALEUR()

If [M:MAT2]UIUCTL=2
  [M:MAT2]UIUCUR=VALEUR
  Affzo [M:MAT2]UIUCUR
Endif
If [M:MAT2]OIUCTL=2
  [M:MAT2]OIUCUR=VALEUR
  Affzo [M:MAT2]OIUCUR
Endif
If [M:MAT2]UILCTL=2
  [M:MAT2]UILCUR=VALEUR
  Affzo [M:MAT2]UILCUR
Endif
If [M:MAT2]OILCTL=2
  [M:MAT2]OILCUR=VALEUR
  Affzo [M:MAT2]OILCUR
Endif

End

#####################################################################################
Subprog C_TOLUOM(VALEUR)
Variable Char    VALEUR()

If sum([M:MAT1]QSQTY,[M:MAT1]QEQTY,[M:MAT2]IQSQTY,[M:MAT2]IQEQTY)>0 & VALEUR=""
  GMESSAGE = mess(421,194,1)
  GERR=1 : mkstat=2 : End
Endif

End

#####################################################################################
Subprog AM_TOLUOM(VALEUR)
Variable Char    VALEUR()

If [M:MAT1]QSCTL=2
  [M:MAT1]QSUOM=VALEUR
  Affzo [M:MAT1]QSUOM
Endif
If [M:MAT1]QECTL=2
  [M:MAT1]QEUOM=VALEUR
  Affzo [M:MAT1]QEUOM
Endif
If [M:MAT2]IQSCTL=2
  [M:MAT2]IQSUOM=VALEUR
  Affzo [M:MAT2]IQSUOM
Endif
If [M:MAT2]IQECTL=2
  [M:MAT2]IQEUOM=VALEUR
  Affzo [M:MAT2]IQEUOM
Endif

End

######################################################################################
Subprog AM_QSCTL(VALEUR)
Variable Integer VALEUR

If VALEUR=2
  [M:MAT1]QSUOM = [M:MAT0]TOLUOM
  Actzo [M:MAT1]5
Else
  Raz [M:MAT1]QSPER,QSQTY,QSUOM
  [M:MAT1]QSACT=2
  Grizo [M:MAT1]QSPER,QSQTY,QSACT
Endif
Affzo [M:MAT1]5

End

######################################################################################
Subprog AM_QECTL(VALEUR)
Variable Integer VALEUR

If VALEUR=2
  [M:MAT1]QEUOM = [M:MAT0]TOLUOM
