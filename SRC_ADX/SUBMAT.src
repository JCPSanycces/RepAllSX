#######################################################################################
Subprog UOM_QTY(VALEUR)
Variable Decimal VALEUR

If VALEUR<>0 & [M:MAT0]TOLUOM=""
  GMESSAGE = mess(421,194,1)
  GERR=1 : zonsui="TOLUOM" : End
Endif

End

