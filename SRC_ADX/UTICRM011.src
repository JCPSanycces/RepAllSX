#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTICRM011   Moulinette gestion SITE OBJETS BROWSER CRM       Module TC #
#             objets                                                     #
##########################################################################
# FGR 15/07/2014 : X3SUIVI101463
##########################################################################
Local Char DOSSIER(30)

  If 0=1 Then
    DOSSIER = nomap
    Call SAIDOS(DOSSIER, "") From SAIDOS
    If DOSSIER <> "" Then
      If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
      Read [ADS]DOSSIER=[L]DOSSIER
      If fstat Then
        Raz [F:ADS]
      Endif
      Call TEMPON("O") From GESECRAN
      Call OUVRE_TRACE("Correction") From LECFIC
      Call MAJ_UTICRM011(DOSSIER)
      Call TEMPOFF     From GESECRAN
      Call FERME_TRACE From LECFIC
      Call LEC_TRACE From LECFIC
    Endif
  Else
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    For [ADS]DOSSIER
      If [F:ADS]DOSSIER <> "X3INDV6" and [F:ADS]DOSSIER <> "X3TESTV6" Then
        DOSSIER = [F:ADS]DOSSIER
        Call MAJ_UTICRM011(DOSSIER)
      Endif
    Next
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTICRM011(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Char WOBJET(GLONAOB)
Local Integer WNBR
Local Integer B_OK

  Call ECR_TRACE("UTICRM011: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  If clalev([F:AOB]) = 0 : Local File =DOSSIER + ".AOBJET"  [AOB] : Endif
  Raz COMPTEUR
  #
  For WOBJET="SIH", "CON", "RQW", "SRE", "BAP", "CLL", "CMG", "OMP", "TSK", "ITN"
    Read [AOB]ABREV=WOBJET
    If !fstat Then
      If [F:AOB]TYPGES <> 4 Then
        # Pas de fenêtre pour les browsers
        Call VALID("O" + WOBJET, DOSSIER, 1, B_OK) From VALWIN
        If B_OK <> 1 Then
          Call ECR_TRACE("Erreur revalidation fenêtre O" + WOBJET, 1) From GESECRAN
        Endif
      Endif
      #
      COMPTEUR += 1
    Endif
  Next WOBJET
  #
  Close Local File [AOB]
  Call ECR_TRACE("UTICRM011 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI = "X3" Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  Call MAJ_UTICRM011(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  If APPLI = "X3" Then
    End
  Endif
  Call MAJ_UTICRM011(APPLI)
End
