#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# Class TECPTESTA
# Issue X3-66487 - 2018-05-08 by SINGC
###################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  #Case [L]CURPTH
  #   When ""
  #    Case [L]AEVENT
  #    Endcase
  #Endcase
Return

###################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "TIMENT_ADD_LINE"             : Gosub TIMENT_ADD_LINE
    #
    When "_LOAD_ONE_TIMENT"            : Gosub _LOAD_ONE_TIMENT
    When "_TIMENT_COPY"                : Gosub _TIMENT_COPY
  Endcase
Return

###################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
  Endcase
Return

###################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return

###################################################################################################
# METHODS
###################################################################################################
$TIMENT_ADD_LINE
#Value Char SCLB ()
#Value Integer IPTESEQ
#Value Integer IPTESTA
#Local Integer ARET_VALUE

Local Integer ILINE

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------------------
  If SCLB <> AVOID.ACHAR and IPTESEQ > 0 Then
    ILINE = fmet this.ADDLINE("TIMENT", [V]CST_ALASTPOS)
    If ILINE <> [V]CST_ANOTDEFINED Then
      this.TIMENT(ILINE).CLB = SCLB
      this.TIMENT(ILINE).PTESEQ = IPTESEQ
      this.TIMENT(ILINE).PTESTA = IPTESTA
    Endif
  Endif
  # ------------------------------------
Return

###################################################################################################
$_LOAD_ONE_TIMENT
#Variable Instance TECPTESTA Using C_TECPTESTA : #
#Local Integer ARET_VALUE

Local Char SCLB(GLONVCR)
Local Integer NI
Local Integer ILINE
Local Integer IRET

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------------------
  Raz SCLB
  For NI = 1 To maxtab(TECPTESTA.TIMENT)
    If TECPTESTA.TIMENT(NI) <> null and find(TECPTESTA.TIMENT(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
      If SCLB = AVOID.ACHAR Then
        SCLB = TECPTESTA.TIMENT(NI).CLB
      Endif
      If TECPTESTA.TIMENT(NI).CLB = SCLB Then
        ILINE = fmet this.ADDLINE("TIMENT", [V]CST_ALASTPOS)
        If ILINE <> [V]CST_ANOTDEFINED Then
          IRET = fmet this._TIMENT_COPY(TECPTESTA, NI, ILINE)
          If IRET < [V]CST_AERROR Then
            IRET = fmet TECPTESTA.ADELLINE("TIMENT", TECPTESTA.TIMENT(NI).AORDER)
          Endif
        Endif
      Endif
    Endif
  Next NI
  # ------------------------------------
Return

###################################################################################################
$_TIMENT_COPY
#Variable Instance TECPTESTA Using C_TECPTESTA : #
#Value Shortint LINEFROM
#Value Shortint LINETO
#Local Integer ARET_VALUE

  [L]ARET_VALUE = [V]CST_AOK
  # ------------------------------------
  this.TIMENT(LINETO).CLB = TECPTESTA.TIMENT(LINEFROM).CLB       # 1
  this.TIMENT(LINETO).PTESEQ = TECPTESTA.TIMENT(LINEFROM).PTESEQ # 2
  this.TIMENT(LINETO).PTESTA = TECPTESTA.TIMENT(LINEFROM).PTESTA # 3
  # ------------------------------------
Return

