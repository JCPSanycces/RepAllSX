# Issue 110325 - 2016-01-05 by SR : Critères de picking sur RCP : US 120
##################################################################
# SELSHHRCP :  Sélection du numéro d'expédition                  #
#       pour picking expés en réceptions                         #
##################################################################
#--------------------------------------#
# Avant ouverture fenêtre de sélection #
#--------------------------------------#
$SEL_SELSHHRCP
OBJET="SHIP"
TIT(0)=mess(502,198,1)
CRITERE(1)="LEGCPY=GSOCIETE"

START="SHIPNUM"
SIZLIG=80 : SIZCOL=240
Return


#######################################################################
# SEL_PUOMPOI :  Sélection de l'unité               action e-commerce #
#                en am du fournisseur                     HN 02/11/00 #
#   FOURN  : Numéro du fournisseur dont les unités sont à chercher(zc)#
#   REFART : Référence de l'article dont les unités sont à chercher   #
#   INDFIC : Indicateur fichiers à traiter                            #
#            1 = Article (ITMMASTER)                                  #
#            2 = Article-fournisseur (ITMBPS)                         #
#            3 = Article + article-fournisseur (ITMMASTER+ITMBPS)     #
#   INDUNI : Indicateur unités à traiter                              #
#            1 = Unité d'achat (UA)                                   #
#            2 = Unité de conditionnement (UC)                        #
#            3 = Unité de stock (US)                                  #
#            4 = Unité d'achat + unité de conditionnement (UA+UC)     #
#            5 = Les trois unités (UA+UC+US)                          #
#            6 = Unité d'achat et de vente simultanément (UA=UV)      #
#                utilisé depuis les contrats avec zone [M]BPCORD      #
#                                              et zone [M]BETFCY      #
#   UNITE  : Unité sélectionnée                                       #
#######################################################################
#-------------------------------------------------------#
# Avant ouverture de la fenêtre de sélection des unités #
#-------------------------------------------------------#
$SEL_PUOMPOI
Local Char    REFART(GLONITM) : REFART= PARAM(1)
Local Integer INDFIC          : INDFIC= val(PARAM(2))
Local Integer INDUNI          : INDUNI= val(PARAM(3))
Local Char    UNITE (GLONUOM) : UNITE = PARAM(4)
Local Integer SAVNOLIGN       : SAVNOLIGN=nolign
Local Char    FOURN (GLONBPS) : FOURN = VALEUR
Local Char    UNIVEN(GLONUOM)
Local Integer I
#----- Contrôle validité des indicateurs -----#
If INDFIC=0 | INDFIC>3 : OK=0 : Return : Endif
If INDUNI=0 | INDUNI>6 : OK=0 : Return : Endif
If [M]BETFCY(nolign-1)<>2 : OK=0 : Return : Endif
#----- Ouverture et lecture table article si nécessaire -----#
If clalev([F:ITM])=0 Local File ITMMASTER [ITM] : Endif
If clalev([F:ITP])=0 Local File ITMBPS    [ITP] : Endif
If [F:ITM]ITMREF<>REFART
  Read [ITM] ITM0=REFART
  If fstat Raz [F:ITM] : Endif
Endif
If [F:ITP]ITMREF<>REFART | [F:ITP]BPSNUM<>VALEUR
  Read [ITP] ITP0=REFART;VALEUR
  If fstat Raz [F:ITP] : Endif
Endif
#-- Contrôle de l'unité précédente
#-- Si non inter-site doit faire partie de l'ITP, si on en a un
#-- Ou ITM
#-- Si inter-site on doit avoir soit UA-UV ou UA et UC de l'article
If UNITE<>""
  If [M]BETFCY(nolign-1)=2
    Call CONTSAUIMP(UNITE,REFART,[M]BPCORD(nolign-1),UNIVEN) From TRTVENCTL
  Endif
  If [M]BETFCY(nolign-1)=1 | UNIVEN<>""
    If [F:ITP]PUU<>"" & UNITE=[F:ITP]PUU & [M]UOMPUUCOE(nolign-1)=1
      OK=0 : Return
    Endif
    If [F:ITP]PCU<>"" & UNITE=[F:ITP]PCU & [M]UOMPUUCOE(nolign-1)=[F:ITP]PCUPUUCOE
      OK=0 : Return
    Endif
    I=find(UNITE,[F:ITM]PCU(0..dim([F:ITM]PCU)-1))
    If I<>0
      If [F:ITP]PUU<>"" & [M]UOMPUUCOE(nolign-1)=arr([F:ITM]PCUSTUCOE(I-1)/[F:ITP]PCUPUUCOE,0.000001)
        OK=0 : Return
      Endif
      If [F:ITM]PUU<>"" &  [M]UOMPUUCOE(nolign-1)=arr([F:ITM]PCUSTUCOE(I-1)/[F:ITM]PUUSTUCOE,0.000001)
        OK=0 : Return
      Endif
    Endif
  Endif
Endif
#----- Variables locales -----#
Local    Char    TABUNITE(GLONUOM+12)(dim([F:ITM]PCU)+4)
Local    Char    TABCODE (GLONUOM)   (dim([F:ITM]PCU)+4)
Local    Char    CODE(GLONUOM)
Local    Char    WTEXTE(80)
Local    Integer NBUNITE, NO, INDUNITE, SAUFLG
INDUNITE=INDUNI
If INDUNI=6
  If GMODU(5)<>2 | dim([M]BPCORD)<=0 | dim([M]BETFCY)<=0
    INDUNITE=1 : SAUFLG=0
  Elsif [M]BETFCY<>2
    INDUNITE=1 : SAUFLG=0
  Else
    INDUNITE=1 : SAUFLG=1
  Endif
Else
  SAUFLG=0
Endif
#-- En inter-sites on autorise UA si UA=UV et les UC
If INDUNI=4
  If GMODU(5)<>2 | dim([M]BPCORD)<=0 | dim([M]BETFCY)<=0
    SAUFLG=0
  Elsif [M]BETFCY<>2
    SAUFLG=0
  Else
    SAUFLG=1
  Endif
Else
  SAUFLG=0
Endif
#----- Ouverture et lecture des fichiers si nécessaire -----#
If clalev([F:TUN])=0    Local File TABUNIT   [TUN] : Endif
If clalev([F:AXX])=0    Local File ATEXTRA   [AXX] : Endif
If INDFIC=1 | INDFIC=3
  If clalev([F:ITM])=0 Local File ITMMASTER [ITM] : Endif
  If [F:ITM]ITMREF<>REFART
    Read [ITM] ITM0=REFART
    If fstat Raz [F:ITM] : Endif
  Endif
Endif
If INDFIC=2 | INDFIC=3
  If clalev([F:ITP])=0 Local File ITMBPS    [ITP] : Endif
  If [F:ITP]ITMREF<>REFART | [F:ITP]BPSNUM<>FOURN
    Read [ITP] ITP0=REFART;FOURN
    If fstat Raz [F:ITP] : Endif
  Endif
Endif
#----- Chargement de la table des unités -----#
If INDFIC=1 | INDFIC=3
  If (INDUNITE=1 | INDUNITE=4 | INDUNITE=5) & [F:ITM]PUU<>""
                           CODE=[F:ITM]PUU    : Gosub CHARG_UNIT2 : Endif
  If INDUNITE=2 | INDUNITE=4 | INDUNITE=5
    For I=0 To dim([F:ITM]PCU)-1
      If [F:ITM]PCU(I)<>"" CODE=[F:ITM]PCU(I) : Gosub CHARG_UNIT2 : Endif
    Next I
  Endif
  If (INDUNITE=3 | INDUNITE=5) & [F:ITM]STU<>""
                           CODE=[F:ITM]STU    : Gosub CHARG_UNIT2 : Endif
Endif
If INDFIC=2 | INDFIC=3
  If (INDUNITE=1 | INDUNITE=4 | INDUNITE=5) & [F:ITP]PUU<>""
                           CODE=[F:ITP]PUU    : Gosub CHARG_UNIT2 : Endif
  If (INDUNITE=2 | INDUNITE=4 | INDUNITE=5) & [F:ITP]PCU<>""
                           CODE=[F:ITP]PCU    : Gosub CHARG_UNIT2 : Endif
Endif
If NBUNITE >= 0
  For I=0 To NBUNITE-1
    NBTEX +=1
    TEX(NBTEX)   = TABCODE(I)
    TEXTE(NBTEX) = TABUNITE(I)
  Next I
Endif
TIT = mess(43,195,1)
Return

$VERF_PUOMPOI
nolign=SAVNOLIGN
If VALEUR<>UNITE
  [M:POI1]BPSNUM(nolign-1)=FOURN
  [M:POI1]UOM(nolign-1)= VALEUR
  Affzo [POI1]UOM(nolign-1)
  Call AM_UOM(VALEUR) From SUBPOI
Endif
Return

$FIN_PUOMPOI
If VALEUR<>FOURN
  VALEUR=FOURN
Endif
Affzo [POI1]QTYUOM(nolign-1),UOMPUUCOE(nolign-1),PUU(nolign-1),QTYPUU(nolign-1),
&           STU(nolign-1),QTYSTU(nolign-1)
Return


$CHARG_UNIT2
#--------------------------------------------------#
# CHARGEMENT DE LA LIGNE POUR SéLECTION DES UNITES #
#--------------------------------------------------#
If find(CODE,TABCODE) Return : Endif
#----- Contrôle si l'unité est également une unité de vente -----#
If SAUFLG=1
  Call CONTSAUIMP(CODE,REFART,[M]BPCORD,UNIVEN) From TRTVENCTL
  If UNIVEN="" Return : Endif
Endif
#----- Chargement de l'unité -----#
If [F:TUN]UOM<>CODE
   Read [TUN] TUN0=CODE : If fstat Raz [F:TUN] : Endif
Endif
Call GET_ATEXTRA ("TABUNIT","DESSHO",GLANGUE,[L]WTEXTE) From TRTX3TEX
TABUNITE(NBUNITE)=CODE+space$(GLONUOM+2-len(CODE))+[L]WTEXTE
TABCODE(NBUNITE)=CODE
NBUNITE+=1
Return


######################################################################
# SEMSCOLOC : Sélection emplacement sous-traitant       MBT 28/04/04 #
######################################################################
#-------------------------------------------------------------#
# Avant ouverture de la fenêtre de sélection des emplacements #
#-------------------------------------------------------------#
$SEL_SCOLOC
Local Char    WLOC(GLONEMP) : WLOC=VALEUR
Local Integer I
If !clalev([F:STC])  Local File STOLOC [STC] : Endif
Raz TEX, TEXTE
I=1
Filter [STC]Where LOCCAT=4
For [STC] With Nohint
  If I=1
    TEX(I)   =[F:STC]LOC
    TEXTE(I) =[F:STC]LOC+space$(GLONEMP+2-len([F:STC]LOC))
    TEXTE(I)+=[F:STC]LOCTYP+space$(GLONTLO+2-len([F:STC]LOCTYP))+mess([F:STC]OCPCOD,757,1)
    I+=1
  Elsif !find([F:STC]LOC,TEX(1..I-1))
    TEX(I)   =[F:STC]LOC
    TEXTE(I) =[F:STC]LOC+space$(GLONEMP+2-len([F:STC]LOC))
    TEXTE(I)+=[F:STC]LOCTYP+space$(GLONTLO+2-len([F:STC]LOCTYP))+mess([F:STC]OCPCOD,757,1)
    I+=1
  Endif
  If I>=dim(TEX)  Break : Endif
Next
Filter [STC]
NBTEX=I-1
TIT=mess(604,197,1)
Return

# Issue X3-86234 - 2018-06-05 by SR : Select a supplier for a Product
######################################################################
# SELBPSITM : Select a supplier for an product          SR 05/06/18  #
######################################################################
$SEL_SELBPSITM
Local Char    WBPSNUM(GLONBPS) : WBPSNUM=VALEUR
Local Char    WITMREF(GLONITM) : WITMREF=PARAM(1)

If clalev([F:ITP])=0 Local File ITMBPS [ITP]     : Endif
If clalev([F:BPS])=0 Local File BPSUPPLIER [BPS] : Endif

Link [ITP] With [BPS]BPS0=[F:ITP]BPSNUM As [ITP1]
CRITERE = "BPSNUM>=WBPSNUM and ITMREF = WITMREF"
START  = "BPSNUM"
ORDRE  = "PIO;BPSNUM"
DEFPAG = 1 : # To be able to change page
TIT(0) = mess(5,195,1)
NBCOL =0
NBCOL += 1 : COL(NBCOL) = "BPSNUM"
Call TEXTFIC("ITMBPS","BPSNUM",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 :   COL(NBCOL) = "[F:BPS]BPSNAM"
COL(NBCOL) = "[F:BPS]BPSNAM"
Call TEXTFIC("BPSUPPLIER","BPSNAM",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "ITMREFBPS"
Call TEXTFIC("ITMBPS","ITMREFBPS",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "ITMDESBPS"
Call TEXTFIC("ITMBPS","ITMDESBPS",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "PIO"
Call TEXTFIC("ITMBPS","PIO",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess(CTMBPSFLG,1,1)"
Call TEXTFIC("ITMBPS","CTMBPSFLG",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess(DOUFLG,516,1)"
Call TEXTFIC("ITMBPS","DOUFLG",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "PURMINQTY"
Call TEXTFIC("ITMBPS","PURMINQTY",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "PUU"
Call TEXTFIC("ITMBPS","PUU",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "QLYMRK"
Call TEXTFIC("ITMBPS","QLYMRK",1,TIT(NBCOL)) From OBJDIV
Default File [ITP1]
Return
# End issue X3-86234

# Issue X3-86112 - 2018-06-15 by SR : Select a product for a supplier
######################################################################
# SELITP :  Select a product for a supplier             SR 15/06/18  #
# TABLE  = SELITP1 : [V]GITMFLG = 1                                  #
# TABLE  = SELITP2 : [V]GITMFLG = 2                                  #
######################################################################
$SEL_SELITP
Local Char     WBPSNUM(GLONBPS) : WBPSNUM=PARAM(1)
If clalev([F:ITP])<=0 Local File ITMBPS    [ITP] : Endif
If clalev([F:ITM])<=0 Local File ITMMASTER [ITM] : Endif
If clalev([F:AXX])=0 Local File ATEXTRA   [AXX] : Endif

If TABLE = "SELITP1"
  Link [ITP] With [ITM]ITM0=[F:ITP]ITMREF,
& [AXX]AXX0="ITMMASTER";"DES1AXX";GLANGUE;ITMREF;"" As [ITP1] Order By Key  ITP0
  CRITERE = "BPSNUM=WBPSNUM and ITMREF >= VALEUR"
  ORDRE  = "ITMREF"
  START  = "ITMREF"
  TIT(0) = mess(307,195,1)
Else
  Link [ITP] With [ITM]ITM0=[F:ITP]ITMREF,
& [AXX]AXX0="ITMMASTER";"DES1AXX";GLANGUE;ITMREF;"" As [ITP1] Order By Key  ITP2
  CRITERE = "BPSNUM=WBPSNUM and ITMREFBPS >= VALEUR"
  ORDRE  = "ITMREFBPS"
  START  = "ITMREFBPS"
  TIT(0) = mess(15,195,1)
Endif
DEFPAG = 1 : # To be able to change page
#------ Row level permission Filter -----#
Call AJOUTE_CONDITION_ROLE(CRITERE,ICRITERE,"ITM") From CRMUTIL150
NBCOL =0
If TABLE = "SELITP1"
  NBCOL += 1 : COL(NBCOL) = "ITMREF"
  Call TEXTFIC("ITMBPS","ITMREF",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1
  # translated designation or ITMDES1 if no traduction for the connecting language
  COL(NBCOL)="string$(1,[F:AXX]TEXTE)+string$(len([F:AXX]TEXTE)=0,[F:ITM]ITMDES1)"
  Call TEXTFIC("ITMMASTER","DES1AXX",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "ITMREFBPS"
  Call TEXTFIC("ITMBPS","ITMREFBPS",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "ITMDESBPS"
  Call TEXTFIC("ITMBPS","ITMDESBPS",1,TIT(NBCOL)) From OBJDIV
Else
  NBCOL += 1 : COL(NBCOL) = "ITMREFBPS"
  Call TEXTFIC("ITMBPS","ITMREFBPS",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "ITMDESBPS"
  Call TEXTFIC("ITMBPS","ITMDESBPS",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "ITMREF"
  Call TEXTFIC("ITMBPS","ITMREF",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 :
  # translated designation or ITMDES1 if no traduction for the connecting language
  COL(NBCOL)="string$(1,[F:AXX]TEXTE)+string$(len([F:AXX]TEXTE)=0,[F:ITM]ITMDES1)"
  Call TEXTFIC("ITMMASTER","DES1AXX",1,TIT(NBCOL)) From OBJDIV
Endif
NBCOL += 1 : COL(NBCOL) = "PURMINQTY"
Call TEXTFIC("ITMBPS","PURMINQTY",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "PUU"
Call TEXTFIC("ITMBPS","PUU",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "QLYMRK"
Call TEXTFIC("ITMBPS","QLYMRK",1,TIT(NBCOL)) From OBJDIV
Default File [ITP1]
Return

$FIN_SELITP
VALEUR = [F:ITM]ITMREF
Return
# End issue X3-86112

# Issue X3-86269 - 2018-06-18 by SR : Select a product for a supplier
######################################################################
# SELITMBPS :  Select a product for a supplier          SR 85/06/18  #
######################################################################
$SEL_SELITMBPS
Local Char     WBPSNUM(GLONBPS) : WBPSNUM=PARAM(1)
Local Char     TYP(3)           : TYP=PARAM(2)
If clalev([F:ITP])<=0 Local File ITMBPS     [ITP] : Endif
If clalev([F:BPS])<=0 Local File BPSUPPLIER [BPS] : Endif
If clalev([F:ITM])<=0 Local File ITMMASTER  [ITM] : Endif
If clalev([F:AXX])<=0 Local File ATEXTRA    [AXX] : Endif

Link [ITP] With [ITM]ITM0=[F:ITP]ITMREF,
& [BPS]BPS0=[F:ITP]BPSNUM,
& [AXX]AXX0="ITMMASTER";"DES1AXX";GLANGUE;ITMREF;"" As [ITP1] Order By Key  ITP1
If TYP = "BPS"
  CRITERE = "ITMREF >= VALEUR"
Else
  CRITERE = "ITMREFBPS >= VALEUR"
Endif
If WBPSNUM <> ""
  CRITERE -= "& BPSNUM = WBPSNUM"
Endif
# if screen is PCRITORD & current field is product-supplier and Product field not empty
If dim([M:PCO1]WITMREF)>0 & [M:PCO1]WITMREF <> "" & TYP = "ITP"
  CRITERE -= "& ITMREF = [M:PCO1]WITMREF"
Endif
ORDRE  = "ITMREF;PIO;BPSNUM"
START  = "ITMREF"
DEFPAG = 1 : # To be able to change page
NBCOL =0
# Selcetion of a product
If TYP = "BPS"
  TIT(0) =mess(307,195,1)
  NBCOL += 1 : COL(NBCOL) = "ITMREF"
  Call TEXTFIC("ITMBPS","ITMREF",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1
  # translated designation or ITMDES1 if no traduction for the connecting language
  COL(NBCOL)="string$(1,[F:AXX]TEXTE)+string$(len([F:AXX]TEXTE)=0,[F:ITM]ITMDES1)"
  Call TEXTFIC("ITMMASTER","DES1AXX",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "ITMREFBPS"
  Call TEXTFIC("ITMBPS","ITMREFBPS",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "ITMDESBPS"
  Call TEXTFIC("ITMBPS","ITMDESBPS",1,TIT(NBCOL)) From OBJDIV
# Selection of a Product-Supplier
Else
  TIT(0) =mess(15,195,1)
  NBCOL += 1 : COL(NBCOL) = "ITMREFBPS"
  Call TEXTFIC("ITMBPS","ITMREFBPS",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "ITMDESBPS"
  Call TEXTFIC("ITMBPS","ITMDESBPS",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "ITMREF"
  Call TEXTFIC("ITMBPS","ITMREF",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 :
  # translated designation or ITMDES1 if no traduction for the connecting language
  COL(NBCOL)="string$(1,[F:AXX]TEXTE)+string$(len([F:AXX]TEXTE)=0,[F:ITM]ITMDES1)"
  Call TEXTFIC("ITMMASTER","DES1AXX",1,TIT(NBCOL)) From OBJDIV
Endif
# if supplier empty
If WBPSNUM =""
  NBCOL += 1 : COL(NBCOL) = "BPSNUM"
  Call TEXTFIC("ITMBPS","BPSNUM",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 :   COL(NBCOL) = "[F:BPS]BPSNAM"
  Call TEXTFIC("BPSUPPLIER","BPSNAM",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "PIO"
  Call TEXTFIC("ITMBPS","PIO",1,TIT(NBCOL)) From OBJDIV
Endif
NBCOL += 1 : COL(NBCOL) = "PURMINQTY"
Call TEXTFIC("ITMBPS","PURMINQTY",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "PUU"
Call TEXTFIC("ITMBPS","PUU",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "QLYMRK"
Call TEXTFIC("ITMBPS","QLYMRK",1,TIT(NBCOL)) From OBJDIV
Default File [ITP1]
Return

$FIN_SELITMBPS
If TYP="BPS"
   VALEUR=[F:ITP]ITMREF
Else
   VALEUR=[F:ITP]ITMREFBPS
Endif
If WBPSNUM=""
   PARAM(1)=[F:ITP]BPSNUM
Endif
Return
# End issue X3-86269



######################################################################
# SELPPHW :  Select a product for a supplier          SR 85/06/18  #
######################################################################
$SEL_SELPPHW
  #----- Variables locales -----#
  Local Integer  WTYP             : WTYP=val(PARAM(1))
  Local Char     WBPSNUM(GLONBPS) : WBPSNUM=PARAM(2)
  Local Char     WITMREF(GLONITM) : WITMREF=PARAM(3)
  Local Shortint WNOLIGN          : WNOLIGN=val(PARAM(4))
  Local Char     WABMSK(4)        : WABMSK=PARAM(5)
  # Issue 71069 - 2013-08-21 by MUARN : PJT
  Local    Char  WABMSKH (04)     : WABMSKH = PARAM(6)
  Local Integer  SAVNOLIGN        : SAVNOLIGN=nolign
  Local Char     CRITERE(50), WCRITERE(50), PPDFILTRE(50)
  Local Integer  I, WI
  Local Char     WSECTION(GLONCCE)
  If clalev([F:PPH])<=0 Local File PRESP     [PPH] : Endif
  If clalev([F:PPD])<=0 Local File PRESPD    [PPD] : Endif
  If clalev([F:PQD])<=0 Local File PQUOTATD  [PQD] : Endif
  If clalev([F:CAL])<=0 Local File CPTANALIN [CAL] : Endif
  If clalev([F:ITM])<=0 Local File ITMMASTER [ITM] : Endif
  If clalev([F:BPR])<=0 Local File BPARTNER  [BPR] : Endif

  If clalev([F:AXX])<=0 Local File ATEXTRA    [AXX] : Endif

  Local Char    WQRY_BPSNUM(GLONBPR)(1..)
  Local Char    WQRY_ITMREF(GLONITM)(1..)
  Local Char    WQRY_ITMDES(GLONDES)(1..)
  Local Char    WQRY_ITMREFBPS(20)(1..)
  Local Char    WQRY_ITMDESBPS(GLONDES)(1..)
  Local Char    WQRY_PQHNUM(50)(1..)
  Local Integer WQRY_PPDLIN(1..)
  Local Date    WQRY_PLISTRDAT(1..)
  Local Date    WQRY_PLIENDDAT(1..)
  Local Char    WQRY_PUU(3)(1..)
  Local Decimal WQRY_MINQTY(1..)
  Local Decimal WQRY_MAXQTY(1..)
  Local Decimal WQRY_PRI(1..)
  Local Char    WQRY_CUR(3)(1..)
  Local Char    WQRY_PQDPJT(GLONPJT)(1..)
  Local Integer WQRY_PQDLIN(1..)

  TIT=mess(20,195,1)

  #---------------------------------#
  # Après l'ouverture de la fenêtre #
  #---------------------------------#
  #----- Droits d'accès au site en fonction des habilitations -----#
  If GUSRFCY<>"\" & GNBAUZ<>GNBSITE
    WCRITERE="find(PQHFCY,GUSRFCY(1..GNBAUZ))<>0"
  Else
    WCRITERE="1=1"
  Endif
  #----- Filtre suivant article-fournisseur suivant la clé art-four -----#
  If WITMREF="" & WBPSNUM=""
    Filter [PPH] Where evalue(WCRITERE) Order By Key PPH1
  Elsif WITMREF=""
    Filter [PPH] Where BPSNUM=WBPSNUM & evalue(WCRITERE) Order By Key PPH2
  Elsif WBPSNUM=""
    Filter [PPH] Where ITMREF=WITMREF & evalue(WCRITERE) Order By Key PPH1
  Else
    Filter [PPH] Where BPSNUM=WBPSNUM & ITMREF=WITMREF & evalue(WCRITERE)
& Order By Key PPH2
  Endif
  #----- Charger le tableau -----#
  WI = 0
  For [PPH]
    If [F:PQD]PQHNUM <> [F:PPH]PQHNUM | [F:PQD]PQDLIN <> [F:PPH]PQDLIN
      Read [PQD]PQD0 = [F:PPH]PQHNUM;[F:PPH]PQDLIN
      If fstat Raz [F:PQD] : Endif
    Endif
    #----- Lecture article si n'existe pas pas de sélection -----#
    # Issue 71069 - 2013-08-21 by MUARN : PJT
    # # Si Multi affaire ou Si (pas de PJT à l'entête et 1ere ligne) ou  PJT de l'appel d'offre=PJT à l'entête
    If GPJTSNGDOC = 1 |
&   ((evalue("[M:"+WABMSKH+"]PJTH") = "" & evalue("[M:"+WABMSK+"]NBLIG") <1) | [F:PQD]PQDPJT =evalue("[M:"+WABMSKH+"]PJTH"))
      Read [ITM] ITM0=[F:PPH]ITMREF
      Raz GBIDI1
      #----- En inter-site si la catégorie de la commande de vente est positionné
      If WTYP=2 & [M:POH0]BETFCY=2
         If[M:POH0]SOHCAT=1 & [F:ITM]RCPFLG<>2
           GBIDI1=1
         Elsif [M:POH0]SOHCAT=3 & [F:ITM]RCPFLG=2
           GBIDI1=1
         Endif
      Endif
      PPDFILTRE=""
      GPOINT="PPDFILTRE" : Gosub ENTREE From EXEFNC
      If PPDFILTRE="" PPDFILTRE="1=1" : Endif
      #-----
      If parse(PPDFILTRE)
        Call ERREUR("Filter error PPDFILTRE") From GESECRAN : PPDFILTRE="1=1"
      Endif
      #-----
      If !fstat & GBIDI1=0
        Filter [PPD] Where BPSNUM=[F:PPH]BPSNUM
&                        & PQHNUM=[F:PPH]PQHNUM
&                        & ITMREF=[F:PPH]ITMREF
&                        & PQDLIN=[F:PPH]PQDLIN
&                        & evalue(PPDFILTRE)
        For [PPD]
          WI = WI + 1
          WQRY_BPSNUM(WI)    = [F:PPH]BPSNUM
          WQRY_ITMREF(WI)    = [F:PPH]ITMREF
          WQRY_ITMDES(WI)    = [F:PQD]ITMDES
          WQRY_ITMREFBPS(WI) = [F:PPH]ITMREFBPS
          WQRY_ITMDESBPS(WI) = [F:PPH]ITMDESBPS
          WQRY_PQHNUM(WI)    = [F:PPH]PQHNUM
          WQRY_PPDLIN(WI)    = [F:PPD]PPDLIN
          WQRY_PLISTRDAT(WI) = [F:PPD]PLISTRDAT
          WQRY_PLIENDDAT(WI) = [F:PPD]PLIENDDAT
          WQRY_PUU(WI)       = [F:PPD]PUU
          WQRY_MINQTY(WI)    = [F:PPD]MINQTY
          WQRY_MAXQTY(WI)    = [F:PPD]MAXQTY
          If [F:PPD]PRIDIV<>0 : WQRY_PRI(WI) = [F:PPD]PRI/[F:PPD]PRIDIV : Endif
          WQRY_CUR(WI)       = [F:PPD]CUR
          WQRY_PQDPJT(WI)    = [F:PQD]PQDPJT
          WQRY_PQDLIN(WI)    = [F:PPH]PQDLIN
        Next
      Endif
    Endif
  Next

  Filter [PPH] : Filter [PPD]
  If WI = 0
    GMESSAGE=mess(26,194,1) : GERR=2 : FIN=1 : Return
  Endif

  Local File
& (
& Char    BPSNUM(GLONBPR),
& Char    ITMREF(GLONITM),
& Char    ITMDES(GLONDES),
& Char    ITMREFBPS(20),
& Char    ITMDESBPS(GLONDES),
& Char    PQHNUM(50),
& Integer PPDLIN,
& Date    PLISTRDAT,
& Date    PLIENDDAT,
& Char    PUU(3),
& Decimal MINQTY,
& Decimal MAXQTY,
& Decimal PRI,
& Char    CUR(3),
& Char    PQDPJT(GLONPJT),
& Integer PQDLIN
& )
&  From Variable
& WQRY_BPSNUM,
& WQRY_ITMREF,
& WQRY_ITMDES,
& WQRY_ITMREFBPS,
& WQRY_ITMDESBPS,
& WQRY_PQHNUM,
& WQRY_PPDLIN,
& WQRY_PLISTRDAT,
& WQRY_PLIENDDAT,
& WQRY_PUU,
& WQRY_MINQTY,
& WQRY_MAXQTY,
& WQRY_PRI,
& WQRY_CUR,
& WQRY_PQDPJT,
& WQRY_PQDLIN
& As [PPH1]

  CRITERE = "1=1"
  ORDRE   = "BPSNUM;ITMREF;PQHNUM"
  START   = "ITMREF"
  DEFPAG  = 1 # To be able to change page
  NBCOL   = 0

  NBCOL += 1 : COL(NBCOL) = "ITMREF"
  Call TEXTFIC("PRESP","ITMREF",1,TIT(NBCOL)) From OBJDIV
  # translated designation or ITMDES if no traduction for the connecting language
  NBCOL += 1 : COL(NBCOL) = "ITMDES"
  Call TEXTFIC("PQUOTATD","ITMDES",2,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "ITMREFBPS"
  Call TEXTFIC("PRESP","ITMREFBPS",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "ITMDESBPS"
  Call TEXTFIC("PRESP","ITMDESBPS",3,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "PQHNUM"
  Call TEXTFIC("PRESP","PQHNUM",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "PPDLIN"
  Call TEXTFIC("PRESPD","PPDLIN",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "PLISTRDAT"
  Call TEXTFIC("PRESPD","PLISTRDAT",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "PLIENDDAT"
  Call TEXTFIC("PRESPD","PLIENDDAT",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "PUU"
  Call TEXTFIC("PRESPD","PUU",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "MINQTY"
  Call TEXTFIC("PRESPD","MINQTY",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "MAXQTY"
  Call TEXTFIC("PRESPD","MAXQTY",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "PRI"
  Call TEXTFIC("PRESPD","PRI",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "CUR"
  Call TEXTFIC("PRESPD","CUR",1,TIT(NBCOL)) From OBJDIV
  NBCOL += 1 : COL(NBCOL) = "PQDPJT"
  Call TEXTFIC("PQUOTATD","PQDPJT",1,TIT(NBCOL)) From OBJDIV

  Default File [PPH1]
Return

$VERF_SELPPHW
  Local Char SWMESS(80),WZONE  # Issue 71069 - 2013-08-21 by MUARN : PJT
  Read [PQD] PQD0=[PPH1]PQHNUM;[PPH1]PQDLIN
  If !fstat
    # Issue 71069 - 2013-08-21 by MUARN : PJT
    # Si première ligne & pas de code affaire à l'entête on alimente le code affaire à l'entête
    If evalue("[M:"+WABMSK+"]NBLIG") <1 & evalue("[M:"+WABMSKH+"]PJTH")= "" & GPJTSNGDOC = 2
       Assign  "[M:"+WABMSKH+"]PJTH" With [F:PQD]PQDPJT
       WZONE = "[M:"+WABMSKH+"]PJTH"
       If func TRTPJT.IS_PJT_AVAILABLE([F:PQD]PQDPJT,WZONE, SWMESS) = G_NON Then
        Call PJT_ADD_MSG([F:PQD]PQDPJT, SWMESS) From TRTPJT
        GERR = 1
        OK = 0
        Return
      Endif
    Else
      WZONE = "[M:"+WABMSK+"]PJT"
      If func TRTPJT.IS_PJT_AVAILABLE([F:PQD]PQDPJT,WZONE, SWMESS) = G_NON Then
        Call PJT_ADD_MSG([F:PQD]PQDPJT, SWMESS) From TRTPJT
        GERR = 1
        OK = 0
        Return
      Endif
    Endif
    Assign "[M:"+WABMSK+"]PJT (WNOLIGN)" With [F:PQD]PQDPJT
    # FIN Issue 71069 - 2013-08-21 by MUARN

    WBPSNUM=[PPH1]BPSNUM
    WITMREF=[PPH1]ITMREF
    Assign "[M:"+WABMSK+"]PQHNUM(WNOLIGN)" With [PPH1]PQHNUM
    Assign "[M:"+WABMSK+"]PPDLIN(WNOLIGN)" With [PPH1]PPDLIN
    If WTYP=1
      #---------------------------------------------------------------------------#
      # Point d'entrée CHXPQHQTY : Choix de la qté de l'appel d'offre à récupérer #
      # ------------------------------------------------------------------------- #
      # QTYFLG : Indicateur quantité à prendre en compte                          #
      #            0 = Qté maxi de la réponse d'appel d'offre [F:PPD]MAXQTY       #
      #            1 = Qté mini de la réponse d'appel d'offre [F:PPD]MINQTY       #
      #            2 = Qté de la demande d'appel d'offre [F:PQD]QTYPUU            #
      # WTYP   : Type de document en cours de traitement                          #
      #            1 = Demande d'achat                                            #
      #            2 = Commande d'achat                                           #
      #---------------------------------------------------------------------------#
      Local Decimal WQTY
      Local Char    WUNITE(GLONUOM)
      Local Libelle QTYFLG : QTYFLG=0
      Gosub POINT_CHXPQHQTY From TRTACHSEL1
      Case QTYFLG
        When 1
          WQTY  =[PPH1]MAXQTY
          WUNITE=[PPH1]PUU
        When 2
          WQTY  =[F:PQD]QTYPUU
          WUNITE=[F:PQD]PUU
        When Default
          WQTY  =[PPH1]MAXQTY
          WUNITE=[PPH1]PUU
      Endcase
      #----- Si demande d'achat -----#
      Assign "[M:"+WABMSK+"]ITMDES (WNOLIGN)" With [F:PQD]ITMDES
      Assign "[M:"+WABMSK+"]ITMDES1(WNOLIGN)" With [F:PQD]ITMDES1
      Assign "[M:"+WABMSK+"]QTYPUU (WNOLIGN)" With WQTY
      Assign "[M:"+WABMSK+"]PUU(WNOLIGN)"     With WUNITE
      Assign "[M:"+WABMSK+"]CUR(WNOLIGN)"     With [PPH1]CUR
      Assign "[M:"+WABMSK+"]PJT(WNOLIGN)"     With [F:PQD]PQDPJT
      #----- Reprise des comptes et sections analytique de l'appel d'offre -----#
      Call CHARG_ACCCCE(WNOLIGN,"","","[M:"+WABMSK+"]CCE",
&                     "PQD",0,[F:PQD]PQHNUM,[F:PQD]PQDLIN,0,"") From TRTX3CPT
      #----- Initialisation si sections analytiques vides -----#
      If GNBDIE>0
        For I=1 To GNBDIE
          If evalue("[M:"+WABMSK+"]CCE"+num$(I)+"(WNOLIGN)")=""
            Call INIT_CCE(WSECTION,I,"PSD","",WNOLIGN) From TRTX3CPT
            Assign "[M:"+WABMSK+"]CCE"+num$(I)+"(WNOLIGN)" With WSECTION
          Endif
        Next I
      Endif
      #----- Calcul du prix net -----#
      Read [BPS] BPS0=[PPH1]BPSNUM
      If !fstat
        Local Decimal NET
        If [F:BPS]PLISTC<>""
          Local Decimal MAJREM(0..8)
          For I=0 To 8
            If evalue("dim([F:PPD]DISCRGVAL"+num$(I+1)+")")>0
              MAJREM(I)=evalue("[F:PPD]DISCRGVAL"+num$(I+1))
            Endif
          Next I
          If dim(GCALNETLIN)>0  GCALNETLIN=nolign     : Endif
          If dim(GCALNETABR)>0  GCALNETABR="[M:PPHW]" : Endif
          Call CALNET(2,[F:BPS]PLISTC,[PPH1]PRI ,MAJREM,
&                   [PPH1]MAXQTY,NET,[PPH1]CUR) From TRTPRICE
        Endif
        If evalue("dim([M:"+WABMSK+"]NETPRI(WNOLIGN))")>=0
          Assign "[M:"+WABMSK+"]NETPRI(WNOLIGN)" With NET
        Endif
      Endif
    Else
      #----- Si commande il faut charger [F:PPD] et [F:PPH] -----#
      Read [PPD]PPD0=[PPH1]BPSNUM;[PPH1]PQHNUM;
&                  [PPH1]PQDLIN;[PPH1]PPDLIN
      If fstat  Raz [F:PPD] : Endif
      Read [PPH] PPH0=[PPH1]BPSNUM;[PPH1]PQHNUM;[PPH1]PQDLIN
      If fstat  Raz [F:PPH] : Endif
      #----- Reprise des comptes et sections analytique de l'appel d'offre -----#
      Call CHARG_ACCCCE(WNOLIGN,"","","[M:"+WABMSK+"]CCE",
&                     "PQD",0,[F:PQD]PQHNUM,[F:PQD]PQDLIN,0,"") From TRTX3CPT
      #----- Initialisation si sections analytiques vides -----#
      If GNBDIE>0
        For I=1 To GNBDIE
          If evalue("[M:"+WABMSK+"]CCE"+num$(I)+"(WNOLIGN)")=""
            Call INIT_CCE(WSECTION,I,"POP","",WNOLIGN) From TRTX3CPT
            Assign "[M:"+WABMSK+"]CCE"+num$(I)+"(WNOLIGN)" With WSECTION
          Endif
        Next I
      Endif
      #-----
      VALEUR=WITMREF : PARAM(3)=WITMREF
      If VALEUR<>"" mkstat=99 : Endif
    Endif
  Endif
Return

$FIN_SELPPHW
  # Issue 71069 - 2013-08-21 by MUARN : PJT
  Call PJT_INFO_MSG() From TRTPJT
  # SR Tester WTYP
  If WTYP = 2
    Affzo [POH1]PJTH
  Endif
  #----- On relit article de la sélection ou du départ -----#
  If WITMREF<>"" & WITMREF<>[F:ITM]ITMREF
    Read [ITM] ITM0=WITMREF : If fstat  Raz [F:ITM] : Endif
  Endif
Return
# End # Issue X3-94369 - 2018-07-09 by RBA

##########################################################
# Appel du point d'entrée CHXPQHQTY depuis :             #
#     - le traitement SUBPOH  (Gestion des commandes)    #
#     - le traitement TRTACHSEL1 (Traitement sélections) #
##########################################################
$POINT_CHXPQHQTY
GPOINT="CHXPQHQTY" : Gosub ENTREE From EXEFNC
Return

