##########################################################################
# Action SELITM : Sélection des articles avec filtres et options         #
# ---------------------------------------------------------------------- #
#   zone courante AZC  : Référence article                  MBT 06/12/00 #
#   PARAM(1) = FILTRE  : Critères pour le filtre                         #
#   PARAM(2) = OPTIONA : Options de l'objet ITM                          #
##########################################################################
#---------------------------------------------------------#
# Avant ouverture de la fenêtre de sélection des articles #
#---------------------------------------------------------#
$SEL_SELITM
If PARAM(1)="" PARAM(1)="1=1" : Endif
CRITERE(1)=PARAM(1)
OPTIONS=PARAM(2)
# Issue 116028 - 2016-04-25 by SR :
GPOINT = "CUSITMFLT" : Gosub ENTREE From EXEFNC
OBJET="ITM"
Return


########################################################################
# SEL_ITMREFW : Sélection article   action e-commerce                  #
#                                                          HN 19/09/00 #
# Article actif et non fabriqué et non sous-traité et non fantôme      #
########################################################################
# Issue X3-65722 - 2018-03-05 by SR : Section revue pour optimisation du remplissage de CRITERE
# Et Exploitation des rôles
$SEL_ITMREFW
Local Char WCRITERE(240)
Raz CRITERE,ICRITERE
If clalev([M:PTH1])>0 & [F:POQ]ITMREF<>""
  #-- Si on a déjà sélectionner une ligne pas de sélection
  OK=0 : mkstat=1 : Return
Endif
If clalev([F:ATZ])=0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] : Endif
If clalev ([F:AXX])=0 : Local File ATEXTRA  [AXX]  : Endif  # FGR 07/06/2009 : X3SUIVI56380

Local Char CODFIC(GLONATB) : CODFIC = "ITMMASTER"

Link [ITM] With [AXX]AXX0="ITMMASTER";"DES1AXX";GLANGUE;ITMREF;"" As [NEW] # FGR 07/06/2009 : X3SUIVI56380
#Default File [ITM]
Default File [NEW]                                                  # FGR 07/06/2009 : X3SUIVI56380
If clalev([M:PSH0])>0 & GPLNFLT=2
   WCRITERE = 'SCSFLG<>2 & PHAFLG<>2 & ITMSTA=1'
   WCRITERE+=' & (PLANNER="'+[M:PSH0]REQUSR+'"| [F:ITM]PLANNER="")'
Elsif clalev([M:PSH0])>0 & GPLNFLT=3
   WCRITERE = 'SCSFLG<>2 & PHAFLG<>2 & ITMSTA=1'
   WCRITERE+=' & PLANNER="'+[M:PSH0]REQUSR+'"'
Elsif clalev([M:PQH1]) & GPQHBUY=2 & GBUYFLT=2
   WCRITERE = 'PHAFLG<>2 & ITMSTA=1'
   WCRITERE+=' & (STOMGTCOD>1 | BUY="" | BUY=[M:PQH1]REQUSR)'
Elsif clalev([M:PQH1])
   WCRITERE = 'PHAFLG<>2 & ITMSTA=1'
Else
   WCRITERE = 'SCSFLG<>2 & PHAFLG<>2 & ITMSTA=1'
Endif
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
#-----
# Issue 78449 - 2011-12-06 by VPO : dans module achat, les articles doivent être achetés
WCRITERE='PURFLG=2'
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB

#-----
Call AJOUTE_CONDITION_ROLE(CRITERE,ICRITERE,"ITM") From CRMUTIL150
#-----
START  = "ITMREF"
ORDRE  = "ITMREF"   # FQ 56558
TIT(0) = mess(12,123,1)
# Issue 111299  - 2015-09-25 by MUARN : ajout objet pour sélection, et code d'accès
# les colonnes viennent directement de l'objet
#NBCOL  = 0
#NBCOL += 1 : COL(NBCOL) = "ITMREF"    : Gosub TEXTE
##NBCOL += 1 : COL(NBCOL) = "ITMDES1"   : Gosub TEXTE
##NBCOL += 1 : COL(NBCOL) = "DES1AXX"   : Gosub TEXTE : COL(NBCOL)="[F:AXX]TEXTE"  # FGR 07/06/2009 : X3SUIVI56380
#NBCOL += 1 : COL(NBCOL) = "DES1AXX"   : Gosub TEXTE : COL(NBCOL)="string$(1,[F:AXX]TEXTE)+string$(len([F:AXX]TEXTE)=0,[F:ITM]ITMDES1)"  # FGR 29/09/2009 : X3SUIVI57887
#COLTYP(NBCOL) = 30  # FGR 01/02/2010  X3SUIVI62036
#NBCOL += 1 : COL(NBCOL) = "PURFLG"    : Gosub TEXTE : COL(NBCOL)="mess(PURFLG,1,1)"
#NBCOL += 1 : COL(NBCOL) = "SEAKEY"    : Gosub TEXTE
#NBCOL += 1 : COL(NBCOL) = "ITMSTA"    : Gosub TEXTE : COL(NBCOL)="mess(ITMSTA,246,1)"

CRITCAR="ITMREF>='"+VALEUR+"'"
DEFPAG=1 : # Pour pouvoir paginer la fenêtre de sélection

# Issue 111299  - 2015-09-25 by MUARN : ajout objet pour sélection, et code d'accès
OBJET="ITM"

Return

#########################################################################
# SEL_LIGPOQ : Sélection lignes de commandes dans les réceptions        #
#                                                           HN 28/11/00 #
#########################################################################
# Issue X3-65722 - 2018-03-05 by SR : Section revue pour optimisation du remplissage de CRITERE
$SEL_LIGPOQ
Local Shortint NOL           : NOL=nolign-1
Local Char     WNUM(GLONVCR) : WNUM=PARAM(1)
Local Char WCRITERE(240)
Raz CRITERE,ICRITERE
#----------------------------------------------------------------#
# Ne pas ouvrir de fenetre de sélection si séquence déja choisie #
#----------------------------------------------------------------#
If [M:PTH1]POHNUM(NOL)= [F:POQ]POHNUM & [M:PTH1]POPLIN(NOL)=[F:POQ]POPLIN &
& [M:PTH1]POQSEQ<>0 & [M:PTH1]POQSEQ(NOL)=[F:POQ]POQSEQ & [M:PTH1]POPLIN(NOL)<>0
  OK=0 : Return
Endif
If [F:POH]POHTYP<>2 & [F:POQ]POPLIN<>0 & [F:POQ]POPLIN=[M:PTH1]POPLIN(NOL)
  OK=0 : Return
Endif
If clalev([F:ATZ])=0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:POQ])=0 : Local File PORDERQ   [POQ] : Endif
Local Char CODFIC(GLONATB) : CODFIC = "PORDERQ"
WCRITERE ='POHNUM=WNUM & PRHFCY=[M:PTH0]PRHFCY & LINCLEFLG <> 2'
WCRITERE+=' & ORI <> 2 & WIPSTA <2'
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
If num$([M:PTH1]POPLIN(NOL)) <> "0" & [F:POH]POHTYP = 2
  WCRITERE='POPLIN = [M:PTH1]POPLIN(NOL)'
  Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Endif
START="POPLIN"
TIT(0) =mess(36,198,1)
NBCOL =0
NBCOL += 1 : COL(NBCOL) = "POHNUM"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "POPLIN"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "POQSEQ"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "ITMREF"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "QTYPUU"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "RCPQTYPUU" : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "PUU"       : Gosub TEXTE
Default File [POQ]
Return
#-----------------------------------------------------------------------#
$VERF_LIGPOQ
Read [POQ]POQ0 = [F:POQ]POHNUM;[F:POQ]POPLIN;[F:POQ]POQSEQ
If fstat
  Raz [F:POQ] : mkstat=1 : GERR=1
Else
  #----- Contrôle période comptable si article non géré en stock -----#
  If [F:ITM]ITMREF<>[F:POQ]ITMREF
    Read [ITM]ITM0=[F:POQ]ITMREF : If fstat  Raz [F:ITM] : Endif
  Endif
  If [F:ITF]ITMREF<>[F:POQ]ITMREF | [F:ITF]STOFCY<>[F:POQ]PRHFCY
    Read [ITF] ITF0=[F:POQ]ITMREF;[F:POQ]PRHFCY
    If fstat  Raz [F:ITF] : [F:ITF]STOMGTCOD=[F:ITM]STOMGTCOD : Endif
  Endif
  If [F:ITF]STOMGTCOD<2
    Call CTLPER([M:PTH0]PRHFCY,[M:PTH0]RCPDAT) From TRTACHCTL1
    If mkstat  GERR=1 : Return : Endif
  Endif
  #-----
  VALEUR=[F:POQ]POPLIN
  [M:PTH1]POPLIN(NOL)=[F:POQ]POPLIN
  [M:PTH1]POQSEQ(NOL)=[F:POQ]POQSEQ
  [M:PTH1]ITMREF(NOL)=[F:POQ]ITMREF
  Affzo [PTH1]POPLIN(NOL), ITMREF(NOL)
  nolign=NOL+1
  Gosub DIVPTHLIG From SUBPTHB
  Default File [POQ] : # Cassé par le CHARG_COMPTE_NAT appelé depuis le CHARG_LIG_PTH
  If mkstat = 2 : Raz VALEUR,[M:PTH1]ITMREF(NOL),[M:PTH1]POQSEQ(NOL) : Endif
Endif
Return

#########################################################################
$TEXTE
Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
Return

#########################################################################
# SEL_ITMPOQ : Sélection lignes de commandes dans les réceptions        #
#              en ayant saisie la réf art                               #
#                                                           HN 30/11/01 #
#########################################################################
# Issue X3-65722 - 2018-03-05 by SR : Section revue pour optimisation du remplissage de CRITERE
$SEL_ITMPOQ
Raz GBIDI3
Local Shortint NOL           : NOL=nolign-1
Local Char     WNUM(GLONVCR) : WNUM=PARAM(1)
Local Char WCRITERE(240)
Raz CRITERE,ICRITERE
If [M:PTH1]POHNUM(NOL)=""  OK=0 : Return : Endif
#-- Si les zones sont renseignées on dégage
If [F:POH]POHTYP<>2 & [M:PTH1]POPLIN(NOL)<>0 : OK=0 : Return : Endif
If [F:POH]POHTYP=2  & [M:PTH1]POPLIN(NOL)<>0 & [M:PTH1]POQSEQ(NOL)<>0
  OK=0 : Return
Endif
#------------------------------------------------------------#
# Ne pas ouvrir de fenetre de sélection s'il n'y en a qu'une #
#------------------------------------------------------------#
If VALEUR <>""
  For [POQ] POQ0 Where POHNUM=WNUM & PRHFCY=[M:PTH0]PRHFCY & ITMREF=VALEUR
&                    & ORI<>2 & WIPSTA<2 & LINCLEFLG<>2
    I+ = 1
  Next
Else
  For [POQ] POQ0 Where POHNUM=WNUM & PRHFCY=[M:PTH0]PRHFCY
&                    & ORI<>2 & WIPSTA<2 & LINCLEFLG<>2
    I+ = 1
  Next
Endif
# Pas trouvé
If I = 0 GERR=1 : GMESSAGE =mess (23,100,1)+" / "+mess(104,194,1)
 mkstat = 2 : FIN = 1 : Return
Endif
# Trouvé un seul
If I=1
  Gosub VERF_ITMPOQ
  FIN = 1 : Return
Endif
If clalev([F:ATZ])=0 : Local File ATABZON   [ATZ] : Endif
If clalev([F:POQ])=0 : Local File PORDERQ   [POQ] : Endif
Local Char CODFIC(GLONATB) : CODFIC = "PORDERQ"
WCRITERE ='POHNUM=WNUM & PRHFCY=[M:PTH0]PRHFCY'
WCRITERE+=' & ORI <> 2 & WIPSTA <2 & LINCLEFLG <> 2'
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
If VALEUR <> ""
  WCRITERE='ITMREF = VALEUR'
  Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Endif
START="ITMREF"
TIT(0) =mess(36,198,1)
NBCOL =0
NBCOL += 1 : COL(NBCOL) = "POHNUM"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "ITMREF"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "POPLIN"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "POQSEQ"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "QTYPUU"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "RCPQTYPUU" : Gosub TEXTE
NBCOL += 1 : COL(NBCOL) = "PUU"       : Gosub TEXTE
Default File [POQ]
Return
#-----------------------------------------------------------------------#
$VERF_ITMPOQ
Raz GBIDI1
Read [POQ] POQ0 = [F:POQ]POHNUM;[F:POQ]POPLIN;[F:POQ]POQSEQ
If fstat Raz [F:POQ] : mkstat=1 : GERR =1
Else
  VALEUR=[F:POQ]ITMREF : [M:PTH1]ITMREF(NOL)=[F:POQ]ITMREF
  [M:PTH1]POQSEQ(NOL)=[F:POQ]POQSEQ
  [M:PTH1]POPLIN(NOL)=[F:POQ]POPLIN : Affzo [PTH1]POPLIN(NOL)
  [M:PTH1]ITMREF(NOL)=[F:POQ]ITMREF : Affzo [PTH1]ITMREF(NOL)
  nolign=NOL+1
  Gosub DIVPTHLIG From SUBPTHB
  If mkstat = 2 : Raz VALEUR,[M:PTH1]POPLIN(NOL),[M:PTH1]POQSEQ(NOL) : Endif
Endif
Return


###############################################################################
# Action SELPOQITM : Sélection standard lignes de commandes à réceptionner    #
#                    Cette sélection est générique, elle peut donc être       #
#                    utilisée par un autre écran que celui des réceptions     #
#                    C'est le cas des écrans VT par exemple.                  #
# --------------------------------------------------------------------------- #
#   zone courante  AZC  : Référence article       ITMREF  (E-S)  MBT 08/02/06 #
#   PARAM(1) = STOFCY   : Site de réception       PRHFCY  (E-S)               #
#   PARAM(2) = BPSNUM   : Fournisseur             BPSNUM  (E-S)               #
#   PARAM(3) = NUM      : Numéro de commande      POHNUM  (E-S)               #
#   PARAM(4) = LIN      : No ligne commande       POPLIN  (S)                 #
#   PARAM(5) = SEQ      : Séquence ligne commande POQSEQ  (S)                 #
#                                                                             #
# Nota : Paramètres renseignés en entrée (E) et/ou en sortie (S)              #
###############################################################################
# Issue X3-65722 - 2018-03-05 by SR : Section revue pour optimisation du remplissage de CRITERE
#-------------------------------------------------------------------#
# Avant ouverture de la fenêtre de sélection des lignes de commande #
#-------------------------------------------------------------------#
$SEL_SELPOQITM
Local Char    WPRHFCY(GLONFCY) : WPRHFCY=PARAM(1)
Local Char    WBPSNUM(GLONBPS) : WBPSNUM=PARAM(2)
Local Char    WPOHNUM(GLONPOH) : WPOHNUM=PARAM(3)
Local Integer WPOPLIN
Local Integer WPOQSEQ
Local Char    CODFIC(GLONATB)  : CODFIC="PORDERQ"
Local Char    WCRITERE(240)
Raz CRITERE,ICRITERE
#-----
If !clalev([F:ATZ])  Local File ATABZON   [ATZ]  : Endif
If !clalev([F:POQ2]) Local File PORDERQ   [POQ2] : Endif
Link [POQ2] With [ITM] ITM0=[POQ2]ITMREF As [POQX]
Default File [POQX]
#-----
If WPOHNUM<>""
  WCRITERE="[F:POQ2]POHNUM=WPOHNUM"
Endif
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
If WPRHFCY<>""
    WCRITERE="[F:POQ2]PRHFCY=WPRHFCY"
    Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Endif
If WBPSNUM<>""
  WCRITERE="[F:POQ2]BPSNUM=WBPSNUM"
  Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Endif
If VALEUR<>""
  WCRITERE="pat([F:POQ2]ITMREF,VALEUR+'*')"
  Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Endif
# Issue 112754 - 2016-11-29 by SR : Services
#CRITERE(1)-="& [F:POQ2]ORI<>2 & [F:POQ2]WIPSTA<2 & [F:POQ2]LINCLEFLG<>2"
#CRITERE(2) ="& [F:ITM]ITMSTA=1 & [F:ITM]SCSFLG <> 2 & [F:ITM]PHAFLG <> 2 & [F:ITM]RCPFLG=2"
WCRITERE="[F:POQ2]ORI<>2 & [F:POQ2]WIPSTA<2 & [F:POQ2]LINCLEFLG<>2 & [F:POQ2]ITMKND<>2"
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
WCRITERE="[F:ITM]ITMSTA=1 & [F:ITM]PHAFLG <> 2 & [F:ITM]RCPFLG=2"
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
# End issue 112754
# Issue 95491 - 2014-01-31 by SR : Pas de sous-traitance
If GFONCTION = "VXAPR"
  WCRITERE="[F:POQ2]LINTYP=1"
  Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Endif
# End issue 95491

#-----
START="ITMREF"
TIT(0) =mess(351,198,1)
NBCOL =0
NBCOL += 1 : COL(NBCOL)="ITMREF"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="POHNUM"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="POPLIN"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="POQSEQ"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="QTYPUU"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="RCPQTYPUU" : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="PUU"       : Gosub TEXTE
Return
#-------------------------------#
# Après sélection dans la table #
#-------------------------------#
$VERF_SELPOQITM
WPOHNUM=[F:POQ2]POHNUM
WPOPLIN=[F:POQ2]POPLIN
WPOQSEQ=[F:POQ2]POQSEQ

Read [POQ] POQ0=WPOHNUM;WPOPLIN;WPOQSEQ
If fstat
  Raz [F:POQ]
Else
#                                                   # hcb 71276 deb
  If GFONCTION = "VXAPR"
     If [F:ITM]ECCSTO > 1 & [F:POQ]ECCVALMAJ = ""
         Local File ITMBPS [ITP1]
         Read [ITP1]ITP0=[F:ITM]ITMREF;[F:POQ]BPSNUM
         If fstat
            Raz [F:ITP1]
         Endif
         If [F:ITM]LOAECCFLG <> 2 & [F:ITP1]LOAECCFLG <> 2
            mkstat = 2
            GMESSAGE = mess(429,184,1) #  En VT un aticle géré en version sans préchargement est interdit !
            Return
         Endif
     Endif
  Endif
#                                                   # hcb 71276 fin
  VALEUR  =[F:POQ]ITMREF
  PARAM(1)=[F:POQ]PRHFCY
  PARAM(2)=[F:POQ]BPSNUM
  PARAM(3)=[F:POQ]POHNUM
  PARAM(4)=num$([F:POQ]POPLIN)
  PARAM(5)=num$([F:POQ]POQSEQ)
Endif
Return


###############################################################################
# Action SELPOQPOP : Sélection standard lignes d'une commande pour un article #
#                    Cette sélection est générique, elle peut donc être       #
#                    utilisée par un autre écran que celui des réceptions     #
#                    C'est le cas des écrans VT par exemple.                  #
# --------------------------------------------------------------------------- #
#   zone courante  AZCI : No ligne commande       POPLIN  (E-S)  MBT 20/03/07 #
#   PARAM(1) = NUM      : Numéro de commande      POHNUM  (E)                 #
#   PARAM(2) = ITMREF   : Référence article       ITMREF  (E)                 #
#   PARAM(3) = SEQ      : Séquence ligne commande POQSEQ  (S)                 #
#                                                                             #
# Nota : Paramètres renseignés en entrée (E) et/ou en sortie (S)              #
###############################################################################
# Issue X3-65722 - 2018-03-05 by SR : Section revue pour optimisation du remplissage de CRITERE
#-------------------------------------------------------------------#
# Avant ouverture de la fenêtre de sélection des lignes de commande #
#-------------------------------------------------------------------#
$SEL_SELPOQPOP
Local Char    WPOHNUM(GLONPOH) : WPOHNUM=PARAM(1)
Local Char    WITMREF(GLONITM) : WITMREF=PARAM(2)
Local Integer WPOPLIN
Local Integer WPOQSEQ
Local Char    CODFIC(GLONATB)  : CODFIC="PORDERQ"
Local Char    WCRITERE(240)
Raz CRITERE,ICRITERE
#-----
If !clalev([F:ATZ])  Local File ATABZON   [ATZ] : Endif
If !clalev([F:POQ])  Local File PORDERQ   [POQ] : Endif
#-----
WCRITERE ="POHNUM=WPOHNUM & ITMREF=WITMREF"
WCRITERE-="& ORI<>2 & WIPSTA<2 & LINCLEFLG<>2"
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB

#-----
START="POPLIN"
TIT(0) =mess(33,7750,1)
NBCOL =0
If !GVTMOD
  NBCOL+=1 : COL(NBCOL)="POHNUM"    : Gosub TEXTE
Endif
NBCOL += 1 : COL(NBCOL)="POPLIN"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="ITMREF"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="QTYPUU"    : Gosub TEXTE
NBCOL += 1 : COL(NBCOL)="RCPQTYPUU" : Gosub TEXTE
If !GVTMOD
  NBCOL+=1 : COL(NBCOL)="PUU"       : Gosub TEXTE
Endif
NBCOL += 1 : COL(NBCOL)="EXTRCPDAT" : Gosub TEXTE
Default File [POQ]
Return
#-------------------------------#
# Après sélection dans la table #
#-------------------------------#
$VERF_SELPOQPOP
WPOPLIN=[F:POQ]POPLIN
WPOQSEQ=[F:POQ]POQSEQ
Read [POQ] POQ0=WPOHNUM;WPOPLIN;WPOQSEQ
If fstat
  Raz [F:POQ]
Else
  VALEUR  =[F:POQ]POPLIN
  PARAM(3)=num$([F:POQ]POQSEQ)
Endif
Return


###############################################################################
# Action SELSCOADD : Sélection adresses sous-traitant avec filtres et options #
# --------------------------------------------------------------------------- #
#   zone courante  AZC  : Code adresse S/T                       MBT 19/03/04 #
#   PARAM(1) = BPSNUM   : Fournisseur (Client livré)                          #
#   PARAM(2) = FILTRE   : Critères pour le filtre                             #
#   PARAM(3) = OPTIONA  : Options de l'objet BPD                              #
###############################################################################
# Issue X3-65722 - 2018-03-05 by SR : Section revue pour optimisation du remplissage de CRITERE
# Et Exploitation des rôles
#------------------------------------------------------------------------#
# Avant ouverture de la fenêtre de sélection des adresses clients livrés #
#------------------------------------------------------------------------#
$SEL_SCOADD
Local Char    WCRITERE(240)
Raz CRITERE,ICRITERE
If PARAM(2)=""  PARAM(2)="1=1" : Endif
If !clalev([F:ATZ])  Local File ATABZON  [ATZ] : Endif
START="BPAADD"
ORDRE="BPAADD"
# Issue X3-95319 - 2018-06-29 by MUARN : ajout que les adresses actives
WCRITERE=PARAM(2)-"& BPCNUM=PARAM(1) & ENAFLG=2"
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
#-----
Call AJOUTE_CONDITION_ROLE(CRITERE,ICRITERE,"BPD") From CRMUTIL150
#-----
OPTIONS=PARAM(3)
OBJET=""
TIT(0) = mess(10,195,1)
NBCOL  = 0
NBCOL += 1 : COL(NBCOL) = "BPCNUM"
Call TEXTFIC("BPDLVCUST","BPCNUM",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "BPAADD"
Call TEXTFIC("BPDLVCUST","BPAADD",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "BPDNAM"
Call TEXTFIC("BPDLVCUST","BPDNAM",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "SCOLOC"
Call TEXTFIC("BPDLVCUST","SCOLOC",1,TIT(NBCOL)) From OBJDIV
Default File [BPD]
Return
#-------------------------------#
# Après sélection dans la table #
#-------------------------------#
$VERF_SCOADD
VALEUR=[F:BPD]BPAADD
Return

###############################################################################
# Action SELFCYADD : Sélection adresses d'un site avec filtres et options     #
# --------------------------------------------------------------------------- #
#   zone courante  AZC  : Code adresse S/T                      GA 26/02/2007 #
#   PARAM(1) = FCY      : Site                                                #
#   PARAM(2) = FILTRE   : Critères pour le filtre                             #
#   PARAM(3) = OPTIONA  : Options ?                                           #
###############################################################################
# Issue X3-65722 - 2018-03-05 by SR : Section revue pour optimisation du remplissage de CRITERE
#------------------------------------------------------------------------#
# Avant ouverture de la fenêtre de sélection des adresses d'un site      #
#------------------------------------------------------------------------#
$SEL_FCYADD
Local Char    WCRITERE(240)
Raz CRITERE,ICRITERE
If !clalev([F:ATZ])  Local File ATABZON  [ATZ] : Endif
START="BPAADD"
ORDRE="BPAADD"
If PARAM(2)=""
   WCRITERE="BPATYP=3 & BPANUM=PARAM(1)"
Else
   WCRITERE=PARAM(2)-"& BPATYP=3 & BPANUM=PARAM(1)"
Endif
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
#-----
OPTIONS=PARAM(3)
OBJET=""
TIT(0) = mess(291,195,1) : # Adresses du site
NBCOL  = 0
NBCOL += 1 : COL(NBCOL) = "BPANUM"
Call TEXTFIC("BPADDRESS","BPANUM",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "BPAADD"
Call TEXTFIC("BPADDRESS","BPAADD",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "BPADES"
Call TEXTFIC("BPADDRESS","BPADES",1,TIT(NBCOL)) From OBJDIV
Default File [BPA]
Return
#-------------------------------#
# Après sélection dans la table #
#-------------------------------#
$VERF_FCYADD
VALEUR=[F:BPA]BPAADD
Return



###############################################################################
# Action SELBPSITM1 : Sélection des fournisseurs d'un article avec filtre 1   #
# Action SELBPSITM2 : Sélection des fournisseurs d'un article avec filtre 2   #
# --------------------------------------------------------------------------- #
#   zone courante  AZC  : Code fournisseur                       MBT 18/01/06 #
#   PARAM(1) = ITMREF   : Référence article                                   #
#   PARAM(2) = FILTRE1 ou FILTRE2 : Critères pour le filtre                   #
###############################################################################
# Issue X3-65722 - 2018-03-05 by SR : Section revue pour optimisation du remplissage de CRITERE
# Et Exploitation des rôles
#-------------------------------------------------------------#
# Avant ouverture de la fenêtre de sélection des fournisseurs #
#-------------------------------------------------------------#
$SEL_BPSITM2
Local Char    WCRITERE(240)
Raz CRITERE,ICRITERE
If PARAM(2)=""  PARAM(2)="1=1" : Endif
If !clalev([F:ATZ])  Local File ATABZON  [ATZ] : Endif
# Issue X3-86266 - 2018-06-15 by MUARN : Add columns
If clalev([F:BPS])=0 Local File BPSUPPLIER [BPS] : Endif
Link [ITP] With [BPS]BPS0=[F:ITP]BPSNUM As [ITP1]
# End issue X3-86266

START="BPSNUM"
# Issue 81848 - 2012-05-21 by SR
#ORDRE="BPSNUM"
ORDRE="PIO;BPSNUM"
WCRITERE =PARAM(2)-"& ITMREF= PARAM(1)"
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
#-----
Call AJOUTE_CONDITION_ROLE(CRITERE,ICRITERE,"BPS") From CRMUTIL150
#-----
OPTIONS=""
OBJET=""
If instr(1,PARAM(2),"CTMBPSFLG=2")
  TIT(0) = mess(253,195,1)
Else
  TIT(0) = mess(251,195,1)-PARAM(1)
Endif
# Issue X3-86266 - 2018-06-18 by MUARN : Add columns, replace ITP by ITP1
Default File [ITP1]
NBCOL  = 0
NBCOL += 1 : COL(NBCOL) = "BPSNUM"
Call TEXTFIC("ITMBPS","BPSNUM",1,TIT(NBCOL)) From OBJDIV
# Issue X3-86266 - 2018-06-15 by MUARN : Add columns
NBCOL += 1
Call TEXTFIC("BPSUPPLIER","BPSNAM",1,TIT(NBCOL)) From OBJDIV
COL(NBCOL) = "[F:BPS]BPSNAM"
# End issue X3-86266
NBCOL += 1 : COL(NBCOL) = "ITMREFBPS"
Call TEXTFIC("ITMBPS","ITMREFBPS",1,TIT(NBCOL)) From OBJDIV
# Issue X3-86266 - 2018-06-15 by MUARN : Add columns
NBCOL += 1 : COL(NBCOL) = "ITMDESBPS"
Call TEXTFIC("ITMBPS","ITMDESBPS",1,TIT(NBCOL)) From OBJDIV
# End issue X3-86266
NBCOL += 1 : COL(NBCOL) = "PIO"
Call TEXTFIC("ITMBPS","PIO",1,TIT(NBCOL)) From OBJDIV
# Issue X3-86266 - 2018-06-15 by MUARN : Add columns
NBCOL += 1 : COL(NBCOL) = "mess(CTMBPSFLG,1,1)"
Call TEXTFIC("ITMBPS","CTMBPSFLG",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "mess(DOUFLG,516,1)"
Call TEXTFIC("ITMBPS","DOUFLG",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "PURMINQTY"
Call TEXTFIC("ITMBPS","PURMINQTY",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "PUU"
Call TEXTFIC("ITMBPS","PUU",1,TIT(NBCOL)) From OBJDIV
# End issue X3-86266
NBCOL += 1 : COL(NBCOL) = "QLYMRK"
Call TEXTFIC("ITMBPS","QLYMRK",1,TIT(NBCOL)) From OBJDIV
# Issue X3-86266 - 2018-06-15 by MUARN : Modify columns
#NBCOL += 1 : COL(NBCOL) = "mess(DOUFLG,516,1)"
#Call TEXTFIC("ITMBPS","DOUFLG",1,TIT(NBCOL)) From OBJDIV
#NBCOL += 1 : COL(NBCOL) = "mess(CTMBPSFLG,1,1)"
#Call TEXTFIC("ITMBPS","CTMBPSFLG",1,TIT(NBCOL)) From OBJDIV
# End issue X3-86266

Return
#-------------------------------#
# Après sélection dans la table #
#-------------------------------#
$VERF_BPSITM2
VALEUR=[F:ITP]BPSNUM
Return


