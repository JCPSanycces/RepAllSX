#<AdxTL>@(#)11.0.0.0 $Revision$
###########################################################################
# TRTACHSEL1            TRAITEMENTS DE SELECTION             MODULE ACHAT #
# ----------------------------------------------------------------------- #
# ACTIONS SUR CHAMPS                                                      #
#   - S_PRHFCY   : Sélection site réception et même société juridique     #
#                                                                         #
# SOUS-PROGRAMMES DIVERS                                                  #
#   - SEL_LIG    : Fenêtre sélection des lignes qtés sur cdes ouvertes    #
# ----------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Saisie de fenêtre GSAISIE)                    #
# Issue X3-86234/X3-86112/X3-86269                                        #
# replaced by actions "SEL_TABLE"                                         #
#   - SELBPSITM  : Fenêtre sélection des fournisseurs d'un article        #
#   - SELITMBPS  : Fenêtre sélection des articles d'un fournisseur        #
#   - SELITP1    : Fenêtre sélection article/fournisseur par réf. interne #
#   - SELITP2    : Fenêtre sélection article/fournisseur par réf. fourn.  #
#   - SELPPHW    : Fenêtre sélection des appels d'offre                   #
#                                                                         #
# ACTIONS modélisation WEB (Sélection dans une table GACTION)             #
#   - SELPPC     : Sélection des codes  tarifs avec filtres et options    #
#   - SELPPL     : Sélection des fiches tarifs avec filtres et options    #
#   - SELPFI     : Sélection des éléments fact avec filtres et options    #
#   - SELITM     : Sélection des articles avec filtres et options         #
#   - SELPITMREF : Sélection de la référence article                      #
#   - SELPRHFCY  : Sélection du site de réception                         #
#   - SELSHIFCY  : Sélection du site d'expédition                         #
#   - SELPITMFCY : Sélection du site de l'article                         #
#   - SELPTHPOH  : Sélection des cdes depuis le masque critère réception  #
#   - SELLCCPOH  : Sélection des cdes depuis le masque critère LCC        #
#   - SELPTHSDH  : Sélection des livraisons depuis le masque réception    #
#   - SELPNHPOH  : Sélection des commandes depuis la gestion des retours  #
#   - SELPNHPTH  : Sélection des réceptions depuis la gestion des retours #
#   - SELPNHPTD  : Sélection des lignes de réceptions depuis les retours  #
#   - SELFCY     : Sélection des sites avec filtres et options            #
#   - SELTPV     : Sélection des types de facture avec filtres et options #
#   - SELITMFCY  : Sélection des article-sites avec filtres et options    #
#   - SELPIH     : Sélection des factures avec filtres et options         #
#   - SELPOD     : Sélection ligne contrat-article avec filtres & options #
#   - SELPOCLIN  : Sélection ligne article-contrat avec filtres & options #
#   - SELITMFAC  : Sélection des lignes article à facturer                #
#   - SELLIGPOQ  : Sélection de la ligne de commande a réceptionner       #
#   - SELITMPOQ  : Sélection de la ligne de commande a réceptionner (ART) #
#   - SELPOQITM  : Sélection STD ligne de commande à réceptionner (ART)   #
#   - SELPOQPOP  : Sélection STD ligne de commande à réceptionner (POPLIN)#
#   - SELSCOADD  : Sélection adresses sous-traitants (clients livrés)     #
#   - SELFCYADD  : Sélection adresses d'un site (GA 02/2007)              #
#   - SELBPSITM1 : sélection des fournisseurs d'un article avec filtre 1  #
#   - SELBPSITM2 : sélection des fournisseurs d'un article avec filtre 2  #
#   - SELPIHFACC : Sélection des factures pour factures complémentaires   #
#   - SELPTHFACC : Sélection des réceptions pour factures complémentaires #
#   - SELPOHFACC : Sélection des commandes  pour factures complémentaires #
#   - SELSHHFACC : Sélection des expéditions pour factures complémentaires #
#   - SELTRPFACC : Sélection des transports pour factures complémentaires #
#   - SELSHHRCP  : Sélection des expéditions pour réception               #
# Issue X3-86234 - 2018-06-05 by SR : New action type                     #
#   - SELBPSITM  : Supplier selection for a product                       #
# ACTIONS modélisation WEB (Sélection dans une liste GACTION)             #
#   - SELPUOM    : Sélection des unités                                   #
#   - SELPUOMPOI : Sélection des unités en AM_BPSNUM                      #
#   - SELSCOLOC  : Sélection emplacement sous-traitant                    #
###########################################################################
$ACTION
Case ACTION
 When "SEL_TABLE"
  #--------------------------------------------#
  # Avant ouverture de la fenêtre de sélection #
  #--------------------------------------------#
  Case TABLE
   When "SELPPC"     : Gosub SEL_SELPPC
   When "SELPPL"     : Gosub SEL_SELPPL
   When "SELPFI"     : Gosub SEL_SELPFI
   When "SELITM"     : Gosub SEL_SELITM
   When "SELPITMREF" : Gosub SEL_ITMREFW
   When "SELPRHFCY"  : Gosub SEL_PRHFCYW
   When "SELSHIFCY"  : Gosub SEL_SELSHIFCY
   When "SELPITMFCY" : Gosub SEL_ITMFCYW
   When "SELPTHPOH"  : Gosub SEL_PTHPOH
   When "SELLCCPOH"  : Gosub SEL_LCCPOH       : #MAE, LCC 04/2015
   When "SELPTHSDH"  : Gosub SEL_PTHSDH       : # GA 03/2006
   When "SELPNHPOH"  : Gosub SEL_PNHPOH
   When "SELPNHPTH"  : Gosub SEL_PNHPTH
   When "SELPNHPTD"  : Gosub SEL_PNHPTD
   When "SELFCY"     : Gosub SEL_SELFCY
   When "SELTPV"     : Gosub SEL_SELTPV
   When "SELITMFCY"  : Gosub SEL_SELITMFCY
   When "SELPIH"     : Gosub SEL_SELPIH
   When "SELPOD"     : Gosub SEL_SELPOD
   When "SELPOCLIN"  : Gosub SEL_SELPOCLIN
   When "SELITMFAC"  : Gosub SEL_SELITMFAC
   When "SELLIGPOQ"  : Gosub SEL_LIGPOQ
   When "SELITMPOQ"  : Gosub SEL_ITMPOQ
   When "SELPOQITM"  : Gosub SEL_SELPOQITM
   When "SELPOQPOP"  : Gosub SEL_SELPOQPOP
   When "SELSCOADD"  : Gosub SEL_SCOADD
   When "SELFCYADD"  : Gosub SEL_FCYADD       : # GA 02/2007
   When "SELBPSITM1" : Gosub SEL_BPSITM2
   When "SELBPSITM2" : Gosub SEL_BPSITM2
   When "SELPIHFACC" : Gosub SEL_SELPIHFACC
   When "SELPTHFACC" : Gosub SEL_SELPTHFACC
   When "SELPTHFACC" : Gosub SEL_SELPTHFACC : # Issue 82703 - 2012-10-04 by SR
   When "SELPOHFACC" : Gosub SEL_SELPOHFACC : # Issue 110325 - 2016-01-05 by SR : FCC sur expé
   When "SELSHHFACC" : Gosub SEL_SELSHHFACC
   When "SELTRPFACC" : Gosub SEL_SELTRPFACC
   When "SELSHHRCP"  : Gosub SEL_SELSHHRCP  : # Issue 110325 - 2016-09-12 by SR : US 120
   When "SELBPSITM"  : Gosub SEL_SELBPSITM  : # Issue X3-86234 - 2018-06-05 by SR
   When "SELITP1"    : Gosub SEL_SELITP     : # Issue X3-86112 - 2018-06-15 by SR
   When "SELITP2"    : Gosub SEL_SELITP     : # Issue X3-86112 - 2018-06-15 by SR
   When "SELITMBPS"  : Gosub SEL_SELITMBPS  : # Issue X3-86269 - 2018-06-18 by SR
   When "SELPPHW"    : Gosub SEL_SELPPHW    : # Issue X3-94369 - 2018-07-09 by RBA
  Endcase
 When "VERF_TABLE"
  #-------------------------------#
  # Après sélection dans la table #
  #-------------------------------#
  Case TABLE
   When "SELPRHFCY"  : Gosub VERF_PRHFCYW
   When "SELSHIFCY"  : Gosub VERF_SELSHIFCY
   When "SELPTHPOH"  : Gosub VERF_PTHPOH
   When "SELLCCPOH"  : Gosub VERF_LCCPOH       : #MAE, LCC 04/2015
   When "SELPTHSDH"  : Gosub VERF_PTHSDH       : # GA 03/2006
   When "SELPNHPTD"  : Gosub VERF_PNHPTD
   When "SELPOD"     : Gosub VERF_SELPOD
   When "SELITMFAC"  : Gosub VERF_SELITMFAC
   When "SELLIGPOQ"  : Gosub VERF_LIGPOQ
   When "SELITMPOQ"  : Gosub VERF_ITMPOQ
   When "SELPOQITM"  : Gosub VERF_SELPOQITM
   When "SELPOQPOP"  : Gosub VERF_SELPOQPOP
   When "SELSCOADD"  : Gosub VERF_SCOADD
   When "SELFCYADD"  : Gosub VERF_FCYADD
   When "SELBPSITM1" : Gosub VERF_BPSITM2
   When "SELBPSITM2" : Gosub VERF_BPSITM2
   When "SELPPHW"    : Gosub VERF_SELPPHW    : # Issue X3-94369 - 2018-07-09 by RBA
  Endcase
 When "FIN_TABLE"
  #------------------------#
  # Sortie de la sélection #
  #------------------------#
  Case TABLE
   When "SELITMFAC"  : Gosub FIN_SELITMFAC
   When "SELPIHFACC" : Gosub FIN_SELPIHFACC
   When "SELITP1"    : Gosub FIN_SELITP      : # Issue X3-86112 - 2018-06-15 by SR
   When "SELITP2"    : Gosub FIN_SELITP      : # Issue X3-86112 - 2018-06-15 by SR
   When "SELITMBPS"  : Gosub FIN_SELITMBPS   : # Issue X3-86269 - 2018-06-18 by SR
   When "SELPPHW"    : Gosub FIN_SELPPHW     : # Issue X3-94369 - 2018-07-09 by RBA
  Endcase
 When "SEL_LISTE"
  #--------------------------------------------#
  # Avant ouverture de la fenêtre de sélection #
  #--------------------------------------------#
  Case LISTE
   When "SELPUOM"    : Gosub SEL_PUOM
   When "SELPUOMPOI" : Gosub SEL_PUOMPOI
   When "SELSCOLOC"  : Gosub SEL_SCOLOC
  Endcase
 When "VERF_LISTE"
  Case LISTE
   When "SELPUOMPOI" : Gosub VERF_PUOMPOI
  Endcase
 When "FIN_LISTE"
  Case LISTE
   When "SELPUOMPOI" : Gosub FIN_PUOMPOI
  Endcase
Endcase
Return


#######################################################################
# SEL_PUOM :   Sélection de l'unité                 action e-commerce #
#                                                         HN 02/11/00 #
#   UNITE  : Unité sélectionnée (zc)                                  #
#   FOURN  : Numéro du fournisseur dont les unités sont à chercher    #
#   REFART : Référence de l'article dont les unités sont à chercher   #
#   INDFIC : Indicateur fichiers à traiter                            #
#            1 = Article (ITMMASTER)                                  #
#            2 = Article-fournisseur (ITMBPS)                         #
#            3 = Article + article-fournisseur (ITMMASTER+ITMBPS)     #
#   INDUNI : Indicateur unités à traiter                              #
#            1 = Unité d'achat (UA)                                   #
#            2 = Unité de conditionnement (UC)                        #
#            3 = Unité de stock (US)                                  #
#            4 = Unité d'achat + unité de conditionnement (UA+UC)     #
#            5 = Les trois unités (UA+UC+US)                          #
#            6 = Unité d'achat et de vente simultanément (UA=UV)      #
#                utilisé depuis les contrats avec zone [M]BPCORD      #
#                                              et zone [M]BETFCY      #
#######################################################################
#-------------------------------------------------------#
# Avant ouverture de la fenêtre de sélection des unités #
#-------------------------------------------------------#
$SEL_PUOM
Local Char    UNITE (GLONUOM) : UNITE = VALEUR
Local Char    FOURN (GLONBPS) : FOURN = PARAM(1)
Local Char    REFART(GLONITM) : REFART= PARAM(2)
Local Integer INDFIC          : INDFIC= val(PARAM(3))
Local Integer INDUNI          : INDUNI= val(PARAM(4))
Local Integer I


#----- Contrôle validité des indicateurs -----#
If INDFIC=0 | INDFIC>3 : OK=0 : Return : Endif
If INDUNI=0 | INDUNI>6 : OK=0 : Return : Endif
#----- Ouverture tables si nécessaire -----#
If clalev([F:AXX])=0 Local File ATEXTRA   [AXX] : Endif
If clalev([F:ITM])=0 Local File ITMMASTER [ITM] : Endif
#----- Lecture article si nécessaire -----#
If [F:ITM]ITMREF<>REFART
  Read [ITM] ITM0=REFART
  If fstat Raz [F:ITM] : Endif
Endif
#----- Variables locales -----#
Local    Char    TABUNITE(GLONUOM+12)(dim([F:ITM]PCU)+4)
Local    Char    TABCODE (GLONUOM)   (dim([F:ITM]PCU)+4)
Local    Char    CODE(GLONUOM), UNIVEN(GLONUOM)
Local    Char    WTEXTE(80)
Local    Integer NBUNITE, NO, INDUNITE, SAUFLG
INDUNITE=INDUNI
If INDUNI=6
  If GMODU(5)<>2 | dim([M]BPCORD)<=0 | dim([M]BETFCY)<=0
    INDUNITE=1 : SAUFLG=0
  Elsif [M]BETFCY<>2
    INDUNITE=1 : SAUFLG=0
  Else
    INDUNITE=1 : SAUFLG=1
  Endif
Else
  SAUFLG=0
Endif
#-- En inter-sites on autorise UA si UA=UV et les UC
If INDUNI=4
  If GMODU(5)<>2 | dim([M]BPCORD)<=0 | dim([M]BETFCY)<=0
    SAUFLG=0
  Elsif [M]BETFCY<>2
    SAUFLG=0
  Else
    SAUFLG=1
  Endif
Else
  SAUFLG=0
Endif
#----- Ouverture et lecture des fichiers si nécessaire -----#
If clalev([F:TUN])=0    Local File TABUNIT   [TUN] : Endif
If INDFIC=1 | INDFIC=3
  If clalev([F:ITM])=0 Local File ITMMASTER [ITM] : Endif
  If [F:ITM]ITMREF<>REFART
    Read [ITM] ITM0=REFART
    If fstat Raz [F:ITM] : Endif
  Endif
Endif
If INDFIC=2 | INDFIC=3
  If clalev([F:ITP])=0 Local File ITMBPS    [ITP] : Endif
  If [F:ITP]ITMREF<>REFART | [F:ITP]BPSNUM<>FOURN
    Read [ITP] ITP0=REFART;FOURN
    If fstat Raz [F:ITP] : Endif
  Endif
Endif
#----- Chargement de la table des unités -----#
If INDFIC=1 | INDFIC=3
  If (INDUNITE=1 | INDUNITE=4 | INDUNITE=5) & [F:ITM]PUU<>""
                           CODE=[F:ITM]PUU    : Gosub CHARG_UNIT : Endif
  If INDUNITE=2 | INDUNITE=4 | INDUNITE=5
    For I=0 To dim([F:ITM]PCU)-1
      If [F:ITM]PCU(I)<>"" CODE=[F:ITM]PCU(I) : Gosub CHARG_UNIT : Endif
    Next I
  Endif
  If (INDUNITE=3 | INDUNITE=5) & [F:ITM]STU<>""
                           CODE=[F:ITM]STU    : Gosub CHARG_UNIT : Endif
Endif
If INDFIC=2 | INDFIC=3
  If (INDUNITE=1 | INDUNITE=4 | INDUNITE=5) & [F:ITP]PUU<>""
                           CODE=[F:ITP]PUU    : Gosub CHARG_UNIT : Endif
  If (INDUNITE=2 | INDUNITE=4 | INDUNITE=5) & [F:ITP]PCU<>""
                           CODE=[F:ITP]PCU    : Gosub CHARG_UNIT : Endif
Endif
If NBUNITE >= 0
  For I=0 To NBUNITE-1
    NBTEX +=1
    TEX(NBTEX)   = TABCODE(I)
    TEXTE(NBTEX) = TABUNITE(I)
  Next I
Endif
TIT = mess(43,195,1)
Return

$CHARG_UNIT
#--------------------------------------------------#
# CHARGEMENT DE LA LIGNE POUR SéLECTION DES UNITéS #
#--------------------------------------------------#
If find(CODE,TABCODE) Return : Endif
#----- Contrôle si l'unité est également une unité de vente -----#
If SAUFLG=1
  Call CONTSAUIMP(CODE,REFART,[M]BPCORD,UNIVEN) From TRTVENCTL
  If UNIVEN="" Return : Endif
Endif
#----- Chargement de l'unité -----#
If [F:TUN]UOM<>CODE
   Read [TUN] TUN0=CODE : If fstat Raz [F:TUN] : Endif
Endif
Call GET_ATEXTRA ("TABUNIT","DESSHO",GLANGUE,[L]WTEXTE) From TRTX3TEX
TABUNITE(NBUNITE)=CODE+space$(GLONUOM+2-len(CODE))+[L]WTEXTE
TABCODE(NBUNITE)=CODE
NBUNITE+=1
Return

##########################################################################
# SEL_PTHPOH : Sélection commandes dans les réceptions action e-commerce #
#            dans la fenêtre de critère ou dans ecran PTH0   HN 27/11/00 #
##########################################################################
# Issue X3-65722 - 2018-03-05 by SR : Section revue pour optimisation du remplissage de CRITERE
$SEL_PTHPOH
Local Char WCRITERE(240)
Raz CRITERE,ICRITERE
# Issue 117070 - 2016-06-10 by SR :Si VT pas de filtre sur Intersite/Soc, ni fourn,on ne sait pas encore
If GVTMOD
  CRITERE(1)="1=1"
Else
  If clalev([M:PCO1])>0 & [M:PCO1]WBETFCY=2
    WCRITERE ="[F:POH2]BETFCY=2"
  Elsif [M:PTH0]BETFCY=2
    WCRITERE="[F:POH2]BETFCY=2"
  Else
    WCRITERE="[F:POH2]BETFCY<>2"
  Endif
  Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
  If clalev([M:PCO1])>0 & PARAM(1)<>""
    WCRITERE='pat([F:POH2]BPSNUM,"'+PARAM(1)+'")<>0'
    Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
  Elsif PARAM(1)<>""
    WCRITERE='[F:POH2]BPSNUM="'+PARAM(1)+'"'
    Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
  Endif
Endif
# End issue 117070
WCRITERE="[F:POH2]CLEFLG<>2 & [F:POH2]APPFLG>2 & [F:POH2]RCPFLG<3"
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
WCRITERE ='([F:POH2]RCPFCY=[M:PTH0]PRHFCY | [F:POH2]RCPFCY="") & [F:FCY]LEGCPY=GSOCIETE'
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Local File PORDER [POH2] : # Réouverture à cause du Link du tiroir de l'objet PTH
Link [POH2] With [FCY] FCY0=[F:POH2]POHFCY As [POHL]
Default File [POHL]
START="[F:POH2]POHNUM"
OBJET=""
TIT(0) = mess(62,195,1)
NBCOL  = 0
If !GVTMOD
  NBCOL+=1 : COL(NBCOL) = "[POH2]ORDDAT"
  Call TEXTFIC("PORDER","ORDDAT",1,TIT(NBCOL)) From OBJDIV
Endif
NBCOL += 1 : COL(NBCOL) = "[POH2]POHNUM"
Call TEXTFIC("PORDER","POHNUM",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[POH2]POHFCY"
Call TEXTFIC("PORDER","POHFCY",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[POH2]BPSNUM"
Call TEXTFIC("PORDER","BPSNUM",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[POH2]ORDREF"
Call TEXTFIC("PORDER","ORDREF",1,TIT(NBCOL)) From OBJDIV
DEFPAG=1 : # Pour pouvoir paginer la fenêtre de sélection
Return
#---------------------------------------------#
# La sélection de la commande a été effectuée #
#---------------------------------------------#
$VERF_PTHPOH
Read [POH] POH0=[F:POH2]POHNUM : If fstat  Raz [F:POH] : Endif
Return

#MAE, LCC 04/2015 deb
##########################################################################
# SEL_LCCPOH : Sélection commandes dans les landed cost : conteneurs et  #
#            expéditions dans la fenêtre de critère ou dans ecran ABREV  #
##########################################################################
# Issue X3-65722 - 2018-03-05 by SR : Section revue pour optimisation du remplissage de CRITERE
$SEL_LCCPOH
Local Char WABREV (10)
Local Char WCRITERE(240)
Raz CRITERE,ICRITERE
If PARAM(1)<>""
  WCRITERE='pat([F:POH2]BPSNUM,"'+PARAM(1)+'")<>0'
  Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Endif
WCRITERE="[F:POH2]CLEFLG<>2 & [F:POH2]APPFLG>2 & [F:POH2]RCPFLG<3"
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
WCRITERE='([F:POH2]RCPFCY="")'
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Local File PORDER [POH2] : # Réouverture à cause du Link du tiroir de l'objet PTH
Link [POH2] With [FCY] FCY0=[F:POH2]POHFCY As [POHL]
Default File [POHL]
START="[F:POH2]POHNUM"
OBJET=""
TIT(0) = mess(62,195,1)
NBCOL  = 0
If !GVTMOD
  NBCOL+=1 : COL(NBCOL) = "[POH2]ORDDAT"
  Call TEXTFIC("PORDER","ORDDAT",1,TIT(NBCOL)) From OBJDIV
Endif
NBCOL += 1 : COL(NBCOL) = "[POH2]POHNUM"
Call TEXTFIC("PORDER","POHNUM",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[POH2]POHFCY"
Call TEXTFIC("PORDER","POHFCY",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[POH2]BPSNUM"
Call TEXTFIC("PORDER","BPSNUM",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[POH2]ORDREF"
Call TEXTFIC("PORDER","ORDREF",1,TIT(NBCOL)) From OBJDIV
DEFPAG=1 : # Pour pouvoir paginer la fenêtre de sélection
Return
#---------------------------------------------#
# La sélection de la commande a été effectuée #
#---------------------------------------------#
$VERF_LCCPOH
Read [POH] POH0=[F:POH2]POHNUM : If fstat  Raz [F:POH] : Endif
Return
#MAE, LCC 04/2015 fin
###########################################################################
# SEL_PTHSDH : Sélection livraisons dans les réceptions action e-commerce #
#              GA 03/2006 idem SEL_PTHPOH                                 #
# SR : semble ne pas être utilisée                                        #
###########################################################################
# Issue X3-65722 - 2018-03-05 by SR : Section revue pour optimisation du remplissage de CRITERE
$SEL_PTHSDH
Local Char WCRITERE(240)
Raz CRITERE,ICRITERE
If clalev([M:PCO1])>0 & [M:PCO1]WBETFCY=2
  WCRITERE="[F:SDH2]BETFCY=2"
Elsif [M:PTH0]BETFCY=2
  WCRITERE="[F:SDH2]BETFCY=2"
Else
  WCRITERE="[F:SDH2]BETFCY<>2"
Endif
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
If clalev([M:PCO1])>0 & PARAM(1)<>""
  WCRITERE='pat([F:SDH2]BPSNUM,"'+PARAM(1)+'")<>0 & [F:SDH2]CLEFLG<>2 & [F:SDH2]APPFLG>2'
Elsif PARAM(1)<>""
  WCRITERE='[F:SDH2]BPSNUM="'+PARAM(1)+'" & [F:SDH2]APPFLG>2 & [F:SDH2]CLEFLG<2'
Else
  WCRITERE="[F:SDH2]CLEFLG<>2 & [F:SDH2]APPFLG>2"
Endif
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
WCRITERE='([F:SDH2]PRHFCY=[M:PTH0]PRHFCY | [F:SDH2]PRHFCY="") & [F:FCY]LEGCPY=GSOCIETE'
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Local File SDELIVERY[SDH2] : # Réouverture à cause du Link du tiroir de l'objet SDH
Link [SDH2] With [FCY] FCY0=[F:SDH2]STOFCY As [SDHL]
Default File [SDHL]
START="[F:SDH2]SDHNUM"
OBJET=""
TIT(0) = mess(375,198,1) : # Sélection livraisons
NBCOL  = 0
NBCOL += 1 : COL(NBCOL) = "[SDH2]SHIDAT"
Call TEXTFIC("SDELIVERY","SHIDAT",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[SDH2]SDHNUM"
Call TEXTFIC("SDELIVERY","SDHNUM",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[SDH2]PRHFCY"
Call TEXTFIC("SDELIVERY","PRHFCY",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[SDH2]BPSNUM"
Call TEXTFIC("SDELIVERY","BPSNUM",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[SDH2]STOFCY"
Call TEXTFIC("SDELIVERY","STOFCY",1,TIT(NBCOL)) From OBJDIV
DEFPAG=1 : # Pour pouvoir paginer la fenêtre de sélection
Return
#----------------------------------------------#
# La sélection de la livraison a été effectuée #
#----------------------------------------------#
$VERF_PTHSDH
Read [SDH] SDH0=[F:SDH2]SDHNUM : If fstat  Raz [F:SDH] : Endif
Return

########################################################################
# SEL_PNHPTH : Sélection réception dans les retours  action e-commerce #
#            dans la fenêtre de critère                    HN 20/10/00 #
########################################################################
# Issue X3-65722 - 2018-03-05 by SR : Section revue pour optimisation du remplissage de CRITERE
$SEL_PNHPTH
Local Char WCRITERE(240)
Raz CRITERE,ICRITERE
If clalev([M:PCR1])>0 & PARAM(1)<>""
  WCRITERE='pat([F:PTH]BPSNUM,"'+PARAM(1)+'")<>0'
Elsif PARAM(1)<>""
  WCRITERE='[F:PTH]BPSNUM="'+PARAM(1)+'"'
Endif
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
START="PTHNUM"
OBJET ="PTH"
OPTIONS="#"
Return

########################################################################
# SEL_PNHPTD : Sélection réception dans les retours  action e-commerce #
#            dans l'écran des retours                      HN 20/10/00 #
# -------------------------------------------------------------------- #
# PARAM(1) = Numéro de réception                                       #
# PARAM(2) = Code fournisseur  (n'est pas utilisé ?)                   #
# PARAM(3) = Référence article                                         #
# PARAM(4) = Ligne de réception                                        #
# PARAM(5) = Nom du champ                                              #
########################################################################
# Issue X3-65722 - 2018-03-05 by SR : Section revue pour optimisation du remplissage de CRITERE
# Et exploitation des rôles
$SEL_PNHPTD
Local Integer SAVNOLIGN : SAVNOLIGN=nolign
Local Char WCRITERE(240)
Raz CRITERE,ICRITERE
#-----
If clalev([F:PTH])=0  Local File PRECEIPT  [PTH] : Endif
If clalev([F:ATZ])=0  Local File ATABZON   [ATZ] : Endif
Local File PRECEIPTD [PTD2] : # Réouverture à cause du Link du tiroir de l'objet PNH
#-----
If PARAM(5)="PTHNUM"
  START  = '[F:PTD2]PTHNUM' : CRITOBJ='[F:PTD2]PTHNUM>="'+PARAM(1)+'"'
Else
  START  = '[F:PTD2]PTDLIN' : CRITOBJ='[F:PTD2]PTDLIN>='+PARAM(4)
Endif
TIT(0) = mess(8,31,1)
NBCOL  = 0
NBCOL += 1 : COL(NBCOL) = "[PTD2]PTHNUM"
Call TEXTFIC("PRECEIPTD","PTHNUM",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[PTD2]PTDLIN"
Call TEXTFIC("PRECEIPTD","PTDLIN",1,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[PTD2]ITMREF"
Call TEXTFIC("PRECEIPTD","ITMREF",1,TIT(NBCOL)) From OBJDIV
#----- Critères de sélection entêtes réception -----#
WCRITERE ="[F:FCY]LEGCPY=GSOCIETE"
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
If [M:PCRW]WBPSNUM<>""
  WCRITERE="pat([F:PTH]BPSNUM,[M:PCRW]WBPSNUM)<>0"
  Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Endif
If [M:PCRW]WBPSNDE<>""
  WCRITERE="pat([F:PTH]BPSNDE,[M:PCRW]WBPSNDE)<>0"
  Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Endif
If PARAM(5)<>"PTHNUM" & PARAM(1)<>""
  WCRITERE='[F:PTH]PTHNUM="'+PARAM(1)+'"'
  Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Endif
If GBUYFLT=2
   WCRITERE='([F:ITM]BUY=[M:PNH1]BUY | [F:ITM]BUY="")'
   Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Endif
#----- Critères de sélection lignes réception -----#
If GPRTNQTY <> 2
  WCRITERE ="PRHFCY=[M:PNH1]PNHFCY"
  Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
  WCRITERE="(([F:ITM]STOMGTCOD>1 & QTYSTU-RTNQTYSTU>0)"
  WCRITERE+=" | (RRRQTYPUU-RTNQTYPUU>0 | RRRQTYSTU-RTNQTYSTU>0))"
  Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Else
  WCRITERE ="PRHFCY=[M:PNH1]PNHFCY"
  Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
  WCRITERE="(QTYPUU-RTNQTYPUU> 0 | QTYSTU-RTNQTYSTU>0)"
  Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Endif
If [M:PCRW]WNUMCDE<>""
  WCRITERE="pat(POHNUM,[M:PCRW]WNUMCDE)<>0"
  Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Endif
If [M:PCRW]WITMREF<>""
  WCRITERE="pat(ITMREF,[M:PCRW]WITMREF)<>0"
  Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Endif
If [M:PCRW]WNUMRCP<>""
  WCRITERE="pat(PTHNUM,[M:PCRW]WNUMRCP)<>0"
  Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Endif
If [M:PCRW]WLOT   <>""
  WCRITERE="pat(LOT,[M:PCRW]WLOT)<>0"
  Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Endif
If PARAM(3) <>""
  WCRITERE='ITMREF="'+PARAM(3)+'"'
  Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Endif
#-----
Call AJOUTE_CONDITION_ROLE(CRITERE,ICRITERE,"PTH") From CRMUTIL150
#----- Définition des tables liées avec filtres pour alimentation picking -----#
Link [PTD2] With [PTH] PTH0=[PTD2]PTHNUM, [FCY] FCY0=[PTD2]PRHFCY,
&                [ITM] ITM0=[PTD2]ITMREF  As [PHD]
Default File [PHD]
DEFPAG=1 : # Pour pouvoir paginer la fenêtre de sélection
Return
#----------------------------------------------#
# La sélection de la réception a été effectuée #
#----------------------------------------------#
$VERF_PNHPTD
Read [PTH] PTH0=[F:PTD2]PTHNUM                : If fstat  Raz [F:PTH] : Endif
Read [PTD] PTD0=[F:PTD2]PTHNUM;[F:PTD2]PTDLIN : If fstat  Raz [F:PTD] : Endif
If PARAM(5)="PTHNUM"
  VALEUR=[F:PTD2]PTHNUM
  PARAM(1)=[F:PTD2]PTHNUM
  PARAM(4)=num$([F:PTD2]PTDLIN)
  nolign=SAVNOLIGN
  [M:PNH1]PTHNUM(nolign-1)=[F:PTD2]PTHNUM
  [M:PNH1]PTDLIN(nolign-1)=[F:PTD2]PTDLIN
  Local Decimal WVALEUR : WVALEUR=[F:PTD2]PTDLIN
  Call AM_PTDLIN(WVALEUR) From SUBPNH
  If mkstat
    Raz [M:PNH1]PTHNUM(nolign-1), [M:PNH1]PTDLIN(nolign-1), PARAM(1), PARAM(4)
  Endif
Else
  VALEUR=[F:PTD2]PTDLIN
  PARAM(1)=[F:PTD2]PTHNUM
  PARAM(4)=num$([F:PTD2]PTDLIN)
Endif
nolign=SAVNOLIGN
Return

########################################################################
# SEL_PNHPOH : Sélection commande dans les retours   action e-commerce #
#            dans la fenêtre de critère                    HN 20/10/00 #
########################################################################
# Issue X3-65722 - 2018-03-05 by SR : Section revue pour optimisation du remplissage de CRITERE
$SEL_PNHPOH
Local Char WCRITERE(240)
Raz CRITERE,ICRITERE
If clalev([F:POH])=0  Local File PORDER [POH] : Endif
WCRITERE="APPFLG>2"
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
If clalev([M:PCR1])>0 & PARAM(1)<>""
  WCRITERE='pat(BPSNUM,"'+PARAM(1)+'")'
  Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Elsif PARAM(1)<>""
  WCRITERE='[F:POH]BPSNUM="'+PARAM(1)+'"'
  Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Endif
OBJET ="POH"
Return

########################################################################
# SEL_ITMFCYW : Sélection site de l'article          action e-commerce #
#               en DA                                      HN 29/09/00 #
########################################################################
$SEL_ITMFCYW
START='STOFCY'
OBJET ="ITF"
CRITOBJ='[F:ITF]ITMREF = [M]ITMREF (nolign-1)'    # 36092 mm 05.06
Return

########################################################################
# SEL_PRHFCYW : Sélection site de réception          action e-commerce #
#                                                          HN 26/09/00 #
########################################################################
# Si on a plusieurs fichiers toujours préciser la classe               #
########################################################################
# Issue X3-65722 - 2018-03-05 by SR : Section revue pour optimisation du remplissage de CRITERE
# Et Exploitation des rôles
$SEL_PRHFCYW
Local Shortint WSTOMGTCOD : WSTOMGTCOD=val(PARAM(1))
Local Char WCRITERE(240)
Raz CRITERE,ICRITERE
If !clalev([F:ATZ])  Local File ATABZON  [ATZ] : Endif
#----------------------------------------------------#
# On filtre les sites sur même société juridique     #
# et sur site de stockage pour article géré en stock #
# pas de filtre sur dépot pour les autres            #
#----------------------------------------------------#
If !clalev ([F:ITM]) | WSTOMGTCOD=1
  WCRITERE='[F:FCY]LEGCPY=GSOCIETE'
Else
  WCRITERE ='[F:FCY]LEGCPY=GSOCIETE  & [F:FCY]WRHFLG=2'
Endif
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
#-----
START  = "[F:FCY]FCY" : CRITOBJ="[F:FCY]FCY>=[L]VALEUR"
TIT(0) = mess(183,195,1)
NBCOL  = 0
NBCOL += 1 : COL(NBCOL) = "[FCY]LEGCPY"
Call TEXTFIC("FACILITY","LEGCPY",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[FCY]FCY"
Call TEXTFIC("FACILITY","FCY"   ,3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[FCY]FCYNAM"
Call TEXTFIC("FACILITY","FCYNAM",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[FCY]FCYSHO"
Call TEXTFIC("FACILITY","FCYSHO",3,TIT(NBCOL)) From OBJDIV
# NBCOL += 1 : COL(NBCOL) = "[FCY]WRHFLG"
# Call TEXTFIC("FACILITY","WRHFLG",3,TIT(NBCOL)) From OBJDIV
#-----
Call AJOUTE_CONDITION_ROLE(CRITERE,ICRITERE,"FCY") From CRMUTIL150
#----- Si appel depuis les commandes classiques -----#
If dim([M:POH0]BETFCY)>0
  If [M:POH0]BETFCY=2 & [M:POH0]BPCORD<>"" & [M:POH0]SALFCY<>""
    Link [BPD] With [FCY] FCY0=[F:BPD]RCPFCY As [FBC]
&              Where [F:BPD]BPCNUM=[M:POH0]BPCORD & [F:BPD]RCPFCY<>""
    Default File [FBC]
  Else
    Default File [FCY]
  Endif
#----- Si appel depuis les commandes ouvertes -----#
Elsif dim([M:POC0]BETFCY)>0
  If [M:POC0]BETFCY=2 & [M:POC0]BPCORD<>"" & [M:POC0]SALFCY<>""
    Link [BPD] With [FCY] FCY0=[F:BPD]RCPFCY As [FBC]
&              Where [F:BPD]BPCNUM=[M:POC0]BPCORD & [F:BPD]RCPFCY<>""
    Default File [FBC]
  Else
    Default File [FCY]
  Endif
#----- Si appel depuis les demandes d'achat -----#
Elsif dim([M:PSH0]REQUSR)>0
  If GPLNFLT>1 & WSTOMGTCOD>1
    If [F:ITM]ITMREF<>[M:PSH1]ITMREF(nolign-1)
      Read [ITM] ITM0=[M:PSH1]ITMREF(nolign-1) : If fstat Raz [F:ITM] : Endif
    Endif
    NBCOL += 1 : COL(NBCOL) = "[ITF]PLANNER"
    Call TEXTFIC("ITMFACILIT","PLANNER",1,TIT(NBCOL)) From OBJDIV
    Local Char CRITLNK(110)
    CRITLNK="[F:ITF]ITMREF=[F:ITM]ITMREF & "
    If GPLNFLT=2
      CRITLNK+='([F:ITF]PLANNER=[M:PSH0]REQUSR | [F:ITF]PLANNER="")'
    Else
      CRITLNK+="[F:ITF]PLANNER=[M:PSH0]REQUSR"
    Endif
    CRITLNK+=" & [F:FCY]LEGCPY=GSOCIETE"
    Link [ITF] With [FCY] FCY0=[F:ITF]STOFCY As [ITY] Where evalue(CRITLNK)
    Default File [ITY]
  Else
    Default File [FCY]
  Endif
#----- Autres appels -----#
Else
  Default File [FCY]
Endif
Return
########################################################################
$VERF_PRHFCYW
Read [FCY] FCY0=[F:FCY]FCY : If fstat Raz [F:FCY] : Endif
Return


#####################################################################
# SEL_SELSHIFCY : Sélection site d'expédition (cde inter-sites)     #
# ----------------------------------------------------------------- #
#   zone courante AZC  : Site d'expédition             MBT 16/06/04 #
#   PARAM(1) = ITMREF  : Article                                    #
#   PARAM(2) = FILTRE  : Critères pour le filtre                    #
#####################################################################
#-------------------------------------------------------------------#
# Avant ouverture de la fenêtre de sélection des sites d'expédition #
#-------------------------------------------------------------------#
# Issue X3-65722 - 2018-03-05 by SR : Section revue pour optimisation du remplissage de CRITERE
# Et Exploitation des rôles
$SEL_SELSHIFCY
Local Char WCRITERE(240)
Raz CRITERE,ICRITERE
If PARAM(2)="" PARAM(2)="1=1" : Endif
If clalev([F:ATZ])=0  Local File ATABZON    [ATZ] : Endif
#-----
If [F:ITM]ITMREF<>PARAM(1)
  Read [ITM] ITM0=PARAM(1) : If fstat  Raz [F:ITM] : Endif
Endif
#-----
If [F:ITM]STOMGTCOD>1
  WCRITERE=PARAM(2)-"& [F:ITF]ITMREF=PARAM(1)"
Else
  WCRITERE=PARAM(2)-"& [F:FCY]WRHFLG=2"
Endif
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
#-----
Call AJOUTE_CONDITION_ROLE(CRITERE,ICRITERE,"FCY") From CRMUTIL150
#-----
START="[F:FCY]FCY"
ORDRE="[F:FCY]FCY"
OBJET=""
TIT(0) = mess(183,195,1)
NBCOL  = 0
NBCOL += 1 : COL(NBCOL) = "[F:FCY]LEGCPY"
Call TEXTFIC("FACILITY","LEGCPY",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:FCY]FCY"
Call TEXTFIC("FACILITY","FCY",3,TIT(NBCOL))    From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:FCY]FCYNAM"
Call TEXTFIC("FACILITY","FCYNAM",3,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "[F:FCY]FCYSHO"
Call TEXTFIC("FACILITY","FCYSHO",3,TIT(NBCOL)) From OBJDIV
If [F:ITM]STOMGTCOD>1
  Link [ITF] With [FCY] FCY0=[F:ITF]STOFCY As [ITY]
  Default File [ITY]
Else
  Default File [FCY]
Endif
Return
#-------------------------------#
# Après sélection dans la table #
#-------------------------------#
$VERF_SELSHIFCY
VALEUR=[F:FCY]FCY
Return


