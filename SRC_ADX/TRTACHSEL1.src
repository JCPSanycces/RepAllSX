########################################################################
# S_PRHFCY : SéLECTION SITE DE RéCEPTION  - PRHFCY ET RCPFCY           #
# ATTENTION LE CALL EST ENCORE UTILISE DANS L'ECRAN PBENCHW1           #
# NE PAS SUPPRIMER                                                     #
########################################################################
Subprog S_PRHFCY(VALEUR,WSTOMGTCOD)
Variable Char     VALEUR
Value    Libelle  WSTOMGTCOD
#----------------------------------------------------#
# ON FILTRE LES SITES SUR MêME SOCIéTé JURIDIQUE     #
# ET SUR SITE DE STOCKAGE POUR ARTICLE GéRE EN STOCK #
# PAS DE FILTRE SUR DéPOT POUR LES AUTRES            #
#----------------------------------------------------#
If clalev ([F:ITM])=0 | WSTOMGTCOD=1
  Filter [FCY] Where LEGCPY=GSOCIETE
Else
  Filter [FCY] Where LEGCPY=GSOCIETE  & WRHFLG=2
Endif
If dim([M:POC0]BETFCY)>0
  If [M:POC0]BETFCY=2
    Local Char LIB(20)(4)
    If clalev([F:ATZ])<=0 Local File ATABZON [ATZ] : Endif
    Read [ATZ] CODZONE="FACILITY";"LEGCPY" : If fstat Raz [F:ATZ] : Endif
    Call TEXTE([F:ATZ]NOABREG, LIB(0)) From OBJDIV
    Read [ATZ] CODZONE="FACILITY";"FCY"    : If fstat Raz [F:ATZ] : Endif
    Call TEXTE([F:ATZ]NOABREG, LIB(1)) From OBJDIV
    Read [ATZ] CODZONE="FACILITY";"FCYNAM" : If fstat Raz [F:ATZ] : Endif
    Call TEXTE([F:ATZ]NOABREG, LIB(2)) From OBJDIV
    Read [ATZ] CODZONE="FACILITY";"FCYSHO" : If fstat Raz [F:ATZ] : Endif
    Call TEXTE([F:ATZ]NOABREG, LIB(3)) From OBJDIV
    Link [BPR] With [FCY]FCY0=FCY As [FBC] Where [BPR]FCY<>"" & [BPR]BPCFLG=2
$DEB_CHOISITCLI
    Choose [FBC] Using [FCY]LEGCPY Titled LIB(0),
&                      [FCY]FCY    Titled LIB(1),
&                      [FCY]FCYNAM Titled LIB(2),
&                      [FCY]FCYSHO Titled LIB(3)
&                Sized (80,240)    Titled mess(183,195,1)
    If status=GSTASRA Goto DEB_CHOISITCLI : Endif
    If status=0 | status=7 Raz [F:FCY] : Endif
    If [F:FCY]FCY<>""
      VALEUR=[F:FCY]FCY
      Read [FCY] FCY0=VALEUR : If fstat Raz [F:FCY] : VALEUR="" : mkstat=1 : Endif
    Else
      mkstat=1
    Endif
  Else
    Call SELECT ("FCY","",VALEUR,"") From SELOBJ
  Endif
Elsif dim([M:PSH0]REQUSR)>0
  If GPLNFLT>1 & WSTOMGTCOD>1
    If [F:ITM]ITMREF<>[M:PSH1]ITMREF(nolign-1)
      Read [ITM] ITM0=[M:PSH1]ITMREF(nolign-1) : If fstat Raz [F:ITM] : Endif
    Endif
    Local Char CRITLNK(110)
    CRITLNK="[F:ITF]ITMREF=[F:ITM]ITMREF & "
    If GPLNFLT=2
      CRITLNK+='([F:ITF]PLANNER=[M:PSH0]REQUSR | [F:ITF]PLANNER="")'
    Else
      CRITLNK+="[F:ITF]PLANNER=[M:PSH0]REQUSR"
    Endif
    CRITLNK+=" & [F:FCY]LEGCPY=GSOCIETE"
    Local Char LIB(20)(5)
    If clalev([F:ATZ])<=0 Local File ATABZON [ATZ] : Endif
    Read [ATZ] CODZONE="FACILITY";"LEGCPY"    : If fstat Raz [F:ATZ] : Endif
    Call TEXTE([F:ATZ]NOABREG, LIB(0)) From OBJDIV
    Read [ATZ] CODZONE="FACILITY";"FCY"       : If fstat Raz [F:ATZ] : Endif
    Call TEXTE([F:ATZ]NOABREG, LIB(1)) From OBJDIV
    Read [ATZ] CODZONE="FACILITY";"FCYNAM"    : If fstat Raz [F:ATZ] : Endif
    Call TEXTE([F:ATZ]NOABREG, LIB(2)) From OBJDIV
    Read [ATZ] CODZONE="FACILITY";"FCYSHO"    : If fstat Raz [F:ATZ] : Endif
    Call TEXTE([F:ATZ]NOABREG, LIB(3)) From OBJDIV
    Read [ATZ] CODZONE="ITMFACILIT";"PLANNER" : If fstat Raz [F:ATZ] : Endif
    Call TEXTE([F:ATZ]NOABREG, LIB(4)) From OBJDIV
    Link [ITF] With [FCY] FCY0=[F:ITF]STOFCY As [ITY] Where evalue(CRITLNK)
$DEB_CHOISITART
    Choose [ITY] Using [FCY]LEGCPY  Titled LIB(0),
&                      [FCY]FCY     Titled LIB(1),
&                      [FCY]FCYNAM  Titled LIB(2),
&                      [FCY]FCYSHO  Titled LIB(3),
&                      [ITF]PLANNER Titled LIB(4)
&                Sized (80,240)    Titled mess(183,195,1)
    If status=GSTASRA Goto DEB_CHOISITART : Endif
    If status=0 | status=7 Raz [F:FCY] : Endif
    If [F:FCY]FCY<>""
      VALEUR=[F:FCY]FCY
      Read [FCY] FCY0=VALEUR : If fstat Raz [F:FCY] : VALEUR="" : mkstat=1 : Endif
    Else
      mkstat=1
    Endif
  Else
    Call SELECT ("FCY","",VALEUR,"") From SELOBJ
  Endif
Else
  Call SELECT ("FCY","",VALEUR,"") From SELOBJ
Endif
Filter [FCY]
End

##########################################################################
# SELITMFAC : S/P sélection d'une ligne article à facturer  MBT 12/10/98 #
#   BPSFAC : Fournisseur facturant                                       #
#   TYPOR  : Origine (1=Commande  2=Réception  3=Retour  4=Facture)      #
#   NUMOR  : Numéro sélectionné (""=Aucun)                               #
#   LINOR  : Ligne                                                       #
#   SEQOR  : Numéro de séquence (Si origine=commande autrement 0)        #
#   REFART : Référence de l'article sélectionné (""=Aucun)               #
# En sortie si NUMOR="" --> Rien n'a été sélectionné (mkstat=1)          #
# ---------------------------------------------------------------------- #
# Remplacé par l'action SELITMFAC avec paramètres :         MBT 20/11/00 #
#   PARAM(1) = BPSFAC : Fournisseur facturant                            #
#   PARAM(2) = TYPOR  : Origine (1=Cde  2=Récept  3=Retour  4=Facture)   #
#   PARAM(3) = NUMOR  : Numéro sélectionné (""=Aucun)                    #
#   PARAM(4) = LINOR  : Ligne                                            #
#   PARAM(5) = SEQOR  : Numéro de séquence (Si origine=cde autrement 0)  #
#   PARAM(6) = REFART : Référence de l'article sélectionné (""=Aucun)    #
#   PARAM(7) = NOMZON : Nom du champ courant (ex. "LINORI")              #
##########################################################################
# Issue X3-65722 - 2018-03-05 by SR : Section revue pour optimisation du remplissage de CRITERE
#--------------------------------------------#
# Avant ouverture de la fenêtre de sélection #
#--------------------------------------------#
$SEL_SELITMFAC
#----- Variables locales -----#
Local Char     BPSFAC(GLONBPS) : BPSFAC=PARAM(1)
Local Shortint TYPOR           : TYPOR =val(PARAM(2))
Local Char     NUMOR (GLONVCR) : NUMOR =PARAM(3)
Local Integer  LINOR           : LINOR =val(PARAM(4))
Local Integer  SEQOR           : SEQOR =val(PARAM(5))
Local Char     REFART(GLONITM) : REFART=PARAM(6)
Local Char     NOMZON(GLONAVA) : NOMZON=PARAM(7)
Local Shortint NOL             : NOL=nolign-1
Local Char     CODE(10)
Local Char     FOUFAC(GLONBPS)
Local Libelle  INTERSITE, INTERSOC
Local Shortint OUVFICFLG  : Raz OUVFICFLG
Local Integer  SVG_ADXMXL : Raz SVG_ADXMXL
Local Char WCRITERE(240)
Raz CRITERE,ICRITERE
#----- Sauvegarde de la valeur courante -----#
Case type(VALEUR)
  When 1,2,4,5,6,7,9 : Local Decimal SVGVALEUR
  When 3             : Local Date    SVGVALEUR
  When Default       : Local Char    SVGVALEUR(30)
Endcase
SVGVALEUR=VALEUR
#----- Test si zone courante ITMREF et si ligne diverse c'est fini ! -----#
If NOMZON="ITMREF" & (TYPOR>4 | GIMPORT) OK=0 : Return : Endif
#-----
If clalev([F:AMZ])=0 Local File AMSKZON [AMZ] : OUVFICFLG=1 : Endif
If adxmxl<200  SVG_ADXMXL=adxmxl : adxmxl=200 : Endif
# Issue 110325 - 2016-01-11 by SR : FCC sur expé
Case TYPOR
  When 1 : TIT(0)=mess(36,198,1)
           If NUMOR <>""
             WCRITERE ="POHNUM=NUMOR"
             Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
           Endif
           If REFART<>""
             WCRITERE="ITMREF=REFART"
             Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
           Endif
           # Issue 102940 - 2014-09-26 by SR : Critère assoupli pour FCC
           # Issue 82703 - 2012-10-04 by SR
           If [M:PIH0]PIHTYP = 2
              # Issue 101413 - 2014-07-15 by SR : Interdire les commandes de sous-traitance
              WCRITERE="WIPSTA<2 & POHTYP = 1 & !find([F:POQ]VCRTYPORI,10,36)"
              Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
           Else
              WCRITERE="WIPSTA<2 & LININVFLG<2 & LINTYP<3"
              Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
           Endif
           COL(1)="POHNUM"
           CODE=""        : GBIDC3="POHNUM"    : Gosub SELITMFAC_TIT : TIT(1)=GBIDC3
           COL(2)="POPLIN"
           CODE=""        : GBIDC3="POPLIN"    : Gosub SELITMFAC_TIT : TIT(2)=GBIDC3
           COL(3)="POQSEQ"
           CODE=""        : GBIDC3="POQSEQ"    : Gosub SELITMFAC_TIT : TIT(3)=GBIDC3
           COL(4)="ITMREF"
           CODE=""        : GBIDC3="ITMREF"    : Gosub SELITMFAC_TIT : TIT(4)=GBIDC3
           COL(5)="QTYPUU"
           CODE="POH2"    : GBIDC3="QTYPUU"    : Gosub SELITMFAC_TIT : TIT(5)=GBIDC3
           COL(6)="INVQTYPUU"
           CODE=""        : GBIDC3="INVQTYPUU" : Gosub SELITMFAC_TIT : TIT(6)=GBIDC3
           COL(7)="PUU"
           CODE="POH2"    : GBIDC3="PUU"       : Gosub SELITMFAC_TIT : TIT(7)=GBIDC3
           NBCOL=7
           If NOMZON="ITMREF" START="ITMREF" Else START="POPLIN" : Endif
           SIZLIG=80 : SIZCOL=240
           Raz [F:POQ] : Default File [POQ]
  When 2 : TIT(0)=mess(36,198,1)
           # Issue 102940 - 2014-09-26 by SR : Critère assoupli pour FCC
           #If NUMOR <>"" CRITERE(1) ="PTHNUM=NUMOR & "  : Endif
           #  If REFART<>"" CRITERE(1)+="ITMREF=REFART & " : Endif
           If NUMOR <>""
             WCRITERE ="PTHNUM=NUMOR  "
             Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
           Endif
           # Issue X3-47495 - 2017-07-10 by SR : si Critère vide, ne pas commencer par "&"
#           If REFART<>"" CRITERE(1)+="& ITMREF=REFART  " : Endif
            If REFART<>""
              WCRITERE="ITMREF=REFART"
              Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
           Endif
           # End issue X3-47495
           If [M:PIH0]PIHTYP <> 2
              WCRITERE="LININVFLG<2"
              Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
              # Issue 120453 - 2016-12-16 by SR : Inter soc
              WCRITERE= "(VERFLG=2 | SDHNUM = '')"
              Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
           Endif
           COL(1)="PTHNUM"
           CODE=""        : GBIDC3="PTHNUM"    : Gosub SELITMFAC_TIT : TIT(1)=GBIDC3
           COL(2)="PTDLIN"
           CODE=""        : GBIDC3="PTDLIN"    : Gosub SELITMFAC_TIT : TIT(2)=GBIDC3
           COL(3)="ITMREF"
           CODE=""        : GBIDC3="ITMREF"    : Gosub SELITMFAC_TIT : TIT(3)=GBIDC3
           COL(4)="QTYPUU"
           CODE="POH2"    : GBIDC3="QTYPUU"    : Gosub SELITMFAC_TIT : TIT(4)=GBIDC3
           COL(5)="INVQTYPUU"
           CODE=""        : GBIDC3="INVQTYPUU" : Gosub SELITMFAC_TIT : TIT(5)=GBIDC3
           COL(6)="PUU"
           CODE="POH2"    : GBIDC3="PUU"       : Gosub SELITMFAC_TIT : TIT(6)=GBIDC3
           NBCOL=6
           If NOMZON="ITMREF" START="ITMREF" Else START="PTDLIN" : Endif
           SIZLIG=80 : SIZCOL=240
           Raz [F:PTD] : Default File [PTD]
  When 3 : TIT(0)=mess(36,198,1)
           If NUMOR <>""
              WCRITERE ="PNHNUM=NUMOR"
              Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
            Endif
           If REFART<>""
              WCRITERE="ITMREF=REFART"
              Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
           Endif
           WCRITERE="LININVFLG<2"
           Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
           COL(1)="PNHNUM"
           CODE=""        : GBIDC3="PNHNUM"    : Gosub SELITMFAC_TIT : TIT(1)=GBIDC3
           COL(2)="PNDLIN"
           CODE=""        : GBIDC3="PNDLIN"    : Gosub SELITMFAC_TIT : TIT(2)=GBIDC3
           COL(3)="ITMREF"
           CODE=""        : GBIDC3="ITMREF"    : Gosub SELITMFAC_TIT : TIT(3)=GBIDC3
           COL(4)="QTYPUU"
           CODE="POH2"    : GBIDC3="QTYPUU"    : Gosub SELITMFAC_TIT : TIT(4)=GBIDC3
           COL(5)="INVQTYPUU"
           CODE=""        : GBIDC3="INVQTYPUU" : Gosub SELITMFAC_TIT : TIT(5)=GBIDC3
           COL(6)="PUU"
           CODE="POH2"    : GBIDC3="PUU"       : Gosub SELITMFAC_TIT : TIT(6)=GBIDC3
           NBCOL=6
           If NOMZON="ITMREF" START="ITMREF" Else START="PNDLIN" : Endif
           SIZLIG=80 : SIZCOL=240
           Raz [F:PND] : Default File [PND]
  When 4 : If clalev([F:PIDB])=0 Local File PINVOICED [PIDB] : Endif
           If [M:PIH0]PIHTYP=3
             If clalev([F:PIHB])=0 Local File PINVOICE [PIHB] : Endif
           Endif
           TIT(0)=mess(36,198,1)
           If NUMOR <>""
             WCRITERE ="NUM=NUMOR"
             Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
           Endif
           If REFART<>""
              WCRITERE="ITMREF=REFART"
              Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
           Endif
           If [M:PIH0]PIHTYP=3
             WCRITERE="PIHTYP<3"
             Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
             # Issue 87184 - 2013-01-15 by MUARN : pas les lignes service et matière fournies
             WCRITERE="LINTYP<3"
             Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
           Endif
           COL(1)="NUM"
           CODE="PIH0"    : GBIDC3="NUM"       : Gosub SELITMFAC_TIT : TIT(1)=GBIDC3
           COL(2)="PIDLIN"
           CODE="PIH3"    : GBIDC3="PIDLIN"    : Gosub SELITMFAC_TIT : TIT(2)=GBIDC3
           COL(3)="ITMREF"
           CODE="PIH3"    : GBIDC3="ITMREF"    : Gosub SELITMFAC_TIT : TIT(3)=GBIDC3
           COL(4)="ITMDES"
           CODE="PIH3"    : GBIDC3="ITMDES"    : Gosub SELITMFAC_TIT : TIT(4)=GBIDC3
           COL(5)="QTYUOM"
           CODE="PIH3"    : GBIDC3="QTYUOM"    : Gosub SELITMFAC_TIT : TIT(5)=GBIDC3
           COL(6)="UOM"
           CODE="PIH3"    : GBIDC3="UOM"       : Gosub SELITMFAC_TIT : TIT(6)=GBIDC3
           NBCOL=6
           If NOMZON="ITMREF" START="ITMREF" Else START="PIDLIN" : Endif
           SIZLIG=80 : SIZCOL=240
           Raz [F:PIDB] : Default File [PIDB]
 When 6 : TIT(0)=mess(36,198,1)
           WCRITERE =  "LEGCPY=GSOCIETE"
           Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
           If NUMOR <>""
             WCRITERE="SHIPNUM=NUMOR"
             Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
           Endif
           If REFART<>""
             WCRITERE="ITMREF=REFART"
             Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
           Endif
           COL(1)="SHIPNUM"
           CODE=""        : GBIDC3="SHIPNUM"    : Gosub SELITMFAC_TIT : TIT(1)=GBIDC3
           COL(2)="SHIPLIN"
           CODE=""        : GBIDC3="SHIPLIN"    : Gosub SELITMFAC_TIT : TIT(2)=GBIDC3
           COL(3)="ITMREF"
           CODE=""        : GBIDC3="ITMREF"    : Gosub SELITMFAC_TIT : TIT(3)=GBIDC3
           COL(4)="SHIQTYPUU"
           CODE="SHIP1"    : GBIDC3="SHIQTYPUU"    : Gosub SELITMFAC_TIT : TIT(4)=GBIDC3
           COL(5)="PUU"
           CODE="SHIP1"    : GBIDC3="PUU"       : Gosub SELITMFAC_TIT : TIT(5)=GBIDC3
           NBCOL=5
           If NOMZON="ITMREF" START="ITMREF" Else START="SHIPLIN" : Endif
           SIZLIG=80 : SIZCOL=240
           Raz [F:SHD] : Default File [SHD]
Endcase
Return
#-------------------------------#
# Après sélection dans la table #
#-------------------------------#
$VERF_SELITMFAC
# Issue 110325 - 2016-01-11 by SR : FCC sur expé
Case TYPOR
  When 1 : NUMOR=[F:POQ]POHNUM : LINOR=[F:POQ]POPLIN : SEQOR=[F:POQ]POQSEQ
           Read [POQ] POQ0=NUMOR;LINOR;SEQOR : If fstat Raz [F:POQ] : Endif
           REFART=[F:POQ]ITMREF
  When 2 : NUMOR=[F:PTD]PTHNUM : LINOR=[F:PTD]PTDLIN : SEQOR=0
           Read [PTD] PTD0=NUMOR;LINOR  : If fstat Raz [F:PTD]  : Endif
           REFART=[F:PTD]ITMREF
  When 3 : NUMOR=[F:PND]PNHNUM : LINOR=[F:PND]PNDLIN : SEQOR=0
           Read [PND] PND0=NUMOR;LINOR  : If fstat Raz [F:PND]  : Endif
           REFART=[F:PND]ITMREF
  When 4 : NUMOR=[F:PIDB]NUM : LINOR=[F:PIDB]PIDLIN : SEQOR=0
           Read [PIDB] PID0=NUMOR;LINOR : If fstat Raz [F:PIDB] : Endif
           REFART=[F:PIDB]ITMREF
  When 6 : NUMOR=[F:SHD]SHIPNUM : LINOR=[F:SHD]SHIPLIN : SEQOR=0
           Read [SHD]SHD0=NUMOR;LINOR  : If fstat Raz [F:SHD]  : Endif
           REFART=[F:SHD]ITMREF
Endcase
#----- Appartenance à la même société + cde signée, ret validé et fourn.fact. -----#
If clalev([F:FCY])=0 Local File FACILITY [FCY] : Endif
Case TYPOR
  When 1 :
           # Issue 82703 - 2012-10-04 by SR : dissocier facture complémentaire
           If [M:PIH0]PIHTYP <> 2
              If [F:POQ]LINCLEFLG>1 & [F:POQ]RCPQTYPUU<=[F:POQ]INVQTYPUU
                GMESSAGE=mess(142,194,1) : GERR=2 : mkstat=1 : Return
              Endif
           Endif
           Read [POH] POH0=[F:POQ]POHNUM : If fstat Raz [F:POH] : Endif
           If [F:POH]APPFLG<3
             GMESSAGE=mess(146,194,1)  : GERR=2 : mkstat=1 : Return
           Endif
           #----- Date document d'origine pas supérieure à date document en cours -----#
           If GCTLDATORI=2 & [F:POH]ORDDAT>[M:PIH0]ACCDAT
             GMESSAGE=mess(98,197,1)-[F:POH]POHNUM-"("+format$(GFMD,[F:POH]ORDDAT)+")\"-mess(409,194,1)
             GERR=2 : mkstat=1 : Return
           Endif
           #-----
           FOUFAC=[F:POH]BPSINV : INTERSITE=[F:POH]BETFCY : INTERSOC=[F:POH]BETCPY
           Read [FCY] FCY0=[F:POQ]POHFCY : If fstat Raz [F:FCY] : Endif
  When 2 : Read [PTH] PTH0=[F:PTD]PTHNUM : If fstat Raz [F:PTH] : Endif
           #----- Date document d'origine pas supérieure à date document en cours -----#
           #VPO 21/04/11 73382 ajout ctl DATORI aussi avec date BL
           If GCTLDATORI=2
             If [F:PTH]NDEDAT=[0/0/0]
               If [F:PTH]RCPDAT>[M:PIH0]ACCDAT
                 GMESSAGE=mess(117,198,1)-[F:PTH]PTHNUM-"("+format$(GFMD,[F:PTH]RCPDAT)+")\"-mess(410,194,1)
                 GERR=2 : mkstat=1 : Return
               Endif
             Else
               If min([F:PTH]NDEDAT,[F:PTH]RCPDAT)>[M:PIH0]ACCDAT
                 GMESSAGE=mess(117,198,1)-[F:PTH]PTHNUM-"("+format$(GFMD,min([F:PTH]NDEDAT,[F:PTH]RCPDAT))+")\"-mess(420,194,1)
                 GERR=2 : mkstat=1 : Return
               Endif
             Endif
           Endif
           #-----
           FOUFAC=[F:PTH]BPSINV : INTERSITE=[F:PTH]BETFCY : INTERSOC=[F:PTH]BETCPY
           Read [FCY] FCY0=[F:PTD]PRHFCY : If fstat Raz [F:FCY] : Endif
  When 3 : Read [PNH] PNH0=[F:PND]PNHNUM : If fstat Raz [F:PNH] : Endif
           If [F:PNH]CFMFLG<2
             GMESSAGE=mess(144,194,1)  : GERR=2 : mkstat=1 : Return
           Endif
           #----- Date document d'origine pas supérieure à date document en cours -----#
           If GCTLDATORI=2 & [F:PNH]RTNDAT>[M:PIH0]ACCDAT
             GMESSAGE=mess(192,198,1)-[F:PNH]PNHNUM-"("+format$(GFMD,[F:PNH]RTNDAT)+")\"-mess(411,194,1)
             GERR=2 : mkstat=1 : Return
           Endif
           #-----
           FOUFAC=[F:PNH]BPSINV : INTERSITE=[F:PNH]BETFCY : INTERSOC=[F:PNH]BETCPY
           Read [FCY] FCY0=[F:PNH]PNHFCY : If fstat Raz [F:FCY] : Endif
  When 4 : Read [FCY] FCY0=[F:PIDB]FCY   : If fstat Raz [F:FCY] : Endif
           If [M:PIH0]PIHTYP=3
             Read [PIHB] PIH0=[F:PIDB]NUM : If fstat Raz [F:PIHB] : Endif
             #----- Date document d'origine pas supérieure à date document en cours -----#
             If GCTLDATORI=2 & [F:PIHB]ACCDAT>[M:PIH0]ACCDAT
               GMESSAGE=mess(55,198,1)-[F:PIHB]NUM-"("+format$(GFMD,[F:PIHB]ACCDAT)+")\"-mess(407,194,1)
               GERR=2 : mkstat=1 : Return
             Endif
             #-----
             FOUFAC=[F:PIHB]BPR
           Else
             FOUFAC=BPSFAC
           Endif
  When 6 : Read [SHH] SHH0=[F:SHD]SHIPNUM : If fstat Raz [F:SHH] : Endif
           Read [FCY] FCY0=[F:SHD]POHFCY : If fstat Raz [F:FCY] : Endif
           If GCTLDATORI=2
              If [F:SHH]SHIPDAT>[M:PIH0]ACCDAT
                 GMESSAGE=mess(500,198,1)-[F:SHH]SHIPNUM-"("+format$(GFMD,[F:SHH]SHIPDAT)+")\"-mess(410,194,1)
                 GERR=2 : mkstat=1 : Return
               Endif
           Endif
           #-----
           FOUFAC=[M:PIH0]BPR
Endcase
If [F:FCY]LEGCPY<>GSOCIETE
  GMESSAGE=mess(151,194,1) : GERR=2 : mkstat=1 : Return
Endif
# Issue 82703 - 2012-10-04 by SR : dissocier facture complémentaire
If [M:PIH0]PIHTYP <> 2
    If FOUFAC<>BPSFAC
        GMESSAGE=mess(150,194,1) : GERR=2 : mkstat=1 : Return
    Endif
    If INTERSITE=2 & INTERSOC<>2
        GMESSAGE=mess(239,194,1) : GERR=2 : mkstat=1 : Return
    Endif
Endif
Return
#------------------------#
# Sortie de la sélection #
#------------------------#
$FIN_SELITMFAC
If SVG_ADXMXL>0 adxmxl=SVG_ADXMXL : Endif
If OUVFICFLG=1        Close Local File [AMZ]  : Raz OUVFICFLG : Endif
If clalev([F:PIHB])>0
  # Issue 93187 - 2013-11-15 by MUARN : VATDAT non ACCDAT
  #GBIDA1=[F:PIHB]ACCDAT : GBIDC3=[F:PIDB]VAT(0)
  GBIDA1=[F:PIHB]VATDAT : GBIDC3=[F:PIDB]VAT(0)
  Close Local File [PIHB]
Endif
Default File [PIH]
If NOMZON<>"LINORI" VALEUR=SVGVALEUR : Endif
If NUMOR="" LINOR=0 : SEQOR=0 : REFART="" : mkstat=1 : Endif
If mkstat
 If NOMZON="ITMREF" VALEUR="" : [M:PIH3]ITMREF(NOL)="" : Endif
 Return
Endif
If NOMZON ="LINORI"
   VALEUR=LINOR
  #[M:PIH2]LINORI(NOL)=LINOR
  [M:PIH3]SEQORI(NOL)=SEQOR
Endif
If NOMZON ="ITMREF"
  [M:PIH3]NUMORI(NOL)=NUMOR
  [M:PIH3]LINORI(NOL)=LINOR
  [M:PIH3]SEQORI(NOL)=SEQOR
  #----- Blocage logique de la cde, réception, retour ou facture -----#
  Local Char FICH(3), NOM(GLONATB+1), SYMBOL2(30)
  # Issue 110325 - 2016-01-11 by SR : FCC sur expé
  Case [M:PIH3]TYPORI(NOL)
    When 1 : FICH="POH" : NOM="$PORDER"
    When 2 : FICH="PTH" : NOM="$PRECEIPT"
    When 3 : FICH="PNH" : NOM="$PRETURN"
    When 4 : FICH="PIH" : NOM="$PINVOICE"
    When 6 : FICH="SHH" : NOM="$SHIPMENT"
  Endcase
  #----- Si avoir, contrôle date facture d'origine donne le même taux de taxe -----#
  If [M:PIH0]PIHTYP=3 & [M:PIH3]TYPORI(NOL)=4
    Gosub CTRL_DATE_TAXE From SUBPIHB
    If mkstat
      Raz [M:PIH3]NUMORI(NOL), [M:PIH3]LINORI(NOL)
      VALEUR="" : [M:PIH3]ITMREF(NOL)="" : Return
    Endif
  Endif
  #----- Contrôle si avoir ou facture non validé sur document d'origine -----#
  # rien à faire sur les FCC sur expé
  If [M:PIH3]TYPORI(NOL)<4
    Gosub CTRL_VALID From SUBPIHD
    If mkstat
      Raz [M:PIH3]NUMORI(NOL), [M:PIH3]LINORI(NOL)
      VALEUR="" : [M:PIH3]ITMREF(NOL)="" : Return
    Endif
  Endif
  #-----
  SYMBOL2=FICH+[M:PIH3]NUMORI(NOL) : Lock=SYMBOL2
  If fstat GMESSAGE=NOM-[M:PIH3]NUMORI(NOL)-mess(10,100,1) : GERR=1
    Raz [M:PIH3]NUMORI(NOL), [M:PIH3]LINORI(NOL)
    mkstat=1 : VALEUR="" : [M:PIH3]ITMREF(NOL)="" : Return
  Endif
  If dim(GPIH_SYMBOL2)>=0 GPIH_SYMBOL2=SYMBOL2 : Endif
  #----- Chargement des autres champs de la ligne -----#
  [M:PIH3]ITMREF(NOL)=VALEUR : Call CHARG_LIG (NOL,[M:PIH3]NBLIG) From SUBPIHB
  If !GIMPORT
    Affzo [PIH3]NUMORI(NOL),LINORI(NOL),ITMDES(NOL),UOM(NOL),QTYUOM(NOL),NETPRI(NOL),
&               AMTNOTLIN(NOL)
  Endif
Endif
Return
#-------------------------------------------------#
# Chargement des titres de colonne pour le Choose #
#-------------------------------------------------#
$SELITMFAC_TIT
# Issue 110325 - 2016-01-11 by SR : FCC sur expé
If CODE=""
  Case GBIDC3
    When "POHNUM"    : GBIDC3=mess(98,197,1)
    When "POPLIN"    : GBIDC3=mess(18,197,1)
    When "POQSEQ"    : GBIDC3=mess(8,47,1)
    When "PTHNUM"    : GBIDC3=mess(117,198,1)
    When "PTDLIN"    : GBIDC3=mess(18,197,1)
    When "PNHNUM"    : GBIDC3=mess(192,198,1)
    When "PNDLIN"    : GBIDC3=mess(18,197,1)
    When "ITMREF"    : GBIDC3=mess(14,195,1)
    When "INVQTYPUU" : GBIDC3=mess(143,194,1)
    When "SHIPNUM"   : GBIDC3=mess(500,198,1)
    When "SHIPLIN"   : GBIDC3=mess(18,197,1)
    When "SHIQTYPUU" : GBIDC3=mess(544,194,1)
    When "PUU"       : GBIDC3=mess(397,198,1)
  Endcase
  Return
Endif
Read [AMZ] CODE=CODE;GBIDC3 : If fstat Raz [F:AMZ] : Endif
Call TEXTE([F:AMZ]INTIT,GBIDC3) From OBJDIV
Return


################################################################
# SELPIHFACC : Sélection du numéro de facture   MBT 23/09/2008 #
#      pour chargement lignes factures complémentaires         #
################################################################
# Issue X3-65722 - 2018-03-05 by SR : Section revue pour optimisation du remplissage de CRITERE
#--------------------------------------#
# Avant ouverture fenêtre de sélection #
#--------------------------------------#
$SEL_SELPIHFACC
Local Shortint OUVFICFLG : Raz OUVFICFLG
Local Char WCRITERE(240)
Raz CRITERE,ICRITERE
If clalev([F:AMZ])=0 Local File AMSKZON [AMZ] : OUVFICFLG=1 : Endif
TIT(0)=mess(207,198,1)
WCRITERE="PIHTYP=1 & ORIMOD=6 & CPY=GSOCIETE & STA=3"
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
If GCTLDATORI=2
   WCRITERE="ACCDAT<=[M:PIH0]ACCDAT"
   Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Endif
COL(1)="FCY"    : GBIDC3="FCY"    : Gosub CHARG_LIB : TIT(1)=GBIDC3
COL(2)="NUM"    : GBIDC3="NUM"    : Gosub CHARG_LIB : TIT(2)=GBIDC3
COL(3)="BPR"    : GBIDC3="BPR"    : Gosub CHARG_LIB : TIT(3)=GBIDC3
COL(4)="ACCDAT" : GBIDC3="ACCDAT" : Gosub CHARG_LIB : TIT(4)=GBIDC3
NBCOL=4
START="NUM"
SIZLIG=80 : SIZCOL=240
Default File [PIHB]
Return
#-----------------------#
# Sotie de la sélection #
#-----------------------#
$FIN_SELPIHFACC
If OUVFICFLG=1 Close Local File [AMZ] : Raz OUVFICFLG : Endif
Return
#--------------------------------------------#
# Chargement libellé colonne de la sélection #
#--------------------------------------------#
$CHARG_LIB
Read [AMZ] CODE="PIH0";GBIDC3 : If fstat Raz [F:AMZ] : Endif
Call TEXTE([F:AMZ]INTIT,GBIDC3) From OBJDIV
Return


##################################################################
# SELPTHFACC : Sélection du numéro de réception   MBT 23/09/2008 #
#       pour chargement lignes factures complémentaires          #
##################################################################
# Issue X3-65722 - 2018-03-05 by SR : Section revue pour optimisation du remplissage de CRITERE
#--------------------------------------#
# Avant ouverture fenêtre de sélection #
#--------------------------------------#
$SEL_SELPTHFACC
Local Char WCRITERE(240)
Raz CRITERE,ICRITERE
OBJET="PTH"
TIT(0)=mess(198,198,1)
WCRITERE="INVFLG=1 & CPY=GSOCIETE"
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
#VPO 21/04/11 73382 ajout ctl DATORI aussi avec date BL
#If GCTLDATORI=2  CRITERE(1)-="& RCPDAT<=[M:PIH0]ACCDAT" : Endif
If GCTLDATORI=2
  WCRITERE="((NDEDAT=[0/0/0] & RCPDAT<=[M:PIH0]ACCDAT)|(NDEDAT<>[0/0/0] & min(NDEDAT,RCPDAT)<=[M:PIH0]ACCDAT))"
  Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Endif
START="PTHNUM"
SIZLIG=80 : SIZCOL=240
Return

# Issue 82703 - 2012-10-04 by SR
##################################################################
# SELPOHFACC : Sélection du numéro de commande   SR   04/10/2012 #
#       pour chargement lignes factures complémentaires          #
##################################################################
# Issue X3-65722 - 2018-03-05 by SR : Section revue pour optimisation du remplissage de CRITERE
#--------------------------------------#
# Avant ouverture fenêtre de sélection #
#--------------------------------------#
$SEL_SELPOHFACC
Local Char WCRITERE(240)
Raz CRITERE,ICRITERE
OBJET="POH"
TIT(0)=mess(196,198,1)
#CRITERE(1)="APPFLG > 2 & CLEFLG = 1 & RCPFLG = 1 & INVFLG=1 & CPY=GSOCIETE"
WCRITERE="APPFLG > 2 & CPY=GSOCIETE"
Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
If GCTLDATORI=2
  WCRITERE="ORDDAT<=[M:PIH0]ACCDAT"
  Call ADDCRIT(CRITERE, ICRITERE, "CRITERE", WCRITERE, "&") From GOBJSUB
Endif
START="POHNUM"
SIZLIG=80 : SIZCOL=240
Return

# Issue 110325 - 2016-01-05 by SR : FCC sur expé
##################################################################
# SELSHHFACC : Sélection du numéro d'expédition                  #
#       pour chargement lignes factures complémentaires          #
