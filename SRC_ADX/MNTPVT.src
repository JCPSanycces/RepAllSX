#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################
# Issue X3-64159 - 2018-02-13 by CBO : Choose the traitment's folder and delete not used fields
# CBO   17.02.2015 FQ100398/26 : Syracused event or not
# CBO - 28/08/2014
# GBN - 16/03/2004 - Traitement de revalidation en masse de la description des événements
# GBN - 18/05/2004 - Ajouts d'outils de maintenance sur le paramètrage et les tables des événements
# GBN - 08/11/2004 - Ajout fonction de modif de l'alim d'une zone
# GBN - 22/12/2004 - Ajout Société dans critère de sélection pour la suppression des événements générés
###################################################################################
Local Char PARAM(30)(1..1)
Local Char VALEUR(30)
  PARAM(1)=""
  Call TRAITE_CHAR(VALEUR, PARAM, "", "MNTPVT", "MNTPVT", 4, "") From GTRAITE
End

$ACTION
  Case ACTION
    When "AVANT_PAR" : Gosub AVANT_PAR
    When "DEBUT"     : Gosub DEBUT
    When "SETBOUT"   : Gosub SETBOUT
    When "END"       : ABANDON=G_OUI
    When "EXEC"      : Gosub EXEC
    When Default
  Endcase
Return


###################################################################################
$AVANT_PAR
  If !clalev([M:VET]) : Local Mask MNTPVT    [VET] : Endif
Return

###################################################################################
$DEBUT
Global Integer ABANDON
  Grizo [M:VET]EVT
  Grizo [M:VET]PLN
  Grizo [M:VET]CPY
  Affzo [M:VET]

  Gosub DECLAR_DOSSIER From SUBPVT
Return

###################################################################################
$SETBOUT
Return

###################################################################################
$EXEC

Local Char    TRTCRIT(255)

  If dim(ABANDON) > 0 and ABANDON = G_OUI
    Return
  Endif

  If !GSERVEUR
    Call OUVRE_TRACE("Maintenance événements") From LECFIC
  Endif

  # Ajouter un filtre construit sur les critère renseignés dans le masque [VET]

  Gosub SET_FILTRE

  #==> Validation

  Gosub OUVRE From SUBPVT
  Local Integer NBEVTTOT, NBEVT : Raz NBEVTTOT, NBEVT

  GAPPLI_TRT = [M:VET]DOSSIER_TRT # Issue X3-64159
  GAPPLI_PARAM = [M:VET]DOSSIER_PAR # Issue X3-64159

  If !clalev([F:PVTA])
    Local File = GAPPLI_PARAM + ".PAREVT"    [PVTA]
  Endif

  #==> Edition du contenu événement

  If [M:VET]FLGEDT=G_OUI
    Gosub EDIT_EVT
  Endif

  Filter [F:PVTA] Where evalue (TRTCRIT)
  NBEVTTOT=rowcount([F:PVTA])

  Call OUVRE_BOITE("Validation ...", NBEVTTOT) From GESECRAN
  Call SET_BOITE("Validation ...", NBEVTTOT) From GESECRAN
  Call ECR_TRACE("", 0) From GESECRAN
  Call ECR_TRACE("[- VALIDATION DES EVENEMENTS -]", 0) From GESECRAN
  Call ECR_TRACE("Evénement" + "/" + "Plan d'amortissement", 0) From GESECRAN
  For [PVTA]
    Call ECR_TRACE([F:PVTA]EVT - "/" - mess([F:PVTA]PLN, 3101, 1), 0) From GESECRAN

    If [M:VET]FLGVAL=G_OUI
      # FQ100398/26
      Gosub SYRACUSED_OBJECT From SUBPVT

      If find(left$([F:PVTA]EVT, 3), WT_SYR_OBJ)
        # evts Syracuse
        Call VALIDATION([F:PVTA]EVT, [F:PVTA]EVTINT, GAPPLI_PARAM, GAPPLI_TRT) From GENEVETRT6
      Else
        # anciens evts
        Call VALIDATION([F:PVTA]EVT, [F:PVTA]EVTINT, GAPPLI_PARAM, GAPPLI_TRT) From GENEVETRT5
      Endif
    Endif

    NBEVT += 1
    Call AFF_BOITE([F:PVTA]EVT - "/" - mess([F:PVTA]PLN, 3101, 1), NBEVT, OK) From GESECRAN
  Next
  Call FERME_BOITE From GESECRAN
  Filter [PVTA]

  If !GSERVEUR
    Call LEC_TRACE From LECFIC
  Endif

Return


###################################################################################
# Sous-programmes et routines communes
###################################################################################

#=====================================================================
# Edition du paramètrage des événements                              #
#=====================================================================
$EDIT_EVT

Local Integer I
Local Char    PEVTINT(30)
Local Char    DATATYP(30)
  If !clalev([F:PVTA]) : Local File =GAPPLI_PARAM +".PAREVT"    [PVTA] : Endif

  Filter [PVTA] Where evalue(TRTCRIT)
  For [PVTA]
    Call ECR_TRACE("",0) From GESECRAN
    Call ECR_TRACE([F:PVTA]EVT-"/"-mess([F:PVTA]PLN,3101,1),0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
    PEVTINT = [F:PVTA]EVTINT
    Gosub PRINT_EVTINT From SUBPVT
  Next

  Filter [PVTA]

Return

#=====================================================================
# Préparation du filtre de sélection des événements                  #
#=====================================================================
$SET_FILTRE

  If [M:VET]ALLEVT<>G_OUI
    TRTCRIT = "EVT=[M:VET]EVT"
  Endif
  If [M:VET]ALLPLN <> G_OUI
    If TRTCRIT <> ""
      TRTCRIT += "&"
    Endif
    TRTCRIT += "PLN=[M:VET]PLN"
  Endif
  If TRTCRIT = ""
    TRTCRIT = "1=1"
  Endif
Return

#=====================================================================
# S/p de tassement des trous dans les numéros d'ordre                #
#=====================================================================
Subprog TAS_NUORD(PAPPLI,PEVT,PPLN,POBJ,POPTION,RCOD)
Value    Char    PAPPLI  # Application sur laquelle le traitement doit s'exécuter
Value    Char    PEVT    # Code événement à traiter
Value    Integer PPLN    # Plan à traiter
Value    Integer POBJ    # Objet métier pour lequel l'événement est géré
Value    Integer POPTION # Option du s/p -> traitement des événements déjà générés.
Variable Integer RCOD    # Code retour

Local Char    DATATYP(30)
Local Integer RETOUR

If !clalev([F:GVTW]) : Local File GENEVT [GVTW] : Endif


  Read [GVTW]GVT0=PEVT;PPLN
  If fstat
    RCOD=1    # Couple PEVT,PPLN inconnu
    End
  Endif

# Accéder à la table
# pour RéCUPéRER l'objet métier sur lequel s'applique l'action

  If !clalev([F:EVEW])
    Case POBJ
      When GVML_OMBIEN  : Local File EVEFAS [EVEW]
      When GVML_OMDEPEN : Local File EVELOF [EVEW]
      When GVML_OMLOCFI : Local File EVELEA [EVEW]
      When Default
    Endcase
  Endif

  # Traitement des différents types de données

  DATATYP="A" : Gosub TAS_DATATYP
  DATATYP="N" : Gosub TAS_DATATYP
  DATATYP="M" : Gosub TAS_DATATYP
  DATATYP="D" : Gosub TAS_DATATYP

End

$TAS_DATATYP
  Trbegin [GVTW]
  Call TAS_NUORD_TD("[F:GVTW]",DATATYP,RETOUR)
  If RETOUR
    Rollback
    Call ECR_TRACE("Le type de donnée"-DATATYP-"n'a pas pu être tassé",1) From GESECRAN
  Else
    Rewrite [GVTW]
    If fstat
      Rollback
      Call ECR_TRACE("Le type de donnée"-DATATYP-"n'a pas pu être tassé",1) From GESECRAN
    Else
      Call ECR_TRACE("Le type de donnée"-DATATYP-"a été correctement tassé",0) From GESECRAN
      Commit
    Endif
  Endif

Return

#=====================================================================
# S/p de tassement des trous dans les nuord pour un type de donnée   #
#=====================================================================
Subprog TAS_NUORD_TD(PCLASSE,PDATATYP,RCOD)
Value    Char    PCLASSE      # Classe contenant l'enregistrement EVT/PLN à tasser
Value    Char    PDATATYP     # type de données à traiter
Variable Integer RCOD         # Code retour

Local Integer  RETOUR
Local Integer  I_MAX
Local Integer  I_ZON
Local Integer  I_TROU
Local Integer  I_SUIVANT

#I_MAX=evalue("dim("+PCLASSE+"FLDORD)"+PDATATYP)

  If    PDATATYP="A" or  PDATATYP="N"
    I_MAX=40
  Elsif PDATATYP="M" or  PDATATYP="D"
    I_MAX=10
  Endif

  Raz I_TROU

  For I_ZON=0 To I_MAX-1
    If evalue(PCLASSE+"FLDNAM"+PDATATYP+"(I_ZON)=''")
      Break
    Endif

    If evalue(PCLASSE+"FLDORD"+PDATATYP+"(I_ZON)<>I_ZON")
      Call DEPLACE_ZON(PCLASSE,PDATATYP,I_ZON,evalue(PCLASSE+"FLDORD"+PDATATYP+"(I_ZON)"),RETOUR)
      If RETOUR
        RCOD=2
        End
      Endif
    Endif
  Next I_ZON

End

#=====================================================================
# S/p de tassement des trous dans les nuord pour un type de donnée   #
#=====================================================================
# RCOD   0   - S/p OK
#        80  - Erreur dans l'update
#=====================================================================
Subprog DEPLACE_ZON(PCLASSE,PDATATYP,PTROU,PSUIVANT,RCOD)
Value    Char    PCLASSE    # Classe contenant l'enregistrement EVT/PLN à tasser
Value    Char    PDATATYP   # Type de donnée en cours de traitement
Value    Integer PTROU      # Indice de la case où mettre les informations
Value    Integer PSUIVANT   # Indice des informations à déplacer
Variable Integer RCOD       # Code retour du s/p

Local Char NOMZON(30)

# On modifie le numéro d'ordre de la zone dans GENEVTD

If !clalev([F:GVDW]) : Local File GENEVTD [GVDW] : Endif

  Update [GVDW] Where (EVT=evalue(PCLASSE+"EVT")
&                  & PLN=evalue(PCLASSE+"PLN")
&                  & FLDNAM=evalue(PCLASSE+"FLDNAM"+PDATATYP+"("+num$(PTROU)+")"))
&             With  FLDORD=PTROU
  If fstat
    RCOD=80
    End
  Endif

  # On déplace ce qui était dans PSUIVANT dans PTROU et on initialise PSUIVANT

  NOMZON=PCLASSE+"FLDORD"+PDATATYP+"(PTROU)"    : Assign NOMZON With PTROU

End

#=====================================================================
# S/p de déplacement des zones d'un événement / plan d'un offset     #
# passé en paramètre pour un des types de donnée passé en paramètre  #
# Ce sous-pro s'applique à un enregistrement de GENEVT et à tous les #
# enregistrements correspondants de GENEVTD                          #
# Pour l'instant on ne gère que des offset positif                   #
#=====================================================================
# RCOD   0   - S/p OK
#        1   - Erreur d'accès à la table GENEVT
#        2   - Le couple PEVT/PPLN n'existe pas
#        3   - Le couple PEVT/PPLN est locké
#        4   - Erreur en mise à jour de la table GENEVT
#
#       11   - Erreur de mise à jour de GENEVTD
#
#       50   - L'offset dépasse le nombre de zone
#       51   - Offset trop grand pour pouvoir effectuer le déplacement
#
#=====================================================================
Subprog DEPLACE_BLOC(PEVT,PPLN,PDATATYP,POFFSET,RCOD)
Value    Char    PEVT
Value    Integer PPLN
Value    Char    PDATATYP
Value    Integer POFFSET
Variable Integer RCOD

If !clalev([F:GVTW]) : Local File GENEVT  [GVTW] : Endif
If !clalev([F:GVDW]) : Local File GENEVTD [GVDW] : Endif

  Trbegin [GVTW], [GVDW]

  # Accès à l'enregistrement EVT/PLN à traiter

  Read [GVTW]GVT0=PEVT;PPLN
  If fstat
    Case fstat
      When 1       : RCOD=3
      When 5       : RCOD=2
      When Default : RCOD=1
    Endcase
    Rollback
    End
  Endif

# Il existe on commence le traitement ...

Local Integer NB_ZON_MAX
Local Integer I_ZON
Local Integer LAST_ZON_NORD

# Détermination du nombre d'occurrence maxi pour le type de donnée passé en paramètre

  If    PDATATYP="A" or PDATATYP="N"
    NB_ZON_MAX = 40
  Elsif PDATATYP="M" or PDATATYP="D"
    NB_ZON_MAX = 10
  Endif

# Contrôle que l'offset n'est pas supérieur au nom d'occurrence du type de données

  If POFFSET >= NB_ZON_MAX
    RCOD = 50
    Rollback
    End
  Endif

# Récupération du nuord de la dernière zone paramètrée

  For I_ZON=0 To NB_ZON_MAX-1
    If evalue("[F:GVTW]FLDNAM"+PDATATYP+"("+num$(I_ZON)+")=''")
      Break
    Endif
    LAST_ZON_NORD=evalue("[F:GVTW]FLDORD"+PDATATYP+"("+num$(I_ZON)+")")
  Next I_ZON

# Contrôle que nuord de la dernière zone paramètrée + offset ne dépasse pas le nombre d'occurrence du type de données

  If LAST_ZON_NORD+POFFSET>=NB_ZON_MAX
    RCOD=51
    Rollback
    End
  Endif

# On effectue le déplacement dans [GVTW] pour chaque zone paramètrée

Local Char    NOM_ZON(30)
Local Integer NEW_NORD

  For I_ZON=0 To NB_ZON_MAX-1
    If evalue("[F:GVTW]FLDNAM"+PDATATYP+"("+num$(I_ZON)+")=''")
      Break
    Endif

    NOM_ZON  = "[F:GVTW]FLDORD"+PDATATYP+"("+num$(I_ZON)+")"
    NEW_NORD = evalue("[F:GVTW]FLDORD"+PDATATYP+"("+num$(I_ZON)+")+POFFSET")
    Assign NOM_ZON With NEW_NORD
  Next I_ZON

  Rewrite [F:GVTW]
  If fstat
    RCOD=4
    Rollback
    End
  Endif

# On effectue le déplacement dans [GVDW] pour chaque code interne

  For I_ZON=0 To NB_ZON_MAX-1
    If evalue("[F:GVTW]FLDNAM"+PDATATYP+"("+num$(I_ZON)+")=''")
      Break
    Endif
    Update [GVDW] Where evalue("EVT=[F:GVTW]EVT & PLN=[F:GVTW]PLN & FLDNAM=[F:GVTW]FLDNAM"+PDATATYP+"("+num$(I_ZON)+")")
&              With FLDORD=evalue("[F:GVTW]FLDORD"+PDATATYP+"("+num$(I_ZON)+")")
    If fstat
      RCOD=11
      Rollback
      End
    Endif
  Next I_ZON

  Commit
  RCOD=0

End

#=====================================================================
# S/p d'insertion des zones libres dans le paramètrage des événements#
# existant.                                                          #
# Ce sous-pro s'applique à un enregistrement de GENEVT et à tous les #
# enregistrements correspondants de GENEVTD                          #
# Pour l'instant on ne gère que des offset positif                   #
#=====================================================================
# RCOD   0   - S/p OK
# RCOD   11  - Erreur d'accès à la table GENEVT
# RCOD   51  - Erreur dans le s/p deplace_bloc td alpha
# RCOD   52  - Erreur dans le s/p deplace_bloc td numérique
# RCOD   53  - Erreur dans le s/p deplace_bloc td date
# RCOD   61  - Erreur dans la routine de création des enr ZL
#
#=====================================================================
Subprog INSER_ZL(PEVT,PPLN,RCOD)
Value    Char    PEVT      # Code événement à traiter
Value    Integer PPLN      # Plan d'amortissement
Variable Integer RCOD      # Code retour

Local Char    TYPE_ALPHA(30) : TYPE_ALPHA  = "A"
Local Char    TYPE_NUM(30)   : TYPE_NUM    = "N"
Local Char    TYPE_DATE(30)  : TYPE_DATE   = "D"
Local Integer TYPE_INT_A : TYPE_INT_A = 7
Local Integer TYPE_INT_M : TYPE_INT_M = 4
Local Integer TYPE_INT_C : TYPE_INT_C = 4
Local Integer TYPE_INT_D : TYPE_INT_D = 8
Local Char    ZL_PREF(30)    : ZL_PREF    = "USRFLD"
Local Char    ZL_ALPHA(30)   : ZL_ALPHA   = "A"
Local Char    ZL_MONTANT(30) : ZL_MONTANT = "M"
Local Char    ZL_COEFF(30)   : ZL_COEFF   = "C"
Local Char    ZL_DATE(30)    : ZL_DATE    = "D"
Local Integer ZL_NB_A    : ZL_NB_A    = 10
Local Integer ZL_NB_M    : ZL_NB_M    = 6
Local Integer ZL_NB_C    : ZL_NB_C    = 2
Local Integer ZL_NB_D    : ZL_NB_D    = 4

Local Integer DEP_ALPHA  : DEP_ALPHA = 10
Local Integer DEP_NUM    : DEP_NUM   = 8
Local Integer DEP_DATE   : DEP_DATE  = 4

Local Char    TRTCRIT(255)
Local Integer RETOUR

Local Integer RUP_EVTINT
Local Char    SAV_EVTINT(30)

Local Integer TRT_ALPHA : TRT_ALPHA= G_OUI
Local Integer TRT_NUM   : TRT_NUM  = G_OUI
Local Integer TRT_DATE  : TRT_DATE = G_OUI

If !clalev([F:GVDL]) : Local File GENEVTD [GVDL] : Endif
If !clalev([F:GVDE]) : Local File GENEVTD [GVDE] : Endif

# Positionnement des flag de traitement des différents types de données

  Filter [GVDL] Where (EVT=PEVT & PLN=PPLN)
  For [GVDL]
    If left$([F:GVDL]FLDNAM,len(ZL_PREF)+1)=ZL_PREF+ZL_ALPHA   : TRT_ALPHA   = G_NON : Endif
    If left$([F:GVDL]FLDNAM,len(ZL_PREF)+1)=ZL_PREF+ZL_MONTANT : TRT_NUM     = G_NON : Endif
    If left$([F:GVDL]FLDNAM,len(ZL_PREF)+1)=ZL_PREF+ZL_COEFF   : TRT_NUM     = G_NON : Endif
    If left$([F:GVDL]FLDNAM,len(ZL_PREF)+1)=ZL_PREF+ZL_DATE    : TRT_DATE    = G_NON : Endif
  Next
  Filter [GVDL]

# Décaler les nuord pour chaque type de données

  Call ECR_TRACE("-> Déplacement des zones existantes",0) From GESECRAN

  If    TRT_ALPHA=G_NON
    Call ECR_TRACE("     > Zones libres de type alpanumériques déjà présentes",0) From GESECRAN
  Elsif TRT_ALPHA=G_OUI
    Call DEPLACE_BLOC(PEVT,PPLN,TYPE_ALPHA,DEP_ALPHA,RETOUR)
    If RETOUR
      Call ECR_TRACE("s/p DEPLACE_BLOC"-num$(RETOUR),1) From GESECRAN
      RCOD=51
      End
    Endif
    Call ECR_TRACE("    > Zones alphanumériques de +"-num$(DEP_ALPHA)-"Ok",0) From GESECRAN
  Endif

  If TRT_NUM=G_NON
    Call ECR_TRACE("     > Zones libres de type numériques déjà présentes",0) From GESECRAN
  Elsif TRT_NUM=G_OUI
    Call DEPLACE_BLOC(PEVT,PPLN,TYPE_NUM,DEP_NUM,RETOUR)
    If RETOUR
      Call ECR_TRACE("s/p DEPLACE_BLOC"-num$(RETOUR),1) From GESECRAN
      RCOD=52
      End
    Endif
    Call ECR_TRACE("    > Zones numériques de +"-num$(DEP_NUM)-"Ok",0) From GESECRAN
  Endif

  If    TRT_DATE=G_NON
    Call ECR_TRACE("     > Zones libres de type date déjà présentes",0) From GESECRAN
  Elsif TRT_DATE=G_OUI
    Call DEPLACE_BLOC(PEVT,PPLN,TYPE_DATE,DEP_DATE,RETOUR)
    If RETOUR
      Call ECR_TRACE("s/p DEPLACE_BLOC"-num$(RETOUR),1) From GESECRAN
      RCOD=53
      End
    Endif
    Call ECR_TRACE("    > Zones date de +"-num$(DEP_DATE)-"Ok",0) From GESECRAN
  Endif

# Créer les enregistrements nécessaires pour chaque code interne existant
# A déplacer dans la traitement de chaque bloc pour conserver la cohérence du paramètrage

  Trbegin [GVDE]
  TRTCRIT="EVT=PEVT & PLN=PPLN"
  Filter [GVDL] Where evalue (TRTCRIT)
  Raz SAV_EVTINT
  For [GVDL]GVD2
    If SAV_EVTINT<>[F:GVDL]EVTINT
      Gosub CRE_ZL_ENR
      If GOK < 1
        Break
      Endif
      SAV_EVTINT=[F:GVDL]EVTINT
    Endif
  Next

  If GOK < 1
    RCOD=61
    Rollback
    Filter [GVDL]
    End
  Endif

  Commit
  Filter [GVDL]

End

#********************************************

$CRE_ZL_ENR
 Local Integer I_ZON
 Local Integer I_ZL

If (TRT_ALPHA=G_OUI | TRT_NUM=G_OUI | TRT_DATE=G_OUI)
 Call ECR_TRACE("-> Création des enregistrements ZL pour le code interne :"-[F:GVDL]EVTINT,0) From GESECRAN
Endif

#-> ZL de type alphanumérique

  If TRT_ALPHA=G_OUI
    Raz I_ZL
    For I_ZON=0 To ZL_NB_A-1
      I_ZL+=1
      [F:GVDE]=[F:GVDL]
      [F:GVDE]FLDTYP=TYPE_INT_A
      [F:GVDE]FLDNAM=ZL_PREF+ZL_ALPHA+num$(I_ZL)
      [F:GVDE]FLDORD=I_ZON
      Raz [F:GVDE]FLDFILO
      Raz [F:GVDE]FLDFILD
      Raz [F:GVDE]DES
      Write [F:GVDE]
      If fstat
        GOK=0
        Break
      Endif
    Next I_ZON

    If GOK<1
      Return
    Endif
    Call ECR_TRACE("    > Alphanumériques OK",0) From GESECRAN

  Endif

#-> ZL de type montant

  If TRT_NUM=G_OUI
    Raz I_ZL
    For I_ZON=0 To ZL_NB_M-1
      I_ZL+=1
      [F:GVDE]=[F:GVDL]
      [F:GVDE]FLDTYP=TYPE_INT_M
      [F:GVDE]FLDNAM=ZL_PREF+ZL_MONTANT+num$(I_ZL)
      [F:GVDE]FLDORD=I_ZON
      Raz [F:GVDE]FLDFILO
      Raz [F:GVDE]FLDFILD
      Raz [F:GVDE]DES
      Write [F:GVDE]
      If fstat
        GOK=0
        Break
      Endif
    Next I_ZON

    If GOK<1
      Return
    Endif
    Call ECR_TRACE("    > Montants OK",0) From GESECRAN

  Endif

#-> ZL de type coefficient

  If TRT_NUM=G_OUI
    Raz I_ZL
    For I_ZON=ZL_NB_M To ZL_NB_M+ZL_NB_C-1
      I_ZL+=1
      [F:GVDE]=[F:GVDL]
      [F:GVDE]FLDTYP=TYPE_INT_C
      [F:GVDE]FLDNAM=ZL_PREF+ZL_COEFF+num$(I_ZL)
      [F:GVDE]FLDORD=I_ZON
      Raz [F:GVDE]FLDFILO
      Raz [F:GVDE]FLDFILD
      Raz [F:GVDE]DES
      Write [F:GVDE]
      If fstat
        GOK=0
        Break
      Endif
    Next I_ZON

    If GOK<1
      Return
    Endif
    Call ECR_TRACE("    > Coefficients OK",0) From GESECRAN

  Endif

#-> ZL de type date

  If TRT_DATE=G_OUI
    Raz I_ZL
    For I_ZON=0 To ZL_NB_D-1
      I_ZL+=1
      [F:GVDE]=[F:GVDL]
      [F:GVDE]FLDTYP=TYPE_INT_D
      [F:GVDE]FLDNAM=ZL_PREF+ZL_DATE+num$(I_ZL)
      [F:GVDE]FLDORD=I_ZON
      Raz [F:GVDE]FLDFILO
      Raz [F:GVDE]FLDFILD
      Raz [F:GVDE]DES
      Write [F:GVDE]
      If fstat
        GOK=0
        Break
      Endif
    Next I_ZON

    If GOK<1
      Return
    Endif
    Call ECR_TRACE("    > Dates OK",0) From GESECRAN

  Endif

Return

#********************************************

#=====================================================================
# S/p permettant de supprimer les définitions déjà existantes des ZL #
# dans GENEVT sans supprimer les enregistrements ZL de GENEVTD       #
# Ce sous-pro s'applique à un enregistrement de GENEVT et à tous les #
# enregistrements correspondants de GENEVTD                          #
# On commence par supprimer les références au ZL dans GENEVTD puis   #
# on tasse les zones                                                 #
# Pour l'instant on ne gère que des offset positif                   #
#=====================================================================
# RCOD   0   - S/p OK
# RCOD   11  - Erreur d'accès à la table GENEVT
#=====================================================================
Subprog RETRAITE_ZL(PEVT,PPLN,RCOD)
Value    Char    PEVT   # Code événement à traiter
Value    Integer PPLN   # Plan d'amortissement à traiter
Variable Integer RCOD   # Code retour du sous-programme

If !clalev([F:GVTL]) : Local File GENEVT [GVTL] : Endif

Local Integer I_ZON
Local Integer RETOUR
Local Char    TAB_FLDNAM(10)(40)
Local Integer TAB_FLDORD(40)
Local Char    DATATYP(1)
Local Integer DATANBR
Local Integer OFFSET
Local Integer SAV_ORD_A
Local Integer SAV_ORD_N
Local Integer SAV_ORD_D
Local Integer SAV_ORD_M

  Trbegin [GVTL]

  Read [F:GVTL]GVT0=PEVT;PPLN
  If fstat
    RCOD=11
    Rollback
    End
  Endif

  Call ECR_TRACE ("-> Suppression des référence ZL dans GENEVT",0) From GESECRAN

#-> Suppression des ZL de GENEVT

DATATYP="A" : DATANBR=40 : Gosub FIL_TAB_FLD : Gosub REPORT_TAB_FLD
 Call ECR_TRACE ("     > ZL alphanumériques OK",0) From GESECRAN
DATATYP="N" : DATANBR=40 : Gosub FIL_TAB_FLD : Gosub REPORT_TAB_FLD
 Call ECR_TRACE ("     > ZL numériques OK",0) From GESECRAN
DATATYP="M" : DATANBR=10 : Gosub FIL_TAB_FLD : Gosub REPORT_TAB_FLD
DATATYP="D" : DATANBR=10 : Gosub FIL_TAB_FLD : Gosub REPORT_TAB_FLD
 Call ECR_TRACE ("     > ZL dates OK",0) From GESECRAN

#-> Réécriture de GENEVT

  Rewrite [GVTL]
  If fstat
    RCOD=11
    Rollback
    End
  Endif

  Commit
  Call ECR_TRACE ("     > Mise à jour de GENEVT Ok",0) From GESECRAN
  #-> Repositionnement des zones autres que ZL au bon nuord
  Call ECR_TRACE ("",0) From GESECRAN
  Call ECR_TRACE ("-> Repositionnement des zones autres que ZL dans GENEVT / GENEVTD",0) From GESECRAN
  DATATYP="A" : OFFSET=10-SAV_ORD_A : Call DEPLACE_BLOC(PEVT,PPLN,DATATYP,OFFSET,RETOUR)
  If !RETOUR
    Call ECR_TRACE ("     > Zones alphanumériques Ok - déplacement"-num$(OFFSET),0) From GESECRAN
  Endif
  DATATYP="N" : OFFSET=8-SAV_ORD_N : Call DEPLACE_BLOC(PEVT,PPLN,DATATYP,OFFSET,RETOUR)
  If !RETOUR
    Call ECR_TRACE ("     > Zones numériques Ok - déplacement"-num$(OFFSET),0) From GESECRAN
  Endif
  DATATYP="D" : OFFSET=4-SAV_ORD_D  : Call DEPLACE_BLOC(PEVT,PPLN,DATATYP,OFFSET,RETOUR)
  If !RETOUR
    Call ECR_TRACE ("     > Zones dates Ok - déplacement"-num$(OFFSET),0) From GESECRAN
  Endif

End

$FIL_TAB_FLD
Local Integer I_FIL : Raz I_FIL
  Raz TAB_FLDNAM, TAB_FLDORD

  For I_ZON=0 To DATANBR-1
    If evalue("[F:GVTL]FLDNAM"+DATATYP+"("+num$(I_ZON)+")<>''")
      If evalue ("!pat([F:GVTL]FLDNAM"+DATATYP+"("+num$(I_ZON)+"),'USRFLD*')")
        TAB_FLDNAM(I_FIL)=evalue("[F:GVTL]FLDNAM"+DATATYP+"("+num$(I_ZON)+")")
        TAB_FLDORD(I_FIL)=evalue("[F:GVTL]FLDORD"+DATATYP+"("+num$(I_ZON)+")")
        I_FIL+=1
      Endif
    Endif
  Next I_ZON

Return

$REPORT_TAB_FLD
 Local Char NOMZON(30)

  For I_ZON=0 To DATANBR-1
    NOMZON="[F:GVTL]FLDNAM"+DATATYP+"("+num$(I_ZON)+")" : Assign NOMZON With ""
    NOMZON="[F:GVTL]FLDORD"+DATATYP+"("+num$(I_ZON)+")" : Assign NOMZON With 0
  Next I_ZON

  For I_ZON=0 To DATANBR-1
    If TAB_FLDNAM(I_ZON)=""
      Break
    Endif

    NOMZON="[F:GVTL]FLDNAM"+DATATYP+"("+num$(I_ZON)+")" : Assign NOMZON With TAB_FLDNAM(I_ZON)
    NOMZON="[F:GVTL]FLDORD"+DATATYP+"("+num$(I_ZON)+")" : Assign NOMZON With TAB_FLDORD(I_ZON)
    If I_ZON=0
      NOMZON="SAV_ORD_"+DATATYP
      Assign NOMZON With TAB_FLDORD(I_ZON)
    Endif
  Next I_ZON

Return

#=====================================================================
# S/p permettant de remettre en cohérence les enregistrements évé    #
# nements déjà générés avec une modification du paramètrage de la    #
# description de cet événement.                                      #
# Seuls les modifications de numéro d'ordre sont traitées par ce s/p #
# Les infos dans les enregistrements événenements sont déplacés en   #
# fonction de la nouvelle description du couple type d'évt / plan    #
#=====================================================================
# RCOD   0   - S/p OK
# RCOD   1   - Erreur lors de la récupération du type d'objet associé
#              à l'événement.
# RCOD   2   - Type d'objet métier invalide ou non pris en compte par
#              le sous-programme
#
# RCOD  10+f - Erreur d'accès à la table GENEVT
# RCOD  20+f - Erreur d'accès à la table EVExxx
#
#
#=====================================================================
Subprog SYNC_EVE_PARM(PEVT,PPLN,POPTION,RCOD)
Value    Char    PEVT
Value    Integer PPLN
Value    Integer POPTION       # Option - 0 par défaut / 1 - contrôle cohérence seulement
Variable Integer RCOD

Local Integer OBJTYP           # type d'objet métier auquel est associé l'événement
Local Char    SPGCRIT(255)     # Critère de sélection du traitement
Local Char    DATATYP(1)       # Type de données à traiter
Local Integer DATANBR          # Nombre d'occurrence du type de données DATATYP
Local Integer I_ZON
Local Integer I_EVE
Local Integer DIFF
Local Integer NORD_PARAM
Local Integer NORD_EVE

#-> Récupération du type d'objet métier

  Call GET_OBJTYP_FROM_EVT(PEVT,OBJTYP)
  If OBJTYP
  Else
    RCOD=1
    End
  Endif

#-> Ouverture de la table événement en fonction de l'objet métier

  Case OBJTYP
  When GVML_OMBIEN
    If !clalev([F:EVEL]) : Local File EVEFAS [EVEL] : Endif
    If !clalev([F:EVER]) : Local File EVEFAS [EVER] : Endif
  When GVML_OMDEPEN
    If !clalev([F:EVEL]) : Local File EVELOF [EVEL] : Endif
    If !clalev([F:EVER]) : Local File EVELOF [EVER] : Endif
  When GVML_OMLOCFI
    If !clalev([F:EVEL]) : Local File EVELEA [EVEL] : Endif
    If !clalev([F:EVER]) : Local File EVELEA [EVER] : Endif
  When Default
    RCOD=2
    End
  Endcase

#-> Ouverture et lecture du paramètrage de l'événement

  If !clalev([F:GVTW]) : Local File GENEVT [GVTW] : Endif
  Read [GVTW]GVT0=PEVT:PPLN
  If fstat
    RCOD = 10 + fstat
    End
  Endif

  If POPTION = 0
    Trbegin [EVER]
  Endif

  #-> Pose du filtre sur EVEL et traitement des événements déjà générés

  SPGCRIT="EVT=PEVT & PLN=PPLN"
  Filter [EVEL] Where evalue(SPGCRIT)
  For [EVEL]
    If POPTION
      Call ECR_TRACE("   > "-[F:EVEL]REF-[F:EVEL]CREUSR-[F:EVEL]CREDAT-[F:EVEL]EVTINT-[F:EVEL]EVTDAT,0) From GESECRAN
      Gosub COMPARE_EVE
    Else
      GOK=1
      Gosub TRAITE_EVE
      If GOK<1
        Break
      Endif
    Endif
  Next
  Filter [EVEL]

# Terminaison de la transaction

  If !POPTION
    If GOK
      Commit
    Else
      Rollback
    Endif
  Endif

End

###### Traitement d'un enregistrement

$TRAITE_EVE

  If dim ([F:EVEL]LIN)>0
    Read [EVER]EFS0=[F:EVEL]CPY;[F:EVEL]EVT;[F:EVEL]PLN;[F:EVEL]REF;[F:EVEL]LIN;[F:EVEL]CREUSR;[F:EVEL]TIMSTP
  Else
    Read [EVER]EFS0=[F:EVEL]CPY;[F:EVEL]EVT;[F:EVEL]PLN;[F:EVEL]REF;[F:EVEL]CREUSR;[F:EVEL]TIMSTP
  Endif
  If fstat
    RCOD=20+fstat
    GOK=0
    Return
  Endif

  DATATYP="M" : DATANBR=10 : Gosub TRAITE_DATATYP
  DATATYP="A" : DATANBR=40 : Gosub TRAITE_DATATYP
  DATATYP="N" : DATANBR=40 : Gosub TRAITE_DATATYP
  DATATYP="D" : DATANBR=10 : Gosub TRAITE_DATATYP
  Rewrite [EVER]
  If fstat
    RCOD=20+fstat
    GOK=0
    Return
  Endif

Return

###### Traitement d'un type de données

$TRAITE_DATATYP

 Local Char NOMZON(30)

 # On nettoie les occurrences de l'enregistrement à réécrire

  For I_ZON=0 To DATANBR-1
   Case DATATYP
   When "A"
     Raz [F:EVER]FLDNAMA(I_ZON)
     Raz [F:EVER]FLDFILAO(I_ZON)
     Raz [F:EVER]FLDFILAD(I_ZON)
   When "N"
     Raz [F:EVER]FLDNAMN(I_ZON)
     Raz [F:EVER]FLDFILN(I_ZON)
   When "M"
     Raz [F:EVER]FLDNAMM(I_ZON)
     Raz [F:EVER]FLDFILMO(I_ZON)
     Raz [F:EVER]FLDFILMD(I_ZON)
   When "D"
     Raz [F:EVER]FLDNAMD(I_ZON)
     Raz [F:EVER]FLDFILD(I_ZON)
   When Default
   Endcase
  Next I_ZON

  For I_ZON=0 To DATANBR-1
    If evalue("[F:GVTW]FLDNAM"+DATATYP+"("+num$(I_ZON)+")<>''")
      Case DATATYP
      When "A" : I_EVE=find([F:GVTW]FLDNAMA(I_ZON),[F:EVEL]FLDNAMA)
      When "N" : I_EVE=find([F:GVTW]FLDNAMN(I_ZON),[F:EVEL]FLDNAMN)
      When "M" : I_EVE=find([F:GVTW]FLDNAMM(I_ZON),[F:EVEL]FLDNAMM)
      When "D" : I_EVE=find([F:GVTW]FLDNAMD(I_ZON),[F:EVEL]FLDNAMD)
      When Default
      Endcase
      If I_EVE=0         # La zone n'existe pas dans EVE, il faut la créer
        NORD_PARAM=evalue("[F:GVTW]FLDORD"+DATATYP+"("+num$(I_ZON)+")")
        NOMZON="[F:EVER]FLDNAM"+DATATYP+"("+num$(NORD_PARAM)+")"
        Assign NOMZON With evalue("[F:GVTW]FLDNAM"+DATATYP+"("+num$(NORD_PARAM)+")")
      Else
        I_EVE-=1
        NORD_PARAM = evalue("[F:GVTW]FLDORD"+DATATYP+"("+num$(I_ZON)+")")
        NORD_EVE   = I_EVE
        NOMZON="[F:EVER]FLDNAM"+DATATYP+"("+num$(NORD_PARAM)+")"
        Assign NOMZON With evalue("[F:EVEL]FLDNAM"+DATATYP+"("+num$(NORD_EVE)+")")
        If    DATATYP="A" | DATATYP="M"
          NOMZON="[F:EVER]FLDFIL"+DATATYP+"O("+num$(NORD_PARAM)+")"
          Assign NOMZON With evalue("[F:EVEL]FLDFIL"+DATATYP+"O("+num$(NORD_EVE)+")")
          NOMZON="[F:EVER]FLDFIL"+DATATYP+"D("+num$(NORD_PARAM)+")"
          Assign NOMZON With evalue("[F:EVEL]FLDFIL"+DATATYP+"D("+num$(NORD_EVE)+")")
        Elsif DATATYP="N" | DATATYP="D"
          NOMZON="[F:EVER]FLDFIL"+DATATYP+"("+num$(NORD_PARAM)+")"
          Assign NOMZON With evalue("[F:EVEL]FLDFIL"+DATATYP+"("+num$(NORD_EVE)+")")
        Endif
      Endif
    Endif
  Next I_ZON

Return

$COMPARE_EVE

  DATATYP="A" : DATANBR=40 : Gosub COMPARE_DATATYP
  If DIFF
    Call ECR_TRACE ("     > Déphasage sur les zones alphanumériques",1) From GESECRAN
  Endif
  DATATYP="N" : DATANBR=40 : Gosub COMPARE_DATATYP
  If DIFF
    Call ECR_TRACE ("     > Déphasage sur les zones numériques",1) From GESECRAN
  Endif
  DATATYP="M" : DATANBR=10 : Gosub COMPARE_DATATYP
  If DIFF
    Call ECR_TRACE ("     > Déphasage sur les zones menus locaux",1) From GESECRAN
  Endif
  DATATYP="D" : DATANBR=10 : Gosub COMPARE_DATATYP
  If DIFF
    Call ECR_TRACE ("     > Déphasage sur les zones dates",1) From GESECRAN
  Endif

Return

$COMPARE_DATATYP

  DIFF=0
  Local Char ZON_PARM(30)
  Local Char ZON_EVE(30)

  For I_ZON=0 To DATANBR-1
    If evalue("[F:GVTW]FLDNAM"+DATATYP+"("+num$(I_ZON)+")<>''")
      NORD_PARAM=evalue("[F:GVTW]FLDORD"+DATATYP+"("+num$(I_ZON)+")")
      ZON_PARM = evalue("[F:GVTW]FLDNAM"+DATATYP+"("+num$(I_ZON)+")")
      ZON_EVE  = evalue("[F:EVEL]FLDNAM"+DATATYP+"("+num$(NORD_PARAM)+")")
      If ZON_PARM<>ZON_EVE
        DIFF=1
        Break
      Endif
    Endif
  Next I_ZON

Return

#=====================================================================
# S/p permettant de récupérer le type d'objet métier auquel est      #
# rattaché l'événément passé en paramètre                            #
#=====================================================================
Subprog GET_OBJTYP_FROM_EVT(PEVT,ROBJTYP)
Value    Char    PEVT
Variable Integer ROBJTYP

  If !clalev([F:ADI]) : Local File ATABDIV : Endif
  Read [ADI]CODE=962;PEVT
  If fstat
    ROBJTYP=0
  Else
    ROBJTYP=[F:ADI]N2
  Endif

End

##########################################################################
# Gestion du masque de lancement VALEVT [VET]
##########################################################################


##########################################################################
Subprog AM_ALLEVT(VALEUR)
Variable Integer VALEUR
 If VALEUR=G_OUI
  Diszo [M:VET]EVT : Affzo [M:VET]EVT
  Diszo [M:VET]PLN : Affzo [M:VET]PLN
 Else
  Actzo [M:VET]EVT : Affzo [M:VET]EVT
 Endif
End

##########################################################################
Subprog AM_ALLPLN(VALEUR)
Variable Integer VALEUR
 If VALEUR=G_OUI & [M:VET]ALLEVT=G_OUI
  Diszo [M:VET]PLN : Affzo [M:VET]PLN
 Else
  Actzo [M:VET]PLN : Affzo [M:VET]PLN
 Endif
End


##########################################################################
Subprog AV_EVT(VALEUR)
Variable Char    VALEUR()
 If [M:VET]ALLEVT=G_OUI
  Diszo [M:VET]EVT
 Else
  Actzo [M:VET]EVT
 Endif
End

##########################################################################
Subprog AV_PLN(VALEUR)
Variable Integer VALEUR
 If [M:VET]ALLPLN=G_OUI
  Diszo [M:VET]PLN
 Else
  Actzo [M:VET]PLN
 Endif
End

