#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
######################################################################################
$OPENJBSCON

##--global variable to control if the conection is already opened
If dim(GDKSJAV)<=0
   Global Integer GDKSJAV : GDKSJAV = 0
Endif

If GDKSJAV = 1
    If GTRACE <> ""
        Call ECR_TRACE(mess(190,7711,1), 0) From GESECRAN
        If dim([L]PRIVCON)>0
          [L]PRIVCON = 0
        Endif
        Goto FOPENJBSCON
    Endif
Endif

#TODO activar o onerrgo
#Onerrgo ERR_OPEN

Opadxd [F:DKJ]SRVJAVA With 7, nomap, GLANGUE, GUSER, password Using [DKSB]

Onerrgo

If OK
    GDKSJAV = 1
    If GTRACE <> ""
        Call ECR_TRACE(mess(191,7711,1), 0) From GESECRAN
    Endif
Endif

FOPENJBSCON
Return
######################################################################################
######################################################################################
$DISPOSE

Calliu = "com.sage.x3.runtime.bundle.deamon.broker.CBroker:clear" With Using [DKSB]

Return
######################################################################################
######################################################################################
$CLOSEJBSCON

If dim([L]PRIVCON) > 0
  If ![L]PRIVCON
    Return
  Endif
Endif

Onerrgo ERR_CLOSE
Opadxd Using [DKSB]
Onerrgo

GDKSJAV = 0

If OK
    If GTRACE <> ""
        Call ECR_TRACE(mess(192,7711,1), 0) From GESECRAN
    Endif
Endif

Return
######################################################################################
######################################################################################
$ERR_OPEN

OK = 0

If GTRACE <> ""
    MESSAGE = mess(6,7711,1)
    Call ECR_TRACE(MESSAGE, 1) From GESECRAN
Endif

Resume
######################################################################################
######################################################################################
$ERR_CLOSE

OK = 0

If GTRACE <> ""
    MESSAGE = mess(7,7711,1)
    Call ECR_TRACE(MESSAGE, 1) From GESECRAN
Endif

Resume
######################################################################################
######################################################################################
