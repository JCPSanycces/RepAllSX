#<AdxTL>@(#)10.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Validation des fenêtres
#----------------------------------------------------------------------------------------#

Subprog GENE
Call OUVRE_TRACE("Validate All Windows") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub VALID
End

#-------------------#
$VALID

Local Integer I , VALMOD(20)

If DOSSIER<>GDOSX3
 For I=0 To dim(VALMOD)-1
  VALMOD(I) = 2
 Next I
Else
 VALMOD(0) = 2
 For I=1 To dim(VALMOD)-1
  VALMOD(I) = 2
 Next I
Endif

Call VALID_DIF(DOSSIER,0,"","","","","","","","","","","A","Z","","","","","","","","",VALMOD) From VALDICO

Close Local File

Return
