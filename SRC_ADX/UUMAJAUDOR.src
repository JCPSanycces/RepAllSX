#<AdxTL>@(#)2.0.0.0 $Revision$

#----------------------------------------------------------------------------------------#
# Mise à jour rowid des tables AUDITH,AUDITBI,AJSAUDIT sous Oracle (gestion des tiggers)
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Oracle : update trigger files") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJROW
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJROW
End

#-------------------#
$MAJROW
# Issue 84672 - 2012-10-15 by VPO : gestion ROWID AUDITH,AJSAUDIT,AUDITBI
#If GTYPDBA<>1 or filinfo(filpath("FIL","AUDITH","fde",DOSSIER),0)<=0 : Return : Endif
If GTYPDBA<>1 : Return : Endif
Local Integer STAT
Call SET_ROWID_OR(DOSSIER,STAT) From SUBTRIGGER
Return
