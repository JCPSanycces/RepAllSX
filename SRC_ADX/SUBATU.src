#<AdxTL>@(#)5.0.0.0 $Revision$
Raz GPILOBJ , GNBMASKOUV
Call OBJET("ATU",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
$ACTION
Case ACTION
 When "LIENS"     : Gosub LIENS
 When "LIENS2"    : Gosub LIENS2
 When "DEBUT_MOD" : Gosub DEBUT_MOD
 When "CREATION"  : Gosub CREATION
 When "SEL_TABLE" : Gosub SEL_TABLE
Endcase
Return

$LIENS
Call LECTEXTRA([M]INTIT(nolign-1),"TABSUBDIV","INTIT",[M]CRYTYP,[M]COD(nolign-1)) From ATEXTRA
Return

$LIENS2
Call INTIT_COL([M]CRY,[M]TYP,[M]INTCOD,[M]INTINT)
Return

Subprog INTIT_COL(CRY,TYP,INTCOD,INTINT)
Value Char CRY
Value Integer TYP
Variable Char INTCOD , INTINT
Local Char    INTIT(80)
Read [TCY]TCY0=CRY
If !fstat
 Case TYP
  When 2
   Call LECTEXTRA(INTIT,"TABCOUNTRY","ETATNAM",CRY,"") From ATEXTRA
  When 3
   Call LECTEXTRA(INTIT,"TABCOUNTRY","ETATNAM2",CRY,"") From ATEXTRA
 Endcase
 INTCOD = func AFNC.MES(mess(211,139,1),INTIT) : # Code
 INTINT = func AFNC.MES(mess(212,139,1),INTIT) : # Intitulé
Endif
End

$DEBUT_MOD
Delete [AXX] Where CODFIC="TABSUBDIV" & ZONE="INTIT" & LANGUE=GLANGUE & IDENT1=[M]CRYTYP
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX","*") From GLOCK : Return
Endif
Return

$CREATION
Call MAJTEXTRA([M]INTIT(nolign-1),"TABSUBDIV","INTIT",[M]CRYTYP,[M]COD(nolign-1)) From ATEXTRA
Return

######################################################################################
$SEL_TABLE
Case TABLE
 When "SELATU"
  OBJET = "AT0"
  CRITERE = 'CRY = "'+PARAM(1)+'"'
  CRITERE += '& TYP = '+PARAM(2)
  ORDRE = "[F:ATU]COD"
  START = "[F:ATU]COD"
Endcase
Return

######################################################################################
Subprog TUNATU(ETAT,CRY,TYP)
Variable Char    ETAT
Value Char CRY
Value Integer TYP
Call OBJET_LIB(TYP,"ATU",CRY+"~"+ETAT) From GOBJET
End

##################################################
Subprog CONATU(ETAT,CRY,TYP)
Variable Char    ETAT()
Value    Char    CRY
Value    Integer TYP
If GABREV<>"ATU"
 Read [ATU]ATU0=CRY;TYP;ETAT
 If fstat
  GMESSAGE = ETAT-":"-mess(23,100,1) : # Fiche inexistante
  mkstat = 2 : End
 Endif
Endif
End

######################################################################################
Subprog AS_TYP(VALEUR)
Variable Integer  VALEUR
GMENLOC(1) = 1
Read [TCY]TCY0=[M]CRY
If [F:TCY]ETATFLG<>2 : GMENLOC(2) = 1 : Endif
If [F:TCY]ETATFLG2<>2 : GMENLOC(3) = 1 : Endif
End

Subprog C_TYP(VALEUR)
Variable Integer VALEUR
[M]CRYTYP = [M]CRY+"~"+num$(VALEUR)
Call INTIT_COL([M]CRY,VALEUR,[M]INTCOD,[M]INTINT)
End

Subprog C_CRY(VALEUR)
Variable Char    VALEUR()
Read [TCY]TCY0=VALEUR
If [F:TCY]ETATFLG<>2 & [F:TCY]ETATFLG2<>2
 GMESSAGE = VALEUR-":"-mess(213,139,1) : # Ce pays ne permet pas de gérer les subdivisions
 mkstat = 2 : End
Endif
End

Subprog C_NBLIG
If status=65
 Look [ALB]ALB1=[M]COD(nolign-1);[M]CRY;[M]TYP
 If !fstat
  GMESSAGE = [M]COD(nolign-1)-":"-mess(1,115,1) : # Suppression impossible
  mkstat = 2 : End
 Endif
Endif
End

