#<AdxTL>@(#)4.0.0.0 $Revision$
#CHECK UNUSED_SOURCE

Subprog CHARG_DFC(SITE,DADSITE,ANNEE)
Value Char SITE()
Value Char DADSITE()
Value Char ANNEE ()
If ANNEE=""
 Filter[DFC] Where FCY=SITE
 Read[DFC]DFC0 Last
 If fstat=0 : ANNEE=[F:DFC]YEA : Endif
 Filter [DFC]
Endif
Effzo [M:FCYP]20
Read [F:DFC]DFC0=SITE;ANNEE
If !fstat
 [M:FCYP] = [F:DFC]
Endif
If !GIMPORT
 If DADSITE=SITE & [M:FCYP]DADFLG=2
  Actzo [M:FCYP]20
  Actzo [M:FCYP]BPASGE,BPADCL
Else
  Grizo [M:FCYP]20
  Grizo [M:FCYP]BPASGE,BPADCL
 Endif
Endif
Affzo[M:FCYP]20
End

Subprog CREDFC(SITE)
Value Char    SITE()
Delete [DFC] Where FCY=SITE & YEA=[M:FCYP]YEA
If fstat=1
 GOK = -1
 GLOCK = "$DADFCY"-SITE
 End
Elsif fstat>5
 GOK = 0
 Call RSTA("DFC",SITE) From GLOCK
 End
Endif
If [M:FCYP]DADFLG=2 & [M:FCYP]DADFCY=[M:FCY0]FCY
 [F:DFC]FCY = SITE
 [F:DFC]YEA = [M:FCYP]YEA
 [F:DFC]    = [M:FCYP]
 Write [DFC]
 If fstat
  GOK=0 : Call FSTA("DFC") From GLOCK
 Endif
Endif
End

#Sous-programme appelé en cas de modif : le site était un site
#de DADS mais ne l'est plus...
Subprog CTLDAD
If [M:FCYP]DADFLG<>2
 #Suppression des info DADS pour le site courant...
 Delete [DFC] Where FCY=[M:FCY0]FCY
 If fstat=1
  GOK = -1
  GLOCK = "$DADFCY"-[M:FCY0]FCY
  End
 Elsif fstat>5
  GOK = 0
  Call RSTA("DFC",[M:FCY0]FCY) From GLOCK
  End
 Endif
Endif
End

