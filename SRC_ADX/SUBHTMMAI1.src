#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion objet HTMMAI1
##########################################################################################################
$ACTION
  Case ACTION
    When Default
  Endcase
Return

##########################################################################################################
Funprog GET_TEXTE(IFNC, SLAN, SAUS, STXT, SERRMSG)
Value Integer IFNC
Value Char SLAN
Value Char SAUS
Variable Clbfile STXT
Variable Char SERRMSG

Local Integer IARENDRE

  IARENDRE = [V]CST_AYES
  Raz SERRMSG
  Raz STXT
  # ---------------------------------------------
  Local File HTMMAITXT [HTMMAI]
  # 1°) on cherche le texte dans la langue par rapport à l'utilisateur
  Read [HTMMAI]HTMMAI0=IFNC;SLAN;SAUS
  If fstat Then
    # 2°) sinon on cherche le texte dans la langue pour l'utilisateur par défaut (AUS="")
    Read [HTMMAI]HTMMAI0=IFNC;SLAN;""
    If fstat Then
      # 3°) sinon on cherche le texte dans la langue de connection par rapport à l'utilisateur
      Read [HTMMAI]HTMMAI0=IFNC;GLANGUE;SAUS
      If fstat Then
        # 4°) sinon on cherche le texte dans la langue de connection pour l'utilisateur par défaut (AUS="")
        Read [HTMMAI]HTMMAI0=IFNC;GLANGUE;""
        If fstat Then
          # 5°) sinon on cherche le texte en anglais par rapport à l'utilisateur
          Read [HTMMAI]HTMMAI0=IFNC;"ENG";SAUS
          If fstat Then
            # 6°) sinon on cherche le texte en anglais pour l'utilisateur par défaut (AUS="")
            Read [HTMMAI]HTMMAI0=IFNC;"ENG";""
            If fstat Then
              # Si on n'a pas trouvé de texte on rend une erreur
              # C'est une information pas une erreur
              #IARENDRE = [V]CST_ANO
              #SERRMSG = mess(1168,196,1)
              Call MESSAGE(mess(1168,196,1)) From GESECRAN
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
  # ---------------------------------------------
  If IARENDRE = [V]CST_AYES and SERRMSG = "" Then
    # La classe [F] contient l'enregistrement avec le texte
    # On regarde s'il y a du variable dans la chaine et on fait les substitutions
    IARENDRE = func SUBSTITUE_VARIABLE([F:HTMMAI]TXT1, SERRMSG)
    If IARENDRE = [V]CST_AYES Then
      STXT = [F:HTMMAI]TXT1
    Endif
  Endif
  # ---------------------------------------------
End IARENDRE

##########################################################################################################
Funprog SUBSTITUE_VARIABLE(STXT, SERRMSG)
Variable Clbfile STXT
Variable Char SERRMSG

  IARENDRE = [V]CST_AYES
  Raz SERRMSG
  # ---------------------------------------------
  IARENDRE = func SUBSTITUE_VARIABLE_BALISE("|", STXT, SERRMSG)
  #  IARENDRE = func SUBSTITUE_VARIABLE_BALISE("%%", STXT, SERRMSG)
  #  If IARENDRE = [V]CST_AYES Then
  #    IARENDRE = func SUBSTITUE_VARIABLE_BALISE("$$", STXT, SERRMSG)
  #  Endif
  # ---------------------------------------------
End IARENDRE

##########################################################################################################
Funprog SUBSTITUE_VARIABLE_BALISE(SBALISE, STXT, SERRMSG)
Value Char SBALISE
Variable Clbfile STXT
Variable Char SERRMSG

Local Integer IARENDRE
Local Integer NI
Local Integer NE
Local Char SFIELD(250)
Local Clbfile SMSG(6)

  #SBALISE = "%%"  => Champ de table
  #SBALISE = "$$"  => Formule évaluée
  ILENBALISE = len(SBALISE)
  # ---------------------------------------------
  IARENDRE = [V]CST_AYES
  Raz SERRMSG
  # ---------------------------------------------
  Raz SMSG
  NI = instr(1,STXT,SBALISE)
  If NI > 0 Then
    SMSG = left$(STXT,NI-1)
    NE = instr(NI+ILENBALISE,STXT,SBALISE)
    If NE > 0 Then
      Repeat
        SFIELD = mid$(STXT,NI+ILENBALISE,NE-NI-ILENBALISE)
        Case SBALISE
          When "%%"
            If evalue("dim(" + SFIELD + ")") > 0 Then
              SMSG += num$(evalue(SFIELD))
            Else
              SMSG += "*****"
            Endif
          When "$$", "|"
            Onerrgo ERR_SUBSTITUE_VARIABLE_BALISE
            SMSG += num$(evalue(SFIELD))
            Onerrgo
          When Default
        Endcase
        # ----------------
        NE += ILENBALISE
        # ----------------
        NI = instr(NE,STXT,SBALISE)
        If NI > 0 Then
          SMSG += mid$(STXT,NE,NI-NE)
          NE = instr(NI+ILENBALISE,STXT,SBALISE)
          If NE <= 0 Then
            # Erreur dans la gestion des balises
            IARENDRE = [V]CST_ANO
            SERRMSG = mess(1167,196,1) - "(" + SBALISE + ")" - "(" + mess([F:HTMMAI]FNC,2073,1) + "/" + [F:HTMMAI]LAN + "/" + [F:HTMMAI]AUS + ")"
            Break
          Endif
        Else
          # On récupère la fin de la chaine
          SMSG += mid$(STXT,NE,len(STXT))
        Endif
      Until NI = 0
    Else
      # Erreur dans la gestion des balises
      IARENDRE = [V]CST_ANO
      SERRMSG = mess(1167,196,1) - "(" + SBALISE + ")" - "(" + mess([F:HTMMAI]FNC,2073,1) + "/" + [F:HTMMAI]LAN + "/" + [F:HTMMAI]AUS + ")"
    Endif
  Else
    SMSG = STXT
  Endif
  If IARENDRE = [V]CST_AYES Then
    STXT = SMSG
  Endif
  # ---------------------------------------------
End IARENDRE

$ERR_SUBSTITUE_VARIABLE_BALISE
  SMSG += "?????"
Resume

