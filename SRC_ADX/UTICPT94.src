#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTICPT94   UTI process                                    Module CPT   #
#            correction utility
#
# Issue X3-59287 - 2017-11-08 by FHA : ST1 ST2 ST3 records replicated in GDD as STT1 STT2 STT3
# Issue X3-56195 - 2017-09-15 by GLE   : Fix issue on archive folders
#
##########################################################################


Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("GDD table Update: replication of ST* records as STT*") From LECFIC
  Call MAJ_UTICPT94(WDOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

Close Local File
End

##########################################################################
Subprog MAJ_UTICPT94(DOSSIER)
Value Char DOSSIER

# Issue X3-56195 - 2017-09-15 by GLE : Do not perform on archive folders
If (func DOSSUB.ISHISTFOLD(DOSSIER))
  Call ECR_TRACE("UTICPT94 : Not to perform on archive folder : "+DOSSIER,0) From GESECRAN
  End
Endif

Local Integer WCOMPTEUR
Call ECR_TRACE("UTICPT94 : GDD Update: replication of ST* records as STT*",0) From GESECRAN
Call ECR_TRACE("UTICPT94 : Start of process on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:GDD])  =0  Local File =DOSSIER+".GDIAENTRYD"   [GDD] : Endif
If clalev([F:GD2])  =0  Local File =DOSSIER+".GDIAENTRYD"   [GD2] : Endif
If clalev([F:GD3])  =0  Local File =DOSSIER+".GDIAENTRYD"   [GD3] : Endif

WCOMPTEUR = 0
Call DEBTRANS From GLOCK

Trbegin [GD2]
Filter [F:GDD] Where find(FLD,"ST1","ST2","ST3")<>0
For [F:GDD]GDD0
  # Transcodification
  Local Char WSTFLD
  Case [F:GDD]FLD
    When "ST1" : [L]WSTFLD="STT1"
    When "ST2" : [L]WSTFLD="STT2"
    When "ST3" : [L]WSTFLD="STT3"
  Endcase
  # Does a STT* record exixt already ?
  Look [F:GD3]GDD0=[F:GDD]DIA;[L]WSTFLD
  If fstat=0
    # yes
    Call ECR_TRACE("GDD:"-[F:GDD]DIA+"/"+[L]WSTFLD-"already exists"-DOSSIER,0) From GESECRAN
  Else
    # no so replicate ST* as STT*
    [F:GD2]=[F:GDD]
    [F:GD2]FLD=[L]WSTFLD
    Write [F:GD2]
    If !fstat
      WCOMPTEUR += 1
      Call ECR_TRACE("GDD:"-[F:GDD]DIA+"/"+[F:GDD]FLD-"replicated in"-[F:GD2]DIA+"/"+[F:GD2]FLD-DOSSIER,0) From GESECRAN
    Else
      Call ECR_TRACE("GDD:"-[F:GDD]DIA+"/"+[F:GDD]FLD-"replication failed"-DOSSIER,1) From GESECRAN
    Endif
  Endif
Next
Filter [F:GDD]
Commit


Close Local File [GDD]
Close Local File [GD2]
Close Local File [GD3]

Call ECR_TRACE("UTICPT94 : "+num$(WCOMPTEUR)+" records processed",0) From GESECRAN

End

########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

If APPLI=GDOSX3 : End : Endif

If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif

If [F:ADS]MODULE(1)<>2 : End : Endif                                 : # module compta

Call MAJ_UTICPT94(APPLI)
End

#######################################################################
# To execute during DOSMAJxx process (validation of folder)
# call by DOSMAJxx
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3: End : Endif
If [F:ADS]MODULE(1)<>2 : End : Endif                                 : # module compta

Call MAJ_UTICPT94(APPLI)
End

