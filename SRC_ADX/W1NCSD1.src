#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque NCSD1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:29"
A_USER  = "DOC"
A_STAMP = "20181109230529"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask NCSD1 [NCSD1]
Gosub HORODAT
Local Inpbox "NCSD1" From GFONCTION At A_STAMP With A_WINDPREV Mask [NCSD1] As [SIM_]
Grizo [NCSD1]10
Grizo [NCSD1]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [NCSD1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=14
X1(1)=1 : X2(1)=74 : Y1(1)=15 : Y2(1)=15
Return

$ON_NBLIG
Onevent BEFORE_INPUT Call AS_NBLIG From W1NCSD1
Return

Subprog IB_NBLIG
Local Decimal BASPAG
## Action STD
Call IB_NBLIG From SUBNCSDOC
Gosub _AFF
End

Subprog AS_NBLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(735,GBOUT1) From OBJDIV
Call IB_NBLIG
Onkey 129 Titled GBOUT1 Call B1_NBLIG From W1NCSD1
Gosub _AFF
End

Subprog B1_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action GOBJETC0
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC0"
 Local Char    OBJCLE(30)
 OBJCLE = [M:NCSD1]NCSID(nolign-1)
 Call OBJET_CHAR(OBJCLE,[M:NCSD1]CODOBJ(nolign-1),num$([M:NCSD1]VCRTYP(nolign-1))) From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_NCSID
Return

$ON_DOCTYP
Onevent INIT_AREA Call D_DOCTYP(zc) From W1NCSD1
Return

Subprog D_DOCTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]DOCTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_VCRNUM
Return

$ON_VCRTYP
Onevent INIT_AREA Call D_VCRTYP(zc) From W1NCSD1
Return

Subprog D_VCRTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]VCRTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_DOCDAT
Onevent BEFORE_AREA Gosub AV_DOCDAT From W1NCSD1
Return

$AV_DOCDAT
Chgfmt [M]DOCDAT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_NCSQTY
Onevent BEFORE_AREA Gosub AV_NCSQTY From W1NCSD1
Return

$AV_NCSQTY
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find("",GUNITE(1..GNBUNT)),1))
Endif
Chgfmt [M]NCSQTY(indice) With "NPz:"+GUNTFMT
Gosub _AFF
Return

$ON_DOCQTY
Onevent BEFORE_AREA Gosub AV_DOCQTY From W1NCSD1
Return

$AV_DOCQTY
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find("",GUNITE(1..GNBUNT)),1))
Endif
Chgfmt [M]DOCQTY(indice) With "NPz:"+GUNTFMT
Gosub _AFF
Return

$ON_BPSNUM
Return

$ON_BPCNUM
Return

$ON_PJT
Return

$ON_LINSTA
Onevent INIT_AREA Call D_LINSTA(zc) From W1NCSD1
Return

Subprog D_LINSTA(VALEUR)
Variable Integer VALEUR
If varinit([M]LINSTA,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_LSITE
Return

$ON_LDOCTYP
Onevent INIT_AREA Call D_LDOCTYP(zc) From W1NCSD1
Return

Subprog D_LDOCTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]LDOCTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$CHG_STY
Return


