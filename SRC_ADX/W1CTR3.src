$ON_NBRPSN
Onevent CONTROL Call C_NBRPSN From W1CTR3
Onevent BEFORE_INPUT Call AS_NBRPSN From W1CTR3
Return

Subprog IB_NBRPSN
Local Decimal BASPAG
## Action STD
Call IB_NBRPSN From SUBCTR
Gosub _AFF
End

Subprog AS_NBRPSN
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(45790,GBOUT1) From OBJDIV
Call IB_NBRPSN
Onkey 129 Titled GBOUT1 Call B1_NBRPSN From W1CTR3
Gosub _AFF
End

Subprog C_NBRPSN
Local Decimal BASPAG
## Action STD
Call C_NBRPSN From SUBCTR
If mkstat : GERR = 1 : GZONE = "NBRPSN" : GZNUM = 0 : Endif
Gosub _AFF
End

Subprog B1_NBRPSN
Local Decimal BASPAG
If !GWEBSERV
 ## Action GOBJETC0
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "GOBJETC0"
 Local Char    OBJCLE(30)
 OBJCLE = [M:CTR3]PYRDAT(nolign-1)
 Call OBJET_CHAR(OBJCLE,"VEP",[F:HRCTR]REFNUM+"~"+[M:CTR3]BUL(nolign-1)) From GOBJET
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_PSNSTRDAT
Onevent BEFORE_INPUT Call AS_PSNSTRDAT(zc) From W1CTR3
Onevent CONTROL Call C_PSNSTRDAT(zc) From W1CTR3
Onevent BEFORE_AREA Gosub AV_PSNSTRDAT From W1CTR3
Return

$AV_PSNSTRDAT
Chgfmt [M]PSNSTRDAT(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

Subprog AS_PSNSTRDAT(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action SUBCTRLEG
Call BEFORE_ENTRY(VALEUR) From SUBCTRLEG
If mkstat=2
 [M]PSNSTRDAT(INDIC) = VALEUR
 Affzo PSNSTRDAT(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

Subprog C_PSNSTRDAT(VALEUR)
Variable Date    VALEUR
## Action STD
Call C_PSNSTRDAT(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "PSNSTRDAT" : GZNUM = 1805 : Endif
Gosub _AFF
End

$ON_PSNENDDAT
Onevent BEFORE_INPUT Call AS_PSNENDDAT(zc) From W1CTR3
Onevent CONTROL Call C_PSNENDDAT(zc) From W1CTR3
Onevent BEFORE_AREA Gosub AV_PSNENDDAT From W1CTR3
Return

$AV_PSNENDDAT
Chgfmt [M]PSNENDDAT(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

Subprog AS_PSNENDDAT(VALEUR)
Variable Date    VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action SUBCTRLEG
Call BEFORE_ENTRY(VALEUR) From SUBCTRLEG
If mkstat=2
 [M]PSNENDDAT(INDIC) = VALEUR
 Affzo PSNENDDAT(INDIC) : mkstat = 2
Endif
Gosub _AFF
End

Subprog C_PSNENDDAT(VALEUR)
Variable Date    VALEUR
## Action DATDEBFIN
Call DATDEBFIN(VALEUR,[M]PSNSTRDAT(nolign-1)) From EXEFNC
If mkstat : GERR = 1 : GZONE = "PSNENDDAT" : GZNUM = 1806 : Endif
If !mkstat
 ## Action STD
 Call C_PSNENDDAT(VALEUR) From SUBCTR
 If mkstat : GERR = 1 : GZONE = "PSNENDDAT" : GZNUM = 1806 : Endif
Endif
Gosub _AFF
End

