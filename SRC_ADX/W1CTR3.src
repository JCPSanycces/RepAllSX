#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR3 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:43"
A_USER  = "DOC"
A_STAMP = "20181109230343"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRPSN"
  If [M]NBRPSN=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CTR3 [CTR3]
Gosub HORODAT
Local Inpbox "CTR3" From GFONCTION At A_STAMP With A_WINDPREV Mask [CTR3] As [SIM_]
Grizo [CTR3]10
Grizo [CTR3]20
Grizo [CTR3]30
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CTR3]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=31 : Y1(0)=1 : Y2(0)=4
X1(1)=32 : X2(1)=88 : Y1(1)=1 : Y2(1)=4
X1(2)=1 : X2(2)=88 : Y1(2)=5 : Y2(2)=23
Return

$ON_PSNTYP
Onevent INIT_AREA Call D_PSNTYP(zc) From W1CTR3
Onevent BEFORE_INPUT Call AS_PSNTYP(zc) From W1CTR3
Return

Subprog D_PSNTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]PSNTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_PSNTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_TYPCAC
Onevent BEFORE_INPUT Call AS_TYPCAC(zc) From W1CTR3
Onevent INIT_AREA Call D_TYPCAC(zc) From W1CTR3
Return

Subprog D_TYPCAC(VALEUR)
Variable Integer VALEUR
If varinit([M]TYPCAC,indice)=0
 VALEUR = 3
Endif
Gosub _AFF
End

Subprog AS_TYPCAC(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
## Action STD
Call AS_TYPCAC(VALEUR) From SUBCTR
If mkstat=2
 [M]TYPCAC(INDIC) = VALEUR
 Affzo TYPCAC(INDIC) : mkstat = 2
Endif
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_AEMNUM
Return

$ON_STACTR
Onevent AFTER_CHANGE Gosub AMM_STACTR From W1CTR3
Onevent INIT_AREA Call D_STACTR(zc) From W1CTR3
Onevent BEFORE_INPUT Call AS_STACTR(zc) From W1CTR3
Return

Subprog D_STACTR(VALEUR)
Variable Integer VALEUR
If varinit([M]STACTR,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_STACTR(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_STACTR
Call AM_STACTR(zc)
If !mkstat & GOBJET
 zoncou = "STACTR" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_STACTR(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_STACTR(VALEUR) From SUBCTR
If mkstat : GERR = 1 : GZONE = "STACTR" : GZNUM = 46622 : Endif
Gosub _AFF
End

