#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque ECP3 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBRPOT
mkstat = 0
zoncou = "NBRPOT"
indice = 0
status = 1
zoncou = "NBRPOT"
If varmode([M]NBRPOT,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NBRPOT From SUBECP
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NBRPOT : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRPOT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRPOT
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRPOT = nolign
   status = 75
   Call SAI_NBRPOT(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_NBRPOT From SUBECP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NBRPOT" : GZNUM = 0 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone WDATPOT
mkstat = 0
zoncou = "WDATPOT"
indice = 0
WDATE = [M]WDATPOT
If varmode([M]WDATPOT,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_WDATPOT([M]WDATPOT) From SUBECP
 GACTION = SAVACT
 If mkstat=1 : Raz [M]WDATPOT : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "WDATPOT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_WDATPOT([M]WDATPOT) From SUBECP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "WDATPOT" : GZNUM = 212 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   If WDATE<>[M]WDATPOT or IMPMOD
    SAVACT = GACTION : GACTION = "STD"
    Call AM_WDATPOT([M]WDATPOT) From SUBECP
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "WDATPOT" : GZNUM = 212 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone WORIGINE
mkstat = 0
zoncou = "WORIGINE"
indice = 0
IMPENT = [M]WORIGINE
If varinit([M]WORIGINE,indice)=0
 IMPENT = 2
Endif
[M]WORIGINE = IMPENT

## Zone WPOT
mkstat = 0
zoncou = "WPOT"
indice = 0
WCHAR = [M]WPOT
If varmode([M]WPOT,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_WPOT([M]WPOT) From SUBECP
 GACTION = SAVACT
 If mkstat=1 : Raz [M]WPOT : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "WPOT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_WPOT([M]WPOT) From SUBECP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "WPOT" : GZNUM = 22321 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Local Char    VALEUR(250)
   VALEUR = [M]WPOT
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
   [M]WPOT = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "WPOT" : GZNUM = 22321 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]WPOT or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_WPOT([M]WPOT) From SUBECP
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "WPOT" : GZNUM = 22321 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone WJOBPOT
mkstat = 0
zoncou = "WJOBPOT"
indice = 0
WCHAR = [M]WJOBPOT
If varmode([M]WJOBPOT,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_WJOBPOT([M]WJOBPOT) From SUBECP
 GACTION = SAVACT
 If mkstat=1 : Raz [M]WJOBPOT : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "WJOBPOT" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_WJOBPOT([M]WJOBPOT) From SUBECP
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "WJOBPOT" : GZNUM = 45853 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Local Char    VALEUR(250)
   VALEUR = [M]WJOBPOT
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
   [M]WJOBPOT = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "WJOBPOT" : GZNUM = 45853 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]WJOBPOT or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_WJOBPOT([M]WJOBPOT) From SUBECP
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "WJOBPOT" : GZNUM = 45853 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone WCAT2483
mkstat = 0
zoncou = "WCAT2483"
indice = 0
If varinit([M]WCAT2483,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]WCAT2483,"10453","") From SUBADI
 GACTION = SAVACT
Endif

## Zone WADD4
mkstat = 0
zoncou = "WADD4"
indice = 0
IMPENT = [M]WADD4
If varinit([M]WADD4,indice)=0
 IMPENT = 1
Endif
If varmode([M]WADD4,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_WADD4(IMPENT) From SUBECP
 GACTION = SAVACT
 If mkstat=1 : Raz IMPENT : Endif
 [M]WADD4(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "WADD4" : Gosub ACTION From =IMPTRT
  IMPENT = [M]WADD4(indice)
 Endif
Endif
[M]WADD4 = IMPENT

####################################
## Bloc liste 3
####################################
IMPTBL = 0

####################################
## Bloc tableau 4
####################################
IMPTBL = 1

indice = 0
status = 1
zoncou = "NBRSUPPOT"
If !mkstat
 NBLIG = [M]NBRSUPPOT
 For nolign=1 To NBLIG
  indice = nolign-1
  [M]NBRSUPPOT = nolign
  status = 75
  Call SAI_NBRSUPPOT(IMPFIC,ACTION,IMPTRT)
  If mkstat : Break : Endif
 Next nolign
 If mkstat : End : Endif
 indice = 0
Endif

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBRPOT(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRPOT
mkstat = 0
zoncou = "NBRPOT"
SAVACT = GACTION : GACTION = "STD"
Call C_NBRPOT From SUBECP
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "NBRPOT" : GZNUM = 0 : Endif
Gosub AFF From GSAISIE
If mkstat : End : Endif

## Zone ORIGINE
mkstat = 0
zoncou = "ORIGINE"
IMPENT = [M]ORIGINE(indice)
If varinit([M]ORIGINE,indice)=0
 IMPENT = 1
Endif
[M]ORIGINE(indice) = IMPENT

## Zone NBRPOT
mkstat = 0
zoncou = "NBRPOT"

End

####################################
## Bloc tableau 4
####################################
Subprog SAI_NBRSUPPOT(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1



End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "ECP3"
Return

