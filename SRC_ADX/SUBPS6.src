#<AdxTL>@(#)9.0.0.0 $Revision$
#
# Generation of the program that returns the JSON prototype
# Written by DOM
#

Subprog MAJTRT3(CODE,DOSSIER,SILENCE)
Value Char CODE
Value Char DOSSIER
Value Integer SILENCE

# Local variables
Local Char    MAGIC(80)
Local Char    MACHINE(GDIMFIC), APPLI(GDIMFIC)
Local Char    NOMTRT(GLONADC) , FICTRT(250)
Local Char    SAVIFS(5) , SAVIRS(5)
Local Integer SAVIUM
Local Integer OKVAL
Local Char    MESSAGE(250)

Local Integer I , J , K , K1 , K2 , C , NBFIC , STAT
Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

  If clalev([PS1]) : LogicClose File [PS1]  : Endif : Local File =APPLI+".PARSTA1"
  If clalev([PS2]) : LogicClose File [PS2]  : Endif : Local File =APPLI+".PARSTA2"
  If clalev([PSL]) : LogicClose File [PSL]  : Endif : Local File =APPLI+".PARSTALIG"
  If clalev([AXX]) : LogicClose File [AXX]  : Endif : Local File =APPLI+".ATEXTRA"
  If clalev([ATB]) : LogicClose File [ATB]  : Endif : Local File =APPLI+".ATABLE"
  If clalev([ATB1]): LogicClose File [ATB1] : Endif : Local File =APPLI+".ATABLE" [ATB1]
  If clalev([ATZ]) : LogicClose File [ATZ]  : Endif : Local File =APPLI+".ATABZON"
  If clalev([ATZ1]): LogicClose File [ATZ1] : Endif : Local File =APPLI+".ATABZON" [ATZ1]
  If clalev([ATY]) : LogicClose File [ATY]  : Endif : Local File =APPLI+".ATYPE"
  If clalev([ATY1]): LogicClose File [ATY1] : Endif : Local File =APPLI+".ATYPE" [ATY1]
  If clalev([AOB]) : LogicClose File [AOB]  : Endif : Local File =APPLI+".AOBJET"
  If clalev([ATI]) : LogicClose File [ATI]  : Endif : Local File =APPLI+".ATABIND"
  If clalev([ATX]) : LogicClose File [ATX]  : Endif : Local File =APPLI+".ATEXTE"
  If clalev([ACV]) : LogicClose File [ACV]  : Endif : Local File =APPLI+".ACTIV"
  If clalev([AST]) : LogicClose File [AST]  : Endif : Local File =APPLI+".APLSTD"
  If clalev([SAT]) : LogicClose File [SAT]  : Endif : Local File =APPLI+".STAT"
  If clalev([ADV]) : LogicClose File [ADV]  : Endif : Local File =APPLI+".ATABTAB" [ADV]
  If clalev([ACLA]): LogicClose File [ACLA] : Endif : Local File =APPLI+".ACLASSE" [ACLA]
  If clalev([ASW]) : LogicClose File [ASW]  : Endif : Local File =APPLI+".ASHW" [ASW]
  If clalev([ADWA]): LogicClose File [ADWA] : Endif : Local File =APPLI+".ADOVAL" [ADWA]



  Read [PS2]PS20=CODE

# Generation variable declaration
  Gosub DECL_GEN From AJSONLIB

# Let's start the generation with the header
  Gosub PREFIXE From SUBPS2
  PFIX3="STS"
  NOMTRT = "W"+LETTRE+PFIX3+CODE

  If !SILENCE
    Call TEMPON(mess(159,133,1)-NOMTRT) From GESECRAN : # Validation du traitement
  Endif

  OKVAL = 1
  Gosub GENETRT3

  If !OKVAL
    Call ECR_TRACE(MESSAGE,-1) From GESECRAN
    Openo
    Gosub DESACTIVE From SUBPS2
  Else
    Call VALID("TRT",NOMTRT,DOSSIER,STAT) From VALMSKSUB
  Endif

  If !SILENCE
    Call TEMPOFF From GESECRAN
  Endif

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM

End

$GENETRT3

# Local variables declaration
  Local Char KEYTEMP(GLONAVA),CLE1(200),CLE2(200),MAGIC(100)
  Local Integer I,J,K
  Local Integer NOABREV
  Local Integer IFTOTAL, IFPREVIOUS, IFBUDGET
  Local Char CRIT_STA(250)

# If NOABREV is set to 1, the variable names aren't prefixed by the abbreviation of the table,
# except if the abbrevations are given in the statistical definition
  NOABREV=1

# Miscellaneous variables
  Local Char ABVTAB(GLONABR)
  Local Integer FIRST_FLD,NB_FLD,FOUND
  Local Char FLDTEMP(GLONABR+GLONAVA+1),PROPTEMP(250), HIERTEMP(250), HIER_TEMP(250)

# Variables used for generation
# Bug fix when no field is present in the stat (found by HR team) - Dominique BOPP, Sept 1, 20140
  Local Integer DIMFLD
  DIMFLD=max([PS2]NBRFLD,1)
  Local Char HIERARCHY(100)(1..DIMFLD), PROPERTIES(100)(1..DIMFLD), FIELDNAME(100)(1..DIMFLD), HIERNAME(100)(1..DIMFLD)
  Local Char FIELDFORM(100)(1..DIMFLD),KEYTYP(100)(1..DIMFLD), KEYFLD(100)(1..DIMFLD), KEYLINK(100)(1..DIMFLD)
  Local Char KEYEXPR(100)(1..DIMFLD)
  Local Integer FIRSTFLD(1..DIMFLD),NBFLD(1..DIMFLD),KEYLENGTH(1..DIMFLD), FIELDLEN(1..DIMFLD), INTOBJ(1..DIMFLD)
  Local Integer NBHIER
  Local Char AMT_FMT(20)
  Local Decimal FMT_AMT

# Variables used during link analysis
  Local Char CODTYPE(10)
  Local Integer TYPLEN
  Local Integer TABNUMB
  Local Char CLASSCODE(20)
  Local Char REPCODE(20)
  Local Char MAINTABLE(20)
  Local Char MAINKEYFIELD(20)
  Local  Integer FLDLABEL
  Local Char LINKEXPR(200)
  Local Integer OKPR, IF_DEFFMT

# Variables used for storing statistical lines definition
  Local Libelle FRTFLG(1..dim([PS2]CUMFRM))
  Local Integer NBRAMT

  NBRAMT=0
  For [PSL]PSL0 Where COD=[PS2]COD
    I=[PSL]NUMLIG
    FRTFLG(I)=[PSL]FRTFLG
    NBRAMT=max(NBRAMT,I)
  Next

# Miscellaneous assignments
  MAGIC  = mess(77,133,1) : # Adonix Supervisor

# Statistic code analysis : PS2 is on line
  FIRST_FLD=1 : NB_FLD=0 : FOUND=0
  NBHIER=1 : PROPTEMP="" : HIERTEMP=""
  For I=1 To [PS2]NBRFLD
    ABVTAB=[PS2]TBLABR(I-1)
    If ABVTAB="" and NOABREV=0
        Read [ATB]CODFIC=[PS2]TBL(I-1)
        If fstat=0
            ABVTAB=[ATB]ABRFIC
        Else
            ABVTAB=""
        Endif
    Endif
    FLDTEMP=toupper(ABVTAB)+string$(ABVTAB<>"","_")+toupper([PS2]FLDNAM(I-1))+string$([PS2]FLDIND(I-1)<>0,"_"+num$([PS2]FLDIND(I-1)))

    # If a field group has been created, use it to define "real" hierarchies
    If (I>1 and (dim([PS2]FLDGRP)<0 or [PS2]FLDGRP(I-1)="" or [PS2]FLDGRP(I-2)<>[PS2]FLDGRP(I-1)))
        HIERARCHY(NBHIER)=HIER_TEMP
        PROPERTIES(NBHIER)=PROPTEMP
        HIERNAME(NBHIER)=HIERTEMP
        FIRSTFLD(NBHIER)=FIRST_FLD
        NBFLD(NBHIER)=NB_FLD
        PROPTEMP=""
        HIERTEMP=""
        FIRST_FLD=I
        NB_FLD=0
        NBHIER+=1
    Endif
    PROPTEMP+=string$(PROPTEMP<>"","/")+FLDTEMP
    NB_FLD+=1
    FIELDNAME(I)=FLDTEMP

    Read [ATZ]CODZONE=[PS2]TBL(I-1);[PS2]FLDNAM(I-1)
    If fstat=0
        TABNUMB=[ATZ]NOLIB
        CODTYPE=[ATZ]CODTYP
        Call GET_PAR_TYPE(CODTYPE,TYPLEN,TABNUMB,CLASSCODE,REPCODE,MAINTABLE,MAINKEYFIELD,FLDLABEL,LINKEXPR,OKPR)
        FIELDFORM(I)=string$(CODTYPE="M" and TABNUMB>1,"LA"+num$(TABNUMB)+":"+num$(TYPLEN)+"X")
        If OKPR=0
            Read [ATY]CODTYP=CODTYPE
            KEYTYP(I)=func AJSONLIB.TYPZON([ATY]TYPTYP,TABNUMB)
            KEYLENGTH(I)=TYPLEN
            KEYFLD(I)=MAINKEYFIELD
            KEYLINK(I)=toupper(REPCODE)
            KEYEXPR(I)=LINKEXPR
            INTOBJ(I)=FLDLABEL
        Else
            KEYTYP(I)=func AJSONLIB.TYPZON([ATY]TYPTYP,[ATZ]NOLIB)
            KEYLINK(I)=string$([ATZ]NOLIB>1,"~"+num$([ATZ]NOLIB))
        Endif
        FIELDLEN(I)=[PS2]FLDLON(I-1)
    Else
        KEYTYP(I)=func AJSONLIB.TYPZON([ATY]TYPTYP,[ATZ]NOLIB)
    Endif

    If HIERTEMP=""
        HIER_TEMP="func ASYRREQ.T(L,P,'"+[PS2]COD+"',F,"+num$(I)+")"
    Else
        HIER_TEMP+="+'/'+func ASYRREQ.T(L,P,'"+[PS2]COD+"',F,"+num$(I)+")"
    Endif
    HIERTEMP+=string$(HIERTEMP<>"","_")+FLDTEMP

    If I=[PS2]NBRFLD
        HIERARCHY(NBHIER)=HIER_TEMP
        PROPERTIES(NBHIER)=PROPTEMP
        HIERNAME(NBHIER)=HIERTEMP
        FIRSTFLD(NBHIER)=FIRST_FLD
        NBFLD(NBHIER)=NB_FLD
    Endif
  Next I

# Set IFTOTAL to 1 if aggregated amounts are required
  IFTOTAL=0
  For I=0 To [PS2]NBRFRM-1
    If [PS2]CUMFRM(I)>2
        IFTOTAL=1
        Break
    Endif
  Next I

# Set IFPREVIOUS to 1 if amount of previous period are required
  IFPREVIOUS=sigma(0,[PS2]NBRFRM-1,pat(" "+ctrans([PS2]AMTFRM(indcum),",+-/*^()[]",space$(10))+" ","* CC# *")
&                                 +pat(" "+ctrans([PS2]AMTFRM(indcum),",+-/*^()[]",space$(10))+" ","* PP# *"))<>0

# Set IFBUDGET to 1 if budgets are required
  IFBUDGET=sigma(1,[PS2]NBRFRM,[L]FRTFLG(indcum)>1)<>0

# Start the generation
  COMMENT=mess(6,124,1)-[PS2]COD-format$("D:YYYY[-]MM[-]DD[T]hh[:]mm[:]ss",date$) : # Statistic structure filling
  Gosub DEB_GEN From AJSONLIB

# PROTO JSON subprog generation
  Gosub JPRO_HEAD_GEN From AJSONLIB

# Miscellaneous declaration
  Wrseq Using [SSS_]
  Wrseq "# Miscellaneous declarations" Using [SSS_]
  Wrseq "Local Char P(10) : P='PARSTA2'" Using [SSS_]
  Wrseq "Local Char F(10) : F='FLDINTIT'" Using [SSS_]

  Wrseq "Local Char L(10) : L=ACTX.LAN" Using [SSS_]
  Wrseq "Local Integer FIRST_E" Using [SSS_]
  Wrseq "Local Char DOL_KEY(10) : DOL_KEY="+'"'+"'{$key}'"+'"' Using [SSS_]
  Wrseq "Local Char QUO_STA(20) : QUO_STA="+'"'+"'"+[PS2]COD+"'"+'"' Using [SSS_]
  Wrseq "" Using [SSS_]
  Wrseq Using [SSS_]

# Init
  NBP=0 : Gosub PRO_GEN From AJSONLIB

# Base URL and computed formula because simple quotes are nested in double quotes
  PRF="{"
  NBP+=1 : PRO(NBP)="$baseUrl" : TYP(NBP)=4 : VLE(NBP)="PSYR.PREFIX"
  NBP+=1 : PRO(NBP)="$url" : TYP(NBP)=4 : VLE(NBP)='"{$baseUrl}/STAT("+toupper(QUO_STA)+")?representation=STAT~'+[PS2]COD+'.$cube&role={$role}"'
  POF=","
  Gosub PRO_GEN From AJSONLIB

# Tile and type
  NBP+=1 : PRO(NBP)="$title" : TYP(NBP)=4 : VLE(NBP)='func ASYRREQ.T(L,"PARSTA2","'+[PS2]COD+'","INTIT",0)'
  POF=","
  Gosub PRO_GEN From AJSONLIB

  NBP+=1 : PRO(NBP)="$type" : TYP(NBP)=4
  VLE(NBP)='"application/json; vnd.sage=syracuse.presentation=x3.erp.superv/STAT("+toupper(QUO_STA)+")"'
  POF=","
  Gosub PRO_GEN From AJSONLIB

  NBP+=1 : PRO(NBP)="$methods" : TYP(NBP)=3 : VLE(NBP)="GET"
  NBP+=1 : PRO(NBP)="codeStat" : VLE(NBP)=[PS2]COD
  NBP+=1 : PRO(NBP)="$properties" : TYP(NBP)=5

# Just for test : adds deb/end dates, next/previous deb/end with links on them
  Local Char FLOOP_SE(20)
  Local Integer FLOOP_12
  For FLOOP_SE="start","end"
    For FLOOP_12=1 To 1+IFPREVIOUS
      NBP+=1 : PRO(NBP)="dat"+FLOOP_SE+num$(FLOOP_12) : TYP(NBP)=5
      NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/x-date"
      NBP+=1 : PRO(NBP)="$title" : TYP(NBP)=4 : VLE(NBP)="func M(L,126,"+num$(277+(FLOOP_SE="end"))+") + ' ' + " + '"'+ num$(FLOOP_12)+ '"'
      NBP+=1 : PRO(NBP)="$isAdvanced" : TYP(NBP)=1 : VLE(NBP)="1"
      NBP+=1 : PRO(NBP)="$links" : TYP(NBP)=5
      NBP+=1 : PRO(NBP)="$details" : TYP(NBP)=5
      Gosub PRO_GEN From AJSONLIB
      Wrseq APWCB+'"$url":"{$baseUrl}/STATS('+"'+QUO_STA+"+"')?representation=STATS~"+[PS2]COD+'.$cube&{link'+FLOOP_SE+'P}'+DQ+","+Q Using [SSS_]
      NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/json;vnd.sage=syracuse"
      POF="}}" : Gosub PRO_GEN From AJSONLIB
      POF="}," : Gosub PRO_GEN From AJSONLIB
    Next
    NBP+=1 : PRO(NBP)="link"+FLOOP_SE+"P" : TYP(NBP)=5
    NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/x-string"
    NBP+=1 : PRO(NBP)="$isExcluded" : TYP(NBP)=1 : VLE(NBP)="1"
    POF="}," : Gosub PRO_GEN From AJSONLIB
  Next
  If [PS2]UPDLEV>=2
    NBP+=1 : PRO(NBP)="def_company" : TYP(NBP)=5
    NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/x-string"
    NBP+=1 : PRO(NBP)="$title" : TYP(NBP)=4 : VLE(NBP)="func M(L,45,2)"
    NBP+=1 : PRO(NBP)="$isAdvanced" : TYP(NBP)=1 : VLE(NBP)="1"
    NBP+=1 : PRO(NBP)="$links" : TYP(NBP)=5
    NBP+=1 : PRO(NBP)="$details" : TYP(NBP)=5
    NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/json;vnd.sage=syracuse"
    POF="," : Gosub PRO_GEN From AJSONLIB
    NBP+=1 : PRO(NBP)="$url" :  TYP(NBP)=4 : VLE(NBP)='"{$baseUrl}/COMPANY('+"'{def_company}')?representation=COMPANY.$details&role={$role}"+'"'
    POF="}}},"
    Gosub PRO_GEN From AJSONLIB
  Endif
  If [PS2]UPDLEV=3
    NBP+=1 : PRO(NBP)="def_facility" : TYP(NBP)=5
    NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/x-string"
    NBP+=1 : PRO(NBP)="$title" : TYP(NBP)=4 : VLE(NBP)="func M(L,45,3)"
    NBP+=1 : PRO(NBP)="$isAdvanced" : TYP(NBP)=1 : VLE(NBP)="1"
    NBP+=1 : PRO(NBP)="$maxlength" : VLE(NBP)=num$(GLONCPY) : TYP(NBP)=2
    POF="," : Gosub PRO_GEN From AJSONLIB
    NBP+=1 : PRO(NBP)="$links" : TYP(NBP)=5
    NBP+=1 : PRO(NBP)="$details" : TYP(NBP)=5
    NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/json;vnd.sage=syracuse"
    POF="," : Gosub PRO_GEN From AJSONLIB
    NBP+=1 : PRO(NBP)="$url" :  TYP(NBP)=4 : VLE(NBP)='"{$baseUrl}/FACILITY('+"'{def_facility}')?representation=FACILITY.$details&role={$role}"+'"'
    NBP+=1 : PRO(NBP)="$target" : TYP(NBP)=4 : VLE(NBP)='"main"'
    POF="}}},"
    Gosub PRO_GEN From AJSONLIB
  Endif
# End of test

  NBP+=1 : PRO(NBP)="$resources" : TYP(NBP)=5
  Gosub PRO_GEN From AJSONLIB

  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/x-array"
  NBP+=1 : PRO(NBP)="$provType" : VLE(NBP)="PORTALSTA"

# Add the parameters
  NBP+=1 : PRO(NBP)="$criteria" : TYP(NBP)=5
  Gosub PRO_GEN From AJSONLIB
  J=0

# Add the company and facility parameter
  If [PS2]UPDLEV=3
    NBP+=1 : PRO(NBP)="FACILITY" : TYP(NBP)=5
    NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/x-string"
    NBP+=1 : PRO(NBP)="$maxlength" : VLE(NBP)=num$(GLONFCY) : TYP(NBP)=2
    POF="," : Gosub PRO_GEN From AJSONLIB
    Wrseq APWCB;'"$title":"'+"'+func E(L,'FACILITY')+'"+'",'+"'" Using [SSS_]
    NBP+=1 : PRO(NBP)="$links" : TYP(NBP)=5
    NBP+=1 : PRO(NBP)="$details" : TYP(NBP)=5
    NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/json;vnd.sage=syracuse"
    POF="," : Gosub PRO_GEN From AJSONLIB
    NBP+=1 : PRO(NBP)="$url" :  TYP(NBP)=4 : VLE(NBP)='"{$baseUrl}/FACILITY('+"'{FACILITY}')?representation=FACILITY.$details&role={$role}"+'"'
    NBP+=1 : PRO(NBP)="$target" : TYP(NBP)=4 : VLE(NBP)='"main"'
    POF="}}}" : J=1
    Gosub PRO_GEN From AJSONLIB
  Endif
  If [PS2]UPDLEV>=2
    PRF=string$(J,",") : J=1
    NBP+=1 : PRO(NBP)="COMPANY" : TYP(NBP)=5
    NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/x-string"
    NBP+=1 : PRO(NBP)="$maxlength" : VLE(NBP)=num$(GLONCPY) : TYP(NBP)=2
    POF="," : Gosub PRO_GEN From AJSONLIB
    Wrseq APWCB;'"$title":"'+"'+func E(L,'COMPANY')+'"+'",'+"'" Using [SSS_]
    NBP+=1 : PRO(NBP)="$links" : TYP(NBP)=5
    NBP+=1 : PRO(NBP)="$details" : TYP(NBP)=5
    NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/json;vnd.sage=syracuse"
    POF="," : Gosub PRO_GEN From AJSONLIB
    NBP+=1 : PRO(NBP)="$url" :  TYP(NBP)=4 : VLE(NBP)='"{$baseUrl}/COMPANY('+"'{COMPANY}')?representation=COMPANY.$details&role={$role}"+'"'
    NBP+=1 : PRO(NBP)="$target" : TYP(NBP)=4 : VLE(NBP)='"main"'
    POF="}}}" : J=1
    Gosub PRO_GEN From AJSONLIB
  Endif

  PRF=string$(J,",")
  NBP+=1 : PRO(NBP)="DATBEG1" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/x-date"
  NBP+=1 : PRO(NBP)="$title"
  POF="},"
  Gosub PRO_GEN From AJSONLIB

  NBP+=1 : PRO(NBP)="DATEND1" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/x-date"
  NBP+=1 : PRO(NBP)="$title"
  POF="}"
  Gosub PRO_GEN From AJSONLIB
  J=1

  If IFPREVIOUS
    PRF=string$(J,",")
    NBP+=1 : PRO(NBP)="DATBEG2" : TYP(NBP)=5
    NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/x-date"
    NBP+=1 : PRO(NBP)="$title"
    POF="},"
    Gosub PRO_GEN From AJSONLIB
    NBP+=1 : PRO(NBP)="DATEND2" : TYP(NBP)=5
    NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/x-date"
    NBP+=1 : PRO(NBP)="$title"
    POF="}"
    Gosub PRO_GEN From AJSONLIB
  Endif

  PRF="},"
  NBP+=1 : PRO(NBP)="$item" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/json"
  POF=","
  Gosub PRO_GEN From AJSONLIB

  NBP+=1 : PRO(NBP)="$url" : TYP(NBP)=4
  VLE(NBP)='"{$baseUrl}/stats("+QUO_STA+")?representation=$cube("+QUO_STA+")&role={$role}"'
  POF=","
  Gosub PRO_GEN From AJSONLIB

  NBP+=1 : PRO(NBP)="$title" : TYP(NBP)=4
  VLE(NBP)='func ASYRREQ.T(L,"PARSTA2","'+[PS2]COD+'","INTIT",0)'
  NBP+=1 : PRO(NBP)="$properties" : TYP(NBP)=5
  Gosub PRO_GEN From AJSONLIB

  NBP+=1 : PRO(NBP)="linkDown" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/x-string"
  NBP+=1 : PRO(NBP)="$isExcluded": VLE(NBP)="1" : TYP(NBP)=1
  POF="},"
  Gosub PRO_GEN From AJSONLIB

# Date field (constant)
  NBP+=1 : PRO(NBP)="dateStat" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/x-date"
  NBP+=1 : PRO(NBP)="$capabilities": VLE(NBP)="sort,filter"
  NBP+=1 : PRO(NBP)="$isExcluded": VLE(NBP)="1" : TYP(NBP)=1
  POF="},"
  Gosub PRO_GEN From AJSONLIB

# Loop on fields
  For I=1 To [PS2]NBRFLD

    NBP+=1 : PRO(NBP)=FIELDNAME(I) : TYP(NBP)=5
    NBP+=1 : PRO(NBP)="$title" : TYP(NBP)=4 : VLE(NBP)='func ASYRREQ.T(L,"PARSTA2","'+[PS2]COD+'","FLDINTIT",'+num$(I)+')'
    NBP+=1 : PRO(NBP)="$capabilities" : VLE(NBP)="sort,filter"
    NBP+=1 : PRO(NBP)="$type"
    If left$(KEYLINK(I),1)="~" : # Local menu
      VLE(NBP)=KEYTYP(I)
      POF=","
      Gosub PRO_GEN From AJSONLIB
      NUMLOC=val(right$(KEYLINK,2))
      Gosub MEN_GEN From AJSONLIB
      POF="},"
      Gosub PRO_GEN From AJSONLIB
    Elsif KEYLINK(I)<>""
      VLE(NBP)=KEYTYP(I)
      POF=","
      Gosub PRO_GEN From AJSONLIB
      NBP+=1 : PRO(NBP)="$links" : TYP(NBP)=5
      NBP+=1 : PRO(NBP)="$details" : TYP(NBP)=5
      NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/json;vnd.sage=syracuse"
      POF="," : Gosub PRO_GEN From AJSONLIB
      NBP+=1 : PRO(NBP)="$url" : TYP(NBP)=4
      VLE(NBP)='"{$baseUrl}/'+KEYLINK(I)+"('{"+FIELDNAME(I)+"}')?representation="+KEYLINK(I)+'.$details&role={$role}"'
      NBP+=1 : PRO(NBP)="$target" : TYP(NBP)=4 : VLE(NBP)='"main"'
      POF="}}}," : J=1
      Gosub PRO_GEN From AJSONLIB
    Else
      VLE(NBP)=KEYTYP(I)
      NBP+=1 : PRO(NBP)="$constraints" : TYP(NBP)=5
      NBP+=1 : PRO(NBP)="$maxLength" : TYP(NBP)=2 : VLE(NBP)=num$(FIELDLEN(1))
      POF="},"
      Gosub PRO_GEN From AJSONLIB
      NBP+=1 : PRO(NBP)="$capabilities" : VLE(NBP)="sort,filter"
      NBP+=1 : PRO(NBP)="$isHidden" : TYP(NBP)=1 : VLE(NBP)="0"
      NBP+=1 : PRO(NBP)="$isParameter" : TYP(NBP)=1 : VLE(NBP)="1"
      POF="},"
      Gosub PRO_GEN From AJSONLIB
    Endif
### SAM #10917 fix
    NBP+=1 : PRO(NBP)="C_"+FIELDNAME(I) : TYP(NBP)=5
    NBP+=1 : PRO(NBP)="$capabilities" : VLE(NBP)="sort,filter"
    NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/x-string"
    POF="},"
    Gosub PRO_GEN From AJSONLIB
### End of SAM #10917 fix
  Next I

# Get the default format
    #93020 AMT_FMT = fmet GACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,"","FMTSTA")
    Read [ADWA]ADW0="";"";"FMTSTA"
    If fstat
     AMT_FMT="12.2#"
    Else
     AMT_FMT=[F:ADWA]VALEUR
    Endif
    For J=12 To 2 Step -1
      K=instr(1,AMT_FMT,string$(J,'#'))
      If K : AMT_FMT=left$(AMT_FMT,K-1)+ num$(J)+right$(AMT_FMT,K+J) : Endif
    Next J
    AMT_FMT=ctrans(right$(AMT_FMT,instr(1,AMT_FMT,":")+1),"#","")

# Loop on numeric values
  For I=1 To [PS2]NBRFRM
    IF_DEFFMT=0
    NBP+=1 : PRO(NBP)="amount"+num$(I) : TYP(NBP)=5
    NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/x-decimal"
    NBP+=1 : PRO(NBP)="$precision" : TYP(NBP)=2
    If [PS2]FMTFRM(I-1)<>0
       FMT_AMT=[PS2]FMTFRM(I-1)
    Elsif [PS2]CUMFRM(I-1)>2
      FMT_AMT=3.2
    Else
      FMT_AMT=val(AMT_FMT)
      IF_DEFFMT=1
    Endif

    VLE(NBP)=num$(1+int(FMT_AMT)+10*(FMT_AMT-int(FMT_AMT)))
    NBP+=1 : PRO(NBP)="$scale" : TYP(NBP)=2 : VLE(NBP)=num$(10*(FMT_AMT-int(FMT_AMT)))
    NBP+=1 : PRO(NBP)="$format"
    If IF_DEFFMT=1 and int(FMT_AMT)=FMT_AMT
       # Issue 57552 - 2017-10-10 by CCC : respect format without decimal => remove ".#"
       VLE(NBP)="#"+string$(int(FMT_AMT)>3,",###") #+".#"
    Else
       VLE(NBP)=string$(10*(FMT_AMT-int(FMT_AMT)),"0") : VLE(NBP)="#"+string$(int(FMT_AMT)>3,",###")+string$(VLE(NBP)<>"",".")+VLE(NBP)
    Endif
    NBP+=1 : PRO(NBP)="$title" : TYP(NBP)=4 : VLE(NBP)='func ASYRREQ.T(L,"PARSTA2","'+[PS2]COD+'","INTITFRM",'+num$(I)+")"
    POF="}," : # bug double quote POF="}"+string$(I<[PS2]NBRFRM,',')  CCL
    Gosub PRO_GEN From AJSONLIB
  Next I

# linkUp and linkDown values

  PRF="" : # bug double quote PRF="," CCL
  NBP+=1 : PRO(NBP)="linkUp" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/x-string"
  NBP+=1 : PRO(NBP)="$isExcluded": VLE(NBP)="1" : TYP(NBP)=1
  POF="}"
  Gosub PRO_GEN From AJSONLIB

  PRF=","
  NBP+=1 : PRO(NBP)="linkDown" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/x-string"
  NBP+=1 : PRO(NBP)="$isExcluded": VLE(NBP)="1" : TYP(NBP)=1
  POF="}"
  Gosub PRO_GEN From AJSONLIB

  Wrseq APWCB+'}'+Q  Using [SSS_] : # Closes the deepest level of '$', and $item
  PRF=","
  NBP+=1 : PRO(NBP)="$links" : TYP(NBP)=5
  Gosub PRO_GEN From AJSONLIB

  NBP+=1 : PRO(NBP)="levelDown" : TYP(NBP)=5
  Gosub PRO_GEN From AJSONLIB
  Wrseq APWCB+'"$url":"{$baseUrl}/STATS('+"'+QUO_STA+"+"')?representation=STATS~"+[PS2]COD+'.$cube&{linkDown}'+DQ+","+Q Using [SSS_]
  NBP+=1 : PRO(NBP)="$title" : TYP(NBP)=4 : VLE(NBP)='func M(L,101,47)'
  POF="},"
  Gosub PRO_GEN From AJSONLIB
  NBP+=1 : PRO(NBP)="levelUp" : TYP(NBP)=5
  Gosub PRO_GEN From AJSONLIB
  Wrseq APWCB+'"$url":"{$baseUrl}/STATS('+"'+QUO_STA+"+"')?representation=STATS~"+[PS2]COD+'.$cube&{linkUp}'+DQ+","+Q Using [SSS_]
  NBP+=1 : PRO(NBP)="$title" : TYP(NBP)=4 : VLE(NBP)='func M(L,101,46)'
  POF="}}},"
  Gosub PRO_GEN From AJSONLIB

# Let's start cube
  NBP+=1 : PRO(NBP)="$cube" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$mode" : VLE(NBP)="table"
# NBP+=1 : PRO(NBP)="$style" : VLE(NBP)="pie" : # 28 th April
  NBP+=1 : PRO(NBP)="$title": TYP(NBP)=4 : VLE(NBP)='func ASYRREQ.T(L,"PARSTA2","'+[PS2]COD+'","INTSHO",0)'
  NBP+=1 : PRO(NBP)="$displaysOneMeasure" : TYP(NBP)=1 : VLE(NBP)="1"
  NBP+=1 : PRO(NBP)="$hierarchies" : TYP(NBP)=5
  Gosub PRO_GEN From AJSONLIB

# Loop on hierarchies
  For I=1 To NBHIER
    NBP+=1 : PRO(NBP)=HIERNAME(I) : TYP(NBP)=5
    NBP+=1 : PRO(NBP)="$title" : TYP(NBP)=4 : VLE(NBP)=HIERARCHY(I)
    NBP+=1 : PRO(NBP)="$properties" : TYP(NBP)=5 : VLE(NBP)='['
    Gosub PRO_GEN From AJSONLIB
    For J=FIRSTFLD(I) To FIRSTFLD(I)+NBFLD(I)-1
      Wrseq APWCB+'"'+FIELDNAME(J)+'"'+string$(J<FIRSTFLD(I)+NBFLD(I)-1,',')+Q Using [SSS_]
    Next J
    Wrseq APWCB+"]},"+Q Using [SSS_]
  Next I

# The date hierarchy, then close $hierarchies, and start measures
  Wrseq APWCB+'"date":{"properties":["dateStat"],"periods":"YSQMD"}},"$measures":{'+Q Using [SSS_]

# Loop on measures : no comma after the last one
  If [PS2]NBRFRM>0
   Wrseq APWCB+sigma(1,[PS2]NBRFRM,'"amount'+num$(indcum)+'":{'+string$(indcum=1,'"$isDefault":true')+'}'+string$(indcum<[PS2]NBRFRM,","))+Q Using [SSS_]
  Endif

# Closes '$measures', then '$cube', then starts axes and the first axis with its hierarchies
  Wrseq APWCB+'}},'+'"$axes":[{"$title":"'+Q+"+"+HIERARCHY(1)+"+"+Q+'","$hierarchies":['+Q Using [SSS_]

# Loop on hierarchies
  For I=1 To NBHIER
      Wrseq APWCB+'["'+HIERNAME(I)+'",'+num$(I=1)+',0]'+string$(I<NBHIER,",")+Q Using [SSS_]
  Next I
  Wrseq APWCB+']},'+Q Using [SSS_] : # Closes $hierarchies and then axis #1

# Measures in axis, then close axes, then the default slicer, finally close everything
  Wrseq APWCB+'{"$title":"Measures","$hierarchies":[["$measures"]]}],'
&            +'"$slicer":{"$title":"'+HIERNAME(1)+'","$hierarchies":[["'+HIERNAME(1)+'",1,0]]}'
&            +'}}}'+Q Using [SSS_] : # Final close
  Wrseq "End" Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "#" Using [SSS_]
  Wrseq "# Get the data for a statistical code" Using [SSS_]
  Wrseq "#" Using [SSS_]
  Wrseq "$GET" Using [SSS_]
  Wrseq "Local Integer IF_AXES,IF_SLICER,I,J,K,L,M,P" Using [SSS_]
  If [PS2]UPDLEV>=2
    Wrseq "Local Char CPY_FCY_FILTER(250)" Using [SSS_]
    Wrseq "Local Integer IF_COMPANY" Using [SSS_]
    Wrseq "Local Char DEF_COMPANY("+num$(GLONCPY)+")" Using [SSS_]
    If [PS2]UPDLEV=3
      Wrseq "Local Integer IF_FACILITY" Using [SSS_]
      Wrseq "Local Char DEF_FACILITY("+num$(GLONFCY)+")" Using [SSS_]
    Endif
  Endif
  Wrseq "Local Char ERRCODE(250)" Using [SSS_]
  Wrseq "Local Integer NBFLD(1.."+num$(NBHIER)+")" Using [SSS_]
  Wrseq "Local Char KEY_VALUES(40)(1..16)" Using [SSS_]
  Wrseq "Local Clbfile AXES(2),SLICER(2)" Using [SSS_]
  Wrseq "Local Clbfile FIRST_MEMBERS(3), UP_FILTERS(3), DOWN_FILTERS(3)" Using [SSS_]
  For I=1 To [PS2]NBRFLD
    Wrseq 'Local Char DEF_'+FIELDNAME(I)+'(250)' Using [SSS_]
    Wrseq "Local Integer IF_"+FIELDNAME(I) Using [SSS_]
  Next I

# Declaration of variables used for calculation
  If NBRAMT>0
   Wrseq "Local Decimal "; Using [SSS_]
   For I=1 To NBRAMT
     Wrseq string$(I>1,", ")+"C"+num$(I); Using [SSS_]
     Wrseq string$([L]FRTFLG(I)=2,", P"+num$(I)); Using [SSS_]

     If IFTOTAL
       Wrseq ", TC"+num$(I); Using [SSS_]
       Wrseq string$([L]FRTFLG(I)=2,", TP"+num$(I)); Using [SSS_]
     Endif
     If IFPREVIOUS
       Wrseq ", CC"+num$(I); Using [SSS_]
       Wrseq string$([L]FRTFLG(I)=2,", PP"+num$(I)); Using [SSS_]
       If IFTOTAL
         Wrseq ", TCC"+num$(I); Using [SSS_]
         Wrseq string$([L]FRTFLG(I)=2,", TPP"+num$(I)); Using [SSS_]
       Endif
     Endif
   Next I
  Endif

  # Including the progressive cumulated value (only for 2 types of cumulated values)
  For I=1 To [PS2]NBRFRM
    If find([PS2]CUMFRM(I-1),2,4)
        Wrseq ", CPR"+num$(I); Using [SSS_]
    Endif
  Next I

  Wrseq Using [SSS_]

  Wrseq "Local Integer DEBUT" Using [SSS_]
  Wrseq "Local Date DATBEG1,DATEND1" Using [SSS_]
  Wrseq "Local Integer IF_DATBEG1,IF_DATEND1" Using [SSS_]
  Wrseq "Local Integer IF_PORTVIEW" Using [SSS_]
  Wrseq "Local Char DEF_PORTVIEW(30)" Using [SSS_]

# Diagnoses have been disabled  (March 20,2014) and replaced by hidden fields

# Wrseq "Local Integer NB_DIAGNOSES" Using [SSS_]
# Wrseq "Local Char DIAGNOSES(250)(1..)" Using [SSS_]
  If IFPREVIOUS
    Wrseq "Local Date DATBEG2,DATEND2" Using [SSS_]
    Wrseq "Local Integer IF_DATBEG2,IF_DATEND2" Using [SSS_]
  Endif
  Wrseq Using [SSS_]

  If [PS2]UPDLEV>1
    Wrseq "# SET THE DEFAULT COMPANY AND THE DEFAULT SITE" Using [SSS_]
    Wrseq "Local Char FCYDEF_PRF(10),CPYDEF_PRF(10)" Using [SSS_]
    Wrseq "" Using [SSS_]
    Wrseq "# Open the profile, site, company and user related tables" Using [SSS_]
    Wrseq "  If clalev([F:APF]) : LogicClose File [APF] : Endif : Local File APROFIL [APF]" Using [SSS_]
    Wrseq "  If clalev([F:AUS]) : LogicClose File [AUS] : Endif : Local File AUTILIS [AUS]" Using [SSS_]
    Wrseq "  If clalev([F:AME]) : LogicClose File [AME] : Endif : Local File AMETUTI [AME]" Using [SSS_]
    Wrseq "  If clalev([F:FCY]) : LogicClose File [FCY] : Endif : Local File FACILITY [FCY]" Using [SSS_]
    Wrseq "  If clalev([F:AFT]) : LogicClose File [AFT] : Endif : Local File AFCTFCT [AFT]" Using [SSS_]
    Wrseq "" Using [SSS_]
    Wrseq "# Get the right menu profile and read the menu profile record" Using [SSS_]
    Wrseq "  Read [AUS]CODUSR = GACTX.USER" Using [SSS_]
    Wrseq "  If [F:AUS]PRFMEN=''" Using [SSS_]
    Wrseq "    Read [AME]AME0 = [F:AUS]CODMET" Using [SSS_]
    Wrseq "    Read [APF]CODPRF = 0;[F:AME]PRFMEN" Using [SSS_]
    Wrseq "  Else" Using [SSS_]
    Wrseq "    Read [APF]CODPRF = 0;[F:AUS]PRFMEN" Using [SSS_]
    Wrseq "  Endif" Using [SSS_]
    Wrseq "  If [F:AUS]PRFFCT=''" Using [SSS_]
    Wrseq "    Read [AME]AME0 = [F:AUS]CODMET" Using [SSS_]
    Wrseq "    Read [AFT]AFT0=[F:AME]PRFFCT" Using [SSS_]
    Wrseq "  Else" Using [SSS_]
    Wrseq "    Read [AFT]AFT0=[F:AUS]PRFFCT" Using [SSS_]
    Wrseq "  Endif" Using [SSS_]
    Wrseq "" Using [SSS_]
    Wrseq "# Assign the default company and file values" Using [SSS_]
    Wrseq "  FCYDEF_PRF=[F:AFT]FCYDEF("+num$(min(max([PS2]MODULE-1,1),len(mess(0,14,1))))+")" Using [SSS_]
    Wrseq "  If FCYDEF_PRF<>''" Using [SSS_]
    Wrseq "    Read [FCY]FCY0=FCYDEF_PRF" Using [SSS_]
    Wrseq "    CPYDEF_PRF=[FCY]LEGCPY" Using [SSS_]
    Wrseq "  Endif" Using [SSS_]
    Wrseq Using [SSS_]
  Endif

  For I=1 To NBHIER
    Wrseq "  NBFLD("+num$(I)+")="+num$(NBFLD(I)) Using [SSS_]
  Next I
  Wrseq "  ASND.DATA='{'" Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "# Analyze axes and slicers" Using [SSS_]
  Wrseq "  For I=1 To MAXTAB(ARCV.PARAMCOD)" Using [SSS_]
  Wrseq "      Case toupper(ARCV.PARAMCOD(I))" Using [SSS_]
  Wrseq "        When '$AXES'" Using [SSS_]
  Wrseq "          Call URLJS(ARCV.PARAMVAL(I),AXES,ERRCODE) From ASYRFNC" Using [SSS_]
  Wrseq "          IF_AXES=1" Using [SSS_]
  Wrseq "        When '$SLICER'" Using [SSS_]
  Wrseq "          Call URLJS(ARCV.PARAMVAL(I),SLICER,ERRCODE) From ASYRFNC" Using [SSS_]
  Wrseq "          IF_SLICER=1" Using [SSS_]
  If [PS2]UPDLEV=3
    Wrseq "        When 'FACILITY'" Using [SSS_]
    Wrseq "          DEF_FACILITY=ARCV.PARAMVAL(I)" Using [SSS_]
    Wrseq "          IF_FACILITY=1" Using [SSS_]
  Endif
  If [PS2]UPDLEV>=2
    Wrseq "      When 'COMPANY'" Using [SSS_]
    Wrseq "          DEF_COMPANY=ARCV.PARAMVAL(I)" Using [SSS_]
    Wrseq "          IF_COMPANY=1" Using [SSS_]
  Endif
  For I=1 To [PS2]NBRFLD
    Wrseq "      When '"+FIELDNAME(I)+"'" Using [SSS_]
    Wrseq "          DEF_"+FIELDNAME(I)+"=ARCV.PARAMVAL(I)" Using [SSS_]
    Wrseq "          IF_"+FIELDNAME(I)+"=1" Using [SSS_]
  Next I
  Wrseq "      When 'DATBEG1'" Using [SSS_]
  Wrseq "          DATBEG1=func DATVAL(ARCV.PARAMVAL(I))" Using [SSS_]
  Wrseq "          IF_DATBEG1=1" Using [SSS_]
  Wrseq "      When 'DATEND1'" Using [SSS_]
  Wrseq "          DATEND1=func DATVAL(ARCV.PARAMVAL(I))" Using [SSS_]
  Wrseq "          IF_DATEND1=1" Using [SSS_]
  If IFPREVIOUS
    Wrseq "      When 'DATBEG2'" Using [SSS_]
    Wrseq "          DATBEG2=func DATVAL(ARCV.PARAMVAL(I))" Using [SSS_]
    Wrseq "          IF_DATBEG2=1" Using [SSS_]
    Wrseq "      When 'DATEND2'" Using [SSS_]
    Wrseq "          DATEND2=func DATVAL(ARCV.PARAMVAL(I))" Using [SSS_]
    Wrseq "          IF_DATEND2=1" Using [SSS_]
  Endif
  Wrseq "      When 'PORTVIEW'" Using [SSS_]
  Wrseq "          DEF_PORTVIEW=ARCV.PARAMVAL(I)" Using [SSS_]
  Wrseq "          IF_PORTVIEW=(DEF_PORTVIEW<>'')" Using [SSS_]
  Wrseq "      Endcase" Using [SSS_]
  Wrseq "  Next I" Using [SSS_]
  Wrseq Using [SSS_]

  Wrseq "# If a portal view code is given, compute the missing parameters" Using [SSS_]
  Wrseq "  If IF_PORTVIEW" Using [SSS_]
  Wrseq "    Gosub PORTVIEW_STD" Using [SSS_]
  Wrseq "  Endif" Using [SSS_]
  Wrseq "" Using [SSS_]

  Wrseq "# Default values for dates if not given, with consistency control" Using [SSS_]
  Wrseq "  If IF_DATBEG1=0" Using [SSS_]
  Wrseq "    DATBEG1=fmet GACTX.APARAM.AGETUSERVALDATE('DATSTADEB')" Using [SSS_]
# Wrseq "    NB_DIAGNOSES+=1" Using [SSS_]
# Wrseq "    DIAGNOSES(NB_DIAGNOSES)='Default start date used: '+format$('D:YYYY[-]MM[-]DD',DATBEG1)" Using [SSS_]
  Wrseq "  Endif" Using [SSS_]
  Wrseq "  If IF_DATEND1=0" Using [SSS_]
  Wrseq "    DATEND1=fmet GACTX.APARAM.AGETUSERVALDATE('DATSTAFIN')" Using [SSS_]
# Wrseq "    NB_DIAGNOSES+=1" Using [SSS_]
# Wrseq "    DIAGNOSES(NB_DIAGNOSES)='Default end date used: '+format$('D:YYYY[-]MM[-]DD',DATEND1)" Using [SSS_]
  Wrseq "  Endif" Using [SSS_]
  Wrseq "  If DATBEG1=[0/0/0]" Using [SSS_]
  Wrseq "    If DATEND1=[0/0/0]" Using [SSS_]
  Wrseq "      DATBEG1=gdat$(1,1,year(date$))" Using [SSS_]
  Wrseq "      DATEND1=gdat$(31,12,year(date$))" Using [SSS_]
# Wrseq "      NB_DIAGNOSES+=1" Using [SSS_]
# Wrseq "      DIAGNOSES(NB_DIAGNOSES)='Period set by default from '+format$('D:YYYY[-]MM[-]DD',DATBEG1)+' to '+format$('D:YYYY[-]MM[-]DD',DATEND1)" Using [SSS_]
  Wrseq "    Else" Using [SSS_]
  Wrseq "      DATEND1=Func DATEN(DATEND1,"+num$([PS2]PERTYP)+")" Using [SSS_]
  Wrseq "      DATBEG1=Func DATBG(DATEND1,"+num$([PS2]PERTYP)+")" Using [SSS_]
# Wrseq "      NB_DIAGNOSES+=1" Using [SSS_]
# Wrseq "      DIAGNOSES(NB_DIAGNOSES)='Start date set by default to '+format$('D:YYYY[-]MM[-]DD',DATBEG1)" Using [SSS_]
  Wrseq "    Endif" Using [SSS_]
  Wrseq "  Else" Using [SSS_]
  Wrseq "    DATBEG1=Func DATBG(DATBEG1,"+num$([PS2]PERTYP)+")" Using [SSS_]
  Wrseq "    If DATEND1=[0/0/0]" Using [SSS_]
  Wrseq "      DATEND1=Func DATEN(DATBEG1,"+num$([PS2]PERTYP)+")" Using [SSS_]
# Wrseq "      NB_DIAGNOSES+=1" Using [SSS_]
# Wrseq "      DIAGNOSES(NB_DIAGNOSES)='End date set by default to '+format$('D:YYYY[-]MM[-]DD',DATEND1)" Using [SSS_]
  Wrseq "    Else" Using [SSS_]
  Wrseq "      DATEND1=Func DATEN(DATEND1,"+num$([PS2]PERTYP)+")" Using [SSS_]
  Wrseq "    Endif" Using [SSS_]
  Wrseq "  Endif" Using [SSS_]
  Wrseq Using [SSS_]
  If IFPREVIOUS
    Wrseq "# Consistency rules : the second period must be before the first period" Using [SSS_]
    Wrseq "  If IF_DATBEG2=0 or DATBEG2>DATBEG1" Using [SSS_]
    Wrseq "    Call ADC("+num$([PS2]PERTYP)+",DATBEG1,DATBEG2,Func DCL(DATBEG1,DATEND1+1,"+num$([PS2]PERTYP)+"))" Using [SSS_]
    Wrseq "    DATBEG2=Func DATBG(DATBEG2,"+num$([PS2]PERTYP)+")" Using [SSS_]
    Wrseq "    DATEND2=DATBEG1-1" Using [SSS_]
#   Wrseq "    NB_DIAGNOSES+=1" Using [SSS_]
#   Wrseq "    DIAGNOSES(NB_DIAGNOSES)='Previous period set by default from '+format$('D:YYYY[-]MM[-]DD',DATBEG2)+' to '+format$('D:YYYY[-]MM[-]DD',DATEND2)" Using [SSS_]
    Wrseq "  Elsif IF_DATEND2=0 or DATEND2<DATBEG2" Using [SSS_]
    Wrseq "    DATEND2=DATBEG1-1" Using [SSS_]
#   Wrseq "    NB_DIAGNOSES+=1" Using [SSS_]
#   Wrseq "    DIAGNOSES(NB_DIAGNOSES)='End of previous period set by default to '+format$('D:YYYY[-]MM[-]DD',DATEND2)" Using [SSS_]
    Wrseq "  Endif" Using [SSS_]
    Wrseq Using [SSS_]
  Endif

  If [PS2]UPDLEV=3
    Wrseq "# Company and site default value got from profile if not already specified" Using [SSS_]
    Wrseq "  If IF_FACILITY=0 and FCYDEF_PRF<>''" Using [SSS_]
    Wrseq "    DEF_FACILITY=FCYDEF_PRF" Using [SSS_]
    Wrseq "    IF_FACILITY=1" Using [SSS_]
    Wrseq "  Endif" Using [SSS_]
    Wrseq "  If IF_COMPANY=0 and IF_FACILITY=0 and CPYDEF_PRF<>''" Using [SSS_]
  Endif
  If [PS2]UPDLEV=2
    Wrseq "  If IF_COMPANY=0 and CPYDEF_PRF<>''" Using [SSS_]
  Endif
  If [PS2]UPDLEV>=2
    Wrseq "    DEF_COMPANY=CPYDEF_PRF" Using [SSS_]
    Wrseq "    IF_COMPANY=1" Using [SSS_]
    Wrseq "  Endif" Using [SSS_]
    Wrseq Using [SSS_]
  Endif

  Wrseq "# JSON analysis to find out the level (variable L)" Using [SSS_]
  Wrseq "# If no AXES parameters, the level is given by the first nul value in other criteria" Using [SSS_]
  Wrseq " If IF_AXES=0" Using [SSS_]
  Wrseq "    L=1" Using [SSS_]
  Wrseq "    Gosub PORTVIEW_OTH" Using [SSS_]
  Wrseq " Else" Using [SSS_]
  Wrseq "    K=0" Using [SSS_]
  Wrseq "    L=0" Using [SSS_]
  Wrseq "    M=1" Using [SSS_]
  Wrseq "    P0=0 : P1=0" Using [SSS_]
  Wrseq "    I=instr(1,AXES,'"+'"$hierarchies"'+"')" Using [SSS_]
  Wrseq "    If I=0 : Return : Endif : # Error found" Using [SSS_]
  Wrseq "    J=instr(I,AXES,'[')" Using [SSS_]
  Wrseq "    If J=0 : Return : Endif : # Error found" Using [SSS_]
  Wrseq "    While P0=0 and I<>0" Using [SSS_]
  Wrseq "        I=instr(J+1,AXES,'[')" Using [SSS_]
  Wrseq "        Break (I=0)" Using [SSS_]
  Wrseq "        I=instr(I+1,AXES,'"+DQ+"')" Using [SSS_]
  Wrseq "        Break (I=0)" Using [SSS_]
  Wrseq "        I=instr(I+1,AXES,'"+DQ+"')" Using [SSS_]
  Wrseq '        While I>1 and mid$(AXES,I-1,1)="\"' Using [SSS_]
  Wrseq "            I=instr(I+1,AXES,'"+DQ+"')" Using [SSS_]
  Wrseq "        Wend" Using [SSS_]
  Wrseq "        Break (I=0)" Using [SSS_]
  Wrseq "        I=instr(I+1,AXES,',')" Using [SSS_]
  Wrseq "        Break (I=0)" Using [SSS_]
  Wrseq "        J=instr(I+1,AXES,',') : K=instr(I+1,AXES,']')" Using [SSS_]
  Wrseq "        If J=0" Using [SSS_]
  Wrseq "            J=K : P1=0" Using [SSS_]
  Wrseq "        Elsif J<K" Using [SSS_]
  Wrseq "            P1=val(mid$(AXES,J+1,K-J-1))" Using [SSS_]
  Wrseq "        Else" Using [SSS_]
  Wrseq "            J=min(J,K)" Using [SSS_]
  Wrseq "            P1=0" Using [SSS_]
  Wrseq "        Endif" Using [SSS_]
  Wrseq "        P0=val(mid$(AXES,I+1,J-I-1))" Using [SSS_]
  Wrseq "        Break (J=0)" Using [SSS_]
  Wrseq "        If P0=0" Using [SSS_]
  Wrseq "            I=instr(J,AXES,'[')" Using [SSS_]
  Wrseq "            L+=NBFLD(M)" Using [SSS_]
  Wrseq "            M+=1" Using [SSS_]
  Wrseq "        Else" Using [SSS_]
  Wrseq "            L+=P0+P1" Using [SSS_]
  Wrseq "        Endif" Using [SSS_]
  Wrseq "    Wend" Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "    I=instr(1,AXES,'"+DQ+"$members"+DQ+"')" Using [SSS_]
  Wrseq "    If I" Using [SSS_]
  Wrseq "        K=0" Using [SSS_]
  Wrseq "        I+=len('"+DQ+"$members"+DQ+"')" Using [SSS_]
  Wrseq "        While K<L-1" Using [SSS_]
  Wrseq "            J=instr(I+1,AXES,'"+DQ+"')+1" Using [SSS_]
  Wrseq "            I=instr(J,AXES,'"+DQ+"')" Using [SSS_]
  Wrseq "            Break (I=0) or (J=1)" Using [SSS_]
  Wrseq "            KEY_VALUES(K+1)=mid$(AXES,J,I-J)" Using [SSS_]
  Wrseq "            K+=1" Using [SSS_]
  Wrseq "        Wend" Using [SSS_]
  Wrseq "    Endif" Using [SSS_]
  Wrseq "  Endif" Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "# Prepare the header in order to define the criteria hidden and visible" Using [SSS_]
  Wrseq "  APPEND ASND.DATA,'"+DQ+'$properties":{"$resources":{"$item":{"$properties":{'+Q Using [SSS_]
  For I=1 To [PS2]NBRFLD
  Wrseq "  APPEND ASND.DATA,'"+string$(I>1,',')+'"'+FIELDNAME(I)+'":{"$isHidden":'+Q+"+string$(L="+num$(I)+',"false")'
&                      +"+string$(L<>"+num$(I)+',"true")+"}"' Using [SSS_]
### SAM  #10917 fix
  Wrseq "  APPEND ASND.DATA,',"+'"C_'+FIELDNAME(I)+'":{"$isHidden":'+Q+"+string$(L="+num$(I)+',"false")'
&                      +"+string$(L<>"+num$(I)+',"true")+"}"' Using [SSS_]
### End SAM #10917 fix
  Next I
  Wrseq Using [SSS_]

  Wrseq "# Set the first members values" Using [SSS_]
  Wrseq 'Local Date DD1,DD2' Using [SSS_]
  Wrseq 'Local Char PREV_FILTERS(250),NEXT_FILTERS(250),KEY_BUFFER(250)' Using [SSS_]
  Wrseq '' Using [SSS_]
  Wrseq '  FIRST_MEMBERS="" : UP_FILTERS="" : I=0' Using [SSS_]
  Wrseq '  DD1=DATBEG1 : DD2=DATEND1' Using [SSS_]
  Wrseq '  FIRST_MEMBERS="" : UP_FILTERS="" : I=0' Using [SSS_]
  Wrseq '  NEXT_FILTERS=""  : PREV_FILTERS=""' Using [SSS_]
  Wrseq '  If func SUBPS6.DELTA_MINUS(DD1,DD2,'+num$([PS2]PERTYP)+')' Using [SSS_]
  Wrseq '    Append PREV_FILTERS,"DATBEG1="+format$("D:4Y[-]MM[-]DD",DD1)' Using [SSS_]
  Wrseq '    Append PREV_FILTERS,"&DATEND1="+format$("D:4Y[-]MM[-]DD",DD2)' Using [SSS_]
  Wrseq '  Endif' Using [SSS_]
  If IFPREVIOUS
    Wrseq '  DD1=DATBEG2 : DD2=DATEND2' Using [SSS_]
    Wrseq '  If func SUBPS6.DELTA_MINUS(DD1,DD2,'+num$([PS2]PERTYP)+')' Using [SSS_]
    Wrseq '    Append PREV_FILTERS,"&DATBEG2="+format$("D:4Y[-]MM[-]DD",DD1)' Using [SSS_]
    Wrseq '    Append PREV_FILTERS,"&DATEND2="+format$("D:4Y[-]MM[-]DD",DD2)' Using [SSS_]
    Wrseq '  Endif' Using [SSS_]
  Endif
  Wrseq '  DD1=DATBEG1 : DD2=DATEND1' Using [SSS_]
  Wrseq '  If func SUBPS6.DELTA_PLUS(DD1,DD2,'+num$([PS2]PERTYP)+')' Using [SSS_]
  Wrseq '    Append NEXT_FILTERS,"DATBEG1="+format$("D:4Y[-]MM[-]DD",DD1)' Using [SSS_]
  Wrseq '    Append NEXT_FILTERS,"&DATEND1="+format$("D:4Y[-]MM[-]DD",DD2)' Using [SSS_]
  Wrseq '  Endif' Using [SSS_]
  If IFPREVIOUS
    Wrseq '  DD1=DATBEG2 : DD2=DATEND2' Using [SSS_]
    Wrseq '  If func SUBPS6.DELTA_PLUS(DD1,DD2,'+num$([PS2]PERTYP)+')' Using [SSS_]
    Wrseq '    Append NEXT_FILTERS,"&DATBEG2="+format$("D:4Y[-]MM[-]DD",DD1)' Using [SSS_]
    Wrseq '    Append NEXT_FILTERS,"&DATEND2="+format$("D:4Y[-]MM[-]DD",DD2)' Using [SSS_]
    Wrseq '  Endif' Using [SSS_]
  Endif
  Wrseq '  If IF_DATBEG1' Using [SSS_]
  Wrseq '    APPEND UP_FILTERS,"DATBEG1="+format$("D:4Y[-]MM[-]DD",DATBEG1)' Using [SSS_]
  Wrseq '    I=1' Using [SSS_]
  Wrseq '  Endif' Using [SSS_]
  Wrseq '  If IF_DATEND1' Using [SSS_]
  Wrseq '    APPEND UP_FILTERS,string$(I,"&")+"DATEND1="+format$("D:4Y[-]MM[-]DD",DATEND1)' Using [SSS_]
  Wrseq '    I=1' Using [SSS_]
  Wrseq '  Endif' Using [SSS_]
  If IFPREVIOUS
    Wrseq '  If IF_DATBEG2' Using [SSS_]
    Wrseq '    APPEND UP_FILTERS,string$(I,"&")+"DATBEG2="+format$("D:4Y[-]MM[-]DD",DATBEG2)' Using [SSS_]
    Wrseq '    I=1' Using [SSS_]
    Wrseq '  Endif' Using [SSS_]
    Wrseq '  If IF_DATEND2' Using [SSS_]
    Wrseq '    APPEND UP_FILTERS,string$(I,"&")+"DATEND2="+format$("D:4Y[-]MM[-]DD",DATEND2)' Using [SSS_]
    Wrseq '    I=1' Using [SSS_]
    Wrseq '  Endif' Using [SSS_]
  Endif

  If [PS2]UPDLEV>=2
    Wrseq '  If IF_COMPANY' Using [SSS_]
    Wrseq '    APPEND UP_FILTERS,string$(I,"&")+"COMPANY="+DEF_COMPANY' Using [SSS_]
    Wrseq '    APPEND PREV_FILTERS,string$(PREV_FILTERS<>"","&COMPANY="+DEF_COMPANY)' Using [SSS_]
    Wrseq '    APPEND NEXT_FILTERS,string$(NEXT_FILTERS<>"","&COMPANY="+DEF_COMPANY)' Using [SSS_]
    Wrseq '    I=1' Using [SSS_]
    Wrseq '  Endif' Using [SSS_]
    If [PS2]UPDLEV=3
      Wrseq '  If IF_FACILITY' Using [SSS_]
      Wrseq '    APPEND UP_FILTERS,string$(I,"&")+"FACILITY="+DEF_FACILITY' Using [SSS_]
      Wrseq '    APPEND PREV_FILTERS,string$(PREV_FILTERS<>"","&FACILITY="+DEF_FACILITY)' Using [SSS_]
      Wrseq '    APPEND NEXT_FILTERS,string$(NEXT_FILTERS<>"","&FACILITY="+DEF_FACILITY)' Using [SSS_]
      Wrseq '    I=1' Using [SSS_]
      Wrseq '  Endif' Using [SSS_]
    Endif
  Endif

  Wrseq "  DOWN_FILTERS=UP_FILTERS" Using [SSS_]
  Wrseq '  While 1=1' Using [SSS_]
  For I=1 To [PS2]NBRFLD-1
    Wrseq "    Break L="+num$(I) Using [SSS_]
    If I>1 : Wrseq "    DOWN_FILTERS=UP_FILTERS" Using [SSS_] : Endif
    If left$(KEYLINK(I),1)<>"~"
        Case KEYTYP(I)
          When "application/x-decimal","application/x-integer"
            Wrseq "    KEY_BUFFER=func STRG(KEY_VALUES("+num$(I)+'))' Using [SSS_]
            Wrseq "    Append FIRST_MEMBERS,'"+DQ+FIELDNAME(I)+'":'+Q+'+KEY_BUFFER+'+Q+','+Q Using [SSS_]
          When Default
            Wrseq "    KEY_BUFFER=func STRG(KEY_VALUES("+num$(I)+'))' Using [SSS_]
            Wrseq "    Append FIRST_MEMBERS,'"+DQ+FIELDNAME(I)+'":"'+Q+'+KEY_BUFFER+'+Q+'",'+Q Using [SSS_]
        Endcase
    Else
        Wrseq "    KEY_BUFFER=func STRG(KEY_VALUES("+num$(I)+'))' Using [SSS_]
        Wrseq "    Append FIRST_MEMBERS,'"+DQ+FIELDNAME(I)+'":'+Q+'+KEY_BUFFER+'+Q+','+Q Using [SSS_]
    Endif
    If I=1
      Wrseq "    Append UP_FILTERS,string$(I,'&')+'"+FIELDNAME(I)+"='+KEY_BUFFER" Using [SSS_]
    Else
      Wrseq "    Append UP_FILTERS,'&"+FIELDNAME(I)+"='+KEY_BUFFER" Using [SSS_]
    Endif
    Wrseq "    Append PREV_FILTERS,string$(PREV_FILTERS<>'','&"+FIELDNAME(I)+"='+KEY_BUFFER)" Using [SSS_]
    Wrseq "    Append NEXT_FILTERS,string$(NEXT_FILTERS<>'','&"+FIELDNAME(I)+"='+KEY_BUFFER)" Using [SSS_]
  Next I
  Wrseq "    Break" Using [SSS_]
  Wrseq "  Wend" Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "  L=max(min(L,"+num$([PS2]NBRFLD)+"),1)" Using [SSS_]
  Wrseq Using [SSS_]

  If [PS2]UPDLEV=3
    Wrseq "# Company and facility filter" Using [SSS_]
    Wrseq "  If IF_COMPANY & DEF_COMPANY<>''" Using [SSS_]
    Wrseq "    CPY_FCY_FILTER='CPY="+DQQ+"+DEF_COMPANY+"+QDQQ Using [SSS_]
    Wrseq "  Endif" Using [SSS_]
    Wrseq "  If IF_FACILITY & DEF_FACILITY<>''" Using [SSS_]
    Wrseq "    CPY_FCY_FILTER+=string$(CPY_FCY_FILTER<>'','&')+'FCY="+DQQ+"+DEF_FACILITY+"+QDQQ Using [SSS_]
    Wrseq "  Endif" Using [SSS_]
    Wrseq "  CPY_FCY_FILTER+=string$(CPY_FCY_FILTER='','1=1')" Using [SSS_]
    Wrseq Using [SSS_]
  Elsif [PS2]UPDLEV=2
    Wrseq "# Company filter" Using [SSS_]
    Wrseq "  If IF_COMPANY & DEF_COMPANY<>''" Using [SSS_]
    Wrseq "    CPY_FCY_FILTER='CPY="+DQQ+"+DEF_COMPANY+"+QDQQ Using [SSS_]
    Wrseq "  Else" Using [SSS_]
    Wrseq "    CPY_FCY_FILTER='1=1'" Using [SSS_]
    Wrseq "  Endif" Using [SSS_]
    Wrseq Using [SSS_]
  Endif

  Wrseq "  APPEND ASND.DATA,'}'" Using [SSS_] : # Only 1
  Wrseq Using [SSS_]

# Link section added
  If [PS2]NBRFLD>1
    Wrseq Using [SSS_]
    Wrseq '# Add the zooming links' Using [SSS_]
    Wrseq "  Append ASND.DATA,chr$(10)+'"+',"$links":{'+"'" Using [SSS_]
    Wrseq "  If L<"+num$([PS2]NBRFLD) Using [SSS_]
    Wrseq "    Append ASND.DATA,chr$(10)+'"+'"levelUp":{"$isHidden":false},'+"'" Using [SSS_]
    Wrseq "  Else" Using [SSS_]
    Wrseq "    Append ASND.DATA,chr$(10)+'"+'"levelUp":{"$isHidden":true},'+"'" Using [SSS_]
    Wrseq "  Endif" Using [SSS_]
    Wrseq "  If L=1" Using [SSS_]
    Wrseq "    Append ASND.DATA,chr$(10)+'"+'"levelDown":{"$isHidden":true}'+"'" Using [SSS_]
    Wrseq "  Else" Using [SSS_]
    Wrseq "    Append ASND.DATA,chr$(10)+'"+'"levelDown":{"$isHidden":false}'+"'" Using [SSS_]
    Wrseq "  Endif" Using [SSS_]
    Wrseq "  Append ASND.DATA,'}}'" Using [SSS_] : # Two
  Else
    Wrseq "  Append ASND.DATA,'}'" Using [SSS_] : # One
  Endif

  Wrseq "  If IF_AXES" Using [SSS_]
  Wrseq "    APPEND ASND.DATA,',"+DQ+'$axes":'+Q Using [SSS_]
  Wrseq "    APPEND ASND.DATA,AXES" Using [SSS_]
  Wrseq "  Endif" Using [SSS_]
  Wrseq "  If IF_SLICER" Using [SSS_]
  Wrseq "    APPEND ASND.DATA,',"+DQ+'$slicer":'+Q Using [SSS_]
  Wrseq "    APPEND ASND.DATA,SLICER" Using [SSS_]
  Wrseq "  Endif" Using [SSS_]
  Wrseq "  APPEND ASND.DATA,'}}'" Using [SSS_]

  Wrseq "# Database access" Using [SSS_]
  Wrseq Using [SSS_]
  If IFBUDGET
    Wrseq "  If clalev([SAT]) : LogicClose File [SAT] : Endif : Local File STAT [SAT]" Using [SSS_]
    Wrseq "  If clalev([SAP]) : LogicClose File [SAP] : Endif : Local File STATPRV [SAP]" Using [SSS_]
  Endif
  Wrseq "  If clalev([SAPT]) : LogicClose File [SAPT] : Endif" Using [SSS_]
  If IFBUDGET
    Wrseq "  Link [SAT] With [SAP]SAP0=[SAT]COD;[SAT]CPY;[SAT]FCY;[SAT]DAT"; Using [SSS_]
    I=1
    While evalue("dim([SAT]CRI"+num$(I)+")")>0
        Wrseq ";[SAT]CRI"+num$(I); Using [SSS_]
        I+=1
    Wend
    Wrseq " As [SAPT]"; Using [SSS_]
  Else
    Wrseq "  Local File STAT [SAPT]"; Using [SSS_]
  Endif
  If [PS2]UPDLEV>=2
    Wrseq " Where evalue(CPY_FCY_FILTER)" Using [SSS_]
  Else
    Wrseq Using [SSS_]
  Endif
  Wrseq Using [SSS_]

# If a total is required, a first loop must be generated
  If IFTOTAL
     Wrseq "# Compute the totals and budget totals if needed" Using [SSS_]
     If NBRAMT>0
        Wrseq "  Raz "+sigma(1,NBRAMT,"TC"+num$(indcum)+string$(indcum<NBRAMT,", ")); Using [SSS_]
     Endif
     If IFBUDGET
       For I=1 To NBRAMT
         If [L]FRTFLG(I)>1 : Wrseq ", TP"+num$(I); Using [SSS_] : Endif
       Next I
     Endif
     Wrseq Using [SSS_]
     Wrseq "  Case L" Using [SSS_]
     Wrseq "    When 1" Using [SSS_]
     If NBRAMT>0
      Wrseq "      For [SAPT] Where COD='"+[PS2]COD+"' & DAT>=DATBEG1 & DAT<=DATEND1 & CRI1<>'$$$' & CRI2='$$$'" Using [SSS_]
      For I=1 To NBRAMT
         Wrseq "        TC"+num$(I)+"+=[SAPT]AMT("+num$(I-1)+")" Using [SSS_]
         If [L]FRTFLG(I)>1
            Wrseq "        TP"+num$(I)+"+=[SAP]AMT("+num$(I-1)+")" Using [SSS_]
         Endif
      Next I
      Wrseq "      Next" Using [SSS_]
     Endif
     For I=2 To [PS2]NBRFLD
       Wrseq "    When "+num$(I) Using [SSS_]
       Wrseq "      For [SAPT] Where COD='"+[PS2]COD+"' & DAT>=DATBEG1 & DAT<=DATEND1 &"; Using [SSS_]
       For J=1 To I-1
          Wrseq " CRI"+num$(J)+"=KEY_VALUES("+num$(J)+") &"; Using [SSS_]
       Next J
       Wrseq " CRI"+num$(I)+"='$$$'" Using [SSS_]
       For J=1 To NBRAMT
         Wrseq "        TC"+num$(J)+"+=[SAPT]AMT("+num$(J-1)+")" Using [SSS_]
         If [L]FRTFLG(J)>1
             Wrseq "        TP"+num$(J)+"+=[SAP]AMT("+num$(J-1)+")" Using [SSS_]
         Endif
       Next J
       Wrseq "      Next" Using [SSS_]
     Next I
     Wrseq "  Endcase" Using [SSS_]
     Wrseq Using [SSS_]
     If IFPREVIOUS
       Wrseq "# Compute the totals and budget totals for the previous period if needed" Using [SSS_]
       If NBRAMT>0
           Wrseq "  Raz "+sigma(1,NBRAMT,"TCC"+num$(indcum)+string$(indcum<NBRAMT,", ")); Using [SSS_]
       Endif
       For I=1 To NBRAMT
          If [L]FRTFLG(I)>1 : Wrseq ", TPP"+num$(I); Using [SSS_] : Endif
       Next I
       Wrseq Using [SSS_]
       Wrseq "  Case L" Using [SSS_]
       Wrseq "    When 1" Using [SSS_]
       Wrseq "      For [SAPT] Where COD='"+[PS2]COD+"' & DAT>=DATBEG2 & DAT<=DATEND2 & CRI1<>'$$$' & CRI2='$$$'" Using [SSS_]
       For I=1 To NBRAMT
         Wrseq "        TCC"+num$(I)+"+=[SAPT]AMT("+num$(I-1)+")" Using [SSS_]
         If [L]FRTFLG(I)>1
             Wrseq "        TPP"+num$(I)+"+=[SAP]AMT("+num$(I-1)+")" Using [SSS_]
         Endif
       Next I
       Wrseq "      Next" Using [SSS_]
       For I=2 To [PS2]NBRFLD
         Wrseq "    When "+num$(I) Using [SSS_]
         Wrseq "      For [SAPT] Where COD='"+[PS2]COD+"' & DAT>=DATBEG2 & DAT<=DATEND2 &"; Using [SSS_]
         For J=1 To I-1
           Wrseq " CRI"+num$(J)+"=KEY_VALUES("+num$(J)+") &"; Using [SSS_]
         Next J
         Wrseq " CRI"+num$(I)+"='$$$'" Using [SSS_]
         For J=1 To NBRAMT
           Wrseq "        TCC"+num$(J)+"+=[SAPT]AMT("+num$(J-1)+")" Using [SSS_]
           If [L]FRTFLG(J)>1
               Wrseq "        TPP"+num$(J)+"+=[SAP]AMT("+num$(J-1)+")" Using [SSS_]
           Endif
         Next J
         Wrseq "      Next" Using [SSS_]
       Next I
       Wrseq "  Endcase" Using [SSS_]
     Endif
  Endif

  Wrseq Using [SSS_]
  Wrseq "# Compute the detail calculation" Using [SSS_]
  Wrseq "  Case L" Using [SSS_]
  CRIT_STA=""
  For I=1 To [PS2]NBRFLD
    Wrseq "    When "+num$(I) Using [SSS_]
    If len(CRIT_STA)>50
        Wrseq "      Filter [SAPT] Where COD='"+[PS2]COD+"'"
&             +CRIT_STA Using [SSS_]
        Wrseq "&                         & CRI"+num$(I)+"<>'$$$'"+string$(I<[PS2]NBRFLD," & CRI"+num$(I+1)+"='$$$'") Using [SSS_]
    Else
        Wrseq "      Filter [SAPT] Where COD='"+[PS2]COD+"'"
&             +" & CRI"+num$(I)+"<>'$$$'"+string$(I<[PS2]NBRFLD," & CRI"+num$(I+1)+"='$$$'")+CRIT_STA Using [SSS_]
    Endif
    CRIT_STA+=" & CRI"+num$(I)+"=KEY_VALUES("+num$(I)+")"
    Wrseq "&                  Order By Key CLE=CRI"+num$(I) Using [SSS_]
  Next I
  Wrseq "  Endcase" Using [SSS_]
  Wrseq Using [SSS_]

# Init of cumulative values
  If [PS2]NBRFRM>0
   Wrseq "  Raz DEBUT"+sigma(1,[PS2]NBRFRM,string$(find([PS2]CUMFRM(indcum-1),2,4)<>0,", CPR"+num$(indcum))) Using [SSS_]
   Wrseq Using [SSS_]
  Endif

# Just for test
  Wrseq "# Links to previous or next period" Using [SSS_]
  Wrseq "  Append ASND.DATA,',"+DQ+'linkstartP":"'+Q+'+PREV_FILTERS+'+QDQ+Q Using [SSS_]
  Wrseq "  Append ASND.DATA,',"+DQ+'linkendP":"'+Q+'+NEXT_FILTERS+'+QDQ+Q Using [SSS_]
  Wrseq "  Append ASND.DATA,',"+DQ+'datstart1":"'+Q+'+format$("D:YYYY[-]MM[-]DD",DATBEG1)+'+QDQ+Q Using [SSS_]
  Wrseq "  Append ASND.DATA,',"+DQ+'datend1":"'+Q+'+format$("D:YYYY[-]MM[-]DD",DATEND1)+'+QDQ+Q Using [SSS_]
  If IFPREVIOUS
    Wrseq "  Append ASND.DATA,',"+DQ+'datstart2":"'+Q+'+format$("D:YYYY[-]MM[-]DD",DATBEG2)+'+QDQ+Q Using [SSS_]
    Wrseq "  Append ASND.DATA,',"+DQ+'datend2":"'+Q+'+format$("D:YYYY[-]MM[-]DD",DATEND2)+'+QDQ+Q Using [SSS_]
  Endif

  If [PS2]UPDLEV>=2
    Wrseq "  Append ASND.DATA,',"+DQ+'def_company":"'+Q+'+DEF_COMPANY+'+QDQ+Q Using [SSS_]
  Endif
  If [PS2]UPDLEV>=3
    Wrseq "  Append ASND.DATA,',"+DQ+'def_facility":"'+Q+'+DEF_FACILITY+'+QDQ+Q Using [SSS_]
  Endif


  Wrseq Using [SSS_]
# End of test

  Wrseq "# Main loop" Using [SSS_]
  If IFPREVIOUS
      Wrseq "  For [SAPT]CLE(1)  Where DAT>=min(DATBEG1,DATBEG2) and DAT<=max(DATEND1,DATEND2)" Using [SSS_]
  Else
      Wrseq "  For [SAPT]CLE(1)  Where DAT>=DATBEG1 and DAT<=DATEND1" Using [SSS_]
  Endif
  Wrseq  '#'  Using [SSS_]
  If NBRAMT>0
      Wrseq "    Raz "+sigma(1,NBRAMT,"C"+num$(indcum)+string$(indcum<NBRAMT,", ")); Using [SSS_]
  Endif
  If IFBUDGET
      For I=1 To NBRAMT
          If [L]FRTFLG(I)>1
              Wrseq ", P"+num$(I); Using [SSS_]
          Endif
      Next I
  Endif
  If IFPREVIOUS
      Wrseq sigma(1,NBRAMT,", CC"+num$(indcum)); Using [SSS_]
      If IFBUDGET
          For I=1 To NBRAMT
              If [L]FRTFLG(I)>1
                  Wrseq ", PP"+num$(I); Using [SSS_]
              Endif
          Next I
      Endif
  Endif
  Wrseq Using [SSS_]

  Wrseq "    For [SAPT]CLE" Using [SSS_]
  If IFPREVIOUS
      Wrseq "      If [SAPT]DAT>=DATBEG1 & [SAPT]DAT<=DATEND1" Using [SSS_]
      For I=1 To NBRAMT
          Wrseq "          C"+num$(I)+"+=[SAPT]AMT("+num$(I-1)+")" Using [SSS_]
          If [L]FRTFLG(I)>1
              Wrseq "          P"+num$(I)+"+=[SAP]AMT("+num$(I-1)+")" Using [SSS_]
          Endif
      Next I
      Wrseq "      Elsif [SAPT]DAT>=DATBEG2 & [SAPT]DAT<=DATEND2" Using [SSS_]
      For I=1 To NBRAMT
          Wrseq "          CC"+num$(I)+"+=[SAPT]AMT("+num$(I-1)+")" Using [SSS_]
          If [L]FRTFLG(I)>1
              Wrseq "          PP"+num$(I)+"+=[SAP]AMT("+num$(I-1)+")" Using [SSS_]
          Endif
      Next I
      Wrseq "      Endif" Using [SSS_]
  Else
      Wrseq "      #" Using [SSS_]
      For I=1 To NBRAMT
          Wrseq "      C"+num$(I)+"+=[SAPT]AMT("+num$(I-1)+")" Using [SSS_]
          If [L]FRTFLG(I)>1
              Wrseq "          P"+num$(I)+"+=[SAP]AMT("+num$(I-1)+")" Using [SSS_]
          Endif
      Next I
  Endif
  Wrseq "    Next" Using [SSS_]

  Wrseq Using [SSS_]
  Wrseq "    If DEBUT" Using [SSS_]
  Wrseq "        APPEND ASND.DATA,"+'",{"' Using [SSS_]
  Wrseq "    Else" Using [SSS_]
  Wrseq "        APPEND ASND.DATA,',"+'"$resources":[{'+Q Using [SSS_]
  Wrseq "        DEBUT=1" Using [SSS_]
  Wrseq "    Endif" Using [SSS_]
  Wrseq "    APPEND ASND.DATA,'"+DQ+'level":'+Q+"+num$(L)+','" Using [SSS_]
  Wrseq "    APPEND ASND.DATA, FIRST_MEMBERS" Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "    Case L" Using [SSS_]
  For I=1 To [PS2]NBRFLD
    Wrseq "      When "+num$(I) Using [SSS_]
    If left$(FIELDFORM(I),2)="LA" or find(KEYTYP(I),"application/x-decimal","application/x-integer")
        Wrseq "         APPEND ASND.DATA,"+QDQQ+"+func STRG('"+FIELDNAME(I)+"')+"+QDQ+':'+"'+[SAPT]CRI"+num$(I)+"+','" Using [SSS_]
    Else
# Disable the object in the data feed when a link is present (Dominique 28 of August)
# 4 lines in comments and two "}" replaced by "")
#       If KEYLINK(I)<>""
#           Wrseq "         APPEND ASND.DATA,'"+DQ+"'+func STRG('"+FIELDNAME(I)+Q+")+'"+'":{"'+KEYFLD(I)+'":"'+Q Using [SSS_]
#       Else
            Wrseq "         APPEND ASND.DATA,'"+DQ+"'+func STRG('"+FIELDNAME(I)+Q+")+'"+'":"'+Q Using [SSS_]
#           Wrseq "         APPEND ASND.DATA,'"+DQ+"'+func STRG('"+FIELDNAME(I)+Q+")+'"+'":"'+Q Using [SSS_]
#       Endif
        If FIELDFORM(I)<>""
            Wrseq "         APPEND ASND.DATA,func STRG(vireblc(format$('"+FIELDFORM(I)+"',[SAPT]CRI"+num$(I)+")),2)+"+QDQ
&                   +string$(KEYLINK(I)<>"","")+","+Q Using [SSS_] : # Here was a "}"
        Else
            Wrseq "         APPEND ASND.DATA,func STRG([SAPT]CRI"+num$(I)+")+"+QDQ+string$(KEYLINK(I)<>"","")+","+Q Using [SSS_] :  : # Here was a "}"
        Endif
    Endif
    Wrseq "         APPEND ASND.DATA,'"+'"$uuid":"'+Q+'+num$([SAPT]AUUID)+'+Q+'",'+Q Using [SSS_]
### SAM #10917 fix
#   Wrseq "         APPEND ASND.DATA,'"+DQ+'$title":"'+Q Using [SSS_]
    Wrseq "         APPEND ASND.DATA,'"+DQ+'C_'+FIELDNAME(I)+'":"'+Q Using [SSS_]
### End of SAM #10917 fix
    Wrseq "         APPEND ASND.DATA,func STRG([SAPT]DES"+num$(I)+")+"+QDQ+",'" Using [SSS_]
    Wrseq "         APPEND ASND.DATA,'"+DQ+'linkUp":"'+Q+'+UP_FILTERS+'+Q+'&'+FIELDNAME(I)+"='+func STRG([SAPT]CRI"+num$(I)+')+'+QDQ+','+Q Using [SSS_]
  Next I
  Wrseq "    Endcase" Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "# Add the linkdown value" Using [SSS_]
  Wrseq "  APPEND ASND.DATA,'"+'"linkDown":"'+Q+'+DOWN_FILTERS+'+QDQ+","+Q Using [SSS_]
  Wrseq Using [SSS_]

  For I=1 To [PS2]NBRFRM
    Case [PS2]CUMFRM(I-1)
        When 1 : Wrseq "    APPEND ASND.DATA,'"+'"amount'+num$(I)+'":'+Q+"+num$("+[PS2]AMTFRM(I-1)+")"+string$(I<[PS2]NBRFRM,'+","') Using [SSS_]
        When 2 : Wrseq "    CPR"+num$(I)+"+="+[PS2]AMTFRM(I-1) Using [SSS_]
                 Wrseq "    APPEND ASND.DATA,'"+'"amount'+num$(I)+'":'+Q+"+num$(CPR"+num$(I)+")"+string$(I<[PS2]NBRFRM,'+","') Using [SSS_]
        When 3 : Wrseq "    APPEND ASND.DATA,'"+'"amount'+num$(I)+'":'+Q+"+num$(100*(func D("+[PS2]AMTFRM(I-1)+","+func REP_FRM([PS2]AMTFRM(I-1))+")))"
&                      +string$(I<[PS2]NBRFRM,'+","') Using [SSS_]
        When 4 : Wrseq "    CPR"+num$(I)+"+="+[PS2]AMTFRM(I-1) Using [SSS_]
                 Wrseq "    APPEND ASND.DATA,'"+'"amount'+num$(I)+'":'+Q+"+num$(100*func D(CPR"+num$(I)+","+func REP_FRM([PS2]AMTFRM(I-1))+"))"
&                      +string$(I<[PS2]NBRFRM,'+","') Using [SSS_]
    Endcase
  Next
  Wrseq '    APPEND ASND.DATA,"}"+chr$(13)+chr$(10)' Using [SSS_]
  Wrseq "  Next" Using [SSS_]
  Wrseq "  If DEBUT" Using [SSS_]
  Wrseq '    APPEND ASND.DATA,"]"' Using [SSS_]
  Wrseq '  Endif' Using [SSS_]
  Wrseq Using [SSS_]
# Wrseq '  If NB_DIAGNOSES' Using [SSS_]
# Wrseq "    APPEND ASND.DATA,',"+DQ+'$diagnoses":['+Q Using [SSS_]
# Wrseq '    For I=1 to NB_DIAGNOSES' Using [SSS_]
# Wrseq '      APPEND ASND.DATA,'+Q+'{"severity":"warning","message":"'+Q+"+DIAGNOSES(I)+"+Q+'"}'+Q+"+string$(I<NB_DIAGNOSES,',')" Using [SSS_]
# Wrseq '    Next I' Using [SSS_]
# Wrseq '    APPEND ASND.DATA,"]"' Using [SSS_]
# Wrseq '  Endif' Using [SSS_]
  Wrseq '  APPEND ASND.DATA,"}"' Using [SSS_]
  Wrseq '  Return' Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq '# Some libraries that have been including in order to have an autonomous program' Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq '# Add the backshlash escaping character on string constants' Using [SSS_]
  Wrseq 'Funprog STRG(CHAINE)' Using [SSS_]
  Wrseq 'Value Char CHAINE' Using [SSS_]
  Wrseq 'Local Char RESULT(250)' Using [SSS_]
  Wrseq 'Local Integer POS1,POS2' Using [SSS_]
  Wrseq 'POS2=1' Using [SSS_]
  Wrseq 'POS1=instr(POS2,CHAINE,'+QDQQ+')' Using [SSS_]
  Wrseq 'While POS1<>0' Using [SSS_]
  Wrseq '    RESULT+=mid$(CHAINE,POS2,POS1-POS2)+'+Q+'\"'+Q Using [SSS_]
  Wrseq '    POS2=POS1+1' Using [SSS_]
  Wrseq '    POS1=instr(POS2,CHAINE,'+Q+'"'+Q+")" Using [SSS_]
  Wrseq 'Wend' Using [SSS_]
  Wrseq 'End RESULT+right$(CHAINE,POS2)' Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq '# Divide A per B but return A if B is null' Using [SSS_]
  Wrseq 'Funprog D(A,B)' Using [SSS_]
  Wrseq 'Value Decimal A,B' Using [SSS_]
  Wrseq '  If B=0' Using [SSS_]
  Wrseq '    End A' Using [SSS_]
  Wrseq '  Endif' Using [SSS_]
  Wrseq 'End A/B' Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq '# Returns the date value from a chain normalized date (null date sent if any format mismatch)' Using [SSS_]
  Wrseq 'Funprog DATVAL(C)' Using [SSS_]
  Wrseq 'Value Char C' Using [SSS_]
  Wrseq 'Local Integer IDT' Using [SSS_]
  Wrseq '  IDT=instr(1,C,"T")' Using [SSS_]
  Wrseq '  If IDT' Using [SSS_]
  Wrseq '    C=vireblc(left$(C,IDT-1),4)' Using [SSS_]
  Wrseq '  Else' Using [SSS_]
  Wrseq '    C=vireblc(C,2)' Using [SSS_]
  Wrseq '  Endif' Using [SSS_]
  Wrseq '  If pat(C,"####-##-##")' Using [SSS_]
  Wrseq '    End gdat$(val(right$(C,9)),val(mid$(C,6,2)),val(left$(C,4)))' Using [SSS_]
  Wrseq '  Endif' Using [SSS_]
  Wrseq ' End [0/0/0]' Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq '# Compute the begin of the period' Using [SSS_]
  Wrseq 'Funprog DATBG(D,P)' Using [SSS_]
  Wrseq 'Value Date D' Using [SSS_]
  Wrseq 'Value Integer P' Using [SSS_]
  Wrseq 'Case P' Using [SSS_]
  Wrseq '  When 1 : End D' Using [SSS_]
  Wrseq '  When 2 : End D-dayn(D)+1' Using [SSS_]
  Wrseq '  When 3 : End gdat$(1+15*(day(D)>=16),month(D),year(D))' Using [SSS_]
  Wrseq '  When 4 : End gdat$(1,month(D),year(D))' Using [SSS_]
  Wrseq '  When 5 : End gdat$(1,1+int((month(D)-1)/3),year(D))' Using [SSS_]
  Wrseq '  When 6 : End gdat$(1,1,year(D))' Using [SSS_]
  Wrseq '  When 7 : End gdat$(1+10*(day(D)>=11)+10*(day(D)>=21),month(D),year(D))' Using [SSS_]
  Wrseq 'Endcase' Using [SSS_]
  Wrseq 'End [0/0/0]' Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq '# Compute the end of the period' Using [SSS_]
  Wrseq 'Funprog DATEN(D,P)' Using [SSS_]
  Wrseq 'Value Date D' Using [SSS_]
  Wrseq 'Value Integer P' Using [SSS_]
  Wrseq '  Case P' Using [SSS_]
  Wrseq '    When 1 : End D' Using [SSS_]
  Wrseq '    When 2 : End D-dayn(D)+7' Using [SSS_]
  Wrseq '    When 3 : If day(D)>=16' Using [SSS_]
  Wrseq '             End eomonth(D)' Using [SSS_]
  Wrseq '           Else End gdat$(15,month(D),year(D))' Using [SSS_]
  Wrseq '           Endif' Using [SSS_]
  Wrseq '    When 4 : End eomonth(D)' Using [SSS_]
  Wrseq '    When 5 : End eomonth(gdat$(1,3+int((month(D)-1)/3),year(D)))' Using [SSS_]
  Wrseq '    When 6 : End gdat$(31,12,year(D))' Using [SSS_]
  Wrseq '    When 7 : If day(D)>=21' Using [SSS_]
  Wrseq '               End eomonth(D)' Using [SSS_]
  Wrseq '             Elsif day(D)>=11' Using [SSS_]
  Wrseq '               End gdat$(20,month(D),year(D))' Using [SSS_]
  Wrseq '             Else End gdat$(10,month(D),year(D))' Using [SSS_]
  Wrseq '             Endif' Using [SSS_]
  Wrseq '  Endcase' Using [SSS_]
  Wrseq 'End [0/0/0]' Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq '# Compute the number of periods between 2 dates' Using [SSS_]
  Wrseq 'Funprog DCL(DAT1,DAT2,PERTYP)' Using [SSS_]
  Wrseq 'Value    Date    DAT1' Using [SSS_]
  Wrseq 'Value    Date    DAT2' Using [SSS_]
  Wrseq 'Value    Integer PERTYP' Using [SSS_]
  Wrseq '  Case PERTYP' Using [SSS_]
  Wrseq '    When 1 : End DAT1-DAT2' Using [SSS_]
  Wrseq '    When 2 : End (DAT1-DAT2)/7' Using [SSS_]
  Wrseq '    When 3 : End 24*(year(DAT1)-year(DAT2))+2*(month(DAT1)-month(DAT2))+(day(DAT2)<day(DAT1))-(day(DAT2)>day(DAT1))' Using [SSS_]
  Wrseq '    When 4 : End 12*(year(DAT1)-year(DAT2))+(month(DAT1)-month(DAT2))' Using [SSS_]
  Wrseq '    When 5 : End 4*(year(DAT1)-year(DAT2))+(month(DAT1)-month(DAT2))/3' Using [SSS_]
  Wrseq '    When 6 : End year(DAT1)-year(DAT2)' Using [SSS_]
  Wrseq '    When 7 : End 36*(year(DAT1)-year(DAT2))+3*(month(DAT1)-month(DAT2))' Using [SSS_]
  Wrseq '&              + min(2,int((day(DAT1)-1)/10))-min(2,int((day(DAT2)-1)/10))' Using [SSS_]
  Wrseq '  Endcase' Using [SSS_]
  Wrseq 'End 0' Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq '# Shift a date by a given number of periods (positive or negative)' Using [SSS_]
  Wrseq 'Subprog ADC(PERTYP,DAT1,DAT2,DECAL)' Using [SSS_]
  Wrseq 'Value    Integer PERTYP' Using [SSS_]
  Wrseq 'Value    Date    DAT1' Using [SSS_]
  Wrseq 'Variable Date    DAT2' Using [SSS_]
  Wrseq 'Value    Integer DECAL' Using [SSS_]
  Wrseq '  Case PERTYP' Using [SSS_]
  Wrseq '    When 1 : DAT2 = DAT1+DECAL' Using [SSS_]
  Wrseq '    When 2 : DAT2 = DAT1+7*DECAL' Using [SSS_]
  Wrseq '    When 3 : DAT2 = addmonth(DAT1,fix(DECAL/2))' Using [SSS_]
  Wrseq '             If day(DAT2)>15' Using [SSS_]
  Wrseq '               DAT2 = eomonth(DAT2)' Using [SSS_]
  Wrseq '             Endif' Using [SSS_]
  Wrseq '             Case mod(DECAL,2)' Using [SSS_]
  Wrseq '               When 1' Using [SSS_]
  Wrseq '                 If day(DAT2)<16' Using [SSS_]
  Wrseq '                   DAT2 = eomonth(DAT2)' Using [SSS_]
  Wrseq '                 Else' Using [SSS_]
  Wrseq '                   DAT2 = eomonth(DAT2)+15' Using [SSS_]
  Wrseq '                 Endif' Using [SSS_]
  Wrseq '               When -1' Using [SSS_]
  Wrseq '                 If DAT2=eomonth(DAT2)' Using [SSS_]
  Wrseq '                    DAT2 = gdat$(15,month(DAT2),year(DAT2))' Using [SSS_]
  Wrseq '                 Else' Using [SSS_]
  Wrseq '                    DAT2 = eomonth(addmonth(DAT2,-1))' Using [SSS_]
  Wrseq '                 Endif' Using [SSS_]
  Wrseq '             Endcase' Using [SSS_]
  Wrseq '    When 4 : DAT2 = addmonth(DAT1,DECAL)' Using [SSS_]
  Wrseq '    When 5 : DAT2 = addmonth(DAT1,3*DECAL)' Using [SSS_]
  Wrseq '    When 6 : DAT2 = addmonth(DAT1,12*DECAL)' Using [SSS_]
  Wrseq '    When 7 : DAT2 = addmonth(DAT1,fix(DECAL/3))' Using [SSS_]
  Wrseq '             Case mod(DECAL,3)' Using [SSS_]
  Wrseq '               When 0' Using [SSS_]
  Wrseq '               When 1' Using [SSS_]
  Wrseq '                 Case day(DAT2)' Using [SSS_]
  Wrseq '                   When 10      : DAT2 = gdat$(20,month(DAT2)+1,year(DAT2))' Using [SSS_]
  Wrseq '                   When 20      : DAT2 = eomonth(DAT2)' Using [SSS_]
  Wrseq '                   When Default : DAT2 = gdat$(10,month(DAT2)+1,year(DAT2))' Using [SSS_]
  Wrseq '                 Endcase' Using [SSS_]
  Wrseq '               When -1' Using [SSS_]
  Wrseq '                 Case day(DAT2)' Using [SSS_]
  Wrseq '                   When 10      : DAT2 = eomonth(addmonth(DAT2,-1))' Using [SSS_]
  Wrseq '                   When 20      : DAT2 = gdat$(10,month(DAT2),year(DAT2))' Using [SSS_]
  Wrseq '                   When Default : DAT2 = gdat$(20,month(DAT2),year(DAT2))' Using [SSS_]
  Wrseq '                 Endcase' Using [SSS_]
  Wrseq '               When 2' Using [SSS_]
  Wrseq '                 Case day(DAT2)' Using [SSS_]
  Wrseq '                   When 10      : DAT2 = eomonth(DAT2)' Using [SSS_]
  Wrseq '                   When 20      : DAT2 = gdat$(10,month(DAT2)+1,year(DAT2))' Using [SSS_]
  Wrseq '                   When Default : DAT2 = gdat$(20,month(DAT2)+1,year(DAT2))' Using [SSS_]
  Wrseq '                 Endcase' Using [SSS_]
  Wrseq '               When -2' Using [SSS_]
  Wrseq '                 Case day(DAT2)' Using [SSS_]
  Wrseq '                   When 10      : DAT2 = gdat$(20,month(DAT2)-1,year(DAT2))' Using [SSS_]
  Wrseq '                   When 20      : DAT2 = eomonth(addmonth(DAT2,-1))' Using [SSS_]
  Wrseq '                   When Default : DAT2 = gdat$(10,month(DAT2),year(DAT2))' Using [SSS_]
  Wrseq '                 Endcase' Using [SSS_]
  Wrseq '             Endcase' Using [SSS_]
  Wrseq '  Endcase' Using [SSS_]
  Wrseq 'End' Using [SSS_]
  Wrseq "" Using [SSS_]

# Analyze the values from a portal view (added September the 2th, 2013)
  Wrseq "$PORTVIEW_STD" Using [SSS_]
  Wrseq "Local Char PAR_VAL(20)" Using [SSS_]
  Wrseq "" Using [SSS_]
  Wrseq "  If clalev([APV]) : LogicClose File [APV] : Endif : Local File APTLVW [APV]" Using [SSS_]
  Wrseq "" Using [SSS_]
  Wrseq "  Read [APV]APV0=DEF_PORTVIEW" Using [SSS_]
  Wrseq "  If fstat=0" Using [SSS_]
  Wrseq "    For PAR_VAL='DATDEB1', 'DATFIN1', 'DATDEB2', 'DATFIN2', 'CPY', 'FCY'" Using [SSS_]
  Wrseq "      J=find(PAR_VAL,[APV]SRCPARCOD(0..dim([APV]SRCPARCOD)-1))" Using [SSS_]
  Wrseq "      If J" Using [SSS_]
  Wrseq "        Case PAR_VAL" Using [SSS_]
  Wrseq "          When 'DATDEB1'" Using [SSS_]
  Wrseq "            If IF_DATBEG1=0" Using [SSS_]
  Wrseq "              DATBEG1=Func EVALDATE([APV]SRCPARFOR(J-1))" Using [SSS_]
  Wrseq "              IF_DATBEG1=1" Using [SSS_]
  Wrseq "            Endif" Using [SSS_]
  Wrseq "          When 'DATFIN1'" Using [SSS_]
  Wrseq "            If IF_DATEND1=0" Using [SSS_]
  Wrseq "              DATEND1=Func EVALDATE([APV]SRCPARFOR(J-1))" Using [SSS_]
  Wrseq "              IF_DATEND1=1" Using [SSS_]
  Wrseq "            Endif" Using [SSS_]

  If IFPREVIOUS
    Wrseq "          When 'DATDEB2'" Using [SSS_]
    Wrseq "            If IF_DATBEG2=0" Using [SSS_]
    Wrseq "              DATBEG2=Func EVALDATE([APV]SRCPARFOR(J-1))" Using [SSS_]
    Wrseq "              IF_DATBEG2=1" Using [SSS_]
    Wrseq "            Endif" Using [SSS_]
    Wrseq "          When 'DATFIN2'" Using [SSS_]
    Wrseq "            If IF_DATEND2=0" Using [SSS_]
    Wrseq "              DATEND2=Func EVALDATE([APV]SRCPARFOR(J-1))" Using [SSS_]
    Wrseq "              IF_DATEND2=1" Using [SSS_]
    Wrseq "            Endif" Using [SSS_]
  Endif

  If [PS2]UPDLEV>=2
    Wrseq "          When 'CPY'" Using [SSS_]
    Wrseq "            If IF_COMPANY=0" Using [SSS_]
    Wrseq "              DEF_COMPANY=Func EVALCHAR([APV]SRCPARFOR(J-1))" Using [SSS_]
    Wrseq "              IF_COMPANY=([APV]SRCPARFOR(J-1)<>'')" Using [SSS_]
    Wrseq "            Endif" Using [SSS_]
    If [PS2]UPDLEV=3
      Wrseq "          When 'FCY'" Using [SSS_]
      Wrseq "            If IF_FACILITY=0" Using [SSS_]
      Wrseq "              DEF_FACILITY=Func EVALCHAR([APV]SRCPARFOR(J-1))" Using [SSS_]
      Wrseq "              IF_FACILITY=([APV]SRCPARFOR(J-1)<>'')" Using [SSS_]
      Wrseq "            Endif" Using [SSS_]
    Endif
  Endif

  Wrseq "        Endcase" Using [SSS_]
  Wrseq "      Endif" Using [SSS_]
  Wrseq "    Next" Using [SSS_]
  Wrseq "  Endif" Using [SSS_]
  Wrseq "" Using [SSS_]

  Wrseq "Return" Using [SSS_]
  Wrseq "" Using [SSS_]

  Wrseq "$PORTVIEW_OTH" Using [SSS_]
  If [PS2]NBRFLD>1
    Wrseq "Local Char PAR_VAL(20)" Using [SSS_]
    Wrseq "" Using [SSS_]
    Wrseq "  If clalev([APV]) : LogicClose File [APV] : Endif : Local File APTLVW [APV]" Using [SSS_]
    Wrseq "" Using [SSS_]
    Wrseq "  Read [APV]APV0=DEF_PORTVIEW" Using [SSS_]
    Wrseq "  If fstat=0" Using [SSS_]
    Wrseq "    For PAR_VAL="+sigma(1,[PS2]NBRFLD-1,"'CRIT"+num$(indcum)+"'"+string$(indcum<[PS2]NBRFLD-1,",")) Using [SSS_]
    Wrseq "      J=find(PAR_VAL,[APV]SRCPARCOD(0..dim([APV]SRCPARCOD)-1))" Using [SSS_]
    Wrseq "      If J" Using [SSS_]
    Wrseq "        Case PAR_VAL" Using [SSS_]
    For J=1 To [PS2]NBRFLD-1
      Wrseq "          When 'CRIT"+num$(J)+"'" Using [SSS_]
      Wrseq "            If IF_"+FIELDNAME(J)+"=0" Using [SSS_]
      Wrseq "              DEF_"+FIELDNAME(J)+"=Func EVALCHAR([APV]SRCPARFOR(J-1))" Using [SSS_]
      Wrseq "              If DEF_"+FIELDNAME(J)+"<>'' : IF_"+FIELDNAME(J)+"=1 : Endif" Using [SSS_]
      Wrseq "            Endif" Using [SSS_]
    Next J
    Wrseq "        Endcase" Using [SSS_]
    Wrseq "      Endif" Using [SSS_]
    Wrseq "    Next" Using [SSS_]
    Wrseq "  Endif" Using [SSS_]

    For J=1 To [PS2]NBRFLD-1
      Wrseq "  If IF_"+FIELDNAME(J)+"=1" Using [SSS_] : # Forget   and DEF_"+FIELDNAME(J)+"<>''" Sept 27th
      Wrseq "    L+=(L="+num$(J)+")" Using [SSS_]
      Wrseq "    KEY_VALUES("+num$(J)+")=string$(L="+num$(J+1)+",DEF_"+FIELDNAME(J)+")" Using [SSS_]
      Wrseq "  Endif" Using [SSS_]
    Next J
  Endif

  Wrseq "Return" Using [SSS_]
  Wrseq "" Using [SSS_]
  Wrseq "Funprog EVALDATE(EVALCHAINE)" Using [SSS_]
  Wrseq "Value Char EVALCHAINE()" Using [SSS_]
  Wrseq "" Using [SSS_]
  Wrseq "Onerrgo RIEN_DAT" Using [SSS_]
  Wrseq "Local Date RESULTAT" Using [SSS_]
  Wrseq "" Using [SSS_]
  Wrseq "  RESUL_TAT=evalue(EVALCHAINE)" Using [SSS_]
  Wrseq "  If type(RESUL_TAT)<>3" Using [SSS_]
  Wrseq "    RESULTAT=gdat$(num$(RESUL_TAT))" Using [SSS_]
  Wrseq "  Else " Using [SSS_]
  Wrseq "    RESULTAT=RESUL_TAT" Using [SSS_]
  Wrseq "  Endif" Using [SSS_]
  Wrseq "End RESULTAT" Using [SSS_]
  Wrseq "$RIEN_DAT" Using [SSS_]
  Wrseq "End [0/0/0]" Using [SSS_]
  Wrseq "" Using [SSS_]
  Wrseq "Funprog EVALCHAR(EVALCHAINE)" Using [SSS_]
  Wrseq "Value Char EVALCHAINE()" Using [SSS_]
  Wrseq "" Using [SSS_]
  Wrseq "Onerrgo RIEN_CH" Using [SSS_]
  Wrseq "" Using [SSS_]
  Wrseq "Local Char RESULTAT(250)" Using [SSS_]
  Wrseq "  RESULTAT=num$(evalue(EVALCHAINE))" Using [SSS_]
  Wrseq "  End RESULTAT" Using [SSS_]
  Wrseq "$RIEN_CH" Using [SSS_]
  Wrseq "End ''" Using [SSS_]

  Openo Using [SSS_]
Return

# Replace in a formula the Ci, CCi, Pi, PPi, by Tci, TCCi, TPi, TPPi in order to get the formula to be used for total
Funprog REP_FRM(FORMU)
Value Char FORMU()
Local Integer II
Local Char CHAINE(255)
  II=1
  While II<=len(FORMU)
    If (mid$(FORMU,II,2)="CC" or mid$(FORMU,II,2)="PP") and (mid$(FORMU,II+2,1)>="1") and (mid$(FORMU,II+2,1)<="9")
        CHAINE+="T"+mid$(FORMU,II,3)
        II+=3
    Elsif (mid$(FORMU,II,1)="C" or mid$(FORMU,II,1)="P") and (mid$(FORMU,II+1,1)>="1") and (mid$(FORMU,II+1,1)<="9")
        CHAINE+="T"+mid$(FORMU,II,2)
        II+=2
    Else
        While II<=len(FORMU) & instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789",toupper(mid$(FORMU,II,1)))<>0
            CHAINE+=mid$(FORMU,II,1)
            II+=1
        Wend
        If II<=len(FORMU)
            CHAINE+=mid$(FORMU,II,1)
            II+=1
        Endif
    Endif
  Wend
End CHAINE

Subprog GET_PAR_TYPE(CODTYP,TYPLEN,TABNUMB,CLASSCODE,REPCODE,MAINTABLE,MAINKEYFIELD,FLDLABEL,LINKEXPR,OK)
 Value Char CODTYP()
 Variable Integer TYPLEN
 Value Integer TABNUMB
 Variable Char CLASSCODE()
 Variable Char REPCODE()
 Variable Char MAINTABLE()
 Variable Char MAINKEYFIELD()
 Variable Integer FLDLABEL
 Variable Char LINKEXPR()
 Variable Integer OK

 Local Integer M,N,FOUND,NOLINK

  NOLINK=0 : # Enable the links for the moment

  OK=0

  Read [ATY]CODTYP=[L]CODTYP
  If fstat : OK=1 : End : Endif : # Error management has to be improved

# Find the length necessary to display the value
  If [ATY]CODTYP="M" and TABNUMB<>0
    # Modification : this is no more a link but an enumeration
    CLASSCODE="" : MAINTABLE="" : REPCODE="" : MAINKEYFIELD="" : FLDLABEL=0 : LINKEXPR=""
    OK=2
    End
    # The old previous code is still here
    M=0 : For N=1 To len(mess(0,TABNUMB,1)) : M=max(M,len(mess(N,TABNUMB,1))) : Next N
    TYPLEN=M
    If NOLINK : CLASSCODE="" : Goto NOLINK : Endif : # Added in order to disable the links
    CLASSCODE="APLSTD"
    MAINTABLE="APLSTD"
    REPCODE="APLSTD"
    MAINKEYFIELD="LANNUM"
    FLDLABEL=776 : # Message, a changer plus tard
    LINKEXPR=num$(TABNUMB)+"~{LANNUM}"
    End
  Elsif [ATY]CODTYP="ADI" and TABNUMB<>0
    Read [ADV]CODE=TABNUMB
    If fstat=0
        TYPLEN=[ADV]LNG
    Else
        TYPLEN= GLONADI
    Endif
    If NOLINK : CLASSCODE="" : Goto NOLINK : Endif : # Added in order to disable the links
    CLASSCODE="ATABDIV"
    MAINTABLE="ATABDIV"
    REPCODE="ATABDIV"
    MAINKEYFIELD="CODE"
    FLDLABEL=5096 : # Code, a changer plus tard
    LINKEXPR=num$(TABNUMB)+"~{CODE}"
    End
  Elsif [ATY]LNGTYP
    TYPLEN=[ATY]LNGTYP
  Endif

# Is there a class (Syracuse) ?
  CLASSCODE=""
  If [ATY]CODCLA<>"" and NOLINK=0 : # Added in order to disable the links
    Read [ACLA]ACLA0=[ATY]CODCLA
    If fstat=0
        CLASSCODE=[ATY]CODCLA
    Else
        OK=2
    Endif
  Endif
$NOLINK
  If CLASSCODE=""
    Raz MAINTABLE, MAINKEYFIELD, FLDLABEL, LINKEXPR, REPCODE
    End
  Endif

# Search a suitable main representation if any exists
  FOUND=0
  For [ASW] Where CODCLA=[ATY]CODCLA and TYPREP=1
    FOUND=1
    Break
  Next
  If FOUND
    REPCODE=[ASW]CODCLA
  Else
    REPCODE="" : End
  Endif

# Search the main table
  If [ACLA]TABREF<>""
    MAINTABLE=[ACLA]TABREF
  Else
    MAINTABLE="" : End
  Endif

# Get the key
  FOUND=0
  For [ATI] Where CODFIC=MAINTABLE and NUMLIG=1
    FOUND=1
    Break
  Next
  If FOUND
    # Is it a composite key ? If yes, stop (for the moment)
    If pat(vireblc([ATI]DESCRIPT,2),"?*+?*") or pat(vireblc([ATI]DESCRIPT,2),"?*-?*")
        OK=3 : End
    Endif
    Read [ATZ]CODZONE=MAINTABLE;vireblc([ATI]DESCRIPT,2)
    If fstat=0
        MAINKEYFIELD=toupper([ATZ]CODZONE)
        FLDLABEL=[ATZ]NOCOURT
        LINKEXPR="{"+MAINKEYFIELD+"}"
    Else
        OK=4
        End
    Endif
  Else
    OK=5
    End
  Endif
End

$GET
#Openo "/home/dbopp/trace.tra",0 Using [TRC]
#Wrseq "REPRESENTATION="+REPRESENTATION Using [TRC]
#Wrseq "TRT="+right$(REPRESENTATION,instr(1,REPRESENTATION,"~")+1) Using [TRC]
#Wrseq "PREFIX="+func PREFIX_TRT_PROTO+right$(REPRESENTATION,instr(1,REPRESENTATION,"~")+1) Using [TRC]
#Openo Using [TRC]
Gosub GET From =func PREFIX_TRT_PROTO+right$(REPRESENTATION,instr(1,REPRESENTATION,"~")+1)

# Prepare response
ASND.STAT     = 200
ASND.URL      = PSYR.PREFIX+'/'+REPRESENTATION
ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+"."+REPRESENTATION+"."+TYPE_REPRES
# ASND.DATA     = WCLOB
Return

# Functions that compute a shift in dates based on a periodicity

Funprog DELTA_MINUS(D1,D2,PERIOD)
Variable Date D1,D2
Value Integer PERIOD
Local Integer N

If D1=[0/0/0] or D2=[0/0/0] : End 0 : Endif

Gosub COMP_DELTA
Case PERIOD
  When 1   : If day(D1)=1 and day(D2)=day(eomonth(D2))
               N=month(D2)-month(D1)+12*(year(D2)-year(D1))+1
               D1=gdat$(day(D1),month(D1)-N,year(D1))
               D2=eomonth(gdat$(day(D2),month(D2)-N,year(D2)))
             Else
               D1-=N : D2-=N
             Endif
  When 2   : If day(D1)=1 and month(D1)=1 and day(D2)=day(eomonth(D2)) and month(D2)=12
               N=month(D2)-month(D1)+12*(year(D2)-year(D1))+1
               D1=gdat$(day(D1),month(D1)-N,year(D1))
               D2=gdat$(day(D2),month(D2)-N,year(D2))
             Else
               D1-=7*N : D2-=7*N
             Endif
  When 3   : D1=gdat$(day(D1),month(D1)-int((N+1)/2),year(D1))
             D2=gdat$(day(D2),month(D2)-int((N+1)/2),year(D2))
             D1=gdat$(1+14*(day(D1)>14),month(D1),year(D1))
             If day(D2)>14 : D2=eomonth(D2) : Else D2=gdat$(14,month(D2),year(D2)) : Endif
             If mod(N,2)
               If day(D1)<14 : D1=gdat$(15,month(D1),year(D1)) : Else D1=eomonth(D1) : Endif
               If day(D2)<14 : D2=gdat$(15,month(D2),year(D2)) : Else D2=eomonth(D2) : Endif
             Endif
  When 4,5 : D1=gdat$(day(D1),month(D1)-N*(1+2*(PERIOD=5)),year(D1))
             D2=eomonth(gdat$(day(D2),month(D2)-N*(1+2*(PERIOD=5)),year(D2)))
  When 6   : D1=gdat$(day(D1),month(D1),year(D1)-N)
             D2=gdat$(day(D2),month(D2),year(D2)-N)
  When 7   : D1=gdat$(min(day(D1),28),month(D1)-int((N+2)/3),year(D1))
             D2=gdat$(min(day(D2),28),month(D2)-int((N+2)/3),year(D2))
             D1=gdat$(1+9*(day(D1)>9)+10*(day(D1)>19),month(D1),year(D1))
             If day(D2)>19 : D2=eomonth(D2) : Else D2=gdat$(9+10*(day(D2)>9),month(D2),year(D2)) : Endif
             If mod(N,3)
               If    day(D1)=1 and mod(N,3)=2 : D1=gdat$(10,month(D1),year(D1))
               Elsif day(D1)=1 and mod(N,3)=1 : D1=gdat$(20,month(D1),year(D1))
               Elsif day(D1)=10 and mod(N,3)=2 : D1=gdat$(20,month(D1),year(D1))
               Elsif day(D1)=10 and mod(N,3)=1 : D1=gdat$(1,month(D1+1),year(D1))
               Elsif day(D1)=20 and mod(N,3)=2 : D1=gdat$(1,month(D1+1),year(D1))
               Elsif day(D1)=20 and mod(N,3)=1 : D1=gdat$(10,month(D1+1),year(D1))
               Endif
               If    day(D2)=9 and mod(N,3)=2 : D2=gdat$(19,month(D2),year(D2))
               Elsif day(D2)=9 and mod(N,3)=1 : D2=eomonth(D2)
               Elsif day(D2)=19 and mod(N,3)=2 : D2=eomonth(D2)
               Elsif day(D2)=19 and mod(N,3)=1 : D2=gdat$(9,month(D2+1),year(D2))
               Elsif day(D2)>=20 and mod(N,3)=2 : D2=gdat$(9,month(D2+1),year(D2))
               Elsif day(D2)>=20 and mod(N,3)=1 : D2=gdat$(19,month(D2+1),year(D2))
               Endif
             Endif
 Endcase
End N

$COMP_DELTA
Case PERIOD
  When 1,2 : N=int((D2-D1)/(1+6*(PERIOD-1)))+1
  When 3   : Q1=2*(month(D1)+12*year(D1))+(day(D1)>=15)
             Q2=2*(month(D2)+12*year(D2))+(day(D2)>=15)
             N=Q2-Q1+1
  When 4,5 : N=int((month(D2)-month(D1)+12*(year(D2)-year(D1)))/(1+2*(PERIOD=5)))+1
  When 6   : N=year(D2)-year(D1)+1
  When 7   : Q1=3*month(D1)+36*year(D1)+(day(D1)>=10)+(day(D1)>=20)
             Q2=3*month(D2)+36*year(D2)+(day(D2)>=10)+(day(D2)>=20)
             N=Q2-Q1+1
Endcase
Return

Funprog DELTA_PLUS(D1,D2,PERIOD)
Variable Date D1,D2
Value Integer PERIOD
Local Integer N

If D1=[0/0/0] or D2=[0/0/0] : End 0 : Endif

Gosub COMP_DELTA

Case PERIOD
  When 1   : If day(D1)=1 and day(D2)=day(eomonth(D2))
               N=month(D2)-month(D1)+12*(year(D2)-year(D1))+1
               D1=gdat$(day(D1),month(D1)+N,year(D1))
               D2=gdat$(day(D2),month(D2)+N,year(D2))
             Else
               D1+=N : D2+=N
             Endif
  When 2   : If day(D1)=1 and month(D1)=1 and day(D2)=day(eomonth(D2)) and month(D2)=12
               N=month(D2)-month(D1)+12*(year(D2)-year(D1))+1
               D1=gdat$(day(D1),month(D1)+N,year(D1))
               D2=gdat$(day(D2),month(D2)+N,year(D2))
             Else
               D1+=7*N : D2+=7*N
             Endif
  When 3   : D1=gdat$(day(D1),month(D1)+int(N/2),year(D1))
             D2=gdat$(day(D2),month(D2)+int(N/2),year(D2))
             D1=gdat$(1+14*(day(D1)>14),month(D1),year(D1))
             If day(D2)>14 : D2=eomonth(D2) : Else D2=gdat$(14,month(D2),year(D2)) : Endif
             If mod(N,2)
               If day(D1)<14 : D1=gdat$(15,month(D1),year(D1)) : Else D1=eomonth(D1) : Endif
               If day(D2)<14 : D2=gdat$(15,month(D2),year(D2)) : Else D2=eomonth(D2) : Endif
             Endif
  When 4,5 : D1=gdat$(day(D1),month(D1)+N*(1+2*(PERIOD=5)),year(D1))
             D2=eomonth(gdat$(day(D2),month(D2)+N*(1+2*(PERIOD=5)),year(D2)))
  When 6   : D1=gdat$(day(D1),month(D1),year(D1)+N)
             D2=gdat$(day(D2),month(D2),year(D2)+N)
  When 7   : D1=gdat$(min(day(D1),28),month(D1)+int(N/3),year(D1))
             D2=gdat$(min(day(D2),28),month(D2)+int(N/3),year(D2))
             D1=gdat$(1+9*(day(D1)>9)+10*(day(D1)>19),month(D1),year(D1))
             If day(D2)>19 : D2=eomonth(D2) : Else D2=gdat$(9+10*(day(D2)>9),month(D2),year(D2)) : Endif
            End "N="+num$(N)+" D1="+format$("D:DD[/]MM[/]YYYY",D1)+" D2="+format$("D:DD[/]MM[/]YYYY",D2)
             If mod(N,3)
               If    day(D1)=1 and mod(N,3)=1 : D1=gdat$(10,month(D1),year(D1))
               Elsif day(D1)=1 and mod(N,3)=2 : D1=gdat$(20,month(D1),year(D1))
               Elsif day(D1)=10 and mod(N,3)=1 : D1=gdat$(20,month(D1),year(D1))
               Elsif day(D1)=10 and mod(N,3)=2 : D1=gdat$(1,month(D1+1),year(D1))
               Elsif day(D1)=20 and mod(N,3)=1 : D1=gdat$(1,month(D1+1),year(D1))
               Elsif day(D1)=20 and mod(N,3)=2 : D1=gdat$(10,month(D1+1),year(D1))
               Endif
               If    day(D2)=9 and mod(N,3)=1 : D2=gdat$(19,month(D2),year(D2))
               Elsif day(D2)=9 and mod(N,3)=2 : D2=eomonth(D2)
               Elsif day(D2)=19 and mod(N,3)=1 : D2=eomonth(D2)
               Elsif day(D2)=19 and mod(N,3)=2 : D2=gdat$(9,month(D2+1),year(D2))
               Elsif day(D2)>=20 and mod(N,3)=1 : D2=gdat$(9,month(D2+1),year(D2))
               Elsif day(D2)>=20 and mod(N,3)=2 : D2=gdat$(19,month(D2+1),year(D2))
               Endif
             Endif
 Endcase
End N

