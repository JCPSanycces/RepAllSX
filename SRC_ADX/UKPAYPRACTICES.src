#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* UK-PAYPRACTICES report (english / LAN BRI )
#*
# Issue X3-54644 - 2017-09-20 by MWA : Report creation in GESARP
# Issue X3-54839 - 2017-09-20 by BEFOU : Creation View UKPAYPRACITCES
# Issue X3-54863 - 2017-09-20 by BEFOU : Crystal Report - Summary Stat 1 & 2
#  26/09/2017 By Befou Adding AREPORTM for filtrer Compagny / Group of Compagny
#*!

Local Char PARAM(10)(1..3) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AIMP1","AIMP1",4,"") From GTRAITE
End

$ACTION
Case ACTION
 When "OUVRE"   : Gosub OUVRE  From CPTRPT
 When "INIPAR"  : Gosub INIPAR From CPTRPT
 When "INIPAR2" : Gosub INIPAR From CPTRPT : # X3-22084
 When "CONT1"   : Gosub CONT1
Endcase
Return

$CONT1
  If [M]PARCOD(nolign-1) = "societe"
   # Either a legal company or a company group
   Local Integer K
   K = find("societe",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
   Read [CPY]CPY0 = [M:RPT]VALINT1(K-1)
   If !fstat and [F:CPY]CPYLEGFLG<>2
    If clalev([F:AGF])=0 : Local File AGRPFCY    [AGF]  : Endif
    Read [AGF]AGF0=[M:RPT]VALINT1(K-1)
    If !fstat
     If [F:AGF]FLGCPY<>2
      # Not a company group
      GMESSAGE = [M:RPT]VALINT1(K-1)+"\"+mess(63,127,1) : # Réservé au groupe de société
      mkstat = 2
      Return
     Endif
    Endif
   Endif
  Endif

  # X3-22084
  Case [M]PARCOD(nolign-1)
   When "grpcol"
    If [F:LED]COA = ""
     Local Integer K
     K = find("societe",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
     Read [CPY]CPY0 = [M:RPT]VALINT1(K-1)
     Read [GCM]GCM0 = [F:CPY]ACM
     Read [LED]LED0 = [F:GCM]LED([F:GCM]GENLEDTYP-1)
    Endif
   When "borne1"
    Gosub CHECK_BORNES
   When "borne2"
    Gosub CHECK_BORNES
  Endcase
  If mkstat=2 : Return : Endif
Return

$CHECK_BORNES
  # X3-22084
  Local Integer K
  Local Integer BORNE1, BORNE2
  Raz BORNE1,BORNE2
  K = find("borne1",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
  BORNE1 = val([M:RPT]VALINT1(K-1))
  K = find("borne2",[M:RPT]PARCOD(0..[M:RPT]NBRPAR-1))
  BORNE2 = val([M:RPT]VALINT1(K-1))

  # Controls if borne1 and borne2 are entered in the ascending order
  If BORNE1>BORNE2
    GMESSAGE = mess(207,104,1)
    mkstat=2
  Endif
Return

####################################################
## Etats UK-PAYPRACTICES
####################################################
Subprog IMPRIME(NBPAR, PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Local Char    PARAMAREPORTM(5)(1..10)
Local Integer NUMREQ, REPONSE, NUMLIG
Local Char PTYP(50), PNUM(50)
Local Date PSTRDAT, PENDDAT


####################################################
## Vérif paramètres
####################################################
  GOK = 1
  Call IMPRIME(NBPAR, PARAMETRE) From CPTRPT
  If GOK < 1
    End
  Endif

  Call TEMPON("O") From GESECRAN
  Gosub LOAD_PARAM
  #################################################################
  # Get the number of the request (put in LOAD_PARAM ? )
  Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM)
  NUMREQ = val(PARAM)
  PARAM = num$(NUMREQ)
  # Send the numedt to the report
  Call SETPARAM("numedt", NBPAR, PARAMETRE, PARAM) From ETAT
  ##################################################################

  Gosub OUVFIC
  ####################################################
  #RAZ of the table AREPORTM
  Gosub DEL_ENREG

  PARAMAREPORTM(1)=COLADEB
  PARAMAREPORTM(2)=COLAFIN
  PARAMAREPORTM(3)=GRPACOL

  NUMLIG =0
  Call GETTYPSOCSITGRP(SOCIETE,REPONSE) From CPTDIV #
  Case REPONSE
    When 0:End  # Inexisting
    When 1: # 1:société juridique
        Call INSERT_ENREG(SOCIETE,NUMREQ,"UK-PAYPRACTICES",NUMLIG,LANG,PARAMAREPORTM ) # Insert Line in AREPORTM
    When 2: End#2:SITE
    When 3: End#3:GRP DE SITE
    When 4: #4:GRP DE SOCIÉTÉS
      Filter [AGC] Where GRP=SOCIETE
      For [AGC]AGC0 # For
       Call INSERT_ENREG([F:AGC]CPY,NUMREQ,"UK-PAYPRACTICES",NUMLIG,LANG,PARAMAREPORTM ) # Insert Line in AREPORTM  [F:AGC]CPY
       NUMLIG+=1
      Next
    When Default
  Endcase

  # Gosub LOAD_PARAM

  #Call DEBTRANS From GLOCK
  # Gosub SET_CRITERES

  Call TEMPOFF From GESECRAN

End
#********************************************************************#
#* Deleting AREPORTM Lines With RPTCOD = UK-PAYPRACTUCES AND USER    #
#********************************************************************!
$DEL_ENREG

  GOK = 1
  Trbegin [ARM]
  Delete [ARM] Where USR = GUSER and RPTCOD='UK-PAYPRACTICES' and CREDAT< (date$-7 )
  Commit

Return
#********************************************************************#
#* WRITE LINE IN AREPORTM - SIMPLE
#* @param FCY - Society
#* @param NUMEDT Number of the request
#* @param RPTCOD Name of the report
#* @param NUMLIG Id Of The Line ( for not have duplicate key 0 if  )
#*!
Subprog INSERT_ENREG(FCY,NUMEDT,RPTCOD,NUMLIG,LAN,PARAM)
Value Char    PARAM()(1..10)
Value Char FCY() , RPTCOD , LAN
Value Integer NUMEDT,NUMLIG
  # Insert line in AREPORTM
  GOK=1
  Trbegin [ARM]
    [F:ARM]RPTCOD = RPTCOD
    [F:ARM]USR    = GUSER
    [F:ARM]NUMREQ = NUMEDT
    [F:ARM]NUMLIG = NUMLIG
    [F:ARM]CLEA1  = FCY
    [F:ARM]CLEA2 = PARAM(1) #COLADEB(GLONSAC)
    [F:ARM]CLEA3 = PARAM(2) #COLAFIN(GLONSAC)
    [F:ARM]CLEA4 = PARAM(3) #GRPACOL(GLONGSC)
    [F:ARM]CLEA5 = LAN #GRPACOL(GLONGSC)
    [F:ARM]CREDAT=date$
    Write [ARM] # WRITING
    If fstat
      GOK = 0 : Call FSTA("ARM") From GLOCK
    Endif
    If GOK=0 : Rollback : End : Endif
    Commit
End

$OUVFIC
  If clalev([F:ARM])=0  : Local File AREPORTM   [ARM]  : Endif
  If clalev([F:AGC])=0  : Local File AGRPCPY   [AGC]  : Endif
Return

#**
#* Read parameters
#*!
$LOAD_PARAM

Local Char    PARAM(30) , ETAT(GLONARP)
Local Char    SOCIETE(GLONCPY)
Local Char    X3PRF(GLONAPM) , X3FCT(GLONAFC) , LANG
Local Char    COLADEB(GLONSAC), COLAFIN(GLONSAC), GRPACOL(GLONGSC)

  Call GETPARAM("X3ETA",NBPAR,PARAMETRE,PARAM)
  J = instr(1, PARAM, ".")
  If J
    PARAM = left$(PARAM, J - 1)
  Endif
  ETAT = PARAM

  Call GETPARAM("societe", NBPAR, PARAMETRE, SOCIETE)

  # Collectifs Grp of Collectifs #
  Call GETPARAM("coldeb", NBPAR,PARAMETRE, COLADEB)
  Call GETPARAM("colfin", NBPAR, PARAMETRE, COLAFIN)
  Call GETPARAM("grpcol", NBPAR, PARAMETRE, GRPACOL)

  Call GETPARAM("X3PRF",NBPAR,PARAMETRE,X3PRF)
  Call GETPARAM("X3FCT",NBPAR,PARAMETRE,X3FCT)
  Call GETPARAM("X3LAN",NBPAR,PARAMETRE,LANG)

Return

#**
#* retrieve the param's value
#*
#* @param PARAM
#* @param NBPAR
#* @param PARAMETRE
#* @param VALEUR
#*!
Subprog GETPARAM(PARAM, NBPAR, PARAMETRE, VALEUR)
Value    Char    PARAM()
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR()

Local Integer L

  Call GETPARAM(PARAM, NBPAR, PARAMETRE, VALEUR) From ETAT
  L = len(PARAM)
  If right$(PARAM,L-2) = "deb"
    If VALEUR = string$(len(VALEUR)," ")
      VALEUR = ""
    Endif
  Elsif right$(PARAM,L-2) = "fin"
    If VALEUR = string$(len(VALEUR),"z")
      VALEUR = ""
    Endif
  Endif
End

