#<AdxTL>@(#)3.0.0.0 $Revision$
Local Char PARAM(30)(1..1) , VALEUR(250)
GSERVEUR = 0
Call TRAITE_CHAR(VALEUR,PARAM,"","PATCH","PATCH",3,"") From GTRAITE
End

#---------------------------------------------------#
## Integration of Representation
#---------------------------------------------------#

$PRESENTATIONS
Local File =DOSSIER(D)+".ASHW"       [ASW]
&         ,=DOSSIER(D)+".ASHW"       [ASW2]
&         ,=DOSSIER(D)+".ASHW"       [ASW3]
&         ,=DOSSIER(D)+".ASHWFLD"    [ASWF]
&         ,=DOSSIER(D)+".ASHWPAR"    [ASWP]
&         ,=DOSSIER(D)+".ASHWPAR"    [ASWP2]
&         ,=DOSSIER(D)+".ASHWEXPPRO" [ASWR]
&         ,=DOSSIER(D)+".ASHWEXPPRO" [ASWR2]
&         ,=DOSSIER(D)+".ASHWMET"    [ASWM]
&         ,=DOSSIER(D)+".ASHWMET"    [ASWM2]
&         ,=DOSSIER(D)+".ASHWPARMET" [ASWMP]
&         ,=DOSSIER(D)+".ASHWPARMET" [ASWMP2]
&         ,=DOSSIER(D)+".ASHWLNK"    [ASWK]
&         ,=DOSSIER(D)+".ASHWLNK"    [ASWK2]
&         ,=DOSSIER(D)+".ASHWOPT"    [ASWO]
&         ,=DOSSIER(D)+".ASHWOPT"    [ASWO2]
&         ,=DOSSIER(D)+".ASHWCOL"    [ASWC]
&         ,=DOSSIER(D)+".ASHWCOL"    [ASWC2]
&         ,=DOSSIER(D)+".ASHWSEC"    [ASWS]
&         ,=DOSSIER(D)+".ASHWSEC"    [ASWS2]
&         ,=DOSSIER(D)+".ASHWBLC"    [ASWB]
&         ,=DOSSIER(D)+".ASHWBLC"    [ASWB2]
&         ,=DOSSIER(D)+".ASHWMENU"   [ASWMN]
&         ,=DOSSIER(D)+".ASHWMENU"   [ASWMN2]
&         ,=DOSSIER(D)+".ACLAOPT"    [ACLAO]

Local Integer NMET, NALIAS, NOPT, NMEN
Local Char    TBMET(GLONASM)(1..)
Local Char    TBALIAS(GLONAVB)(1..)
Local Char    TBOPT(10)(1..)
Local Char    TBMEN(GLONAVA)(1..)
Local Char    OLDACT(GLONACT)
Local Char    OLDABR(GLONABR)
Local Char    WCODLNK(GLONAVA),WANCLNK(GLONAVC)
Local Integer WAFFLNK
Local Integer B,J,I,K,OK_LNK
Local Char WBLC(10),WSEC(10)
Local Char WACTBLC (GLONACV), WACTSEC(GLONACV)

Local Integer WENAFAC(10)

Local Integer WNBFLDGRPPRO
Local Char WFLDGRPPRO(GLONAVC)(1..)

Local Integer WNBEXPPRO
Local Char WEXPPRO(GLONAVC)(1..)

Local Integer WNBCOL
Local Char WCOL(GLONAVC)(1..)

#115502
Local Integer NLNK
Local Char TBLNK(250)(1..)

#95271
Local Char    RES_COD(80)(0..),RES_CLA(GLONACLA)(0..), RES_TIT(30)(0..)
Local Integer RES_TYP(0..), RES_MOD(0..), RES_ORD(0..), RES_NBR, RES_NO
Local Char    WWCODPAR(80)(0..),WWCODCLAPAR(GLONACLA)(0..),WWCODCUR(80)(0..),WWFLDCLE(250)(0..), WWINTITPAR(30)(0..)
Local Integer WWTYPINTPAR(0..), WWADRVAL(0..), WWTYPKEY(0..), WWNUMPAR(0..),WWTYPPAR(0..),WWNOLIB(0..),WWLNG(0..),WWTYPAFF(0..), WWNBRPARALL
#

Read [ASW]ASW0 = NOMOBJ
If TYPENR=2 :#SCM deletion
 If fstat
  NEWOBJ = 1
  Raz [F:ASW]
 Elsif [F:ASW]CODACT>="X" & !find([F:ASW]CODACT,ACTIV(1..NBACT))
  Call ECR_TRACE("---"-mess(37,115,1),0) From GESECRAN : # Objet spécifique
  Gosub FIN_OBJ From PATCH
  Goto FIN_REPRES
 Else
  NEWOBJ = 0
 Endif
 # Pour faire synchro des liens en fin de patch
 If dim(ISASWMOD)>0 : ISASWMOD+=1 : Endif
 Call DEBTRANS From GLOCK
 Gosub TR_ASW
Elsif TYPENR=-2 :#SCM deletion
 If !fstat
  Call DEBTRANS From GLOCK
  Gosub DEL_ASW
 Endif
 Gosub FIN_OBJ From PATCH
Endif
$FIN_REPRES
Close Local File [ASW], [ASWF], [ASWP], [ASWR], [ASWM], [ASWMP], [ASWO], [ASWC], [ASWS], [ASWB], [ASWK], [ASWMN], [ACLAO]
Close Local File [ASW2], [ASW3], [ASWP2], [ASWR2], [ASWM2], [ASWMP2], [ASWO2],[ASWC2],[ASWS2],[ASWB2], [ASWK2], [ASWMN2]
Return

$DEL_ASW
Local Char CODE(GLONASW) : [L]CODE = [L]NOMOBJ
Trbegin [ASW]
 Gosub ANNULE From SUBASW
 If fstat : GOK = 0 : ER = 99 : ERFIC = "ASHW"-NOMOBJ : Return : Endif
 Delete [ASW] Curr
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ASHW"-NOMOBJ : Return
 Endif
Commit
Call  UPDATE_RIGHTSETAG(DOSSIER(D)) From ASYRFNC
Call DELETE_ALLSTC(DOSSIER(D),[L]NOMOBJ) From ASHWVALSUB
If [L]ISOKSPOTTING=2 : Call TRACE_COR_PATCH("ASW",NOMOBJ,"","A") From GOBJET : Endif
Call ECR_TRACE(func AFNC.MES1(mess(61,149,1),NOMOBJ),0) From GESECRAN : #  : ENREGISTREMENT SUPPRIMÉ
Return

#-------------------------------------------------#
$TR_ASW
Raz WNBFLDGRPPRO,WNBEXPPRO,WNBCOL
Raz WFLDGRPPRO,WEXPPRO,WCOL
WENAFAC(0)=1 : WENAFAC(1)=1 : WENAFAC(2)=1 : WENAFAC(3)=1 : WENAFAC(4)=1 : WENAFAC(5)=1
WENAFAC(6)=1 : WENAFAC(6)=1 : WENAFAC(6)=1 : WENAFAC(9)=1
[F:ASW2]=[F:ASW]
Trbegin [ASW], [ASWF], [ASWP], [ASWR], [ASWM], [ASWMP], [ASWO],[ASWC],[ASWS],[ASWB], [ASWK], [ASWMN] , [ATX]
#95271
Delete [ASWP]  Where CODREP=NOMOBJ & TYPPAR=9

 NBZ = 0
 Repeat
  Gosub LIRE From PATCH
  Case TYPENR
   When 7 : # Normal End
    Break
   When 3 : # For each element
    IDENT = CHAMP(2)
    Case CHAMP(1)
     When "ASW"   : Gosub ASW1
     When "ASWF"  : Gosub ASW2
     When "ASWM"  : Gosub ASW3
     When "ASWMP" : Gosub ASW4
     When "ASWS"  : Gosub ASW51
     When "ASWB"  : Gosub ASW52
     When "ASWR"  : Gosub ASW6
     When "ASWK"  : Gosub ASW7
     When "ASWP"  : Gosub ASW8
     When "ASWO"  : Gosub ASW9
     When "ASWC"  : Gosub ASW10
     When "ASWMN" : Gosub ASW11
     When Default : ER = 31
    Endcase
   When Default
    ER = 32
  Endcase
  If ER or !OKOBJ : Break : Endif
 Until 1=0
 If ER or !OKOBJ : Goto ABORT : Endif

## removal of excess options

 For [ASWO]ASWO0 Where CODREP=NOMOBJ
  If [F:ASWO]OPTFLGCLA=2
   Read [ACLAO]ACLAO0=[F:ASW]CODCLA;[F:ASWO]OPTCOD
   If fstat
    Delete [ASWO]
   Elsif !find([F:ACLAO]OPTCOD,TBOPT(1..NOPT))
&  & ([F:ACLAO]OPTACT<"X" or find([F:ACLAO]OPTACT,ACTIV(1..NBACT)))
    Delete [ASWO]
   Endif
  Else
   If !find([F:ASWO]OPTCOD,TBOPT(1..NOPT))
&  & ([F:ASWO]OPTACT<"X" or find([F:ASWO]OPTACT,ACTIV(1..NBACT)))
    Delete [ASWO]
   Endif
  Endif
 Next

## removal of excess fields

 For [ASWF]ASWF0 Where CODREP=NOMOBJ
  If !find([F:ASWF]CODFLD,ZONE(1..NBZ))
&  & ([F:ASWF]ACTFLD<"X" or find([F:ASWF]ACTFLD,ACTIV(1..NBACT)))
   Delete [ASWP] Where CODREP=[F:ASWF]CODREP & (TYPPAR=1 | TYPPAR=2) & CODFLD=[F:ASWF]CODFLD
   Delete [ASWF]
  Else
   #95271
   Gosub FILL_FLD_PAR
   For RES_NO=0 To [L]RES_NBR-1
    If !find(RES_COD(RES_NO),"AINSTANCE","APRONAME","AVALCNT","AEXIST","AVALUE","AFORMAT")
     Read [ASWP]ASWP0 = NOMOBJ; 1; 1;[F:ASWF]CODFLD;"";1;[L]RES_COD(RES_NO)
     If fstat
      Read [ASWP]ASWP0 = NOMOBJ; 9; 1;[F:ASWF]CODFLD;"";1;[L]RES_COD(RES_NO)
      If !fstat
       [F:ASWP]TYPPAR=1
       Write [ASWP]
       If fstat
        GOK = 0 : Call FSTA("ASWP") From GLOCK : Break 2
       Endif
      Endif
     Endif
    Endif
   Next
   For RES_NO=0 To [L]WWNBRPARALL-1
    Read [ASWP]ASWP0 = NOMOBJ; 1; 2;[F:ASWF]CODFLD;"";1;[L]WWCODPAR(RES_NO)
    If fstat
     Read [ASWP]ASWP0 = NOMOBJ; 9; 2;[F:ASWF]CODFLD;"";1;[L]WWCODPAR(RES_NO)
     If !fstat
       [F:ASWP]TYPPAR=1
       Write [ASWP]
       If fstat
        GOK = 0 : Call FSTA("ASWP") From GLOCK : Break 2
       Endif
     Endif
    Endif
   Next
   #
  Endif
$SUITEASWF
 Next
 #95271
 Delete [ASWP]  Where CODREP=NOMOBJ & TYPPAR=9
 If ER or !OKOBJ : Goto ABORT : Endif

## removal of excess methods

 For [ASWM]ASWM0 Where CODREP=NOMOBJ
  If !find([F:ASWM]CODMET,TBMET(1..NMET))
&  & ([F:ASWM]ACTMET<"X" or find([F:ASWM]ACTMET,ACTIV(1..NBACT)))
   Delete [ASWMP] Where CODREP=[F:ASWM]CODREP & CODMET=[F:ASWM]CODMET
   Delete [ASWM]
  Endif
 Next

## removal of excess menu

 For [ASWMN]ASWMN0 Where CODREP=NOMOBJ
  If !find([F:ASWMN]CODMENU,TBMEN(1..NMEN))
&  & ([F:ASWMN]ACTMENU<"X" or find([F:ASWMN]ACTMENU,ACTIV(1..NBACT)))
   Delete [ASWMN]
  Endif
 Next

## removal of excess properties
 For [ASWR]ASWR0 Where CODREP=NOMOBJ
  WBLC=[F:ASWR]BLCPRO
  Gosub FIND_ACTBLCSEC
  If dim([F:ASWR]ACTPRO)>0 & [F:ASWR]ACTPRO>="X" & !find([F:ASWR]ACTPRO,ACTIV(1..NBACT)) : # Specific
     OLDACT = [F:ASWR]ACTPRO
  Elsif WACTBLC>="X" & !find(WACTBLC,ACTIV(1..NBACT)) : # Specific
     OLDACT = WACTBLC
  Elsif WACTSEC>="X" & !find(WACTSEC,ACTIV(1..NBACT)) : # Specific
     OLDACT = WACTSEC
  Else
     OLDACT=""
  Endif

  If !find([F:ASWR]ALIAS,TBALIAS(1..NALIAS))
&  & (OLDACT<"X" or find(OLDACT,ACTIV(1..NBACT)))
   Delete [ASWR]
  Else
   WNBFLDGRPPRO+=1
   WFLDGRPPRO(WNBFLDGRPPRO)=func SUBASW_TOOL.GET_COL_FROM_PRO_PATH_DOSS(DOSSIER(D),[F:ASW]CODREP,[F:ASW]CODCLA,[F:ASW]ABRCLA,[F:ASWR]CODPRO,1)
   WNBEXPPRO+=1
   WEXPPRO(WNBEXPPRO)=[F:ASWR]CODPRO
   If [F:ASWR]DETPRO=2 : WENAFAC(0)=2 : Endif
   If [F:ASWR]QRYPRO=2 : WENAFAC(2)=2 : Endif
   If [F:ASWR]EDIPRO=2 : WENAFAC(1)=2 : Endif
   If [F:ASWR]LOKPRO=2 : WENAFAC(3)=2 : Endif
   If [F:ASWR]SUMPRO=2 : WENAFAC(4)=2 : Endif
   Endif
 Next

 ## removal of excess Collections

 For [ASWC]ASWC0 Where CODREP=NOMOBJ
  If ([F:ASWC]ACTCOL<"X" or find([F:ASWC]ACTCOL,ACTIV(1..NBACT)))
   #delete non-used collections
   J=0
   If WNBFLDGRPPRO>0
  J+=find([F:ASWC]CODCOL,WFLDGRPPRO(1..WNBFLDGRPPRO))
   Endif
   If J=0
 For [ASWF] Where CODREP=[F:ASW]CODREP & FLDGRP=[F:ASWC]CODCOL
   J=1
   Break
 Next
   Endif
   If J=0
 Delete [ASWC]
   Else
 WNBCOL+=1
 WCOL(WNBCOL)=[F:ASWC]CODCOL
   Endif
  Else
   WNBCOL+=1
   WCOL(WNBCOL)=[F:ASWC]CODCOL
  Endif
 Next

## removal of excess Links

 For [ASWK]ASWK0 Where CODREP=NOMOBJ
  If ([F:ASWK]ACVLNK<"X" or find([F:ASWK]ACVLNK,ACTIV(1..NBACT)))
   [L]OK_LNK=1
   Case [F:ASWK]AFFLNK
    When 1
      If !find([F:ASWK]ANCLNK,WEXPPRO(1..WNBEXPPRO)) : [L]OK_LNK=0 : Endif
    When 2,3
      If !find([F:ASWK]ANCLNK,WCOL(1..WNBCOL)) : [L]OK_LNK=0 : Endif
   Endcase
   #115502
   If [L]OK_LNK=1
    If !find(num$([F:ASWK]AFFLNK)+'/'+[F:ASWK]ANCLNK+'/'+[F:ASWK]CODLNK,TBLNK(1..NLNK))
      [L]OK_LNK=0
    Endif
   Endif
   If [L]OK_LNK=0
    Delete [ASWP] Where CODREP=[F:ASWK]CODREP & TYPPAR=3 & CODFLD=[F:ASWK]ANCLNK & CODLNK=[F:ASWK]CODLNK & AFFLNK=[F:ASWK]AFFLNK
    Delete [ASWK]
   Endif
  Endif
 Next


 #delete non-used blocks
 For [ASWB]ASWB0 Where CODREP=NOMOBJ
   J=0
   For [ASWR] Where CODREP=NOMOBJ & BLCPRO=[F:ASWB]CODBLC
      J=1
      Break
   Next
   If J=0
     Delete [ASWB]
   Endif
 Next ASWB

 #delete non-used sections
 For [ASWS]ASWS0 Where CODREP=NOMOBJ
   J=0
   For [ASWB] Where CODREP=NOMOBJ & SECBLC=[F:ASWS]CODSEC
      J=1
      Break
   Next
   If J=0
     Delete [ASWS]
   Endif
 Next DASWS

 ## Update of facets
 Read [ASW]ASW0 = NOMOBJ
 For B=0 To [F:ASW]NBRFAC-1
   [F:ASW]ENAFAC(B) = WENAFAC(B)
   If [F:ASW2]ACTLNKFAC(B)>="X" & !find([F:ASW2]ACTLNKFAC(B),ACTIV(1..NBACT)) : # Specific
    [F:ASW]DEFLNKFAC(B) = [F:ASW2]DEFLNKFAC(B)
    [F:ASW]AFFLNKFAC(B) = [F:ASW2]AFFLNKFAC(B)
    [F:ASW]LNKMENFAC(B) = [F:ASW2]LNKMENFAC(B)
    [F:ASW]ACTLNKFAC(B) = [F:ASW2]ACTLNKFAC(B)
   Endif
 Next B
 Rewrite [ASW]
 If fstat
  GOK = 0 : ER = 99 : ERFIC = "ASHW"-[F:ASW]CODREP : Return
 Endif

 If ER or !OKOBJ : Goto ABORT : Endif
Commit

## validation
If [L]ISOKSPOTTING=2
Call TRACE_COR_PATCH("ASW",[F:ASW]CODREP,"",string$(NEWOBJ>0,"C")+string$(NEWOBJ=0,"M")) From GOBJET
Endif

Gosub SAV_OPENI From PATCH
# Dans l'appli X3 , on ne valide que les objets des modules Superviseur, tronc commun, développement
# 119695: si patch SCM, on valide toujours
If GPRODUIT<>0 | APPLI<>GDOSX3 | find([F:ASW]MODULE,1,9,10) | (dim([L]ISFULLMOD)>0 & [L]ISFULLMOD = 2)
 Call ECR_TRACE("---"-mess(14,123,1)-TYPOBJ-NOMOBJ,0) From GESECRAN : # Validation
 Local Integer ASAVGVALID : ASAVGVALID =GVALIDDIFF
 GVALIDDIFF = 3
 Call VALIDATION(0,APPLI,NOMOBJ) From SUBASW
 GVALIDDIFF = ASAVGVALID
Endif
Gosub REST_OPENI From PATCH
Return

$ABORT
Rollback
Return


#---------------------------------------------------#
## Header Representations
#---------------------------------------------------#

$ASW1
FICHIER = "ASHW" : ABR = "ASW"
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
MODOBJ = max(1,[F:ASW]MODULE)
If [F:ADS]MODULE(MODOBJ-1)<>2
 OKOBJ = 0 : Return
Endif
ACVOBJ = [F:ASW]CODACT
If ACVOBJ<>"" & [F:ADS]DOSSIER<>GDOSX3
 Read [ACV]CODACT = ACVOBJ
 If fstat or [F:ACV]FLACT<>2
  OKOBJ = 0 : Return
 Endif
Endif
If NEWOBJ
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ASW]CREUSR = GUSER
  [F:ASW]UPDUSR = GUSER
 Endif
 Write [ASW]
Else
 # Get specifics treatments
 For B=0 To [F:ASW2]NBRTRT-1
  If [F:ASW2]ACTTRT(B)>="X" & !find([F:ASW2]ACTTRT(B),ACTIV(1..NBACT))
   J=find([F:ASW2]CODTRT(B),[F:ASW]CODTRT(0..[F:ASW]NBRTRT-1))
   If J
      [F:ASW]CODTRT(J-1) = [F:ASW2]CODTRT(B)
      [F:ASW]TYPTRT(J-1) = [F:ASW2]TYPTRT(B)
      [F:ASW]ACTTRT(J-1) = [F:ASW2]ACTTRT(B)
      [F:ASW]RANTRT(J-1) = [F:ASW2]RANTRT(B)
   Else
      J=[F:ASW]NBRTRT
      [F:ASW]NBRTRT +=1
      [F:ASW]CODTRT(J) = [F:ASW2]CODTRT(B)
      [F:ASW]TYPTRT(J) = [F:ASW2]TYPTRT(B)
      [F:ASW]ACTTRT(J) = [F:ASW2]ACTTRT(B)
      [F:ASW]RANTRT(J) = [F:ASW2]RANTRT(B)
   Endif
  Endif
 Next B
 If (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0) :#U11 patch SCM
  [F:ASW]UPDUSR = GUSER
 Endif
 Rewrite [ASW]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ASHW"-[F:ASW]CODREP : Return
Endif
Return

#---------------------------------------------------#
## Fields
#---------------------------------------------------#

$ASW2
NBZ += 1 : ZONE(NBZ) = IDENT
FICHIER = "ASHWFLD" : ABR = "ASWF"
OLDABR=ABR
Read [ASWF]ASWF0 = NOMOBJ;IDENT
If fstat
 NEWZON = 1
 OLDACT = ""
 Raz [F:ASWF]
Elsif ([F:ASWF]ACTFLD>="X" & !find([F:ASWF]ACTFLD,ACTIV(1..NBACT)))
# Specific
 Call ECR_TRACE([F:ASWF]CODFLD-mess(147,126,1)-"("+[F:ASWF]ACTFLD+")",0) From GESECRAN
# Specific
 Gosub FIN_FIC From PATCH
 OLDACT = [F:ASWF]ACTFLD
 Return
Else
 NEWZON = 0
 OLDACT = [F:ASWF]ACTFLD
Endif
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  OK = 1
# Respect des codes d'accès, table de contrôle
  If find(VARIA,"ACS","CODCTL","TABCONT") and (dim([L]ISFULLMOD)<0 or [L]ISFULLMOD=0)
   If evalue("[F:ASWF]"+VARIA)<>""
    OK = 0
   Endif
  Endif
  If OK
   Gosub AFF_ZONE From PATCH
   If GOK<1 : ER = 99 : Break : Endif
  Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
#95271
Update [ASWP2] Where CODREP=[F:ASWF]CODREP & TYPPAR=1 & CODFLD=[F:ASWF]CODFLD With TYPPAR=9
Delete [ASWP2] Where CODREP=[F:ASWF]CODREP & TYPPAR=2 & CODFLD=[F:ASWF]CODFLD
If NEWZON
 Write [ASWF]
Else
 Rewrite [ASWF]
Endif
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ASHWFLD"-[F:ASWF]CODREP-[F:ASWF]CODFLD : Return
Endif

Return




#---------------------------------------------------#
## Methods
#---------------------------------------------------#

$ASW3
FICHIER = "ASHWMET" : ABR = "ASWM"
NMET += 1 : TBMET(NMET) = IDENT
Read [ASWM]ASWM0 = NOMOBJ;IDENT
If !fstat & [F:ASWM]ACTMET>="X" & !find([F:ASWM]ACTMET,ACTIV(1..NBACT)) : # Specific
 Gosub FIN_FIC From PATCH
 OLDACT = [F:ASWM]ACTMET
 Return
Elsif !fstat
 OLDACT = [F:ASWM]ACTMET
Else
 OLDACT = ""
Endif
Raz [F:ASWM]
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif

Delete [ASWMP2]  Where CODREP=NOMOBJ & CODMET=[F:ASWM]CODMET
Delete [ASWM2] Where CODREP=NOMOBJ & CODMET=[F:ASWM]CODMET
Write [ASWM]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ASHWMET"-[F:ASWM]CODREP-[F:ASWM]CODMET : Return
Endif
Return

#---------------------------------------------------#
## Methods parameters
#---------------------------------------------------#

$ASW4
FICHIER = "ASHWPARMET" : ABR = "ASWMP"
Read [ASWM]ASWM0 = NOMOBJ;IDENT
If !fstat & OLDACT>="X" & !find(OLDACT,ACTIV(1..NBACT)) : # Specific
 Gosub FIN_FIC From PATCH
 Return
Endif
Raz [F:ASWMP]
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
#Delete [ASWMP2] Where CODREP=NOMOBJ & CODMET=[F:ASWMP]CODMET & CODPARMET=[F:ASWMP]CODPARMET
Write [ASWMP]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ASHWPARMET"-[F:ASWMP]CODREP-[F:ASWMP]CODMET-[F:ASWMP]CODPARMET : Return
Endif
Return


$ASW51
FICHIER = "ASHWSEC" : ABR = "ASWS"
Read [ASWS]ASWS0 = NOMOBJ;IDENT
If !fstat & [F:ASWS]ACTSEC>="X" & !find([F:ASWS]ACTSEC,ACTIV(1..NBACT)) : # Specific
 Gosub FIN_FIC From PATCH
 OLDACT = [F:ASWS]ACTSEC
 Return
Elsif !fstat
 OLDACT = [F:ASWS]ACTSEC
Else
 OLDACT = ""
Endif
Raz [F:ASWS]
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif

Delete [ASWS2] Where CODREP=NOMOBJ & CODSEC=[F:ASWS]CODSEC
Write [ASWS]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ASHWSEC"-[F:ASWS]CODREP-[F:ASWS]CODSEC : Return
Endif
Return

$ASW52
FICHIER = "ASHWBLC" : ABR = "ASWB"
Read [ASWB]ASWB0 = NOMOBJ;IDENT
If !fstat & [F:ASWB]ACTBLC>="X" & !find([F:ASWB]ACTBLC,ACTIV(1..NBACT)) : # Specific
 Gosub FIN_FIC From PATCH
 OLDACT = [F:ASWB]ACTBLC
 Return
Elsif !fstat
 OLDACT = [F:ASWB]ACTBLC
 WSEC=[F:ASWB]SECBLC
 Gosub FIND_ACTSEC
 If WACTSEC>="X" & !find(WACTSEC,ACTIV(1..NBACT)) : # Specific
   Gosub FIN_FIC From PATCH
   OLDACT = [F:ASWB]ACTBLC
   Return
 Endif
Else
 OLDACT = ""
Endif
Raz [F:ASWB]
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif

# block, creation if not in a specific section
WSEC=[F:ASWB]SECBLC
Gosub FIND_ACTSEC
If WACTSEC>="X" & !find(WACTSEC,ACTIV(1..NBACT)) : # Specific
  Return
Endif

Delete [ASWB2] Where CODREP=NOMOBJ & CODBLC=[F:ASWB]CODBLC
Write [ASWB]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ASHWBLC"-[F:ASWB]CODREP-[F:ASWB]CODBLC : Return
Endif
Return

#---------------------------------------------------#
## Properties
#---------------------------------------------------#

$ASW6
FICHIER = "ASHWEXPPRO" : ABR = "ASWR"
NALIAS += 1 : TBALIAS(NALIAS) = IDENT
Read [ASWR]ASWR0 = NOMOBJ;IDENT
If fstat
  OLDACT = ""
Else
  WBLC=[F:ASWR]BLCPRO
  Gosub FIND_ACTBLCSEC
  If dim([F:ASWR]ACTPRO)>0 & [F:ASWR]ACTPRO>="X" & !find([F:ASWR]ACTPRO,ACTIV(1..NBACT)) : # Specific
     Gosub FIN_FIC From PATCH
     OLDACT = [F:ASWR]ACTPRO
     Return
  Elsif WACTBLC>="X" & !find(WACTBLC,ACTIV(1..NBACT)) : # Specific
     Gosub FIN_FIC From PATCH
     OLDACT = WACTBLC
     Return
  Elsif WACTSEC>="X" & !find(WACTSEC,ACTIV(1..NBACT)) : # Specific
     Gosub FIN_FIC From PATCH
     OLDACT = WACTSEC
     Return
  Endif
Endif
Raz [F:ASWR]
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif

# propertie, creation if not in a specific block/section
WREP=[F:ASWR]CODREP
WBLC=[F:ASWR]BLCPRO
Gosub FIND_ACTBLCSEC
If WACTBLC>="X" & !find(WACTBLC,ACTIV(1..NBACT)) : # Specific
   OLDACT = WACTBLC
   Return
Elsif WACTSEC>="X" & !find(WACTSEC,ACTIV(1..NBACT)) : # Specific
   OLDACT = WACTSEC
   Return
Endif

Delete [ASWR2] Where CODREP=NOMOBJ & ALIAS=[F:ASWR]ALIAS
Write [ASWR]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ASHWEXPPRO"-[F:ASWR]CODREP-[F:ASWR]ALIAS : Return
Endif
Return

#--------------------------------------------#
# Find actvity code for a bloc/section (WBLC)
#--------------------------------------------#
$FIND_ACTBLCSEC
Raz WACTBLC, WACTSEC
Read [ASWB]ASWB0=[F:ASW]CODREP;WBLC
If !fstat
  WACTBLC=[F:ASWB]ACTBLC
  Read [ASWS]ASWS0=[F:ASW]CODREP;[F:ASWB]SECBLC
  If !fstat
    WACTSEC=[F:ASWS]ACTSEC
  Endif
Endif
Return

#--------------------------------------------#
# Find actvity code for a section (WSEC)
#--------------------------------------------#
$FIND_ACTSEC
Raz WACTSEC

Read [ASWS]ASWS0=[F:ASW]CODREP;WSEC
If !fstat
  WACTSEC=[F:ASWS]ACTSEC
Endif
Return

#---------------------------------------------------#
## Links
#---------------------------------------------------#

$ASW7
FICHIER = "ASHWLNK" : ABR = "ASWK"
OLDABR=ABR
K = instr(1,IDENT,"~")
If K
 [L]WCODLNK = left$(IDENT,K-1)
 [L]IDENT = right$(IDENT,K+1)
 K = instr(1,IDENT,"~")
 If K
  [L]WAFFLNK = val(left$(IDENT,K-1))
  [L]WANCLNK = right$(IDENT,K+1)
 Else
  Gosub FIN_OBJ From PATCH
  Return
 Endif
Else
 Gosub FIN_OBJ From PATCH
 Return
Endif
NLNK += 1 : TBLNK(NLNK) = num$(WAFFLNK)+'/'+WANCLNK+'/'+WCODLNK : #115502
Read [ASWK]ASWK0 = NOMOBJ;WAFFLNK;WANCLNK;WCODLNK
If !fstat & [F:ASWK]ACVLNK>="X" & !find([F:ASWK]ACVLNK,ACTIV(1..NBACT)) : # Specific
 Gosub FIN_FIC From PATCH
 OLDACT = [F:ASWK]ACVLNK
 Return
Elsif !fstat
 OLDACT = [F:ASWK]ACVLNK
Else
 OLDACT = ""
Endif
Raz [F:ASWK]
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif

Delete [ASWP] Where CODREP=[F:ASWK]CODREP & TYPPAR=3 & CODFLD=[F:ASWK]ANCLNK & CODLNK=[F:ASWK]CODLNK & AFFLNK=[F:ASWK]AFFLNK
Delete [ASWK2] Where CODREP=NOMOBJ & CODLNK=[F:ASWK]CODLNK & ANCLNK=[F:ASWK]ANCLNK & AFFLNK=[F:ASWK]AFFLNK
Write [ASWK]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ASHWLNK"-[F:ASWK]CODREP-
&             func SUBASW_TOOL.BUILD_ASW6_IDENT2([F:ASWK]AFFLNK,[F:ASWK]ANCLNK,[F:ASWK]CODLNK)
 Return
Endif
Return

#---------------------------------------------------#
## Fields/Links parameters
#---------------------------------------------------#

$ASW8
FICHIER = "ASHWPAR" : ABR = "ASWP"
If OLDABR="ASWF"
  Read [ASWF]ASWF0 = NOMOBJ;IDENT
Elsif OLDABR="ASWK"
  Read [ASWK]ASWK0 = NOMOBJ;WAFFLNK;WANCLNK;WCODLNK
Else
  Gosub FIN_FIC From PATCH
  Return
Endif
If !fstat & OLDACT>="X" & !find(OLDACT,ACTIV(1..NBACT)) : # Specific
 Gosub FIN_FIC From PATCH
 Return
Elsif fstat
 Gosub FIN_FIC From PATCH
 Return
Endif
Raz [F:ASWP]
Repeat
 Gosub LIRE_ZONE From PATCH
 If ER : Break : Endif
 If DIME>0 & IND+1<=DIME
  Gosub AFF_ZONE From PATCH
  If GOK<1 : ER = 99 : Break : Endif
 Endif
Until TYPENR=6
If ER : Return : Endif
#Delete [ASWP2] Where CODREP=NOMOBJ & CODFLD=[F:ASWP]CODFLD & CODPAR=[F:ASWP]CODPAR & TYPPAR=[F:ASWP]TYPPAR & TYPKEY=[F:ASWP]TYPKEY
Write [ASWP]
If fstat
 GOK = 0 : ER = 99 : ERFIC = "ASHWPAR"-[F:ASWP]CODREP-
&         func SUBASW_TOOL.BUILD_ASW5_IDENT2([F:ASWP]TYPPAR,[F:ASWP]AFFLNK,[F:ASWP]TYPKEY,[F:ASWP]CODLNK,[F:ASWP]CODFLD,[F:ASWP]CODPAR)
 Return
Endif
Return

