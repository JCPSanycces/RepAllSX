#------------------------------------------------------
$FILL_FLD_PAR
#95271
Raz RES_COD,RES_CLA, RES_TIT
Raz RES_TYP, RES_MOD, RES_ORD, RES_NBR
Raz WWCODPAR,WWCODCLAPAR,WWCODCUR,WWFLDCLE, WWINTITPAR
Raz WWTYPINTPAR, WWADRVAL, WWTYPKEY, WWNUMPAR,WWTYPPAR,WWNOLIB,WWLNG,WWTYPAFF, WWNBRPARALL
If filinfo(filpath("FIL","AVIEWIND","fde",DOSSIER(D)),0)<0
 Local File =DOSSIER(D)+".ATABIND" [ATI]
Else
 Local File =DOSSIER(D)+".AVIEWIND" [ATI]
Endif
Local File =DOSSIER(D)+".ATYPE"      [ATY]

If [F:ASWF]CODTYP<>""
 Read [ATY]CODTYP = [F:ASWF]CODTYP
 If !fstat
  Call LOAD_TYPE_PARAM(DOSSIER(D),[F:ASWF]CODTYP,RES_COD,RES_TYP,RES_TIT,RES_MOD,RES_CLA,RES_ORD,RES_NBR) From AFNC
 Endif
 If [F:ASWF]LOBTAB<>""
  Read [ATI]NUMLIG = [F:ASWF]LOBTAB;1
  If !fstat
   Call CHARGE_CLE([F:ATI]CODFIC,[F:ATI]DESCRIPT,DOSSIER(D),[F:ATY]CODCLA,[F:ASWF]CODFLD,1,WWCODPAR,WWCODCUR,WWTYPPAR,
& WWFLDCLE,WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,
& WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,WWNBRPARALL) From SUBACLA
  Endif
 Elsif [F:ATY]CODCLA<>""
  Call CHARGE_CLA_ATI_CLE(DOSSIER(D),[F:ATY]CODCLA,[F:ASWF]CODFLD,1,WWCODPAR,WWCODCUR,WWTYPPAR,WWFLDCLE,WWINTITPAR,WWTYPINTPAR,WWADRVAL,WWTYPKEY,WWCODCLAPAR,WWNUMPAR,WWNOLIB,WWLNG,WWTYPAFF,
& WWNBRPARALL) From SUBACLA
 Endif
Endif
LogicClose File [ATI],[ATY]
Return

