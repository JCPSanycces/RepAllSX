#<AdxTL>@(#)9.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AHISTO","AHISTO",3,"") From GTRAITE
End

#----------------------------------------------#
$ACTION
Case ACTION
 When "OUVRE"   : Gosub OUVRE : # Nouveau par AHISTO
 When "FILTRE"  : Gosub FILTRE
 When "FERME"   : Gosub FERME
Endcase
Return

#----------------------------------------------#
# GTRAITE
#----------------------------------------------#

$EPURE_TMP
# Epuration des fichiers .DATA pour les imprimantes ZPL
REFDAT = date$-TEMPS
REP = "PAT"
EXT = "DATA"
ORDSYS = 'lsadx -a "'+nomap+'" -t '+REP+' '+EXT
Local File (TMP(30)) From System ORDSYS As [TMP_]
For [TMP_]
 FICTMP = filpath(REP,[F:TMP_]TMP,EXT)
 SECONDES  = filinfo(FICTRA,9)
 DATFIC = [01/01/1970]+int(SECONDES/(24*3600))
 TAILLE = filinfo(FICTMP,7)
 If TAILLE=0 | DATFIC<=REFDAT
  If TRACEDET
   Call ECR_TRACE([F:TMP_]TMP+"."+EXT-":"-filcom(REP,[F:TMP_]TMP,EXT),0) From GESECRAN
  Endif
  NBEPU += 1
  If !SIMUL
   Call EFFACE(FICTMP,STAT) From ORDSYS
  Endif
 Endif
Next TMP_
Return

#----------------------------------------------#
# AHISTO
#----------------------------------------------#

$OUVRE
Local Integer OK , I , STAT , SECONDES , NBEPU , TAILLE  
Local Char    REP(10) , EXT(10) , CRI(250)
Local Date    DATFIC , REFDAT
Local Char    ORDSYS(250) , FICTMP(GDIMFIC)
Return

$FERME
Gosub EPURE_TMP
NRDEL = NBEPU
NBRES = NBFIC
Return

$FILTRE
FILTSUP = '1=0' : # La table AREPORTA ne doit pas être épurée
Return

#----------------------------------------------#
Subprog AS_DATEPU(VALEUR)
Variable Date     VALEUR
If [M]NBMOIS<>0
 mkstat = 1
Else
 VALEUR = date$-1
Endif
End

