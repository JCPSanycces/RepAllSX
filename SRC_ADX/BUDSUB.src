#<AdxTL>@(#)12.0.0.0 $Revision$

############################################################################
Subprog C_BUD(VALEUR)
Variable Char     VALEUR()
Local Integer I
Call CONTROLE("BUP","",VALEUR,"",mkstat) From CONTOBJ
If mkstat : End : Endif
Call CONTEXE([F:BUP]ACS) From CPTSUB
If mkstat : End : Endif
If [F:BUP]PYMACC<>""
 Call LECTURE("GYM",[F:BUP]PYMACC,"") From CONTOBJ
 Call CONTEXE([F:GYM]ACS) From CPTSUB
 If mkstat : GMESSAGE = mess(33,103,1)-[F:BUP]PYMACC-":"-tolower(GMESSAGE) : End : Endif
Endif
Gosub INDDIE
For I=1 To INDDIE
 If [F:BUP]PYMCCE(I-1)<>""
  Call LECTURE("CYM",[F:BUP]PYMCCE(I-1),"") From CONTOBJ
  Call CONTEXE([F:CYM]ACS) From CPTSUB
  If mkstat : GMESSAGE = mess(34,103,1)-[F:BUP]PYMCCE(I-1)-":"-tolower(GMESSAGE) : Break : Endif
 Endif
Next
If mkstat : End : Endif
Call CONTDEV([F:BUP]CUR,datesyst) From TRTDEV
End

############################################################################
$INDDIE
INDDIE = [F:BUP]DIENBR
Return

