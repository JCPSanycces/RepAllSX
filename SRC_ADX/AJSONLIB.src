Local Decimal A,B
Local Char CHAINE(100)
A=int(val(timestamp$)/1000)*1000
CHAINE=func DATEWEB(A)
Errbox CHAINE
B=func DATEMILLI(CHAINE)
Errbox num$(B)-num$(A)
End

# Declaration of common variables
$DECL_GEN
# Local variables declaration
Local Char    MAGIC(80)
If type(MACHINE)<0 : Local Char MACHINE(GDIMFIC) : Endif
If type(APPLI)<0   : Local Char  APPLI(GDIMFIC) : Endif
Local Char    FICTRT(250), NOMTRT(100), COMMENT(200)
If type(DOSSIER)<0 : Local Char DOSSIER(20) : Endif
Local Char    SAVIFS(5) , SAVIRS(5)
Local Integer SAVIUM,NUMLOC
Local Integer I,J
Local Char Q(1) : Q="'"
Local Char DQ(1) : DQ='"'
Local Char QDQ(2): QDQ=Q+DQ
Local Char DQQ(2): DQQ=DQ+Q
Local Char QDQQ(3) : QDQQ=Q+DQQ
Local Char APWCB(30)
Local Integer NBP
Local Char PRO(20)(1..20)
Local Char SEP(20)(1..20)
Local Libelle TYP(1..20)
Local Char VLE(250)(1..250)
Local Char PRF(20), POF(20)
Return

# File header generation
# NOMTRT is supposed to be defined, as well as DOSSIER, and COMMENT, and MACHINE
$DEB_GEN

  Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
  FICTRT = filpath("TRT",NOMTRT,"src",APPLI,"",MACHINE)

  SAVIFS = adxifs
  SAVIRS = adxirs
  SAVIUM = adxium

  adxifs = ""
  adxirs = chr$(10)
  adxium = GUTF8
  MAGIC  = mess(77,133,1) : # Superviseur Adonix

# Program header generation
  APWCB=" Append WCLOB,'"
  Openo FICTRT , 0 Using [SSS_]
  Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$" Using [SSS_]
  Wrseq "#"-MAGIC Using [SSS_]
  Wrseq "#"-COMMENT Using [SSS_]
  Wrseq Using [SSS_]

$HEAD_GEN
  Wrseq "#" Using [SSS_]
  Wrseq "# Miscellaneous subprograms" Using [SSS_]
  Wrseq "#" Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "# Get translatable texts and transcode backshlashes and double quotes" Using [SSS_]
  Wrseq "# Code embedded in the program in order to gain in performance (maybe not useful)" Using [SSS_]
  Wrseq  Using [SSS_]
  Wrseq "# Gets the message from APLSTD" Using [SSS_]
  Wrseq "Funprog M(LANGUE,NUMCHAP,NUMES)" Using [SSS_]
  Wrseq "Value Char LANGUE()" Using [SSS_]
  Wrseq "Value Integer NUMCHAP,NUMES" Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "  Local File APLSTD" Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "  Read [AST]LAN=LANGUE;NUMCHAP;NUMES" Using [SSS_]
  Wrseq '  If fstat : End "" : Endif' Using [SSS_]
  Wrseq "  End escjson([AST]LANMES)" Using [SSS_]
  Wrseq  Using [SSS_]
  Wrseq "# Gets the message from ATEXTE" Using [SSS_]
  Wrseq "Funprog A(LANGUE,NUMERO)" Using [SSS_]
  Wrseq "Value Char LANGUE()" Using [SSS_]
  Wrseq "Value Integer NUMERO" Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "  Local File ATEXTE" Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "  Read [ATX]NUMERO=LANGUE;NUMERO" Using [SSS_]
  Wrseq '  If fstat : End "" : Endif' Using [SSS_]
  Wrseq "  End escjson([ATX]TEXTE)" Using [SSS_]
  Wrseq Using [SSS_]
#{SAM 118150
#  Wrseq "# Gets the message from ATEXTRA" Using [SSS_]
#  Wrseq "Funprog T(LANGUE,TABLE,CLE,CHAMP,INDEX)" Using [SSS_]
#  Wrseq "Value Char LANGUE(),TABLE(),CHAMP(),CLE()" Using [SSS_]
#  Wrseq "Value Integer INDEX" Using [SSS_]
#  Wrseq "Local Integer I,J,IM" Using [SSS_]
#  Wrseq "Local Char TEXTE(200)" Using [SSS_]
#  Wrseq Using [SSS_]
#  Wrseq "  Local File ATEXTRA" Using [SSS_]
#  Wrseq Using [SSS_]
#  Wrseq "  Read [AXX]AXX0=TABLE;CHAMP;LANGUE;CLE;string$(INDEX<>0,num$(INDEX))" Using [SSS_]
#  Wrseq '  If fstat : End "" : Endif' Using [SSS_]
#  Wrseq "  End escjson([AXX]TEXTE)" Using [SSS_]
#  Wrseq Using [SSS_]
#SAM 118150}
  Wrseq "# Gets the title of an entity in the dictionary" Using [SSS_]
  Wrseq "Funprog E(LANGUE,TABLE)" Using [SSS_]
  Wrseq "Value Char LANGUE(),TABLE()" Using [SSS_]
  Wrseq "" Using [SSS_]
  Wrseq "  Local File ATABIND" Using [SSS_]
  Wrseq "  Local File ATABZON" Using [SSS_]
  Wrseq "  Local File ATABLE" Using [SSS_]
  Wrseq "  Read [ATB]CODFIC=TABLE" Using [SSS_]
  Wrseq "  If fstat : End '' : Endif" Using [SSS_]
  Wrseq "  Read [ATI]NUMLIG(2)=TABLE;1" Using [SSS_]
  Wrseq "  If fstat : End '' : Endif" Using [SSS_]
  Wrseq "  Read [ATZ]CODZONE=TABLE;vireblc(ctrans([ATI]DESCRIPT,'+-','  '),3)" Using [SSS_]
  Wrseq "  If fstat : End '' : Endif" Using [SSS_]
  Wrseq "  End func A(LANGUE,[ATZ]NOCOURT)" Using [SSS_]
  Wrseq "" Using [SSS_]
Return

# JSON prototype subprogram header
$JPRO_HEAD_GEN
  Wrseq "#" Using [SSS_]
  Wrseq "# Sends the JSON prototype" Using [SSS_]
  Wrseq "#" Using [SSS_]
  Wrseq "Subprog PROTO_JSON(ACTX,PSYR,WCLOB,TIME_UPD,LEVEL_NUM,TYPE_REPRES)" Using [SSS_]
  Wrseq "Variable INSTANCE  ACTX Using "+[V]CST_C_NAME_CLASS_CONTEXT Using [SSS_]
  Wrseq "Variable INSTANCE  PSYR     Using C_ASYR" Using [SSS_]
  Wrseq "Variable Clbfile   WCLOB" Using [SSS_]
  Wrseq "Variable Decimal   TIME_UPD" Using [SSS_]
  Wrseq "Value    Char      LEVEL_NUM()" Using [SSS_]
  Wrseq "Value    Char      TYPE_REPRES()" Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "# Open ATEXTRA and APLSTD" Using [SSS_]
  Wrseq "  Local File ATEXTRA [ATX]" Using [SSS_]
  Wrseq "  Local File APLSTD [AST]" Using [SSS_]
  Wrseq Using [SSS_]
  Wrseq "# The timestamp value corresponds to the generation time" Using [SSS_]
  Wrseq "  TIME_UPD="+num$(val(timestamp$)) Using [SSS_]
Return

# Generation of properties in a list
# NBP is the number of properties
# PRO() are the property name
# TYP() are the type (1=true/false, 2=numeric, 3=alpha (also 0 as default value), 4=formula, 5=structure or array, structure by defaut)
# VLE() are the value
# SEP() are the intermediate separators
# PRF is the prefix (usually '[' or '{')
# POF is the postfix (usually ',' or '}' or ']'
# Sets the variables to empty / null values once the line is written
$PRO_GEN
  Local Integer PL_QUO : # Fix if a single quote is in the text
  If NBP>=0
    Wrseq APWCB+PRF; Using [SSS_]
    If NBP
      For IGEN=1 To NBP
        Wrseq '"'+PRO(IGEN)+'":'; Using [SSS_]
        SEP(IGEN)+=string$(SEP(IGEN)="" & TYP(IGEN)<>5,",")
        Case TYP(IGEN)
          When 1 : Wrseq string$(VLE(IGEN)<>"1",'false')+string$(VLE(IGEN)="1",'true')+string$(IGEN=NBP,POF+Q)+string$(IGEN<>NBP,SEP(IGEN)); Using [SSS_]
          When 2 : Wrseq VLE(IGEN)+string$(IGEN=NBP,POF+Q)+string$(IGEN<>NBP,SEP(IGEN)); Using [SSS_]
          When 0,3 : PL_QUO=instr(1,VLE(IGEN),"'")
                     While PL_QUO
                       VLE(IGEN)=left$(VLE(IGEN),PL_QUO-1)+"'"+'+chr$(39)+'+"'"+right$(VLE(IGEN),PL_QUO+1)
                       PL_QUO=instr(PL_QUO+12,VLE(IGEN),"'")
                     Wend
                     Wrseq DQ+VLE(IGEN)+DQ+string$(IGEN=NBP,POF+Q)+string$(IGEN<>NBP,SEP(IGEN)); Using [SSS_]
          When 4 : Wrseq DQQ+"+"+VLE(IGEN)+"+"+QDQ+string$(IGEN=NBP,POF+Q)+string$(IGEN<>NBP,SEP(IGEN)); Using [SSS_]
          When 5 : Wrseq string$(VLE(IGEN)="","{")+VLE(IGEN)+string$(IGEN=NBP,POF+Q)+string$(IGEN<>NBP,SEP(IGEN)); Using [SSS_]
        Endcase
      Next IGEN
      Wrseq Using [SSS_]
    Else
      Wrseq POF+Q Using [SSS_]
    Endif
  Endif
  Raz PRO,VLE,POF,NBP,PRF,SEP,TYP
Return

# Generation of a local menu description (NUMLOC is the local menu) : # Does stops after closing square bracket
$MEN_GEN
  NBP+=1 : PRO(NBP)="$value" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$type" : VLE(NBP)="application/x-integer"
# NBP+=1 : PRO(NBP)="$constraints" : TYP(NBP)=5
  NBP+=1 : PRO(NBP)="$enum" : TYP(NBP)=5 : VLE(NBP)='['
  Gosub PRO_GEN
  Wrseq "  IML=0" Using [SSS_]
  Wrseq "  For [AST]LAN Where LAN=L and LANCHP="+num$(NUMLOC)+" and LANNUM>0" Using [SSS_]
  Wrseq "    If IML>0 : "+APWCB+",' : Endif" Using [SSS_]
  Wrseq "    IML+=1" Using [SSS_]
  Wrseq "  "+APWCB+'{"$value":'+Q+"+num$(IML)+','" Using [SSS_]
  Wrseq "  "+APWCB+'"$title":"'+Q+"+[AST]LANMES+"+QDQ+"}"+Q Using [SSS_]
  Wrseq "  Next" Using [SSS_]
# POF=']}}' : Gosub PRO_GEN
  POF=']}' : Gosub PRO_GEN
Return



# Returns the HTML data type associated to the internal type (local menu #30)
Funprog TYPZON(TYP,MENL)
Value Libelle TYP
Value Shortint MENL
 Case TYP
    When 1       : End string$(MENL=1,"application/x-boolean")+string$(MENL<>1,"application/x-choice")
    When 2,3     : End "application/x-integer"
    When 4,5,6   : End "application/x-decimal"
    When 7       : End "application/x-string"
    When 8       : End "application/x-date"
    When 10      : End "text/plain"
    When 11      : End "application/x-uuid" : # Modification done in october 2014 (management of unique id)
    When 12      : End "application/x-datetime"
 Endcase
End "application/octet-stream"

# Returns the HTML data type associated to the internal type
Funprog ATYPEZON(TYP,MENL)
Value Char TYP
Value Shortint MENL
 If !clalev([ATY]) : Local File ATYPE : Endif
 Read [ATY]CODTYP=TYP
 If fstat<>0 : End "" : Endif
End func TYPZON([ATY]TYPTYP,MENL)

#
# Miscellaneous subprograms
#

# Get translatable texts and transcode backshlashes and double quotes
# Code also embedded in generated program in order to gain in performance (maybe not useful)
Funprog M(LANGUE,NUMCHAP,NUMES)
Value Char LANGUE()
Value Integer NUMCHAP,NUMES

  If !clalev([AST]) : Local File APLSTD : Endif

  Read [AST]LAN=LANGUE;NUMCHAP;NUMES
  If fstat : End "" : Endif
  End escJson([AST]LANMES)

Funprog A(LANGUE,NUMERO)
Value Char LANGUE()
Value Integer NUMERO

  If !clalev([ATX]) : Local File ATEXTE: Endif

  Read [ATX]NUMERO=LANGUE;NUMERO
  If fstat : End "" : Endif
  End escJson([ATX]TEXTE)

Funprog Q(TEXTE)
Value Char TEXTE()
Local Integer I,J,IM
End escJson(TEXTE)

Funprog T(LANGUE,TABLE,CLE,CHAMP,INDEX)
Value Char LANGUE(),TABLE(),CHAMP(),CLE()
Value Integer INDEX
Local Integer I,J,IM
Local Char TEXTE(200)

  If !clalev([AXX]) : Local File ATEXTRA : Endif

  Read [AXX]AXX0=TABLE;CHAMP;LANGUE;CLE;string$(INDEX<>0,num$(INDEX))
  If fstat : End "" : Endif
  End escJson([AXX]TEXTE)

#
# This function returns the date time in "web format" from a value got by a val(timestamp)
# Some consistency controls are missing, and the date is suppoed to be in GMT format
#
Funprog DATEWEB(MILLISECONDS)
Value Decimal MILLISECONDS
Local Decimal SECONDS
Local Date    THEDAY
  SECONDS=mod((MILLISECONDS/1000),24*3600)
  THEDAY=[1/1/1970]+int(MILLISECONDS/(1000*24*3600))
  End mid$("MonTueWedThuFriSatSun",dayn(THEDAY)*3-2,3)+","-format$("K:3XAaa5X",format$("D:DD[ ]MMM[ ]YYYY",THEDAY))
&  -format$("N0:2",int(SECONDS/3600))+":"+format$("N0:2",mod(int(SECONDS/60),60))+":"
&  +format$("N0:2",mod(SECONDS,60))+"GMT"

#
# This function returns the number of milliseconds since January 1, 1970 from a time in "web format"
#
Funprog DATEMILLI(DATEWEB)
Value Char DATEWEB
Local Char CHAINE(100)
Local Integer I,J,K

  I=instr(1,DATEWEB,",")
  If I
    DATEWEB=vireblc(right$(DATEWEB,I+1),2)
  Endif
  CHAINE=vireblc(DATEWEB,3)
  J=val(CHAINE)
  If J>=1 and J<=31
    CHAINE=vireblc(right$(DATEWEB,len(CHAINE)+1),2)
    I=find(toupper(left$(toupper(CHAINE),3)),"JAN","FEB","MAR","APR","MAY","JUN","JUL","AUG","SEP","OCT","NOV","DEC")
    If I
      CHAINE=vireblc(right$(CHAINE,4),2)
      K=val(vireblc(CHAINE,3))
      If K>1900
        CHAINE=vireblc(right$(CHAINE,len(vireblc(CHAINE,3))+1),2)
        If pat(left$(CHAINE,8),"##:##:##")
          I=gdat$(J,I,K)-[1/1/1970]
          End ((I*24+val(mid$(CHAINE,1,2)))*3600+val(mid$(CHAINE,4,2))*60+val(mid$(CHAINE,7,2)))*1000
        Endif
      Endif
    Endif
  Endif
End 0

# Returns true if the process is still running
Funprog PROCESS_RUNNING(PROCESS_ID)
Value Integer PROCESS_ID

  If func ASESSIONS.ISMNGSESSIONS
    End func ASESSIONS.PROCESS_RUNNING(PROCESS_ID)
  Endif

  Local Integer OK
  OK=[V]CST_AFALSE

  Local File (SID,SCLI,SDOS,SUSR,STYP) From System adxmac(0)+"@psadx -t " As [SYS_]

  For [SYS_]
    If [F:SYS_]SID=num$(PROCESS_ID)
      OK=[V]CST_ATRUE : Break
    Endif
  Next SYS_

  Close Local File [SYS_]
End OK

# Gets the value of a string property in a JSON
# Does not check if the JSON structure is ok
Funprog GET_PROP(JSONSTRING,VARNAME)
Value Clbfile JSONSTRING
Value Char VARNAME
Local Integer I,J
  I=instr(1,JSONSTRING,'"'+VARNAME+'"')
  If I
    I=instr(I+len(VARNAME)+2,JSONSTRING,":")
    If I
      I=instr(I+1,JSONSTRING,'"')
      If I
        J=instr(I+1,JSONSTRING,'"')
        If J
          End seg$(JSONSTRING,I+1,J-1)
        Endif
      Endif
    Endif
  Endif
End ""

