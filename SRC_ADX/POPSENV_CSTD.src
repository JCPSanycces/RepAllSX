#**----------------------------------------------------------------<br/>
#* CONVERT_RUNTIME_TO_ENDTIME : Convert operation run time into end time (HH:MM:SS).
#**<br/>----------------------------------------------------------------<br/>
#* @param RUNTIME - Decimal = Operation run time (in hours including part hours)
#* @return NEWTIME - Char - Time operation ends (HH:MM:SS)
#**<br/>----------------------------------------------------------------
#*!
Funprog CONVERT_RUNTIME_TO_ENDTIME (RUNTIME)
    Value Double RUNTIME
    Local Char NEWTIME(10)
    Local Char STRINGDT(20)
    Local Double NEWSECS
    Local Integer HOURS
    Local Integer MINUTES
    Local Integer SECONDS
    Local Integer DAYS

    HOURS = 0

    If (RUNTIME < 0)
        # This is invalid do something.
        HOURS = 0
    Elsif (RUNTIME > 24)
        # Runtime is more than a day.
        RUNTIME = mod(RUNTIME, 24)
    Endif

    If HOURS > 0
        NEWSECS = RUNTIME * 3600
        HOURS = NEWSECS / 3600
        NEWSECS -= HOURS * 3600
        MINUTES = NEWSECS / 60
        NEWSECS -= MINUTES * 60
        SECONDS = NEWSECS
    Endif

    NEWTIME = format$("N0:2", HOURS)+":"+format$("N0:2", MINUTES)+":"+format$("N0:2", SECONDS)
End NEWTIME

#**----------------------------------------------------------------<br/>
#* CONVERT_DATETIME_TO_MINS : Convert datetime type into minutes.
#**<br/>----------------------------------------------------------------<br/>
#* @param DATETIMETOCONV - DateTime = Datetime to convert
#* @return MINUTES - Decimal - Number of minutes
#**<br/>----------------------------------------------------------------
#*!
Funprog CONVERT_DATETIME_TO_MINS (DATETIMETOCONV)
    Value Datetime DATETIMETOCONV
    Local Decimal MINUTES
    Local Char STRINGDT(20)
    Local Double NEWSECS
    Local Double HHSECS
    Local Double MMSECS
    Local Double SECS

    STRINGDT = num$(DATETIMETOCONV)
    HHSECS = 3600 * (val(mid$(STRINGDT, 12, 2)))
    MMSECS = 60 * (val(mid$(STRINGDT, 15, 2)))
    SECS = (val(mid$(STRINGDT, 18, 2)))

    NUMSECS = HHSECS + MMSECS + SECS

    MINUTES = NUMSECS / 60

End MINUTES

#**----------------------------------------------------------------<br/>
#* CONVERT_STR_END_TO_RUNTIME : Convert the start and end time of an operation sent from
#* Planner One, into a operation runtime based on the workstation used.
#**<br/>----------------------------------------------------------------<br/>
#* @param TIMUOMCOD - Integer = Time unit 1 = hours otherwise minutes
#* @param STRDAT - Date = Operation start date
#* @param STRTIM - Decimal = Operation start time
#* @param ENDDAT - Date = Operation end date
#* @param ENDTIM - Decimal = Operation end time
#* @return RUNTIME - Decimal - Calculated run time based on start and end time
#**<br/>----------------------------------------------------------------
#*!
Funprog CONVERT_STR_END_TO_RUNTIME(TIMUOMCOD, STRDAT, STRTIM, ENDDAT, ENDTIM)
    Value Integer TIMUOMCOD
    Variable Date STRDAT
    Variable Decimal STRTIM
    Variable Date ENDDAT
    Variable Decimal ENDTIM

    Local Decimal RUNTIME
    Local Decimal DIFF
    Local Integer DAYDIFF

    RUNTIME = 0
    # Check if the operation starts and end on the same day.
    # The time calculation will be different.
    DAYDIFF = ENDDAT - STRDAT
    If DAYDIFF = 0
        DIFF = ENDTIM - STRTIM
    Else
        DIFF = (DAYDIFF * 24 * 60) - (STRTIM - ENDTIM)
    Endif

    # Convert time to minutes or hours based on code.
    If TIMUOMCOD = 1
        # This is hours
        RUNTIME = DIFF / 60
    Else
        # This is minutes
        RUNTIME = DIFF
    Endif

End RUNTIME

#**----------------------------------------------------------------<br/>
#* GET_WORKORDER_URL : Generate the URL required to view the work order
#**<br/>----------------------------------------------------------------<br/>
#* @param MFGNUM - Char = Work order
#* @return URL - Char - last part of URL needed to display work order function
#**<br/>----------------------------------------------------------------
#*!
Funprog GET_WORKORDER_URL (MFGNUM)
    Value Char MFGNUM()
    Local Char TABKEY(50)(1..10),TABKEYVAL(50)(1..10),TABPAR(50)(1..10),TABPARVAL(250)(1..10)
    Local Char URL(60)
    Local Clbfile WURL
    Local Integer PSASTATUS

    [L]TABKEY(1) = "MFGNUM"
    [L]TABKEYVAL(1) = MFGNUM
    [L]PSASTATUS = func ASYRFNC.AGET_CLASSICURL(GACTX, [V]CST_ATRUE, "GESMFG", [V]CST_AMODIFFCT, TABKEY, TABKEYVAL, TABPAR, TABPARVAL, WURL)

    [L]URL = right$(WURL, instr(1,WURL,"$"))
End [L]URL

#**----------------------------------------------------------------<br/>
#* GET_RESOURCE_URL : Generate the URL required to view the work center
#**<br/>----------------------------------------------------------------<br/>
#* @param WST - Char = Work center
#* @param FCY - Char = Site
#* @return URL - Char - last part of URL needed to display work center function
#**<br/>----------------------------------------------------------------
#*!
Funprog GET_RESOURCE_URL (WST, FCY)
    Value Char WST()
    Value Char FCY()
    Local Char TABKEY(50)(1..10),TABKEYVAL(50)(1..10),TABPAR(50)(1..10),TABPARVAL(250)(1..10)
    Local Char URL(60)
    Local Clbfile WURL
    Local Integer PSASTATUS

    [L]TABKEY(1) = "WST"
    [L]TABKEYVAL(1) = WST
    [L]TABKEY(2) = "WCRFCY"
    [L]TABKEYVAL(2) = FCY
    [L]PSASTATUS = func ASYRFNC.AGET_CLASSICURL(GACTX, [V]CST_ATRUE, "GESMWS", [V]CST_AMODIFFCT, TABKEY, TABKEYVAL, TABPAR, TABPARVAL, WURL)

    [L]URL = right$(WURL, instr(1,WURL,"$"))
End [L]URL

#**----------------------------------------------------------------<br/>
#* UPDATEWOWITHNEWDATES : Update WO with earliest start date and latest enddate.
#**<br/>----------------------------------------------------------------<br/>
#* @param WRKORD - C_POPSWRKORD = Work order class
#* @param STRDAT - Date = Start date of the work order / suggestion
#* @param ENDDAT - Date = End date of the work order / suggestion
#* @param MESSAGE - Char = Error message if update fails
#* @param USER - Char = User who is doing update
#* @return ASTATUS value based on fstat value if fstat <> 0 = CST_AERROR
#**<br/>----------------------------------------------------------------
#*!
Funprog UPDATEWOWITHNEWDATES(WRKORD, STRDAT, ENDDAT, MESSAGE, USER)
    Variable Instance WRKORD Using C_POPSWRKORD
    Variable Date STRDAT
    Variable Date ENDDAT
    Variable Char MESSAGE()
    Variable Char USER()

    Local Integer PSASTATUS
    Local Integer IFTRANSOPEN
    #Local Char MESSAGE(100)
    Local Integer STAT
    Local Char MFGNUM(GLONVCR)
    Local Char ITMREF(GLONITM)

    [L]IFTRANSOPEN = adxlog

    If [L]IFTRANSOPEN = 0
        Trbegin MFGHEAD
    Endif

    # X3-22333 - STWIL - Now need to split the work order number from itmref
    [L]PSASTATUS = func POPSENVUPD_CSTD.SPLIT_WO_KEY(WRKORD.MFGNUM, [L]MFGNUM, [L]ITMREF)

    # Update MFGHEAD
    Read [MFG]MFG0 = [L]MFGNUM
    If fstat = [V]CST_AOK & ([F:MFG]EARSTRDAT <> STRDAT | [F:MFG]LATENDDAT <> ENDDAT)
        Readlock [MFG]MFG0 = [L]MFGNUM
        If fstat = [V]CST_AOK
            [F:MFG]UPDDATTIM = datetime$
            [F:MFG]UPDUSR = USER
            [F:MFG]EARSTRDAT = STRDAT
            [F:MFG]LATENDDAT = ENDDAT
            Rewrite [F:MFG]

            If [L]IFTRANSOPEN = 0
                Commit
            Endif

            Unlock [MFG]
        Endif
    Endif

    STAT = fstat
    # Use the new function to set ASTATUS and output a message if necessary.
    [L]PSASTATUS = func POPSENV_CSTD.MANAGE_FSTAT(STAT, MESSAGE)

End [L]PSASTATUS

#**----------------------------------------------------------------<br/>
#* MANAGE_FSTAT : Convert the fstat value into a ASTATUS value and message.
#**<br/>----------------------------------------------------------------<br/>
#* @param FSTATVAL - Integer = fstat value returned from file operation
#* @param MESSAGE - Char = Error message determined by fstat value
#* @return ASTATUS value based on fstat value if fstat <> 0 = CST_AERROR
#**<br/>----------------------------------------------------------------
#*!
Funprog MANAGE_FSTAT(FSTATVAL, MESSAGE)
    Variable Integer FSTATVAL
    Variable Char MESSAGE()

    Local Integer PSASTATUS

    Case FSTATVAL
        When [V]CST_AOK
            MESSAGE = "No error"
        When [V]CST_ALOCK
            MESSAGE = mess(364,193,1)
        When [V]CST_AOUTSEARCH
            MESSAGE = mess(365,193,1)
        When [V]CST_ADUPKEY
            MESSAGE = mess(366,193,1)
        When [V]CST_AOUTKEYS
            MESSAGE = mess(367,193,1)
        When [V]CST_ANOREC
            MESSAGE = mess(368,193,1)
        When [V]CST_ARECTICKUPD
            MESSAGE = mess(369,193,1)
        When [V]CST_ARECTICKDEL
            MESSAGE = mess(370,193,1)
        When Default
            MESSAGE = "Default error="+num$(FSTATVAL)
    Endcase

    If (FSTATVAL = [V]CST_AOK)
        [L]PSASTATUS = [V]CST_AOK
    Else
        [L]PSASTATUS = [V]CST_AERROR
    Endif

End [L]PSASTATUS

