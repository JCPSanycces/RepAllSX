$EARLIESTSTARTDATE
    # Issue X3-85700 - YARAM: To avoid unnecessary constraints in ps, we're setting the earliest startdate as today
    # unless the wo is already in progress when we use the start date.
    If([F:MFG]MFGTRKFLG > 3 )
      [L]STRDAT = [F:MFG]STRDAT
    Else
      [L]STRDAT = date$
    Endif
    [L]ROUSTRDAT = [L]STRDAT
    [L]BOMSTRDAT = [L]STRDAT

    Read [ROH]ROH0 = [F:MFI]ITMREF;[F:MFG]ROUALT;this.FCY
    If (fstat = [V]CST_AOK)
        If ([F:ROH]ROUSTRDAT > [L]ROUSTRDAT)
            [L]ROUSTRDAT = [F:ROH]ROUSTRDAT
        Endif
        If ([F:MFG]ROUECCMAJ <> "")
            Read [RVV]RVV1 = [F:ROH]ITMREF;this.FCY;[F:MFG]ROUECCMAJ;[F:MFG]ROUECCMIN
            If (fstat = [V]CST_AOK)
                If ([F:RVV]STRDAT > [L]ROUSTRDAT)
                    [L]ROUSTRDAT = [F:RVV]STRDAT
                Endif
            Endif
        Endif
    Endif

    Read [BOH]BOH0 = [F:MFI]ITMREF;[F:MFI]BOMALT;2
    If (fstat = [V]CST_AOK)
        If ([F:BOH]BOHSTRDAT > [L]BOMSTRDAT)
            # Issue X3-64061 - YARAM: typo, [F:BOH] was written as [F:BOM] which caused class non-existent exception
            [L]BOMSTRDAT = [F:BOH]BOHSTRDAT
        Endif
        If ([F:MFI]ECCVALMAJ <> "")
            Read [EVL]EVL1 = [F:MFI]ITMREF;[F:MFI]ECCVALMAJ;[F:MFI]ECCVALMIN;2
            If (fstat = [V]CST_AOK)
                If ([F:EVL]STRDAT > [L]BOMSTRDAT)
                    [L]BOMSTRDAT = [F:EVL]STRDAT
                Endif
            Endif
        Endif
    Endif

    If ([L]BOMSTRDAT > [L]ROUSTRDAT)
        [L]STRDAT = [L]BOMSTRDAT
    Else
        [L]STRDAT = [L]ROUSTRDAT
    Endif

    # We now convert this to UTC outside of this sub routine.
    #this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).STRDAT = STRDAT

Return

$LATESTENDDATE
    [L]ENDDAT = [F:MFG]ENDDAT
    [L]ROUENDDAT = [L]ENDDAT
    [L]BOMENDDAT = [L]ENDDAT

    Read [ROH]ROH0 = [F:MFI]ITMREF;[F:MFG]ROUALT;this.FCY
    If (fstat = [V]CST_AOK)
        If ([F:ROH]ROUENDDAT <> AVOID.ADATE & [F:ROH]ROUENDDAT < [L]ROUENDDAT)
            [L]ROUENDDAT = [F:ROH]ROUENDDAT
        Endif
        If ([F:MFG]ROUECCMAJ <> "")
            Read [RVV]RVV1 = [F:ROH]ITMREF;this.FCY;[F:MFG]ROUECCMAJ;[F:MFG]ROUECCMIN
            If (fstat = [V]CST_AOK)
                If ([F:RVV]ENDDAT <> AVOID.ADATE & [F:RVV]ENDDAT < [L]ROUENDDAT)
                    [L]ROUENDDAT = [F:RVV]ENDDAT
                Endif
            Endif
        Endif
    Endif

    Read [BOH]BOH0 = [F:MFI]ITMREF;[F:MFI]BOMALT;2
    If (fstat = [V]CST_AOK)
        If ([F:BOH]BOHENDDAT <> AVOID.ADATE & [F:BOH]BOHENDDAT < [L]BOMENDDAT)
            [L]BOMENDDAT = [F:BOH]BOHENDDAT
        Endif
        If ([F:MFI]ECCVALMAJ <> "")
            Read [EVL]EVL1 = [F:MFI]ITMREF;[F:MFI]ECCVALMAJ;[F:MFI]ECCVALMIN;2
            If (fstat = [V]CST_AOK)
                If ([F:EVL]ENDDAT <> AVOID.ADATE & [F:EVL]ENDDAT < [L]BOMENDDAT)
                    [L]BOMENDDAT = [F:EVL]ENDDAT
                Endif
            Endif
        Endif
    Endif

    If ([L]BOMENDDAT < [L]ROUENDDAT)
        [L]ENDDAT = [L]BOMENDDAT
    Else
        [L]ENDDAT = [L]ROUENDDAT
    Endif

    # This is now set by initial objective date
    #this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).ENDDAT = ENDDAT

Return

$UPDATE_ROUTE_INFO
    Local Instance CURRUSRES Using C_POPSUSRES
    CURRUSRES = NewInstance C_POPSUSRES AllocGroup null
    Local Integer RPLNUM

#    Link [ROO] With
#&        [ROH]ROH0=[ROO]ITMREF;[F:ROO]ROUALT;[ROO]FCY
#&        As [ROO_]
#&        Where [F:ROO]FCY = this.FCY & [F:ROO]ITMREF = [L]ITMREF & [F:ROO]OPENUM = [L]OPENUM & [F:ROO]ROUALT = [L]ROUALT

#    For [F:ROO_]
        [L]ILINE_US = fmet this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).ADDLINE("USRES", [V]CST_ALASTPOS)
        If [L]ILINE_US <> [V]CST_ANOTDEFINED
            # Currently all usable resources are work centres, so type is always 1.
            this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).RESTYP = 1
            this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).WST = [L]EXTWST
            If [F:ROO]WST <> ""
                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).WSTFCY = this.FCY
            Endif
            this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).OPETIM = func POPSENV_CSTD.CONVERT_TIME_TO_SECS([L]OPETIM, [L]TIMUOMCOD)
            # X3-47988 - STWIL - if the main resource is subcontract type then we have no additional times
            If [L]SCOCOD = 2 & [L]SCOLTI > 0
                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).PRPTIM = 0
                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).WAITIM = 0
                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).SETTIM = 0
            Else
                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).SETTIM = func POPSENV_CSTD.CONVERT_TIME_TO_SECS([L]SETTIM, [L]TIMUOMCOD)
                # Preparation time is always in hours.
                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).PRPTIM = func POPSENV_CSTD.CONVERT_TIME_TO_SECS([L]PRPTIM, 1)
                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).WAITIM = [L]WAITIM + [L]PSPTIM
            Endif
            this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).WSTNBR = [L]WSTNBR
            this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).PRIORITY = 5
            # Add operation tools to the usable resource
            For [ROO]ROO0 Where [F:ROO]FCY = this.FCY & [F:ROO]ITMREF = [L]ITMREF & [F:ROO]OPENUM = [L]OPENUM & [F:ROO]ROUALT = [L]ROUALT
                If ([F:ROO]EQUNUM <> "")
                    [L]ILINE_TL = fmet this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).ADDLINE("TOOLS", [V]CST_ALASTPOS)
                    If [L]ILINE_TL <> [V]CST_ANOTDEFINED
                        this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).TOOLS([L]ILINE_TL).EQUNUM = [F:ROO]EQUNUM
                        this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).TOOLS([L]ILINE_TL).ITMDES1 = [F:ITM]ITMDES1
                    Endif
                Endif
            Next

            # Take a copy of the current useable resource
            [L]OK = func COPYUSRESCLASS([L]CURRUSRES, this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US))

            # X3-47988 - STWIL - If we have a sub-contract by exception add it in, as it may not be a replacement
            If [L]SCOCOD = 3
                [L]ILINE_US = fmet this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).ADDLINE("USRES", [V]CST_ALASTPOS)
                If [L]ILINE_US <> [V]CST_ANOTDEFINED
                    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Add usres" - [L]EXTWST - [MFO]SCOWST)
                    [L]OK = func COPYUSRESCLASS(this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US), [L]CURRUSRES)
                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).WST = [L]SCOWST
                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).PRIORITY = 7
                    [L]OK = func GETRESOURCEINFO([F:RPW]RPLWST([L]RPLNUM), this.FCY, [L]EFFIC, this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).WSTNBR)
                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).OPETIM = func POPSENV_CSTD.CONVERT_TIME_TO_SECS([L]EXCOPETIM, [L]TIMUOMCOD)
                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).PRPTIM = 0
                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).WAITIM = 0
                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).SETTIM = 0
                Endif
            Endif

            # Check if there are any replacement work centres
            For [RPW] Where WST = [L]EXTWST & WCRFCY = this.FCY
                For [L]RPLNUM = 0 To 24
                    #[L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Additional usres" - [F:ROO]WST - [F:RPW]RPLWST([L]RPLNUM))
                    If vireblc([F:RPW]RPLWST([L]RPLNUM), 1) <> "" & [F:RPW]RPLWST([L]RPLNUM) <> [L]EXTWST
                        If [L]SCOCOD <> 3 | [F:RPW]RPLWST([L]RPLNUM) <> [L]SCOWST
                            [L]ILINE_US = fmet this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).ADDLINE("USRES", [V]CST_ALASTPOS)
                            If [L]ILINE_US <> [V]CST_ANOTDEFINED
                                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Add usres" - [L]EXTWST - [F:RPW]RPLWST([L]RPLNUM))
                                [L]OK = func COPYUSRESCLASS(this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US), [L]CURRUSRES)
                                #this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US) = [L]CURRUSRES
                                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).WST = [F:RPW]RPLWST([L]RPLNUM)
                                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).PRIORITY = [F:RPW]PIO([L]RPLNUM) * 5 + 5
                                [L]OK = func GETRESOURCEINFO([F:RPW]RPLWST([L]RPLNUM), this.FCY, [L]EFFIC, this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).WSTNBR)
                                If [L]EFFIC <> 100
                                    [L]OPETIM = [L]STDOPETIM * (100 / [L]EFFIC)
                                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).OPETIM = func POPSENV_CSTD.CONVERT_TIME_TO_SECS([L]OPETIM, [L]TIMUOMCOD)
                                Else
                                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).OPETIM = func POPSENV_CSTD.CONVERT_TIME_TO_SECS([L]STDOPETIM, [L]TIMUOMCOD)
                                Endif
                                # X3-47988 - STWIL - If we have a subcontract resource, always have a minimum of 1 day runtime.
                                If [F:RPW]WSTTYP([L]RPLNUM) = 3
                                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).OPETIM = max (86400, this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES(
& [L]ILINE_US).OPETIM)
                                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).PRPTIM = 0
                                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).SETTIM = 0
                                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).WAITIM = 0
                                # X3-47988 - STWIL - The main resource is a subcontract type but this replacement is not, therefore we need to reset the operation times
                                Elsif [L]SCOCOD = 2
                                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).SETTIM = func POPSENV_CSTD.CONVERT_TIME_TO_SECS([L]SETTIM, [L]TIMUOMCOD)
                                    # Preparation time is always in hours.
                                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).PRPTIM = func POPSENV_CSTD.CONVERT_TIME_TO_SECS([L]PRPTIM, 1)
                                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).USRES([L]ILINE_US).WAITIM = [L]WAITIM + [L]PSPTIM
                                Endif
                            Endif
                        Endif
                    Endif
                Next [L]RPLNUM
            Next
        Endif
#    Next
    FreeGroup CURRUSRES
Return

$UPDATE_MARKER_INFO
    Filter [MRK] Where MFGNUM = [L]MFGNUM & OPENUM = [L]OPENUM
    For [F:MRK]
        [L]ILINE_MK = fmet this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).ADDLINE("MARKERS", [V]CST_ALASTPOS)
        If [L]ILINE_MK <> [V]CST_ANOTDEFINED
            # Currently all usable resources are work centres, so type is always 1.
            this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).MARKERS([L]ILINE_MK).MRKID = [F:MRK]MRKID
            this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).MARKERS([L]ILINE_MK).COMMENT = [F:MRK]COMMENT
        Endif
    Next
    Filter [MRK]
Return

$UPDATE_CUSTOM_FIELDS
    Local Integer WOCUSFLD1
    Local Integer WOCUSFLD2
    Local Integer OPCUSFLD1
    Local Integer OPCUSFLD2
    Local Integer CUSFLDS

    Raz [F:PSCV]

    Filter [PSCV] Where DEFFLG = 2 | FCY = this.FCY
    For [PSCV]
        WOCUSFLD1 = [F:PSCV]WOCUSFLD(0)
        WOCUSFLD2 = [F:PSCV]WOCUSFLD(1)
        OPCUSFLD1 = [F:PSCV]OPCUSFLD(0)
        OPCUSFLD2 = [F:PSCV]OPCUSFLD(1)
        If [F:PSCV]FCY = this.FCY
            Break
        Endif
    Next

    # Check if we need to send the custom fields definitions
    If [F:PSCV]UPDDATTIM > [L]LREFDAT & [F:PSCV]UPDDATTIM <= [L]LTIMENOW
        [L]CUSFLDUPD = 1
    Else
        [L]CUSFLDUPD = 0
    Endif

    CUSFLDS = 1
    If WOCUSFLD1 > 0
        Read [PSCF]PSCF0=3502;WOCUSFLD1
        If fstat = [V]CST_AOK
            POPSCUSFLDS(CUSFLDS) = NewInstance C_POPSCUSFLDS AllocGroup null
            SetInstance POPSCUSFLDS(CUSFLDS) With [F:PSCF]
            POPSCUSFLDS(CUSFLDS).FLDORD = 1
            CUSFLDS += 1
        Endif
    Endif
    If WOCUSFLD2 > 0
        Read [PSCF]PSCF0=3502;WOCUSFLD2
        If fstat = [V]CST_AOK
            POPSCUSFLDS(CUSFLDS) = NewInstance C_POPSCUSFLDS AllocGroup POPSCUSFLDS(CUSFLDS - 1)
            SetInstance POPSCUSFLDS(CUSFLDS) With [F:PSCF]
            POPSCUSFLDS(CUSFLDS).FLDORD = 2
            CUSFLDS += 1
        Endif
    Endif
    If OPCUSFLD1 > 0
        Read [PSCF]PSCF0=3503;OPCUSFLD1
        If fstat = [V]CST_AOK
            POPSCUSFLDS(CUSFLDS) = NewInstance C_POPSCUSFLDS AllocGroup POPSCUSFLDS(CUSFLDS - 1)
            SetInstance POPSCUSFLDS(CUSFLDS) With [F:PSCF]
            POPSCUSFLDS(CUSFLDS).FLDORD = 1
            CUSFLDS += 1
        Endif
    Endif
    If WOCUSFLD2 > 0
        Read [PSCF]PSCF0=3503;OPCUSFLD2
        If fstat = [V]CST_AOK
            POPSCUSFLDS(CUSFLDS) = NewInstance C_POPSCUSFLDS AllocGroup POPSCUSFLDS(CUSFLDS - 1)
            SetInstance POPSCUSFLDS(CUSFLDS) With [F:PSCF]
            POPSCUSFLDS(CUSFLDS).FLDORD = 2
            CUSFLDS += 1
        Endif
    Endif
Return

$UPDATE_OP_CUSTOM_INFO
    For I = 1 To 4
        If POPSCUSFLDS(I) = null
            Break
        Endif
        If POPSCUSFLDS(I).ENTTYP = "OP"
            [L]ILINE_CUSFLD = fmet this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).ADDLINE("CUSVALS", [V]CST_ALASTPOS)
            If [L]ILINE_CUSFLD <> [V]CST_ANOTDEFINED
                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).CUSVALS([L]ILINE_CUSFLD).ID = POPSCUSFLDS(I).AUUID
                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).CUSVALS([L]ILINE_CUSFLD).CUSVAL = evalue(POPSCUSFLDS(I).FORMULE)
            Endif
        Endif
    Next
Return

$UPDATE_WO_CUSTOM_INFO
    Local Char SAVVCRNUM(GLONVCR)

    # Get the customer number and name if the WO is linked to a sales order
    If [F:MFI]VCRTYPORI = 2
        Read [BPC]BPC0=[F:MFI]BPCNUM
        If fstat <> [V]CST_AOK
            Raz [F:BPC]
        Endif
    Else
        [L]SAVVCRNUM = [F:MFI]VCRNUMORI
        [F:MFI]VCRNUMORI = ""
    Endif

    # Currently we only have 2 custom fields for WO and 2 for OP
    For I = 1 To 4
        If POPSCUSFLDS(I) = null
            Break
        Endif
        If POPSCUSFLDS(I).ENTTYP = "WO"
            [L]ILINE_CUSFLD = fmet this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).ADDLINE("CUSVALS", [V]CST_ALASTPOS)
            If [L]ILINE_CUSFLD <> [V]CST_ANOTDEFINED
                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).CUSVALS([L]ILINE_CUSFLD).ID = POPSCUSFLDS(I).AUUID
                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).CUSVALS([L]ILINE_CUSFLD).CUSVAL = evalue(POPSCUSFLDS(I).FORMULE)
            Endif
        Endif
    Next

    # Set VCRNUMORI back to it's previous value if we blanked it
    If [F:MFI]VCRTYPORI <> 2
        [F:MFI]VCRNUMORI = [L]SAVVCRNUM
    Endif

Return

$UPDATE_OPERATION_LINKS_INFO
    Local Decimal SCDQTY
    Local Decimal SCDTIM
    Local Integer COUNT
    Local Integer PRVLINE
    Local Instance SCHEDULES Using C_POPSWRKORD
    SCHEDULES = NewInstance C_POPSWRKORD AllocGroup null
    [L]BETWEENOP = 0
    [L]PREVOP = ""
    [L]NEXTOP = ""
    [L]ILINE_LN = 0

    # Create operation links. There needs to be a link created between operations
    # where operations are successors.
    # Need to link and filter differently for work orders and suggestions
    If [L]ORDTYP = 1
        Link [SCH] With
&           [OPS]OPS1=[F:SCH]MFGNUM;[F:SCH]OPENUM;[F:SCH]OPESPLNUM,
&           [MFO]MFO0=[F:SCH]MFGNUM;[F:SCH]OPENUM;[F:SCH]OPESPLNUM
&           As [SCH_]

        Filter [F:SCH_] Where MFGNUM = [L]MFGNUM and [F:MFO]OPESTA <> 6
    Else
        Link [SCH] With
&           [OPS]OPS1=[F:SCH]MFGNUM;[F:SCH]OPENUM;[F:SCH]OPESPLNUM
&           As [SCH_]

        Filter [F:SCH_] Where MFGNUM = [L]MFGNUM
    Endif

    For [F:SCH_]

        # Loop on operation
        # Take test for next operation.

        If ([L]BETWEENOP = 0 & [F:SCH]SCDCOD <> 7)
            [L]BETWEENOP = 1
        Else
            If [F:SCH]SCDCOD = 7 # all operations parallel
                If [L]COUNT = 0
                    [L]BETWEENOP = 0
                Else
                    [L]ILINE_LN = fmet this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).ADDLINE("OPELNKS", [V]CST_ALASTPOS)
                    If [L]ILINE_LN <> [V]CST_ANOTDEFINED
                        this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPELNKS([L]ILINE_LN).PRVOPID = SCHEDULES.OPELNKS(1).OPENUM
                        this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPELNKS([L]ILINE_LN).SCDCOD = "SS"
                        If [F:SCH]OPESPLNUM > 0
                            If [F:SCH]NEXOPENUM = 0
                                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPELNKS([L]ILINE_LN).NEXOPENUM = [L]MFGNUM + "|" + [L]ITMREF + "|" + format$("N0:5", [F:SCH]OPENUM) + "|" + format$("N0:5", [F:
& SCH]OPESPLNUM)
                            Else
                                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPELNKS([L]ILINE_LN).NEXOPENUM = [L]MFGNUM + "|" + [L]ITMREF + "|" + format$("N0:5", [F:SCH]NEXOPENUM) + "|" + format$("N0:5", 0
& )
                            Endif
                        Else
                            this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPELNKS([L]ILINE_LN).NEXOPENUM = [L]MFGNUM + "|" + [L]ITMREF + "|" + format$("N0:5", [F:SCH]OPENUM) + "|" + format$("N0:5", [F:SCH]
& OPESPLNUM)
                        Endif
                    Endif
                Endif

            # Check for Absolute successor
            Elsif [L]SCDCOD = "AS" & [L]COUNT > 1
                [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Count =" - num$([L]COUNT))
                For [L]PRVLINE = [L]COUNT To 1 Step -1
                    [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Current link (" + num$([L]PRVLINE) + ") Total links (" + num$([L]COUNT) + ")")
                    [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Link type (" + num$([L]PRVLINE) + ") = " + SCHEDULES.OPELNKS([L]PRVLINE).SCDCOD)

                    If (SCHEDULES.OPELNKS([L]PRVLINE).SCDCOD = "ES" | SCHEDULES.OPELNKS([L]PRVLINE).SCDCOD = "AS") & [L]PRVLINE <> [L]COUNT
                        [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Break (" + num$([L]PRVLINE) + ") = " + SCHEDULES.OPELNKS([L]PRVLINE).SCDCOD)
                        Break
                    Endif

                    [L]ILINE_LN = fmet this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).ADDLINE("OPELNKS", [V]CST_ALASTPOS)

                    If [L]ILINE_LN <> [V]CST_ANOTDEFINED
                        [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Add new link =" - num$([L]COUNT))
                        this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPELNKS([L]ILINE_LN).OPENUM = func FORMAT_OP_KEY ([L]MFGNUM, [L]ITMREF, [F:SCH]OPENUM, [F:SCH]OPESPLNUM)
                        this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPELNKS([L]ILINE_LN).PRVOPID = SCHEDULES.OPELNKS([L]PRVLINE).OPENUM
                        [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Add new link =" - this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPELNKS([L]ILINE_LN).PRVOPID)
                        [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "2a Next OP = " + format$("N0:5", [F:SCH]NEXOPENUM) + "~" + format$("N0:5", [F:SCH]OPESPLNUM))
                        [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "3a Next OP = " + format$("N0:5", SCHEDULES.OPELNKS([L]PRVLINE).NEXOPENUM) + "~" + format$("N0:5", [F:SCH]OPESPLNUM))
                        If [F:SCH]OPESPLNUM > 0
                            If [F:SCH]NEXOPENUM = 0
                                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPELNKS([L]ILINE_LN).NEXOPENUM = [L]MFGNUM + "|" + [L]ITMREF + "|" + format$("N0:5", [F:SCH]OPENUM) + "|" + format$("N0:5", [F:
& SCH]OPESPLNUM)
                            Else
                                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPELNKS([L]ILINE_LN).NEXOPENUM = [L]MFGNUM + "|" + [L]ITMREF + "|" + format$("N0:5", [F:SCH]NEXOPENUM) + "|" + format$("N0:5", 0
& )
                            Endif
                        Else
                            this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPELNKS([L]ILINE_LN).NEXOPENUM = [L]MFGNUM + "|" + [L]ITMREF + "|" + format$("N0:5", [F:SCH]OPENUM) + "|" + format$("N0:5", [F:SCH]
& OPESPLNUM)
                        Endif
                        this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPELNKS([L]ILINE_LN).SCDCOD = ""
                        [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Overlap -" - num$([L]SCDQTY) - num$([L]SCDTIM))
                        this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPELNKS([L]ILINE_LN).SCDQTY = [L]SCDQTY
                        this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPELNKS([L]ILINE_LN).SCDTIM = [L]SCDTIM
                    Endif
                Next [L]PRVLINE

               [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "End Absolute loop")
            Else
                [L]ILINE_LN = fmet this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).ADDLINE("OPELNKS", [V]CST_ALASTPOS)

                If [L]ILINE_LN <> [V]CST_ANOTDEFINED
                    [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Previous OP = " + [L]PREVOP)
                    [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Next OP = " + format$("N0:5", [F:SCH]OPENUM) + "|" + format$("N0:5", [F:SCH]OPESPLNUM))
                    [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "2 Next OP = " + format$("N0:5", [F:SCH]NEXOPENUM) + "|" + format$("N0:5", [F:SCH]OPESPLNUM))
                    [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "3 Next OP = " + format$("N0:5", [F:SCH]NEXOPENUM) + "|" + format$("N0:5", [F:SCH]OPESPLNUM))
                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPELNKS([L]ILINE_LN).OPENUM = func FORMAT_OP_KEY ([L]MFGNUM, [L]ITMREF, [F:SCH]OPENUM, [F:SCH]OPESPLNUM)
                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPELNKS([L]ILINE_LN).PRVOPID = [L]PREVOP
                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPELNKS([L]ILINE_LN).NEXOPENUM = [L]MFGNUM + "|" + [L]ITMREF + "|" + format$("N0:5", [F:SCH]OPENUM) + "|" + format$("N0:5", [F:SCH]OPESPLNUM
& )

                     If [L]SCDCOD = "ES"
                        this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPELNKS([L]ILINE_LN).SCDCOD = " "
                    Else
                        this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPELNKS([L]ILINE_LN).SCDCOD = [L]SCDCOD
                    Endif
                    [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Overlap -" - num$([L]SCDQTY) - num$([L]SCDTIM))
                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPELNKS([L]ILINE_LN).SCDQTY = [L]SCDQTY
                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPELNKS([L]ILINE_LN).SCDTIM = [L]SCDTIM

                Endif
            Endif
            [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Previous OP = " + [L]PREVOP)
        Endif

        If  [F:SCH]SCDCOD <> 7
            ## do if first op all types but not if all ops parl on all other >1
            [L]PREVOP = func FORMAT_OP_KEY ([L]MFGNUM, [L]ITMREF, [F:SCH]OPENUM, [F:SCH]OPESPLNUM)
            [L]NEXTOP = num$([F:SCH]NEXOPENUM)
            If [L]NEXTOP = "0"
                [L]NEXTOP = num$([F:SCH]OPENUM)
            Endif

            [L]SCDCOD = func POPSENV_CSTD.CONVERT_OPERATION_LINK_TYPE([F:SCH]SCDCOD)

            # Work out if we have a overlap
            If [F:SCH]SCDCOD = 2
                [L]SCDQTY = [F:SCH]SCDLOT * [F:SCH]LOTQTY
            Else
                [L]SCDQTY = [F:SCH]SCDQTY
            Endif
            If [F:SCH]SCDTIM > 0
                [L]SCDTIM = func POPSENV_CSTD.CONVERT_TIME_TO_SECS([F:SCH]SCDTIM, [F:OPS]TIMUOMCOD)
            Else
                [L]SCDTIM = 0
            Endif
        Endif

        [L]COUNT = fmet SCHEDULES.ADDLINE("OPELNKS", [V]CST_ALASTPOS)
        If [L]COUNT <> [V]CST_ANOTDEFINED
            SCHEDULES.OPELNKS([L]COUNT).OPENUM = func FORMAT_OP_KEY ([L]MFGNUM, [L]ITMREF, [F:SCH]OPENUM, [F:SCH]OPESPLNUM)
            SCHEDULES.OPELNKS([L]COUNT).NEXOPENUM = func FORMAT_OP_KEY ([L]MFGNUM, [L]ITMREF, [F:SCH]NEXOPENUM, [F:SCH]OPESPLNUM)
            SCHEDULES.OPELNKS([L]COUNT).SCDCOD = func POPSENV_CSTD.CONVERT_OPERATION_LINK_TYPE([F:SCH]SCDCOD)
        Endif


    Next

    FreeGroup SCHEDULES

Return

$UPDATE_CONTINUATION
    this.ENDTIMSTP = num$([L]LTIMENOW)
    this.CURTAB = [L]CURTAB
    this.CURKEY = [L]CURKEY

    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Update continuation properties" - [L]CURTAB - [L]CURKEY - this.ENDTIMSTP)
    [L]OK = func ENDLOG([L]LOGINUSE, POPSLOG)

Return

$ADD_ERROR
    # Add an error repository if this is the first error.
    If this.ERRREP = null
        [L]ERRLIN = fmet this.ADDLINE("ERRREP", [V]CST_ALASTPOS)
    Endif
    If [L]ERRLIN <> [V]CST_ANOTDEFINED
        [L]ILINE_ER = fmet this.ERRREP([L]ERRLIN).ADDLINE("ERRORS", [V]CST_ALASTPOS)
        If [L]ILINE_ER <> [V]CST_ANOTDEFINED
            this.ERRREP([L]ERRLIN).ERRORS([L]ILINE_ER).ERRCOD = [L]ERRCOD
            this.ERRREP([L]ERRLIN).ERRORS([L]ILINE_ER).ERRMES = [L]ERRMESS
            [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Error message -" - [L]ERRMESS)
        Endif
    Endif
    this.CURTAB = ""
    this.CURKEY = ""
    this.ENDTIMSTP = ""
Return

# X3-19099 - STWIL - Determine the latest operation end date/time
# To do this we need to compare the end dates of each operation. If the operation
# end date is the same we need to check the end time, not the fraction, of the operation
# This is done for each operation on the work order
$DETERMINE_LAST_RESOURCE
    # Ignore any closed operations
    If [F:MFO]OPESTA <> 5
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "OP Enddate -" - num$([F:MFO]OPEEND))
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Lst OP Enddate -" - num$([L]LSTOPEDAT))
        # X3-29591 - STWIL - Convert fraction of day to time before test as larger fraction may not be later time.
        Call OPETIME ([L]LCURDEFDIH, [L]FCY, [F:MFO]EXTWST, [F:MFO]OPEEND, [F:SCH]OPEENDFRD, [L]OPEENDTIME) From JALLIBB_SYRA
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "OP End time -" - [L]OPEENDTIME)
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Lst OP End time -" - num$([L]LSTOPETIM))
        [L]CUROPETIM = gdatetime$(right$(num$([F:MFO]OPEEND), 7) + "-" + mid$(num$([F:MFO]OPEEND), 4, 2) + "-" + left$(num$([F:MFO]OPEEND), 2)+"T"+left$([L]OPEENDTIME,2) + ":" +right$([
& L]OPEENDTIME,3)+ ":00Z")
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Current OP End time -" - num$([L]CUROPETIM))
        # X3-29591 - STWIL - Update new variable [L]LSTWST instead of [L]EXTWST as this is reset elsewhere
        If [F:MFO]OPEEND > [L]LSTOPEDAT
            [L]LSTOPEDAT = [F:MFO]OPEEND
            [L]LSTWST = [F:MFO]EXTWST
            [L]LSTOPETIM = [L]CUROPETIM
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Date Work centre -" - [L]LSTWST - num$([L]LSTOPETIM))
        Endif
        If [F:MFO]OPEEND = [L]LSTOPEDAT & [L]CUROPETIM > [L]LSTOPETIM
            [L]LSTOPETIM = [L]CUROPETIM
            [L]LSTWST = [F:MFO]EXTWST
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Time Work centre -" - [L]LSTWST - num$([L]LSTOPETIM))
        Endif
    Endif
Return

# We have an assignment create the work order link
$UPDATE_WO_LINK
    Filter [ORD] Where STOFCY = this.FCY &
&               VCRTYP = 10 &
&               VCRNUM = [F:MLK]DEMNUM  &
&               VCRLIN = [F:MLK]DEMLIN  &
&               VCRSEQ = [F:MLK]DEMSEQ  &
&               WIPTYP = 6
&               Order By Key ORD3

    For [ORD]
        If !fstat
            LINK_FOUND = 1
        Endif
    Next

    Filter [ORD]

    If LINK_FOUND = 1
        # If the child product is linked to a specific operation
        PARENT_MATCH = [F:ORD]BOMOPE

        LINK_FOUND = 0
        # We now need to get the parent product
        Filter [ORD] Where STOFCY = this.FCY &
&                   VCRTYP = 10 &
&                   VCRNUM = [F:MLK]DEMNUM  &
&                   WIPTYP = 5
&                   Order By Key ORD3

        For [ORD]
            If !fstat
                LINK_FOUND = 1
            Endif
        Next
        Filter [ORD]

        If LINK_FOUND = 1
            Link [SCH] With
&           [MFO]MFO0=[F:SCH]MFGNUM;[F:SCH]OPENUM;[F:SCH]OPESPLNUM
&           As [SCH_]
            # Find final production step operation
            Filter [SCH_] Where MFGNUM = [F:MLK]RESSNUM & [F:MFO]OPESTA <> 6 Order By Key SCH0 Desc
            CHILD_OP = -1
            For [SCH_]
                If CHILD_OP = -1
                    CHILD_OP = [F:SCH]OPENUM
                    CHILD_SPL = [F:SCH]OPESPLNUM
                Endif
                If [F:SCH]MFGMST = 2
                    CHILD_OP = [F:SCH]OPENUM
                    CHILD_SPL = [F:SCH]OPESPLNUM
                    Break
                Endif
            Next
            Filter [SCH_]

            # step 4, confirm phase for upper level WO from scheduling table
            Filter [SCH_] Where MFGNUM = [F:MLK]DEMNUM  & [F:MFO]OPESTA <>6 Order By Key SCH0

            PARENT_OP = -1
            FIRST_OP = -1
            For [SCH_]
                If FIRST_OP = -1
                    FIRST_OP = [F:SCH]OPENUM
                    FIRST_SPL = [F:SCH]OPESPLNUM
                Endif
                If [F:SCH]OPENUM = PARENT_MATCH
                    PARENT_OP = [F:SCH]OPENUM
                    PARENT_SPL = [F:SCH]OPESPLNUM
                    Break
                Endif
            Next
            Filter [SCH_]

            If PARENT_OP > -1 | FIRST_OP > -1
                If PARENT_OP = -1
                    # if phase not found, sync with 1st phase
                    PARENT_OP = FIRST_OP
                Endif
                [L]ILINE_WL = fmet this.WOREP([L]LIN).ADDLINE("WOLNKS", [V]CST_ALASTPOS)
                If [L]ILINE_WL <> [V]CST_ANOTDEFINED
                    this.WOREP([L]LIN).WOLNKS(ILINE_WL).PRVWOID = func FORMAT_WO_KEY([F:MLK]RESSNUM, [F:MLK]ITMREF)
                    this.WOREP([L]LIN).WOLNKS(ILINE_WL).PRVOPID = func FORMAT_OP_KEY([F:MLK]RESSNUM, [F:MLK]ITMREF, CHILD_OP, CHILD_SPL)
                    this.WOREP([L]LIN).WOLNKS(ILINE_WL).NXTWOID = func FORMAT_WO_KEY([F:MLK]DEMNUM, [F:ORD]ITMREF)
                    this.WOREP([L]LIN).WOLNKS(ILINE_WL).NXTOPID = func FORMAT_OP_KEY([F:MLK]DEMNUM, [F:ORD]ITMREF, PARENT_OP, PARENT_SPL)
                    this.WOREP([L]LIN).WOLNKS(ILINE_WL).DELETED = 0
                    # Always set to blank (simple successor)
                    this.WOREP([L]LIN).WOLNKS(ILINE_WL).LNKTYP = ""

                    # Issue X3-44547 - 2017-07-21 by ALSHE : delete WO link depending on assignments
                    [L]MTOLINKKEY1 = func FORMAT_MTOLINK_KEY([F:MLK]DEMNUM, [F:MLK]DEMLIN, [F:MLK]DEMSEQ)
                    [L]MTOLINKKEY2 = func FORMAT_MTOLINK_KEY([F:MLK]RESSNUM, [F:MLK]RESSLIN, [F:MLK]RESSSEQ)
                    [L]ASTATUS = func ADDOBJINF(this.FCY, "MLK", [L]MTOLINKKEY1, [L]MTOLINKKEY2,
&                                               func FORMAT_OP_KEY([F:MLK]DEMNUM, [F:ORD]ITMREF, PARENT_OP, PARENT_SPL),
&                                               func FORMAT_OP_KEY([F:MLK]RESSNUM, [F:MLK]ITMREF, CHILD_OP, CHILD_SPL),"","")
                    # End issue X3-44547

                Endif
            Endif
        Endif
    Endif
Return

#**----------------------------------------------------------------<br/>
#* COPYUSRESCLASS : Copy information from one POPSUSRES class to another
#**<br/>----------------------------------------------------------------<br/>
#* @param COPYTO - C_POPSUSRES = X3 work order status
#* @param COPYFROM - C_POPSUSRES = X3 work order status
#* @return OK - Integer - Whether successful or not, 0 = success
#**<br/>----------------------------------------------------------------
#*!
Funprog COPYUSRESCLASS(COPYTO, COPYFROM)
    Value Instance COPYTO Using C_POPSUSRES
    Value Instance COPYFROM Using C_POPSUSRES

    Local Integer OK
    Local Integer I
    Local Integer TOOLNUM
    Local Integer TOOLIN

    OK = 0

    COPYTO.RESTYP = COPYFROM.RESTYP
    COPYTO.WST = COPYFROM.WST
    COPYTO.WSTFCY = COPYFROM.WSTFCY
    COPYTO.SETTIM = COPYFROM.SETTIM
    COPYTO.OPETIM = COPYFROM.OPETIM
    COPYTO.PRPTIM = COPYFROM.PRPTIM
    COPYTO.WAITIM = COPYFROM.WAITIM
    COPYTO.PSPTIM = COPYFROM.PSPTIM
    COPYTO.WSTNBR = COPYFROM.WSTNBR
    If COPYFROM.TOOLS <> null
        [L]TOOLNUM = maxtab(COPYFROM.TOOLS)
        For I = 1 To TOOLNUM
            [L]TOOLIN = fmet COPYTO.ADDLINE("OPETOOLS", [V]CST_ALASTPOS)
            If [L]TOOLIN <> [V]CST_ANOTDEFINED
                COPYTO.TOOLS(TOOLIN).EQUNUM = COPYFROM.TOOLS([L]I).EQUNUM
                COPYTO.TOOLS(TOOLIN).ITMDES1 = COPYFROM.TOOLS([L]I).ITMDES1
            Endif
        Next [L]I
    Endif

End [L]OK

#**----------------------------------------------------------------<br/>
#* CONTINUATION_REPOSITORY : Calculate which repository a table belongs to.
#**<br/>----------------------------------------------------------------<br/>
#* @param CURTAB - Char = Table name
#* @return CURRREP - Char - Repository table belongs to
#**<br/>----------------------------------------------------------------
#*!
Funprog CONTINUATION_REPOSITORY(CURTAB)
    Variable Char CURTAB()
    Local Char CURREP(20)

    Case CURTAB
        When "DIAHOU","TABUNAVAIL","TABWEEDIA"
            CURREP = "CALREP"
        When "WORKSTATIO","TABWRKCTR"
            CURREP = "RESREP"
        When "WRKORDS","WRKORDS-D","WRKORDS-H","POPSTAG","ORDERS","ORDERS-R","ORDERS-D"
            CURREP = "WOREP"
        When Default
            CURREP = ""
    Endcase

End CURREP

#**----------------------------------------------------------------<br/>
#* CONVERT_X3_TO_PO_STATUS : Convert X3 work order status to Production Scheduler status
#**<br/>----------------------------------------------------------------<br/>
#* @param X3STAT - Integer = X3 work order status
#* @return POSTAT - Integer - Production Scheduler work order status
#**<br/>----------------------------------------------------------------
#*!
Funprog CONVERT_X3_TO_PO_STATUS(X3STAT)
    Value Integer X3STAT
    Local Integer POSTAT

    Case (X3STAT)
        When 1
            POSTAT = 0
        When 2
            POSTAT = 0
        When 3
            POSTAT = 0
        When 4
            POSTAT = 1
        When 5
            POSTAT = 2
        When 6
            POSTAT = 2
        When 7
            POSTAT = 1
        When Default
            POSTAT = X3STAT
    Endcase
End POSTAT

#**----------------------------------------------------------------<br/>
#* CONVERT_CONSTRAINT_TO_BEHAVIOUR : Convert work center constraint to Production Scheduler behaviour
#**<br/>----------------------------------------------------------------<br/>
#* @param CONSTRAINT - Integer = X3 constraint
#* @return BEHAVIOUR - Integer - Production Scheduler behaviour
#**<br/>----------------------------------------------------------------
#*!
Funprog CONVERT_CONSTRAINT_TO_BEHAVIOUR(CONSTRAINT)
    Value Integer CONSTRAINT
    Local Integer BEHAVIOUR

    Case (CONSTRAINT)
        When 1
            BEHAVIOUR = 1
        When 2
            BEHAVIOUR = 0
        When Default
            BEHAVIOUR = CONSTRAINT
    Endcase
End BEHAVIOUR

#**----------------------------------------------------------------<br/>
#* CONVERT_OPERATION_LINK_TYPE : Convert operation link type to Production Scheduler type
#**<br/>----------------------------------------------------------------<br/>
#* @param X3TYPE - Char = X3 operation link type
#* @return POTYPE - Char - Production Scheduler link type
#**<br/>----------------------------------------------------------------
#*!
Funprog CONVERT_OPERATION_LINK_TYPE(X3TYPE)
    Value Integer X3TYPE

    Local Char POTYPE(2)

    Case (X3TYPE)
        When 1
            POTYPE = "AS"
        When 2
            POTYPE = " "
        When 3
            POTYPE = " "
        When 4
            POTYPE = " "
        When 5
            POTYPE = "SS"
        When 6
            POTYPE = "EE"
        When 7
            POTYPE = "SS"
        When 8
            POTYPE = " "
        When 9
            POTYPE = "ES"
        When Default
            POTYPE = " "
    Endcase
End POTYPE

#**----------------------------------------------------------------<br/>
#* CONVERT_HHMM_TO_SECS : Convert operation run time into number of seconds.
#**<br/>----------------------------------------------------------------<br/>
#* @param HHMM - Char = Time in hours and minutes
#* @return SECS - Integer - Number of seconds
#**<br/>----------------------------------------------------------------
#*!
Funprog CONVERT_HHMM_TO_SECS (HHMM)
    Value Char HHMM
    Local Integer SECS
    Local Integer HH
    Local Integer MM

    HH = val(left$ (HHMM, 2)) * 3600
    MM = val(right$ (HHMM, 3)) * 60
    SECS = HH + MM
End SECS

#**----------------------------------------------------------------<br/>
#* CONVERT_TIME_TO_SECS : Convert operation run time into number of seconds.
#**<br/>----------------------------------------------------------------<br/>
#* @param TIMETOCONV - Decimal = Operation run time
#* @param H_OR_M - Integer = Unit of run time (1 = hours otherwise minutes)
#* @return SECS - Integer - Number of seconds
#**<br/>----------------------------------------------------------------
#*!
Funprog CONVERT_TIME_TO_SECS (TIMETOCONV, H_OR_M)
    Value Decimal TIMETOCONV
    Value Integer H_OR_M
    Local Integer SECS

    If H_OR_M = 1
        SECS = TIMETOCONV * 3600
    Else
        SECS = TIMETOCONV * 60
    Endif

End SECS

##**----------------------------------------------------------------<br/>
##* CONVERT_HOURS_TO_HHMM : Convert fraction of day into time (HHMM).
##**<br/>----------------------------------------------------------------<br/>
##* @param HOURS - Decimal = Number of hours
##* @return NEWTIME - Char - Time operation ends (HHMM)
##**<br/>----------------------------------------------------------------
##*!
Funprog CONVERT_HOURS_TO_HHMM (HOURS)
    Value Decimal HOURS
    Local Integer SECS
    Local Char HHMM(10)
    Local Double NEWSECS
    Local Integer HRS
    Local Integer MINUTES

    NEWSECS = HOURS * 3600

    HRS = NEWSECS / 3600
    NEWSECS -= HRS * 3600
    MINUTES = NEWSECS / 60

    HHMM = format$("N0:2", HOURS)+format$("N0:2", MINUTES)
End HHMM

