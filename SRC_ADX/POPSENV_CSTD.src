#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe POPSENV
# This is an interface between Ortems Planner One that is being OEM'd as
# Production Scheduler. It uses a javascript bundle to handle the requests
# from the Planner One service. The Planner One service issues a http get
# request to retrieve data uses the site code and a timestamp. If the
# timestamp is not blank then only those records that have changed since
# the timestamp are read. The Planner One service also issues a http PUT
# to send updated data which is then used to update the X3 tables.
#
# The structure of the data being exchanged uses interface classes in
# collections to represent the JSON required by Planner One. The javascript
# bundle performs a transformation from JSON to the X3 classes and vice
# versa.


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return [L]ASTATUS Local Integer
#*!
$EVENTS
 Case [L]CURPTH
   When ""
     Case [L]AEVENT
      When "AREAD"   : Gosub AREAD
      When Default
     Endcase
 Endcase
Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return [L]ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#   Case [L]ARULE
#   Endcase
#Endcase
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
Return

$AREAD
    # Open all of the required files
    Local File FACILITY   [FCY]
    Local File TABWRKCTR  [TWC]
    Local File WORKSTATIO [MWS]
    Local File MFGHEAD    [MFG]
    Local File MFGOPE     [MFO]
    Local File DIAHOU     [DIH]
    Local File TABWEEDIA  [TWD]
    Local File TABUNAVAIL [TUV]
    Local File MFGITM     [MFI]
    Local File ITMMASTER  [ITM]
    Local File ROUOPE     [ROO]
    Local File SCHEDULING [SCH]
    Local File ROUTING    [ROH]
    Local File POPSCALEXP [CEP]
    Local File CAPVAR     [CPV]
    Local File POPSTAG    [TAG]
    Local File POPSMRK    [MRK]
    Local File POPSPIN    [PIN]
    Local File RVMVAL     [RVV]
    Local File BOM        [BOH]
    Local File ECCVAL     [EVL]
    Local File ORDERS     [ORD]
    Local File OPERATIONS [OPS]
    #Local File POPSWOS    [PSWOS]      # Issue X3-7276 - 2017-02-01 by CCC
    Local File RPLWST      [RPW]
    Local File ADOVAL      [ADW]
    Local File POPSOBJ     [PSOBJ]
    Local File POPSCUSFLDS [PSCF]
    Local File POPSCUSVALS [PSCV]
    Local File BPCUSTOMER  [BPC]
    Local File MTOLINK     [MLK]

    Local Instance POPSLOG Using C_ALOG
    POPSLOG = NewInstance C_ALOG AllocGroup null

    # X3-29632 - STWIL - Timezone class to convert local times to UTC
    Local Instance TIMEZONE Using C_TIMEZONE
    TIMEZONE = NewInstance C_TIMEZONE AllocGroup null

    Local Instance POPSCUSFLDS(1..4) Using C_POPSCUSFLDS

    Local Integer  ILINE_GRPRES
    Local Integer  ILINE_RES
    Local Integer  ILINE_CEP
    Local Integer  ILINE_CPV
    Local Integer  ILINE_TAG
    Local Integer  ILINE
    Local Integer  LIN
    Local Integer  PERLINE
    Local Char     LTEXTE(255)
    Local Datetime LREFDAT
    Local Datetime LTIMENOW
    Local Integer  LDELTAFLG
    Local Integer  LOGINUSE
    Local Integer  OK
    Local Integer  I
    Local Integer  IFTRANSOPEN
    Local Integer  MAXNORECS
    Local Integer  CONTINUE
    Local Integer  RECCNT
    Local Integer  ERRLIN
    Local Integer  ILINE_ER

    Local Char STRDATTIM(20)
    Local Char ENDDATTIM(20)
    Local Char STRDAT(20)
    Local Char ENDDAT(20)
    Local Char LOGNAME(30)
    Local Char LOGTIME(30)
    Local Char CURREP(20)
    Local Char ERRMESS(250)
    Local Char MESSAGE(250)
    Local Char ERRCOD(6)
    Local Char LCURDEFDIH(GLONDIH) # current value of DEFDIH parameter for the site
    Local Char MFGNUM(GLONVCR)
    Local Char ITMREF(GLONITM)
    Local Char ENDHOU(10)
    Local Integer ROUALT
    Local Integer OPENUM
    Local Double REMQTY
    Local Integer LFCYUPD       # =1 if site has been modified => time structure and unavailability have to be sent again
    Local Integer LDEFDIHUPD    # =1 if DEFDIH has been updated
    Local Integer CUSFLDUPD     # =1 if custom value record has been updated meaning we need to send custom field definitions
    Local Integer ILINE_CUSFLD

    Local Integer ILINE_WL
    Local Integer LINK_FOUND
    Local Integer CHILD_OP
    Local Integer CHILD_SPL
    Local Integer PARENT_OP
    Local Integer PARENT_SPL
    Local Integer PARENT_MATCH
    Local Integer FIRST_OP
    Local Integer FIRST_SPL

    Local Integer LINK_EXISTS

    # Update the class from the parameters
    this.FCY = [L]FCY
    this.TIMESTAMP = [L]TIMESTAMP
    this.ENDTIMSTP = [L]ENDTIMSTP
    this.CURTAB = [L]CURTAB
    this.CURKEY = [L]CURKEY
    this.MAXREC = [L]MAXREC

    [L]CURREP = func CONTINUATION_REPOSITORY([L]CURTAB)

    [L]MAXNORECS = val([L]MAXREC)
    [L]CONTINUE = 0
    [L]RECCNT = 0

    # This log is for debugging and timing purposes and is not intended
    # to be seen by the user.
    # Normally the LOGINUSE flag will be set to 0 for release use the parameter to set to 1
    [L]LOGINUSE = 0
    [L]LOGTIME = time$
    If this.TIMESTAMP = ""
        If func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 3, this.FCY, "PSLOGTRACE") = "YES"
            [L]LOGINUSE = 1
        Endif
        If [L]MAXNORECS = 0
            [L]LOGNAME = "POPS"+this.FCY
        Else
            [L]LOGNAME = "POPS"+this.FCY+left$([L]LOGTIME, 2)+mid$([L]LOGTIME, 4, 2)+right$([L]LOGTIME, 7)
        Endif
    Else
        [L]LOGINUSE = 0
        [L]LOGNAME = "POPSD"+this.FCY+left$([L]LOGTIME, 2)+mid$([L]LOGTIME, 4, 2)+right$([L]LOGTIME, 7)
    Endif

    [L]OK = func STARTLOG([L]LOGINUSE, POPSLOG, mess(885,197,1) + " - AREAD", [L]LOGNAME)

    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Start of function"-[L]LOGNAME)
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "FCY=" - this.FCY - "TIMESTAMP=" + this.TIMESTAMP - "MAXREC=" + this.MAXREC)
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Current rep=" + [L]CURREP - "Current table=" + [L]CURTAB - "Current Rec=" + [L]CURKEY)

    # Setup site details and timestamp if passed
    Read [FCY]FCY0 = this.FCY
    If fstat = 0
        this.FCYNAM = [F:FCY]FCYNAM
    Else
        [L]ERRMESS = mess(349,193,1)
        [L]ASTATUS = fmet this.ASETERROR("",[L]ERRMESS, [V]CST_AERROR)
        [L]ERRCOD = num$([L]ASTATUS)
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Issue with site")

        # Add an error repository
        Gosub ADD_ERROR

        [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Stop processing")
        [L]OK = func ENDLOG([L]LOGINUSE, POPSLOG)

        FreeGroup TIMEZONE
        FreeGroup POPSLOG

        Return
    Endif

    # X3-29632 - STWIL - Setup timezone class to convert local times to UTC
    ASTATUS = fmet TIMEZONE.INITIALIZE(func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 3, this.FCY, "PSTIMEZONE"), "")
    If ASTATUS <> [V]CST_AOK
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Issue with timezone")
    Endif

    [L]IFTRANSOPEN = adxlog

    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "adxlog="-num$(adxlog))

    If [L]IFTRANSOPEN = 0
        # Issue X3-7276 - 2017-02-06 by CCC
        #Trbegin MFGHEAD, POPSWOS
        Trbegin MFGHEAD
    Endif

    # Set up timestamp value
    If this.TIMESTAMP <> ""
        LREFDAT = gdatetime$(this.TIMESTAMP)
        LDELTAFLG = 1
    Else
        LDELTAFLG = 0
# Issue x3-7276 - 2017-02-02 by CCC : Deletion management
#        # This is an initialisation - delete the MRP suggestions records in POPSWOS
#        If [L]CURTAB = ""
#            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Delete POPSWOS records")
#            [L]OK = func POPSENV_CSTD.DELETE_SUGGESTIONS(this.FCY)
#        Endif
    Endif

    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Create setup repository")

    # Create setup repository if no timestamp
    # X3-105117 - STWIL - Change to check for CURTAB as CURREP may be blank on subsequent requests
    If [L]LDELTAFLG = 0 & [L]CURTAB = ""
        LIN = fmet this.ADDLINE("SETUP", [V]CST_ALASTPOS)
        If LIN <> [V]CST_ANOTDEFINED
            this.SETUP(LIN).RETENTION = 20

            this.SETUP(LIN).STAWKTMP = "twd"    # Issue x38281 - 2017-02-09 by CCC : default weekly structure of the site

            # X3-105117 - STWIL - Issue continuation after setup so that service restart doesn't reset POPSOBJ table
            [L]CURREP = "CALREP"
            [L]CURTAB = "DIAHOU"
            [L]CURKEY = ""
            # If there hasn't been an error commit the transaction
            If [L]IFTRANSOPEN = 0
                [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Transaction committed")
                Commit
            Endif

            Gosub UPDATE_CONTINUATION
            Return
        Else
            # There was an error so set error and return.
            [L]ERRMESS = mess(350,193,1)
            [L]ASTATUS = fmet this.ASETERROR("", [L]ERRMESS, [V]CST_AERROR)
            [L]ERRCOD = num$(ASTATUS)
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Unable to create setup repository")
            [L]OK = func ENDLOG([L]LOGINUSE, POPSLOG)

            # There has been an error rollback the transaction
            If [L]IFTRANSOPEN = 0
                [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Transaction committed")
                Rollback
            Endif

            # Add an error repository
            Gosub ADD_ERROR

            FreeGroup TIMEZONE
            FreeGroup POPSLOG

            Return
        Endif

    Endif

    # Update the timestamp value for the response, if first request.
    If ([L]ENDTIMSTP = "")
        [L]LTIMENOW = datetime$
    Else
        [L]LTIMENOW = gdatetime$(this.ENDTIMSTP)
    Endif

    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "End timestamp = " + num$([L]LTIMENOW))

    # Issue X3-8281 - 2017-02-10 by CCC : to know if site has been modified and then update default weekly structure
    If [F:FCY]UPDDATTIM>=[L]LREFDAT & [F:FCY]UPDDATTIM<=[L]LTIMENOW
        [L]LFCYUPD = 1
    Endif

    # Issue X3-8281 - 2017-02-08 by CCC : Check if DEFDIH has been modified for the site
    [L]LCURDEFDIH = func ADP_TOOL.GET_PARAM(GACTX.AFOLDER, 3, this.FCY, "DEFDIH")
    If func GETADPVAL(this.FCY, "DEFDIH")<>[L]LCURDEFDIH
        [L]LDEFDIHUPD=1
    Endif

    # X3-105117 - STWIL - Only delete the POPSOBJ table records if site is initialised
    If [L]LDELTAFLG = 0 & [L]CURKEY = ""
        # Issue X3-7276 - 2017-02-01 by CCC : Site is reinitialized => delete in POPSOBJ all that was sent to PS
        Delete [PSOBJ] Where FCY=this.FCY
    Endif

    # Create calendar repository if required
    If [L]CURREP = "" | [L]CURREP = "CALREP"
        [L]CURREP = ""
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Create calendar repository")
        [L]LIN = fmet this.ADDLINE("CALREP", [V]CST_ALASTPOS)
        If [L]LIN = [V]CST_ANOTDEFINED
            # There was an error so set error and return.
            [L]ERRMESS = mess(351,193,1)
            [L]ASTATUS = fmet this.ASETERROR("", [L]ERRMESS, [V]CST_AERROR)
            [L]ERRCOD = num$(ASTATUS)
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Unable to create calendar repository")
            [L]OK = func ENDLOG([L]LOGINUSE, POPSLOG)

            # There has been an error rollback the transaction
            If [L]IFTRANSOPEN = 0
                [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Transaction committed")
                Rollback
            Endif

            # Add an error repository
            Gosub ADD_ERROR

            FreeGroup TIMEZONE
            FreeGroup POPSLOG

            Return
        Endif

        # Issue X3-7276 - 2017-01-31 by CCC : Deletion management
        If [L]LDELTAFLG & ([L]CURTAB = "" | [L]CURTAB = "POPSOBJ-CAL")
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Look for 'Deleted' calendar objects DIH & TWD")
            If [L]MAXNORECS=0
                I=-1    # no limit
            Else
                I = [L]MAXNORECS-[L]RECCNT      # number of records that can still be inserted
            Endif
            [L]ASTATUS = fmet this.CALREP([L]LIN).CHKDEL(this.FCY,[L]CURTAB,[L]CURKEY,I)
            If [L]MAXNORECS=0
                [L]RECCNT -= I+1    # Here I is negative
            Else
                [L]RECCNT = [L]MAXNORECS - I
            Endif
            If [L]CURTAB<>""
                [L]CONTINUE = 1
            Endif
            If [L]ASTATUS <> [V]CST_AOK # If there was an error during deletion of PSOBJ record, it's not serious => log and continue
                [L]ERRMES = mess(81,125,1)-"POPSOBJ-CAL"
                [L]ASTATUS = fmet this.ASETERROR("", [L]ERRMESS, [V]CST_AERROR)
                [L]ERRCOD = num$(ASTATUS)
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, [L]ERRMESS)
                [L]OK = func ENDLOG([L]LOGINUSE, POPSLOG)
            Endif
        Endif



        # check if we need to read day templates
        If [L]CURTAB = "" | [L]CURTAB = "DIAHOU"
            # Filter day template if timestamp passed
            If [L]LDELTAFLG
                Filter [DIH] Where [F:DIH]UPDDATTIM>=LREFDAT & [F:DIH]UPDDATTIM<=[L]LTIMENOW
            Endif

            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Read DIA records ")
            # Add day template items to collection
            For [F:DIH]DIH0 From [L]CURKEY To "~"
                If [L]MAXNORECS > 0 & [L]RECCNT + 1 > [L]MAXNORECS
                    [L]CURKEY = [F:DIH]NUM
                    [L]CURTAB = "DIAHOU"
                    [L]CONTINUE = 1
                    Break
                Endif
                [L]ILINE = fmet this.CALREP([L]LIN).ADDLINE("DAYTEMP", [V]CST_ALASTPOS)
                If [L]ILINE <> [V]CST_ANOTDEFINED
                    this.CALREP([L]LIN).DAYTEMP([L]ILINE).NUM = [F:DIH]NUM

                    [L]ASTATUS = func ADDOBJ(this.FCY, "DIH", [F:DIH]NUM, "")    # Issue X3-7276 - 2017-01-31 by CCC

                    # Create periods collection
                    For I = 0 To dim([F:DIH]STRHOU) - 1
                        If [F:DIH]STRHOU(I) <> ""
                            [L]PERLINE = fmet this.CALREP([L]LIN).DAYTEMP([L]ILINE).ADDLINE("PERIODS", [V]CST_ALASTPOS)
                            If [L]PERLINE <> [V]CST_ANOTDEFINED
                                this.CALREP([L]LIN).DAYTEMP([L]ILINE).PERIODS([L]PERLINE).STRHOU = func POPSENV_CSTD.CONVERT_HHMM_TO_SECS([F:DIH]STRHOU(I))
                                this.CALREP([L]LIN).DAYTEMP([L]ILINE).PERIODS([L]PERLINE).EFFIC = 100.0
                                # if ENDHOU = 0 then this is 24:00 midnight so we need to set to 86400 secs
                                If [F:DIH]ENDHOU(I) = "0000" | [F:DIH]ENDHOU(I) = "2359"
                                    [L]ENDHOU = "2400"
                                Else
                                    [L]ENDHOU = [F:DIH]ENDHOU(I)
                                Endif
                                this.CALREP([L]LIN).DAYTEMP([L]ILINE).PERIODS([L]PERLINE).ENDHOU = func POPSENV_CSTD.CONVERT_HHMM_TO_SECS([L]ENDHOU)
                                # We can't split the time if period carrys over to the next day as we end up with unwanted time periods
                                # Leave as is, Planner One will ignore these which are usable in X3 any way.
                                # if end time is earlier than start time then the period is continuing into the next day
                                # so we need to create another record.
#                                If [L]ENDHOU > [F:DIH]STRHOU(I)
#                                    this.CALREP([L]LIN).DAYTEMP([L]ILINE).PERIODS([L]PERLINE).ENDHOU = func POPSENV_CSTD.CONVERT_HHMM_TO_SECS([L]ENDHOU)
#                                Else
#                                    # Start this days end time to 24:00 (86400 secs)
#                                    this.CALREP([L]LIN).DAYTEMP([L]ILINE).PERIODS([L]PERLINE).ENDHOU = 86400
#                                    [L]PERLINE = fmet this.CALREP([L]LIN).DAYTEMP([L]ILINE).ADDLINE("PERIODS", [V]CST_ALASTPOS)
#                                    If [L]PERLINE <> [V]CST_ANOTDEFINED
#                                        # As we have started a new day the start time will be 0:00am (0 secs)
#                                        this.CALREP([L]LIN).DAYTEMP([L]ILINE).PERIODS([L]PERLINE).STRHOU = 0
#                                        this.CALREP([L]LIN).DAYTEMP([L]ILINE).PERIODS([L]PERLINE).EFFIC = 100.0
#                                        this.CALREP([L]LIN).DAYTEMP([L]ILINE).PERIODS([L]PERLINE).ENDHOU = func POPSENV_CSTD.CONVERT_HHMM_TO_SECS([L]ENDHOU)
#                                    Endif
#                                    this.CALREP([L]LIN).DAYTEMP([L]ILINE).PERIODS([L]PERLINE).ENDHOU = 86400
#                                Endif
                            Endif
                        Endif
                    Next
                Endif
                RECCNT += 1
                [L]CURTAB = ""
                [L]CURKEY = ""
            Next
            If [L]LDELTAFLG
                Filter [DIH]
            Endif
        Endif

        # check if we need to read weekly time schemas
        If [L]CURTAB = "" | [L]CURTAB = "TABWEEDIA"

            If [L]LDELTAFLG
                If LDEFDIHUPD=1
                    Filter [TWD] Where [F:TWD]UPDDATTIM>=LREFDAT & [F:TWD]UPDDATTIM<=[L]LTIMENOW
&                                    | [F:TWD]DIAHOU(0)="" & [F:TWD]DAYCAP(0)>0
&                                    | [F:TWD]DIAHOU(1)="" & [F:TWD]DAYCAP(1)>0
&                                    | [F:TWD]DIAHOU(2)="" & [F:TWD]DAYCAP(2)>0
&                                    | [F:TWD]DIAHOU(3)="" & [F:TWD]DAYCAP(3)>0
&                                    | [F:TWD]DIAHOU(4)="" & [F:TWD]DAYCAP(4)>0
&                                    | [F:TWD]DIAHOU(5)="" & [F:TWD]DAYCAP(5)>0
&                                    | [F:TWD]DIAHOU(6)="" & [F:TWD]DAYCAP(6)>0
                Else
                    Filter [TWD] Where [F:TWD]UPDDATTIM>=LREFDAT & [F:TWD]UPDDATTIM<=[L]LTIMENOW
                Endif
            Endif

            # Create weekly time schema collection
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Read TWD records ")
            For [F:TWD]TWD0 From [L]CURKEY To "~"
                If [L]MAXNORECS > 0 & [L]RECCNT + 1 > [L]MAXNORECS
                    [L]CURKEY = [F:TWD]TWD
                    [L]CURTAB = "TABWEEDIA"
                    [L]CONTINUE = 1
                    Break
                Endif

                [L]ILINE = fmet this.CALREP([L]LIN).ADDLINE("WEEKTEMP", [V]CST_ALASTPOS)
                If [L]ILINE <> [V]CST_ANOTDEFINED

                    [L]ASTATUS = fmet this.CALREP([L]LIN).WEEKTEMP([L]ILINE).INITIATE([F:TWD]TWD,
&                                                               string$([F:TWD]DIAHOU(0)<>"",[F:TWD]DIAHOU(0)) + string$([F:TWD]DIAHOU(0)="" & [F:TWD]DAYCAP(0)>0,[L]LCURDEFDIH),
&                                                               string$([F:TWD]DIAHOU(1)<>"",[F:TWD]DIAHOU(1)) + string$([F:TWD]DIAHOU(1)="" & [F:TWD]DAYCAP(1)>0,[L]LCURDEFDIH),
&                                                               string$([F:TWD]DIAHOU(2)<>"",[F:TWD]DIAHOU(2)) + string$([F:TWD]DIAHOU(2)="" & [F:TWD]DAYCAP(2)>0,[L]LCURDEFDIH),
&                                                               string$([F:TWD]DIAHOU(3)<>"",[F:TWD]DIAHOU(3)) + string$([F:TWD]DIAHOU(3)="" & [F:TWD]DAYCAP(3)>0,[L]LCURDEFDIH),
&                                                               string$([F:TWD]DIAHOU(4)<>"",[F:TWD]DIAHOU(4)) + string$([F:TWD]DIAHOU(4)="" & [F:TWD]DAYCAP(4)>0,[L]LCURDEFDIH),
&                                                               string$([F:TWD]DIAHOU(5)<>"",[F:TWD]DIAHOU(5)) + string$([F:TWD]DIAHOU(5)="" & [F:TWD]DAYCAP(5)>0,[L]LCURDEFDIH),
&                                                               string$([F:TWD]DIAHOU(6)<>"",[F:TWD]DIAHOU(6)) + string$([F:TWD]DIAHOU(6)="" & [F:TWD]DAYCAP(6)>0,[L]LCURDEFDIH)
&                                                              )

                    [L]ASTATUS = func ADDOBJ(this.FCY, "TWD", [F:TWD]TWD, "")    # Issue X3-7276 - 2017-01-31 by CCC

                Endif
                [L]RECCNT += 1
                [L]CURTAB = ""
                [L]CURKEY = ""
            Next
            If [L]LDELTAFLG
                Filter [TWD]
            Endif
       Endif

       If CURTAB="" | [L]CURTAB = "TABWEEDIA-FCY"
            # Issue X3-8281 - 2017-02-09 by CCC : Send weekly structure of the site if init, default time schema has changed or working days could have been changed on the site
            If (LDELTAFLG=0 | LDEFDIHUPD=1 | LFCYUPD=1)
                If [L]MAXNORECS > 0 & [L]RECCNT + 1 > [L]MAXNORECS
                    [L]CURKEY = "twd"
                    [L]CURTAB = "TABWEEDIA-FCY"
                    [L]CONTINUE = 1
                Else
                    [L]ILINE = fmet this.CALREP([L]LIN).ADDLINE("WEEKTEMP", [V]CST_ALASTPOS)
                    If [L]ILINE <> [V]CST_ANOTDEFINED
                        [L]ASTATUS = fmet this.CALREP([L]LIN).WEEKTEMP([L]ILINE).INITIATE("twd",
&                                                                       string$([F:FCY]UVYDAY(0)=2,[L]LCURDEFDIH),
&                                                                       string$([F:FCY]UVYDAY(1)=2,[L]LCURDEFDIH),
&                                                                       string$([F:FCY]UVYDAY(2)=2,[L]LCURDEFDIH),
&                                                                       string$([F:FCY]UVYDAY(3)=2,[L]LCURDEFDIH),
&                                                                       string$([F:FCY]UVYDAY(4)=2,[L]LCURDEFDIH),
&                                                                       string$([F:FCY]UVYDAY(5)=2,[L]LCURDEFDIH),
&                                                                       string$([F:FCY]UVYDAY(6)=2,[L]LCURDEFDIH)
&                                                                      )
                        [L]RECCNT += 1
                        [L]CURTAB = ""
                        [L]CURKEY = ""
                    Endif
                Endif
            Endif
        Endif

        # check if we need to read weekly time schemas
        If [L]CURTAB = "" | [L]CURTAB = "TABUNAVAIL"
            # If there is an exception code on the site send the information as global exceptions
            # Issue X3-8281 - 2017-02-08 by CCC : if the code has chend on site, send the new values
            If [L]MAXNORECS > 0 & [L]RECCNT + 1 > [L]MAXNORECS
                [L]CURKEY = [F:TUV]UVYCOD
                [L]CURTAB = "TABUNAVAIL"
                [L]CONTINUE = 1
            Else
                If [F:FCY]UVYCOD = "" & func GETADPVAL(this.FCY, "UVYCOD")<>""
                    [L]ILINE = fmet this.CALREP([L]LIN).ADDLINE("GLOBEXP", [V]CST_ALASTPOS)
                    If [L]ILINE <> [V]CST_ANOTDEFINED
                        this.CALREP([L]LIN).GLOBEXP([L]ILINE).UVYDES=""
                        this.CALREP([L]LIN).GLOBEXP([L]ILINE).STRDATTIM = gdatetime$(num$(year(date$-10))+"-01-01T00:00:00Z")
                        this.CALREP([L]LIN).GLOBEXP([L]ILINE).ENDDATTIM = gdatetime$(num$(year(date$-10))+"-01-01T00:00:01Z")
                        this.CALREP([L]LIN).GLOBEXP([L]ILINE).OPENED = 0
                    Endif
                Else
                    If [L]LDELTAFLG & [F:FCY]UVYCOD = func GETADPVAL(this.FCY, "UVYCOD")
                        Filter [TUV] Where [F:TUV]UPDDATTIM>=[L]LREFDAT & [F:TUV]UPDDATTIM<=[L]LTIMENOW & [F:TUV]UVYCOD = [F:FCY]UVYCOD
                    Else
                        Filter [TUV] Where [F:TUV]UVYCOD = [F:FCY]UVYCOD
                    Endif

                    # Create weekly time schema collection
                    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Read TUV records ")
                    Read [TUV]UVY0 First
                    If !fstat
                        For [L]I = 0 To [F:TUV]UVYNBR - 1
                            [L]ILINE = fmet this.CALREP([L]LIN).ADDLINE("GLOBEXP", [V]CST_ALASTPOS)
                            If [L]ILINE <> [V]CST_ANOTDEFINED
                                [L]STRDAT = num$([F:TUV]UVYSTRDAT(I))
                                [L]STRDATTIM = right$([L]STRDAT, 7) + "-" + mid$([L]STRDAT, 4, 2) + "-" + left$([L]STRDAT, 2)
                                Append [L]STRDATTIM, "T00:00:00Z"
                                [L]ENDDAT = num$([F:TUV]UVYENDDAT(I))
                                [L]ENDDATTIM = right$([L]ENDDAT, 7) + "-" + mid$([L]ENDDAT, 4, 2) + "-" + left$([L]ENDDAT, 2)
                                Append [L]ENDDATTIM, "T23:59:59Z"

                                this.CALREP([L]LIN).GLOBEXP([L]ILINE).STRDATTIM = gdatetime$(STRDATTIM)
                                this.CALREP([L]LIN).GLOBEXP([L]ILINE).ENDDATTIM = gdatetime$(ENDDATTIM)
                                this.CALREP([L]LIN).GLOBEXP([L]ILINE).OPENED = 0
                                Call LECTEXTRA_SYR (this,"UVYAXX",this.CALREP([L]LIN).GLOBEXP([L]ILINE).UVYDES,"TABUNAVAIL","UVYAXX",[F:TUV]UVYCOD,num$(val([F:TUV]UVYSTRDAT(I)))) From ATEXTRA
                            Endif
                        Next
                    Endif
                    [L]RECCNT += 1
                    [L]CURTAB = ""
                    [L]CURKEY = ""
                    Filter [TUV]
                Endif
                # Issue X3-8281 - 2017-02-08 by CCC : Save the value used for unavailability code
                Call SETADPVAL(this.FCY, "UVYCOD", [F:FCY]UVYCOD)
            Endif
        Endif
    Endif

    If [L]CONTINUE = 1
        # If there hasn't been an error commit the transaction
        If [L]IFTRANSOPEN = 0
            [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Transaction committed")
            Commit
        Endif

        Gosub UPDATE_CONTINUATION
        Return
    Endif

    # Issue X3-8281 - 2017-02-08 by CCC : Save DEFDIH used after having send everything related to this parameter
    #                                   => do it after UPDATE_CONTINUATION
    If LDEFDIHUPD=1
        Call SETADPVAL(this.FCY, "DEFDIH", [L]LCURDEFDIH)
    Endif

    If [L]CURREP = "" | [L]CURREP = "RESREP"
        [L]CURREP = ""
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Create resource repository ")
        # Create resource repository
        [L]LIN = fmet this.ADDLINE("RESREP", [V]CST_ALASTPOS)
        If [L]LIN = [V]CST_ANOTDEFINED
            # There was an error so set error and return.
            [L]ERRMESS = mess(379,193,1)
            [L]ASTATUS = fmet this.ASETERROR("", [L]ERRMESS, [V]CST_AERROR)
            [L]ERRCOD = num$(ASTATUS)
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Unable to create resource repository")
            [L]OK = func ENDLOG([L]LOGINUSE, POPSLOG)

            # There has been an error rollback the transaction
            If [L]IFTRANSOPEN = 0
                [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Transaction committed")
                Rollback
            Endif

            # Add an error repository
            Gosub ADD_ERROR

            FreeGroup TIMEZONE
            FreeGroup POPSLOG

            Return
        Endif

        # Issue X3-7276 - 2017-01-31 by CCC : Deletion management
        If [L]LDELTAFLG & ([L]CURTAB = "" | [L]CURTAB = "POPSOBJ-RES")
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Look for 'Deleted' resources objects TWC & MWS")
            If [L]MAXNORECS=0
                I=-1    # no limit
            Else
                I = [L]MAXNORECS-[L]RECCNT      # number of records that can still be inserted
            Endif
            [L]ASTATUS = fmet this.RESREP([L]LIN).CHKDEL(this.FCY,[L]CURTAB,[L]CURKEY,I)
            If [L]MAXNORECS=0
                [L]RECCNT -= I+1    # Here I is negative
            Else
                [L]RECCNT = [L]MAXNORECS - I
            Endif
            If [L]CURTAB<>""
                [L]CONTINUE = 1
            Endif
            If [L]ASTATUS <> [V]CST_AOK # If there was an error during deletion of PSOBJ record, it's not serious => log and continue
                [L]ERRMES = mess(81,125,1)-"POPSOBJ-RES"
                [L]ASTATUS = fmet this.ASETERROR("", [L]ERRMESS, [V]CST_AERROR)
                [L]ERRCOD = num$(ASTATUS)
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, [L]ERRMESS)
                [L]OK = func ENDLOG([L]LOGINUSE, POPSLOG)
            Endif
        Endif


        # check if we need to read work centres or work groups
        If ([L]CURTAB = "" | [L]CURTAB = "WORKSTATIO")
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Read MWS records ")
            # Join work centre groups and work centres
            Link [MWS] With
&               [TWC]TWC0=[MWS]WCR,
&               [FCY]FCY0=[MWS]WCRFCY
&           As [RES_]
&           Where [MWS]WCRFCY=this.FCY
&           Order By Key KEYPO=[MWS]WCR;[MWS]WST

            If [L]LDELTAFLG
                Filter [RES_] Where ([F:TWC]UPDDATTIM>[L]LREFDAT & [F:TWC]UPDDATTIM<=[L]LTIMENOW) | ([F:MWS]UPDDATTIM>[L]LREFDAT & [F:MWS]UPDDATTIM<=[L]LTIMENOW)
            Endif

            For [F:RES_]KEYPO(1) From [L]CURKEY To "~"
                If [L]MAXNORECS > 0 & [L]RECCNT + 1 > [L]MAXNORECS
                    [L]CURKEY = [F:TWC]WCR
                    [L]CURTAB = "WORKSTATIO"
                    [L]CONTINUE = 1
                    Break
                Endif
                # Add resource group items to the collection
                [L]ILINE_GRPRES = fmet this.RESREP([L]LIN).ADDLINE("RESGRPS", [V]CST_ALASTPOS)
                If [L]ILINE_GRPRES <> [V]CST_ANOTDEFINED
                    this.RESREP([L]LIN).RESGRPS([L]ILINE_GRPRES).WCR   = [F:MWS]WCR

                    [L]ASTATUS = func ADDOBJ(this.FCY, "TWC", [F:MWS]WCR, "")    # Issue X3-7276 - 2017-01-31 by CCC

                    # Should we be sending the translated text given that the PO user may have a different language?
                    Call LECTEXTRA_SYR(this,"WCRDESAXX", LTEXTE,"TABWRKCTR","WCRDESAXX",this.RESREP([L]LIN).RESGRPS([L]ILINE_GRPRES).WCR,"") From ATEXTRA
                    this.RESREP([L]LIN).RESGRPS([L]ILINE_GRPRES).WCRDESAXX = LTEXTE #[F:TWC]WCRDES
                    For [F:RES_]KEYPO(2)
                        # Add resource items to the collection
                        [L]ILINE_RES = fmet this.RESREP([L]LIN).ADDLINE("RESOURCES", [V]CST_ALASTPOS)
                        If [L]ILINE_RES <> [V]CST_ANOTDEFINED
                            this.RESREP([L]LIN).RESOURCES([L]ILINE_RES).WST      = [F:MWS]WST
                            this.RESREP([L]LIN).RESOURCES([L]ILINE_RES).WSTFCY   = this.FCY
                            Call LECTEXTRA_SYR(this,"WSTDESAXX", LTEXTE,"WORKSTATIO","WSTDESAXX",this.RESREP([L]LIN).RESOURCES([L]ILINE_RES).WST,this.RESREP(LIN).RESOURCES(ILINE_RES).WSTFCY) From
& ATEXTRA
                            this.RESREP([L]LIN).RESOURCES([L]ILINE_RES).WSTDES = LTEXTE#[F:MWS]WSTDES
                            this.RESREP([L]LIN).RESOURCES([L]ILINE_RES).WCR = [F:MWS]WCR
                            this.RESREP([L]LIN).RESOURCES([L]ILINE_RES).TWD = [F:MWS]TWD
                            this.RESREP([L]LIN).RESOURCES([L]ILINE_RES).CONSTRAINT = func POPSENV_CSTD.CONVERT_CONSTRAINT_TO_BEHAVIOUR([F:MWS]CONSTRAINT)
                            this.RESREP([L]LIN).RESOURCES([L]ILINE_RES).WSTNBR = [F:MWS]WSTNBR
                            this.RESREP([L]LIN).RESOURCES([L]ILINE_RES).URL = func POPSENV_CSTD.GET_RESOURCE_URL([F:MWS]WST, this.FCY)
                            [L]ASTATUS = func ADDOBJ(this.FCY, "MWS", [F:MWS]WST, "")    # Issue X3-7276 - 2017-01-31 by CCC
                            If LDELTAFLG
                                Filter [CPV] Where [F:CPV]UPDDATTIM>=[L]LREFDAT & [F:CPV]UPDDATTIM<=[L]LTIMENOW & [F:CPV]WST = [F:MWS]WST & [F:CPV]WCRFCY = [F:MWS]WCRFCY
                            Else
                                Filter [CPV] Where [F:CPV]WST = [F:MWS]WST & [F:CPV]WCRFCY = [F:MWS]WCRFCY
                            Endif

                            Local Char CODVARDES(GLONAX3)
                            For [F:CPV]
                                For [L]I = 0 To dim([F:CPV]CODVAR) - 1
                                    If [F:CPV]CODVAR([L]I) = ""
                                        Break
                                    Else
                                        [L]ILINE_CPV = fmet this.RESREP([L]LIN).RESOURCES([L]ILINE_RES).ADDLINE("CAPVARS", [V]CST_ALASTPOS)
                                        If [L]ILINE_CPV <> [V]CST_ANOTDEFINED
                                            this.RESREP([L]LIN).RESOURCES([L]ILINE_RES).CAPVARS([L]ILINE_CPV).STRDAT = [F:CPV]STRDAT([L]I)
                                            # Issue 121077 - 2017-01-20 by CCC : As PS is waiting for a date+time, add 1 to consider the end of the day of enddat
                                            this.RESREP([L]LIN).RESOURCES([L]ILINE_RES).CAPVARS([L]ILINE_CPV).ENDDAT = [F:CPV]ENDDAT([L]I)+1
                                            this.RESREP([L]LIN).RESOURCES([L]ILINE_RES).CAPVARS([L]ILINE_CPV).TWD = [F:CPV]TWD([L]I)
                                            Call LECTEXTRA_SYR(this,"LNGDES",CODVARDES, "ATABDIV", "LNGDES", "801",[F:CPV]CODVAR([L]I)) From ATEXTRA
                                            this.RESREP([L]LIN).RESOURCES([L]ILINE_RES).CAPVARS([L]ILINE_CPV).CODVAR = CODVARDES
                                        Endif
                                    Endif
                                Next
                            Next
                            Filter [F:CPV]
                            If [L]LDELTAFLG
                                Filter [CEP] Where [F:CEP]UPDDATTIM>=[L]LREFDAT & [F:CEP]UPDDATTIM<=[L]LTIMENOW & [F:CEP]WST = [F:MWS]WST & [F:CEP]WSTFCY = [F:MWS]WCRFCY
                            Else
                                Filter [CEP] Where [F:CEP]WST = [F:MWS]WST & [F:CEP]WSTFCY = [F:MWS]WCRFCY
                            Endif

                            For [F:CEP]
                                [L]ILINE_CEP = fmet this.RESREP([L]LIN).RESOURCES([L]ILINE_RES).ADDLINE("CALEXPS", [V]CST_ALASTPOS)
                                If [L]ILINE_CEP <> [V]CST_ANOTDEFINED
                                    this.RESREP([L]LIN).RESOURCES([L]ILINE_RES).CALEXPS([L]ILINE_CEP).STRDAT = [F:CEP]STRDAT
                                    this.RESREP([L]LIN).RESOURCES([L]ILINE_RES).CALEXPS([L]ILINE_CEP).ENDDAT = [F:CEP]ENDDAT
                                    this.RESREP([L]LIN).RESOURCES([L]ILINE_RES).CALEXPS([L]ILINE_CEP).OPENED = [F:CEP]OPENED
                                    this.RESREP([L]LIN).RESOURCES([L]ILINE_RES).CALEXPS([L]ILINE_CEP).COMMENT = [F:CEP]COMMENT
                                    this.RESREP([L]LIN).RESOURCES([L]ILINE_RES).CALEXPS([L]ILINE_CEP).EDITABLE = [F:CEP]EDITABLE
                                Endif
                            Next
                            Filter [F:CEP]
                        Else
                            Break 2
                        Endif
                    Next
                Else
                    Break
                Endif
                [L]RECCNT += 1
                [L]CURTAB = ""
                [L]CURKEY = ""
            Next
        Endif
    Endif

    If [L]CONTINUE = 1
        # If there hasn't been an error commit the transaction
        If [L]IFTRANSOPEN = 0
            [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Transaction committed")
            Commit
        Endif

        Gosub UPDATE_CONTINUATION
        Return
    Endif

    If [L]CURREP = "" | [L]CURREP = "WOREP"
        [L]CURREP = ""
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Create Works order repository")
        # Create work order repository
        [L]LIN = fmet this.ADDLINE("WOREP", [V]CST_ALASTPOS)
        If [L]LIN = [V]CST_ANOTDEFINED
            # There was an error so set error and return.
            [L]ERRMESS = mess(352,193,1)
            [L]ASTATUS = fmet this.ASETERROR("", [L]ERRMESS, [V]CST_AERROR)
            [L]ERRCOD = ([L]ASTATUS)
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Unable to create work order repository")
            [L]OK = func ENDLOG([L]LOGINUSE, POPSLOG)

            # There has been an error rollback the transaction
            If [L]IFTRANSOPEN = 0
                [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Transaction committed")
                Rollback
            Endif

            # Add an error repository
            Gosub ADD_ERROR

            FreeGroup TIMEZONE
            FreeGroup POPSLOG

            Return
        Endif

        # X3-40846 - STWIL - Update the custom fields in use
        Gosub UPDATE_CUSTOM_FIELDS

        # Only update custom field definitions if the custom value record has changed
        If LDELTAFLG = 0 | [L]CUSFLDUPD = 1
            For [PSCF]PSCF0 # From val([L]CURKEY) To 999999999
                [L]ILINE_CUSFLD = fmet this.WOREP([L]LIN).ADDLINE("CUSFLDS", [V]CST_ALASTPOS)
                If [L]ILINE_CUSFLD <> [V]CST_ANOTDEFINED
                    this.WOREP([L]LIN).CUSFLDS([L]ILINE_CUSFLD).ID = [F:PSCF]AUUID
                    If [F:PSCF]ENTTYP = "WO" & (WOCUSFLD1 = [F:PSCF]MESNUM | WOCUSFLD2 = [F:PSCF]MESNUM)
                        If WOCUSFLD1 = [F:PSCF]MESNUM
                            this.WOREP([L]LIN).CUSFLDS([L]ILINE_CUSFLD).FLDORD = 1
                        Else
                            this.WOREP([L]LIN).CUSFLDS([L]ILINE_CUSFLD).FLDORD = 2
                        Endif
                        this.WOREP([L]LIN).CUSFLDS([L]ILINE_CUSFLD).DELETED = 0
                    Elsif [F:PSCF]ENTTYP = "OP" & (OPCUSFLD1 = [F:PSCF]MESNUM | OPCUSFLD2 = [F:PSCF]MESNUM)
                        If OPCUSFLD1 = [F:PSCF]MESNUM
                            this.WOREP([L]LIN).CUSFLDS([L]ILINE_CUSFLD).FLDORD = 1
                        Else
                            this.WOREP([L]LIN).CUSFLDS([L]ILINE_CUSFLD).FLDORD = 2
                        Endif
                        this.WOREP([L]LIN).CUSFLDS([L]ILINE_CUSFLD).DELETED = 0
                    Else
                        this.WOREP([L]LIN).CUSFLDS([L]ILINE_CUSFLD).FLDORD = [F:PSCF]FLDORD
                        this.WOREP([L]LIN).CUSFLDS([L]ILINE_CUSFLD).DELETED = 1
                    Endif
                    this.WOREP([L]LIN).CUSFLDS([L]ILINE_CUSFLD).NAME = mess([F:PSCF]MESNUM, [F:PSCF]MENNUM, 1)
                    this.WOREP([L]LIN).CUSFLDS([L]ILINE_CUSFLD).FLDTYP = [F:PSCF]FLDTYP
                    this.WOREP([L]LIN).CUSFLDS([L]ILINE_CUSFLD).ENTITY = [F:PSCF]ENTTYP
                Endif
                # X3-58951 - STWIL - Don't blank continuation fields as custom fields are not included
                # in the data slicing.
                #[L]CURTAB = ""
                #[L]CURKEY = ""
            Next
        Endif

        # Issue X3-7276 - 2017-01-31 by CCC : Deletion management
        If [L]LDELTAFLG & ([L]CURTAB = "" | [L]CURTAB = "POPSOBJ-WO")
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Look for 'Deleted' WO objects MFG & WOS")
            If [L]MAXNORECS=0
                I=-1    # no limit
            Else
                I = [L]MAXNORECS-[L]RECCNT      # number of records that can still be inserted
            Endif
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "timestamp MFG & WOS av="+timestamp$)
            [L]ASTATUS = fmet this.WOREP([L]LIN).CHKDEL(this.FCY,[L]CURTAB,[L]CURKEY,I)
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "timestamp MFG & WOS ap="+timestamp$)
            If [L]MAXNORECS=0
                [L]RECCNT -= I+1    # Here I is negative
            Else
                [L]RECCNT = [L]MAXNORECS - I
            Endif
            If [L]CURTAB<>""
                [L]CONTINUE = 1
            Endif
            If [L]ASTATUS <> [V]CST_AOK # If there was an error during deletion of PSOBJ record, it's not serious => log and continue
                [L]ERRMES = mess(81,125,1)-"POPSOBJ-WO"
                [L]ASTATUS = fmet this.ASETERROR("", [L]ERRMESS, [V]CST_AERROR)
                [L]ERRCOD = num$(ASTATUS)
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, [L]ERRMESS)
                [L]OK = func ENDLOG([L]LOGINUSE, POPSLOG)
            Endif
        Endif

        # Send any tags that have been setup, but only if this is an initial load
        If [L]LDELTAFLG = 0 & ([L]CURTAB = "" | [L]CURTAB = "POPSTAG")
            For [TAG] From [L]CURKEY To "~"
                If [L]MAXNORECS > 0 & [L]RECCNT + 1 > [L]MAXNORECS
                    [L]CURKEY = [F:TAG]TAGID
                    [L]CURTAB = "POPSTAG"
                    [L]CONTINUE = 1
                    Break
                Endif
                [L]ILINE_TAG = fmet this.WOREP([L]LIN).ADDLINE("TAGS", [V]CST_ALASTPOS)
                If [L]ILINE_TAG <> [V]CST_ANOTDEFINED
                    this.WOREP([L]LIN).TAGS([L]ILINE_TAG).TAGID = [F:TAG]TAGID
                    this.WOREP([L]LIN).TAGS([L]ILINE_TAG).DELETED = [F:TAG]DELETED
                    this.WOREP([L]LIN).TAGS([L]ILINE_TAG).TAGICON = [F:TAG]TAGICON
                    this.WOREP([L]LIN).TAGS([L]ILINE_TAG).TAGORD = [F:TAG]TAGORD
                Endif
                [L]RECCNT += 1
                [L]CURTAB = ""
                [L]CURKEY = ""
            Next
        Endif

        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Read MFGITM records ")

        # Move the work order reads into separate sub routines so that they can
        # be worked on independently.

        Gosub UNLINKEDTABLES

        # Need to remove custom fields class instances
        If POPSCUSFLDS <> null
            FreeGroup POPSCUSFLDS
        Endif

        If [L]ERRMESS <> ""
            If [L]IFTRANSOPEN = 0
                [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Transaction rolled back")
                Rollback
            Endif
            [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Stop processing")
            [L]OK = func ENDLOG([L]LOGINUSE, POPSLOG)

            FreeGroup TIMEZONE
            FreeGroup POPSLOG

            Return
        Endif

        # Do work order links
        If [L]CURTAB = ""
            # Link assignments to work order header
            Link [MLK] With
&               [MFG]MFG0~=[MLK]RESSNUM
&               As [MLK_]
            # Filter out records of the wrong type and update time if passed and those work order not in PS
            If [L]LDELTAFLG
                Filter [MLK_] Where STOFCY=this.FCY & DWIPTYP = 6 & RESSTYP = 10 &
&                              ([MFG]OPTFLG = 2 | [MFG]SCDFLG = 4) &
&                              UPDDATTIM > [L]LREFDAT & UPDDATTIM <= [L]LTIMENOW Order By Key MLK1
            Else
                Filter [MLK_] Where STOFCY=this.FCY & DWIPTYP = 6 & RESSTYP = 10 &
&                              ([MFG]OPTFLG = 2 | [MFG]SCDFLG = 4)
&                 Order By Key MLK1
            Endif

            [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Start processing WO links")
            For [MLK_]
                # Have a child work order, look for parent
                Read [MFG]MFG0 = [F:MLK]DEMNUM
                If fstat = [V]CST_AOK & ([MFG]OPTFLG = 2 | [MFG]SCDFLG = 4)
                    Gosub UPDATE_WO_LINK
                Endif
            Next
            Filter [MLK_]

            If [L]LDELTAFLG = 1
                [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Start processing WO links for new work orders")
                # Check all work orders being sent to Production Scheduler in case they have assignments
                For I = 1 To [L]ILINE_WO
                    If this.WOREP([L]LIN).WRKORDS(I).DELETED = 0
                        [L]OK = func POPSENVUPD_CSTD.SPLIT_WO_KEY(this.WOREP([L]LIN).WRKORDS(I).MFGNUM, [L]MFGNUM, [L]ITMREF)
                        Filter [MLK] Where STOFCY=this.FCY & DWIPTYP = 6 & RESSTYP = 10 &
&                                       (RESSNUM = [L]MFGNUM | DEMNUM = [L]MFGNUM)
&                       Order By Key MLK1
                        [L]LINK_FOUND = 0
                        For [MLK]
                            [L]LINK_EXISTS = func FIND_WO_LINK_EXISTS([F:MLK]RESSNUM, [F:MLK]DEMNUM, this.WOREP([L]LIN).WOLNKS)
                            # Link doesn't already exist send it
                            If [L]LINK_EXISTS = 0
                                [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Found assignment for new work order")
                                Gosub UPDATE_WO_LINK
                            Endif
                        Next
                        Filter [MLK]
                    Endif
                Next I
            Endif
        Endif

# Issue X3-7276.s - 2017-02-01 by CCC
#        # Check if any work orders have status changes and report them as deleted
#        If [L]LDELTAFLG & ([L]CURTAB = "" | [L]CURTAB = "WRKORDS-D")
#            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Read 'Deleted' wo records ")
#            For [MFG] From [L]CURKEY To "~" Where MFGFCY = this.FCY & UPDDATTIM > [L]LREFDAT & [F:MFG]UPDDATTIM<=[L]LTIMENOW & ((OPTFLG = 1 & SCDFLG <> 4) | MFGSTA = 4)
#                If [L]MAXNORECS > 0 & [L]RECCNT + 1 > [L]MAXNORECS
#                    [L]CURKEY = [F:MFG]MFGNUM
#                    [L]CURTAB = "WRKORDS-D"
#                    [L]CONTINUE = 1
#                    Break
#                Endif
#                [L]ILINE_WO = fmet this.WOREP([L]LIN).ADDLINE("WRKORDS", [V]CST_ALASTPOS)
#                If [L]ILINE_WO <> [V]CST_ANOTDEFINED
#                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).MFGNUM   = [F:MFG]MFGNUM
#                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).DELETED = 1
#                Endif
#                [L]RECCNT += 1
#                [L]CURTAB = ""
#                [L]CURKEY = ""
#            Next
#        Endif
# Issue X3-7276.e - 2017-02-01 by CCC

#        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Read held wo records ")
#        # Check if any work orders have been 'held' and report them as deleted
#        If [L]LDELTAFLG & ([L]CURTAB = "" | [L]CURTAB = "WRKORDS-H")
#            For [MFG] From [L]CURKEY To "~" Where MFGFCY = this.FCY & UPDDATTIM > [L]LREFDAT & [F:MFG]UPDDATTIM<=[L]LTIMENOW & OPTFLG = 2 & SUSFLG = 2
#                If [L]MAXNORECS > 0 & [L]RECCNT + 1 > [L]MAXNORECS
#                    [L]CURKEY = [F:MFG]MFGNUM
#                    [L]CURTAB = "WRKORDS-H"
#                    [L]CONTINUE = 1
#                    Break
#                Endif
#                [L]ILINE_WO = fmet this.WOREP([L]LIN).ADDLINE("WRKORDS", [V]CST_ALASTPOS)
#                If [L]ILINE_WO <> [V]CST_ANOTDEFINED
#                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).MFGNUM   = [F:MFG]MFGNUM
#                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).DELETED = 1
#                Endif
#                [L]RECCNT += 1
#                [L]CURTAB = ""
#                [L]CURKEY = ""
#            Next
#        Endif
    Endif

    # If there hasn't been an error commit the transaction
    If [L]IFTRANSOPEN = 0
        [L]OK = func OUTPUTLOGMSG([L]LOGINUSE, POPSLOG, "Transaction committed")
        Commit
    Endif

    If [L]CONTINUE = 1
        # This is called from lots of places and closes the Log file.
        # Don't need to close it again.
        Gosub UPDATE_CONTINUATION
    Else
        this.MAXREC = ""
        this.CURTAB = ""
        this.CURKEY = ""
        this.ENDTIMSTP = ""
        this.TIMESTAMP = num$([L]LTIMENOW)

        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "End of processing")
        [L]OK = func ENDLOG([L]LOGINUSE, POPSLOG)
    Endif

    FreeGroup TIMEZONE
    FreeGroup POPSLOG

Return

$UNLINKEDTABLES
    Local Integer FSTREC
    Local Char PREVOP(75)
    Local Char NEXTOP(75)
    Local Char MTOLINKKEY1(75)
    Local Char MTOLINKKEY2(75)

    Local Integer BETWEENOP
    Local Char SCDCOD(2)

    Local Integer MFGSTA
    Local Integer ILINE_WO
    Local Integer ILINE_OP
    Local Integer ILINE_US
    Local Integer ILINE_TL
    Local Integer ILINE_LN
    Local Integer ILINE_MK
    Local Integer WSTNBR
    Local Integer TIMUOMCOD
    Local Integer UPDERR : UPDERR = 0
    Local Integer KEYSPLIT
    Local Integer ORDTYP
    Local Integer SCOCOD

    Local Char STATEXT(30)
    Local Char FIXDAT(30)
    Local Char OPESTARTTIME(10)
    Local Char OPEENDTIME(10)
    Local Char OPESTRDAT(10)
    Local Char OPEENDDAT(10)
    Local Char EXTWST(GLONWST)
    Local Char FSTWST(GLONWST)
    Local Char LSTWST(GLONWST)
    Local Char SHIFTSTA(10)
    Local Char SHIFTEND(10)
    Local Char SCOWST(GLONWST)
    Local Char LASTWO(GLONVCR)

    Local Date STRDAT
    Local Date ROUSTRDAT
    Local Date BOMSTRDAT
    Local Date ENDDAT
    Local Date ROUENDDAT
    Local Date BOMENDDAT
    Local Date LSTOPEDAT

    Local Decimal SCOLTI
    Local Decimal SETTIM
    Local Decimal OPETIM
    Local Decimal PRPTIM
    Local Decimal PSPTIM
    Local Decimal WAITIM
    Local Decimal EFFIC
    Local Decimal EXCOPETIM
    Local Decimal STDOPETIM
    Local Datetime LSTOPETIM
    Local Datetime CUROPETIM

    # X3-32098 - STWIL - Add the FDMA class and material fix date.
    Local Instance FDMA Using C_MFGFDMA
    Local Datetime MATFIXDAT
    Local Integer MATFIX
    Local Char FDMATIM(10)

    # X3-57679 - STWIL - We should always use the start of the day for FDMA start time.
#    # X3-32098 - STWIL - Calculate daily start time using DEFDIH parameter for use with FDMA
#    Read [DIH]DIH0 = [L]LCURDEFDIH
#    If fstat = 0
#        If instr(1, [F:DIH]STRHOU(0), ":") = 0
#            [L]FDMATIM = left$([F:DIH]STRHOU(0), 2) + ":" + right$([F:DIH]STRHOU(0), 3) + ":00"
#        Else
#            [L]FDMATIM = [F:DIH]STRHOU(0) + ":00"
#        Endif
#    Else
        [L]FDMATIM = "00:00:00"
#    Endif

    If ([L]CURTAB = "" | [L]CURTAB = "WRKORDS")

        # X3-60591 - STWIL - Keep track of the current work order so we can exclude other
        #                       by products and semi-finished products
        [L]LASTWO = ""

        # Join work order items with item master and work order header
        Link [MFI] With
&          [ITM]ITM0=[MFI]ITMREF,
&          [MFG]MFG0=[MFI]MFGNUM
&       As [WOR_]

        # Filter out records at the wrong status and update time if passed
        # Need to do it on MFI and MFG
        If [L]LDELTAFLG
            Filter [WOR_] Where MFGFCY=this.FCY & MFGSTA < 4 &
&                              ([MFG]OPTFLG = 2 | [MFG]SCDFLG = 4) &
&                              (([MFI]UPDDATTIM > [L]LREFDAT & [MFI]UPDDATTIM <= [L]LTIMENOW) |
&                              ([MFG]UPDDATTIM > [L]LREFDAT & [MFG]UPDDATTIM <= [L]LTIMENOW))
        Else
            Filter [WOR_] Where MFGFCY=this.FCY & MFGSTA < 4 & ([MFG]OPTFLG = 2 | [MFG]SCDFLG = 4)
        Endif

        For [F:WOR_] From [L]CURKEY To "~"
            # X3-60591 - STWIL - Have we already processed this work order?
            #                       if not process this work order.
            If [F:MFI]MFGNUM <> [L]LASTWO
                [L]LASTWO = [F:MFI]MFGNUM

                If [L]MAXNORECS > 0 & [L]RECCNT + 1 > [L]MAXNORECS
                    [L]CURKEY = [F:MFI]MFGNUM#+num$([F:MFI]MFGLIN)
                    [L]CURTAB = "WRKORDS"
                    [L]CONTINUE = 1
                    Break
                Endif
                # Add work order items to collection
                [L]ILINE_WO = fmet this.WOREP([L]LIN).ADDLINE("WRKORDS", [V]CST_ALASTPOS)
                If [L]ILINE_WO <> [V]CST_ANOTDEFINED
                    #[L]OK = len(this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).MFGNUM)
                    #[L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Work order number length "+num$([L]OK))
                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).MFGNUM   = func FORMAT_WO_KEY ([F:MFI]MFGNUM, [F:MFI]ITMREF)
                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).MFGSTA = mess([F:MFI]MFGSTA, 317, 1)
                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).RMNEXTQTY = [F:MFI]RMNEXTQTY
                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).DELETED = 0
                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).MFGPIO = [F:MFI]MFGPIO
                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).BPCNUM = [F:MFI]BPCNUM
                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).ITMREF = [F:MFI]ITMREF
                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).ITMDES1 = [F:ITM]ITMDES1
                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).WODES = [F:MFI]MFGDES
                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).URL = func POPSENV_CSTD.GET_WORKORDER_URL([F:MFI]MFGNUM)
                    # Include major and minor number if on the product <product> VERS MAJ MIN
                    If [F:MFI]ECCVALMAJ <> "" | [F:MFI]ECCVALMIN <> ""
                        this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).ITMVAR = "Vers" - [F:MFI]ECCVALMAJ - [F:MFI]ECCVALMIN
                    Endif

                    # X3-22333 - STWIL - Need to add ITMREF as we now used this as the key sent to Production Scheduler
                    [L]ASTATUS = func ADDOBJ(this.FCY, "MFG", [F:MFI]MFGNUM, [F:MFI]ITMREF)    # Issue X3-7276 - 2017-01-31 by CCC

                    # X3-19099 - STWIL - Reset local variable for WO Due date
                    [L]LSTOPEDAT = [0/0/0]
                    [L]LSTOPETIM = 0

                    # X3-40846 - STWIL - Send any custom fields that have been setup
                    Gosub UPDATE_WO_CUSTOM_INFO

                    # X3-32098 - STWIL - Initialize the FDMA class
                    FDMA = NewInstance C_MFGFDMA AllocGroup null
                    # Issue X3-65500 - 2017-11-23 by ALSHE : Calculate FDMA for all components at once - [F:MFI]MFGLI not regarded in calculation
                    [L]OK = fmet FDMA.INITIALIZE([F:MFI]MFGNUM, [F:MFI]MFGLIN, [F:MFI]MFGFCY, [L]FDMATIM)
                    #[L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Read MFGOPE records ")
                    # Issue 29698 - 2017-04-10 by CCC : add OPESPLNUM in key PIN0
                    Link [MFO] With
&                       [SCH]SCH0=[F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM,
&                       [OPS]OPS1=[F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM,
&                       [PIN]PIN0=[F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM
&                   As [MFO_]

                    # X3-46461 - STWIL - Reset the first operation resource
                    [L]FSTWST = ""
                    # X3-74477 - STWIL - Also reset the last operation resource
                    [L]LSTWST = ""
                    Filter [F:MFO_] Where MFGNUM=[F:MFI]MFGNUM & OPESTA<>6
                    For [F:MFO_]#KEYOP(1)
                        # Loop on operation
                        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Work order operation "+[F:MFO]MFGNUM-num$([F:MFO]OPENUM))
                        [L]ILINE_OP = fmet this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).ADDLINE("OPERS", [V]CST_ALASTPOS)
                        If [L]ILINE_OP <> [V]CST_ANOTDEFINED
                            this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).MFGNUM = func FORMAT_WO_KEY ([F:MFI]MFGNUM, [F:MFI]ITMREF)
                            this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).OPENUM = func FORMAT_OP_KEY ([F:MFI]MFGNUM, [F:MFI]ITMREF, [F:MFO]OPENUM, [F:MFO]OPESPLNUM)
                            this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).ROODES = [F:MFO]ROODES

                            # Issue X3-29698 - 2017-04-06 by CCC : determine the pin to send
                            If [F:MFO]OPESPLNUM > 0
                                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).PINTYP = 4
                            Else
                                If [F:MFO]FRCSTRDAT <> AVOID.ADATE & !find([F:PIN]PINTYP,1,2)
                                    # Set by default "Reserved resource" if a forced date exists in the WO
                                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).PINTYP = 3
                                Else
                                    # if pintyp=3 or 4, it's not normal => send 0
                                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).PINTYP = find([F:PIN]PINTYP,1,2)
                                Endif
                            Endif
                            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "=> Pintyp="+num$(this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).PINTYP))

                            # Only send the operation resource if the WO has been published or the operation is in progress
                            If [F:MFG]SCDFLG = 4 | [F:MFO]OPESTA > 3
&                           | this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).PINTYP>0  # Issue X3-29698 - 2017-04-06 by CCC : the resourceId is mandatory if a pin has been set
                                If [F:MFO]CPLWST = ""
                                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).CPLWST = [F:MFO]EXTWST
                                Else
                                    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).CPLWST = [F:MFO]CPLWST
                                Endif
                            Else
                                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).CPLWST = ""
                            Endif
                            this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).OPESTA = func POPSENV_CSTD.CONVERT_X3_TO_PO_STATUS([F:MFO]OPESTA)
                            this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).EXTQTY = [F:MFO]EXTQTY
                            this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).REMQTY = max([F:MFO]EXTQTY-[F:MFO]CPLQTY+[F:MFO]REJCPLQTY, 0)
                            # Issue X3-29698 - 2017-04-10 by CCC : Set PINTYP before CPLWST
                            #If [F:MFO]OPESPLNUM > 0
                            #    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).PINTYP = 4
                            #Else
                            #    this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).PINTYP = [F:PIN]PINTYP
                            #Endif
                            this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).WSTFCY = this.FCY
                            If [F:MFO]OPESTA = 5 | [F:MFO]OPESTA = 4
                                [L]OPESTARTTIME = "00:00:00"
                                [L]OPEENDTIME = "00:00:00" #func POPSENV_CSTD.CONVERT_RUNTIME_TO_ENDTIME([F:MFO]CPLOPETIM)
                                [L]OPESTRDAT = right$(num$([F:MFO]OPESTR), 7) + "-" + mid$(num$([F:MFO]OPESTR), 4, 2) + "-" + left$(num$([F:MFO]OPESTR), 2)
                                [L]OPEENDDAT = right$(num$([F:MFO]OPEEND), 7) + "-" + mid$(num$([F:MFO]OPEEND), 4, 2) + "-" + left$(num$([F:MFO]OPEEND), 2)
                            Else
                                Call OPETIME ([L]LCURDEFDIH, [L]FCY, [F:MFO]EXTWST, [F:MFO]OPESTR, [F:SCH]OPESTRFRD, [L]OPESTARTTIME) From JALLIBB_SYRA
                                [L]OPESTARTTIME = left$([L]OPESTARTTIME,2) + ":" +right$([L]OPESTARTTIME,3)+ ":00Z"
                                Call OPETIME ([L]LCURDEFDIH, [L]FCY, [F:MFO]EXTWST, [F:MFO]OPEEND, [F:SCH]OPEENDFRD, [L]OPEENDTIME) From JALLIBB_SYRA
                                [L]OPEENDTIME = left$([L]OPEENDTIME,2) + ":" +right$([L]OPEENDTIME,3)+ ":00Z"
                                [L]OPESTRDAT = right$(num$([F:SCH]OPESTRDAT), 7) + "-" + mid$(num$([F:SCH]OPESTRDAT), 4, 2) + "-" + left$(num$([F:SCH]OPESTRDAT), 2)
                                [L]OPEENDDAT = right$(num$([F:SCH]OPEENDDAT), 7) + "-" + mid$(num$([F:SCH]OPEENDDAT), 4, 2) + "-" + left$(num$([F:SCH]OPEENDDAT), 2)
                            Endif

                            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Work order operation start datetime"+num$([L]OPESTRDAT)+[L]OPESTARTTIME)
                            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Work order operation end datetime"+num$([L]OPEENDDAT)+[L]OPEENDTIME)
                            # X3-29632 - STWIL - Use timezone class to convert local times to UTC
                            ASTATUS = fmet TIMEZONE.TO_UNIVERSAL_TIME(gdatetime$(num$([L]OPESTRDAT) + "T" + [L]OPESTARTTIME + "Z"), this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).STRDATTIM
& )
                            ASTATUS = fmet TIMEZONE.TO_UNIVERSAL_TIME(gdatetime$(num$([L]OPEENDDAT) + "T" + [L]OPEENDTIME + "Z"), this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).ENDDATTIM)
                            #this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).STRDATTIM = gdatetime$(num$([L]OPESTRDAT) + "T" + [L]OPESTARTTIME + "Z")
                            #this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).ENDDATTIM = gdatetime$(num$([L]OPEENDDAT) + "T" + [L]OPEENDTIME + "Z")

                            If ([F:MFO]FRCSTRDAT <> AVOID.ADATE)
                                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Fixed start date"+num$([F:MFO]FRCSTRDAT))
                                [L]FIXDAT = right$(num$([F:MFO]FRCSTRDAT), 7) + "-" + mid$(num$([F:MFO]FRCSTRDAT), 4, 2) + "-" + left$(num$([F:MFO]FRCSTRDAT), 2) + "T"
                                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Fixed start date"+num$([L]FIXDAT))
                                If ([F:MFO]FRCSTRHOU = "")
                                    Append [L]FIXDAT, "00:00:00Z"
                                Else
                                    Append [L]FIXDAT, left$([F:MFO]FRCSTRHOU, 2)+":"+right$([F:MFO]FRCSTRHOU, 3)+":00Z"
                                Endif
                                # X3-29632 - STWIL - Use timezone class to convert local times to UTC
                                ASTATUS = fmet TIMEZONE.TO_UNIVERSAL_TIME(gdatetime$([L]FIXDAT), this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).FIXDAT)
                                #this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).FIXDAT = gdatetime$([L]FIXDAT)
                                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).FIXED = 1
                            # Fix the start date for ordered sub-contract operations
                            Elsif [F:MFO]OPESTA = 7
                                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).FIXDAT = this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).STRDATTIM
                                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).FIXED = 1
                            Else
                                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).FIXED = 0
                            Endif

                            [L]REMQTY = max([F:MFO]EXTQTY-[F:MFO]CPLQTY+[F:MFO]REJCPLQTY, 0)
                            [L]ROUALT = [F:SCH]ROUALT
                            [L]ITMREF = [F:MFI]ITMREF
                            [L]OPENUM = [F:MFO]OPENUM
                            [L]MFGNUM = [F:MFI]MFGNUM
                            # X3-47988 - STWIL - Need to set the sub-contract variables
                            [L]SCOCOD = [F:MFO]SCOCOD
                            [L]SCOWST = [F:MFO]SCOWST
                            [L]SCOLTI = [F:MFO]SCOLTI
                            If [F:MFO]OPESTA = 5 | [F:MFO]OPESTA = 4
                                [L]EXTWST = [F:MFO]CPLWST
                                [L]WSTNBR = [F:MFO]CPLWSTNBR
                                # Don't send setup time for 'in progress' or 'completed' operations
                                [L]SETTIM = 0
                                # Always send expected run time
                                [L]OPETIM = [F:MFO]EXTOPETIM
                                [L]PRPTIM = [F:MFO]PRPTIM
                                [L]TIMUOMCOD = [F:MFO]TIMUOMCOD
                                # Wait time and post-op time are always in hours.
                                [L]WAITIM = func POPSENV_CSTD.CONVERT_TIME_TO_SECS([F:MFO]WAITIM, 1)
                                [L]PSPTIM = func POPSENV_CSTD.CONVERT_TIME_TO_SECS([F:MFO]PSPTIM, 1)
                            Else
                                # Update whether this operation has been published or forced
                                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).SEQORD = [F:OPS]SEQORD
                                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).FORPLA = [F:OPS]FORPLA

                                [L]EXTWST = [F:OPS]EXTWST
                                [L]WSTNBR = [F:OPS]EXTWSTNBR
                                # Always send expected run time and setup time
                                [L]SETTIM = [F:OPS]EXTSETTIM
                                [L]OPETIM = [F:OPS]EXTOPETIM
                                [L]PRPTIM = [F:OPS]PRPTIM
                                [L]TIMUOMCOD = [F:OPS]TIMUOMCOD
                                # Wait time and post-op time are always in hours.
                                [L]WAITIM = func POPSENV_CSTD.CONVERT_TIME_TO_SECS([F:OPS]WAITIM, 1)
                                [L]PSPTIM = func POPSENV_CSTD.CONVERT_TIME_TO_SECS([F:OPS]PSPTIM, 1)
                            Endif

                            # X3-46461 - STWIL - Save the first operation resource
                            If [L]FSTWST = ""
                                [L]FSTWST = [L]EXTWST
                            Endif

                            # X3-47988 - STWIL - Start - Set the correct runtimes for sub-contract operations
                            # We need to find the efficiency of the resource and determine to standard
                            # runtime so we can adjust based on replacement resource efficiency
                            [L]EFFIC = func GETRESOURCEEFFIC ([L]EXTWST, this.FCY)
                            If [L]EFFIC <> 100
                                [L]STDOPETIM = [L]OPETIM * ([L]EFFIC / 100)
                            Else
                                [L]STDOPETIM = [L]OPETIM
                            Endif

                            # If we have an un-ordered sub-contract operation make the runtime the lead time
                            If [F:MFO]SCOCOD = 2
                                If [F:MFO]SCOLTI > 0
                                    [L]OPETIM = [F:MFO]SCOLTI * 24
                                Else
                                    [L]OPETIM = 24
                                Endif
                                # if run time is in minutes multiple hours by 60
                                If [L]TIMUOMCOD = 2
                                    [L]OPETIM = [L]TIMUOMCOD * 60
                                Endif
                            # Operation is sub-contract by exception need to save runtime, resource
                            Elsif [F:MFO]SCOCOD = 3
                                If [F:MFO]SCOLTI > 0
                                    [L]EXCOPETIM = [F:MFO]SCOLTI * 24
                                    # if run time is in minutes multiple hours by 60
                                    If [L]TIMUOMCOD = 2
                                        [L]EXCOPETIM = [L]TIMUOMCOD * 60
                                    Endif
                                Else
                                    [L]EXCOPETIM = 24
                                Endif
                            Endif
                            # X3-47988 - STWIL - End - Set the correct runtimes for sub-contract operations

                            # X3-32098 - STWIL - Add the FDMA (First date of material availability) to the operation.
                            [L]OK = fmet FDMA.GETFDMA([L]OPENUM, [L]MATFIXDAT, [L]MATFIX)
                            If [L]MATFIX = 1
                                ASTATUS = fmet TIMEZONE.TO_UNIVERSAL_TIME(gdatetime$([L]MATFIXDAT), this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).MATFIXDAT)
                            Endif
                            this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).MATFIX = [L]MATFIX

                            # If we have part completed an operation but overrun the expected time
                            # we need to calculate the remaining time, rather than 0.
                            #If [L]REMQTY > 0 & [L]OPETIM = 0
                            #    [L]OPETIM = ([F:MFO]EXTOPETIM / [F:MFO]EXTQTY) * [L]REMQTY
                            #Endif

                            # X3-40846 - STWIL - Send any custom fields that have been setup
                            Gosub UPDATE_OP_CUSTOM_INFO

                            # Send any markers that have been added to this operation.
                            #[L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Before Read WO Marker records ")
                            Gosub UPDATE_MARKER_INFO

                            # Update usable resources
                            Gosub UPDATE_ROUTE_INFO

                            # X3-19099 - STWIL - Determine the latest operation end date/time
                            # The sub routine sets LSTWST
                            Gosub DETERMINE_LAST_RESOURCE

                        Endif
                    Next

                    # Free FDMA class
                    FreeGroup FDMA

                    #[L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Work out wo limits records ")
                    # Work out the earliest start date and latest end date
                    Gosub EARLIESTSTARTDATE
                    #[L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Got earliest start date ")
                    Gosub LATESTENDDATE
                    #[L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Got latest end date ")

                    # X3 - 74477 - STWIL - Check if LSTWST is not set if all operations closed,
                    # if it is not, set it to FSTWST
                    If [L]LSTWST = ""
                        [L]LSTWST = [L]FSTWST
                    Endif
                    # X3 - 46461 - STWIL - Set start time to start of standard shift
                    Call OPETIME ([L]LCURDEFDIH, [L]FCY, [L]FSTWST, [L]STRDAT, 0, [L]SHIFTSTA) From JALLIBB_SYRA
                    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Shift start parameters -" - num$([L]STRDAT) - [L]LSTWST - this.FCY - [L]LCURDEFDIH - [L]SHIFTSTA)
                    # Set the work order start date - convert to UTC.
                    ASTATUS = fmet TIMEZONE.TO_UNIVERSAL_TIME(gdatetime$(right$(num$([L]STRDAT), 7) + "-" + mid$(num$([L]STRDAT), 4, 2) + "-" + left$(num$([L]STRDAT), 2) + "T" + left$([L]SHIFTSTA,2) +
& ":" +right$([L]SHIFTSTA,3) + ":00Z"), this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).STRDAT)

                    # We have the last operation for this work order work out the end of shift for this resource
                    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Shift end parameters -" - num$([F:MFG]OBJDAT) - [L]LSTWST - this.FCY - [L]LCURDEFDIH)
                    # Get the end of shift time using OPETIME with 1 as the fraction
                    Call OPETIME ([L]LCURDEFDIH, [L]FCY, [L]LSTWST, [F:MFG]OBJDAT, 1, [L]SHIFTEND) From JALLIBB_SYRA
                    If right$([L]SHIFTEND,3) = "59"
                        [L]SHIFTEND = left$([L]SHIFTEND,2) + ":" +right$([L]SHIFTEND,3)+ ":59"
                    Else
                        [L]SHIFTEND = left$([L]SHIFTEND,2) + ":" +right$([L]SHIFTEND,3)+ ":00"
                    Endif

                    # X3-19099 Use the initial objective date as the work order due date
                    # X3-29632 - STWIL - Use timezone class to convert local times to UTC
                    ASTATUS = fmet TIMEZONE.TO_UNIVERSAL_TIME(gdatetime$(right$(num$([F:MFG]OBJDAT), 7) + "-" + mid$(num$([F:MFG]OBJDAT), 4, 2) + "-" + left$(num$([F:MFG]OBJDAT), 2)+"T"+[L]SHIFTEND+
& "Z"), this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).ENDDAT)
                    #this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).ENDDAT = gdatetime$(right$(num$([F:MFG]OBJDAT), 7) + "-" + mid$(num$([F:MFG]OBJDAT), 4, 2) + "-" + left$(num$([F:MFG]OBJDAT), 2)+"T"+[L]
#& SHIFTEND +"Z")
                    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "WO due date -" - right$(num$([F:MFG]OBJDAT), 7) + "-" + mid$(num$([F:MFG]OBJDAT), 4, 2) + "-" + left$(num$([F:MFG]OBJDAT), 2)+"T"+
& [L]
& SHIFTEND+"Z")

                    # Update the following dates on the WO.
                    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "WO dates" - num$(this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).STRDAT) - num$(this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).ENDDAT))

                    # Need to update works order with new dates
                    [L]ASTATUS = func POPSENV_CSTD.UPDATEWOWITHNEWDATES(this.WOREP([L]LIN).WRKORDS([L]ILINE_WO), [L]STRDAT, [L]ENDDAT, [L]MESSAGE, this.ACTX.USER)
                    If [L]ASTATUS <> [V]CST_AOK
                        [L]ERRCOD = num$([L]ASTATUS)
                        [L]ERRMESS = mess(362,193,1)
                        [L]ASTATUS = fmet this.ASETERROR("", [L]ERRMESS, [V]CST_AERROR)
                        # X3-22333 - STWIL - Now need to split the work order number from itmref
                        [L]OK = func POPSENVUPD_CSTD.SPLIT_WO_KEY(this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).MFGNUM, [L]MFGNUM, [L]ITMREF)
                        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Unable to update work order dates" - this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).MFGNUM)
                        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Unable to update work order dates" - [L]MFGNUM)
                        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Error" - [L]MESSAGE)
                        [L]OK = func ENDLOG([L]LOGINUSE, POPSLOG)

                        # Add an error repository
                        Gosub ADD_ERROR
                        UPDERR = 1
                        Break
                    Endif
                    #[L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Before Read WO Operation links")
                    [L]ORDTYP = 1
                    Gosub UPDATE_OPERATION_LINKS_INFO

                Endif
                [L]RECCNT += 1
                [L]CURTAB = ""
                [L]CURKEY = ""
            Endif
        Next
        If UPDERR > 0
            Return
        Endif
    Endif

    If ([L]CURTAB = "" | [L]CURTAB = "ORDERS")
        # Now add any suggestions to the work order collection
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Read Suggestions records ")

        Link [ORD] With
&          [ITM]ITM0=[ORD]ITMREF
&       As [ORD_]

        # Filter out records at the wrong status and update time if passed
        If [L]LDELTAFLG
            Filter [ORD_] Where ORIFCY=this.FCY & WIPSTA = 3 & WIPTYP = 5 & OPTFLG = 2 & UPDDATTIM > [L]LREFDAT & [F:ORD]UPDDATTIM<=[L]LTIMENOW
        Else
            Filter [ORD_] Where ORIFCY=this.FCY & WIPSTA = 3 & WIPTYP = 5 & OPTFLG = 2
        Endif

        If [L]CURKEY = ""
            [L]MFGNUM = ""
            [L]ITMREF = ""
        Else
            [L]KEYSPLIT = instr(1, [L]CURKEY, ":")
            #Issue X3-97145 by GEBIL 17/07/2018 : Work order suggestions not transferred to PS
            [L]MFGNUM = left$([L]CURKEY, [L]KEYSPLIT  - 1)
            [L]ITMREF = right$([L]CURKEY, [L]KEYSPLIT + 1)
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Read Suggestions records curkey="+[L]CURKEY)
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Read Suggestions records split key="+[L]MFGNUM+"~"+[L]ITMREF)
        Endif
        For [ORD_] From 5;[L]MFGNUM;[L]ITMREF To 5;"~"
            If [L]MAXNORECS > 0 & [L]RECCNT + 1 > [L]MAXNORECS
                [L]CURKEY = [F:ORD]WIPNUM+":"+[F:ORD]ITMREF
                [L]CURTAB = "ORDERS"
                [L]CONTINUE = 1
                Break
            Endif
            # Add work order items to collection
            [L]ILINE_WO = fmet this.WOREP([L]LIN).ADDLINE("WRKORDS", [V]CST_ALASTPOS)
            If [L]ILINE_WO <> [V]CST_ANOTDEFINED
                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).MFGNUM   = func FORMAT_WO_KEY ([F:ORD]WIPNUM, [F:ORD]ITMREF)
                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).MFGSTA = mess([F:ORD]WIPSTA, 317, 1)
                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).RMNEXTQTY = [F:ORD]RMNEXTQTY
                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).DELETED = 0
                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).MFGPIO = [F:ORD]PIO
                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).BPCNUM = [F:ORD]BPRNUM
                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).ITMREF = [F:ORD]ITMREF
                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).ITMDES1 = [F:ITM]ITMDES1
                # Include major and minor number if on the product <product> VERS MAJ MIN
                this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).ITMVAR = "Vers" - [F:ORD]ECCVALMAJ - [F:ORD]ECCVALMIN

                [L]ASTATUS = func ADDOBJ(this.FCY, "WOS", [F:ORD]WIPNUM, [F:ORD]ITMREF)    # Issue X3-7276 - 2017-01-31 by CCC

                #[L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Write Suggestions to POPSWOS table ")

                # Need to set the start date of the suggestion
                [L]STRDAT = [F:ORD]STRDAT

                #[L]ASTATUS = func POPSENV_CSTD.WRITESUGGESTION ([L]LOGINUSE, POPSLOG, [F:ORD]ORIFCY, [F:ORD]WIPNUM, [F:ORD]ITMREF, [L]MESSAGE)
                If [L]ASTATUS <> [V]CST_AOK
                    [L]ERRMESS = mess(380,193,1)
                    [L]ASTATUS = fmet this.ASETERROR("", [L]ERRMESS, [V]CST_AERROR)
                    [L]ERRCOD = num$([L]ASTATUS)
                    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Unable to update work order suggestion table")
                    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Error" - [L]MESSAGE)
                    [L]OK = func ENDLOG([L]LOGINUSE, POPSLOG)

                    # Add an error repository
                    Gosub ADD_ERROR
                    Break
                Endif

                # X3-46461 - STWIL - Reset the first operation resource
                [L]FSTWST = ""

                #[L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Read OPERATIONS records ")
                # Issue 29698 - 2017-04-11 by CCC : add OPESPLNUM in key PIN
                Link [OPS] With
&                  [SCH]SCH0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM,
&                  [PIN]PIN0=[F:OPS]MFGNUM;[F:OPS]OPENUM;[F:OPS]OPESPLNUM
&               As [OPS_]

                Filter [F:OPS_] Where MFGNUM=[F:ORD]WIPNUM & OPESTA<>6
                For [F:OPS_]
                    # Loop on operation
                    [L]ILINE_OP = fmet this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).ADDLINE("OPERS", [V]CST_ALASTPOS)
                    If [L]ILINE_OP <> [V]CST_ANOTDEFINED
                        this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).MFGNUM = func FORMAT_WO_KEY ([F:OPS]MFGNUM, [F:ORD]ITMREF)
                        this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).OPENUM = func FORMAT_OP_KEY ([F:OPS]MFGNUM, [F:ORD]ITMREF, [F:OPS]OPENUM, [F:OPS]OPESPLNUM)
                        this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).CPLWST = [F:OPS]CPLWST
                        this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).OPESTA = func POPSENV_CSTD.CONVERT_X3_TO_PO_STATUS([F:OPS]OPESTA)
                        this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).EXTQTY = [F:OPS]EXTQTY
                        this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).REMQTY = max([F:OPS]EXTQTY-[F:OPS]CPLQTY+[F:OPS]REJCPLQTY, 0)
                        this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).PINTYP = [F:PIN]PINTYP
                        this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).WSTFCY = this.FCY

                        [L]REMQTY = max([F:OPS]EXTQTY-[F:OPS]CPLQTY+[F:OPS]REJCPLQTY, 0)
                        [L]ROUALT = [F:SCH]ROUALT
                        [L]ITMREF = [F:ORD]ITMREF
                        [L]OPENUM = [F:OPS]OPENUM
                        [L]MFGNUM = [F:ORD]WIPNUM
                        [L]EXTWST = [F:OPS]EXTWST
                        [L]SETTIM = [F:OPS]EXTSETTIM
                        [L]OPETIM = [F:OPS]EXTOPETIM
                        [L]PRPTIM = [F:OPS]PRPTIM
                        [L]TIMUOMCOD = [F:OPS]TIMUOMCOD

                        # X3-46461 - STWIL - Save the first operation resource
                        If [L]FSTWST = ""
                            [L]FSTWST = [L]EXTWST
                        Endif

                        # X3-47988 - STWIL - Need to set the sub-contract variables
                        # [F:OPS]SCOFLG is not set for suggestions so we need to work out
                        # the value based on resource type and sub-contract resource
                        If [F:OPS]EXTWSTTYP = 3
                            [L]SCOCOD = 2
                        Elsif [F:OPS]SCOWST = ""
                            [L]SCOCOD = 1
                        Else
                            [L]SCOCOD = 3
                        Endif
                        [L]SCOWST = [F:OPS]SCOWST
                        [L]SCOLTI = [F:OPS]SCOLTI
                        # Wait time and post-op time are always in hours.
                        [L]WAITIM = func POPSENV_CSTD.CONVERT_TIME_TO_SECS([F:OPS]WAITIM, 1)
                        [L]PSPTIM = func POPSENV_CSTD.CONVERT_TIME_TO_SECS([F:OPS]PSPTIM, 1)
                        Call OPETIME ([L]LCURDEFDIH, [L]FCY, [F:OPS]EXTWST, [F:SCH]OPESTRDAT, [F:SCH]OPESTRFRD, [L]OPESTARTTIME) From JALLIBB_SYRA
                        [L]OPESTARTTIME = "T" + left$([L]OPESTARTTIME,2) + ":" +right$([L]OPESTARTTIME,3)+ ":00Z"
                        Call OPETIME ([L]LCURDEFDIH, [L]FCY, [F:OPS]EXTWST, [F:SCH]OPEENDDAT, [F:SCH]OPEENDFRD, [L]OPEENDTIME) From JALLIBB_SYRA
                        [L]OPEENDTIME = "T" + left$([L]OPEENDTIME,2) + ":" +right$([L]OPEENDTIME,3)+ ":00Z"
                        [L]OPESTRDAT = right$(num$([F:SCH]OPESTRDAT), 7) + "-" + mid$(num$([F:SCH]OPESTRDAT), 4, 2) + "-" + left$(num$([F:SCH]OPESTRDAT), 2)
                        [L]OPEENDDAT = right$(num$([F:SCH]OPEENDDAT), 7) + "-" + mid$(num$([F:SCH]OPEENDDAT), 4, 2) + "-" + left$(num$([F:SCH]OPEENDDAT), 2)

                        # X3-29632 - STWIL - Use timezone class to convert local times to UTC
                        ASTATUS = fmet TIMEZONE.TO_UNIVERSAL_TIME(gdatetime$([L]OPESTRDAT + [L]OPESTARTTIME), this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).STRDATTIM)
                        ASTATUS = fmet TIMEZONE.TO_UNIVERSAL_TIME(gdatetime$([L]OPEENDDAT + [L]OPEENDTIME), this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).ENDDATTIM)
                        #this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).STRDATTIM = gdatetime$(num$([F:OPS]OPESTR) + "T00:00:00Z")
                        #this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).OPERS([L]ILINE_OP).ENDDATTIM = gdatetime$(num$([F:OPS]OPEEND) + "T00:00:00Z")

                        # X3-47988 - STWIL - Start - Set the correct runtimes for sub-contract operations
                        # We need to find the efficiency of the resource and determine to standard
                        # runtime so we can adjust based on replacement resource efficiency
                        [L]EFFIC = func GETRESOURCEEFFIC ([L]EXTWST, this.FCY)
                        If [L]EFFIC <> 100
                            [L]STDOPETIM = [L]OPETIM * ([L]EFFIC / 100)
                        Else
                            [L]STDOPETIM = [L]OPETIM
                        Endif

                        # If we have an un-ordered sub-contract operation make the runtime the lead time
                        If [L]SCOCOD = 2 & [F:OPS]SCOLTI > 0
                            [L]OPETIM = [F:OPS]SCOLTI * 24
                            # if run time is in minutes multiple hours by 60
                            If [L]TIMUOMCOD = 2
                                [L]OPETIM = [L]TIMUOMCOD * 60
                            Endif
                        # Operation is sub-contract by exception need to save runtime, resource
                        Elsif [L]SCOCOD = 3
                            If [F:OPS]SCOLTI > 0
                                [L]EXCOPETIM = [F:OPS]SCOLTI * 24
                                # if run time is in minutes multiple hours by 60
                                If [L]TIMUOMCOD = 2
                                    [L]EXCOPETIM = [L]TIMUOMCOD * 60
                                Endif
                            Else
                                [L]EXCOPETIM = 0
                            Endif
                        Endif
                        # X3-47988 - STWIL - End - Set the correct runtimes for sub-contract operations

                        # Send any markers that have been added to this operation.
                        #[L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Before Read Suggestions Markers")
                        Gosub UPDATE_MARKER_INFO

                        # Update usable resources
                        Gosub UPDATE_ROUTE_INFO
                    Endif
                Next

                # X3 - 46461 - STWIL - Set start time to start of standard shift
                Call OPETIME ([L]LCURDEFDIH, [L]FCY, [L]FSTWST, [L]STRDAT, 0, [L]SHIFTSTA) From JALLIBB_SYRA
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Shift start parameters -" - num$([L]STRDAT) - [L]LSTWST - this.FCY - [L]LCURDEFDIH - [L]SHIFTSTA)
                # Set the work order start date - convert to UTC.
                ASTATUS = fmet TIMEZONE.TO_UNIVERSAL_TIME(gdatetime$(right$(num$([L]STRDAT), 7) + "-" + mid$(num$([L]STRDAT), 4, 2) + "-" + left$(num$([L]STRDAT), 2) + "T" + left$([L]SHIFTSTA,2) + ":"
& +right$([L]SHIFTSTA,3) + ":00Z"), this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).STRDAT)

                # We have the last operation for this work order work out the end of shift for this resource
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Shift end parameters -" - num$([F:MFG]OBJDAT) - [L]LSTWST - this.FCY - [L]LCURDEFDIH)
                # Get the end of shift time using OPETIME with 1 as the fraction
                Call OPETIME ([L]LCURDEFDIH, [L]FCY, [L]EXTWST, [F:ORD]ENDDAT, 1, [L]SHIFTEND) From JALLIBB_SYRA
                If right$([L]SHIFTEND,3) = "59"
                    [L]SHIFTEND = left$([L]SHIFTEND,2) + ":" +right$([L]SHIFTEND,3)+ ":59"
                Else
                    [L]SHIFTEND = left$([L]SHIFTEND,2) + ":" +right$([L]SHIFTEND,3)+ ":00"
                Endif
                # X3-29632 - STWIL - Use timezone class to convert local times to UTC
                ASTATUS = fmet TIMEZONE.TO_UNIVERSAL_TIME(gdatetime$(right$(num$([F:ORD]ENDDAT), 7) + "-" + mid$(num$([F:ORD]ENDDAT), 4, 2) + "-" + left$(num$([F:ORD]ENDDAT), 2)+"T"+[L]SHIFTEND+
& "Z"), this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).ENDDAT)
                #this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).ENDDAT = gdatetime$(right$(num$([F:MFG]OBJDAT), 7) + "-" + mid$(num$([F:MFG]OBJDAT), 4, 2) + "-" + left$(num$([F:MFG]OBJDAT), 2)+"T"+[L]
#& SHIFTEND +"Z")
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Suggestion WO end date -" - right$(num$([F:ORD]ENDDAT), 7) + "-" + mid$(num$([F:ORD]ENDDAT), 4, 2) + "-" + left$(num$([F:ORD]ENDDAT),
& 2)+"T"+[L]
& SHIFTEND+"Z")
                # X3 - 46461 - STWIL - Set start and end time to start of standard shift

                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Write Suggestion operation links ")
                [L]ORDTYP = 2
                Gosub UPDATE_OPERATION_LINKS_INFO
            Endif
            [L]RECCNT += 1
            [L]CURTAB = ""
            [L]CURKEY = ""
        Next
    Endif

# Issue X3-7276 - 2017-02-01 by CCC: deletion of WOS is managed by POPSWOREP.CHKDEL
#    # Only do this for synchronisation
#    If [L]LDELTAFLG
#        # Update Planner One with suggestions that have been removed from planning
#        If ([L]CURTAB = "" | [L]CURTAB = "ORDERS-R")
#            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Read Suggestions removed from planning")
#            If [L]CURKEY = ""
#                [L]MFGNUM = ""
#                [L]ITMREF = ""
#            Else
#                [L]KEYSPLIT = instr(1, [L]CURKEY, ":")
#                [L]MFGNUM = left$([L]CURKEY, [L]KEYSPLIT)
#                [L]ITMREF = right$([L]CURKEY, [L]KEYSPLIT + 1)
#                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Read removed Suggestions records curkey="+[L]CURKEY)
#                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Read removed Suggestions records split key="+[L]MFGNUM+"~"+[L]ITMREF)
#            Endif
#            For [ORD] From 5;[L]MFGNUM;[L]ITMREF To 5;"~"
#&                Where ORIFCY=this.FCY & WIPSTA = 3 & OPTFLG = 1 & UPDDATTIM > [L]LREFDAT & [F:ORD]UPDDATTIM<=[L]LTIMENOW
#                If [L]MAXNORECS > 0 & [L]RECCNT + 1 > [L]MAXNORECS
#                    [L]CURKEY = [F:ORD]WIPNUM+":"+[F:ORD]ITMREF
#                    [L]CURTAB = "ORDERS-R"
#                    [L]CONTINUE = 1
#                    Break
#                Endif
#                    [L]ILINE_WO = fmet this.WOREP([L]LIN).ADDLINE("WRKORDS", [V]CST_ALASTPOS)
#                    If [L]ILINE_WO <> [V]CST_ANOTDEFINED
#                        this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).MFGNUM   = [F:ORD]WIPNUM
#                        this.WOREP([L]LIN).WRKORDS([L]ILINE_WO).DELETED = 1
#                    Endif
#                    [L]RECCNT += 1
#                    [L]CURTAB = ""
#                    [L]CURKEY = ""
#            Next
#            Filter [F:ORD]
#        Endif
#
#        # Update Planner One with suggestions that no longer exist
#        If ([L]CURTAB = "" | [L]CURTAB = "ORDERS-D")
#            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, POPSLOG, "Read deleted Suggestions")
#            If [L]CURKEY = ""
#                [L]MFGNUM = ""
