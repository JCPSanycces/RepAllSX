#**----------------------------------------------------------------<br/>
#* GETRESOURCEEFFIC : Get efficiency value of a work center
#**<br/>----------------------------------------------------------------<br/>
#* @param WST - Char = Work center
#* @param FCY - Char = Site
#* @return the value that has been sent to PS
#**<br/>----------------------------------------------------------------
#*!
Funprog GETRESOURCEEFFIC(WST, FCY)
    Value Char WST
    Value Char FCY

    Local Decimal EFFIC
    Local File WORKSTATIO [MWS]

    # We need to find the efficiency of the resource
    Read [F:MWS]WST0 = WST;FCY
    If fstat = [V]CST_AOK
        [L]EFFIC = [F:MWS]EFF
    Else
        [L]EFFIC = 100
    Endif

End [L]EFFIC

#**----------------------------------------------------------------<br/>
#* GETRESOURCEINFO : Get efficiency and no of resources of a work center
#**<br/>----------------------------------------------------------------<br/>
#* @param WST - Char = Work center
#* @param FCY - Char = Site
#* @param EFFIC - Decimal = Efficiency of the work station
#* @param WSTNBR - ShortInt = Number of resources of the work station
#* @return whether successful
#**<br/>----------------------------------------------------------------
#*!
Funprog GETRESOURCEINFO(WST, FCY, EFFIC, WSTNBR)
    Value Char WST
    Value Char FCY
    Variable Decimal EFFIC
    Variable Shortint WSTNBR

    Local Integer SUCCESS
    Local File WORKSTATIO [MWS]

    # We need to find the efficiency of the resource
    Read [F:MWS]WST0 = WST;FCY
    If fstat = [V]CST_AOK
        EFFIC = [F:MWS]EFF
        WSTNBR = [F:MWS]WSTNBR
        SUCCESS = 1
    Else
        EFFIC = 100
        WSTNBR = 1
        SUCCESS = 0
    Endif

End [L]SUCCESS

#**----------------------------------------------------------------<br/>
#* CONVERT_DATETIME_TO_FRDAY : Convert the datetime of an operation to a fraction of a day.
#**<br/>----------------------------------------------------------------<br/>
#* @param OPEDATTIM - DateTime = Operation start or end time
#* @param EXTWST - Char = Expected resource
#* @param FCY - Char = Site
#* @param DEFDIH - Char = Default time schema if not on resource weekly structure
#*
#* @return FRDAY : Decimal : Time passed as a fraction of a day
#*!
Funprog CONVERT_DATETIME_TO_FRDAY(OPEDATTIM, EXTWST, FCY, DEFDIH, USECAL, TIMTYP)
    Value Datetime OPEDATTIM
    Value Char EXTWST()
    Value Char FCY()
    Value Char DEFDIH()
    Value Integer USECAL # Use resource calendar = 1, 24 hour calendar = 0
    Value Integer TIMTYP # Time type 1 = prep, 2 = operation, 3 = post-op

    Local Char DATTIM(20)
    Local Char HHMM(6)
    Local Date OPEDAT
    Local Integer OK
    Local Decimal OPEDUR
    Local Decimal CURCAP
    Local Decimal FRDAY
    Local File WORKSTATIO [MWS]
    Local File TABWEEDIA [TWD]
    Local File CAPVAR [CPV]
    Local File TABUNAVAIL [TUV]
    Local File FACILITY [FCY]
    Local Char LOGNAME(20)
    Local Integer LOGINUSE
    Local Integer LNBR
    Local Integer LRET

    Local Instance FRDAYLOG Using C_ALOG
    FRDAYLOG = NewInstance C_ALOG AllocGroup null

    [L]FRDAY = 0

    [L]LOGINUSE = 1
    [L]LOGNAME = "CONVFRDAY1"
    [L]OK = func STARTLOG ([L]LOGINUSE, FRDAYLOG, "CONV_DA_FRD", [L]LOGNAME)
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Start test")

    # Make sure we have something in all the variables
    If EXTWST <> "" & OPEDATTIM <> AVOID.ADATTIM & FCY <> "" & DEFDIH <> ""
        # Get a string version of the date time
        [L]DATTIM = num$(OPEDATTIM)
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Datetime=" + [L]DATTIM)
        # Get the date
        [L]OPEDAT = left$([L]DATTIM, 4) + mid$([L]DATTIM, 6, 2) + mid$([L]DATTIM, 9, 2)
        # Get the time
        [L]HHMM = mid$([L]DATTIM, 12, 2) + mid$([L]DATTIM, 15, 2)
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "HHMM=" + [L]HHMM)
        # Work out the number of hours for the time
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "CONVHOU")
        Call CONVHOU([L]HHMM,[L]OPEDUR) From JALLIBB

        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Read FCY")
        If [F:FCY]FCY <> FCY
            Read [FCY]FCY0 = FCY
            If fstat <> [V]CST_AOK
                [L]FRDAY = 0
                [L]OK = func ENDLOG ([L]LOGINUSE, FRDAYLOG)

                FreeGroup FRDAYLOG
            Endif
        Endif

        If [F:FCY]UVYCOD = ""
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "UVYCOD = ''")
            Raz [F:TUV]
        Else
            If [F:TUV]UVYCOD <> [F:FCY]UVYCOD
                [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Read TUV")
                Read [TUV]UVY0 = [F:FCY]UVYCOD
                If fstat <> [V]CST_AOK
                    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "TUV failed")
                    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "TUV failed - " + [F:FCY]UVYCOD + num$(fstat))
                    [L]FRDAY = 0
                    [L]OK = func ENDLOG ([L]LOGINUSE, FRDAYLOG)

                    FreeGroup FRDAYLOG
                Endif
            Endif
        Endif

        If [F:MWS]WST <> EXTWST | [F:MWS]WCRFCY <> FCY
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Read WST-" + EXTWST)
            Read [MWS]WST0 = EXTWST;FCY
            If fstat <> [V]CST_AOK
                [L]FRDAY = 0
                [L]OK = func ENDLOG ([L]LOGINUSE, FRDAYLOG)

                FreeGroup FRDAYLOG
            Endif
        Endif

        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "LOACAPN")
        # Get the capacity for the day in question
        Call LOACAPN ([L]OPEDAT, [L]OPEDAT, [L]CURCAP, [L]LNBR, [L]LRET) From JALLIBB_SYRA

        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "CALDFR")
        # Call current function to calculate fraction of a day
        Call CALDFRCAP (FCY, [L]OPEDAT, USECAL, [L]OPEDUR, [L]HHMM, [L]CURCAP, [L]FRDAY, EXTWST, TIMTYP, DEFDIH) From JALLIBB_SYRA
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "ROUND")
        [L]FRDAY = arr([L]FRDAY, 0.0001)
    Endif

    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Calc frday=" + num$([L]FRDAY))
    [L]OK = func ENDLOG ([L]LOGINUSE, FRDAYLOG)

    FreeGroup FRDAYLOG

End [L]FRDAY

#**----------------------------------------------------------------<br/>
#* CONVERT_START_END_TO_DURATION : Convert the start and end datetimes of an operation to a duration in hours.
#**<br/>----------------------------------------------------------------<br/>
#* @param STADATTIM : DateTime : Operation start time
#* @param ENDDATTIM : DateTime : Operation end time
#* @param SETTIM : Decimal : Setup time in hours
#* @param PRPTIM : Decimal : Preparation time in hours
#* @param WAITIM : Decimal : Wait time in hours
#* @param EXTWST : Char : Expected resource
#* @param FCY : Char : Site
#* @param DEFDIH : Char : Default time schema if not on resource weekly structure
#* @param PRPSTRDAT : Date : Preparation start date
#* @param PRPSTF : Decimal : Preparation start time as a fraction
#* @param OPESTRDAT : Date : Operation start date
#* @param OPESTF : Decimal : Operation start time as a fraction
#* @param OPEENDDAT : Date : Operation end date
#* @param OPEENF : Decimal : Operation end time as a fraction
#* @param WAIENDDAT : Date : Post-op end date
#* @param WAIENF : Decimal : Post-op end time as a fraction
#* @param LOGINUSE : Integer : Is logging being used?
#* @return DUR : Decimal : Number of work hours duration between start and end
#*!
Funprog CONVERT_START_END_TO_DURATION(STADATTIM, ENDDATTIM, SETTIM, PRPTIM, WAITIM, EXTWST, FCY, DEFDIH, PRPSTRDAT, PRPSTF, OPESTRDAT, OPESTF, OPEENDDAT, OPEENF, WAIENDDAT, WAIENF, LOGINUSE)
    Value Datetime STADATTIM
    Value Datetime ENDDATTIM
    Value Decimal SETTIM
    Value Decimal PRPTIM
    Value Decimal WAITIM
    Value Char EXTWST()
    Value Char FCY()
    Value Char DEFDIH()
    Variable Date PRPSTRDAT
    Variable Decimal PRPSTF
    Variable Date OPESTRDAT
    Variable Decimal OPESTF
    Variable Date OPEENDDAT
    Variable Decimal OPEENF
    Variable Date WAIENDDAT
    Variable Decimal WAIENF
    Value Integer LOGINUSE

    Local Datetime STRDTTIM
    Local Datetime ENDDTTIM

    Local Char SDATTIM(20)
    Local Char EDATTIM(20)
    Local Char STAHHMM(6)
    Local Char ENDHHMM(6)
    Local Char WAIHHMM(6)
    Local Date STADAT
    Local Date ENDDAT
    Local Date STADURDAT
    Local Date ENDDURDAT
    Local Date DURSTRDAT
    Local Date DURENDDAT
    Local Integer STALNBR
    Local Integer ENDLNBR
    Local Integer OK
    Local Integer DAYS
    Local Decimal STAFRDAY
    Local Decimal ENDFRDAY
    Local Decimal STADUR
    Local Decimal ENDDUR
    Local Decimal STACURCAP
    Local Decimal ENDCURCAP
    Local Decimal DUR
    Local Decimal DAYSDUR
    Local Decimal LOCPRPTIM
    Local Decimal LOCTIMADJ
    Local File WORKSTATIO [MWS]
    Local File TABWEEDIA [TWD]
    Local File CAPVAR [CPV]
    Local File TABUNAVAIL [TUV]
    Local File FACILITY [FCY]
    Local Char LOGNAME(50)
    Local Char LOGTIME(50)
    Local Integer LRET
    Local Integer CODCAP
    Local Integer DURTYP
    Local Decimal CURCAP(2000)
    Local Integer LNBR(2000)
    Local Integer ADJUST
    Local Integer OFFSET : OFFSET = 20 # For resource capacity calculations

    Local Instance FRDAYLOG Using C_ALOG
    FRDAYLOG = NewInstance C_ALOG AllocGroup null

    [L]DUR = 0

    [L]LOGTIME = time$
    [L]LOGNAME = "CONVDTDUR1" + EXTWST + left$([L]LOGTIME, 2)+mid$([L]LOGTIME, 4, 2)+right$([L]LOGTIME, 7)
    #[L]LOGNAME = "CONVDTDUR1" + EXTWST
    [L]OK = func STARTLOG ([L]LOGINUSE, FRDAYLOG, "CONV_ST_END_DUR", [L]LOGNAME)
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Start test")

    # Make sure we have something in all the variables
    If EXTWST = "" | STADATTIM = AVOID.ADATTIM | ENDDATTIM = AVOID.ADATTIM | FCY = "" | DEFDIH = ""
        [L]OK = func ENDLOG ([L]LOGINUSE, FRDAYLOG)

        FreeGroup FRDAYLOG
        End [L]DUR
    Endif

    # Read all the records we need
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Read FCY")
    Read [FCY]FCY0 = FCY
    If fstat <> [V]CST_AOK
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "FCY failed - " + FCY + num$(fstat))
        [L]FRDAY = 0
        [L]OK = func ENDLOG ([L]LOGINUSE, FRDAYLOG)

        FreeGroup FRDAYLOG
        End [L]DUR
    Endif

    If [F:FCY]UVYCOD = ""
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "UVYCOD = ''")
        Raz [F:TUV]
    Else
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Read TUV")
        Read [TUV]UVY0 = [F:FCY]UVYCOD
        If fstat <> [V]CST_AOK
            [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "TUV failed - " + [F:FCY]UVYCOD + num$(fstat))
            [L]FRDAY = 0
            [L]OK = func ENDLOG ([L]LOGINUSE, FRDAYLOG)

            FreeGroup FRDAYLOG
            End [L]DUR
        Endif
    Endif

    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Read WST-" + EXTWST)
    Read [MWS]WST0 = EXTWST;FCY
    If fstat <> [V]CST_AOK
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "WST failed - " + EXTWST + num$(fstat))
        [L]FRDAY = 0
        [L]OK = func ENDLOG ([L]LOGINUSE, FRDAYLOG)

        FreeGroup FRDAYLOG
        End [L]DUR
    Endif

    # Get a copy of the start and end datetimes
    [L]STRDTTIM = STADATTIM
    [L]ENDDTTIM = ENDDATTIM

    # Get a string version of the date time
    [L]SDATTIM = num$([L]STRDTTIM)
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Start datetime=" + [L]SDATTIM)
    # Get the date
    [L]STADAT = left$([L]SDATTIM, 4) + mid$([L]SDATTIM, 6, 2) + mid$([L]SDATTIM, 9, 2)
    # Get the time
    [L]STAHHMM = mid$([L]SDATTIM, 12, 2) + mid$([L]SDATTIM, 15, 2)

    # Get start time information
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Start HHMM=" + [L]STAHHMM)
    # Work out the number of hours for the time
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Start CONVHOU")
    Call CONVHOU([L]STAHHMM,[L]STADUR) From JALLIBB

    # Get the capacity for the start day
    Call LOACAPN ([L]STADAT, [L]STADAT, [L]STACURCAP, [L]STALNBR, [L]LRET) From JALLIBB_SYRA
    # Call current function to calculate fraction of a day for the start day
    Call CALDFR (FCY, [L]STADAT, [L]STADUR, [L]STAHHMM, [L]STACURCAP, [L]STAFRDAY, EXTWST, DEFDIH) From JALLIBB_SYRA
    [L]STAFRDAY = arr([L]STAFRDAY, 0.0001)

    # Get the end time information
    # Get a string version of the date time
    [L]EDATTIM = num$([L]ENDDTTIM)
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "End datetime=" + [L]EDATTIM)
    # Get the date
    [L]ENDDAT = left$([L]EDATTIM, 4) + mid$([L]EDATTIM, 6, 2) + mid$([L]EDATTIM, 9, 2)
    # Get the time
    [L]ENDHHMM = mid$([L]EDATTIM, 12, 2) + mid$([L]EDATTIM, 15, 2)
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "End HHMM=" + [L]ENDHHMM)
    # Work out the number of hours for the time
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "End CONVHOU")
    Call CONVHOU([L]ENDHHMM,[L]ENDDUR) From JALLIBB

    # Get the capacity for the end day
    Call LOACAPN ([L]ENDDAT, [L]ENDDAT, [L]ENDCURCAP, [L]ENDLNBR, [L]LRET) From JALLIBB_SYRA
    # Calculate the end time fraction
    If WAITIM > 0
        CODCAP = 2
        DURTYP = 3
    Else
        CODCAP = 1
        DURTYP = 2
    Endif
    [L]CURCAP(1) = [L]ENDCURCAP
    Call CALDFRCAP (FCY, [L]ENDDAT, [L]CODCAP, [L]ENDDUR, [L]ENDHHMM, [L]CURCAP(1), [L]ENDFRDAY, EXTWST, [L]DURTYP, DEFDIH) From JALLIBB_SYRA
    #Call CALDFR (FCY, [L]ENDDAT, [L]ENDDUR, [L]ENDHHMM, [L]CURCAP(1), [L]ENDFRDAY, EXTWST, DEFDIH) From JALLIBB_SYRA
    #[L]ENDFRDAY = arr([L]ENDFRDAY, 0.0001)
    [L]ENDDUR = [L]ENDFRDAY * [L]ENDCURCAP

    # Set the calendar start and end date
    [L]DURSTRDAT = [L]STADAT - [L]OFFSET
    [L]DURENDDAT = [L]ENDDAT + [L]OFFSET
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Calendar start date ="+num$([L]DURSTRDAT))
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Calendar end date ="+num$([L]DURENDDAT))

    # If there is post-op time (wait time, post-op time) take this off the end date time
    If WAITIM > 0
        WAIENF = [L]ENDFRDAY
        WAIENDDAT = [L]ENDDAT
        [L]WAIHHMM = [L]ENDHHMM
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Wait end day capacity=" + num$([L]CURCAP(1)))
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Wait end frday ="+num$([L]ENDFRDAY))

        CODCAP = 0
        DURTYP = 3
        # Need to decrease the end datetime by the number of hours wait
        # Get the capacity between calendar start and end date
        #Call LOACAPN ([L]DURSTRDAT, [L]DURENDDAT, [L]CURCAP, [L]LNBR, [L]LRET) From JALLIBB_SYRA
        Raz [L]CURCAP
        Call CALDUR("-", WAIENDDAT, WAIENF, WAITIM, [L]DURSTRDAT, [L]DURENDDAT, CODCAP, [L]CURCAP, [L]ENDDUR, [L]ENDDAT, [L]ENDFRDAY, [L]LNBR, [L]ENDLNBR, DURTYP, FCY) From JALLIBB_SYRA
#        [L]ENDFRDAY = arr([L]ENDFRDAY, 0.0001)

        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Op end day fraction=" + num$([L]ENDFRDAY))
        # Now we have the fraction for the 24 time, convert that to working time fraction
        [L]ENDHHMM = func CONVERT_HOURS_TO_HHMM([L]ENDFRDAY * 24)
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Op end day time=" + [L]ENDHHMM)
        Call CONVHOU([L]ENDHHMM,[L]ENDDUR) From JALLIBB
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Op end day duration=" + num$([L]ENDDUR))
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Op end day capacity=" + num$([L]ENDCURCAP))
#        Call LOACAPN ([L]STADAT, [L]ENDDAT, [L]CURCAP, [L]LNBR, [L]LRET) From JALLIBB_SYRA
        Call CALDFR (FCY, [L]ENDDAT, [L]ENDDUR, [L]ENDHHMM, [L]ENDCURCAP, [L]ENDFRDAY, EXTWST, DEFDIH) From JALLIBB_SYRA
        [L]ENDFRDAY = arr([L]ENDFRDAY, 0.0001)
        [L]ENDDUR = [L]ENDFRDAY * [L]ENDCURCAP

        # We now need to update the end date time fraction to the current resource
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Wait end frday ="+num$([L]WAIENF))
        # We have already calculated the end day and end time fraction for 24 hour day
        # convert it to a time for this resource
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Wait end day time=" + [L]WAIHHMM)
#        Call CONVHOU([L]ENDHHMM,[L]ENDDUR) From JALLIBB
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Wait end day duration=" + num$([L]ENDDUR))
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Wait end day capacity=" + num$([L]ENDCURCAP))
#        Call LOACAPN ([L]STADAT, [L]ENDDAT, [L]CURCAP, [L]LNBR, [L]LRET) From JALLIBB_SYRA
        Call CALDFR (FCY, [L]WAIENDDAT, [L]ENDDUR, [L]WAIHHMM, [L]ENDCURCAP, [L]WAIENF, EXTWST, DEFDIH) From JALLIBB_SYRA
        [L]WAIENF = arr([L]WAIENF, 0.0001)
#        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Wait end frday ="+num$([L]WAIFRDAY))

    Endif
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "New end date=" + num$([L]ENDDAT))
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "New end day fraction=" + num$([L]ENDFRDAY))

    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "In between days ="+num$([L]DAYS))

    # If there is preparation time, add this to the start time to get the operation start time.
    If PRPTIM > 0
        # Set the preparation start date and time
        PRPSTRDAT = [L]STADAT
        PRPSTF = [L]STAFRDAY
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Prep date =" + num$([L]STADAT))
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Prep day fraction=" + num$([L]PRPSTF))

        [L]ADJUST = 0
        # Check if the preparation time ends at the end of the working day
        If PRPTIM = (1 - PRPSTF) * [L]STACURCAP
            [L]ADJUST = 1
            # Adjust the prep time to generate the correct operation start date
            [L]LOCTIMADJ = PRPTIM + 0.05
        Else
            [L]LOCTIMADJ = PRPTIM
        Endif
        CODCAP = 1
        DURTYP = 1
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Prep day prep time=" + num$(PRPTIM))
        # Need to increase the start datetime by the number of hours prep
        # Get the capacity between start and end date
        Call LOACAPN ([L]DURSTRDAT, [L]DURENDDAT, [L]CURCAP, [L]LNBR, [L]LRET) From JALLIBB_SYRA
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Prep day capacity ret val=" + num$(PRPSTF))
        Call CALDUR("+", PRPSTRDAT, PRPSTF, [L]LOCTIMADJ, [L]DURSTRDAT, [L]DURENDDAT, CODCAP, [L]CURCAP, [L]STADUR, [L]STADAT, [L]STAFRDAY, [L]LNBR, [L]STALNBR, DURTYP, FCY) From JALLIBB_SYRA
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Initial start day fraction=" + num$([L]STAFRDAY))
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Initial start day capacity=" + num$([L]STACURCAP))
        # The preparation time has ended at the end of the working day.
        # The operation cannot start until the start of the shift tomorrow.
        If [L]ADJUST
            # The prep time has been adjusted to generate the correct date but ignore the fraction
            [L]STAFRDAY = 0
            [L]ADJUST = 0
        Endif
    Endif
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Start date =" + num$([L]STADAT))
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Start day fraction=" + num$([L]STAFRDAY))
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Start day capacity=" + num$([L]STACURCAP))

    # Set the operation start date and time
    OPESTRDAT = [L]STADAT
    OPESTF = [L]STAFRDAY

    # Set the operation End date and time
    OPEENDDAT = [L]ENDDAT
    OPEENF = [L]ENDFRDAY

    If ENDDAT - STADAT > 1
        DAYS = ENDDAT - STADAT - 1
        STADURDAT = STADAT + 1
        ENDDURDAT = ENDDAT - 1

        # Get the capacity for the full days in question only if there are any
        Call LOACAPN ([L]STADURDAT, [L]ENDDURDAT, [L]CURCAP, [L]LNBR, [L]LRET) From JALLIBB_SYRA
        [L]DAYSDUR = sigma(0, [L]DAYS, [L]CURCAP(indcum))
    Endif
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "In between days =" + num$([L]STADURDAT)+ num$([L]ENDDURDAT))
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "In between days capacity=" + num$([L]DAYSDUR))

    # Calculate the number of hours runtime, this currently includes setup time.
    # runtime = capacity of full days - setup time + (start day capacity * start day fraction) + (end day capacity * end day fraction)
    # Unless the start and end are on the same day when we only need (end day capacity * end day fraction) - setup time
    If OPESTRDAT = OPEENDDAT
        # Calculate the number of work hours between start and end time
        [L]STADUR = OPESTF * [L]STACURCAP
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Calc start day duration=" + num$([L]STADUR))
        [L]ENDDUR = OPEENF * [L]ENDCURCAP
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Calc end day duration=" + num$([L]ENDDUR))
        [L]DUR = [L]ENDDUR - [L]STADUR - SETTIM
    Else
        # Calculate the number of work hours between start and end time
        [L]STADUR = [L]STACURCAP - (OPESTF * [L]STACURCAP)
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Calc start day duration=" + num$([L]STADUR))
        [L]ENDDUR = OPEENF * [L]ENDCURCAP
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Calc end day duration=" + num$([L]ENDDUR))
        [L]DUR = [L]DAYSDUR + [L]STADUR + [L]ENDDUR - SETTIM
        [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Calc duration=" + num$([L]DUR))
    Endif
    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "CALDFR")

    [L]OK = func OUTPUTLOGMSG ([L]LOGINUSE, FRDAYLOG, "Calc duration=" + num$([L]DUR))
    [L]OK = func ENDLOG ([L]LOGINUSE, FRDAYLOG)

    FreeGroup FRDAYLOG

End [L]DUR

#**----------------------------------------------------------------<br/>
#* UPDATE_DATETIME_WITH_HOURS : Increase or decrease date time by number of hours
#**<br/>----------------------------------------------------------------<br/>
#* @param TIMETOCONV - Char = String version of current date time
#* @param HOURS - Decimal = Number of hours + or -
#* @return SECS - Datetime - New date time
#**<br/>----------------------------------------------------------------
#*!
Funprog UPDATE_DATETIME_WITH_HOURS (TIMETOCONV, HOURS, ADD)
    Value Char TIMETOCONV()
    Value Decimal HOURS
    Value Integer ADD

    Local Datetime NEWDATTIM

    Local Integer DAYS
    Local Integer HRS
    Local Integer MINS
    Local Integer SECS

    Local Integer CURHRS
    Local Integer CURMINS
    Local Integer CURSECS

    Local Date DAT

    # Convert hours into hours minutes and seconds
    [L]SECS = HOURS * 3600

    HRS = SECS / 3600
    SECS -= HOURS * 3600
    MINS = SECS / 60
    SECS -= MINS * 60

    If HRS > 23
        DAYS = HRS / 24
        HRS -= DAYS * 24
    Endif

    #NEWTIME = format$("N0:2", HOURS)+":"+format$("N0:2", MINUTES)+":"+format$("N0:2", SECONDS)

    CURHRS = val(mid$(TIMETOCONV, 12, 2))
    CURMINS = val(mid$(TIMETOCONV, 15, 2))
    CURSECS = val(mid$(TIMETOCONV, 18, 2))

    [L]DAT = left$([L]TIMETOCONV, 4) + mid$([L]TIMETOCONV, 6, 2) + mid$([L]TIMETOCONV, 9, 2)

    If ADD
        CURSECS += SECS

        If SECS > 59
            MINS += 1
            CURSECS -= 60
        Endif

        CURMINS += MINS

        If MINS > 59
            HRS += 1
            CURMINS -= 60
        Endif

        CURHRS += HRS

        If HRS > 23
            DAYS += 1
            CURHRS -= 24
        Endif

        If DAYS > 0
            [L]DAT += DAYS
        Endif
    Else
        If SECS > CURSECS
            MINS += 1
            If MINS > 59
                HRS += 1
                MINS -= 60
            Endif
            SECS -= 60
        Endif

        CURSECS -= SECS

        If MINS > CURMINS
            HRS += 1
            If HRS > 23
                DAYS += 1
                HRS -= 24
            Endif
            MINS -= 60
        Endif

        CURMINS -= MINS

        If HRS > CURHRS
            DAYS += 1
        Endif

        CURHRS -= HRS

        If DAYS > 0
            [L]DAT -= DAYS
        Endif
    Endif

    [L]NEWDATTIM = gdatetime$(right$(num$([L]DAT), 7) + "-" + mid$(num$([L]DAT), 4, 2) + "-" + left$(num$([L]DAT), 2) + "T" + format$("N0:2", CURHRS)+":"+format$("N0:2", CURMINS)+":"+format$("N0:2",
& CURSECS) + "Z")

End NEWDATTIM

#**----------------------------------------------------------------<br/>
#* FORMAT_WO_KEY : Concatenate work order and item reference
#**<br/>----------------------------------------------------------------<br/>
#* @param MFGNUM - Char = Work order number
#* @param ITMREF - Char = Item reference (product code)
#* @return WOKEY - Char = Concatenated key
#**<br/>----------------------------------------------------------------
#*!
Funprog FORMAT_WO_KEY(MFGNUM, ITMREF)
    Value Char MFGNUM()
    Value Char ITMREF()

    Local Char WOKEY(62)

    [L]WOKEY = MFGNUM + "|" + ITMREF

End WOKEY

#**----------------------------------------------------------------<br/>
#* FORMAT_OP_KEY : Concatenate work order and item reference with operation number
#**<br/>----------------------------------------------------------------<br/>
#* @param MFGNUM - Char = Work order number
#* @param ITMREF - Char = Item reference (product code)
#* @param OPENUM - Integer = Operation number
#* @param OPENUM - Integer = Operation split number
#* @return OPKEY - Char = Concatenated key
#**<br/>----------------------------------------------------------------
#*!
Funprog FORMAT_OP_KEY(MFGNUM, ITMREF, OPENUM, OPESPLNUM)
    Value Char MFGNUM()
    Value Char ITMREF()
    Value Integer OPENUM
    Value Integer OPESPLNUM

    Local Char OPKEY(75)

    [L]OPKEY = MFGNUM + "|" + ITMREF + "|" + format$("N0:5", OPENUM) + "|" + format$("N0:5", OPESPLNUM)

End OPKEY

# Issue X3-44547 - 2017-07-21 by ALSHE : delete WO link depending on assignments
#**----------------------------------------------------------------<br/>
#* FORMAT_MTOLINK_KEY : Concatenate item reference with demand from assignment
#**<br/>----------------------------------------------------------------<br/>
#* @param NUM             - Char = order number
#* @param LIN             - Integer = line number
#* @param SEQ             - Integer = sequence number
#* @return MOTLINKKEY     - Char = Concatenated key
#**<br/>----------------------------------------------------------------
#*!
Funprog FORMAT_MTOLINK_KEY(NUM, LIN, SEQ)
    Value Char    NUM()
    Value Integer LIN
    Value Integer SEQ
    Local Char    MTOLINKKEY(GLONVCR+22)

    [L]MTOLINKKEY = NUM + "|" + format$("N0:10", LIN) + "|" + format$("N0:10", SEQ)

End MTOLINKKEY

#**----------------------------------------------------------------<br/>
#* FIND_WO_LINK_EXISTS : Does this WO number exists in the current list of WO links
#**<br/>----------------------------------------------------------------<br/>
#* @param MFGNUM - Char = Work order number
#* @return EXISTS - Integer = Link exists for this work order
#**<br/>----------------------------------------------------------------
#*!
Funprog FIND_WO_LINK_EXISTS(CHMFGNUM, PAMFGNUM, WOLNKS)
    Value Char CHMFGNUM()
    Value Char PAMFGNUM()
    Value Instance WOLNKS() Using C_POPSWOLNK

    Local Char CHWO(GLONVCR)
    Local Char PAWO(GLONVCR)
    Local Char ITM(GLONVCR)
    Local Integer EXISTS
    Local Integer OK

    EXISTS = 0
    For I = 0 To maxtab(WOLNKS) - 1
        # Check child and parent work orders
        [L]OK = func POPSENVUPD_CSTD.SPLIT_WO_KEY(WOLNKS(I).PRVWOID, [L]CHWO, [L]ITM)
        [L]OK = func POPSENVUPD_CSTD.SPLIT_WO_KEY(WOLNKS(I).NXTWOID, [L]PAWO, [L]ITM)
        If [L]PAWO = PAMFGNUM & [L]CHWO = CHMFGNUM
            EXISTS = 1
            Break
        Endif
    Next I

End EXISTS

#**----------------------------------------------------------------<br/>
#* OUTPUTLOGMSG : Write a message to the current log
#**<br/>----------------------------------------------------------------<br/>
#* @param LOGINUSE  = Is logging being used?
#* @param POPSLOG   = ALOG class
#* @param MESSAGE   = Message to be written to the log
#* @return 0=OK ; 1=Error occurred
#**<br/>----------------------------------------------------------------
#*!
Funprog OUTPUTLOGMSG(LOGINUSE, POPSLOG, MESSAGE)
    Variable Integer LOGINUSE
    Variable Instance POPSLOG Using C_ALOG
    Value Char MESSAGE()

    Local Integer SUCCESS

    If [L]LOGINUSE = 1
        [L]SUCCESS = fmet POPSLOG.APUTLINE(num$(datetime$)+": "+MESSAGE,0)
        [L]SUCCESS = fmet POPSLOG.AFLUSHLOG()
    Endif

End [L]SUCCESS

#**----------------------------------------------------------------<br/>
#* STARTLOG : Open a log file
#**<br/>----------------------------------------------------------------<br/>
#* @param LOGINUSE  = Is logging being used?
#* @param POPSLOG   = ALOG class
#* @param TITLE     = Title of the log
#* @param LOGNAME   = Name of the log
#* @return 0=OK ; 1=Error occurred
#**<br/>----------------------------------------------------------------
#*!
Funprog STARTLOG(LOGINUSE, POPSLOG, TITLE, LOGNAME)
    Variable Integer LOGINUSE
    Variable Instance POPSLOG Using C_ALOG
    Value Char TITLE()
    Value Char LOGNAME()

    Local Integer SUCCESS

    If [L]LOGINUSE = 1
        [L]SUCCESS = fmet POPSLOG.ABEGINLOG(TITLE)
        [L]SUCCESS = fmet POPSLOG.ASETNAME(LOGNAME)
    Endif

End [L]SUCCESS

#**----------------------------------------------------------------<br/>
#* ENDLOG : Close the currently open log
#**<br/>----------------------------------------------------------------<br/>
#* @param LOGINUSE  = Is logging being used?
#* @param POPSLOG   = ALOG class
#* @return 0=OK ; 1=Error occurred
#**<br/>----------------------------------------------------------------
#*!
Funprog ENDLOG(LOGINUSE, POPSLOG)
    Variable Integer LOGINUSE
    Variable Instance POPSLOG Using C_ALOG

    Local Integer SUCCESS

    If [L]LOGINUSE = 1
        [L]SUCCESS = fmet POPSLOG.AENDLOG()
    Endif

End [L]SUCCESS

#**---------------------------------------------------------------------<br/>
#* ADDOBJINF : Track the addition of an object in PS
#**<br/>----------------------------------------------------------------<br/>
#* @param PFCY = Site
#* @param PTYP = Type of object (DIH, TUV, TWD, TWC, MWS, MFG, WOS, MLK)
#* @param PID1 = ID1 of the object
#* @param PID2 = ID2 of the object
#* @param INF1 = Iformation field 1
#* @param INF2 = Iformation field 2
#* @param INF3 = Iformation field 3
#* @param INF4 = Iformation field 4
#* @return 0=OK ; 1=Writing error in [PSOBJ]
#**<br/>----------------------------------------------------------------
#*!
Funprog ADDOBJINF(PFCY, PTYP, PID1, PID2, INF1, INF2, INF3, INF4)
Value Char PFCY
Value Char PTYP
Value Char PID1
Value Char PID2
Value Char INF1
Value Char INF2
Value Char INF3
Value Char INF4

Local File POPSOBJ [PSOBJ]

Look [PSOBJ]PSOBJ0=PFCY;PTYP;PID1;PID2

If fstat
    [F:PSOBJ]FCY    = PFCY
    [F:PSOBJ]TYP    = PTYP
    [F:PSOBJ]IDENT1 = PID1
    [F:PSOBJ]IDENT2 = PID2
    [F:PSOBJ]INF1   = INF1
    [F:PSOBJ]INF2   = INF2
    [F:PSOBJ]INF3   = INF3
    [F:PSOBJ]INF4   = INF4
    [F:PSOBJ]CREDAT = date$
    Write [PSOBJ]
    If fstat
        End 1
    Endif
Endif

End 0

#**---------------------------------------------------------------------<br/>
#* ADDOBJ : Track the addition of an object in PS
#**<br/>----------------------------------------------------------------<br/>
#* @param PFCY = Site
#* @param PTYP = Type of object (DIH, TUV, TWD, TWC, MWS, MFG, WOS, MLK)
#* @param PID1 = ID1 of the object
#* @param PID2 = ID2 of the object
#* @return 0=OK ; 1=Writing error in [PSOBJ]
#**<br/>----------------------------------------------------------------
#*!
Funprog ADDOBJ(PFCY, PTYP, PID1, PID2)
Value Char PFCY
Value Char PTYP
Value Char PID1
Value Char PID2

Local File POPSOBJ [PSOBJ]

Look [PSOBJ]PSOBJ0=PFCY;PTYP;PID1;PID2

If fstat
    [F:PSOBJ]FCY    = PFCY
    [F:PSOBJ]TYP    = PTYP
    [F:PSOBJ]IDENT1 = PID1
    [F:PSOBJ]IDENT2 = PID2
    [F:PSOBJ]CREDAT = date$
    Write [PSOBJ]
    If fstat
        End 1
    Endif
Endif

End 0


#**----------------------------------------------------------------<br/>
#* SETADPVAL : Get value of a parameter used to be sent to PS
#**<br/>----------------------------------------------------------------<br/>
#* @param PFCY = Site
#* @param PADP = code of the parameter
#* @param PVAL = value of the parameter
#* @return Error code
#**<br/>----------------------------------------------------------------
#*!
Subprog SETADPVAL(PFCY,PADP,PVAL)
Value Char PFCY
Value Char PADP
Value Char PVAL

Local File POPSOBJ [PSOBJ]
Raz [F:PSOBJ]
Read [PSOBJ]PSOBJ0=PFCY;"ADP";PADP
If fstat
    [F:PSOBJ]FCY = PFCY
    [F:PSOBJ]TYP = "ADP"
    [F:PSOBJ]IDENT1 = PADP
    [F:PSOBJ]IDENT2 = PVAL
    Write [PSOBJ]
Else
    [F:PSOBJ]IDENT2 = PVAL
    Rewrite [PSOBJ]
Endif

End

#**----------------------------------------------------------------<br/>
#* GETADPVAL : Get value of a parameter used to be sent to PS
#**<br/>----------------------------------------------------------------<br/>
#* @param PFCY = Site
#* @param PADP = Code of the parameter
#* @return the value that has been sent to PS
#**<br/>----------------------------------------------------------------
#*!
Funprog GETADPVAL(PFCY,PADP)
Value Char PFCY
Value Char PADP

Local File POPSOBJ [PSOBJ]
Raz [F:PSOBJ]
Read [PSOBJ]PSOBJ0=PFCY;"ADP";PADP

End [F:PSOBJ]IDENT2

