  [L]ASTATUS = fmet this.IDENT(AINDCLA)._AFORMAT : Gosub TESTALLSTAT
 Endif
Next AINDCLA
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_NBRDIE From WMC1CACCEDEF : Gosub TESTALLSTAT :  Endif
For AINDCLA=1 To 20
 If this.DIMCEN(AINDCLA)<>null& find(this.DIMCEN(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.DIMCEN(AINDCLA)._AFORMAT : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To 5
 If this.LISCCE(AINDCLA)<>null& find(this.LISCCE(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.LISCCE(AINDCLA)._AFORMAT : Gosub TESTALLSTAT
 Endif
Next AINDCLA
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_NBLIG From WMC1CACCEDEF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_CREDATTIM From WMC1CACCEDEF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_UPDDATTIM From WMC1CACCEDEF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_AUUID From WMC1CACCEDEF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_CREUSR From WMC1CACCEDEF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AFORMAT_UPDUSR From WMC1CACCEDEF : Gosub TESTALLSTAT :  Endif
Return

####################################################################
# OTHERS
####################################################################

$_AOTHERS
Gosub DECLARE_VAR From WMC0CACCEDEF
Local Integer ALLSTAT
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_COD From WMC1CACCEDEF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_COD From WMC1CACCEDEF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CPY From WMC1CACCEDEF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CPY From WMC1CACCEDEF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_DES From WMC1CACCEDEF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_DES From WMC1CACCEDEF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_DESSHO From WMC1CACCEDEF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_DESSHO From WMC1CACCEDEF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_DESTRA From WMC1CACCEDEF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_DESTRA From WMC1CACCEDEF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_SHOTRA From WMC1CACCEDEF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_SHOTRA From WMC1CACCEDEF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_MODULE From WMC1CACCEDEF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_MODULE From WMC1CACCEDEF : Gosub TESTALLSTAT :  Endif
For AINDCLA=1 To 25
 If this.IDENT(AINDCLA)<>null& find(this.IDENT(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.IDENT(AINDCLA)._AOTHERS : Gosub TESTALLSTAT
 Endif
Next AINDCLA
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_NBRDIE From WMC1CACCEDEF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_NBRDIE From WMC1CACCEDEF : Gosub TESTALLSTAT :  Endif
For AINDCLA=1 To 20
 If this.DIMCEN(AINDCLA)<>null& find(this.DIMCEN(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.DIMCEN(AINDCLA)._AOTHERS : Gosub TESTALLSTAT
 Endif
Next AINDCLA
For AINDCLA=1 To 5
 If this.LISCCE(AINDCLA)<>null& find(this.LISCCE(AINDCLA).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
  [L]ASTATUS = fmet this.LISCCE(AINDCLA)._AOTHERS : Gosub TESTALLSTAT
 Endif
Next AINDCLA
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_NBLIG From WMC1CACCEDEF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_NBLIG From WMC1CACCEDEF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CREDATTIM From WMC1CACCEDEF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CREDATTIM From WMC1CACCEDEF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UPDDATTIM From WMC1CACCEDEF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UPDDATTIM From WMC1CACCEDEF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_AUUID From WMC1CACCEDEF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_AUUID From WMC1CACCEDEF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_CREUSR From WMC1CACCEDEF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_CREUSR From WMC1CACCEDEF : Gosub TESTALLSTAT :  Endif
If !find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) : Gosub _AOTHERS_UPDUSR From WMC1CACCEDEF : Gosub TESTALLSTAT : Gosub _AOTHERS_REF_UPDUSR From WMC1CACCEDEF : Gosub TESTALLSTAT :  Endif
[L]ASTATUS = fmet this.ACONTROL
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



