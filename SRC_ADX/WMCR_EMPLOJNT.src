#<AdxTL>@(#)0.0.0.0 $Revision$Class Spouses (>1)
# Supervisor
## CRUD-CLASSE ## EMPLOJNT
# 2018-11-06 07:06:07 002


Gosub TEST : End

############################################################################################
# Program TEST
############################################################################################
$TEST
Local Integer SILENCE
Call OUVRE_TRACE("Test program")From LECFIC

Gosub ATRT_TEST

Call LEC_TRACE From LECFIC
Call SUPP_TRACE From LECFIC


Return

#---------------------------------------------------------------#
$ATRT_TEST
Local Integer ASTATUS
If !SILENCE : Call TRACE("1 --> Open main table" ) From ASYRCOM : Endif
Local File EMPLOJNT [JNT_]

If !SILENCE : Call TRACE("2 --> Local Instance C_EMPLOJNT") From ASYRCOM : Endif
Local Instance EMPLOJNT Using C_EMPLOJNT

If !SILENCE : Call TRACE("3 --> New Instance C_EMPLOJNT") From ASYRCOM : Endif
EMPLOJNT = NewInstance C_EMPLOJNT AllocGroup null

If !SILENCE : Call TRACE("4 --> Reading main table, Read First") From ASYRCOM : Endif
Read [JNT_]JNT0 First
If !fstat
 If !SILENCE : Call TRACE("Call program read of EMPLOJNT") From ASYRCOM : Endif
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOJNT.AREAD([JNT_]REFNUM,[JNT_]NUMLIG))
Endif

If !SILENCE
 Call TRACE("5 --> Check :"-num$([L]ASTATUS)) From ASYRCOM
 Call TRACE("EMPLOJNT.REFNUM ="-num$(EMPLOJNT.REFNUM)) From ASYRCOM
 Call TRACE("EMPLOJNT.NUMLIG ="-num$(EMPLOJNT.NUMLIG)) From ASYRCOM
 Call TRACE("6 --> List of keys :") From ASYRCOM
 For I=1 To maxtab(EMPLOJNT.AKEYS)
  Call TRACE("-"-num$(I)-":"-EMPLOJNT.AKEYS(I)) From ASYRCOM
 Next
Endif
Close Local File [JNT_]
FreeGroup EMPLOJNT
Return

############################################################################################
### Funprog _AREADETAG
############################################################################################
Funprog _AREADETAG(EMPLOJNT,ACLE,ASTATUS,_ETAG)
Variable Instance EMPLOJNT Using C_EMPLOJNT
Value Char ACLE
Variable Integer ASTATUS
Variable Char _ETAG
[L]ASTATUS = [V]CST_AOK
Local Char _REFNUM(15)
Local Shortint _NUMLIG
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_REFNUM = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_NUMLIG = val([L]CLE(2)) : Endif
Raz [L]_ETAG
Local File EMPLOJNT [JNT]
Default File [F:JNT]
Read [F:JNT]JNT0 = [L]_REFNUM;[L]_NUMLIG
If fstat
 [L]ASTATUS = [V]CST_AERROR
Endif
If [L]ASTATUS=[V]CST_AOK and dim([F:JNT]UPDTICK)>0
 [L]_ETAG = num$([F:JNT]UPDTICK)
Endif
End [L]ASTATUS

############################################################################################
### Subprog _AREADSUP
############################################################################################
Subprog _AREADSUP(EMPLOJNT,ACLE,ASTATUS)
Variable Instance EMPLOJNT Using C_EMPLOJNT
Value Char ACLE
Variable Integer ASTATUS
Local Char _REFNUM(15)
Local Shortint _NUMLIG
Gosub SET_CLE From ASYRSUB
If [L]CLE(1)<>"" : [L]_REFNUM = num$([L]CLE(1)) : Endif
If [L]CLE(2)<>"" : [L]_NUMLIG = val([L]CLE(2)) : Endif
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOJNT.AREAD([L]_REFNUM,[L]_NUMLIG))
End

############################################################################################
### Subprog AREAD
############################################################################################
Subprog AREAD(EMPLOJNT,_REFNUM,_NUMLIG,ASTATUS)
Variable Instance EMPLOJNT Using C_EMPLOJNT
Value Char _REFNUM
Value Shortint _NUMLIG
Variable Integer ASTATUS

If EMPLOJNT = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOJNT
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If EMPLOJNT.APARENT=null
 [L]A_I = EMPLOJNT.freeSnapshot
 EMPLOJNT.snapshotEnabled = 0
 EMPLOJNT.setAccessorEnabled = 0
Endif

Gosub ATRT_AREAD
If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif

If [L]ASTATUS<[V]CST_AERROR & EMPLOJNT.APARENT=null
 # Load Link
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOJNT._ALNKPRO)
 If [L]ASTATUS>=[V]CST_AERROR : Goto AREAD_END : Endif
Endif

$AREAD_END
If EMPLOJNT.APARENT=null
 EMPLOJNT.snapshotEnabled = 1
 EMPLOJNT.setAccessorEnabled = 1
Endif
LogicClose File [JNT]
End

#-----------------------------------------------------#
$ATRT_AREAD
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOJNT._ACTION_PARAM("AREAD_BEFORE",[L]_REFNUM,[L]_NUMLIG))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Default File [F:JNT]
Read [F:JNT]JNT0 = [L]_REFNUM;[L]_NUMLIG
If fstat
[L]A_ERROR = [L]_REFNUM+"~"+num$([L]_NUMLIG)
& -":"-mess(23,100,1)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(EMPLOJNT,"",0,[L]ASTATUS,[V]CST_AHTTP_NOT_FOUND,[L]A_ERROR) : Goto AREAD_END
Endif
[L]A_STRSITE = ""
[L]A_STRACC = ""
If dim([F:JNT]AUUID)>0 & [F:JNT]AUUID=NullUuid
 [F:JNT]AUUID = getUuid
Endif
SetInstance EMPLOJNT With [F:JNT]
EMPLOJNT.ASTALIN = [V]CST_ALL

[L]ASTATUS = max([L]ASTATUS,fmet EMPLOJNT.ACTION("AREAD_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


Return



