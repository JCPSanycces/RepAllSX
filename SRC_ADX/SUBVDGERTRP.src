#** #############################################################################################
#* On Field Action D_LINENO (Initialization) of the hidden field LINENO the value for this field
#* is set
#* @param VALEUR  VALUE Integer   Value of the field LINENO
#*
#*! #############################################################################################
Subprog D_LINENO(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0
    VALEUR = max([M:TRGP0]LINENO(0..[M:TRGP0]NBLIG-1))+1
    #If there is no value for LINENO is set in the grid
    #the function max returns -999....
    #in that case we set the value by our own.
    If VALEUR < 0
      VALEUR = (nolign - 1)
    Endif
Endif
End

######################################################################################
## Section automatically added (screen TRGP0) 08/14/2012 12:16:26 (ANGRE)
######################################################################################
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR

  If [M:TRGP0]ENDDAT <> [0/0/0] and VALEUR <> [0/0/0]
    If [M:TRGP0]ENDDAT < VALEUR
    # TODO: Message 33,177,1
      Call ERREURT(( mess(33,177,1) ),1) From GESECRAN
      mkstat = 2
    Endif
  Endif

End

Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR

  If [M:TRGP0]STRDAT <> [0/0/0] and VALEUR <> [0/0/0]
    If [M:TRGP0]STRDAT > VALEUR
    # TODO: Message 34,177,1
      Call ERREURT(( mess(34,177,1) ),1) From GESECRAN
      mkstat = 2
    Endif
  Endif

End


######################################################################################
## Section automatically added (screen TRGP0) 10/30/2012 14:23:55 (ANGRE)
######################################################################################
Subprog C_REPLINE(VALEUR)
Variable Char    VALEUR()
  Read [RLI]RLI0 = [M]LEG; 1; VALEUR
    If fstat
        Call MESSAGE ( mess(306,107,1) ) From GESECRAN#( mess(306,107,1) ) From GESECRAN  # "Incorrect turnover type"
        mkstat = 2
    Endif
End


