#** #############################################################################################
#* Chunk $LIENS is triggerd on ticking on a item in the left list.
#* The sub SHOWLINES is called which shows the related lines for the item
#*! #############################################################################################
#$LIENS
# # Gosub SHOWLINES
#Return


#** #############################################################################################
#* Chunk $SHOWLINES writes the related items to a item in the left list in the grid
#*! #############################################################################################
$SHOWLINES
  nolign = 0
  Filter [TRPG] Where LEG=[M:TRGP0]LEG & VAT=[M:TRGP0]VAT
  For [TRPG]TRPG4
    nolign += 1
    [M:TRGP0] = [F:TRPG]
  Next
  [M:TRGP0]NBLIG = nolign
  Filter [TRPG]
  Affzo [M:TRGP0]
Return

