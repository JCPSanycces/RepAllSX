#<AdxTL>@(#)2.0.0.0 $Revision$
# Sert à initialiser le nouveau champ PHYREFOLD de la table PHYELT, avec 
# le champ PHYREF
End

Subprog EXE_UTIIMM08(APPLI)
Value Char APPLI
Local Integer OK

  If clalev([F:WPHY]) : Close Local File [WPHY] : Endif
  Local File =APPLI+".PHYELT" [WPHY]

  Call ECR_TRACE("UTIIMM08: Process Start on : "+APPLI,0) From GESECRAN

  Call DEBTRANS From GLOCK
  Gosub TR_UTIIMM08
  Call ECR_TRACE("UTIIMM08: Process End on : "+APPLI,0) From GESECRAN

  If clalev([F:WPHY]) : Close Local File [WPHY] : Endif
End


#### Corps de la moulinette - début
$TR_UTIIMM08

  Filter [F:WPHY] Where PHYREFOLD=""
  Trbegin [WPHY]
  
  For [F:WPHY]
    [F:WPHY]PHYREFOLD=[F:WPHY]PHYREF
    [F:WPHY]CREORI = 1              # Origine de saisie Saisie transactionnelle
    Rewrite [WPHY]
    If fstat
      GOK = 0 : Call ECR_TRACE(mess(13,100,1)-"PHYELT:"-[F:WPHY]PHYREF,1) From GESECRAN
      Break
    Endif
  Next
  
  If !GOK Then
    Goto AB_UTIIMM08
  Else
    Commit
  Endif
  Filter [F:WPHY]
Return

$AB_UTIIMM08
  Rollback
Return 
#### Corps de la moulinette - fin 


Subprog PATCH(APPLI)
Value Char    APPLI
Local Integer GPHY

  If APPLI=adxmother(0) : End : Endif

  # On  regarde si le module Immobilisation est à "Oui"
  If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If [F:ADS]MODULE(13) <> 2 : End : Endif

  # On  regarde si le code activité PHY Elements Physiques pour le dossier est à "Oui"
  If !clalev([F:ADA]) : Local File ADOSACT  [ADA] : Endif
  Read [ADA]ADA0=APPLI;"PHY"                 : # Dossier avec Eléments physiques

  If fstat Then
    GPHY = G_OUI          : # Par défaut on gère les éléments physiques
  Else
    GPHY = [F:ADA]FLACT
  Endif

  If GPHY<>G_OUI : End : Endif

  If filinfo(filpath("FIL","PHYELT","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM08(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj7 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
Local Integer GPHY

  If APPLI=adxmother(0) : End : Endif

  # On  regarde si le module Immobilisation est à "Oui"
  If !clalev([F:ADS]) : Local File ADOSSIER [ADS] : Endif
  Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
  If [F:ADS]MODULE(13) <> 2 : End : Endif

  # On  regarde si le code activité PHY Elements Physiques pour le dossier est à "Oui"
  If !clalev([F:ADA]) : Local File ADOSACT  [ADA] : Endif
  Read [ADA]ADA0=APPLI;"PHY"                 : # Dossier avec Eléments physiques

  If fstat Then
    GPHY = G_OUI          : # Par défaut on gère les éléments physiques
  Else
    GPHY = [F:ADA]FLACT
  Endif

  If GPHY<>G_OUI : End : Endif

  If filinfo(filpath("FIL","PHYELT","fde",APPLI),0) < 0 : End : Endif
  Call EXE_UTIIMM08(APPLI)
End

