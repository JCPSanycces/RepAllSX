#<AdxTL>@(#)0.0.0.0 $Revision$
#------------------------------------------------------------------------------------------------------
#            Script containing calls for handling picking left list on sales invoices
#------------------------------------------------------------------------------------------------------
# Issue X3-39424 - 20170517 by LD : Error in scheduled invoices picking

#------------------------------------------------------------------------------------------------------
# Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management
#------------------------------------------------------------------------------------------------------
#**Filtering for Scheduled invoices picking left list on sales invoices
#*----------------------------------------------------------
#*--Filling FILGAUSUP variable (dimension to 240 in GOBJET)
#*----------------------------------------------------------
#*----------Picking list associated object SVIC1 :----------
#*-Tables SVCRINVCNDD [SVICD], SVCRINVCND [SVIC], SORDERP [SOP], SORDER [SOH], SORDERQ [SOQ]
#*----------------------------------------------------------
#* The filtering is used on the following link :
#* Link [SVICD] With
#* [SVIC]SVIC0=10;[F:SVICD]VCRNUMORI;[F:SVICD]VCRLINORI;[F:SVICD]VCRSEQORI,
#* [SOP]SOP0=[F:SVICD]VCRNUMORI;[F:SVICD]VCRLINORI;[F:SVICD]VCRSEQORI,
#* [SOH]SOH0=[F:SVICD]VCRNUMORI,
#* [SOQ]SOQ0=[F:SVICD]VCRNUMORI;[F:SVICD]VCRLINORI;[F:SVICD]VCRSEQORI
#* As [SVICD_]
#* Order By Key SVICD4
#*----------------------------------------------------------
#*!
$FILGAUCHE7
  #--If no current record (except during creation) or not an invoice or posted invoice
  #--or invoice origin other than direct or invoice scheduling
  If (GREP="" & !CLECUR) | [M]INVTYP<>1 | [M]INVSTA=3 | find([M]SIHORI,1,10)=0
     FILGAUSUP(0)='[F:SVIC]VCRTYP=9999'
     Return
  Endif

  #--No picking of invoice scheduling if invoice with stock transaction and already having lines fed
  If ([M:SIH4]NBLIG>0 or [M:SIH4]ITMREF(0)<>"" ) and [M:SIH1]STOMVTFLG=2 and [M:SIH1]SIHORI=1
    FILGAUSUP(0)+='&[F:SVIC]VCRTYP=9999'
    Return
  Endif

  #Raz WLENGHT_FILLED

  #--Only scheduling invoices that have a sales order line as origin
  FILGAUSUP(0)  ='[F:SVIC]VCRTYP=10'                                         :# WLENGHT_FILLED(0)=17

  #--Scheduling invoice lines have to be 'To be invoiced'
  FILGAUSUP(0) +='&[F:SVICD]INVCNDSTA<=1'                                    :# WLENGHT_FILLED(0)+=22

  #--Original orders have to be of 'Normal' type
  FILGAUSUP(0) +='&[F:SOP]SOHCAT=1'                                          :# WLENGHT_FILLED(0)+=16

  #--Eventually : use of picking criterias from the menu option 'Picking criterias'
  If [M:SIH0]CRISOHNUM<>"" FILGAUSUP(0)+='&[F:SOH]SOHNUM=[M]CRISOHNUM' Endif :# WLENGHT_FILLED(0)+=27
  If [M:SIH0]CRIITMREF<>"" FILGAUSUP(0)+='&[F:SOP]ITMREF=[M]CRIITMREF' Endif :# WLENGHT_FILLED(0)+=27

  If [M]SALFCY<>""         FILGAUSUP(0)+='&[F:SVIC]SALFCY=[M]SALFCY'   Endif :# WLENGHT_FILLED(0)+=25

  If find(REPONSE,GSTARAF,GSTATIR,GSTAPRG,GSTASVG)
     If [M]BPCINV<>"" FILGAUSUP(0)+='&[F:SVIC]BPCINV=[M]BPCINV'
                      FILGAUSUP(0)+='&[F:SOH]BPCINV=[M]BPCINV'
     Endif
  Else
     FILGAUSUP(0)+='&[F:SVIC]BPCINV=[M]BPCINV'                               :# WLENGHT_FILLED(0)+=25
     FILGAUSUP(0)+='&[F:SOH]BPCINV=[M]BPCINV'                                :# WLENGHT_FILLED(0)+=24
  Endif

  If [M]NBLIG <> 0
     If [M]BPRPAY<>"" FILGAUSUP(0)+='&[F:SOH]BPCPYR=[M]BPRPAY'         Endif :# WLENGHT_FILLED(0)+=24

     If [M]BPCGRU<>"" FILGAUSUP(0)+='&[F:SOH]BPCGRU=[M]BPCGRU'         Endif :# WLENGHT_FILLED(0)+=24
  Endif
  #--FILGAUSUP(0) filled potentially up to 231/240 characters

  #  Les Lignes ne doivent pas être des composants de kit/sous-traité
  FILGAUSUP(1)='&(!find([F:SOP]LINTYP,3,4,5,11,12,13))'                      :# WLENGHT_FILLED(1)+=38

  # V6.2 : Certification
  # Si ctrl date documents : La date de facturation doit avoir une date <= à la date de la facture
  If GCTLDATORI=2  FILGAUSUP(1) +='&[F:SOH]ORDDAT<=[M]INVDAT' : Endif        :# WLENGHT_FILLED(1)+=25 false

  If [M]NBLIG <> 0
     If [M]CUR<>""    FILGAUSUP(1)+='&[F:SVIC]CUR=[M]CUR'                    :# WLENGHT_FILLED(1)+=19
                      FILGAUSUP(1)+='&[F:SOH]CUR=[M]CUR'        Endif        :# WLENGHT_FILLED(1)+=18

     If [M]PTE<>""    FILGAUSUP(1)+='&[F:SOH]PTE=[M]PTE'        Endif        :# WLENGHT_FILLED(1)+=18

     If [M]PRITYP<>0  FILGAUSUP(1)+='&[F:SVIC]PRITYP=[M]PRITYP'              :# WLENGHT_FILLED(1)+=25
                      FILGAUSUP(1)+='&[F:SOH]PRITYP=[M]PRITYP'  Endif        :# WLENGHT_FILLED(1)+=24

     If [M]VACBPR<>"" FILGAUSUP(1)+='&[F:SOH]VACBPR=[M]VACBPR'  Endif        :# WLENGHT_FILLED(1)+=24

     If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2 : FILGAUSUP(1)+='&[F:SOH]SSTENTCOD=[M]SSTENTCOD' : Endif # LTA.n  79065   #89534 - Use FILGAUSUP(2) in place of index 1  # 106867.n
                                                                             :# WLENGHT_FILLED(1)+=30
  Endif

  # Les commandes doivent être non facturées
  FILGAUSUP(1) +='&[F:SOH]INVSTA<>3'                                         :# WLENGHT_FILLED(1)+=17

  #--FILGAUSUP(1) filled potentially up to 238/240 characters

  #TODO Leave those ?
  # Les Lignes ne doivent pas être des lignes de contrats de service
  FILGAUSUP(2)  ='&[F:SOP]CONNUM=""'                                         :# WLENGHT_FILLED(2)+=17

  # order holds
  FILGAUSUP(2) +='&[F:SOH]HLDSTA<2'                                          :# WLENGHT_FILLED(2)+=16
  # Les commandes doivent être signées
  FILGAUSUP(2) +='&[F:SOH]APPFLG>2'                                          :# WLENGHT_FILLED(2)+=16

  If [M]INVDAT <> [0/0/0]
     FILGAUSUP(2)+='&[F:SVICD]NEXINVDAT<=[M]INVDAT'                          :# WLENGHT_FILLED(2)+=30
  Endif

  If [M]SALFCY<>"" FILGAUSUP(2)+='&[F:SOH]SALFCY=[M]SALFCY'    Endif         :# WLENGHT_FILLED(2)+=24

  #--CPO 71065 Code affaire
  If [M]NBLIG > 0 | ([M]NBLIG = 0 & [M]PJT <> "")
     If GPJTSNGDOC = G_OUI Then
       FILGAUSUP(2)+='&[F:SOH]PJT=[M]PJT'                                    :# WLENGHT_FILLED(1)+=18
     Endif
  Endif
  #--/CPO

  #--FILGAUSUP(2) filled potentially up to 121/240 characters


  # X3-65724 (LC-14/02/18)   Filter in left picking list and row permission
#  # Issue X3-39424
#  #GBIDC3="" : Call FILROLE("SVIC",GBIDC3) From SUBARL
#  GBIDC3="" : Call FILROLE("SOH",GBIDC3) From SUBARL
#  # End issue X3-39424
#  If GBIDC3<>"" FILGAUSUP(3)+= "& " + GBIDC3 : Endif
  # Raz FILSUITE,IFILSUITE # X3-88182 (LCC-06/08/18) Pagination on invoice picking list
  Call AJOUTE_CONDITION_ROLE(FILSUITE,IFILSUITE,"SOH") From CRMUTIL150
# END X3-65724 (LC-14/02/18)   Filter in left picking list and row permission


Return
#------------------------------------------------------------------------------------------------------
$DEB_PICK
Local Integer WNPICK, WSTAPICK,WIS_DEPICK
Local Integer IJCPO,WISOK,WSIGMA,WTEMPSIGMA
Local Char    WMES(150)
#--The upper node possible to group depick is the order, than the order line, than the schedule invoice line
Local Char    WVCRNUMORI_DEPICK(GLONVCR)
Local Tinyint WVCRTYP_DEPICK
Local Integer WVCRLINORI_DEPICK, WVCRSEQORI_DEPICK

  ##--No need to do the control if less then 2 lines
  #If [M:SIH4]NBLIG<2 : Return : Endif
  #
  #Raz [M:SIH4]ISDEPICKED

  #WIS_DEPICK = 0
  #WNPICK     = 0
  #WISOK      = [V]CST_AYES
