#------------------------------------------------------------------------------------------------------
$SEL7
#-----------------------------------------------------------------------#
# Selecting an scheduling invoice line                                  #
#-----------------------------------------------------------------------#
Local Char    WMESS9(80), WMESS1(80)
  # Alimentation de la clé de SOQ et forçage de la valeur de SOPSEQ
  #[F:SOQ]SOHNUM = [F:SOP]SOHNUM
  #[F:SOQ]SOPLIN = [F:SOP]SOPLIN
  #[F:SOQ]SOQSEQ = [F:SOP]SOPLIN
  #[F:SOP]SOPSEQ = [F:SOP]SOPLIN

  ##--- Lecture des tables [SOQ],[SOH],[SOP]
  #--Tables SOH, SOQ and SOP are part of the link defined on the SVIC1 browser object (associated to the current picking list)
  #Read [SOQ]SOQ0=[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ
  #If fstat
  #   Call RSTA ("SOQ",[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)) From GLOCK
  #   OK=0 : Return
  #Endif
  #Read [SOH]SOH0=[F:SOQ]SOHNUM
  #If fstat
  #   Call RSTA ("SOH",[F:SOQ]SOHNUM) From GLOCK
  #   OK=0 : Return
  #Endif
  #Read [SOP]SOP0=[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOPLIN
  #If fstat
  #   Call RSTA ("SOP",[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)) From GLOCK
  #   OK=0 : Return
  #Endif

  # Vérification si la ligne n'a pas été soldée
  # depuis le dernier raffraichissement de la liste de picking
  If [F:SOQ]INVQTY + [F:SOQ]ODLQTY >= [F:SOQ]QTY
     GMESSAGE = [F:SOQ]SOHNUM-":"-mess(27,159,1)-[F:SOQ]ITMREF-":"-mess(248,192,1)
     OK=0 : Return
  Endif

  #TODO Add a test on the new INVAMTxxx field to be added on the sales order (in case of amount driven schedule invoice)

  If [M:SIH0]SALFCY=""
     If GFCY<>[F:SOH]SALFCY
         # Chargement globales référenciels, comptes et sections de la société
         GFCY=[F:SOH]SALFCY : Gosub CHARG_PARAM From SUBSIHA
         If GERR=1 OK=0 : Return Endif
     Endif
     # Alimentation des champs liés au type de facture
     # --> Alimentation catégorie facture, type pièce, code journal
     # --> Alimentation infos compteur
     # --> Si type pièce renseigné : Contrôle et récup infos compteur
     Local Char WSIVTYP(GLONTSV)
     Gosub INIT_SIVTYP From SUBSIHB
     If GERR=1 OK=0 : Return Endif
     [M:SIH0]SIVTYP=WSIVTYP
     # Récupération des paramètres vente du site / de la société
     Call GLOBVAR(GFCY,"VEN") From TRTX3
     # Récupération du paramètre TC
     Local Char PARAM(GLONADP)
     Call PARAML(GFCY,"SIVSUP",PARAM) From ADOVAL
     GSIVSUP = val(PARAM)
  Endif

  #--- Lecture des tables articles
  Gosub LEC_TABART From SUBSIHC

  # --- Contrôle état crédit de la commande
  # WCTL=0 : Ctrl non encore effectué car 1ère ligne de la cde traitée
  # WCTL=1 : Ctrl déjà effectué sur les lignes précédentes de la cde avec abandon
  # WCTL=2 : Ctrl déjà effectué sur les lignes précédentes de la cde avec poursuite
  If WCTL=0
      WCTL=2
      #--- Contrôle état crédit de la commande
      Call SDCDTSTA ([F:SOH]SOHNUM,[F:SOH]BPCORD,[F:SOH]CHGTYP,0,[F:SOH]CUR,[F:SOH]ORDDAT,[F:SOH]UNL,1,
&                    CDTSTA,[M]OST,[M]OSTAUZ) From TRTVENCDT
      WMESS9 =  '\'+ '\' + format$("N:9.2",[M]OST) + '>' - format$("N:9.2",[M]OSTAUZ)
      Case CDTSTA
       When 2 : # Client bloqué
                OK=0 : GERR=1
                GMESSAGE=[F:SOH]SOHNUM-mess(52,192,1)
                WCTL=1 : Return
       When 3 : # Dépassement d'en cours
                # Si déblocage crédit non autorisé on bloque
                If GCDTUNL=1
                    OK=0:GERR=1
                    GMESSAGE=[F:SOH]SOHNUM-mess(29,192,1)
                    #-- 81855
                    If dim(GVENFLG02)>=0 & (GVENFLG02=2 or GVENFLG02=3 )
                      GMESSAGE += WMESS9
                    Endif
                    WCTL=1 : Return
                Endif
                WOK=2
                WMESS1 =  [F:SOH]SOHNUM-mess(29,192,1)
                #-- 81855
                If dim(GVENFLG02)>=0 & (GVENFLG02=2 or GVENFLG02=3 )
                      WMESS1 += WMESS9
                Endif
                Call AVERTIR(WMESS1 ,WOK) From GESECRAN
                If WOK=1 OK=0 : WCTL=1 : Return Endif
       When 4 : #--no blocking for schedule invoice (mail CH 09/03/2016)
                # Acomptes non versés
                If GLOKORD=2
                   OK=0 : GERR=2
                   GMESSAGE=[F:SOH]SOHNUM-mess(53,192,1)
                   WCTL=1 : Return
                Endif
       When 5 : # Sage Exchange
                OK=0 : GERR=1
                Local Char VCRNUM
                Local Integer VCRTYP
                Call SEPP_CUR_DOC([F:SOH]SOHNUM,[L]VCRTYP,[L]VCRNUM) From SEPPCDT
                If [L]VCRNUM<>[F:SOH]SOHNUM
                  If [L]VCRTYP=4
                    GMESSAGE = func AFNC.MES1(mess(52,2092,1),mess(54,198,1)-[L]VCRNUM)
                  Else
                    GMESSAGE = func AFNC.MES1(mess(52,2092,1),mess(55,198,1)-[L]VCRNUM)
                  Endif
                Else
                  GMESSAGE = mess(9,2092,1)
                Endif
                GMESSAGE=[F:SOH]SOHNUM-GMESSAGE
                WCTL=1 : Return
       When Default
      Endcase
  Elsif WCTL=1
      OK=0 : Return
  Endif

  #--- Appel au traitement de contrôle de la sélection

  # C'est la 1ére commande de la facture
  If [M:SIH4]NBLIG <> 0
     If sum([M:SIH4]SOHNUM(0..[M:SIH4]NBLIG-1)) = ""
        YSOHNUM = [F:SOH]SOHNUM
     Endif
  Endif

  #--Invoice schedule line specific control
  Gosub CTL_SVICD

  # Contrôle que la ligne de commande est facturable
  Gosub CTL_SVICD_CDE_LIG
  If OK=0 Return Endif

  # C'est la première ligne de la facture
  If [M]NBLIG = 0
     # Lecture client facture
     Read [BPC]BPC0 = [F:SOH]BPCINV
     If fstat
        Call RSTA("BPC",[F:SOH]BPCINV) From GLOCK : OK=0 : Return
     Endif
     # Lecture client livré
     Read [BPD]BPD0 = [F:SOQ]BPCORD;[F:SOQ]BPAADD
     If fstat
        Call RSTA("BPD",[F:SOQ]BPCORD+[F:SOQ]BPAADD) From GLOCK : OK=0 : Return
     Endif
     # Lecture mode de livraison
     If clalev ([F:TMD]) <= 0 Local File TABMODELIV [TMD] Endif
     Raz [F:TMD]
     If [F:SOQ]MDL <> ""
        Read [TMD]TMD0 = [F:SOQ]MDL
        If  fstat : Raz [F:TMD] : Endif
     Endif
     # Alimentation des masques (entête)
     Call ALI_SVICD_SOHSIH() From LIBSAL_INVCND_SIH_PICK
     YSOHNUM = [F:SOH]SOHNUM
     Close Local File [TMD]

     # LTA.sn 79065
     If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
       [M:SIH1]SSTENTCOD = [F:SOH]SSTENTCOD
     Endif
     # LTA.en 79065
  Else
     # Contrôle des conditions des regroupement, et des liens cde/fac
     Gosub CTL_SVICD_CDE
     If OK=0 Return Endif
  Endif

  # Contrôle de l'insertion
  If [M:SIH4]NBLIG+1 >= dim([M:SIH4]ITMREF)-1
     GERR=1 : GMESSAGE=mess(122,199,1)
     OK=0   : Return
  Endif

  SYMBOLE2 = "SOH"+[F:SOH]SOHNUM
  Lock = SYMBOLE2
  If fstat
     # modification en cours sur un autre poste
     GERR=1 : GMESSAGE=[F:SOH]SOHNUM-":"-mess(10,100,1)
     OK=0   : Return
  Endif
  #TODO add lock on symbole SOQ/SOP/SVIC ?
  ##--Locking SOQ
  #local char SYMBOLE3(50),SYMBOLE4(50),SYMBOLE5(50)
  #SYMBOLE3  "SOQ"+[F:SOQ]SOHNUM+"\"+num$([F:SOQ]SOPLIN)+"\"+num$([F:SOQ]SOQSEQ)
  #Lock = SYMBOLE3
  #If fstat
  #   # modification en cours sur un autre poste
  #   GERR=1 : GMESSAGE=[F:SOQ]SOHNUM-mess(162,154,1)-[F:SOQ]ITMREF-":"-mess(10,100,1)
  #   OK=0   : Return
  #Endif
  ##--Locking SOP
  #SYMBOLE4 = "SOP"+[F:SOP]SOHNUM+"\"+num$([F:SOP]SOPLIN)+"\"+num$([F:SOP]SOPSEQ)
  #Lock = SYMBOLE4
  #If fstat
  #   # modification en cours sur un autre poste
  #   GERR=1 : GMESSAGE=[F:SOP]SOHNUM-mess(162,154,1)-[F:SOP]ITMREF-":"-mess(10,100,1)
  #   OK=0   : Return
  #Endif
  #--Locking SVIC : Example from Locked symbols : SVIC~CDE-2015-5103\10\1000\1000
  SYMBOLE5 = "SVIC"+"~"+[F:SVIC]VCRNUMORI+"\"+"10"+"\"+num$([F:SVIC]VCRLINORI)+"\"+num$([F:SVIC]VCRSEQORI)
  Lock = SYMBOLE5
  If fstat
     # modification en cours sur un autre poste
     GERR=1 : GMESSAGE=mess(511,192,1)-[F:SVIC]VCRNUMORI-mess(162,154,1)-[F:SVIC]ITMREF-":"-mess(10,100,1)
     OK=0   : Return
  Endif

  #-----------------------------------------------
  # Traitement de la ligne de commande à facturer
  #-----------------------------------------------
  Gosub TRT_LIGCDE
  If OK=0
    Unlock = SYMBOLE2
    #TODO add lock on symbole SOQ/SOP/SVIC ?
    #Unlock = SYMBOLE3
    #Unlock = SYMBOLE4
    Unlock = SYMBOLE5
  Endif

  Default File [SIV]

  [M:SIH1]SIHORI=10
  [M:SIH1]STOMVTFLG=1
  Diszo [M:SIH1]STOMVTFLG
  Diszo [M:SIH1]STOFCY

  If GREP<>"C" and GSIHSUPPLIGDSP<>999999 and [M:SIH4]NBLIG > 0
    Local Integer WTEMPDSP : Raz WTEMPDSP
  Call CTLSUPP_EXISTDSP("SIH",[M:SIH4]NBLIG-1,WTEMPDSP) From TRTVENDIV
  If WTEMPDSP=1
      GSIHSUPPLIGDSP +=1
    Endif
  Endif

  Call RECH_ORINUM From SUBSIHB

  #  Local Tinyint PNEWINVCNDSTA : PNEWINVCNDSTA = 5 #--'On invoice'
  #  Gosub SET_SVIC_LIG_INVCNDSTA

Return
#------------------------------------------------------------------------------------------------------
$SET_SVIC_LIG_INVCNDSTA
  If dim(PNEWINVCNDSTA)<1 or find(PNEWINVCNDSTA,1,2,3,4,5,6)=0 : Return : Endif

  #--Setting the VCRINVCNDSTA flag to 5 'On invoice'
  #--First, the global working handler has to be instantiate if not done yet
  If GSIDHYBHANDLE=null
    GSIDHYBHANDLE = NewInstance C_SIDHYBHANDLE AllocGroup null
  Endif
  Local Integer WOK,SIDHYBHANDLER_LINE
  #--Let's find the invoice line's original schedule invoice's index into the GSIDHYBHANDLE class's SVCRINVCND collection, if present
  #--Set the WSIDHYBHANDLER_LINE with record's into the SVCRINVCND collection of GSIDHYBHANDLE
  Gosub GSIDHYBHANDLE_GET_INDEX_WITH_INSTANCE_ADD_USING_M_SIH From LIBSAL_INVCND_SIH #--Because of the different kind of schedule invoice origins
  If SIDHYBHANDLER_LINE<1
     GERR=1 : GMESSAGE=mess(511,192,1)-[F:SVIC]VCRNUMORI-mess(162,154,1)-[F:SVIC]ITMREF-":"
     GMESSAGE -= mess(529,192,1) #'Erreur lors du chargement en mémoire de l'échéancier de facturation'
     OK=0   : Return
  Endif
  WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).SET_LIG_INVCNDSTA([M:SIH4]VCRINVCNDLIN(NOL),PNEWINVCNDSTA)
  If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
    # Error management
#    GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE))
    WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
    If WRET>=[V]CST_AERROR
      GERR = 1
    Endif
#    WRET = func SUBINVCND.RAZMAXMSG(GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE),"SVCRINVCND")
  Endif

Return
#------------------------------------------------------------------------------------------------------
$CTL_SVICD
Local Char    WMES(150)
Local Integer WISOK,WSIGMA,WTEMPSIGMA

  WMES = [F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-format$(GFMDAT,[F:SVICD]NEXINVDAT)

  #--Only 'To be invoiced' type schedule invoice line
  If [F:SVICD]INVCNDSTA>1
    OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(507,192,1)-"'"+mess(1,2419,1)+"'"
    Return
  Endif

  Gosub IS_PICK_ALLOWED
  If OK=0 or GERR>0 : Return : Endif

  #--Check next invoice date ordering (always pick an earlier schedule invoice next invoice date)
  Filter [SVICD99] Where NEXINVDAT <  [F:SVICD]NEXINVDAT and
&                        INVCNDSTA <= 1                  and
&                        VCRTYP     = [F:SVICD]VCRTYP    and
&                        VCRNUMORI  = [F:SVICD]VCRNUMORI and
&                        VCRLINORI  = [F:SVICD]VCRLINORI and
&                        VCRSEQORI  = [F:SVICD]VCRSEQORI
  WISOK=[V]CST_ATRUE
  For [SVICD99]
    #--Were those previous lines picked on the current invoice ?
    WSIGMA=0 : WTEMPSIGMA=0
    If [M:SIH4]NBLIG>0
      WTEMPSIGMA = sigma(0,[M:SIH4]NBLIG-1,
&             ([M:SIH4]SOHNUM      (indcum)=[SVICD99]VCRNUMORI    and
&              [M:SIH4]SOPLIN      (indcum)=[SVICD99]VCRLINORI    and
&              [M:SIH4]VCRINVCNDLIN(indcum)=[SVICD99]VCRINVCNDLIN and
&              [M:SIH4]VCRINVCNDTYP(indcum)=10                    and
&              [M:SIH4]QTY         (indcum)>=[SVICD99]INVCNDQTY )
&      &( WSIGMA=0 and sigma(WSIGMA=1,1,1))) #-- ">=" on QTY is wanted in order to include the extra-billing
      If WTEMPSIGMA=0
        #TODO Here, we'll have to consider the possibility of the present line having been entirely consumed by a increase in the qty
        #of a already picked line and thus, allow the pick without message
        WISOK=[V]CST_AFALSE #--the previous line found is not present on the current invoice
      Endif
    Else
      WISOK=[V]CST_AFALSE #--no previous picked lines and existing schedule line with earlier next invoice date
    Endif

    If WISOK<>[V]CST_ATRUE
  #    OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(512,192,1)-"'"+mess(1,2419,1)+"'"-mess(513,192,1)
  #    GMESSAGE+="\"+mess(514,192,1)
      GERR=2 : GMESSAGE=WMES+"\"+mess(512,192,1)-"'"+mess(1,2419,1)+"'"-mess(513,192,1)
      Break
    Endif
  Next
  Filter [SVICD99]
  If OK=0 or GERR=1 : Return : Endif

  #TODO controlling that the actual picked schedule invoice line did not been consummed partially/totally for a previous line having it's values increded

Return
#------------------------------------------------------------------------------------------------------
$IS_PICK_ALLOWED
Local Shortint WPICK_ALLOWED

  OK=1
  WPICK_ALLOWED=[V]CST_AYES

  #--First, the global working handler has to be instantiate if not done yet
  If GSIDHYBHANDLE=null
    GSIDHYBHANDLE = NewInstance C_SIDHYBHANDLE AllocGroup null
  Endif
  Local Integer WOK,SIDHYBHANDLER_LINE
  #--Let's find the invoice line's original schedule invoice's index into the GSIDHYBHANDLE class's SVCRINVCND collection, if present
  #--Set the WSIDHYBHANDLER_LINE with record's into the SVCRINVCND collection of GSIDHYBHANDLE
  [F:SIV]INVTYP=1 #--For following gosub...
  Gosub GSIDHYBHANDLE_GET_INDEX_USING_F_SIV_SID_SVICD From LIBSAL_INVCND_SIH #--Because of the different kind of schedule invoice origins
  #--No actual instance of the schedule invoice => it means that there were no changes before picking
  If SIDHYBHANDLER_LINE<1 or GERR>0
    WPICK_ALLOWED=[V]CST_AYES
    Return
  Endif

  If [F:SVIC]PRITYP=2
    WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).IS_PICK_ALLOWED([F:SVICD]VCRINVCNDLIN,[F:SVICD]INVCNDQTY,[F:SVICD]INVCNDAMTATI,WPICK_ALLOWED)
  Else
    WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).IS_PICK_ALLOWED([F:SVICD]VCRINVCNDLIN,[F:SVICD]INVCNDQTY,[F:SVICD]INVCNDAMTNOT,WPICK_ALLOWED)
  Endif
  If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
    # Error management
#    GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE))
    WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
    If WRET>=[V]CST_AERROR
      GERR = 1
    Endif
#    WRET = func SUBINVCND.RAZMAXMSG(GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE),"SVCRINVCND")
  Endif

  If WPICK_ALLOWED<>[V]CST_AYES
    OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(527,192,1)+"."-mess(528,192,1)
    Return
  Endif

Return
#------------------------------------------------------------------------------------------------------
$CTL_SVICD_CDE
Local Char    WMES(150), WBPCINV(GLONBPC), WSALFCY(GLONFCY)
Local Char    WBPCGRU(GLONBPC), WBPCPYR(GLONBPC), WVACBPR(GLONTVB), WPJT(GLONPJT)
Local Integer WPRITYP
Local Char SWPJTMSG(250)                                                          : # Dde 71065

  #--WONFAITQUOI contient ce qu'il faut
  Gosub INIT_WONFAITQUOI From SUBSIHC
  Case WONFAITQUOI
      When GBOXSVIC1 : WMES = [F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-format$(GFMDAT,[F:SVICD]NEXINVDAT)
                     WBPCINV = [F:SOH]BPCINV
                     WSALFCY = [F:SOH]SALFCY
                     WBPCGRU = [F:SOH]BPCGRU
                     WBPCPYR = [F:SOH]BPCPYR
                     WPRITYP = [F:SOH]PRITYP
                     WVACBPR = [F:SOH]VACBPR
                     WPJT    = [F:SOH]PJT
      When Default
  Endcase

  #--------------------------------------------------------------------------------#
  # La ligne d'échéancier de facturation sélectionnés ne doit pas être déjà sélectionnée  #
  #--------------------------------------------------------------------------------#

  For I=0 To [M:SIH4]NBLIG-1
    #--WONFAITQUOI contient ce qu'il faut
    Case WONFAITQUOI
      When GBOXSVIC1 :
           If [F:SVICD]VCRNUMORI=[M:SIH4]SOHNUM(I) & [F:SVICD]VCRLINORI=[M:SIH4]SOPLIN(I) & [M]CREFLG(I)=0
             If [F:SVICD]VCRINVCNDLIN=[M:SIH4]VCRINVCNDLIN(I)
               OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(506,192,1)
               Break
             Endif
           Endif
      When Default
     Endcase
  Next I
  If OK=0 Return Endif

  #-----------------------------------------#
  #  Contrôle des critéres de regroupement  #
  #-----------------------------------------#
  If WBPCINV<>[M:SIH0]BPCINV | ([M:SIH1]BPRPAY<>"" & WBPCPYR<>[M:SIH1]BPRPAY) |
&    ([M:SIH1]BPCGRU<>"" & WBPCGRU<>[M:SIH1]BPCGRU)
     OK=0 : GERR=1
     GMESSAGE=WMES+"\"+mess(101,192,1)+"\"+mess(102,192,1)
     Return
  Endif
  If WSALFCY<>[M:SIH0]SALFCY
     OK=0 : GERR=1
     GMESSAGE=WMES+"\"+mess(101,192,1)+"\"+mess(103,192,1)
     Return
  Endif

  #--WONFAITQUOI
  Case WONFAITQUOI
    When GBOXSVIC1 :
                If [F:SOH]PLISTC<>[M:SIH0]PLISTC
                   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(101,192,1)+"\"+mess(305,192,1)
                   Return
                Endif
                If (dim([M]BPIEECNUM)>0 &[F:SOH]BPIEECNUM<>[M]BPIEECNUM) | [F:SOH]EECICT<>[M]EECICT
                   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(101,192,1)+"\"+mess(303,192,1)
                   Return
                Endif
                If dim([M]EECLOC)>0 & [F:SOH]EECLOC<>[M]EECLOC
                   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(101,192,1)+"\"+mess(304,192,1)
                   Return
                Endif
                If [F:SOH]CUR<>[M:SIH2]CUR | [F:SOH]PTE<>[M:SIH2]PTE |
&                     ([M:SIH2]DEP<>"" & [F:SOH]DEP<>[M:SIH2]DEP)
                   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(101,192,1)+"\"+mess(104,192,1)
                   Return
                Endif
                If [F:SOH]BETFCY<>[M:SIH1]BETFCY | [F:SOH]BETCPY<>[M:SIH1]BETCPY
                   OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(101,192,1)+"\"+mess(102,192,1)
                   Return
                Endif
                # Factures inter-sociétés
                If [M]BETFCY=2
                    # Pas de cdes créés manuellement avec des cdes créés automatiquement
                    If [F:SOH]ORIFCY=[F:SOH]SALFCY & [M]ORIFCY<>[M]SALFCY
                       OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(180,191,1)+":\"+mess(172,191,1)-mess(182,191,1)
                       Return
                    Endif
                    # Pas de cdes créés automatiquement avec des cdes créés manuellement
                    If [F:SOH]ORIFCY<>[F:SOH]SALFCY & [M]ORIFCY=[M]SALFCY
                       OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(181,191,1)+":\"+mess(178,191,1)
                       Return
                    Endif
                Endif
      When Default
  Endcase

  If WPRITYP<>[M:SIH1]PRITYP | WVACBPR<>[M:SIH1]VACBPR
      OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(101,192,1)+"\"+mess(105,192,1)
      Return
  Endif

  # LTA.sn 79065
  If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2 & [M:SIH4]NBLIG>0 & [F:SOH]SSTENTCOD<>[M:SIH1]SSTENTCOD & find(WONFAITQUOI,GBOXSO3,GBOXSVIC1)>0  # 106867.n
    OK=0 : GERR=1
    GMESSAGE=func AFNC.MES2(mess(374,192,1), [F:SOH]SOHNUM, [F:SOH]SSTENTCOD)
    Return
  Endif
  # LTA.en 79065

  #-----------------------------------------------------------

  #----------------------------------#
  # Contrôle des liens cde/liv/fac   #
  #----------------------------------#
  #--CPO vu mail CH 07/03/2016 à enlever
  ## 1 facture/commande(soldée) ou 1 commande/BL
  #If [M:SIH0]IME<=3 & YSOHNUM<>"" & [F:SOH]SOHNUM<>YSOHNUM
  #   OK=0 : GERR=1
  #   GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(55,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
  #   Return
  #Endif
  ## Si une facture par client livré
  #If [M:SIH0]IME=4 & ([F:SOQ]BPCORD<>[M:SIH1]BPCORD | [F:SOQ]BPAADD<>[M:SIH1]BPAADD)
  #   OK=0 : GERR=1
  #   GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-format$(GFMDAT,[F:SOQ]SHIDAT)
  #&           +"\"+mess(101,192,1)+"\"+mess(192,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
  #   Return
  #Endif
  #--/CPO

  #--Il faut avant tout voir si le contrat à l'origine de la facture
  #--n'a pas fait l'objet d'autres factures
  Local Tinyint WEXIST_PREV_INV, WEXIST_PREVPICKED

  WEXIST_PREV_INV = func SVIC_CHECK_EXIST_PREV_INV([F:SOH]SOHNUM,[M:SIH0]NUM,WEXIST_PREVPICKED)

  # Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management
  #-- Normal order -> Invoices (by using a scheduling invoice)
  # Controle du champ GRUFLG :
  # Si Oui (1), pas de restriction
  #  Sinon (2), vérifier que les éléments en % ont la meme valeur
  Local Integer I2
  Local Decimal DTAAMTCMP
  Local Char    TSTRUL
  For I=0 To dim([F:SOH]INVDTA) - 1
      If [F:SOH]INVDTA(I) = 0 : Break : Endif
      If [F:SOH]INVDTATYP(I) = 3 : # %
          # Recherche Param concernant Doc Ori et Dest
          TSTRUL = num$([F:SOH]INVDTA(I)) + "~10~4"
          I2=find(TSTRUL, [M:SFIT]T_TST_RUL(0..[M:SFIT]NBSFIT-1))-1

          If I2>=0 and [M:SFIT]T_GRUFLG(I2) = 2
              If [M:SFIT]T_BRDRUL(I2)=3 and ([F:SOH]INVSTA<>1 or WEXIST_PREV_INV=[V]CST_ATRUE): # eclaté sur 1ere facture et deja partiellement ou totalement facturée
                  DTAAMTCMP=0
              Else
                  DTAAMTCMP=[F:SOH]INVDTAAMT(I)
              Endif

              I2 = find ([F:SOH]INVDTA(I), [M:SIH2]INVDTA(0..[M:SIH2]NBFAC-1))
              #--Avant de positionner l'erreur, il faut être sûrs qu'il ne s'agisse pas de la même cde
              #--si nous sommes en cours de création
              #--Cas des lignes d'échéanciers de la même cde, pickées à la suite...
              #--WEXIST_PREVPICKED=[V]CST_ATRUE
              If I2>0 and [M:SIH2]INVDTAAMT(I2-1) <> DTAAMTCMP and WEXIST_PREVPICKED<>[V]CST_ATRUE
                  OK=0 : GERR=1
                  # Pour cet élément de facturation, le regroupement avec des valeurs différentes est interdit (xxx)"
                  Local Char SHOAXX
                  Call LECTEXTRA([L]SHOAXX,"SFOOTINV","SHOAXX",num$([F:SOH]INVDTA(I)),"") From ATEXTRA
                  GMESSAGE = mess(327,192,1) + " (" + [L]SHOAXX + ")"
                  #GMESSAGE+= num$([M:SIH2]INVDTAAMT(I2-1))+"<>"+num$(DTAAMTCMP)
                  Break
              Endif
          Endif
      Endif
  Next I
  #--/

  #--Controle des codes adresses client commande et facture
  If ([F:SOH]BPAINV<>[M:ADB3]BPAADD)
      OK=0 : GERR=1
      GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&         format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(101,192,1)+"\"+mess(329,192,1)
      Return
  Endif

Return
#------------------------------------------------------------------------------------------------------
#--------------------------------------------------------------------------------#
# Contrôle de la ligne d'échéance de facturation sélectionnée                    #
# Elle doit être facturable                                                      #
#--------------------------------------------------------------------------------#
$CTL_SVICD_CDE_LIG
Local Char SWPJTMSG(250)

  # Ligne gérée en contremarque et commande d'achat non générée
  If find([F:SOQ]FMI,2) & [F:SOQ]FMINUM=""
     If [F:SOQ]ALLQTY=0
         OK=0 : GERR=1
         GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&                 format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(111,192,1)
         Return
     Else
         WOK=1
         Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&                format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(160,197,1)+"\"+mess(147,191,1),WOK) From GESECRAN
         If WOK=1 OK=0 : Return Endif
     Endif
  Endif
  #--All other values are forbiden
  If [F:SOQ]FMI>2
         OK=0 : GERR=1
         GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&                 format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(508,192,1)-","-mess(509,192,1)-":'"+mess([F:SOQ]FMI,445,1)+"'"-mess(510,192,1)
         Return
  Endif
  ## Ligne gérée en contremarque réceptionnée et pas de quantité allouée
  #If [F:SOQ]FMI=3 & [F:SOQ]ALLQTY=0 & [F:SOQ]STOMGTCOD>1
  #   WOK=1
  #   Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-format$(GFMDAT,[F:SOQ]SHIDAT)
  #&              +"\"+mess(65,192,1),WOK) From GESECRAN
  #   If WOK=1 OK=0 : Return Endif
  #Endif
  ## Ligne gérée avec un ordre de production et OF non généré
  #If [F:SOQ]FMI=5 & [F:SOQ]FMINUM=""
  #   If [F:SOQ]ALLQTY=0
  #       OK=0 : GERR=1
  #       GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
  #&               format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(138,192,1)
  #       Return
  #   Else
  #       WOK=1
  #       Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
  #&              format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(201,197,1)+"\"+mess(147,191,1),WOK) From GESECRAN
  #       If WOK=1 OK=0 : Return Endif
  #   Endif
  #Endif
  #
  ## Ligne gérée avec un ordre de production et pas de quantité allouée
  #If [F:SOQ]FMI=5 & [F:SOQ]ALLQTY=0
  #   WOK=1
  #   Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-format$(GFMDAT,[F:SOQ]SHIDAT)
  #&              +"\"+mess(124,192,1),WOK) From GESECRAN
  #   If WOK=1 OK=0 : Return Endif
  #Endif
  ## Si livraison ligne cde complète et ligne cde non allouée totalement
  #If [F:SOH]DME=2 & (WQTY+[F:SOQ]ODLQTY+[F:SOQ]DLVQTY < [F:SOQ]QTY)
  #   WOK=1
  #   #-- X3Suivi 61125 : Param utilisateur livraison commande complète --#
  #   Gosub TEST_LIVR_PARTIELLE
  #   If WOK=1 :
  #     If WMESS1 <> '' : GMESSAGE=WMESS1 : Endif
  #     OK=0 : Return
  #   Endif
  #Endif

  # --------------------------------------
  #--CPO vu mail CH 07/03/2016 à enlever
  #Local Integer LRET
  #
  #  If [M:SIH0]INVTYP = 1 Then
  #    If dim([M:SIH4]ECCVALMAJ) >= 0 Then
  #      Call CTLECCVAL([F:SOQ]ECCVALMAJ, [F:SOQ]STOFCY, [F:SOQ]ITMREF, 4, "", [M:SIH0]INVDAT, LRET) From STKSOR
  #      If LRET >= 1 Then
  #        Raz OK
  #        Return
  #      Endif
  #    Endif
  #    #
  #    If dim([M:SIH4]ECCVALMIN) >= 0 Then
  #      Call STKCTRECC([F:SOQ]ITMREF, [F:SOQ]ECCVALMAJ, [F:SOQ]ECCVALMIN, "", 4) From STKACT
  #      If mkstat Then
  #        Raz OK
  #        Return
  #      Endif
  #    Endif
  #  Endif
  # --------------------------------------

Return
#------------------------------------------------------------------------------------------------------
###########################################################################
# TRT_LIGCDE    Traitement de la ligne commande à facturer                #
#-------------------------------------------------------------------------#
# Utilisation : picking commande depuis la gestion des factures           #
#               bouton  facture  depuis la gestion des commandes          #
###########################################################################
$TRT_LIGCDE
#Local Integer WRUP   : # Génération des ruptures (0=non / 1=oui)
Local Integer WRET
#Local Integer WSTA, WA, WQ, WR
#Local Integer WSTOSEQ
Local Integer WSAU_UOMDEC
Local Decimal WQTY, WQTYSTU, WQTYARR #, WSTUDIS, WQTA
#Local Decimal WQTYCPE, WQTYSTUCPE, WCOECPE
Local Char    WSAU(GLONUOM)
Local Decimal WSAUSTUCOE
#Local Decimal WSVGQTYSTU
Local Integer WNEGSTO

  # FGR 30/11/2011 : X3SUIVI71065 (début)
  Local Char SWPJTMSG(250)

  If func TRTPJT.IS_PJT_AVAILABLE([F:SOQ]PJT, "[M:SIH4]DPJT", SWPJTMSG) = G_NON Then
    Call PJT_ADD_MSG([F:SOQ]PJT, SWPJTMSG) From TRTPJT
    OK = 0
    Return
  Endif
  # FGR 30/11/2011 : X3SUIVI71065 (fin)

  WNEGSTO = [F:ITM]NEGSTO

  #TODO As the orignal picked line is a schedule invoice, it means that existing specific code would have to adapt
  #Better comment the GPOINT for now
  #GPOINT = "TRT_LIGCDE" : Gosub ENTREE From EXEFNC

  WSAUSTUCOE = [F:SOP]SAUSTUCOE
  WSAU       = [F:SOP]SAU
  If WSAUSTUCOE=0 WSAUSTUCOE=1 Endif

  #----------------------------------------
  # Détermination de la quantité à facturer
  #----------------------------------------

  #Raz WRUP
  ## Qté facturée = qté restant à facturer sauf
  ## si article géré en stock ou article non géré en stock et quantité allouée <> 0
  #WQTY    = [F:SOQ]QTY - ([F:SOQ]ODLQTY + [F:SOQ]INVQTY)
  #WQTYSTU = [F:SOQ]QTYSTU - ([F:SOQ]ODLQTYSTU + [F:SOQ]INVQTYSTU)
  #
  ## Si proforma
  #If [M:SIH0]INVTYP=5
  #   Goto TRT_LIGCDE_SUI
  #Endif
  ## Si article non géré en stock et non composé d'un kit/sous-traité
  #If [F:SOQ]STOMGTCOD=1 & !find([F:SOP]LINTYP,2,10)
  #   If [F:SOQ]TDLQTY<>0
  #      WQTY    = [F:SOQ]TDLQTY
  #      WQTYSTU = [F:SOQ]TDLQTYSTU
  #   Endif
  #Endif

  WQTY    = [F:SVICD]INVCNDQTY
  #--As the stock quantity is not on the invoice schedule line, we have to re-compute
  WSAU_UOMDEC = 0
  Read [TUNSAU]TUN0=[F:SOP]STU
  If fstat : Raz [F:TUNSAU] : Endif
  WSAU_UOMDEC = [F:TUNSAU]UOMDEC
  WQTYSTU = arr(WQTY*WSAUSTUCOE,10^(-WSAU_UOMDEC))
  #--

$TRT_LIGCDE_SUI
#--- La sélection est correcte

  Gosub SVIC_ORISOH_SIH_PLUS From SUBSFIT #-- Normal order -> Invoices (by using a scheduling invoice)
  If GERR = 1 Then
    Raz OK
    Call ERREUR(GMESSAGE) From GESECRAN
    Return
  Endif

  # Ouverture de la ligne
  nolign = [M:SIH4]NBLIG
  Insa nolign,1,[M:SIH4]NBLIG [M:SIH4]NBLIG
  [M:SIH4]NBLIG += 1
  nolign = [M:SIH4]NBLIG
  NOL = nolign-1
  status = 0

  # Alimentation de la classe [M:SIH4] de la ligne
  Call ALI_SVICD_SOQSIH(NOL,WQTY,WQTYSTU) From LIBSAL_INVCND_SIH_PICK

  Call LINNUM("SIDLIN") From TABLEAUX

  # Calculs prix net, marge et maj montants livrés et poids
  GNETMAR=0
  Call ALICLCAMT([M:SIH4]ITMREF(NOL),[M:SIH4]QTY(NOL),NOL,"SIH4",
&                [M:SIH4]CLCAMT1(NOL),[M:SIH4]CLCAMT2(NOL)) From TRTX3
  #--Pas de calcul prix net : Il faut garder le prix net de la cde
  #--(Si frais/remise dépendant de la qté (par ligne) et plusieurs fac.,le prix net doit être le même sur chaque fac.)
  Call CLCPFM   ([M:SIH4]DSTOFCY(NOL),[M:SIH1]PRITYP,[M:SIH0]CHGTYP,
&                [M:SIH0]INVDAT,[M:SIH2]CUR,NOL,1) From TRTVENPRI
  Call APRES_LIGNE(NOL,0) From SUBSIHB
  GNETMAR=1

  nolign  = NOL+1

  Local Tinyint PNEWINVCNDSTA : PNEWINVCNDSTA = 5 #--'On invoice'
  Gosub SET_SVIC_LIG_INVCNDSTA

Return
#------------------------------------------------------------------------------------------------------
#$TEST_LIVR_PARTIELLE
#   Local Char WMESS1 (100)
#   If [F:SOQ]ODLQTY+[F:SOQ]DLVQTY<>0
#      #-- X3Suivi 61125 : Param utilisateur livraison commande complète --#
#      #-- La quantité à livrer < au reste à livrer & livraison ligne doit être complète
#     If GLOKSDHPRT=2
#       WMESS1 = [F:SOH]SOHNUM-mess(27,159,1)-":"-[F:SOQ]ITMREF-mess(184,197,1)-":"- format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(57,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
#     Else
#       #-- Voulez-vous forcer la livraison ?
#       Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-":"-[F:SOQ]ITMREF-mess(184,197,1)-":"-
#&                  format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(57,192,1)-"\"-mess(146,191,1),WOK) From GESECRAN :#--CPO 83985 GFMDAT au lieu de GFMD
#     Endif
#   Else
#     #-- La quantité à livrer < la quantité commandée & livraison ligne doit être complète
#     If GLOKSDHPRT=2
#       WMESS1 = [F:SOH]SOHNUM-mess(27,159,1)-":"-[F:SOQ]ITMREF-mess(184,197,1)-":"- format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(297,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
#     Else
#       #-- Voulez-vous forcer la livraison ?
#       Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-":"-[F:SOQ]ITMREF-mess(184,197,1)-":"-
#&                  format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(297,192,1)-"\"-mess(146,191,1),WOK) From GESECRAN :#--CPO 83985 GFMDAT au lieu de GFMD
#     Endif
#   Endif
#
#Return
#------------------------------------------------------------------------------------------------------
$REAJUSTE_QTY
#---------------------------------------------
# TS : réajustement qté en unité vente entière
#---------------------------------------------

GPOINT = "NO_REAJUST" : Gosub ENTREE From EXEFNC
If GOK=0 : GOK=1 :  Return : Endif

If WSAU<>[F:ITM]STU
   WQTYARR = WQTY
   Call QTEARR(WQTYARR,WSAU) From TRTDIV
   If WQTYARR=WQTY Return Endif

   Call CTRQTYPCU(WSAU,WSAUSTUCOE,WQTYSTU,WQTYARR) From STKLIB
   If WQTYARR<>WQTYSTU
      WQTYSTU = WQTYARR
      WQTY    = WQTYSTU/WSAUSTUCOE
   Endif
Endif

Return
#---------------------------------------------
#------------------------------------------------------------
# Alimentation des masques SIH à partir de la 1ère commande
#------------------------------------------------------------
Subprog ALI_SVICD_SOHSIH ()
Local  Integer  I, NBPOSTE
Local  Char     SECTION, WALI(3)
Local  Char     CODCPT(GLONCAC)
Local  Char     SMESSAGE(80)

  nolign=1
  Local Char EXCLI(GLONBPC) : EXCLI=[M:SIH0]BPCINV
  Local Char EXCUR(GLONCUR) : EXCUR=[M:SIH0]CUR

  [M:SIH0] = [F:SOH]
  [M:SIH1] = [F:SOH]
  [M:SIH2] = [F:SOH]

  [M:SIH0] = [F:SVIC]
  [M:SIH1] = [F:SVIC]
  [M:SIH2] = [F:SVIC]
  GBPCNUM  = [F:SVIC]BPCORD

  #--Le transclasse va initialiser les champs DSPTOTQTY/DSPTOTWEI/DSPTOTVOL avec les valeurs inscrite dans le SOH
  #--On doit les Raz car ces champs sont mis à jour dans les ss-pros appelés par les avant et après lignes
  Raz [M:SIH0]DSPTOTQTY ,[M:SIH0]DSPTOTVOL, [M:SIH0]DSPTOTWEI

  If EXCLI<>[M:SIH0]BPCINV or EXCUR<>[M:SIH0]CUR
      Call NEW_SFIT ("M","SIH2",[M:SIH0]CUR,[M:SIH0]BPCINV,[F:SOH]BPCORD,[M:SIH0]INVDAT) From SUBSFIT
  Endif
  #-/
  [M:SIH1]STOFCY    = [F:SOQ]STOFCY
  [M:SIH1]BPAADD    = [F:SOQ]BPAADD

  If func TRTPJT.IS_PJT_AVAILABLE([M:SIH1]PJT, "[M:SIH1]PJT", SMESSAGE) = G_NON Then
    Call PJT_ADD_MSG([M:SIH1]PJT, SMESSAGE) From TRTPJT
    Raz [M:SIH1]PJT
  Endif
  # FGR 24/11/2011 X3SUIVI71065 (fin)

  #----------------------------------------------------#
  # Chargement libellés et formats colonnes tarif      #
  #----------------------------------------------------#
  # Alimentation concernant les colonnes frais/remises en fonction de la structure tarif de la société
  Call ALICOLREM (1,5,GFLAG,"SIH4",[M:SIH2]CUR,0,[M:SIH0]PLISTC) From TRTPRICE

  # Positionnement sur client facture de la facture
  If [M:SIH0]BPCINV<>[F:BPC]BPCNUM
     Read [BPC]BPC0=[M:SIH0]BPCINV
  Endif

  # 102423 : Belgium Early discounts
  # Early discount rate determination
  If find(GDEPMGTMOD, 1,5)
      Call ALIDISVAT (5, [M:SIH2]DEP, GBIDI1, [M:SIH2]DEPRAT) From SUBTDA
  Endif
  #  102423

  # Alimentation adresse facture
  Raz [M:SIH0]BPAINV
  # Si client cde <> client en ligne (client fac de la facture)
  If GBPCNUM<>[F:BPC]BPCNUM
     Read [BPC]BPC0=GBPCNUM
     # Si client fac de la facture = client fac du client cde de la facture
     If !fstat
        If [M:SIH0]BPCINV=[F:BPC]BPCINV
           [M:SIH0]BPAINV = [F:BPC]BPAINV
        Endif
     Endif
     # Repositionnement sur client facture de la facture
     Read [BPC]BPC0=[M:SIH0]BPCINV
  Endif

  Call ALI_PRTMOD("SIH0",5) From TRTX3
  If [M:SIH0]COPNBR=0
     [M:SIH0]COPNBR=1
  Endif

  # ---   Suivi texte facture du client sur entete facture
  If GSALTEXINV = 1 & [F:BPC]INVTEX <> ""
     [M:SIH0]SIHTEX1 = [F:BPC]INVTEX
  Elsif GSALTEXINV = 2 & [F:BPC]INVTEX <> ""
  # ---   Suivi texte facture du client sur pied facture
     [M:SIH0]SIHTEX2 = [F:BPC]INVTEX
  Endif

  If [M:SIH0]BPAINV=""
     # Si client fac de la facture = client fac du client fac de la facture
     If [M:SIH0]BPCINV=[F:BPC]BPCINV
        [M:SIH0]BPAINV    = [F:BPC]BPAINV
     Else
        [M:SIH0]BPAINV    = [F:BPC]BPAADD
     Endif
  Endif

  Read [TMD]TMD0 = [F:SOH]MDL
  If  fstat : Raz [F:TMD] : Endif

  If dim([M:SIH0]EECNAT)>0 & [M:SIH0]INVTYP<>5
     [M:SIH0]EECTRN    = [F:TMD]EECTRN
  Endif

  [M:SIH1]STOMVTFLG = 1

  [M:SIH1]INVSTA    = 1 : [M:SIH1]STARPT = 1

  [M:SIH1]SIHORI    = 10 #TODO See what was done while SIHORI=2 Orders
  [M:SIH1]SIHORINUM = [F:SOH]SOHNUM
  [M:SIH1]SIHORIDAT = [F:SOH]ORDDAT
  [M:SIH0]INVREF    = [F:SOH]CUSORDREF

  [M:SIH1]BPRPAY    = [F:SOH]BPCPYR

  [M:SIH2]STRDUDDAT = [M:SIH0]INVDAT

  [M:SIH2]CURTYP    = [F:SOH]CHGTYP
  If dim([M:SIH2]BPRFCT) > 0 [M:SIH2]BPRFCT = [F:BPC]FCTNUM Endif

  # Initialisation du collectif
  Call INIT_COMPTE([F:BPC]BPCNUM,GSOCIETE,"C",CODCPT) From CPTSUB
  Call LECTURE("CAC",[L]CODCPT,"2~"+GCOA(GTYPGEN)) From CONTOBJ
  If [F:CAC]ACC(0)<>""
     Call LECTURE("GAC",[F:CAC]ACC(0),GCOA(GTYPGEN)) From CONTOBJ
     If !fstat & [F:GAC]SAC=2
         [M:SIH2]BPRSAC = [F:GAC]ACCSHO
     Else
         [M:SIH2]BPRSAC = ""
     Endif
  Endif

  #----- Chargement zones devises et cours -----#
  Call INI_COURS("SIH2",GSOCIETE,[M:SIH2]CUR,[M:SIH0]INVDAT,[M:SIH2]CURTYP) From SUBBICS

  For I= 0 To dim([M:SIH2]INVDTAAMT) - 1
      Raz [M:SIH2]INVDTAAMT(I)
      Raz [M:SIH2]INVDTA(I)
      Raz [M:SIH2]INVDTATYP(I)
  Next

  WALI = "OUI"
  # Init. du tableau des éléments de facturation
  NBPOSTE = dim([M:SIH2]INVDTA)
  Call STRUFOOT (7,"SIH2",NBPOSTE,[M:SIH2]CURTYP,[F:SOH]CUR,[M:SIH2]CUR,WALI) From SUBSFIT

  [M:SIH2]NBFAC = NBPOSTE

  # --- adresse client facture
  [M:ADB3]BPAADD       = [F:SOH]BPAINV
  [M:ADB3]ADBBPR       = [F:SOH]BPCINV
  [M:ADB3]BPRNAM(0)    = [F:SOH]BPINAM(0)
  [M:ADB3]BPRNAM(1)    = [F:SOH]BPINAM(1)
  [M:ADB3]BPAADDLIG(0) = [F:SOH]BPIADDLIG(0)
  [M:ADB3]BPAADDLIG(1) = [F:SOH]BPIADDLIG(1)
  [M:ADB3]BPAADDLIG(2) = [F:SOH]BPIADDLIG(2)
  [M:ADB3]POSCOD       = [F:SOH]BPIPOSCOD
  [M:ADB3]CTY          = [F:SOH]BPICTY
  [M:ADB3]SAT          = [F:SOH]BPISAT
  [M:ADB3]CRY          = [F:SOH]BPICRY
  [M:ADB3]CRYNAM       = [F:SOH]BPICRYNAM
  [M:ADB3]CNTNAM       = [F:SOH]CNINAM

  If [M:ADB3]BPRNAM <> "" |  [M:ADB3]BPAADDLIG <> "" |
&    [M:ADB3]POSCOD <> "" |  [M:ADB3]CTY <> ""      |
&    [M:ADB3]SAT    <> "" |
&    [M:ADB3]CRY    <> "" |  [M:ADB3]CRYNAM <> ""
      [M:ADB3]ADBFLG = 3
  Else
      [M:ADB3]ADBFLG = 0
  Endif

  # --- adresse livraison
  # Alimentation code adresse (client livré) dans [M:ADB2] pour saisie adresse libre
  If dim([M:ADB2]BPAADD) > 0
      [M:ADB2]BPAADD   = [F:SOH]BPAADD
  Endif
  [M:ADB2]ADBBPR       = [F:SOH]BPCORD
  [M:ADB2]BPRNAM(0)    = [F:SOH]BPDNAM(0)
  [M:ADB2]BPRNAM(1)    = [F:SOH]BPDNAM(1)
  [M:ADB2]BPAADDLIG(0) = [F:SOH]BPDADDLIG(0)
  [M:ADB2]BPAADDLIG(1) = [F:SOH]BPDADDLIG(1)
  [M:ADB2]BPAADDLIG(2) = [F:SOH]BPDADDLIG(2)
  [M:ADB2]POSCOD       = [F:SOH]BPDPOSCOD
  [M:ADB2]CTY          = [F:SOH]BPDCTY
  [M:ADB2]SAT          = [F:SOH]BPDSAT
  [M:ADB2]CRY          = [F:SOH]BPDCRY
  [M:ADB2]CRYNAM       = [F:SOH]BPDCRYNAM
  [M:ADB2]CNTNAM       = [F:SOH]CNDNAM

  If [M:ADB2]BPRNAM <> "" | [M:ADB2]BPAADDLIG <> "" |
&    [M:ADB2]POSCOD <> "" | [M:ADB2]CTY <> ""      |
&    [M:ADB2]SAT    <> "" |
&    [M:ADB2]CRY    <> "" | [M:ADB2]CRYNAM <> ""
    [M:ADB2]ADBFLG = 3
  Else
      [M:ADB2]ADBFLG = 0
  Endif
  If func AFNC.ACTIV("LTA") and dim([M:ADB2]ADRVAL) > 0 #LTA.sn
    [M:ADB2]ADRVAL = [F:SOH]ADRVAL
  Endif                                                 #LTA.en

  # Chargement des sections analytiques entête facture à partir de l'entête commande ou contrat
  Call CHARG_CCEH("SIH2","NBAXE","SOH") From TRTX3CPT

  # On complète les sections vides
  If dim([M:SIH2]NBAXE)>0
    [M:SIH2]NBAXE=GNBDIE
    For I=1 To GNBDIE
      If [M:SIH2]CCE(I-1)=""
        [M:SIH2]DIE(I-1)=GDIE(I)
        Call INISEC(SECTION,"SIH",GDIE(I)) From SUBCDE
        [M:SIH2]CCE(I-1)=SECTION
      Endif
    Next I
  Endif

End
#------------------------------------------------------------------------------------------------------
#----------------------------------------------------------------
# Alimentation des masques SIH à partir d'une ligne de commande
#----------------------------------------------------------------
Subprog ALI_SVICD_SOQSIH (NOL,WQTAFAC,WQTAFACSTU)

Value Integer NOL
Value Decimal WQTAFAC
Value Decimal WQTAFACSTU

Local Integer I

  [M:SIH4] = [F:SOQ]
  [M:SIH4] = [F:SOP]
  [M:SIH4] = [F:SVICD]

  #--SIDORI (same local menu as the header SIHORI)
  #--VCRINVCNDTYP (the schedule invoice line's original document; VCRTYP)
  [M:SIH4]SIDORI   (NOL) = 10 #--'Invoice schedule'
  [M:SIH4]VCRINVCNDTYP(NOL) = [F:SVICD]VCRTYP
  [M:SIH4]INVPRC      (NOL) = [F:SVICD]INVPERCENT

  # --------------------------------------
  # FGR 21/04/2015 : X3SUIVI105605 (début) ici pour ne le faire que sur les proforma
  #TODO No value for these fields
  #If [M:SIH0]INVTYP = 5 Then
  If dim([M:SIH4]ECCVALMAJ) >= 0 Then
    Raz [M:SIH4]ECCVALMAJ(NOL)
  Endif
  If dim([M:SIH4]ECCVALMIN) >= 0 Then
    Raz [M:SIH4]ECCVALMIN(NOL)
  Endif
  #Endif
  # FGR 21/04/2015 : X3SUIVI105605 (fin)
  # --------------------------------------

  If dim([M:SIH4]STRDAT)>0 [M:SIH4]STRDAT(NOL)=[F:SVICD]PERFROM Endif
  If dim([M:SIH4]ENDDAT)>0 [M:SIH4]ENDDAT(NOL)=[F:SVICD]PERTO   Endif

  If [M]BETFCY=2 & [M]ORIFCY="" [M]ORIFCY=[F:SOH]ORIFCY : Endif

  If dim([M:SIH4]LOT)>0 Raz [M:SIH4]LOT(NOL) Endif
  If dim([M:SIH4]LOC)>0 Raz [M:SIH4]LOC(NOL) Endif
  If dim([M:SIH4]STA)>0 Raz [M:SIH4]STA(NOL) Endif

  #TODO here there won't be an allocation; set to global
  [M:SIH4]ALLTYP(NOL)  = 1 #2
  [M:SIH4]DSTOFCY(NOL) = [F:SOQ]STOFCY

  [M:SIH4]DPJT(NOL)    = [F:SOQ]PJT  # FGR 24/11/2011 X3SUIVI71065

  [M:SIH4]LOTFIL(NOL)  = [F:SOQ]LOT
  [M:SIH4]STAFIL(NOL)  = [F:SOQ]STA
  [M:SIH4]LOCFIL(NOL)  = [F:SOQ]LOC

  [M:SIH4]VACITM1(NOL) = [F:SOP]VACITM(0)
  [M:SIH4]VACITM2(NOL) = [F:SOP]VACITM(1)
  [M:SIH4]VACITM3(NOL) = [F:SOP]VACITM(2)
  [M:SIH4]VAT1(NOL)    = [F:SOP]VAT(0)
  [M:SIH4]VAT2(NOL)    = [F:SOP]VAT(1)
  [M:SIH4]VAT3(NOL)    = [F:SOP]VAT(2)
  If dim([M:SIH4]TSICOD1(NOL))>0 [M:SIH4]TSICOD1(NOL)=[F:SOP]TSICOD(0) Endif
  If dim([M:SIH4]TSICOD2(NOL))>0 [M:SIH4]TSICOD2(NOL)=[F:SOP]TSICOD(1) Endif
  If dim([M:SIH4]TSICOD3(NOL))>0 [M:SIH4]TSICOD3(NOL)=[F:SOP]TSICOD(2) Endif
  If dim([M:SIH4]TSICOD4(NOL))>0 [M:SIH4]TSICOD4(NOL)=[F:SOP]TSICOD(3) Endif
  If dim([M:SIH4]TSICOD5(NOL))>0 [M:SIH4]TSICOD5(NOL)=[F:SOP]TSICOD(4) Endif

  Raz [M:SIH4]SIDLIN(NOL), [M:SIH4]ORILIN(NOL)

  [M:SIH4]XSERMGTCOD(NOL) = [F:ITM]SERMGTCOD

  # ---   Suivi texte détail cde sur fac : Duplication
  Local Integer WRET
  If find (GSALTEXLIN,5)
      [M:SIH4]SIDTEX(NOL) = [F:SOQ]SOQTEX
      If left$([F:SOQ]SOQTEX,3)="SOQ"
         Call DUP_CLOB("SID",[M:SIH4]SIDTEX(NOL),WRET) From TRTX3TEX
         If WRET<1 Raz [M:SIH4]SIDTEX(NOL) Endif
      Endif
  Endif
  # ---   Suivi texte sur fac : Recherche texte article et duplication
  If find (GSALTEXLIN,3)
     [M:SIH4]SIDTEX(NOL) = [F:ITU]ITSTEX
     If [M:SIH4]SIDTEX(NOL)=""
        [M:SIH4]SIDTEX(NOL) = [F:ITS]ITSTEX
     Endif
  Endif

  [M:SIH4]QTY(NOL)     = WQTAFAC
  [M:SIH4]QTYSTU(NOL)  = WQTAFACSTU

  [M:SIH4]YQTY(NOL)    = [M:SIH4]QTY(NOL)
  [M:SIH4]YQTYSTU(NOL) = [M:SIH4]QTYSTU(NOL)
  # Chargement de la quantité pour calcul de qté en nomenclature
  [M:SIH4]CQTY(NOL)    = [M:SIH4]QTY(NOL)

   # Si on a une base de calcul de taxe, c'est qu'il y a une formule
   Local    Decimal  WANC_CLCAMT1, WANC_CLCAMT2
   WANC_CLCAMT1=[M:SIH4]CLCAMT1(NOL) : WANC_CLCAMT2=[M:SIH4]CLCAMT2(NOL)
   If [M:SIH4]CLCAMT1(NOL)<>0 | [M:SIH4]CLCAMT2(NOL)<>0
      # Recalcul des montants de base calcul de taxe (peuvent être dépendant de la qté)
      Call ALICLCAMT([M:SIH4]ITMREF(NOL), [M:SIH4]QTY(NOL), NOL, "SIH4", [M:SIH4]CLCAMT1(NOL), [M:SIH4]CLCAMT2(NOL)) From TRTX3
   Endif
   # Recalcul des taxes systématique avec [M]INVDAT (au cas où le taux ait changé entre date cde et date facture)
   Local Date WDATCONVPRI
   WDATCONVPRI=[M:SIH0]INVDAT
   If [M:SIH1]PRITYP=1
      [M:SIH4]NETPRINOT(NOL) = [M:SIH4]NETPRI(NOL)
      Call CLCTAXEPRIV([M:SIH4]NETPRI(NOL),[F:SOP]VAT,[M:SIH1]PRITYP,GSOCIETE,WDATCONVPRI,
&                      [M:SIH4]QTY(NOL),[M:SIH1]VACBPR,[M:SIH4]CLCAMT1(NOL),[M:SIH4]CLCAMT2(NOL),[M:SIH4]NETPRIATI(NOL)) From TRTX3
   Else
      [M:SIH4]NETPRIATI(NOL) = [M:SIH4]NETPRI(NOL)
      Call CLCTAXEPRIV([M:SIH4]NETPRI(NOL),[F:SOP]VAT,[M:SIH1]PRITYP,GSOCIETE,WDATCONVPRI,
&                      [M:SIH4]QTY(NOL),[M:SIH1]VACBPR,[M:SIH4]CLCAMT1(NOL),[M:SIH4]CLCAMT2(NOL),[M:SIH4]NETPRINOT(NOL)) From TRTX3
   Endif

  # Positionnement flag stock maj
  [M:SIH4]RTNSTOUPD(NOL)  = 1

  # Chargement sections analytiques
  Call CHARG_ACCCCE(NOL,"","","[M:SIH4]CCE",
&                   "SOP",0,[F:SOP]SOHNUM,[F:SOP]SOPLIN,[F:SOP]SOPSEQ,"") From TRTX3CPT
  # Initialisation des sections analytiques vides
  Local Integer I
  Local Char    SECTION
  For I=1 To GNBDIE
      If evalue("dim([M:SIH4]CCE"+num$(I)+"(NOL))") >0 & evalue("[M:SIH4]CCE"+num$(I)+"(NOL)")=""
          Call INISEC(SECTION, "SID", I) From TRTX3CPT
          Assign "[M:SIH4]CCE"+num$(I)+"(NOL)" With SECTION
      Endif
  Next

  If dim([M:SIH4]EECFLOPHY)>0
      #[M:SIH4]EECFLOPHY(NOL) = func TRTVENFAC.INIT_EECFLOPHY([F:ITM]EECGES,[M:SIH1]STOMVTFLG)
      [M:SIH4]EECFLOPHY(NOL) = 1
  Endif

End
#------------------------------------------------------------------------------------------------------
#**
#* Unpicking of an invoice schedule line
#!
$DESEL7
Local Integer WRET,NOL
Local Integer WISOK,WSIGMA,WTEMPSIGMA
Local Char    WMES(150) : WMES = [F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-format$(GFMDAT,[F:SVICD]NEXINVDAT)

  Raz I,J
  OK = 0

  If [M:SIH4]NBLIG <> 0
    While OK <> 1
      I = find([SVICD]VCRNUMORI,[M:SIH4]SOHNUM(J..[M:SIH4]NBLIG-1))
      If !I Break Endif
      If [M:SIH4]CREFLG(J+I-1)=0 & [SVICD]VCRLINORI    = [M:SIH4]SOPLIN(J+I-1)
&                                & [SVICD]VCRSEQORI    = [M:SIH4]SOQSEQ(J+I-1)
&                                & [SVICD]VCRINVCNDLIN = [M:SIH4]VCRINVCNDLIN(J+I-1)
&                                & [SVICD]VCRTYP       = [M:SIH4]VCRINVCNDTYP(J+I-1)
        NOL=J+I-1
        #--A just picked and modified line that impact the original schedule invoice line
        #--Cannot be depicked anymore, unless the user cancels hi's modifications...
        Gosub IS_DEPICK_ALLOWED
        If OK=0 or GERR=1 : Return : Endif
        # Maj montant marge et suppression des textes
        GMODIF=1
        #--CPO 79343
        If GREP<>"C" and GSIHSUPPLIGDSP>0 and GSIHSUPPLIGDSP<>999999
          Local Integer WTEMPDSP : Raz WTEMPDSP
          Call CTLSUPP_EXISTDSP("SIH",NOL,WTEMPDSP) From TRTVENDIV
          If WTEMPDSP=1
            GSIHSUPPLIGDSP -=1
          Endif
        Endif
        #--/CPO
        WRET = 0
        If left$([M:SIH4]SIDTEX(NOL),3)="SID"
          Call SUP_CLOB([M:SIH4]SIDTEX(NOL),WRET) From TRTX3TEX
        Endif
        Call SUB_TOT(NOL) From SUBSIHB
        If find([M]LINTYP(NOL),2,10) GMODIF=3 : Endif
        If [M:SIH4]STOMGTCOD(NOL)<>1
          # Nettoyage de l'écran de travail STOSORW
          Call DELSTOSORW(NOL,NOL,"SIH4",[M:SIH4]DSTOFCY(NOL),WRET) From STKSOR
          If WRET<>0 OK=0 : Return Endif
        Endif
        #--Removing marked modifications
        Gosub GSIDHYBHANDLE_REMOVE_INDEX_INSTANCE
        If GERR=1 : OK=0 : Return : Endif

        Dela NOL,1,[M:SIH4]NBLIG-1 [M:SIH4]NBLIG
        [M:SIH4]NBLIG -= 1
        # Si annulation composé kit alors suppression des composants
        If GMODIF = 3
          NL = NOL
          Gosub SUPNOM From TRTVENBOM
        Endif
        Raz GMESSAGE
        OK = 1
      Else
        J = J+I
      Endif
    Wend
  Endif

  # Si suite à désélection de la ligne, il n'y a plus de ligne sélectionnée
  # sur cette commande, il faut la débloquer
  Raz I,J
  OK = 3
  If [M:SIH4]NBLIG <> 0
      WSIGMA=0 : WTEMPSIGMA=0
      WTEMPSIGMA = sigma(0,[M:SIH4]NBLIG-1,
&                         ([M:SIH4]SOHNUM(indcum)=[SOQ]SOHNUM and
&                          [M:SIH4]VCRINVCNDTYP(indcum)=10    and
&                          [M:SIH4]CREFLG(indcum)=0)
&                        &(WSIGMA=0 and sigma(WSIGMA=1,1,1)))
    If WTEMPSIGMA=0
      #--Unlock all, there is no another just inserted line whose's schedule invoice is comming from the same order
      OK=3
    Else
      OK=1 #--There is another just inserted line comming from the same order
      #--but is there another inserted line on the same sales order line?
      WSIGMA=0 : WTEMPSIGMA=0
      WTEMPSIGMA = sigma(0,[M:SIH4]NBLIG-1,
&           ([M:SIH4]SOHNUM(indcum)=[SOQ]SOHNUM and
&            [M:SIH4]SOPLIN(indcum)=[SOQ]SOPLIN and
&            [M:SIH4]VCRINVCNDTYP(indcum)=10    and
&            [M:SIH4]CREFLG(indcum)=0)
&          &(WSIGMA=0 and sigma(WSIGMA=1,1,1)))
      If WTEMPSIGMA=0
        #--There is an inserted line comming from the same sales order line, no unlock for the schedule invoice
        OK=2
      Endif
    Endif
  Endif

  If OK = 3
    # Unlock entête commande
    SYMBOLE2 = "SOH"+[F:SOQ]SOHNUM
    Unlock = SYMBOLE2
  Endif
  If OK >= 2
    #TODO add lock on symbole SOQ/SOP/SVIC ?
    ##--Unlocking SOQ
    #SYMBOLE2 = "SOQ"+[F:SOQ]SOHNUM+"\"+num$([F:SOQ]SOPLIN)+"\"+num$([F:SOQ]SOQSEQ)
    #Unlock = SYMBOLE2
    ##--Locking SOP
    #SYMBOLE2 = "SOP"+[F:SOP]SOHNUM+"\"+num$([F:SOP]SOPLIN)+"\"+num$([F:SOP]SOPSEQ)
    #Unlock = SYMBOLE2
    #--Locking SVIC
    SYMBOLE2 = "SVIC"+"~"+[F:SVIC]VCRNUMORI+"\"+"10"+"\"+num$([F:SVIC]VCRLINORI)+"\"+num$([F:SVIC]VCRSEQORI)
    Unlock = SYMBOLE2
  Endif

  Gosub DESEL1_6 From SUBSIHC

Return
#------------------------------------------------------------------------------------------------------
$IS_DEPICK_ALLOWED
Local Shortint WDEPICK_ALLOWED

  OK=1
  WDEPICK_ALLOWED=[V]CST_AYES

  #--First, the global working handler has to be instantiate if not done yet
  If GSIDHYBHANDLE=null
    GSIDHYBHANDLE = NewInstance C_SIDHYBHANDLE AllocGroup null
  Endif
  Local Integer WOK,SIDHYBHANDLER_LINE
  #--Let's find the invoice line's original schedule invoice's index into the GSIDHYBHANDLE class's SVCRINVCND collection, if present
  #--Set the WSIDHYBHANDLER_LINE with record's into the SVCRINVCND collection of GSIDHYBHANDLE
  Gosub GSIDHYBHANDLE_GET_INDEX_USING_M_SIH From LIBSAL_INVCND_SIH #--Because of the different kind of schedule invoice origins
  #--No actual instance of the schedule invoice => it means that there were no changes before picking
  If SIDHYBHANDLER_LINE<1 or GERR>0
    WDEPICK_ALLOWED=[V]CST_AYES
    Return
  Endif

  WRET = fmet GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE).IS_DEPICK_ALLOWED([M:SIH4]VCRINVCNDLIN(NOL),WDEPICK_ALLOWED)
  If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
    # Error management
#    GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE))
    WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
    If WRET>=[V]CST_AERROR
      GERR = 1
    Endif
#    WRET = func SUBINVCND.RAZMAXMSG(GSIDHYBHANDLE.SIDTOSVIC(SIDHYBHANDLER_LINE),"SVCRINVCND")
  Endif

  If WDEPICK_ALLOWED<>[V]CST_AYES
    OK=0 : GERR=1 : GMESSAGE=WMES+"\"+mess(525,192,1)+"."+"\"+mess(526,192,1)
    Return
  Endif

Return
#------------------------------------------------------------------------------------------------------
$GSIDHYBHANDLE_REMOVE_INDEX_INSTANCE

  Raz WRET
  Case [M:SIH4]VCRINVCNDTYP(NOL)
    When 10 :
      #--Sales order line origin
      WRET =  fmet GSIDHYBHANDLE.REMOVE_INDEX_INSTANCE(
&                  [M:SIH4]VCRINVCNDTYP(NOL),[M:SIH4]SOHNUM(NOL),[M:SIH4]SOPLIN(NOL),[M:SIH4]SOQSEQ(NOL)
&                 ,[M:SIH4]VCRINVCNDLIN(NOL),[M:SIH4]SVICUUID(NOL),[M:SIH0]NUM)
    When Default
  Endcase

  If (WRET > [V]CST_AOK) #--The method also throws an [V]cst_ainfo message if last line results in negative values
    # Error management
#    GMESSAGE  = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GSIDHYBHANDLE)
    WRET= func LIBSAL_INVCND.GET_INSTANCE_ERRORS(GSIDHYBHANDLE, [V]CST_ALL, [V]CST_AYES, GMESSAGE)
    If WRET>=[V]CST_AERROR
      GERR = 1
    Else
      GERR = 2
    Endif
#    WRET = func SUBINVCND.RAZMAXMSG(GSIDHYBHANDLE,"SIDTOSVIC")
    Return
  Endif

Return

Return
#------------------------------------------------------------------------------------------------------
#**
#* Invoicing elements tranfer : Sales order -> Invoice (throught schedule invoice)
#* Search for a previous invoice for the current sales order
#* Search for a previous delivery for the current sales order
#*Return : [V]CST_ATRUE if it exists other invoices for the PSOHNUM sale order
#*         [V]CST_AFALSE if PSOHNUM="" or no other invoices
#*!
Funprog SVIC_CHECK_EXIST_PREV_INV(PSOHNUM,PSIHNUM,VEXIST_PREVPICKED)
Value Char PSOHNUM
Value Char PSIHNUM
Variable Tinyint VEXIST_PREVPICKED

VEXIST_PREVPICKED=[V]CST_AFALSE

If PSOHNUM="" : End [V]CST_AFALSE : Endif

Local Tinyint WRET

  Local File SINVOICED [SID99]

  Filter [SID99] Where SOHNUM=PSOHNUM and find(NUM,PSIHNUM,"")=0
  Read [SID99] First
  If fstat>0
    WRET = [V]CST_AFALSE
  Else
    WRET = [V]CST_ATRUE
  Endif
  Filter [SID99]

  #--If there is a previous invoice, we don't need to go further
  If WRET=[V]CST_ATRUE : End WRET : Endif

  Local File SDELIVERYD [SDD99]

  Filter [SDD99] Where SOHNUM=PSOHNUM
  Read [SDD99] First
  If fstat>0
    WRET = [V]CST_AFALSE
  Else
    WRET = [V]CST_ATRUE
  Endif
  Filter [SDD99]

  #--If there is a previous invoice, we don't need to go further
  If WRET=[V]CST_ATRUE : End WRET : Endif

  #--Case of Creation mode and previously picked scheduling invoice lines comming from the same order as PSOHNUM
  If PSIHNUM="" or GREP="C"
    Local Integer IJ
    IJ=find(PSOHNUM,[M:SIH4]SOHNUM(0..[M:SIH4]NBLIG-1))
    If IJ>0
      VEXIST_PREVPICKED=[V]CST_ATRUE
    Endif
  Endif

End WRET
#------------------------------------------------------------------------------------------------------
$RAFFRAICHI

  If WONFAITQUOI<>GBOXSVIC1 :  Return : Endif

  If sum([M:SIH4]SOQSEQ)<>0 and [M:SIH0]INVTYP=1 and [M:SIH1]SIHORI=10
    For I=0 To [M:SIH4]NBLIG-1
      # Ligne issue d'un picking commande réalisé au cours de cette transaction
      If [M:SIH4]SOHNUM(I)<>"" and [M:SIH4]SDHNUM(I)="" and [M:SIH4]CREFLG(I)=0 and
&        [M:SIH4]SIDORI(I)=10 and !find([M:SIH4]LINTYP(I),3,4,5,11,12,13)
        Read [SVICD]SVICD0=[M:SIH4]VCRINVCNDTYP(I);[M:SIH4]SOHNUM(I);[M:SIH4]SOPLIN(I);[M:SIH4]SOQSEQ(I);[M:SIH4]VCRINVCNDLIN(I)
        If fstat : OK=0 : GERR=1 : Break :Endif
        If    WPICK=1 Gosub DEPICK From GOBJSUB
        Elsif WPICK=2 Gosub REPICK From GOBJSUB
        Endif
      Endif
    Next I
  Endif
  If OK=0 or GERR=1 : Return : Endif

Return
#------------------------------------------------------------------------------------------------------

