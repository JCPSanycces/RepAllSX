#<AdxTL>@(#)0.0.0.0 $Revision$
Call OBJET("DEM",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
## Gestion des demandes de formation
######################################################################################
# Améliorations de plan prévisionnel (SYMEU - Septembre 2010 - V6.1)
# -> EXI 66191 LOT 10
# - Suite aux modifications du plan prévisionnel, l'année du plan de formation prévisionnel
#   de la demande n'est plus saisissable -> modif du champ YEAPLF de l'écran DEM1 et suppres-
#   sion des actions sur ce champ.
# SYMEU - 04/10/10 - EXI 66191 LOT 10 - V6.1 : stage non défini
# SEGAY : FQ79677 30/01/12 Modification d'un stage ou d'une session dans une demande
# SEGAY : FQ79713 12/04/13 Impression lettre de refus
# MABOS : FQ89650 02/05/13 Pb Tabulation sur 1ere ligne après suppression ligne
######################################################################################

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "INICRE"      : Gosub INICRE
 When "CREATION"    : Gosub CRE_LIGNES
 When "MODIF"       : Gosub CRE_LIGNES
 When "SETBOUT"     : Gosub SETBOUT
 When "VERIF_MOD"   : Gosub VERIF
 When "VERIF_CRE"   : Gosub VERIF
 When "RAZCRE"      : Gosub RAZCRE
 When "RAZDUP"      : Gosub RAZDUP
 When "ANNULE"      : Gosub ANNULE
 When "FILTRE"      : Gosub FILTRE
 When "APRES_CHOI"  : Gosub APRES_CHOI
 When "FILGAUCHE"   : Gosub FILGAUCHE
 When "FERME"       : Gosub FERME
 When "STYLE"       : Gosub STYLE
 When Default
Endcase
Return

$OUVRE
If clalev([F:ADI])=0   : Local File ATABDIV   [ADI]   : Endif
If clalev([F:ID])=0    : Local File EMPLOID   [ID]    : Endif
If clalev([F:DML])=0   : Local File DEMLIG    [DML]   : Endif
If clalev([F:TCA])=0   : Local File TABCOUAFF [TCA]   : Endif
If clalev([F:HRSES])=0 : Local File SESSIONS  [HRSES] : Endif
If clalev([F:STG])=0   : Local File STAGE     [STG]   : Endif
If clalev([F:PLF])=0   : Local File PLNFORM   [PLF]   : Endif
If clalev([F:SRV])=0   : Local File SERVICE   [SRV]   : Endif

Local Integer STAT, I
Local Char    COMPTEUR(GLONANM), NIV
Call PARAMUTIL("NIVDEM",NIV,GUSER,"") From SUBAUS
If val(NIV)=0
 OK = 0
 # Vous n'avez pas de niveau d'autorisation défini dans le paramètre NIVDEM
 GMESSAGE = mess(70,10717,1)
Endif

If clalev([F:CPY])=0   : Local File COMPANY  [CPY]   : Endif
If clalev([F:FCY])=0   : Local File FACILITY [FCY]   : Endif
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif

Local Char CRITDEM(250)

# SBA US4302_111201
Gosub SET_VAR_COUNTER From TOOLSHRTCA



Return

$STYLE
#LIPET - 2017-11-13 - START
 Call DISPLAY_HIDE() From SUBDEMLEG
#LIPET - 2017-11-13 - END
Return

$FERME
  If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$CHARGE_NAM
  [M:DEM1]NAM = [F:ID]NAM-[F:ID]SRN
  Affzo [M:DEM1]NAM
Return

$LIENS
Local Integer I

Read [HRCTR]CTR0(2)=[M:DEM1]REFNUM;[M:DEM1]CTR
If !fstat
  Call LECTURE("FCY",[HRCTR]ETRFCY,"") From CONTOBJ
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
Else
  Read [ID]ID0=[M:DEM1]REFNUM
  If !fstat
   Call LECTURE("CPY",[F:ID]CPY,"") From CONTOBJ
   GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
  Endif
Endif
If GNBLEG=1 : GCURLEG = GDOSLEG : Endif
Call DISPLAY_HIDE() From SUBDEMLEG
Gosub CHARGE_LIGNES

# Modif impossible si demande sur plan définitif ou inscrite ou réalisée
If find(2,[M:DEM3]FLGINS) | find(3,[M:DEM3]FLGINS) | find(4,[M:DEM3]FLGINS)
 Diszo [DEM0] STG, DATDEM
# Diszo [DEM1] 2-20 : # FQ71012 - MABON 25/01/11 : Finalement, on doit pouvoir modifier les données de DEM1
Else
 Actzo [DEM0]
# Actzo [DEM1] 2-20 : # FQ71012 - MABON 25/01/11 : Puisque plus de Diszo, plus besoin de Actzo

 If [M:DEM1]FLGPLF=2 : # Hors plan
  Grizo [DEM1]YEAPLF
 Endif

# FQ78757 - MABON 19/12/11 - DATSTR et DATEND doivent petre gérés en dehors de cette boucle
Endif
# Fin MABON

 # Session
 If [M:DEM1]SES<>""
  Grizo [DEM1]DATSTR, DATEND
# SEGAY : FQ79677 30/01/12 pouvoir dégriser la période si on venait d'une demande avec session
 Else
  Actzo [DEM1]DATSTR, DATEND
 Endif
# FQ78757 - MABON 19/12/11 - DATSTR et DATEND doivent petre gérés en dehors de cette boucle
#Endif
# Fin MABON

# Origine de la demande
If [M]ORI=1      : # Individuelle
Diszo [M:DEM3]NBREMP, EMP, CTRNUM, FCY, CATFRT, SRV, SEX, AGE, JOBPOT, POT : # MABON 10/09/10 - Ajout SEX, AGE, JOBPOT et POT
Elsif [M]ORI=2   : # Hiérarchique
 Actzo [M:DEM3]
 For I=0 To [M:DEM3]NBRDEM-1
  If [M:DEM3]EMP(I)<>"" Then
    Diszo [M:DEM3]SEX(I), AGE(I), JOBPOT(I), POT(I)
  Endif
 Next
Endif
# MABON 10/09/10 - Gestion champ RENREF
Call PARAMUTIL("NIVDEM",NIV,GUSER,"") From SUBAUS
For I=0 To [M:DEM3]NBRDEM-1
 If [M:DEM3]STA(I)=3 and val(NIV)>=3 Then
   Actzo [M:DEM3]RENREF(I)
 Else
   Grizo [M:DEM3]RENREF(I)
 Endif
Next
# MABON 04/11/10 - Si l'origine de la demande est "Parcours" et individuelle, on grise Individuelle/Hiérarchique
If [M]ORIDEM=2 Then
  Diszo [M:DEM1]ORI
Else
  Actzo [M:DEM1]ORI
Endif

Read [ID]ID0=[M:DEM1]REFNUM
If !fstat
 Gosub CHARGE_NAM
 Call GRISE_CTR([F:ID]FLGMULCTR)
Endif

Return

$SETBOUT
# On ne peut pas modifier une demande si toutes les lignes sont inscrites ou réalisées ou sur plan
I = 0
For nolign=0 To [M:DEM3]NBRDEM-1
 If [M:DEM3]FLGINS(nolign)=1
  I = 1
  Break
 Endif
Next
If I=0 : Call VIREBOUT(CHAINE,"M") From GOBJET : Endif
Return

$FILTRE
If dim([F]DEMNUM)>0 & (find("SES",GPILCOD(1..GPILOBJ)) | find("INS",GPILCOD(1..GPILOBJ)))
#If dim(SAVFONC)>=0 & (SAVFONC="GESHRSES" | SAVFONC="GESINS") & TUNNEL
 If FILTSUP<>"" : FILTSUP += " & " : Endif
 FILTSUP -= "DEMNUM='"+[F]DEMNUM+"'"
Endif
Return

$FILGAUCHE
# SBA add LEGFIL
If GLEGFIL<>""
  If(FILGAUCHE<>"") :FILGAUCHE-="&" : Endif
  FILGAUCHE -= "(find([F:FCY]LEG,'"+GLEGFIL+"','')>0)"
  If FILGAUSUP<>"" : FILGAUSUP += " & " : Endif
  FILGAUSUP += "(find([F:FCY]LEG,'"+GLEGFIL+"','')>0)"
Endif
If find("SES",GPILCOD(1..GPILOBJ)) | find("INS",GPILCOD(1..GPILOBJ))
#If dim(SAVFONC)>=0 & (SAVFONC="GESHRSES" | SAVFONC="GESINS") & TUNNEL
 If FILGAUSUP<>"" : FILGAUSUP += " & " : Endif
 FILGAUSUP -= "DEMNUM='"+[F]DEMNUM+"'"
Endif
Return

# FQ81085 - MABON 22/06/12 - Navigate in the records, taking into account GLEGFIL
$FILDEM

  CRITDEM="1=1"
  If GLEGFIL<>""
    If CRITDEM<>"" Then CRITDEM-="&" : Endif
    CRITDEM -= "(find([F:FCY]LEG,'"+GLEGFIL+"','')>0)"
  Endif
  Filter [DEM_] Where evalue(CRITDEM)
Return

$APRES_CHOI

  Case REPONSE
    When GSTASUI, GSTAPRE, GSTAFIR,GSTALAS
      Gosub FILDEM
      If REPONSE=GSTASUI Then Read [DEM_]DEM0 > [M:DEM0]DEMNUM  : Endif
      If REPONSE=GSTAPRE Then Read [DEM_]DEM0 < [M:DEM0]DEMNUM  : Endif
      If REPONSE=GSTAFIR Then Read [DEM_]DEM0 First             : Endif
      If REPONSE=GSTALAS Then Read [DEM_]DEM0 Last              : Endif
      Filter [DEM_]
      Gosub SUIVPREC From TOOLSHRLEG
  Endcase
Return
# End MABON

$CHARGE_LIGNES
nolign = 1

For [DML]DML0 Where DEMNUM=[F:DEM]DEMNUM
 [M:DEM3] = [F:DML]
 If val(NIV)<[F:DML]STA
  Grizo [M:DEM3]STA(nolign-1)
 Else
  Actzo [M:DEM3]STA(nolign-1)
 Endif
 If [M:DEM3]EMP(nolign-1)<>"" Then
   Read [ID]ID0=[M:DEM3]EMP(nolign-1)
   If !fstat
    [M:DEM3]NAM(nolign-1)    = [F:ID]NAM
    [M:DEM3]SRN(nolign-1)    = [F:ID]SRN
   Endif
 Endif
 nolign +=1
Next
[M:DEM3]NBRDEM = nolign-1
Affzo [M:DEM3]
Return

# SBA US4302_111201
$INICRE
## Affectation du no de demande
If [F:DEM]DEMNUM=""
# Read [TCA]TCA0 = 20 : # Module gestion des talents
# COMPTEUR = [F:TCA]CODNUM(0)
# If COMPTEUR=""
#  # Compteur demande non défini
#  GMESSAGE = mess(4,10717,1)
#  GOK = 0 : Return
# Endif
 W_MODULE=20
 TYPMESS=1
 W_POS=0
 W_SIT=GSOCIETE
 W_CRITCOMP=""
 W_DATCPT=datesyst
 Gosub GET_COUNTER From TOOLSHRTCA
 # GMESSAGE = mess(4,10717,1) : # Compteur demande non défini
 If !GOK : Return : Endif
 Call VERIF_VCR(W_VALUECPT,W_CPTNAME)
 If GOK=0 : Return : Endif
 [F:DEM]DEMNUM=W_VALUECPT
 [M:DEM0]DEMNUM = [F:DEM]DEMNUM
 Affzo [M:DEM0]DEMNUM
# Call LECTCA(20,STAT) From SUBTCA : # Module gestion des talents
# If !STAT
#  GMESSAGE = mess(4,10717,1) : # Compteur demande non défini
#  GOK = 0 : Return
# Else
#  COMPTEUR= [F:TCA]CODNUM(0)
# Endif
 #Call NUMERO(COMPTEUR,"",datesyst,"",[F:DEM]DEMNUM,STAT) From SUBANM
# If STAT
#  # Erreur sur compteur
#  GMESSAGE = mess(4,10702,1)-COMPTEUR
#  GOK = 0 : Return
# Endif
 #Call VERIF_VCR([F:DEM]DEMNUM,COMPTEUR)
 #If GOK=0 : Return : Endif
 #[M:DEM0]DEMNUM = [F:DEM]DEMNUM
 #Affzo [M:DEM0]DEMNUM
Endif
Return


$INICRE_OLD
## Affectation du no de demande
If [F:DEM]DEMNUM=""
# Read [TCA]TCA0 = 20 : # Module gestion des talents
# COMPTEUR = [F:TCA]CODNUM(0)
# If COMPTEUR=""
#  # Compteur demande non défini
#  GMESSAGE = mess(4,10717,1)
#  GOK = 0 : Return
# Endif
 Call LECTCA(20,STAT) From SUBTCA : # Module gestion des talents
 If !STAT
  GMESSAGE = mess(4,10717,1) : # Compteur demande non défini
  GOK = 0 : Return
 Else
  COMPTEUR= [F:TCA]CODNUM(0)
 Endif
 Call NUMERO(COMPTEUR,"",datesyst,"",[F:DEM]DEMNUM,STAT) From SUBANM
 If STAT
  # Erreur sur compteur
  GMESSAGE = mess(4,10702,1)-COMPTEUR
  GOK = 0 : Return
 Endif
 Call VERIF_VCR([F:DEM]DEMNUM,COMPTEUR)
 If GOK=0 : Return : Endif
 [M:DEM0]DEMNUM = [F:DEM]DEMNUM
 Affzo [M:DEM0]DEMNUM
Endif
Return




Subprog VERIF_VCR(NUM,COMPTEUR)
Variable Char NUM
Value    Char COMPTEUR
Local Integer STAT
If clalev([F:DEMZ])=0 : Local File DEMANDE [DEMZ] : Endif
Read [DEMZ]DEM0=NUM
If fstat : End : Endif
While !fstat
 Call NUMERO(COMPTEUR,"",datesyst,"",NUM,STAT) From SUBANM
 Read [DEMZ]DEM0=NUM
Wend
If STAT
 # Erreur sur compteur
 GMESSAGE = mess(4,10702,1)-COMPTEUR
 GOK = 0 : End
Endif
End

$CRE_LIGNES
Delete [DML] Where DEMNUM=[M:DEM0]DEMNUM
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("DML",[F:DML]DEMNUM-num$([F:DML]NUMLIG)) From GLOCK : Return
Else
 For nolign=1 To [M:DEM3]NBRDEM
  [F:DML]       = [M:DEM3]
  [F:DML]DEMNUM = [M:DEM0]DEMNUM
  [F:DML]NUMLIG = nolign-1
  Write [DML]
  If fstat
   GOK=0 : Call FSTA("DML") From GLOCK : Break
  Endif
 Next
 If GOK=0 : Return : Endif
Endif
Return

$VERIF
If [M]NBRDEM=0
 # Il faut au moins saisir un participant
 GMESSAGE = mess(43,10717,1)
 OK=0 : Return
Endif
For I=0 To [M]NBRDEM-1
 If [M]EMP(I)<>""
  Call CTL_TCHEMP([M]EMP(I))
  If mkstat=2
   OK=0 : Break
  Endif
  # Controls that the contract is in the correct leg
  Call CHECK_LEGCTR([M:DEM3]EMP(I),[M:DEM3]CTRNUM(I),"CTRNUM")
  If mkstat=2 Then OK=0 : Break : Endif
 Endif
 If [M:DEM3]CATFRT(I)="" and GCURLEG="FRA" Then
  GMESSAGE=mess(144,10726,1)-":"-mess(10,123,1) : # Catégorie : Zone obligatoire
  mkstat=2
  OK=0 : Break
 Endif
Next
Call CALL_INIML1 #FQ93180  - Initialisation ML1 <> 0
Return

$RAZCRE
#GCURLEG=GLEGFIL
$RAZDUP
GCURLEG=""
For nolign=0 To [M:DEM3]NBRDEM-1
 [M:DEM3]STA(nolign)       = 1
 [M:DEM3]FLGINS(nolign)    = 1
 [M:DEM3]OLDFLGINS(nolign) = 1
Next
Affzo [M:DEM3]STA,FLGINS
#on reinitialise le plan de formation
[M:DEM1]YEAPLF=""
#LIPET - 2017-05-17 - X3-35995 - START
Raz [M:DEM1]STRDAT, [M:DEM1]ENDDAT              : # JML 25/08/15
#LIPET - 2017-05-17 - X3-35995 - END
Affzo [M:DEM1]YEAPLF
#LIPET - 2017-05-17 - X3-35995 - START
Affzo [M:DEM3]STA,FLGINS
#LIPET - 2017-05-17 - X3-35995 - END
# MABON 10/09/10 - Initialisation de l'origine de la demande à 1, et du flag Période prof à non
[M:DEM1]ORIDEM=1
[M:DEM1]CODCSI="" : [M:DEM1]FLGPRO=1
Affzo [M:DEM1]ORIDEM, CODCSI, FLGPRO
Return

$ANNULE
# FQ80516 - MABON 05/03/12 - Si suppression d'une demande, annulation des workflows
Call MAJ_HISSUI
# Fin MABON
Return

#FQ93180  - Initialisation ML1 <> 0
#**
#* Initialisation ML1 <> 0
#*!
Subprog CALL_INIML1
Local Integer I
For I=0 To 3
  If evalue("clalev([M:DEM"+num$(I)+"])")>0
    Call INI_ML1("DEM"+num$(I)) From DIVPAYE
  Endif
Next I
End

#**
#* FQ80516 - MABON 05/03/12 - Si suppression d'une demande, annulation des workflows
#*
#* @param STA
#*!
Subprog MAJ_HISSUI
Local Char    REP (GLONADI)

  If GWEBSERV : End : Endif

  If clalev([F:AWS])=0 : Local File AWRKHISSUI [AWS] : Endif

  REP = "ANN"

  Update [F:AWS] Where VALCTX1 = [M:DEM0]DEMNUM
&                With [F:AWS]FLGSIG = 5
&                   , [F:AWS]ACTSIG = REP
&                   , [F:AWS]USRSIG = GUSER
&                   , [F:AWS]DATSIG = date$

End

######################################################################################
## Etiquettes Ecran DEM1
######################################################################################

Subprog AM_ORI(VALEUR)
Variable Integer VALEUR
Local    Integer I
If VALEUR=1    : # Individuelle
 If [M:DEM1]REFNUM<>""
  Call DEM_IND([M:DEM1]REFNUM,[M:DEM1]CTR)
 Else
  Diszo [M:DEM3]NBREMP, EMP, CTRNUM, FCY, CATFRT, SRV, SEX, AGE, JOBPOT, POT : # MABON 10/09/10 - Ajout SEX, AGE, JOBPOT et POT
 Endif
Elsif VALEUR=2 : # Hiérarchique
 Actzo [M:DEM3]
 For I=0 To [M:DEM3]NBRDEM-1
  If [M:DEM3]EMP(I)<>"" Then
    Diszo [M:DEM3]SEX(I), AGE(I), JOBPOT(I), POT(I)
  Endif
 Next
Endif
End

Subprog AS_REFNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 Local Char TMPMAT
 Local Char WLEG
 Local Integer WOK
 # SBA check intialisation.
 # can be ameliorate.
 Call PARAMUTIL("REFNUM",TMPMAT,GUSER,"") From SUBAUS
 If([M:DEM0]STG<>"")
      Call GET_LEGSTG([M:DEM0]STG,WOK,WLEG,0)From TOOLSHRLEG
 Endif
 If clalev([F:CPY])=0   : Local File COMPANY  [CPY]   : Endif
 If clalev([F:FCY])=0   : Local File FACILITY [FCY]   : Endif
 If clalev([F:CTR1])=0 : Local File EMPLOCTR [CTR1] : Endif
 WOK=0
  #
 For [CTR1]CTR0 Where REFNUM=TMPMAT & CTRDAT<=[M:DEM0]DATDEM & (XITDAT=[0/0/0] | XITDAT>=[M:DEM0]DATDEM)
    Call LECTURE("FCY",[F:CTR1]ETRFCY,"") From CONTOBJ
    Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
    Call LECTURE("SRV",[F:CTR1]ETRSRV,"") From CONTOBJ
    If(WLEG="" or WLEG=[F:CPY]LEG)
      WOK+=1
      Break
    Endif
Next
  Filter[CTR1]
  If(WOK)
    VALEUR=TMPMAT
  Endif
Endif
End

Subprog C_REFNUM(VALEUR)
Variable Char    VALEUR()
If [M:DEM1]ORI=1
 ## Contrôle que le formateur interne n'est pas stagiaire
 Call CTL_TCHEMP(VALEUR)
 If mkstat=2 : End : Endif
Endif
End

Subprog CTL_TCHEMP(VALEUR)
Value Char VALEUR()
Local Integer OK
## Contrôle que le formateur interne n'est pas stagiaire
If [M:DEM1]SES<>""
 Call LECTURE("HRSES",[M:DEM1]SES,"") From CONTOBJ
 If [F:HRSES]TCHEMP=VALEUR
#  Call LECTURE("ID",VALEUR,"") From CONTOBJ
  Call LECTURE("EML",VALEUR,"") From CONTOBJ
  OK = 2
  # participe au stage alors qu'il est le formateur
  Call AVERTIR ([F:ID]NAM-mess(42,10717,1),OK) From GESECRAN
  If OK=1 : mkstat=2 : End : Endif
 Endif
Else
 If [M:DEM0]STG<>""
  Call LECTURE("STG",[M:DEM0]STG,"") From CONTOBJ
  If [F:STG]TCHEMP=VALEUR
#   Call LECTURE("ID",VALEUR,"") From CONTOBJ
   Call LECTURE("EML",VALEUR,"") From CONTOBJ
   OK = 2
   # participe au stage alors qu'il est le formateur
   Call AVERTIR ([F:ID]NAM-mess(42,10717,1),OK) From GESECRAN
   If OK=1 : mkstat=2 : End : Endif
  Endif
 Endif
Endif
End

Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()
Local Char CONTRAT(GLONHRCTR)
Raz [M:DEM1]CTR
#Call LECTURE("ID",VALEUR,"") From CONTOBJ
Call LECTURE("EML",VALEUR,"") From CONTOBJ
If [F:ID]FLGMULCTR<>2
# Call CHERCHE_CTR(VALEUR,date$,CONTRAT) From DIVPAYE
 Call CHERCHE_CTR(VALEUR,[M:DEM0]DATDEM,CONTRAT) From DIVPAYE
 #LIPET - 2017-05-17 - X3-35995 - START
 #Call VERIF_PRESENCE(VALEUR,CONTRAT)
 Call VERIF_PRESENCE_FROM(VALEUR,CONTRAT,[M:DEM0]DATDEM)
 #LIPET - 2017-05-17 - X3-35995 - END
 If mkstat=2 : End : Endif
 # Controls that the contract is in the correct leg
 Call CHECK_LEGCTR(VALEUR,CONTRAT,"CTR")
 If mkstat=2 Then End : Endif
 If [M:DEM1]ORI=1
  # Contrôle que le salarié appartient à la cible
  Call VERIF_CIBLE(VALEUR,CONTRAT)
  If mkstat=2 : End : Endif
 Endif
 [M:DEM1]CTR = CONTRAT
 Affzo [DEM1]CTR
 Read [HRCTR]CTR0(2)=VALEUR;CONTRAT
 If !fstat
  Call LECTURE("FCY",[HRCTR]ETRFCY,"") From CONTOBJ
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  # SBA : 27/06/2012 ajout de GCURLEG
  GSOCIETE=[F:CPY]CPY : GCURLEG=[F:CPY]LEG
 Endif
 If [M:DEM1]ORI=1
  Call DEM_IND(VALEUR,[M:DEM1]CTR)
 Endif
 #LIPET - 2017-06-21 - X3-35995 - START
 Gosub CHARGE_NAM
 #LIPET - 2017-06-21 - X3-35995 - END
Endif
#Gosub CHARGE_NAM
Call GRISE_CTR([F:ID]FLGMULCTR)
Call DISPLAY_HIDE() From SUBDEMLEG
End

Subprog GRISE_CTR(VALEUR)
Value Integer VALEUR
If VALEUR=2
 Actzo [M:DEM1]CTR
Else
 Diszo [M:DEM1]CTR
Endif
Affzo [M:DEM1]CTR
End

Subprog AS_CTR(VALEUR)
Variable Char    VALEUR()
If [M:DEM1]CTR=""
 GCURLEG=func FGET_LEGSEL(2)
 #LIPET - 2017-05-17 - X3-35995 - START
 #Call SELCTR([M:DEM1]REFNUM,date$,date$,VALEUR) From DIVPAYE
 Call SELCTR([M:DEM1]REFNUM,[M:DEM0]DATDEM,[M:DEM0]DATDEM,VALEUR) From DIVPAYE
 #LIPET - 2017-05-17 - X3-35995 - END
Endif
End

Subprog C_CTR(VALEUR)
Variable Char    VALEUR()
## Contrôle que le salarié est présent
#LIPET - 2017-05-17 - X3-35995 - START
#Call VERIF_PRESENCE([M:DEM1]REFNUM,VALEUR)
Call VERIF_PRESENCE_FROM([M:DEM1]REFNUM,VALEUR,[M:DEM0]DATDEM)
#LIPET - 2017-05-17 - X3-35995 - END
If mkstat=2 : End : Endif
If [M:DEM1]ORI=1
 # Contrôle que le salarié appartient à la cible
 Call VERIF_CIBLE([M:DEM1]REFNUM,VALEUR)
 If mkstat=2 : End : Endif
Endif
Call CHECK_LEGCTR([M:DEM1]REFNUM,VALEUR,"CTR")
If(mkstat=2):End:Endif
End

Subprog AM_CTR(VALEUR)
Variable Char    VALEUR()

Call CHECK_LEGCTR([M:DEM1]REFNUM,VALEUR,"CTR")
If(mkstat=2):End:Endif
If(VALEUR<>"")
  Read [HRCTR]CTR0(2)=[M:DEM1]REFNUM;VALEUR
  If !fstat
    Call LECTURE("FCY",[HRCTR]ETRFCY,"") From CONTOBJ
    Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
    GSOCIETE=[F:CPY]CPY
  Endif
Endif
If [M:DEM1]ORI=1
 Call DEM_IND([M:DEM1]REFNUM,VALEUR)
Endif
#sba test
Call DISPLAY_HIDE() From SUBDEMLEG
Call SET_FLAGINVALID()
End

Subprog DEM_IND(MATRI,CTR)
Variable Char MATRI()
Value    Char CTR
# Demande individuelle : On alimente en automatique le participant
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:ID])=0  : Local File EMPLOID  [ID]  : Endif
If clalev([F:ADI])=0 : Local File ATABDIV  [ADI] : Endif
Raz [M:DEM3]
Read [ID]ID0=MATRI
If !fstat
 [M:DEM3]STA(0)       = 1
 [M:DEM3]FLGINS(0)    = 1
 [M:DEM3]OLDFLGINS(0) = 1
 [M:DEM3]NBREMP(0)    = 1
 [M:DEM3]EMP(0)       = MATRI
 [M:DEM3]NAM(0)       = [F:ID]NAM
 [M:DEM3]SRN(0)       = [F:ID]SRN
 [M:DEM3]CTRNUM(0)    = CTR
 [M:DEM3]SEX(0)       = [F:ID]SEX
 Filter [ADI] Where NUMTAB=10454 Order By Key CLE=N1
 For [ADI]CLE
  #LIPET - 2017-05-17 - X3-35995 - START
  #If fix((date$-[F:ID]DATBRN)/365)<=[F:ADI]N1
  If fix(([M:DEM0]DATDEM-[F:ID]DATBRN)/365)<=[F:ADI]N1
  #LIPET - 2017-05-17 - X3-35995 - END
   Break
  Endif
 Next
 Filter [ADI]
 [M:DEM3]AGE(0)      = [F:ADI]CODE
 #LIPET - 2017-05-17 - X3-35995 - START
# Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=date$
# Read [HRCTR]CTR0 Last
# Filter [HRCTR]
 # On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
 Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & (CTRDAT<=[M:DEM0]DATDEM| (FLGRET=2 & RETDATEFF<=[M:DEM0]DATDEM))
 If fstat
   Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & (XITDAT=[0/0/0] | XITDAT>=[M:DEM0]DATDEM)
   Read [HRCTR]CTR0 Last
 Endif
 Read [HRCTR]CTR0 Last
 Filter [HRCTR]
 #LIPET - 2017-05-17 - X3-35995 - END
 If !fstat
  [M:DEM3]FCY(0)     = [F:HRCTR]ETRFCY
  [M:DEM3]SRV(0)     = [F:HRCTR]ETRSRV

  #SBA désactivé car porté par le demandeur
  Read [FCY]FCY0=[F:HRCTR]ETRFCY
  If !fstat
   [M:DEM3]CPY(0)    = [F:FCY]LEGCPY
#   #Legistlation code
   Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
   GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
   If GNBLEG=1 : GCURLEG = GDOSLEG : Endif
  Endif
  #SBA fin
  # MABON 10/09/10 - Ajout JOBPOT et POT
  [M:DEM3]JOBPOT(0)  = [F:HRCTR]JOBPOT
  [M:DEM3]POT(0)     = [F:HRCTR]POT
  Call CAT2483(MATRI,CTR,[M:DEM3]CATFRT(0))
 Endif

 If [M:DEM1]SES<>""
  Call LECTURE("HRSES",[M:DEM1]SES,"") From CONTOBJ
  # MABON - 03/09/10 - On n'a plus de flag DIF : c'est géré maintenant en dispositif comme un autre, donc dans TYPFRT
#  If [F:HRSES]FLGDIF=2
  #LIPET - 2017-06-27 - X3-35995 - START
#  If [F:HRSES]TYPFRT=3
#   [M:DEM3]DESTYPFRT(0) = 3
#  Else
#   [M:DEM3]DESTYPFRT(0) = [F:HRSES]TYPFRT
#  Endif
  #LIPET - 2017-06-27 - X3-35995 - END
 Elsif [M:DEM0]STG<>""
  Call LECTURE("STG",[M:DEM0]STG,"") From CONTOBJ
  # MABON - 19/08/10 - On n'a plus de flag DIF : c'est géré maintenant en dispositif comme un autre, donc dans TYPFRT
#  If [F:STG]FLGDIF=2
  #LIPET - 2017-06-27 - X3-35995 - START
#  If [F:STG]TYPFRT=3
#   [M:DEM3]DESTYPFRT(0) = 3
#  Else
#   [M:DEM3]DESTYPFRT(0) = [F:STG]TYPFRT
#  Endif
  #LIPET - 2017-06-27 - X3-35995 - START
 Endif
 [M:DEM3]NBRDEM = 1
Endif
Affzo [M:DEM3]
# MABON 10/09/10 - Ajout SEX, AGE, JOBPOT et POT
Diszo [M:DEM3]NBREMP, EMP, CTRNUM, FCY, CATFRT, SRV, SEX, AGE, JOBPOT, POT
If [M:DEM3]EMP(0)="" Then
  Actzo [M:DEM3]SEX, AGE, JOBPOT, POT
Endif
End


Subprog AM_SES(VALEUR)
Variable Char    VALEUR()
Local Integer L_OK # SEGAY : FQ79677 30/01/12 Modification d'une session dans une demande
If VALEUR<>""
 Read [HRSES]SES0=VALEUR
 If !fstat
  [M:DEM1]DATSTR    = [F:HRSES]STRDAT
  [M:DEM1]DATEND    = [F:HRSES]ENDDAT
  Grizo [M]DATSTR, DATEND
  Affzo [M]DATSTR, DATEND
  [M:DEM0]STG=[F:HRSES]STG : Affzo [M:DEM0]STG, ZSTG
 Endif
 # SEGAY : FQ79677 30/01/12 Modification d'une session dans une demande
 L_OK = 1
 If GREP='C' : End : Endif
 # SBA modif put condition in a  subprog
 Local Integer ASK
 Call CHECK_ASKUPDATE("TYPFRT",ASK,"SES")
 If ASK
 #If [M:DEM1]ORI=1 & [M:DEM3]DESTYPFRT(0) <> [F:SES]TYPFRT
 ###Voulez-vous initialiser cette demande et le dispositif de formation du participant par les données de la session ?
    Call OUINON(mess(268,10717,1),L_OK) From GESECRAN
 Else
   Call CHECK_ASKUPDATE("",ASK,"SES")
  If ASK
#If [M:DEM1]DOM <> [F:HRSES]DOM or [M:DEM1]THM <> [F:HRSES]THM or [M:DEM1]DESNATFIS <> [F:HRSES]NATFIS or [M:DEM1]DESCATACN <> [F:HRSES]CATACN
  #### Voulez-vous initialiser cette demande par les données de la session ?
     Call OUINON(mess(267,10717,1),L_OK) From GESECRAN
   Endif
 Endif
 If L_OK=2
 # SBA modif
Call SETFIELDS("SES")
#    [M:DEM1]DOM = [F:HRSES]DOM
#    Affzo [M:DEM1]DOM
#    [M:DEM1]THM = [F:HRSES]THM
#    Affzo [M:DEM1]THM
#    If [F:HRSES]NATFIS<>0
#       [M:DEM1]DESNATFIS=[F:HRSES]NATFIS
#       Affzo [M:DEM1]DESNATFIS
#    Endif
#    If [F:HRSES]CATACN<>0
#       [M:DEM1]DESCATACN=[F:HRSES]CATACN
#       Affzo [M:DEM1]DESCATACN
#    Endif
#    If [M:DEM1]ORI=1 &  [M:DEM3]DESTYPFRT(0) <> [F:HRSES]TYPFRT
#       [M:DEM3]DESTYPFRT(0)=[F:SES]TYPFRT
#       Affzo [M:DEM3]DESTYPFRT(0)
#    Endif
#    mkstat = 0
 Endif
 # END FQ79677 30/01/12 Modification d'une session dans une demande
Else
 Effzo [DEM1]DATSTR, DATEND
 Actzo [DEM1]DATSTR, DATEND
Endif
Call SET_FLAGINVALID()
End

Subprog C_SES(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("HRSES",VALEUR,"") From CONTOBJ
 If [F:HRSES]FLGCLO=2
  # Cette session est clôturée
  GMESSAGE = mess(60,10717,1)
  mkstat = 2 : End
 Endif
 If [M:DEM0]STG<>"" & [F:HRSES]STG<>[M:DEM0]STG
  # Cette session ne dépend pas du stage YYYY
  GMESSAGE = mess(30,10717,1)-[M:DEM0]STG
  mkstat = 2 : End
 Endif
Endif
End

Subprog D_DOM(VALEUR)
Variable Char    VALEUR()
If clalev([F:HRSES])=0 : Local File SESSIONS [HRSES] : Endif
If clalev([F:STG])=0 : Local File STAGE    [STG] : Endif
Call LECTURE("HRSES",[M:DEM1]SES,"") From CONTOBJ
# sba control leg
If !fstat & [F:HRSES]DOM<>""
 VALEUR = func GET_VALDOM([F:HRSES]DOM) : End
Endif

# sba control leg
Call LECTURE("STG",[M:DEM0]STG,"") From CONTOBJ
If !fstat : VALEUR = func GET_VALDOM([F:STG]DOM) : Endif
End

Subprog D_THM(VALEUR)
Variable Char    VALEUR()
If clalev([F:HRSES])=0 : Local File SESSIONS [HRSES] : Endif
If clalev([F:STG])=0 : Local File STAGE    [STG] : Endif
Call LECTURE("HRSES",[M:DEM1]SES,"") From CONTOBJ
# sba control leg
If !fstat & [F:HRSES]THM<>""
 VALEUR = func GET_VALTHM([F:HRSES]THM) : End
Endif
# sba control leg
Call LECTURE("STG",[M:DEM0]STG,"") From CONTOBJ
If !fstat : VALEUR = func GET_VALTHM([F:STG]THM) : Endif
End

Subprog C_DATSTR(VALEUR)
Variable Date    VALEUR
If [M:DEM0]STG<>""
 Read[STG]STG0=[M:DEM0]STG
 If !fstat & VALEUR<>[0/0/0]
&& (([F:STG]STRVLY<>[0/0/0] & VALEUR<[F:STG]STRVLY) | ([F:STG]ENDVLY<>[0/0/0] & VALEUR>[F:STG]ENDVLY))
  # La période de validité du stage est du ../../.. au ../../..
  Call MESSAGE(mess(17,10717,1)-num$([F:STG]STRVLY)-mess(95,100,1)-num$([F:STG]ENDVLY)) From GESECRAN
  VALEUR = [F:STG]STRVLY
  End
 Endif
Endif
End

Subprog C_DATEND(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0] & VALEUR<[M]DATSTR
 # Période incorrecte
 GMESSAGE = mess(25,10702,1)
 mkstat = 2 : End
Endif
If [M:DEM0]STG<>""
 Read[STG]STG0=[M:DEM0]STG
 If !fstat & VALEUR<>[0/0/0] & [F:STG]ENDVLY<>[0/0/0] & VALEUR>[F:STG]ENDVLY
  VALEUR = [F:STG]ENDVLY
  If VALEUR<[M:DEM1]DATSTR
   # La pèriode de validité du stage est du ../../.. au ../../..
   GMESSAGE = mess(17,10717,1)-num$([F:STG]STRVLY)-mess(95,100,1)-num$([F:STG]ENDVLY)
   mkstat = 2 : End
  Else
   # La pèriode de validité du stage est du ../../.. au ../../..
   Call MESSAGE(mess(17,10717,1)-num$([F:STG]STRVLY)-mess(95,100,1)-num$([F:STG]ENDVLY)) From GESECRAN
  Endif
 Endif
Endif
End

Subprog AM_FLGPLF(VALEUR)
Variable Integer VALEUR

If VALEUR=1    : # Dans plan
 Actzo [M]YEAPLF
Elsif VALEUR=2 : # Hors plan
 Effzo [M]YEAPLF
 Grizo [M]YEAPLF
Endif
End

