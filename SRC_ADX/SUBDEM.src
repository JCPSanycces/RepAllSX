#If !fstat & [F:HRSES]CATACN<>0
If !fstat & [F:HRSES]CATACN<>''
#LIPET - 2017-06-27 - X3-35995 - END
 VALEUR = [F:HRSES]CATACN : End
Endif
Call LECTURE("STG",[M:DEM0]STG,"") From CONTOBJ
If !fstat : VALEUR = [F:STG]CATACN : Endif
End

Subprog AM_DESCATACN(VALEUR)
#LIPET - 2017-06-27 - X3-35995 - START
#Variable Integer VALEUR
Variable Char VALEUR
#LIPET - 2017-06-27 - X3-35995 - END
## Non défini au niveau demande -> on ne contrôle pas
#LIPET - 2017-06-27 - X3-35995 - START
#If VALEUR=len(mess(0,10453,1)) : End : Endif
If VALEUR='' : End : Endif
#LIPET - 2017-06-27 - X3-35995 - END
## Non défini au niveau session -> on ne contrôle pas
If [M:DEM1]SES<>""
 Call LECTURE("HRSES",[M:DEM1]SES,"") From CONTOBJ
 If [F:HRSES]CATACN<>len(mess(0,10453,1)) & [F:HRSES]CATACN<>VALEUR
  # Catégorie d'action incompatible avec la session
  GMESSAGE = mess(21,10717,1)
  GERR = 3 : End
 Endif
Elsif [M:DEM0]STG<>""
 ## Non défini au niveau stage -> on ne contrôle pas
 Call LECTURE("STG",[M:DEM0]STG,"") From CONTOBJ
 #LIPET - 2017-06-27 - X3-35995 - START
 #If [F:STG]CATACN<>len(mess(0,10453,1)) & [F:STG]CATACN<>VALEUR
 If [F:STG]CATACN<>'' & [F:STG]CATACN<>VALEUR
 #LIPET - 2017-06-27 - X3-35995 - END
  # Catégorie d'action incompatible avec le stage
  GMESSAGE = mess(20,10717,1)
  GERR = 3 : End
 Endif
Endif
End


