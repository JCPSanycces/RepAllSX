######################################################################################
## Vérifie que la demande correspond au critère cible du stage
######################################################################################

Subprog VERIF_CRITCIBLE(ZONE,VALEUR)
Value Char ZONE
Value Char VALEUR

Local Char    FORMULE(250)
Local Integer I, J, OK
Local Char    CPYDEM(GLONCPY)
Local Char    CPY(GLONCPY)(0..100), FCY(GLONFCY)(0..100)

If clalev([F:STG])=0 : Local File STAGE [STG] : Endif
If [M:DEM0]STG<>""
 Call LECTURE("STG",[M:DEM0]STG,"") From CONTOBJ
 ## Contrôle si la zone est dans le critère cible du stage
 If [F:STG]TRG<>""
  I = 1
  FORMULE = toupper([F:STG]TRG)
  While I
   I = instr(I,FORMULE,ZONE)
   If I
    If mid$(FORMULE,I-1,1)="]"
     J = I-2
     While mid$(FORMULE,J,1)<>"[" & J>0
      J -=1
     Wend
     If J
      FORMULE = left$(FORMULE,J-1)+"VALEUR"+right$(FORMULE,I+len(ZONE))
     Endif
    Else
     FORMULE = left$(FORMULE,I-1)+"VALEUR"+right$(FORMULE,I+len(ZONE))
    Endif
   Endif
  Wend
  Onerrgo ERREUR
  If evalue(FORMULE) = 0
   OK = 2
   # La population n'appartient pas au critère "Autre sélection" visé par le stage
   Call AVERTIR(mess(247,10717,1)-"\"-toupper([F:STG]TRG),OK) From GESECRAN
   If OK=1 : mkstat=2 : Endif
   End
  Endif
  Onerrgo
 Endif

 # FQ74938 - MABON 26/07/11 - Contrôle société et site dans le cadre d'une demande sur une population
 If ZONE="FCY" Then
   If clalev([F:HRSTR])=0 : Local File STAGETRG [HRSTR] : Endif
   Read [F:HRSTR]STR0=[M:DEM0]STG
   If !fstat Then
    ## Contrôle que le salarié appartient à la cible société du stage
    If [F:HRSTR]CPYTRG<>"" & VALEUR<>"" Then
      If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
      Call LECTURE("FCY", VALEUR, "") From CONTOBJ
      CPYDEM=[F:FCY]LEGCPY
      Call CALC_TRG([F:HRSTR]CPYTRG, "COMPANY", "CPY", CPY)
      If !find(CPYDEM,CPY(0..50)) Then
        # La population n'appartient pas aux sociétés ciblées par le stage
        Call AVERTIR(mess(248,10717,1)-"\"-[F:HRSTR]CPYTRG,OK) From GESECRAN
        If OK=1 : mkstat=2 : Endif
        End
      Endif
    Endif

    ## Contrôle que le salarié appartient à la cible site du stage
    If [F:HRSTR]FCYTRG<>"" and VALEUR<>"" Then
      Call CALC_TRG([F:HRSTR]FCYTRG, "FACILITY", "FCY", FCY)
      If !find(VALEUR,FCY(0..50)) Then
        # La population n'appartient pas aux sites ciblés par le stage
        Call AVERTIR(mess(249,10717,1)-"\"-[F:HRSTR]FCYTRG,OK) From GESECRAN
        If OK=1 : mkstat=2 : Endif
        End
      Endif
    Endif
   Endif
 Endif
 # Fin MABON
Endif
End

$ERREUR
Resume


######################################################################################
## Vérifie que le salarié est présent dans la société
######################################################################################

#LIPET - 2017-05-17 - X3-35995 - START
#Subprog VERIF_PRESENCE(MATRI,CTR)
Subprog VERIF_PRESENCE(MATRI,CTR,DAT1,DAT2)
Value Date    DAT1,DAT2
#LIPET - 2017-05-17 - X3-35995 - END
Value Char    MATRI
Value Char    CTR
Local Integer OK

If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif

## Entrée-Sorties
#Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=Date$
#LIPET - 2017-05-17 - X3-35995 - START
#If dim([M:DEM0]DATDEM)>0 Then
#  #Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=[M:DEM0]DATDEM
#  Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=[M:DEM0]DATDEM
#Else
#Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=date$
#Endif
#Read [HRCTR]CTR1 Last
Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & (CTRDAT<=DAT1 | (FLGRET=2 & RETDATEFF<=DAT1))
Read [HRCTR]CTR1 Last
Filter [HRCTR]
#LIPET - 2017-05-17 - X3-35995 - END
If fstat<=2
 #LIPET - 2017-05-17 - X3-35995 - START
 #If [F:HRCTR]XITDAT<>[0/0/0] and [F:HRCTR]XITDAT<date$ and [F:HRCTR]XITFNL=2
 If [F:HRCTR]XITDAT<>[0/0/0] and [F:HRCTR]XITDAT<DAT2 and [F:HRCTR]XITFNL=2
 #LIPET - 2017-05-17 - X3-35995 - END
  # Salarié non présent dans la société
  GMESSAGE = mess(67,10717,1)
  mkstat = 2 : End
 Elsif [F:HRCTR]XITDAT<>[0/0/0]
  OK = 2
  # Sortie du salarié le xx/xx/xx
  Call AVERTIR (mess(68,10717,1)-num$([F:HRCTR]XITDAT),OK) From GESECRAN
  If OK=1 : mkstat=2 : End : Endif
 Endif
Else
 # Salarié non présent dans la société
 GMESSAGE = mess(67,10717,1)
 mkstat = 2 : End
Endif
End


###################################
#LIPET - 2017-05-17 - X3-35995 - START
#Verifie la validité d'un contrat d'un salarié à partir d'une date
Subprog VERIF_PRESENCE_FROM(MATRI,CTR,DAT1)
Value Char    MATRI
Value Char    CTR
Value Date    DAT1
Local Integer OK

If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
If CTRNUM<>"" Then
  Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR
Else
  Filter [HRCTR] Where REFNUM=MATRI & ( [F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=DAT1 )
Endif

Read [HRCTR]CTR1 Last
If fstat<=2
  If [F:HRCTR]XITDAT=[0/0/0]
     # Présent
  Elsif [F:HRCTR]XITDAT>=DAT1
      OK = 2
      # Sortie du salarié le xx/xx/xx après la date
      Call AVERTIR (mess(68,10717,1)-num$([F:HRCTR]XITDAT),OK) From GESECRAN
      If OK=1 : mkstat=2 : End : Endif
  Elsif   ([F:HRCTR]XITDAT<DAT1 and [F:HRCTR]XITFNL=2)
      # filtre ctr terminé + sortie définitive avant la date
      # Salarié non présent dans la société
      GMESSAGE = mess(67,10717,1)
      mkstat = 2 : End
  Else  # [F:CTR]XITDAT<DAT1)
    # ctr terminé mais pas sortie définitive- On n'accepte ou pas - Même message ???
      GMESSAGE = mess(67,10717,1)
      mkstat = 2 : End
  Endif
  Filter [HRCTR]
Else
   Filter [HRCTR]
   # Salarié non présent dans la société
   GMESSAGE = mess(67,10717,1)
   mkstat = 2 : End
Endif
End
#LIPET - 2017-05-17 - X3-35995 - END
#**#####################################################################################
#* En création, initialisation de la date de la demande par la date du jour
#*!
Subprog AS_DATDEM(VALEUR)
Variable Date    VALEUR

  If GREP='C' Then
    VALEUR=date$
  Endif
End

######################################################################################
# SYMEU : EXI 66191 LOT 10 - V6.1 : stage non défini : contrôle du stage
######################################################################################
Subprog C_STG(VALEUR)
Variable Char    VALEUR()
  Call CTL_STG_NON_DEF(VALEUR) From DIVFOR
  If mkstat Then End Endif
  # FQ72868 - MABON 15/04/11 - Récupération Hors plan
  If GREP="C" Then
    Call LECTURE("STG", VALEUR, "") From CONTOBJ
    If !fstat Then
      # FQ93180 - SEGAY 24/10/13 - Initialisation FLGPLF <> 0
      If [F:STG]FLGPLF <> 0
         [M:DEM1]FLGPLF    = [F:STG]FLGPLF
      Else
         [M:DEM1]FLGPLF    = 1
      Endif
      Affzo [M:DEM1]FLGPLF
    Endif
  Endif
  # Fin MABON
End

######################################################################################
# SEGAY : FQ79677 30/01/12 Modification d'un stage dans une demande
######################################################################################
Subprog AM_STG(VALEUR)
Variable Char    VALEUR()
Local Integer L_OK
L_OK = 1
If GREP="C" Then
  Call SETFIELDS("STG")
Endif
If VALEUR="" or  GREP='C' Then
  GCURLEG=[F:STG]LEG
  End
Endif
Local Integer ASK :ASK=0
# SBA modif put condition in a  subprog
Call CHECK_ASKUPDATE("TYPFRT",ASK,"STG")
#If [M:DEM1]ORI=1 & [M:DEM3]DESTYPFRT(0) <> [F:STG]TYPFRT
If ASK
###Voulez-vous initialiser cette demande et le dispositif de formation du participant par les données du stage ?
  Call OUINON(mess(266,10717,1),L_OK) From GESECRAN
Else
  Call CHECK_ASKUPDATE("",ASK,"STG")
  #If [M:DEM1]DOM <> [F:STG]DOM or [M:DEM1]THM <> [F:STG]THM or [M:DEM1]DESNATFIS <> [F:STG]NATFIS or [M:DEM1]DESCATACN <> [F:STG]CATACN
  If ASK
#### Voulez-vous initialiser cette demande par les données du stage ?
    Call OUINON(mess(265,10717,1),L_OK) From GESECRAN
  Endif
Endif
If L_OK=2
  # SBA modif : assign in a subprog
  Call SETFIELDS("STG")
#  [M:DEM1]DOM = [F:STG]DOM
#  Affzo [M:DEM1]DOM
#  [M:DEM1]THM = [F:STG]THM
#  Affzo [M:DEM1]THM
#  If [F:STG]NATFIS<>0
#     [M:DEM1]DESNATFIS=[F:STG]NATFIS
#     Affzo [M:DEM1]DESNATFIS
#  Endif
#  If [F:STG]CATACN<>0
#     [M:DEM1]DESCATACN=[F:STG]CATACN
#     Affzo [M:DEM1]DESCATACN
#  Endif
#  If [M:DEM1]ORI=1 &  [M:DEM3]DESTYPFRT(0) <> [F:STG]TYPFRT
#     [M:DEM3]DESTYPFRT(0)=[F:STG]TYPFRT
#     Affzo [M:DEM3]DESTYPFRT(0)
#  Endif
#  mkstat = 0
Endif
Call SET_FLAGINVALID()
Call DISPLAY_HIDE() From SUBDEMLEG
End
######################################################################################
# SYMEU : EXI 66191 LOT 7 - V6.1 : workflow quand une demande de DIF est saisie
# Gestion de la réponse du manager : Visa ou Refus
######################################################################################
Subprog WRKSIG(ACTION,NUMDEM,EMP,CTRNUM,NUMLIG)
Value Char    ACTION(), NUMDEM(), EMP(), CTRNUM(), NUMLIG()

If !clalev([F:DML]) : Local File DEMLIG  [DML] : Endif
If !clalev([F:DEM]) : Local File DEMANDE [DEM] : Endif
Local Char CRITERE(250)

Read [F:DEM]DEM0 = NUMDEM
If !fstat Then
  Lock ="DML"+NUMDEM
  If fstat
    [V]GOK  =-1
    [V]GLOCK="%DML"+NUMDEM
    End
  Endif
  # on ne veut que les lignes correspondant à la demande dont :
  # - le dispositif est = DIF,
  # - le statut = Saisie,
  # - le participant et le contrat sont ceux reçus en paramètre
  If EMP<>"" Then
    #LIPET - 2017-06-27 - X3-35995 - START
    #[L]CRITERE  = "[F:DML]DEMNUM='"+NUMDEM+"' & [F:DML]EMP='"+EMP+"' & [F:DML]CTRNUM='"+CTRNUM+"' & [F:DML]DESTYPFRT=3 & [F:DML]STA=1"
    [L]CRITERE  = "[F:DML]DEMNUM='"+NUMDEM+"' & [F:DML]EMP='"+EMP+"' & [F:DML]CTRNUM='"+CTRNUM+"' & [F:DML]STA=1"
    #LIPET - 2017-06-27 - X3-35995 - END
  Else
    #LIPET - 2017-06-27 - X3-35995 - START
    #[L]CRITERE  = "[F:DML]DEMNUM='"+NUMDEM+"' & [F:DML]NUMLIG="+NUMLIG+" & [F:DML]DESTYPFRT=3 & [F:DML]STA=1"
    [L]CRITERE  = "[F:DML]DEMNUM='"+NUMDEM+"' & [F:DML]NUMLIG="+NUMLIG+" & [F:DML]STA=1"
    #LIPET - 2017-06-27 - X3-35995 - END
  Endif
  Case ACTION
    When "VIS"   : Update [F:DML] Where evalue([L]CRITERE) With STA=2          : # En cours
    When "#VIS"   : Update [F:DML] Where evalue([L]CRITERE) With STA=5          : # En cours
    When "REF","#REF"   :
      If len(GCOMMENTSIG)>0
        Update [F:DML] Where evalue([L]CRITERE) With STA=3, RENREF=GCOMMENTSIG : # Refusée
      Else
        Update [F:DML] Where evalue([L]CRITERE) With STA=3                     : # Refusée
      Endif
    When Default : End
  Endcase
  If fstat
    [V]GOK=0
    Call RSTA("DML",NUMDEM) From GLOCK
    End
  Endif
Endif

End

######################################################################################
# Workflow quand une demande de DIF est validée par le manager
# Gestion de la réponse du RRH : Visa ou Refus
######################################################################################
Subprog WRKSIGI(ACTION,NUMDEM,EMP,CTRNUM,NUMLIG)
Value Char    ACTION(), NUMDEM(), EMP(), CTRNUM(), NUMLIG()

If !clalev([F:DML]) : Local File DEMLIG  [DML] : Endif
If !clalev([F:DEM]) : Local File DEMANDE [DEM] : Endif
Local Char CRITERE(250)

Read [F:DEM]DEM0 = NUMDEM
If !fstat Then
  Lock ="DML"+NUMDEM
  If fstat
    [V]GOK  =-1
    [V]GLOCK="%DML"+NUMDEM
    End
  Endif
  # on ne veut que les lignes correspondant à la demande dont :
  # - le dispositif est = DIF,
  # - le statut = Saisie,
  # - le participant et le contrat sont ceux reçus en paramètre
  If EMP<>"" Then
    #LIPET - 2017-06-27 - X3-35995 - START
    #[L]CRITERE  = "[F:DML]DEMNUM='"+NUMDEM+"' & [F:DML]EMP='"+EMP+"' & [F:DML]CTRNUM='"+CTRNUM+"' & [F:DML]DESTYPFRT=3 & [F:DML]STA=2"
    [L]CRITERE  = "[F:DML]DEMNUM='"+NUMDEM+"' & [F:DML]EMP='"+EMP+"' & [F:DML]CTRNUM='"+CTRNUM+"' & [F:DML]STA=2"
    #LIPET - 2017-06-27 - X3-35995 - END
  Else
    #LIPET - 2017-06-27 - X3-35995 - START
    #[L]CRITERE  = "[F:DML]DEMNUM='"+NUMDEM+"' & [F:DML]NUMLIG="+NUMLIG+" & [F:DML]DESTYPFRT=3 & [F:DML]STA=2"
    [L]CRITERE  = "[F:DML]DEMNUM='"+NUMDEM+"' & [F:DML]NUMLIG="+NUMLIG+" & [F:DML]STA=2"
    #LIPET - 2017-06-27 - X3-35995 - END
  Endif
  Case ACTION
    When "VIS"   : Update [F:DML] Where evalue([L]CRITERE) With STA=5          : # Acceptée
    When "REF"   :
      If len(GCOMMENTSIG)>0
        Update [F:DML] Where evalue([L]CRITERE) With STA=3, RENREF=GCOMMENTSIG : # Refusée
      Else
        Update [F:DML] Where evalue([L]CRITERE) With STA=3                     : # Refusée
      Endif
    When Default : End
  Endcase
  If fstat
    [V]GOK=0
    Call RSTA("DML",NUMDEM) From GLOCK
    End
  Endif
Endif

End

######################################################################################
# Workflow quand une demande de stage est saisie
# Gestion de la réponse du manager : Visa ou Refus
######################################################################################
Subprog WRKSIGD(ACTION, NUMDEM, REFNUM, CTRNUM, NUMLIG,CRIT1)
Value    Char    ACTION, NUMDEM, REFNUM, CTRNUM, NUMLIG, CRIT1
Local    Char    CRITERE(250)

  If !clalev([F:DML]) : Local File DEMLIG  [DML] : Endif
  If !clalev([F:DEM]) : Local File DEMANDE [DEM] : Endif

  Read [F:DEM]DEM0 = NUMDEM
  If !fstat Then
    Lock ="DML"+NUMDEM
    If fstat Then
      [V]GOK  =-1
      [V]GLOCK="%DML"+NUMDEM
      End
    Endif
    # on ne veut que les lignes correspondant à la demande dont :
    # - le statut = Saisie,
    # - le suivi = Saisie
    If REFNUM<>"" Then
      [L]CRITERE  = "[F:DML]DEMNUM='"+NUMDEM+"' & [F:DML]EMP='"+REFNUM+"' & [F:DML]CTRNUM='"+CTRNUM+"' & [F:DML]STA=1"
   Else
      [L]CRITERE  = "[F:DML]DEMNUM='"+NUMDEM+"' & [F:DML]NUMLIG="+NUMLIG+" & [F:DML]STA=1"
    Endif
    Case ACTION
      When "VIS"   : Update [F:DML] Where evalue([L]CRITERE) With STA=2         : # En cours
      When "#VIS"   : Update [F:DML] Where evalue([L]CRITERE) With STA=5         : # En cours
      When "REF","#REF"   :
        If len(GCOMMENTSIG)>0
          Update [F:DML] Where evalue([L]CRITERE) With STA=3, RENREF=GCOMMENTSIG : # Refusée
        Else
          Update [F:DML] Where evalue([L]CRITERE) With STA=3                     : # Refusée
        Endif
      When Default : End
    Endcase
    If fstat
      [V]GOK=0
      Call RSTA("DML",NUMDEM) From GLOCK
      End
    Endif
    If CRIT1<>"" Then : # Délégation
      Local Char    GRPDEB(250),CHRONO3,DEST3,KEY3(250)
      Local Integer IC
      IC = instr(1,CRIT1,"~")
      CHRONO3 = left$(CRIT1,IC-1)
      DEST3   = right$(CRIT1,IC+1)
      If clalev([F:AWS3])=0 : Local File AWRKHISSUI [AWS3] : Endif
      Read [F:AWS3]AWS0=CHRONO3;DEST3
      If !fstat Then
        If [F:AWS3]NUMORG<>"" Then
          KEY3=[F:AWS3]NUMORG+"~"+[F:AWS3]USRORG+"~"+CRIT1+"~"+GUSER+"~~1"
        Else
          KEY3=CRIT1+"~~~"+GUSER+"~~1"
        Endif
      Endif
      Case ACTION
        When "VIS","#VIS"   : Call WORKPLUS(9,"DEMSTG","VIS",KEY3,"",0,0,0,GRPDEB) From AWRK
        When "REF","#REF"   : Call WORKPLUS(9,"DEMSTG","REF",KEY3,"",0,0,0,GRPDEB) From AWRK
        When Default : End
      Endcase
    Endif
  Endif
End

