End

Subprog AM_DESNATFIS(VALEUR)
#LIPET - 2017-06-27 - X3-35995 - START
#Variable Integer VALEUR
Variable Char VALEUR
#LIPET - 2017-06-27 - X3-35995 - END
## Non défini au niveau demande -> on ne contrôle pas
#LIPET - 2017-06-27 - X3-35995 - START
#If VALEUR=len(mess(0,10452,1)) : End : Endif
If VALEUR='' : End : Endif
#LIPET - 2017-06-27 - X3-35995 - END
## Non défini au niveau session -> on ne contrôle pas
If [M:DEM1]SES<>""
 Call LECTURE("HRSES",[M:DEM1]SES,"") From CONTOBJ
 #LIPET - 2017-06-27 - X3-35995 - START
 #If [F:HRSES]NATFIS<>len(mess(0,10452,1)) & [F:HRSES]NATFIS<>VALEUR
 If [F:HRSES]NATFIS<>'' & [F:HRSES]NATFIS<>VALEUR
 #LIPET - 2017-06-27 - X3-35995 - END
  # Nature fiscale incompatible avec la session
  GMESSAGE = mess(19,10717,1)
  GERR = 3 : End
 Endif
Elsif [M:DEM0]STG<>""
 ## Non défini au niveau stage -> on ne contrôle pas
 Call LECTURE("STG",[M:DEM0]STG,"") From CONTOBJ
 #LIPET - 2017-06-27 - X3-35995 - START
 #If [F:STG]NATFIS<>len(mess(0,10452,1)) & [F:STG]NATFIS<>VALEUR
 If [F:STG]NATFIS<>'' & [F:STG]NATFIS<>VALEUR
 #LIPET - 2017-06-27 - X3-35995 - END
  # Nature fiscale incompatible avec le stage
  GMESSAGE = mess(18,10717,1)
  GERR = 3 : End
 Endif
Endif
End

Subprog D_DESCATACN(VALEUR)
#LIPET - 2017-06-27 - X3-35995 - START
#Variable Integer VALEUR
Variable Char VALEUR
#LIPET - 2017-06-27 - X3-35995 - END
If clalev([F:HRSES])=0 : Local File SESSIONS [HRSES] : Endif
If clalev([F:STG])=0 : Local File STAGE    [STG] : Endif
