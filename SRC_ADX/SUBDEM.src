######################################################################################
#
# SBA : get legislation for the sélection STG,REFNUM and CTRNUM.
#
Funprog FGET_LEGSEL(INDFLD)
Value Integer INDFLD
Local Integer OK
Local  Char MLEG
MLEG=GLEGFIL
Case INDFLD
  When 1 :
    #STG
    GCURLEG=""
   If([M:DEM1]CTR<>"")
      Call GET_LEGHRCTR([M:DEM1]REFNUM,[M:DEM1]CTR,OK,MLEG,0)From TOOLSHRLEG
    Endif
  When 2 :
    GCURLEG=""
   If([M:DEM0]STG<>"")
      Call GET_LEGSTG([M:DEM0]STG,OK,MLEG,0)From TOOLSHRLEG
   Endif
  When 3:
    Call GET_LEGHRCTR([M:DEM1]REFNUM,[M:DEM1]CTR,OK,MLEG,0)From TOOLSHRLEG
Endcase
End MLEG


####################################################
#
# SBA factoring : check condition to update values from stage or sessions
#
Subprog CHECK_ASKUPDATE(TYPREQ,ASK,ORIG)
Value Char TYPREQ
Variable Integer ASK
Value Char ORIG
Gosub  GET_DEFFILE
ASK=0
If(TYPREQ = "TYPFRT")
  If([M:DEM1]CTR<>"" & func FGET_LEGSEL(3)="FRA" & [M:DEM1]ORI=1)
    If [M:DEM3]DESTYPFRT(0) <> [F]TYPFRT
      ASK=1
    Endif
  Endif
Else
  If [M:DEM1]DOM <> func GET_VALDOM([F]DOM) or [M:DEM1]THM <> func GET_VALTHM([F]THM) or
&   (func FGET_LEGSEL(3)="FRA" and([M:DEM1]DESNATFIS <> [F]NATFIS or [M:DEM1]DESCATACN <> [F]CATACN))
    ASK=1
  Endif
Endif
End
####################################################
#
# SBA factoring : set default values from stage or sessions
#
Subprog SETFIELDS(ORIG)
Value Char ORIG

  Gosub  GET_DEFFILE
  GCURLEG=func FGET_LEGSEL(3)
  [M:DEM1]DOM = func GET_VALDOM([F]DOM)
  Affzo [M:DEM1]DOM, ZDOM
  [M:DEM1]THM = func GET_VALTHM([F]THM)
  Affzo [M:DEM1]THM, ZTHM
  #LIPET - 2017-06-27 - X3-35995 - START
  #If [F]NATFIS<>0
  If [F]NATFIS<>""
  #LIPET - 2017-06-27 - X3-35995 - END
    [M:DEM1]DESNATFIS=[F]NATFIS
    #LIPET - 2017-06-27 - X3-35995 - START
    #If(GCURLEG="FRA"or GCURLEG=""): Affzo [M:DEM1]DESNATFIS:Endif
    Affzo [M:DEM1]DESNATFIS
    #LIPET - 2017-06-27 - X3-35995 - END
  Endif
  #LIPET - 2017-06-27 - X3-35995 - START
  If [F]CATACN<>''
  #LIPET - 2017-06-27 - X3-35995 - END
    [M:DEM1]DESCATACN=[F]CATACN
    #LIPET - 2017-06-27 - X3-35995 - START
    #If(GCURLEG="FRA"or GCURLEG=""): Affzo [M:DEM1]DESCATACN:Endif
    Affzo [M:DEM1]DESCATACN
    #LIPET - 2017-06-27 - X3-35995 - END
  Endif
  If [M:DEM1]ORI=1 &  [M:DEM3]DESTYPFRT(0) <> [F]TYPFRT
    [M:DEM3]DESTYPFRT(0)=[F]TYPFRT
    #LIPET - 2017-06-27 - X3-35995 - START
    #If(GCURLEG="FRA"or GCURLEG=""):Affzo [M:DEM3]DESTYPFRT(0):Endif
    Affzo [M:DEM3]DESTYPFRT(0)
    #LIPET - 2017-06-27 - X3-35995 - END
  Endif
  If(ORIG="STG") Then
    [M:DEM1]SES="" : [M:DEM1]ZSES="" : Affzo [M:DEM1]SES, ZSES
  Endif
  mkstat = 0
#LIPET - 2017-06-27 - X3-35995 - END
End

$GET_DEFFILE
  If(ORIG="STG")
    Default File [F:STG]
  Else
    Default File [F:HRSES]
  Endif
Return
####################################
# SBA
# Get value from leg. if leg <> gcurleg result = empty
#
Funprog GET_VALDOM(DOM)
Value Char DOM
Local Char RESULT
Local Char NUMADI
NUMADI="10381"
RESULT=DOM
Gosub VALID_LEGADI
End RESULT

Funprog GET_VALTHM(THM)
Value Char THM
Local Char RESULT
Local Char NUMADI
NUMADI="10457"
RESULT=THM
Gosub VALID_LEGADI
End RESULT

$VALID_LEGADI
GCURLEG=func FGET_LEGSEL(3)
Call CONTROLE("ADI","!",RESULT,NUMADI,mkstat) From CONTOBJ
If(mkstat)
  RESULT=""
  mkstat=0
  Endif
Return

####################################
# force to check fields
# Can be ameliorate ( set only necessary fields )

Subprog SET_FLAGINVALID()
  #Setmok [M:DEM3]With 0
  Setmok [M:DEM3] With 0
  Setmok [M:DEM1]With 0
End

Subprog SETDEFCURLEG(VALEUR,FLD)
 Value Char VALEUR
 Value Char FLD
  If(GCURLEG="")
    If([M:DEM1]CTR<>"" & FLD<>"CTR")
      GCURLEG=func FGET_LEGSEL(3)
    Else
     If(FLD="CTR" & VALEUR<>"")
        Local Integer OK
        Call GET_LEGHRCTR([M:DEM1]REFNUM,VALEUR,OK,GCURLEG,0)From TOOLSHRLEG
     Endif
    Endif
  Endif
End

Subprog CHECK_LEGCTR(MAT,CTR,ORIG)
Value Char MAT
Value Char CTR
Value Char ORIG
Local Integer OK
Local Char TMPLEG
Local Char CURLEG
Local Char SAVLEG
SAVLEG=GCURLEG
Case ORIG
  When "CTR" :
    If([M:DEM0]STG<>"")
        CURLEG=func FGET_LEGSEL(2)
#sba
#    Else
#        CURLEG=GLEGFIL
    Endif
  When "CTRNUM" :
        CURLEG=func FGET_LEGSEL(1)
Endcase
Call GET_LEGHRCTR(MAT,CTR,OK,TMPLEG,0)From TOOLSHRLEG

GCURLEG=SAVLEG
If(CURLEG <>"" and CURLEG<>TMPLEG)
  GMESSAGE = mess(276,10717,1)- CURLEG : # La législation du contrat doit être
  mkstat=2
Endif

End

