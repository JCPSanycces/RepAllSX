## Etiquette ajoutée par le superviseur (écran DEM1) 21/08/2012 16:59:14 (MABON)
######################################################################################
Subprog AP_REFNUM(VALEUR)
Variable Char    VALEUR()
# SEGAY 07/12/12 US 1040 81085
# If REFNUM is updtaded no AM_REFNUM because supervisor go AM_REFNUM
#Call AM_REFNUM(VALEUR)
Local Char TMPMAT
If GREP = "C" & VALEUR = [M]REFNUM
   Call PARAMUTIL("REFNUM",TMPMAT,GUSER,"") From SUBAUS
   If GREP = "C" &  TMPMAT = VALEUR  & [M]CTR = ""  : End : Endif
Endif
If VALEUR = [M]REFNUM : Call AM_REFNUM(VALEUR) : Endif
End


