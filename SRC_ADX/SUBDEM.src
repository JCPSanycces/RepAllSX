######################################################################################
## SEGAY 81085 US 460 (écran DEM3) 15/06/2012 14:53:15 (SEGAY)
######################################################################################
Subprog AVANT_NBRDEM
# SEGAY 81085 US 460
[M]WLEGLIG(nolign-1)=func SUBDEM.FGET_LEGSEL(3)

End

Subprog AS_NBRDEM
If [M:DEM3]FLGINS(nolign-1)>=2
 # Demande de formation non modifiable
 GMESSAGE = mess(85,10717,1)-mess([M:DEM3]FLGINS(nolign-1),10464,1)
 mkstat   = 1 : End
Endif

# MABON - Si demande hiérarchique et qu'origine=Parcours, on ne doit pas pouvoir saisir plusieurs lignes
If [M:DEM1]ORI=2 & [M:DEM1]ORIDEM=2 & nolign>1
 mkstat   = 2 : End
Endif
End

Subprog C_NBRDEM
# Si demande individuelle, on a 1 ligne maximum de participant
If [M:DEM1]ORI=1 & !adxgtb & (status=82 | status=73 | status=65 | status=68 | status=83)
 mkstat = 2 : End
Endif
#MABOS-02/05/13-FQ89650
If status = 65 & [M:DEM3]NBRDEM =1
  Effzo [M:DEM3]
Endif
#end MABOS-02/05/13-FQ89650
End

Subprog AS_STA(VALEUR)
Variable Integer VALEUR
Local Char    NIV
Local Integer I
Call PARAMUTIL("NIVDEM",NIV,GUSER,"") From SUBAUS
## On ne peut pas modifier une demande si on a pas le niveau d'autorisation requis
If val(NIV)<VALEUR
 mkstat=2 : End
Endif
## Les statuts de la demande sont accessibles en fonction du niveau d'autorisation de l'utilisateur
For I=val(NIV)+1 To len(mess(0,10454,1))
 GMENLOC(I) = 1 : # On interdit les statuts dont on a pas le niveau d'autorisation
Next
For I=1 To val(NIV)
 GMENLOC(I) = 0 : # On autorise les statuts dont on a le niveau d'autorisation
Next
End

Subprog C_STA(VALEUR)
Variable Integer VALEUR
Local    Integer I, NBPAR
If VALEUR=len(mess(0,10454,1)) & [M:DEM0]STG=""
 # Stage non renseigné : la demande ne peut pas être acceptée
 GMESSAGE = mess(16,10717,1)
 mkstat = 2 : End
Endif
If VALEUR=len(mess(0,10454,1)) : # acceptée
 For I=0 To [M:DEM3]NBRDEM -1
  If [M:DEM3]STA(I)=len(mess(0,10454,1)) & I<>nolign-1
   NBPAR += [M:DEM3]NBREMP(I)
  Endif
 Next
 If [M:DEM1]SES<>""
  Call LECTURE("HRSES",[M:DEM1]SES,"") From CONTOBJ
  If NBPAR>[F:HRSES]NBRPRTMAX
   # Nombre de participants invalide
   GMESSAGE = mess(6,10717,1)
   mkstat = 2 : End
  Endif
 Else
  Call LECTURE("STG",[M:DEM0]STG,"") From CONTOBJ
  If NBPAR>[F:STG]NBRPRTMAX
   # Nombre de participants invalide
   GMESSAGE = mess(6,10717,1)
   mkstat = 2 : End
  Endif
 Endif
Endif
End

Subprog AM_STA(VALEUR)
Variable Integer VALEUR

  # MABON 10/09/10 - Gestion champ RENREF
  If VALEUR=3 Then
    Actzo [M:DEM3]RENREF(nolign-1)
  Else
    [M:DEM3]RENREF(nolign-1)=""
    Diszo [M:DEM3]RENREF(nolign-1)
  Endif
End

Subprog AS_NBREMP(VALEUR)
Variable Decimal VALEUR

# MABON - Si origine=Parcours, on ne doit pas pouvoir modifier le nombre
If [M:DEM1]ORIDEM=2
 mkstat   = 2 : End
Endif
End

Subprog AM_NBREMP(VALEUR)
Variable Decimal VALEUR
If VALEUR<>1
 Raz [M]EMP(nolign-1),[M]CTRNUM(nolign-1)
 Affzo [M]EMP(nolign-1),CTRNUM(nolign-1)
Endif
End

Subprog AS_EMP(VALEUR)
Variable Char    VALEUR()
If [M]NBREMP(nolign-1)>1
 mkstat = 1 : End
Endif

# MABON - Si origine=Parcours, on ne doit pas pouvoir modifier le matricule
If [M:DEM1]ORIDEM=2
 mkstat   = 2 : End
Endif
End

Subprog C_EMP(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If VALEUR<>""
 Call UNICITE(VALEUR,[M]EMP) From OBJDIV
 If mkstat : End : Endif
 Call CTL_TCHEMP(VALEUR)
 If mkstat=2 : End : Endif
Endif
End

Subprog AM_EMP(VALEUR)
Variable Char    VALEUR()
Local Char CONTRAT(GLONHRCTR)
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
Read [ID]ID0=VALEUR
If !fstat
 [M:DEM3]NAM(nolign-1)    = [F:ID]NAM
 [M:DEM3]SRN(nolign-1)    = [F:ID]SRN
 Filter [ADI] Where NUMTAB=10454 Order By Key CLE=N1
 For [ADI]CLE
  #LIPET - 2017-05-17 - X3-35995 - START
  #If fix((date$-[F:ID]DATBRN)/365)<=[F:ADI]N1
  If fix(([M:DEM0]DATDEM-[F:ID]DATBRN)/365)<=[F:ADI]N1
  #LIPET - 2017-05-17 - X3-35995 - END
   Break
  Endif
 Next
 Filter [ADI]
 [M:DEM3]AGE(nolign-1)    = [F:ADI]CODE
 [M:DEM3]SEX(nolign-1)    = [F:ID]SEX
 [M:DEM3]NBREMP(nolign-1) = 1
 Raz [M:DEM3]CTRNUM(nolign-1)
 Affzo [M]NBREMP(nolign-1), AGE(nolign-1), ZAGE(nolign-1), SEX(nolign-1)

 If [F:ID]FLGMULCTR<>2
#  Call CHERCHE_CTR(VALEUR,date$,CONTRAT) From DIVPAYE
  Call CHERCHE_CTR(VALEUR,[M:DEM0]DATDEM,CONTRAT) From DIVPAYE
  #LIPET - 2017-05-17 - X3-35995 - START
  #Call VERIF_PRESENCE(VALEUR,CONTRAT)
  Call VERIF_PRESENCE_FROM(VALEUR,CONTRAT,[M:DEM0]DATDEM)
  #LIPET - 2017-05-17 - X3-35995 - END
  If mkstat=2 : End : Endif
  # Controls that the contract is in the correct leg
  Call CHECK_LEGCTR(VALEUR,CONTRAT,"CTRNUM")
  If mkstat=2 Then End : Endif
  # Contrôle que le salarié appartient à la cible
  Call VERIF_CIBLE(VALEUR,CONTRAT)
  If mkstat=2 : End : Endif
  [M:DEM3]CTRNUM(nolign-1) = CONTRAT
  Call CAT2483(VALEUR,[M:DEM3]CTRNUM(nolign-1),[M:DEM3]CATFRT(nolign-1))
  Filter [HRCTR] Where REFNUM=VALEUR & CTRNUM=CONTRAT & CTRDAT<=date$
  Read [HRCTR]CTR0 Last
  Filter [HRCTR]
  If !fstat
   [M:DEM3]FCY(nolign-1)    = [F:HRCTR]ETRFCY
   [M:DEM3]SRV(nolign-1)    = [F:HRCTR]ETRSRV

   # SBA porté par le demandeur
   Read [FCY]FCY0=[F:HRCTR]ETRFCY
   If !fstat
    [M:DEM3]CPY(nolign-1)   = [F:FCY]LEGCPY
    #Legistlation code
#    Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
#    GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
#    If GNBLEG=1 : GCURLEG = GDOSLEG : Endif
   Endif
   #SBA fin
   # MABON 10/09/10 - Ajout JOBPOT et POT
   [M:DEM3]JOBPOT(nolign-1) = [F:HRCTR]JOBPOT
   [M:DEM3]POT(nolign-1)    = [F:HRCTR]POT
  Endif
  Affzo [M:DEM3]CTRNUM(nolign-1), CATFRT(nolign-1), FCY(nolign-1), SRV(nolign-1), ZSRV(nolign-1), JOBPOT(nolign-1), POT(nolign-1)
 Endif

Endif
End

Subprog AS_CTRNUM(VALEUR)
Variable Char    VALEUR()
If clalev([F:ID])=0 : Local File EMPLOID [ID] : Endif
Read[ID]ID0=[M]EMP(nolign-1)
If fstat | [M]NBREMP(nolign-1)>1
 mkstat = 1 : End
Endif
If [F:ID]FLGMULCTR<>2
 mkstat = 2 : End
Endif
If [M:DEM3]CTRNUM(nolign-1)=""
 GCURLEG=func FGET_LEGSEL(3)
 #LIPET - 2017-05-17 - X3-35995 - START
 #Call SELCTR([M:DEM3]EMP(nolign-1),date$,date$,VALEUR) From DIVPAYE
 Call SELCTR([M:DEM3]EMP(nolign-1),[M:DEM0]DATDEM,[M:DEM0]DATDEM,VALEUR) From DIVPAYE
 #LIPET - 2017-05-17 - X3-35995 - END
Endif
End

Subprog C_CTRNUM(VALEUR)
Variable Char    VALEUR()
Call CHECK_LEGCTR([M:DEM3]EMP(nolign-1),VALEUR,"CTRNUM")
If(mkstat=2):End:Endif
## Contrôle que le salarié est présent
#LIPET - 2017-05-17 - X3-35995 - START
#Call VERIF_PRESENCE([M:DEM3]EMP(nolign-1),VALEUR)
Call VERIF_PRESENCE_FROM([M:DEM3]EMP(nolign-1),VALEUR,[M:DEM0]DATDEM)
#LIPET - 2017-05-17 - X3-35995 - END
If mkstat=2 : End : Endif
# Contrôle que le salarié appartient à la cible
Call VERIF_CIBLE([M:DEM3]EMP(nolign-1),VALEUR)
If mkstat=2 : End : Endif
End

Subprog AM_CTRNUM(VALEUR)
Variable Char    VALEUR()
#LIPET - 2017-05-17 - X3-35995 - START
Local Date WDAT
[L]WDAT=[F:HRCTR]CTRDAT
#LIPET - 2017-05-17 - X3-35995 - END
If clalev([F:FCY])=0 : Local File FACILITY [FCY]: Endif
Call CAT2483([M:DEM3]EMP(nolign-1),VALEUR,[M:DEM3]CATFRT(nolign-1))
Filter [HRCTR] Where REFNUM=[M:DEM3]EMP(nolign-1) & CTRNUM=VALEUR & CTRDAT<=date$
Read [HRCTR]CTR0 Last
Filter [HRCTR]
If !fstat
 [M:DEM3]FCY(nolign-1)    = [F:HRCTR]ETRFCY
 [M:DEM3]SRV(nolign-1)    = [F:HRCTR]ETRSRV
 Read [FCY]FCY0=[F:HRCTR]ETRFCY
 If !fstat
  [M:DEM3]CPY(nolign-1)   = [F:FCY]LEGCPY
  #Legistlation code
  Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
  GCURLEG=[F:CPY]LEG : GSOCIETE=[F:CPY]CPY
  If GNBLEG=1 : GCURLEG = GDOSLEG : Endif
 Endif
 # MABON 10/09/10 - Ajout JOBPOT et POT
 [M:DEM3]JOBPOT(nolign-1) = [F:HRCTR]JOBPOT
 [M:DEM3]POT(nolign-1)    = [F:HRCTR]POT
Endif
Affzo [DEM3]CTRNUM(nolign-1), CATFRT(nolign-1), FCY(nolign-1), SRV(nolign-1), ZSRV(nolign-1), JOBPOT(nolign-1), POT(nolign-1)
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If [M]EMP(nolign-1)<>""
 mkstat = 2 : End
Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call VERIF_CRITCIBLE("FCY",VALEUR)
Endif
End

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
# SBA pour MABON 29/06/12
#If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
#Read [FCY]FCY0=VALEUR
#If !fstat
# [M:DEM3]CPY(nolign-1)=[F:FCY]LEGCPY
#Endif
If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
If VALEUR="" Then
  [M:DEM3]CPY(nolign-1)=""
Else
  Read [FCY]FCY0=VALEUR
  If !fstat
  [M:DEM3]CPY(nolign-1)=[F:FCY]LEGCPY
  Endif
Endif
End

Subprog AS_CATFRT(VALEUR)
Variable Char    VALEUR()
If [M]EMP(nolign-1)<>"" & VALEUR<>""
 mkstat = 2 : End
Endif
End

Subprog CALC_TRG(TRGTRG, TYPTRG, SUPTRG, TRG_RET)
Value    Char    TRGTRG, TYPTRG, SUPTRG
Variable Char    TRG_RET()(0..100)
Local    Char    TRG(255), TRG_T
Local    Integer I, J, K

  If TYPTRG<>"ADI" Then
    If clalev([F:SUP])>0 Then Close Local File [F:SUP] Endif
    Local File =TYPTRG [SUP]
  Endif

  If TRGTRG<>"" Then
    J=0
    TRG=TRGTRG
    While instr(1,TRG,";")>0
      I=instr(1,TRG,";") : TRG_T=mid$(TRG,1,I-1)
      If instr(1,TRG_T,"&")>0 Then
        K=instr(1,TRG_T,"&")
        If TYPTRG="ADI" Then
          Filter [F:ADI] Where NUMTAB=val(SUPTRG) & CODE>=mid$(TRG_T,1,K-1) and CODE<=mid$(TRG_T,K+1,len(TRG_T))
          For [F:ADI]
            TRG_RET(J) = [F:ADI]CODE : J += 1
          Next
          Filter [F:ADI]
        Else
          Filter [F:SUP] Where evalue(SUPTRG)>=mid$(TRG_T,1,K-1) and evalue(SUPTRG)<=mid$(TRG_T,K+1,len(TRG_T))
          For [F:SUP]
            TRG_RET(J) = evalue("[F:SUP]"+SUPTRG) : J += 1
          Next
          Filter [F:SUP]
        Endif
      Else
        If TYPTRG='COMPANY' Then
          Call CALC_GRPCPY(TRG_T, TRG_RET, J) From TOOLSVAR
        Else
          TRG_RET(J) = TRG_T
          J += 1
        Endif
      Endif
      TRG = right$(TRG,I+1)
    Wend
    If instr(1,TRG,"&")>0 Then
      K=instr(1,TRG,"&")
      If TYPTRG="ADI" Then
        Filter [F:ADI] Where NUMTAB=val(SUPTRG) & CODE>=mid$(TRG,1,K-1) and CODE<=mid$(TRG,K+1,len(TRG))
        For [F:ADI]
          TRG_RET(J) = [F:ADI]CODE : J += 1
        Next
        Filter [F:ADI]
      Else
        Filter [F:SUP] Where evalue(SUPTRG)>=mid$(TRG,1,K-1) and evalue(SUPTRG)<=mid$(TRG,K+1,len(TRG))
        For [F:SUP]
          TRG_RET(J) = evalue("[F:SUP]"+SUPTRG) : J += 1
        Next
        Filter [F:SUP]
      Endif
    Elsif TRG<>"" Then
      If TYPTRG='COMPANY' Then
        Call CALC_GRPCPY(TRG, TRG_RET, J) From TOOLSVAR
      Else
        TRG_RET(J) = TRG
      Endif
    Endif
  Endif
End

Subprog C_CATFRT(VALEUR)
Variable Char    VALEUR()
Local    Integer OK
Local    Char    CAT(GLONADI)(0..100), TRG(255), TRG_T
Local    Integer I, J, K
# MABON - 24/08/10 - La catégorie cible n'est plus dans STAGE mais dans STAGETRG, et c'est un champ à valeurs multiples
#If clalev([F:STG])=0 : Local File STAGE [STG] : Endif
# Call LECTURE("STG",[M:DEM0]STG,"") From CONTOBJ
 ## Contrôle que la catégorie appartient à la cible catégorie du stage
# If [F:STG]CATTRG<>"" & VALEUR<>"" & VALEUR<>[F:STG]CATTRG
#  OK = 2
#  # Le salarié n'appartient pas à la catégorie ciblée par le stage
#  Call AVERTIR(mess(66,10717,1)-":"-[F:STG]CATTRG,OK) From GESECRAN
#  If OK=1 : mkstat=2 : End : Endif
# Endif

  If clalev([F:HRSTR])=0 : Local File STAGETRG [HRSTR] : Endif
  If clalev([F:ADI])=0 : Local File ATABDIV  [ADI] : Endif
  If [M:DEM0]STG<>""
    Read [F:HRSTR]STR0=[M:DEM0]STG
    If !fstat Then
      ## Contrôle que la catégorie appartient à la cible catégorie du stage
      #LIPET - 2017-06-27 - X3-35995 - START
      #Call CALC_TRG([F:HRSTR]CATTRG, "ADI", "453", CAT)
      Call CALC_TRG([F:HRSTR]CATTRG, "ADI", "10453", CAT)
      #LIPET - 2017-06-27 - X3-35995 - END
      If [F:HRSTR]CATTRG<>"" & VALEUR<>"" & !find(VALEUR,CAT(0..25)) Then
        OK = 2
        # Le salarié n'appartient pas à la catégorie ciblée par le stage
        Call AVERTIR(mess(66,10717,1)-":"-[F:HRSTR]CATTRG,OK) From GESECRAN
        If OK=1 : mkstat=2 : End : Endif
      Endif
    Endif
  Endif
End

Subprog D_DESTYPFRT(VALEUR)
#LIPET - 2017-06-27 - X3-35995 - START
#Variable Integer VALEUR
Variable Char VALEUR
#LIPET - 2017-06-27 - X3-35995 - END

If nolign>1
 VALEUR = [M]DESTYPFRT(nolign-2)
Else
#LIPET - 2017-06-27 - X3-35995 - START
 #VALEUR= len(mess(0,10455,1)) :#Non défini
 VALEUR= "" :#Non défini
#LIPET - 2017-06-27 - X3-35995 - END
 If [M:DEM1]SES<>""
  Call LECTURE("HRSES",[M:DEM1]SES,"") From CONTOBJ
  # MABON - 03/09/10 - On n'a plus de flag DIF : c'est géré maintenant en dispositif comme un autre, donc dans TYPFRT
#  If [F:HRSES]FLGDIF=2
#LIPET - 2017-06-27 - X3-35995 - START
  #If [F:HRSES]TYPFRT=3
  #VALEUR =3
  If [F:HRSES]TYPFRT=''
   VALEUR =''
#LIPET - 2017-06-27 - X3-35995 - END
  Else
   VALEUR = [F:HRSES]TYPFRT
  Endif
 Elsif [M:DEM0]STG<>""
  Call LECTURE("STG",[M:DEM0]STG,"") From CONTOBJ
  # MABON - 19/08/10 - On n'a plus de flag DIF : c'est géré maintenant en dispositif comme un autre, donc dans TYPFRT
#  If [F:STG]FLGDIF=2
#LIPET - 2017-06-27 - X3-35995 - START
  #If [F:STG]TYPFRT=3
  # VALEUR = 3
  If [F:STG]TYPFRT=''
   VALEUR = ''
#LIPET - 2017-06-27 - X3-35995 - END
  Else
   VALEUR = [F:STG]TYPFRT
  Endif
 Endif
Endif
End

Subprog AM_DESTYPFRT(VALEUR)
#LIPET - 2017-06-21 - X3-35995 - START
#Variable Integer VALEUR
Variable Char VALEUR
#LIPET - 2017-06-21 - X3-35995 - END
## Non défini au niveau demande -> on ne contrôle pas
#LIPET - 2017-06-21 - X3-35995 - START
#If VALEUR=len(mess(0,10455,1)) : End : Endif
If VALEUR='' : End : Endif
#LIPET - 2017-06-21 - X3-35995 - END
 ## Non défini au niveau session -> on ne contrôle pas
If [M:DEM1]SES<>""
 Call LECTURE("HRSES",[M:DEM1]SES,"") From CONTOBJ
 # MABON - 03/09/10 - On n'a plus de flag DIF : c'est géré maintenant en dispositif comme un autre, donc dans TYPFRT
# If [F:HRSES]TYPFRT<>len(mess(0,10455,1)) & [F:HRSES]TYPFRT<>VALEUR & ([F:HRSES]FLGDIF<>2 | VALEUR<>3)
#LIPET - 2017-06-21 - X3-35995 - START
 #If [F:HRSES]TYPFRT<>len(mess(0,10455,1)) & [F:HRSES]TYPFRT<>VALEUR & ([F:HRSES]TYPFRT<>3 | VALEUR<>3)
 If [F:HRSES]TYPFRT<>'' & [F:HRSES]TYPFRT<>VALEUR & ([F:HRSES]TYPFRT<>'' | VALEUR<>'')
 #LIPET - 2017-06-21 - X3-35995 - END
  # Dispositif incompatible avec la session
  GMESSAGE = mess(23,10717,1)
  GERR = 3 : End
 Endif
Elsif [M:DEM0]STG<>""
 ## Non défini au niveau stage -> on ne contrôle pas
 Call LECTURE("STG",[M:DEM0]STG,"") From CONTOBJ
  # MABON - 19/08/10 - On n'a plus de flag DIF : c'est géré maintenant en dispositif comme un autre, donc dans TYPFRT
# If [F:STG]TYPFRT<>len(mess(0,10455,1)) & [F:STG]TYPFRT<>VALEUR & ([F:STG]FLGDIF<>2 | VALEUR<>3)
#LIPET - 2017-06-21 - X3-35995 - START
 #If [F:STG]TYPFRT<>len(mess(0,10455,1)) & [F:STG]TYPFRT<>VALEUR & ([F:STG]TYPFRT<>3 | VALEUR<>3)
 If [F:STG]TYPFRT<>'' & [F:STG]TYPFRT<>VALEUR & ([F:STG]TYPFRT<>'' | VALEUR<>'')
 #LIPET - 2017-06-21 - X3-35995 - END
  # Dispositif incompatible avec le stage
  GMESSAGE = mess(22,10717,1)
  GERR = 3 : End
 Endif
Endif
End

