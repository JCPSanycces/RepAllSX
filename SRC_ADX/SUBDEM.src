Subprog B2_NBRDEM
If dim(GLIGLETREF)<=0    : Global Integer GLIGLETREF : Endif
If dim(GLIGLETREF)>0
  GLIGLETREF=nolign
Endif
Call IMPRIME
If dim(GLIGLETREF)>0    : Kill GLIGLETREF         : Endif

End


