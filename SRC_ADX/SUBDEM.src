######################################################################################
# Workflow quand une demande de stage est validée par le manager
# Gestion de la réponse du RRH : Visa ou Refus
######################################################################################
Subprog WRKSIGS(ACTION, NUMDEM, REFNUM, CTRNUM, NUMLIG, CRIT1)
Value    Char    ACTION, NUMDEM, REFNUM, CTRNUM, NUMLIG, CRIT1
Local    Char    CRITERE(250)

  If !clalev([F:DML]) : Local File DEMLIG  [DML] : Endif
  If !clalev([F:DEM]) : Local File DEMANDE [DEM] : Endif

  Read [F:DEM]DEM0 = NUMDEM
  If !fstat Then
    Lock ="DML"+NUMDEM
    If fstat Then
      [V]GOK  =-1
      [V]GLOCK="%DML"+NUMDEM
      End
    Endif
    # on ne veut que les lignes correspondant à la demande dont :
    # - le statut = Saisie,
    # - le suivi = Saisie
    If REFNUM<>"" Then
      [L]CRITERE  = "[F:DML]DEMNUM='"+NUMDEM+"' & [F:DML]EMP='"+REFNUM+"' & [F:DML]CTRNUM='"+CTRNUM+"' & [F:DML]STA=2"
    Else
      [L]CRITERE  = "[F:DML]DEMNUM='"+NUMDEM+"' & [F:DML]NUMLIG="+NUMLIG+" & [F:DML]STA=2"
    Endif
    Case ACTION
      When "VIS"   : Update [F:DML] Where evalue([L]CRITERE) With STA=5          : # Acceptée
      When "REF"   :
        If len(GCOMMENTSIG)>0
          Update [F:DML] Where evalue([L]CRITERE) With STA=3, RENREF=GCOMMENTSIG : # Refusée
        Else
          Update [F:DML] Where evalue([L]CRITERE) With STA=3                     : # Refusée
        Endif
      When Default : End
    Endcase
    If fstat
      [V]GOK=0
      Call RSTA("DML",NUMDEM) From GLOCK
      End
    Endif
    If CRIT1<>"" Then : # Délégation
      Local Char    GRPDEB(250),CHRONO3,DEST3,KEY3(250)
      Local Integer IC
      IC = instr(1,CRIT1,"~")
      CHRONO3 = left$(CRIT1,IC-1)
      DEST3   = right$(CRIT1,IC+1)
      If clalev([F:AWS3])=0 : Local File AWRKHISSUI [AWS3] : Endif
      Read [F:AWS3]AWS0=CHRONO3;DEST3
      If !fstat Then
        If [F:AWS3]NUMORG<>"" Then
          KEY3=[F:AWS3]NUMORG+"~"+[F:AWS3]USRORG+"~"+CRIT1+"~"+GUSER+"~~1"
        Else
          KEY3=CRIT1+"~~~"+GUSER+"~~1"
        Endif
      Endif
      Case ACTION
        When "VIS"   : Call WORKPLUS(9,"DEMSTG","VIS",KEY3,"",0,0,0,GRPDEB) From AWRK
        When "REF"   : Call WORKPLUS(9,"DEMSTG","REF",KEY3,"",0,0,0,GRPDEB) From AWRK
        When Default : End
      Endcase
    Endif
  Endif
End

Subprog WRKRER(KRONO,ADEST)
Value Char    KRONO(), ADEST()
#64406 Appellé en fin de workflow demande si 0 signataire trouvé = alimentation CTX(8) avec destinataire routage

 Update [F:AWS2] Where CHRONO = KRONO & DEST = ADEST
&                With  VALCTX8 = DEST

End

Funprog GETUSERDEL(USR_DEL1,USR_DEL2,LEVSIG,CODAWH)
Value Char    USR_DEL1,USR_DEL2
Value Integer LEVSIG
Value Char    CODAWH
Local Char    NATURE,DEST,DEST_DEL
Local Integer I,LRET

  LRET=1
  If !find(LEVSIG,0,1) Then End LRET : Endif

  If clalev([F:AWH2])=0 : Local File AWRKPARH [AWH2] : Endif
  Read [F:AWH2]AWH0=CODAWH
  If LEVSIG=0 Then
    DEST_DEL=USR_DEL1
    DEST    =USR_DEL1
  Else
    DEST_DEL=USR_DEL2
    DEST    =USR_DEL2
  Endif
  I=1
  If [F:AWH2]OPTDEL(I-1)=4 : # Premier de libre
    Filter [AWU2] Where USER=DEST_DEL & VLYSTR<=date$ & (VLYEND=[0/0/0] or VLYEND>=date$)
&                     & (NATURE="" or NATURE=[F:AWH2]NATURE(I-1))
&                     & TYPDEL=2 : # Pouvoir de signature
    Read [AWU2] First
    Filter [AWU2]
    If !fstat
      DEST_DEL = [F:AWU2]USRDEL : # Le premier libre avec pouvoir de signature devient destinataire principal
    Endif
  Endif
  If DEST_DEL<>DEST Then LRET=2 : Endif
End LRET
Subprog D_STA(VALEUR)
Variable Integer  VALEUR
  Actzo [M:DEM3]NBREMP, EMP, CTRNUM, FCY, CATFRT, SRV, SEX, AGE, JOBPOT, POT
End

