Subprog AS_ORGFIN(VALEUR)
Variable Char    VALEUR()
#If [M:DEM3]FLGINS(nolign-1)=2 : # Demande sur plan définitif
# mkstat = 2 : End
#Endif
#--STA_EXI 66191 LOT 1
Local Char LOFIDEF : #--SEGAY STA_EXI 66191 LOT 1
Local Char LSAVOFIDEF : #--SEGAY STA_EXI 66191 LOT 1
#Dans la Demande la valeur par défaut OFIDEF peut-être au niveau de société du matricule
#Call AS_ORGFIN(VALEUR) From SUBSTG
LOFIDEF = ""
If [M]CPY(nolign-1) <> "" & [M]CTRNUM(nolign-1) <> ""
 Call PARAM([M]CPY(nolign-1),"OFIDEF",LOFIDEF) From ADOVAL
 If dim(GOFIDEF )>0
    LSAVOFIDEF =GOFIDEF
    GOFIDEF = LOFIDEF
    Call AS_ORGFIN(VALEUR) From SUBSTG
    GOFIDEF = LSAVOFIDEF
 Endif
Else
 Call AS_ORGFIN(VALEUR) From SUBSTG
Endif
#--END_EXI 66191 LOT 1
End

