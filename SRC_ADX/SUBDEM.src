Subprog C_POT(VALEUR)
Variable Char    VALEUR()
Local Integer I

  For I=0 To [M]NBRDEM
    If I<>nolign-1 Then
      If [M]EMP(I)=[M]EMP(nolign-1) & [M]FCY(I)=[M]FCY(nolign-1) & [M]CATFRT(I)=[M]CATFRT(nolign-1)
&      & [M]SRV(I)=[M]SRV(nolign-1) & [M]SEX(I)=[M]SEX(nolign-1) & [M]AGE(I)=[M]AGE(nolign-1)
&      & [M]JOBPOT(I)=[M]JOBPOT(nolign-1) & [M]POT(I)=VALEUR
        GMESSAGE = mess(28,10717,1)-num$(I+1) : # Demande déjà existante en ligne
        mkstat=2 : End
     Endif
   Endif
  Next
End

######################################################################################
## Recherche de la catégorie 2483 d'un salarié
######################################################################################
Subprog CAT2483(MATRI,CTR,CAT)
Value    Char    MATRI()
Value    Char    CTR()
Variable Char    CAT()
#LIPET - 2017-06-21 - X3-35995 - START
Local Date       WDAT
#LIPET - 2017-06-21 - X3-35995 - END
If clalev([F:ACV])=0     : Local File ACTIV    [ACV]    : Endif
If clalev([F:HRCTRC])=0  : Local File EMPLOCTR [HRCTRC] : Endif

Raz CAT
Read [ACV]CODACT="FRT"
If fstat | [F:ACV]FLACT<>2 : End : Endif
#LIPET - 2017-06-21 - X3-35995 - START
#On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
If dim([M:DEM0]DATDEM)>0 & [M:DEM0]DATDEM<date$ Then
  [L]WDAT = [M:DEM0]DATDEM
Elsif dim([M:HRSES1]STRDAT)>0 & [M:HRSES1]STRDAT<>[0/0/0]
  [L]WDAT = [M:HRSES1]STRDAT
Else
  [L]WDAT = date$
Endif
#LIPET - 2017-06-21 - X3-35995 - END
Filter [HRCTRC] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=date$
Read [HRCTRC]CTR0 Last
Filter [HRCTRC]
#LIPET - 2017-06-21 - X3-35995 - START
# Dans GESDEM
If fstat & dim([M:DEM0]DATDEM)>0
  Filter [HRCTRC] Where REFNUM=MATRI & CTRNUM=CTR & (XITDAT=[0/0/0] | XITDAT>=[L]WDAT)
  Read [HRCTRC]CTR0 Last
Endif
#LIPET - 2017-06-21 - X3-35995 - END
If !fstat
 # SBA add the condition from the leg
 Local Char WLEG
 Local Integer OK,DISP
 Call  GET_LEGFCY([F:HRCTRC]ETRFCY,OK,WLEG,DISP) From TOOLSHRLEG
 If WLEG="FRA"
  CAT = [F:HRCTRC]CATFRT
 Endif
Endif

End

######################################################################################
## Recherche des infos d'un salarié
######################################################################################
Subprog INFOS_SAL(MATRI,CTR,CPY,FCY,JOT,POT)
Value    Char    MATRI()
Value    Char    CTR()
Variable Char    CPY(), FCY(), JOT(), POT()
Local    Date    DATMAT

  If clalev([F:ACV])=0    : Local File ACTIV    [ACV]   : Endif
  If clalev([F:HRCTR])=0  : Local File EMPLOCTR [HRCTR] : Endif
  If clalev([F:FCY])=0    : Local File FACILITY [FCY]   : Endif

  Raz CPY
  Read [ACV]CODACT="FRT"
  If fstat | [F:ACV]FLACT<>2 : End : Endif
  #LIPET - 2017-06-27 - X3-35995 - START
  #On doit prendre la date de rétroactivité au lieu de la date du contrat, pour déterminer la présence du salarié
#  Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & CTRDAT<=date$
#  Read [HRCTR]CTR0 Last
#  Filter [HRCTR]
  If dim([M:DEM0]DATDEM)>0 & [M:DEM0]DATDEM<date$ Then
    [L]DATMAT = [M:DEM0]DATDEM
  Else
    [L]DATMAT = date$
  Endif
  Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & (CTRDAT<=[L]DATMAT | (FLGRET=2 & RETDATEFF<=[L]DATMAT))
  Read [HRCTR]CTR0 Last

  #Dans GESDEM
  If fstat & dim([M:DEM0]DATDEM)>0
   Filter [HRCTR] Where REFNUM=MATRI & CTRNUM=CTR & (XITDAT=[0/0/0] | XITDAT>=[L]DATMAT)
   Read [HRCTR]CTR0 Last
  Endif
  Read [HRCTR]CTR0 Last
  Filter [HRCTR]
  #LIPET - 2017-06-27 - X3-35995 - END
  If !fstat
    FCY=[F:HRCTR]ETRFCY
    Read [F:FCY]FCY0=FCY
    If !fstat Then
      CPY=[F:FCY]LEGCPY
    Endif
    JOT=[F:HRCTR]JOBPOT
    POT=[F:HRCTR]POT
  Endif
End

######################################################################################
## Vérifie que la demande correspond à la cible du stage
######################################################################################
Subprog  VERIF_CIBLEBASE(MATRI,CTR,STAGE)
Value Char    MATRI
Value Char    CTR
Value Char    STAGE
Local Date    DATMAT
Local Integer OK
Local Char    CATEG(GLONADI), MESG(250)(0..3)
Local Char    CPYSAL(GLONCPY), FCYSAL(GLONFCY), JOTSAL(GLONJOT), POTSAL(GLONPOT)
Local Char    CAT(GLONADI)(0..100), CPY(GLONCPY)(0..100), FCY(GLONFCY)(0..100), JOT(GLONJOT)(0..100)
Local Char    POT(GLONPOT)(0..100), POP(GLONPOP)(0..100)
# to display mesg ($ADD_MESG)
Local Integer IND
Local Char    TMP_MSG(150),W_SEP(2)
  If clalev([F:STG])=0 : Local File STAGE [STG] : Endif
  # MABON - 24/08/10 - La catégorie cible n'est plus dans STAGE mais dans STAGETRG, et c'est un champ à valeurs multiples
  If clalev([F:HRSTR])=0 : Local File STAGETRG [HRSTR] : Endif
  If clalev([F:HRPOA])=0 : Local File POPULA   [HRPOA] : Endif
  If STAGE<>""
    #Read [F:HRSTR]STR0=[M:DEM0]STG
    Read [F:HRSTR]STR0=STAGE
    If !fstat Then
      ## Contrôle que le salarié appartient à la cible catégorie du stage
      Call CAT2483(MATRI,CTR,CATEG)
      If [F:HRSTR]CATTRG<>"" and CATEG<>"" Then
        #LIPET - 2017-05-17 - X3-35995 - START
        #Call CALC_TRG([F:HRSTR]CATTRG, "ADI", "453", CAT)
        Call CALC_TRG([F:HRSTR]CATTRG, "ADI", "10453", CAT)
        #LIPET - 2017-05-17 - X3-35995 - END
        If !find(CATEG,CAT(0..50)) Then
          # Le salarié n'appartient pas à la catégorie ciblée par le stage
          TMP_MSG = mess(66,10717,1)-":"-[F:HRSTR]CATTRG
          Gosub ADD_MESG
        Endif
      Endif

      ## Recherche des infos du salarié/contrat
      Call INFOS_SAL(MATRI,CTR,CPYSAL,FCYSAL,JOTSAL,POTSAL)
      ## Contrôle que le salarié appartient à la cible société du stage
      If [F:HRSTR]CPYTRG<>"" and CPYSAL<>"" Then
        Call CALC_TRG([F:HRSTR]CPYTRG, "COMPANY", "CPY", CPY)
        If !find(CPYSAL,CPY(0..50)) Then
         # If MESG<>"" : MESG +="\\" : Endif
          # Le salarié n'appartient pas aux sociétés ciblées par le stage
          #MESG -= mess(107,10717,1)-":"-[F:HRSTR]CPYTRG
          TMP_MSG =  mess(107,10717,1)-":"-[F:HRSTR]CPYTRG
          Gosub ADD_MESG
        Endif
      Endif

      ## Contrôle que le salarié appartient à la cible site du stage
      If [F:HRSTR]FCYTRG<>"" and FCYSAL<>"" Then
        Call CALC_TRG([F:HRSTR]FCYTRG, "FACILITY", "FCY", FCY)
        If !find(FCYSAL,FCY(0..50)) Then
          #If MESG<>"" : MESG +="\\" : Endif
          # Le salarié n'appartient pas aux sites ciblés par le stage
          #MESG -= mess(108,10717,1)-":"-[F:HRSTR]FCYTRG
          TMP_MSG = mess(108,10717,1)-":"-[F:HRSTR]FCYTRG
          Gosub ADD_MESG
        Endif
      Endif

      ## Contrôle que le salarié appartient à la cible emploi type du stage
      If [F:HRSTR]JOTTRG<>"" and JOTSAL<>"" Then
        Call CALC_TRG([F:HRSTR]JOTTRG, "JOBTYP", "COD", JOT)
        If !find(JOTSAL,JOT(0..50)) Then
          #If MESG<>"" : MESG +="\\" : Endif
          # Le salarié n'appartient pas aux emplois types ciblés par le stage
          #MESG -= mess(109,10717,1)-":"-[F:HRSTR]JOTTRG
          TMP_MSG = mess(109,10717,1)-":"-[F:HRSTR]JOTTRG
          Gosub ADD_MESG
        Endif
      Endif

      ## Contrôle que le salarié appartient à la cible poste du stage
      If [F:HRSTR]POTTRG<>"" and POTSAL<>"" Then
        Call CALC_TRG([F:HRSTR]POTTRG, "POSTE", "COD", POT)
        If !find(POTSAL,POT(0..50)) Then
          #If MESG<>"" : MESG +="\\" : Endif
          # Le salarié n'appartient pas aux postes ciblés par le stage
          #MESG -= mess(110,10717,1)-":"-[F:HRSTR]POTTRG
          TMP_MSG = mess(110,10717,1)-":"-[F:HRSTR]POTTRG
          Gosub ADD_MESG
        Endif
      Endif

      ## Contrôle que le salarié appartient à la cible population du stage
      If [F:HRSTR]POPTRG<>"" Then
        Call CALC_TRG([F:HRSTR]POPTRG, "POPUL", "COD", POP)
        OK=1
  # SEGAY 07/12/12 US 1040 81085
  # Contract read in Call INFOS_SAL
  #          For I=0 To dim(POP)-1
  #            Read [F:HRPOA]POA0=POP(I);MATRI
  #            If !fstat Then OK=2 : Break : Endif
  #          Next
        If POP(0)=""
           OK =2
        Else
          For I=0 To dim(POP)-1
            If POP(I) = "" : Break : Endif
            If [F:HRCTR]CTRNUM=CTR & POP(I) <> ""
               Read [F:HRPOA]POA0=POP(I);MATRI;CTR;[F:HRCTR]CTRDAT
               If !fstat Then OK=2 : Break : Endif
            Endif
          Next
        Endif
        If OK=1 Then
          #If MESG<>"" : MESG +="\\" : Endif
          # Le salarié n'appartient pas aux populations ciblées par le stage
          #MESG -= mess(111,10717,1)-":"-[F:HRSTR]POTTRG
# SEGAY 07/12/12 US 1040 81085
#          TMP_MSG = mess(111,10717,1)-":"-[F:HRSTR]POPTRG
# Le contrat du salarié n'appartient pas aux populations ciblées par le stage
          TMP_MSG = mess(297,10717,1)-":"-[F:HRSTR]POPTRG
          Gosub ADD_MESG
        Endif
      Endif
    Endif

    ## Contrôle que le salarié appartient au critère cible du stage
    #Call LECTURE("STG",[M:DEM0]STG,"") From CONTOBJ
    Call LECTURE("STG",STAGE,"") From CONTOBJ
    If [F:STG]TRG<>""
      Gosub OUVRE From WPDEFTABLE
      #LIPET - 2017-05-17 - X3-35995 - START
      #DATMAT = date$
      If dim([M:DEM0]DATDEM)>0 & [M:DEM0]DATDEM<date$ Then
        DATMAT = [M:DEM0]DATDEM
      Else
        DATMAT = date$
      Endif
      #LIPET - 2017-05-17 - X3-35995 - END
      Gosub LECEMP From WPDEFTABLE
      If evalue([F:STG]TRG)=0
        #If MESG<>"" : MESG +="\\" : Endif
        # Le salarié n'appartient pas au critère "Autre sélection" visé par le stage
        #MESG -=mess(10,10717,1)-"\"-toupper([F:STG]TRG)
        TMP_MSG = mess(10,10717,1)-"\"-toupper([F:STG]TRG)
        Gosub ADD_MESG
      Endif
    Endif
    If MESG(0)<>""
      OK = 2 : # OK
      IND=0
      While(IND<4 and MESG(IND)<>"" )
        Call AVERTIR(MESG(IND),OK) From GESECRAN
        If OK=1 : mkstat=2 : End : Endif
        IND+=1
      Wend
    Endif
  Endif
End

$ADD_MESG
If(len(MESG(IND))+len(W_SEP)+len(TMP_MSG)>250)
  W_SEP=""
  IND+=1
Endif
MESG(IND)+=W_SEP+TMP_MSG
W_SEP="\\"
Return

