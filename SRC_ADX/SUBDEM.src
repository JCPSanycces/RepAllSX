Funprog GETDEMCOL(PORI)
Value Integer PORI
Local Char WCOLLABORATEUR(GLONEML)
If PORI = 1 and [M:DEM3]NBRDEM=1 and [M:DEM3]NBREMP(0)=1 and [M:DEM3]EMP(0)<>""
    WCOLLABORATEUR=[M:DEM3]EMP(0)
Else
    WCOLLABORATEUR=""
Endif
End WCOLLABORATEUR

# SEGAY 12/04/13 79713
Funprog GETNUMLIG
Local Integer WNUMLIG
WNUMLIG=0
If dim(GLIGLETREF)>0
   WNUMLIG=GLIGLETREF
Endif
End WNUMLIG

