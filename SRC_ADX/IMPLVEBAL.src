#<AdxTL>@(#)0.0.0.0 $Revision$ 
#<AdxTL>@(#)0.0.0.0 $Revision$
Call IMPORTATION("HRLVEACCRU") From GIMPOBJ
End

###################################################################################
$ACTION
  Case ACTION
    When "IMP_OUVRE"     : Gosub OUVRE        #Import
    When "AP_IMPORT"     : Gosub AP_IMPORT    #Import
    When "IMP_VERIF_MOD" : Gosub IMP_VERIF_MOD#Import
    When "IMP_VERIF_CRE" : Gosub IMP_VERIF_MOD#Import
    When "IMP_CREATION"  : Gosub IMP_MODIF    #Import
    When "IMP_MODIF"  : Gosub IMP_MODIF       #Import
##PEVAN - 2018-03-07 - X3-81606 - START
    When "EXP_OUVRE"     : Gosub EXP_OUVRE    #Export
    When "EXPORT"        : Gosub EXPORT       #Export
##PEVAN - 2018-03-07 - X3-81606 - END
  Endcase
Return


###################################################################################
$OUVRE
  If clalev([F:HRACCR])=0  : Local File HRLVEACCRU [HRACCR]  : Endif
  If clalev([F:HRACCRIM])=0 : Local File HRLVEACCRU [HRACCRIM] : Endif
  Global Integer WERR
  Local Char TIMCOD(250)
  [V]WERR=0
  nolign=0
Return

$IMP_VERIF_MOD
  If !GOK
    OK = 0
  Endif
Return

$IMP_MODIF
  If GOK
    If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
    If clalev([F:FCYIM])=0   : Local File FACILITY [FCYIM]  : Endif
    Filter [F:HRCTR] Where [F:HRCTR]CTRNUM=[F:HRACCR]CTR
    Read [F:HRCTR] First
    Read [F:FCYIM]FCY0=[F:HRCTR]ETRFCY
    GCURLEG = [F:FCYIM]LEG
#PEVAN - 2018-07-30 - X3-90320 - START
#    Call DELETE_FUTURE_ACCRUALS([HRACCR]CTR, [F:HRACCR]LVEACCDAT, TIMCOD, 0, GCURLEG) From SUBDCGGLM
    Call DELETE_FUTURE_ACCRUALS([HRACCR]CTR, [HRACCR]CTRDAT, [F:HRACCR]LVEACCDAT, TIMCOD, 0, GCURLEG) From SUBDCGGLM
#PEVAN - 2018-07-30 - X3-90320 - END
  Endif
Return

###################################################################################

##PEVAN - 2018-03-07 - X3-81606 - START
$EXPORT
  If [F:HRACCR]LVEACCTYP <> "Linking" : [L]OK=0 : Return : Endif
  [F:HRACCR]LVEACCDAT = datesyst
Return

$EXP_OUVRE
Return
##PEVAN - 2018-03-07 - X3-81606 - END

$AP_IMPORT

Gosub TR1

Return

#######################################################################################
#                ENREGISTREMENT DES DONNEES DANS LES TABLES
#######################################################################################
$TR1

Local Integer ACTIVE
Local Date CYCLE_START_DATE, CYCLE_END_DATE
Local Integer VALID : VALID = 0

GOK = 1

If [F:HRACCR]REFNUM = ""
  GOK = 0
  GMESSAGE = "REFNUM cannot be empty"
  Return
Endif

If [HRACCR]CTR = ""
  GOK = 0
  GMESSAGE = "CTR cannot be empty"
  Return
Endif

If [HRACCR]LVEACCLST = ""
  GOK = 0
  GMESSAGE = "Leave Sub Type cannot be empty"
  Return
Endif

Trbegin [F:HRACCR]

#Filter [HRACCRIM] Where [F:HRACCRIM]REFNUM=[F:HRACCR]REFNUM & [HRACCRIM]CTR=[HRACCR]CTR & [HRACCRIM]LVEACCLST=[HRACCR]LVEACCLST & [HRACCRIM]LVEACCDAT=[HRACCR]LVEACCDAT
#If rowcount([HRACCRIM]) = 0
  Call EMPLOYEE_SUB_TYPE_CHECK([F:HRACCR]CTR, [F:HRACCR]LVEACCLST, ACTIVE) From SUBHRBAL
  If ACTIVE = 1
    Call GET_NATURE_OF_EVENT([F:HRACCR]LVEACCLST,TIMCOD) From SUBHRBAL
    If TIMCOD <> "NOTFOUND"
      If clalev([F:TIM])=0     : Local File TIMCOD [TIM]      : Endif
      If clalev([F:HRCTRIM])=0 : Local File EMPLOCTR [HRCTRIM]: Endif
      If clalev([F:FCYIM])=0   : Local File FACILITY [FCYIM]  : Endif
      Filter [F:HRCTRIM] Where [F:HRCTRIM]CTRNUM=[F:HRACCR]CTR
      Read [F:HRCTRIM] First
      Read [F:FCYIM]FCY0=[F:HRCTRIM]ETRFCY
      GCURLEG = [F:FCYIM]LEG
      Call GET_CYCLE_START_DATE_EXTRACTION([F:HRACCR]CTR, [F:HRACCR]LVEACCLST, [F:HRACCR]LVEACCDAT , CYCLE_START_DATE, CYCLE_END_DATE, 0, GCURLEG) From SUBHRBAL

      If CYCLE_END_DATE = [0/0/0]
        GMESSAGE = "Cycle end date for Leave sub type " + [F:HRACCR]LVEACCLST + " cannot be empty"
        GOK = 0
        Rollback
        Return
      Endif
      #PEVAN - X3-104022 2018-08-29 - START
      Local Char ACC(GLONVCR)
      [L]ACC = func SUBDCG.GET_GLM_UNILVENUM([F:HRCTRIM]REFNUM)
#      Gosub GET_TRANSNR
#      If [L]ACC = ""
#        GMESSAGE = "Transaction number could not be created " + [F:HRACCR]LVEACCLST
#        GOK = 0
#        Rollback
#        Return
#      Endif
      #PEVAN - X3-104022 2018-08-29 - END

      [F:HRACCR]LVEACCTRS        = [L]ACC
      [F:HRACCR]LVEACCTIM        = TIMCOD
      [F:HRACCR]SYSDAT           = datesyst
      [F:HRACCR]LVEACCTYP        = mess(417,198,1)
      [F:HRACCR]LVEACCEXP        = CYCLE_END_DATE
      Write [HRACCR]
      GOK = 1
    Else
      GMESSAGE = "Leave sub type " + [HRACCR]LVEACCLST + " is not linked to a Nature of event"
      GOK = 0
    Endif
  Else
    GMESSAGE = "The leave sub type " + [HRACCR]LVEACCLST + " is not active on CTR " + [HRACCR]CTR
    GOK = 0
  Endif
#Else
#  GMESSAGE = "There are records for this CTR " + [HRACCR]CTR
#  GOK = 0
#Endif

If GOK = 1
  Commit
Else
  Rollback
Endif

Return

#########################

$GET_TRANSNR
  If clalev([F:TCA])=0  : Local File TABCOUAFF [TCA]  : Endif
  If clalev ([HRACCR]) = 0 : Local File HRLVEACCRU [HRACCR] : Endif
  Local Integer STAT
  Local Char    COMPTEUR(GLONANM)
  Local Char    ACC(GLONVCR)
  Read [TCA]TCA0 = 15 : # Module Human resources
  COMPTEUR = [F:TCA]CODNUM(24)
  Call NUMERO([L]COMPTEUR,[F:HRCTRIM]ETRFCY,[F:HRCTRIM]DATANC,[F:HRCTRIM]CTRNUM,[L]ACC,[L]STAT) From SUBANM
  If STAT
   Call ERREUR(mess(4,10702,1)-COMPTEUR) From GESECRAN : # "Erreur sur compteur"
   GOK = 0 : End
  Endif
Return

