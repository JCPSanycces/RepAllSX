##########################################################################
Subprog AM_TTRDESFLG(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    Actzo [M:LKP7]SREHD1FLG
    Actzo [M:LKP7]TTRDES
  Else
    Grizo [M:LKP7]SREHD1FLG
    Grizo [M:LKP7]TTRDES
    [M:LKP7]SREHD1FLG = 1
    [M:LKP7]TTRDES = ""
  Endif
  [M:LKP7]TTRDESFLG = VALEUR
  Affzo [M:LKP7]
End

##########################################################################
Subprog AM_QURNUM(VALEUR)
Variable Char    VALEUR()

  If VALEUR = "" Then
    [M:LKP7]QURNAM = ""
  Else
    Read [MQR]MQR0=VALEUR
    If fstat Then
      VALEUR = ""
    Else
      [M:LKP7]QURNAM = [F:MQR]QURNAM
    Endif
  Endif
  [M:LKP7]QURNUM = VALEUR
  Affzo [M:LKP7]
End

##########################################################################
Subprog C_QURNUM(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    Read [MQR]MQR0=VALEUR
    If fstat Then
      GMESSAGE = mess(83,123,1) #Valeur incorrect.
      GERR = 1
      mkstat = 2
    Else
      If [F:MQR]TGR <> "SERREQUEST" Then
        #La cible n'est pas une demande de service. Saisie refusée.
        GMESSAGE = mess(999,182,1)
        GERR = 1
        mkstat = 2
      Endif
    Endif
  Endif
End
