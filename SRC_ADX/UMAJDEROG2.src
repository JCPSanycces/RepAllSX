#<AdxTL>@(#)2.0.0.0 $Revision$

##**
#* MOULINETTE DE CONTRĂ”LE ET DE MAJ DU DĂ‰ROGATOIRE :
#*   Le principe est de comparer les valeurs avec celle d'un nouveau calcul
#*   La mise Ă  jour ne se fait que sur la pĂ©riode courante (si Ă©cart)
#*
#* @param PSIMU         lancement en simulation
#* @param PFULLTRC      trace complĂ¨te
#* @param PCPYTOUS      toutes sociĂ©tĂ©s
#* @param PCPY          sociĂ©tĂ© sĂ©lectionnĂ©e
#* @param PFCYTOUS      tous sites
#* @param PFCY          site sĂ©lectionnĂ©
#* @param PACCCODTOUS   tous codes comptables
#* @param PACCCOD       code comptable sĂ©lectionnĂ©
#* @param PFXDTOUS      tous biens
#* @param PAASREF       bien sĂ©lectionnĂ©
#* @param PEXP1         expression complĂ©mentaire de sĂ©lection (sur FXDASSETS)
#* @param PNIV_COMPTA   = 1 ou 2 (SUR pĂ©riode courante)
#* si niveau = 1 Ă©cart cumulĂ© sur exercice et pĂ©riode
#* si niveau = 2 Ă©cart cumulĂ© sur pĂ©riode
#* si niveau = 1
#* Ă©cart LEG    = (newLEGCUM - initLEGCUM) + (newPERLEGCUM - initPERLEGCUM)
#* Ă©cart LEGRVE = (newLEGRVECUM - initLEGRVECUM) + (newPERLEGRVE - initPERLEGRVE)
#* si niveau = 2
#* Ă©cart LEG    = (newPERLEGCUM - initPERLEGCUM)
#* Ă©cart LEGRVE = (newPERLEGRVE - initPERLEGRVE)
#*
#* @param PNIV_CTRLE = 1 (cumuls exercices) ou 2 (+ cumuls pĂ©riodiques) ou 3 (+ dotation pĂ©riodiques)
#* @param PFORCEBIEN = 2 oui : on Ă©dite le bien mĂŞme si pas d'erreur :uniquement si un bien est sĂ©lectionnĂ©
#* @param PPER1 = 2 oui : on sĂ©lectionne la 1Â° pĂ©riode
#* @param PPERCOUR = 2 oui : on sĂ©lectionne la pĂ©riode courante
# si PPER1 et PPERCOUR Ă  non : on travaille de la 1Â° jusqu'Ă  la periode courante
#*
#* @param PMJQUECOUR = 2 oui : on maj uniquement la pĂ©riode courante
#* @param PCALAUTONOME = 2 oui : fonctionne en autonome : passe par les fcts de calcul copiĂ©es ds ce trt
#* @param PTRTFIRSTPER = 2 oui : la sĂ©lection dĂ©marre de la premiĂ¨re personne sinon de la couranteper courante (et non de la premiĂ¨re)
#*!


# MWA 2018.06.11 X3-93379 : Variable VER inexistante.


Subprog UMAJDEROG(PSIMU, PFULLTRC, PCPYTOUS, PCPY, PFCYTOUS, PFCY,
&                 PACCCODTOUS, PACCCOD, PFXDTOUS, PAASREF, PEXP1,
&                 PNIV_COMPTA, PNIV_CTRLE, PFORCEBIEN, PPER1,
&                 PPERCOUR, PMJQUECOUR, PCALAUTONOME, PTRTFIRSTPER)
Value Integer PSIMU, PFULLTRC, PCPYTOUS
Value Char PCPY()
Value Integer PFCYTOUS
Value Char PFCY()
Value Integer PACCCODTOUS
Value Char PACCCOD()
Value Integer PFXDTOUS
Value Char PAASREF()
Value Char PEXP1()
Value Integer PNIV_COMPTA, PNIV_CTRLE, PFORCEBIEN, PPER1, PPERCOUR, PMJQUECOUR,
&             PCALAUTONOME, PTRTFIRSTPER


###########################################
#    TRAITEMENT DE 1Â° ContrĂ´le du dĂ©rogatoire (exercice courant : per closes et ouvertes)
#                  2Â° MAJ du dĂ©rogatoire
#
# Modifs :
# CBO 2012.12.26 FQ00000  : MAJ (pour ALS)
# MWA 2015.02.24 FQ106373 : Recalcul du dĂ©rogatiore systĂ©matique lorsque l'on vient de UMAJDEROG
# CBO 2015.02.27 FQ106373 : ajout PCALAUTONOME pour forcer Ă  passer par le calcul copiĂ©
# CFF 2015.04.02 H05F58   : Report correction directe chez le client
# CBO 2015.04.16 FQ106373/2 : fct CAL_CMP_MNT pour les abs
# CBO 2015.04.28 FQ106373/3 : ajout code erreur et reformatage

Local Char WRELEASE(100)
WRELEASE = "2015.04.02 FQ00000 : correction contrĂ´le PERLEGCUM/RVE"
###########################################

Local Integer WNQUELPER

    WNQUELPER = 0       # affichage de la 1Â° pĂ©riode Ă  la per courante (si erreur)
    If PPER1 = G_OUI
        WNQUELPER = 1   # affichage de la 1Â° pĂ©riode (si erreur)
    Endif
    If PPERCOUR = G_OUI
        WNQUELPER += 2  # affichage de la pĂ©riode courante (si erreur)
    Endif

    If PNIV_COMPTA < 1 or PNIV_COMPTA > 2
        PNIV_COMPTA = 1
    Endif
    If PNIV_CTRLE < 1 or PNIV_CTRLE > 3
        PNIV_CTRLE = 2
    Endif

    If PSIMU <> G_OUI
        PSIMU    = G_NON : # G_OUI pour le mode simulation, G_NON pour le mode correctif
    Endif
    If PFULLTRC <> G_OUI
        PFULLTRC = G_NON : # G_OUI pour la trace Ă©tendue, G_NON pour la trace normale
    Endif

    If PCPYTOUS = G_OUI
        PCPY = ""
    Else
        PCPYTOUS = G_NON
    Endif

    If PFCYTOUS = G_OUI
        PFCY = ""
    Else
        PFCYTOUS = G_NON
    Endif

    If PACCCODTOUS = G_OUI
        PACCCOD = ""
    Else
        PACCCODTOUS = G_NON
    Endif

    If PFXDTOUS = G_OUI
        PAASREF = ""
    Else
        PFXDTOUS = G_NON
    Endif

    If PFORCEBIEN = G_OUI
        If PAASREF = ""
            PFORCEBIEN = G_NON
        Endif
    Else
        PFORCEBIEN = G_NON
    Endif

    If PMJQUECOUR <> G_OUI
        PMJQUECOUR = G_NON
    Endif

    If PCALAUTONOME <> G_OUI
      PCALAUTONOME = G_NON
    Endif

    If PTRTFIRSTPER <> G_OUI
      PTRTFIRSTPER = G_NON
    Endif
###########################################

Local Integer NB_FXD, NB_DEP, NB_DEP_ERR, NB_DEP_MAJ, NBDEPMJSV
Local Integer NB_FXD_SAV, NB_DEP_SAV, NBDEPERRSV, LNBSOC
Local Integer WNB_ERR_BIEN, WNBERRBIESV
Local Integer I, WDEJA
Local Integer WNOLD_VERS, WSTAPER, WBPREMIERE, WN_VERS, WNDELTA2L
Local Date    STRFIYCOU      # DĂ©but d'exercice courant
Local Date    STRFIYCOU2     # DĂ©but d'exercice suivant (si sel)
Local Date    ENDFIYCOU      # Fin d'exercice courant
Local Date    ENDFIYCOU2     # Fin d'exercice suivant (si sel)
Local Date    STRPERCOU      # DĂ©but de pĂ©riode courante
Local Date    ENDPERCOU      # Fin de pĂ©riode courante
Local Date    ENDPEROUV2     # DerniĂ¨re pĂ©riode ouverte de l'exercice suivant (si sel)
Local Date    WTSTRPERCOU(1..48)
Local Integer WTSTAPER(1..48)
Local Integer WTTYPPST(1..48)
Local Char WMESS(50), WINFOS_PER(200), WSVER(30)
Local Char WFILTRESOC(200), WFILTRE(200), WFILTRE_PLAN(200)
Local Integer WTPERNONOK(50)

# Ces tableaux permettent de charger les infos Ă  afficher lors d'une erreur
# (ou en full trace pour un bien sans erreur)
Local Decimal WTMTFIS_AMT(0..10), WTMTCPT_AMT(0..10)
Local Decimal WTMTFIS_DER(0..10), WTMTCPT_DER(0..10)
Local Char WTLIB_AMT(20)(0..10), WTLIB_DER(20)(0..10)
Local Decimal WTMTRES_AMT(0..10), WTMTRES_DER(0..10)
Local Decimal WERROR, WNB_ERR_PREM, WMTPREM1, WMTPREM2

Local Integer N_PER
Local Decimal WNECART1, WNECART2, WNECART3, WNECART4, WNECARTPLAN
Local Decimal WNEC_LEGC, WNEC_LEGRVEC, WNEC_LEGF, WNEC_LEGRVEF
Local Decimal WNECLEGEC, WNECLEGRVEEC, WNECLEGEF, WNECLEGRVEEF
Local Decimal WNECLEGPC, WNECLEGRVEPC, WNECLEGPF, WNECLEGRVEPF

Local Char TCOL(50)(20)
Local Integer TBCOLNUM(20), TLGCOL(20), NBCOL


Global Integer GPREM_ERR, GTCODE_ERR(100) # FQ106373/3
    If !clalev([CPY])  : Local File COMPANY   [CPY]  : Endif
    If !clalev([CNX])  : Local File CONTEXT   [CNX]  : Endif
    If !clalev([FIY])  : Local File FISCYEAR  [FIY]  : Endif

    Gosub NUMPATCH

    If !clalev([M:DIV])  : Local Mask CALDIV    [DIV]  : Endif
    If !clalev([M:DIV2]) : Local Mask CALDIV2   [DIV2] : Endif
    If !clalev([M:FIY])  : Local Mask CALFIY    [FIY]  : Endif
    If !clalev([M:CNX])  : Local Mask CALCNX    [CNX]  : Endif
    If !clalev([M:DEP])  : Local Mask CALDEP    [DEP]  : Endif
    If !clalev([M:PCPT]) : Local Mask CALDEP    [PCPT] : Endif
    If !clalev([M:PCPO]) : Local Mask CALDEP    [PCPO] : Endif
    If !clalev([M:PFIS]) : Local Mask CALDEP    [PFIS] : Endif
    If !clalev([M:PFIO]) : Local Mask CALDEP    [PFIO] : Endif

    If !clalev([WFAS]) : Local File FXDASSETS [WFAS]  : Endif
    If !clalev([WFA2]) : Local File FXDASSETS [WFA2]  : Endif
    If !clalev([WDEP]) : Local File DEPREC    [WDEP]  : Endif

    NBCOL = 9 # trace figĂ©e Ă  x colonnes

    Gosub DEB_TRACE

    Gosub TRT_SOCS

    Call ECR_TRACE("",0) From GESECRAN
    Call ECR_TRACE("",0) From GESECRAN
    Call ECR_TRACE("==============================================================",0) From GESECRAN
    Call ECR_TRACE(num$(LNBSOC) - "companies processed", 0) From GESECRAN
    Call ECR_TRACE(num$(NB_FXD) + "/" + num$(WNB_ERR_BIEN) - "fixed assets processed/updated", 0) From GESECRAN
    Call ECR_TRACE(num$(NB_DEP) + "/" - num$(NB_DEP_ERR) + "/" - num$(NB_DEP_MAJ) -
&                    "DEPREC read/error/updated", 0) From GESECRAN
    Call ECR_TRACE("---->" - num$(WNB_ERR_PREM) - "on first period", 0) From GESECRAN
    Call ECR_TRACE("==============================================================",0) From GESECRAN

    # CBO 2015.04.21: Fermeture des structures DIV (suite Ă  l'ajout de EXTCALL)
    Close Mask [M:DIV]
    Close Mask [M:DIV2]
    Call FERME_TRACE() From LECFIC
    Call LEC_TRACE() From LECFIC

End

# utile en V5 et V6 :
# Les programmes de calculs (de patchs trop anciens) ne peuvent ĂŞtre utilisĂ©s avec ce traitement.
# on dispose d'1 version recopiĂ©e (compatible) du calcul du dĂ©rogatoire dans ce traitement.
# cela est utilisĂ© jusqu'au patch < 21 en V5 ou < 22 en V6.
# ensuite, on appelle directement ceux du calcul (pour avoir les derniĂ¨res modifs ou corrections).

# -> Recherche des sous-pros de calcul qu'on va utiliser : (soit les recopiĂ©s, soit ceux du calcul directement)

$NUMPATCH

    WSVER = mid$(ver$(0), 9, 2)

    # complĂ¨te Ă  partir de 19
    If WSVER = "15"
        WN_VERS = 5
    Elsif WSVER = "16"
        WN_VERS = 6
    Elsif WSVER = "17"
        WN_VERS = 7
    Elsif WSVER = "18"
        WN_VERS = 8
    Elsif WSVER = "19"
        WN_VERS = 9
    Elsif WSVER >= "20"
        WN_VERS = 10 + max(0, val(WSVER) - 20)
    Endif

    # si WNOLD_VERS > 0 cela veut dire qu'on utilise la
    # copie du calcul intĂ©grĂ©e Ă  cette moulinette (valable pour V5 et V6)
    If (GADONIX = 2 and WN_VERS < 7)
        WNOLD_VERS = WN_VERS
    Endif

    If clalev([F:ZAP])
        Close File [F:ZAP]
    Endif
    Local File APATCH [ZAP]

    Filter [ZAP] Where TYP = "P"
    Read [ZAP] Last
    If fstat
        [F:ZAP]PATNUM = -10
    Endif
    Filter [ZAP]

    # X3-93379
    # If [F:ZAP]VER = 150 and [F:ZAP]PATNUM < 21
    If dim([F:ZAP]VER)>0 and [F:ZAP]VER = 150 and [F:ZAP]PATNUM < 21
        WNOLD_VERS = 5
    # X3-93379
    #Elsif [F:ZAP]VER = 160 and [F:ZAP]PATNUM < 22
    Elsif dim([F:ZAP]VER)>0 and [F:ZAP]VER = 160 and [F:ZAP]PATNUM < 22
        WNOLD_VERS = 6
    Endif
    # FQ106373 calcul intĂ©grĂ©e Ă  cette moulinette si forcĂ© par PCALAUTONOME
    If (WNOLD_VERS = 0 or WNOLD_VERS > 6) and PCALAUTONOME = G_OUI
        WNOLD_VERS = 6
    Endif
Return


$DEB_TRACE
    Call OUVRE_TRACE("Update of Derogatory") From LECFIC

    Call ECR_TRACE("Process                  : UMAJDEROG", 0) From GESECRAN
    Call ECR_TRACE("", 0) From GESECRAN

    Call ECR_TRACE("All companies            :" - mess(PCPYTOUS, 1, 1), 0) From GESECRAN
    If PCPYTOUS = G_NON
    Call ECR_TRACE("Company                  :" - PCPY, 0) From GESECRAN
    Endif
    Call ECR_TRACE("All sites                :" - mess(PFCYTOUS, 1, 1), 0) From GESECRAN
    If PFCYTOUS = G_NON
    Call ECR_TRACE("site                     :" - PFCY, 0) From GESECRAN
    Endif

    Call ECR_TRACE("All accounting codes     :" - mess(PACCCODTOUS, 1, 1), 0) From GESECRAN
    If PACCCODTOUS = G_NON
    Call ECR_TRACE("accounting code          :" - PACCCOD, 0) From GESECRAN
    Endif
    Call ECR_TRACE("All assets               :" - mess(PFXDTOUS, 1, 1), 0) From GESECRAN
    If PFXDTOUS = G_NON
    Call ECR_TRACE("Asset                    :" - PAASREF, 0) From GESECRAN
    Call ECR_TRACE("Detail of each period    :" - mess(PFORCEBIEN, 1, 1), 0) From GESECRAN
    Endif

    If PEXP1 <> ""
    Call ECR_TRACE("Expression               :" - PEXP1, 0) From GESECRAN
    Endif

    Call ECR_TRACE("", 0) From GESECRAN
    Call ECR_TRACE("Full log                 :" - mess(PFULLTRC, 1, 1), 0) From GESECRAN
    Call ECR_TRACE("", 0) From GESECRAN
    Call ECR_TRACE("Comptabilisation level   :" - num$(PNIV_COMPTA), 0) From GESECRAN

    Call ECR_TRACE("", 0) From GESECRAN
    Call ECR_TRACE("level 1 :", 0) From GESECRAN
    Call ECR_TRACE("  For LEG    : delta(LEGCUM) + delta(PERLEGCUM)", 0) From GESECRAN
    Call ECR_TRACE("  For LEGRVE : delta(LEGRVECUM) + delta(PERLEGRVE)", 0) From GESECRAN

    Call ECR_TRACE("level 2 :", 0) From GESECRAN
    Call ECR_TRACE("  For LEG    : delta(PERLEGCUM)", 0) From GESECRAN
    Call ECR_TRACE("  For LEGRVE : delta(PERLEGRVE)", 0) From GESECRAN

    Call ECR_TRACE("", 0) From GESECRAN
    Call ECR_TRACE("Detail Control   :" - num$(PNIV_CTRLE), 0) From GESECRAN

    Call ECR_TRACE("", 0) From GESECRAN
    Call ECR_TRACE("level 1 :", 0) From GESECRAN
    Call ECR_TRACE("   LEGCUM/LEGRVECUM", 0) From GESECRAN
    Call ECR_TRACE("level 2 :", 0) From GESECRAN
    Call ECR_TRACE("   LEGCUM/LEGRVECUM +  PERLEGCUM/PERLEGRVE", 0) From GESECRAN
    Call ECR_TRACE("level 3 :", 0) From GESECRAN
    Call ECR_TRACE("   LEGCUM/LEGRVECUM + PERLEGCUM/PERLEGRVE + LEG/LEGRVE", 0) From GESECRAN

    Call ECR_TRACE("", 0) From GESECRAN
    Call ECR_TRACE("1Â° period                :" - mess(PPER1, 1, 1), 0) From GESECRAN
    Call ECR_TRACE("Current period           :" - mess(PPERCOUR, 1, 1), 0) From GESECRAN
    If PPER1 = G_NON and PPERCOUR = G_NON
    Call ECR_TRACE("All periods              :" - mess(G_OUI, 1, 1), 0) From GESECRAN
    Else
    Call ECR_TRACE("All periods              :" - mess(G_NON, 1, 1), 0) From GESECRAN
    Endif

    Call ECR_TRACE("", 0) From GESECRAN
    Call ECR_TRACE("Simulation               :" - mess(PSIMU, 1, 1), 0) From GESECRAN

    If PTRTFIRSTPER = G_OUI
    Call ECR_TRACE("1Â° readen period         : first period", 0) From GESECRAN
    Else
    Call ECR_TRACE("1Â° readen period         : Current period", 0) From GESECRAN
    Endif
    Call ECR_TRACE("Just current period updated   :" - mess(PMJQUECOUR, 1, 1), 0) From GESECRAN


    If [F:ZAP]PATNUM < 0
        [F:ZAP]PATNUM = 0
    Endif
    Call ECR_TRACE("", 0) From GESECRAN
    Call ECR_TRACE("Version                  :" - num$(WN_VERS), 0) From GESECRAN
    If WN_VERS = 5
    If [F:ZAP]PATNUM < 21
    Call ECR_TRACE("Patch                    :" - num$([F:ZAP]PATNUM) - " < 21", 0) From GESECRAN
    Else
    Call ECR_TRACE("Patch                    :" - num$([F:ZAP]PATNUM) - " >= 21", 0) From GESECRAN
    Endif
    Elsif WN_VERS = 6
    If [F:ZAP]PATNUM < 22
    Call ECR_TRACE("Patch                    :" - num$([F:ZAP]PATNUM) - " < 22", 0) From GESECRAN
    Else
    Call ECR_TRACE("Patch                    :" - num$([F:ZAP]PATNUM) - " >= 22", 0) From GESECRAN
    Endif
    Endif
    Call ECR_TRACE("Internal release         :" - WRELEASE, 0) From GESECRAN
    Call ECR_TRACE("Stand-alone mode         :" - mess(PCALAUTONOME, 1, 1), 0) From GESECRAN # FQ106373

    Call ECR_TRACE("", 0) From GESECRAN
    Call ECR_TRACE("", 0) From GESECRAN
    Call ECR_TRACE("Date" - format$("D:" + GFMDAT4, date$) - "Time" - time$,0) From GESECRAN
    Call ECR_TRACE("", 0) From GESECRAN
Return

$TRT_SOCS

    Raz WTMTFIS_AMT, WTMTCPT_AMT, WTMTFIS_DER, WTMTCPT_DER,
&       WTLIB_AMT, WTLIB_DER, WTMTRES_AMT, WTMTRES_DER


    WDEJA = 0
    If PCPYTOUS = G_OUI
        WFILTRESOC = "1 = 1"
    Else
        Call FILTRE1ELT(WDEJA, WFILTRESOC, PCPYTOUS, "CPY", PCPY)
    Endif
    WDEJA = 0
    If PCPYTOUS = G_OUI and PFCYTOUS = G_OUI and
&       PACCCODTOUS = G_OUI and PFXDTOUS = G_OUI
        WFILTRE = ""
    Else
        Call FILTRE1ELT(WDEJA, WFILTRE, PFCYTOUS, "FCY", PFCY)
        Call FILTRE1ELT(WDEJA, WFILTRE, PACCCODTOUS, "ACCCOD", PACCCOD)
        Call FILTRE1ELT(WDEJA, WFILTRE, PFXDTOUS, "AASREF", PAASREF)

    Endif
    If WFILTRE <> ""
        WFILTRE -= "and"
    Endif
    WFILTRE -= "CPY = [F:CPY]CPY and (ISSDAT >= STRFIYCOU or ISSDAT = [0/0/0])"
    If PEXP1 <> ""
        WFILTRE -= "and (" - PEXP1 + ")"
    Endif

    Call TEMPON("") From GESECRAN
    For [CPY] Where evalue(WFILTRESOC)

        Raz [M:DIV], [M:FIY], [M:CNX], [M:DEP], [M:PCPT], [M:PCPO], [M:PFIS], [M:PFIO]
        Raz [M:DIV2]

        Raz WNEC_LEGC, WNEC_LEGRVEC, WNEC_LEGF, WNEC_LEGRVEF
        Raz WNECLEGEC, WNECLEGRVEEC, WNECLEGEF, WNECLEGRVEEF
        Raz WNECLEGPC, WNECLEGRVEPC, WNECLEGPF, WNECLEGRVEPF

        # Chargement des dates du contexte (courantes et prĂ©cĂ©dentes)
        Call GET_CPY_DAT_CNX([F:CPY]CPY, STRFIYCOU,STRFIYCOU2, ENDFIYCOU, ENDFIYCOU2,
&                            STRPERCOU, ENDPERCOU, ENDPEROUV2, WMESS,
&                            WTSTRPERCOU, WTSTAPER, WTTYPPST)

        If WMESS <> ""
            If PCPYTOUS = G_NON
                Call ECR_TRACE("==============================================================",0) From GESECRAN
                Call ECR_TRACE("", 0) From GESECRAN
                Call ECR_TRACE("Company" - [F:CPY]CPY, 0) From GESECRAN
                Call ECR_TRACE("", 0) From GESECRAN
                Call ECR_TRACE("Error :" - WMESS, 0) From GESECRAN
            Endif
        Else

            Call ECR_TRACE("==============================================================",0) From GESECRAN
            Call ECR_TRACE("", 0) From GESECRAN
            Call ECR_TRACE("Company" - [F:CPY]CPY, 0) From GESECRAN
            Call ECR_TRACE("", 0) From GESECRAN
            Call ECR_TRACE("Context             :" - mess(1, GML_NCONTEXT, 1), 0) From GESECRAN
            Call ECR_TRACE("Current fiscal year :" - format$("D:" + GFMDAT4, STRFIYCOU) - "->" - format$("D:" + GFMDAT4, ENDFIYCOU), 0) From GESECRAN
            Call ECR_TRACE("Current period      :" - format$("D:" + GFMDAT4, STRPERCOU) - "->" - format$("D:" + GFMDAT4, ENDPERCOU), 0) From GESECRAN
            If ENDFIYCOU2 <> [0/0/0]
            Call ECR_TRACE("Next fiscal year    :" - format$("D:" + GFMDAT4, STRFIYCOU2) - "->" - format$("D:" + GFMDAT4, ENDFIYCOU2), 0) From GESECRAN
            Call ECR_TRACE("Last opened period  :" - format$("D:" + GFMDAT4, ENDPEROUV2), 0) From GESECRAN
            Endif
            Call ECR_TRACE("", 0) From GESECRAN

            [M:DIV]SOC = [F:CPY]CPY
            [M:DIV]TRTDEM = "CALVNC"
            If WNOLD_VERS = 5
                Gosub CAL_LEC_PARAMETRES_OV5 From UMAJDEROG5 #CHECK IGNORE_LINE
            Elsif WNOLD_VERS = 6
                Gosub CAL_LEC_PARAMETRES_OV6
            Else
                Gosub CAL_LEC_PARAMETRES From GLOBB1
            Endif

            # Alimentation du masque [M:DIV]
            [M:DIV]CSTLVLMAX = 11
            [M:DIV]CSTFIYMAX = func AFNC.ACTIV("NFIY") : # FQ59941
            [M:DIV]DATNUL    = [0/0/0]
            [M:DIV]MNTNUL    = 0
            [M:DIV]DATFMT    = "D:" + GFMDAT4
            [M:DIV]TRTLVL    = 0                    : # -- Niveau atteint dans le traitement
            [M:DIV]BDEBUG    = 2                    : # Debug
#            [M:DIV]TRTDEM    = "UCORRSITA"
            If WNOLD_VERS = 5
                Call CAL_LEC_CONTEXTES_OV5 ([F:CPY]CPY, WERROR) From UMAJDEROG5 #CHECK IGNORE_LINE
                Call CAL_LEC_EXERCICES_PERIODES_OV5 ([F:CPY]CPY, G300CPFI) From UMAJDEROG5 #CHECK IGNORE_LINE
            Elsif WNOLD_VERS = 6
                Call CAL_LEC_CONTEXTES_OV6 ([F:CPY]CPY, WERROR)
                Call CAL_LEC_EXERCICES_PERIODES_OV6 ([F:CPY]CPY, G300CPFI)
            Else
                Call CAL_LEC_CONTEXTES ([F:CPY]CPY, WERROR) From GLOBB0
                # Alimentation du masque [M:FIY]
                Call CAL_LEC_EXERCICES_PERIODES ([F:CPY]CPY, G300CPFI) From GLOBB0
            Endif

            # Contexte Ă  calculer
            [M:DIV]CNT = G300CPFI
            # Indice exercice courant
            [M:DIV]FEC = find( GVML_TECOURA, [M:FIY]STAFIY )
            # Indice de la pĂ©riode courante de l'exercice courant
            [M:DIV]FPC = [M:FIY]INDDEBPER ([M:DIV]FEC-1) + [M:FIY]INDCURPER ([M:DIV]FEC-1) - 1
            # Devise du contexte Ă  calculer
            [M:DIV]CUR = [M:CNX]CUR (find ([M:DIV]CNT,  [M:CNX]CNX) - 1)
            # Format d'Ă©dition de la devise du contexte Ă  calculer
            [M:DIV]CURFMT = "N3:"+GDEVFMT1 (find([M:DIV]CUR, GDEVISE))
            [M:DIV]DPC = 1  # find( [M:FIY]DATSTRPER ([M:DIV]FPC-1), [M:DEP]PERSTRDAT )
            # FQ106373
            If dim([M:DIV2]EXTCALL) >= 0
             [M:DIV2]EXTCALL = "UMAJDEROG"
            Endif

            Gosub TRT_UNE_SOC

            If NBDEPERRSV = NB_DEP_ERR
                Call ECR_TRACE("Company ->" - [F:CPY]CPY - ":" - num$(NB_FXD - NB_FXD_SAV) - "Fixed assets read without error", 0) From GESECRAN
            Else
                LNBSOC += 1
                Call ECR_TRACE("", 0) From GESECRAN
                Call ECR_TRACE(" Company ->" - [F:CPY]CPY - ":" - num$(NB_FXD - NB_FXD_SAV) + "/" + num$(WNB_ERR_BIEN - WNBERRBIESV) - "Fixed assets read/updated", 0) From GESECRAN
                I = len(" Company ->" - [F:CPY]CPY - ":") - 1
                Call ECR_TRACE(string$(I, " ") + ":" - num$(NB_DEP - NB_DEP_SAV) + "/" - num$(NB_DEP_ERR - NBDEPERRSV) + "/" - num$(NB_DEP_MAJ - NBDEPMJSV) -
&                    "DEPREC read/error/updated", 0) From GESECRAN


                Call ECR_TRACE("", 0) From GESECRAN
                Raz TCOL, TBCOLNUM, TLGCOL
                Call INILG_COL(1, TLGCOL, NBCOL)

                TCOL(1)  = "Sum of Delta :"
                TCOL(2)  = " LEG"
                TCOL(3)  = " LEGRVE"
                TBCOLNUM(2) = 2
                TBCOLNUM(3) = 2
                Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 1)

                Raz TBCOLNUM, TCOL
                TCOL(1)  = "Derogatory :"
                Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 1)

                TBCOLNUM(2) = 1 : TBCOLNUM(3) = 1
                TCOL(1)  = "FIY"
                TCOL(2)  = num$(WNECLEGEC)
                TCOL(3)  = num$(WNECLEGRVEEC)
                Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 1)
                TBCOLNUM(2) = 1 : TBCOLNUM(3) = 1
                TCOL(1)  = "Period"
                TCOL(2)  = num$(WNECLEGPC)
                TCOL(3)  = num$(WNECLEGRVEPC)
                Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 1)

                TBCOLNUM(2) = 1 : TBCOLNUM(3) = 1
                TCOL(1)  = "sum"
                TCOL(2)  = num$(WNEC_LEGC)
                TCOL(3)  = num$(WNEC_LEGRVEC)
                Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 1)

                Call ECR_TRACE("", 0) From GESECRAN


                Raz TBCOLNUM, TCOL
                TCOL(1)  = "Reinstatement :"
                Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 1)

                TBCOLNUM(2) = 1 : TBCOLNUM(3) = 1
                TCOL(1)  = "FIY"
                TCOL(2)  = num$(WNECLEGEF)
                TCOL(3)  = num$(WNECLEGRVEEF)
                Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 1)
                TBCOLNUM(2) = 1 : TBCOLNUM(3) = 1
                TCOL(1)  = "Period"
                TCOL(2)  = num$(WNECLEGPF)
                TCOL(3)  = num$(WNECLEGRVEPF)
                Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 1)

                TCOL(1)  = "sum"
                TCOL(2)  = num$(WNEC_LEGF)
                TCOL(3)  = num$(WNEC_LEGRVEF)
                Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 1)
            Endif
            NB_FXD_SAV = NB_FXD
            WNBERRBIESV = WNB_ERR_BIEN
            NB_DEP_SAV = NB_DEP
            NBDEPERRSV = NB_DEP_ERR
            NBDEPMJSV = NB_DEP_MAJ
        Endif
    Next
    Call TEMPOFF From GESECRAN

Return


$TRT_UNE_SOC

    For [WFAS] Where evalue (WFILTRE)
        NB_FXD += 1
        WDEJA = 0
        If mod(NB_FXD, 100) = 0
            Call TEMPON(num$(NB_FXD) - [F:CPY]CPY - "/" - [F:WFAS]AASREF - "(" + num$(WNB_ERR_BIEN) - "errors)") From GESECRAN
        Endif

        # Boucle sur le plan comptable (toujours prĂ©sent)
        # ===============================================
        WFILTRE_PLAN = "AASREF = [F:WFAS]AASREF "#and DPRPLN = num$(PNUMPLN)"
        If ENDFIYCOU2 = [0/0/0] and ENDPEROUV2 = [0/0/0]
          If PTRTFIRSTPER = G_OUI
            WFILTRE_PLAN -= "and FIYENDDAT = ENDFIYCOU and PERENDDAT <= ENDPERCOU"
          Else
            WFILTRE_PLAN -= "and FIYENDDAT = ENDFIYCOU and PERENDDAT = ENDPERCOU"
          Endif
        Else
          If PTRTFIRSTPER = G_OUI
            WFILTRE_PLAN -= "and (FIYENDDAT = ENDFIYCOU or (FIYENDDAT = ENDFIYCOU2 and PERENDDAT <= ENDPEROUV2))"
          Else
            WFILTRE_PLAN -= "and (FIYENDDAT = ENDFIYCOU or (FIYENDDAT = ENDFIYCOU2 and PERENDDAT = ENDPEROUV2))"
          Endif
        Endif
        Raz GPREM_ERR, GTCODE_ERR # FQ106373/3

        # Lecture du dĂ©rogatoire/rĂ©intĂ©gration Ă  partir des DEPREC (Origine)
        # ==================================================================
        # Lecture du plan comptable [M:PCPT]
        Call LEC_DEPREC(WFILTRE_PLAN, G301CPT, ENDFIYCOU, ENDPERCOU, ENDFIYCOU2, ENDPEROUV2, NB_DEP)
        Transmask [M:DEP] To [M:PCPT]
        Transmask [M:DEP] To [M:PCPO] : # Sauvegarde des valeurs Origine du Comptable
        # Lecture du plan fiscal [M:PFIS]
        Call LEC_DEPREC(WFILTRE_PLAN, G301FIS, ENDFIYCOU, ENDPERCOU, ENDFIYCOU2, ENDPEROUV2, NB_DEP)
        Transmask [M:DEP] To [M:PFIS]
        Transmask [M:DEP] To [M:PFIO] : # Sauvegarde des valeurs Origine du Fiscal

        [M:DIV]DPC = 1

        # Recalcul du dĂ©rogatoire Ă  partir des amortissements (New)
        # =========================================================
        # recalcul du dĂ©rogatoire avec [M:PCPT] et [M:PFIS]
        If WNOLD_VERS = 5
            Gosub CAL_DEROG_REINT_OV5 From UMAJDEROG5 #CHECK IGNORE_LINE
        Elsif WNOLD_VERS = 6
            Gosub CAL_DEROG_REINT_OV6
        Else
            Gosub CAL_DEROG_REINT From GLOBB2
        Endif
        WBPREMIERE = 0
        WNDELTA2L  = 0

        # Controle si les valeurs New sont diffĂ©rentes des valeurs Old
        # ============================================================
        If func FAS_IS_MODIFIED(WTPERNONOK, NB_DEP_ERR, PNIV_CTRLE,
&                WNQUELPER, WBPREMIERE, WNDELTA2L, ENDPERCOU) or PFORCEBIEN = G_OUI

            WNB_ERR_BIEN += 1
            Gosub AFFICHE_ERR_AND_MAJ

            # Maj des donnĂ©es : --> CAS : de la per 1 Ă  la per courante
            If PSIMU = G_NON
                If PMJQUECOUR = G_NON
                    Gosub MAJ_DEPREC_FXDASSETS
                Endif
            Endif

        Endif
    Next
    Filter [WFAS]
Return

# affichage des erreurs sur des pĂ©riodes classiques
$AFFICHE_ERR_AND_MAJ

    Call ECR_TRACE("", 0) From GESECRAN
    Call ECR_TRACE("Error asset :" - [F:WFAS]AASREF +
&          "     (Split :" - mess([F:WFAS]FLGSPL, 1, 1) + ") (Entry origin :" - mess([F:WFAS]CREORI, GML_CREORI, 1) + ")", 1) From GESECRAN


    For N_PER = 1 To [M:DEP]NB_DEP

############################## COMPTABLE

        If WTPERNONOK(N_PER) = 1 or WTPERNONOK(N_PER) = 3 or PFORCEBIEN = G_OUI

            WINFOS_PER = func FINFOSPER([M:PCPT]PERSTRDAT(N_PER-1), WTSTRPERCOU, WTSTAPER, WTTYPPST, WSTAPER)
            Call ECR_TRACE(" Period :" - format$("D:" + GFMDAT4, [M:PCPT]PERSTRDAT(N_PER-1)) -
&        "->" - format$("D:" + GFMDAT4, [M:PCPT]PERENDDAT(N_PER-1)) -
&        "(" + num$(N_PER) + "Â°/" + num$([M:DEP]NB_DEP) + ")"  - WINFOS_PER, 0) From GESECRAN


            Raz TCOL, TBCOLNUM, WNECART1, WNECART2, WNECART3, WNECART4
            Call INILG_COL(1, TLGCOL, NBCOL)
            TBCOLNUM(3) = 2 : TBCOLNUM(5) = 2 : TBCOLNUM(7) = 2 :TBCOLNUM(8) = 2 :TBCOLNUM(9) = 2
            TCOL(1) = "Derogatory"
            TCOL(2) = "[ Initial"
            TCOL(3) = "]"
            TCOL(4) = "[ New"
            TCOL(5) = "]"
            TCOL(6) = " Cas"
            TCOL(7) = "[Delta"
            TCOL(8) = "derog.]"
            TCOL(9) = "[Ec. amt]"
            Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 0)

            Raz TCOL, TBCOLNUM
            TBCOLNUM(2) = 1 : TBCOLNUM(3) = 1 : TBCOLNUM(4) = 1 : TBCOLNUM(5) = 1
            TBCOLNUM(7) = 1 : TBCOLNUM(8) = 1 : TBCOLNUM(9) = 1
            WNECART1 =  [M:PCPT]LEGCUM(N_PER-1) - [M:PCPO]LEGCUM(N_PER-1)
            TCOL(1)  = "LEGCUM/LEGRVECUM"
            TCOL(2)  = num$([M:PCPO]LEGCUM(N_PER-1))
            TCOL(3)  = num$([M:PCPO]LEGRVECUM(N_PER-1))
            WNECART2 = [M:PCPT]LEGRVECUM(N_PER-1) - [M:PCPO]LEGRVECUM(N_PER-1)
            TCOL(4)  = num$([M:PCPT]LEGCUM(N_PER-1))
            TCOL(5)  = num$([M:PCPT]LEGRVECUM(N_PER-1))
            TCOL(6)  = ""
            TCOL(7)  = num$(WNECART1)
            TCOL(8)  = num$(WNECART2)
            WNECARTPLAN = [M:PFIO]DPRCUM(N_PER-1) - [M:PCPO]DPRCUM(N_PER-1)
            TCOL(9)  = num$(WNECARTPLAN)

            If PNIV_CTRLE >= 1
                Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 0)
            Endif

            Raz TCOL
            TBCOLNUM(6) = 2
            WNECART3 =  [M:PCPT]PERLEGCUM(N_PER-1) - [M:PCPO]PERLEGCUM(N_PER-1)
            TCOL(1)  = "PERLEGCUM/PERLEGRVE"
            TCOL(2)  = num$([M:PCPO]PERLEGCUM(N_PER-1))
            TCOL(3)  = num$([M:PCPO]PERLEGRVE(N_PER-1))
            WNECART4 = [M:PCPT]PERLEGRVE(N_PER-1) - [M:PCPO]PERLEGRVE(N_PER-1)
            TCOL(4)  = num$([M:PCPT]PERLEGCUM(N_PER-1))
            TCOL(5)  = num$([M:PCPT]PERLEGRVE(N_PER-1))
            If GPREM_ERR
              TCOL(6)  = num$(GPREM_ERR)
              GPREM_ERR = 0
            Else
              TCOL(6)  = ""
            Endif
            TCOL(7)  = num$(WNECART3)
            TCOL(8)  = num$(WNECART4)
            WNECARTPLAN = ([M:PFIO]PERCLOCUM(N_PER-1) + [M:PFIO]PERCLOEXC(N_PER-1))
&                     - ([M:PCPO]PERCLOCUM(N_PER-1) + [M:PCPO]PERCLOEXC(N_PER-1))
            TCOL(9)  = num$(WNECARTPLAN)
            If PNIV_CTRLE >= 2
                Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 0)
            Endif

            Raz TCOL
            TBCOLNUM(7) = 0 : TBCOLNUM(8) = 0
            TCOL(1)  = "LEG/LEGRVE"
            TCOL(2)  = num$([M:PCPO]LEG(N_PER-1))
            TCOL(3)  = num$([M:PCPO]LEGRVE(N_PER-1))
            TCOL(4)  = num$([M:PCPT]LEG(N_PER-1))
            TCOL(5)  = num$([M:PCPT]LEGRVE(N_PER-1))

            TCOL(6)  = num$(GTCODE_ERR(N_PER-1))
            TCOL(7)  = ""
            TCOL(8)  = ""
            WNECARTPLAN = ([M:PFIO]PERENDDPE(N_PER-1) + [M:PFIO]PEREXCDPR(N_PER-1))
&                     - ([M:PCPO]PERENDDPE(N_PER-1) + [M:PCPO]PEREXCDPR(N_PER-1))
            TCOL(9)  = num$(WNECARTPLAN)
            If PNIV_CTRLE >= 3
              Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 0)
            Endif

# si niveau = 1, on prend [] sinon non
# Ă©cart LEG    = (newLEGCUM - initLEGCUM) + (newPERLEGCUM - initPERLEGCUM)
#              = [WNECART1] + WNECART3
# Ă©cart LEGRVE = (newLEGRVECUM - initLEGRVECUM) + (newPERLEGRVE - initPERLEGRVE)
#              = [WNECART2] + WNECART4

#WNECART1 LEGCUM
#WNECART2 LEGRVECUM
#WNECART3 PERLEGCUM
#WNECART4 PERLEGRVE

            If WSTAPER = 2 # statut courant
                Raz TCOL, TBCOLNUM
                TBCOLNUM(6) = 1 : TBCOLNUM(7) = 1
                TCOL(1)  = "Delta"
                If PNIV_COMPTA = 1
                    TCOL(7)  = num$(WNECART1 + WNECART3)
                    TCOL(8)  = num$(WNECART2 + WNECART4)
                    WNEC_LEGC    += WNECART1 + WNECART3
                    WNEC_LEGRVEC += WNECART2 + WNECART4

                    WNECLEGEC += WNECART1
                    WNECLEGRVEEC += WNECART2
                    WNECLEGPC += WNECART3
                    WNECLEGRVEPC += WNECART4
                Else
                    TCOL(7)  = num$(WNECART3)
                    TCOL(8)  = num$(WNECART4)
                    WNEC_LEGC    += WNECART3
                    WNEC_LEGRVEC += WNECART4

#                WNECLEGEC += WNECART1
#                WNECLEGRVEEC += WNECART2
                    WNECLEGPC += WNECART3
                    WNECLEGRVEPC += WNECART4
                Endif
                If TCOL(7) <> "0" or  TCOL(8) <> "0"
                    Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 1)
                Endif
            Endif
        Endif

############################## FISCAL

        If WTPERNONOK(N_PER) = 2 or WTPERNONOK(N_PER) = 3 or PFORCEBIEN = G_OUI

            If WTPERNONOK(N_PER) = 2
                WINFOS_PER = func FINFOSPER([M:PCPT]PERSTRDAT(N_PER-1), WTSTRPERCOU, WTSTAPER, WTTYPPST, WSTAPER)
                Call ECR_TRACE(" Period :" - format$("D:" + GFMDAT4, [M:PCPT]PERSTRDAT(N_PER-1)) -
&        "->" - format$("D:" + GFMDAT4, [M:PCPT]PERENDDAT(N_PER-1)) -
&        "(" + num$(N_PER) + "Â°/" + num$([M:DEP]NB_DEP) + ")" - WINFOS_PER, 0) From GESECRAN
            Endif

            Raz TCOL, TBCOLNUM, WNECART1, WNECART2, WNECART3, WNECART4
            Call INILG_COL(1, TLGCOL, NBCOL)
            TBCOLNUM(3) = 2 : TBCOLNUM(5) = 2 : TBCOLNUM(7) = 2 :TBCOLNUM(8) = 2 :TBCOLNUM(9) = 2

            TCOL(1) = "Reinstatement"
            TCOL(2) = "[ Initial"
            TCOL(3) = "]"
            TCOL(4) = "[ New"
            TCOL(5) = "]"
            TCOL(6) = ""
            TCOL(7) = "[Delta"
            TCOL(8) = "]"
            TCOL(9) = "[Ec. Amt]"
            Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 0)

            Raz TCOL, TBCOLNUM
            TBCOLNUM(2) = 1 : TBCOLNUM(3) = 1 : TBCOLNUM(4) = 1 : TBCOLNUM(5) = 1
            TBCOLNUM(7) = 1 : TBCOLNUM(8) = 1 : TBCOLNUM(9) = 1
            WNECART1 =  [M:PFIS]LEGCUM(N_PER-1) - [M:PFIO]LEGCUM(N_PER-1)
            TCOL(1)  = "LEGCUM/LEGRVECUM"
            TCOL(2)  = num$([M:PFIO]LEGCUM(N_PER-1))
            TCOL(3)  = num$([M:PFIO]LEGRVECUM(N_PER-1))
            WNECART2 = [M:PFIS]LEGRVECUM(N_PER-1) - [M:PFIO]LEGRVECUM(N_PER-1)
            TCOL(4)  = num$([M:PFIS]LEGCUM(N_PER-1))
            TCOL(5)  = num$([M:PFIS]LEGRVECUM(N_PER-1))
            TCOL(7)  = num$(WNECART1)
            TCOL(8)  = num$(WNECART2)
            WNECARTPLAN = [M:PFIO]DPRCUM(N_PER-1) - [M:PCPO]DPRCUM(N_PER-1)
            TCOL(9)  = num$(-WNECARTPLAN)
            If PNIV_CTRLE >= 1
                Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 0)
            Endif

            Raz TCOL
            WNECART3 =  [M:PFIS]PERLEGCUM(N_PER-1) - [M:PFIO]PERLEGCUM(N_PER-1)
            TCOL(1)  = "PERLEGCUM/PERLEGRVE"
            TCOL(2)  = num$([M:PFIO]PERLEGCUM(N_PER-1))
            TCOL(3)  = num$([M:PFIO]PERLEGRVE(N_PER-1))
            WNECART4 = [M:PFIS]PERLEGRVE(N_PER-1) - [M:PFIO]PERLEGRVE(N_PER-1)
            TCOL(4)  = num$([M:PFIS]PERLEGCUM(N_PER-1))
            TCOL(5)  = num$([M:PFIS]PERLEGRVE(N_PER-1))
            TCOL(7)  = num$(WNECART3)
            TCOL(8)  = num$(WNECART4)
            WNECARTPLAN = ([M:PFIO]PERCLOCUM(N_PER-1) + [M:PFIO]PERCLOEXC(N_PER-1))
&                     - ([M:PCPO]PERCLOCUM(N_PER-1) + [M:PCPO]PERCLOEXC(N_PER-1))
            TCOL(9)  = num$(-WNECARTPLAN)

            If PNIV_CTRLE >= 2
                Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 0)
            Endif

            Raz TCOL
            TBCOLNUM(7) = 0 : TBCOLNUM(8) = 0
            TCOL(1)  = "LEG/LEGRVE"
            TCOL(2)  = num$([M:PFIO]LEG(N_PER-1))
            TCOL(3)  = num$([M:PFIO]LEGRVE(N_PER-1))
            TCOL(4)  = num$([M:PFIS]LEG(N_PER-1))
            TCOL(5)  = num$([M:PFIS]LEGRVE(N_PER-1))
            TCOL(7)  = ""
            TCOL(8)  = ""
            WNECARTPLAN = ([M:PFIO]PERENDDPE(N_PER-1) + [M:PFIO]PEREXCDPR(N_PER-1))
&                     - ([M:PCPO]PERENDDPE(N_PER-1) + [M:PCPO]PEREXCDPR(N_PER-1))
            TCOL(9)  = num$(-WNECARTPLAN)
            If PNIV_CTRLE >= 3
                Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 0)
            Endif

            If WSTAPER = 2 # statut courant
                Raz TCOL, TBCOLNUM
                TBCOLNUM(7) = 1 : TBCOLNUM(8) = 1
                TCOL(1)  = "Delta"
                If PNIV_COMPTA = 1
                    TCOL(7)  = num$(WNECART1 + WNECART3)
                    TCOL(8)  = num$(WNECART2 + WNECART4)
                    WNEC_LEGF    += WNECART1 + WNECART3
                    WNEC_LEGRVEF += WNECART2 + WNECART4

                    WNECLEGEF += WNECART1
                    WNECLEGRVEEF += WNECART2
                    WNECLEGPF += WNECART3
                    WNECLEGRVEPF += WNECART4
                Else
                    TCOL(7)  = num$(WNECART3)
                    TCOL(8)  = num$(WNECART4)
                    WNEC_LEGF    += WNECART3
                    WNEC_LEGRVEF += WNECART4

#                WNECLEGEF += WNECART1
#                WNECLEGRVEEF += WNECART2
                    WNECLEGPF += WNECART3
                    WNECLEGRVEPF += WNECART4

                Endif
                If TCOL(7) <> "0" or  TCOL(8) <> "0"
                    Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 1)
                Endif
            Endif

            #################### Erreur sur 1Â° pĂ©riode : delta DPR et LEG
            If WBPREMIERE
                Gosub ERRPREM_LIGNE
                WNB_ERR_PREM += 1
            Endif
        Endif

        # cumuls exercice diffĂ©rents sur 2 pĂ©riodes
        If WNDELTA2L and WNDELTA2L = N_PER

            If WTPERNONOK(N_PER) = 0

                WINFOS_PER = func FINFOSPER([M:PCPT]PERSTRDAT(N_PER-1), WTSTRPERCOU, WTSTAPER, WTTYPPST, WSTAPER)
                Call ECR_TRACE(" Period :" - format$("D:" + GFMDAT4, [M:PCPT]PERSTRDAT(N_PER-1)) -
&        "->" - format$("D:" + GFMDAT4, [M:PCPT]PERENDDAT(N_PER-1)) -
&        "(" + num$(N_PER) + "Â°/" + num$([M:DEP]NB_DEP) + ")"  - WINFOS_PER, 0) From GESECRAN

            Endif

            Gosub WNDELTA2L
        Endif
        WBPREMIERE = 0

        # Maj des donnĂ©es : --> CAS : uniquement la per courante
        If PMJQUECOUR = G_OUI
            If PSIMU = G_NON and WSTAPER = 2 and
&              (WTPERNONOK(N_PER) >= 1 and WTPERNONOK(N_PER) <= 3)

                Trbegin [WDEP]
                FLGOK = G_OUI

                Gosub MAJ_DEPREC_DET
                If FLGOK = G_OUI
                    Gosub MAJ_FXDASSETS
                Endif

                If FLGOK = G_OUI
#                  Rollback
                    Commit
                Else
                    Rollback
                Endif
            Endif
        Endif
    Next
Return

# Affichage d'1 erreur sur la 1Â° pĂ©riode :
# la situation initiale est mauvaise (cumuls dĂ©but exercice)
$ERRPREM_LIGNE

    Call ECR_TRACE("  ----> Caution : error on first period :", -1) From GESECRAN
    Call INILG_COL(2, TLGCOL, NBCOL)

    WMTPREM1 = [M:PFIO]DPRCUM(0) - [M:PCPO]DPRCUM(0)
    WMTPREM2 = ([M:PCPO]LEGCUM(0) - [M:PCPO]LEGRVECUM(0)) - ([M:PFIO]LEGCUM(0) - [M:PFIO]LEGRVECUM(0))
    If WMTPREM1 <> WMTPREM2

        Raz TCOL, TBCOLNUM
        TBCOLNUM(3) = 1 : TBCOLNUM(5) = 1 : TBCOLNUM(8) = 1
        TBCOLNUM(2) = 2 : TBCOLNUM(4) = 2 : TBCOLNUM(7) = 2

        TCOL(1)  = "FiY :"
        TCOL(2)  = "Delta DPR"
        TCOL(3)  = num$(WMTPREM1)
        TCOL(4)  = "Delta LEG"
        TCOL(5)  = num$(WMTPREM2)
        TCOL(7)  = "Delta"
        TCOL(8)  = num$(WMTPREM1 - WMTPREM2)
        Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 1)
    Endif

    WMTPREM1 = ([M:PFIO]PERCLOCUM(0) + [M:PFIO]PERCLOEXC(0)) - ([M:PCPO]PERCLOCUM(0) + [M:PCPO]PERCLOEXC(0))
    WMTPREM2 = ([M:PCPO]PERLEGCUM(0) - [M:PCPO]PERLEGRVE(0)) - ([M:PFIO]PERLEGCUM(0) - [M:PFIO]PERLEGRVE(0))
    If WMTPREM1 <> WMTPREM2

        Raz TCOL, TBCOLNUM
        TBCOLNUM(3) = 1 : TBCOLNUM(5) = 1 : TBCOLNUM(8) = 1
        TBCOLNUM(2) = 2 : TBCOLNUM(4) = 2 : TBCOLNUM(7) = 2

        TCOL(1)  = "period :"
        TCOL(2)  = "Delta DPR"
        TCOL(3)  = num$(WMTPREM1)
        TCOL(4)  = "Delta LEG"
        TCOL(5)  = num$(WMTPREM2)
        TCOL(7)  = "Delta"
        TCOL(8)  = num$(WMTPREM1 - WMTPREM2)

        Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 1)
    Endif
Return

# Affichage d'1 erreur sur 1 nÂ° pĂ©riode :
# les cumuls exercice sont diffĂ©rents entre les 2
$WNDELTA2L
    Call ECR_TRACE("  ----> Caution : error between 2 periods (FY's sums are differents) :", -1) From GESECRAN
    Call INILG_COL(3, TLGCOL, NBCOL)

    If [M:PCPO]DPRCUM(N_PER-1) <> [M:PCPO]DPRCUM(N_PER-2) or
&      [M:PFIO]DPRCUM(N_PER-1) <> [M:PFIO]DPRCUM(N_PER-2)

        Raz TCOL, TBCOLNUM
        TBCOLNUM(3) = 2 : TBCOLNUM(4) = 2 : TBCOLNUM(5) = 2

        TCOL(1)  = "Period :"
        TCOL(3)  = "precedent"
        TCOL(4)  = "checked"
        TCOL(5)  = "Delta"
        Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 1)

        If [M:PCPO]DPRCUM(N_PER-1) <> [M:PCPO]DPRCUM(N_PER-2)
            Raz TCOL, TBCOLNUM
            TBCOLNUM(3) = 1 : TBCOLNUM(4) = 1 : TBCOLNUM(5) = 1
            TBCOLNUM(2) = 2

            TCOL(1)  = mess(G301CPT, GML_NPLAN, 1)
            TCOL(2)  = "DPRCUM"
            TCOL(3)  = num$([M:PCPO]DPRCUM(N_PER-2))
            TCOL(4)  = num$([M:PCPO]DPRCUM(N_PER-1))
            TCOL(5)  = num$([M:PCPO]DPRCUM(N_PER-1) - [M:PCPO]DPRCUM(N_PER-2))
            Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 1)
        Endif

        If [M:PFIO]DPRCUM(N_PER-1) <> [M:PFIO]DPRCUM(N_PER-2)
            Raz TCOL, TBCOLNUM
            TBCOLNUM(3) = 1 : TBCOLNUM(4) = 1 : TBCOLNUM(5) = 1
            TBCOLNUM(2) = 2

            TCOL(1)  = mess(G301FIS, GML_NPLAN, 1)
            TCOL(2)  = "DPRCUM"
            TCOL(3)  = num$([M:PFIO]DPRCUM(N_PER-2))
            TCOL(4)  = num$([M:PFIO]DPRCUM(N_PER-1))
            TCOL(5)  = num$([M:PFIO]DPRCUM(N_PER-1) - [M:PFIO]DPRCUM(N_PER-2))
            Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 1)
        Endif
    Endif

###################################################

    If [M:PCPO]LEGCUM(N_PER-1) <> [M:PCPO]LEGCUM(N_PER-2) or
&      [M:PCPO]LEGRVECUM(N_PER-1) <> [M:PCPO]LEGRVECUM(N_PER-2) or
&      [M:PFIO]LEGCUM(N_PER-1) <> [M:PFIO]LEGCUM(N_PER-2) or
&      [M:PFIO]LEGRVECUM(N_PER-1) <> [M:PFIO]LEGRVECUM(N_PER-2)

        Raz TCOL, TBCOLNUM
        TBCOLNUM(3) = 2 : TBCOLNUM(4) = 2 : TBCOLNUM(5) = 2
        TBCOLNUM(7) = 2 : TBCOLNUM(8) = 2 : TBCOLNUM(9) = 2

        TCOL(1)  = "Period :"
        TCOL(3)  = "precedent"
        TCOL(4)  = "checked"
        TCOL(5)  = "Delta"
        TCOL(7)  = "precedent"
        TCOL(8)  = "checked"
        TCOL(9)  = "Delta"
        Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 1)

        If [M:PCPO]LEGCUM(N_PER-1) <> [M:PCPO]LEGCUM(N_PER-2) or
&          [M:PCPO]LEGRVECUM(N_PER-1) <> [M:PCPO]LEGRVECUM(N_PER-2)
            Raz TCOL, TBCOLNUM
            TBCOLNUM(3) = 1 : TBCOLNUM(4) = 1 : TBCOLNUM(5) = 1
            TBCOLNUM(7) = 1 : TBCOLNUM(8) = 1 : TBCOLNUM(9) = 1
            TBCOLNUM(2) = 2 : TBCOLNUM(6) = 2

            TCOL(1)  = mess(G301CPT, GML_NPLAN, 1)
            TCOL(2)  = "LEGCUM"
            TCOL(3)  = num$([M:PCPO]LEGCUM(N_PER-2))
            TCOL(4)  = num$([M:PCPO]LEGCUM(N_PER-1))
            TCOL(5)  = num$([M:PCPO]LEGCUM(N_PER-1) - [M:PCPO]LEGCUM(N_PER-2))
            TCOL(6)  = "LEGRVECUM"
            TCOL(7)  = num$([M:PCPO]LEGRVECUM(N_PER-2))
            TCOL(8)  = num$([M:PCPO]LEGRVECUM(N_PER-1))
            TCOL(9)  = num$([M:PCPO]LEGRVECUM(N_PER-1) - [M:PCPO]LEGRVECUM(N_PER-2))
            Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 1)
        Endif

        If [M:PFIO]LEGCUM(N_PER-1) <> [M:PFIO]LEGCUM(N_PER-2) or
&          [M:PFIO]LEGRVECUM(N_PER-1) <> [M:PFIO]LEGRVECUM(N_PER-2)
            Raz TCOL, TBCOLNUM
            TBCOLNUM(3) = 1 : TBCOLNUM(4) = 1 : TBCOLNUM(5) = 1
            TBCOLNUM(7) = 1 : TBCOLNUM(8) = 1 : TBCOLNUM(9) = 1
            TBCOLNUM(2) = 2 : TBCOLNUM(6) = 2

            TCOL(1)  = mess(G301FIS, GML_NPLAN, 1)
            TCOL(2)  = "LEGCUM"
            TCOL(3)  = num$([M:PFIO]LEGCUM(N_PER-2))
            TCOL(4)  = num$([M:PFIO]LEGCUM(N_PER-1))
            TCOL(5)  = num$([M:PFIO]LEGCUM(N_PER-1) - [M:PFIO]LEGCUM(N_PER-2))
            TCOL(6)  = "LEGRVECUM"
            TCOL(7)  = num$([M:PFIO]LEGRVECUM(N_PER-2))
            TCOL(8)  = num$([M:PFIO]LEGRVECUM(N_PER-1))
            TCOL(9)  = num$([M:PFIO]LEGRVECUM(N_PER-1) - [M:PFIO]LEGRVECUM(N_PER-2))
            Call AFFICHE_COL(TCOL, TBCOLNUM, TLGCOL, NBCOL, 1)
        Endif
    Endif

Return


Subprog AFFICHE_COL(PTCOL, PTBCOLNUM, PTLGCOL, PNBCOL, PBANO)
Value Char PTCOL()()
Value Integer PTBCOLNUM(), PTLGCOL(), PNBCOL, PBANO

    Local Integer I
    Local Char WLIGNE(250)

    WLIGNE = " "
    For I = 1 To PNBCOL
        If I = 8
            WLIGNE += " "
        Endif
        WLIGNE += func AFFCHP(PTLGCOL(I), PTCOL(I), 0, PTBCOLNUM(I))
    Next I
    If PBANO
        Call ECR_TRACE(WLIGNE, -1) From GESECRAN
    Else
        Call ECR_TRACE(WLIGNE, 0) From GESECRAN
    Endif
End

Subprog INILG_COL(PTYPE, RLGCOL, PNBCOL)
Value Integer PTYPE #1 : std 2 : premiere per 3 : delta entre deux per
Variable Integer RLGCOL()
Value Integer PNBCOL

    Local Integer I

    For I = 1 To PNBCOL
        RLGCOL(I) = 13
    Next I

    If PTYPE = 1
        RLGCOL(1) = 20
        RLGCOL(6) = 4
        RLGCOL(7) = 11
        RLGCOL(8) = 11
    Else
        RLGCOL(1) = 10
    Endif

End

Funprog AFFCHP(PLEN_COL, PCHP, PPASZERO, PBCOLNUM)
Value Integer PLEN_COL
Value Char PCHP()
Value Integer PPASZERO, PBCOLNUM # 1 col num  2 col alpha Ă  cadrer Ă  droite

    Local Integer LG, LG2

    If (PPASZERO and PCHP = "0") or PCHP = ""
        End string$(PLEN_COL, " ")
    Endif

    # cadrage Ă  droite d'1 alpha
    LG = len(PCHP)
    If PBCOLNUM = 2
    If PLEN_COL < LG
#Infbox "" -  PCHP - num$(PLEN_COL) - num$(LG)
End "XX"
    Endif
        End string$(PLEN_COL - LG, " ") + left$(PCHP, LG)
    Endif

    If LG > 2
        If PBCOLNUM = 1
            If mid$(PCHP, LG -2, 1) = "," or  mid$(PCHP, LG -2, 1) = "."
                LG += 0
            Elsif mid$(PCHP, LG -1, 1) = "," or  mid$(PCHP, LG -1, 1) = "."
                PCHP += "0"
                LG += 1
            Else
                PCHP += ".00"
                LG += 3
            Endif
        Endif
    Elsif LG > 0 and PBCOLNUM = 1
        PCHP += ".00"
        LG += 3
    Endif

    LG2 = PLEN_COL - LG
    If LG2 > 0
        If PBCOLNUM = 1
            End string$(LG2, " ") + left$(PCHP, LG)
        Else
            End PCHP + string$(LG2, " ")
        Endif
    Endif
End left$(PCHP, PLEN_COL)


Funprog FINFOSPER(PPERSTRDAT, PTSTRPERCOU, PTSTAPER, PTTYPPST, RSTATPER)
Value Date PPERSTRDAT
Value Date    PTSTRPERCOU(1..)
Value Integer PTSTAPER(1..)
Value Integer PTTYPPST(1..)
Variable Integer RSTATPER

Local Integer I
    RSTATPER = 0
    For I = 1 To 48
        If PPERSTRDAT = PTSTRPERCOU(I)
            RSTATPER = PTSTAPER(I)
            End "(Period status" - mess(PTSTAPER(I), GML_STATPER, 1) - "/ Posting type" - mess(PTTYPPST(I), GML_TYPPST, 1) + ")"
        Endif
        If PTSTRPERCOU(I) = [0/0/0]
            End ""
        Endif
    Next I
End ""


#**
#* Infos du contexte :
#* Remarque : la partie sur l'exercice suivant n'est pas d'actualitĂ© : donc en commentaires
#*
#*
#* @param PCPY
#* @param RSTRFIYCOU
#* @param RSTRFIYCOU2
#* @param RENDFIYCOU
#* @param RENDFIYCOU2
#* @param RSTRPERCOU
#* @param RENDPERCOU
#* @param RENDPEROUV2
#* @param RMESS
#* @param RTSTRFIYCOU
#* @param RTSTAPER
#* @param RTTYPPST
#*!
Subprog GET_CPY_DAT_CNX(PCPY, RSTRFIYCOU, RSTRFIYCOU2, RENDFIYCOU, RENDFIYCOU2,
&                        RSTRPERCOU, RENDPERCOU, RENDPEROUV2, RMESS,
&                        RTSTRFIYCOU, RTSTAPER, RTTYPPST)
Value    Char    PCPY           # SociĂ©tĂ© passĂ©e en paramĂ¨tre
Variable Date    RSTRFIYCOU     # DĂ©but d'exercice COUrant
Variable Date    RSTRFIYCOU2    # DĂ©but d'exercice suivant (si)
Variable Date    RENDFIYCOU     # Fin d'exercice COUrant
Variable Date    RENDFIYCOU2    # Fin d'exercice suivant (si)
Variable Date    RSTRPERCOU     # DĂ©but de pĂ©riode COUrante
Variable Date    RENDPERCOU     # Fin de pĂ©riode COUrante
Variable Date    RENDPEROUV2    # DerniĂ¨re pĂ©riode ouverte exe suivant
Variable Char    RMESS()
Variable Date    RTSTRFIYCOU(1..)
Variable Integer RTSTAPER(1..)
Variable Integer RTTYPPST(1..)


Local Date    LDATSTRFIY
Local Integer I, J

    RSTRFIYCOU2 = [0/0/0]
    RENDFIYCOU2 = [0/0/0]
    RENDPEROUV2 = [0/0/0]
    RMESS = ""
    Read [CNX]CNX0= PCPY; 1
    If fstat
        RMESS = "Context" - mess(1, GML_NCONTEXT, 1) - "not found"
        End
    Endif

    # verif si les plans cptbles et fiscal existent
    RRET = find(G301CPT, [F:CNX]PLNCAA(0..([F:CNX]NBPLC - 1)))
    If RRET = 0
        RMESS = "Plan" - mess(G301CPT, GML_NPLAN, 1) - "not found"
        End
    Endif
    RRET = find(G301FIS, [F:CNX]PLNCAA(0..([F:CNX]NBPLC - 1)))
    If RRET = 0
        RMESS = "Plan" - mess(G301FIS, GML_NPLAN, 1) - "not found"
        End
    Endif

    # lecture de l'exercice courant
    Filter [FIY] Where (CPY=PCPY & CNX=[F:CNX]CNX & STAFIY=GVML_TECOURA)
    Read [FIY] First
    Filter [FIY]
    If !fstat
        If [F:FIY]DATSTRFIY = [0/0/0]
            RMESS = "DATSTRFIY = [0/0/0]"
            Filter [CNX]
            End
        Endif
        If [F:FIY]DATENDFIY = [0/0/0]
            RMESS = "DATENDFIY = [0/0/0]"
            Filter [CNX]
            End
        Endif
        If [F:FIY]DATSTRPER([F:FIY]INDCURPER - 1) = [0/0/0]
            RMESS = "DATSTRPER = [0/0/0]"
            Filter [CNX]
            End
        Endif
        If [F:FIY]DATENDPER([F:FIY]INDCURPER - 1) = [0/0/0]
            RMESS = "DATENDPER = [0/0/0]"
            Filter [CNX]
            End
        Endif

        # dernier exercice Ă  traiter
        RSTRFIYCOU = [F:FIY]DATSTRFIY
        RENDFIYCOU = [F:FIY]DATENDFIY

        # derniĂ¨re pĂ©riode Ă  traiter (per courante)
        RSTRPERCOU = [F:FIY]DATSTRPER([F:FIY]INDCURPER - 1)
        RENDPERCOU = [F:FIY]DATENDPER([F:FIY]INDCURPER - 1)

        J = 0
        For I = 0 To [F:FIY]NBRPER
            If [F:FIY]DATSTRPER(I) = [0/0/0]
                Break
            Endif
            RTSTRFIYCOU(I + 1) = [F:FIY]DATSTRPER(I)
            RTSTAPER(I + 1) = [F:FIY]STAPER(I)
            RTTYPPST(I + 1) = [F:FIY]TYPPST(I)
            J = I + 1
        Next I

    Endif
    Filter [CNX]

End

Subprog FILTRE1ELT(RDEJA, RFILTRE, PCHPTOUS, PNOMCHP, PVALCHP)
Variable Integer RDEJA
Variable Char RFILTRE()
Value Integer PCHPTOUS
Value Char PNOMCHP(), PVALCHP()

Local Char WFILTRE2(200)
    If PCHPTOUS = G_OUI
        End
    Endif

    I = instr(1, PVALCHP, "*")
    If I
        WFILTRE2 = '(' +PNOMCHP - '>= "' + left$(PVALCHP, I - 1)
        WFILTRE2 += '" and' - PNOMCHP - '<= "' + left$(PVALCHP, I - 1) + 'Z")'
    Else
        WFILTRE2 = PNOMCHP - '= P' + PNOMCHP
    Endif

    If RDEJA
        RFILTRE -= "and" - WFILTRE2
    Else
        RDEJA = 1
        RFILTRE = WFILTRE2
    Endif
End

Subprog  LEC_DEPREC (PFILTRE_PLAN, PNUMPLN,
&       ENDFIYCOU, ENDPERCOU, ENDFIYCOU2, ENDPEROUV2, RNB_DEP)
Value Char PFILTRE_PLAN()
Value Integer PNUMPLN
Value Date ENDFIYCOU, ENDPERCOU, ENDFIYCOU2, ENDPEROUV2
Variable Integer RNB_DEP
  Raz [M:DEP]

  Local Date    DTFNEXE
  Local Integer INDDEP
  INDDEP = 1

  PFILTRE_PLAN -= "and DPRPLN =" - num$(PNUMPLN)
  For [WDEP]DEP0 Where evalue(PFILTRE_PLAN)
    nolign = INDDEP
    [M:DEP]=[F:WDEP]
    [M:DEP]FLGACT(nolign-1) = "N"
    INDDEP +=1
    RNB_DEP += 1
  Next
  [M:DEP]NB_DEP = INDDEP-1
End

Funprog FAS_IS_MODIFIED(RTPERNONOK, RNB_DEP_ERR, PNIV_CTRLE,
&                       PNQUELPER, RBPREMIERE, RNDELTA2L, PEPCOUCPY)
Variable Integer RTPERNONOK(), RNB_DEP_ERR
Value Integer PNIV_CTRLE, PNQUELPER
Variable Integer RBPREMIERE, RNDELTA2L
Value Date PEPCOUCPY

Local Shortint RET
Local Shortint COND1
Local Shortint COND2
Local Shortint COND3

  RET = 0
  Raz RTPERNONOK

  Local Integer N_PER

  For N_PER = 1 To [M:DEP]NB_DEP

      # La 1Â° pĂ©riode est diffĂ©rente :
      # si la situation de dĂ©part n'est pas ok : le reste ne devrait pas l'ĂŞtre !
      If N_PER = 1 and func PERATRAITER(N_PER, PNQUELPER, [M:PFIO]PERENDDAT(N_PER - 1), PEPCOUCPY)
          If [M:PFIO]DPRCUM(0) - [M:PCPO]DPRCUM(0) <>
&            ([M:PCPO]LEGCUM(0) - [M:PCPO]LEGRVECUM(0)) - ([M:PFIO]LEGCUM(0) - [M:PFIO]LEGRVECUM(0))
              RBPREMIERE =  1
              RET = 1
              RTPERNONOK(1) = 3
              RNB_DEP_ERR += 1
          Else
              If ([M:PFIO]PERCLOCUM(0) + [M:PFIO]PERCLOEXC(0)) - ([M:PCPO]PERCLOCUM(0) + [M:PCPO]PERCLOEXC(0)) <>
&                ([M:PCPO]PERLEGCUM(0) - [M:PCPO]PERLEGRVE(0)) - ([M:PFIO]PERLEGCUM(0) - [M:PFIO]PERLEGRVE(0))
                  RBPREMIERE = 1
                  RET = 1
                  RNB_DEP_ERR += 1
                  RTPERNONOK(1) = 3
              Endif
          Endif
      Endif

      # La nÂ° pĂ©riode a des cumuls exercices <> de la prĂ©cĂ©dente
      If N_PER > 1 and RNDELTA2L = 0 and func PERATRAITER(N_PER, PNQUELPER, [M:PFIO]PERENDDAT(N_PER - 1), PEPCOUCPY)
          # un bien ayant eu 1 rĂ©Ă©val par VM a des cumuls diffĂ©rents
          If [M:PCPT]RVATYP <> 3 and [M:PFIS]RVATYP <> 3
             If  [M:PCPT]LEGCUM(N_PER-1)    <>  [M:PCPT]LEGCUM(N_PER-2)    or
&                [M:PCPT]LEGRVECUM(N_PER-1) <>  [M:PCPT]LEGRVECUM(N_PER-2) or
&                [M:PFIS]LEGCUM(N_PER-1)    <>  [M:PFIS]LEGCUM(N_PER-2)    or
&                [M:PFIS]LEGRVECUM(N_PER-1) <>  [M:PFIS]LEGRVECUM(N_PER-2)
                  RNDELTA2L = N_PER
                  RET = 1
                  RNB_DEP_ERR += 1
#                  RTPERNONOK(N_PER) = 5
              Else
                  If [M:PCPO]DPRCUM(N_PER-1) <> [M:PCPO]DPRCUM(N_PER-2) or
&                    [M:PFIO]DPRCUM(N_PER-1) <> [M:PFIO]DPRCUM(N_PER-2)
                      RNDELTA2L = N_PER
                      RET = 1
                      RNB_DEP_ERR += 1
#                      RTPERNONOK(N_PER) = 5
                  Endif
              Endif
          Endif
      Endif

      If func PERATRAITER(N_PER, PNQUELPER, [M:PFIO]PERENDDAT(N_PER - 1), PEPCOUCPY)

        # DĂ©rogatoire
        # ===========
        # ContrĂ´le situation dĂ©but exercice (LEGCUM)
        # ligne 1- rubriques old identiques aux rubriques new
        # ligne 2- new.legcum = (old.legcum - old.legrvecum)
        COND1 = ([M:PCPT]LEGCUM(N_PER-1)=[M:PCPO]LEGCUM(N_PER-1) and [M:PCPT]LEGRVECUM(N_PER-1)=[M:PCPO]LEGRVECUM(N_PER-1))
&            or ([M:PCPT]LEGCUM(N_PER-1)=([M:PCPO]LEGCUM(N_PER-1)-[M:PCPO]LEGRVECUM(N_PER-1)))
        # ContrĂ´le situation dĂ©but PĂ©riode (PERLEGCUM)
        # ligne 1- rubriques old identiques aux rubriques new
        # ligne 2- new.perlegcum = (old.perlegcum - old.perlegrve)
        # ligne 3- new.perlegrve = (old.perlegrve - old.perlegcum)
        COND2 = ([M:PCPT]PERLEGCUM(N_PER-1)=[M:PCPO]PERLEGCUM(N_PER-1) and [M:PCPT]PERLEGRVE(N_PER-1)=[M:PCPO]PERLEGRVE(N_PER-1))
&            or ([M:PCPT]PERLEGCUM(N_PER-1)=([M:PCPO]PERLEGCUM(N_PER-1)-[M:PCPO]PERLEGRVE(N_PER-1)))
&            or ([M:PCPT]PERLEGRVE(N_PER-1)=([M:PCPO]PERLEGRVE(N_PER-1)-[M:PCPO]PERLEGCUM(N_PER-1)))
        # ContrĂ´le situation PĂ©riode (LEG)
        COND3 = ([M:PCPT]LEG(N_PER-1)=[M:PCPO]LEG(N_PER-1) and [M:PCPT]LEGRVE(N_PER-1)=[M:PCPO]LEGRVE(N_PER-1))

        If ((PNIV_CTRLE >= 1 and not(COND1))
&        or (PNIV_CTRLE >= 2 and not(COND2))
&        or (PNIV_CTRLE >= 3 and not(COND3)))
          RET = 1
          If RTPERNONOK(N_PER) = 0
            RNB_DEP_ERR += 1
            RTPERNONOK(N_PER) = 1
          Endif
        Endif

        # RĂ©intĂ©gration
        # =============
        # ContrĂ´le situation dĂ©but exercice (LEGCUM)
        # ligne 1- rubriques old identiques aux rubriques new
        # ligne 2- new.legcum = (old.legcum - old.legrvecum)
        COND1 = ([M:PFIS]LEGCUM(N_PER-1)=[M:PFIO]LEGCUM(N_PER-1) and [M:PFIS]LEGRVECUM(N_PER-1)=[M:PFIO]LEGRVECUM(N_PER-1))
&            or ([M:PFIS]LEGCUM(N_PER-1)=([M:PFIO]LEGCUM(N_PER-1)-[M:PFIO]LEGRVECUM(N_PER-1)))
        # ContrĂ´le situation dĂ©but PĂ©riode (PERLEGCUM)
        # ligne 1- rubriques old identiques aux rubriques new
        # ligne 2- new.perlegcum = (old.perlegcum - old.perlegrve)
        # ligne 3- new.perlegrve = (old.perlegrve - old.perlegcum)
        COND2 = ([M:PFIS]PERLEGCUM(N_PER-1)=[M:PFIO]PERLEGCUM(N_PER-1) and [M:PFIS]PERLEGRVE(N_PER-1)=[M:PFIO]PERLEGRVE(N_PER-1))
&            or ([M:PFIS]PERLEGCUM(N_PER-1)=([M:PFIO]PERLEGCUM(N_PER-1)-[M:PFIO]PERLEGRVE(N_PER-1)))
&            or ([M:PFIS]PERLEGRVE(N_PER-1)=([M:PFIO]PERLEGRVE(N_PER-1)-[M:PFIO]PERLEGCUM(N_PER-1)))
        # ContrĂ´le situation PĂ©riode (LEG)
        COND3 = ([M:PFIS]LEG(N_PER-1)=[M:PFIO]LEG(N_PER-1) and [M:PFIS]LEGRVE(N_PER-1)=[M:PFIO]LEGRVE(N_PER-1))

        If ((PNIV_CTRLE >= 1 and not(COND1))
&        or (PNIV_CTRLE >= 2 and not(COND2))
&        or (PNIV_CTRLE >= 3 and not(COND3)))
          RET = 1
          If RTPERNONOK(N_PER) = 0
            RNB_DEP_ERR += 1
          Endif
          If RTPERNONOK(N_PER) < 3
            RTPERNONOK(N_PER) += 2
          Endif
        Endif

      Endif
  Next

End RET


#** Editer ou non une pĂ©riode ds le cr (en fonction des options choisies)
#*
#*
#* @param N_PER pĂ©riode a Ă©diter ds le cr
#* @param PNQUELPER rĂ¨gle choisie 0 : ttes erreurs, 1 pĂ©riode 1, 2pĂ©riode courante
#* @param RTSTAPER
#*!
Funprog PERATRAITER(PN_PER, PNQUELPER, PEPCOUFXD, PEPCOUCPY)
Value Integer PN_PER, PNQUELPER
Value Date PEPCOUFXD, PEPCOUCPY

    # toutes les pĂ©riodes (en erreur)
    If PNQUELPER = 0
        End 1
    Endif

    # premiĂ¨re pĂ©riode
    If PN_PER = 1 and PNQUELPER <> 2
        End 1
    Endif

    # pĂ©riode courante
    If PEPCOUFXD = PEPCOUCPY and PNQUELPER <> 1
        End 1
    Endif
End 0

$MAJ_DEPREC_FXDASSETS

    Trbegin [WDEP]
    FLGOK = G_OUI

    # Maj de la per 1 Ă  la per courante
    For N_PER = 1 To [M:DEP]NB_DEP
        If WTPERNONOK(N_PER)
            Gosub MAJ_DEPREC_DET
            If FLGOK = G_NON
                Break
            Endif
        Endif
    Next
    If FLGOK = G_OUI
        Gosub MAJ_FXDASSETS
    Endif

    If FLGOK = G_OUI
#        Rollback
        Commit
    Else
        Rollback
    Endif

Return

$MAJ_DEPREC_DET

    # Maj comptable
    Read [F:WDEP]DEP0=[F:WFAS]AASREF;[M:PCPT]DPRPLN;[M:PCPT]FIYENDDAT;[M:PCPT]PERENDDAT(N_PER-1)

#    [F:WDEP]LEG       = [M:PCPT]LEG(N_PER-1)
    [F:WDEP]LEGCUM    = [M:PCPT]LEGCUM(N_PER-1)
#    [F:WDEP]LEGRVE    = [M:PCPT]LEGRVE(N_PER-1)
    [F:WDEP]LEGRVECUM = [M:PCPT]LEGRVECUM(N_PER-1)
    [F:WDEP]PERLEGCUM = [M:PCPT]PERLEGCUM(N_PER-1)
    [F:WDEP]PERLEGRVE = [M:PCPT]PERLEGRVE(N_PER-1)

#    If [F:WDEP]PERENDDAT = [M:FIY]DATENDPER([M:FIY]INDCURPER-1)
        [F:WDEP]DEPSTA = GVML_SCNOCAL
#    Endif

    Rewrite [F:WDEP]
    If fstat
    #
        Call ECR_TRACE("Erreur mise Ă  jour DEPREC" - [F:WFAS]AASREF -
&       mess(G301CPT, GML_NPLAN, 1) -
&       "FiY :" - [M:PCPT]FIYENDDAT -
&       "Period :" - [M:PCPT]PERENDDAT(N_PER-1) -
&       "fstat :" - num$(fstat), 1) From GESECRAN
        FLGOK = G_NON
        Return
    Endif

    # Maj fiscal
    Read [F:WDEP]DEP0=[F:WFAS]AASREF;[M:PFIS]DPRPLN;[M:PFIS]FIYENDDAT;[M:PFIS]PERENDDAT(N_PER-1)

    [F:WDEP]LEGCUM    = [M:PFIS]LEGCUM(N_PER-1)
    [F:WDEP]LEGRVECUM = [M:PFIS]LEGRVECUM(N_PER-1)
    [F:WDEP]PERLEGCUM = [M:PFIS]PERLEGCUM(N_PER-1)
    [F:WDEP]PERLEGRVE = [M:PFIS]PERLEGRVE(N_PER-1)

#    If [F:WDEP]PERENDDAT = [M:FIY]DATENDPER([M:FIY]INDCURPER-1)
        [F:WDEP]DEPSTA = GVML_SCNOCAL
#    Endif

    Rewrite [F:WDEP]
    If fstat
        Call ECR_TRACE("Erreur mise Ă  jour DEPREC" - [F:WFAS]AASREF -
&       mess(G301FIS, GML_NPLAN, 1) -
&       "FiY :" - [M:PFIS]FIYENDDAT -
&       "Period :" - [M:PFIS]PERENDDAT(N_PER-1) -
&       "fstat :" - num$(fstat), 1) From GESECRAN
        FLGOK = G_NON
        Return
    Endif
    NB_DEP_MAJ += 1
Return

$MAJ_FXDASSETS

    Read [F:WFA2]FAS0=[F:WFAS]AASREF
    [F:WFA2]FLGCLC = G_OUI
    [F:WFA2]FLGCNXCLC(0) = G_OUI

    Rewrite [F:WFA2]
    If fstat
      Call ECR_TRACE("Erreur mise Ă  jour FXDASSETS" - [F:WFAS]AASREF -
&     "fstat :" - num$(fstat), 1) From GESECRAN
      FLGOK = G_NON
    Endif
Return

$CAL_DEROG_REINT_OV6
Local Integer ID
Local Decimal WSLD
Local Decimal WDEREXE
Local Decimal WECADER
Local Decimal WCOEAFI  :  WCOEAFI = 1.

Local Integer RTRN
Local Decimal WDPRCUMR_C
Local Decimal WDPRCUMR_F
Local Decimal WSLDDPR
Local Decimal WSLDLEG

  If ( [F:WFAS]ISSDAT <> [0/0/0] and [F:WFAS]ISSDAT < [M:FIY]DATSTRFIY([M:DIV]FEC-1) and
&      (not ([M:DIV]BACTCCN) or ([M:DIV]BACTCCN and [F:WFAS]CCNETRTYP <> GVML_NA1ERBC )) ) Then
    Return
  Endif
  If ( [M:DIV]PLNFIS and [M:DIV]CNT = G300CPFI ) Then
    If ( [M:DIV]TRTDEM = "CALSOC" and not G_BERRDER and [M:PCPT]LSTCLODAT([M:DIV]DPC-1) <> [0/0/0] and [M:PFIS]LSTCLODAT([M:DIV]DPC-1) <> [0/0/0] ) Then
      WSLDDPR = ([M:PFIS]DPRCUM([M:DIV]DPC-1)+[M:PFIS]PERCLOCUM([M:DIV]DPC-1)+[M:PFIS]PERCLOEXC([M:DIV]DPC-1))
&             - ([M:PCPT]DPRCUM([M:DIV]DPC-1)+[M:PCPT]PERCLOCUM([M:DIV]DPC-1)+[M:PCPT]PERCLOEXC([M:DIV]DPC-1))
      WSLDLEG = ( ([M:PCPT]LEGCUM   ([M:DIV]DPC-1)+[M:PCPT]PERLEGCUM([M:DIV]DPC-1)) -
&                 ([M:PCPT]LEGRVECUM([M:DIV]DPC-1)+[M:PCPT]PERLEGRVE([M:DIV]DPC-1)) )
&             - ( ([M:PFIS]LEGCUM   ([M:DIV]DPC-1)+[M:PFIS]PERLEGCUM([M:DIV]DPC-1)) -
&                 ([M:PFIS]LEGRVECUM([M:DIV]DPC-1)+[M:PFIS]PERLEGRVE([M:DIV]DPC-1)) )
      If ( WSLDDPR <> WSLDLEG ) Then
        G_BERRDER = 1
        Call ECR_TRACE(mess(194,7774,1),-1) From   GLOBB0
      Endif
    Endif
    # CFF 2015.04.21 106373/2/2000
    # Si un des 2 cumuls exercice est non forcĂ©, alors on met Ă  jour le dĂ©rogatoire ou la rĂ©intĂ©gration dĂ©but exercice
    If ( [M:PCPT]DPRCUMFLG([M:DIV]DPC-1) <> G_OUI or [M:PFIS]DPRCUMFLG([M:DIV]DPC-1) <> G_OUI ) Then
      If (func CAL_CMP_MNT ([M:PFIS]DPRCUM([M:DIV]DPC-1),">",[M:PCPT]DPRCUM([M:DIV]DPC-1),[M:PCPT]DPRBAS([M:DIV]DPC-1))) Then
        [M:PCPT]LEGCUM([M:DIV]DPC-1)    = [M:PFIS]DPRCUM([M:DIV]DPC-1) - [M:PCPT]DPRCUM([M:DIV]DPC-1)
        [M:PCPT]LEGRVECUM([M:DIV]DPC-1) = 0.
        [M:PCPT]PERLEGCUM([M:DIV]DPC-1) = 0.
        [M:PCPT]PERLEGRVE([M:DIV]DPC-1) = 0.
        [M:PFIS]LEGCUM([M:DIV]DPC-1)    = 0.
        [M:PFIS]LEGRVECUM([M:DIV]DPC-1) = 0.
        [M:PFIS]PERLEGCUM([M:DIV]DPC-1) = 0.
        [M:PFIS]PERLEGRVE([M:DIV]DPC-1) = 0.
      Else
        [M:PFIS]LEGCUM([M:DIV]DPC-1)    = [M:PCPT]DPRCUM([M:DIV]DPC-1) - [M:PFIS]DPRCUM([M:DIV]DPC-1)
        [M:PFIS]LEGRVECUM([M:DIV]DPC-1) = 0.
        [M:PFIS]PERLEGCUM([M:DIV]DPC-1) = 0.
        [M:PFIS]PERLEGRVE([M:DIV]DPC-1) = 0.
        [M:PCPT]LEGCUM([M:DIV]DPC-1)    = 0.
        [M:PCPT]LEGRVECUM([M:DIV]DPC-1) = 0.
        [M:PCPT]PERLEGCUM([M:DIV]DPC-1) = 0.
        [M:PCPT]PERLEGRVE([M:DIV]DPC-1) = 0.
      Endif
    Endif
    # Si on est sur la 1Ă¨re pĂ©riode d'amortissement (pĂ©riode non close par le produit) ou UMAJDEROG, alors
    # - on met Ă  jour le dĂ©rogatoire ou la rĂ©intĂ©gration dĂ©but exercice
    # - on met Ă  jour le dĂ©rogatoire ou la rĂ©intĂ©gration dĂ©but de pĂ©riode
    # Nota: le cas UMAJDEROG permet de constituer les valeurs "calculĂ©es" qui seront comparĂ©es avec les valeurs "stockĂ©es"
    If ( [M:PCPT]LSTCLODAT([M:DIV]DPC-1) = [0/0/0] or [M:PFIS]LSTCLODAT([M:DIV]DPC-1) = [0/0/0] or
&        [M:DIV2]EXTCALL = "UMAJDEROG" ) Then
      If (func CAL_CMP_MNT ([M:PFIS]DPRCUM([M:DIV]DPC-1),">",[M:PCPT]DPRCUM([M:DIV]DPC-1),[M:PCPT]DPRBAS([M:DIV]DPC-1))) Then
        # On passe la diffĂ©rence d'amortissement en provision de dĂ©rogatoire
        [M:PCPT]LEGCUM([M:DIV]DPC-1)    = [M:PFIS]DPRCUM([M:DIV]DPC-1) - [M:PCPT]DPRCUM([M:DIV]DPC-1)
        # RAZ de la reprise et de la rĂ©intĂ©gration
        [M:PCPT]LEGRVECUM([M:DIV]DPC-1) = 0.
        [M:PFIS]LEGCUM   ([M:DIV]DPC-1) = 0.
        [M:PFIS]LEGRVECUM([M:DIV]DPC-1) = 0.
      Else
        # On passe la diffĂ©rence d'amortissement en provision de rĂ©intĂ©gration
        [M:PFIS]LEGCUM   ([M:DIV]DPC-1) = [M:PCPT]DPRCUM([M:DIV]DPC-1) - [M:PFIS]DPRCUM([M:DIV]DPC-1)
        # RAZ de la reprise et du dĂ©rogatoire
        [M:PFIS]LEGRVECUM([M:DIV]DPC-1) = 0.
        [M:PCPT]LEGCUM   ([M:DIV]DPC-1) = 0.
        [M:PCPT]LEGRVECUM([M:DIV]DPC-1) = 0.
      Endif
      # Calcul des cumuls pĂ©riodiques de dĂ©rogatoire/rĂ©intĂ©gration
      Local Decimal WLEG_F, WLEGRVE_F, WLEG_C, WLEGRVE_C, WDERDEV_C, WDERRVEDEV_C, WDERRVEISS
      Call  CAL_PER_DEROG_REINT_OV6( "CALP_1",
&             [M:DIV]BSOR, [F:WFAS]ISSDAT, [F:WFAS]OWNTYP, [F:WFAS]GACACN, [M:DIV]CUR, [M:DIV]BACTCCN,
&             [M:DIV]FLGDERBEC, [F:WFAS]CCNETRTYP, [M:PCPT]DPRBAS([M:DIV]DPC-1), [M:PCPT]ALWCOD([M:DIV]DPC-1),
&             [M:PFIS]ALWAMT([M:DIV]DPC-1), [M:PFIS]ALWCUM([M:DIV]DPC-1), [M:PFIS]ALWCOD([M:DIV]DPC-1),
&             [M:PFIS]DPRCUM([M:DIV]DPC-1), 0, 0,
&             [M:PFIS]ENDDPE([M:DIV]DPC-1), [M:PFIS]EXCDPR([M:DIV]DPC-1), [M:PFIS]PERCLOCUM([M:DIV]DPC-1),
&             [M:PFIS]PERCLOEXC([M:DIV]DPC-1), [M:PFIS]NBV([M:DIV]DPC-1),
&             [M:PFIS]LEGCUM([M:DIV]DPC-1),    [M:PFIS]LEGRVECUM([M:DIV]DPC-1),
&             0, 0,
&             [M:PCPT]DPRCUM([M:DIV]DPC-1), 0, 0,
&             [M:PCPT]ENDDPE([M:DIV]DPC-1), [M:PCPT]EXCDPR([M:DIV]DPC-1), [M:PCPT]PERCLOCUM([M:DIV]DPC-1),
&             [M:PCPT]PERCLOEXC([M:DIV]DPC-1), [M:PCPT]NBV([M:DIV]DPC-1),
&             [M:PCPT]LEGCUM([M:DIV]DPC-1),    [M:PCPT]LEGRVECUM([M:DIV]DPC-1),
&             0, 0,
&             [M:PCPT]FIYENDDAT([M:DIV]DPC-1), [M:PCPT]PERSTRDAT([M:DIV]DPC-1), [M:PCPT]PERENDDAT([M:DIV]DPC-1),
&             [M:PCPT]PSTDER([M:DIV]DPC-1), [M:PCPT]PSTDERRVE([M:DIV]DPC-1),
&             WLEG_F, WLEGRVE_F, WLEG_C, WLEGRVE_C, WDERDEV_C, WDERRVEDEV_C, WDERRVEISS, RTRN)
If RTRN
      GPREM_ERR = RTRN # FQ106373/3
Endif
      # Enregistrement des cumuls pĂ©riodiques de dĂ©rogatoire/rĂ©intĂ©gration
      [M:PCPT]PERLEGCUM([M:DIV]DPC-1) = WLEG_C
      If (WLEG_C <> 0 ) Then
      Endif
      [M:PFIS]PERLEGCUM([M:DIV]DPC-1) = WLEG_F
      If (WLEG_F <> 0 ) Then
      Endif
      [M:PCPT]PERLEGRVE([M:DIV]DPC-1) = WLEGRVE_C
      If (WLEGRVE_C <> 0 ) Then
      Endif
      [M:PFIS]PERLEGRVE([M:DIV]DPC-1) = WLEGRVE_F
      If (WLEGRVE_F <> 0 ) Then
      Endif
    Endif

    # Calcul du dĂ©rogatoire pour les pĂ©riode courante et les suivantes
    For ID = [M:DIV]DPC To [M:PFIS]NB_DEP
      If ( ID > [M:DIV]DPC ) Then
        If ( [M:PCPT]PERSTRDAT(ID-1) = [M:PCPT]FIYSTRDAT(ID-1) ) Then
          [M:PCPT]LEGCUM(ID-1)    = [M:PCPT]LEGCUM(ID-2)    + [M:PCPT]PERLEGCUM(ID-2) + [M:PCPT]LEG(ID-2)
          [M:PCPT]LEGRVECUM(ID-1) = [M:PCPT]LEGRVECUM(ID-2) + [M:PCPT]PERLEGRVE(ID-2) + [M:PCPT]LEGRVE(ID-2)
          [M:PFIS]LEGCUM(ID-1)    = [M:PFIS]LEGCUM(ID-2)    + [M:PFIS]PERLEGCUM(ID-2) + [M:PFIS]LEG(ID-2)
          [M:PFIS]LEGRVECUM(ID-1) = [M:PFIS]LEGRVECUM(ID-2) + [M:PFIS]PERLEGRVE(ID-2) + [M:PFIS]LEGRVE(ID-2)
          [M:PCPT]PERLEGCUM(ID-1) = 0.
          [M:PCPT]PERLEGRVE(ID-1) = 0.
          [M:PFIS]PERLEGCUM(ID-1) = 0.
          [M:PFIS]PERLEGRVE(ID-1) = 0.
        Else
          [M:PCPT]PERLEGCUM(ID-1) = [M:PCPT]PERLEGCUM(ID-2) + [M:PCPT]LEG(ID-2)
          [M:PCPT]PERLEGRVE(ID-1) = [M:PCPT]PERLEGRVE(ID-2) + [M:PCPT]LEGRVE(ID-2)
          [M:PFIS]PERLEGCUM(ID-1) = [M:PFIS]PERLEGCUM(ID-2) + [M:PFIS]LEG(ID-2)
          [M:PFIS]PERLEGRVE(ID-1) = [M:PFIS]PERLEGRVE(ID-2) + [M:PFIS]LEGRVE(ID-2)
          [M:PCPT]LEGCUM(ID-1)    = [M:PCPT]LEGCUM(ID-2)
          [M:PCPT]LEGRVECUM(ID-1) = [M:PCPT]LEGRVECUM(ID-2)
          [M:PFIS]LEGCUM(ID-1)    = [M:PFIS]LEGCUM(ID-2)
          [M:PFIS]LEGRVECUM(ID-1) = [M:PFIS]LEGRVECUM(ID-2)
        Endif
      Endif
      Call  CAL_PER_DEROG_REINT_OV6( "CALCUL",
&                                [M:DIV]BSOR, [F:WFAS]ISSDAT, [F:WFAS]OWNTYP, [F:WFAS]GACACN, [M:DIV]CUR, [M:DIV]BACTCCN,
&                                [M:DIV]FLGDERBEC, [F:WFAS]CCNETRTYP, [M:PCPT]DPRBAS([M:DIV]DPC-1), [M:PCPT]ALWCOD(ID-1),
&                                [M:PFIS]ALWAMT(ID-1), [M:PFIS]ALWCUM(ID-1), [M:PFIS]ALWCOD(ID-1),
&                                [M:PFIS]DPRCUM(ID-1), [M:PFIS]PERCLOCUM(ID-1), [M:PFIS]PERCLOEXC(ID-1),
&                                [M:PFIS]ENDDPE(ID-1), [M:PFIS]EXCDPR(ID-1), [M:PFIS]PERENDDPE(ID-1),
&                                [M:PFIS]PEREXCDPR(ID-1), [M:PFIS]NBV(ID-1),
&                                [M:PFIS]LEGCUM(ID-1),    [M:PFIS]LEGRVECUM(ID-1),
&                                [M:PFIS]PERLEGCUM(ID-1), [M:PFIS]PERLEGRVE(ID-1),
&                                [M:PCPT]DPRCUM(ID-1), [M:PCPT]PERCLOCUM(ID-1), [M:PCPT]PERCLOEXC(ID-1),
&                                [M:PCPT]ENDDPE(ID-1), [M:PCPT]EXCDPR(ID-1), [M:PCPT]PERENDDPE(ID-1),
&                                [M:PCPT]PEREXCDPR(ID-1), [M:PCPT]NBV(ID-1),
&                                [M:PCPT]LEGCUM(ID-1),    [M:PCPT]LEGRVECUM(ID-1),
&                                [M:PCPT]PERLEGCUM(ID-1), [M:PCPT]PERLEGRVE(ID-1),
&                                [M:PCPT]FIYENDDAT(ID-1), [M:PCPT]PERSTRDAT(ID-1), [M:PCPT]PERENDDAT(ID-1),
&                                [M:PCPT]PSTDER(ID-1), [M:PCPT]PSTDERRVE(ID-1),
&                                [M:PFIS]LEG(ID-1), [M:PFIS]LEGRVE(ID-1), [M:PCPT]LEG(ID-1), [M:PCPT]LEGRVE(ID-1),
&                                [M:PCPT]DERDEV(ID-1), [M:PCPT]DERRVEDEV(ID-1), [F:WFAS]DERRVEISS, RTRN)


If RTRN
      GTCODE_ERR(ID - 1) = RTRN # FQ106373/3
Endif
    Next ID
  Endif
Return

Subprog CAL_PER_DEROG_REINT_OV6( CALLCTX,
&  BSOR, ISSDAT, OWNTYP, GACACN, CUR, BACTCCN, FLGDERBEC, CCNETRTYP, C_DPRBAS, C_ALWCOD,
&  F_ALWAMT, F_ALWCUM, F_ALWCOD, F_DPRCUM, F_PERCLOCUM, F_PERCLOEXC, F_ENDDPE, F_EXCDPR, F_PERENDDPE, F_PEREXCDPR, F_NBV,
&  F_LEGCUM, F_LEGRVECUM, F_PERLEGCUM, F_PERLEGRVE,
&  C_DPRCUM, C_PERCLOCUM, C_PERCLOEXC, C_ENDDPE, C_EXCDPR, C_PERENDDPE, C_PEREXCDPR, C_NBV,
&  C_LEGCUM, C_LEGRVECUM, C_PERLEGCUM, C_PERLEGRVE,
&  C_FIYENDDAT, C_PERSTRDAT, C_PERENDDAT, C_PSTDER, C_PSTDERRVE,
&  F_LEG, F_LEGRVE, C_LEG, C_LEGRVE, C_DERDEV, C_DERRVEDEV, DERRVEISS, RTRN)
Value Char       CALLCTX           # Contexte d'appel "CALCUL"
Value Integer    BSOR
Value Date       ISSDAT
Value Integer    OWNTYP
Value Integer    GACACN
Value Char       CUR
Value Integer    BACTCCN
Value Integer    FLGDERBEC
Value Integer    CCNETRTYP
Value Decimal    C_DPRBAS
Value Decimal    C_ALWCOD
Value Decimal    F_ALWAMT
Value Decimal    F_ALWCUM
Value Decimal    F_ALWCOD
Value Decimal    F_DPRCUM
Value Decimal    F_PERCLOCUM
Value Decimal    F_PERCLOEXC
Value Decimal    F_ENDDPE
Value Decimal    F_EXCDPR
Value Decimal    F_PERENDDPE
Value Decimal    F_PEREXCDPR
Value Decimal    F_NBV
Value Decimal    F_LEGCUM
Value Decimal    F_LEGRVECUM
Value Decimal    F_PERLEGCUM
Value Decimal    F_PERLEGRVE
Value Decimal    C_DPRCUM
Value Decimal    C_PERCLOCUM
Value Decimal    C_PERCLOEXC
Value Decimal    C_ENDDPE
Value Decimal    C_EXCDPR
Value Decimal    C_PERENDDPE
Value Decimal    C_PEREXCDPR
Value Decimal    C_NBV
Value Decimal    C_LEGCUM
Value Decimal    C_LEGRVECUM
Value Decimal    C_PERLEGCUM
Value Decimal    C_PERLEGRVE
Value Date       C_FIYENDDAT
Value Date       C_PERSTRDAT
Value Date       C_PERENDDAT
Value Decimal    C_PSTDER
Value Decimal    C_PSTDERRVE
Variable Decimal F_LEG
Variable Decimal F_LEGRVE
Variable Decimal C_LEG
Variable Decimal C_LEGRVE
Variable Decimal C_DERDEV
Variable Decimal C_DERRVEDEV
Variable Decimal DERRVEISS
Variable Integer RTRN
Local Decimal WDEREXE
Local Decimal WECADER
Local Decimal WCOEAFI  :  WCOEAFI = 1.
Local Decimal WSLD
Local Decimal  FIS_CUM  : FIS_CUM = F_DPRCUM    + F_PERCLOCUM   + F_PERCLOEXC
Local Decimal  FIS_EXE  : FIS_EXE = F_ENDDPE    + F_EXCDPR
Local Decimal  FIS_PER  : FIS_PER = F_PERENDDPE + F_PEREXCDPR
Local Decimal  CPT_CUM  : CPT_CUM = C_DPRCUM    + C_PERCLOCUM   + C_PERCLOEXC
Local Decimal  CPT_EXE  : CPT_EXE = C_ENDDPE    + C_EXCDPR
Local Decimal  CPT_PER  : CPT_PER = C_PERENDDPE + C_PEREXCDPR
  C_LEG     = 0.
  C_LEGRVE  = 0.
  F_LEG     = 0.
  F_LEGRVE  = 0.
  If ( F_ALWAMT  <> 0 and F_ALWCUM  = 0  and find (F_ALWCOD , GVML_RPAID25, GVML_RPAID50, GVML_RPPR39B) ) Then
    If ( find(CALLCTX, "EXTP_1", "CALP_1") > 0 ) Then
      If ( F_PERENDDPE  <> 0 ) Then
        C_LEG   = F_ALWAMT
      Endif
    Else
      If ( F_PERCLOCUM  = 0 ) Then
        C_LEG   = F_ALWAMT
      Endif
    Endif
    If (func CAL_CMP_MNT ( (FIS_EXE - CPT_EXE),">",F_ALWAMT, C_DPRBAS)) Then
      WDEREXE = FIS_EXE - CPT_EXE
      If (WDEREXE) Then
        WCOEAFI = ((( WDEREXE - F_ALWAMT ) * 100. ) / WDEREXE ) / 100
      Else
        WCOEAFI = 1.
      Endif
      C_LEG = C_LEG + ( (FIS_PER - CPT_PER) * WCOEAFI )
      Call CAL_ARRONDI_MNT (C_LEG, CUR, C_LEG) From   GLOBB8
      If ( find(CALLCTX, "CALCUL", "CALP_1") > 0 ) Then
      Endif
      If ( C_PERENDDAT = C_FIYENDDAT or func GLOBB9.CAL_DAT_INSIDE(ISSDAT, C_PERSTRDAT , C_PERENDDAT ,"I") ) Then
        WECADER = WDEREXE - ( (C_PERLEGCUM + C_LEG) - ( C_PERLEGRVE + C_LEGRVE ) )
        C_LEG   = C_LEG   - WECADER
      Endif
    Endif
    If (func CAL_CMP_MNT ( (FIS_EXE - CPT_EXE),"<",F_ALWAMT, C_DPRBAS)) Then
      WDEREXE = FIS_EXE - CPT_EXE
      If (WDEREXE) Then
        WCOEAFI = (((F_ALWAMT - WDEREXE) * 100. ) / WDEREXE ) / 100
      Else
        WCOEAFI = 1.
      Endif
      C_LEGRVE  = ( (FIS_PER - CPT_PER) * WCOEAFI  )
      Call CAL_ARRONDI_MNT (C_LEGRVE , CUR , C_LEGRVE  ) From   GLOBB8
      If ( find(CALLCTX, "CALCUL", "CALP_1") > 0 ) Then
      Endif
      If ( C_PERENDDAT = C_FIYENDDAT  or func GLOBB9.CAL_DAT_INSIDE(ISSDAT, C_PERSTRDAT , C_PERENDDAT ,"I") ) Then
        WECADER = WDEREXE - ( (C_PERLEGCUM + C_LEG) - ( C_PERLEGRVE + C_LEGRVE ) )
        C_LEGRVE  = C_LEGRVE  - WECADER
      Endif
    Endif
  Else
    If (func CAL_CMP_MNT ( CPT_PER, ">",FIS_PER, C_DPRBAS) and
&       ((CPT_CUM = 0 and FIS_CUM = 0) or (func CAL_CMP_MNT ( CPT_CUM, ">=",FIS_CUM, C_DPRBAS))) ) Then
      F_LEG = CPT_PER - FIS_PER
      If ( find(CALLCTX, "CALCUL", "CALP_1") > 0 ) Then
        RTRN = 3
      Endif
    Elsif (func CAL_CMP_MNT ( FIS_PER, ">",CPT_PER, C_DPRBAS) and
&       ((CPT_CUM = 0 and FIS_CUM = 0) or (func CAL_CMP_MNT ( FIS_CUM, ">=",CPT_CUM, C_DPRBAS))) ) Then
      C_LEG = FIS_PER - CPT_PER
      If ( find(CALLCTX, "CALCUL", "CALP_1") > 0 ) Then
        RTRN = 1
      Endif
    Elsif ( func CAL_CMP_MNT ( FIS_PER, "<",CPT_PER, C_DPRBAS) and
&           func CAL_CMP_MNT ( FIS_CUM, ">",CPT_CUM, C_DPRBAS) and  FIS_CUM <>  0 ) Then
      WSLD = (C_LEGCUM  + C_PERLEGCUM ) - (C_LEGRVECUM  + C_PERLEGRVE )
      If ( WSLD <> 0 and func CAL_CMP_MNT ( WSLD,">=",(CPT_PER - FIS_PER), C_DPRBAS)) Then
        C_LEGRVE = CPT_PER - FIS_PER
        If ( find(CALLCTX, "CALCUL", "CALP_1") > 0 ) Then
          RTRN = 2
        Endif
      Else
        C_LEGRVE   = WSLD
        If ( find(CALLCTX, "CALCUL", "CALP_1") > 0 ) Then
          RTRN = 32
        Endif
        F_LEG = CPT_PER - FIS_PER -  WSLD
        If ( find(CALLCTX, "CALCUL", "CALP_1") > 0 ) Then
          RTRN = 32
        Endif
      Endif
    Elsif ( func CAL_CMP_MNT ( FIS_PER, ">",CPT_PER, C_DPRBAS) and
&           func CAL_CMP_MNT ( FIS_CUM, "<",CPT_CUM, C_DPRBAS) and  CPT_CUM <>  0 ) Then
      WSLD = (F_LEGCUM + F_PERLEGCUM ) - (F_LEGRVECUM  + F_PERLEGRVE )
      If ( WSLD <> 0 and func CAL_CMP_MNT ( WSLD,">=",(FIS_PER - CPT_PER), C_DPRBAS)) Then
        F_LEGRVE = FIS_PER - CPT_PER
        If ( find(CALLCTX, "CALCUL", "CALP_1") > 0 ) Then
          PCAS = 4
        Endif
      Else
        F_LEGRVE   = WSLD
        If ( find(CALLCTX, "CALCUL", "CALP_1") > 0 ) Then
          PCAS = 14
        Endif
        C_LEG = FIS_PER - CPT_PER -  WSLD
        If ( find(CALLCTX, "CALCUL", "CALP_1") > 0 ) Then
          PCAS = 14
        Endif
      Endif
    Endif
  Endif
  DERRVEISS = 0
  If ( BSOR ) Then
    If ( BACTCCN and CCNETRTYP = GVML_NA1ERBC and
&        ( F_ALWCOD  = GVML_RPCONCE or C_ALWCOD  = GVML_RPCONCE ) ) Then
    Else
      If ( func GLOBB9.CAL_DAT_INSIDE(ISSDAT, C_PERSTRDAT , C_PERENDDAT ,"I") or ISSDAT < C_PERSTRDAT  ) Then
        DERRVEISS =  (C_LEGCUM + C_PERLEGCUM + C_LEG) - (C_LEGRVE + C_PERLEGRVE + C_LEGRVE)
        If ( find(CALLCTX, "CALCUL", "CALP_1") > 0 ) Then
        Endif
      Endif
    Endif
  Endif
  If ( OWNTYP <> GVML_TDPREVU and
&     (GACACN <> GVML_NIENCOU  or FLGDERBEC = G_OUI) ) Then
    C_DERDEV      = C_LEG      - C_PSTDER
    C_DERRVEDEV   = C_LEGRVE   - C_PSTDERRVE
  Else
    C_DERDEV      = 0
    C_DERRVEDEV   = 0
  Endif
End

# FQ106373
Funprog CAL_CMP_MNT (PMNT1, POPE, PMNT2, PMNTREF)
Value Decimal PMNT1
Value Char    POPE()
Value Decimal PMNT2
Value Decimal PMNTREF
Local Integer RRES
  Local Decimal MNT1
  Local Decimal MNT2
  If (PMNTREF < 0) Then
    MNT1 = PMNT1 * -1
    MNT2 = PMNT2 * -1
  Else
    MNT1 = PMNT1
    MNT2 = PMNT2
  Endif
  RRES = 0
  Case POPE
    When "<"
      If (MNT1 < MNT2)  : RRES = 1 : Endif
    When "<="
      If (MNT1 <= MNT2) : RRES = 1 : Endif
    When "="
      If (MNT1 = MNT2)  : RRES = 1 : Endif
    When ">="
      If (MNT1 >= MNT2) : RRES = 1 : Endif
    When ">"
      If (MNT1 >  MNT2) : RRES = 1 : Endif
  Endcase
End RRES

#########################################################
# partie recopiĂ©e pour version non compatible :
#########################################################

$CAL_LEC_PARAMETRES_OV6
  Local Char LPARAM(30)
  Local Char  L_PARAM(32), L_VALPARM(5), L_LIGNE(50)
  Local Char  L_SEP(5) : L_SEP = "!"
  Call ECR_TRACE(mess(137,7774,1)+"\",0) From   GLOBB0 # "PARAMETRES du calcul"
  Call ECR_TRACE(string$(50,"*"),0) From   GLOBB0
  L_PARAM=mess(47,7774,1) : L_VALPARM=num$([M:DIV]NIVDET)
  L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&           L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
  Call ECR_TRACE(L_LIGNE,0) From   GLOBB0
  [M:DIV]NBBCOTRA = func AFNC.ACTIV("BPC")
  If !([M:DIV]NBBCOTRA) Then
    [M:DIV]NBBCOTRA = 9999
  Endif
  L_PARAM=mess(147,7774,1) : L_VALPARM=num$([M:DIV]NBBCOTRA)
  L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&           L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
  Call ECR_TRACE(L_LIGNE,0) From   GLOBB0
  Call PARAM([M:DIV]SOC,"CALNBUNDO",LPARAM) From ADOVAL
  If (LPARAM = "" ) Then
    [M:DIV]NBBCOUDO  = 25000
  Else
    [M:DIV]NBBCOUDO  = val(LPARAM)
  Endif
  Local Char L_VALPARM2(6)
  L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("CALNBUNDO") : L_VALPARM2=num$(val(LPARAM))
  L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&           L_SEP+space$(3)+left$(L_VALPARM2,6)+space$(8-len(left$(L_VALPARM2,6)))+L_SEP
  Call ECR_TRACE(L_LIGNE,0) From   GLOBB0
  Call PARAM([M:DIV]SOC,"NBMINCLC",LPARAM) From ADOVAL
  If (LPARAM = "") Then
    [M:DIV]ERRID = 17 : Call ERRFND From   GLOBB0 : Return
  Endif
  G_TIMLIM = val(LPARAM)
  If (G_TIMLIM > 86400 or  G_TIMLIM <= 0 ) Then : G_TIMLIM = 14400 : Endif : # (4 heures par dĂ©faut)
  L_PARAM=mess(146,7774,1) : L_VALPARM=num$(arr(G_TIMLIM/60, 0.01))
  L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&           L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
  Call ECR_TRACE(L_LIGNE,0) From   GLOBB0
  G_TIMLIM = G_TIMLIM * 60
  Call PARAM([M:DIV]SOC,"PCOTVAPMV",LPARAM) From ADOVAL
  If (LPARAM = "" ) Then
    [M:DIV]ERRID = 3 : Call ERRFND From   GLOBB0 : Return : # DĂ©pilement suite Ă  erreur logique
  Endif
  [M:DIV]FLGTVAPMV  = val(LPARAM)
  L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("PCOTVAPMV") : L_VALPARM=mess(val(LPARAM),1,1)
  L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&           L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
  Call ECR_TRACE(L_LIGNE,0) From   GLOBB0
  Call PARAM([M:DIV]SOC, "IMLRVEISS", LPARAM) From ADOVAL
  If (LPARAM = "" ) Then
    [M:DIV]ERRID = 4 : Call ERRFND From   GLOBB0 : Return : # DĂ©pilement suite Ă  erreur logique
  Endif
  [M:DIV]FLGISSIML = val(LPARAM)
  L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("IMLRVEISS") : L_VALPARM=mess(val(LPARAM),1,1)
  L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&           L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
  Call ECR_TRACE(L_LIGNE,0) From   GLOBB0
  Call PARAM([M:DIV]SOC,"DEROENCOUR",LPARAM) From ADOVAL
  If (LPARAM = "" ) Then
    [M:DIV]ERRID = 21 : Call ERRFND From   GLOBB0 : Return
  Endif
  [M:DIV]FLGDERBEC = val(LPARAM)
  L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("DEROENCOUR") : L_VALPARM=mess(val(LPARAM),1,1)
  L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&           L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
  Call ECR_TRACE(L_LIGNE,0) From   GLOBB0
  Call PARAM([M:DIV]SOC,"PRVSITUPD",LPARAM) From ADOVAL
  If (LPARAM = "" ) Then
    [M:DIV]ERRID = 17 : Call ERRFND From   GLOBB0 : Return
  Endif
  [M:DIV]FLGPRVSIT = val(LPARAM)
  L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("PRVSITUPD") : L_VALPARM=mess(val(LPARAM),1,1)
  L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&           L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
  Call ECR_TRACE(L_LIGNE,0) From   GLOBB0
  Call PARAM([M:DIV]SOC,"RNDCHGLPDF",LPARAM) From ADOVAL
  If (LPARAM = "" ) Then
    [M:DIV]FLGRNDCHG = G_NON
     LPARAM = "1"
  Else
    [M:DIV]FLGRNDCHG = val(LPARAM)
  Endif
  L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("RNDCHGLPDF") : L_VALPARM=mess(val(LPARAM),1,1)
  L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&           L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
  Call ECR_TRACE(L_LIGNE,0) From   GLOBB0
  Call PARAM([M:DIV]SOC,"DPRPLNPIO",LPARAM) From ADOVAL
  If (LPARAM = "" or val(LPARAM) = 0) Then
    [M:DIV2]DPRPLNPIO = G301CPT
    LPARAM = "1"
  Else
    If !clalev([F:CNXW]) : Local File CONTEXT [CNXW] : Endif
    Read [CNXW]CNX0=[M:DIV]SOC;G300CPFI
    If ( find([M:DIV2]DPRPLNPIO, [F:CNXW]PLNCAA) <> 0 ) Then
      [M:DIV2]DPRPLNPIO = val(LPARAM)
    Else
      [M:DIV]ERRID = 49 : Call ERRFND From   GLOBB0 : Return
    Endif
    Close Local File [CNXW]
  Endif
  If ( [M:DIV2]DPRPLNPIO <> G301AUC ) Then
  L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("DPRPLNPIO") : L_VALPARM=mess(val(LPARAM),3101,1)
  L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&           L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
  Call ECR_TRACE(L_LIGNE,0) From   GLOBB0
  Endif
  If ([M:DIV]BACTKPL) Then
    Call PARAM([M:DIV]SOC,"MINPERDEP",LPARAM) From ADOVAL
    If (LPARAM = "" or val(LPARAM) = 0) Then
      [M:DIV]DOTPERMIN = 0.50
       LPARAM = "0.50"
    Else
      [M:DIV]DOTPERMIN = val(LPARAM)
    Endif
    L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("MINPERDEP") : L_VALPARM=num$([M:DIV]DOTPERMIN)
    L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&             L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
    Call ECR_TRACE(L_LIGNE,0) From   GLOBB0
    Call PARAM([M:DIV]SOC,"MDRCURPER",LPARAM) From ADOVAL
    If (LPARAM = "" ) Then
      [M:DIV]MDRCURPER = G_NON
       LPARAM = "1"
    Else
      [M:DIV]MDRCURPER = val(LPARAM)
    Endif
    L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("MDRCURPER") : L_VALPARM=mess(val(LPARAM),1,1)
    L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&             L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
    Call ECR_TRACE(L_LIGNE,0) From   GLOBB0
  Endif
  Call PARAM([M:DIV]SOC,"MINFIYDEP",LPARAM) From ADOVAL
  If (LPARAM = "" ) Then
    [M:DIV]DOTEXEMIN = 0.00
  Else
    [M:DIV]DOTEXEMIN = val(LPARAM)
    L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("MINFIYDEP") : L_VALPARM=num$([M:DIV]DOTEXEMIN)
    L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&             L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
    Call ECR_TRACE(L_LIGNE,0) From   GLOBB0
  Endif
  Call PARAM([M:DIV]SOC,"NETVALWRO",LPARAM) From ADOVAL
  If (LPARAM = "" ) Then
    [M:DIV]ENDNVLWRO = 0.00
  Else
    [M:DIV]ENDNVLWRO = val(LPARAM)
    L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("NETVALWRO") : L_VALPARM=num$([M:DIV]ENDNVLWRO)
    L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&             L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
    Call ECR_TRACE(L_LIGNE,0) From   GLOBB0
  Endif
  Call PARAM([M:DIV]SOC,"CPYTAXRUL",LPARAM) From ADOVAL
  If (LPARAM = "" ) Then
    [M:DIV2]TAXRUL = 1
  Else
    [M:DIV2]TAXRUL = val(LPARAM)
    L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("CPYTAXRUL") : L_VALPARM=num$([M:DIV2]TAXRUL)
    L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&             L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
    Call ECR_TRACE(L_LIGNE,0) From   GLOBB0
  Endif
  Call PARAM([M:DIV]SOC,"WEESTR",LPARAM) From ADOVAL
  If (LPARAM = "" ) Then
    [M:DIV2]WEESTRDAY = 1
  Else
    [M:DIV2]WEESTRDAY = val(LPARAM)
    If ([M:DIV2]WEESTRDAY <> 1) Then
      Local Char L_VALPARM3(8)
      L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("WEESTR") : L_VALPARM3=mess(val(LPARAM),9833,1)
      L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&               L_SEP+space$(1)+left$(L_VALPARM3,8)+space$(10-len(left$(L_VALPARM3,8)))+L_SEP
      Call ECR_TRACE(L_LIGNE,0) From   GLOBB0
    Endif
  Endif
  Call ECR_TRACE(string$(50,"*")+"\",0) From   GLOBB0
  [M:DIV]DEPMAX = func AFNC.ACTIV("DEP")
  [M:DIV]PPLMAX = func AFNC.ACTIV("NPPL")
  Call PARAM([M:DIV]SOC,"CALPERSAN",LPARAM) From ADOVAL
  [M:DIV]CALPERSAN = val(LPARAM)
  Call PARAM("","REEV96",LPARAM) From ADOVAL
  [M:DIV2]FLGR96 = val(LPARAM)
Return

Subprog  CAL_LEC_CONTEXTES_OV6 (PSOC, RERROR)
Value Char       PSOC
Variable Decimal RERROR
Local Integer I
Local Integer INDCNT
Local Integer INDPLN
  Local Integer BGESCCN : # Concessions gĂ©rĂ©e
  BGESCCN = func AFNC.ACTIV("CCN")
  [M:DIV]BACTCCN = BGESCCN
  Local Integer BACTKRU : # Russie
  BACTKRU = func AFNC.ACTIV("KRU")
  [M:DIV]BACTKRU = BACTKRU
  Local Integer BACTKPL : # Polonais
  BACTKPL = func AFNC.ACTIV("KPL")
  [M:DIV]BACTKPL = BACTKPL
  Raz [M:CNX]
  If clalev([F:WCNX]) =0 : Local File CONTEXT    [WCNX]  : Endif        : # Contextes
  [M:DIV]PLNCPT = 0
  [M:DIV]PLNFIS = 0
  [M:DIV]PLNMIN = 0
  [M:DIV]PLNORI = 0
  [M:DIV]PLNR76 = 0
  [M:DIV]PLNIAS = 0
  [M:DIV]PLNTEC = 0
  [M:DIV]PLNRET = 0
  [M:DIV]PLNSUB = 0
  [M:DIV]PLNLI1 = 0
  [M:DIV]PLNLI2 = 0
  [M:DIV]PLNLI3 = 0
  [M:DIV]PLNLI4 = 0
  [M:DIV]PLNLI5 = 0
  [M:DIV]PLNLI6 = 0
  [M:DIV]CNXUO  = 0
  INDCNT = 1
  INDPLN = 1
  For [WCNX]CNX0 Where [F:WCNX]CPY=PSOC
    If ([F:WCNX]HRZEXE = 0 or [F:WCNX]HRZPER = 0 ) Then : [F:WCNX]HRZEXE = 2 : [F:WCNX]HRZPER = 2 : Endif
    If ([F:WCNX]HRSEXE < 2 ) Then : [F:WCNX]HRSEXE = 2 : Endif
    If ([F:WCNX]HRSPER < 2 ) Then : [F:WCNX]HRSPER = 2 : Endif
    nolign = INDCNT
    [M:CNX]=[F:WCNX]
    If ([M:DIV]TRTDEM = "CALDPS") Then
      [M:CNX]HRZEXE(nolign-1) = [F:WCNX]HRSEXE
      [M:CNX]HRZPER(nolign-1) = [F:WCNX]HRSPER
    Endif
    INDCNT += 1
    If ( [F:WCNX]FLGCNXUO = G_OUI ) Then
      [M:DIV]CNXUO = [F:WCNX]CNX
    Endif
    For I = 1 To [F:WCNX]NBPLC
      If ( G_ACTCCN =  G_OUI ) and ( [F:WCNX]CNX = G300CPFI ) Then
        If ( BGESCCN ) Then
          Raz [M:DIV]CCNFLG     : [M:DIV]CCNFLG    = [F:WCNX]CCNFLG
          Raz [M:DIV]CCNMOD     : [M:DIV]CCNMOD    = [F:WCNX]CCNMOD
          Raz [M:DIV]CCNGRTFLG  : [M:DIV]CCNGRTFLG = [F:WCNX]CCNGRTFLG
          Raz [M:DIV]CCNRPRTYP  : [M:DIV]CCNRPRTYP = [F:WCNX]CCNRPRTYP
          Raz [M:DIV]CCNINDPLN  : [M:DIV]CCNINDPLN = [F:WCNX]CCNINDPLN
          Raz [M:DIV]CCNGRTPLN  : [M:DIV]CCNGRTPLN = [F:WCNX]CCNGRTPLN
          Raz [M:DIV]CCNCADPLN  : [M:DIV]CCNCADPLN = [F:WCNX]CCNCADPLN
        Else
          Raz [M:DIV]CCNFLG
          Raz [M:DIV]CCNMOD
          Raz [M:DIV]CCNGRTFLG
          Raz [M:DIV]CCNRPRTYP
          Raz [M:DIV]CCNINDPLN
          Raz [M:DIV]CCNGRTPLN
          Raz [M:DIV]CCNCADPLN
        Endif
      Endif
      [M:DIV]PLNCNT   (INDPLN-1) = [F:WCNX]CNX              : #  Code contexte
      [M:DIV]PLNCAA   (INDPLN-1) = [F:WCNX]PLNCAA   (I-1)   : #  Code plan
      [M:DIV]ORIBASDPR(INDPLN-1) = [F:WCNX]ORIBASDPR(I-1)   : #  Origine base amortissement
      [M:DIV]PLNSTD   (INDPLN-1) = [F:WCNX]PLNSTD   (I-1)   : #  Norme
      [M:DIV]FLUTRATXS(INDPLN-1) = [F:WCNX]FLUTRATXS(I-1)   : #  Suivi flux liasse
      [M:DIV]FLUTRAACC(INDPLN-1) = [F:WCNX]FLUTRAACC(I-1)   : #  Suivi flux compte
      [M:DIV]LNKPLN   (INDPLN-1) = [F:WCNX]LNKPLN   (I-1)   : #  Plan liĂ©
      Case [F:WCNX]PLNCAA(I-1)
        When G301CPT  : [M:DIV]PLNCPT = 1
        When G301FIS  : [M:DIV]PLNFIS = 1
        When G301MIN  : [M:DIV]PLNMIN = 1
        When G301ORI  : [M:DIV]PLNORI = 1
        When G301R76  : [M:DIV]PLNR76 = 1
        When G301IAS  : [M:DIV]PLNIAS = 1
        When G301TEC  : [M:DIV]PLNTEC = 1
        When G301RET  : [M:DIV]PLNRET = 1
        When G301SUB  : [M:DIV]PLNSUB = 1
        When G301LI1  : [M:DIV]PLNLI1 = 1
        When G301LI2  : [M:DIV]PLNLI2 = 1
        When G301LI3  : [M:DIV]PLNLI3 = 1
        When G301LI4  : [M:DIV]PLNLI4 = 1
        When G301LI5  : [M:DIV]PLNLI5 = 1
        When G301LI6  : [M:DIV]PLNLI6 = 1
      Endcase
      INDPLN += 1
    Next I
 Next CNX0
  [M:CNX]NB_CNX = INDCNT-1
  [M:DIV]NB_PLN = INDPLN-1
End

Subprog  CAL_LEC_EXERCICES_PERIODES_OV6 (PSOC, PCNT)
Value    Char    PSOC
Value    Integer PCNT
  If clalev([F:WFIS]) =0 : Local File FISCYEAR   [WFIS]  : Endif        : # Exercices/pĂ©riodes
Local Integer I       : I = 0
Local Integer INDEXE  : INDEXE = 1  : # indice exercice
Local Integer INDPER  : INDPER = 1  : # indice pĂ©riode
Local Integer INDESS  : INDESS = 0  : # indice exercice suivant le Suivant
Local Integer INDCLO  : INDCLO = 0  : # indice exercice clos
Local Integer WPDS
Local Integer I_EXE
Local Date    LDTDB
Local Date    LDTDBEXE
Local Date    LDTFNEXE
Local Integer LINDEXE
Local Integer LNUMEXE : LNUMEXE = 0
Local Integer I_CNT : I_CNT = find(PCNT, [M:CNX]CNX)
  Raz [M:FIY]
  For [WFIS]FIY0 Where [F:WFIS]CPY=PSOC and [F:WFIS]CNX=PCNT
    If ( [F:WFIS]STAFIY = GVML_TECOURA ) Then
      INDESS = INDEXE + 2
      If ( [F:WFIS]CNX = G300CPFI ) Then
        [M:DIV]DIFTYP = [F:WFIS]DFDTYP
        [M:DIV]DIFRGL = [F:WFIS]DFDCOD
        [M:DIV]DIFRAT = [F:WFIS]DFDRAT
      Endif
    Endif
    [M:FIY]DATSTRFIY(INDEXE-1) = [F:WFIS]DATSTRFIY
    [M:FIY]DATENDFIY(INDEXE-1) = [F:WFIS]DATENDFIY
    [M:FIY]RAT39BIS (INDEXE-1) = [F:WFIS]RAT39BIS
    [M:FIY]STAFIY   (INDEXE-1) = [F:WFIS]STAFIY
    [M:FIY]EVTCREFLG(INDEXE-1) = [F:WFIS]EVTCREFLG
    [M:FIY]DFDTYP   (INDEXE-1) = [F:WFIS]DFDTYP     # FQ90432
    [M:FIY]INDCURPER(INDEXE-1) = [F:WFIS]INDCURPER
    [M:FIY]NBRPER   (INDEXE-1) = [F:WFIS]NBRPER
    If (   [F:WFIS]STAFIY = GVML_TEPREC ) Then
      INDCLO = INDCLO + 1
      [M:FIY]INDDEBPER(INDEXE-1) = INDPER
      [M:FIY]INDCURPER(INDEXE-1) = 1
      [M:FIY]NBRPER   (INDEXE-1) = 1
      [M:FIY]DATSTRPER(INDPER-1) = [F:WFIS]DATSTRFIY
      [M:FIY]DATENDPER(INDPER-1) = [F:WFIS]DATENDFIY
      [M:DIV]PD(0)= LDTDBEXE : [M:DIV]PD(1)= LDTFNEXE : [M:DIV]PC(0)= "M"
      Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WPDS = [M:DIV]RV(0)
      [M:FIY]NBRMONPER(INDPER-1) = WPDS
      [M:DIV]PD(0)= LDTDBEXE : [M:DIV]PD(1)= LDTFNEXE : [M:DIV]PC(0)= "W"
      Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WPDS = [M:DIV]RV(0)
      [M:FIY]NBRWEKPER(INDPER-1) = WPDS
      [M:DIV]PD(0)= LDTDBEXE : [M:DIV]PD(1)= LDTFNEXE : [M:DIV]PC(0)= "D"
      Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WPDS = [M:DIV]RV(0)
      [M:FIY]NBRDAYPER(INDPER-1) = WPDS
      INDPER += 1
    Elsif ( LNUMEXE < [M:CNX]HRZPER(I_CNT-1) or ( [M:DIV]TRTDEM = "CALSIM" ) ) Then : # FQ74517 FQ78670
      LNUMEXE += 1
      If ( [F:WFIS]NBRPER = 0 ) Then
        [M:FIY]INDDEBPER(INDEXE-1) = INDPER
        [M:FIY]INDCURPER(INDEXE-1) = 1
        [M:FIY]NBRPER   (INDEXE-1) = 1
        [M:FIY]DATSTRPER(INDPER-1) = [F:WFIS]DATSTRFIY
        [M:FIY]DATENDPER(INDPER-1) = [F:WFIS]DATENDFIY
        [M:DIV]PD(0)= [F:WFIS]DATSTRFIY : [M:DIV]PD(1)= [F:WFIS]DATENDFIY : [M:DIV]PC(0)= "M"
        Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WPDS = [M:DIV]RV(0)
        [M:FIY]NBRMONPER(INDPER-1) = WPDS
        [M:DIV]PD(0)= [F:WFIS]DATSTRFIY : [M:DIV]PD(1)= [F:WFIS]DATENDFIY : [M:DIV]PC(0)= "W"
        Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WPDS = [M:DIV]RV(0)
        [M:FIY]NBRWEKPER(INDPER-1) = WPDS
        [M:DIV]PD(0)= [F:WFIS]DATSTRFIY : [M:DIV]PD(1)= [F:WFIS]DATENDFIY : [M:DIV]PC(0)= "D"
        Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WPDS = [M:DIV]RV(0)
        [M:FIY]NBRDAYPER(INDPER-1) = WPDS
        INDPER += 1
      Else
        [M:FIY]INDDEBPER(INDEXE-1) = INDPER
        For I = 1 To [F:WFIS]NBRPER
          If (I>1 and [F:WFIS]DATSTRPER(I-1)<=[F:WFIS]DATENDPER(I-2) ) Then
            [M:DIV]ERRID = 29 : Call ERRFND From   GLOBB0
            Break
          Endif
          [M:FIY]DATSTRPER(INDPER-1) = [F:WFIS]DATSTRPER(I-1)
          [M:FIY]DATENDPER(INDPER-1) = [F:WFIS]DATENDPER(I-1)
          [M:FIY]NBRMONPER(INDPER-1) = [F:WFIS]NBRMONPER(I-1)
          [M:FIY]NBRWEKPER(INDPER-1) = [F:WFIS]NBRWEKPER(I-1)
          [M:FIY]NBRDAYPER(INDPER-1) = [F:WFIS]NBRDAYPER(I-1)
          [M:FIY]STAPER   (INDPER-1) = [F:WFIS]STAPER(I-1)
          INDPER += 1
        Next I
        If ([M:DIV]ERROR) Then : Break : Endif
      Endif
    Else
      [M:FIY]INDDEBPER(INDEXE-1) = INDPER
      [M:FIY]INDCURPER(INDEXE-1) = 1
      [M:FIY]NBRPER   (INDEXE-1) = 1
      [M:FIY]DATSTRPER(INDPER-1) = [F:WFIS]DATSTRFIY
      [M:FIY]DATENDPER(INDPER-1) = [F:WFIS]DATENDFIY
      [M:DIV]PD(0)= [F:WFIS]DATSTRFIY : [M:DIV]PD(1)= [F:WFIS]DATENDFIY : [M:DIV]PC(0)= "M"
      Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WPDS = [M:DIV]RV(0)
      [M:FIY]NBRMONPER(INDPER-1) = WPDS
      [M:DIV]PD(0)= [F:WFIS]DATSTRFIY : [M:DIV]PD(1)= [F:WFIS]DATENDFIY : [M:DIV]PC(0)= "W"
      Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WPDS = [M:DIV]RV(0)
      [M:FIY]NBRWEKPER(INDPER-1) = WPDS
      [M:DIV]PD(0)= [F:WFIS]DATSTRFIY : [M:DIV]PD(1)= [F:WFIS]DATENDFIY : [M:DIV]PC(0)= "D"
      Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WPDS = [M:DIV]RV(0)
      [M:FIY]NBRDAYPER(INDPER-1) = WPDS
      INDPER += 1
    Endif
    INDEXE += 1
  Next
  If ([M:DIV]ERROR) Then : End : Endif
  [M:FIY]NB_EXE = INDEXE-1
  [M:FIY]NB_PER = INDPER-1
  Local Integer EXEMAX
  If ( [M:DIV]TRTDEM = "CALSIM" ) Then
    EXEMAX = [M:DIV]CSTFIYMAX - INDCLO
  Else
    EXEMAX = [M:CNX]HRZEXE(I_CNT-1) + INDCLO
    If ([M:CNX]HRZEXE(I_CNT-1) + INDCLO> [M:DIV]CSTFIYMAX ) Then
      [M:DIV]ERRID = 30 : Call ERRFND From   GLOBB0 : End : # DĂ©pilement suite Ă  erreur logique
    Endif
  Endif
  For I_EXE = INDEXE To EXEMAX
    LDTDB  = func GLOBB9.CAL_DAT_PLUS( [M:FIY]DATENDFIY(I_EXE-2), 1, "D" )
    [M:DIV]PD(0)= LDTDB : [M:DIV]PV(0)= GVML_TPJOUR
    Gosub GSB_CAL_EXERCICE_SELON_DATE From   GLOBB8
    LDTDBEXE = [M:DIV]RD(1) : LDTFNEXE = [M:DIV]RD(2) : LINDEXE  = [M:DIV]RE(0)
    If ([M:DIV]ERROR) Then : Break : Endif
    [M:FIY]DATSTRFIY(I_EXE-1) = LDTDBEXE
    [M:FIY]DATENDFIY(I_EXE-1) = LDTFNEXE
    [M:FIY]RAT39BIS (I_EXE-1) = 0
    [M:FIY]STAFIY   (I_EXE-1) = 0
    [M:FIY]EVTCREFLG(I_EXE-1) = G_NON
    [M:FIY]INDDEBPER(I_EXE-1) = INDPER
    [M:FIY]INDCURPER(I_EXE-1) = 1
    [M:FIY]NBRPER   (I_EXE-1) = 1
    [M:FIY]DATSTRPER(INDPER-1) = LDTDBEXE
    [M:FIY]DATENDPER(INDPER-1) = LDTFNEXE
    [M:DIV]PD(0)= LDTDBEXE : [M:DIV]PD(1)= LDTFNEXE : [M:DIV]PC(0)= "M"
    Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WPDS = [M:DIV]RV(0)
    [M:FIY]NBRMONPER(INDPER-1) = WPDS
    [M:DIV]PD(0)= LDTDBEXE : [M:DIV]PD(1)= LDTFNEXE : [M:DIV]PC(0)= "W"
    Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WPDS = [M:DIV]RV(0)
    [M:FIY]NBRWEKPER(INDPER-1) = WPDS
    [M:DIV]PD(0)= LDTDBEXE : [M:DIV]PD(1)= LDTFNEXE : [M:DIV]PC(0)= "D"
    Gosub GSB_CAL_DAT_DIFF From   GLOBB9 : WPDS = [M:DIV]RV(0)
    [M:FIY]NBRDAYPER(INDPER-1) = WPDS
    INDPER += 1
    If (INDPER >= [M:DIV]DEPMAX ) Then : Break : Endif
  Next I_EXE
  If ([M:DIV]ERROR) Then : End : Endif
  [M:FIY]NB_EXE = I_EXE-1
  [M:FIY]NB_PER = INDPER-1
End

