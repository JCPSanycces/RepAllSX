#<AdxTL>@(#)4.0.0.0 $Revision$
$ACTION
Case ACTION
 When "IMP_TAB" : Gosub IMP_TAB
Endcase
Return

$IMP_TAB
## Pour importer les quantièmes (Suite au bug 19125)
Case IMPZON
 When "J1" : [M]J1(nolign-1) = [F:TPT]DAYMON(0)
 When "J2" : [M]J2(nolign-1) = [F:TPT]DAYMON(1)
 When "J3" : [M]J3(nolign-1) = [F:TPT]DAYMON(2)
 When "J4" : [M]J4(nolign-1) = [F:TPT]DAYMON(3)
 When "J5" : [M]J5(nolign-1) = [F:TPT]DAYMON(4)
 When "J6" : [M]J6(nolign-1) = [F:TPT]DAYMON(5)
Endcase
Return


