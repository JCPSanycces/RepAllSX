########################################################################## Type de montant de vente
Subprog AV_ISSAMTTYP(VALEUR)
Variable Integer VALEUR

  #FQ104752 on remet le type montant de vente à "Aucun" dans le cas d'une annulation de sortie.
  If  [M:FASS]CCLISSFLG = G_OUI and VALEUR <> GVML_TVAUCUN
    [M:FASS]ISSAMTTYP = GVML_TVAUCUN
    Affzo [M:FASS]ISSAMTTYP
    Grizo [M:FASS]ISSAMTTYP
  Endif #FQFQ104752 END

End

########################################################################## Type de montant de vente
Subprog AM_ISSAMTTYP(VALEUR)
Variable Integer VALEUR

Local Integer N_C
  If ( [M:FASS]ISSTYP <> GVML_TSVENTE and VALEUR =  GVML_TVSAISI ) Then
    Local Integer OK
    Call OUINON(mess(52,GML_MSGFAS,1), OK) From GESECRAN
    If ( OK = 1) Then : mkstat = 2 : End : Endif
  Endif

  #*Fq-67621
  #* Si le type de sortie est <> de "Vente" ou que le type montant de vente = "Aucun"
  #* on rend inaccessible tout le bloc "Facture de vente"
  If  [M:FASS]ISSTYP <> GVML_TSVENTE or VALEUR = GVML_TVAUCUN
      Effzo [M:FASS]20 : Grizo [M:FASS]20    #Fq-67621
      # FQ100398/16
      If dim(GFXDNBERR) < 0
        [M:FASS]SIVTYP = G_SIVTYP : Affzo [M:FASS]SIVTYP
      Endif
  Else
     #* Si le type de sortie est = "Vente" et que le type montant de vente <> "Aucun"
     #* on rend accessible le bloc "Facture de vente"
         # Type de facture : Valeur par défaut selon paramétrage - FQ67621
     # FQ100398/16
     Local Char WSIVTYP
     Call PARAM([M:FASS]ISSCPY," TYPINVFAS", WSIVTYP) From ADOVAL
     If WSIVTYP <> ""
      [M:FASS]SIVTYP = WSIVTYP
     Endif
     Actzo [M:FASS]SIVTYP   : Affzo [M:FASS]SIVTYP
     Actzo [M:FASS]BUY      : Affzo [M:FASS]BUY
     Actzo [M:FASS]VAT      : Affzo [M:FASS]VAT
     Actzo [M:FASS]COMMENT1 : Affzo [M:FASS]COMMENT1
     # Sauf le n° de facture de vente si SALINV="oui"
     If G_SALINV=G_OUI
        Diszo [M:FASS]IVCSALISS
        Actzo [M:FASS]BPRSAC   : Affzo [M:FASS]BPRSAC
      Else
         # sauf le Collectif si GSALINV="non"
         Actzo [M:FASS]IVCSALISS : Affzo [M:FASS]IVCSALISS
         Diszo [M:FASS]BPRSAC
      Endif
  Endif
  # Mise à jour des montants
  For N_C = 0 To [M:FASS]NB_CNX - 1
    Call CALCUL_MONTANTS_DEVISES([M:FASS]ISSAMT, [M:FASS]RATCURCNX(N_C), N_C) From TRTFAS
  Next N_C
  [M:FASS]ISSAMTTYP= VALEUR
  Affzo  [M:FASS]ISSAMTTYP

End

########################################################################## Type de montant de vente
Subprog AP_ISSAMTTYP(VALEUR)
Variable Integer VALEUR

###-> Massif et unitaire ; activation des zones suivantes en fonction du type de montant de vente.
 Case VALEUR
  When GVML_TVAUCUN                # Aucun
   Effzo [M:FASS]ISSAMT : Grizo [M:FASS]ISSAMT
   Effzo [M:FASS]VALPLN : Grizo [M:FASS]VALPLN
   Effzo [M:FASS]BRDTYP : Grizo [M:FASS]BRDTYP
   Effzo [M:FASS]BRDPLN : Grizo [M:FASS]BRDPLN
   #*Fq-67621
#   Effzo [M:FASS]SIVTYP : Grizo [M:FASS]SIVTYP
#   Effzo [M:FASS]BUY    : Grizo [M:FASS]BUY
#   Effzo [M:FASS]BPRSAC : Grizo [M:FASS]BPRSAC
#   Effzo [M:FASS]COMMENT1 : Grizo [M:FASS]COMMENT1    #*Fq-67621
    Effzo [M:FASS]20 : Grizo [M:FASS]20      #Fq-67621
  When GVML_TVSAISI                # Montant à saisir
   Actzo [M:FASS]ISSAMT
   Actzo [M:FASS]BRDTYP
   Actzo [M:FASS]BRDPLN
   Effzo [M:FASS]VALPLN : Grizo [M:FASS]VALPLN
  When GVML_TVVNCPL                # Valeur nette du plan
   Effzo [M:FASS]ISSAMT : Grizo [M:FASS]ISSAMT
   Effzo [M:FASS]BRDTYP : Grizo [M:FASS]BRDTYP
   Effzo [M:FASS]BRDPLN : Grizo [M:FASS]BRDPLN
   Actzo [M:FASS]VALPLN
  When Default
 Endcase
 Affzo [M:FASS] : Setmok [M:FASS] With 0
End

########################################################################## ISSAMT = VNC du plan n
Subprog AS_VALPLN(VALEUR)
Variable Integer VALEUR

###-> initialisation massif et unitaire

# On ne présente que les plans gérés par la société de sélection en massif ou la société du
# bien en unitaire

 Local Char CPYREF
 Local Integer I_PLN
 Case ACTTYPGES
  When GTAMMAS : CPYREF = [M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1)
  When GTAMUNI : CPYREF = [M:FAS0]CPY
  When Default
 Endcase
 For I_PLN=1 To G301MAX-1
  If func GLOBIENS.CPY_PLN_GERE(CPYREF,I_PLN)=G_NON
   GMENLOC(I_PLN)=1
  Endif
 Next I_PLN
 GMENLOC(G301MAX)=1

End

########################################################################## ISSAMT = VNC du plan n
Subprog C_VALPLN(VALEUR)
Variable Integer VALEUR

 # Un plan dont la devise de suivi est différente de la devise société ne peut être choisi

 Local Char L_CPY

 # Alimentation de la société de référence

 If ACTTYPGES=GTAMMAS
  L_CPY=[M:MHC]CPY((find(G_OUI,[M:MHC]FLGCPY))-1)
 Elsif ACTTYPGES=GTAMUNI
  L_CPY=[M:FAS0]CPY
 Endif

 # Contrôle de la devise du plan par rapport à la devise société.

 If func GLOFCYCPY.GET_DEVISE_PLN (L_CPY, VALEUR)<>GCNXCURCPF
  GERR     = 1
  GMESSAGE = mess(428,GML_MSGFAS,1) # "Ce plan est suivi dans une devise différente de la devise société" #
  mkstat   = 2
  End
 Endif

End


########################################################################## Montant de vente
Subprog AM_ISSAMT(VALEUR)
Variable Decimal VALEUR

Local Integer N_C

  For N_C = 0 To [M:FASS]NB_CNX - 1
    Call CALCUL_MONTANTS_DEVISES(VALEUR, [M:FASS]RATCURCNX(N_C), N_C) From TRTFAS
  Next N_C
End

########################################################################## Clé de répartition
Subprog AS_BRDTYP(VALEUR)
Variable Integer VALEUR

 Local Char CPYREF

 Case ACTTYPGES
  When GTAMMAS : CPYREF = [M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1)
  When GTAMUNI : CPYREF = [M:FAS0]CPY
  When Default
 Endcase
 If func GLOBIENS.CPY_PLN_GERE(CPYREF,G301IAS)=G_NON : GMENLOC(3)=1 : Endif

 If ACTTYPGES=GTAMUNI
  If [M:FASS]ISSCMPFLG<>G_OUI & [M:FASS]ISSTYP=GVML_TSVENTE
   Effzo [M:FASS]BRDTYP
   Grizo [M:FASS]BRDTYP
   Affzo [M:FASS]BRDTYP
  Else
   Actzo [M:FASS]BRDTYP
  Endif
 Endif

End

########################################################################## Clé de répartition
Subprog AP_BRDTYP(VALEUR)
Variable Integer VALEUR

###-> initialisation massif et unitaire

# Si la clé de répartition est une clé basée sur la valeur nette d'un plan, on active le choix
# de plan sinon la zone de choix est inaccessible.

#Gbn-07012004-Bug n° 27547-On active le plan que si BRDTYP est lui-même activé et vaut 1
#If VALEUR=1
 If VALEUR=1 & varmode([M:FASS]BRDTYP)=0
  Actzo [M:FASS]BRDPLN
 Else
  Effzo [M:FASS]BRDPLN
  Grizo [M:FASS]BRDPLN
 Endif

End

########################################################################## Clé selon VNC du plan n
Subprog AS_BRDPLN(VALEUR)
Variable Integer VALEUR

###-> initialisation massif et unitaire

# On ne présente que les plans gérés par la société de sélection en massif ou la société du
# bien en unitaire

 Local Char CPYREF
 Local Integer I_PLN

 Case ACTTYPGES
  When GTAMMAS : CPYREF = [M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1)
  When GTAMUNI : CPYREF = [M:FAS0]CPY
  When Default
 Endcase

 For I_PLN=1 To G301MAX-1
  If func GLOBIENS.CPY_PLN_GERE(CPYREF,I_PLN)=G_NON
   GMENLOC(I_PLN)=1
  Endif
 Next I_PLN
 GMENLOC(G301MAX)=1

End
######################################################################################
Subprog AM_VAT(VALEUR)
Variable Char    VALEUR()

  # FQ67621
 If !clalev([F:TVT])    : Global File TABVAT [TVT]   : Endif
  If (VALEUR = "") Then
    # Le code taxe peut ne pas être renseigné. Dans ce cas on estime que les taux de TVA et TVA du sur vente sont à zéro
    [M:FASS]ISSVATRAT  = 0
    [M:FASS]ISSVATAMT  = 0
    End
  Endif

  If !clalev([F:TRA])  : Local File TABRATVAT  [TRA]  : Endif
  Local Date     DAT
  Local Char     COMPANY, TAX
  Local Integer  STAT
  Local Decimal  TAUX1, TAUX2
  [L]TAX     = VALEUR
  [L]DAT     = [M:FASS]ISSDAT
  [L]COMPANY = [M:FASS]ISSCPY
   Gosub LECTAX From SUBTVT
  If (![L]STAT) Then
    [M:FASS]ISSVATRAT   = [L]TAUX1
    Call AP_ISSVATRAT([L]TAUX1)
  Else
    # Erreur en lecture des taux de taxe"
    GMESSAGE = mess(896,GML_MSGFAS,1)
    GERR     = 1
    mkstat   = 2
  Endif
End


######################################################################################
Subprog B2_VAT(VALEUR)
Variable Char    VALEUR()
  # FQ67621
 If !clalev([M:BIC0])   : Global Mask BIC0   [BIC0]  : Endif
 If !clalev([M:BIC1])   : Global Mask BIC1   [BIC1]  : Endif
 If !clalev([M:BIC3])   : Global Mask BIC3   [BIC3]  : Endif
 If !clalev([M:BICT])   : Global Mask BICT   [BICT]  : Endif
 If !clalev([F:TVT])    : Global File TABVAT [TVT]   : Endif

 # BIC0
 [M:BIC0]CPY    = [M:FASS]ISSCPY
 [M:BIC0]BPR    = [M:FASS]BUY
 [M:BIC0]ACCDAT = [M:FASS]ISSDAT

 # BIC1
 [M:BIC1]CUR    = [M:FASS]ACGCUR


 #X3-38745  If !GWEBSERV
 #X3-38745   ## Action SAITAX
 #X3-38745   Local Char    PARMSK(250)(1..20) , SAVACT(20)
 #X3-38745   SAVACT = GACTION : GACTION = "SAITAX"
 #X3-38745
 #X3-38745   Call SAISIE_CHAR(VALEUR,PARMSK,"DBICT","SUBBIH","SPEBIH") From GSAISIE
 #X3-38745   GACTION = SAVACT
 #X3-38745  Endif

 # BIC3
 NOL = 0
 nolign = 1
 [M:BIC3]VAT   (nolign-1)    = [M:FASS]VAT
 [M:BIC3]AMTVAT(nolign-1)    = [M:FASS]ISSVATAMT
 [M:BIC3]AMTNOTLIN(nolign-1) = [M:FASS]ISSAMT
 #X3-38745 [M:BIC3]TAX1(nolign-1)=[M:BICT]TAX1
 #X3-38745 [M:BIC3]TAX2(nolign-1)=[M:BICT]TAX2
 #X3-38745 [M:BIC3]AMTTAX1(nolign-1)=[M:BICT]AMTTAX1
 #X3-38745 [M:BIC3]AMTTAX2(nolign-1)=[M:BICT]AMTTAX2
 [M:BIC3]NBLIG  = 1

 If !GWEBSERV
  ## Action SAITAX
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "SAITAX"
  Call SAISIE_CHAR(VALEUR,PARMSK,"DBICT","SUBBIH","SPEBIH") From GSAISIE
  GACTION = SAVACT
 Endif

 #X3-38745
 [M:FASS]TAX1       = [M:BIC3]TAX1(NOL)
 [M:FASS]AMTTAX1    = [M:BIC3]AMTTAX1(NOL)
 [M:FASS]TAX2       = [M:BIC3]TAX2(NOL)
 [M:FASS]AMTTAX2    = [M:BIC3]AMTTAX2(NOL)
 [M:FASS]TAXRCP     = [M:BIC3]TAXRCP(NOL)
 [M:FASS]AMTTAXRCP  = [M:BIC3]AMTTAXRCP(NOL)
 [M:FASS]TAXISS     = [M:BIC3]TAXISS(NOL)
 [M:FASS]AMTTAXISS  = [M:BIC3]AMTTAXISS(NOL)
 [M:FASS]TAXOTH1    = [M:BIC3]TAXOTH1(NOL)
 [M:FASS]AMTTAXOTH1 = [M:BIC3]AMTTAXOTH1(NOL)
 [M:FASS]TAXOTH2    = [M:BIC3]TAXOTH2(NOL)
 [M:FASS]AMTTAXOTH2 = [M:BIC3]AMTTAXOTH2(NOL)
 #X3-38745 END

 If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
 Gosub AFF From GSAISIE

 nolign = 1

 If ( VALEUR =  [M:FASS]VAT ) and  [M:BIC3]AMTVAT(nolign-1) <>  [M:FASS]ISSVATAMT
   #Vous ne pouvez-pas modifier ici la TVA due sur vente
   GMESSAGE= mess(900,GML_MSGFAS,1)
   GERR=1
   mkstat=2
   End
 Endif


End
###*FQ-67621 ####################################################################################
Subprog C_VAT(VALEUR)
Variable Char    VALEUR()

 #Fq-91395:  Uniquement si l'on n'est pas en Import....
 If !GIMPORT
     If (VALEUR = "") and ( [M:FASS]ISSTYP = GVML_TSVENTE ) and ( [M:FASS]ISSAMTTYP<> GVML_TVAUCUN )
       # Le code taxe est obligatoire pour le motif "Vente"  et le type montant vente <> "Aucun"
       GMESSAGE = mess(126,104,1)
       GERR     = 1
       mkstat   = 2
       End
     Endif
  Endif


End
########################################################################## Taux de TVA due sur vente : # FQ27566
Subprog AP_ISSVATRAT(VALEUR)
Variable Decimal VALEUR

  ##FQ-XXXXXFq-67621 On ne recalcule le montant de la TVA que s'il n'a pas été forcé dans l'écran de saisie des codes TVA [M:BIC3]
  #FQ-XXXXXIf G_VATAMTFLG <>  G_OUI
     Call GET_MNT_ARRONDI([M:FASS]ISSAMT*VALEUR/100,GCNXCURCPF,[M:FASS]ISSVATAMT) From GLOBIENS
     Affzo [M:FASS]ISSVATAMT
  #FQ-XXXXXEndif

 If VALEUR > 0
   If ACTTYPGES=GTAMUNI and [M:FAS1]DEDVATRAT = 100
     [M:FASS]PYBVATTYP = GVML_SNSREGU
     Diszo [M:FASS]PYBVATTYP
   Else
     [M:FASS]PYBVATTYP = GVML_DEDCOMP
     Actzo [M:FASS]PYBVATTYP
   Endif
 Else
   #FQ57746-Utilisateur a choisi taux T.V.A. à 0 et régle de T.V.A. "pas de régul". Si 1er passage sur contrôler on ne réapplique par l'alim par défaut
   If ACTSTATUS<STA_MODIF
    [M:FASS]PYBVATTYP = GVML_RVTVA
    Actzo [M:FASS]PYBVATTYP
   Endif
 Endif

 Affzo [M:FASS]PYBVATTYP
End

########################################################################## Règle de TVA
Subprog AS_PYBVATTYP(VALEUR)
Variable Integer VALEUR

 If [M:FASS]ISSTYP=GVML_TSFCLOC | [M:FASS]ISSTYP=GVML_TSFCONT | [M:FASS]ISSTYP=GVML_TSREPRI
  GMENLOC(GVML_RVTVA20)=1
  GMENLOC(GVML_RVTVA10)=1
  GMENLOC(GVML_RVTVA05)=1
  GMENLOC(GVML_DEDCOMP)=1
  GMENLOC(GVML_RVTVA)=1
 Elsif [M:FASS]ISSTYP=GVML_TSREBUT | [M:FASS]ISSTYP=GVML_TSVOLDI
  GMENLOC(GVML_DEDCOMP)=1
  GMENLOC(GVML_RVTVA)=1
# FQ54343 Elsif [M:FASS]ISSTYP=GVML_TSVENTE | [M:FASS]ISSDATRUL=GVML_IRCONCE
 Elsif [M:FASS]ISSTYP=GVML_TSVENTE
  GMENLOC(GVML_RVTVA20)=1
  GMENLOC(GVML_RVTVA10)=1
  GMENLOC(GVML_RVTVA05)=1
  If [M:FASS]ISSVATRAT > 0
   GMENLOC(GVML_RVTVA)=1
  Else
   GMENLOC(GVML_DEDCOMP)=1
  Endif
 Endif

End

########################################################################## Règle de TVA
Subprog AP_PYBVATTYP(VALEUR)
Variable Integer VALEUR

End

########################################################################## Taux devise
Subprog AM_RATCURCNX(VALEUR)
Variable Decimal VALEUR

  Call CALCUL_MONTANTS_DEVISES([M:FASS]ISSAMT, VALEUR, nolign-1) From TRTFAS
End

##########################################################################
Subprog C_BUY(VALEUR)
Variable Char    VALEUR()

 #*Fq-91395 - il ne s'agit pas d'1 Import
 If !GIMPORT
 If VALEUR = "" and G_SALINV=G_OUI and [M:FASS]ISSTYP = GVML_TSVENTE
  # Client obligatoire
  GMESSAGE = mess(895,GML_MSGFAS,1)
  GERR     = 1
  mkstat   = 2
 Endif
 Endif

End
######################################################################################
Subprog AM_BUY(VALEUR)
Variable Char    VALEUR()

  # FQ67621
  Local Char INTERM
  Local Char CODCPT(GLONCAC)
  Local Char PLNREFGEN
  PLNREFGEN = [M:FPC]COA(find([M:FPC]GENLEDTYP,[M:FPC]LEDTYP)-1)

  If !clalev([F:GAC]) : Local File GACCOUNT   [GAC] : Endif
  If !clalev([F:CAC]) : Local File GACCCODE   [CAC] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif

  Call LECTURE("BPC",VALEUR,"") From CONTOBJ
  If ( ACTTYPGES = GTAMUNI ) Then
    Call INIT_COMPTE(VALEUR,[M:FAS0]CPY,"C",CODCPT) From CPTSUB
  Else
    Call INIT_COMPTE(VALEUR,[M:FASS]ISSCPY,"C",CODCPT) From CPTSUB
  Endif
  If ( [L]CODCPT <> "" ) Then
   Call LECTURE("CAC",[L]CODCPT,"2~"+PLNREFGEN) From CONTOBJ
   INTERM = [F:CAC]ACC(10)
   If INTERM = ""
     INTERM = [F:CAC]ACC(0)
   Endif
  Endif
  If (INTERM <> "") Then
   Call LECTURE("GAC",INTERM,PLNREFGEN) From CONTOBJ
   If (!fstat & [F:GAC]SAC=2) Then
    [M:FASS]BPRSAC = [F:GAC]ACCSHO
    [M:FASS]SACACC = [F:GAC]ACC
   Else
    [M:FASS]BPRSAC = ""
    Raz [M:FASS]SACACC
   Endif
  Endif
  Affzo [M:FASS]SACACC
End


##########################################################################
Subprog AV_NBOBJ
 If ACTTYPGES=GTAMMAS
  #Infbox num$(status)
  If [M:MFS0]CMP(nolign-1)=""
   Enable GSTAANU
   Enable 65
   GBOUT1=""
  Else
   Disable GSTAANU
   Disable 65
   GBOUT1=""
  Endif
 Else
  Disable GSTAANU
  Disable 65
  GBOUT1=""
 Endif
End

##########################################################################
Subprog C_NBOBJ
  If status=65
   Local Integer NBR_CMP_SUP
   Call SUPPRIME_COMPO([M:MFS0]OBJREF(nolign-1),NBR_CMP_SUP) From SUBMAS
   If NBR_CMP_SUP : Affzo [M:MFS0] : Setmok [M:FASS] With 0 : Endif
  Endif
End
########################################################################## Montant de sortie
Subprog AV_ISSAMT0_MFS(VALEUR)
Variable Decimal VALEUR
 If [M:MFS0]UNLINK(nolign-1)<>G_OUI
  If [M:FASS]ISSAMTTYP<> GVML_TVAUCUN & [M:FASS]ISSAMTTYP<> GVML_TVSAISI
   Grizo [M:MFS0]ISSAMT0(nolign-1)
  Else
   Actzo [M:MFS0]ISSAMT0(nolign-1)
  Endif
 Endif
End

########################################################################## Montant de sortie
Subprog AM_ISSAMT0_MFS(VALEUR)
Variable Decimal VALEUR

 Local Integer ROK
 Local Decimal TOTAL_VENTE, MONTANT_VENTE
 Local Integer I_BCO
 Local Integer NBISSOBJ        # Nombre de biens à sortir
 Local Integer RECALC_INFO     # Recalcul des infos après modification d'un montant


If [M:MFS0]NBOBJ>1
 Case [M:FASS]ISSAMTTYP
  When GVML_TVSAISI
   For I_BCO=1 To [M:MFS0]NBOBJ
    If I_BCO=nolign
     TOTAL_VENTE+=VALEUR
    Else
     TOTAL_VENTE+=[M:MFS0]ISSAMT0(I_BCO-1)
    Endif
    If [M:MFS0]UNLINK(I_BCO-1)<>G_OUI
     NBISSOBJ+=1
    Endif
   Next I_BCO
   If NBISSOBJ>1
    MESSAGE = mess(234,GML_MSGFAS,1)+"           : "-num$([M:FASS]ISSAMT)                               # "Enveloppe de vente"
    MESSAGE+="\"+mess(235,GML_MSGFAS,1)+" : "-num$(TOTAL_VENTE)                                         # "Total des montants de vente"
    MESSAGE+="\"+mess(236,GML_MSGFAS,1)+"                        : "-num$(TOTAL_VENTE-[M:FASS]ISSAMT)   # "Ecart"
    MESSAGE+="\"+mess(233,GML_MSGFAS,1)+". "+mess(419,GML_MSGFAS,1)                                            # "MODIFICATION du montant de vente. Confirmez-vous"
   Else
    MESSAGE=mess(233,GML_MSGFAS,1)+". "+mess(419,GML_MSGFAS,1)                                                 # "Modification du montant de vente. Confirmez-vous"
   Endif
  When Default
   MESSAGE=mess(233,GML_MSGFAS,1)+". "+mess(419,GML_MSGFAS,1)                                                  # "Modification du montant de vente. Confirmez-vous"
 Endcase
 Call AVERTIR (MESSAGE,ROK) From GESECRAN
 Case ROK
  When G_NON
   VALEUR=[M:MFS0]ISSAMT0(nolign-1)   # On restaure la valeur d'origine
  When Default
   RECALC_INFO=G_OUI
 Endcase
Else
 MESSAGE=mess(233,GML_MSGFAS,1)+mess(71,GML_MSGFAS,1)    # "Modification du montant de vente. Confirmez-vous"
 Call AVERTIR (MESSAGE,ROK) From GESECRAN
 Case ROK
  When G_NON
   VALEUR=[M:MFS0]ISSAMT0(nolign-1)   # On restaure la valeur d'origine
  When Default
   RECALC_INFO=G_OUI
 Endcase
Endif

If RECALC_INFO=G_OUI
 # Recalcul de la +/- value
 Local Integer I_PLN
 For I_PLN=1 To [M:MFS0]NBPLN
  [M:MFS0]GAL(I_PLN-1)=VALEUR-[M:MFS0]NBV(I_PLN-1)
  Affzo [M:MFS0]GAL(I_PLN-1)
 Next I_PLN
 ##FQ-XXXXXFq-67621 On ne recalcule le montant de la TVA que s'il n'a pas été forcé dans l'écran de saisie des codes TVA [M:BIC3]
 If [M:FASS]ISSVATRAT > 0 #FQ-XXXXX and   G_VATAMTFLG <>  G_OUI
   [M:MFS0]ISSVATAMT(nolign-1)=VALEUR*[M:FASS]ISSVATRAT/100
   Call GET_MNT_ARRONDI([M:MFS0]ISSVATAMT(nolign-1),[M:MFS0]CPYDEV,[M:MFS0]ISSVATAMT(nolign-1)) From GLOBIENS
   Call MAJ_TVA_MFS([M:MFS0]ISSVATAMT(nolign-1))
 Else
   [M:MFS0]ISSVATAMT(nolign-1)=0
 Endif
Endif

If TOTAL_VENTE=0
   G_TOTBICCOK= G_NON
Else
   G_TOTBICCOK= G_OUI
Endif

End

########################################################################## Calcul des reversements et déductions TVA
Subprog MAJ_TVA_MFS(PISSVATAMT)
Value Decimal PISSVATAMT : # Montant TVA de sortie

  Local Decimal MONTANT_ORIGINE
  Local Decimal MONTANT_ARRONDI
  Local Decimal RATIO_REGUL
  Local Integer ENDVATREGDAT
  Local Integer STAT

  # FQ46680
  Local Decimal WDURDET
  Local Decimal WDURRES

  If !clalev([M:DIV])   : Local Mask CALDIV  [DIV]  : Endif #FQ82207
  If !clalev([M:DIV2])  : Local Mask CALDIV2 [DIV2] : Endif #FQ82207

  If [M:MFS0]THESLI(nolign-1) = 0 Then
    # Il n'y a pas de durée de régularisation, donc pas de régularisation
    [M:MFS0]ACGCPLDED(nolign-1) = 0
    [M:MFS0]IASCPLDED(nolign-1) = 0
    # FQ46680
    [M:MFS0]ACGREVVAT(nolign-1)  = 0
    [M:MFS0]IASREVVAT(nolign-1)  = 0 : # FQ70141 : [F:MFS0] -> [M:MFS0]
    [M:MFS0]ISSVATTRF(nolign-1)  = 0 : # FQ70141 : [F:MFS0] -> [M:MFS0]
    [M:MFS0]ISSVATTRFI(nolign-1) = 0 : # FQ70141 : [F:MFS0] -> [M:MFS0]
  Else
   Case [M:FASS]PYBVATTYP

    When GVML_RVTVA   : # Reversement
      # ---- Reversement de TVA
      # FQ46680
      # Durée de détention en année
      WDURDET = year([M:FASS]ISSDAT) - year([M:MFS0]VATREGDAT(nolign-1))+1
      # Durée résiduel de régularisation
      WDURRES = [M:MFS0]THESLI(nolign-1) - WDURDET
      #
      # Si la sortie a lieu avant la fin de la période de régularisation (WDURRES > 0)
      # -- PCG --

      # FQ46680
      # TVA transférable
      [M:MFS0]ISSVATTRF(nolign-1) = [M:MFS0]IVCVATAMT(nolign-1) * (WDURRES / [M:MFS0]THESLI(nolign-1))
      # Arrondi dans la devise du contexte
      #Call CAL_ARRONDI_MNT ([M:MFS0]ISSVATTRF(nolign-1), [M:MFS0]CPYDEV(nolign-1), [M:MFS0]ISSVATTRF(nolign-1)) From =G_GLOB8
      [M:DIV]PV(0)= [M:MFS0]ISSVATTRF(nolign-1) : [M:DIV]PC(0)= [M:MFS0]CPYDEV(nolign-1)
      Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:MFS0]ISSVATTRF(nolign-1) = [M:DIV]RV(1)

      If ( WDURRES > 0 and [M:MFS0]DEDVATAMT(nolign-1) <> 0 ) Then
        # FQ46680
        # Si la TVA facturée a été récupérée totalement ou partiellement et que la bien a été détenu au moins 1 année
        # TVA à reverser  = ((0 - Coefficient de déduction) * TVA facturée ) * ( Dur. résid. Pér. Rég. / Dur. Pér. rég.)
        [M:MFS0]ACGREVVAT(nolign-1) = ((0 - [M:MFS0]DEDCOEF(nolign-1) ) * [M:MFS0]IVCVATAMT(nolign-1) ) *
&                                           (WDURRES / [M:MFS0]THESLI(nolign-1))
        # Arrondi dans la devise du contexte
        #Call CAL_ARRONDI_MNT ([M:MFS0]ACGREVVAT(nolign-1), [M:MFS0]CPYDEV(nolign-1) , [M:MFS0]ACGREVVAT(nolign-1)) From =G_GLOB8
        [M:DIV]PV(0)= [M:MFS0]ACGREVVAT(nolign-1) : [M:DIV]PC(0)= [M:MFS0]CPYDEV(nolign-1)
        Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:MFS0]ACGREVVAT(nolign-1) = -[M:DIV]RV(1)
        [M:MFS0]VATREGAMT(nolign-1) = [M:MFS0]VATREGAMT(nolign-1) + [M:MFS0]ACGREVVAT(nolign-1)
      Endif

      If (GCNXPROIAS) Then
        # FQ46680
        # TVA transférable
        [M:MFS0]ISSVATTRFI(nolign-1) = [M:MFS0]IVCVATAMTI(nolign-1) * (WDURRES / [M:MFS0]THESLI(nolign-1))
        # Arrondi dans la devise du contexte
        #Call CAL_ARRONDI_MNT ([M:MFS0]ISSVATTRFI(nolign-1), [M:MFS0]CPYDEV(nolign-1) , [M:MFS0]ISSVATTRFI(nolign-1)) From =G_GLOB8
        [M:DIV]PV(0)= [M:MFS0]ISSVATTRFI(nolign-1) : [M:DIV]PC(0)= [M:MFS0]CPYDEV(nolign-1)
        Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:MFS0]ISSVATTRFI(nolign-1) = [M:DIV]RV(1)

        # -- IAS --
        If ( WDURRES > 0  and  [M:MFS0]DEDVATAMTI(nolign-1) <> 0 ) Then
          # FQ46680
          # Si la TVA facturée a été récupérée totalement ou partiellement et que la bien a été détenu au moins 1 année
          # TVA à reverser  = ((0 - Coefficient de déduction) * TVA facturée ) * ( Dur. résid. Pér. Rég. / Dur. Pér. rég.)
          [M:MFS0]IASREVVAT(nolign-1) = ((0 - [M:MFS0]DEDCOEF(nolign-1)  ) * [M:MFS0]IVCVATAMTI(nolign-1) ) *
&                                             (WDURRES / [M:MFS0]THESLI(nolign-1))
          # Arrondi dans la devise du contexte
          #Call CAL_ARRONDI_MNT ([M:MFS0]IASREVVAT(nolign-1), [M:MFS0]CPYDEV(nolign-1) , [M:MFS0]IASREVVAT(nolign-1)) From =G_GLOB8
          [M:DIV]PV(0)= [M:MFS0]IASREVVAT(nolign-1) : [M:DIV]PC(0)= [M:MFS0]CPYDEV(nolign-1)
          Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:MFS0]IASREVVAT(nolign-1) = -[M:DIV]RV(1)
          [M:MFS0]IASVATREG(nolign-1) = [M:MFS0]IASVATREG(nolign-1) + [M:MFS0]IASREVVAT(nolign-1)
        Endif
      Endif


    When GVML_DEDCOMP : # Déduction complémentaire

      # FQ46680
      # Durée de détention en année
      WDURDET = year([M:FASS]ISSDAT) - year([M:MFS0]VATREGDAT(nolign-1))+1
      # Durée résiduel de régularisation
      WDURRES = [M:MFS0]THESLI(nolign-1) - WDURDET

      # -- PCG --
      If ( WDURRES > 0  and [M:MFS0]IVCVATAMT(nolign-1)-[M:MFS0]DEDVATAMT(nolign-1) <> 0 ) Then
        # Si la TVA facturée a été partiellement récupérée et que la bien a été détenu au moins 1 année
        # TVA à reverser  = ((1 - Coefficient de déduction) * TVA facturée ) * ( Dur. résid. Pér. Rég. / Dur. Pér. rég.)
        [M:MFS0]ACGCPLDED(nolign-1) = ((1 - [M:MFS0]DEDCOEF(nolign-1) ) * [M:MFS0]IVCVATAMT(nolign-1) ) *
&                                           (WDURRES / [M:MFS0]THESLI(nolign-1))
        # Arrondi dans la devise du contexte
        #Call CAL_ARRONDI_MNT ([M:MFS0]ACGCPLDED(nolign-1), [M:MFS0]CPYDEV(nolign-1) , [M:MFS0]ACGCPLDED(nolign-1)) From =G_GLOB8
        [M:DIV]PV(0)= [M:MFS0]ACGCPLDED(nolign-1) : [M:DIV]PC(0)= [M:MFS0]CPYDEV(nolign-1)
        Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:MFS0]ACGCPLDED(nolign-1) = [M:DIV]RV(1)
        [M:MFS0]VATREGDED(nolign-1) = [M:MFS0]VATREGDED(nolign-1) + [M:MFS0]ACGCPLDED(nolign-1)
      Endif

      # -- IFRS --

      If (GCNXPROIAS = G_OUI) Then
      # Si le bien a été soumis à TVA
        If (  WDURRES > 0  and ([M:MFS0]IVCVATAMTI(nolign-1)-[M:MFS0]DEDVATAMTI(nolign-1) ) <> 0 ) Then
          # FQ46680
          # Si la TVA facturée a été partiellement récupérée et que la bien a été détenu au moins 1 année
          # TVA à reverser  = ((1 - Coefficient de déduction) * TVA facturée ) * ( Dur. résid. Pér. Rég. / Dur. Pér. rég.)
          [M:MFS0]IASCPLDED(nolign-1) = ((1 - [F:WFAS]DEDCOEF ) * [F:WFAS]IVCVATAMTI ) * (WDURRES / [F:WFAS]THESLI)
          # Arrondi dans la devise du contexte
          #Call CAL_ARRONDI_MNT ([M:MFS0]IASCPLDED(nolign-1), [M:MFS0]CPYDEV(nolign-1) , [M:MFS0]IASCPLDED(nolign-1)) From =G_GLOB8
          [M:DIV]PV(0)= [M:MFS0]IASCPLDED(nolign-1) : [M:DIV]PC(0)= [M:MFS0]CPYDEV(nolign-1)
          Gosub GSB_CAL_ARRONDI_MNT From =G_GLOB8 : [M:MFS0]IASCPLDED(nolign-1) = [M:DIV]RV(1)
          [M:MFS0]VATREGDEDI(nolign-1) = [M:MFS0]VATREGDEDI(nolign-1) + [M:MFS0]IASCPLDED(nolign-1)
        Endif
      Endif

    When Default
   Endcase
  Endif

  Affzo [M:MFS0] ACGCPLDED(nolign-1), IASCPLDED(nolign-1)
  # FQ46680
  Affzo [M:MFS0]ACGREVVAT(nolign-1), IASREVVAT(nolign-1)
  Affzo [M:MFS0]ISSVATTRF(nolign-1), ISSVATTRFI(nolign-1)

End


########################################################################## Montant de T.V.A.
Subprog AV_ISSVATAMT_MFS(VALEUR)
Variable Decimal VALEUR
If [M:MFS0]UNLINK(nolign-1)<>G_OUI
 If [M:FASS]PYBVATTYP<>GVML_DEDCOMP Then
  Grizo [M:MFS0]ISSVATAMT(nolign-1)
 Else
  Actzo [M:MFS0]ISSVATAMT(nolign-1)
 Endif
Endif

End

########################################################################## Montant de TVA sur sortie
Subprog AM_ISSVATAMT_MFS(VALEUR)
Variable Decimal VALEUR
  Call MAJ_TVA_MFS(VALEUR)
End


######################################################################################
Subprog D_SIVTYP(VALEUR)
Variable Char    VALEUR()
 # FQ67621
 If ( ACTTYPGES = GTAMUNI ) Then
   Call PARAM([M:FAS0]CPY,"TYPINVFAS",VALEUR) From ADOVAL
 Endif
End
##Fq-67621 ####################################################################################
Subprog C_SIVTYP(VALEUR)
Variable Char    VALEUR()

 If G_SALINV = G_OUI
   If VALEUR = ""
      GMESSAGE = mess(886, GML_MSGFAS, 1)
      GERR=1
      mkstat=2
   Endif
 Endif

 # Contrôle de la catégorie de facture qui doit être : "Facture"
 # et de même législation que la société ou "Toutes législations"
 If (VALEUR <> "") and (VALEUR <> [M:FASS]SIVTYP)
    If !clalev([F:TSV]) : Local File TABSIVTYP [TSV] : Endif
    Read [TSV]TSV0=VALEUR;[M:FPC]LEG
    If fstat
       Read [TSV]TSV0=VALEUR;""
    Endif
    If [F:TSV]INVTYP <> 1
       GMESSAGE = mess(897,GML_MSGFAS,1)
       GERR=1
       mkstat=2
    Endif
 Endif

End
######################################################################################
# Remplacement de l'action CHGACTPARM qui repasse à STA_TEMP par l'action ci-dessous
# qui permet de repartir à zéro si motif du flag "sortie des biens composants"
Subprog AM_ISSCMPFLG(VALEUR)
Variable Integer VALEUR

 If ACTSTATUS>=STA_MODIF # Demande Mwa pour tenir compte du préchargement possible en unitaire
  Local Integer POK
  If ACTTYPGES=GTAMMAS
    MESSAGE="Paramètre modifié.\La population sera reconstituée.\Voulez-vous continuer ?"
    Call OUINON(MESSAGE,POK) From GESECRAN
    Case POK
     When G_OUI
      Gosub VIDE_TOUT
     When Default
      mkstat = 2
    Endcase
  Elsif ACTTYPGES=GTAMUNI
    Gosub VIDE_TOUT
  Endif
 Endif

End

#==
$VIDE_TOUT
  Local Integer ERROR
  Local Integer NBDLREC
  Local Char    MES
  Call UNLOCKER (NUMACT,MES,ERROR) From TRCPROCOM
  Call VIDER    (NUMACT,"TMPMASFAS",NBDLREC,ERROR) From TRCPROCOM
  Call VIDER    (NUMACT,"TMPPLNFAS",NBDLREC,ERROR) From TRCPROCOM
  ACTSTATUS=STA_DEBUT
Return

