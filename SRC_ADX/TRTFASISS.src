#--------------------------------------------------------------#
# Alimentation d'un enregistrement de TMP1                     #
#--------------------------------------------------------------#
$CREE_ENR_BCO
  Local Integer N_PLN

  [F:TMP1]TRTNUM  = NUMACT
  [F:TMP1]FLGERR  = G_NON

  If    TABORI="[F:MAS1]"
    [F:TMP1]FLGMOD  = G_OUI  : # la ligne du tableau sera modifiable
    [F:TMP1]CMP1    = evalue(TABORI+"AASREF")
  Elsif TABORI="[F:MAS2]"
    [F:TMP1]FLGMOD  = G_NON  : # la ligne du tableau ne sera pas modifiable
    [F:TMP1]CMP     = evalue(TABORI+"CMP")
    [F:TMP1]CMP1    = evalue(TABORI+"CMP")
  Endif

  [F:TMP1]OBJREF  = evalue (TABORI+"AASREF")
  [F:TMP1]AASDES1 = evalue (TABORI+"AASDES1")
  [F:TMP1]CPY     = evalue (TABORI+"CPY")
  [F:TMP1]FCY     = evalue (TABORI+"FCY")
  [F:TMP1]CMPSTA  = evalue (TABORI+"CMPSTA")
  [F:TMP1]ACCCOD  = evalue (TABORI+"ACCCOD")   #*Fq-67621
  [F:TMP1]GAC     = evalue (TABORI+"GAC")      #*Fq-67621

  If TABORI="[F:MAS2]"
    [F:TMP1]CMP= evalue (TABORI+"CMP")
  Elsif TABORI="[F:MAS1]"
    Raz [F:TMP1]CMP
  Endif

  If (([F:TMP1]CMPSTA=GVML_SBCOMPO)  & ([M:FASS]ISSCMPFLG=G_NON)  )
& and  (TABORI="[F:MAS2]")
    If [M:FASS]CCLISSFLG=G_NON
      [F:TMP1]UNLINK        = G_OUI
    Else
      [F:TMP1]UNLINK        = G_NON
    Endif
  Else
    If (TABORI="[F:MAS1]") & (([F:TMP1]CMPSTA=GVML_SBCOMPO))
      # On sort un bien composant sans sortir le bien principal, il faut donc le détacher
      [F:TMP1]UNLINK        = G_OUI
    Else
      # On sort un bien principal
      [F:TMP1]UNLINK        = G_NON
    Endif
    [F:TMP1]ISSTYP        = evalue (TABORI+"ISSTYP")
    [F:TMP1]ISSDATRUL     = evalue (TABORI+"ISSDATRUL")
    [F:TMP1]R76COE        = evalue (TABORI+"R76COE")
    [F:TMP1]ISSDAT        = evalue (TABORI+"ISSDAT")

    For N_PLN = 1 To G301MAX-1
      [F:TMP1]ISSAMT(N_PLN-1) = evalue (TABORI+"ISSAMT("+num$(N_PLN-1)+")")
    Next N_PLN

    #*FQ-67621
    For I_CCE = 1 To GOPTCANA-1
      [F:TMP1]CCE(I_CCE-1) = evalue (TABORI+"CCE("+num$(I_CCE-1)+")")
      [F:TMP1]DIE(I_CCE-1) = evalue (TABORI+"DIE("+num$(I_CCE-1)+")")
    Next I_CCE

    [F:TMP1]DSP     = evalue (TABORI+"DSP")

    [F:TMP1]ISSVATRAT     = evalue (TABORI+"ISSVATRAT")
    [F:TMP1]ISSVATAMT     = evalue (TABORI+"ISSVATAMT")
    [F:TMP1]EXTISSFLG     = evalue (TABORI+"EXTISSFLG")
    [F:TMP1]IVCVATAMT     = evalue (TABORI+"IVCVATAMT")
    [F:TMP1]IVCVATAMTI    = evalue (TABORI+"IVCVATAMTI")
    # FQ 46680
    [F:TMP1]ISSVATTRF     = evalue (TABORI+"ISSVATTRF")
    [F:TMP1]ISSVATTRFI    = evalue (TABORI+"ISSVATTRFI")
    [F:TMP1]DEDCOEF       = evalue (TABORI+"DEDCOEF")
    [F:TMP1]VATRSD        = evalue (TABORI+"VATRSD")
    [F:TMP1]ACGCPLDED     = evalue (TABORI+"ACGCPLDED")
    [F:TMP1]IASCPLDED     = evalue (TABORI+"IASCPLDED")
    [F:TMP1]ACGREVVAT     = evalue (TABORI+"ACGREVVAT")
    [F:TMP1]IASREVVAT     = evalue (TABORI+"IASREVVAT")
    [F:TMP1]DEDVATRAT     = evalue (TABORI+"DEDVATRAT")
    [F:TMP1]DEDVATRATI    = evalue (TABORI+"DEDVATRATI")
    [F:TMP1]DEDVATAMT     = evalue (TABORI+"DEDVATAMT")
    [F:TMP1]VATREGCUM     = evalue (TABORI+"VATREGCUM")
    [F:TMP1]VATREGAMT     = evalue (TABORI+"VATREGAMT")
    # FQ49106
    [F:TMP1]VATREGDED     = evalue (TABORI+"VATREGDED")
    [F:TMP1]VATREGDEDI    = evalue (TABORI+"VATREGDEDI")

    [F:TMP1]VATREGDAT     = evalue (TABORI+"VATREGDAT")
    [F:TMP1]DEDVATAMTI    = evalue (TABORI+"DEDVATAMTI")
    [F:TMP1]IASREGCUM     = evalue (TABORI+"IASREGCUM")
    [F:TMP1]IASVATREG     = evalue (TABORI+"IASVATREG")
    [F:TMP1]THESLI        = evalue (TABORI+"THESLI")
    [F:TMP1]ACGCUR        = evalue (TABORI+"ACGCUR")
    [F:TMP1]IASCUR        = evalue (TABORI+"IASCUR")
    [F:TMP1]IASRATCUR     = evalue (TABORI+"IASRATCUR")
    [F:TMP1]IASCURTYP     = evalue (TABORI+"IASCURTYP")

    [F:TMP1]SALCLSDAT     = evalue (TABORI+"SALCLSDAT")

    If [F:TMP1]SALCLSDAT <> [0/0/0]  #FQ95754_7
      G_SALCLS = G_OUI
    Else
      G_SALCLS = G_NON
    Endif

    [F:TMP1]VALNET        = [F:TML]OBJAMT(0)
    [F:TMP1]ACGBSEVAL     = [F:TML]OBJAMT(1)
    [F:TMP1]IASBSEVAL     = [F:TML]OBJAMT(2)
  Endif
Return

#--------------------------------------------------------------#
# Alimentation des enregistrements de TPF1                     #
#--------------------------------------------------------------#
$CREE_ENR_PLN
  Local Integer I_PLN
  Local Char    W_CPY
  Local Integer CNX
  Local Date    W_CNX_DATE(1..5)
  Local Integer CDRET
  Local    Decimal VALNETTE(1..G301MAX-1) : # Valeurs nettes pour chaque bien par plan
  Local    Date    SORREG  (0..G301MAX-1)
  Local    Date    SORREGT (0..G301MAX-1)
  Local    Date    SORREGI (0..G301MAX-1)
  Local    Integer CODERR

  If !clalev([F:DEPW]) : Local File DEPREC [DEPW] : Endif

  W_CPY    = evalue(TABORI+"CPY")
  W_AASREF = evalue(TABORI+"AASREF")

 #=> Calcul de la valeur nette du BCO
  If [M:FASS]CCLISSFLG=G_NON
    Call CALCULER_VALEURS_SORTIE (TABORI, [M:FASS]ISSTYP, [M:FASS]ISSDAT, VALNETTE, SORREG, SORREGT, SORREGI, CODERR)
    If CODERR
      GOK=0
      Return
    Endif
  Endif

 #=> Création des enregistrements dans la table par plan

  For I_PLN=1 To G301MAX-1
    If func GLOBIENS.CPY_PLN_GERE(W_CPY,I_PLN)=G_OUI
      Raz [TPF1]
      [F:TPF1]CPY       = W_CPY
      [F:TPF1]TRTNUM    = NUMACT
      [F:TPF1]OBJREF    = evalue(TABORI+"AASREF")
      [F:TPF1]DPRPLN    = I_PLN
      [F:TPF1]FLGERR    = 1
      [F:TPF1]FLGMOD    = 1
      #Fq-67621 Call GET_PLN_CUR(W_CPY,I_PLN,[F:TPF1]PLNCUR) From TRTFASISS
      Call GET_PLN_CUR(W_CPY,I_PLN,[F:TPF1]PLNCUR) From TRTFAS
      Call GET_CNX_FROM_PLAN(W_CPY,I_PLN,CNX) From GLOBIENS
      If [M:FASS]CCLISSFLG=G_OUI
        Call GET_CNX_DAT(W_CPY,CNX,W_CNX_DATE,CDRET) From GLOBIENS
        [F:TPF1]FIYENDDAT=W_CNX_DATE(2)
        [F:TPF1]PERENDDAT=W_CNX_DATE(4)
      Else
        Call GET_FIY_PER([M:FASS]ISSDAT,W_CPY,CNX,[F:TPF1]FIYENDDAT,[F:TPF1]PERENDDAT,CDRET) From GLOBIENS
      Endif

      If [M:FASS]CCLISSFLG=G_OUI
        Read[DEPW]DEP0=W_AASREF;I_PLN;[F:TPF1]FIYENDDAT;[F:TPF1]PERENDDAT
        If !fstat
          [F:TPF1]NBV = [F:DEPW]NBV
        Endif
      Else
        [F:TPF1]NBV   = VALNETTE(I_PLN)
      Endif

      Write [TPF1]
      If fstat
        Case fstat
          When 1
            RMES="TMPPLNFAS"-mess(227,GML_MSGFAS,1)    # "Table verrouillée"
            GOK=-1
          When 3
            RMES=mess(129,GML_MSGFAS,1)-num$([F:TPF1]TRTNUM)+"/"+[F:TPF1]OBJREF+"/"+num$([F:TPF1]DPRPLN)
            GOK=0
          When Default
        Endcase
        Break 1
      Else
        NBTMPPLN +=1
      Endif
    Endif
 Next I_PLN
Return

#--------------------------------------------------------------------------------------#
# Génération des événements de sortie pour un bien comptable                           #
#--------------------------------------------------------------------------------------#
Subprog GENERE_EVE_ISS(PCLASSE)
Value Char PCLASSE

 #> Est-ce que le bien est sorti ? Est-ce qu'il s'agit d'une sortie prévisionnelle ou réelle ?
  If [F:MAS1]ISSDAT=[0/0/0]  : End : Endif
  If [F:MAS1]EXTISSFLG=G_OUI : End : Endif

 #> la classe [F:FASZ] est la classe utilisée dans l'alimentation des événements
  If !clalev([FASZ]) : Local File FXDASSETS [FASZ] : Endif

  Case PCLASSE
    When "[F:MAS1]" : [F:FASZ] = [F:MAS1]
    When "[F:MAS2]" : [F:FASZ] = [F:MAS2]
    When Default
  Endcase

  [F:FASZ]IVCSALISS = G_WNUMBIC

 #> Génération des événements de sortie :
 #  -----------------------------------
  Local Integer I_CNX
  Local Integer I_PLN
  Local Integer L_PERC, L_PERS
  Local Integer NBEVT
  Local Integer EXISTISSEVT
  Local Integer TRTEVT
  Local Char    EVTINT
  Local Date    CNXDAT(1..5)
  Local Date    ISSFIYENDDAT
  Local Date    ISSPERENDDAT
  Local Date    DATE_EFFET
  Local Integer CODERR
  Local Integer INDICE_PLN

  Global Decimal CPLDED, REVVAT : # Déduction de TVA complémentaire ou reversement, PCG ou IAS en fonction du plan
  Global Decimal GISSRATCUR

 #> Les classes [M:Pxxx] contiennent les DEPREC du plan xxx (CPT, FIS, ...) suite à l'appel de CALCULER_VALEURS_SORTIE

  For [CNX] Where CPY=[F:FASZ]CPY

    Call GET_CNX_DAT([F:CNX]CPY,[F:CNX]CNX,CNXDAT,CODERR) From GLOBIENS

    For INDICE_PLN=1 To [F:CNX]NBPLC
      I_PLN = [F:CNX]PLNCAA(INDICE_PLN-1)

      GOK=1 : TRTEVT=G_OUI

      EVTINT="FASISS"+num$(I_PLN)

      # Récupération du masque du plan dans [M:DEP]
      Case I_PLN
        When G301CPT  : Transmask [M:PCPT] To [M:DEP]
        When G301FIS  : Transmask [M:PFIS] To [M:DEP]
        When G301MIN  : Transmask [M:PMIN] To [M:DEP]
        When G301ORI  : Transmask [M:PORI] To [M:DEP]
        When G301R76  : Transmask [M:PR76] To [M:DEP]
        When G301IAS  : Transmask [M:PIAS] To [M:DEP]
        When G301TEC  : Transmask [M:PTEC] To [M:DEP]
        When G301RET  : Transmask [M:PRET] To [M:DEP]
        When G301SUB  : Transmask [M:PSUB] To [M:DEP]
        When G301LI1  : Transmask [M:PLI1] To [M:DEP]
        When G301LI2  : Transmask [M:PLI2] To [M:DEP]
        When G301LI3  : Transmask [M:PLI3] To [M:DEP]
        When G301LI4  : Transmask [M:PLI4] To [M:DEP]
        When G301LI5  : Transmask [M:PLI5] To [M:DEP]
        When G301LI6  : Transmask [M:PLI6] To [M:DEP]
      Endcase

      # Recherche de la ligne correspondant à la période courante
      L_PERC = find(CNXDAT(4),[M:DEP]PERENDDAT)
      If !L_PERC : GOK=0 : Break : Endif
      nolign   = L_PERC
      [F:DEPC] = [M:DEP]

      # Recherche de la ligne correspondant à la période de sortie
      Call GET_FIY_PER([F:FASZ]ISSDAT,[F:FASZ]CPY,[F:CNX]CNX,ISSFIYENDDAT,ISSPERENDDAT,CODERR) From GLOBIENS
      If CODERR : GOK=0 : Break : Endif

      L_PERS = find(ISSPERENDDAT,[M:DEP]PERENDDAT)
      If !L_PERS Then
        [F:DEPS] = [F:DEPC]
      Else
        nolign   = L_PERS
        [F:DEPS] = [M:DEP]
      Endif

      # Période de sortie antérieure à la période courante SRA : on garde la période courante
      If [F:DEPS]PERENDDAT<[F:DEPC]PERENDDAT
        [F:DEPS]=[F:DEPC]
      Endif
      # Période de sortie postérieure à la période courante : on garde la période de sortie
      If [F:DEPS]PERENDDAT>[F:DEPC]PERENDDAT
        [F:DEPC]=[F:DEPS]
      Endif

      # Particularités par plan
      If [F:CNX]ORIBASDPR(INDICE_PLN-1) = GVML_OBIAS Then
        CPLDED = [F:FASZ]IASCPLDED
        REVVAT = [F:FASZ]IASREVVAT
      Else
        CPLDED = [F:FASZ]ACGCPLDED
        REVVAT = [F:FASZ]ACGREVVAT
      Endif

      DATE_EFFET = max([F:FASZ]ISSDAT,CNXDAT(3))

      # FQ46680 Nouvelles règles TVA 2008
      If ( [F:DEPS]DPRPLN = G301CPT ) Then

        # FQ46680 Ecriture historique TVA
        If clalev([F:HIS]) = 0  : Local File VATHIS [HIS] : Endif
        Local Char    LTIMSTP1, LTIMSTP2
        Local Integer LCDRET

        # Ecriture Sortie dans HISVAT ( PCG )
        If !(clalev([F:HFAS]))  : Local File FXDASSETS [HFAS]  : Endif
        [F:HFAS] = [F:FASZ]
        [F:HFAS]VATREGDAT =  date$

        Local  Integer LTYPREG

        Local  Char LFORMPCG(50)
        If ( [F:HFAS]ACGCPLDED <> 0 ) Then
          LFORMPCG = "(1 -" - format$('N:'+GFMT3, [F:HFAS]DEDCOEF) - ")*" - format$('N:'+GFMT3, [F:HFAS]IVCVATAMT) -
&                    "*(" - num$([F:HFAS]VATRSD) - "/"  - num$([F:HFAS]THESLI) - ")"
        Endif
        If ( [F:HFAS]ACGREVVAT <> 0 ) Then
          LFORMPCG = "(0 -" - format$('N:'+GFMT3, [F:HFAS]DEDCOEF) - ")*" - format$('N:'+GFMT3, [F:HFAS]IVCVATAMT) -
&                    "*(" - num$([F:HFAS]VATRSD) - "/"  - num$([F:HFAS]THESLI) - ")"
        Endif
        If ( [F:FASZ]ISSVATRAT <> 0 ) Then : LTYPREG = GVML_TRSORST : Else  : LTYPREG = GVML_TRSORNT : Endif
        Call TVA_ECR_HISTORIQUE (LTYPREG, G301CPT, [F:DEPS]BSEVAL, [F:DEPS]BSEVAL, LFORMPCG, LCDRET) From TRTFAS
        If (LCDRET) Then : RERROR = 99 : Break : Endif :   # Erreur écriture dans l'historique
      Endif

      If ([F:DEPS]DPRPLN=G301IAS) Then
        # FQ46680 Ecriture historique TVA

        # Ecriture Sortie dans HISVAT ( PCG )
        If !(clalev([F:HFAS]))  : Local File FXDASSETS [HFAS]  : Endif
        [F:HFAS] = [F:FASZ]

        Local Integer LCDRET
        Local Integer LTYPREG
        Local  Char LFORMIAS(50)
        If ( [F:HFAS]IASCPLDED <> 0 ) Then
          LFORMIAS = "(1 -" - format$('N:'+GFMT3, [F:HFAS]DEDCOEF) - ")*" - format$('N:'+GFMT3, [F:HFAS]IVCVATAMTI) -
&                    "*(" - num$([F:HFAS]VATRSD) - "/"  - num$([F:HFAS]THESLI) - ")"
        Endif
        If ( [F:HFAS]IASREVVAT <> 0 ) Then
          LFORMIAS = "(0 -" - format$('N:'+GFMT3, [F:HFAS]DEDCOEF) - ")*" - format$('N:'+GFMT3, [F:HFAS]IVCVATAMTI) -
&                    "*(" - num$([F:HFAS]VATRSD) - "/"  - num$([F:HFAS]THESLI) - ")"
        Endif
        If ( [F:FASZ]ISSVATRAT <> 0 ) Then : LTYPREG = GVML_TRSORST : Else  : LTYPREG = GVML_TRSORNT : Endif
        Call TVA_ECR_HISTORIQUE (LTYPREG, G301IAS, [F:DEPS]BSEVAL, [F:DEPS]BSEVAL, LFORMIAS, LCDRET) From TRTFAS
        If (LCDRET) Then : RERROR = 99 : Break : Endif :   # Erreur écriture dans l'historique
      Endif
      # FQ46680 Nouvelles règles TVA 2008

      G_SORREG   = G_TBSORREG  (I_PLN-1)
      G_SORREGT  = G_TBSORREGT (I_PLN-1)
      G_SORREGI  = G_TBSORREGI (I_PLN-1)
      # Génération d'événement
      Call GENER_EVE(GVML_OMBIEN,
&                    [F:FASZ]CPY,
&                    [F:FASZ]FCY,
&                    [F:FASZ]AASREF,
&                    0,
&                    EVTINT,
&                    [F:FASZ]ISSDAT,
&                    DATE_EFFET,
&                    CODERR) From GENEVE

      If CODERR>13
        GOK=0
        # Erreur lors de la génération d'événement
        GMESSAGE=mess(101,7771,1)
        End
      Else
        NBEVT+=1
      Endif
    Next
  Next

  #*FQ95754_7 Annulation de classement pour vente : extourne événements de classement pour vente
  If [F:FASZ]SALCLSDAT <> [0/0/0] or G_SALCLS = G_OUI
    Local Integer I_PLAN
    Local Date    EVTDAT
    If !clalev([F:EVT0])
      Local File EFASCFS [EVT0]
    Else
      Close Local File [EVT0] : Local File EFASCFS [EVT0]
    Endif
    If !clalev([F:EVT1])
      Local File EFASCFS [EVT1]
    Else
      Close Local File [EVT1] : Local File EFASCFS [EVT1]
    Endif
    For I_PLAN=1 To G301MAX-1
      LCDINT="FASCFS"+num$(I_PLAN)
      Filter [F:EVT0] Where (CPY=[F:FASZ]CPY & DPRPLN=I_PLAN & REF=[F:FASZ]AASREF & SNSEVE<>GVML_TEAACT)
      Read [F:EVT0]EVE0 Last
      If !fstat
        If func GENEVE.EXISTE_EXTOURNE_EVE(LCDRET)=G_NON
          EVTDAT=[F:EVT0]EVTDAT
          Call EXTOURNE_EVE(GVML_OMBIEN,[F:FASZ]CPY,[F:FASZ]FCY,[F:FASZ]AASREF,0,LCDINT,EVTDAT,LCDRET) From GENEVE
        Endif
      Endif
      Filter [EVT0]
    Next # I_PLAN

  Case PCLASSE
    When "[F:MAS1]"
      [F:MAS1]SALCLSDAT  =  [0/0/0]
      [F:MAS1]EXTSALAMT  =  0
    When "[F:MAS2]"
      [F:MAS2]SALCLSDAT  =  [0/0/0]
      [F:MAS2]EXTSALAMT  =  0
    When Default
  Endcase
  Endif  #*FQ95754_7 END

  Kill CPLDED, REVVAT
  Kill GISSRATCUR
End

#--------------------------------------------------------------------------------------#
# Génération des événements de sortie pour un bien comptable                           #
#--------------------------------------------------------------------------------------#
Subprog GENERE_EVE_CCNISS(PCLASSE)
Value Char PCLASSE

 #> Est-ce que le bien est sorti ? Est-ce qu'il s'agit d'une sortie prévisionnelle ou réelle ?
  If [F:MAS1]ISSDAT=[0/0/0]  : End : Endif
  If [F:MAS1]EXTISSFLG=G_OUI : End : Endif

 #> la classe [F:FASZ] est la classe utilisée dans l'alimentation des événements
  If !clalev([FASZ]) : Local File FXDASSETS [FASZ] : Endif

  Case PCLASSE
    When "[F:MAS1]" : [F:FASZ] = [F:MAS1]
    When "[F:MAS2]" : [F:FASZ] = [F:MAS2]
    When Default
  Endcase

 #> Génération des événements de sortie :
 #  -----------------------------------
  Local Integer I_CNX
  Local Integer I_PLN
  Local Integer L_PERC, L_PERS
  Local Integer NBEVT
  Local Integer EXISTISSEVT
  Local Integer TRTEVT
  Local Char    EVTINT
  Local Date    CNXDAT(1..5)
  Local Date    ISSFIYENDDAT
  Local Date    ISSPERENDDAT
  Local Date    DATE_EFFET
  Local Integer CODERR
  Local Integer INDICE_PLN

  Global Decimal CPLDED, REVVAT : # Déduction de TVA complémentaire ou reversement, PCG ou IAS en fonction du plan
  Global Decimal GISSRATCUR

 #> Les classes [M:Pxxx] contiennent les DEPREC du plan xxx (CPT, FIS, ...) suite à l'appel de CALCULER_VALEURS_SORTIE

  Read [F:CNX]CNX0=[F:FASZ]CPY;G300CPFI
  If fstat
   End
  Endif
  Call GET_CNX_DAT([F:CNX]CPY,[F:CNX]CNX,CNXDAT,CODERR) From GLOBIENS

  # Recherche de la ligne correspondant à la période courante
  L_PERC = find(CNXDAT(4),[M:PRPR]PERENDDAT)
  If !L_PERC : GOK=0 : Endif
  nolign   = L_PERC
  [F:RPRC] = [M:PRPR]

  # Recherche de la ligne correspondant à la période de sortie
  Call GET_FIY_PER([F:FASZ]ISSDAT,[F:FASZ]CPY,[F:CNX]CNX,ISSFIYENDDAT,ISSPERENDDAT,CODERR) From GLOBIENS
  If CODERR : GOK=0 : Endif

  L_PERS = find(ISSPERENDDAT,[M:PRPR]PERENDDAT)
  If !L_PERS Then
   [F:RPRS] = [F:RPRC]
  Else
   nolign   = L_PERS
   [F:RPRS] = [M:PRPR]
  Endif

  # Période de sortie antérieure à la période courante SRA : on garde la période courante
  If [F:RPRS]PERENDDAT<[F:RPRC]PERENDDAT
   [F:RPRS]=[F:RPRC]
  Endif
  # Période de sortie postérieure à la période courante : on garde la période de sortie
  If [F:RPRS]PERENDDAT>[F:RPRC]PERENDDAT
   [F:RPRC]=[F:RPRS]
  Endif

  DATE_EFFET = max([F:FASZ]ISSDAT,CNXDAT(3))
  EVTINT     = "FASCCNISS"

      # Génération d'événement
      Call GENER_EVE(GVML_OMBIEN,
&                    [F:FASZ]CPY,
&                    [F:FASZ]FCY,
&                    [F:FASZ]AASREF,
&                    0,
&                    EVTINT,
&                    [F:FASZ]ISSDAT,
&                    DATE_EFFET,
&                    CODERR) From GENEVE

      If CODERR>13
        GOK=0
        # Erreur lors de la génération d'événement
        GMESSAGE=mess(101,401,1)
      Else
        NBEVT+=1
      Endif
End

#--------------------------------------------------------------#
# Annulation des événements de sortie s'ils existent ...       #
#--------------------------------------------------------------#
$ANNULE_EVE_ISS
  Local Integer I_PLN       # Indice parcours des plans d'amortissement
  Local Integer RETOUR      # Code retour des s/p
  Local Integer NBCCLEVT    # Nombre d'événements annulés
  Local Char    WK_EVTINT   # Code interne des événements de sortie.

  If !clalev([F:EVT0])
   Local File EFASISS [EVT0]
  Else
   If dim([F:EVT0]ISSTYP)<0 | (dim([F:EVT0]ISSTYP)>0 & dim([F:EVT0]ISSAMT)<0) #Fq67163
    Close Local File [EVT0] : Local File EFASISS [EVT0]
   Endif
  Endif

  If !clalev([F:EVT1])
   Local File EFASISS [EVT1]
  Else
   If dim([F:EVT1]ISSTYP)<0 | (dim([F:EVT1]ISSTYP)>0 & dim([F:EVT1]ISSAMT)<0) #Fq67163
    Close Local File [EVT1] : Local File EFASISS [EVT1]
   Endif
  Endif

  For I_PLN=1 To G301MAX-1
    If func GLOBIENS.CPY_PLN_GERE(WK_CPY,I_PLN)=G_OUI
      WK_EVTINT="FASISS"+num$(I_PLN)
      Filter [F:EVT0] Where (CPY=WK_CPY & DPRPLN=I_PLN & REF=WK_AASREF & EVTDAT=WK_ISSDAT & SNSEVE<>GVML_TEAACT)
      Read [F:EVT0]EVE0 Last
      If !fstat
        If func GENEVE.EXISTE_EXTOURNE_EVE(RETOUR)=G_NON

          # FQ 46680 Nouvelles TVA 2008
          If (I_PLN = G301CPT) Then
            # Ecriture historique TVA
            # Recherche d'une éventuelle sortie à annuler
            If clalev([F:HIS]) = 0  : Local File VATHIS [HIS] : Endif
            Local Char    LTIMSTP1, LTIMSTP2
            Local Integer LCDRET

            # Recherche de l'existence d'une annulation de sortie dans l'exercice
            Filter [HIS] Where AASREF=WK_AASREF and DPRPLN = G301CPT and VATREGTYP = GVML_TRANSOR  and
&                        DATVATREG >= GDEBEXECPF and DATVATREG <= GFINEXECPF
            If (rowcount([F:HIS]) <> 0 ) Then
              Read [HIS]VAT1 Last
              Filter [HIS] : LTIMSTP1 = [F:HIS]TIMSTP
            Else
              Filter [HIS] : LTIMSTP1 = ""
            Endif
            # Recherche de la dernière sortie dans l'exercice
            Filter [HIS] Where AASREF=WK_AASREF and DPRPLN = G301CPT and ( VATREGTYP = GVML_TRSORST or VATREGTYP = GVML_TRSORNT ) and
&                              DATVATREG >= GDEBEXECPF and DATVATREG <= GFINEXECPF
            If (rowcount([F:HIS]) <> 0 ) Then
              Read [HIS]VAT1 Last
              Filter [HIS]  : LTIMSTP2 = [F:HIS]TIMSTP
            Else
              Filter [HIS]  : LTIMSTP2 = ""
            Endif
            If ( LTIMSTP1 > LTIMSTP2 or ( LTIMSTP1 = "" and LTIMSTP2 = "" ) ) Then
              # Pas d'annulation de sortie a effectué
            Else
              # Annulation de la sortie précédente
              [F:HIS]VATREGTYP =  GVML_TRANSOR
              [F:HIS]VATREGAMT = -[F:HIS]VATREGAMT
              [F:HIS]VATREGDED = -[F:HIS]VATREGDED
              [F:HIS]BASDEV    = 0
              [F:HIS]FORMULE   = ""
              [F:HIS]TIMSTP    = func GENEVE.BUILD_TIMSTP(date$, time)
              Write [HIS]
            Endif
          Endif

          If (I_PLN = G301IAS) Then
            # Ecriture historique TVA
            # Recherche d'une éventuelle sortie à annuler

            # Recherche de l'exitence d'une annulation de sortie dans l'exercice
            Filter [HIS] Where AASREF=WK_AASREF and DPRPLN = G301IAS and VATREGTYP = GVML_TRANSOR and
&                           DATVATREG >= GDEBEXECPF and DATVATREG <= GFINEXECPF
            If (rowcount([F:HIS]) <> 0 ) Then
              Read [HIS]VAT1 Last
              Filter [HIS] : LTIMSTP1 = [F:HIS]TIMSTP
            Else
              Filter [HIS] : LTIMSTP1 = ""
            Endif
            # Recherche de la dernière sortie dans l'exercice
            Filter [HIS] Where AASREF=WK_AASREF and DPRPLN = G301IAS and ( VATREGTYP = GVML_TRSORST or VATREGTYP = GVML_TRSORNT ) and
&                              DATVATREG >= GDEBEXEIAS and DATVATREG <= GFINEXEIAS
            If (rowcount([F:HIS]) <> 0 ) Then
              Read [HIS]VAT1 Last
              Filter [HIS]  : LTIMSTP2 = [F:HIS]TIMSTP
            Else
              Filter [HIS]  : LTIMSTP2 = ""
            Endif
            If ( LTIMSTP1 > LTIMSTP2 or ( LTIMSTP1 = "" and LTIMSTP2 = "" ) ) Then
              # Pas d'annulation de sortie a effectué
            Else
              # Annulation de la sortie précédente
              [F:HIS]VATREGTYP =  GVML_TRANSOR
              [F:HIS]VATREGAMT = -[F:HIS]VATREGAMT
              [F:HIS]VATREGDED = -[F:HIS]VATREGDED
              [F:HIS]BASDEV    = 0
              [F:HIS]FORMULE   = ""
              [F:HIS]TIMSTP    = func GENEVE.BUILD_TIMSTP(date$, time)
              Write [HIS]
            Endif
          Endif
          # FQ 46680 Nouvelles TVA 2008

          Call EXTOURNE_EVE(GVML_OMBIEN,WK_CPY,WK_FCY,WK_AASREF,0,WK_EVTINT,WK_ISSDAT,RETOUR) From GENEVE
          If RETOUR
          Else
            NBCCLEVT+=1
          Endif
        Endif
      Else
        If fstat>0 & fstat<4
          Break
          GOK=0
        Endif
      Endif
    Endif
  Next I_PLN
  Filter [EVT0]
Return

#--------------------------------------------------------------#
# Annulation des événements de sortie / provisions
# s'ils existent ...
#--------------------------------------------------------------#
$ANNULE_EVE_CCNISS
  Local Integer RETOUR      # Code retour des s/p
  Local Integer NBCCLEVT    # Nombre d'événements annulés
  Local Char    WK_EVTINT   # Code interne des événements de sortie.

  If !clalev([F:EVT0])
   Local File EFASCCNISS [EVT0]
  Else
   If (dim([F:EVT0]ISSTYP)>0 & dim([F:EVT0]PSTACGRPR)<0) | dim([F:EVT0]ISSTYP)<0 #Fq67163
    Close Local File [EVT0] : Local File EFASCCNISS [EVT0]
   Endif
  Endif

  If !clalev([F:EVT1])
   Local File EFASCCNISS [EVT1]
  Else
   If (dim([F:EVT1]ISSTYP)>0 & dim([F:EVT1]PSTACGRPR)<0)| dim([F:EVT1]ISSTYP)<0 #Fq67163
    Close Local File [EVT1] : Local File EFASCCNISS [EVT1]
   Endif
  Endif

  If func GLOBIENS.CPY_PLN_GERE(WK_CPY,G301CPT)=G_OUI
    WK_EVTINT="FASCCNISS"
    Filter [F:EVT0] Where (CPY=WK_CPY & FCY=WK_FCY & DPRPLN=G301AUC & REF=WK_AASREF & EVTDAT=WK_ISSDAT & SNSEVE<>GVML_TEAACT)
    Read [F:EVT0]EVE0 Last
    If !fstat
      If func GENEVE.EXISTE_EXTOURNE_EVE(RETOUR)=G_NON
        Call EXTOURNE_EVE(GVML_OMBIEN,WK_CPY,WK_FCY,WK_AASREF,0,WK_EVTINT,WK_ISSDAT,RETOUR) From GENEVE
        If RETOUR
        Else
          NBCCLEVT+=1
        Endif
      Endif
    Else
      If fstat>0 & fstat<4
        GOK=0
      Endif
    Endif
  Endif
  Filter [EVT0]
Return

##########################################################################
# Gestion du masque FASISSP [M:FASS] - Masque paramètres de la sortie
##########################################################################
#{MASQUE}#
########################################################################## Sortie / annulation de sortie
Subprog AM_CCLISSFLG(VALEUR)
Variable Integer VALEUR

  If VALEUR=G_OUI
     If ACTTYPGES=GTAMMAS
        Effzo [M:FASS]ISSCMPFLG  : Grizo [M:FASS]ISSCMPFLG
        Effzo [M:FASS]IMLFLG     : Grizo [M:FASS]IMLFLG
        Effzo [M:FASS]ISSDAT     : Grizo [M:FASS]ISSDAT
        Effzo [M:FASS]EXTISSFLG  : Grizo [M:FASS]EXTISSFLG
        Effzo [M:FASS]ISSTYP     : Grizo [M:FASS]ISSTYP
        Effzo [M:FASS]ISSDATRUL  : Grizo [M:FASS]ISSDATRUL
        Effzo [M:FASS]R76COE     : Grizo [M:FASS]R76COE
        Effzo [M:FASS]ISSAMTTYP  : Grizo [M:FASS]ISSAMTTYP
        Effzo [M:FASS]VALPLN     : Grizo [M:FASS]VALPLN
        Effzo [M:FASS]ISSAMT     : Grizo [M:FASS]ISSAMT
        Effzo [M:FASS]BRDTYP     : Grizo [M:FASS]BRDTYP
        Effzo [M:FASS]BRDPLN     : Grizo [M:FASS]BRDPLN
        Effzo [M:FASS]PYBVATTYP  : Grizo [M:FASS]PYBVATTYP
        Effzo [M:FASS]ISSVATRAT  : Grizo [M:FASS]ISSVATRAT
        Effzo [M:FASS]BUY        : Grizo [M:FASS]BUY
        Effzo [M:FASS]BPRSAC     : Grizo [M:FASS]BPRSAC
        Effzo [M:FASS]SACACC     : Grizo [M:FASS]SACACC
        Effzo [M:FASS]IVCSALISS  : Grizo [M:FASS]IVCSALISS
        If GPHY = G_OUI
          Effzo [M:FASS]ECRPHYATT  : Grizo [M:FASS]ECRPHYATT
        Endif
        # FQ67624
        #*Fq-67621 Effzo [M:FASS]VAT     : Grizo [M:FASS]VAT
        #*Fq-67621 Effzo [M:FASS]SIVTYP  : Grizo [M:FASS]SIVTYP
        Grizo [M:FASS]VAT
        Grizo [M:FASS]SIVTYP
     Else
        [M:FASS]= [M:FAS4]
        Affzo [M:FASS]
     Endif
  Else
     Actzo [M:FASS]ISSCMPFLG
     Actzo [M:FASS]IMLFLG
     Actzo [M:FASS]ISSDAT
     Actzo [M:FASS]ISSTYP
     Actzo [M:FASS]ISSDATRUL
     Actzo [M:FASS]R76COE
     Actzo [M:FASS]EXTISSFLG
     Actzo [M:FASS]ISSAMTTYP
     Actzo [M:FASS]VALPLN
     Actzo [M:FASS]ISSAMT
     Actzo [M:FASS]BRDTYP
     Actzo [M:FASS]BRDPLN
     Actzo [M:FASS]PYBVATTYP
     Actzo [M:FASS]ISSVATRAT
     Actzo [M:FASS]BUY
     If G_SALINV <> G_OUI  #Fq-67621 pas de facture de vente générée
        Actzo [M:FASS]IVCSALISS : Affzo [M:FASS]IVCSALISS
        Diszo [M:FASS]SIVTYP
        Diszo [M:FASS]BPRSAC
        Diszo [M:FASS]SACACC
     Else
        Effzo [M:FASS]IVCSALISS  : Grizo [M:FASS]IVCSALISS
     Endif
     If GPHY = G_OUI
        Actzo [M:FASS]ECRPHYATT
      Endif
      # FQ67624
      Actzo [M:FASS]VAT
      Actzo [M:FASS]SIVTYP
    Endif

    Affzo [M:FASS]

End

########################################################################## Sortie prévisionnelle
Subprog AM_EXTISSFLG(VALEUR)
Variable Integer VALEUR

  Local Char CPYREF
  If !clalev([F:CNX]) : Local File CONTEXT  [CNX] : Endif
  If !clalev([F:FIS]) : Local File FISCYEAR [FIS] : Endif

 # La date de sortie doit être >= au debut de l'exercice courant de chaque contexte
 # ayant au moins un plan géré

  Case ACTTYPGES
    When GTAMMAS : CPYREF = [M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1)
    When GTAMUNI : CPYREF = [M:FAS0]CPY
    When Default
  Endcase

 # Si la sortie est réelle, la date de sortie doit être <= à la date de fin d'exercice
 # de chaque contexte géré dans la société de référence

  If ( [M:FASS]ISSDAT <> [0/0/0] & VALEUR=G_NON) Then
    Local Integer  NBPLAN
    For [CNX] Where CPY= CPYREF
      Filter [FIS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY=GVML_TESUIV # Exercice suivant
      Read [FIS]FIY0 Last
      Filter [FIS]
      If ( [M:FASS]ISSDAT > [F:FIS]DATENDFIY ) Then
        GERR= 1: GMESSAGE = mess(238,GML_MSGFAS,1)
        zonsui = "ISSDAT"
      Endif
    Next
  Endif
End

########################################################################## Date de sortie
Subprog C_ISSDAT(VALEUR)
Variable Date    VALEUR

  Local Integer  NBPLAN

###-> Contrôle unitaire

  If ACTTYPGES=GTAMUNI
    Local Shortint NOL
    [L]NOL = [M:FAS0]FISLIG

   # Si le bien est déjà sorti , il ne peut subir qu'une annulation de sortie.
    If ([M:FAS4]ISSDAT <> [0/0/0] and VALEUR  <> [0/0/0] and [M:FAS4]EXTISSFLG = G_NON) Then
      GERR= 1: GMESSAGE = mess(48,GML_MSGFAS,1)
      mkstat = 2 : End
    Endif

   # La date de sortie doit être >= à la date d'achat
    If (VALEUR <> [0/0/0] and VALEUR < [M:FAS1]PURDAT ) Then
      GERR= 1: GMESSAGE = mess(31,GML_MSGFAS,1)
      mkstat = 2 : End
    Endif

    # FQ59066
    # La date de sortie doit être >= à la date d'achat des biens composants si le bien est principal et si l'indicateur "Sortie des biens
    # composants" à Oui
    If (VALEUR <> [0/0/0] and [M:FASS]ISSCMPFLG = G_OUI and [M:FAS1]CMPSTA = GVML_SBPRINC) Then
      For [F:WFAS]FAS5 Where CMP=[M:FAS0]AASREF and PURDAT>VALEUR
        # La date de sortie doit être au moins égale à la date d'achat des biens composants de ce bien
        GERR= 1: GMESSAGE = mess(793,GML_MSGFAS,1)
        mkstat = 2
        Break
      Next
      If GERR=1 : End : Endif
    Endif

   # La date de sortie doit être >= à la date de début d'amt du plan fiscal
   # FQ47616 sauf si le bien est en cours.
   #If (VALEUR <> [0/0/0] and VALEUR < [M:FAS3]STRDPRDAT ([L]NOL-1) ) Then # FQ47616
   If  (VALEUR <> [0/0/0] and VALEUR < [M:FAS3]STRDPRDAT ([L]NOL-1) ) and ([M:FAS1]GACACN = GVML_NIENSER) Then
      GERR= 1: GMESSAGE = mess(30,GML_MSGFAS,1)
      mkstat = 2 : End
    Endif
  Endif


 ###-> Contrôle massif et unitaire

  Local Char    CPYREF
  Local Char    CPYLEG     # Législation de la société
  Local Integer RURAIEXC   # Exception à la règle de contrôle SRA pour les sociétés de législation russe.
  Local Date    LDATREFCTL # Date de référence du contrôle

  If !clalev([F:CNX]) : Local File CONTEXT  [CNX] : Endif
  If !clalev([F:FIS]) : Local File FISCYEAR [FIS] : Endif

 # La date de sortie doit être >= au debut de l'exercice courant de chaque contexte
 # ayant au moins un plan géré

  Case ACTTYPGES
    When GTAMMAS : CPYREF = [M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1)
    When GTAMUNI : CPYREF = [M:FAS0]CPY
    When Default
  Endcase

  If ( VALEUR <> [0/0/0] ) Then
    CPYLEG   = func GLOFCYCPY.GET_SOC_LEG(CPYREF)
    RURAIEXC = G_NON #A remplacer par un appel à une valeur paramètre
    For [CNX] Where CPY= CPYREF
      Filter [FIS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY=GVML_TECOURA # Exercice courant
      Read [FIS]FIY0 Last
      Filter [FIS]
      #Fq67508-Contrôle de la date par rapport au début exercice ou début de période si LEG=RUS et pas de désactivation du contrôle
      If CPYLEG="RUS" & RURAIEXC<>G_OUI
       LDATREFCTL=[F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
       GMESSAGE = mess(813,GML_MSGFAS,1)
      Else
       LDATREFCTL=[F:FIS]DATSTRFIY
       GMESSAGE = mess(32,GML_MSGFAS,1)
      Endif
      If ( VALEUR < LDATREFCTL ) Then
        GERR= 1
        mkstat = 2
        End #CHECK IGNORE_LINE
      Else
       Raz GMESSAGE
      Endif
    Next
  Endif

 # Si la sortie est réelle, la date de sortie doit être <= à la date de fin d'exercice
 # de chaque contexte géré dans la société de référence
  If ( VALEUR <> [0/0/0] & [M:FASS]EXTISSFLG=G_NON) Then
    For [CNX] Where CPY= CPYREF
      Filter [FIS] Where CPY=[F:CNX]CPY and CNX=[F:CNX]CNX and STAFIY=GVML_TESUIV # Exercice suivant
      Read [FIS]FIY0 Last
      Filter [FIS]
      If ( VALEUR > [F:FIS]DATENDFIY ) Then
        GERR= 1: GMESSAGE = mess(238,GML_MSGFAS,1)
        mkstat = 2
        End
      Endif
    Next
  Endif

  If ( VALEUR <> [0/0/0] & [M:FASS]EXTISSFLG=G_NON) Then
    If VALEUR<[F:FAS]TRFDAT Then
      GERR= 1: GMESSAGE = mess(676,GML_MSGFAS,1)-num$([F:FAS]TRFDAT)
      mkstat = 2 : End
    Endif
  Endif
End

########################################################################## Date de sortie
Subprog AM_ISSDAT(VALEUR)
Variable Date    VALEUR

###-> Contrôle massif et unitaire

  # Demande de confirmation si date de sortie > à la date de fin d'exercice courant
  # du contexte fiscal & comptable

  Local Date DTSOBC
  Local Integer EXTISS, ERR, OK
  Local Char    CPYREF

  DTSOBC = VALEUR
  EXTISS = [M:FASS]EXTISSFLG

  Case ACTTYPGES
    When GTAMMAS : CPYREF = [M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1)
    When GTAMUNI : CPYREF=[M:FAS0]CPY
    When Default
  Endcase

  # Issue X3-74074
  If (ACTTYPGES = GTAMUNI) Then
    If func TRTFASISS2.SBV_ISSUE_CHECK(VALEUR, [M:FAS0]AASREF) = [V]CST_ANO
      GERR=1 : GMESSAGE=mess(29,GML_MSGFAS,1)
    Endif
  Endif

  #*Fq-67621 Call CONTROLE_DATE_SORTIE( CPYREF, DTSOBC, EXTISS, ERR ) From TRTFAS
  Call CONTROLE_DATE_SORTIE( CPYREF, DTSOBC, EXTISS, ERR ) From TRTFAS

  If ([L]ERR) Then
    Case [L]ERR
      When 1
        Call OUINON(mess(51,GML_MSGFAS,1), OK) From GESECRAN
        If ( OK = 1) Then : mkstat = 2 : End : Endif
      When 11
        If ACTTYPGES=GTAMUNI
          Local Integer CDRET
          Call CTRL_SRA(CPYREF, [M:FAS0]AASREF, DTSOBC, CDRET) From TRTFAS
          If CDRET
            If G_ACTKPL=G_OUI
             GERR=1 : GMESSAGE=mess(495,GML_MSGFAS,1)+":"+mess(839,GML_MSGFAS,1) # "SORTIE rétroactive impossible : bien déprécié et/ou réévalué et/ou modernisé"
            Else
             GERR=1 : GMESSAGE=mess(495,GML_MSGFAS,1)+":"+mess(513,GML_MSGFAS,1) # "SORTIE rétroactive impossible : bien déprécié et/ou réévalué"
            Endif
            mkstat=2 : End
          Endif
        Endif
    Endcase
  Endif

  # Mise à jour des taux des contextes
  Local Shortint N_C
  For N_C = 0 To [M:FASS]NB_CNX-1
    Call CDVCAL( [M:FASS]RATCURCNX(N_C), [M:FASS]CURCNX(N_C), [M:FASS]CURCNX(0), [M:FASS]ISSCPY,
&                [M:FASS]CURTYPCNX(N_C), [M:FASS]ISSDAT  ) From TRTDIV
    Affzo [M:FASS]RATCURCNX(N_C)
  Next N_C
End

########################################################################## Type de sortie
Subprog AS_ISSTYP(VALEUR)
Variable Integer  VALEUR

###-> Initialisation massif et unitaire

  # tous type de détention  pas accès aux motifs de sortie ci-dessous :
  GMENLOC(GVML_TSCIG)   =1 # Cession intra groupe
  GMENLOC(GVML_TSAPPOR) =1 # Apport partiel d'actif
  GMENLOC(GVML_TSFUSIO) =1 # Fusion
  GMENLOC(GVML_TSSCISS) =1 # Scission
  GMENLOC(GVML_TSRENEW)  =1 # Renouvellement FQ54343
  GMENLOC(GVML_TSFCONC)  =1 # Renouvellement FQ54343

###-> Initialisation unitaire

  If ACTTYPGES=GTAMUNI

    Case [M:FAS1]OWNTYP

      When GVML_TDPROPR
      # type de détention "En propriété"
        GMENLOC(GVML_TSFCONT) =1 # Fin de contrat crédit bail
        GMENLOC(GVML_TSFCLOC) =1 # Fin de contrat location
        GMENLOC(GVML_TSCRESI) =1 # Contrat résilié
        GMENLOC(GVML_TSREPRI) =1 # Bien repris

      #  - Bien avec motif de détention "En crédit Bail" :
      #     Motif de sortie valable :
      #           a - Bien repris
      #           b - Fin de contrat de crédit bail si le BCO est rattaché à un contrat de crédit bail
      #           c - Résiliation de contrat de crédit bail si le BCO est rattaché à un contrat de crédit bail
      When GVML_TDCBAIL
      # type de détention "En crédit bail"
        GMENLOC(GVML_TSVENTE) =1 # Vente
        GMENLOC(GVML_TSREBUT) =1 # Rebut
        GMENLOC(GVML_TSVOLDI) =1 # Vol disparition
        GMENLOC(GVML_TSFCLOC) =1 # Fin de contrat location
        #*Fq-91622 If [M:FAS2]LEAREF<>""
        #*Fq-121637 If [M:FAS2]LEAREF = ""
        If func AFNC.ACTIV("LEA")=0 or [M:FAS2]LEAREF = ""
           GMENLOC(GVML_TSFCONT) =1 # Fin de contrat crédit bail
           GMENLOC(GVML_TSCRESI) =1 # Contrat résilié
        Endif
        #*Fq-91622 GMENLOC(GVML_TSCRESI) =1 # Contrat résilié

      When GVML_TDLOCAT
      # type de détention "En location"
        GMENLOC(GVML_TSVENTE) =1 # Vente
        GMENLOC(GVML_TSREBUT) =1 # Rebut
        GMENLOC(GVML_TSVOLDI) =1 # Vol disparition
        #*FQ-91622 If [M:FAS2]LEAREF<>""
        #*Fq-121637 If [M:FAS2]LEAREF = ""
        If func AFNC.ACTIV("LEA")=0 or [M:FAS2]LEAREF = ""
           GMENLOC(GVML_TSFCLOC) =1 # Fin de contrat location
        Endif
        GMENLOC(GVML_TSFCONT) =1 # Fin de contrat crédit bail
        GMENLOC(GVML_TSCRESI) =1 # Contrat résilié

      When GVML_TDCONCE
      # type de détention "En concession"
        GMENLOC(GVML_TSFCLOC) =1 # Fin de contrat location
        GMENLOC(GVML_TSFCONT) =1 # Fin de contrat crédit bail
        GMENLOC(GVML_TSCRESI) =1 # Contrat résilié
        GMENLOC(GVML_TSREPRI) =1 # Bien repris
    Endcase
  Else
   #FQ57746
   #VALEUR=GVML_TSVENTE
   ## FQ49106
   #[M:FASS]PYBVATTYP = GVML_SNSREGU  : Affzo [M:FASS]PYBVATTYP
   #[M:FASS]ISSVATRAT = GDEFVATRAT    : Affzo [M:FASS]ISSVATRAT
  Endif
End

########################################################################## Type de sortie
Subprog AM_ISSTYP(VALEUR)
Variable Integer VALEUR

 # FQ48963
 # Si le motif de sortie est différent de vente le champ Règle TVA sur sortie
 # a comme valeur par défaut "Non assujettie à  la TVA"
 # Si le motif de sortie est "Vente" le champ Règle TVA sur sortie
 # a comme valeur par défaut "Sans régularisation". Cette valeur sera ensuite affinée en fonction
 # du taux de TVA de cession

 If (VALEUR <> GVML_TSVENTE ) Then
   [M:FASS]PYBVATTYP = GVML_SNSREGU
   Actzo [M:FASS]PYBVATTYP
   # FQ67621
   Effzo [M:FASS]ISSVATRAT : Grizo [M:FASS]ISSVATRAT
   Grizo [M:FASS]VAT : Affzo [M:FASS]VAT
    Effzo [M:FASS]20 : Grizo [M:FASS]20 #Fq-67621
    Actzo [M:FASS]BUY : Affzo [M:FASS]BUY
 Else
 # FQ100398/16
   If dim(GFXDNBERR) < 0
     [M:FASS]SIVTYP = G_SIVTYP #Fq-67621
   Endif
   [M:FASS]PYBVATTYP = GVML_SNSREGU
   # FQ69691B
   If [M:FASS]FGISSVAT = G_OUI
       [M:FASS]ISSVATRAT = 0
   Else
       [M:FASS]ISSVATRAT = GDEFVATRAT
   Endif
   Actzo [M:FASS]PYBVATTYP
   Actzo [M:FASS]ISSVATRAT : Affzo [M:FASS]ISSVATRAT
 Endif

 # FQ67621 Facture de vente à produire (SALINV=oui)
 If ( ACTTYPGES = GTAMUNI ) Then
   If ( G_SALINV = G_OUI ) Then
     Effzo [M:FASS]IVCSALISS : Grizo [M:FASS]IVCSALISS
     If (VALEUR = GVML_TSVENTE ) Then
        Actzo [M:FASS]VAT
        Effzo [M:FASS]ISSVATRAT : Grizo [M:FASS]ISSVATRAT
        Actzo [M:FASS]BUY
        Actzo [M:FASS]COMMENT1
        Actzo [M:FASS]SIVTYP
     Else
        Grizo [M:FASS]VAT       : Affzo [M:FASS]VAT
        Effzo [M:FASS]20        : Grizo [M:FASS]20 #Fq-67621
        Actzo [M:FASS]IVCSALISS :  Affzo [M:FASS]IVCSALISS
        Actzo [M:FASS]BUY       :  Affzo [M:FASS]BUY
     Endif
   Else # Pas de génération de facture 1/3
     # CRI 18/01/2013    Grizo [M:FASS]VAT : Affzo [M:FASS]VAT
     If VALEUR = GVML_TSREPRI | VALEUR = GVML_TSFCONT | VALEUR = GVML_TSFCLOC | VALEUR = GVML_TSREBUT
        Effzo [M:FASS]20 : Grizo [M:FASS]20  #Fq-67621
     Else
       Actzo [M:FASS]IVCSALISS  :  Affzo [M:FASS]IVCSALISS
       Actzo [M:FASS]BUY
       Actzo [M:FASS]COMMENT1
       Actzo [M:FASS]SIVTYP
     Endif
   Endif
 Else
   Local Char LPARAM
   Call PARAM([M:FASS]ISSCPY, "SALINV", LPARAM) From ADOVAL
   If (val(LPARAM) = G_OUI) Then
     Effzo [M:FASS]IVCSALISS : Grizo [M:FASS]IVCSALISS
     If (VALEUR = GVML_TSVENTE) Then
       Actzo [M:FASS]VAT
       Effzo [M:FASS]ISSVATRAT : Grizo [M:FASS]ISSVATRAT
     Else
       Grizo [M:FASS]VAT : Affzo [M:FASS]VAT
     Endif
   Else
     Grizo [M:FASS]VAT : Affzo [M:FASS]VAT
     If VALEUR = GVML_TSREPRI | VALEUR = GVML_TSFCONT | VALEUR = GVML_TSFCLOC | VALEUR = GVML_TSREBUT
        Effzo [M:FASS]20 : Grizo [M:FASS]20     #Fq-67621
     Else
       Actzo [M:FASS]IVCSALISS  :  Affzo [M:FASS]IVCSALISS
       Actzo [M:FASS]BUY
       Actzo [M:FASS]COMMENT1
       Actzo [M:FASS]SIVTYP
     Endif
   Endif
 Endif
End


######################################################################### Type de sortie
Subprog AP_ISSTYP(VALEUR)
Variable Integer VALEUR

###-> Contrôle massif et unitaire

 # FQ48963 déplacé en AM
 # Si le motif de sortie est différent de vente le champ Règle TVA sur sortie
 # a comme valeur par défaut "Non assujettie à  la TVA"
 # Si le motif de sortie est "Vente" le champ Règle TVA sur sortie
 # a comme valeur par défaut "Sans régularisation". Cette valeur sera ensuite affinée en fonction
 # du taux de TVA de cession
 ##If (VALEUR <> GVML_TSVENTE ) Then
 ##  [M:FASS]PYBVATTYP = GVML_SNSREGU
 ##  Actzo [M:FASS]PYBVATTYP
 ##  Effzo [M:FASS]ISSVATRAT : Grizo [M:FASS]ISSVATRAT
 ##Else
 ##  [M:FASS]PYBVATTYP = GVML_SNSREGU
 ##  [M:FASS]ISSVATRAT = GDEFVATRAT
 ##  Actzo [M:FASS]PYBVATTYP
 ##  Actzo [M:FASS]ISSVATRAT
 ##Endif

 # Si "Bien repris", "Fin de contrat crédit bail", "Fin de contrat location"
 # on désactive la zone type de montant
 If VALEUR = GVML_TSREPRI | VALEUR = GVML_TSFCONT | VALEUR = GVML_TSFCLOC | VALEUR = GVML_TSREBUT
  [M:FASS]ISSAMTTYP=GVML_TVAUCUN
  Effzo [M:FASS]ISSAMTTYP : Grizo [M:FASS]ISSAMTTYP
  Effzo [M:FASS]VALPLN    : Grizo [M:FASS]VALPLN
  Effzo [M:FASS]ISSAMT    : Grizo [M:FASS]ISSAMT
  Effzo [M:FASS]BRDTYP    : Grizo [M:FASS]BRDTYP
  Effzo [M:FASS]BRDPLN    : Grizo [M:FASS]BRDPLN
 Else
  Actzo [M:FASS]ISSAMTTYP
 Endif

 # Réaffichage du masque pour prise en compte alimentations par défaut

 Affzo [M:FASS]PYBVATTYP
 Affzo [M:FASS]ISSVATRAT

End

