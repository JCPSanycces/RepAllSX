 Local Char MASUNI : MASUNI="M"
 Call LAUNCH_ACT(MASUNI)
End
######################################################################
#
# 1 - Etiquettes du traitement standard ou de la saisie fenêtre ACTION              --> {ET_ACTION}
# 2 - Etiquettes / Point d'entrée de l'action métier communs u / m ACTMET           --> {ET_ACTMET}
# 3 - Etiquettes / Points d'entrée objet de reprise                                 --> {ET_REP}
# 4 - Traitements de gestion de la trace - informations particulières à l'action    --> {ET_GESTRACE}
# 5 - Sous-programmes communs                                                       --> {SOUPRO}
# 6 - Fonctions communes                                                            --> {FONCTION}
# 7 - Routines communes                                                             --> {ROUTINE}
# 8 - Gestion du masque FASISSP [M:FASS]                                            --> {MASQUE}
#
######################################################################
#
# RAF :
#
######################################################################
# Etiquettes modèle Traitement standard / saisie fenêtre / gobjet
######################################################################
#{ET_ACTION}#
$ACTION
 If dim(ORIACT)>0 & ORIACT<>""
  Case ORIACT
   When "TRTOBJ"
    Case ACTION
     When "LIENS0"        : Gosub MFS_LIENS0
     When "LIENS"         : Gosub MFS_LIENS
     When "LIENS2"        : Gosub MFS_LIENS2
     When "INICRE"        : Gosub MFS_INICRE
     When Default
    Endcase
   When Default
  Endcase
 Else
  Case ACTION
   When "INIT_DIA"     : Gosub INIT_DIA
   When "INIT"         : Gosub INIT
   When "AVANT_PAR"    : Gosub AVANT_PAR
   When "OUVRE"        : Gosub OUVRE
   When "DEBUT"        : Gosub DEBUT
   When "APRES_MODIF"  : Gosub APRES_MODIF
   When "SETBOUT"      : Gosub SETBOUT
   When "AP_CHOIX"     : Gosub AP_CHOIX
   When "BOUTON"       : Gosub BOUTON
   When "END"          : Gosub END_BOITE
   When "AVANT_OK"     : Gosub AVANT_OK
   When "OK"           : Gosub OK
   When "ABA"          : Gosub ABA
   When "CONTROLE"     : Gosub CONTROLE
   When "EXEC"         : Gosub EXEC
   When "FIN"          : Gosub FIN
   When "TERMINE"      : Gosub TERMINE
   When "SORTIE"       : Gosub SORTIE
   When "IMP_MVT"      : Gosub IMP_MVT
   When Default
  Endcase
 Endif

Return

#=====================================================================
$INIT_DIA                    # (Massif - Saisie des paramètres)
 If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
 TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$INIT                    # (Unitaire et Massif - interactif et exécution batch)
 If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
 TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
 Gosub ACTION From =TRTMODACT

 # FQ64909 : Déclaration ici pour que ces variables soient connue en exécution interactive ou batch
 If GSERVEUR
   Global Date       G_SORREG
   Global Date       G_SORREGT
   Global Date       G_SORREGI
   Global Date       G_TBSORREG  (0..G301MAX-1)
   Global Date       G_TBSORREGT (0..G301MAX-1)
   Global Date       G_TBSORREGI (0..G301MAX-1)
   Global Char       G_WNUMBIC      #Fq-67621  N° facture de vente (attribué dès la création de la 1ère ligne de facture)
   Global Decimal    TOT_BICC       #Fq-67621  Somme des montants des lignes de la facture Tiers
   Global Char       G_SIVTYP       #Fq-67621  Type de facture de vente : issue du param TYPINVFAS (chap TRS)
   Global Integer    G_TOTBICCOK    : G_TOTBICCOK=G_OUI    #Fq-67621  Total vente calculé dans l'écran de contrôle : OK si diff de 0
   Global Integer    G_SALCLS       : G_SALCLS=G_NON       #Fq-XXXXXX
   Global Integer    G_SALINV       : G_SALINV=G_NON       #Fq-119079
 Endif

 # FQ79623 : montant de sortie tout sur le bien principal
 Gosub INIT_TTPRINC

Return
#============================================
# FQ79623 : montant de sortie réparti  sur le bien principal
# décla de var propres
# et lecture d'un paramètre dépendant
$INIT_TTPRINC

  If dim(GPARCUMCPST) < 0
    Global Integer GPARCUMCPST
  Endif # FQ91989

  Global Decimal GTCUMCPSECPST(10)
  Local Char WCH

  # En cas de cumul sur le bien principal
  # tenir compte si la répartition se fait en prenant les
  # composants ou non
  # (cela n'a d'intêret qu'en traitement massif)
  GPARCUMCPST = G_OUI
  Call PARAM("", "FXMCUMCPST", WCH) From ADOVAL
  If WCH = num$(G_NON)
    GPARCUMCPST = G_NON
  Endif
# FQ91989  Endif

Return
#=====================================================================
$AVANT_PAR               # (Massif uniquement - Interactif et soumission batch)

 If dim(TRTMODACT)<0 : Global Char TRTMODACT : Endif
 TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
 Gosub ACTION From =TRTMODACT

##### Ouverture des masques de la fenêtre de l'action massive pour pouvoir les garder jusqu'à
##### EXEC - Ouverture manuelle des masques de la fenêtre.
##### Nécessaire jusqu'à ce qu'une modif permette de lancer une action massive avec plus
##### d'un écran de critère.

Local Char WINACT : WINACT=ACTMETNAM+"M"
Local Integer I_MSK
If !clalev([F:AWI]) : Local File AWINDOW : Endif
If !clalev([F:AMK]) : Local File AMSK    : Endif
Read [AWI]AWI0=WINACT
If !fstat
 Local Mask =[F:AWI]MSKENT
 For I_MSK=0 To [F:AWI]NBMSK
   Read [AMK]CODMSK=[F:AWI]NOMMSK(I_MSK)
   Local Mask =[F:AMK]CODMSK
 Next I_MSK
Endif

 #-> Initialisation de la date de sortie et du motif de sortie et de la devise

 Raz [M:FASS]ISSDAT

 #--> Réaffichage du masque paramètre et positionnement à  non valide pour forcer tous les contrôles

 Affzo  [M:FASS]
 Setmok [M:FASS] With 0

##### Préparation et lancement de l'action en mode silencieux
 If ACTSILENCE=G_OUI & TRTFILMSK<>""
  TYPPRG=0
  Gosub INIT_WIN  From TRMPROACT
  Gosub ALIM_MASK From =TRTFILMSK
  # FQ64909
  ##FQ-54939
  Global Date       G_SORREG
  Global Date       G_SORREGT
  Global Date       G_SORREGI
  Global Date       G_TBSORREG  (0..G301MAX-1)
  Global Date       G_TBSORREGT (0..G301MAX-1)
  Global Date       G_TBSORREGI (0..G301MAX-1)
  Global Char       G_WNUMBIC        #Fq-67621 Numéro facture 1/3 client
  Global Decimal    TOT_BICC         #Fq-67621 Montant global de la facture 1/3 client
  Global Integer    G_HBIC_OK        #Fq-67621  Entête facture 1/ généré ?
  Global Char       G_SIVTYP         #Fq-67621  Type de facture de vente : issue du param TYPINVFAS (chap TRS)
 #Fq-67621  Total vente calculé dans l'écran de contrôle : OK si diff de 0
 # sera mis à G_NON en cas de montant TOTAL_VENTE = 0 dans l'écran Contrôler
 Global Integer    G_TOTBICCOK    : G_TOTBICCOK=G_OUI
 Global Integer    G_SALCLS       : G_SALCLS=G_NON       #Fq-XXXXXX
 Global Integer    G_SALINV       : G_SALINV=G_NON       #Fq-119079
Endif

Return

#=====================================================================
$OUVRE                   # (Massif interactif et Unitaire)

 Global Date       G_SORREG
 Global Date       G_SORREGT
 Global Date       G_SORREGI
 Global Date       G_TBSORREG  (0..G301MAX-1)
 Global Date       G_TBSORREGT (0..G301MAX-1)
 Global Date       G_TBSORREGI (0..G301MAX-1)
 Global Char       G_WNUMBIC         #Fq-67621 numéro facture 1/3 client
 Global Char       G_SIVTYP          #Fq-67621  Type de facture de vente : issue du param TYPINVFAS (chap
 #Fq-67621  Total vente calculé dans l'écran de contrôle : OK si diff de 0
 # sera mis à G_NON en cas de montant TOTAL_VENTE = 0 dans l'écran Contrôler
 Global Integer    G_TOTBICCOK    : G_TOTBICCOK=G_OUI
 Global Integer    G_SALCLS       : G_SALCLS=G_NON       #Fq-XXXXXX
 Global Integer    G_SALINV       : G_SALINV=G_NON       #Fq-119079

 # FQ79623 : montant de sortie tout sur le bien principal
 Gosub INIT_TTPRINC

 If dim(TRTMODACT)<0
  Global Char TRTMODACT
  TRTMODACT= func GLOBIENS.GET_TRTMOD_NAM()
 Endif

 Gosub ACTION From =TRTMODACT

 If !clalev([F:WFAS]) : Local File FXDASSETS   [WFAS]   : Endif
 If !clalev([F:CNX])  : Local File CONTEXT     [CNX]    : Endif
 If !clalev([F:GAC])  : Local File GACCOUNT    [GAC]    : Endif   #Fq-67621
 If !clalev([F:CAC])  : Local File GACCCODE    [CAC]    : Endif   #Fq-67621
 If !clalev([F:BPC])  : Local File BPCUSTOMER  [BPC]    : Endif   #Fq-67621

 # FQ110038 (dans SUBTSV la FQ105200 BRBAN utilise l'abréviation SLT n'ayant pas été ouverte ?)
 If func AFNC.ACTIV("INVCA") > 0
   If !clalev([F:SLT])  : Local File SALTRS      [SLT]    : Endif
 Endif

 ######> UNITAIRE
 If ACTTYPGES=GTAMUNI
  # Le bien peut-il faire l'objet d'une sortie d'actif ?

  Local Integer L_IS_SORTABL
  L_IS_SORTABL=func TRTFAS.IS_SORTABLE([M:FASS]ISSCPY, [M:FAS4]ISSDAT, [M:FAS1]OWNTYP)
  If L_IS_SORTABL
   Case L_IS_SORTABL
    When 1       : GMESSAGE = mess(418,GML_MSGFAS,1)+"." # "La sortie d'un bien en modèle est interdite."
    When 2       : GMESSAGE = mess(417,GML_MSGFAS,1)+"." # "L'annulation de la sortie d'un bien effectuée dans un exercice antérieur est interdite"
    When Default : GMESSAGE = mess(29,GML_MSGFAS,1)
   Endcase
   GERR=1 : FIN=1
  Endif

  If ([F:FAS]CMPSTA = GVML_SBPOOL) Then
     # FQ67615 Sortie interdite pour un bien Pool.
     GMESSAGE = mess(882,GML_MSGFAS,1)
     GERR = 1 : FIN = 1
  Endif

  #Fq68380 - Annulation de sortie interdite ayant été sorti par une opération de CIG
  If find([F:FAS]ISSTYP, GVML_TSAPPOR, GVML_TSFUSIO, GVML_TSSCISS, GVML_TSCIG)> 0
     #L'annulation de la sortie d'un bien effectuée par une opération de Cession intra groupe est interdite.
     GMESSAGE = mess(815,GML_MSGFAS,1)
     GERR = 1 : FIN = 1
  Endif

  #Fq54343 - Annulation de sortie interdite pour un bien dont le motif de sortie est renouvellement
  If G_ACTCCN=G_OUI & [F:FAS]ISSTYP=GVML_TSRENEW
   GMESSAGE = mess(782,GML_MSGFAS,1)-[F:FAS]RNWAASREF #"L'annulation du renouvellement ne peut se faire que sur le bien renouvelant"
   GERR=1 : FIN=1
  Endif

  # Annulation de sortie interdite pour une bien rattaché à un contrat échu ou résilié
  Local Integer L_LEA_ACTIF
  Call ACTIV("LEA", L_LEA_ACTIF) From SUBACV
  If L_LEA_ACTIF
   If [F:FAS]LEAREF<>""
    Local Integer LEASTA
    LEASTA = func SUBLEA.GET_LEASTA([F:FAS]LEAREF)
    If LEASTA = GVML_STECHU | LEASTA = GVML_STRESIL
     GMESSAGE = mess(504,GML_MSGFAS,1) #"Ce bien est rattaché à un contrat échu ou résilié. Annulation de sortie interdite"
     GERR = 1 : FIN = 1
    Endif
   Endif
  Endif

  # Si le bien est sorti
  If ( [M:FAS4]ISSDAT <> [0/0/0] ) Then
    # S'il s'agit d'un bien composant
    If ( [M:FAS1]CMP <> "" ) Then
      # Si la sortie est "réelle"
      If ([M:FAS4]EXTISSFLG = G_NON ) Then
        # Un bien composant ne peut pas voir les termes de sa sortie modifiés
        GERR= 1: GMESSAGE = mess(47,GML_MSGFAS,1) : FIN=1
      Else
      # Si la sortie est prévisionnelle mais qu'elle est induite par son bien de rattachement
        Read [WFAS]FAS0=[M:FAS1]CMP
        If ( [F:WFAS]EXTISSFLG = G_OUI ) Then
          # Un bien composant ne peut pas voir les termes de sa sortie modifiés
          GERR= 1: GMESSAGE = mess(47,GML_MSGFAS,1) : FIN=1
        Endif
      Endif
    Endif
  Else  # bien non-sorti
    # Avertissement si le bien a été déprécié dans la période
    If func TRTFAS.CTRL_IML([M:FAS0]CPY, [M:FAS0]AASREF) = G_OUI
      Call ERREUR(mess(633,GML_MSGFAS,1)) From GESECRAN
    Endif

    # Issue 120085
    # Erreur : Le bien a eu une reprise de dépréciation dans la période, annulez la avant de sortir le bien.
    If func TRTFAS.CTRL_IMLRVE([M:FAS0]CPY, [M:FAS0]AASREF) = G_OUI
      GERR     = 1
      FIN      = 1
      GMESSAGE = mess(940,GML_MSGFAS,1)
    Endif
    # End Issue 120085

    #--FQ104997 : Controle existence d' un evt de sortie, alors que la date de sortie est non renseignée dans FAS4
    If !clalev([ZEVT]) : Local File EFASISS [ZEVT] : Endif
    Filter [F:ZEVT] Where (REF=[M:FAS0]AASREF & CPY=[M:FAS0]CPY and DPRPLN=G301CPT)
    Read [F:ZEVT]EVE0 Last
    Filter [ZEVT]
    If fstat=0 & [F:ZEVT]SNSEVE=GVML_TEACT
      #  message erreur
      GERR=1
# FQ121934
#      GMESSAGE="OUVRE : ATTENTION, CONTACTEZ LE SUPPORT 'SAGE' : un événement de sortie existe déjà pour ce bien alors que la date de sortie n'est pas renseignée."
      GMESSAGE="$OUVRE : CAUTION, Contact SAGE support : an exit event already exists for this asset while the release date is not filled in."
      FIN=1
      Return
    Endif #--/FQ104997
  Endif
  # FQ100398/13

  # FQ80044
  If [M:FAS1]CMPSTA = GVML_SBCOMPO or [M:FAS1]CMPSTA= GVML_SBCMPOA
    Call ERREUR(mess(865,GML_MSGFAS,1)) From GESECRAN
#    Call ERREUR("Ce bien est un composant : il sera délié du bien principal") From GESECRAN
  Endif

  #Fq67577-Pologne
  If G_ACTKPL=G_OUI & [M:FPC]LEG="POL"
   If func TRTFASMDR.IS_MDR_PENDING([M:FAS0]CPY, [M:FAS0]AASREF, 0, 0)
    GERR     = 1
    FIN      = 1
    GMESSAGE = mess(827,GML_MSGFAS,1) #"Action impossible : modernisation en cours"
   Endif
  Endif
  #Fin-Pologne


 # FQ81990 Endif déplacé (If ACTTYPGES=GTAMUNI)
 Endif
Return

#=====================================================================
$DEBUT # (Massif interactif et Unitaire)
Local Integer I
Local Char TEXTE(255)
Local Integer OK, ROK

  Gosub ACTION From =TRTMODACT

  If !GBATCH

    ######> MASSIF ET UNITAIRE

    #-> Effacement du masque paramètre

    Effzo [M:FASS]

    #-> Initialisation de la date de transfert, du motif de transfert et de la devise

    Raz [M:FASS]ISSDAT

    ######> UNITAIRE

    If ACTTYPGES=GTAMUNI
      #==> Alimentations par défaut des zones du masque paramètre en unitaire
      Local Decimal MONTSOR
      # Récupération des informations de sortie du bien si le bien a déjà été sorti.
      Raz [M:FASS]
      [M:FASS] = [M:FAS4]

      [M:FASS]ISSCPY = [M:FAS0]CPY

      #*Fq-67621 Si la société n'est pas de législation "FRA"
      # Bloc 5 :  Réévaluation / Dépréciation = masqué
      If [M:FPC]LEG <>"FRA"
         Chgfmt [M:FASS]R76COE      With "-NX:5.6#"
         Chgtbk [M:FASS]25 With ""
      Else
         Chgfmt [M:FASS]R76COE      With "NX:5.6#"
         Affzo [M:FASS]25
      Endif

      #YYFIN_119079
      Local Char XPARAM(10)
      Call PARAM([M:FASS]ISSCPY,"SALINV",XPARAM) From ADOVAL
      G_SALINV=val(XPARAM)
      #YYFIN_119079 End

      # SALINV = "oui"
      # ==> Facture vente non saisissable
      # ==> Type facture et Collectif saisissable
      #FQ91395 If SALINV=G_OUI et que l'on n'est pas en Import
      If G_SALINV=G_OUI and !GIMPORT
          Diszo [M:FASS]IVCSALISS
          Actzo [M:FASS]BUY
          Actzo [M:FASS]SIVTYP
          Actzo [M:FASS]BPRSAC
      Else
          # SALINV = "non"
          # ==> Facture vente saisissable
          # ==> Type facture et Collectif non saisissable
          Actzo [M:FASS]IVCSALISS : Affzo [M:FASS]IVCSALISS
          Actzo [M:FASS]BUY
          Diszo [M:FASS]SIVTYP
          Diszo [M:FASS]BPRSAC
      Endif #*FQ-67621
#================
# Import des mvts
# on va venir initialiser ici l'action
$DEB_ITFMVT

# FQ100398/16
Local Date DATE_ISS
Local Integer NB_ISS, RET #FQ95754_7

      [M:FASS]NB_CNX = 0 # FQ100398/16
      # Récupération des informations des contextes.
      For [CNX] Where CPY=[M:FASS]ISSCPY
        If [F:CNX]CNX=G300CPFI
          [M:FASS]CUR = [F:CNX]CUR
        Endif

        [M:FASS]CNX([M:FASS]NB_CNX)       = [F:CNX]CNX
        [M:FASS]CURCNX([M:FASS]NB_CNX)    = [F:CNX]CUR
        [M:FASS]CURTYPCNX([M:FASS]NB_CNX) = [F:CNX]CURTYP
        [M:FASS]RATCURCNX([M:FASS]NB_CNX) = 0
        [M:FASS]ISSAMTCUR([M:FASS]NB_CNX) = 0

        If  [M:FASS]CURCNX([M:FASS]NB_CNX) = [M:FASS]CURCNX(0) # FQ100398/16
          Diszo [M:FASS]RATCURCNX([M:FASS]NB_CNX)
          Diszo [M:FASS]ISSAMTCUR([M:FASS]NB_CNX)
        Endif

        [M:FASS]NB_CNX += 1
      Next

      # Désactivation du flag sortie des biens composants si le BCO n'est pas principal ou s'il l'est mais qu'il n' a pas de
      # composant ou complémentaire
      If [M:FAS1]CMPSTA=GVML_SBPRINC
        If !clalev([F:FAS2]) : Local File FXDASSETS [FAS2] : Endif
        Look [FAS2]FAS5=[M:FAS0]AASREF
        If fstat
          Effzo [M:FASS]ISSCMPFLG
          Grizo [M:FASS]ISSCMPFLG
        Else
         [M:FASS]ISSCMPFLG=G_OUI : Affzo [M:FASS]ISSCMPFLG
        Endif
      Else
        [M:FASS]ISSCMPFLG=G_OUI
        Grizo [M:FASS]ISSCMPFLG
      Endif

      # Flag d'annulation de dépréciation coché et grisé
      [M:FASS]IMLFLG = G_OUI
      Grizo [M:FASS]IMLFLG

      # Si la date de sortie n'est pas renseignée elle est alimentée par défaut avec la date du jour.
      If ([M:FASS]ISSDAT = [0/0/0] ) Then
        # Indicateur annulation de sortie
        Grizo [M:FASS]CCLISSFLG : Affzo [M:FASS]CCLISSFLG

        If GPHY=G_OUI Then
          Local Char WFILTER(250)
          Local Integer PHY_TYPE_ISS

          WFILTER = "AASREF = '" + [M:FAS0]AASREF + "'"
          # Get issue parameters from the physical movement if found
          [L]RET = func PHYELT_C_MPR._GET_ISSUE_PARAM_FROM_PHY(WFILTER, NB_ISS, DATE_ISS, PHY_TYPE_ISS)

          If NB_ISS > 0 Then
            # Get ISSDAT from the physical movement
            [M:FASS]ISSDAT = DATE_ISS
            # Get ISSTYP from the physical movement
            Local Tinyint WISSTYP
            [L]RET = func PHYELT_C_MPR._GET_FAS_ISSTYP_FROM_PHY(PHY_TYPE_ISS, WISSTYP)
            [M:FASS]ISSTYP = WISSTYP

            If NB_ISS > 1 Then
              TEXTE=mess(45,GML_MSGPHY,1)
              Call OUINON(TEXTE,OK) From GESECRAN
              If OK=1 Then
                FIN=1
                Return
              Endif
            Endif
          Endif
        Endif
        #FQ95754_7 si bien classé pour vente...
        If  [M:FAS4]SALCLSDAT<> [0/0/0]
           G_SALCLS = G_OUI
           [M:FASS]ISSTYP     =  GVML_TSVENTE   # Motif = "Vente"
           [M:FASS]ISSDATRUL  =  GVML_IRJOURP   # Règle = Sortie "Au jour précisé"
           [M:FASS]ISSAMTTYP  =  GVML_TVSAISI   # Montant "à saisir"
           [M:FASS]ISSDAT =  [M:FAS4]SALCLSDAT
           [M:FASS]ISSAMT =  [M:FAS4]EXTSALAMT
        Else
           G_SALCLS = G_NON
        Endif  #FQ95754_7 END
      Else
        # Le bien est déjà sorti, la sortie du bien ne peut être qu'annulée. Il faut donc
        # conditionner les champs en conséquence.
        Diszo [M:FASS] : Affzo [M:FASS] : Setmok [M:FASS] With 0
        # Indicateur annulation de sortie
        [M:FASS]CCLISSFLG=G_OUI
        Affzo [M:FASS]CCLISSFLG
        # Si le BCO courant est principal, on cherche s'il a au moins un composant déjà sorti
        If [M:FAS1]CMPSTA=GVML_SBPRINC
          Local Integer COMP_SORTI : COMP_SORTI=G_NON
          If !clalev([F:FAS2]) : Local File FXDASSETS [FAS2] : Endif
          Filter [FAS2] Where CMP=[M:FAS0]AASREF
          For [FAS2]
            If [F:FAS2]ISSDAT<>[0/0/0] : COMP_SORTI = G_OUI : Endif
          Next
          Filter [FAS2]
          If COMP_SORTI = G_OUI
            [M:FASS]ISSCMPFLG=G_OUI : Grizo [M:FASS]ISSCMPFLG
          Elsif COMP_SORTI = G_NON
            Effzo [M:FASS]ISSCMPFLG  : Grizo [M:FASS]ISSCMPFLG
          Endif
        Endif
      Endif

      # Si la société est française et que le bien est acquis avant le 01/01/1977, la saisie
      # du coefficient de réévaluation 76 est permise
      If !(( func GLOFCYCPY.GET_SOC_PAYS([M:FAS0]CPY) = "FR" and func GLOFCYCPY.GET_SOC_LEG([M:FAS0]CPY) = "FRA" ) and
&          ( [M:FAS1]PURDAT < [01/01/1977] )) Then
        Grizo [M:FASS]R76COE
      Endif

      If GPHY = G_OUI Then
        [M:FASS]ECRPHYATT = G_OUI
        # désactivation du flag "Ecraser les mouvements en attente"
        Grizo [M:FASS]ECRPHYATT
      Endif

      Affzo [M]1-99
      Affzo [M:FASS]ISSVATRAT

      #FQ95754_7 "Avertissement : le bien est détenu pour vente ==> les valeurs de sortie sont pré-alimentées."
      If [M:FASS]CCLISSFLG <> G_OUI and [M:FAS4]SALCLSDAT<> [0/0/0]
        Infbox mess(924,GML_MSGFAS,1)
      Endif #FQ95754_7  END

#    Endif : # ACTTYPGES=GTAMUNI
    Else
      #*Fq-67621 Si la société n'est pas de législation "FRA"
      # Bloc 5 :  Réévaluation / Dépréciation = masqué
      If [M:FPC]LEG <>"FRA"
         Chgfmt [M:FASS]R76COE      With "-NX:5.6#"
         Chgtbk [M:FASS]25 With ""
      Else
         Chgfmt [M:FASS]R76COE      With "NX:5.6#"
         Affzo [M:FASS]25
      Endif
    ######> MASSIF ET UNITAIRE
    Endif

  Endif

  #--> Réaffichage du masque paramètre et positionnement à non valide pour forcer tous les contrôles
  Affzo  [M:FASS]
  Setmok [M:FASS] With 0

  #--> Si mode silencieux, alimentation du masque
  If ACTSILENCE=G_OUI & TRTFILMSK<>""
    TYPPRG=0
    Gosub ALIM_MASK From =TRTFILMSK
  Endif

Return

#=====================================================================
$APRES_MODIF             # (Massif interactif et Unitaire)
 Case COUZON
  When Default
 Endcase
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$SETBOUT                 # (Massif interactif et unitaire)
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$AP_CHOIX                 # (Unitaire)
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$BOUTON                  # (Massif interactif et unitaire)
 If ACTTYPGES=GTAMMAS          # Massif
  If [M:FASS]CCLISSFLG=G_OUI     # Annulation de sortie
   CRITACT="CMPSTA <> GVML_SBCOMPO & CMPSTA <> GVML_SBPOOL & ISSDAT<>[0/0/0]"
  Elsif [M:FASS]CCLISSFLG=G_NON  # Sortie d'actif
   #FQ-67621 (corr annexe) CRITACT="CMPSTA <> GVML_SBCOMPO & CMPSTA <> GVML_SBPOOL ISSDAT=[0/0/0] & OWNTYP <> GVML_TDMODEL"
   CRITACT="CMPSTA <> GVML_SBCOMPO & CMPSTA <> GVML_SBPOOL & ISSDAT=[0/0/0] & OWNTYP <> GVML_TDMODEL"
  Endif
 Endif
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$END_BOITE               # (Massif interactif et unitaire)
 Gosub ACTION From =TRTMODACT
Return


#=====================================================================

$AVANT_OK

Local Integer SV_NBELTATT, WMVT
#Local Char WPHY(GLONPHY) Issue 115092
Local Date WTRFDAT

Local Integer ERRFIN

  # Si on est en unitaire
  If GPHY= G_OUI and ACTTYPGES=GTAMUNI Then
#  FQ100398/13
    Local Char WPHY(GLONPHY), WFCY(GLONFCY), WLCTCOD(GLONLCT), WREN(30)

     If func PHYELT_C_MPR._GET_INFO_PHY_WITH_TRF_MVT([M:FAS0]AASREF, 0,
&          WPHY, WTRFDAT, WFCY, WLCTCOD, WREN, WMVT) Then
      # Issue 110486
      If [M:FASS]CCLISSFLG <> [V]CST_AYES
        TEXTE=mess(41,GML_MSGPHY,1)-mess(92,GML_MSGPHY,1)
        Call OUINON(TEXTE,OK) From GESECRAN
        # Si on ne confirme pas la sortie
        If OK=1 Then
           GERR = 1
           ERRFIN = 1
        Endif
      Endif
      # End Issue 110486
    Endif
  Endif

Return

#=====================================================================
$OK                      # (Massif interactif et unitaire)

 If ERRFIN <> 1 Then
   Gosub ACTION From =TRTMODACT
   If ACTSTATUS=STA_DEBUT & ACTTYPGES=GTAMMAS  # Massif
    If [M:FASS]CCLISSFLG=G_OUI
     CRITACT="CMPSTA<> GVML_SBCOMPO & CMPSTA <> GVML_SBPOOL & ISSDAT<>[0/0/0]"  # Tous les biens différents de composants pas encore rattachés
    Elsif [M:FASS]CCLISSFLG=G_NON
     CRITACT="CMPSTA<> GVML_SBCOMPO & CMPSTA <> GVML_SBPOOL & ISSDAT=[0/0/0]"
    Endif
   Endif
 Endif

Return

#=====================================================================
$CONTROLE

    If dim(GFXDNBERR) > 0

        # ne pas continuer si erreur lors de l'alim des champs
        If GFXDERRALCHP
            FIN = 1
            GERR = 1
            Setmode
            Return
        Endif

        Local Integer SV_ERR_TRACE
        Default Mask [M:FASS]

        GIMPORT = 1 # permet de ne pas afficher à l'écran les messages d'erreur
        SV_ERR_TRACE = GERRTRACE
        Call SAIMSK("", "IMP_MVT", "TRTFASISS") From W0FASISSP
        If SV_ERR_TRACE = GERRTRACE
            Call CTLVARMODE(GFXDNBERR) From FXDINT
        Endif
        GIMPORT = 0
        # setmode final
        Setmode
        If GFXDERRALCHP or SV_ERR_TRACE <> GERRTRACE
            FIN = 1
            GERR = 1
            If [F:FXM]DESRJTMVT = ""
                [F:FXM]DESRJTMVT = GMESSAGE
                If [F:FXM]DESRJTMVT = ""
                    [F:FXM]DESRJTMVT = right$(GMESSIMP, 2)
                Endif
            Endif
            Return
        Endif
    Endif

 Gosub ACTION From =TRTMODACT

 If FIN = 1 : Return : Endif

 If ACTSTATUS=STA_DEBUT & ACTTYPGES=GTAMMAS  & GSERVEUR # Massif batch (exécution)
  If [M:FASS]CCLISSFLG=G_OUI
    CRITACT="CMPSTA <> GVML_SBCOMPO & CMPSTA <> GVML_SBPOOL & ISSDAT<>[0/0/0]"  # Tous les biens différents de composants pas encore rattachés
  Elsif [M:FASS]CCLISSFLG=G_NON
   # FQ59451
   CRITACT="ISSDAT=[0/0/0]"
   If !GIMPORT
     CRITACT+=" & CMPSTA <> GVML_SBCOMPO & CMPSTA <> GVML_SBPOOL"
   Endif
  Endif
 Endif
Return

#=====================================================================
$ABA
 Effzo [M:FASS]
 Gosub DEBUT
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$EXEC                    # (Massif interactif et batch)

 Gosub ACTION From =TRTMODACT

Return

#=====================================================================
$FIN                     # (Massif interactif et unitaire)
 Gosub ACTION From =TRTMODACT
Return

#=====================================================================
$TERMINE                  # (Massif interactif et batch)
 Gosub ACTION From =TRTMODACT

 If dim(G_SORREG)       >0   : Kill G_SORREG         : Endif
 If dim(G_SORREGT)      >0   : Kill G_SORREGT        : Endif
 If dim(G_SORREGI)      >0   : Kill G_SORREGI        : Endif
 If dim(G_TBSORREG)     >0   : Kill G_TBSORREG       : Endif
 If dim(G_TBSORREGT)    >0   : Kill G_TBSORREGT      : Endif
 If dim(G_WNUMBIC)      >0   : Kill G_WNUMBIC        : Endif
 If dim(TOT_BICC)       >0   : Kill TOT_BICC         : Endif  #=Fq-67621
 If dim(G_HBIC_OK)      >0   : Kill G_HBIC_OK        : Endif  #=Fq-67621
 If dim(G_SIVTY)        >0   : Kill G_SIVTYP         : Endif  #=Fq-67621
 If dim(G_TOTISSAMT)    >0   : Kill G_TOTISSAMT      : Endif  #=Fq-67621
 If dim(G_TOTBICCOK)    >0   : Kill G_TOTBICCOK      : Endif  #=Fq-67621
 If dim(G_SALCLS)       >0   : Kill G_SALCLS         : Endif  #=Fq-XXXXXX
 If dim(G_SALINV)       >0   : Kill G_SALINV         : Endif  #=Fq-119079

Return
#=====================================================================
$SORTIE                  # (Massif interactif et batch)
 Gosub ACTION From =TRTMODACT
Return

######################################################################
# Points d'entrée de l'action métier communs unitaire / massif
######################################################################
#
# Construction du nom des étiquettes :
#
# AAAA_BBBB_CCCCCC
#
# AAAA => Nom de la table origine (MAS1 / TMP1 / TPF1
# BBBB => Etape de l'action
# CCCC => Table destination ou Action ou Objet
#
######################################################################
#{ET_ACTMET}#
$ACTMET

Case ACTMET

  When "CRITMEN"            :   Gosub CRITMEN              # U  - Activation menu ou bouton
  When "SET_PRECHARGE"      :   Gosub SET_PRECHARGE        # U  - A positionner à G_OUI s'il n'y a pas de bouton sélectionner
  When "SET_CALCPARM"       :   Gosub SET_CALCPARM         # UM - A positionner à G_OUI si l'action utilise le moteur de calcul
  When "FILL_HEA"           :   Gosub FILL_HEA             # U  - Alimentation partie spécifique en-tête

# Actions hors sous-programmes, communes au massif et à l'unitaire

  When "SET_CRITACT"        :   Gosub SET_CRITACT          # UM - CRITACT critère de sélection particulier à l'action métier

# s/p "LOCKER"

  When "OUVR_LOCK"          :   Gosub OUVR_LOCK            # UM - Ouverture de tables annexes pour les lock
  When "MAS1_CONTROLE"      :   Gosub MAS1_CONTROLE        # M  - Exclusion élément de la population à sélectionner
  When "MAS1_LOCK_AUTRE"    :   Gosub MAS1_LOCK_AUTRE      # UM - Lock objet lié à l'enr en ligne de la population
  When "MAS1_LOCK_MONTANT"  :   Gosub MAS1_LOCK_MONTANT    # UM - Permet d'alimenter les zones montant de TMPMASLCK
  When "CLOS_LOCK"          :   Gosub CLOS_LOCK            # UM - Fermeture de tables annexes pour les lock

# s/p "CHARGER"

  When "OUVR_ALIM_TMP1"     :   Gosub OUVR_ALIM_TMP1       # UM - Ouverture de tables annexes pour l'alim des table tmp.
  When "MAS1_ALIM_TMP1"     :   Gosub MAS1_ALIM_TMP1       # UM - Transfert zones tables de données -> tables tempo

# s/p "APPLIQUE_TEMP"

  When "OUVR_APPL_TMP1"     :   Gosub OUVR_APPL_TMP1       #
  When "TMP1_APPL_TMP1"     :   Gosub TMP1_APPL_TMP1       # UM - Application des paramètres de l'action aux enr de la table temporaire principale
  When "TPF1_APPL_TPF1"     :   Gosub TPF1_APPL_TPF1       # UM - Application des paramètres de l'action aux enr de la table temporaire annexe
  When "END_APPL_TMP1"      :   Gosub END_APPL_TMP1        # UM - Traitement en fin de boucle avant fin de la transaction

# s/p "REPORT_MASK" Report objet principal dans les masques (unitaire uniquement)

  When "TMP1_ALIM_MASK"     :   Gosub TMP1_ALIM_MASK       # U  - Tansfert table temporaire principale -> masques de l'écran
  When "TPF1_ALIM_MASK"     :   Gosub TPF1_ALIM_MASK       # U  - Tansfert table temporaire principale -> masques de l'écran
  When "REAF_ALIM_MASK"     :   Gosub REAF_ALIM_MASK       # U  - Tansfert tables temporaires -> masques de l'écran (pour réaffichage)

# s/p "APPLIQUE_DIRT" Mise à jour directe (massif uniquement)

  When "OUVR_APPL_DIRT"     :   Gosub OUVR_APPL_DIRT       # M  - Ouverture de tables annexes pour la maj directe en massif
  When "MAS1_APPL_DIRT"     :   Gosub MAS1_APPL_DIRT       # M  - Mise à jour directe des tables de données avec les paramètres de l'action
  When "END_APPL_DIRT"      :   Gosub END_APPL_DIRT        # M  - Traitement de fin de boucle avant fin de la transaction
  When "CLOS_APPL_DIRT"     :   Gosub CLOS_APPL_DIRT       # M  - Fermeture des tables annexes

# s/p "REPORTER"

  When "OUVR_ALIM_TABLE"    :   Gosub OUVR_ALIM_TABLE      # UM - Ouverture de table annexes pour le report tmp -> données
  When "TMP1_ALIM_TABLE"    :   Gosub TMP1_ALIM_TABLE      # UM - Report table temporaire principale -> FXDASSETS
  When "TPF1_ALIM_TABLE"    :   Gosub TPF1_ALIM_TABLE      # UM - Report table temporaire par plan -> DEPREC
  When "END_ALIM_TABLE"     :   Gosub END_ALIM_TABLE       # UM - Fin du report tmp -> données
  When "CLOS_ALIM_TABLE"    :   Gosub CLOS_ALIM_TABLE      # UM - Fermeture de table annexes pour le report tmp -> données

# Objet de visualisation / contrôle des modifications

  When "VISU_LOAD_PLAN"     :   Gosub VISU_LOAD_PLAN       # UM - Report table TPF dans Masque visu
  When "VISU_SAVE_PLAN"     :   Gosub VISU_SAVE_PLAN       # UM - Report masque visu dans table TPF

# Objet de visualisation / contrôle des modifications

  When "AM_FLGCPY"          :   Gosub AM_FLGCPY            # M  - Cochage/décochage d'une société

  When Default

 Endcase

Return

#=====================================================================
# Massif : Cochage/décochage d'une société
$AM_FLGCPY

  [M:FASS]NB_CNX = 0
  If VALEUR = G_OUI
  # Issue X3-66048 - 2018-02-23 by BEFOU : using FCYPCY instead of FCY ( CPY is on a different array ! )
    [M:FASS]ISSCPY = [M:MHC]FCYCPY(nolign-1)


    # Type de facture : Valeur par défaut selon paramétrage - FQ67621
    Call PARAM([M:FASS]ISSCPY,"TYPINVFAS",[M:FASS]SIVTYP) From ADOVAL
    G_SIVTYP = [M:FASS]SIVTYP

    #YYFIN_119079
    Local Char XPARAM(10)
    Call PARAM([M:FASS]ISSCPY,"SALINV",XPARAM) From ADOVAL
    G_SALINV=val(XPARAM)
    #YYFIN_119079 End

    # Si la société est française et qu'on est en massif, la saisie
    # du coefficient de réévaluation 76 est permis
    If ( func GLOFCYCPY.GET_SOC_PAYS([M:FASS]ISSCPY) = "FR" or func GLOFCYCPY.GET_SOC_LEG([M:FASS]ISSCPY) = "FRA" ) Then
      Actzo [M:FASS]R76COE
      Chgfmt [M:FASS]R76COE      With "NX:5.6#"
      Affzo [M:FASS]25
    Else
      #*Fq-67621 Grizo [M:FASS]R76COE
      Chgfmt [M:FASS]R76COE      With "-NX:5.6#"
      Chgtbk [M:FASS]25 With ""
    Endif
    For [CNX] Where CPY=[M:FASS]ISSCPY
      If [F:CNX]CNX=G300CPFI : [M:FASS]CUR = [F:CNX]CUR : Endif

      [M:FASS]CNX([M:FASS]NB_CNX)       = [F:CNX]CNX
      [M:FASS]CURCNX([M:FASS]NB_CNX)    = [F:CNX]CUR
      [M:FASS]CURTYPCNX([M:FASS]NB_CNX) = [F:CNX]CURTYP
      [M:FASS]RATCURCNX([M:FASS]NB_CNX) = 0
      [M:FASS]ISSAMTCUR([M:FASS]NB_CNX) = 0

      If  [M:FASS]CURCNX(NB_CNX) = [M:FASS]CURCNX(0)
        Diszo [M:FASS]RATCURCNX([M:FASS]NB_CNX)
        Diszo [M:FASS]ISSAMTCUR([M:FASS]NB_CNX)
      Endif

      Call CALCUL_MONTANTS_DEVISES([M:FASS]ISSAMT, [M:FASS]RATCURCNX([M:FASS]NB_CNX), [M:FASS]NB_CNX) From TRTFAS

      [M:FASS]NB_CNX += 1
    Next
  Endif

  Affzo [M:FASS] : Setmok [M:FASS] With 0
Return

#=====================================================================
# Unitaire : critère désactivation / activation menu CRITMEN
$CRITMEN
 Local Integer ACCFCY
 Local Char AUZFCY (15)
 # Accès selon droit à l'option
 Call DROITSITE ( [M:FAS0]FCY, [L]AUZFCY, [L]ACCFCY ) From SUPCPT
 If ( not [L]ACCFCY or not instr(1, [L]AUZFCY, 'Z') ) Then
   CRITMEN = "1=0"
 Else
   CRITMEN = "1=1"
 Endif
Return

#=====================================================================
# Unitaire : Modif de la variable déclenchant le préchargement en unitaire PRECHARGE
$SET_PRECHARGE
 PRECHARGE=G_NON
Return

#=====================================================================
# Unitaire / massif : A activer uniquement si une action nécessite des appels au moteur de calcul
SET_CALCPARM
 CALC_MOTEUR = G_OUI
Return

#=====================================================================
# Unitaire : Modif de la variable fixant les critères de sélection propres à l'action
$SET_CRITACT
 # FQ59451 On autorise la sortie d'un bien composant uniquement dans le cas des reprises
 If ACTTYPGES=GTAMMAS and !GIMPORT
  CRITACT="CMPSTA<>GVML_SBCOMPO"  # Tous les biens différents de composants pas encore rattachés
 Endif
 # FQ67615 Un bien de statut "Pool" est exclu de la sélection
 If ( ACTTYPGES=GTAMMAS ) Then
  # FQ90781
  If ( CRITACT = "" ) Then
   CRITACT+=" CMPSTA<>GVML_SBPOOL"
  Else
   CRITACT+=" & CMPSTA<>GVML_SBPOOL"
  Endif
 Endif
Return

#=====================================================================
# Unitaire : Permet d'alimenter des zones spécifiques de l'en-tête de la fenêtre
$FILL_HEA
Return

###############################################################################################
# PHASE DE LOCK DE LA POPULATION DE BIENS COMPTABLES A TRAITER                                #
###############################################################################################

#=====================================================================
# Unitaire et massif : Sert à ouvrir des tables utilisées dans MAS1_CONTROLE
#                      et MAS1_LOCK_AUTRE
$OUVR_LOCK
 Global Integer NBOBJLCK_CMP : NBOBJLCK_CMP = 0  : # Nombre de biens composants lockés
                                                   # si flag sortie des biens composants à Oui
Global Integer NBOBJLCK_PRIN : NBOBJLCK_PRIN = 0
 If !clalev([F:MAS2]) : Local File FXDASSETS [MAS2] : Endif
Return

#=====================================================================
# Unitaire / massif : contrôle élément pour retrait de la population
$MAS1_CONTROLE

 # Avant d'effectuer le lock, on contrôle si le bien comptable correspond à tous les critères de sélection.
 # Pourquoi le faire ici ???? Parcequ'inclure tous les cas de figure dans le critère de sélection de la population
 # Conduirait à construire un critère probablement très compliqué. Aussi il est certainement plus efficace de
 # sélectionner un nombre peut être important de biens mais avec un critère correspondant à des index de FXDASSETS
 # connus puis d'éliminer ce qui ne doit pas être traité au fur et à mesure.

If ACTTYPGES=GTAMMAS & [M:FASS]CCLISSFLG=G_NON

  # Issue X3-74074
  If func TRTFASISS2.SBV_ISSUE_CHECK([M:FASS]ISSDAT, [F:MAS1]AASREF) = [V]CST_ANO
   GOK=0
   Return
  Endif

 #Gbn-On ne peut pas sélectionner un bien déjà sorti
 #If [F:MAS1]ISSDAT<>[0/0/0] & ACTSILENCE=G_OUI
 # GOK=0
 # Return
 #Endif

 # Les biens sortis doivent avoir une date d'achat antérieure à la date de sortie.
 # La date d'achat doit être antérieure à la date de sortie
 # Si la date de sortie est égale à la date d'achat, il ne faut pes exclure le bien.

 If [F:MAS1]PURDAT>[M:FASS]ISSDAT
  GOK=0
  Return
 Endif

 # FQ59066
 # La date de sortie doit être >= à la date d'achat des biens composants si le bien est principal et si l'indicateur "Sortie des biens
 # composants" à Oui
 If ([M:FASS]ISSCMPFLG = G_OUI and [F:MAS1]CMPSTA = GVML_SBPRINC) Then
  For [F:MAS2]FAS5 Where CMP=[F:MAS1]AASREF and PURDAT>[M:FASS]ISSDAT
   GOK=0
   Break
  Next
 Endif

 If GOK<1
  Return
 Endif

 # 1 - Bien avec type de détention "En propriété" ou "En prévision" :
 #     Motif de sortie valable :
 #           a - Vente
 #           b - Rebut
 #           c - Vol ou disparition
 #           d - Apport partiel d'actif
 #           e - Fusion
 #           f - Scission
 #           g - Vente intra-groupe

 If [F:MAS1]OWNTYP=GVML_TDPROPR
& | [F:MAS1]OWNTYP=GVML_TDPREVU
  Case [M:FASS]ISSTYP
   When GVML_TSVENTE : GOK=1
   When GVML_TSREBUT : GOK=1
   When GVML_TSVOLDI : GOK=1
   When GVML_TSAPPOR : GOK=1
   When GVML_TSFUSIO : GOK=1
   When GVML_TSSCISS : GOK=1
   When GVML_TSCIG   : GOK=1
   When GVML_TSFCONC
     #FQ54343
     If ([F:MAS1]CCNREF <> "" ) Then
      # Autorisation particulère lorsqu'un bien en concession
      GOK = 1
     Else
      GOK = 0
     Endif
   When Default      : GOK=0
  Endcase

  # FQ54343
  # If [M:FASS]ISSDATRUL=GVML_IRCONCE : GOK=0 : Endif
 Endif

 If GOK<1 :  Return :  Endif

 # 2 - Bien avec motif de détention "En location" :
 #     Motif de sortie valable :
 #           a - Bien repris
 #           b - Fin de contrat de location si le BCO est rattaché à un contrat de location financement

 If [F:MAS1]OWNTYP=GVML_TDLOCAT
  Case [M:FASS]ISSTYP
   When GVML_TSREPRI : GOK=1
   When GVML_TSFCLOC
    If [F:MAS1]LEAREF=""
     GOK=1
    Else
     GOK=0
    Endif
   When Default      : GOK=0
  Endcase

  # FQ54343
  # If [M:FASS]ISSDATRUL=GVML_IRCONCE : GOK=0 : Endif
 Endif

 If GOK<1
  Return
 Endif

 # 3 - Bien avec motif de détention "En crédit Bail" :
 #     Motif de sortie valable :
 #           a - Bien repris
 #           b - Fin de contrat de crédit bail si le BCO est rattaché à un contrat de crédit bail
 #           c - Résiliation de contrat de crédit bail si le BCO est rattaché à un contrat de crédit bail

 If [F:MAS1]OWNTYP=GVML_TDCBAIL
  Case [M:FASS]ISSTYP
   When GVML_TSREPRI : GOK=1
   When GVML_TSFCONT, GVML_TSCRESI
    If [F:MAS1]LEAREF<>""
     GOK=1
    Else
     GOK=0
    Endif
   When Default      : GOK=0
  Endcase

  # FQ54343
  # If [M:FASS]ISSDATRUL=GVML_IRCONCE : GOK=0 : Endif
 Endif

 If GOK<1
  Return
 Endif

 # 4 - Bien avec motif de détention "En concession" :
 #     Motif de sortie valable :
 #           a - Vente
 #           b - Rebus
 #           c - Vol ou disparition

 If [F:MAS1]OWNTYP=GVML_TDCONCE
  Case [M:FASS]ISSTYP
   When GVML_TSVENTE : GOK=1
   When GVML_TSREBUT : GOK=1
   When GVML_TSVOLDI : GOK=1
   When GVML_TSRENEW : GOK=1 #FQ54343
   When GVML_TSFCONC : GOK=1 #FQ54343
   When Default      : GOK=0
  Endcase
 Endif

 If GOK<1
  Return
 Endif

 # 5 - Bien avec type de détention "En modèle" :
 #     !!!!!! Sortie impossible !!!!!!

  If [F:MAS1]OWNTYP=GVML_TDMODEL
   GOK=0
  Endif

 # Bien ayant subi une réévaluation ou une depréciation entre la date de sortie et le début de la période courante (SRA)
 # 6 - SRA - Contrôle si le bien a été déprécié ou réévalué.
 #     !!!!!! Sortie impossible !!!!!!
 Local Integer LERR
  #*Fq-67621 Call CONTROLE_DATE_SORTIE( [F:MAS1]CPY, [M:FASS]ISSDAT , [M:FASS]EXTISSFLG, LERR )
 Call CONTROLE_DATE_SORTIE( [F:MAS1]CPY, [M:FASS]ISSDAT , [M:FASS]EXTISSFLG, LERR ) From TRTFAS
 If LERR=11
  Call CTRL_SRA([F:MAS1]CPY, [F:MAS1]AASREF, [M:FASS]ISSDAT, LERR) From TRTFAS
  If LERR
   GOK=0
  Endif
 Endif

 # Si pas annulation automatique des depréciations de la période courante, il faut exclure les biens
 # dans cette situation
 If [M:FASS]IMLFLG=G_NON
  If func TRTFAS.CTRL_IML([F:MAS1]CPY, [F:MAS1]AASREF) = G_OUI
   GOK=0
  Endif
 Endif

 # Issue 120085
 # Erreur : Le bien a eu une reprise de dépréciation dans la période, annulez la avant de sortir le bien.
 If func TRTFAS.CTRL_IMLRVE([F:MAS1]CPY, [F:MAS1]AASREF) = G_OUI
   GOK     = 0
 Endif
 # End Issue 120085

 #fq67577-Pologne
 # Bien d'une société polonaise en cours de modernisation sur au moins un plan : le bien ne peut être sorti
 If G_ACTKPL=G_OUI & [M:FPC]LEG="POL"
  If func TRTFASMDR.IS_MDR_PENDING([F:MAS1]CPY, [F:MAS1]AASREF, 0, 0)
   GOK=0
  Endif
 Endif
 #Fin-Pologne

Endif

# Pas d'Annulation de sortie pour un bien rattaché à un contrat échu ou résilié
If ACTTYPGES=GTAMMAS & [M:FASS]CCLISSFLG=G_OUI
  Local Integer L_LEA_ACTIF
  Call ACTIV("LEA", L_LEA_ACTIF) From SUBACV
  If L_LEA_ACTIF
   If [F:MAS1]LEAREF<>""
    Local Integer LEASTA
    LEASTA = func SUBLEA.GET_LEASTA([F:MAS1]LEAREF)
    If LEASTA = GVML_STECHU | LEASTA = GVML_STRESIL
      GOK=0
    Endif
   Endif
  Endif
Endif

##Fq-68380 Pas d'Annulation de sortie pour un bien sorti via une CIG
If ACTTYPGES=GTAMMAS & [M:FASS]CCLISSFLG=G_OUI
   If find ([F:MAS1]ISSTYP,GVML_TSAPPOR, GVML_TSFUSIO, GVML_TSSCISS, GVML_TSCIG )> 0
      GOK=0
    Endif
Endif


#fq54343 - Annulation de sortie avec motif renouvellement autorisé seulement en silencieux
If G_ACTCCN=G_OUI & ACTTYPGES=GTAMMAS & [M:FASS]CCLISSFLG=G_OUI & ACTSILENCE<>G_OUI & [F:MAS1]ISSTYP=GVML_TSRENEW
 GOK=0
Endif

Return

#=====================================================================
# Unitaire / massif : Lock d'objet lié à l'enregistrement en ligne
#                     Alimenter RMES si un message doit apparaître
#=====================================================================
$MAS1_LOCK_AUTRE

 Local Integer LCKOK
 # FQ79623
 Raz GTCUMCPSECPST
NBOBJLCK_PRIN += 1
 # On traite les composants d'un bien principal
 If [F:MAS1]CMPSTA = GVML_SBPRINC

  # Sortie - On sélectionne tous les composants
  # Annulation de sortie - On sélectionne tous les compo sortis
  If [M:FASS]CCLISSFLG = G_NON
   Filter [MAS2] Where CMP=[F:MAS1]AASREF
  Elsif [M:FASS]CCLISSFLG = G_OUI
   Filter [MAS2] Where (CMP=[F:MAS1]AASREF & ISSDAT<>[0/0/0])
  Endif
  # Boucle sur les composants
  For [MAS2]
   LKEY = func GLOBIENS.GET_KEY_FXDASSETS ([F:MAS2]AASREF)
   If !(LKEY="")
     LCKOK=func GLOBIENS.LOCK_SYMBOLE ("FAS", [F:MAS2]CPY, LKEY, 0)
    If LCKOK=0
     RMES=mess(226,GML_MSGFAS,1)-[F:MAS2]AASREF+"/"+[F:MAS2]AASDES1+"."  # "Enregistrement en cours d'utilisation"
     GOK=-1
     Break
    Elsif LCKOK=1
     # FQ81493
     If dim(NBOBJLCK) >= 0
      NBOBJLCK += 1
     Endif
     #*FQ104997 GOK=1
     Raz [TML]
     [F:TML]TRTNUM  = NUMACT
     [F:TML]OBJTYP  = GVML_OMBIEN
     [F:TML]OBJREF  = [F:MAS2]AASREF
     [F:TML]OBJLIN  = 0
     [F:TML]OBJCPY  = [F:MAS2]CPY
     [F:TML]OBJSYM  = LKEY
     [F:TML]OBJMAIN = G_NON
     # Calcul de la Valeur nette du bien
     If [M:FASS]ISSAMTTYP <> GVML_TVAUCUN     : # Si Type de montant <> sans montant (Raf - Optimiser dans le cas de l'unitaire sur BCO non principal)
      Local    Decimal VALNETTE(1..G301MAX-1) : # Valeurs nettes pour chaque bien par plan
      Local    Date    SORREG  (0..G301MAX-1)
      Local    Date    SORREGT (0..G301MAX-1)
      Local    Date    SORREGI (0..G301MAX-1)
      Local    Integer CODERR
      Call CALCULER_VALEURS_SORTIE ("[F:MAS2]", [M:FASS]ISSTYP, [M:FASS]ISSDAT, VALNETTE, SORREG, SORREGT, SORREGI, CODERR)
      If CODERR
       GOK=0
       Return #CHECK IGNORE_LINE
      Endif

      If [M:FASS]ISSAMTTYP = GVML_TVVNCPL
        # Si Type de montant de vente = "Valeur nette du plan" VALPLN
        [F:TML]OBJAMT(0)=VALNETTE([M:FASS]VALPLN)
	      # FQ81209 optimisation sévère : si après CONTROLER sur VB on revient en VN on a un pb
        #       Elsif ([M:FASS]ISSAMTTYP=GVML_TVSAISI & [M:FASS]BRDTYP=GVML_TRVNCPL) & [M:FASS]ISSCMPFLG=G_OUI
      Elsif [M:FASS]ISSAMTTYP=GVML_TVSAISI #& [M:FASS]BRDTYP=GVML_TRVNCPL) & [M:FASS]ISSCMPFLG=G_OUI
        # Si montant saisi à ventiler selon la valeur nette du plan BRDPLN
        [F:TML]OBJAMT(0)=VALNETTE([M:FASS]BRDPLN)
      Endif
     Endif

    # Calcul des valeurs bilan PCG et IAS
    #*Fq-67621 [F:TML]OBJAMT(1)=func TRTFASISS.GET_VAL_BILAN(G301CPT,[F:MAS2]AASREF)
    #*Fq-67621[F:TML]OBJAMT(2)=func TRTFASISS.GET_VAL_BILAN(G301IAS,[F:MAS2]AASREF)
    [F:TML]OBJAMT(1)=func TRTFAS.GET_VAL_BILAN(G301CPT,[F:MAS2]AASREF)
    [F:TML]OBJAMT(2)=func TRTFAS.GET_VAL_BILAN(G301IAS,[F:MAS2]AASREF)

    # cumul des composants pour (selon le cas) les ajouter au bien principal
    GTCUMCPSECPST(0) += [F:TML]OBJAMT(0)
    GTCUMCPSECPST(1) += [F:TML]OBJAMT(1)
    GTCUMCPSECPST(2) += [F:TML]OBJAMT(2)

    # Ecriture de l'enregistrement correspondant au composant dans la table des locks
     Write [TML]
     If fstat
      Case fstat
       When 1
        RMES="TMPMASLCK"-mess(227,GML_MSGFAS,1)  # "TMPMASLCK table verrouillée"
       When 3
        RMES=mess(129,GML_MSGFAS,1)-[F:TML]TRTNUM+"/"+[F:TML]OBJREF  # Tentative d'écriture en double de la clé
        If ACTREFOBJ="LOF" : RMES+="/"+[F:TML]OBJLIN : Endif
        RMES-="\TMPMASLCK"       #
      Endcase
      GOK=0
      Break
     Endif

     # Totalisation des zones montant de l'enregistrement de lock (On le fait nous car la tot est faite par le modèle
     # uniquement pour les bien de la population principale en sortie de MAS1_LOCK_MONTANT)
     If [M:FASS]ISSCMPFLG = G_OUI
       NBOBJLCK_CMP += 1

#  FQ79623 : cas du montant de sortie tout sur le bien principal
# Il ne faut pas totaliser les composants
# If GPARCUMCPST = G_OUI
#   le cumul sera fait via GTCUMCPSECPST()
# Else
#   On ne répartit pas en tenant compte des composants : pas de cumul
       If [M:FASS]TTPRINC <> G_OUI
         TOTOBJAMT(0) += [F:TML]OBJAMT(0)
         TOTOBJAMT(1) += [F:TML]OBJAMT(1)
         TOTOBJAMT(2) += [F:TML]OBJAMT(2)
         TOTOBJAMT(3) += [F:TML]OBJAMT(3)
         TOTOBJAMT(4) += [F:TML]OBJAMT(4)
       Endif
     Endif
    Elsif LCKOK=-1
     GOK=0
    Endif
   Endif
  Next
  Filter [MAS2]
 Endif

 #Fq51962
 If GPHY=G_OUI
  # Numérotation élément physique à partir du bien
  # Incrémentation du NBOBJLCK en fonction du nombre d'éléments physiques rattachés à un bien
  NBOBJLCK += func PHYELT_C_MPR._GET_SELECTED_PHY_NBR("AASREF = '" + [F:MAS1]AASREF + "'")
 Endif

Return

#=====================================================================
# Unitaire / massif : Sert à alimenter les zones montant de TMPMASLCK OBJAMT
#=====================================================================
$MAS1_LOCK_MONTANT
 Local    Decimal VALNETTE(1..G301MAX-1) : # Valeurs nettes pour chaque bien par plan
 Local    Date    SORREG  (0..G301MAX-1)
 Local    Date    SORREGT (0..G301MAX-1)
 Local    Date    SORREGI (0..G301MAX-1)
 Local    Integer CODERR

 # Calcul de la Valeur nette du BCO courant (Utile seulement si ISSAMTTYP<>Aucun)
 Call CALCULER_VALEURS_SORTIE ("[F:MAS1]", [M:FASS]ISSTYP, [M:FASS]ISSDAT, VALNETTE, SORREG, SORREGT, SORREGI, CODERR)
 If CODERR
  GOK=0
  Return
 Else
  If [M:FASS]ISSAMTTYP = GVML_TVVNCPL
   # Si Type de montant de vente = "Valeur nette du plan" VALPLN
   [F:TML]OBJAMT(0)=VALNETTE([M:FASS]VALPLN)
# FQ81209 optimisation sévère : si après CONTROLER sur VB on revient en VN on a un pb
#  Elsif [M:FASS]ISSAMTTYP= GVML_TVSAISI & [M:FASS]BRDTYP = GVML_TRVNCPL
  Elsif [M:FASS]ISSAMTTYP= GVML_TVSAISI
   # Si montant saisi à ventiler selon la valeur nette du plan BRDPLN
   [F:TML]OBJAMT(0)=VALNETTE([M:FASS]BRDPLN)
  Endif
 Endif

 # calcul des valeurs bilan IAS et PCG (Utile uniquement si répartition du montant de vente par valeur bilan mais
 # comme on veut les présenter systématiquement dans l'objet de reprise ...)

 #*Fq-67621 [F:TML]OBJAMT(1)=func TRTFASISS.GET_VAL_BILAN(G301CPT,[F:MAS1]AASREF)
 #*Fq-67621 [F:TML]OBJAMT(2)=func TRTFASISS.GET_VAL_BILAN(G301IAS,[F:MAS1]AASREF)
 [F:TML]OBJAMT(1)=func TRTFAS.GET_VAL_BILAN(G301CPT,[F:MAS1]AASREF)
 [F:TML]OBJAMT(2)=func TRTFAS.GET_VAL_BILAN(G301IAS,[F:MAS1]AASREF)


 # FQ79623 : cumul des composants via le bien principal
 If [M:FASS]TTPRINC = G_OUI and GPARCUMCPST = G_OUI
    [F:TML]OBJAMT(0) += GTCUMCPSECPST(0)
    [F:TML]OBJAMT(1) += GTCUMCPSECPST(1)
    [F:TML]OBJAMT(2) += GTCUMCPSECPST(2)
 Endif
Return

#=====================================================================
# Unitaire et massif : Sert à fermer les tables utilisées dans MAS1_CONTROLE
#                      et MAS1_LOCK_AUTRE
#=====================================================================
$CLOS_LOCK
 If clalev([F:MAS2]) : Close File [MAS2] : Endif

 # On contrôle que la ventilation pourra se faire, c'est à dire que les bases de ventilation sont <> de 0
 # si plus d'un bien a été sélectionné pour la sortie
  # FQ81209 : meilleure gestion du nb d'objets lockés pour la répart
  # et changement du message d'erreur : le 613 par le 863
  Local Integer WNBTEST
  If [M:FASS]TTPRINC = G_OUI or [M:FASS]ISSCMPFLG <> G_OUI
      WNBTEST = NBOBJLCK_PRIN
  Else
      WNBTEST = NBOBJLCK_PRIN + NBOBJLCK_CMP
  Endif

# If (NBOBJLCK + NBOBJLCK_CMP > 1) and ([M:FASS]ISSAMTTYP = GVML_TVSAISI)
 If (WNBTEST > 1) and ([M:FASS]ISSAMTTYP = GVML_TVSAISI)
  Case [M:FASS]BRDTYP

    When GVML_TRVNCPL       #    ---> Ventilé par plan
      If TOTOBJAMT(0)=0
        GERR=1
        GMESSAGE=mess(863, GML_MSGFAS, 1)
      Endif

    When GVML_TRVBPCG       #    ---> Ventilé par valeur bilan PCG
      If TOTOBJAMT(1)=0
        GERR=1
        GMESSAGE=mess(863, GML_MSGFAS, 1)
      Endif

    When GVML_TRVBIAS       #    ---> Ventilé par valeur bilan IAS
      If TOTOBJAMT(2)=0
        GERR=1
        GMESSAGE=mess(863, GML_MSGFAS, 1)
      Endif

    When Default
  Endcase
 Endif
 Kill WNBTEST
Return

###############################################################################################
# CREATION DES ENREGISTREMENTS DANS LES TABLES TEMPORAIRES                                    #
###############################################################################################

#=====================================================================
# Unitaire / massif : Sert à ouvrir des tables utilisées dans MAS1_ALIM_TMP1
#=====================================================================
$OUVR_ALIM_TMP1
 If !clalev([F:MAS2]) : Local File FXDASSETS [MAS2] : Endif
Return

#=====================================================================
# Unitaire / massif : Chargement de la population en table temporaire
#                     Etiquette appelée par le s/p CHARGER
#                     Si une erreur se produit dans cette étiquette
#                     Alimenter RMES avec le message qui doit apparaître
#                     dans une boîte en unitaire ou en massif
#=====================================================================
$MAS1_ALIM_TMP1

 Local Char TABORI
 Local Char SAV_ID_TML

#=> On créé les composants dans la table temporaire si :
#   le BCO courant est un bien principal
#   La sortie est réelle ou
#   La sortie est prévisionnelle et les composants ne sont pas à sortir ou

 If [F:MAS1]CMPSTA = GVML_SBPRINC & (([M:FASS]EXTISSFLG=G_NON) | ([M:FASS]EXTISSFLG=G_OUI & [M:FASS]ISSCMPFLG=G_OUI))
  If    [M:FASS]CCLISSFLG=G_NON
   Filter [MAS2] Where (CMP=[F:MAS1]AASREF)
  Elsif [M:FASS]CCLISSFLG=G_OUI
   Filter [MAS2] Where (CMP=[F:MAS1]AASREF & ISSDAT<>[0/0/0])
  Endif
  For [MAS2]

   # Lecture de TML pour récupérer la valeur nette du composant

   Read [TML]TML0=NUMACT;[F:MAS2]AASREF


   TABORI="[F:MAS2]"

   # Si les composants sont à sortir on alimente TPF1 - infos par plan

   If [M:FASS]ISSCMPFLG=G_OUI
    Gosub CREE_ENR_PLN From TRTFASISS
   Endif

   # Alimentation de TMP1 - infos par bien pour les composants

   Raz [F:TMP1]
   Gosub CREE_ENR_BCO   From TRTFASISS

   # Ecriture de l'enregistrement par bien du composant

   Write [TMP1]
   If fstat
    Case fstat
     When 1
      RMES="TMPMASFAS"-mess(227,GML_MSGFAS,1)  # "TMPMASFAS table verrouillée"
      GOK=-1
     When 3
      RMES=mess(129,GML_MSGFAS,1)-num$([F:TMP1]TRTNUM)+"/"+[F:TMP1]OBJREF
      GOK=0
     When Default
    Endcase
    Break 1
   Else
    NBTMP+=1
   Endif
  Next
  Filter [MAS2]
 Endif

 #=> Si une erreur s'est produite on sort

 If GOK<1
  Return
 Endif

 #--> Alimentation table temporaire pour le bien comptable courant

 Read [TML]TML0=NUMACT;[F:MAS1]AASREF
 TABORI="[F:MAS1]"
 Gosub CREE_ENR_PLN From TRTFASISS
 Raz [F:TMP1]
 Gosub CREE_ENR_BCO   From TRTFASISS
 Write [TMP1]
 If fstat
  Case fstat
   When 1
    RMES="TMPMASFAS"-mess(227,GML_MSGFAS,1)  # TMPMASFAS table verrouillée
    GOK=-1
   When 3
    RMES=mess(129,GML_MSGFAS,1)-[F:TMP1]TRTNUM+"/"+[F:TMP1]OBJREF+"/"+[F:TMP1]DPRPLN
    GOK=0
   When Default
  Endcase
  Break 1
 Else
  NBTMP+=1
 Endif

Return

###############################################################################################
# APPLICATION DES PARAMETRES DANS LES TABLES TEMPORAIRES                                      #
###############################################################################################

#=====================================================================
$OUVR_APPL_TMP1

 Global Decimal TOT_BICC        #*Fq-67621  MOntant global facture 1/3 client
 Global Integer G_HBIC_OK       #*Fq-67621  Entête facture 1/ généré ?
 Local  Decimal TOTAL_ISSAMT    # Total des montants de sortie
 Global Decimal G_TOTISSAMT     #*Fq-67621  Total des montants de sortie
 Local  Decimal DELTA_ISSAMT    # Différence entre le total des montants de sortie et l'enveloppe de vente

 Local Char    CPYCUR          # Devise de la société de sélection
 Local Char    CPYDES          # Designation de la devise

 If    ACTTYPGES=GTAMMAS
  Call GET_CPY_CUR([M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1),CPYCUR,CPYDES) From GLOFCYCPY
 Elsif ACTTYPGES=GTAMUNI
  Call GET_CPY_CUR([F:FAS]CPY,CPYCUR,CPYDES) From GLOFCYCPY
 Endif

Return

#=====================================================================
# Unitaire / massif : Application paramètres action au contenu de la table temporaire principale
$TMP1_APPL_TMP1

 Local Decimal RATVAT
 Local Integer STAT,SV_NBELTATT
 Local Char SV_LOCD
 Local Char WPARAM #*FQ-67621

 If [M:FASS]CCLISSFLG <> G_OUI
    ##############
    # Sortie BCO #
    ##############
    If (([F:TMP1]CMPSTA=GVML_SBCOMPO)  & [M:FASS]ISSCMPFLG=G_NON)
      #-----------------------------------------------
      # Traitement des composants et complémentaires #
      # Et composants à détacher                     #
      #-----------------------------------------------
       If    ACTTYPGES=GTAMUNI
        # Si on est en unitaire
        If [F:TMP1]OBJREF=[M:FAS0]AASREF
         #Le BCO courant est un composant, on le sort
         # FQ79623 : ajout du statut du bien
         Call MAJ_INFOS_SORTIE("[F:TMP1]","SOR",[F:TMP1]ACGBSEVAL,[F:TMP1]IASBSEVAL,
&        [F:TMP1]VALNET,CPYCUR,G_NON, [F:TMP1]CMPSTA) From TRTFASISS2
         # On ne totalise pas puisqu'il est tout seul
         If    [M:FASS]EXTISSFLG=G_OUI
         # La sortie est réelle, on détache le composant de son principal
          [F:TMP1]UNLINK    = G_NON
         Elsif [M:FASS]EXTISSFLG=G_NON
         # La sortie est prévisionnelle, on ne détache pas le composant
          [F:TMP1]UNLINK    = G_OUI
         Endif
        Endif
       Elsif ACTTYPGES=GTAMMAS
       # BCO complémentaire ou composant à détacher
        [F:TMP1]UNLINK    = G_OUI
       Endif
      Else
      #-----------------------------------------------------------------------------------------
      # Traitement des biens principaux et autonomes : alimentation des informations de sortie #
      #-----------------------------------------------------------------------------------------
      # FQ79623 : ajout du statut du bien
       Call MAJ_INFOS_SORTIE("[F:TMP1]","SOR",[F:TMP1]ACGBSEVAL,[F:TMP1]IASBSEVAL,
&                             [F:TMP1]VALNET,CPYCUR,G_NON, [F:TMP1]CMPSTA) From TRTFASISS2
       # Addition du montant de sortie au total des montants de sortie s'ils sont calculé par ventilation
       If [M:FASS]ISSAMTTYP=GVML_TVSAISI
        TOTAL_ISSAMT+=[F:TMP1]ISSAMT(0)
       Endif
         G_TOTISSAMT += [F:TMP1]ISSAMT(0)#*Fq-67621
        If GPHY=G_OUI Then
         #-----------------------------------------------------------------------------------------
         # Traitement des biens ayant des éléments physique avec des mvt en attente
         #-----------------------------------------------------------------------------------------
#  FQ100398/13
         Local Date WTRFDAT
         Local Integer WMVT
         Local Char WPHY(GLONPHY), WFCY(GLONFCY), WLCTCOD(GLONLCT), WREN(30)

         # Issue 110486 ajout dans le test de  [M:FASS]ECRPHYATT = G_NON
         If [M:FASS]ECRPHYATT = G_NON and func PHYELT_C_MPR._GET_INFO_PHY_WITH_TRF_MVT([F:TMP1]OBJREF, 0,
&          WPHY, WTRFDAT, WFCY, WLCTCOD, WREN, WMVT) Then

           [F:TMP1]FLGERR = G_OUI
           # Bien non traité car élément avec mouvement en attente
           [F:TMP1]MSGERR = mess(75,7775,1)
         Endif
        Endif
      Endif

 Elsif [M:FASS]CCLISSFLG=G_OUI
    ########################
    # Annulation de sortie #
    ########################
    # Annulation de sortie, on remet les infos de sortie à null
    # FQ79623 : ajout du statut du bien
    Call MAJ_INFOS_SORTIE("[F:TMP1]","ANN",0,0,0,"",G_NON, [F:TMP1]CMPSTA) From TRTFASISS2

 Endif
Return

#=====================================================================
# Unitaire / massif : Application paramètres action au contenu de la table temporaire annexe (par plan)
$TPF1_APPL_TPF1
 # Je n'ai pas mis l'alimentation des zones de TPF1 ici mais dans l'étiquette d'application des paramètres à TMP1
 # au dessus car dans cette étiquette, je ne dispose pas des informations nécessaires.
Return

#=====================================================================
# Unitaire / massif : Traitement de fin de boucle d'application des paramètres dans les tables temporaires
$END_APPL_TMP1

 Local Char WPARAM #*Fq-67621

 If ([M:FASS]ISSAMTTYP=GVML_TVSAISI)        # Montant saisi à répartir
  DELTA_ISSAMT=TOTAL_ISSAMT-[M:FASS]ISSAMT
  If DELTA_ISSAMT<>0
   # On modifie le montant de sortie du dernier BCO avec le Delta détecté
#  Filter [TMP1] Where (TRTNUM=NUMACT & UNLINK<>G_OUI)
   Filter [TMP1] Where (TRTNUM=NUMACT & ISSDAT<>[0/0/0])
   Read [TMP1]MFS0 Last
   [F:TMP1]ISSAMT(0)-=DELTA_ISSAMT
   Call GET_MNT_ARRONDI([F:TMP1]ISSAMT*[M:FASS]ISSVATRAT/100,CPYCUR,[F:TMP1]ISSVATAMT) From GLOBIENS
   Rewrite [TMP1]
   If fstat    # Raf - err
    # Err ???
    GOK=0
    Return
   Endif

   # FQ79623 : ajout du statut du bien
   Call MAJ_INFOS_SORTIE("[F:TMP1]","SOR",[F:TMP1]ACGBSEVAL,[F:TMP1]IASBSEVAL,
&       [F:TMP1]VALNET,CPYCUR,G_NON, [F:TMP1]CMPSTA) From TRTFASISS2

   Filter [TMP1]
  Endif
 Endif

 #*Fq-67621 : on ne crée la facture de vente que si le montant global de cette facture (cumul des lignes générées) est <> 0
 #*Fq-91395 : on n'est pas en Import
 If !GIMPORT
  #YYFIN_119079
  Local Char XPARAM(10)
  Call PARAM([F:TMP1]CPY,"SALINV",XPARAM) From ADOVAL
  G_SALINV=val(XPARAM)
  #YYFIN_119079 End
  If GOK and (ACTTYPGES=GTAMMAS) and ( [M:FASS]CCLISSFLG=G_NON ) and ( G_SALINV=G_OUI )
    If ( TOT_BICC <> 0 )
       WPARAM="[F:TMP1]"
       Call CRE_HEADER_BIC(WPARAM) From TRTFAS
   Endif
Endif
Endif  #*Fq-91395 END

Return

###############################################################################################
# ALIMENTATION DES MASQUES DE LA TRANSACTION BIENS COMPTABLES AVEC LES INFOS DE SORTIE        #
###############################################################################################

#=====================================================================
# Unitaire : Permet de reporter les infos de TMP1 dans les masques de l'objet métier
#            Positionner ACTMODIF à 1 si des infos de l'objet métier sont modifiées
$TMP1_ALIM_MASK

  If [F:TMP1]UNLINK=G_OUI
    [M:FAS1]CMPSTA=GVML_SBAUTON
    # FQ80044 ajout de alim de CMPORI
    [F:TMP1]CMPORI = [M:FAS1]CMP
    Raz [M:FAS1]CMP
  Endif
  [M:FAS4]ISSDAT    = [F:TMP1]ISSDAT
  [M:FAS4]EXTISSFLG = [F:TMP1]EXTISSFLG
  [M:FAS4]ISSTYP    = [F:TMP1]ISSTYP
  [M:FAS4]ISSDATRUL = [F:TMP1]ISSDATRUL
  [M:FAS4]R76COE    = [F:TMP1]R76COE
  [M:FAS4]PYBVATTYP = [F:TMP1]PYBVATTYP
  [M:FAS4]ISSVATRAT = [F:TMP1]ISSVATRAT
  [M:FAS4]ISSVATAMT = [F:TMP1]ISSVATAMT
  [M:FAS4]BUY       = [F:TMP1]BUY
  [M:FAS4]IVCSALISS = G_WNUMBIC  #FQ-67621

  Local Char LIBZON(25)

  If [M:FAS4]ISSVATRAT > 0
    [M:FAS4]ACGCPLDED = [F:TMP1]ACGCPLDED
    If GCNXPROIAS = G_OUI : [M:FAS4]IASCPLDED = [F:TMP1]IASCPLDED : Endif
    #*Fq-91288Call TEXTE(22873, LIBZON) From OBJDIV  : # "Déduction complém PCG"
    #*Fq-91288 Fq-XXXXX Chgtzn [M:FAS4]ACGCPLDED With LIBZON
    Chgtzn [M:FAS4]ACGCPLDED With mess(912,GML_MSGFAS,1)
    #*Fq-91288 Call TEXTE(22872, LIBZON) From OBJDIV  : # "Déduction complém IFRS"
    #*Fq-91288 chgtzn [M:FAS4]IASCPLDED With LIBZON
    Chgtzn [M:FAS4]IASCPLDED With mess(913,GML_MSGFAS,1)
  Else
    [M:FAS4]ACGCPLDED = [F:TMP1]ACGREVVAT
    If GCNXPROIAS = G_OUI : [M:FAS4]IASCPLDED = [F:TMP1]IASREVVAT : Endif
    #*Fq-91288 Call TEXTE(34941, LIBZON) From OBJDIV : # "TVA reversement PCG"
    #*Fq-91288 Chgtzn [M:FAS4]ACGCPLDED With LIBZON
    Chgtzn [M:FAS4]ACGCPLDED With mess(910,GML_MSGFAS,1)
    #*Fq-91288 Call TEXTE(34942, LIBZON) From OBJDIV : # "TVA reversement IFRS"
    #*Fq-91288 Chgtzn [M:FAS4]IASCPLDED With LIBZON
    Chgtzn [M:FAS4]IASCPLDED With mess(911,GML_MSGFAS,1)
  Endif

  # FQ 46680 Nouvelles règles TVA
  [M:FAS4]ISSVATTRF  = [F:TMP1]ISSVATTRF
  [M:FAS4]ISSVATTRFI = [F:TMP1]ISSVATTRFI

  # Ne pas supprimer le rattachement à  LEA si la sortie est prévisionnelle
  #Fq-68457 ou si type de sortie=contrat résilié
  Local Integer L_LEA_ACTIF
  Call ACTIV("LEA", L_LEA_ACTIF) From SUBACV
  If L_LEA_ACTIF
    #Fq-68457 If [M:FAS4]EXTISSFLG<>G_OUI
    If [M:FAS4]EXTISSFLG<>G_OUI and( [M:FAS4]ISSTYP <> GVML_TSCRESI )
      If [M:FAS2]LEAREF<>"" & [F:TMP1]ISSDAT<>[0/0/0]
        [M:FAS8]LEAREFORI=[M:FAS2]LEAREF
        Raz [M:FAS2]LEAREF
      Endif
    Endif
  Endif
  [M:FAS4]IVCSALISS = [F:TMP1]IVCSALISS
  [M:FAS4]FLGUPDISS = G_OUI

  #FQ95754_7 si sortie d'un bien classé pour vente : on réinitialise date et montant de vente attendus
  If G_SALCLS = G_OUI
     [M:FAS4]SALCLSDAT = [0/0/0]
     [M:FAS4]EXTSALAMT = 0
  Endif  #FQ95754_7 END

  # FQ 57971
  [M:FAS4]DERRVEISS = [F:TMP1]DERRVEISS

  If ( GKFR = G_OUI )
    # FQ 46680 Nouvelles règles TVA
    [M:FAS5]VATRSD     = [F:TMP1]VATRSD
    [M:FAS5]VATREGDED  = [F:TMP1]VATREGDED
    [M:FAS5]VATREGDEDI = [F:TMP1]VATREGDEDI
    [M:FAS5]VATREGAMT  = [F:TMP1]VATREGAMT
    [M:FAS5]IASVATREG  = [F:TMP1]IASVATREG

    # FQ 46680 Nouvelles règles TVA
    [M:FAS5]VATREGDED += [F:TMP1]ACGCPLDED
    [M:FAS5]VATREGAMT += [F:TMP1]ACGREVVAT
    [M:FAS5]VATREGDEDI+= [F:TMP1]IASCPLDED
    [M:FAS5]IASVATREG += [F:TMP1]IASREVVAT
  Endif

  ACTMODIF=1

  # Le bien est à recalculer
  [M:FAS0]FLGCLC = G_OUI

  # Les provision sont à recalculer pour un bien en concession
  If G_ACTCCN=G_OUI & [M:FAS1]OWNTYP=GVML_TDCONCE
   [M:FAS0]FLGRPRCLC = G_OUI
  Endif
  # Maj des champs UPDx - FQ104286
  [M:FAS9]UPDUSR=GUSER
  [M:FAS9]UPDDAT=date$

Return

#=====================================================================
# Unitaire : Permet de reporter les infos de TPF1 dans les masques de l'objet métier
#            Positionner ACTMODIF à 1 si des infos de l'objet métier sont modifiées
$TPF1_ALIM_MASK
 Local Integer RCNX

 If [F:TMP1]ISSDAT<>[0/0/0]
  [M:FAS4]NBV(find([F:TPF1]DPRPLN,[M:FAS4]DPRPLN)-1)       = [F:TPF1]NBV
  [M:FAS4]GAL(find([F:TPF1]DPRPLN,[M:FAS4]DPRPLN)-1)       = [F:TMP1]GAL([F:TPF1]DPRPLN-1)
  [M:FAS4]SHOGAL(find([F:TPF1]DPRPLN,[M:FAS4]DPRPLN)-1)    = [F:TMP1]SHOGAL([F:TPF1]DPRPLN-1)
  [M:FAS4]LNGGAL(find([F:TPF1]DPRPLN,[M:FAS4]DPRPLN)-1)    = [F:TMP1]LNGGAL([F:TPF1]DPRPLN-1)
  [M:FAS4]ISSAMT(find([F:TPF1]DPRPLN,[M:FAS4]DPRPLN)-1)    = [F:TMP1]ISSAMT([F:TPF1]DPRPLN-1)
  [M:FAS4]IMLRVEISS(find([F:TPF1]DPRPLN,[M:FAS4]DPRPLN)-1) = [F:TMP1]IMLRVEISS([F:TPF1]DPRPLN-1)
 Else
  [M:FAS4]NBV(find([F:TPF1]DPRPLN,[M:FAS4]DPRPLN)-1)       = 0
  [M:FAS4]GAL(find([F:TPF1]DPRPLN,[M:FAS4]DPRPLN)-1)       = 0
  [M:FAS4]SHOGAL(find([F:TPF1]DPRPLN,[M:FAS4]DPRPLN)-1)    = 0
  [M:FAS4]LNGGAL(find([F:TPF1]DPRPLN,[M:FAS4]DPRPLN)-1)    = 0
  [M:FAS4]ISSAMT(find([F:TPF1]DPRPLN,[M:FAS4]DPRPLN)-1)    = 0
  [M:FAS4]IMLRVEISS(find([F:TPF1]DPRPLN,[M:FAS4]DPRPLN)-1) = 0
 Endif

 # FQ90084
 #[M:FAS3]FLGUPDISS(find([F:TPF1]DPRPLN,[M:FAS3]DPRPLN)-1)    = G_OUI
 If [M:FASS]CCLISSFLG=G_OUI and [M:FAS3]FLGUPDISS(find([F:TPF1]DPRPLN,[M:FAS3]DPRPLN)-1)=G_OUI
   [M:FAS3]FLGUPDISS(find([F:TPF1]DPRPLN,[M:FAS3]DPRPLN)-1)    = G_NON
 Else
   [M:FAS3]FLGUPDISS(find([F:TPF1]DPRPLN,[M:FAS3]DPRPLN)-1)    = G_OUI
 Endif

 # Le bien est à recalculer pour ce contexte et ce plan
 Call GET_CNX_FROM_PLAN([M:FAS0]CPY,[F:TPF1]DPRPLN,RCNX) From GLOBIENS
 [M:FAS0]FLGCNXCLC(RCNX-1)                             = G_OUI
 [M:FAS3]DEPSTA(find([F:TPF1]DPRPLN,[M:FAS3]DPRPLN)-1) = GVML_SCNOCAL

 If [M:FASS]CCLISSFLG=G_OUI
    # Annulation FQ84213
    Local File EFASISS [WEVT]
    Filter [F:WEVT] Where (CPY=[F:TMP1]CPY & DPRPLN=[F:TPF1]DPRPLN & REF=[F:TMP1]OBJREF & SNSEVE<>GVML_TEAACT)
    Read [F:WEVT] Last
    If !fstat & [F:WEVT]SNSEVE=GVML_TEACT
      # FQ84213_2
      Local Integer LERR
      Call CONTROLE_DATE_SORTIE( [F:TMP1]CPY, [F:WEVT]SORREG , G_NON, LERR ) From TRTFAS
      If LERR=11
        # FQ122633
        # Annulation de sortie rétroactive
        #[M:FAS3]IMLBLC(find([F:TPF1]DPRPLN,[M:FAS3]DPRPLN)-1) = [F:WEVT]IMLRVEISS
        If !clalev([F:WFIS]) : Local File FISCYEAR [WFIS] : Endif
        Filter [WFIS] Where CPY=[F:TMP1]CPY and CNX=RCNX and STAFIY=GVML_TECOURA
        Read [WFIS]FIY0 Last
        Filter [WFIS]
        If ([F:WEVT]CURPERSTR <> [F:WFIS]DATSTRPER([F:WFIS]INDCURPER-1)) Then : # FQ122633
          [M:FAS3]IMLBLC(find([F:TPF1]DPRPLN,[M:FAS3]DPRPLN)-1) = [F:WEVT]IMLRVEISS
        Endif
      Endif
    Endif
    Filter [WEVT] #FQ97433
    Close File [WEVT]
 Endif

Return

#=====================================================================
# Unitaire : Permet de réafficher les masques de l'objet métier si des modifs
#            y ont été reportées.
REAF_ALIM_MASK
  Affzo [M:FAS1]
  Affzo [M:FAS2]
  Affzo [M:FAS3]
  Affzo [M:FAS4]
  #FQ46680
  If GKFR = G_OUI : Affzo [M:FAS5] : Endif
Return

###############################################################################################
# SORTIE OU ANNULATION DE SORTIE D UNE POPULATION DE BIENS COMPTABLES EN MISE A JOUR DIRECTE  #
###############################################################################################

#=====================================================================
# Massif : Sert à ouvrir des tables utilisées dans MAS1_APPL_MAS1
$OUVR_APPL_DIRT

 Local Decimal  TOTAL_ISSAMT   # Total des montants de sortie
 Global Decimal G_TOTISSAMT    #Fq-67621  Montant global de la facture 1/ généré ?
 Global Decimal TOT_BICC       #Fq-67621  Montant global de la facture 1/ généré ?
 Global Integer G_HBIC_OK      #Fq-67621  Entête facture 1/ généré ?
 Local Decimal DELTA_ISSAMT    # Différence entre le total des montants de sortie et l'enveloppe de vente
 Local Date    CCLISSDAT       # Pour mémorisation de la date de sortie en cas d'annulation (gestion événements)
 Local Char    LAST_BCO        # Mémorise le dernier bien comptable traité pour calcul écart de totalisation
 Local Char    TRC_CPY         # Société courante : rupture société pour émission en-tête trace
 Local Char    CPYCUR          # Devise de la société de sélection
 Local Char    CPYDES          # Désignation de la devise

 Local Char    WK_CPY          # Zones pour l'annulation des événements de sortie
 Local Char    WK_FCY          #
 Local Char    WK_AASREF       #
 Local Date    WK_ISSDAT       #
 Local Integer WK_EXTISSFLG    #


 If    ACTTYPGES=GTAMMAS
  Call GET_CPY_CUR([M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1),CPYCUR,CPYDES) From GLOFCYCPY
 Elsif ACTTYPGES=GTAMUNI
  Call GET_CPY_CUR([F:FAS]CPY,CPYCUR,CPYDES) From GLOFCYCPY
 Endif

 If !clalev([F:MAS2]) : Local File FXDASSETS [MAS2] : Endif
 If !clalev([F:TML2]) : Local File TMPMASLCK [TML2] : Endif
 If !clalev([F:DEP])  : Local File DEPREC    [DEP]  : Endif
 If !clalev([F:CNX])  : Local File CONTEXT   [CNX]  : Endif
 If !clalev([F:GAC]) : Local File GACCOUNT   [GAC]  : Endif   #Fq-67621
 If !clalev([F:CAC]) : Local File GACCCODE   [CAC]  : Endif   #Fq-67621
 If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC]  : Endif   #Fq-67621

 #Fq-67621 Gosub OUVR_EVE
 Gosub OUVR_EVE From TRTFAS

Return

#=====================================================================
# Massif : Application paramètres action aux tables de données : mise à jour directe
$MAS1_APPL_DIRT

  #*FQ104997  GOK=1

  Local Integer I_PLN, CODERR
  Local Char    LPARAM
  Local Char    SV_LOCD
  Local Integer SV_NBELTATT
  Local Char    WPARAM #*FQ-67621

 #-> A rupture société on émet un en-tête dans la trace et le séparateur de la société précédente

  If [F:MAS1]CPY<>TRC_CPY
    If TRC_CPY<>""
      #*Fq-67621 Call SEP_COMPTE_RENDU(TRC_CPY)
      Call SEP_COMPTE_RENDU(TRC_CPY) From TRTFAS
    Endif
    Call ET_COMPTE_RENDU([F:MAS1]CPY) From TRTFASISS
    TRC_CPY=[F:MAS1]CPY
  Endif

  # recupere le nombre de mouvement en attente de transfert des éléments rattaché au bien
  If GPHY = G_OUI Then
    #  FQ100398/13
    Local Date WTRFDAT
    Local Integer WMVT
    Local Char WPHY(GLONPHY), WFCY(GLONFCY), WLCTCOD(GLONLCT), WREN(30)

   If [M:FASS]ECRPHYATT = G_NON and  func PHYELT_C_MPR._GET_INFO_PHY_WITH_TRF_MVT([F:MAS1]AASREF, 0,
&          WPHY, WTRFDAT, WFCY, WLCTCOD, WREN, WMVT) Then

      # écriture de la trace
      Call ECR_TRACE_ERREUR([F:MAS1]CPY,[F:MAS1]AASREF,0,G_OUI,mess(75,7775,1)) From TRCPROCOM
      Raz RMES
      Return
    Endif
  Endif

 # Maj du code forçage du montant de subvention des dépenses rattachées au bien
  If !clalev([F:LOF]) : Local File LAYOUTFAS    : Endif
  Filter[LOF] Where (AASREF = [F:MAS1]AASREF) & (FLGGRA=G_OUI)
    For [LOF] With Stability
      If  [M:FASS]CCLISSFLG <> G_OUI  # Sortie du bien
        [F:LOF]FLGAMTGRA = G_OUI
      Else
        Local Integer LGRT : # X3-104535
        LGRT = func AFNC.ACTIV("GRT")
        If LGRT = G_OUI
                            # Annulation de la sortie du bien
          #FQ91644 ajout [F:LOF]CPY
          Call PARAM([F:LOF]CPY ,"GRTPRVUPD",LPARAM) From ADOVAL
          LGRTPRVUPD = val(LPARAM)
          # si Remise en cause subvention ant.
          If LGRTPRVUPD = G_OUI
            [F:LOF]FLGAMTGRA = G_NON
          Else # si non Remise en cause subvention ant.mais pas de clôture
            Filter [DEP] Where (CPY=[F:MAS1]CPY) & (AASREF= [F:MAS1]AASREF)  & (LSTCLODAT > [0/0/0])
            Read [DEP]First
            If fstat
              [F:LOF]FLGAMTGRA = G_NON
            Endif
            Filter [DEP]
          Endif
        Endif : # X3-104535
      Endif
      Rewrite [F:LOF]
      If fstat
        GOK=0
        If RMES = ""
          # FQ89830
          RMES = "COD01 fstat =" - num$(fstat) - [F:MAS1]AASREF - [F:LOF]CODLOF - num$([F:LOF]LINLOF)
        Endif
        Break
      Endif
    Next
  Filter [LOF]

 #-> Application des modifications sur le BCO en ligne dans [F:MAS1]

  If    [M:FASS]CCLISSFLG=G_OUI   # Annulation de la sortie du bien
    # Sauvegarde des infos nécessaires à l'annulation des événements de sortie
    WK_CPY       = [F:MAS1]CPY
    WK_FCY       = [F:MAS1]FCY
    WK_AASREF    = [F:MAS1]AASREF
    WK_ISSDAT    = [F:MAS1]ISSDAT
    WK_EXTISSFLG = [F:MAS1]EXTISSFLG
    #Fq54343-Biens en concession : annulation de renouvellement
    If G_ACTCCN=G_OUI & [F:MAS1]ISSTYP=GVML_TSRENEW
     [F:MAS1]CCNTRFCUM=0
     [F:MAS1]CCNTRFCAD=0
     [F:MAS1]CCNTRFGRT=0
     [F:MAS1]CCNTRFRPR=0
     #[F:MAS1]RNWAASREF="" #RAF à supprimer
    Endif
    # Annulation des infos de sortie pour le BCO
   # FQ79623 : ajout du statut du bien
    Call MAJ_INFOS_SORTIE("[F:MAS1]","ANN",0,0,0,"",G_NON, [F:MAS1]CMPSTA) From TRTFASISS2
  Elsif [M:FASS]CCLISSFLG=G_NON   # Sortie du bien
    # Sauvegarde de l'identifiant
    LAST_BCO=[F:MAS1]AASREF
    # Alimentation des infos de sortie
   # FQ79623 : ajout du statut du bien
    Call MAJ_INFOS_SORTIE("[F:MAS1]","SOR",[F:TML]OBJAMT(1),
&    [F:TML]OBJAMT(2),[F:TML]OBJAMT(0),CPYCUR,G_NON, [F:MAS1]CMPSTA) From TRTFASISS2

    #fq54343-Renouvellement des biens en concession : calcul des fonds à transmettre.
    If G_ACTCCN=G_OUI & [M:FASS]ISSTYP=GVML_TSRENEW
     Local Integer RCOD
     Call CAL_FONDS_TRANSMIS([F:MAS1]CPY, [F:MAS1]AASREF, G_NON, [M:FASS]ISSDAT, [M:FASS]ISSDATRUL,
&                            [F:MAS1]CCNTRFCAD, [F:MAS1]CCNTRFGRT, [F:MAS1]CCNTRFRPR, [F:MAS1]CCNCADDEV, RCOD) From SUBRWP
     [F:MAS1]CCNTRFCUM=[F:MAS1]CCNTRFCAD+[F:MAS1]CCNTRFGRT+[F:MAS1]CCNTRFRPR
    Endif

    # Addition du montant de sortie au total des montants de sortie s'ils sont calculés par ventilation
    If [M:FASS]ISSAMTTYP=GVML_TVSAISI
      TOTAL_ISSAMT+=[F:MAS1]ISSAMT(0)
    Endif
  Endif

  G_TOTISSAMT += [F:MAS1]ISSAMT(0)  #Fq-67621


  # FQ49106
  [F:MAS1]VATREGDED += [F:MAS1]ACGCPLDED
  [F:MAS1]VATREGAMT += [F:MAS1]ACGREVVAT
  [F:MAS1]VATREGDEDI+= [F:MAS1]IASCPLDED
  [F:MAS1]IASVATREG += [F:MAS1]IASREVVAT

 #-> Le bien devra être recalculé
  [F:MAS1]FLGCLC=G_OUI

 #-> Les provision sont à recalculer pour un bien en concession
  If G_ACTCCN=G_OUI & [F:MAS1]OWNTYP=GVML_TDCONCE
   [F:MAS1]FLGRPRCLC = G_OUI
  Endif

  If [F:MAS1]SALCLSDAT <> [0/0/0]
    G_SALCLS = G_OUI
  Else
     G_SALCLS = G_NON
  Endif

 #-> Mise à jour FLGUDPISS sur la période courante des DEPREC des plans
  Local Integer L_PERC

  If !clalev([F:FIS])  : Local File FISCYEAR  [FIS]  : Endif
  If !clalev([F:CNX])  : Local File CONTEXT   [CNX]  : Endif
  If !clalev([F:DEP])  : Local File DEPREC    [DEP]  : Endif

  For [CNX]CNX0 Where CPY=[F:MAS1]CPY
    Read [FIS]FIY1=[F:CNX]CPY;[F:CNX]CNX;GVML_TECOURA
    For I_PLN=1 To [F:CNX]NBPLC
      Read [DEP]DEP0=[F:MAS1]AASREF;[F:CNX]PLNCAA(I_PLN-1);[F:FIS]DATENDFIY;[F:FIS]DATENDPER([F:FIS]INDCURPER-1)
      If fstat
        GOK=0
        If RMES = ""
          # FQ89830
          RMES = "COD02 fstat =" - num$(fstat) - [F:MAS1]AASREF - mess([F:CNX]PLNCAA(I_PLN-1), 3101, 1)
        Endif
        Break
      Endif

      If [M:FASS]CCLISSFLG=G_NON
        # Récupération du DEPREC courant dans le masque du plan
        #FQ89830
        Call GET_DEPREC_FROM_MASK([F:CNX]PLNCAA(I_PLN-1), [F:FIS]DATENDPER([F:FIS]INDCURPER-1), CODERR) From TRTFASISS2

        # Pas de test de CODERR car si on ne trouve pas le DEPREC il sera de toute façon recalculé.
      # FQ84213
      Elsif [M:FASS]CCLISSFLG=G_OUI
        # Annulation
        Local File EFASISS [WEVT]
        Filter [F:WEVT] Where (CPY=[F:DEP]CPY & DPRPLN=[F:DEP]DPRPLN & REF=[F:DEP]AASREF & SNSEVE<>GVML_TEAACT)
        Read [F:WEVT] Last
        If !fstat & [F:WEVT]SNSEVE=GVML_TEACT
          # FQ84213_2
          Local Integer LERR
          Call CONTROLE_DATE_SORTIE( [F:DEP]CPY, [F:WEVT]SORREG , G_NON, LERR ) From TRTFAS
          If LERR=11
            # FQ122633
            # Annulation de sortie rétroactive
            #[F:DEP]IMLBLC = [F:WEVT]IMLRVEISS
            If ([F:WEVT]CURPERSTR <> [F:DEP]PERSTRDAT) Then
              [F:DEP]IMLBLC = [F:WEVT]IMLRVEISS
            Endif
          Endif
        Endif
        Filter [WEVT] #FQ97433
        Close File [WEVT]
      Endif


      # FQ90084
      #[F:DEP]FLGUPDISS = G_OUI
      If ([M:FASS]CCLISSFLG=G_OUI and [F:DEP]FLGUPDISS=G_OUI)
        [F:DEP]FLGUPDISS = G_NON
      Else
        [F:DEP]FLGUPDISS = G_OUI
      Endif

      # Le bien devra être recalculé
      [F:MAS1]FLGCNXCLC([F:CNX]CNX-1) = G_OUI
      [F:DEP]DEPSTA                   = GVML_SCNOCAL

      #-> Si nécessaire, annulation de la dépréciation de la période
      #   Appel systématique car la fonction intègre le contrôle
      If [M:FASS]CCLISSFLG = G_OUI and [M:FASS]EXTISSFLG = G_NON and [F:CNX]PLNSTD(I_PLN-1) <> GVML_NPSTD
        Call EXT_CANCEL_IML_DEP ("[F:DEP]", CODERR) From TRTFASIML
        If CODERR > 0 and CODERR <> 3
          GOK  = 0
          RMES = mess(634,GML_MSGFAS,1)-[F:DEP]AASREF-mess([F:DEP]DPRPLN,3101,1) : # Erreur lors de l'annulation de la dépréciation
          Break
        Endif
      Endif

      Rewrite [F:DEP]
      If fstat
        GOK=0
        # FQ89830
        RMES = "COD03 fstat =" - num$(fstat) - [F:DEP]AASREF - mess([F:DEP]DPRPLN,3101,1)
        Break
      Endif
    Next I_PLN
  Next
  If GOK<1 : Return : Endif

  #*Fq-67621 MASSIF : Création d'une facture 1/ client si :
  # - Sortie (pas en annulation de sortie)
  # - Paramètre SALINV (Facture de vente à produire) = "oui" (globale G_SALINV)
  # - Type de sortie ="Vente"
  # - Type de montant de vente <> "Aucun"
  # - Sortie non prévisionnelle ==> EXTISSFLG = "non"
  # - Montant de sortie <> 0
  #*Fq-91395 - il ne s'agit pas d'1 Import
  If !GIMPORT
    #YYFIN_119079
    Local Char XPARAM(10)
    Call PARAM([F:MAS1]CPY,"SALINV",XPARAM) From ADOVAL
    G_SALINV=val(XPARAM)
    #YYFIN_119079 End
  If ( [M:FASS]CCLISSFLG = G_NON ) and [F:MAS1]EXTISSFLG <> G_OUI and
&      ( G_SALINV = G_OUI ) and ([M:FASS]ISSTYP = GVML_TSVENTE )  and ( [M:FASS]ISSAMTTYP<> GVML_TVAUCUN )
      If TOTOBJAMT(0)  <> 0   or  G_TOTISSAMT <> 0
        WPARAM = "[F:MAS1]"
         Call CRE_LINES_BIC(WPARAM) From TRTFAS
         If GOK<1
             #899-Impossible de générer la facture tiers client : abandon de la vente
             RMES=mess(899,GML_MSGFAS,1)-[F:MAS1]AASREF
             GOK=0
             Return
         Else
             [F:MAS1]IVCSALISS = G_WNUMBIC
         Endif
      Endif
   Endif
  Endif

  #FQ95754_7 si sortie d'un bien classé pour vente : on réinitialise date et montant de vente attendus
  If G_SALCLS = G_OUI or [F:MAS1]SALCLSDAT<> [0/0/0]
    [F:MAS1]SALCLSDAT = [0/0/0]
    [F:MAS1]EXTSALAMT = 0
  Endif  #FQ95754_7 END

  [F:MAS1]UPDUSR=GUSER #FQ104286
  [F:MAS1]UPDDAT=date$ #FQ104286

 #-> Mise à jour du BCO en ligne dans [F:MAS1]
  Rewrite [MAS1]

 #-> Emission du CR de mise à jour du BCO dans la trace
  If fstat
    Case fstat
      When 1
        RMES=mess(226,GML_MSGFAS,1)-[F:MAS1]AASREF  # "Enregistrement en cours d'utilisation"
        GOK=-1
      When 3
        RMES=mess(129,GML_MSGFAS,1)-[F:MAS1]AASREF
        GOK=0
      When Default
    Endcase
   #> Emission erreur soit dans la trace soit dans des globales si action silencieuse
    If ACTSILENCE=G_OUI
      G_MAJOK=G_NON
      GT_OBJ_REF(I_OBJ)=[F:MAS1]AASREF
      GT_OBJ_DES(I_OBJ)=[F:MAS1]AASDES1
      I_OBJ+=1
    Else
      #*Fq-67621 Call BCO_COMPTE_RENDU([F:MAS1]CPY,[F:MAS1]AASREF,[F:MAS1]AASDES1,"Erreur",RMES)  # Raf - mes
      Call BCO_COMPTE_RENDU([F:MAS1]CPY,[F:MAS1]AASREF,[F:MAS1]AASDES1,"Erreur",RMES) From TRTFAS
    Endif
  Else
    If [M:FASS]CCLISSFLG = G_OUI   # Annulation de sortie
      If FLGSIM<>G_OUI & WK_EXTISSFLG<>G_OUI
        # Génération des événements d'annulation
        Gosub ANNULE_EVE_ISS
        If GOK<1
          If RMES = ""
            # FQ89830
            RMES = "COD04" - [F:MAS1]AASREF
          Endif
          Return
        Endif

        If G_ACTCCN=G_OUI & [F:MAS1]OWNTYP=GVML_TDCONCE
         Gosub ANNULE_EVE_CCNISS
         If GOK<1
          If RMES = ""
            # FQ89830
            RMES = "COD05" - [F:MAS1]AASREF
          Endif
           Return
         Endif
        Endif
      Endif
      # Si OK, on continue, sinon, erreur (émission différenciée en fonction de ACTSILENCE)
      If ACTSILENCE=G_OUI
        G_MAJOK=G_OUI
        GT_OBJ_REF(I_OBJ)=[F:MAS1]AASREF
        GT_OBJ_DES(I_OBJ)=[F:MAS1]AASDES1
        I_OBJ+=1
      Else
        # "Annulation de la sortie"
        #*Fq-67621  Call BCO_COMPTE_RENDU([F:MAS1]CPY,[F:MAS1]AASREF,[F:MAS1]AASDES1,"Ok",mess(228,GML_MSGFAS,1))  # "Annulation de la sortie"
        Call BCO_COMPTE_RENDU([F:MAS1]CPY,[F:MAS1]AASREF,[F:MAS1]AASDES1,"Ok",mess(228,GML_MSGFAS,1)) From TRTFAS
      Endif
    Elsif [M:FASS]CCLISSFLG = G_NON   # Sortie
      # Génération de l'événement de sortie
      Call GENERE_EVE_ISS("[F:MAS1]")

      # Fq54343 - Génération de l'événement de sortie / Provisions si gestion des concessions et bien en concession
      If G_ACTCCN=G_OUI & [F:MAS1]OWNTYP=GVML_TDCONCE
       Call GENERE_EVE_CCNISS("[F:MAS1]")
      Endif
      If ACTSILENCE=G_OUI
        G_MAJOK=G_OUI
        GT_OBJ_REF(I_OBJ)=[F:MAS1]AASREF
        GT_OBJ_DES(I_OBJ)=[F:MAS1]AASDES1
        I_OBJ+=1
      Else
        Local Char LIGNE(115)
        LIGNE=space$(18-len(format$('N:'+GFMT3,[F:MAS1]ISSAMT(0))))+format$('N:'+GFMT3,[F:MAS1]ISSAMT(0))
&            +space$(18-len(format$('N:'+GFMT3,[F:MAS1]ISSVATAMT)))+format$('N:'+GFMT3,[F:MAS1]ISSVATAMT)
&            +space$(18-len(format$('N:'+GFMT3,[F:TML]OBJAMT(0))))+format$('N:'+GFMT3,[F:TML]OBJAMT(0))
&            +space$(18-len(format$('N:'+GFMT3,[F:MAS1]GAL(G301CPT-1))))+format$('N:'+GFMT3,[F:MAS1]GAL(G301CPT-1))
&            +space$(18-len(format$('N:'+GFMT3,[F:MAS1]GAL(G301FIS-1))))+format$('N:'+GFMT3,[F:MAS1]GAL(G301FIS-1))
        # "Sortie"
        #*Fq-67621 Call BCO_COMPTE_RENDU([F:MAS1]CPY,[F:MAS1]AASREF,[F:MAS2]AASDES1,"Ok",LIGNE)
        Call BCO_COMPTE_RENDU([F:MAS1]CPY,[F:MAS1]AASREF,[F:MAS2]AASDES1,"Ok",LIGNE)  From TRTFAS
      Endif
    Endif
    #---------------------- Appel de la prcocédure de gestion de l'élément phy ---------------------------
    # Issue 102073: Is there Physical element(s) for the asset?
    If (GPHY=G_OUI) and (func PHYELT_C_MPR._GET_SELECTED_PHY_NBR("AASREF = '" + [F:MAS1]AASREF + "'")>0)
      Gosub SORTIE_ELT_PHY From TRTFASISS2 : # FQ122633
    Endif
    # End issue 102073
    NBCPYMAJ+=1
  Endif

 #=> Si une erreur s'est produite on sort
  Raz RMES
  If GOK<1
    RMES = GMESSAGE
    Return
  Endif

  #=> On met à jour les composants s'il y en a du BCO courant dans [MAS1]
  If [F:MAS1]CMPSTA = GVML_SBPRINC & (([M:FASS]EXTISSFLG=G_NON) | ([M:FASS]EXTISSFLG=G_OUI & [M:FASS]ISSCMPFLG=G_OUI))  # Ajouter une condition pour UMAF002
    If [M:FASS]CCLISSFLG = G_NON
      Filter [MAS2] Where (CMP=[F:MAS1]AASREF)
    Elsif [M:FASS]CCLISSFLG = G_OUI
      Filter [MAS2] Where (CMP=[F:MAS1]AASREF & ISSDAT<>[0/0/0])
    Endif
    For [MAS2]
   #-> Incrémentation du compteur de BCO traités
      NBCPYTRT+=1

     #-> Application des modifications sur le BCO composant en ligne dans [F:MAS2]
      If [M:FASS]CCLISSFLG = G_OUI  # Annulation de sortie
        # Sauvegarde des infos nécessaires à l'annulation des événements de sortie
        WK_CPY       = [F:MAS2]CPY
        WK_FCY       = [F:MAS2]FCY
        WK_AASREF    = [F:MAS2]AASREF
        WK_ISSDAT    = [F:MAS2]ISSDAT
        WK_EXTISSFLG = [F:MAS2]EXTISSFLG
        # Annulation des infos de sortie pour le composant
        # FQ79623 : ajout du statut du bien
        Call MAJ_INFOS_SORTIE("[F:MAS2]","ANN",0,0,0,"",G_NON, [F:MAS2]CMPSTA) From TRTFASISS2
      Elsif [M:FASS]CCLISSFLG = G_NON  # Sortie
        If    [M:FASS]ISSCMPFLG = G_NON        #  Détachement du BCO composant
          [F:MAS2]CMPSTA     = GVML_SBAUTON    # Le composant devient autonome
          [F:MAS2]CMPORI     = [F:MAS2]CMP     # On sauvegarde le principal
          Raz [F:MAS2]CMP                      # On supprime la référence au bien principal
        Elsif [M:FASS]ISSCMPFLG = G_OUI        # Sortie du BCO composant
          # Sauvegarde de l'identifiant
          LAST_BCO=[F:MAS1]AASREF
          Read [TML2]TML0=NUMACT;[F:MAS2]AASREF
          # Alimentation des infos de sortie
        # FQ79623 : ajout du statut du bien
          Call MAJ_INFOS_SORTIE("[F:MAS2]","SOR",[F:TML2]OBJAMT(1),
&          [F:TML2]OBJAMT(2),[F:TML2]OBJAMT(0),CPYCUR,G_NON, GVML_SBCOMPO) From TRTFASISS2
          # Addition du montant de sortie au total des montants de sortie s'ils sont calculés par ventilation
          If [M:FASS]ISSAMTTYP=GVML_TVSAISI
            TOTAL_ISSAMT+=[F:MAS2]ISSAMT(0)
          Endif
        Endif
        G_TOTISSAMT += [F:MAS2]ISSAMT(0)
      Endif

      #FQ86084
      Local Char SVMAS1AASREF
      SVMAS1AASREF = [F:MAS1]AASREF
      [F:MAS1]AASREF = [F:MAS2]AASREF

      # Issue 102073: Is there Physical element(s) for the asset?
      If (GPHY=G_OUI) and (func PHYELT_C_MPR._GET_SELECTED_PHY_NBR("AASREF = '" + [F:MAS1]AASREF + "'")>0)
        Gosub SORTIE_ELT_PHY From TRTFASISS2 : # FQ122633
      Endif
      # End issue 1020733

      [F:MAS1]AASREF = SVMAS1AASREF

     #->Mise à jour FLGUDPISS sur la période courante des DEPREC des plans
      If [M:FASS]CCLISSFLG = G_OUI or ( [M:FASS]CCLISSFLG = G_NON and [M:FASS]ISSCMPFLG = G_OUI ) Then
        For [CNX]CNX0 Where CPY=[F:MAS2]CPY
          Read [FIS]FIY1=[F:CNX]CPY;[F:CNX]CNX;GVML_TECOURA
          For I_PLN=1 To [F:CNX]NBPLC
            Read [DEP]DEP0=[F:MAS2]AASREF;[F:CNX]PLNCAA(I_PLN-1);[F:FIS]DATENDFIY;[F:FIS]DATENDPER([F:FIS]INDCURPER-1)
            If fstat
              GOK=0
              If RMES = ""
                # FQ89830
                RMES = "COD06 fstat =" - num$(fstat) - [F:MAS2]AASREF - mess([F:CNX]PLNCAA(I_PLN-1),3101,1)
              Endif
              Break
            Endif

            If [M:FASS]CCLISSFLG=G_NON
              # Récupération du DEPREC courant dans le masque du plan
              #FQ89830
              Call GET_DEPREC_FROM_MASK([F:CNX]PLNCAA(I_PLN-1), [F:FIS]DATENDPER([F:FIS]INDCURPER-1), CODERR) From TRTFASISS2

              # Pas de test de CODERR car si on ne trouve pas le DEPREC il sera de toute façon recalculé.

              # FQ84213
              Elsif [M:FASS]CCLISSFLG=G_OUI
                # Annulation
                Local File EFASISS [WEVT]
                Filter [F:WEVT] Where (CPY=[F:DEP]CPY & DPRPLN=[F:DEP]DPRPLN & REF=[F:DEP]AASREF & SNSEVE<>GVML_TEAACT)
                Read [F:WEVT] Last
                If !fstat & [F:WEVT]SNSEVE=GVML_TEACT
                  # FQ84213_2
                  Local Integer LERR
                  Call CONTROLE_DATE_SORTIE( [F:DEP]CPY, [F:WEVT]SORREG , G_NON, LERR ) From TRTFAS
                  If LERR=11
                    # FQ122633
                    # Annulation de sortie rétroactive
                    #[F:DEP]IMLBLC = [F:WEVT]IMLRVEISS
                    If ([F:WEVT]CURPERSTR <> [F:DEP]PERSTRDAT) Then
                      [F:DEP]IMLBLC = [F:WEVT]IMLRVEISS
                    Endif
                  Endif
                Endif
                Filter [WEVT] #FQ97433
                Close File [WEVT]
            Endif

            [F:DEP]FLGUPDISS = G_OUI

            # Le bien devra être recalculé
            [F:MAS2]FLGCNXCLC([F:CNX]CNX-1) = G_OUI
            [F:DEP]DEPSTA                   = GVML_SCNOCAL

            #-> Si nécessaire, annulation de la dépréciation de la période
            #   Appel systématique car la fonction intègre le contrôle
            If [M:FASS]CCLISSFLG = G_NON and [M:FASS]EXTISSFLG = G_NON and [F:CNX]PLNSTD(I_PLN-1) <> GVML_NPSTD
              Call EXT_CANCEL_IML_DEP ("[F:DEP]", CODERR) From TRTFASIML
              If CODERR > 0 and CODERR <> 3
                GOK  = 0
                RMES = mess(634,GML_MSGFAS,1)-[F:DEP]AASREF-mess([F:DEP]DPRPLN,3101,1) : # Erreur lors de l'annulation de la dépréciation
                Break
              Endif
            Endif

            Rewrite [F:DEP]
            If fstat
              GOK=0
              If RMES = ""
                # FQ89830
                RMES = "COD07 fstat =" - num$(fstat) - [F:MAS2]AASREF - mess([F:CNX]PLNCAA(I_PLN-1), 3101, 1)
              Endif
              Break
            Endif
          Next I_PLN
        Next

        If GOK<1
          Return #CHECK IGNORE_LINE
        Endif
      Endif

     #-> Le bien devra être recalculé
      [F:MAS2]FLGCLC=G_OUI

     #-> Les provision sont à recalculer pour un bien en concession
      If G_ACTCCN=G_OUI & [F:MAS2]OWNTYP=GVML_TDCONCE
       [F:MAS2]FLGRPRCLC = G_OUI
      Endif

     #-> Flag de modification de sortie
      [F:MAS2]FLGUPDISS=G_OUI

     # FQ49106
     [F:MAS2]VATREGDED += [F:MAS2]ACGCPLDED
     [F:MAS2]VATREGAMT += [F:MAS2]ACGREVVAT
     [F:MAS2]VATREGDEDI+= [F:MAS2]IASCPLDED
     [F:MAS2]IASVATREG += [F:MAS2]IASREVVAT


     #*Fq-67621 MASSIF BIENS COMPOSANTS : Création d'une facture 1/ client si :
     # - Sortie (pas en annulation de sortie)
     # - Paramètre SALINV (Facture de vente à produire) = "oui" (globale G_SALINV)
     # - Type de sortie ="Vente"
     # - Type de montant de vente <> "Aucun"
      # - Sortie non prévisionnelle ==> EXTISSFLG = "non"
     # - Montant de sortie <> 0
     #
     #*Fq-91395 - il ne s'agit pas d'1 Import
    If !GIMPORT
      #YYFIN_119079
      Local Char XPARAM(10)
      Call PARAM([F:MAS2]CPY,"SALINV",XPARAM) From ADOVAL
      G_SALINV=val(XPARAM)
      #YYFIN_119079 End
    If ( [M:FASS]CCLISSFLG = G_NON ) and [F:MAS1]EXTISSFLG <> G_OUI and
&        ( G_SALINV = G_OUI ) and ([M:FASS]ISSTYP = GVML_TSVENTE )  and ( [M:FASS]ISSAMTTYP<> GVML_TVAUCUN )
        If TOTOBJAMT(0)  <> 0   or  G_TOTISSAMT <> 0
         Local Char WPARAM
          WPARAM = "[F:MAS2]"
           Call CRE_LINES_BIC(WPARAM) From TRTFAS
           If GOK<1
              #899-Impossible de générer la facture tiers client : abandon de la vente
               RMES=mess(899,GML_MSGFAS,1)-[F:MAS1]AASREF
               GOK=0
               Return
           Else
               [F:MAS2]IVCSALISS = G_WNUMBIC
           Endif
        Endif
     Endif
     Endif

     [F:MAS2]UPDUSR=GUSER #FQ104286
     [F:MAS2]UPDDAT=date$ #FQ104286

     #-> Mise à jour du BCO en ligne dans [F:MAS2]
      Rewrite [MAS2]

     #-> Emission du CR de mise à jour du BCO dans la trace

      If fstat
        Case fstat
          When 1
            RMES=mess(226,GML_MSGFAS,1)-[F:MAS2]AASREF    # "Enregistrement en cours d'utilisation"
            GOK=-1
          When 3
            RMES=mess(129,GML_MSGFAS,1)-[F:MAS2]AASREF
            GOK=0
         When Default
            RMES=mess(104,GML_MSGFAS,1)-"FXDASSETS"-mess(105,GML_MSGFAS,1)-"xx"-mess(106,GML_MSGFAS,1)-[F:MAS2]AASREF   #
            GOK=0
        Endcase
        If ACTSILENCE=G_OUI
          G_MAJOK=G_OUI
          GT_OBJ_REF(I_OBJ)=[F:MAS1]AASREF
          GT_OBJ_DES(I_OBJ)=[F:MAS1]AASDES1
          I_OBJ+=1
        Else
         #*Fq-67621  Call BCO_COMPTE_RENDU([F:MAS2]CPY,[F:MAS2]AASREF,[F:MAS2]AASDES1,"Erreur",RMES)
         Call BCO_COMPTE_RENDU([F:MAS2]CPY,[F:MAS2]AASREF,[F:MAS2]AASDES1,"Erreur",RMES) From TRTFAS
        Endif
        Break 1
      Else
        If    [M:FASS]CCLISSFLG = G_OUI   # Annulation de sortie
          If FLGSIM<>G_OUI & WK_EXTISSFLG<>G_OUI
            # Génération des événements d'annulation
            Gosub ANNULE_EVE_ISS
            If GOK<1
              If RMES = ""
                # FQ89830
                RMES = "COD08" - [F:MAS2]AASREF
              Endif

              Return #CHECK IGNORE_LINE
            Endif
            If G_ACTCCN=G_OUI & [F:MAS2]OWNTYP=GVML_TDCONCE
             Gosub ANNULE_EVE_CCNISS
             If GOK<1
              If RMES = ""
                # FQ89830
                RMES = "COD09" - [F:MAS2]AASREF
              Endif
              Return #CHECK IGNORE_LINE
             Endif
            Endif
          Endif
          # Si OK, on continue, sinon, erreur (émission différenciée en fonction de ACTSILENCE)
          # "Annulation de la sortie"
          #*Fq-67621 Call BCO_COMPTE_RENDU([F:MAS2]CPY,[F:MAS2]AASREF,[F:MAS2]AASDES1,"Ok",mess(228,GML_MSGFAS,1))      # "Annulation de la sortie"
          Call BCO_COMPTE_RENDU([F:MAS2]CPY,[F:MAS2]AASREF,[F:MAS2]AASDES1,"Ok",mess(228,GML_MSGFAS,1))  From TRTFAS
        Elsif [M:FASS]CCLISSFLG = G_NON   # Sortie
          If    [M:FASS]ISSCMPFLG = G_NON     # Détachement des BCO composants
            # FQ-80044 ajout du cpst détaché dans la trace
            If ACTSILENCE=G_OUI
              Call ECR_TRACE([F:MAS2]AASREF - [F:MAS2]AASDES1 - ":" - mess(232,GML_MSGFAS,1), 0) From GESECRAN
              # Call ECR_TRACE("Composant détaché : " + [F:MAS2]AASREF - [F:MAS2]AASDES1, 0) From GESECRAN
            Else
              # "Bien détaché"
              #*Fq-67621 Call BCO_COMPTE_RENDU([F:MAS2]CPY,[F:MAS2]AASREF,[F:MAS2]AASDES1,"Ok",mess(232,GML_MSGFAS,1))
              Call BCO_COMPTE_RENDU([F:MAS2]CPY,[F:MAS2]AASREF,[F:MAS2]AASDES1,"Ok",mess(232,GML_MSGFAS,1))  From TRTFAS
            Endif
          Elsif [M:FASS]ISSCMPFLG = G_OUI     # Sortie des BCO composants
            # Génération de l'événement de sortie
            Call GENERE_EVE_ISS("[F:MAS2]")
            # Fq54343 - Génération de l'événement de sortie / Provisions si gestion des concessions et bien en concession
            If G_ACTCCN=G_OUI & [F:MAS2]OWNTYP=GVML_TDCONCE
             Call GENERE_EVE_CCNISS("[F:MAS2]")
            Endif
            If ACTSILENCE=G_OUI
              G_MAJOK=G_OUI
            # Fq69691 ajout pour import des mvts :
            # pb alim GT_OBJ_REF (ds TRMPROACT, il est créé à dim = 1
            # ds le else de ce test, on voit que c'est le composant qu'on alimente
            #              GT_OBJ_REF(I_OBJ)=[F:MAS1]AASREF
            #              GT_OBJ_DES(I_OBJ)=[F:MAS1]AASDES1
              GT_OBJ_REF(0)=[F:MAS2]AASREF
              GT_OBJ_DES(0)=[F:MAS2]AASDES1

              # Fq80044 message
              # Call ECR_TRACE([F:MAS2]AASREF - [F:MAS2]AASDES1 - ":" - "Bien détaché", 0) From GESECRAN
              Call ECR_TRACE([F:MAS2]AASREF - [F:MAS2]AASDES1 - ":" - mess(864, GML_MSGFAS, 1), 0) From GESECRAN

              I_OBJ+=1
            Else
              Local Char LIGNE(115)
              LIGNE=space$(18-len(format$('N:'+GFMT3,[F:MAS2]ISSAMT(0))))+format$('N:'+GFMT3,[F:MAS2]ISSAMT(0))
&                  +space$(18-len(format$('N:'+GFMT3,[F:MAS2]ISSVATAMT)))+format$('N:'+GFMT3,[F:MAS2]ISSVATAMT)
&                  +space$(18-len(format$('N:'+GFMT3,[F:TML]OBJAMT(0))))+format$('N:'+GFMT3,[F:TML]OBJAMT(0))
&                  +space$(18-len(format$('N:'+GFMT3,[F:MAS2]GAL(G301CPT-1))))+format$('N:'+GFMT3,[F:MAS2]GAL(G301CPT-1))
&                  +space$(18-len(format$('N:'+GFMT3,[F:MAS2]GAL(G301FIS-1))))+format$('N:'+GFMT3,[F:MAS2]GAL(G301FIS-1))
              # "Sortie"
              #*Fq-67621  Call BCO_COMPTE_RENDU([F:MAS2]CPY,[F:MAS2]AASREF,[F:MAS2]AASDES1,"Ok",LIGNE)
              Call BCO_COMPTE_RENDU([F:MAS2]CPY,[F:MAS2]AASREF,[F:MAS2]AASDES1,"Ok",LIGNE)  From TRTFAS
            Endif
          Endif
        Endif
        NBCPYMAJ+=1
      Endif
    Next

    Filter [MAS2]
  Endif : # Fin test mise à jour des composants
  Raz RMES
Return

#=====================================================================
$END_APPL_DIRT # Massif uniquement

  Local Char WPARAM  #*Fq-67621

  #*Fq-67621  Call SEP_COMPTE_RENDU([F:MAS1]CPY)
  Call SEP_COMPTE_RENDU([F:MAS1]CPY) From TRTFAS

 #*Fq-67621 : on ne crée la facture de vente que si le montant global de cette facture (cumul des lignes générées) est <> 0
 #* Fq-91395 et que l'on n'est pas en Import
 If !GIMPORT
   #YYFIN_119079
   Local Char XPARAM(10)
   Call PARAM([F:MAS1]CPY,"SALINV",XPARAM) From ADOVAL
   G_SALINV=val(XPARAM)
   #YYFIN_119079 End
   If GOK and (ACTTYPGES=GTAMMAS) and [M:FASS]CCLISSFLG=G_NON and (G_SALINV=G_OUI) and
&    ([M:FASS]ISSTYP = GVML_TSVENTE )  and ( [M:FASS]ISSAMTTYP <> GVML_TVAUCUN )
    If ( TOT_BICC <> 0 )
       WPARAM ="[F:MAS1]"
       Call CRE_HEADER_BIC(WPARAM) From TRTFAS
       [F:MAS1]IVCSALISS = G_WNUMBIC
    Else
        # Le montant de la facture est égal à zéro ==> pas de facture générée"
        # Remise à blanc de la référence facture
        [F:MAS1]IVCSALISS = ""
    Endif
 Endif
 Endif #* Fq-91395 END


 If !clalev([F:FAS]) : Local File FXDASSETS [FAS] : Endif

 If ([M:FASS]ISSAMTTYP=GVML_TVSAISI & [M:FASS]CCLISSFLG<>G_OUI)

  Local Integer I_PLN

  DELTA_ISSAMT=TOTAL_ISSAMT-[M:FASS]ISSAMT(0)
  If DELTA_ISSAMT<>0

   # On modifie le montant de sortie du dernier BCO avec le Delta détecté
   Local Char SOC : SOC=[F:MAS1]CPY

   Read [MAS1]FAS1=SOC;LAST_BCO  # Relecture du dernier bien mis à jour

   Filter [MAS1] Where AASREF=LAST_BCO
   Read [MAS1] First
   If fstat
    GOK=0
   Endif
   [F:MAS1]ISSAMT(0)-=DELTA_ISSAMT
   Call GET_MNT_ARRONDI([F:MAS1]ISSAMT(0)*[M:FASS]ISSVATRAT/100,CPYCUR,[F:MAS1]ISSVATAMT) From GLOBIENS
   #Fq69717-MAJ des montants de sortie de tous les plans
   # FQ79623 : ajout du statut du bien
   Call MAJ_INFOS_SORTIE("[F:MAS1]","SOR",[F:TML]OBJAMT(1),
&   [F:TML]OBJAMT(2),[F:TML]OBJAMT(0),CPYCUR,G_OUI, [F:MAS1]CMPSTA) From TRTFASISS2

   Rewrite [MAS1]
   If fstat    # Raf - err
    # Err ???
    GOK=0
    Return
   Endif
   Filter [MAS1]

   #Fq69717
   If !clalev([F:EVT0])
    Local File EFASISS [EVT0]
   Else
    If dim([F:EVT0]ISSTYP)<0 | (dim([F:EVT0]ISSTYP)>0 & dim([F:EVT0]ISSAMT)<0) #Fq67163
     Close Local File [EVT0] : Local File EFASISS [EVT0]
    Endif
   Endif
   Local Integer I_PLN
   For I_PLN=1 To G301MAX-1
    Filter [F:EVT0] Where REF=[F:MAS1]AASREF & DPRPLN=I_PLN
    Read [F:EVT0] Last
    If !fstat & [F:EVT0]SNSEVE=GVML_TEACT
     Local Char LTIMSTP : LTIMSTP=[F:EVT0]TIMSTP
     Delete [F:EVT0] Where REF=[F:MAS1]AASREF & TIMSTP=LTIMSTP
    Endif
    Filter [F:EVT0]
   Next I_PLN

   Call GENERE_EVE_ISS("[F:MAS1]")


   If ACTSILENCE<>G_OUI
    Local Char LIGNE(115)
    #fq66388-VALNETTE variable inexistante
    LIGNE=
&        +space$(18-len(format$('N:'+GFMT3,[F:MAS1]ISSAMT(0))))+format$('N:'+GFMT3,[F:MAS1]ISSAMT(0))
&        +space$(18-len(format$('N:'+GFMT3,[F:MAS1]ISSVATAMT)))+format$('N:'+GFMT3,[F:MAS1]ISSVATAMT)
&        +space$(18-len(format$('N:'+GFMT3,[F:TML]OBJAMT(0))))+format$('N:'+GFMT3,[F:TML]OBJAMT(0))
&        +space$(18-len(format$('N:'+GFMT3,[F:MAS1]GAL(G301CPT-1))))+format$('N:'+GFMT3,[F:MAS1]GAL(G301CPT-1))
&        +space$(18-len(format$('N:'+GFMT3,[F:MAS1]GAL(G301FIS-1))))+format$('N:'+GFMT3,[F:MAS1]GAL(G301FIS-1))

    # X3-104535
    Call UPDATE_LAST_BCO(NUMACT,[F:MAS1]CPY,[F:MAS1]AASREF,[F:MAS1]AASDES1,LIGNE) From TRTFASISS2
   Endif
  Endif
 Endif

Return

#=====================================================================
$CLOS_APPL_DIRT

 #Fq-67621 Gosub CLOS_EVE
 Gosub CLOS_EVE From TRTFAS

Return

###############################################################################################
# REPORT DU CONTENU DES TABLES TEMPORAIRES DANS LES TABLES METIERS                            #
###############################################################################################

#=====================================================================
$OUVR_ALIM_TABLE
 If !clalev([F:CNX])  : Local File CONTEXT   [CNX]  : Endif
 If !clalev([F:FIS])  : Local File FISCYEAR  [FIS]  : Endif
 If !clalev([F:DEP])  : Local File DEPREC    [DEP]  : Endif
 If !clalev([F:TPFW]) : Local File TMPPLNFAS [TPFW] : Endif
 Local Char TRC_CPY   : Raz TRC_CPY

 Local Char    WK_CPY          # Zones pour l'annulation des événements de sortie
 Local Char    WK_FCY          #
 Local Char    WK_AASREF       #
 Local Date    WK_ISSDAT       #
 Local Integer WK_EXTISSFLG    #
 Local Integer N_PLN
 Local Integer CODERR
 Local Char    CPYCUR          # Devise de la société de sélection
 Local Char    CPYDES          # Designation de la devise

 If    ACTTYPGES=GTAMMAS
  Call GET_CPY_CUR([M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1),CPYCUR,CPYDES) From GLOFCYCPY
 Elsif ACTTYPGES=GTAMUNI
  Call GET_CPY_CUR([F:FAS]CPY,CPYCUR,CPYDES) From GLOFCYCPY
 Endif

 #Fq-67621 Gosub OUVR_EVE
 Gosub OUVR_EVE  From TRTFAS

Return

#=====================================================================
# Unitaire / massif : Report du contenu de la table temporaire principale dans la table de données principale
$TMP1_ALIM_TABLE
Local Char    SV_LOCD
Local Integer SV_NBELTATT
Local Char    WPARAM   #*Fq-67621
#
  #-> A rupture société on émet un en-tête dans la trace
  If [F:TMP1]CPY<>TRC_CPY & ACTTYPGES=GTAMMAS
    If TRC_CPY<>""
       #*Fq-67621  Call SEP_COMPTE_RENDU(TRC_CPY)
       Call SEP_COMPTE_RENDU(TRC_CPY) From TRTFAS
    Endif
    Call ET_COMPTE_RENDU([F:TMP1]CPY) From TRTFASISS
    TRC_CPY=[F:TMP1]CPY
  Endif
 # recupere le nombre de mouvement en attente de transfert des éléments rattaché au bien
  If GPHY = G_OUI Then
  #  FQ100398/13
    Local Char WPHY(GLONPHY), WFCY(GLONFCY), WLCTCOD(GLONLCT), WREN(30)
    Local Date WTRFDAT
    Local Integer WMVT

   If [M:FASS]ECRPHYATT = G_NON and  func PHYELT_C_MPR._GET_INFO_PHY_WITH_TRF_MVT([F:TMP1]OBJREF, 0,
&          WPHY, WTRFDAT, WFCY, WLCTCOD, WREN, WMVT) Then

      # écriture de la trace
      Call ECR_TRACE_ERREUR([F:TMP1]CPY,[F:TMP1]OBJREF,0,G_OUI,mess(75,7775,1)) From TRCPROCOM
      Raz RMES
      Return
    Endif
  Endif

  If [F:TMP1]UNLINK=G_NON or (ACTTYPGES=GTAMUNI and [F:TMP1]OBJREF=[M:FAS0]AASREF)   # BCO principal ou composant à sortir
    If [M:FASS]CCLISSFLG=G_NON Then
      # Recalcul des informations de sorties
      # FQ79623 : ajout du statut du bien
      Call MAJ_INFOS_SORTIE("[F:TMP1]","SOR",[F:TMP1]ACGBSEVAL,[F:TMP1]IASBSEVAL,
&      [F:TMP1]VALNET,CPYCUR,G_OUI, [F:TMP1]CMPSTA) From TRTFASISS2
    Endif

    # Mise à jour FLGUDPISS sur la période courante des DEPREC des plans
    If (ACTTYPGES=GTAMMAS | (ACTTYPGES=GTAMUNI & IS_OBJ_MAIN<>G_OUI))

      # FQ49106
      [F:MAS1]VATREGDED += [F:TMP1]ACGCPLDED
      [F:MAS1]VATREGAMT += [F:TMP1]ACGREVVAT
      [F:MAS1]VATREGDEDI+= [F:TMP1]IASCPLDED
      [F:MAS1]IASVATREG += [F:TMP1]IASREVVAT

      For [CNX]CNX0 Where CPY=[F:TMP1]CPY
        Read [FIS]FIY1=[F:CNX]CPY;[F:CNX]CNX;GVML_TECOURA
        For I_PLN=1 To [F:CNX]NBPLC
          Read [DEP]DEP0=[F:TMP1]OBJREF;[F:CNX]PLNCAA(I_PLN-1);[F:FIS]DATENDFIY;[F:FIS]DATENDPER([F:FIS]INDCURPER-1)
          If fstat
            GOK=0
            Break
          Endif

          If [M:FASS]CCLISSFLG=G_NON
            # Récupération du DEPREC courant dans le masque du plan
            #FQ89830
            Call GET_DEPREC_FROM_MASK([F:CNX]PLNCAA(I_PLN-1), [F:FIS]DATENDPER([F:FIS]INDCURPER-1), CODERR) From TRTFASISS2
            # Pas de test de CODERR car si on ne trouve pas le DEPREC il sera de toute façon recalculé.

          # FQ84213
          Elsif [M:FASS]CCLISSFLG=G_OUI
            # Annulation
            Local File EFASISS [WEVT]
            Filter [F:WEVT] Where (CPY=[F:DEP]CPY & DPRPLN=[F:DEP]DPRPLN & REF=[F:DEP]AASREF & SNSEVE<>GVML_TEAACT)
            Read [F:WEVT] Last
            If !fstat & [F:WEVT]SNSEVE=GVML_TEACT
              # FQ84213_2
              Local Integer LERR
              Call CONTROLE_DATE_SORTIE( [F:DEP]CPY, [F:WEVT]SORREG , G_NON, LERR ) From TRTFAS
              If LERR=11
                # FQ122633
                # Annulation de sortie rétroactive
                #[F:DEP]IMLBLC = [F:WEVT]IMLRVEISS
                If ([F:WEVT]CURPERSTR <> [F:DEP]PERSTRDAT) Then
                  [F:DEP]IMLBLC = [F:WEVT]IMLRVEISS
                Endif
              Endif
            Endif
            Filter [WEVT] #FQ97433
            Close File [WEVT]
          Endif

          [F:DEP]FLGUPDISS = G_OUI

          # Le bien devra être recalculé
          [F:MAS1]FLGCNXCLC([F:CNX]CNX-1) = G_OUI
          [F:DEP]DEPSTA                   = GVML_SCNOCAL

          #-> Si nécessaire, annulation de la dépréciation de la période
          #   Appel systématique car la fonction intègre le contrôle
          If [M:FASS]CCLISSFLG = G_NON and [M:FASS]EXTISSFLG = G_NON and [F:CNX]PLNSTD(I_PLN-1) <> GVML_NPSTD
            Call EXT_CANCEL_IML_DEP ("[F:DEP]", CODERR) From TRTFASIML
            If CODERR > 0 and CODERR <> 3
              GOK  = 0
              RMES = mess(634,GML_MSGFAS,1)-[F:DEP]AASREF-mess([F:DEP]DPRPLN,3101,1) : # Erreur lors de l'annulation de la dépréciation
              Break
            Endif
          Endif

          Rewrite [F:DEP]
          If fstat
            GOK=0
            Break
          Endif
        Next I_PLN
      Next
      If GOK<1 : Return : Endif
    Else # Bien principal en unitaire
      If [M:FASS]CCLISSFLG = G_NON and [M:FASS]EXTISSFLG = G_NON
        For [CNX]CNX0 Where CPY=[F:TMP1]CPY
          Read [FIS]FIY1=[F:CNX]CPY;[F:CNX]CNX;GVML_TECOURA
          For I_PLN=1 To [F:CNX]NBPLC
            If [F:CNX]PLNSTD(I_PLN-1) <> GVML_NPSTD
              #-> Si nécessaire, annulation de la dépréciation de la période
              #   Appel systématique car la fonction intègre le contrôle
              Read [DEP]DEP0=[M:FAS0]AASREF;[F:CNX]PLNCAA(I_PLN-1);[F:FIS]DATENDFIY;[F:FIS]DATENDPER([F:FIS]INDCURPER-1)
              If fstat
                GOK=0
                Break
              Endif

              nolign=find([F:CNX]PLNCAA(I_PLN-1),[M:FAS3]DPRPLN)
              [F:DEP] = [M:FAS3]

              Call EXT_CANCEL_IML_DEP ("[F:DEP]", CODERR) From TRTFASIML
              If CODERR > 0 and CODERR <> 3
                GOK  = 0
                RMES = mess(634,GML_MSGFAS,1)-[F:DEP]AASREF-mess([F:DEP]DPRPLN,3101,1) : # Erreur lors de l'annulation de la dépréciation
                Break
              Endif

              [M:FAS3] = [F:DEP]
            Endif
          Next
        Next
      Endif
    Endif

    If (ACTTYPGES=GTAMUNI)
      Local Char LPARAM
      If !clalev([F:LOF]) : Local File LAYOUTFAS    : Endif
      Filter[LOF] Where (AASREF = [F:MAS1]AASREF) & (FLGGRA=G_OUI)
      For [LOF] With Stability
        If  [M:FASS]CCLISSFLG <> G_OUI  # Sortie du bien
          [F:LOF]FLGAMTGRA = G_OUI
        Else                            # Annulation de la sortie du bien
          Local Integer LGRT : # X3-104535
          LGRT = func AFNC.ACTIV("GRT")
          If LGRT = G_OUI
            # FQ91644 ajout de [F:LOF]CPY
            Call PARAM([F:LOF]CPY ,"GRTPRVUPD",LPARAM) From ADOVAL
            LGRTPRVUPD = val(LPARAM)
            # si Remise en cause subvention ant.
            If LGRTPRVUPD = G_OUI
             [F:LOF]FLGAMTGRA = G_NON
            Else # si non Remise en cause subvention ant.mais pas de clôture
              Filter [DEP] Where (CPY=[F:MAS1]CPY) & (AASREF= [F:MAS1]AASREF)  & (LSTCLODAT > [0/0/0])
              Read [DEP]First
              If fstat
                [F:LOF]FLGAMTGRA = G_NON
              Endif
              Filter [DEP]
            Endif
          Endif  : # X3-104535
        Endif
        Rewrite [F:LOF]
        If fstat
          GOK=0
          Break
        Endif
      Next
      Filter [LOF]
    Endif : # fin If (ACTTYPGES=GTAMUNI)

    # Sauvegarde des infos nécessaires à l'annulation des événements de sortie
    If [M:FASS]CCLISSFLG = G_OUI
      WK_CPY       = [F:MAS1]CPY
      WK_FCY       = [F:MAS1]FCY
      WK_AASREF    = [F:MAS1]AASREF
      WK_ISSDAT    = [F:MAS1]ISSDAT
      WK_EXTISSFLG = [F:MAS1]EXTISSFLG
    Endif

    # Report des informations
    [F:MAS1]ISSTYP     = [F:TMP1]ISSTYP
    [F:MAS1]ISSDATRUL  = [F:TMP1]ISSDATRUL
    [F:MAS1]R76COE     = [F:TMP1]R76COE
    [F:MAS1]ISSDAT     = [F:TMP1]ISSDAT
    [F:MAS1]PYBVATTYP  = [F:TMP1]PYBVATTYP
    [F:MAS1]ISSVATRAT  = [F:TMP1]ISSVATRAT
    [F:MAS1]ISSVATAMT  = [F:TMP1]ISSVATAMT
    [F:MAS1]EXTISSFLG  = [F:TMP1]EXTISSFLG
    [F:MAS1]ACGCPLDED  = [F:TMP1]ACGCPLDED
    [F:MAS1]IASCPLDED  = [F:TMP1]IASCPLDED
    [F:MAS1]SALCLSDAT  = [F:TMP1]SALCLSDAT  #FQ95754_7
    # FQ 46680 Nouvelles règles TVA
    [F:MAS1]ISSVATTRF  = [F:TMP1]ISSVATTRF
    [F:MAS1]ISSVATTRFI = [F:TMP1]ISSVATTRFI
    # FQ49106
    [F:MAS1]VATREGAMT   = [F:TMP1]VATREGAMT
    [F:MAS1]VATREGDED   = [F:TMP1]VATREGDED
    [F:MAS1]IASVATREG   = [F:TMP1]IASVATREG
    [F:MAS1]VATREGDEDI  = [F:TMP1]VATREGDEDI

    [F:MAS1]ACGREVVAT  = [F:TMP1]ACGREVVAT
    [F:MAS1]IASREVVAT  = [F:TMP1]IASREVVAT

    # Le bien devra être recalculé
    [F:MAS1]FLGCLC     = G_OUI

    # Les provision sont à recalculer pour un bien en concession
    If G_ACTCCN=G_OUI & [F:MAS1]OWNTYP=GVML_TDCONCE
     [F:MAS1]FLGRPRCLC = G_OUI
    Endif

    # Reprise de dérogatoire sur sortie FQ57971
    [F:MAS1]DERRVEISS  = [F:TMP1]DERRVEISS

    For N_PLN = 1 To G301MAX-1
      [F:MAS1]ISSAMT    (N_PLN-1) = [F:TMP1]ISSAMT    (N_PLN-1)
      [F:MAS1]GAL       (N_PLN-1) = [F:TMP1]GAL       (N_PLN-1)
      [F:MAS1]SHOGAL    (N_PLN-1) = [F:TMP1]SHOGAL    (N_PLN-1)
      [F:MAS1]LNGGAL    (N_PLN-1) = [F:TMP1]LNGGAL    (N_PLN-1)
      [F:MAS1]IMLRVEISS (N_PLN-1) = [F:TMP1]IMLRVEISS (N_PLN-1)
    Next N_PLN
    [F:MAS1]BUY        = [F:TMP1]BUY
    [F:MAS1]IVCSALISS  = [F:TMP1]IVCSALISS
    [F:MAS1]FLGUPDISS  = G_OUI             # Flag de modification de sortie

    [F:MAS1]UPDUSR=GUSER #FQ104286
    [F:MAS1]UPDDAT=date$ #FQ104286

     #FQ95754_7 si sortie d'un bien classé pour vente : on réinitialise date et montant de vente attendus
     If  [F:MAS1]SALCLSDAT<> [0/0/0]
       G_SALCLS = G_OUI
       [F:MAS1]SALCLSDAT = [0/0/0]
       [F:MAS1]EXTSALAMT = 0
     Endif  #FQ95754_7 END

    #--> Si le bien est en "crédit bail" ou en contrat de location financement, on le détache du contrat
    # Ne pas supprimer le rattachement à LEA si la sortie est prévisionnelle
    #Fq-68457 ou si type de sortie=contrat résilié
    #Fq-68457 If [F:MAS1]EXTISSFLG<>G_OUI
    #Fq-68457 If ( [F:MAS1]EXTISSFLG<>G_OUI )
    If ( [F:MAS1]EXTISSFLG<>G_OUI ) and ( [F:MAS1]ISSTYP <> GVML_TSCRESI )
      If (([F:MAS1]OWNTYP=GVML_TDLOCAT | [F:MAS1]OWNTYP=GVML_TDCBAIL) & ([F:MAS1]LEAREF<>""))
        [F:MAS1]LEAREFORI=[F:MAS1]LEAREF
        Raz [F:MAS1]LEAREF
      Endif
    Endif

    # UNITAIRE ==> On crée les lignes BIC puis l'entête dans la foulée
    #Fq-67621 Création d'une facture 1/ client si :
    #          - Sortie (pas en annulation de sortie)
    #          - Paramètre SALINV (Facture de vente à produire) = "oui" (globale G_SALINV)
    #          - Type de sortie ="Vente"
    #          - sortie non prévisionnelle ==> EXTISSFLG = "non"
    #*Fq-91395 - il ne s'agit pas d'1 Import
    If !GIMPORT
      #YYFIN_119079
      Local Char XPARAM(10)
      Call PARAM([F:MAS1]CPY,"SALINV",XPARAM) From ADOVAL
      G_SALINV=val(XPARAM)
      #YYFIN_119079 End
      If   ( [M:FASS]ISSTYP =  GVML_TSVENTE ) and  ( [M:FASS]ISSAMTTYP<> GVML_TVAUCUN ) and ( G_SALINV = G_OUI ) and  ( [M:FASS]CCLISSFLG = G_NON )
       # En unitaire ========================================
       If ( ACTTYPGES = GTAMUNI ) and   ( [M:FASS]EXTISSFLG <> G_OUI )
             If G_TOTISSAMT <> 0 or (G_TOTISSAMT=0 and [F:MAS1]ISSAMT(0) <> 0)
               WPARAM= "[F:MAS1]"
               Call CRE_LINES_BIC(WPARAM) From TRTFAS
               If GOK<1
                  # Impossible de générer la facture tiers client : abandon de la vente
                  GMESSAGE= mess(899,GML_MSGFAS, 1)
                  GOK=0
                  Return
               Else
                  [M:FAS4]IVCSALISS =  G_WNUMBIC
                  [F:MAS1]IVCSALISS =  G_WNUMBIC
               Endif
         Endif
       Else # Massif par contrôler
          If ( ACTTYPGES = GTAMMAS ) and  ( [M:FASS]EXTISSFLG <> G_OUI )
            #YYFIN_119079
            Local Char XPARAM(10)
            Call PARAM([F:TMP1]CPY,"SALINV",XPARAM) From ADOVAL
            G_SALINV=val(XPARAM)
            #YYFIN_119079 End
            If TOTOBJAMT(0) <> 0 and  G_TOTBICCOK= G_OUI and ( G_SALINV = G_OUI )
                WPARAM="[F:TMP1]"
                Call CRE_LINES_BIC(WPARAM) From TRTFAS
                If GOK<1
                  # Impossible de générer la facture tiers client : abandon de la vente
                   GMESSAGE= mess(899,GML_MSGFAS,1)
                   GOK=0
                   Return
                Else
                   [F:TMP1]IVCSALISS =  G_WNUMBIC
                   [F:MAS1]IVCSALISS =  G_WNUMBIC
                Endif
             Endif
          Endif
       Endif
  Endif
  Endif  #* Fq-91395 END


    #--> Génération des événements
    If ((ACTTYPGES=GTAMUNI) | (ACTTYPGES=GTAMMAS & FLGSIM<>G_OUI))
      If [M:FASS]CCLISSFLG = G_OUI & WK_EXTISSFLG<>G_OUI
        Gosub ANNULE_EVE_ISS
        If GOK<1
          Return
        Endif
        If G_ACTCCN=G_OUI & [F:MAS1]OWNTYP=GVML_TDCONCE
         Gosub ANNULE_EVE_CCNISS
         If GOK<1
           Return
         Endif
        Endif
      Else
        If GOK  #FQ104997
          Call GENERE_EVE_ISS("[F:MAS1]")
        Endif #FQ104997
        # Fq54343 - Génération de l'événement de sortie / Provisions si gestion des concessions et bien en concession
        #FQ104997 If G_ACTCCN=G_OUI & [F:MAS1]OWNTYP=GVML_TDCONCE
        If GOK & G_ACTCCN=G_OUI & [F:MAS1]OWNTYP=GVML_TDCONCE
         Call GENERE_EVE_CCNISS("[F:MAS1]")
        Endif
      Endif
    Endif

    #
    #
    #--> Message dans la trace si traitement massif :
    #    référence du bien, informations de sortie particulière à chaque bien
    If ACTTYPGES = GTAMMAS
      If [M:FASS]CCLISSFLG = G_OUI   # Annulation de sortie
        #*Fq-67621  Call BCO_COMPTE_RENDU([F:MAS1]CPY,[F:MAS1]AASREF,[F:MAS1]AASDES1,"Ok",mess(228,GML_MSGFAS,1))
        Call BCO_COMPTE_RENDU([F:MAS1]CPY,[F:MAS1]AASREF,[F:MAS1]AASDES1,"Ok",mess(228,GML_MSGFAS,1)) From TRTFAS
      Elsif [M:FASS]CCLISSFLG = G_NON   # Sortie
        # On récupére la valeur nette comptable
        Local Decimal NBV_CPT
        Read [TPFW]TPF0=NUMACT;[F:MAS1]AASREF;G301CPT
        If !fstat
          NBV_CPT=[F:TPFW]NBV
        Endif
        # Construction de la ligne à émettre dans la trace
        Local Char LIGNE(115)
        LIGNE=space$(18-len(format$('N:'+GFMT3,[F:MAS1]ISSAMT(0))))+format$('N:'+GFMT3,[F:MAS1]ISSAMT(0))
&            +space$(18-len(format$('N:'+GFMT3,[F:MAS1]ISSVATAMT)))+format$('N:'+GFMT3,[F:MAS1]ISSVATAMT)
&            +space$(18-len(format$('N:'+GFMT3,NBV_CPT)))+format$('N:'+GFMT3,NBV_CPT)
&            +space$(18-len(format$('N:'+GFMT3,[F:MAS1]GAL(G301CPT-1))))+format$('N:'+GFMT3,[F:MAS1]GAL(G301CPT-1))
&            +space$(18-len(format$('N:'+GFMT3,[F:MAS1]GAL(G301FIS-1))))+format$('N:'+GFMT3,[F:MAS1]GAL(G301FIS-1))
        # "Sortie"
        #*Fq-67621  Call BCO_COMPTE_RENDU([F:MAS1]CPY,[F:MAS1]AASREF,[F:MAS1]AASDES1,"Ok",LIGNE)
        Call BCO_COMPTE_RENDU([F:MAS1]CPY,[F:MAS1]AASREF,[F:MAS1]AASDES1,"Ok",LIGNE) From TRTFAS
      Endif
    Endif

    #---------------------- Appel de la prcocédure de gestion de l'élément phy --------------------------
    # Issue 102073: Is there Physical element(s) for the asset?
    If (GPHY=G_OUI) and (func PHYELT_C_MPR._GET_SELECTED_PHY_NBR("AASREF = '" + [F:MAS1]AASREF + "'")>0)
      Gosub SORTIE_ELT_PHY From TRTFASISS2 : # FQ122633
    Endif
    # End issue 1020733

  Elsif [F:TMP1]UNLINK=G_OUI            # Il s'agit d'un composant à détacher
    [F:MAS1]CMPSTA     = GVML_SBAUTON    # Le composant devient autonome
    [F:MAS1]CMPORI     = [F:MAS1]CMP     # On sauvegarde le principal
    Raz [F:MAS1]CMP                      # On supprime la référence au bien principal
    If ACTTYPGES = GTAMMAS
      #--> Message dans la trace si traitement massif :
      #    référence du bien, message informant du détachement du bien
      # "Bien détaché"
      #*Fq-67621  Call BCO_COMPTE_RENDU([F:MAS1]CPY,[F:MAS1]AASREF,[F:MAS1]AASDES1,"Ok",mess(232,GML_MSGFAS,1))
      Call BCO_COMPTE_RENDU([F:MAS1]CPY,[F:MAS1]AASREF,[F:MAS1]AASDES1,"Ok",mess(232,GML_MSGFAS,1))  From TRTFAS
    Endif
  Endif

Return
#=====================================================================
# Unitaire / massif : Report du contenu de la table temporaire principale dans la table de données principale
$TPF1_ALIM_TABLE
Return
#=====================================================================
# Unitaire / massif : Fin du report tmp -> données
$END_ALIM_TABLE

   Local Char WPARAM #*Fq-67621

   #YYFIN_119079
   Local Char XPARAM(10)
   If  ( ACTTYPGES = GTAMUNI ) #<<< Unitaire
     Call PARAM([F:MAS1]CPY,"SALINV",XPARAM) From ADOVAL
   Else                        #<<< Massif
     Call PARAM([F:TMP1]CPY,"SALINV",XPARAM) From ADOVAL
   Endif
   G_SALINV=val(XPARAM)
   #YYFIN_119079 End

   #* Fq-91395... si l'on n'est pas en Import
   If !GIMPORT
   If  (GOK) and  ( [M:FASS]CCLISSFLG = G_NON )  and (G_HBIC_OK <> G_OUI) and
&                 ( [M:FASS]ISSTYP =  GVML_TSVENTE ) and  ( [M:FASS]ISSAMTTYP <> GVML_TVAUCUN ) and ( G_SALINV = G_OUI )
      #*Fq-67621  En unitaire si le bien a des composants et que l'on n'est pas en annulation de sortie
      #* on crée ici l'entête facture (en fin de traitement)
      If  ( ACTTYPGES = GTAMUNI ) #<<< Unitaire
         If TOT_BICC <> 0
            WPARAM ="[F:MAS1]"
            Call CRE_HEADER_BIC(WPARAM) From TRTFAS
            If GOK<1
               GOK=0
               [F:MAS1]IVCSALISS = ""
            Endif
         Else
            [F:MAS1]IVCSALISS = G_WNUMBIC
         Endif
      Else  #<<< Massif
         #*Fq-67621  En massif si on est passé par contrôler.....on crée ici l'entête facture (en fin de traitement)
         If TOT_BICC <> 0 and G_TOTBICCOK= G_OUI
            WPARAM ="[F:TMP1]"
            Call CRE_HEADER_BIC(WPARAM) From TRTFAS
            If GOK<1
               GOK=0
               [F:TMP1]IVCSALISS = ""
            Endif
         Else
            [F:TMP1]IVCSALISS = G_WNUMBIC
         Endif
      Endif
   Endif
   Endif #* Fq-91395 END

Return
#=====================================================================
# Unitaire / massif : Fermeture de table annexes pour le report tmp -> données
$CLOS_ALIM_TABLE

 #Fq-67621 Gosub CLOS_EVE
 Gosub CLOS_EVE From TRTFAS

Return

#=====================================================================
# Unitaire / massif : Report du contenu de la table temporaire principale dans la table de données principale
$VISU_LOAD_PLAN
 [M:MFS0]NBV(nolign-1)    = [F:TPF]NBV

 Read [F:MFS]MFS0=[F:TPF]TRTNUM;[F:TPF]OBJREF
 [M:MFS0]GAL(nolign-1)    = [F:MFS]GAL([F:TPF]DPRPLN-1)
 [M:MFS0]SHOGAL(nolign-1) = [F:MFS]SHOGAL([F:TPF]DPRPLN-1)
 [M:MFS0]LNGGAL(nolign-1) = [F:MFS]LNGGAL([F:TPF]DPRPLN-1)
Return

#=====================================================================
# Unitaire / massif : Report du contenu de la table temporaire principale dans la table de données principale
$VISU_SAVE_PLAN
 [F:TPF]NBV                     = [M:MFS0]NBV(nolign-1)

 Read [F:MFS]MFS0=[F:TPF]TRTNUM;[F:TPF]OBJREF
 [F:MFS]GAL([F:TPF]DPRPLN-1)    = [M:MFS0]GAL(nolign-1)
 [F:MFS]SHOGAL([F:TPF]DPRPLN-1) = [M:MFS0]SHOGAL(nolign-1)
 [F:MFS]LNGGAL([F:TPF]DPRPLN-1) = [M:MFS0]LNGGAL(nolign-1)
 Rewrite [F:MFS] Curr
Return


######################################################################
# Points d'entrée objet de reprise
######################################################################
#{ET_REP}#
#=====================================================================
# Traitement du tableau des infos par plan de l'objet de reprise.
#=====================================================================

$MFS_LIENS0
 Local Char CPYDES

 If ACTTYPGES=GTAMMAS
  Call GET_CPY_CUR([M:MHC]CPY(find(G_OUI,[M:MHC]FLGCPY)-1),[M:MFS0]CPYDEV,CPYDES) From GLOFCYCPY
 Elsif ACTTYPGES=GTAMUNI
  Call GET_CPY_CUR([M:FAS0]CPY,[M:MFS0]CPYDEV,CPYDES) From GLOFCYCPY
 Endif

Return

#=====================================================================
$MFS_LIENS
 [M:MFS0]ISSAMT0(nolign-1) = [F:MFS]ISSAMT(0)

 If [M:FASS]ISSVATRAT = 0
   [M:MFS0]ACGCPLDED(nolign-1) = [M:MFS0]ACGREVVAT(nolign-1)
   If GCNXPROIAS = G_OUI : [M:MFS0]IASCPLDED(nolign-1) = [M:MFS0]IASREVVAT(nolign-1) : Endif
 Endif
Return

#=====================================================================
MFS_LIENS2
 Sorta [M:MFS0]NBOBJ [M:MFS0]NBOBJ Order By [M:MFS0]CMP1([S]indice),[M:MFS0]OBJREF([S]indice)

 #Gbn-260405-Bug n°29954-Si annulation de sortie, on ne peut rien modifier sur l'écran de contrôle
 If [M:FASS]CCLISSFLG=G_OUI
  Grizo [M:MFS0]
 Endif
Return

#=====================================================================
MFS_INICRE
  [F:MFS]ISSAMT(0) = [M:MFS0]ISSAMT0(nolign-1)
Return

#=====================================================================
# Traitement du tableau des infos par plan de l'objet de reprise.
#=====================================================================

#==============================================================#
# Cette action est appelée pour chaque enregistrement lu dans  #
# la table temporaire par plan pour l'objet métier sur lequel  #
# on vient de cliquer.                                         #
# Alimenter ici les zones du tableau par plan spécifique à l'  #
# action                                                       #
# Table temporaire -> [F:TPF]   | Pour les BCO                 #
# Masque           -> [M:MFS0]  |                              #
# ligne courante   -> nolign    |                              #
#==============================================================#

$LOADPLN
 [M:MFS0]PLNCUR(nolign-1)    = [F:TPF]PLNCUR
 [M:MFS0]NBV(nolign-1)       = [F:TPF]NBV
 [M:MFS0]FIYENDDAT(nolign-1) = [F:TPF]FIYENDDAT
 [M:MFS0]PERENDDAT(nolign-1) = [F:TPF]PERENDDAT

 Read [F:MFS]MFS0=[F:TPF]TRTNUM;[F:TPF]OBJREF
 [M:MFS0]GAL(nolign-1)    = [F:MFS]GAL([F:TPF]DPRPLN-1)
 [M:MFS0]SHOGAL(nolign-1) = [F:MFS]SHOGAL([F:TPF]DPRPLN-1)
 [M:MFS0]LNGGAL(nolign-1) = [F:MFS]LNGGAL([F:TPF]DPRPLN-1)
Return

#==============================================================#
# Cette action est appelée pour chaque enregistrement de la    #
# table temporaire à mettre à jour.                            #
# Alimenter ici les zones spécifiques à l'action de la table   #
# temporaire par plan à partir des zones du tableau par plan   #
# Table temporaire -> [F:TPF]   | Pour les BCO                 #
# Masque           -> [M:MFS0]  |                              #
# ligne courante   -> nolign    |                              #
#==============================================================#

$SAVEPLN
 [F:TPF]PLNCUR    = [M:MFS0]PLNCUR(nolign-1)
 [F:TPF]NBV       = [M:MFS0]NBV(nolign-1)
 [F:TPF]FIYENDDAT = [M:MFS0]FIYENDDAT(nolign-1)
 [F:TPF]PERENDDAT = [M:MFS0]PERENDDAT(nolign-1)

 Read [F:MFS]MFS0=[F:TPF]TRTNUM;[F:TPF]OBJREF
 [F:MFS]GAL([F:TPF]DPRPLN-1)    = [M:MFS0]GAL(nolign-1)
 [F:MFS]SHOGAL([F:TPF]DPRPLN-1) = [M:MFS0]SHOGAL(nolign-1)
 [F:MFS]LNGGAL([F:TPF]DPRPLN-1) = [M:MFS0]LNGGAL(nolign-1)
 Rewrite [F:MFS] Curr
Return

################################################################################
# Traitement de gestion de la trace - informations particulières à l'action    #
################################################################################
#{ET_GESTRACE}#
$GESTRACE
 Local Char MES_ACTION(100)
 Case TRTYP
  When 1         # Ouverture de la trace
   If ACTSILENCE<>G_OUI
    If !clalev([F:XTRA]) : Local File TRCABX3 [XTRA] : Endif
    Call OUVRE_TRACE(mess(229,GML_MSGFAS,1),1) From TRACEABX3  # "Sortie"
   Endif
  When 20        # Paramètres de l'action
   If ACTSILENCE<>G_OUI
    If [M:FASS]CCLISSFLG=G_NON
     Call  ECR_TRACE("",GTRC_PARAM,left$(mess(356,GML_MSGFAS,1)+space$(28),28)+":"-mess([M:FASS]ISSCMPFLG,1,1),0,1) From TRACEABX3                    # "Sortie des biens composants
     Call  ECR_TRACE("",GTRC_PARAM,left$(mess(357,GML_MSGFAS,1)+space$(28),28)+":"-mess([M:FASS]EXTISSFLG,1,1),0,1) From TRACEABX3                    # "Sortie prévisionnelle"
     If GPHY = G_OUI Then : # FQ51962
       Call  ECR_TRACE("",GTRC_PARAM,left$(mess( 79,7775,1)+space$(35),35)+":"-mess([M:FASS]ECRPHYATT,1,1),0,1) From TRACEABX3                    # "ecraser les mvt en attente"
     Endif
     Call  ECR_TRACE("",GTRC_PARAM,left$(mess(358,GML_MSGFAS,1)+space$(28),28)+":"-format$("D:DD[ ]MMMMMMMMMM4Y",[M:FASS]ISSDAT),0,1) From TRACEABX3  # "Date de sortie"
     Call  ECR_TRACE("",GTRC_PARAM,left$(mess(2959,200,1)+space$(28),28)+":"-mess([M:FASS]ISSTYP,3159,1),0,1) From TRACEABX3                     # "Motif de sortie"
# FQ67621
#     Call  ECR_TRACE("",GTRC_PARAM,left$(mess(005,693,1)+space$(28),28)+":"-[M:FASS]BUY-[M:FASS]ZBUY,0,1) From TRACEABX3                       # "Acheteur"
     Call  ECR_TRACE("",GTRC_PARAM,left$(mess(005,693,1)+space$(28),28)+":"-[M:FASS]BUY,0,1) From TRACEABX3                       # "Acheteur"
     #Gbn-220305-Bug n°27906
     Call  ECR_TRACE("",GTRC_PARAM,left$(mess(429,GML_MSGFAS,1)+space$(28),28)+":"-[M:FASS]IVCSALISS,0,1) From TRACEABX3                             # "Facture de vente"
      If [M:FASS]ISSAMTTYP=1
       Call ECR_TRACE("",GTRC_PARAM,mess(359,GML_MSGFAS,1),0,1) From TRACEABX3                                       # "Aucun montant de vente"
      Elsif [M:FASS]ISSAMTTYP=2
       Call ECR_TRACE("",GTRC_PARAM,"",0,1) From TRACEABX3
       Call ECR_TRACE("",GTRC_PARAM,left$(mess(360,GML_MSGFAS,1)+space$(28),28)+":",0,1) From TRACEABX3   # "Calcul du montant de vente"
       Call ECR_TRACE("",GTRC_PARAM,string$(len(mess(360,GML_MSGFAS,1)),"-"),0,1) From TRACEABX3                     #"--------------------------"
       Call ECR_TRACE("",GTRC_PARAM,"    "-mess(361,GML_MSGFAS,1)-format$('N:'+GFMT3,[M:FASS]ISSAMT(0))-"",0,1) From TRACEABX3        # Montant saisi
      MES_ACTION=mess(362,GML_MSGFAS,1)-mess([M:FASS]BRDTYP,3231,1)                                                   # "Ventilé selon la"
       If [M:FASS]BRDTYP=1
        MES_ACTION-=mess([M:FASS]BRDPLN,3101,1)
       Endif
       Call ECR_TRACE("",GTRC_PARAM,"    "-MES_ACTION,0,1) From TRACEABX3
      Elsif [M:FASS]ISSAMTTYP=3
       Call ECR_TRACE("",GTRC_PARAM,"",0,1) From TRACEABX3
       Call ECR_TRACE("",GTRC_PARAM,left$(mess(360,GML_MSGFAS,1)+space$(28),28)+":",0,1) From TRACEABX3   # "Calcul du montant de vente"
       Call ECR_TRACE("",GTRC_PARAM,string$(len(mess(360,GML_MSGFAS,1)),"-"),0,1) From TRACEABX3                     # "--------------------------"
       Call ECR_TRACE("",GTRC_PARAM,"    "-mess([M:FASS]ISSAMTTYP,3230,1)-mess([M:FASS]VALPLN,3101,1),0,1) From TRACEABX3
      Endif
      Call ECR_TRACE("",GTRC_PARAM,"",0,1) From TRACEABX3
      Call ECR_TRACE("",GTRC_PARAM,left$(mess(363,GML_MSGFAS,1)+space$(28),28)+":",0,1) From TRACEABX3                           # "Calcul de la TVA sur vente"
      Call ECR_TRACE("",GTRC_PARAM,string$(len(mess(363,GML_MSGFAS,1)),"-"),0,1) From TRACEABX3
      MES_ACTION=mess([M:FASS]PYBVATTYP,3160,1)
      Call ECR_TRACE("",GTRC_PARAM,"    "-MES_ACTION,0,1) From TRACEABX3
    Elsif [M:FASS]CCLISSFLG=G_OUI
     Call ECR_TRACE("",GTRC_PARAM,mess(365,GML_MSGFAS,1),0,1) From TRACEABX3                                      # "Annulation de sortie"
    Endif
    Call ECR_TRACE("",GTRC_PARAM,"",0,1) From TRACEABX3
   Endif
  When Default
 Endcase
Return

# FQ69691 ajout pour import des mvts
$IMP_MVT
Local Char WWIMPZON

    WWIMPZON = IMPZON

    Case IMPZON
        When "ISSDAT"
            If WDATE <> [M:FAS4]ISSDAT
                IMPMOD = 1
            Endif
        When "ISSTYP"
            If WNUM <> [M:FAS4]ISSTYP
                IMPMOD = 1
            Endif
        When "ISSAMTTYP"
            If WNUM <> 0
                IMPMOD = 1
            Endif
        When "ISSAMT"
# Tjrs le 1° plan ?
        # FQ69691B
            If WNUM <> [M:FAS4]ISSAMT(0) or [M:FASS]FGISSAMT = G_OUI
                IMPMOD = 1
            Endif
# tx de tva sur vente
        # FQ69691B
        When "ISSVATRAT"
            If [M:FASS]FGISSVAT = G_OUI
                IMPMOD = 1
            Endif
        When "PYBVATTYP"
            If WNUM <> [M:FAS4]PYBVATTYP
                IMPMOD = 1
            Endif
        When "IVCSALISS"
            If WCHAR <> [M:FAS4]IVCSALISS
                IMPMOD = 1
            Endif
        When "BUY"
            If WCHAR <> [M:FAS4]BUY
                IMPMOD = 1
            Endif
        #FQ100398/16
        When "SIVTYP"
            If WCHAR <> ""
                IMPMOD = 1
            Endif
        When Default
    Endcase

    # si champ ds la liste (et valorisé) : il a forcément été paramétré : donc modifié
    If IMPMOD <> 1
        If find(WWIMPZON, GRUBALIM(1..GNBRUBALIM))
            IMPMOD = 1
        Endif
    Endif

Return
######################################################################
# Sous-programmes communs
######################################################################
#{SOUPRO}#

#--------------------------------------------------------------#
# S/P de calcul de la valeur nette comptable d'un BCO et des   #
# différents montants au moment de la sortie                   #
#--------------------------------------------------------------#
Subprog CALCULER_VALEURS_SORTIE (PCLASSE, PISSTYP, PISSDAT, RVALNETTE, RSORREG, RSORREGT, RSORREGI, RERROR)
Value    Char    PCLASSE
Value    Integer PISSTYP
Value    Date    PISSDAT
Variable Decimal RVALNETTE(0..)
Variable Date    RSORREG (0..G301MAX-1)
Variable Date    RSORREGT(0..G301MAX-1)
Variable Date    RSORREGI(0..G301MAX-1)
Variable Integer RERROR

Local Shortint   N_PLN

 Raz RVALNETTE, RERROR

 If !clalev([F:WFAS]) : Local File FXDASSETS [WFAS] : Endif

 #*FQ107128 If find(PCLASSE,"[F:MAS1]","[F:MAS2]","[F:FASS]", "[F:FAS]")
 #* X3-110500  If find(PCLASSE,"[F:MAS1]","[F:MAS2]","[F:FASS]", "[F:FAS]", "[F:TRT]")
 If find(PCLASSE,"[F:MAS1]","[F:MAS2]","[F:FASS]", "[F:FAS]", "[F:TRT]", "[F:FASM]")
   Read [WFAS]FAS0=evalue(PCLASSE+"AASREF")
 Else
   Read [WFAS]FAS0=evalue(PCLASSE+"OBJREF")
 Endif

 # Chargement des informations pour le calcul de la valeur nette
 [F:WFAS]ISSDAT    = PISSDAT
 [F:WFAS]ISSTYP    = PISSTYP
 [F:WFAS]ISSDATRUL = [M:FASS]ISSDATRUL
 [F:WFAS]R76COE    = [M:FASS]R76COE
 [F:WFAS]EXTISSFLG = [M:FASS]EXTISSFLG
 [F:WFAS]ISSVATRAT = [M:FASS]ISSVATRAT
 [F:WFAS]PYBVATTYP = [M:FASS]PYBVATTYP

 For N_PLN = 1 To G301MAX-1
   [F:WFAS]ISSAMT(N_PLN-1) = evalue(PCLASSE+"ISSAMT(N_PLN-1)")
 Next

 # Détermination des valeurs nettes à la date PISSDAT, renvoyées dans la variable dimensionnée RVALNETTE

 # Approche pessimiste, pour prendre en compte le cas d'une erreur système
 #==
 # où dans cette situation on sort du sous programme sans récupérer RERROR.
 # Si tout se passe bien RERROR sera restitué à 0 dans le cas contraire,
 # s'il s'agit d'une erreur logique elle sera récupérée via le paramètre
 # s'il s'agit d'une erreur système elle n'est pas passée via le paramètre
 RERROR = 1
 #==
 Call SIMULER_VALEUR_NETTE(PISSDAT, G_NON, RVALNETTE, RSORREG, RSORREGT, RSORREGI, RERROR) From GLOBB
 Onerrgo ERREUR_SP From TRCPROCOM
End



#--------------------------------------------------------------#
# Emission de l'en-tête du tableau de compte-rendu dans la     #
# trace                                                        #
#--------------------------------------------------------------#
Subprog ET_COMPTE_RENDU(PCPY)    #
Value Char PCPY

  Local Char LIGNE(115)
  If ACTSILENCE=G_OUI : End : Endif
  Call ECR_TRACE(PCPY,GTRC_CRACTIO,"",0,1) From TRACEABX3
  LIGNE =string$(115,"=") : Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
  LIGNE =space$(2)
  LIGNE+=left$(mess(002,3141,1)+space$(21),21)+"!"+space$(1)
  LIGNE+=space$(max(0,18-len(mess(230,GML_MSGFAS,1))))+mess(230,GML_MSGFAS,1) #Gbn-270405-Bug n°29964 (message 366->230)
  LIGNE+=space$(max(0,18-len(mess(367,GML_MSGFAS,1))))+mess(367,GML_MSGFAS,1)
  LIGNE+=space$(max(0,18-len(mess(368,GML_MSGFAS,1))))+mess(368,GML_MSGFAS,1)
  LIGNE+=space$(max(0,18-len(mess(369,GML_MSGFAS,1))))+mess(369,GML_MSGFAS,1)
  LIGNE+=space$(max(0,18-len(mess(370,GML_MSGFAS,1))))+mess(370,GML_MSGFAS,1)  : Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
  If GPHY Then
    LIGNE="    "+mess(6,3141,1)+"     "+mess(251,GML_MSGFAS,1)+""
    Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
  Endif
  LIGNE =string$(115,"=") : Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3

 #LIGNE ="==================================================================================================================" :  Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
 #LIGNE ="  Bien comptable       ! H.T.              T.V.A             VN comptable      +/- Value compt.  +/- Value fisc.   " :  Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
 #LIGNE ="    Element physique   Désignation                                                                                 "
 #LIGNE ="===================================================================================================================" :  Call ECR_TRACE(PCPY,GTRC_CRACTIO,LIGNE,0,1) From TRACEABX3
End


#--------------------------------------------------------------#
# Comparaison mise à jour d'une zone d'une classe origine vers #
# une classe destination si les valeurs sont différentes       #
#--------------------------------------------------------------#
Subprog APPL_ZONE(PCLASSE,PZONE,PCLASSEP,PZONEP,RET)
Value    Char    PCLASSE      # Classe à mettre à jour
Value    Char    PZONE        # Zone à modifier
Value    Char    PCLASSEP     # Classe paramètre
Value    Char    PZONEP       # Zone paramètre
Variable Integer RET       # Code retour

  Local    Char    NOMZONE

  If evalue(PCLASSEP+PZONEP+"<>''")
    If evalue(PCLASSE+PZONE+"<>"+PCLASSEP+PZONEP)
      NOMZONE=PCLASSE+PZONE
      Assign NOMZONE With evalue(PCLASSEP+PZONEP)
    Endif
  Endif
End

#--------------------------------------------------------------#
# S/P de lancement de l'action (Développement)                 #
#--------------------------------------------------------------#
Subprog LAUNCH_ACT(PACTTYP)
Value Char PACTTYP

  Case PACTTYP
    When "U"
      Raz GPILOBJ
      Call DEFVAR From GLOBIMM
      Call INIVAR From GLOBIMM
      Call OBJET("FAS",GBIDC1,GBIDC2) From GOBJET
    When "M"
      Local Char PARAM(30)(1..5)
      Local Char VALEUR
      PARAM(1)="M"              # Massif / unitaire
      PARAM(2)="FASISS"         # Nom de l'action métier
      PARAM(3)="2"              # Objet métier de référence
      PARAM(4)=num$(1)          # Mono société
      PARAM(5)=num$(1)          # Plan d'amortissement
      Call TRAITE_CHAR(VALEUR,PARAM,"","TRTFASISS","FASISSM",4,"") From GTRAITE
    When Default
  Endcase
End

