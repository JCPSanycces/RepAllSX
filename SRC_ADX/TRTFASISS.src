##########################################################################
# FQ79623
# On ne peut répartir le montant de sortie sur le bien principal
# si le (type de) montant de sortie est la valeur nette

# Remarque : on a l'action CHGACTCRIT sur le champ dans l'écran et non CHGACTPARM
# parce qu'il faut recharger la population si on le change car c'est ici
# que l'on fait les cumul (VN, VB...) et qu'ils sont différents selon cette case à cocher.
Subprog C_TTPRINC(VALEUR)
Variable Integer VALEUR
  # Impossible si le type de montant de sortie est la valeur nette.
     If VALEUR = G_OUI and [M:FASS]ISSAMTTYP = GVML_TVVNCPL
    GMESSAGE = mess(862, GML_MSGFAS, 1)
    GERR     = 1
    mkstat   = 2
  Endif
End

##########################################################################
Subprog B2_TTPRINC(VALEUR)
Variable Integer VALEUR

    Infbox "FXMCUMCPST =" - mess(GPARCUMCPST, 1, 1)

End

##########################################################################
Subprog C_BRDTYP(VALEUR)
Variable Integer VALEUR
  If ACTSTATUS >= STA_TEMP

    Local Integer WSVBRDTYP
    WSVBRDTYP = [M:FASS]BRDTYP
    [M:FASS]BRDTYP = VALEUR

    GERR=0
    # ds CLOS_LOCK, on vérifie si le cumul est > 0
    Gosub CLOS_LOCK
    [M:FASS]BRDTYP = WSVBRDTYP
    If GERR=1
      mkstat   = 2
    Endif
  Endif
End
###*FQ-67621 ####################################################################################
Subprog AM_BPRSAC(VALEUR)
Variable Char    VALEUR()

  If !clalev([F:CAC]) : Local File GACCCODE   [CAC] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif

  Local Char PLNREFGEN
  Local Char WSACACC

  PLNREFGEN = [M:FPC]COA(find([M:FPC]GENLEDTYP,[M:FPC]LEDTYP)-1)
 # - On récupère  le compte collectif associé au code comptable du client
 #   --> si le compte de la ligne n°11 est renseigné on le récupère
 #   --> sinon on va chercherle compte de la ligne n°1
 # - On récupère ensuite le code d'appel du collectif lié au compte

 If ( VALEUR <> "") and (VALEUR <> [M:FASS]BPRSAC )
    Raz [M:FASS]SACACC  : Affzo [M:FASS]SACACC
    Read[BPC]BPC0= [M:FASS]BUY
    If fstat=0
       Read [CAC]CAC0=2;[F:BPC]ACCCOD;PLNREFGEN # 2 TYP = 2 : "Client"
       If fstat=0
          If [F:CAC]ACC(10)  <> ""
             Read[GAC]GAC0= PLNREFGEN;[F:CAC]ACC(10)
          Else
            Read[GAC]GAC0= PLNREFGEN;[F:CAC]ACC(0)
          Endif
          If fstat = 0
             [M:FASS]SACACC = [F:GAC]ACCSHO      #7  #7
          Endif
       Endif
    Endif
 Endif

   Affzo [M:FASS]SACACC

End

###*FQ-67621 ####################################################################################
Subprog C_BPRSAC(VALEUR)
Variable Char    VALEUR()


  If G_SALINV = G_OUI and VALEUR = ""
     # If SALINV ==> collective account required
     GMESSAGE = mess(898,GML_MSGFAS,1)
     GERR     = 1
     mkstat   = 2
     End
  Endif

End
#####################################################################################
#-------------------------------------------------------------------------------
#**
#* Callback function
#*
#* @param PHY
#* @param PCASE
#* @param PVALUE
#* @param PPHYREF
#* @param PPHYDES1
#* @return CST_ATRUE or CST_AFALSE to stop disposal process
#*!
Funprog  CALLBACK_ISS(PARAM_PHY, PCASE, PVALUE, PPHYREF, PPHYDES1)
Variable Instance PARAM_PHY Using C_PHYELTISS
Value Integer PCASE
Value Integer PVALUE
Value Char PPHYREF()
Value Char PPHYDES1()

  Local Integer LOK

  Case PCASE
    When 1:
      # Set progress bar
      Call SET_BOITE(TXTPROG, PVALUE) From GESECRAN
    When 2:
      # Increase issued physical asset number
      NBPHY_TRT += 1

      # Update progress bar
      Local Char MSGPROG(40)

      MSGPROG = PPHYREF + '['+num$(NBPHY_TRT) + ']'
      Call AFF_BOITE(MSGPROG, NBPHY_TRT, LOK) From GESECRAN

      # Set log value columns
      [L]LOK  = fmet CLOG.LOG_INIT_LINE()
      [L]LOK += fmet CLOG.LOG_PUT_INT_COLUMN(1, NBPHY_TRT)
      [L]LOK += fmet CLOG.LOG_PUT_COLUMN(2, PPHYREF)
      [L]LOK += fmet CLOG.LOG_PUT_COLUMN(3, PPHYDES1)
      [L]LOK += fmet CLOG.LOG_WRITE([V]CST_AOK)

      # Write error messages
      # (CLOG is global variable)
      # Issue 110494
      Call LOG_WRITE_AERROR_GENERAL_COUNT(PARAM_PHY, CLOG, [L]NBPHY_INF, NBPHY_WAR, NBPHY_ERR) From FXDLOG_CSTD
#      Call LOG_WRITE_AERROR_STACK_COUNT(PHY, CLOG, NBPHY_INF, NBPHY_WAR, NBPHY_ERR, NBPHY_ERR) From FXDLOG_CSTD
      # End Issue 110494
    When 3:
    When Default:
  Endcase

End [V]CST_ATRUE

#**
#* Callback function of disposal cancellation
#*
#* @param PHY
#* @param PCASE
#* @param PVALUE
#* @param PPHYREF
#* @param PPHYDES1
#* @param PDATEISS
#* @return CST_ATRUE or CST_AFALSE to stop disposal process
#*!
Funprog  CALLBACK_CNL_ISS(PARAM_PHY, PCASE, PVALUE, PPHYREF, PPHYDES1, PDATEISS)
Variable Instance PARAM_PHY Using C_PHYELTISS
Value Integer PCASE
Value Integer PVALUE
Value Char PPHYREF()
Value Char PPHYDES1()
Value Date PDATEISS

  Local Integer LOK

  Case PCASE
    When 1:
      # Set progress bar
      Call SET_BOITE(TXTPROG, PVALUE) From GESECRAN
    When 2:
      # Increase issued physical asset number
      NBPHY_TRT += 1

      # Update progress bar
      Local Char MSGPROG(40)
      MSGPROG = PPHYREF + '['+num$(NBPHY_TRT) + ']'
      Call AFF_BOITE(MSGPROG, NBPHY_TRT, LOK) From GESECRAN

      # Set log value columns
      [L]LOK = fmet CLOG.LOG_INIT_LINE()
      [L]LOK = fmet CLOG.LOG_PUT_INT_COLUMN(1, NBPHY_TRT)
      [L]LOK = fmet CLOG.LOG_PUT_COLUMN(2, PPHYREF)
      [L]LOK = fmet CLOG.LOG_PUT_COLUMN(3, PPHYDES1)
      [L]LOK = fmet CLOG.LOG_WRITE([V]CST_AOK)

      # Write contents of stack messages
      # (CLOG is global variable)
      Call LOG_WRITE_AERROR_STACK_COUNT(PARAM, CLOG, NBPHY_INF, NBPHY_WAR, NBPHY_ERR, NBPHY_ERR) From FXDLOG_CSTD
      # Issue 110494
      Call LOG_WRITE_AERROR_GENERAL_COUNT(PARAM_PHY, CLOG, [L]NBPHY_INF, NBPHY_WAR, NBPHY_ERR) From FXDLOG_CSTD
#      Call LOG_WRITE_AERROR_STACK_COUNT(PHY, CLOG, NBPHY_INF, NBPHY_WAR, NBPHY_ERR, NBPHY_ERR) From FXDLOG_CSTD
      # End Issue 110494

    When 3:
    When Default:
  Endcase

End [V]CST_ATRUE

