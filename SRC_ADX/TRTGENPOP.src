#<AdxTL>@(#)6.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTGENPOP","TRTGENPOP",4,"XYTRTGENPOP") From GTRAITE
End



$ACTION
Case ACTION
When "INIT"     : Gosub INIT
When "CONTROLE" : Gosub CONTROLE
When "EXEC"     : Gosub EXEC
When Default
Endcase
Return


$INIT
If clalev([F:HRPOP])=0  : Local File POPUL    [HRPOP] : Endif
If clalev([F:HRPOA])=0  : Local File POPULA   [HRPOA] : Endif
If clalev([F:POB])=0    : Local File POPULB   [POB]   : Endif
If clalev([F:CTR2])=0   : Local File EMPLOCTR [CTR2]  : Endif
If clalev([F:CTR3])=0   : Local File EMPLOCTR [CTR3]  : Endif :#77982
Gosub OUVRE From WPDEFTABLE
Local Char    MATRI(GLONEML), CRITERE(250), CTR(GLONHRCTR)
Local Date    DATDIA, DATMAT
Local Integer ERREUR
Local Mask TRTGENPOP [DIA]
Local Integer DELFROMPOA :#77982
Raz [M:DIA]
If GFONCTION="GESPOP"
 [M:DIA]POPDEB = [M:POP1]COD
 [M:DIA]POPFIN = [M:POP1]COD
Endif
Return


$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP = 1
 TRA = 2
Endif
Return


$EXEC
# Reconstitution des populations de salariés
TIT = mess(123,10703,1)
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
CRITERE = '[F:HRPOP]CRI<>""'
If [M:DIA]POPDEB<>"" : # Borne début population
 CRITERE -= '& [F:HRPOP]COD>="'+[M:DIA]POPDEB+'"'
Endif
If [M:DIA]POPFIN<>"" : # Borne fin population
 CRITERE -= '& [F:HRPOP]COD<="'+[M:DIA]POPFIN+'"'
Endif
DATDIA = date$
Call DEBTRANS From GLOCK
Gosub TR1
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
#SAVAN - 2018/04/24 - X3-86552 - start
#SAVAN - 2018/04/26 - X3-86552 - start
#Gosub LINKING_ACCRUALS From SUBACCRUAL
#PEVAN - 2018-08-01 X3-90320 - START
#Call LINKING_ACCRUALS_PROG("","","","",[0/0/0],5,0) From SUBACCRUAL
If func AFNC.ACTIV("GLM")>0
  Call LINKING_ACCRUALS_PROG("","","","",[0/0/0],5,0) From SUBACCRUAL
Endif
#PEVAN - 2018-08-01 X3-90320 - END
#SAVAN - 2018/04/26 - X3-86552 - end
#SAVAN - 2018/04/24 - X3-86552 - end
Return


$TR1
GOK = 1
Trbegin [HRPOA]
## On enlève de la liste des salariés ceux qui ne vérifient pas le critère d'appartenance
## et qui ont été crées en automatique
## On ajoute dans la liste des salariés ceux qui vérifient le critère d'appartenance
# FQ81085 - US915 - MABON 25/10/12 - Ajout filtre sur FLGNEWSAL<>2 (pour ne pas sélectionner les salariés temporaires)
#For [ID]ID0
For [ID]ID0 Where FLGNEWSAL<>2
 MATRI = [F:ID]REFNUM
 #77982 : Ajout "& (XITDAT=[0/0/0] | XITDAT>DATMAT)"
 #LIPET - 2018-07-20 - X3-101061 - START
 #For [CTR2]CTR0(2) Where REFNUM=MATRI & CTRDAT<=DATDIA & (XITDAT=[0/0/0] | XITDAT>DATDIA)
 Filter [CTR2] Where REFNUM=MATRI & CTRDAT<=DATDIA
 For [CTR2]
 #LIPET - 2018-07-20 - X3-101061 - END
  CTR    = [F:CTR2]CTRNUM
  # FQ81085 - US915 - MABON 25/10/12 - Ajout contrat+date dans les populations
  DATMAT = [F:CTR2]CTRDAT
  # Fin MABON
  Gosub LECEMP From WPDEFTABLE
  Filter [HRPOP] Where evalue(CRITERE)
  For [HRPOP]
   ERREUR = 0
   Onerrgo ERR
    OK = evalue([F:HRPOP]CRI)
   Onerrgo
   If ERREUR=1 : Break 3 : Endif

#   If evalue([F:HRPOP]CRI)=1
   If evalue([F:HRPOP]CRI)=1 & ([F:HRPOP]LEG="" | [F:HRPOP]LEG=func TOOLSHRLEG.GETLEGFCY([F:CTR2]ETRFCY))
    # FQ81085 - US915 - MABON 25/10/12 - Ajout contrat+date dans les populations
#    Read [HRPOA]POA0=[F:HRPOP]COD;MATRI
    Read [HRPOA]POA0=[F:HRPOP]COD;MATRI;CTR;DATMAT
    # Fin MABON
    If fstat
     If [M:DIA]SIM<>2 : # Ce n'est pas une simulation
      [F:HRPOA]COD    = [F:HRPOP]COD
      [F:HRPOA]REFNUM = MATRI
      # FQ81085 - US915 - MABON 25/10/12 - Ajout contrat+date dans les populations
      [F:HRPOA]CTRNUM = CTR
      [F:HRPOA]CTRDAT = DATMAT
      # Fin MABON
      [F:HRPOA]TYP    = 0
      # 29593
      [F:HRPOA]MAJTYP = 1 : # Auto
      If dim([F:HRPOA]CREUSR)>0 : [F:HRPOA]CREUSR = GUSER : Endif
      If dim([F:HRPOA]CREDAT)>0 : [F:HRPOA]CREDAT = date$ : Endif
      If dim([F:HRPOA]CRETIM)>0 : [F:HRPOA]CRETIM = time  : Endif
      Write [HRPOA]
      If fstat
       GOK=0 : Call FSTA("HRPOA") From GLOCK : Break 3
      Endif
     Endif
     ## Ajout
#     Call ECR_TRACE(mess(135,10702,1)-format$("K:55X",MATRI+" "+[F:ID]NAM)+[F:HRPOP]COD+" "+[F:HRPOP]DES,0) From GESECRAN
     Call ECR_TRACE([F:HRPOP]COD-[F:HRPOP]DES-":"-mess(135,10702,1)-format$("K:55X",MATRI-[F:ID]NAM-[F:ID]SRN)-"-"-format$("K:55X",CTR-DATMAT),0) From GESECRAN
    Endif
   # 29593
   Else
     # FQ81085 - US915 - MABON 25/10/12 - Ajout contrat+date dans les populations
#     Read [HRPOA]POA0=[F:HRPOP]COD;MATRI
     Read [HRPOA]POA0=[F:HRPOP]COD;MATRI;CTR;DATMAT
     # Fin MABON
#     If !fstat & [F:HRPOA]MAJTYP=1
     If !fstat & [F:HRPOA]MAJTYP<>2
      #77982 Multi contract management
      [L]DELFROMPOA=1
      # FQ81085 - US915 - MABON 25/10/12 - On ne vérifie plus si multi-contrats, car on a ajouté le contrat+date dans les populations
#      If [ID]FLGMULCTR=2
#        Gosub CONTROLMULCTR
#      Endif
      # Fin MABON
      #end 77982
      If [L]DELFROMPOA
        If [M:DIA]SIM<>2 : # Ce n'est pas une simulation
          # FQ81085 - US915 - MABON 25/10/12 - Ajout contrat+date dans les populations
#          Delete [HRPOA]POA0=[F:HRPOP]COD;MATRI
          Delete [HRPOA]POA0=[F:HRPOP]COD;MATRI;CTR;DATMAT
          # Fin MABON
          If fstat
            GOK=0 : Call FSTA("POA") From GLOCK : Break 3
          Endif
        Endif
#        Call ECR_TRACE(mess(136,10702,1)-format$("K:55X",MATRI+" "+[F:ID]NAM)+[F:HRPOP]COD+" "+[F:HRPOP]DES,0) From GESECRAN
        Call ECR_TRACE([F:HRPOP]COD-[F:HRPOP]DES-":"-mess(136,10702,1)-format$("K:55X",MATRI-[F:ID]NAM-[F:ID]SRN)-"-"-format$("K:55X",CTR-DATMAT),0) From GESECRAN
      Endif
     # fin 29593
     Else
      Filter [HRPOA] Where COD=[F:HRPOP]COD & REFNUM=MATRI & CTRNUM=CTR & CTRDAT=[0/0/0] & [F:HRPOA]MAJTYP<>2
      For [F:HRPOA]
        [L]DELFROMPOA=1
        If [L]DELFROMPOA
          If [M:DIA]SIM<>2 : # Ce n'est pas une simulation
            Delete [HRPOA]POA0=[F:HRPOP]COD;MATRI;CTR;[0/0/0]
            If fstat
              GOK=0 : Call FSTA("POA") From GLOCK : Break 3
            Endif
          Endif
          Call ECR_TRACE([F:HRPOP]COD-[F:HRPOP]DES-":"-mess(136,10702,1)-format$("K:55X",MATRI-[F:ID]NAM-[F:ID]SRN)-"-"-format$("K:55X",CTR-DATMAT),0) From GESECRAN
        Endif
      Next
      Filter [HRPOA]
     Endif
   Endif
  Next
 Next
Next
Filter [HRPOP]

# FQ81085 - US915 - MABON 25/10/12 - Suppression des salariés/contrat dont le site n'a pas la même leg que la population
Filter [HRPOP] Where evalue(CRITERE)
If clalev([F:HRCTR])=0 : Local File EMPLOCTR [HRCTR] : Endif
For [HRPOP]
  If [F:HRPOP]LEG<>"" Then
    For [F:HRPOA] Where COD=[F:HRPOP]COD
      Read [F:HRCTR]CTR0=[F:HRPOA]REFNUM;[F:HRPOA]CTRNUM;[F:HRPOA]CTRDAT
      If !fstat Then
        MATRI   = [F:HRPOA]REFNUM
        CTR     = [F:HRPOA]CTRNUM
        DATMAT  = [F:HRPOA]CTRDAT
        Gosub LECEMP From WPDEFTABLE
        If [F:HRPOP]LEG<>func TOOLSHRLEG.GETLEGFCY([F:HRCTR]ETRFCY) Then
          If [M:DIA]SIM<>2 : # Ce n'est pas une simulation
            Delete [HRPOA]POA0=[F:HRPOP]COD;MATRI;CTR;DATMAT
            If fstat
              GOK=0 : Call FSTA("POA") From GLOCK : Break 3
            Endif
          Endif
          Call ECR_TRACE([F:HRPOP]COD-[F:HRPOP]DES-":"-mess(136,10702,1)-format$("K:55X",MATRI-[F:ID]NAM-[F:ID]SRN)-"-"-format$("K:55X",CTR-DATMAT),0) From GESECRAN
        Endif
      Endif
    Next
  Endif
Next
Filter [HRPOP]
# Fin MABON

# FQ81085 - US915 - MABON 25/10/12 - Suppression des salariés qui n'ont pas de contrat
Filter [HRPOP] Where evalue(CRITERE)
If clalev([F:HRCTR])=0  : Local File EMPLOCTR [HRCTR]  : Endif
If clalev([F:HRPOA2])=0 : Local File POPULA   [HRPOA2] : Endif
Local Integer TYP0
For [HRPOP]
  For [F:HRPOA] Where COD=[F:HRPOP]COD & CTRNUM=""
    Filter [F:HRPOA2] Where REFNUM=[F:HRPOA]REFNUM & CTRNUM<>""
    Filter [F:HRCTR] Where REFNUM=[F:HRPOA]REFNUM
    If rowcount([F:HRCTR])=0 | rowcount([F:HRPOA2])>0 Then
      MATRI = [F:HRPOA]REFNUM
      TYP0  = [F:HRPOA]TYP
      If [M:DIA]SIM<>2 : # Ce n'est pas une simulation
        Delete [HRPOA] Where COD=[F:HRPOP]COD & REFNUM=MATRI & CTRNUM=""
        If fstat
          GOK=0 : Call FSTA("POA") From GLOCK : Break 3
        Endif
      Endif
      If TYP0=0 Then Call ECR_TRACE([F:HRPOP]COD-[F:HRPOP]DES-":"-mess(136,10702,1)-format$("K:55X",MATRI-[F:ID]NAM-[F:ID]SRN),0) From GESECRAN : Endif
    Endif
    Filter [F:HRPOA2]
    Filter [F:HRCTR]
  Next
Next
Filter [HRPOP]
# Fin MABON

#LIPET - 2017-06-02 - X3-42214 - START
# FQ122019 - 31/03/17 - New parameter "Update contracts" to add contracts on lines in the populations without
# membership rule
If [M:DIA]UPDCTR=2 Then
  CRITERE = '[F:HRPOP]CRI=""'
  If [M:DIA]POPDEB<>"" : # Borne début population
   CRITERE -= '& [F:HRPOP]COD>="'+[M:DIA]POPDEB+'"'
  Endif
  If [M:DIA]POPFIN<>"" : # Borne fin population
   CRITERE -= '& [F:HRPOP]COD<="'+[M:DIA]POPFIN+'"'
  Endif
  For [HRPOP] Where evalue(CRITERE)
#    For [F:POA] Where COD=[F:POP]COD
    For [F:HRPOA] Where COD=[F:HRPOP]COD & CTRNUM=""
      Read [F:ID]ID0=[F:HRPOA]REFNUM
      If [F:ID]FLGNEWSAL<>2 Then
        MATRI = [F:ID]REFNUM
        For [CTR2]CTR0 Where REFNUM=MATRI & CTRDAT<=DATDIA
          CTR = [F:CTR2]CTRNUM
          DATMAT=[F:CTR2]CTRDAT
          Read [HRPOA2]POA0=[F:HRPOP]COD;MATRI;CTR;DATMAT
          If fstat
            If [M:DIA]SIM<>2 : # Ce n'est pas une simulation
              Delete [HRPOA] Where COD=[F:HRPOP]COD & REFNUM=MATRI & CTRNUM=""
              [F:HRPOA]COD    = [F:HRPOP]COD
              [F:HRPOA]REFNUM = MATRI
              [F:HRPOA]CTRNUM = CTR
              [F:HRPOA]CTRDAT = DATMAT
              [F:HRPOA]TYP    = 0
              [F:HRPOA]MAJTYP = 1 : # Auto
              If dim([F:HRPOA]CREUSR)>0 : [F:HRPOA]CREUSR = GUSER : Endif
              If dim([F:HRPOA]CREDAT)>0 : [F:HRPOA]CREDAT = date$ : Endif
              If dim([F:HRPOA]CRETIM)>0 : [F:HRPOA]CRETIM = time  : Endif
              Write [HRPOA]
              If fstat
               GOK=0 : Call FSTA("HRPOA") From GLOCK : Break 3
              Endif
              Call ECR_TRACE([F:HRPOP]COD-[F:HRPOP]DES-":"-mess(135,10702,1)-MATRI-[F:ID]NAM-[F:ID]SRN-CTR-num$(DATMAT),0) From GESECRAN
            Endif
          Endif
        Next
      Endif
    Next
  Next
Endif
# End FQ122019
#LIPET - 2017-06-02 - X3-42214 - END

If   GOK<0 : Goto ROLL_TR1
Elsif !GOK : Goto AB_TR1
Endif
Commit
Return


$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$ERR
Local Char MESSA(250)
MESSA = errmes$(errn)+"\"+errm
# Erreur lors de l'évaluation du critère d'appartenance pour la population
Call ECR_TRACE(mess(11,10701,1)-":"-[F:HRPOP]COD-"\"-MESSA,1) From GESECRAN
ERREUR = 1
Resume

#77982 Multi contract management
$CONTROLMULCTR
Local Char SCTR(GLONHRCTR)
[L]SCTR = [L]CTR

#LIPET - 2018-07-20 - X3-101061 - START
#For [CTR3]CTR0(2) Where [F:CTR3]REFNUM=MATRI & [F:CTR3]CTRDAT<=DATDIA & ([F:CTR3]XITDAT=[0/0/0] | [F:CTR3]XITDAT>DATDIA)
Filter [CTR3] Where [F:CTR3]REFNUM=MATRI & [F:CTR3]CTRDAT<=DATDIA
For [CTR3]
#LIPET - 2018-07-20 - X3-101061 - END
  [L]CTR = [F:CTR3]CTRNUM
  #LIPET - 2017-06-02 - X3-42214 - START
  [L]DATMAT=[F:CTR3]CTRDAT : # 96877
  #LIPET - 2017-06-02 - X3-42214 - END
  Gosub LECEMP From WPDEFTABLE
  If evalue([F:HRPOP]CRI)=1
    [L]DELFROMPOA=0
    Break
  Endif
Next
[L]CTR = [L]SCTR
Gosub LECEMP From WPDEFTABLE
Return

