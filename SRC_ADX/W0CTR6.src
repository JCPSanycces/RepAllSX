#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CTR6 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc tableau 1
####################################
IMPTBL = 1

## Zone NBRCHEF
mkstat = 0
zoncou = "NBRCHEF"
indice = 0
status = 1
zoncou = "NBRCHEF"
If varinit([M]NBRCHEF,indice)=0
 [M]NBRCHEF = len(mess(0,50,1))
Endif
If varmode([M]NBRCHEF,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRCHEF" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRCHEF
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRCHEF = nolign
   status = 75
   Call SAI_NBRCHEF(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBRRPL
mkstat = 0
zoncou = "NBRRPL"
indice = 0
status = 1
zoncou = "NBRRPL"
If varmode([M]NBRRPL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRRPL" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBRRPL
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBRRPL = nolign
   status = 75
   Call SAI_NBRRPL(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

####################################
## Bloc tableau 3
####################################
IMPTBL = 1

## Zone NBRPOP
mkstat = 0
zoncou = "NBRPOP"
indice = 0
status = 1
zoncou = "NBRPOP"
SAVACT = GACTION : GACTION = "STD"
Call AV_NBRPOP From SUBCTR
GACTION = SAVACT
If mkstat=1 : Raz [M]NBRPOP : Endif
If !mkstat
 If varmode([M]NBRPOP,indice)=0
  SAVACT = GACTION : GACTION = "STD"
  Call AS_NBRPOP From SUBCTR
  GACTION = SAVACT
  If mkstat=1 : Raz [M]NBRPOP : Endif
  If !mkstat
   IMPMOD = 0 : IMPZON = "NBRPOP" : Gosub ACTION From =IMPTRT
  Endif
  If !mkstat
   NBLIG = [M]NBRPOP
   For nolign=1 To NBLIG
    indice = nolign-1
    [M]NBRPOP = nolign
    status = 75
    Call SAI_NBRPOP(IMPFIC,ACTION,IMPTRT)
    If mkstat : Break : Endif
   Next nolign
   If mkstat : End : Endif
   indice = 0
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_NBRPOP From SUBCTR
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "NBRPOP" : GZNUM = 0 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

####################################
## Bloc liste 4
####################################
IMPTBL = 0

mkstat = 0

End

####################################
## Bloc tableau 1
####################################
Subprog SAI_NBRCHEF(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRCHEF
mkstat = 0
zoncou = "NBRCHEF"

## Zone RESPO
mkstat = 0
zoncou = "RESPO"
IMPENT = [M]RESPO(indice)
If varinit([M]RESPO,indice)=0
 IMPENT = nolign
Endif
[M]RESPO(indice) = IMPENT

## Zone CHEFCTR
mkstat = 0
zoncou = "CHEFCTR"
If varmode([M]CHEFCTR,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CHEFCTR" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "DROITEMP"
 Call DROIT([M]CHEFCTR(indice),"","","") From DIVPAYE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CHEFCTR" : GZNUM = 1459 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("EML","!",[M]CHEFCTR(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "CHEFCTR" : GZNUM = 1459 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_CHEFCTR([M]CHEFCTR(indice)) From SUBCTR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CHEFCTR" : GZNUM = 1459 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone NAMCHEF
mkstat = 0
zoncou = "NAMCHEF"
SAVACT = GACTION : GACTION = "STD"
Call AV_NAMCHEF([M]NAMCHEF(indice)) From SUBCTR
GACTION = SAVACT
If mkstat=1 : Raz [M]NAMCHEF(indice) : Endif

## Zone NBRCHEF
mkstat = 0
zoncou = "NBRCHEF"

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBRRPL(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRRPL
mkstat = 0
zoncou = "NBRRPL"

## Zone RPL
mkstat = 0
zoncou = "RPL"
If varmode([M]RPL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "RPL" : Gosub ACTION From =IMPTRT
 Endif
 SAVACT = GACTION : GACTION = "DROITEMP"
 Call DROIT([M]RPL(indice),"","","") From DIVPAYE
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "RPL" : GZNUM = 10793 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  Call CONTROLE("EML","!",[M]RPL(indice),"",mkstat) From CONTOBJ
  If mkstat : GERR = 1 : GZONE = "RPL" : GZNUM = 10793 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "STD"
   Call C_RPL([M]RPL(indice)) From SUBCTR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "RPL" : GZNUM = 10793 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone NAMSUPPL
mkstat = 0
zoncou = "NAMSUPPL"
SAVACT = GACTION : GACTION = "STD"
Call AV_NAMSUPPL([M]NAMSUPPL(indice)) From SUBCTR
GACTION = SAVACT
If mkstat=1 : Raz [M]NAMSUPPL(indice) : Endif

## Zone CMTRPL
mkstat = 0
zoncou = "CMTRPL"
If varmode([M]CMTRPL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CMTRPL" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone NBRRPL
mkstat = 0
zoncou = "NBRRPL"

End

####################################
## Bloc tableau 3
####################################
Subprog SAI_NBRPOP(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBRPOP
mkstat = 0
zoncou = "NBRPOP"
SAVACT = GACTION : GACTION = "STD"
Call C_NBRPOP From SUBCTR
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "NBRPOP" : GZNUM = 0 : Endif
Gosub AFF From GSAISIE
If mkstat : End : Endif

## Zone POP
mkstat = 0
zoncou = "POP"
WCHAR = [M]POP(indice)
If varmode([M]POP,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_POP([M]POP(indice)) From SUBCTR
 GACTION = SAVACT
 If mkstat=1 : Raz [M]POP(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "POP" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]POP(indice),2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 5296 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTPOP"
   Call CONTPOP([M]POP(indice),GCURLEG) From SUBPOP
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 5296 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    Call CONTROLE("POP","",[M]POP(indice),"",mkstat) From CONTOBJ
    If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 5296 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "STD"
     Call C_POP([M]POP(indice)) From SUBCTR
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 5296 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      If WCHAR<>[M]POP(indice) or IMPMOD
       SAVACT = GACTION : GACTION = "STD"
       Call AM_POP([M]POP(indice)) From SUBCTR
       GACTION = SAVACT
       If mkstat : GERR = 1 : GZONE = "POP" : GZNUM = 5296 : Endif
       Gosub AFF From GSAISIE
       If mkstat : End : Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone MAJTYP
mkstat = 0
zoncou = "MAJTYP"
IMPENT = [M]MAJTYP(indice)
If varinit([M]MAJTYP,indice)=0
 IMPENT = 1
Endif
[M]MAJTYP(indice) = IMPENT

## Zone LISTHIERAR
mkstat = 0
zoncou = "LISTHIERAR"
SAVACT = GACTION : GACTION = "STD"
Call AV_LISTHIERAR([M]LISTHIERAR(indice)) From SUBCTR
GACTION = SAVACT
If mkstat=1 : Raz [M]LISTHIERAR(indice) : Endif

## Zone NBRPOP
mkstat = 0
zoncou = "NBRPOP"
status = 71
SAVACT = GACTION : GACTION = "STD"
Call APRES_NBRPOP From SUBCTR
GACTION = SAVACT

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CTR6"
Return

