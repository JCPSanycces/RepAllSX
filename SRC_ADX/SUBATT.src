#<AdxTL>@(#)10.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("ATT",GBIDC1,GBIDC2) From GOBJET
End

##############################################################################################
# TRADUCTION des tables
#                     fonction webisée                                                    cg #
##############################################################################################

$ACTION
Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "SETBOUT"      : Gosub SETBOUT
  When "LIENS"        : Gosub LIENS
                        Affzo [M:ATT]5-10
  When "AV_IMPRIME"   : Gosub COP_ECRAN
                        OK = 0
  When "AVANT_MODFIC" : Gosub AVANT_MODFIC
  When "APRES_MOD"    : Gosub APRES_MODFIC
  When "FERME"        : Gosub FERME
Endcase
Return

############################################################
$SETBOUT
Call VIREBOUT(CHAINE,"CDAHS") From GOBJET
Return

############################################################
$OUVRE
Gosub DEFVAR From ATRANSLATION

If !clalev([F:ATX]) : Local File ATEXTE  [ATX] : Endif

Local File ATABLE  [XTB]
Local File ATABZON [XTZ]

Call OUVRE_TRACE(mess(208,100,1)) From LECFIC

Local File ATEXTE  [ATX2]

#-----------------------------
# prog spe a chaque produit opdadx sur indusprd.....
# test si ca marche ou pas la remontée ..
#-----------------------------
Local Integer WOK
WOK = 0

Call EXISTE_ADX ("","","ATRANSLATIONB",WOK) From ORDSYS
If WOK = 1
   WOK =0
   WNBRFOLDER= 0
   Call OUVRE_FIC (GFOLDER_INDUS,GFOLDER_VERSION,GFOLDER_PRODUIT,WNBRFOLDER,WOK) From ATRANSLATIONB
   # les erreurs sont afficher dans atransaltionb
Endif


Return

############################################################
$COP_ECRAN
Call PRTSCR("ATBTRAD","","",0,0) From ATRTX3
Return

############################################################
$FERME
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
Call IMPSCR From ATRTX3
Return

############################################################
$LIENS
Local Integer I, J, K
Local Char    WLAN
## Ig A quoi sert ce trans-class ?? (Aucun champ commun)
[M:ATT]        = [F:TLA]
[M:ATT]LANREF  = GLANREF
[M:ATT]LANTRAD = GLANTRAD

Read [XTB]CODFIC = [M]CODFIC
If fstat : Raz [F:XTB] : Endif

# -------------------------------------------------------#
# on doit afficher le libelle dans la langue de reference
# -------------------------------------------------------#
WLAN    = GLANGUE
GLANGUE = [M:ATT]LANREF
Call TEXTE([M:ATT]INTITFIC,[M:ATT]ZINTITFIC) From OBJDIV

# remettre glangue correct
GLANGUE = WLAN

Effzo [M:ATT]10
[M:ATT]BASPAG2 = 0
nolign         = 0
## Verif langue de référence existe bien
Read [TLA]TLA0= [M:ATT]LANREF
If fstat
 Call MESSAGE("Code language don't exist") From GESECRAN
 Return
Endif

# Chargement textes champs
Filter [XTZ] Where CODFIC = [F:XTB]CODFIC
&            Order By Key NUMLIG
For [XTZ]
 Call LOA_LIGNE([F:XTZ]NOCOURT,[F:XTZ]NOABREG,[F:XTZ]NOLONG)
Next
Filter [XTZ]
Return

############################################################
$AVANT_MODFIC
Local Integer I, J, K
If [M]LANTRAD <> ""
 J = 0
 For I = 0 To [M:ATT]BASPAG2-1
  If mod(I,2) = 1
   If [M:ATT]TXTNOR(I) <> [M:ATT]TXTNOROLD(I) | [M:ATT]TXTABR(I) <> [M:ATT]TXTABROLD(I) |
&     [M:ATT]TXTLON(I) <> [M:ATT]TXTLONOLD(I)
    J += 1
   Endif
  Endif
 Next I
 If J <> 0
  K = 2
  Call AVERTIR(mess(206,100,1)-num$(J),K) From GESECRAN
  If K = 2
   Gosub TRT_MAJ
   #Gosub LIENS
  Endif
 Endif
Endif
Return

############################################################
$TRT_MAJ
For I = 0 To [M:ATT]BASPAG2-1
  If mod(I,2) = 1
    If [M:ATT]TXTNOR(I) <> [M:ATT]TXTNOROLD(I)
      Call MAJ_TEXTE([M:ATT]NUMNOR(I),[M:ATT]TXTNOR(I))
    Endif
    If [M:ATT]TXTABR(I) <> [M:ATT]TXTABROLD(I)
      Call MAJ_TEXTE([M:ATT]NUMABR(I),[M:ATT]TXTABR(I))
    Endif
    If [M:ATT]TXTLON(I) <> [M:ATT]TXTLONOLD(I)
      Call MAJ_TEXTE([M:ATT]NUMLON(I),[M:ATT]TXTLON(I))
    Endif
  Endif
Next I
# Mise à jour trace
For I = 0 To [M:ATT]BASPAG2-1
  If mod(I,2) = 1
    If [M:ATT]TXTNOR(I) <> [M:ATT]TXTNOROLD(I)
      Call MAJ_TRACE([M:ATT]ZON(I),[M:ATT]NUMNOR(I),[M:ATT]TXTNOR(I-1),[M:ATT]TXTNOR(I))
    Endif
    If [M:ATT]TXTABR(I) <> [M:ATT]TXTABROLD(I)
      Call MAJ_TRACE([M:ATT]ZON(I),[M:ATT]NUMABR(I),[M:ATT]TXTABR(I-1),[M:ATT]TXTABR(I))
    Endif
    If [M:ATT]TXTLON(I) <> [M:ATT]TXTLONOLD(I)
      Call MAJ_TRACE([M:ATT]ZON(I),[M:ATT]NUMLON(I),[M:ATT]TXTLON(I-1),[M:ATT]TXTLON(I))
    Endif
  Endif
Next I
Return

###########################################################
$MAJTX
#----------------------------
# mise a jour des envir indus en interne
# apres le commit dans le dossier en cours car cette partie se lance depusi indusprd
If WNBRFOLDER <> 0
        Local Integer WOK
        WOK = 0
        Local Char WTRACE
        Raz WTRACE
        Call EXISTE_ADX ("","","ATRANSLATIONB",WOK) From ORDSYS
        If WOK = 1
            # on boucle idem sur le tableau
            For I = 0 To [M:ATT]BASPAG2-1
             If mod(I,2) = 1
               If [M]LANTRAD <> GFRA
                   If [M:ATT]TXTNOR(I) <> [M:ATT]TXTNOROLD(I)
                     #115210/6
                     If [M:ATT]NUMNOR(I) < GMAXTXTSTD | [M:ATT]NUMNOR(I) > GNEWTXTSTD
                           # si tout est ok alors là on met a jour les autres envri..
                            # a faire apres le commit.... sur indusprd
                            WOK = 0
                            Call MAJ_TRADTEX([M:ATT]NUMNOR(I),[M]LANTRAD,GFOLDER_INDUS,GFOLDER_VERSION,GFOLDER_PRODUIT,WNBRFOLDER,WTRACE,WOK) From ATRANSLATIONB
                            # les erreeur sont dans atransaltionb
                     Endif
                   Endif
                   If [M:ATT]TXTABR(I) <> [M:ATT]TXTABROLD(I)
                     #115210/6
                     If [M:ATT]NUMABR(I) < GMAXTXTSTD | [M:ATT]NUMABR(I)>GNEWTXTSTD
                           # si tout est ok alors là on met a jour les autres envri..
                            # a faire apres le commit.... sur indusprd
                            WOK = 0
                            Call MAJ_TRADTEX([M:ATT]NUMABR(I),[M]LANTRAD,GFOLDER_INDUS,GFOLDER_VERSION,GFOLDER_PRODUIT,WNBRFOLDER,WTRACE,WOK) From ATRANSLATIONB
                          # les erreeur sont dans atransaltionb
                     Endif
                   Endif
                   If [M:ATT]TXTLON(I) <> [M:ATT]TXTLONOLD(I)
                     #115210/6
                     If [M:ATT]NUMLON(I) < GMAXTXTSTD | [M:ATT]NUMLON(I)>GNEWTXTSTD
                           # si tout est ok alors là on met a jour les autres envri..
                            # a faire apres le commit.... sur indusprd
                            WOK = 0
                            Call MAJ_TRADTEX([M:ATT]NUMLON(I),[M]LANTRAD,GFOLDER_INDUS,GFOLDER_VERSION,GFOLDER_PRODUIT,WNBRFOLDER,WTRACE,WOK) From ATRANSLATIONB
                            # les erreeur sont dans atransaltionb
                      Endif
                   Endif
               Endif
            Endif
            Next I
         Endif
 Endif
Return


############################################################
$APRES_MODFIC
Gosub MAJTX
Gosub LIENS
Affzo [M:ATT]5-99
Return

####################################################################################################
######################## SUBPROG            ########################################################
####################################################################################################

Subprog LOA_LIGNE(LNOR,LABR,LLON)
Value Integer LNOR
Value Integer LABR
Value Integer LLON
Local Char    WLAN(GLONLAN)
Local Char    WFLG(3)
#
If LLON = LNOR
  If LLON = LABR
    WFLG = "==="
  Else
    WFLG = "==#"
  Endif
Else
  If LNOR = LABR
    WFLG = "#=="
  Else
    If LLON = LABR
      WFLG = "=#="
    Else
      WFLG = "###"
    Endif
  Endif
Endif
#
[M:ATT]FLG(nolign) = WFLG
[M:ATT]ZON(nolign) = [F:XTZ]CODZONE
# On utilise la langue de référence
WLAN = [M:ATT]LANREF

Read [ATX]NUMERO = WLAN;LNOR
  Case fstat
    When 0 :
      [M:ATT]TXTNOR(nolign) = [F:ATX]TEXTE
    When Default :
      [M:ATT]TXTNOR(nolign) = ""
  Endcase
[M:ATT]NUMNOR(nolign) = LNOR
#
Read [ATX]NUMERO = WLAN;LABR
  Case fstat
    When 0 :
      [M:ATT]TXTABR(nolign) = [F:ATX]TEXTE
    When Default :
      [M:ATT]TXTABR(nolign) = ""
  Endcase
[M:ATT]NUMABR(nolign) = LABR
#
Read [ATX]NUMERO = WLAN;LLON
  Case fstat
    When 0 :
      [M:ATT]TXTLON(nolign) = [F:ATX]TEXTE
    When Default :
      [M:ATT]TXTLON(nolign) = ""
  Endcase
[M:ATT]NUMLON(nolign) = LLON
# Dans la nouvelle langue ligne suivante
[M:ATT]BASPAG2 += 1
nolign         += 1
WLAN = [M:ATT]LANTRAD
Read [ATX]NUMERO = WLAN;LNOR
  Case fstat
    When 0 :
      [M:ATT]TXTNOR(nolign) = [F:ATX]TEXTE
    When Default :
      [M:ATT]TXTNOR(nolign) = ""
  Endcase
[M:ATT]NUMNOR(nolign) = LNOR
#
Read [ATX]NUMERO = WLAN;LABR
  Case fstat
    When 0 :
      [M:ATT]TXTABR(nolign) = [F:ATX]TEXTE
    When Default :
      [M:ATT]TXTABR(nolign) = ""
  Endcase
[M:ATT]NUMABR(nolign) = LABR
#
Read [ATX]NUMERO = WLAN;LLON
  Case fstat
    When 0 :
      [M:ATT]TXTLON(nolign) = [F:ATX]TEXTE
    When Default :
      [M:ATT]TXTLON(nolign) = ""
  Endcase
[M:ATT]NUMLON(nolign) = LLON
[M:ATT]TXTNOROLD(nolign) = [M:ATT]TXTNOR(nolign)
[M:ATT]TXTABROLD(nolign) = [M:ATT]TXTABR(nolign)
[M:ATT]TXTLONOLD(nolign) = [M:ATT]TXTLON(nolign)
#
[M:ATT]BASPAG2 += 1
nolign         += 1
End

############################################################
Subprog MAJ_TEXTE(LNUM,LTXT)
Value Integer LNUM
Value Char    LTXT

Local Char MESSAGE(250)
Local Integer ASTATUS

Local Char WLAN
WLAN = [M:ATT]LANTRAD

If LNUM = 0 : End : Endif

If WLAN = GFRA
      #115210/6
      If LNUM < GMAXTXTSTD | LNUM>GNEWTXTSTD
            End
      Endif
Endif

#lecture dans la langue de trad
Read [ATX]NUMERO = WLAN;LNUM
If fstat=0
 [F:ATX]CLEREC = left$(vireblc(toupper(ctrans(LTXT)),4),20)
 [F:ATX]TEXTE  = LTXT
 [F:ATX]LANORI= ""
 Call FLDUPD("ATX") From OBJDIV
 Rewrite [ATX]
 If fstat : GOK = 0 : Call FSTA("ATX") From GLOCK : End : Endif
 #115210
 If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" & ([F:ATX]NUMERO<GMAXTXTSTD | [F:ATX]NUMERO>GNEWTXTSTD)
   ASTATUS = func ATXTSVC.TRANSLATE_ONETEXT_CHAR(GPRODUIT, [F:ATX]NUMERO, [F:ATX]LAN, [F:ATX]TEXTE,[F:ATX]COMMENT,MESSAGE)
   If ASTATUS<>[V]CST_AOK
    GMESSAGE=MESSAGE : GOK=0
   Endif
 Endif
Else
 WLAN = GFRA
 Read [ATX2]NUMERO = WLAN;LNUM
 If fstat=0
  [F:ATX]       = [F:ATX2]
  [F:ATX]CLEREC = left$(vireblc(toupper(ctrans(LTXT)),4),20)
  [F:ATX]LAN    = [M]LANTRAD
  [F:ATX]TEXTE  = LTXT
  [F:ATX]LANORI= ""
  Call FLDCRE("ATX") From OBJDIV
  Write [ATX]
  If fstat : GOK = 0 : Call FSTA("ATX") From GLOCK : End : Endif
  #115210
  If func AFNC.PARAMDOS(nomap,"ATXTSRV")="2" & ([F:ATX]NUMERO<GMAXTXTSTD | [F:ATX]NUMERO>GNEWTXTSTD)
    ASTATUS = func ATXTSVC.TRANSLATE_ONETEXT_CHAR(GPRODUIT, [F:ATX]NUMERO, [F:ATX]LAN, [F:ATX]TEXTE,[F:ATX]COMMENT,MESSAGE)
    If ASTATUS<>[V]CST_AOK
     GMESSAGE=MESSAGE : GOK=0
    Endif
  Endif
 Endif
Endif

End

############################################################
Subprog MAJ_TRACE(LZON,LNUM,LFRA,LETR)
Value Char    LZON
Value Integer LNUM
Value Char    LFRA
Value Char    LETR
#
If GOK = 1
    WMSG = [M:ATT]CODFIC-LZON+LFRA+"    "+LETR+" ("+num$(LNUM)+")"
    Call ECR_TRACE(WMSG,0) From GESECRAN
Else
    WMSG = [M:ATT]CODFIC-LZON-LFRA-mess(17,107,1)
    Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
End

########################################################################
Subprog ATEXTE_X3IND130 (WAPPLI,WNUMERO,WTEXTE)
Value Char WAPPLI
Value Integer WNUMERO
Value Char WTEXTE

If WNUMERO = 0      : End : Endif
#115210/6
If WNUMERO > GMAXTXTSTD  & WNUMERO<GNEWTXTSTD : End : Endif

Local Char WLANTRAD

WLANTRAD = [M]LANTRAD

# Mise a jour fichier ATEXTE pour X3IND130
# MAIS avant on controle que le fra de X3IND130 = fra du dossier ref
# sinon on ne copie pas X3IND130 car dossier ref pas a jour
Local Char WTEXTE_FRA(150)
Local Char WTEXT_INDUS(150)
Local Char WCOMMENT_INDUS(80)

Local Char WLAN_INDUS(GLONLAN)
Local Integer WNUM_INDUS

Local Char WTEXTE_COMMENT(40)


Read [XTX]NUMERO = GFRA;WNUMERO
If fstat = 0
    WTEXTE_FRA = [F:XTX]TEXTE
    WTEXTE_COMMENT = [F:XTX]COMMENT
Else
    # on ne met rien a jour car pas present dans x3ind130
    End
Endif

# lecture de fra dans le dossier ref
# n'existe pas encore .. dossier n'est pas a jour
Read [ATX2]NUMERO = GFRA;WNUMERO
If fstat = 0
    If [F:ATX2]TEXTE <> WTEXTE_FRA
      Call ECR_TRACE("INDUS FOLDER will not be updated, contact ADONIX indus from gaillard",1) From GESECRAN
      End
    Endif
Else
      Call ECR_TRACE("INDUS FOLDER will not be updated, contact ADONIX indus from GAILLARD",1) From GESECRAN
      End
Endif

# on enregistre le texte dans la langue de traduction
Read [XTX]NUMERO = WLANTRAD;WNUMERO
Case fstat
        When 0 :
           [F:XTX]CLEREC  = left$(vireblc(toupper(ctrans(WTEXTE)),4),20)
           [F:XTX]TEXTE  = WTEXTE
           [F:XTX]LANORI= ""
           Call FLDUPD("XTX") From OBJDIV
           Rewrite [XTX]
           If fstat : GOK = 0 : Call FSTA("XTX") From GLOCK : Endif
           WTEXT_INDUS = WTEXTE
           WLAN_INDUS = [M:ATT]LANTRAD
           WNUM_INDUS= WNUMERO
           WCOMMENT_INDUS=""
           # 7 sept 2007
           # sur la v140 on ne remonte pas le GER
           # idem arabe
           If [M:ATT]LANTRAD <> "GER" and [M:ATT]LANTRAD <> "POL" and [M:ATT]LANTRAD <> "RUS" and [M:ATT]LANTRAD <> "ARB"
               Gosub MAJSUPER_140 From ASUPERV140
           Endif
           # 26 octobre 2009 idem pour polonais et russe en v5
           # idem arabe
           If [M:ATT]LANTRAD <> "POL" and [M:ATT]LANTRAD <> "RUS" and [M:ATT]LANTRAD <> "ARB"
               Gosub MAJSUPER_150 From ASUPERV150
           Endif
           # idem arabe
           If [M:ATT]LANTRAD <> "ARB"
               Gosub MAJSUPER_160 From ASUPERV160
           Endif
           Gosub MAJSUPER_170 From ASUPERV170
           Gosub MAJSUPER_180 From ASUPERV180
           Gosub MAJSUPER_190 From ASUPERV190
        When 4, 5 :
           #------------------------------------#
           # vérif si enre existe en fra
           #------------------------------------#
           WLANTRAD = GFRA
           Read [ATX2]NUMERO = WLANTRAD;WNUMERO
              Case fstat
                When 0 :
                    [F:XTX]       = [F:ATX2]
                    [F:XTX]LAN    = [M:ATT]LANTRAD
                    [F:XTX]CLEREC  = left$(vireblc(toupper(ctrans(WTEXTE)),4),20)
                    [F:XTX]TEXTE  = WTEXTE
                    [F:XTX]LANORI= ""
                    Call FLDCRE("XTX") From OBJDIV
                    Write [XTX]
                    If fstat : GOK = 0 : Call FSTA("XTX") From GLOCK  : Endif
                    # dans le cas du BRI on met a jour egalement langue USA uniquement en creation
                  # suite a demande (2007) sophie rebeyrotte : inversion
                  # c'est maintenant le ENG qui est maitre et qui met a jour le bri

                    If GUSER = "XENG" and [M:ATT]LANTRAD = "ENG"
                        Read [ATX2]NUMERO = "BRI";WNUMERO
                        Case fstat
                            When 4, 5 :
                                Read [ATX2]NUMERO = WLANTRAD;WNUMERO
                                [F:XTX]        = [F:ATX2]
                                [F:XTX]LAN     = "BRI"
                                [F:XTX]CLEREC  = left$(vireblc(toupper(ctrans(WTEXTE)),4),20)
                                [F:XTX]TEXTE   = WTEXTE
                                [F:XTX]LANORI= ""
                                Call FLDCRE("XTX") From OBJDIV
                                Write [XTX]
                                If fstat : GOK = 0 : Call FSTA("XTX") From GLOCK  : Endif
                        Endcase
                    Endif
                    WLANTRAD = [M]LANTRAD
                    WTEXT_INDUS = WTEXTE
                    WLAN_INDUS = [M:ATT]LANTRAD
                    WNUM_INDUS= WNUMERO
                    WCOMMENT_INDUS=""
                    # 7 sept 2007
                    # sur la v140 on ne remonte pas le GER
                    If [M:ATT]LANTRAD <> "GER" and [M:ATT]LANTRAD <> "POL" and [M:ATT]LANTRAD <> "RUS" and [M:ATT]LANTRAD <> "ARB"
                       Gosub MAJSUPER_140 From ASUPERV140
                    Endif
                    If [M:ATT]LANTRAD <> "POL" and [M:ATT]LANTRAD <> "RUS" and [M:ATT]LANTRAD <> "ARB"
                            Gosub MAJSUPER_150 From ASUPERV150
                    Endif
                    If [M:ATT]LANTRAD <> "ARB"
                        Gosub MAJSUPER_160 From ASUPERV160
                    Endif
                    Gosub MAJSUPER_170 From ASUPERV170
                    Gosub MAJSUPER_180 From ASUPERV180
                    Gosub MAJSUPER_190 From ASUPERV190
                Endcase
            WLANTRAD = [M]LANTRAD
        When Default :
            GOK = 0
            Call FSTA("XTX") From GLOCK
Endcase
End



####################################################################################################
######################## ETIQUETTES CHAMPS  ########################################################
####################################################################################################

############################################################
Subprog AS_CODFIC(VALEUR)
Variable Char    VALEUR()
End

############################################################
Subprog C_CODFIC(VALEUR)
Variable Char    VALEUR()
If [M:ATT]LANTRAD = ""
  mkstat = 2
Endif
End

############################################################
Subprog AV_BASPAG2
End

############################################################
Subprog APRES_BASPAG2
If mod(nolign,2) = 0
  If [M:ATT]TXTNOR(nolign-1) <> [M:ATT]TXTNOROLD(nolign-1) |
&    [M:ATT]TXTABR(nolign-1) <> [M:ATT]TXTABROLD(nolign-1) |
&    [M:ATT]TXTLON(nolign-1) <> [M:ATT]TXTLONOLD(nolign-1)
    [M:ATT]UPDFLG(nolign-1) = 2
  Else
    [M:ATT]UPDFLG(nolign-1) = 1
  Endif
Else
  [M:ATT]UPDFLG(nolign-1) = 0
Endif
Affzo [M:ATT]TXTNOR(nolign-1)
Affzo [M:ATT]TXTABR(nolign-1)
Affzo [M:ATT]TXTLON(nolign-1)
Affzo [M:ATT]UPDFLG(nolign-1)
End

############################################################
Subprog AV_UPDFLG(VALEUR)
Variable Integer  VALEUR()
If mod(nolign,2) = 0
  If [M:ATT]TXTNOR(nolign-1) <> [M:ATT]TXTNOROLD(nolign-1) |
&    [M:ATT]TXTABR(nolign-1) <> [M:ATT]TXTABROLD(nolign-1) |
&    [M:ATT]TXTLON(nolign-1) <> [M:ATT]TXTLONOLD(nolign-1)
    VALEUR = 2
  Else
    VALEUR = 1
  Endif
Else
  [M:ATT]UPDFLG(nolign-1) = 0
Endif
End

############################################################
Subprog C_LANTRAD(VALEUR)
Variable Char    VALEUR()

#Interdire de traduire en Francais
#If VALEUR = GFRA or VALEUR = [M]LANREF
# mkstat = 2
# End
#Endif

If VALEUR = [M]LANREF
 mkstat = 2
 End
Endif

Read [TLA]TLA0=VALEUR
If fstat
 mkstat = 2
Endif
End

############################################################
Subprog AV_LANTRAD(VALEUR)
Variable Char    VALEUR()
End

#############################################################
Subprog AM_LANTRAD(VALEUR)
Variable Char    VALEUR()

GLANTRAD = VALEUR
If [M:ATT]CODFIC <> ""
  Gosub LIENS
  Affzo [M:ATT]10
Endif
End

############################################################
Subprog AS_TXTLON(VALEUR)
Variable Char    VALEUR()
If mod(nolign-1,2) = 0
    mkstat = 2
    End
Endif

# rien a saisir si langue fra et numero <  50000
# modif du texte fra uniquement si texte spécifique
If [M]LANTRAD = GFRA
    #115210/6
    If [M]NUMLON (nolign-1) < GMAXTXTSTD | [M]NUMLON (nolign-1)>GNEWTXTSTD
        mkstat = 2
        End
    Endif
Endif


End

############################################################
Subprog AM_TXTLON(VALEUR)
Variable Char    VALEUR()
If [M:ATT]NUMLON(nolign-1) = [M:ATT]NUMNOR(nolign-1)
  [M:ATT]TXTNOR(nolign-1) = VALEUR
  Affzo [M:ATT]TXTNOR(nolign-1)
Endif
If [M:ATT]NUMLON(nolign-1) = [M:ATT]NUMABR(nolign-1)
  [M:ATT]TXTABR(nolign-1) = VALEUR
  Affzo [M:ATT]TXTABR(nolign-1)
Endif
End

############################################################
Subprog AS_TXTNOR(VALEUR)
Variable Char    VALEUR()
If mod(nolign-1,2) = 0
    mkstat = 2
    End
Endif

If [M:ATT]NUMNOR(nolign-1) = [M:ATT]NUMLON(nolign-1)
    mkstat = 2
    End
Endif

# rien a saisir si langue fra et numero <  50000
# modif du texte fra uniquement si texte spécifique
If [M]LANTRAD = "FRA"
    #115210/6
    If [M]NUMNOR (nolign-1) < GMAXTXTSTD | [M]NUMNOR (nolign-1)>GNEWTXTSTD
        mkstat = 2
        End
    Endif
Endif

End

############################################################
Subprog AM_TXTNOR(VALEUR)
Variable Char    VALEUR()
If [M:ATT]NUMNOR(nolign-1) = [M:ATT]NUMABR(nolign-1)
  [M:ATT]TXTABR(nolign-1) = VALEUR
  Affzo [M:ATT]TXTABR(nolign-1)
Endif
If [M:ATT]NUMNOR(nolign-1) = [M:ATT]NUMLON(nolign-1)
  [M:ATT]TXTLON(nolign-1) = VALEUR
  Affzo [M:ATT]TXTLON(nolign-1)
Endif
End

############################################################
Subprog AS_TXTABR(VALEUR)
Variable Char    VALEUR()
If mod(nolign-1,2) = 0
    mkstat = 2
    End
Endif
If [M:ATT]NUMABR(nolign-1) = [M:ATT]NUMLON(nolign-1)
    mkstat = 2
    End
Endif
If [M:ATT]NUMABR(nolign-1) = [M:ATT]NUMNOR(nolign-1)
    mkstat = 2
    End
Endif

# rien a saisir si langue fra et numero <  50000
# modif du texte fra uniquement si texte spécifique
If [M]LANTRAD = "FRA"
    #115210/6
    If [M]NUMABR (nolign-1) < GMAXTXTSTD | [M]NUMABR (nolign-1)>GNEWTXTSTD
        mkstat = 2
        End
    Endif
Endif


End

############################################################
Subprog AM_TXTABR(VALEUR)
Variable Char    VALEUR()
End

############################################################
Subprog B1_TXTLON(VALEUR)
Variable Char    VALEUR()
Local Integer WNUM
End

############################################################
Subprog B1_TXTNOR(VALEUR)
Variable Char    VALEUR()
Local Integer WNUM
End

############################################################
Subprog B1_TXTABR(VALEUR)
Variable Char    VALEUR()
Local Integer WNUM
End

