#<AdxTL>@(#)1.0.0.0 $Revision$
############################################################
# Calcul des réapprovionnements hors MRP action SAISTKB
############################################################
$ACTION
Case ACTION
  When "OUVRE_BATCH"  : Gosub OUVRE_BATCH_REAHCB
  When "INIT"         : Gosub INIT_REAHCB
  When "DEBUT"        : Gosub DEBUT_REAHCB
  When "CONTROLE"     : Gosub CONTROLE_REAHCB
  When "EXEC"         : Gosub EXEC_REAHCB
  When "TERMINE"      : Gosub TERMINE_REAHCB
  When "INIT_DIA"     : Gosub INIT_DIA_REAHCB
  When "OK"           : Gosub OK_REAHCB
  When "END"          : Gosub END_REAHCB
Endcase
Return
############################################################
$OUVRE_BATCH_REAHCB
# FQ 43367 10/2007
Gosub OPEN_FILE
Return
############################################################
$INIT_REAHCB
Gosub OPEN_FILE
Local Mask STKB [DIA]
Raz [M:DIA] : # FQ 44560 GA 12/2007
If !GSERVEUR
  Call OUVRE_TRACE(mess(91,196,1)) From LECFIC
Endif
Return
############################################################
$DEBUT_REAHCB
# Issue 118005
Call LECMEMO("STD","[M:DIA]","stkb") From GMEMO
Affzo [DIA] : # GH 10/05/12 bug 81969
Return
#############################################################
$CONTROLE_REAHCB
Return
#############################################################
$EXEC_REAHCB
If [M:DIA]STOFCY <> ""
  Gosub TRAITEMENT
Endif
Return
#############################################################
$TERMINE_REAHCB
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif
Return
#############################################################
$INIT_DIA_REAHCB
Local Integer LRET
Raz [M:DIA]
[M:DIA]STOFCY = GFCYDEF(0)
# 02.05 28716
# controle compteur encours
Call CTRCPT(GSTKCPT(8),GLONVCR+10, LRET) From STKLIB
If LRET <> 0
  GMESSAGE = mess(222,199,1)
  GERR = 1
  FIN  = 1
#Else
#  Raz [M:DIA]
#  [M:DIA]STOFCY = GFCYDEF(0)
Endif
Return
#############################################################
$OK_REAHCB
FIN  = 1
Return
#############################################################
$END_REAHCB
Close Local File [F:ORDR] : # FQ 45011
Close Local File [F:ORDB] : # FQ 45011
Raz [M:DIA]
FIN = 1
Return
############################################################
$TRAITEMENT
If GSERVEUR
  Onerrgo ERRBATCH
Endif
Gosub TRT_INI
WMSG = mess(91,196,1)+" : "+[M:DIA]STOFCY
#
Call PRTSCR("STKB","","",0,1) From ATRTX3
Gosub GEN_FILTER
WFCY = [M:DIA]STOFCY
WTRS = [M:DIA]REOLEVCOD
If WTRS=3 WBAS=0 # Issue 92392 GA 10/2013 Calculation only
Else      WBAS = [M:DIA]REOLEVBAS
Endif
WTRP = [M:DIA]REOPERCOD
If WTRP=3 WBAP=0 # Issue 92392 GA 10/2013 Calculation only
Else      WBAP = [M:DIA]REOPERBAS
Endif
WTSD = [M:DIA]REOTSDCLC
WSAF = [M:DIA]SAFSTOCLC
WMIN = [M:DIA]REOMINCLC
WMAX = [M:DIA]MAXSTOCLC
WMES = 1
Call CALREAPRO(WFCY,WITF,WITM1,WITM2,WTRS,WBAS,WTRP,WBAP,WTSD,WSAF,WMIN,WMAX,WMES,WRET)
&    From FUNSTKB
#
Return
###########################################################
#Génération des filtres [ITF] et [ITM] en fonction des sélections
$GEN_FILTER
Local Integer I
WITF  = ""
WITM1 = ""
WITM2 = ""
#Filtre [ITF]
If [M:DIA]ITMREFSTR <> "" | [M:DIA]ITMREFEND <> ""
  WITF = "ITMREF>='"+[M:DIA]ITMREFSTR+"'&ITMREF<='"+[M:DIA]ITMREFEND+"'"
Endif
If [M:DIA]PLNSTR <> ""    | [M:DIA]PLNEND <> ""
  If WITF <> ""
    WITF = WITF+"&"
  Endif
  WITF = WITF+"PLANNER>='"+[M:DIA]PLNSTR+"'&PLANNER<='"+[M:DIA]PLNEND+"'"
Endif
If ([M:DIA]ABCCLSA = 2 | [M:DIA]ABCCLSB = 2 | [M:DIA]ABCCLSC = 2)
  If WITF <> ""
    WITF = WITF+"&"
  Endif
  WITF = WITF+"find([F:ITF]ABCCLS"
  If [M:DIA]ABCCLSA = 2
    WITF = WITF+",1"
  Endif
  If [M:DIA]ABCCLSB = 2
    WITF = WITF+",2"
  Endif
  If [M:DIA]ABCCLSC = 2
    WITF = WITF+",3"
  Endif
  WITF = WITF+")<>0"
Endif
#Filtre [ITM]
WITM1 = "([F:ITM]LIFSTRDAT=[0/0/0]|[F:ITM]LIFSTRDAT<=date$)&([F:ITM]LIFENDDAT=[0/0/0]|[F:ITM]LIFENDDAT>=date$)"
WITM2 = "[F:ITM]ITMSTA<4"
If [M:DIA]ITGCODSTR <> "" | [M:DIA]ITGCODEND <> ""
  WITM1 += "&[F:ITM]TCLCOD>='"+[M:DIA]ITGCODSTR+"'&[F:ITM]TCLCOD<='"+[M:DIA]ITGCODEND+"'"
Endif
If dim([M:DIA]TSICODSTR) > 0
  For I = 0 To dim([M:DIA]TSICODSTR)-1
    If [M:DIA]TSICODSTR(I) <> "" | [M:DIA]TSICODEND(I) <> ""
      If I < 3
        WITM1 += "&[F:ITM]TSICOD("+num$(I)+")>='"+[M:DIA]TSICODSTR(I)+
&                "'&[F:ITM]TSICOD("+num$(I)+")<='"+[M:DIA]TSICODEND(I)+"'"
      Else
        WITM2 += "&[F:ITM]TSICOD("+num$(I)+")>='"+[M:DIA]TSICODSTR(I)+
&                "'&[F:ITM]TSICOD("+num$(I)+")<='"+[M:DIA]TSICODEND(I)+"'"
      Endif
    Endif
  Next I
Endif
Return
############################################################
$TRT_INI
Local Char    WFCY(GLONFCY)
Local Char    WITF(250)
Local Char    WITM1(250)
Local Char    WITM2(250)
Local Integer WTRS
Local Integer WBAS
Local Integer WTRP
Local Integer WBAP
Local Integer WTSD
Local Integer WSAF
Local Integer WMIN
Local Integer WMAX
Local Integer WDMY
Local Integer WMES
Local Integer WRET
Local Char    WMSG(120)
Local Integer WBAT
Local Integer SAVOBJET
#Local Char    SAVPROG
Local Integer CHOIX
Local Integer WFSTAT
Local Integer WBOU(1..GNBBOU)
Return
###########################################################
# Routine de base de calcul des réappro hors MRP
# LFCY = site
# LITF = Expression pour Filter sur ITF
# LITM1= Expression pour selections ITM
# LITM2= Expression pour selections ITM
# LTRS = Flag traitement sur seuil
# LBAS = Base traitement sur seuil
# LTRP = Flag traitement périodique
# LBAP = Base traitement périodique
# LTSD = Flag recalcul seuil réapro
# LSAF = Flag recalcul stock sécurité
# LMIN = Flag recalcul lot économique
# LMAX = Flag recalcul stock maxi
# LMSG = Code fichier trace 0 = non / 1 = oui / 2 = oui déjà ouvert
# LRET = Code retour
Subprog CALREAPRO(LFCY,LITF,LITM1,LITM2,LTRS,LBAS,LTRP,LBAP,LTSD,LSAF,LMIN,LMAX,LMSG,LRET)
Variable Char    LFCY
Variable Char    LITF
Variable Char    LITM1
Variable Char    LITM2
Variable Integer LTRS
Variable Integer LBAS
Variable Integer LTRP
Variable Integer LBAP
Variable Integer LTSD
Variable Integer LSAF
Variable Integer LMIN
Variable Integer LMAX
Variable Integer LMSG
Variable Integer LRET
#
Local    Integer IT, IW
Local    Decimal TISS(100) :# Consommations mensuelles
Local    Decimal WNJC      :# Nombre moyen jours calendaires / mois
Local    Decimal WNJO      :# Nombre moyen jours ouvrés / mois
Local    Decimal WJOU      :# zone de travail nombre jours
Local    Decimal WDEL
#Zones de travail
Local    Decimal WTSD, WWTSD
Local    Decimal WSAF, WWSAF
Local    Decimal WMIN, WWMIN
Local    Decimal WMAX, WWMAX
#Indicateurs de traitement
Local    Integer ITSD
Local    Integer ISAF
Local    Integer IMIN
Local    Integer IMAX
#
Local    Integer WFSTAT
Local    Integer I
Local    Char    WINT(15)
Local    Char    WFIL(60)
Local    Integer WRET
Local    Char    WFMT(10) : #, WFMTVCR(10)
Local    Date    WDAT
# 03.06 35277
Local    Date    TODAY     : TODAY  = date$
#Test traitement
If LTRS = 1 & LTRP = 1
  End
Endif
Call TEMPON("C") From GESECRAN
#Ouverture fichiers
Gosub OPEN_FILE


#Génération filtre articles selon traitement
WFIL = "STOFCY=LFCY&ABCCLS<4&find([F:ITF]REOMGTCOD"
Case LTRS
  When 2, 3 : WFIL += ",4"
Endcase
Case LTRP
  When 2, 3 : WFIL += ",5"
Endcase
WFIL += ")<>0"

#---------
# PE permettant d'ajouter des filtres supplémentaires 01.07 39278
GPOINT = "CUSFLT"
Gosub  ENTREE From EXEFNC
#---------

If LITF = ""
  Filter [ITF] Where evalue(WFIL)
&              Order By Key ITF0
Else
  Filter [ITF] Where evalue(WFIL) & evalue(LITF)
&              Order By Key ITF0
Endif
#
For [ITF]
  WFSTAT = fstat
  WWSAF = [F:ITF]SAFSTO
  WWTSD = [F:ITF]REOTSD
  WWMIN = [F:ITF]REOMINQTY
  WWMAX = [F:ITF]MAXSTO
  I     = 1
  Read [ITM]ITM0=[F:ITF]ITMREF
  If fstat = 0
    If !(evalue(LITM1) & evalue(LITM2))
      I = 0
    Endif
    #--- Issue 103815
    #Call LECITV([F:ITF]STOFCY,[F:ITF]ITMREF, "",WRET) From STKLIB
    #If WRET > 1
    #  I = 0
    #Endif
    Read [ITV]ITV0=[F:ITF]ITMREF;[F:ITF]STOFCY
    If find(fstat,4,5)
      # Issue 117230 GH 27/09/16 - record creation managed now inside a transaction
      Trbegin [ITV]
        Raz [F:ITV]
        [F:ITV]ITMREF = [F:ITF]ITMREF
        [F:ITV]STOFCY = [F:ITF]STOFCY
        Call ECRITV From STKLIB
      If fstat
         Commit
      Else
         I = 0
         Rollback
      Endif
    Endif
    #---
    Read [TUN]TUN0=[F:ITM]STU
    If fstat
      I = 0
    Endif
#constitution format quantité
    If [F:TUN]UOMDEC <> 0
      WFMT = "N:11."+num$([F:TUN]UOMDEC)
    Else
      WFMT = "N:15"
    Endif
    Read [ITG]ITG0="";[F:ITM]TCLCOD
    If fstat
      I = 0
    Endif
    If I = 1
      # Issue 92392 GA 10/2013 simplified :-)
      #If (LBAS = 0 | LBAS > 1) | (LBAP = 0 | LBAP > 1)
      #   If (LTSD = 2 | LSAF = 2 | LMIN = 2 | LMAX = 2)
      If (LBAS <> 1 | LBAP <> 1) & (LTSD = 2 | LSAF = 2 | LMIN = 2 | LMAX = 2)
          GOK = 1
          Trbegin [ITF]
            Gosub CAL_DATA
          If GOK = 1
            Commit
          Else
            I = 0
            Rollback
          Endif
      Endif
      If I = 1
        Case [F:ITF]REOMGTCOD
          When 4 : If LTRS = 2 : Gosub REA_SEUIL : Endif
          When 5 : If LTRP = 2 : Gosub REA_PERIO : Endif
        Endcase
      Endif
    Endif
  Endif
  fstat = WFSTAT
Next
Filter [ITF]
#
Call TEMPOFF From GESECRAN
End
###########################################################
#Reapprovisionnement sur seuil
$REA_SEUIL
Local Decimal WDIS
Local Decimal WSEU
Local Decimal WLOT
Local Decimal WQTY
If LBAS = 1
  WSEU = [F:ITF]REOTSD
  WLOT = [F:ITF]REOMINQTY
Else
  WSEU = WWTSD
  WLOT = WWMIN
Endif
GOK  = 1
Trbegin [ORD]
WMSG = ""
Gosub DEL_ORDERS
If GOK = 1

# 01/2008 FQ 45011
  Gosub CAL_STODIS

  # 11.05 33334 (strictement inférieur)
  If WDIS < WSEU
    WQTY = WSEU - WDIS
    Gosub CTL_LOT   # FQ 70831 GA 01/2011 ajuster au lot technique ?
    Gosub ECR_ORDERS
  Endif
Endif
If GOK = 1
  Commit
  If LMSG <> 0 & WMSG <> ""
    Call ECR_TRACE(WMSG,0)
  Endif
Else
  Rollback
  WMSG = [F:ITF]STOFCY+" "+format$("K:"+num$(GLONITM)+"X",[F:ITF]ITMREF)+" "+mess(12,100,1)
  Call ECR_TRACE(WMSG,1)
Endif
Return
###########################################################
#Réapprovisionnement periodique (sur seuil hors periodicité)
$REA_PERIO
Local Decimal WDIS
Local Decimal WSEU
Local Decimal WLOT
Local Decimal WQTY
Local Decimal WMAX
If [F:ITV]LASREODAT = [0/0/0]
  WDAT = date$-[F:ITF]REOPER
Else
  WDAT = [F:ITV]LASREODAT
Endif
If LBAP = 1
  WSEU = [F:ITF]REOTSD
  WLOT = [F:ITF]REOMINQTY
  WMAX = [F:ITF]MAXSTO
Else
  WSEU = WWTSD
  WLOT = WWMIN
  WMAX = WWMAX
Endif

# 01/2008 FQ 45011
Gosub CAL_STODIS

WQTY = WMAX - WDIS
#
If WQTY<0          # Issue 88377 GA 08/2013 trop de stock ?
    WMSG = [F:ITF]STOFCY+" "+format$("K:"+num$(GLONITM)+"X",[F:ITF]ITMREF)+" "+mess(621,199,0)
    Call ECR_TRACE(WMSG,-1)
    Return
Elsif WQTY>0       # Issue 88377 GA 08/2013 ne pas ajuster au lot si aucun réappro
   Gosub CTL_LOT   # FQ 70831 GA 01/2011 ajuster au lot technique ?
Endif
#
If (WDAT+[F:ITF]REOPER) <= date$
  Trbegin [ORD], [ITV]
  GOK  = 1
  WMSG = ""
  If WQTY > 0
    Gosub DEL_ORDERS
    If GOK = 1
      Gosub ECR_ORDERS
    Endif
  Endif
  If GOK = 1
    [F:ITV]LASREODAT = WDAT+[F:ITF]REOPER
    Rewrite [ITV]
      If fstat : GOK = 0 : Call FSTA("ITV") From GLOCK : Endif
  Endif
  If GOK = 1
    Commit
    If LMSG <> 0 & WMSG <> ""
      Call ECR_TRACE(WMSG,0)
    Endif
  Else
    Rollback
    WMSG = [F:ITF]STOFCY+" "+format$("K:"+num$(GLONITM)+"X",[F:ITF]ITMREF)+" "+mess(12,100,1)
    Call ECR_TRACE(WMSG,1)
  Endif
Else
  # FQ 69074 GA 11/2010 avant If WDIS <= WSEU (idem autres cas)
  If WDIS < WSEU
    Trbegin [ORD]
    GOK = 1
    WMSG = ""
    If WQTY > 0
      Gosub DEL_ORDERS
      If GOK = 1
        Gosub ECR_ORDERS
      Endif
    Endif
    If GOK = 1
      Commit
      If LMSG <> 0 & WMSG <> ""
        Call ECR_TRACE(WMSG,0)
      Endif
    Else
      Rollback
      WMSG = [F:ITF]STOFCY+" "+format$("K:"+num$(GLONITM)+"X",[F:ITF]ITMREF)+" "+mess(12,100,1)
      Call ECR_TRACE(WMSG,1)
    Endif
  Endif
Endif
Return
###########################################################
# Effacement anciennes suggestions et traces
$DEL_ORDERS
# V6 GA 11/2008 (WIPTYP = 2 | WIPTYP = 5 | WIPTYP = 7 | WIPTYP = 9) &
# FQ 73645 GA 05/2011 sauf contremarque ?
Filter [ORD] Where STOFCY = [F:ITF]STOFCY                 &
&                  ITMREF = [F:ITF]ITMREF                 &
&                  find(WIPTYP,2,5,7,9,13)<>0             &
&                  FMI     < 2                            &
&                  WIPSTA = 3
&            Order By Key ORD1
For [ORD]
# FQ 71164 GA 05/2011 pour que la trace soit correcte: trace de Suppression
  WMSG = mess(53,123,1)-[F:ITF]STOFCY+" "+format$("K:"+num$(GLONITM)+"X",[F:ITF]ITMREF)
&      + " "+format$("K:2X",mess([F:ORD]WIPTYP,341,1))+format$("K:1X",mess([F:ORD]WIPSTA,342,1))+" :"
&      + " "+format$("K:"+num$(GLONVCR)+"X",[F:ORD]WIPNUM)
&      + " "+format$(WFMT,[F:ORD]RMNEXTQTY)+" "+[F:ITM]STU
  Call DELSUG From CBNLIB
  If GOK <> 1
    Break
  Elsif [F:ITF]REOCOD=1 : # Issue 117230 GH 21/09/16 - deleted suggestions appear in the log when suggestions are not to generate anymore
    Call ECR_TRACE(WMSG,0) From GESECRAN
  Endif
Next
Raz WMSG
Filter [ORD]
Return
###########################################################
$ECR_ORDERS
If WQTY = 0
  Return
Endif

Raz [M:ORDK]

[M:ORDK]MAJCOD     = "C"
Case [F:ITF]REOCOD
  When 1 : # Issue 117230 GH 21/09/16 - when no suggestion is to generate, indicates the needed qty in the log
    WMSG = [F:ITF]STOFCY+" "+format$("K:"+num$(GLONITM)+"X",[F:ITF]ITMREF)+" "
    WMSG+= format$("K:15X",mess(99,198,1))+" : "+format$(WFMT,WQTY)+" "+[F:ITM]STU
    Goto ECR_ORDERS_FIN
  When 2 :
    [M:ORDK]WIPTYP = 2
    [M:ORDK]ORIFCY = [F:ITF]STOFCY
    [M:ORDK]STOFCY = [F:ITF]STOFCY
    # recherche fournisseur            llc 03.01 7449
    If [F:ITP]ITMREF <> [F:ITF]ITMREF
        Raz [F:ITP]   # FQ 76189 GA 09/2011
      # FQ 69315 GA 11/2010 selon FUNCBNA FQ 55168
        Filter [ITP] Where ITMREF=[F:ITF]ITMREF Order By Key ITP1
        #Read [ITP] First : If fstat : Raz [F:ITP] : Endif
        For [ITP]
          Read [BPR]BPR0=[F:ITP]BPSNUM
          If !fstat
              # FQ 69925 GA 01/2011 suite FQ 69315 avant WFCY
              If [F:BPR]FCY <> [F:ITF]STOFCY : [F:ORD]BPRNUM = [F:ITP]BPSNUM : Break : Endif
          Endif
        Next
        Filter [ITP]
    Endif
    [M:ORDK]BPRNUM = [F:ITP]BPSNUM
  When 3 :
    [M:ORDK]WIPTYP = 5
    [M:ORDK]ORIFCY = [F:ITF]STOFCY
    [M:ORDK]STOFCY = [F:ITF]STOFCY
  When 4 :
    [M:ORDK]WIPTYP = 8
    [M:ORDK]ORIFCY = [F:ITF]STOFCY
    [M:ORDK]STOFCY = [F:ITF]REOFCY
    If [F:ITF]REOFCY<>""  # Issue 97355 GA 03/2014 fournisseur intersite
        Filter [BPR] Where FCY=[F:ITF]REOFCY & BETFCY=2 & BPSFLG=2
        For [BPR]
            [M:ORDK]BPRNUM = [F:BPR]BPRNUM : Break
        Next
        Filter [BPR]
    Endif
  When 5 : # Sous-traitance
    [M:ORDK]WIPTYP = 13
    [M:ORDK]ORIFCY = [F:ITF]STOFCY
    [M:ORDK]STOFCY = [F:ITF]STOFCY
  When Default :                     # FQ 61715 GA 05/2010
    GOK = 0
    Goto ECR_ORDERS_FIN
Endcase
[M:ORDK]WIPSTA     = 3
# Numéro suggestion
Call NUMERO(GSUG,[M:ORDK]STOFCY,date$,"",[M:ORDK]WIPNUM,WRET) From SUBANM
If WRET = 1
  GOK = 0
  Goto ECR_ORDERS_FIN
Endif
[M:ORDK]ITMREF     = [F:ITF]ITMREF
[M:ORDK]PJT        = ""
[M:ORDK]STRDAT     = date$
# application délai (llc 06.04 21295)
Case [F:ITF]REOCOD
    When 2, 4    :
    #When 2      : # Issue 117230 GH 27/09/16 - for intersite, apply the purchase lead time instead of the production lead time
                   [M:ORDK]ENDDAT = [M:ORDK]STRDAT + [F:ITF]OFS
                   # 11.04 26623
                   If [F:FCY]FCY <> [F:ITF]STOFCY : Call LECTURE ("FCY", [F:ITF]STOFCY, "") From CONTOBJ : Endif
                   Call CTL_JOU2([M:ORDK]ENDDAT, [M:ORDK]STRDAT,[F:FCY]UVYDAY,[F:FCY]UVYCOD, 0)
    When 5       :
       # Issue 80214 GA 03/2012 Sous-traitance: idem FUNCBN Fournisseur, Alternative de nomenclature, Délai, ...
       Local Char    WSRVITMREF(GLONITM)
       Local Decimal WPURLTI : WPURLTI = [F:ITF]OFS
       If [M:ORDK]BPRNUM=""
         Call FIND_BPRNUM ([M:ORDK]ITMREF,[M:ORDK]BOMALT,"",[M:ORDK]STOFCY,[M:ORDK]BPRNUM) From SCOLIB
       Endif
       If [M:ORDK]BPRNUM = [F:ITP]BPSNUM & [F:ITP]BOMALT<>0
          [M:ORDK]BOMALT = [F:ITP]BOMALT
       Endif
       Call FIND_SCI_LTI([M:ORDK]ITMREF,[M:ORDK]BPRNUM,[M:ORDK]STOFCY,[M:ORDK]BOMALT,WSRVITMREF,WPURLTI) From SCOLIB
       [M:ORDK]ENDDAT = [M:ORDK]STRDAT + WPURLTI
       If [F:FCY]FCY <> [F:ITF]STOFCY : Call LECTURE ("FCY", [F:ITF]STOFCY, "") From CONTOBJ : Endif
       Call CTL_JOU2([M:ORDK]ENDDAT, [M:ORDK]STRDAT,[F:FCY]UVYDAY,[F:FCY]UVYCOD, 0)

    When Default : Call CALCUL_DATE_PLN([M:ORDK]STRDAT, [F:ITF]MFGLTI, [F:ITF]STOFCY, 0, [M:ORDK]ENDDAT) From MFGLIB
Endcase
[M:ORDK]VCRTYP     = 11
[M:ORDK]VCRNUM     = [M:ORDK]WIPNUM
[M:ORDK]VCRLIN     = 0
[M:ORDK]VCRSEQ     = 0
# FQ 78619 GA 01/2012
Call QTEARR(WQTY,[F:ITM]STU) From TRTDIV
[M:ORDK]EXTQTY     = WQTY
[M:ORDK]CPLQTY     = 0
[M:ORDK]ALLQTY     = 0
[M:ORDK]SHTQTY     = 0
#[M:ORDK]WORTIAQTY  = 0   : # Bug 78554
[M:ORDK]FMI        = 1
[M:ORDK]MRPMES     = 1
[M:ORDK]VCRTYPORI  = 0
[M:ORDK]VCRNUMORI  = ""
[M:ORDK]VCRLINORI  = 0
[M:ORDK]VCRSEQ     = 0
#[M:ORDK]BOMALT     = 0     # Issue 80214 GA 03/2012
[M:ORDK]ORI        = 3
[M:ORDK]ABBFIL     = ""
[M:ORDK]PIO        = 1        # llc 02.01 7867

# PE écriture suggestion (llc 08.04)
GPOINT = "BEFWRISUG"
Gosub  ENTREE From EXEFNC
If GPOINT = "" : Goto ECR_ORDERS_FIN : Endif

#constitution message et génération ordre POS ou WOS
WMSG = [F:ITF]STOFCY+" "+format$("K:"+num$(GLONITM)+"X",[F:ITF]ITMREF)
# Issue 117230 GH 21/09/16 - done previously in the label
#If [F:ITF]REOCOD = 1
#  WMSG = WMSG+format$("K:15X",mess(99,198,1))+" : "+format$(WFMT,WQTY)+" "+[F:ITM]STU
#Else
  Call WIP From TRTWIP
  # Issue 80214 GA 03/2012 ????
  #If find([F:ITF]REOCOD,4,5)
  If [F:ITF]REOCOD = 4
    [M:ORDK]WIPTYP = 7
    [M:ORDK]ORIFCY = [F:ITF]REOFCY : # <MG> 11683 27/11/01
    [M:ORDK]STOFCY = [F:ITF]STOFCY
    Call WIP From TRTWIP
  Endif
#    WFMTVCR = "K:"+num$(max(15,GLONVCR))+"X"   # V6 remplacement de "K:15X"
# FQ 71164 GA 05/2011 suite FQ 59780 la table ORD est local au TRTWIP, afficher les données de [M:ORDK]
  WMSG = WMSG+format$("K:2X",mess([M:ORDK]WIPTYP,341,1))+format$("K:1X",mess([M:ORDK]WIPSTA,342,1))+" :"
&      + " "+format$("K:"+num$(GLONVCR)+"X",[M:ORDK]WIPNUM)
&      + " "+format$(WFMT,WQTY)+" "+[F:ITM]STU
#Endif
$ECR_ORDERS_FIN
Return
###########################################################
# Calcul seuil, stock secu, lot éco, stock max
$CAL_DATA
Local Char    WPAR(10)
Local Decimal WSEC

# Recherche paramètres généraux
Call PARAM(LFCY,"AVGDAY",WPAR) From ADOVAL
WNJC = val(WPAR)
Call PARAM(LFCY,"AVGWRKDAY",WPAR) From ADOVAL
WNJO = val(WPAR)
If WNJC = 0 | WNJO = 0
  LRET = 99
  Return
Endif

# Recherche paramètres réappro (par catégorie article ou site)
Read [STE]STE0=LFCY;[F:ITM]TCLCOD
If fstat
   Read [STE]STE0=LFCY;""
   If fstat
      LRET = 99
      Return
   Endif
Endif

#Determination délai et nombre de jours moyen mensuel
# FQ 74264 GA 06/2011
#If [F:ITG]MFGFLG = 2 | [F:ITG]PURFLG = 2
# Issue 89920 GA 06/2013 ssi type suggestion = Fabrication # FQ 74264 GA 06/2011
#If [F:ITG]MFGFLG = 2
If [F:ITG]MFGFLG = 2 & [F:ITF]REOCOD=3
   WJOU = WNJO
   WDEL = [F:ITF]MFGLTI
Else
   WJOU = WNJC
   WDEL = [F:ITF]OFS
Endif

# Lecture fichier historique
Raz TISS, WTSD, WSAF, WMIN, WMAX, ITSD, ISAF, IMIN, IMAX
IT = 0
# Issue 117230 GH 27/09/16 - optimisation
#Filter [ITH] Where ITMREF = [F:ITF]ITMREF &
#&                  STOFCY = LFCY
#&            Order By Key ITH1
#Read [ITH] Last
#  If fstat
#    Goto CAL_DATA1
#  Else
#    # 03.06 35277 on ignore l'historique sur la période en cours (incomplet)
#    If (TODAY >= [F:ITH]PERSTR & TODAY < [F:ITH]PEREND) : Goto CAL_DATA0 : Endif
#    Gosub LOA_TABLES
#  Endif
#$CAL_DATA0
#Read [ITH] Prev
#  If fstat
#    Goto CAL_DATA1
#  Else
#    If  IT < dim(TISS)-1
#      Gosub LOA_TABLES
#      Goto CAL_DATA0
#    Else
#      Goto CAL_DATA1
#    Endif
#  Endif
#$CAL_DATA1
#Filter [ITH]
Filter [ITH] Where ITMREF = [F:ITF]ITMREF & STOFCY = LFCY
&            Order By Key ITH0 Desc
For [ITH]
   # 03.06 35277 on ignore l'historique sur la période en cours (incomplet)
   If !(TODAY >= [F:ITH]PERSTR & TODAY < [F:ITH]PEREND)
      If IT < dim(TISS)-1
         IT += 1
         TISS(IT) = [F:ITH]MONISSQTY
      Else Break
      Endif
   Endif
Next
Filter [ITH]

# Issue 117230 GH 27/09/16 - useless because already done before in this label
##Determination délai et nombre de jours moyen mensuel
## FQ 74264 GA 06/2011
##If [F:ITG]MFGFLG = 2 | [F:ITG]PURFLG = 2
#If [F:ITG]MFGFLG = 2
#   WJOU = WNJO
#   WDEL = [F:ITF]MFGLTI
#Else
#   WJOU = WNJC
#   WDEL = [F:ITF]OFS
#Endif

#Calcul stock sécurité
If LSAF = 2
  GPOINT = "CALSAFSTO"
  GPE    = 0
  Gosub ENTREE From EXEFNC
  If GPE = 0
    Call CAL_SAFSTO(TISS,IT,WJOU,WDEL,WSAF,ISAF) From FUNSTKB
  Endif
  If ISAF = 0
    WWSAF = WSAF
  Endif

Endif
#Calcul seuil réappro
If LTSD = 2
  If LSAF = 2 & ISAF = 0 & WSAF <> 0
    WSEC = WSAF                 # FQ 69925 GA 01/2011 avant [F:ITF]SAFSTOCLC (pas encore maj)
  Else
    WSEC = [F:ITF]SAFSTO
  Endif
  GPOINT = "CALREOTSD"
  GPE    = 0
  Gosub ENTREE From EXEFNC
  If GPE = 0
    Call CAL_REOTSD(TISS,IT,WJOU,WDEL,WSEC,WTSD,ITSD) From FUNSTKB
  Endif
  If ITSD = 0
    WWTSD = WTSD
  Endif
Endif
#Calcul Lot économique
If LMIN = 2
  GPOINT = "CALREOMIN"
  GPE    = 0
  Gosub ENTREE From EXEFNC
  If GPE = 0
    Call CAL_REOMIN(TISS,IT,WMIN,IMIN) From FUNSTKB
  Endif
  If IMIN = 0
    WWMIN = WMIN
  Endif
Endif
#Calcul stock maximum
If LMAX = 2
   #Determination nombre de jour moyen
   # FQ 74264 GA 06/2011
   #If [F:ITG]MFGFLG = 2 | [F:ITG]PURFLG = 2
   #If [F:ITG]MFGFLG = 2 : # Issue 38569 GH 22/11/2017 - to be consistent with other corrections for ticket 89920
   If [F:ITG]MFGFLG = 2 & [F:ITF]REOCOD=3
      WDEL = (([F:ITF]MFGLTI*7)/5)+[F:ITF]REOPER
   Else
      WDEL = [F:ITF]OFS+[F:ITF]REOPER
   Endif
  WJOU = WNJC
  GPOINT = "CALSTOMAX"
  GPE    = 0
  Gosub ENTREE From EXEFNC
  If GPE = 0
    Call CAL_STOMAX(TISS,IT,WJOU,WDEL,WMAX,IMAX) From FUNSTKB
  Endif
  If IMAX = 0
    WWMAX = WMAX
  Endif
Endif
#Mise à jour
Readlock [ITF] Curr
If fstat = 1
  WMSG = mess(20,100,1)+" : "+[F:ITF]ITMREF
  Call ECR_TRACE(WMSG,1)
  GOK = -1
  Return
Endif
If fstat
  GOK = 0
  Return
Endif
If ISAF = 0 : [F:ITF]SAFSTOCLC = WSAF : Endif
If ITSD = 0 : [F:ITF]REOTSDCLC = WTSD : Endif
If IMIN = 0 : [F:ITF]REOMINCLC = WMIN : Endif
If IMAX = 0 : [F:ITF]MAXSTOCLC = WMAX : Endif
Rewrite [ITF]
If fstat : GOK = 0 : Call FSTA("ITF") From GLOCK : Return : Endif
#Affichage trace
If LSAF = 2
  Call TEXTFIC("ITMFACILIT","SAFSTO",2,WINT) From OBJDIV
  WMSG = [F:ITF]STOFCY+" "+format$("K:"+num$(GLONITM)+"X",[F:ITF]ITMREF)+" "+format$("K:16X",WINT)
  Case ISAF
    When 0       :
      WMSG = WMSG+format$(WFMT,WSAF)+" "+format$("K:3X",[F:ITM]STU)
    When Default :
      WMSG = WMSG+mess(ISAF,731,1)
  Endcase
  If LMSG <> 0
    Call ECR_TRACE(WMSG,0)
  Endif
Endif
If LTSD = 2
  Call TEXTFIC("ITMFACILIT","REOTSD",2,WINT) From OBJDIV
  WMSG = [F:ITF]STOFCY+" "+format$("K:"+num$(GLONITM)+"X",[F:ITF]ITMREF)+" "+format$("K:16X",WINT)
  Case ITSD
    When 0       :
      WMSG = WMSG+format$(WFMT,WTSD)+" "+format$("K:3X",[F:ITM]STU)
    When Default :
      WMSG = WMSG+mess(ITSD,731,1)                # 06.05 30579
  Endcase
  If LMSG <> 0
    Call ECR_TRACE(WMSG,0)
  Endif
Endif
If LMIN = 2
  Call TEXTFIC("ITMFACILIT","REOMINQTY",2,WINT) From OBJDIV
  WMSG = [F:ITF]STOFCY+" "+format$("K:"+num$(GLONITM)+"X",[F:ITF]ITMREF)+" "+format$("K:16X",WINT)
  Case IMIN
    When 0       :
      WMSG = WMSG+format$(WFMT,WMIN)+" "+format$("K:3X",[F:ITM]STU)
    When Default :
      WMSG = WMSG+mess(IMIN,731,1)                # 06.05 30579
  Endcase
  If LMSG <> 0
    Call ECR_TRACE(WMSG,0)
  Endif
Endif
If LMAX = 2
  Call TEXTFIC("ITMFACILIT","MAXSTO",2,WINT) From OBJDIV
  WMSG = [F:ITF]STOFCY+" "+format$("K:"+num$(GLONITM)+"X",[F:ITF]ITMREF)+" "+format$("K:16X",WINT)
  Case IMAX
    When 0       :
      WMSG = WMSG+format$(WFMT,WMAX)+" "+format$("K:3X",[F:ITM]STU)
    When Default :
      WMSG = WMSG+mess(IMAX,731,1)                # 06.05 30579
  Endcase
  If LMSG <> 0
    Call ECR_TRACE(WMSG,0)
  Endif
Endif
Return
###########################################################
$LOA_TABLES
IT += 1
TISS(IT) = [F:ITH]MONISSQTY
Return
###########################################################
# Calcul stock de sécurité
# Classes [ITF] [STE] [ITG] Chargées
# LISS = Table des consommations mensuelles (valeurs récentes entête)
# LNBR = Nombre d'élements de LISS (chargés à partir de 1)
# LJOU = nombre de jour moyen mensuel (en accord avec délai)
# LDEL = Délai réappro
#
# LSAF = Stock de sécurité calculé
# LRET = Code retour 0 = OK
#                    1 = résultat calcul nul
#                    2 = Historique minimum insuffisant
#                    3 = Historique maximum non défini
#                    4 = Taux de service indéfini
#                    5 = Taux de service absent fichier [TSA]
#
Subprog CAL_SAFSTO(LISS,LNBR,LJOU,LDEL,LSAF,LRET)
Variable Decimal LISS()
Variable Integer LNBR
Variable Decimal LJOU
Variable Decimal LDEL
Variable Decimal LSAF
Variable Integer LRET
#
Local    Decimal WSRV
Local    Decimal WSIG
Local    Decimal WSAF
Local    Integer I
Raz LSAF, LRET
#Controle paramètres historique
If LNBR < [F:STE]SAFMINHIS | LNBR = 0
  LRET = 2
  End
Endif
If [F:STE]SAFMAXHIS = 0
  LRET = 3
  End
Endif
#Bornage historique maximum
If LNBR > [F:STE]SAFMAXHIS
  I = [F:STE]SAFMAXHIS
Else
  I = LNBR
Endif
WSRV = 0
Case [F:ITF]ABCCLS
  When 1 : WSRV = [F:STE]SRVRATA
  When 2 : WSRV = [F:STE]SRVRATB
  When 3 : WSRV = [F:STE]SRVRATC
Endcase
If WSRV = 0
  LRET = 4
  End
Endif
#Lecture taux de service
Read [TSA]TSA0=WSRV
  If fstat
    LRET = 5
    End
  Endif
#Calcul écart type conso journalière
WSIG = (sqr(var(LISS(1..I)))/sqr(LJOU))
WSAF = ([F:TSA]SRVRATCOE*WSIG*sqr(LDEL))
LSAF = arr(WSAF,10^-[F:TUN]UOMDEC)
If LSAF = 0
  LRET = 1
Endif
End
###########################################################
# Calcul seuil réappro
# Classes [ITF] [STE] [ITG] Chargées
# LISS = Table des consommations mensuelles (valeurs récentes entête)
# LNBR = Nombre d'élements de LISS (chargés à partir de 1)
# LJOU = nombre de jour moyen mensuel (en accord avec délai)
# LDEL = Délai réappro
# LSAF = Stock de sécurité de référence ( pour ajout)
# LRET = Code retour 0 = OK
#                    1 = résultat calcul nul
#                    2 = Historique minimum insuffisant
#                    3 = Historique maximum non défini
Subprog CAL_REOTSD(LISS,LNBR,LJOU,LDEL,LSAF,LTSD,LRET)
Variable Decimal LISS()
Variable Integer LNBR
Variable Decimal LJOU
Variable Decimal LDEL
Variable Decimal LSAF
Variable Decimal LTSD
Variable Integer LRET
#
Local    Decimal WTSD
Local    Integer I
#
Raz LTSD, LRET
# Controle historique minimum
If LNBR < [F:STE]TSDMINHIS | LNBR = 0
  LRET = 2
  End
Endif
If [F:STE]TSDMAXHIS = 0
  LRET = 3
  End
Endif
#Bornage historique maximum
If LNBR > [F:STE]TSDMAXHIS
  I = [F:STE]TSDMAXHIS
Else
  I = LNBR
Endif
#
WTSD = ((avg(LISS(1..I))/LJOU)*LDEL)
If [F:STE]SAFSTOFLG = 2
  WTSD += LSAF
Endif
LTSD = arr(WTSD,10^-[F:TUN]UOMDEC)
If LTSD = 0
  LRET = 1
Endif
End
###########################################################
# Calcul lot économique
# Classes [ITF] [STE] [ITG] Chargées
# LISS = Table des consommations mensuelles (valeurs récentes entête)
# LNBR = Nombre d'élements de LISS (chargés à partir de 1)
# LJOU = nombre de jour moyen mensuel (en accord avec délai)
# LDEL = Délai
# LMIN = Stock maximum calculé
# LRET = Code retour 0 = OK
#                    1 = Résultat nul
#                    2 = Historique minimum insuffisant
#                    3 = Historique maximum non défini
Subprog CAL_REOMIN(LISS,LNBR,LMIN,LRET)
Variable Decimal LISS()
Variable Integer LNBR
Variable Decimal LMIN
Variable Integer LRET
#
Local    Decimal WMIN
Local    Decimal WCST
Local    Decimal WRK1, WRK2
Local    Integer I
#
Raz LMIN, LRET
# Controle paramètres historique
If LNBR < [F:STE]EOQMINHIS | LNBR = 0
  LRET = 2
  End
Endif
If [F:STE]EOQMAXHIS = 0
  LRET = 3
  End
Endif
#Bornage historique maximum
If LNBR > [F:STE]EOQMAXHIS
  I = [F:STE]EOQMAXHIS
Else
  I = LNBR
Endif
If [F:STE]ORDCST = 0
  LRET =6
  End
Endif
If [F:STE]STOCSTRAT = 0
  LRET = 7
  End
Endif
#Lecture cout standard ou dernier prix
Filter [ITC] Where STOFCY=[F:ITF]STOFCY
&                & ITMREF=[F:ITF]ITMREF
&                & CSTTYP=1
&                & ITCSTRDAT<=date$
&                & ITCENDDAT>=date$
&                & UID=0
Read [ITC]ITC0 First
If fstat = 0
    WCST = [F:ITC]VLTTOT
Else
    Read [ITV]ITV0=[F:ITF]ITMREF;[F:ITF]STOFCY
    If fstat = 0
       WCST = [F:ITV]LASRCPPRI
    Endif
Endif
If WCST = 0
  LRET = 8
  End
Endif
#
# Issue 81843 WRK1 = (avg(LISS(1..LNBR))*24)*[F:STE]ORDCST
WRK1 = (avg(LISS(1..I))*24)*[F:STE]ORDCST
WRK2 = (([F:STE]STOCSTRAT/100)*WCST)
#If WRK2 > 0 : WMIN = sqr(WRK1/WRK2) : Else : WMIN = 0 : Endif            # 06.05 30579
If WRK2>0 & WRK1>0 : WMIN = sqr(WRK1/WRK2) : Else : WMIN = 0 : Endif      # GH 20/07/2015 bug 107037
LMIN = arr(WMIN,10^-[F:TUN]UOMDEC)
If LMIN = 0
  LRET = 1
Endif
End
###########################################################
# Calcul stock maximum
# Classes [ITF] [STE] [ITG] Chargées
# LISS = Table des consommations mensuelles (valeurs récentes entête)
# LNBR = Nombre d'élements de LISS (chargés à partir de 1)
# LJOU = nombre de jour moyen mensuel (en accord avec délai)
# LDEL = Délai
# LMAX = Stock maximum calculé
# LRET = Code retour 0 = OK
#                    1 = Résultat nul
#                    2 = Historique minimum insuffisant
#                    3 = Historique maximum non défini
#
Subprog CAL_STOMAX(LISS,LNBR,LJOU,LDEL,LMAX,LRET)
Variable Decimal LISS()
Variable Integer LNBR
Variable Decimal LJOU
Variable Decimal LDEL
Variable Decimal LMAX
Variable Integer LRET
#
Local    Decimal WMAX
Local    Integer I
#
Raz LMAX, LRET
# Controle paramètres
If LNBR < [F:STE]MAXMINHIS | LNBR = 0
  LRET = 2
  End
Endif
If [F:STE]MAXMAXHIS = 0
  LRET = 3
  End
Endif
#Bornage historique maximum
If LNBR > [F:STE]MAXMAXHIS
  I = [F:STE]MAXMAXHIS
Else
  I = LNBR
Endif
#
WMAX = ((avg(LISS(1..I))/LJOU)*LDEL)
LMAX = arr(WMAX,10^-[F:TUN]UOMDEC)
If LMAX = 0
  LRET = 1
Endif
End
###########################################################
$OPEN_FILE
If clalev([F:ATZ]) = 0 : Local File ATABZON    [ATZ] : Endif
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:TUN]) = 0 : Local File TABUNIT    [TUN] : Endif
If clalev([F:TCU]) = 0 : Local File TABCUR     [TCU] : Endif
If clalev([F:ITG]) = 0 : Local File ITMCATEG   [ITG] : Endif
If clalev([F:TSA]) = 0 : Local File TABSAFSTO  [TSA] : Endif
If clalev([F:STE]) = 0 : Local File STOPAR     [STE] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITV]) = 0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITP]) = 0 : Local File ITMBPS     [ITP] : Endif   # llc 03.01 7449
If clalev([F:BPR]) = 0 : Local File BPARTNER   [BPR] : Endif   # FQ 69925 GA 01/2011 ajout suite FQ 69315
If clalev([F:ITC]) = 0 : Local File ITMCOST    [ITC] : Endif
If clalev([F:ITH]) = 0 : Local File ITMMVTHIS  [ITH] : Endif
If clalev([F:ORD]) = 0 : Local File ORDERS     [ORD] : Endif
If clalev([F:ORD1])= 0 : Local File ORDERS     [ORD1]: Endif
If clalev([F:ORDR])= 0 : Local File ORDERS     [ORDR]: Endif    # FQ 45011 Ressource
If clalev([F:ORDB])= 0 : Local File ORDERS     [ORDB]: Endif    # FQ 45011 Besoin
Local Mask ORDK [ORDK]
Return
############################################################
Subprog ECR_TRACE(LMSG,LERR)
Value Char    LMSG
Value Integer LERR
Call ECR_TRACE(LMSG,LERR) From GESECRAN
End
############################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1)
End

# redéfinition du sous-pro de CONTX3 pour continuer à décaler
# si date indisponible
# 11.04 26623
Subprog CTL_JOU2(DATCTL,DATMIN,UVYDAY,UVYCOD,SENS)
Variable Date    DATCTL
Value    Date    DATMIN
Value    Libelle UVYDAY(0..)
Value    Char    UVYCOD
Value    Integer SENS
#----- Variables locales -----#
Local Integer JCOUR, I
#-----
If mkstat=2 End : Endif
mkstat=0
#-----
$CTL_JOU2_TR0
JCOUR=dayn(DATCTL) : I=0
#----- Contrôle si jour de la semaine est ouvert -----#
$CTL_JOU2_TR1
If UVYDAY(JCOUR-1)<>1 Goto CTL_JOU2_TR2 : Endif
I+=1
If I>7 Goto CTL_JOU2_TR2 : Endif
If SENS=0  JCOUR+=1   Else  JCOUR-=1 : Endif
If JCOUR=8 JCOUR=1  : Endif
If JCOUR=0 JCOUR=7  : Endif
Goto CTL_JOU2_TR1
#----- Réajustement de la date -----#
$CTL_JOU2_TR2
If I<>0
  If SENS=0 DATCTL+=I Else DATCTL-=I : Endif
Endif
#----- Contrôle date minimum -----#
If DATCTL<DATMIN & DATMIN<>[0/0/0]
  SENS=0 : DATCTL=DATMIN : Goto CTL_JOU2_TR0
Endif
#----- Contrôle par rapport aux périodes d'indisponibilité -----#
Call CTL_PER(DATCTL,UVYCOD) From CONTX3
If mkstat
    mkstat = 0
    DATCTL += 1
    Goto CTL_JOU2_TR0
Endif
End

# ----------------------------------------------------------- #
# FQ 70831 GA 01/2011
# Ajustement de la qté au lot technique (idem Calcul CBN/PDP)
# ----------------------------------------------------------- #
$CTL_LOT
# WLOT contient [F:ITF]REOMINQTY ou WWMIN calculé
If WQTY < WLOT : WQTY = WLOT : Endif                # 03.03 17551

GPOINT = "CALMFGLOT"
GPE    = 0
Gosub ENTREE From EXEFNC
If GPE = 0
    # Si Mode de réappro=Fabrication/Sous-traitance ET lot technique
    # alors on tient compte du lot technique
    If find([F:ITF]REOCOD,3,5) & [F:ITF]MFGLOTQTY <> 0 & mod(WQTY,[F:ITF]MFGLOTQTY) <> 0
        S = int(WQTY/[F:ITF]MFGLOTQTY) + 1
        WQTY = S * [F:ITF]MFGLOTQTY
    Endif
Endif

Return

# ----------------------------------------------------------- #
# 01/2008 FQ 45011                                            #
# la fonction STOPRETOT est insuffisante et devenue obsolète  #
# elle tient compte des contremarques/OF dans [F:ITV]ORDSTO   #
# mais pas des cdes de vente de contremarques/OF              #
# car celles-ci ne sont allouées qu'après fabrication         #
# ----------------------------------------------------------- #
$CAL_STODIS
Local Integer WTYPLOC : WTYPLOC = 5
Local Integer WSTA    : WSTA = 3

# point d'entrée STODISPAR (28778)
GPOINT = "STODISPAR" : Gosub ENTREE From EXEFNC

Call STOPRETOT("",WTYPLOC,WSTA,"",WDIS) From STKLIB

WDIS -= [F:ITV]GLOSHT + [F:ITV]DETSHT

# point d'entrée STODIS
GPOINT = "STODIS" : Gosub ENTREE From EXEFNC

If [M:DIA]WAISTOFLG = 1 : # ne pas tenir compte des sorties en attente
  WDIS += [F:ITV]WAISTO
Endif

# 01/2008 FQ 45011
If [F:ITV]ORDSTO > 0
   Gosub LECTURE_POF_WOF_EOF
Endif

Return

$LECTURE_POF_WOF_EOF : # 01/2008 FQ 45011
# recherche des ressources sur contremarque (POF & WOF)
# déjà inclues dans [F:ITV]ORDSTO
  For [ORDR]ORD1 Hint Key ORD1
&              Where STOFCY  = [F:ITV]STOFCY &
&                    ITMREF  = [F:ITV]ITMREF &
&                    FMI     > 1             &
&                    WIPSTA  = 1             &
&                    find(WIPTYP,5,2,13)<>0
  # recherche de la cde vente contremarques/OF à l'origine
    Gosub LECTURE_SOF
  Next
Return

$LECTURE_SOF : # 01/2008 FQ 45011
If [F:ORDR]VCRTYPORI=2 & [F:ORDR]VCRNUMORI<>""
# FQ 71085 GA 01/2011 ajout VCRLIN sinon pb si plusieurs lignes même article dans la SOF
  For [ORDB]ORD1 Hint Key ORD1
&              Where STOFCY  = [F:ITV]STOFCY     &
&                    ITMREF  = [F:ITV]ITMREF     &
&                    VCRTYP  = [F:ORDR]VCRTYPORI &
&                    VCRNUM  = [F:ORDR]VCRNUMORI &
&                    VCRLIN  = [F:ORDR]VCRLINORI &
&                    FMI     > 1                 &
&                    WIPSTA  = 1                 &
&                    WIPTYP  = 1
   # qté de la cde vente contremarque à l'origine de la ressource [F:ORDR]
     WDIS -= [F:ORDB]RMNEXTQTY
  Next
Endif
Return

############################################################
# FQ 65353 GA 06/2010              Appelé par AM_REOMGTCOD
# Purge anciennnes suggestions générées par un calcul X3
# ORI: 3=réappro hors MRP, 5=CBN, 6=PDP
$PUR_ORD
Local Integer WSLE,WESS
WSLE = 1
WESS = 0
$PUR_ORD1
For [ORD]ORD4 Hint Key ORD4
&             Where ITMREF  = [F:ITF]ITMREF &
&                   STOFCY  = [F:ITF]STOFCY &
&                   find(WIPTYP,2,5,7,9)<>0 &
&                   WIPSTA  = 3             &
&                   FMI     < 2             &
&                   find(ORI,3,5,6)<>0
    Readlock [ORD] Curr
    Case fstat
      When 0 :
        Call DELSUG From CBNLIB
        If GOK <> 1
          Break
        Endif
      When 1 :
        GOK = -1
        Break
      When Default :
        GOK = 0
        Call FSTA("ORD") From GLOCK
        Break
    Endcase
Next
If GOK = -1
    Sleep WSLE
    If WESS = 10
        Call ECR_TRACE(mess(20,100,1)-"ORDERS"-[F:ITF]ITMREF-[F:ITF]STOFCY,1) From GESECRAN
    Else
        GOK   = 1
        WESS += 1
        WSLE += 1
        Goto PUR_ORD1
    Endif
Endif
Return

##########################################################################
# pour les batchs                                                        #
##########################################################################
# 12.06
Subprog PARAM(DOSSIER,USER,P1,P2,OK)
#-----------------------------#
# obligatoire pour les batchs #
#-----------------------------#
Value    Char    DOSSIER   : # dossier de lancement
Value    Char    USER      : # utilisateur
Variable Char    P1()(1..) : # on peut avoir 2 fois 50 chaînes de 15 caractères
Variable Char    P2()(1..)
Variable Integer OK


Gosub INIT_REAHCB

Local Char    WIN (GLONFEN)
WIN="ISTKB"
Call PARAM (DOSSIER,USER,P1,P2,OK,TIT,WIN) From CPTTRT

End

