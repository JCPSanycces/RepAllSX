#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
#  SIXFCY : pour traitements de bascule Integrale --> X3                #
#########################################################################
#                                                                       #
# Subprog SIXFCY                                                        #
#     Création des Sites (avec MAJ Adresse)                             #
#     Création des Regroupement des sites                               #
#                                                                       #
#     Init des tables Sociétés/Sites                                    #
#     MAJ de Habilitations fonctionnelles                               #
#                                                                       #
# --------------------------------------------------------------------- #
# PRE-REQUIS :                                                          #
# --------------------------------------------------------------------- #
#     1 - Migrations précédentes : Société                              #
#                                                                       #
# --------------------------------------------------------------------- #
# Remarques :                                                           #
# --------------------------------------------------------------------- #
#                                                                       #
#                                                                       #
#                                                                       #
#########################################################################

# Supp...
If !clalev([F:BPA])  : Local File BPADDRESS  [BPA] : Endif   # Adresses
If !clalev([F:FGR])  : Local File FACGROUP   [FGR] : Endif   # Regroupement
If !clalev([F:FCY])  : Local File FACILITY   [FCY] : Endif   # Site
If !clalev([F:STE])  : Local File STOPAR     [STE] : Endif   # Parametres stocks

If !clalev([F:XDPO]) : Local File XIDPO      [XDPO]: Endif   # Sites Intégrale

Trbegin [BPA], [FCY], [FGR], [XDPO]
Delete [FCY] Where 1=1
Delete [FGR] Where 1=1
Delete [BPA] Where BPATYP=3
Update [XDPO] Where 1=1 With FLGREP=1
Commit 
# Fin Supp

Gosub SI_CONTEXT From SIXFONCTION

Global Integer X_NB
Call OUVRE_BOITE("XIDPO",nbrecord([XDPO])) From GESECRAN
Raz X_NB
Call EXEC
Call FERME_BOITE From GESECRAN
Kill X_NB

End
#########################################################################
Subprog EXEC

Local Integer WOUV_TRACE
If GTRACE = ""
 Call OUVRE_TRACE("SIXFCY : Process translation file from INTEGRALE to X3") From LECFIC
 WOUV_TRACE=1
Endif

Onerrgo TRT_ERR

If !clalev([F:FCY])  : Local File =SI_DOSSIER+".FACILITY"   [FCY]  : Endif   # Sites   X3

#---- Migration des sites : FACILITY & FACGROUP  ------#
Call ECR_TIME("SIXFCY : "+SI_MES(49)+" FACILITY & FACGROUP") From DOSSUB
Call SI_FACILITY
If GOK<>1 : Goto FIN_FCY : Endif

#----  Initialisation INISOC ------#
Call INISOC From GLOBSUP
If GOK<>1 : Goto FIN_FCY : Endif

#----   Mise à jour des habilitations fonctionnelles ------#
Call TEMPON(SI_MES(168)) From GESECRAN
For [FCY]
 Call CREATIONSITE([F:FCY]FCY,[F:FCY]LEGCPY) From SUBAFP1
Next
Call TEMPOFF From GESECRAN

$FIN_FCY
Onerrgo 
If WOUV_TRACE=1
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

$TRT_ERR
Call ECR_TRACE(errp-"("-num$(errl)-") :"-errmes$(errn)-errm, 1) From GESECRAN
Resume

#########################################################################
# Création des sites
#########################################################################
Subprog SI_FACILITY

Local Integer STOP, NB
Local Char LREPRISE(50)

If !clalev([F:XDPO]) : Local File =SI_DOSSIER+".XIDPO"      [XDPO] : Endif   # Sites

If !clalev([F:CPY])  : Local File =SI_DOSSIER+".COMPANY"    [CPY]  : Endif   # Société X3
If !clalev([F:FCY])  : Local File =SI_DOSSIER+".FACILITY"   [FCY]  : Endif   # Sites   X3
If !clalev([F:AGC])  : Local File =SI_DOSSIER+".AGRPCPY"    [AGC]  : Endif   # Groupe société 
If !clalev([F:FGR])  : Local File =SI_DOSSIER+".FACGROUP"   [FGR]  : Endif   # Regroupement
If !clalev([F:BPA])  : Local File =SI_DOSSIER+".BPADDRESS"  [BPA]  : Endif   # Adresses
If !clalev([F:STE])  : Local File =SI_DOSSIER+".STOPAR"     [STE]  : Endif   # Paramètrage stock
If !clalev([F:CAC])  : Local File =SI_DOSSIER+".GACCCODE"   [CAC] : Endif    # Codes comptables

If !clalev([F:SPX])  : Local File =SI_DOSSIER+".SIPARX3"    [SPX]  : Endif   # Paramétrage Migration Intégrale 

# Site financier & Société juridique
#-------------------------------------------------
# Données initialiées par la fonction de paramétrage Migration Intégrale (GESSIP).
# Un site financier par société
Local Char MAIFCY(GLONFCY) : Raz MAIFCY : # Site Financier
Local Char MAICPY(GLONCPY) : Raz MAICPY : # Société juridique
Read [SPX]  First
[L]MAIFCY = [F:SPX]FCY
[L]MAICPY = [F:SPX]CPY

If !clalev([F:XSOC]) : Local File XISOC       [XSOC] : Endif   # Société Intégrale
Read [XSOC] First
[L]MAICPY = [F:XSOC]X3CLE

#-------------------------------------------------

SI_SUBPRG = "SIXFCY"
SI_TABLE  = "XIDPO"
Gosub SI_CRITSUP From SIXFONCTION

$LOOP_FCY
Raz NB

If STOP=1
 CRITERE = "CODDPO>'"+LREPRISE+"'"
 STOP=0
Else
 CRITERE="1=1"
Endif

Call DEBTRANS From GLOCK
Trbegin [FCY], [BPA], [FGR], [XDPO]

# Traitement des comptes généraux
For [XDPO] Where left$(CODDPO,2)<>"$$" & FLGREP<>2
&             & evalue(CRITERE)
&             & evalue(SI_CRITERE)
 
 GOK = 1

 Call AFFBOITE([F:XDPO]CODDPO) From SUBSIM

 # creation Site (FACILITY)
 Gosub CRE_FCY
 If GOK<=0 : Break : Endif

 # creation Parametres stocks (STOPAR)
 Gosub CRE_STE
 If GOK<=0 : Break : Endif

 # creation adresse (BPADDRESS)
 Gosub CRE_BPA 
 If GOK<=0 : Break : Endif

 # creation Regroupement Site (FACGROUP)
 Gosub CRE_FGR
 If GOK<=0 : Break : Endif

 Readlock [XDPO] Curr
 [F:XDPO]FLGREP = 2
 Rewrite [XDPO]

 # NB alimenté dans CRE_FCY
 If NB>1000
  LREPRISE = [F:XDPO]CODDPO
  STOP     = 1
  Break
 Endif
Next

If GOK>0
 If SI_SIMU<>2
  Commit
 Else
  Rollback
 Endif
 If STOP
  Goto LOOP_FCY
 Endif
Else
 Rollback
Endif
End

##################################################################
$CRE_FCY
Raz [F:FCY]

# recuperation et controle code compte
If !func SIXFONCTION.SI_CTL("FCY",[F:XDPO]X3CLE,"XIDPO ("+[F:XDPO]CODDPO+")")
 GOK=0 : Return
Else
 [F:FCY]FCY    = [F:XDPO]X3CLE
Endif

[F:FCY]FCYNAM  = [F:XDPO]NOMDPO
[F:FCY]BPAADD  = "001"

# Site financier
#-------------------------------------------------
If [F:FCY]FCY=[L]MAIFCY or [L]MAIFCY=""
 [L]MAIFCY         = [F:FCY]FCY
 [F:FCY]FINFLG     = 2
 [F:FCY]FINRSPFCY  = [F:FCY]FCY 
 #-- Si Site financier alors DAS2 à renseigner
 [F:FCY]DADFLG    = 2
 [F:FCY]DADFCY    = [F:FCY]FCY 
 [F:FCY]MFGFLG    = 2  # Site Production
 [F:FCY]SALFLG    = 2  # Site Vente
 [F:FCY]PURFLG    = 2  # Site Achat
Else
 [F:FCY]FINFLG     = 1
 [F:FCY]FINRSPFCY  = [L]MAIFCY 
Endif

[F:FCY]WRHFLG     = 2  # Site Dépot

# Données initialiées par défaut
#-------------------------------------------------
[F:FCY]LEG       = GDOSLEG
[F:FCY]LEGCPY    = [L]MAICPY
[F:FCY]CRY       = GPAYS
Call INITACCCOD([F:FCY]ACCCOD,[F:FCY]LEGCPY,[V]GCACFCY) From SITSIG

# Donnée immo
#-------------------------------------------------
[F:FCY]IVYFLG = 2 
[F:FCY]IVYFCY = [F:FCY]FCY

For I=0 To 4
 [F:FCY]UVYDAY(I) = 2
Next

# création des axes
Local Integer NBRAXE, AXE
Call NBAXE(NBRAXE) From SIXCCE
For AXE=0 To dim([F:FCY]DIE)-1
  [F:FCY]DIE(AXE) = ""
  [F:FCY]CCE(AXE) = ""
Next
For AXE=1 To NBRAXE
 If AXE<dim([F:FCY]DIE)
  [F:CPY]DIE(AXE) = "AX"+num$(AXE)
  [F:CPY]CCE(AXE) = ""
 Endif
Next


# Dates et utilisateurs
#-------------------------------------------------
[F:FCY]CREDAT   = date$
[F:FCY]CREUSR   = GUSER              
[F:FCY]UPDDAT   = date$   
[F:FCY]UPDUSR   = GUSER   

SI_TABLE = "FACILITY"
Gosub SI_BEFWRI From SIXFONCTION

Write [FCY]
If fstat
 # Site ... : ... (...) Erreur d'écriture 
 Call ECR_TRACE(mess(3,45,1)-[F:FCY]FCY-"("+[F:XDPO]CODDPO+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0
Else
 NB+=1
Endif

Return


##################################################################
#  Creation STOPAR
##################################################################
$CRE_STE
Raz [F:STE]

[F:STE]STOFCY      = [F:FCY]FCY
[F:STE]TCLCOD      = "" 

# Données initialiées par parametrage
[F:STE]DAYGAPCLSA  = [F:SPX]DAYGAPCLSA
[F:STE]DAYGAPCLSB  = [F:SPX]DAYGAPCLSB
[F:STE]DAYGAPCLSC  = [F:SPX]DAYGAPCLSC
[F:STE]DAYGAPCLSD  = [F:SPX]DAYGAPCLSD

# Données initialiées par défaut
[F:STE]SHTPAR1     = 2
[F:STE]SHTPAR2     = 3
[F:STE]SHTPAR3     = 4
[F:STE]SHTCAT1     = 2
[F:STE]SHTCAT2     = 3
[F:STE]SHTCAT3     = 4
[F:STE]SHTAUTFLG   = 2
[F:STE]STACARFLG   = 2
[F:STE]LOCCARFLG   = 2

# Dates et utilisateurs
#-------------------------------------------------
[F:STE]CREDAT      = date$
[F:STE]CREUSR      = GUSER              
[F:STE]UPDDAT      = date$   
[F:STE]UPDUSR      = GUSER   

SI_TABLE = "STOPAR"
Gosub SI_BEFWRI From SIXFONCTION

Write [STE]
If fstat
 # Site ... : ... (...) Erreur d'écriture 
 Call ECR_TRACE("STOPAR"-[F:STE]STOFCY-"("+[F:XDPO]CODDPO+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0
Else
 NB+=1
Endif

Return



##################################################################
#  Creation BPADDRESS
##################################################################
$CRE_BPA
Local Integer LEXI : Raz LEXI
Local Char LBPAADD(3)
If dim([F:FCY]BPAADD) > 0   & [F:FCY]BPAADD<>""
   LBPAADD    = [F:FCY]BPAADD          # Adresse par défaut
Else
   LBPAADD    = "001"                  # Adresse par défaut
Endif

Look [BPA]BPA0 = 3;[F:FCY]FCY;LBPAADD
If fstat <> 0
 Readlock [BPA]BPA0=3;[F:FCY]FCY;LBPAADD
 If fstat
  Raz [F:BPA]
  Raz LEXI
 Else
  LEXI = 1
 Endif
 
 # Rubriques reprises de l'Integrale
 [F:BPA]BPAADDLIG (0) =  [F:XDPO]ADR1      # Ligne adresse 1
 [F:BPA]BPAADDLIG (1) =  [F:XDPO]ADR2      # Ligne adresse 2
 [F:BPA]BPAADDLIG (2) =  [F:XDPO]ADR3      # Ligne adresse 3
 [F:BPA]POSCOD        =  [F:XDPO]CODPST    # Code postal     
 [F:BPA]CTY           =  [F:XDPO]VIL       # Ville           
 [F:BPA]CRY           =  GPAYS             # Pays          

 Call NUMONLY([F:XDPO]TEL,[F:BPA]TEL) From SIXFONCTION    # Téléphone
 Call NUMONLY([F:XDPO]TLC,[F:BPA]FAX) From SIXFONCTION    # Fax

 # Rubriques reprises du client X3
 [F:BPA]BPATYP    = 3                      # Type entité
 [F:BPA]BPANUM    = [F:FCY]FCY             # Entité
 [F:BPA]BPAADD    = LBPAADD                # Adresse 
 [F:BPA]CREDAT    = [F:FCY]CREDAT          # Date création
 [F:BPA]CREUSR    = [F:FCY]CREUSR          # Opérateur création
 [F:BPA]UPDDAT    = [F:FCY]UPDDAT          # Date modification
 [F:BPA]UPDUSR    = [F:FCY]UPDUSR          # Opérateur modification
 
 # Rubriques par defaut 
 [F:BPA]BPAADDFLG = 2                      # Par défaut
 [F:BPA]CRETIM    = time                   # Heure
 [F:BPA]UPDTIM    = time                   # Heure

 # Maj
 If LEXI
  [F:BPA]UPDDAT = date$ 
  [F:BPA]UPDUSR = GUSE  
  [F:BPA]UPDTIM = time                   # Heure
  Rewrite [BPA]
 Else
  SI_TABLE = "BPADDRESS"
  Gosub SI_BEFWRI From SIXFONCTION
  Write [BPA]
  If fstat
  # Adresse ... : ... (...) Erreur d'écriture 
   Call ECR_TRACE(mess(33,102,1)-[F:FCY]FCY-"("+[F:XDPO]CODDPO+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
   GOK = 0
  Endif
 Endif
Endif
Return


##################################################################
#  Creation FACGROUP
##################################################################
$CRE_FGR
Gosub CRE_FGR2
Return

Readlock [FGR]FGR0 = [F:FCY]LEGCPY;[F:FCY]FCY
If fstat=1
 # Regroupement  ... : ... (...) Erreur d'écriture 
 Call ECR_TRACE(mess(68,104,1)-[F:FCY]FCY-"("+[F:XDPO]CODDPO+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0
Elsif fstat
 Raz [F:FGR]
 [F:FGR]CPY    = [F:FCY]LEGCPY
 [F:FGR]FCY    = [F:FCY]FCY
 [F:FGR]GRPDES = [F:FCY]FCYNAM
 [F:FGR]GRPSHO = [F:FCY]FCYSHO
 [F:FGR]CREDAT = date$
 [F:FGR]CREUSR = GUSER
 Write [FGR]
Else
 [F:FGR]GRPDES = [F:FCY]FCYNAM
 [F:FGR]GRPSHO = [F:FCY]FCYSHO
 [F:FGR]UPDDAT    = date$
 [F:FGR]UPDUSR    = GUSER
 Rewrite [FGR]
Endif
If fstat
 # Regroupement  ... : ... (...) Erreur d'écriture 
 Call ECR_TRACE(mess(68,104,1)-[F:FCY]FCY-"("+[F:XDPO]CODDPO+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
 GOK = 0
Endif
Return

$CRE_FGR2
For [AGC]AGC0(1) Where CPY=[F:FCY]LEGCPY
 Readlock [FGR]FGR0 = [F:AGC]GRP;[F:FCY]FCY
 If fstat=1
 # Regroupement  ... : ... (...) Erreur d'écriture 
  Call ECR_TRACE(mess(68,104,1)-[F:FCY]FCY-"("+[F:XDPO]CODDPO+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
  GOK = 0
 Elsif fstat
  Raz [F:FGR]
  [F:FGR]CPY    = [F:AGC]GRP
  [F:FGR]FCY    = [F:FCY]FCY
  Write [FGR]
  If fstat
   # Regroupement  ... : ... (...) Erreur d'écriture 
   Call ECR_TRACE(mess(68,104,1)-[F:FCY]FCY-"("+[F:XDPO]CODDPO+")"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
   GOK = 0
  Endif
 Endif
Next
Return



