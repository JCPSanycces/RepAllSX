#<AdxTL>@(#)8.0.0.0 $Revision$
#**********************************************************************#
#    Modification                                                      #
# XXXXX XX.XX.XXXX xxxxxx_x : XXXXXXXXXXXXXXXXXXXXXXXXXXXX             #
# FPE   14.11.2017 X3-61594 : Journal traceability displays wrong      #
#                             company currency.                        #
########################################################################

Raz GBIDC1, GBIDC2
Call OBJET("REL",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "EXEBOUT"   : Gosub EXEBOUT
 When "SETBOUT"   : Gosub SETBOUT
 When "AVANTBOUT" : Gosub AVANTBOUT
 When "STATUT"    : Gosub STATUT
 When "RAZCRE"    : Gosub RAZCRE
 When "RAZDUP"    : Gosub RAZDUP
 When "ABANDON"   : Gosub ABANDON
 When "VERIF_CRE" : Gosub VERIF_CRE
 When "INICRE"    : Gosub INICRE
 When "CREATION"  : Gosub CREATION
 When "APRES_CRE" : Gosub APRES_CRE
 When "VERIF_MOD" : Gosub VERIF_MOD
 When "INIMOD"    : Gosub INIMOD
 When "MODIF"     : Gosub MODIF
 When "APRES_MOD" : Gosub APRES_MOD
 When "EXEACT"    : Gosub EXEACT
 When "LIENS"     : Gosub LIENS
 When "FIN"       : Gosub FIN
Endcase
Return

#######
$OUVRE
#######
If clalev([F:SOI2])=0 : Local File SOI        [SOI2] : Endif
If clalev([F:DUD2])=0 : Local File GACCDUDATE [DUD2] : Endif
If clalev([F:DUD3])=0 : Local File GACCDUDATE [DUD3] : Endif
If clalev([F:SIH])=0  : Local File SINVOICE   [SIH]  : Endif
If clalev([F:PIH])=0  : Local File PINVOICE   [PIH]  : Endif
If clalev([F:MTB])=0  : Local File MTCBATCH   [MTB]  : Endif
If clalev([F:TCA])=0  : Local File TABCOUAFF  [TCA]  : Endif
If clalev([F:TAM])=0  : Local File TABPAM     [TAM] : Endif

Local Integer OK2 , STAT
Local Char    REL(GLONVCR) , MESSAGE(50)
Local Decimal MNTREPORT
Local Char    CRITSAC2(255), CRITFCY2(255)
Local Char    SYMHAE(255)
Local Char    SAV_SOINUM(30)
Local Libelle BPR_TYP

# Pour proposer des relevés à reporter
Local Integer NB_REL_REP                        : # Nbre de relevés maximum à reporter
[L]NB_REL_REP = 10                              : # Penser au TRT RELAUTO !!
Local Char    REL_NUM(GLONVCR)([L]NB_REL_REP)   : # No relevé à reporter
Local Char    TYP_REL(GLONGTE)([L]NB_REL_REP)   : # Type de pièce du relevé à reporter
Local Char    NUM_REL(GLONVCR)([L]NB_REL_REP)   : # No   de pièce du relevé à reporter
Local Integer REL_FLG([L]NB_REL_REP)            : # Flag correspondance type de pièce/pièce avec Ech
Local Integer REPORT_REL                        : # Nbre de relevés reportés

## Habilitations Boutons
Local Integer ACCFCY, SAVCONS
Local Char    AUZFCY(15)
Local Integer MONOCPY # <JFL>
Return

$FIN
Return

########
$SETBOUT
########
If CLECUR
 Call VIREBOUT(CHAINE,"H") From GOBJET  :# Changement de clé interdit
Endif
If REP<>""
 Call VIREBOUT(CHAINE,"BOV") From GOBJET
Elsif !CLECUR or [M]FLGPST<>1
 Call VIREBOUT(CHAINE,"OV") From GOBJET
Elsif GDIV(0)="1" : # Pas de comptabilisation des relevés
 Call VIREBOUT(CHAINE,"V") From GOBJET
Endif
# Annulation et modification interdites quand
# -> relevé validé
# -> relevé reporté
If CLECUR & ([M]FLGPST=2 | [M]FWDSOI<>"")
 Call VIREBOUT(CHAINE,"AM") From GOBJET
Endif
# JML 25/04/00 Zooms
If [M:REL0]TYPSOI<>"" & [M:REL0]NUMSOI<>""
 CHMEN += "1" : # Zoom "Pièces compables"
Endif

# FGR 18/01/2012 : X3SUIVI71278 (début)
  If GREP = "" Then
    CHMEN += "N" : # Option "Traçabilité pièces"
  Endif
# FGR 18/01/2012 : X3SUIVI71278 (fin)

# Habilitation bouton
Call DROITSITE([M]FCY,[L]AUZFCY,[L]ACCFCY) From CPTSUB
If ![L]ACCFCY | !instr(1,[L]AUZFCY,"V")
    Call VIREBOUT(CHAINE,"V") From GOBJET
Endif
If ![L]ACCFCY | !instr(1,[L]AUZFCY,"J")
  Call VIREBOUT(CHAINE,"O") From GOBJET
Endif
# <JFL>
# suppression des boutons : supprimer, enregistrer, créer + interdiction de duplication
If MONOCPY : Call VIREBOUT(CHAINE,"AMCD") From GOBJET : Endif
# </JFL>
Raz GMESSAGE
Return

########
$EXEBOUT
########
Case REP
 When "B"  :# Génération relevé
  If [L]REL<>""
   CLECUR=1 : [F:SOI]SOINUM=[L]REL
   Gosub SET_CLE From GOBJSUB
   AFFICHE=1 : Gosub RELIT From GOBJSUB
  Endif
 When "V" :# Validation relevé
  If ![L]STAT
   AFFICHE=1 : Gosub RELIT From GOBJSUB
  Endif
 When "O" : # Mise à jour
  If GOK=1
   Gosub RELIT From GOBJSUB
  Endif
Endcase
Return

########
$EXEACT
########
Case BOUT
 When "B"
  If GOK=1 : CLECUR = 0 : Gosub RELIT From GOBJSUB : Endif
 When "S"
  If GOK=1
   CLECUR = 0
   CLECUR1 = "" : CLECUR2 = ""
   Gosub DEVERROU From GOBJET
   Gosub RELIT From GOBJSUB
   OK = 0
  Endif
Endcase
Return

############
$AVANTBOUT
############
Case BOUT
 When "1"            # avant tunnel vers les pièces comptables
  SAVCONS=GCONSULT
  GCONSULT=2
Endcase
Return

########
$STATUT
########
Case BOUT
 When "1"      # après tunnel vers les pièces comptables
  GCONSULT = SAVCONS
Endcase
Return

########
$RAZCRE
########
$RAZDUP
Effzo [REL0]SOINUM,FLGPST,SOICOD
Grizo SOINUM
# Issue X3-61594
Gosub SET_GFCY
# End issue X3-61594
Return

########
$ABANDON
########
If REP="C" or REP="D"
 Actzo SOINUM
Endif
Return

$VERIF_CRE
If [M:REL0]DUDNBR=0
 # Pas de ligne : validation impossible
 GERR = 1 : GMESSAGE = mess(105,117,1)
 [L]OK=0 : Return
Endif
Gosub FLGFWD  :# Pour relevés créditeurs
[M:REL0]FLGFWDSOI = 1
Gosub REPORT_REL
Return

$INICRE
## Recherche d'un n° de pièce
Local Integer STAT
Local Char    MESSA(80)
Local Char    COMPTREG(GLONANM)
Local Integer OKTCA

COMPTREG = ""
Call GETSOC([M]FCY) From DEVSUB
Call LECTCA(3,OKTCA) From SUBTCA
If OKTCA
 COMPTREG = [F:TCA]CODNUM(4)
Endif
If COMPTREG="" : COMPTREG = "REL" : Endif

If [M:REL0]FCY<>""
 Call NUMERO(COMPTREG,[M:REL0]FCY,[M:REL0]SOIDAT,"",[F:SOI]SOINUM,STAT) From SUBANM
Else
 Call NUMERO(COMPTREG,[M:REL0]CPY,[M:REL0]SOIDAT,"",[F:SOI]SOINUM,STAT) From SUBANM
Endif
If GOK<1 | STAT
 If STAT
  # Problème lors de la récupération du compteur
  Gosub MESSAGE From SUBANM
  GMESSAGE=mess(104,117,1)-"("+COMPTREG+") : "+MESSA
  GERR=1
 Endif
 GOK = 0 : Return
Endif
[M:REL0]SOINUM   = [F:SOI]SOINUM
[F:SOI]FLGPST    = 1  :# Non validé
Gosub CALTOT
Return

$CREATION
Gosub MAJECH
If GOK<1 : Return : Endif
Gosub MAJSOI
If GOK<1 : Return : Endif
Return

$APRES_CRE
# Relecture car si report et SOICPT=1 nouvelles échéances
AFFICHE =1 : Gosub RELIT From GOBJSUB
Gosub AFF_REPORT
Affzo [M:REL0]SOINUM,TEX1,TEX2
Actzo SOINUM
Return

$VERIF_MOD
If [M:REL0]DUDNBR=0
 # Pas de ligne : validation impossible
 GERR = 1 : GMESSAGE = mess(105,117,1)
 [L]OK=0 : Return
Endif
Gosub FLGFWD
If [L]OK=0 : Return : Endif
Gosub REPORT_REL
Return

$INIMOD
Gosub CALTOT
Return

$MODIF
# Echéances
Filter [F:DUD] Where SOINUM=[M:REL0]SOINUM
&              Order By Key CLE=SOINUM
For [F:DUD]CLE
 [L]OK2=0
 For I=0 To [M:REL0]DUDNBR-1
  If [F:DUD]ACCNUM=[M:REL0]ACCNUM(I) & [F:DUD]DUDLIG=[M:REL0]DUDLIG(I)
   [L]OK2=1 : Break
  Endif
 Next I
 If ![L]OK2  :# Echéance annulée
  ## Lock de la pièce
  SYMHAE = "HAE"+num$([F:DUD]NUM)+"\"+num$([F:DUD]TYP)
  Lock =SYMHAE
  If fstat : GOK=-1 : GLOCK="%"+SYMHAE : Break : Endif
  Gosub SUPP_ECHE
  If GOK<1 : Break : Endif
  # Echéance de relevé reporté?
  If GDIV(0)="2"  :# Comptabilisation des relevés
   Filter [SOI2] Where TYPSOI=[F:DUD]TYP & NUMSOI=[F:DUD]NUM
&                      & FWDSOI=[M:REL0]SOINUM
   Read [SOI2]SOI1 First
   If !fstat
    Readlock [SOI2] Curr
    If fstat=1
     GOK=-1 : GLOCK="$SOI"-[F:DUD]TYP-[F:DUD]NUM : Break
    Elsif fstat=0
     Raz [F:SOI2]FWDSOI
     Rewrite [F:SOI2]
     If fstat
      GOK=0 : Call FSTA("SOI2") From GLOCK : Break
     Endif
    Endif
   Endif
   Filter [F:SOI2]
  Endif
 Endif
Next
Filter [F:DUD]
If GOK<1 : Return : Endif
Gosub MAJECH
If GOK<1 : Return : Endif

# Relevés
Gosub MAJSOI
If GOK<1 : Return : Endif
If [M:REL0]FLGFWDSOI=1  :# Pas de report
 Gosub SUPP_SOI
 If GOK<1 : Return : Endif
Endif
Return

##########
$APRES_MOD
##########
# Relecture car si report et SOICPT=1 nouvelles échéances
AFFICHE =1 : Gosub RELIT From GOBJSUB
Gosub AFF_REPORT
Affzo [M:REL0]TEX1,TEX2
Return

# Issue X3-61594
$SET_GFCY
  If [M:REL0]FCY <> ""
    GFCY = [M:REL0]FCY
  Else
    GFCY = func GET_FCY_FROM_CPY([M:REL0]CPY)
  Endif
Return

#**
#* Get the site from the given company
#*  - The main site of the company, if set
#*  - If not, the first site linked to the company
#*
#* @param PCPY: company to get the site from
#* @return : the facility, or blank if company not found or other errors
#*!
Funprog GET_FCY_FROM_CPY(PCPY)
Variable Char PCPY

  Local Char RFCY(GLONFCY)
  Local File COMPANY[CPY]
  Read [CPY]CPY0 = PCPY
  If !fstat
    If [F:CPY]MAIFCY <> ""
      RFCY = [F:CPY]MAIFCY
    Else
      Local File FACILITY [FCY]
      Read [FCY]FCY1(1) = [F:CPY]CPY
      If !fstat
        RFCY = [F:FCY]FCY
      Endif
    Endif
  Endif
  Close Local File
End RFCY
# End issue X3-61594

########
$LIENS
########
Call SETMAINREF([M]CPY,GTYPGEN,GTYPANA) From CPTDIV
Call LECPLAN([M]CPY,GTYPGEN,[M]COA) From CPTDIV
Call LEC_CPY([M]CPY) From CPTLEC
GSOCIETE = [M]CPY
GCURLEG  = [F:CPY]LEG

If [M]SAC<>""
 Read [GAC]GAC1 = [M]COA;[M]SAC
 If !fstat
  [M:REL0]SACACC=[F:GAC]ACC
 Else
  Raz [M:REL0]SACACC
 Endif
Else
 Raz [M:REL0]SACACC
Endif

# Pour rester compatible avec version<120, ou si saisie manuelle
#               De quel type (Cli/Fou) est le relevé ?
If [M]BPRTYP=0
 Read [GAC]GAC1 = [M]COA;[M]SAC
 If fstat : Raz [F:GAC] : Endif
 BPR_TYP = [M]BPRTYP
 Call CLIFOU([M]BPR,[M]COA,[F:GAC]ACC,2,BPR_TYP) From PAYDIV
 [M]BPRTYP = BPR_TYP
Endif

nolign=1
For [F:DUD]DUD2 Where SOINUM=[M:REL0]SOINUM
 NOL=nolign-1
 Gosub CHARG_ECHE From SUBREL0
 nolign+=1
Next
Call PARAM([M:REL0]CPY,"SOICPT",GDIV(0)) From ADOVAL  :# Comptabilisation relevé
Call PARAM([M:REL0]CPY,"SOISAC",GDIV(1)) From ADOVAL  :# Relevé mono-colectif
Call PARAM([M:REL0]CPY,"SOIFCY",GDIV(2)) From ADOVAL  :# Relevé mono-site
Call PARAM([M:REL0]CPY,"SOIBPR",GDIV(3)) From ADOVAL  :# Tiers du relevé
Gosub AFF_REPORT

# Issue X3-61594
  Gosub SET_GFCY
# End issue X3-61594

Return

############################################################################
## Affectation n° de relevé aux échéances
$MAJECH
For I=0 To [M:REL0]DUDNBR-1
 Readlock [F:DUD]DUD1=[M:REL0]ACCNUM(I);[M:REL0]DUDLIG(I)
 If fstat=1
  GOK=-1 : GLOCK="$GACCDUDATE"-num$([M:REL0]ACCNUM(I))-num$([M:REL0]DUDLIG(I))
  Break
 Elsif fstat
  GOK=0 : Call RSTA("DUD",num$([M:REL0]ACCNUM(I))-num$([M:REL0]DUDLIG(I))) From GLOCK
  Break
 Endif
 ## Lock de la pièce
 SYMHAE = "HAE"+num$([F:DUD]NUM)+"\"+num$([F:DUD]TYP)
 Lock =SYMHAE
 If fstat : GOK=-1 : GLOCK="%"+SYMHAE : Break
 Elsif [F:DUD]PAM<>[M:REL0]LIGPAM(I)
  # Mode de règlement modifié en ligne
  GERR = 1 : GMESSAGE = mess(65,117,1)-num$(I+1)
  GOK=0 : Break
 Elsif [F:DUD]SOI<>2
  # Pas de relevé à faire en ligne
  GERR = 1 : GMESSAGE = mess(106,117,1)-num$(I+1)
  GOK=0 : Break
 Elsif [F:DUD]SOINUM<>"" & [F:DUD]SOINUM<>[M:REL0]SOINUM
  # Ligne n° xx Relevé xx
  GERR = 1 : GMESSAGE = mess(061,100,1)-num$(I+1)+" :"-mess(42,117,1)-num$([F:DUD]SOINUM)
  GOK=0 : Break
 Elsif (GDIV(3)="1" & [F:DUD]BPRPAY<>[M:REL0]BPR)
&      | (GDIV(3)="2" & [F:DUD]BPR<>[M:REL0]BPR)
  # Tiers modifié en ligne
  GERR = 1 : GMESSAGE = mess(108,117,1)-num$(I+1)
  GOK=0 : Break
 Endif
 [F:DUD]SOINUM=[M:REL0]SOINUM
 Rewrite [F:DUD]
 If fstat
  GOK=0 : Call FSTA("DUD") From GLOCK : Break
 Endif
 Call HISTOECH("DUD",1,[M:REL0]SOIDAT)From MODECHE
Next I
Return

$CALTOT
[F:SOI]AMTCUR=sigma(I=0,[M:REL0]DUDNBR-1,[M:REL0]LIGAMT(I))
Return

# Relevé créditeur
$FLGFWD
[L]OK2 = 1
If [M:REL0]RMT<0 & [M:REL0]BPRTYP=1    :# Relevé créditeur : à reporter? (Client)
 [L]OK2=2 : Call OUINON(mess(109,117,1),[L]OK2) From GESECRAN
Elsif [M:REL0]RMT>0 & [M:REL0]BPRTYP=2 :# Relevé débiteur : à reporter? (Fournisseur)
 [L]OK2=2 : Call OUINON(mess(22,121,1),[L]OK2) From GESECRAN
Elsif [M:REL0]FLGFWD=2                 :# Relevé à reporter?
 [L]OK2=2 : Call OUINON(mess(110,117,1),[L]OK2) From GESECRAN
Endif
If [L]OK2=2
 [M:REL0]FLGFWD = 2  :# Relevé à reporter
Else
 [M:REL0]FLGFWD = 1
Endif

# Le relevé est à reporter, et d'autres relevés sont reportés dessus
# -> annulation de ces reports
If GDIV(0)="1" & [M:REL0]FLGFWD=2 & [M:REL0]FLGFWDSOI=2
 # Relevé à reporter \ Le report des relevés va être annulé
 Call AVERTIR(mess(110,117,1)+"\"+mess(15,121,1),[L]OK2) From GESECRAN
 If [L]OK2=1 : [L]OK=0 : Return : Endif
 [M:REL0]FLGFWDSOI=1
Endif
Return

######################################################################################
# Report de relevé
######################################################################################
$REPORT_REL
## Relevé à reporter?  PHASE I, on regarde jusqu'a 10 (NB_REL_REP) relevés par Tiers à reporter

[L]OK2=0 : [L]MESSAGE=mess(111,117,1) : # Report des relevés

[L]REPORT_REL = 0
[L]CRITSAC2   = "1=1"
[L]CRITFCY2   = "1=1"
If GDIV(1)="1" : # SOISAC, Mono-collectif
 [L]CRITSAC2 = "SAC=[M:REL0]SAC"
Endif
If GDIV(2)="1" : # SOIFCY, Mono-site
 [L]CRITFCY2 = "FCY=[M:REL0]FCY"
Endif

If GDIV(0)="1"  :# Pas de comptabilisation
 Filter [F:SOI2] Where FLGFWD=2 & (FWDSOI="" | FWDSOI=[M:REL0]SOINUM)
&                    & SOINUM<>[M:REL0]SOINUM & CUR=[M:REL0]CUR
&                    & BPR=[M:REL0]BPR & CPY=[M:REL0]CPY
&                    & evalue([L]CRITSAC2) & evalue([L]CRITFCY2)
Else            :# Comptabilisation
 Filter [F:SOI2] Where FLGFWD=2 & (FWDSOI="" | FWDSOI=[M:REL0]SOINUM) & FLGPST=2
&                    & SOINUM<>[M:REL0]SOINUM & CUR=[M:REL0]CUR
&                    & BPR=[M:REL0]BPR & CPY=[M:REL0]CPY
&                    & evalue([L]CRITSAC2) & evalue([L]CRITFCY2)
Endif

Raz [L]REL_NUM , [L]TYP_REL , [L]NUM_REL , [L]REL_FLG
For [F:SOI2]SOI3
 If GDIV(0)="2"  :# Comptabilisation
  If !find([F:SOI2]SOINUM,[M:REL0]SOIDUD(0..[M:REL0]DUDNBR-1))
   [L]REL_NUM([L]REPORT_REL) = [F:SOI2]SOINUM
   [L]TYP_REL([L]REPORT_REL) = [F:SOI2]TYPSOI
   [L]NUM_REL([L]REPORT_REL) = [F:SOI2]NUMSOI
   [L]REPORT_REL+=1 : If [L]REPORT_REL=[L]NB_REL_REP : Break : Endif
  Endif
 Endif
 [L]OK2=1 : [L]MESSAGE-=[F:SOI2]SOINUM
Next
Filter [F:SOI2]
If [L]OK2
 [L]OK2=2 : Call OUINON([L]MESSAGE,[L]OK2) From GESECRAN
 If [L]OK2=2
  [M:REL0]FLGFWDSOI = 2
 Else
  [M:REL0]FLGFWDSOI = 1
 Endif
Endif
Return

######################################################################################
# Affichage informations report
$AFF_REPORT
Raz [M:REL0]TEX1 : Raz [M:REL0]TEX2
If [M:REL0]FLGFWD=2
 If [M:REL0]FWDSOI<>""  :# Report sur relevé
  [M:REL0]TEX1=mess(112,117,1)-[M:REL0]FWDSOI
 Else                   :# Relevé à reporter
  [M:REL0]TEX1=mess(110,117,1)
 Endif
Endif
If [M:REL0]FLGFWDSOI=2
 # Report des relevés
 [M:REL0]TEX2=mess(111,117,1)
 Filter [F:SOI2] Where FWDSOI=[M:REL0]SOINUM
 Raz [L]MNTREPORT
 For [F:SOI2]SOI1
  [M:REL0]TEX2-=[F:SOI2]SOINUM
  [L]MNTREPORT += [F:SOI2]AMTCUR
 Next
 Filter [F:SOI2]
 [M:REL0]TEX2 -= "("+num$([L]MNTREPORT)-[M]CUR+")"
Endif
Return

$MAJSOI
If [M:REL0]FLGFWDSOI=2  :# Relevés reportés
 # Des relevés ont été reportés dans le relevé en cours de création
 #  - Pas de comptabilisation
 #    -> On balaye les relevés à reporter non reportés ayant les
 #       mêmes caractéristiques
 #  - Comptabilisation
 #    -> On balaye les échéances générées par des relevés à reporter
 # On stocke dans le relevé à reporter la référence du relevé sur
 # lequel il a été reporté

 Read [SOI]SOI0=[M:REL0]SOINUM
 If fstat
  GOK=0 : Call FSTA("SOI") From GLOCK : Return
 Endif

 If GDIV(0)="1"  :# Pas de comptabilisation

  # Si Mono établissement, pas de code FCY sur SOI !!
  [L]CRITSAC2   = "1=1"
  [L]CRITFCY2   = "1=1"
  If GDIV(1)="1" : # SOISAC, Mono-collectif
   [L]CRITSAC2 = "SAC=[F:DUD]SAC"
  Endif
  If GDIV(2)="1" : # SOIFCY, Mono-site
   [L]CRITFCY2 = "FCY=[F:DUD]FCY"
  Endif
  Filter [F:SOI2] Where FLGFWD=2 & FWDSOI="" & SOINUM<>[M:REL0]SOINUM
&                     & BPR=[M:REL0]BPR & CPY=[M:REL0]CPY
&                     & CUR=[M:REL0]CUR
&                     & evalue([L]CRITSAC2) & evalue([L]CRITFCY2)

  Raz [L]MNTREPORT
  For [F:SOI2]SOI3
   Readlock [F:SOI2] Curr
   If fstat=1
    GOK=-1 : GLOCK="$SOI"-num$([F:SOI2]SOINUM) : Break
   Elsif fstat
    GOK=0 : Call RSTA("SOI2",num$([F:SOI2]SOINUM)) From GLOCK : Break
   Endif
   # A t'on assez de lignes pour reporter les échéances ?
   If [F:SOI2]DUDNBR+[F:SOI]DUDNBR<=dim([M:REL0]NUM)
#    [F:SOI2]FWDSOI = [M:REL0]SOINUM
#    Rewrite [F:SOI2]
#    If fstat
#     GOK=0 : Call FSTA("SOI2") From GLOCK : Break
#    Endif

    # Il faut basculer les échéances sur nouveau relevé !
    #  A condition qu'il y ait assez de ligne
    For [DUD3]DUD2 Where SOINUM=[F:SOI2]SOINUM With Lock
     If fstat=1
      GOK=-1 : GLOCK="$GACCDUDATE" : Break(2)
     Endif
     ## Lock de la pièce
     SYMHAE = "HAE"+num$([F:DUD3]NUM)+"\"+num$([F:DUD3]TYP)
     Lock =SYMHAE
     If fstat : GOK=-1 : GLOCK="%"+SYMHAE : Break(2) : Endif

     [F:SOI]AMTCUR += [F:DUD3]AMTCUR*[F:DUD3]SNS
     [L]MNTREPORT  += [F:DUD3]AMTCUR*[F:DUD3]SNS

     [F:DUD3]SOINUM = [F:SOI]SOINUM
     [F:SOI]DUDNBR += 1
     Rewrite [DUD3]
     If fstat
      GOK=0 : Call FSTA("DUD3") From GLOCK : Break(2)
     Endif
      Call HISTOECH("DUD3",1,[F:SOI]SOIDAT)From MODECHE
    Next : # [DUD3]

    Delete [SOI2]
    If fstat=1
     GOK = -1 : Call FSTA("SOI2") From GLOCK : Break
    Endif
   Endif : # If [F:SOI2]DUDNBR+[F:SOI]DUDNBR<=dim([M:REL0]NUM)
  Next : # [SOI2]
  Filter [F:SOI2]

  If [M:REL0]RMT+[L]MNTREPORT<0 & [M:REL0]RMT>0
   # Et RMT>0 sinon on a déjà posé la question
   [L]OK2=2 : Call OUINON(mess(109,117,1),[L]OK2) From GESECRAN         #### Relevé créditeur : à reporter?
  Endif
  If [L]OK2=2
   [F:SOI]FLGFWD = 2  :# Relevé à reporter
  Else
   [F:SOI]FLGFWD = 1
  Endif

  [M:REL0]FLGFWDSOI = 1 : # Force car on vire la pièce reporté !
  [F:SOI]FLGFWDSOI  = 1
  Rewrite [SOI]
  If fstat
   GOK=0 : Call FSTA("SOI") From GLOCK : Return
  Endif
 ####
 Else : # Comptabilisation
 ####
  For I=1 To [M:REL0]DUDNBR
   If [M:REL0]SOIDUD(I-1)<>""
    Filter [SOI2] Where TYPSOI=[M:REL0]TYP(I-1) & NUMSOI=[M:REL0]NUM(I-1)
    Read [SOI2]SOI4 First
    If !fstat
     Readlock [SOI2] Curr
     If fstat=1
      GOK=-1 : GLOCK="$SOI"-num$([M:REL0]TYP(I-1))-num$([M:REL0]NUM(I-1))
      Break
     Elsif fstat=0
      [F:SOI2]FWDSOI = [M:REL0]SOINUM
      Rewrite [F:SOI2]
      If fstat
       GOK=0 : Call FSTA("SOI2") From GLOCK : Break
      Endif
     Endif
    Endif
    Filter [F:SOI2]
   Endif
  Next I
  Filter [F:SOI2] : # Pour cause de Break !

  # Voyons voir si il y en a pas d'autres à reporter
  If [L]REPORT_REL :# Relevé à reporter
   I=0
   While [L]REL_NUM(I)<>""
    Readlock [F:SOI2]SOI0=[L]REL_NUM(I)
    If fstat=1
     GOK=-1 : GLOCK="$SOI"-num$([L]REL_NUM(I)) : Break
    Elsif fstat
     GOK=0 : Call RSTA("SOI2",num$([L]REL_NUM(I))) From GLOCK : Break
    Endif
    [F:SOI2]FWDSOI = [M:REL0]SOINUM
    Rewrite [F:SOI2]
    If fstat
     GOK=0 : Call FSTA("SOI2") From GLOCK : Break
    Endif
    # Pendant qu'on y est, il faut aussi se taper l'échéance associée
    [L]SAV_SOINUM  = [M:REL0]SOINUM
    [M:REL0]SOINUM = ""
    Gosub CRIT_ECHE From SUBREL0
    [M:REL0]SOINUM = [L]SAV_SOINUM
    Filter [F:DUD2] Where TYP=[L]TYP_REL(I) & NUM=[L]NUM_REL(I)
&                       & evalue(CRITECH)
    For [F:DUD2]DUD0 With Lock
     If fstat=1
      GOK=-1 : GLOCK="$GACCDUDATE" : Break(2)
     Endif
     ## Lock de la pièce
     SYMHAE = "HAE"+num$([F:DUD2]NUM)+"\"+num$([F:DUD2]TYP)
     Lock =SYMHAE
     If fstat : GOK=-1 : GLOCK="%"+SYMHAE : Break(2) : Endif

     [F:SOI]AMTCUR += [F:DUD2]AMTCUR*[F:DUD2]SNS
     [F:SOI]DUDNBR += 1

     [F:DUD2]SOINUM = [M:REL0]SOINUM
     Rewrite [F:DUD2]
     If fstat
      GOK=0 : Call FSTA("DUD2") From GLOCK : Break(2)
     Endif
      Call HISTOECH("DUD2",1,[M:REL0]SOIDAT)From MODECHE
    Next
    Filter [F:DUD2]

    Rewrite [SOI]
    If fstat
     GOK=0 : Call FSTA("SOI") From GLOCK : Break
    Endif

    I+=1 : If I=[L]NB_REL_REP : Break : Endif
   Wend
   Filter [F:DUD2] : # Pour cause de Break !
  Endif
 Endif : # If GDIV(0)="1"
 If GOK<1 : Return : Endif
Endif
Return


$SUPP_ECHE
Readlock [F:DUD]CLE Curr
If fstat=1
 GOK=-1
 GLOCK="$GACCDUDATE"-num$([F:DUD]ACCNUM)-num$([F:DUD]DUDLIG)
 Return
Elsif fstat
 GOK=0
 Call RSTA("DUD",num$([F:DUD]ACCNUM)-num$([F:DUD]DUDLIG)) From GLOCK
 Return
Endif
Raz [F:DUD]SOINUM
Case [M:REL0]ANUREL
 When 1 : [F:DUD]SOI=1
 When 2 : [F:DUD]SOI=2
Endcase
Rewrite [F:DUD]
If fstat
 GOK=0 : Call FSTA("DUD") From GLOCK : Return
Endif
Return

# Annulation du report de relevé
$SUPP_SOI
Filter [SOI2] Where FWDSOI=[F:SOI]SOINUM
For [F:SOI2] Hint Key SOI1 With Lock
 If fstat=1
  GOK=-1 : GLOCK="$SOI"-num$([F:SOI2]SOINUM) : Break
 Endif
 Raz [F:SOI2]FWDSOI
 Rewrite [F:SOI2]
 If fstat
  GOK=0 :  Call FSTA("SOI2") From GLOCK : Break
 Endif

 Gosub CRIT_ECHE From SUBREL0
 Filter [F:DUD2] Where TYP=[F:SOI2]TYPSOI & NUM=[F:SOI2]NUMSOI
&                    & evalue(CRITECH)
 For [F:DUD2]DUD0 With Lock
  If fstat=1
   GOK=-1 : GLOCK="$GACCDUDATE" : Break(2)
  Endif
  ## Lock de la pièce
  SYMHAE = "HAE"+num$([F:DUD2]NUM)+"\"+num$([F:DUD2]TYP)
  Lock =SYMHAE
  If fstat : GOK=-1 : GLOCK="%"+SYMHAE : Break(2) : Endif

  If [F:DUD2]SOINUM=[F:SOI]SOINUM : # Car dans le filtre CRIT_ECHE, SOINUM peut être vide
   [F:SOI]AMTCUR -= [F:DUD2]AMTCUR*[F:DUD2]SNS
   [F:SOI]DUDNBR -= 1

   Raz [F:DUD2]SOINUM
   Rewrite [F:DUD2]
   If fstat
    GOK=0 : Call FSTA("DUD2") From GLOCK : Break(2)
   Endif
   Call HISTOECH("DUD2",1,[F:SOI]SOIDAT)From MODECHE
  Endif
 Next : # [DUD2]
 Filter [F:DUD2]
 Rewrite [SOI]
 If fstat
  GOK=0 : Call FSTA("SOI") From GLOCK : Break
 Endif
Next : # [SOI2]
Filter [F:DUD2] : # Pour cause de Break !
Filter [F:SOI2]
Return

## Mise à jour des échéances d'un relevé
$TR_MAJ
GOK=1
Trbegin [DUD]

 Filter [DUD] Where SOINUM=[M:REL0]SOINUM
 For [DUD]
  [F:DUD]PAM    = [M:REL0]PAM
  [F:DUD]DUDDAT = [M:REL0]DUDDAT
  Rewrite [DUD]
  If fstat
   GOK=0 : Call FSTA("DUD") From GLOCK : Break
  Endif
  Call HISTOECH("DUD",1,[M:REL0]SOIDAT)From MODECHE
 Next
 If !GOK : Goto AB_TR_MAJ : Endif
 Filter [DUD]

Commit
Return

$ROLL_TR_MAJ
Rollback : Call ROLL From GLOCK
If GROLL : Rollback : Return Else Goto TR_MAJ : Endif

$AB_TR_MAJ
Rollback : Return

