#<AdxTL>@(#)12.0.0.0 $Revision$

$ACTION
Case ACTION
 When "FIN"        : Gosub FIN
 When "SEL_LISTE"  : Gosub SEL_LISTE
 When "VERF_LISTE" : Gosub VERF_LISTE
 When "EXEC","OK"       : Gosub EXEC
Endcase
Return

$FIN
PARAM(2) = [M]CHAINE
Return

$SEL_LISTE
If GSTATUT=GSTAESC : Return : Endif
Local Integer SAVNOL
SAVNOL = nolign
Call TEMPON("R") From GESECRAN
Local Char LANGUE(GLONLAN)
Local Char TXT(150)
LANGUE = PARAM(1)
TXT    = toupper(ctrans(PARAM(2)))
For [AX2] Where LAN=LANGUE & pat(toupper(ctrans([F:AX2]TEXTE)),"*"+TXT+"*")
 If NBTEX>=dim(TEX)-1 : Break : Endif
 NBTEX += 1
 TEX(NBTEX) = "1"-num$([F:AX2]NUMERO)
 TEXTE(NBTEX) = mess(1,937,1)-num$([F:AX2]NUMERO)-":"-[F:AX2]TEXTE
Next
For [AS2] Where LAN=LANGUE & pat(toupper(ctrans([F:AS2]LANMES)),"*"+TXT+"*")
 If NBTEX>=dim(TEX)-1 : Break : Endif
 NBTEX += 1
 TEX(NBTEX) = "2"-num$([F:AS2]LANCHP)-num$([F:AS2]LANNUM)
 TEXTE(NBTEX) = mess(2,937,1)-num$([F:AS2]LANCHP)+"/"+num$([F:AS2]LANNUM)-":"-[F:AS2]LANMES
Next
Call TEMPOFF From GESECRAN
Return


$VERF_LISTE
PARAM(3) = left$(TEX(CHOIX),1)
Case PARAM(3)
 When "1"
  PARAM(4) = "0"
  PARAM(5) = right$(TEX(CHOIX),3)
 When "2"
  K = instr(3,TEX(CHOIX)," ")
  PARAM(4) = seg$(TEX(CHOIX),3,K-1)
  PARAM(5) = right$(TEX(CHOIX),K+1)
Endcase
nolign = SAVNOL
Return

$EXEC
Call TEMPON("R") From GESECRAN
Local Char LANGUE(GLONLAN)
Local Char TXT(150)
LANGUE = [M:AVO1]WLAN
TXT    = toupper(ctrans([M:DIA]CHAINE))
For [AX2] Where LAN=LANGUE & pat(toupper(ctrans([F:AX2]TEXTE)),"*"+TXT+"*")
 If [M:AVO1]NBLIG>=dim([M:AVO1]TYP) : Break : Endif
 If !find("1"-"0"-num$([F:AX2]NUMERO),[M:AVO1]CLE(0..[M:AVO1]NBLIG-1))
  [M:AVO1]TYP([M:AVO1]NBLIG) = 1
  [M:AVO1]CHP([M:AVO1]NBLIG) = 0
  [M:AVO1]NUM([M:AVO1]NBLIG) = [F:AX2]NUMERO
  [M:AVO1]STD([M:AVO1]NBLIG) = [F:AX2]TEXTE
  [M:AVO1]LNG([M:AVO1]NBLIG) = [F:AX2]LONG
  [M:AVO1]FLG([M:AVO1]NBLIG) = 1
  [M:AVO1]CLE([M:AVO1]NBLIG) = "1"-"0"-num$([F:AX2]NUMERO)
  [M:AVO1]NBLIG += 1
 Endif
Next
For [AS2] Where LAN=LANGUE & pat(toupper(ctrans([F:AS2]LANMES)),"*"+TXT+"*")
 If [M:AVO1]NBLIG>=dim([M:AVO1]TYP) : Break : Endif
 If !find("2"-num$([F:AS2]LANCHP)-num$([F:AS2]LANNUM),[M:AVO1]CLE(0..[M:AVO1]NBLIG-1))
  [M:AVO1]TYP([M:AVO1]NBLIG) = 2
  [M:AVO1]CHP([M:AVO1]NBLIG) = [F:AS2]LANCHP
  [M:AVO1]NUM([M:AVO1]NBLIG) = [F:AS2]LANNUM
  [M:AVO1]STD([M:AVO1]NBLIG) = [F:AS2]LANMES
  [M:AVO1]LNG([M:AVO1]NBLIG) = type([F:AS2]LANMES)-10
  [M:AVO1]FLG([M:AVO1]NBLIG) = 1
  [M:AVO1]CLE([M:AVO1]NBLIG) = "2"-num$([F:AS2]LANCHP)-num$([F:AS2]LANMES)
  [M:AVO1]NBLIG += 1
 Endif
Next
Call TEMPOFF From GESECRAN
Affzo [AVO1]20
mkstat = 4
Return

