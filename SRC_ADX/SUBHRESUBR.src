#<AdxTL>@(#)0.0.0.0 $Revision$ E-submission registration
$ACTION
  Case ACTION
    When "OUVRE"            : Gosub OUVRE
    When "AVANTBOUT"        : Gosub AVANTBOUT
    When "AFFMASK"          : Gosub AFFMASK
    When "LIENS"            : Gosub LIENS
    When Default
  Endcase
Return

$OUVRE
  If clalev([F:ESUBREG])    = 0 : Local File HRESUBREG        [ESUBREG]         : Endif
  If clalev([F:CPYUKI])     = 0 : Local File HRCOMPANYUKI     [CPYUKI]          : Endif
  If clalev([F:BPADDR])     = 0 : Local File BPADDRESS        [BPADDR]          : Endif
Return

$AFFMASK
Return

$AVANTBOUT
  Case [L]BOUT
    When "G"
      Call GETCAPTCHA
    When "Z"
      Call REGISTERCOMPANY
  Endcase
Return

$LIENS
  Call TOGGLE_READONLY
Return

Subprog TOGGLE_READONLY
  If [M:ESUBREG1]SIGNTOKEN = ""
    Actzo [M:ESUBREG]EMAIL
    Actzo [M:ESUBREG1]ORGID
  Else
    Grizo [M:ESUBREG]EMAIL
    Grizo [M:ESUBREG1]ORGID
  Endif
End

Subprog GETCAPTCHA()

  Local Integer STATUSCODE
  Local Clbfile RESHEAD, RESBODY
  Local Char TOKEN(255)
  Local Clbfile CAPTCHAURL
  Local Clbfile ARGUMENTS

  Local Clbfile STSURL, RTXURL
  STSURL = func HRESUB_FUNC.GETSERVICEURL("RTISTS")
  RTXURL = func HRESUB_FUNC.GETSERVICEURL("RTIRTX")

  # exports.getCaptchaURL = function(_, application, stsUrl, rtxUrl)
  ARGUMENTS = '"sage.global.x3", '
  ARGUMENTS += '"' + STSURL + '", '
  ARGUMENTS += '"' + RTXURL + '"'
  #ARGUMENTS += '"https://qa.sage-rtx.com/api/v1/"'

  STATUSCODE = func ASYRWEBSER.EXEC_JS("bundle-sage-rtx-helper/lib/rtx-helper", "getCaptchaURL", "wait", ARGUMENTS, '0, 0, 0', 0, "", "0", RESHEAD, RESBODY)
  If STATUSCODE<>200
    GMESSAGE = "Error retrieving Sage Token\Status code: " -num$(STATUSCODE) - "\Header: " - RESHEAD
    mkstat = 2 : GERR=1
    End
  Endif

#  If GUSER = 'PITRU'
#    Local Integer I
#    Local Clbfile MSG
#    MSG = RESHEAD
#    For I = 0 To len(MSG) / 200
#      Infbox "HEAD (" + num$(I) + "): " + mid$(MSG, I*200+1, 200)
#    Next I
#
#    MSG = RESBODY
#    For I = 0 To len(MSG) / 200
#      Infbox "BODY (" + num$(I) + "): " + mid$(MSG, I*200+1, 200)
#    Next I
#  Endif

  TOKEN = func AJSONLIB.GET_PROP(RESBODY, "token")
  CAPTCHAURL = func AJSONLIB.GET_PROP(RESBODY, "captchaURL")

  [M:ESUBREG1]ORGID = ""
  [M:ESUBREG1]COMPID = ""
  [M:ESUBREG1]SIGNTOKEN = ""

  [F:ESUBREG]SIGNTOKEN = ""

  Call TOGGLE_READONLY()

  #[M:ESUBREG1]URL = CAPTCHAURL
  [M:ESUBREG1]URL = "/rtx/html/captcha.html?token=" + TOKEN +  "&captchaurl=" + CAPTCHAURL
  Call INITURL([M:ESUBREG1]CAPTCHA,"URL","","") From INTRUTILA
  Affzo [M:ESUBREG1]CAPTCHA

  Affzo [M:ESUBREG1]
End

Subprog REGISTERCOMPANY()
  Read[F:CPYUKI]CPYUKI0=[M:ESUBREG]CPY
  If !fstat Then
    Local Char SIGNTOKEN(128), ORGID(36), COMPID(36)
    Local Integer STATUSCODE
    Local Clbfile RESHEAD, RESBODY
    Local Clbfile ARGUMENTS

    Local Clbfile RTXURL
    RTXURL = func HRESUB_FUNC.GETSERVICEURL("RTIRTX")

    COMPID = num$(getUuid)

    # exports.registerCompany = function(_, application, rtxUrl, organisationId, companyData) {
    ARGUMENTS = '"x3", '
    ARGUMENTS += '"' + RTXURL + '", '
    ARGUMENTS += '"' + [M:ESUBREG1]ORGID + '", '
    ARGUMENTS += '{"adminEmail": "' + [M:ESUBREG]EMAIL + '", '
    ARGUMENTS += '"company": {"uuid": "' + COMPID + '",'
    ARGUMENTS += '"name": "' + [M:ESUBREG]CPYNAM + '",'
    ARGUMENTS += '"adminEmail": "' + [M:ESUBREG]EMAIL + '",'
    ARGUMENTS += '"payeReference": "' + [M:ESUBREG]PAYREFNUM + '"}}'

    STATUSCODE = func ASYRWEBSER.EXEC_JS("bundle-sage-rtx-helper/lib/rtx-helper", "registerCompany", "wait", ARGUMENTS, '0, 0, 0, 0', 0, "", "0", RESHEAD, RESBODY)
    If STATUSCODE<>200
      GMESSAGE = "Error registering with RTX\Status code: " -num$(STATUSCODE) - "\Header: " - RESHEAD
      mkstat = 2 : GERR=1
      End ""
    Endif

    STATUSCODE = evalue(func AJSONLIB.GET_PROP(RESBODY, "statusCode"))

    If STATUSCODE = 201
      ORGID = func AJSONLIB.GET_PROP(RESBODY, "organisationId")
      SIGNTOKEN = func AJSONLIB.GET_PROP(RESBODY, "signingToken")

      [M:ESUBREG1]ORGID = ORGID
      [M:ESUBREG1]SIGNTOKEN = SIGNTOKEN
      [M:ESUBREG1]COMPID = COMPID
      Affzo [M:ESUBREG1]

      Readlock [ESUBREG]ESUBREG0= [M:ESUBREG]CPY
      If fstat = 0
        [F:ESUBREG]CPY = [M:ESUBREG]CPY
        [F:ESUBREG]CPYNAM = [M:ESUBREG]CPYNAM
        [F:ESUBREG]PAYREFNUM = [M:ESUBREG]PAYREFNUM
        [F:ESUBREG]EMAIL = [M:ESUBREG]EMAIL
        [F:ESUBREG]USERID = [M:ESUBREG]USERID
        [F:ESUBREG]PWD = [M:ESUBREG]PWD
        [F:ESUBREG]ORGID = ORGID
        [F:ESUBREG]SIGNTOKEN = SIGNTOKEN
        [F:ESUBREG]COMPID = COMPID
        Rewrite [F:ESUBREG]
        Unlock [ESUBREG]

        If fstat
          GOK=0 : Call FSTA("ESUBREG") From GLOCK
        Endif
      Else
        Raz [F:ESUBREG]
        [F:ESUBREG]CPY = [M:ESUBREG]CPY
        [F:ESUBREG]CPYNAM = [M:ESUBREG]CPYNAM
        [F:ESUBREG]PAYREFNUM = [M:ESUBREG]PAYREFNUM
        [F:ESUBREG]EMAIL = [M:ESUBREG]EMAIL
        [F:ESUBREG]USERID = [M:ESUBREG]USERID
        [F:ESUBREG]PWD = [M:ESUBREG]PWD
        [F:ESUBREG]ORGID = ORGID
        [F:ESUBREG]SIGNTOKEN = SIGNTOKEN
        [F:ESUBREG]COMPID = COMPID
        Write [F:ESUBREG]

        If fstat
          GOK=0 : Call FSTA("ESUBREG") From GLOCK
        Endif
      Endif

      Call TOGGLE_READONLY

      Infbox "Company details successfully registered and signing key retrieved from RTX."

    Else
#      If GUSER = 'PITRU'
#        Local Integer I
#        Local Clbfile MSG
#        MSG = RESBODY
#        For I = 0 To len(MSG) / 200
#          Infbox "MSG (" + num$(I) + "): " + mid$(MSG, I*200+1, 200)
#        Next I
#      Endif

      GMESSAGE = "Error registering with RTX\Status code: " + num$(STATUSCODE) + "\Message: " + unescJson(func AJSONLIB.GET_PROP(RESBODY, "message"))
      mkstat = 2 : GERR=1
    Endif
  Else
    GMESSAGE = "No company ID found. Please make sure you have selected a company."
    mkstat = 2 : GERR=1
  Endif
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
  Read[F:CPYUKI]CPYUKI0=VALEUR
  If !fstat Then
    [M:ESUBREG]CPYNAM = [F:CPYUKI]CPYNAM
#ALHAR - 12-03-2018 X3-81954 - start
    If [M:ESUBREG]CPYNAM = ''
      If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
      Read [F:CPY]CPY0=[F:CPYUKI]CPY
      [M:ESUBREG]CPYNAM = [F:CPY]CPYNAM
      If [M:ESUBREG]CPYNAM = ''
        GMESSAGE = "No company name found. Please make sure you have selected a company with name."
        mkstat = 2 : GERR=1
        End
      Endif
    Endif
#ALHAR - 12-03-2018 X3-81954 - end
    [M:ESUBREG]PAYREFNUM = [F:CPYUKI]TAXDTT + "/" + [F:CPYUKI]PAYREFNUM
  Endif

  Filter [BPADDR] Where BPATYP=2 and BPANUM = [F:CPYUKI]CPY
  Read [BPADDR]BPA0 First
  If !fstat Then
    [M:ESUBREG]EMAIL = [F:BPADDR]WEB(0)
  Endif

  Affzo [M:ESUBREG]
End

