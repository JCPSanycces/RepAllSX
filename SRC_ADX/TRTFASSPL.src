#========================================================================#
#========================================================================#
#  Gestion du masque FASSPL1 : Eclatement                               #
#========================================================================#

#=====================================
# C_ TYPE ECLATEMENT
#=====================================
Subprog C_SPLBAS(VALEUR)
Variable Integer VALEUR

Local Decimal LCUMLOFI
Local Integer STAT

# si répartition par quantité : il faut que le bien d'origine ait une quantité au moins égale à  2
If (VALEUR = GVML_TECLQTY) & ([M:FAS1]AASQTY < 2) and ([F:TUNB]UOMDEC = 0)
   #"éclatement par quantité impossible : quantité < 2 "
   GERR=1   :   GMESSAGE= mess(288,GML_MSGFAS,1)
   mkstat=2
   GMENLOC(GVML_TECLQTY)=1   : End
Endif

# si répartition par dépense : il faut au moins 2 dépenses liées au bien d'origine
If (VALEUR = GVML_TECLDEP) & ([M:OCP]NBOBJ < 2)
   # "éclatement par dépense impossible : nb de dépenses liées < 2 "
   GERR=1   :   GMESSAGE= mess(289,GML_MSGFAS,1)
   mkstat=2
   GMENLOC(GVML_TECLDEP)=1   : End
Endif

# si répartition par dépense : il faut que le cumul des valeurs des dépenses liées = la valeur HT PCG (et IFRS) du bien
# soit égal à  la valeur HT PCG et IFRS du bien à éclater
# mess 427=Eclatement par dépense impossible :
# Valeur HT PCG (et/ou  IFRS) du bien différente du cumul des dépenses immobilisées.

# ------------- Conversion en devise IAS : si la devise IAS est renseignée
If [M:FAS1]IASCUR <> ""
  Call CONVERT3([M:FAS1]ACGCUR, [M:FAS1]IASCUR, GCOUDEV, [M:FAS1]IASCURTYP, [M:FAS1]PURDAT,
&                  GCUMLOF, LCUMLOFI, [M:FAS1]IASRATCUR, STAT) From CPTSUB
Endif

If (VALEUR = GVML_TECLDEP) & (GCUMLOF <> [M:FAS1]ACGETRNOT or LCUMLOFI <> [M:FAS1]IASETRNOT)
  GERR=1   :   GMESSAGE= mess(427,GML_MSGFAS,1)
  mkstat=2
  GMENLOC(GVML_TECLDEP)=1   : End
Endif

## Interdiction éclatement par qté ou montant si plusieurs dépenses rattachées
## et au-moins une dépense rattachée est subventionnée
##
##*FQ-92254 Contrôle déplacé en C_LOFSPLFLG
# If (VALEUR = GVML_TECLQTY) or (VALEUR = GVML_TECLAMT)
#   If  [M:OCP]NBOBJ  > 1
#      # boucle sur les dépenses rattachées
#      For I_OBJ =  1 To [M:OCP]NBOBJ
#         Read [LOF]LOF0 =[M:OCP]CODLOF(I_OBJ-1);[M:OCP]LINLOF(I_OBJ-1)
#         If [F:LOF]PLNINV <> "" & [F:LOF]FLGGRA = G_OUI
#             GMENLOC(GVML_TECLQTY)=1
#             GMENLOC(GVML_TECLAMT)=1
#             # "éclatement par qté ou  montant impossible car une dépense est subventionnée "
#             GERR=1  : GMESSAGE= mess(558,GML_MSGFAS,1) : mkstat=2
#             Break
#         Endif
#      Next I_OBJ
#   Endif
#Endif

End
#=====================================
# AP_ TYPE ECLATEMENT
#=====================================
Subprog AP_SPLBAS(VALEUR)
Variable Integer VALEUR

# Si on éclate par  quantité on répartit obligatoirement la quantité
If VALEUR = GVML_TECLQTY
  [M:FASE]QTYSPL = G_OUI
  Affzo [M:FASE]QTYSPL
  Diszo [M:FASE]QTYSPL
  [M:FASE]PRCFLG = G_NON   #*Fq-54343
  Affzo [M:FASE]PRCFLG     #*Fq-54343
  Diszo [M:FASE]PRCFLG     #*Fq-54343
  # le type de montant est grizé mais il faut initialiser quand même le montant à éclater
  # et le type de montant
  If  [M:FAS1]ACGETRNOT <> 0
    [M:FASE]SPLAMTBEF  = [M:FAS1]ACGETRNOT
    [M:FASE]SPLAMTTYP = GVML_VENTPCG
  Else
    If [M:FAS1]IASETRNOT <> 0
      [M:FASE]SPLAMTBEF  = [M:FAS1]IASETRNOT
    [M:FASE]SPLAMTTYP = GVML_VENTIAS
    Endif
  Endif
  Affzo [M:FASE]SPLAMTTYP
  Diszo [M:FASE]SPLAMTTYP
  Diszo [M:OCP]5    #*Fq-62392
Endif

# Si on éclate par répartition du montant on peut répartir aussi la quantité
#Fq-54343 Si on éclate par répartition du montant on peut répartir aussi la quantité
If VALEUR = GVML_TECLAMT
  If [M:FAS1]AASQTY > 1 or [M:FASE]UOMDEC <> 0
    [M:FASE]QTYSPL = G_OUI
    Affzo [M:FASE]QTYSPL
    Actzo [M:FASE]QTYSPL
  Else
    [M:FASE]QTYSPL = G_NON
    Affzo [M:FASE]QTYSPL
    Diszo [M:FASE]QTYSPL
  Endif
  Actzo [M:FASE]SPLAMTTYP
  Diszo [M:OCP]5    #*Fq-62392
Endif

# Si on éclate par répartition des dépenses on ne peut pas répartir la quantité
If VALEUR = GVML_TECLDEP
  [M:FASE]QTYSPL = G_NON
  Affzo [M:FASE]QTYSPL
  Diszo [M:FASE]QTYSPL
  # le type de montant est grizé mais il faut initialiser quand même le montant à éclater
  # et le type de montant
  If  [M:FAS1]ACGETRNOT <> 0
    [M:FASE]SPLAMTBEF  = [M:FAS1]ACGETRNOT
    [M:FASE]SPLAMTTYP = GVML_VENTPCG
  Else
    If [M:FAS1]IASETRNOT <> 0
      [M:FASE]SPLAMTBEF  = [M:FAS1]IASETRNOT
      [M:FASE]SPLAMTTYP = GVML_VENTIAS
    Endif
  Endif
  Affzo [M:FASE]SPLAMTTYP
  Diszo [M:FASE]SPLAMTTYP
Endif

## Interdiction éclatement par qté ou montant si plusieurs dépenses rattachées
## et au-moins une dépense rattachée est subventionnée
##*FQ-92254 ????? voir s'il faut conserver ce contrôle...
##*FQ-92254 ????? en le déplaçant pour qu'il soit fait après accès au flag LOFSPLFLG
# If (VALEUR = GVML_TECLQTY) or (VALEUR = GVML_TECLAMT)
#   If  [M:OCP]NBOBJ  > 1
#      # boucle sur les dépenses rattachées
#      For I_OBJ =  1 To [M:OCP]NBOBJ
#         Read [LOF]LOF0 =[M:OCP]CODLOF(I_OBJ-1);[M:OCP]LINLOF(I_OBJ-1)
#         If [F:LOF]PLNINV <> "" & [F:LOF]FLGGRA = G_OUI
#             GMENLOC(GVML_TECLQTY)=1
#             GMENLOC(GVML_TECLAMT)=1
#             # "éclatement par qté ou  montant impossible car une dépense est subventionnée "
#             GERR=1  : GMESSAGE= mess(558,GML_MSGFAS,1) : mkstat=2
#             Break
#         Endif
#      Next I_OBJ
#   Endif
#Endif

End
#=====================================
## AM_ TYPE ECLATEMENT
#=====================================
Subprog AM_SPLBAS(VALEUR)
Variable Integer VALEUR

If VALEUR <> [M:FASE]SPLBAS
  Disable GSTAOK
Endif

If VALEUR <> [M:FASE]SPLBAS
  Raz [M:FASE]QTYAFT
  Raz [M:FASE]SPLAMTAFT
  Affzo [M:FASE]QTYAFT
  Affzo [M:FASE]SPLAMTAFT
  Actzo [M:OCP]5   #*Fq-62392
Endif

# si répartition par quantité : ilfaut que le bien d'origine ait une quantité au moins égale à  2
If (VALEUR = GVML_TECLQTY)
   If ([M:FAS1]AASQTY < 2) and ([F:TUNB]UOMDEC = 0)
      #"éclatement par quantité impossible : quantité < 2 "
      GERR=1   :   GMESSAGE= mess(288,GML_MSGFAS,1)
      mkstat=2
      GMENLOC(GVML_TECLQTY)=1   : End
   Else
     If ([F:TUNB]UOMDEC = 0)
       #FQ91070
       If dim(GFXDNBERR) < 0
         [M:FASE]NBFAS =  [M:FAS1]AASQTY
       Else
         # que si NBFAS n'est pas paramétré en ITF des MVTS
         If  GNBFAS_FXD = G_NON
           [M:FASE]NBFAS =  [M:FAS1]AASQTY
         Endif
       Endif
     Endif
   Endif
   Diszo [M:OCP]5      #*Fq-62392
Endif

# si répartition par quantité : il faut que le bien d'origine ait une quantité > qté d'origine
If (VALEUR = GVML_TECLQTY) &  ([F:TUNB]UOMDEC = 0) & ([M:FASE]NBFAS > [M:FAS1]AASQTY )
   # Nombre d'éclatements invalide
   GERR=1   :   GMESSAGE= mess(396,GML_MSGFAS,1)
   mkstat=2 : End
Endif

# Si on éclate par répartition du montant on peut répartir aussi la quantité
# si la quantité est > 1 et que l'unité n'accepte pas les décimales
If VALEUR = GVML_TECLAMT
  #FQ91070
  If dim(GFXDNBERR) < 0
    [M:FASE]NBFAS =  0
  Endif
  Affzo  [M:FASE]NBFAS
  If ([M:FASE]QTYBEF > 1) or ([F:TUNB]UOMDEC <> 0)
    [M:FASE]QTYSPL = G_OUI
    Affzo [M:FASE]QTYSPL
    Actzo [M:FASE]QTYSPL
  Else
    [M:FASE]QTYSPL = G_NON
    Affzo [M:FASE]QTYSPL
    Diszo [M:FASE]QTYSPL
  Endif
  Actzo [M:FASE]SPLAMTTYP
  Diszo [M:OCP]5    #*Fq-62392
   If [M:OCP]NBOBJ > 1
     Affzo  [M:FASE]LOFSPLFLG
     Actzo  [M:FASE]LOFSPLFLG
  Endif
   Actzo [M:FASE]PRCFLG   #*FQ99093
Else #*FQ99093 si éclatement par qtés ou dépenses pas de répartition en pourcentage
   [M:FASE]PRCFLG = G_NON
   Affzo [M:FASE]PRCFLG
   Diszo [M:FASE]PRCFLG #*FQ99093 END
Endif

  # Si on modifie le type d'éclatement pour éclater par dépense
  # on remet à 0 le nombre d'éclatements
If  VALEUR = GVML_TECLDEP
    [M:FASE]LOFSPLFLG = G_NON #*FQ99093
    Affzo [M:FASE]LOFSPLFLG   #*FQ99093
    Diszo [M:FASE]LOFSPLFLG   #*FQ99093
  #FQ91070
  If dim(GFXDNBERR) < 0
    [M:FASE]NBFAS =  0
  Else
    # que si NBFAS n'est pas paramétré en ITF des MVTS
    If  GNBFAS_FXD = G_NON
      [M:FASE]NBFAS = 0
    Endif
  Endif
  Affzo  [M:FASE]NBFAS
  Actzo [M:OCP]5   #*Fq-62392
Else #*FQ99093 One can choose to explode or not linked expenses
   Actzo [M:FASE]LOFSPLFLG
Endif


End
#=====================================
# AP_ TYPE MONTANT ECLATEMENT
#=====================================
Subprog AP_SPLAMTTYP(VALEUR)
Variable Integer VALEUR

Case VALEUR
  When GVML_VENTPCG  : [M:FASE]SPLAMTBEF  = [M:FAS1]ACGETRNOT
  When GVML_VENTIAS  : [M:FASE]SPLAMTBEF  = [M:FAS1]IASETRNOT
  When GVML_VBILPCG  : [M:FASE]SPLAMTBEF  = [M:FAS1]ACGBSEVAL
  When GVML_VBILIAS  : [M:FASE]SPLAMTBEF  = [M:FAS1]IASBSEVAL
  When GVML_VBRPCG
     For I = 1 To   [M:FAS3]NBLIG1
      If [M:FAS3]DPRPLN(I-1)  = G301CPT
         [M:FASE]SPLAMTBEF  = [M:FAS3]DPRBAS(I-1)
         Break
      Endif
     Next I
  When GVML_VBRIAS
     For I = 1 To   [M:FAS3]NBLIG1
      If [M:FAS3]DPRPLN(I-1)  = G301IAS
         [M:FASE]SPLAMTBEF  = [M:FAS3]DPRBAS(I-1)
         Break
      Endif
     Next I
  When Default : [M:FASE]SPLAMTBEF  = [M:FAS1]ACGETRNOT
    If  [M:FAS1]ACGETRNOT<> 0  :   [M:FASE]SPLAMTBEF  = [M:FAS1]ACGETRNOT
    Else
      If [M:FAS1]IASETRNOT <> 0  :  [M:FASE]SPLAMTBEF  = [M:FAS1]IASETRNOT
      Endif
    Endif
Endcase

Affzo[M:FASE]SPLAMTBEF


If G_HASELT <> G_OUI #Fq-52661
   If [M:FASE]SPLAMTBEF = 0 :  [M:FASE]SPLBAS=GVML_TECLAMT
      # "type d'éclatement invalide car montant nul"
       GERR=1   :    GMESSAGE=mess(290,GML_MSGFAS,1)
      mkstat=2
       GMENLOC(GVML_TECLAMT)=1   : End
    Endif
 Endif #Fq-52661


End
#=====================================
# AM_ TYPE MONTANT ECLATEMENT
#=====================================
Subprog AM_SPLAMTTYP(VALEUR)
Variable Integer VALEUR

Local Integer I

If VALEUR <> [M:FASE]SPLAMTTYP
  Disable GSTAOK
Endif

Case VALEUR
  When GVML_VENTPCG  : [M:FASE]SPLAMTBEF  = [M:FAS1]ACGETRNOT
  When GVML_VENTIAS  : [M:FASE]SPLAMTBEF  = [M:FAS1]IASETRNOT
  When GVML_VBILPCG  : [M:FASE]SPLAMTBEF  = [M:FAS1]ACGBSEVAL
  When GVML_VBILIAS  : [M:FASE]SPLAMTBEF  = [M:FAS1]IASBSEVAL
  When GVML_VBRPCG
     For I = 1 To   [M:FAS3]NBLIG1
      If [M:FAS3]DPRPLN(I-1)  = G301CPT
         [M:FASE]SPLAMTBEF  = [M:FAS3]DPRBAS(I-1)
         Break
      Endif
     Next I
  When GVML_VBRIAS
     For I = 1 To   [M:FAS3]NBLIG1
      If [M:FAS3]DPRPLN(I-1)  = G301IAS
         [M:FASE]SPLAMTBEF  = [M:FAS3]DPRBAS(I-1)
         Break
      Endif
     Next I
  When Default
Endcase

Affzo[M:FASE]SPLAMTBEF

If G_HASELT <> G_OUI  #Fq-52661
   ##Fq-60516 If [M:FASE]SPLAMTBEF <= 0 & [M:FASE]SPLBAS=GVML_TECLAMT
   If [M:FASE]SPLAMTBEF = 0 & [M:FASE]SPLBAS=GVML_TECLAMT
    # "Type d'éclatement invalide car montant nul"
    GERR=1   :   GMESSAGE= mess(290,GML_MSGFAS,1)
     mkstat=2
     GMENLOC(GVML_TECLAMT)=1   : End
  Endif
Endif   #Fq-52661


End
#=====================================
# AM_ NOMBRE BIENS APRES ECLATEMENT
#=====================================
Subprog AM_NBFAS(VALEUR)
Variable Decimal VALEUR

Local Integer I

If VALEUR <> [M:FASE]NBFAS
  Disable GSTAOK
  Raz [M:FASE]QTYAFT
  Raz [M:FASE]SPLAMTAFT
  For I = 1 To [M:OCP]NBOBJ
    [M:OCP]SELFLG(I-1) = G_NON
    Affzo [M:OCP]SELFLG(I-1)
  Next I

#  #FQ99886
#  If [M:OCP]NBOBJ  > 0
#    [M:FASE]LOFSPLFLG = G_OUI
#     If [M:OCP]NBOBJ = 1
#        Diszo [M:FASE]LOFSPLFLG
#     Else
#        Actzo [M:FASE]LOFSPLFLG
#     Endif
#  Endif #FQ99886 END

  #FQ101620
  If  ( [M:FASE]SPLBAS = GVML_TECLDEP ) or ( [M:OCP]NBOBJ = 0 )
    [M:FASE]LOFSPLFLG = G_NON
  Else
     [M:FASE]LOFSPLFLG = G_OUI
  Endif
  Affzo [M:FASE]LOFSPLFLG

  If ( [M:FASE]SPLBAS = GVML_TECLDEP ) or [M:OCP]NBOBJ = 1
        Diszo [M:FASE]LOFSPLFLG
     Else
        Actzo [M:FASE]LOFSPLFLG
  Endif  #FQ101620 END

Endif

# On ne peut pas éclater en moins de 2 !!
If VALEUR < 2
   # Nombre d'éclatements invalide
   GMESSAGE = mess(396,GML_MSGFAS,1)
  GERR     = 1 :   mkstat   = 2 :   End
Endif

# Si on répartit la quantité, et que l'UOM n'a pas de décimales, le nombre d'éclatements
# Ne peut être > à la la quantité d'origine.
If [M:FASE]SPLBAS = GVML_TECLQTY
  If VALEUR > [M:FAS1]AASQTY and ([F:TUNB]UOMDEC = 0)
    GMESSAGE = mess(10,GML_MSGLOF,1) : # Nombre d'éclatements invalide
    GERR     = 1 :     mkstat   = 2 : End
  Else
    [M:FASE]QTYSPL= G_OUI
    Diszo [M:FASE]QTYSPL
    Affzo [M:FASE]QTYSPL
    [M:FASE]PRCFLG = G_NON   #Fq-54343
    Diszo [M:FASE]PRCFLG     #Fq-54343
  Endif
Endif

# Si éclatement par Dépenses ==> pas de répartition de la quantité
If ([M:FASE]SPLBAS = GVML_TECLDEP)
  [M:FASE]QTYSPL= G_NON
  Diszo [M:FASE]QTYSPL
  Affzo [M:FASE]QTYSPL
  [M:FASE]PRCFLG = G_NON    #Fq-54343
  Diszo [M:FASE]PRCFLG      #Fq-54343
Endif

# Si éclatement par Montant
If [M:FASE]SPLBAS = GVML_TECLAMT
  # Si on réparti la quantité, et que l'UOM n'a pas de décimales, le nombre d'éclatements
  # Ne peut excéder la quantité d'origine.
  If[M:FASE]QTYBEF > 1
    If  VALEUR > [M:FASE]QTYBEF and [M:FASE]UOMDEC = 0
      [M:FASE]QTYSPL = G_NON
      Diszo[M:FASE]QTYSPL
      Affzo [M:FASE]QTYSPL
    Else
     [M:FASE]QTYSPL = G_OUI
      Actzo [M:FASE]QTYSPL
      Affzo [M:FASE]QTYSPL
    Endif
  Elsif [F:TUNB]UOMDEC = 0
  # La quantité du bien d'origine est < 1
    [M:FASE]QTYSPL = G_NON
    Diszo [M:FASE]QTYSPL
    Affzo [M:FASE]QTYSPL
  Endif
   #*****
  If VALEUR > 999
    # Nombre d'éclatement invalide
    GMESSAGE = mess(10,GML_MSGLOF,1)
    GERR     = 1 :     mkstat   = 2 :     End
  Endif
#    [M:FASE]PRCFLG = G_NON    #Fq-54343 #FQ91070
    Actzo [M:FASE]PRCFLG      #Fq-54343
Endif


# Si éclatement par Dépenses
If [M:FASE]SPLBAS = GVML_TECLDEP
  If (VALEUR <> [M:OCP]NBOBJ)
    If (VALEUR <> 2)
       # Nombre d'éclatement invalide
       GMESSAGE = mess(10,GML_MSGLOF,1)
       GERR     = 1 :     mkstat   = 2 :     End
    Endif
  Endif
Endif

If G_HASELT = G_OUI
  If SPLELT = GVMLTECLELT
    If VALEUR > [OCP1]NBELT
      GMESSAGE = mess(10,GML_MSGLOF,1)
      GERR     = 1 :     mkstat   = 2 :     End
    Endif
  Endif
Endif
[M:FASE]NBFAS = VALEUR

End
#========================================================
# AP_ Flag REPARTIR QUANTITE  (si éclatement par montant)
#========================================================
Subprog AP_QTYSPL(VALEUR)
Variable Integer VALEUR

End
#=====================================
# C_ QUANTITE APRES éclatement
#=====================================
Subprog C_QTYAFT(VALEUR)
Variable Decimal VALEUR

If VALEUR = 0
   # Quantité invalide
   GMESSAGE = mess(291,GML_MSGFAS,1)
   GERR     = 1 :   mkstat   = 2 :   End
Endif


End

#=====================================
# AV_ Type de numérotation
#=====================================
Subprog AS_TYPNUM(VALEUR)
Variable Integer VALEUR

  If GAASAUTNUM  = 1
    # Si pas de numérotation automatique : pas possible de choisir nouveau numéro
     GMENLOC(GVML_NENONU)=1
  Endif
  If GAASAUTNUM   = 2
    # Si numérotation automatique obligatoire : pas possible de choisir aucun
    GMENLOC(GVML_NEAUCU)=1
  Endif
  If GAASAUTNUM   = 3
    # Si numérotation automatique facultative : tout est possible !
  Endif
  If len([F:FAS]AASREF)=20
    GMENLOC(GVML_NEADNU) = 1
    Raz [M:FASE]LIGINC
    Diszo [M:FASE]LIGINC
    Affzo [M:FASE]LIGINC
  Endif

  GMENLOC(GVML_NEINLI)=1 # poste du menu utilisé pour l'éclatement d'une dépense

End
#=====================================
# AM_ Type de numérotation
#=====================================
Subprog AM_TYPNUM(VALEUR)
Variable Integer VALEUR
Local Integer SIGM


If VALEUR <> [M:FASE]TYPNUM
  Disable GSTAOK
Endif

If VALEUR = GVML_NEAUCU  or VALEUR = GVML_NENONU
  Raz[M:FASE]LIGINC :  Diszo [M:FASE]LIGINC
Elsif VALEUR = GVML_NEADNU
  [M:FASE]LIGINC = 1
  Actzo [M:FASE]LIGINC
Endif

If VALEUR = GVML_NEADNU
   # controle de la taille des N°générés par incrément, par rapport à la taille de la zone AASREF
   For I = 1 To [M:FASE]NBFAS
     SIGM += [M:FASE]LIGINC
   Next I
   If len([M:OAC0]OBJREF)+len(num$(SIGM)) > 20
     GERR = 1
     #"Dépassement de capacité de la zone référence du bien comptable, Veuillez changer votre type de numérotation."
     GMESSAGE =mess(800,GML_MSGFAS,1)
     GERR=1 : mkstat=2 : End
   Endif
Endif

End
#=====================================
# AM_ Type de numérotation
#=====================================
Subprog AM_LIGINC(VALEUR)
Variable Decimal VALEUR

If VALEUR < 1
  GMESSAGE = mess(12,GML_MSGLOF,1) : # Incrément invalide
  GERR     = 1 :   mkstat   = 2 :   End
Endif

End
#=====================================
# AS_ Référence bien "fils"
#=====================================
Subprog AS_AASREF(VALEUR)
Variable Char    VALEUR()


If [M:FASE]TYPNUM = GVML_NEADNU
  mkstat = 2
Elsif [M:FASE]TYPNUM = GVML_NENONU
Endif

End
#=====================================
# AM_ Référence bien "fils"
#=====================================
Subprog AM_AASREF(VALEUR)
Variable Char    VALEUR()

Local Integer I

If G_HASELT=G_NON
  For I = 1 To [M:FASE]NBBCO
    If I <> nolign
      If [M:FASE]AASREF(I-1) = VALEUR
        # Cette référence a déjà  été saisie sur la ligne
        GMESSAGE = mess(19,GML_MSGLOF,1)-num$(I)
        GERR     = 1 :       mkstat   = 2 :       End
      Endif
    Endif
    #------------------------------
    # Suite de la boucle
  Next I
Else
  For I = 1 To [M:FASE]NBBCO
    If I <> nolign
      If [M:OCP1]AASREF(I-1) = VALEUR
        # Cette référence a déjà  été saisie sur la ligne
        GMESSAGE = mess(31,GML_MSGPHY,1)-num$(I)
        GERR     = 1
        mkstat   = 2
        End
      Endif
    Endif

  #------------------------------
  # Suite de la boucle
  Next I
Endif

Read [FAS]FAS0 = VALEUR
If fstat = 0
  # Cette référence existe déjà  dans la table
  If G_HASELT=G_NON
    GMESSAGE = mess(20,GML_MSGLOF,1)
  Else
    GMESSAGE = mess(32,GML_MSGPHY,1)-mess(33,GML_MSGPHY,1)
  Endif
  GERR     = 1 :   mkstat   = 2 :   End
Endif

  If G_HASELT=G_OUI
    [M:FASE]AASREF(nolign-1)=VALEUR
    If [M:FASE]SPLELT = GVMLTECLDEP or ([M:FASE]SPLELT = GVMLTECLELT and [M:FASE]NBFAS <> [M:OCP1]NBELT)
      For I=1 To [M:OCP1]NBLIG
        If [M:OCP1]NUMLIG(I-1)=nolign
          If VALEUR<>''
            [M:OCP1]AASREF(I-1)=VALEUR
          Else
            [M:OCP1]AASREF(I-1)='Bien n°'+num$(nolign)
          Endif
          Call ACTION_BLOCK (ACB_AFFZO, "FASSPL3", "NBLIG") From GLOBIENS
        Endif
      Next
      If !clalev([F:TPH]) :  Local File TMPFASPHY [TPH] Endif
      # FQ91070
      If dim(GFXDNBERR) < 0
        Trbegin [TPH]
      Endif
      GOK=1
      Read [TPH]TPH0=nolign
      If !fstat
        If VALEUR<>''
          [F:TPH]AASREF = VALEUR
        Else
          [F:TPH]AASREF = 'Bien n°'+num$(nolign)
        Endif
        Rewrite [F:TPH]
        # FQ91070
        If dim(GFXDNBERR) < 0
          If fstat
            Rollback
          Else
            Commit
          Endif
        Endif
      Endif
    Else
      [M:OCP1]AASREF(nolign-1)=VALEUR
      Call ACTION_BLOCK (ACB_AFFZO, "FASSPL3", "NBLIG") From GLOBIENS
    Endif
  Endif
  Call ACTION_BLOCK (ACB_AFFZO, "FASSPL1B", "NBBCO") From GLOBIENS
End
#=====================================
# AM_ Quantité bien "fils"
#=====================================
Subprog AM_AASQTY(VALEUR)
Variable Decimal VALEUR

Local Integer I
Local Decimal LQTY

If  [M:FASE]QTYSPL=G_OUI
  LQTY = VALEUR
  #FQ-61074For I = 1 To [M:FASE]NBFAS
  For I = 1 To [M:FASE]NBBCO
    If I <> nolign
      LQTY = LQTY + [M:FASE]AASQTY(I-1)
    Endif
    #------------------------------
    # Suite de la boucle
  Next I

  If [M:FASE]UOMDEC = 0
  # Si l'unité n'a pas de décimale : il doit rester 1 pour le bien d'origine
    If LQTY > [M:FASE]QTYBEF-1
      GMESSAGE = mess(794,GML_MSGFAS,1) : # Quantité invalide
      GERR     = 1 :       mkstat   = 2 :       End
    Endif
  Else
    # Si l'unité a des décimales : le solde doit être > 0
    If [M:FASE]QTYBEF <= LQTY
      GMESSAGE = mess(794,GML_MSGFAS,1) : # Quantité invalide
      GERR     = 1 :       mkstat   = 2 :       End
    Endif
  Endif
  #------------------------------
  [M:FASE]AASQTY(nolign-1) = VALEUR
  Call CALCUL_SOLDE ( )
Endif

End
#=====================================
# B1_ QUANTITE APRES éclatement
#=====================================
Subprog B1_AASQTY(VALEUR)
Variable Decimal VALEUR

 Local Integer I_NBCO
 For I_NBCO=nolign To [M:FASE]NBBCO
  [M:FASE]AASQTY(I_NBCO)=VALEUR
  Affzo [M:FASE]AASQTY(I_NBCO)
  Call AM_AASQTY([M:FASE]AASQTY(I_NBCO))
 Next I_NBCO

End
#=====================================
# AM_ Montant éclatement bien "fils"
#=====================================
Subprog AM_SPLAMT(VALEUR)
Variable Decimal VALEUR

Local Integer OK
Local Integer I
Local Decimal LMNT, ARRLMNT
Local Decimal LPRC #Fq-54343

# si montant d'origine < 0, le montant saisi doit l'être aussi
If [M:FASE]SPLAMTBEF < 0 and VALEUR > 0
   GMESSAGE = mess(17,GML_MSGLOF,1) : # Le signe du montant saisi est incorrect
   GERR     = 1 :   mkstat   = 2 :   End
Elsif [M:FASE]SPLAMTBEF > 0 and VALEUR < 0
   # si montant d'origine > 0, le montant saisi doit l'être aussi
   GMESSAGE = mess(17,GML_MSGLOF,1) : # Le signe du montant saisi est incorrect
   GERR     = 1 :   mkstat   = 2 :   End
Endif

# Si montant du bien d'origne <> 0 on signale si le bien éclaté est à  0
If [M:FASE]SPLAMTBEF <> 0
  If VALEUR = 0
    #Fq-90106 Call AVERTIR (mess(18,GML_MSGLOF,1), OK) From GESECRAN : # Le montant de la dépense est à  zéro
    #"Le montant du bien comptable est égal à zéro, confirmez-vous ?
    Call AVERTIR (mess(906,GML_MSGFAS,1), OK) From GESECRAN :
    If OK = 1
      GERR   = 1 :       mkstat = 2 :       End
    Endif
  Endif
Endif

LMNT = abs(VALEUR)
If G_HASELT=G_NON
  For I = 1 To [M:FASE]NBBCO
    If I <> nolign
      LMNT = LMNT + abs([M:FASE]SPLAMT(I-1))
    Endif
    #------------------------------
    # Suite de la boucle
  Next I
Else
  For I = 1 To [M:FASE]NBBCO
    If I <> nolign
      LMNT = LMNT + abs([M:OCP1]SPLAMT(I-1))
    Endif
    #------------------------------
    # Suite de la boucle
  Next I
Endif

If abs([M:FASE]SPLAMTBEF) <= LMNT
  GMESSAGE = mess(16,GML_MSGLOF,1) : # Montant invalide
  GERR     = 1 :   mkstat   = 2 :   End
Endif
#------------------------------
Call GET_MNT_ARRONDI (VALEUR ,GLOCALDEV, ARRLMNT) From GLOBIENS
[M:FASE]SPLAMT(nolign-1) = ARRLMNT
LPRC = ar2( ( [M:FASE]SPLAMT(nolign-1) /[M:FASE]SPLAMTBEF )* 100 )  #Fq-54343
[M:FASE]SPLPRC(nolign-1) = LPRC            #Fq-54343
Affzo [M:FASE]SPLPRC(nolign-1)             #Fq-54343

# FQ94737 ne pas appeler AM_SPLPRC et reporter le contrôle sur le total des % <= 100
# d'ailleurs ce contrôle semble inutile : celui au dessus le fait sur la somme des montants
#Call AM_SPLPRC([M:FASE]SPLPRC(nolign-1) )  #Fq-54343

If   [M:FASE]PRCFLG =G_OUI
   LPRC = 0
   For I = 1 To [M:FASE]NBFAS
      LPRC += [M:FASE]SPLPRC(I-1)
   Next I
   #
   If LPRC >= 100
      GMESSAGE = mess(795,GML_MSGFAS,1) : # pourcentage invalide
      GERR     = 1
      mkstat   = 2
      End
    Endif
Endif

If G_HASELT=G_OUI
  [M:OCP1]SPLAMT(nolign-1) = ARRLMNT
  Call ACTION_BLOCK (ACB_AFFZO, "FASSPL1B", "NBBCO") From GLOBIENS
Endif

# recalcul de l'ensemble des montants suite à la modification du montant
Call PRORATE_MONTANT (nolign)

Call CALCUL_SOLDE ( )
  If G_HASELT=G_OUI
    For I=[M:FASE]NBBCO+1 To [M:OCP1]NBLIG
      [M:OCP1]SPLAMT(I-1)=[M:FASE]SPLAMTAFT
      Call ACTION_BLOCK (ACB_AFFZO, "FASSPL3", "NBLIG") From GLOBIENS
    Next
  Endif

If [M:OCP]NBOBJ = 1
    Call ECLATEMENT_DEPENSE( )
Endif

End
#=========================================
# AM_ indicateur de sélection des dépenses
#=========================================
Subprog AM_SELFLG(VALEUR)
Variable Integer VALEUR

If ([M:FASE]NBFAS = [M:OCP]NBOBJ)  &  ([M:FASE]SPLBAS = GVML_TECLDEP)  & (VALEUR = G_OUI)
   #- "Vous ne devez pas cocher de dépense car nb éclatement = nb dépenses liées"
   GMESSAGE =  mess(515,GML_MSGFAS,1) : #"Vous ne devez pas cocher de dépense car nb éclatement = nb dépenses liées"
   GERR     = 1 :   mkstat   = 2 :   End
Endif

End

#=========================================
## C_date d'éclatement
#=========================================
Subprog C_MVTDAT(VALEUR)
Variable Date    VALEUR

 #=> la date d'éclatement doit être postérieure au début d'exercice courant de tous les contexte de la société
 Local Date    CPYSTRFIY(1..G300MAX)
 Local Date    CPYENDFIY(1..G300MAX)
 Local Date    CPYSTRPER(1..G300MAX)
 Local Date    CPYENDPER(1..G300MAX)
 Local Integer RETOUR
 Local Integer I_CPY
 Local Integer I_CNX
 Local Integer NBR_CPY

 NBR_CPY=1

 If !(NBR_CPY=0)

  Local Char TAB_CPY(3)(NBR_CPY)
  Local Date LIMDAT
  TAB_CPY(0)=[M:FAS0]CPY
  For I_CPY=1 To NBR_CPY

   # Appel du sous-pro d'alimentation des dates
   Call GET_CPY_DAT(TAB_CPY(I_CPY-1),CPYSTRFIY,CPYENDFIY,CPYSTRPER,CPYENDPER,RETOUR) From GLOBIENS
   For I_CNX=1 To G300MAX
    If CPYSTRFIY(I_CNX)<>[0/0/0] & VALEUR<CPYSTRFIY(I_CNX)
     If CPYSTRFIY(I_CNX)>LIMDAT
      LIMDAT=CPYSTRFIY(I_CNX)
     Endif
     # La date d'éclatement doit être >= à la date de début d'exercice courant de chacun des contextes de la société
     GERR=1 : GMESSAGE=mess(435,GML_MSGFAS,1)
    mkstat=2
    Endif
   Next I_CNX
  Next I_CPY
 Endif

End
######################################################################################
Subprog C_NBFAS(VALEUR)
Variable Decimal VALEUR
End
######################################################################################
Subprog C_SPLELT(VALEUR)
Variable Integer VALEUR
Local Integer NBECLAT


  NBECLAT = G_NBFASFIN
  If G_NBFASFIN<[M:OCP1]NBELT
    NBECLAT +=1
  Endif

  Case VALEUR
    When GVMLTECLELT             :  Actzo [M:FASE]NBFAS
    When GVMLTECLMVT,GVMLTECLDEP :  Diszo [M:FASE]NBFAS
    When Default
  Endcase


  If VALEUR=GVMLTECLMVT and G_NBFASFIN=0
    GERR=1
    GMESSAGE=mess(23,GML_MSGPHY,1)
    [M:FASE]SPLELT=GVMLTECLELT
    Affzo [M:FASE]SPLELT
    mkstat=2
  Endif

  If VALEUR=GVMLTECLDEP and [M:OCP]NBOBJ<2
    GERR=1
    GMESSAGE=mess(35,GML_MSGPHY,1)
    [M:FASE]SPLELT=GVMLTECLELT
    Affzo [M:FASE]SPLELT
    mkstat=2
  Endif

End
######################################################################################
Subprog AP_SPLAMTTYPB(VALEUR)
Variable Integer VALEUR

  Case VALEUR
    When GVML_VENTPCG  : [M:FASE]SPLAMTBEF  = [M:FAS1]ACGETRNOT : [M:OCP1]SPLAMTBEF  = [M:FAS1]ACGETRNOT
    When GVML_VENTIAS  : [M:FASE]SPLAMTBEF  = [M:FAS1]IASETRNOT : [M:OCP1]SPLAMTBEF  = [M:FAS1]IASETRNOT
    When GVML_VBILPCG  : [M:FASE]SPLAMTBEF  = [M:FAS1]ACGBSEVAL : [M:OCP1]SPLAMTBEF  = [M:FAS1]ACGBSEVAL
    When GVML_VBILIAS  : [M:FASE]SPLAMTBEF  = [M:FAS1]IASBSEVAL : [M:OCP1]SPLAMTBEF  = [M:FAS1]IASBSEVAL
    When GVML_VBRPCG
      For I = 1 To [M:FAS3]NBLIG1
        If [M:FAS3]DPRPLN(I-1) = G301CPT
          [M:FASE]SPLAMTBEF  = [M:FAS3]DPRBAS(I-1)
          [M:OCP1]SPLAMTBEF  = [M:FAS3]DPRBAS(I-1)
          Break
        Endif
      Next I
    When GVML_VBRIAS
      For I = 1 To   [M:FAS3]NBLIG1
        If [M:FAS3]DPRPLN(I-1) = G301IAS
          [M:FASE]SPLAMTBEF  = [M:FAS3]DPRBAS(I-1)
          [M:OCP1]SPLAMTBEF  = [M:FAS3]DPRBAS(I-1)
          Break
        Endif
      Next I
    When Default
      [M:FASE]SPLAMTBEF  = [M:FAS1]ACGETRNOT
      [M:OCP1]SPLAMTBEF  = [M:FAS1]ACGETRNOT
      If [M:FAS1]ACGETRNOT<> 0
        [M:FASE]SPLAMTBEF  = [M:FAS1]ACGETRNOT
        [M:OCP1]SPLAMTBEF  = [M:FAS1]ACGETRNOT
      Else
        If [M:FAS1]IASETRNOT <> 0
          [M:FASE]SPLAMTBEF  = [M:FAS1]IASETRNOT
          [M:OCP1]SPLAMTBEF  = [M:FAS1]IASETRNOT
        Endif
      Endif
  Endcase
  Affzo[M:FASE]SPLAMTBEF
  Affzo[M:OCP1]SPLAMTBEF

#*Fq-67530 If G_HASELT <> G_OUI  #Fq-52661
#*Fq-67530  If [M:FASE]SPLAMTBEF = 0
#*Fq-67530    # "type d'éclatement invalide car montant nul"
#*Fq-67530    GERR=1 : GMESSAGE=mess(26,GML_MSGPHY,1)
#*Fq-67530    mkstat=2
#*Fq-67530    End
#*Fq-67530  Endif     #Fq-52661
#*Fq-67530Endif
End
######################################################################################
Subprog AM_SPLAMTTYPB(VALEUR)
Variable Integer VALEUR
Local Integer I

  If VALEUR <> [M:FASE]SPLAMTTYPB
    Disable GSTAOK
  Endif

  Case VALEUR
    When GVML_VENTPCG  : [M:FASE]SPLAMTBEF  = [M:FAS1]ACGETRNOT : [M:OCP1]SPLAMTBEF  = [M:FAS1]ACGETRNOT
    When GVML_VENTIAS  : [M:FASE]SPLAMTBEF  = [M:FAS1]IASETRNOT : [M:OCP1]SPLAMTBEF  = [M:FAS1]IASETRNOT
    When GVML_VBILPCG  : [M:FASE]SPLAMTBEF  = [M:FAS1]ACGBSEVAL : [M:OCP1]SPLAMTBEF  = [M:FAS1]ACGBSEVAL
    When GVML_VBILIAS  : [M:FASE]SPLAMTBEF  = [M:FAS1]IASBSEVAL : [M:OCP1]SPLAMTBEF  = [M:FAS1]IASBSEVAL
    When GVML_VBRPCG
      For I = 1 To   [M:FAS3]NBLIG1
        If [M:FAS3]DPRPLN(I-1) = G301CPT
          [M:FASE]SPLAMTBEF  = [M:FAS3]DPRBAS(I-1)
          [M:OCP1]SPLAMTBEF  = [M:FAS3]DPRBAS(I-1)
          Break
        Endif
      Next I
    When GVML_VBRIAS
      For I = 1 To   [M:FAS3]NBLIG1
        If [M:FAS3]DPRPLN(I-1)  = G301IAS
          [M:FASE]SPLAMTBEF  = [M:FAS3]DPRBAS(I-1)
          [M:OCP1]SPLAMTBEF  = [M:FAS3]DPRBAS(I-1)
          Break
        Endif
      Next I
    When Default
  Endcase

  Affzo[M:FASE]SPLAMTBEF
  Affzo[M:OCP1]SPLAMTBEF

  #Fq-60516 If [M:FASE]SPLAMTBEF <= 0
  If [M:FASE]SPLAMTBEF = 0
    # "Type d'éclatement invalide car montant nul"
    GERR=1 : GMESSAGE= mess(26,GML_MSGPHY,1)
    mkstat=2
    End
  Endif

End

######################################################################################
Subprog AM_SPLELT(VALEUR)
Variable Integer VALEUR

If VALEUR <> [M:FASE]SPLELT
  Disable GSTAOK
  Raz [M:FASE]QTYAFT
  Raz [M:FASE]SPLAMTAFT
  Affzo [M:FASE]QTYAFT
  Affzo [M:FASE]SPLAMTAFT
  #*FQ-61132
  If VALEUR =GVMLTECLMVT
    If G_NBFASFIN < [M:OCP1]NBELT
       [M:FASE]NBFAS  = G_NBFASFIN+1
    Else
       [M:FASE]NBFAS  = G_NBFASFIN
    Endif
    Affzo  [M:FASE]NBFAS
  Else
    If    VALEUR = GVMLTECLELT
     [M:FASE]NBFAS  =  [M:OCP1]NBELT
      Affzo  [M:FASE]NBFAS
    Endif
  Endif   #*FQ-61132
Endif

End
######################################################################################
Subprog AM_AASDES1(VALEUR)
Variable Char    VALEUR()
End
######################################################################################
Subprog AM_SPLPRC(VALEUR)
Variable Decimal VALEUR

Local Integer OK
Local Integer I
Local Decimal LMNT, ARRLMNT, LPRC

If   [M:FASE]PRCFLG =G_OUI
   LPRC = VALEUR
   For I = 1 To [M:FASE]NBFAS
      If I <> nolign
         LPRC  = LPRC  + [M:FASE]SPLPRC(I-1)
      Endif
      #------------------------------
      # Suite de la boucle
   Next I
   #
   If LPRC >= 100
      GMESSAGE = mess(795,GML_MSGFAS,1) : # pourcentage invalide
      GERR     = 1 :       mkstat   = 2 :       End
    Endif
Endif

If VALEUR <> [M:FASE]SPLPRC(nolign-1) or dim(GFXDNBERR) >= 0 # FQ91070 ajout du or pour forcer le passage en itf des mvts
   #FI-608[M:FASE]SPLAMT(nolign-1)= ([M:FASE]SPLAMTBEF * VALEUR)/100
   [M:FASE]SPLAMT(nolign-1)= ar2(([M:FASE]SPLAMTBEF * VALEUR)/100)
   Affzo [M:FASE]SPLAMT(nolign-1)
   # recalcul de l'ensemble des montants suite à la modification du montant
   Call PRORATE_MONTANT (nolign)

   Call CALCUL_SOLDE ( )
   If G_HASELT=G_OUI
      For I=[M:FASE]NBBCO+1 To [M:OCP1]NBLIG
        [M:OCP1]SPLAMT(I-1)=[M:FASE]SPLAMTAFT
        Call ACTION_BLOCK (ACB_AFFZO, "FASSPL3", "NBLIG") From GLOBIENS
      Next
    Endif

   If [M:OCP]NBOBJ = 1
     Call ECLATEMENT_DEPENSE( )
   Endif
Endif

End

######################################################################################
## Fq-54343
######################################################################################
Subprog AM_PRCFLG(VALEUR)
Variable Integer VALEUR

Local Integer I

If [M:FASE]PRCFLG <> G_OUI and  VALEUR = G_OUI
  For I = 1 To [M:FASE]NBBCO
     If [M:FASE]AASREF(I-1) <> ""
         Actzo [M:FASE]SPLPRC(I-1)
         Affzo [M:FASE]SPLPRC(I-1)
    Endif
  Next I
Endif

End
