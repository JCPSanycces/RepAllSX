Variable Decimal VALEUR

If VALEUR <=0 or VALEUR >= 100
   # Pourcentage invalide
   GMESSAGE = mess(796,GML_MSGFAS,1)
   GERR     = 1 :       mkstat   = 2 :       End
Endif

End
