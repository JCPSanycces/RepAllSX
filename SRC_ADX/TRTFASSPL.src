######################################################################################
##*FQ-92254
######################################################################################
Subprog C_LOFSPLFLG(VALEUR)
Variable Integer VALEUR

## Interdiction éclatement par qté ou montant si plusieurs dépenses rattachées
## et au-moins une dépense rattachée est subventionnée
If ( VALEUR = G_OUI ) : End  : Endif

 If ([M:FASE]SPLBAS = GVML_TECLQTY) or ([M:FASE]SPLBAS = GVML_TECLAMT)
   If  [M:OCP]NBOBJ  > 1
      # boucle sur les dépenses rattachées
      For I_OBJ =  1 To [M:OCP]NBOBJ
         Read [LOF]LOF0 =[M:OCP]CODLOF(I_OBJ-1);[M:OCP]LINLOF(I_OBJ-1)
         If [F:LOF]PLNINV <> "" & [F:LOF]FLGGRA = G_OUI
             GMENLOC(GVML_TECLQTY)=1
             GMENLOC(GVML_TECLAMT)=1
             # "éclatement par qté ou  montant impossible car une dépense est subventionnée "
             GERR=1  : GMESSAGE= mess(558,GML_MSGFAS,1) : mkstat=2
             Break
         Endif
      Next I_OBJ
   Endif
Endif

End
