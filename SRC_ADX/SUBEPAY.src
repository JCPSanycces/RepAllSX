Subprog D_INI(VALEUR)
Variable Char    VALEUR()
If GFONCTION='GESVEP' : End : Endif

[M]ALLCPY = 2
[M]ALLFCY = 2
[M]ALLSRV = 2
[M]ALLPRF = 2
Call D_INI(VALEUR) From DIVPAYE
Affzo [M]ALLPRF,ALLSRV
End


