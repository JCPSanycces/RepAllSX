# Issue X3-77407 - 2018-03-01 by CCC : Manage preloading of classes & representations
# Classes
Local File =DOSSIER+".ACLASSE"    [ACLA]
&         ,=DOSSIER+".ACLAFLD"    [ACLAF]
&         ,=DOSSIER+".ACLAMET"    [ACLAM]
&         ,=DOSSIER+".ACLAMETSTD" [ACLAT]
&         ,=DOSSIER+".ACLALNK"    [ACLAK]
&         ,=DOSSIER+".ACLAOPT"    [ACLAO]
&         ,=DOSSIER+".ACLACOL"    [ACLAC]

Link [ACLA] With [ACLAF]ACLAF0(1)=[F:ACLA]CODCLA,
&                [ACLAM]ACLAM0(1)=[F:ACLA]CODCLA,
&                [ACLAT]ACLAT0(1)=[F:ACLA]CODCLA,
&                [ACLAK]ACLAK0(1)=[F:ACLA]CODCLA,
&                [ACLAO]ACLAO0(1)=[F:ACLA]CODCLA,
&                [ACLAC]ACLAC0(1)=[F:ACLA]CODCLA
&           As [LNK]
&           Where find([L]ACTIV,[F:ACLA]CODACT,[F:ACLA]ACTTRT)<>0
&               | [F:ACLAF]ACTFLD   =[L]ACTIV
&               | [F:ACLAM]ACTMET   =[L]ACTIV
&               | [F:ACLAT]ACTMETSTD=[L]ACTIV
&               | [F:ACLAK]ACVLNK   =[L]ACTIV
&               | [F:ACLAO]OPTACT   =[L]ACTIV
&               | [F:ACLAC]ACTCOL   =[L]ACTIV
&           Order By Key KLNK=[F:ACLA]CODCLA

Columns [LNK] ([F:ACLA]CODCLA, [F:ACLA]CODTRT, [F:ACLA]INTCLA)
For [LNK]KLNK(1)
    Raz TRAITE, TRAITV
    OBJET   = "ACLA"
    NOM     = [F:ACLA]CODCLA
    Call TEXTE([F:ACLA]INTCLA,INTITULE) From OBJDIV
    Gosub EXTOBJ
    If !OK : Break : Endif
    For NTRT=0 To dim([F:ACLA]CODTRT)-1
        If [F:ACLA]CODTRT(NTRT)=""
            Break
        Endif
        TRAITE = [F:ACLA]CODTRT(NTRT)
        Gosub TRAITE
        If !OK : Break 2 : Endif
    Next
Next
Columns [LNK]
LogicClose File [ACLA], [ACLAF], [ACLAM], [ACLAT], [ACLAK], [ACLAO], [ACLAC]
If !OK : Return : Endif

# Representations
Local File =DOSSIER+".ASHW"       [ASW]
&         ,=DOSSIER+".ASHWFLD"    [ASWF]
&         ,=DOSSIER+".ASHWOPT"    [ASWO]
&         ,=DOSSIER+".ASHWCOL"    [ASWC]
&         ,=DOSSIER+".ASHWSEC"    [ASWS]
&         ,=DOSSIER+".ASHWBLC"    [ASWB]
&         ,=DOSSIER+".ASHWMET"    [ASWM]
&         ,=DOSSIER+".ASHWEXPPRO" [ASWR]
&         ,=DOSSIER+".ASHWLNK"    [ASWK]
&         ,=DOSSIER+".ASHWMENU"   [ASWMN]

Link [ASW] With [ASWF]ASWF0(1)=[F:ASW]CODREP,
&               [ASWO]ASWO0(1)=[F:ASW]CODREP,
&               [ASWC]ASWC0(1)=[F:ASW]CODREP,
&               [ASWS]ASWS0(1)=[F:ASW]CODREP,
&               [ASWB]ASWB0(1)=[F:ASW]CODREP,
&               [ASWM]ASWM0(1)=[F:ASW]CODREP,
&               [ASWR]ASWR0(1)=[F:ASW]CODREP,
&               [ASWK]ASWK0(1)=[F:ASW]CODREP,
&               [ASWMN]ASWMN0(1)=[F:ASW]CODREP
&           As [LNK]
&           Where find([L]ACTIV,[F:ASW]CODACT,[F:ASW]ACTTRT,[F:ASW]ACTLNKFAC)<>0
&               | [F:ASWF]ACTFLD   =[L]ACTIV
&               | [F:ASWO]OPTACT   =[L]ACTIV
&               | [F:ASWC]ACTCOL   =[L]ACTIV
&               | [F:ASWS]ACTSEC   =[L]ACTIV
&               | [F:ASWB]ACTBLC   =[L]ACTIV
&               | [F:ASWM]ACTMET   =[L]ACTIV
&               | [F:ASWR]ACTPRO   =[L]ACTIV
&               | [F:ASWK]ACVLNK   =[L]ACTIV
&               | [F:ASWMN]ACTMENU =[L]ACTIV
&           Order By Key KLNK=[F:ASW]CODREP

Columns [LNK] ([F:ASW]CODREP, [F:ASW]CODTRT, [F:ASW]INTREP)
For [LNK]KLNK(1)
    Raz TRAITE, TRAITV
    OBJET   = "ASW"
    NOM     = [F:ASW]CODREP
    Call TEXTE([F:ASW]INTREP,INTITULE) From OBJDIV
    Gosub EXTOBJ
    If !OK : Break : Endif
    For NTRT=0 To dim([F:ASW]CODTRT)-1
        If [F:ASW]CODTRT(NTRT)=""
            Break
        Endif
        TRAITE = [F:ASW]CODTRT(NTRT)
        Gosub TRAITE
        If !OK : Break 2 : Endif
    Next
Next
Columns [LNK]
LogicClose File [ASW], [ASWF], [ASWO], [ASWC], [ASWS], [ASWB], [ASWM], [ASWR], [ASWK], [ASWMN]
If !OK : Return : Endif

ACTIONX = "EXTOBJ" : Gosub ACTION_PRODUIT

If filinfo(filpath("FIL","ABIDATMRT","fde",[M]DOSSIER),0)>=0

 ### BI datamart
 For [ABM]ABM0 Where CODACT = [L]ACTIV
  OBJET = "ABM"
  NOM   = [F:ABM]COD
  Call TEXTE([F:ABM]INTIT,INTITULE) From OBJDIV
  Gosub EXTOBJ : If !OK : Break : Endif
 Next
 If !OK : Return : Endif

 ## BI table de fait
 For [ABF]ABF0 Where CODACT=[L]ACTIV
  OBJET = "ABF"
  NOM   = [F:ABF]CODABF
  Call TEXTE([F:ABF]INTIT,INTITULE) From OBJDIV
  Gosub EXTOBJ : If !OK : Break : Endif
 Next
 If !OK : Return : Endif
 For [ABZ]ABZ1(1) Where ACTFLD=[L]ACTIV
  OBJET = "ABF"
  NOM   = [F:ABZ]CODABF
  Call CONTROLE("ABF","",NOM,"",mkstat) From CONTOBJ
  If !fstat : Call TEXTE([F:ABF]INTIT,INTITULE) From OBJDIV  : Endif
  Gosub EXTOBJ : If !OK : Break : Endif
 Next
 If !OK : Return : Endif

## BI Dimesions
 For [ABI]ABI0 Where CODACT=[L]ACTIV
  OBJET = "ABI"
  NOM   = [F:ABI]CODDIM
  Call TEXTE([F:ABI]INTIT,INTITULE) From OBJDIV
  Gosub EXTOBJ : If !OK : Break : Endif
 Next
 If !OK : Return : Endif
 For [ABJ]ABJ1(1) Where ACTDIM=[L]ACTIV
  OBJET = "ABI"
  NOM   = [F:ABJ]CODDIM
  Call CONTROLE("ABI","",NOM,"",mkstat) From CONTOBJ
  If !fstat : Call TEXTE([F:ABI]INTIT,INTITULE) From OBJDIV  : Endif
  Gosub EXTOBJ : If !OK : Break : Endif
 Next
 If !OK : Return : Endif

 ### BI condition predefini
 For [AII]AII0 Where ACV = [L]ACTIV
  OBJET = "AII"
  NOM   = [F:AII]COD
  Call TEXTE([F:AII]DES,INTITULE) From OBJDIV
  Gosub EXTOBJ : If !OK : Break : Endif
 Next
 If !OK : Return : Endif

 ### BI hierarchie
 For [AHH]AHH0 Where ACV = [L]ACTIV
  OBJET = "AHH"
  NOM   = [F:AHH]COD
  Call TEXTE([F:AHH]DES,INTITULE) From OBJDIV
  Gosub EXTOBJ : If !OK : Break : Endif
 Next
 If !OK : Return : Endif

 ### BI etat BO
 For [ABO]ABO0 Where ACV = [L]ACTIV
  OBJET = "ABO"
  NOM   = [F:ABO]COD
  Call TEXTE([F:ABO]DES,INTITULE) From OBJDIV
  Gosub EXTOBJ : If !OK : Break : Endif
 Next
 If !OK : Return : Endif

 ### BI regle de synchro
 For [ABV]ABV0 Where CODACT = [L]ACTIV
  OBJET = "ABV"
  NOM   = [F:ABV]CODREG
  Call TEXTE([F:ABV]INTIT,INTITULE) From OBJDIV
  Gosub EXTOBJ : If !OK : Break : Endif
 Next
 If !OK : Return : Endif
Endif

# Autres tables
For [ATZ]CODTYP Where CODTYP="ACV"
 If !find([F:ATZ]CODFIC,"ATABLE",  "ATABZON",  "ATABIND","AMSK",     "AMSKZON","AOBJET", "AOBJTAB"
&                      ,"AWINDOW", "AWINBOUT", "AWINBRO","AFONCTION","ACTION", "ATYPE","ATYPEPRO",  "AREPORT"
&                      ,"ACONSULT","AMENLOC",  "AENTREE","ACTIV",    "ADOSACT","ADOPAR", "ATABTAB"
&                      ,"ASUBPROG","ADOCUMENT","ADOCFNC","AURL",     "AVIEW",  "AVIEWD", "AGLOBVAR"
&                      ,"ADICTRT", "ANAVIG",   "AWRKLNK","AHISTO",   "AOBJEXT","ACTL"
&                      ,"ACLASSE", "ACLAFLD",  "ACLAMET","ACLAMETSTD","ACLALNK","ACLAOPT","ACLACOL"
&                      ,"ASHW","ASHWFLD","ASHWOPT","ASHWCOL","ASHWSEC","ASHWBLC","ASHWMET","ASHWEXPPRO","ASHWLNK","ASHWMENU"
&                      ,"ATRANSAC","ABIDATMRT","ABITABFLD","ABITABDAT","ABICOND","ABIHIERA","ABIDIM"
&                      ,"ABIDIMFLD","ABIREPORT","ABIREGORG")
  Read [ATB]CODFIC    = [F:ATZ]CODFIC
  Read [ATI]NUMLIG(1) = [F:ATZ]CODFIC
  CHAINE = [F:ATI]DESCRIPT
  NBCLE  = 0
  While CHAINE<>""
   NBCLE += 1
   I1 = instr(1,CHAINE,"+")
   I2 = instr(1,CHAINE,"-")
   If    I1 & I2  : I1 = min(I1,I2)
   Elsif I2 & !I1 : I1 = I2
   Endif
   If I1
    CLEF(NBCLE) = left$(CHAINE,I1-1)
    CHAINE      = right$(CHAINE,I1+1)
   Else
    CLEF(NBCLE) = CHAINE
    CHAINE      = ""
   Endif
  Wend
  If [F:ATB]TYPFIC=3 : # cll
   Local File =GDOSX3+"."+[F:ATB]CODFIC [AAA_]
  Else
   Local File =[M]DOSSIER+"."+[F:ATB]CODFIC [AAA_]
  Endif
  CRITFIC = [F:ATZ]CODZONE+'="'+[L]ACTIV+'"'
  For [AAA_] Where evalue(CRITFIC)
   OBJET = [F:ATB]ABRFIC
   NOM   = ""
   For J=1 To NBCLE
    If J>1 : NOM -= '&' : Endif
    NOM -= CLEF(J)+"="
    Case evalue("type([F:AAA_]"+CLEF(J)+")")
     When 1,2,4,5,6,7,8,9 : NOM += num$(evalue("[F:AAA_]"+CLEF(J)))
     When 3               : NOM += "["+format$(GFMD,evalue("[F:AAA_]"+CLEF(J)))+"]"
     When Default         : NOM += '"'+evalue("[F:AAA_]"+CLEF(J))+'"'
    Endcase
   Next
   NOM = vireblc(NOM,2)
   Gosub EXTOBJ : If !OK : Break : Endif
  Next
  Close Local File [AAA_]
  If !OK : Break : Endif : # CCL 115030
 Endif
Next
Return

$EXTOBJ
OK = 1
If !find(OBJET-NOM,CLE(0..I-1))

 [M]TYPOBJ(I) = OBJET
 [M]NOMOBJ(I) = NOM
 [M]INTITOBJ(I) = INTITULE
 CLE(I) = OBJET-NOM
 I += 1
 If I>=dim([M]NOMOBJ)
  OK = 0
 Elsif TRAITE<>""
  Gosub TRAITE
  If OK & TRAITV<>""
   TRAITE = TRAITV
   Gosub TRAITE
   TRAITV = ""
  Endif
 Endif
Endif
Raz [L]INTITULE
Return

$TRAITE
OK = 1
If filinfo(filpath("TRT",TRAITE,"src",[M]DOSSIER),0)>=0
 If !find("TRT"-TRAITE,CLE(0..I-1))
  [M]TYPOBJ(I) = "TRT"
  [M]NOMOBJ(I) = TRAITE
  Read [ADC]ADC0 = TRAITE
  If !fstat : [M]INTITOBJ(I) = [F:ADC]DES : Endif
  CLE(I) = [M]TYPOBJ(I)-[M]NOMOBJ(I)
  I += 1
  If I>=dim([M]NOMOBJ) : OK = 0 : Endif
 Endif
Endif
TRAITE = ""
Return

Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP, VALEUR,[M]FICPATCH,E_TYPE_FILEOVERWRITE,GMESSAGE)
End

Subprog AM_VOLFIL(VALEUR)
Variable Char    VALEUR()
Local Char    FICHIER(GDIMFIC)
Local Integer OK
If filinfo([M]FICPATCH,0)>=0 & ([M]NBOBJ=0)
 Call OUINON(mess(47,115,1),OK) From GESECRAN : # Chargement objets
 If OK=2 : [L]FICHIER = [M]FICPATCH : Gosub CHARGE : Endif
Endif
GFICPATH = VALEUR
End

