    OBJET = "ACD"
    OPTIONS = "#"
   When "TFO"
    Local File =[L]DOSSIER+".TABFOR" [TFO]
    OBJET = "TFO"
   When "ETA"
   When "TRT"
   When "TXT"
    If left$(VALEUR,1)='"' or left$(VALEUR,1)="'"
     FIC = seg$(VALEUR,2,len(VALEUR)-1)
    Else
     FIC = VALEUR
    Endif
    If filinfo(filpath("TXT",VALEUR,"txt",[L]DOSSIER),0)<0
     GMESSAGE = filpath("TXT",VALEUR,"txt",[L]DOSSIER)-mess(101,100,1) : mkstat = 2 : # Fichier inexistant
    Endif
   When "IND"
    Local File =[L]DOSSIER+".ATEXTE" [ITX_]
   When Default
    ACTIONX = "SEL_TABLE" : Gosub ACTION_PRODUIT
  Endcase
Endcase
