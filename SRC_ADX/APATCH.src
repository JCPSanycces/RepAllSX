$ER
ER = errn
ME = errm
Resume

$SEL_PATTERN
Gosub SELFICPAT From SUBARZ
Return

$SEL_BIAR
If filinfo(filpath("BI","","",[L]DOSSIER),0)<0
 Return
Endif
Local Char    WNAM(50)(1..GNBSEL)
Local Char    ORDSYS(250)
Local Integer NBFIC , I
Local File   (Char NAM(50)) From   Variable WNAM As [FIC]
NBCOL = 1
COL(NBCOL) = "[F:FIC]NAM"
COLTYP(NBCOL) = type([F:FIC]NAM)
ORDSYS = "lsadx -a"-[L]DOSSIER-"BI biar"
Call SYSTEME2(adxmac(0),ORDSYS,"",NBFIC,WNAM) From ORDSYS
NBFIC = min(NBFIC,dim(WNAM))
For I=NBFIC+1 To dim(WNAM)
 WNAM(I) = chr$(255)
Next I
adxmxl = NBFIC
TIT(0) = mess(83,148,1) : # Objets biar
ORDRE = "NAM"
Default File [FIC]
Return

$SEL_ELT
Local Integer MAXFIC
MAXFIC = 1000
Local Char    WUSR(GLONAUS)(1..MAXFIC) , WTIM(10)(1..MAXFIC) , WREP(80)(1..MAXFIC) , WNAM(40)(1..MAXFIC)
Local Date    WDAT(1..MAXFIC)
Local Integer WTAI(1..MAXFIC)
Local Char    CHEMIN(GDIMFIC) , ORDSYS(80)(1..2) , FICHIER(GDIMFIC) , NAMEFIC(40) , APPLI(GLONADS)
Local Integer I , J , K , L , M , R , NBFIC , STA , NIV
Local Integer NBREP0 , NBREP1 , NBREP2 , NBREP3 , NBREP4
Local Char    REP0(80)(1..1000) , REP1(80)(1..1000) , REP2(80)(1..1000) , REP3(80)(1..1000)
Local Char    REP4(80)(1..1000)
Local Char    UTIL(GLONAUS) , NOM(GLONDES) , HREMOD(GLONHS)
Local Decimal TAILLE
Local Date    DATMOD
Local Char    TIT(50)(0..10)
Local Char    REPBASE(GDIMFIC) , SOUSREP(GDIMFIC)(1..9)
Local File   (Char USR(GLONAUS) , Date DAT , Char TIM(10) , Char REP(80) , Integer TAI , Char NAM(40))
&     From   Variable WUSR , WDAT , WTIM , WREP , WTAI , WNAM As [FIC]
NBCOL  = 1 : COL(NBCOL) = "[F:FIC]NAM" : COLTYP(NBCOL) = type([F:FIC]NAM) : TIT(NBCOL) = mess(4,95,1)
NBCOL += 1 : COL(NBCOL) = "[F:FIC]USR" : COLTYP(NBCOL) = type([F:FIC]USR) : TIT(NBCOL) = mess(37,133,1)
NBCOL += 1 : COL(NBCOL) = "[F:FIC]DAT" : COLTYP(NBCOL) = type([F:FIC]DAT) : TIT(NBCOL) = mess(3,11,1)
NBCOL += 1 : COL(NBCOL) = "[F:FIC]TIM" : COLTYP(NBCOL) = type([F:FIC]TIM) : TIT(NBCOL) = mess(91,134,1)
NBCOL += 1 : COL(NBCOL) = "[F:FIC]TAI" : COLTYP(NBCOL) = type([F:FIC]TAI) : TIT(NBCOL) = mess(52,125,1)
NBCOL += 1 : COL(NBCOL) = "[F:FIC]REP" : COLTYP(NBCOL) = type([F:FIC]REP) : TIT(NBCOL) = mess(37,139,1)
APPLI      = GDOSX3
REPBASE    = "X3_PUB"
SOUSREP(1) = "X3_ROOT/XSL"
SOUSREP(2) = "ADX_PORTAL/Archives"
SOUSREP(3) = "X3_ROOT/RESSTD"
SOUSREP(4) = "X3_ROOT/RESVER"
SOUSREP(5) = "X3_ROOT/RESPER"
SOUSREP(6) = "X3_ROOT/X3CLI"
SOUSREP(7) = "X3_ROOT/GEN/ALL/LIB"
SOUSREP(8) = "X3_ROOT/GEN/FRA/LIB"
SOUSREP(9) = "X3_CLIENT"
NBFIC = 0
For R=1 To dim(SOUSREP)
 CHEMIN = filpath(SOUSREP(R),"","",REPBASE)
 ORDSYS = "lsadx -a"-APPLI-CHEMIN
 Call SYSTEME2(adxmac(0),ORDSYS,"",NBREP0,REP0) From ORDSYS
 For I=1 To NBREP0
  If !find(REP0(I),".","..")
   NAMEFIC = REP0(I)
   FICHIER = SOUSREP(R)+"/"+NAMEFIC
   CHEMIN  = filpath(FICHIER,"","",REPBASE)
   Call EXISTE(CHEMIN,STA) From ORDSYS
   Case STA
    When 1
     If find(R,1,2) | (find(R,7,8) & left$(NAMEFIC,4)="ADX_") | right$(CHEMIN,len(CHEMIN)-3)=".tar"
&                   | (R=6 & tolower(left$(NAMEFIC,3))="ide")
      If NBFIC+1>MAXFIC : Break 2 : Endif
      Gosub ADDFIC
     Endif
    When 2
     If R<=2
      ORDSYS = "lsadx -a"-APPLI-CHEMIN
      Call SYSTEME2(adxmac(0),ORDSYS,"",NBREP1,REP1) From ORDSYS
      For J=1 To NBREP1
       If !find(REP1(J),".","..")
        NAMEFIC = REP1(J)
        FICHIER = SOUSREP(R)+"/"+REP0(I)+"/"+NAMEFIC
        CHEMIN  = filpath(FICHIER,"","",REPBASE)
        Call EXISTE(CHEMIN,STA) From ORDSYS
        Case STA
         When 1
          If NBFIC+1>MAXFIC : Break 3 : Endif
          Gosub ADDFIC
         When 2
          ORDSYS = "lsadx -a"-APPLI-CHEMIN
          Call SYSTEME2(adxmac(0),ORDSYS,"",NBREP2,REP2) From ORDSYS
          For K=1 To NBREP2
           If !find(REP2(K),".","..")
            NAMEFIC = REP2(K)
            FICHIER = SOUSREP(R)+"/"+REP0(I)+"/"+REP1(J)+"/"+NAMEFIC
            CHEMIN  = filpath(FICHIER,"","",REPBASE)
            Call EXISTE(CHEMIN,STA) From ORDSYS
            Case STA
             When 1
              If NBFIC+1>MAXFIC : Break 4 : Endif
              Gosub ADDFIC
             When 2
              ORDSYS = "lsadx -a"-APPLI-CHEMIN
              Call SYSTEME2(adxmac(0),ORDSYS,"",NBREP3,REP3) From ORDSYS
              For L=1 To NBREP3
               If !find(REP3(L),".","..")
                NAMEFIC = REP3(L)
                FICHIER = SOUSREP(R)+"/"+REP0(I)+"/"+REP1(J)+"/"+REP2(K)+"/"+NAMEFIC
                CHEMIN  = filpath(FICHIER,"","",REPBASE)
                Call EXISTE(CHEMIN,STA) From ORDSYS
                Case STA
                 When 1
                  If NBFIC+1>MAXFIC : Break 5 : Endif
                  Gosub ADDFIC
                 When 2
                  ORDSYS = "lsadx -a"-APPLI-CHEMIN
                  Call SYSTEME2(adxmac(0),ORDSYS,"",NBREP4,REP4) From ORDSYS
                  For M=1 To NBREP4
                   If !find(REP4(M),".","..")
                    NAMEFIC = REP4(M)
                    FICHIER = SOUSREP(R)+"/"+REP0(I)+"/"+REP1(J)+"/"+REP2(K)+"/"+REP3(M)+"/"+NAMEFIC
                    CHEMIN  = filpath(FICHIER,"","",REPBASE)
                    Call EXISTE(CHEMIN,STA) From ORDSYS
                    Case STA
                     When 1
                      If NBFIC+1>MAXFIC : Break 6 : Endif
                      Gosub ADDFIC
                     When 2
                      If NIV<5
                       NIV = 5
                       # Trop de sous-répertoires
                       GMESSAGE = mess(38,139,1)-filpath(SOUSREP(R),"","",REPBASE)
                       GMESSAGE -= "("+num$(NIV)+")"
                       Call ERREUR(GMESSAGE) From GESECRAN
                      Endif
                    Endcase
                   Endif
                  Next M
                Endcase
               Endif
              Next L
            Endcase
           Endif
          Next K
        Endcase
       Endif
      Next J
     Endif
   Endcase
  Endif
 Next I
Next R
TIT = mess(36,139,1)-":"-num$(NBFIC)-"("+filpath("","","",REPBASE)+")" : # Nb de fichiers trouvés
For I=NBFIC+1 To MAXFIC
 WNAM(I) = chr$(255)
Next I
adxmxl = NBFIC
Default File [FIC]
ORDRE = "NAM"
Return

$ADDFIC
Call INFOFIC(CHEMIN,UTIL,NOM,TAILLE,DATMOD,HREMOD,STA) From EDITRTWEB
NBFIC += 1
WNAM(NBFIC) = NAMEFIC
WREP(NBFIC) = left$(FICHIER,instr(1,FICHIER,NAMEFIC)-1)
WUSR(NBFIC) = UTIL
WDAT(NBFIC) = DATMOD
WTIM(NBFIC) = HREMOD
WTAI(NBFIC) = TAILLE
Return

$FIN_ELT
VALEUR = [F:FIC]REP+[F:FIC]NAM
Return

#---------------------#
$FIN_TABLE
Case OBJTYP
 When "ELT"
  Gosub FIN_ELT
 When "ASU"
  If [F:ASU]PRG="" & [F:ASU]SUBPRG=""
   VALEUR = ""
  Else
   VALEUR = [F:ASU]PRG+"~"+[F:ASU]SUBPRG
  Endif
 When "ADZ"
  If [F:ADZ]MOTCLE=""
   VALEUR = ""
  Else
   VALEUR = [F:ADZ]MOTCLE
  Endif
 When "AMC"
  If [F:AMC]TYPZON=0 & [F:AMC]IDENT1=""
   VALEUR = ""
  Else
   VALEUR = num$([F:AMC]TYPZON)+"~"+[F:AMC]IDENT1
  Endif
 When "ADO"
  If [F:ADO]TYP=""  & [F:ADO]COD=""
   VALEUR = ""
  Else
   VALEUR = [F:ADO]TYP+"~"+[F:ADO]COD
  Endif
 When "TFO"
  If [F:TFO]FORTYP=0 & [F:TFO]FORCOD=""
   VALEUR = ""
  Else
   VALEUR = num$([F:TFO]FORTYP)+"~"+[F:TFO]FORCOD
  Endif
 When "ADF"
  If [F:ADF]TYP="" & [F:ADF]COD=""
   VALEUR = ""
  Else
   VALEUR = [F:ADF]TYP+"~"+[F:ADF]COD
  Endif
 When "APR"
  If [F:APR]CODLEG="" & [F:APR]CODPRO=""
   VALEUR = ""
  Else
   VALEUR = [F:APR]CODLEG+"~"+[F:APR]CODPRO
  Endif
Endcase
Return

#-----------------------------------------#
Subprog C_NBLAN
If status<65 or (status>90 & status<=1729)
 If [M]NBLAN=0
  GMESSAGE = mess(08,125,1) : #  IL doit y avoir au moins 1 LANGUE
  mkstat = 1 : End
 Endif
Endif
End

Subprog AS_TYPEXP(VALEUR)
Variable Integer VALEUR

End

Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
 mkstat = 2 : End
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR

If VALEUR=1
 Raz [M]VOLFIL
 Grizo [M]VOLFIL
Else
Actzo [M]VOLFIL
Endif
Affzo [M]VOLFIL
End

Subprog IB_FICHIER
GBOUT1 = mess(47,115,1) : # Chargement objets
If [M]TYPEXP=1
 GBOUTS = ""
Endif
End

Subprog B1_FICHIER(VALEUR)
Value Char    VALEUR()
Local Char FICHIER(GDIMFIC) , URL(10)
Local Integer STAT
If GUSER="CCL" & GADONIX=2 & 0
 Local File XXCORT [XCT]
 For [XCT] Where USR="CCL"
  [M]TYPOBJ([M]NBOBJ)   = [XCT]OBJ
  [M]NOMOBJ([M]NBOBJ)   = [XCT]COD
  [M]INTITOBJ([M]NBOBJ) = "intit"
  [M]NBOBJ += 1
 Next XCT
 Close Local File [XCT]
 Affzo [M]
 End
Endif
If [M]TYPEXP=1
 Call SET_FICNAM(VALEUR,FICHIER,URL) From ORDSYS
 Call COPSRV(VALEUR,FICHIER,STAT) From ORDSYS
 If STAT : End : Endif
 Gosub CHARGE
 [M]FICPATCH = VALEUR
Else
 Call EXISTE(VALEUR,STAT) From ORDSYS
 If STAT=1
  FICHIER = VALEUR
  Gosub CHARGE
  [M]FICPATCH = VALEUR
 Endif
Endif
mkstat = 99
End

Subprog VERFCLI(VALEUR)
Variable Char VALEUR
Local Integer STAT , OK
Local Char    REPERT(GDIMFIC) , FICHIER(GDIMFIC)
Local Char    NAM(GDIMFIC) , SUF(30) , PARAM(30) , URL(GDIMFIC)
If GBROWS : End : Endif
Call EXIST_FILECLI(VALEUR,"FullPath","","",FICHIER,STAT) From ORDSYS
If STAT & (VALEUR<>[M]FICPATCH or [M]NBOBJ=0)
 Call OUINON(mess(47,115,1),OK) From GESECRAN : # Chargement objets
 If OK=2
  Call SET_FICNAM(VALEUR,[L]FICHIER,URL) From ORDSYS
  Call COPSRV(VALEUR,[L]FICHIER,STAT) From ORDSYS
  If STAT : End : Endif
  Gosub CHARGE
  [M]FICPATCH = VALEUR
 Endif
Endif
End

$CHARGE
## Préchargement des objets du fichier
Call TEMPON("L") From GESECRAN
Local Integer TYPENR , NB , NOCT , SAVIUM
Local Libelle BUFFER(1..1000)
Local Shortint NBCH : NBCH = max(60,dim([M]ACTIV))
Local Char    CHAINE(80) , CHAMP(250)(1..NBCH) , SAVIFS(2) , SAVIRS(2)
Local Blbfile BLOB(10)
[M]NBOBJ = 0
Raz CHAMP, TYPENR
SAVIFS = adxifs
SAVIRS = adxirs
SAVIUM = adxium
adxifs = ","
adxirs = chr$(10)
adxium = GUTF8
Openi [L]FICHIER , 0
Rdseq TYPENR,CHAMP
While fstat=0 & TYPENR<>8
 If [M]NBOBJ>=dim([M]NOMOBJ)
  Call ERREUR(mess(26,100,1)) From GESECRAN # Tableau plein
  Break
 Endif
 Call DELIMITE(CHAMP) From PATCH
 Case TYPENR
  When -2 : #SCM deletion
   Call ECR_TRACE(mess(36,115,1)-"("+num$(-2)+")",1) From GESECRAN : # Structure fichier incorrecte
   Break
  When 1 : # mb 3.5.2 bug 14188
   [M]COMMENT = CHAMP(1)
   [M]NBLAN = 0
   While CHAMP(2)<>""
    K = instr(1,CHAMP(2),"/")
    If K
     [M]LANGUE([M]NBLAN) = left$(CHAMP(2),K-1)
     CHAMP(2) = right$(CHAMP(2),K+1)
    Else
     [M]LANGUE([M]NBLAN) = CHAMP(2)
     CHAMP(2) = ""
    Endif
    Call LECTEXTRA([M]ZLANGUE([M]NBLAN),"TABLAN","INTSHO",[M]LANGUE([M]NBLAN),"") From ATEXTRA
    [M]NBLAN += 1
   Wend
   [M]VERSION = CHAMP(3)
   [M]TYPPTC  = val(CHAMP(6))
   [M]NBACT = 0
   While CHAMP(4)<>""
    K = instr(1,CHAMP(4),"/")
    If K
     [M]ACTIV([M]NBACT) = left$(CHAMP(4),K-1)
     CHAMP(4) = right$(CHAMP(4),K+1)
    Else
     [M]ACTIV([M]NBACT) = CHAMP(4)
     CHAMP(4) = ""
    Endif
    [M]NBACT += 1
   Wend
  When 2
   ## Action ACTLOBJPAT (mb 8.6.10)
   mkstat = 0
   If left$(CHAMP(1),1)<>"~"
    Local Char    VALMSK(250) , PARMSK(250)(1..20) , SAVACT(20)
    Local Integer SAVIMP
    SAVACT = GACTION : GACTION = "ACTLOBJPAT"
    SAVIMP = GIMPORT : GIMPORT = 1
    PARMSK(1) = [M]DOSSIER
    PARMSK(2) = CHAMP(1)
    PARMSK(3) = "[M]LANGUE"
    PARMSK(4) = "" : # bug 71525 CHAMP(3)
    VALMSK    = CHAMP(2)
    Call S_AFF_CHAR(VALMSK,PARMSK,"ACTLOBJPAT","APATCH","") From GACTION
    GACTION  = SAVACT
    GIMPORT = SAVIMP
   Endif
   If !mkstat
    [M]TYPOBJ([M]NBOBJ)   = CHAMP(1)
    [M]NOMOBJ([M]NBOBJ)   = CHAMP(2)
    [M]INTITOBJ([M]NBOBJ) = CHAMP(3)
    [M]NBOBJ += 1
   Else
    #93725
    #Call ECR_TRACE(func AFNC.INTCLE("AOB",CHAMP(1))-CHAMP(2)+"/"+GMESSAGE,-1) From GESECRAN
    Call ECR_TRACE(mess(167,125,1)-CHAMP(1)-func AMK_TOOL.GET_FIELD_LABEL("APATCH", "NOMOBJ")-CHAMP(2)+"\"+GMESSAGE,-1) From GESECRAN
    Raz GMESSAGE , mkstat
   Endif
   If find(CHAMP(1),"TRT")
    Repeat
     Rdseq CHAMP(1)
    Until fstat or CHAMP(1)=string$(10,"*")
   Elsif find(CHAMP(1),"ADX","ELT","BIA","ELX")
    Gosub CH_FIC
   Elsif CHAMP(1)="ETA"
    Gosub CH_ETA
   Elsif CHAMP(1)="TAB"
    Repeat
     Raz CHAMP, TYPENR
     Rdseq TYPENR,CHAMP
     If TYPENR=3
      Gosub CH_FIC
     Endif
    Until TYPENR<>3
   Endif
  When 22,24,23,25 : # Blob , Clob
   Rdseq NOCT
   If find(TYPENR,24,25)
    Getseq 1,BLOB Sized NOCT
   Else
    Repeat
     NB = dim(BUFFER)
     If NOCT>NB
      Getseq NB , BUFFER
      NOCT -= NB
     Else
      Getseq NOCT , BUFFER
      NOCT = 0
     Endif
    Until NOCT=0
   Endif
   Repeat
    Rdseq CHAINE
   Until fstat or CHAINE=string$(10,"*")
   If fstat
    Break
   Endif
 Endcase
 Raz CHAMP, TYPENR
 Rdseq TYPENR,CHAMP
Wend
Openi
adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Affzo COMMENT,LANGUE,VERSION,ACTIV,ZACTIV,TYPOBJ,NOMOBJ,INTITOBJ,TYPPTC,ZLANGUE,PRODUIT
Call TEMPOFF From GESECRAN
Return

$CH_ETA
Repeat
 Rdseq TYPENR,CHAMP
 If TYPENR=3
  Gosub CH_FIC
 Endif
Until TYPENR=7 or fstat
Return

$CH_FIC
Rdseq NOCT
Repeat
 NB = dim(BUFFER)
 If NOCT>NB
  Getseq NB , BUFFER
  NOCT -= NB
 Else
  Getseq NOCT , BUFFER
  NOCT = 0
 Endif
Until NOCT=0
Repeat
 Rdseq CHAINE
Until fstat or CHAINE=string$(10,"*")
Return

Subprog C_DOSSIER(VALEUR)
Variable Char    VALEUR()
Local Integer ER
If VALEUR="" : End : Endif
If filinfo(filpath("FIL","ADOVAL","fde",VALEUR),0)<0
 Call ERREUR(mess(106,125,1)) From GESECRAN : # Dossier inaccessible
 mkstat = 2 : End
Else
 Onerrgo ERRDOS
 Local File =VALEUR+".ADOVAL" [AD__]
 Read [AD__]ADW0 = "";"";"TYPDOS"
 Onerrgo
 If ER
  Call ERREUR(mess(142,100,1)) From GESECRAN : #  Le numéro de version du dossier est incorrect
  mkstat = 2 : End
 Endif
 If !fstat & val([F:AD__]VALEUR)-1<>GPRODUIT
  # Ce dossier existe et n'est pas un dossier du produit courant
  Call ERREUR(VALEUR-":"-mess(197,126,1)) From GESECRAN
  mkstat = 2 : End
 Endif
 Close Local File [AD__]
Endif
End

$ERRDOS
ER = errn
Resume

Subprog C_COMMENT(VALEUR)
Variable Char    VALEUR()
If instr(1,VALEUR,'"') & instr(1,VALEUR,"'")
 GMESSAGE = '" :'-mess(94,123,1) : # Caractère interdit
 mkstat = 2 : End
Elsif instr(1,VALEUR,'"')
 VALEUR = ctrans(VALEUR,'"',"'")
Endif
End

Subprog AS_NBOBJ
Raz GBOUT2 , GBOUT3 , GBOUT4 , GBOUT5
If [M]NBACT>0
 GBOUT2 = mess(108,126,1) : # Préchargement
Endif
If GADONIX=2
 GBOUT3 = mess(236,139,1) : # Différence objet courant
 GBOUT4 = mess(237,139,1) : # Différence tous objet
Endif
GBOUT5 = mess(1,143,1) : # Modèles de paramétrage
End

Subprog B3_NBOBJ
Local Char PARAM(250)(1..6) , VALEUR(10)
If nolign>0
 PARAM(1) = [M:DIA]NOMOBJ(nolign-1)
 PARAM(2) = [M:DIA]TYPOBJ(nolign-1)
 PARAM(3) = ""
 PARAM(4) = ""
 PARAM(5) = "1"
 Call TRAITE_CHAR(VALEUR,PARAM,"","ADIF","ADIF",3,"XYADIF") From GTRAITE
Endif
End

Subprog B4_NBOBJ
Local Char PARAM(250)(1..6) , VALEUR(10)
PARAM(1) = "[M:DIA]NOMOBJ"
PARAM(2) = "[M:DIA]TYPOBJ"
PARAM(3) = ""
PARAM(4) = ""
PARAM(5) = "0"
Call TRAITE_CHAR(VALEUR,PARAM,"","ADIF","ADIF",3,"XYADIF") From GTRAITE
End

Subprog B5_NBOBJ
Local Char COD(GLONAPH)
Local Integer OK
Local File =[M:DIA]DOSSIER+".APATCHMOD" [APH] , =[M:DIA]DOSSIER+".AWRKLNK" [AWM]
Call SAICAR(COD,mess(1,143,1),mess(1,143,1),"APH",0,0,"",OK) From GESECRAN : # Modèle de paramétrage
If !OK : End : Endif
For [APH]APH0 Where MODPAT=COD
 [M:DIA]NBOBJ += 1
 [M:DIA]TYPOBJ([M:DIA]NBOBJ-1)   = "AAA"
 [M:DIA]NOMOBJ([M:DIA]NBOBJ-1)   = [F:APH]MODDON+"~~"+[F:APH]TRANSAC+"~='"+[F:APH]EXPSEL+"'"
 Read [AWM]AWM0=[F:APH]MODDON
 If !fstat : Call TEXTE([F:AWM]INTITMOD,[M:DIA]INTITOBJ([M:DIA]NBOBJ-1)) From OBJDIV : Endif
Next APH
Affzo 30
End

Subprog C_TYPOBJ(VALEUR)
Variable Char    VALEUR()
End

Subprog C_INTITOBJ(VALEUR)
Variable Char    VALEUR()
VALEUR = ctrans(VALEUR,'"',"'")
End

Subprog IB_NOMOBJ
Local Char DOSSIER(GLONADD)
[L]DOSSIER = [M]DOSSIER
Gosub SET_TYP
If [M]TYPOBJ(nolign-1)="AAA"
 Raz GBOUTS
Else
 Raz GBOUT7
Endif
If !find([M]TYPOBJ(nolign-1),TEX(1..NBTEX))  : # gbout1>0 : SELCRITFLD
 Raz GBOUTS,GBOUT2,GBOUT3,GBOUT4,GBOUT5,GBOUT6
Elsif find([M]TYPOBJ(nolign-1),"EXE")        : # gbout2>0 : SELTRTEXE
 Raz GBOUTS,GBOUT1,GBOUT3,GBOUT4,GBOUT5,GBOUT6
Elsif find([M]TYPOBJ(nolign-1),"TRT")        : # gbout3>0 : SELTRT trt
 Raz GBOUTS,GBOUT1,GBOUT2,GBOUT4,GBOUT5,GBOUT6
 GBIDC2 = "src"
Elsif find([M]TYPOBJ(nolign-1),"ADX")        : # gbout4>0 : SELTRT adx
 Raz GBOUTS,GBOUT1,GBOUT2,GBOUT3,GBOUT5,GBOUT6
 GBIDC2 = "adx"
Elsif find([M]TYPOBJ(nolign-1),"ETA")        : # gbout5>0 : SELCRY2
 Raz GBOUTS,GBOUT1,GBOUT2,GBOUT3,GBOUT4,GBOUT6
Elsif find([M]TYPOBJ(nolign-1),"AY","AYS","AYG","AYD","AYF","AYE","AYB","AYW"
& ,"AYA","AYL","AYO","AYI","AYM","AYC","AYU","ELX")
 Raz GBOUTS,GBOUT1,GBOUT2,GBOUT3,GBOUT4,GBOUT5
Else                                         : # gbouts>0 : selection par defaut
 Raz GBOUT1,GBOUT2,GBOUT3,GBOUT4,GBOUT5,GBOUT6
Endif
End

Subprog AS_NOMOBJ(VALEUR)
Variable Char    VALEUR()
Local Char ACTIONX(20)
If TYPOBJ(nolign-1)="ELX"
 ACTIONX = "AS_NOMOBJ" : Gosub ACTION_XTEND
Endif
ACTIONX = "AS_NOMOBJ" : Gosub ACTION_PRODUIT
End

Subprog C_NOMOBJ(VALEUR)
Variable Char    VALEUR()
Local Integer OK , I
OK = 1
For I=1 To [M]NBOBJ
 If [M]TYPOBJ(I-1)-[M]NOMOBJ(I-1)=[M]TYPOBJ(nolign-1)-toupper(VALEUR) & I<>nolign
  OK =0 : Break
 Endif
Next
If !OK
 GMESSAGE = mess(24,123,1)-num$(I) : # Code déjà existant en LIGNE
 mkstat =2 : End
Endif
End

Subprog B2_NBOBJ
Local Integer I , J , K , KK , OK , NBCLE , I1 , I2, NTRT
Local Char    CLE(100)(dim([M]NOMOBJ)) , CLEF(10)(1..16)
Local Char    OBJET(GLONAOB) , NOM(80) , TRAITE(GLONADC) , TRAITV(GLONADC) , ACTIV(GLONACV)
Local Char    CHAINE(80) , CRITFIC(80) , INTITULE(30)
If clalev([F:ATB])=0 : Local File =[M]DOSSIER+".ATABLE"    [ATB] : Endif
If clalev([F:ATZ])=0 : Local File =[M]DOSSIER+".ATABZON"   [ATZ] : Endif
If clalev([F:ATI])=0 : Local File =[M]DOSSIER+".ATABIND"   [ATI] : Endif
If clalev([F:AMK])=0 : Local File =[M]DOSSIER+".AMSK"      [AMK] : Endif
If clalev([F:AMZ])=0 : Local File =[M]DOSSIER+".AMSKZON"   [AMZ] : Endif
If clalev([F:AWI])=0 : Local File =[M]DOSSIER+".AWINDOW"   [AWI] : Endif
If clalev([F:AWT])=0 : Local File =[M]DOSSIER+".AWINBOUT"  [AWT] : Endif
If clalev([F:AWB])=0 : Local File =[M]DOSSIER+".AWINBRO"   [AWB] : Endif
If clalev([F:AOB])=0 : Local File =[M]DOSSIER+".AOBJET"    [AOB] : Endif
If clalev([F:AOT])=0 : Local File =[M]DOSSIER+".AOBJTAB"   [AOT] : Endif
If clalev([F:ATY])=0 : Local File =[M]DOSSIER+".ATYPE"     [ATY] : Endif
If clalev([F:ATYP])=0 : Local File =[M]DOSSIER+".ATYPEPRO"     [ATYP] : Endif
If clalev([F:AFC])=0 : Local File =[M]DOSSIER+".AFONCTION" [AFC] : Endif
If clalev([F:ACT])=0 : Local File =[M]DOSSIER+".ACTION"    [ACT] : Endif
If clalev([F:ARP])=0 : Local File =[M]DOSSIER+".AREPORT"   [ARP] : Endif
If clalev([F:ACN])=0 : Local File =[M]DOSSIER+".ACONSULT"  [ACN] : Endif
If clalev([F:APE])=0 : Local File =[M]DOSSIER+".AENTREE"   [APE] : Endif
If clalev([F:ADP])=0 : Local File =[M]DOSSIER+".ADOPAR"    [ADP] : Endif
If clalev([F:AGB])=0 : Local File =[M]DOSSIER+".AGLOBVAR"  [AGB] : Endif
If clalev([F:ACST])=0 : Local File =[M]DOSSIER+".ACONSTANT"  [ACST] : Endif
If clalev([F:ADV])=0 : Local File =[M]DOSSIER+".ATABTAB"   [ADV] : Endif
If clalev([F:ASU])=0 : Local File =[M]DOSSIER+".ASUBPROG"  [ASU] : Endif
If clalev([F:AWM])=0 : Local File =[M]DOSSIER+".AWRKLNK"   [AWM] : Endif
If clalev([F:AUR])=0 : Local File =[M]DOSSIER+".AURL"      [AUR] : Endif
If clalev([F:ADO])=0 : Local File =[M]DOSSIER+".ADOCUMENT" [ADO] : Endif
If clalev([F:ADF])=0 : Local File =[M]DOSSIER+".ADOCFNC"   [ADF] : Endif
If clalev([F:ACV])=0 : Local File =[M]DOSSIER+".ACTIV"     [ACV] : Endif
If clalev([F:AVW])=0 : Local File =[M]DOSSIER+".AVIEW"     [AVW] : Endif
If clalev([F:AVD])=0 : Local File =[M]DOSSIER+".AVIEWD"    [AVD] : Endif
If clalev([F:ANG])=0 : Local File =[M]DOSSIER+".ANAVIG"    [ANG] : Endif
If clalev([F:AHI])=0 : Local File =[M]DOSSIER+".AHISTO"    [AHI] : Endif
If clalev([F:AOE])=0 : Local File =[M]DOSSIER+".AOBJEXT"   [AOE] : Endif
If clalev([F:ATN])=0 : Local File =[M]DOSSIER+".ATRANSAC"  [ATN] : Endif
If clalev([F:APR])=0 : Local File =[M]DOSSIER+".APROCESSUS"  [APR] : Endif
If clalev([F:ADC])=0 : Local File =GDOSX3+".ADICTRT"       [ADC] : Endif

##  BI CCL
If filinfo(filpath("FIL","ABIDATMRT","fde",[M]DOSSIER),0)>=0
 If clalev([F:ABM])=0 : Local File =[M]DOSSIER+".ABIDATMRT" [ABM] : Endif
 If clalev([F:ABF])=0 : Local File =[M]DOSSIER+".ABITABDAT" [ABF] : Endif
 If clalev([F:ABZ])=0 : Local File =[M]DOSSIER+".ABITABFLD" [ABZ] : Endif
 If clalev([F:AII])=0 : Local File =[M]DOSSIER+".ABICOND"   [AII] : Endif
 If clalev([F:AHH])=0 : Local File =[M]DOSSIER+".ABIHIERA"  [AHH] : Endif
 If clalev([F:ABI])=0 : Local File =[M]DOSSIER+".ABIDIM"    [ABI] : Endif
 If clalev([F:ABJ])=0 : Local File =[M]DOSSIER+".ABIDIMFLD" [ABJ] : Endif
 If clalev([F:ABO])=0 : Local File =[M]DOSSIER+".ABIREPORT" [ABO] : Endif
 If clalev([F:ABV])=0 : Local File =[M]DOSSIER+".ABIREGORG" [ABV] : Endif
Endif

## POur AML
Local File =[M]DOSSIER+".AMENLOC" [AML]
Local File =[M]DOSSIER+".APLSTD"  [AST4]
Local File =[M]DOSSIER+".APLSTD"  [AST5]
Local File =[M]DOSSIER+".APLSTD"  [AST6]
Link [AML]  With [AST4]CLE = [F:AML]MENLOC;0;GLANGUE
&              , [AST5]CLE = 0;[F:AML]MENLOC;GLANGUE
&              , [AST6]CLE = 200;([F:AML]MENLOC-200);GLANGUE
& As [AML_]
& Order By Key MENLOC

### Init produit
ACTIONX = "INI_B2_NBOBJ" : Gosub ACTION_PRODUIT

I = [M]NBOBJ
For J=0 To I-1
 CLE(J) = [M]TYPOBJ(J)-[M]NOMOBJ(J)
Next J
OK = 1
For KK=0 To [M]NBACT-1
 [L]ACTIV = [M]ACTIV(KK)
 Call TEMPON(mess(14,115,1)-[L]ACTIV) From GESECRAN : # Code activité
 Gosub REMPLIT
 If !OK : Break : Endif
Next KK
[M]NBOBJ = I
Call TEMPOFF From GESECRAN
Gosub TRIOBJ
End

$REMPLIT
# Le code activité
OBJET    = "ACV"
NOM      = [L]ACTIV
Call CONTROLE("ACV","",[L]ACTIV,"",mkstat) From CONTOBJ
If !fstat : Call TEXTE([F:ACV]LIBACT,INTITULE) From OBJDIV : Endif
Gosub EXTOBJ : If !OK : Return : Endif

# Tables
For [ATB]CODFIC Where CODACT=[L]ACTIV
 OBJET = "ATB"
 NOM   = [F:ATB]CODFIC
 Call TEXTE([F:ATB]INTITFIC,INTITULE) From OBJDIV
 Gosub EXTOBJ : If !OK : Break : Endif
Next
If !OK : Return : Endif
For [ATZ]CODZONE(1) Where CODACT=[L]ACTIV
 OBJET = "ATB"
 NOM   = [F:ATZ]CODFIC
 Call CONTROLE("ATB","",NOM,"",mkstat) From CONTOBJ
 If !fstat : Call TEXTE([F:ATB]INTITFIC,INTITULE) From OBJDIV  : Endif
 Gosub EXTOBJ : If !OK : Break : Endif
Next
If !OK : Return : Endif
For [ATI]CODIND(1) Where CODACT=[L]ACTIV
 OBJET = "ATB"
 NOM   = [F:ATI]CODFIC
 Call CONTROLE("ATB","",NOM,"",mkstat) From CONTOBJ
 If !fstat : Call TEXTE([F:ATB]INTITFIC,INTITULE) From OBJDIV  : Endif
 Gosub EXTOBJ : If !OK : Break : Endif
Next
If !OK : Return : Endif

# Ecrans
For [AMK]CODMSK
 If [F:AMK]CODACT=[L]ACTIV or find([L]ACTIV,[F:AMK]ACTBLOC(0..[F:AMK]NBBLOC-1))<>0
  OBJET   = "AMK"
  NOM     = [F:AMK]CODMSK
  TRAITE  = [F:AMK]TRTSPE
  TRAITV  = [F:AMK]TRTSPV
  Call TEXTE([F:AMK]INTMSK,INTITULE) From OBJDIV
  Gosub EXTOBJ : If !OK : Break : Endif
 Endif
Next
If !OK : Return : Endif
For [AMZ]CODZON(1) Where CODACT=[L]ACTIV
 OBJET   = "AMK"
 NOM     = [F:AMZ]CODMSK
 Read [AMK]CODMSK = [F:AMZ]CODMSK
 TRAITE  = [F:AMK]TRTSPE
 TRAITV  = [F:AMK]TRTSPV
 Call TEXTE([F:AMK]INTMSK,INTITULE) From OBJDIV
 Gosub EXTOBJ : If !OK : Break : Endif
Next
If !OK : Return : Endif

# Fenêtres
For [AWI]AWI0
 If [F:AWI]CODACT=[L]ACTIV or find([L]ACTIV,[F:AWI]ACTMSK(0..[F:AWI]NBMSK-1))<>0
  OBJET = "AWI"
  NOM   = [F:AWI]WIN
  Call NOMSPEWIN([F:AWI]WIN,TRAITE) From MSKDIV
  Call TEXTE([F:AWI]DES,INTITULE) From OBJDIV
  Gosub EXTOBJ : If !OK : Break : Endif
 Endif
Next
If !OK : Return : Endif
For [AWT]AWT0 Where CODACTBOUT=[L]ACTIV
 OBJET = "AWI"
 NOM   = [F:AWT]WIN
 Call NOMSPEWIN([F:AWT]WIN,TRAITE) From MSKDIV
 Call CONTROLE("AWI","#",NOM,"",mkstat) From CONTOBJ
 If !fstat : Call TEXTE([F:AWI]DES,INTITULE) From OBJDIV : Endif
 Gosub EXTOBJ : If !OK : Break : Endif
Next
If !OK : Return : Endif
For [AWB]AWB0
 If find([L]ACTIV,[F:AWB]ACTLIS(0..[F:AWB]NBLIS-1))
  OBJET = "AWI"
  NOM   = [F:AWB]WIN
  Call NOMSPEWIN([F:AWB]WIN,TRAITE) From MSKDIV
  Call CONTROLE("AWI","#",NOM,"",mkstat) From CONTOBJ
  If fstat : Call TEXTE([F:AWI]DES,INTITULE) From OBJDIV : Endif
  Gosub EXTOBJ : If !OK : Break : Endif
 Endif
Next
If !OK : Return : Endif

# Objets
For [AOB]ABREV Where CODACT=[L]ACTIV
 OBJET   = "AOB"
 NOM     = [F:AOB]ABREV
 TRAITE  = "SPE"+[F:AOB]ABREV
 TRAITV  = "SPV"+[F:AOB]ABREV
 Call TEXTE([F:AOB]LIBEL,INTITULE) From OBJDIV
 Gosub EXTOBJ : If !OK : Break : Endif
Next
If !OK : Return : Endif
For [AOT]ABREV Where TABACT=[L]ACTIV
 OBJET   = "AOB"
 NOM     = [F:AOT]ABREV
 TRAITE  = "SPE"+[F:AOT]ABREV
 TRAITV  = "SPV"+[F:AOT]ABREV
 Call TEXTE([F:AOB]LIBEL,INTITULE) From OBJDIV
 Gosub EXTOBJ : If !OK : Break : Endif
Next
If !OK : Return : Endif

# Types de données
For [ATY]CODTYP Where CODACT=[L]ACTIV
 OBJET = "ATY"
 NOM   = [F:ATY]CODTYP
 Call TEXTE([F:ATY]INTITTYP,INTITULE) From OBJDIV
 Gosub EXTOBJ : If !OK : Break : Endif
Next
If !OK : Return : Endif

# Types prototype
For [ATYP]ATYP0 Where CODACT=[L]ACTIV
 OBJET = "ATYP"
 NOM   = [F:ATYP]COD
 Call TEXTE([F:ATYP]INTIT,INTITULE) From OBJDIV
 Gosub EXTOBJ : If !OK : Break : Endif
Next
If !OK : Return : Endif

# Fonctions
For [AFC]CODINT
 If [F:AFC]CODACT=[L]ACTIV or find([L]ACTIV,[F:AFC]ACTOPT(0..dim([F:AFC]ACTOPT)-1))<>0
&    or find([L]ACTIV,[F:AFC]ACTVAR(0..[F:AFC]NBVAR-1))
  OBJET  = "AFC"
  NOM    = [F:AFC]CODINT
  TRAITE = [F:AFC]TRAIT
  Call TEXTE([F:AFC]NOM,INTITULE) From OBJDIV
  Gosub EXTOBJ : If !OK : Break : Endif
 Endif
Next
If !OK : Return : Endif

# Actions
For [ACT]ACTION Where CODACT=[L]ACTIV
 OBJET  = "ACT"
 NOM    = [F:ACT]ACTION
 TRAITE = [F:ACT]CODTRT
 Call TEXTE([F:ACT]INTITA,INTITULE) From OBJDIV
 Gosub EXTOBJ : If !OK : Break : Endif
Next
If !OK : Return : Endif

# Etats
For [ARP]ARP0 Where CODACT=[L]ACTIV
 OBJET = "ARP"
 NOM   = [F:ARP]RPTCOD
 TRAITE = [F:ARP]TRTINI
 Call TEXTE([F:ARP]RPTDES,INTITULE) From OBJDIV
 Gosub EXTOBJ : If !OK : Break : Endif
 If filinfo(filpath("REPORT",[F:ARP]CRYCOD,"rpt",[M]DOSSIER),0)>=0
  OBJET = "ETA"
  NOM   = [F:ARP]CRYCOD
  Call CONTROLE("ARP","#",NOM,"",mkstat) From CONTOBJ
  If !fstat : Call TEXTE([F:ARP]RPTDES,INTITULE) From OBJDIV : Endif
  Gosub EXTOBJ : If !OK : Break : Endif
 Endif
Next
If !OK : Return : Endif

# Consultations
For [ACN]ACN0 Where CODACT=[L]ACTIV
 OBJET  = "ACN"
 NOM    = [F:ACN]COD
 TRAITE = [F:ACN]PRGSPE
 Call TEXTE([F:ACN]LIBEL,INTITULE) From OBJDIV
 Gosub EXTOBJ : If !OK : Break : Endif
Next
If !OK : Return : Endif

# Menus locaux
For [AML_]MENLOC Where CODACT=[L]ACTIV
 OBJET  = "AML"
 NOM    = num$([F:AML]MENLOC)
 [L]INTITULE =  string$([F:AML]MENLOC<100&[F:AML]MENLOCAL=2,[F:AST5]LANMES)
 [L]INTITULE -= string$([F:AML]MENLOC>200&[F:AML]MENLOCAL=2,[F:AST6]LANMES)
 [L]INTITULE -= string$([F:AML]MENLOCAL<>2,[F:AST4]LANMES)
 Gosub EXTOBJ : If !OK : Break : Endif
Next
If !OK : Return : Endif

# Paramètres
For [ADP]ADP0 Where CODACT=[L]ACTIV
 OBJET  = "ADP"
 NOM    = [F:ADP]PARAM
 TRAITE = [F:ADP]TRAIT
 Call TEXTE([F:ADP]NAM,INTITULE) From OBJDIV
 Gosub EXTOBJ : If !OK : Break : Endif
Next
If !OK : Return : Endif

# Tables diverses
For [ADV]CODE Where CODACT=[L]ACTIV
 OBJET  = "ADV"
 NOM    = num$([F:ADV]NUMTAB)
 Call LECTEXTRA(INTITULE,"ATABTAB","LNGDES",num$([F:ADV]NUMTAB),"") From ATEXTRA
 Gosub EXTOBJ : If !OK : Break : Endif
 OBJET  = "ADI"
 NOM    = num$([F:ADV]NUMTAB)
 Call LECTEXTRA(INTITULE,"ATABTAB","LNGDES",num$([F:ADV]NUMTAB),"") From ATEXTRA
 Gosub EXTOBJ : If !OK : Break : Endif
Next
