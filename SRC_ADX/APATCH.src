#<AdxTL>@(#)2.0.0.0 $Revision$
Local Char PARAM(30)(1..1) , VALEUR(10)
Raz GNBMASKOUV
GFUSION = 1
Call TRAITE_CHAR(VALEUR,PARAM,"","APATCH","APATCH",4,"") From GTRAITE
End

#-------------------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"         : Gosub INIT
 When "EXEC"         : Gosub EXEC
 When "DEBUT"        : Gosub DEBUT
 When "SETBOUT"      : Gosub SETBOUT
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "CONTROLE"     : Gosub CONTROLE
 When "SEL_TABLE"    : Gosub SEL_TABLE
 When "FIN_TABLE"    : Gosub FIN_TABLE
 When "SEL_LISTE"    : Gosub SEL_LISTE
 When "TRT_DIV"      : Gosub TRT_DIV
Endcase
Return

#--------------------------------------------------------#
$SETBOUT
If GCONSULT
 Diszo [M:DIA]
 Call VIREBOUT(CHMEN,"b") From GOBJET : #Rappel
 Call VIREBOUT(CHBOU,"O") From GOBJET
 IMGFLG(5) = 1 : # Croix blanche
Else
 IMGFLG(5) = 0
Endif
Return

#--------------------------#
$APRES_MODIF
Case COUZON
 When "DOSSIER"
  If dim(GTXNUM)>0 & dim(GTXNB)>0
   Raz GTXNUM , GTXNB
  Endif
Endcase
Return

#---------------------#
$ACTION_XTEND
Local Integer OKTRT
Call EXISTE_ADX("","","APATCHAYT",OKTRT) From ORDSYS
If OKTRT
 If dim([L]ACTION)>0
  Local Char OACTION(20)
  OACTION = ACTION
 Else
  Local Char ACTION(20)
 Endif
 ACTION = ACTIONX
 Gosub ACTION From APATCHAYT
 If dim([L]OACTION)>0 & OACTION<>""
  ACTION = OACTION
 Endif
Endif
Return

#---------------------#
$ACTION_PRODUIT
Local Integer OKTRT
Call EXISTE_ADX("","","APATCHB",OKTRT) From ORDSYS
If OKTRT
 If dim([L]ACTION)>0
  Local Char OACTION(20)
  OACTION = ACTION
 Else
  Local Char ACTION(20)
 Endif
 ACTION = ACTIONX
 Gosub ACTION From APATCHB
 If dim([L]OACTION)>0 & OACTION<>""
  ACTION = OACTION
 Endif
Endif
Return

#---------------------#
$INIT
Local Char    FICPATCH(GDIMFIC) , URL(10)
Local Integer STAT
Local Mask APATCH [DIA]
TMP = 1
Return

#---------------------#
$DEBUT
Raz [M:DIA]

[M]TYPEXP=2
Call AM_TYPEXP([M]TYPEXP)

[M:DIA]NBLAN += 1  : [M:DIA]LANGUE(0) = GLANGUE
If GLANDEF<>GLANGUE
 [M:DIA]NBLAN += 1 : [M:DIA]LANGUE(1) = GLANDEF
Endif
[M:DIA]DOSSIER = nomap
[M:DIA]VERSION = "1"
Case GPRODUIT
 When -1 : [M:DIA]PRODUIT = "SU" : # Pour test
 When  0 : [M:DIA]PRODUIT = "X3"
 When  1 : [M:DIA]PRODUIT = "GX"
 When  2 : [M:DIA]PRODUIT = "PA"
 When  3 : [M:DIA]PRODUIT = "AB"
Endcase
Affzo
Setmok [M:DIA] With 0

Return

#---------------------#
$CONTROLE
If GSTATUT=GSTAESC : FIN = 1 : Return : Endif
Return

#---------------------#
$TRIOBJ
# Tri dans l'ordre où l'intégration pose le moins de problèmes
If [M:DIA]NBOBJ=0 : Return : Endif
Local Integer ORDOBJ([M:DIA]NBOBJ)
Call ORDOBJ(ORDOBJ,[M:DIA]TYPOBJ,[M:DIA]NBOBJ)
Sorta [M:DIA]NBOBJ [M:DIA]TYPOBJ,[M:DIA]NOMOBJ,[M:DIA]INTITOBJ,ORDOBJ Order By ORDOBJ(indice),[M:DIA]NOMOBJ(indice)
Affzo [M:DIA]30
Return

#---------------------------------#
Subprog ORDOBJ(ORD,COD,NBR)
Variable Integer ORD(0..)
Value Char COD()(0..)
Value Integer NBR
Local Integer I

# cg 4 juillet 2011 : ajout type IND pour patcher a coté les trads des textes
# specifique pour indus

For I=0 To NBR-1
 ORD(I) = find(COD(I)
&           ,"ACV","AML","ELT","BIA","TXT","EXE","AHI","ATN","ADC","ANG"
&           ,"ADX","TRT","ETA","ACS","ANM","ACT","AFC","ACL","ASL","ATYP"
&           ,"AGB","ACTX","ACST","ASU","ATY","ADV","ADI","ATB","AVW","AUR","AMK","ARP"
&           ,"AOB","AOP","ADP","AWI","AOE","AEN","ACN","PS1","PS2"
&           ,"TAB","GAU","AWM","AWR","AWA","AWW","ABT","ABA","ABG","ACLA","ASW"
&           ,"ADZ","ADO","ADF","ALH","ALQ","ALT","ABF","ABI","ABM","ABV"
&           ,"ABO","AHH","AII","ASY","TFO","APR","AWE","ANT","AMC"
&           ,"AY" ,"AYS","ELX","AYG","AYD","AYF","AYM","AYI","AYE"
&           ,"AYB","AYO","AYA","AYL","AYW","AYC","AYU","IND"
&           )
 If ORD(I)=0
  ORD(I) = 100
 Endif
Next I
End

#---------------------#
$EXEC
Gosub TRIOBJ
If [M:DIA]TYPEXP=1 : # Client
 Call SET_FICNAM([M:DIA]FICPATCH,FICPATCH,URL) From ORDSYS
Else
 FICPATCH = [M:DIA]FICPATCH
Endif
Call PATCH(FICPATCH,[M:DIA]COMMENT,[M:DIA]DOSSIER,[M:DIA]VERSION,[M:DIA]NBOBJ
& ,[M:DIA]TYPOBJ,[M:DIA]NOMOBJ,[M:DIA]INTITOBJ,[M:DIA]NBLAN,[M:DIA]LANGUE,[M:DIA]NBACT,[M:DIA]ACTIV
& ,[M:DIA]PRODUIT,[M:DIA]TYPPTC)

If [M:DIA]TYPEXP=1
 Call COPCLI(FICPATCH,[M:DIA]FICPATCH,STAT) From ORDSYS
 GFICPATH = [M:DIA]FICPATCH
Endif
Return

#--------------------------------------------------------------------------------------------------------------------------#
Subprog PATCH(FICPATCH,COMMENT,DOSSIER,VERSION,NBOBJ,TYPOBJ,NOMOBJ,INTITOBJ,NBLAN,LANGUE,NBACT,ACTIV,PRODUIT,TYPPTC)
Value Char    FICPATCH
Value Char    COMMENT
Value Char    DOSSIER
Value Char    VERSION
Value Integer NBOBJ
Value Char    TYPOBJ()(1..)
Value Char    NOMOBJ()(1..)
Value Char    INTITOBJ()(1..)
Value Integer NBLAN
Value Char    LANGUE()(1..)
Value Integer NBACT
Value Char    ACTIV()(1..)
Value Char    PRODUIT
Value Integer TYPPTC

maxmem = max(int(maxmem/1024),45000)

Local Integer I , J , K , L , Z , P , ILAN , STAT , ER
Local Char    SAVIFS(2) , SAVIRS(2)
Local Integer SAVIUM
Local Char    FICHIER(GLONATB) , ABR(GLONABR+2) , VARIA(GLONAVA) , IDENT(250) , CHAINE(250) , CHAINE2(250)(1..10)
Local Integer TYP , IND , NBZONE
Local Integer NUMERO , CHAPITRE, PARAM
Local Libelle BUFFER(1..30)
Local Integer NB , COMPTE , NOCT , TYPENR
Local Char    REP(10) , SREP(GLONLAN) , EXT(10) , NOMPROG(30)
Local Char    MODDON(GLONAWM) , TRANSAC(GLONATN) , CODLEG(GLONADI)
Local Char    ZFIC(GLONATB) , ZIDENT(80) , ZA(80) , ZPAR(GLONAVA) , ZVAL(250)(1..4)
Local Integer Z1 , Z2 , ZP
Local Char    TYPS(255) , CODS(255) , ACTIONX(10)
Local Char    FICBIN(255) , REPERT(255) , FIC(255) , SEP(1) , FICWEB(255) , FIC_TMP(GDIMFIC)
Local Clbfile CLOB(12)
Local Blbfile BLOB(12)
Local Char    ABROBJ(10) , CLEOBJ(255) , INTOBJ(80) , ME(80)
Local Char    MACHINE(GLONAMC) , APPLI(GLONADS) , DOSX3(GLONADD) , OGDOSX3(GLONADS)

Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS

ACTIONX = "CREINI" : Gosub ACTION_XTEND : Gosub ACTION_PRODUIT

OGDOSX3 = GDOSX3
Local File =DOSSIER+".ADOVAL" [ADW]
Read [ADW]ADW0 = "";"";"SUPDOS"
GDOSX3 = [F:ADW]VALEUR
If GDOSX3="" : GDOSX3 = "X3" : Endif
If instr(1,DOSX3,"@")
 DOSX3 = MACHINE+"@"+GDOSX3
Else
 DOSX3 = GDOSX3
Endif

If instr(1,DOSX3,"@")
 Local File =DOSX3+".ADOSACT" [ADA]
 Local File =DOSX3+".TABLAN"  [TLA]
Else
 Local File ADOSACT           [ADA]
 Local File TABLAN            [TLA]
Endif

Local File =DOSSIER+".ADICTRT"    [ADC]
Local File =DOSSIER+".ATEXTE"     [ATX]
Local File =DOSSIER+".ATEXTRA"    [AXX]
Local File =DOSSIER+".ATABZON"    [ATZ2]
Local File =DOSSIER+".ATEXTRA"    [AXX_]
Local File =DOSSIER+".ATABLE"     [ATB_]
Local File =DOSSIER+".ATABZON"    [ATZ_]
Local File =DOSSIER+".ATABIND"    [ATI_]
Local File =DOSSIER+".ATYPE"      [ATY_]
Local File =DOSSIER+".AMSKPAR"    [AMP_]
Local File =DOSSIER+".AWRKLNK"    [AWM_]
Local File =DOSSIER+".AWRKTAB"    [AWK_]
Local File =DOSSIER+".AMSK"       [AMK]
Local File =DOSSIER+".AMSKZON"    [AMZ]
Local File =DOSSIER+".AMSKACT"    [AMA]
Local File =DOSSIER+".AMSKPAR"    [AMP]
Local File =DOSSIER+".ATABLE"     [ATB]
Local File =DOSSIER+".ATABZON"    [ATZ]
Local File =DOSSIER+".ATABIND"    [ATI]
If filinfo(filpath("FIL","ATABAUD","fde",DOSSIER),0)>=0
 Local File =DOSSIER+".ATABAUD"   [ATA]
Endif
Local File =DOSSIER+".AVIEW"      [AVW]
Local File =DOSSIER+".AVIEWD"     [AVD]
Local File =DOSSIER+".AVIEWC"     [AVC]
Local File =DOSSIER+".AVIEWB"     [AVB]
Local File =DOSSIER+".AFONCTION"  [AFC]
Local File =DOSSIER+".AVARLOC"    [AVR]
Local File =DOSSIER+".ACTION"     [ACT]
Local File =DOSSIER+".ACTPAR"     [ATR]
Local File =DOSSIER+".ACTCODPAR"  [AAR]

Local File =DOSSIER+".ATYPE"      [ATY]
Local File =DOSSIER+".ATYPERUL"    [ATYR]
Local File =DOSSIER+".ATYPERPAR"   [ATYRP]
Local File =DOSSIER+".ATYPELNK"    [ATYL]
Local File =DOSSIER+".ATYPELPAR"   [ATYLP]

Local File =DOSSIER+".ATYPEPRO"     [ATYP]
Local File =DOSSIER+".ACONTEXT"     [ACTX]
Local File =DOSSIER+".AOBJET"       [AOB]
Local File =DOSSIER+".AOBJTAB"      [AOT]
Local File =DOSSIER+".AOBJLST"      [AOL]
Local File =DOSSIER+".AOBJEXT"      [AOE]
Local File =DOSSIER+".AOBJEXTD"     [AOD]
Local File =DOSSIER+".AMENLOC"      [AML]
Local File =DOSSIER+".APLSTD"       [AST]
Local File =DOSSIER+".APLSTD"       [AST2]
Local File =DOSSIER+".ATABDIV"      [ADI]
Local File =DOSSIER+".ATABTAB"      [ADV]
Local File =DOSSIER+".ADOPAR"       [ADP]
Local File =DOSSIER+".AGLOBVAR"     [AGB]
Local File =DOSSIER+".ACONSTANT"    [ACST]
Local File =DOSSIER+".ADOCFLD"      [ADZ]
Local File =DOSSIER+".ACTL"         [ACL]
Local File =DOSSIER+".ACTIV"        [ACV]
Local File =DOSSIER+".AWINDOW"      [AWI]
Local File =DOSSIER+".AWINBRO"      [AWB]
Local File =DOSSIER+".AWINBOUT"     [AWT]
Local File =DOSSIER+".AWINPAR"      [AWP]
Local File =DOSSIER+".ACLOB"        [ACB]
Local File =DOSSIER+".TABFOR"       [TFO]
Local File =DOSSIER+".AWEBSERVIC"   [AWE]
Local File =DOSSIER+".AWEBSERDES"   [AWY]
Local File =DOSSIER+".AGDPRSETTING" [AGS]
Local File =DOSSIER+".AUTILITY"     [AUTI]

If GSOPHIA & nomap="MNTPRD"
 Local File =DOSX3+".ATEXTE"     [ATX_]
Else
 Local File =DOSSIER+".ATEXTE"   [ATX_]
Endif

#cg 4 juillet 2011 specifique indus
Local File =DOSSIER+".ATEXTE"   [ITX_]

Read [ADW]ADW0 = "";"";"TYPDOS"
If GPRODUIT<>val([F:ADW]VALEUR)-1
 # Ce dossier existe et n'est pas un dossier du produit courant
 Call ERREUR(DOSSIER-":"-mess(197,126,1)) From GESECRAN
 End
Endif

adxifs = ","
adxirs = chr$(10)
adxium = GUTF8
Openo FICPATCH , 0

# En-tête fichier

CHAINE = ""
For I=1 To NBLAN
 If len(CHAINE)+len(LANGUE(I))+1>type(CHAINE)-20
  Break
 Endif
 If I>1 : CHAINE += "/" : Endif
 CHAINE += LANGUE(I)
Next I
Raz CHAINE2
J = 1
For I=1 To NBACT
 If len(CHAINE2(J))+len(ACTIV(I))+1>type(CHAINE2)-20
  J += 1
 Elsif I>1
  CHAINE2(J) += "/"
 Endif
 CHAINE2(J) += ACTIV(I)
Next I

Wrseq '1';'"'+COMMENT+'"';'"'+CHAINE+'"';'"'+VERSION+'"';'"'+CHAINE2(1)+'"';'"'+PRODUIT+'"';'"'+num$(TYPPTC)+'"';
For J=2 To dim(CHAINE2)
 If CHAINE2(J)<>""
  Wrseq '"'+CHAINE2(J)+'"';
 Endif
Next J
Wrseq

# Boucle sur objet
For P=1 To NBOBJ
 I = P : # mb 8.4.9 Pour le moment
 CLEOBJ = NOMOBJ(P)
 ABROBJ = TYPOBJ(P)
 INTOBJ = INTITOBJ(P)
 Wrseq '2';'"'+ABROBJ+'"';'"'+CLEOBJ+'"';'"'+INTOBJ+'"' : # Entête objet
 Gosub OBJET
 If ABROBJ<>"AY"
  Wrseq '7';'"'+ABROBJ+'"';'"'+CLEOBJ+'"';'"'+INTOBJ+'"' : # Fin objet
 Endif
 If P=NBOBJ : Break : Endif
Next P

# Fin fichier

Wrseq '8';'"'+COMMENT+'"'

Openo

GDOSX3 = OGDOSX3
End

#------------------------------------------#
$OBJET
Case ABROBJ
 When "AAA"   : Gosub PATCH         From APATCHMOD
 When "ABA"   : Gosub ABONNEMENTS   From APATCH2
 When "ABF"   : Gosub TABLE_FAIT    From APATCH2
 When "ABG"   : Gosub GRP_TACHES    From APATCH2
 When "ABI"   : Gosub DIMENSION     From APATCH2
 When "ABM"   : Gosub DATAMART      From APATCH2
 When "ABO"   : Gosub ETAT_BO       From APATCH2
 When "ABT"   : Gosub TACHES        From APATCH2
 When "ABV"   : Gosub SYNCHRO_ABI   From APATCH2
 When "ACD"   : Gosub PLAGE         From APATCH2
 When "ACL"   : Gosub TAB_CONTROLE  From APATCH2
 When "ACLA"  : Gosub CLASSE        From APATCH2
 When "ACN"   : Gosub CONSULT       From APATCH2
 When "ACT"   : Gosub SACTION       From APATCH2
 When "ACST"  : Gosub ACONSTANT     From APATCH2
 When "ACTX"  : Gosub CONTEXT       From APATCH2
 When "ACV"   : Gosub ACTIV         From APATCH2
 When "ADC"   : Gosub DICTRT        From APATCH2
 When "ADF"   : Gosub LIENS_DOC     From APATCH2
 When "ADI"   : Gosub TABDIV        From APATCH2
 When "ADO"   : Gosub DOCUMENTATION From APATCH2
 When "ADP"   : Gosub PARAM         From APATCH2
 When "ADV"   : Gosub PARAM_DIV     From APATCH2
 When "ADX"   : Gosub TRTBIN        From APATCH2
 When "ADZ"   : Gosub AIDE_CHAMP    From APATCH2
 When "AFC"   : Gosub FONCTION      From APATCH2
 When "AGB"   : Gosub GLOBVAR       From APATCH2
 When "AGS"   : Gosub AGDPRSETTING  From APATCH2
 When "AHH"   : Gosub HIERARCHIE    From APATCH2
 When "AHI"   : Gosub DICEPU        From APATCH2
 When "AII"   : Gosub COND_ABI      From APATCH2
 When "ALH"   : Gosub REQUETES      From APATCH2
 When "ALQ"   : Gosub REQUETES      From APATCH2
 When "ALT"   : Gosub REQUETES      From APATCH2
 When "AMC"   : Gosub MOTCLE        From APATCH2
 When "AMK"   : Gosub ECRAN         From APATCH2
 When "AML"   : Gosub MENLOC        From APATCH2
 When "ANG"   : Gosub NAVIG         From APATCH2
 When "ANM"   : Gosub COMPTEUR      From APATCH2
 When "ANT"   : Gosub NETVIBES      From APATCH2
 When "AOB"   : Gosub OBJET         From APATCH2
 When "AOE"   : Gosub MODELE        From APATCH2
 When "APH"   : Gosub MODELE_APH    From APATCH2
 When "APR"   : Gosub PROCESSUS     From APATCH2
 When "ARA"   : Gosub PATTERN       From APATCH2
 When "ARP"   : Gosub ETAT          From APATCH2
 When "ASU"   : Gosub SUBPRG        From APATCH2
 When "ASW"   : Gosub REPRESENTATION From APATCH2
 When "ASY"   : Gosub STYLES        From APATCH2
 When "ATB"   : Gosub TABLE         From APATCH2
 When "ATN"   : Gosub TRANSACTION   From APATCH2
 When "ATY"   : Gosub ATYPE         From APATCH2
 When "ATYP"  : Gosub ATYPEPRO      From APATCH2
 When "AUR"   : Gosub URL           From APATCH2
 When "AUTI"  : Gosub AUTILITY      From APATCH2
 When "AVW"   : Gosub VUE           From APATCH2
 When "AWA"   : Gosub REGLE_WRK     From APATCH2
 When "AWE"   : Gosub WEBSERVICE    From APATCH2
 When "AWI"   : Gosub FENETRE       From APATCH2
 When "AWM"   : Gosub MODELE_WRK    From APATCH2
 When "AWR"   : Gosub AFFECT_WRK    From APATCH2
 When "AWW"   : Gosub PARAM_WRK     From APATCH2
 When "BIA"   : Gosub BIAR          From APATCH2
 When "ELT"   : Gosub WEB           From APATCH2
 When "ETA"   : Gosub ETABIN        From APATCH2
 #2016/01/26 The type FIC doesn't exist anymore When "FIC"   : Gosub FICSEQ        From APATCH2
 When "IND"   : Gosub INDTEX        From APATCHIND
 When "TAB"   : Gosub TABNEUTRE     From APATCH2
 When "TFO"   : Gosub TABFOR        From APATCH2
 When "TRT"   : Gosub TRAITEMENT    From APATCH2
 When "TXT"   : Gosub TEXTE         From APATCH2
 When "AY","AYS","AYG","AYD","AYF","AYE","AYB","AYW","AYA","AYL","AYO","AYI","AYM","AYC","AYU","ELX"
  ACTIONX = "CREEXE" : Gosub ACTION_XTEND
 When Default
  OK = 1
  ACTIONX = "CREEXE" : Gosub ACTION_PRODUIT
  If OK
   Gosub DIVERS From APATCH2
  Endif
Endcase
Return

#--------------#
$SET_TYP
Local Integer NBTEX , OKACT
Local Char    TEX(10)(1..), TEXTE(50)(1..,1..2) , ACTIONX(10)
NBTEX = 0
NBTEX += 1 : TEX(NBTEX) = "ABA" : TEXTE(NBTEX,2) = mess(96,134,1)  : # Abonnements
NBTEX += 1 : TEX(NBTEX) = "ABT" : TEXTE(NBTEX,2) = mess(92,134,1)  : # Taches batch
NBTEX += 1 : TEX(NBTEX) = "ABG" : TEXTE(NBTEX,2) = mess(97,134,1)  : # Groupes de tâches
NBTEX += 1 : TEX(NBTEX) = "ACL" : TEXTE(NBTEX,2) = mess(111,133,1) : # Table de contrôle
NBTEX += 1 : TEX(NBTEX) = "ACN" : TEXTE(NBTEX,2) = mess(15,126,1)  : # Consultation
NBTEX += 1 : TEX(NBTEX) = "ACT" : TEXTE(NBTEX,2) = mess(30,124,1)  : # Action
NBTEX += 1 : TEX(NBTEX) = "ACV" : TEXTE(NBTEX,2) = mess(14,115,1)  : # Code activité
NBTEX += 1 : TEX(NBTEX) = "ADC" : TEXTE(NBTEX,2) = mess(111,125,1) : # Traitement (dico)
If func AFNC.ACTIVDOS([L]DOSSIER,"ABI")
 NBTEX += 1 : TEX(NBTEX) = "ABM" : TEXTE(NBTEX,2) = mess(41,127,1)  : # Datamart
 NBTEX += 1 : TEX(NBTEX) = "ABF" : TEXTE(NBTEX,2) = mess(63,148,1)  : # Table de fait
 NBTEX += 1 : TEX(NBTEX) = "ABI" : TEXTE(NBTEX,2) = mess(6,16,1)    : # Dimension
 NBTEX += 1 : TEX(NBTEX) = "AHH" : TEXTE(NBTEX,2) = mess(43,127,1)  : # Hierarchie
 NBTEX += 1 : TEX(NBTEX) = "ABV" : TEXTE(NBTEX,2) = mess(10,148,1)  : # Règle de synchronisation
 NBTEX += 1 : TEX(NBTEX) = "AII" : TEXTE(NBTEX,2) = mess(44,127,1)  : # Conditions prédéfnies
 NBTEX += 1 : TEX(NBTEX) = "ABO" : TEXTE(NBTEX,2) = mess(42,127,1)  : # Etats Business Objects
 NBTEX += 1 : TEX(NBTEX) = "BIA" : TEXTE(NBTEX,2) = mess(83,148,1)  : # Objets biar
Endif
NBTEX += 1 : TEX(NBTEX) = "ADI" : TEXTE(NBTEX,2) = mess(75,125,1)  : # Tables diverses
NBTEX += 1 : TEX(NBTEX) = "ADF" : TEXTE(NBTEX,2) = mess(138,139,1) : # Liens de documentation
NBTEX += 1 : TEX(NBTEX) = "ADO" : TEXTE(NBTEX,2) = mess(108,139,1) : # Documentation
NBTEX += 1 : TEX(NBTEX) = "ADP" : TEXTE(NBTEX,2) = mess(81,123,1)  : # Paramètre
NBTEX += 1 : TEX(NBTEX) = "ADX" : TEXTE(NBTEX,2) = mess(44,115,1)  : # Traitement (adx)
NBTEX += 1 : TEX(NBTEX) = "ADV" : TEXTE(NBTEX,2) = mess(136,125,1) : # Paramètrage tables diverses
NBTEX += 1 : TEX(NBTEX) = "ADZ" : TEXTE(NBTEX,2) = mess(189,151,1) : # Aide sur champ
NBTEX += 1 : TEX(NBTEX) = "AFC" : TEXTE(NBTEX,2) = mess(33,124,1)  : # Fonction
NBTEX += 1 : TEX(NBTEX) = "AGB" : TEXTE(NBTEX,2) = mess(122,139,1) : # Variable globale
NBTEX += 1 : TEX(NBTEX) = "ACST": TEXTE(NBTEX,2) = mess(1,47,1)    : # Variable constante
NBTEX += 1 : TEX(NBTEX) = "AGS" : TEXTE(NBTEX,2) = mess(26,42,1)   : # GDPR Setting
NBTEX += 1 : TEX(NBTEX) = "AHI" : TEXTE(NBTEX,2) = mess(110,125,1) : # Formule d'épuration
NBTEX += 1 : TEX(NBTEX) = "ALH" : TEXTE(NBTEX,2) = mess(2,7818,1)  : # Requetes
NBTEX += 1 : TEX(NBTEX) = "ALQ" : TEXTE(NBTEX,2) = mess(3,7818,1)  : # Requetes SQL
NBTEX += 1 : TEX(NBTEX) = "ALT" : TEXTE(NBTEX,2) = mess(261,139,1) : # Requetes graphiques
NBTEX += 1 : TEX(NBTEX) = "AMK" : TEXTE(NBTEX,2) = mess(2,42,1)    : # Ecran
NBTEX += 1 : TEX(NBTEX) = "AML" : TEXTE(NBTEX,2) = mess(3,95,1)    : # Message
NBTEX += 1 : TEX(NBTEX) = "ANG" : TEXTE(NBTEX,2) = mess(101,125,1) : # Navigation
NBTEX += 1 : TEX(NBTEX) = "ANM" : TEXTE(NBTEX,2) = mess(184,100,1) : # Compteur
NBTEX += 1 : TEX(NBTEX) = "AOB" : TEXTE(NBTEX,2) = mess(15,124,1)  : # Objet
NBTEX += 1 : TEX(NBTEX) = "AOE" : TEXTE(NBTEX,2) = mess(97,141,1)  : # Modèle import-export
NBTEX += 1 : TEX(NBTEX) = "ARP" : TEXTE(NBTEX,2) = mess(46,115,1)  : # Etats (dico)
NBTEX += 1 : TEX(NBTEX) = "ASU" : TEXTE(NBTEX,2) = mess(207,124,1) : # Sous-programmes
NBTEX += 1 : TEX(NBTEX) = "ATB" : TEXTE(NBTEX,2) = mess(56,123,1)  : # Tables
NBTEX += 1 : TEX(NBTEX) = "ATN" : TEXTE(NBTEX,2) = mess(109,125,1) : # Transaction
NBTEX += 1 : TEX(NBTEX) = "ATY" : TEXTE(NBTEX,2) = mess(164,124,1) : # Type de données
NBTEX += 1 : TEX(NBTEX) = "ATYP" : TEXTE(NBTEX,2) = mess(237,143,1) : # Content type
NBTEX += 1 : TEX(NBTEX) = "AUR" : TEXTE(NBTEX,2) = mess(208,124,1) : # Définition des URL
NBTEX += 1 : TEX(NBTEX) = "AVW" : TEXTE(NBTEX,2) = mess(15,127,1)  : # Vues
NBTEX += 1 : TEX(NBTEX) = "AWA" : TEXTE(NBTEX,2) = mess(55,75,1)   : # Règle Workflow
NBTEX += 1 : TEX(NBTEX) = "AWI" : TEXTE(NBTEX,2) = mess(14,126,1)  : # Fenêtre
NBTEX += 1 : TEX(NBTEX) = "AWM" : TEXTE(NBTEX,2) = mess(152,75,1)  : # Modeles de données Worflow
NBTEX += 1 : TEX(NBTEX) = "AWR" : TEXTE(NBTEX,2) = mess(153,75,1)  : # Règles d'affection Workflow
NBTEX += 1 : TEX(NBTEX) = "AWW" : TEXTE(NBTEX,2) = mess(154,75,1)  : # Plan travail Workflow
NBTEX += 1 : TEX(NBTEX) = "ELT" : TEXTE(NBTEX,2) = mess(206,133,1) : # Elément web
NBTEX += 1 : TEX(NBTEX) = "ETA" : TEXTE(NBTEX,2) = mess(45,115,1)  : # Etat (rpt)
NBTEX += 1 : TEX(NBTEX) = "EXE" : TEXTE(NBTEX,2) = mess(193,123,1) : # Exécution trt
NBTEX += 1 : TEX(NBTEX) = "TAB" : TEXTE(NBTEX,2) = mess(117,126,1) : # Table (contenu)
NBTEX += 1 : TEX(NBTEX) = "TRT" : TEXTE(NBTEX,2) = mess(43,115,1)  : # Traitement (src)
NBTEX += 1 : TEX(NBTEX) = "TXT" : TEXTE(NBTEX,2) = mess(49,115,1)  : # Texte (txt)
NBTEX += 1 : TEX(NBTEX) = "ASY" : TEXTE(NBTEX,2) = mess(23,42,1)   : # Styles
NBTEX += 1 : TEX(NBTEX) = "APH" : TEXTE(NBTEX,2) = mess(1,143,1)   : # Modèles de patch
NBTEX += 1 : TEX(NBTEX) = "ACD" : TEXTE(NBTEX,2) = mess(64,143,1)  : # Plages de développement
NBTEX += 1 : TEX(NBTEX) = "AAA" : TEXTE(NBTEX,2) = mess(3,143,1)   : # Patch d'après un modèle
NBTEX += 1 : TEX(NBTEX) = "TFO" : TEXTE(NBTEX,2) = mess(4,74,1)    : # Formules
NBTEX += 1 : TEX(NBTEX) = "APR" : TEXTE(NBTEX,2) = mess(88,134,1)  : # Processus
NBTEX += 1 : TEX(NBTEX) = "AWE" : TEXTE(NBTEX,2) = mess(4,924,1)   : # Web services
NBTEX += 1 : TEX(NBTEX) = "ANT" : TEXTE(NBTEX,2) = mess(20,7958,1) : # Netvibes
NBTEX += 1 : TEX(NBTEX) = "ACLA" : TEXTE(NBTEX,2) = mess(254,125,1): # Classes données
NBTEX += 1 : TEX(NBTEX) = "ASW" : TEXTE(NBTEX,2) = mess(255,125,1) : # Classes représentations
NBTEX += 1 : TEX(NBTEX) = "ARA" : TEXTE(NBTEX,2) = mess(70,143,1)  : # Fichiers pattern
NBTEX += 1 : TEX(NBTEX) = "IND" : TEXTE(NBTEX,2) = mess(79,143,1)  : # Traduction
NBTEX += 1 : TEX(NBTEX) = "ACTX" : TEXTE(NBTEX,2) = mess(293,139,1) : # Code contexte
NBTEX += 1 : TEX(NBTEX) = "AMC"  : TEXTE(NBTEX,2) = mess(120,124,1) : # Mots-clés
NBTEX += 1 : TEX(NBTEX) = "AUTI" : TEXTE(NBTEX,2) = mess(27,42,1)   : # Utility processes
If func AFNC.ACTIVDOS([L]DOSSIER,"AYT")
 ACTIONX = "CRELST" : Gosub ACTION_XTEND
Endif
ACTIONX = "CRELST" : Gosub ACTION_PRODUIT
Return

#--------------------------------------------------------------------#
$SEL_LISTE
Case LISTE
 When "ALISTYPATC" : Gosub LIS_TYPATC
Endcase
Return

#-----------------#
$LIS_TYPATC
Local Char DOSSIER(GLONADD)
[L]DOSSIER = PARAM(1)
If DOSSIER="" : DOSSIER = nomap : Endif
Gosub SET_TYP
For I=1 To NBTEX
 TEXTE(I,1) = TEX(I)
Next I
Sorta NBTEX TEX Order By TEX(indice+1)
For I=1 To NBTEX
 J = find(TEX(I),TEXTE(1..NBTEX,1))
 If J<>I
  TEXTE(J,1) = TEXTE(I,2)
  TEXTE(I,2) = TEXTE(J,2)
  TEXTE(J,2) = TEXTE(J,1)
  TEXTE(J,1) = TEXTE(I,1)
  TEXTE(I,1) = TEX(I)
 Endif
Next I
TIT(0) = mess(181,139,1) : # Types d'objets gérés par un patch
TIT(1) = mess(59,100,1)  : # Type
TIT(2) = mess(30,109,1)  : # Intitulé
Return

#--------------------------------------------------------------------#
$TRT_DIV
Case TRAIT
 When "ACTLTYPATC" : Gosub CTL_TYPATC
 When "ACTLOBJPAT" : Gosub CTL_OBJPAT
Endcase
Return

#--------------#
$CTL_TYPATC
Local Char DOSSIER(GLONADD) , ACTIONX(10)
[L]DOSSIER = PARAM(1)
If [L]DOSSIER="" : [L]DOSSIER = nomap : Endif
Gosub SET_TYP
If !find(VALEUR,TEX(1..NBTEX))
 Local File =[L]DOSSIER+".ATABLE" [ATB]
 Read [ATB]ABRFIC = VALEUR
 If !fstat
  GBIDC1 = [F:ATB]CODFIC
  If [L]DOSSIER<>nomap
   Local File =[L]DOSSIER+".ATEXTE" [ATX] , =[L]DOSSIER+".ATEXTRA" [AXX]
  Endif
  Call TEXTE([F:ATB]INTITFIC,[M]INTITOBJ(nolign-1)) From OBJDIV
 Else
  GMESSAGE = mess(42,115,1) : mkstat = 2 : End : # Type d'objet incorrect
 Endif
Endif
If find(VALEUR,"AY","AYS","AYG","AYD","AYF","AYE","AYB","AYW","AYA","AYL","AYO","AYI","AYM","AYC","AYU","ELX")
 ACTIONX = "C_TYPOBJ" : Gosub ACTION_XTEND
Endif
ACTIONX = "C_TYPOBJ" : Gosub ACTION_PRODUIT
Return

#--------------#
$CTL_OBJPAT
Local Char    FIC(20) , ACTIONX(10) , TYPS(250) , CODS(250) , PRG(255) , SUBPRG(255), COD1(30)
Local Char    DOSSIER(GLONADD) , OBJTYP(10) , FLDLAN(20) , INTIT(80) , CRITERE(250)
Local Char    ME(80)
Local Integer ER , OKTRT , L , M
DOSSIER = PARAM(1)
If DOSSIER="" : DOSSIER = nomap : Endif
If DOSSIER<>nomap
 Local File =DOSSIER+".ATEXTE" [ATX] , =DOSSIER+".ATEXTRA" [AXX]
Endif
OBJTYP = PARAM(2)
FLDLAN = PARAM(3)
Case OBJTYP
 When "ABA"       : VALEUR = vireblc(format$("K:"+num$(GLONABA)+"c",VALEUR),2)
 When "ABT"       : VALEUR = vireblc(format$("K:"+num$(GLONABT)+"c",VALEUR),2)
 When "ABG"       : VALEUR = vireblc(format$("K:"+num$(GLONABG)+"c",VALEUR),2)
 When "ACL"       : VALEUR = vireblc(format$("K:"+num$(GLONACL)+"c",VALEUR),2)
 When "ACN"       : VALEUR = vireblc(format$("K:"+num$(GLONACN)+"c",VALEUR),2)
 When "ACT"       : VALEUR = vireblc(format$("K:"+num$(GLONACT)+"c",VALEUR),2)
 When "ACV"       : VALEUR = vireblc(format$("K:"+num$(GLONACV)+"c",VALEUR),2)
 When "ADC"       : VALEUR = vireblc(format$("K:"+num$(GLONADC)+"c",VALEUR),2)
 When "ADF"       : VALEUR = vireblc(VALEUR,2)
 When "ADI"       : VALEUR = vireblc(format$("K:5c",VALEUR),2)
 When "ADO"       : VALEUR = vireblc(VALEUR,2)
 When "ADP"       : VALEUR = vireblc(format$("K:"+num$(GLONADP)+"c",VALEUR),2)
 When "ADV"       : VALEUR = vireblc(format$("K:5c",VALEUR),2)
 When "ADX","EXE" : VALEUR = vireblc(format$("K:"+num$(GLONADC)+"c",VALEUR),2)
 When "ADZ"       : VALEUR = vireblc(VALEUR,2)
 When "AFC"       : VALEUR = vireblc(format$("KT:"+num$(GLONAFC)+"X",VALEUR),2)
 When "AGB"       : VALEUR = vireblc(format$("K:"+num$(GLONAGB)+"c",VALEUR),2)
 When "ACST"      : VALEUR = vireblc(format$("K:"+num$(GLONACST)+"c",VALEUR),2)
 When "AGS"       : VALEUR = vireblc(format$("K:"+num$(GLONAGS)+"c",VALEUR),2)
 When "ACTX"      : VALEUR = vireblc(format$("K:"+num$(GLONACTX)+"c",VALEUR),2)
 When "AHI"       : VALEUR = vireblc(format$("K:"+num$(GLONAHI)+"c",VALEUR),2)
 When "ALH"       : VALEUR = vireblc(format$("K:"+num$(GLONALH)+"c",VALEUR),2)
 When "ALQ"       : VALEUR = vireblc(format$("K:"+num$(GLONALH)+"c",VALEUR),2)
 When "ALT"       : VALEUR = vireblc(format$("K:"+num$(GLONALH)+"c",VALEUR),2)
 When "ABM"       : VALEUR = vireblc(format$("K:"+num$(GLONABM)+"c",VALEUR),2)
 When "AMK"       : VALEUR = vireblc(format$("KT:"+num$(GLONAMK)+"X",VALEUR),2)
 When "AML"       : VALEUR = vireblc(format$("K:5c",VALEUR),2)
 When "ANG"       : VALEUR = vireblc(format$("K:"+num$(GLONANG)+"c",VALEUR),2)
 When "ANM"       : VALEUR = vireblc(format$("K:"+num$(GLONANM)+"c",VALEUR),2)
 When "AOB"       : VALEUR = vireblc(format$("KT:"+num$(GLONAOB)+"X",VALEUR),2)
 When "AOE"       : VALEUR = vireblc(format$("K:"+num$(GLONAOE)+"c",VALEUR),2)
 When "ARP"       : VALEUR = vireblc(format$("K:"+num$(GLONARP)+"c",VALEUR),2)
 When "ASU"       : VALEUR = vireblc(VALEUR,2)
 When "ATB"       : VALEUR = vireblc(format$("KT:"+num$(GLONATB)+"X",VALEUR),2)
 When "ATN"       : VALEUR = vireblc(format$("K:"+num$(GLONATN)+"c",VALEUR),2)
 When "ATY"       : VALEUR = vireblc(format$("K:"+num$(GLONATY)+"c",VALEUR),2)
 When "ATYP"      : VALEUR = vireblc(format$("K:10c",VALEUR),2)
 When "ASY"       : VALEUR = vireblc(format$("K:"+num$(GLONASY)+"c",VALEUR),2)
 When "AUR"       : VALEUR = vireblc(format$("K:"+num$(GLONAUR)+"c",VALEUR),2)
 When "AUTI"      : VALEUR = vireblc(format$("K:"+num$(GLONAUTIL)+"c",VALEUR),2)
 When "AVW"       : VALEUR = vireblc(format$("KT:"+num$(GLONAVW)+"X",VALEUR),2)
 When "AWA"       : VALEUR = vireblc(format$("K:"+num$(GLONAWA)+"c",VALEUR),2)
 When "ABF"       : VALEUR = vireblc(format$("K:"+num$(GLONABF)+"c",VALEUR),2)
 When "AHH"       : VALEUR = vireblc(format$("K:"+num$(GLONAHH)+"c",VALEUR),2)
 When "ABO"       : VALEUR = vireblc(format$("K:"+num$(GLONABO)+"c",VALEUR),2)
 When "ABV"       : VALEUR = vireblc(format$("K:"+num$(GLONABV)+"c",VALEUR),2)
 When "AII"       : VALEUR = vireblc(format$("K:"+num$(GLONAII)+"c",VALEUR),2)
 When "ABI"       : VALEUR = vireblc(format$("K:"+num$(GLONABI)+"c",VALEUR),2)
 When "AWI"       : VALEUR = vireblc(format$("K:"+num$(GLONFEN)+"c",VALEUR),2)
 When "AWM"       : VALEUR = vireblc(format$("K:"+num$(GLONAWM)+"c",VALEUR),2)
 When "AWR"       : VALEUR = vireblc(VALEUR,2)
 When "AWW"       : VALEUR = vireblc(format$("K:"+num$(GLONAWW)+"c",VALEUR),2)
 When "ELT","BIA" : VALEUR = vireblc(VALEUR,2)
 When "ETA"       : VALEUR = vireblc(format$("K:"+num$(GLONACR)+"X",VALEUR),2)
 When "EXE"       : VALEUR = vireblc(format$("K:"+num$(GLONADC)+"c",VALEUR),2)
 When "TAB"       : VALEUR = vireblc(VALEUR,2)
 When "TRT"       : VALEUR = vireblc(format$("K:"+num$(GLONADC)+"c",VALEUR),2)
 When "TXT"       : VALEUR = vireblc(VALEUR,2)
 When "TFO"       : VALEUR = vireblc(VALEUR,2)
 When "APR"       : VALEUR = vireblc(VALEUR,2)
 When "AWE"       : VALEUR = vireblc(VALEUR,2)
 When "IND"       : VALEUR = vireblc(VALEUR,2)
 When "ANT"       : VALEUR = vireblc(format$("K:"+num$(GLONANT)+"c",VALEUR),2)
 When "ACLA"       : VALEUR = vireblc(format$("K:"+num$(GLONACLA)+"c",VALEUR),2)
 When "ASW"       : VALEUR = vireblc(format$("K:"+num$(GLONASW)+"c",VALEUR),2)
 When "AMC"       : VALEUR = vireblc(VALEUR,2)
 When "AY","AYS","AYG","AYD","AYF","AYE","AYB","AYW","AYA","AYL","AYO","AYI","AYM","AYC","AYU","ELX"
                    VALEUR = vireblc(VALEUR,2)
 When Default     : Local Integer CTL_OBJPAT
                  : ACTIONX = "CTL_OBJPAT" : Gosub ACTION_PRODUIT
                  : If !CTL_OBJPAT & OBJTYP<>"AAA"
                  :  VALEUR = vireblc(format$("KT:80X",VALEUR),2)
                  :  If instr(1,VALEUR,'"') & instr(1,VALEUR,"'")
                  :   GMESSAGE = '" :'-mess(94,123,1) : # Caractère interdit
                  :   mkstat = 2 : End
                  :  Elsif instr(1,VALEUR,'"')
                  :   VALEUR = ctrans(VALEUR,'"',"'")
                  :  Endif
                  : Endif
Endcase
Case OBJTYP
 When "ABA"
  Local File ABATABT [ABA]
  Call CONTROLE("ABA","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : INTIT = [F:ABA]NOMABT : Endif
 When "ABT"
  Local File ABATTAC [ABT]
  Call CONTROLE("ABT","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:ABT]DES,INTIT) From OBJDIV : Endif
 When "ABG"
  Local File ABATGRP [ABG]
  Call CONTROLE("ABG","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:ABG]DES,INTIT) From OBJDIV : Endif
 When "ACL"
  Local File =[L]DOSSIER+".ACTL" [ACL]
  Call CONTROLE("ACL","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat
   mkstat = 1 : End
  Else
   Call LECTEXTRA(INTIT,"ACTL","DES",VALEUR,"") From ATEXTRA
  Endif
 When "ACN"
  Local File =[L]DOSSIER+".ACONSULT" [ACN]
  Call CONTROLE("ACN","",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:ACN]LIBEL,INTIT) From OBJDIV : Endif
 When "ACT"
  Local File =[L]DOSSIER+".ACTION" [ACT]
  Call CONTROLE("ACT","",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:ACT]INTITA,INTIT) From OBJDIV : Endif
 When "ACV"
  Local File =[L]DOSSIER+".ACTIV" [ACV]
  Call CONTROLE("ACV","",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:ACV]LIBACT,INTIT) From OBJDIV : Endif
 When "ADC"
  Local File ADICTRT [ADC]
  Call CONTROLE("ADC","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : INTIT = [F:ADC]DES : Endif
 When "ADF"
  Local File =[L]DOSSIER+".ADOCFNC"  [ADF]
  J = instr(1,VALEUR,"~")
  If J = 0 : GMESSAGE = VALEUR+"\"+mess(83,123,1) : mkstat = 1 : End : Endif : # Valeur incorrecte
  Call CONTROLE("ADF","",right$(VALEUR,J+1),left$(VALEUR,J-1),mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : INTIT = [F:ADF]COD : Endif
 When "ADI","ADV"
  Local File =[L]DOSSIER+".ATABTAB" [ADV]
  Call CONTROLE("ADV","",VALEUR,"",mkstat) From CONTOBJ
  If fstat
   mkstat = 1 : End
  Else
   Call LECTEXTRA(INTIT,"ATABTAB","LNGDES",num$([F:ADV]NUMTAB),"") From ATEXTRA
  Endif
 When "ADO"
  Local File =[L]DOSSIER+".ADOCUMENT"  [ADO]
  J = instr(1,VALEUR,"~")
  If J=0 : GMESSAGE = VALEUR+"\"+mess(83,123,1) : mkstat = 1 : End : Endif : # Valeur
  [L]TYPS = left$(VALEUR,J-1)
  [L]CODS = right$(VALEUR,J+1)
  Onerrgo ER
  CRITERE = ""
  If evalue("dim("+FLDLAN+")")>0
   For I=0 To evalue("dim("+FLDLAN+")")-1
    If evalue(FLDLAN+"(I)")<>""
     If CRITERE=""
      CRITERE = "("
     Else
      CRITERE += " or "
     Endif
     CRITERE += 'LAN="'+evalue(FLDLAN+"(I)")+'"'
    Endif
   Next I
  Endif
  Onerrgo
  If CRITERE<>""
   CRITERE += ") & "
  Endif
  CRITERE += 'TYP="'+[L]TYPS+'" & COD="'+[L]CODS+'"'
  Filter [ADO] Where evalue(CRITERE)
  Read [ADO]ADO0 First
  Filter [ADO]
  If !fstat
   INTIT = [F:ADO]TIT
  Else
   GMESSAGE = VALEUR+"\"+mess(23,100,1) : # Fiche inexistante
   mkstat = 1 : End
  Endif
 When "ADZ"
  Local File =[L]DOSSIER+".ADOCFLD"  [ADZ]
  Onerrgo ER
  OK = 0
  If evalue("dim("+FLDLAN+")")>0
   For I=0 To evalue("dim("+FLDLAN+")")-1
    If evalue(FLDLAN+"(I)")<>""
     Read [ADZ]ADZ0=evalue(FLDLAN+"(I)");[L]VALEUR
     If !fstat : OK = 1 : Break : Endif
    Endif
   Next I
  Endif
  Onerrgo
  If !OK
   GMESSAGE = VALEUR+"\"+mess(23,100,1) : # Fiche inexistante
   mkstat = 1 : End
  Endif
 When "ADP"
  Local File =[L]DOSSIER+".ADOPAR"  [ADP]
  Read [ADP]ADP1 = VALEUR
  If fstat
   GMESSAGE+="\"+mess(23,100,1) : # Fiche inexistante
   mkstat = 1 : End
  Else
   Call TEXTE([F:ADP]NAM,INTIT) From OBJDIV
  Endif
 When "ADX"
  Call EXISTE_ADX("",[L]DOSSIER,VALEUR,OKTRT) From ORDSYS
  If !OKTRT
   GMESSAGE = mess(90,123,1) : # Traitement inexistant
   mkstat = 2 : End
  Else
   If !clalev([F:ADC])   : Local File ADICTRT  [ADC]  : Endif
   Read [ADC]ADC0 = VALEUR
   If !fstat : INTIT= [F:ADC]DES : Endif
  Endif
 When "EXE"
  Call EXISTE_ADX("","",VALEUR,OKTRT) From ORDSYS
  If !OKTRT
   GMESSAGE = mess(90,123,1) : # Traitement inexistant
   mkstat = 2 : End
  Else
   If !clalev([F:ADC])   : Local File ADICTRT  [ADC]  : Endif
   Read [ADC]ADC0 = VALEUR
   If !fstat : INTIT = [F:ADC]DES : Endif
  Endif
 When "AFC"
  Local File =[L]DOSSIER+".AFONCTION" [AFC]
  Call CONTROLE("AFC","",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:AFC]NOM,INTIT) From OBJDIV : Endif
 When "AGB"
  Local File =[L]DOSSIER+".AGLOBVAR" [AGB]
  Call CONTROLE("AGB","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:AGB]INTIT,INTIT) From OBJDIV : Endif
 When "ACST"
  Local File =[L]DOSSIER+".ACONSTANT" [ACST]
  Call CONTROLE("ACST","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:ACST]INTIT,INTIT) From OBJDIV : Endif
 When "ACTX"
  Local File =[L]DOSSIER+".ACONTEXT" [ACTX]
  Call CONTROLE("ACTX","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:ACTX]INTIT,INTIT) From OBJDIV : Endif
 When "AGS"
  Local File =[L]DOSSIER+".AGDPRSETTING" [AGS]
  Call CONTROLE("AGS","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : INTIT="AGDPRSETTING"-VALEUR : Endif
 When "AUTI"
  Local File =[L]DOSSIER+".AUTILITY" [AUTI]
  Call CONTROLE("AUTI","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : INTIT= [F:AUTI]COMMENT : Endif
 When "AUR"
  Local File =[L]DOSSIER+".AURL" [AUR]
  Call CONTROLE("AUR","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:AUR]INTIT,INTIT) From OBJDIV : Endif
 When "AHI"
  Local File =[L]DOSSIER+".AHISTO" [AHI]
  Call CONTROLE("AHI","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:AHI]DES,INTIT) From OBJDIV : Endif
 When "ALH"
  Local File =[L]DOSSIER+".ALISTEH" [ALH]
  Call CONTROLE("ALH","",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call LECTEXTRA(INTIT,"ALISTEH","INTIT",[F:ALH]COD,"") From ATEXTRA : Endif
 When "ALQ"
  Local File =[L]DOSSIER+".ALISTEH" [ALH]
  Call CONTROLE("ALQ","",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call LECTEXTRA(INTIT,"ALISTEH","INTIT",[F:ALH]COD,"") From ATEXTRA : Endif
 When "ALT"
  Local File =[L]DOSSIER+".ALISTEH" [ALH]
  Call CONTROLE("ALT","",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call LECTEXTRA(INTIT,"ALISTEH","INTIT",[F:ALH]COD,"") From ATEXTRA : Endif
 When "ABM"
  Local File =[L]DOSSIER+".ABIDATMRT" [ABM]
  Call CONTROLE("ABM","",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:ABM]INTIT,INTIT) From OBJDIV : Endif
 When "AMK"
  Local File =[L]DOSSIER+".AMSK" [AMK]
  Call CONTROLE("AMK","",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:AMK]INTMSK,INTIT) From OBJDIV : Endif
 When "AML"
  Local File =[L]DOSSIER+".AMENLOC" [AML]
  Local File =[L]DOSSIER+".APLSTD"  [AST4]
  Local File =[L]DOSSIER+".APLSTD"  [AST5]
  Local File =[L]DOSSIER+".APLSTD"  [AST6]
  Link [AML]  With [AST4]CLE = [F:AML]MENLOC;0;GLANGUE
&                , [AST5]CLE = 0;[F:AML]MENLOC;GLANGUE
&                , [AST6]CLE = 200;([F:AML]MENLOC-200);GLANGUE
& As [AML_]
& Order By Key MENLOC
  Call CONTROLE("AML","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat
   mkstat = 1 : End
  Else
   Read [AML_]MENLOC=val(VALEUR)
   INTIT =  string$([F:AML]MENLOC<100&[F:AML]MENLOCAL=2,[F:AST5]LANMES)
   INTIT -= string$([F:AML]MENLOC>200&[F:AML]MENLOCAL=2,[F:AST6]LANMES)
   INTIT -= string$([F:AML]MENLOCAL<>2,[F:AST4]LANMES)
  Endif
 When "ANG"
  Local File =[L]DOSSIER+".ANAVIG" [ANG]
  Call CONTROLE("ANG","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:ANG]DES,INTIT) From OBJDIV : Endif
 When "ANM"
  Local File =[L]DOSSIER+".ACODNUM" [ANM]
  Call CONTROLE("ANM","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat
   mkstat = 1 : End
  Else
   Call LECTEXTRA(INTIT,"ACODNUM","DES",[F:ANM]CODNUM,"") From ATEXTRA
  Endif
 When "AOB"
  Local File =[L]DOSSIER+".AOBJET" [AOB]
  Call CONTROLE("AOB","",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:AOB]LIBEL,INTIT) From OBJDIV : Endif
 When "AOE"
  Local File =[L]DOSSIER+".AOBJEXT" [AOE]
  Call CONTROLE("AOE","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat
   mkstat = 1 : End
  Else
   Call LECTEXTRA(INTIT,"AOBJEXT","INTIT",[F:AOE]EXT,"") From ATEXTRA
  Endif
 When "ARP"
  Local File =[L]DOSSIER+".AREPORT" [ARP]
  Call CONTROLE("ARP","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:ARP]RPTDES,INTIT) From OBJDIV : Endif
 When "ASU"
  Local File =[L]DOSSIER+".ASUBPROG"  [ASU]
  J = instr(1,VALEUR,"~")
  If J = 0 : GMESSAGE = VALEUR+"\"+mess(83,123,1) : mkstat = 1 : End : Endif :# Valeur
  Call CONTROLE("ASU","",right$(VALEUR,J+1),left$(VALEUR,J-1),mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:ASU]INTIT,INTIT) From OBJDIV : Endif
 When "ATB"
  Local File =[L]DOSSIER+".ATABLE" [ATB]
  Call CONTROLE("ATB","",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:ATB]INTITFIC,INTIT) From OBJDIV : Endif
 When "ATN"
  Local File =[L]DOSSIER+".ATRANSAC" [ATN]
  Call CONTROLE("ATN","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:ATN]DES,INTIT) From OBJDIV : Endif
 When "ATY"
  Local File =[L]DOSSIER+".ATYPE" [ATY]
  Call CONTROLE("ATY","",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:ATY]INTITTYP,INTIT) From OBJDIV : Endif
 When "ASY"
  Local File =[L]DOSSIER+".ASTYLE" [ASY]
  Call CONTROLE("ASY","",VALEUR,"",mkstat) From CONTOBJ
  If !fstat : Call TEXTE([F:ASY]DES,INTIT) From OBJDIV : Endif
 When "AVW"
  Local File =[L]DOSSIER+".AVIEW" [AVW]
  Call CONTROLE("AVW","",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:AVW]INTIT,INTIT) From OBJDIV : Endif
 When "AWA"
  Local File =[L]DOSSIER+".AWRKPAR" [AWA]
  Call CONTROLE("AWA","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call LECTEXTRA(INTIT,"AWRKPAR","INTIT",[F:AWA]CODE,"") From ATEXTRA : Endif
 When "AWI"
  Local File =[L]DOSSIER+".AWINDOW" [AWI]
  Call CONTROLE("AWI","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:AWI]DES,INTIT) From OBJDIV : Endif
 When "ABF"
  Local File =[L]DOSSIER+".ABITABDAT" [ABF]
  Call CONTROLE("ABF","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:ABF]INTIT,INTIT) From OBJDIV : Endif
 When "AHH"
  Local File =[L]DOSSIER+".ABIHIERA" [AHH]
  Call CONTROLE("AHH","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:AHH]DES,INTIT) From OBJDIV : Endif
 When "ABO"
  Local File =[L]DOSSIER+".ABIREPORT" [ABO]
  Call CONTROLE("ABO","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:ABO]DES,INTIT) From OBJDIV : Endif
 When "ABI"
  Local File =[L]DOSSIER+".ABIDIM" [ABI]
  Call CONTROLE("ABI","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:ABI]INTIT,INTIT) From OBJDIV : Endif
 When "ABV"
  Local File =[L]DOSSIER+".ABIREGORG" [ABV]
  Call CONTROLE("ABV","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:ABV]INTIT,INTIT) From OBJDIV : Endif
 When "AII"
  Local File =[L]DOSSIER+".ABICOND" [AII]
  Call CONTROLE("AII","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:AII]DES,INTIT) From OBJDIV : Endif
 When "AWM"
  Local File =[L]DOSSIER+".AWRKLNK" [AWM]
  Call CONTROLE("AWM","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:AWM]INTITMOD,INTIT) From OBJDIV : Endif
 When "AWR"
  Local File =[L]DOSSIER+".AWRKREG"  [AWR]
  Read [AWR]AWR1(1) = VALEUR
  If fstat
   GMESSAGE = VALEUR+"\"+mess(23,100,1) : # Fiche inexistante
   mkstat = 1 : End
  Else
   Call LECTEXTRA(INTIT,"AWRKREG","INTIT",[F:AWR]REGLE,[F:AWR]CPY) From ATEXTRA
  Endif
 When "APR"
  Local File =[L]DOSSIER+".APROCESSUS" [APR]
  J = instr(1,VALEUR,"~")
  If J = 0 : GMESSAGE = VALEUR+"\"+mess(83,123,1) : mkstat = 1 : End : Endif :# Valeur
  Call CONTROLE("APR","",right$(VALEUR,J+1),left$(VALEUR,J-1),mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call LECTEXTRA(INTIT,"APROCESSUS","INTIT1",[F:APR]CODPRO,"") From ATEXTRA: Endif
 When "AWW"
  Local File =[L]DOSSIER+".AWRKTRN" [AWW]
  Call CONTROLE("AWW","#",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call LECTEXTRA(INTIT,"AWRKTRN","INTIT",[F:AWW]WRKTRN,"") From ATEXTRA : Endif
 When "ELT"
  Local Char FICBIN(255) , FIC(255) , SEP(1) , REPERT(255) , EXT(10) , FICWEB(255)
  FICWEB = VALEUR
  Gosub FICWEB From APATCH2
  If filinfo(FICBIN,0)<0
   GMESSAGE = "|"+FICBIN+"|\"+mess(101,100,1) : # Fichier inexistant
   mkstat = 2 : End
  Endif
 When "ARA"
  If filinfo(filpath("PAT",VALEUR,"PAT",[L]DOSSIER),0)<0
   GMESSAGE = "|"+FICBIN+"|\"+mess(101,100,1) : # Fichier inexistant
   mkstat = 2 : End
  Endif
 When "AWE"
  Local File =[L]DOSSIER+".AWEBSERVIC" [AWE]
  Call CONTROLE("AWE","",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call LECTEXTRA(INTIT,"AWEBSERVIC","LIBW",[F:AWE]PUBLI,"") From ATEXTRA : Endif
 When "ANT"
  Local File =[L]DOSSIER+".ANETVIBE" [ANT]
  Call CONTROLE("ANT","",VALEUR,"",mkstat) From CONTOBJ
  If !fstat : Call LECTEXTRA(INTIT,"ANETVIBE","DESLNG",[F:ANT]CODE,"") From ATEXTRA : Endif
 When "ACLA"
  Local File =[L]DOSSIER+".ACLASSE" [ACLA]
  Call CONTROLE("ACLA","",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:ACLA]INTCLA,INTIT) From OBJDIV : Endif
 When "ASW"
  Local File =[L]DOSSIER+".ASHW" [ASW]
  Call CONTROLE("ASW","",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:ASW]INTREP,INTIT) From OBJDIV : Endif
 When "ATYP"
  Local File =[L]DOSSIER+".ATYPEPRO" [ATYP]
  Call CONTROLE("ATYP","",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call TEXTE([F:ATYP]INTIT,INTIT) From OBJDIV : Endif
 When "BIA"
  If filinfo(filpath("BI",VALEUR,"biar",[L]DOSSIER),0)<0
   GMESSAGE = "|"+filpath("BI",VALEUR,"biar",[L]DOSSIER)+"|\"+mess(101,100,1) : # Fichier inexistant
   mkstat = 2 : End
  Endif
 When "ETA"
  OK = 0
  Onerrgo ER
  If evalue("dim("+FLDLAN+")")>0
   For I=0 To evalue("dim("+FLDLAN+")")-1
    If evalue(FLDLAN+"(I)")<>""
     If filinfo(filpath(filpath("REPORT",evalue(FLDLAN+"(I)"),"",[L]DOSSIER),VALEUR,"rpt",[L]DOSSIER),0)>=0
      OK = 1 : Break
     Endif
    Endif
   Next I
  Endif
  If !OK
   GMESSAGE = mess(163,123,1) : # Etat inexistant
   mkstat = 2 : End
  Else
   If !clalev([F:ARP])   : Local File AREPORT  [ARP]  : Endif
   Read [ARP]ARP0 = VALEUR
   If !fstat : Call TEXTE([F:ARP]RPTDES,INTIT) From OBJDIV : Endif
  Endif
 When "GRP"
  mkstat = 1 : # Obsolète en 150
 When "TAB"
  If filinfo(filpath("FIL",VALEUR,"fde",[L]DOSSIER),0)<0
   GMESSAGE = mess(124,124,1) : # Table inexistante
   mkstat = 2 : End
  Else
   Local File =[L]DOSSIER+".ATABLE" [ATB]
   Call CONTROLE("ATB","",VALEUR,"",mkstat) From CONTOBJ
   If !fstat : Call TEXTE([F:ATB]INTITFIC,INTIT) From OBJDIV : Endif
  Endif
 When "TRT"
  If filinfo(filpath("TRT",VALEUR,"src",[L]DOSSIER),0)<0
   GMESSAGE = mess(90,123,1) : # Traitement inexistant
   mkstat = 2 : End
  Else
   If !clalev([F:ADC])   : Local File ADICTRT  [ADC]  : Endif
   Read [ADC]ADC0 = VALEUR
   If !fstat : INTIT = [F:ADC]DES : Endif
  Endif
 When "TXT"
  If left$(VALEUR,1)='"' or left$(VALEUR,1)="'"
   FIC = seg$(VALEUR,2,len(VALEUR)-1)
  Else
   FIC = VALEUR
  Endif
  If filinfo(filpath("TXT",VALEUR,"txt",[L]DOSSIER),0)<0
   GMESSAGE = filpath("TXT",VALEUR,"txt",[L]DOSSIER)-mess(101,100,1) : mkstat = 2 : # Fichier inexistant
  Endif
 When "APH"
  Local File =[L]DOSSIER+".APATCHMOD" [APH]
  Call CONTROLE("APH","",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call LECTEXTRA(INTIT,"APATCHMOD","INTPAT",[F:APH]MODDON,"") From ATEXTRA : Endif
 When "ACD"
  Local File ACTLDEV [ACD]
  Call CONTROLE("ACD","",VALEUR,"",mkstat) From CONTOBJ
  If fstat : mkstat = 1 : End : Else : Call LECTEXTRA(INTIT,"ACTLDEV","INTCOD",[F:ACD]COD,"") From ATEXTRA : Endif
 When "TFO"
  Local File =[L]DOSSIER+".TABFOR" [TFO]
  J = instr(1,VALEUR,"~")
  If J=0 : GMESSAGE = VALEUR+"\"+mess(83,123,1) : mkstat = 1 : End : Endif : # Valeur
  [L]TYPS = left$(VALEUR,J-1)
  [L]CODS = right$(VALEUR,J+1)
  Read [TFO]TFO0 = val(TYPS);CODS
  If !fstat
   Call LECTEXTRA(INTIT,"TABFOR","DES",num$([F:TFO]FORNUM),[F:TFO]FORCOD) From ATEXTRA
  Else
   GMESSAGE = VALEUR+"\"+mess(23,100,1) : # Fiche inexistante
   mkstat = 1 : End
  Endif
 When "AAA"
  Local File =[L]DOSSIER+".AWRKLNK" [AWM]
  Local File =[L]DOSSIER+".ATABDIV" [ADI]
  K = instr(1,VALEUR,"~")
  L = instr(K+1,VALEUR,"~")
  M = instr(L+1,VALEUR,"~")
  If !K & !L & !M
   GMESSAGE = mess(37,124,1) : # Expression incorrecte
   mkstat = 1 : End
  Else
   Call CONTROLE("AWM","#",left$(VALEUR,K-1),"",mkstat) From CONTOBJ
   If !fstat : Call TEXTE([F:AWM]INTITMOD,INTIT) From OBJDIV
   Else      : mkstat = 1 : End
   Endif
   If L>K+1
    Call LECTURE("ADI",seg$(VALEUR,K+1,L-1),"909") From CONTOBJ
    If fstat
     GMESSAGE = seg$(VALEUR,K+1,L-1)-":"-mess(154,139,1) : # Législation inexistante
     mkstat = 1 : End
    Endif
   Endif
   CRITERE = func APATCHMOD.CRITERE(right$(VALEUR,M+1))
   If len(CRITERE)>210
    GMESSAGE = mess(62,123,1) : # Expression trop longue
    mkstat = 1 : End
   Endif
  Endif
 When "AY","AYS","AYG","AYD","AYF","AYE","AYB","AYW","AYA","AYL","AYO","AYI","AYM","AYC","AYU","ELX"
  ACTIONX = "C_NOMOBJ" : Gosub ACTION_XTEND
  If mkstat : End : Endif
 When "IND"
   Call TEXTE(val(VALEUR),INTIT) From OBJDIV
 When "AMC"
  Local File =[L]DOSSIER+".AMOTCLE"  [AMC]
  J = instr(1,VALEUR,"~")
  If J = 0 : GMESSAGE = VALEUR+"\"+mess(83,123,1) : mkstat = 1 : End : Endif :# Valeur
  COD1=left$(VALEUR,J-1)
  COD2=right$(VALEUR,J+1)
  J = instr(1,COD2,"~")
  If J : COD2=left$(COD2,J-1) : Endif
  If clalev([F:AMC])=0 : Local File AMOTCLE [AMC] : Endif
  Read [AMC]AMC0 = val(COD1);COD2
  If fstat
    GMESSAGE = VALEUR+"\"+mess(23,100,1) : # Fiche inexistante
    mkstat = 1 : End
  Else
    If clalev([F:ATB])=0 : Local File ATABLE [ATB] : Endif
    If clalev([F:ASW])=0 : Local File ASHW [ASW] : Endif
    If clalev([F:ACLA])=0 : Local File ACLASSE [ACLA] : Endif
    If clalev([F:AMK])=0 : Local File AMSK [AMK] : Endif
    Case val(COD1)
      When 1 : Read [ATB]CODFIC=COD2
      When 2 : Read [AMK]CODMSK=COD2
      When 3 : Read [ACLA]ACLA0=COD2
      When 4 : Read [ASW]ASW0=COD2
    Endcase
    If !fstat
      Case val(COD1)
        When 1 : Call TEXTE([F:ATB]INTITFIC,INTIT) From OBJDIV
        When 2 : Call TEXTE([F:AMK]INTMSK,INTIT) From OBJDIV
        When 3 : Call TEXTE([F:ACLA]INTCLA,INTIT) From OBJDIV
        When 4 : Call TEXTE([F:ASW]INTREP,INTIT) From OBJDIV
      Endcase
    Endif
  Endif
 When Default
  Local Integer C_NOMOBJ
  ACTIONX = "C_NOMOBJ" : Gosub ACTION_PRODUIT
  If VALEUR="" or parse(VALEUR)<>0 & !C_NOMOBJ
   mkstat = 1 : End : # on a déjà contrôlé les caractères interdits dans le patch
  Elsif mkstat
   End
  Elsif INTIT=""
   ER = 0
   Onerrgo ER
   Local File =[L]DOSSIER+".ATABLE" [ATB]
   If left$(OBJTYP,1)="~"
    OBJTYP = right$(OBJTYP,2)
   Endif
   Read [ATB]ABRFIC = OBJTYP
   If !fstat
    If [F:ATB]TYPFIC=3
     Local File =GDOSX3+"."+[F:ATB]CODFIC [DIV]
    Else
     Local File =[L]DOSSIER+"."+[F:ATB]CODFIC [DIV]
    Endif
    If ER
     # Erreur d'accès sur un fichier
     GMESSAGE = "|"+[F:ATB]CODFIC+"|\"+mess(12,100,1)
     mkstat = 1 : End
    Else
     For [F] Where evalue([L]VALEUR)
      Break
     Next
     If ER
      # Table
      GMESSAGE = mess(56,123,1)-[F:ATB]CODFIC-":"-ME-errmes$(ER)
      mkstat = 1 : End
     Endif
     Close Local File [DIV]
    Endif
   Endif
  Endif
Endcase
Onerrgo ER
If PARAM(4)<>""
 Assign PARAM(4) With ctrans(INTIT,'"',"'")
Endif
Onerrgo
Return

#-----------------------------------------#
$SEL_TABLE
Local Integer ER
Local Char    DOSSIER(GLONADD) , OBJTYP(10) , FLDLAN(20)
DOSSIER = PARAM(1)
If DOSSIER="" : DOSSIER = nomap : Endif
If DOSSIER<>nomap
 Local File =DOSSIER+".ATEXTE" [ATX] , =DOSSIER+".ATEXTRA" [AXX]
Endif
Case TABLE
 When "SELCRYPAT"
  Gosub SEL_CRY From SUBARP
 When "ALISOBJPAT"
  OBJTYP  = PARAM(2)
  FLDLAN  = PARAM(3)
  Case OBJTYP
   When "ABA"
    Local File ABATABT [ABA]
    OBJET = "ABA"
    OPTIONS = "#"
   When "ABT"
    Local File ABATTAC [ABT]
    OBJET = "ABT"
    OPTIONS = "#"
   When "ABG"
    Local File ABATGRP [ABG]
    OBJET = "ABG"
    OPTIONS = "#"
   When "ACL"
    Local File =[L]DOSSIER+".ACTL" [ACL]
    OBJET = "ACL"
    OPTIONS = "#"
   When "ACN"
    Local File =[L]DOSSIER+".ACONSULT" [ACN]
    OBJET = "ACN"
   When "ACT"
    Local File =[L]DOSSIER+".ACTION" [ACT]
    OBJET = "ACT"
   When "ACV"
    Local File =[L]DOSSIER+".ACTIV" [ACV]
    OBJET = "ACV"
   When "ADC"
    Local File ADICTRT [ADC]
    OBJET = "ADC"
   When "ADF"
    Local File =[L]DOSSIER+".ADOCFNC" [ADF]
    OBJET = "ADF"
   When "ADI","ADV"
    Local File =[L]DOSSIER+".ATABTAB" [ADV]
    OBJET = "ADV"
   When "ADO"
    Local File =[L]DOSSIER+".ADOCUMENT" [ADO]
    OBJET = "ADO"
    Onerrgo ER
    CRITERE = ""
    If evalue("dim("+FLDLAN+")")>0
     For I=0 To evalue("dim("+FLDLAN+")")-1
      If evalue(FLDLAN+"(I)")<>""
       If CRITERE=""
        CRITERE = "("
       Else
        CRITERE += " or "
       Endif
       CRITERE += 'LAN="'+evalue(FLDLAN+"(I)")+'"'
      Endif
     Next I
    Endif
    Onerrgo
    If CRITERE<>""
     CRITERE += ")"
    Endif
    If VALEUR<>""
     J = instr(1,VALEUR,"~")
     If J
       EXPSTART = '[F:ADO]TYP="'+left$(VALEUR,J-1)+'"'
       EXPSTART += ' & [F:ADO]COD="'+right$(VALEUR,J+1)+'"'
     Else
       EXPSTART = '[F:ADO]TYP="'+VALEUR+'"'
     Endif
    Endif
   When "ADP"
    Local File =[L]DOSSIER+".ADOPAR" [ADP]
    OBJET = "ADP"
   When "ADX","EXE"
   When "ADZ"
    Local File =[L]DOSSIER+".ADOCFLD" [ADZ]
    OBJET = "ADZ"
    Onerrgo ER
    CRITERE = ""
    If evalue("dim("+FLDLAN+")")>0
     For I=0 To evalue("dim("+FLDLAN+")")-1
      If evalue(FLDLAN+"(I)")<>""
       If CRITERE=""
        CRITERE = "("
       Else
        CRITERE += " or "
       Endif
       CRITERE += 'LAN="'+evalue(FLDLAN+"(I)")+'"'
      Endif
     Next I
    Endif
    Onerrgo
    If CRITERE<>""
     CRITERE += ")"
    Endif
    If VALEUR<>""
     EXPSTART = '[F:ADZ]MOTCLE="'+VALEUR+'"'
    Endif
   When "AFC"
