   When "AML"
    Local File =[L]DOSSIER+".APLSTD"  [AST4]
    Local File =[L]DOSSIER+".APLSTD"  [AST5]
    Local File =[L]DOSSIER+".APLSTD"  [AST6]
    Local File =[L]DOSSIER+".AMENLOC" [AML]
    Link [AML]  With [AST4]CLE = [F:AML]MENLOC;0;GLANGUE
&                  , [AST5]CLE = 0;[F:AML]MENLOC;GLANGUE
&                  , [AST6]CLE = 200;([F:AML]MENLOC-200);GLANGUE
&   As [AML_]
&   Order By Key MENLOC
    Default File [AML_]
    OBJET = "AML"
    ORDRE = "MENLOC"
    OPTIONS = "#"
   When "ANG"
    Local File =[L]DOSSIER+".ANAVIG" [ANG]
    OBJET = "ANG"
    OPTIONS = "#"
   When "ANM"
    Local File =[L]DOSSIER+".ACODNUM" [ANM]
    OBJET = "ANM "
    OPTIONS = "#"
   When "AOB"
    Local File =[L]DOSSIER+".AOBJET" [AOB]
    OBJET = "AOB"
   When "AOE"
    Local File =[L]DOSSIER+".AOBJEXT" [AOE]
    OBJET = "AOE"
    OPTIONS = "#"
   When "ARP"
    Local File =[L]DOSSIER+".AREPORT" [ARP]
    OBJET = "ARP"
   When "ASU"
    Local File =[L]DOSSIER+".ASUBPROG" [ASU]
    OBJET = "ASU"
   When "AWE"
    Local File =[L]DOSSIER+".AWEBSERVIC" [AWE]
    OBJET = "AWE"
   When "ANT"
    Local File =[L]DOSSIER+".ANETVIBE" [ANT]
    OBJET = "ANT"
   When "ACLA"
    Local File =[L]DOSSIER+".ACLASSE" [ACLA]
    OBJET = "ACLA"
   When "ASW"
    Local File =[L]DOSSIER+".ASHW" [ASW]
    OBJET = "ASW"
   When "ATYP"
    Local File =[L]DOSSIER+".ATYPEPRO" [ATYP]
    OBJET = "ATYP"
   When "AMC"
    Local File =[L]DOSSIER+".AMOTCLE" [AMC]
    OBJET = "AMC"
    If VALEUR<>""
     J = instr(1,VALEUR,"~")
     If J
       EXPSTART = '[F:AMC]TYPZON='+left$(VALEUR,J-1)
       EXPSTART += ' & [F:AMC]IDENT1="'+right$(VALEUR,J+1)+'"'
     Else
       EXPSTART = '[F:AMC]TYPZON='+VALEUR
     Endif
    Endif
    ORDRE = "TYPZON;IDENT1"
   When "ATB","TAB"
    Local File =[L]DOSSIER+".ATABLE" [ATB]
    OBJET = "ATB"
   When "APR"
    Local File =[L]DOSSIER+".APROCESSUS" [APR]
    OBJET = "APR"
    OPTIONS = "#"
   When "ATN"
    Local File =[L]DOSSIER+".ATRANSAC" [ATN]
    OBJET = "ATN"
    OPTIONS = "#"
   When "ATY"
    Local File =[L]DOSSIER+".ATYPE" [ATY]
