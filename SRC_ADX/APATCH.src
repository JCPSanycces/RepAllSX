    OBJET = "AVW"
   When "AWA"
    Local File =[L]DOSSIER+".AWRKPAR" [AWA]
    OBJET = "AWA"
    OPTIONS = "#"
   When "AWI"
    Local File =[L]DOSSIER+".AWINDOW" [AWI]
    OBJET = "AWI"
    OPTIONS = "#"
   When "ABF"
    Local File =[L]DOSSIER+".ABITABDAT" [ABF]
    OBJET = "ABF"
    OPTIONS = "#"
   When "AHH"
    Local File =[L]DOSSIER+".ABIHIERA" [AHH]
