    OPTIONS = "#"
   When "AII"
    Local File =[L]DOSSIER+".ABICOND" [AII]
    OBJET = "AII"
    OPTIONS = "#"
   When "ABI"
    Local File =[L]DOSSIER+".ABIDIM" [ABI]
    OBJET = "ABI"
    OPTIONS = "#"
   When "AWM","AAA"
    Local File =[L]DOSSIER+".AWRKLNK" [AWM]
    OBJET = "AWM"
    OPTIONS = "#"
   When "AWR"
    Local File =[L]DOSSIER+".AWRKREG" [AWR]
