#<AdxTL>@(#)9.0.0.0 $Revision$
GTEST=0
Raz GPILOBJ, GPILCOD
Call OBJET("BIS",GBIDC1,"1") From GOBJET
End


$ACTION
Case GACTION
 When "GASTRC"
  Case ACTION
   When "SEL_LISTE" : Gosub SEL_LISTE
  Endcase
Endcase
Return

#################################################
## Zoom sur les pièces comptables ##
#################################################
$SEL_LISTE

Onerrgo ERREUR From CONTROLE
If clalev([F:TVD])=0 : Local File TRCVCRDOC   [TVD]  : Endif
If clalev([F:PIH])=0 : Local File PINVOICE    [PIH]  : Endif
If clalev([F:SIH])=0 : Local File SINVOICE    [SIH]  : Endif
If clalev([F:DAE])=0 : Local File GACCENTRYD  [DAE]  : Endif
Onerrgo
If GERREUR : GERREUR=0 : OK=0 : Return : Endif

NBTEX = 0
Filter [TVD] Where TYPNUM=val(PARAM(1)) & NUM=PARAM(2)
For [TVD]
 Read [HAE]HAE0 = [F:TVD]TYPVCR;[F:TVD]NUMVCR
 If fstat=0
  NBTEX += 1
  TEX(NBTEX) = [F:HAE]TYP-[F:HAE]NUM
 Endif
Next
Filter [TVD]
# Pour inhiber l'action SUITE
If NBTEX>1 : VALEUR="ZZZ" : Endif
Return


$AVANT_SUITE
# Pour inhiber l'action SUITE
If VALBOUT="ZZZ" : OK=0 : Return : Endif
I=instr(1,VALBOUT," ")
If I
 [L]VALC1="GAS" : [L]VALC3=left$(VALBOUT,I-1) : [L]VALC2=right$(VALBOUT,I+1)
 GCONSULT=1
Else
 # Dans le cas où l'action n'aurait rien envoyé => Aucune trace sous la table TRCVCRDOC.
 # Retour à l'ancien "zoom"
 If dim([M:PIH0]NUM)>0
  [L]VALC1="GAS" :  [L]VALC3 = [M:PIH0]GTE : [L]VALC2 = [M:PIH0]NUM
 Elsif dim([M:SIH0]NUM)>0
  [L]VALC1="GAS" :  [L]VALC3 = [M:SIH0]GTE : [L]VALC2 = [M:SIH0]NUM
 Elsif dim([M:BIS0]NUM)>0
  [L]VALC1="GAS" :  [L]VALC3 = [M:BIS0]GTE : [L]VALC2 = [M:BIS0]NUM
 Elsif dim([M:BIC0]NUM)>0
  [L]VALC1="GAS" :  [L]VALC3 = [M:BIC0]GTE : [L]VALC2 = [M:BIC0]NUM
 Else 
  OK=0
 Endif
Endif

Return


