#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque AJS2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:01:10"
A_USER  = "DOC"
A_STAMP = "20181109230110"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask AJS2 [AJS2]
Gosub HORODAT
Local Inpbox "AJS2" From GFONCTION At A_STAMP With A_WINDPREV Mask [AJS2] As [SIM_]
Grizo [AJS2]5
Grizo [AJS2]10
Grizo [AJS2]15
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [AJS2]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=2
X1(1)=1 : X2(1)=74 : Y1(1)=3 : Y2(1)=15
X1(2)=1 : X2(2)=74 : Y1(2)=16 : Y2(2)=23
Return

$ON_RESNAM
Onevent AFTER_CHANGE Gosub AMM_RESNAM From W1AJS2
Onevent BEFORE_INPUT Call AS_RESNAM(zc) From W1AJS2
Return

Subprog AS_RESNAM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_RESNAM(zc) From W1AJS2
Gosub _AFF
End

$AMM_RESNAM
Call AM_RESNAM(zc)
If !mkstat & GOBJET
 zoncou = "RESNAM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_RESNAM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_RESNAM(VALEUR) From AJSSYNC
If mkstat : GERR = 1 : GZONE = "RESNAM" : GZNUM = 42354 : Endif
Gosub _AFF
End

Subprog S_RESNAM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AJSSELREST
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AJSSELREST"
 Call S_TAB_CHAR(VALEUR,PARMSK,"AJSSELREST","AJSSYNC","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_NBLIG
Onevent BEFORE_INPUT Call AS_NBLIG From W1AJS2
Return

Subprog AS_NBLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
mkstat = 2 : GMESSAGE = ""
If !mkstat
Endif
Gosub _AFF
End

$ON_RESCLE
Onevent AFTER_CHANGE Gosub AMM_RESCLE From W1AJS2
Onevent BEFORE_INPUT Call AS_RESCLE(zc) From W1AJS2
Return

Subprog AS_RESCLE(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(6028,GBOUTS) From OBJDIV
Onkey   2 Titled GBOUTS Call S_RESCLE(zc) From W1AJS2
Gosub _AFF
End

$AMM_RESCLE
Call AM_RESCLE(zc)
If !mkstat & GOBJET
 zoncou = "RESCLE" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_RESCLE(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_RESCLE(VALEUR) From AJSSYNC
If mkstat : GERR = 1 : GZONE = "RESCLE" : GZNUM = 2943 : Endif
Gosub _AFF
End

Subprog S_RESCLE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action AJSSELRES
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "AJSSELRES"
 PARMSK(1) = [AJS2]RESNAM
 Call S_TAB_CHAR(VALEUR,PARMSK,"AJSSELRES","AJSSYNC","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

$ON_RESUUID
Onevent AFTER_CHANGE Gosub AMM_RESUUID From W1AJS2
Return

$AMM_RESUUID
Call AM_RESUUID(zc)
If !mkstat & GOBJET
 zoncou = "RESUUID" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_RESUUID(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_RESUUID(VALEUR) From AJSSYNC
If mkstat : GERR = 1 : GZONE = "RESUUID" : GZNUM = 42348 : Endif
Gosub _AFF
End

$CHG_STY
Return


