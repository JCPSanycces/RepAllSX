#<AdxTL>@(#)8.0.0.0 $Revision$
#########################################################################
#                                                                       #
#    MODELISATION E-COMMERCE                                            #
#                                                                       #
# ACTION  : TRTMANALL  : Action traitement allocations manuelles        #
#                                                                       #
#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION

#--- Actions liées au traitement standard
Case ACTION
 When "INIT"       : Gosub INIT
# When "INIT_DIA"   : Gosub INIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "TERMINE"    : Gosub TERMINE
 When Default
Endcase

#--- Actions liées à la fenêtre de saisie criteres DMANALL
If GBOITE="DMANALL"
   Case ACTION
    When "DEBUT"      : Affzo [DIA]1-99
    When "OK"         : GOK=1
    When "END"        : GOK=0 : FIN=1
    When Default
   Endcase
Endif

#--- Actions liées à la fenêtre de saisie principale FMANALL
If GBOITE="FMANALL"
   Case ACTION
    When "SETBOUT"    : Gosub SETBOUT
    When "OUVRE"      : Gosub OUVRE
    When "DEBUT"      : Gosub DEBUT
    When "APRES_MODIF": Gosub APRES_MODIF
    When "SUI"        : Gosub SUIVANT
    When "PRE"        : Gosub PRECEDENT
    When "FIN"        : Gosub FIN
    When "BOUTON"     : Gosub BOUTON
    When "AB1_NBLIG"  : Gosub AB1_NBLIG
    When "BB1_NBLIG"  : Gosub BB1_NBLIG
    When Default
   Endcase
Endif

Return

#########################################################################
#    Actions liés au type traitement et affichage divers                #
#########################################################################
$INIT
Case GACTION
 When "TRTMANALL"  : Gosub INI_TRTMANALL : Gosub INIT_DIA
Endcase
Return
#######################################################################
#    Détail des actions liées au traitement standard                  #
#######################################################################
#######################################################################
$INI_TRTMANALL
GORDCAT=4
# C'est une fonction vente qui travaille sur un site d'expédition
# On surcharge donc le site par défaut du module avec celui d'expédition
# pour que les contrôles d'autorisation des sites soient corrects.
GFCYDEF(0) = GFCYDEF(7)

#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:SOH]) = 0 Local File SORDER      [SOH]:Endif
If clalev([F:SOQ]) = 0 Local File SORDERQ     [SOQ]:Endif
If clalev([F:SOP]) = 0 Local File SORDERP     [SOP]:Endif
If clalev([F:SOC]) = 0 Local File SORDERC     [SOC]:Endif
If clalev([F:ITM]) = 0 Local File ITMMASTER   [ITM]:Endif
If clalev([F:ITS]) = 0 Local File ITMSALES    [ITS]:Endif
If clalev([F:ITV]) = 0 Local File ITMMVT      [ITV]:Endif
If clalev([F:ITF]) = 0 Local File ITMFACILIT  [ITF]:Endif
If clalev([F:ITG]) = 0 Local File ITMCATEG    [ITG]:Endif
If clalev([F:FCY]) = 0 Local File FACILITY    [FCY]:Endif
If clalev([F:BPC]) = 0 Local File BPCUSTOMER  [BPC]: Endif
If GWRHACT=2
   If !clalev([F:WRH])  Local File WAREHOUSE  [WRH] : Endif
   If !clalev([F:ITW])  Local File ITMWRH     [ITW] : Endif
Endif
If clalev([F:SRU]) = 0 Local File TABSTORUL   [SRU]: Endif    :  # Issue 115110

# ------------------------------------------- #
# Alimentation à partir du site de vente      #
#              du site financier    GFINRSP   #
#              de la société        GSOCIETE  #
#              de la devise société GLOCALDEV #
# ------------------------------------------- #
Call GETDEV(GFCYDEF(5)) From DEVSUB
# ------------------------------------------- #
# Récupération des paramêtres de vente        #
# ------------------------------------------- #
Call GLOBVAR(GFCYDEF(5),"VEN") From TRTX3

# --> Récupération du paramètre stock : GENSHT    : Génération des ruptures
Local Char     WPARAM(10)
Call PARAML(GFCYDEF(0),"GENSHT",WPARAM) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
GGENSHT= val(WPARAM)

Return
#######################################################################
$INIT_DIA

Local Char    TIT(50) : TIT = mess(33,191,1)

Local Mask SMANALL1 [DIA]

Raz [M:DIA]
[M:DIA]STOFCY    = GFCYDEF(7)
[M:DIA]SHIDAT=date$
If [M:DIA]DRNFLG = 1
    [M:DIA]DRN= 0
Endif

[M:DIA]GENSHT = GGENSHT
[M:DIA]IMPCLI = GUSERERBPC
If GUSERERBPC=3 [M:DIA]IMPCLI=2 Endif

Call LECMEMO ("STD","[M:DIA]","va2") From GMEMO

Return

#######################################################################
$CONTROLE
If GOK<1   FIN=1   Else   TMP=1   Endif

Return

#######################################################################
$TERMINE

TRA=1
Call FERME_TRACE From LECFIC

Return
#########################################################################
$OUVRE

Local Char    CRITERE(250), CRITERE1(250), CRITENT(160), CRITDET(250)
Local Integer OK, NBALL, WRESULTAT
Local Char    CLECUR(GLONITM), WITMREFFIN(GLONITM), WITMREFDEB(GLONITM), WCLEPREC(GLONITM)
Local Char    WMESS(120), WMESS1(120), WMESS2(80), WMESS3(80)
Local Decimal WALLSTU, WSHTSTU
Local Decimal WALL, WSHT, WCOE, WALLQTY, WDISSTO
Local Decimal WQTY, WQTYSTU, WALLCPS
Local Decimal WALLLINNBR
Local Integer WRET
Local Char    WTRTLIG(1)

Local Char    WTSICOD(20)(0..10)

Local Integer VERROU, NOL
Local Integer WCDTSTA
Local Char    WSALFCY(GLONFCY), WBPCNAM(GLONNAM)

# --> Récupération du paramètre vente : GSOHAPPALL    : Allocation des commandes non signées
Local Char     WPARAM(GLONADP)
Call PARAML([M]STOFCY,"SOHAPPALL",WPARAM) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
GSOHAPPALL= val(WPARAM)
# --> Récupération du paramètre vente : GSOHAPPORD    : Encours si commandes non signées
Local Char     WPARAM(GLONADP)
Call PARAML([M:DIA]STOFCY,"SOHAPPORD",WPARAM) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
GSOHAPPORD= val(WPARAM)

Gosub SEL_SOQ
Raz CLECUR
If [M]ITMREFDEB=[M]ITMREFFIN & [M]ITMREFDEB <> ""
    CLECUR = [M]ITMREFDEB
    WITMREFDEB = [M]ITMREFDEB
    WITMREFFIN = [M]ITMREFDEB
Endif

# --- Déclaration classe ecran pour les encours --- #
Local Mask ORDK     [ORDK] : Raz [M:ORDK]
# --- Déclaration classe ecran pour les allocations --- #
Local Mask ALLPAR   [ALP]  : Raz [M:ALP]

Local Integer  WCDTUNL
#------------------------------------------------------------#
# Chargement flag déblocage crédit autorisé                  #
#------------------------------------------------------------#
#Call CTLACC("/SCDTUNL") From TRTVENCTL
#If mkstat = 2 WCDTUNL = 1 : mkstat=0
#Else          WCDTUNL = 2 : Endif
Local Char WPARAM(10)
Call PARAMUTIL("SCDTUNL",WPARAM,"","") From SUBAUS
WCDTUNL=val(WPARAM)
If WCDTUNL=0 WCDTUNL=1 Endif

# V6 Affectations
Gosub OPEN_MTO From MTOLINKLIB

Return
#########################################################################
$SETBOUT

#Raz ETABOU
#ETABOU(GSPE1) = 1
#ETABOU(GSPE2) = 1
If !instr(1,CHBOU,"<") CHBOU+= "<" Endif
If !instr(1,CHBOU,">") CHBOU+= ">" Endif

#Return : # pour test

If CLECUR = WITMREFDEB
#    ETABOU(GPREC) = 0
#    ETABOU(GSPE3) = 0
    Call VIREBOUT(CHBOU, "<") From GOBJET
    Call VIREBOUT(CHMEN, "3") From GOBJET
#Else
#    ETABOU(GPREC) = 1
#    ETABOU(GSPE3) = 1
Endif
If CLECUR = WITMREFFIN
#    ETABOU(GSUIV) = 0
#    ETABOU(GSPE4) = 0
    Call VIREBOUT(CHBOU, ">") From GOBJET
    Call VIREBOUT(CHMEN, "4") From GOBJET
#Else
#    ETABOU(GSUIV) = 1
#    ETABOU(GSPE4) = 1
Endif
#ETABOU(GBFIN) = 1

Return
#########################################################################
$BOUTON

Case BOUT
    When "1"  :  Gosub ENREGISTRE   : # Enregistrement de l'allocation
    When "2"  :  Gosub ABORT        : # Abandon de l'allocation
    When "3"  :  Gosub PRECEDENT    : # Article précédent
    When "4"  :  Gosub SUIVANT      : # Article suivant
Endcase
Return
#########################################################################
$DEBUT

Local Char    TIT(50) : TIT = mess(33,191,1)
Default File [SOQ]
Default Mask [SAL2]
Raz [M:SAL2]

 Link [SOQ] With
& [SOP]SOP0=[SOQ]SOHNUM;[SOQ]SOPLIN;[SOQ]SOQSEQ,
& [SOC]SOC0=[SOQ]SOHNUM;[SOQ]SOPLIN
& As [KSOQ]

# --> Lecture du premier et du dernier article à traiter
If CLECUR=""
    Filter [KSOQ] Where (evalue (CRITERE) & evalue (CRITERE1) & evalue (FILSUP) & evalue (CRITDET))
&                Order By ITMREF;SOQSTA
    Read [KSOQ] First
    If !fstat
        CLECUR = [F:SOQ]ITMREF
        WITMREFDEB = [F:SOQ]ITMREF
        Read [KSOQ] Last
        If !fstat WITMREFFIN = [F:SOQ]ITMREF : Endif
    Endif
    Filter [KSOQ]
Endif
If CLECUR <> ""
    WFIN=0
    Gosub LIRE
    While WFIN=0
    # --- Pas d'allocations à traiter pour cet article : Recherche du suivant
    #    Read [F:SOQ]SOQ2 > CLECUR;GHIDATE
        Read [F:SOQ]SOQ2 > CLECUR;gdat$(31,12,9999)
        If fstat<= 2 & [F:SOQ]ITMREF <= WITMREFFIN
            CLECUR = [F:SOQ]ITMREF
            Gosub LIRE
        Else
            WFIN=1
        Endif
    Wend
Endif
If [M:SAL2]NBLIG=0
    GERR=2 : GMESSAGE=mess(285,197,1)
    FIN=1
Endif

Return
#######################################################################
$ENREGISTRE

Gosub MODIF
Return
#######################################################################
$ABORT

Gosub LIRE
Return

#######################################################################
$FIN

#-- Appel l'état "PRTSCR"
Call IMPSCR From ATRTX3
Close Mask [ALP]

Return
##########################################################################
#---------------------------------------------------------------------#
# Selection sur les lignes de commandes SOQ                           #
#---------------------------------------------------------------------#
$SEL_SOQ
#--> critères de saisie
CRITERE = "1=1"
If [M]SOHNUMDEB <> ""
   CRITERE -= '& SOHNUM >="'+[M]SOHNUMDEB+'"'
Endif
If [M]SOHNUMFIN <> ""
   CRITERE -= '& SOHNUM <="'+[M]SOHNUMFIN+'"'
Endif
If [M]BPCORDDEB <> ""
   CRITERE -= '& BPCORD >="'+[M]BPCORDDEB+'"'
Endif
If [M]BPCORDFIN <> ""
   CRITERE -= '& BPCORD <="'+[M]BPCORDFIN+'"'
Endif
If [M]BPAADDDEB <> ""
   CRITERE -= '& BPAADD >="'+[M]BPAADDDEB+'"'
Endif
If [M]BPAADDFIN <> ""
   CRITERE -= '& BPAADD <="'+[M]BPAADDFIN+'"'
Endif
If [M]ITMREFDEB <> ""
   CRITERE -= '& ITMREF >="'+[M]ITMREFDEB+'"'
Endif
If [M]ITMREFFIN <> ""
   CRITERE -= '& ITMREF <="'+[M]ITMREFFIN+'"'
Endif
If [M]CPY <> ""                              : # Bug 66478
   CRITERE -= '& CPY = "'+[M]CPY+'"'         : # Bug 66478
Endif                                        : # Bug 66478
If [M]STOFCY <> ""
   CRITERE -= '& STOFCY = "'+[M]STOFCY+'"'
Endif
If [M]DRNFLG = 2
   CRITERE -= "& DRN =" +num$([M]DRN)
Endif

#--> Critères supplémentaires
CRITERE1 = "DEMSTA = 1"                :# statut ordre ferme
CRITERE1 -= "& SOQSTA <> 3"            :# état ligne non soldée

#--> Critères paramétrables
CRITDET = "1=1"
If [M]CALCRITDET <> "" CRITDET = [M]CALCRITDET Endif
CRITENT = "1=1"
If [M]ALLCRITENT <> "" CRITENT = [M]ALLCRITENT Endif


#---------------------------------------------------------------------#
# Point d'entree ajout filtres supplémentaires                        #
#---------------------------------------------------------------------#
Local Char FILSUP (250)
FILSUP="1=1"
GPOINT="MANALLFIL" : Gosub ENTREE From EXEFNC

Return

#---------------------------------------------------#
# Traitement des actions evenementielles            #
#---------------------------------------------------#
$APRES_MODIF
REP="M"
Gosub SETBOUT
Return

#---------------------------------------------------#
# Lecture des allocations à traiter pour un article #
#---------------------------------------------------#
$LIRE
Local Decimal WSHTQTYSTU

GERR=4: GMESSAGE="                                  "
REP=""
Raz [M]
[M]ALLPAR = [M:DIA]ALLPAR
nolign=0

If GTRACE = ""
    Call OUVRE_TRACE (TIT) From LECFIC
Endif
WMESS=mess(80,197,1)-CLECUR

[M]ITMREF = CLECUR
Gosub LEC_ITM
[M]SAU    = [F:ITM]SAU
[M]SAU1   = [F:ITM]SAU
[M]STU    = [F:ITM]STU
[M]STU1   = [F:ITM]STU
Gosub LEC_ITS
#[M]ITMDES1 = [F:ITS]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M]ITMDES1, "[F:ITM]") From TRTX3 # FGR 02/07/2009 : X3SUIVI56270
# Link [SOQ] With
#& [SOP]SOP0=[SOQ]SOHNUM;[SOQ]SOPLIN;[SOQ]SOQSEQ,
#& [SOC]SOC0=[SOQ]SOHNUM;[SOQ]SOPLIN
#& As [KSOQ]


# --- Positionnement du filter sur l'article à traiter
Filter [KSOQ] Where (ITMREF=CLECUR & evalue(CRITERE) & evalue(CRITERE1) & evalue(FILSUP) & evalue(CRITDET)) Order By Key SOQ2
For [KSOQ]
# --- Sélections complémentaires
    Gosub LEC_SOP
    If OK=1 Goto NXTSOQ : Endif
    Gosub SEL_SOQCOMPL
    If OK=1 Goto NXTSOQ :Endif
    Gosub SEL_SOHCOMPL
    If OK=1 Goto NXTSOQ :Endif
    Gosub SEL_SOPCOMPL
    If OK=1 Goto NXTSOQ :Endif

    nolign+=1
    NOL=nolign-1
    [M] = [F]
    [M]LINTYP(NOL) = [F:SOP]LINTYP
    [M]CDTSTA(NOL) = WCDTSTA
    [M]BPCNAM(NOL) = WBPCNAM
    [M]DME(NOL)    = [F:SOH]DME
    [M]DSAU (NOL)  = [F:SOP]SAU
    [M]DSTU (NOL)  = [F:SOP]STU
    [M]DCOE(NOL)   = [F:SOP]SAUSTUCOE
# --- Calcul du total livré/facturé
    If [F:SOH]SOHCAT = 3
        [M]DLVQTY(NOL)    = [F:SOQ]INVQTY + [F:SOQ]ODLQTY
        [M]DLVQTYSTU(NOL) = [F:SOQ]INVQTYSTU + [F:SOQ]ODLQTYSTU
    Else
        [M]DLVQTY(NOL)    = [F:SOQ]DLVQTY + [F:SOQ]ODLQTY
        [M]DLVQTYSTU(NOL) = [F:SOQ]DLVQTYSTU + [F:SOQ]ODLQTYSTU
    Endif
# --- Calcul du total préparé/préparé livrable
    [M]PREQTY(NOL)    = [F:SOQ]OPRQTY + [F:SOQ]PREQTY
    [M]PREQTYSTU(NOL) = [F:SOQ]OPRQTYSTU + [F:SOQ]PREQTYSTU
    [M:SAL2]YALLQTY   (NOL) = [F:SOQ]ALLQTY
    [M:SAL2]YALLQTYSTU(NOL) = [F:SOQ]ALLQTYSTU
    [M:SAL2]YSHTQTY   (NOL) = [F:SOQ]SHTQTY
    [M:SAL2]YSHTQTYSTU(NOL) = [F:SOQ]SHTQTYSTU
    # FGR 04/05/2015 : X3SUIVI105605 (début)
    If func AFNC.ACTIV("ECC") Then
      [M:SAL2]ECCVALMAJ(NOL) = [F:SOQ]ECCVALMAJ
      [M:SAL2]ECCVALMIN(NOL) = [F:SOQ]ECCVALMIN
    Endif
    # FGR 04/05/2015 : X3SUIVI105605 (fin)

# --- Calcul du reste à allouer
    If [M:SAL2]YALLQTY(NOL) + [M:SAL2]YSHTQTY(NOL) < [M:SAL2]QTY(NOL)
        [M:SAL2]RALLQTY(NOL) = [M:SAL2]QTY(NOL)-[M:SAL2]YALLQTY(NOL)-[M:SAL2]YSHTQTY(NOL)-[M:SAL2]PREQTY(NOL)-[M:SAL2]DLVQTY(NOL)
    Else
        [M:SAL2]RALLQTY(NOL) = 0
    Endif

# --- Calcul de la qté à allouer
    If [M:SAL2]CDTSTA(NOL) = 1 & !find([M:SAL2]LINTYP(NOL), 3,4,5,11,12,13)
        [M:SAL2]ALLQTY(NOL)  = [M:SAL2]YALLQTY(NOL) + [M:SAL2]YSHTQTY(NOL) + [M:SAL2]RALLQTY(NOL)
        [M:SAL2]ALLQTYSTU(NOL) = [M:SAL2]ALLQTY(NOL)* [M:SAL2]DCOE(NOL)

        Call QTEARR([M:SAL2]ALLQTYSTU(NOL), [M:SAL2]DSTU(NOL)) From TRTDIV
    Else
        [M:SAL2]ALLQTY(NOL)    = [M:SAL2]YALLQTY(NOL) + [M:SAL2]SHTQTY(NOL)
        [M:SAL2]ALLQTYSTU(NOL) = [M:SAL2]YALLQTYSTU(NOL) + [M:SAL2]SHTQTYSTU(NOL)
    Endif

# --- Si kit/sous-traité : Calcul de la qté livrable au niveau du kit
    If find([M:SAL2]LINTYP(NOL),2,10) & [M:SAL2]ALLQTYSTU(NOL)<>0
        # Au départ qté livrable=qté allouée du kit
        [M]DLBQTYSTU(NOL)=[M]YALLQTYSTU(NOL)
        Call RECSHTKIT ([M]SOHNUM(NOL), [M]SOPLIN(NOL), [M]SOQSEQ(NOL), WSHTQTYSTU, WRET) From TRTVENALL
        # Qté livrable = Qté allouée du kit - Qté Rupture ramenée au niveau kit
        Local Decimal WDLBQTYSTU : WDLBQTYSTU=([M]YALLQTYSTU(NOL)+[M]YSHTQTYSTU(NOL))-WSHTQTYSTU
        If WDLBQTYSTU<[M]DLBQTYSTU(NOL) [M]DLBQTYSTU(NOL)=WDLBQTYSTU Endif
    Endif

    Gosub CHARGE_LIGNE
    [M]UPDFLG(NOL) = 0
    [M]CREFLG(NOL) = NOL+1
    [M]NBLIG+=1
    $NXTSOQ
    If nolign >= dim([M]SOHNUM(0..[M]NBLIG-1)) Call MESSAGE (mess(53,184,1)) From GESECRAN : Break Endif
Next
Filter [KSOQ]

[M:SAL2]NBLIG = nolign
MAXSTA   = nolign

If [M:SAL2]NBLIG > 0
    Affzo [M:SAL2]1-99
    WFIN=1
Else
# --- Pas d'allocations à traiter pour cet article : Recherche du suivant
#    Read [F:SOQ]SOQ2 > CLECUR;GHIDATE
#   Read [F:SOQ]SOQ2 > CLECUR;gdat$(31,12,9999)
#   If fstat<= 2 & [F:SOQ]ITMREF <= WITMREFFIN
#       CLECUR = [F:SOQ]ITMREF
#       Goto LIRE
#   Endif
#    WFIN=1
Endif

Return


#-----------------------------------------------------------------------#
# Lecture du SOP pour récupérer la désignation dans la trace            #
#-----------------------------------------------------------------------#
$LEC_SOP
OK=2
Read [SOP]SOP0 = [F:SOQ]SOHNUM; [F:SOQ]SOPLIN; [F:SOQ]SOQSEQ
If fstat & [F:SOQ]SOHCAT <> 4 OK=1 : Return
Elsif fstat
    If [F:SOC]SOHNUM <> [F:SOQ]SOHNUM | [F:SOC]SOPLIN <> [F:SOQ]SOPLIN
        Raz [F:SOP]
        Read [SOC]SOC0 = [F:SOQ]SOHNUM; [F:SOQ]SOPLIN
        If fstat OK=1 : Return : Endif
    Endif
    [F:SOP] = [F:SOC]
Endif
Return
#-----------------------------------------------------------------------#
# Sélections complémentaires sur l'enregistrement SOQ                   #
#-----------------------------------------------------------------------#
$SEL_SOQCOMPL
Local Date WDATORI, WDATDES

# On exclut les lignes si :

# --> Mode de livraison contremarque receptionnée ou ordre production
If [F:SOQ]FMI = 3 | [F:SOQ]FMI = 5 OK=1 : Return : Endif

# Si site non renseigné dans les critères, ctrl d'autorisation de la fonction pour le site
# (Si site renseigné, le ctrl a été fait en saisie du chps site)
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
 If !find([F:SOQ]STOFCY,GUSRFCY(1..GNBAUZ)) OK=1 : Return Endif
Endif

OK=2
#-----------------------------------------------------------------------#
# ----- Sélection sur la date expédition -----                          #
#-----------------------------------------------------------------------#
# --> Selection si date expé. <= date expé. saisie

If [M:DIA]SHIDAT <> [0/0/0] & [F:SOQ]SHIDAT <= [M:DIA]SHIDAT Return : Endif

Gosub LEC_ITF

WDATORI = date$
## Article acheté   : On tient compte du délai de réappro     : délai calendaire
#If find([F:ITM]CLSTYP, 1,3)
#     WDATORI = WDATORI + [F:ITF]OFS
## Article fabriqué : On tient compte du délai de fabrication : délai ouvré
#Elsif find([F:ITM]CLSTYP,2,4)
#     If [F:ITF]MFGLTI <> 0
#         Call CALC_SHIDAT(WDATORI, [F:ITF]MFGLTI, [F:SOQ]STOFCY, 0, 0, [0/0/0], WDATDES) From TRTVENDAT
#         WDATORI = WDATDES
#     Endif
#Endif

Local Date WDATCALP, WDATCALM : WDATCALP=WDATORI : WDATCALM=WDATORI
# Article acheté   : On tient compte du délai de réappro     : délai calendaire
If [F:ITM]PURFLG=2 WDATCALP += [F:ITF]OFS  Endif

# Article fabriqué : On tient compte du délai de fabrication : délai ouvré
If [F:ITM]MFGFLG=2 & [F:ITF]MFGLTI <> 0
    Call CALC_SHIDAT(WDATORI, [F:ITF]MFGLTI, [F:SOQ]STOFCY, 0, 0, [0/0/0], WDATCALM) From TRTVENDAT
Endif

# On prend ensuite la date la plus élevée (un article peut être acheté et fabriqué)
WDATORI=max(WDATCALP,WDATCALM)

# On tient compte dans les 2 cas du délai de prépa : délai ouvré
If [F:ITF]PRPLTI <> 0
    Call CALC_SHIDAT(WDATORI, [F:ITF]PRPLTI, [F:SOQ]STOFCY, 0, 0, [0/0/0], WDATDES) From TRTVENDAT
    WDATORI = WDATDES
Endif

# --> Selection si date expé. <= date trt + délai + délai prépa
If [F:SOQ]SHIDAT <= WDATORI Return : Endif

OK=1
Return

#-----------------------------------------------------------------------#
# Sélections complémentaires sur l'enregistrement SOP                   #
#-----------------------------------------------------------------------#
$SEL_SOPCOMPL

# On prend les lignes de composants uniquement si elles sont déjà allouées (pour notamment traiter la rupture)
If find([F:SOP]LINTYP, 3,4,5,11,12,13) & [F:SOQ]ALLQTYSTU+[F:SOQ]SHTQTYSTU=0 OK=1:Return:Endif

# On exclut les lignes si :

# --> Non géré en stock et non composé de kit/sous-traité
If [F:SOQ]STOMGTCOD = 1 & !(find([F:SOP]LINTYP, 2,10)) OK=1:Return:Endif

# --> On exclut les lignes totalement allouées sf s'il s'agit du réaffichage des allocations effectuées
If [M:DIA]ALLTOT <> 2 & WRESULTAT=0
    If [F:SOH]SOHCAT = 3
        If [F:SOQ]ALLQTYSTU+[F:SOQ]OPRQTYSTU+[F:SOQ]PREQTYSTU+[F:SOQ]ODLQTYSTU+[F:SOQ]INVQTYSTU >= [F:SOQ]QTYSTU &
&          [F:SOQ]SHTQTYSTU = 0
            OK=1
        Endif
    Else
        If [F:SOQ]ALLQTYSTU+[F:SOQ]OPRQTYSTU+[F:SOQ]PREQTYSTU+[F:SOQ]ODLQTYSTU+[F:SOQ]DLVQTYSTU >= [F:SOQ]QTYSTU &
&          [F:SOQ]SHTQTYSTU = 0
            OK=1
        Endif
    Endif
Endif

#----------------------------------------------------------------------------#
# Point d'entree pour rajouter des filtres sur les enregistrements à traiter #
#----------------------------------------------------------------------------#
GPOINT="MANALLSEL" : Gosub ENTREE From EXEFNC

Return

#-----------------------------------------------------------------------#
# Sélections complémentaires sur l'entête comande SOH                   #
#-----------------------------------------------------------------------#
$SEL_SOHCOMPL
Local Integer WCHG_CDE    :    WCHG_CDE=0

OK=2
If [F:SOH]SOHNUM <> [F:SOQ]SOHNUM
    Read [SOH]SOH0 = [F:SOQ]SOHNUM
    If fstat OK=1 :Return:Endif
    WCHG_CDE=1
Endif

If !evalue (CRITENT) OK=1 : Return : Endif

If [F:SOH]BPCNAM(0) <> ""
    WBPCNAM=[F:SOH]BPCNAM(0)
Else
    If [F:BPC]BPCNUM<>[F:SOH]BPCORD
        Read [BPC]BPC0 = [F:SOH]BPCORD
        If fstat Raz [F:BPC] : Endif
    Endif
    WBPCNAM=[F:BPC]BPCNAM
Endif

# --> On exclut les cdes à allocation automatique
#If [M:DIA]AUTALL = 1 & [F:SOH]ALLSOH = 1 OK=1 : RETURN : Endif

# --> On exclut les cdes non signées si Pas d'encours ou Pas d'allocation des commandes non signées
If (GSOHAPPORD=1 | GSOHAPPALL=1) & [F:SOH]APPFLG<= 2 OK=1 : Return : Endif

If func MANHLDLIB.BLK_ALLOC([F:SOH]HLDSTA,[F:SOH]HLDCOD) : OK=1 : Return : Endif  # order holds

If WSALFCY <> [F:SOH]SALFCY
    # --> Alimentation à partir du site de vente
    Call GETDEV([F:SOH]SALFCY) From DEVSUB
    # --> Récupération des paramêtres de vente
    Call GLOBVAR([F:SOH]SALFCY,"VEN") From TRTX3
    WSALFCY = [F:SOH]SALFCY
Endif

# --> Calcul de  l'état crédit uniquement si on a changé de commande
#     On exclut les commandes dt l'état crédit vaut bloqué
#     On exclut les commandes dt l'état crédit vaut depassement en-cours et blocage
#     On exclut les commandes dt l'état crédit vaut acompte non versé et blocage
  If WCHG_CDE = 1
    Call SDCDTSTA([F:SOH]SOHNUM,[F:SOH]BPCORD,[F:SOH]CHGTYP,0,"",[F:SOH]ORDDAT,[F:SOH]UNL, 2,WCDTSTA,GBIDD1,GBIDD2) From TRTVENCDT
  Endif

  #If WCDTSTA=2 | (WCDTSTA=3 & WCDTUNL=1) | (WCDTSTA=4 & GLOKORD=2)  # FGR 10/03/2015 : X3SUIVI23273
  If WCDTSTA=2  | (WCDTSTA=4 & GLOKORD=2)                            # FGR 10/03/2015 : X3SUIVI23273
    OK=1
    WMESS1=mess(98,197,1)-":"-[F:SOH]SOHNUM-mess(99,197,1)-":"-[F:SOH]BPCORD-WBPCNAM-mess(80,197,1)-":"-[F:SOQ]ITMREF-[F:SOP]ITMDES1
    Call ECR_TRACE(WMESS-WMESS1,0) From GESECRAN
    If WCDTSTA = 2
      Call ECR_TRACE(mess(100,197,1), 1) From GESECRAN
    #Elsif WCDTSTA=3 & WCDTUNL = 1                                   # FGR 10/03/2015 : X3SUIVI23273
    #  Call ECR_TRACE(mess(101,197,1), 1) From GESECRAN              # FGR 10/03/2015 : X3SUIVI23273
    Elsif WCDTSTA=4 & GLOKORD = 2
      Call ECR_TRACE(mess(102,197,1), 1) From GESECRAN
    Endif
  Endif
  # FGR 10/03/2015 : X3SUIVI23273 (début)
  If (WCDTSTA=3 & WCDTUNL=1)
    #- Si pas (Intersit & non intersoc) ou si Ctrl intersit encours&prix
    If !([F:SOH]BETFCY=2 & [F:SOH]BETCPY<>2) or GCTLBETFCY=2
      OK=1
      WMESS1=mess(98,197,1)-":"-[F:SOH]SOHNUM-mess(99,197,1)-":"-[F:SOH]BPCORD-WBPCNAM-mess(80,197,1)-":"-[F:SOQ]ITMREF-[F:SOP]ITMDES1
      Call ECR_TRACE(WMESS-WMESS1,0)     From GESECRAN
      Call ECR_TRACE(mess(101,197,1), 1) From GESECRAN
    Endif
  Endif
  # FGR 10/03/2015 : X3SUIVI23273 (fin)
Return

#---------------------------------------------------#
# Enregistrement des modifications                  #
#---------------------------------------------------#
$MODIF

Gosub ECRIRE
# Réaffichage des allocations réalisées
WRESULTAT=1
CLECUR=[M]ITMREF
Gosub LIRE
WRESULTAT=1
If [M]NBLIG = 0
    GERR=2 : GMESSAGE=mess(286,197,1)
    FIN=1
Endif

Return

#---------------------------------------------------#
# Mise à jour des du tableau des allocations        #
#---------------------------------------------------#
$ECRIRE
NBALL=0
If GTRACE = ""
    Call OUVRE_TRACE (TIT) From LECFIC
Endif
WMESS=mess(80,197,1)-":"-[M]ITMREF-[M]ITMDES1
If [M:DIA]STOFCY <> "" WMESS-=mess(81,197,1)-":"-[M:DIA]STOFCY Endif

CLECUR = [M]ITMREF
For nolign=1 To [M]NBLIG
    NOL = nolign-1
    WMESS1=mess(98,197,1)-":"-[M]SOHNUM(NOL)-mess(99,197,1)-":"-[M]BPCORD(NOL)-[M]BPCNAM(NOL)
    If [M:DIA]STOFCY = "" WMESS-=mess(80,197,1)-":"-[M]STOFCY(NOL) Endif
    If [M]ALLQTYSTU (NOL) - ([M]YALLQTYSTU(NOL)+[M]YSHTQTYSTU(NOL)) = 0
# ----- Il n'y a pas de nouvelle allocation
        If [M]YSHTQTYSTU(NOL) <> 0
# --------- On essaie de réallouer la qté en rupture
            WTRTLIG = "M"
            WALLSTU = 0 : WALLCPS = 0
            WSHTSTU = [M]YSHTQTYSTU (NOL)
        Else
            Goto NXTALL
        Endif
    Elsif [M]ALLQTYSTU (NOL) - ([M]YALLQTYSTU(NOL)+[M]YSHTQTYSTU(NOL)) < 0
# ----- C'est une diminution/annulation de l'allocation
        WTRTLIG = "D"
        WQTYSTU = ([M]YALLQTYSTU(NOL)+[M]YSHTQTYSTU(NOL)) - [M]ALLQTYSTU(NOL)
        WALLCPS = WQTYSTU
# ----------- On traite en priorité la quantité rupture
        If [M]YSHTQTYSTU(NOL) <> 0
# ----------- On décrémente la quantité rupture
            If WQTYSTU < [M]YSHTQTYSTU (NOL)
                WSHTSTU = WQTYSTU
                WALLSTU = 0
            Else
# ----------- On annule la quantité rupture et on décrémente la quantité allouée
                WSHTSTU = [M]YSHTQTYSTU (NOL)
                WQTYSTU -= WSHTSTU
                WALLSTU = WQTYSTU
            Endif
        Else
# ----------- On traite ensuite la quantité allouée
            WSHTSTU = 0
            If WQTYSTU < ([M]YALLQTYSTU(NOL)+[M]YSHTQTYSTU(NOL))
# ---------------- On décrémente la quantité rupture
                WALLSTU = WQTYSTU
            Else
# ---------------- On annule la quantité allouée
                WTRTLIG = "A"
                WALLSTU = [M]YALLQTYSTU (NOL)
            Endif
        Endif
    Else
# ----- C'est une augmentation de l'allocation
        If [M]YALLQTYSTU(NOL) = 0 & [M]YSHTQTYSTU(NOL) = 0
             WTRTLIG = "C"
        Else
             WTRTLIG = "M"
        Endif
        WSHTSTU = [M]YSHTQTYSTU(NOL)
        WALLSTU = [M]ALLQTYSTU(NOL) - ([M]YALLQTYSTU(NOL)+[M]YSHTQTYSTU(NOL))
        WALLCPS = [M]ALLQTYSTU(NOL)
    Endif
    If WALLSTU + WSHTSTU <> 0
        Call DEBTRANS From GLOCK
        Gosub MAJALL
        If GOK<1 : Break : Endif
    Endif
    NBALL += 1
    $NXTALL
Next nolign

$FIN_ECRIRE
Return

#-----------------------------------------------------------------------#
# Mise à jour d'une ligne d'allocation                                  #
#-----------------------------------------------------------------------#
$MAJALL
Local Char    WTRTORD
Local Decimal WCPLQTY
Local Integer WALLLINNOM : # Nbre de lignes allouées d'une nomenclature
Local Integer WALLSTA   : # Status allocation de la ligne

OK=1 : GOK=1
Trbegin [SOH]
    Gosub VERROU
    If !OK GOK=0 : Goto AB_ECRIRE Endif

#   --> Traitement de la ligne de commande
    Read [SOQ] SOQ0=[M]SOHNUM(NOL);[M]SOPLIN(NOL);[M]SOQSEQ(NOL)
    If fstat
        GOK = 0 :Call RSTA("SOQ", [M]SOHNUM(NOL)-num$([M]SOPLIN(NOL))-num$([M]SOQSEQ(NOL))) From GLOCK
        Goto AB_ECRIRE
    Endif
    Read [SOP] SOP0 = [M]SOHNUM(NOL);[M]SOPLIN(NOL);[M]SOQSEQ(NOL)

    #VPO 18/05/09
    #If fstat & [F:SOH]SOHCAT <> 4
    If fstat & [M]SOHCAT(NOL) <> 4
        GOK = 0 :Call RSTA("SOP", [M]SOHNUM(NOL)-num$([M]SOPLIN(NOL))-num$([M]SOQSEQ(NOL))) From GLOCK
        Goto AB_ECRIRE
    Elsif fstat
        Raz [F:SOP]
        If [F:SOC]SOHNUM <> [M]SOHNUM(NOL) | [F:SOC]SOPLIN <> [M]SOPLIN(NOL)
            Read [SOC]SOC0 = [M]SOHNUM(NOL); [M]SOPLIN(NOL)
            If fstat
                GOK = 0 :Call RSTA("SOC", [M]SOHNUM(NOL)-num$([M]SOPLIN(NOL))) From GLOCK
                Goto AB_ECRIRE
            Endif
        Endif
        [F:SOP] = [F:SOC]
    Endif
#   Allocation partielle toujours autorisée
#   Sauf si non cochée ds l'écran et livraison.ligne/cde complète et ce n'est pas un kit/sous-traité
#   Un kit et ses composants ne peuvent être alloués partiellement (sinon déphasage possible)
    WALLPAR=0
    If [M:DIA]ALLPAR=1 & find([M]DME(NOL),2,3) & !find([F:SOP]LINTYP,2,10) WALLPAR=1 : Endif
#   Génération des ruptures
#   Si cochée à l'écran ou kit
#   On génère toujours les ruptures sur un kit/sous-traité et ses composants (sinon déphasage possible)
    WGENSHT=[M:DIA]GENSHT
    If find([F:SOP]LINTYP,2,3,4,5,10,11,12,13) WGENSHT=2 Endif
#   L'allocation ne se fait pas sur les articles non gérés en stock
#   C'est le cas des composés de kit non gérés en stock
#   On passe quand même içi pour allouer les composants
    If [F:SOQ]STOMGTCOD <> 1
#       Génération de l'allocation
#       (Les quantité allouées et ruptures sont toujours positives)
        Call GENALLORD("","",WTRTLIG, [M:DIA]IMPCLI, WGENSHT, WALLPAR, WALLSTU, WSHTSTU, WRET) From TRTVENALL
        If WRET = 2 & GOK=1
#           Allocation impossible : Livraison ligne/commande complète et stock disponible insuffisant
#           On continue quand même le traitement des allocations (GOK reste à 1)
            Call ECR_TRACE(WMESS1,0) From GESECRAN
            Call ECR_TRACE("    "+mess(103,197,1)+":"+mess(105,197,1)+mess(367,199,1), 0) From GESECRAN
            GOK=0: Goto AB_ECRIRE
        Elsif WRET <> 0
            Call ECR_TRACE(WMESS1,0) From GESECRAN
            Call ECR_TRACE(mess(96,197,1), 0) From GESECRAN
            GOK=0: Goto AB_ECRIRE
        Endif
    Endif

    WALL = WALLSTU * (1/[M]DCOE(NOL))
    Call QTEARR(WALL, [F:SOP]SAU) From TRTDIV
    WSHT = WSHTSTU * (1/[M]DCOE(NOL))
    Call QTEARR(WSHT, [F:SOP]SAU) From TRTDIV

    # Création et modification  : Qté allouée en +
    #                             Nouvelle Qté rupture
    # Annulation  et diminution : Qté allouée en -
    #                             Qté rupture en -
    If find(WTRTLIG, "C","M")
        [F:SOQ]ALLQTYSTU += WALLSTU
        [F:SOQ]SHTQTYSTU = WSHTSTU
    Else
        [F:SOQ]ALLQTYSTU -= WALLSTU
        [F:SOQ]SHTQTYSTU -= WSHTSTU
        WALL *=-1
        WSHT *=-1
    Endif
#   Mise à jour commande
    Call MAJALLORD([F:SOQ]SOHNUM, [F:SOQ]SOPLIN, [F:SOQ]SOQSEQ, [F:SOQ]ALLTYP, 1, [F:SOQ]ALLQTYSTU, [F:SOQ]SHTQTYSTU, WRET) From TRTVENALL
    If WRET <> 0 : GOK = 0 : Goto AB_ECRIRE : Endif
#   Alimentation de la trace
    If NBALL=0 Call ECR_TRACE(WMESS,0) From GESECRAN : Raz WMESS : Endif
    Call ECR_TRACE(WMESS1,0) From GESECRAN
#    If [F:SOP]LINTYP=2 WALLKIT=2 : WMESS=mess([F:SOP]LINTYP,423,1) Endif
    If find([F:SOP]LINTYP,2,10) WMESS=mess([F:SOP]LINTYP,423,1) Endif
    If [F:SOQ]STOMGTCOD=1 WMESS-=mess(283,197,1) Endif
    If WMESS <>"" Call ECR_TRACE("  "+WMESS,0) From GESECRAN Endif
    If [F:SOQ]STOMGTCOD<>1
        WMESS1 = mess(106,197,1)+":"+format$("N:15F", WALL)-[F:SOP]SAU
        WMESS2 = mess(107,197,1)+":"+format$("N:15F", WSHT)-[F:SOP]SAU
        Call ECR_TRACE("    "+mess(479,197,1)-WMESS1-WMESS2,0) From GESECRAN
    Endif
    #VPO 18/05/09
    #If [F:SOH]SOHCAT = 3 WCPLQTY = [F:SOQ]INVQTYSTU Else WCPLQTY = [F:SOQ]DLVQTYSTU : Endif
    If [M]SOHCAT(NOL) = 3 WCPLQTY = [F:SOQ]INVQTYSTU Else WCPLQTY = [F:SOQ]DLVQTYSTU : Endif
    WALLSTA=1
    If [F:SOQ]ALLQTYSTU+[F:SOQ]OPRQTYSTU+[F:SOQ]PREQTYSTU+[F:SOQ]ODLQTYSTU+WCPLQTY>=[F:SOQ]QTYSTU & [F:SOQ]SHTQTYSTU=0
        WALLSTA = 3
    Elsif sum([F:SOQ]ALLQTYSTU,[F:SOQ]OPRQTYSTU,[F:SOQ]PREQTYSTU)<> 0
        WALLSTA = 2
    Endif


    WMESS1 = mess(480,197,1)-format$("N:15F", [F:SOQ]QTY)-[F:SOP]SAU
    WMESS2 = mess(481,197,1)-format$("N:15F", [F:SOQ]ALLQTY)
    WMESS3 = mess(66,191,1)-":"-format$("N:15F", [F:SOQ]SHTQTY)
    Call ECR_TRACE("    "+mess(18,197,1)-format$("K:15X", mess(WALLSTA,416,1))+"=>"-WMESS1-WMESS2-WMESS3,0) From GESECRAN
    NBALL += 1
#   Si Composé de kit/sous-traité, il faut allouer les composants
    If find([F:SOP]LINTYP,2,10) & WALLCPS <> 0
        WALLSTU=WALLCPS
        Call GENALLKIT ([F:SOQ]SOHNUM, [F:SOQ]SOPLIN, [F:SOQ]SOQSEQ, WTRTLIG, [M:DIA]IMPCLI, WGENSHT, WALLPAR, 1, 1, WALLSTU,
&                           WRET) From TRTVENALL
        If WRET <> 0
            Call ECR_TRACE(WMESS1,0) From GESECRAN
            Call ECR_TRACE(mess(194,197,1), 0) From GESECRAN
            OK=0 : Goto AB_ECRIRE
        Endif
    Endif
    Gosub DEVERROU
Commit
Return

$ROLL_ECRIRE
Rollback
Call ROLL From GLOCK
If GROLL Return : Else : Goto MAJALL : Endif

$AB_ECRIRE
Rollback
Return

$DEVERROU
Unlock = SYMBOLE
Return

$VERROU
#VPO 18/05/09 54861 pb lock cde ouverte
If [M]SOHCAT(NOL)<>4
SYMBOLE = "SOH"+[M]SOHNUM(NOL)
Else
#   Ligne de commande ouverte
SYMBOLE = "SOC"+num$([M]SOPLIN(NOL))+"\"+[M]SOHNUM(NOL)
Endif
Lock = SYMBOLE With lockwait = 0
If fstat
    Call ECR_TRACE([M]SOHNUM(NOL) - mess(10,100,1),1) From GESECRAN
    OK=0
Endif
Return

#----------------------------------------------------#
# Recherche allocations article suivant              #
#----------------------------------------------------#
$AVANT_SUIVANT
#GERR=3
#GMESSAGE = mess(32,191,1)
Return

$PRECEDENT
Local Char WSVGITMREF : Raz WSVGITMREF

If [M]ITMREF<>"" WSVGITMREF=[M]ITMREF Endif

If WCLEPREC <> ""
    CLECUR = WCLEPREC
    Gosub LIRE
Else
    CLECUR = [M]ITMREF
    WFIN=0
    While WFIN=0
        Read [F:SOQ]SOQ2 < CLECUR;[0/0/0]
        If fstat<= 2 & [F:SOQ]ITMREF >= WITMREFDEB
            CLECUR = [F:SOQ]ITMREF
            Gosub LIRE
        Else
            WFIN=1
        Endif
    Wend
Endif
If [M:SAL2]NBLIG=0
    # Debut de fichier, on se repositionne sur le dernier article traité
    If WSVGITMREF<>"" CLECUR = WSVGITMREF : Gosub LIRE Endif
    GERR=2 : GMESSAGE=mess(11,100,1)
    #    FIN=1
Endif
Raz WCLEPREC

Return

$SUIVANT
Local Char WSVGITMREF : Raz WSVGITMREF

If [M]ITMREF<>"" WSVGITMREF=[M]ITMREF Endif

CLECUR   = [M]ITMREF
WCLEPREC = [M]ITMREF

WFIN=0
While WFIN=0
    Read [F:SOQ]SOQ2 > CLECUR;gdat$(31,12,9999)
    If fstat<= 2 & [F:SOQ]ITMREF <= WITMREFFIN
        CLECUR = [F:SOQ]ITMREF
        Gosub LIRE
    Else
        WFIN=1
    Endif
Wend
If [M]NBLIG = 0
    # Fin de fichier, on se repositionne sur le dernier article traité
    If WSVGITMREF<>"" CLECUR = WSVGITMREF : Gosub LIRE Endif
    GERR=2 : GMESSAGE=mess(11,100,1)
#    FIN=1
Endif

Return

#$SUIV
#Gosub LIRE
#If [M]NBLIG = 0
#    GERR=2 : GMESSAGE=mess(286,197,1)
#    FIN=1
#Endif
#Return

#######################################################################
#                     ACTIONS CHAMPS                                  #
#######################################################################
#    ECRAN SMANALL1
########################################
# --------------------------------------- STOFCY ---------------------------------
########################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
# --> Récupération du paramètre stock : GENSHT    : Génération des ruptures
Local Char     WPARAM(10)
Call PARAML(VALEUR,"GENSHT",WPARAM) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
GGENSHT= val(WPARAM)
[M:DIA]GENSHT = GGENSHT
# --> Récupération du paramètre vente : USERERBPC : Consommation réservations clients
Local Char     WPARAM(10)
Call PARAML(VALEUR,"USERERBPC",WPARAM) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
GUSERERBPC= val(WPARAM)
[M:DIA]IMPCLI = GUSERERBPC
If GUSERERBPC=3 [M:DIA]IMPCLI=2 : Endif
Affzo [M:DIA]GENSHT
Affzo [M:DIA]IMPCLI
End
########################################
# ----------------------------------- SOHNUMDEB ---------------------------------
########################################
Subprog AM_SOHNUMDEB(VALEUR)    : # Web - Faible - Synchrone
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]SOHNUMFIN = VALEUR : Affzo [M:DIA]SOHNUMFIN : Endif
End
########################################
# ----------------------------------- BPCCORDEB ---------------------------------
Subprog AM_BPCORDDEB(VALEUR)    : # Web - Faible - Synchrone
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]BPCORDFIN = VALEUR : Affzo [M:DIA]BPCORDFIN :  Endif
End
# ------------------------------------ BPAADDDEB ---------------------------------
########################################
Subprog AS_BPAADDDEB(VALEUR)    : # Web - Obligatoire - Synchrone
Variable Char    VALEUR()
If [M]BPCORDDEB = "" mkstat=2 Endif
End
########################################
Subprog AM_BPAADDDEB(VALEUR)    : # Web - Faible - Synchrone
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]BPAADDFIN = VALEUR : Affzo [M:DIA]BPAADDFIN : Endif
End
# ------------------------------------ BPAADDFIN ---------------------------------
########################################
Subprog AS_BPAADDFIN(VALEUR)    : # Web - Obligatoire - Synchrone
Variable Char    VALEUR()
If [M]BPCORDFIN = "" mkstat=2 Endif
End
########################################
Subprog C_BPAADDFIN(VALEUR)    : # Web - Faible - Synchrone
Variable Char    VALEUR()
If  [M]BPCORDDEB = [M]BPCORDFIN
    If VALEUR < [M]BPAADDDEB GMESSAGE= mess(44,199,1) : mkstat=2:Endif
Endif
End
########################################
# ----------------------------------- ITMREFDEB ---------------------------------
########################################
Subprog AM_ITMREFDEB(VALEUR)    : # Web - Faible - Synchrone
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]ITMREFFIN = VALEUR : Affzo [M:DIA]ITMREFFIN : Endif
End
# ----------------------------------- ALLCRITENT ---------------------------------
########################################
Subprog AS_ALLCRITENT(VALEUR)
Variable Char    VALEUR()
Raz [M]FILTTABENT, XXCONV, XXVAR
[M]FILTTABENT="find(ABRFIC,'SOH')"
End
# ----------------------------------- ALLCRITDET ---------------------------------
########################################
Subprog AS_ALLCRITDET(VALEUR)
Variable Char    VALEUR()
Raz [M]FILTTABDET, XXCONV, XXVAR
[M]FILTTABDET="find(ABRFIC,'SOQ')"
For I=0 To dim([F:SOP]TSICOD)-1
    [M]XXVAR(I)="WTSICOD("+num$(I)+"),Famille statistique"+num$(I+1)
Next
End
########################################
Subprog AM_ALLCRITDET(VALEUR)
Variable Char    VALEUR()

Local Char    WCRITDET(150), WCRITTSI(250), WCRITRES(250)
Local Char    WCRIT(250), WCRITVAL(250)
Local Integer W,I,J,K1,K2

#WCRITERE='XXXX & WTSICOD(0)="A" & YYYY & WTSICOD(1)="B"'
I=1
WCRITDET=toupper(VALEUR)
If instr(I,WCRITDET, "WTSICOD")
    I=1
    WCRITRES="("
    Repeat
    W=instr(I,WCRITDET, "WTSICOD")
    If W<>0
        J=W
        WCRIT=seg$(WCRITDET,I,J-1)
        K1 = instr(1+J+6,WCRITDET,'"')
        WCRITVAL=seg$(WCRITDET,1+J+6,K1)
        K2 = instr(K1+1,WCRITDET,'"')
        WCRITVAL+=seg$(WCRITDET,K1+1,K2)
        WCRITTSI="([F:SOQ]SOHCAT<>4&[F:SOP]TSICOD"+WCRITVAL+")|("+"[F:SOQ]SOHCAT=4&[F:SOC]TSICOD"+WCRITVAL+")"
        WCRIT+=WCRITTSI
        WCRITRES+=WCRIT
        I=K2+1
    Endif
    Until W = 0
    WCRITRES+=")"

    WCRIT=right$(WCRITDET,I)
    WCRITRES+=WCRIT

#    Infbox WCRITRES
#    Infbox num$(len(VALEUR))
#    Infbox num$(len(WCRITRES))

    If len(WCRITRES)> 250 mkstat=2 : GMESSAGE=mess(4,159,1) : End : Endif
    [M]CALCRITDET=WCRITRES
Else
    [M]CALCRITDET=VALEUR
Endif

End
########################################
# --------------------------------------- DRNFLG ---------------------------------
Subprog AP_DRNFLG(VALEUR)   : # Web - Faible - Synchrone
Variable Integer VALEUR

If VALEUR = 1
    [M:DIA]DRN = 0
Endif
If VALEUR = 2 & [M:DIA]DRN = 0
    [M:DIA]DRN = 1
    Affzo [M:DIA]DRN
Endif
If VALEUR <> 2 Grizo [M:DIA]DRN Else Actzo [M:DIA]DRN : Endif

End
########################################
# --------------------------------------- DRN ---------------------------------
Subprog C_DRN(VALEUR)    : # Web - Faible - Synchrone
Variable Integer VALEUR
If [M]DRNFLG = 1 & VALEUR <> 0 mkstat =2 : Endif
If [M]DRNFLG = 2 & VALEUR  = 0 mkstat =2 : Endif
End
########################################
#    ECRAN SMANALL2
########################################
##########################################################################
## Etiquette ajoutée par le superviseur 09/09/2003 16:34:53 (LD)
##########################################################################
Subprog IB_NBLIG

# Bouton   1 : Allocations manuelles
# Bouton   2 : Allocation automatique
# Bouton   3 : Désallocation

If nolign>[M]NBLIG Raz GBOUT2, GBOUT3 Endif
If find([M:SAL2]LINTYP(nolign-1), 3,4,5,11,12,13) Raz GBOUT2, GBOUT3 Endif
If [M]STOMGTCOD(nolign-1)=1 Raz GBOUT1 Endif
End
########################################
Subprog AS_NBLIG

If nolign > [M]NBLIG End Endif
Gosub AFF_ITM
# Si kit/sous-traité, affichage au niveau du composé de la qté livrable
If !find(2,10, [M]LINTYP(0..[M]NBLIG-1))  End Endif
GERR=4: GMESSAGE="                                  "
If find([M]LINTYP(nolign-1),2,10) & [M]DLBQTYSTU(nolign-1)<([M]YALLQTYSTU(nolign-1)+[M]YSHTQTYSTU(nolign-1))
    Local Decimal WDLBQTY
    If [M]DCOE(nolign-1)<>1
        WDLBQTY=[M]DLBQTYSTU(nolign-1)*(1/[M]DCOE(nolign-1))
    Else
        WDLBQTY=[M]DLBQTYSTU(nolign-1)
    Endif
    Call QTEARR(WDLBQTY, [M]DSAU(nolign-1)) From TRTDIV
    GMESSAGE=(mess(610,197,1)-num$(WDLBQTY)-[M]DSAU(nolign-1))
Endif
End
########################################
Subprog APRES_NBLIG
If status = 7 | status = 6 End : Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran SMANALL2) 10/11/2004 16:43:24 (LD)
######################################################################################
Subprog AV_SOHNUM(VALEUR)
Variable Char    VALEUR()
If VALEUR="" | nolign>[M]NBLIG End Endif
Gosub COLOR_KIT
End
########################################
Subprog AV_YALLQTY(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 | nolign>[M]NBLIG End Endif
Gosub COLOR_KIT
End
##########################################################################
## Etiquette ajoutée par le superviseur 09/09/2003 15:13:03 (LD)
##########################################################################
Subprog AS_ALLQTY(VALEUR)
Variable Decimal VALEUR
If find([M]LINTYP(nolign-1), 3,4,5,11,12,13) mkstat=2 Endif
End
########################################
Subprog AV_ALLQTY(VALEUR)
Variable Decimal VALEUR
pcolor=GCOUL(0)
If [M]RALLQTY(nolign-1) <> 0 | [M]SHTQTY(nolign-1) <> 0
    pcolor=GCOUL(1)
Elsif find([M]LINTYP(nolign-1),2,10) & [M]DLBQTYSTU(nolign-1)<([M]YALLQTYSTU(nolign-1)+[M]YSHTQTYSTU(nolign-1))
    pcolor=GCOUL(2)
Endif
End
########################################
Subprog AP_ALLQTY(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL,OK,I : NOL=nolign-1

Raz GMESSAGE
# Pas d'allocations partielles et livraison ligne/cde complète : on doit tout allouer
# Sauf pour les kits/sous-traité (on autorise toujours l'allocation partielle)
If [M]ALLPAR=1 & find([M]DME(NOL), 2,3) & !find([M]LINTYP(NOL), 2,3,4,5,10,11,12,13)
#   La qté à allouer doit être égale au reste à allouer
    If VALEUR < [M]RALLQTY(NOL)
        GMESSAGE=mess(295,192,1)
    Endif
#   La qté à allouer doit être disponible
    If [M]DISSTOSAU < VALEUR
        GMESSAGE-="\"-mess(44,192,1)
#        OK=1: Call AVERTIR(mess(44,192,1), OK) From GESECRAN
#        If OK=1 mkstat=2 : End : Endif
    Endif
    If GMESSAGE <> ""
        OK=1: Call AVERTIR(GMESSAGE, OK) From GESECRAN
        Raz GMESSAGE : If OK=1 mkstat=2 : End : Endif
    Endif
Endif
# Dde de confirmation si on alloue malgré les ruptures déjà existantes
If VALEUR <> 0 & [M]DISSTOSTU > 0 & [M]SHTSTO > 0
    OK=1: Call OUINON(mess(51,191,1), OK) From GESECRAN
    If OK=1 mkstat=2 : End : Endif
Endif
End
########################################
Subprog AM_ALLQTY(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL : NOL = nolign-1
Local    Integer OK, I
Local    Decimal WALLQTY
# On essaie d'allouer plus que ce qui reste à allouer
If (VALEUR - [M]YALLQTY(NOL)) > [M]RALLQTY(NOL)
    OK=2:Call AVERTIR(mess(213,191,1), OK) From GESECRAN
    If OK <> 2 mkstat = 2 : End : Endif
Endif
# Calcul de la nouvelle qté en rupture si on génère les ruptures
#WALLQTY = VALEUR
#[M]XALLQTY(NOL)=[M]ALLQTY(NOL)
#If [M:DIA]GENSHT=2
#    Gosub CALC_RUPTURE
#    Affzo [M]SHTQTY(NOL)
#Endif
End
#######################################################################
#                       ETIQUETTES                                    #
#######################################################################
# ------------------------------------------------------------------- #
#                 Lecture de l'article                                #
# ------------------------------------------------------------------- #
$LEC_ITM
If [F:ITM]ITMREF <>  [M]ITMREF
                     Read [ITM] ITM0=[M]ITMREF
                     If fstat Raz [F:ITM] : Endif
                     Endif
Return
# ------------------------------------------------------------------- #
#                 Lecture de l'article vente                          #
# ------------------------------------------------------------------- #
$LEC_ITS
If [F:ITS]ITMREF <>  [M]ITMREF
                     Read [ITS] ITS0=[M]ITMREF
                     If fstat Raz [F:ITS] : Endif
                     Endif
Return
# ------------------------------------------------------------------- #
#                 Lecture de l'article site                           #
# ------------------------------------------------------------------- #
$LEC_ITF
If [F:ITF]ITMREF <> [F:SOQ]ITMREF | [F:ITF]STOFCY <> [F:SOQ]STOFCY
    Read [ITF]ITF0=[F:SOQ]ITMREF;[F:SOQ]STOFCY
    If fstat Raz [F:ITF] :Endif
Endif
Return
# ------------------------------------------------------------------- #
#                 Lecture des tables article                          #
#                 Lecture des cumuls mvts article-site                #
#                 Alimentation des stocks physique et dispo           #
# ------------------------------------------------------------------- #
$LEC_ITV
Local Integer WRET, WSTA
Local Char    WNUM
#--- Issue 115110
Local Integer WTRSTYP
Local Char    WECCVALMAJ(GLONECS)
#---
[M:SAL2]SAU       = [M:SAL2]DSAU(NOL)
[M:SAL2]SAU1      = [M:SAL2]DSAU(NOL)
[M:SAL2]COE       = [M:SAL2]DCOE(NOL)
[M:SAL2]STU       = [M:SAL2]DSTU(NOL)
[M:SAL2]STU1      = [M:SAL2]DSTU(NOL)
[M:SAL2]STU2      = [M:SAL2]DSTU(NOL)

If [M:SAL2]STOMGTCOD(NOL) <> 1
    Call LECITM([M:SAL2]STOFCY(NOL),[M:SAL2]ITMREF,"",0,"",WRET) From STKLIB
    If WRET<>0  Return : Endif
Else
    Raz [M:SAL2]SHTSTO, [M:SAL2]PHYSTOSTU, [M:SAL2]PHYSTOSAU
    Raz [M:SAL2]DISSTOSTU, [M:SAL2]DISSTOSAU
    Return
Endif
[M:SAL2]SHTSTO    = [F:ITV]DETSHT+[F:ITV]GLOSHT

# A voir ? si il faut ajouter CTLSTO et REJSTO
[M:SAL2]PHYSTOSTU = [F:ITV]PHYSTO
If [M:SAL2]PHYSTOSTU <> 0
    [M:SAL2]PHYSTOSAU=[M:SAL2]PHYSTOSTU*(1/[M:SAL2]DCOE(NOL))
    Call QTEARR([M:SAL2]PHYSTOSAU, [M:SAL2]SAU) From TRTDIV
Else
    [M:SAL2]PHYSTOSAU = 0
Endif

# Récupération des statuts autorisés
#Raz WSTA
#If [F:ITG]GLOAAAFLG=2 WSTA+=1 Endif
#If [F:ITG]GLOQQQFLG=2 WSTA+=2 Endif
#If [F:ITG]GLORRRFLG=2 WSTA+=4 Endif
# Calcul stock disponible
#Call STODISTOT("",1,WSTA,"",[M:SAL2]DISSTOSTU) From STKLIB

# Calcul stock disponible
Local Decimal WSTUDISSTU, WSTUDIS
If find(GUSERERBPC, 2,3) WNUM=vireblc(format$("K:15X",[M:SAL2]BPCORD(NOL))+format$("K:3X",[M:SAL2]BPAADD(NOL)), 1) : Endif

#--- Issue 115110 : Added LECCVAL parameter in 10th position
WECCVALMAJ=""
If dim([M:SAL2]ECCVALMAJ)>0 & [M:SAL2]ECCVALMAJ(NOL)<>""
  If [M:SAL2]SOHCAT(NOL)=2
    WTRSTYP=17
  Else
    WTRSTYP=4
  Endif
  Call LECSRU([M:SAL2]STOFCY(NOL),[F:ITM]TCLCOD,WTRSTYP,"","",WRET) From STKLIB
  If WRET=0 & [F:SRU]ORDVER=2
     WECCVALMAJ=[M:SAL2]ECCVALMAJ(NOL)
  Endif
Endif
Call STODISALL([M:SAL2]STOFCY(NOL),[M:SAL2]ITMREF,2,[M:SAL2]ALLTYP(NOL),2,2,1,"",WNUM,WECCVALMAJ,[M:SAL2]DISSTOSTU,WRET) From STKALL
#Call STODISALL([M:SAL2]STOFCY(NOL),[M:SAL2]ITMREF,2,[M:SAL2]ALLTYP(NOL),2,2,1,"",WNUM,[M:SAL2]DISSTOSTU,WRET) From STKALL
#--- End issue 115110

If WRET=1 Return Endif
If [M:SAL2]DISSTOSTU <> 0
    [M:SAL2]DISSTOSAU=[M:SAL2]DISSTOSTU*(1/[M:SAL2]DCOE(NOL))
    Call QTEARR([M:SAL2]DISSTOSAU, [M:SAL2]SAU) From TRTDIV
Else
    [M:SAL2]DISSTOSAU = 0
Endif
Return
# ------------------------------------------------------------------- #
#                 Affichage article                                   #
# ------------------------------------------------------------------- #
$AFF_ITM
Local Integer NOL : NOL=nolign-1
Gosub LEC_ITV

Affzo [M]15
Return

# -------------------------------------------------------------------------------------
# Pour kit/sous-traité, si qté livrable calculée par rapport rupture des composants < qté allouée
# --> Affichage en vert des champs référence article, qté allouée et qté à allouer
# -------------------------------------------------------------------------------------
$COLOR_KIT
pcolor=GCOUL(0)
If find([M]LINTYP(nolign-1),2,10) & [M]DLBQTYSTU(nolign-1)<([M]YALLQTYSTU(nolign-1)+[M]YSHTQTYSTU(nolign-1))
    pcolor=GCOUL(2)
Endif
Return
######################################################################################
#------------------------------------------------------------------------------#
# Réaffichage de l'écran                                                       #
#             Appelé après le bouton allocation automatique                    #
#             Appelé après le bouton désallocation                             #
#------------------------------------------------------------------------------#
$MAJ_MSK_SAL2
Local Decimal WALLQTY, WDISSTO
Local Integer NOL    :    NOL=LNOL

If [F:SOQ]SOHNUM <> LVCRNUM | [F:SOQ]SOPLIN <> LVCRLIN | [F:SOQ]SOQSEQ <> LVCRSEQ
    Read [SOQ]SOQ0=LVCRNUM;LVCRLIN;LVCRSEQ
    If fstat : Return : Endif
Endif

[M:SAL2]SHTQTY(NOL)      = [F:SOQ]SHTQTY
[M:SAL2]YSHTQTY(NOL)      = [F:SOQ]SHTQTY
[M:SAL2]YSHTQTYSTU(NOL)   = [F:SOQ]SHTQTYSTU

[M:SAL2]YALLQTY   (NOL)  = [F:SOQ]ALLQTY
[M:SAL2]YALLQTYSTU(NOL)  = [F:SOQ]ALLQTYSTU
# --- Calcul du reste à allouer
If [M:SAL2]YALLQTY(NOL) < [M:SAL2]QTY(NOL)
    [M:SAL2]RALLQTY(NOL) = [M:SAL2]QTY(NOL)-[M:SAL2]YALLQTY(NOL)-[M:SAL2]YSHTQTY(NOL)-[M:SAL2]PREQTY(NOL)-[M:SAL2]DLVQTY(NOL)
Else
    [M:SAL2]RALLQTY(NOL) = 0
Endif
# --- rechargement du type d'allocation
[M:SAL2]ALLTYP(NOL)      = [F:SOQ]ALLTYP
# --- Calcul de la qté à allouer
If [M:SAL2]CDTSTA(NOL) = 1 & !find([M:SAL2]LINTYP(NOL), 3,4,5,11,12,13)
    [M:SAL2]ALLQTY(NOL)  = [M:SAL2]YALLQTY(NOL) + [M:SAL2]YSHTQTY(NOL) + [M:SAL2]RALLQTY(NOL)
    [M:SAL2]ALLQTYSTU(NOL) = [M:SAL2]ALLQTY(NOL) * [M:SAL2]DCOE(NOL)
    Call QTEARR([M:SAL2]ALLQTYSTU(NOL), [M:SAL2]DSTU(NOL)) From TRTDIV
Else
    [M:SAL2]ALLQTY(NOL)    = [M:SAL2]YALLQTY(NOL) + [M:SAL2]YSHTQTY(NOL)
    [M:SAL2]ALLQTYSTU(NOL) = [M:SAL2]YALLQTYSTU(NOL) + [M:SAL2]YSHTQTYSTU(NOL)
Endif

Gosub CHARGE_LIGNE

Affzo [M:SAL2]1-99
Return

# ------------------------------------------------------------------- #
#                 Chargement de la ligne dans le tableau              #
# ------------------------------------------------------------------- #
$CHARGE_LIGNE
# --- Lecture des cumuls mvts article-site
# --- Alimentation des stocks physique et dispo
Gosub LEC_ITV
Return

# --------------------------------------------------------------------- #
#     ETIQUETTES UTILISEES PAR ACTION SAISTOALL (ALLOCATIONS MANUELLES) #
#                                                                       #
#                Appelées depuis TRTSTOALLA                             #
# --------------------------------------------------------------------- #

#---------------------------------------------------------------------- #
# Action avant bouton  : Vérifications au préalable                     #
# Si GNOTALL=1 Pas d'ouverture de la fenêtre allocations manuelles      #
#---------------------------------------------------------------------- #
$AB1_NBLIG
Local Integer OK, NOL : NOL=nolign-1
Local Char    SYMBOLE(50)

#--------------------------------------------------#
# Verrouillage de la commande                      #
#--------------------------------------------------#
If [M:SAL2]SOPLIN(NOL)=[M:SAL2]SOQSEQ(NOL)
#   Ligne de commande normale
    SYMBOLE = "SOH"+[M:SAL2]SOHNUM(NOL)
Else
#   Ligne de commande ouverte
    SYMBOLE = "SOC"+num$([M:SAL2]SOPLIN(NOL))+"\"+[M:SAL2]SOHNUM(NOL)
Endif
Lock = SYMBOLE
If fstat
   # modification en cours sur un autre poste
   GERR=1 : GMESSAGE=[M:SAL2]SOHNUM(NOL)-":"-mess(10,100,1) : GNOTALL=1 : Return
Endif
# -- Ligne allouée en Global : On demande si on veut l'allouer en détaillé
If [M:SAL2]ALLTYP(NOL)=1
    OK=1 : Call OUINON (mess(144,191,1), OK) From GESECRAN
    If OK=1 GNOTALL=1 : Return : Endif
Endif

Return

#---------------------------------------------------------------------- #
# Chargement des paramètres dans masque STOALL                          #
# Cette étiquette est appelée depuis CHARGE_PARAM From TRTSTOALLA       #
#---------------------------------------------------------------------- #
$CHARGE_STOALL
#Local Char    LWRH(GLONWRH)
#Local Integer LEXC
# Chargement du masque [M:ALL]

Raz [M:ALL]
[M:ALL]VCRTYP=2
[M:ALL]VCRNUM=[M:SAL2]SOHNUM (LNOL)
[M:ALL]VCRLIN=[M:SAL2]SOPLIN (LNOL)
[M:ALL]VCRSEQ=[M:SAL2]SOQSEQ (LNOL)
[M:ALL]PCU=[M:SAL2]DSAU (LNOL)
[M:ALL]STU=[M:SAL2]STU
[M:ALL]PCUSTUCOE=[M:SAL2]DCOE (LNOL)
[M:ALL]BPCORD=[M:SAL2]BPCORD (LNOL)
[M:ALL]BPAADD=[M:SAL2]BPAADD (LNOL)
# Quantité besoin = commandé - déjà préparé - déjà livré/facturé
[M:ALL]RETQTY = [M:SAL2]QTYSTU (LNOL) - [M:SAL2]PREQTYSTU (LNOL) - [M:SAL2]DLVQTYSTU (LNOL)
If [M:ALL]RETQTY < 0 [M:ALL]RETQTY = 0 Endif

[M:ALL]OLDALLQTY = [M:SAL2]YALLQTYSTU (LNOL)
[M:ALL]SHTQTY = [M:SAL2]SHTQTYSTU (LNOL)
# Alimentation de la qté à allouer
[M:ALL]QTYTOALL  = [M:SAL2]ALLQTYSTU (LNOL)
# Alimentation de la qté déjà allouée en global
Raz [M:ALL]GLOALLQTY : If [M:SAL2]ALLTYP(LNOL)=1 [M:ALL]GLOALLQTY=[M:SAL2]YALLQTYSTU(LNOL) Endif

[M:ALL]ALLTYP = [M:SAL2]ALLTYP (LNOL)
[M:ALL]RETDAT = max(date$,[M:SAL2]SHIDAT(LNOL))
[M:ALL]DLVDAT = max(date$,[M:SAL2]EXTDLVDAT(LNOL))
[M:ALL]PECINTLOC = 2
[M:ALL]PECPLFLOC = 2    : # Prise en cpte empl quai : Oui
[M:ALL]XLOT   = [M:SAL2]LOT(LNOL)
[M:ALL]XLOC   = [M:SAL2]LOC(LNOL)
[M:ALL]XSTA   = [M:SAL2]STA(LNOL)
#Call WRHAUTO([M:SAL2]STOFCY(LNOL),[M:SAL2]ITMREF,2,0,0,LWRH,LEXC) From STKWRH
#If LEXC=1 [M:ALL]XWRH=LWRH Endif

# FGR 04/05/2015 : X3SUIVI105605 (début)
If dim([M:SAL2]ECCVALMAJ) >= 0 Then
  [M:ALL]WECCVALMAJ = [M:SAL2]ECCVALMAJ(NOL)
Endif
# FGR 04/05/2015 : X3SUIVI105605 (fin)

GTYPLIG=0
If find([M:SAL2]LINTYP(LNOL), 3,4,5,11,12,13)
    GTYPLIG=1
    Diszo [M:ALL]QTYTOALL
Endif
# On génère toujours les ruptures sur un kit/sous-traité et ses composants (sinon déphasage possible)
GDIAGENSHT=[M:DIA]GENSHT
If find([M:SAL2]LINTYP(LNOL),2,3,4,5,10,11,12,13) GDIAGENSHT=2 Endif
GRERBPC=[M:DIA]IMPCLI
If [M:SAL2]SOHCAT=2
   GPRET = 1
Else
   GPRET = 0
Endif

Return

#---------------------------------------------------------------------- #
# Contrôle avant enregistrement                                         #
# Si contrôle non OK, mettre OK=0 pour ne pas enregister                #
# Cette étiquette est appelée depuis AVANT_ENR From TRTSTOALLA          #
#---------------------------------------------------------------------- #
$AVANT_STOALL
# Quantité totale <> quantité à allouer
If [M:ALL]PECQTY < [M:ALL]QTYTOALL
    OK = 2
#   Livraison ligne/cde complète : On doit tout allouer
    If [M:DIA]ALLPAR=1 & find([M:SAL2]DME(LNOL), 2,3) & !find([M:SAL2]LINTYP(LNOL),2,10)
        Call OUINON(mess(107,191,1),OK) From GESECRAN
    Endif
    If OK <> 2 FOK=0 : Return : Endif
Endif
Return
#---------------------------------------------------------------------- #
# Mise à jour complémentaires après enregistrement                      #
# Si problème mettre GOK=0 pour annuler l'enregistrement                #
#---------------------------------------------------------------------- #
# WALLQTY contient la quantité allouée                                  #
# WSHTQTY contient la quantité en rupture                               #
#---------------------------------------------------------------------- #
$APRES_STOALL
Local Integer NOL : NOL=LNOL
Local Integer WRET, WALLSTA
Local Decimal WALLSTU, WALL, WSHT, WCPLQTY
Local Char    WMESS(120), WMESS1(120), WMESS2(80), WMESS3(80)
Local Char    WTRTLIG(1)

If [M:DIA]STOFCY <> "" WMESS-=mess(81,197,1)-":"-[M:DIA]STOFCY Endif


#Call ECR_TRACE(mess(80,197,1)-":"-[M:SAL2]ITMREF-[M:SAL2]ITMDES1,0) From GESECRAN
WMESS=mess(80,197,1)-":"-[M:SAL2]ITMREF-[M:SAL2]ITMDES1
If [M:DIA]STOFCY <> "" WMESS-=mess(81,197,1)-":"-[M:DIA]STOFCY Endif
Call ECR_TRACE(WMESS,0) From GESECRAN


WMESS1=mess(98,197,1)-":"-[M:SAL2]SOHNUM(NOL)-mess(99,197,1)-":"-[M:SAL2]BPCORD(NOL)
Call ECR_TRACE(WMESS1,0) From GESECRAN

#[M:ALL]ALLTYP=2
If WCSOQTY<>0
    Local Char WVCRRER
    WVCRRER = format$("K:"+num$(GLONBPC)+"X", [M:ALL]BPCORD)+format$("K:"+num$(GLONBPD)+"X", [M:ALL]BPAADD)
    WVCRRER = vireblc(WVCRRER, 1)
    # Si consommation des réservations clients : Maj de l'encours correspondant
    Call MAJORDBPC(1,WVCRRER,[M:SAL2]ITMREF,[M:SAL2]STOFCY(NOL),WCSOQTY,WRET) From TRTVENALL
    If WRET <> 0 GOK=0 : Return Endif
Endif
#   Mise à jour commande
Call MAJALLORD([M:ALL]VCRNUM, [M:ALL]VCRLIN, [M:ALL]VCRSEQ, [M:ALL]ALLTYP, 1, WALLQTY, WSHTQTY, WRET) From TRTVENALL
If WRET <> 0 : GOK = 0 : Return : Endif
#   Si Composé de kit, il faut allouer les composants
WALLSTU=WALLQTY+WSHTQTY
WALLSTU=WALLSTU-([M:SAL2]YALLQTYSTU(NOL)+[M:SAL2]SHTQTYSTU(NOL))
#   Alimentation de la trace
Raz WMESS
If find([M:SAL2]LINTYP(NOL),2,10) WMESS=mess([M:SAL2]LINTYP(NOL),423,1) Endif
If [M:SAL2]STOMGTCOD(NOL)=1 WMESS-=mess(283,197,1) Endif
If WMESS <>"" Call ECR_TRACE("  "+WMESS,0) From GESECRAN Endif
If [M:SAL2]STOMGTCOD(NOL)<>1
    WALL=[F:SOQ]ALLQTY -[M:SAL2]YALLQTY(NOL)
    WSHT=[F:SOQ]SHTQTY -[M:SAL2]YSHTQTY(NOL)
    WMESS1 = mess(106,197,1)+":"+format$("N:15F", WALL)-[F:SOP]SAU
    WMESS2 = mess(107,197,1)+":"+format$("N:15F", WSHT)-[F:SOP]SAU
    Call ECR_TRACE("    "+mess(479,197,1)-WMESS1-WMESS2,0) From GESECRAN
Endif
If [F:SOH]SOHCAT = 3 WCPLQTY = [F:SOQ]INVQTYSTU Else WCPLQTY = [F:SOQ]DLVQTYSTU : Endif
WALLSTA=1
If [F:SOQ]ALLQTYSTU+[F:SOQ]OPRQTYSTU+[F:SOQ]PREQTYSTU+[F:SOQ]ODLQTYSTU+WCPLQTY>=[F:SOQ]QTYSTU & [F:SOQ]SHTQTYSTU=0
    WALLSTA = 3
Elsif sum([F:SOQ]ALLQTYSTU,[F:SOQ]OPRQTYSTU,[F:SOQ]PREQTYSTU)<> 0
    WALLSTA = 2
Endif


WMESS1 = mess(480,197,1)-format$("N:15F", [F:SOQ]QTY)-[F:SOP]SAU
WMESS2 = mess(481,197,1)-format$("N:15F", [F:SOQ]ALLQTY)
WMESS3 = mess(66,191,1)-":"-format$("N:15F", [F:SOQ]SHTQTY)
Call ECR_TRACE("    "+mess(18,197,1)-format$("K:15X", mess(WALLSTA,416,1))+"=>"-WMESS1-WMESS2-WMESS3,0) From GESECRAN

Raz WTRTLIG

If find([M:SAL2]LINTYP(NOL),2,10) & WALLSTU <> 0
    If WALLSTU < 0
# ----- C'est une diminution/annulation de l'allocation
        WTRTLIG = "D"
        WALLSTU = abs(WALLSTU)
    Elsif WALLSTU > 0
# ----- C'est une augmentation de l'allocation
        If [M:SAL2]YALLQTYSTU(NOL) = 0 & [M:SAL2]SHTQTYSTU(NOL) = 0
             WTRTLIG = "C"
        Else
             WTRTLIG = "M"
        Endif
        WALLSTU=WALLQTY+WSHTQTY
    Endif
    Call GENALLKIT ([M:ALL]VCRNUM, [M:ALL]VCRLIN, [M:ALL]VCRSEQ, WTRTLIG, GRERBPC, 2, 0, 1, 1, WALLSTU,
&                   WRET) From TRTVENALL
    If WRET <> 0
        Call ECR_TRACE(WMESS1,0) From GESECRAN
        Call ECR_TRACE(mess(194,197,1), 0) From GESECRAN
        GOK=0 : Return
    Endif
Endif
#    Réaffichage du masque [M:SAL2]
If [F:SOH]SOHNUM <> [M:SAL2]SOHNUM (NOL)
    Read [SOH]SOH0=[M:SAL2]SOHNUM (NOL)
    If fstat : Return : Endif
Endif
If [F:SOQ]SOHNUM<>[M:SAL2]SOHNUM (NOL) | [F:SOQ]SOPLIN<>[M:SAL2]SOPLIN(NOL) | [F:SOQ]SOQSEQ<>[M:SAL2]SOQSEQ(NOL)
    Read [SOQ]SOQ0=[M:SAL2]SOHNUM(NOL);[M:SAL2]SOPLIN(NOL);[M:SAL2]SOQSEQ(NOL)
    If fstat : Return : Endif
Endif
If [F:SOP]SOHNUM<>[M:SAL2]SOHNUM (NOL) | [F:SOP]SOPLIN<>[M:SAL2]SOPLIN(NOL) | [F:SOP]SOPSEQ<>[M:SAL2]SOQSEQ(NOL)
    Read [SOP]SOP0=[M:SAL2]SOHNUM(NOL);[M:SAL2]SOPLIN(NOL);[M:SAL2]SOQSEQ(NOL)
    If fstat : Return : Endif
Endif
[M:SAL2]YALLQTY(NOL)    = [F:SOQ]ALLQTY
[M:SAL2]YALLQTYSTU(NOL) = [F:SOQ]ALLQTYSTU
[M:SAL2]SHTQTY(NOL)     = [F:SOQ]SHTQTY
[M:SAL2]SHTQTYSTU(NOL)  = [F:SOQ]SHTQTYSTU
[M:SAL2]YSHTQTY(NOL)    = [F:SOQ]SHTQTY
[M:SAL2]YSHTQTYSTU(NOL) = [F:SOQ]SHTQTYSTU

# --- Calcul du reste à allouer
If [M:SAL2]YALLQTY(NOL) < [M:SAL2]QTY(NOL)
    [M:SAL2]RALLQTY(NOL) = [M:SAL2]QTY(NOL)-[M:SAL2]YALLQTY(NOL)-[M:SAL2]YSHTQTY(NOL)-[M:SAL2]PREQTY(NOL)-[M:SAL2]DLVQTY(NOL)
Else
    [M:SAL2]RALLQTY(NOL) = 0
Endif

# --- rechargement du type d'allocation
[M:SAL2]ALLTYP(NOL)   = [F:SOQ]ALLTYP

# --- Calcul de la qté à allouer
If [M:SAL2]CDTSTA(NOL) = 1 & !find([M:SAL2]LINTYP(NOL), 3,4,5,11,12,13)
    [M:SAL2]ALLQTY(NOL)  = [M:SAL2]YALLQTY(NOL) + [M:SAL2]YSHTQTY(NOL) + [M:SAL2]RALLQTY(NOL)
    [M:SAL2]ALLQTYSTU(NOL) = [M:SAL2]ALLQTY(NOL) * [M:SAL2]DCOE(NOL)
    Call QTEARR([M:SAL2]ALLQTYSTU(NOL), [M:SAL2]DSTU(NOL)) From TRTDIV
Else
    [M:SAL2]ALLQTY(NOL)    = [M:SAL2]YALLQTY(NOL) + [M:SAL2]YSHTQTY(NOL)
    [M:SAL2]ALLQTYSTU(NOL) = [M:SAL2]YALLQTYSTU(NOL) + [M:SAL2]YSHTQTYSTU(NOL)
Endif

Gosub CHARGE_LIGNE

# --- Si kit/sous-traité : Calcul de la qté livrable au niveau du kit
If find([M:SAL2]LINTYP(NOL),2,10) & [M:SAL2]ALLQTYSTU(NOL)<>0
    # Au départ qté livrable=qté allouée du kit
    [M:SAL2]DLBQTYSTU(NOL)=[M:SAL2]YALLQTYSTU(NOL)
    Local Decimal WSHTQTYSTU
    Call RECSHTKIT ([M:SAL2]SOHNUM(NOL), [M:SAL2]SOPLIN(NOL), [M:SAL2]SOQSEQ(NOL), WSHTQTYSTU, WRET) From TRTVENALL
    # Qté livrable = Qté allouée du kit - Qté Rupture ramenée au niveau kit
    Local Decimal WDLBQTYSTU : WDLBQTYSTU=([M:SAL2]YALLQTYSTU(NOL)+[M:SAL2]YSHTQTYSTU(NOL))-WSHTQTYSTU
    If WDLBQTYSTU<[M:SAL2]DLBQTYSTU(NOL) [M:SAL2]DLBQTYSTU(NOL)=WDLBQTYSTU Endif

    # Affichage de la qté livrable
    GERR=4: GMESSAGE="                                  "
    If [M:SAL2]DLBQTYSTU(NOL)<([M:SAL2]YALLQTYSTU(NOL)+[M:SAL2]YSHTQTYSTU(NOL))
        Local Decimal WDLBQTY
        If [M:SAL2]DCOE(NOL)<>1
            WDLBQTY=[M:SAL2]DLBQTYSTU(NOL)*(1/[M:SAL2]DCOE(NOL))
        Else
            WDLBQTY=[M:SAL2]DLBQTYSTU(NOL)
        Endif
        Call QTEARR(WDLBQTY, [M:SAL2]DSAU(NOL)) From TRTDIV
        GMESSAGE=(mess(610,197,1)-num$(WDLBQTY)-[M:SAL2]DSAU(NOL))
    Endif
Endif

Affzo [M:SAL2]1-99

Return

#---------------------------------------------------------------------- #
# Action apres bouton                                                   #
#---------------------------------------------------------------------- #
$BB1_NBLIG
# Suppression du verrou sur la commande
Unlock=SYMBOLE

Return

##########################################################################

