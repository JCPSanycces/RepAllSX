########################################################################################################################
#
# Modification de paramètrage en attente de traitement
#
# @ver        1.0.0
# @date       07/05/2007
# @user       GBO
# @modif      07/05/2007
#
# Liste des sous-programmes :
# -------------------------
#
# UPD_WAI_TRT(PCPY,PCNX,PMOD,PCARBORD,PTYP,RCOD)
# MAJ_DEPSTA(PCPY,PCNX,PUPDTYP,PUPDPAR,PUPDVAL,PMOD,PCARBORD,RCOD)
# AM_ALLCPY(VALEUR)
# C_CPY(VALEUR)
# AM_ALLCNX(VALEUR)
# AS_CNX(VALEUR)
#
# Liste des fonctions :
# -------------------
#
# Liste des routines :
# ------------------
#
# $ACTION
# $OUVRE
# $AVANT_PAR
# $DEBUT
# $TRT_CONTEXT
# $INIT_TRT_CNX
# $TRT_RESULT_MAJ
# $MAJ_CALCNX
# $MAJ_RATPIOCAA
# $MAJ_PROWEK
# $MAJ_ISSSIMPL
# $MAJ_DPM
# $MAJ_DEROENCOUR
# $MAJ_IMLRVEISS
# $MAJ_NBEXESTO
# $MAJ_PRVSITUPD
# $MAJ_PCOAMTPMV
# $ET_TRC
# $DET_TRC
# $FIN_TRC
#
########################################################################################################################
# Modifications :
# -------------
#
# - XXX - JJ.MM.AAAA - Fq nnnnn - Commentaire
# - GLE - 14.02.2013 - Fq 87970 - Initialisation de OK et GOK avant les boucles de traitement
# - GLE - 15.11.2010 - Fq 67765 - Application des mêmes critères que dans GLOBB pour sélectionner les biens à mettre "A calculer"
# - GLE - 15.11.2010 - Fq 66894 - Optimisation des flux
# - GBO - 18.02.2010 - Fq 54343 - Concessions et provisions pour renouvellement (LDE)
########################################################################################################################
Local Char PARBOUT(250)(1..10)
VALBOUT = "12"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"UPDWAITRT","UPDWAITRT","",3, "") From GTRAITE
End
######################################################################################
$ACTION
 Case ACTION
  When "OUVRE"     : Gosub OUVRE
  When "DEBUT"     : Gosub DEBUT
  When "AVANT_PAR" : Gosub AVANT_PAR
  When "EXEC"      : Gosub EXEC
  When "END"       : ABANDON=G_OUI
  When Default
 Endcase
Return

######################################################################################

$OUVRE
 Global Integer ABANDON
Return

#-------------------------------------------------------------------------------------
$AVANT_PAR
 If !clalev([M:UWT]) : Local Mask UPDWAITRT  [UWT] : Endif
Return

#-------------------------------------------------------------------------------------
$DEBUT
  Raz [M:UWT]
  [M:UWT]ALLCPY=G_OUI
  [M:UWT]ALLCNX=G_OUI
  Grizo [M:UWT]CPY
  Grizo [M:UWT]CNX
  Affzo [M:UWT]
Return

#-------------------------------------------------------------------------------------
$EXEC

 If ABANDON=G_OUI : Kill ABANDON : Return : Endif

 Local Integer RCOD

 If GTRACE="" & !GSERVEUR
  Call OUVRE_TRACE(mess(141,7774,1)) From LECFIC
  Local Integer LTRC
 Endif

 # Appel du sous-pro de traitement
 Call UPD_WAI_TRT([M:UWT]CPY,[M:UWT]CNX,1,"*","ALL",RCOD) From UPDWAITRT

 If dim(LTRC)>0
  Call LEC_TRACE() From LECFIC
  Kill LTRC
 Endif

Return


######################################################################################
# SOUS-PROGRAMMES / ROUTINES / FONCTIONS
######################################################################################
#**
#* Sous-programme de traitement des modifications de paramètrage en attente.
#*
#* @param PCPY      : Société     Si vide, traitement de toutes les sociétés
#* @param PCNX      : Contexte    Si vide, traitement de tous les contextes des sociétés traitées
#* @param PMOD      : Mode        0 - mode silencieux / 1 - génération d'une trace.
#* @param PCARBORD  : Cadre       caractère pour dessiner les cadres
#* @param PTYP      : Type modif. CAL - Calcul / FLU - Flux / ALL - Tous FQ66894
#* @param RCOD      : Code retour
#*!
Subprog UPD_WAI_TRT(PCPY,PCNX,PMOD,PCARBORD,PTYP,RCOD)
Value    Char    PCPY
Value    Integer PCNX
Value    Integer PMOD
Value    Char    PCARBORD
Value    Char    PTYP
Variable Integer RCOD

Local Char    L_CRITCPY
Local Char    L_CRITCNX
Local Char    LIGNE(115)
Local Integer NO_MODIF   : NO_MODIF=1

If !clalev([F:CPY]) : Local File COMPANY   [CPY]  : Endif
If !clalev([F:CNX]) : Local File CONTEXT   [CNX]  : Endif
If !clalev([F:FIS]) : Local File FISCYEAR  [FIS]  : Endif
If !clalev([F:DEP]) : Local File DEPREC    [DEP]  : Endif
If !clalev([F:FAS]) : Local File FXDASSETS [FAS]  : Endif

If PCPY=""
 L_CRITCPY="1=1"
Else
 L_CRITCPY="CPY=PCPY"
Endif

If PCNX=0
 L_CRITCNX="CPY=[F:CPY]CPY"
Else
 L_CRITCNX="CNX=PCNX & CPY=[F:CPY]CPY"
Endif

For [CPY] Where evalue(L_CRITCPY)
 For [CNX] Where evalue(L_CRITCNX)
  If [F:CNX]UPDWAINBR
   If PMOD & dim(LETRC)<0 : Gosub ET_TRC : Local Integer LETRC : Endif
   Gosub TRT_CONTEXT
   If dim(LCPYTRC)<0 : Local Integer LCPYTRC : Endif
  Endif
 Next
 If dim(LCPYTRC)>0 : Kill LCPYTRC : Endif
Next
If PMOD & NO_MODIF & dim(LETRC)>0: Call ECR_TRACE2(mess(142,7774,1),0) From TRACEABX3 : Endif
If PMOD & dim(LETRC)>0 : Gosub FIN_TRC : Endif

End

#=====================================================================================
# Sous-programme de traitement des modifications de paramètrage en attente.
# Paramètre :
#  - PMOD    Mode        0 - mode silencieux / 1 - génération d'une trace.
#=====================================================================================
Subprog MAJ_DEPSTA(PCPY,PCNX,PUPDTYP,PUPDPAR,PUPDVAL,PMOD,PCARBORD,RCOD)
Value    Char    PCPY          # Société
Value    Integer PCNX          # Contexte
Value    Char    PUPDTYP       # Type de paramètre modifié
Value    Char    PUPDPAR       # Nom du paramètre modifié
Value    Char    PUPDVAL       # Valeur de paramètre
Value    Integer PMOD          # Mode
Value    Char    PCARBORD      # Caractère cadre
Variable Integer RCOD          # Code retour

Local Char    L_CRITCPY
Local Char    L_CRITCNX
Local Char    LIGNE(115)
Local Integer NO_MODIF   : NO_MODIF=1
Local Integer LTRS

If !clalev([F:CPY]) : Local File COMPANY   [CPY]  : Endif
If !clalev([F:CNX]) : Local File CONTEXT   [CNX]  : Endif
If !clalev([F:FIS]) : Local File FISCYEAR  [FIS]  : Endif
If !clalev([F:DEP]) : Local File DEPREC    [DEP]  : Endif
If !clalev([F:FAS]) : Local File FXDASSETS [FAS]  : Endif

If PCPY=""
 L_CRITCPY="1=1"
Else
 L_CRITCPY="CPY=PCPY"
Endif

If PCNX=0
 L_CRITCNX="CPY=[F:CPY]CPY"
Else
 L_CRITCNX="CNX=PCNX & CPY=[F:CPY]CPY"
Endif

Read [CPY]CPY0=PCPY
Read [CNX]CNX0=PCPY;PCNX

Gosub INIT_TRT_CNX

Raz [F:FAS]

If PUPDTYP="DPM"
 LUPDWAIPAR=PUPDPAR : Gosub MAJ_DPM       From UPDWAICOM
Else
 Case PUPDPAR
  When "CALCNX"      : Gosub MAJ_CALCNX     From UPDWAICOM
  When "PROWEK"      : Gosub MAJ_PROWEK     From UPDWAICOM
  When "RAT39BIS"    : Gosub MAJ_RAT39BIS   From UPDWAICOM
  When "DFDTYP"      : Gosub MAJ_DFDTYP     From UPDWAICOM
  When "DFDCOD"      : Gosub MAJ_DFDCOD     From UPDWAICOM
  When "DFDRAT"      : Gosub MAJ_DFDRAT     From UPDWAICOM
  When "DEROENCOUR"  : Gosub MAJ_DEROENCOUR From UPDWAICOM
  When "IMLRVEISS"   : Gosub MAJ_IMLRVEISS  From UPDWAICOM
  When "NBEXESTO"    : Gosub MAJ_NBEXESTO   From UPDWAICOM
  When "PRVSITUPD"   : Gosub MAJ_PRVSITUPD  From UPDWAICOM
  When "PCOAMTPMV"   : Gosub MAJ_PCOAMTPMV  From UPDWAICOM
  When "FLUX"        : Gosub MAJ_FLUX       From UPDWAICOM : # FQ66894
 Endcase
Endif

If OK
 #Commit
 #Rollback
 #Infbox num$(L_NBENRTRT)-"enregistrements mis à jour"
Else
 #Rollback
 #RERROR=-1
Endif

End

#-------------------------------------------------------------------------------------
$UPD_BCO
 Local Integer BFIRST : BFIRST = 1
 Local Integer MAJ_BCO
 #GOK = 1 : OK=1 : L_NBENRTRT=0                                                   : # FQ87970 : mis dans un GOSUB à part
 #If dim(LTRS)<0 : Trbegin [F:DEP], [F:FAS], [F:CNX] : Local Integer LTRS : Endif : # FQ87970 : mis dans un GOSUB à part
 Filter [F:DEP] Where evalue(L_CRIT2) & evalue(L_CRIT1) & evalue(L_CRIT3)

 MAJ_BCO = G_NON : # FQ67765

 For [F:DEP]DEP0
# DEBUT FQ67765
#  If ([F:DEP]AASREF<>[F:FAS]AASREF or BFIRST )
#   BFIRST = 0
#   Read [F:FAS]FAS0=[F:DEP]AASREF
#   If fstat>1
#    Call ECR_TRACE("UPDWAITRT/UPD_BCO "+L_PARNAM+" => Read [F:FAS]"-num$(fstat),1) From GESECRAN
#    GOK=0 : Break
#   Else
#    MAJ_BCO = G_NON
#   Endif
#   If [F:FAS]FLGCLC<>G_OUI                    : [F:FAS]FLGCLC=G_OUI                  : MAJ_BCO=G_OUI : Endif
#   If [F:FAS]FLGCNXCLC([F:DEP]CNX-1) <> G_OUI : [F:FAS]FLGCNXCLC([F:DEP]CNX-1)=G_OUI : MAJ_BCO=G_OUI : Endif
#   If G_ACTCCN=G_OUI & [F:CNX]CNX=G300CPFI
#    If [F:CNX]CCNFLG=G_OUI & [F:CNX]CCNMOD=GVML_GCRNW
#     [F:FAS]FLGRPRCLC=G_OUI : MAJ_BCO=G_OUI
#    Endif
#   Endif
#   If MAJ_BCO=G_OUI
#    Rewrite [F:FAS]
#    If fstat
#     Call ECR_TRACE("UPDWAITRT/UPD_BCO "+L_PARNAM+" => Rewrite [F:FAS]"-num$(fstat),1) From GESECRAN
#     GOK=0
#    Endif
#   Endif
#  Endif
  If [F:FAS]FLGCLC<>G_OUI                    : [F:FAS]FLGCLC=G_OUI                  : MAJ_BCO=G_OUI : Endif
  If [F:FAS]FLGCNXCLC([F:DEP]CNX-1) <> G_OUI : [F:FAS]FLGCNXCLC([F:DEP]CNX-1)=G_OUI : MAJ_BCO=G_OUI : Endif
  If G_ACTCCN=G_OUI & [F:CNX]CNX=G300CPFI
   If [F:CNX]CCNFLG=G_OUI & [F:CNX]CCNMOD=GVML_GCRNW
    [F:FAS]FLGRPRCLC=G_OUI : MAJ_BCO=G_OUI
   Endif
  Endif

# FIN FQ67765
  [F:DEP]DEPSTA=GVML_SCNOCAL
  Rewrite [F:DEP]
  If fstat
   Call ECR_TRACE("UPDWAITRT/UPD_BCO "+L_PARNAM+" => Rewrite [F:DEP]"-num$(fstat),1) From GESECRAN
   GOK=0
  Else
   L_NBENRTRT+=1
  Endif
 Next

# DEBUT FQ67765
 If MAJ_BCO=G_OUI
  Rewrite [F:FAS]
  If fstat
   Call ECR_TRACE("UPDWAITRT/UPD_BCO "+L_PARNAM+" => Rewrite [F:FAS]"-num$(fstat),1) From GESECRAN
   GOK=0
  Endif
 Endif
# FIN FQ67765

 OK=GOK
 Filter [F:DEP]
Return

#===================================================================================== FQ66894
# Sous-programme de traitement des modifications de paramètrage en attente.
# Paramètre :
#  - PMOD    Mode        0 - mode silencieux / 1 - génération d'une trace.
#=====================================================================================
Subprog MAJ_FAS(PCPY,PCNX,PUPDTYP,PUPDPAR,PUPDVAL,PMOD,PCARBORD,RCOD)
Value    Char    PCPY          # Société
Value    Integer PCNX          # Contexte
Value    Char    PUPDTYP       # Type de paramètre modifié
Value    Char    PUPDPAR       # Nom du paramètre modifié
Value    Char    PUPDVAL       # Valeur de paramètre
Value    Integer PMOD          # Mode
Value    Char    PCARBORD      # Caractère cadre
Variable Integer RCOD          # Code retour

Local Char    L_CRITCPY
Local Char    L_CRITCNX
Local Char    LIGNE(115)
Local Integer NO_MODIF   : NO_MODIF=1
Local Integer LTRS

If !clalev([F:CPY]) : Local File COMPANY   [CPY]  : Endif
If !clalev([F:CNX]) : Local File CONTEXT   [CNX]  : Endif
If !clalev([F:FIS]) : Local File FISCYEAR  [FIS]  : Endif
If !clalev([F:FAS]) : Local File FXDASSETS [FAS]  : Endif

If PCPY=""
 L_CRITCPY="1=1"
Else
 L_CRITCPY="CPY=PCPY"
Endif

If PCNX=0
 L_CRITCNX="CPY=[F:CPY]CPY"
Else
 L_CRITCNX="CNX=PCNX & CPY=[F:CPY]CPY"
Endif

Read [CPY]CPY0=PCPY
Read [CNX]CNX0=PCPY;PCNX

Gosub INIT_TRT_CNX

Raz [F:FAS]

Case PUPDPAR
 When "FLUX"      : Gosub MAJ_FLUX     From UPDWAICOM
Endcase

If OK
 #Commit
 #Rollback
 #Infbox num$(L_NBENRTRT)-"enregistrements mis à jour"
Else
 #Rollback
 #RERROR=-1
Endif

End

#------------------------------------------------------------------------------------- FQ66894
$UPD_FAS
 Local Integer MAJ_BCO
 Local Char    FLGCNXFLXS
 GOK = 1 : OK=1 : L_NBENRTRT=0
 If dim(LTRS)<0 : Trbegin [F:FAS], [F:CNX] : Local Integer LTRS : Endif
 Filter [F:FAS] Where evalue(L_CRIT1) & evalue(L_CRIT2) & evalue(L_CRIT3)

 For [F:FAS]FAS1
   MAJ_BCO    = G_NON

   If PUPDPAR="FLUX"
     FLGCNXFLXS = [F:FAS]FLGCNXFLX
     [F:FAS]FLGCNXFLX = func GLOFUNC.SETRNGSTR([F:FAS]FLGCNXFLX, [F:CNX]CNX, PUPDVAL)
     If [F:FAS]FLGCNXFLX<>FLGCNXFLXS
       MAJ_BCO=G_OUI
     Endif
   Endif

   If MAJ_BCO=G_OUI
    Rewrite [F:FAS]
    If fstat
     Call ECR_TRACE("UPDWAITRT/UPD_FAS "+L_PARNAM+" => Rewrite [F:FAS]"-num$(fstat),1) From GESECRAN
     GOK=0
    Else
     L_NBENRTRT+=1
    Endif
   Endif
 Next

 OK=GOK
 Filter [F:FAS]
Return

#-------------------------------------------------------------------------------------
# Traitement des modifications en attente pour le contexte. Pour mémoire, les modifs
# peuvent être de nature suivante :
#
#   ADP        Paramètre du chapitre AAS
#   DPM        Modification d'un mode d'amortissement
#   ADI-xxxx   Modification de la valeur d'un code de la table diverse xxxx
#   CNX        Modification d'un paramètre du contexte ou demande de recalcul complet
#
#  Ordre de traitement des populations :
#
#  Type ALL ou CAL
#  CNX    CALCNX
#  CNX    RATPIOCAA
#  CNX    PROWEK
#  CNX    RAT39BIS
#  CNX    DFDTYP
#  CNX    DFDCOD
#  CNX    DFDRAT
#  CNX    ISSIMPL
#  DPM    Tous modes
#  ADI    Toutes tables diverses
#  ADP    Tous paramètre
#
#  Type ALL ou FLU
#  CNX    FLUX
#-------------------------------------------------------------------------------------
$TRT_CONTEXT
Local    Char    PUPDTYP       # Type de paramètre modifié FQ66894
Local    Char    PUPDPAR       # Nom du paramètre modifié  FQ66894
Local    Char    PUPDVAL       # Valeur de paramètre       FQ66894

 Gosub INIT_TRT_CNX

 #> Boucle de dépilage des modifs en attente

 L_NBUPD=[F:CNX]UPDWAINBR

 While [F:CNX]UPDWAINBR>0 & L_NBUPD>0
  If find(PTYP,"ALL","CAL")<>0 : # FQ66894
    #> Calcul complet du contexte demandé

    If find("CALCNX",[F:CNX]UPDWAIPAR)
     I_UPD=find("CALCNX",[F:CNX]UPDWAIPAR)-1
     Gosub MAJ_CALCNX From UPDWAICOM : Gosub TRT_RESULT_MAJ : Goto NEXT_PARAM
    Endif

    #> Modification paramètrage du contexte

    # Recalcul de tous les biens pour tous les plans du contexte

    If find("PROWEK",[F:CNX]UPDWAIPAR)
     I_UPD=find("PROWEK",[F:CNX]UPDWAIPAR)-1
     Gosub MAJ_PROWEK From UPDWAICOM : Gosub TRT_RESULT_MAJ : Goto NEXT_PARAM
    Endif
    If find("RAT39BIS",[F:CNX]UPDWAIPAR)
     I_UPD=find("RAT39BIS",[F:CNX]UPDWAIPAR)-1
     Gosub MAJ_RAT39BIS From UPDWAICOM : Gosub TRT_RESULT_MAJ : Goto NEXT_PARAM
    Endif
    If find("DFDTYP",[F:CNX]UPDWAIPAR)
     I_UPD=find("DFDTYP",[F:CNX]UPDWAIPAR)-1
     Gosub MAJ_DFDTYP From UPDWAICOM : Gosub TRT_RESULT_MAJ : Goto NEXT_PARAM
    Endif
    If find("DFDCOD",[F:CNX]UPDWAIPAR)
     I_UPD=find("DFDCOD",[F:CNX]UPDWAIPAR)-1
     Gosub MAJ_DFDCOD From UPDWAICOM : Gosub TRT_RESULT_MAJ : Goto NEXT_PARAM
    Endif
    If find("DFDRAT",[F:CNX]UPDWAIPAR)
     I_UPD=find("DFDRAT",[F:CNX]UPDWAIPAR)-1
     Gosub MAJ_DFDRAT From UPDWAICOM : Gosub TRT_RESULT_MAJ : Goto NEXT_PARAM
    Endif
    #> Modification Mode d'amortissement

    # Recalcul de tous les biens pour tous les plans du contexte utilisant le mode modifié

    If find("DPM",[F:CNX]UPDWAITYP)
     I_UPD=find("DPM",[F:CNX]UPDWAITYP)-1
     Local Char PUPDPAR : PUPDPAR=[F:CNX]UPDWAIPAR(I_UPD)
     Gosub MAJ_DPM From UPDWAICOM : Gosub TRT_RESULT_MAJ : Goto NEXT_PARAM
    Endif

    #> Modification d'un paramètre du chapitre AAS

    # Recalcul de tous les biens nature comptable En cours pour le plan Fiscal du contexte

    If find("DEROENCOUR",[F:CNX]UPDWAIPAR)
     I_UPD=find("DEROENCOUR",[F:CNX]UPDWAIPAR)-1
     Gosub MAJ_DEROENCOUR From UPDWAICOM : Gosub TRT_RESULT_MAJ : Goto NEXT_PARAM
    Endif


    # Recalcul de tous les biens sortis pour tous les plans du contexte présentant un solde de dépréciation

    If find("IMLRVEISS",[F:CNX]UPDWAIPAR)
     I_UPD=find("IMLRVEISS",[F:CNX]UPDWAIPAR)-1
     Gosub MAJ_IMLRVEISS From UPDWAICOM : Gosub TRT_RESULT_MAJ : Goto NEXT_PARAM
    Endif

    # Recalcul de tous les biens sortis pour tous les plans du contexte

    If find("NBEXESTO",[F:CNX]UPDWAIPAR)
     I_UPD=find("NBEXESTO",[F:CNX]UPDWAIPAR)-1
     Gosub MAJ_NBEXESTO From UPDWAICOM : Gosub TRT_RESULT_MAJ : Goto NEXT_PARAM
    Endif

    # Recalcul de tous les biens sortis pour tous les plans du contexte

    If find("PRVSITUPD",[F:CNX]UPDWAIPAR)
     I_UPD=find("PRVSITUPD",[F:CNX]UPDWAIPAR)-1
     Gosub MAJ_PRVSITUPD From UPDWAICOM : Gosub TRT_RESULT_MAJ : Goto NEXT_PARAM
    Endif

    # Recalcul de tous les biens sortis pour tous les plans du contexte

    If find("PCOTVAPMV",[F:CNX]UPDWAIPAR)
     I_UPD=find("PCOTVAPMV",[F:CNX]UPDWAIPAR)-1
     Gosub MAJ_PCOAMTPMV From UPDWAICOM : Gosub TRT_RESULT_MAJ : Goto NEXT_PARAM
    Endif
  Endif

  If find(PTYP,"ALL","FLU")<>0 : # FQ66894
    #> Flux pour le contexte demandé

    If find("FLUX",[F:CNX]UPDWAIPAR)
     PUPDTYP = "FLUX"
     If func SUBCNX2.CNXFLX("[F:CNX]")
       PUPDVAL = num$(GVML_FLXNOTG)
     Else
       PUPDVAL = num$(GVML_FLXNO)
     Endif
     I_UPD=find("FLUX",[F:CNX]UPDWAIPAR)-1
     Gosub MAJ_FLUX From UPDWAICOM : Gosub TRT_RESULT_MAJ : Goto NEXT_PARAM
    Endif
  Endif

  L_NBUPD=0

  $NEXT_PARAM
  NO_MODIF=0
  If dim(LCPYTRC)<0 : Local Integer LCPYTRC : Endif
  If dim(LCNXTRC)<0 : Local Integer LCNXTRC : Endif
 Wend

 If dim(LCNXTRC)>0 : Kill LCNXTRC : Endif

Return

#-------------------------------------------------------------------------------------
$INIT_TRT_CNX

 Local Char    L_CRIT1(255)
 Local Char    L_CRIT2(255)
 Local Char    L_CRIT3(255)
 Local Char    L_CRITFAS(255) : # FQ67765
 Local Char    L_PARNAM
 Local Char    L_CPY
 Local Integer L_CNX          : # FQ67765
 Local Date    L_EXEDEB
 Local Date    L_FINEXE
 Local Date    L_DEBPER
 Local Date    L_FINPER
 #Local Integer L_PLN(1..G301MAX-1) : # FQ67765
 Local Integer I_UPD
 Local Integer OK
 Local Integer L_NBUPD
 Local Integer L_NBENRTRT
 Local Char    L_UPDWAIPAR

 #> Société

 L_CPY = [F:CPY]CPY

 #> Contexte

 L_CNX = [F:CNX]CNX  : # FQ67765

 #> Recherche des dates

 Read [FIS]FIY1=[F:CPY]CPY;[F:CNX]CNX;GVML_TECOURA
 L_DEBEXE=[F:FIS]DATSTRFIY
 L_FINEXE=[F:FIS]DATENDFIY
 L_DEBPER=[F:FIS]DATSTRPER([F:FIS]INDCURPER-1)
 L_FINPER=[F:FIS]DATENDPER([F:FIS]INDCURPER-1)

 # FQ67765 : on utilise le nouveau champs CNX de DEPREC plutôt que de passer par une liste de plans
 #> Plans à inclure dans la recherche
 #For I=1 To [F:CNX]NBPLC
 # If [F:CNX]PLNCAA(I-1)
 #  L_PLN(I)=[F:CNX]PLNCAA(I-1)
 # Else
 #  L_PLN(I)=0
 # Endif
 #Next I

 #> Préparation des critères
 Gosub INIT_CRITERES From UPDWAICNX : # FQ67765
Return

#-------------------------------------------------------------------------------------
$TRT_RESULT_MAJ
 If OK
  LIGNE += num$(L_NBENRTRT)
  Dela I_UPD,1 [F:CNX]UPDWAITYP, [F:CNX]UPDWAIPAR, [F:CNX]UPDWAIBCO
  [F:CNX]UPDWAINBR-=1
  Rewrite [CNX]
  If fstat
   Rollback
   LIGNE += mess(143,7774,1)-"CONTEXT -> fstat"-num$(fstat)
  Else
   Commit
  Endif
 Else
  LIGNE += mess(143,7774,1)-"DEPREC -> fstat"-num$(fstat)
  Rollback
 Endif
 L_NBUPD         -=1 : If PMOD : Call ECR_TRACE2(LIGNE,val(string$(1,OK<1))) From TRACEABX3 : Endif

 If dim(LTRS)>0 : Kill LTRS : Endif : # FQ79813a
Return

#-------------------------------------------------------------------------------------
$ET_TRC
 If dim(GCALOPTIM)>0 : Call ECR_TRACE2("\"+mess(139,7774,1)+"\",0) From TRACEABX3 : Endif
 LIGNE=string$(115,PCARBORD) : Call ECR_TRACE2(LIGNE,0) From TRACEABX3
 LIGNE=left$(mess(002,045,1),8)+space$(01)+
&      left$(mess(521,7773,1),8)+space$(13)+
&      left$(mess(059,100,1),4)+space$(07)+
&      left$(mess(143,105,1),9)+space$(03)+
&      left$(mess(030,109,1),8)+space$(23)+
&      left$("Nbr de modifications ou erreurs",33)
 Call ECR_TRACE2(LIGNE,0) From TRACEABX3
 LIGNE=string$(115,PCARBORD) : Call ECR_TRACE2(LIGNE,0) From TRACEABX3
Return

#-------------------------------------------------------------------------------------
$DET_TRC
 Local Char LCPY
 Local Char LCNX
 Local Char LINT(30)
 Local Char LTYP
 Local Char LPAR

 If dim(LCPYTRC)>0
  LCPY=""
 Else
  LCPY=[F:CPY]CPY
 Endif

 If dim(LCNXTRC)>0
  LCNX=""
 Else
  LCNX=mess([F:CNX]CNX,3100,1)
 Endif

 LTYP = [F:CNX]UPDWAITYP(I_UPD)
 LPAR = [F:CNX]UPDWAIPAR(I_UPD)

 Case [F:CNX]UPDWAITYP(I_UPD)
  When "ADP" : Gosub ADP_INT From UPDWAICNX
  When "DPM" : Gosub DPM_INT From UPDWAICNX
  When "CNX" : Gosub CNX_INT From UPDWAICNX
 Endcase

 If pat([F:CNX]UPDWAITYP(I_UPD),"ADI-*")
  Gosub ADI_INT From UPDWAICNX
 Endif

 LIGNE=left$(LCPY,03)                    + space$(08-len(left$(LCPY,3)))+
&      left$(LCNX,19)                    + space$(21-len(left$(LCNX,19)))+
&      left$([F:CNX]UPDWAITYP(I_UPD),08) + space$(11-len(left$([F:CNX]UPDWAITYP(I_UPD),8)))+
&      left$([F:CNX]UPDWAIPAR(I_UPD),10) + space$(12-len(left$([F:CNX]UPDWAIPAR(I_UPD),10)))+
&      left$(LINT,29)                    + space$(31-len(left$(LINT,29)))

Return

#-------------------------------------------------------------------------------------
$FIN_TRC
 LIGNE=string$(115,PCARBORD) : Call ECR_TRACE2(LIGNE,0) From TRACEABX3
#Call ECR_TRACE("",0) From GLOCALC3
Return

#------------------------------------------------------------------------------------- FQ87970
$SET_OK
  GOK = 1 : OK=1 : L_NBENRTRT=0
  If dim(LTRS)<0 : Trbegin [F:DEP], [F:FAS], [F:CNX] : Local Integer LTRS : Endif
Return

######################################################################################
# ACTIONS CHAMP DU MASQUE UWT
######################################################################################

Subprog AM_ALLCPY(VALEUR)
Variable Integer VALEUR
 If VALEUR=G_OUI
  Raz [M:UWT]CPY : Grizo [M:UWT]CPY
 Else
  Actzo [M:UWT]CPY
 Endif
 Affzo [M:UWT]CPY
End

#-------------------------------------------------------------------------------------
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
 If !clalev([F:CNX]) : Local File CONTEXT [CNX] : Endif
 Filter [CNX] Where CPY=VALEUR & UPDWAINBR<>0
 If !rowcount([F:CNX])
  GMESSAGE = "Aucune modification en attente pour les contextes de cette société" # Aucune modification en attente pour les contextes de cette société
  mkstat = 2 : Filter [F:CNX] : End
 Endif
 Filter [F:CNX]
End

#-------------------------------------------------------------------------------------
Subprog AM_ALLCNX(VALEUR)
Variable Integer VALEUR
 If VALEUR=G_OUI
  Raz [M:UWT]CNX : Grizo [M:UWT]CNX
 Else
  Actzo [M:UWT]CNX
 Endif
 Affzo [M:UWT]CNX
End

#-------------------------------------------------------------------------------------
Subprog AS_CNX(VALEUR)
Variable Integer VALEUR
 Raz GMENLOC
 If [M:UWT]ALLCNX<>G_OUI & [M:UWT]CPY<>""
  If !clalev([F:CNX]) : Local File CONTEXT [CNX] : Endif
  Local Integer I
  For I=1 To G300MAX
   Read [CNX]CNX0=[M:UWT]CPY;I
   If fstat=5 | (fstat=0 & [F:CNX]UPDWAINBR=0)
     Discombo I From CNX
   Endif
  Next I
 Endif
End

#-------------------------------------------------------------------------------------
Subprog AV_CPY(VALEUR)
Variable Char    VALEUR()
 If [M:UWT]ALLCPY=G_NON
  Actzo [M:UWT]CPY
 Endif
End
