# stocke (et vérifie) si un ABV CHP n'est passé en Dim() Ou un ABV n'est pas passé en CLALEV()
Subprog VERIFDIM(PCHAINE, PABV, PCHP, PTDIMT, PNBDIMT, PNRET)

Value Clbfile PCHAINE
Value Char PABV, PCHP
Variable Char PTDIMT()
Variable Integer PNBDIMT
Variable Integer PNRET

    Local Integer I, WBDIM


    PNRET = 0
    WBDIM = 0

    # Abrev trouvée (déjà repérée) : ==> ne pas refaire
    If PCHP <> ""
        I = find("[" + PABV + "]" + PCHP, PTDIMT(1..PNBDIMT))
        If I
            PNRET = 1
            End
        Endif
    Endif
    
    I = find("[" + PABV + "]" , PTDIMT(1..PNBDIMT))
    If I
        PNRET = 1
        End
    Endif


    If  PCHP = ""
        If pat(toupper(PCHAINE), "*CLALEV([M:"   + PABV + "])*")
            WBDIM = 2
        Endif
    Else
        If pat(toupper(PCHAINE), "*DIM(["   + PABV + "]" + PCHP + ")*")
&       or pat(toupper(PCHAINE), "*DIM([F:" + PABV + "]" + PCHP + ")*")
&       or pat(toupper(PCHAINE), "*DIM([M:" + PABV + "]" + PCHP + ")*")
            WBDIM = 1
        Endif
    Endif

    # pas de Dim ou de Clalev : contrôler
    If WBDIM = 0
        PNRET = 0
        End
    Endif

    # Abrev trouvée : ==> ne pas contrôler, c'est un test programme d'existence : on lui fait confiance
    If WBDIM = 1
        PNBDIMT += 1
        PTDIMT(PNBDIMT) = "[" + PABV + "]" + PCHP
    Else
        PNBDIMT += 1
        PTDIMT(PNBDIMT) = "[" + PABV + "]"
    Endif
    PNRET = 2
    
End

Funprog FINDMSK(PMSK, POSD, POSF)
Value Char PMSK
Value Integer POSD, POSF

Local Integer WPOS, WPOSOLD, WPOSD, WPOSF


    WPOSD = POSD
    WPOSF = POSF

    If POSF and POSF < 10
        WPOS = find(PMSK, GTCBOMSK(WPOSD..WPOSF))
        End WPOS
    Endif
    
    WPOSOLD = -1
    WPOS = int(WPOSD + (WPOSF - WPOSD)/2)
    
    While WPOS
        If PMSK = GTCBOMSK(WPOS)
            Break
        Elsif WPOS < WPOSD or WPOS >= WPOSF
            WPOS = 0
            Break
        Elsif PMSK < GTCBOMSK(WPOS)
            WPOSF = WPOS
            WPOS = int(WPOSD + (WPOSF - WPOSD)/2)
        Elsif PMSK > GTCBOMSK(WPOS)
            WPOSD = WPOS
            WPOS = int(WPOSD + (WPOSF - WPOSD)/2)
        Endif
        If WPOSOLD = WPOS
            If WPOS = WPOSF - 1 and PMSK = GTCBOMSK(WPOSF)
                WPOS = WPOSF
            Else
                WPOS = 0
            Endif
            Break
        Endif
        WPOSOLD = WPOS
    Wend
End WPOS

Subprog FINDABV(PABV, POSD, POSF, RDEBABV, RFINABV)
Value Char PABV
Value Integer POSD, POSF
Variable Integer RDEBABV, RFINABV

Local Integer WPOS, WPOSOLD, WPOSD, WPOSF

#GTCBOABV(GLONABR)(1..GMAX_NBMSK)
#    Global Integer GCBONBABV
    WPOSD = POSD
    WPOSF = POSF
    RDEBABV = 0
    RFINABV = 0

    If POSF and POSF < 10
        WPOS = find(PABV, GTCBOABV(WPOSD..WPOSF))
        If WPOS = 0
            End
        Endif
        RDEBABV = WPOS
        RFINABV = WPOS

        ICBO2 = WPOS - 1
        While ICBO2 >= WPOSD
            If GTCBOABV(ICBO2) = PABV
                RDEBABV = ICBO2
                ICBO2 -= 1
            Else
                Break
            Endif
        Wend

        ICBO2 = WPOS + 1
        While ICBO2 <= WPOSF
            If GTCBOABV(ICBO2) = PABV
                RFINABV = ICBO2
                ICBO2 += 1
            Else
                Break
            Endif
        Wend
        End
    Endif
    
    WPOSOLD = -1
    WPOS = int(WPOSD + (WPOSF - WPOSD)/2)
    
    While WPOS
        If PABV = GTCBOABV(WPOS)
            Break
        Elsif WPOS < WPOSD or WPOS >= WPOSF
            WPOS = 0
            Break
        Elsif PABV < GTCBOABV(WPOS)
            WPOSF = WPOS
            WPOS = int(WPOSD + (WPOSF - WPOSD)/2)
        Elsif PABV > GTCBOABV(WPOS)
            WPOSD = WPOS
            WPOS = int(WPOSD + (WPOSF - WPOSD)/2)
        Endif
        If WPOSOLD = WPOS
            If WPOS = WPOSF - 1 and PABV = GTCBOABV(WPOSF)
                WPOS = WPOSF
            Else
                WPOS = 0
            Endif
            Break
        Endif
        WPOSOLD = WPOS
    Wend
    
    If WPOS and PABV = GTCBOABV(WPOS)
        RDEBABV = WPOS
        RFINABV = WPOS

        ICBO2 = WPOS - 1
        While ICBO2 >= POSD
            If GTCBOABV(ICBO2) = PABV
                RDEBABV = ICBO2
                ICBO2 -= 1
            Else
                Break
            Endif
        Wend

        ICBO2 = WPOS + 1
        While ICBO2 <= POSF
            If GTCBOABV(ICBO2) = PABV
                RFINABV = ICBO2
                ICBO2 += 1
            Else
                Break
            Endif
        Wend

    Endif
End


