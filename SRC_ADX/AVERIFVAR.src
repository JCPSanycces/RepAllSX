#<AdxTL>@(#)4.0.0.0 $Revision$
######################################################
#  Traitement de vérification syntaxique grossière
#  et variables tables inexistantes
#  -----------------------------------
#  BOPP 2002 => Indus (SB)
#
#  (c) 1999-2002 ADONIX
######################################################

Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
    Call TRAITE_CHAR(VALBOUT,PARBOUT, "", "AVERIFSRC", "AVERIFSRC", 3, "") From GTRAITE
End
#------------------------------------------------------------------------------------------------------------------------#


Subprog AVERIFVAR (CHEMINTRA, PATCH, SRCPATCH, NOMTRT, DOSSIER, PMODULE, OWNER, ECREXP, EXCLSUP,
&                 PORT, MACHINE, CHEMINTRAW, TMSK, NBMSK, NBERRTOT, NBWARTOT, XVERIFVAR, XMODULE0,
&                 PNUMERREUR, PDEMANDEUR, PPASSE1FAITE, PBLISTETRT, PLIBVERIF, PVERSION)


Value Char CHEMINTRA    :  # Chemin où seront créés les fichiers de trace
Value Char PATCH        :  # Si patch, on ne vérifie que les traitement modifiés
Value Char SRCPATCH     :  # Si patch, chemin où sont les sources patchés
Value Char NOMTRT       :  # Nom du source à analyser (jokers autorisés)
Value Char DOSSIER      :  # Si non patch, dossier analysé

Value Integer PMODULE   :  # Si travail sur sources d'un module particulier
Value Integer OWNER     :  # Si on veut travailler sur les sources d'un owner particulier
Value Integer ECREXP    :  # écrire les exceptions dans le compte-rendu
Value Integer EXCLSUP   :  # exclure le module superviseur
Value Integer PORT      :  # port du dossier
Value Char MACHINE      :  # machine du dossier
Value Char CHEMINTRAW
Variable Char TMSK()    :  # Local Mask chargés ds AVERIFVAR
Variable Integer NBMSK  :  # nb Local Mask chargés ds AVERIFVAR
Variable Integer NBERRTOT, NBWARTOT
Value Integer XVERIFVAR : # ne pas éditer les erreurs si la verif des VAR est uniquement déclenchée pour celle des écrans
Value Integer XMODULE0  : # recherche des traitements sans module
Value Integer PNUMERREUR : # pour ne travailler que sur une seule erreur
Value Integer PDEMANDEUR : # niveau indus, dev, distri, spe...
Variable Integer PPASSE1FAITE, PBLISTETRT
Value Char PLIBVERIF
Value Integer PVERSION

# si on le positionne à 1 : un champ non trouvé n'apparaitra qu'une fois
# si on le positionne à 0 : on verra autant de message que de fois où on trouve ce champ
Local Integer WUNMESSPARERR
WUNMESSPARERR = 0

Local Integer MAX_NBABR, MAX_NBABRABV

MAX_NBABR    = 501
MAX_NBABRABV = 5001

Local Char ZADXIFS,ZADXIRS,ABV(3), ABV4(4), ABV5(5), ABVMES(50), CHP, WABVTROPLG(20)
Local Char ABVTL(5), CLEFILTER(10)
Local Clbfile CHAINE(3), CHAINSAV(3), CHAINCPT(3), CHAINE1(3), CHAININS(3), CHTST(3), CHAINE5(3), CHAINE6(3), CHAINELEC(3)

Local Char CHDOSSIER(100), CHDOSSIERSRC(100), DOSSIERSRC(100), CHDOSSIERSYS(100), DOSSIERSYS(100)
Local Integer BCHAINELEC
Local Integer NF, I, IP,IQ,IR,IS, NLIG,FST,NEX,OPT, TITAECRIRE, NBTRAITES, NBERREUR, NEX1, IR2
Local Char EXCEPT(30)(1000)
Local Char TXTERR(200)
Local Shortint SAUVEMODULE
Local Shortint IR3, IR4, SIMPLEQUOT , DOUBLEQUOT

Local Char TABRFICNS(6)(MAX_NBABR), TABRFICSTD(12)(MAX_NBABR), LTABLE(50), TABRFICNANA(6)(MAX_NBABR)
Local Integer NBABRNS, NBABRFICNANA
Local Char TABLIENS(6)(MAX_NBABR), TABABVLIENS(6)(MAX_NBABRABV), TABCLELIENS(10)(MAX_NBABR)
Local Char TABCLEFILTER(10)(GMAX_NBFIC)
Local Integer NBLIENS, BOK, IABF, NLIGSAV, NSK, NSKLEC

Local Char TABCLASG(12)(20), TABCLASS(12)(20)

Local Char WFILECHECK(10), WABREVCHECK(5), WTEXTE(150), WCODMSK(20), TDIMT(20)(5000)
Local Integer WIGNWRSEQ, WIGNWRTRT, IB, BTSTSYNTAX, WNRET, NBABVNF, NBDIMT, WMIGRATE, TNBCHPABV(10000)
Local Char TABVNF(6)(500), TABVCHPNF(12)(10000)

Local Integer NBWARNING, TITAECRIREW, INDERREUR, TERREUR(50), WBABVNANA
# TITAECRIRE booléen pour savoir si on a déjà écrit le nom du source

# abreviations non analysées (syntaxe complexe....) :
# passer ce booleen à 0 pour ne pas les éditer ou 1 pour éditer sur le CR des anomalies
WBABVNANA = 0

# tableaux juste pour le traitement analysé (TMSK est général et sert à un autre pgm de contrôle)
Local Char TMSKTRT(10)(100), TABVMSKTRT(10)(100, 10), TABVMSKNANA(10)(100), TERRFIC(15)(100)
Local Integer NBMSKTRT, NBABVMSKNANA, NBCHECK, EF, ILF
Local Integer MI1, MI2, MI3, BAEFFZO, PASAFFICH

# CBO 20110124 FQ70150
Local Char TABRMSKNS(6)(MAX_NBABR), TABRMSKSTD(12)(MAX_NBABR)
Local Integer NBMSKNS
# CBO 2011.02.07
Local Char WCAR(1)
Local Integer WNCAR


Global Char WCBO(250)
PNUMERREUR = mod(PNUMERREUR, 100)
#--------------------#
#Liste des exceptions
#--------------------#
If instr(1,DOSSIER,"X3")>0 Then
  Gosub LISTEX_X3
Elsif instr(1,DOSSIER,"PAY")>0 Then
  Gosub LISTEX_PAY
Elsif instr(1,DOSSIER,"GEO")>0 Then
  Gosub LISTEX_GEO
Endif

Gosub CHARGE_CL

ZADXIFS=adxifs : ZADXIRS=adxirs
adxifs=chr$(0):adxirs=chr$(10)


Call TEMPON("Vérifications des" - PLIBVERIF) From GESECRAN


    DOSSIERSRC = DOSSIER

    
    
# modif JDE : pour dissocier les sources de la base : activer les 2 lignes suivantes
#    DOSSIERSRC = adxmother(0)
#    PDEMANDEUR = 5
    If MACHINE = ""
        CHDOSSIER    = DOSSIER
        CHDOSSIERSRC = DOSSIERSRC
#        CHDOSSIERSYS = DOSSIERSYS
    Else
        CHDOSSIER    = MACHINE + ":" + num$(PORT) + "@" + DOSSIER
        CHDOSSIERSRC = MACHINE + ":" + num$(PORT) + "@" + DOSSIERSRC
#        CHDOSSIERSYS = MACHINE + ":" + num$(PORT) + "@" + DOSSIERSYS
    Endif

    If PVERSION < 7
        CHDOSSIERSYS =""
    Else
        CHDOSSIERSYS = func DOSCONT.DOSX3(CHDOSSIER)
    Endif

#-------------------------------------------------------------------------------------------#
#GTFICHIERSV : tableau des tables, contient les abréviations des tables
#GTINDFICV : tableau des indices représentant la tranche du tableau des zones pour chaque table
#GTZONESV : tableau des zones et des index, à la suite pour chaque table
#-------------------------------------------------------------------------------------------#


If clalev ([F:ATZ])
    Close File [ATZ]
Endif
If clalev ([F:ATB])
    Close File [ATB]
Endif
If clalev ([F:ATI])
    Close File [ATI]
Endif


If clalev ([F:AMK])
    Close File [AMK]
Endif
If clalev ([F:AMZ])
    Close File [AMZ]
Endif
If clalev ([F:AST])
    Close File [AST]
Endif
If clalev ([F:ADC])
    Close File [ADC]
Endif
If clalev ([F:AVW])
    Close File [AVW]
Endif
If clalev ([F:AVC])
    Close File [AVC]
Endif
If clalev ([F:AVD])
    Close File [AVD]
Endif


    Local File = CHDOSSIER + ".ATABZON" [ATZ]
    Local File = CHDOSSIER + ".ATABLE"  [ATB]
    Local File = CHDOSSIER + ".ATABIND" [ATI]
    
    Local File = CHDOSSIER + ".AMSK"    [AMK]
    Local File = CHDOSSIER + ".AMSKZON" [AMZ]
    Local File = CHDOSSIER + ".APLSTD"  [AST]

    BPASFIC = 0
    Onerrgo ERRDOSSIER
#    Local File = CHDOSSIERSRC + ".ADICTRT" [ADC]   : # table des traitements
    Local File = CHDOSSIERSYS + ".ADICTRT" [ADC]   : # table des traitements
    Onerrgo
    If BPASFIC = 1
        Local File = "ADICTRT" [ADC]
    Endif
    Local File = CHDOSSIER + ".AVIEW" [AVW]   : # table des vues
    Local File = CHDOSSIER + ".AVIEWC" [AVC]
    Local File = CHDOSSIER + ".AVIEWD" [AVD]


    If NOMTRT = "" or NOMTRT = "*" or instr(1, NOMTRT, "*")
        If PBLISTETRT = 0
            Call LISTETRT(PDEMANDEUR, PORT, MACHINE, DOSSIERSRC) From AVERIFSRC
            PBLISTETRT = 1
        Endif
    Else
    
        GNBTRTADX = 1
        GTTRAITEMENTS(1) = NOMTRT
    
    Endif
    
    If PPASSE1FAITE = 0
    
    #cbo2011
    Global Integer GMAX_NBMSK2
    GMAX_NBMSK2 = GMAX_NBMSK * 2
    Global Char GTCBOMSK(20)(1..GMAX_NBMSK2)
    Global Char GTCBOCHP(GLONAVA)(1..GMAX_ZONEMSK), GTCBOCHPB(GLONAVA)(1..GMAX_ZONEMSK), GTCBOCHPC(GLONAVA)(1..GMAX_ZONEMSK)
    Global Integer GTCBOPOSCHP(1..GMAX_NBMSK2), GCBONBMSK, GCBONBCHP

    Global Char GTCBOABV(GLONABR)(1..GMAX_NBMSK2)
    Global Integer GTCBOPOSABV(1..GMAX_NBMSK2), GCBONBABV, ICBO, ICBO2, GCBOPSD, GCBOPSF
    
    GCBONBMSK = 0
    GCBONBCHP = 0
    #    Filter [AMK] Where CODMSK < "VXACC"  PDEMANDEUR
    
    If PDEMANDEUR = -1 or PDEMANDEUR = -2
        Filter [AMK] Where CODMSK <> "" Order By CODMSK
    Elsif PDEMANDEUR = -5
        Filter [AMK] Where CODMSK >= "W" and CODMSK < "X" Order By CODMSK
    Elsif PDEMANDEUR < 10
        Filter [AMK] Where CODMSK < "W" or (CODMSK >= "X" and CODMSK < "Y") Order By CODMSK
    Else
        Filter [AMK] Where CODMSK < "W" or CODMSK >= "X" Order By CODMSK
    Endif
#    Filter [AMK] Where CODMSK < "Y" Order By CODMSK
    For [AMK]
        GCBONBMSK += 1
        GTCBOMSK(GCBONBMSK) = [F:AMK]CODMSK
        GTCBOPOSCHP(GCBONBMSK) = GCBONBCHP + 1
        
        For [AMZ] Where CODMSK=[F:AMK]CODMSK
            GCBONBCHP += 1
            If GCBONBCHP > 2 * GMAX_ZONEMSK
                GTCBOCHPC(GCBONBCHP - (2 * GMAX_ZONEMSK)) = [F:AMZ]CODZON
            Elsif GCBONBCHP > GMAX_ZONEMSK
                GTCBOCHPB(GCBONBCHP - GMAX_ZONEMSK) = [F:AMZ]CODZON
            Else
                GTCBOCHP(GCBONBCHP) = [F:AMZ]CODZON
            Endif
        Next
    Next
    Filter [AMK]
    GTCBOPOSCHP(GCBONBMSK + 1) = GCBONBCHP + 1

    GCBONBABV = 0
    If PDEMANDEUR = -1 or PDEMANDEUR = -2
        Filter [AMK] Where CODMSK <> "" Order By ABRMSK
    Elsif PDEMANDEUR = -5
        Filter [AMK] Where CODMSK >= "W" and CODMSK < "X" Order By ABRMSK
    Elsif PDEMANDEUR < 10
        Filter [AMK] Where CODMSK < "W" or (CODMSK >= "X" and CODMSK < "Y") Order By ABRMSK
    Else
        Filter [AMK] Where CODMSK < "W" or CODMSK >= "X" Order By ABRMSK
    Endif

#    Filter [AMK] Where CODMSK < "Y" Order By ABRMSK
    For [AMK]
        GCBONBABV +=1
        GTCBOABV(GCBONBABV) = [F:AMK]ABRMSK
        
        ICBO = func FINDMSK([F:AMK]CODMSK, 1, GCBONBMSK)
        If ICBO = 0
            Infbox [F:AMK]ABRMSK - [F:AMK]CODMSK - "non trouvé ds GTCBOMSK qui a enreg :" - num$(GCBONBMSK)
            GTCBOABV(GCBONBABV) = ""
            GCBONBABV -=1
            Break
        Else
            GTCBOPOSABV(GCBONBABV) = ICBO
        Endif

    Next
    Filter [AMK]

    #cbo2011
    
        # Chargement en tableaux des fichiers, rubriques et indexes
        GNBFIV=0
        GNBZOV=1
        Local Integer MAX_GNBZOV
        If PDEMANDEUR >= 0 and PDEMANDEUR <= 5
            Filter [ATZ] Where CODFIC < "W"
        Endif
        For [ATZ]CODZONE(1)
          Read [ATB]CODFIC=[ATZ]CODFIC
          If fstat=0 and [F:ATB]CODACT<>"MIG" 
            GNBFIV+=1
            GTFICHIERSV(GNBFIV)=[ATB]ABRFIC
            GTINDFICV(GNBFIV)=GNBZOV
            For [ATZ]CODZONE
              GTZONESV(GNBZOV)=[ATZ]CODZONE
              GNBZOV+=1
              If GNBZOV >= GMAX_ZONEFIC
                  MAX_GNBZOV += 1
                  GNBZOV -=1
              Endif
            Next
            For [ATI]CODIND Where CODFIC=[ATB]CODFIC
              GTZONESV(GNBZOV)=[ATI]CODIND
              GNBZOV+=1
              If GNBZOV >= GMAX_ZONEFIC
                  MAX_GNBZOV += 1
                  GNBZOV -=1
              Endif
            Next
          Endif
        Next
        GTINDFICV(GNBFIV+1)=GNBZOV

        If PDEMANDEUR >= 0 and PDEMANDEUR <= 5
            Filter [ATZ]
        Endif
    
        # Chargement en tableaux (mêmes que les fichiers) des vues, rubriques et indexes
        For [AVD]AVD1(1)
            Read [AVW]AVW0 = [AVD]CODVUE
            GNBFIV+=1
            GTFICHIERSV(GNBFIV)=[AVW]ABRVUE
            GTINDFICV(GNBFIV)=GNBZOV
            For [AVD]AVD1
              GTZONESV(GNBZOV)=[AVD]FLDVUE
              GNBZOV+=1
              If GNBZOV >= GMAX_ZONEFIC
                  MAX_GNBZOV += 1
                  GNBZOV -=1
              Endif

            Next
            For [AVC]AVC0 Where CODVUE=[AVW]CODVUE
              GTZONESV(GNBZOV)=[AVC]CODCLE
              GNBZOV+=1
              If GNBZOV >= GMAX_ZONEFIC
                  MAX_GNBZOV += 1
                  GNBZOV -=1
              Endif

            Next
        Next
        GTINDFICV(GNBFIV+1)=GNBZOV
        
        PPASSE1FAITE = 1
        GVALCBO(11) = GNBZOV + MAX_GNBZOV
    Endif

    #Fichier de trace

    Openo CHEMINTRA, -1
    SAUVEMODULE = -1
    Gosub ECRDEBUT
    Openo
    
    If XMODULE0 = 1
        Openo CHEMINTRAW, -1
        Gosub ECRDEBUT
        Openo
    Endif
    
    
    Openo CHEMINTRA, -1 Using [FER]
    If XMODULE0 = 1
        Openo CHEMINTRAW, -1 Using [FWR]
    Endif

    For NF=1 To GNBTRTADX
        If NF > GMAX_TRT
            Wrseq Using [FER]
            Wrseq Using [FER]
            Wrseq "Attention : nombre de traitements" - num$(GNBTRTADX) - "supérieur au max" - num$(GMAX_TRT)  Using [FER]
            Break
        Endif
        If PATCH = "" | filinfo(SRCPATCH + "/" + GTTRAITEMENTS(NF) + ".src", 0) > 0
          Gosub ANALYSE
        Endif
    Next NF

    If XVERIFVAR = 2
    
        Wrseq Using [FER]
        Wrseq Using [FER]
        Wrseq func AVERIFSRC.MESNUM(45, 144, num$(NBERREUR), num$(NBTRAITES), "", "", "")  Using [FER]
        Wrseq Using [FER]
        
        If XMODULE0 = 1
            Wrseq Using [FWR]
            Wrseq Using [FWR]

            Wrseq func AVERIFSRC.MESNUM(45, 144, num$(NBWARNING), num$(NBTRAITES), "", "", "")  Using [FWR]
            Wrseq Using [FWR]
        Endif
    
        If PNUMERREUR
            IR = PNUMERREUR
            ILF = PNUMERREUR
        Else    
            If XMODULE0 = 2
                IR = 1
                ILF = 2
            Else
                #cbocbocbo
                IR = 1 #3
                ILF = GNBERREUR(GNUMMOUL)
            Endif
        Endif

        Call RECAPMOUL(IR, ILF, TERREUR) From AVERIFSRC

        Wrseq Using [FER]
        Wrseq Using [FWR]
        Wrseq func AVERIFSRC.MESNUM(46, 144, PLIBVERIF, "", "", "", "") - time$  Using [FER]
        Wrseq func AVERIFSRC.MESNUM(46, 144, PLIBVERIF, "", "", "", "") - time$ Using [FWR]
    Endif


    #Wrseq "nombre de CHECK paramétrés" - num$(NBCHECK) Using [FER]
    #Wrseq Using [FER]

    If XMODULE0 = 2
        Wrseq mess(47, 144, 1) - time$ Using [FER]
    Endif
    Openo  Using [FER]
    If XMODULE0 = 1
        Openo Using [FWR]
    Endif

    adxifs=ZADXIFS : adxirs=ZADXIRS
    
    NBERRTOT += NBERREUR
    NBWARTOT += NBWARNING
    
    Call TEMPOFF From GESECRAN


    Close File [ATZ]
    Close File [ATB]
    Close File [ATI]

    Close File [AMK]
    Close File [AMZ]
    Close File [AST]
    Close File [ADC]
    Close File [AVW]
    Close File [AVC]
    Close File [AVD]
    Goto FINVAR
    
    Kill WCBO
$ECRDEBUT

    Wrseq
    Wrseq
    Wrseq
    Wrseq "-------------------------###" - func AVERIFSRC.MESNUM(48, 144, PLIBVERIF, "", "", "", "") - ". ###---------------------------"
    Wrseq
    Wrseq

    If ECREXP = 2
        Gosub ECRIREEXCPT
    Endif
    
    If PNUMERREUR
        Wrseq func AVERIFSRC.MESNUM(49, 144, num$(100 + PNUMERREUR), "", "", "", "")
    Endif

Return


$ERRDOSSIER
    BPASFIC = 1

Resume

#----------------------------------------------------------------------#

$ANALYSE

#----------------------------------------------------------------------#

    TITAECRIRE  = 1
    TITAECRIREW = 1
    PASAFFICH = 100
    TXTERR = ""
    If mod(NF,PASAFFICH)=0
        If PNUMERREUR
            Call TEMPON("V.VAR :" - num$(NF) - "/" - num$(GNBTRTADX) - GTTRAITEMENTS(NF) -
&           "module" - num$(PMODULE)) From GESECRAN
        Else
            Call TEMPON("V.VAR :" - num$(NF) - "/" - num$(GNBTRTADX) - GTTRAITEMENTS(NF) -
&           "Err" - num$(NBERREUR) - "Ano" - num$(NBWARNING))     From GESECRAN
        Endif
    Endif

    BOK = func AVERIFSRC.SRCAPASTRAITER (GTTRAITEMENTS(NF), NOMTRT, CHDOSSIERSRC, PMODULE,
&                      EXCLSUP, PATCH, SRCPATCH, OWNER, TXTERR, PDEMANDEUR)

    If find("*" + GTTRAITEMENTS(NF), EXCEPT(1..NEX))
        Return
    Endif
WCBO = GTTRAITEMENTS(NF)
    # traitements de migration de l'intégrale vers X3 : utilise des tables X... avec code activité
    If left$(GTTRAITEMENTS(NF), 3) = "SIX"
        Return
    Endif


    If BOK = 1
        Return
    Elsif BOK = 3 or BOK = 2
        If XMODULE0 = 2 # recherche source sans module
            INDERREUR = 1
            TITAECRIRE  = 0
            Call ECRTXTERR(INDERREUR, XVERIFVAR, XMODULE0, PNUMERREUR, TITAECRIRE, TITAECRIREW,
&         TXTERR, GTTRAITEMENTS(NF), TERREUR, PMODULE, NBERREUR, NBWARNING, NLIG, NLIGSAV,
&         SAUVEMODULE, CHAINE, PATCH, WMIGRATE)
        Else
            Return
        Endif
    Elsif BOK = 4
        If XMODULE0 = 2
            INDERREUR = 2
            TITAECRIRE  = 0
            Call ECRTXTERR(INDERREUR, XVERIFVAR, XMODULE0, PNUMERREUR, TITAECRIRE, TITAECRIREW,
&         TXTERR, GTTRAITEMENTS(NF), TERREUR, PMODULE, NBERREUR, NBWARNING, NLIG, NLIGSAV,
&         SAUVEMODULE, CHAINE, PATCH, WMIGRATE)
        Else
            Return
        Endif
    Endif

    #inutile de chercher dans le source pour ce cas 
    If XMODULE0 = 2
        NBTRAITES += 1
        Return
    Endif


#-------------------#
#On traite le source
#-------------------#
    GVALCBO(100 + [F:ADC]MODULE) += 1
    
    NBTRAITES += 1
    If PATCH=""
        If filinfo(filpath("TRT", GTTRAITEMENTS(NF), "src", CHDOSSIERSRC), 0) < 0
            Wrseq func AVERIFSRC.MESNUM(50, 144, GTTRAITEMENTS(NF), "", "", "", "") Using [FER]
            Return
        Endif
        Openi filpath("TRT", GTTRAITEMENTS(NF), "src", CHDOSSIERSRC), 0
    Else
        Openi SRCPATCH + "/" + GTTRAITEMENTS(NF) + ".src", 0
    Endif

    NBABRNS = 0
    NBLIENS = 0
    Raz NBMSKNS, TABRMSKNS
    Raz TABRFICNS, TABLIENS, TABABVLIENS, TABCLELIENS, TABCLEFILTER, NBABVNF, TABVNF, TABVCHPNF, TDIMT, NBDIMT
    Raz TMSKTRT, TABVMSKTRT, NBMSKTRT, TABVMSKNANA, NBABVMSKNANA, TABRFICNANA, NBABRFICNANA
    Raz TERRFIC, EF, TNBCHPABV
    FST = 0
    NLIG = -1
    NLIGSAV = -1
    
    Raz WFILECHECK, WABREVCHECK, WIGNWRSEQ, WIGNWRTRT, WMIGRATE
    CHAINELEC = ""
    BCHAINELEC = 0

    While FST=0

        Call LIREETFMT(CHAINE, CHAINELEC, BCHAINELEC, FST, NLIG, NSK, NSKLEC) From AVERIFSRC
        Call VIRECOMCHK (CHAINE, 1, 0, WFILECHECK, WABREVCHECK, WIGNWRSEQ, WIGNWRTRT, WMIGRATE) From AVERIFSRC
        #ignore ou unused source
        If WIGNWRTRT = 1  or WIGNWRTRT = 3
            Return
        Endif

   #     If WFILECHECK <> "" and WABREVCHECK <> ""
            If WIGNWRTRT >= 20 and WIGNWRTRT < 30

                WIGNWRTRT -= 20
                Read [ATB]CODFIC = WFILECHECK
                If fstat = 0
                    # ne pas mettre X fois la même abréviation
                    # chargement en tableaux des fichiers (#CHECK FILE_DECLARE)
    
                    ILF = find(WABREVCHECK, TABRFICNS(1..NBABRNS))
                    If ILF = 0
                        NBABRNS += 1
                        ILF = NBABRNS
                    Endif
                    TABRFICSTD(ILF) = [F:ATB]ABRFIC
                    TABRFICNS(ILF) = WABREVCHECK
                    CHAINE = ""
                Endif            

            Elsif WIGNWRTRT >= 30 and WIGNWRTRT < 40

                WIGNWRTRT -= 30
                Read [AMK]CODMSK = WFILECHECK
                If fstat = 0
                    # ne pas mettre X fois la même abréviation
                    # chargement en tableaux des fichiers (#CHECK FILE_DECLARE)
    
                    ILF = find(WABREVCHECK, TABRMSKNS(1..NBMSKNS))
                    If ILF = 0
                        NBMSKNS += 1
                        ILF = NBMSKNS
                    Endif
                    TABRMSKSTD(ILF) = [F:AMK]ABRMSK
                    TABRMSKNS(ILF) = WABREVCHECK
                    CHAINE = ""
                Endif            

            
            # enlever quand en prod FQ70150
#            Else
#                Read [ATB]CODFIC = WFILECHECK
#                
#                If fstat = 0
#                    # ne pas mettre X fois la même abréviation
#                    # chargement en tableaux des fichiers (#CHECK FILE_DECLARE)
#    
#                    ILF = find(WABREVCHECK, TABRFICNS(1..NBABRNS))
#                    If ILF = 0
#                        NBABRNS += 1
#                        ILF = NBABRNS
#                    Endif
#                    TABRFICSTD(ILF) = [F:ATB]ABRFIC
#                    TABRFICNS(ILF) = WABREVCHECK
#                    CHAINE = ""
#                Endif
            # fin enlever quand en prod FQ70150
            Endif
      #  Endif

        If instr(1, CHAINE, "#CHECK") or  instr(1, CHAINE, "# CHECK")
            NBCHECK += 1
        Endif    

        CHAININS = CHAINE
        CHAINE = func AVERIFSRC.DECOUPCH (CHAININS, WIGNWRSEQ)
        While CHAINE <> ""

            CHAINE5 = CHAINE
            
            # chargement en tableaux des abréviations non standard (lors de Local File)
            Call TABABRNS (CHAINE, NBABRNS, TABRFICSTD, TABRFICNS, GTTRAITEMENTS(NF), NLIG, TMSK, NBMSK,
&             TMSKTRT, TABVMSKTRT, NBMSKTRT, TABVMSKNANA, NBABVMSKNANA, TABRFICNANA, NBABRFICNANA, WBABVNANA,
&              TERRFIC, EF, XVERIFVAR, WABVTROPLG)
            If WABVTROPLG <> ""
                TXTERR = WABVTROPLG - ":" - mess(1114, 144, 1)
                Call ECRTXTERR(14, XVERIFVAR, XMODULE0, PNUMERREUR, TITAECRIRE, TITAECRIREW,
&                    TXTERR, GTTRAITEMENTS(NF), TERREUR, PMODULE, NBERREUR, NBWARNING, NLIG, NLIGSAV,
&                    SAUVEMODULE, CHAINE, PATCH, WMIGRATE)
           
            Endif
            
            For I = 1 To EF
                TXTERR = TERRFIC(I) - ":" - mess(1113, 144, 1)
                INDERREUR = 13
                CHAINE6 = CHAINE
                CHAINE = CHAINE5
                Call ECRTXTERR(INDERREUR, XVERIFVAR, XMODULE0, PNUMERREUR, TITAECRIRE, TITAECRIREW,
&                    TXTERR, GTTRAITEMENTS(NF), TERREUR, PMODULE, NBERREUR, NBWARNING, NLIG, NLIGSAV,
&                    SAUVEMODULE, CHAINE, PATCH, WMIGRATE)
                CHAINE = CHAINE6
            Next I 
           
            # Chargement en tableau des link trouvés
            Call TABLNK (CHAINE, NBLIENS, TABLIENS, TABABVLIENS, TABCLELIENS, TABRFICNS, TABRFICSTD, NBABRNS)

            # Chargement en tableau des Filter trouvés (la clef)
            Call TABFILTRE(CHAINE, GTFICHIERSV, GNBFIV, TABRFICSTD, TABRFICNS, NBABRNS, TABCLEFILTER, TABLIENS, NBLIENS, TABCLELIENS,
&                GTTRAITEMENTS(NF), NLIG, WBABVNANA, XVERIFVAR)

   
            #---------------------------------------------------------------------------------------------#
            # La ligne contient un '[' (posi=IP), ne contient pas de 'evalue', et n'est pas un commentaire
            # ne contient pas de Assign
            #---------------------------------------------------------------------------------------------# 
            Call PURGECH("", CHAINE, 1) From AVERIFSRC
#            IP = instr(1,CHAINE,"[") * (instr(1,CHAINE,"evalue")=0) * (ascii(vireblc(CHAINE,0))<>35) * (instr(1,CHAINE,"Assign")=0)
            IP = instr(1, CHAINE, "Assign")
            If IP
                IP = instr(1, CHAINE, "With")
                CHAINE = right$(CHAINE, IP + 5)
            Endif
#CBO 2011.02.07            IP = instr(1, CHAINE, "[") * (instr(1, CHAINE, "evalue")=0) * (instr(1, CHAINE, "Assign") =0)


            IP = instr(1, CHAINE, "[")
            If IP
                IQ = instr(1, CHAINE, "evalue")
                If IQ
                    IP = 0
                Else
                    IQ = instr(1, CHAINE, "Assign")
                    If IQ
                        IP = 0
                    Endif
                Endif
            Endif
#fin CBO 2011.02.07
                      
            If CHAINE = ""
                IP = 0
            Endif

            # mémo de la chaine intacte (complète avant traitement)
            CHAINCPT = CHAINE
            
            Raz ABV, ABV4, ABV5, ABVMES
            OPT=0
            
            # on peut avoir effzo (ou affzo) [M:abv]ch1 , ch2 , ch3
            If left$(CHAINCPT, 5) = "Effzo" or left$(CHAINCPT, 5) = "Affzo" or
&              left$(CHAINCPT, 5) = "Grizo" or left$(CHAINCPT, 5) = "Actzo" or
&              left$(CHAINCPT, 5) = "Diszo"
                BAEFFZO = 1
                IQ = 0
            Else
                BAEFFZO = 0
            Endif
            
            While IP

                # voir si il y a une deuxième var sur la ligne
                If OPT <> 0 and (BAEFFZO)
                    IQ = IP + 1
                    If mid$(CHAINE, IQ, 1) = " "
                        IQ += 1
                    Endif
                Else
                    OPT = 0
                Endif


                If pat(right$(CHAINE,IP),"[??]*")
                    OPT=1
                    ABV=mid$(CHAINE,IP+1, 2)
                    ABVMES = ABV
                    IQ=IP+4
                Elsif pat(right$(CHAINE,IP),"[F:??]*")
                    OPT=2
                    ABV=mid$(CHAINE,IP+3, 2)
                    ABVMES = ABV
                    IQ=IP+6
                Elsif pat(right$(CHAINE,IP),"[M:??]*")
                    OPT=3
                    ABV=mid$(CHAINE,IP+3, 2)
                    ABVMES = ABV
                    IQ=IP+6
                Elsif pat(right$(CHAINE,IP),"[M]*")
                    OPT=3
                    ABV = ""
                    ABVMES = ABV
  #                  Dbgaff
                    IQ=IP+3
                Elsif pat(right$(CHAINE,IP),"[???]*")
                    OPT=1
                    ABV=mid$(CHAINE,IP+1, 3)
                    ABVMES = ABV
                    IQ=IP+5
                Elsif pat(right$(CHAINE,IP),"[F:???]*")
                    OPT=2
                    ABV=mid$(CHAINE,IP+3, 3)
                    ABVMES = ABV
                    IQ=IP+7
                Elsif pat(right$(CHAINE,IP),"[M:???]*")
                    OPT=3
                    ABV=mid$(CHAINE,IP+3, 3)
                    ABVMES = ABV
                    IQ=IP+7
               Elsif pat(right$(CHAINE,IP),"[F:????]*")
                    OPT=2
                    ABV  = mid$(CHAINE,IP+3, 3)
                    ABV4 = mid$(CHAINE,IP+3, 4)
                    ABVMES = ABV4
                    IQ=IP+8             
               Elsif pat(right$(CHAINE,IP),"[M:????]*")
                    OPT=3
                    ABV  = mid$(CHAINE,IP+3, 3)
                    ABV4 = mid$(CHAINE,IP+3, 4)
                    ABVMES = ABV4
                    IQ=IP+8             
                Elsif pat(right$(CHAINE,IP),"[????]*")
                    OPT=1
                    ABV  = mid$(CHAINE,IP+1,3)
                    ABV4 = mid$(CHAINE,IP+1,4)
                    ABVMES = ABV4
                    IQ=IP+6    
                Elsif pat(right$(CHAINE,IP),"[F:?????]*")
                    OPT=2
                    ABV  = mid$(CHAINE,IP+3, 3)
                    ABV5 = mid$(CHAINE,IP+3, 6)
                    ABVMES = ABV5
                    IQ=IP+9
                    OPT += 10
                Elsif pat(right$(CHAINE,IP),"[M:?????]*")
                    OPT=3
                    ABV  = mid$(CHAINE,IP+3, 3)
                    ABV5 = mid$(CHAINE,IP+3, 6)
                    ABVMES = ABV5
                    IQ=IP+9 
                    OPT += 10
                Elsif pat(right$(CHAINE,IP),"[?????]*")
                    OPT=1
                    ABV  = mid$(CHAINE,IP+1, 3)
                    ABV5 = mid$(CHAINE,IP+1, 5)
                    ABVMES = ABV5
                    IQ=IP+7
                    If pat(right$(CHAINE,IP),"[G:???]*") = 0    
                        OPT += 10
                    Endif
                Endif

                
                If OPT < 4 and left$(ABV, 1) = ":"
                    OPT += 20
                Endif
                
                If OPT > 0


                    # Recherche du champ situé derrière []
                    CHP=""
                    # iq est la position du début du champ
# CBO 2011.02.07
                    While len(CHAINE) >= IQ
                        WCAR = toupper(mid$(CHAINE, IQ, 1))
                        WNCAR = ascii(WCAR)
                        If (WNCAR >= 65 and WNCAR <= 90) or (WNCAR >= 48 and WNCAR <= 57) or WNCAR = 95
                            CHP += WCAR
                            IQ + =1
                        Else
                            Break
                        Endif
                    Wend

#                    While len(CHAINE) >= IQ & instr(1, "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789_", toupper(mid$(CHAINE, IQ, 1)))
#                        CHP += toupper(mid$(CHAINE, IQ, 1))
#                        IQ + =1
#                    Wend
# fin CBO 2011.02.07
                    # vérif si test dim(...) ou clalev()

                    Call VERIFDIM(CHAINE, ABVMES, CHP, TDIMT, NBDIMT, WNRET)
                    If WNRET
                        Goto FINCTL
                    Endif    


                    TXTERR = ""
                    If CHP = "" or (ABV > "X" and PDEMANDEUR >= 0 and PDEMANDEUR < 10) : # Pour éviter les listes gauches en Z et autres cas tordus
                        Goto FINCTL
                    Endif       

                    If find(ABVMES + "." + GTTRAITEMENTS(NF), EXCEPT(1..NEX))
                        Goto FINCTL
                    Endif
                    If find(ABVMES + "." + CHP, EXCEPT(1..NEX))
                        Goto FINCTL
                    Endif
                    If find(ABVMES + "." + CHP + "." + GTTRAITEMENTS(NF), EXCEPT(1..NEX))
                        Goto FINCTL
                    Endif

                    If find(ABVMES, TABRFICNANA(1..NBABRFICNANA))
                        Goto FINCTL
                    Endif
                    IR = 0

                    If ABVMES <> ""
                        # recherche si abréviation non standard
                        # d'abord pour palier le cas d'1 std utilisée sur une autre table
                        IR = find(ABVMES, TABRFICNS(1..NBABRNS))
                        If IR
                            IR = find(TABRFICSTD(IR), GTFICHIERSV(1..GNBFIV))
                        Endif
                        # recherche sur les abrev std
                        If IR = 0
                            IR = find(ABVMES, GTFICHIERSV(1..GNBFIV))
                        Endif
                    Endif
#                    If ABVMES <> ""
#                        IR = find(ABVMES, GTFICHIERSV(1..GNBFIV))
#    
#                        # recherche si abréviation non standard
#                        If IR = 0
#                            IR = find(ABVMES, TABRFICNS(1..NBABRNS))
#                            If IR
#                                IR = find(TABRFICSTD(IR), GTFICHIERSV(1..GNBFIV))
#                            Endif
#                        Endif
#                    Endif


                    # abréviation trop longue
                    If OPT > 10
                    
                        INDERREUR = 14
                        If OPT = 11 # pas de F: ou M:
                            TXTERR = "[" + ABVMES + "]" + CHP - ":" - mess(1114, 144, 1)
                        Elsif OPT = 12 # F:
                            TXTERR = "[F:" + ABVMES + "]" + CHP - ":" - mess(1114, 144, 1)
                        Elsif OPT = 13 # M:
                            TXTERR = "[M:" + ABVMES + "]" + CHP - ":" - mess(1114, 144, 1)
                        Elsif OPT = 21 # :
                            TXTERR = "[" + ABVMES + "]" - ":" - "Abrev hors syntaxe"
                        Elsif OPT = 22 # F::
                            TXTERR = "[F:" + ABVMES + "]" - ":" - "Abrev hors syntaxe"
                        Elsif OPT = 23 # M::
                            TXTERR = "[M:" + ABVMES + "]" - ":" - "Abrev hors syntaxe"
                        Endif
                    
                        IR = 0
                    Endif

                    # abreviation trouvée d'1 fichier
                    If IR
                        
                        CLEFILTER = TABCLEFILTER(IR)
                      
                        IS=find(CHP, GTZONESV(GTINDFICV(IR)..GTINDFICV(IR+1)-1)):  # IS=0 => CHP n'est ni un champ ni un index
                        #--------------------------------------------------------------------------------------#
                        # Filtrage des champs dans une chaîne de caractère (ex : ZONE="[F:GAC]CCE"+num$(I)  )
                        # Filtrage des dim([F:ABV]CHAMP)
                        # Filtrage des Filter ou Delete [F:ABV]Where
                        # Filtrage des Read [F:ABV]Curr
                        # Filtrage des [F:ABV]CLE
                        # Filtrage des exceptions recensées
                        #--------------------------------------------------------------------------------------#
                        If IS=0
                            Gosub TSTSYNTAX
                            
                            If BTSTSYNTAX

                                # on a trouvé un fichier mais pas un de ses champs mais avec 1 syntaxe fichier : donc Ok...
                                # pas d'erreur 
                                TXTERR  = ""
                            Else
                                # on a trouvé un fichier mais pas un de ses champs et sans 1 syntaxe fichier: donc pb :


                                # si on a un Filter avec order by  CLEF = CHP : c'est Ok            
                                If CLEFILTER <> CHP
                                    # vérif si test dim(...)

                                    # recherche une déclaration dans le code (ligne ou instruction précédente)
                                    If func DECLARAVT(CHAINSAV, ABVMES, CHP) = 0
                                        If OPT = 1 # pas de F: ou M:
                                            # recherche si c'est un masque
                                            Call LIRABVCHP (ABVMES, CHP, WNRET, WCODMSK,
&                                             TABVNF, NBABVNF, TABVCHPNF, TMSKTRT, TABVMSKTRT,
&                                              NBMSKTRT, TABVMSKNANA, NBABVMSKNANA, WUNMESSPARERR, DOSSIER, NLIG, TNBCHPABV,
&                                              NBMSKNS, TABRMSKNS, TABRMSKSTD)
                                            If WNRET = 1 or (WNRET = 2  and val(CHP) = 0)
                                                TXTERR = "[" - ABVMES - "]" + CHP - ":" - mess(58, 144, 1)
                                                INDERREUR = 7
                                            Endif
                                        Elsif OPT = 2 # F:
        
                                            TXTERR = "[F:" + ABVMES + "]" + CHP - ":" - mess(1109, 144, 1)
                                            INDERREUR = 9

                                        Elsif OPT = 3 # M:
                                            Call LIRABVCHP (ABVMES, CHP, WNRET, WCODMSK,
&                                             TABVNF, NBABVNF, TABVCHPNF, TMSKTRT, TABVMSKTRT, NBMSKTRT,
&                                              TABVMSKNANA, NBABVMSKNANA, WUNMESSPARERR, DOSSIER, NLIG, TNBCHPABV,
&                                              NBMSKNS, TABRMSKNS, TABRMSKSTD)
                                            If WNRET = 1
                                                TXTERR = "[M:" + ABVMES + "]" - ":" - mess(1105, 144, 1)
                                                INDERREUR = 5
                                            Elsif WNRET = 2 and val(CHP) = 0
                                                TXTERR = "[M:" + ABVMES + "]" + CHP - ":" - mess(1108, 144, 1)
                                                INDERREUR = 8
                                            Endif
                                        Endif
                                    Endif
                                Endif
                
                            Endif
                        Else
                            # on a trouvé un fichier et un de ses champs : donc Ok...
                            TXTERR  = ""
                        Endif
                    Else

        
                        # recherche si c'est un link as : on ne contrôle pas ici
                
                        If OPT = 1 or OPT = 2
                            IR = find(ABVMES, TABLIENS(1..499))
                        Else
                            IR = 0
                        Endif
                        
                        
                        # ce n'est pas un lnk, on regarde ce que c'est...
                        If IR = 0
                            If func DECLARAVT(CHAINSAV, ABVTL, CHP) = 0
                                If OPT = 1
                                    If  left$(ABVMES, 2) = "G:"
                                        If find(CHP, TABCLASG) = 0
                                            TXTERR = "[G:" + ABVMES + "]" + CHP - ":" - mess(1110, 144, 1)
                                            INDERREUR = 10
                                        Endif
                                    # on ne passe jamais ici...
                                    Elsif  left$(ABVMES, 2) = "S:"
                                        If find(CHP, TABCLASS(1..10)) = 0
                                            TXTERR = "[S:]" + CHP - ":" - mess(1111, 144, 1)
                                            INDERREUR = 11
                                        Endif
                                    Elsif left$(ABVMES, 2) <> "V:" and left$(ABVMES, 2) <> "L:"
     
                                            Call LIRABVCHP (ABVMES, CHP, WNRET, WCODMSK,
&                                             TABVNF, NBABVNF, TABVCHPNF, TMSKTRT, TABVMSKTRT, NBMSKTRT,
&                                              TABVMSKNANA, NBABVMSKNANA, WUNMESSPARERR, DOSSIER, NLIG, TNBCHPABV,
&                                              NBMSKNS, TABRMSKNS, TABRMSKSTD)
                                            If WNRET = 1
                                                TXTERR = "[" + ABVMES + "]" - ":" - mess(1104, 144, 1)
                                            INDERREUR = 4
                                        Elsif WNRET = 2 and val(CHP) = 0
                                            TXTERR = "[" + ABVMES + "]" + CHP - ":" - mess(58, 144, 1)
                                            INDERREUR = 7
                                        Endif
    
                                    Endif
                                Elsif OPT = 2
                                # c'est du F:

                                    IABF = find(ABVMES, TABVNF(1..NBABVNF))
                                    If IABF = 0
                                        NBABVNF += 1
                                        TABVNF(NBABVNF) = ABVMES
    
                                        TXTERR = "[F:" + ABVMES + "]" - ":" - mess(1106, 144, 1)
                                        INDERREUR = 6
                                    Endif
                                Elsif OPT = 3
                                    # c'est du M:
                                    Call LIRABVCHP (ABVMES, CHP, WNRET, WCODMSK,
&                                        TABVNF, NBABVNF, TABVCHPNF, TMSKTRT, TABVMSKTRT, NBMSKTRT,
&                                        TABVMSKNANA, NBABVMSKNANA, WUNMESSPARERR, DOSSIER, NLIG, TNBCHPABV,
&                                        NBMSKNS, TABRMSKNS, TABRMSKSTD)
                                    If WNRET = 1
                                        TXTERR = "[M:" + ABVMES + "]" - ":" - mess(1105, 144, 1)
                                        INDERREUR = 5
                                    Elsif WNRET = 2 and val(CHP) = 0
                                        TXTERR = "[M:" + ABVMES + "]" + CHP - ":" - mess(1108, 144, 1)
                                        INDERREUR = 8
                                    Endif
                                Endif
                            Endif
                        Endif
                        
                        # on n'a pas trouvé le champ et l'abrev correspond à un Link
                        If TXTERR <> "" and IR    
                            # si For [ABV]CHP et CHP est la def dans Order by Key : c'est bon
                            If TABCLELIENS(IR) <> CHP
                                # boucle sur les abrev du link pour trouver les fichiers et vérifier si CHP appartient à un d'eux
                                IR2 = 1
     
                                LTABLE = ""
                                While IR2 > 0 and IR2 <= 10
                                    ABVTL = TABABVLIENS(10*(IR -1) + IR2)
                                    If ABVTL <> ''
                                        If LTABLE = ""
                                            LTABLE = ABVTL
                                        Else
                                            LTABLE = LTABLE + "," - ABVTL
                                        Endif

                                        # recherche dans la table des abrevs
        
                                        If CHP <> "" and (ABV <= "X" or PDEMANDEUR < 0 or PDEMANDEUR > 5) : # Pour éviter les listes gauches en Z et autres cas tordus
                                            IR3 = find(ABVTL, GTFICHIERSV(1..GNBFIV))
    
                                            # recherche si abréviation non standard
                                            If IR3 = 0
                                                IR3 = find(ABVTL, TABRFICNS(1..NBABRNS))
                                                If IR3
                                                    IR3 = find(TABRFICSTD(IR3), GTFICHIERSV(1..GNBFIV))
                                                Endif
                                            Endif
                    
                    
                                            # abreviation d'1 fichier
                                            If IR3
                                                If find(CHP, GTZONESV(GTINDFICV(IR3)..GTINDFICV(IR3+1)-1))
                                                #
                                                    IR2 = 20
                                                    Break
                                                Endif
                                            Endif
                                        Endif                                
                                        IR2 += 1
                                    Else
                                        IR2 = 0
                                    Endif
                                Wend
                            
                                # champ non trouvé    
                                If IR2 < 20
                                    If func DECLARAVT(CHAINSAV, ABVTL, CHP) = 0
                                        TXTERR = "[" + ABVMES + "]" - ":" - mess(1112, 144, 1) - LTABLE
                                        INDERREUR = 12
                                    Endif
                                Else
                                    # trouvé en Link : donc pas d'erreur...
                                    TXTERR = ""
                                Endif
                            Endif
                        Endif
                    Endif


$FINCTL
                    # affichage erreur
                    Call ECRTXTERR(INDERREUR, XVERIFVAR, XMODULE0, PNUMERREUR, TITAECRIRE, TITAECRIREW,
&                        TXTERR, GTTRAITEMENTS(NF), TERREUR, PMODULE, NBERREUR, NBWARNING, NLIG, NLIGSAV,
&                        SAUVEMODULE, CHAINE, PATCH, WMIGRATE)

                Endif

                If IQ < IP
                    IQ = IP + 1
                Endif

                # CBO 20110418 FQ73335
                If BAEFFZO
                    IR = instr(IP+1, CHAINE, "(")
                    If IR
                        IP = instr(IR+1, CHAINE, ")")
                    Endif
                Endif

                IP = instr(IP+1, CHAINE, "[")
                If IP = 0 and BAEFFZO
                    IP = instr(IQ, CHAINE, ",")
                Endif
            Wend

$FINCH        
            CHAINE = func AVERIFSRC.DECOUPCH (CHAININS, WIGNWRSEQ)
        
            # sauvegarde pour analyse
            If CHAINCPT <> "" and left$(CHAINCPT, 1) <> "#"
                CHAINSAV = CHAINCPT
            Endif

        Wend

    Wend
    
    If NBABRNS > GVALCBO(12)
        GVALCBO(12) = NBABRNS
    Endif

    If NBABVMSKNANA > GVALCBO(13)
        GVALCBO(13) = NBABVMSKNANA
    Endif
   
    If NBABRFICNANA > GVALCBO(14)
        GVALCBO(14) = NBABRFICNANA
    Endif          

    
Return


$TSTSYNTAX

        #
        # On va exclure du contrôle :
        #
        #    les champs vides
        #    les lignes où l'abreviation de la classe est > 'X'
        #    les champs qui sont un indexe
        #    les abreviations absentes du tableau GTFICHIERSV (donc doivent être des masques)
        #
        # On va contrôler si la chaîne fait partie d'une liste de cas possibles :
        #
        #    si elle n'y est pas : il peut y avoir un problème
        #
        #    derrière []champ un '
        #    derrière []champ un "

        #    derrière []WHERE qq chose
        #    derrière READ[]CURR qq chose
        #    derrière []CLE qq chose
        #    ABREV.CHAMP dans la liste des exceptions
        #    ABREV.CHAMP.TRAITEMENT dans la liste des exceptions
        #    derrière DIM([ABV]CHP qq chose
        #    derrière *???ZO[ABV]CHP qq chose
        #    derrière READ[ABV]FIRST qq chose
        #    derrière READ[ABV]LAST qq chose
        #    derrière READ[ABV]NEXT qq chose
        #    derrière READ[ABV]PREV qq chose
        #    derrière DELETE[ABV]CURR qq chose
        #    derrière LOOK[ABV]FIRST qq chose
        #    derrière LINK[ABV]WITH qq chose

        # ajout CBO 2008.09.12
        #    derrière FOR[ABV]RECKEY qq chose

#&                       or pat(toupper(CHAINE),   "*DIM([" + ABVMES + "]"  + CHP + ")*") = 1 
#&                       or pat(toupper(CHAINE), "*DIM([F:" + ABVMES + "]"  + CHP + ")*") = 1 

    BTSTSYNTAX = 0
    CHTST = toupper(vireblc(CHAINE, 4))
    
    If  pat(CHTST,   "*[" + ABVMES + "]" + CHP + "'*") = 1
&    or pat(CHTST,   "*[" + ABVMES + "]" + CHP + '"*') = 1
&    or pat(CHTST, "*[F:" + ABVMES + "]" + CHP + '"*') = 1
&    or pat(CHTST, "*[F:" + ABVMES + "]" + CHP + "'*") = 1
        BTSTSYNTAX = 1
        Return
    Endif
    
    If pat(CHTST,         "*[" + ABVMES + "]WHERE*") = 1
&   or pat(CHTST,       "*[F:" + ABVMES + "]WHERE*") = 1
&   or pat(CHTST,         "*[" + ABVMES + "]CLE*") = 1
&   or pat(CHTST,       "*[F:" + ABVMES + "]CLE*") = 1
&   or (pat(CHTST, "*???ZO["   + ABVMES + "]" + CHP + "*") = 1 and val(CHP))
&   or (pat(CHTST, "*???ZO[M:" + ABVMES + "]" + CHP + "*") = 1 and val(CHP))
        BTSTSYNTAX = 2
        Return
    Endif
    
    If pat(CHTST,    "*READ[" + ABVMES + "]CURR*") = 1
&   or pat(CHTST,  "*READ[F:" + ABVMES + "]CURR*") = 1
&   or pat(CHTST,    "*READ[" + ABVMES + "]FIRST*") = 1
&   or pat(CHTST,  "*READ[F:" + ABVMES + "]FIRST*") = 1
&   or pat(CHTST,    "*READ[" + ABVMES + "]LAST*") = 1
&   or pat(CHTST,  "*READ[F:" + ABVMES + "]LAST*") = 1
&   or pat(CHTST,    "*READ[" + ABVMES + "]NEXT*") = 1
&   or pat(CHTST,  "*READ[F:" + ABVMES + "]NEXT*") = 1
&   or pat(CHTST,    "*READ[" + ABVMES + "]PREV*") = 1
&   or pat(CHTST,  "*READ[F:" + ABVMES + "]PREV*") = 1
        BTSTSYNTAX = 3
        Return
    Endif
    
    If pat(CHTST,   "*READLOCK[" + ABVMES + "]CURR") = 1
&   or pat(CHTST, "*READLOCK[F:" + ABVMES + "]CURR") = 1
&   or pat(CHTST,   "*READLOCK[" + ABVMES + "]FIRST") = 1
&   or pat(CHTST, "*READLOCK[F:" + ABVMES + "]FIRST") = 1
&   or pat(CHTST,   "*READLOCK[" + ABVMES + "]LAST") = 1
&   or pat(CHTST, "*READLOCK[F:" + ABVMES + "]LAST") = 1
&   or pat(CHTST,   "*READLOCK[" + ABVMES + "]NEXT") = 1
&   or pat(CHTST, "*READLOCK[F:" + ABVMES + "]NEXT") = 1
&   or pat(CHTST,   "*READLOCK[" + ABVMES + "]PREV") = 1
&   or pat(CHTST, "*READLOCK[F:" + ABVMES + "]PREV") = 1
        BTSTSYNTAX = 3
        Return
    Endif

    If pat(CHTST,   "*REWRITE[" + ABVMES + "]FIRST*") = 1
&   or pat(CHTST, "*REWRITE[F:" + ABVMES + "]FIRST*") = 1
&   or pat(CHTST,   "*REWRITE[" + ABVMES + "]LAST*") = 1
&   or pat(CHTST, "*REWRITE[F:" + ABVMES + "]LAST*") = 1
&   or pat(CHTST,   "*REWRITE[" + ABVMES + "]NEXT*") = 1
&   or pat(CHTST, "*REWRITE[F:" + ABVMES + "]NEXT*") = 1
&   or pat(CHTST,   "*REWRITE[" + ABVMES + "]PREV*") = 1
&   or pat(CHTST, "*REWRITE[F:" + ABVMES + "]PREV*") = 1
&   or pat(CHTST,    "REWRITE[" + ABVMES + "]CURR*") = 1
&   or pat(CHTST,  "REWRITE[F:" + ABVMES + "]CURR*") = 1
        BTSTSYNTAX = 3
        Return
    Endif

    If pat(CHTST,   "*DELETE[" + ABVMES + "]CURR*") = 1
&   or pat(CHTST, "*DELETE[F:" + ABVMES + "]CURR*") = 1
&   or pat(CHTST,     "*LOOK[" + ABVMES + "]FIRST*") = 1
&   or pat(CHTST,   "*LOOK[F:" + ABVMES + "]FIRST*") = 1
&   or pat(CHTST,     "*LINK[" + ABVMES + "]WITH*") = 1
&   or pat(CHTST,   "*LINK[F:" + ABVMES + "]WITH*") = 1
&   or pat(CHTST,      "*FOR[" + ABVMES + "]RECKEY*") = 1
&   or pat(CHTST,    "*FOR[F:" + ABVMES + "]RECKEY*") = 1
&   or pat(CHTST,      "*FOR[" + ABVMES + "]HINTKEY*") = 1
&   or pat(CHTST,    "*FOR[F:" + ABVMES + "]HINTKEY*") = 1
        BTSTSYNTAX = 3
        Return
    Endif

#    If find(ABVMES + "." + CHP, EXCEPT(1..NEX)) <> 0
#&   or find(ABVMES + "." + CHP + "." + GTTRAITEMENTS(NF), EXCEPT(1..NEX)) <> 0
#        BTSTSYNTAX = 4
#        Return
#    Endif
Return



