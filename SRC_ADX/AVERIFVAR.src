#**
#* ecrit l'erreur trouvée dans le fichier de trace
#*
#* @since 02/05/2010
#* 
#* @param INDERREUR 
#* @param XVERIFVAR 
#* @param XMODULE0 
#* @param PNUMERREUR 
#* @param TITAECRIRE 
#* @param TITAECRIREW 
#* @param TXTERR 
#* @param PTRAITEMENT 
#* @param TERREUR 
#* @param PMODULE 
#* @param NBERREUR 
#* @param NBWARNING 
#* @param NLIG 
#* @param NLIGSAV 
#* @param SAUVEMODULE 
#* @param CHAINE 
#* @param PATCH 
#*!
Subprog ECRTXTERR(INDERREUR, XVERIFVAR, XMODULE0, PNUMERREUR, TITAECRIRE, TITAECRIREW,
&         TXTERR, PTRAITEMENT, TERREUR, PMODULE, NBERREUR, NBWARNING, NLIG, NLIGSAV,
&         SAUVEMODULE, CHAINE, PATCH, PMIGRATE)

Value Integer INDERREUR, XVERIFVAR, XMODULE0, PNUMERREUR
Variable Integer TITAECRIRE, TITAECRIREW
Value Char TXTERR, PTRAITEMENT
Variable Integer TERREUR()
Value Integer PMODULE
Variable Integer NBERREUR, NBWARNING, NLIG, NLIGSAV
Variable Shortint SAUVEMODULE
Value Clbfile CHAINE
Value Char PATCH
Value Integer PMIGRATE


    If TXTERR = ""
        End
    Endif
    If XVERIFVAR <> 2 and (XMODULE0 <> 2 or INDERREUR > 2)
        End
    Endif
    
    If PNUMERREUR
        If PNUMERREUR <> INDERREUR
            TXTERR = ""
            End
        Endif
    Else
        # désactivation temporaire de ces erreurs
        If GBTDESACTIVE(GNUMMOUL, INDERREUR) or (PMIGRATE and GTMIGRATE(GNUMMOUL, INDERREUR))
            TXTERR = ""
            End
        Endif
    Endif
    
    Call ECRIRETITRE(TITAECRIRE, TITAECRIREW, INDERREUR, PMODULE, PTRAITEMENT, SAUVEMODULE,
&       NBERREUR, NBWARNING, NLIG, NLIGSAV) From AVERIFSRC


    TERREUR(INDERREUR) += 1
    GTRECAPERR(GNUMMOUL, [F:ADC]MODULE, INDERREUR) += 1
    If GBTWARNING(GNUMMOUL, INDERREUR)
        If INDERREUR < 3
            Wrseq "  *** (" + mess(55, 144, 1) - num$(INDERREUR + 100) + ")" - TXTERR Using [FWR]
        Else
            Wrseq "  *** (" +  mess(57, 144, 1) - num$(NLIG) -  mess(55, 144, 1) - num$(INDERREUR + 100) + ")" - TXTERR Using [FWR]
            If CHAINE <> "" and PATCH <> ""
                Wrseq "  -->" - CHAINE  Using [FWR]
            Endif
        Endif
    Else
        If INDERREUR < 3
            Wrseq "  *** (" +  mess(56, 144, 1) - num$(INDERREUR + 100) + ")" - TXTERR Using [FER]
        Else
            Wrseq "  *** (" +  mess(57, 144, 1) - num$(NLIG) -  mess(56, 144, 1) - num$(INDERREUR + 100) + ")" - TXTERR Using [FER]
            If CHAINE <> "" and PATCH <> "" ###and (INDERREUR = 13 or INDERREUR = 113)
                Wrseq "  -->" - CHAINE  Using [FER]
            Endif
        Endif
    Endif
 
    TXTERR = ""
End
#______________________________________________________
# vérifie si l'instruction précédente déclare un filtre
# = 1 : FILTRE TROUVé SINON 0
Funprog DECLARAVT(PCHPREC, PABV, PCHP)
Value Clbfile PCHPREC
Value Char PABV
Value Char PCHP


    # instruction de déclaration...
    If pat(PCHPREC, "*FILTER*") = 1 or pat(PCHPREC, "*Filter*") = 1 or
&      pat(PCHPREC, "*Order By Key*") = 1 or pat(PCHPREC, "*ORDER BY KEY*")
    
    
        # déclaration de la zone contrôlée
        If pat(PCHPREC, "*[" + PABV + "]*") = 1 or pat(PCHPREC, "*Order By Key" - PCHP - "*") = 1 or
&          pat(PCHPREC, "*ORDER BY KEY" - PCHP - "*") = 1
            End 1
        Endif
    Endif
        
    # si abrev, chp trouvée ds la ligne précédente : on a déjà contrôlé : c'est pas la peine de le refaire
    If pat(PCHPREC, "*[" + PABV + "]" + PCHP + "*") or  pat(PCHPREC, "*[F:" + PABV + "]" + PCHP + "*") or  pat(PCHPREC, "*[M:" + PABV + "]" + PCHP + "*")
        End 2
    Endif

End 0


# chargement en tableaux des abréviations non standard pour trouver la standard + chargement des Local mask
Subprog TABABRNS(PCHAINE, NBABRNS, TABRFICSTD, TABRFICNS, PTRAITEMENT, PNLIG, TMSK, NBMSK,
&       TMSKTRT, TABVMSKTRT, NBMSKTRT, TABVMSKNANA, NBABVMSKNANA, TABRFICNANA, NBABRFICNANA, WBABVNANA,
&       PTERRFIC, PEF, PXVERIFVAR, RABREV)
Variable Clbfile PCHAINE
Variable Integer NBABRNS
Variable Char TABRFICSTD()
Variable Char TABRFICNS()
Value Char PTRAITEMENT
Value Integer PNLIG
Variable Char TMSK()
Variable Integer NBMSK
Variable Char TMSKTRT(), TABVMSKTRT()(,)
Variable Integer NBMSKTRT
Variable Char TABVMSKNANA()
Variable Integer NBABVMSKNANA
Variable Char TABRFICNANA()
Variable Integer NBABRFICNANA
Value Integer WBABVNANA
Variable Char PTERRFIC()
Variable Integer PEF
Value Integer PXVERIFVAR
Variable Char RABREV

Local Char CH1(100), CH2(100), WFIC(50), WABVDECL(10), WABV(10)
Local Integer ILF, ILF2, ILF3, POSEGAL, ILF4, CPTRPAR
Local Clbfile WCHAINE(3)

    PEF = 0
    POSEGAL = 0
    RABREV = ""

    # chargement du tableau des masques (pour la vérif des écrans)
    
    ILF = instr(1, PCHAINE, "Local Mask")
    If ILF
        If instr(1, PCHAINE, "Close Local Mask")
            PCHAINE = ""
            End
        Endif

        Call CHGLCLMSK (PCHAINE, TMSK, NBMSK, TMSKTRT, TABVMSKTRT, NBMSKTRT, PTRAITEMENT, PNLIG,
&            TABVMSKNANA, NBABVMSKNANA, WBABVNANA, PXVERIFVAR, RABREV, ILF)
        End
    Endif


    # chargement des local file
    
    If instr(1, PCHAINE, "Local File")
        If instr(1, PCHAINE, "Close Local File")
            PCHAINE = ""
            End
        Endif
    Else
        End
    Endif


    # 1°) recherche des local file ... from ... As [ABV] ...
    WCHAINE = PCHAINE
    ILF = instr(1, WCHAINE, "From")
    If ILF
        ILF = instr(ILF, WCHAINE, "As")
        If ILF

            CH2 = right$(WCHAINE, ILF + 2)
            ILF = instr(1, CH2, "[")
            If ILF
                CH2 = right$(CH2, ILF + 1)
                ILF = instr(1, CH2, "]")
                If ILF
                    WABV = left$(CH2, ILF - 1)
                    
                    If WABV <> ""
                        If left$(WABV, 2) = "F:"
                            WABV = right$(WABV, 3)
                        Endif
                        If len(WABV) > 4
                            RABREV = "[F:" + WABV + "]"
                        Endif
                        NBABRFICNANA += 1
                        TABRFICNANA(NBABRFICNANA) = WABV
                    Endif
                    PCHAINE = ""
                    End
                Endif
            Endif
        Endif
        
        If PXVERIFVAR = 2 and WBABVNANA
            Wrseq "  .....9991" - PTRAITEMENT - "(" + num$(PNLIG) + ") abréviation table" - WABV - "non traitée."  Using [FWR]
            Wrseq "  ---->" - PCHAINE Using [FWR]
        Endif
        PCHAINE = ""
        End
    Endif

    # 2°) recherche des local file fic1 [ABV1], fic2 [ABV2] ...

    WCHAINE = PCHAINE
    ILF3 = instr(1, WCHAINE, "Where")
    If ILF3
        WCHAINE = left$(WCHAINE, ILF3 - 1)
    Endif
    
    ILF3 = 1
    While ILF3
    
        ILF2 = 0
        ILF4 = 0
        CPTRPAR = 0
        # test si il y a plusieurs fichiers déclarés sur la même instruction
        ILF3 = instr(1, WCHAINE, ",")
        If ILF3
            # est-ce une virgule Ok ou ds un truc du genre :left$(var, lg)
            ILF2 = instr(1, WCHAINE, "(")
            If ILF2 and ILF2 < ILF3
                CPTRPAR = 1
                ILF2 += 1
                ILF4 = ILF2
            Endif
        Endif

        While CPTRPAR and (ILF2 <= len(WCHAINE))

            If mid$(WCHAINE, ILF2, 1) = "("
                If CPTRPAR or (ILF2 > 0 and ILF2 < ILF3)
                    CPTRPAR += 1
                Endif
            Elsif mid$(WCHAINE, ILF2, 1) = ")"
                CPTRPAR -= 1
            Endif
            
            If CPTRPAR = 0
            
                WCHAINE = right$(WCHAINE, ILF2 + 1)
                ILF3 = instr(1, WCHAINE, ",")
            Endif
            ILF2 += 1
        Wend
            
        # est-ce une virgule Ok ou ds un truc du genre :left$(var, lg)


        # on a une virgule            
        If ILF3
            CH1 = left$(WCHAINE, ILF3 - 1)
            ILF = instr(1, CH1, "Local File")
            If ILF
                CH1 = vireblc(right$(CH1, ILF + 10), 4)
            Else
                CH1 = vireblc(CH1, 4)
            Endif

            WCHAINE = "Local File" - right$(WCHAINE, ILF3 + 1)
        Else
            ILF = instr(1, WCHAINE, "Local File")
            If ILF
                CH1 = vireblc(right$(WCHAINE, ILF + 10), 4)
            Else
                CH1 = vireblc(WCHAINE, 4)
            Endif
            WCHAINE = ""
        Endif

        POSEGAL = instr(1, CH1, "=")


        ILF = instr(1, CH1, "Where")
        If ILF
            CH1 = left$(CH1, ILF - 1)
            # on considère qu'il n'y a pas d'autre Local File derrière
            ILF3 = 0
        Endif

        
        
        ILF = instr(1, CH1, "[")

        If ILF

            # complexe : il y a une variable en nom de fic...
            If instr(ILF + 1, CH1, "[")

                # pour éviter un = [M:ECR]CHP[ABV]
                CH2 = right$(CH1, ILF + 1)
                ILF2 = instr(1, CH2, "[")

                While ILF2
                    CH2 = right$(CH2, ILF2 + 1)
                    ILF2 = instr(1, CH2, "[")
                Wend
                
                # on est après le dernier [
                ILF2 = instr(1, CH2, "]")

                If ILF2 = 0
                    If PXVERIFVAR = 2 and WBABVNANA
                        Wrseq "  .....9997" - PTRAITEMENT - "(" + num$(PNLIG) + ") manque ]"  Using [FWR]
                        Wrseq "  ---->" - PCHAINE Using [FWR]
                    Endif
                    PCHAINE = ""
                    End
                
                Endif
                
                WABV = left$(CH2, ILF2 - 1)
                If instr(1, WABV, "(") or instr(1, WABV, ")")
                    # trop complexe ou non compris
                    If PXVERIFVAR = 2 and WBABVNANA
                        Wrseq "  .....9992" - PTRAITEMENT - "(" + num$(PNLIG) + ") abréviation table" - WABV - "non traitée."  Using [FWR]
                        Wrseq "  ---->" - PCHAINE Using [FWR]
                    Endif
                    PCHAINE = ""
                    End
                Else
                    # chargement ds la liste des repérés mais non analysables
                    NBABRFICNANA += 1
                    TABRFICNANA(NBABRFICNANA) = WABV
                    PCHAINE = ""
                    End
                Endif
            Else
                # on n'a pas d'abrev : c'est une var genre [F:XXX]YYYYYY ou =[F:XXX]YYYYYY
                If ILF = 1 or ILF = 2
                    PCHAINE = ""
                    End
                Endif
            Endif
       
            WFIC = left$(CH1, ILF - 1)
            Call FNOMFIC (WFIC)

            WABV = right$(CH1, ILF + 1)
            ILF = instr(1, WABV, "]")
            If ILF = 0
                If PXVERIFVAR = 2 and WBABVNANA
                    Wrseq "  .....9993" - PTRAITEMENT - "(" + num$(PNLIG) + ") syntaxe non traitée" Using [FWR]
                    Wrseq "  ---->" - PCHAINE Using [FWR]
                Endif
                PCHAINE = ""
                End
            Endif
            WABVDECL = left$(WABV, ILF - 1)
            If left$(WABVDECL, 2) = "F:"
                WABVDECL = right$(WABVDECL, 3)
            Endif
            If len(WABVDECL) > 4
                RABREV = "[F:" + WABVDECL + "]"
            Endif


            # partie analyse de ABRFIC et CODFIC ---------------------------------------------------------

            # vérif que ce n'est pas une abrev std
            If WABVDECL = ""
                fstat = 1
            Else
                Read [ATB]ABRFIC = WABVDECL
            Endif

            If fstat or (fstat = 0 and [F:ATB]CODFIC <> WFIC)
                If NBABRNS > 495
                    Wrseq "ERR Interne" - PTRAITEMENT - ": Dépasst " - num$(NBABRNS) - "pour" - WFIC - WABVDECL Using [FWR]
                Else
                    If WFIC = ""
                        fstat = 1
                    Else
                        Read [ATB]CODFIC = WFIC
                    Endif
                    If fstat = 0
                        # ne pas mettre X fois la même abréviation
                        ILF = find(WABVDECL, TABRFICNS(1..NBABRNS))
                        If ILF
                            If TABRFICSTD(ILF) <> [F:ATB]ABRFIC
           # si on veut sortir ça (la même abrev pour x tables),
           # il faudrait lire l'ancienne abv pour avoir le nom en clair
#                                Wrseq "ERR ABR fic" - PTRAITEMENT - "(" + num$(PNLIG) + ")déclaré :" - WABVDECL - "/" - WFIC - "d'abv standard" - [F:ATB]ABRFIC - "déjà déclarée pour la table d'abv std" - [ATB]CODFIC Using [FWR]
                            Endif
                        Else
                            NBABRNS += 1
                            ILF = NBABRNS
                        Endif

                        TABRFICSTD(ILF) = [F:ATB]ABRFIC
                        TABRFICNS(ILF) = WABVDECL
                        PCHAINE = ""
                    Else
                        #lire vue sur abv

                        # vérif que ce n'est pas une abrev std
                        If WABVDECL = ""
                            fstat = 1
                        Else
                            Read [AVW]AVW1 = WABVDECL
                        Endif
                        If fstat
                            If NBABRNS > 495
                                Wrseq "ERR Interne" - PTRAITEMENT - ": Dépasst " - num$(NBABRNS) - "pour" - WFIC - WABVDECL Using [FWR]
                            Else 
                                If WFIC = ""
                                    fstat = 1
                                Else
                                    Read [AVW]AVW0 = WFIC
                                Endif
                                If fstat = 0
                                    # ne pas mettre X fois la même abréviation
                                    ILF = find(WABVDECL, TABRFICNS(1..NBABRNS))
                                    If ILF
                                        If TABRFICSTD(ILF) <> [F:AVW]ABRVUE
           # si on veut sortir ça (la même abrev pour x tables),
           # il faudrait lire l'ancienne abv pour avoir le nom en clair
#                                            Wrseq "ERR ABR vue" - PTRAITEMENT - "(" + num$(PNLIG) + ")déclaré :" - WABVDECL - "/" - WFIC - "d'abv standard" - [F:AVW]ABRVUE - "pour déjà déclarée" - TABRFICSTD(ILF) Using [FWR]
                                        Endif
                                    Else
                                        NBABRNS += 1
                                        ILF = NBABRNS
                                    Endif
                                    
                                    TABRFICSTD(ILF) = [F:AVW]ABRVUE
                                    TABRFICNS(ILF) = WABVDECL
                                    PCHAINE = ""
                                Else
                                    If POSEGAL = 0 and WFIC <> ""
                                        PEF += 1
                                        PTERRFIC(PEF) = WFIC
                                    Endif
                                Endif
                            Endif
                        Endif
                    Endif
                Endif
            Endif
        Endif
    Wend

End

# chargement du tableau des masques (pour la vérif des écrans)
Subprog CHGLCLMSK (PCHAINE, TMSK, NBMSK, TMSKTRT, TABVMSKTRT, NBMSKTRT, PTRAITEMENT, PNLIG,
&       TABVMSKNANA, NBABVMSKNANA, WBABVNANA, PXVERIFVAR, RABREV, PPOSCLOSE)

Variable Clbfile PCHAINE
Variable Char TMSK()
Variable Integer NBMSK
Variable Char TMSKTRT(), TABVMSKTRT()(,)
Variable Integer NBMSKTRT
Value Char  PTRAITEMENT
Value Integer PNLIG
Variable Char TABVMSKNANA
Variable Integer NBABVMSKNANA
Value Integer WBABVNANA, PXVERIFVAR
Variable Char RABREV
Value Integer PPOSCLOSE

Local Char CH1(100), CH2(100), WMASK(20), WABVDECL(10)
Local Integer ILF, ILF2, ILF3, POSEGAL, WBQUOTE, ILF4
Local Clbfile WCHAINE(3)

    # Local Mask TOTO [AB1], TITI [AB2]
    RABREV = ""
    ILF3 = 1
    WCHAINE = PCHAINE
    While ILF3
        ILF3 = instr(1, WCHAINE, ",")
        If ILF3

            CH1 = left$(WCHAINE, ILF3 - 1)
            If PPOSCLOSE
                CH1 = vireblc(right$(CH1, PPOSCLOSE + 10), 4)
                PPOSCLOSE = 0
            Else
                CH1 = vireblc(CH1, 4)
            Endif
            WCHAINE = right$(WCHAINE, ILF3 + 1)
        Else
            If PPOSCLOSE
                CH1 = vireblc(right$(WCHAINE, PPOSCLOSE + 10), 4)
                PPOSCLOSE = 0
            Else
                CH1 = vireblc(WCHAINE, 4)
            Endif
            WCHAINE = ""
        Endif

        POSEGAL = instr(1, CH1, "=")
        If POSEGAL
            CH1 = right$(CH1, POSEGAL + 1)
        Endif
        
        ILF = instr(1, CH1, ".")
        If ILF
            CH2 = right$(CH1, ILF + 1)
            CH1 = CH2
        Endif
 
        If POSEGAL
            WBQUOTE = 0
            ILF2 = instr(1, CH1, "'")
            If ILF2
                WBQUOTE = 1
                ILF3 = instr(ILF2 + 1, CH1, "'")
                If ILF3
                    CH2 = right$(CH1, ILF3 + 1)
                    CH1 = left$(CH1, ILF3 - 1)
                    CH1 = right$(CH1, ILF2 + 1)
                Else
 #cbo                   CH1 = right$(CH1, ILF2 + 1)
 #cbo                   CH2 = right$(CH1, ILF2 + 1)
                Endif
            Else
                ILF2 = instr(1, CH1, '"')
                If ILF2
                    WBQUOTE = 1
                    ILF3 = instr(ILF2 + 1, CH1, '"')
                    If ILF3
                        CH2 = right$(CH1, ILF3 + 1)
                        CH1 = left$(CH1, ILF3 - 1)
                        CH1 = right$(CH1, ILF2 + 1)
                    Else
 #cbo                       CH1 = right$(CH1, ILF2 + 1)
 #cbo                       CH2 = right$(CH1, ILF2 + 1)
                    Endif
                Endif
            
            Endif
            # il faut voir si ch2 ne contient qu'une abrev
            If ILF2
                ILF2 = instr(1, CH2, '[')
                If ((ILF2 = 2 and left$(CH2, 1) = " ") or ILF2 = 1) and ILF3
                Else
                    If PXVERIFVAR = 2 and WBABVNANA
                Wrseq "  .....9994" - PTRAITEMENT - "(" + num$(PNLIG) + ") Local Mask non analysé : syntaxe complexe ou non complète (?)" Using [FWR]
                Wrseq "  ---->" - PCHAINE Using [FWR]
                    Endif
                    PCHAINE = ""
                    End
                Endif
                
                CH1 = CH1 + CH2
                
            Endif
        Endif

# ici, il faut avoir ch1 = masque[champ]

        # trouver l'abrev standard si elle n'est pas dans le code   
        ILF = instr(1, CH1, "[")
        If ILF = 0 and POSEGAL = 0

            Read [AMK]CODMSK = CH1
            If fstat = 0
                CH1 = CH1 + "[" + [F:AMK]ABRMSK + "]"
                ILF = instr(1, CH1, "[")
            Endif
        Endif
        
        If ILF = 0 or ILF = 1
            If PXVERIFVAR = 2 and WBABVNANA
                Wrseq "  .....9995" - PTRAITEMENT - "(" + num$(PNLIG) + ") Local Mask déclaré sans abréviation" Using [FWR]
                Wrseq "  ---->" - PCHAINE Using [FWR]
            Endif
            PCHAINE = ""
            End
        Endif


        # on a un = suivi de texte entre quote puis qq chose avant le [ABV] : cela doit bien être une variable
        # on a = et pas de quote
        If (WBQUOTE and ILF > 1) or(POSEGAL and WBQUOTE = 0 and ILF > 0)
            
            # charger la table des abréviations non déclarées
            ILF2 = ILF
            While ILF2
                ILF2 = instr(ILF + 1, CH1, "[")
                If ILF2
                    ILF = ILF2
                Endif
            Wend
            WABVDECL = right$(CH1, ILF + 1)
            WABVDECL = left$(WABVDECL, len(WABVDECL) - 1)
            NBABVMSKNANA += 1
            TABVMSKNANA(NBABVMSKNANA) = WABVDECL
            If left$(WABVDECL, 2) = "M:"
                WABVDECL= right$(WABVDECL, 3)
            Endif
            If len(WABVDECL) > 4
                RABREV = "[M:" + WABVDECL + "]"
            Endif
            PCHAINE = ""
            End
        Endif
        
        # pour éviter un = [M:ECR]CHP[ABV]
        CH2 = right$(CH1, ILF + 1)
        ILF2 = instr(1, CH2, "[")
        #on a un deuxième [
        If ILF2
            ILF = ILF2
            CH1 = CH2
            # trop complexe : il y a une variable en nom de fic...
            If instr(1, CH1, "]") or instr(1, CH1, "(") or instr(1, CH1, ")")

                # charger la table des abréviations non déclarées
                ILF2 = ILF
                While ILF2
                    ILF2 = instr(ILF + 1, CH1, "[")
                    If ILF2
                        ILF = ILF2
                    Endif
                Wend
                WABVDECL = right$(CH1, ILF + 1)
                WABVDECL = left$(WABVDECL, len(WABVDECL) - 1)
                NBABVMSKNANA += 1
                TABVMSKNANA(NBABVMSKNANA) = WABVDECL

                PCHAINE = ""
                End
            Endif
        Endif
       
       
        WMASK = left$(CH1, ILF - 1)

        CH2 = right$(CH1, ILF + 1)
        ILF = instr(1, CH2, "]")
        If ILF = 0
            If PXVERIFVAR = 2  and WBABVNANA
                Wrseq "  .....9996" - PTRAITEMENT - "(" + num$(PNLIG) + ") Local Mask non analysé : syntaxe non complète (?)" Using [FWR]
                Wrseq "  ---->" - PCHAINE Using [FWR]
            Endif
            PCHAINE = ""
            End
        Endif
        WABVDECL = left$(CH2, ILF - 1)
        If left$(WABVDECL, 2) = "M:"
            WABVDECL= right$(WABVDECL, 3)
        Endif
        If len(WABVDECL) > 4
            RABREV = "[M:" + WABVDECL + "]"
        Endif

        # vérif si déjà dans la liste (globale) --> pour le contrôle des écrans
        If NBMSK
            ILF = find(WMASK, TMSK(1..NBMSK))
        Else
            ILF = 0
        Endif
        If ILF = 0
            NBMSK += 1
            If NBMSK < GMAX_NBMSK
                TMSK(NBMSK) = WMASK
            Endif
        Endif

        # vérif si déjà dans la liste (du trt contrôlé)
        # avec gestion des abréviations
        If NBMSKTRT
            ILF = find(WMASK, TMSKTRT(1..NBMSKTRT))
        Else
            ILF = 0
        Endif
        If ILF
            # le masque est chargé avec une autre abréviation
            For ILF2 = 1 To 9
                If TABVMSKTRT(ILF, ILF2) = WABVDECL
                    Break
                Elsif TABVMSKTRT(ILF, ILF2) = ""
                    TABVMSKTRT(ILF, ILF2) = WABVDECL
                    Break
                Endif
            Next ILF2
        Else
            NBMSKTRT += 1
            TMSKTRT(NBMSKTRT) = WMASK
            TABVMSKTRT(NBMSKTRT, 1) = WABVDECL
        Endif

    Wend

End

Subprog FNOMFIC(PCHAINE)
Variable Char PCHAINE

Local Integer INF


    # cherche si nomfic entre double quote
    INF = instr(1, PCHAINE, '"')
    If INF
        PCHAINE = right$(PCHAINE, INF + 1)

        INF = instr(1, PCHAINE, '"')
        If INF
            PCHAINE = left$(PCHAINE, INF - 1)
        Endif
    Endif

    # cherche si nomfic entre simple quote
    INF = instr(1, PCHAINE, "'")
    If INF
        PCHAINE = right$(PCHAINE, INF + 1)

        INF = instr(1, PCHAINE, "'")
        If INF
            PCHAINE = left$(PCHAINE, INF - 1)
        Endif
    Endif


    INF = instr(1, PCHAINE, ".")
    If INF
        PCHAINE = right$(PCHAINE, INF + 1)
    Endif

    INF = instr(1, PCHAINE, '*')
    If INF
        PCHAINE = right$(PCHAINE, INF + 1)
    Endif
End

# Recherche des link ... as : pour ne pas sortir en erreur
Subprog TABLNK(PCHAINE, NBLIENS, TABLIENS, TABABVLIENS, TABCLELIENS, TABRFICNS, TABRFICSTD, NBABRNS)
Variable Clbfile PCHAINE
Variable Integer NBLIENS
Variable Char TABLIENS()
Variable Char TABABVLIENS()
Variable Char TABCLELIENS()()
Variable Char TABRFICNS(), TABRFICSTD()
Variable Integer NBABRNS

Local Integer ILN, ILN2, ILF
Local Char CH1(200), CH2(200), WCLE(10)


    ILN = instr(1, PCHAINE, "Link")
    If ILN = 0
        End
    Endif

    # Ne pas analyser comme un Link 1 chaine Wrseq ...
    ILN2 = instr(1, PCHAINE, "Wrseq")
    If ILN2 > 0 and ILN2 < ILN
        End
    Endif
    
    ILN = instr(1, PCHAINE, "As")
    If ILN = 0
        End
    Endif
    
    CH1 = vireblc(right$(PCHAINE, ILN + 2), 4)

    # recherche des abrev contenues dans le lien
    ILN = instr(1, CH1, "[")
    If ILN

        # recherche des abrev contenues dans le lien
    
        CH2 = right$(CH1, ILN + 1)
        ILN = instr(1, CH2, "]")
        If ILN
            CH1 = left$(CH2, ILN - 1)
            # si un local file utilise cette abrev en non std : on l'enlève
            ILF = find(CH1, TABRFICNS(1..NBABRNS))
            If ILF
                TABRFICSTD(ILF) = ""
                TABRFICNS(ILF) = ""
                If ILF = NBABRNS
                    NBABRNS -= 1
                Endif
            Endif


            # CH1 est l'abrev du Link
            ILN = find(CH1, TABLIENS(1..NBLIENS))
            If ILN
                Call TABABVLNK (PCHAINE, ILN, TABABVLIENS, WCLE)

            Else                        
                NBLIENS += 1
                TABLIENS(NBLIENS) = CH1
                Call TABABVLNK (PCHAINE, NBLIENS, TABABVLIENS, WCLE)

             Endif
            If WCLE <> ""
               TABCLELIENS(NBLIENS) = WCLE
            Endif
            PCHAINE = ""
        Endif
    Endif

End

# Recherche des abrev des link ... as : pour ne pas sortir en erreur
# PCHAINE contient la chaine avant le as
Subprog TABABVLNK(PCHAINE, NUMLIEN, TABABVLIENS, RCLE)
Variable Clbfile PCHAINE
Value Integer NUMLIEN
Variable Char TABABVLIENS()
Variable Char RCLE

Local Integer I, J, K, L
Local Char CHN(255), CHN2(255)

    I = instr(1, PCHAINE, "Order By")
    If I
        CHN2 = right$(PCHAINE, I + 8)
        Call CLEORDERBY (CHN2, RCLE)
    Endif        
    If I = 0
        I = instr(1, PCHAINE, "Order With Key")
        If I
            CHN2 = right$(PCHAINE, I + 14)
            Call CLEORDERBY (CHN2, RCLE)
        Endif        
    Endif

    I = instr(1, PCHAINE, "As")
    If I
        PCHAINE = left$(PCHAINE, I - 1)
    Endif
    
    For I = 1 To 10
        TABABVLIENS(((NUMLIEN - 1) * 10) + I) = ""
    Next I
    
    K = 0
    I = instr(1, PCHAINE, "[")
    While I
        CHN = right$(PCHAINE, I + 1)
        J = instr(1, CHN, "]")
    
        If J
            CHN = left$(CHN, J - 1)
            J = instr(1, CHN, ":")
            If J
                CHN = right$(CHN, J + 1)
            Endif
            L = find(CHN, TABABVLIENS(((NUMLIEN - 1)*10 + 1) .. (NUMLIEN*10)))
            If L = 0
                K += 1
                TABABVLIENS(((NUMLIEN - 1) * 10) + K) = CHN
#                Infbox "lien" - num$(NUMLIEN) - "ABV" - num$(K) - CHN
            Endif
            I = instr(I + 1, PCHAINE, "[")
        Else
            I = 0
        Endif
    Wend
End


# RECHERCHE DE CLE DANS Order By Key CLE =CHP1;CHP2"
Subprog CLEORDERBY(PCHAINE, RCLE)
Variable Char PCHAINE
Variable Char RCLE

Local Integer I

    I = instr(1, PCHAINE, "Key")
    If I
        PCHAINE = right$(PCHAINE, I + 3)
    Endif
    I = instr(1, PCHAINE, "=")
    If I
        PCHAINE = left$(PCHAINE, I - 1)
        RCLE = vireblc(PCHAINE, 4)
    Else
        RCLE = ""
    Endif

End


# Recherche des Filter ... order by : pour ne pas sortir en erreur
Subprog TABFILTRE(PCHAINE, FICHIERS, WNBFI, TABRFICSTD, TABRFICNS, NBABRNS, TABCLEFILTER, 
& TABLIENS, NBLIENS, TABCLELIENS, PTRAITEMENT, NLIG, WBABVNANA, PXVERIFVAR)
Variable Clbfile PCHAINE
Variable Char FICHIERS()
Value Integer WNBFI
Variable Char TABRFICSTD()
Variable Char TABRFICNS()
Value Integer NBABRNS
Variable Char TABCLEFILTER()
Variable Char TABLIENS()
Value Integer NBLIENS
Variable Char TABCLELIENS()
Value Char PTRAITEMENT
Value Integer NLIG
Value Integer WBABVNANA, PXVERIFVAR


Local Integer ILN, ILN2
Local Char CH1(200), WABV(10)


#Filter [LBLA] Where evalue(CRITERE(1..ICRIT))
#& Order By Key CLE = [BLA]FCY;[BLA]ACC

    If PCHAINE = ""
        End
    Endif
    
    CH1 = ""
    ILN = instr(1, PCHAINE, "Filter")
    If ILN = 0
        End
    Endif
    # fin d'un filtre : ras
    If PCHAINE = "Filter"
        End
    Endif

    # Ne pas analyser comme un Filter 1 chaine Wrseq ...
    ILN2 = instr(1, PCHAINE, "Wrseq")
    If ILN2 > 0 and ILN2 < ILN
        End
    Endif

    ILN = instr(1, PCHAINE, "[")
    If ILN = 0
        If WBABVNANA
            Call ECRERRSI (PXVERIFVAR, "  ....." - PTRAITEMENT - "(" - num$(NLIG) - ") : [ manquant", 1)
            Call ECRERRSI (PXVERIFVAR, "  ---->" - PCHAINE, 1)
        Endif
        End
    Endif
    
    WABV = right$(PCHAINE, ILN + 1)
    ILN = instr(1, WABV, "]")
    If ILN = 0
        If WBABVNANA
            Call ECRERRSI (PXVERIFVAR, "  ....." - PTRAITEMENT - "(" - num$(NLIG) - ") : ] manquant", 1)
            Call ECRERRSI (PXVERIFVAR, "  ---->" - PCHAINE, 1)
        Endif
        End
    Endif

    WABV = left$(WABV, ILN - 1)

    ILN2 = find(WABV, FICHIERS(1..WNBFI))
    If ILN2 = 0
        ILN2 = find(WABV, TABRFICNS(1..NBABRNS))
        If ILN2
            ILN2 = find(TABRFICSTD(ILN2), FICHIERS(1..WNBFI))
        Endif
    Endif
    If ILN2 = 0
        ILN2 = find(WABV, TABLIENS(1..NBLIENS))
        If ILN2
            ILN2 = 0 - ILN2
        Else
            End
        Endif
    Endif
    
    
    ILN = instr(1, PCHAINE, "Order By Key")
    If ILN
        CH1 = right$(PCHAINE, ILN + 12)

        ILN = instr(1, CH1, "=")
        If ILN
            CH1 = vireblc(left$(CH1, ILN - 1), 4)
        Endif

        If ILN2 < 0
            TABCLELIENS(0 - ILN2) = CH1
        Else
            TABCLEFILTER(ILN2) = CH1
        Endif
    Endif
    
End

Subprog ECRERRSI (PXVERIFVAR, TXTERR, PWARNING)
Value Integer PXVERIFVAR
Value Char TXTERR
Value Integer PWARNING

    If PXVERIFVAR = 2
        If PWARNING
            Wrseq TXTERR Using [FWR]
        Else
            Wrseq TXTERR Using [FER]
        Endif
    Endif
End




# charge (et vérifie) si une abréviation non déclarée est déjà repérée
Subprog LIRABVCHP (PABV, PCHP, PNRET, PCODMSK, TABVNF, NBABVNF, TABVCHPNF,
& TMSKTRT, TABVMSKTRT, NBMSKTRT, TABVMSKNANA, NBABVMSKNANA, WUNMESSPARERR, PDOSSIER, PNLIG, TNBCHPABV,
& NBMSKNS, TABRMSKNS, TABRMSKSTD)

Variable Char PABV
Value Char PCHP
Variable Integer PNRET
Variable Char PCODMSK, TABVNF()
Variable Integer NBABVNF
Variable Char TABVCHPNF(), TMSKTRT(), TABVMSKTRT()(,)
Value Integer NBMSKTRT
Variable Char TABVMSKNANA()
Value Integer NBABVMSKNANA, WUNMESSPARERR
Value Char PDOSSIER
Value Integer PNLIG
Variable Integer TNBCHPABV()
Value Integer NBMSKNS
Variable Char TABRMSKNS(), TABRMSKSTD()


Local Integer POSABV, POSCHP, K, NBCHPPARMSK, ILF, ILF2, ILF3
Local Char WCHPSSZ(20), WSAUVEABV(20), WABV(20), WABVSAV(20)
Local Integer CI, CJ, WSVNRET
    NBCHPPARMSK = 20
    PNRET = 0
    PCODMSK = ""
    WSAUVEABV = PABV

    # on ne décode pas les champs sans abréviation ###
    If PABV = ""
        PNRET = 0
        End
    Endif
    WABV = PABV


    POSABV = find(WABV, TABVNF(1..NBABVNF))
    If POSABV
        POSCHP = find(PCHP, TABVCHPNF(1 + (POSABV - 1) * NBCHPPARMSK..(NBCHPPARMSK - 1) + (POSABV - 1) * NBCHPPARMSK))

        # abréviation/champ déjà traitée en erreur dans le compte-rendu
        If POSCHP
            If WUNMESSPARERR = 0
                PNRET = 2
            Endif
            End
        Endif
    Else
        POSCHP = 0
    Endif

    # abréviation non analysable (pb de syntaxe)
    ILF3 = 0
    If find(WABV, TABVMSKNANA(1..NBABVMSKNANA))
        End
    Endif
        
        
    PNRET = 1
    #est-ce un local mask déclaré ?
    ILF3 = 0
    For ILF = 1 To NBMSKTRT
        For ILF2 = 1 To 9
            If TABVMSKTRT(ILF, ILF2) = ""
                Break
            Endif

            If WABV = TABVMSKTRT(ILF, ILF2)
                ILF3 = 1

                # on en a qu'un à lire... (nom de masque unique)
  ###              Filter [AMK] Where CODMSK = TMSKTRT(ILF) Order By CODMSK
                PCODMSK = TMSKTRT(ILF)
#CBO2011                Read [AMK]CODMSK = TMSKTRT(ILF)
#CBO2011                If fstat = 0
                ICBO = func FINDMSK(TMSKTRT(ILF), 1, GCBONBMSK)   #CBO2011 
                If ICBO                                           #CBO2011 
                    ICBO2 = ICBO                                  #CBO2011 
                    [F:AMK]CODMSK = TMSKTRT(ILF)
                    Gosub LIRABV
                    If PNRET > 2
                        Break(2)
                    Endif
                Endif
            Endif
        Next ILF2
    Next ILF
    
    # si non Ok : recherche d'une abrev std
    If ILF3 = 0
        # on en a autant à lire qu'on trouve d'abréviations identiques...
###        Filter [AMK] Where ABRMSK = WABV Order By ABRMSK

#CBO2011        For [AMK]ABRMSK Where ABRMSK = WABV
        Call FINDABV(WABV, 1, GCBONBABV, GCBOPSD, GCBOPSF)    #CBO2011 
        If GCBOPSD and GCBOPSF                                #CBO2011 
            For ICBO = GCBOPSD To GCBOPSF                     #CBO2011 
                [F:AMK]CODMSK = GTCBOMSK(GTCBOPOSABV(ICBO))   #CBO2011 
                ICBO2 = GTCBOPOSABV(ICBO)                     #CBO2011 
                Gosub LIRABV
                If PNRET = 3 or PNRET = 4
                    Break
                Endif
            Next
        Endif                                                 #CBO2011 
    Endif

    # CBO 20110124 FQ70150
    # pas d'abréviation trouvée : on cherche si abv déclarée par local mask --> passage au standard correspondant
    If PNRET = 1 or PNRET = 2
        ILF = find(WABV, TABRMSKNS(1..NBMSKNS))
        If ILF
        
            WSVNRET = PNRET
            PNRET = 1
#            WABV = TABRMSKSTD(ILF)
            # on en a autant à lire qu'on trouve d'abréviations identiques...
###            Filter [AMK] Where ABRMSK = TABRMSKSTD(ILF) Order By ABRMSK

#CBO2011            For [AMK]ABRMSK Where ABRMSK = TABRMSKSTD(ILF)
            Call FINDABV(TABRMSKSTD(ILF), 1, GCBONBABV, GCBOPSD, GCBOPSF) #CBO2011 
            If GCBOPSD and GCBOPSF                                        #CBO2011 
                For ICBO = GCBOPSD To GCBOPSF                             #CBO2011 
                    [F:AMK]CODMSK = GTCBOMSK(GTCBOPOSABV(ICBO))           #CBO2011 
                    ICBO2 = GTCBOPOSABV(ICBO)                             #CBO2011 
    
                    Gosub LIRABV
                    If PNRET = 3 or PNRET = 4
                        Break
                    Endif
                Next
    
                # on avait trouvé une abrev, on reste sur ce niveau d'erreur
                If WSVNRET = 2 and  PNRET = 1
                    PNRET = 2
                Endif
            Endif                                                         #CBO2011 
        Endif
    Endif

    # pas d'abréviation trouvée : 
    If PNRET = 1
        If POSABV = 0 # and PABV <> ""
            NBABVNF += 1
            TABVNF(NBABVNF) = PABV
        Endif
        End
    Endif

    # champ non trouvé pour cette abréviation :
    If PNRET = 2
        If POSABV = 0
            NBABVNF += 1
            TABVNF(NBABVNF) = PABV
            POSABV = NBABVNF
        Endif

        If POSABV
            If TNBCHPABV(POSABV) < NBCHPPARMSK
                TNBCHPABV(POSABV) += 1
                TABVCHPNF(TNBCHPABV(POSABV) + (POSABV - 1) * NBCHPPARMSK) = PCHP
            Endif
        Endif
    Endif
End

$LIRABVOLD
    PNRET = 2
    Read [AMZ]CODE = [F:AMK]CODMSK ; PCHP

    If fstat = 0
        PNRET = 3
        PCODMSK = [F:AMK]CODMSK
        Return
    Endif
    
    # cas de libellé de champ
    If left$(PCHP, 1) = "Z"
        WCHPSSZ = right$(PCHP, 2)
        Read [AMZ]CODE = [F:AMK]CODMSK ; WCHPSSZ
        If fstat = 0 and ([F:AMZ]LIEN = 2 or [F:AMZ]LIEN = 3)
            PNRET = 4
            PCODMSK = [F:AMK]CODMSK
            Return
        Endif
    Endif
Return

$LIRABV
#Gosub LIRABVOLD
#Return

    PNRET = 2
    For ICBO3 = GTCBOPOSCHP(ICBO2) To GTCBOPOSCHP(ICBO2 + 1) - 1
        If ICBO3 > 2 * GMAX_ZONEMSK
            If GTCBOCHPC(ICBO3 - (2 * GMAX_ZONEMSK)) = PCHP
                PNRET = 3
                PCODMSK = [F:AMK]CODMSK
                Break
            Endif
        Elsif ICBO3 > GMAX_ZONEMSK
            If GTCBOCHPB(ICBO3 - GMAX_ZONEMSK) = PCHP
                PNRET = 3
                PCODMSK = [F:AMK]CODMSK
                Break
            Endif
        Else
            If GTCBOCHP(ICBO3) = PCHP
                PNRET = 3
                PCODMSK = [F:AMK]CODMSK
                Break
            Endif
        Endif
    Next ICBO3
    
    # cas de libellé de champ
    If left$(PCHP, 1) = "Z" and PNRET <> 3
        WCHPSSZ = right$(PCHP, 2)
        For ICBO3 = GTCBOPOSCHP(ICBO2) To GTCBOPOSCHP(ICBO2 + 1) - 1
            If ICBO3 > 2 * GMAX_ZONEMSK
                If GTCBOCHPC(ICBO3 - (2 * GMAX_ZONEMSK)) = WCHPSSZ
                    PNRET = 4
                    PCODMSK = [F:AMK]CODMSK
                    Break
                Endif
            Elsif ICBO3 > GMAX_ZONEMSK
                If GTCBOCHPB(ICBO3 - GMAX_ZONEMSK) = WCHPSSZ
                    PNRET = 4
                    PCODMSK = [F:AMK]CODMSK
                    Break
                Endif
            Else
                If GTCBOCHP(ICBO3) = WCHPSSZ
                    PNRET = 4
                    PCODMSK = [F:AMK]CODMSK
                    Break
                Endif
            Endif
        Next ICBO3
    Endif
Return
# ancienne version de LIRABV
#$LIRABVSAV
