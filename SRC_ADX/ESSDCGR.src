#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
Endcase
Return

$OUVRE
If clalev([F:DCG])    = 0 : Local File DEMCONGE     [DCG]     : Endif
If clalev([F:ID])     = 0 : Local File EMPLOID      [ID]     : Endif
Default File [F:DCG]
Return

$DEBUT
##Update header icon
#[M]WSTA2 = func ESS_FUNCTIONS.SET_ICON(2)
#[M]WSTADES2 = 2
#[M]WSTA5 = func ESS_FUNCTIONS.SET_ICON(5)
#[M]WSTADES5 = 5

Local Integer STAT(1..10)
STAT(1) = 2
STAT(2) = 5
Call POPULATE_MASK(STAT,PARAM(1)) From ESSDCGR
Return

Subprog POPULATE_MASK(VSTAT,VEMP)
Value Integer VSTAT
Value Char VEMP
Local Char EMPNAM(40), EMPSRN(40)
Local Char EMPCODE (GLONEML)

If VEMP = AVOID.ACHAR
  EMPCODE=fmet GACTX.ACACHE.USRESS.AGETVALCHAR(GACTX.USER,"REFNUM")
Else
  EMPCODE = VEMP
Endif

Read [F:ID]ID0 = EMPCODE
If !fstat
  EMPNAM = [F:ID]NAM
  EMPSRN = [F:ID]SRN
Endif
#Getting additional employee information

Filter [F:DCG] Where REFNUM = EMPCODE and find(STA,VSTAT) and UID>0 Order By STRDAT Desc
nolign =0
For [F:DCG]
  nolign+=1
  If nolign > dim([M]REFNUM) : Break : Endif
  [M] = [F]
  [M]NAM(nolign-1)  = EMPNAM
  [M]SRN(nolign-1)  = EMPSRN

  #Update icon
  #[M]WSTA(nolign-1) = func ESS_FUNCTIONS.SET_ICON([F:DCG]STA)
  [M]NBRLIN = nolign
Next
Filter [F:DCG]
Affzo [M]1-99
End

