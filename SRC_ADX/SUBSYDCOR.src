#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################################################
# Programme de synchronisation des correspondants
#
# COR_INIT      : Initialisation synchronisation des correspondants
#
# COR_SET_DESC   : Description passage info Outlook/Adonix
# COR_SET        : Mise à jour d'un correspondant depuis Outlook vers Adonix
# COR_LOADSET    : Transformation des infos de Outlook en Adonix
# COR_SET_OK     : Confirmation mise à jour Outlook vers Adonix
#
# COR_GET_DESC   : Description passage info Adonix/Outlook
# COR_GET        : Mise à jour d'un correspondant depuis Adonix vers Outlook
# COR_GET_OK     : Confirmation mise à jour Adonix vers Outlook
##########################################################################################################
# FGR 21/07/2009 : X3SUIVI56584 : Remplacement de USERID(login X3) par GUSER(AUS) partout "où il faut"
##########################################################################################################
# Debut synchronisation correspondants
# ------------------------------------------------------------
Subprog COR_INIT(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, TBKINT, TBVINT)
# <Par Techniques>
Variable Char RET()               # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Variable Char TBKINT()(1..)       # Paramètres caractères
Variable Integer TBVINT(1..)

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN

#Variables globales indiquant les droits sur la synchro des correspondants
Global Integer GIBCORADXCRE       #Droit création correspondant dans Adonix
Global Integer GIBCORADXUPD       #Droit modification correspondant dans Adonix
Global Integer GIBCORADXDLT       #Droit suppression correspondant dans Adonix
Global Integer GIBCOROTKCRE       #Droit création correspondant dans Outlook
Global Integer GIBCOROTKUPD       #Droit modifcation correspondant dans Outlook
Global Integer GIBCOROTKDLT       #Droit suppression correspondant dans Outlook
Global Integer GIBPOSSYNCCOR      #synchronisation correspondant possible
Global Integer GINUMETAPEGET      #Numéro de l'étape dans la partie GET

Local Integer IBPARAMCHRG
Local Integer INDICETAB
Local Char TEXTMESGLOB(250)
Local Char TEXTMESTMP(250)
Local Char TEXTMES(250)
Local Integer IBERROR
Local Integer INBMES

  GINUMETAPEGET = 1
  GIBCORADXCRE = MC_FALSE
  GIBCORADXUPD = MC_FALSE
  GIBCORADXDLT = MC_FALSE
  GIBCOROTKCRE = MC_FALSE
  GIBCOROTKUPD = MC_FALSE
  GIBCOROTKDLT = MC_FALSE
  IBERROR = MC_FALSE
  IBPARAMCHRG = MC_FALSE
  INDICETAB = 1
  Raz TEXTMESGLOB
  Raz TEXTMESTMP
  Raz TEXTMES
  INBMES = 1
  # Statut
  RET = MC_OK
  #Initialisation synchronisation des correspondants
  Call ECR_TRACE(mess(275,177,1), 0) From GESECRAN
  If dim(MSGFLG) > 0 Then
    INBMES = 1
    While INBMES < dim(MSGFLG)+1
      If MSGTXT(INBMES) <> "" Then
        Call ECR_TRACE(MSGTXT(INBMES), 0) From GESECRAN
      Endif
      INBMES += 1
    Wend
    INBMES = 1
  Endif
  Raz MSGFLG
  Raz MSGTXT
  If GCRMSYNC <> 2 Then
    IBPARAMCHRG = MC_TRUE
  Endif
  If GCRMSYNCCOR <> 2 Then
    IBPARAMCHRG = MC_TRUE
  Endif
  If USERID = "" Then
    IBPARAMCHRG = MC_TRUE
  Endif
  If IBPARAMCHRG = MC_FALSE Then
    IBPARAMCHRG = MC_TRUE
    #On a un utilisateur On regarde son paramétrage
    Local File SYNCPAR [SYP]
    Read [SYP]SYP0=GUSER
    If fstat = 0 Then
      If [F:SYP]CORADXCRE = 2 Then
        GIBCORADXCRE = MC_TRUE
        GIBPOSSYNCCOR = MC_TRUE
      Endif
      If [F:SYP]CORADXUPD = 2 Then
        GIBCORADXUPD = MC_TRUE
        GIBPOSSYNCCOR = MC_TRUE
      Endif
      If [F:SYP]CORADXDLT = 2 Then
        GIBCORADXDLT = MC_TRUE
        GIBPOSSYNCCOR = MC_TRUE
      Endif
      If [F:SYP]COROTKCRE = 2 Then
        GIBCOROTKCRE = MC_TRUE
        GIBPOSSYNCCOR = MC_TRUE
      Endif
      If [F:SYP]COROTKUPD = 2 Then
        GIBCOROTKUPD = MC_TRUE
        GIBPOSSYNCCOR = MC_TRUE
      Endif
      If [F:SYP]COROTKDLT = 2 Then
        GIBCOROTKDLT = MC_TRUE
        GIBPOSSYNCCOR = MC_TRUE
      Endif
    Endif
  Else
    GIBPOSSYNCCOR = MC_FALSE
  Endif
  #On alimente le tableau de paramètre pour Retour à Outlook
  # Synchronisation possible sur les correspondants
  TBKINT(INDICETAB) = MC_MD
  If GIBCORADXCRE = MC_FALSE and GIBCORADXUPD = MC_FALSE and GIBCORADXDLT = MC_FALSE and GIBCOROTKCRE = MC_FALSE and GIBCOROTKUPD = MC_FALSE and GIBCOROTKDLT = MC_FALSE Then
    TBVINT(INDICETAB) = MC_FALSE
  Else
    TBVINT(INDICETAB) = MC_TRUE
  Endif
  INDICETAB += 1
  TBKINT(INDICETAB) = MC_MDADX_C : TBVINT(INDICETAB) = GIBCORADXCRE : INDICETAB += 1
  TBKINT(INDICETAB) = MC_MDADX_U : TBVINT(INDICETAB) = GIBCORADXUPD : INDICETAB += 1
  TBKINT(INDICETAB) = MC_MDADX_D : TBVINT(INDICETAB) = GIBCORADXDLT : INDICETAB += 1
  TBKINT(INDICETAB) = MC_MDAPL_C : TBVINT(INDICETAB) = GIBCOROTKCRE : INDICETAB += 1
  TBKINT(INDICETAB) = MC_MDAPL_U : TBVINT(INDICETAB) = GIBCOROTKUPD : INDICETAB += 1
  TBKINT(INDICETAB) = MC_MDAPL_D : TBVINT(INDICETAB) = GIBCOROTKDLT : INDICETAB += 1
  #Initialisation synchronisation des correspondants
  #Paramétrage synchronisation Outlook-Adonix
  Call ECR_TRACE(mess(226,177,1),0) From GESECRAN
  #Création
  If GIBCORADXCRE = MC_TRUE Then
    TEXTMES = mess(59,123,1) - ":" - mess(2,1,1)
  Else
    TEXTMES = mess(59,123,1) - ":" - mess(1,1,1)
  Endif
  TEXTMESTMP = TEXTMES
  TEXTMESGLOB = TEXTMES
  #Modification
  If GIBCORADXUPD = MC_TRUE Then
    TEXTMES = mess(60,123,1) - ":" - mess(2,1,1)
  Else
    TEXTMES = mess(60,123,1) - ":" - mess(1,1,1)
  Endif
  TEXTMESGLOB = TEXTMESTMP + "  " + TEXTMES
  TEXTMESTMP = TEXTMESGLOB
  #Suppression
  If GIBCORADXDLT= MC_TRUE Then
    TEXTMES = mess(53,123,1) - ":" - mess(2,1,1)
  Else
    TEXTMES = mess(53,123,1) - ":" - mess(1,1,1)
  Endif
  TEXTMESGLOB = TEXTMESTMP + "  " + TEXTMES
  Call ECR_TRACE(TEXTMESGLOB,0) From GESECRAN
  #Paramétrage synchronisation Adonix-Outlook
  Call ECR_TRACE(mess(227,177,1),0) From GESECRAN
  #Création
  If GIBCOROTKCRE = MC_TRUE Then
    TEXTMES = mess(59,123,1) - ":" - mess(2,1,1)
  Else
    TEXTMES = mess(59,123,1) - ":" - mess(1,1,1)
  Endif
  TEXTMESTMP = TEXTMES
  TEXTMESGLOB =  TEXTMES
  #Modification
  If GIBCOROTKUPD = MC_TRUE Then
    TEXTMES = mess(60,123,1) - ":" - mess(2,1,1)
  Else
    TEXTMES = mess(60,123,1) - ":" - mess(1,1,1)
  Endif
  TEXTMESGLOB = TEXTMESTMP + "  " + TEXTMES
  TEXTMESTMP = TEXTMESGLOB
  #Suppression
  If GIBCOROTKDLT = MC_TRUE Then
    TEXTMES = mess(53,123,1) - ":" - mess(2,1,1)
  Else
    TEXTMES = mess(53,123,1) - ":" - mess(1,1,1)
  Endif
  TEXTMESGLOB = TEXTMESTMP + "  " + TEXTMES
  Call ECR_TRACE(TEXTMESGLOB,0) From GESECRAN
  #Nettoyage du aux traitements précédents
  Local File SYNCDATA [SYD]
  #Suppression enregistrement généré par synchro
  Call DEBTRANS From GLOCK
  Trbegin [SYD]
  Delete [SYD] Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "COR" and [F:SYD]SYDGEN = 1
  If fstat = 0 Then
    Commit
  Else
    Rollback
    IBERROR = MC_TRUE
    MSGFLG(INBMES) = MC_ERROR
    #Erreur lors de l'initialisation des données de synchronisation (suppression données obsolètes)
    MSGTXT(INBMES) = mess(229,177,1)
    Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
    INBMES += 1
  Endif
  If IBERROR = MC_FALSE Then
    #Aucun enregistrement n'a encore été modifié par la synchro
    Call DEBTRANS From GLOCK
    Trbegin [SYD]
    For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "COR" and ([F:SYD]SYDUPD = 1 or [F:SYD]SYDOTKSTA = 0)
      Readlock [SYD]Curr
      If fstat = 0 Then
        [F:SYD]SYDUPD = 0
        [F:SYD]SYDOTKSTA = 1
        Rewrite [SYD]
        If fstat <> 0 Then
          IBERROR = MC_TRUE
          Break
        Endif
      Else
        IBERROR = MC_TRUE
        Break
      Endif
    Next
    If IBERROR = MC_FALSE Then
      Commit
    Else
      Rollback
      MSGFLG(INBMES) = MC_ERROR
      #Erreur lors de l'initialisation des données de synchronisation (Nettoyage données obsolètes)
      MSGTXT(INBMES) = mess(230,177,1)
      Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
      INBMES += 1
      RET = MC_KO
    Endif
  Endif
End

##########################################################################################################
# Description passage info Outlook/Adonix
Subprog COR_SET_DESC(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, XMLDESC)
# <Par Techniques>
Variable Char RET()               # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Variable Clbfile XMLDESC()        # Description structure dynamique

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN

Local Integer TC_MAX : SC_MAX = 150
Local Integer WI : WI= 0
Local Char WDSC(200)(1..SC_MAX)
Local Integer INBMES

  INBMES = 1
  #Ecriture du tableau de message et réinitialisation
  Gosub WRITE_RAZ_MSG From SUBSYDSYN
  Gosub COR_INISETDSC From SUBSYDCORD
  Gosub COR_LD_SETDESC From SUBSYDCORD
  Setlob XMLDESC With [L]WDSC
  # Statut
  RET = MC_OK
End

##########################################################################################################
# subprog COR_SET(MAJ dans Adonix)
##########################################################################################################
Subprog COR_SET(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, VERDESC, CORRESPONDID, UPDFLG, TBKCHR, TBVCHR, TBKINT, TBVINT, TBKDEC, TBVDEC, TBKDATTIM, TBVDATTIM, TBKCLOB, TBVCLOB)
# <Par Techniques>
Variable Char RET()               # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Value Char VERDESC()
Variable Char CORRESPONDID()      # ID permettant de retrouver la correspondant (OL ou X3)
Value Char UPDFLG()
# <Tabl. Dynamiques>
Variable Char TBKCHR()(1..)       # Paramètres caractères
Variable Char TBVCHR()(1..)
Variable Char TBKINT()(1..)       # Paramètres entiers
Variable Integer  TBVINT(1..)
Variable Char  TBKDEC()(1..)      # Paramètres décimaux
Variable Decimal TBVDEC(1..)
Variable Char  TBKDATTIM()(1..)   # Paramètres Dates AAAAMMJJHHMMSS
Variable Char TBVDATTIM()(1..)
Variable Char  TBKCLOB()(1..)     # Paramètres Textes riches
Variable Clbfile TBVCLOB()(1..)
# </TD>

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Char SZCORUSR(GLONAUS)
Local Integer LERRCOD
Local Integer ITRACE
Local Integer IOPENTRACE
Local Integer INBRECORD
Local Char SZMODE(GLONDES)
Local Integer IBERROR
Local Integer INBMES
Local Char SZCORNUM(GLONCOR)
Local Char SZOBJET(GLONAOB)
Local Char SZMESSAGE(250)
Local Char SZREPCONNECT(GLONREP)
Local Char SZSITECONNECT(GLONFCY)

  Raz SZMESSAGE
  SZREPCONNECT = ""
  SZSITECONNECT = ""
  LERRCOD = 0
  IBRETOUR = 1
  IBERROR = MC_FALSE
  INBMES = 1
  INBRECORD = 0
  RET = MC_OK
  Raz SZCORNUM
  Raz SZCORUSR
  Raz SZMODE
  Raz SZCORNUM
  Raz SZOBJET
  #Ecriture du tableau de message et réinitialisation
  Gosub WRITE_RAZ_MSG From SUBSYDSYN
  #Traitement de l'identifiant correspondant
  Call DECOD_OTKID(CORRESPONDID, "COR", SZCORNUM, SZOBJET) From SUBSYDUTIL
  If GCRMSYNC <> 2 Then
    RET = MC_OK
    End
  Endif
  If GCRMSYNCCOR <> 2 Then
    RET = MC_OK
    End
  Endif
  If USERID = "" Then
    MSGFLG(INBMES) = MC_ERROR
    #Aucun utilisateur n'est défini pour la synchronisation.
    MSGTXT(INBMES) = mess(231,177,1)
    Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
    INBMES += 1
    RET = MC_KO
    End
  Endif
  ITRACE = 1
  #Reinitialisation type conflit
  GITYPECONFLIT = 0
  GDTDATEMODIFOTK = [00/00/00]
  GDTDATEMODIFADX = [00/00/00]
  Local File CORRESPOND [COR]
  Local File CORREP[COP]
  Local File CRMCLOB[CRC]
  Local File SYNCDATA [SYD]
  #"Traitement données outlook +" CORRESPONDID ="  + SZCORNUM + " " Type+" : " UPDFLG
  Call ECR_TRACE((mess(228,177,1) - "CORRESPONDID =" - CORRESPONDID + "  " + mess(115,123,1) - ":" - UPDFLG), 0) From GESECRAN
  If UPDFLG = MC_UPD_RES Then
    If SZCORNUM = "" Then
      MSGFLG(INBMES) = MC_ERROR
      #Erreur, l'identifiant Adonix est vide et le correspondant a le mode restauration.
      MSGTXT(INBMES) = mess(276,177,1)
      Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
      INBMES += 1
      RET = MC_KO_NEXT
    Else
      #Deux cas soit la correspondant existe encore et on passe en modif
      #         soit la correspondant n'existe plus et on passe en création avec le code passé
      Read [COR]COR0=SZCORNUM
      If fstat <> 0 Then
        #If faut créer
        UPDFLG = MC_UPD_CRE
      Else
        UPDFLG = MC_UPD_MOD
      Endif
    Endif
  Else
    If UPDFLG = MC_UPD_CRE Then
      SZCORNUM = ""
    Endif
  Endif
  If SZCORNUM = "" Then
    If UPDFLG <> MC_UPD_CRE Then
      MSGFLG(INBMES) = MC_ERROR
      #Erreur, l'identifiant Adonix est vide et le correspondant n'est pas nouveau.
      MSGTXT(INBMES) = mess(277,177,1)
      Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
      INBMES += 1
      RET = MC_KO_NEXT
    Endif
  Endif
  If RET = MC_KO_NEXT or RET = MC_KO Then
    End    #On sort
  Endif
  Call GETREPFROMUTI(GUSER, SZREPCONNECT, SZMESSAGE, IBRETOUR) From CRMUTIL150
  If SZREPCONNECT = "" Then
    #Erreur, aucun représentant n'est associé à cet utilisateur : GUSER
    MSGTXT(INBMES) = mess(301,177,1) - ":" - GUSER
    Call ECR_TRACE(MSGTXT(INBMES),1) From GESECRAN
    INBMES += 1
    RET = MC_KO
  Endif
  Call SITECRMDEF("ACT", SZSITECONNECT) From CRM_UTIL
  If UPDFLG = MC_UPD_CRE Then
    #Cas d'un nouveau correspondant
    If GIBCORADXCRE = MC_TRUE Then
      #On a le droit de creer un correspondant donc on le creer
      SZMODE = MC_UPD_CRE
      Gosub COR_LOADSET
      #Rq: transaction géré dans la fonction avec commit ou rollback
      Call CRECOR("SUBSYDCOR", ITRACE, 0, SZCORNUM, LERRCOD) From SUBCORCC
      If LERRCOD = 0 Then
        CORRESPONDID = "COR" + SZCORNUM
        Call DEBTRANS From GLOCK
        Read [COR]COR0=SZCORNUM
        If fstat = 0 Then
          Trbegin [SYD]
          #Si pas de problème lors de la création de la correspondant, on cree une info de synchro
          Call SYDWRITE(GUSER, SZSITECONNECT, [F:COR]CORNUM, "COR", "M", 1, 1, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
          If IBRETOUR = 0 Then
            IBERROR = MC_TRUE
            MSGFLG(INBMES) = MC_ERROR
            #Erreur lors de l'écriture des données de synchronisation pour le nouveau correspondant - ":" -  [F:COR]CORNUM
            MSGTXT(INBMES) = mess(278,177,1) - ":" - [F:COR]CORNUM
            Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
            INBMES += 1
            RET = MC_KO_NEXT
            Rollback
          Else
            Commit
          Endif
          #Traitement des zones à transcoder
          If IBERROR = MC_FALSE Then
            Gosub TRTERRORCODIF
          Endif
        Else
          RET = MC_KO_NEXT
          MSGFLG(INBMES) = MC_ERROR
          #Erreur lors de la lecture du correspondant - ":" -  [F:COR]CORNUM
          MSGTXT(INBMES) = mess(271,177,1) - ":" - [F:COR]CORNUM
          Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
          INBMES += 1
          IBERROR = MC_TRUE
        Endif
      Else
        MSGFLG(INBMES) = MC_ERROR
        MSGTXT(INBMES) = GMESSIMP
        INBMES += 1
        MSGFLG(INBMES) = MC_ERROR
        #Erreur lors de la création d'un nouveau correspondant.
        MSGTXT(INBMES) = mess(279,177,1)
        Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
        INBMES += 1
        RET = MC_KO_NEXT
        IBERROR = MC_TRUE
      Endif
    Endif
  Else
    #On est en modification ou en suppression
    #On vérifie que la correspondant existe
    Read [COR]COR0=SZCORNUM
    If fstat <> 0 Then
      #correspondant non trouve, elle a du être supprimé
      If UPDFLG <> MC_UPD_SUP Then
        #La correspondant existe dans Outlook
        #On vérifie que l'on a une trace pour l'utilisateur dans la synchro
        INBRECORD = 0
        Call DEBTRANS From GLOCK
        Trbegin [SYD]
        For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "COR" and [F:SYD]SYDKEY = SZCORNUM
          INBRECORD + = 1
          If [F:SYD]SYDATTTYP <> "A" Then
            Readlock [SYD]Curr
            If fstat = 0 Then
              [F:SYD]SYDATTTYP = "A"
              [F:SYD]SYDOTKSTA = 1
              [F:SYD]SYDUPD = 1
              [F:SYD]SYDDAT = date$
              [F:SYD]SYDHOU = time$
              [F:SYD]CREUSR= GUSER
              [F:SYD]CREDAT = date$
              Rewrite [SYD]
              If fstat <> 0 Then
                RET = MC_KO_NEXT
                IBERROR = MC_TRUE
                MSGFLG(INBMES) = MC_ERROR
                #Erreur lors de la modification des données de synchronisation pour le correspondant - ":" -  [F:COR]CORNUM
                MSGTXT(INBMES) = mess(280,177,1) - ":" - [F:COR]CORNUM
                Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                INBMES += 1
                Break
              Endif
            Else
              RET = MC_KO_NEXT
              IBERROR = MC_TRUE
              MSGFLG(INBMES) = MC_ERROR
              #Impossible de locker les données de synchronisation pour le correspondant - ":" -  [F:COR]CORNUM
              MSGTXT(INBMES) = mess(281,177,1) - ":" - [F:COR]CORNUM
              Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
              INBMES += 1
              Break
            Endif
          Endif
        Next
        If INBRECORD = 0 and IBERROR = MC_FALSE Then
          #On n'a pas de donné de synchronisation
          #On crée une donnée pour indiqué à OutLook de supprimé
          Call SYDWRITE(GUSER, SZSITECONNECT, SZCORNUM, "COR", "A", 1, 1, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
          If IBRETOUR = 0 Then
            MSGFLG(INBMES) = MC_ERROR
            #Erreur lors de l'écriture des données de synchronisation pour le correspondant - ":" -  [F:COR]CORNUM
            MSGTXT(INBMES) = mess(282,177,1) - ":" - [F:COR]CORNUM
            Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
            INBMES += 1
            RET = MC_KO_NEXT
            IBERROR = MC_TRUE
          Endif
        Endif
        #On vérifie que l'on a une transaction en cours
        If adxlog Then
          If IBERROR = MC_TRUE Then
            Rollback
          Else
            Commit
          Endif
        Endif
      Endif
    Else
      #test le cas du représentant
      #Si représentant on ne fait rien, on passe au suivant
      If [F:COR]CORTYP = "REP" Then
        MSGFLG(INBMES) = MC_WARNING
        #Les représentants ne sont pas synchronisés avec Outlook.
        MSGTXT(INBMES) = mess(412,177,1)
        Call ECR_TRACE(MSGTXT(INBMES), 0) From GESECRAN
        MSGFLG(INBMES) = MC_WARNING
        #Représentant - ":" -  [F:COR]CORNUM+ "     " + non traité
        MSGTXT(INBMES) = mess(413,177,1) - ":" - [F:COR]CORNUM + "    " + mess(414,177,1)
        Call ECR_TRACE(MSGTXT(INBMES), 0) From GESECRAN
        INBMES += 1
        RET = MC_OK
        End
      Endif
      #La correspondant existe
      If UPDFLG = MC_UPD_SUP Then
        #Il faut supprimer la correspondant
        If GIBCORADXDLT = MC_TRUE Then
          SZMODE = MC_UPD_SUP
          Delete [COP] Where [F:COP]COPNUM = [F:COR]CORNUM and [F:COP]COPREP = SZREPCONNECT
          If fstat <> 0 Then
            MSGFLG(INBMES) = MC_ERROR
            #Erreur lors de la suppression d'une relation représentant +" ( " + F:COR]CORNUM +" / " +    SZREPCONNECT + " ) "
            MSGTXT(INBMES) = mess(266,177,1) - "(" + [F:COR]CORNUM - "/" - SZREPCONNECT + ")"
            Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
            INBMES += 1
          Else
            #On a pu supprimer la correspondant et l'ordre vient de Outlook
            #On supprime les liens
            Call DEBTRANS From GLOCK
            Trbegin [SYD]
            Delete Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "COR" and [F:SYD]SYDKEY = SZCORNUM
            If fstat <> 0 Then
              Rollback
              IBERROR = MC_TRUE
              #Problème car incohérence entre CORRESPOND ET SYNCDATA
              MSGFLG(INBMES) = MC_ERROR
              #Erreur lors de la suppression des données de synchronisation pour le correspondant - ":" - SZCORNUM
              MSGTXT(INBMES) = mess(284,177,1) - ":" - SZCORNUM
              Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
              INBMES += 1
            Else
              Commit
            Endif
          Endif
        Endif
      Else
        #On est en modif sur un correspondant, on vérifie si toujours affecter à l'utilisateur
        Read [COP]COP0=SZREPCONNECT;[F:COR]CORNUM
        If fstat <> 0 Then
          #On a eu un changement d'affectation de représentant
          #On vérifie dans les données de synchro pour l'ancien
          INBRECORD = 0
          Call DEBTRANS From GLOCK
          Trbegin [SYD]
          For [SYD]SYD1 Where [F:SYD]SYDUSR = SZCORUSR and [F:SYD]SYDTYP = "COR" and [F:SYD]SYDKEY = SZCORNUM
            INBRECORD += 1
            If [F:SYD]SYDATTTYP <> "P" Then
              Readlock [SYD]Curr
              If fstat = 0 Then
                [F:SYD]SYDATTTYP = "P"
                [F:SYD]SYDOTKSTA = 1
                [F:SYD]SYDUPD = 1
                [F:SYD]SYDDAT = date$
                [F:SYD]SYDHOU = time$
                [F:SYD]CREUSR = GUSER
                [F:SYD]CREDAT = date$
                Rewrite [SYD]
                If fstat <> 0 Then
                  RET = MC_KO_NEXT
                  MSGFLG(INBMES) = MC_ERROR
                  #Erreur lors de la modification des données de synchronisation pour le correspondant - ":" -  [F:COR]CORNUM
                  MSGTXT(INBMES) = mess(280,177,1) - ":" - [F:COR]CORNUM
                  Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                  INBMES += 1
                  IBERROR = MC_TRUE
                  Break
                Endif
              Else
                RET = MC_KO_NEXT
                MSGFLG(INBMES) = MC_ERROR
                #Impossible de locker les données de synchronisation pour le correspondant - ":" - [F:COR]CORNUM
                MSGTXT(INBMES) = mess(281,177,1) - ":" - [F:COR]CORNUM
                Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                INBMES += 1
                IBERROR = MC_TRUE
                Break
              Endif
            Endif
          Next
          If INBRECORD = 0 and IBERROR = MC_FALSE Then
            #On crée une donnée pour indiqué à OutLook de supprimé pour l"utilisateur
            Call SYDWRITE(SZCORUSR, SZSITECONNECT, SZCORNUM, "COR", "P", 1, 1, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
            If IBRETOUR = 0 Then
              RET = MC_KO_NEXT
              MSGFLG(INBMES) = MC_ERROR
              #Erreur lors de l'écriture des données de synchronisation pour le correspondant - ":" -  [F:COR]CORNUM
              MSGTXT(INBMES) = mess(282,177,1) - ":" - [F:COR]CORNUM
              Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
              INBMES += 1
              IBERROR = MC_TRUE
            Endif
          Endif
          #On vérifie que l'on a une transaction en cours
          If adxlog Then
            If IBERROR = MC_TRUE Then
              Rollback
            Else
              Commit
            Endif
          Endif
        Endif
        #On modifie le correspondant
        If GIBCORADXUPD = MC_TRUE and IBERROR = MC_FALSE Then
          INBRECORD = 0
          For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "COR" and [F:SYD]SYDKEY = SZCORNUM
            INBRECORD += 1
            Break
          Next
          If INBRECORD > 0 Then
            #correspondant aussi modifier dans X3 donc Conflit
            #On recherche le type de conflit
            Gosub GETTYPECONFLIT
          Endif
          SZMODE = MC_UPD_MOD
          Gosub COR_LOADSET
          #Rq: transaction géré dans la fonction avec commit ou rollback
          Call UPDCOR("SUBSYDCOR", ITRACE, IOPENTRACE, SZCORNUM, LERRCOD) From SUBCORCM
          If LERRCOD = 0 Then
            #On vérifie que l'on a une donnée de synchro
            INBRECORD = 0
            Call DEBTRANS From GLOCK
            Trbegin [SYD]
            For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "COR" and [F:SYD]SYDKEY = SZCORNUM
              INBRECORD += 1
              If [F:SYD]SYDATTTYP <> "M" Then
                Readlock [SYD]Curr
                If fstat = 0 Then
                  [F:SYD]SYDATTTYP = "M"
                  [F:SYD]SYDOTKSTA = 1
                  [F:SYD]SYDUPD = 1
                  [F:SYD]SYDDAT = date$
                  [F:SYD]SYDHOU = time$
                  [F:SYD]CREUSR = GUSER
                  [F:SYD]CREDAT = date$
                  Rewrite [SYD]
                  If fstat <> 0 Then
                    RET = MC_KO_NEXT
                    IBERROR = MC_TRUE
                    MSGFLG(INBMES) = MC_ERROR
                    #Erreur lors de la modification des données de synchronisation pour le correspondant - ":" -  [F:COR]CORNUM
                    MSGTXT(INBMES) = mess(280,177,1) - ":" - [F:COR]CORNUM
                    Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                    INBMES += 1
                    Break
                  Endif
                Else
                  RET = MC_KO_NEXT
                  IBERROR = MC_TRUE
                  MSGFLG(INBMES) = MC_ERROR
                  #Impossible de locker les données de synchronisation pour le correspondant - ":" -  [F:COR]CORNUM
                  MSGTXT(INBMES) = mess(281,177,1) - ":" - [F:COR]CORNUM
                  Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                  INBMES += 1
                  Break
                Endif
              Endif
            Next
            If INBRECORD = 0 and IBERROR = MC_FALSE Then
              #On n'a pas de donné de synchronisation
              #On crée une donnée pour indiqué à OutLook d'en tenir compte
              Call SYDWRITE(GUSER, SZSITECONNECT, SZCORNUM, "COR", "M", 1, 1, 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDB
              If IBRETOUR = 0 Then
                RET = MC_KO_NEXT
                MSGFLG(INBMES) = MC_ERROR
                #Erreur lors de l'écriture des données de synchronisation pour le correspondant - ":" -  [F:COR]CORNUM
                MSGTXT(INBMES) = mess(282,177,1) - ":" - [F:COR]CORNUM
                Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
                INBMES += 1
                IBERROR = MC_TRUE
              Endif
            Endif
            #On vérifie que l'on a une transaction en cours
            If adxlog Then
              If IBERROR = MC_TRUE Then
                Rollback
              Else
                Commit
              Endif
            Endif
            #Traitement des zones à transcoder
            If IBERROR = MC_FALSE Then
              Gosub TRTERRORCODIF
            Endif
          Else
            MSGFLG(INBMES) = MC_ERROR
            MSGTXT(INBMES) = GMESSIMP
            INBMES += 1
            MSGFLG(INBMES) = MC_ERROR
            #Erreur lors de la modification du correspondant - ":" -  [F:COR]CORNUM
            MSGTXT(INBMES) = mess(285,177,1) - ":" - [F:COR]CORNUM
            Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
            INBMES += 1
            RET = MC_KO_NEXT
          Endif
        Else
          RET = MC_OK
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
# Recherche du type de conflit
##########################################################################################################
$GETTYPECONFLIT
Local Integer IOTK

  #date de modification dans Outlook
  IOTK = 1
  While IOTK < dim(TBKDATTIM)+1
    If  TBKDATTIM(IOTK) = "LastModificationTime" Then
      #Date de modification
      Call GETDATEFROMCHAR(TBVDATTIM(IOTK),GDTDATEMODIFOTK,IERRINF,ICHAPTER,IBRETOUR) From SUBSYDUTIL
      Break
    Endif
    IOTK += 1
  Wend
  #date de modification dans Adonix
  GDTDATEMODIFADX = [F:COR]UPDDAT
  If GDTDATEMODIFADX >= GDTDATEMODIFOTK Then
    GITYPECONFLIT = MC_RECENTADX
  Else
    GITYPECONFLIT = MC_RECENTOTK
  Endif
Return

##########################################################################################################
# Transfert des infos de Outlook vers Adonix
##########################################################################################################
$COR_LOADSET
Local Integer ICHAR
Local Integer IINT
Local Integer IDEC
Local Integer IDATE
Local Integer ICLOB
Local Integer IOTK
Local Integer IVALEUR
Local Integer INBHOUR
Local Char SZREP(GLONREP)
Local Char SZSITE(GLONFCY)
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Date DTVALEUR
Local Char SZVALEUR(250)
Local Char SZCODE(250)
Local Char SCPYCRY(GLONCPY)  # Issue X3-46689 - 2017-07-04 by FGR
Local Char SHOMCRY(GLONCPY)  # Issue X3-46689 - 2017-07-04 by FGR

  Raz SCPYCRY                # Issue X3-46689 - 2017-07-04 by FGR
  Raz SHOMCRY                # Issue X3-46689 - 2017-07-04 by FGR
  Raz SZREP
  Raz SZSITE
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = MC_TRUE
  DTVALEUR = [00/00/00]
  Raz SZVALEUR
  Raz SZCODE
  #Tableau de char
  Raz GTBKCHR
  Raz GTBVCHR
  #Tableau entiers
  Raz GTBKINT
  Raz GTBVINT
  #Tableau decimal
  Raz GTBKDEC
  Raz GTBVDEC
  #tableau date
  Raz GTBKDATTIM
  Raz GTBVDATTIM
  #tableau clob
  Raz GTBKCLOB
  Raz GTBVCLOB
  Raz GTBTRTFIE
  Raz GTBTRTVAL
  GNBTRT = 0
  ICHAR = 1
  IINT = 1
  IDEC = 1
  IDATE = 1
  ICLOB = 1
  #Traitement du tableau de char d'outlook
  IOTK = 1
  While IOTK < dim(TBKCHR)+1
    Case TBKCHR(IOTK)
      When "Email1Address"
        #E-mail professionnel
        If TBVCHR(IOTK) <> "" Then
          GTBKCHR(ICHAR) = "CPYEML"
          GTBVCHR(ICHAR) = TBVCHR(IOTK)
          ICHAR += 1
        Endif
      When "Email2Address"
        #E-mail personnel
        If TBVCHR(IOTK) <> "" Then
          GTBKCHR(ICHAR) = "HOMEML"
          GTBVCHR(ICHAR) = TBVCHR(IOTK)
          ICHAR += 1
        Endif
      When "BusinessAddressPostalCode"
        #Code postal professionnel
        If TBVCHR(IOTK) <> "" Then
          GTBKCHR(ICHAR) = "CPYZIP"
          GTBVCHR(ICHAR) = TBVCHR(IOTK)
          ICHAR += 1
        Endif
      When "HomeAddressPostalCode"
        #Code postal personnel
        If TBVCHR(IOTK) <> "" Then
          GTBKCHR(ICHAR) = "HOMZIP"
          GTBVCHR(ICHAR) = TBVCHR(IOTK)
          ICHAR += 1
        Endif
      When "BusinessAddressState"
        #Etat professionnel
        If TBVCHR(IOTK) <> "" Then
          GTBKCHR(ICHAR) = "CPYSAT"
          GTBVCHR(ICHAR) = TBVCHR(IOTK)
          ICHAR += 1
        Endif
      When "HomeAddressState"
        #Etat personnel
        If TBVCHR(IOTK) <> "" Then
          GTBKCHR(ICHAR) = "HOMSAT"
          GTBVCHR(ICHAR) = TBVCHR(IOTK)
          ICHAR += 1
        Endif
      When "Language"
        #Langue
        If TBVCHR(IOTK) <> "" Then
          GTBKCHR(ICHAR) = "LAN"
          GTBVCHR(ICHAR) = TBVCHR(IOTK)
          ICHAR += 1
        Endif
      When "LastName"
        #nom
        If TBVCHR(IOTK) <> "" Then
          GTBKCHR(ICHAR) = "LNA"
          GTBVCHR(ICHAR) = TBVCHR(IOTK)
          ICHAR += 1
        Endif
      When "BusinessAddressCountry"
        #Pays (prodessionel)
        If TBVCHR(IOTK) <> "" Then
          Raz SZVALEUR
          Call SYN_GETPAYS(TBVCHR(IOTK), SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
          If IBRETOUR = 1 Then
            GTBKCHR(ICHAR) = "CPYCRY"
            GTBVCHR(ICHAR) = SZVALEUR
            SCPYCRY = SZVALEUR         # Issue X3-46689 - 2017-07-04 by FGR
            SZCODE = SZVALEUR
            ICHAR += 1
            Call SYN_SETPAYS(SZCODE, X3LAN, SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
            If IBRETOUR = 1 and SZVALEUR <> "" Then
              GTBKCHR(ICHAR) = "CPYCRYNAM"
              GTBVCHR(ICHAR) = SZVALEUR
              ICHAR += 1
            Else
              GTBKCHR(ICHAR) = "CPYCRYNAM"
              GTBVCHR(ICHAR) = TBVCHR(IOTK)
              ICHAR += 1
            Endif
          Else
            GTBKCHR(ICHAR) = "CPYCRYNAM"
            GTBVCHR(ICHAR) = TBVCHR(IOTK)
            ICHAR += 1
          Endif
        Endif
      When "HomeAddressCountry"
        #Pays (personnel)
        If TBVCHR(IOTK) <> "" Then
          Raz SZVALEUR
          Call SYN_GETPAYS(TBVCHR(IOTK), SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
          If IBRETOUR = 1 Then
            GTBKCHR(ICHAR) = "HOMCRY"
            GTBVCHR(ICHAR) = SZVALEUR
            SHOMCRY = SZVALEUR         # Issue X3-46689 - 2017-07-04 by FGR
            SZCODE = SZVALEUR
            ICHAR += 1
            Call SYN_SETPAYS(SZCODE, X3LAN, SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
            If IBRETOUR = 1 and SZVALEUR <> "" Then
              GTBKCHR(ICHAR) = "HOMCRYNAM"
              GTBVCHR(ICHAR) = SZVALEUR
              ICHAR += 1
            Else
              GTBKCHR(ICHAR) = "HOMCRYNAM"
              GTBVCHR(ICHAR) = TBVCHR(IOTK)
              ICHAR += 1
            Endif
          Else
            GTBKCHR(ICHAR) = "HOMCRYNAM"
            GTBVCHR(ICHAR) = TBVCHR(IOTK)
            ICHAR += 1
          Endif
        Endif
      When "FirstName"
        #Prénom
        If TBVCHR(IOTK) <> "" Then
          GTBKCHR(ICHAR) = "FNA"
          GTBVCHR(ICHAR) = TBVCHR(IOTK)
          ICHAR += 1
        Endif
      When "BusinessAddressStreet"
        #Adresse rue (professionnel)
        If TBVCHR(IOTK) <> "" Then
          GTBKCHR(ICHAR) = "CPYADD"
          GTBVCHR(ICHAR) = TBVCHR(IOTK)
          ICHAR += 1
        Endif
      When "HomeAddressStreet"
        #Adresse rue (personnel)
        If TBVCHR(IOTK) <> "" Then
          GTBKCHR(ICHAR) = "HOMADD"
          GTBVCHR(ICHAR) = TBVCHR(IOTK)
          ICHAR += 1
        Endif
      When "CompanyName"
        #Société
        If TBVCHR(IOTK) <> "" Then
          Raz SZVALEUR
          Call SYN_GETBPR(TBVCHR(IOTK), SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
          If SZVALEUR <> "" Then
            GTBKCHR(ICHAR) = "BPRNUM"
            GTBVCHR(ICHAR) = SZVALEUR
            ICHAR += 1
          Else
            GTBKCHR(ICHAR) = "BPRLIB"
            GTBVCHR(ICHAR) = TBVCHR(IOTK)
            ICHAR += 1
          Endif
        Endif
      # Issue X3-46689 - 2017-07-04 by FGR : BEGIN in the next loop
      #When "BusinessFaxNumber"
      #  #Fax (professionnel)
      #  If TBVCHR(IOTK) <> "" Then
      #    GTBKCHR(ICHAR) = "CPYFAX"
      #    GTBVCHR(ICHAR) = TBVCHR(IOTK)
      #    ICHAR += 1
      #  Endif
      #When "HomeFaxNumber"
      #  #Fax (personnel)
      #  If TBVCHR(IOTK) <> "" Then
      #    GTBKCHR(ICHAR) = "HOMFAX"
      #    GTBVCHR(ICHAR) = TBVCHR(IOTK)
      #    ICHAR += 1
      #  Endif
      #When "BusinessTelephoneNumber"
      #  #Téléphone (professionnel)
      #  If TBVCHR(IOTK) <> "" Then
      #    GTBKCHR(ICHAR) = "CPYTEL"
      #    GTBVCHR(ICHAR) = TBVCHR(IOTK)
      #    ICHAR += 1
      #  Endif
      #When "HomeTelephoneNumber"
      #  #Téléphone (personnel)
      #  If TBVCHR(IOTK) <> "" Then
      #    GTBKCHR(ICHAR) = "HOMTEL"
      #    GTBVCHR(ICHAR) = TBVCHR(IOTK)
      #    ICHAR += 1
      #  Endif
      #When "MobileTelephoneNumber"
      #  #telephone portable (professionnel)
      #  If TBVCHR(IOTK) <> "" Then
      #    GTBKCHR(ICHAR) = "CPYMOB"
      #    GTBVCHR(ICHAR) = TBVCHR(IOTK)
      #    ICHAR += 1
      #  Endif
      # Issue X3-46689 - 2017-07-04 by FGR : END
      When "JobTitle"
        #Libellé fonction
        If TBVCHR(IOTK) <> "" Then
          GTBKCHR(ICHAR) = "FNCLIB"
          GTBVCHR(ICHAR) = TBVCHR(IOTK)
          ICHAR += 1
        Endif
      When "Title"
        #Civilité
        If TBVCHR(IOTK) <> "" Then
          GTBKCHR(ICHAR) = "TTR"
          GTBVCHR(ICHAR) = TBVCHR(IOTK)
          ICHAR += 1
        Endif
      When "BusinessAddressCity"
        #Ville (professionnel)
        If TBVCHR(IOTK) <> "" Then
          GTBKCHR(ICHAR) = "CPYCTY"
          GTBVCHR(ICHAR) = TBVCHR(IOTK)
          ICHAR += 1
        Endif
      When "HomeAddressCity"
        #Ville (personnel)
        If TBVCHR(IOTK) <> "" Then
          GTBKCHR(ICHAR) = "HOMCTY"
          GTBVCHR(ICHAR) = TBVCHR(IOTK)
          ICHAR += 1
        Endif
    Endcase
    IOTK += 1
  Wend
  # Issue X3-46689 - 2017-07-04 by FGR : BEGIN : The first loop can't manage phone because we are not sure to have already the county
  IOTK = 1
  While IOTK < dim(TBKCHR)+1
    Case TBKCHR(IOTK)
      When "BusinessFaxNumber"
        #Fax (professionnel)
        If TBVCHR(IOTK) <> "" Then
          GTBKCHR(ICHAR) = "CPYFAX"
          GTBVCHR(ICHAR) = func SUBSYDUTIL.OL_EXTRACT_PHONE(SCPYCRY, TBVCHR(IOTK))
          ICHAR += 1
        Endif
      When "HomeFaxNumber"
        #Fax (personnel)
        If TBVCHR(IOTK) <> "" Then
          GTBKCHR(ICHAR) = "HOMFAX"
          GTBVCHR(ICHAR) = func SUBSYDUTIL.OL_EXTRACT_PHONE(SHOMCRY, TBVCHR(IOTK))
          ICHAR += 1
        Endif
      When "BusinessTelephoneNumber"
        #Téléphone (professionnel)
        If TBVCHR(IOTK) <> "" Then
          GTBKCHR(ICHAR) = "CPYTEL"
          GTBVCHR(ICHAR) = func SUBSYDUTIL.OL_EXTRACT_PHONE(SCPYCRY, TBVCHR(IOTK))
          ICHAR += 1
        Endif
      When "HomeTelephoneNumber"
        #Téléphone (personnel)
        If TBVCHR(IOTK) <> "" Then
          GTBKCHR(ICHAR) = "HOMTEL"
          GTBVCHR(ICHAR) = func SUBSYDUTIL.OL_EXTRACT_PHONE(SHOMCRY, TBVCHR(IOTK))
          ICHAR += 1
        Endif
      When "MobileTelephoneNumber"
        #telephone portable (professionnel)
        If TBVCHR(IOTK) <> "" Then
          GTBKCHR(ICHAR) = "CPYMOB"
          GTBVCHR(ICHAR) = func SUBSYDUTIL.OL_EXTRACT_PHONE(SCPYCRY, TBVCHR(IOTK))
          ICHAR += 1
        Endif
    Endcase
    IOTK += 1
  Wend
  # Issue X3-46689 - 2017-07-04 by FGR : END
  #Traitement du tableau entier d'outlook
  #  IOTK = 1
  #  While IOTK < dim(TBKINT)+1
  #    Case TBKINT(IOTK)
  #      When "test"
  #    Endcase
  #    IOTK += 1
  #  Wend
  #Traitement du tableau de décimal d'outlook
  IOTK = 1
  While IOTK < dim(TBKDEC)+1
    Case TBKDEC(IOTK)
      When "test"
    Endcase
    IOTK += 1
  Wend
  #Traitement du tableau de date d'outlook
  IOTK = 1
  While IOTK < dim(TBKDATTIM)+1
    Case TBKDATTIM(IOTK)
      When "test"
    Endcase
    IOTK += 1
  Wend
  #Traitement du tableau de clob d'outlook
  IOTK = 1
  While IOTK < dim(TBKCLOB)+1
    Case TBKCLOB(IOTK)
      When "Body"
        GTBKCLOB(ICLOB) = "CRCCLOB"
        GTBVCLOB(ICLOB) = TBVCLOB(IOTK)
        ICLOB += 1
    Endcase
    IOTK += 1
  Wend
  #Traitement des zones spéciales
  #Représentant
  Call PARAMUTIL("AUSCRMF", SZREP, GUSER, SZSITE) From SUBAUS
  GTBKCHR(ICHAR) = "COPREP"
  GTBVCHR(ICHAR) = SZREP
  ICHAR += 1
  #Stokage de l'utilisateur
  GTBKCHR(ICHAR) = "GUSER"
  GTBVCHR(ICHAR) = GUSER
  ICHAR += 1
  #Numéro de correspondant (cas particulier de larestoration
  If SZCORNUM  <> "" Then
    GTBKCHR(ICHAR) = "CORNUM"
    GTBVCHR(ICHAR) = SZCORNUM
    ICHAR += 1
  Endif
Return

##########################################################################################################
# Affectation des valeurs pour la création, modification, suppression d'une correspondant. (exemple)
#############################################################################
$COR_SET_HEA_INFO
Local Integer INDEXE
Local Char SZREP(GLONREP)
Local Integer IBAFFECTE
Local Char SZVALEUR(250)
Local Char SZVALEUR1(250)
Local Char SZVALEUR2(250)
Local Char SZVALEUR3(250)
Local Char SZMESSAGE(250)
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer IBMODIF

  Raz SZREP
  Raz SZVALEUR
  Raz SZVALEUR1
  Raz SZVALEUR2
  Raz SZVALEUR3
  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN
  Raz SZMESSAGE
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = MC_TRUE
  INDEXE = 0
  IBAFFECTE = MC_FALSE
  IBMODIF = 0
  Case IMPZON
    When "CORNUM"
      #Numéro de correspondant
      If GREP = "C" Then
        INDEXE = find("CORNUM", GTBKCHR)
        If INDEXE <> 0 Then
          [M:COR0]CORNUM = GTBVCHR(INDEXE)
        Endif
      Endif
    When "CPYEML"
      #E-mail professionnel
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("CPYEML", GTBKCHR)
          If INDEXE <> 0 Then
            [M:COR2]CPYEML = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
    When "HOMEML"
      #E-mail personnel
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
        If IBAFFECTE = MC_TRUE Then
          INDEXE = find("HOMEML", GTBKCHR)
          If INDEXE <> 0 Then
            [M:COR3]HOMEML = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
    When "CPYZIP"
      #Code postal professionnel
      If GREP <> MC_UPD_SUP Then
        If GITYPECONFLIT = MC_NOCONFLIT or GITYPECONFLIT = MC_RECENTOTK Then
          IBAFFECTE = MC_TRUE
        Else
          IBAFFECTE = MC_FALSE
        Endif
