    When "CRCCLOB"
      #Compte-rendu
      Raz SZVALEUR
      INDEXE = find("GUSER", GTBKCHR)
      If INDEXE <> 0 Then
        SZVALEUR = GTBVCHR(INDEXE)
      Else
        SZVALEUR = GUSER
      Endif
      INDEXE = find("CRCCLOB", GTBKCLOB)
      If INDEXE <> 0 Then
        Call CONCATCLOB( SZVALEUR, [M:COR1]CRCCLOB, GTBVCLOB(INDEXE), GITYPECONFLIT, IBMODIF, SZMESSAGE, IBRETOUR) From SUBSYDUTIL
      Endif
