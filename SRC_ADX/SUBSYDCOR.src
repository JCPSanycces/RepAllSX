      If GREP = "C" Then
        [M:COR4]NBLIGNCOP = 1
        INDEXE = find("COPREP", GTBKCHR)
        If INDEXE <> 0 Then
          [M:COR4]COPREP(0) = GTBVCHR(INDEXE)
        Endif
      Endif
  Endcase
Return

#############################################################################
#DETAIL
$COR_SET_DET_INFO
Local Integer ILIGNESAVE

  Case IMPZON
    When "COPREP"
      If GREP = "C" Then
        If indice = 0 Then
          INDEXE = find("COPREP", GTBKCHR)
          If INDEXE <> 0 Then
            IMPMOD = 1
            [M:COR4]COPREP(indice) = GTBVCHR(INDEXE)
          Endif
        Endif
      Endif
  Endcase
Return

##########################################################################################################
# Traitement de l'enregistrement des erreurs de transcodifications
$TRTERRORCODIF
Local Integer ITRT

  If !clalev([F:SYL]) : Local File SYNCLINK [SYL] : Endif
  ITRT = 0
  If GNBTRT > 0 Then
    #On a des données a sauvegarder
    Call DEBTRANS From GLOCK
    Trbegin [SYL]
    While ITRT < GNBTRT
      Call  SYLWRITE(GUSER, "COR",  SZCORNUM, GTBTRTFIE(ITRT), GTBTRTVAL(ITRT), IERRINF, ICHAPTER, IBRETOUR) From SUBSYLB
      If IBRETOUR = MC_FALSE Then
        MSGFLG(INBMES) = MC_ERROR
        #Erreur lors de l'écriture des traces de transcodifications. Correspondant - ":" -  [F:COR]CORNUM + Champs +GTBTRTFIE(ITRT)
        MSGTXT(INBMES) = mess(286,177,1) - ":" - [F:COR]CORNUM - mess(149,123,1) - GTBTRTFIE(ITRT)
        Call ECR_TRACE(MSGTXT(INBMES),1) From GESECRAN
        INBMES += 1
        Break
      Endif
      ITRT+ = 1
    Wend
    If IBRETOUR = MC_TRUE Then
      Commit
    Else
      Rollback
      RET = MC_KO_NEXT
    Endif
  Endif
Return

##########################################################################################################
# Confirmation Set (Outlook vers Adonix)
# ------------------------------------------------------------
Subprog COR_SET_OK(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, CORRESPONDID)
# <Par Techniques>
Variable Char RET()    # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)# Niveau des messages retournés
Variable Char MSGTXT()(1..)# Texte des messages retournés
# </PT>
Value Char CORRESPONDID()            # ID permettant de retrouver la correspondant

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN

Local Integer IBERROR
Local Integer INBMES
Local Char SZCORNUM(GLONCOR)
Local Char SZOBJET(GLONAOB)
Local Integer WI
Local Char SZRET(GLONDES)

  IBERROR = MC_FALSE
  Raz SZCORNUM
  Raz SZOBJET
  # Analyse des messages si besoin
  WI = find(2,MSGFLG)
  #  If(WI!= 0) .....
  WI = find(1,MSGFLG)
  #  If(WI!= 0) .....
  INBMES = 1
  #Ecriture du tableau de message et réinitialisation
  Gosub WRITE_RAZ_MSG From SUBSYDSYN
  #"Confirmation données outlook  CORRESPONDID = "  + CORRESPONDID + " " Status +" : " + RET
  Call ECR_TRACE((mess(258,177,1) - "CORRESPONDID =" - CORRESPONDID - "  " - mess(259,123,1) - ":" - RET),0) From GESECRAN
  #Traitement de l'identifiant correspondant
  Call DECOD_OTKID(CORRESPONDID, "COR", SZCORNUM, SZOBJET) From SUBSYDUTIL
  Local File SYNCDATA [SYD]
  Raz SZRET
  If RET = MC_WRN Then
    SZRET = MC_OK
  Else
    SZRET = RET
  Endif
  IBERROR = MC_FALSE
  If SZRET <> MC_OK Then
    Call DEBTRANS From GLOCK
    Trbegin [SYD]
    For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "COR" and [F:SYD]SYDKEY = SZCORNUM
      Readlock [SYD]Curr
      If fstat = 0 Then
        [F:SYD]SYDOTKSTA = 0
        Rewrite [SYD]
        If fstat <> 0 Then
          IBERROR = MC_TRUE
          MSGFLG(INBMES) = MC_ERROR
          #Erreur lors de la modification des données de synchronisation pour le correspondant - ":" -  SZCORNUM
          MSGTXT(INBMES) = mess(280,177,1) - ":" - SZCORNUM
          Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
          INBMES += 1
          Break
        Endif
      Else
        IBERROR = MC_TRUE
        MSGFLG(INBMES) = MC_ERROR
        #Impossible de locker les données de synchronisation pour le correspondant - ":" -  SZCORNUM
        MSGTXT(INBMES) = mess(281,177,1) - ":" - SZCORNUM
        Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
        INBMES += 1
        Break
      Endif
    Next
    If IBERROR = MC_FALSE Then
      Commit
      RET = MC_OK
    Else
      Rollback
      RET = MC_KO_NEXT
    Endif
  Endif
End

##########################################################################################################
# Description passage info Adonix/Outlook
# ------------------------------------------------------------
Subprog COR_GET_DESC(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, XMLDESC)
# <Par Techniques>
Variable Char RET()               # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Variable Clbfile XMLDESC()        # Description structure dynamique

Local Integer INBMES

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN
  INBMES = 1
  #Ecriture du tableau de message et réinitialisation
  Gosub WRITE_RAZ_MSG From SUBSYDSYN

Local Integer TC_MAX : SC_MAX = 150
Local Integer WI : WI= 0
Local Char WDSC(200)(1..SC_MAX)

  Gosub COR_INIGETDSC From SUBSYDCORD
  Gosub COR_LD_GETDESC From SUBSYDCORD
  Setlob XMLDESC With [L]WDSC
  # Statut
  RET = MC_OK
End

##########################################################################################################
# subprog COR_GET(MAJ OutLook depuis Adonix)
# ------------------------------------------------------------
Subprog COR_GET(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, VERDESC, CORRESPONDID, UPDFLG, TBKCHR, TBVCHR, TBKINT, TBVINT, TBKDEC, TBVDEC, TBKDATTIM, TBVDATTIM, TBKCLOB, TBVCLOB)
# <Par Techniques>
Variable Char RET()               # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Value Char VERDESC()
Variable Char CORRESPONDID()      # ID permettant de retrouver la correspondant (OL ou X3)
Variable Char UPDFLG()            # Type de mise à jour (C,M,S)
# <Tabl. Dynamiques>
Variable Char TBKCHR()(1..)       # Paramètres caractères
Variable Char TBVCHR()(1..)
Variable Char TBKINT()(1..)       # Paramètres entiers
Variable Integer  TBVINT(1..)
Variable Char  TBKDEC()(1..)      # Paramètres décimaux
Variable Decimal TBVDEC(1..)
Variable Char  TBKDATTIM()(1..)   # Paramètres Dates AAAAMMJJHHMMSS
Variable Char TBVDATTIM()(1..)
Variable Char  TBKCLOB()(1..)     # Paramètres Textes riches
Variable Clbfile TBVCLOB()(1..)
# </TD>

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN
  #Mise à vide des tableaux dynamiques
  Gosub RAZPARAMDYN From SUBSYDSYN

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer INBRECORD
Local Char SZSYDATTTYP(250)
Local Integer ISYDGEN
Local Integer ISYDUPD
Local Integer INBMES
Local Char SZCORNUM(GLONCOR)
Local Char SZOBJET(GLONAOB)

  IBRETOUR = 1
  INBRECORD = 0
  ISYDGEN = 0
  ISYDUPD = 0
  Raz SZSYDATTTYP
  INBMES = 1
  Raz SZCORNUM
  Raz SZOBJET
  #Ecriture du tableau de message et réinitialisation
  Gosub WRITE_RAZ_MSG From SUBSYDSYN
  RET = MC_OK
  Local File CORRESPOND [COR]
  Local File SYNCDATA [SYD]
  Local File CRMCLOB [CRC]
  Local File CORREP [COP]
  If GIBCOROTKCRE = MC_FALSE and GIBCOROTKUPD = MC_FALSE and GIBCOROTKDLT = MC_FALSE Then
    #Aucun droit synchronisation  dans Outlook on sort
    RET = MC_NOMORE
    End  # FGR 29/03/2010 : X3SUIVI62472 : et pas Return
  Endif
  #Ontraite les enregistrements par type
  #Rappel
  # "C" création,
  # "D" duplication,
  # "M" modification,
  # "A" annulation
  # "P" changement utilisateur (pour ancien)
  # "R" restauration ou forcage synchro
  INBRECORD = 0
  #Etape 1
  #Enregistrement à créer
  If GINUMETAPEGET = 1 Then
    If GIBCOROTKCRE = MC_FALSE Then
      #Pas le droit de créer On passe à l'étape 2
      GINUMETAPEGET = 3
    Else
      INBRECORD = 0
      For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "COR" and [F:SYD]SYDOTKSTA = 1 and ([F:SYD]SYDATTTYP = "C" or [F:SYD]SYDATTTYP = "D")
        INBRECORD += 1
        SZCORNUM = [F:SYD]SYDKEY
        SZSYDATTTYP = [F:SYD]SYDATTTYP
        ISYDGEN = [F:SYD]SYDGEN
        ISYDUPD = [F:SYD]SYDUPD
        Break
      Next
      If INBRECORD = 0 Then
        #On n'a plus d'enregistrement On passe à l'étape 2
        GINUMETAPEGET = 2
      Endif
    Endif
  Endif
  #Etape 2
  #Enregistrement modifié
  If GINUMETAPEGET = 2 Then
    If GIBCOROTKUPD = MC_FALSE Then
      #Pas le droit de créer On passe à l'étape 3
      GINUMETAPEGET = 3
    Else
      INBRECORD = 0
      For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "COR" and [F:SYD]SYDOTKSTA = 1 and [F:SYD]SYDATTTYP = "M"
        INBRECORD += 1
        SZCORNUM = [F:SYD]SYDKEY
        SZSYDATTTYP = [F:SYD]SYDATTTYP
        ISYDGEN = [F:SYD]SYDGEN
        ISYDUPD = [F:SYD]SYDUPD
        Break
      Next
      If INBRECORD = 0 Then
        #On n'a plus d'enregistrement On passe à l'étape 3
        GINUMETAPEGET = 3
      Endif
    Endif
  Endif
  #Etape 3
  #Enregistrement restauration ou forcage synchro
  If GINUMETAPEGET = 3 Then
    If GIBCOROTKCRE = MC_FALSE and GIBCOROTKUPD = MC_FALSE Then
      #Pas le droit de créer et de modifer  On passe à l'étape 4
      GINUMETAPEGET = 4
    Else
      INBRECORD = 0
      For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "COR" and [F:SYD]SYDOTKSTA = 1 and [F:SYD]SYDATTTYP = "R"
        INBRECORD += 1
        SZCORNUM = [F:SYD]SYDKEY
        SZSYDATTTYP = [F:SYD]SYDATTTYP
        ISYDGEN = [F:SYD]SYDGEN
        ISYDUPD = [F:SYD]SYDUPD
        Break
      Next
      If INBRECORD = 0 Then
        #On n'a plus d'enregistrement On passe à l'étape 4
        GINUMETAPEGET = 4
      Endif
    Endif
  Endif
  #Etape 4
  #suppression enregistrement non touché par synchro
  If GINUMETAPEGET = 4 Then
    If GIBCOROTKDLT = MC_FALSE Then
      #Pas le droit de créer On passe à l'étape 5
      GINUMETAPEGET = 5
    Else
      INBRECORD = 0
      For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "COR" and [F:SYD]SYDOTKSTA = 1 and ([F:SYD]SYDATTTYP = "A" or [F:SYD]SYDATTTYP = "P")
        INBRECORD += 1
        SZCORNUM = [F:SYD]SYDKEY
        SZSYDATTTYP = [F:SYD]SYDATTTYP
        ISYDGEN = [F:SYD]SYDGEN
        ISYDUPD = [F:SYD]SYDUPD
        Break
      Next
      If INBRECORD = 0 Then
        #On n'a plus d'enregistrement On passe à l'étape 5
        GINUMETAPEGET = 5
      Endif
    Endif
  Endif
  If GINUMETAPEGET <> 5 Then
    #On a un enregistrement, il faut le traiter
    #Cas des enregistrements nouveaux ou modifiés (la correspondant existe dans Adonix)
    Call CODE_OTKID(SZCORNUM, "COR", CORRESPONDID) From SUBSYDUTIL
    #"Traitement données Adonix" "CORRESPONDID = "  + CORRESPONDID+ " " Type+" : " SZSYDATTTYP
    Call ECR_TRACE((mess(260,177,1) - "CORRESPONDID =" - CORRESPONDID + "  " + mess(115,123,1) - ":" - SZSYDATTTYP), 0) From GESECRAN
    If SZSYDATTTYP = "P" Then
      UPDFLG = "A"
    Else
      UPDFLG = SZSYDATTTYP
    Endif
    If SZSYDATTTYP <> "A"  Then
      Read [COR]COR0=SZCORNUM
      If fstat <> 0 Then
        #Problème car incohérence entre CORRESPOND ET SYNCDATA
        MSGFLG(INBMES) = MC_ERROR
        #Erreur lors de la lecture du correspondant : + SZCORNUM
        MSGTXT(INBMES) = mess(271,177,1) - SZCORNUM
        Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
        INBMES += 1
        RET = MC_KO_NEXT
      Endif
    Endif
    If RET = MC_OK Then
      #On charge les tableaux dynamiques
      Gosub COR_LOADGET
    Endif
  Else
    RET = MC_NOMORE
  Endif
End

##########################################################################################################
# Transfert des infos de Adonix vers Outlook
##########################################################################################################
$COR_LOADGET
Local Integer ICHAR
Local Integer IINT
Local Integer IDEC
Local Integer IDATE
Local Integer ICLOB
Local Char SZVALEUR(250)
Local Char SZMESSAGE(250)
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Char SZNOM(GLONNAM)
Local Char SZPRENOM(GLONNAM)
Local Char SZSOC(250)
Local Clbfile LBCLOB
Local Integer IBVIDE

  IBRETOUR = 1
  Raz SZNOM
  Raz SZPRENOM
  Raz SZSOC
  Raz SZMESSAGE
  Raz LBCLOB
  ICHAR = 1
  IINT = 1
  IDEC = 1
  IDATE = 1
  ICLOB = 1
  Raz SZVALEUR
  IBVIDE = MC_FALSE
  If UPDFLG = "A" Then
    IBVIDE = MC_TRUE
  Endif
  #Tiers
  TBKCHR(ICHAR) = "CompanyName"
  If [F:COR]CORTYP <> "REP" Then
    If [F:COR]BPRNUM <> "" Then
      Call SYN_SETBPR([F:COR]BPRNUM, SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
      If IBRETOUR = MC_TRUE and IBVIDE = MC_FALSE Then
        TBVCHR(ICHAR) = SZVALEUR
      Endif
    Else
      TBVCHR(ICHAR) = [F:COR]BPRLIB
      SZVALEUR = [F:COR]BPRLIB
    Endif
  Else
    SZVALEUR = [F:COR]BPRNUM
  Endif
  SZSOC = SZVALEUR
  ICHAR += 1
  #E-mail professionnel
  TBKCHR(ICHAR) = "Email1Address"
  TBVCHR(ICHAR) = [F:COR]CPYEML
  ICHAR += 1
  #E-mail personnel
  TBKCHR(ICHAR) = "Email2Address"
  TBVCHR(ICHAR) = [F:COR]HOMEML
  ICHAR += 1
  #Code postal professionnel
  TBKCHR(ICHAR) = "BusinessAddressPostalCode"
  TBVCHR(ICHAR) = [F:COR]CPYZIP
  ICHAR += 1
  #Code postal personnel
  TBKCHR(ICHAR) = "HomeAddressPostalCode"
  TBVCHR(ICHAR) = [F:COR]HOMZIP
  ICHAR += 1
  #Etat professionnel
  TBKCHR(ICHAR) = "BusinessAddressState"
  TBVCHR(ICHAR) = [F:COR]CPYSAT
  ICHAR += 1
  #Etat personnel
  TBKCHR(ICHAR) = "HomeAddressState"
  TBVCHR(ICHAR) = [F:COR]HOMSAT
  ICHAR += 1
  #Nom
  TBKCHR(ICHAR) = "LastName"
  TBVCHR(ICHAR) = [F:COR]LNA
  SZNOM= [F:COR]LNA
  ICHAR += 1
  #Pays (prodessionel)
  TBKCHR(ICHAR) = "BusinessAddressCountry"
  TBVCHR(ICHAR) = [F:COR]CPYCRYNAM
  ICHAR += 1
  #Pays (personnel)
  TBKCHR(ICHAR) = "HomeAddressCountry"
  TBVCHR(ICHAR) = [F:COR]HOMCRYNAM
  ICHAR += 1
  #Prénom
  TBKCHR(ICHAR) = "FirstName"
  TBVCHR(ICHAR) = [F:COR]FNA
  SZPRENOM= [F:COR]FNA
  ICHAR += 1
  #Adresse rue (professionnel)
  TBKCHR(ICHAR) = "BusinessAddressStreet"
  Raz SZVALEUR
  Call SYN_CODIFADR([F:COR]CPYADD(0), [F:COR]CPYADD(1), [F:COR]CPYADD(2), SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
  TBVCHR(ICHAR) = SZVALEUR
  ICHAR += 1
  #Adresse rue(personnel)
  TBKCHR(ICHAR) = "HomeAddressStreet"
  Raz SZVALEUR
  Call SYN_CODIFADR([F:COR]HOMADD(0), [F:COR]HOMADD(1), [F:COR]HOMADD(2), SZVALEUR, IERRINF, ICHAPTER, IBRETOUR) From SUBSYDUTIL
  TBVCHR(ICHAR) = SZVALEUR
  ICHAR += 1
  #Fax (professionnel)
  TBKCHR(ICHAR) = "BusinessFaxNumber"
  # Issue X3-46689 - 2017-07-04 by FGR : BEGIN
  #TBVCHR(ICHAR) = [F:COR]CPYFAX
  TBVCHR(ICHAR) = func SUBSYDUTIL.GET_FORMATTED_CRY_PHONE([F:COR]CPYCRY, [F:COR]CPYFAX)
  # Issue X3-46689 - 2017-07-04 by FGR : END
  ICHAR += 1
  #Fax (personnel)
  TBKCHR(ICHAR) = "HomeFaxNumber"
  # Issue X3-46689 - 2017-07-04 by FGR : BEGIN
  #TBVCHR(ICHAR) = [F:COR]HOMFAX
  TBVCHR(ICHAR) = func SUBSYDUTIL.GET_FORMATTED_CRY_PHONE([F:COR]HOMCRY, [F:COR]HOMFAX)
  # Issue X3-46689 - 2017-07-04 by FGR : END
  ICHAR += 1
  #Téléphone (professionnel)
  TBKCHR(ICHAR) = "BusinessTelephoneNumber"
  # Issue X3-46689 - 2017-07-04 by FGR : BEGIN
  #TBVCHR(ICHAR) = [F:COR]CPYTEL
  TBVCHR(ICHAR) = func SUBSYDUTIL.GET_FORMATTED_CRY_PHONE([F:COR]CPYCRY, [F:COR]CPYTEL)
  # Issue X3-46689 - 2017-07-04 by FGR : END
  ICHAR += 1
  #Téléphone (personnel)
  TBKCHR(ICHAR) = "HomeTelephoneNumber"
  # Issue X3-46689 - 2017-07-04 by FGR : BEGIN
  #TBVCHR(ICHAR) = [F:COR]HOMTEL
  TBVCHR(ICHAR) = func SUBSYDUTIL.GET_FORMATTED_CRY_PHONE([F:COR]HOMCRY, [F:COR]HOMTEL)
  # Issue X3-46689 - 2017-07-04 by FGR : END
  ICHAR += 1
  #telephone portable (professionnel)
  TBKCHR(ICHAR) = "MobileTelephoneNumber"
  # Issue X3-46689 - 2017-07-04 by FGR : BEGIN
  #TBVCHR(ICHAR) = [F:COR]CPYMOB
  TBVCHR(ICHAR) = func SUBSYDUTIL.GET_FORMATTED_CRY_PHONE([F:COR]CPYCRY, [F:COR]CPYMOB)
  # Issue X3-46689 - 2017-07-04 by FGR : END
  ICHAR += 1
  #Libellé fonction
  TBKCHR(ICHAR) = "JobTitle"
  TBVCHR(ICHAR) = [F:COR]FNCLIB
  ICHAR += 1
  #Civilité
  TBKCHR(ICHAR) = "Title"
  If [F:COR]TTR = "" Then
    TBVCHR(ICHAR) = mess([F:COR]TTL,941,1)
  Else
    TBVCHR(ICHAR) = [F:COR]TTR
  Endif
  ICHAR += 1
  #Ville (professionnel)
  TBKCHR(ICHAR) = "BusinessAddressCity"
  TBVCHR(ICHAR) = [F:COR]CPYCTY
  ICHAR += 1
  #Ville (personnel)
  TBKCHR(ICHAR) = "HomeAddressCity"
  TBVCHR(ICHAR) = [F:COR]HOMCTY
  ICHAR += 1
  #Classer sous
  TBKCHR(ICHAR) = "FileAs"
  SZVALEUR = SZNOM
  If SZVALEUR  <> "" Then
    If SZPRENOM <> "" Then
      SZVALEUR = SZVALEUR - "," - SZPRENOM
    Endif
  Else
    SZVALEUR = SZPRENOM
  Endif
  If SZSOC <> "" Then
    SZVALEUR = SZVALEUR - "(" + SZSOC + ")"
  Endif
  TBVCHR(ICHAR) = SZVALEUR
  ICHAR += 1
  #Compte rendu
  TBKCLOB(ICLOB) = "Body"
  Raz TBVCLOB(ICLOB)
  For [CRC] Where [F:CRC]CRCCORNUM = [F:COR]CORNUM and [F:CRC]CRCREP = ""
    LBCLOB = [F:CRC]CRCCLOB
    Break
  Next
  If LBCLOB <> "" Then
    Call ADDBALISEOTK(LBCLOB, SZMESSAGE, IBRETOUR) From SUBSYDUTIL
    TBVCLOB(ICLOB) = LBCLOB
  Endif
  ICLOB += 1
Return

##########################################################################################################
# Confirmation Get
# ------------------------------------------------------------
Subprog COR_GET_OK(RET, RMTAPP, USERID, X3LAN, MSGFLG, MSGTXT, CORRESPONDID)
# <Par Techniques>
Variable Char RET()               # Statut retour ss-prgrm
Value Char RMTAPP()
Value Char USERID()
Value Char X3LAN()
Variable Integer MSGFLG(1..)      # Niveau des messages retournés
Variable Char MSGTXT()(1..)       # Texte des messages retournés
# </PT>
Value Char CORRESPONDID()         # ID permettant de retrouver la correspondant

  #Initialisation variables
  Gosub INITVAR From SUBSYDSYN

Local Char SZCORNUM(GLONCOR)
Local Char SZOBJET(GLONAOB)
Local Integer INBMES
Local Integer IBERROR
Local Char SZRET(GLONDES)

  Raz SZCORNUM
  Raz SZOBJET
  INBMES = 1
  #Ecriture du tableau de message et réinitialisation
  Gosub WRITE_RAZ_MSG From SUBSYDSYN
  #"Confirmation données Adonix CORRESPONDID = "  + CORRESPONDID + " " Status +" : " + RET
  Call ECR_TRACE((mess(261,177,1) - "CORRESPONDID =" - CORRESPONDID + "  " + mess(259,123,1) - ":" - RET), 0) From GESECRAN
  IBERROR = MC_FALSE
  Raz SZRET
  If RET = MC_WRN Then
    SZRET = MC_OK
  Else
    SZRET = RET
  Endif
  Local File SYNCDATA [SYD]
  Call DECOD_OTKID(CORRESPONDID, "COR", SZCORNUM, SZOBJET) From SUBSYDUTIL
  Call DEBTRANS From GLOCK
  Trbegin [SYD]
  If SZRET = MC_OK Then
    #Tout s'est bien passé, on supprime les enregistrements de SYNCDATA
    Delete Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "COR" and [F:SYD]SYDKEY = SZCORNUM
    If fstat <> 0 Then
      IBERROR = MC_TRUE
      #Problème car incohérence entre CORRESPOND ET SYNCDATA
      MSGFLG(INBMES) = MC_ERROR
      #Erreur lors de la suppression des données de synchronisation pour le correspondant - ":" - SZCORNUM
      MSGTXT(INBMES) = mess(284,177,1) - ":" - SZCORNUM
      Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
      INBMES += 1
    Endif
  Else
    #Problème on met à jour le flag
    For [SYD]SYD1 Where [F:SYD]SYDUSR = GUSER and [F:SYD]SYDTYP = "COR" and [F:SYD]SYDKEY = SZCORNUM
      Readlock [SYD]Curr
      If fstat = 0 Then
        [F:SYD]SYDOTKSTA = 0
        Rewrite [SYD]
        If fstat <> 0 Then
          IBERROR = MC_TRUE
          MSGFLG(INBMES) = MC_ERROR
          #Erreur lors de la modification des données de synchronisation pour le correspondant - ":" - SZCORNUM
          MSGTXT(INBMES) = mess(280,177,1) - ":" - SZCORNUM
          Call ECR_TRACE(MSGTXT(INBMES) ,1) From GESECRAN
          INBMES += 1
          Break
        Endif
      Else
        IBERROR = MC_TRUE
        MSGFLG(INBMES) = MC_ERROR
        #Impossible de locker les données de synchronisation pour le correspondant - ":" - SZCORNUM
        MSGTXT(INBMES) = mess(281,177,1) - ":" - SZCORNUM
        Call ECR_TRACE(MSGTXT(INBMES), 1) From GESECRAN
        INBMES += 1
        Break
      Endif
    Next
  Endif
  If IBERROR = MC_FALSE Then
    Commit
    RET = MC_OK
  Else
    Rollback
    RET = MC_KO_NEXT
  Endif
End

