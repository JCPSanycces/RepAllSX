#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
#    Transportation note types                                                       #
######################################################################################
$ACTION

Case ACTION
  When "OUVRE"         : Gosub OUVRE
  When "AFFMASK"       : Gosub AFFMASK
  When "RAZCRE"        : Gosub RAZCRE
  When "RAZDUP"        : Gosub RAZDUP
  When "INICRE"        : Gosub INICRE
  When "INIMOD"        : Gosub INIMOD
  When "ANNULE"        : Gosub ANNULE
  When "LIENS"         : Gosub LIENS
  When "FERME"         : Gosub FERME
  When "SEL_TABLE"
    Case TABLE
      When "SELTTN"    : Gosub SELTTN
    Endcase
  When "VERIF_CRE"     : Gosub VERIF_CRE
  When "VERIF_MOD"     : Gosub VERIF_MOD
Endcase

Return
######################################################################################
######################################################################################
$OUVRE

#-----------------------------------#
# Save global variables             #
#-----------------------------------#
Gosub SAUV_GLOB From TRTX3GLOB
Raz GGRPFCY
Raz GSOCIETE

If !clalev([F:TTN3]) : Local File TABTNHTYP [TTN3] : Endif
If !clalev([F:ANM])  : Local File ACODNUM   [ANM]  : Endif

Return
######################################################################################
######################################################################################
$VERIF_CRE

Gosub VERIF

Return
######################################################################################
######################################################################################
$VERIF_MOD

Gosub VERIF

Return
######################################################################################
######################################################################################
$VERIF

Case [M:TTN1]LEG
  When ""
    Read [F:TTN3]TTN0=[M:TTN1]TNHTYP;"POR"
    If !fstat
      If [M:TTN1]RECTYP <> [F:TTN3]RECTYP
        Call ECR_TRACE(func AFNC.MES2(mess(136,7711,1),[F:TTN3]TNHTYP,[F:TTN3]LEG),2) From GESECRAN
        OK = 0 : Return
      Endif
      If [M:TTN1]SAFTTRNTYP <> [F:TTN3]SAFTTRNTYP
        Call ECR_TRACE(func AFNC.MES2(mess(137,7711,1),[F:TTN3]TNHTYP,[F:TTN3]LEG),2) From GESECRAN
        OK = 0 : Return
      Endif
    Endif
  When "POR"
    Read [F:TTN3]TTN0=[M:TTN1]TNHTYP;""
    If !fstat
      If [M:TTN1]RECTYP <> [F:TTN3]RECTYP
        Call ECR_TRACE(func AFNC.MES2(mess(136,7711,1),[F:TTN3]TNHTYP,mess(59,151,1)),2) From GESECRAN
        OK = 0 : Return
      Endif
      If [M:TTN1]SAFTTRNTYP <> [F:TTN3]SAFTTRNTYP
        Call ECR_TRACE(func AFNC.MES2(mess(137,7711,1),[F:TTN3]TNHTYP,mess(59,151,1)),2) From GESECRAN
        OK = 0 : Return
      Endif
    Endif
Endcase

Return
######################################################################################
######################################################################################
$INICRE

Gosub MAJ_ATEXTRA

Return
######################################################################################
######################################################################################
$INIMOD

Gosub MAJ_ATEXTRA

Return
######################################################################################
######################################################################################
$MAJ_ATEXTRA

If GREP="D"
 Call DUPTEXTRA("TABTNHTYP","DESAXX",CLECUR1,"","TABTNHTYP","DESAXX",[F:TTN]TNHTYP,[F:TTN]LEG)  From ATEXTRA
 Call DUPTEXTRA("TABTNHTYP","SHOAXX",CLECUR1,"","TABTNHTYP","SHOAXX",[F:TTN]TNHTYP,[F:TTN]LEG)  From ATEXTRA
Endif

#--- Creation / Modif de ATEXTRA
Call MAJTEXTRA ([M:TTN1]DESAXX,"TABTNHTYP","DESAXX",[M:TTN1]TNHTYP,[M:TTN1]LEG) From ATEXTRA
Call MAJTEXTRA ([M:TTN1]SHOAXX,"TABTNHTYP","SHOAXX",[M:TTN1]TNHTYP,[M:TTN1]LEG) From ATEXTRA

Return
######################################################################################
######################################################################################
$AFFMASK

Call FMTLEG From TRTX3 : # Pour rendre invisible si nécessaire le champ "Législation"
Gosub GRILEG

Return
######################################################################################
######################################################################################
$RAZCRE

Gosub GRILEG

#RMA * 85785
If func AFNC.ACTIV("KPO") > 0
  Call SHOW_HIDE_TTN([M:TTN1]LEG) From PORLEGLIB
Endif

Return
######################################################################################
######################################################################################
$RAZDUP

#RMA * 85785
If func AFNC.ACTIV("KPO") > 0
  Call SHOW_HIDE_TTN([M:TTN1]LEG) From PORLEGLIB
Endif

Return
######################################################################################
######################################################################################
$LIENS

GCURLEG = [F:TTN]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
GGRPFCY = [F:TTN]GFY

#RMA * 85785
If func AFNC.ACTIV("KPO") > 0
  Call SHOW_HIDE_TTN([M:TTN1]LEG) From PORLEGLIB
Endif

# Issue X3-143 - 2016-10-03 by RICAR : 107966 - Change the field actions on RECTYP, SAFTTRNTYP and COMAT
# Issue X3-143
If func AFNC.ACTIV("KPO") > 0
  Gosub DISABLE_TTN_FIELDS From PORLEGLIB
Endif
# End issue X3-143

Return
######################################################################################
######################################################################################
$GRILEG

If func AFNC.ACTIV("LEG")=0 : # Mono-legislation folder
  Diszo [M:TTN1]LEG
  [M:TTN1]LEG=GDOSLEG(1)
  Affzo [M:TTN1]LEG : If dim([M:TTN1]ZLEG)>0  Affzo [TTN1]ZLEG : Endif
Endif

Return
######################################################################################
######################################################################################
$ANNULE

Delete [AXX]Where CODFIC="TABTNHTYP" & IDENT1=[F:TTN]TNHTYP & IDENT2=[F:TTN]LEG

Return
######################################################################################
######################################################################################
$SELTTN

If clalev([F:TTN])=0  : Local File TABTNHTYP  [TTN] : Endif

If clalev([F:FCY])=0  : Local File FACILITY   [FCY] : Endif
If clalev([F:CPY])=0  : Local File COMPANY    [CPY] : Endif
If clalev([F:FGR])=0  : Local File FACGROUP   [FGR] : Endif
If clalev([F:AXX])=0  : Local File ATEXTRA    [AXX] : Endif
If clalev([F:AMZZ])=0 : Local File AMSKZON   [AMZZ] : Endif :#--CPO 71937 Pour déterminer les options de sélection
If clalev([F:AGF])=0  : Local File AGRPFCY    [AGF] : Endif :#--CPO 71937

Local Char    FCY(GLONFCY)
Local Char    CPY(GLONCPY)
Local Char    LEG(GLONADI)
Local Char    GRP(GLONAGF)
Local Integer WNOL
Local Integer ERR
Local Char    SZVIEW(GLONAVW)

#--Selection options
If dim(OPTIONS)<0 : Local Char OPTIONS(30) Endif
Local Char CODMSK   (GLONAMK)
Local Char CHAMPCOD (GLONAVA)
CODMSK  =PARAM(6)
CHAMPCOD=PARAM(7)

OPTIONS=""
If CODMSK<>"" & CHAMPCOD<>""
  Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
  If fstat=0 : OPTIONS =[F:AMZZ]OPTOBJ : Endif
Endif

If GFONCTION = "GESTTN" Then
  OBJET = "TTN"
  Return
Endif

#--------------------------------------------------------------------------------------------------
# Identifying the parameters
#--------------------------------------------------------------------------------------------------
LEG  = PARAM(1)
FCY  = PARAM(2)
GRP  = PARAM(3)
CPY  = PARAM(4)

#--Init. of legislation
If func AFNC.ACTIV("LEG")=0
 [L]LEG = GDOSLEG
Endif

If [L]LEG=""
 If [L]FCY<>""
  Call LEC_FCY([L]FCY) From CPTLEC
  Call LEC_CPY([F:FCY]LEGCPY) From CPTLEC
  [L]LEG = [F:CPY]LEG
 Elsif [L]CPY<>""
  Call LEC_CPY([L]CPY) From CPTLEC
  [L]LEG = [F:CPY]LEG
 Endif
Endif

If [L]LEG=""
 [L]LEG = GCURLEG
Endif

START   = "[F:TTN]TNHTYP"
ORDRE   = "[F:TTN]TNHTYP;[F:TTN]LEG"
OBJET   = "TTN"
OPTIONS = "|"

#--------------------------------------------------------------------------------------------------
## Standard selection criteria
#--------------------------------------------------------------------------------------------------

CRITERE(1) = '1=1'
#--Groupe de soc/sites
If [L]FCY="" & [L]CPY="" & [L]GRP<>""
  #--If group it's a company
  Read [F:AGF]AGF0=[L]GRP
  If !fstat
    If [F:AGF]FLGLEG=2 : [L]CPY=[L]GRP : Endif
  Endif
  #--Le filtrage sur les groupes sites/sociétés sont fait dans le link directement
Endif
#--Facility
If    [L]FCY<>""
  CRITERE(1) -= '& ([F:TTN]GFY="" | ([F:TTN]GFY<>"" & [F:FGR]FCY="'+[L]FCY+'"))'
#--Company
#Elsif [L]CPY<>""
#  CRITERE(1) -= '& ([F:TTN]GFY="" | ([F:TTN]GFY<>"" & [F:TREC]LEGCPY="'+[L]CPY+'"))'
Endif
#--Legislation
If [L]LEG<>""
  CRITERE(2) -= '& ([F:TTN]LEG="'+[L]LEG+'" | [F:TTN]LEG="")'
Endif
#--First selection character
If dim(SELCAR)>0 & SELCAR<>0
  CRITERE(2) -= '& left$([F:TTN]TNHTYP,'+num$(SELCAR)+')>="'+left$(VALEUR,SELCAR)+'"'
Endif

ICRITERE = 3
Call FILROLE(OBJET,FILROLE) From SUBARL
If FILROLE<>"" & FILROLE<>"1=1"
 For I=0 To dim(FILROLE)-1
  Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",FILROLE(I),"&") From GOBJSUB
 Next I
Endif

# Options de sélection
If OPTIONS<>""
  Gosub OPTIONS From WOTTN
  ICRITERE=2
  For I=1 To NBCOND
   If instr(1,OPTIONS,OPT(I))
    Call ADDCRIT(CRITERE,ICRITERE,"CRITERE","("+CONDIT(I)+")","&") From GOBJSUB
   Endif
  Next I
Endif

DEFPAG = 1

Return
######################################################################################
######################################################################################
Subprog CONTTTN(COD,LEG,CODMSK,CHAMPCOD,FCY,GROUPE,CPY)
Variable Char    COD()
Value    Char    LEG()
Value    Char    CODMSK()
Value    Char    CHAMPCOD()
Value    Char    FCY
Value    Char    GROUPE
Value    Char    CPY


Local    Integer CAS
Local    Char    OPTIONS(30)

If GFONCTION = "GESTTN" | COD="" : End : Endif

If clalev([F:TTN]) =0 : Local File TABTNHTYP [TTN]  : Endif
If clalev([F:AMZZ])=0 : Local File AMSKZON   [AMZZ] : Endif :#--for the selection options of the object

If func AFNC.ACTIV("LEG")=0
  LEG = GDOSLEG
Endif

CAS = 1 : #--Legislation is empty

# No GCURLEG but we have CPY or FCY on-line
If clalev([F:CPY])=0  : Local File COMPANY    [CPY] : Endif
If clalev([F:FCY])=0  : Local File FACILITY   [FCY] : Endif
If [L]LEG="" and ([L]CPY<>"" | [L]FCY<>"")
  If [L]FCY<>""
    If [F:FCY]FCY<>[L]FCY
      Read [F:FCY]FCY0=[L]FCY
      If fstat : Raz [F:FCY] Endif
    Endif
    If [L]CPY="" : [L]CPY=[F:FCY]LEGCPY : Endif
  Endif
  If [L]CPY<>""
    If [F:CPY]CPY<>[L]CPY
      Read [F:CPY]CPY0=[L]CPY
      If fstat : Raz [F:CPY] Endif
    Endif
    [L]LEG=[F:CPY]LEG
  Endif
Endif

If LEG<>""
  Read [TTN]TTN0=COD;LEG
  If fstat
    Read [TTN]TTN0=COD;""
  Else
    CAS = 2 : #--Legislation isn't empty
  Endif
Else
  Read [TTN]TTN0(1)=COD
  If !fstat
    LEG = [F:TTN]LEG
    CAS = 2
  Endif
Endif

If fstat
  Filter [TTN] Where TNHTYP=[L]COD
  Look [TTN]TTN0 First
  If !fstat
    # "No existing record for the curent legislation"
    GMESSAGE = [L]COD-":"-mess(232,107,1)-"["+[L]LEG+"]"
  Else
    # "Record does not exist"
    GMESSAGE = [L]COD-":"-mess(23,100,1)
  Endif
  Filter [TTN]
  mkstat = 2 : End
Endif

#--Filter by company group
If [L]CPY<>"" and [L]FCY=""
  If [F:TTN]GFY<>""
    If clalev([F:AGF])=0 : Local File AGRPFCY    [AGF]  : Endif
    Read [AGF]AGF0=[F:TTN]GFY
    If !fstat
      If [F:AGF]FLGLEG=2
        #--Company
        If [F:TTN]GFY<>[L]CPY
          GMESSAGE += COD+"\"+mess(63,127,1)-":"-[F:TTN]GFY :
          mkstat = 2 : End
        Endif
      Elsif [F:AGF]FLGCPY=2
        If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
        Look [AGC]AGC0 = [F:TTN]GFY;[L]CPY
        If fstat
          GMESSAGE += COD+"\"+mess(63,127,1)-":"-[F:TTN]GFY :
          mkstat = 2 : End
        Endif
      Endif
    Endif
  Endif
Endif
#--

#--Coeherence control between tax group and legislation
If [F:TTN]GFY<>"" and LEG<>""
  Call CTLGFYLEG([F:TTN]GFY,LEG,"","") From TRTVENCTL
  If mkstat : End : Endif
Endif
#--Coeherence control between between group and return legislation
If GROUPE<>"" and [F:TTN]LEG<>""
  Call CTLGFYLEG(GROUPE,[F:TTN]LEG,"","") From TRTVENCTL
  If mkstat : End : Endif
Endif

#--Findig Object options defined on the data type of the field in the screen
OPTIONS=""
If CODMSK<>"" & CHAMPCOD<>""
  Read [F:AMZZ]CODE=CODMSK;CHAMPCOD
  If fstat=0 : OPTIONS=[F:AMZZ]OPTOBJ : Endif
Endif

If CAS=2
 Call CONTROLE("TTN",OPTIONS,LEG,COD,mkstat) From CONTOBJ
Else
 Call CONTROLE("TTN",OPTIONS,"",COD,mkstat) From CONTOBJ
Endif

End
######################################################################################
######################################################################################
Subprog TUNTTN(COD,LEG)
Variable Char    COD()
Value    Char    LEG()
Local Integer TOKILL

TOKILL = 0
If dim(VCOD)<1
  Global Char VCOD(GLONTTN)
  TOKILL = 1
Endif

# To update the TTN code after the tunnel order
VCOD = COD
If clalev([F:TTN])=0 : Local File TABTNHTYP [TTN] : Endif
If GNBLEG=1
  LEG = GDOSLEG
Elsif LEG="" & GCURLEG<>""
  LEG = GCURLEG
#--If LEG="" then firstly we search a TTN record with LEG="" secondly a TTN record with TTN<>""
Elsif LEG=""
  Read [TTN]TTN0 = VCOD;[L]LEG
  If fstat
    Read [TTN]TTN0(1)=VCOD
    If !fstat
      LEG = [F:TTN]LEG
    Endif
  Endif
Endif

Read [TTN]TTN0 = [L]COD;[L]LEG
If fstat : LEG = "" : Endif

Call OBJET("TTN",[L]LEG,VCOD) From GOBJET

COD = VCOD
If TOKILL : Kill VCOD : Endif

End
######################################################################################
######################################################################################
$FERME
#------------------------------------#
# Restore global variables           #
#------------------------------------#
Gosub REST_GLOB From TRTX3GLOB

# To manage the button Tunnel
If TUNNEL<>1 : Return : Endif
If dim(VCOD)<1 : Global Char VCOD(GLONTTN) : Endif

VCOD = CLE2

Return
######################################################################################
# Counter control
######################################################################################
$CTL_CODNUM

If [F:ANM]CODNUM <> VALEUR
   Read [ANM]ANM0 = VALEUR
   If fstat Raz [F:ANM] Endif
Endif

# Contrôle de la cohérence de la législation entre le type de livraison et le compteur
If [F:ANM]LEG<>"" & [F:ANM]LEG<>[M:TTN1]LEG
    GMESSAGE=mess(184,100,1)-VALEUR-mess(74,127,1)-"("
    If [M:TTN1]LEG<>""
      GMESSAGE+=[F:ANM]LEG-"<>"-[M:TTN1]LEG+")"
    Else
      GMESSAGE+=[F:ANM]LEG-"<>"-mess(91,187,1)+")"
    Endif
    mkstat=1 : End
Endif


If sum([F:ANM]POSLNG(0..dim([F:ANM]POSLNG)-1)) > GLONVCR
   GERR=1
   GMESSAGE = mess(223,199,1)
   mkstat = 1
Endif

Return
######################################################################################
######################################################################################
## Section automatically added (screen TTN1) 22-10-2014 11:10:47 (RMA)
######################################################################################
Subprog C_LEG(VALEUR)
Variable Char    VALEUR()

GCURLEG = VALEUR

#Issue X3-82950 - 2018-03-20 by VAVIL : 122007 - Sequence number control
If func AFNC.ACTIV("KPO")>0 & find(VALEUR,"POR","")
  Local Char WMESS(100) : WMESS = ""
  Call CTL_CODNUM_LEG(VALEUR,[M:TTN1]TNHTYP,"TTN",WMESS)    From PORLEGLIB
  If WMESS <> "" : GMESSAGE = WMESS : mkstat = 2 : Endif
Endif
# Issue End

End
######################################################################################
Subprog C_GFY(VALEUR)
Variable Char    VALEUR()

GGRPFCY = VALEUR

End
######################################################################################
Subprog AM_GFY(VALEUR)
Variable Char    VALEUR()

GGRPFCY = VALEUR

End
######################################################################################
Subprog C_CODNUM(VALEUR)
Variable Char    VALEUR()
#Issue X3-82950 - 2018-03-20 by VAVIL : 122007 - Sequence number control
If VALEUR<>''
  If func AFNC.ACTIV("KPO")>0 & find([M:TTN1]LEG,"POR","")
    Local Char WMESS(100) : WMESS = ""
    If find(VALEUR,[M:TTN1]CODNUMEND) : GMESSAGE = mess(142,7711,1) : mkstat = 2 : End : Endif
    Call CTL_CODNUM_NORMAL(VALEUR,[M:TTN1]LEG,[M:TTN1]TNHTYP,"TTN",WMESS) From PORLEGLIB
    If WMESS <> "" : GMESSAGE = WMESS : mkstat = 2 : Endif
  Endif
Endif
# Issue End

Gosub CTL_CODNUM

End
######################################################################################
Subprog C_CODNUMEND(VALEUR)
Variable Char    VALEUR()
#Issue X3-82950 - 2018-03-20 by VAVIL : 122007 - Sequence number control
If VALEUR<>''
  If find([M:TTN1]LEG,"POR","")
    Local Char WMESS(100) : WMESS = ""
    If find(VALEUR,[M:TTN1]CODNUM,[M:TTN1]CODNUMEND) : GMESSAGE = mess(142,7711,1) : mkstat = 2 : End : Endif
    Call CTL_CODNUM_FINAL(VALEUR,[M:TTN1]LEG,[M:TTN1]TNHTYP,"TTN",WMESS) From PORLEGLIB
    If WMESS <> "" : GMESSAGE = WMESS : mkstat = 2 : Endif
  Endif
Endif
# Issue End

Gosub CTL_CODNUM

End
