$_GET_RES_STRING
Local Char RES(250)
Case _LAN
 When "FRA":
  Case _ID
   When 446: RES='Compteurs document'
   When 771: RES='Compteur'
   When 4159: RES='Opérateur modification'
   When 1320: RES='Opérateur création'
  Endcase
 When "ENG":
  Case _ID
   When 446: RES='Doc sequence numbers'
   When 771: RES='Sequence number'
   When 4159: RES='Change user'
   When 1320: RES='Creation user'
  Endcase
 When "ITA":
  Case _ID
   When 446: RES='Contatore documento'
   When 771: RES='Contatore'
   When 4159: RES='Utente modifica'
   When 1320: RES='Utente creazione'
  Endcase
 When "POR":
  Case _ID
   When 446: RES='Contadores documentos'
   When 771: RES='Contador'
   When 4159: RES='Modificação operador'
   When 1320: RES='Operador criação'
  Endcase
 When "SPA":
  Case _ID
   When 446: RES='Contadores documento'
   When 771: RES='Contador'
   When 4159: RES='Operador modificación'
   When 1320: RES='Operador creación'
  Endcase
 When "BRI":
  Case _ID
   When 446: RES='Sequence Numbers'
   When 771: RES='Seq counter'
   When 4159: RES='Change User'
   When 1320: RES='Creation User'
  Endcase
 When "GER":
  Case _ID
   When 446: RES='Nummern Dokument'
   When 771: RES='Nummernkreis'
