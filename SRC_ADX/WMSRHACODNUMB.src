   When 446: RES='文件序列号'
   When 771: RES='序列号'
   When 4159: RES='修改用户'
   When 1320: RES='创建用户'
  Endcase
 When "ARB":
  Case _ID
   When 446: RES='أرقام تسلسل الوثائق'
   When 771: RES='الرقم التسلسلي '
   When 4159: RES='تغيير المستخدم'
   When 1320: RES='إنشاء المستخدم'
  Endcase
Endcase
Return
