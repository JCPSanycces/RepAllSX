#<AdxTL>@(#)2.0.0.0 $Revision$
####################################################################################
# Program Name: VXASELTRS
# Description : ADC Transaction Selections
# Author      : 
# Date        : February 8th, 2006
####################################################################################

$ACTION

Case ACTION
  When "SEL_TABLE"    : Gosub SEL_TABLE
Endcase

Return

############################################################
$SEL_TABLE

Case TABLE
    When "VXASTKTRS"    : Gosub VXASTKTRS 
    When "VXAPURTRS"    : Gosub VXAPURTRS
    When "VXAMFGTRS"    : Gosub VXAMFGTRS
Endcase

Return

#############################################################
$VXASTKTRS

Local Integer TRNTYP

If clalev([F:SRT]) =0 : Local File STKTRS   [SRT] : Endif
If clalev([F:AXX]) =0 : Local File ATEXTRA  [AXX] : Endif

Link [SRT] With
& [AXX]AXX0="STKTRS";"DESAXX";GLANGUE;[F:SRT]SRTTYPCAR;[F:SRT]SRTNUM
& As [SRT_]

Default File [SRT_]

TRNTYP = val(PARAM(1))

CRITERE = 'SRTTYP=TRNTYP&ENAFLG=2'

#MAE, 07/08/08, impression des étiquettes autorisée en VT
#When 1 : CRITERE+="&SPOTFLG<>2&SPERFLG<>2&PRNCOD1<>2&SRUB1FLG<>2&SRUB2FLG<>2&SRUB3FLG<>2&SRUB4FLG<>2"
# hcb 60191 (SPERFLG supprimé)
# when 3 VXASC AIT AST prncod <> 2 supprimé   #--- Lot V01
Case TRNTYP
 When 1 : CRITERE+="&SPOTFLG<>2&SRUB1FLG<>2&SRUB2FLG<>2&SRUB3FLG<>2&SRUB4FLG<>2"
 When 2 : CRITERE+="&STKFLG<>2" 
 When 3 : Case GFONC1
           When "VXASC","VXBSC" : CRITERE+="&BETFCYCOD=1&BETFCYCOD=1&CHGPCUCOD<>2"
           When "VXAIT","VXBIT" : CRITERE+="&BETFCYCOD=2&BETFCYCOD=2" 
           When "VXAST","VXBST" : CRITERE+="&BETFCYCOD=4&BETFCYCOD=4"
          Endcase
 When 5 : CRITERE+="&SPERFLG<>2&SPOTFLG<>2&SRUB1FLG<>2&SRUB2FLG<>2&SRUB3FLG<>2&SRUB4FLG<>2"
 When 9 : CRITERE+="&STKFLG<>2"                                                #  hcb 93103


Endcase

TIT(0) = mess(3,126,1) # "Transaction Selection"

NBCOL = 0

NBCOL += 1 : COL(NBCOL) = "SRTNUM"
Call TEXTFIC("STKTRS","SRTNUM",2,TIT(NBCOL)) From OBJDIV  
NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"
Call TEXTFIC("STKTRS","DESAXX",2,TIT(NBCOL)) From OBJDIV  

Return


#############################################################
$VXAPURTRS

Local Integer TRNTYP

If clalev([F:PTR])=0 : Local File PURTRS  [PTR] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif
# hcb 60322 num$

Link [PTR] With
& [AXX]AXX0="PURTRS";"DESAXX";GLANGUE;num$([F:PTR]PTRTYP);[F:PTR]PTRNUM
& As [PTR_]

Default File [PTR_]

TRNTYP = val(PARAM(1))

CRITERE = 'PTRTYP=TRNTYP&ENAFLG=2'

#TEST MAE When 6 : CRITERE+="&SPOTFLG<>2&SPERFLG<>2&SRUB1FLG<>2&SRUB2FLG<>2&SRUB3FLG<>2&SRUB4FLG<>2&PRNCOD1<>2&DOCFLG=1"
# hcb 60191 (SPERFLG supprimé)
# When 6 : CRITERE+="&SPOTFLG<>2&SRUB1FLG<>2&SRUB2FLG<>2&SRUB3FLG<>2&SRUB4FLG<>2&DOCFLG=1"   #--- Lot V01

Case TRNTYP
 When 6 : CRITERE+="&SPOTFLG<>2&SRUB1FLG<>2&SRUB2FLG<>2&SRUB3FLG<>2&SRUB4FLG<>2"
Endcase

TIT(0) = mess(3,126,1) # "Transaction Selection"

NBCOL = 0
NBCOL += 1 : COL(NBCOL) = "PTRNUM"
Call TEXTFIC("PURTRS","PTRNUM",2,TIT(NBCOL)) From OBJDIV  
NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"
Call TEXTFIC("PURTRS","DESAXX",2,TIT(NBCOL)) From OBJDIV  

Return


#############################################################
$VXAMFGTRS
Local Integer TRNTYP
If clalev([F:BTS]) =0 : Local File BENCHTRS [BTS] : Endif
If clalev([F:AXX]) =0 : Local File ATEXTRA  [AXX] : Endif
# hcb 60322 num$
Link [BTS] With
& [AXX]AXX0="BENCHTRS";"DESAXX";GLANGUE;num$([F:BTS]BTSTYP);[F:BTS]BTSNUM
& As [BTS_]

Default File [BTS_]

TRNTYP = val(PARAM(1))

CRITERE   = 'BTSTYP=TRNTYP&ENAFLG=2'
#MAE, impression étiquette autorisée en mode VT
#When 62 :  CRITERE+="&SPOTFLG<>2&SPERFLG<>2&PRNCOD1<>2&SRUB1FLG<>2&SRUB2FLG<>2&SRUB3FLG<>2&SRUB4FLG<>2"
# hcb 60322 (SPERFLG supprimé)

Case TRNTYP 
    When 60 :  CRITERE += "&OPEUOMMOD<>2"
    When 61 :  CRITERE += "&STKFLG<>2" 
    When 62 :  CRITERE += "&SPOTFLG<>2&SRUB1FLG<>2&SRUB2FLG<>2&SRUB3FLG<>2&SRUB4FLG<>2"
Endcase

TIT(0) = mess(3,126,1) # "Transaction Selection"

NBCOL = 0
NBCOL += 1 : COL(NBCOL) = "BTSNUM"
Call TEXTFIC("MFGTRS","BTSNUM",2,TIT(NBCOL)) From OBJDIV  
NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"
Call TEXTFIC("MFGTRS","DESAXX",2,TIT(NBCOL)) From OBJDIV  

Return


