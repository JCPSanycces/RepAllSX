#<AdxTL>@(#)10.0.0.0 $Revision$
#------------#
# Pour tests #
#------------#
If !clalev([PYH])  Local File PAYMENTH [PYH] : Endif

Local Char    WMSG(250)
Local Char    COD_OBJ(GLONAOB)
Local Char    CLE_LEC(GLONPAY)
Local Char    CHAMPS_LUS(50)(1..10)
Local Blbfile BLOB_LUS(1)
#-----
COD_OBJ="PAY"
CLE_LEC="AF320000000000000154"
Call LECTURE(COD_OBJ,CLE_LEC,CHAMPS_LUS,BLOB_LUS) From WMNETCPT1
# ici on récupère dans CHAMPS_LUS les valeurs des champs paramétrés dans le bloc "Champs Liste" pour l'enregistrement CLE_LEC
End


#############################################
$ACTION
Case ACTION
 When "DESC_LISTE" : Gosub DESC_LISTE
 When "DESC_LEC"   : Gosub DESC_LEC
 When "LISTE"      : Gosub LISTE
 When "LECTURE"    : Gosub LECTURE
 When "RAFRAICHIR" : Gosub RAFRAICHIR
Endcase
Return
#############################################


# Sous-programme de description du web service de liste
$DESC_LISTE
Return


# Sous-programme de description du web service de lecture
$DESC_LEC
Return


# Sous-programme de liste
# ici on récupère un tableau contenant un enregistrement par ligne, un champ par colonne
# voir dans le traitement WMNETCPT1 les variables à utiliser
$LISTE
# calcul de FLD_1 pour la liste
For NBL=1 To NB_LIG
 # CHP3(NBL) : [F:PYH]NUM
 # CHP9(NBL) : [F:PYH]SNS
 # CHP10(NBL) : [F:PYH]AMTCUR
 Read [PYH]PYH0=CHP3(NBL)
 CHP8(NBL)  = num$(val(string$([F:PYH]SNS=2, num$([F:PYH]AMTCUR)))+val(string$([F:PYH]SNS=1, num$(-1*[F:PYH]AMTCUR))))
Next
Return


# Sous-programme de lecture détail
$LECTURE
Return


# Sous-programme de rafraichissement favoris
$RAFRAICHIR
For NBL=1 To NB_LIG
 Read [PYH]PYH0=CHP3(NBL)
 If fstat=0
  CHP8(NBL)  = num$(val(string$([F:PYH]SNS=2, num$([F:PYH]AMTCUR)))+val(string$([F:PYH]SNS=1, num$(-1*[F:PYH]AMTCUR))))
 Endif
Next
Return
