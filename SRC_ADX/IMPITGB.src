#############################################################
# Pour court-circuiter ces sous-programme des traitements   #
# W0ITG4 et W0ITG8 selon le type de règle de gestion (E/S)  #
# Appeler dans IMP_DEFTRT depuis IMPITG                     #
#############################################################

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT
End

Subprog SAI_NBLOC(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT
If [M]NBLOC>0 
   If status=72
      Dela nolign-1,1,[M]NBLOC NBLOC 
      [M]NBLOC-=1
   Elsif status=73
      [M]NBLOC-=1
   Endif
Endif
End

Subprog SAI_NBENT(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT
If [M]NBENT>0
   If status=72
      Dela nolign-1,1,[M]NBENT NBENT 
      [M]NBENT-=1
   Elsif status=73
      [M]NBENT-=1
   Endif
Endif
End

