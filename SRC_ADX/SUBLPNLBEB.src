#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# RELOADLPN   : Remplissage du tableau ecran LPB1
###############################################################################
Subprog RELOADLPN

If  ([M:LPB0]MONITMFLG1 = 1 & [M:LPB0]MONITMFLG2 = 1) | ([M:LPB0]MONLOTFLG1 = 1 & [M:LPB0]MONLOTFLG2 = 1) |
&   ([M:LPB0]LPNSTAT1   = 1 & [M:LPB0]LPNSTAT2   = 1) | ([M:LPB0]PRTFLG1    = 1 & [M:LPB0]PRTFLG2    = 1)
  Call ERREUR(mess(553,184,1)) From GESECRAN
  End
Endif
Local Char ETAT, ETAT2
Local Integer LSTJFLG # Indique si le filtre est fait sur STOJOU ou sur le Link
Local Char    LCRIT(250)
Local Char    LETAT, LPRN
nolign = 0
Effzo [M:LPB1]
Local Char FILSUP(250)
Local Char SELFOR(250)
FILSUP = "1=1"
SELFOR = "1=1"
LCRIT  = "1=1"
GPOINT="BEFFILLPB1"
Gosub  ENTREE From EXEFNC
#                                                   selections ecran LPB0
LCRIT = "STOFCY=[M:LPB0]STOFCY"
If [M:LPB0]TCTRNUMEND <> ""
   LCRIT  += "&TCTRNUM>=[M:LPB0]TCTRNUMSTR"
   LCRIT  += "&TCTRNUM<=[M:LPB0]TCTRNUMEND"
Endif
If [M:LPB0]LPNNUMEND <> ""
   LCRIT  += "&LPNNUM>=[M:LPB0]LPNNUMSTR"
   LCRIT  += "&LPNNUM<=[M:LPB0]LPNNUMEND"
Endif
If [M:LPB0]LOCEND <> ""
   LCRIT  += "&LOC>=[M:LPB0]LOCSTR"
   LCRIT  += "&LOC<=[M:LPB0]LOCEND"
Endif
#                                                   selections ecran LPBR  (critères)
If [M:LPB0]LOCTYPEND <> ""
   LCRIT  += "&LOCTYP>=[M:LPB0]LOCTYPSTR"
   LCRIT  += "&LOCTYP<=[M:LPB0]LOCTYPEND"
Endif
If dim([M:LPB0]WRH) > 0 & [M:LPB0]WRH <> ""
   LCRIT  += "&WRH= [M:LPB0]WRH"
Endif
If [M:LPB0]MONITMFLG1 <> [M:LPB0]MONITMFLG2
   If [M:LPB0]MONITMFLG1 = 2
      LCRIT  += "&MONITMFLG=2"
   Else
      LCRIT  += "&MONITMFLG<2"
   Endif
Endif
If [M:LPB0]MONLOTFLG1 <> [M:LPB0]MONLOTFLG2
   If [M:LPB0]MONLOTFLG1 = 2
      LCRIT  += "&MONLOTFLG=2"
   Else
      LCRIT  += "&MONLOTFLG< 2"
   Endif
Endif
If  [M:LPB0]LPNSTAT1 <>  [M:LPB0]LPNSTAT2
    If [M:LPB0]LPNSTAT1 = 2
       LCRIT  += "&LPNSTAT< 2"
    Else
       LCRIT  += "&LPNSTAT= 2"
    Endif
Endif
If  [M:LPB0]PRTFLG1 <>  [M:LPB0]PRTFLG2
    If [M:LPB0]PRTFLG1 = 2
       LCRIT  += "&PRTFLG< 2"
    Else
       LCRIT  += "&PRTFLG= 2"
    Endif
Endif

#                                                   selections formule
If [M:LPB0]SELFOR <> ""
   Read [TFO]TFO0=57;[M:LPB0]SELFOR
   If fstat = 0
      SELFOR = [F:TFO]FORFOR
   Endif
Endif

Filter [F:LPN] Where evalue(LCRIT) & evalue(SELFOR) & evalue(FILSUP)
&      Order By Key LPN0
For [LPN]
    If [F:TCTR]TCTRNUM <> [F:LPN]TCTRNUM
       Read [F:TCTR]TCTR0 = [F:LPN]TCTRNUM
       If fstat : Raz [F:TCTR] : Endif
    Endif
    If nolign = dim([M:LPB1]LBENBR) : Break : Endif
    nolign  += 1
    [M:LPB1]                      = [F:LPN]
    [M:LPB1]TRT       (nolign-1) = 1+!([F:LPN]PRTFLG=2)
    [M:LPB1]LBEFMT    (nolign-1) = [F:TCTR]LBEFMT
    [M:LPB1]LBENBR    (nolign-1) = 1
    If [M:LPB1]LBEFMT (nolign-1) <> ""
       Call AM_LBEFMT([M:LPB1]LBEFMT(nolign-1)) From SUBLPNLBE
    Endif
    GPOINT="ALISCRLPB1"
    Gosub  ENTREE From EXEFNC
Next
Filter [LPN]
[M:LPB1]NBLIG = nolign
Affzo [M:LPB1]
End


###############################################################################
# PRINTLPN    : Impression etiquette contenant
###############################################################################
Subprog PRINTLPN(PRET)
Variable Integer PRET
Raz PRET
Local Integer I
Local Integer J
Local Integer WNB, WNUMLIG
Raz I
Raz J
Local Char WPRT(GLONAIM) , WLBEFMT(GLONARP)

   #-- Recherche sur le tableau de la première ligne qui ne convient pas
   #-- Si on trouve une ligne et que I=0 on sort du sigma
    I = sigma(0,[M:LPB1]NBLIG-1, (indcum+1)*(([M:LPB1]TRT(indcum)=2)
&          & (([M:LPB1]LBEFMT(indcum)="") | ([M:LPB1]PRT(indcum)=""&[M:LPB1]DEFIMP(indcum)=""))
&          & I=0 & sigma(I=1,1,1)))
    If I>0
        Call ERREUR(mess(48,184,1)-num$(I)-"("+mess(222,200,1)+","+mess(41,197,1)+","+mess(16,135,1)+")") From GESECRAN
        PRET = 1
        End
    Endif

# Tri du tableau selon imprimante,format
Sorta [M:LPB1]NBLIG [M:LPB1]NBLIG
&     Order By [M:LPB1]PRT(indice),[M:LPB1]LBEFMT(indice),[M:LPB1]LPNNUM(indice)
Raz  WNB, WNUMLIG,WPRT,WLBEFMT
Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
For I = 0 To [M:LPB1]NBLIG-1
    Raz TBPAR, TBVAL
    If [M:LPB1]TRT(I)=2 & [M:LPB1]LBENBR(I)<>0 & [M:LPB1]LBEFMT(I)<>"" & [M:LPB1]PRT(I)<>""
       If [M:LPB1]PRT(I) <> WPRT  |  [M:LPB1]LBEFMT(I) <> WLBEFMT
          If WPRT <> "" & WNB > 0
             Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
             Raz GBIDI1    # Sinon ça plante quand on vient d'un document !!!!
             TBPAR(1) = "usr"
             TBVAL(1) = GUSER
             TBPAR(2) = "etat"
             TBVAL(2) = WLBEFMT
             TBPAR(3) = "numedt"
             TBVAL(3) = num$(GWNUMREQ)
             TBPAR(4) = "impselections"
             TBVAL(4) = "1"
             Call ETAT(WLBEFMT,WPRT,GLANGUE,0,"",TBPAR,TBVAL) From AIMP3
          Endif
          GWNUMREQ = uniqid([LBP])
          WLBEFMT  = [M:LPB1]LBEFMT(I)
          WPRT     = [M:LPB1]PRT   (I)
          Raz WNB,WNUMLIG
       Endif
       Read [LPN]LPN0=[M:LPB1]LPNNUM(I)
       If !fstat
          [F:LPN]PRTFLG = 2
          Rewrite [LPN]
       Endif
       For J = 1 To [M:LPB1]LBENBR (I)
           Call  REMPLBP([M:LPB1]LPNNUM(I),GWNUMREQ,J+WNUMLIG,[M:LPB1]LBEFMT(I),0,PRET) From STKLPN
           If PRET = 0
              GOK  = 0
              Break 2
           Endif
           WNB +=1
           WNUMLIG = [F:LBP]NUMLIG
       Next J
    Endif
Next I
If WNB > 0
   Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
   Raz GBIDI1    # Sinon ça plante quand on vient d'un document !!!!
   TBPAR(1) = "usr"
   TBVAL(1) = GUSER
   TBPAR(2) = "etat"
   TBVAL(2) = WLBEFMT
   TBPAR(3) = "numedt"
   TBVAL(3) = num$(GWNUMREQ)
   TBPAR(4) = "impselections"
   TBVAL(4) = "1"
   Call ETAT(WLBEFMT,WPRT,GLANGUE,0,"",TBPAR,TBVAL) From AIMP3
Endif

End

