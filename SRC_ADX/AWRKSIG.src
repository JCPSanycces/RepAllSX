#<AdxTL>@(#)1.0.0.0 $Revision$
Local Char PARAM(250)(1..6) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","AWRKSIG","",1,"") From GTRAITE
End

#-----------------------------------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "EXEC"        : Gosub EXEC
Endcase
Return

#---------------------------#
$INIT
Local Char    RACINE(GDIMFIC) , REPERT(GDIMFIC) , FICHIER(GDIMFIC)
Local Char    FORMULE(255) , LIGNE(250) , CHAINE(250)
Local Char    CHRONO(GLONVCR) , NEWACT(GLONADI)
Local Char    PARWRK(250)(1..6) , VALWRK(10) , SPEWRK(GLONADC)
Local Integer K , STAT , ERN
Local Char    ERM(250)
Local Char    ORDSYS(250) , CMD(250) , DIR(250)

If clalev([F:AWG])=0  : Local File AWRKHISMES [AWG]  : Endif
If clalev([F:AWO])=0  : Local File AWRKHISDES [AWO]  : Endif
If clalev([F:AWJ])=0  : Local File AWRKHISJOI [AWJ]  : Endif
If clalev([F:AWS2])=0 : Local File AWRKHISSUI [AWS2] : Endif
If clalev([F:AWF])=0  : Local File AWRKPARF   [AWF]  : Endif

Local Shortint DIMKEY
DIMKEY = type([F:AWO]LNKHTP)-10
Local Char     LNKKEY(DIMKEY)

Return

#---------------------------#
$EXEC
If !GSERVEUR
 Call OUVRE_TRACE(mess(77,75,1)) From LECFIC : # Traitements des signatures distantes
Endif

# Traitement des signatures distantes par lien HTTP
Gosub TRT_LIEN_HTTP

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
TRA  = 1
Return

#-----------------------------------------------------------------------------#
$TRT_LIEN_HTTP
Local Char MACSRV(GLONAMC)
If GWRKRMTMAC="" & adxmac(0)<>""
 MACSRV=adxmac(0)
Else
 MACSRV=GWRKRMTMAC
Endif

# Chemin serveur
RACINE = vireblc(GWRKRMTDIR,2)
K = instr(1,RACINE,"]")
If K
 ERN = func ASYRSTO.CTL_VOLFIL(2,RACINE,CHAINE,0,ERM)
 If ERN<>0
  STAT = 1 : Goto ERREUR
 Else
  RACINE = CHAINE
 Endif
Elsif RACINE="" # 115785 CCL AWRKSIG create a directory on c:\
 ERM = "|"+"GWRKRMTDIR :"- mess(141,105,1) : #  Paramètre non défini
 STAT = 1 : Goto ERREUR
Endif

# Répertoire des fichiers liens actions
Onerrgo ERRFIC
REPERT = RACINE+"/"+GINSTID+nomap
FICHIER = filpath("","","","","",MACSRV)
If ERN
 ERM = "|"+MACSRV-":"-mess(199,100,1) : # Machine inaccessible
Else
 FICHIER = filpath(REPERT,"","","","",MACSRV)
 If ERN
  ERM = "|"+REPERT-":"-mess(147,141,1) : # Répertoire inaccessible
 Else
  K = filinfo(FICHIER,0)
 Endif
Endif
Onerrgo
If ERN
 STAT = 1 : Goto ERREUR
Elsif K<0
 # mb 28.1.13 Try to create directory
 K = instr(1,FICHIER,"@")
 If K
  ORDSYS = left$(FICHIER,K)
  DIR = right$(FICHIER,K+1)
 Else
  ORDSYS = ""
  DIR = FICHIER
 Endif
 ORDSYS += 'ae_mkdir'-'"'+DIR+'"'
 System CMD=ORDSYS
 K = filinfo(FICHIER,0)
 If K<0
  ERM = "|"+FICHIER-":"-mess(86,133,1) : # Répertoire inexistant
  STAT = 1 : Goto WARNING
 Endif
Endif

Local File (HLP(30)) From System MACSRV+'@lsadx -t "'+REPERT+'" lka' As [HLP_]

For [HLP_] Where HLP<>""
 FICHIER = filpath(REPERT,HLP,"lka","","",MACSRV)
 Onerrgo ERRFIC
 Openi FICHIER Using [FIC_]
 Onerrgo
 If !ERN
  Iomode adxirs chr$(10) Using [FIC_]
  Iomode adxifs ''       Using [FIC_]
  Iomode adxium GUTF8    Using [FIC_]
  LNKKEY = ""
  Rdseq LIGNE Using [FIC_]
  While LIGNE<>""
   If left$(LIGNE,2)="K="
    LNKKEY = right$(LIGNE,3)
    Break
   Endif
   Rdseq LIGNE Using [FIC_]
  Wend
  Openi Using [FIC_]
  Gosub TRT_ACT
  If OK>=0 | STAT : # Si l'erreur vient d'un verrou, le fichier n'est pas effacé
   Call EFFACE(FICHIER,STAT) From ORDSYS
   If filinfo(FICHIER,0)>0
    Call ECR_TRACE(mess(1,115,1)-"\|"-FICHIER,1) From GESECRAN : # Suppression impossible
   Endif
  Endif
 Endif
Next HLP_
Return

#---------------------------#
$TRT_ACT

STAT = 0 : # Status erreur

# Traitement fichier lien
Call ECR_TRACE("***"-format$("D:",date$)-time$-mess(41,75,1)-"\|"+FICHIER,0) From GESECRAN

K = instr(1,[F:HLP_]HLP,"-")
CHRONO = left$([F:HLP_]HLP,K-1)
NEWACT = right$([F:HLP_]HLP,K+1)
Call ECR_TRACE(mess(77,105,1)-":"-CHRONO-","-mess(27,115,1)-NEWACT,0) From GESECRAN : # Chrono , Action

OK = 0
Read [AWO]AWO1(1) = LNKKEY
If fstat
 ERM = mess(88,75,1)-'"'+LNKKEY+'"'-':'-mess(45,105,1) : # Lien http : Lien impossible
 STAT = 1 : Goto ERREUR
Elsif [F:AWO]USER="" & [F:AWO]EMAIL=""
 ERM = mess(141,100,1) : # Code utilisateur inexistant
 STAT = 1 : Goto ERREUR
Endif

If [F:AWO]USER=""
 Read [AWS2]AWS3 = CHRONO;[F:AWO]EMAIL
 If fstat : ERM = CHRONO-[F:AWO]EMAIL-"AWRKHISSUI" : Endif
Else
 Read [AWS2]AWS0 = CHRONO;[F:AWO]USER
 If fstat : ERM = CHRONO-[F:AWO]USER-"AWRKHISSUI" : Endif
Endif
If fstat
 ERM -= ":"-mess(45,105,1) : # Lien impossible
 STAT = 1 : Goto ERREUR
Endif

Read [AWF]AWF0 = [F:AWS2]CODWRK
If fstat
 ERM = [F:AWS2]CODWRK-":"-mess(107,75,1) : # Paramètrage workflow inexistant
 STAT = 1 : Goto ERREUR
Endif

If NEWACT="" | !find(NEWACT,[F:AWF]ACTSIG)
 ERM = NEWACT-":"-mess(76,75,1) : # Opération de signature inexistante
 STAT = 1 : Goto ERREUR
Endif

# A utiliser dans le texte du workflow
If GSERVEUR
 GUSER    = [F:AWS2]DEST
 GNOMUSER = [F:AWS2]EMAIL
Endif

PARWRK(1) = [F:AWS2]CHRONO
PARWRK(2) = [F:AWS2]DEST
PARWRK(3) = [F:AWS2]DEST
PARWRK(4) = [F:AWS2]EMAIL
PARWRK(5) = NEWACT
PARWRK(6) = "-1"
Call TRTSPE(nomap,"SIGWRK",SPEWRK) From SUBACT
Call TRAITE_CHAR(VALWRK,PARWRK,"","SAIWRKSIG","",5,SPEWRK) From GTRAITE : # Signature
OK = val(PARWRK(6))

If OK=1
 ERM = CHRONO-":"-mess(89,75,1) : # Chrono signé correctement par
 If PARWRK(3)=""
  ERM -= PARWRK(4)
 Else
  ERM -= PARWRK(3)
 Endif
Else
 ERM = mess(90,75,1)-CHRONO : # Erreur pendant la signature du chrono
Endif
Call ECR_TRACE(ERM,OK<>1) From GESECRAN
Return

#----------------------------------------------------------------------------------#
$ERRFIC
ERN = errn
ERM = "|"+errp-"("+num$(errl)+")"-mess(6,123,1)-num$(ERN)-":"-errmes$(abs(ERN))-errm

#---------------------------#
$TRACE
Call ECR_TRACE(ERM,ERN) From GESECRAN
Resume

#----------------------------------------------------------------------------------#
$WARNING
Call ECR_TRACE(ERM,-1) From GESECRAN
Return

#----------------------------------------------------------------------------------#
$ERREUR
ERM += "\"+mess(125,75,1)-CHRONO : # Erreur fichier signature. Chrono non signé
Call ECR_TRACE(ERM,STAT) From GESECRAN
Return

