#<AdxTL>@(#)7.0.0.0 $Revision$
###############################################################################
# LOAD_FROM_SGW : Charge l'écran STOCHG [SQD] à partir de STOCHGW [SGW]       #
###############################################################################
$LOAD_FROM_SGW


Local Integer Z            # hcb unicite
Local Integer WCHARGE      # hcb unicite
Local Char    LSLO(GLONSLO) # hcb 90366

#                                                          # hcb 110327 deb
Local Char LMSKCOU
LMSKCOU = func STKLIB.MSKDEF
If LMSKCOU = "[CHGS]"
   [M:SQD]WSTOSEQ = [M:CHGS]WSTOSEQ
Else
   [M:SQD]WSTOSEQ = evalue(LMABR+"WSTOSEQ(LLIGDOC)")
Endif
#                                                          # hcb 110327 end
I = find([M:SQD]WSTOSEQ, [M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1))-1
# S'il n'y a encore rien dans STOCHGW, et qu'il n'y a pas de n° de série
# il faut récupérer le STOCOU. S'il y a des n° de série, le stocou est calculé dans FILLSTOCHGW
# Dans le cas de SCS, STOCHGW existe dès le picking
If I<0
    If LMSKCOU <> "[CHGS]"                                                      # hcb 110327
       If (dim([M:SQD]SERNUMDEP)<=0 | [M:SQD]SERNUMDEP="")
          [M:SQD]WSTOCOU([M:SQD]NBCOU)  = evalue(LMABR+"WSTOCOU(LLIGDOC)")
          [M:SQD]NBCOU+=1
       Endif
    Endif                                                                       # hcb 110327
Else
    While I<[M:SGW]NBLIG & [M:SQD]WSTOSEQ=[M:SGW]WSTOSEQ(I)
        If I>0 & [M:SQD]WSTOSEQ=[M:SGW]WSTOSEQ(I-1) & [M:SGW]WLIGDET(I-1)=[M:SGW]WLIGDET(I) & [M:SGW]WSTOSEQIND(I) = 0   # hcb 110327
            If dim([M:SQD]SERNUMF)>0
                [M:SQD]SERNUMF([M:SQD]NBLIG)   = [M:SGW]WSERNUMF(I)
            Endif
            [M:SQD]QTYPCUDES([M:SQD]NBLIG) += [M:SGW]WQTYPCUDES(I)
            [M:SQD]QTYSTUDES([M:SQD]NBLIG) += [M:SGW]WQTYSTUDES(I)
        Else
            [M:SQD]PCUDES([M:SQD]NBLIG)    = [M:SGW]WPCUDES(I)
            [M:SQD]QTYPCUDES([M:SQD]NBLIG) = [M:SGW]WQTYPCUDES(I)
            [M:SQD]COEDES([M:SQD]NBLIG)    = [M:SGW]WCOEDES(I)
            Actzo [M:SQD]PCUDES([M:SQD]NBLIG),QTYPCUDES([M:SQD]NBLIG),COEDES([M:SQD]NBLIG)
            Local Char LUSCAV
            Local Char LFMT
            Local Integer LMODIF
            Local Decimal LCOE
            Call CTLUOM([M:SQD]ITMREF,3,"",[M:SQD]PCUDES([M:SQD]NBLIG),LCOE, LUSCAV, LFMT, LMODIF) From STKACT
            If LMODIF=2
                Diszo [M:SQD]COEDES([M:SQD]NBLIG)
            Endif
            [M:SQD]QTYSTUDES([M:SQD]NBLIG) = [M:SGW]WQTYSTUDES(I)
            [M:SQD]STADES([M:SQD]NBLIG)    = [M:SGW]WSTADES(I)
            Actzo [M:SQD]STADES([M:SQD]NBLIG)
            If dim([M:SQD]SERNUM)>0
                [M:SQD]SERNUM([M:SQD]NBLIG)    = [M:SGW]WSERNUM(I)
                [M:SQD]SERNUMF([M:SQD]NBLIG)   = [M:SGW]WSERNUMF(I)
                Actzo [M:SQD]SERNUM([M:SQD]NBLIG),SERNUMF([M:SQD]NBLIG)
            Endif
           If dim([M:SQD]LPNNUMDES)>0                                               # hcb X3-77043
                [M:SQD]LPNNUMDES([M:SQD]NBLIG)    = [M:SGW]WLPNNUMDES(I)            # hcb X3-77043
                Actzo [M:SQD]LPNNUMDES([M:SQD]NBLIG)                                # hcb X3-77043
            Endif                                                                   # hcb X3-77043
            If dim([M:SQD]LOCTYPDES)>0
                [M:SQD]LOCTYPDES([M:SQD]NBLIG) = [M:SGW]WLOCTYPDES(I)
                Actzo [M:SQD]LOCTYPDES([M:SQD]NBLIG)
            Endif
            If dim([M:SQD]LOCDES)>0
                [M:SQD]LOCDES([M:SQD]NBLIG)    = [M:SGW]WLOCDES(I)
                Actzo [M:SQD]LOCDES([M:SQD]NBLIG)
            Endif
            If dim([M:SQD]WRHDES)>0
                [M:SQD]WRHDES([M:SQD]NBLIG)    = [M:SGW]WWRHDES(I)
                Actzo [M:SQD]WRHDES([M:SQD]NBLIG)
            Endif
            If dim([M:SQD]WLOCSEQ)>0
                [M:SQD]WLOCSEQ([M:SQD]NBLIG)    = [M:SGW]WLOCSEQ(I)
            Endif
#                                                                             # hcb 110327 deb
            If dim([M:SQD]WSTOSEQIND)>0
               [M:SQD]WSTOSEQIND([M:SQD]NBLIG)    = [M:SGW]WSTOSEQIND(I)
            Endif
#                                                                             # hcb 110327 fin
            # Transfert zones de l'écran STOCHGW vers l'écran STOQUA
            GPOINT="SGW_SQD" : Gosub ENTREE From EXEFNC

        Endif
   #     If dim([M:SQD]LPNNUMDES)>0 &  [M:SQD]LPNNUM<>"" & [M:SQD]LPNNUMDES([M:SQD]NBLIG)=""    # hcb X3-77043
   #       [M:SQD]LPNNUMDES([M:SQD]NBLIG) = [M:SQD]LPNNUM                                       # hcb X3-77043
   #     Endif                                                                                  # hcb X3-77043
        If dim([M:SQD]LOCTYPDES)>0 &  [M:SQD]LOCTYP<>"" & [M:SQD]LOCTYPDES([M:SQD]NBLIG)=""
          [M:SQD]LOCTYPDES([M:SQD]NBLIG) = [M:SQD]LOCTYP
        Endif
        If dim([M:SQD]LOCDES)>0 & [M:SQD]LOC<>""    & [M:SQD]LOCDES([M:SQD]NBLIG)=""
          [M:SQD]LOCDES([M:SQD]NBLIG)    = [M:SQD]LOC
        Endif
        If dim([M:SQD]WRHDES)>0 & [M:SQD]WRH<>""    & [M:SQD]WRHDES([M:SQD]NBLIG)=""
          [M:SQD]WRHDES([M:SQD]NBLIG)    = [M:SQD]WRH
        Endif
        If [M:SQD]NBLIG=0 | [M:SQD]WSTJFLG([M:SQD]NBLIG-1)>0 | [M:SQD]WSTOSEQ=[M:SGW]WSTOSEQ(I-1) & [M:SGW]WSTOCOU(I)<>[M:SGW]WSTOCOU(I-1)
            [M:SQD]WSTOCOU([M:SQD]NBCOU)  = [M:SGW]WSTOCOU(I)
            [M:SQD]WLIGDET2([M:SQD]NBCOU) = [M:SQD]NBLIG
            [M:SQD]NBCOU += 1
        Endif
        If I+1>=[M:SGW]NBLIG
&        | [M:SQD]WSTOSEQ<>[M:SGW]WSTOSEQ(I+1)
&        | [M:SQD]WSTOSEQ=[M:SGW]WSTOSEQ(I+1) & [M:SGW]WLIGDET(I)<>[M:SGW]WLIGDET(I+1)
&        | [M:SGW]WSTOSEQIND(I) <> 0                                                     # hcb 110327
            [M:SQD]NBLIG += 1
        Endif
        I+=1
    Wend
Endif

If dim([M:SQD]LOT)>0 & [M:SQD]LOT<>""    # Pas de complément lot pour le lot blanc
    Raz WCHARGE                                                      # hcb unicite
    I = find([M:SQD]WSTOSEQ, [M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1))-1
    If I>=0
        I=[M:SGW]NUMLIGLOT(I)
        [M:SQD]LOT     = [M:SGW]LOT(I)
        If dim([M:SQD]SLO)>0
            [M:SQD]SLO     = [M:SGW]SLO(I)
        Endif
        [M:SQD]BPSLOT  = [M:SGW]BPSLOT(I)
        [M:SQD]POT     = [M:SGW]POT(I)
        [M:SQD]ACT     = [M:SGW]ACT(I)
        [M:SQD]SHL     = [M:SGW]SHL(I)
        [M:SQD]SHLDAT  = [M:SGW]SHLDAT(I)
        [M:SQD]REFPER  = [M:SGW]REFPER(I)

        [M:SQD]SHLUOM     = [M:SGW]SHLUOM   (I)             # hcb v6per
        [M:SQD]SHLLTI     = [M:SGW]SHLLTI   (I)             # hcb v6per
        [M:SQD]SHLLTIUOM  = [M:SGW]SHLLTIUOM(I)             # hcb v6per
        [M:SQD]NEWLTIDAT  = [M:SGW]NEWLTIDAT(I)             # hcb v6per
        [M:SQD]DLU        = [M:SGW]DLU      (I)             # hcb v6per
        [M:SQD]DLUDAT     = [M:SGW]DLUDAT   (I)             # hcb v6per

        [M:SQD]USRFLD1 = [M:SGW]USRFLD1(I)
        [M:SQD]USRFLD2 = [M:SGW]USRFLD2(I)
        [M:SQD]USRFLD3 = [M:SGW]USRFLD3(I)
        [M:SQD]USRFLD4 = [M:SGW]USRFLD4(I)
#                                                                                         # hcb 111781 deb
        If dim([M:SQD]ECCVALMAJ)>0
           [M:SQD]ECCVALMAJ = [M:SGW]ECCVALMAJ(I)
        Endif
        If dim([M:SQD]ECCVALMIN)>0
           [M:SQD]ECCVALMIN = [M:SGW]ECCVALMIN(I)
        Endif
        If dim([M:SQD]ECCSAIFLG)>0
           [M:SQD]ECCSAIFLG = 1
        Endif
#                                                                                         # hcb 111781 deb

        [M:SQD]VALIDE  = [M:SGW]VALIDE(I)
        [M:SQD]MODIF   = [M:SGW]MODIF(I)
        WCHARGE = 1

#                                                                      hcb unicite   deb
    Else
        If dim([M:SQD]SLO)>0 & GFEALOTLEV = 2 & [F:ITM]LOTMGTCOD = 4
           Raz Z
           Z = sigma(0,[M:SGW]NBLIG-1,(indcum+1)*([M:SGW]WSTOSEQ(indcum)<>0 & [M:SGW]LOT(indcum) = [M:SQD]LOT &
&                    Z=0 & sigma(Z=1,1,1)))
           If Z <> 0
              Z  -=1
             [M:SQD]BPSLOT  = [M:SGW]BPSLOT      (Z)
             [M:SQD]POT     = [M:SGW]POT         (Z)
             [M:SQD]ACT     = [M:SGW]ACT         (Z)
             [M:SQD]SHL     = [M:SGW]SHL         (Z)
             [M:SQD]SHLDAT  = [M:SGW]SHLDAT      (Z)
             [M:SQD]REFPER  = [M:SGW]REFPER      (Z)

             [M:SQD]SHLUOM     = [M:SGW]SHLUOM   (Z)
             [M:SQD]SHLLTI     = [M:SGW]SHLLTI   (Z)
             [M:SQD]SHLLTIUOM  = [M:SGW]SHLLTIUOM(Z)
             [M:SQD]NEWLTIDAT  = [M:SGW]NEWLTIDAT(Z)
             [M:SQD]DLU        = [M:SGW]DLU      (Z)
             [M:SQD]DLUDAT     = [M:SGW]DLUDAT   (Z)

             [M:SQD]USRFLD1 = [M:SGW]USRFLD1     (Z)
             [M:SQD]USRFLD2 = [M:SGW]USRFLD2     (Z)
             [M:SQD]USRFLD3 = [M:SGW]USRFLD3     (Z)
             [M:SQD]USRFLD4 = [M:SGW]USRFLD4     (Z)
#                                                                                         # hcb 111781 deb
             If dim([M:SQD]ECCVALMAJ)>0
                [M:SQD]ECCVALMAJ = [M:SGW]ECCVALMAJ(Z)
             Endif
             If dim([M:SQD]ECCVALMIN)>0
                [M:SQD]ECCVALMIN = [M:SGW]ECCVALMIN(Z)
             Endif
             If dim([M:SQD]ECCSAIFLG)>0
                [M:SQD]ECCSAIFLG = 1
             Endif
#                                                                                         # hcb 111781 deb
             [M:SQD]VALIDE  = [M:SGW]VALIDE      (Z)
             [M:SQD]MODIF   = [M:SGW]MODIF       (Z)
             WCHARGE = 1
           Endif
# hcb 90366 deb
        Else
           If dim([M:SQD]SLO)>0
              LSLO = [M:SQD]SLO
           Else
              Raz LSLO
           Endif

           Raz Z
           Z = sigma(0,[M:SGW]NBLIG-1,(indcum+1)*([M:SGW]WSTOSEQ(indcum)<>0 & [M:SGW]LOT(indcum) = [M:SQD]LOT & [M:SGW]SLO(indcum) = LSLO &
&                    Z=0 & sigma(Z=1,1,1)))
           If Z <> 0
              Z  -=1
             [M:SQD]BPSLOT  = [M:SGW]BPSLOT      (Z)
             [M:SQD]POT     = [M:SGW]POT         (Z)
             [M:SQD]ACT     = [M:SGW]ACT         (Z)
             [M:SQD]SHL     = [M:SGW]SHL         (Z)
             [M:SQD]SHLDAT  = [M:SGW]SHLDAT      (Z)
             [M:SQD]REFPER  = [M:SGW]REFPER      (Z)

             [M:SQD]SHLUOM     = [M:SGW]SHLUOM   (Z)
             [M:SQD]SHLLTI     = [M:SGW]SHLLTI   (Z)
             [M:SQD]SHLLTIUOM  = [M:SGW]SHLLTIUOM(Z)
             [M:SQD]NEWLTIDAT  = [M:SGW]NEWLTIDAT(Z)
             [M:SQD]DLU        = [M:SGW]DLU      (Z)
             [M:SQD]DLUDAT     = [M:SGW]DLUDAT   (Z)

             [M:SQD]USRFLD1 = [M:SGW]USRFLD1     (Z)
             [M:SQD]USRFLD2 = [M:SGW]USRFLD2     (Z)
             [M:SQD]USRFLD3 = [M:SGW]USRFLD3     (Z)
             [M:SQD]USRFLD4 = [M:SGW]USRFLD4     (Z)
#                                                                                         # hcb 111781 deb
             If dim([M:SQD]ECCVALMAJ)>0
                [M:SQD]ECCVALMAJ = [M:SGW]ECCVALMAJ(Z)
             Endif
             If dim([M:SQD]ECCVALMIN)>0
                [M:SQD]ECCVALMIN = [M:SGW]ECCVALMIN(Z)
             Endif
             If dim([M:SQD]ECCSAIFLG)>0
                [M:SQD]ECCSAIFLG = 1
             Endif
#                                                                                         # hcb 111781 deb

             [M:SQD]VALIDE  = [M:SGW]VALIDE      (Z)
             [M:SQD]MODIF   = [M:SGW]MODIF       (Z)
             WCHARGE = 1
           Endif
# hcb 90366 fin

        Endif
#                                                                       hcb unicite   fin
    Endif
    If WCHARGE = 0                                                     # hcb unicite
        If dim([M:SQD]SLO)>0
           Read [STL]STL0=[M:SQD]ITMREF;[M:SQD]LOT;[M:SQD]SLO
        Else
           Read [STL]STL0=[M:SQD]ITMREF;[M:SQD]LOT;""
        Endif
        If fstat
           If [M:STQ1]VALFLG=2                     # hcb 50950
              Raz [F:STL]                          # hcb 50950
           Else                                    # hcb 50950
              Call FSTA("STL") From GLOCK
           Endif                                   # hcb 50950
        Else
        Endif
        # [M:SQD]LOT        = [F:STL]LOT           # hcb 50950
        # If dim([M:SQD]SLO)>0                     # hcb 50950
        #    [M:SQD]SLO     = [F:STL]SLO           # hcb 50950
        # Endif                                    # hcb 50950
        [M:SQD]BPSLOT  = [F:STL]BPSLOT
        [M:SQD]POT     = [F:STL]POT
        [M:SQD]ACT     = [F:STL]ACT
        [M:SQD]SHL     = [F:STL]SHL
        [M:SQD]SHLDAT  = [F:STL]SHLDAT
        [M:SQD]REFPER  = [F:STL]REFPER
        [M:SQD]SHLUOM     = [F:STL]SHLUOM                   # hcb v6per
        [M:SQD]SHLLTI     = [F:STL]SHLLTI                   # hcb v6per
        [M:SQD]SHLLTIUOM  = [F:STL]SHLLTIUOM                # hcb v6per
        [M:SQD]NEWLTIDAT  = [F:STL]NEWLTIDAT                # hcb v6per
        [M:SQD]DLU        = [F:STL]DLU                      # hcb v6per
        [M:SQD]DLUDAT     = [F:STL]DLUDAT                   # hcb v6per

        [M:SQD]USRFLD1 = [F:STL]USRFLD1
        [M:SQD]USRFLD2 = [F:STL]USRFLD2
        [M:SQD]USRFLD3 = [F:STL]USRFLD3
        [M:SQD]USRFLD4 = [F:STL]USRFLD4
#                                                                                         # hcb 111781 deb
        If dim([M:SQD]ECCVALMAJ)>0
           [M:SQD]ECCVALMAJ = [F:STL]ECCVALMAJ
        Endif
        If dim([M:SQD]ECCVALMIN)>0
           [M:SQD]ECCVALMIN = [F:STL]ECCVALMIN
        Endif
        If dim([M:SQD]ECCSAIFLG)>0
           [M:SQD]ECCSAIFLG = 1
        Endif
#                                                                                         # hcb 111781 deb

#  hcb  90247  deb
         [F:STL]LTIDAT = [M:SQD]IPTDAT
         Call CALLTI([F:ITM]EXYMGTCOD,[F:STL]LTIDAT,[F:STL]SHLLTI ,[F:STL]SHLLTIUOM,"",[M:SQD]NEWLTIDAT) From STKLIB
#        si date recontrole > date limite utilisation : date recontrole = date limite utilisation
         If [M:SQD]NEWLTIDAT  <> [31/12/2999]     # date recontrole
            If [M:SQD]NEWLTIDAT  > [F:STL]DLUDAT
               [M:SQD]NEWLTIDAT  = [F:STL]DLUDAT
            Endif
         Endif
#  hcb  90247  fin

        [M:SQD]VALIDE  = 2
        [M:SQD]MODIF   = 2
    Endif
Endif
If [F:ITM]SERMGTCOD=3 | [F:ITM]SERMGTCOD=2 & (dim([M:SQD]SERNUMDEP)>0 & [M:SQD]SERNUMDEP<>"")
    Diszo [M:SQD]PCUDES,COEDES
Endif


Return

###############################################################################
# LOAD_FROM_STJ : Charge l'écran STOQUA [SQD] à partir du fichier STOJOU [STJ]
###############################################################################
$LOAD_FROM_STJ
Local Char LSER(GLONSER)
Local Integer LSTJRET
# hcb 40793  rajout controle sur status lignes 154 163

If dim([M:SQD]SERNUMDEP)>0 & [M:SQD]SERNUMDEP<>"" & [F:ITM]SERMGTCOD <> 4  # hcb 110327
    Filter [STJ] Where STOFCY = [M:SQD]STOFCY
&                    & VCRTYP = [M:SQD]VCRTYP
&                    & VCRNUM = [M:SQD]VCRNUM
&                    & REGFLG = 1
&                    & QTYSTU > 0
&                    & SERNUM >= [M:SQD]SERNUMDEP
&                    & SERNUM <= [M:SQD]SERNUMFDEP
&                    & len(SERNUM) = len([M:SQD]SERNUMDEP)
&                    & left$(STA,1) <> "Q"
&            Order By SERNUM
Else
    Filter [STJ] Where STOFCY = [M:SQD]STOFCY
&                    & VCRTYP = [M:SQD]VCRTYP
&                    & VCRNUM = [M:SQD]VCRNUM
&                    & VCRLIN = [M:SQD]VCRLIN
&                    & REGFLG = 1
&                    & QTYSTU > 0
&                    & left$(STA,1) <> "Q"

Endif
    For [STJ] Hint Key STJ1
       If [F:ITM]SERMGTCOD = 4                                            # hcb 110327
           If [M:SQD]NBLIG=0                                               # hcb 110327
              [M:SQD]NBLIG=1                                               # hcb 110327
           Endif                                                           # hcb 110327
        Else                                                               # hcb 110327
        If [M:SQD]NBLIG=0
            [M:SQD]NBLIG=1
            If dim([M:SQD]SERNUM)>0
                [M:SQD]SERNUM([M:SQD]NBLIG-1)    = [F:STJ]SERNUM
            Endif
        Else
            If dim([M:SQD]SERNUMF)>0 & [M:SQD]SERNUM([M:SQD]NBLIG-1)<>""
                Call PLUS_UN(LSER, LSER, LSTJRET) From STKLIB
            Endif
#                              rajout test LPNNUMDES                     # hcb X3-77043
            If [M:SQD]PCUDES([M:SQD]NBLIG)    <> [F:STJ]PCU
&            | [M:SQD]COEDES([M:SQD]NBLIG)    <> [F:STJ]PCUSTUCOE
&            | [M:SQD]STADES([M:SQD]NBLIG)    <> [F:STJ]STA
&            | LSER  <> [F:STJ]SERNUM
&            | dim([M:SQD]LPNNUMDES)>0 & [M:SQD]LPNNUMDES([M:SQD]NBLIG) <> [F:STJ]LPNNUM
&            | dim([M:SQD]LOCDES)>0 & [M:SQD]LOCDES([M:SQD]NBLIG) <> [F:STJ]LOC
&            | dim([M:SQD]WRHDES)>0 & [M:SQD]WRHDES([M:SQD]NBLIG) <> [F:STJ]WRH
                    [M:SQD]NBLIG += 1
                    If dim([M:SQD]SERNUM)>0
                        [M:SQD]SERNUM([M:SQD]NBLIG-1)    = [F:STJ]SERNUM
                    Endif
            Endif
        Endif
        Endif                                                             # hcb 110327
        Gosub CHARG_SQD
    Next

Filter [STJ]
Return

$CHARG_SQD
    [M:SQD]WSTJFLG([M:SQD]NBLIG-1)   = 1
    [M:SQD]PCUDES([M:SQD]NBLIG-1)    = [F:STJ]PCU
    [M:SQD]QTYPCUDES([M:SQD]NBLIG-1)+= [F:STJ]QTYPCU
    [M:SQD]COEDES([M:SQD]NBLIG-1)    = [F:STJ]PCUSTUCOE
    [M:SQD]QTYSTUDES([M:SQD]NBLIG-1)+= [F:STJ]QTYSTU
    [M:SQD]STADES([M:SQD]NBLIG-1)    = [F:STJ]STA
    If dim([M:SQD]SERNUMF)>0
        [M:SQD]SERNUMF([M:SQD]NBLIG-1) = [F:STJ]SERNUM
    Endif
    If dim([M:SQD]LPNNUMDES)>0                                                     # hcb X3-77043
       [M:SQD]LPNNUMDES([M:SQD]NBLIG-1)  = [F:STJ]LPNNUM                           # hcb X3-77043
    Endif                                                                          # hcb X3-77043
    If dim([M:SQD]LOCDES)>0
        [M:SQD]LOCDES([M:SQD]NBLIG-1)  = [F:STJ]LOC
    Endif
    If dim([M:SQD]WRHDES)>0
        [M:SQD]WRHDES([M:SQD]NBLIG-1)  = [F:STJ]WRH
    Endif
    If dim([M:SQD]LOCTYPDES)>0
        If [F:STC]STOFCY<>[F:STJ]STOFCY | [F:STC]LOC <> [F:STJ]LOC
            Read [STC]STC0=[F:STJ]STOFCY;[F:STJ]LOC
        Endif
        [M:SQD]LOCTYPDES([M:SQD]NBLIG-1) = [F:STC]LOCTYP
    Endif
#                                                                          # hcb 110327 deb
    If [F:ITM]SERMGTCOD = 4
       If dim([M:SQD]SERNUMF)>0
          [M:SQD]SERNUM ([M:SQD]NBLIG-1) = [F:STJ]SERDEB
          [M:SQD]SERNUMF([M:SQD]NBLIG-1) = [F:STJ]SERFIN
       Endif
       [M:SQD]NBLIG += 1
    Endif
#                                                                          # hcb 110327 end

    # Transfert zones du fichier STOJOU vers l'écran STOQUA
    GPOINT="STJ_SQD" : Gosub ENTREE From EXEFNC


Return

##################################################
$MAJ_PECQTY
    [M:SQD]PECQTYSTU     = sum([M:SQD]QTYSTUDES)
    [M:SQD]PECQTYPCU     = sum([M:SQD]QTYSTUDES)/[M:SQD]PCUSTUCOE
    Affzo [M:SQD]PECQTYSTU,PECQTYPCU
Return

##################################################
# Contrôle qu'on ne dépasse pas la quantité de départ
# Et si l'article est géré en n° série E/S recalcule le n° série fin
##################################################
Subprog CTRNEWQTY( PNOL, PQTYN, PCOEN )
Value Integer PNOL
Value Decimal PQTYN
Value Decimal PCOEN

Local Integer I
Local Decimal LQTYSTUN
Local Integer LRET
Local Char    LSERF(GLONSER)

LQTYSTUN = PQTYN*PCOEN
Call QTEARR(LQTYSTUN,[M:SQD]STU) From TRTDIV    # hcb 63440

If sum([M:SQD]QTYSTUDES)-[M:SQD]QTYSTUDES(PNOL) + LQTYSTUN > [M:SQD]QTYSTU
    mkstat = 2
    GMESSAGE = mess( 393, 199, 1)
Elsif [F:ITM]SERMGTCOD=3
    LSERF=[M:SQD]SERNUM(PNOL)
    For I=2 To LQTYSTUN
        Call PLUS_UN(LSERF,LSERF,LRET) From STKLIB
        If LRET
#           mkstat = 2                          # hcb 103276
            Break
        Endif
    Next
    If mkstat : End : Endif
    [M:SQD]SERNUMF(PNOL) = LSERF
    Affzo [M:SQD]SERNUMF(PNOL)
Endif
End

##################################################
Subprog CTRSERNUM( PNOL, PSER, PSERF )
Value    Integer PNOL
Value    Char    PSER
Variable Char    PSERF

Local Char LLOC(GLONLOC)
Local Char LLOT(GLONLOT)
Local Char LSLO(GLONSLO)
Local Char LPAL(GLONPAL)
Local Char LCTR(GLONCTR)
Local Char LSF1(GLONSF1)
Local Char LSF2(GLONSF2)
Local Char LLPN(GLONLPN)                                             # hcb X3-77043
Raz LLOC, LLOT, LSLO, LPAL, LCTR, LSF1, LSF2, LLPN                   # hcb X3-77043
If dim([M:SQD]LPNNUM)>0                                              # hcb X3-77043
   LLPN = [M:SQD]LPNNUM                                              # hcb X3-77043
Endif                                                                # hcb X3-77043
If dim([M:SQD]LOC)>0
   LLOC = [M:SQD]LOC
Endif
If dim([M:SQD]LOT)>0
   LLOT = [M:SQD]LOT
Endif
If dim([M:SQD]SLO)>0
   SLO = [M:SQD]SLO
Endif
If dim([M:SQD]PALNUM)>0
   LPAL = [M:SQD]PALNUM
Endif
If dim([M:SQD]CTRNUM)>0
   LCTR = [M:SQD]CTRNUM
Endif
If dim([M:SQD]STOFLD1)>0
   LSF1 = [M:SQD]STOFLD1
Endif
If dim([M:SQD]STOFLD2)>0
   LSF2 = [M:SQD]STOFLD2
Endif

Local Integer I
Local Integer LRET

    PSERF = PSER
    Repeat
        I+=1
        # Est-ce que le numéro est utilisé dans SQD?
        F = sigma(0, [M:SQD]NBLIG-1, ( indcum<>PNOL )
&                                  & ( len([M:SQD]SERNUM(indcum)) = len(PSERF) )
&                                  & ( [M:SQD]SERNUM(indcum)  <= PSERF )
&                                  & ( [M:SQD]SERNUMF(indcum) >= PSERF ) )
        If F
            LRET=1
        Else
#                                         rajout LLPN                               # hcb X3-77043
            Call CTRSERNUM([M:SQD]ITMREF,[M:SQD]STOFCY,PSERF,[M:SQD]WSTOSEQ,
&                          [M:SQD]PCU,[M:SQD]STA,LLOC,LLOT,LSLO,LPAL,LCTR,
&                          LSF1,LSF2,LLPN,0,LRET) From SUBSCSB
        Endif
        Case LRET
            When 0 :
                If I<[M:SQD]QTYSTUDES(PNOL)
                    Call PLUS_UN( PSERF, PSERF, LRET ) From STKLIB
                Endif
            When 1 :
                GMESSAGE = PSERF-":"-mess( 32, 184, 1) # N° de série déjà utilisé
                Raz PSERF
            When 2 :
                GMESSAGE = PSERF-":"-mess( 43, 196, 1 )    # N° de série inexistant
                Raz PSERF
            When 3 :
                GMESSAGE = PSERF-":"-mess( 367, 199, 1 )    # Pas de stock disponible
                Raz PSERF
            When 4 :
                GMESSAGE = PSERF-":"-mess( 31, 184, 1 )    # Caractéristiques stock incorrectes
                Raz PSERF
        Endcase
    Until PSERF="" | I>=[M:SQD]QTYSTUDES(PNOL)

End

# hcb 50950
########################################################################
# POSTABLE : Positionnement sur les tables ITM, ITF, ITFD, ITG, STL
########################################################################
Subprog POSTABLE2(PFCYDES, PITM, PLOT, PSLO, PRET)
Value    Char PFCYDES
Value    Char PITM
Value    Char PLOT
Value    Char PSLO
Variable Integer PRET

#---- Positionnement sur les tables ------------#
Call LECITM2( PFCYDES, PITM, "", PRET ) From STKLIB

If [F:STL]LOT<>PLOT | [F:STL]SLO<>PSLO
   Read [STL]STL0=PITM;PLOT;PSLO
   If fstat
      Raz [F:STL]
   Endif
Endif

If [F:ITFD]ITMREF<>PITM | [F:ITFD]STOFCY<>PFCYDES
    Read [ITFD]ITF0=PITM;PFCYDES
    If fstat
        Raz [F:ITFD]
    Endif
Endif

End

