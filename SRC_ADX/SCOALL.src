#<AdxTL>@(#)8.0.0.0 $Revision$
############################################################################
# Librairie de sous-programme Allocation EO (Ordre de sous-traitance)      #
############################################################################
# Subprog ALLOC_EO(LTRT, LTRS, LSCONUM, LALLTYP, LDESALL, LRET)
# Subprog ALLOCATION(LTRTLIG, LALLTYP, LALL, LSHT, LRET)
# Subprog ALLOC_MAT(LTRT, LTRS, LSCONUM, LALLTYP, LDESALL, LRET, LITM, LSCILIN, LSCMLIN, QTYBESOIN)
# Subprog ALLOC_APPROMAT(LTRS, LFCY, LITM, LLOC, LRET)
# Subprog MAJALLMAT(LSCONUM, LSCILIN, LSCMLIN, LITM, LQTY, LSHT, LMOD, LRET)
# Subprog UPDATE_ALL(LCOD)
############################################################################


#---------------------------------------------------------------------------#
# Actions liées aux allocations Ordre de sous-traitance (selon MFGALL)      #
# - SAISCOALL    Gestion allocation Ordre de sous-traitance (SAIMFGALL)     #
#---------------------------------------------------------------------------#
$ACTION
Case ACTION
    When "OUVRE":         Case GACTION
                              When "SAISCOALL" : Gosub OUVRE_SCOALL
                          Endcase
    When "DEBUT":         Case GACTION
                              When "SAISCOALL" : Gosub DEBUT_SCOALL
                          Endcase
    When "SETBOUT":       Case GACTION
                              When "SAISCOALL" : Gosub SETBOUT_SCOALL
                          Endcase
    When "BOUTON":        Case GACTION
                              When "SAISCOALL" : Gosub BOUTON_SCOALL
                          Endcase
    When "FIN":           Case GACTION
                              When "SAISCOALL":  Gosub FIN_SCOALL
                          Endcase
    When Default
Endcase
Return



#---------------------------------------------------------------------------#
# Action SAISCOALL                                                          #
#---------------------------------------------------------------------------#
###########################################################################
# ouverture
$OUVRE_SCOALL
Local    Char    WSCONUM(GLONVCR) : WSCONUM = PARAM(1)
Local    Integer WSCILIN : WSCILIN = val(PARAM(2)) : # 1000: un seul article lancé
Local    Char    WFCY(GLONFCY)
Local    Integer WTRKFLG
Local    Integer WRET
Local    Integer WLK, WDLK

# ouverture tables
Gosub OPEN_FILES_SCO From SCOLIB
If clalev([F:ORD]) = 0 : Local File ORDERS    [ORD] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER [ITM] : Endif
# Issue X3-64602 - 2017-11-30 by MUARN : Matière sur bon de prépa
If clalev([F:STA])=0  Local File STOALL     [STA]   Endif

If dim(GALL) < 0 : Global Integer GALL : Endif
GALL = 0
Return

###########################################################################
# ouverture
$DEBUT_SCOALL
WLK=0 : # GH 12/10/2011 bug 77075
If WDLK<>1
   WLK =  func TRTX3FNC.CHECK_LOCK("SCO",WSCONUM,1,WDLK)
Endif

# lecture entête Ordre de sous-traitance
Read [SCO]SCO0=WSCONUM
If fstat : PARAM(3) = num$(1) : FIN = 1 : Return : Endif

Read [SCI]SCI0=WSCONUM;WSCILIN
If fstat : PARAM(3) = num$(1) : FIN = 1 : Return : Endif

WFCY     = [F:SCI]PRHFCY
WTRKFLG  = [F:SCO]SCOTRKFLG

[M:SCA1] = [F:SCO]
[M:SCA1] = [F:SCI]
[M:SCA1]STOFCY = WFCY

# on revérifie si aucune matière avant de sortir en erreur
If [M:SCA1]MATLINNBR = 0 : Gosub MAJSCOHEAD From SCOLIB : Endif

If [M:SCA1]MATLINNBR = 0 : PARAM(3) = num$(2) : FIN = 1 : Return : Endif
Case [M:SCA1]ALLSTA
    When 1     :  [M:SCA1]TALL = 2               # FQ 53991 Par défaut on propose Alloc détaillée
    When 2,4   :  [M:SCA1]TALL = 1
    When 3,5   :  If [M:SCA1]OVRALLNBR <> 0
                      [M:SCA1]TALL = 1
                  Else
                      [M:SCA1]TALL = 2
                  Endif
Endcase
[M:SCA1]TDESALL = 1
Affzo  [SCA1]
Return

###########################################################################
# ouverture
$SETBOUT_SCOALL
Case [M:SCA1]ALLSTA
    When 1 :     ETABOU(GSPE1) = 1                           # allocation
                 ETABOU(GSPE2) = 0                           # désallocation
                 ETABOU(GSPE3) = 0                           # visu allocation
    When 2,4:    ETABOU(GSPE1) = 1
                 ETABOU(GSPE2) = 1
                 ETABOU(GSPE3) = 1
    When 3,5:    If [M:SCA1]DETALLNBR = [M:SCA1]MATLINNBR
                     If [M:SCA1]SHTMATNBR = 0
                         ETABOU(GSPE1) = 0
                     Else
                         ETABOU(GSPE1) = 1
                     Endif
                 Else
                         ETABOU(GSPE1) = 1
                 Endif
                 ETABOU(GSPE2) = 1
                 ETABOU(GSPE3) = 1
Endcase
If GCONSULT = 1
    ETABOU(GSPE1) = 0
    ETABOU(GSPE2) = 0
Endif
If [F:SCO]MATCLENBR = [F:SCO]MATLINNBR
    ETABOU(GSPE1) = 0
    ETABOU(GSPE2) = 0
Endif

If WLK : # GH 12/10/2011 bug 77075
    ETABOU(GSPE1) = 0
    ETABOU(GSPE2) = 0
    Diszo [SCA1]
Endif
Return

###########################################################################
# ouverture
$BOUTON_SCOALL
Case BOUT
    When "1"       :     # allouer
                         Call ALLOC_EO("C", 1, WSCONUM, [M:SCA1]TALL, [M:SCA1]TDESALL, WRET)
                         If WRET = 0 : GALL = 1 : Endif
                         # relecture entête Ordre de sous-traitance
                         Read [SCO]SCO0=WSCONUM
                         If fstat : PARAM(3) = num$(1) : FIN = 1 : Return : Endif
                         Gosub DEBUT_SCOALL
    When "2"       :     # désallouer
                         Call ALLOC_EO("A", 1, WSCONUM, [M:SCA1]TALL, [M:SCA1]TDESALL, WRET)
                         If WRET = 0 : GALL = 1 : Endif
                         # relecture entête Ordre de sous-traitance
                         Read [SCO]SCO0=WSCONUM
                         If fstat : PARAM(3) = num$(1) : FIN = 1 : Return : Endif
                         Gosub DEBUT_SCOALL
Endcase
FIN=0

Return

###########################################################################
# ouverture
$OK_SCOALL
Return

###########################################################################
# fermeture
$FIN_SCOALL
If WDLK=1 : # GH 12/10/2011 bug 77075
   Unlock = "SCO"+WSCONUM
Endif

If GALL = 1
    Case GFONCTION
        When "FUNGBENCH" : If clalev ([M:MGD])=0
                               [M:MGB]REACT = 2
                               GLRET = 2
                               Gosub FABRICATION From FUNGBENCH
                           Else
                               [M:MGD]REACT = 2
                               GDLRET = 2
                               Gosub FABRICATION From FUNDBENCH
                           Endif
        When "FUNDBENCH" : If clalev ([M:MGB])=0
                               [M:MGD]REACT = 2
                               GDLRET = 2
                               Gosub FABRICATION From FUNDBENCH
                           Else
                               [M:MGB]REACT = 2
                               GLRET = 2
                               Gosub FABRICATION From FUNGBENCH
                           Endif
        When "FUNBENPLT" : If dim([M:MBP]REACT)
                               [M:MBP]REACT = 2
                               Gosub PILOTAGE From FUNBENPLT
                               GLRET = 2
                           Endif
     Endcase
Endif
Return

###########################################################################
#                                                                         #
#    TRAITEMENTS LIES aux ALLOCATIONS de matières                         #
#                                                                         #
###########################################################################
#-------------------------------------------------------------------------#
# ALLOC_EO  : Sous-programme d'allocation d'un Ordre de sous-traitance   #
#             Génération des allocations dans le fichier STOALL           #
#                        par appel des composants d'allocations de STKALL #
#-------------------------------------------------------------------------#
# Prérequis : L'écran paramêtre ALLPAR doit être ouvert                   #
#-------------------------------------------------------------------------#
# Entrée  LTRT       : Type de traitement                                 #
#                            "C" : Création d'une allocation              #
#                            "M" : Modification                           #
#                            "A" : Annulation                             #
#                            "E" : Passage global/détail                  #
#         LTRS       : Mode transaction (LTRS=1 pour transaction)         #
#         LSCONUM    : Numéro Ordre de sous-traitance                     #
#         LALLTYP    : Type alloc (1 = global, 2  = détail)               #
#         LDESALL    : Type désallocation (1 = complète, 2 = par type)    #
#         LRET       : Code retour                                        #
#                             0 : OK                                      #
#                             1 : Erreur                                  #
#-------------------------------------------------------------------------#
Subprog ALLOC_EO(LTRT, LTRS, LSCONUM, LALLTYP, LDESALL, LRET)
Value     Char     LTRT
Value     Integer  LTRS
Value     Char     LSCONUM
Value     Integer  LALLTYP
Value     Integer  LDESALL
Variable  Integer  LRET

Local     Integer  WALLTYP
Local     Integer  WRET
Local     Decimal  WCPLQTY
Local     Decimal  WALL, WSHT
Local     Integer  MEMSTA
Local     Char     WCLE(50)
Local     Integer  WSCILIN : # N° article       => constante 1000 (mono-article)
Local     Integer  WSCMLIN : # N° ligne matière
Local     Integer  WSCSLIN : # N° ligne service => constante (une seule opération)
Local     Char     WITM(GLONITM)
Local     Integer  WALLTYP
Local     Char     WTRT(1)
Local     Char     WPARAM(10)


# ouverture écrans
If clalev([M:ORDK])= 0 : Local Mask ORDK   [ORDK] : Endif
If clalev([M:ALP]) = 0 : Local Mask ALLPAR [ALP]  : Endif

# début de la transaction d'allocation
GOK  = 1
LRET = 0
WTRT = LTRT
If LTRS = 1 : Call DEBTRANS From GLOCK : Endif
$TR_ALLOC
If LTRS = 1 : Trbegin ADOVAL           : Endif

# lecture entête Ordre de sous-traitance
Readlock [SCO]SCO0=LSCONUM
If    fstat = 1  : GOK = -1 : LRET = 1 : GLOCK="$SCOHEAD"-LSCONUM             : Goto ROLL_ALLOC
Elsif fstat      : GOK =  0 : LRET = 1 : Call RSTA("SCO", LSCONUM) From GLOCK : Goto AB_ALLOC    : Endif

# un seul article WSCILIN=1000 par Ordre de sous-traitance
WSCILIN=1000
# lecture Article lancé
Readlock [SCI]SCI0=LSCONUM;WSCILIN
If    fstat = 1  : GOK = -1 : LRET = 1 : GLOCK="$SCOITM"-LSCONUM-num$(WSCILIN)              : Goto ROLL_ALLOC
Elsif fstat      : GOK =  0 : LRET = 1 : Call RSTA("SCI", LSCONUM-num$(WSCILIN)) From GLOCK : Goto AB_ALLOC    : Endif

# GA ajout pour gestion des SCO: utilisé par fonction SCOLIBM/CAL_AVASCOQTY
# une seule opération WSCSLIN=5 par Article lancé de l'Ordre de sous-traitance
WSCSLIN=5
# lecture Service de sous-traitance
Readlock [SCS]SCS0=LSCONUM;WSCILIN;WSCSLIN
If    fstat = 1  : GOK = -1 : LRET = 1 : GLOCK="$SCOSRV"-LSCONUM-num$(WSCILIN)-num$(WSCSLIN)              : Goto ROLL_ALLOC
Elsif fstat      : GOK =  0 : LRET = 1 : Call RSTA("SCS", LSCONUM-num$(WSCILIN)-num$(WSCSLIN)) From GLOCK : Goto AB_ALLOC    : Endif


# on connait le site, récupération du paramètre stock : MARGE alerte péremption jours
#Call PARAM([F:SCI]PRHFCY,"MARPER",WPARAM) From ADOVAL          #hcb v6per
#GSMARPER = val(WPARAM)                                         #hcb v6per


# parcours des Matières de l'Ordre de sous-traitance
  For [SCM]SCM0 Where SCONUM=LSCONUM

    # si matière soldée/exclue => pas de traitement
    If LTRT <> "A" & [F:SCM]MATSTA > 2 : Goto SUIV : Endif

    # si matière fournie par le sous-traitant => pas de traitement
    If LTRT <> "A" & [F:SCM]SCOFLG > 2 : Goto SUIV : Endif

    LTRT = WTRT
    #WSCILIN = [F:SCM]SCILIN
    WSCMLIN = [F:SCM]SCMLIN
    WITM = [F:SCM]CPNITMREF
    # mémo statut
    MEMSTA = [F:SCM]ALLSTA

    # si désallocation et matière non allouée, pas de traitement
    # If LTRT = "A" & [F:SCM]ALLSTA = 1    : Goto SUIV : Endif

    # si désallocation des globales uniquement et allocation détail, pas de traitement
    If LTRT = "A" & LDESALL = 2 & LALLTYP = 1 & !find([F:SCM]ALLSTA,2,3) : Goto SUIV : Endif

    # si désallocation des détails uniquement et allocation globale, pas de traitement
    If LTRT = "A" & LDESALL = 2 & LALLTYP = 2 & !find([F:SCM]ALLSTA,4,5) : Goto SUIV : Endif

    # si demande allocation globale et matière allouée détail, pas de traitement
    If LTRT = "C" & LALLTYP = 1 & [F:SCM]ALLSTA > 3 : Goto SUIV : Endif

    # si passage de global vers détail, mode "E"
    If (LTRT = "C" & LALLTYP = 2 & [F:SCM]ALLSTA > 1 & [F:SCM]ALLSTA < 4) : LTRT = "E" : Endif

    # Issue X3-64602 - 2017-11-30 by MUARN : Matière sur bon de prépa
    If (LTRT = "C" | LTRT ="A") & dim([M:SCO2]CPNITMREF)
      WSRGQTY=0
      # Issue X3-80972 - 2018-03-05 by MUARN : en génération d'EO la table n'est pas ouverte
      If clalev([F:STA])=0  Local File STOALL     [STA]   Endif
      For [STA]STA1 Where VCRTYP=36 & VCRNUM=LSCONUM
&                    & VCRLIN=[F:SCM]SCILIN & VCRSEQ=[F:SCM]SCMLIN & STOCOU=0
        If [F:STA]SRGQTYSTU > 0 : WSRGQTY+=[F:STA]SRGQTYSTU : Break : Endif
      Next
      If WSRGQTY > 0 : Goto SUIV : Endif
    Endif

    Case LTRT
        When "C","M": If [F:SCM]ALLQTY = 0 & [F:SCM]SHTQTY = 0
                          TRTLIG = "C"
                      Else
                          TRTLIG="M"
                      Endif
                    # GA 16/03/2009 il ne faut pas tenir compte de DLVQTY
                    # sinon si l'ordre a été désalloué on ne peut plus réallouer
                  ### WALL    = [F:SCM]RETQTY - [F:SCM]ALLQTY - [F:SCM]SHTQTY - [F:SCM]DLVQTY
                      WALL    = [F:SCM]RETQTY - [F:SCM]ALLQTY - [F:SCM]SHTQTY - [F:SCM]USEQTY
                      WSHT    = [F:SCM]SHTQTY
                      WALLTYP = LALLTYP
                      If WALL <= 0 & WSHT <= 0 : Goto SUIV : Endif
        When "A":     TRTLIG  = "A"
                      WALL    = [F:SCM]ALLQTY
                      WSHT    = [F:SCM]SHTQTY
                      If LDESALL = 1
                          Case [F:SCM]ALLSTA
                               When 2,3: WALLTYP = 1
                               When 4,5: WALLTYP = 2
                          Endcase
                      Else
                          WALLTYP = LALLTYP
                      Endif
        When "E":     TRTLIG  = "E"
                      WALL    = [F:SCM]ALLQTY
                      WSHT    = [F:SCM]SHTQTY
                      WALLTYP = LALLTYP
                      If WALL <= 0 & WSHT <= 0 : Goto SUIV : Endif
    Endcase

    Readlock [SCM]SCM0=LSCONUM;WSCILIN;WSCMLIN
    WCLE = LSCONUM-num$([F:SCM]SCILIN)-num$([F:SCM]SCMLIN)
    If fstat=1
       GOK = -1 : LRET = 1 : GLOCK="$SCOMAT"-WCLE              : Goto ROLL_ALLOC
    Elsif fstat
       GOK =  0 : LRET = 1 : Call RSTA("SCM", WCLE) From GLOCK : Goto AB_ALLOC
    Endif

    # appel à la routine de gestion des allocations
    Call ALLOCATION(TRTLIG, WALLTYP, WALL, WSHT, WRET)
    If WRET  = 9
       Gosub REWRITE_SCM From SCOLIB
       WRET = 0
       Goto SUIV
    Endif
    If WRET <> 0 : LRET = 1 : Goto AB_ALLOC : Endif

    # mise à jour matière
    Case LTRT
       When "C","M": [F:SCM]ALLQTY    += WALL
                     [F:SCM]SHTQTY     = WSHT
                     Case LALLTYP
                       When 1: [F:SCM]ALLSTA = 3
                       When 2: [F:SCM]ALLSTA = 5
                     Endcase
       When "A":     [F:SCM]ALLQTY     = 0
                     [F:SCM]SHTQTY     = 0
                     [F:SCM]ALLSTA     = 1
       When "E":     [F:SCM]ALLQTY     = WALL
                     [F:SCM]SHTQTY     = WSHT
                     [F:SCM]ALLSTA     = 5
    Endcase
    # si rupture, maj statut allocation
    If [F:SCM]SHTQTY <> 0 : [F:SCM]ALLSTA -= 1 : Endif

    # mise à jour matière
    Gosub REWRITE_SCM From SCOLIB

    # mise à jour de l'encours
    Call UPDATE_MSX("M", 0) From SCOLIB

    # v6 affectations
    Gosub MAJ_MTO_SCM From SCOMTOLIB

$SUIV
    If GOK<1 : LRET = 1 : Goto AB_ALLOC : Endif
    Next
#
$TR_FIN
# GA: on revérifie toutes les matières en fin de traitement plutôt que une à une
  Gosub MAJSCOHEAD From SCOLIB
#
  Gosub REWRITE_SCO From SCOLIB
  If GOK<0 : LRET = 1 : Goto ROLL_ALLOC : Endif
#
  Gosub REWRITE_SCI From SCOLIB
  If GOK<0 : LRET = 1 : Goto ROLL_ALLOC : Endif
#
  Gosub REWRITE_SCS From SCOLIB
  If GOK<0 : LRET = 1 : Goto ROLL_ALLOC : Endif
#
  If LTRS = 1
     Commit
  Endif
End

$ROLL_ALLOC
If LTRS = 1
    Rollback  : Call ROLL From GLOCK
    If !GROLL : LRET = 0 : Goto TR_ALLOC : Endif
Endif
End

$AB_ALLOC
If LTRS = 1
    Rollback
Endif
End

###########################################################################
#-------------------------------------------------------------------------#
# ALLOCATION: sous-programme d'allocation                                 #
#-------------------------------------------------------------------------#
# Entrée                                                                  #
#         LTRTLIG    : Type de traitement                                 #
#                            "C" : Création d'une allocation              #
#                            "M" : Modification                           #
#                            "D" : Diminution                             #
#                            "A" : Annulation                             #
#                            "E" : Evolution (global vers détail)         #
#         LALLTYP    : Type allocation                                    #
#         LALL       : Quantité à allouer                                 #
# Sortie  LALL       : Quantité réellement allouée                        #
#         LSHT       : Quantité rejettée                                  #
#         LRET       : Code retour                                        #
#-------------------------------------------------------------------------#
Subprog ALLOCATION(LTRTLIG, LALLTYP, LALL, LSHT, LRET)
Value    Char    LTRTLIG
Value    Integer LALLTYP
Variable Decimal LALL
Variable Decimal LSHT
Variable Integer LRET
#
Local    Char    WFCY(GLONFCY)    :       WFCY    = [F:SCM]STOFCY
Local    Char    WITM(GLONITM)    :       WITM    = [F:SCM]CPNITMREF
Local    Char    WSCONUM(GLONVCR) :       WSCONUM = [F:SCM]SCONUM
Local    Decimal WSCILIN          :       WSCILIN = [F:SCM]SCILIN
Local    Decimal WSCMLIN          :       WSCMLIN = [F:SCM]SCMLIN
Local    Integer WVCRTYP          :       WVCRTYP = 36                : # GA avant 10 pour les OF
Local    Integer L                :       L    = nolign-1
Local    Decimal WALLSTU, WSHTSTU, WALLQTY, WSHTQTY, WSHTQTYSUP, WQTY
Local    Integer WOPT
Local    Integer WRUP             :       WRUP      = 1                    # on génère toujours les ruptures
Local    Integer WALLPAR          :       WALLPAR   = 0                    # allocations partielles toujours autorisées pour
                                                                           # avoir des ruptures (vu avec TS 05.05)
Local    Char    WMAJ(1)             :       WMAJ      = "C"
Local    Integer WRET

# paramètres allocation (il est préférable de l'ouvrir en amont)
If clalev([M:ALP]) = 0 : Local Mask ALLPAR [ALP]  : Endif

LRET = 0
If [F:SCM]SCOFLG <> 2 : End : Endif

# lecture ITM et ITF si nécessaire
LRET = func ITMLIB.READ_ITM_ITF ([F:SCM]CPNITMREF,[F:SCM]STOFCY)
If LRET = 1 : End : Endif

# point d'entrée filtre allocation
GPOINT = "SCOALL" : Gosub ENTREE From EXEFNC
If WRET <> 0 : Goto FIN_ALLOCATION : Endif

# Alimentation de la classe ecran ALLPAR
Raz [M:ALP]
[M:ALP]TRSTYP    = 0
[M:ALP]VCRTYP    = WVCRTYP
[M:ALP]VCRNUM    = WSCONUM
[M:ALP]VCRLIN    = WSCILIN
[M:ALP]VCRSEQ    = WSCMLIN  : # à revoir ???
[M:ALP]STOFCY    = [F:SCM]STOFCY
[M:ALP]ITMREF    = [F:SCM]CPNITMREF
[M:ALP]PCU       = [F:SCM]STU
[M:ALP]PCUSTUCOE = 1
[M:ALP]TYPQTY    = 2
[M:ALP]BESDAT    = [F:SCM]DLVDAT
[M:ALP]DLVDAT    = [F:SCM]DLVDAT
[M:ALP]PECRER    = 1
[M:ALP]PECINTLOC = 1  # Pas d'emplacement interne pour les matières sous-traitance V6 05/2008
[M:ALP]PECPLFLOC = 1  # Prise en cpte empl quai : Oui ? idem OF : Non TS 02/2009
[M:ALP]PECCUNLOK = 2  # Prise en cpte stock en cours inventaire : Oui ? idem OF
[M:ALP]LOT       = [F:SCM]LOT
[M:ALP]LOC       = [F:SCM]LOC
[M:ALP]PECSCOLOC = 2              : # Prise en compte emplacements sous-traitants
[M:ALP]PECOWNER  = [F:SCM]STOFCY  : # Site propriétaire du stock
[M:ALP]STOLOC    = [F:SCM]LOC     : # FQ 54076 (ligne remise)
[M:ALP]STA       = [F:SCM]STA
[M:ALP]PECQLYCTL = 2
WSHTQTY          = LSHT
WALLQTY          = LALL
[M:ALP]BPRNUM    = [F:SCO]BPRNUM    : # Mail TS du 11/04/06
[M:ALP]BPAADD    = [F:SCI]BPAADD    : # Mail TS du 11/04/06
Raz [M:ALP]WRH
# Issue 107513/US2 GA 04/2015 : ECC for [M:SCO2] table SCOMAT
If dim([M:ALP]ECCVALMAJ)>0 & [F:ITM]ECCSTO>1
   [M:ALP]ECCVALMAJ=[F:SCM]ECCVALMAJ
Endif
If dim([M:ALP]ECCVALMIN)>0 & [F:ITM]ECCSTO>2
   [M:ALP]ECCVALMIN=[F:SCM]ECCVALMIN
Endif

Case LTRTLIG
     When "C" : # ------ Création     -----------
        [M:ALP]QTY = WALLQTY
        Call GENSTOALL(WMAJ, LALLTYP, WRUP, WALLPAR, LRET) From STKALL
        If LRET <> 0  : End : Endif
#       Quantité qui a été allouée
        WALLSTU = [M:ALP]ALLQTY
#       Quantité rupture
        WSHTSTU = [M:ALP]ALLQTYSHT
     When "M" : # ------ Modification -----------
# ----- Suppression de l'allocation existante sur les manquants
        If  WSHTQTY <> 0
            #--- 84767
            #WOPT = 2    : # suppression manquants seulss
            WOPT = 12    : # suppression manquants seulss si pas de liste à ranger
            #---
            WQTY = 0 : WSHTQTYSUP = 0
            Call DELALL(WVCRTYP, WSCONUM, WSCILIN, WSCMLIN, WITM, WOPT, WQTY, WSHTQTYSUP, LRET) From STKALL
            If LRET <> 0  : End : Endif
#           On enlève de la quantité rupture les manquants reellement supprimés
            WSHTQTY -= WSHTQTYSUP
        Endif
# ----- Allocation de la nouvelle qté + les manquants supprimés
        WALLQTY = WALLQTY + WSHTQTYSUP
        #--- 84767
        If WALLQTY<>0
           [M:ALP]QTY = WALLQTY
           Call GENSTOALL(WMAJ, LALLTYP, WRUP, WALLPAR, LRET) From STKALL
           If LRET <> 0  : End : Endif
#          Quantité qui a été allouée
           WALLSTU = [M:ALP]ALLQTY
#          On ajoute à la quantité déjà en rupture la nouvelle quantité rupture générée
           WSHTQTY += [M:ALP]ALLQTYSHT
           WSHTSTU = WSHTQTY
        #--- 84767
        Endif
     When "A" : # ------ Annulation   -----------
        WOPT = 0    :     # suppression allocations + manquants
        WALLQTY = 0 : WSHTQTYSUP = 0
        Call DELALL(WVCRTYP, WSCONUM, WSCILIN, WSCMLIN, WITM, WOPT, WALLQTY, WSHTQTYSUP, LRET) From STKALL
        If LRET <> 0  : End : Endif
#       Quantité allouée qui a été supprimée
        WALLSTU=WALLQTY
        WSHTSTU=WSHTQTYSUP
     When "D" : # ------ Diminution -----------
        WQTY = WALLQTY + WSHTQTY
        If WQTY <> 0
            WOPT=0                              : # 0 : diminution manquant puis allocation
            If WALLQTY <> 0
                If WSHTQTY = 0 WOPT=1 Endif     : # 1 : diminution allocations seules
            Elsif WSHTQTY <> 0
                WOPT = 2                        : # 2 : diminution manquant seuls
            Endif
            Call DIMALL(WVCRTYP, WSCONUM, WSCILIN, WSCMLIN, WITM, WOPT, WQTY, WALLQTY, WSHTQTY, LRET) From STKALL
            If LRET <> 0  : End : Endif
#           Quantité allouée qui a été diminuée
            WALLSTU = WALLQTY
            WSHTSTU = WSHTQTY
        Endif
     When "E" : # ------ Passage de global à détail -----------
# ----- suppression allocations + manquants
        WOPT = 0    :
        WALLQTY = 0 : WSHTQTYSUP = 0
        Call DELALL(WVCRTYP, WSCONUM, WSCILIN, WSCMLIN, WITM, WOPT, WALLQTY, WSHTQTYSUP, LRET) From STKALL
        If LRET <> 0  : End : Endif

# ----- création nouvelles allocations
        [M:ALP]QTY = LALL + LSHT
        Call GENSTOALL(WMAJ, LALLTYP, WRUP, WALLPAR, LRET) From STKALL
        If LRET <> 0  : End : Endif
#       Quantité qui a été allouée
        WALLSTU = [M:ALP]ALLQTY
#       Quantité rupture
        WSHTSTU = [M:ALP]ALLQTYSHT
     When Default :
        End
Endcase
LALL = WALLSTU
LSHT = WSHTSTU
$FIN_ALLOCATION
If LRET <> 0  : LALLSTU =0   : Endif
End

#########################################################################
# Allocation d une matière d un ordre de sous-traitance                 #
#########################################################################
Subprog ALLOC_MAT(LTRT, LTRS, LSCONUM, LALLTYP, LDESALL, LRET, LITM, LSCILIN, LSCMLIN, QTYBESOIN)
Value     Char     LTRT
Value     Integer  LTRS
Value     Char     LSCONUM
Value     Integer  LALLTYP
Value     Integer  LDESALL
Variable  Integer  LRET
Value     Char     LITM
Value     Integer  LSCILIN
Value     Integer  LSCMLIN
Value     Decimal  QTYBESOIN

Local     Integer  WALLTYP
Local     Integer  WRET
Local     Decimal  WCPLQTY
Local     Decimal  WALL, WSHT, WECART
Local     Integer  MEMSTA
Local     Char     WCLE(50)
Local     Integer  WALLTYP
Local     Char     WTRT(1)

Gosub OPEN_FILES_SCO From SCOLIB
If clalev([F:ORD]) = 0 : Local File ORDERS  [ORD] : Endif
If clalev([M:ORDK])= 0 : Local Mask ORDK    [ORDK] : Endif

# début de la transaction d'allocation
GOK=1
LRET=0
WTRT = LTRT
If LTRS = 1
    Call DEBTRANS From GLOCK
Endif
$TR_ALLOCMAT
If LTRS = 1
    Trbegin ADOVAL
Endif
    Readlock [SCO]SCO0=LSCONUM
    If fstat=1  : GOK=-1: LRET = 1 : GLOCK="$SCOHEAD"-LSCONUM             : Goto ROLL_ALLOCMAT
    Elsif fstat : GOK=0 : LRET = 1 : Call RSTA("SCO", LSCONUM) From GLOCK : Goto AB_ALLOCMAT: Endif
    #

    Readlock [SCM]SCM0=LSCONUM;LSCILIN;LSCMLIN
    WCLE = LSCONUM-num$(LSCILIN)-num$(LSCMLIN)-LITM
    If fstat=1
       GOK=-1: LRET = 1 : GLOCK="$SCOMAT"-WCLE              : Goto ROLL_ALLOCMAT
    Elsif fstat
       GOK=0 : LRET = 1 : Call RSTA("SCM", WCLE) From GLOCK : Goto AB_ALLOCMAT
    Endif

    If LTRT <> "A" & [F:SCM]MATSTA > 2  : Goto SUIVMAT : Endif
    LTRT = WTRT
    # mémo statut
    MEMSTA = [F:SCM]ALLSTA
    # si désallocation et matière non allouée, pas de traitement
    If LTRT = "A" & [F:SCM]ALLSTA = 1    : Goto SUIVMAT : Endif
    # si désallocation des globales uniquement et allocation détail, pas de traitement
    If LTRT = "A" & LDESALL = 2 & LALLTYP = 1 & !find([F:SCM]ALLSTA,2,3) : Goto SUIVMAT : Endif
    # si désallocation des détails uniquement et allocation globale, pas de traitement
    If LTRT = "A" & LDESALL = 2 & LALLTYP = 2 & !find([F:SCM]ALLSTA,4,5) : Goto SUIVMAT : Endif
    # si demande allocation globale et matière allouée détail, pas de traitement
    If LTRT = "C" & LALLTYP = 1 & [F:SCM]ALLSTA > 3 : Goto SUIVMAT : Endif
    # si passage de global vers détail, mode "E"
    If ( LTRT = "C" & LALLTYP=2 & [F:SCM]ALLSTA > 1 & [F:SCM]ALLSTA < 4)
       LTRT = "E"
    Endif

    # si désallocation et matière non allouée, pas de traitement
    If LTRT = "R" & [F:SCM]ALLSTA = 1    : Goto SUIVMAT : Endif
    # si désallocation des globales uniquement et allocation détail, pas de traitement
    If LTRT = "R" & LDESALL = 2 & LALLTYP = 1 & !find([F:SCM]ALLSTA,2,3) : Goto SUIVMAT : Endif
    # si désallocation des détails uniquement et allocation globale, pas de traitement
    If LTRT = "R" & LDESALL = 2 & LALLTYP = 2 & !find([F:SCM]ALLSTA,4,5) : Goto SUIVMAT : Endif

    Case LTRT
        When "C","M":
                      If [F:SCM]ALLQTY = 0 & [F:SCM]SHTQTY = 0
                          TRTLIG = "C"
                      Else
                          TRTLIG="M"
                      Endif
                      WALL    = [F:SCM]RETQTY - [F:SCM]ALLQTY - [F:SCM]SHTQTY - [F:SCM]USEQTY
                      WSHT    = [F:SCM]SHTQTY
                      WALLTYP = LALLTYP
                      If QTYBESOIN <> 0
                          WALL = QTYBESOIN
                      Endif
                      If WALL <= 0 & WSHT <= 0 : Goto SUIVMAT : Endif
        When "A":     TRTLIG  = "A"
                      WALL    = [F:SCM]ALLQTY
                      WSHT    = [F:SCM]SHTQTY
                      If LDESALL = 1
                          Case [F:SCM]ALLSTA
                               When 2,3: WALLTYP = 1
                               When 4,5: WALLTYP = 2
                          Endcase
                      Else
                          WALLTYP = LALLTYP
                      Endif
        When "R":     TRTLIG  = "A"
                      WALL    = [F:SCM]RETQTY - [F:SCM]ALLQTY - [F:SCM]SHTQTY - [F:SCM]USEQTY
                      WSHT    = [F:SCM]SHTQTY
                      If LDESALL = 1
                          Case [F:SCM]ALLSTA
                               When 2,3: WALLTYP = 1
                               When 4,5: WALLTYP = 2
                          Endcase
                      Else
                          WALLTYP = LALLTYP
                      Endif
                      If WALL <= 0 & WSHT <= 0 : Goto SUIVMAT : Endif
        When "E":     TRTLIG  = "E"
                      WALL    = [F:SCM]ALLQTY
                      WSHT    = [F:SCM]SHTQTY
                      WALLTYP = LALLTYP
                      If WALL <= 0 & WSHT <= 0 : Goto SUIVMAT : Endif
    Endcase


    # appel à la routine de gestion des allocations
    Call ALLOCATION(TRTLIG, WALLTYP, WALL, WSHT, WRET)
    If WRET  = 9
        Gosub REWRITE_SCM From SCOLIB
        WRET = 0
        Goto SUIVMAT
    Endif
    If WRET <> 0 : LRET = 1 : Goto AB_ALLOCMAT : Endif

    # mise à jour matière
    Case LTRT
        When "C","M": [F:SCM]ALLQTY    += WALL
                      [F:SCM]SHTQTY     = WSHT
                      Case LALLTYP
                        When 1: [F:SCM]ALLSTA = 3
                        When 2: [F:SCM]ALLSTA = 5
                      Endcase
        When "A","R": [F:SCM]ALLQTY     = 0
                      [F:SCM]SHTQTY     = 0
                      [F:SCM]ALLSTA     = 1
        When "E":     [F:SCM]ALLQTY     = WALL
                      [F:SCM]SHTQTY     = WSHT
                      [F:SCM]ALLSTA     = 5
    Endcase
    # si rupture, maj statut allocation
    If [F:SCM]SHTQTY <> 0 : [F:SCM]ALLSTA -= 1 : Endif

    # mise à jour de l'encours
    Call UPDATE_MSX("M", 0) From SCOLIB

    # mise à jour matière
    Gosub REWRITE_SCM From SCOLIB
$SUIVMAT
    If GOK<0 : LRET = 1 : Goto ROLL_ALLOCMAT : Endif

    # mise à jour entête
    Gosub MAJSCOHEAD From SCOLIB
    #
    Gosub REWRITE_SCO From SCOLIB
    If GOK<0 : LRET = 1 : Goto ROLL_ALLOCMAT : Endif

    # v6 affectations
    Gosub MAJ_MTO_SCM From SCOMTOLIB
#
$TR_FINMAT
If LTRS = 1
    Commit
Endif
End

$ROLL_ALLOCMAT
If LTRS = 1
    Rollback  : Call ROLL From GLOCK
    If !GROLL : LRET = 0 : Goto TR_ALLOCMAT : Endif
Endif
End

$AB_ALLOCMAT
If LTRS = 1
    Rollback
Endif


End

#########################################################################
# Purge des ruptures sur un emplacement approvisionné                   #
# llc 02.02
#########################################################################
Subprog ALLOC_APPROMAT(LTRS, LFCY, LITM, LLOC, LRET)
Value     Integer  LTRS
Value     Char     LFCY
Value     Char     LITM
Value     Char     LLOC
Variable  Integer  LRET

Local     Char     WMESS(85)
Local     Char     WMESS1(85)
Local     Char     WMESS2(85)
Local     Integer  WRET

If clalev([F:SCM]) = 0 : Local File SCOMAT  [SCM] : Endif
If clalev([F:STA]) = 0 : Local File STOALL  [STA]  : Endif

Filter [SCM] Where STOFCY = LFCY &
&                  ITMREF = LITM &
&                  LOC    = LLOC
For [SCM]SCM1
    Filter [STA] Where STOFCY = [F:SCM]STOFCY &
&                      ITMREF = [F:SCM]CPNITMREF &
&                      VCRTYP = 36            &
&                      VCRNUM = [F:SCM]SCONUM &
&                      VCRLIN = [F:SCM]SCILIN &
&                      VCRSEQ = [F:SCM]SCMLIN &
&                      ALLTYP = 4
&                Order By Key STA2               # llc 05.02 14394 Performances
    For [STA]
        If fstat : Break : Endif
        Call ALLOC_MAT("C", LTRS, [F:SCM]SCONUM, 2, 0, WRET, [F:SCM]CPNITMREF, [F:SCM]SCILIN, [F:SCM]SCMLIN , 0) From SCOALL
        If WRET = 1
            LRET = 1
            # FQ 69909 Ctrl des sources avant 2 x Filter + End
        Endif
        Break
    Next
    Filter [STA]
    If LRET=1 Break Endif # FQ 69909 Ctrl des sources ligne ajoutée suite au remplacement du End
Next

Filter [SCM]
End

#########################################################################
# Mise à jour matière après allocation manuelle                         #
#########################################################################
Subprog MAJALLMAT(LSCONUM, LSCILIN, LSCMLIN, LITM, LQTY, LSHT, LMOD, LRET)
Value     Char     LSCONUM
Value     Integer  LSCILIN
Value     Integer  LSCMLIN
Value     Char     LITM
Value     Decimal  LQTY
Value     Decimal  LSHT
Value     Integer  LMOD
Variable  Integer  LRET

# FQ 70409 GA 01/2011 nouvelle fonction simplifiée pour les performances
Call MAJALLMAT2(LSCONUM, LSCILIN, LSCMLIN, LITM, LQTY, LSHT, LMOD, LRET)

# Maj de l'entete d'EO
Call MAJALLSCO (LSCONUM, LSCILIN, LSCMLIN, LITM, LRET)

End

#########################################################################
# Mise à jour matière après allocation manuelle                         #
#########################################################################
Subprog MAJALLMAT2(LSCONUM, LSCILIN, LSCMLIN, LITM, LQTY, LSHT, LMOD, LRET)
Value     Char     LSCONUM
Value     Integer  LSCILIN
Value     Integer  LSCMLIN
Value     Char     LITM
Value     Decimal  LQTY
Value     Decimal  LSHT
Value     Integer  LMOD
Variable  Integer  LRET

Local     Integer  MEMSTA

Gosub OPEN_FILES_SCO From SCOLIB
If clalev([F:ORD]) = 0 : Local File ORDERS  [ORD] : Endif
If clalev([M:ORDK])= 0 : Local Mask ORDK    [ORDK] : Endif

# FQ 63624 GA 03/2010 idem MFGALL
# lecture matière
Read [SCM]SCM0=LSCONUM;LSCILIN;LSCMLIN
If fstat : WRET=1 : End : Endif

# si matière soldée ou exclue ou composant Texte, Valo: on ressort sans rien faire
If [F:SCM]MATSTA > 2 | [F:SCM]CPNTYP >= 5 : End : Endif

# lecture matière
Readlock [SCM]SCM0=LSCONUM;LSCILIN;LSCMLIN
If fstat : WRET=1 : Call RSTA("SCM", LSCONUM-num$(LSCILIN)-num$(LSCMLIN)) From GLOCK : End : Endif

# FQ 63624 GA 03/2010 idem MFGALL
# si matière soldée ou exclue ou composant Texte, Valo: on ressort sans rien faire
#If [F:SCM]MATSTA > 2 | [F:SCM]CPNTYP >= 5 : Gosub REWRITE_SCM From SCOLIB : End : Endif

# mémo statut
MEMSTA = [F:SCM]ALLSTA

# lecture entête Ordre de sous-traitance
Readlock [SCO]SCO0=LSCONUM
If fstat : LRET=1 : Call RSTA("SCO", LSCONUM) From GLOCK : End : Endif

# lecture Article lancé
#Readlock [SCI]SCI0=LSCONUM;LSCILIN
#If fstat : LRET=1 : Call RSTA("SCI", LSCONUM) From GLOCK : End : Endif
# Issue 86829 - 2012-12-21 by CCC : Il faut lire SCI pour mettre à jour les alloc
Read [SCI]SCI0=LSCONUM;LSCILIN
If fstat : LRET=1 : Call RSTA("SCI", LSCONUM) From GLOCK : End : Endif


[F:SCM]ALLQTY    = LQTY
[F:SCM]SHTQTY    = LSHT

Case LMOD
    When 1:     If [F:SCM]ALLQTY = 0 & [F:SCM]SHTQTY = 0
                   [F:SCM]ALLSTA = 1
                Else
                   [F:SCM]ALLSTA    = 3
                   # si rupture, maj statut allocation
                   If [F:SCM]SHTQTY <> 0 : [F:SCM]ALLSTA -= 1 : Endif
                Endif
    When 2:     If [F:SCM]ALLQTY = 0 & [F:SCM]SHTQTY = 0
                   [F:SCM]ALLSTA = 1
                Else
                   [F:SCM]ALLSTA    = 5
                   # si rupture, maj statut allocation
                   If [F:SCM]SHTQTY <> 0 : [F:SCM]ALLSTA -= 1 : Endif
                Endif
Endcase

# Emplacement de sous-traitance ?
If clalev([F:STA])=0  Local File STOALL     [STA]   Endif
Filter [STA] Where ITMREF=[F:SCM]CPNITMREF
&                & VCRTYP=36
&                & VCRNUM=[F:SCM]SCONUM
&                & VCRLIN=[F:SCM]SCILIN
&                & VCRSEQ=[F:SCM]SCMLIN
Read [STA]STA2 First
If !fstat & [F:STA]LOC<>""
   [F:SCM]LOC = [F:STA]LOC
Endif
Filter [STA]

# mise à jour matière
Gosub REWRITE_SCM From SCOLIB

# mise à jour de l'encours
Call UPDATE_MSX("M", 0) From SCOLIB

# mise à jour entête
Gosub MAJSCOHEAD From SCOLIB

Gosub REWRITE_SCO From SCOLIB
#Gosub REWRITE_SCI From SCOLIB

# v6 affectations
Gosub MAJ_MTO_SCM From SCOMTOLIB


End


##################################################################
# Routine de mise à jour des allocations matières
# [F:SCO],[F:SCM] doivent être chargés avant l'appel
# LCOD = M,    Modification allocation
# LCOD = A,    Suppression  allocation
##################################################################
Subprog UPDATE_ALL(LCOD)
Value    Char     LCOD
Local    Integer  WRET
Local    Decimal  WALL, WSHT, WWRK, WDIFF
Local    Integer  WALLTYP
Local    Char     WCOD(1),XCOD(1)
Local    Integer  MEMSTA : MEMSTA = [F:SCM]ALLSTA # mémo statut
#
XCOD = LCOD

# Matière non allouée, les codes "A", "M" de maj des alloc sont inopérants
If [F:SCM]ALLSTA <2 & !find(LCOD,"G","D","C") : End : Endif

#Pas d'allocation sur une matière soldée ou dont la quantité prévue est déjà réalisée
If LCOD = "M" & ([F:SCM]SCMTRKFLG = 5 | ([F:SCM]RETQTY - [F:SCM]USEQTY <= 0))
   End
Endif
# Ne pas éliminer allocation de rupture si qté besoin inchangée et mode allocation trs = manuel
If  LCOD = "M" & [F:SCM]SHTQTY<>0
    If ([F:SCM]ALLQTY + [F:SCM]SHTQTY = [F:SCM]RETQTY- [F:SCM]USEQTY) & [F:PTR]MODALL=1
        ####If dim([F:SCO]DOVRALLNBR)> 0 : Gosub MAJSCO : Endif
        End
    Endif
Endif
If find(LCOD,"G","D")
    If LCOD = "G" : WALLTYP = 1 : Endif
    If LCOD = "D" : WALLTYP = 2 : Endif
    #XCOD = "C" # Issue 92646 suite 90321 GA 09/2013 attention aux maj !
    If [F:SCM]ALLQTY + [F:SCM]SHTQTY = 0
       XCOD = "C"
    Else
       XCOD = "M"
    Endif
Else
    Case [F:SCM]ALLSTA
        When 1  :  WALLTYP = 2    # FQ 53991 Par défaut on propose Alloc détaillée
        When 2,3:  WALLTYP = 1    # allocation globale
        When 4,5:  WALLTYP = 2    # allocation détaillée
    Endcase
Endif
#
Case XCOD
    When "C":    WALL = [F:SCM]RETQTY
                 WSHT = 0
                 WCOD = "C"
    When "M":    WWRK = [F:SCM]ALLQTY + [F:SCM]SHTQTY
                     If WWRK > [F:SCM]RETQTY - [F:SCM]USEQTY   # si diminution allocation # llc 04.02 13460
                        WDIFF = WWRK - ([F:SCM]RETQTY - [F:SCM]USEQTY)                    # llc 04.02 13460
                        If WDIFF <= [F:SCM]SHTQTY
                            WALL    = 0
                            WSHT    = WDIFF
                        Else
                            WALL    = WDIFF - [F:SCM]SHTQTY
                            WSHT    = [F:SCM]SHTQTY
                        Endif
                        WCOD = "D"
                     Else
                        WALL = [F:SCM]RETQTY - [F:SCM]ALLQTY - [F:SCM]SHTQTY - [F:SCM]USEQTY  # llc 04.02 13460
                        WSHT = [F:SCM]SHTQTY
                        WCOD = "M"
                     Endif
    When "A":        WALL = [F:SCM]ALLQTY
                     WSHT = [F:SCM]SHTQTY
                     WCOD = "A"
Endcase
#
Call ALLOCATION(WCOD, WALLTYP, WALL, WSHT, WRET) From SCOALL
If WRET <> 0 : End : Endif
# mise à jour matière
If [F:SCM]ALLSTA = 1 [F:SCM]ALLSTA= 2 * WALLTYP Endif # FQ 59736 GA 11/2009
Case WCOD
    When "C": [F:SCM]ALLQTY     = WALL
              [F:SCM]SHTQTY     = WSHT
    When "M": [F:SCM]ALLQTY    += WALL
              [F:SCM]SHTQTY     = WSHT
    When "D": [F:SCM]ALLQTY    -= WALL
              [F:SCM]SHTQTY    -= WSHT
    When "A": [F:SCM]ALLQTY = 0
              [F:SCM]SHTQTY = 0
              [F:SCM]ALLSTA = 1                       # FQ 59736 GA 11/2009
Endcase
# mise à jour statut allocation
# sr 03.05 demande 29007 : On ne touche pas cet indicateur si on solde la matière (WCOD = "A")
If  WCOD <> "A"
    Case [F:SCM]ALLSTA
        When 2,4:   If [F:SCM]SHTQTY = 0  : [F:SCM]ALLSTA += 1 : Endif
        When 3,5:   If [F:SCM]SHTQTY <> 0 : [F:SCM]ALLSTA -= 1 : Endif
    Endcase
Endif
Case LCOD
    When "G": If [F:SCM]SHTQTY = 0 : [F:SCM]ALLSTA = 3 : Else : [F:SCM]ALLSTA = 2 : Endif
    When "D": If [F:SCM]SHTQTY = 0 : [F:SCM]ALLSTA = 5 : Else : [F:SCM]ALLSTA = 4 : Endif
Endcase
####If dim([M:SCO1]OVRALLNBR)> 0 : Gosub MAJSCO : Endif
#
End

#-----------------------------------------------------------------------#
# Mise à jour de l'entete EO                      # FQ 70409 GA 01/2011 #
#-----------------------------------------------------------------------#
Subprog MAJALLSCO(LNUM, LLIN, LSEQ, LITM, LRET)
Value     Char     LNUM
Value     Integer  LLIN
Value     Integer  LSEQ
Value     Char     LITM
Variable  Integer  LRET
Local Integer XTOT
Local Integer I
#
  If LNUM="" End Endif
  LRET=0

  Gosub OPEN_FILES_SCO From SCOLIB

  Readlock [SCO]SCO0=LNUM
  If fstat = 1
     GOK = -1 : GLOCK = "$SCOHEAD"+[F:SCO]SCONUM
     LRET=1 : End
  Elsif fstat
     GOK = 0  : Call RSTA("SCO",   [F:SCO]SCONUM) From GLOCK
     LRET=2 : End
  Endif
#
  Gosub MAJSCOHEAD From SCOLIB
#
  Rewrite [SCO]
  If fstat
     GOK = 0 : Call FSTA("SCO") From GLOCK
     LRET=2 : End
  Endif
#
End

