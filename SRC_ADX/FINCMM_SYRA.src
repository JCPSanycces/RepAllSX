#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################################################################
# ROUTINES ABOUT COMMITMENTS
##############################################################################################################
# UPD_CMM      : Updates or creates automatically a commitment
#
# Private routines :
# _IS_TOTRECEIP : Checks if the receipt is total or not
# _UPD_CMM      : Updates or Creates automatically a commitment
##############################################################################################################

########################################################################################################
## UPD_CMM
########################################################################################################
#**
#* This Funprog is called from the purchasing process and the  commitments carry forward<br>
#* Returns the commitment number created or updated, and the status of the creation/update operation
#*
#* @param ACTX	    Context
#* @param MYLOG     C_ALOG ou AVOID.AINS
#* @param DAT       Date
#* @param SITE      Site
#* @param CUR       Currency of the amount of commitment
#* @param AMT       Amount of the commitment
#* @param RATDIV    Array of divisor rates
#* @param RATMLT    Array of multiplier rates
#* @param QTY       Quantity
#* @param ACC       Array of accounts
#* @param LED       Array of the leger codes matching the array of accounts
#* @param BPR       Business Partner
#* @param DIE       Array of the dimension types
#* @param CCE       Array of the dimensions matching the order of the dimensions types
#* @param SENS      1=Expense -1=Revenue
#* @param SIGN      1=Engage the amount of the commitment -1=Desengage amount of the commitment
#* @param CMMTYP    1=Precommitment 2=Commitment (ML 631)
#* @param CTLBUD    1=Activate the budget control when the balance is updated
#* @param DOCUMENT  (1)Number of the source document (2)Line number of the source document
#* @param REASON    (1) Reason for action (ML 2683)  (2) Document reason (ML 2684)
#* @param AUTJOUCOD Automatic journal code (Code de la pièce automatique)
#* @param IDENT     Identifier of the automatic journal
#* @param TYPVCR    Document type
#* @param NUMVCR    Entry number
#* @param TYPORG    Source document type (ML 2623)
#* @param RATTYP    Rate type (ML 202)
#* @param FCTNAM    Name of the calling fonction
#* @param CMMNUM    Commitment number. It can be populated or not
#* @param ERRMES    Error message
#*!
Funprog UPD_CMM(ACTX,MYLOG,DAT,SITE,CUR,AMT,RATDIV,RATMLT,QTY,ACC,LED,BPR,DIE,CCE,SENS,SIGN,CMMTYP,CTLBUD,DOCUMENT,REASON,AUTJOUCOD,IDENT,TYPVCR,NUMVCR,TYPORG,RATTYP,FCTNAM,CMMNUM,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Instance MYLOG Using OBJECT : # C_ALOG ou AVOID.AINS
Value    Date     DAT              : # Date
Value    Char     SITE             : # Site
Value    Char     CUR              : # Currency of the amount of commitment
Value    Decimal  AMT              : # Amount of the commitment
Value    Decimal  RATDIV(1..)      : # Array of divisor rates
Value    Decimal  RATMLT(1..)      : # Array of multiplier rates
Value    Decimal  QTY              : # Quantity
Value    Char     ACC()(1..)       : # Array of accounts
Value    Char     LED()(1..)       : # Array of the leger codes matching the array of accounts
Value    Char     BPR              : # Business Partner
Value    Char     DIE()(1..)       : # Array of the dimension types
Value    Char     CCE()(1..)       : # Array of the dimensions matching the order of the dimensions types
Value    Integer  SENS             : # 1=Expense -1=Revenue
Value    Integer  SIGN             : # 1=Engage the amount of the commitment -1=Desengage amount of the commitment
Value    Tinyint  CMMTYP           : # 1=Precommitment 2=Commitment <ML 631>
Value    Integer  CTLBUD           : # 1=Activate the budget control when the balance is updated
Value    Char     DOCUMENT()(1..)  : # (1)Number of the source document (2)Line number of the source document
                                   : # (3) Sequence number for orders in PORDERP table
                                   : # (4) Sequence number for open orders in PORDERQ table
Value    Tinyint  REASON(1..)      : # (1) Reason for action <ML 2683>  (2) Document reason <ML 2684>
Value    Char     AUTJOUCOD        : # Automatic journal code (Code de la pièce automatique)
Value    Char     IDENT()(1..)     : # Identifier of the automatic journal
Value    Char     TYPVCR           : # Document type
Value    Char     NUMVCR           : # Entry number
Value    Tinyint  TYPORG           : # Source document type <ML 2623>
Value    Tinyint  RATTYP           : # Rate type <ML 202>
Value    Char     FCTNAM           : # Name of the calling fonction
Variable Char     CMMNUM()         : # Commitment number. It can be populated or not
Variable Char     ERRMES()         : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK
[L]ASTATUS = func _UPD_CMM(ACTX,MYLOG,DAT,SITE,CUR,AMT,RATDIV,RATMLT,QTY,ACC,LED,BPR,DIE,CCE,SENS,SIGN,
&            CMMTYP,CTLBUD,DOCUMENT,REASON,AUTJOUCOD,IDENT,TYPVCR,NUMVCR,TYPORG,RATTYP,FCTNAM,CMMNUM,ERRMES)
End [L]ASTATUS

########################################################################################################
## _UPD_CMM
########################################################################################################
#**
#* This Funprog is called from the purchasing process and the carry forward commitments.<br>
#* Returns the commitment number created or updated, and the status of the creation/update operation
#*
#* @private
#* @param ACTX      Context
#* @param MYLOG     C_ALOG ou AVOID.AINS
#* @param DAT       Date
#* @param SITE      Site
#* @param CUR       Currency of the amount of commitment
#* @param AMT       Amount of the commitment
#* @param RATDIV    Array of divisor rates
#* @param RATMLT    Array of multiplier rates
#* @param QTY       Quantity
#* @param ACC       Array of accounts
#* @param LED       Array of the leger codes matching the array of accounts
#* @param BPR       Business Partner
#* @param DIE       Array of the dimension types
#* @param CCE       Array of the dimensions matching the order of the dimensions types
#* @param SENS      1=Expense -1=Revenue
#* @param SIGN      1=Engage the amount of the commitment -1=Desengage amount of the commitment
#* @param CMMTYP    1=Precommitment 2=Commitment (ML 631)
#* @param CTLBUD    1=Activate the budget control when the balance is updated
#* @param DOCUMENT  (1)Number of the source document (2)Line number of the source document
#* @param REASON    (1) Reason for action (ML 2683)  (2) Document reason (ML 2684)
#* @param AUTJOUCOD Automatic journal code (Code de la pièce automatique)
#* @param IDENT     Identifier of the automatic journal
#* @param TYPVCR    Document type
#* @param NUMVCR    Entry number
#* @param TYPORG    Source document type (ML 2623)
#* @param RATTYP    Rate type (ML 202)
#* @param FCTNAM    Name of the calling fonction
#* @param CMMNUM    Commitment number. It can be populated or not
#* @param ERRMES    Error message
#*!
Funprog _UPD_CMM(ACTX,MYLOG,DAT,SITE,CUR,AMT,RATDIV,RATMLT,QTY,ACC,LED,BPR,DIE,CCE,SENS,SIGN,CMMTYP,CTLBUD,DOCUMENT,REASON,AUTJOUCOD,IDENT,TYPVCR,NUMVCR,TYPORG,RATTYP,FCTNAM,CMMNUM,ERRMES)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Value    Instance MYLOG Using OBJECT : # C_ALOG ou AVOID.AINS
Value    Date     DAT              : # Date
Value    Char     SITE             : # Site
Value    Char     CUR              : # Currency of the amount of commitment
Value    Decimal  AMT              : # Amount of the commitment
Value    Decimal  RATDIV(1..)      : # Array of divisor rates
Value    Decimal  RATMLT(1..)      : # Array of multiplier rates
Value    Decimal  QTY              : # Quantity
Value    Char     ACC()(1..)       : # Array of accounts
Value    Char     LED()(1..)       : # Array of the leger codes matching the array of accounts
Value    Char     BPR              : # Business Partner
Value    Char     DIE()(1..)       : # Array of the dimension types
Value    Char     CCE()(1..)       : # Array of the dimensions matching the order of the dimensions types
Value    Integer  SENS             : # 1=Expense -1=Revenue
Value    Integer  SIGN             : # 1=Engage the amount of the commitment -1=Desengage amount of the commitment
Value    Tinyint  CMMTYP           : # 1=Precommitment 2=Commitment <ML 631>
Value    Integer  CTLBUD           : # 1=Activate the budget control when the balance is updated
Value    Char     DOCUMENT()(1..)  : # (1)Number of the source document (2)Line number of the source document
                                   : # (3) Sequence number for orders in PORDERP table
                                   : # (4) Sequence number for open orders in PORDERQ table
Value    Tinyint  REASON(1..)      : # (1) Reason for action <ML 2683>  (2) Document reason <ML 2684>
Value    Char     AUTJOUCOD        : # Automatic journal code (Code de la pièce automatique)
Value    Char     IDENT()(1..)     : # Identifier of the automatic journal
Value    Char     TYPVCR           : # Document type
Value    Char     NUMVCR           : # Entry number
Value    Tinyint  TYPORG           : # Source document type <ML 2623>
Value    Tinyint  RATTYP           : # Rate type <ML 202>
Value    Char     FCTNAM           : # Name of the calling fonction
Variable Char     CMMNUM()         : # Commitment number. It can be populated or not
Variable Char     ERRMES()         : # Error message

Local Integer ASTATUS : [L]ASTATUS = [V]CST_AOK

Gosub DECL_VAR
Gosub OPEN_FILE
Call LEC_ACV("GDD", FLGGDD) From CPTLEC
If FLGGDD=1
 Gosub OPEN_FILE_GDD
Endif

Gosub LOAD_ACACHE_CLASS
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

Case TYPORG
 When 3   : PURTYP = 1 :# Purchase request - Demande d'achat => Pre commitment
 When 1,2 : PURTYP = 2 :# Order or delivery request - Commande ou Demande de livraison qui provient d'une commande ouverte => Commitment
Endcase

Raz PURLIN, PURSEQ, ANALIN
PURNUM = DOCUMENT(1)                                     : # Number of the source purchase document
If dim(DOCUMENT)>=2 : PURLIN = val(DOCUMENT(2)) : Endif  : # Line number of the purchase document
If dim(DOCUMENT)>=3 : PURSEQ = val(DOCUMENT(3)) : Endif  : # Sequence number (for the purchase orders)
If TYPORG=2 & dim(DOCUMENT)>=4 : [L]ANALIN = val(DOCUMENT(4)) : Endif : # (4) Sequence number for open orders in PORDERQ table

Call LEC_GCM(ACM) From CPTLEC
LEDTYPANA = [F:GCM]ANALEDTYP

ALREADY_READ = 0
CTL_ISNEWLED = 0
NEW_LINNUM   = 1
If CMMNUM=""
 CREENG = 1
Else
 Readlock [F:CMM]CMM0=CMMNUM
 If fstat=1
  Call RSTA("CMM",CMMNUM,ACTX,[L]ASTATUS) From ASYRSUB : End [L]ASTATUS
 Elsif fstat
  CREENG = 1
 Else
  CREENG = 0
  Raz [F:CMD]
  Filter [CMD] Where NUM=CMMNUM Order By Key CMD0 Desc
  For [CMD]
   CTL_ISNEWLED = 1
   NEW_LINNUM   = [F:CMD]LIN+1
   Break
  Next
  Filter [CMD]
 Endif
Endif

# Keep only, from [L]LED, the ledgers ticked commitment and existing in the account core model of the company and
# ledger that was not added. 60018 If a new commitment ledger is added, the purchase requests &  purchase orders
# are not updated with the new ledger. Then, if a purchase request that does not have this new ledger is taken into
# account in a purchase order after adding the ledger, we do not have to update the commitment on this new ledger.
# Keep the others informations matching the ledger
NBRCMMLED = 0
NBRDIE = 0
For I=1 To dim([L]LED)
 J = find([L]LED(I),[F:GCM]LED(0..dim([F:GCM]LED)-1))
 If J
  Read [LED]LED0 = [F:GCM]LED(J-1)
  If !fstat & [F:LED]CMM=2 & ( !CTL_ISNEWLED | (find(J,[F:CMD]LEDTYP(0..dim([F:CMD]LEDTYP)-1))) )
   NBRCMMLED +=1
   CMMLEDTYP(NBRCMMLED) = J
   CMMLED(NBRCMMLED)    = [F:GCM]LED(J-1)
   CMMCURLED(NBRCMMLED) = [F:GCM]CUR(J-1)
   CMMACC(NBRCMMLED)    = [L]ACC(I)
   CMMCOA(NBRCMMLED)    = [F:LED]COA
   CMMDACRAT(NBRCMMLED) = [F:GCM]DACRAT(J-1)
   CMMRATDIV(NBRCMMLED) = [L]RATDIV(I)
   CMMRATMLT(NBRCMMLED) = [L]RATMLT(I)
   CMMBUDFLG(NBRCMMLED) = [F:LED]BUD
   For K=0 To [F:LED]DIENBR-1
    X = find([F:LED]DIE(K),DIE(1..dim(DIE)))
    If X & !find([F:LED]DIE(K),CMMDIE(1..dim(CMMDIE)))
     NBRDIE +=1
     CMMDIE(NBRDIE) = DIE(X)
     CMMCCE(NBRDIE) = CCE(X)
     # To manage the particularities of the operation budgets, we separate the dimension sections of commitments
     # from dimension sections of budget lines. See envelope changes for annual envelopes in Invoice receivables & Credits to receive
     # (Gestion des factures et avoirs à recevoir)
     CMDDIE(NBRDIE) = DIE(X)
     CMDCCE(NBRDIE) = CCE(X)
     BUDDIE(NBRDIE) = DIE(X)
     BUDCCE(NBRDIE) = CCE(X)
    Endif
   Next
  Endif
 Endif
Next
If NBRCMMLED=0
 [L]ASTATUS = [V]CST_AERROR : ERRMES = mess(199,107,1) : End [L]ASTATUS
Endif

I_LEDTYPANA = find(LEDTYPANA,CMMLEDTYP(1..NBRCMMLED))
If I_LEDTYPANA
 LEDTYPREF = LEDTYPANA
Else
 LEDTYPREF   = CMMLEDTYP(1)
 I_LEDTYPANA = 1
Endif

# Search and check the fiscalyear and the period for [L]dat
[L]ASTATUS = func FINPER_SYRA.GET_PER(ACTX, COMPANY, LEDTYPREF, DAT, FIY, PERIOD, ERRMES)
If FIY=0 | PERIOD=0
 [L]ASTATUS = [V]CST_AERROR : ERRMES = num$(DAT)-mess(1,104,1) : End [L]ASTATUS
Endif
Read [FIY]FIY0=COMPANY;LEDTYPREF;FIY
If [F:FIY]FIYSTA<>2 : [L]ASTATUS = [V]CST_AERROR : ERRMES = mess(1,104,1)-num$(DAT)-mess(20,101,1) : End [L]ASTATUS : Endif
If [F:FIY]FIYSTA=3  : [L]ASTATUS = [V]CST_AERROR : ERRMES = mess(1,104,1)-num$(DAT)-mess(42,101,1) : End [L]ASTATUS : Endif
Read [PER]PER0=COMPANY;LEDTYPREF;FIY;PERIOD
If [F:PER]PERSTA<>2 : [L]ASTATUS = [V]CST_AERROR : ERRMES = mess(1,104,1)-num$(DAT)-mess(35,101,1) : End [L]ASTATUS : Endif
If [F:PER]PERSTA=3  : [L]ASTATUS = [V]CST_AERROR : ERRMES = mess(1,104,1)-num$(DAT)-mess(36,101,1) : End [L]ASTATUS : Endif
CMDFIY = FIY
CMDPER = PERIOD

If adxtyp=33
 GPOINT = "ENGAGE" : Gosub ENTREE From EXEFNC
Endif
If CREENG=-1 : End [L]ASTATUS : Endif

# Allocates a sequence number to the new commitment
If CREENG
 Gosub GET_COUNTER
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
Endif

# Lock
SYMBOLE = "CMM"+CMMNUM
Lock =SYMBOLE
If fstat=1
 [L]ASTATUS = [V]CST_AWARNING : ERRMES = mess(CMMTYP,631,1)-CMMNUM+"\"+mess(20,100,1)-mess(56,100,1)-SYMBOLE : End [L]ASTATUS
Endif

# Update CMMAMTLED()
Gosub CAL_AMOUNT

# Update GCOMMIT[CMM] table
If CREENG
 Raz [F:CMM]
 [F:CMM]NUM = CMMNUM
 Case CMMTYP
  When 1 : [F:CMM]TYP = 1 : # Pré-Engagement
  When 2 : [F:CMM]TYP = 2 : # Engagement
 Endcase
 For I=0 To len(mess(0,2644,1))-1
  K = find(I+1,CMMLEDTYP(1..NBRCMMLED))
  If K
   [F:CMM]LED(I)    = CMMLED(K)
   [F:CMM]CURLED(I) = CMMCURLED(K)
   [F:CMM]RATMLT(I) = CMMRATMLT(K)
   [F:CMM]RATDIV(I) = CMMRATDIV(K)
  Endif
 Next
 [F:CMM]CPY    = COMPANY
 [F:CMM]FCY    = SITE
 [F:CMM]BPR    = BPR
 [F:CMM]CUR    = CUR
 [F:CMM]TYPCUR = RATTYP
 If SENS=-1    : [F:CMM]SNS    = 2 : # Revenue <ML 632>
 Elsif SENS=1  : [F:CMM]SNS    = 1 : # Expense <ML 632>
 Endif
 If TYPVCR<>"" : [F:CMM]TYPREF = TYPVCR : Endif
 If NUMVCR<>"" : [F:CMM]NUMREF = NUMVCR : Endif
 [F:CMM]TYPORG = TYPORG
 [F:CMM]NUMORG = DOCUMENT(1)
 [F:CMM]CREDAT = date$
 [F:CMM]CREUSR = ACTX.USER
 Gosub EVAL_HEA
 If [F:CMM]REFINT="" : [F:CMM]REFINT = DOCUMENT(1) : Endif
 If [F:CMM]DESVCR="" : [F:CMM]DESVCR = mess(28,104,1) : Endif
 Write [CMM]

Else

 [F:CMM]BPR    = BPR
 [F:CMM]CUR    = CUR
 [F:CMM]UPDDAT = date$
 [F:CMM]UPDUSR = ACTX.USER
 If TYPVCR<>"" : [F:CMM]TYPREF = TYPVCR : Endif
 If NUMVCR<>"" : [F:CMM]NUMREF = NUMVCR : Endif
 [F:CMM]TYPORG = TYPORG
 [F:CMM]NUMORG = DOCUMENT(1)
 Rewrite [CMM]

Endif

If fstat
 Call FSTA("CMM",ACTX,[L]ASTATUS) From ASYRSUB
 End [L]ASTATUS
Endif

# Update GCOMMITD[CMD] table
If FLGGDD
 Gosub BUO_CLOSING
 If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif
Endif

# Update BUDPURAUD [BUA] : the audit table
Gosub UPD_BUA
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

Raz [F:CMD]
[F:CMD] = [F:CMM]
[F:CMD]LIN    = NEW_LINNUM
[F:CMD]FCYLIN = SITE
[F:CMD]BPRACC = BPR
[F:CMD]ACCDAT = CMDDAT
[F:CMD]FIY    = CMDFIY
[F:CMD]PER    = CMDPER
[F:CMD]AMTCUR += SIGN*AMT
[F:CMD]GRDACT = REASON(1)
[F:CMD]GRDPCE = REASON(2)

OKQTY = 0
For I=0 To len(mess(0,2644,1))-1
 K = find(I+1,CMMLEDTYP(1..NBRCMMLED))
 If K
  [F:CMD]LED(I)    = CMMLED(K)
  [F:CMD]LEDTYP(I) = CMMLEDTYP(K)
  [F:CMD]COA(I)    = CMMCOA(K)
  [F:CMD]ACC(I)    = CMMACC(K)
  [F:CMD]CURLED(I) = CMMCURLED(K)
  [F:CMD]AMTLED(I) += SIGN*CMMAMTLED(K)
  If !OKQTY
   Call LEC_GAC(CMMACC(K),CMMCOA(K)) From CPTLEC
   If [F:GAC]FLGUOM=2 : OKQTY=1 : Endif
  Endif
 Else
  [F:CMD]LEDTYP(I) = 0
 Endif
Next

If OKQTY
 [F:CMD]QTY += SIGN*QTY
 [F:CMD]UOM = [F:GAC]UOM
Else
 [F:CMD]QTY = 0
 [F:CMD]UOM = ""
Endif

For I=1 To dim([F:CMD]DIE)
 [F:CMD]DIE(I-1) = CMMDIE(I)
 [F:CMD]CCE(I-1) = CMDCCE(I)
Next

Gosub EVAL_LIN
If [F:CMD]DES=""
 For I=0 To dim([F:CMD]ACC)-1
  If [F:CMD]ACC(I)<>""
   Call LECTEXTRA(ACTX,"",[F:CMD]DES,"GACCOUNT","DESTRA",[F:CMD]COA(I),[F:CMD]ACC(I)) From ASYRFNC
   Break
  Endif
 Next
Endif

Write [CMD]
If fstat
 Call FSTA("CMD",ACTX,[L]ASTATUS) From ASYRSUB
 End [L]ASTATUS
Else
 If FCTNAM="CMMREP" & MYLOG<>AVOID.AINS
  [L]ASTATUS = fmet MYLOG.APUTLINE(mess(CMMTYP,631,1)-CMMNUM-":"-format$(ACTX.AINTL.SHORTDATE,DAT)-":"-mess(REASON(1),2683,1)-mess(REASON(2),2684,1)-":"-num$(SIGN*AMT),[V]CST_AOK)
 Endif
Endif

Gosub UPD_BAL_BUD
If [L]ASTATUS>=[V]CST_AERROR : End [L]ASTATUS : Endif

End [L]ASTATUS

##############################################################################################################
$LOAD_ACACHE_CLASS
I = fmet ACTX.ACACHE.AFCY.AGETINDEX(SITE)
If I = [V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = SITE-mess(15,104,1) : Return
Endif

COMPANY = fmet ACTX.ACACHE.AFCY.AGETVALCHAR(SITE,"LEGCPY")

I = fmet ACTX.ACACHE.ACPY.AGETINDEX(COMPANY)
If I = [V]CST_ANOTDEFINED
 [L]ASTATUS = [V]CST_AERROR : ERRMES = COMPANY-mess(16,104,1) : Return
Endif

CPYCUR  = fmet ACTX.ACACHE.ACPY.AGETVALCHAR(COMPANY,"ACCCUR")
ACM     = fmet ACTX.ACACHE.ACPY.AGETVALCHAR(COMPANY,"ACM")
LEGCPY  = fmet ACTX.ACACHE.ACPY.AGETVALCHAR(COMPANY,"LEG")
Return

##############################################################################################################
$DECL_VAR
Local Char    COMPANY(GLONCPY)       : # Legal company of the site
Local Char    CPYCUR(GLONCUR)        : # Company currency
Local Char    ACM(GLONGCM)           : # Account core model of the company
Local Char    LEGCPY(GLONADI)        : # Legislation of the company
Local Tinyint LEDTYPANA              : # Type of main analytical ledger
Local Tinyint LEDTYPREF              : # Type of the reference ledger
Local Integer I_LEDTYPANA            : # Index of LEDTYPANA in the CMMLEDTYP array

Local Integer NBRCMMLED              : # Number of the ledgers ticked commitments in the [L]LED parameter
Local Integer CTL_ISNEWLED           : # If the commitment exists do not take the commitment ledgers added after the creation of the commitment
Local Integer NBRDIE                 : # Number of the dimension types
Local Char    CMMDIE(GLONDIE)(1..20) : # Array of all the dimension types
Local Char    CMMCCE(GLONCCE)(1..20) : # Array of all the dimensions
Local Integer CMMLEDTYP(1..len(mess(0,2644,1)))          : # Array of the ledger types ticked commitment in the [L]LED parameter
Local Char    CMMLED(GLONLED)(1..len(mess(0,2644,1)))    : # Array of the ledger codes, matching the order of the commitment ledgers (CMMLEDTYP)
Local Char    CMMCURLED(GLONCUR)(1..len(mess(0,2644,1))) : # Array of the ledger currencies, matching the order of CMMLEDTYP
Local Char    CMMACC(GLONGAC)(1..len(mess(0,2644,1)))    : # Array of the accounts comming from the [L]ACC parameter, matching the order of CMMLEDTYP
Local Char    CMMCOA(GLONCOA)(1..len(mess(0,2644,1)))    : # Array of the charts of accounts, matching the order of CMMLEDTYP
Local Integer CMMDACRAT(1..len(mess(0,2644,1)))          : # Array of the rate entries in the ACM, matching the order of CMMLEDTYP
Local Decimal CMMRATMLT(1..len(mess(0,2644,1)))          : # Array of the multiplier rates in the ACM, matching the order of CMMLEDTYP
Local Decimal CMMRATDIV(1..len(mess(0,2644,1)))          : # Array of the divisor rates in the ACM, matching the order of CMMLEDTYP
Local Integer CMMBUDFLG(1..len(mess(0,2644,1)))          : # Array of the budget flags, matching the order of CMMLEDTYP
Local Decimal CMMAMTLED(1..len(mess(0,2644,1)))          : # Array of the amounts in the ledger currency

# For operation budget, in the invoice receivables (facture à recevoir) and the credits to receive (avoir à recevoir)
# Separate dimensions of commitment from dimension of line commitment when changes of envelope happen on annual envelope
Local Char    CMDDIE(GLONDIE)(1..20) : # Array of the dimension types axes for the commitment line
Local Char    CMDCCE(GLONCCE)(1..20) : # Array of all the dimensions for the commitment line
Local Date    CMDDAT : CMDDAT=DAT    : # Date of the commitment line
Local Integer CMDFIY,CMDPER          : # Fiscal year and period matches the date of the commitment line
Local Char    BUDDIE(GLONDIE)(1..20) : # Array of the dimension types axes for the budget line
Local Char    BUDCCE(GLONCCE)(1..20) : # Array of all the dimensions for the budget line
Local Date    BUDDAT : BUDDAT=DAT    : # Date of the budget line

# BUO_CLOSING MAJ_BUD
Local Char    ENTITY(GLONCCE), ENVELOP(GLONCCE), CCE3(GLONCCE)
Local Integer INDENT, INDENV, INDCCE3, OKBUO, YEAFLG
Local Char    BUDCOD(GLONBUP), FCYBUD(GLONFCY)
Local Char    ENVDIE(GLONDIE)
Local Char    DIEENV(GLONDIE), DIEENT(GLONDIE), DIE3(GLONDIE)
Local Char    LEDCOD(GLONLED)        : # Ledger code of the ledger type LEDTYP
Local Char    LEDCUR(GLONCUR)        : # Currency of the ledger type LEDTYP
Local Char    BUDCRI(250)            : # Criteria
Local Char    SITUATION(3)
Local Integer TOTRCP    : # Total receipt flag. Check if the receipt is total or not
Local Integer CMMLFT    : # Commitment left flag. Indicates if there is commitment amount left on order
Local Integer FIYORD    : # Fiscal year of the purchase order
Local Integer PURFRWFIY : # Fiscal year of the carry forward of the commitment
Local Integer FIYCUR    : # Fiscalyear of [L]dat
Local Integer FIYENV    : # Fiscal year of the envelope
Local Date    ENDDAT    : # Paramater required in call func FINPER_SYRA.GET_FIYDATES

Local Integer FIY                    : # Fiscal year of the [L]DAT parameter
Local Integer PERIOD                 : # Period of the [L]DAT parameter
Local Integer CREENG                 : # 1=commitment to create 0=commitment to update. Used in the ENGAGE entry point
Local Char    SYMBOLE(30)
Local Char    CMMCOU(GLONANM)        : # Counter that allocates a sequence number to a new commitment
Local Decimal DIF_AMT                : # Difference between the amount engaged and disengaged due to the rate change variation
Local Decimal AMTLED                 : # Amount of the commitment in the ledger currency
Local Integer NEW_LINNUM             : # Number of the new line to insert in GCOMMITD table
Local Integer OKQTY                  : # =1 if the flag "Unit of work" is ticked in the account
Local Integer PURFRW                 : # =1 if the purchase document is carried forward - Flag indication pièce d'achat reportée
Local Integer FLGGDD                 : # =1 if the GDD activity code is set
Local Integer PURTYP                 : # =1 if Pre commitment =2 if commitment
Local Char    PURNUM(GLONVCR)        : # Number of the source purchase document = DOCUMENT(1)
Local Integer PURLIN                 : # Line number of the purchase document = DOCUMENT(2)
Local Integer PURSEQ                 : # Sequence number (for the purchase orders) = DOCUMENT(3)
Local Integer ANALIN                 : # Sequence of delivery requests  = DOCUMENT(4)
Local Integer ALREADY_READ           : # 1 = Automatic journal is already read 0=Automatic journal is not read yet

Local Integer I,J,K,X,OK
Return

##############################################################################################################
$OPEN_FILE
If adxtyp=33 | !clalev([F:ACV])   : Local File ACTIV     [ACV]  : Endif
If adxtyp=33 | !clalev([F:GCM])   : Local File GACM      [GCM]  : Endif
If adxtyp=33 | !clalev([F:LED])   : Local File GLED      [LED]  : Endif
If adxtyp=33 | !clalev([F:CMM])   : Local File GCOMMIT   [CMM]  : Endif
If adxtyp=33 | !clalev([F:CMD])   : Local File GCOMMITD  [CMD]  : Endif
If adxtyp=33 | !clalev([F:GAC])   : Local File GACCOUNT  [GAC]  : Endif
If adxtyp=33 | !clalev([F:TCA])   : Local File TABCOUAFF [TCA]  : Endif
If adxtyp=33 | !clalev([F:BUA])   : Local File BUDPURAUD [BUA]  : Endif
If adxtyp=33 | !clalev([F:BUD])   : Local File BUD       [BUD]  : Endif
If adxtyp=33 | !clalev([F:BUD2])  : Local File BUD       [BUD2] : Endif
If adxtyp=33 | !clalev([F:CPOH])  : Local File PORDER    [CPOH] : Endif
If adxtyp=33 | !clalev([F:CPOQ])  : Local File PORDERQ   [CPOQ] : Endif
If adxtyp=33 | !clalev([F:CCAL])  : Local File CPTANALIN [CCAL] : Endif
If adxtyp=33 | !clalev([F:CUOP])  : Local File UPORDERP  [CUOP] : Endif
If adxtyp=33 | !clalev([F:CPTH])  : Local File PRECEIPT  [CPTH] : Endif
If adxtyp=33 | !clalev([F:CPTD])  : Local File PRECEIPTD [CPTD] : Endif
If adxtyp=33 | !clalev([F:CPND])  : Local File PRETURND  [CPND] : Endif
If adxtyp=33 | !clalev([F:FIY])   : Local File FISCALYEAR [FIY] : Endif
If adxtyp=33 | !clalev([F:PER])   : Local File PERIOD     [PER] : Endif
Return

$OPEN_FILE_GDD
If adxtyp=33 | !clalev([F:ENV])  : Local File ENVELOPPE [ENV]  : Endif
If adxtyp=33 | !clalev([F:ENV2]) : Local File ENVELOPPE [ENV2] : Endif
If adxtyp=33 | !clalev([F:BUP])  : Local File BUDPAR    [BUP]  : Endif
Return

##############################################################################################################
# Return the counter in CMMCOU
$GET_COUNTER
Raz CMMCOU
Read [TCA]TCA0=2;"";COMPANY
If !fstat
 Case CMMTYP
  When 1 : CMMCOU = [F:TCA]CODNUM(5) : # Pre commitment
  When 2 : CMMCOU = [F:TCA]CODNUM(1) : # Commitment
 Endcase
Endif
If CMMCOU=""
 Read [TCA]TCA0=2;LEGCPY;""
 If !fstat
 Case CMMTYP
  When 1 : CMMCOU = [F:TCA]CODNUM(5) : # Pre commitment
  When 2 : CMMCOU = [F:TCA]CODNUM(1) : # Commitment
 Endcase
Endif
Endif
If CMMCOU=""
 Read [TCA]TCA0=2;"";""
 If !fstat
  Case CMMTYP
   When 1 : CMMCOU = [F:TCA]CODNUM(5) : # Pre commitment
   When 2 : CMMCOU = [F:TCA]CODNUM(1) : # Commitment
  Endcase
 Endif
Endif
If CMMCOU="" : CMMCOU = "CMM" : Endif
[L]ASTATUS = func ANM_TOOL.NUMERO(ACTX,CMMCOU,SITE,DAT,"",CMMNUM,ERRMES)
If [L]ASTATUS>=[V]CST_AERROR
 ERRMES = mess(60,199,1)-"("+CMMCOUT+") : "+ERRMES : Return
Endif
Return

##############################################################################################################
$CAL_AMOUNT
# 59712
# If the commitment or pre commitment already exists, the disengaged amount could be slightly different from the engaged amount
# Example : It was 12.34 and we disengage 12.35
If !CREENG
 DIF_AMT = SIGN*AMT
 For [CMD]CMD0 Where NUM=CMMNUM
  DIF_AMT +=[F:CMD]AMTCUR
 Next
 If DIF_AMT<0 & abs(DIF_AMT)<1
  AMT = AMT-abs(DIF_AMT)
 Endif
Endif

For I=1 To NBRCMMLED
 CMMAMTLED(I)=0
 Case CMMDACRAT(I)
  When 1,3 :# Rate entry=Multiplier or Both
   If CMMRATMLT(I)<>0
    CMMAMTLED(I) = AMT*CMMRATMLT(I)
   Else
    If CMMCURLED(I)<>CUR
     Call CONVERT(ACTX,CUR,CMMCURLED(I),CPYCUR,RATTYP,DAT,AMT,AMTLED,OK) From TRTDEV_SYRA
     If !OK
      CMMAMTLED(I) = AMTLED
     Endif
    Else
     CMMAMTLED(I)= AMT
    Endif
    If AMT<>0
     CMMRATMLT(I)= CMMAMTLED(I)/AMT
     CMMRATDIV(I)= 1
    Endif
   Endif
  When 2 : # Rate entry=Divisor
   If CMMRATDIV(I)<>0
    CMMAMTLED(I) = AMT/CMMRATDIV(I)
   Else
    If CMMCURLED(I)<>CUR
     Call CONVERT(ACTX,CUR,CMMCURLED(I),CPYCUR,RATTYP,DAT,AMT,AMTLED,OK) From TRTDEV_SYRA
     If !OK
      CMMAMTLED(I) = AMTLED
     Endif
    Else
     CMMAMTLED(I)= AMT
    Endif
    If CMMAMTLED(I)<>0
     CMMRATDIV(I)= AMT/CMMAMTLED(I)
     CMMRATMLT(I)= 1
    Endif
   Endif
 Endcase
Next
Return

##############################################################################################################
## Evaluation of some fields according to the automatic journal header
$EVAL_HEA
If AUTJOUCOD<>""
 If !ALREADY_READ :  Gosub READ_AUTJOU : Endif
 [L]ASTATUS = func FINGAU_SYRA.EVAL_CHAR(ACTX,"VCR",1,"",[F:CMM]DESVCR,ERRMES)
 [L]ASTATUS = func FINGAU_SYRA.EVAL_CHAR(ACTX,"REF",1,"",[F:CMM]REFINT,ERRMES)
 GPOINT = "EVALHEA" : Gosub ENTREE From EXEFNC
Endif
Return

##############################################################################################################
## Evaluation of some fields according to the automatic journal line
$EVAL_LIN
If AUTJOUCOD<>""
 If !ALREADY_READ : Gosub READ_AUTJOU : Endif
 [L]ASTATUS = func FINGAU_SYRA.EVAL_CHAR(ACTX,"DES",2,"",[F:CMD]DES,ERRMES)
 GPOINT = "EVALLIN" : Gosub ENTREE From EXEFNC
Endif
Return

##############################################################################################################
## Read the automatic journal  : AUTJOUCOD
$READ_AUTJOU
Local Integer NBCLE , INDCUR
Local Char    CRITERE(250) , CLE(10)(1..8)

If adxtyp=33 | !clalev([F:GAU]) : Local File GAUTACE     [GAU] : Endif
If adxtyp=33 | !clalev([F:GAD]) : Local File GAUTACED    [GAD] : Endif

Read [GAU]GAU0 =AUTJOUCOD
If fstat : Return : Endif
Read [GAD]GAD0 =AUTJOUCOD;1
If fstat : Return : Endif

If adxtyp=33 | !clalev([F:TB0]) : Local File =[F:GAU]TBL [TB0] : Endif
# Open the linked tables required in the automatic journal
Gosub OUVRE  From ="WMGAU"+AUTJOUCOD
# Read the triggering table [TB0]
Gosub CLE    From ="WMGAU"+AUTJOUCOD
CRITERE = ""
For I=1 To NBCLE
 If [F:GAU]GRPFLG=1 | IDENT(I)<>""
  If CRITERE<>"" : CRITERE += " & " : Endif
  Case evalue("type([F:TB0]"+CLE(I)+")")
   When 1,2,4,5,6,7,8,9
    CRITERE += CLE(I)+'='+IDENT(I)
   When 3
    CRITERE += CLE(I)+'=['+format$(ACTX.AINTL.SHORTDATE,gdat$(IDENT(I)))+']'
   When Default
    CRITERE += CLE(I)+'="'+IDENT(I)+'"'
  Endcase
 Endif
Next I
Default File [TB0]
If [F:GAU]FORCND<>""
 If CRITERE<>"" : CRITERE -= "&" : Endif
 CRITERE -= "("+[F:GAU]FORCND+")"
Endif
If CRITERE<>""
 Filter [TB0] Where evalue(CRITERE)
Endif
[G:TB0]currind = 1
[G:TB0]currlen = 0
For [TB0] : Break : Next
Gosub LIENS  From ="WMGAU"+AUTJOUCOD
Gosub LIENS1 From ="WMGAU"+AUTJOUCOD
ALREADY_READ = 1
Return

##############################################################################################################
## Update CMDCCE CMDDAT CMDFIY CMDPER BUDCCE BUDDAT
$BUO_CLOSING
[L]ASTATUS = func FINPER_SYRA.GET_FIY(ACTX, COMPANY, LEDTYPANA, DAT, FIYCUR, ERRMES)
Call GET_BUOINF(CMMDIE,CMMCCE,SITE,BUDCOD,ENTITY,INDENT,ENVELOP,INDENV,CCE3,INDCCE3,OKBUO,YEAFLG,FCYBUD) From FINBUO_SYRA
If !OKBUO : Return : Endif
# It is an operation budget : entity and envelope dimension are set and eventually a third dimension too
ENVDIE    = CMMDIE(INDENV)

SITUATION = num$(REASON(1))+";"+num$(REASON(2))
Call LEC_ENV(ENVELOP) From CPTLEC

# Is the receipt is total or not ?
TOTRCP = func _IS_TOTRECEIP(PURNUM,PURLIN,PURSEQ)

# Is there Commitment left on order ? Has it been postponed ?
CMMLFT = 1 # There are still  commitment amount
PURFRW = 0 # The commitment is not carried forward
PURFRWFIY = 0 # Fiscal year of the carry forward

Read [CPOH]POH0 = PURNUM
If !fstat
 [L]ASTATUS = func FINPER_SYRA.GET_FIY(ACTX,COMPANY,LEDTYPANA,[F:CPOH]ORDDAT,FIYORD,ERRMES)
 If FIYORD=0
  [L]ASTATUS = [V]CST_AERROR : ERRMES = num$([F:CPOH]ORDDAT)-mess(1,104,1) : End [L]ASTATUS
 Endif
 Read [BUA]BUA0 = 2;"";PURNUM;PURLIN;PURSEQ;ANALIN;FIYORD
 If !fstat
  If [F:BUA]CMM<=0
   CMMLFT = 0
  Endif
  If [F:BUA]POSTPONED=2
   PURFRW    = 1
   PURFRWFIY = [F:BUA]FIY+1
  Endif
 Endif
Endif

#-- 80562 : Change the receipt date on the order line, after the carry forward of the commitment.
#-- We have to disengage on the carry forward fiscal year.
#-- Cas de modification de date de réception sur la ligne de commande aprés report
#-- des engagements. Il faut désengager sur l'exercice de report
If SITUATION="2;2" : # Modification of an order
 If PURFRW & FIYCUR<PURFRWFIY
  [L]ASTATUS = func FINPER_SYRA.GET_FIYDATES(ACTX, COMPANY, LEDTYPANA, PURFRWFIY, CMDDAT, ENDDAT, ERRMES)
  BUDDAT = CMDDAT
 Endif
Endif

Gosub INI_DIE

If YEAFLG=1 : # Annual envelope
 Gosub BUO_ANNUAL
Else        : # Multi-annual envelope
 # In the case of order then partial receipt then total commitment report and then FAR
 # After the commitment report, the disengagement due to the creation of the invoice receivable (FAR)
 # must be done on N+1 and not on N
 Case SITUATION
  When "1;4","1;5" : # Creation invoice receivable (FAR) / creation credit to receive (AAR)
   # If the status of the budget line is closed or commitments carried forward, we search the budget line
   # of the next year
   If TYPORG=1 | TYPORG=2 :# Order
    Read [CPOH]POH0 = DOCUMENT(1) :# Number of the source purchase document
    If !fstat
     [L]ASTATUS = func FINPER_SYRA.GET_FIY(ACTX,COMPANY,LEDTYPANA,[F:CPOH]ORDDAT,FIYORD,ERRMES)
     If FIYORD=0
      [L]ASTATUS = [V]CST_AERROR : ERRMES = num$([F:CPOH]ORDDAT)-mess(1,104,1) : End [L]ASTATUS
     Endif
     Raz [F:BUD]
     I = find(DIEENT,[F:LED]DIE(0..[F:LED]DIENBR-1))
     If I : Assign "[F:BUD]CCE"+num$(I) With ENTITY : Endif
     I = find(DIEENV,[F:LED]DIE(0..[F:LED]DIENBR-1))
     If I : Assign "[F:BUD]CCE"+num$(I) With ENVELOP : Endif
     If DIE3<>""
      I = find(DIE3,[F:LED]DIE(0..[F:LED]DIENBR-1))
      If I : Assign "[F:BUD]CCE"+num$(I) With CCE3 : Endif
     Endif
     [F:BUD]LEDTYP = LEDTYPANA
     [F:BUD]BUD    = [F:ENV]BUD
     [F:BUD]CPY    = COMPANY
     [F:BUD]FCY    = FCYBUD
     [F:BUD]FIY    = FIYORD
     [F:BUD]VER    = "1"
     [F:BUD]ACC    = CMMACC(I_LEDTYPANA)
     Read [BUD]BUD0=
     If !fstat
      If ([F:BUD]STA=5 | [F:BUD]STA=4) & !CMMLFT
       Raz [F:BUD2]
       I = find(DIEENT,[F:LED]DIE(0..[F:LED]DIENBR-1))
       If I : Assign "[F:BUD2]CCE"+num$(I) With ENTITY : Endif
       I = find(DIEENV,[F:LED]DIE(0..[F:LED]DIENBR-1))
       If I : Assign "[F:BUD2]CCE"+num$(I) With ENVELOP : Endif
       If DIE3<>""
        I = find(DIE3,[F:LED]DIE(0..[F:LED]DIENBR-1))
        If I : Assign "[F:BUD2]CCE"+num$(I) With CCE3 : Endif
       Endif
       [F:BUD2]LEDTYP = LEDTYPANA
       [F:BUD2]BUD    = [F:ENV]BUD
       [F:BUD2]CPY    = COMPANY
       [F:BUD2]FCY    = FCYBUD
       [F:BUD2]FIY    = FIYORD+1
       [F:BUD2]VER    = "1"
       [F:BUD2]ACC    = CMMACC(I_LEDTYPANA)
       Read [BUD2]BUD0=
       If fstat | [F:BUD2]STA<>3
        If MYLOG<>AVOID.AINS
         [L]ASTATUS = fmet MYLOG.APUTLINE(mess(260,108,1)-ENVELOP-"/"+mess(2,2693,1)-num$(FIYORD+1),[V]CST_AERROR)
         [L]ASTATUS = [V]CST_AERROR : Return
        Else
         ERRMESS = mess(260,108,1)-ENVELOP-"/"+mess(2,2693,1)-num$(FIYORD+1)
         [L]ASTATUS = [V]CST_AERROR : Return
        Endif
       Elsif !fstat
        [L]ASTATUS = func FINPER_SYRA.GET_FIYDATES(ACTX, COMPANY, LEDTYPANA, (FIYORD+1), CMDDAT, ENDDAT, ERRMES)
        BUDDAT = CMDDAT
        [L]ASTATUS = func FINPER_SYRA.GET_PER(ACTX, COMPANY, LEDTYPANA, CMDDAT, CMDFIY, CMDPER, ERRMES)
       Endif
      Endif
     Endif
    Endif
   Endif
 Endcase

 # If the purchase request or the order/delivery request is carried forward, we have to disengage
 # on the receipt fiscal year if it is a creation/deletion or a balance operation
 # First update the flag PURFRW if the order/delivery request or the purchase request is carried forward
 # Then check that an approved budget line exists in the receipt fiscal year
 Raz PURFRW
 Raz [F:BUA]

 If REASON(1)=1 | REASON(1)=3 | REASON(1)=4 | REASON(1)=6
  Raz [F:BUD]
  I = find(DIEENT,[F:LED]DIE(0..[F:LED]DIENBR-1))
  If I : Assign "[F:BUD]CCE"+num$(I) With ENTITY : Endif
  I = find(DIEENV,[F:LED]DIE(0..[F:LED]DIENBR-1))
  If I : Assign "[F:BUD]CCE"+num$(I) With ENVELOP : Endif
  If DIE3<>""
   I = find(DIE3,[F:LED]DIE(0..[F:LED]DIENBR-1))
   If I : Assign "[F:BUD]CCE"+num$(I) With CCE3 : Endif
  Endif
  [F:BUD]LEDTYP = LEDTYPANA
  [F:BUD]BUD    = [F:ENV]BUD
  [F:BUD]CPY    = COMPANY
  [F:BUD]FCY    = FCYBUD
  [F:BUD]FIY    = FIYCUR
  [F:BUD]VER    = "1"
  [F:BUD]ACC    = CMMACC(I_LEDTYPANA)
  Read [BUD]BUD0=
  If !fstat
   Read [BUA]BUA0 = PURTYP;"";PURNUM;PURLIN;PURSEQ;0;FIYCUR
   If !fstat
    If [F:BUD]STA=5 | [F:BUD]STA=4
     Case [L]PURTYP
      When 1 : If [F:BUA]CMMPRP=0 : PURFRW=1 : Endif
      When 2 : If [F:BUA]CMM=0    : PURFRW=1 : Endif
     Endcase
    Endif
    If [F:BUA]POSTPONED=2 : PURFRW=1 : Endif
   Endif
  Endif
  If PURFRW
   [L]BUDCRI = "1=1"
   I = find(DIEENT,[F:LED]DIE(0..[F:LED]DIENBR-1))
   If I : [L]BUDCRI += "& [F:BUD]CCE"+num$(I)+"='"+ENTITY+"'" : Endif
   I = find(DIEENV,[F:LED]DIE(0..[F:LED]DIENBR-1))
   If I : [L]BUDCRI += "& [F:BUD]CCE"+num$(I)+"='"+ENVELOP+"'" : Endif
   If DIE3<>""
    I = find(DIE3,[F:LED]DIE(0..[F:LED]DIENBR-1))
    If I : [L]BUDCRI += "& [F:BUD]CCE"+num$(I)+"='"+[L]CCE3+"'" : Endif
   Endif
   Filter [BUD2] Where LEDTYP=LEDTYPANA & BUD=[F:ENV]BUD & CPY=COMPANY & FCY=FCYBUD & FIY=(FIYCUR+1)
&&   VER="1" & ACC=CMMACC(I_LEDTYPANA) & evalue(BUDCRI) & STA=3
   Raz [F:BUD2]
   For [BUD2]BUD0
    Break
   Next
   Filter [BUD2]
   If [F:BUD2]BUD=""
    If MYLOG<>AVOID.AINS
     [L]ASTATUS = fmet MYLOG.APUTLINE(mess(260,108,1)-ENVELOP-"/"+mess(2,2693,1)-num$(FIYCUR+1),[V]CST_AERROR)
     [L]ASTATUS = [V]CST_AERROR : Return
    Else
     ERRMESS = mess(260,108,1)-ENVELOP-"/"+mess(2,2693,1)-num$(FIYCUR+1)
     [L]ASTATUS = [V]CST_AERROR : Return
    Endif
   Else
    [L]ASTATUS = func FINPER_SYRA.GET_FIYDATES(ACTX, COMPANY, LEDTYPANA, (FIYCUR+1), CMDDAT, ENDDAT, ERRMES)
    BUDDAT = CMDDAT
    [L]ASTATUS = func FINPER_SYRA.GET_PER(ACTX, COMPANY, LEDTYPANA, CMDDAT, CMDFIY, CMDPER, ERRMES)
   Endif
  Endif
 Endif
Endif

Return

##############################################################################################################
# Annual envelope
##############################################################################################################
$BUO_ANNUAL
[L]ASTATUS = func FINPER_SYRA.GET_FIY(ACTX,COMPANY,LEDTYPANA,[F:ENV]REASTR,FIYENV,ERRMES)
If FIYENV=0
 [L]ASTATUS = [V]CST_AERROR : ERRMES = num$([F:ENV]REASTR)-mess(1,104,1) : End [L]ASTATUS
Endif

Raz [F:BUD]
I = find(DIEENT,[F:LED]DIE(0..[F:LED]DIENBR-1))
If I : Assign "[F:BUD]CCE"+num$(I) With ENTITY : Endif
I = find(DIEENV,[F:LED]DIE(0..[F:LED]DIENBR-1))
If I : Assign "[F:BUD]CCE"+num$(I) With ENVELOP : Endif
If DIE3<>""
 I = find(DIE3,[F:LED]DIE(0..[F:LED]DIENBR-1))
 If I : Assign "[F:BUD]CCE"+num$(I) With CCE3 : Endif
Endif
[F:BUD]LEDTYP = LEDTYPANA
[F:BUD]BUD    = [F:ENV]BUD
[F:BUD]CPY    = COMPANY
[F:BUD]FCY    = FCYBUD
[F:BUD]FIY    = FIYENV
[F:BUD]VER    = "1"
[F:BUD]ACC    = CMMACC(I_LEDTYPANA)
Read [BUD]BUD0=
If !fstat
 Case SITUATION
  When "1;4","1;5" : # Creation FAR,Creation AAR
   If [F:BUD]STA=5 & (!CMMLFT | PURFRW)
    # Cas de la FAR APRES report des engagements, il y a une enveloppe sur N+1
    # Case of Invoice receivables after the carry forward of the commitment, if there is an envelop on N+1
    Read [ENV2]ENV0 = [F:ENV]ENVRCD
    If !fstat
     BUDCCE(INDENV) = [F:ENV2]ENV
     BUDDAT         = [F:ENV2]REASTR
     CMDCCE(INDENV) = [F:ENV2]ENV
     CMDDAT         = [F:ENV2]REASTR
     [L]ASTATUS = func FINPER_SYRA.GET_PER(ACTX, COMPANY, LEDTYPANA, CMDDAT, CMDFIY, CMDPER, ERRMES)
    Endif
   Endif

  When "5;4","5;5" : #Extourne FAR,Extourne AAR
   If [F:BUD]STA<>5 & FIYCUR>FIYENV
    # Before the carry forward of the commitment
    # If the status of the budget line of the Annual budget envelop on N
    # IS NOT "carried forward for commitment', and the fiscalyear of the given
    # parameter date is bigger than the fiscal year of the parameter envelop
    # then the envelop of the commitment line and the budget affectaion have
    # to change for the receiver envelop on N+1
    # Avant le report d'engagement
    # Si le statut de la ligne bugétaire n'est pas 'reporté pour engagement, et que l'année fiscale
    # de la date paramètre est supérieure à l'année fiscale de l'enveloppe, alors l'enveloppe de la
    # ligne d'engagement et de la mise à jour du budget doit être l'enveloppe de reception sur l'exercice
    # fiscal suivant.
    CMMCCE(INDENV) = [F:ENV]ENVRCD
    BUDCCE(INDENV) = [F:ENV]ENVRCD
    CMDCCE(INDENV) = [F:ENV]ENVRCD

    # Update the annual envelope number with the receipt envelope N+1 in the order and receipt
    # if all is receipted or if the command is balanced
    If ENVDIE<>"" & (TOTRCP | !CMMLFT)
     # Order - Commande d'achat
     Readlock [CCAL]CAL0="POP";0;PURNUM;PURLIN;PURSEQ;"";1
     If !fstat
      INDENV = find(ENVDIE,[F:CCAL]DIE(0..dim([F:CCAL]DIE)-1))
      If INDENV & [F:CCAL]CCE(INDENV-1)<>[F:ENV]ENVRCD
       [F:CCAL]CCE(INDENV-1)=[F:ENV]ENVRCD
       Rewrite [CCAL]
       If fstat
        Call FSTA("CCAL",ACTX,[L]ASTATUS) From ASYRSUB
        End [L]ASTATUS
       Endif
      Endif
     Endif
     # PO price history - Historique commande d'achat
     Filter [CUOP] Where POHNUM=PURNUM & POPLIN=PURLIN & POPSEQ=PURSEQ
     For [CUOP]POP0
      Readlock [CCAL]CAL0="UOP";0;PURNUM;PURLIN;0;num$([F:CUOP]LINREVNUM);1
      If !fstat
       INDENV = find(ENVDIE,[F:CCAL]DIE(0..dim([F:CCAL]DIE)-1))
       If INDENV
        [F:CCAL]CCE(INDENV-1)=[F:ENV]ENVRCD
        Rewrite [CCAL]
        If fstat
         Call FSTA("CCAL",ACTX,[L]ASTATUS) From ASYRSUB
         End [L]ASTATUS
        Endif
       Endif
      Endif
     Next
     Filter [CUOP]
     # Detail receipt - Réceptions sur la commande
     Filter [CPTD] Where POHNUM=PURNUM & POPLIN=PURLIN
     For [CPTD]PTD0
      Readlock [CCAL]CAL0="PTD";0;[F:CPTD]PTHNUM;[F:CPTD]PTDLIN;0;"";1
      If !fstat
       INDENV = find(ENVDIE,[F:CCAL]DIE(0..dim([F:CCAL]DIE)-1))
       If INDENV
        [F:CCAL]CCE(INDENV-1)=[F:ENV]ENVRCD
        Rewrite [CCAL]
        If fstat
         Call FSTA("CCAL",ACTX,[L]ASTATUS) From ASYRSUB
         End [L]ASTATUS
        Endif
       Endif
      Endif
     Next
     Filter [CPTD]
    Endif :# Quantity - Total Receipt

    If SITUATION = "5;5" #extourne AAR
     # Detail return - Retours sur la commande
     Filter [CPND] Where POHNUM=PURNUM & POPLIN=PURLIN
     For [CPND]PND0
      Readlock [CCAL]CAL0="PND";0;[F:CPND]PNHNUM;[F:CPND]PNDLIN;0;"";1
      If !fstat
       INDENV = find(ENVDIE,[F:CCAL]DIE(0..dim([F:CCAL]DIE)-1))
       If INDENV
        [F:CCAL]CCE(INDENV-1)=[F:ENV]ENVRCD
        Rewrite [CCAL]
        If fstat
         Call FSTA("CCAL",ACTX,[L]ASTATUS) From ASYRSUB
         End [L]ASTATUS
        Endif
       Endif
     Endif
     Next
     Filter [CPND]
    Endif

   Elsif [F:BUD]STA=5

    #Cas de la FAR APRES report des engagements
    # If the status of the budget line of the Annual budget envelop on N
    # is 'carried forward for commitment'.
    Read [ENV2]ENV0 = [F:ENV]ENVRCD
    If !fstat
     BUDCCE(INDENV) = [F:ENV2]ENV
     BUDDAT         = [F:ENV2]REASTR
     CMDCCE(INDENV) = [F:ENV2]ENV
     CMDDAT         = [F:ENV2]REASTR
     [L]ASTATUS = func FINPER_SYRA.GET_PER(ACTX, COMPANY, LEDTYPANA, CMDDAT, CMDFIY, CMDPER, ERRMES)
    Endif

   Endif
 Endcase
Endif

 # In case of deletion or closing or closing cancellation of a purchase request or order which has been carried forward to N+1
 # because the date of the purchase object is still in fiscalyear N, in order to do the
 # commitment and budget mouvement on the right fiscalyear, date of update must be on N.
 #---
 # En cas de suppression ou solde ou annulation de solde, d'une DA ou d'une CMD qui a été reporté sur N+1,
 # puisque la date de l'objet d'achat est encore sur N, la date de mise à jour de la ligne d'engagement
 # et la date de mise à jour du budget doivent être changées.
 If ( REASON(1)=3 | REASON(1)=4 | REASON(1)=6 ) & FIYCUR<FIYENV
  [L]ASTATUS = func FINPER_SYRA.GET_FIYDATES(ACTX, COMPANY, LEDTYPANA, FIYENV, CMDDAT, ENDDAT, ERRMES)
  BUDDAT = CMDDAT
  [L]ASTATUS = func FINPER_SYRA.GET_PER(ACTX, COMPANY, LEDTYPANA, CMDDAT, CMDFIY, CMDPER, ERRMES)
 Endif

 # Cas FAR avant report sur ENVA /Case of invoice receivables before carry forward on annual envelope
 # L'extourne de la FAR a modifié l'enveloppe de la commande avec l'enveloppe N+1
 # du coup lorsqu'on fait le solde pour report on le fait sur N+1 au lieu de N
 #---
 # The reversal of the invoice receivable changed the envelope of the order with the envelope N+1
 # then the carry forward is done on N+1 instead of N
 If SITUATION="4;6" & FIYCUR<FIYENV
  BUDCCE(INDENV) = [F:ENV]ENVORG
  BUDDAT         = DAT
  CMDCCE(INDENV) = [F:ENV]ENVORG
  CMDDAT         = DAT
  [L]ASTATUS = func FINPER_SYRA.GET_PER(ACTX, COMPANY, LEDTYPANA, CMDDAT, CMDFIY, CMDPER, ERRMES)
 Endif

 # 84195 Create the carry forward
 If SITUATION="1;6" & FIYCUR>FIYENV
  CMMCCE(INDENV) = [F:ENV]ENVRCD
  CMDCCE(INDENV) = [F:ENV]ENVRCD
  BUDCCE(INDENV) = [F:ENV]ENVRCD
 Endif
Return

$INI_DIE
Call LEC_BUP([L]BUDCOD) From CPTLEC
DIEENT = [F:BUP]DIE(0)
DIEENV = [F:BUP]DIE(1)
DIE3   = [F:BUP]DIE(2)
[L]ASTATUS = func FINACM_SYRA.GET_LEDCUR(ACTX, COMPANY, LEDTYPANA, LEDCOD, LEDCUR, ERRMES)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Call LEC_LED(LEDCOD) From CPTLEC
Return

########################################################################################################
## _IS_TOTRECEIP - Check if the receipt is total or not
########################################################################################################
#**
#* Check if the receipt is total or not
#*
#* @private
#* @param ORDNUM    Number of the order
#* @param ORDLIN    Line of the order
#* @param ORDSEQ    Sequence
#*!
Funprog _IS_TOTRECEIP(ORDNUM, ORDLIN, ORDSEQ)
Value Char    ORDNUM  # Number of the order
Value Integer ORDLIN  # Line of the order
Value Integer ORDSEQ  # Sequence

Local Integer QTYORDUOM,QTYORDPUU,QTYRCPUOM,QTYRCPPUU,QTYRTNUOM,QTYRTNPUU, TOTRCP

TOTRCP = 0
#-- Quantity ordered
Read [CPOQ]POQ0=ORDNUM;ORDLIN;ORDSEQ
If !fstat
 QTYORDUOM = [F:CPOQ]QTYUOM
 QTYORDPUU = [F:CPOQ]QTYPUU
Endif

#-- Quantity receipted
Filter [CPTD] Where POHNUM=ORDNUM & POPLIN=ORDLIN & POQSEQ=ORDSEQ
For [CPTD]PTD0
 QTYRCPUOM += [F:CPTD]QTYUOM
 QTYRCPPUU += [F:CPTD]QTYPUU
Next
Filter [CPTD]

#-- Quantity returned
Filter [CPND] Where POHNUM=ORDNUM & POPLIN=ORDLIN & POQSEQ=ORDSEQ
For [CPND]PND0
 QTYRTNUOM += [F:CPND]QTYUOM
 QTYRTNPUU += [F:CPND]QTYPUU
Next
Filter [CPND]

# Total receipt ?
TOTRCP = ((QTYORDUOM<>0 & QTYORDUOM=QTYRCPUOM) | (QTYORDPUU<>0 & QTYORDPUU=QTYRCPPUU))
End TOTRCP

##############################################################################################################
# Update BUDPURAUD table
##############################################################################################################
$UPD_BUA
If PURNUM = "" : Return : Endif

If FLGGDD & SITUATION="2;2" & PURFRW & FIYCUR<PURFRWFIY
 FIY = PURFRWFIY
Endif

# The field TYPPCE is empty in [BUA] because TYPPCE relates to the invoices
Readlock [BUA]BUA0 = [L]PURTYP;"";[L]PURNUM;[L]PURLIN;[L]PURSEQ;[L]ANALIN;FIY

If fstat=1
 Call FSTA("BUA",ACTX,[L]ASTATUS) From ASYRSUB
 Return
Elsif !fstat
 If REASON(1)=3 : # Deletion
  Delete [BUA]BUA0 Curr
  If fstat
   Call FSTA("BUA",ACTX,[L]ASTATUS) From ASYRSUB
   Return
  Endif
 Else
  If [F:BUA]BUD="" & [F:BUA]POSTPONED=2 &
&   ((PURTYP=1 & REASON(1)<>2) | REASON(1)=2 | REASON(1)=4 | (REASON(1)=1 & find(REASON(2),4,5)))
   FIY +=1
   [L]ASTATUS = func FINPER_SYRA.GET_FIYDATES(ACTX, COMPANY, LEDTYPANA, FIY, CMDDAT, ENDDAT, ERRMES)
   BUDDAT = CMDDAT
   [L]ASTATUS = func FINPER_SYRA.GET_PER(ACTX, COMPANY, LEDTYPANA, CMDDAT, CMDFIY, CMDPER, ERRMES)
  Endif
  Case CMMTYP
   When 1 :# Pre commitment
    [F:BUA]CMMPRP += SIGN*SENS*AMT
   When 2 :# Commitment
    [F:BUA]CMM    += SIGN*SENS*AMT
  Endcase

  For I=0 To len(mess(0,2644,1))-1
   K = find(I+1,CMMLEDTYP(1..NBRCMMLED))
   If K
    [F:BUA]LEDTYP(I) = CMMLEDTYP(K)
    [F:BUA]LED(I)    = CMMLED(K)
    [F:BUA]CURLED(I) = CMMCURLED(K)
    [F:BUA]COA(I)    = CMMCOA(K)
    [F:BUA]ACC(I)    = CMMACC(K)
    Case CMMTYP
     When 1 :# Pre commitment
      [F:BUA]CMMPRPLED(I) += SIGN*SENS*CMMAMTLED(K)
     When 2 :# Commitment
      [F:BUA]CMMLED(I)    += SIGN*SENS*CMMAMTLED(K)
    Endcase
   Else
    [F:BUA]LEDTYP(I) = 0
   Endif
  Next

  For I=1 To min(dim([F:BUA]DIE),dim(DIE))
   Assign "[F:BUA]DIE("+num$(I-1)+")" With evalue("DIE("+num$(I)+")")
   Assign "[F:BUA]CCE("+num$(I-1)+")" With evalue("CCE("+num$(I)+")")
  Next

  [F:BUA]QTY   += SIGN*QTY
  [F:BUA]BPR    = BPR
  [F:BUA]GRDACT = REASON(1)
  [F:BUA]GRDPCE = REASON(2)
  [F:BUA]UPDDAT = date$
  [F:BUA]UPDUSR = ACTX.USER

  If REASON(1)=4 & REASON(2)=6 : # Closing-Solde / Carry forward-Report
   [F:BUA]POSTPONED = 2
  Endif

  Rewrite [BUA]
  If fstat
   Call FSTA("BUA",ACTX,[L]ASTATUS) From ASYRSUB
   Return
  Endif

  If (FCTNAM="BUOCMMREP" | FCTNAM="CMMREP") & MYLOG<>AVOID.AINS
   [L]ASTATUS = fmet MYLOG.APUTLINE(mess(211,107,1)-":"-mess(PURTYP,2684,1)-"/"-[L]PURNUM-"/"-num$([L]PURLIN)-"/"-num$([L]PURSEQ)-"/"-num$([L]ANALIN)-"/"-num$(FIY),[V]CST_AOK)
  Endif
 Endif

Elsif fstat

 Raz [BUA]
 [F:BUA]BUANUM = uniqid([F:BUA])
 [F:BUA]TYPPCE = ""
 [F:BUA]TYP    = [L]PURTYP
 [F:BUA]NUM    = [L]PURNUM
 [F:BUA]LIN    = [L]PURLIN
 [F:BUA]SEQ    = [L]PURSEQ
 [F:BUA]ANALIN = [L]ANALIN
 If FLGGDD & OKBUO
  [F:BUA]BUD   = BUDCOD
 Endif

 Case CMMTYP
  When 1 :# Pre commitment
   [F:BUA]CMMPRP = SIGN*SENS*AMT
  When 2 :# Commitment
   [F:BUA]CMM    = SIGN*SENS*AMY
 Endcase
 For I=0 To len(mess(0,2644,1))-1
  K = find(I+1,CMMLEDTYP(1..NBRCMMLED))
  If K
   [F:BUA]LEDTYP(I) = CMMLEDTYP(K)
   [F:BUA]LED(I)    = CMMLED(K)
   [F:BUA]CURLED(I) = CMMCURLED(K)
   [F:BUA]COA(I)    = CMMCOA(K)
   [F:BUA]ACC(I)    = CMMACC(K)
   Case CMMTYP
    When 1 :# Pre commitment
     [F:BUA]CMMPRPLED(I) = SIGN*SENS*CMMAMTLED(K)
    When 2 :# Commitment
     [F:BUA]CMMLED(I)    = SIGN*SENS*CMMAMTLED(K)
   Endcase
  Else
   [F:BUA]LEDTYP(I) = 0
  Endif
 Next

 For I=1 To min(dim([F:BUA]DIE),dim(DIE))
  Assign "[F:BUA]DIE("+num$(I-1)+")" With evalue("DIE("+num$(I)+")")
  Assign "[F:BUA]CCE("+num$(I-1)+")" With evalue("CCE("+num$(I)+")")
 Next

 If FLGGDD & OKBUO & YEAFLG=1
  Call LEC_ENV(ENVELOP) From CPTLEC
  [L]ASTATUS = func FINPER_SYRA.GET_FIY(ACTX,COMPANY,LEDTYPANA,[F:ENV]REASTR,FIYENV,ERRMES)
  If FIYENV=0
   [L]ASTATUS = [V]CST_AERROR : ERRMES = num$([F:ENV]REASTR)-mess(1,104,1) : End [L]ASTATUS
  Endif
  If FIY>FIYENV
   Assign "[F:BUA]CCE("+num$(INDENV-1)+")" With [F:ENV]ENVRCD
  Endif
 Endif

 [F:BUA]CUR    = CUR
 [F:BUA]DAT    = DAT
 [F:BUA]CPY    = COMPANY
 [F:BUA]FCY    = SITE
 [F:BUA]FIY    = FIY
 [F:BUA]BPR    = BPR
 [F:BUA]CMMNUM = CMMNUM
 [F:BUA]CODGAU = AUTJOUCOD
 [F:BUA]QTY    = QTY
 [F:BUA]CREDAT = date$
 [F:BUA]CREUSR = ACTX.USER
 [F:BUA]GRDACT = REASON(1)
 [F:BUA]GRDPCE = REASON(2)

 Write [BUA]
 If fstat
  Call FSTA("BUA",ACTX,[L]ASTATUS) From ASYRSUB
  Return
 Endif
 If (FCTNAM="BUOCMMREP" | FCTNAM="CMMREP" | FCTNAM="FUNPTH") & MYLOG<>AVOID.AINS
  [L]ASTATUS = fmet MYLOG.APUTLINE(mess(212,107,1)-":"-mess([L]PURTYP,2684,1)-"/"-[L]PURNUM-"/"-num$([L]PURLIN)-"/"-num$([L]PURSEQ)-"/"-num$([L]ANALIN)-"/"-num$(FIY),[V]CST_AOK)
 Endif
Endif
Return

##############################################################################################################
# Update the balance tables : BLACMM & BLAQTY
# Update the pre commitment/commitment amount in the budget table BUD
# The budget control is done in the UPDBUD program if CTLBUD=1
##############################################################################################################
$UPD_BAL_BUD
Local Char DIELED(GLONDIE)(1..dim([L]DIE))
Local Char CCELED(GLONCCE)(1..dim([L]DIE))
For I=1 To len(mess(0,2644,1))
 If CMMLED(I)<>""
  Raz DIELED, CCELED
  [L]ASTATUS = func FINCCE_SYRA.GET_CCELEDLST(ACTX,BUDDIE,BUDCCE,CMMLED(I),DIELED,CCELED)
  If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
  [L]ASTATUS = func FINBUD_SYRA.UPD_BUD(ACTX,BUDDAT,SITE,CMMLEDTYP(I),CUR,AMT,CMMAMTLED(I),QTY,CMMACC(I),BPR,
&                                       DIELED,CCELED,SENS,SIGN,CMMTYP,CTLBUD,ERRMES)
  If [L]ASTATUS>=[V]CST_AERROR
   If CTLBUD<>2 & ERRMES<>""
    [L]ASTATUS = fmet ACTX.ASETERROR("",ERRMESS,[V]CST_AERROR)
   Endif
   Break
  Endif
 Endif
Next
Return

