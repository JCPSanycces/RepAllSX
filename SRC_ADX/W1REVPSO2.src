#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque REVPSO2 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:15"
A_USER  = "DOC"
A_STAMP = "20181109230615"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG2"
  If [M]NBLIG2=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask REVPSO2 [REVPSO2]
Gosub HORODAT
Local Inpbox "REVPSO2" From GFONCTION At A_STAMP With A_WINDPREV Mask [REVPSO2] As [SIM_]
Grizo [REVPSO2]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [REVPSO2]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=100 : Y1(0)=1 : Y2(0)=21
Return

$ON_ITMREF
Return

$ON_ITMDES
Onevent CONTROL Call C_ITMDES(zc) From W1REVPSO2
Return

Subprog C_ITMDES(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "ITMDES" : GZNUM = 282 : Endif
Gosub _AFF
End

$ON_SAU
Return

$ON_QTY
Onevent BEFORE_AREA Gosub AV_QTY From W1REVPSO2
Onevent CONTROL Call C_QTY(zc) From W1REVPSO2
Return

$AV_QTY
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find("",GUNITE(1..GNBUNT)),1))
Endif
Chgfmt [M]QTY(indice) With "Nz:"+GUNTFMT
Gosub _AFF
Return

Subprog C_QTY(VALEUR)
Variable Decimal VALEUR
## Action %OBLIG
If VALEUR=0
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "QTY" : GZNUM = 54683 : Endif
Gosub _AFF
End

$ON_BASPRI
Onevent BEFORE_AREA Gosub AV_BASPRI From W1REVPSO2
Return

$AV_BASPRI
## Action PARDEV
Gosub _AFF
Return

$ON_PRODGRPLVL
Onevent INIT_AREA Call D_PRODGRPLVL(zc) From W1REVPSO2
Onevent BEFORE_INPUT Call AS_PRODGRPLVL(zc) From W1REVPSO2
Return

Subprog D_PRODGRPLVL(VALEUR)
Variable Integer VALEUR
If varinit([M]PRODGRPLVL,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_PRODGRPLVL(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_PBUCOD
Return

$ON_TASCOD
Return

$CHG_STY
Return


