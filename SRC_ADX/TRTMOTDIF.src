#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#If GUSER = 'BRBAN'  : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"  : Gosub OUVRE
  When "OK"     : Gosub OK
  When "DEBUT"  : Gosub DEBUT
Endcase
Return

$OUVRE
If !clalev([F:VEP3]) : Local File VALEMP [VEP3] : Endif

Local Mask TRTMOTDIF [DIA]
Raz [M:DIA]

Return

$OK
If [M:VEP0]MODIF  <> 0
  [M:VEP1]MOTDIFINC(0) = [M:DIA]MOTDIFINC1
  [M:VEP1]MOTDIFINC(1) = [M:DIA]MOTDIFINC2
  [M:VEP1]MOTDIFINC(2) = [M:DIA]MOTDIFINC3
  [M:VEP1]MOTDIFINC(3) = [M:DIA]MOTDIFINC4
  [M:VEP1]MOTDIFINC(4) = [M:DIA]MOTDIFINC5
  [M:VEP1]MOTDIFINC(5) = [M:DIA]MOTDIFINC6
  [M:VEP1]MOTDIFINC(6) = [M:DIA]MOTDIFINC7
  [M:VEP1]MOTDIFINC(7) = [M:DIA]MOTDIFINC8
Endif
mkstat = 4

Return

$DEBUT

[M:DIA]MOTDIFINC1 = [M:VEP1]MOTDIFINC(0)
[M:DIA]MOTDIFINC2 = [M:VEP1]MOTDIFINC(1)
[M:DIA]MOTDIFINC3 = [M:VEP1]MOTDIFINC(2)
[M:DIA]MOTDIFINC4 = [M:VEP1]MOTDIFINC(3)
[M:DIA]MOTDIFINC5 = [M:VEP1]MOTDIFINC(4)
[M:DIA]MOTDIFINC6 = [M:VEP1]MOTDIFINC(5)
[M:DIA]MOTDIFINC7 = [M:VEP1]MOTDIFINC(6)
[M:DIA]MOTDIFINC8 = [M:VEP1]MOTDIFINC(7)

Affzo [M:DIA]

Return

