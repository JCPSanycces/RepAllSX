#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
#* Modifications :
# FQ74044 - SEGAY - 13/02/12 -
#      Ajout vérification du nouveau champ FILTRE sur la nature d'évènement
#     MABOS-22/05/13-FQ89268-US1612- Modif pour multi-contrats
#     MABOS-10/07/13-FQ89268-US1728- Ajout parametres, appel SEARCH_CTR
#     SBA - 06/11/13 - FQ92969-US2029 - Modifier trace
#     FQ81491 - 15/11/13 - prise en compte date d'effet + fiches de rétroactivité
#     FQ92876 - 27/06/14 - Récupération des axes depuis le planning personnel Ou initialisation si pas de planning
######################################################################################

# Importation Badgeuse dit BODET : révision WGA 09/2009 - demande 57666
Call IMPORTATION("BADGEUSE") From GIMPOBJ
End

###################################################################################
$ACTION
Case ACTION
 When "IMP_OUVRE"     : Gosub IMP_OUVRE
 When "AP_IMPORT"     : Gosub AP_IMPORT
 When "IMP_VERIF_CRE" : Gosub IMP_VERIF_CRE
 When "IMP_VERIF_MOD" : Gosub IMP_VERIF_CRE
 #63169
 When "IMP_CREATION"  : Gosub IMP_CREATION
 When "IMP_MODIF"     : Gosub IMP_CREATION
 # fin 63169
 When "IMP_FERME"     : Gosub IMP_FERME
Endcase
Return

#-------------------------------------------------------------------------------
$IMP_OUVRE
If !clalev([F:TIR]) : Local File TIMRECAP [TIR] : Endif
#LIPET - X3-11725 - 18-01-2017 - START
#If !clalev([F:PEO]) : Local File PERIOD   [PEO] : Endif
If !clalev([F:HRPEOD]) : Local File HRPEODET   [HRPEOD] : Endif
#LIPET - X3-11725 - 18-01-2017 - END
If !clalev([F:TIM]) : Local File TIMCOD   [TIM] : Endif
If !clalev([F:ID])  : Local File EMPLOID  [ID]  : Endif
If !clalev([F:NAT]) : Local File NATACTIV [NAT] : Endif
#LIPET - X3-11725 - 18-01-2017 - START
#If !clalev([F:CTR]) : Local File EMPLOCTR [CTR] : Endif
#If !clalev([F:CTR2]): Local File EMPLOCTR [CTR2]: Endif
If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR] : Endif
If !clalev([F:HRCTR2]): Local File EMPLOCTR [HRCTR2]: Endif
#LIPET - X3-11725 - 18-01-2017 - END
#63169
If !clalev([F:CNE]) : Local File CNGEMP   [CNE] : Endif
If !clalev([F:CNG]) : Local File CNGCPY   [CNG] : Endif
# fin 63169
If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif

Local Date    PYRDAT
Local Char    TIMCOD(GLONTPS), TIRZON(GLONAVA)
Local Decimal JOUR(1..2), HEURE(1..2)
Local Integer SEM0, LTYPDAY, LDAYNGT , CRETIR , MAJTIR , FLGTIR , TYPS
Raz CRETIR , MAJTIR
Local Char    SITPEO(GLONFCY)
Local Char    LESITE(GLONFCY) : #59323

Return

#-------------------------------------------------------------------------------
$AP_IMPORT
# bug superviseur
GIMP(2)=vireblc(GIMP(2),2)
GOK=1
Raz GMESSAGE
Call TRANSCODE(1,GIMP(2),1) From SUBIMPOBJ

#SBA US2029_92969 : on récupère le texte pour l'afficher dans la trace
Call LECTURE("EML",[F:TIP]REFNUM,"") From CONTOBJ

If fstat
 #LIPET - X3-11725 - 18-01-2017 - START
 #GMESSAGE=mess(83,702,1)-":"-[F:TIP]REFNUM : #  Matricule inexistant
 GMESSAGE=mess(83,10702,1)-":"-[F:TIP]REFNUM : #  Matricule inexistant
 #LIPET - X3-11725 - 18-01-2017 - END
 Call TRACE(2,GMESSAGE) From SUBIMPOBJ :# FQ74044 - SEGAY 13/02/12
 GOK=0
 Return
Endif

Local Char WTTRACE(250)
[L]WTTRACE=[F:TIP]REFNUM-"-"-[F:ID]NAM-[F:ID]SRN-"/"
If len(GIMP(2))<5 | left$(GIMP(2),1)="/"
  #MABOS-05/06/13
  #LIPET - X3-11725 - 18-01-2017 - START
  #GMESSAGE=mess(143,709,1)-"/"-mess(00026,00127,1)-":"-GIMP(2): #  'Nature d'événement inexistante / Transcodage Import/Export'
  GMESSAGE=mess(143,10709,1)-"/"-mess(00026,00127,1)-":"-GIMP(2): #  'Nature d'événement inexistante / Transcodage Import/Export'
  #LIPET - X3-11725 - 18-01-2017 - END
  #SBA US2029_9296
  GMESSAGE=[L]WTTRACE-GMESSAGE
 Call TRACE(2,GMESSAGE) From SUBIMPOBJ
 GMESSAGE=""
 GOK=0
 Return
Endif

# MABOS-22/05/13-FQ89268-US1612
#Filter [CTR] Where REFNUM=[F:TIP]REFNUM & CTRDAT<=[F:TIP]STRDAT
#&                & (XITDAT=[0/0/0] | XITDAT>=[F:TIP]ENDDAT)
#&     Order By Key CLE=CTRDAT Desc
#Read [CTR] First
#MABOS-10/07/13-FQ89268-US1728-Ajout parametres, appel SEARCH_CTR

Call SEARCH_CTR([F:TIP]REFNUM, [F:TIP]CTRNUM,[F:TIP]CTRDAT,[F:TIP]STRDAT, [F:TIP]ENDDAT, GMESSAGE) From DIVPAYE
#LIPET - X3-11725 - 18-01-2017 - START
If clalev([F:FCY2])=0 : Local File FACILITY [FCY2]  : Endif

 Read [FCY2]FCY0 = [F:HRCTR]ETRFCY
 If !fstat
  GCURLEG = [F:FCY2]LEG
 Endif
#LIPET - X3-11725 - 18-01-2017 - END

If [V]GOK=0 Then
  #  Call TRACE(2,GMESSAGE) From SUBIMPOBJ
  #SBA US2029_9296
  Call TRACE(2,[L]WTTRACE-GMESSAGE) From SUBIMPOBJ
  GMESSAGE=""
  Return
Endif
#end MABOS-22/05/13-FQ89268-US1612

Case left$(GIMP(2),3)
 When "TIP"
  TIMCOD=right$(GIMP(2),5)
  #LIPET - X3-11725 - 18-01-2017 - START
  #Call LECTURE("TIM",TIMCOD,"") From CONTOBJ
  Call LECTURE("HRTIM",TIMCOD,GCURLEG) From CONTOBJ
  #LIPET - X3-11725 - 18-01-2017 - END
  If fstat
  #SBA US2029_92969
  #LIPET - X3-11725 - 18-01-2017 - START
  # GMESSAGE=mess(143,709,1)-":"-TIMCOD   : #  Nature d'évènement inexistante
   #GMESSAGE=[L]WTTRACE-mess(143,709,1)-":"-TIMCOD   : #  Nature d'évènement inexistante
   GMESSAGE=[L]WTTRACE-mess(143,10709,1)-":"-TIMCOD   : #  Nature d'évènement inexistante
   #LIPET - X3-11725 - 18-01-2017 - END
   Call TRACE(2,GMESSAGE) From SUBIMPOBJ :# FQ74044 - SEGAY 13/02/12
   GOK=0
   Return
  Else
# FQ74044 - SEGAY 13/02/12 - Ajout vérification du nouveau champ FILTRE
    If [F:TIM]FILTRE<>"" | [F:TIM]POP<>"" Then
      Local Integer RET
      Call VERIF_FILTRE_TIM([F:TIM]FILTRE,[F:TIM]POP,[F:TIP]REFNUM,[F:TIP]CTRNUM,RET) From DIVPAYE
      If RET>0 Then
         #SBA US2029_92969
        #Call TRACE(2,mess(320,199,1)-":"-TIMCOD) From SUBIMPOBJ : # # Nature d'événement incompatible avec ce salarié
        Call TRACE(2,[L]WTTRACE-mess(320,199,1)-":"-TIMCOD) From SUBIMPOBJ : # # Nature d'événement incompatible avec ce salarié
        [V]GOK=0
        Return
      Endif
    Endif
# END FQ74044 - SEGAY
  Endif

  [F:TIP]LIG   =uniqid([TIP])

  #LIPET - X3-11725 - 18-01-2017 - START
#  [F:TIP]FCY   =[F:CTR]ETRFCY
#  [F:TIP]SRV   =[F:CTR]ETRSRV
#  [F:TIP]CTRNUM = [F:CTR]CTRNUM
  [F:TIP]FCY   =[F:HRCTR]ETRFCY
  [F:TIP]SRV   =[F:HRCTR]ETRSRV
  [F:TIP]CTRNUM = [F:HRCTR]CTRNUM
  #LIPET - X3-11725 - 18-01-2017 - END

  # FQ92876 - 27/06/14 - Récupération des axes depuis le planning personnel Ou initialisation si pas de planning
#  Call JOUR( [F:TIP]REFNUM,[F:TIP]STRDAT,LTYPDAY,JOUR,HEURE
#&         , LDAYNGT,[F:TIP]FCY,[F:TIP]CTRNUM,0,[F:TIP]STRTIM,[F:TIP]ENDTIM,[F:TIP]BRKTIM
#&         , [F:TIP]NATCOD,[F:TIP]CCE,I
#&         ) From SUBPLN
  Local Integer INI
  Local Char    CCE(GLONCCE)(1..max(1,GOPTCANA))
  Local Char    DIE(GLONDIE)(1..max(1,GOPTCANA))
  Call JOUR_AXE( [F:TIP]REFNUM,[F:TIP]STRDAT,LTYPDAY,JOUR,HEURE
&         , LDAYNGT,[F:TIP]FCY,[F:TIP]CTRNUM,0,[F:TIP]STRTIM,[F:TIP]ENDTIM,[F:TIP]BRKTIM
&         , [F:TIP]NATCOD,CCE,INI,DIE
&         ) From SUBPLN
  Gosub CALC_CCEDIE From IMPBADGEUSE
  # Fin FQ92876

  [F:TIP]DAYNGT=LDAYNGT
  [F:TIP]TIM   =TIMCOD

  If (func AFNC.ACTIV("SRV") > 0) & [F:TIM]TYPDAY = 2
   If [F:TIP]NATCOD <>""
    [F:TIP]TYPDAY=[F:NAT]TYPDAY
   Else
    Case dayn([F:TIP]STRDAT)
     When 6,7     : [F:TIP]TYPDAY = 2
     When Default : [F:TIP]TYPDAY = 1
    Endcase
   Endif
  Else
   [F:TIP]TYPDAY = 0
  Endif

  #59323
  LESITE = [F:TIP]FCY
  #LIPET - X3-11725 - 18-01-2017 - START
#  Call PERIO(LESITE,[F:TIP]REFNUM) From SUBPEO
#  #Filter [PEO] Where YEA=year([F:TIP]STRDAT) & FCY=[F:TIP]FCY
#  Filter [PEO] Where YEA=year([F:TIP]STRDAT) & FCY=LESITE
#  # fin 59323
#
#  Read [PEO]PEO0 First
#  Filter [PEO]
  Call PERIO(LESITE,[F:TIP]REFNUM) From SUBHRPEO
  #Filter [PEO] Where YEA=year([F:TIP]STRDAT) & FCY=[F:TIP]FCY
  #Filter [HRPEOD] Where YEA=year([F:TIP]STRDAT) & PERCOD=[F:HRCTR]PERCOD
  #LIPET - 2017-08-31 - START
  #Filter [HRPEOD] Where PERYEA=year([F:TIP]STRDAT) & PERCOD=[F:HRCTR]PERCOD
  Filter [HRPEOD] Where PERCOD=[F:HRCTR]PERCOD and PERYEA=year([F:TIP]STRDAT) #and PERNUM =
  # fin 59323
  #Read [HRPEOD]HRPEOD0 First
  Read [HRPEOD]HRPEOD0(2) First
  #LIPET - 2017-08-31 - END
  Filter [HRPEOD]
  #
  #LIPET - X3-11725 - 18-01-2017 - END
  If fstat<=2
   SITPEO = [F:TIP]FCY
  Else
   SITPEO = ""
  Endif

#Les intervalles de dates doivent porter sur un seul mois ou période d'extraction

  If [F:TIP]STRDAT <> [F:TIP]ENDDAT
   TYPS = 0                 : # période de paie
  Else
   TYPS = [F:TIM]MONDAC-1   : # [F:TIM]MONDAC : 1=Extraction temps , 2=Mois calendaire
  Endif

  #59323
  LESITE = SITPEO
  #LIPET - X3-11725 - 18-01-2017 - START
#  Call PERIO(LESITE,[F:TIP]REFNUM) From SUBPEO
#  #Filter [PEO] Where FCY=SITPEO &
#  #&  PERSTR(TYPS)<=[F:TIP]STRDAT & PEREND(TYPS)>=[F:TIP]STRDAT
#  Filter [PEO] Where FCY=LESITE &
#&  PERSTR(TYPS)<=[F:TIP]STRDAT & PEREND(TYPS)>=[F:TIP]STRDAT
#  #fin 59323
#
#  Look [PEO]PEO0 First
#
#  If fstat
#  #SBA US2029_92969
#   #GMESSAGE=mess(12,709,1)-":"-num$([F:TIP]STRDAT) : # Pas de paye définie à cette date
#   GMESSAGE=[L]WTTRACE-mess(12,709,1)-":"-num$([F:TIP]STRDAT) : # Pas de paye définie à cette date
#   Call TRACE(2,GMESSAGE) From SUBIMPOBJ :# FQ74044 - SEGAY 13/02/12
#   GOK=0
#   Return
#  Endif
#  Filter [PEO] Where FCY=SITPEO &
#&  PERSTR(TYPS)<=[F:TIP]STRDAT & PEREND(TYPS)>=[F:TIP]STRDAT &
#&  PERSTR(TYPS)<=[F:TIP]ENDDAT & PEREND(TYPS)>=[F:TIP]ENDDAT
#  Read [PEO]PEO0 First
#  Filter [PEO]
#  If fstat>2
#  #SBA US2029_92969
#   #GMESSAGE=mess(36,709,1)-":"-num$([F:TIP]STRDAT)+"->"+num$([F:TIP]ENDDAT) : # Période à cheval sur 2 paies
#    GMESSAGE=[L]WTTRACE-mess(36,709,1)-":"-num$([F:TIP]STRDAT)+"->"+num$([F:TIP]ENDDAT) : # Période à cheval sur 2 paies
#   Call TRACE(2,GMESSAGE) From SUBIMPOBJ :# FQ74044 - SEGAY 13/02/12
#   GOK=0
#   Return
#  Endif
  Call PERIO(LESITE,[F:TIP]REFNUM) From SUBHRPEO
  #Filter [PEO] Where FCY=SITPEO &
  #&  PERSTR(TYPS)<=[F:TIP]STRDAT & PEREND(TYPS)>=[F:TIP]STRDAT
  Filter [HRPEOD] Where PERCOD=[F:HRCTR]PERCOD &
&  PERSTR(TYPS)<=[F:TIP]STRDAT & PEREND(TYPS)>=[F:TIP]STRDAT
  #fin 59323

  Look [HRPEOD]HRPEOD0 First

  If fstat
  #SBA US2029_92969
   #GMESSAGE=mess(12,709,1)-":"-num$([F:TIP]STRDAT) : # Pas de paye définie à cette date
   GMESSAGE=[L]WTTRACE-mess(12,10709,1)-":"-num$([F:TIP]STRDAT) : # Pas de paye définie à cette date
   Call TRACE(2,GMESSAGE) From SUBIMPOBJ :# FQ74044 - SEGAY 13/02/12
   GOK=0
   Return
  Endif
  Filter [HRPEOD] Where PERCOD=[F:HRCTR]PERCOD &
&  PERSTR(TYPS)<=[F:TIP]STRDAT & PEREND(TYPS)>=[F:TIP]STRDAT &
&  PERSTR(TYPS)<=[F:TIP]ENDDAT & PEREND(TYPS)>=[F:TIP]ENDDAT
  Read [HRPEOD]HRPEOD0 First
  Filter [HRPEOD]
  If fstat>2
  #SBA US2029_92969
   #GMESSAGE=mess(36,709,1)-":"-num$([F:TIP]STRDAT)+"->"+num$([F:TIP]ENDDAT) : # Période à cheval sur 2 paies
    GMESSAGE=[L]WTTRACE-mess(36,10709,1)-":"-num$([F:TIP]STRDAT)+"->"+num$([F:TIP]ENDDAT) : # Période à cheval sur 2 paies
   Call TRACE(2,GMESSAGE) From SUBIMPOBJ :# FQ74044 - SEGAY 13/02/12
   GOK=0
   Return
  Endif
  #LIPET - X3-11725 - 18-01-2017 - END
  If [F:TIP]STRDAY = 2 | [F:TIP]ENDDAY = 2  : # demi-journée
   # l'évévnement doit porter sur un jour et être de type saisie jour
   If ([F:TIP]STRDAT <> [F:TIP]ENDDAT) | [F:TIM]DAYDAC <> 2
   #LIPET - X3-11725 - 18-01-2017 - START
#    GMESSAGE=mess(181,709,1)-
#&    ": ("+TIMCOD-num$([F:TIP]STRDAT)+"->"+num$([F:TIP]ENDDAT)+")" : # Cette journée ne contient...
       GMESSAGE=mess(181,10709,1)-
&    ": ("+TIMCOD-num$([F:TIP]STRDAT)+"->"+num$([F:TIP]ENDDAT)+")" : # Cette journée ne contient...
   #LIPET - X3-11725 - 18-01-2017 - END
 #SBA US2029_92969
    GMESSAGE=[L]WTTRACE-GMESSAGE
 Call TRACE(2,GMESSAGE) From SUBIMPOBJ :# FQ74044 - SEGAY 13/02/12
    GOK=0                                                       : #... pas deux plages horaires
    Return
   Endif
  Endif

  #LIPET - X3-11725 - 18-01-2017 - START
  #[F:TIP]DATPYR = [F:PEO]PYRDAT
  [F:TIP]DATPYR = [F:HRPEOD]PYRDAT
  #LIPET - X3-11725 - 18-01-2017 - END
  # FQ92876 - 27/06/14 - Récupération des axes depuis le planning personnel Ou initialisation si pas de planning
#  [F:TIP]DSP   =""
  [F:TIP]ANAFLG=0
#  [F:TIP]STRTIM=""
#  [F:TIP]ENDTIM=""
#  [F:TIP]BRKTIM=0

  [F:TIP]AUTFLG=1 : # Génération automatique
  [F:TIP]STAFLG=""
  [F:TIP]STA   =0 : # à quoi ça sert ?

  [F:TIP]CPY   =""
  [F:TIP]BPCNUM=""
  [F:TIP]SOHNUM=""
  [F:TIP]SOHLIG=0
  [F:TIP]INVFLG=1

  If [F:TIP]NATCOD>""
   [F:TIP]QTY1=[F:NAT]QTY1
   [F:TIP]QTY2=[F:NAT]QTY2
   [F:TIP]FLD1=[F:NAT]FLD1
   [F:TIP]FLD2=[F:NAT]FLD1
  Endif


  # FQ82073 - MABON 07/12/12 - Si [F:TIP]CTRDAT n'est pas importé, il faut le calculer
  If [F:TIP]CTRDAT=[0/0/0] Then
  #LIPET - X3-11725 - 18-01-2017 - START
   #[F:TIP]CTRDAT=func TPSSTD.CALC_CTRDATDEF([F:TIP]REFNUM,[F:TIP]CTRNUM,[F:PEO]PEREND(0),[F:TIP]DATPYR,[F:TIP]ENDDAT,1)
    [F:TIP]CTRDAT=func TPSSTD.CALC_CTRDATDEF([F:TIP]REFNUM,[F:TIP]CTRNUM,[F:HRPEOD]PEREND(0),[F:TIP]DATPYR,[F:TIP]ENDDAT,1)
  #LIPET - X3-11725 - 18-01-2017 - END
  Else
  #LIPET - X3-11725 - 18-01-2017 - START
   # Contrôle date saisie
   #Read [F:CTR2]CTR0=[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]CTRDAT
   Read [F:HRCTR2]CTR0=[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]CTRDAT
   #LIPET - X3-11725 - 18-01-2017 - END
   If fstat
    #LIPET - X3-11725 - 18-01-2017 - START
    #SBA US2029_92969
    #GMESSAGE=[F:TIP]REFNUM+"/"+[F:TIP]CTRNUM+"/"+format$("D:"+GFMDAT4,[F:TIP]CTRDAT)-mess(26,701,1) : # Contrat inexistant
    #GMESSAGE=[L]WTTRACE+[F:TIP]CTRNUM+"/"+format$("D:"+GFMDAT4,[F:TIP]CTRDAT)-mess(26,701,1) : # Contrat inexistant
    GMESSAGE=[L]WTTRACE+[F:TIP]CTRNUM+"/"+format$("D:"+GFMDAT4,[F:TIP]CTRDAT)-mess(26,10701,1) : # Contrat inexistant
    #LIPET - X3-11725 - 18-01-2017 - END
  Call TRACE(2,GMESSAGE) From SUBIMPOBJ :# FQ74044 - SEGAY 13/02/12
    GOK=0
    Return
   Else
     #LIPET - X3-11725 - 18-01-2017 - START
     # FQ81491 - 15/11/13 - Prise en compte date d'effet, d'où l'ajout de FLGRET et RETDATEFF
     #If  (([F:CTR2]FLGRET<>2 & [F:CTR2]CTRDAT<=[F:TIP]DATPYR) | ([F:CTR2]FLGRET=2 & [F:CTR2]RETDATEFF<=[F:TIP]DATPYR)) & ([F:CTR2]XITDAT=[0/0/0] | [F:TIP]ENDDAT<=[F:CTR2]XITDAT) Then
     If  (([F:HRCTR2]FLGRET<>2 & [F:HRCTR2]CTRDAT<=[F:TIP]DATPYR) | ([F:HRCTR2]FLGRET=2 & [F:HRCTR2]RETDATEFF<=[F:TIP]DATPYR)) & ([F:HRCTR2]XITDAT=[0/0/0] | [F:TIP]ENDDAT<=[F:HRCTR2]XITDAT) Then
      # Date ok
     #LIPET - X3-11725 - 18-01-2017 - END
     Else
       #LIPET - X3-11725 - 18-01-2017 - START
       #SBA US2029_92969
       #GMESSAGE=mess(138,701,1) : # Contrat incompatible avec l'événement
       #GMESSAGE=[L]WTTRACE-mess(138,701,1): # Contrat incompatible avec l'événement
       GMESSAGE=[L]WTTRACE-mess(138,10701,1): # Contrat incompatible avec l'événement
       #LIPET - X3-11725 - 18-01-2017 - END
       Call TRACE(2,GMESSAGE) From SUBIMPOBJ :# FQ74044 - SEGAY 13/02/12
       GOK=0
       Return
     Endif
   Endif
  Endif
  # Fin MABON


  If dim([F:TIP]CREUSR)=1 : [F:TIP]CREUSR=GUSER  : Endif
  If dim([F:TIP]CREDAT)=1 : [F:TIP]CREDAT=date$     : Endif
  If dim([F:TIP]CRETIM)=1 : [F:TIP]CRETIM=time      : Endif
  If dim([F:TIP]EXPNUM)=1 : [F:TIP]EXPNUM=[C]EXPORT : Endif

 When "TIR"
  TIRZON=right$(GIMP(2),5)
  If !find(TIRZON,[G:TIR]adxfname(0..[G:TIR]nbzon-1))
   #SBA US2029_92969
   # GMESSAGE=mess(41,100,1)-": TIMRECAP"-TIRZON
   GMESSAGE=[L]WTTRACE-mess(41,100,1)-": TIMRECAP"-TIRZON
   Call TRACE(2,GMESSAGE) From SUBIMPOBJ :# FQ74044 - SEGAY 13/02/12
   GOK=0
   Return
  Endif

  PYRDAT=[F:TIP]STRDAT
  #LIPET - X3-11725 - 18-01-2017 - START
  #Call CADRE_PYRDAT(PYRDAT,[F:CTR]ETRFCY) From TPSSUB
  Call CADRE_PYRDAT(PYRDAT,[F:HRCTR]PERCOD) From TPSSUB
  #LIPET - X3-11725 - 18-01-2017 - END
  If mkstat
   #LIPET - X3-11725 - 18-01-2017 - START
   #SBA US2029_92969
   #GMESSAGE=mess(12,709,1)-":"-num$([F:TIP]STRDAT) : # Pas de paye définie à cette date
   #GMESSAGE=[L]WTTRACE-mess(12,709,1)-":"-num$([F:TIP]STRDAT) : # Pas de paye définie à cette date
   GMESSAGE=[L]WTTRACE-mess(12,10709,1)-":"-num$([F:TIP]STRDAT) : # Pas de paye définie à cette date
   #LIPET - X3-11725 - 18-01-2017 - END
   Call TRACE(2,GMESSAGE) From SUBIMPOBJ :# FQ74044 - SEGAY 13/02/12
   GOK=0
   Return
  Endif
  #LIPET - X3-11725 - 18-01-2017 - START
  #Call DAT([F:PEO]PERSTR(0),I,SEM0) From SUBPLN
#MIPEA - 2017-11-27- US X3-63170- START
Call SET_GFIRDAY([F:HRCTR]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-27- US X3-63170- END
  Call DAT([F:HRPEOD]PERSTR(0),I,SEM0) From SUBPLN
  #LIPET - X3-11725 - 18-01-2017 - END
  Call DAT([F:TIP]STRDAT,I,J) From SUBPLN
  I=J-SEM0

  # FQ82073 - MABON 03/01/13 - Ajout CTRDAT dans TIMRECAP : calcul des semaines du mois
  Local Integer K,NBSEM,ANNEE,SEMAINE
  Local Date    DAT,ENDWEK(0..5)
  #LIPET - X3-11725 - 18-01-2017 - START
  #DAT = [F:PEO]PERSTR(0)
  DAT = [F:HRPEOD]PERSTR(0)
  #LIPET - X3-11725 - 18-01-2017 - END
  Repeat
   Call DAT(DAT,ANNEE,SEMAINE) From SUBPLN
   ENDWEK(NBSEM) = DAT+6
   If [F:TIP]STRDAT<=ENDWEK(NBSEM) Then I=NBSEM : Endif
   NBSEM += 1
   DAT += 7
   #LIPET - X3-11725 - 18-01-2017 - START
   #Until DAT>[F:PEO]PEREND(0)
   Until DAT>[F:HRPEOD]PEREND(0)
   #LIPET - X3-11725 - 18-01-2017 - END
  # Fin MABON

  #LIPET - X3-11725 - 18-01-2017 - START
  #Readlock [TIR]TIR0=[F:TIP]REFNUM;[F:CTR]CTRNUM;PYRDAT
  Readlock [TIR]TIR0=[F:TIP]REFNUM;[F:HRCTR]CTRNUM;PYRDAT
  #LIPET - X3-11725 - 18-01-2017 - END
  If fstat=1
   GOK  =-1
   #LIPET - X3-11725 - 18-01-2017 - START
   #GLOCK="$TIMRECAP"-[F:TIP]REFNUM-[F:CTR]CTRNUM-num$(PYRDAT)
   GLOCK="$TIMRECAP"-[F:TIP]REFNUM-[F:HRCTR]CTRNUM-num$(PYRDAT)
   #LIPET - X3-11725 - 18-01-2017 - END
   Return
  Elsif fstat
   Raz [F:TIR]

   #LIPET - X3-11725 - 18-01-2017 - START
#   [F:TIR]REFNUM=[F:TIP]REFNUM
#   [F:TIR]CTRNUM=[F:CTR]CTRNUM
#   [F:TIR]PYRDAT=PYRDAT
#   [F:TIR]FCY   =[F:CTR]ETRFCY
#   [F:TIR]SRV   =[F:CTR]ETRSRV
#   [F:TIR]CODACS=[F:ID]CODACS
   [F:TIR]REFNUM=[F:TIP]REFNUM
   [F:TIR]CTRNUM=[F:HRCTR]CTRNUM
   [F:TIR]PYRDAT=PYRDAT
   [F:TIR]FCY   =[F:HRCTR]ETRFCY
   [F:TIR]SRV   =[F:HRCTR]ETRSRV
   [F:TIR]CODACS=[F:ID]CODACS
   #LIPET - X3-11725 - 18-01-2017 - END
   # FQ82073 - MABON 03/01/13 - Ajout CTRDAT dans TIMRECAP
   For K=0 To min(dim([F:TIR]CTRDAT)-1,dim(ENDWEK)-1)
     If ENDWEK(K)<>[0/0/0] Then
      #LIPET - X3-11725 - 18-01-2017 - START
      #[F:TIR]CTRDAT(K)=func TPSSTD.CALC_CTRDATDEF([F:TIR]REFNUM,[F:TIR]CTRNUM,[F:PEO]PEREND(0),PYRDAT,ENDWEK(K),2)
      [F:TIR]CTRDAT(K)=func TPSSTD.CALC_CTRDATDEF([F:TIR]REFNUM,[F:TIR]CTRNUM,[F:HRPEOD]PEREND(0),PYRDAT,ENDWEK(K),2)
      #LIPET - X3-11725 - 18-01-2017 - END
     Endif
   Next
   # Fin MABON
   If dim([F:TIR]CREUSR)=1 : [F:TIR]CREUSR=GUSER  : Endif
   If dim([F:TIR]CREDAT)=1 : [F:TIR]CREDAT=date$     : Endif
   If dim([F:TIR]CRETIM)=1 : [F:TIR]CRETIM=time      : Endif
   If dim([F:TIR]EXPNUM)=1 : [F:TIR]EXPNUM=[C]EXPORT : Endif
   Assign "[F:TIR]"+TIRZON+"("+num$(I)+")" With [F:TIP]NBRDAY+[F:TIP]NBRHOU

   Write [TIR]
   FLGTIR = 1

  Else
   # FQ82073 - MABON 03/01/13 - Ajout CTRDAT dans TIMRECAP
   For K=0 To min(dim([F:TIR]CTRDAT)-1,dim(ENDWEK)-1)
     If [F:TIR]CTRDAT(K)=[0/0/0] & ENDWEK(K)<>[0/0/0] Then
      [F:TIR]CTRDAT(K)=func TPSSTD.CALC_CTRDATDEF([F:TIR]REFNUM,[F:TIR]CTRNUM,PYRDAT,PYRDAT,ENDWEK(K),2)
     Endif
   Next
   # Fin MABON
   If dim([F:TIR]UPDUSR)=1 : [F:TIR]UPDUSR=GUSER  : Endif
   If dim([F:TIR]UPDDAT)=1 : [F:TIR]UPDDAT=date$     : Endif
   If dim([F:TIR]UPDTIM)=1 : [F:TIR]UPDTIM=time      : Endif
   If dim([F:TIR]EXPNUM)=1 : [F:TIR]EXPNUM=[C]EXPORT : Endif

   Assign "[F:TIR]"+TIRZON+"("+num$(I)+")"
&   With [F:TIP]NBRDAY+[F:TIP]NBRHOU+evalue("[F:TIR]"+TIRZON+"("+num$(I)+")")

   Rewrite [TIR]
   FLGTIR = 2

  Endif
  If fstat
   GOK=0
   Call FSTA("TIR") From GLOCK
   Return
  Endif
  Case FLGTIR
   When 1
    CRETIR +=1
    Call TRACE(0,"TIMRECAP:"-[L]WTTRACE-num$([F:TIR]PYRDAT)) From SUBIMPOBJ
   When 2
    MAJTIR +=1
    Call TRACE(1,"TIMRECAP:"-[L]WTTRACE-num$([F:TIR]PYRDAT)) From SUBIMPOBJ
  Endcase
Endcase
Return

$CALC_CCEDIE

  If INI=1
    Local Char CPY_TIP(GLONCPY) : CPY_TIP=[F:TIP]CPY
    If CPY_TIP="" & [F:TIP]FCY<>"" Then
      Read [F:FCY]FCY0=[F:TIP]FCY
      If !fstat Then
        CPY_TIP=[F:FCY]LEGCPY
      Endif
    Endif
    Gosub LISTDIE From TPSSUB
    Local Integer JS : JS=0
    For AXE=1 To GOPTCANA
      If find(DIE(AXE),WLSTDIE(1..WNBRDIE)) Then
        [F:TIP]CCE(JS) = CCE(AXE)
        [F:TIP]DIE(JS) = DIE(AXE)
        JS += 1
      Endif
    Next
  Else
#MIPEA - X3-11725 - 26-01-2017 - START
    Gosub OUVRE From WPDEFTABLE
#    Gosub OUVRE From DEFTABLE
#MIPEA - X3-11725 - 26-01-2017 - END
    If [F:ID]REFNUM<>[F:TIP]REFNUM  : Read [ID]ID0  =[F:TIP]REFNUM : Endif
#LIPET - 01-03-2017 - START
#    Local Char MATRI(GLONMAT) : MATRI=[F:TIP]REFNUM
#    Local Char CTR(GLONCTR)   : CTR=[F:TIP]CTRNUM
    Local Char MATRI(GLONEML) : MATRI=[F:TIP]REFNUM
    Local Char CTR(GLONHRCTR)   : CTR=[F:TIP]CTRNUM
#LIPET - 01-03-2017 - END
    Gosub INISEC From TPSSUB
    Gosub VERFSEC From TRTREM
  Endif
Return

#-------------------------------------------------------------------------------
$IMP_VERIF_CRE
If len(GIMP(2))<5 | left$(GIMP(2),1)="/"
 GMESSAGE = GIMP(2)-":"-mess(26,127,1)  : # Transcodage Import/Export
 OK = 0
Elsif left$(GIMP(2),3)="TIP" & [F:TIP]LIG = 0 & GOK
 GMESSAGE="TIMEMP"-mess(156,115,1)
 OK = 0
Endif
If GOK = 0
 OK = 0
Endif
#63169
If OK=0 : Return : Endif
If left$(GIMP(2),3)="TIP"
 #LIPET - X3-11725 - 18-01-2017 - START
 #Call LECTURE("TIM",[F:TIP]TIM,"") From CONTOBJ
 Call LECTURE("HRTIM",[F:TIP]TIM,GCURLEG) From CONTOBJ
 #LIPET - X3-11725 - 18-01-2017 - END
 If !fstat & [F:TIM]CATTIM=3 & [F:TIM]FLGBLC=2
  Filter [CNG] Where CPY=func DIVPAYE.GETSOC([F:TIP]FCY) & TIM=[F:TIP]TIM
&           & ( (STRDAT<=[F:TIP]STRDAT & ENDDAT>=[F:TIP]ENDDAT) | (DEBDAT<=[F:TIP]STRDAT & FINDAT>=[F:TIP]ENDDAT) )
#JASMI - 2014-09-04 - START
 #LIPET - X3-11725 - 18-01-2017 - START
 #If func AFNC.ACTIV("KSA")>0 & (func AFNC.ACTIV("KFR")=0 & func AFNC.ACTIV("KPO")=0) Then
 If func DIVPAYE.IS_ZA_DEV_LEG(GCURLEG)
 #LIPET - X3-11725 - 18-01-2017 - END
  Filter [F:CNE] Where TIM=[F:TIP]TIM & REFNUM=[F:TIP]REFNUM & CTRNUM=[F:TIP]CTRNUM & EMPLEASTR<=[F:TIP]STRDAT & EMPLEAEND>=[F:TIP]ENDDAT
  Read [F:CNE]CNE0 Last
  Filter [F:CNE]
  If !fstat
    Filter [F:CNG] Where CPY=func DIVPAYE.GETSOC([F:TIP]FCY) & TIM=[F:TIP]TIM & YEA=[F:CNE]YEA
  Endif
 Endif
#JASMI - 2014-09-04 - END
  Read [CNG]CNG0 First
  Filter [CNG]
  If !fstat
   Read [CNE]CNE0=[F:CNG]YEA;[F:TIP]REFNUM;[F:TIP]CTRNUM;[F:TIP]TIM
   If fstat
   #LIPET - X3-11725 - 18-01-2017 - START
    # Salarié xxx Fiche congé par employé inexistante pour l'année
    #GMESSAGE = mess(64,709,1)-[F:TIP]REFNUM-mess(165,709,1)-num$([F:CNG]YEA)
    #OK = 0 : Return
    GMESSAGE = mess(64,10709,1)-[F:TIP]REFNUM-mess(165,10709,1)-num$([F:CNG]YEA)
    OK = 0 : Return
    #LIPET - X3-11725 - 18-01-2017 - END
   Endif
  Else
   #SBA US2029_92969
     #GMESSAGE = mess(319,199,1)-[F:TIM]COD : # Fiche période de congé inexistante pour l'évènement
     GMESSAGE = [L]WTTRACE-mess(319,199,1)-[F:TIM]COD : # Fiche période de congé inexistante pour l'évènement
   OK = 0 : Return
  Endif
 Endif
Endif
# fin 63169
Return

#-------------------------------------------------------------------------------
$IMP_FERME
Raz GMESSAGE
If CRETIR | MAJTIR
 #LIPET - X3-11725 - 18-01-2017 - START
 #Call ECR_TRACE("\\"+string$(70,"-")+"\TIMRECAP"-mess(4,309,1)+"\",0) From GESECRAN  : # Synthèse des temps
 Call ECR_TRACE("\\"+string$(70,"-")+"\TIMRECAP"-mess(4,10309,1)+"\",0) From GESECRAN  : # Synthèse des temps
 #LIPET - X3-11725 - 18-01-2017 - end
 Call ECR_TRACE(num$(CRETIR)-mess(103,141,1),0) From GESECRAN : # Enregistrements créés
 Call ECR_TRACE(num$(MAJTIR)-mess(104,141,1),0) From GESECRAN : # Enregistrements modifiés
Endif
Call ECR_TRACE("\"+string$(70,"-")+"\TIMEMP"-mess(2,933,1),0) From GESECRAN  : # Saisie des temps
Return

#-------------------------------------------------------------------------------
#63169
$IMP_CREATION
If left$(GIMP(2),3)="TIP"
 #LIPET - X3-11725 - 18-01-2017 - START
 #Call LECTURE("TIM",[F:TIP]TIM,"") From CONTOBJ
 Call LECTURE("HRTIM",[F:TIP]TIM,GCURLEG) From CONTOBJ
 #LIPET - X3-11725 - 18-01-2017 - END
 If !fstat & [F:TIM]CATTIM=3
  Call ADD_CPPRIS([F:TIP]NBRDAY) From TPSSTD1
  If [V]GOK<1 : Return : Endif
 Endif
Endif
Return

