#######################################################################################
# Classe OPPOR
#######################################################################################
# CRM METHODS                                                                         #
#######################################################################################
$ADELETE_CONTROL_AFTER
Return

#######################################################################################
$CRM_INIT_OPPOR_FROM_SRE
#Value Char CHRONO ()

Local Integer INBSRE

  If CHRONO <> "" Then
    #Détecte si une autre affaire a déjà été créée pour couvrir cette même demande
    Local File OPPORCRM [OPPCRM]
    INBSRE = 0
    Filter [OPPCRM] Where [F:OPPCRM]OPPSRENUM=CHRONO
    INBSRE = rowcount([F:OPPCRM])
    Filter [OPPCRM]
    If INBSRE > 0 Then
      If INBSRE > 1 Then
        # NNN autres affaires ont déjà été créées pour couvrir la demande de service n° : XXXX
        [L]ARET_VALUE = fmet this.SETERROR("", num$(INBSRE) - mess(412,182,1) - CHRONO, [V]CST_AERROR)
      Else
        # Une autre affaire a déjà été créée pour couvrir la demande de service n° : XXXX
        [L]ARET_VALUE = fmet this.SETERROR("", mess(413,182,1) - CHRONO, [V]CST_AERROR)
      Endif
    Endif
    # -------------------------
    If [L]ARET_VALUE <> [V]CST_AERROR Then
      Local File SERREQUEST [SRE]
      Read [SRE]SRE0=CHRONO
      If fstat Then
        [L]ARET_VALUE = fmet this.SETERROR("", mess(23,100,1) - ":" - CHRONO, [V]CST_AERROR)
      Else
        this.SALFCY = [F:SRE]SALFCY
        this.OPPCMP = [F:SRE]SREBPC
        this.OPPMCN = [F:SRE]SRECCN
        #Remplissage origine
        this.OPPORITYP = 2 #Généré
        this.OPPORI = 6    #Demande de service
        this.OPPORIVCR = [M:OPP0]OPPSRENUM
        this.OPPORIVCRL = 0
        this.PIMPL.PIMDESAXX = mess(286,196,1) - [F:SRE]SRENUM         # Couvrir commercialement la demande n° xxx
        [L]ARET_VALUE = fmet this.COM_PROMOTE_CRM()
        If [L]ARET_VALUE <> [V]CST_AERROR Then
          this.CRM(1).OPPSRENUM = [F:SRE]SRENUM
          this.CRM(1).OPPCDA = [F:SRE]SRERESDAT
          this.CRM(1).OPPSTEADI = 400
          this.CRM(1).STRSTE = date$
        Endif
      Endif
    Endif
  Endif
Return

#######################################################################################
$_CRM_ADD_STEPB
#Value Char TYP ()
#Value Char VCRNUM ()
#Value Char PREOPPNUM ()
#Local Integer ARET_VALUE

Local Char SZADICODE(GLONADI)
Local Char SZSQHCODE(GLONADI)
Local Integer IDOBAPCLL
Local Integer NI

  If fmet this.COM_IS_CRM_OPPOR() = [V]CST_AFALSE Then
    Return  # L'affaire n'est ni CRM, ni mixte : rien à faire
  Endif
  If find(TYP,"SQH","SOH","CLL","BAP") = 0 Then
    # Contrôle des types acceptés (bug if error here)
    [L]ARET_VALUE = fmet this.SETERROR("", mess(1178,196,1) - ":" - TYP, [V]CST_AERROR)
    Return
  Endif
  # ------------------------------------
  Local File ATABDIV [ADI]
  # ------------------------------------
  If TYP = "BAP" or TYP = "CLL" Then
    # Mise à jour depuis un rdv ou un appel
    If TYP = "BAP" Then
      Local File BAPPOINT [BAP]
      Read [BAP]APP0=VCRNUM
      If [F:BAP]APTDON <> [V]CST_AYES Then
        Return
      Endif
    Elsif TYP = "CLL" Then
      Local File PHONECALL [CLL]
      Read [CLL]CLL0=VCRNUM
      If [F:CLL]CLLDON <> [V]CST_AYES Then
        Return
      Endif
    Endif
    # --------------------------------------------------------------------
    # Obtient le code de table diverse correspondant à la remise d'un devis
    Filter [ADI] Where [F:ADI]NUMTAB = 400 and [F:ADI]N2 = 3
    For [ADI]
      SZSQHCODE = [F:ADI]CODE
      Break
    Next
    Filter [ADI]
    If SZSQHCODE = "" Then
      Return
    Endif
    #Obtient le code de table diverse correspondant à la négociation
    Filter [ADI] Where [F:ADI]NUMTAB = 400 and [F:ADI]N2 = 4
    For [ADI]
      SZADICODE = [F:ADI]CODE
      Break
    Next
    Filter [ADI]
    If SZADICODE = "" Then
      Return
    Endif
    # --------------------------------------------------------------------
    If this.CRM(1).OPPSTEA2 = "WIN" Then
      # Si l'affaire est déjà gagnée, on n'enregistre plus d'étapes avant-vente, même si elle n'est pas close
      Return
    Elsif this.CRM(1).OPPSTEA2 = "LOS" or this.CRM(1).OPPSTEA2 = "FOR" Then
      # Si l'affaire est perdue ou abandonnée, et qu'on enregistre un CLL/BAP c'est qu'elle revient dans le circuit.
      # Même close elle sera réouverte. Donc on continue. On ne fait rien ici
    Elsif this.OPPCLO = [V]CST_AYES Then
      Return  # Si l'affaire est close, c'est fini
    Endif
    # -------------------------------------
    IDOBAPCLL = [V]CST_AFALSE
    For NI = 1 To maxtab(this.CRM(1).STPSTB)
      If this.CRM(1).STPSTB(NI) <> null and find(this.CRM(1).STPSTB(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        If this.CRM(1).STPSTB(NI).STE = SZSQHCODE Then
          IDOBAPCLL = [V]CST_ATRUE
          Break
        Endif
      Endif
    Next NI
    If IDOBAPCLL = [V]CST_AFALSE Then
      Return  # Tant qu'il n'y a pas de devis, on n'est pas en négociation : on n'enregistre pas les BAP/CLL
    Endif
    [L]ARET_VALUE = fmet this._CRM_ADD_STEPB_DATA(TYP, VCRNUM, PREOPPNUM, SZADICODE)
  Elsif TYP = "SQH" Then
    # Mise à jour depuis un devis
    # Obtient le code de table diverse correspondant à la remise d'un devis
    Filter [ADI] Where [F:ADI]NUMTAB = 400 and [F:ADI]N2 = 3
    For [ADI]
      SZADICODE = [F:ADI]CODE
      Break
    Next
    Filter [ADI]
    If SZADICODE = "" Then
      Return
    Endif
    If this.CRM(1).OPPSTEA2 = "WIN" Then
      # Si l'affaire est déjà gagnée, on n'enregistre plus les devis, même si elle n'est pas close
      Return
    Elsif this.CRM(1).OPPSTEA2 = "LOS" or this.CRM(1).OPPSTEA2 = "FOR" Then
      # Si l'affaire est perdue ou abandonnée, et qu'on enregistre un devis c'est qu'elle revient dans le circuit.
      # Même close elle sera réouverte. Donc on continue. On ne fait rien ici
    Elsif this.OPPCLO = [V]CST_AYES Then
      Return  # Si l'affaire est close, c'est fini
    Endif
    [L]ARET_VALUE = fmet this._CRM_ADD_STEPB_DATA(TYP, VCRNUM, PREOPPNUM, SZADICODE)
  Elsif TYP = "SOH" Then
    # Mise à jour depuis une commande de vente
    # Obtient le code de table diverse correspondant au gain d'une affaire
    Filter [ADI] Where [F:ADI]NUMTAB = 400 and [F:ADI]N2 = 5
    For [ADI]
      SZADICODE = [F:ADI]CODE
      Break
    Next
    Filter [ADI]
    If SZADICODE = "" Then
      Return
    Endif
    If this.CRM(1).OPPSTEA2 = "WIN" Then
      # Si l'affaire est déjà gagnée, on n'enregistre plus de commande, même si elle n'est pas close
      Return
    Elsif this.CRM(1).OPPSTEA2 = "LOS" or this.CRM(1).OPPSTEA2 = "FOR" Then
      # Si l'affaire est perdue ou abandonnée, et qu'on enregistre une commande c'est qu'elle revient dans le circuit.
      # Même close elle sera réouverte. Donc on continue. On ne fait rien ici
    Elsif this.OPPCLO = [V]CST_AYES Then
      Return  # Si l'affaire est close, c'est fini
    Endif
    [L]ARET_VALUE = fmet this._CRM_ADD_STEPB_DATA(TYP, VCRNUM, PREOPPNUM, SZADICODE)
  Endif
Return

#######################################################################################
$_CRM_ADD_STEPB_DATA
#Value Char TYP ()
#Value Char VCRNUM ()
#Value Char PREOPPNUM ()
#Value Char CODADI ()
#Local Integer ARET_VALUE

Local Integer ILINE
Local Integer NI
Local Instance ZPREOPP Using C_OPPOR

  # -------------------------------------
  If PREOPPNUM <> "" Then
    ZPREOPP = NewInstance With C_OPPOR
    [L]ARET_VALUE = fmet ZPREOPP.CRM_DEL_STEPB(PREOPPNUM, TYP, VCRNUM)
    If [L]ARET_VALUE = [V]CST_AERROR Then
      [L]ARET_VALUE = fmet this.SETERROR("", mess(1179,196,1) - ":" - PREOPPNUM, [V]CST_AERROR)
      FreeGroup ZPREOPP
      Return
    Endif
    FreeGroup ZPREOPP
  Endif
  # -------------------------------------
  Local File ATABDIV [ADI]
  Read [ADI]CODE=400;CODADI
  # -------------------------------------
  ILINE = fmet this.CRM(1).ADDLINE("STPSTB", [V]CST_ALASTPOS)
  this.CRM(1).STPSTB(ILINE).STE = [F:ADI]CODE
  If find([F:ADI]N3,[V]CST_AYES,[V]CST_ANO) = 0 Then
    this.CRM(1).STPSTB(ILINE).DON = [V]CST_AYES
  Else
    this.CRM(1).STPSTB(ILINE).DON = [F:ADI]N3
  Endif
  this.CRM(1).STPSTB(ILINE).STRDAT = date$
  this.CRM(1).STPSTB(ILINE).ENDDAT = date$
  this.CRM(1).STPSTB(ILINE).STEORIAOB = TYP
  this.CRM(1).STPSTB(ILINE).STEORIVCR = VCRNUM
  # Issue X3-99077 - 2018-07-06 by FGR : BEGIN : Not necessary
  #this.CRM(1).STPSTB(ILINE).STELIN = 1
  #If ILINE > 1 Then
  #  # S'il y a plusieurs lignes à la même date il faut trouver un STELIN libre
  #  For NI = 1 To maxtab(this.CRM(1).STPSTB)
  #    If NI <> ILINE Then
  #      If this.CRM(1).STPSTB(NI) <> null and find(this.CRM(1).STPSTB(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
  #        If this.CRM(1).STPSTB(NI).STRDAT = this.CRM(1).STPSTB(ILINE).ENDDAT Then
  #          this.CRM(1).STPSTB(ILINE).STELIN = this.CRM(1).STPSTB(NI).STELIN + 1
  #        Endif
  #      Endif
  #    Endif
  #  Next NI
  #Endif
  # Issue X3-99077 - 2018-07-06 by FGR : END
  # -------------------------------------------------
  # Etape en cours
  this.CRM(1).STRSTE = this.CRM(1).STPSTB(ILINE).ENDDAT
  this.CRM(1).OPPREACDA = this.CRM(1).STPSTB(ILINE).ENDDAT
  this.CRM(1).OPPSTEADI = 400
  this.CRM(1).OPPSTE = this.CRM(1).STPSTB(ILINE).STE
  If TYP = "SQH" Then
    this.CRM(1).OPPNBQ += 1
  Elsif TYP = "SOH" Then
    this.CRM(1).OPPSTEA2 = "WIN"
  Else
    this.CRM(1).OPPSTEA2 = ""
  Endif
  this.OPPCLO = [F:ADI]N1
  # -------------------------------------------------
Return

#######################################################################################
$_CRM_DEL_STEPB
#Value Char TYP ()
#Value Char VCRNUM ()
#Local Integer ARET_VALUE

Local Integer NI
Local Integer IDOBAPCLL
Local Integer ILINE

  If fmet this.COM_IS_CRM_OPPOR() = [V]CST_AFALSE Then
    Return  # L'affaire n'est ni CRM, ni mixte : rien à faire
  Endif
  If find(TYP,"SQH","SOH","CLL","BAP") = 0 Then
    # Contrôle des types acceptés
    [L]ARET_VALUE = fmet this.SETERROR("", mess(1178,196,1) - ":" - TYP, [V]CST_AERROR)
    Return
  Endif
  # ------------------------------------
  If (find(TYP,"SQH","CLL","BAP") > 0 and this.OPPCLO = [V]CST_AYES or this.CRM(1).OPPSTEA2 <> "") or
&    (TYP = "SOH" and this.OPPCLO = [V]CST_AYES or this.CRM(1).OPPSTEADI = 421)
& Then
    If this.OPPCLO = [V]CST_AYES or this.CRM(1).OPPSTEA2 <> "" Then
      # ----------------------------------------------
      # Si l'affaire est close ou gagnée, on efface juste le lien ([F:OSB]STEORIAOB et [F:OSB]STEORIVCR). L'étape reste
      # ----------------------------------------------
      IDOBAPCLL = [V]CST_AFALSE
      For NI = 1 To maxtab(this.CRM(1).STPSTB)
        If this.CRM(1).STPSTB(NI) <> null and find(this.CRM(1).STPSTB(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If this.CRM(1).STPSTB(NI).STEORIAOB = TYP and this.CRM(1).STPSTB(NI).STEORIVCR = VCRNUM Then
            IDOBAPCLL = [V]CST_ATRUE
            ILINE = NI
            Break
          Endif
        Endif
      Next NI
      If IDOBAPCLL = [V]CST_ATRUE Then
        Raz this.CRM(1).STPSTB(ILINE).STEORIAOB
        Raz this.CRM(1).STPSTB(ILINE).STEORIVCR
      Endif
      # ----------------------------------------------
    Else
      # ----------------------------------------------
      # Sinon :
      #    * Si ça n'est pas la dernière étape il faut juste la supprimer
      #    * Si c'est la dernière étape :
      #         1°) il faut la supprimer
      #         2°) Mettre à jour [OPP] avec les données de la nouvelle dernière étape
      # ----------------------------------------------
      IDOBAPCLL = 0
      For NI = 1 To maxtab(this.CRM(1).STPSTB)
        If this.CRM(1).STPSTB(NI) <> null and find(this.CRM(1).STPSTB(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
          If this.CRM(1).STPSTB(NI).STEORIAOB = TYP and this.CRM(1).STPSTB(NI).STEORIVCR = VCRNUM Then
            #ILINE = fmet this.CRM(1).ADELLINE("STPSTB", NI)
            ILINE = fmet this.CRM(1).ADELLINE("STPSTB", this.CRM(1).STPSTB(NI).AORDER)
            IDOBAPCLL = 1
          Else
            If IDOBAPCLL = 0 Then
              # On n'a rien supprimé : on sauvegarde la clé pour retrouver l'enregistrement
              ILINE = NI
            Elsif IDOBAPCLL = 1 Then
              # Si on vient là c'est que ça n'était pas le dernier
              IDOBAPCLL = 2
              Break # pas la peine de continuer la boucle, on n'autra rien à faire
            Endif
          Endif
        Endif
      Next NI
      # ----------------------------------------------
      If IDOBAPCLL = 1 Then
        # Si ça vaut 1 c'est que c'était le dernier : mettre à jour [OPP] avec les données de la nouvelle dernière étape
        this.CRM(1).STRSTE = this.CRM(1).STPSTB(ILINE).ENDDAT
        this.CRM(1).OPPSTE = this.CRM(1).STPSTB(ILINE).STE
        #
        Read [ADI]CODE=this.CRM(1).OPPSTEADI;this.CRM(1).OPPSTE
        this.OPPCLO = [F:ADI]N1
        Case [F:ADI]N2
          When 5
            this.CRM(1).OPPSTEA2 = "WIN"
          When 6
            this.CRM(1).OPPSTEA2 = "LOS"
          When 7
            this.CRM(1).OPPSTEA2 = "FOR"
          When Default
            this.CRM(1).OPPSTEA2 = ""
        Endcase
      Endif
      # ----------------------------------------------
      If TYP = "SQH" Then
        this.CRM(1).OPPNBQ -= 1
        If this.CRM(1).OPPNBQ < 1 Then
          # En théorie dans ce cas il ne faudrait pas conserver les CLL/BAP puisqu'ils ne s'enregistrent
          # qu'à partir du moment où au moins un devis a été créé.
          this.CRM(1).OPPNBQ = 0
        Endif
      Endif
      # ----------------------------------------------
    Endif
  Endif
Return

#######################################################################################
$CRM_INIT_TECH_PROP
  If this.CRM(1) <> null Then
    this.CRM(1).CUR = this.CUR
    this.CRM(1).SALFCY = this.SALFCY
    this.CRM(1).CPY = this.CPY
    this.CRM(1).OPPDATOPN = this.OPPDATOPN
  Endif
Return

#######################################################################################
$CRM_RESET_ERRORS
Local Integer NI

  # Issue X3-96497 - 2018-06-28 by FGR
  If this.CRM(1) <> null Then
    [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.CRM(1).ADELETERRORALL())
    For NI = 1 To maxtab(this.CRM(1).STPSTA)
      If this.CRM(1).STPSTA(NI) <> null and find(this.CRM(1).STPSTA(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.CRM(1).STPSTA(NI).ADELETERRORALL())
      Endif
    Next NI
    For NI = 1 To maxtab(this.CRM(1).STPSTB)
      If this.CRM(1).STPSTB(NI) <> null and find(this.CRM(1).STPSTB(NI).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = 0 Then
        [L]ARET_VALUE = max([L]ARET_VALUE, fmet this.CRM(1).STPSTB(NI).ADELETERRORALL())
      Endif
    Next NI
  Endif
Return

