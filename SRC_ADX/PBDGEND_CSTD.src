  # SAM # 111399 changed ACTION to ARULE
$PROPERTIES
  Case [L]CURPRO
    When "ACCTYP"
      Case [L]ARULE
        When "INIT" : this.ACCTYP = 1
      Endcase
  Endcase
Return

############################################################################################
# Implementation of the METHODS
############################################################################################

# create new unique line number
$CONTROL_BEFORE
   Local File PBDGEND [PBDGEND]
   Filter [F:PBDGEND]
&     Where CODE = this.CODE and LEG = this.LEG and ISOITEM = this.ISOITEM and ISDETAIL = this.ISDETAIL
&     Order By LINE
   Read [F:PBDGEND] Last
   If !fstat
     this.LINE = [F:PBDGEND]LINE + 1   # next free number
   Endif
   LogicClose File [PBDGEND]
Return



$CHECK_POSTED
Local Instance PBDGEN Using C_PBDGEN
   [L]PBDGEN = NewInstance C_PBDGEN  AllocGroup null
   ASTATUS = fmet [L]PBDGEN.AREAD(this.CODE)         # read header PBDGEN
   If ASTATUS = [V]CST_AOK
     If PBDGEN.POSTED = [V]CST_AYES            # check if already posted -> if yes, no edit
       ASTATUS = fmet this.ASETERROR( "", mess(382,107,1), [V]CST_AERROR ) #  'Data has been already posted, modification not possible'
     Endif
   Endif

   FreeGroup [L]PBDGEN
Return


