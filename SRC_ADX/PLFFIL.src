#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque PLFFIL

$ACTION
Case ACTION
 When "DEBUT" : Gosub DEBUT
 When Default
Endcase
Return

$DEBUT
If [M]NAL=2
 Raz [M]CPY,[M]FCY
 [M]ALLCPY=1 : [M]ALLFCY=1
 Grizo ALLCPY,CPY,ALLFCY,FCY
Else
 Gosub GRISE From DIVPAYE
Endif
Affzo
Return



######################################################################################
## Etiquette Ecran PLFFIL
######################################################################################

Subprog AM_NAL(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Raz [M]CPY,[M]FCY
 [M]ALLCPY=1 : [M]ALLFCY=1
 Grizo ALLCPY,CPY,ALLFCY,FCY
Else
 Raz [M]CPY,[M]FCY
 [M]ALLCPY=2 : [M]ALLFCY=2
 Grizo CPY,ALLFCY,FCY
 Actzo ALLCPY
Endif
Affzo
End

Subprog AS_ALLCPY(VALEUR)
Variable Integer VALEUR
Call AS_ALLCPY(VALEUR) From DIVPAYE
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
Call C_ALLCPY(VALEUR) From DIVPAYE
End

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
Call AS_CPY(VALEUR) From DIVPAYE
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer VALEUR
Call AS_ALLFCY(VALEUR) From DIVPAYE
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR) From DIVPAYE
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
Call AS_FCY(VALEUR) From DIVPAYE
End

## 36044

Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Gosub GRISE From DIVPAYE
End
######################################################################################
## Section automatically added (screen PLFFIL) 05/11/2017 16:04:10 (LIPET)
######################################################################################
Subprog C_ALLSRV(VALEUR)
Variable Integer VALEUR
Call C_ALLSRV(VALEUR) From DIVPAYE
End

Subprog AS_SRV(VALEUR)
Variable Char    VALEUR()
Call AS_SRV(VALEUR) From DIVPAYE
End


