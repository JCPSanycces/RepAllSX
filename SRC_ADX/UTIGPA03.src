#<AdxTL>@(#)5.0.0.0 $Revision$

##########################################################################
# UTIGPA03        Utilitaire de resynchronisation  OF      Module GPAO  #
# ---------------------------------------------------------------------- #
# Problème à résoudre :                                                  #
#   Dérection  et résolution de désynchronisation entre le statut        #
#   d'allocation de l'entête OF et l'état d'allocation des composants    #
##########################################################################

Call MAJ_UTIGPA03
End


Subprog MAJ_UTIGPA03
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("Resynchronisation statut allocation") From LECFIC
If DOSSIER <> ""
  Call EXE_UTIGPA03(DOSSIER) 
Endif
Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End


Subprog EXE_UTIGPA03(DOSSIER)
Value Char DOSSIER
Call ECR_TRACE("UTIGPA03 : Début traitement du dossier "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:MFM])  =0  Local File =DOSSIER+".MFGMAT"      [MFM]  : Endif
If clalev([F:MFG])  =0  Local File =DOSSIER+".MFGHEAD"     [MFG]  : Endif

#----- Variables locales -----#
Local Char     WMESSAGE(80)

Local Integer COMPTEUR, STOP 
Local Char     CLE1(20), CLE3(20), CRITERE(200)
Local Integer  CLE2, CLE4, CLE5

Local Char     WMFGNUM(20)
Local Integer  XTOT, WOVRALLNBR, WDETALLNBR, WSHTMATNBR, WALLSTA, WCORNBR, WMFGNBR

#----------------------------------------------------------------#
# Première boucle : on part des matières
#----------------------------------------------------------------#
Call ECR_TRACE("UTIGPA03 : début phase 1 ",0) From GESECRAN

Raz CLE1, CLE2, CLE3, CLE4, STOP, WCORNBR, WMFGNBR, WMFGNUM
$BOUCLE_MFM_1
If STOP=1
  STOP=2 : CRITERE='MFGNUM="'+CLE1+'"'+' & MFGLIN ='+num$(CLE2)+' & BOMSEQ='+num$(CLE4)+ 
&                                      ' & ITMREF >"'+CLE3+'"'                      
Elsif STOP=2
  STOP=3 : CRITERE='MFGNUM="'+CLE1+'"'+' & MFGLIN ='+num$(CLE2)+' & BOMSEQ >'+num$(CLE4)
Elsif STOP=3
  STOP=4 : CRITERE='MFGNUM="'+CLE1+'"'+' & MFGLIN >'+num$(CLE2)
Elsif STOP=4
  STOP=0 : CRITERE='MFGNUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif

Raz COMPTEUR

Call DEBTRANS From GLOCK
Trbegin [MFM]

For [F:MFM]MFM0 Where evalue(CRITERE) 
    If fstat : STOP = 9 : Endif
    If WMFGNUM = "" : WMFGNUM = [F:MFM]MFGNUM : Endif    
    If [F:MFM]MFGNUM <> WMFGNUM | STOP = 9 
        WMFGNBR +=1 
        Read [MFG]MFG0=WMFGNUM
        If !fstat
# sr 07.02 demande 15130 Même si les matières sont soldées
#            # si toutes les matières sont soldées
#            If [F:MFG]MATCLENBR <> [F:MFG]MATLINNBR

                # nouveau statut allocation (non alloué, partiel, complet)
                XTOT = WOVRALLNBR + WDETALLNBR
                If (XTOT = 0)                     
                    WALLSTA = 1 
                Else
                    If (XTOT < [F:MFG]MATLINNBR - [F:MFG]MATCLENBR)          # llc 04.02 14090
                        WALLSTA = 2 
                    Else 
                        # sr 07.02 demande 15130  tester >= au lieu de =
                        If (XTOT >= [F:MFG]MATLINNBR - [F:MFG]MATCLENBR)      # llc 04.02 14090   
                            WALLSTA = 3 
                        Endif 
                    Endif 
                Endif
                # si des ruptures existent, statut allocation + 2
                If WSHTMATNBR <> 0 : WALLSTA += 2 : Endif
                # si toutes les matières sont soldées, on force le statut à "complet" ...
                If [F:MFG]MATCLENBR = [F:MFG]MATLINNBR
                    WALLSTA = 3
                Endif
                If [F:MFG]ALLSTA <> WALLSTA
                    Readlock [MFG]MFG0 = WMFGNUM
                    If !fstat
                        [F:MFG]ALLSTA = WALLSTA
                        Rewrite [MFG]
                        Call ECR_TRACE("Resynchronisation"-"OF:"-WMFGNUM,0) From GESECRAN
                        WCORNBR += 1
                    Endif
#                Endif
            Endif
            Raz WOVRALLNBR
            Raz WSHTMATNBR
            Raz WDETALLNBR
        Endif
        WMFGNUM = [F:MFM]MFGNUM
        fstat = 0
        If STOP = 9 : STOP = 0 : Break : Endif
        # régularisation entête
        If COMPTEUR > GMAXUPDTRS 
            CLE1 = [F:MFM]MFGNUM
            CLE2 = [F:MFM]MFGLIN
            CLE4 = [F:MFM]BOMSEQ
            CLE3 = [F:MFM]ITMREF
            STOP = 4 
            Break 
        Endif

    Endif

    Case [F:MFM]ALLSTA    # évaluation nouveaux totaux 
        When 2:    WOVRALLNBR += 1
                   WSHTMATNBR += 1 
        When 3:    WOVRALLNBR += 1
        When 4:    WDETALLNBR += 1
                   WSHTMATNBR += 1 
        When 5:    WDETALLNBR += 1
    Endcase
    
    COMPTEUR += 1
Next
If GOK <= 0 
   Rollback 
Else 
 Commit 
Endif
If STOP : Goto BOUCLE_MFM_1 : Endif
Call ECR_TRACE("OF Analysés:"-num$(WMFGNBR),0) From GESECRAN
Call ECR_TRACE("OF Resynchronisés:"-num$(WCORNBR),0) From GESECRAN
Call ECR_TRACE("UTIGPA3 : fin phase 1 ",0) From GESECRAN

#----- Fin du traitement -----#
$FIN_UTIGPA03
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(7)<>2 End : Endif
Call EXE_UTIGPA03(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj6 (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif

If [F:ADS]MODULE(7)<>2 End : Endif
Call EXE_UTIGPA03(APPLI)
End


