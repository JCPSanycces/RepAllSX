#<AdxTL>@(#)7.0.0.0 $Revision$
##########################################################################################
Subprog MAJ_ERR(TXTCLOB,II,VALEURS)
Variable Clbfile TXTCLOB
Variable Integer II
Variable Char VALEURS()(1..500)

Local Clbfile MYCLOB(10)
Local Char RECH(250),AREMP(250)

# Parcours de l'arborescence des menus
  For KK=1 To II-1
    RECH="mess("+VALEURS(KK)+")"
    AREMP=evalue("func AGENADOF.LIBMESS("+VALEURS(KK)+")")
    Gosub ERRREPLACE
  Next KK
End

$ERR_ADH
Call ECR_TRACE(mess(9,75,1)-": ",1) From GESECRAN
If TEXBASE=1
 Call ECR_TRACE([ADH]LAN-num$([ADH]TYP)-[ADH]COD-num$([ADH]LEV)-num$([ADH]SUBLEV)-"("-errmes$(errn)-errm-")",1) From GESECRAN : #  : Erreur d'évaluation sur le texte :
Elsif TEXBASE=2
 Call ECR_TRACE([ADH2]LAN-num$([ADH2]TYP)-[ADH2]COD-num$([ADH2]LEV)-num$([ADH2]SUBLEV)-"("-errmes$(errn)-errm-")",1) From GESECRAN : #  : Erreur d'évaluation sur le texte :
Endif
Return

$ERRREPLACE
J=instr(1,TXTCLOB,RECH)
While J>0
    MYCLOB=left$(TXTCLOB,J-1)+AREMP+right$(TXTCLOB,J+len(RECH))
    TXTCLOB=MYCLOB
    J=instr(1,TXTCLOB,RECH)
Wend
Return

##########################################################################################
Funprog LIBMESS(I,CHAP,BIDON)
Value Integer I,CHAP,BIDON
  # Retour direct du paramètre renvoyé par MST
End func AGENADO.MST(I,CHAP)

#########################################################################################

# Ecriture d'un tableau contenant une liste de paramètres d'actions
Subprog WRPARAMACT

Local Integer NBCOL,II,JJ,KK : NBCOL=3
Local Char TITRECOL(30)(1..3)
Local Char POURCENTCOL(5)(1..3)
Local Char COLONNE(100)(1..3,1..100)

  TITRECOL(1)=func AGENADO.MST(143,105) : POURCENTCOL(1)="15%"
  TITRECOL(2)=func AGENADO.MST(30,109) : POURCENTCOL(2)="65%"
  TITRECOL(3)=func AGENADO.RDM("ACT2","TYPPAR") : POURCENTCOL(2)="30%"


  JJ=1
  For [ATR]NOPAR Where ACTION=[ACT]ACTION
    Read [AAR]CODPAR=[ATR]CODPAR
    If fstat=0
        COLONNE(1,JJ)=[ATR]CODPAR
        COLONNE(2,JJ)=func AGENADO.RDT([AAR]INTITPAR)
        COLONNE(3,JJ)=func AGENADO.MST([AAR]TYPPAR,33)
        JJ+=1
    Endif
  Next

  If JJ>1
    Gosub WTABLEAU From AGENADOF
  Endif
End

#########################################################################################
# Ecriture d'un tableau contenant une liste de paramètres d'actions
Subprog WRPARETAT(DEBFIN,JJ)
Variable Integer DEBFIN,JJ

Local Integer NBCOL : NBCOL=3
Local Char TITRECOL(30)(1..3)
Local Char POURCENTCOL(5)(1..3)
Local Char COLONNE(100)(1..3,1..100)
Local Char INTMENLOC(250)
Local Integer II,KK,LL

  DEBFIN=0
  TITRECOL(1)=func AGENADO.MST(143,105) : POURCENTCOL(1)="15%"
  TITRECOL(2)=func AGENADO.RDM("ARP2","PARNAM") : POURCENTCOL(2)="75%"
  TITRECOL(3)=func AGENADO.RDM("ARP2","PARTYP") : POURCENTCOL(3)="10%"
#  NBPAR=0 Inutile ???
  JJ=1
  For [ARD]ARD0 Where RPTCOD=[ARP]RPTCOD and PARSAI=2
    DEBFIN+=([ARD]PARSTREND=2)
    COLONNE(1,JJ)=[ARD]PARCOD
    COLONNE(2,JJ)=func AGENADO.RDT([ARD]PARNAM)
    If [ARD]PARTYP="M"
        INTMENLOC=" ("+func AGENADO.RDM("AST1","MENLOCAL")+"<I> "
        KK=len(func AGENADO.MST(0,[ARD]PARNOLIB))
        For LL=1 To KK
            INTMENLOC+=string$(LL>1,", ")+func AGENADO.MST(LL,[ARD]PARNOLIB)
            Break (len(INTMENLOC)>50)
        Next LL
        INTMENLOC+=string$(LL<KK,"...")
        COLONNE(2,JJ)+=INTMENLOC+"</i>)"
        COLONNE(3,JJ)='<a href="../MCD/MEN'+func AGENLIBA.FORMAT_AML([ARD]PARNOLIB)+'.htm">M'+num$([ARD]PARNOLIB)+'</a>'
    Else
        Read [ATY]CODTYP=[ARD]PARTYP
        If [ATY]OBJLIEN<>""
            COLONNE(3,JJ)='<a href="../FCT/GES'+[ATY]OBJLIEN+'.htm">'+[ARD]PARTYP+"</a>"
        Else
            COLONNE(3,JJ)=[ARD]PARTYP
        Endif
    Endif
    JJ+=1
  Next

  If JJ>1
    Gosub WTABLEAU From AGENADOF
  Endif
End
#########################################################################################
# Ecriture d'un tableau contenant une liste de paramètres de sous-programme
Subprog WRPARASU(DEBFIN,JJ)
Variable Integer DEBFIN,JJ

Local Integer NBCOL : NBCOL=3
Local Char TITRECOL(30)(1..3)
Local Char POURCENTCOL(5)(1..3)
Local Char COLONNE(100)(1..3,1..100)
Local Char INTMENLOC(250)
Local Integer II,KK,LL

  DEBFIN=0
  TITRECOL(1)=func AGENADO.MST(143,105) : POURCENTCOL(1)="15%"
  TITRECOL(2)=func AGENADO.RDM("ARP2","PARNAM") : POURCENTCOL(2)="60%"
  TITRECOL(3)=func AGENADO.RDM("ARP2","PARTYP") : POURCENTCOL(3)="25%"

  If dim([ASP]DIME)>0
     JJ = 0
     For [ASP]ASP0 Where PRG=[F:ASU]PRG & SUBPRG=[F:ASU]SUBPRG
       JJ += 1
       COLONNE(1,JJ)=[ASP]PARAM+string$([ASP]DIME>1,"(0.."+num$([ASP]DIME-1)+")")
       COLONNE(2,JJ)=func AGENADO.RDT([ASP]INTITPAR)
       COLONNE(3,JJ)=func AGENADO.MST([ASP]TYPPAR,33)+", "+func AGENADO.MST([ASP]ADRVAL,34)
     Next ASP
  Else
     #   NBPAR=0 Inutile ???
     For JJ=1 To [ASU]NBRPAR
       COLONNE(1,JJ)=[ASU]PARAM(JJ-1)+string$([ASU]DIME(JJ-1)>1,"(0.."+num$([ASU]DIME(JJ-1)-1)+")")
       COLONNE(2,JJ)=func AGENADO.RDT([ASU]INTITPAR(JJ-1))
       COLONNE(3,JJ)=func AGENADO.MST([ASU]TYPPAR(JJ-1),33)+", "+func AGENADO.MST([ASU]ADRVAL(JJ-1),34)
     Next
  Endif

  If [ASU]NBRPAR>0
    Gosub WTABLEAU From AGENADOF
  Else
    JJ=0
  Endif
End

#########################################################################################
# Ecriture d'un tableau contenant une liste de tables
Subprog WRTABLE(NOMTBL,NBTB)
Value Char NOMTBL()(1..)
Value Integer NBTB
Local Integer II,JJ,KK

Local Integer NBCOL : NBCOL=2
Local Char TITRECOL(30)(1..2)
Local Char POURCENTCOL(5)(1..2)
Local Char COLONNE(100)(1..2,1..100)

  TITRECOL(1)=func AGENADO.MST(106,142) : POURCENTCOL(1)="26%"
  TITRECOL(2)=func AGENADO.MST(107,142) : POURCENTCOL(2)="72%"

  JJ=1
  For II=1 To NBTB
    Read [ATB]CODFIC=NOMTBL(II)
    If fstat=0
        COLONNE(1,JJ)='<a href="../MCD/'+NOMTBL(II)+'.htm">'+NOMTBL(II)+'</a> ['+[ATB]ABRFIC+']'
        Read [AOB]NOMFIC=[ATB]CODFIC;[ATB]ABRFIC
        If fstat=0 & "GES"+[AOB]ABREV<>[ADO]COD
            Read [AFC]CODINT="GES"+[AOB]ABREV
            If fstat=0
                COLONNE(2,JJ)='<a href="../FCT/GES'+[AOB]ABREV+'.htm">'+func AGENADO.RDT([ATB]INTITFIC)+'</a>'
            Else
                COLONNE(2,JJ)=func AGENADO.RDT([ATB]INTITFIC)
            Endif
        Else
            COLONNE(2,JJ)=func AGENADO.RDT([ATB]INTITFIC)
        Endif
        JJ+=1
    Endif
  Next II

  If JJ>1
    Gosub WTABLEAU From AGENADOF
  Endif
End

#########################################################################################
# Ecriture d'un tableau à 2 entrées
Subprog WRTAB2(TIT1,TIT2,PC1,PC2,TBL1,TBL2,NBR)
Value Char TIT1,TIT2
Variable Char TBL1()(1..), TBL2()(1..)
Value Integer PC1,PC2,NBR
Local Integer II,JJ,KK

Local Integer NBCOL : NBCOL=2
Local Char TITRECOL(30)(1..2)
Local Char POURCENTCOL(5)(1..2)
Local Char COLONNE(100)(1..2,1..100)

  TITRECOL(1)=TIT1
  TITRECOL(2)=TIT2
  POURCENTCOL(1)=num$(PC1)+"%"
  POURCENTCOL(2)=num$(PC2)+"%"

  JJ=1
  For II=1 To NBR
    COLONNE(1,JJ)=TBL1(JJ)
    COLONNE(2,JJ)=TBL2(JJ)
    JJ+=1
  Next II

  If JJ>1
    Gosub WTABLEAU From AGENADOF
  Endif
End

#########################################################################################
# Ecriture d'un tableau contenant une liste de tables avec un flag significatif oui/non
Subprog WRTBSIG(NOMTBL,SIGN,NBTB)
Value Char NOMTBL()(1..)
Value Integer SIGN(1..)
Value Integer NBTB
Local Integer II,JJ,KK

Local Integer NBCOL : NBCOL=3
Local Char TITRECOL(30)(1..3)
Local Char POURCENTCOL(5)(1..3)
Local Char COLONNE(100)(1..3,1..100)
Local Char ABREVI(4)
  TITRECOL(1)=func AGENADO.MST(106,142) : POURCENTCOL(1)="20%"
  TITRECOL(2)=func AGENADO.MST(119,142) : POURCENTCOL(2)="25%"
  TITRECOL(3)=func AGENADO.MST(107,142) : POURCENTCOL(3)="55%"

  JJ=1
  For II=1 To NBTB
    KK=instr(1,NOMTBL(II),"[")
    If KK
        ABREVI=vireblc(ctrans(right$(NOMTBL(II),KK+1),"]",""),2)
        NOMTBL(II)=vireblc(left$(NOMTBL(II),KK-1),2)
    Endif
    Read [ATB]CODFIC=NOMTBL(II)
    If KK=0
        ABREVI=[ATB]ABRFIC
    Endif
    If fstat=0
        COLONNE(1,JJ)='<a href="../MCD/'+NOMTBL(II)+'.htm">'+NOMTBL(II)+'</a> ['+ABREVI+']'
        COLONNE(2,JJ)=func AGENADO.MST(SIGN(II),1)
        Read [AOB]NOMFIC=[ATB]CODFIC;[ATB]ABRFIC
        If fstat=0 & "GES"+[AOB]ABREV<>[ADO]COD
            Read [AFC]CODINT="GES"+[AOB]ABREV
            If fstat=0
                COLONNE(3,JJ)='<a href="../FCT/GES'+[AOB]ABREV+'.htm">'+func AGENADO.RDT([ATB]INTITFIC)+'</a>'
            Else
                COLONNE(3,JJ)=func AGENADO.RDT([ATB]INTITFIC)
            Endif
        Else
            COLONNE(3,JJ)=func AGENADO.RDT([ATB]INTITFIC)
        Endif
        JJ+=1
    Endif
  Next II

  If JJ>1
    Gosub WTABLEAU  From AGENADOF
  Endif
End

#########################################################################################
# Ecriture du dictionnaire d'une table
Subprog WRDICATB(DOSS,TABLE,GEN_FIN)
Variable Char DOSS
Variable Char TABLE
Variable Integer GEN_FIN

Local Integer NBCOL
Local Char TITRECOL(30)(1..9)
Local Char POURCENTCOL(5)(1..9)
Local Char COLONNE(100)(1..9,1..500)
Local Integer JJ

# La définition de la table
  NBCOL=0
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ARP3","TBL") : POURCENTCOL(NBCOL)="" : # Table...
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("PS12","ABRLNK") : POURCENTCOL(NBCOL)="" : # Abréviation
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("AMK0","ZINTMSK") : POURCENTCOL(NBCOL)="" : # Intitulé
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ATB1","MODULE") : POURCENTCOL(NBCOL)="" : # Module
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ATB1","CODACT") : POURCENTCOL(NBCOL)="" : # Code activité
  JJ=2
  COLONNE(1,1)=[ATB]CODFIC : COLONNE(2,1)=[ATB]ABRFIC : COLONNE(3,1)=func AGENADO.RDT([ATB]INTITFIC)
  COLONNE(4,1)=func AGENADO.MST([ATB]MODULE,14) : COLONNE(5,1)=string$([ATB]CODACT="","&nbsp;")+[ATB]CODACT
  Gosub WTABDIC From AGENADOF

# La liste des index avec ou sans filtre sur code activité
  If GEN_FIN=2
    Local File =DOSS+".ATABIND" [ATI1] Where CODFIC=TABLE and CODACT<"X"
  Else
    #VPO 09/01/08 41328
    #Link [ATI] With [ACV1]CODACT=[ATI]CODACT As [ATI1] Where CODFIC=TABLE and [ACV1]FLACT=2
    Link [ATI] With [ACV1]CODACT=[ATI]CODACT As [ATI1] Where CODFIC=TABLE
&                    and ([ACV1]FLACT=2 or [ATI]CODACT="")
&                    and ([ATI]CODACT<>"FAL")
  Endif
  NBCOL=0
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("AOE1","FLGKEY") : POURCENTCOL(NBCOL)="" : # "Clé"
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("AIM1","PRTDES") : POURCENTCOL(NBCOL)="" : # "Description"
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ATB3","HOMONYM") : POURCENTCOL(NBCOL)="" : # "Homonymes"
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ATB1","CODACT") : POURCENTCOL(NBCOL)="" : # "Code activité"
  JJ=1
  For [ATI1]NUMLIG
    COLONNE(1,JJ)=[ATI1]CODIND
    COLONNE(2,JJ)=[ATI1]DESCRIPT
    COLONNE(3,JJ)=func AGENADO.MST([ATI1]HOMONYM,1)
    COLONNE(4,JJ)=string$([ATI1]CODACT="","&nbsp;")+[ATI1]CODACT
    JJ+=1
  Next
  If JJ>1
    Gosub WTABDIC From AGENADOF
  Endif
  Close Local File [ATI1]


# La liste des champs avec ou sans filtre sur code activité
  If GEN_FIN=2
    Local File =DOSS+".ATABZON" [ATZ1] Where CODFIC=TABLE and CODACT<"X"
  Else
    #VPO 09/01/08 41328
    #Link [ATZ] With [ACV1]CODACT=[ATZ]CODACT As [ATZ1] Where CODFIC=TABLE and [ACV1]FLACT=2
    Link [ATZ] With [ACV1]CODACT=[ATZ]CODACT As [ATZ1] Where CODFIC=TABLE
&                    and ([ACV1]FLACT=2 or [ATZ]CODACT="")
&                    and ([ATZ]CODACT<>"FAL")
  Endif
  NBCOL=0
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ATB2","CODZONE") : POURCENTCOL(NBCOL)="13%"
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ATB2","INTITCOURT") : POURCENTCOL(NBCOL)="20%"
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ATB2","DIME") : POURCENTCOL(NBCOL)="3%"
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ATB2","CODTYP") : POURCENTCOL(NBCOL)="5%"
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ATB2","LONG") : POURCENTCOL(NBCOL)="5%"
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ATB2","NOLIB") : POURCENTCOL(NBCOL)="6%"
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ATB2","EXPLIEN") : POURCENTCOL(NBCOL)="30%"
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ATB2","ANNUL") : POURCENTCOL(NBCOL)="15%"
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ATB2","CODACT") : POURCENTCOL(NBCOL)="5%"
  JJ=1
  For [ATZ1]CODZONE
    COLONNE(1,JJ)=[ATZ1]CODZONE
    COLONNE(2,JJ)=func AGENADO.RDT([ATZ1]NOCOURT)
    COLONNE(3,JJ)=string$([ATZ1]DIME>1,num$([ATZ1]DIME))+string$([ATZ1]DIME<=1,"&nbsp;")
    COLONNE(4,JJ)='<a href="ATY_'+[ATZ1]CODTYP+'.htm">'+[ATZ1]CODTYP+"</a>"
    COLONNE(5,JJ)=string$([ATZ1]LONG>0,num$([ATZ1]LONG))+string$([ATZ1]LONG=0,"&nbsp;")
    COLONNE(6,JJ)=string$([ATZ1]NOLIB>0,
&                         '<a href="MEN'+func AGENLIBA.FORMAT_AML([ATZ1]NOLIB)+'.htm">'+num$([ATZ1]NOLIB)+"</a>")
&                +string$([ATZ1]NOLIB=0,"&nbsp;")
    Read [ATY]CODTYP=[ATZ1]CODTYP
    If [ATY]FICLIEN<>""
        Read [ATB]CODFIC=[ATY]FICLIEN
        Read [ATI]NUMLIG(2)=[ATB]CODFIC;1
        COLONNE(7,JJ)='<a href="'+[ATB]CODFIC+'.htm" font color="red">['+[ATB]ABRFIC+"]"+[ATI]CODIND
&                    +"</font>="
        If [ATZ1]EXPLIEN<>""
            COLONNE(7,JJ)+=[ATZ1]EXPLIEN+"</a>"
            Read [ATB]CODFIC=TABLE
        Else
            Read [ATB]CODFIC=TABLE
            COLONNE(7,JJ)+="["+[ATB]ABRFIC+"]"+[ATZ1]CODZONE+"</a"
        Endif
        COLONNE(8,JJ)=func AGENADO.MST([ATZ1]ANNUL,24)
    Else
        COLONNE(7,JJ)="&nbsp;"
        COLONNE(8,JJ)="&nbsp;"
    Endif
    COLONNE(9,JJ)=string$([ATZ1]CODACT="","&nbsp;")+[ATZ1]CODACT
    JJ+=1
  Next
  If JJ>1
    Gosub WTABDIC From AGENADOF
  Endif
  Close Local File [ATZ1]

End


#########################################################################################
# Ecriture du dictionnaire des menus locaux
Subprog WRDICAML(DOSS,TABLE,GEN_FIN)
Variable Char DOSS
Variable Char TABLE
Variable Integer GEN_FIN

Local Integer NBCOL
Local Char TITRECOL(30)(1..6)
Local Char POURCENTCOL(5)(1..6)
Local Char COLONNE(100)(1..6,1..500)
Local Integer JJ

# La définition du menu local
  NBCOL=0
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("AST1","MENLOCAL") : POURCENTCOL(NBCOL)="" : # Menu local
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("AWW1","INTLNG") : POURCENTCOL(NBCOL)="" : # Titre
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("AST1","LONG") : POURCENTCOL(NBCOL)="" : # Longueur
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("AST1","MINI") : POURCENTCOL(NBCOL)="" : # Mini
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("AST1","MAXI") : POURCENTCOL(NBCOL)="" : # Maxi
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("AST1","CODACT") : POURCENTCOL(NBCOL)="" : # Code activité
  JJ=2
  COLONNE(1,1)=num$([AML]MENLOC): COLONNE(2,1)=func AGENADO.TML([AML]MENLOC): COLONNE(3,1)=num$([AML]LONG)
  COLONNE(4,1)=num$([AML]MINI) : COLONNE(5,1)=num$([AML]MAXI)
  COLONNE(6,1)=string$([AML]CODACT="","&nbsp;")+[AML]CODACT
  Gosub WTABDIC From AGENADOF

# La liste des choix du menu local
  NBCOL=0
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("AST1","LANNUM") : POURCENTCOL(NBCOL)="10%" : # "Numéro"
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ATEXTRA","TEXTE") : POURCENTCOL(NBCOL)="90%" : # "Texte"
  JJ=1
  For [AST1]LAN Where LAN=COD_LAN & LANCHP=val(TABLE) & LANNUM>0
    COLONNE(1,JJ)=num$(JJ)
    COLONNE(2,JJ)=string$([AST1]LANMES="","&nbsp;")+[AST1]LANMES
    JJ+=1
  Next
  If JJ>1
    Gosub WTABDIC From AGENADOF
  Endif
End

#########################################################################################
# Ecriture du dictionnaire des types
Subprog WRDICATY(DOSS,TABLE,GEN_FIN)
Variable Char DOSS
Variable Char TABLE
Variable Integer GEN_FIN

Local Integer NBCOL
Local Char TITRECOL(30)(1..6)
Local Char POURCENTCOL(5)(1..6)
Local Char COLONNE(100)(1..6,1..500)
Local Integer JJ

# La définition du type
  Read [ATY]CODTYP=TABLE

  NBCOL=0
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ATY1","OBJLIEN") : POURCENTCOL(NBCOL)="" : # Objet lié
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ATY1","FICLIEN") : POURCENTCOL(NBCOL)="" : # Table liée
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ATY1","TYPTYP") : POURCENTCOL(NBCOL)="" : # Type interne
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ATY1","FORTYP") : POURCENTCOL(NBCOL)="" : # Format
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ATY1","NOLIB") : POURCENTCOL(NBCOL)="" : # No menu local
  NBCOL+=1 : TITRECOL(NBCOL)=func AGENADO.RDM("ATY1","CODACT") : POURCENTCOL(NBCOL)="" : # Code activité
  JJ=2
  COLONNE(1,1)=string$([ATY]OBJLIEN="","&nbsp;")+[ATY]OBJLIEN
  If [ATY]OBJLIEN<>""
    Read [AOB]ABREV=[ATY]OBJLIEN
    If fstat=0
        COLONNE(2,1)='<a href="'+[AOB]NOMFIC+'.htm">'+[AOB]NOMFIC+'</a>'
    Endif
  Endif
  COLONNE(2,1)+=string$(COLONNE(2,1)="","&nbsp;")
  COLONNE(3,1)=func AGENADO.MST([ATY]TYPTYP,30)
  COLONNE(4,1)=string$([ATY]FORTYP="","&nbsp;")+[ATY]FORTYP
  COLONNE(5,1)=string$([ATY]NOLIB<>0,'<a href="MEN'+func AGENLIBA.FORMAT_AML([ATY]NOLIB)+'.htm">'+num$([ATY]NOLIB)+'</a>')
&             +string$([ATY]NOLIB=0,"&nbsp;")
  COLONNE(6,1)=string$([ATY]CODACT="","&nbsp;")+[ATY]CODACT
  Gosub WTABDIC From AGENADOF
End


#########################################################################################
# Ecriture d'un tableau dictionnaire (de 1 à JJ-1, sur NBCOL colonnes)
$WTABDIC
  Wrseq '        <p>' Using [DOC]
  Wrseq '          <table border=0 cellPadding=2 cellSpacing=0 cols='+num$(NBCOL)-'width=780>' Using [DOC]
  Wrseq '            <tr>' Using [DOC]
  For II=1 To NBCOL
    Wrseq '              <th id="hdico'+string$(II=NBCOL,"s")+'">' Using [DOC]
    Wrseq '                '+TITRECOL(II) Using [DOC]
    Wrseq '              </th>' Using [DOC]
  Next II
  Wrseq '            </tr>' Using [DOC]

  For II=1 To JJ-1
    Wrseq '            <tr>' Using [DOC]
    For KK=1 To NBCOL
        Wrseq '              <td id="lzone'+string$(KK=NBCOL,"s")+'" '; Using [DOC]
        Wrseq string$(POURCENTCOL(KK)<>"",'width="'+POURCENTCOL(KK)+ '" ')+'valign=top>' Using [DOC]
        Wrseq '                '+COLONNE(KK,II) Using [DOC]
        Wrseq '              </td>' Using [DOC]
    Next KK
    Wrseq '            </tr>' Using [DOC]
  Next II
  Wrseq '          </table>' Using [DOC]

Return

#########################################################################################
# Ecriture d'un tableau générique (de 1 à JJ-1, sur NBCOL colonnes)
$WTABLEAU
  Wrseq '        <p>' Using [DOC]
  Wrseq '          <table class="std1">' Using [DOC]
  Wrseq '            <tr>' Using [DOC]
  For II=1 To NBCOL
    Wrseq '              <th class="std1ColOdd">'; Using [DOC]
    Wrseq '                <p>'+TITRECOL(II)+'</p>' Using [DOC]
    Wrseq '              </th>' Using [DOC]
  Next II
  Wrseq '            </tr>' Using [DOC]

  For II=1 To JJ-1
    Wrseq '            <tr>' Using [DOC]
    For KK=1 To NBCOL
        Wrseq '              <td '; Using [DOC]
        Wrseq string$(POURCENTCOL(KK)<>"",'width="'+POURCENTCOL(KK)+ '" ')+'valign=top>' Using [DOC]
        Wrseq '                <p>'+COLONNE(KK,II)+'</p>' Using [DOC]
        Wrseq '              </td>' Using [DOC]
    Next KK
    Wrseq '            </tr>' Using [DOC]
  Next II
  Wrseq '          </table>' Using [DOC]

Return

