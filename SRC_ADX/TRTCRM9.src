#<AdxTL>@(#)8.0.0.0 $Revision$
##########################################################################################################
#   Traitement de gestion d'un appel entrant                           Module CRM         28 juillet 2000
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "AVANT_MEN"    : Gosub AVANT_MEN
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Char GFMTFCRM9(50)(3)

  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
  If !clalev([F:CNT]) : Local File CONTACT [CNT] : Endif     # FGR 13/05/2009 : X3SUIVI50196
  NAVIG = "FUNCRM9"
Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
  If GMODU(13) = 2 Then
    ETAMEN(1) = 1
    ETAMEN(2) = 1
    ETAMEN(3) = 1
    ETAMEN(4) = 1
    ETAMEN(5) = 1
    ETAMEN(6) = 1
    ETAMEN(7) = 1
  Endif
  If GMODU(12) = 2 Then
    ETAMEN(8) = 1
    ETAMEN(9) = 1
    ETAMEN(10) = 1
  Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT
Local Integer IRESULT
Local Integer IINDICE
Local Integer IINDICEMAX
Local Integer ILENGTHMAX
Local Integer ILENGTH

  ILENGTHMAX = 0
  #Format de CNTTYP
  ILENGTH = 0
  ILENGTHMAX = 0
  IINDICE = 0
  IINDICEMAX = len(mess(0,3038,1))
  While IINDICE<IINDICEMAX
    ILENGTH = len(mess(IINDICE,3038,1))
    If ILENGTH > ILENGTHMAX Then
      ILENGTHMAX = ILENGTH
    Endif
    IINDICE += 1
  Wend
  # FGR 02/12/2013 : X3SUIVI93355 : Option "P" pour non saisissable
  GFMTFCRM9(0) = "LA3038P:num$(ILENGTHMAX+2)" + "x"
  #format de BPAADDFLG
  ILENGTH = 0
  ILENGTHMAX = 0
  IINDICE = 0
  IINDICEMAX = len(mess(0,1,1))
  While IINDICE<IINDICEMAX
    ILENGTH = len(mess(IINDICE,1,1))
    If ILENGTH > ILENGTHMAX Then
      ILENGTHMAX = ILENGTH
    Endif
    IINDICE += 1
  Wend
  # FGR 02/12/2013 : X3SUIVI93355 : Option "P" pour non saisissable
  GFMTFCRM9(1) = "LA1P:" + num$(ILENGTHMAX) + "x"
  #format$ de BPADES
  IRESULT = type([M:CRM9]BPADES)
  ILENGTHMAX = IRESULT - 10
  # FGR 02/12/2013 : X3SUIVI93355 : Option "P" pour non saisissable
  GFMTFCRM9(2) = "KP:" + num$(ILENGTHMAX) + "x"
  [M:CRM9]TYPESEARCH = "BPR"
  Gosub GEREAFFICHAGE
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
  Case BOUT
    When "D"
      If (nolign-1) >= 0 Then
        [M:CRM9]OBJTYP = [M:CRM9]OBJ(nolign-1)
        [M:CRM9]OBJKEY = [M:CRM9]CODE(nolign-1)
      Endif
  Endcase
Return

##########################################################################################################
$AVANT_MEN
  [M:CRM9]NVGCOD = BOUT
  [M:CRM9]OBJTYP = [M:CRM9]OBJ(nolign-1)
  [M:CRM9]OBJKEY = [M:CRM9]CODE(nolign-1)
  If [M:CRM9]TYPESEARCH = "AIN" Then
    [M:CRM9]CCNKEY = [M:CRM9]CODE(nolign-1)
    [M:CRM9]BPRKEY = ""
  Else
    [M:CRM9]CCNKEY = ""
    [M:CRM9]BPRKEY = [M:CRM9]CODE(nolign-1)
  Endif
  Case BOUT
    When ")"
      #Planifier Rendez-vous
      GBCRMFLGNEW = 1
    When "("
      #Planifier Appel
      GBCRMFLGNEW = 1
    When "£"
      #Planifier Tache
      GBCRMFLGNEW = 1
    When "}"
      #Enregistrer Rendez-vous
      GBCRMFLGNEW = 1
    When "{"
      #Enregistrer Appel
      GBCRMFLGNEW = 1
    When "~"
      #Enregistrer tache
      GBCRMFLGNEW = 1
    When "!"
      #Enregistrer Affaire
      GBCRMFLGNEW = 1
    When "%"
      #Enregistrer demande de service
      GBCRMFLGNEW = 1
    When "3"
      #Enregistrer demande de garantie
      GBCRMFLGNEW = 1
    When "µ"
      #Enregistrer contrat de service
      GBCRMFLGNEW = 1
  Endcase
Return

##########################################################################################################
$FINSAI
  Kill GFMTFCRM9
  #Nettoie l'écran avant de partir.
  Raz [M:CRM9]
Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
Return

##########################################################################################################
$BOUTON
  Case BOUT
    When "C"
      Gosub ONLOAD
    When Default
  Endcase
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
$ONLOAD
  Gosub GERETYPE
  If [M:CRM9]TYPESEARCH = "AIN" Then
    Gosub LOADAIN
  Else
    Gosub LOADBPR
  Endif
  Gosub GEREAFFICHAGE
Return

##########################################################################################################
$GERETYPE
Local Char SZTYPE(GLONAOB)
Local Integer IBTROUVE

  Raz SZTYPE
  IBTROUVE = 0
  SZTYPE = "BPR"
  If [M:CRM9]BPRNAM <> "" and IBTROUVE = 0 Then
    SZTYPE = "BPR"
    IBTROUVE = 1
  Endif
  If [M:CRM9]BPRZIP <> "" and IBTROUVE = 0 Then
    SZTYPE = "BPR"
    IBTROUVE = 1
  Endif
  If [M:CRM9]BPRCTY <> "" and IBTROUVE = 0 Then
    SZTYPE = "BPR"
    IBTROUVE = 1
  Endif
  If [M:CRM9]BPRADEDEF = 2 and IBTROUVE = 0 Then
    SZTYPE = "BPR"
    IBTROUVE = 1
  Endif
  If [M:CRM9]TIERS <> "" and IBTROUVE = 0 Then
    # FGR 13/05/2009 : X3SUIVI50196
    SZTYPE = "BPR"
    IBTROUVE = 1
  Endif
  If [M:CRM9]CCNLNA <> "" and IBTROUVE = 0 Then
    SZTYPE = "AIN"
    IBTROUVE = 1
  Endif
  If [M:CRM9]CCNFNA <> "" and IBTROUVE = 0 Then
    SZTYPE = "AIN"
    IBTROUVE = 1
  Endif
  If [M:CRM9]TELFAXMOB <> "" and IBTROUVE = 0 Then
    # FGR 13/05/2009 : X3SUIVI50196
    SZTYPE = "AIN"
    IBTROUVE = 1
  Endif
  [M:CRM9]TYPESEARCH = SZTYPE
Return

##########################################################################################################
$GEREAFFICHAGE
  If [M:CRM9]TYPESEARCH = "AIN" Then
    #Champs à rendre invisible
    #On masque CNTTYP
    #format de BPAADDFLG
    If left$(GFMTFCRM9(1),1) <> "-" Then
      GFMTFCRM9(1) = "-" + GFMTFCRM9(1)
    Endif
    #format de BPADES
    If left$(GFMTFCRM9(2),1) <> "-" Then
      GFMTFCRM9(2) = "-" + GFMTFCRM9(2)
    Endif
    #Champs à rendre visible    O
    #CNTTYP
    If left$(GFMTFCRM9(0),1) = "-" Then
      GFMTFCRM9(0) = right$(GFMTFCRM9(0), 2)
    Endif
  Else
    #Champs à rendre invisible
    #On masque CNTTYP
    If left$(GFMTFCRM9(0),1) <> "-" Then
      GFMTFCRM9(0) = "-" + GFMTFCRM9(0)
    Endif
    #Champs à rendre visible    O
    #format de BPAADDFLG
    If left$(GFMTFCRM9(1),1) = "-" Then
      GFMTFCRM9(1) = right$(GFMTFCRM9(1), 2)
    Endif
    #format de BPADES
    If left$(GFMTFCRM9(2),1) = "-" Then
      GFMTFCRM9(2) = right$(GFMTFCRM9(2), 2)
    Endif
  Endif
  If [M:CRM9]NBREC = 0 Then
    [M:CRM9]NBREC = 1
    Affzo [M:CRM9]15
    Effzo [M:CRM9]15
  Endif
  Affzo [M:CRM9]1-99
Return

##########################################################################################################
$LOADBPR
Local Char SZWHERE(250)(20)
Local Integer ILIGNEWHERE
Local Char SZAND(6)
Local Char SZVALEUR(100)
Local Char SZRECHERCHE(100)
Local Integer ILIGNE
Local Integer INBLIGNETOTAL

  Raz SZWHERE
  ILIGNEWHERE = 0
  Raz SZAND
  Raz SZVALEUR
  Raz SZRECHERCHE
  ILIGNE = 0
  INBLIGNETOTAL = 0
  Effzo [M:CRM9]15
  [M:CRM9]NBREC = 0
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  #Il faut créer le link
  Link [BPA] With [BPR]BPR0 = [F:BPA]BPANUM As [BPRA] Where [F:BPR]BPRNUM <> "" and [F:BPA]BPATYP = 1
  #
  If [M:CRM9]BPRNAM <> "" Then
    SZVALEUR = [M:CRM9]BPRNAM
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE = '"' + toupper(SZVALEUR) + '*"'
    SZWHERE(ILIGNEWHERE) = SZAND - "pat(toupper([F:BPR]BPRNAM)," + SZRECHERCHE + ")<>0 "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM9]BPRZIP <> "" Then
    SZVALEUR = [M:CRM9]BPRZIP
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE = '"' + toupper(SZVALEUR) + '*"'
    SZWHERE(ILIGNEWHERE) = SZAND - "pat(toupper([F:BPA]POSCOD)," + SZRECHERCHE + ")<>0 "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM9]BPRCTY <> "" Then
    SZVALEUR = [M:CRM9]BPRCTY
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE = '"' + toupper(SZVALEUR) + '*"'
    SZWHERE(ILIGNEWHERE) = SZAND - "pat(toupper([F:BPA]CTY)," + SZRECHERCHE + ")<>0 "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM9]BPRADEDEF = 2 Then
    SZWHERE(ILIGNEWHERE)= SZAND - "[F:BPA]BPAADDFLG=2 "
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM9]TIERS <> "" Then
    # FGR 13/05/2009 : X3SUIVI50196
    SZWHERE(ILIGNEWHERE)= SZAND - "find([F:BPR]BPRNUM," + [M:CRM9]TIERS + ")<>0"
    Raz [M:CRM9]TIERS
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  Call AJOUTE_CONDITION_ROLE (SZWHERE, ILIGNEWHERE, "BPR") From CRMUTIL150  # FGR 24/04/2009 : X3SUIVI54295 : utilisation rôles normalisée
  #
  # FGR 04/11/2008 : X3SUIVI50195 : Ajout d'un point d'entrée
  Gosub PE_BPRAINCRM9 From TRTCRMPE
  #
  If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
    Filter [BPRA] Where evalue(SZWHERE) Order By [F:BPR]BPRNAM Desc; [F:BPA]CTY Desc
  Else
    Filter [BPRA] Order By [F:BPR]BPRNAM Desc; [F:BPA]CTY Desc
  Endif
  INBLIGNETOTAL = rowcount([BPRA])
  ILIGNE = 0
  For [BPRA]
    If ILIGNE >= dim([M:CRM9]NAM)-1 Then
      Break
    Endif
    If [F:BPA]BPANUM <> "" and [F:BPR]BPRNUM <> "" Then
      If [F:BPR]BPCFLG = 2 Then
        [M:CRM9]OBJ(ILIGNE) = "BPC"  # Client
      Elsif [F:BPR]PPTFLG = 2 Then
        [M:CRM9]OBJ(ILIGNE) = "BPP"  # Prospect
      Else
        [M:CRM9]OBJ(ILIGNE) = "BPR"  # Tiers
      Endif
      [M:CRM9]NAM(ILIGNE) = [F:BPR]BPRNAM
      [M:CRM9]ZIP(ILIGNE) = [F:BPA]POSCOD
      [M:CRM9]CTY(ILIGNE) = [F:BPA]CTY
      [M:CRM9]TEL(ILIGNE) = [F:BPA]TEL(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
      [M:CRM9]CRY(ILIGNE) = [F:BPA]CRY
      [M:CRM9]BPAADDFLG(ILIGNE) = [F:BPA]BPAADDFLG
      [M:CRM9]BPADES(ILIGNE) = [F:BPA]BPADES
      [M:CRM9]CODE(ILIGNE) = [F:BPR]BPRNUM
      [M:CRM9]BPRNUM(ILIGNE) = [F:BPR]BPRNUM
      ILIGNE += 1
    Endif
  Next
  Filter [BPRA]
  [M:CRM9]NBREC = ILIGNE
  If ILIGNE < INBLIGNETOTAL Then
    #Tous les enregistrements n'ont pas pu être affichés, un critère plus discriminant doit être saisi.
    GMESSAGE = mess(963,182,1)
    GERR = 2
  Endif
Return

##########################################################################################################
$LOADAIN
Local Char SZWHERE(250)(20)
Local Integer ILIGNEWHERE
Local Char SZAND(6)
Local Char SZVALEUR(100)
Local Char SZRECHERCHE(100)
Local Integer ILIGNE
Local Integer INBLIGNETOTAL

  Raz SZWHERE
  ILIGNEWHERE = 0
  Raz SZAND
  Raz SZVALEUR
  Raz SZRECHERCHE
  ILIGNE = 0
  INBLIGNETOTAL = 0
  Effzo [M:CRM9]15
  [M:CRM9]NBREC = 0
  If !clalev([F:AIN]) : Local File "CONTACTCRM" [AIN] : Endif
  #
  If [M:CRM9]CCNLNA <> "" Then
    SZVALEUR = [M:CRM9]CCNLNA
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE = '"' + toupper(SZVALEUR) + '*"'
    SZWHERE(ILIGNEWHERE) = " pat(toupper([F:AIN]CNTLNA)," + SZRECHERCHE + ")<>0"
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM9]CCNFNA <> "" Then
    SZVALEUR = [M:CRM9]CCNFNA
    Call VIRE_ASTERIX_END (SZVALEUR) From CRMUTIL150
    SZRECHERCHE = '"' + toupper(SZVALEUR) + '*"'
    SZWHERE(ILIGNEWHERE) = SZAND - "pat(toupper([F:AIN]CNTFNA)," + SZRECHERCHE + ")<>0"
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM9]TELFAXMOB <> "" Then
    # FGR 13/05/2009 : X3SUIVI50196
    SZWHERE(ILIGNEWHERE) = SZAND - "([F:AIN]CNTETS=[M:CRM9]TELFAXMOB or [F:AIN]CNTFAX=[M:CRM9]TELFAXMOB or [F:AIN]CNTMOB=[M:CRM9]TELFAXMOB)"
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  If [M:CRM9]CRITPST = 2 Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:AIN]CNTTYP=1"
    ILIGNEWHERE += 1
    SZAND = " AND "
  Elsif [M:CRM9]CRITPST = 3 Then
    SZWHERE(ILIGNEWHERE) = SZAND - "[F:AIN]CNTTYP=2"
    ILIGNEWHERE += 1
    SZAND = " AND "
  Endif
  Call AJOUTE_CONDITION_ROLE (SZWHERE, ILIGNEWHERE, "AIN") From CRMUTIL150  # FGR 24/04/2009 : X3SUIVI54295 : utilisation rôles normalisée
  # FGR 04/11/2008 : X3SUIVI50195 : Ajout d'un point d'entrée
  Gosub PE_BPRAINCRM9 From TRTCRMPE
  #
  If func CRMUTIL150.TEST_TAB_WHERE_NON_VIDE(SZWHERE, ILIGNEWHERE) = 1 Then
    Filter [AIN] Where evalue (SZWHERE) Order By [F:AIN]CNTLNA Desc; [F:AIN]CNTFNA Desc
  Else
    Filter [AIN] Order By [F:AIN]CNTLNA Desc; [F:AIN]CNTFNA Desc
  Endif
  INBLIGNETOTAL = rowcount([AIN])
  ILIGNE = 0 : # FGR 24/04/2009 : X3SUIVI54724
  For [AIN]
    If ILIGNE >= dim([M:CRM9]NAM)-1 Then
      Break
    Endif
    [M:CRM9]CNTTYP(ILIGNE) = [F:AIN]CNTTYP
    If [M:CRM9]CNTTYP(ILIGNE) = 2 Then
      [M:CRM9]OBJ(ILIGNE) = "LDS"  # Lead
    Else
      [M:CRM9]OBJ(ILIGNE) = "AIN"  # Interlocuteur
    Endif
    Call BUILDFULNAM("AIN", [M:CRM9]NAM(ILIGNE)) From CRMUTIL140
    [M:CRM9]ZIP(ILIGNE) = [F:AIN]ZIP
    [M:CRM9]CTY(ILIGNE) = [F:AIN]CTY
    [M:CRM9]TEL(ILIGNE) = [F:AIN]CNTETS
    [M:CRM9]CRY(ILIGNE) = [F:AIN]CRY
    [M:CRM9]CODE(ILIGNE) = [F:AIN]CNTNUM
    [M:CRM9]CCNNUM(ILIGNE) = [F:AIN]CNTNUM
    ILIGNE += 1
  Next
  Filter [AIN]
  [M:CRM9]NBREC = ILIGNE
  If ILIGNE < INBLIGNETOTAL Then
    #Tous les enregistrements n'ont pas pu être affichés, un critère plus discriminant doit être saisi.
    GMESSAGE = mess(963,182,1)
    GERR = 2
  Endif
Return

