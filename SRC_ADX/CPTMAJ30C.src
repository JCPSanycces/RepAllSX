#<AdxTL>@(#)3.0.0.0 $Revision$
Call OUVRE_TRACE("") From LECFIC
Local File ADOSSIER [ADS]
Read [ADS]DOSSIER = "DEMOFRA"
#Call ACPTMAJ30 From CPTMAJ30
Call SUPP_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End
##########################################################################################################
# ... MAJ30 : Mises à jour à effectuer lors du passage à la version 6 
##########################################################################################################
##-------------------------------------------------------------------------------------------------------#
# Migration des mouvements
##-------------------------------------------------------------------------------------------------------#
# $GACCENTRY   :  En tête de pièces comptables
##-------------------------------------------------------------------------------------------------------#
# $GACCENTRYD  :  Pièces comptables 'générales', 'analytique' & 'IAS' flagué Auto
##-------------------------------------------------------------------------------------------------------#
# $GACCENTRYA  :  Pièces comptables purement 'analytiques'
##-------------------------------------------------------------------------------------------------------#
# $GACEIAS     :  Pièces comptables purement 'IAS' flagué Auto
##-------------------------------------------------------------------------------------------------------#
# $GCOMMIT     :  Pièces d'engagements
# $GCOMMID     
##-------------------------------------------------------------------------------------------------------#
# $GENTLOH     :  Pièces par LOT
# $GENTLOTD
##-------------------------------------------------------------------------------------------------------#
# $BUD         :  Mouvements budgétaires
##-------------------------------------------------------------------------------------------------------#
# $BUDOD       :  Pièces budgétaires
##-------------------------------------------------------------------------------------------------------#
End

##-------------------------------------------------------------------------------------------------------#
$GACCENTRY
##-------------------------------------------------------------------------------------------------------#

# Mise à jour des tables V6
Local File =[F:ADS]DOSSIER+".GACCENTRY"    [HAE]    Order By Key CLE=CPY;TYP;NUM    # Entête de pièces

Local File =[F:ADS]DOSSIER+".GACM"        [GCM]         # Modèles comptables 
Local File =[F:ADS]DOSSIER+".COMPANY"     [CPY]         # Sociétés

Call ECR_TIME(mess(81,125,1)-": GACCENTRY") From DOSSUB : # maj table

Gosub SET_FIRST From TRTFIRST
Raz STOP, CRITERE
$LOOP_HAE
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:HAE]CPY='"+ACLE1+"' & [F:HAE]TYP='"+ACLE2+"' & [F:HAE]NUM>'"+ACLE3+"'"
Elsif STOP=2
 STOP = 3
 CRITERE = "[F:HAE]CPY='"+ACLE1+"' & [F:HAE]TYP>'"+ACLE2+"'"
Elsif STOP=3
 STOP = 0
 CRITERE = "[F:HAE]CPY>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif
 
Trbegin [HAE]
GOK = 1

For [HAE]CLE(1) Where evalue(CRITERE)

 Read [CPY]CPY0 = [F:HAE]CPY 
 If [F:CPY]ACM <> [F:GCM]GCM
  Read [F:GCM]GCM0 = [F:CPY]ACM
 Endif

 For [HAE]CLE

  #  Zones liées aux modèle comptable (ici STD... 3 lignes référentiel non autoamtique SOC/ANA/IAS et 3 lignes de reporting automatiques)
  For I=1 To dim([F:GCM]LED)
   If [F:GCM]LED(I-1)<>""
    [F:HAE]LED(I-1)    = [F:GCM]LED(I-1)
    [F:HAE]CURLED(I-1) = [F:GCM]CUR(I-1)
    [F:HAE]RATDIV(I-1) = 1 
    If I<3
     [F:HAE]RATMLT(I-1) = [F:HAE]RATCUR
    Else
     [F:HAE]RATMLT(I-1) = [F:HAE]RATRPT
    Endif
   Endif
  Next

  Rewrite [HAE]
  If fstat
   GOK = 0 : Call ERREUR("GACCENTRY"-[F:HAE]TYP-[F:HAE]NUM,1) From DOSDIC
  Else
#   Call ECR_TRACE("$HAE"-[F:HAE]CPY-[F:HAE]TYP-[F:HAE]NUM,0) From GESECRAN
  Endif

  NB+=1
  If NB>GMAXUPDTRS 
   ACLE1 = [F:HAE]CPY
   ACLE2 = [F:HAE]TYP
   ACLE3 = [F:HAE]NUM
   STOP=1
   Break 2
  Endif
 Next
Next
#Pas de Rollback
#If GOK<1 : Rollback
#Else     : Commit
#Endif
Commit

If STOP
 Goto LOOP_HAE
Endif
Gosub UNSET_FIRST From TRTFIRST

Close Local File [HAE], [GCM], [CPY]
Return

##-------------------------------------------------------------------------------------------------------#
$GACCENTRYD
##-------------------------------------------------------------------------------------------------------#

# Mise à jour des tables V6
Local File =[F:ADS]DOSSIER+".GACCENTRY"    [HAE]        # En tête de pièces
Local File =[F:ADS]DOSSIER+".GACCENTRYD"   [DAE]        # Ligne générale  de pièces
Local File =[F:ADS]DOSSIER+".GACCENTRYA"   [DAA]        # Ligne analytique de pièces

Local File =[F:ADS]DOSSIER+".GACCENTRYD"   [DAE2]       # Ligne générale  de pièces

If PLIAS<>""
 Local File =[F:ADS]DOSSIER+".GACEIAS"     [HIA]        # Entête de pièces IAS
Endif

Local File =[F:ADS]DOSSIER+".GACM"        [GCM]         # Modèles comptables 
Local File =[F:ADS]DOSSIER+".GLED"        [LED]         # Référentiels
Local File =[F:ADS]DOSSIER+".COMPANY"     [CPY]         # Sociétés

Local Integer ACCNUM_GEN, ACCNUM_ANA, ACCNUM_IAS
Local Char    COAGEN(30), COAANA(30), COAIAS(30)
Local Char    LEDGEN(3), LEDANA(3), LEDIAS(3)
# 
Local Integer TYPGEN           # Type de référentiel dit 'Social'
Local Integer TYPANA           # Type de référentiel dit 'Analytique'
Local Integer TYPIAS           # Type de référentiel dit 'Sectoriel'
Local Integer TYPAUTGEN        # Type de référentiel automatique 
Local Integer TYPAUTANA        # Type de référentiel automatique 
Local Integer TYPAUTIAS        # Type de référentiel automatique 

Call ECR_TIME(mess(81,125,1)-": GACCENTRYD (1/2)") From DOSSUB : # maj table

Link [DAE2] With [HAE]HAE0=[F:DAE2]TYP;[F:DAE2]NUM
&   As [LNK]
&   Order By Key CLE = [F:HAE]CPY;[F:DAE2]TYP;[F:DAE2]NUM;[F:DAE2]LIG

Gosub SET_FIRST From TRTFIRST
Raz STOP, CRITERE
$LOOP_DAE
If GTYPDBA=2 #SQL
 Filter [F:LNK] Where [F:DAE2]LEDTYP<1
Endif
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:HAE]CPY='"+ACLE1+"' & [F:DAE2]TYP='"+ACLE2+"' & [F:DAE2]NUM='"+ACLE3+"' & [F:DAE2]LIG>"+num$(ICLE1)
Elsif STOP=2
 STOP = 3
 CRITERE = "[F:HAE]CPY='"+ACLE1+"' & [F:DAE2]TYP='"+ACLE2+"' & [F:DAE2]NUM>'"+ACLE3+"'"
Elsif STOP=3
 STOP = 4
 CRITERE = "[F:HAE]CPY='"+ACLE1+"' & [F:DAE2]TYP>'"+ACLE2+"'"
Elsif STOP=4
 STOP = 0
 CRITERE = "[F:HAE]CPY>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif
 
Trbegin [HAE], [DAE]
GOK = 1

For [LNK]CLE(1) Where evalue(CRITERE)

 Raz COAGEN, COAANA, COAIAS
 Raz TYPGEN, TYPANA, TYPIAS, TYPAUTGEN, TYPAUTANA, TYPAUTIAS
 Read [CPY]CPY0 = [F:HAE]CPY 
 If !fstat 
  If [F:CPY]ACM <> [F:GCM]GCM
   Read [F:GCM]GCM0 = [F:CPY]ACM
  Endif
  LEDGEN     = [F:GCM]LED(0)
  LEDANA     = [F:GCM]LED(1)
  LEDIAS     = [F:GCM]LED(2)
  Read [F:LED]LED0 = LEDGEN
  COAGEN = [F:LED]COA
  TYPGEN = 1
  If  LEDANA<>""
   Read [F:LED]LED0 = LEDANA
   COAANA = [F:LED]COA
   TYPANA = 2
  Else
   If [F:GCM]ANALEDTYP=0
    # Erreur de lecture - Modèle comptable inexistant
    TYPANA = 0 : Call ERREUR("GACCENTRYD-"-mess(2,45,1)-[F:HAE]CPY-"-"-mess(5,618,1)-[F:CPY]ACM-"-"-mess(198,105,1),4) From DOSDIC
   Else
    Read [F:LED]LED0 = [F:GCM]LED([F:GCM]ANALEDTYP-1)
    COAANA = [F:LED]COA
    TYPANA = [F:GCM]ANALEDTYP
    LEDANA = [F:GCM]LED([F:GCM]ANALEDTYP-1)
   Endif
  Endif
  If LEDIAS<>""
   Read [F:LED]LED0 = LEDIAS
   COAIAS = [F:LED]COA
   TYPIAS = 3
  Endif

  For I=3 To dim([F:GCM]LED)-1
   If [F:GCM]LED(I)<>""
    Case [F:GCM]LED(I)
     When LEDGEN : [L]TYPAUTGEN = I
     When LEDANA : [L]TYPAUTANA = I
     When LEDIAS : [L]TYPAUTIAS = I
    Endcase
   Endif 
  Next

  For [LNK]CLE
   # Lignes de pièces comptables.
   Raz [F:DAE]
   [F:DAE] = [F:DAE2]
  
   # champs renommée
   [F:DAE]LIN    = [F:DAE2]LIG
  
   # nouveaux champs
   [F:DAE]IDTLIN = num$([F:DAE]LIN)  # Les tansactions récupérées sont de type "Saisie colonne".
   [F:DAE]FIY    = [F:HAE]FIY  # A vérifier
   [F:DAE]PER    = [F:HAE]PER  # A vérifier

   # écriture plan générale si pièce non purement analytique
   If [F:HAE]ANA<>2
    [F:DAE]LEDTYP  = [L]TYPGEN
    [F:DAE]LED     = [L]LEDGEN
    [F:DAE]COA     = [L]COAGEN
    [F:DAE]CURLED  = [F:HAE]CURLED([F:DAE]LEDTYP-1)
    [F:DAE]AMTLED  = [F:DAE2]AMTLOC 
    [F:DAE]AMTFLG  = [F:DAE2]AMTLOCFLG
    [F:DAE]AMTLED1 = [F:DAE2]AMTLOC1
    [L]ACCNUM_GEN  = [F:DAE]ACCNUM
    Write [DAE]
    If fstat
     GOK = 0 : Call ERREUR("GACCENTRYD"-[F:DAE]TYP-[F:DAE]NUM-num$([F:DAE]LIN)-num$([F:DAE]LEDTYP),1) From DOSDIC
    Endif
    # Gestion de l'automatique en même temps... (récupération de ACCNUM pour ACCNUMORI + Montant forcé...)
    If [L]TYPAUTGEN
     [F:DAE]LEDTYP  = [L]TYPAUTGEN
     [F:DAE]CURLED  = [F:HAE]CURLED([F:DAE]LEDTYP-1)
     [F:DAE]AMTLED  = [F:DAE2]AMTRPT 
     [F:DAE]AMTFLG  = [F:DAE2]AMTRPTFLG
     [F:DAE]AMTLED1 = [F:DAE2]AMTRPT1
     Call ACCNUM_DAE([F:DAE]ACCNUM)  # Il faut regénérer un nouvel ACCNUM
     [F:DAE]ACCNUMORI = [L]ACCNUM_GEN
     Write [DAE]
     If fstat
      GOK = 0 : Call ERREUR("GACCENTRYD"-[F:DAE]TYP-[F:DAE]NUM-num$([F:DAE]LIN)-num$([F:DAE]LEDTYP),1) From DOSDIC
     Endif
    Endif
   Endif

   # écriture plan analytique
   If [L]LEDANA<>"" & [F:DAE2]CNA<>"" & [L]TYPGEN<>[L]TYPANA
    [F:DAE]LEDTYP  = [L]TYPANA
    [F:DAE]LED     = [L]LEDANA
    [F:DAE]COA     = [L]COAANA
    [F:DAE]ACC     = [F:DAE2]CNA
    [F:DAE]CURLED  = [F:HAE]CURLED([F:DAE]LEDTYP-1)
    [F:DAE]AMTLED  = [F:DAE2]AMTLOC 
    [F:DAE]AMTFLG  = [F:DAE2]AMTLOCFLG
    [F:DAE]AMTLED1 = [F:DAE2]AMTLOC1
    Call ACCNUM_DAE([F:DAE]ACCNUM)  # Il faut regénérer un nouvel ACCNUM
    [F:DAE]ACCNUMORI = 0
    [L]ACCNUM_ANA = [F:DAE]ACCNUM
    Write [DAE]
    If fstat
     GOK = 0 : Call ERREUR("GACCENTRYD"-[F:DAE]TYP-[F:DAE]NUM-num$([F:DAE]LIN)-num$([F:DAE]LEDTYP),1) From DOSDIC
    Endif
    # Gestion de l'automatique en même temps... (récupération de ACCNUM pour ACCNUMORI + Montant forcé...)
    If [L]TYPAUTANA
     [F:DAE]LEDTYP  = [L]TYPAUTANA
     [F:DAE]CURLED  = [F:HAE]CURLED([F:DAE]LEDTYP-1)
     [F:DAE]AMTLED  = [F:DAE2]AMTRPT 
     [F:DAE]AMTFLG  = [F:DAE2]AMTRPTFLG
     [F:DAE]AMTLED1 = [F:DAE2]AMTRPT1
     Call ACCNUM_DAE([F:DAE]ACCNUM)  # Il faut regénérer un nouvel ACCNUM
     [F:DAE]ACCNUMORI = [L]ACCNUM_ANA
     Write [DAE]
     If fstat
      GOK = 0 : Call ERREUR("GACCENTRYD"-[F:DAE]TYP-[F:DAE]NUM-num$([F:DAE]LIN)-num$([F:DAE]LEDTYP),1) From DOSDIC
     Endif
    Endif
   Endif

   # écriture plan IAS
   If LEDIAS<>""
    Read [HIA]HIA0 = [F:DAE2]TYP;[F:DAE2]NUM
    If !fstat & [F:HIA]FLG = 2
     [F:DAE]LEDTYP  = [L]TYPIAS
     [F:DAE]LED     = [L]LEDIAS
     [F:DAE]COA     = [L]COAIAS
     [F:DAE]ACC     = [F:DAE2]ACC
     [F:DAE]CURLED  = [F:HAE]CURLED([F:DAE]LEDTYP-1)
     [F:DAE]AMTLED  = [F:DAE2]AMTLOC 
     [F:DAE]AMTFLG  = [F:DAE2]AMTLOCFLG
     [F:DAE]AMTLED1 = [F:DAE2]AMTLOC1
     Call ACCNUM_DAE([F:DAE]ACCNUM)  # Il faut regénérer un nouvel ACCNUM
     [F:DAE]ACCNUMORI = 0
     [L]ACCNUM_IAS = [F:DAE]ACCNUM
     Write [DAE]
     If fstat
      GOK = 0 : Call ERREUR("GACCENTRYD"-[F:DAE]TYP-[F:DAE]NUM-num$([F:DAE]LIN)-num$([F:DAE]LEDTYP),1) From DOSDIC
     Endif
     If [F:DAE2]SCT1<>"" or [F:DAE2]SCT2<>""
      # Enregsitrement sous DAA
      Raz [DAA]
      # Transclasse... initialisation par rapport à DAE.
      [DAA] = [DAE]
      [F:DAA]ANALIN+=1
      [F:DAA]DIE(0) = [L]AXEIAS1
      [F:DAA]CCE(0) = [F:DAE2]SCT1     
      [F:DAA]DIE(1) = [L]AXEIAS2
      [F:DAA]CCE(1) = [F:DAE2]SCT2     
      [F:DAA]AMTLED = [F:DAE2]AMTLOC 
      Write [DAA]
      If fstat
       GOK = 0 : Call ERREUR("GACCENTRYA"-[F:DAA]TYP-[F:DAA]NUM-num$([F:DAA]LIN)-num$([F:DAA]LEDTYP),1) From DOSDIC
      Endif
      # Gestion de l'automatique en même temps... (récupération du Montant forcé...)
      If [L]TYPAUTIAS
       [F:DAA]LEDTYP = [L]TYPAUTIAS
       [F:DAA]CURLED = [F:HAE]CURLED([F:DAA]LEDTYP-1)
       [F:DAA]AMTLED = [F:DAE2]AMTRPT 
       Write [DAA]
       If fstat
        GOK = 0 : Call ERREUR("GACCENTRYA"-[F:DAA]TYP-[F:DAA]NUM-num$([F:DAA]LIN)-num$([F:DAA]LEDTYP),1) From DOSDIC
       Endif   
       # Gestion de l'automatique en même temps... (récupération de ACCNUM pour ACCNUMORI + Montant forcé...)
       [F:DAE]LEDTYP = [L]TYPAUTIAS
       [F:DAE]CURLED = [F:HAE]CURLED([F:DAE]LEDTYP-1)
       [F:DAE]AMTLED = [F:DAE2]AMTRPT 
       [F:DAE]AMTFLG = [F:DAE2]AMTRPTFLG
       [F:DAE]AMTLED1= [F:DAE2]AMTRPT1
       Call ACCNUM_DAE([F:DAE]ACCNUM)  # Il faut regénérer un nouvel ACCNUM
       [F:DAE]ACCNUMORI = [L]ACCNUM_IAS
       Write [DAE]
       If fstat
        GOK = 0 : Call ERREUR("GACCENTRYD"-[F:DAE]TYP-[F:DAE]NUM-num$([F:DAE]LIN)-num$([F:DAE]LEDTYP),1) From DOSDIC
       Endif
      Endif
     Endif
    Endif
   Endif

   NB+=1
   If NB>GMAXUPDTRS 
    ACLE1 = [F:HAE]CPY
    ACLE2 = [F:DAE2]TYP
    ACLE3 = [F:DAE2]NUM
    ICLE1 = [F:DAE2]LIG
    STOP=1
    Break 2
   Endif
  Next
 Else
  # Pas de société... pas de migration possible pour les pièces
  GOK = 0 : Call ERREUR("GACCENTRYD"-[F:HAE]CPY-mess(16,104,1),4) From DOSDIC
 Endif 
Next
#Pas de Rollback
#If GOK<1 : Rollback
#Else     : Commit
#Endif
Commit

If STOP
 Goto LOOP_DAE
Endif
Gosub UNSET_FIRST From TRTFIRST

Close Local File [HAE], [DAE], [DAA], [DAE2], [GCM], [LED], [CPY]
If PLIAS<>""
 Close Local File [HIA]
Endif
Return

$DELETE_DAE
Call ECR_TIME(mess(81,125,1)-": GACCENTRYD (2/2)") From DOSSUB : # maj table
Local File =[F:ADS]DOSSIER+".GACCENTRYD"   [DAE]         # Ligne générale  de pièces
Trbegin [DAE]
Delete [DAE] Where LEDTYP<1
If fstat
 GOK = 0 : Call ERREUR("GACCENTRYD",3) From DOSDIC
Endif
Commit

Close Local File [DAE]
Return

##-------------------------------------------------------------------------------------------------------#
$GACCENTRYA
##-------------------------------------------------------------------------------------------------------#

# Mise à jour des tables V6
Local File =[F:ADS]DOSSIER+".GACCENTRY"    [HAE]         # Entête de pièces
Local File =[F:ADS]DOSSIER+".GACCENTRYD"   [DAE]         # Ligne générale de pièces
Local File =[F:ADS]DOSSIER+".GACCENTRYA"   [DAA]         # Ligne analytique de pièces

# Ouverture des tables V5
Local File =[F:ADS]DOSSIER+".GACCENTRYA"   [DAA2]        # Ligne analytique de pièces

Local File =[F:ADS]DOSSIER+".GACM"        [GCM]         # Modèles comptables 
Local File =[F:ADS]DOSSIER+".GLED"        [LED]         # Référentiels
Local File =[F:ADS]DOSSIER+".COMPANY"     [CPY]         # Sociétés

Local Integer ACCNUM_GEN, ACCNUM_ANA, ACCNUM_IAS
Local Char    COAGEN(30), COAANA(30), COAIAS(30)
Local Char    LEDGEN(3), LEDANA(3), LEDIAS(3)
# 
Local Integer TYPGEN           # Type de référentiel dit 'Social'
Local Integer TYPANA           # Type de référentiel dit 'Analytique'
Local Integer TYPIAS           # Type de référentiel dit 'Sectoriel'
Local Integer TYPAUTGEN        # Type de référentiel automatique 
Local Integer TYPAUTANA        # Type de référentiel automatique 
Local Integer TYPAUTIAS        # Type de référentiel automatique 


Link [DAA2] With [HAE]HAE0=[F:DAA2]TYP;[F:DAA2]NUM
&   As [LNK]
&   Order By Key CLE = [F:HAE]CPY;[F:DAA2]TYP;[F:DAA2]NUM;[F:DAA2]LIG;[F:DAA2]ANALIG

Call ECR_TIME(mess(81,125,1)-": GACCENTRYA (1/2)") From DOSSUB : # maj table


Gosub SET_FIRST From TRTFIRST 
Raz STOP, CRITERE
$LOOP_DAA
Raz NB
If GTYPDBA=2 #SQL
 Filter [F:LNK] Where [F:DAA2]LIN=0 & [F:DAA2]LEDTYP<1
Else
 Filter [LNK] Where [F:DAA2]LIN=0  ## Déjà mise à jour les lignes IAS
Endif
If STOP = 1 
 STOP = 2
 CRITERE = "[F:HAE]CPY='"+ACLE1+"' & [F:DAA2]TYP='"+ACLE2+"' & [F:DAA2]NUM='"+ACLE3+"' & [F:DAA2]LIG="+num$(ICLE1)+" & [F:DAA2]ANALIG>"+num$(ICLE2)
Elsif STOP = 2
 STOP = 3
 CRITERE = "[F:HAE]CPY='"+ACLE1+"' & [F:DAA2]TYP='"+ACLE2+"' & [F:DAA2]NUM='"+ACLE3+"' & [F:DAA2]LIG>"+num$(ICLE1)
Elsif STOP = 3
 STOP = 4
 CRITERE = "[F:HAE]CPY='"+ACLE1+"' & [F:DAA2]TYP='"+ACLE2+"' & [F:DAA2]NUM>'"+ACLE3+"'"
Elsif STOP = 4
 STOP = 5
 CRITERE = "[F:HAE]CPY='"+ACLE1+"' & [F:DAA2]TYP>'"+ACLE2+"'"
Elsif STOP = 5
 STOP = 0
 CRITERE = "[F:HAE]CPY>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif
 
Trbegin [DAA]
GOK = 1

For [LNK]CLE(1) Where evalue(CRITERE)

 Raz COAGEN, COAANA, COAIAS
 Raz TYPGEN, TYPANA, TYPIAS, TYPAUTGEN, TYPAUTANA, TYPAUTIAS
 Read [CPY]CPY0 = [F:HAE]CPY 
 If !fstat
  If [F:CPY]ACM <> [F:GCM]GCM
   Read [F:GCM]GCM0 = [F:CPY]ACM
  Endif
  LEDGEN     = [F:GCM]LED(0)
  LEDANA     = [F:GCM]LED(1)
  LEDIAS     = [F:GCM]LED(2)
  Read [F:LED]LED0 = LEDGEN
  COAGEN = [F:LED]COA
  TYPGEN = 1
  If  LEDANA<>""
   Read [F:LED]LED0 = LEDANA
   COAANA = [F:LED]COA
   TYPANA = 2
  Else
   If [F:GCM]ANALEDTYP=0
    # Erreur de lecture - Modèle comptable inexistant
    TYPANA = 0 : Call ERREUR("GACCENTRYA-"-mess(2,45,1)-[F:HAE]CPY-"-"-mess(5,618,1)-[F:CPY]ACM-"-"-mess(198,105,1),4) From DOSDIC
   Else
    Read [F:LED]LED0 = [F:GCM]LED([F:GCM]ANALEDTYP-1)
    COAANA = [F:LED]COA
    TYPANA = [F:GCM]ANALEDTYP
    LEDANA = [F:GCM]LED([F:GCM]ANALEDTYP-1)
   Endif
  Endif
  If LEDIAS<>""
   Read [F:LED]LED0 = LEDIAS
   COAIAS = [F:LED]COA
   TYPIAS = 3
  Endif

  For I=3 To dim([F:GCM]LED)-1
   If [F:GCM]LED(I)<>""
    Case [F:GCM]LED(I)
     When LEDGEN : [L]TYPAUTGEN = I
     When LEDANA : [L]TYPAUTANA = I
     When LEDIAS : [L]TYPAUTIAS = I
    Endcase
   Endif 
  Next

  If [L]TYPANA>0
   For [LNK]CLE
    Raz [F:DAA]

    [F:DAA] = [F:DAA2]

    # champs renommée
    [F:DAA]LIN    = [F:DAA2]LIG
    [F:DAA]ANALIN = [F:DAA2]ANALIG
 
    # champs issus de DAE
    Read [F:DAE]DAE0 = [F:DAA]TYP;[F:DAA]NUM;[F:DAA]LIG
    If !fstat
     [F:DAA]SNS = [F:DAE]SNS
     [F:DAA]CUR = [F:DAE]CUR
    Endif

    # nouveaux champs
    [F:DAA]LEDTYP = [L]TYPANA
    [F:DAA]IDTLIN = num$([F:DAA2]LIN)  # Les tansactions récupérées sont de type "Saisie colonne".
    [F:DAA]LED    = [F:GCM]LED([L]TYPANA-1)
    [F:DAA]CURLED = [F:GCM]CUR([L]TYPANA-1)
    [F:DAA]COA    = [L]COAANA
    [F:DAA]ACC    = [F:DAA2]CNA
    If [L]COAANA=[L]COAGEN
     [F:DAA]ACC    = [F:DAE]ACC
    Endif
    [F:DAA]AMTLED = [F:DAA2]AMTLOC 
    For I=1 To [L]MIGGOPTCANA
     [F:DAA]DIE(I-1) = "AX"+num$(I)
     [F:DAA]CCE(I-1) = [F:DAA2]CCE(I-1)
    Next
    Write [DAA]
    If fstat
     GOK = 0 : Call ERREUR("GACCENTRYA"-[F:DAA]TYP-[F:DAA]NUM-num$([F:DAA]LIN)-num$([F:DAA]LEDTYP)-num$([F:DAA]ANALIN),1) From DOSDIC
    Endif
    # Gestion de l'automatique en même temps... (récupération Montant forcé...)
    If [L]TYPAUTANA
     [F:DAA]LEDTYP = [L]TYPAUTANA
     [F:DAA]CURLED = [F:GCM]CUR([L]TYPAUTANA-1)
     [F:DAA]AMTLED = [F:DAA2]AMTRPT 
     Write [DAA]
     If fstat
      GOK = 0 : Call ERREUR("GACCENTRYA"-[F:DAA]TYP-[F:DAA]NUM-num$([F:DAA]LIN)-num$([F:DAA]LEDTYP)-num$([F:DAA]ANALIN),1) From DOSDIC
     Endif
    Endif

    NB+=1
    If NB>GMAXUPDTRS 
     ACLE1 = [F:HAE]CPY
     ACLE2 = [F:DAA2]TYP
     ACLE3 = [F:DAA2]NUM
     ICLE1 = [F:DAA2]LIG
     ICLE2 = [F:DAA2]ANALIG
     STOP=1
     Break 2 
    Endif
   Next
  Endif
 Else
  # Pas de société... pas de migration possible pour les pièces
  GOK = 0 : Call ERREUR("GACCENTRYA"-[F:HAE]CPY-mess(16,104,1),4) From DOSDIC
 Endif 
Next

#Pas de Rollback
#If GOK<1 : Rollback
#Else     : Commit
#Endif
Commit

If STOP
 Goto LOOP_DAA
Endif
Gosub UNSET_FIRST From TRTFIRST

Close Local File [HAE], [DAE], [DAA], [DAA2], [GCM], [LED], [CPY]
Return

$DELETE_DAA
Call ECR_TIME(mess(81,125,1)-": GACCENTRYA (2/2)") From DOSSUB : # maj table
Local File =[F:ADS]DOSSIER+".GACCENTRYA"   [DAA]         # Ligne analytique de pièces
Trbegin [DAA]
Delete [DAA] Where LEDTYP<1
If fstat
 GOK = 0 : Call ERREUR("GACCENTRYA",3) From DOSDIC
Endif
Commit

Close Local File [DAA]
Return

##-------------------------------------------------------------------------------------------------------#
Subprog ACCNUM_DAE(NUMERO)
Variable Integer NUMERO
Local File =[F:ADS]DOSSIER+".GACCENTRYD" [DAE]
NUMERO = uniqid([F:DAE])
End

##-------------------------------------------------------------------------------------------------------#
$GACEIAS
##-------------------------------------------------------------------------------------------------------#
# Uniquement les pièces flaguées "MANUEL"... et les numéros sont réatribués.

Local File =[F:ADS]DOSSIER+".GACCENTRY"    [HAE]         # Entête de pièces
Local File =[F:ADS]DOSSIER+".GACCENTRYD"   [DAE]         # Ligne générale  de pièces
Local File =[F:ADS]DOSSIER+".GACCENTRYA"   [DAA]         # Ligne analytique de pièces

Local File =[F:ADS]DOSSIER+".GACEIAS"      [HIA]         # Entête de pièces IAS
Local File =[F:ADS]DOSSIER+".GACEIASD"     [DIA]         # Ligne générale  de pièces IAS

Local File =[F:ADS]DOSSIER+".GTYPACCENT"   [GTE]         # Type de pièces
Local File =[F:ADS]DOSSIER+".GACM"         [GCM]         # Modèles comptables 
Local File =[F:ADS]DOSSIER+".GLED"         [LED]         # Référentiels
Local File =[F:ADS]DOSSIER+".COMPANY"      [CPY]         # Sociétés
Local File =[F:ADS]DOSSIER+".ACODNUM"      [ANM]         # Compteur 
Local File =[F:ADS]DOSSIER+".AVALNUM"      [AVN]         # Compteur 

Local Integer ACCNUM_IAS, NBESSAI, STAT
Local Char NUM_IAS
Local Char    COAIAS(30)
Local Char    LEDIAS(3)
# 
Local Integer TYPIAS           # Type de référentiel dit 'Sectoriel'
Local Integer TYPAUTIAS        # Type de référentiel automatique 

Local Char    MESSA(80), GMESSAGE(80)

Call ECR_TIME(mess(81,125,1)-": GACEIAS-GACEIASD") From DOSSUB : # maj table

Link [DIA] With [HIA]HIA0=[F:DIA]TYP;[F:DIA]NUM
&   As [LNK]
&   Order By Key CLE = [F:HIA]CPY;[F:DIA]TYP;[F:DIA]NUM;[F:DIA]LIG

Gosub SET_FIRST From TRTFIRST 
Raz STOP, CRITERE
$LOOP_DIA
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:HIA]FLG=1 & [F:HIA]CPY='"+ACLE1+"' & [F:DIA]TYP='"+ACLE2+"' & [F:DIA]NUM='"+ACLE3+"' & [F:DIA]LIG>"+num$(ICLE1)
Elsif STOP = 2
 STOP = 3
 CRITERE = "[F:HIA]FLG=1 & [F:HIA]CPY='"+ACLE1+"' & [F:DIA]TYP='"+ACLE2+"' & [F:DIA]NUM>'"+ACLE3+"'"
Elsif STOP = 3
 STOP = 4
 CRITERE = "[F:HIA]FLG=1 & [F:HIA]CPY='"+ACLE1+"' & [F:DIA]TYP>'"+ACLE2+"'"
Elsif STOP = 4
 STOP = 0
 CRITERE = "[F:HIA]FLG=1 & [F:HIA]CPY>'"+ACLE1+"'"
Else
 CRITERE = "[F:HIA]FLG=1"
Endif
 
Trbegin [HAE],[DAE]
GOK = 1

For [LNK]CLE(2) Where evalue(CRITERE)

 Raz COAIAS
 Raz TYPIAS,  TYPAUTIAS
 Read [CPY]CPY0 = [F:HIA]CPY 
 If [F:CPY]ACM <> [F:GCM]GCM
  Read [F:GCM]GCM0 = [F:CPY]ACM
 Endif
 LEDIAS     = [F:GCM]LED(2)
 If LEDIAS<>""
  Read [F:LED]LED0 = LEDIAS
  COAIAS = [F:LED]COA
  TYPIAS = 3
 Endif

 For [LNK]CLE(4)

  # Attribution d'un nouveau numéro de compteur
  Read [HAE]HAE0 = [F:HIA]TYP;[F:HIA]NUM
  If fstat
   [L]NUM_IAS = [F:HIA]NUM
  Else
   Raz [L]NUM_IAS
   Read [GTE]GTE0 = [F:HIA]TYP
   If !fstat & [F:GTE]COU<>""
    Read [ANM]ANM0 = [F:GTE]COU
    If fstat
     Raz [L]NUM_IAS
     # Erreur de lecture - compteur inexistant
     Call ERREUR([F:GTE]COU-mess(12,114,1),4) From DOSDIC
    Else
     NBESSAI = 0
     $ININUM
     Call NUMERO([F:GTE]COU,[F:HIA]FCY,[F:HIA]ACCDAT,[F:HIA]JOU,[L]NUM_IAS,STAT) From SUBANM
     If GOK<1 | STAT
      GOK = 0
      If STAT
       Case STAT
        When 1  : STAT = 12
        When 2  : STAT = 13
        When 99 : STAT = 20
       Endcase
       MESSA = [F:GTE]COU : Gosub MESSAGE From CPTAUTO
       GMESSAGE = MESSA
       Call ERREUR(GMESSAGE,4) From DOSDIC
       Raz [L]NUM_IAS
      Endif
     Endif
     Look [HAE]HAE0 = [F:HIA]TYP;[L]NUM_IAS
     If !fstat : # Ca existe déjà, on prend le suivant..
      NBESSAI += 1
      If NBESSAI>100 : # On va quand même pas boucler éternellement
       Call RSTA("ANM","#"+mess(78,106,1)) From GLOCK
       GOK = 0
      Else
       Goto ININUM
      Endif
     Endif
    Endif
   Endif
  Endif

  If [L]NUM_IAS<>""
   For [LNK]CLE

    Raz [F:DAE]
    [F:DAE]    = [F:DIA]
    [F:DAE]NUM = [L]NUM_IAS

    # champs renommée
    [F:DAE]LIN    = [F:DIA]LIG
  
    # nouveaux champs
    [F:DAE]IDTLIN = num$([F:DAE]LIN)  # Les tansactions récupérées sont de type "Saisie colonne".
    [F:DAE]FIY    = [F:HIA]FIY  # A vérifier
    [F:DAE]PER    = [F:HIA]PER  # A vérifier

    [F:DAE]LEDTYP  = [L]TYPIAS
    [F:DAE]LED     = [L]LEDIAS
    [F:DAE]COA     = [L]COAIAS
    [F:DAE]CURLED  = [F:GCM]CUR([F:DAE]LEDTYP-1)
    [F:DAE]AMTLED  = [F:DIA]AMTLOC 
    Call ACCNUM_DAE([F:DAE]ACCNUM)  # Il faut regénérer un nouvel ACCNUM
    [F:DAE]ACCNUMORI = 0
    [L]ACCNUM_IAS = [F:DAE]ACCNUM
    Write [DAE]
    If fstat
     GOK = 0 : Call ERREUR("GACCENTRYD"-[F:DAE]TYP-[F:DAE]NUM-num$([F:DAE]LIN)-num$([F:DAE]LEDTYP),1) From DOSDIC
    Endif
    If [F:DIA]SCT1<>"" or [F:DIA]SCT2<>""
     # Enregsitrement sous DAA
     Raz [DAA]
     # Transclasse... initialisation par rapport à DAE.
     [DAA] = [DAE]
     [F:DAA]ANALIN+=1
     [F:DAA]DIE(0) = [L]AXEIAS1
     [F:DAA]CCE(0) = [F:DIA]SCT1     
     [F:DAA]DIE(1) = [L]AXEIAS2
     [F:DAA]CCE(1) = [F:DIA]SCT2     
     [F:DAA]AMTLED = [F:DIA]AMTLOC 
     Write [DAA]
     If fstat
      GOK = 0 : Call ERREUR("GACCENTRYA"-[F:DAA]TYP-[F:DAA]NUM-num$([F:DAA]LIN)-num$([F:DAA]LEDTYP),1) From DOSDIC
     Endif
     # Gestion de l'automatique en même temps... (récupération du Montant forcé...)
     If [L]TYPAUTIAS
      [F:DAA]LEDTYP  = [L]TYPAUTIAS
      [F:DAA]CURLED  = [F:GCM]CUR([F:DAA]LEDTYP-1)
      [F:DAA]AMTLED  = [F:DIA]AMTRPT 
       Write [DAA]
      If fstat
       GOK = 0 : Call ERREUR("GACCENTRYA"-[F:DAA]TYP-[F:DAA]NUM-num$([F:DAA]LIN)-num$([F:DAA]LEDTYP),1) From DOSDIC
      Endif   
      # Gestion de l'automatique en même temps... (récupération de ACCNUM pour ACCNUMORI + Montant forcé...)
      [F:DAE]LEDTYP = [L]TYPAUTIAS
      [F:DAE]CURLED = [F:GCM]CUR([F:DAE]LEDTYP-1)
      [F:DAE]AMTLED = [F:DIA]AMTRPT 
      Call ACCNUM_DAE([F:DAE]ACCNUM)  # Il faut regénérer un nouvel ACCNUM
      [F:DAE]ACCNUMORI = [L]ACCNUM_IAS
      Write [DAE]
      If fstat
       GOK = 0 : Call ERREUR("GACCENTRYD"-[F:DAE]TYP-[F:DAE]NUM-num$([F:DAE]LIN)-num$([F:DAE]LEDTYP),1) From DOSDIC
      Endif
     Endif
    Endif

    NB+=1
    If NB>GMAXUPDTRS 
     ACLE1 = [F:HIA]CPY
     ACLE2 = [F:DIA]TYP
     ACLE3 = [F:DIA]NUM
     ICLE1 = [F:DIA]LIG
     STOP=1
     # Ecriture de l'entête
     Gosub WRIHAE_IAS
     Break 3
    Endif
   Next
  Endif
   
  # Ecriture de l'entête
  Gosub WRIHAE_IAS

 Next
Next

#Pas de Rollback
#If GOK<1 : Rollback
#Else     : Commit
#Endif
Commit

If STOP
 Goto LOOP_DIA
Endif
Gosub UNSET_FIRST From TRTFIRST

Close Local File [HAE], [DAE], [DAA], [HIA], [DIA], [GTE], [GCM], [LED], [CPY]
Return

$WRIHAE_IAS
  Raz [F:HAE]
  [F:HAE]    = [F:HIA]
  [F:HAE]NUM = [L]NUM_IAS
  [F:HAE]BPRVCR = [F:HIA]NUM
  [F:HAE]BPRDATVCR = datesyst
  [F:HAE]CUR = [F:GCM]CUR([F:GCM]GENLEDTYP-1)

  [F:HAE]FLGGEN = 2 

  #  Zones liées aux modèle comptable (ici STD... 3 lignes référentiel non autoamtique SOC/ANA/IAS et 3 lignes de reporting automatiques)
  For I=1 To dim([F:GCM]LED)
   If [F:GCM]LED(I-1)<>""
    [F:HAE]LED(I-1)    = [F:GCM]LED(I-1)
    [F:HAE]CURLED(I-1) = [F:GCM]CUR(I-1)
    [F:HAE]RATDIV(I-1) = 1 
    [F:HAE]RATMLT(I-1) = 1
   Endif
  Next

  Write [HAE]
  If fstat
   GOK = 0 : Call ERREUR("GACCENTRY"-[F:HAE]TYP-[F:HAE]NUM-num$([F:HAE]LIN),1) From DOSDIC
  Endif
Return

##-------------------------------------------------------------------------------------------------------#
$GCOMMIT
##-------------------------------------------------------------------------------------------------------#

# Mise à jour des tables V6

Local File =[F:ADS]DOSSIER+".GCOMMIT"    [CMM]    # Entête d'engagements

Local File =[F:ADS]DOSSIER+".GACM"        [GCM]         # Modèles comptables 
Local File =[F:ADS]DOSSIER+".GLED"        [LED]         # Référentiels
Local File =[F:ADS]DOSSIER+".COMPANY"     [CPY]         # Sociétés

Local Char    COAANA(30)
Local Char    LEDANA(3)
Local Integer TYPANA

Call ECR_TIME(mess(81,125,1)-": GCOMMIT") From DOSSUB : # maj table

Gosub SET_FIRST From TRTFIRST 
Raz STOP, CRITERE
$LOOP_CMM
Raz NB
If STOP = 1 
 STOP = 0
 CRITERE = "[F:CMM]NUM>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif
 
Trbegin [CMM]
GOK = 1

For [CMM] Where evalue(CRITERE)

 Raz COAANA
 If [F:CPY]CPY <> [F:CMM]CPY
  Read [CPY]CPY0 = [F:CMM]CPY
 Endif
 If [F:CPY]ACM <> [F:GCM]GCM
  Read [F:GCM]GCM0 = [F:CPY]ACM
 Endif

 If  [F:GCM]LED(1)<>""
  Read [F:LED]LED0 = [F:GCM]LED(1)
  COAANA = [F:LED]COA
  LEDANA = [F:GCM]LED(1)
  TYPANA = 2
 Else
  If [F:GCM]ANALEDTYP=0
   If [F:CMM]CPY=""
    TYPANA = 0 : Call ERREUR("GCOMMIT"-mess(16,104,1),4) From DOSDIC
   Else 
    # Erreur de lecture - Modèle comptable inexistant
    TYPANA = 0 : Call ERREUR("GCOMMIT-"-mess(2,45,1)-[F:CMM]CPY-"-"-mess(5,618,1)-[F:CPY]ACM-"-"-mess(198,105,1),4) From DOSDIC
   Endif
  Else
   Read [F:LED]LED0 = [F:GCM]LED([F:GCM]ANALEDTYP-1)
   COAANA = [F:LED]COA
   LEDANA = [F:GCM]LED([F:GCM]ANALEDTYP-1)
   TYPANA = [F:GCM]ANALEDTYP
  Endif
 Endif

 If [L]TYPANA>0
  [F:CMM]LED([L]TYPANA-1)     = [L]LEDANA
  [F:CMM]RATMLT([L]TYPANA-1)  = [F:CMM]RATCUR
  [F:CMM]RATDIV([L]TYPANA-1)  = 1
 Endif

 [F:CMM]REFINT     = [F:CMM]REFORD 


 #Différence sens V5(+1,-1)->V6(1,2)
 If [F:CMM]SNS<>1
  [F:CMM]SNS=2
 Endif
  
 Rewrite [CMM]
 If fstat
  GOK = 0 : Call ERREUR("GCOMMIT"-[F:CMM]NUM,1) From DOSDIC
 Else
#   Call ECR_TRACE("$CMM"-[F:CMM]NUM,0) From GESECRAN
 Endif

 NB+=1
 If NB>GMAXUPDTRS 
  ACLE1 = [F:CMM]NUM
  STOP=1
  Break 
 Endif
Next
  
#Pas de Rollback
#If GOK<1 : Rollback
#Else     : Commit
#Endif
Commit

If STOP
 Goto LOOP_CMM
Endif
Gosub UNSET_FIRST From TRTFIRST
Close Local File [CMM], [GCM], [LED], [CPY]
Return


##-------------------------------------------------------------------------------------------------------#
$GCOMMITD
##-------------------------------------------------------------------------------------------------------#

# Mise à jour des tables V6
Local File =[F:ADS]DOSSIER+".GCOMMIT"    [CMM]        # Entête d'engagements
Local File =[F:ADS]DOSSIER+".GCOMMITD"   [CMD]        # Ligne d'engagements

Local File =[F:ADS]DOSSIER+".GCOMMITD"   [CMD2]       # Ligne d'engagements

Local File =[F:ADS]DOSSIER+".GACM"       [GCM]        # Modèles comptables 
Local File =[F:ADS]DOSSIER+".GLED"       [LED]        # Référentiels
Local File =[F:ADS]DOSSIER+".COMPANY"    [CPY]        # Sociétés

Local Integer ACCNUM_GEN, ACCNUM_ANA, ACCNUM_IAS
Local Char    COAANA(30)
Local Char    LEDANA(3)
# 
Local Integer TYPANA           # Type de référentiel dit 'Analytique'
Local Integer TYPAUTANA        # Type de référentiel automatique 

Call ECR_TIME(mess(81,125,1)-": GCOMMITD (1/2)") From DOSSUB : # maj table

Link [CMD2] With [CMM]CMM0=[F:CMD2]NUM
&   As [LNK]
&   Order By Key CLE = [F:CMM]CPY;[F:CMD2]NUM;[F:CMD2]LINNUM

Gosub SET_FIRST From TRTFIRST 
Raz STOP, CRITERE
$LOOP_CMD
Raz NB
If GTYPDBA=2 #SQL
 Filter [F:LNK] Where [F:CMD2]LIN<1
Endif
If STOP = 1 
 STOP = 2
 CRITERE = "[F:CMM]CPY='"+ACLE1+"' & [F:CMD2]NUM='"+ACLE2+"' & [F:CMD2]LINNUM>"+num$(ICLE1)
Elsif STOP = 2
 STOP = 3
 CRITERE = "[F:CMM]CPY='"+ACLE1+"' & [F:CMD2]NUM>'"+ACLE2+"'"
Elsif STOP = 3
 STOP = 0
 CRITERE = "[F:CMM]CPY>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif
 
Trbegin [CMM], [CMD]
GOK = 1

For [LNK]CLE(1) Where evalue(CRITERE)

 Raz COAANA
 Raz TYPANA, TYPAUTANA
 Read [CPY]CPY0 = [F:CMM]CPY 
 If !fstat
  If [F:CPY]ACM <> [F:GCM]GCM
   Read [F:GCM]GCM0 = [F:CPY]ACM
  Endif
  LEDANA     = [F:GCM]LED(1)
  If  LEDANA<>""
   Read [F:LED]LED0 = LEDANA
   COAANA = [F:LED]COA
   TYPANA = 2
  Else
   If [F:GCM]ANALEDTYP=0
    # Erreur de lecture - Modèle comptable inexistant
    TYPANA = 0 : Call ERREUR("GCOMMITD-"-mess(2,45,1)-[F:CMM]CPY-"-"-mess(5,618,1)-[F:CPY]ACM-"-"-mess(198,105,1),4) From DOSDIC
   Else
    Read [F:LED]LED0 = [F:GCM]LED([F:GCM]ANALEDTYP-1)
    COAANA = [F:LED]COA
    TYPANA = [F:GCM]ANALEDTYP
    LEDANA = [F:GCM]LED([F:GCM]ANALEDTYP-1)
   Endif
  Endif

  If [L]TYPANA>0
   For [LNK]CLE
    # Lignes d'engagements

    Raz [F:CMD]
    [F:CMD] = [F:CMD2]
  
    # champs renommée
    [F:CMD]LIN    = [F:CMD2]LINNUM
   
    # nouveaux champs (UOM, non initialisé ?)
    [F:CMD]CUR    = [F:CMM]CUR
    [F:CMD]CURLED([L]TYPANA-1) = [F:GCM]CUR([L]TYPANA-1)

    # écriture engagement sont enregsitrée sur le plan analytique
    [F:CMD]LED([L]TYPANA-1)     = [L]LEDANA
    [F:CMD]LEDTYP([L]TYPANA-1)  = [L]TYPANA
    [F:CMD]COA([L]TYPANA-1)     = [L]COAANA
    [F:CMD]ACC([L]TYPANA-1)     = [F:CMD2]CNA
   
    For I=1 To [L]MIGGOPTCANA
     [F:CMD]DIE(I-1) = "AX"+num$(I)
     [F:CMD]CCE(I-1) = evalue("[F:CMD2]CCE"+num$(I))
    Next

    [F:CMD]AMTLED([L]TYPANA-1)  = [F:CMD2]AMTLOC
    Write [CMD]
    If fstat
     GOK = 0 : Call ERREUR("GCOMMITD"-[F:CMD]NUM-num$([F:CMD]LINNUM),1) From DOSDIC
    Else
#    Call ECR_TRACE("$CMD"-[F:CMM]NUM-num$([F:CMD]LIN),0) From GESECRAN
    Endif

    # Pas de contrepartie... donc champ obsolète... AMTRPT

    NB+=1
    If NB>GMAXUPDTRS 
     ACLE1 = [F:CMD]CPY
     ACLE2 = [F:CMD]NUM
     ICLE1 = [F:CMD]LINNUM
     STOP=1
     Break 2
    Endif
   Next
  Endif
 Else
  # Pas de société... pas de migration possible pour les pièces
  GOK = 0 : Call ERREUR("GCOMMITD"-[F:CMM]CPY-mess(16,104,1),4) From DOSDIC
 Endif 
Next
#Pas de Rollback
#If GOK<1 : Rollback
#Else     : Commit
#Endif
Commit

If STOP
 Goto LOOP_CMD
Endif
Gosub UNSET_FIRST From TRTFIRST

Close Local File [CMM], [CMD], [CMD2], [GCM], [LED], [CPY]
Return

$DELETE_CMD
Call ECR_TIME(mess(81,125,1)-": GCOMMITD (2/2)") From DOSSUB : # maj table

Local File =[F:ADS]DOSSIER+".GCOMMITD"   [CMD]        # Ligne d'engagements
Trbegin [CMD]
Delete [CMD] Where LIN<1
If fstat
 GOK = 0 : Call ERREUR("GCOMMITD",3) From DOSDIC
Endif
Commit
Close Local File [CMD]
Return

##-------------------------------------------------------------------------------------------------------#
$GENTLOH
##-------------------------------------------------------------------------------------------------------#

# Mise à jour des tables V6
Local File =[F:ADS]DOSSIER+".GENTLOTH"   [LOH]         # Entête de lot

Call ECR_TIME(mess(81,125,1)-": GENTLOH ") From DOSSUB : # maj table

Gosub SET_FIRST From TRTFIRST 
Raz STOP, CRITERE
$LOOP_LOH
Raz NB
If STOP = 1 
 STOP = 2
 CRITERE = "LOT='"+ACLE1+"' & ORNVCR>"+num$(ICLE1)
Elsif STOP = 2
 STOP = 0
 CRITERE = "LOT>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif
 
Trbegin [LOH]
GOK = 1

For [LOH]LOH0 Where evalue(CRITERE)

 # ré-écriture de l'entête : Gestion des Devises (A revoir) + Nouveaux champs (TYPRAT + TYPDUD)
 [F:LOH]NBRCUR = 0 
 [F:LOH]CURMGT([F:LOH]NBRCUR)  = [F:LOH]CUR
 [F:LOH]RATDIV([F:LOH]NBRCUR)  = 1 
 [F:LOH]RATMLT([F:LOH]NBRCUR)  = [F:LOH]RATCUR
 [F:LOH]NBRCUR += 1 
 [F:LOH]CURMGT([F:LOH]NBRCUR)  = GSYSCUR
 [F:LOH]RATDIV([F:LOH]NBRCUR)  = 1 
 [F:LOH]RATMLT([F:LOH]NBRCUR)  = [F:LOH]RATRPT
  
 Rewrite [LOH]
 If fstat
  GOK = 0 : Call ERREUR("GENTLOTH"-[F:LOH]LOT-num$([F:LOH]ORNVCR),1) From DOSDIC
 Else
#   Call ECR_TRACE("$LOH"-[F:LOH]LOT,0) From GESECRAN
 Endif

 NB+=1
 If NB>GMAXUPDTRS 
  ACLE1 = [F:LOH]LOT
  ICLE1 = [F:LOH]ORNVCR
  STOP=1
  Break
 Endif
Next

#Pas de Rollback
#If GOK<1 : Rollback
#Else     : Commit
#Endif
Commit

If STOP
 Goto LOOP_LOH
Endif
Gosub UNSET_FIRST From TRTFIRST
Close Local File [LOH]
Return

##-------------------------------------------------------------------------------------------------------#
$GENTLOTD
##-------------------------------------------------------------------------------------------------------#

# Mise à jour des tables V6
Local File =[F:ADS]DOSSIER+".GENTLOT"    [LOT]         # Lot de saisie Inchangé !!!
Local File =[F:ADS]DOSSIER+".GENTLOTH"   [LOH]         # Entête de lot
Local File =[F:ADS]DOSSIER+".GENTLOTD"   [LOD]         # Ligne générale de lot
Local File =[F:ADS]DOSSIER+".GENTLOTA"   [LOA]         # Ligne analytique de lot

Local File =[F:ADS]DOSSIER+".GENTLOTD"   [LOD2]        # Ligne générale de pièces
Local File =[F:ADS]DOSSIER+".GENTLOTA"   [LOA2]        # Ligne analytique de pièces

Local File =[F:ADS]DOSSIER+".GACM"        [GCM]         # Modèles comptables 
Local File =[F:ADS]DOSSIER+".GLED"        [LED]         # Référentiels
Local File =[F:ADS]DOSSIER+".COMPANY"     [CPY]         # Sociétés

Local Integer ACCNUM_GEN, ACCNUM_ANA, ACCNUM_IAS
Local Char    COAGEN(30), COAANA(30), COAIAS(30)
Local Char    LEDGEN(3), LEDANA(3), LEDIAS(3)
# 
Local Integer TYPGEN           # Type de référentiel dit 'Social'
Local Integer TYPANA           # Type de référentiel dit 'Analytique'
Local Integer TYPIAS           # Type de référentiel dit 'Sectoriel'

Call ECR_TIME(mess(81,125,1)-": GENTLOTD-GENTLOTA (1/2)") From DOSSUB : # maj table

Link [LOD2] With [LOT]LOT0=[F:LOD2]LOT , [LOH]LOH0=[F:LOD2]LOT;[F:LOD2]ORNVCR
&   As [LNK]
&   Order By Key CLE = [F:LOT]CPY;[F:LOH]LOT;[F:LOD2]ORNVCR;[F:LOD2]LIG

Gosub SET_FIRST From TRTFIRST 
Raz STOP, CRITERE
$LOOP_LOT
Raz NB
If GTYPDBA=2 #SQL
 Filter [F:LNK] Where [F:LOD2]LIN<1
Endif
If STOP = 1 
 STOP = 2
 CRITERE = "[F:LOT]CPY='"+ACLE1+"' & [F:LOH]LOT='"+ACLE2+"' & [F:LOD2]ORNVCR="+num$(ICLE1)+" & [F:LOD2]LIG>"+num$(ICLE2)
Elsif STOP = 2
 STOP = 3
 CRITERE = "[F:LOT]CPY='"+ACLE1+"' & [F:LOH]LOT='"+ACLE2+"' & [F:LOD2]ORNVCR>"+num$(ICLE1)
Elsif STOP = 3
 STOP = 4
 CRITERE = "[F:LOT]CPY='"+ACLE1+"' & [F:LOH]LOT>'"+ACLE2+"'"
Elsif STOP = 4
 STOP = 0
 CRITERE = "[F:LOT]CPY>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif
 
Trbegin [LOH], [LOD], [LOA]
GOK = 1

For [LNK]CLE(1) Where evalue(CRITERE)

 Raz COAGEN, COAANA, COAIAS
 Raz TYPGEN, TYPANA, TYPIAS
 Read [CPY]CPY0 = [F:LOT]CPY 
 If !fstat
  If [F:CPY]ACM <> [F:GCM]GCM
   Read [F:GCM]GCM0 = [F:CPY]ACM
  Endif
  LEDGEN     = [F:GCM]LED(0)
  LEDANA     = [F:GCM]LED(1)
  LEDIAS     = [F:GCM]LED(2)
  Read [F:LED]LED0 = LEDGEN
  COAGEN = [F:LED]COA
  TYPGEN = 1
  If  LEDANA<>""
   Read [F:LED]LED0 = LEDANA
   COAANA = [F:LED]COA
   TYPANA = 2
  Else
   If [F:GCM]ANALEDTYP=0
    # Erreur de lecture - Modèle comptable inexistant
    TYPANA = 0 : Call ERREUR("GENTLOTD-"-mess(2,45,1)-[F:LOT]CPY-"-"-mess(5,618,1)-[F:CPY]ACM-"-"-mess(198,105,1),4) From DOSDIC
   Else
    Read [F:LED]LED0 = [F:GCM]LED([F:GCM]ANALEDTYP-1)
    COAANA = [F:LED]COA
    TYPANA = [F:GCM]ANALEDTYP
    LEDANA = [F:GCM]LED([F:GCM]ANALEDTYP-1)
   Endif
  Endif
  If LEDIAS<>""
   Read [F:LED]LED0 = LEDIAS
   COAIAS = [F:LED]COA
   TYPIAS = 3
  Endif

  For [LNK]CLE
   # Lignes d'engagement

   Raz [F:LOD]
   [F:LOD] = [F:LOD2]
  
   # champs renommée
   [F:LOD]LIN    = [F:LOD2]LIG
  
   # nouveaux champs
   [F:LOD]LEDTYP  = [L]TYPGEN
   [F:LOD]COA     = [L]COAGEN

   # écriture plan analytique
   If COAANA<>"" & [F:LOD2]CNA<>""
    [F:LOD]LEDTYP(1)  = [L]TYPANA
    [F:LOD]COA(1)     = [L]COAANA
    [F:LOD]ACC(1)     = [F:LOD2]CNA
   Endif

   Write [LOD]
   If fstat
    GOK = 0 : Call ERREUR("GENTLOTD"-[F:LOD]LOT-num$([F:LOD]ORNVCR)-num$([F:LOD]LIN),1) From DOSDIC
   Endif

   For [LOA2] Where LOT=[F:LOD2]LOT & ORNVCR=[F:LOD2]ORNVCR & LIG=[F:LOD2]LIG & LIN<1
    Raz [LOA]
    [F:LOA] = [F:LOA2]
    
    # champs renommée
    [F:LOA]LIN    = [F:LOA2]LIG
    [F:LOA]ANALIN = [F:LOA2]ANALIG
    For I=1 To [L]MIGGOPTCANA
     [F:LOA]DIE(I-1) = "AX"+num$(I)
     [F:LOA]CCE(I-1) = [F:LOA2]CCE(I-1)
    Next

    Write [LOA]
    If fstat
     GOK = 0 : Call ERREUR("GENTLOTA"-[F:LOA]LOT-num$([F:LOA]ORNVCR)-num$([F:LOA]LIN)-num$([F:LOA]ANALIN),1) From DOSDIC
    Endif
   Next

   NB+=1
   If NB>GMAXUPDTRS 
    ACLE1 = [F:LOT]CPY
    ACLE2 = [F:LOH]LOT
    ICLE1 = [F:LOD2]ORNVCR
    ICLE2 = [F:LOD2]LIG
    STOP=1
    Break 2
   Endif
  Next
 Else
  # Pas de société... pas de migration possible pour les pièces
  GOK = 0 : Call ERREUR("GENTLOTD"-[F:LOT]CPY-mess(16,104,1),4) From DOSDIC
 Endif 
Next
#Pas de Rollback
#If GOK<1 : Rollback
#Else     : Commit
#Endif
Commit

If STOP
 Goto LOOP_LOT
Endif
Gosub UNSET_FIRST From TRTFIRST
Close Local File [LOT], [LOH], [LOD], [LOA], [LOD2], [LOA2], [GCM], [LED], [CPY]
Return

$DELETE_LOD
Call ECR_TIME(mess(81,125,1)-": GENTLOTD-GENTLOTA (2/2)") From DOSSUB : # maj table

Local File =[F:ADS]DOSSIER+".GENTLOTD"   [LOD]         # Ligne générale de lot
Local File =[F:ADS]DOSSIER+".GENTLOTA"   [LOA]         # Ligne analytique de lot
Trbegin [LOD]
Delete [LOD] Where LIN<1
If fstat
 GOK = 0 : Call ERREUR("GENTLOTD",3) From DOSDIC
Endif
Commit

Trbegin [LOA]
Delete [LOA] Where LIN<1
If fstat
 GOK = 0 : Call ERREUR("GENTLOTA",3) From DOSDIC
Endif
Commit

Close Local File [LOD], [LOA]
Return

##-------------------------------------------------------------------------------------------------------#
$BUD
##-------------------------------------------------------------------------------------------------------#

# Mise à jour des tables V6
Local File =[F:ADS]DOSSIER+".BUD"         [BUD]         # Budget
Local File =[F:ADS]DOSSIER+".BUDPAR"      [BUP]         # Paramètrage budget
Local File =[F:ADS]DOSSIER+".CACNA"       [CNA]         # Natures

Local File =[F:ADS]DOSSIER+".GACM"        [GCM]         # Modèles comptables 
Local File =[F:ADS]DOSSIER+".GLED"        [LED]         # Référentiels
Local File =[F:ADS]DOSSIER+".COMPANY"     [CPY]         # Sociétés
Local File =[F:ADS]DOSSIER+".FACILITY"    [FCY]         # Sites

Local Char    COAANA(30)
Local Char    LEDANA(3)
Local Integer TYPANA

Call ECR_TIME(mess(81,125,1)-": BUD ") From DOSSUB : # maj table

Gosub SET_FIRST From TRTFIRST
Raz STOP, CRITERE
$LOOP_BUD
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "BUD='"+ACLE1+"' & FCY='"+ACLE2+"' & FIY="+num$(ICLE1)+" & CNA='"+ACLE3+"'"+" & CCE1='"+ACLE4+"'"+" & CCE2='"+ACLE5+"'"+" & CCE3>'"+ACLE6+"'"
Elsif STOP=2
 STOP = 3
 CRITERE = "BUD='"+ACLE1+"' & FCY='"+ACLE2+"' & FIY="+num$(ICLE1)+" & CNA='"+ACLE3+"'"+" & CCE1='"+ACLE4+"'"+" & CCE2>'"+ACLE5+"'"
Elsif STOP=3
 STOP = 4
 CRITERE = "BUD='"+ACLE1+"' & FCY='"+ACLE2+"' & FIY="+num$(ICLE1)+" & CNA='"+ACLE3+"'"+" & CCE1>'"+ACLE4+"'"
Elsif STOP=4
 STOP = 5
 CRITERE = "BUD='"+ACLE1+"' & FCY='"+ACLE2+"' & FIY="+num$(ICLE1)+" & CNA>'"+ACLE3+"'"
Elsif STOP=5
 STOP = 6
 CRITERE = "BUD='"+ACLE1+"' & FCY='"+ACLE2+"' & FIY>"+num$(ICLE1)
Elsif STOP=6
 STOP = 7
 CRITERE = "BUD='"+ACLE1+"' & FCY>'"+ACLE2+"'"
Elsif STOP=7
 STOP = 0
 CRITERE = "BUD>'"+ACLE1+"'" 
Else
 CRITERE = "1=1"
Endif

Trbegin [BUD]
GOK = 1

For [BUD] Where evalue(CRITERE)

 Raz COAANA
 If [F:FCY]FCY <> [F:BUD]FCY
  Read [FCY]FCY0 = [F:BUD]FCY
  If !fstat
   If [F:CPY]CPY <> [F:FCY]LEGCPY
    Read [CPY]CPY0 = [F:FCY]LEGCPY
   Endif
  Else
   If [F:CPY]CPY <> [F:BUD]FCY
    Read [CPY]CPY0 = [F:BUD]FCY
   Endif
  Endif
 Endif
 If [F:CPY]ACM <> [F:GCM]GCM
  Read [F:GCM]GCM0 = [F:CPY]ACM
 Endif

 If  [F:GCM]LED(1)<>""
  Read [F:LED]LED0 = [F:GCM]LED(1)
  COAANA = [F:LED]COA
  LEDANA = [F:GCM]LED(1)
  TYPANA = 2
 Else
  If [F:GCM]ANALEDTYP=0
   If [F:BUD]FCY=""
    TYPANA = 0 : Call ERREUR("BUD"-mess(15,104,1),4) From DOSDIC
   Else 
    # Erreur de lecture - Modèle comptable inexistant
    TYPANA = 0 : Call ERREUR("BUD-"-mess(3,45,1)-[F:BUD]FCY-"-"-mess(5,618,1)-[F:CPY]ACM-"-"-mess(198,105,1),4) From DOSDIC
   Endif
  Else
   Read [F:LED]LED0 = [F:GCM]LED([F:GCM]ANALEDTYP-1)
   COAANA = [F:LED]COA
   LEDANA = [F:GCM]LED([F:GCM]ANALEDTYP-1)
   TYPANA = [F:GCM]ANALEDTYP
  Endif
 Endif

 If [F:BUP]BUD<>[F:BUD]BUD
  Read [BUP]BUP0 = [F:BUD]BUD
 Endif

 If [F:BUD]CNA<>[F:CNA]CNA
  Read [CNA]CNA0 = [F:BUD]CNA
 Endif

 If [F:BUP]LEV=1
  Raz [F:BUD]FCY
 Endif
 
 ## Nouveaux champs
 [F:BUD]CPY    = [F:CPY]CPY
 [F:BUD]LEDTYP = [L]TYPANA
 [F:BUD]VER    = "1"
 [F:BUD]LED    = [L]LEDANA
 [F:BUD]COA    = [L]COAANA
 [F:BUD]ACC    = [F:BUD]CNA
 If [F:BUD]AXI1>0 : [F:BUD]DIE1   = "AX"+num$([F:BUD]AXI1) : Endif
 If [F:BUD]AXI2>0 : [F:BUD]DIE2   = "AX"+num$([F:BUD]AXI2) : Endif
 If [F:BUD]AXI3>0 : [F:BUD]DIE3   = "AX"+num$([F:BUD]AXI3) : Endif
 
 [F:BUD]CUR    = [F:BUP]CUR
 [F:BUD]UOM    = [F:CNA]UOM

 Call ACCNUM_BUD([F:BUD]ACCNUM)  # Il faut générer un ACCNUM

 Rewrite [BUD]
 If fstat
  GOK = 0 : Call ERREUR("BUD"-[F:BUD]BUD-[F:BUD]FCY-num$([F:BUD]FIY)-[F:BUD]CNA-[F:BUD]CCE1-[F:BUD]CCE2-[F:BUD]CC3,1) From DOSDIC
 Endif

  NB+=1
  If NB>GMAXUPDTRS 
   ACLE1 = [F:BUD]BUD
   ACLE2 = [F:BUD]FCY
   ICLE1 = [F:BUD]FIY
   ACLE3 = [F:BUD]CNA
   ACLE4 = [F:BUD]CCE1
   ACLE5 = [F:BUD]CCE2
   ACLE6 = [F:BUD]CCE3
   STOP=1
   Break 
  Endif
Next

#Pas de Rollback
#If GOK<1 : Rollback
#Else     : Commit
#Endif
Commit

If STOP
 Goto LOOP_BUD
Endif
Gosub UNSET_FIRST From TRTFIRST

Close Local File [BUD], [BUP], [CNA], [GCM], [LED], [CPY], [FCY]
Return

##-------------------------------------------------------------------------------------------------------#
Subprog ACCNUM_BUD(NUMERO)
Variable Integer NUMERO
Local File =[F:ADS]DOSSIER+".BUD" [BUD]
NUMERO = uniqid([F:BUD])
End

##-------------------------------------------------------------------------------------------------------#
$BUDOD
##-------------------------------------------------------------------------------------------------------#

# Mise à jour des tables V6
Local File =[F:ADS]DOSSIER+".BUDOD"       [BDE]         # OD Budgetaire (En-tête)
Local File =[F:ADS]DOSSIER+".BUDODS"      [BDO]         # OD Budgétaire (Ligne)

Local File =[F:ADS]DOSSIER+".GACM"        [GCM]         # Modèles comptables 
Local File =[F:ADS]DOSSIER+".GLED"        [LED]         # Référentiels
Local File =[F:ADS]DOSSIER+".COMPANY"     [CPY]         # Sociétés
Local File =[F:ADS]DOSSIER+".FACILITY"    [FCY]         # Sites
Local File =[F:ADS]DOSSIER+".BUDPAR"      [BUP]         # Paramètrage budget

Local Char    COAANA(30)
Local Char    LEDANA(3)
Local Integer TYPANA

Call ECR_TIME(mess(81,125,1)-": BUDOD ") From DOSSUB : # maj table

Gosub SET_FIRST From TRTFIRST
Raz STOP, CRITERE
$LOOP_BDO
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "NUM='"+ACLE1+"' & LINNUM>"+num$(ICLE1)
Elsif STOP=2
 STOP = 0
 CRITERE = "NUM>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [BDO], [BDE]
GOK = 1

For [BDO] Where evalue(CRITERE)

 Raz COAANA
 If [F:FCY]FCY <> [F:BDO]FCY
  Read [FCY]FCY0 = [F:BDO]FCY
  If !fstat
   If [F:CPY]CPY <> [F:FCY]LEGCPY
    Read [CPY]CPY0 = [F:FCY]LEGCPY
   Endif
  Else
   If [F:CPY]CPY <> [F:BDO]FCY
    Read [CPY]CPY0 = [F:BDO]FCY
   Endif
  Endif
 Endif
 
 If [F:CPY]ACM <> [F:GCM]GCM
  Read [F:GCM]GCM0 = [F:CPY]ACM
 Endif

 If  [F:GCM]LED(1)<>""
  Read [F:LED]LED0 = [F:GCM]LED(1)
  COAANA = [F:LED]COA
  LEDANA = [F:GCM]LED(1)
  TYPANA = 2
 Else
  If [F:GCM]ANALEDTYP=0
   If [F:BUD]FCY=""
    TYPANA = 0 : Call ERREUR("BUDOD"-mess(15,104,1),4) From DOSDIC
   Else 
    # Erreur de lecture - Modèle comptable inexistant
    TYPANA = 0 : Call ERREUR("BUDOD-"-mess(3,45,1)-[F:BDO]FCY-"-"-mess(5,618,1)-[F:CPY]ACM-"-"-mess(198,105,1),4) From DOSDIC
   Endif
  Else
   Read [F:LED]LED0 = [F:GCM]LED([F:GCM]ANALEDTYP-1)
   COAANA = [F:LED]COA
   LEDANA = [F:GCM]LED([F:GCM]ANALEDTYP-1)
   TYPANA = [F:GCM]ANALEDTYP
  Endif
 Endif

 ## Nouveaux champs
 [F:BDO]CPY    = [F:CPY]CPY
 [F:BDO]LEDTYP = [L]TYPANA
 [F:BDO]LED    = [L]LEDANA
 [F:BDO]COA    = [L]COAANA
 [F:BDO]ACC    = [F:BDO]CNA
 If [F:BDO]AXI1>0 : [F:BDO]DIE1   = "AX"+num$([F:BDO]AXI1) : Endif
 If [F:BDO]AXI2>0 : [F:BDO]DIE2   = "AX"+num$([F:BDO]AXI2) : Endif
 If [F:BDO]AXI3>0 : [F:BDO]DIE3   = "AX"+num$([F:BDO]AXI3) : Endif

 [F:BDO]LIN    = [F:BDO]LINNUM

 If [F:BUP]BUD<>[F:BDO]BUD
  Read [BUP]BUP0 = [F:BDO]BUD
 Endif

 If [F:BUP]LEV=1
  Raz [F:BDO]FCY
 Endif

 Rewrite [BDO]
 If fstat
  GOK = 0 : Call ERREUR("BUDODS"-[F:BDO]NUM-num$([F:BDO]LINNUM),1) From DOSDIC
 Endif

 If [F:BDO]LINNUM=1
  Update [F:BDE] Where NUM=[F:BDO]NUM With [F:BDE]VER="1", [F:BDE]BUD=[F:BDO]BUD
  If fstat
   GOK = 0 : Call ERREUR("BUDOD"-[F:BDE]NUM,1) From DOSDIC
  Endif
 Endif

 NB+=1
 If NB>GMAXUPDTRS 
  ACLE1 = [F:BDO]NUM
  ICLE1 = [F:BDO]LINNUM
  STOP=1
  Break
 Endif
Next

#Pas de Rollback
#If GOK<1 : Rollback
#Else     : Commit
#Endif
Commit

If STOP
 Goto LOOP_BDO
Endif
Gosub UNSET_FIRST From TRTFIRST

Close Local File [BDE], [BDO], [GCM], [LED], [CPY], [FCY], [BUP]

Return


